    <JadeMethod name="setForCreate" id="4a6c67c6-b400-416d-95ad-bfea9901f35a">
        <updating/>
        <source>setForCreate(_pxyRole : CM_SecurityRole) updating;
// ---------------------------------------------------------------------------
// Created:			27 March 2001 by cnwdwq1
// Purpose:			!     
// Parameters:	None
// Returns:			Nothing
// Changed On	Changed By		Reason
// ----------	----------		--------------------------------------------------
// 22/03/2018	jlgdap1			TFS 37445 PEL1 Voyage Status Security
// 02/11/2022 	navds20 		ChangeRequest 54253: EUP - VAS Work Orders
// ---------------------------------------------------------------------------
// Auditing of individual property values is not required on a create.
vars

begin
	self.name 			:= _pxyRole.name;
	self.myParentRole 	:= _pxyRole.myParentRole;

	self.permissions.clear;
	_pxyRole.permissions.copy(self.permissions);

	self.mySecurityRoleVisibility.setForUpdate(_pxyRole.mySecurityRoleVisibility.availableToShippingCompany);

	self.allToDoTasksAddRemove.clear;
	_pxyRole.allToDoTasksAddRemove.copy(self.allToDoTasksAddRemove);

	self.allToDoTasksComplete.clear;
	_pxyRole.allToDoTasksComplete.copy(self.allToDoTasksComplete);

	self.allStopsView.clear;
	_pxyRole.allStopsView.copy(self.allStopsView);

	self.allStopsMaint.clear;
	_pxyRole.allStopsMaint.copy(self.allStopsMaint);
	
	self.allStopsCancel.clear();
	_pxyRole.allStopsCancel.copy(self.allStopsCancel);
	
	self.allQryReports.clear;
	_pxyRole.allQryReports.copy(self.allQryReports);

	self.allTransactionTypesForEvents.clear;
	_pxyRole.allTransactionTypesForEvents.copy(self.allTransactionTypesForEvents);	
	
	self.allVoyageStatusesMaint.clear;										// TFS 37445
	_pxyRole.allVoyageStatusesMaint.copy(self.allVoyageStatusesMaint);		// TFS 37445

	self.allInvoiceStatusesMaint.clear;										// TFS 39618
	_pxyRole.allInvoiceStatusesMaint.copy(self.allInvoiceStatusesMaint); 	// TFS 39618

	self.allVolumeDiscrepancyReasons.clear();								// 2/5/19 MAP TFS41707
	_pxyRole.allVolumeDiscrepancyReasons.copy(self.allVolumeDiscrepancyReasons);
	
	self.allWorkOrderStatusMaint.clear;										//02/11/2022 navds20 TFS 54253
	_pxyRole.allWorkOrderStatusMaint.copy(self.allWorkOrderStatusMaint);	//02/11/2022 navds20 TFS 54253
	
	self.setEventTypes( _pxyRole.allEventTypes );							//09 Mar 2020	NDL	TFS 48784

	self.myRoot := _pxyRole.myRoot;

end;</source>
        <Parameter name="_pxyRole" type="CM_SecurityRole"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="9272a847-ead0-45cf-a53f-53b9dc7e46b6">
        <updating/>
        <source>setForUpdate(_pxyRole : CM_SecurityRole) updating;
// ---------------------------------------------------------------------------
// Created:			27 March 2001 by cnwdwq1
// Purpose:			!     
// Parameters:	None
// Returns:			Nothing
// Changed On	Changed By		Reason
// ----------	----------		--------------------------------------------------
// 22/03/2018	jlgdap1			TFS 37445 PEL1 Voyage Status Security
// 02/11/2022 	navds20 		ChangeRequest 54253: EUP - VAS Work Orders
// ---------------------------------------------------------------------------
vars
	i 		: Integer;
	userTerm	: CM_UserTerminal;
	child		: CM_SecurityRole;

begin
	// Lock self before comparing values to ensure we have the latest edition.
	// We assume that we're called within a transaction, so the lock will be
	// released at commit/abort transaction.
	exclusiveLock(self);
	
	self.name			:= _pxyRole.name;
	self.myParentRole 	:= _pxyRole.myParentRole;

	if _pxyRole.permissions.isEmpty then
		app.myAA.auditUpdate(self, "permissions", self.permissions);
		self.permissions.clear;
	else
		if self.permissions.size &lt;&gt; _pxyRole.permissions.size then
			app.myAA.auditUpdate(self, "permissions", self.permissions);
			self.permissions.clear;
			_pxyRole.permissions.copy(self.permissions);
		else
			foreach i in 1 to self.permissions.size do
				if self.permissions[i] &lt;&gt; _pxyRole.permissions[i] then
					app.myAA.auditUpdate(self, "permissions", self.permissions);
					self.permissions.clear;
					_pxyRole.permissions.copy(self.permissions);
					break;
				endif;
			endforeach;
		endif;
	endif;

	if self.mySecurityRoleVisibility = null then
		create self.mySecurityRoleVisibility persistent;	
	endif;

	self.mySecurityRoleVisibility.setForUpdate(_pxyRole.mySecurityRoleVisibility.availableToShippingCompany);

	self.allToDoTasksAddRemove.clear;
	_pxyRole.allToDoTasksAddRemove.copy(self.allToDoTasksAddRemove);

	self.allToDoTasksComplete.clear;
	_pxyRole.allToDoTasksComplete.copy(self.allToDoTasksComplete);

	self.allStopsView.clear;
	_pxyRole.allStopsView.copy(self.allStopsView);
	
	self.allStopsMaint.clear;
	_pxyRole.allStopsMaint.copy(self.allStopsMaint);
	
// cnwdad1 03/06/2010 - CCMS 1129.
	self.allStopsCancel.clear();
	_pxyRole.allStopsCancel.copy(self.allStopsCancel);
	
	self.allQryReports.clear;
	_pxyRole.allQryReports.copy(self.allQryReports);

	self.allTransactionTypesForEvents.clear;
	_pxyRole.allTransactionTypesForEvents.copy(self.allTransactionTypesForEvents);	
		
	foreach userTerm in self.allUserTerminals do
		userTerm.checkNavMenuAgainstPermissions(false);
		userTerm.checkReportMenuAgainstSecurity();
	endforeach;

	foreach child in self.allChildRoles do
		child.updateFromParent(null);
	endforeach;

	//13 Feb 2018	NDL	TFS 36947
	self.allChildMaintenanceRoles.clear();
	if not _pxyRole.allChildMaintenanceRoles.isEmpty then
		_pxyRole.allChildMaintenanceRoles.copy( self.allChildMaintenanceRoles );
	endif;
	
	self.allVoyageStatusesMaint.clear;										 // TFS 37445
	_pxyRole.allVoyageStatusesMaint.copy(self.allVoyageStatusesMaint);		 // TFS 37445

	self.allInvoiceStatusesMaint.clear;										 // TFS 39618
	_pxyRole.allInvoiceStatusesMaint.copy(self.allInvoiceStatusesMaint);	 // TFS 39618
	
	self.allVolumeDiscrepancyReasons.clear();										// 2/5/19 MAP TFS41707
	_pxyRole.allVolumeDiscrepancyReasons.copy(self.allVolumeDiscrepancyReasons);
	
	self.allWorkOrderStatusMaint.clear;												//02/11/2022 navds20 TFS 54253
	_pxyRole.allWorkOrderStatusMaint.copy(self.allWorkOrderStatusMaint);			//02/11/2022 navds20 TFS 54253
	
	self.setEventTypes( _pxyRole.allEventTypes );									//09 Mar 2020	NDL	TFS 48784

end;</source>
        <Parameter name="_pxyRole" type="CM_SecurityRole"/>
    </JadeMethod>
    <JadeMethod name="setFromClone" id="4e667813-a29a-47cc-98e6-3bb9da8dc0b9">
        <updating/>
        <source>setFromClone(_oldRole : CM_SecurityRole io) updating;
// ---------------------------------------------------------------------------
// Created:     19 February 2003 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 22/03/2018	jlgdap1		TFS 37445 PEL1 Voyage Status Security
// 02/11/2022   navds20     ChangeRequest 54253: EUP - VAS Work Orders
// ---------------------------------------------------------------------------
vars
	secRoleVis	: CM_SecurityRoleVisibility;
	ao			: CM_AuditObject;
	ut			: CM_UserTerminal;
	
begin

	foreach ao in _oldRole.allAuditObjectsForClass do	//21 Jan 2021	NDL	TFS 50152
		ao.setPropertyValue('mySubject', self);
	endforeach;

	_oldRole.allQryReports.copy(self.allQryReports);
	_oldRole.allStopsMaint.copy(self.allStopsMaint);
	_oldRole.allStopsCancel.copy(self.allStopsCancel);								// cnwdad1 03/06/2010 - CCMS 1129.
	_oldRole.allStopsView.copy(self.allStopsView);
	_oldRole.allToDoTasksAddRemove.copy(self.allToDoTasksAddRemove);
	_oldRole.allToDoTasksComplete.copy(self.allToDoTasksComplete);
	_oldRole.allTransactionTypesForEvents.copy(self.allTransactionTypesForEvents);	// 14/7/17 MAP TFS4846
	_oldRole.allVoyageStatusesMaint.copy(self.allVoyageStatusesMaint);				// TFS 37445
	_oldRole.allInvoiceStatusesMaint.copy(self.allInvoiceStatusesMaint);			// TFS 39618
	_oldRole.allWorkOrderStatusMaint.copy(self.allWorkOrderStatusMaint); 			//02/11/2022 navds20 TFS 54253
	self.setEventTypes( _oldRole.allEventTypes );									//09 Mar 2020	NDL	TFS 48784

	foreach ut in _oldRole.allUserTerminals do
		ut.setPropertyValue('mySecurityRole', self);
	endforeach;
	
	secRoleVis := _oldRole.mySecurityRoleVisibility;
	_oldRole.setPropertyValue('mySecurityRoleVisibility', null);

	_oldRole.permissions.copy(self.permissions);

	_oldRole.setPropertyValue('name', _oldRole.name &amp; '2');
	
	delete _oldRole;

	self.mySecurityRoleVisibility := secRoleVis;
	self.myRoot := CM_Root.firstInstance;
	
	self.myParentRole := CM_SecurityRoleTerminalRoot.firstInstance;
	
end;</source>
        <Parameter name="_oldRole" type="CM_SecurityRole" usage="io"/>
    </JadeMethod>
    <JadeMethod name="setMyRoot" id="55fa1374-f4e2-4785-a943-0267d4db4b5e">
        <updating/>
        <source>setMyRoot() updating;
// ---------------------------------------------------------------------------
// Created:     04 July 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	self.myRoot := app.myRoot;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="setPermissionsFromIntArray" id="b3eb02a5-5827-4c22-b533-a0c9fed8ea48">
        <source>setPermissionsFromIntArray(_permNoArray : IntegerArray; _permValue : Boolean);
// ---------------------------------------------------------------------------
// Created:     12 February 2003		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	permNo			: Integer;
begin
	foreach permNo in _permNoArray do
		self.permissions[permNo] := _permValue;
	endforeach;
end;</source>
        <Parameter name="_permNoArray" type="IntegerArray"/>
        <Parameter name="_permValue" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="549a6c42-b147-44d5-9875-2a61a83b2985">
        <updating/>
        <source>setProxy(_name : String; _parentRole : CM_SecurityRole;
			_permissions : BooleanArray; 
			_availToShipCo : Boolean; 
			_root : CM_Root; 
			_todoTasksAddRemove,
			_todoTasksComplete : CM_ToDoTaskDescArray;
			_stopTablesView : CM_StopsTableByIdDict;
			_stopTablesMaint : CM_StopsTableByIdDict;
			_stopTablesDelete : CM_StopsTableByIdDict;
			_rptDict : CM_QryReportDict;
			_tranTypeDict : CM_TransactionTypeByType;
			_statuses : CM_VoyageStatusById;			// TFS 37445 // TFS 39618
			_invoiceStatuses : CM_InvoiceStatusById;	// TFS 39618
			_volDescReasons: CM_VolumeDiscrepReasonsByCode;
			_eventTypes	: CM_EventTypeByTypeDict;	//09 Mar 2020	NDL	TFS 48784
			_workOrderStatus : CMIF_WOStatusAgent	//31/10/2022 navds20 TFS 54253
			) updating; 
// ---------------------------------------------------------------------------
// Created:			27 March 2001 by cnwdwq1
// Purpose:			!     
// Parameters:	None
// Returns:			Nothing
// Changed On	Changed By	Reason
// ----------	----------	--------------------------------------------------
// 03/06/2010	cnwdad1		CCMS 1129 - Added _stopTablesDelete parameter.
// 22/03/2018	jlgdap1		TFS 37445 PEL1 Voyage Status Security
// 31/10/2022 	navds20 	ChangeRequest 54253: EUP - VAS Work Orders
// ---------------------------------------------------------------------------
// Auditing of individual property values is not required on a create.
vars
	len			    : Integer;
	workOrderStatus : CMIF_WOStatusAgent; 
	intArr		    : IntegerArray;	
begin
	
	// test incoming name length since name property has a finite length RDD 22/8/2001 PAR 1323 POT 2001/169
	if _name.length &gt; self.name.maxLength then
		app.raiseCMException2(ERR_STRING_TO_LONG, 'name', self.name.maxLength.String, ETRow_Name, null);
	else
		self.name := _name;
	endif;

	self.myParentRole := _parentRole;

	self.permissions.clear; // in case this is called other than on a create (shouldn't be!)
	if _permissions &lt;&gt; null then
		_permissions.copy(self.permissions);
	endif;

	if self.mySecurityRoleVisibility = null then
		create self.mySecurityRoleVisibility transient;
	endif;
	
	self.mySecurityRoleVisibility.setForUpdate(_availToShipCo);

	self.allToDoTasksAddRemove.clear;
	if _todoTasksAddRemove &lt;&gt; null then
		_todoTasksAddRemove.copy(self.allToDoTasksAddRemove);
	endif;

	self.allToDoTasksComplete.clear;
	if _todoTasksComplete &lt;&gt; null then
		_todoTasksComplete.copy(self.allToDoTasksComplete);
	endif;

	self.allStopsView.clear;
	if _stopTablesView &lt;&gt; null then
		_stopTablesView.copy(self.allStopsView);
	endif;

	self.allStopsMaint.clear;
	if _stopTablesMaint &lt;&gt; null then
		_stopTablesMaint.copy(self.allStopsMaint);
	endif;
	
	//start 31/10/2022 navds20 TFS 54253
	self.allWorkOrderStatusMaint.clear;
	if _workOrderStatus &lt;&gt; null and _workOrderStatus.allWoStatusItems &lt;&gt; null then
		create intArr transient;
		_workOrderStatus.getIntegerArr(_workOrderStatus.allWoStatusItems,intArr);
		intArr.copy(self.allWorkOrderStatusMaint);
	endif;
	//end 31/10/2022 navds20 TFS 54253
	
	// cnwdad1 03/06/2010 - CCMS 1129.
	self.allStopsCancel.clear();
	if _stopTablesDelete &lt;&gt; null then
		_stopTablesDelete.copy(self.allStopsCancel);
	endif;
	
	self.allQryReports.clear;
	if _rptDict &lt;&gt; null then
		_rptDict.copy(self.allQryReports);
	endif;
	
	self.allTransactionTypesForEvents.clear();
	if _tranTypeDict &lt;&gt; null then
		_tranTypeDict.copy(self.allTransactionTypesForEvents);
	endif;
	
	self.allVoyageStatusesMaint.clear;						// TFS 37445
	if _statuses &lt;&gt; null then								// TFS 37445
		_statuses.copy(self.allVoyageStatusesMaint);		// TFS 37445
	endif;													// TFS 37445

	self.allInvoiceStatusesMaint.clear;						 // TFS 39618
	if _invoiceStatuses &lt;&gt; null then						 // TFS 39618
		_invoiceStatuses.copy(self.allInvoiceStatusesMaint); // TFS 39618
	endif;													 // TFS 39618
	
	self.allVolumeDiscrepancyReasons.clear();				// 2/5/19 MAP TFS41707
	if _volDescReasons &lt;&gt; null then
		_volDescReasons.copy(self.allVolumeDiscrepancyReasons);
	endif;
	
	self.setEventTypes( _eventTypes );						//09 Mar 2020	NDL	TFS 48784

	self.myRoot := _root;
epilog
	delete intArr;											//02/11/2022 navds20 TFS 54253
end;</source>
        <Parameter name="_name" type="String"/>
        <Parameter name="_parentRole" type="CM_SecurityRole"/>
        <Parameter name="_permissions" type="BooleanArray"/>
        <Parameter name="_availToShipCo" type="Boolean"/>
        <Parameter name="_root" type="CM_Root"/>
        <Parameter name="_todoTasksAddRemove" type="CM_ToDoTaskDescArray"/>
        <Parameter name="_todoTasksComplete" type="CM_ToDoTaskDescArray"/>
        <Parameter name="_stopTablesView" type="CM_StopsTableByIdDict"/>
        <Parameter name="_stopTablesMaint" type="CM_StopsTableByIdDict"/>
        <Parameter name="_stopTablesDelete" type="CM_StopsTableByIdDict"/>
        <Parameter name="_rptDict" type="CM_QryReportDict"/>
        <Parameter name="_tranTypeDict" type="CM_TransactionTypeByType"/>
        <Parameter name="_statuses" type="CM_VoyageStatusById"/>
        <Parameter name="_invoiceStatuses" type="CM_InvoiceStatusById"/>
        <Parameter name="_volDescReasons" type="CM_VolumeDiscrepReasonsByCode"/>
        <Parameter name="_eventTypes" type="CM_EventTypeByTypeDict"/>
        <Parameter name="_workOrderStatus" type="CMIF_WOStatusAgent"/>
    </JadeMethod>
    <JadeMethod name="setWOStatus" id="2e86f247-495b-4f4b-b48f-46e700f37b48">
        <source>setWOStatus();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 Oct 2022 navds20 ChangeRequest 54253: EUP - VAS Work Orders

*/

vars

begin
	self.allWorkOrderStatusMaint.add(WO_STATUS_USERENTRY);
	self.allWorkOrderStatusMaint.add(WO_STATUS_PENDING);
	self.allWorkOrderStatusMaint.add(WO_STATUS_NOTAPPROVED);
	self.allWorkOrderStatusMaint.add(WO_STATUS_APPROVED);
	self.allWorkOrderStatusMaint.add(WO_STATUS_PARTCOMPLETE);
	self.allWorkOrderStatusMaint.add(WO_STATUS_COMPLETE);
	self.allWorkOrderStatusMaint.add(WO_STATUS_PENDING_CANCEL);
	self.allWorkOrderStatusMaint.add(WO_STATUS_CANCELLED);
	self.allWorkOrderStatusMaint.add(WO_STATUS_PENDING_HOLD);
	self.allWorkOrderStatusMaint.add(WO_STATUS_HELD);
	self.allWorkOrderStatusMaint.add(WO_STATUS_PENDING_FIN);
	self.allWorkOrderStatusMaint.add(WO_STATUS_REJECTED_FIN);
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="updateFromParent" id="71e8660c-3622-4bde-ac45-85af7cbea975">
        <updating/>
        <source>updateFromParent(_cmifMonitor : CMIF_Monitor input) updating;
// ---------------------------------------------------------------------------
// Created:     21 February 2003 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	child		: CM_SecurityRole;
	userTerm	: CM_UserTerminal;

begin
	self.validatePermissions(null, false);	
	self.validateQryReports(false);
	
	if self.myParentRole &lt;&gt; null then
		self.validateStops(self.allStopsMaint, self.myParentRole.allStopsMaint, false);
		self.validateStops(self.allStopsCancel, self.myParentRole.allStopsCancel, false);		// cnwdad1 03/06/2010 - CCMS 1129.
		self.validateStops(self.allStopsView, self.myParentRole.allStopsView, false);
	endif;
	
	self.validateToDoTasks(false);
	
	self.validateEventTypes(false);	//09 Mar 2020	NDL	TFS 48784

	foreach userTerm in self.allUserTerminals do
		userTerm.checkNavMenuAgainstPermissions(false);
		userTerm.checkReportMenuAgainstSecurity();
		
		if _cmifMonitor &lt;&gt; null then
			_cmifMonitor.partsDone := _cmifMonitor.partsDone + 1;
			_cmifMonitor.updateProgress(_cmifMonitor.message,
										_cmifMonitor.partsInJob,
										_cmifMonitor.partsDone);
		endif;
	endforeach;
	
	foreach child in self.allChildRoles do
		child.updateFromParent(_cmifMonitor);
	endforeach;
end;</source>
        <Parameter name="_cmifMonitor" type="CMIF_Monitor" usage="input"/>
    </JadeMethod>
    <JadeMethod name="updateInvoiceStatusPermission" id="0ad03cd2-d92f-4e90-9ae1-264c54aee839">
        <source>updateInvoiceStatusPermission();
/*

Date		Who		Reason
10 November 2015	cnwer1	Initial creation PAR

*/


vars
	childRole,
	pxySecurityRole : CM_SecurityRole;
	permissionAgent	: CM_PermissionAgent;
	canUpdateInvoiceLines  : Boolean;
begin

	

	create permissionAgent transient;
	canUpdateInvoiceLines:=self.canDo(PmAdmInvoicelistMaint);
	beginLoad;
		pxySecurityRole := self.pxyCreateUpdateProxy();
	endLoad;
// TFS 39618 PATCH 1 	pxySecurityRole.permissions[PmAdmInvoiceStatusPost]:=canUpdateInvoiceLines;
// TFS 39618 PATCH 1 	pxySecurityRole.permissions[PmAdmInvoiceStatusVoid]:=canUpdateInvoiceLines;
	pxySecurityRole.permissions[PmAdmInvoiceLineStatusVoid]:=canUpdateInvoiceLines;
	pxySecurityRole.permissions[PmAdmInvoiceLineStatusNormal]:=canUpdateInvoiceLines;
	app.myTrxUA.trxUpdateSecurityRole(pxySecurityRole, permissionAgent, app.myPassport);
	
	foreach childRole in self.allChildRoles do
		childRole.updateInvoiceStatusPermission();
	endforeach;
epilog
	delete permissionAgent;
	delete pxySecurityRole;

end;</source>
    </JadeMethod>
    <JadeMethod name="updateNewPermission" id="597d82a0-6112-4100-b667-73fc3031e42f">
        <source>updateNewPermission(_newPermission : Integer);
/*

Date		Who		Reason
08/06/2016	cnwer1	Initial creation tfs 2011
05/10/2017	jlgdap1	TFS 7278 / TFS 7395 PKT System Role permissions being removed by upgrade
*/

vars
	childRole,
	pxySecurityRole : CM_SecurityRole;
	permissionAgent	: CM_PermissionAgent;
begin

	create permissionAgent transient;
	permissionAgent.populatePermissionDict(true, true, 0);			// TFS 7278 / TFS 7395
	beginLoad;
		pxySecurityRole := self.pxyCreateUpdateProxy();
	endLoad;
	pxySecurityRole.permissions[_newPermission]:=true;
	app.myTrxUA.trxUpdateSecurityRole(pxySecurityRole, permissionAgent, app.myPassport);
	
	foreach childRole in self.allChildRoles do
		childRole.updateNewPermission(_newPermission);
	endforeach;
epilog
	delete permissionAgent;
	delete pxySecurityRole;
end;</source>
        <Parameter name="_newPermission" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="updatePermissionsForChildren" id="2a4706f1-f56f-46ff-92bc-4721add7a6a5">
        <source>updatePermissionsForChildren(_parent : CM_SecurityRole);
// ---------------------------------------------------------------------------
// Created:     18 February 2003 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	rowsSelf,
	rowsParent,
	idx			: Integer;
	permSelf	: Boolean;

begin

	rowsSelf	:= self.permissions.size;
	rowsParent	:= _parent.permissions.size;
	
	foreach permSelf in self.permissions do
		idx := idx + 1;
		if idx &lt;= rowsParent then
			if permSelf and (not _parent.permissions[idx]) then
				self.permissions[idx] := false;
			endif;
		else
			self.permissions[idx] := false;
		endif;
	endforeach;
	
end;</source>
        <Parameter name="_parent" type="CM_SecurityRole"/>
    </JadeMethod>
    <JadeMethod name="validate" id="e85be464-c490-4e2a-babd-dd157dd03a1c">
        <source>validate(_permAgent : CM_PermissionAgent) protected;
// ---------------------------------------------------------------------------
// Created:     20 February 2003 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//14/06/2022 navds20 TFS 53760 DuplicateItem not Translatable
// ---------------------------------------------------------------------------
vars
	tmpRole,
	realRole	: CM_SecurityRole;
	
begin
	if self.name = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'name', ETRow_Name, null);
		app.raiseCMException(Input_required_field_name, ETRow_Name, null); // cnwdb2	PAR 35364
		return;
	endif;
	
	tmpRole := app.myRoot.allRoles[self.name];
	if tmpRole &lt;&gt; null then
		realRole := self.pxyGetRealObject();
		if realRole = null or
		   (realRole &lt;&gt; null and realRole &lt;&gt; tmpRole) then
			//app.raiseCMException2(DuplicateItem, 'A security role', self.name, ETRow_Name, null); //14.06.2022 navds20 53760
			// A security role already exists for %1 : Securit_role_already_exists
			app.raiseCMException1(Securit_role_already_exists, self.name, ETRow_Name, null); //14.06.2022 navds20 53760
		endif;
	endif;

	if self.myParentRole = null and self.name &lt;&gt; "SUPERCLASS" then
	//	app.raiseCMException1(REQUIRED_FIELD, 'parent role', ETRow_MyParentRole, null);
		app.raiseCMException(Input_required_field_parentRol, ETRow_MyParentRole, null); // cnwdb2	PAR 35364
		return;
	endif;

	if _permAgent = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'permission agent', ETRow_Name, null);
		app.raiseCMException(Input_required_field_permAgent, ETRow_Name, null); // cnwdb2	PAR 35364
		return;
	endif;
	
	self.validatePermissions(_permAgent, true);
	
	if self.myParentRole &lt;&gt; null then
		self.validateStops(self.allStopsMaint, self.myParentRole.allStopsMaint, true);
		self.validateStops(self.allStopsCancel, self.myParentRole.allStopsCancel, true);		// cnwdad1 03/06/2010 - CCMS 1129.
		self.validateStops(self.allStopsView, self.myParentRole.allStopsView, true);
	endif;
	
	self.validateToDoTasks(true);
	self.validateQryReports(true);
	self.validateEventTypes(true);	//09 Mar 2020	NDL	TFS 48784
	
end;</source>
        <access>protected</access>
        <Parameter name="_permAgent" type="CM_PermissionAgent"/>
    </JadeMethod>
    <JadeMethod name="validateEventTypes" id="6c04f207-3060-4774-aee3-c681d37781c4">
        <source>validateEventTypes(_giveWarning : Boolean) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 March 2020	jlgndl1	Initial creation

*/

vars
	eventType	: CM_EventType;
	warnParent	: Boolean;

begin

	if self.myParentRole = null then
		return;
	endif;
	
	foreach eventType in self.allEventTypes do
		if (not self.myParentRole.allEventTypes.includes(eventType)) then
			self.allEventTypes.remove(eventType);
			warnParent := true;
		endif;
	endforeach;

	if _giveWarning and warnParent then
		app.raiseCMWarning3(SecRoleItemDisabledOnParent, self.myParentRole.name, self.name, 'Event Types', null, null, self);
	endif;
	
end;</source>
        <access>protected</access>
        <Parameter name="_giveWarning" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="a9bd70ab-d35f-406e-b894-81deaee30313">
        <source>validateForCreate(_permAgent : CM_PermissionAgent);
// ---------------------------------------------------------------------------
// Created:     20 February 2003 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	self.validate(_permAgent);

end;</source>
        <Parameter name="_permAgent" type="CM_PermissionAgent"/>
    </JadeMethod>
    <JadeMethod name="validateForDelete" id="13c22876-afb1-42a2-8fa7-6c2dd219e176">
        <source>validateForDelete();
// ---------------------------------------------------------------------------
// Created:     20 February 2003 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	role	: CM_SecurityRole;

begin

	foreach role in self.allChildRoles do
		role.validateForDelete();
	endforeach;

end;</source>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="48c68ca9-0202-4801-a28d-771bc6dbd75e">
        <source>validateForUpdate(_permAgent : CM_PermissionAgent);
// ---------------------------------------------------------------------------
// Created:     20 February 2003 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	realRole	: CM_SecurityRole;

begin

	self.validate(_permAgent);

	realRole := self.pxyGetRealObject();

	if self.myParentRole &lt;&gt; null then
		if self.myParentRole = realRole then
			app.raiseCMException(Err_ParentRoleCannotBeSelf, ETRow_MyParentRole, null);
		endif;
		
		if self.myParentRole.isChildOf(realRole) then
			app.raiseCMException2(Err_ParentRoleCannotBeChild, self.myParentRole.name, self.name, ETRow_MyParentRole, null);
		endif;
		
		if (self.isSystemSecurityRole and (not self.myParentRole.isSystemSecurityRole)) or
		   ((not self.isSystemSecurityRole) and self.myParentRole.isSystemSecurityRole) then
			app.raiseCMException2(Err_ParentRoleCannotBeDiffType, self.myParentRole.name, self.name, ETRow_MyParentRole, null);
		endif;
	endif;

end;</source>
        <Parameter name="_permAgent" type="CM_PermissionAgent"/>
    </JadeMethod>
    <JadeMethod name="validatePermissions" id="6a75e2d5-2e81-48b7-8504-663057ed91d2">
        <source>validatePermissions(_permAgent : CM_PermissionAgent; _giveWarning : Boolean) protected;
// ---------------------------------------------------------------------------
// Created:     20 February 2003 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	idx,
	numPerm		: Integer;
	warnType,
	warnParent,
	perm		: Boolean;

begin

	if self.myParentRole = null then
		return;
	endif;
	
	numPerm := self.permissions.size;

	foreach idx in 1 to numPerm do
		perm := self.permissions[idx];

		if _permAgent &lt;&gt; null then
			// Validate that only permissions of the correct type are set
			if perm and (self.isSystemSecurityRole &lt;&gt; _permAgent.isSystemPermission(idx)) then
				self.permissions[idx] := false;
				warnType := true;
				continue;
			endif;
		endif;
				
		// Validate that only permssions for the parent are set
		if perm and (not self.myParentRole.canDo(idx)) then
			// turn off permission if parent can't do
			self.permissions[idx] := false;
			// dec 2005 rs1 par 1114 
			// if they are not licensed to use permission suppress the warning that
			// there parent dosn't have access.
			if app.myRoot.canDo(idx) then
				warnParent := true;
			endif;
		endif;
	endforeach;
	
	if _giveWarning and warnType then
		app.raiseCMWarning2(SecRolePermInvalidTypeWarn, self.getRoleTypeString, self.name, null, null, self);
	endif;
	
	if _giveWarning and warnParent then
		app.raiseCMWarning2(SecRolePermDisabledOnParent, self.myParentRole.name, self.name, null, null, self);
	endif;
	
end;</source>
        <access>protected</access>
        <Parameter name="_permAgent" type="CM_PermissionAgent"/>
        <Parameter name="_giveWarning" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateQryReports" id="0de0c2ea-4466-4050-a001-5eaec7969358">
        <source>validateQryReports(_giveWarning : Boolean) protected;
// ---------------------------------------------------------------------------
// Created:     20 February 2003 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	rpt			: CM_QryReport;
	warnParent	: Boolean;

begin

	if self.myParentRole = null then
		return;
	endif;

	foreach rpt in self.allQryReports do
		if (not self.myParentRole.allQryReports.includes(rpt)) then
			app.writeStatement( class.name &amp; '::' &amp; method.name &amp; ' remaining ' &amp; rpt.reportName);
			self.allQryReports.remove(rpt);
			warnParent := true;
		endif;
	endforeach;

	if _giveWarning and warnParent then
		app.raiseCMWarning3(SecRoleItemDisabledOnParent, self.myParentRole.name, self.name, 'report', null, null, self);
	endif;
	
end;</source>
        <access>protected</access>
        <Parameter name="_giveWarning" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateStops" id="89901a61-9303-4d50-8eb1-aeaedd3c8ec4">
        <source>validateStops(_myDict : CM_StopsTableByIdDict input; _parentDict : CM_StopsTableByIdDict; _giveWarning : Boolean) protected;
// ---------------------------------------------------------------------------
// Created:     20 February 2003 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	tmpStopTable	: CM_StopsTable;
	warnParent		: Boolean;

begin

	foreach tmpStopTable in _myDict do
		if (not _parentDict.includes(tmpStopTable)) then
			_myDict.remove(tmpStopTable);
			warnParent := true;
		endif;
	endforeach;

	if _giveWarning and warnParent then
		app.raiseCMWarning3(SecRoleItemDisabledOnParent, self.myParentRole.name, self.name, 'stops', null, null, self);
	endif;
	
end;</source>
        <access>protected</access>
        <Parameter name="_myDict" type="CM_StopsTableByIdDict" usage="input"/>
        <Parameter name="_parentDict" type="CM_StopsTableByIdDict"/>
        <Parameter name="_giveWarning" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateToDoTasks" id="6f8e2dc9-5596-4f93-80cb-5207e82a9f5c">
        <source>validateToDoTasks(_giveWarning : Boolean) protected;
// ---------------------------------------------------------------------------
// Created:     20 February 2003 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	todoTask	: CM_ToDoTaskDesc;
	warnParent	: Boolean;

begin

	if self.myParentRole = null then
		return;
	endif;

	foreach todoTask in self.allToDoTasksAddRemove do
		if (not self.myParentRole.allToDoTasksAddRemove.includes(todoTask)) then
			self.allToDoTasksAddRemove.remove(todoTask);
			warnParent := true;
		endif;
	endforeach;

	foreach todoTask in self.allToDoTasksComplete do
		if (not self.myParentRole.allToDoTasksComplete.includes(todoTask)) then
			self.allToDoTasksComplete.remove(todoTask);
			warnParent := true;
		endif;
	endforeach;

	if _giveWarning and warnParent then
		app.raiseCMWarning3(SecRoleItemDisabledOnParent, self.myParentRole.name, self.name, 'todo tasks', null, null, self);
	endif;
	
end;</source>
        <access>protected</access>
        <Parameter name="_giveWarning" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="zfixupMaintViewPermission" id="b2e293d4-b4d7-4335-818f-a3b505543ab1">
        <updating/>
        <source>zfixupMaintViewPermission(_permNew, _permExisting : Integer; _updateself : Boolean) updating;
/*
Purpose:		TFS 2198	
Date		Who		Reason
12 July 2016	cnwab1	Initial creation
*/

vars
	secrole : CM_SecurityRole;
	size : Integer;
begin

	size := self.permissions.size;
	
	if _updateself  and size &gt;= _permExisting then
		self.permissions[_permNew] := self.permissions[_permExisting];
	endif;
	
	foreach secrole in self.allChildRoles discreteLock do
		secrole.zfixupMaintViewPermission(_permNew, _permExisting, true);
	endforeach;
epilog

end;</source>
        <Parameter name="_permNew" type="Integer"/>
        <Parameter name="_permExisting" type="Integer"/>
        <Parameter name="_updateself" type="Boolean"/>
    </JadeMethod>
</Class>
