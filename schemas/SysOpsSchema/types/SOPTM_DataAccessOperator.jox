<Class name="SOPTM_DataAccessOperator" id="11b21657-25de-4b8b-b5e9-dfa230c3211b">
    <superclass name="SOPTM_DataAccess"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="sysops"/>
    <JadeMethod name="create" id="93321f66-c646-42d3-8dfd-64dab0e76fb2">
        <updating/>
        <source>create() updating;
// ---------------------------------------------------------------------------
// Created:     17 December 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	self.name := SOP_TableMaintForm.Table_DataAccessOperators;
	self.permissionView	 := PmCmpDAOperatorTableView;
	self.permissionMaint := PmCmpDAOperatorTableMaint;

end;</source>
    </JadeMethod>
    <JadeMethod name="getDisplayHeading" id="a6ac03eb-15e4-4012-9b5a-4f50f2b856f7">
        <source>getDisplayHeading(): String;
// ---------------------------------------------------------------------------
// Created:     11 May 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars

begin
	return app.getTerminologyAlternate(null, null, CM_TerminologyOperator, CM_TermExpressionSingular, 'Operator') &amp; ' Data Access Groups';

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getMultiGroupHeading" id="0b5ef3d2-f86a-4974-9df9-acedf9af4cbc">
        <source>getMultiGroupHeading(): String;

// Created by cnwdvb1 on 26 July 2007

vars

begin
	return app.getTerminologyAlternate(null, null, CM_TerminologyOperator, CM_TermExpressionPlural, 'Operators');

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setupThumbnailDetails" id="4f19b045-7645-4229-b0e0-dce7b2ff87f0">
        <source>setupThumbnailDetails();

vars
	theForm : SOP_TableMaintForm;

begin
  
  theForm := self.myForm;
 
	theForm.setupForDataAccessController('Operators', 'displayEntryOperator', CM_Operator);
    theForm.mulSelect1.setAvailable(app.myRoot.allOperators, true);

end;</source>
    </JadeMethod>
    <JadeMethod name="showThumbnail" id="b6561234-78ec-4b9a-ae92-9d477b89a54d">
        <updating/>
        <source>showThumbnail(pDataAccess : CM_DataAccessController) updating;

vars

	theForm : SOP_TableMaintForm;

begin
  
    theForm := self.myForm;
   	theForm.chkIncludeNotSet.visible := true; // AKB2004SEP
	theForm.myDataAccessClass := CM_Operator;
	// par10009
	theForm.shtMultiSelect1.caption := app.getTerminologyAlternate(null, null, CM_TerminologyOperator, CM_TermExpressionSingular, 'Operator');
//	theForm.shtMultiSelect1.caption := "Operator";
	theForm.chkIncludeNotSet.value := pDataAccess.includeIfNull;

	theForm.txtName.text := pDataAccess.name;
	theForm.optAllow.value	:= (not pDataAccess.mustNotBeIncluded);
	theForm.optDisallow.value := pDataAccess.mustNotBeIncluded;
	theForm.setMSHeadingsForDataAccess();
    theForm.mulSelect1.setSelected(pDataAccess.allObjects);
	self.disableMulSelect1Contents();
end;</source>
        <Parameter name="pDataAccess" type="CM_DataAccessController"/>
    </JadeMethod>
    <JadeMethod name="tblDataDisplayRow" id="7be85908-13cc-4cd8-9ba4-2494cdd8476d">
        <source>tblDataDisplayRow(table: Table input; obj: Object): String;

vars
begin
	if obj.CM_DataAccessController.classContainedName = CM_Operator.name then //7.3.09 cnwgb1 PAR 19041
		return inheritMethod(table, obj);
	else
		return null;
	endif;
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="obj" type="Object"/>
        <ReturnType type="String"/>
    </JadeMethod>
</Class>
