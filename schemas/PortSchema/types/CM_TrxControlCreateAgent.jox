	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(false);

	if app.myRoot.allLocales[_localeCode] &lt;&gt; null then
		//app.raiseCMException2(DuplicateItem, 'Locale', _localeCode, null, null); //14.06.2022 navds20 53760
		// Locale already exists for %1 : Locale_already_exists
		app.raiseCMException1(Locale_already_exists, _localeCode, null, null); //14.06.2022 navds20 53760
		return;
	endif;

	beginTransaction;
	
	create _locale persistent;
	_locale.setForCreate(_localeCode, _localeDescr, _isUserDefined, app.myRoot);
	
	
epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_localeCode" type="String"/>
        <Parameter name="_localeDescr" type="String"/>
        <Parameter name="_locale" type="CM_Locale" usage="output"/>
        <Parameter name="_isUserDefined" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxCreateLocationCheckTrans" id="7e9f0dcc-4955-4e1e-9025-fcb65cb07fdd">
        <updating/>
        <source>trxCreateLocationCheckTrans(	_trxCmifSet : CMIF_TITxnControllerSet input;
								_trxDict : CM_TITransactionSet input;
								_passport : CM_Passport input	) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 August 2015	cnwndl1	Initial creation	Par 36608

*/

vars

	cmif : CMIF_TITransactionController;
	cmifLCC : CMIF_LocationCheckController;
	ti : CM_TrackedItem;
	txn : CM_TITransaction;

begin

	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(false);
	
	_passport.useTIDictDeferUpdate := true;
	_passport.useTITransactionDeferUpdate := true;
	
	beginTransaction;
	
	foreach cmif in _trxCmifSet do
		cmifLCC := cmif.CMIF_LocationCheckController;
		ti := cmifLCC.myTrackedItem;
		
		txn := ti.createTransaction( cmif, app.myPassport );
		if txn &lt;&gt; null then
			_trxDict.add(txn);
		endif;
		
		if _passport.hasErrors() then
			break;
		endif;
	endforeach;
	
	if _passport.hasErrors() then
		return;
	endif;
	
	if _passport.noErrors() then
		_passport.doDeferredUpdates();
	endif;

epilog

	self.finaliseActivityWithPassport(_passport);

end;</source>
        <Parameter name="_trxCmifSet" type="CMIF_TITxnControllerSet" usage="input"/>
        <Parameter name="_trxDict" type="CM_TITransactionSet" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
