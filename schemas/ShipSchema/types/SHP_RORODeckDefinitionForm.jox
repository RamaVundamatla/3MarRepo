    <JadeMethod name="doEditDeckItem" id="dff6f933-ce0a-4921-b82d-df0fa5fb2391">
        <source>doEditDeckItem() protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14 April 2011	cnwer1	Initial creation CCMS 1031

*/

vars

	deckItem : CM_DeckItem;
begin

	if self.tblDeckItems.accessRow(self.tblDeckItems.row) = null then
		return;
	endif;
	deckItem:=self.tblDeckItems.accessRow(self.tblDeckItems.row).itemObject.CM_DeckItem;

	if deckItem &lt;&gt; null then
		// TFS 2198 CNWAB1
		if app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
			self.myAssistant.SHP_Assistant.showRORODeckItemForm(self.myCurrentDeck,deckItem, SHP_ParentChildForm.Mode_Edit);
		else
			self.myAssistant.SHP_Assistant.showRORODeckItemForm(self.myCurrentDeck,deckItem, SHP_ParentChildForm.Mode_View);
	
		endif;

	endif;
epilog

end;</source>
