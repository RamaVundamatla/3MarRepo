    <JadeMethod name="isTIInHighlightedLC" id="565a6612-baed-48f1-888c-843ee768f245">
        <source>isTIInHighlightedLC(_ti : CM_TrackedItem) : Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 May 2010	cnwjk3	Initial creation

*/

vars
	height 	: Integer;
	key		: String;
begin
	if _ti = null then
		return false;
	endif;
	
	if _ti.myPrimaryActualLocation = null then 
		return false;
	endif;
	
	if not _ti.myPrimaryActualLocation.isKindOf(CM_GridController) then
		return false;
	endif;
	
	if _ti.myPrimaryActualLocation.isKindOf(CM_GridController)  and (self.drawMode = CMIF_RDTDrawElement.MODE_FACE or self.drawMode = CMIF_RDTDrawElement.MODE_END) then
		// A gridded side view, so we need to include the height of the TI in the key
		height := _ti.myPrimaryActualLocation.CM_GridController.getActualStackPositionOfTI(_ti); 
	endif;
	
	key := self.genHighlightedLCKey(_ti.myPrimaryActualLocation, height);
	
	return self.allHighlightLCsByID.includesKey(key);
epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="onResize" id="3759e576-6291-4133-90bb-8ef4eb047a0f">
