    <DbClassMap file="userData"/>
    <JadeMethod name="extractFieldsBody" id="1ab85060-9569-4182-aa17-6c3f9e93d625">
        <source>extractFieldsBody(_terminal: CM_Terminal; _outputFile: File; _counter: Integer io; _breakOut : Boolean output)protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 May 2011	#cnwdz2	 

*/
vars
	
	userTerminal : CM_UserTerminal;
begin
	foreach userTerminal in _terminal.allUserTerminals do
		self.extractFieldsFromObject(userTerminal.myUser, _outputFile, _counter, _breakOut);		
	endforeach;
epilog	
end;</source>
        <access>protected</access>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_outputFile" type="File"/>
        <Parameter name="_counter" type="Integer" usage="io"/>
        <Parameter name="_breakOut" type="Boolean" usage="output"/>
    </JadeMethod>
