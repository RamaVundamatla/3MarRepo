    <JadeMethod name="findAnyDuplicateId" id="1afa926d-a387-4d8f-9ca6-bfa204eb74d3">
        <source>findAnyDuplicateId() : String protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 October 2013	cnwndl1	Initial creation	Par 31829

*/

vars

	prospectId : String;
	prospectIds : StringArray;
	allGTEs : CMGTE_EntitySet;
	gte : CMGTE_Entity;

begin

	if not self.isAttachmentForm then
		return null;
	endif;
	
	create allGTEs transient;
	if self.myMainForm &lt;&gt; null and self.myMainForm.isKindOf( CMUI_ReceiveCargoForm ) then
		self.myMainForm.CMUI_ReceiveCargoForm.getAllMainFormGTEs( allGTEs );
	else
		self.getAllMainFormGTEs( allGTEs );
	endif;
	
	if self.updateMode = self.Mode_Update then
		//update mode only allows one at a time
		prospectId := self.txtCargoID.getString;
		if self.myProxyTrackedItem &lt;&gt; null and self.myProxyTrackedItem.id = prospectId then
			return null;
		elseif self.myPxyGTEEntity &lt;&gt; null and self.myPxyGTEEntity.id = prospectId then
			return null;
		elseif self.myIntFacePreNote &lt;&gt; null and self.myIntFacePreNote.id = prospectId then
			return null;
		endif;
		
		if self.myPxyGTEEntity &lt;&gt; null and self.myPxyGTEEntity.id &lt;&gt; prospectId then
			//we are changing its id, make sure its not someone elses id.
			if not allGTEs.isEmpty then
				foreach gte in allGTEs do
					if prospectId = gte.id then
						return prospectId;
					endif;
				endforeach;
			endif;
		endif;
		
	elseif self.updateMode = self.Mode_Add then
		// could be muliples being added in parallel.
		// should not be any pre-existing GTEs with any of these ids.
		create prospectIds transient;
		if self.cargoIDs.size &gt; 0 then
			self.cargoIDs.copy( prospectIds );
		else
			prospectId := self.txtCargoID.getString;
			prospectIds.add(prospectId);
		endif;
		
		if not allGTEs.isEmpty then
			foreach prospectId in prospectIds do
				foreach gte in allGTEs do
					if prospectId = gte.id then
						return prospectId;
					endif;
				endforeach;
			endforeach;
		endif;
		
	endif;

	return null;
	
epilog

	delete prospectIds;
	delete allGTEs;

end;</source>
        <access>protected</access>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="findOnSiteTI" id="5abb7137-af67-4eeb-90e2-8f849f4e136f">
        <source>findOnSiteTI(_id : String) : CM_TrackedItem;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 October 2013	cnwmc5	Initial creation	PAR 31630

*/

vars
	ti : CM_TrackedItem;
begin
	if self.cmbType.getObject() &lt;&gt; null then
		ti := self.myTerminal.lookupTrackedItem(_id, self.cmbType.getObject().CM_CargoType.type, TI_STATE_NORMAL, null, true);
	else
		ti := self.myTerminal.lookupTrackedItem(_id, TI_CargoType_Null, TI_STATE_NORMAL, null, true);
	endif;
	
	if ti &lt;&gt; null and ti.id &lt;&gt; _id then
		ti := null;
	endif;
	
	return ti;
epilog

end;</source>
        <Parameter name="_id" type="String"/>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="findTIMaster" id="5bf3f048-dbee-4fc8-bf7b-6e4a2970c1f9">
        <source>findTIMaster(_id :String):CM_TIMaster protected;
// ---------------------------------------------------------------------------
// Created:     18 May 2010 by cnwcs5
// Purpose:     We cannot rely on the proxy having a reference to the
//				TI Master but we need to easiliy find it to set default weights
// Parameters:  None
// Returns:     TI Master mthat matches _id, selected cargo type
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	cargoType	:CM_CargoType;
	master		:CM_TIMaster;
begin
	if self.isGeneralCargo() or self.isAttachmentForm() then
		// Try to find master TI based on selected cargo type
		cargoType := self.cmbType.getObject().CM_CargoType;
		if cargoType &lt;&gt; null then
			master := app.myRoot.findTIMasterByCargoType(cargoType.id, _id);
		endif;
	else
		// Assume container
		master := app.myRoot.findTIMasterContainerByID(_id);
	endif;
	
	return master;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_id" type="String"/>
        <ReturnType type="CM_TIMaster"/>
    </JadeMethod>
    <JadeMethod name="frmCoordinates_doAlignCtrls" id="8f49dcc9-20c7-484d-af1d-d5902a38ddf5">
        <controlMethod name="CMUI_FieldGeneric::doAlignCtrls"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>frmCoordinates_doAlignCtrls(_fieldGeneric: CMUI_FieldGeneric input) updating;
/*
Date		    Who			Reason
01 September 2011	cnwas3	  Initial creation: CCMS 1035 CargoSideView form
*/

vars
	labelLeft	: Real;

begin
	
	self.txtX.width := (_fieldGeneric.width - _fieldGeneric.myLabel.width - 3*_fieldGeneric.HORIZONTAL_SPACING - self.lblX.width)/2;
	self.txtY.width := self.txtX.width;
	
	self.lblX.move(_fieldGeneric.myLabel.width + _fieldGeneric.HORIZONTAL_SPACING, 0, self.lblX.width, _fieldGeneric.height);
	self.lblX.borderStyle := self.lblX.BorderStyle_None;
	self.txtX.move(self.lblX.left + self.lblX.width , 2, self.txtX.width, self.txtX.height);
	
	
	labelLeft := self.txtX.left + self.txtX.width + _fieldGeneric.HORIZONTAL_SPACING;
	self.lblY.move(labelLeft, 0, self.lblY.width, _fieldGeneric.height);
	self.lblY.borderStyle := self.lblY.BorderStyle_None;
	self.txtY.move(self.lblY.left + self.lblY.width , 2, self.txtY.width, self.txtY.height);
epilog

end;</source>
        <Parameter name="_fieldGeneric" type="CMUI_FieldGeneric" usage="input"/>
    </JadeMethod>
