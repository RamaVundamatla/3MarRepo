    <JadeMethod name="isDataSheetDisplayed" id="419f89a5-a99d-4057-84bb-ca47ad638ba6">
        <source>isDataSheetDisplayed(_index : Integer output) : Boolean;
// ---------------------------------------------------------------------------
// Created:	29 September 2009 By Graeme Black cnwgb1
// Purpose:	Determine if shtEDIData or one of its clones is displayed in the folder
// ---------------------------------------------------------------------------
// 14/10/2009	cnwcs5	par 20836 - changed method to be more efficient
vars
	sheet	:Sheet;
begin
	sheet := self.fldDetail.topSheet;			// par 20836
	if sheet.name = self.shtEDIData.name then	// par 20836
		_index := sheet.index;					// par 20836
		return true;							// par 20836
	endif;										// par 20836
	
	return false;								// par 20836
epilog

end;</source>
        <Parameter name="_index" type="Integer" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="loadDataForFirstTime" id="fbc76a45-0bc5-47a9-a3ac-a0c1d43c0fbd">
        <updating/>
        <source>loadDataForFirstTime() updating, protected;
// ---------------------------------------------------------------------------
//10 Jan 2017	cnwrs1	TFS 3137 - resize the form when show captions is on
// ---------------------------------------------------------------------------
vars
	showCaptions : Boolean;
begin
	if self.frmToolbar.showCaptions then
		showCaptions := self.frmToolbar.showCaptions;
		self.frmToolbar.showCaptions := false;	 //turn it off 
		self.toolbarShowCaptions(showCaptions);	// turn back on and get sizeDeiff in toolbarShowCaptions
	endif;
	inheritMethod;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="loadEDIFileTypes" id="bc1ddad4-db91-45fb-a970-567cb5477297">
        <source>loadEDIFileTypes(_cmb: CMUI_ComboBox input; _fileType : Integer) protected;
/*
----------   ----------  --------------------------------------------------
Created:	01 August 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	typeToSet,
	ediFileType			: CM_EDIFileType;
	fileTypeDict		: CM_EDIFileTypeByTypeNameDict;
	iter				: Iterator;
begin
	_cmb.clear();
	_cmb.sorted := true;
	//th2 1/08/06 load all user defined file types
	fileTypeDict := app.myRoot.allEDIFileTypes;
	iter := fileTypeDict.createIterator();
	//fileTypeDict.startKeyGeq(EDIFileType_UserDefined, null, iter);
	
	while iter.next(ediFileType) do
		//cnwrs1 Mar 2007 Par 13575 only allow user defined types to be selected
		if ediFileType.type &lt;&gt; EDIFileType_UserDefined
		//Mar 2007 par 13846 this appears to be the only way to load this
		and ediFileType.type &lt;&gt; EDIFileType_CSVFESCOBookRef
		//Mar 2007 it makes sense that all generic types are avilable here
		and ediFileType.type &lt;&gt; EDIFileType_CSVMSCLoad
		and ediFileType.type &lt;&gt; EDIFileType_CSVMSKLoad
		and ediFileType.type &lt;&gt; EDIFileType_CSVPONLoad
		and ediFileType.type &lt;&gt; EDIFileType_CSVTOL
		and ediFileType.type &lt;&gt; EDIFileType_CSVTranship
		then
			continue;
		endif;
		
		if app.myRoot.canDoEDIFileType(ediFileType.type) then
			_cmb.itemObject[_cmb.addItem(ediFileType.name)] := ediFileType;
			
			if ediFileType.type = _fileType then
				typeToSet := ediFileType;
			endif;
		endif;
	endwhile;

	if typeToSet &lt;&gt; null then
		_cmb.listObject := typeToSet;
	endif;
epilog
	delete iter;
end;</source>
        <access>protected</access>
        <Parameter name="_cmb" type="CMUI_ComboBox" usage="input"/>
        <Parameter name="_fileType" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="loadFilterAction" id="5fbc6d37-0f7d-4f17-b8ef-fa3aafe31a9a">
        <source>loadFilterAction(_cmb: CMUI_ComboBox input) protected;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 28 September 2023
TFS#		: 60232
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/
vars
	ediTypeIndex		: Integer;
begin
	_cmb.clear();
	_cmb.sorted := true;
	_cmb.addItem("");
	
	ediTypeIndex := self.cmbFiltEdiType.listIndex;
	
	if ediTypeIndex &gt; 0 and (self.cmbFiltEdiType.itemData[ediTypeIndex] = EDIDataType_TransportManifest
		or self.cmbFiltEdiType.itemData[ediTypeIndex] = EDIDataType_CallOff) then
		_cmb.addItem(CMIF_JsonHeaderEUP.Status_Create);
		_cmb.addItem(CMIF_JsonHeaderEUP.Status_Cancel);
		_cmb.addItem(CMIF_JsonHeaderEUP.Status_Replace);			
	endif ;			
end;</source>
        <access>protected</access>
        <Parameter name="_cmb" type="CMUI_ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="loadFilterMessageType" id="cad3d208-0069-46d7-8afd-1ebc283d95d3">
        <source>loadFilterMessageType(_cmb: CMUI_ComboBox input) protected;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 28 September 2023
TFS#		: 60232
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/
vars
	ediTypeIndex : Integer;
begin
	ediTypeIndex := self.cmbFiltEdiType.listIndex;
	
	_cmb.clear();
	_cmb.sorted := true;
	_cmb.addItem("");
	
	if ediTypeIndex &gt; 0 and self.cmbFiltEdiType.itemData[ediTypeIndex] = EDIDataType_TransportManifest then		
		_cmb.addItem("Manifest" &amp; " (Unknown)");
		_cmb.addItem("Manifest" &amp; " (Road)");
		_cmb.addItem("Manifest" &amp; " (Ship)");
		_cmb.addItem("Manifest" &amp; " (Rail)");
	elseif ediTypeIndex &gt; 0 and self.cmbFiltEdiType.itemData[ediTypeIndex] = EDIDataType_CallOff then
		_cmb.addItem("CallOffWithTransport" &amp; " (Unknown)");
		_cmb.addItem("CallOffWithTransport" &amp; " (Road)");
		_cmb.addItem("CallOffWithTransport" &amp; " (Ship)");
		_cmb.addItem("CallOffWithTransport" &amp; " (Rail)");		
		_cmb.addItem("CallOffWithoutTransport" &amp; " (Unknown)");
		_cmb.addItem("CallOffWithoutTransport" &amp; " (Road)");
		_cmb.addItem("CallOffWithoutTransport" &amp; " (Ship)");
		_cmb.addItem("CallOffWithoutTransport" &amp; " (Rail)");		
	endif ;			
end;</source>
        <access>protected</access>
        <Parameter name="_cmb" type="CMUI_ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="loadFilterTransMode" id="7f8552a8-f960-434f-bf73-bcc305ab141a">
        <source>loadFilterTransMode(_cmb: CMUI_ComboBox input) protected;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 28 September 2023
TFS#		: 60232
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/
vars
	idx: Integer;
	ediTypeIndex		: Integer;
begin
	_cmb.clear();
	_cmb.sorted := true;	
	
	ediTypeIndex := self.cmbFiltEdiType.listIndex;
	
	if ediTypeIndex &gt; 0 and (self.cmbFiltEdiType.itemData[ediTypeIndex] = EDIDataType_TransportManifest
		or self.cmbFiltEdiType.itemData[ediTypeIndex] = EDIDataType_CallOff) then
		_cmb.addItem(Empty_String);
		
		idx := _cmb.addItem(TI_TRANSMODE_ROAD_STR);		
		_cmb.itemData[idx] := TI_TRANSMODE_ROAD;
		
		idx := _cmb.addItem(TI_TRANSMODE_RAIL_STR);
		_cmb.itemData[idx] := TI_TRANSMODE_RAIL;
		
		idx := _cmb.addItem(TI_TRANSMODE_SHIP_STR);	
		_cmb.itemData[idx] := TI_TRANSMODE_SHIP;
	endif ;			
end;</source>
        <access>protected</access>
        <Parameter name="_cmb" type="CMUI_ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="loadFormatMenuItem" id="670d6f63-1d86-4bf3-b488-56760a5c53a2">
        <updating/>
        <source>loadFormatMenuItem(_cloneMaster, _sourceMenu : MenuItem input; _index: Integer): MenuItem updating, protected;
//----------------------------------------------------------------
//	Created:	17 November 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	oidStr	: String;
	newMenu	: MenuItem;
	
begin

	oidStr := _sourceMenu.description;
	if oidStr &lt;&gt; null then
		newMenu := oidStr.asOid.MenuItem;
	endif;

	if newMenu = null then
	
		self.clonedMenuCount := self.clonedMenuCount + 1;
		newMenu := _cloneMaster.loadSubMenu(self.clonedMenuCount);
		newMenu.userObject	:= _sourceMenu;
		_sourceMenu.description	:= newMenu.getOidString;
	
	endif;
	
	newMenu.caption 		:= _sourceMenu.caption;
	newMenu.checked 		:= _sourceMenu.checked;
	newMenu.disableReason	:= _sourceMenu.disableReason;
	newMenu.enabled			:= _sourceMenu.enabled;
	newMenu.helpContextId	:= _sourceMenu.helpContextId;
	newMenu.helpKeyword		:= _sourceMenu.helpKeyword;
	newMenu.picture			:= _sourceMenu.picture;
	newMenu.visible 		:= _sourceMenu.visible;
	
	return newMenu;
	
end;</source>
        <access>protected</access>
        <Parameter name="_cloneMaster" type="MenuItem" usage="input"/>
        <Parameter name="_sourceMenu" type="MenuItem" usage="input"/>
        <Parameter name="_index" type="Integer"/>
        <ReturnType type="MenuItem"/>
    </JadeMethod>
    <JadeMethod name="locateFileLine" id="4e1f83f6-c715-4487-a50c-d40fc3c3bd41">
        <updating/>
        <source>locateFileLine(_showMessage : Boolean) updating;
//----------------------------------------------------------------
//	Created:	05 August 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
// 13/07/2011	cnwcs5	par 26557 - select EDITI in error on cloned sheet
// 18/04/2013	cnwcs5	par 31255 - handle incorrect property names on errors
//24/08/2018 	Jlgns1	Bug 39897: POL - FW: Warning Message
vars
	obj					: Object;
	table, clone		: CM_DataTable;
	row, dummy, index	: Integer;
	fieldName, propName	: String;
	errObj				: CM_Error;
	lineSeq, errSeq 	: Integer;
	sheet				: Sheet;
begin
	
	sheet := self.fldDetail.topSheet;
	
	if sheet = self.shtEDIFile then
		// use local variable to hold self.tblFileError
		table	:= self.tblFileError;
		row 	:= table.row;
		
		if row &lt; 1 then return; endif;
		
		obj 		:= table.accessRow(row).itemObject;
		propName 	:= table.accessCell(row, 2).text[1:3];
		
		// re-use local variable to hold self.tblFileLine
		table 		:= self.tblFileLine;
		
		if CM_Error.hasInstance(obj) then
			errObj := obj.CM_Error;
			
			table.clearAllSelected();
			
			errSeq := errObj.fieldName.Integer; //par 17172 cnwrs1 july 2008
			
			if errSeq &gt; table.rows then
				return;
			endif;
			
			lineSeq := table.accessCell(errSeq, self.COLUMN_SEQ).text.Integer; //par17172
			
			if lineSeq = errSeq then //par17172
				if errSeq &lt; table.rows then
					table.selectRow(errSeq, true);
				endif;
				return;
			else
				// the errSeq is now wrong as we have deleted or added lines so must correct 
				errSeq := errSeq + (errSeq -lineSeq);
				if errSeq &lt; table.rows then
					table.selectRow(errSeq, true);
				endif;
				return;
			endif;
		endif;
	elseif sheet.name = self.shtEDIData.name then
		// use local variable to hold the EDI TI error table
		table	:= self.tblEDITIError;
		row 	:= table.row;
		
		if row &lt;= table.fixedRows then
			return;
		endif;
		
		obj 		:= table.accessRow(row).itemObject;
		fieldName 	:= table.accessCell(row, 3).text;
		
		// re-use local variable to store reference to table of EDI tracked items
		// on the current sheet
		table 		:= self.tblEDITI;
		
		if obj.isKindOf (CM_EDITrackedItem) then
			propName	:= obj.CM_EDITrackedItem.getPropertyNameForFieldName (fieldName);	// par 31255
			
			if not table.findObjectInRow (obj, dummy) then
				// we need to find which cloned table has our TI 
				index	:= 1;
				clone 	:= table.getControl (index);
				
				while clone &lt;&gt; null do
					if clone.findObjectInRow (obj, dummy) then
						table := clone;
						break;
					endif;
					
					index 	:= index + 1;
					clone 	:= table.getControl (index);
				endwhile;
			endif;
		endif;
		
		// table will either contain the table with obj in it or the table with index = 0
		if table.index &lt;&gt; sheet.index then
			// our table is on a different sheet
			sheet := self.shtEDIData.getControl (table.index);
			
			if sheet &lt;&gt; null then
				self.fldDetail.topSheet := sheet;
			endif;
		endif;
	else
		return;
	endif;
	
	if obj = null or table = null then
		if _showMessage then			//Bug 39897
			app.msgBox( app.getErrorString(Futher_informatio_available), app.getErrorString(Warning), MsgBox_OK_Only);	//23 Nov 2016	NDL	TFS 2905
			//app.raiseUnexpectedProgramError(class.name, method.name, 'the selected item or the target table is null');
		endif;
		return;
	endif;

	table.clearAllSelected();
	table.selectObject(obj, true);
epilog 
	if table &lt;&gt; null then	//23 Nov 2016	NDL	TFS 2905
		self.setTblFindReplaceForCol(table, propName);
	endif;
end;</source>
        <Parameter name="_showMessage" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="mnuAuditData_click" id="2ff3ac69-6649-4979-8e25-5eebfde6065c">
