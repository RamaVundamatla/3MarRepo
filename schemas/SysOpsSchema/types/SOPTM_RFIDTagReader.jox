    <JadeMethod name="setControlsForAddEdit" id="75ada4ea-492b-4c59-8f63-581e23be4a5a">
        <updating/>
        <source>setControlsForAddEdit() updating;
/*
----------   ----------  --------------------------------------------------
Created:	30 August 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

	theForm 			: SOP_TableMaintForm;
	entTableRow			: EntTableRow;
	entTableDef			: EntTableDef;
begin
  
  	theForm := self.myForm;
	theForm.tblInput1.userInputEnabled := true;
	entTableDef := app.myController.getEntTableDef(ETDef_RFIDTagReader);
	
	foreach entTableRow in entTableDef.allEntTableRows do
		theForm.tblInput1.enableRowByName(entTableRow.name);
	endforeach;
	
	if theForm.mode = theForm.Mode_Add then 
		theForm.tblInput1.clearValues;
		theForm.tblInput1.setFocus;
		theForm.tblInput1.moveFirst();
		theForm.tblInput1.gotFocus(theForm.tblInput1);		
	else
		self.showThumbnail(theForm.myCurrentObject.CM_RFIDTagReader);
	endif;
    theForm.tblInput1.cnEcResizeContents;


epilog

end;

</source>
    </JadeMethod>
    <JadeMethod name="setViewForContext" id="6645ec82-0c48-4071-9d37-aed1a4e84de2">
        <source>setViewForContext(_context : Integer);
/*
----------   ----------  --------------------------------------------------
Created:	01 September 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	view				: EntTableView;
	entTableDef			: EntTableDef;
begin
	entTableDef := app.myController.getEntTableDef(ETDef_RFIDTagReader);
	
	if _context = null or
		_context = TagReaderContext_Machine then
		view := entTableDef.allEntTableViews['contextMachine'];
	elseif _context = TagReaderContext_WindowsPC then
		view := entTableDef.allEntTableViews['contextWindows'];
	elseif _context = TagReaderContext_LaneDevice then
		view := entTableDef.allEntTableViews['contextLaneDevice'];
	else
		return;
	endif;
		
	self.myForm.tblInput1.showHideRowsByView(view, CM_EntryTable.ShowHideRows, false);
	self.myForm.tblInput1.adjustHeight(200);
epilog

end;




</source>
        <Parameter name="_context" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setupThumbnailDetails" id="f0e0a072-8875-4d73-9b17-c43ccffd76bb">
        <updating/>
        <source>setupThumbnailDetails() updating;
/*
----------   ----------  --------------------------------------------------
Created:	30 August 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
11/09/2009	cnwcs5	ccms1061 - removed vta (road transfer area)
*/
vars
	theForm : SOP_TableMaintForm;
begin
	theForm 				:= self.myForm;
	theForm.useProxyObject 	:= true;
	
	theForm.setTblDataEntRows(ETDef_RFIDTagReadData);
	//12/01/2011 cnwdz2 25840
	//theForm.zClearSortColumns();
	//theForm.zAddSortColumn(ETRow_Code, false);

	theForm.shtTblInput1.visible := true;
	theForm.shtTblInput1.caption := app.getErrorString (XLAT_Rfid_reader_details);
	theForm.initTblInput(theForm.tblInput1, ETDef_RFIDTagReader);
	
	// load comntext combo
	theForm.myAssistant.comboBoxRFIDTagReaderContext(theForm.cmbReaderContext, null);
	// load gate and interchange areas
	theForm.myAssistant.comboBoxTerminalArea_RFIDAreas (theForm.cmbGateArea, null);
	// load machines
	theForm.myAssistant.comboBoxMachineId(theForm.cmbMachine, null);
epilog

end;

</source>
    </JadeMethod>
    <JadeMethod name="showThumbnail" id="5c8d6c9f-0d8e-45ef-b5f8-322ee48d6aca">
        <updating/>
        <source>showThumbnail(_rfidTagReader : CM_RFIDTagReader) updating;
/*
----------   ----------  --------------------------------------------------
Created:	30 August 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	theForm 		: SOP_TableMaintForm;
	entTableDef		: EntTableDef;
	entTableRow		: EntTableRow;
	ta				: CM_TerminalArea;
	cmb				: CMUI_ComboBox;
	lane			: CM_LaneController;
begin
	theForm := self.myForm;
	theForm.tblInput1.clearValues;
	
	entTableDef := app.myController.getEntTableDef(ETDef_RFIDTagReader);
	self.setViewForContext(_rfidTagReader.context);
	
	if _rfidTagReader.context = TagReaderContext_Machine then
		theForm.cmbReaderContext.listIndex := 1;
	elseif _rfidTagReader.context = TagReaderContext_WindowsPC then
		theForm.cmbReaderContext.listIndex := 2;
	elseif _rfidTagReader.context = TagReaderContext_LaneDevice then
		theForm.cmbReaderContext.listIndex := 3;
	endif;
	
	if _rfidTagReader.context = TagReaderContext_LaneDevice then
		cmb 	:= theForm.cmbGateArea;
		lane	:= _rfidTagReader.getLaneController;
		
		if lane &lt;&gt; null then
			// select terminal area and lane in the list box
			ta := lane.myTerminalArea;
			if cmb.findObject(ta) &gt; 0 then
				cmb.listObject := ta;
				
				self.doCmbAreasClick();
				
				if theForm.cmbGateLane.findObject (lane) &gt; 0 then
					theForm.cmbGateLane.listObject := lane;
				endif;
			endif;
		endif;
		// load the read/assign combo
		theForm.tblInput1.setComboValuesByName (ETRow_RfidReadAssign, 
												null.String &amp; Tab &amp;
												app.getErrorString (XLAT_RFID_Read) &amp; Tab &amp; 
												app.getErrorString (XLAT_RFID_Assign));
	elseif _rfidTagReader.context = TagReaderContext_Machine and 
		_rfidTagReader.myMachine &lt;&gt; null and
		theForm.cmbMachine.findObject(_rfidTagReader.myMachine) &gt; 0 then
		
		theForm.cmbMachine.listObject := _rfidTagReader.myMachine;
	endif;
		
	foreach entTableRow in entTableDef.allEntTableRows do
		theForm.tblInput1.setValueByName(entTableRow.name, _rfidTagReader.getDisplayStringForAttribute(entTableRow.name, false));
	endforeach;
		
end;

</source>
        <Parameter name="_rfidTagReader" type="CM_RFIDTagReader"/>
    </JadeMethod>
</Class>
