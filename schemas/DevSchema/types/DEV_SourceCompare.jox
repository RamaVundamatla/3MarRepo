    <JadeMethod name="doBrowseForFolder" id="06878c37-e0ca-4675-9f2a-3150c44fa701">
        <source>doBrowseForFolder(_folderTextBox : TextBox input; _onServer : Boolean) protected;
/*

Purpose:			Browse for a folder, either on the server or client

Parameters:			_onServer set to true if a server folder is required

Return Value:		Selected folder, or null if none selected

Date		Who		Reason
28 October 2021	navpw1	Initial creation TFS: 52202

*/

vars
	ff			: FileFolder;
	newFolder	: String;
	
begin
	create ff transient;
	if _onServer then
		newFolder := ff.browseForServerFolder("Choose a server folder", _folderTextBox.text);
	else
		newFolder := ff.browseForFolder("Choose a folder", _folderTextBox.text);
	endif;

	if newFolder &lt;&gt; null then
		_folderTextBox.text := newFolder;
	endif;
	
epilog
	delete ff;

end;</source>
        <access>protected</access>
        <Parameter name="_folderTextBox" type="TextBox" usage="input"/>
        <Parameter name="_onServer" type="Boolean"/>
    </JadeMethod>
