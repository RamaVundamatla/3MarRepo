vars

begin
	//not required for logs as order line may be for a different customer and/or discharge port
end;</source>
    </JadeMethod>
    <JadeMethod name="validateForDelete" id="d8054a78-e56e-4088-bc40-c7e91184194b">
        <source>validateForDelete();
//--------------------------------------------------------------
//Created: 23 August 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	entries : Integer;
begin
	entries := self.allBOLOuts.size;
	if entries &gt; 0 then
		app.raiseCMException2(ObjectStillHasEntries, 'Stock Order for voyage' &amp; self.myVoyage.code, entries.String, null, null);
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="validateMe" id="1d16c353-f5bd-48ae-83c5-66459097604e">
        <source>validateMe(_passport : CM_Passport input) protected;
//--------------------------------------------------------------
//Created: July 2002 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	inheritMethod(_passport);

	if self.myVoyage = null then
	//	app.raiseCMException1(REQUIRED_FIELD, "Voyage", ETRow_Voyage, null);
		app.raiseCMException(Input_required_field_voyage, ETRow_Voyage, null); // cnwdb2	PAR 35364
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
</Class>
