    <JadeMethod name="pxyCreateUpdateProxy" id="7afdd189-bcd5-48ad-84f5-09eea07d6e06">
        <source>pxyCreateUpdateProxy(): SelfType;
/*
Purpose:			

Date		Who		Reason
12 January 2023	navtnr20	TFS CR 55622 Task 55690: Jade - Shipping Terms TRX
*/

vars
	pxyME : SelfType;
begin
	pxyME :=  inheritMethod();
	
	pxyME.myBusinessUnit := self.myBusinessUnit;
	pxyME.code := self.code;
	pxyME.description := self.description;
	
	return pxyME;

epilog

