    <JadeMethod name="cmbChapterBuild" id="a08997dd-6dc5-48e7-9cf2-86eae0cf27dd">
        <source>cmbChapterBuild();
/*

Purpose:			

Parameters:			

Return Value:		

Date					Who		Reason
08 December 2022		jlizm1	Initial creation TFS 55280 Harmonized System Codes

*/

vars
	obj : Object;
	section : CM_HSCodeSection;
	chapter : CM_HSCodeChapter;
	idx : Integer;
	str : String;
	iter : Iterator;
begin
	self.cmbChapter.clear;
	self.cmbChapter.sorted := false;
	self.cmbChapter.addItem(app.getErrorString(All_Chapters));
	self.cmbChapter.itemObject[self.cmbChapter.newIndex] := null;
	self.cmbChapter.listIndex := 1;
	
	obj := self.cmbSection.listObject;
	
	if obj = null or not obj.isKindOf(CM_HSCodeSection) then
		iter:=app.myRoot.allHSChapters.createIterator;
	else
		section := obj.CM_HSCodeSection;
		iter:=section.allHSCodeChapters.createIterator;
	endif;
	
	while iter.next(chapter) do 
		idx := self.cmbChapter.addItem(chapter.getDisplayString);
		self.cmbChapter.itemObject[idx] := chapter;
	endwhile;
	
	self.cmbChapter.listIndex := 1;
	
epilog
	delete iter;
end;</source>
    </JadeMethod>
