	if realConsignGroup = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_ConsigneeConsignorGroup.name, null, null);
		return;
	endif;

	app.myValUA.valConsignGroup(realConsignGroup, pProxyConsignGroup);
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);

	exclusiveLock(realConsignGroup);

	if _passport.noErrors and realConsignGroup.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'ConsignGroup', null, null);
		return;
	endif;
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realConsignGroup, true);
	endif;
	
	if _passport.noErrors then
		realConsignGroup.setForUpdate(pProxyConsignGroup);
	endif;

	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realConsignGroup, false);
	endif;

end;</source>
        <Parameter name="pProxyConsignGroup" type="CM_ConsigneeConsignorGroup"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateConsigneeCmbOrderFlag" id="28351a06-7adc-4b12-8c16-9a93b0fae56f">
        <source>utlUpdateConsigneeCmbOrderFlag(pValue : Boolean; _passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:     19 August 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	theRoot,
	tmpRoot		: CM_Root;
	cc			: CM_ConsigneeConsignor;
		
begin

	self.initialiseActivity();

	theRoot := app.myRoot;
	exclusiveLock(theRoot);

	if pValue then
		tmpRoot := theRoot;
	else
		tmpRoot := null;
	endif;
	
	if _passport.noErrors then
		on Exception do self.exHandlerConsigneeCmbOrderFlag(exception, cc);
		
		foreach cc in theRoot.allConsigneeConsignors do
			cc.setMyRootForDescr(tmpRoot);
			if _passport.hasErrors then
				break;
			endif;
		endforeach;
	endif;

	if _passport.noErrors then
	    theRoot.setConfig(ConsigneeConsignorCmbOrdDescr, pValue, true);
	endif;

end;</source>
        <Parameter name="pValue" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateConsigneeConsignor" id="a7e4b860-627f-4bc6-b2ff-e51f681c3747">
        <source>utlUpdateConsigneeConsignor(_proxy :CM_ConsigneeConsignor; _passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	realConsigneeConsignor	: CM_ConsigneeConsignor;
	expectedEdition			: Integer;
	colourChanged			: Boolean;
	eventStr 				: String;
	
begin

	self.initialiseActivity();

	_proxy.raiseExceptionIfNotProxy(method);

	app.setContinueCMExceptions(true);

	_proxy.pxyGetRealObjectAndEdition(realConsigneeConsignor, expectedEdition);
	
	if realConsigneeConsignor = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_ConsigneeConsignor.name, null, null);
		return;
	endif;

	app.myValUA.valConsigneeConsignor(realConsigneeConsignor, _proxy);
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);

	self.exclusiveLock(realConsigneeConsignor);

	if _passport.noErrors and realConsigneeConsignor.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'ConsigneeConsignor', null, null);
		return;
	endif;
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realConsigneeConsignor, true);
	endif;
	
	if _passport.noErrors then
		if realConsigneeConsignor.colour &lt;&gt; _proxy.colour then
			colourChanged := true;
		endif;
		
		realConsigneeConsignor.setForUpdate(_proxy);
	endif;

	if _passport.noErrors then
		if colourChanged then
			eventStr := eventStr &amp;  "&lt;" &amp; GridXML_ColourCode &amp; "&gt;" &amp; realConsigneeConsignor.code  &amp; "&lt;/" &amp; GridXML_ColourCode &amp; "&gt;";
			eventStr := eventStr &amp;  "&lt;" &amp; GridXML_Colour &amp; "&gt;" &amp; realConsigneeConsignor.colour.String  &amp; "&lt;/" &amp; GridXML_Colour &amp; "&gt;";
			realConsigneeConsignor.causeEvent(EVENT_CODE_COLOUR_CHANGE, false, eventStr);
		endif;
		
		self.myUpdateAuditAgent.audUpdateGeneric(realConsigneeConsignor, false);
		
		if _passport.isOpsViewEnabled(null) then // ### TFS 53105 31MAY2022 NAVAB1
			realConsigneeConsignor.createOpsViewEWSActivity(BGP_OpsViewWSRequest.OPS_ACTION_UPDATE, BGP_OpsViewWSRequest.OPS_TYPE_CONSIGNEENOR, realConsigneeConsignor); // ### TFS 53105 31MAY2022 NAVAB1
		endif;
	endif;

end;</source>
        <Parameter name="_proxy" type="CM_ConsigneeConsignor"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateContRange" id="c85204db-c98c-4015-a02a-983121443710">
        <source>utlUpdateContRange(pProxyContRange:CM_ContRange; _passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	realContRange:CM_ContRange;
	expectedEdition:Integer;
	
begin

	self.initialiseActivity();

	pProxyContRange.raiseExceptionIfNotProxy(method);

	app.setContinueCMExceptions(true);

	pProxyContRange.pxyGetRealObjectAndEdition(realContRange, expectedEdition);
	
	if realContRange = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_ContRange.name, null, null);
		return;
	endif;

	app.myValUA.valContRange(realContRange, pProxyContRange);
	
	if (not self.checkValidationWithPassport(_passport)) then
		return;		// note that this gets "ignored" in the eplog
	endif;


	app.setContinueCMExceptions(false);

	exclusiveLock(realContRange);

	if _passport.noErrors and realContRange.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'ContRange', null, null);
		return;
	endif;
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realContRange, true);
	endif;
	
	if _passport.noErrors then
		realContRange.setForUpdate(pProxyContRange);
	endif;

	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realContRange, false);
	endif;

end;</source>
        <Parameter name="pProxyContRange" type="CM_ContRange"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateContainerPackDummy" id="26779a34-6ec2-49c8-be4b-b89d145828f9">
        <updating/>
        <source>utlUpdateContainerPackDummy(_realBOLOut: CM_BOLOut; _editionBOLOut: Integer;
		_realChildTIs: CM_TISet; _noCharge : Boolean;
		_passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     16 July 2002 by cnwsb1
//
// This dummy container method will take the TIs and invoice them
//
// ---------------------------------------------------------------------------
vars
	realChildTI		: CM_TrackedItem;
	ctrl			: CMIF_TITransactionController;
	storageTrans : CMIF_StorageTransController;

begin
	self.initialiseActivity();
	
	if WarehouseIntegrated then
		app.raiseCMException1(WarehouseIntegratedError, "Use updContainerPack", null, null);
		return;
	endif;
	
	if _realBOLOut = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'parent Docket', null, null);
		app.raiseCMException(Input_required_field_parentDoc, null, null); // cnwdb2	PAR 35364
		return;
	endif;
	
	if _editionBOLOut &lt; 1 then
		app.raiseCMException2(ExpectedEditionInvalid, _editionBOLOut.String, method.name, null, null);
		return;
	endif;
	
	if _realChildTIs = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'set of child TIs', null, null);
		app.raiseCMException(Input_required_field_setChldTi, null, null); // cnwdb2	PAR 35364
		return;
	endif;
	if _realChildTIs.isEmpty then
	//	app.raiseCMException1(REQUIRED_FIELD, 'must be at least one child TI', null, null);
		app.raiseCMException(Input_required_field_atlestOne, null, null); // cnwdb2	PAR 35364
		return;
	endif;
	
	app.setContinueCMExceptions(true);
	
	// Is any further validation required ?
	//app.myValUA.val???();

	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);
	
	exclusiveLock(_realBOLOut);
	
	if _realBOLOut.myMasterTI &lt;&gt; null then
		// NB: The real utlUpdatePackContainer wants a masterTI, but this dummy
		// method does not.  The container data is stored in string format against
		// the BOL Out.
		app.raiseUnexpectedProgramError(class.name, method.name,
				"There can not be a master TI for a dummy container pack");
		return;
	endif;
	
	if _passport.noErrors and _realBOLOut.edition &lt;&gt; _editionBOLOut then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'Tracked ItemOutwards Docket', null, null);
		return;
	endif;
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(_realBOLOut, true);
	endif;
	
	// Invoicing charges ===================================
	
	// ### TFS CR 58263 TASK 58264 15JAN2024 NAVAB1
	create storageTrans transient;
	storageTrans.dateTime		:= app.actualTimeServer;
	storageTrans.operatorCode	:= _realBOLOut.myOperator.code;
	storageTrans.myTerminal		:= _realBOLOut.myTerminal;
	storageTrans.userId			:= _passport.userCode;
	storageTrans.noCharge		:= _noCharge;
	storageTrans.userGenerated	:= true;
	storageTrans.myBOL			:= _realBOLOut;
	
	if _passport.noErrors then
		// This creates a storage charge (where applicable) up to
		// today for the time a TI was in storage.  eg. If a pack was in
		// a warehouse for 80 days, and 30 days storage charge has already
		// been raised, this will charge another 20 days (less the 30 days
		// no-charge period).
		storageTrans.type := TRANS_TYPE_STORAGE;
		
		foreach realChildTI in _realChildTIs do
			if not _passport.noErrors then
				break;
			endif;
			storageTrans.myTrackedItem := realChildTI;
			realChildTI.createTransaction(storageTrans, _passport);
		endforeach;
	endif;
	
	// Now we Pack the TIs out.  This transaction is also invoiceable.
	create ctrl transient;
	ctrl.dateTime		:= app.actualTimeServer;
	ctrl.operatorCode	:= _realBOLOut.myOperator.code;
	ctrl.myTerminal		:= _realBOLOut.myTerminal;
	ctrl.userId			:= _passport.userCode;
	ctrl.noCharge		:= _noCharge;
	ctrl.userGenerated	:= true;
	ctrl.myBOL			:= _realBOLOut;
	
	if _passport.noErrors then
		ctrl.type := TRANS_TYPE_PACK;
		
		foreach realChildTI in _realChildTIs do
			if not _passport.noErrors then
				break;
			endif;
			ctrl.myTrackedItem := realChildTI;
			realChildTI.createTransaction(ctrl, _passport);
		endforeach;
	endif;
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(_realBOLOut, false);
	endif;

epilog
	delete ctrl;
	delete storageTrans;// ### TFS CR 58263 TASK 58264 15JAN2024 NAVAB1

end;</source>
        <Parameter name="_realBOLOut" type="CM_BOLOut"/>
        <Parameter name="_editionBOLOut" type="Integer"/>
        <Parameter name="_realChildTIs" type="CM_TISet"/>
        <Parameter name="_noCharge" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateContainerVGM" id="b48b75d0-120f-4c7b-85dc-5ec46f6b1a4c">
        <source>utlUpdateContainerVGM(_realTI: CM_TrackedItem input; _ediPrenoteTI : CM_EDIPrenoteTI input; _passport : CM_Passport input );

/*

Purpose:			

Parameters:			

Return Value:		
/* Changes

Date		Name	TFS#		Description
============================================================================
13/06/2018	jlgns1				Initial creation
14/06/2018 	JLGNS1	Bug 38885	SNO - VGM Issue
07/06/2019	jlgka1	TFS 45048 - SNO - COPARN with VGM but no weight certifying person / authority
30 Jul 2019	jlgsl4	TFS 45766 - SNO - Inconsistent weight information
29/04/2025	jlizm1	MTN 34565 	Negative cargo weights being allowed through edi resulting in display errors
============================================================================*/
vars
	updController		: CMIF_TIUpdateController;	
	//jlgka1 TFS 45048 --&gt;
	updCertifiedName	: String;
	updAuthorisedName 	: String;
	updAuthSig			: String;	
	updCommsType		: String;
	updDocDetails		: String; 
	updEdiTrans			: String; 
	updEmail			: String;
	updMail				: String;
	updPhone			: String;
	updFax				: String;
	updTelephone 		: String;
	updDocDT			: TimeStamp;
	updDeterDT 			: TimeStamp;
	vgmDetails			: CM_VGMDetails;
	//jlgka1 TFS 45048 &lt;--
begin
	updDocDT	 := null;
	updDeterDT 	 := null;
	
	if _realTI = null then
		return;
	endif;
	
	if _ediPrenoteTI.tareWeight &gt; 0 and _ediPrenoteTI.tareWeight &gt; _ediPrenoteTI.weight then
		app.raiseCMException(Tare_weight_more_than_total, app.getString(Tare_weight), _ediPrenoteTI);
		return;
	endif;
	
	updController := app.createTIUpdateControl(TI_UPDMODE_NORMAL, app.getMyUserCode(), null);	
	
	_realTI.setIsWeightCertified(_ediPrenoteTI.isWeightCertified, updController, _passport);			
	
	//jlgka1 TFS 45048 --&gt;
	//initialised variable value from realTI
	updCertifiedName 	:= _realTI.weightCertifiedReference;
	updAuthorisedName 	:= _realTI.weightCertifiedName;
	
	vgmDetails 			:= _realTI.getMyVGMDetails();
	
	if vgmDetails &lt;&gt; null then
		updAuthSig 		:= vgmDetails.vgmAuthSignature;
		updCommsType 	:= vgmDetails.vgmCommsType;
		updDocDetails 	:= vgmDetails.vgmDocumentDetails;
		updEdiTrans 	:= vgmDetails.vgmEDITransmission;			
		updEmail 		:= vgmDetails.vgmElectronicMail;
		updMail 		:= vgmDetails.vgmMail;
		updPhone 		:= vgmDetails.vgmPhone;
		updFax 			:= vgmDetails.vgmTelefax;
		updTelephone 	:= vgmDetails.vgmTelephone;
		updDocDT 		:= vgmDetails.vgmDocsIssuedDT;
		updDeterDT 		:= vgmDetails.vgmDeterminationDT;
	endif;
	
	//Override variable value with EDI value only if they exists.
	if _ediPrenoteTI.weightCertifiedReference &lt;&gt; null then
		updCertifiedName := _ediPrenoteTI.weightCertifiedReference;
	endif;
	
	if _ediPrenoteTI.weightCertifiedName &lt;&gt; null then
		updAuthorisedName := _ediPrenoteTI.weightCertifiedName;
	endif;
	
	if _ediPrenoteTI.vgmAuthSignature &lt;&gt; null then
		updAuthSig := _ediPrenoteTI.vgmAuthSignature;
	endif;
	
	if _ediPrenoteTI.vgmCommsType &lt;&gt; null then
		updCommsType := _ediPrenoteTI.vgmCommsType;
	endif;
	
	if _ediPrenoteTI.vgmDocumentDetails &lt;&gt; null then
		updDocDetails := _ediPrenoteTI.vgmDocumentDetails;
	endif;
	
	if _ediPrenoteTI.vgmEDITransmission &lt;&gt; null then
		updEdiTrans := _ediPrenoteTI.vgmEDITransmission;
	endif;
	
	if _ediPrenoteTI.vgmElectronicMail &lt;&gt; null then
		updEmail := _ediPrenoteTI.vgmElectronicMail;
	endif;
	
	if _ediPrenoteTI.vgmMail &lt;&gt; null then
		updMail := _ediPrenoteTI.vgmMail;
	endif;
	
	if _ediPrenoteTI.vgmPhone &lt;&gt; null then
		updPhone := _ediPrenoteTI.vgmPhone;
	endif;
	
	if _ediPrenoteTI.vgmTelefax &lt;&gt; null then
		updFax := _ediPrenoteTI.vgmTelefax;
	endif;
	
	if _ediPrenoteTI.vgmTelephone &lt;&gt; null then
		updTelephone := _ediPrenoteTI.vgmTelephone;
	endif;
	
	if _ediPrenoteTI.vgmDocsIssuedDT &lt;&gt; null then
		updDocDT := _ediPrenoteTI.vgmDocsIssuedDT;
	endif;
	
	if _ediPrenoteTI.vgmDeterminationDT &lt;&gt; null then
		updDeterDT := _ediPrenoteTI.vgmDeterminationDT;
	endif;
	
	_realTI.setMyVGMDetails(updCertifiedName, 
							updAuthorisedName,			
							updAuthSig, 
							updCommsType, 
							updDocDetails,		
							updEdiTrans, 
							updEmail, 
							updMail,			
							updPhone, 
							updFax, 
							updTelephone, 						
							updDocDT, 
							updDeterDT, 
							updController);
	//jlgka1 TFS 45048 &lt;--
	_realTI.setTotalWeightWithoutTrans(_ediPrenoteTI.weight);
	if _ediPrenoteTI.tareWeight &gt; 0 then // --&gt; TFS 45766 - EDIPrenoteTIs without total weight won't get here...
		_realTI.setWeightTare(_ediPrenoteTI.tareWeight);
		_realTI.setWeightCargo(_ediPrenoteTI.weight - _ediPrenoteTI.tareWeight); // set cargo weight
	endif; // &lt;-- TFS 45766					
	
epilog

	delete updController;

end;</source>
        <Parameter name="_realTI" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_ediPrenoteTI" type="CM_EDIPrenoteTI" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateCountry" id="8a2ad6a0-7ad3-4ede-a03c-1bf358600284">
        <source>utlUpdateCountry(cmifCountry : CMIF_Country; pProxyCountry:CM_Country; _passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	cancelSave:Boolean;
	realCountry:CM_Country;
	expectedEdition:Integer;
	aPort : CM_Port;
	itemAudit : CM_UpdateTransactionAuditAgent;
	allRegions : CM_CountryRegionByCode;
	region		: CM_CountryRegion;
	allAudits	: ObjectArray;
	index		: Integer;
begin

	self.initialiseActivity();

	pProxyCountry.raiseExceptionIfNotProxy(method);

	app.setContinueCMExceptions(true);

	pProxyCountry.pxyGetRealObjectAndEdition(realCountry, expectedEdition);
	
	if realCountry = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_Country.name, null, null);
		return;
	endif;

	app.myValUA.valCountry(realCountry, pProxyCountry);
	
	if (not self.checkValidationWithPassport(_passport)) then
		return;		// note that this gets "ignored" in the eplog
	endif;
	
	create allRegions transient;
	create allAudits transient;

	app.setContinueCMExceptions(false);

	exclusiveLock(realCountry);

	if _passport.noErrors and realCountry.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'country', null, null);
		return;
	endif;
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realCountry, true);
		
		//03/08/2023	navkc1	CR 59552   Task 59554
		if realCountry.myCountryRegion &lt;&gt; pProxyCountry.myCountryRegion then
			
			if realCountry.myCountryRegion &lt;&gt; null then
				allRegions.add(realCountry.myCountryRegion);
			endif;
			
			if pProxyCountry.myCountryRegion &lt;&gt; null then
				allRegions.add(pProxyCountry.myCountryRegion);
			endif;
			
			foreach region in allRegions do
				create itemAudit transient;
				itemAudit.audUpdateGeneric(region, true);
				allAudits.add(itemAudit);
			endforeach;
		endif;
	endif;
	
	if _passport.noErrors then
		realCountry.setForUpdate(pProxyCountry);
		foreach aPort in realCountry.ports do
			aPort.setMyCountry(null);
		endforeach;
		
		foreach aPort in cmifCountry.allRealPorts do
			aPort.setMyCountry(realCountry);
		endforeach;
	
	endif;

	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realCountry, false);
		
		//03/08/2023	navkc1	CR 59552   Task 59554
		foreach region in allRegions do
			index += 1;
			itemAudit := allAudits[index].CM_UpdateTransactionAuditAgent;
			itemAudit.audUpdateGeneric(region, false);
			delete itemAudit;
		endforeach;
	endif;

epilog
	delete allRegions;
	delete allAudits;
end;</source>
        <Parameter name="cmifCountry" type="CMIF_Country"/>
        <Parameter name="pProxyCountry" type="CM_Country"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateCountryRegion" id="2bb11e93-8018-41dc-8e61-06565a4badbd">
        <updating/>
        <source>utlUpdateCountryRegion(_pxyCountryRegion : CM_CountryRegion; _passport : CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03/08/2023	navkc1	CR 59552   Task 59554: Jade CustDocs - Country Region TRX

*/

vars
	expectedEdition 		: Integer;
	realCountryRegion		: CM_CountryRegion;
	itemAudit				: CM_UpdateTransactionAuditAgent;
	country					: CM_Country;
	allCountries			: CM_CountryByCodeDict;
	allAudits				: ObjectArray;
	index					: Integer;
begin
	self.initialiseActivity();

	_pxyCountryRegion.raiseExceptionIfNotProxy(method);

	app.setContinueCMExceptions(true);
	
	_pxyCountryRegion.pxyGetRealObjectAndEdition(realCountryRegion, expectedEdition);
	
	if realCountryRegion = null then
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_CountryRegion.name, null, null);
	endif;
	
	app.myValUA.valCountryRegion(_pxyCountryRegion, realCountryRegion);
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);

	exclusiveLock(realCountryRegion);
	
	create allAudits transient;
	create allCountries transient;
	
	_pxyCountryRegion.allCountries.copy(allCountries);
	realCountryRegion.allCountries.copyNoDuplicates(allCountries, false);
	
	if _passport.noErrors() then
		self.myUpdateAuditAgent.audUpdateGeneric(realCountryRegion, true);
		
		foreach country in allCountries do
			create itemAudit transient;
			itemAudit.audUpdateGeneric(country, true);
			allAudits.add(itemAudit);
		endforeach;
		
	endif;
	
	if _passport.noErrors() then
		realCountryRegion.setForUpdate(_pxyCountryRegion);
	endif;
	
	if _passport.noErrors() then
		self.myUpdateAuditAgent.audUpdateGeneric(realCountryRegion, false);
		
		foreach country in allCountries do
			index += 1;
			itemAudit := allAudits[index].CM_UpdateTransactionAuditAgent;
			itemAudit.audUpdateGeneric(country, false);
			delete itemAudit;
		endforeach;
		
	endif;
epilog
	delete allAudits;
	delete allCountries;
end;</source>
        <Parameter name="_pxyCountryRegion" type="CM_CountryRegion"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateCraneMoveRates" id="95b6b807-1cc7-4106-95e3-25f60719032e">
        <source>utlUpdateCraneMoveRates(_pxyCraneMoveRates : CM_CraneMoveRates input;
						_passport : CM_Passport input);
/*

Purpose:			


Return Value:		


Date		Who		Reason
01 February 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars
	realCraneMoveRate : CM_CraneMoveRates;
begin
	self.initialiseActivity();
	
	app.setContinueCMExceptions(true);
	
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);

	realCraneMoveRate:=app.myProxyManager.getRealObject(_pxyCraneMoveRates).CM_CraneMoveRates;
	
	if realCraneMoveRate = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_CraneMoveRates.name, null, null);
		return;
	endif;
	
	realCraneMoveRate.setForUpdate(_pxyCraneMoveRates);

	

epilog

end;</source>
        <Parameter name="_pxyCraneMoveRates" type="CM_CraneMoveRates" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateCraneSeedJobNumber" id="b5ceaf1b-8590-4325-a690-944da5fd65b1">
        <source>utlUpdateCraneSeedJobNumber(_crane: CM_Crane; _seedJobNum: Integer;_passport: CM_Passport input);
// ---------------------------------------------------------------------------
// Created:		July 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars
//	realCellularVoyage 	: CM_CellularVoyage;
	crane				: CM_Crane;
begin

	self.initialiseActivity();

//	realCellularVoyage := _realCellularVoyage;
	crane := _crane;
	
	if crane = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_Crane.name, null, null);
		return;
	endif;

	exclusiveLock(crane);

	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(crane, true);
	endif;

	if _passport.noErrors then
		crane.setForUpdateSeedJobNum(_seedJobNum);
	endif;

	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(crane, false);
	endif;

end;</source>
        <Parameter name="_crane" type="CM_Crane"/>
        <Parameter name="_seedJobNum" type="Integer"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateCreditNote" id="164870c0-f52b-4063-87b7-43faceca32f4">
        <source>utlUpdateCreditNote(_allInvoices : CM_InvoiceSet input; _pxyCreditNote : CM_Invoice input; _pExistingCreditNote : CM_Invoice output; _passport : CM_Passport input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 January 2023	navkc1	Initial creation TFS CR 55305 Task 55536: UI - Invoice Credit Note UI
30/01/2023		navkc1	TFS CR 55305 Task 55535: Jade - Invoice Credit Note Audits
20/07/2023		navkc1	Bug 58995: EUP - Inv Maint Credit Notes
*/

vars
	expectedEdition 	: Integer;
	invoice,
	otherInvoice		: CM_Invoice;
	allInvoiceToUnlink,
	allOtherInvToNotify	: CM_InvoiceSet;
	itemAudit 			: CM_UpdateTransactionAuditAgent;
	debtorChange : Boolean;	
begin
	self.initialiseActivity();

	_pxyCreditNote.raiseExceptionIfNotProxy(method);

	app.setContinueCMExceptions(true);
	
	_pxyCreditNote.pxyGetRealObjectAndEdition(_pExistingCreditNote, expectedEdition);
	
	foreach invoice in _allInvoices do
		app.myValUA.valCreditNoteFromInvoice(invoice);
	endforeach;
	
	//20/07/2023	navkc1	Bug 58995
	app.myValUA.valInvoice(_pExistingCreditNote, _pxyCreditNote);
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);
	
	create allInvoiceToUnlink transient;
	create allOtherInvToNotify transient;
	
	// Get list of invoices to unlink
	_pExistingCreditNote.allOtherInvoices.copy(allInvoiceToUnlink);
	
	create itemAudit transient;
	
	itemAudit.audUpdateGeneric(_pExistingCreditNote, true);
	
	// Link the invoices
	foreach invoice in _allInvoices do
		// If the invoice is in the unlink list, remove it
		if allInvoiceToUnlink.includes(invoice) then
			allInvoiceToUnlink.remove(invoice);
		endif;
		//30/01/2023		navkc1	TFS CR 55305 Task 55535
		self.myUpdateAuditAgent.audUpdateGeneric(invoice, true);
		
		otherInvoice := invoice.myOtherInvoice;
		if otherInvoice &lt;&gt; null then
			allOtherInvToNotify.addNoDuplicates(otherInvoice, false);
		endif;
		
		invoice.setMyOtherInvoice(_pExistingCreditNote);
		self.myUpdateAuditAgent.audUpdateGeneric(invoice, false);
		invoice.causeEvent(_passport.myTerminal.getTerminalEvent(Event_InvoiceUpdate), false, invoice);
	endforeach;
	
	// Unlink other invoices
	foreach invoice in allInvoiceToUnlink do
		//30/01/2023		navkc1	TFS CR 55305 Task 55535
		self.myUpdateAuditAgent.audUpdateGeneric(invoice, true);
		
		otherInvoice := invoice.myOtherInvoice;
		if otherInvoice &lt;&gt; null then
			allOtherInvToNotify.addNoDuplicates(otherInvoice, false);
		endif;
		
		invoice.setMyOtherInvoice(null);
		self.myUpdateAuditAgent.audUpdateGeneric(invoice, false);
		invoice.causeEvent(_passport.myTerminal.getTerminalEvent(Event_InvoiceUpdate), false, invoice);
	endforeach;
	
	//30/01/2023		navkc1	TFS CR 55305 Task 55535
	if _passport.noErrors() then
		self.myUpdateAuditAgent.audUpdateGeneric(_pExistingCreditNote, true);
	endif;
	
	if _passport.noErrors() then
		debtorChange := _pExistingCreditNote.debtor &lt;&gt; _pxyCreditNote.debtor; // ### TFS BUG 58791 22JUN2023 NAVAB1
		_pExistingCreditNote.debtor := _pxyCreditNote.debtor;
		_pExistingCreditNote.setInvoiceType(_pxyCreditNote.invoiceType);
		_pExistingCreditNote.status := _pxyCreditNote.status;
		_pExistingCreditNote.setMyBillingAddress(_pxyCreditNote.myBillingAddress);
		_pExistingCreditNote.fromDT := _pxyCreditNote.fromDT;
		// ### TFS BUG 58791 22JUN2023 NAVAB1
		if debtorChange then
			_pExistingCreditNote.updateDebtorInvoiceLines();
		endif;
		//20/07/2023	navkc1	Bug 58995
		_pExistingCreditNote.setForUpdate(_pxyCreditNote);
		_pExistingCreditNote.setForUpdateSeparations(_pxyCreditNote);
	endif;
	
	itemAudit.audUpdateGeneric(_pExistingCreditNote, false);
	
	//30/01/2023		navkc1	TFS CR 55305 Task 55535
	if _passport.noErrors() then
		self.myUpdateAuditAgent.audUpdateGeneric(_pExistingCreditNote, false);
		_pExistingCreditNote.causeEvent(_passport.myTerminal.getTerminalEvent(Event_InvoiceUpdate), false, _pExistingCreditNote);
		
		foreach otherInvoice in allOtherInvToNotify do
			otherInvoice.causeEvent(_passport.myTerminal.getTerminalEvent(Event_InvoiceUpdate), false, otherInvoice);
		endforeach;
	endif;
	
epilog
	delete allInvoiceToUnlink;
	delete allOtherInvToNotify;
	delete itemAudit;
end;</source>
        <Parameter name="_allInvoices" type="CM_InvoiceSet" usage="input"/>
        <Parameter name="_pxyCreditNote" type="CM_Invoice" usage="input"/>
        <Parameter name="_pExistingCreditNote" type="CM_Invoice" usage="output"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateCurrencyCode" id="99eba2e9-5b23-4efd-a7ab-f2865aa257a8">
        <source>utlUpdateCurrencyCode(_proxyCode : CM_CurrencyCode ; _passport : CM_Passport input);

vars
	realCode 		: CM_CurrencyCode;
	expectedEdition	: Integer;
	
begin

	self.initialiseActivity();

	_proxyCode.raiseExceptionIfNotProxy(method);

	app.setContinueCMExceptions(true);

	_proxyCode.pxyGetRealObjectAndEdition(realCode, expectedEdition);
	
	if realCode = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_CurrencyCode.name, null, null);
		return;
	endif;

	app.myValUA.valCurrencyCode (realCode, _proxyCode );
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;

	app.setContinueCMExceptions(false);

	exclusiveLock(realCode);

	if _passport.noErrors and realCode.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'Currency Code', null, null);
		return;
	endif;
	
	if _passport.noErrors then
		realCode.setForUpdate(_proxyCode);
	endif;

end;</source>
        <Parameter name="_proxyCode" type="CM_CurrencyCode"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
