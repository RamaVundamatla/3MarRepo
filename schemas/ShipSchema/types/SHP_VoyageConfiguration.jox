	self.setEditViewMode();
end;</source>
    </JadeMethod>
    <JadeMethod name="doResize" id="d60d455b-7900-4913-a348-fce2517f1c5f">
        <updating/>
        <source>doResize() updating;
//
//20 Jan 2017	cnwrs1	TFS 3137 - resize the form when show captions is on
//
vars

begin
	inheritMethod();
	self.mulYACriteria.repositionAfterResize();
	self.fldVoyageConfig.top := self.frmToolbar.height; 						// ### 05Oct2021 NAVPW1
	self.fldVoyageConfig.height := self.clientHeight - self.frmToolbar.height; // ### 05Oct2021 NAVPW1
end;
</source>
    </JadeMethod>
    <JadeMethod name="doSaveColourCoding" id="01110b81-e074-4e65-9432-9d86515f6192">
        <updating/>
        <source>doSaveColourCoding() updating;
// --------------------------------------------------------------------------------
// Created:		3 December 2009 by cnwjo3
//
// Purpose:		Save the values in the combo box and the selected list box
//
vars
	opCriteriaColl : CM_YACriteriaTypeArray;
	
	groupLabelCriteriaColl : CM_YACriteriaTypeArray;
	pxyYAVoyage : CM_YAVoyageConfig;
	theReturn : Integer;
	ct : CM_YACriteriaType;
begin
	create opCriteriaColl transient;
	create groupLabelCriteriaColl transient;
	
	self.mulYACriteria.getSelected(opCriteriaColl);

	
	if self.myYAVoyageConfig = null then
		app.raiseUnexpectedProgramError(class.name, method.name, "Terminal " &amp; self.myTerminal.code &amp; " has no voyage YA Config.");
		return;
	else
		pxyYAVoyage := app.createUpdateProxy(self.myYAVoyageConfig).CM_YAVoyageConfig;
	endif;
	
	if self.cmbDefaultColour.text &lt;&gt; null then
		ct := self.getYACriteriaTypeByDescription(self.cmbDefaultColour.text);
	endif;
	
	pxyYAVoyage.setProxyVoyage(opCriteriaColl, groupLabelCriteriaColl, Red, ct, null);
	
	while true do
		app.myTrxUA.trxUpdateYAIMEXConfig(pxyYAVoyage, app.myPassport);
		if app.myPassport.trxCompletedOK then
			global.beep;
			break;
		else
			theReturn := app.showErrorWarningDialog(app.getErrorString(Rail_configuration),  app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			return;
		endif;
		break;
	endwhile;
epilog
	delete opCriteriaColl;
	delete groupLabelCriteriaColl;
	delete pxyYAVoyage;
end;</source>
    </JadeMethod>
    <JadeMethod name="doSaveConfigTerm" id="7d6c08ec-7018-4ac7-9d98-95b8e818ed02">
        <updating/>
        <source>doSaveConfigTerm() updating;
// --------------------------------------------------------------------------------
// Created:		3 December 2009 by cnwjo3
//
// Purpose:		Save the CMIF_ConfigTerminal object.  The process is that we don't actually update the object while
//				the user interacts with the form.  All values are collected at the end and the transient object is updated here
// 
// Changed On	By			Reason
// ----------	--------	-------------------------------------------------------------------
// 26/10/2010	cnwdap1		PAR #23794 CCMS MES 1102 added "Show Release Requests on Ship Load List" option
// 02/06/2015	cnwdap1		PAR #36269 TFS 331 Save new terminal config options for weight and height dispaly
// 14/09/2016   cnwma1		2666:PAR38198 PTL - Delays not printing end date and time
// 26/04/2017	cnwdap1		TFS 4221 Add new terminal config option "Cannot Update External Voyage Code"
// 11/06/2016	jlgdap1		TFS 44554 AAT Stevedore Data Access
// 06/11/2019	jlgdap1		TFS 46405 AAT Flat Rack and OOG in LOLO Planning Screen
// 03/06/2020   cnwma1 	    ChangeRequest 49400: ASPA - Invoice Enhancements for Barges
// 11/03/2025	navlw1		JIRA-34230: MTN | Prenote Voyage Cut Offs - Terminal Configuration UI
// 04/04/2025	navlw1		JIAR-34523: MTN | New Terminal Config for Auto Adjusting Cut-offs
vars
	tableRowObj	: EntTableRow;
	configTbl   : CM_EntryTable;
	config 	    : CMIF_ConfigTerminal;
	result 		: Integer;
begin
	configTbl := self.tblConfigTerm;
	config := self.cmif_ConfigTerminal;

	
	config.sequenceJobInCustomOrder			:= configTbl.getValueByName(ETRow_SequenceJobInCustomOrder).Boolean;
	config.sequenceUnderDeckSeaToWharf		:= configTbl.getValueByName(ETRow_SeqUnderDeckSeaToWharf).Boolean;
	config.seqGroupSingleLifts  			:= configTbl.getValueByName(ETRow_SeqGroupSingleLifts).Boolean;
	config.seperateLengthSequencing  		:= configTbl.getValueByName(ETRow_SeperateLengthSequencing).Boolean;
	config.autoCustomSeqSingleFirst  		:= configTbl.getValueByName(ETRow_AutoCustomSeqSingleFirst).Boolean;
	config.shipAllowLoadifnoDisch  		:= configTbl.getValueByName(ETRow_ShipAllowLoadifnoDisch).Boolean; // PAR 25513
	config.startSeqNum20_OverDeck  			:= configTbl.getValueByName(ETRow_StartSeqNum20_OverDeck).Integer;
	config.startSeqNum20_UnderDeck  		:= configTbl.getValueByName(ETRow_StartSeqNum20_UnderDeck).Integer;
	config.startSeqNum40_OverDeck  			:= configTbl.getValueByName(ETRow_StartSeqNum40_OverDeck).Integer;
	config.startSeqNum40_UnderDeck  		:= configTbl.getValueByName(ETRow_StartSeqNum40_UnderDeck).Integer;
	config.sameSeqNumberTwinLift  			:= configTbl.getValueByName(ETRow_SameSeqNumberTwinLift).Boolean;
	config.shipRemoveLeadingZeros  			:= configTbl.getValueByName(ETRow_ShipRemoveLeadingZeros).Boolean;
	config.useReadyToShip  					:= configTbl.getValueByName(ETRow_UseReadyToShip).Boolean;
	config.readyToShipPlanning  			:= configTbl.getValueByName(ETRow_ReadyToShipPlanning).Boolean;
	config.shipJobSeed  					:= configTbl.getValueByName(ETRow_ShipJobSeed).Integer;
	config.shipJobNumberIncrement  			:= configTbl.getValueByName(ETRow_ShipJobNumberIncrement).Integer;
	config.separateOnUnderDeckJobs  		:= configTbl.getValueByName(ETRow_SeparateOnUnderDeckJobs).Boolean;
	config.jobAdditionalTime  				:= configTbl.getValueByName(ETRow_JobAdditionalTime).Integer;
	config.shipSLiftIfDiffHeights  			:= configTbl.getValueByName(ETRow_ShipSLiftIfDiffHeights).Boolean;
	config.shipSLiftIfTLWgtExced  			:= configTbl.getValueByName(ETRow_ShipSLiftIfTLWgtExced).Boolean;
	config.craneLaneDescription 			:= app.craneLaneDescStringToEnum(configTbl.getValueByName(ETRow_CraneLaneDescription).String);
	config.reportGrpDescriptionType 			:= app.repGrpDescTypeStringToEnum(configTbl.getValueByName(ETRow_ReportGrpDescriptionType).String); // PAR 34184
	config.voyAllocSortOrder 			:= app.voyAllocSortOrderStringToEnum(configTbl.getValueByName(ETRow_VoyAllocSortOrder).String); // PAR 34184
	config.allocateCraneLane  				:= configTbl.getValueByName(ETRow_AllocateCraneLane).Boolean;
	config.shipShowYardPosition  			:= configTbl.getValueByName(ETRow_ShipShowYardPosition).Boolean;
	config.shipTransitBoxColor  			:= configTbl.getValueByName(ETRow_ShipTransitBoxColor).Integer;
	config.autoLinkSlotJobCreate  			:= configTbl.getValueByName(ETRow_AutoLinkSlotJobCreate).Boolean;
	config.autoLinkSlotPlan  				:= configTbl.getValueByName(ETRow_AutoLinkSlotPlan).Boolean;
	config.autoLinkSlotJobCreateSOB  		:= configTbl.getValueByName(ETRow_AutoLinkSlotJobCreateSOB).Boolean;
	config.autoLinkSlotPlanSOB  			:= configTbl.getValueByName(ETRow_AutoLinkSlotPlanSOB).Boolean;
	config.shipShowISOType  				:= configTbl.getValueByName(ETRow_ShipShowISOType).Boolean;
	config.shipImportTaskOptions  			:= configTbl.getValueByName(ETRow_ShipImportTaskOptions).Boolean;
	config.hiCubePlanningWarning			:= app.hiCubePlanWarnStringToEnum(configTbl.getValueByName(ETRow_HiCubePlanningWarning).String);// 05/11/2010 cnwas3 par 26168
	config.craneClearance  					:= configTbl.getValueByName(ETRow_CraneClearance).Integer;
	config.oOWUseSimpleNonPlanned  			:= configTbl.getValueByName(ETRow_OOWUseSimpleNonPlanned).Boolean;
	config.oOWSimpleGeneralLabel  			:= configTbl.getValueByName(ETRow_OOWSimpleGeneralLabel).String;
	config.oOWSimplePoweredLabel  			:= configTbl.getValueByName(ETRow_OOWSimplePoweredLabel).String;
	config.autoCreateBoomUpJob  			:= configTbl.getValueByName(ETRow_AutoCreateBoomUpJob).Boolean;
	config.autoCreateHatchLidJob  			:= configTbl.getValueByName(ETRow_AutoCreateHatchLidJob).Boolean;
	config.autoCreateLongTravelJob  		:= configTbl.getValueByName(ETRow_AutoCreateLongTravelJob).Boolean;
	config.autoOOWJobRenumber  				:= configTbl.getValueByName(ETRow_AutoOOWJobRenumber).Boolean;
	config.autoLoadPlanAt3Height  			:= configTbl.getValueByName(ETRow_AutoLoadPlanAt3Height).Boolean;
	config.transhipConsign  				:= self.cmbTranshipConsi.listObject.CM_ConsigneeConsignor;
	config.transhipCreateRemarks  			:= configTbl.getValueByName(ETRow_TranshipCreateRemarks).Boolean;
	config.shipSeqShtMedium  				:= configTbl.getValueByName(ETRow_ShipSeqShtMedium).String;
	config.shipSeqShtLarge  				:= configTbl.getValueByName(ETRow_ShipSeqShtLarge).String;
	config.shipSeqShtXLarge  				:= configTbl.getValueByName(ETRow_ShipSeqShtXLarge).String;
	config.shpTranshipTBAMatch  				:= configTbl.getValueByName(ETRow_ShpTranshipTBAMatch).Boolean; // TFS 45590
	
	// PAR 31661
	config.shpSeqShtMediumRORO  				:= configTbl.getValueByName(ETRow_ShpSeqShtMediumRORO).String;
	config.shpSeqShtLargeRORO  				:= configTbl.getValueByName(ETRow_ShpSeqShtLargeRORO).String;
	config.shpSeqShtXLargeRORO  				:= configTbl.getValueByName(ETRow_ShpSeqShtXLargeRORO).String;
	config.shipSLiftIfTLWELoadPlan  				:= configTbl.getValueByName(ETRow_ShipSLiftIfTLWELoadPlan).Boolean;

	config.showOnlyVoyageCode  				:= configTbl.getValueByName(ETRow_ShowOnlyVoyageCode).Boolean;
	config.shipDelBookRefsOnDepart  		:= configTbl.getValueByName(ETRow_ShipDelBookRefsOnDepart).Boolean;
	config.shipLinePortGroupsForInv  		:= configTbl.getValueByName(ETRow_ShipLinePortGroupsForInv).Boolean;
	config.showPortOfCallTranship  			:= configTbl.getValueByName(ETRow_ShowPortOfCallTranship).Boolean;
	config.isShipLanderSealCheck  			:= configTbl.getValueByName(ETRow_IsShipLanderSealCheck).Boolean;
	
	config.shipCloseBookVoyDepart := configTbl.getValueByName(ETRow_ShipCloseBookVoyDepart).Boolean; // PAR 36155
	config.shipNoVoyageCodeUpdate := configTbl.getValueByName(ETRow_ShipNoVoyageCodeUpdate).Boolean; // PAR 36155
	
	// PAR #23794 CCMS MES 1102
	config.showRelReqOnShipLoadList			:= configTbl.getValueByName(ETRow_RelReqOnShipLoadList).Boolean;
	
	//PAR 7749 ccms 1035 cnwas3
	//config.shpLinearMeterWidthRORO 			:= configTbl.getValueByName(ETRow_ShpLinearMeterWidthRORO).Decimal;
	config.shpLinearMeterWidthRORO 			:= configTbl.getValueByName(ETRow_ShpLinearMeterWidthRORO).String.asDecimalJMT; //12 Sep 2012	NDL	Par 30350
	
	//28 Mar 2011	NDL	Par 27203
	config.fortyWeightForwardCell			:= configTbl.getValueByName(ETRow_FortyWeightForwardCell).Boolean;
	
	//cnwmc5 - 28 July 2014 - PAR 34565
	config.calcRatesFromMoves				:= configTbl.getValueByName(ETRow_CalcRatesFromMoves).Boolean;

	config.shipCutoffsShowError				:= configTbl.getValueByName(ETRow_ShipCutoffsShowError).Boolean; // PAR 35397
	
	config.showCargoIconsInPlan				:= configTbl.getValueByName(ETRow_ShowCargoIconsInPlan).Boolean;	// PAR #36269
	config.showHeightsLOLOPlanning			:= configTbl.getValueByName(ETRow_ShowHeightsLOLOPlanning).Boolean;	// PAR #36269
	config.showWeightsLOLOPlanning			:= configTbl.getValueByName(ETRow_ShowWeightsLOLOPlanning).Boolean; // PAR #36269
	
	config.etaEtdMandatory			 := configTbl.getValueByName(ETRow_EtaEtdMandatory).Boolean;					   //01 Jul 2016	NDL
	config.shipLoadPlanDLRShowError  := configTbl.getValueByName(ETRow_ShipLoadPlanDLRShowError).Boolean;
	config.delayDefaultEstimateEnd   :=  configTbl.getValueByName(ETRow_DelayDefaultEstimateEnd).Boolean; 			   //14/09/2016 cnwma1 TFS #2666 PAR #38198
	
	config.defVoyageRep1 		    := configTbl.getValueByName(ETRow_DefVoyageRep1).String;						   //02 Feb 2017	NDL	TFS 3216/3047
	config.defVoyageRep2 			:= configTbl.getValueByName(ETRow_DefVoyageRep2).String;						   //02 Feb 2017	NDL	TFS 3216/3047
	config.unassignResetsPrevVals   := configTbl.getValueByName(ETRow_UnassignResetsPrevVals).Boolean;				   //02 Feb 2017	NDL	TFS 3216/3047
	config.closeShipReqsOnDepart    := configTbl.getValueByName(ETRow_CloseShipReqsOnDepart).Boolean;				   //02 Feb 2017	NDL	TFS 3216/3047
	config.autoGenIDsForOnShip      := configTbl.getValueByName(ETRow_AutoGenIDsForOnShip).Boolean;					   //02 Feb 2017	NDL	TFS 3216/3047
	config.cannotUpdateExternalCode := configTbl.getValueByName(ETRow_CannotUpdateExternalCode).Boolean;			   // TFS 4221
	config.cannotUpdateVoyGrpCode   := configTbl.getValueByName(ETRow_CannotUpdateVoyGrpCode).Boolean;				   //03/06/2020 cnwma1 Tfs #49400
	config.hhShowUnplanOptions 	    := configTbl.getValueByName(ETRow_HhShowUnplanOptions).Boolean;					   // 8/9/17 MAP TFS6818
	config.noVoyTradeVal 			:= configTbl.getValueByName(ETRow_NoVoyTradeVal).Boolean;						   //06 Jun 2018	NDL	TFS 38905
	config.showOnlyDoorDirections   := configTbl.getValueByName(ETRow_ShowOnlyDoorDirections).Boolean;				   //06 Jun 2018	NDL	TFS 38905
	config.totDaysReqAddForCargo 	:= configTbl.getValueByName(ETRow_TotDaysReqAddForCargo).Decimal;				   //27 Aug 2018	NDL	TFS 40267
	
	config.shipCraneOpHrsSecRole := app.myRoot.allRoles[configTbl.getValueByName(ETRow_ShipCraneOpHrsSecRole).String]; // TFS 44554
	config.mandatoryOneStevedore := configTbl.getValueByName(ETRow_MandatoryOneStevedore).Boolean;						// TFS 44554
	
	config.considerHazAsSpecialStow := configTbl.getValueByName(ETRow_ConsiderHazAsSpecialStow).Boolean;	// TFS 46405
	config.considerODAsSpecialStow := configTbl.getValueByName(ETRow_ConsiderODAsSpecialStow).Boolean;		// TFS 46405
	
	config.shipCutoffsForPrenotes := configTbl.getValueByName(ETRow_ShipCutoffsForPrenotes).Boolean; // #JIRA-34230 navlw1 11/03/2025
	config.shipCutoffsAutoAdjust := configTbl.getValueByName(ETRow_ShipCutoffsAutoAdjust).Boolean; // #JIRA-34523 navlw1 04/04/2025
	
	//27 Aug 2018	NDL	TFS 40267
	if self.cmbRoundHrs.listIndex &lt; 1 then
		config.totDaysReqRoundedToHours := 0;
	else
		config.totDaysReqRoundedToHours := self.cmbRoundHrs.listData;
	endif;
	
	config.voyageRetroDefault := configTbl.getValueByName(ETRow_VoyageRetroDefault).Boolean;	//17 May 2021	NDL	TFS 51199
	
	while true do
		app.myTrxUA.trxUpdateConfig(config,self.myTerminal, self.expectedEdition,app.myPassport);
		if app.myPassport.trxCompletedOK() then
			break;
		else
			result := app.showErrorWarningDialog(self.caption, app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and result = IDOK then
				app.myPassport.warningsAcknowledged := true;
				continue;
			endif;
			return;
		endif;
		break;
	endwhile;

	if app.getMyTerminalDO_NOT_USE() &lt;&gt; null then
		self.myTerminal := app.getMyTerminalDO_NOT_USE();
		self.expectedEdition := self.myTerminal.edition;
	else
		//basically we need to set the edition of the cm_terminal object
		//if we can't then we can't resave the config information....
		app.msgBox(app.getErrorString3(UNEXPECTED_PROGRAM_ERROR,self.name,method.name,"CM_Terminal null"),"",0);
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="fldVoyageConfig_querySheetChg" id="37cf9000-8c76-44d2-9ad6-516647fc6c31">
        <controlMethod name="CMUI_Folder::querySheetChg"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>fldVoyageConfig_querySheetChg(folder: Folder; newSheet: Sheet):Boolean updating;
// --------------------------------------------------------------------------------
// Created:		30 November 2009 by cnwjo3
//
vars

begin
	return sheetChange(newSheet.CMUI_Sheet);
end;</source>
        <Parameter name="folder" type="Folder"/>
        <Parameter name="newSheet" type="Sheet"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getConfigTerminalProp" id="68f7bc98-bb92-4284-bc1c-627a3c2a0917">
        <source>getConfigTerminalProp(_attr : String) : String;
// --------------------------------------------------------------------------------
// Created:		30 November 2009 by cnwjo3
//
// Purpose:		This method gets the CMIF_ConfigTerminal property value from
//				an EntTableRow name.  Unfortunately it appears this enttables rows
//				do not exactly match up the constant names... weird....  so need to use compareGeneric
//
// Changed On	By			Reason
// ----------	--------	---------------------------------------------------------------------------
// 26/10/2010	cnwdap1		PAR #23794 CCMS MES 1102 Added "Show Release Requests on Ship Load List" option
// 02/06/2015	cnwdap1		PAR #36269 TFS 331 Show new config options for showing weights and heights
// 14/09/2016   cnwma1		2666:PAR38198 PTL - Delays not printing end date and time
// 26/04/2017	cnwdap1		TFS 4221 Add new terminal config option "Cannot Update External Voyage Code"
// 11/06/2019	jlgdap1		TFS 44554 AAT Stevedore Data Access
// 06/11/2019	jlgdap1		TFS 46405 AAT Flat Rack and OOG in LOLO Planning Screen
// 03/06/2020   cnwma1 		ChangeRequest 49400: ASPA - Invoice Enhancements for Barges
// 11/03/2025	navlw1		JIRA-34230: MTN | Prenote Voyage Cut Offs - Terminal Configuration UI
// 04/04/2025	navlw1		JIAR-34523: MTN | New Terminal Config for Auto Adjusting Cut-offs
//
vars
	value 		  : String;
	config 		  : CMIF_ConfigTerminal;
	craneDesc,
	hiCubeWarning : String;
begin
	config := self.cmif_ConfigTerminal;
	if _attr.compareGeneric(ETRow_ZTableBreak1,true,false,null) = 0 then   //its a heading break
		return null;
	elseif _attr.compareGeneric(ETRow_ShipExchIfStatusLoading,true,false,null) = 0 then // ### TFS CR 57138 TASK 57310 29MAR2023 NAVAB1
		return config.shipExchIfStatusLoading.String; // ### TFS CR 57138 TASK 57310 29MAR2023 NAVAB1
	elseif _attr.compareGeneric(ETRow_SequenceJobInCustomOrder,true,false,null) = 0 then
		return config.sequenceJobInCustomOrder.String;
	elseif _attr.compareGeneric(ETRow_ShipAllowLoadifnoDisch,true,false,null) = 0 then // PAR 25513
		return config.shipAllowLoadifnoDisch.String; // PAR 25513
	elseif _attr.compareGeneric(ETRow_SeqUnderDeckSeaToWharf,true,false,null) = 0 then
		return config.sequenceUnderDeckSeaToWharf.String;
	elseif _attr.compareGeneric(ETRow_SeqGroupSingleLifts,true,false,null) = 0 then
		return config.seqGroupSingleLifts.String;
	elseif _attr.compareGeneric(ETRow_SeperateLengthSequencing,true,false,null) = 0 then
		return config.seperateLengthSequencing.String;
	elseif _attr.compareGeneric(ETRow_AutoCustomSeqSingleFirst,true,false,null) = 0 then
		return config.autoCustomSeqSingleFirst.String;
	elseif _attr.compareGeneric(ETRow_StartSeqNum20_OverDeck,true,false,null) = 0 then
		return config.startSeqNum20_OverDeck.String;
	elseif _attr.compareGeneric(ETRow_StartSeqNum20_UnderDeck,true,false,null) = 0 then
		return config.startSeqNum20_UnderDeck.String;
	elseif _attr.compareGeneric(ETRow_StartSeqNum40_OverDeck,true,false,null) = 0 then
		return config.startSeqNum40_OverDeck.String;
	elseif _attr.compareGeneric(ETRow_StartSeqNum40_UnderDeck,true,false,null) = 0 then
		return config.startSeqNum40_UnderDeck.String;
	elseif _attr.compareGeneric(ETRow_SameSeqNumberTwinLift,true,false,null) = 0 then
		return config.sameSeqNumberTwinLift.String;
	elseif _attr.compareGeneric(ETRow_ShipRemoveLeadingZeros,true,false,null) = 0 then
		return config.shipRemoveLeadingZeros.String;
	elseif _attr.compareGeneric(ETRow_ZTableBreak2,true,false,null) = 0 then  //its a heading break;
		return null;
	elseif _attr.compareGeneric(ETRow_UseReadyToShip,true,false,null) = 0 then
		return config.useReadyToShip.String;
	elseif _attr.compareGeneric(ETRow_ReadyToShipPlanning,true,false,null) = 0 then
		return config.readyToShipPlanning.String;
	elseif _attr.compareGeneric(ETRow_ShipJobSeed,true,false,null) = 0 then
		return config.shipJobSeed.String;
	elseif _attr.compareGeneric(ETRow_ShipJobNumberIncrement,true,false,null) = 0 then
		return config.shipJobNumberIncrement.String;
	elseif _attr.compareGeneric(ETRow_SeparateOnUnderDeckJobs,true,false,null) = 0 then
		return config.separateOnUnderDeckJobs.String;
	elseif _attr.compareGeneric(ETRow_JobAdditionalTime,true,false,null) = 0 then
		return config.jobAdditionalTime.String;
	elseif _attr.compareGeneric(ETRow_ShipSLiftIfDiffHeights,true,false,null) = 0 then
		return config.shipSLiftIfDiffHeights.String;
	elseif _attr.compareGeneric(ETRow_ShipSLiftIfTLWgtExced,true,false,null) = 0 then
		return config.shipSLiftIfTLWgtExced.String;
	elseif _attr.compareGeneric(ETRow_CraneLaneDescription,true,false,null) = 0 then
		craneDesc :=app.craneLaneDescEnumToString(config.craneLaneDescription);
		self.myAssistant.comboBoxCraneLaneDescription(self.cmbCraneDesc, craneDesc);
		return craneDesc;
	elseif _attr.compareGeneric(ETRow_ReportGrpDescriptionType,true,false,null) = 0 then // PAR 34184
		craneDesc :=app.repGrpDescTypeEnumToString	(config.reportGrpDescriptionType);
		self.myAssistant.comboBoxReportGroupDescType(self.cmbRepGrpDescTyp, craneDesc); // PAR 34184
		return craneDesc; // PAR 34184
		
	
	elseif _attr.compareGeneric(ETRow_ShipCloseBookVoyDepart,true,false,null) = 0 then // PAR 34184
		return config.shipCloseBookVoyDepart.String; // PAR 36155
	elseif _attr.compareGeneric(ETRow_ShipNoVoyageCodeUpdate,true,false,null) = 0 then // PAR 34184
		return config.shipNoVoyageCodeUpdate.String; // PAR 36155
		
	elseif _attr.compareGeneric(ETRow_VoyAllocSortOrder,true,false,null) = 0 then // PAR 34184
		craneDesc :=app.voyAllocSortOrderEnumToString(config.voyAllocSortOrder);
		self.myAssistant.comboBoxVoyAllocSortOrder(self.cmbVoyAllocSort, craneDesc); // PAR 34184
		return craneDesc; // PAR 34184
		
		
		
	elseif _attr.compareGeneric(ETRow_AllocateCraneLane,true,false,null) = 0 then
		return config.allocateCraneLane.String;
	elseif _attr.compareGeneric(ETRow_ZTableBreak3,true,false,null) = 0 then //its a heading break
		return null;
	elseif _attr.compareGeneric(ETRow_ShipShowYardPosition,true,false,null) = 0 then
		return config.shipShowYardPosition.String;
	elseif _attr.compareGeneric(ETRow_ShipTransitBoxColor,true,false,null) = 0 then
		return config.shipTransitBoxColor.String;
	elseif _attr.compareGeneric(ETRow_AutoLinkSlotJobCreate,true,false,null) = 0 then
		return config.autoLinkSlotJobCreate.String;
	elseif _attr.compareGeneric(ETRow_AutoLinkSlotPlan,true,false,null) = 0 then
		return config.autoLinkSlotPlan.String;
	elseif _attr.compareGeneric(ETRow_AutoLinkSlotJobCreateSOB,true,false,null) = 0 then
		return config.autoLinkSlotJobCreateSOB.String;
	elseif _attr.compareGeneric(ETRow_AutoLinkSlotPlanSOB,true,false,null) = 0 then
		return config.autoLinkSlotPlanSOB.String;
	elseif _attr.compareGeneric(ETRow_ShipShowISOType,true,false,null) = 0 then
		return config.shipShowISOType.String;
	elseif _attr.compareGeneric(ETRow_ShipImportTaskOptions,true,false,null) = 0 then
		return config.shipImportTaskOptions.String;
	elseif _attr.compareGeneric(ETRow_HiCubePlanningWarning,true,false,null) = 0 then			// 05/11/2010 cnwas3 par 26168
		hiCubeWarning := app.hiCubePlanWarnEnumToString(config.hiCubePlanningWarning);
		self.myAssistant.comboBoxHiCubePlanningWarning(self.cmbHCPlanWarning, hiCubeWarning);
		return hiCubeWarning;
	elseif _attr.compareGeneric(ETRow_ZTableBreak4,true,false,null) = 0 then  //its a heading break
		return null;
	elseif _attr.compareGeneric(ETRow_CraneClearance,true,false,null) = 0 then
		return config.craneClearance.String;
	elseif _attr.compareGeneric(ETRow_OOWUseSimpleNonPlanned,true,false,null) = 0 then
		return config.oOWUseSimpleNonPlanned.String;
	elseif _attr.compareGeneric(ETRow_OOWSimpleGeneralLabel,true,false,null) = 0 then
		return config.oOWSimpleGeneralLabel.String;
	elseif _attr.compareGeneric(ETRow_OOWSimplePoweredLabel,true,false,null) = 0 then
		return config.oOWSimplePoweredLabel.String;
	elseif _attr.compareGeneric(ETRow_AutoCreateBoomUpJob,true,false,null) = 0 then
		return config.autoCreateBoomUpJob.String;
	elseif _attr.compareGeneric(ETRow_AutoCreateHatchLidJob,true,false,null) = 0 then
		return config.autoCreateHatchLidJob.String;
	elseif _attr.compareGeneric(ETRow_AutoCreateLongTravelJob,true,false,null) = 0 then
		return config.autoCreateLongTravelJob.String;
	elseif _attr.compareGeneric(ETRow_AutoOOWJobRenumber,true,false,null) = 0 then
		return config.autoOOWJobRenumber.String;
	elseif _attr.compareGeneric(ETRow_ZTableBreak5,true,false,null) = 0 then   //its a heading break
		return null;
	elseif _attr.compareGeneric(ETRow_AutoLoadPlanAt3Height,true,false,null) = 0 then
		return config.autoLoadPlanAt3Height.String;
	elseif _attr.compareGeneric(ETRow_TranshipConsign,true,false,null) = 0 then
		self.cmbTranshipConsi.setObject(config.transhipConsign);
