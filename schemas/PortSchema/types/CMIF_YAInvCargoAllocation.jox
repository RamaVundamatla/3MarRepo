    <JadeMethod name="isOperator_Match" id="b9a23d6e-6ccc-4622-8533-98daad6a4bd9">
        <source>isOperator_Match(_yaData: CM_YADataObjects): Boolean;
/*
Purpose:			
Date				Who			Reason
MARCH 2015		CNWAB1		Initial creation
*/
vars
	op : CM_Operator;
	
begin

	if self.myTransaction.operatorCode = null then
		return false;
	endif;
	
	// Only priorities will be empty.
	if _yaData.isEmpty() then
		return true;
	endif;
	
	
	op := app.myRoot.allOperators[self.myTransaction.operatorCode];
	
	if op = null then
		return false;
	endif;
	
	return _yaData.matches(op);
	
end;</source>
