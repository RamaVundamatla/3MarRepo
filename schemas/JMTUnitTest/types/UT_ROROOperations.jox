Date		Who		Reason
02 August 2012	cnwmc5	Initial creation

*/

vars
	voyage : CM_Voyage;
begin
	voyage := self.createVesselVoyage("UTMC_RORO_0", "UTMCRORO1", null);
	
	self.uRotateROROCells(voyage, false, false, true);
	self.uUnRotateROROCells(voyage, false, false, true);
	self.uRotateROROErrorCheck(voyage, false);

	//voyage.myROROStructure.createQuickCargoOOTL(null, false, 12, -12, voyage.myROROStructure.allDecksByCode['D1'], 1);
epilog

end;</source>
