    <JadeMethod name="transactionMapLoad" id="3b0fe454-0aa1-42de-8291-7ee0a5031429">
        <source>transactionMapLoad(_text : String; _userDefinedName : String);
// May 2010		cnwjre1

vars
	loadFile : File;
	fileName : String;
	la 		 : CM_InvoiceTranMapFileLoadAgent;
	bank	 : CM_Bank;
begin

	fileName := "TM_LOAD " &amp; _userDefinedName &amp; ".csv";
	fileName.replaceChar(' ', '_');
	create loadFile transient;
	loadFile.kind := File.Kind_Unknown_Text; // 29/2/16  cnwns1 PAR 36286 unicode version
	loadFile.openOutput(fileName);
	loadFile.writeString(_text);
	loadFile.close;

// NAVAB1 when manually running needs to use the terminal specified //	bank := app.myPassport.myTerminal.getDefaultCompanyBank();	// 35872
	bank := self.getTerminal().getDefaultCompanyBank();

	create la;
	la.myTerminal := app.myPassport.myTerminal;
	la.doLoadCSVFile(bank, fileName, true);	// files on client

epilog
	delete loadFile;
	delete la;
end;</source>
        <Parameter name="_text" type="String"/>
        <Parameter name="_userDefinedName" type="String"/>
    </JadeMethod>
    <JadeMethod name="uCountryOfOrigin" id="c85c881f-6d79-497f-9e1a-59d2ca5df9bc">
        <source>uCountryOfOrigin();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 August 2022	navak20	TFS ChangeRequest 54441: EUP - Additional Field - Country of Origin

*/

constants
Id_WithIn_Length : String = "testCoC";
vars
	newCountry,pxyCountry, oldCountry : CM_Country;
	cmif : CMIF_Country;
	desc : String;
	operator : CM_Operator;
	cargotype : CM_CargoType;
	ti : CM_TrackedItem;
begin
	newCountry := app.myRoot.allCountries["AK"];
	oldCountry := app.myRoot.allCountries["AE"];
	if newCountry &lt;&gt; null then
		app.myTrxDA.trxDeleteCountry(newCountry, app.myPassport);
		self.assertNoTrxErrorsOrWarnings();
	endif;
	
	//Create a new country
	desc := "Aalekh's DO NOT USE";
	create pxyCountry transient;
	pxyCountry.setProxy("AK", desc, null, null, false, null);
	create cmif transient;
	cmif.myProxyCountry := pxyCountry;
	cmif.allRealPorts.clear();
	app.myTrxCA.trxCreateCountry(cmif, newCountry, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	//Creating cargo TI
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
    cargotype := app.myRoot.allCargoTypesById[TI_CargoType_BreakBulk];
    self.deleteCargo(Id_WithIn_Length, cargotype);
	self.opts.addAssoc("CountryOfOrigin", oldCountry);
    ti := self.addCargoOpts(Id_WithIn_Length, "", 'TYRE', operator, cargotype.id);
	self.assertEqual(ti.myCountryOfOrigin, oldCountry);
	
	//Updating the TI
	self.opts.purge();
    self.opts.addAssoc("CountryOfOrigin", newCountry);
    self.updateTrackedItem(ti);
    self.assertEqual(ti.myCountryOfOrigin, newCountry);
	
epilog
	delete pxyCountry;
	delete cmif;
end;</source>
    </JadeMethod>
    <JadeMethod name="uCreateEDIFileTypeUser" id="a0a2c3b1-e4bd-466a-bd55-41148f2ddd88">
        <source>uCreateEDIFileTypeUser(_pxyFileTypeName: CM_EDIFileTypeUser): CM_EDIFileTypeUser;
/*

Purpose:			

Parameters:			Migrated up from UT_DSL

Return Value:		

Date		Who		Reason
16 February 2016	cnwndl1	Initial creation

*/

vars
	realFileTypeUser 	: CM_EDIFileTypeUser;
begin
	realFileTypeUser	:= app.myRoot.allEDIFileTypes[ EDIFileType_UserDefined, _pxyFileTypeName.name ].CM_EDIFileTypeUser;
	if realFileTypeUser &lt;&gt; null then
		// if it does exist then delete it.
		app.myTrxDA.trxDeleteEDIFileTypeUser( realFileTypeUser, app.myPassport );
		self.assertIsDeleted( realFileTypeUser );
		self.assertTrue(app.myPassport.trxCompletedOK());
	endif;
	
	// create the required user definition format.
	app.myTrxCA.trxCreateEDIFileTypeUser(realFileTypeUser, _pxyFileTypeName, app.myPassport);
	realFileTypeUser	:= app.myRoot.allEDIFileTypes.getAtKey( EDIFileType_UserDefined, _pxyFileTypeName.name ).CM_EDIFileTypeUser;
	self.assertNotNullMsg(realFileTypeUser, 'User Type ' &amp; _pxyFileTypeName.name &amp; ' is missing');
	
	return realFileTypeUser;
epilog
end;</source>
        <Parameter name="_pxyFileTypeName" type="CM_EDIFileTypeUser"/>
        <ReturnType type="CM_EDIFileTypeUser"/>
    </JadeMethod>
    <JadeMethod name="unmarkSlotsAsLoadJob" id="eebcc184-c4fa-4358-8ea0-fc08210a46be">
        <source>unmarkSlotsAsLoadJob(_allSlots : CM_SlotControllerArray);
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 December 2008	cnwer1	Initial creation

*/

vars
