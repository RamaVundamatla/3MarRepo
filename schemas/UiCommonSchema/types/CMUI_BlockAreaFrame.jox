    <JadeMethod name="init" id="0eb686ca-fcae-414a-a086-516797e195bb">
        <updating/>
        <source>init(terminalArea : CM_IrregularBlockArea; designMode : Boolean; updateMode : Integer; _parentForm : CM_BaseForm) updating;
begin
	self.createDrawingController(designMode);
	self.myDrawingController.setForCreate(terminalArea, self,_parentForm);
	self.myDrawingController.setMode(updateMode);
end;
