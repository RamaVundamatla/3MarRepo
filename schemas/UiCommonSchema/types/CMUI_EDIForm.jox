		return CM_EDIDataTranship;
	elseif type = EDI_Index_Fleet then	 //cnwrd1 ccms 1034 Fleet file
		return CM_EDIDataFleet;	
	elseif type = EDI_Index_FleetWagon then	 //MES 1010 Interface load jmn
		return CM_EDIDataFleetWagon;			
	elseif type = EDI_Index_UserType then
		return CM_EDIDataCargo;
	elseif type = EDI_Index_USBOLManifest then
		return CM_EDIDataBillOfLading; 
	elseif type = EDI_Index_USCustomMessage then
		return CM_EDIDataUSCustomsMessage;
	elseif type = EDI_Index_CargoSubtype then
		return CM_EDIDataProduct;
	// cnwrl1 02/09/2009 PAR 20320 - MES 1011 New Messina Messages - start of coding
	elseif type = EDI_Index_ReleaseProduct then
		return CM_EDIDataReleaseRequest;
	// cnwrl1 02/09/2009 PAR 20320 - MES 1011 New Messina Messages - end of coding
	// cnwrs1 Messina CCMS 1008 Par 20320 Sept 2009
	elseif type = EDI_Index_BOL then
		return CM_EDIDataBOL;
	elseif type = EDI_Index_Stop then
		return CM_EDIDataStop;
	elseif type = EDI_Index_Train then
		return CM_EDIDataTrain;
	elseif type = EDI_Index_Voyage then
		return CM_EDIDataVoyage;
	elseif type = EDI_Index_Wagon then
		return CM_EDIDataWagon;
	elseif type = EDI_Index_ShipManifest  then
		return CM_EDIDataShipManifest;
	elseif type = EDI_Index_ROROShipManifest  then
		return CM_EDIDataDeckPlan;
	elseif type = EDI_Index_TransportManifest then	//06.Jun.2023 navsp1 TFS 58054
		return CM_EDIDataTransManifest;
	elseif type = EDI_Index_CallOff then
		return CM_EDIDataCallOff;
	else
		return CM_EDIData;
	endif;	
end;</source>
        <Parameter name="_fileType" type="Integer"/>
