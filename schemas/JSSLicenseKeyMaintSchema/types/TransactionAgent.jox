    <JadeMethod name="trxGenerateLicenseKey" id="d22a76c8-3f1e-4bd2-b37d-531801d7c3bd">
        <source>trxGenerateLicenseKey(	pTheUsedProduct:JSSLKUsedProduct input;
						pRequiredEdition:Integer);
// --------------------------------------------------------------------------------
// Created:		27 January 2003 by cnwdad2
//
// Purpose:		Updates an Permission object.
//
// Parameters:	pTheUsedProduct - The used product object to generate the license key for.
//				pRequiredEdition - The object edition of the used product object.
//
// Returns:		Nothing.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	beginTransaction;
	
	exclusiveLock(pTheUsedProduct);
	
	if pRequiredEdition &lt;&gt; 0 then
		if pRequiredEdition &lt;&gt; pTheUsedProduct.edition then
			JSSLKException.raise_(99999, $EDITION_OUTOFDATE("Used Product", pTheUsedProduct.myProduct.productName));
		endif;
	endif;
	
	pTheUsedProduct.generateLicenseKey();
	
	commitTransaction;
end;</source>
        <Parameter name="pTheUsedProduct" type="JSSLKUsedProduct" usage="input"/>
        <Parameter name="pRequiredEdition" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="trxImportConstants" id="f1537ca2-be4a-4044-95aa-4d5d058d0c3f">
        <source>trxImportConstants(pAllImportConstants:JSSLKImportConstantArray; pIsUpdateExisting:Boolean);
// --------------------------------------------------------------------------------
// Created:		23 January 2003 by cnwdad2
//
// Purpose:		Imports one or more Global Constants (from an application schema),
//				and creates Product Components for each one.  Optionally, any
//				Components already existing with a Global Constant Id can be
//				updated.
//
// Parameters:	pAllImportConstants - An array of Global Constant/Product pairs.
//				pIsUpdateExisting - If true, existing Components (with an Id that
//				matches a Global Constant value) will be updated.
//
// Returns:		Nothing.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theImportConstant		: JSSLKImportConstant;
	theConstant				: Constant;
	theProduct				: JSSLKProduct;
	theComponent			: JSSLKComponent;
	componentId				: Integer;
	componentDescription	: String;
	
begin
	beginTransaction;
	
	foreach theImportConstant in pAllImportConstants do
		theConstant	:=	theImportConstant.myConstant;
		theProduct	:=	theImportConstant.myProduct;
		
		if theConstant = null then
			JSSLKException.raise_(99999, "Import error: The Global Constant to import is missing.");
		elseif theProduct = null then
			JSSLKException.raise_(99999, "Import error: The Product to which the imported Component belongs is missing.");
		endif;
		
		componentId				:=	theConstant.valueAsInteger();
		componentDescription	:=	theConstant.text;
		
		theComponent	:=	theProduct.allComponents[componentId];
		
		if theComponent = null then
			theComponent	:=	theProduct.createComponent(componentId, componentDescription);
		elseif pIsUpdateExisting then
			theComponent.updateMe(componentId, componentDescription, theProduct);
		endif;
	endforeach;
	
	commitTransaction;
end;</source>
        <Parameter name="pAllImportConstants" type="JSSLKImportConstantArray"/>
        <Parameter name="pIsUpdateExisting" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="trxRemoveUsedComponents" id="ea491c1b-e730-415b-b52d-42dea53aec05">
        <source>trxRemoveUsedComponents(pTheCustomer:JSSLKCustomer input;
						pRequiredEdition:Integer;
						pAllComponents:JSSLKComponentArray);
// --------------------------------------------------------------------------------
// Created:		23 January 2003 by cnwdad2
//
// Purpose:		Removes multiple used product components from a Customer.
//
// Parameters:	pTheCustomer - The customer object to remove the components from.
//				pRequiredEdition - The object edition of the customer object.
//				pAllComponents - A collection of used components to remove.
//
// Returns:		Nothing.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	beginTransaction;
	
	exclusiveLock(pTheCustomer);
	
	if pRequiredEdition &lt;&gt; 0 then
		if pRequiredEdition &lt;&gt; pTheCustomer.edition then
			JSSLKException.raise_(99999, $EDITION_OUTOFDATE("Customer", pTheCustomer.customerName));
		endif;
	endif;
	
	pTheCustomer.removeUsedComponents(pAllComponents);
	
	commitTransaction;
end;</source>
        <Parameter name="pTheCustomer" type="JSSLKCustomer" usage="input"/>
        <Parameter name="pRequiredEdition" type="Integer"/>
        <Parameter name="pAllComponents" type="JSSLKComponentArray"/>
    </JadeMethod>
    <JadeMethod name="trxUpdateComponent" id="5840168b-ad4b-4774-811b-11d015b1af18">
        <source>trxUpdateComponent(	pTheComponent:JSSLKComponent input;
					pRequiredEdition:Integer;
					pComponentId:Integer;
					pComponentDescription:String;
					pTheProduct:JSSLKProduct);
// --------------------------------------------------------------------------------
// Created:		23 January 2003 by cnwdad2
//
// Purpose:		Updates a Product Component object.
//
// Parameters:	pTheComponent - The component object to update.
//				pRequiredEdition - The object edition of the component object.
//				pComponentId - The unique identifier of the customer.
//				pComponentDescription - A description of the product component.
//				pTheProduct - The owner of the component object.
//
// Returns:		Nothing.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theComponent	: JSSLKComponent;
	
begin
	theComponent	:=	pTheProduct.allComponents[pComponentId];
	
	if theComponent &lt;&gt; null and theComponent &lt;&gt; pTheComponent then
		JSSLKException.raise_(99999, $PRODUCT_COMPONENT_EXISTS(pComponentId.String));
	else
		beginTransaction;
		
		exclusiveLock(pTheComponent);
		
		if pRequiredEdition &lt;&gt; 0 then
			if pRequiredEdition &lt;&gt; pTheComponent.edition then
				JSSLKException.raise_(99999, $EDITION_OUTOFDATE("Component", pTheComponent.componentId.String));
			endif;
		endif;
		
		pTheComponent.updateMe(pComponentId, pComponentDescription, pTheProduct);
		
		commitTransaction;
	endif;
end;</source>
        <Parameter name="pTheComponent" type="JSSLKComponent" usage="input"/>
        <Parameter name="pRequiredEdition" type="Integer"/>
        <Parameter name="pComponentId" type="Integer"/>
        <Parameter name="pComponentDescription" type="String"/>
        <Parameter name="pTheProduct" type="JSSLKProduct"/>
    </JadeMethod>
    <JadeMethod name="trxUpdateCustomer" id="bac3a5b7-e875-4e67-b944-e29d05582f99">
        <source>trxUpdateCustomer(	pTheCustomer:JSSLKCustomer input;
					pRequiredEdition:Integer;
					pCustomerName:String;
					pTheRoot:JSSLKProductRoot);
// --------------------------------------------------------------------------------
// Created:		23 January 2003 by cnwdad2
//
// Purpose:		Updates a Customer object.
//
// Parameters:	pTheCustomer - The customer object to update.
//				pRequiredEdition - The object edition of the customer object.
//				pCustomerName - The name of the customer.
//				pTheRoot - The owner of the customer object.
//
// Returns:		Nothing.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theCustomer	: JSSLKCustomer;
	
begin
	theCustomer	:=	pTheRoot.allCustomers[pCustomerName];
	
	if theCustomer &lt;&gt; null and theCustomer &lt;&gt; pTheCustomer then
		JSSLKException.raise_(99999, $CUSTOMER_EXISTS(pCustomerName));
	else
		beginTransaction;
		
		exclusiveLock(pTheCustomer);
		
		if pRequiredEdition &lt;&gt; 0 then
			if pRequiredEdition &lt;&gt; pTheCustomer.edition then
				JSSLKException.raise_(99999, $EDITION_OUTOFDATE("Customer", pTheCustomer.customerName));
			endif;
		endif;
		
		pTheCustomer.updateMe(pCustomerName, pTheRoot);
		
		commitTransaction;
	endif;
end;</source>
        <Parameter name="pTheCustomer" type="JSSLKCustomer" usage="input"/>
        <Parameter name="pRequiredEdition" type="Integer"/>
        <Parameter name="pCustomerName" type="String"/>
        <Parameter name="pTheRoot" type="JSSLKProductRoot"/>
    </JadeMethod>
    <JadeMethod name="trxUpdateProduct" id="57ed506b-3660-4f99-b75e-cc2d1fe6993f">
        <source>trxUpdateProduct(	pTheProduct:JSSLKProduct input;
					pRequiredEdition:Integer;
					pProductName:String;
					pProductCode:String;
					pProductVersion:String;
					pProductLogo:Binary;
					pTheRoot:JSSLKProductRoot);
// --------------------------------------------------------------------------------
// Created:		23 January 2003 by cnwdad2
//
// Purpose:		Updates a Product object.
//
// Parameters:	pTheProduct - The product object to update.
//				pRequiredEdition - The object edition of the product object.
//				pProductName - The name of the product.
//				pProductCode - The unique product code.
//				pProductVersion - The release version of the product.
//				pProductLogo - An image of the product logo.
//				pTheRoot - The owner of the product object.
//
// Returns:		Nothing.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theProduct	: JSSLKProduct;
	
begin
	theProduct	:=	pTheRoot.allProducts[pProductName];
	
	if theProduct &lt;&gt; null and theProduct &lt;&gt; pTheProduct then
		JSSLKException.raise_(99999, $PRODUCT_EXISTS(pProductName));
	else
		beginTransaction;
		
		exclusiveLock(pTheProduct);
		
		if pRequiredEdition &lt;&gt; 0 then
			if pRequiredEdition &lt;&gt; pTheProduct.edition then
				JSSLKException.raise_(99999, $EDITION_OUTOFDATE("Product", pTheProduct.productName));
			endif;
		endif;
		
		pTheProduct.updateMe(pProductName, pProductCode, pProductVersion, pProductLogo, pTheRoot);
		
		commitTransaction;
	endif;
end;</source>
        <Parameter name="pTheProduct" type="JSSLKProduct" usage="input"/>
        <Parameter name="pRequiredEdition" type="Integer"/>
        <Parameter name="pProductName" type="String"/>
        <Parameter name="pProductCode" type="String"/>
        <Parameter name="pProductVersion" type="String"/>
        <Parameter name="pProductLogo" type="Binary"/>
        <Parameter name="pTheRoot" type="JSSLKProductRoot"/>
    </JadeMethod>
    <JadeMethod name="trxUpdateProductExpiryDate" id="45ef72c2-012b-4eb2-bee5-69118f472353">
        <source>trxUpdateProductExpiryDate(	pTheUsedProduct:JSSLKUsedProduct input;
							pRequiredEdition:Integer;
							pExpiryDate:Date);
// --------------------------------------------------------------------------------
// Created:		30 January 2003 by cnwdad2
//
// Purpose:		Updates a Used Product's expiry date.
//
// Parameters:	pTheUsedProduct - The product object to update.
//				pRequiredEdition - The object edition of the product object.
//				pExpiryDate - The expiry date of the product license.
//
// Returns:		Nothing.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	beginTransaction;
	
	exclusiveLock(pTheUsedProduct);
	
	if pRequiredEdition &lt;&gt; 0 then
		if pRequiredEdition &lt;&gt; pTheUsedProduct.edition then
			JSSLKException.raise_(99999, $EDITION_OUTOFDATE("Used Product", pTheUsedProduct.getProductName()));
		endif;
	endif;
	
	pTheUsedProduct.setExpiryDate(pExpiryDate);
	
	commitTransaction;
end;</source>
        <Parameter name="pTheUsedProduct" type="JSSLKUsedProduct" usage="input"/>
        <Parameter name="pRequiredEdition" type="Integer"/>
        <Parameter name="pExpiryDate" type="Date"/>
    </JadeMethod>
</Class>
