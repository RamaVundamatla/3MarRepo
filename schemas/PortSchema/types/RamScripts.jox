    <JadeMethod name="createContainers_testPrint" id="944e08fa-4256-4d09-b2a1-acab076d107f">
        <source>createContainers_testPrint();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 April 2025	navra1	Initial creation

*/

vars
	cargoTypeInt	: Integer;
	pxyTI			: CM_TrackedItem;
	realTI			: CM_TrackedItem;
	cargoType		: CM_CargoType;
	root			: CM_Root;
	imexInt 		: Integer;
	remarks			: String;
	
	_id: String; 
	_isoType: String; 
	_commodity: String; 
	_operator: CM_Operator; 
	term : CM_Terminal;
	i: Integer;
	bsLocation : CM_LocationsController;
	bs : CM_BlockStack;
	cmifMoveController : CMIF_MoveController;
	user : CM_User;
	
begin
	app.initialize();
	
	
	foreach user in app.myRoot.allUsers do
		if user.code = 'NAVRA1' then
			break;
		endif;
	endforeach;
	
	
	app.myPassport.setMyUser(user);
	
	bs := "2353.1250204".asOid().CM_BlockStack;
	bsLocation := bs.getLocationsController();
	_id := "LOTU";
	root := CM_Root.firstInstance;
	
//	cargoType := root.allCargoTypesById[TI_CargoType_Container];	// cnwrl1 28/04/2010 PAR 23854 - what it was
	// cnwrl1 28/04/2010 PAR 23854 - start of coding
	
	cargoType		:= root.allCargoTypesById[ 1 ];
	// cnwrl1 28/04/2010 PAR 23854 - end of coding
	term := app.myRoot.allTerminals['RAM'];
	
	app.myPassport.setMyTerminal(term);
	
	foreach i in 1 to 50000 do
		_id := "0-";
		_id := _id &amp; i.String;
		beginTransaction;
		realTI := term.createTI(cargoType, false);
//		realTI.setPxyFromDefaultTI(self.getTerminal, TI_CargoType_Container, _id, _commodity, _operator);	// cnwrl1 28/04/2010 PAR 23854 - what it was
	
		realTI.setPxyFromDefaultTI(term, 1, _id, _commodity, _operator);
		realTI.changeState(TI_STATE_NORMAL, app.myPassport);
		realTI.setISOType(_isoType);
		//realTI.setWeight(4000, null, null);					//-cnwml2 MSL CCMS 1017
		realTI.setPropertyValue( "totalWeight", "4000".Decimal );					//+cnwml2 MSL CCMS 1017
		
		global.setExtraData(realTI.allExtraData, realTI, "createdForPrint" , "test");					// 29/08/2012 cnwmh5
		//realTI.setPropertyValue(CM_TrackedItem.userC
		// 13/07/015 cnwmh5
		remarks := realTI.remarks;
		if remarks &lt;&gt; null then
			remarks := remarks &amp; CrLf;
		endif;
		realTI.setRemarks("REM",false);
				
		realTI.moveToLocation(bsLocation,null,null,null,REAL_MODE,true,false,false,false,false,true,0,null,null,null,null,app.myPassport);	// TFS 2651
		commitTransaction;
		
		///
		/*create cmifMoveController transient;
		cmifMoveController.isForcedMove := true;
		cmifMoveController.isSystemMove := true;
		cmifMoveController.setMyTrackedItem(realTI);
		cmifMoveController.setPropertyValue(CMIF_MoveController::userCode.name,"navra1");
		cmifMoveController.allOtherTrackedItems.tryRemove(realTI);
		cmifMoveController.setMyToPrimaryLocation(bsLocation);
		app.myTrxUA.trxMoveTrackedItem(cmifMoveController, app.myPassport);
		write "hi";*/
		///
		
		
	endforeach;
		
	

epilog
	delete cmifMoveController;
	abortTransaction;  // in case if falls over during the begin commit above...
	
	
end;
</source>
    </JadeMethod>
    <JadeMethod name="createExtraFutureActors" id="2a293f3f-ccfc-4e99-84ee-c10c3f2511c7">
        <source>createExtraFutureActors();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 June 2024	navra1	Initial creation

*/

vars
	//testing bulk data
	testObjArray : CM_ObjectArray;
	testObj : CM_OfflineFutureActor;
	i, j:Integer;
	fa:CM_OfflineFutureActor;
	ti:CM_TrackedItem ;
	vvr : CM_VehicleVisitRecord;
	cash : CM_CashReceipt;
	inv:CM_Invoice;
	now : TimeStamp;
	//testing bulk data
	objArray : CM_ObjectArray;		
	cs : CM_TIByCargoTypeIdDict;
begin
	app.initialize();
	create testObjArray transient;
	
	now:=now.addYears(25);
	create objArray transient;
	CM_OfflineFutureActor.allInstances(objArray, null, true);
	write "Creating - in the beginning : "&amp; objArray.size().String;	
	
	
	//testing bulk data
	if process.isRam() then
		create cs transient;
		ti:=app.myRoot.allTerminals.first().allOnsiteTIsByAlternativeId.first();
		cs := app.myRoot.allTerminals["RAM"].allOnsiteTIsByCargoTypeId;
		foreach ti in cs do 
			if ti.myProduct &lt;&gt; null then
				write "got one";
				break;
			endif;
		endforeach;
		vvr := CM_VehicleVisitRecord.instances.first().CM_VehicleVisitRecord;
		cash := CM_CashReceipt.instances.first().CM_CashReceipt;
		inv:=CM_Invoice.instances.first().CM_Invoice;
		
			
			foreach i in 1 to 1000 do
				beginTransaction;
					if j =0 then
						create fa as CM_FutureStorageProcess persistent;
						
						fa.CM_FutureStorageProcess.setMyTrackedItem(ti);
						fa.CM_FutureStorageProcess.setActionTimeStamp(now);
						
						now := now.addDays(1);
					
						
						j:=j+1;
					elseif j = 1 then
						create fa as CM_BarrierCodeReleaseProcess persistent;
						
						fa.CM_OfflineFutureActor.setParentObject(vvr);
						fa.CM_OfflineFutureActor.setActionTimeStamp(now);
						
						now := now.addDays(1);
						
						j:=j+1;
					elseif j=2 then
						create fa as CM_CashStatusAdvanceProcess persistent;
						
						fa.CM_CashStatusAdvanceProcess.setMyCashReceipt(cash);
						fa.CM_OfflineFutureActor.setActionTimeStamp(now);
						
						now := now.addDays(1);
						
						j:=j+1;
					elseif j=3 then
						create fa as CM_FreeStorageExpiryStopCreate persistent;
						
						fa.CM_FreeStorageExpiryStopCreate.setMyTrackedItem(ti);
						
						fa.CM_OfflineFutureActor.setActionTimeStamp(now);
						now := now.addDays(1);
						
						j:=j+1;
					elseif j=4 then
						create fa as CM_InvoiceStatusAdvanceProcess persistent;
						
						fa.CM_InvoiceStatusAdvanceProcess.setMyInvoice(inv);
						
						fa.CM_OfflineFutureActor.setActionTimeStamp(now);
						now := now.addDays(1);
						
						j:=0;
					endif;
				
				commitTransaction;
			endforeach;			
		
	endif;
	//testing bulk data
epilog
	delete testObjArray;
	objArray.clear();
	CM_OfflineFutureActor.allInstances(objArray, null, true);	
	write "Creating - in the end : "&amp; objArray.size().String;
	delete objArray;
	
	
end;</source>
    </JadeMethod>
    <JadeMethod name="deleteExtraFutureActors" id="5e792d2f-b261-4230-adc5-38b1f14db8aa">
        <source>deleteExtraFutureActors();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 June 2024	navra1	Initial creation

*/

vars
	objArray : CM_ObjectArray;
	i : Integer;
	now: TimeStamp;
begin
	app.initialize();

	now:=now.addYears(25);
	create objArray transient;
	CM_OfflineFutureActor.allInstances(objArray, null, true);
	write "Deleting - in the beginning : "&amp; objArray.size().String;
	beginTransaction;
		foreach i in 1 to 150000 do
			if i &gt; 0 then	
				if objArray.size() &gt; i then
					if app.isValidObject(objArray[i]) then
						delete objArray[i];
					endif;
				endif;
			else
				if objArray.size() &gt; i then
					if app.isValidObject(objArray[i]) then
						objArray[i].CM_OfflineFutureActor.setActionTimeStamp(now);
					endif;
				endif;
			endif;
		endforeach;
	commitTransaction;
epilog
	delete objArray;
	create objArray transient;
	CM_OfflineFutureActor.allInstances(objArray, null, true);
	write "Deleting - in the end : "&amp; objArray.size().String;
	delete objArray;
end;
</source>
    </JadeMethod>
    <JadeMethod name="duplicateInvoice" id="2e675dac-2d72-45a1-bc18-bfaa4c2df8eb">
        <source>duplicateInvoice();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 May 2025	navra1	Initial creation

*/

vars
	term : CM_Terminal;
	voyageColl : CM_VoyageByCodeArrivalDT;
	voy : CM_Voyage;
	invType : CM_Invoice;
	allinv : CM_InvoiceBySeqNumDict;
	inv, invInner : CM_Invoice;
	invDesc : CM_InvoiceDesc;
	deb : CM_Debtor;
	value : Decimal[23,6];
	strSet : StringArray;
	dupCount : Integer;
begin
	app.initialize();
	
	
	create strSet transient;
	
	term := app.myRoot.allTerminals['RAM'];
	
	if term &lt;&gt; null then
		voyageColl := term.allVoyagesByCode;
		
		foreach voy in voyageColl do
			allinv:=voy.allInvoices;
			foreach inv in allinv do
				invDesc := inv.getInvoiceType();
				deb := inv.debtor;
				value := inv.totalAmount;
				
				foreach invInner in allinv do
					if invInner &lt;&gt; inv then
						if invInner.getInvoiceType() = invDesc and
							invInner.debtor = deb and 
							invInner.totalAmount = value and
							not strSet.includes(inv.externalNumber &amp; "," &amp; invInner.externalNumber) and							
							not strSet.includes(invInner.externalNumber &amp; "," &amp; inv.externalNumber) then
								strSet.add(inv.externalNumber &amp; "," &amp; invInner.externalNumber);
								strSet.add(invInner.externalNumber &amp; "," &amp; inv.externalNumber);
								dupCount := dupCount+1;
								write "Duplicate invoice found in voyage " &amp; voy.code &amp; " and the original invoice ext number is " &amp; inv.externalNumber &amp; " and " &amp; inv.externalNumber &amp; " and " &amp; invInner.externalNumber &amp; " are equal, duplicate pair number " &amp; dupCount.String;
								
						endif;
					endif;
					
				
				endforeach;
			endforeach;
			
		endforeach;
	endif;

epilog
	if strSet &lt;&gt; null then
		strSet.purge();
	endif;
	delete strSet;
end;</source>
    </JadeMethod>
