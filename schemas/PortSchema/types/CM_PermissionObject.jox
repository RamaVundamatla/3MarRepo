    </JadeMethod>
    <JadeMethod name="updateEntity" id="2acca653-40b7-48f4-907f-252f2cc8dc7f">
        <updating/>
        <source>updateEntity(_constName 	 : String; 
			 _constValue 	 : Integer; 
			 _explanation, 
			 _description, 
			 _category 		 : String; 
			 _isInternal 	 : Boolean;
			 _permType 		 : Integer;
			 _childValues 	 : IntegerArray; 
			 _actionClass, 
			 _attr1, 
			 _extraTblDef, 
			 _heading, 
			 _id, 
			 _mainTblDef, 
			 _param1, 
			 _schemaName, 
			 _windowClass 	 : String;
			 _leafPic, 
			 _toolbarPicUp, 
			 _toolbarPicDown : String; 			 
			 _mobileApps 	 : StringArray;
			 _formType  	 : Integer) updating;
/* ---------------------------------------------------------------------------
Created:     17 May 2002 by cnwth2
Purpose:

Date		Name	TFS#		Description
============================================================================
03 Sep 2019	jlgdi1	45802	Added formType attribute
23 Sep 2019 jlgka1 	TFS 45614 	JMT - Refactoring remove Voyage Commodity Scenario mode
============================================================================*/
begin
	//constant necessities:
	self.constName := _constName;
	self.constValue := _constValue;
	//constant text essentially:
	self.category 	:= _category;
	self.explanation	:= _explanation;
	self.description:= _description;
	self.isInternal 	:= _isInternal;
	self.permType		:= _permType;
	self.formType := _formType;		// 45802
	
	// childValues are the licensing groups that this  
	// permission relates to.
	self.allChildValues.clear;
	if _childValues &lt;&gt; null then
		_childValues.copy(self.allChildValues);
	endif;
	
	self.actionClass	:= _actionClass;
	self.attr1			:= _attr1;
	self.extraTableDef	:= _extraTblDef;
	self.heading		:= _heading;
	self.id				:= _id;
	self.mainTableDef	:= _mainTblDef;
	self.param1			:= _param1;
	self.schemaName		:= _schemaName;
	self.windowClass	:= _windowClass;
	self.pictureStringIcon		:= _leafPic;
	self.pictureStringButton	:= _toolbarPicUp;
	self.pictureStringButtonDown:= _toolbarPicDown;
	
	//jlgka1 TFS 45614 --&gt;
	/*if _windowClass &lt;&gt; null and _isScenario then
		self.isScenario := true;
	endif;*/
	//jlgka1 TFS 45614 &lt;--
	
	//epr TFS 36402 31/1/18
	self.allMobileApps.clear;
	if _mobileApps &lt;&gt; null then
		_mobileApps.copy(self.allMobileApps);
	endif;
	self.updateWebserviceHandheldRefs;
 	//add all attributes to the text property:
	self.constText := outputAsXML();
	

end;</source>
        <Parameter name="_constName" type="String"/>
        <Parameter name="_constValue" type="Integer"/>
        <Parameter name="_explanation" type="String"/>
        <Parameter name="_description" type="String"/>
        <Parameter name="_category" type="String"/>
        <Parameter name="_isInternal" type="Boolean"/>
        <Parameter name="_permType" type="Integer"/>
        <Parameter name="_childValues" type="IntegerArray"/>
        <Parameter name="_actionClass" type="String"/>
        <Parameter name="_attr1" type="String"/>
        <Parameter name="_extraTblDef" type="String"/>
        <Parameter name="_heading" type="String"/>
        <Parameter name="_id" type="String"/>
        <Parameter name="_mainTblDef" type="String"/>
        <Parameter name="_param1" type="String"/>
        <Parameter name="_schemaName" type="String"/>
        <Parameter name="_windowClass" type="String"/>
        <Parameter name="_leafPic" type="String"/>
        <Parameter name="_toolbarPicUp" type="String"/>
        <Parameter name="_toolbarPicDown" type="String"/>
        <Parameter name="_mobileApps" type="StringArray"/>
        <Parameter name="_formType" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="updateFromMenuDtlSystem" id="646423e9-0192-4a96-8701-574cd243c6d3">
        <updating/>
        <source>updateFromMenuDtlSystem(_menDtl : CM_MenuDtlSystem) : Boolean updating;
// ---------------------------------------------------------------------------
// Created:     21 August 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	if _menDtl.isSystemDtl then
		self.permType := 1;		// PermType_System
	else
		self.permType := 0;		// PermType_Terminal
	endif;
	self.heading					:= _menDtl.heading;
	self.id							:= _menDtl.menuId;
	self.pictureStringButton		:= _menDtl.pictureStringButton;
	self.pictureStringButtonDown	:= _menDtl.pictureStringButtonDown;
	self.pictureStringIcon			:= _menDtl.pictureStringIcon;
	self.toolTip					:= _menDtl.toolTip;
	
	if self.myConstant &lt;&gt; null then
		self.myConstant.setText(self.outputAsXML());
		return true;
	endif;
	
	return false;

end;</source>
        <Parameter name="_menDtl" type="CM_MenuDtlSystem"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="updateWebserviceHandheldRefs" id="bb68830a-e53f-405a-ba51-93f99e819416">
        <source>updateWebserviceHandheldRefs() :Boolean;
/*

Purpose:	returns false if no references then can just null the text		

Parameters:			

Return Value:		

Date		Who		Reason
30 January 2018	jlger1	Initial creation 36402

*/

vars

	schema : Schema;
	methods 	: MethodSet;
	class : Class;
	webserviceMethods : MethodNDict;
	meth : Method;
	mobileApp : Object;
	allForms : ObjectArray;
	handheldMenuMethod : Method;
	handHeldClass : Class;
	handHeldName : String;
	passport : CM_Passport;
	obj : Object;
begin
	self.allWebservices.clear;
	self.allHandheldApps.clear;
	create methods transient;
	
	if self.myConstant = null then
		return true;
	endif;
	self.myConstant.getMethodRefs(methods);
	
	
	if methods.isEmpty then
		//write "NO REFS " &amp; constName;
		return false;
	endif;
	
	schema := rootSchema.getSchema("WebServicesSchema");
	
	class:=schema.getClass("JMTUserInterfaceService");
	
	create webserviceMethods transient;
	class.getMethods(webserviceMethods);
	
	
	schema := rootSchema.getSchema("MobileUISchema");
	
	class:=schema.getClass("MOB_MobileGUIAgent");
	create mobileApp as class transient;
	
	//create mobileApp.PortSchema.myPassport transient;
	create passport transient;
	passport.setPropertyValue("myUser",CM_Root.firstInstance.allUsers["SUPERUSER"]);
	passport.setPropertyValue("myTerminal",CM_Root.firstInstance.allTerminals.first); //doesn't matter we are superuser
	

	create allForms transient;
	handheldMenuMethod:=mobileApp.class.getMethod("getFormForPermisson");
	foreach meth in methods do
		if handheldMenuMethod &lt;&gt; null and meth=handheldMenuMethod then
			allForms.clear;
			mobileApp.sendMsgWithParams(handheldMenuMethod.name,passport,self.constValue.Integer,allForms);
			foreach obj in allForms do 
				if obj.isKindOf(Class) then
					handHeldClass:=obj.Class;
					 handHeldName:= mobileApp.sendMsgWithParams("getTranslationOfMenu",handHeldClass,null).String;
					if handHeldName &lt;&gt; null then
						self.allHandheldApps.add(handHeldName);
					endif;
				endif;
			endforeach;
		else
			if webserviceMethods.includes(meth) then			
				self.allWebservices.add( meth.name);					
			endif;
		endif;	
	endforeach;
	
	
	return true;
epilog
	delete methods;
	delete webserviceMethods;
	delete allForms;
	delete mobileApp;
	delete passport;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateSelf" id="34329c8c-f692-4d1b-a41c-9a76804689cc">
        <source>validateSelf() : Boolean;
// ---------------------------------------------------------------------------
// Created:     18 July 2005 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpMethSet	: MethodSet;
	tmpMethod	: Method;
	methodClass	: String;
begin

	if self.myConstant = null then
		return true;
	endif;
	
	create tmpMethSet transient;
	
	self.myConstant.getMethodRefs(tmpMethSet);
	
	foreach tmpMethod in tmpMethSet do
		if tmpMethod.name &lt;&gt; 'create' then
			continue;
		endif;
		
		methodClass := tmpMethod.schemaType.name;
		if self.windowClass &lt;&gt; null and
		   methodClass &lt;&gt; self.windowClass then
			app.writeStatement( self.constName &amp; Tab &amp; methodClass &amp; Tab &amp; tmpMethod.name &amp; Tab &amp;
					'windowClass mismatch ' &amp;
					self.windowClass &amp; ',  create method on ' &amp;
					methodClass);
		else

		endif;
	endforeach;

	return true;

epilog
	delete tmpMethSet;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
