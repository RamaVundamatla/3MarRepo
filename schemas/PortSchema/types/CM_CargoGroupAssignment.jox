epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getNextAvailAssignment" id="f9e4369f-fc06-4e31-b0bc-1af5b94548b7">
        <source>getNextAvailAssignment():CM_CargoGroupAssignment;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 July 2018	jlgndl1	Initial creation	TFS 39186

*/

vars

	iter: Iterator;
	wt : CM_WorkTask;
	cga : CM_CargoGroupAssignment;

begin

	iter := self.myTerminal.allWorkTasksDict.createIterator;
	iter.startAtObject( self );
	while iter.next( wt ) do
		if wt.type &lt;&gt; self.Type_CargoGroupAssignment then
			break;
		endif;
		cga := wt.CM_CargoGroupAssignment;
		if cga = self then
			continue;
		endif;
		if cga.isCompleted then
			continue;
		endif;
		return cga;
	endwhile;
	
	return null;

epilog

	delete iter;

end;</source>
        <ReturnType type="CM_CargoGroupAssignment"/>
    </JadeMethod>
    <JadeMethod name="getNextCargoGroup" id="60699fdf-2518-4d38-8b5d-0e7f0bce5abc">
        <source>getNextCargoGroup( _cargoGroup : CM_CargoGroup; _selectedTi : CM_TrackedItem ):CM_CargoGroup;
/*

Purpose:			

Parameters:			Magically auto find the next cargo group so the user doesn't have to think or be able to read.

Return Value:		

Date		Who		Reason
11 July 2018	jlgndl1	Initial creation	TFS 39186
02 Oct 2018	NDL	TFS 39186 - rewrite

*/

vars

	cg : CM_CargoGroup;
	iter : Iterator;
	ti : CM_TrackedItem;
	
	allCargoGrsByIdDict : CM_TIByIdCargoTypeDict;

begin

	create allCargoGrsByIdDict transient;
	self.getAllCargoGroupsByIdDict( allCargoGrsByIdDict );
	
	if allCargoGrsByIdDict.includes( _cargoGroup ) then
		iter := allCargoGrsByIdDict.createIterator;
		iter.startAtObject( _cargoGroup );
		while iter.next( ti ) do
			if ti = _cargoGroup then
				continue;
			endif;
			cg := ti.CM_CargoGroup;
			if not cg.couldAddCargoItem( _selectedTi ) then
				continue;
			endif;
			return cg;
		endwhile;
	endif;
	
	return null;

epilog

	delete allCargoGrsByIdDict;
	delete iter;

end;</source>
        <Parameter name="_cargoGroup" type="CM_CargoGroup"/>
        <Parameter name="_selectedTi" type="CM_TrackedItem"/>
        <ReturnType type="CM_CargoGroup"/>
    </JadeMethod>
    <JadeMethod name="getNotYetScanned" id="6de720f0-863f-4914-a92e-56ce5736a845">
        <source>getNotYetScanned( _strArray : StringArray input; _includePreAssigned : Boolean  ):Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 July 2018	jlgndl1	Initial creation	TFS 39186

*/

vars

	iter : Iterator;
	allIds: StringArray;
	obj : Object;
	cargoId : String;
	ti : CM_TrackedItem;
	cgn : CM_NotifiedCargoGroup;
	cg : CM_TrackedItem;	//CM_CargoGroup;

begin
	
	create allIds transient;
	iter := self.allCargoIdsDict.createIterator;
	while iter.next( obj ) do
		cargoId := iter.getCurrentKey( 1 ).String;
		if cargoId &lt;&gt; null then
			allIds.add( cargoId );
		endif;
	endwhile;
	
	foreach ti in self.allProcessedTis do
		if allIds.includes( ti.id ) then
			allIds.remove( ti.id  );
		endif;
	endforeach;
	
	if not allIds.isEmpty then
		allIds.copy( _strArray );
	endif;
	
	//02 Oct 2018	NDL	TFS 39186
	if _includePreAssigned then
		foreach cg in self.allCargoGroupsByIdDict do
			cg.CM_CargoGroup.getPreAssignedToScan( _strArray );
		endforeach;
		foreach cgn in self.allNotifiedCargoGroupByIdDict do
			cg := self.myTerminal.getCargoGroupItem( cgn.id );
			if cg &lt;&gt; null and self.allCargoGroupsByIdDict.includes( cg ) then
				continue;
			endif;
			cgn.getPreAssignedToScan( _strArray );
		endforeach;
	endif;
	
	return _strArray.size;

epilog

	delete iter;
	delete allIds;

end;</source>
        <Parameter name="_strArray" type="StringArray" usage="input"/>
        <Parameter name="_includePreAssigned" type="Boolean"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getNumberComplete" id="316addb7-844e-4b92-9e55-8d90944fb832">
        <source>getNumberComplete():Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 July 2018	jlgndl1	Initial creation	TFS 37882

*/

vars

	notifiedCargoGroup : CM_NotifiedCargoGroup;
	count : Integer;
	
	cargoGroup : CM_TrackedItem;	//CM_CargoGroup;

begin

	//02 Oct 2018	NDL	TFS 39186
	foreach cargoGroup in self.allCargoGroupsByIdDict do
		if cargoGroup.CM_CargoGroup.isComplete then
			count := count + 1;
		endif;
		
	endforeach;

	foreach notifiedCargoGroup in self.allNotifiedCargoGroupByIdDict do
		cargoGroup := self.myTerminal.getCargoGroupItem( notifiedCargoGroup.id );
		if cargoGroup &lt;&gt; null and self.allCargoGroupsByIdDict.includes( cargoGroup ) then
			continue;
		endif;
		if notifiedCargoGroup.isCompleted then
			count := count + 1;
		endif;
		
	endforeach;
	
	return count;

epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getNumberOutsanding" id="66a24c5e-2e2e-4de2-b55a-7ecf01107980">
        <source>getNumberOutsanding():Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 July 2018	jlgndl1	Initial creation	TFS 37882

*/

vars

	notifiedCargoGroup : CM_NotifiedCargoGroup;
	count : Integer;
	
	cargoGroup : CM_TrackedItem;	//CM_CargoGroup;

begin

	//02 Oct 2018	NDL	TFS 39186
	foreach cargoGroup in self.allCargoGroupsByIdDict do
		if not cargoGroup.CM_CargoGroup.isComplete then
			count := count + 1;
		endif;
		
	endforeach;

	foreach notifiedCargoGroup in self.allNotifiedCargoGroupByIdDict do
		cargoGroup := self.myTerminal.getCargoGroupItem( notifiedCargoGroup.id );
		if cargoGroup &lt;&gt; null and self.allCargoGroupsByIdDict.includes( cargoGroup ) then
			continue;
		endif;
		if not notifiedCargoGroup.isCompleted then
			count := count + 1;
		endif;
		
	endforeach;
	
	return count;

epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getProgressCount" id="25980d8e-8d2c-45ca-8f11-250d716b7e04">
        <source>getProgressCount():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 September 2015	cnwndl1	Initial creation	Par 36338

*/

vars

begin

	return self.allProcessedTis.size.String &amp; " / " &amp; self.totalTIcount.String;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getStatusString" id="4627d53f-b325-4367-b252-f00c91721042">
        <source>getStatusString():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 July 2018	jlgndl1	Initial creation	TFS 37882

*/

vars

begin

	if self.isCompleted then
		return app.getErrorString(Complete);
	elseif self.isInProgress then	//13 Aug 2018	NDL	TFS 40115
		return app.getErrorString(InProgress);
	else
		return app.getErrorString(Not_started);
	endif;

epilog

end;</source>
