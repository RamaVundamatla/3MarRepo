    <JadeMethod name="setMyPrimaryLocations" id="8b63f9e1-758c-4457-892a-dc4de24a7f2c">
        <updating/>
        <source>setMyPrimaryLocations(_realLocation, _plannedLocation : CM_LocationsController) updating;

// Created by cnwdvb1 on 23 January 2007

vars

begin

	// So we can screen setting of references.
	if _realLocation &lt;&gt; null then
		self.myPrimaryActualLocation := _realLocation;
		self.refreshLocationId(REAL_MODE);
	endif;
	
	if _plannedLocation &lt;&gt; null then
		self.myPrimaryPlannedLocation := _plannedLocation;
		if self.myPrimaryPlannedLocation &lt;&gt; null then //Shouldn't be null
			self.plannedLocnId := self.myPrimaryPlannedLocation.getFullIdForTIForMode(PLANNING_MODE); // PAR 20071
		endif;
	endif;
	

end;</source>
        <Parameter name="_realLocation" type="CM_LocationsController"/>
        <Parameter name="_plannedLocation" type="CM_LocationsController"/>
    </JadeMethod>
