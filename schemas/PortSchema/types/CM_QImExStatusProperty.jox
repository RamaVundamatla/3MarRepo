// Created:     05 March 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars

begin
	return app.myRoot.allImexStatuses[_value].description;

end;</source>
        <Parameter name="_value" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="translateToSearchValue" id="ba8273d6-2812-4a57-9369-fda57aba150d">
        <source>translateToSearchValue(_value: Any): Any;
// ---------------------------------------------------------------------------
// Created:     05 March 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
/*

Date		Who		Reason
06 Oct 2008	cnwkpd1	PAR #18099 - Correct Selector query processing
22 Oct 2008	cnwkpd1	PAR #18348 - Prevent 1002 exceptions in Selector query processing with isOneOf

*/

vars
	invalidObj 		: Boolean;
	object			: CM_IMEXStatus;
	returnVal		: Integer;
	
begin
	if _value &lt;&gt; null then
		if _value.isKindOf(Collection) then			// PAR #18348
			return _value;
		endif;

		if _value.isKindOf(CM_IMEXStatus) then
			object := _value.CM_IMEXStatus;
		else
			object:= app.myRoot.allImexStatuses[_value.Integer]; //epr TFS 45769
		endif;
	endif;
	
	if object &lt;&gt; null then
		on Exception do app.handleDeletedObject(exception, object, invalidObj);
		
		returnVal := object.code;
	endif;
	
	return returnVal;
	
end;
</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="translateToSearchValueForWeb" id="51ca7641-bfaf-469d-a3e3-3ae9d294dd7b">
        <source>translateToSearchValueForWeb(_value: Any; _sending : Boolean): Any;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 24/09/2019	jlgdap1		Initial creation TFS 45769 JMT Web Poral selector query parameters
//
vars
	int : Integer;
	rtnValue, collStr : String;
	strArray : StringArray;
	intArray : IntegerArray;

begin
	if _value.isKindOf(IntegerArray) then
		foreach int in _value.IntegerArray do
			rtnValue := rtnValue &amp; int.String &amp; CNEC_COMMA &amp; Space;
		endforeach;
		rtnValue := rtnValue[1:rtnValue.length-2];
		return rtnValue;
		
	elseif _value.isKindOf(String) and _value.String.cnContains("|") then
		collStr := _value.String;
		create intArray transient;
		create strArray transient;
		collStr.getTokensForDelimiter("|", strArray);
		foreach rtnValue in strArray do
			intArray.add(rtnValue.Integer);
		endforeach;
		return intArray;
		
	endif;
	
	return inheritMethod(_value, _sending);

epilog
	delete strArray;
end;</source>
        <Parameter name="_value" type="Any"/>
        <Parameter name="_sending" type="Boolean"/>
        <ReturnType type="Any"/>
    </JadeMethod>
</Class>
