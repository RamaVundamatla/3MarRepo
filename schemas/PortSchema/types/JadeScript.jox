    <JadeMethod name="rel821_par31222" id="c1233ce2-4cec-4a04-949d-50490cd80549">
        <source>rel821_par31222();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 March 2013	cnwer1	Initial creation HAT 2189
06 Oct 2017		cnwma1  TFS #7257 JMT - Refactoring - Commodity Planning
*/

vars
	vg : CM_VoyageGlobal;
	v : CM_Voyage;
	move : HMS_Movement;
begin
	app.initialize();

	foreach vg in CM_VoyageGlobal.instances do
		if vg.allVoyages.size &gt; 0 and (vg.allVoyagesArriving.size = 0 and vg.allVoyagesDeparting.size = 0) then			
			beginTransaction;
				foreach move in vg.allHMSMovements do
					move.setMyVoyageGlobal(null);
				endforeach;
				vg.allVoyages.clear;
				delete vg;
			commitTransaction;	
		endif;
	endforeach;

epilog

end;</source>
    </JadeMethod>
