    <JadeMethod name="getLCSet" id="f1c4810d-e4ef-49b4-89df-525a6bb18980">
        <source>getLCSet() : CM_LCSet;
// ---------------------------------------------------------------------------
// Created:		November 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	ta : CM_TerminalArea;
	lcSet : CM_LCSet;
begin
	create lcSet transient;
	foreach ta in self.allTAsByTypeId discreteLock do
		ta.allLocationsControllers.copy(lcSet);
	endforeach;
	
	return lcSet;
end;</source>
        <ReturnType type="CM_LCSet"/>
    </JadeMethod>
