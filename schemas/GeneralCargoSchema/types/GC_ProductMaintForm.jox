    <JadeMethod name="setIsCodesEdited" id="6c004b01-74da-4f56-81ca-72bfb9539e45">
        <updating/>
        <source>setIsCodesEdited() updating;
/* ---------------------------------------------------------------------------
Created:	03 July 2009	by cnwvu1

Purpose:	CCMS 1080 (Par17904) - User Defined Cargo Types
			CMUI_CargoTypesFrom and GC_ProductMaintForm call CMUI_CodeMaintForm
			for codes editing in product attributes. 
			isCodesEdited will give a warning for users "Codes were edited..."
			before saving.
   
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars

begin
	
