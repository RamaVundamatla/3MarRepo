    <JadeMethod name="comboBoxLogCondition" id="b331fa4a-e82c-463a-b9ac-830e4e33c38b">
        <source>comboBoxLogCondition(pTbl : CM_EntryTable input; pAttrName : String);
// ---------------------------------------------------------------------------
// Created:     03 May 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	tmpCondition	: CM_Code;
	str			: String;
	
begin

	foreach tmpCondition in app.myRoot.allLogConditionCodes do
		str := str &amp; tmpCondition.code &amp; Tab;
	endforeach;
	
	pTbl.setComboValues(pTbl.getRow(pAttrName), str);
						
