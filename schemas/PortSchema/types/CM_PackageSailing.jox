    <JadeMethod name="create" id="30d42fec-bfc7-4630-8d6a-c53c42c7477c">
        <updating/>
        <source>create() updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 04/08/2016	cnwdap1		Initial creation TFS #2415 - ACTUAL_BAYPLANS has a value of 0
//											so we need to be able to tell whether this has been set or not
//
vars

begin
	self.extractType := NULLINDEX;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getExtraInfo" id="06de6acb-530f-4802-ac9d-e932a611a32f">
        <source>getExtraInfo(_dataContainer: CM_DataContainer);

// Created by cnwdvb1 on 26 June 2006

vars

	block 	: CM_DataContainerBlock;

begin

	inheritMethod(_dataContainer);
	
	block := _dataContainer.addNewBlock;
	block.addNewItem("Include Baplie", DC_Label, 1, self);
	block.addNewItem(app.getYesNo(includeBaplie), DC_Data, 1, self);
	if self.myCamProtocol &lt;&gt; null then
		block.addNewItem("Process Cams", DC_Label, 1, self);
		block.addNewItem(self.myCamProtocol.description, DC_Data, 1, self);
	endif;
end;</source>
        <Parameter name="_dataContainer" type="CM_DataContainer"/>
    </JadeMethod>
    <JadeMethod name="isSailingPackage" id="4a4b861a-9e67-4eb0-b8fc-4c5919912f73">
        <source>isSailingPackage(): Boolean;

// Created by cnwdvb1 on 27 September 2006

vars

begin
	return true;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="aad19def-ae23-472a-95b9-80b01693b00f">
        <source>pxyCreateUpdateProxy(): SelfType;

// Created by cnwdvb1 on 26 June 2006

// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy
// 22/03/2012	cnwcs5		CCMS POL 2144 / par 29312 - Extract BAPLIE by Operator
// 29/03/2012	cnwcs5		par 29318 - conversion for par 29312
vars
	package : SelfType;
	completedOK		: Boolean;
begin

	package := inheritMethod();
	
	package.myRecipient 	:= self.myRecipient;
	package.myCargoOperator := self.myCargoOperator;	// par 29318 - march 2012
	package.myTerminal		:= self.myTerminal;
	package.myTerminalCams 	:= self.myTerminalCams;
	package.myCamProtocol 	:= self.myCamProtocol;
	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	
	return package;
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete package;
	endif;	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForProxySailing" id="5dc99456-aa6f-4e39-b0d0-7bc93c47ce15">
        <updating/>
        <source>setForProxySailing(	_code, _description : String;
					_emailTemplate 		: CM_EmailTemplate;
					_allReports			: ObjectArray input;
					_user				: CM_User;
					_type				: Integer;
					_includesBaplie		: Boolean;
					_extractType,
					_fileType			: Integer;
					_recipient			: CM_Operator;
					_cargoOperator		: CM_Operator;	// par 29312 - march 2012
					_terminal			: CM_Terminal;
					_camProtocol : CM_CamProtocol;
					_terminalCams : CM_Terminal) updating;

// Created by cnwdvb1 on 26 June 2006
// 21/03/2012	cnwcs5	Initial creation - CCMS POL 2144 / Par 29312 - Extract Baplie by Operator
// 29/03/2012	cnwcs5	par 29318 - conversion for 29312
vars

begin

	self.includeBaplie		:= _includesBaplie;
	
	if _includesBaplie then
		self.extractType		:= _extractType;
		self.fileType			:= _fileType;
		self.myRecipient		:= _recipient;
		self.myCargoOperator 	:= _cargoOperator;	// par 29318/29312 - march 2012
		self.myTerminal			:= _terminal;
	else
		self.extractType		:= null;
		self.fileType			:= null;
		self.myRecipient		:= null;
		self.myCargoOperator 	:= null;				// par 29318/29312 - march 2012
		self.myTerminal			:= null;
	endif;
	
	self.myCamProtocol 	:= _camProtocol;
	self.myTerminalCams := _terminalCams;
	
	self.setForProxy(_code, _description, _emailTemplate, _allReports, _user, _type, null, null, null);		//navra1 - CR 61910/Task 62303 - 15th Feb 2024
end;</source>
        <Parameter name="_code" type="String"/>
        <Parameter name="_description" type="String"/>
        <Parameter name="_emailTemplate" type="CM_EmailTemplate"/>
        <Parameter name="_allReports" type="ObjectArray" usage="input"/>
        <Parameter name="_user" type="CM_User"/>
        <Parameter name="_type" type="Integer"/>
        <Parameter name="_includesBaplie" type="Boolean"/>
        <Parameter name="_extractType" type="Integer"/>
        <Parameter name="_fileType" type="Integer"/>
        <Parameter name="_recipient" type="CM_Operator"/>
        <Parameter name="_cargoOperator" type="CM_Operator"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_camProtocol" type="CM_CamProtocol"/>
        <Parameter name="_terminalCams" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="0d3928a9-e868-4134-b653-7e75d133724a">
        <updating/>
        <source>setForUpdate(_proxyPackage: CM_PackageSailing) updating;

// Created by cnwdvb1 on 26 June 2006
// 22/03/2012	cnwcs5	CCMS POL 2144 / par 29312 - Extract BAPLIE by Operator
// 29/03/2012	cnwcs5	par 29318 - conversion for 9312
vars

begin

	self.includeBaplie		:= _proxyPackage.includeBaplie;
	self.extractType		:= _proxyPackage.extractType;
	self.fileType			:= _proxyPackage.fileType;
	self.myRecipient		:= _proxyPackage.myRecipient;
	self.myCargoOperator 	:= _proxyPackage.myCargoOperator;	// par 29318/29312 - march 2012
	self.myTerminal			:= _proxyPackage.myTerminal;
	self.myCamProtocol 		:= _proxyPackage.myCamProtocol;
	self.myTerminalCams 	:= _proxyPackage.myTerminalCams;

	inheritMethod(_proxyPackage);

end;</source>
        <Parameter name="_proxyPackage" type="CM_PackageSailing"/>
    </JadeMethod>
    <JadeMethod name="validate" id="370992fe-fe20-44b7-a0b6-fef016050b15">
        <source>validate(_realPackage : CM_Package);
// Created by cnwdvb1 on 27 June 2006
//
// Changed On	By			Reason
// ----------	------		------------------------------------------------
// 23/05/2016	cnwdap1		TFS #1881 BAPLIE/EDI VGM Updates
// 04/08/2016	cnwdap1		TFS #2415 Format and Extract Type messages were the wrong way around,
//									Coprar and Movins file types weren't included in extract type check
vars

begin
	inheritMethod(_realPackage);

	if self.includeBaplie then	
		if	self.fileType &lt;&gt; EDIFileType_Baplie15 and
			self.fileType &lt;&gt; EDIFileType_Baplie20 and
			self.fileType &lt;&gt; EDIFileType_Baplie22 and				// TFS #1881
			self.fileType &lt;&gt; EDIFileType_VSLStow and
			self.fileType &lt;&gt; EDIFileType_BayFile and
			self.fileType &lt;&gt; EDIFileType_Anf and
			self.fileType &lt;&gt; EDIFileType_Coprar and														// TFS #2415
			self.fileType &lt;&gt; EDIFileType_Movins and														// TFS #2415
			self.fileType &lt;&gt; EDIFileType_XML_TOLL_PREADVICE  then
		//	app.raiseCMException1(REQUIRED_FIELD, 'Extract Type', null, null);
			//app.raiseCMException(Input_required_field_extrctTyp, null, null); // cnwdb2	PAR 35364	// TFS #2415
			app.raiseCMException(Input_required_field_format, null, null); // cnwdb2	PAR 35364		// TFS #2415


		endif;
		
		if self.extractType &lt;&gt; ACTUAL_BAYPLANS and self.extractType &lt;&gt; PROPOSED_BAYPLANS then
		//	app.raiseCMException1(REQUIRED_FIELD, 'Format', null, null);
			//app.raiseCMException(Input_required_field_format, null, null); // cnwdb2	PAR 35364		// TFS #2415
			app.raiseCMException(Input_required_field_extrctTyp, null, null); // cnwdb2	PAR 35364		// TFS #2415
		endif;
		
		if self.myRecipient = null then
		//	app.raiseCMException1(REQUIRED_FIELD, 'Receipient', null, null);
			app.raiseCMException(Input_required_field_recipnt, null, null); // cnwdb2	PAR 35364


		endif;
		
		if self.myTerminal = null then
		//	app.raiseCMException1(REQUIRED_FIELD, 'Terminal', null, null);
			app.raiseCMException(Input_required_field_terminal, null, null); // cnwdb2	PAR 35364


		endif;
	endif;
	
end;</source>
        <Parameter name="_realPackage" type="CM_Package"/>
    </JadeMethod>
</Class>
