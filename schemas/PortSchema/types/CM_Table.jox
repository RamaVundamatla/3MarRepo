    </JadeMethod>
    <JadeMethod name="mouseDown" id="c8613ab5-465e-4889-9b4b-862b45eb9eed">
        <updating/>
        <source>mouseDown(table : Table input; button : Integer; shift : Integer; x : Real; y : Real) updating;

vars
	tmp:      Integer;
	ptRow:    Integer;
	ptCol:    Integer;
	sortCol:  Integer;
begin

	keyAndMouseStatus(shift, button);

	//doLateSelectionEvaluation := false;

	if explorerStyle and button = MouseButton_Right then
		positionToCell(x, y, ptRow, ptCol);
		if ptRow = -1 or ptCol = -1 then
			// point is off table: do nothing.
			return;
		endif;

		if bShift or bControl then
			// leave the row and column alone
		else
			row := ptRow;
			anchorRow := row;
			column := ptCol;
			anchorColumn := column;
		endif;

		if not selected then
			clearAllSelected;
		endif;

		if selectRows then
			selectRow(row);
		endif;

		rowColumnChg(table);
		click(table);

		return;
	endif;

	// handle case where the row or column size is being changed
	// this is a kludge at this time.
	positionToCell(x, y, ptRow, ptCol);
	if row &lt;&gt; ptRow or column &lt;&gt; ptCol then
		return;
	endif;

	if row &lt;= fixedRows then
		if resortOnClick then
			sortCol := column;
			if readOnly then
				if prevRow &gt; 0 and prevRow &lt;= rows then
					row := prevRow;
				endif;
				if prevColumn &gt; 0 and prevColumn &lt;= columns then
					column := prevColumn;
				endif;
			endif;
			
			if bShift or bControl then
				pushSortColumn(sortCol);
				doResort;
			else
				setSortColumn(sortCol);
				doResort;
			endif;
			
			if readOnly then
				// don't evaluate the selection
				prevRow := row;
				prevColumn := column;
				moveToCurrentCell;
				return;		
			else
				selectCell(row, column);
			endif;
		endif;
	elseif explorerStyle then
		if readOnly then
			// if the current cell is selected then this may be the start of a drag-drop
			// so don't change the selection yet.
			if not bShift and selected then
				doLateSelectionEvaluation := true;

				return;
			endif;
		else
			if isInSelectedCells(row, column) and not bShift then
				bControl := true;
				evaluateSelection(0);
				selectCell(row, column);
				keyAndMouseStatus(shift, button);
				doLateSelectionEvaluation := true;
				return;
			endif;
		endif;
	endif;

	evaluateSelection(0);

epilog

	inheritMethod(table, button, shift, x, y);
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="mouseUp" id="bca6b526-6ca1-42ef-b83d-5314a08bb806">
        <updating/>
        <source>mouseUp(table : Table input; button : Integer; shift : Integer; x : Real; y : Real) updating;

vars

begin
	
	if doLateSelectionEvaluation then
		evaluateSelection(0);
		doLateSelectionEvaluation := false;
	endif;

epilog
	inheritMethod(table, button, shift, x, y);
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="moveToCurrentCell" id="72ad91f9-fcd3-4c62-82b5-08281274b801">
        <updating/>
        <source>moveToCurrentCell() updating;

vars
	down:   Boolean;
begin
	// adjust topRow
	if positionTop = -1 then
		// not currently visible
		if topRow &gt; row then
			// need to page up
			topRow := row;
		else
			// need to page down
			down := false;
			topRow := nextPageRow(down);
		endif;
	endif;

	// adjust leftColumn
	if positionLeft = -1 then
		// not currently visible
		if leftColumn &lt; column then
			// need to page up
			leftColumn := column;
			while leftColumn &gt; fixedColumns and positionLeft &lt;&gt; -1 do
				leftColumn := leftColumn - 1;
			endwhile;
			leftColumn := leftColumn + 1;
		else
			leftColumn := column;
		endif;
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="nextPageRow" id="5ea39ca0-929b-4848-8a55-5a71bca0ca30">
        <source>nextPageRow(down: Boolean): Integer;

vars
	pageHeight:      Real;
	y:               Real;
	theRow:          Integer;
begin
	pageHeight := clientHeight;
	theRow := 1;
	while theRow &lt;= fixedRows do
		if rowVisible[theRow] then
			pageHeight := pageHeight - rowHeight[theRow];
		endif;
		theRow := theRow + 1;
	endwhile;

	theRow := row;

	// scan down or up the column to find appropriate row
	while true do
		if theRow &gt; rows then
			break;
		elseif theRow &lt;= fixedRows then
			theRow := fixedRows + 1;
			break;
		endif;
		if rowVisible[theRow] then
			y := y + rowHeight[theRow];
		endif;
		if pageHeight &lt;= y then
			if pageHeight &lt; y then
				// we can't see the whole row so step back one
				if down then
					theRow := theRow - 1;
				else
					theRow := theRow + 1;
				endif;
			endif;
			break;
		else
			// increment the row
			if down then
				theRow := theRow + 1;
			else
				theRow := theRow - 1;
			endif;
		endif;
	endwhile; 

	if theRow &lt;= fixedRows then
		theRow := fixedRows + 1;
	endif;
	if theRow &gt; rows then
		theRow := rows;
	endif;

	return theRow;
end;</source>
        <Parameter name="down" type="Boolean"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="positionToCell" id="50f602a8-9175-4bd8-b95e-ee6767e6f7a0">
        <source>positionToCell(xPos: Real; yPos: Real; theRow: Integer io; theColumn: Integer io);

vars
	x:               Real;
	y:               Real;
begin

	// intialise to first visible row and column
	if fixedRows &gt; 0 then
		theRow := 1;
	else
		theRow := topRow;
	endif;

	if fixedColumns &gt; 0 then
		theColumn := 1;
	else
		theColumn := leftColumn;
	endif;

	// scan along row to find appropriate column
	while true do
		if theColumn &gt; columns then
			theColumn := -1;
			break;
		endif;
		if columnVisible[theColumn] then
			x := x + columnWidth[theColumn];
		endif;
		if xPos &lt;= x then
			break;
		else
			// increment column
			theColumn := theColumn + 1;
			if theColumn &lt; leftColumn and theColumn &gt; fixedColumns then
				theColumn := leftColumn;
			endif;
		endif;
	endwhile; 

	// scan down column to find appropriate row
	while true do
		if theRow &gt; rows then
			theRow := -1;
			break;
		endif;
		if rowVisible[theRow] then
			y := y + rowHeight[theRow];
		endif;
		if yPos &lt;= y then
			break;
		else
			// increment the row
			theRow := theRow + 1;
			if theRow &lt; topRow and theRow &gt; fixedRows then
				theRow := topRow;
			endif;
		endif;
	endwhile; 

end;</source>
        <Parameter name="xPos" type="Real"/>
        <Parameter name="yPos" type="Real"/>
        <Parameter name="theRow" type="Integer" usage="io"/>
        <Parameter name="theColumn" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="pushSortColumn" id="4e90f149-4cbf-4479-ab5f-e8abb257b3bc">
        <updating/>
        <source>pushSortColumn(newSortColumn: Integer) updating;

vars
	needToSort:  Boolean;
	mappedCol:   Integer;
begin
	mappedCol := getMappedSortColumn(newSortColumn);

	if sortColumn[1] = 0 then
		sortColumn[1] := mappedCol;
		sortCased[1] := true;
	elseif sortColumn[2] = 0 then
		if sortColumn[1] = mappedCol then
			sortAsc[1] := not sortAsc[1];
		else
			sortColumn[2] := mappedCol;
			sortCased[2] := true;
		endif;
	elseif sortColumn[3] = 0 then
		if sortColumn[2] = mappedCol then
			sortAsc[2] := not sortAsc[2];
		else
			sortColumn[3] := mappedCol;
			sortCased[3] := true;
		endif;
	elseif sortColumn[3] = mappedCol then
			sortAsc[3] := not sortAsc[3];
	else
		// sort columns are all full up so...
		// start again.
		// now push latest into 1st and drop rest
		flushSortColumn;
		sortColumn[1] := mappedCol;
		sortCased[1] := true;
	endif;

end;</source>
        <Parameter name="newSortColumn" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="readOnly" id="59f46a30-8778-4371-87dd-56eb8533ee9d">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <source>readOnly(set: Boolean; value: Boolean io) mapping, updating;

vars

begin
	/*
	if set then
		// disaffect attempts to change readOnly status
		if explorerStyle then
			value := true;
		endif;
	endif;
	*/

	inheritMethod(set, value);
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="value" type="Boolean" usage="io"/>
    </JadeMethod>
    <JadeMethod name="refreshSelection" id="815e7062-21e1-4c52-accf-4e8fa688653e">
        <updating/>
        <source>refreshSelection() updating;

// reads the cells that should be selected and selects them
// it is a bit slow for big tables...
constants
	TWO_BYTE_SHIFT = 2^16;
vars
	rowIndex:  Integer;
	colIndex:  Integer;
	hashInt:   Integer;
	currentMP: Integer;
begin
	currentMP := app.mousePointer;

	if doLateSelectionEvaluation then
		app.mousePointer := MousePointer_HourGlass;
	endif;
	if explorerStyle then
		foreach hashInt in selectedCells do
			rowIndex := hashInt mod TWO_BYTE_SHIFT;
			colIndex := hashInt div TWO_BYTE_SHIFT;
			selectCell(rowIndex, colIndex);
		endforeach;
	endif;

epilog
	app.mousePointer := currentMP;
end;</source>
    </JadeMethod>
    <JadeMethod name="removeFromSelectedCells" id="80c60af2-48a6-4716-bd31-9169e4c5cad2">
        <updating/>
        <source>removeFromSelectedCells(r: Integer; c: Integer) updating;

constants
	TWO_BYTE_SHIFT = 2^16;
vars
	hashInt:   Integer;
begin
	if not readOnly then
		if selectRows then
			hashInt := r;
		else
			hashInt := c * TWO_BYTE_SHIFT + r;
		endif;
		if selectedCells.includes(hashInt) then
			selectedCells.remove(hashInt);
		else
			// debug
			
		endif;
	endif;
end;</source>
        <Parameter name="r" type="Integer"/>
        <Parameter name="c" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="selectCell" id="270c5b79-1a87-4bc4-bbbc-c68473226109">
        <updating/>
        <source>selectCell(r: Integer; c: Integer) updating;

vars

begin
	if selectRows then
		selectRow(r);
	else
		if not isInSelectedCells(r, c) then
			addToSelectedCells(r, c);
		endif;
		setCellSelected(r, c, true);
	endif;

end;</source>
        <Parameter name="r" type="Integer"/>
        <Parameter name="c" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="selectCells" id="adf48922-47f5-42c5-9089-d57b8b706b5c">
        <updating/>
        <source>selectCells(startRow: Integer; startColumn: Integer; endRow: Integer; endColumn: Integer) updating;

vars
	i:               Integer;
	j:               Integer;
	rowIncrement:    Integer;
	rowdiff:         Integer;
	columnIncrement: Integer;
	columndiff:      Integer;
	currentMP:       Integer;
begin
	currentMP := app.mousePointer;
	app.mousePointer := MousePointer_HourGlass;

	if startRow &gt;= endRow then
		rowIncrement := -1;
	else
		rowIncrement := 1;
	endif;
	rowdiff := endRow - startRow + rowIncrement;

	if startColumn &gt;= endColumn then
		columnIncrement := -1;
	else
		columnIncrement := 1;
	endif;
	columndiff := endColumn - startColumn + columnIncrement;

	if multiSelect then
		if selectRows then
			i := startRow;
			while i &lt;&gt; (startRow + rowdiff) do
				selectRow(i);
				i := i + rowIncrement;
			endwhile;
		else
			i := startRow;
			while i &lt;&gt; (startRow + rowdiff) do
				j := startColumn;
				while j &lt;&gt; (startColumn + columndiff) do
					selectCell(i, j);
					j := j + columnIncrement;
				endwhile;
				i := i + rowIncrement;
			endwhile;
		endif;
	else
		selectCell(endRow, endColumn);
	endif;

epilog
	app.mousePointer := currentMP;
end;</source>
        <Parameter name="startRow" type="Integer"/>
        <Parameter name="startColumn" type="Integer"/>
        <Parameter name="endRow" type="Integer"/>
        <Parameter name="endColumn" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="selectObject" id="b613fa4b-789a-47af-8796-a489f49441d7">
        <updating/>
        <source>selectObject(_obj : Object; _makeTopRow : Boolean) : Boolean updating;

/*

Purpose:		
Parameters:		
Return Value:	

Date				Who		Reason
22 January 2009		cnwrl1	Initial creation (CCMS SFW 1047 - Totals Only Lists)
							This is a copy of the method on CM_DataTable by cnwrs2.

*/
	
vars
	rowIdx	: Integer;
	
begin
	if not self.findObjectInRow( _obj, rowIdx ) then
		return false;
	endif;
	
	self.row							:= rowIdx;
	self.accessRow( rowIdx ).selected	:= true;
	if _makeTopRow then
		self.topRow	:= rowIdx;
	endif;
	
	return true;
	
epilog
	
end;
</source>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_makeTopRow" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="selectRow" id="775812fd-6404-45ed-bf98-37a7bc3b84d0">
        <updating/>
        <source>selectRow(r: Integer) updating;
// selects row ignoring current selection status
vars
	colIndex:       Integer;
begin
	if row &gt; fixedRows then
		//selectedRows[r] := true;
		if not isInSelectedCells(r, 0) then
			addToSelectedCells(r, 0);
		endif;
		if fixedColumns &gt; 0 then
			setCellSelected(r, 1, true);
		else
			colIndex := 1;
			while colIndex &lt;= columns do
				setCellSelected(r, colIndex, true);
				colIndex := colIndex + 1;
			endwhile;
		endif;
	else
		setCellSelected(r, column, false);
	endif;
end;</source>
        <Parameter name="r" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setLastColumnMaxWidth" id="cf83d4f1-4d84-4743-a264-e949948f63db">
        <updating/>
        <source>setLastColumnMaxWidth()  updating;
// ---------------------------------------------------------------------------
// Created:		April  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	idx, aColumns, barWidth : Integer;
begin

	if self.scrollBars = self.ScrollBars_Vertical or self.scrollBars = self.ScrollBars_Both then
		barWidth := 18;
	endif;
	foreach idx in 1 to self.columns - 1 do
		if self.accessColumn(idx).visible then
			aColumns := aColumns + self.accessColumn(idx).width;
		endif;
	endforeach;
	self.accessColumn(self.columns).width := ( self.width - aColumns - 2 - barWidth).Integer;

end;</source>
    </JadeMethod>
    <JadeMethod name="setRowIdColumns" id="862344f4-eda3-4719-933d-a07943010ae5">
        <updating/>
        <source>setRowIdColumns(firstColumn: Integer; secondColumn: Integer) updating;
// columns must be less than 16000
constants
	TWO_BYTE_SHIFT = 2^16;
vars

begin
	if firstColumn = 0 and secondColumn &lt;&gt; 0 then
		// use second column as first and only
		rowIdColumns := secondColumn;
	else
		rowIdColumns := secondColumn * TWO_BYTE_SHIFT + firstColumn;
	endif;
end;</source>
        <Parameter name="firstColumn" type="Integer"/>
        <Parameter name="secondColumn" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setSortColumn" id="a4f631ab-a58c-4405-b5e9-d097721bcb10">
        <updating/>
        <source>setSortColumn(newSortColumn: Integer) updating;

vars
	ascSort:     Boolean;
	mappedCol:   Integer;
begin
	mappedCol := getMappedSortColumn(newSortColumn);
	if sortColumn[1] = mappedCol then
		ascSort := sortAsc[1];
	endif;

	flushSortColumn;
	sortColumn[1] := mappedCol;
	sortAsc[1] :=  not ascSort;
	sortCased[1] := true;

end;</source>
        <Parameter name="newSortColumn" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="toggleCell" id="7d9f5b6f-e2a9-4a88-8530-36b5fb0edae0">
        <updating/>
        <source>toggleCell(r: Integer; c: Integer) updating;

vars
	currStatus:  Boolean;
begin

	if selectRows then
		toggleRow(r);
	else
		if isInSelectedCells(r, c) then
			currStatus := true;
			removeFromSelectedCells(r, c);
		else
			currStatus := false;
			addToSelectedCells(r, c);
		endif;
		setCellSelected(r, 1, not currStatus);
	endif;

end;</source>
        <Parameter name="r" type="Integer"/>
        <Parameter name="c" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="toggleRow" id="6b61b078-6d88-45ac-8dcb-d3510dcf383b">
        <updating/>
        <source>toggleRow(r: Integer) updating;
// toggles selected property of row of current cell 
// as long as we are not in fixed row
vars
	currStatus:     Boolean;
	colIndex:       Integer;
begin
/*
	if row &gt; fixedRows then
		//currStatus := getCellSelected(r, 1);
		if r &lt;= selectedRows.size then
			currStatus := selectedRows[r];
		else
			currStatus := false;
		endif;
		selectedRows[r] := not currStatus;
		if fixedColumns &gt; 0 then
			setCellSelected(r, 1, not currStatus);
		else
			colIndex := 1;
			while colIndex &lt;= columns do
				setCellSelected(r, colIndex, not currStatus);
				colIndex := colIndex + 1;
			endwhile;
		endif;
	else
		setCellSelected(r, column, false);
	endif;
*/
	if r &gt; fixedRows then
		if isInSelectedCells(r, 0) then
			currStatus := true;
			removeFromSelectedCells(r, 0);
		else
			currStatus := false;
			addToSelectedCells(r, 0);
		endif;
		if fixedColumns &gt; 0 then
			setCellSelected(r, 1, not currStatus);
		else
			colIndex := 1;
			while colIndex &lt;= columns do
				setCellSelected(r, colIndex, not currStatus);
				colIndex := colIndex + 1;
			endwhile;
		endif;
	else
		setCellSelected(r, column, false);
	endif;

end;</source>
        <Parameter name="r" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="userNotify" id="6498165b-2432-4573-ace8-0654bcd02eee">
        <updating/>
        <source>userNotify(table : Table input; eventType : Integer; theObject : Object; eventTag : Integer; userInfo : Any) updating;

vars

begin
	if eventType = Selection_Event then
		evaluateSelection(userInfo.Integer);
	endif;

	inheritMethod(table, eventType, theObject, eventTag, userInfo);
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
