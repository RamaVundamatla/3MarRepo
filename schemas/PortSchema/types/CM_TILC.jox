    <JadeMethod name="getOnboardISOTypeGroups" id="c938decb-a204-4d0e-9dc3-074f13ca2248">
        <source>getOnboardISOTypeGroups(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date					Who		Reason
24 November 2023		jlizm1	Initial creation TFS 61273 add Onboard Isotype group field

*/

vars
	lc 			: CM_LocationsController;
	ti 			: CM_TrackedItem;
	tmpStr 		: String;
	isoGroupStr : String;
	isoGroup 	: CM_ISOTypeGroup;
    failedDAC   : CM_DataAccessController;       //JIRA-34864 
	
begin
	foreach lc in self.allLCs do
		foreach ti in lc.allTrackedItems do
            if not ti.canUserAccessSelf(null, failedDAC, app.myPassport) then           //JIRA-34864 
                continue;                                                               //JIRA-34864
            endif;                                                                      //JIRA-34864
			isoGroup := ti.getISOTypeGroup();
			if isoGroup = null then
				continue;
			endif;
			
			isoGroupStr := isoGroup.code;
			/*
			if tmpStr = null then
				tmpStr := isoGroupStr;
			elseif tmpStr.pos(isoGroupStr, 1) = 0 then
				tmpStr := tmpStr &amp; ', ' &amp; isoGroupStr;
			endif;
			*/
			
			tmpStr.addStringToList(isoGroupStr, ", "); //04/04/2025	navkc1 JIRA Story MTN-33940
			
			if ti.isKindOf( CM_TILC ) then // a stack of trailers
				isoGroupStr := ti.getOnboardISOTypeGroups();
				if isoGroupStr &lt;&gt; null then
					tmpStr := tmpStr &amp; ', ' &amp; isoGroupStr;
				endif;
			endif;
			
		endforeach;
	endforeach;
	
	return tmpStr;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getOnboardISOTypes" id="66736f15-5ed8-4c91-ad68-a272fd044a12">
