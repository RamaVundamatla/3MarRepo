    <JadeMethod name="getAllReserveDetailsAssigned" id="3e188c9b-5d0e-44fd-b27e-cbe2019672b5">
        <source>getAllReserveDetailsAssigned() : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 July 2023	navmv20	CR 58420 Task 58421: Jade - Data Extra JRW Views

*/

vars
	detail : CM_ReserveDetail;
	detailStr : String;
begin
	// Because this is an array, need to hold the sharedLock while iterating, otherwise 1308 exceptions can occur
	foreach	detail in self.allReserveDetailAssigned do
 
 		if detailStr = "" then
			detailStr := detail.oidAsBin;
		else
			detailStr := detailStr &amp; "," &amp; detail.oidAsBin;
		endif;

	endforeach;
	
	return detailStr;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getAssignedAsDelimString" id="c1be89ff-9622-496f-a337-effa37cc534f">
        <source>getAssignedAsDelimString( _delimiter : String ):String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 June 2015	cnwndl1	Initial creation	Par 36338
28 May 2024  navrv30 CR 64323 Task 64328: Jade - Change Existing Assigned Method
*/

vars

	str : String;
	iter : Iterator;
	ti : CM_TrackedItem;

begin

	iter := self.allAssignedTrackedItems.createIterator;
	while iter.next( ti ) do
		if str &lt;&gt; null then
			str := str &amp; _delimiter;
		endif;
		if str.length + ti.id.length &gt; 100 then
			str := str[1:str.length] &amp; "..."; 
			break;
		endif;
		str := str &amp; ti.id;
		if ti.totalQuantity &gt; 1 then
			str := str &amp; " (x" &amp; ti.totalQuantity.String &amp; ")";
		endif;		
	endwhile;
	
	return str;

epilog

	delete iter;

end;</source>
        <Parameter name="_delimiter" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getCGCargoSubTypeForContents" id="4ecc112a-fd82-41b4-9bae-31eeb130320c">
        <source>getCGCargoSubTypeForContents() : CM_Product;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02/10/2025	navkc1 JIRA 36151 AAT | RotaBox ISO Type and New Attributes - JADE

*/

vars
	ti : CM_TrackedItem;
begin
	
	ti := self.allAssignedTrackedItems.first();
	
	if ti &lt;&gt; null then
		return ti.getCargoSubTypeForContents();
	endif;
	
	return null;
	
epilog

end;</source>
        <ReturnType type="CM_Product"/>
    </JadeMethod>
    <JadeMethod name="getCGCargoTypeForContents" id="e1c1e3c3-503f-4b48-84bb-c1d3e1c955f6">
        <source>getCGCargoTypeForContents() : CM_CargoType;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02/10/2025	navkc1 JIRA 36151 AAT | RotaBox ISO Type and New Attributes - JADE

*/

vars
	ti : CM_TrackedItem;
begin
	
	ti := self.allAssignedTrackedItems.first();
	
	if ti &lt;&gt; null then
		return ti.getCargoTypeForContents();
	endif;
	
	return null;
	
epilog

end;</source>
        <ReturnType type="CM_CargoType"/>
    </JadeMethod>
    <JadeMethod name="getCOODate" id="09eeda2f-1d5f-4c59-9626-1cd33912d0de">
        <source>getCOODate() : String;
/*
Purpose:			

Date		Who		Reason
24 July 2023 navmv20 CR 58239 Task 58240: UI - New COO columns
28 May 2024  navrv30 CR 64323 Task 64326: Jade - Chnage Existing COO methods to use Details
24/03/2025	navkc1 JIRA Story MTN-34256: MTN | Cargo Group Details for non Euroports Clients
*/

vars
	cgd : CM_CargoGroupDetail;
	retStr, valueStr : String;
	ti : CM_TrackedItem;
begin
	//24/03/2025	navkc1 JIRA Story MTN-34256
	if self.allCargoGroupDetails.isEmpty() then
		foreach ti in self.allAssignedTrackedItems discreteLock do
			retStr.addStringToList(ti.getCOODate(), ", ");
		endforeach;
	else
		foreach cgd in self.allCargoGroupDetails discreteLock do
			valueStr := cgd.cooDates;
			/*
			if valueStr &lt;&gt; null then
				if retStr.pos(valueStr, 1) = 0 then
					if retStr = null then
						retStr := valueStr;
					else
						retStr := retStr &amp; ", " &amp; valueStr;
					endif;
				endif;
			endif;
			*/
			
			retStr.addStringToList(valueStr, ", "); //04/04/2025	navkc1 JIRA Story MTN-33940
		endforeach;
	endif;
	
	return retStr;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
