    <JadeMethod name="eprTest" id="2d4296ed-4e21-44d2-9f7e-0c8f0f3080eb">
        <source>eprTest();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 November 2012	cnwer1	Initial creation SFW 1295

*/

vars
	entry : CM_RTQueueEntry;
	rtArbiter : CM_RTQueueArbiter;
	job : CM_Job;
	wle : CM_WorkListEntry;
lc : CM_LocationsController;
gcController : CM_ROROGCController;
types : StringArray;
	nums : IntegerArray;
	ti : CM_TrackedItem;
	aColour : Integer;
	type : String;
	idx ,size : Integer;
begin
	
	gcController :="9910.106547".asOid.CM_ROROGCController;
	app.initialize;
	create types transient;
	create nums transient;
nums[10] := 0;
	foreach ti in gcController.allTrackedItems do
		aColour := ti.getDrawingColour(TI_ColourMode_DischargePort);
		type := ti.getPlannerReportDischGroupDesc();
		idx := types.indexOf(type);
		if idx = 0 then
			types.add(type);
			size := types.size;
			nums[size] := nums[size] + ti.totalQuantity.max(1);
		else
			nums[idx] := nums[idx] + ti.totalQuantity.max(1);
		endif;
	
	endforeach;
	
	nums.inspectModal;
	types.inspectModal;
		return;
	write "9975.92110".asOid.CM_Request.getNumTIsOfMode(REAL_MODE, true).String;

	//write "2424.632175".asOid.CM_VoyageWLE.isSOB;
	entry:="2831.191230".asOid.CM_RTQueueEntry;
	app.initialize();
	app.myPassport.setMyUserFromCode("CNWER1");
	app.myPassport.setMyTerminal(entry.getMyTerminal());
	create rtArbiter transient;
	job:="2274.50228".asOid.CM_RoadJob;// entry.myJob;
	lc := job.CM_RoadJob.myVehicleVisit.myGateIn.getDefaultYardLocation_IN(job.CM_RoadJob.myVehicle);

	//app.myPassport.setWarningsIgnored(true);
	//app.myTrxUA.trxMoveVehicle(job.CM_RoadJob.myVehicle, lc.CM_YardController, app.myPassport);
	
	beginTransaction;
	
		foreach wle in job.workListEntries discreteLock do
				// if wle complete then there will be no Q entry for it :-)
				foreach 	entry in wle.allRTQueueEntries do
					// cnwjk3 14/10/09 PAR 20985
					// Hack - due to no one developer having the complete picture of how director tasks should behave.
					// See PAR for more details.
					// rtArbiter.moveEntryBasedOnToLocation(rtQueueEntry, terminal);
					//if  rtQueueEntry.findTaskOfType(TASK_DIRECTOR, null) = null then			// was
					//if  rtQueueEntry.findTaskOfType(TASK_DIRECTOR, NULL_INTEGER) = null then	// 26540 cnwjre1 Dec 2010 correct the 'null' parameter
						rtArbiter.reset;
						rtArbiter.moveEntryBasedOnToLocation(entry, entry.getMyTerminal);
					//endif;
				endforeach;
			endforeach;
	
	//rtArbiter.moveEntryBasedOnToLocation(entry, entry.getMyTerminal());
	commitTransaction;
epilog
	delete rtArbiter;
	delete types;
	delete nums;
end;</source>
    </JadeMethod>
    <JadeMethod name="eprTest33386" id="36027488-bc81-4792-905b-27e5abf05289">
