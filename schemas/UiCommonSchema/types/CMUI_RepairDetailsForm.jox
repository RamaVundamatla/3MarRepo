    <JadeMethod name="doOk" id="6c26aba9-0794-475f-b8e3-de1304b8055c">
        <updating/>
        <source>doOk()updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 July 2022	navak20	TFS ChangeRequest 53862: EUP - WMS - Damage Recording Extra Details
17/07/23		navcs2	Bug 59045: FR | 54536 EUP - Repair Data Processing Timing - Old Weights for Repair Messages
31/08/2023	navcs2	Bug 60155: EUP | FR 54536 - Damage and Repair CAMS - Items found WP1
*/

vars
	quantity : Integer;
	tareWeight : Decimal[14,4];
	cargoWeight : Decimal[14,4];
	totalWeight : Decimal[14,4];
	reason : String;
	diameter : Decimal[14,4];
	height : Decimal[14,4];
	volume : Decimal[14,4];
	rollingLength : Decimal[14,4];
	length : Decimal[14,4];
	grammage : Decimal[14,4];
	width : Decimal[14,4];
	theReturn : Integer;
	trackedItem,
	realTI		: CM_TrackedItem;
	txnParams	: CMIF_BBDiscrepancyController;
	ti			: CM_TrackedItem;
begin
	if self.txtQuantity.text &lt;&gt; null then
		quantity := self.txtQuantity.text.Integer;
		if quantity = 0 then													// 31/08/2023	navcs2	Bug 60155
			app.raiseCMException(Not_Allowed_Quantity_Zero, "quantity", null); 	// 31/08/2023	navcs2	Bug 60155
		endif;																	// 31/08/2023	navcs2	Bug 60155
	endif;
	if self.mskTareWeight.text &lt;&gt; null then
		tareWeight := self.mskTareWeight.getConvertedValue();
	endif;
	if self.mskCargoWeight.text &lt;&gt; null then
		cargoWeight := self.mskCargoWeight.getConvertedValue();
	endif;
	if self.mskTotalWeight.text &lt;&gt; null then
		totalWeight := self.mskTotalWeight.getConvertedValue();
	endif;
	if self.txtReason.text &lt;&gt; null then
		reason := self.txtReason.text;
	endif;
	if self.mskDiameter.text &lt;&gt; null then
		diameter := self.mskDiameter.getConvertedValue();
	endif;
	if self.mskHeight.text &lt;&gt; null then
		height := self.mskHeight.getConvertedValue();
	endif;
	if self.mskVolume.text &lt;&gt; null then
		volume := self.mskVolume.getConvertedValue();
	endif;
	if self.mskRollingLength.text &lt;&gt; null then
		if self.myTrackedItem &lt;&gt; null then
			ti := self.myTrackedItem;
		else
			ti := self.pxyTrackedItem;
		endif;
		if ti.totalWeight.Decimal &lt;&gt; self.mskTotalWeight.text.Decimal then
			rollingLength := self.calculateRollingLength();
		else
			rollingLength := self.mskRollingLength.getConvertedValue();
		endif;
	endif;
	if self.mskLength.text &lt;&gt; null then
		length := self.mskLength.getConvertedValue();
	endif;
	if self.txtGrammage.text &lt;&gt; null then
		grammage := self.txtGrammage.text.Decimal;
	endif;
	if self.mskWidth.text &lt;&gt; null then
		width := self.mskWidth.getConvertedValue();
	endif;
	
	self.calculateTotalWeight(self.mskTotalWeight);
	
	if self.myTrackedItem &lt;&gt; null then
		trackedItem := app.createUpdateProxy(self.myTrackedItem).CM_TrackedItem;
		while true do
			app.myTrxUA.trxUpdateRepairedDimensions(trackedItem, quantity, tareWeight, cargoWeight, totalWeight, reason, diameter, height, volume, rollingLength, length,grammage, width, app.myPassport);
			if app.myPassport.trxCompletedOK then
				self.clearErrorWarnings();
				break;
			else
				theReturn := app.showErrorWarningDialog(app.getErrorString(RepairedDetails), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
				if app.myPassport.noErrors and
				   theReturn = IDOK then
					// there must have just been warnings that the user has acknoledged so ..
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
				self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
				return;
			endif;
			break;
		endwhile;
	elseif self.pxyTrackedItem &lt;&gt; null then
		realTI := self.myParentForm.CM_ContainerEnqForm.myCurrentObject.CM_TrackedItem;
		txnParams := self.pxyTrackedItem.setRepairDiscrepancyValues(realTI, quantity, tareWeight, cargoWeight, totalWeight, diameter, height, volume, rollingLength, length,grammage, width, reason);
		self.myParentForm.CM_ContainerEnqForm.allTITxnControllers.add(txnParams);
	endif;
	self.modalResult := IDOK;
	self.unloadForm;
epilog
	if self.pxyTrackedItem = null then
		delete trackedItem;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="loadMeasurementField" id="b7969334-e0fb-4774-9913-aa7f44317a00">
        <source>loadMeasurementField();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 July 2022	navak20	TFS ChangeRequest 53862: EUP - WMS - Damage Recording Extra Details
11 August 2023	navcs2	ChangeRequest 59788: EUP Discrepancy Form overhaul - tare/cargo weights and quantities

*/

vars
	volumeMeasurementType,
	weightMeasurementType : CM_MeasurementType;
begin
	weightMeasurementType := self.myCargoType.getDefaultMeasurementForType(Type_Weight);
	volumeMeasurementType := self.myCargoType.getDefaultMeasurementForType(Type_Volume);
	
	// Tare Weight
	self.mskTareWeight.setup(Type_Weight, self.backColor);
	self.mskTareWeight.setMeasurementType(weightMeasurementType.measurementType);	// 11 August 2023	navcs2	ChangeRequest 59788
	self.mskTareWeight.tabKey := J_key_Tab;
	
	// Lost Weight
	self.mskLostWeight.setup(Type_Weight, self.backColor);
	self.mskLostWeight.setMeasurementType(weightMeasurementType.measurementType);	// 11 August 2023	navcs2	ChangeRequest 59788
	self.mskLostWeight.tabKey := J_key_Tab;
	
	// Cargo Weight
	self.mskCargoWeight.setup(Type_Weight, self.backColor);
	self.mskCargoWeight.setMeasurementType(weightMeasurementType.measurementType);	// 11 August 2023	navcs2	ChangeRequest 59788
	self.mskCargoWeight.tabKey := J_key_Tab;
	
	// Total Weight
	self.mskTotalWeight.setup(Type_Weight, self.backColor);
	self.mskTotalWeight.setMeasurementType(weightMeasurementType.measurementType);	// 11 August 2023	navcs2	ChangeRequest 59788
	self.mskTotalWeight.tabKey := J_key_Tab;
	
	// Diameter
	self.mskDiameter.setup(Type_Length, self.backColor);
	self.mskDiameter.tabKey := J_key_Tab;
	
	// Height
	self.mskHeight.setup(Type_Length, self.backColor);
	self.mskHeight.tabKey := J_key_Tab;
	
	// Volume
	self.mskVolume.setup(Type_Volume, self.backColor);
	self.mskVolume.setMeasurementType(volumeMeasurementType.measurementType);		// 11 August 2023	navcs2	ChangeRequest 59788
	self.mskVolume.tabKey := J_key_Tab;
	
	// Rolling Length
	self.mskRollingLength.setup(Type_Length, self.backColor);
	self.mskRollingLength.tabKey := J_key_Tab;
	
	// Length
	self.mskLength.setup(Type_Length, self.backColor);
	self.mskLength.tabKey := J_key_Tab;
	
	// Width
	self.mskWidth.setup(Type_Length, self.backColor);
	self.mskWidth.tabKey := J_key_Tab;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="loadTrackedItem" id="9451e8a1-8a10-407d-a3ef-8955bab53614">
        <source>loadTrackedItem();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 July 2022	navak20	TFS ChangeRequest 53862: EUP - WMS - Damage Recording Extra Details
17/07/23		navcs2	Bug 59045: FR | 54536 EUP - Repair Data Processing Timing - Old Weights for Repair Messages
30/08/2023	navcs2	Bug 60155: EUP | FR 54536 - Damage and Repair CAMS - Items found WP1
17/10/2023		navcs2	ChangeRequest 59995: EUP | Damage Recording - Updating Cargo Details

*/

vars
	trackedItem : CM_TrackedItem;
	measureType : CM_MeasurementType;
	meaureString: String;
begin
	if self.myTrackedItem &lt;&gt; null then
		trackedItem := self.myTrackedItem;
	elseif self.pxyTrackedItem &lt;&gt; null then
		trackedItem := self.pxyTrackedItem;
	endif;

	measureType := app.getDefaultMeasurementForType(Type_Weight);
	if measureType &lt;&gt; null then
		meaureString := measureType.shortName;
	endif;
	
	if trackedItem &lt;&gt; null and trackedItem.myCargoType.isBreakBulk then
		self.txtOldTotalQuantityVal.text := trackedItem.totalQuantity.String;
		self.txtQuantity.text := trackedItem.totalQuantity.String;
		self.txtOldTotalQuantityVal.text := trackedItem.totalQuantity.String;
		self.txtOldTareWeightVal.text := trackedItem.getDefaultMeasureWeightTare &amp; meaureString;	// 30/08/2023	navcs2	Bug 60155
		self.txtOldCargoWeightVal.text := trackedItem.getDefaultMeasureWeightCargo &amp; meaureString;	// 30/08/2023	navcs2	Bug 60155
		self.txtOldTotalWeightVal.text := trackedItem.getDefaultMeasureTotalWeight &amp; meaureString;	// 30/08/2023	navcs2	Bug 60155
		self.mskLength.setValue(trackedItem.length);
		self.mskVolume.setValue(trackedItem.volume);
		self.mskHeight.setValue(trackedItem.height);
		self.mskWidth.setValue(trackedItem.width);
		self.mskTotalWeight.setValue(trackedItem.totalWeight);										// 17/10/2023 navcs2 ChangeRequest 59995		
		self.mskTareWeight.setValue(trackedItem.getTareWeight);										// 17/10/2023 navcs2 ChangeRequest 59995	
		self.mskCargoWeight.setValue(trackedItem.weightCargo);										// 17/10/2023 navcs2 ChangeRequest 59995	
		self.mskDiameter.setValue(trackedItem.getDiameter());
		self.mskRollingLength.setValue(trackedItem.getRollingLength());
		self.txtGrammage.text := trackedItem.getGrammage().String;
		
	elseif trackedItem &lt;&gt; null and trackedItem.myCargoType.isBulk then
		self.txtOldTareWeightVal.text := trackedItem.getDefaultMeasureWeightTare &amp; meaureString;	// 30/08/2023	navcs2	Bug 60155
		self.txtOldCargoWeightVal.text := trackedItem.getDefaultMeasureWeightCargo &amp; meaureString;	// 30/08/2023	navcs2	Bug 60155
		self.txtOldTotalWeightVal.text := trackedItem.getDefaultMeasureTotalWeight &amp; meaureString;	// 30/08/2023	navcs2	Bug 60155
		self.mskTotalWeight.setValue(trackedItem.totalWeight);										// 17/10/2023 navcs2 ChangeRequest 59995		
		self.mskTareWeight.setValue(trackedItem.getTareWeight);										// 17/10/2023 navcs2 ChangeRequest 59995	
		self.mskCargoWeight.setValue(trackedItem.weightCargo);										// 17/10/2023 navcs2 ChangeRequest 59995	
		self.mskVolume.setValue(trackedItem.totalVolume);
		self.txtOldTotalWeightVal.text := trackedItem.totalWeight.String;
		if trackedItem.myCargoType.isBulkByVolume then
			self.txtOldVolume.text := self.myTrackedItem.totalVolume.String;
		endif;
	endif;
epilog

end;</source>
    </JadeMethod>
