    <JadeMethod name="convertOldStyleTBAsToRRPs" id="a3a9bd43-8e77-4f7f-bbbe-6a7fad8620d6">
        <source>convertOldStyleTBAsToRRPs(_controller : CnEcReleaseController);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 March 2020	jlgndl1	Initial creation	TFS 47004

*/

vars

	tbaS : CM_TISet;
	term : CM_Terminal;
	tba : CM_TrackedItem;
	processedTbaS : CM_TISet;
	deleteTBAs : CM_TISet; 

begin

	if self.hasScriptBeenRunAtAll(method.name, _controller) then
		return;
	endif;
	
	app.writeLog(method.qualifiedName &amp; " Convert Old Stype TBAs to RRPs", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry(" Convert Old Stype TBAs to RRPs") ;	
	endif;
	
	create tbaS transient;
	create processedTbaS transient;
	create deleteTBAs transient;
	
	foreach term in CM_Terminal.instances do
		term.allTbaTIsByIdCargoType.copy( tbaS );
	endforeach;
	
	beginTransaction;
	
	foreach tba in tbaS do	
		if tba.convertTBA( deleteTBAs ) then
			processedTbaS.add(tba);
		endif;	
	endforeach;
	
	deleteTBAs.purge();
	
	commitTransaction;
	
	app.writeLog(method.qualifiedName &amp; " Convert Old Stype TBAs to RRPs " &amp; processedTbaS.size.String &amp; " of " &amp; tbaS.size.String &amp; " Completed", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry(" Convert Old Stype TBAs to RRPs " &amp; processedTbaS.size.String &amp; " of " &amp; tbaS.size.String &amp; " Completed") ;
	endif;
	
	self.addScriptRun(method.name);

epilog

	delete tbaS;
	delete processedTbaS;
	delete deleteTBAs;

end;</source>
        <Parameter name="_controller" type="CnEcReleaseController"/>
    </JadeMethod>
    <JadeMethod name="convertRelReqValConfig" id="9d867b58-abd6-4501-ab7b-70b9cbbd5b27">
        <source>convertRelReqValConfig(_controller : CnEcReleaseController);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 August 2021	navndl1	Initial creation	TFS 51785

*/

vars

	root : CM_Root;
	term : CM_Terminal;
	convValue : Integer;

begin

	if self.hasScriptBeenRunAtAll(method.name, _controller) then
		return;
	endif;
	
	app.writeLog(method.qualifiedName &amp; " Convert 'Selected Cargo Not Matching Release is OK With Warning' config to 'Road Gate Release Request Validation'", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry(" Convert 'Selected Cargo Not Matching Release is OK With Warning' config to 'Road Gate Release Request Validation'") ;	
	endif;

	root := CM_Root.firstInstance;

	beginTransaction;
	foreach term in root.allTerminals do
		if term.getConfig( AllowReleaseMisMatch ) = null then
			//Its never been set so no warning and no error i.e. behaviour from a couple of releases back.
			convValue := 2;
		else
			if term.getConfig( AllowReleaseMisMatch ).Boolean then
				//set to true - show warning only
				convValue := 1;
			else
				//set to false- they want an error - ( The new default behviour as well ).
				convValue := 0;
			endif;
		endif;
		term.setConfig( RoadGateRelReqVal, convValue );
	endforeach;
	commitTransaction;
	
	app.writeLog(method.qualifiedName &amp; " config 'Road Gate Release Request Validation' populated", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry(" config 'Road Gate Release Request Validation' populated") ;
	endif;
	
	self.addScriptRun(method.name);

epilog

end;</source>
        <Parameter name="_controller" type="CnEcReleaseController"/>
    </JadeMethod>
    <JadeMethod name="convertWebReqResDataToBinary" id="92d24614-6ea8-456f-8715-01744f428859">
        <source>convertWebReqResDataToBinary(_controller : CnEcReleaseController);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 July 2023	navra1	Initial creation for 54078 - MTN - Compress msgWebReq and msgWebRes on CM_EdiFile

*/

vars
	terminal : CM_Terminal;	
	ediConfig : CM_EDIConfig;
	allEDIFilesForTerm : CM_EDIFileByCreatedTSDict;
	ediFile : CM_EDIFile;	
	numCompleted : Integer;
	totalNumber : Integer;
	finishTs : TimeStamp;
	nextCommitTs : TimeStamp;
	now : TimeStamp;
	numConverted : Integer;
begin
	if self.hasScriptBeenRunAtAll(method.name, _controller) then
		return;
	endif;
	
	app.writeLog(method.qualifiedName &amp; " Converting EDIFile WebReq and WebRes strings start", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry("Converting EDIFile WebReq and WebRes strings start");
	endif;
	
	foreach terminal in  app.myRoot.allTerminals do
		ediConfig := terminal.myEdiConfig;
		if ediConfig &lt;&gt; null then
			allEDIFilesForTerm := ediConfig.ediFiles;
			totalNumber := totalNumber + allEDIFilesForTerm.size();
		endif;
	endforeach;
	
	finishTs := app.actualTimeServer.addSeconds(60);
	nextCommitTs := app.actualTimeServer.addSeconds(10);
	
	beginTransaction;
	
		foreach terminal in  app.myRoot.allTerminals do
			ediConfig := terminal.myEdiConfig;		
			allEDIFilesForTerm := ediConfig.ediFiles;
			
			if allEDIFilesForTerm &lt;&gt; null then
				foreach ediFile in allEDIFilesForTerm  do
					if ediFile.msgWebReq &lt;&gt; null then
						ediFile.setWebReqString(ediFile.msgWebReq);						
						ediFile.setMsgWebReqAsNull();
						numConverted += 1;
					endif;
					
					if ediFile.msgWebRes &lt;&gt; null then
						ediFile.setWebResString(ediFile.msgWebRes);
						ediFile.setMsgWebResAsNull();
						numConverted += 1;
					endif;					
				
					numCompleted := numCompleted  + 1;
					now := app.actualTimeAppServer();
					
					//see if its time to end
					if now &gt;= finishTs then
						app.writeLog("Time limit (60 seconds) reached, stopping early", LogINFO);
						if _controller &lt;&gt; null then
							_controller.logEntry("Time limit (60 seconds) reached, stopping early");
						endif;
						break;
					endif;
					
					// commit in batches to reduce the final commit time to keep close to our 60 second limit
					if now &gt;= nextCommitTs then
						commitTransaction;
						nextCommitTs := now.addSeconds(10);
						beginTransaction;
					endif;
					
				endforeach;					
			endif;
		
		endforeach;
	
	commitTransaction;
	
	app.writeLog("Total Converted: " &amp; numConverted.String, LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry("Total Converted: " &amp; numConverted.String);
	endif;
	
	// If we've converted everything, or hit the timelimit without converting anything, then we can stop
	// The rest will be handle during the next major upgrade
	if numCompleted = totalNumber or numConverted = 0 then
		self.addScriptRun(method.name);
	endif;
	
	app.writeLog(method.qualifiedName &amp; " Converting EDIFile WebReq and WebRes strings finished", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry("Converting EDIFile WebReq and WebRes strings finished");
	endif;
	
epilog
	
end;</source>
        <Parameter name="_controller" type="CnEcReleaseController"/>
    </JadeMethod>
    <JadeMethod name="create1StopRoadProcess" id="a34fdb9a-996b-48b2-8373-8c037c8e83af">
        <source>create1StopRoadProcess(_updController : CnEcReleaseController);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 25/01/2022	navdap1		Initial creation TFS 52268 AAT 1-Stop VBS Integration
//
vars
	pxyRoadProcess : CM_RoadProcess;
	roadProcess : CM_RoadProcess;
	terminal : CM_Terminal;
	securityRoleTerminal : CM_SecurityRoleTerminal;

begin
	if self.hasScriptBeenRunAtAll(method.name, _updController) then
		return;
	endif;
	
	app.writeLog(method.qualifiedName &amp; " Creating 1-Stop Road Process", LogINFO);
	if _updController &lt;&gt; null then
		_updController.logEntry(" Creating 1-Stop Road Process") ;	
	endif;
	
	beginTransaction;
	
	if not app.myRoot.allRoadProcesses.isEmpty then
		roadProcess := app.myRoot.allRoadProcesses.getAtKey( CM_RoadProcess.ONESTOP_VBS ).CM_RoadProcess;
	endif;
	
	if roadProcess = null then
		create pxyRoadProcess transient;
		pxyRoadProcess.setCode(CM_RoadProcess.ONESTOP_VBS);
		pxyRoadProcess.setDescription("1-Stop LOLO Voyages");
		
		create roadProcess persistent;
		roadProcess.setForCreate( pxyRoadProcess );
		delete pxyRoadProcess;
	endif;
	
	commitTransaction;
	
	app.writeLog(method.qualifiedName &amp; " Creating 1-Stop Road Process complete", LogINFO);
	if _updController &lt;&gt; null then
		_updController.logEntry(" Creating 1-Stop Road Process complete") ;	
	endif;
	
	self.addScriptRun(method.name);
	
epilog
	delete pxyRoadProcess;
end;</source>
        <Parameter name="_updController" type="CnEcReleaseController"/>
    </JadeMethod>
    <JadeMethod name="createCargoGroupDetails" id="412de2a5-f55d-4a97-b7b2-c83380546e6e">
        <source>createCargoGroupDetails(_updController : CnEcReleaseController);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 17/05/2022	navdap1		Initial creation TFS 53387 EUR Cargo Group Overview in Voyage Operations
// 18/05/2023	navmd1		TFS 56062 Code tidy up
// 29/10/2025	navma1		MTTN-36443 STWR - Upgrade Script: Add Conditional Logic to createCargoGroupDetails() for Target Customers
//
vars
	cargoGroup : CM_CargoGroup;
	controller : CMIF_CargoGroupDtlController;
begin
	if self.hasScriptBeenRunAtAll(method.name, _updController) then
		return;
	endif;
	
	
	app.writeLog(method.qualifiedName &amp; " Creating Cargo Group Detail objects", LogINFO);
	if _updController &lt;&gt; null then
		_updController.logEntry(" Creating Cargo Group Detail objects") ;	
	endif;
	
	if app.myRoot.isClientEuroPorts() 
	or app.myRoot.isClientJadeMaster()
	or app.myRoot.isClientJMTTesting() then		//29.10.2025 navma1	MTTN-36443
		beginTransaction;
		foreach cargoGroup in CM_CargoGroup.instances do
			cargoGroup.allCargoGroupDetails.purge;
			controller := create CMIF_CargoGroupDtlController(cargoGroup) transient;
			controller.getCargoGroups(); 			// ### TFS  CR 58857 TASK 58967  30JUN2023 NAVAB1
			controller.recalculateForVoyage(); 		// ### TFS BUG 58853 06JUL2023 NAVAB1
			delete controller;
		endforeach;	
		commitTransaction;
	endif;
	
	app.writeLog(method.qualifiedName &amp; " Creating Cargo Group Detail objects complete", LogINFO);
	if _updController &lt;&gt; null then
		_updController.logEntry(" Creating Cargo Group Detail objects complete") ;	
	endif;
	
	self.addScriptRun(method.name);
epilog
	delete controller;
end;</source>
        <Parameter name="_updController" type="CnEcReleaseController"/>
    </JadeMethod>
    <JadeMethod name="createCargoGroupDetailsAgain" id="fc5a428c-3ff1-4388-9264-e56a3cc5c2e5">
        <source>createCargoGroupDetailsAgain(_updController : CnEcReleaseController);
/*
Purpose:			

Date		Who		Reason
06JUL2023	NAVAB1	 BUG 58853 
*/

//
vars
	cargoGroup : CM_CargoGroup;
	controller : CMIF_CargoGroupDtlController;
	oArray : ObjectArray; 
begin
 
	if self.hasScriptBeenRunAtAll(method.name, _updController) then
		return;
	endif;
	
	
	app.writeLog(method.qualifiedName &amp; " Creating Cargo Group Detail objects", LogINFO);
	if _updController &lt;&gt; null then
		_updController.logEntry(" Creating Cargo Group Detail objects") ;	
	endif;

	// From Release 20.21.18 a JCF will purge all the cargo details, this code is belt and braces, but means that customers who have instances of this class and do not need them will be cleared out and then not get any more.
	create oArray transient;
	CM_CargoGroupDetail.allInstances(oArray,0,false);
	beginTransaction;
	oArray.purge();
	
	// ### TFS BUG 58853 12JUL2023 NAVAB1 - these cargo group details are only used on a screen that can only be seen by EUP
	if app.myRoot.isClientEuroPorts() 
	or app.myRoot.isClientJadeMaster()
	or app.myRoot.isClientJMTTesting() then

		foreach cargoGroup in CM_CargoGroup.instances do
			cargoGroup.allCargoGroupDetails.purge;
			controller := create CMIF_CargoGroupDtlController(cargoGroup) transient;
			controller.getCargoGroups(); // ### TFS  CR 58857 TASK 58967  30JUN2023 NAVAB1
			controller.recalculateForVoyage();   // ### TFS BUG 58853 06JUL2023 NAVAB1
			delete controller;
		endforeach;	
	endif;

	commitTransaction;
	
	app.writeLog(method.qualifiedName &amp; " Creating Cargo Group Detail objects complete", LogINFO);
	if _updController &lt;&gt; null then
		_updController.logEntry(" Creating Cargo Group Detail objects complete") ;	
	endif;
	
	self.addScriptRun(method.name);
epilog
	delete controller;
end;</source>
        <Parameter name="_updController" type="CnEcReleaseController"/>
    </JadeMethod>
    <JadeMethod name="createCargoMultiSurcharge" id="3d06da6b-c42b-4c58-b1e0-84ce548e36b5">
        <source>createCargoMultiSurcharge(_updController : CnEcReleaseController);
/*

Purpose:			Migrates the old Cargo Surcharge objects to use the new Cago Multi Surcharge Objects

Parameters:			_updController	CnEcReleaseController	The update controller to use when making the updates

Return Value:		NONE

Date		Who		Reason
20 September 2022	navpw1	Initial creation TFS: 54571 (54394)

*/

vars
	invoiceType						: CM_InvoiceDesc;
	cargoSurchargeInvLineType		: CM_InvoiceLineDesc;
	terminal						: CM_Terminal;
	company							: CM_Bank;
	surchargesAndExemptions			: CM_InvoiceTypeSurchargeExempt;
	invTypeCargoSurcharge			: CM_InvTypeCargoSurcharge;
	newInvTypeCargoMultiSurcharge	: CM_InvTypeCargoMultiSurcharge;
	validFromTimeStamp				: TimeStamp;
	
begin
	if self.hasScriptBeenRunAtAll(method.name, _updController) then
		return;
	endif;
	
	
	app.writeLog(method.qualifiedName &amp; " Creating Cargo Multi Surcharge objects", LogINFO);
	if _updController &lt;&gt; null then
		_updController.logEntry(" Creating Cargo Multi Surcharge objects") ;	
	endif;
	
	beginTransaction;
	
	//Better to go through Terminal level or through app.myRoot.myRootCompany.subCompanies
	
	foreach terminal in app.myRoot.allTerminals do :terminalLoop
		if terminal.companies.isEmpty then
			continue terminalLoop;
		endif;
		
		foreach company in terminal.companies do :companyLoop
			if company.invoiceTypes.isEmpty then
				continue companyLoop;
			endif;
			
			foreach invoiceType in company.invoiceTypes do :invoiceTypeLoop
				if invoiceType.mySurchargeAndExemptions = null then
					continue invoiceTypeLoop;
				endif;
				
				surchargesAndExemptions := invoiceType.mySurchargeAndExemptions;
				if surchargesAndExemptions = null then
					continue invoiceTypeLoop;
				endif;
				
				if surchargesAndExemptions.allInvTypeCargoSurcharges.isEmpty then
					continue invoiceTypeLoop;
				endif;
				
				foreach invTypeCargoSurcharge in surchargesAndExemptions.allInvTypeCargoSurcharges do
					validFromTimeStamp:= app.actualTimeServer();
					
					create newInvTypeCargoMultiSurcharge persistent;
					
					if invTypeCargoSurcharge.myCargoType &lt;&gt; null then
						newInvTypeCargoMultiSurcharge.allCargoTypes.add(invTypeCargoSurcharge.myCargoType);
					endif;
					
					if invTypeCargoSurcharge.mySubCargoType &lt;&gt; null then
						newInvTypeCargoMultiSurcharge.allCargoSubTypes.add(invTypeCargoSurcharge.mySubCargoType);
					endif;
					
					if invTypeCargoSurcharge.myCommodity &lt;&gt; null then
						newInvTypeCargoMultiSurcharge.allCommodities.add(invTypeCargoSurcharge.myCommodity);
					endif;
					
					if not invTypeCargoSurcharge.allSelectedInvLineTypes.isEmpty then
						invTypeCargoSurcharge.allSelectedInvLineTypes.copy(newInvTypeCargoMultiSurcharge.allSelectedInvLineTypes);
					endif;
					
					cargoSurchargeInvLineType := invTypeCargoSurcharge.myCargoSurchargeInvLineType;
					if cargoSurchargeInvLineType &lt;&gt; null then
						newInvTypeCargoMultiSurcharge.setPropertyValue(CM_InvTypeCargoMultiSurcharge::myCargoSurchargeInvLineType.name, cargoSurchargeInvLineType);
					endif;
					
					newInvTypeCargoMultiSurcharge.setPropertyValue(CM_InvTypeCargoMultiSurcharge::mySurchargesAndExemptions.name, invTypeCargoSurcharge.mySurchargesAndExemptions);
					newInvTypeCargoMultiSurcharge.setPropertyValue(CM_InvTypeCargoMultiSurcharge::surchargeRate.name, invTypeCargoSurcharge.surchargeRate);
					
					//Populate validFrom Date time as now
					//Get current Date time from server
					newInvTypeCargoMultiSurcharge.setPropertyValue(CM_InvTypeCargoMultiSurcharge::validFrom.name, validFromTimeStamp);
					
				endforeach;
				
				surchargesAndExemptions.allInvTypeCargoSurcharges.purge;
				
			endforeach;
			
		endforeach;
		
	endforeach;
	
	commitTransaction;
	
	app.writeLog(method.qualifiedName &amp; " Creating Cargo Multi Surcharge objects complete", LogINFO);
	if _updController &lt;&gt; null then
		_updController.logEntry(" Creating Cargo Multi Surcharge objects complete") ;	
	endif;
	
	self.addScriptRun(method.name);
	
epilog
	
end;</source>
        <Parameter name="_updController" type="CnEcReleaseController"/>
    </JadeMethod>
