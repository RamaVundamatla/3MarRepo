    <JadeMethod name="loadDB" id="5730626c-76a2-4213-8ff6-912e65fb7e71">
        <updating/>
        <source>loadDB(mergeCargo : Boolean; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:	14 October 2009 By Graeme Black cnwgb1
// Status: 	
// Purpose:	Messina 1008 PAR 20320 
// ---------------------------------------------------------------------------
// 20/06/2012	cnwcs5	par 29747 - refactor into trx
// 03 Jan 2018	jlgrs1	TFS 36430 Penn Ship Manifest too many locks
// 21 Jun 2018	jlgrs1	TFS 39298 (TFS 36430) Penn Ship Manifest too many locks
// 25 Sep 2023	navmd1	TFS 60588 Stop file being DB Loaded with errors in passport
//
vars
	cmifEDIShipManifest : CMIF_EDIShipManifest;
	tmpStatus 			: Integer;
	allowPartialLoad 	: Boolean;
	voyStatus : Integer;
begin
	// Tracked items are loaded via Bayplans PAR 20808 cnwgb1 28.10.09
	// Arm our base exception handlers
	on Exception do validationExceptionHandler(exception, _passport);
	allowPartialLoad := self.getMyTerminal.getConfig(EdiShipManAllowPartial).Boolean;
	if not allowPartialLoad then
		app.setContinueCMExceptions(false);
		
		//navra1 - MTN-33087 - 23rd Oct 2024 - start
		if self.myEDIFile &lt;&gt; null and self.myEDIFile.myEDIFileType &lt;&gt; null and self.myEDIFile.myEDIFileType.isIFCSUM() then
			app.myPassport.setContext(Context_Pass_EDI_IFSUM_Load);
		endif;		
		//navra1 - MTN-33087 - 23rd Oct 2024 - end
		
		app.myTrxUA.trxProcessEDIShipManifest(self, false, _passport);
		
		app.myPassport.setContext(Context_Pass_Null);				//navra1 - MTN-33087 - 23rd Oct 2024
	else
		app.setContinueCMExceptions(true);
		create cmifEDIShipManifest transient;

		//navra1 - MTN-33087 - 23rd Oct 2024 - start
		if self.myEDIFile &lt;&gt; null and self.myEDIFile.myEDIFileType &lt;&gt; null and self.myEDIFile.myEDIFileType.isIFCSUM() then
			app.myPassport.setContext(Context_Pass_EDI_IFSUM_Load);
		endif;		
		//navra1 - MTN-33087 - 23rd Oct 2024 - end
		
		cmifEDIShipManifest.loadOrVerifyForDB(self, _passport, false);
		
		app.myPassport.setContext(Context_Pass_Null);				//navra1 - MTN-33087 - 23rd Oct 2024
		
		tmpStatus := self.getStatusFromEDITrackedItems(false);
		
		// Work around Manifests also doing Work Orders too
		if	_passport.isVASEnabled and
			self.myTransportManifest &lt;&gt; null and
			_passport.allErrors.size &gt; 0 and
			tmpStatus = CM_EDIFile.EDI_STATUS_DBLOADED
		then
			tmpStatus := self.getStatusAfterVerifyOrDBLoad(false, _passport);
		endif;
		
		if tmpStatus &lt;&gt; 0 then
			app.myTrxUA.trxSetEDIDataStatusAfterVerify(self, tmpStatus);	// par 27392 cnwrs1 14 Apr 2011
		endif;
	endif;
epilog
	app.myPassport.setContext(Context_Pass_Null);				//navra1 - MTN-33087 - 23rd Oct 2024
	delete cmifEDIShipManifest;
end;
</source>
        <Parameter name="mergeCargo" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="verifyEDIData" id="0687b2a0-4f80-48a0-9800-8a5ab890761a">
        <updating/>
        <source>verifyEDIData(): Integer updating;
// ---------------------------------------------------------------------------
// Created:	16 October 2009 By Graeme Black cnwgb1
// Status: 	
// Purpose:	
// ---------------------------------------------------------------------------
vars
	voyage : CM_Voyage;
	isLoadManifest : Boolean;
	voyageProgress : CM_VoyageProgress;
	operatorCode : String;
	voyStage : CM_VoyageStage;
	errMsg : String;
begin
	//navra1 - MTN-34829 - 8th May 2025 - start	
	if self.myEDIFile &lt;&gt; null and self.myEDIFile.myEDIFileType &lt;&gt; null and self.myEDIFile.myEDIFileType.isIFCSUM() then
		voyage := self.getMyVoyageObject();
		if voyage &lt;&gt; null and voyage.isAutomaticProcess() then
			//it is an AUTO voyage's shipmanifest
			//get direction
			isLoadManifest := self.isShipManifestForLoad();
			voyageProgress := voyage.myVoyageProgress;
			operatorCode := self.getCargoOperatorForShipManif();
			
			if voyageProgress &lt;&gt; null and operatorCode &lt;&gt; null then
				if isLoadManifest then					
					voyStage := voyageProgress.getStageForOperator(CM_VoyageStage.VoyStage_InvoicePosted, operatorCode, CM_VoyageStage.Type_Load);
				else
					voyStage := voyageProgress.getStageForOperator(CM_VoyageStage.VoyStage_InvoicePosted, operatorCode, CM_VoyageStage.Type_Discharge);
				endif;
				
				//The invoice posted stage need not be successful, as log as we got to that stage, we dont want to consider this manifest, this is
				//according to the acceptance criteria on 22nd May 2025 on MTN-34829
				if voyStage &lt;&gt; null then	//and voyStage.status = CM_VoyageStage.STATUS_SUCCESS then
					errMsg := app.getErrorString3(Operat_already_fully_processed, operatorCode, voyage.code, voyStage.getTypeDescription());
					app.myPassport.addErrorFull(Operat_already_fully_processed, errMsg, null, self, null);
					return -1;
				endif;
			endif;			
		endif;
	endif;
	//navra1 - MTN-34829 - 8th May 2025 - end
	
	return 0; // OK, Continue
epilog
	
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="verifyEDIDataTIs" id="75b8ce41-701f-48f5-a8d5-c72809e79912">
        <updating/>
        <source>verifyEDIDataTIs(_passport: CM_Passport input): Integer updating;
// ---------------------------------------------------------------------------
// Created:	15 October 2009 By Graeme Black cnwgb1
// Status: 	
// Purpose:	Messina 1008 PAR 20320 
// ---------------------------------------------------------------------------
// 18/06/2012	cnwcs5	par 29747 - refactor into trx
// 03 Jan 2018	jlgrs1	TFS 36430 Penn Ship Manifest too many locks
// 21 Jun 2018	jlgrs1	TFS 39298 (TFS 36430) Penn Ship Manifest too many locks
// 1/08/2019 	JLGNS1	Bug 45797: PEN - Ship Manifest Upload errors
// 25 Nov 2022 navma1 ChangeRequest 52499: MTN - Improve the performance of the Edi file verification process.
// 20 Mar2023	navdap1	TFS 56793 PRP - Suzano EDI - Shipment Download
// 11 Dec 2023	jlirs1	TFS 59171 User Defined Transport Manifest 
// 12 May 2024	naviv1	TFS 64020 - EUP | FR 53824 - Operator Validation on Voyage Not Working
vars
	ediTI			 : CM_EDITrackedItem;
	allowPartialLoad : Boolean;
	newStatus 		 : Integer;				//Bug 45797
	terminal 		 : CM_Terminal;			//Bug 45797
	errorSet : CM_ErrorSet;
	proxyContainer	 : CM_TrackedItem;
	updateController: CMIF_TIUpdateController;
	realTI			: CM_TrackedItem;
	voyage 			: CM_Voyage;
	operatorCode	: String;
begin
	// Arm our base exception handlers
	on Exception do validationExceptionHandler(exception, _passport);
	
	terminal 		 := self.getMyTerminal();
	allowPartialLoad := terminal.getConfig(EdiShipManAllowPartial).Boolean;
	
	if not allowPartialLoad then
		app.setContinueCMExceptions(false);
		
		//navra1 - MTN-33087 - 23rd Oct 2024 - start
		if self.myEDIFile &lt;&gt; null and self.myEDIFile.myEDIFileType &lt;&gt; null and self.myEDIFile.myEDIFileType.isIFCSUM() then
			app.myPassport.setContext(Context_Pass_EDI_IFSUM_Load);
		endif;		
		//navra1 - MTN-33087 - 23rd Oct 2024 - end
		
		app.myTrxUA.trxProcessEDIShipManifest(self, true, _passport);
		
		app.myPassport.setContext(Context_Pass_Null);				//navra1 - MTN-33087 - 23rd Oct 2024
	else
		create errorSet transient;
		_passport.moveErrorsToSet(errorSet);
		app.setContinueCMExceptions(true);
		self.verifyFileCountAndOperator(errorSet, _passport);		// TFS 56793 
		
		foreach ediTI in self.allEDITrackedItems do
			
			_passport.clearErrorsWarnings();										//Bug 45797
			ediTI.verifySelf();
			
			// Start - 10-May-2024 naviv1 #64020
			voyage := ediTI.getVoyage();
			if voyage &lt;&gt; null then
				operatorCode := ediTI.getOperatorCode;
				if voyage.allOperators[operatorCode] = null then
					app.raiseCMException1(ERR_INVALID_OPERATOR, operatorCode, null, null);
				endif;
			endif;
			// End - 10-May-2024 naviv1 #64020
			
			//06.Dec.2023 navsp1 TFS 61658
			//Add more validation as TI proxy
			if self.myTransportManifest &lt;&gt; null and
			   ediTI.isKindOf(CM_EDICargoTI) then		//11 Dec 2023	jlirs1	TFS 59171 User Defined Transport Manifest 
				updateController := app.createTIUpdateControl(TI_UPDMODE_BAYPLAN, null, null);
				realTI := self.getRealCargoItem(ediTI.CM_EDICargoTI);		//11 Dec 2023	jlirs1	TFS 59171 User Defined Transport Manifest 
				if realTI = null then						//11 Dec 2023	jlirs1	TFS 59171 User Defined Transport Manifest 
					proxyContainer 	:= ediTI.CM_EDICargoTI.createProxy (terminal, realTI, _passport);
					if proxyContainer &lt;&gt; null then				//22.Mar.24 navsp1 TFS 61223
						proxyContainer.validateTrackedItem(updateController, _passport);
						delete proxyContainer;
					endif;
				endif;
				delete updateController;
			endif;
			
			if _passport.hasErrors() then											//Bug 45797
				newStatus := CM_EDITrackedItem.EDI_STATUS_VERIFIED_ERRORS; 			//Bug 45797
			elseif _passport.hasWarnings() then										//Bug 45797
				newStatus := CM_EDITrackedItem.EDI_STATUS_VERIFIED_WARNINGS; 		//Bug 45797
			else																	//Bug 45797
				newStatus := CM_EDITrackedItem.EDI_STATUS_VERIFIED; 				//Bug 45797
			endif;																	//Bug 45797
				
			app.myTrxUA.trxUpdateEDITIStatus(ediTI, newStatus, _passport);			//Bug 45797
			
			if terminal &lt;&gt; null then																	//Bug 45797
				//terminal.causeEvent(terminal.getTerminalEvent(EVENT_EDI_EDITI_UPDATE), false, ediTI);	//Bug 45797		//30.11.2022 navma1 #52499
				terminal.causeEvent(terminal.getTerminalEvent(EVENT_EDI_EDITI_VERIFY), false, ediTI);					//30.11.2022 navma1 #52499
			endif;																						//Bug 45797
			//jlier1 TFS 56234 12/12/22 - lets show all the errors not just the last one
			_passport.moveErrorsToSet(errorSet);
		endforeach;
		_passport.addErrorsFromSet(errorSet);
	endif;
	
	return _passport.allErrors.size();
epilog
	delete errorSet;
	app.myPassport.setPassportEdiMode(CM_Passport.EDI_MODE_NONE);				//07.12.2022 navma1 #52499
	app.myPassport.setContext(Context_Pass_Null);				//navra1 - MTN-33087 - 23rd Oct 2024
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="verifyFileCountAndOperator" id="b9080cb1-4a8d-4a33-9e13-dee1bf1b110c">
        <source>verifyFileCountAndOperator(_errorSet : CM_ErrorSet input; _passport : CM_Passport input);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 20/03/2023	navdap1		Initial creation TFS 56793 PRP - Suzano EDI - Shipment Download
//
vars
	suzaOperator : CM_Operator;
	data : String;
	count, lines, pos : Integer;
	ediTI : CM_EDITrackedItem;

begin
	if self.myEDIFile.myEDIFileType.type = EDIFileType_SuzanoManifest then
		suzaOperator := app.myRoot.allOperators[CM_EDIFileTypeSuzanoManifest.OPERATOR_SUZA];
		if suzaOperator = null or suzaOperator.isNotAvailableForEntry then
			app.raiseCMException1(ERR_INVALID_OPERATOR, CM_EDIFileTypeSuzanoManifest.OPERATOR_SUZA, null, null);
		endif;
		
		data := self.myEDIFile.getRawDataString;
		pos := data.reversePos(":");
		if pos &lt;&gt; null then
			count := data[pos+1:5].Integer;
			foreach ediTI in self.allEDITrackedItems where ediTI.isKindOf(CM_EDICargoOnShipTI) do
				lines := lines + 1;
			endforeach;
			lines := lines + 2;		// for HDR and TRL
			if count &lt;&gt; lines then
				app.raiseCMException2(File_line_count_wrong, count.String, lines.String, null, null);
			endif;
		endif;
		_passport.moveErrorsToSet(_errorSet);
	endif;
epilog

end;</source>
        <Parameter name="_errorSet" type="CM_ErrorSet" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
</Class>
