    <JadeMethod name="hideShowParameters" id="9c7a9267-4231-42e2-b15b-3d7a1004b297">
        <source>hideShowParameters();
/*
Purpose:			

Date		Who		Reason
01 September 2023	navab1	CR 59942 TASK 59943 
*/

vars

begin
	self.grpParams.visible := self.chkShowParameters.value;
	
	if self.chkShowParameters.value then
		self.tblData.top := self.grpParams.top + self.grpParams.height + 10;
