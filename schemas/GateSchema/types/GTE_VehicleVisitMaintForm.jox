    <JadeMethod name="tblCargo_contextMenu" id="85bf9abd-a065-4741-bc4b-5fe7412eb62e">
        <controlMethod name="Table::contextMenu"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblCargo_contextMenu(table: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 October 2020	jlgndl1	Initial creation

*/

vars

	xLeft : Real;
	yTop : Real;
	ti : CM_TrackedItem;
	showingLoaded : Boolean;
	showingDischarged : Boolean;
	vvrOnsite : Boolean;
	canMove : Boolean;

begin

	xLeft := x;
	yTop := y;
	ti := table.accessRow( table.row ).itemObject.CM_TrackedItem;
	if ti &lt;&gt; null then
		canMove := app.myPassport.myUser.canDo( self.myTerminal, self.permissionMaint );
		if canMove then
			vvrOnsite := ( self.myVehicleVisitRecord.getGateOutVVRDetail = null );
			if vvrOnsite then
				showingLoaded := self.optView.value and self.optLoad.value and self.myVehicleVisitRecord.allReleasedTrackedItems.includes( ti );
				showingDischarged := self.optView.value and self.optDischarge.value and self.myVehicleVisitRecord.allReceivedTrackedItems.includes( ti ) ;
			endif;
		endif;
	endif;
	
	conwin.windowToScreen(xLeft, yTop);
	self.screenToWindow(xLeft, yTop);   // convert x, y relative to form
	
	self.mnuCargoEnq.enabled := ( ti &lt;&gt; null ); //03 Nov 2020	NDL	TFS 50274
	
	self.mnuInspect.visible := app.isAllowedToInspect();	
	self.mnuInspect.userObject := ti;
	
	self.mnuUndo.visible := canMove;
	self.mnuUndo.userObject := ti;
	if ( showingLoaded or showingDischarged ) and ti.priorLocation &lt;&gt; null then
		self.mnuUndo.caption := app.getErrorString1(Return_cargo_to, "'" &amp; ti.priorLocation &amp; "'");
		self.mnuUndo.enabled := true;
	else
		self.mnuUndo.caption := app.getErrorString(MOVE_TYPE_Undo);
		self.mnuUndo.enabled := false;
	endif;

	self.popupMenu(mnuContext, xLeft.Integer, yTop.Integer);
	self.mnuColOrg.userObject := table;

	return false;


epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="tblCargo_mouseDown" id="13e6327d-d216-41a0-bf7c-f3611eeb6583">
        <controlMethod name="CM_DataTable::mouseDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblCargo_mouseDown(table: Table input; button: Integer; shift: Integer; x: Real; y: Real) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 November 2020	jlgndl1	Initial creation	TFS 50391

*/

vars

	cell : JadeTableCell;

begin

	cell := self.tblCargo.accessCell( tblCargo.row, tblCargo.column );
	if cell &lt;&gt; null and cell.inputType = Table.InputType_CheckBox then
		if cell.text = "1" then
			cell.text := "0";
		else
			cell.text := "1";
		endif;
	endif;

epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="f4678340-9884-46fc-9ed7-2fbe0561d6a0">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 26 November 2020 13:13:53.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0024082, locale);
	btnClose.translateCaption(Xlat_0024083, locale);
	btnMove.translateCaption(Xlat_0024084, locale);
	grpMode.translateCaption(Xlat_0024085, locale);
	grpMove.translateCaption(Xlat_0024086, locale);
	grpOperation.translateCaption(Xlat_0024087, locale);
	grpUpdate.translateCaption(Xlat_0024107, locale);
	lblBOL.translateCaption(Xlat_0024088, locale);
	lblEffective.translateCaption(Xlat_0024089, locale);
	lblMoveMode.translateCaption(Xlat_0024090, locale);
	lblRelease.translateCaption(Xlat_0024091, locale);
	lblStevedore.translateCaption(Xlat_0024108, locale);
	lblsubLocation.translateCaption(Xlat_0024092, locale);
	mnuCargoEnq.translateCaption(Xlat_0024093, locale);
	mnuColOrg.translateCaption(Xlat_0024094, locale);
	mnuContext.translateCaption(Xlat_0024095, locale);
