    <JadeMethod name="getMachineRuleTerminalArea" id="9ddc1cf7-92d0-4669-8f90-68d92499c522">
        <source>getMachineRuleTerminalArea(): CM_TerminalArea;
// ---------------------------------------------------------------------------
// Created:     May 2010 ANDREW BISHOP
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
// 20/09/2017		jlgdap1			TFS 6935 SNO Changes for Hold Jobs loaded to Operations
// ---------------------------------------------------------------------------

vars
	queueObj : CM_RadioTelemetryQueue;
	queueItem	: CM_RadioTelemetryQueue;
	term : CM_Terminal;
	js : CM_JobSheet;						// TFS 6935
begin

	queueObj := self.myVoyage.myQueue;
	if queueObj = null then	//17 Jun 2010	NDL found while testing Par 24382
		return null;
	endif;
	
	foreach queueItem in queueObj.allSubQueuesById	where queueItem.isCraneQueue do	//23 May 2012	NDL	Par 29621
		if not self.myVoyage.hasCraneGotJS(queueItem.CM_VoyageCraneQueue.crane) then
			if queueItem.CM_VoyageCraneQueue.crane &lt;&gt; null then
				return queueItem.CM_VoyageCraneQueue.crane.transferArea;
			endif;
		endif;
 	endforeach;
	
	foreach queueItem in queueObj.allSubQueuesById 	where queueItem.isWorkPointQueue do	
		if not self.myVoyage.hasWorkPointGotJS(queueItem.CM_VoyageWorkPointQueue.myWorkPoint) then
			if queueItem.CM_VoyageWorkPointQueue.myWorkPoint &lt;&gt; null then
				return queueItem.CM_VoyageWorkPointQueue.myWorkPoint.myWorkPointInterchangeArea;
			endif;
		else																											// TFS 6935
			// Voyage Hold Jobs do have a job sheet, but are still planned / queued to the voyage ship block 			// TFS 6935
			// controller. They're not picked up above, because that's doing drag-drop type jobs from the Voyage		// TFS 6935
			// Operatinos screen. So we have a double-check here														// TFS 6935
			js := self.myVoyage.allJobSheets[queueItem.CM_VoyageWorkPointQueue.myWorkPoint.code.trimBlanks];			// TFS 6935
			if js &lt;&gt; null and js.isVoyageHoldJobSheet then																// TFS 6935
				if queueItem.CM_VoyageWorkPointQueue.myWorkPoint &lt;&gt; null then											// TFS 6935
					return queueItem.CM_VoyageWorkPointQueue.myWorkPoint.myWorkPointInterchangeArea;					// TFS 6935
				endif;																									// TFS 6935
			endif;																										// TFS 6935
		endif;
 	endforeach;
	
	return null;

epilog

end;</source>
        <ReturnType type="CM_TerminalArea"/>
    </JadeMethod>
    <JadeMethod name="getMachineRuleTerminalAreaType" id="23354970-0bfd-4810-9ee4-a917b531a985">
        <source>getMachineRuleTerminalAreaType(): CM_TerminalAreaType;
// ---------------------------------------------------------------------------
// Created:     May 2010 ANDREW BISHOP
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	taType : CM_TerminalAreaType;
begin
	
	taType := inheritMethod();
	
	if taType &lt;&gt; null then
		return taType;
	endif;
	
	return app.myRoot.allTerminalAreaTypes[TA_TYPE_CRANE_TRANS];

end;</source>
        <ReturnType type="CM_TerminalAreaType"/>
    </JadeMethod>
