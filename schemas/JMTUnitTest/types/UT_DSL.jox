    <JadeMethod name="addInterTerminalMove" id="bd8577c1-a3dc-417e-8023-43043d953c97">
        <source>addInterTerminalMove( _ti : CM_TrackedItem; sourceT, targetT : CM_Terminal; vehicle : CM_Vehicle; vehicleJob : CM_InterTermVehicleJob) : CM_InterTerminalMove;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 February 2010	cnwrd1	Initial creation

*/

vars
	pProxyInterTermMove,
	pNewInterTermMove : CM_InterTerminalMove;
begin

	create pProxyInterTermMove transient;
	
	pProxyInterTermMove.setProxy(	_ti.id,	        // cargoID : String;
								_ti.myOperator,	// operator : CM_Operator;
								_ti,	            // sourceTI : CM_TrackedItem;
								sourceT,	    // sourceTerminal : CM_Terminal;
								targetT,	    // targetTerminal : CM_Terminal;
								vehicle,	            // sourceVehicle : CM_Vehicle;
								vehicle.regNumber,	// vehicleId : String;
								ITT_LOADING,	            // status : Integer;
								vehicleJob  // myInterTermVehicleJob : CM_InterTermVehicleJob
								);
						 
	app.myTrxCA.trxCreateInterTerminalMove( pProxyInterTermMove, pNewInterTermMove, app.myPassport );
	
	return pNewInterTermMove;
epilog
	delete pProxyInterTermMove;
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
