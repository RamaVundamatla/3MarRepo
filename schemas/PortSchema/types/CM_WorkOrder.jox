    <JadeMethod name="shouldAuditProperty" id="faf057c7-5566-4f07-a42d-3060442dc418">
        <source>shouldAuditProperty(_rootClass: Class; _property: Property): Boolean protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25/06/2018  cnwma1	ChangeRequest 38635: PEL1 - SAP Cancellations
18/02/2018  cnwma1	Bug 43452: PEL1 - SAP Web Service (1081 Deadlock) issue
12 Jan 2023	navma1  ChangeRequest 56141: EUP - Refactor and Remove CM_WorkOrderTISource from CM_WorkOrderTI
20 Apr 2023 navma1	Defect 57661: MTN - WO - On the Audit details myPinNo is not showing the actual pin number
*/

vars
	propName	: String;
begin
	if _property = null then
		return false;
	endif;
	
	propName := _property.name;
	
	if	propName = CM_WorkOrder::taskStatus.name    			or 
		propName = CM_WorkOrder::myCashReceipt.name 			or  //18.02.2019 cnwma1 TFS #43452
		propName = CM_WorkOrder::myInvoice.name     			or  //18.02.2019 cnwma1 TFS #43452
		propName = CM_WorkOrder::allCashReceipts.name		 	or  //18.02.2019 cnwma1 TFS #43452
		propName = CM_WorkOrder::startAtDT.name        		 	or  //12.01.2023 navma1 #56141:[56147]
		propName = CM_WorkOrder::myPinNo.name					or  //20.04.2023 navma1 #57661
		propName = CM_WorkOrder::allInvoices.name	    
		then
		return false;
		
	endif;
	return inheritMethod(_rootClass, _property);
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_rootClass" type="Class"/>
        <Parameter name="_property" type="Property"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="updateTaskOrderPosition" id="1ed134cb-1f77-4dbc-a851-5888bb3ad96d">
        <source>updateTaskOrderPosition(_pxyWorkOrder : CM_WorkOrder);

/*

Purpose:		Update task order position, add and remove tasks

Parameters:			

Return Value:		


Date		Who		Reason
21 Aug 2009	cnwmd1	Initial creation
20 Mar 2023 navma1  ChangeRequest 56842:[56843] EUP - VAS Task Priority
*/

vars
	pxyTask, 
	realTask 	 : CM_WorkOrderDtl;
	pxyPos, 
	realPos 	 : Integer;
	dynaDict 	 : DynaDictionary;
	objsToRemove : CM_WorkOrderDtlArray;
	term	  	 : CM_Terminal;
	idx		  	 : Integer;
	uniquePrefix,
	toDoUniquePrefix,
	uniqueSuffix : String;
	wodToDo		 : CM_WodToDo;
	
begin
	create dynaDict transient;
	dynaDict.setMembership(CM_WorkOrderDtl);
	dynaDict.addMemberKey(CM_WorkOrderDtl::taskID.name, false, true);
	dynaDict.endKeys(true);
	
	//** Change task position
	self.allWoDtls.copy(dynaDict);
	
	foreach pxyTask in _pxyWorkOrder.allWoDtls do 
		
		pxyPos := _pxyWorkOrder.allWoDtls.indexOf(pxyTask);
		realTask := dynaDict.getAtKey(pxyTask.taskID).CM_WorkOrderDtl;
		
		if realTask &lt;&gt; null then //Task already exists
			self.allWoDtls.remove(realTask); //remove the task before inserting into the new position
		endif;
				
		self.allWoDtls.insert(pxyPos, realTask);	
		
	endforeach;
	
	//** Remove tasks
	create objsToRemove transient;
	dynaDict.clear();
	_pxyWorkOrder.allWoDtls.copy(dynaDict);
	foreach realTask in self.allWoDtls do
		
		realPos := self.allWoDtls.indexOf(realTask);
		pxyTask := dynaDict.getAtKey(realTask.taskID).CM_WorkOrderDtl;
		
		if pxyTask = null then //Pxy Task has been removed
			objsToRemove.add(realTask);
		endif;
				
	endforeach;
	
	foreach realTask in objsToRemove do
		realTask.erase(1);
	endforeach;
	
	/*
	Update Task Id 
	20.03.2023 navma1 #56842:[56843]
	*/
	
	term        	 := self.myTerminal;
	uniquePrefix 	 := self.id &amp; "-";
	toDoUniquePrefix := self.id &amp; "-ToDo-";
	idx 		 	 := 1;
	
	foreach realTask in self.allWoDtls do
		if term &lt;&gt; null then
			uniqueSuffix := term.getNextSuffix(idx);
			realTask.setTaskID(uniquePrefix &amp; uniqueSuffix);
			
			/*
			For Work orders with ToDo Tassks
			*/
			if realTask.isKindOf(CM_WorkOrderTIDtl) and realTask.CM_WorkOrderTIDtl.canAddTodoTaskToCargoWO then
				if not realTask.CM_WorkOrderTIDtl.allToDoRequests.isEmpty then
					foreach wodToDo in realTask.CM_WorkOrderTIDtl.allToDoRequests do
						uniqueSuffix := term.getNextSuffix(idx);
						wodToDo.setTaskID(toDoUniquePrefix &amp; uniqueSuffix);
					endforeach;
				endif;
			endif;
			idx := idx + 1;
		endif;
	endforeach;
	
epilog
	delete objsToRemove;
	delete dynaDict;
end;</source>
        <Parameter name="_pxyWorkOrder" type="CM_WorkOrder"/>
    </JadeMethod>
