    <JadeMethod name="stub_GetSelectedTrackedItem" id="e3ab8e43-fedf-42ab-b8ff-d8352d1d1789">
        <interfaceImplements>
            <JadeInterfaceMethod name="IF_CMUI_TrackedItems::getSelectedTrackedItems"/>
        </interfaceImplements>
        <source>stub_GetSelectedTrackedItem(_allTIs: CM_TIArray input );

	/*
		this method stub has been automatically generated by Jade to satisfy interface implementation requirements
	*/
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 November 2008	cnwer1	Initial creation
23/06/2023	navkc1	CR 58406 Task 58408: Jade - Release Request All Tracked Items
*/

vars
	pxyBulkRelease : CM_BulkRelease;
	reserveDetail : CM_ReserveDetail;
	brItem			: CM_BRefItemContainer;
	row 			: Integer;
begin
	row := self.tblBookingItems.row;
	
	if row &gt; 1 then
		brItem := self.tblBookingItems.accessRow(row).itemObject.CM_BRefItemContainer;	
	endif;
	
	if brItem = null then
		return;
	endif;
	reserveDetail:=brItem.myReserveDetail;
	if reserveDetail = null then
		return;
	endif;
	
	//reserveDetail.allTrackedItems.copy(_allTIs);
	reserveDetail.getAllTrackedItems(_allTIs, false); //23/06/2023	navkc1	CR 58406 Task 58408

epilog

end;</source>
        <Parameter name="_allTIs" type="CM_TIArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="stub_RemoveTrackedItems" id="a432d8fe-27ee-4bc2-958d-56c09c56771a">
        <interfaceImplements>
            <JadeInterfaceMethod name="IF_CMUI_TrackedItems::removeTrackedItem"/>
        </interfaceImplements>
        <source>stub_RemoveTrackedItems(_ti: CM_TrackedItem): Boolean;

	/*
		this method stub has been automatically generated by Jade to satisfy interface implementation requirements
	*/
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 November 2008	cnwer1	Initial creation

*/

vars
	
	reserveDetail		: CM_ReserveDetail;
	release				: CM_BulkRelease;
	idx					: Integer;
	theTI				: CM_TrackedItem;
	
begin

	theTI := _ti;		// PAR 23115

	//cnwjo3, par 20606.  Technically there should only be 1 CM_BulkRelease for a CM_BookingRef, but just in case
	foreach release in self.myProxyBookingRef.allReleaseRequests do
		release.removeTIAssigned(theTI);
		release.removeTIReleased(theTI);
	endforeach;
	
	return true;
	
epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
