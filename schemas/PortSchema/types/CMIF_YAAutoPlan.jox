    <JadeMethod name="calculateMoveLCs" id="55d1b806-8b19-4f3b-8818-ee9fad474f6e">
        <source>calculateMoveLCs(): Real;
// -------------------------------------------
// Created 27 May 2005 by cnwdvb1
// -------------------------------------------
vars

	len : Real;
	
begin

	len := self.getLengthInUnits();
	if len &gt; 1 then
		return len div 2;
	else
		return 1;
	endif;
	return 0;

end;</source>
        <ReturnType type="Real"/>
    </JadeMethod>
