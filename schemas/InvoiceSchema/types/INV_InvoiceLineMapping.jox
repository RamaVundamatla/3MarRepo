    <JadeMethod name="addToolbarControls" id="638b8b46-5a9c-4ce2-b6a0-5953c7549f2e">
        <updating/>
        <source>addToolbarControls() updating, protected;
// ---------------------------------------------------------------------------
// Created:		September 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// 11/10/2022	navpw1	TFS: 54566 - Moved delete toolbar button from prop toolbar to main toolbar and added open invoice line maapings button
// 20/03/2023	navmk20 Bug 56954: FR | 53978 - EUP - Invoicing - Configuration Enhancements - User Story 050 issues
vars
	frm				: CMUI_Toolbar;
	
begin	
	frm := self.frmToolbar;

	inheritMethod();
	frm.addButton(self.btnPrint, CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnShowSearcher, CMUI_Toolbar.Control_Alignment_Left);
	frm.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnEditItem, CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnPropDelete, CMUI_Toolbar.Control_Alignment_Left);			// ### TFS 54566 10Oct2022 NAVPW1
	frm.addButton(self.btnRefresh, CMUI_Toolbar.Control_Alignment_Left);
	frm.addSeperator(CMUI_Toolbar.Control_Alignment_Left);							// ### TFS 54566 07Oct2022 NAVPW1
	frm.addButton(self.btnOpenLineMappings, CMUI_Toolbar.Control_Alignment_Left);	// ### TFS 54566 07Oct2022 NAVPW1
	frm.addSeperator(CMUI_Toolbar.Control_Alignment_Left);// 20.3.2023 navmk20 TFS 56954
	frm.addButton(self.btnImportCSVMap, CMUI_Toolbar.Control_Alignment_Left);// 20.3.2023 navmk20 TFS 56954
	frm.addButton(self.btnExportCSVMap, CMUI_Toolbar.Control_Alignment_Left);				// 20.3.2023 navmk20 TFS 56954
	
	frm := self.frmPropToolbar;
	frm.addButton(self.btnPropSave, CMUI_Toolbar.Control_Alignment_Left);
	//frm.addButton(self.btnPropDelete, CMUI_Toolbar.Control_Alignment_Left);		// ### TFS 54566 10Oct2022 NAVPW1
	frm.addButton(self.btnPropCancel, CMUI_Toolbar.Control_Alignment_Right);
	frm.positionToolbarControls();
	frm.visible := true;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="addToolbarControlsQuery" id="3730ca3c-f8fe-413d-9da8-c72973a01e9d">
