    <JadeMethod name="setUserDefinedTI" id="85bf2468-a7ad-4bb8-8ecc-27945221536f">
        <updating/>
        <source>setUserDefinedTI(_ediTi: CM_EDICargoTI; _site: Integer; _terminal: CM_Terminal; _updateController: CMIF_TIUpdateController input; _passport: CM_Passport input) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 27/06/2023	navdap1		Initial creation TFS 58813 EUP Instructions and Cargo Group
//
vars

begin
	if _ediTi.myEDIData.isTransportManifestRelated then
		self.myCargoGroupTerminal := _terminal;
	endif;
	
	inheritMethod(_ediTi, _site, _terminal, _updateController, _passport);

epilog

end;</source>
        <Parameter name="_ediTi" type="CM_EDICargoTI"/>
