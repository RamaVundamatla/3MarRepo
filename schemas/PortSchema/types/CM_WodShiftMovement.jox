    <JadeMethod name="actionForApproved" id="eed6151c-7b73-4ead-8dda-707104144a31">
        <updating/>
        <source>actionForApproved(_voyage: CM_Voyage input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 October 2018	jlgndl1	Initial creation	TFS 41412

*/

vars

begin

	inheritMethod(_voyage);
	
	//16 Oct 2018	NDL	TFS 41412 and out again 19 Oct 2018
//	if self.myHMSVoyageMovement &lt;&gt; null and self.myHMSVoyageMovement.myMarineServiceTimings &lt;&gt; null then
//		self.myHMSVoyageMovement.myMarineServiceTimings.setMovementDateTimes( self.getOccursDT, false, true, false );
//	endif;

	//23 Oct 2018	NDL	TFS 41412
	self.approvedOccursDT := self.getOccursDT;

epilog

end;</source>
        <Parameter name="_voyage" type="CM_Voyage" usage="input"/>
    </JadeMethod>
    <JadeMethod name="actionForCancelled" id="94e62094-03fa-4c60-b68b-393ce14324be">
        <updating/>
        <source>actionForCancelled(_voyage: CM_Voyage input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 August 2018	jlger1	Initial creation
01/10/2021	jlier1	TFS 51963 - changes voyage process
*/

vars
//	movement : HMS_Object;
	voyStatus : CM_VoyageStatus;
begin
	//inheritMethod(_voyage);
	//10 Dec 2018	NDL	TFS 42043 - don't delete it
//	movement :=self.myHMSVoyageMovement;
//	if movement &lt;&gt; null then //19.09.2018 cnwma1
//		app.myUtilityDA.utlDeleteHMSObject(movement, app.myPassport);
//	endif;
	
	voyStatus :=_voyage.myVoyageProcess.allStatusesById[Voyage_Status_VoyageArrived];
	
	
	_voyage.setStatusFromObject(voyStatus);
epilog

end;</source>
        <Parameter name="_voyage" type="CM_Voyage" usage="input"/>
    </JadeMethod>
    <JadeMethod name="actionItems" id="d132e75e-3d6b-4ac7-b531-ab4a8058d0d4">
        <updating/>
        <source>actionItems(_woActionIF: CMIF_WorkOrderAction; _passport: CM_Passport input) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 24/05/2018	jlgdap1		Initial creation TFS 38560 PEL1 Voyage Work Orders
// 14/06/2018	jlgdap1		TFS 39165 PEL1 Voyage Work Order Transactions
// 26/07/2018	jlgdap1		TFS 39741 PEL1 Marine Service Timings Changes
// 21/09/2018	jlgdap1		TFS 40543 PEL1 WP Time Change does not display all relevant work orders for the Voyage
// 04/12/2018	jlgdap1		TFS 42252 PEL1 Issues with voyages with no tug or pilot
// 09/04/2019	jlgdap1		TFS 43694 PEL1 Charging for Vessels that use a Ramp
//11 Oct 2021 	jlier1			TFS 51963 removed inaportnet
vars
	pxyMovement, realMovement : HMS_Movement;
	detail : CM_WodMarineServiceDetail;
	voyageStatus : CM_VoyageStatus;
	harbour : HMS_Harbour;
	newDepartureTS  : TimeStamp;
	departureMovement : HMS_Movement;
	voyage : CM_Voyage;
	tsInterval : TimeStampInterval;
	timings : HMS_MarineServicesTimings;
	resUsedAgent : CMIF_HMSResourceUsedProforma;
	pxyResource, realResource : HMS_ResourceUsed;
	obj : Object;
	serviceTimings : HMS_MarineServicesTimings;				// TFS 42252
begin
	// create a shift movement 
	create pxyMovement as HMS_VoyageMovement transient;
	pxyMovement.HMS_VoyageMovement.populateFromWodShiftMovement(self);
	
	// now do the update
	app.myUtilityCA.utlCreateHMSMovement(pxyMovement, realMovement, true, _passport);
	
	//01 Aug 2018	NDL	TFS 39900
	if _passport.noErrors and realMovement &lt;&gt; null then
		harbour := self.getMyTerminal.myHarbour;
		if canCreateResources( voyageStatus ) then
		
			app.myUtilityCA.utlAddHMSResources(self.allMarineServiceDetails, voyageStatus, harbour, realMovement.HMS_VoyageMovement, _passport);	
		endif;
		
		if self.myRelatedPermitRequest &lt;&gt; null then
			//create any cargo equipment resources 
			app.myUtilityCA.utlAddHMSResources(self.myRelatedPermitRequest.allMarineServiceDetails, null, harbour, realMovement.HMS_VoyageMovement, _passport);
		endif;
	endif;
	
	if _passport.noErrors then
		self.setIsComplete;
		// create the appropriate transaction for billing purposes
		//self.createHMSResource(WO_TASK_VOY_SHIFTMOVEMENT);		// TFS 39165
		self.createWorkOrderTransaction(TRANS_TYPE_WO_SHIFT);			// TFS 39165
		
		self.myHMSVoyageMovement := realMovement.HMS_VoyageMovement;			// TFS 40543
	endif;
	
	//19 Oct 2018	NDL	TFS 41412
	if self.myHMSVoyageMovement &lt;&gt; null then
		if self.myHMSVoyageMovement.myMarineServiceTimings = null then
			create timings persistent;
			timings.setMyVoyageMovement( self.myHMSVoyageMovement );
		endif;
		if self.myHMSVoyageMovement.myMarineServiceTimings = null then		// TFS 42252
			if self.myHMSVoyageMovement.isTransient then					// TFS 42252
				create serviceTimings transient;							// TFS 42252
			else															// TFS 42252
				create serviceTimings persistent;							// TFS 42252
			endif;															// TFS 42252
			serviceTimings.setMyVoyageMovement(self.myHMSVoyageMovement);	// TFS 42252
		endif;																// TFS 42252
		if self.myHMSVoyageMovement.myMarineServiceTimings &lt;&gt; null then
		//	self.myHMSVoyageMovement.myMarineServiceTimings.setMovementDateTimes( self.getMyParent.enteredByDT, true, false, false );	//requested
		//	self.myHMSVoyageMovement.myMarineServiceTimings.setMovementDateTimes( self.getMyParent.approvedByDT, false, true, false );	//approved
			//23 Oct 2018	NDL	TFS 41412
			self.myHMSVoyageMovement.myMarineServiceTimings.setMovementDateTimes( self.enteredOccursDT, true, false, false, false );	//requested
			self.myHMSVoyageMovement.myMarineServiceTimings.setMovementDateTimes( self.approvedOccursDT, false, true, false, false );	//approved
			self.myHMSVoyageMovement.myMarineServiceTimings.setMovementDateTimes( self.berthArrival, false, false, false, true );	//berth arrival	//26 Oct 2018	NDL	TFS 41413
				/* Ian says 'don't tick any box automatically and leave it up to the user to confirm on the movement 
									when the vessel moves away from the berth if the ramp was actually used there.'
			self.myHMSVoyageMovement.myMarineServiceTimings.setHasRamp(self.hasRamp);			// TFS 43694
			*/
		endif;
	endif;
	
	// TFS 39741 Update the marine service timings on the newly-created shift movement
	// Requested date/time comes from the original from/to date/time on any pilot or tug details,
	// Approved date/time comes from the current from/to date/time on any pilot or tug details
	foreach detail in self.allMarineServiceDetails do
		if detail.myHMSResource.isResourceForClass(HMS_ResourceForPilot)
		or detail.myHMSResource.isResourceForClass(HMS_ResourceForTug) then
			detail.doMarineServiceTimingsUpdate(false, true, false, false);		// requested date/time
			detail.doMarineServiceTimingsUpdate(false, false, true, false);		// approved date/time
		endif;
	endforeach;
	
	voyage:=self.getMyVoyageObject;
	//epr TFS 43374 12/3/19
	newDepartureTS:=self.getNewDepartureTS();
	if newDepartureTS &lt;&gt; null then
		departureMovement:=voyage.getMovementDeparture;
		departureMovement.setOccursOnDT(newDepartureTS);
		if self.getCurrentLengthOfTime &lt;&gt; null then
			tsInterval:=(newDepartureTS - voyage.arrivedDT);
			voyage.setTotalTimeInPort(tsInterval.inDaysAndPartOf);
		endif;
	endif;
	
	// TFS 41411
	if _passport.noErrors and realMovement &lt;&gt; null then
	
		create resUsedAgent transient;
		resUsedAgent.initialise();
		resUsedAgent.dummyUpWharfDeparture(realMovement.HMS_VoyageMovement);
		
		foreach obj in resUsedAgent.allResUsed do
			pxyResource := obj.HMS_ResourceUsed;
			app.myUtilityCA.utlCreateHMSResourceUsed(realMovement, pxyResource, realResource, _passport);	
		
		endforeach;
	endif;
		
epilog
	delete pxyMovement;
end;</source>
        <Parameter name="_woActionIF" type="CMIF_WorkOrderAction"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="canAccessConsigneeConsignor" id="c7627031-9c19-4a5e-919f-aa582e4e87f5">
        <source>canAccessConsigneeConsignor(_user: CM_User): Boolean;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 05/12/2018	jlgdap1		Initial creation TFS 42219 PEL1 Consignee Access Issues
//
vars
	cargoRequest : CM_WodCargoRequest;

begin
	foreach cargoRequest in self.allWodCargoRequests discreteLock do
		if cargoRequest.canAccessConsigneeConsignor(_user) then
			return true;
		endif;
	endforeach;
	
	return false;

epilog

end;</source>
        <Parameter name="_user" type="CM_User"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="canCancel" id="c341450a-9182-495c-b104-52b06ecf976a">
        <source>canCancel(): Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16/08/2018	jlger1	Initial creation
21/09/2018	jlgdap1	TFS 40543 PEL1 WP Time Change does not display all relevant work orders for the Voyage
*/

vars
	
begin
	return self.myHMSVoyageMovement = null or self.myHMSVoyageMovement.moveStatus &lt;&gt; MovementStatus_Actual;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="canCreateResources" id="b04637a0-3d9a-4e2b-9bef-31f4253520c5">
        <source>canCreateResources(	_voyageStatus : CM_VoyageStatus output): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 August 2018	jlgndl1	Initial creation	TFS 39900

*/

vars

	voyage : CM_Voyage;
	voyageProcess : CM_VoyageProcess;
	voyageStatus : CM_VoyageStatus;

begin

	if self.getMyParent &lt;&gt; null and self.getMyParent.taskStatus = WO_STATUS_APPROVED then
		voyage := self.getMyVoyageObject;
		if voyage &lt;&gt; null then
			voyageProcess := voyage.myVoyageProcess;
			if voyageProcess.isMTNWOProcess then //jlier1 TFS 51963 1/10/21
				voyageStatus := app.myRoot.allVoyageStatuses[Voyage_Status_DepServPending];
			endif;
			if voyageStatus &lt;&gt; null and not voyageStatus.allHMSResourcesApproval.isEmpty then
				_voyageStatus := voyageStatus;
				return true;
			endif;
		endif;
	endif;
	
	return inheritMethod( _voyageStatus );

epilog

end;</source>
        <Parameter name="_voyageStatus" type="CM_VoyageStatus" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="createPxyHMSResourceProformas" id="375415b2-8655-42a5-87d1-238d5876d30c">
        <source>createPxyHMSResourceProformas(_hmsUsed : HMS_ResourceUsedSet input; _movement : HMS_VoyageMovement input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 June 2018	jlgab1	Initial creation

*/

vars
	tmpRes : HMS_Resource;
	detail : CM_WodMarineServiceDetail;
	used : HMS_ResourceUsed;
	berth : HMS_Berth;
	voyage : CM_Voyage;
	depmove : HMS_VoyageMovement;
	arrTS, depTS : TimeStamp;
	pxyResUsed : HMS_ResourceUsed;
begin
	foreach detail in self.allMarineServiceDetails	discreteLock do
		used := detail.createPxyHMSResourceProforma(_movement);
		
		if used&lt;&gt; null then
			_hmsUsed.add(used);
		endif;
		
	endforeach;
	
	/* TFS 39721
	berth := _movement.getMyBerth();
	if berth &lt;&gt; null then
		
		tmpRes := berth.myWharf.getResourceForHarbourMovement(HMSMovementTypeShift,HMS_Wharf.First_Resource);
		if tmpRes &lt;&gt; null then
			create pxyResUsed transient;
			pxyResUsed.setProxy(_movement.myHarbour, tmpRes.myResourceType,tmpRes, null, _movement.occursOnDTNEW, _movement.occursOnDTNEW, 1, false);
			pxyResUsed.setMyVoyageMovement(_movement);
			_hmsUsed.add(pxyResUsed);
		endif;
		
		tmpRes := berth.myWharf.getResourceForHarbourMovement(HMSMovementTypeShift,HMS_Wharf.Second_Resource);
		if tmpRes &lt;&gt; null then
			create pxyResUsed transient;
			pxyResUsed.setProxy(_movement.myHarbour, tmpRes.myResourceType,tmpRes, null, _movement.occursOnDTNEW, _movement.occursOnDTNEW, 1, false);
			pxyResUsed.setMyVoyageMovement(_movement);
			_hmsUsed.add(pxyResUsed);
		endif;
	endif;
	*/
epilog

end;</source>
        <Parameter name="_hmsUsed" type="HMS_ResourceUsedSet" usage="input"/>
        <Parameter name="_movement" type="HMS_VoyageMovement" usage="input"/>
    </JadeMethod>
