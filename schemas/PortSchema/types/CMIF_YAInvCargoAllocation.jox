    <JadeMethod name="isSortingMethod_Match" id="e01c2d91-c240-48d2-95ac-b2e786ff375a">
        <source>isSortingMethod_Match(_yaData: CM_YADataObjects): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 June 2023	navpw1	Initial creation TFS: 58429 (58517)

*/

vars
	sortingMethod	: CM_SortingMethod;
	transaction		: CM_TITransaction;
	ti				: CM_TrackedItem;
	
begin
	// Only priorities will be empty.
	if _yaData.isEmpty() then
		return true;
	endif;
	
	transaction := self.myTransaction;
	
	if transaction = null then
		return null;
	endif;
	
	ti := transaction.myTrackedItem;
	
	if ti = null then
		return false;
	endif;
	
	sortingMethod := ti.mySortingMethod;
	
	if sortingMethod = null then
		return false;
	endif;
	
	return _yaData.matches(sortingMethod);
	
end;</source>
