    <JadeMethod name="showTableStats" id="2dad9c9f-6b08-4446-85d9-530d43f66b4f">
        <source>showTableStats();
// ---------------------------------------------------------------------------
// Created:		December 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
constants
	WIDTHDATA = 160;
vars
	theTable					: Table;
	numColumns,idx,
	numCranes				: Integer;
	aJS 						: CM_VoyageJobSheet;
	tmpJobSheetStats			: CMIF_JobSheetStats;
begin
	foreach tmpJobSheetStats in self.myVoyageStats.allJobSheetStats discreteLock do
		numCranes := numCranes + 1;
	endforeach;

	//epr 26/3/07 par 13730
	if numCranes &gt; 1 or numCranes = 0 then
		numColumns	:= numCranes  + 2; // PAR 8436
	else
		numColumns := numCranes + 1;
	endif;
	theTable := self.tblGridAreaInfo;
	theTable.columns := numColumns;
	
	foreach idx in 2 to numColumns do
		theTable.accessColumn(idx).width := WIDTHDATA;
		theTable.accessColumn(idx).backColor := self.colorValueColumn;
	endforeach;

	idx := 1; // PAR 8436
	if numCranes &gt; 1 or numCranes = 0 then // PAR 8436
		idx := 2;
		self.showTableStatsColumn(self.myVoyageStats,idx);
		 
	endif;
	// ##### EACH CRANE
	foreach tmpJobSheetStats in self.myVoyageStats.allJobSheetStats discreteLock do
		idx := idx + 1;
		
		self.showTableStatsColumn(tmpJobSheetStats,idx);
		
	endforeach;
end;</source>
    </JadeMethod>
    <JadeMethod name="showTableStatsColumn" id="709a049f-d5ac-4fd4-bb00-c3fa1a5a514b">
        <source>showTableStatsColumn(_obj :  CMIF_Object input; _column : Integer) protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
12 September 2011	cnwer1	Initial creation CCMS MES 1033

*/

vars
	entRow : EntTableRow;
	row 	: Integer;
	str 	: String;
	theTable : CM_DataTable;
begin
	theTable:= self.tblGridAreaInfo;
	row:=1;
	
	while row &lt;= theTable.rows do
		entRow:=theTable.accessRow(row).itemObject.EntTableRow;
		
		if entRow &lt;&gt; null then	//07 Feb 2018	NDL	TFS 36909
		
			str:= _obj.getDisplayStringForAttribute(entRow.name,false);	
			theTable.accessCell(row,_column).text:=str;
			
			if  _obj.isKindOf(CMIF_VoyageStats) then
				//epr par 31764 6/8/13
				if self.myCurrentVoyage &lt;&gt; null and self.myCurrentVoyage.myROROStructure = null and (entRow.name = ETRow_VolumeMoved 
					or  entRow.name = ETRow_VolumeToMove
					or entRow.name = ETRow_QuantityMoved
					or entRow.name = ETRow_QuantityToMove) then
					theTable.accessRow(row).visible:=false;		
				endif;
			endif;	
			
		endif;
		row:=row + 1;
	endwhile;
	
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_obj" type="CMIF_Object" usage="input"/>
        <Parameter name="_column" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="showTableStatsColumnLabels" id="663417dd-2484-4e54-a63e-be059a3510c3">
        <source>showTableStatsColumnLabels() protected;
/* ---------------------------------------------------------------------------
// Created:		January 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
12 Sep 2011	cnwer1	CCMS 1239
*/

vars
	theTable : CM_DataTable;
	finIO : CM_ExtFinanceIO;
	entTableDef : EntTableDef;
	entTableRow : EntTableRow;
	tmpStr      : String;
	idx		: Integer;
	hideActualRate:	Boolean;
begin
	// PAR 11106
	finIO := self.myTerminal.getConfig(FinancialIOClass).CM_ExtFinanceIO;
	if finIO &lt;&gt; null then
		if finIO.class = CM_Greentree then
			hideActualRate:=true;
		endif;
	endif;
	
	theTable := self.tblGridAreaInfo;
	entTableDef:=app.myRoot.myEntTableDataRoot.allEntTableDefs[ETDef_SideProfileStats];
	foreach entTableRow in entTableDef.allEntTableRows do
		if hideActualRate and 	entTableRow.name =  ETRow_ActualRate then
			continue;
		endif;
		
//		if not hasKPILicense and entTableRow.name = ETRow_NetRate then
//			continue;
//		endif;
		tmpStr := entTableRow.getShortHeading(null, self.myTerminal, app.myCurrentLocale);
		idx:=theTable.addItemObject(entTableRow,tmpStr);
		
	endforeach;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="sizeBowAndSternGraphics" id="b8e8110e-1716-4480-804d-61e94af2dca2">
        <updating/>
        <source>sizeBowAndSternGraphics() updating, protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 09/02/2016	cnwdap1		Initial creation PAR #36766 Bulk Graphical Representation
//
vars

begin
	if self.myBulkDrawingController = null or self.myBulkDrawingController.isStarboardBerthed then
		self.picStern.move(self.dkcSubMain.left, self.dkcMain.top, self.dkcMain.width*.112612, self.dkbGridArea.height);
		self.frmMiddle.move(self.dkcSubMain.left + self.dkcMain.width*.112612, self.dkcMain.top, (self.dkbGridArea.width - ((self.dkcMain.width*.112612)+(self.dkcMain.width*.061937))), self.dkbGridArea.height);
		self.picBow.move(self.dkcSubMain.width + self.dkcSubMain.left - (self.dkcMain.width*.061937), self.dkcMain.top+1, self.dkcMain.width*.061937, self.dkbGridArea.height);
		self.picSternRev.visible := false;
		self.picBowRev.visible := false;
		self.picStern.visible := true;
		self.picBow.visible := true;
	else
		self.picBowRev.move(self.dkcSubMain.left, self.dkcMain.top+1, self.dkcMain.width*.061937, self.dkbGridArea.height);
		self.frmMiddle.move(self.dkcSubMain.left + self.dkcMain.width*.061937, self.dkcMain.top, (self.dkbGridArea.width - ((self.dkcMain.width*.112612)+(self.dkcMain.width*.061937))), self.dkbGridArea.height);
		self.picSternRev.move(self.dkcSubMain.left+self.dkcSubMain.width-(self.dkcMain.width*.112612), self.dkcMain.top, self.dkcMain.width*.112612, self.dkbGridArea.height);
		self.picStern.visible := false;
		self.picBow.visible := false;
		self.picSternRev.visible := true;
		self.picBowRev.visible := true;
	endif;

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="switchDisplayMode" id="40bc29fa-7674-4c32-82ab-bd5f20c30d2b">
        <updating/>
        <source>switchDisplayMode(_newMode : Integer; _doDraw : Boolean) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 27/08/2015	cnwdap1		Initial creation PAR #36766 CCMS SFW 1334 Bulk Graphical Representation
//
vars
	oldMode	: Integer;

begin
	oldMode := self.displayMode;
	if oldMode = _newMode then
		return;
	endif;

	self.hasChanged := false;
	self.displayMode := _newMode;
	self.setCaptionForModes(_newMode);
	
	self.displayMode := _newMode;
	if self.myCurrentVoyage &lt;&gt; null then
		self.myCurrentVoyage.causeEvent(self.myTerminal.getTerminalEvent(ShowHide_VoyageAllocationsCC),true,false);//cnwas3 par26840a
	endif;
	// summarise will only be enabled for display mode of actual.
	self.btnSummariseAll.enabled	:= false;	// cnwrl1 16/02/2009 - (CCMS SFW 1047 - Totals Only Lists)
	
	if _newMode = ShpDisplayMode_Actual then
		self.switchWorkingMode(WorkMode_Weight);
		
		self.displayModeActual(true);
		self.myBulkDrawingController.setViewMode(VIEW_DISPORT); // PAR 25833
		self.myBulkDrawingController.setActPlanQueMode(ShpDisplayMode_Actual);
		self.btnViewDischPort.value := true;
		self.frmStatusLine.hideDisplayModeFrame(false);

	elseif _newMode = ShpDisplayMode_Ops then
		//self.switchWorkingMode(self.WorkMode_Weight);
		self.displayModeOperations(true);
		self.myBulkDrawingController.setViewMode(VIEW_DISPORT);
		self.myBulkDrawingController.setDisplayMode(_newMode);
		self.myBulkDrawingController.setActPlanQueMode(ShpDisplayMode_Actual);
		self.btnViewDischPort.value := true;
		self.frmStatusLine.hideDisplayModeFrame(true);

	else
		app.raiseUnexpectedProgramError(class.name, method.name, 'Invalid mode (' &amp; _newMode.String &amp; ')');
		return;
	endif;
	
	self.frmToolbar.hideExtraSeperators();
	self.frmToolbar.positionToolbarControls();
	
	self.setModes();
	
	if _doDraw then
		self.voyageDrawGridAreasForMode();
	endif;
	
	self.frmStatusLine.doResize();
epilog

end;</source>
        <Parameter name="_newMode" type="Integer"/>
        <Parameter name="_doDraw" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="switchWorkingMode" id="4e5e9a63-4120-47d3-8322-321924954adc">
        <updating/>
        <source>switchWorkingMode(_newMode : Integer) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 27/08/2015	cnwdap1		Initial creation PAR #36766 CCMS SFW 1334 Bulk Graphical Representation
//
vars
	oldMode	: Integer;

begin
	oldMode := self.workingMode;
	
	if oldMode = _newMode then
		return;
	endif;

	self.hasChanged := false;
	self.workingMode := _newMode;
	self.setModes();
	
	self.workModeNone(true);
	
	self.setCaptionForModes(self.displayMode);

	self.workingModeHistory := self.workingMode;
	self.frmToolbar.hideExtraSeperators();
	self.frmToolbar.positionToolbarControls();
epilog

end;</source>
        <Parameter name="_newMode" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="tblGridAreaInfo_contextMenu" id="2163d6b8-1858-453b-88e1-e6e1aefb5e9e">
        <updating/>
        <source>tblGridAreaInfo_contextMenu(_table: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer): Boolean updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 28 January 2016	cnwdap1		Initial creation PAR #
//
vars

begin
	if not inheritMethod(_table, conwin, mouse, x, y) then
		return false;
	endif;
	
	self.mnuGridPlanningTips.visible := false;
	self.mnuGridLayout.visible := false;
	self.mnuZoomSub.visible := false;
	
	return self.showContextMenu(mnuGridAreaContext, _table, conwin, mouse, x, y);

epilog

end;</source>
        <Parameter name="_table" type="Table" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="toolbarClickPreProcessing" id="991b4252-04d9-4de8-aff9-b594ca4bca88">
        <updating/>
        <source>toolbarClickPreProcessing(_theIndex : Integer) : Boolean updating, protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 27/08/2015	cnwdap1		Initial creation PAR #36766 CCMS SFW 1334 Bulk Graphical Representation
//
vars

begin
	if self.myCurrentVoyage = null and _theIndex &lt;&gt; self.BTN_DRAW then
		return false;
	endif;
	
	return true;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_theIndex" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="toolbarShowCaptions" id="37ce2213-7722-4aa3-83ef-a39a87f2b71c">
        <updating/>
        <source>toolbarShowCaptions(_showCaptions: Boolean) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 April 2017	cnwndl1	Initial creation	TFS 4058

*/

vars

	base : Integer;

begin

	self.frmToolbarSelect.showCaptions := _showCaptions;
	base := self.frmToolbarSelect.height.Integer;
	
	self.lblVoyage.top := base;
	self.cmbVoyage.top := base;
	self.msgHolds.top := base + 24;
	
	inheritMethod(_showCaptions);
	
	self.redraw;
	
epilog

end;</source>
        <Parameter name="_showCaptions" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="af8ada1a-183d-48a9-b05f-86ecc29dbdd5">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 05 July 2022 08:29:22.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0022912, locale);
	btnActual.translateBubbleHelp(Xlat_0020811, locale);
	btnActual.translateCaption(Xlat_0020812, locale);
	btnAutoCancel.translateCaption(Xlat_0020813, locale);
