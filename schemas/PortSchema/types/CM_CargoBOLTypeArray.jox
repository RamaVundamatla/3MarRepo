<CollClass name="CM_CargoBOLTypeArray" id="e3789419-7e0f-425c-aa01-12c6aa26d17c">
    <memberType name="CM_CargoBOLType"/>
    <superclass name="CM_ObjectArray"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="terminal"/>
    <JadeMethod name="getCargoTypeByAbbreviation" id="b9ec39ef-6230-44c9-9b07-780c0b8476e9">
        <source>getCargoTypeByAbbreviation(_abbrev : String) : CM_CargoBOLType;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 March 2024	navpw1	Initial creation

*/

vars
	iter	: Iterator;
	ct		: CM_CargoBOLType;
	
begin
	iter := self.createIterator;
	while iter.next( ct ) do
		if ct.abbreviation = _abbrev then
			return ct;
		endif;
	endwhile;
	
	return null;
	
epilog
	delete iter;
	
end;</source>
        <Parameter name="_abbrev" type="String"/>
        <ReturnType type="CM_CargoBOLType"/>
    </JadeMethod>
</CollClass>
