    <JadeMethod name="doBaseFormSave" id="4b7d78ad-b1f8-405f-b8fe-7ef275b267a9">
        <updating/>
        <source>doBaseFormSave() updating, protected;
// ---------------------------------------------------------------------------
// Created:		March 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//22 July 2019	cnwma1	ChangeRequest 45577: ASPA - JMT Interface to AR Oracle
// ---------------------------------------------------------------------------

vars
begin
	if self.frmInvProperties.visible = false then // PAR 10117
		return;
	endif;
	
	if self.currentView = ETView_InvListInvPropNew then
		self.doBaseFormSaveNew();
	elseif self.currentView = ETView_InvListInvPropUpdate then
		self.doBaseFormSaveUpdate();
	elseif self.currentView = ETView_InvListInvPropPost or  
		   self.currentView = ETView_InvListInvPropPostASPA  then   //22.07.2019 cnwma1 TFS #45577
		self.doBaseFormSavePost();
	elseif self.currentView = ETView_InvListInvPropVoid then 		//epr par 36958 29/9/15
		self.doBaseFormSaveVoid();
	elseif self.currentView = ETView_InvListInvPropPending	then		//22.07.2019 cnwma1 TFS #45577
		self.doSaveChangeStatus(CM_Invoice.INVOICE_PENDING);
	endif;
	self.frmToolbar.enabled := true;
	
epilog
	self.tblData.enabled:=true;
	self.btnQuery.enabled := true; // disabled in edit
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doBaseFormSaveNew" id="c064dc2b-f17a-4a45-9796-c22f8a6f7427">
        <updating/>
        <source>doBaseFormSaveNew() updating, protected;
// ---------------------------------------------------------------------------
// Created:		March 2004 By Andrew Bishop cnwab1
//
// Purpose:		
// 22 July 2019	cnwma1	ChangeRequest 45577: ASPA - JMT Interface to AR Oracle
// 01/02/2023	navkc1	TFS CR 55305 Task 55537 UI - Invoice List UI changes
// 26/04/2023   navnmk20 Bug 57663: EUP - Incorrect Statuses Available when copying an invoice
//23 May 2023 navtnr20 	Bug 58089: FR | EUP 54086 - Invoicing - Maintenance Enhancements - 070.b
//14/08/2023	navkc1	Bug 59803: FR | EUP 53978 - Invoicing - Configuration Enhancements - Invoice Update - missing items
// ---------------------------------------------------------------------------

vars
	pxyInvoice,realInvoice : CM_Invoice;
	theReturn	: Integer;

	status : Integer;
begin
	status := self.cmbStatusInvProp.itemData[self.cmbStatusInvProp.listIndex];	// 26.4.2023 navmk20 TFS 57663

	create pxyInvoice transient;
	pxyInvoice.setProxyForCreate(self.myCurrentBank,
								self.cmbDebtorInvProp.listObject.CM_Debtor,
								self.cmbDebtorAddressProp.listObject.CM_Address,		    //22.07.2019 cnwma1 TFS #45577
								self.cmbVoyageInvProp.listObject.CM_Voyage,
								self.cmbInvTypeInv.listObject.CM_InvoiceDesc,
								//self.cmbStatusInvProp.text = app.getErrorString(Suspense),	// for manual invoice - is it Suspense status? default is Pending. Par17895 september 2008 //26.4.2023 navmk20 TFS 57663
								status,	//26.4.2023 navmk20 TFS 57663
								true,	//isManual
								self.myCurrentTI,
								null,	// ### TFS 54565 (54384) 03Oct2022 NAVPW1
								null,	// ### TFS 54565 (54384) 03Oct2022 NAVPW1
								null,	// ### TFS 54565 (54384) 03Oct2022 NAVPW1
								null,	// ### TFS 54565 (54384) 03Oct2022 NAVPW1
								self.cmbCategory.itemData[self.cmbCategory.listIndex], 		// 01/02/2023	navkc1	TFS CR 55305 TASK 55537
								null,  // ### BUG 56925 07MAR2023 NAVAB1,
								self.myCurrentBank.myInvoiceProcess, //26.4.2033 navmk20 TFS 57663
								null,		//navtnr20 23-05-2023 BUG 58089
								null,	//14/08/2023	navkc1	Bug 59803
								null,	//14/08/2023	navkc1	Bug 59803
								null,	//14/08/2023	navkc1	Bug 59803
								null,	//14/08/2023	navkc1	Bug 59803
								null,	//14/08/2023	navkc1	Bug 59803
								null	//14/08/2023	navkc1	Bug 59803							
								);
	while true do
		app.myTrxCA.trxCreateInvoiceManual(pxyInvoice,realInvoice, app.myPassport);
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			global.beep;
			self.frmInvProperties.visible := false;
			if realInvoice.isCreditNote() then
				if realInvoice.externalNumber = null then
					app.msgBox( app.getErrorString1(Credit_note_create_success, realInvoice.sequenceNum.String), app.getErrorString(Information) , MsgBox_OK_Only + MsgBox_Information_Icon);
				else
					app.msgBox( app.getErrorString2(Credit_note_ext_create_success, realInvoice.sequenceNum.String, realInvoice.externalNumber), app.getErrorString(Information) , MsgBox_OK_Only + MsgBox_Information_Icon);
				endif;
			else
				if realInvoice.externalNumber = null then
					app.msgBox( app.getErrorString1(Invoice_created_successful, realInvoice.sequenceNum.String), app.getErrorString(Information) , MsgBox_OK_Only + MsgBox_Information_Icon);
				else
					app.msgBox( app.getErrorString2(Invoice_ext_created_successful, realInvoice.sequenceNum.String, realInvoice.externalNumber), app.getErrorString(Information) , MsgBox_OK_Only + MsgBox_Information_Icon);
				endif;
			endif;
			break;
		else
			theReturn := app.showErrorWarningDialog(app.getErrorString(CM_Manual_Invoice), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			return;
		endif;
		break;
	endwhile;
epilog
	delete pxyInvoice;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doBaseFormSavePost" id="6358ef2d-6c4d-4513-846c-1fb52126e40b">
        <updating/>
        <source>doBaseFormSavePost() updating;
// ---------------------------------------------------------------------------
// Created:		March 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
begin
	app.mousePointer := MP_HOURGLASS;
	//epr par 36958 24/9/15
	// TFS 39618 PATCH 1 if not app.myCurrentUserCan(self.myTerminal, PmAdmInvoiceStatusPost) then
	if not self.myCurrentBank.userCanSet(CM_Invoice.INVOICE_POSTED) then  // TFS 39618 PATCH 1
		app.msgBox(app.getErrorString1(VB_SECMOVE,app.getErrorString(INV_Invoice_Status_Post)) ,
										app.getErrorString(INV_Invoice_Security),
										MsgBox_Exclamation_Mark_Icon + MsgBox_OK_Only);

		return;
	endif;
	
	if self.myCurrentInvoice.myInvoiceProcess.isInvoiceAPIProcess() 
					and self.myCurrentInvoice.status &lt;&gt;  CM_Invoice.INVOICE_POSTED_PENDING then				//navra1 - TFS 54090 CR - 61386/Task - 61564 - 30th Nov 2023
		self.doSaveChangeStatus(CM_Invoice.INVOICE_POSTED_PENDING);											//navra1 - TFS 54090 CR - 61386/Task - 61564 - 30th Nov 2023
	else
		self.doSaveChangeStatus(CM_Invoice.INVOICE_POSTED);
	endif;

epilog
	app.mousePointer := MP_DEFAULT;




end;</source>
    </JadeMethod>
    <JadeMethod name="doBaseFormSaveUpdate" id="b006709e-a845-47df-aab5-2efd1281849a">
        <updating/>
        <source>doBaseFormSaveUpdate() updating;
// ---------------------------------------------------------------------------
// Created:		March 2004 By Andrew Bishop cnwab1
//
// Purpose:		
// 22 July 2019	cnwma1	ChangeRequest 45577: ASPA - JMT Interface to AR Oracle
// 12 Nov  2020 cnwma1  Bug 50335: ASPA - Missing Billing Address in Invoice
//09-June-2023 navtnr20 Bug 58472: EUP | Invoicing - Configuration Enhancements - Debtor Address update on Invoice
//14/08/2023	navkc1	Bug 59803: FR | EUP 53978 - Invoicing - Configuration Enhancements - Invoice Update - missing items
// ---------------------------------------------------------------------------

vars
	debtorInvType	: CM_DebtorInvType;
	pxyInvoice,
	realInvoice 	: CM_Invoice;
	theReturn,
	theRow 			: Integer;
	theDataLine		: String;
	package			: CM_PackageInvoice;
	runPackage 		: Boolean;
	task			: CM_AutoTask;
	schedule		: CM_AutoSchedule;
	debtorAddress,debtorAddress1    : CM_Address;
begin

	realInvoice := self.myCurrentInvoice;
	
	if realInvoice = null then 
		app.msgBox("Please select an invoice.","Invoice Update",MsgBox_Exclamation_Mark_Icon + MsgBox_OK_Only); // PAR 10117
		return;
	endif;
	
	pxyInvoice := app.createUpdateProxy(realInvoice).CM_Invoice;

	if self.cmbDebtorAddressProp.listObject.CM_Address &lt;&gt; null then        //12.12.2020 cnwma1 TFS #50335
		debtorAddress := self.cmbDebtorAddressProp.listObject.CM_Address;
	else
		debtorAddress := pxyInvoice.myBillingAddress;
	endif;
	if self.cmbDebtorAltAddrProp.listObject.CM_Address &lt;&gt; null then        	//navtnr20 09-06-2023 Bug 58472
		debtorAddress1 := self.cmbDebtorAltAddrProp.listObject.CM_Address;	//navtnr20 09-06-2023 Bug 58472
	else
		debtorAddress1 := pxyInvoice.myBillingAddress;						//navtnr20 09-06-2023 Bug 58472
	endif;
	pxyInvoice.setProxyForUpdate(	self.txtNarr.text,
									self.tblInvProperties.getValueByName(ETRow_IsZeroRated).Boolean, 
									self.tblInvProperties.getValueAsDate(ETRow_EndDate),
									self.tblInvProperties.getValueByName(ETRow_PurchaseOrderNumber).String,
									self.tblInvProperties.getValueByName(ETRow_DebtorReference).String,
									debtorAddress,  //12.12.2020 cnwma1 TFS #50335
									debtorAddress1,	//navtnr20 09-06-2023 Bug 58472
									self.tblInvProperties.getValueByName(ETRow_Terms).CM_InvoiceTermsOfTrade, 	//14/08/2023	navkc1	Bug 59803
									self.tblInvProperties.getValueByName(ETRow_CurrencyType).CM_CurrencyType, 	//14/08/2023	navkc1	Bug 59803
									self.tblInvProperties.getValueByName(ETRow_Locale).CM_Locale				//14/08/2023	navkc1	Bug 59803
									);
									
	runPackage := self.tblInvProperties.getValueByName(ETRow_RunPackage).Boolean;

	while true do
		app.myTrxUA.trxUpdateInvoice(pxyInvoice,app.myPassport);
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			theDataLine := realInvoice.getAttributeStringForDefArray(self.tblData.allTblDataEntRows);
			if self.tblData.findObjectInRow(realInvoice,theRow) then
				self.tblData.accessCell(theRow,1).text := theDataLine;
				if realInvoice.isZeroRatedTax then
					self.tblData.accessedRow.backColor := CM_Invoice.ZeroTaxColour;
				else
					self.tblData.accessedRow.backColor := White;
				endif;	
			endif;
			global.beep;
			self.frmInvProperties.visible := false;
			break;
		else
			theReturn := app.showErrorWarningDialog(app.getErrorString(CM_Update_Invoice), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			return;
		endif;
		break;
	endwhile;
	
	// PAR 34764
	if realInvoice.isPosted
	and  runPackage then
		app.mousePointer := MousePointer_HourGlass;
		
			debtorInvType := realInvoice.debtor.allDebtorInvTypes[realInvoice.invoiceType];
			if debtorInvType &lt;&gt; null then
				foreach package in debtorInvType.allPackageInvoices do
					foreach task in package.allTasks do
						schedule := task.allAutoSchedules.first;
						app.runEventScheduleInvoice(schedule, realInvoice, null);
					endforeach;
				endforeach;
			endif;
	endif;

epilog
	app.mousePointer := MousePointer_Default;
	delete pxyInvoice;
end;</source>
    </JadeMethod>
    <JadeMethod name="doBaseFormSaveVoid" id="ce8dd79b-7a99-4864-b238-bcd9c8ad506e">
        <updating/>
        <source>doBaseFormSaveVoid() updating;
/*

Date		Who		Reason
28 September 2015	cnwer1	Initial creation PAR 36958

*/

vars

begin
	app.mousePointer := MP_HOURGLASS;
	//epr par 36958 24/9/15
	// TFS 39618 PATCH 1 if not app.myCurrentUserCan(self.myTerminal, PmAdmInvoiceStatusVoid) then
	if not self.myCurrentBank.userCanSet(CM_Invoice.INVOICE_VOID) then  // TFS 39618 PATCH 1 

		app.msgBox(app.getErrorString1(VB_SECMOVE,app.getErrorString(Invoice_status_void)) ,
										app.getErrorString(INV_Invoice_Security),
										MsgBox_Exclamation_Mark_Icon + MsgBox_OK_Only);

		return;
	endif;

	if self.myCurrentInvoice.isVoided then
		self.doSaveChangeStatus(CM_Invoice.INVOICE_PENDING);
	else
	
		self.doSaveChangeStatus(CM_Invoice.INVOICE_VOID);
	endif;
epilog
	app.mousePointer := MP_DEFAULT;



end;</source>
    </JadeMethod>
    <JadeMethod name="doBtnExport2FileClick" id="fdd9ef46-905a-4c8c-a3ae-886fb3189cec">
        <source>doBtnExport2FileClick();
// ---------------------------------------------------------------------------
// Created:		March 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// 27 Oct 2016	cnwrs1	TFS allow this directory to be assigned %MiscDir% insrtead of D:\qnsPjmt\server\c_misc
// 02 Nov 2017	cnwma1  TFS #7562 DQM - IFS Financial Interface
// 22 July 2019	cnwma1	ChangeRequest 45577: ASPA - JMT Interface to AR Oracle
// 13 Dec 2019 cnwma1   ChangeRequest 47851: QTS - Integration with Oracle Fusion Cloud
// 7/4/2022  jlier1 	TFS 53286 
vars

	fs:      CMDFileSave;
	finIO:   CM_ExtFinanceIO;
	today:   Date;
	obj : Object;
	selectedInvoices : CM_InvoiceSet;
begin
	if self.myCurrentInvoice = null then
		app.msgBox(app.getErrorString(INV_Please_Select_An_Invoice), app.getErrorString(Error),MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	create fs;
	finIO := self.myTerminal.getConfig(FinancialIOClass).CM_ExtFinanceIO;
	if finIO = null 
	or not global.isValidObject(finIO) then
		create finIO as CM_DefaultFinanceIO transient;
	endif;

	if finIO.isKindOf(CM_ADPInterface) then // PAR 36188
		fs.dialogTitle := app.getErrorString(Specify_folder_invoice_export); // PAR 36188
		fs.resetCurrentPath := true; // PAR 36188
		fs.initDir := finIO.CM_ADPInterface.exportPath.normaliseDirectory().substituteDirectory(); // PAR 36188
		fs.fileName := "InvHead" &amp; today.formatAsYYYYMMDD() &amp; ".csv"; // PAR 36188
	elseif finIO.isKindOf(CM_DPHInterface) then
		fs.dialogTitle := app.getErrorString(Specify_folder_invoice_export);
		fs.resetCurrentPath := true;
		fs.initDir := finIO.CM_DPHInterface.exportPath.normaliseDirectory().substituteDirectory();
		fs.fileName := self.myCurrentInvoice.sequenceNum.String &amp; ".csv";
	elseif finIO.isKindOf(CM_NAVPOE) then
		fs.dialogTitle := app.getErrorString(INV_Specify_File);
		fs.resetCurrentPath := true;
		fs.initDir := finIO.CM_NAVPOE.exportPath.normaliseDirectory().substituteDirectory();
		fs.fileName := "NAVPOE.txt";
	elseif finIO.isKindOf(CM_AccPaccPro) then
		fs.dialogTitle := app.getErrorString(INV_Specify_File);
		fs.resetCurrentPath := true;
		fs.initDir := finIO.CM_AccPaccPro.exportPath.normaliseDirectory().substituteDirectory();
		fs.fileName := "INV" &amp; self.myCurrentInvoice.sequenceNum.String &amp; ".txt";
	elseif finIO.isKindOf(CM_Solomon) then
		fs.dialogTitle := app.getErrorString(INV_Specify_File);
		fs.resetCurrentPath := true;
		fs.initDir := finIO.CM_Solomon.exportPath.normaliseDirectory().substituteDirectory();
		fs.fileName := self.myCurrentInvoice.sequenceNum.String &amp; ".csv";
	elseif finIO.isKindOf(CM_Greentree) then
		fs.dialogTitle := app.getErrorString(INV_Specify_File);
		fs.resetCurrentPath := true;
		fs.initDir := finIO.CM_Greentree.exportPath.normaliseDirectory().substituteDirectory();
		fs.fileName := "INV" &amp; self.myCurrentInvoice.sequenceNum.String &amp; ".txt";
	elseif finIO.isKindOf(CM_GPHAInterface) then // PAR 36631
		fs.dialogTitle := app.getErrorString(INV_Specify_File); // PAR 36631
		fs.resetCurrentPath := true; // PAR 36631
		fs.initDir := finIO.CM_GPHAInterface.exportPath.normaliseDirectory().substituteDirectory(); // PAR 36631
		fs.fileName := self.myCurrentInvoice.sequenceNum.String &amp; ".xml"; // PAR 37040 now XML
	elseif finIO.isKindOf(CM_OracleFinancials) then
		fs.dialogTitle := app.getErrorString(SpecifyFileForHeader);
		fs.resetCurrentPath := true;
		fs.initDir := finIO.CM_OracleFinancials.exportPath.normaliseDirectory().substituteDirectory();
		fs.fileName := "ar_invoice_" &amp; self.myCurrentInvoice.sequenceNum.padLeadingWith('0', 6) &amp; ".csv";
	elseif finIO.isKindOf(CM_STWRInterface) then	//13 Sep 2017	NDL	TFS 6938
		fs.dialogTitle := app.getErrorString(INV_Specify_File);
		fs.resetCurrentPath := true; // PAR 36631
		fs.initDir := finIO.CM_STWRInterface.exportPath.normaliseDirectory().substituteDirectory(); // PAR 36631
		fs.fileName := self.myCurrentInvoice.sequenceNum.String &amp; ".xml"; 
	elseif finIO.isKindOf(CM_DUQMInterface) then					//02.11.2017	cnwma1  TFS #7562
		fs.dialogTitle := app.getErrorString(INV_Specify_File);
		fs.resetCurrentPath := true; 
		fs.initDir := finIO.CM_DUQMInterface.exportPath.normaliseDirectory().substituteDirectory(); 
		fs.fileName := "CUSTOMER_ORDER_CREATE_" &amp; self.myCurrentInvoice.sequenceNum.String.padLeadingZeros(8) &amp; ".xml"; 
	elseif finIO.isKindOf(CM_ASPAInterface) then					//22.07.2019 cnwma1 TFS #45577
		fs.dialogTitle := app.getErrorString(INV_Specify_File);
		fs.resetCurrentPath := true; 
		fs.initDir := finIO.CM_ASPAInterface.exportPath.normaliseDirectory().substituteDirectory(); 
		fs.fileName := finIO.CM_ASPAInterface.getFileNameFormat(self.myCurrentInvoice);
	elseif finIO.isKindOf(CM_QTSInterface) then					//23.12.2019 cnwma1 TFS #47851		
		fs.dialogTitle 		:= app.getErrorString(INV_Specify_File);
		fs.resetCurrentPath := true; 
		fs.initDir  := finIO.CM_QTSInterface.exportPath.normaliseDirectory().substituteDirectory(); 
		fs.fileName := finIO.CM_QTSInterface.getFileNameFormat(self.myCurrentInvoice);
	else
		fs.dialogTitle := app.getErrorString(INV_Specify_File);
		fs.resetCurrentPath := true;
		fs.initDir := finIO.getExportFileNameBase(true);
		fs.fileName :=finIO.getExportFileName(self.myCurrentInvoice,app.actualTimeAppServer);
	endif;
	if fs.open = 0 then
		app.mousePointer := MP_HOURGLASS;
		
		if finIO.isKindOf(CM_SALInterface) and self.tblData.allSelectedObjects.size &gt; 1  then
			create selectedInvoices transient;
			foreach obj in self.tblData.allSelectedObjects discreteLock where obj.isKindOf(CM_Invoice) do
				selectedInvoices.add(obj.CM_Invoice);
			endforeach;
			app.myPassport.clearErrorsWarnings;
			finIO.CM_SALInterface.exportToFileBulk(selectedInvoices,fs.fileName); // jlier1 TFS 53552
			if app.myPassport.hasErrors then
				app.showErrorWarningDialog(app.getErrorString(Error),app.myPassport,ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings );
			endif;
		else
			finIO.exportToFile(self.myCurrentInvoice, fs.fileName);
		endif;
	endif;
	global.beep;

epilog
	delete fs;
	delete selectedInvoices;
	if finIO &lt;&gt; null and finIO.isTransient then
		delete finIO;
	endif;
	app.mousePointer := MP_DEFAULT;

end;</source>
    </JadeMethod>
    <JadeMethod name="doBtnExportClick" id="1d687523-d7ef-4556-8b27-7cd55dea69c6">
        <source>doBtnExportClick();
// ---------------------------------------------------------------------------
// Created:		March 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// 7/4/2022  jlier1 	TFS 53286 
vars
	createdTransient	: Boolean;
	finIO:   CM_ExtFinanceIO;
	obj : Object;
	selectedInvoices : CM_InvoiceSet;
begin
	if self.myCurrentInvoice = null then
		app.msgBox(app.getErrorString(INV_Please_Select_An_Invoice), app.getErrorString(Error),MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	
	if not self.myCurrentInvoice.canBeExported then
		app.msgBox(app.getErrorString2(Not_export_invoic_with_status,self.myCurrentInvoice.sequenceNum.String,self.myCurrentInvoice.getStatusDescriptionForSelf),app.getErrorString(Error),MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
		return;
	endif;

	finIO := self.myTerminal.getConfig(FinancialIOClass).CM_ExtFinanceIO;
	if finIO = null 
	or not global.isValidObject(finIO) then
		create finIO as CM_DefaultFinanceIO transient;
		createdTransient := true;
	endif;

	if finIO &lt;&gt; null then
		app.mousePointer := MP_HOURGLASS;
		//13 Sep 2017	NDL	TFS 6938
		if finIO.isKindOf( CM_STWRInterface ) then	
			foreach obj in self.tblData.allSelectedObjects where obj.isKindOf(CM_Invoice) do
				if obj.CM_Invoice.isPosted then
					finIO.export(obj.CM_Invoice);
				endif;
			endforeach;
		elseif finIO.isKindOf(CM_SALInterface) then
			if self.tblData.allSelectedObjects.size &gt; 1 then
				create selectedInvoices transient;
				foreach obj in self.tblData.allSelectedObjects discreteLock where obj.isKindOf(CM_Invoice) do
					selectedInvoices.add(obj.CM_Invoice);
				endforeach;
				app.myPassport.clearErrorsWarnings;
				finIO.CM_SALInterface.exportBulk(selectedInvoices,app.actualTimeAppServer);
				if app.myPassport.hasErrors then
					app.showErrorWarningDialog(app.getErrorString(Error),app.myPassport,ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings );
				endif;
				
			else
				finIO.export(self.myCurrentInvoice);
			endif;
		else
			finIO.export(self.myCurrentInvoice);
		endif;
		global.beep;
	endif;
epilog
	delete selectedInvoices;
	if createdTransient then
		delete finIO;
	endif;
	app.mousePointer := MP_DEFAULT;
end;</source>
    </JadeMethod>
    <JadeMethod name="doBtnNewClick" id="84dd32c7-80f5-4b96-ab98-072c8399a455">
        <updating/>
        <source>doBtnNewClick() updating;
// ---------------------------------------------------------------------------
// Created:		November 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// 03/10/2022  navpw1 	TFS: 54565 (54384)
// 11 Sep 2023 navhl20 	ChangeRequest 59376: CPL - Invoice Generation Clocking (avg 25 secs)

vars
	form : INV_InvoiceNew;
	
begin
	self.myCurrentInvoice := null;
	//self.showInvoicePropFrame(ETView_InvListInvPropNew); // ### TFS 54565 (54384) 03Oct2022 NAVPW1
	
	// ### TFS 54565 (54384) 03Oct2022 NAVPW1
	form := app.loadForm(INV_InvoiceNew, 
					INV_Assistant, 
					false, 
					false,
					false, 
					self.myTerminal,
					null).INV_InvoiceNew;	
	
	if form = null then
		return;
	endif;
	form.createMyAssistant(INV_Assistant);
	form.setMyCurrentBank(self.myCurrentBank);
	form.includeArchivedVoyages := self.btnIncludeArchive.value;	//11.9.2023 navhl20 #59376
	form.showModal();
	// ### TFS 54565 (54384) 03Oct2022 NAVPW1
	
end;</source>
