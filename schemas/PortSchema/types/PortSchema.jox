    <JadeMethod name="getMySecurityRole" id="8eea098e-9fd7-4a79-984c-ac668545b19c">
        <source>getMySecurityRole() : CM_SecurityRole;
//--------------------------------------------------
// Created:	24 February 2006 By: cnwgd1
//--------------------------------------------------
vars
	tmpUser : CM_User;
	tmpTerm : CM_Terminal;
	tmpUserTerm : CM_UserTerminal;
begin
	tmpUser := self.getMyUser();
	tmpTerm := self.getMyTerminalDO_NOT_USE();
	
	if tmpUser = null
	or tmpTerm = null then
		return null;
	endif;
	
	tmpUserTerm := tmpUser.getUserTerminal(tmpTerm);
	
	if tmpUserTerm &lt;&gt; null then
		return tmpUserTerm.mySecurityRole;
	else
		return null;
	endif;
	
end;</source>
