    <JadeMethod name="cmbContentsCargoType_change" id="730b764b-ace2-480d-aedb-49d46a7efb73">
        <controlMethod name="CMUI_FieldFrame::change"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbContentsCargoType_change(frame: Frame) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 01/10/2025	navdap1		Initial creation MTN-36141 AAT | RotaBox Creation (EDI/API/Manual)
//
vars
	cargoType : CM_CargoType;

begin
	cargoType := self.cmbContentsCargoType.getObject().CM_CargoType;
	if cargoType &lt;&gt; null then
		self.cmbProdType.clear;
		if cargoType.isSubCargoTypeRequired then
			self.cmbProdType.listCollection(cargoType.allProducts, true, ComboBox.DisplayCollection_Forward);
		endif;
		self.cmbCommodity.listCollection(cargoType.allCommodities, true, ComboBox.DisplayCollection_Forward);
	else
		self.cmbProdType.clear;
		self.cmbCommodity.listCollection(app.myRoot.allCommodities, true, ComboBox.DisplayCollection_Forward);
	endif;
epilog

end;</source>
        <Parameter name="frame" type="Frame"/>
    </JadeMethod>
