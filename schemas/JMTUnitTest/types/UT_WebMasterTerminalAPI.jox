	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPutBooking.name, loginJson, incomingJsonString, params, expectFailure);
	
	/*//Input_required_field_cargoId
	incomingJsonString := self.bookingBuildJsonRequest(UTErrBookingRef, UTErrOperatorId, UTErrCargoType1, UTErrHazardCode1, UTErrVoyageCode, null, UTErrCargoType2, UTErrCargoSubType2, UTErrSpecialStow1);
	params := null;
	self.opts.purge();
	self.opts.addAssoc("ExpectedResponse", self.buildResponseMessage(Input_required_field_cargoId));
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPutBooking.name, loginJson, incomingJsonString, params, expectFailure);*/
	
	//Input_required_field_cargoType
	incomingJsonString := self.bookingBuildJsonRequest(UTErrBookingRef, UTErrOperatorId, null, UTErrHazardCode1, UTErrVoyageCode, null, UTErrCargoType2, UTErrCargoSubType2, UTErrSpecialStow1);
	params := null;
	self.opts.purge();
	self.opts.addAssoc("ExpectedResponse", self.buildResponseMessage(Input_required_field_cargoType));
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPutBooking.name, loginJson, incomingJsonString, params, expectFailure);
	
	//Input_Required_Hazard_Code1
	incomingJsonString := self.bookingBuildJsonRequest(UTErrBookingRef, UTErrOperatorId, UTErrCargoType1, null, UTErrVoyageCode, null, UTErrCargoType2, UTErrCargoSubType2, UTErrSpecialStow1);
	params := null;
	self.opts.purge();
	self.opts.addAssoc("ExpectedResponse", self.buildResponseMessage(Input_Required_Hazard_Code1));
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPutBooking.name, loginJson, incomingJsonString, params, expectFailure);
	
	//Err_No_Booking_Found - Param Request - Booking Reference wrong
	incomingJsonString := self.bookingBuildJsonRequest(UTErrBookingRef, UTErrOperatorId, UTErrCargoType1, UTErrHazardCode1, UTErrVoyageCode, null, UTErrCargoType2, UTErrCargoSubType2, UTErrSpecialStow1);
	params := "/Booking/" &amp; UTErrBookingRefNotFound &amp; "/" &amp; UTOperatorId &amp; "/" &amp; UTVoyageCode &amp; "?MasterTerminalAPI";
	self.opts.purge();
	self.opts.addAssoc("ExpectedResponse", self.buildResponseMessage(Err_No_Booking_Found, UTErrBookingRefNotFound));
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPutBooking.name, loginJson, incomingJsonString, params, expectFailure);
	
	//Err_No_Booking_Found - Standard Request - Booking Reference wrong
	incomingJsonString := self.bookingBuildJsonRequest(UTErrBookingRefNotFound, UTErrOperatorId, UTErrCargoType1, UTErrHazardCode1, UTErrVoyageCode, null, UTErrCargoType2, UTErrCargoSubType2, UTErrSpecialStow1);
	params := null;
	self.opts.purge();
	self.opts.addAssoc("ExpectedResponse", self.buildResponseMessage(Err_No_Booking_Found, UTErrBookingRefNotFound));
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPutBooking.name, loginJson, incomingJsonString, params, expectFailure);
	
	//Operator_found
	incomingJsonString := self.bookingBuildJsonRequest(UTErrBookingRef, UTErrOperatorIdNotFound, UTErrCargoType1, UTErrHazardCode1, UTErrVoyageCode, null, UTErrCargoType2, UTErrCargoSubType2, UTErrSpecialStow1);
	params := "/Booking/" &amp; UTErrBookingRef &amp; "/" &amp; UTErrOperatorId &amp; "/" &amp; UTErrVoyageCode &amp; "?MasterTerminalAPI";
	self.opts.purge();
	self.opts.addAssoc("ExpectedResponse", self.buildResponseMessage(Operator_found, UTErrOperatorIdNotFound));
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPutBooking.name, loginJson, incomingJsonString, params, expectFailure);
	
	//Voyage_code_found
	incomingJsonString := self.bookingBuildJsonRequest(UTErrBookingRef, UTErrOperatorId, UTErrCargoType1, UTErrHazardCode1, UTErrVoyageCodeNotFound, null, UTErrCargoType2, UTErrCargoSubType2, UTErrSpecialStow1);
	params := "/Booking/" &amp; UTErrBookingRef &amp; "/" &amp; UTErrOperatorId &amp; "/" &amp; UTErrVoyageCode &amp; "?MasterTerminalAPI";
	self.opts.purge();
	self.opts.addAssoc("ExpectedResponse", self.buildResponseMessage(Voyage_code_found, UTErrVoyageCodeNotFound));
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPutBooking.name, loginJson, incomingJsonString, params, expectFailure);
	
	//Tranship_voyage_code_invalid
	incomingJsonString := self.bookingBuildJsonRequest(UTErrBookingRef, UTErrOperatorId, UTErrCargoType1, UTErrHazardCode1, UTErrVoyageCode, UTErrVoyageCodeNotFound, UTErrCargoType2, UTErrCargoSubType2, UTErrSpecialStow1);
	params := null;
	self.opts.purge();
	self.opts.addAssoc("ExpectedResponse", self.buildResponseMessage(Tranship_voyage_code_invalid, UTErrVoyageCodeNotFound));
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPutBooking.name, loginJson, incomingJsonString, params, expectFailure);
	
	//Cargo_Type_Not_Found
	incomingJsonString := self.bookingBuildJsonRequest(UTErrBookingRef, UTErrOperatorId, UTErrCargoTypeNotFound1, UTErrHazardCode1, UTErrVoyageCode, null, UTErrCargoType2, UTErrCargoSubType2, UTErrSpecialStow1);
	params := null;
	self.opts.purge();
	self.opts.addAssoc("ExpectedResponse", self.buildResponseMessage(Cargo_Type_Not_Found, UTErrCargoTypeNotFound1));
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPutBooking.name, loginJson, incomingJsonString, params, expectFailure);
	
	//Cargo_SubType_Not_Found_CType
	incomingJsonString := self.bookingBuildJsonRequest(UTErrBookingRef, UTErrOperatorId, UTErrCargoType1, UTErrHazardCode1, UTErrVoyageCode, null, UTErrCargoType2, UTErrCargoSubTypeNotFound2, UTErrSpecialStow1);
	params := null;
	self.opts.purge();
	self.opts.addAssoc("ExpectedResponse", self.buildResponseMessage(Cargo_SubType_Not_Found_CType, UTErrCargoSubTypeNotFound2, UTErrCargoType2));
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPutBooking.name, loginJson, incomingJsonString, params, expectFailure);
	
	//Special_stow_not_found
	incomingJsonString := self.bookingBuildJsonRequest(UTErrBookingRef, UTErrOperatorId, UTErrCargoType1, UTErrHazardCode1, UTErrVoyageCode, null, UTErrCargoType2, UTErrCargoSubType2, UTErrSpecialStowNotFound1);
	params := null;
	self.opts.purge();
	self.opts.addAssoc("ExpectedResponse", self.buildResponseMessage(Special_stow_not_found, UTErrSpecialStowNotFound1));
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPutBooking.name, loginJson, incomingJsonString, params, expectFailure);
	
	//Hazard_code_not_found
	incomingJsonString := self.bookingBuildJsonRequest(UTErrBookingRef, UTErrOperatorId, UTErrCargoType1, UTErrHazardCode1NotFound1, UTErrVoyageCode, null, UTErrCargoType2, UTErrCargoSubType2, UTErrSpecialStow1);
	params := null;
	self.opts.purge();
	self.opts.addAssoc("ExpectedResponse", self.buildResponseMessage(Hazard_code_not_found, UTErrHazardCode1NotFound1));
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPutBooking.name, loginJson, incomingJsonString, params, expectFailure);
	
	// Unauthorized - Username / Password not OK
	loginJson := BadLogin;
	params := null;
	self.opts.purge();
	self.opts.addAssoc("ExpectedResponse", "401 Unauthorized - Username / Password not OK");
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPutBooking.name, loginJson, incomingJsonString, params, expectFailure);
	
epilog
	delete pxyBooking;
	delete utHelperTerminal;
	app.writeLog("Changing MaxLiftWeightWarnOnly Terminal Config to false", LogINFO);
	app.writeLog("Changing IsSubTerminalsOn Terminal Config to true", LogINFO);
	self.setTerminalConfig(MaxLiftWeightWarnOnly, false);
	self.setTerminalConfig(IsSubTerminalsOn, true);
	
end;</source>
    </JadeMethod>
