    <JadeMethod name="btnUnits_click" id="aaace57d-5199-4ddd-91bc-30d273900025">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnUnits_click(btn: Button input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 July 2012	cnwndl1	Initial creation	Par 29968

*/

vars

	form : INV_ProformaCritTrxUnitsForm;
	selectedTrxTypes : CM_TransactionTypeByType;
	trxType : CM_TransactionType;

begin

	create selectedTrxTypes transient;
	self.mulTransactions.getSelected( selectedTrxTypes );

	if self.myProformaTransactionCriteria = null or selectedTrxTypes.isEmpty then
		app.msgBox(app.getErrorString(Please_save_changes_first), app.getErrorString(Warning), MsgBox_OK_Only + MsgBox_Stop_Icon );
		return;
	endif;
	
	if self.myProformaTransactionCriteria.allTransactionTypes.size &lt;&gt; selectedTrxTypes.size then
		app.msgBox(app.getErrorString(Please_save_changes_first), app.getErrorString(Warning), MsgBox_OK_Only + MsgBox_Stop_Icon );
		return;
	endif;
	
	foreach trxType in self.myProformaTransactionCriteria.allTransactionTypes do
		if not selectedTrxTypes.includes( trxType ) then
			app.msgBox(app.getErrorString(Please_save_changes_first), app.getErrorString(Warning), MsgBox_OK_Only + MsgBox_Stop_Icon );
			return;
		endif;
	endforeach;
	

	form := app.loadForm(INV_ProformaCritTrxUnitsForm, INV_Assistant, false, false, false, self.myTerminal, null).INV_ProformaCritTrxUnitsForm;
	if form = null then
		return;
	endif;

	form.setReferences( self.myProformaTransactionCriteria );
	form.showModal();
	
	
epilog

	delete selectedTrxTypes;

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doHookCode" id="708e1507-e83c-4ef8-9162-d86df2ecc5d2">
        <updating/>
        <source>doHookCode() protected, updating;
// 34917 CCMS GPHA 2368 more cash features - pro forma hook code here
vars
	hookType	: CM_HookType;
	calcType 	: CM_CalculationType;
	isOK : Boolean;
	source		: String;
	constantText	: String;
	methodName	: String;
	parentClass	: Class;
	formCaption	: String;
begin

	hookType := app.myRoot.allHookTypes[HookType_CashProForma];
	if hookType = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Hook Type is null for pro forma transactions.');
		return;
	endif;

	if self.myProformaTransactionCriteria &lt;&gt; null then
		formCaption := " Current Criteria ";
	else
		formCaption := " New Criteria";
	endif;
	
	source := self.hookSource;
	constantText := app.getGlobalConstantText(HookTypes, "HookType_CashProForma");
	methodName := constantText.cnEcGetTagValueOfName('hookMethodName');
	parentClass := rootSchema.getSchema(PortSchemaName).getClass(constantText.cnEcGetTagValueOfName('hookClassType'));
	
	isOK := app.showHookCodeMaintForm2(hookType, source, false, methodName, parentClass, formCaption, true);
	if isOK then
		self.hookSource := source;
	endif;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doOK" id="c68ea769-37f5-4dd5-8849-1b6b8105f03c">
        <updating/>
        <source>doOK(): Boolean updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 July 2012	cnwndl1	Initial creation

*/

vars

	propCount : Integer;
	index : Integer;
	criteriaFrame : CMUI_YACriteriaCntl;
	criteriaType : CM_YACriteriaType;
	proxyCriteria: CM_YACriteria;
	itemCode : String;
	value : Any;
	cmifCriteria : CMIF_YACriteriaPriority;
	criterias: CMIF_Array;
	selectedTrxTypes : CM_TransactionTypeByType;
	priority : Integer;
	proxy : CM_ProformaTransactionCriteria;
	ls : Boolean;
	theReturn : Integer;

begin

	propCount := self.allSelectedCriteriaTypes.size;
	create criterias transient;
	
	foreach index in 1 to propCount do
		criteriaFrame := self.frmCriteria.getControl(index).CMUI_YACriteriaCntl;
		criteriaType := criteriaFrame.getCriteriaType();
		if criteriaType &lt;&gt; null and criteriaFrame.hasValue() then
			create proxyCriteria transient;
			itemCode := criteriaType.description.cnEcUpto(CM_YACriteriaPriority::code.length -1);
			//epr TFS 1822 28/4/16
			value := criteriaFrame.getValue();
			
			proxyCriteria.setProxy(criteriaType, value, itemCode);
			cmifCriteria := proxyCriteria.getTransient();
			criterias.add(cmifCriteria);
		endif;
	endforeach;
	
	create selectedTrxTypes transient;
	self.mulTransactions.getSelected( selectedTrxTypes );
	
	if selectedTrxTypes.isEmpty then
		app.msgBox(app.getErrorString(Selecte_transat_list_empty), app.getErrorString(Error), MsgBox_OK_Only);
		return false;
	endif;
	if criterias.isEmpty then
		app.msgBox(app.getErrorString(No_Criteria_values_selected), app.getErrorString(Error), MsgBox_OK_Only);
		return false;
	endif;
	
	app.cmsBeginLoad(ls);
	if self.myProformaTransactionCriteria = null then
		create proxy transient;
	else
		proxy := self.myProformaTransactionCriteria.pxyCreateUpdateProxy().CM_ProformaTransactionCriteria;
	endif;
	// 34917 add hook code parameters
	proxy.setProxy( criterias, selectedTrxTypes, priority, self.myBank, self.hookSource, app.myPassport.userCode, null, null, null, CM_ProformaTransactionCriteria.TypeCargo );
	app.cmsEndLoad(ls);

	while true do
		if self.myProformaTransactionCriteria = null then
			app.myTrxCA.trxCreateProformaCriteria(proxy, self.myProformaTransactionCriteria, app.myPassport);
		else
			app.myTrxUA.trxUpdateProformaCriteria(proxy, app.myPassport);
		endif;
		
		if app.myPassport.trxCompletedOK then
			self.clearErrorWarnings();
			if self.myBankProformaPropsForm &lt;&gt; null then
				self.myBankProformaPropsForm.populateAttributes();
			endif;
			return true;
		else
			theReturn := app.showErrorWarningDialog(app.getErrorString(Proforma_criteria), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			return false;
		endif;
		break;
	endwhile;
	
	return false;

epilog

	if criterias &lt;&gt; null and not criterias.isEmpty then
		// delete the proxies
		criterias.purge();
	endif;
	delete criterias;
	delete selectedTrxTypes;
	delete proxy;
	app.cmsEndLoad(ls);

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getTranTypeName" id="2bdee0a8-5876-475f-8266-f89586231617">
        <source>getTranTypeName( tType : CM_TransactionType ):String;

/*

Purpose:			

