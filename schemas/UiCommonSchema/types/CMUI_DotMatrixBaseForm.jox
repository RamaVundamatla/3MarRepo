    <JadeMethod name="getParamValues" id="e0531c18-ca76-4240-bd23-6e43f358dfe6">
        <source>getParamValues( _inputString : String;
				_outputType : String io;
				_baseLeftOffset : String io;
				_baseTopOffset : String io;
				_fontSize : String io;
				_fontName : String io;
				_printerName : String io;
				_error : Boolean io
				);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 November 2012	cnwndl1	Initial creation

*/

vars

	pos1 : Integer;
	pos2 : Integer;
	pos3 : Integer;
	workStr : String;
	count : Integer;

begin

	pos1 := 1;
	while true do
		pos2 := _inputString.pos("?", pos1);
		if pos2 &gt; 0 then
			pos3 := _inputString.pos("?", pos2+1);
			if pos3 &gt; 0 then
				workStr := _inputString[pos2+1:pos3-pos2-1];
			elseif pos2 &lt; _inputString.length then
				workStr := _inputString[pos2+1:end];
			endif;
			count := count + 1;
		else
			break;
		endif;
		pos1 := pos2 + 1;
		if count = 1 then
			_outputType := workStr;
		elseif count = 2 then
			if workStr &lt;&gt; null then
				if not workStr.isInteger then
					_error := true;
					_baseLeftOffset := workStr &amp; " " &amp; app.getErrorString(Error_must_numeric);
				else
					_baseLeftOffset := workStr;
				endif;
			endif;
		elseif count = 3 then
			if workStr &lt;&gt; null then
				if not workStr.isInteger then
					_error := true;
					_baseTopOffset := workStr &amp; " " &amp; app.getErrorString(Error_must_numeric);
				else
					_baseTopOffset := workStr;
				endif;
			endif;
		elseif count = 4 then
			if workStr &lt;&gt; null then
				if not workStr.isInteger then
					_error := true;
					_fontSize := workStr &amp; " " &amp; app.getErrorString(Error_must_numeric);
				else
					_fontSize := workStr;
				endif;
			endif;
		elseif count = 5 then
			_fontName := workStr;
		elseif count = 6 then
			_printerName := workStr;
		else
			break;
		endif;
	endwhile;

epilog

end;</source>
        <Parameter name="_inputString" type="String"/>
        <Parameter name="_outputType" type="String" usage="io"/>
        <Parameter name="_baseLeftOffset" type="String" usage="io"/>
        <Parameter name="_baseTopOffset" type="String" usage="io"/>
        <Parameter name="_fontSize" type="String" usage="io"/>
        <Parameter name="_fontName" type="String" usage="io"/>
        <Parameter name="_printerName" type="String" usage="io"/>
        <Parameter name="_error" type="Boolean" usage="io"/>
    </JadeMethod>
    <JadeMethod name="handle1035" id="83c789b9-f186-4c0e-b985-66a03249d7c9">
        <source>handle1035( _exc : Exception; _wordError : Boolean output ):Integer protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 November 2012	cnwndl1	Initial creation

*/

vars
	returnVal		: Integer;
	
begin
	returnVal := Ex_Pass_Back;
	
	
	if _exc.errorCode = 1035 then
		_wordError := true;
		if _exc.resumable then
			returnVal := Ex_Resume_Next;
		endif;
	endif;


epilog

	return returnVal;

end;</source>
        <access>protected</access>
        <Parameter name="_exc" type="Exception"/>
        <Parameter name="_wordError" type="Boolean" usage="output"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="initiateForm" id="c3ebf958-9197-4e30-8283-a48dd969629e">
        <updating/>
        <source>initiateForm( _baseLeftOffset : Integer; _baseTopOffset : Integer ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 November 2012	cnwndl1	Initial creation	Par 30682

*/

vars

	obj : Object;
	label : CMUI_Label;
	fontSize : Real;
	fontName : String;

begin
	
	self.testFrame.height := (self.getPageHeight / 10) * self.pixelsPerMM;

	self.baseLeftOffset := _baseLeftOffset;
	self.baseTopOffset := _baseTopOffset;
	
	self.height	:= self.testFrame.height + self.testFrame.top + 25;
	self.width	:= self.testFrame.width + self.testFrame.left + 25;
	
	//Moved from 'create' as part of Par 33181 NDL 05 Feb 2014
	self.allLabelsArray.clear();
	self.makeLabelsAvailable();

	// set the base details on the labels we are using
	foreach obj in self.allLabelsArray do
		label := obj.CMUI_Label;
		label.caption := null;
		label.visible := true;
		label.fontName := fontName;
		label.fontSize := fontSize;
	endforeach;
	
	self.repositionLabels();

epilog

end;</source>
        <Parameter name="_baseLeftOffset" type="Integer"/>
        <Parameter name="_baseTopOffset" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="makeLabelsAvailable" id="693cb473-d1f0-47d8-a199-59c2a3d23faf">
        <source>makeLabelsAvailable() protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 November 2012	cnwndl1	Initial creation	Par 30682

*/

vars

begin

	//The labels you want to be able to use in this report.  re-implement.

/*	self.allLabelsArray.add( self.lblA );
	self.allLabelsArray.add( self.lblB );
