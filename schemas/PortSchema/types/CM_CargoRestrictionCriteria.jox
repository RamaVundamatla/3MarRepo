    <JadeMethod name="setForUpdate" id="4c2ebe8c-5fc4-4f2a-b9e5-fae68508a697">
        <updating/>
        <source>setForUpdate(_proxy: CM_CargoRestrictionCriteria) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 February 2014	cnwndl1	Initial creation	Par 33439

*/

vars

	wagon : CM_Wagon;

begin

	self.colour := _proxy.colour;
	self.myTerminal := _proxy.myTerminal;
	self.myWagonMaster := _proxy.myWagonMaster;
	
	inheritMethod(_proxy);
	
	if not self.isTransient then
		wagon := self.myTerminal.getCurrentWagonByID( self.myWagonMaster.id );
		if wagon &lt;&gt; null then
			app.myEventManager.createSingleObjInfoNoteEvt(wagon, self.myTerminal.getTerminalEvent(Wagon_Update_Event), wagon);
		endif;
	endif;

epilog

end;</source>
        <Parameter name="_proxy" type="CM_CargoRestrictionCriteria"/>
    </JadeMethod>
    <JadeMethod name="setProxyBaseData" id="0bc50745-f7a9-4f5e-adad-d8c46e7f4713">
        <updating/>
        <source>setProxyBaseData( _colour : Integer; _myWagonMaster : CM_WagonMaster; _myTerminal : CM_Terminal ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 February 2014	cnwndl1	Initial creation

*/

vars

begin

	self.colour := _colour;
	self.myTerminal := _myTerminal;
	self.myWagonMaster := _myWagonMaster;

epilog

end;</source>
        <Parameter name="_colour" type="Integer"/>
        <Parameter name="_myWagonMaster" type="CM_WagonMaster"/>
        <Parameter name="_myTerminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="validateMe" id="2c2e8b3a-1dd9-4189-853c-b16207966ddc">
        <source>validateMe();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 February 2014	cnwndl1	Initial creation	Par 33439

*/

vars

begin

	if self.myTerminal = null then
		app.raiseCMException(Terminal_reference_set, null, null);
	endif;
	
	if self.myWagonMaster = null then
		app.raiseCMException(Wagon_master_selected, null, null);
	endif;
	
	if self.colour = 0 then
		app.raiseCMWarning(No_colour_selected, null, null,self);
	endif;
	
	inheritMethod();

epilog

end;</source>
    </JadeMethod>
</Class>
