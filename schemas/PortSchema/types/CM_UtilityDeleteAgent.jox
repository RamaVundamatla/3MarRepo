    <JadeMethod name="utlDeleteShift" id="23e7756e-4f77-48f3-bb7f-d694413fe980">
        <source>utlDeleteShift(pShift : CM_ShiftEntity; _passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:     08 May 2007 by cnwyl1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	toDelete : CM_ShiftEntity;
	tmpTerm : CM_Terminal;
begin

	self.initialiseActivity();

	if pShift = null then
		app.raiseCMException1(ERR_DEL_NULLOBJECT, 'Worker Shift', null, null);
		return;
	endif;
	toDelete := pShift;
	tmpTerm := toDelete.getMyTerminal();
	
	if not self.exclusiveLockObjectToDelete(toDelete) then
	    // toDelete is null, invalid or has already been deleted
	    return;
	endif;

	if _passport.noErrors then
		self.myDeleteAuditAgent.audDeleteGeneric(toDelete);
		if tmpTerm &lt;&gt; null then
			toDelete.causeEvent(tmpTerm.getTerminalEvent(Event_Shift_Delete), false, null);
		endif;
	endif;

	if _passport.noErrors then
		toDelete.erase(NORMAL_ERASE);
	endif;
	

end;
</source>
        <Parameter name="pShift" type="CM_ShiftEntity"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
