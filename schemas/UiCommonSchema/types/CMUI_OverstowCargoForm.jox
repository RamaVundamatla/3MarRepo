    <JadeMethod name="doContextMenuBuild" id="d56baf7f-87c4-4a6c-84cd-1fb1989f30b1">
        <source>doContextMenuBuild();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 November 2009	cnwphb1	Initial creation

*/

vars
	
begin
	self.mnuContextTIEdit.visible		:= true;
	self.mnuContextTIEnquire.visible	:= true;
	self.mnuContextLocate.visible		:= false;
	self.mnuLoadListPlanLoad.visible	:= false;
	self.mnuLLLocateGridArea.visible	:= true;
	self.mnuContextShowOverstow.visible	:= false;
	self.mnuContextMoveOverstow.visible	:= true;
	self.mnuLLReadyToShip.visible		:= false;
	self.mnuLLUnplan.visible			:= false;
	self.mnuContextSep01.visible		:= true;
	self.mnuContextColourLegend.visible	:= false;
	
	self.mnuSummarise.visible			:= false;	// Default this menu level to invisible, makes sub-menu invisible.
end;</source>
    </JadeMethod>
    <JadeMethod name="doEdit" id="e45e1374-4788-433b-886d-6667c10ca55d">
        <updating/>
        <source>doEdit() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 November 2009	cnwphb1	Initial creation

*/

vars
	objArray	: ObjectArray;
begin
	if self.tblData.row &lt; self.tblData.fixedRows then
		return;
	endif;
	
	create objArray transient;
	
	self.tblData.allSelectedObjects.copy(objArray);
	
	if objArray.isEmpty then
		return;
	endif;
	
	if objArray[1].isKindOf(CM_TrackedItem) then
		self.myAssistant.showCargoEnquiryForTIs(objArray[1].CM_TrackedItem, objArray, self.myMasterMenuAction, true);
	endif;
epilog
	delete objArray;
end;</source>
    </JadeMethod>
