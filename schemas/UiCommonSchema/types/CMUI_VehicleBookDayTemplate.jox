    <JadeMethod name="doClickDefault" id="6de8f0a8-237c-4d35-aece-014de27ca245">
        <source>doClickDefault();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 April 2013	cnwndl1	Initial creation

*/

vars

begin

	if self.chkIsDefault.value then
		self.txtName.enabled := false;
		self.txtName.text := app.getErrorString(Default);
		self.cmbCalendar.enabled := false;
		self.cmbCalendar.listIndex := -1;
		self.txtPriority.enabled := false;
		self.txtPriority.text := "999";
		
	else
		self.txtName.enabled := true;
		self.cmbCalendar.enabled := true;
		self.txtPriority.enabled := true;
		if self.myDayTemplate = null then
			self.txtName.text := null;
			self.cmbCalendar.listIndex := -1;
			self.txtPriority.text := null;
		else
			self.txtName.text := self.myDayTemplate.name;
			self.cmbCalendar.listIndex := self.cmbCalendar.findObject( self.myDayTemplate.myCalendar );
			self.txtPriority.text := self.myDayTemplate.priority.String;
		endif;
		
	endif;
	
	if self.myDayTemplate &lt;&gt; null then
		self.chkIsDefault.enabled := false;
	endif;
	
	

epilog

end;</source>
    </JadeMethod>
