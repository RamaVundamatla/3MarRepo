	sa.add('cp124_CN_lstTest_click');
	sa.add('cp126_CN_lstTest_dblClick');
	sa.add('cp128_YLEF_cmbFiltTATypclick');
	sa.add('cp130_YLEF_cmbFiltTermAclick');
