    <JadeMethod name="validateForDelete" id="c1d65669-805b-468b-93e3-1f95d02f40b5">
        <source>validateForDelete();
//--------------------------------------------------------------
//Created: 22 January 2002 By: cnwgd1	CANNOT DELETE DOCKETS
//--------------------------------------------------------------

// 08/12/2014 cnwdb2 PAR 35364
vars

begin

	if self.allTrackedItems.size &gt; 0 then
		app.raiseCMException2(ObjectStillHasEntries, bolTypeDesc &amp; ' ' &amp; self.number.String, app.getErrorString(Cargo), null, self);
	endif;

//	app.raiseCMWarning2(CONF_DELETE, 'Docket/Bill of Lading ', self.number.String, null, null, self);
	
	app.raiseCMWarning1(Sure_want_delete35364, self.number.String, null, null, self); // PAR 35364

end;</source>
