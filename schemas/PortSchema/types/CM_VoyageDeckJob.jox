    <JadeMethod name="setForCreateSlotRequests" id="199713dd-3056-4cce-aec5-f9ca024d405d">
        <updating/>
        <source>setForCreateSlotRequests(_theJobParams: CMIF_VoyageJobParams input; _passport: CM_Passport input) updating, protected;
/*
Date		Who		Reason
03 Aug 2011	cnwer1	Initial creation CCMS MES 1033
30 Aug 2012	cnwcs5	par 30292 - use updateObjectEdition instead of updateEdition 
*/

vars
	newVJob : CM_VoyageJob;
	doAutoJobCreate ,
	autoLinkSlotJobCreateSOB,
	autoLinkSlotJobCreate: Boolean;
	roroSlotRequest : CM_RORORequest;
	roroSlotController : CM_VoyageROROController;
	theTIs	: CM_TIArray;
	theTI : CM_TrackedItem;
	theVoyage : CM_Voyage;
	theTerminal : CM_Terminal;
begin

	if _theJobParams.allRORORequests.isEmpty then
		return;
	endif;
	
	theVoyage := _theJobParams.myVoyage;
	theTerminal := theVoyage.myTerminal;

	// PAR 29164
	if _theJobParams.usedByOOWCreation then 
		autoLinkSlotJobCreate := false;
	else
		autoLinkSlotJobCreate := theTerminal.getConfig(AutoLinkSlotJobCreate).Boolean;
	endif;
	autoLinkSlotJobCreateSOB := theTerminal.getConfig(AutoLinkSlotJobCreateSOB).Boolean;
	
	create theTIs transient;
	// need to link the RORO slot requests
	foreach roroSlotRequest in _theJobParams.allRORORequests do
		roroSlotRequest.setJob(self);
		roroSlotRequest.createWLEs();
		
		
		// PAR 29164
		if roroSlotRequest.isSOB then
			doAutoJobCreate := autoLinkSlotJobCreateSOB;
		elseif roroSlotRequest.isRehandle then
			doAutoJobCreate := autoLinkSlotJobCreate;
		else
			doAutoJobCreate := false;
		endif;
		// if this baby is linked to another request, cos of DLR and SOB, then add this into the job as well
		if doAutoJobCreate then
			self.setForCreateVoyageCheckLinked(newVJob,_theJobParams,roroSlotRequest,_passport);
		endif;	
			
		
		
		
		
		// ################################
		// This will update the display on screen of this slot
		roroSlotController := roroSlotRequest.myROROController;
		
		self.updateObjectEdition (roroSlotController);		// par 30292
		
		app.myEventManager.createSingleObjInfoNoteEvt(
								theVoyage,
								theTerminal.getTerminalEvent(EVENT_UPDATE_VOYAGE_AREA),
								roroSlotController);
		
			// attach the the cargo to us
		roroSlotRequest.getAllTrackedItems(theTIs);	// this clears the array
	
		foreach theTI in theTIs do
			if theTI &lt;&gt; null then
				self.updateTICollections(theTI, null);// 01/04/2010 cnwcs5 par 23383
				
				if self.isExportReturn then
					theTI.setImExStatus(TI_IMEX_STATUS_EXPORT);
				endif;
			endif;
		endforeach;
	endforeach;
	
	// We have auto created a linked job so it needs some basic setting up after  adding requests and TIs
	if doAutoJobCreate and newVJob &lt;&gt; null then
// 30342 do not need this for RORO				newVJob.setRequestSeqNumbers(_theJobParams);
		if newVJob.remarks = null then
			newVJob.remarks := newVJob.getAutoRemarks();
		endif;
	endif; 
	
epilog
	delete theTIs;

end;</source>
        <access>protected</access>
        <Parameter name="_theJobParams" type="CMIF_VoyageJobParams" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setForCreateVoyageCheckLinked" id="6d5549b7-2aa5-4e1e-8093-942c84fd6110">
        <updating/>
        <source>setForCreateVoyageCheckLinked(_newVJob : CM_VoyageJob io;_theJobParams:CMIF_VoyageJobParams;_theSlotReq : CM_RORORequest;_passport : CM_Passport input) updating;
/*
Purpose:			
Date				Who			Reason
FEB 2012		CNWAB1		Initial creation
*/


vars
	 aLinkedSlotReq, theSlotReq : CM_Request;
	theJobID : String;
	theBay : CM_Bay;
	theOrdinalDeck,theJobType : Integer;
	theProxyVJob : CM_VoyageJob;
	theJobParams : CMIF_VoyageJobParams;
	aRealVJob : CM_VoyageJob;
	theTIs : CM_TIArray;
	theTI : CM_TrackedItem;
begin
	
	// if this baby is linked to another request, cos of DLR and SOB, then add this into the job as well
	aLinkedSlotReq := _theSlotReq.getDLRSOBRequestLink();
	if aLinkedSlotReq &lt;&gt; null then
		// this req is linked to our DLR and has no job so create a auto job for it
		if aLinkedSlotReq.myJob = null then
			if _theSlotReq.isRehandle then
	
				if _newVJob = null then
					create theJobParams transient;
					create theProxyVJob transient;
// PAR 28968					if aLinkedSlotReq.isDischarge then
					if not aLinkedSlotReq.isReleaseType then
						theJobType :=JOB_TYPE_DISCHARGE; 
					else
						theJobType := JOB_TYPE_LOAD;
					endif;
					theProxyVJob.setProxy(_theJobParams.jobNumLinkedLoad, theJobType); 
					theJobParams.myVoyage := self.myVoyage;
					theJobParams.myProxyJob := theProxyVJob;
					theJobParams.craneID := _theJobParams.craneID;
					theProxyVJob.setProxyVoyage(theJobParams.myVoyage);
					app.myUtilityCA.utlCreateVoyageJob(theJobParams, aRealVJob, _passport);
					_newVJob := aRealVJob;
	
				endif;
	
				aLinkedSlotReq.setJob(_newVJob);
				aLinkedSlotReq.createWLEs();
				// attach the TIS to the new auto  created job
				create theTIs transient;
				// this is auto linking stuff. If this is a discharge linking to the load then get the discharge's TIs and attach them to the load job
				theSlotReq := _theSlotReq;
				theSlotReq.getAllTrackedItems(theTIs);
				foreach theTI in theTIs do
					if theTI &lt;&gt; null then
						_newVJob.updateTICollections(theTI, null);	// 01/04/2010 cnwcs5 par 23383
					endif;
				endforeach;
				delete theTIs;
				_newVJob.setRemarks(null); // pass in null will get auto remarks
	
			// THIS WILL BE SOBs
			else
				aLinkedSlotReq.setJob(self);
				aLinkedSlotReq.createWLEs();
			endif;
			// ################################
			// This will update the display on screen of this slot
// PAR 28968			aLinkedSlotReq.myROROController.myVoyage.causeEvent(_passport.myTerminal.getTerminalEvent(EVENT_UPDATE_VOYAGE_AREA), false, aLinkedSlotReq.myROROController);
			aLinkedSlotReq.getVoyage().causeEvent(_passport.myTerminal.getTerminalEvent(EVENT_UPDATE_VOYAGE_AREA), false, aLinkedSlotReq.getLC());
		endif;
	endif;
epilog
	delete theProxyVJob;
	delete theJobParams;
	delete theTIs;
end;</source>
        <Parameter name="_newVJob" type="CM_VoyageJob" usage="io"/>
        <Parameter name="_theJobParams" type="CMIF_VoyageJobParams"/>
        <Parameter name="_theSlotReq" type="CM_RORORequest"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setForUpdateSlotRequests" id="8e581076-d980-4ce2-a55e-04ed7f5da7c4">
        <updating/>
        <source>setForUpdateSlotRequests(_theJobParams: CMIF_VoyageJobParams input; _passport: CM_Passport input) updating, protected;
/*
Date		Who		Reason
03 Aug 2011	cnwer1	Initial creation CCMS MES 1033
30 Aug 2012	cnwcs5	par 30292 - use updateObjectEdition instead of updateEdition 
*/

vars

	aReq : CM_Request;
	aSlotReq : CM_RORORequest;
	tmpSlotController	: CM_VoyageROROController;
	voyageUpdateEvent	: Integer;
	theTI : CM_TrackedItem;
	theTIs : CM_TIArray;
	isLoad : Boolean;
begin

	voyageUpdateEvent := self.myTerminal.getTerminalEvent(EVENT_UPDATE_VOYAGE_AREA);
	aSlotReq := _theJobParams.allRORORequests.first;
	if aSlotReq &lt;&gt; null then
		isLoad :=  aSlotReq.isLoad;
	endif;
		// clear out allthe requests
	foreach aReq in self.allRequests do
		aSlotReq := aReq.CM_RORORequest;
		if aSlotReq.isLoad = isLoad then // only clear out of same type
			if not _theJobParams.allRORORequests.includes(aSlotReq) then
				aSlotReq.setJob(null);

				// ################################
				// This will update the display on screen of this slot
				tmpSlotController := aSlotReq.myROROController;
				
				self.updateObjectEdition (tmpSlotController);	// par 30292
				self.myVoyage.causeEvent(voyageUpdateEvent, false, tmpSlotController);
			endif;
		endif;
	endforeach;
	
	create theTIs transient;
	foreach aSlotReq in _theJobParams.allRORORequests do
		if not self.allRequests.includes(aSlotReq) then
			aSlotReq.setJob(self);
			// ################################
			// This will update the display on screen of this slot
			tmpSlotController := aSlotReq.myROROController;
			
			self.updateObjectEdition (tmpSlotController);	// par 30292
			self.myVoyage.causeEvent(voyageUpdateEvent, false, tmpSlotController);
		endif;
		// attach the the cargo to us
		aSlotReq.getAllTrackedItems(theTIs);
		foreach theTI in theTIs do
			if theTI &lt;&gt; null then
				self.updateTICollections(theTI, null);// 01/04/2010 cnwcs5 par 23383
			endif;
		endforeach;
	endforeach;

epilog
	delete theTIs;

end;</source>
        <access>protected</access>
        <Parameter name="_theJobParams" type="CMIF_VoyageJobParams" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setRequestSeqNumbers" id="6c2d3998-fbf9-4246-a529-e5ab211dd646">
        <updating/>
        <source>setRequestSeqNumbers(_theJobParams: CMIF_VoyageJobParams) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
05 August 2011	cnwer1	Initial creation CCMS MES 1033

*/

vars
	allROROSlotLCSorted : CM_ROROSlotLCsByOrdDict;
	request : CM_Request;
	lc : CM_VoyageROROController;
	voyageRequest : CM_RORORequest; // PAR 28349
	index  : Integer;
	deck	: CM_Deck;
begin
	
	if self.myDeck = null then
		return;
	endif;
	
	if _theJobParams = null then
		return;
	endif;
	create allROROSlotLCSorted transient;

	if  _theJobParams.usedByOOWCreation then
		foreach request in self.allRequests do
			if not request.isKindOf(CM_ROROSlotRequest) then
				break;
			endif;
			voyageRequest:=request.CM_ROROSlotRequest;
			allROROSlotLCSorted.add(voyageRequest.myROROController.CM_ROROSlotController);
		endforeach;
		
		if allROROSlotLCSorted.isEmpty then
			return;
		endif;
		foreach request in self.allRequests do
			voyageRequest:=request.CM_ROROSlotRequest;
			index:=allROROSlotLCSorted.indexOf(voyageRequest.myROROController.CM_ROROSlotController);
			voyageRequest.setSeqNumber(index, true);
		endforeach;
		foreach request in self.allRequests reversed do
			voyageRequest:=request.CM_ROROSlotRequest;
			index:=allROROSlotLCSorted.indexOf(voyageRequest.myROROController.CM_ROROSlotController);
			voyageRequest.setSeqNumber(index, false);
		endforeach;
	else
		// RESET TO ZERO. This is a request set so ordered by OID
		foreach request in self.allRequests reversed do
 // PAR 28349			if not request.isKindOf(CM_ROROSlotRequest) then
 // PAR 28349				continue;
 // PAR 28349			endif;
			voyageRequest:=request.CM_RORORequest; // PAR 28349
			voyageRequest.setSeqNumber(0, true);
			voyageRequest.setSeqNumber(0, false);
		endforeach;
		
		// NUMBER FOR AFT
		index := 0;
		foreach lc in _theJobParams.allROROControllers discreteLock do
			if self.isDischarge or self.jobType = JOB_TYPE_SOB then // PAR 28334
				request := lc.myRORORequestDischarge;
			else
				request := lc.myRORORequestLoad;
			endif;
 // PAR 28349			if not request.isKindOf(CM_ROROSlotRequest) then
 // PAR 28349				continue;
 // PAR 28349			endif;
			voyageRequest:=request.CM_RORORequest; // PAR 28349
			
			// PAR 32935
			if voyageRequest = null then
				continue;
			endif;
			if voyageRequest.numSeqAft &lt;&gt; 0 then
				continue;
			endif;
			index := index + 1;
			voyageRequest.setSeqNumber(index, true);
		endforeach;

		
		// NUMBER FOR FORWARD
		index := 0;
		foreach lc in _theJobParams.allROROControllers reversed, discreteLock do
			if self.isDischarge or self.jobType = JOB_TYPE_SOB then // PAR 28334
				request := lc.myRORORequestDischarge;
			else
				request := lc.myRORORequestLoad;
			endif;
 // PAR 28349			if not request.isKindOf(CM_ROROSlotRequest) then
 // PAR 28349				continue;
 // PAR 28349			endif;
			voyageRequest:=request.CM_RORORequest; // PAR 28349
			
			// PAR 32935
			if voyageRequest = null then
				continue;
			endif;
			if voyageRequest.numSeqForward &lt;&gt; 0 then
				continue;
			endif;
			index := index + 1;
			voyageRequest.setSeqNumber(index, false);
		endforeach;
	
	endif;
	
	//epr par 28431 better place to call the setSeqWorkOrderNum than the load to ops
	self.setSeqWorkOrderNum();
	
epilog
	delete allROROSlotLCSorted;
end;</source>
        <Parameter name="_theJobParams" type="CMIF_VoyageJobParams"/>
    </JadeMethod>
