    <JadeMethod name="mnuGridSelectorClear_click" id="2aa19fc0-8947-4e3c-b250-db565d904c80">
        <controlMethod name="MenuItem::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mnuGridSelectorClear_click(menuItem: MenuItem input) updating;
// ---------------------------------------------------------------------------
// Created:		June 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars

begin
	self.sdf01.allSelectorTIs.clear;
	self.sdf01.drawSelf();	
	
	if not self.sdf02.allGridAreasByRowColumn.isEmpty then
		self.sdf02.allSelectorTIs.clear;
		self.sdf02.drawSelf();	
	endif;
	if not self.sdf03.allGridAreasByRowColumn.isEmpty then
		self.sdf03.allSelectorTIs.clear;
		self.sdf03.drawSelf();	
	endif;

	self.mnuGridSelectorClear.visible := false;
end;</source>
