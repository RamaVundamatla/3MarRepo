				app.invLog("Secondary vessel name are found: "&amp; _secondaryVessel.name.String, LogINFO.String);
			else	
				app.invLog("Secondary vessel name are not found", LogINFO.String);
			endif;
		else
			app.invLog("Secondary vessel are not found", LogINFO.String);
		endif;
	endif;
	// End - 1.3.2023 navmk20 TFS 56140
	if vessMinCharge = null and _secondaryVessel &lt;&gt; null then
		vessMinCharge := self.allInvTypeVesselMinCharges.getAtKey( _secondaryVessel );
		// Start - 1.3.2023 navmk20 TFS 56140
		if canLogExtra then	//27.02.2025 navah1	#34141
			if vessMinCharge &lt;&gt; null then
				if vessMinCharge.minimumChargeAmount &lt;&gt; null then
					app.invLog("Minimum secondary vessel charge amount: " &amp; vessMinCharge.minimumChargeAmount.String, LogINFO.String);		
				else 
					app.invLog("Minimum secondary vessel charge amount is zero", LogINFO.String);
