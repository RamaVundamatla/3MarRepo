        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="doFormLoad" id="fdb5e404-aaf8-41e3-9626-32707fb50e27">
        <updating/>
        <source>doFormLoad() updating, protected;
// --------------------------------------------------------------------------------
// Created:		02 August 2000 by cnwdad1
//
// Purpose:		Standard form load method.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	reportForm		: CnEcReport;
	paramValueColl	: Collection;

begin
	centreWindow();
	inheritMethod();

	// If there is no pick list and the parameter is of primitive type ...
	if	(not self.aMyReportParameter.hasValueList)	and
		(self.aMyReportParameter.isPrimitiveType())	then

		if self.aMyReportParameter.parameterType = "Boolean" then
			cmbValue.visible	:=	false;
			txtValue.visible	:=	false;
			optYes.visible		:=	true;
			optNo.visible		:=	true;
		else
			// ...use text box for input
			cmbValue.visible	:=	false;
			optYes.visible		:=	false;
			optNo.visible		:=	false;
			txtValue.visible	:=	true;

			// Set default value
			if currentSchema.findName(self.aMyReportParameter.myReportDefinition.formName) &lt;&gt; null then
				create reportForm as currentSchema.getClass(self.aMyReportParameter.myReportDefinition.formName);
				txtValue.text	:=	reportForm.getDefaultParameterValue(self.aMyReportParameter, self.aAllReportParameterValues);
			endif;

			txtValue.setFocus();
		endif;
	// ...otherwise ...
	else
		// ...use combo box for input, and ...
		txtValue.visible	:=	false;
		optYes.visible		:=	false;
		optNo.visible		:=	false;
		cmbValue.visible	:=	true;
		cmbValue.setFocus();

		// ...populate the combo box with list of values
		if currentSchema.findName(self.aMyReportParameter.myReportDefinition.formName) &lt;&gt; null then
			create reportForm as currentSchema.getClass(self.aMyReportParameter.myReportDefinition.formName);
			paramValueColl	:=	reportForm.getParameterClassValues(self.aMyReportParameter, self.aAllReportParameterValues);
			
			if paramValueColl &lt;&gt; null then
				cmbValue.listCollection(paramValueColl, false, 0);
				// Set default value
				cmbValue.listIndex	:= cmbValue.findStringExact(1, reportForm.getDefaultParameterValue(self.aMyReportParameter, self.aAllReportParameterValues));
			endif;
		endif;
	endif;

	txtDescription.text	:=	self.aMyReportParameter.myReportDefinition.reportDescription;
	txtName.text		:=	self.aMyReportParameter.displayValue;

	if self.aStringValue &lt;&gt; "" or self.aMyObjectValue &lt;&gt; null then
		if (not self.aMyReportParameter.hasValueList) then
			if self.aMyReportParameter.parameterType = "Boolean" then
				if self.aStringValue = "true" then
					optYes.value	:=	true;
				elseif self.aStringValue = "false" then
					optNo.value		:=	true;
				else
					optYes.value	:=	true;
				endif;

				txtValue.text		:=	optYes.value.String;
			else			
				txtValue.text		:=	self.aStringValue;
			endif;

		elseif self.aMyReportParameter.isPrimitiveType() then
			cmbValue.listIndex	:=	cmbValue.findStringExact(1, self.aStringValue);

		else
			cmbValue.listIndex	:=	cmbValue.findObject(self.aMyObjectValue);
		endif;
	else
		if self.aMyReportParameter.parameterType = "Boolean" then
			optYes.value	:=	true;
			txtValue.text	:=	optYes.value.String;
		endif;
	endif;
epilog
	delete reportForm;
	app.mousePointer	:=	Idle;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doFormUpdate" id="2de2dee9-0cc6-41b7-89ee-895fb202b9fa">
        <updating/>
        <source>doFormUpdate(pIsDelete: Boolean): Boolean updating, protected;
// --------------------------------------------------------------------------------
// Created:		02 August 2000 by cnwdad1
//
// Purpose:		Standard form update method.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.doValidateDetails() then
		if (not self.aMyReportParameter.hasValueList) then
			self.aStringValue	:=	txtValue.text;
		elseif self.aMyReportParameter.isPrimitiveType() then
			self.aStringValue	:=	cmbValue.text;
		else
			self.aMyObjectValue	:=	cmbValue.listObject;
		endif;
	endif;
epilog
	return self.doShowError();
end;</source>
        <access>protected</access>
        <Parameter name="pIsDelete" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doValidateDetails" id="bb780d9f-d15b-4b37-9b05-d1806d995794">
        <updating/>
        <source>doValidateDetails():Boolean updating, protected;

begin
	if (not aMyReportParameter.hasValueList) and (aMyReportParameter.isPrimitiveType()) then
    	if	(aMyReportParameter.parameterType = "Boolean"								and
			txtValue.text.trimBlanks.toLower &lt;&gt; "true"									and
			txtValue.text.trimBlanks.toLower &lt;&gt; "false")								or

			(aMyReportParameter.parameterType = "Date"									and
			txtValue.text.trimBlanks.Date &lt;&gt; null										and
			not txtValue.text.trimBlanks.Date.isValid)									or

			(aMyReportParameter.parameterType = "Decimal"								and
			txtValue.text.trimBlanks.Decimal.String &lt;&gt; txtValue.text.trimBlanks)		or

			(aMyReportParameter.parameterType = "Integer"								and
			txtValue.text.trimBlanks.Integer.String &lt;&gt; txtValue.text.trimBlanks)		or

			(aMyReportParameter.parameterType = "Real"									and
			txtValue.text.trimBlanks.Real.String &lt;&gt; txtValue.text.trimBlanks)			or

			(aMyReportParameter.parameterType = "String"								and
			txtValue.text.trimBlanks &lt;&gt; txtValue.text.trimBlanks)						or

			(aMyReportParameter.parameterType = "Time"									and
			txtValue.text.trimBlanks.Time &lt;&gt; null										and
			not txtValue.text.trimBlanks.Time.isValid)									then

			self.setErrorMessage(aMyReportParameter.parameterType &amp; ": Invalid Parameter Value");
			return false;
		endif;
	else
		// Allow a blank parameter to be entered - the rules of this should be enforced by the report.
	endif;

	return true;
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="optNo_click" id="058cc24d-4a0c-4ca8-9dac-6f393355a70b">
