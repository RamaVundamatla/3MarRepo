    <JadeMethod name="loadUserCargoConfig" id="8b2c3309-ba02-4028-a97e-3bd161d6fb16">
        <updating/>
        <source>loadUserCargoConfig(_file : File input) updating;
// 1776
vars
	fileObj			: File;
	fileLine		: String;
	allRowFields	: HugeStringArray;
	allFileRows		: ObjectArray;
	
begin
	//on FileException do self.xHandlerFile(exception);
	
	fileObj := _file;
	create allFileRows transient;
	self.rowCount	:= 0;
	self.passport := app.myPassport;
	
	while not fileObj.endOfFile() do
		fileLine	:=	fileObj.readLine().trimBlanks();
		self.rowCount :=	self.rowCount + 1;
		
		if rowCount = 1 or fileLine.isBlankRecordCSV() then
			// Ignore the first line, this only contains headers.
			// Also ignore blank lines.
			continue;
		endif;
		
		create allRowFields transient;
		fileLine.csvConvert(allRowFields, ",");
		
		allFileRows.add(allRowFields);
	endwhile;
	
	fileObj.close();

	self.validateUserCargoConfig(allFileRows);
	
	if not self.passport.hasErrors() then
		self.updateUserCargoConfig(allFileRows);
	endif;

epilog
	
	if allFileRows &lt;&gt; null then
		allFileRows.purge();
		delete allFileRows;
	endif;
	app.mousePointer	:= Idle;
end;</source>
        <Parameter name="_file" type="File" usage="input"/>
    </JadeMethod>
    <JadeMethod name="loadVesselData" id="51925e8f-92a2-4612-83e4-a08aa387e1e0">
        <source>loadVesselData(_xmlFile : File; _vesselCode : String; _nullOperator : CM_Operator; _error : String output) : CM_Vessel;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 03/04/2017	cnwdap1		Initial creation TFS 3930 LNX Bulk Vessel Extract / Load
//
vars
	xmlDocumentParser : JadeXMLDocumentParser;
	xmlDocument : JadeXMLDocument;
	rootElement : JadeXMLElement;
	xmlAttribute : JadeXMLAttribute;
	pxyVessel : CM_Vessel;
	realVessel : CM_Vessel;
	conflictManager : CMIF_HMS_ConflictsManager;
	fileName, vesselCode : String;
	classToCreate : Class;
	hadException : Boolean;
	exCode, exMsg : String;
	jpController : CMIF_JobPriorityController;
	tranState, isOK : Boolean;

begin
	fileName := _xmlFile.fileName;
	if fileName = null then
		_error := "NO file name for file " &amp; _xmlFile.getOidString &amp; CrLf;
		return null;
	endif;
	
	on Exception do self.handleVesselLoadException(exception, hadException, exCode, exMsg);	
	on JadeXMLException do app.xmlExceptionHandler(exception);
	//parse xml into doc
	create xmlDocumentParser transient;
	create xmlDocument transient;
	xmlDocumentParser.parseDocumentFile(xmlDocument, fileName);
	
	rootElement := xmlDocument.rootElement;
	//get the class to create 
	xmlAttribute := rootElement.getAttributeByName('type');
	if xmlAttribute = null then
		_error := app.getErrorString1(ERR_Parsing_XML, "The Root Element needs a type attribute") &amp; CrLf;
		return null;
	endif;
	
	classToCreate := self.getClass(xmlAttribute.value);
	
	if classToCreate = CM_Vessel then
		create pxyVessel transient;	
		pxyVessel.importFromXMLDoc(rootElement);
		// importFromXMLDoc sets vessel code to null - set it back again
		pxyVessel.setPropertyValue(CM_Vessel::code.name, _vesselCode);
		if pxyVessel.myOperator = null then
			pxyVessel.setPropertyValue(CM_Vessel::myOperator.name, _nullOperator);
		endif;
	else
		_error := "classToCreate in " &amp; method.qualifiedName &amp; " is " &amp; classToCreate.name &amp; ", should be CM_Vessel" &amp; CrLf;
		return null;
	endif;
	
	app.myPassport.setIsBackgroundWarningsIgnored(true);
	
	beginTransaction;
	app.setServerTimestampAtTrxStart(null); // ### TFS 52639 21Mar2022 NAVPW1
	app.myPassport.initialiseTransaction();	
	
	app.setContinueCMExceptions(true);
	app.myValCA.valVessel(pxyVessel, conflictManager, app.myPassport);

	if not app.myPassport.checkValidation then
		_error := _xmlFile.fileName &amp; " had validation errors - " &amp; app.myPassport.getErrorsAsString() &amp; CrLf;
		abortTransaction;
		return null;
	endif;
	app.setContinueCMExceptions(false);
	create realVessel as pxyVessel.class persistent;
	realVessel.setForCreate(pxyVessel);
	
	create jpController transient;
	jpController.init(false, realVessel, CM_JobPriorityVessel);
	jpController.populateDefaults();
	jpController.purgePriorities();
	
	if not jpController.isResetToSystem then
		jpController.setForCreate();
	endif;
	
	tranState := process.isInTransactionState;
	if app.myPassport.isOkToCommit(false)
	and  process.isInTransactionState then
		if (not app.myEventManager.isMultiTransactionTrx) then
			app.myEventManager.dispatchAllEvents;
		endif;

		app.cmsCommitTransaction(app.myPassport);
		app.myPassport.finaliseTransaction(TRXStatus_Committed);
		isOK := true;
	else
		app.cmsAbortTransaction();
		app.myPassport.finaliseTransaction(TRXStatus_Aborted);
	endif;
	
	if not app.myPassport.trxCompletedOK then
		_error := _xmlFile.fileName &amp; " had creation errors - " &amp; app.myPassport.getErrorsAsString() &amp; CrLf;
		return null;
	endif;
	
	return realVessel;
	
epilog
	delete xmlDocument;
	delete xmlDocumentParser;
	delete pxyVessel;
end;</source>
        <Parameter name="_xmlFile" type="File"/>
        <Parameter name="_vesselCode" type="String"/>
        <Parameter name="_nullOperator" type="CM_Operator"/>
        <Parameter name="_error" type="String" usage="output"/>
        <ReturnType type="CM_Vessel"/>
    </JadeMethod>
    <JadeMethod name="setAllErrors" id="557b1816-1800-48a6-86c8-4c213ed36704">
        <source>setAllErrors(_heading : String) protected;

vars
	err	: CM_Error;
	
begin

	app.writeLog('HEADING &gt;&gt; ' &amp; _heading, LogINFO);

	self.newErrors.clear;	
	foreach err in app.myPassport.allWarnings do
		if not self.allErrors.includes(err) then
			self.allErrors.add(err);
			self.newErrors.add(err);
			app.writeLog('WARNING &gt;&gt; ' &amp; err.errorCode.String &amp; '  ' &amp; err.text, LogINFO);
		endif;
	endforeach;

	foreach err in app.myPassport.allErrors do
		if not self.allErrors.includes(err) then
			self.allErrors.add(err);
			self.newErrors.add(err);
			app.writeLog('ERROR &gt;&gt; ' &amp; err.errorCode.String &amp; '  ' &amp; err.text, LogINFO);
		endif;
	endforeach;
	
	foreach err in self.newErrors do
		err.removeFromPassport();
	endforeach;
	
end;</source>
        <access>protected</access>
        <Parameter name="_heading" type="String"/>
    </JadeMethod>
    <JadeMethod name="trxImportContractObject" id="92c4ffe7-db83-43d2-b34f-5d564b738a3e">
        <updating/>
        <source>trxImportContractObject(_jadeXMLElement : JadeXMLElement input; _proxyArray : ObjectArray input; 
							   _errorStore : CM_ErrorSet input; _bank : CM_Bank) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
May 2013	cnwjre1	Copy invoice line types from test to UAT for DPH
Sep 2015	cnwdap1	PAR #36909 CCMS ADP 2537 Minimum Charge Changes
*/

vars
	serviceNode		: JadeXMLNode;
	xmlNode			: JadeXMLNode;
	xmlElement		: JadeXMLElement;
	serviceElement	: JadeXMLElement;
	iter			: Iterator;
	serviceIter		: Iterator;

	active : Boolean;
	contractId : String;
	
	realILD,
	proxyILD			: CM_InvoiceLineDesc;
	myCalculationType	: CM_CalculationType;
	myInvoiceType		: CM_InvoiceDesc;
	invType 			: CM_InvoiceDesc;
	myDebtorType		: CM_DebtorType;
	myService			: CM_Service;
	services			: CM_ServiceByNameDict	;
	err					: CM_Error;
	isNotAvailableForEntry : Boolean;	//18 Apr 2017	NDL	TFS 3945
	currencyConversionNotRequired : Boolean;
	taxAlwaysCharged : Boolean;
begin
	if _jadeXMLElement = null then
		return;
	endif;
	
	/*narration		:= null;
	remarks			:= null;
	unitNarration	:= null;
	calcTypeCode	:= null;
	invTypeDesc		:= null;
	chargeByUnits	:= null;
	calcTypeCode	:= null;
	isNotAvailableForEntry := false;	//18 Apr 2017	NDL	TFS 3945

	myCalculationType := null;
	create services transient;

	iter := _jadeXMLElement.childNodes.createIterator;
	while iter.next(xmlNode) do
		if not xmlNode.isKindOf(JadeXMLElement) then
			continue;
		endif;

		xmlElement := xmlNode.JadeXMLElement;
		// property values for this invoice line type
		if xmlElement.tagName = "oneLinePerFP" then
			oneLinePerFP := xmlElement.textData.Boolean;
		elseif xmlElement.tagName = "printTrackedItems" then
			printTrackedItems := xmlElement.textData.Boolean;
		elseif xmlElement.tagName = "chargeByUnits" then
			chargeByUnits := xmlElement.textData.Integer;
		elseif xmlElement.tagName = "isVoid" then
			isVoid := xmlElement.textData.Boolean;
		elseif xmlElement.tagName = "narration" then
			narration := xmlElement.textData.trimBlanks();
		elseif xmlElement.tagName = "printingOrder" then
			printingOrder := xmlElement.textData.Integer;
		elseif xmlElement.tagName = "remarks" then
			remarks := xmlElement.textData.trimBlanks();
		elseif xmlElement.tagName = "unitNarration" then
			unitNarration := xmlElement.textData.trimBlanks();
		elseif xmlElement.tagName = "myCalculationType" then
			calcTypeCode := xmlElement.textData.trimBlanks();
		elseif xmlElement.tagName = "invoiceType" then
			invTypeDesc := xmlElement.textData.trimBlanks();
		elseif xmlElement.tagName = "myDebtorType" then		// 36399 was missing
			debtorTypeCode := xmlElement.textData.trimBlanks();
			
		elseif xmlElement.tagName = "minimumChargeAmount" then				// PAR #36909
			minAmount := xmlElement.text.trimBlanks.Real;					// PAR #36909
		elseif xmlElement.tagName = "minimumChargeGroupBy" then				// PAR #36909
			minGroup := xmlElement.text.trimBlanks;							// PAR #36909
		elseif xmlElement.tagName = "minimumChargeInvoiceLineType" then		// PAR #36909
			minGroup := xmlElement.text.trimBlanks;							// PAR #36909
			
		elseif xmlElement.tagName = "isNotAvailableForEntry" then	//18 Apr 2017	NDL	TFS 3945
			isNotAvailableForEntry := xmlElement.textData.Boolean;
		elseif xmlElement.tagName = "currencyConversionNotRequired" then   //16.11.2018 cnwma1 TFS #42059
			currencyConversionNotRequired := xmlElement.textData.Boolean;  //16.11.2018 cnwma1 TFS #42059
		elseif xmlElement.tagName = "taxAlwaysCharged" then	//07 May 2019	NDL	TFS 44651
			taxAlwaysCharged := xmlElement.textData.Boolean;
		// services
		elseif xmlElement.tagName = "services" then
			serviceIter := xmlElement.childNodes.createIterator;
			while serviceIter.next(serviceNode) do
				if not serviceNode.isKindOf(JadeXMLElement) then
					continue;
				endif;
			serviceElement := serviceNode.JadeXMLElement;
			if serviceElement.tagName = "service" then
				serviceName := serviceElement.textData.trimBlanks();
				myService := _bank.services[serviceName];
				if myService &lt;&gt; null then
					services.add(myService);
				endif;
			endif;	
			endwhile;
		endif;
	endwhile;
	
	// don't error from these being null, just skip them and sort out manually later
	if calcTypeCode &lt;&gt; null then
		myCalculationType	:= app.myRoot.allCalculationTypesByCode[calcTypeCode];
	endif;
	if invTypeDesc &lt;&gt; null then
		found := false;
		foreach invType in _bank.invoiceTypes  discreteLock do
			if invType.description = invTypeDesc then
				found := true;
				break;
			endif;
		endforeach;
		if found then
			myInvoiceType := invType;
		endif;
	endif;
	if debtorTypeCode &lt;&gt; null then
		myDebtorType := app.myRoot.allDebtorTypes[debtorTypeCode];
	endif;

	// add if new otherwise update existing object
	realILD := _bank.invoiceLineDescriptors[narration];
	if realILD &lt;&gt; null then
		proxyILD := app.createUpdateProxy(realILD).CM_InvoiceLineDesc;
	else
		create proxyILD as CM_InvoiceLineDesc transient;
	endif;
	proxyILD.bank := _bank;

	proxyILD.setProxy(oneLinePerFP, printTrackedItems, 0, myDebtorType,
						myCalculationType, myInvoiceType, narration,
						printingOrder, remarks, unitNarration,
						//services, false);									// PAR #36909
						//services, false, minAmount, minGroup, minType);		// PAR #36909
						services, isNotAvailableForEntry, minAmount, minGroup, minType, currencyConversionNotRequired,	//18 Apr 2017	NDL	TFS 3945
						taxAlwaysCharged,	//07 May 2019	NDL	TFS 44651
						null);

	_proxyArray.add(proxyILD);*/
	
epilog
	delete iter;
	delete serviceIter;
	delete services;
end;</source>
        <Parameter name="_jadeXMLElement" type="JadeXMLElement" usage="input"/>
        <Parameter name="_proxyArray" type="ObjectArray" usage="input"/>
        <Parameter name="_errorStore" type="CM_ErrorSet" usage="input"/>
        <Parameter name="_bank" type="CM_Bank"/>
    </JadeMethod>
    <JadeMethod name="updateUserCargoConfig" id="b7679bb3-47c0-4110-86b4-720d15abc863">
        <updating/>
        <source>updateUserCargoConfig(_allFileRows : ObjectArray) updating, protected;
// --------------------------------------------------------------------------------
// Created:		August 2011 by cnwjre1
//
// Purpose:		Load user cargo type config for cargo enquiry
//
// Parameters:	_allFileRows - An object array of file rows (each one being a HugeStringArray).
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	priorUserCode		: String;
	priorCargoTypeId	: Integer;
	priorTabDescription	: String;
	object				: Object;
	allRowFields		: HugeStringArray;
	userObj				: CM_User;
	cargoTypeObj		: CM_CargoType;
	entRowObj			: EntTableRow;
	ucType				: CM_UserConfigCargoType;
	proxyUserCargoType	: CM_UserConfigCargoType;
	ucTab				: CM_UserConfigTab;
	ucAttr				: CM_UserConfigAttribute;
	
	// The following are the file field values.
	
	userCode			: String;
	cargoTypeId			: Integer;
	cargoTypeDescription : String;
	isDefault			: Boolean;
	tabName				: String;
	tabDescription		: String;
	tabType				: Integer;
	entRowNumber		: Integer;
	entRowHeading		: String;
	
	
begin
	
	self.rowCount := 1;		// count the csv header which has been skipped from the incoming array
	foreach object in _allFileRows do
		self.rowCount := self.rowCount + 1;
		allRowFields	:=	object.HugeStringArray;
		if allRowFields.size &lt; 9 then
			continue;
		endif;
		
		// Get the field values.
		
		userCode		:=	allRowFields[1];
		cargoTypeId		:=	allRowFields[2].Integer;
		cargoTypeDescription	:=	allRowFields[3];
		isDefault		:=	allRowFields[4].Boolean;
		tabName			:=	allRowFields[5];
		tabDescription	:=	allRowFields[6];
		tabType			:=	allRowFields[7].Integer;
		entRowNumber	:=	allRowFields[8].Integer; 
		entRowHeading	:=	allRowFields[9];

		// user
		userObj := self.getUser(userCode);

		// cargo type
		cargoTypeObj := self.getCargoType(cargoTypeId);
		
		// ent row
		if not isDefault then
			entRowObj := self.getEntTableRow(entRowNumber, entRowHeading);
		endif;
		
		// new user cargo type
		if userCode &lt;&gt; priorUserCode or
		   cargoTypeId &lt;&gt; priorCargoTypeId then
		// update the last user cargoType
		   if proxyUserCargoType &lt;&gt; null then
				if not self.updateUserCargoType(proxyUserCargoType) then
					app.raiseCMException3(LoadUpdateError, 'User cargo config', 'user ' &amp; userCode &amp; ' cargo type ' &amp; cargoTypeDescription, self.rowCount.String, null, null);	
					setAllErrors('Update  (user ' &amp; userCode &amp; ', cargo type ' &amp; cargoTypeDescription &amp; ')');
					return;
				endif;
				delete proxyUserCargoType;
			endif;
			// set up the new, no content (all comes from the load file)
			ucType := userObj.allUserCargoTypes[userObj, cargoTypeObj];
			if ucType &lt;&gt; null then
				proxyUserCargoType := app.createUpdateProxy(ucType).CM_UserConfigCargoType;
				proxyUserCargoType.clearContent();
			else
				create proxyUserCargoType transient;
				proxyUserCargoType.setup(userObj, cargoTypeObj);
			endif;
			proxyUserCargoType.isDefault := isDefault;
			
			priorUserCode := userCode;
			priorCargoTypeId := cargoTypeId;
			priorTabDescription := null;
		endif;
		
		if isDefault then
			// no tabs
			continue;
		endif;
		
		// new tab
		if priorTabDescription &lt;&gt; tabDescription then
			create ucTab transient;
			ucTab.setup(tabDescription, tabName, 0, proxyUserCargoType);
			priorTabDescription := tabDescription;
		endif;
		
		// each attribute
		create ucAttr transient;
		ucAttr.setup(ucTab, entRowObj);

	endforeach;
	// do last user cargo type
	if proxyUserCargoType &lt;&gt; null then
		if not self.updateUserCargoType(proxyUserCargoType) then
				app.raiseCMException3(LoadUpdateError, 'User cargo config', 'user ' &amp; userCode &amp; ' cargo type ' &amp; cargoTypeDescription, self.rowCount.String, null, null);	
				setAllErrors('Update  (user ' &amp; userCode &amp; ', cargo type ' &amp; cargoTypeDescription &amp; ')');
				return;
			endif;
			delete proxyUserCargoType;
		endif;
epilog
end;
</source>
        <access>protected</access>
        <Parameter name="_allFileRows" type="ObjectArray"/>
    </JadeMethod>
    <JadeMethod name="updateUserCargoType" id="9d8161f3-55af-448c-87f9-321746befc2a">
        <updating/>
        <source>updateUserCargoType(_proxyUserCargoType : CM_UserConfigCargoType input) : Boolean updating, protected;

vars

begin
	app.myTrxUA.trxUpdateUser_CargoType(_proxyUserCargoType, app.myPassport);
	if (not app.myPassport.trxCompletedOK) then
		self.setAllErrors('Updating user cargo type (user ' &amp; _proxyUserCargoType.myUser.code &amp; ', cargo type ' &amp; 
							_proxyUserCargoType.myCargoBOLType.description &amp; '), row ' &amp; rowCount.String);
		return false;
	endif;

	return true;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_proxyUserCargoType" type="CM_UserConfigCargoType" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateUserCargoConfig" id="fb01c58b-9c4a-4264-8ac5-e7594cf1c2d9">
        <updating/>
        <source>validateUserCargoConfig(_allFileRows : ObjectArray) updating, protected;
// --------------------------------------------------------------------------------
// Created:		Aug 2011 by cnwjre1
//
// Purpose:		Do per-field validation 
//
// Parameters:	_allFileRows - An object array of file rows (each one being a HugeStringArray).
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	object				: Object;
	allRowFields		: HugeStringArray;
	userObj				: CM_User;
	cargoTypeObj		: CM_CargoType;
	entRowObj			: EntTableRow;
	
	// The following are the file field values.
	
	userCode			: String;
	cargoTypeId			: Integer;
	cargoTypeDescription : String;
	isDefault			: Boolean;
	tabName				: String;
	tabDescription		: String;
	tabType				: Integer;
	entRowNumber		: Integer;
	entRowHeading		: String;
	
	
begin
	on Exception do self.agtPassportExHandler(exception, self.passport);
	self.passport.initialiseTransaction();	

	
	self.rowCount := 1;		// count the csv header which has been skipped from the incoming array
	foreach object in _allFileRows do
		self.rowCount := self.rowCount + 1;
		allRowFields	:=	object.HugeStringArray;
		if allRowFields.size &lt; 9 then
			self.validationError("Not enough columns", allRowFields.size.String);
			continue;
		endif;
		
		// Get the field values.
		
		userCode		:=	allRowFields[1];
		cargoTypeId		:=	allRowFields[2].Integer;
		cargoTypeDescription	:=	allRowFields[3];
		isDefault		:=	allRowFields[4].Boolean;
		tabName			:=	allRowFields[5];
		tabDescription	:=	allRowFields[6];
		tabType			:=	allRowFields[7].Integer;
		entRowNumber	:=	allRowFields[8].Integer; 
		entRowHeading	:=	allRowFields[9];

		// user
		userObj := self.getUser(userCode);

		// Cargo type
		cargoTypeObj := self.getCargoType(cargoTypeId);
		
		if isDefault then
			continue;
		endif;
		// ent row
		entRowObj := self.getEntTableRow(entRowNumber, entRowHeading);
		
		if tabName = "" then
			self.validationError("Tab name is null", null);
		endif;
		if tabDescription = "" then
			self.validationError("Tab description is null", null);
		endif;
		
	endforeach;

	if not self.passport.hasErrors() then
		self.passport.finaliseTransaction(TRXStatus_Committed);
	endif;
epilog

end;

</source>
        <access>protected</access>
        <Parameter name="_allFileRows" type="ObjectArray"/>
    </JadeMethod>
    <JadeMethod name="validationError" id="f5cf5997-55c3-4eb2-9794-7f165cae9de0">
        <updating/>
        <source>validationError(_message : String; _value : String) updating, protected;

vars

begin
	app.raiseCMException3(CsvLoadError, _message, _value, self.rowCount.String, null, null);
end;
</source>
        <access>protected</access>
        <Parameter name="_message" type="String"/>
        <Parameter name="_value" type="String"/>
    </JadeMethod>
</Class>
