    <JadeMethod name="getCurrentLocation" id="e95b1c85-91c1-400c-91b8-199e172336d0">
        <source>getCurrentLocation(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 October 2018	jlgndl1	Initial creation	TFS 41272

*/

vars

	voyage : CM_Voyage;
	departMovement : HMS_VoyageMovement;
	prevMovement : HMS_VoyageMovement;
	berth : HMS_Berth;

begin

	voyage := self.getMyVoyageObject();

	if voyage &lt;&gt; null then
		departMovement := voyage.getMovementDeparture();
		if departMovement &lt;&gt; null then
			prevMovement := departMovement.myPreviousMovement.HMS_VoyageMovement;
			if prevMovement &lt;&gt; null then
				berth := prevMovement.getMyBerth;
				if berth &lt;&gt; null then
					return berth.description;
				endif;
			endif;
		endif;
	endif;
	
	return inheritMethod();

epilog

end;</source>
