<Class name="CM_YATypeContentsStatus" id="65ea6ad9-6e2f-4dda-bade-27c05feb2e37">
    <superclass name="CM_YACriteriaType"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="yardAllocations"/>
    <JadeMethod name="getAllCriteriaValues" id="50d38be9-e7d8-4334-b26d-65772a0199f8">
        <source>getAllCriteriaValues(_terminalObj:CM_Terminal; _allCriteriaValues: ObjectSet input; _filter : Integer; _allDependentObjs : CM_ObjectArray);
// Created:		Oct 2010	cnwjre1	added for CCMS 1043 snap shot summary invoicing
//
//17 September 2013	cnwmc5	PAR 31255 - allowing dependent objects the criteria is based on.
//
begin
	app.myRoot.allContentsStatuses.copy(_allCriteriaValues);
end;</source>
        <Parameter name="_terminalObj" type="CM_Terminal"/>
        <Parameter name="_allCriteriaValues" type="ObjectSet" usage="input"/>
        <Parameter name="_filter" type="Integer"/>
        <Parameter name="_allDependentObjs" type="CM_ObjectArray"/>
    </JadeMethod>
    <JadeMethod name="getCriteriaObjectForTi" id="43a3fde2-f659-4cf2-b3ea-39a39f1bd564">
        <source>getCriteriaObjectForTi(_ti: CM_TrackedItem; _criteriaObject: CM_Object output; _process: Boolean output);
// Created:		Oct 2010	cnwjre1	added for CCMS 1043 snap shot summary invoicing
vars
	contentsStatus	: Integer;
begin
	contentsStatus := _ti.getContentsStatus();
	_criteriaObject:= app.myRoot.allContentsStatuses[contentsStatus];

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_criteriaObject" type="CM_Object" usage="output"/>
        <Parameter name="_process" type="Boolean" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getDataDisplay" id="2e2f3a55-569e-4bc8-b9b8-159a5215c9f5">
        <source>getDataDisplay(pDataObj : CM_YAData) : String;
// Created:		Oct 2010	cnwjre1	added for CCMS 1043 snap shot summary invoicing
begin
	return pDataObj.CM_YADataObjects.getDataDisplay(self);
end;</source>
        <Parameter name="pDataObj" type="CM_YAData"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplay" id="18b1513f-b061-4e06-8553-d3a6c9a58e7c">
        <source>getDisplay(dataObj : Object) : String;
// Created:		Oct 2010	cnwjre1	added for CCMS 1043 snap shot summary invoicing
begin
	return dataObj.CM_ContentsStatus.description;
end;</source>
        <Parameter name="dataObj" type="Object"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getObjects" id="b3c378ce-cb85-46a2-8d68-ea5aab26ed37">
        <source>getObjects(objects : ObjectLongNameDict input);
// Created:		Oct 2010	cnwjre1	added for CCMS 1043 snap shot summary invoicing
// Return a dict of objects for this criteria type
vars
	cs : CM_ContentsStatus;
begin
	foreach cs in app.myRoot.allContentsStatuses do
		objects[cs.getYAIdentifier] := cs;
	endforeach;
end;</source>
        <Parameter name="objects" type="ObjectLongNameDict" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getTypeName" id="387f22a2-fa05-4045-9bc9-1f226c1be55c">
        <source>getTypeName(): String;
// Created:		Oct 2010	cnwjre1	added for CCMS 1043 snap shot summary invoicing
begin
	return "Contents Status";
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="isCMIFDataMatch" id="b974041d-8314-4cf0-a954-4bb2d3346c18">
        <source>isCMIFDataMatch(_cmifAutoPlan: CMIF_YAAutoPlan; _yaData: CM_YADataObjects): Boolean;
// Created:		Oct 2010	cnwjre1	added for CCMS 1043 snap shot summary invoicing
vars

begin

	return _cmifAutoPlan.isContentsStatus_Match(_yaData);
 
end;</source>
        <Parameter name="_cmifAutoPlan" type="CMIF_YAAutoPlan"/>
        <Parameter name="_yaData" type="CM_YADataObjects"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isSnapShotDataMatch" id="60cd24ed-acae-4dc9-beba-0de97fde347a">
        <source>isSnapShotDataMatch(_criteria: CM_YACriteria; _yaType: Integer; _propertyValue: String): Boolean;
// Created:		Oct 2010	cnwjre1	added for CCMS 1043 snap shot summary invoicing
vars
	match	: Boolean;
	obj		: Object;
begin
	if _yaType &lt;&gt; self.type then
		return false;
	endif;
	
	foreach obj in _criteria.myYAData.CM_YADataObjects.allObjects do
		if obj.CM_ContentsStatus.description = _propertyValue then
			return true;
		endif;
	endforeach;
	
	if _criteria.myYAData.isKindOf(CM_YADataPattern) and
	   _criteria.myYAData.CM_YADataPattern.pattern = null then
		return true;
	endif;
	
	return false;
end;
</source>
        <Parameter name="_criteria" type="CM_YACriteria"/>
        <Parameter name="_yaType" type="Integer"/>
        <Parameter name="_propertyValue" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isStorageDetailMatch" id="e203d69c-d305-43ec-a038-e68ca4712fe1">
        <source>isStorageDetailMatch(_criteria : CM_YACriteria; _ti: CM_TrackedItem; _tiTrx : CM_TITransaction): Boolean;
// CCMS 1295 free storage days
vars
	status	: Integer;
	contentsStatus	: CM_ContentsStatus;

begin
//	status := _ti.getContentsStatus();
	
	if _tiTrx &lt;&gt; null then	//13 Nov 2019	NDL	TFS 47344	
		status := _tiTrx.contentsStatus;
	else
		status := _ti.getContentsStatus();
	endif;
	
	contentsStatus := app.myRoot.allContentsStatuses[status];

	// specific value - 31221 handle wild cards as well
	if _criteria.myYAData.CM_YADataObjects.matchesStorage(contentsStatus) then
		return true;
	endif;
	
	// default value
	if _criteria.myYAData.isKindOf(CM_YADataPattern) and
	   _criteria.myYAData.CM_YADataPattern.pattern = null then
		return true;
	endif;
	
	return false;
end;
</source>
        <Parameter name="_criteria" type="CM_YACriteria"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_tiTrx" type="CM_TITransaction"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
