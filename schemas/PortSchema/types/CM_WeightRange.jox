    <JadeMethod name="validateForDelete" id="9116d1cf-4b52-444d-9d2b-9665f965abe6">
        <source>validateForDelete();
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 09/04/2009	cnwrl1		PAR 19373 - make sure do not delete a weight range that is being used.
// 08/06/2009	cnwrl1		PAR 19856 - Handle different types of error message.
// ---------------------------------------------------------------------------
vars
	cm_YATypeWeight		: CM_YATypeWeight;
	alloctionStr		: String;
	terminalStr			: String;
	tempStr				: String;
	
begin
	cm_YATypeWeight	:= CM_YATypeWeight.firstInstance;	// should only be one,
	if cm_YATypeWeight = null then
		return;						// OK to delete
	endif;
	
	// If this WeightRange is being used in a Yard Criteria then need to stop the deletion.
//	if cm_YATypeWeight.isObjectBeingUsedInCriteria( self, tempStr ) then	// cnwrl1 08/06/2009 PAR 19856 - what it was
//		app.raiseCMException2( Object_IsBeingUsedInCriteria, app.getErrorString( Weight_Range ), tempStr.display, null, null );	// cnwrl1 08/06/2009 PAR 19856 - what it was
	if cm_YATypeWeight.isObjectBeingUsedInCriteria( self, alloctionStr, terminalStr ) then
		if alloctionStr &lt;&gt; null then
			tempStr	:= alloctionStr.display;
		elseif terminalStr &lt;&gt; null then
			tempStr	:= terminalStr.display;
		else
			tempStr	:= app.getErrorString( Unknown ).display;
		endif;
		app.raiseCMException2( Object_IsBeingUsedInCriteria, app.getErrorString( Weight_Range ), tempStr, null, null );
	endif;
	
epilog
	
end;
</source>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="35604772-be57-4ed2-a546-5be90e1f9cd3">
        <source>validateForUpdate();
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	self.validateMe;
end;</source>
    </JadeMethod>
    <JadeMethod name="validateMe" id="45432140-c30c-4627-b8ea-c24255eb47c9">
        <source>validateMe() protected;
//
// Changed On 	By			Reason
// ----------	--------	---------------------------------------------------------
// 30/04/2013	cnwdap1		PAR #31155 CCMS SFW 1321 Imperial Measurements
vars
	gtrRange,
	lssRange	: CM_WeightRange;
	root		: CM_Root;
	realMe		: CM_WeightRange;
	iter1,
	iter2		: Iterator;
	measure		: CM_MeasurementType;						// PAR #31155
begin

	root := app.myRoot;
	
	realMe := self.pxyGetRealObject();

	//cnwjo3 par 23031
	if self.lower &lt; MIN_WEIGHT or self.lower &gt; MAX_WEIGHT then
		app.raiseCMException2(ERR_FIELD_WEIGHTRANGE, self.lower.String,ETRow_Lower, null,null);
	endif;
	
	//cnwjo3 par 23031
	if self.upper &lt; MIN_WEIGHT or self.upper &gt; MAX_WEIGHT  then
		app.raiseCMException2(ERR_FIELD_WEIGHTRANGE, self.upper.String,ETRow_Upper, null,null);
	endif;
	
	// cnwrl1 02/04/2009 PAR 19372 - start of coding
	// Make sure the lower value is &lt;= upper value.
	if self.lower &gt; self.upper then
		app.raiseCMException2(	ERR_LOWER_GT_UPPER,
								app.getErrorString( Lower ) &amp; app.getErrorString( Weight ),
								app.getErrorString( Upper ) &amp; app.getErrorString( Weight ),
								null,
								null );
	endif;
	// cnwrl1 02/04/2009 PAR 19372 - end of coding
	
	if root.allWeightRanges.isEmpty() then
		return;
	endif;
	
	measure 	:= app.getDefaultMeasurementForType(Type_Weight);												// PAR #31155
	if self.myMeasurementType &lt;&gt; null then																		// PAR #31155
		gtrRange 	:= self.myMeasurementType.allWeightRanges.getAtKeyGeq(self.myMeasurementType, self.value);	// PAR #31155
	else																										// PAR #31155
		//gtrRange	:= root.allWeightRanges.getAtKeyGeq(self.value);											// PAR #31155
		gtrRange	:= root.allWeightRanges.getAtKeyGeq(measure, self.value);									// PAR #31155
	endif;																										// PAR #31155
	
	if gtrRange &lt;&gt; null and gtrRange = realMe then
		iter1 := root.allWeightRanges.createIterator();
		iter1.startAtObject(gtrRange);
		while iter1.next(gtrRange) do
			//if gtrRange &lt;&gt; realMe then																		// PAR #31155
			if gtrRange &lt;&gt; realMe or gtrRange.myMeasurementType &lt;&gt; realMe.myMeasurementType then				// PAR #31155
				break;
			endif;
		endwhile;
	endif;
	
	if self.myMeasurementType &lt;&gt; null then																		// PAR #31155
		lssRange 	:= self.myMeasurementType.allWeightRanges.getAtKeyLeq(self.myMeasurementType, self.value);	// PAR #31155
	else																										// PAR #31155
		//lssRange	:= root.allWeightRanges.getAtKeyLeq(self.value);											// PAR #31155
		lssRange	:= root.allWeightRanges.getAtKeyLeq(measure, self.value);									// PAR #31155
	endif;																										// PAR #31155
	if lssRange &lt;&gt; null and lssRange = realMe then
		iter2 := root.allWeightRanges.createIterator();
		iter2.startAtObject(lssRange);
		while iter2.back(lssRange) do
			//if lssRange &lt;&gt; realMe then																		// PAR #31155
			if lssRange &lt;&gt; realMe or lssRange.myMeasurementType &lt;&gt; realMe.myMeasurementType then				// PAR #31155
				break;
			endif;
		endwhile;
	endif;
	
	if gtrRange &lt;&gt; null and realMe &lt;&gt; null and gtrRange.myMeasurementType &lt;&gt; realMe.myMeasurementType then		// PAR #31155
		gtrRange := null;																						// PAR #31155
	endif;																										// PAR #31155
	if lssRange &lt;&gt; null and realMe &lt;&gt; null and lssRange.myMeasurementType &lt;&gt; realMe.myMeasurementType then		// PAR #31155
		lssRange := null;																						// PAR #31155
	endif;																										// PAR #31155
	
	if (lssRange &lt;&gt; null and lssRange &lt;&gt; realMe) and lssRange.upper &gt;= self.lower then
		app.raiseCMException4(Range_is_within_range, self.lower.String,self.upper.String,lssRange.lower.String,lssRange.upper.String, self.value.String, null);
		return; //cnwjo3 par 23031, range fail.  just return
		// bad
	endif;
	
	if (gtrRange &lt;&gt; null and gtrRange &lt;&gt; realMe) and gtrRange.upper = self.upper then
		app.raiseCMException4(Range_is_within_range, self.lower.String, self.upper.String, gtrRange.lower.String, gtrRange.upper.String, self.value.String, null);
		return;
		// bad
	endif;
	
	if (lssRange &lt;&gt; null and lssRange &lt;&gt; realMe) and lssRange.upper = self.upper then
		app.raiseCMException4(Range_is_within_range, self.lower.String,self.upper.String, lssRange.lower.String,lssRange.upper.String, self.value.String, null);
		return;
		// bad
	endif;
	
	if (gtrRange &lt;&gt; null and gtrRange &lt;&gt; realMe) and gtrRange.lower &lt;= self.upper then	
		app.raiseCMException4(Range_is_within_range, self.lower.String, self.upper.String, gtrRange.lower.String, gtrRange.upper.String, self.value.String, null);
		return;
		// bad
	endif;
	
	if self.percentage &lt; 0 or self.percentage &gt; 100 then
		app.raiseCMException1(Percentage_invalid, self.percentage.String, null, null);
		return;
	endif;
	
epilog	
	delete iter1;
	delete iter2;	
end;</source>
        <access>protected</access>
    </JadeMethod>
</Class>
