    <JadeMethod name="validateForPacking" id="917631cc-52a7-4e06-a73d-b977653e596b">
        <updating/>
        <source>validateForPacking() : Boolean updating;
// ---------------------------------------------------------------------------
// Created:     16 April 2008 by cnwaer1
//
// Purpose:     
// ---------------------------------------------------------------------------
// 26/08/2010	cnwdap1		PAR #25405 Ensure we have something entered in the Tare Weight (previously 
//								allowed '0' to be entered, which causes problems in weight calculations)
vars
	cargoType 		: CM_CargoType;
	id,
	reqText 		: String;
	reserveDtl		: CM_ReserveDetail;
	found 			: Boolean;
	tmpTI			: CM_TrackedItem;
	tran 			: CM_TITransaction;
begin
	// validate  cargo type
	if self.cmb_CargoType.listObject = null then
		app.msgBox(app.getErrorString(Unspecified_Cargo_Type), null, MsgBox_Exclamation_Mark_Icon);
		cmb_CargoType.setFocus;
		return false;
	endif;	
	
	cargoType := cmb_CargoType.listObject.CM_CargoType;
	id := self.txt_ContainerID.text.trimBlanks;
	
	// Check if is a ISO Container of Master pack. Each crago type has a flag that can be set up to true or false. 
	// Container - cargo type not dynamically created. Flag not ticked
	// Mastepack - cargo type that is dynalically created. Flage is ticked
	if not cargoType.isDynamicallyCreated then
	// we are dealing with a Master pack
		// validate container
		if self.myCargoTI = null or id.length = 0 then 
			app.msgBox(app.getErrorString(InvalidContainer), null, MsgBox_Exclamation_Mark_Icon);
			self.txt_ContainerID.setFocus;
			return false;
		endif;
	endif;
	
	// validate Weight
	//if self.txt_TareWeight.text.trimBlanks.length = 0 then											// PAR #25405
	if self.txt_TareWeight.text.trimBlanks.length = 0 or self.txt_TareWeight.text.Integer = null then	// PAR #25405
		app.msgBox(app.getErrorString(Weight_missing), null, MsgBox_Exclamation_Mark_Icon);
		self.txt_TareWeight.setFocus;
		return false;
	endif;
	
	if myCargoTI &lt;&gt; null then
		if myCargoTI.isKindOf(CM_Container) then
			//15 Sep 2010	NDL	Par 25608 - change from direct ref to using method 'getSealNum'
			if myCargoTI.getSealNum &lt;&gt; null then
				app.msgBox( app.getErrorString(ERR_CannotPackContainerSealed), null, MsgBox_Exclamation_Mark_Icon);
				self.txt_ContainerID.setFocus;
				return false;	
			endif;
		else //AER par 17309 
			if myCargoTI.isPackingComplete() then 
				app.msgBox( app.getErrorString(ERR_CannotPackMasterPackComple), null, MsgBox_Exclamation_Mark_Icon);
				self.txt_ContainerID.setFocus;
				return false;	
			endif;
			if myCargoTI.myCargoType.allProducts.first = null then   // Par 18218
				app.msgBox( app.getErrorString(ERR_CannotPackMasterPackNoProd), null, MsgBox_Exclamation_Mark_Icon);
				self.txt_ContainerID.setFocus;
				return false;	
			endif;
		endif;
	endif;
	if txt_Location.text &lt;&gt; null and self.myMobileDataAgent.findLocationByID(txt_Location.text.toUpper) = null then
		app.msgBox("Not a valid location.",null, MsgBox_Exclamation_Mark_Icon);
		self.txt_Location.setFocus;
		return false;
	endif;

	if cargoType.isDynamicallyCreated then
		myCargoTI := self.myMobileDataAgent.findOrCreateMasterPack(id, cargoType, self.txt_TareWeight.text.trimBlanks.Integer);	
	endif;
	
	// validate Request
	if not self.validateRequest()then
		return false;
	endif;
	
	return true;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateRequest" id="3f98cfeb-b11c-4c18-b8cd-ebece6060d76">
        <updating/>
        <source>validateRequest(): Boolean updating;

vars
	reqText, relString 			: String;
	res		: CM_ReserveDetail;
	relReq		: CM_BulkRelease;
	otherRelAssigned, found	: Boolean;
begin
	// validate Request
	self.myRequest := null;
	// validate the request against what was entered in the form. 
	// Even if the release number has not been changed we still have to check if the request is ACTIVE and for PACKING
	// this is don't in .searchForRequest() method
	
	reqText := self.txt_RequestNo.text.trimBlanks;
	
	if reqText.length = 0 then
		app.msgBox(app.getErrorString(Request_missing),null, MsgBox_Exclamation_Mark_Icon);
		return false;
	endif;
	// myRequest.status must be ACTIVE and for PACKING every time we action the request. So we need to make sure it is accessible.
	self.searchForRequest(self.txt_RequestNo.text.trimBlanks.toUpper);
	if self.myRequest = null then
		return false;
	// we are packing against the children , so the collection needs to have at list one child request line.
	elseif self.myRequest.allReservePackingChildren.size = 0 then
		app.msgBox(app.getErrorString(NoPackChildren),null, MsgBox_Exclamation_Mark_Icon);
		return false;
	endif;
	// Checking to see if the container where we want to pack in, has any references to any other packing requests.
	// Looking for the release in the container's collections:
	// 		1. allBulkReleasesAssigned - collection populated when the user deliberately assigns the container to a release request.
	if (not self.myCargoTI.myCargoType.isDynamicallyCreated) then
		// Check only for Containers not for Masterpacks
		if self.myCargoTI.allBulkReleasesAssigned.size &lt;&gt; 0 then
			otherRelAssigned :=false;
			if (not self.myCargoTI.allBulkReleasesAssigned.includes(self.myRequest)) then
			// if my request is not in the containers collection, check to see if other active packing requests are there.
				foreach relReq in self.myCargoTI.allBulkReleasesAssigned do
					if relReq.status = BR_ACTIVE and relReq.type = BR_TYPE_PACKING then
						otherRelAssigned :=true;
						relString := relReq.code;
						break;
					endif;
				endforeach;
				if otherRelAssigned then
					app.msgBox("This container is already attached to request "&amp; relString, null, MsgBox_Exclamation_Mark_Icon);
					return false;
				endif;
			endif;
		elseif self.myCargoTI.allReserveDetailsReleased.size &lt;&gt; 0 then
			found := false;
			foreach res in self.myCargoTI.allReserveDetailsReleased reversed do
					if res &lt;&gt; null then
						relReq := res.myReserveHeader;
					endif;
					if relReq &lt;&gt; null and relReq = self.myRequest then
						found := true;
						break;
					endif;
			endforeach;
			if not found then
			//the container has not been attached to the Release request , can not go further from here.
				app.msgBox("The container is not attached to the release request.", null, MsgBox_Exclamation_Mark_Icon);
				return false;
			endif;
		else 
			app.msgBox("The container is not attached to the release request.", null, MsgBox_Exclamation_Mark_Icon);
			return false;
		endif;
	/*	if self.myCargoTI.myOperator &lt;&gt; myRequest.myOperator then
			app.msgBox('The request has a different operator from the container',null, MsgBox_Exclamation_Mark_Icon);
			return false;	
		endif;
*/	endif;
	return true;
end;
</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</GUIClass>
