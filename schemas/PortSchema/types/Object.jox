    <JadeMethod name="calculateTotalWeightVolume" id="952b5960-483e-46ed-ac07-4501ab4eabbb">
        <options>4</options>
        <source>calculateTotalWeightVolume(_totalWeight, _totalVolume : Decimal; _density : Decimal; _type : Integer) : Decimal typeMethod;
/*

Purpose:			Bulk-Only calculation

Parameters:			_totalWeight
					_hasNett
					_type: CM_CalculateWeight, CM_CalculateVolume

Return Value:		

Date		Who		Reason
12/10/2009	cnwdap1	PAR #20832 Correct Total Weight handling when both Nett and Tare are entered
18/03/2010	cwnmh5	PAR #22546 - Bypass exception when cargo/tare weight length &gt; txtTotalWeight
						which is being caught when validation is done
27/03/2013	cnwdap1	PAR #31155 CCMS SFW 1321 Imperial Measurements
24/06/2013	cnwcs5	par 31758 - if total weight entered and cargo weight not entered then calculate cargo weight
16 Jul 2013	NDL	Par 32006 - Didn't work for empty receivals.  I.e. Tare weight and No cargo weight, also should recalc unconditionally based
							on the field you are leaving if in Nett or Total weight
25/03/2014	cnwdap1	PAR #33606 CCMS SFW 1366 Bulk - if cargo type is bulk and tracked by weight, calculate and set total volume if we have a density
26 November 2021	navpw1	Initial creation TFS: 52193
*/

vars
	result	: Decimal [16,8];
	ex		: Exception;
begin
	if _type = CM_CalculateWeight then
		// calculate total weight
		result := _totalVolume * _density;
		return result;
	elseif _type = CM_CalculateVolume then
		// calculate total volume
		result := _totalWeight / _density;
		return result;
	else
		app.raiseCMException2(ERR_TRANSACTION_MAP, PortSchema.name &amp; "::" &amp; PortSchema::calculateTotalWeightVolume.name, "Incorrect type passed in" , null, null);
	endif;
epilog

end;</source>
        <Parameter name="_totalWeight" type="Decimal"/>
        <Parameter name="_totalVolume" type="Decimal"/>
        <Parameter name="_density" type="Decimal"/>
        <Parameter name="_type" type="Integer"/>
        <ReturnType type="Decimal"/>
    </JadeMethod>
