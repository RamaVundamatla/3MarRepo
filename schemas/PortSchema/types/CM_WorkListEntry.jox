    <JadeMethod name="getStatusBasedOnRTTasks" id="b31459a4-764c-48b5-8d3e-47ceadbdf6f6">
        <source>getStatusBasedOnRTTasks(): Integer protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 February 2011	cnwer1	Initial creation PAR 25573

*/


vars
	newStatus	:	Integer;
begin
	if self.myRequest.isKindOf(CM_BOLYardRequest) then
		return WLE_UNACTIONED;
	endif;
	
	if self.allRTQueueEntries.isEmpty and self.myFutureMove = null or self.myFutureMove.isKindOf(CM_FutureMovePlanned) then
		//epr 27/4/2011 if there are no rt queue entries or future move and is already set to complete assumme it is completed
		if self.status = WLE_COMPLETED then
			newStatus:=WLE_COMPLETED;
		else
			newStatus:=WLE_UNACTIONED;
		endif;
		
	else
		if self.myTrackedItem = null and not self.myRequest.isKindOf(CM_TIRequest) then
			//Not assigned yet.
			newStatus:=WLE_UNACTIONED;
		elseif self.areAllEntryTasksEqStatus(TASK_COMPLETE) then
			newStatus := WLE_COMPLETED;
		elseif self.areAllEntryTasksEqStatus(TASK_UNACTIONED) or self.areTasksUnactionedOrHeld() then		//cnwmc5 - 26 July 2013 - PAR 31553
			newStatus := WLE_UNACTIONED;
		else
			newStatus := WLE_PART_COMPLETE;	
		endif; 
	endif;
	
	return newStatus;
epilog

end;</source>
        <access>protected</access>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getTargetLocation" id="68c84703-9f30-4bb2-9f0b-ccac75f0c5ac">
