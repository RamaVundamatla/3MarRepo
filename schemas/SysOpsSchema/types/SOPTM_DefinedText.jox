    <JadeMethod name="doSave" id="549759d6-eea0-43ad-a889-8360cef14f4e">
        <updating/>
        <source>doSave(): Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		 Reason
10 October 2022	navsks20 ChangeRequest 53424: MTN - MOB - Input Remarks - Jade

*/

vars
	theForm 				: SOP_TableMaintForm;
	tbl						: CM_EntryTable;
	text					: String;
	sortOrder,context		: Integer;
	isNotAvailableForEntry 	: Boolean;
	pxyDefinedText,
	newDefinedText			: CM_DefinedText;
	terminal				: CM_Terminal;
begin
	theForm := self.myForm;
	tbl 	:= theForm.tblInput1;

	context 			   := app.getDefTextStrToInt(tbl.getValueByName(ETRow_Context).String);
	text 				   := tbl.getValueByName(ETRow_Text).String;
	sortOrder 			   := tbl.getValueByName(ETRow_SortOrder).Integer;
	isNotAvailableForEntry := tbl.getValueByName(ETRow_IsNotAvailableForEntry).Boolean;
	terminal			   := self.myForm.myTerminal;
	
	if theForm.myProxyObject = null then
		if theForm.mode = theForm.Mode_Add then
			create theForm.myProxyObject as CM_DefinedText transient;
		else
			app.raiseUnexpectedProgramError(class.name, method.name, 'Proxy object null for update');
			return false;
		endif;
	endif;
	
	pxyDefinedText := theForm.myProxyObject.CM_DefinedText;
    pxyDefinedText.setProxy(context,sortOrder, isNotAvailableForEntry,text, terminal);
	
	if theForm.mode = theForm.Mode_Add then
		app.myTrxCA.trxCreateDefinedText(pxyDefinedText, newDefinedText, app.myPassport);
	elseif theForm.mode = theForm.Mode_Update then
		app.myTrxUA.trxUpdateDefinedText(pxyDefinedText, app.myPassport);
	endif;
	
	return app.myPassport.trxCompletedOK();
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
