    <JadeMethod name="validateForUpdate" id="109d8950-6999-43ff-b759-2359231e272f">
        <source>validateForUpdate();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 June 2009	cnwndl1	Initial creation

*/

vars

begin
	
	if self.myWagonClass = null 	then
		app.raiseCMException2(ERR_INVALID_VALUE, app.getErrorString(Associated_object), app.getErrorString(Wagon_posit_rule_must_assoc_wi), null, null);
		return;
	endif;

	self.validateMe;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="validateMe" id="bcceb894-3ce1-41cc-8a12-e6d14e6b20bf">
        <source>validateMe() protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 June 2009	cnwndl1	Initial creation

*/

vars

	position : CM_WagonPosition;
	totalPosWeights : Decimal [12,2];
	maxCargoWeight : Decimal [12,2];
	
begin

	if self.numberOfPositions &lt; 1 or self.numberOfPositions &gt; 4 then
		app.raiseCMException(Number_foot_positio_must, null, null);
		return;
	endif;
	
	position := allWagonPositions.last;
	if position.extendsBeyondPosition &gt; 0 then
		app.raiseCMException(Inval_posit_lengt_cargo_over, null, null);
		return;
	endif;
	
	
	
	if self.myWagonClass &lt;&gt; null then
		maxCargoWeight := self.myWagonClass.maxLoadWeight;
	endif;
	
	if maxCargoWeight &gt; 0 then
		foreach position in allWagonPositions do
			totalPosWeights := totalPosWeights + position.maxWeight;
		endforeach;
		if totalPosWeights &gt; maxCargoWeight then
			app.raiseCMException2(ERR_INVALID_VALUE, app.getErrorString(Least_one_position_weight),
					app.getErrorString(Total_weights_entered) &amp; totalPosWeights.asStringJMT
					&amp; "' " &amp; app.getErrorString(Which_exceed_wagon_cargo_weigh) &amp; " '" &amp; maxCargoWeight.asStringJMT &amp; "'.", null, null);
			return;
		endif;
	endif;

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
</Class>
