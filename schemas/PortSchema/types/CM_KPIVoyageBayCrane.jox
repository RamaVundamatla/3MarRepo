vars

begin
	return true;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="d4112b70-8004-4c53-bb98-3a1eda577a0a">
        <updating/>
        <source>setForCreate(_pxyMe: SelfType) updating;
/*
Date		    Who			Reason
16 June 2010	cnwas3	  	Initial creation
08/08/2011		cnwcs5		CCMS MES 1033 - RORO KPI
*/
vars

begin
	inheritMethod(_pxyMe);
	
	self.myCrane 		:= _pxyMe.myCrane;
	self.myVoyage 		:= _pxyMe.myVoyage;	
	self.myVessel 		:= _pxyMe.myVessel;
	self.myBayVoyage 	:= _pxyMe.myBayVoyage;
	self.myBayVessel 	:= _pxyMe.myBayVessel;
	
	self.getNumLids();
epilog

end;</source>
        <Parameter name="_pxyMe" type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setFromTransaction" id="bd3365e5-4df8-4534-a17e-c89877f3faf3">
        <updating/>
        <source>setFromTransaction(_shipTran : CM_TITransaction) updating;
// ---------------------------------------------------------------------------
// Created:     MAY 2010 ANDREW BISHOP
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
// 08/08/2011		cnwcs5			CCMS MES 1033 - RORO KPI
// ---------------------------------------------------------------------------

vars
	
begin

	if _shipTran &lt;&gt; null and (not _shipTran.isChild) then 	// 27 Jul 2010	NDL	Par 23056
		inheritMethod (_shipTran);
		
		self.setTotalTimeAndRate(); 								// PAR 25363
	endif;
end;</source>
        <Parameter name="_shipTran" type="CM_TITransaction"/>
    </JadeMethod>
    <JadeMethod name="setKPI" id="7b6c1d68-25a3-469a-9a5c-625a6c224f62">
        <updating/>
        <source>setKPI(_crane : CM_Crane; _js : CM_VoyageJobSheet; _voy : CM_Voyage; _terminal : CM_Terminal; _bayVoy : CM_BayVoyage; _bayVess : CM_BayDefn) updating;
// ---------------------------------------------------------------------------
// Created:		01 May 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
begin
	if _crane &lt;&gt; null then										//cnwas3 ccms 1134
		self.code := _voy.code &amp; "/" &amp; _crane.id &amp; "/" &amp; _bayVoy.id;
	else
		self.code := _voy.code &amp; "/" &amp; _js.crane &amp; "/" &amp; _bayVoy.id;
	endif;
	
	self.dateTime := _voy.shipExchangeDate;
	
	if not self.dateTime.isValid() then
		self.dateTime := _voy.arrivedDT;
	endif;
	
	if not self.dateTime.isValid() then
		self.dateTime := app.actualTimeServer;
	endif;
	
	self.userCode := app.myPassport.userCode;

	self.myCrane 		:= _crane;
	self.myVoyage 		:= _voy;
	self.myTerminal 	:= _terminal;
	self.myVessel 		:= _voy.getMyVessel();
	self.myBayVoyage 	:= _bayVoy;
	self.myBayVessel 	:= _bayVess;
	
	self.getNumLids();
end;</source>
        <Parameter name="_crane" type="CM_Crane"/>
        <Parameter name="_js" type="CM_VoyageJobSheet"/>
        <Parameter name="_voy" type="CM_Voyage"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_bayVoy" type="CM_BayVoyage"/>
        <Parameter name="_bayVess" type="CM_BayDefn"/>
    </JadeMethod>
    <JadeMethod name="setTotalTimeAndRate" id="793fa44a-9924-4955-94b1-5c1d49921b6b">
        <updating/>
        <source>setTotalTimeAndRate() updating;
// ---------------------------------------------------------------------------
// Created:		19 September 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// 23/08/2011	cnwcs5	CCMS MES 1033 RORO KPI - renamed method and moved some code to superclass
// 29/05/2015	cnwma1  PAR #35561 Archive Voyages
vars
	length 		: Real;
begin

	if self.myCrane &lt;&gt; null then								// 29/05/2015 cnwma1 PAR #35561
		length := self.calculateTotalTime( self.myCrane.getID );
	else
		length := 0;
	endif;
	self.totalTime := length;
	
	if length &lt;&gt; 0 then
		self.totalRate := self.movesTI / length;
	else
		self.totalRate := 0;
	endif;
end;</source>
    </JadeMethod>
</Class>
