    <JadeMethod name="showHideArea" id="f7c26d6f-8cf6-4282-a5c1-9545251d11c8">
        <updating/>
        <source>showHideArea(_area : Integer;_value : Boolean) updating, protected;
/*

Purpose:			


Return Value:		


Date		Who		Reason
26 September 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars
	cmifRoadOpObject : CMIF_RoadOpObject;
	db					: JadeDockBar;
begin
	if _area = Macro then
		if _value then
			self.dockAreaHeightPCent := 85;
		else
			self.dockAreaHeightPCent := 100;
		endif;
	else
		if self.allCMIFRoadOpObjects.size &lt; _area then
			return;
		endif;
		cmifRoadOpObject:=self.allCMIFRoadOpObjects[_area];
		if cmifRoadOpObject = null then
			//nothing has changed that needs resising
			return;
		else
			if cmifRoadOpObject.myDockBar &lt;&gt; null then
				db:=cmifRoadOpObject.myDockBar;
				if db &lt;&gt; null then
					db.visible:= _value;
				endif;
			else
				//nothing to resize
				return;
			endif;
		endif;
	endif;
	
epilog
	
end;</source>
        <access>protected</access>
        <Parameter name="_area" type="Integer"/>
        <Parameter name="_value" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="updateElapsedTimes" id="df58bb96-09ad-4f43-9b54-b38c39f346cd">
