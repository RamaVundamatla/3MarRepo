    <JadeMethod name="handleLoadPort" id="6d55cef6-60f1-4275-98c5-9e17980407d2">
        <source>handleLoadPort(_portCode : String; _code : String output; _color :Integer output; _object : Object output) protected;
// ---------------------------------------------------------------------------
// Created:     26 August 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	iter		: Iterator;
	trimCode,
	theCode,
	codeKey		: String;
	theColor,
	colorKey	: Integer;
	tmpPort		: CM_Port;
	theObject : Object;
begin

	trimCode := _portCode.trimBlanks;
	
	if trimCode = null then
		_code 	:= null;
		_color	:= NullColour;
		return;
	endif;

	iter := self.myIterLoadPort;
	self.allLoadPorts.startKeyGeq(trimCode, 0, iter);
	self.allLoadPorts.getIteratorKeys(codeKey, colorKey, iter);
	
	if codeKey = trimCode then
		// found the right one
		theCode		:= trimCode;
		theColor	:= colorKey;
		iter.next(theObject);
	else
		//tmpPort := self.myRoot.allPorts[trimCode];
		tmpPort := self.myRoot.allPorts[trimCode];
		if tmpPort &lt;&gt; null then
			self.allLoadPorts.add(tmpPort);
			self.beginNotification(tmpPort, EVENT_CODE_COLOUR_CHANGE, Response_Continuous, null);
			theCode		:= trimCode;
			theColor	:= tmpPort.colour;
			theObject := tmpPort;
		else
			theCode		:= null;
			theColor	:= NullColour;
		endif;
	endif;

	_code	:= theCode;
	_color	:= theColor;
	_object := theObject;

end;</source>
