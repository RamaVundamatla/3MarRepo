    <JadeMethod name="includesYardAllocationCriteria" id="c95a8f45-9e79-4f42-9d3b-0433a15b6e93">
        <source>includesYardAllocationCriteria(_criteriaType : Class; _value : Any; _includeTemplates : Boolean): Boolean;
 // PAR 15984 added _includeTemplates
// Created by cnwdvb1 on 20 August 2007
 // CCMS 1574
vars

	allocation	: CM_YardAllocation;
	criteria	: CM_YACriteria;
	data		: CM_YAData;

begin

	// Nothing to do so return false;
	if self.allYardAllocations.isEmpty() then
		return false;
	endif;
	
	// What type of data is being passed in.
	if _value.isKindOf(Integer) then
		create data as CM_YADataInteger transient;
		data.CM_YADataInteger.addAValue(_value.Integer);
	elseif _value.isKindOf(Object) then
		create data as CM_YADataObjects transient;
		data.CM_YADataObjects.addAValue(_value.Object);
	elseif _value.isKindOf(Boolean) then
		create data as CM_YADataBoolean transient;
		data.CM_YADataBoolean.addAValue(_value.Boolean);
	else
		return false;
	endif;
	
	// Take a look at all allocations for this location. Is there
	// a criteria that matches the type we are after and does the
	// data matched that which was passed in.
	foreach allocation in self.allYardAllocations discreteLock do
		if not _includeTemplates and allocation.isYASnapshot() then // PAR 15984
			continue; // PAR 15984
		endif; // PAR 15984
		foreach criteria in allocation.allCriteria discreteLock do
			if criteria.myYACriteriaType.isKindOf(_criteriaType) and 
			criteria.myYAData.doDataComparison(data) then
				return true;
			endif;
		endforeach;
	endforeach;
	
	return false;

epilog	
	delete data;
end;</source>
        <Parameter name="_criteriaType" type="Class"/>
        <Parameter name="_value" type="Any"/>
        <Parameter name="_includeTemplates" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
