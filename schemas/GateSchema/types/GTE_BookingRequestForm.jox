    <JadeMethod name="hasAdditionalDetails" id="0130c30a-e665-4c08-b9db-178d1a45e6b5">
        <source>hasAdditionalDetails():Boolean;

vars

begin
	return self.cmbPoolPartner.listObject &lt;&gt; null
	or self.txtDispatchLocn.text.trimBlanks &lt;&gt; null
	or self.cmbSpecialStow.listObject &lt;&gt; null
	or self.cmbPriority.listObject &lt;&gt; null
	or self.cmbDelivRelReasn.listObject &lt;&gt; null
	or self.chkFumigation.value
	or self.chkHoldPartials.value
	or self.chkMilitary.value
	or self.chkNoEmptiesOut.value
	or self.chkNoFullsIn.value
	or self.chkOverDimension.value
	or self.chkOverrideCut.value
	or self.chkStopped.value
	or self.chkReceiveAsStoc.value
	or self.chkRecieveAsTran.value 
	or self.cmbPackAs.listIndex &gt; 0; //epr par 36556 6/7/15
end;
</source>
