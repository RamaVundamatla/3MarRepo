<GUIClass name="GTE_EditBarrierInTimeForm" id="46fb39ff-bc96-483c-8054-da6bba21b9c5">
    <superclass name="CMUI_Modal"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <ImplicitInverseRef name="lblBarrierInTime" id="9ecc8831-91b5-4776-8f60-8bb0608594a2">
        <embedded/>
        <type name="CMUI_Label"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="txtBarrierInDate" id="04141401-0616-4796-8251-4e3b107d0f47">
        <embedded/>
        <type name="CMUI_DateMask"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="txtBarrierInTime" id="96f81f91-0458-41e2-848a-a8db106bd5b5">
        <embedded/>
        <type name="CMUI_TimeMask"/>
    </ImplicitInverseRef>
    <JadeMethod name="doOK" id="9e5def53-dde3-44cf-bcb9-10116fd77a4f">
        <updating/>
        <source>doOK() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 May 2023	jlier1	Initial creation

*/

vars

begin
	if not self.txtBarrierInDate.getDate.isValid then
			app.raiseCMException(Date_Enter_Valid,null,null);
		return;
	endif;
	
	
	if (not self.txtBarrierInTime.getTime.isValid) or self.txtBarrierInTime.getTime = null then
		app.raiseCMException(Time_Enter_Valid,null,null);
		return;
	endif;
	inheritMethod();

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="8867874e-7b6b-4f4a-8f9d-6a4f135ff2a4">
        <updating/>
        <source>setupForm() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 May 2023	jlier1	Initial creation

*/

vars

begin
	inheritMethod();
	self.txtBarrierInDate.setDate(app.actualTimeAppServer.date);
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="e90a21b5-cd7c-46c8-ba4d-111d36648bbb">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 25 May 2023 09:17:29.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0026066, locale);
	lblBarrierInTime.translateCaption(Xlat_0026067, locale);
end;</source>
    </JadeMethod>
</GUIClass>
