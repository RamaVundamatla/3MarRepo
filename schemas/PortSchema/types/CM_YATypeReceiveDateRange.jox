        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="isCMIFDataMatch" id="9fd1d64f-c8e0-4c65-a811-683eea0bd488">
        <source>isCMIFDataMatch(_cmifAutoPlan: CMIF_YAAutoPlan; _yaData: CM_YAData): Boolean;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 27/05/2025	navdap1		Initial creation MTN-34981 MTN -Yard Allocations - Storing Cargo Based on a Date Range
//
vars
	receiveDate, startDate, endDate : Date;
	ti : CM_TrackedItem;
	reserveCriteria : CM_ReleaseByTypeCriteria;
	criteria : CM_YACriteria;
	
begin
	receiveDate := null;
	startDate := null;
	endDate := null;
	
	ti := _cmifAutoPlan.getMyTrackedItem();
	if ti &lt;&gt; null then
		self.getCriteriaValueForTi(ti, receiveDate);
		
	else
		// We're probably for a release request
		reserveCriteria := _cmifAutoPlan.getReserveSelectionCriteria();
		if reserveCriteria &lt;&gt; null then
			foreach criteria in reserveCriteria.allCriteria where criteria.myYACriteriaType.isReceiveDateRange do
				startDate := criteria.myYAData.CM_YADataDateRange.startDate;
				endDate := criteria.myYAData.CM_YADataDateRange.endDate;
			endforeach;
		endif;
	endif;
	
	if receiveDate.isValid then
		return receiveDate &gt;= _yaData.CM_YADataDateRange.startDate and receiveDate &lt;= _yaData.CM_YADataDateRange.endDate;
		
	elseif startDate.isValid then
		// This gets a bit tricky - we're comparing date ranges
		// So let's only match if the date range in the release request is entirely within the range on the yard allocation
		if startDate &gt;= _yaData.CM_YADataDateRange.startDate and startDate &lt;= _yaData.CM_YADataDateRange.endDate
		and endDate &gt;= _yaData.CM_YADataDateRange.startDate and endDate &lt;= _yaData.CM_YADataDateRange.endDate then
			return true;
		endif;
	endif;
	
	return false;
	
epilog

end;</source>
        <Parameter name="_cmifAutoPlan" type="CMIF_YAAutoPlan"/>
        <Parameter name="_yaData" type="CM_YAData"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isReceiveDateRange" id="5c6cc810-d8fd-4123-9866-1017f0d977fa">
        <source>isReceiveDateRange(): Boolean;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 13/06/2025	navdap1		Initial creation MTN-34981 MTN -Yard Allocations - Storing Cargo Based on a Date Range
//
vars

begin
	return true;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
