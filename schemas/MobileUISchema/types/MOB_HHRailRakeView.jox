    <JadeMethod name="populateListRakeWagons" id="772f8f66-43b9-4b9b-b0c4-288c47efbcb8">
        <source>populateListRakeWagons();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
05 April 2017   cnwsc8  refactor to move to CM_RailLine for access by MTM web service
23 August 2010	cnwndl1	Initial creation

*/

vars
	jdoArray : JadeDynamicObjectArray;
	jdo : JadeDynamicObject;
	railLine : CM_RailLine;
	index : Integer;
	
begin
	railLine := self.myMobileGenericAgent.myCurrentRailLine;
	self.lstRakeWagons.clear;
	
	jdoArray := railLine.getWagonSummary(self.myMobileGenericAgent.inward, self.myMobileGenericAgent.myCurrentTrain, self.myMobileGenericAgent.allConfirmedTis, null);
	foreach jdo in jdoArray do
		index := lstRakeWagons.addItem(jdo.getPropertyValue("text").String);
		lstRakeWagons.itemObject[index] := jdo.getPropertyValue("object").Object;
		lstRakeWagons.itemData[index] := jdo.getPropertyValue("level").Integer;
		lstRakeWagons.itemForeColor[index] := jdo.getPropertyValue("color").Integer;
	endforeach;
	
	self.setButtons;

epilog
	//epr TFS 
	if jdoArray &lt;&gt; null then
		jdoArray.purge;
	endif;
	delete jdoArray;
end;

</source>
    </JadeMethod>
    <JadeMethod name="setButtons" id="e9ac2612-3bcd-437f-b354-d282010154cd">
        <source>setButtons();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
23 August 2010	cnwndl1	Initial creation	Par 25215

*/

vars

	currentIndex : Integer;
	currentWagon : CM_Wagon;
	index : Integer;
	currentRakePos : Integer;
	railLine : CM_RailLine;
	wagon : CM_Wagon;
	hasSpace : Boolean;
	
	
begin

	//default position
	self.btnWagonInsert.enabled := false;
	self.btnWagonUpdate.enabled := false;

	currentIndex := self.lstRakeWagons.listIndex;
	if currentIndex &lt; 1 or currentIndex &gt; self.lstRakeWagons.listCount then
		return;
	endif;
	
	// any valid selection is updateable.
	self.btnWagonUpdate.enabled := true;
	
	//only need to worry about insert from here on
	currentRakePos := self.lstRakeWagons.itemData[currentIndex];
	currentWagon := lstRakeWagons.itemObject[currentIndex].CM_Wagon;
	if currentRakePos &gt; 0 and currentWagon = null then	// we have an empty position - that is definitely 'insert' able.
		self.btnWagonInsert.enabled := true;
		return;
	endif;
	
	// OK any other insert requires a free space on the rail line.
	railLine := self.myMobileGenericAgent.myCurrentRailLine;
	foreach index in 1 to railLine.maximumWagons do
		wagon := railLine.getWagonAtPosition(index);
		if wagon = null then
			// here's  blank space.
			// to really be sure we actually have to check that the interveneing wagons can be moved,
			//i.e. that they have not already been confirmed.
			// But, if we do that now, we will confuse the users, cause they can't see that from here.
			// Better to just raise a awrning when they attempt it. (whihc we do in teh method when they click the button.)
			self.btnWagonInsert.enabled := true;
			return;
		endif;
	endforeach;
		
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupControls" id="f86f024d-2332-4af7-ace6-5cb98b196f77">
        <updating/>
        <source>setupControls() updating;

/*

Purpose:			

Parameters:			

Return Value:		


