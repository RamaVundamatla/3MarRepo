vars

begin

	self.isAudited := true;

end;</source>
    </JadeMethod>
    <JadeMethod name="getAfterValue" id="ee6c72cb-d7a0-47f6-b39f-5bf87b357de3">
        <source>getAfterValue() : String;
// ---------------------------------------------------------------------------
// Created:     09 September 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	pos		: Integer;	
	value	: String;
begin

	value := self.afterValue;
	if value = null then
		return null;
	endif;
	
	if value.length &lt; 2 then
		return null;
	endif;
	
	pos := 2;
	return value.reverse.scanUntil(AuditStringSeparator,pos).reverse;

	
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getBeforeValue" id="44e0d428-d42e-4a86-84ca-7ea3b37014d1">
        <source>getBeforeValue():String;
//----------------------------------------------------------------
//	Created:	09 September 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	value	: String;
	pos		: Integer;
begin

	value := self.beforeValue;
	if value = null then
		return null;
	endif;
	
	if value.length &lt; 2 then
		return null;
	endif;
	
	pos := 2;
	return value.reverse.scanUntil(AuditStringSeparator,pos).reverse;
	
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="init" id="38ffc1b8-900d-47f5-ac6f-af5def8455fe">
        <updating/>
        <source>init(_prop : Property; _class : Class; _controller : CM_AuditController) updating;
// ---------------------------------------------------------------------------
// Created:     20 May 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin

	self.attrName			:= _prop.name;
	self.myClass			:= _class;
	self.myProperty			:= _prop;

	// now set the inverse
	self.myAuditController	:= _controller;
	
end;</source>
        <Parameter name="_prop" type="Property"/>
        <Parameter name="_class" type="Class"/>
        <Parameter name="_controller" type="CM_AuditController"/>
    </JadeMethod>
