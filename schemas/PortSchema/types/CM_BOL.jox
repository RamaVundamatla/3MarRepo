    <JadeMethod name="getLastestScalingEndTs" id="eea8ce09-9cf3-49f9-ac35-60ecb4c2ca13">
        <source>getLastestScalingEndTs() : TimeStamp;

vars

	trns		: CM_BOLTransaction;
	scalerTrns	: CM_BOLInScalerTransaction;
	ts			: TimeStamp;

begin

	// Go through transactions because dictionary is ordered by when transaction
	// was created not scaler times.
	ts := null;
	foreach trns in self.allBOLTransactions do
		if trns.type = TRANS_TYPE_BOLIN_SCALER then
			scalerTrns := trns.CM_BOLInScalerTransaction;
			if scalerTrns.scalingFinishTime &gt; ts or ts = null then
				ts := scalerTrns.scalingFinishTime;
			endif;
		endif;
	endforeach;
	return ts;

end;</source>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
