    <JadeMethod name="testAutoPlanReqIds" id="e992f8a3-a5d8-491e-9371-47fcece9e65c">
        <source>testAutoPlanReqIds(obj: CMIF_AutoMovePlan input);
//Tests the Request against the IDs supplied (or not supplied...)
// 24/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
vars
	numStrs	:	Integer;
	tiId	:	String;
	req	:	CM_DeliveryRequest;
	strsObj	:	CM_Strings;
	iter	:	Iterator;
	aTI	:	CM_TrackedItem;
	totalNumMatched	:	Integer;
	totalRequested	:	Integer;
begin
	if obj.isTestToBeDone(TI_Test_IDMasking, self) = false then
		return;
	endif;
	//---------------
	//Test the request
	//-------------
	req := obj.request;
	strsObj := req.ids;
	if strsObj = null then	
		//No strings to test, quit...
		//obj.addVerboseLogEntry("No Identification masks to test on Request.", IsForLogging, 0); //- cnwmd1, Par 20524
		obj.addVerboseLogEntry(app.getErrorString(Identif_masks_test_request), IsForLogging, Identif_masks_test_request);
		return;
	endif;
	numStrs := strsObj.numStrings;
	if numStrs = 0 then
		//No strings to test, quit...
		//obj.addVerboseLogEntry("No Identification masks to test on Request.", IsForLogging, 0); //- cnwmd1, Par 20524
		obj.addVerboseLogEntry(app.getErrorString(Identif_masks_test_request), IsForLogging, Identif_masks_test_request);
		return;
	endif;
	//----------------
	//Build an iterator
	//----------------
	totalNumMatched := 0;
	totalRequested := req.totalRequested;

	iter := allTrackedItems.createIterator;

	while iter.next(aTI) do
		tiId := aTI.id.trimRight;
		//obj.addVerboseLogEntry("Identification Masking, Testing Id " &amp; tiId &amp; " against Mask.", IsForLogging, 0); //- cnwmd1, Par 20524
		obj.addVerboseLogEntry(app.getErrorString1(Identi_maskin_testin_agains_ma,tiId), IsForLogging, Identi_maskin_testin_agains_ma);
		if req.ids.compareIDStrings(tiId) then
			//------------------
			//OK, its suitable against the request.
			//Might as well test this TI at the same time.
			//------------------
			//obj.addVerboseLogEntry("Identification Masking, " &amp; tiId  &amp; " passed mask test, testing potentially good Item..", IsForLogging, 0); //- cnwmd1, Par 20524
			obj.addVerboseLogEntry(app.getErrorString1(Ident_maski_passe_mask_test_te,tiId), IsForLogging, Ident_maski_passe_mask_test_te);
			obj.updateController(self);
	 		aTI.testAutoPlanRequest(obj);	//This over-writes it if NOT
			if obj.getController &lt;&gt; null then
				//----------------
				//This is a Good TI
				//----------------
				totalNumMatched := totalNumMatched +1;
	  	endif;
		endif;
		if totalNumMatched &gt;= totalRequested then
			//obj.addLogEntry("Identification Masking, found correct number of Items matching mask.", IsForLogging); //- cnwmd1, Par 20524
			obj.addLogEntry(app.getErrorString(Ident_maski_found_corre_numbe_), IsForLogging, Ident_maski_found_corre_numbe_);
			return;	//Good enough for us, quit now.!
		endif;
	endwhile;
	if totalNumMatched = 0 then
		//There are NONE at all here that are worth checking!
		//obj.addLogEntry("Identification Masking Test found no suitable items for the ID's supplied in the request.", IsForLogging); //- cnwmd1, Par 20524
		obj.addLogEntry(app.getErrorString(Ident_maski_test_found_suita_i), IsForLogging, Ident_maski_test_found_suita_i);
		obj.updateController(null);
		return;
	endif;
	if totalRequested &gt; totalNumMatched then
		//Not enough here.. Quit
		//obj.addLogEntry("Insufficient Matched items in this area to satisfy request. (Found " &amp; totalNumMatched.String &amp; ", need " &amp; obj.request.totalRequested.String &amp; ", area contains " &amp;   totalNumMatched.String &amp; " that match Ids, need " &amp; totalRequested.String &amp; ". Skipping this area.", IsForLogging); //- cnwmd1, Par 20524
		obj.addLogEntry(app.getErrorString4(Insuf_match_items_this_area_sa, totalNumMatched.String, obj.request.totalRequested.String, totalNumMatched.String, totalRequested.String), IsForLogging, Insuf_match_items_this_area_sa);
		obj.updateController(null);
		return;
	endif;
epilog
	delete iter;
end;</source>
        <Parameter name="obj" type="CMIF_AutoMovePlan" usage="input"/>
    </JadeMethod>
    <JadeMethod name="testAutoPlanReqIdsYA" id="61e9df13-dd21-4942-bf8c-57cc2df8cd78">
        <source>testAutoPlanReqIdsYA(_yaAgent : CM_YAAutoplanAgent input) : Boolean;
//Tests the Request against the IDs supplied (or not supplied...)
vars
	
begin
	
	return false;
end;</source>
        <Parameter name="_yaAgent" type="CM_YAAutoplanAgent" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="testAutoPlanRequest" id="4fd70a1d-74ea-421e-bff0-e67ccabeef51">
        <source>testAutoPlanRequest(obj: CMIF_AutoMovePlan input);
//Request based testing only, looking for SOURCE of TI's
// 24/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
vars
	ti : CM_TrackedItem;
	i : Integer;
	numToCheck : Integer;
	searchBothEnds : Boolean;
	msgStr : String;
	testAll	:	Boolean;
	numToTest	:	Integer;
	halfWayPoint		:	Integer;
	totalWeNeed	: Integer;			//AJA 3/9/99
	itemsFound : Integer;
begin
	//---------------
	//check the Restrictions on this area.
	//---------------

	//obj.addLogEntry("Testing Restrictions", IsForLogging); //- cnwmd1, Par 20524
	obj.addLogEntry(app.getErrorString(Testing_restrictions), IsForLogging, Testing_restrictions);
	testIsControllerRestricted(obj);
	if obj.getController = null then
		//Restriction in force!
		//obj.addVerboseLogEntry("Restrictions found, skipping", IsForLogging); //- cnwmd1, Par 20524
		obj.addVerboseLogEntry(app.getErrorString(Restrictio_found_skipping), IsForLogging, Restrictio_found_skipping);
		return;
	endif;
	//------------------
	//We check for the number of TI's that exist here. 
	//No point sending a machine all over the place to satisfy requests.
	//------------------
	//obj.addVerboseLogEntry("Testing For total requested", IsForLogging); //- cnwmd1, Par 20524
	obj.addVerboseLogEntry(app.getErrorString(Testing_total_requested), IsForLogging, Testing_total_requested);
	if obj.request.totalRequested = 0 then
		//Silly! Quit
		obj.updateController(null);
		return;
	endif;
	if obj.request.totalRequested &gt; self.allTrackedItems.size then
		//Not enough here.. Quit
		//obj.addLogEntry("Insufficient objects in this area to satisfy request (need " &amp; obj.request.totalRequested.String &amp; ", area contains " &amp;   self.allTrackedItems.size.String &amp; ".. Skipping.", IsForLogging);
		obj.addLogEntry(app.getErrorString2(Insuf_objec_this_area_satis_re, obj.request.totalRequested.String, self.allTrackedItems.size.String), IsForLogging, Insuf_objec_this_area_satis_re);
		obj.updateController(null);
		return;
	endif;

	totalWeNeed := obj.request.totalRequested;
	//-------------------
	//Do they want to attempt ID masking?
	//-------------------
	if obj.isTestToBeDone(TI_Test_IDMasking, self) = true then
		//----------------------
		//Test using ID masking (users are supplying ID's
		//----------------------
		//obj.addLogEntry("Testing Identification Masking.", IsForLogging);//- cnwmd1, Par 20524
		obj.addLogEntry(app.getErrorString(Testing_identifica_masking), IsForLogging, Testing_identifica_masking);
		if obj.request.ids = null or obj.request.ids.numStrings = 0 then
			//No strings to test, continue..
			//obj.addVerboseLogEntry("No Identification masks to test on Request.", IsForLogging);
			obj.addVerboseLogEntry(app.getErrorString(Identif_masks_test_request), IsForLogging, Identif_masks_test_request);
		else
			//--------------
			//Test the id mask
			//--------------
			self.testAutoPlanReqIds(obj);
			//-----------------
			//ALWAYS RETURN. This method checks any TI's that are OK in terms of an id
			//against the request (as below) at the time its ok'ing it for continuing.
			//If the total # are not right, it quits.
			//-----------------
	 		return;
		endif;

	endif;
	//-------------
	//OK, we either have the correct # for ids in the stack...
	//Grab TI's, see if these are any good.
	//-------------
 	numToTest := self.myTerminalArea.autoPlanTest.maxInBlockToTest;
	testAll := ( numToTest = 0 );

	numToCheck := self.allTrackedItems.size;  //Check em all
  if numToCheck = 0 then
  	//aint nothing here!
		obj.updateController(null);
		return;
  endif;
	searchBothEnds := false;
	if testAll then
		obj.addVerboseLogEntry(app.getErrorString1(Conti_check_acces_objec_this_a,numToCheck.String), IsForLogging, Conti_check_acces_objec_this_a);
	else
		if self.allTrackedItems.size &gt; numToTest then
	 		searchBothEnds := true;
			numToCheck := numToTest;
	 		//msgStr := "Continuing to check maximum of " &amp; numToCheck.String &amp; " accessible Objects from each end of this area. (" &amp; self.allTrackedItems.size.String &amp; " in stack)";
			obj.addVerboseLogEntry(app.getErrorString2(Conti_check_maxim_acces_objec_,numToCheck.String, self.allTrackedItems.size.String), IsForLogging, Conti_check_maxim_acces_objec_);
	 		halfWayPoint := self.allTrackedItems.size div 2;
	 	endif;
	endif;
	//obj.addVerboseLogEntry(msgStr, IsForLogging); //- cnwmd1, Par 20524
	i := 1;
	itemsFound := 0;
	foreach ti in allTrackedItems do
		//-------------------
		//Default to the fact this is an OK area.
		//-------------------

		obj.updateController(self);
 		ti.testAutoPlanRequest(obj);	//This over-writes it if NOT
		if obj.getController &lt;&gt; null then
	 	 	//Located one!
	 	 	itemsFound := itemsFound + 1;
	 	 	if itemsFound &gt;= totalWeNeed then
	  			return;       //We have found enough in here to satisfy the request
		  	endif;
		else
  		endif;

  		//-----------------
	 	//Only check as many as we need to, if they have specified a total that is &gt; 
	 	///1/2 tis in area, only check 1/2.
	 	//-----------------
		if not testAll and ( i = numToCheck  or i = halfWayPoint) then
			break;
		endif;
		i := i +1;
 	endforeach;
 	msgStr := "";
 	if searchBothEnds then
		//obj.addVerboseLogEntry("Searching " &amp; numToCheck.String &amp; " from reverse end.", IsForLogging); //- cnwmd1, Par 20524
		obj.addVerboseLogEntry(app.getErrorString1(Searching_from_reverse,numToCheck.String), IsForLogging, Searching_from_reverse);
		i := 1;
		itemsFound := 0;
		foreach ti in allTrackedItems reversed do
			obj.updateController(self);
	  		ti.testAutoPlanRequest(obj);
		  	if obj.getController &lt;&gt; null then
		  		//Located one!
	 	 			itemsFound := itemsFound + 1;

	 	 			if itemsFound &gt;= totalWeNeed then
	  				return;    //We have found enough in here to satisfy the request
	  			endif;
	  	 	endif;
		  	//-----------------
		  	//Only check as many as we need to, if they have specified a total that is &gt; 
		  	///1/2 tis in area, only check 1/2.
		  	//-----------------
			if i = numToCheck or i = halfWayPoint then
				break;
			endif;
		 	i := i +1;
		endforeach;
	endif;
end;</source>
        <Parameter name="obj" type="CMIF_AutoMovePlan" usage="input"/>
    </JadeMethod>
    <JadeMethod name="testAutoPlanRequestYA" id="d196514a-236e-4b64-a534-57dc3f1124ac">
        <source>testAutoPlanRequestYA(_yaAgent : CM_YAAutoplanAgent input) : Boolean;
//Request based testing only, looking for SOURCE of TI's
// 24/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
// 07/01/2015   cnwma1      PAR #37313 Release Requests - Yard Areas
vars

	totalFound,
	totalWeNeed	: Integer;
	cmifRequest	: CMIF_YARequest;
	ti			: CM_TrackedItem;
	testIds		: Boolean;
	tiId		: String;
	bulkRelease	: CM_BulkRelease;
	fMove		: CM_FutureMove;
	wle			: CM_WorkListEntry;
	assignedTIs : CM_TISet;
begin
	

	cmifRequest := _yaAgent.myCurrentCMIFYAAutoPlan.CMIF_YARequest;
	
	if cmifRequest.totalRequested &gt; self.allTrackedItems.size then
		//Not enough here.. Quit
		_yaAgent.addLogEntry(AP_Log_YA_Default,"Insufficient objects in this area to satisfy request (need " &amp; cmifRequest.totalRequested.String &amp; ", area contains " &amp;   self.allTrackedItems.size.String &amp; ".. Skipping.", true);
		return false;
	endif;

	if cmifRequest.ids.isEmpty() then
	else
		_yaAgent.addLogEntry(AP_Log_YA_Default,"Identification masks to test on Request.", true);
		testIds := true;
	endif;

	if cmifRequest.isDeliveryRequest then	//05 Apr 2016	NDL	TFS 1779
		totalWeNeed := cmifRequest.totalRequested;
	elseif cmifRequest.myReserveSelection &lt;&gt; null then                   // 07/01/2015 cnwma1 PAR #37313 
		if cmifRequest.myReserveSelection.myCargoType &lt;&gt; null then
			if cmifRequest.myReserveSelection.myCargoType.id = TI_CargoType_Container then
				totalWeNeed :=cmifRequest.myReserveSelection.totalRequested;
			else 
				totalWeNeed := cmifRequest.totalRequested;
			endif;
		endif;
	else
		totalWeNeed := cmifRequest.totalRequested;
	endif;
	
	if cmifRequest.isDeliveryRequest then
		bulkRelease := cmifRequest.myDeliveryRequest.myOriginatingBulkRelease;
	endif;
	//cnwrd1 par 31623 we may be working a release item that hasnt been manually assigned so we do not want to exclude non assigned ti's as we normally would 30.5.2013
	create assignedTIs transient;	
	if bulkRelease &lt;&gt; null and not bulkRelease.allTrackedItemsAssigned.isEmpty then
		bulkRelease.getAvailableAssignedTis( assignedTIs, cmifRequest.myDeliveryRequest );	//24 Apr 2020	NDL	TFS 49095  // ### TFS 52721 16NOV2022 NAVAB1
	/*	foreach ti in bulkRelease.allTrackedItemsAssigned do
			//epr par 33595 4/3/14
			if ti.hasBeenMerged then
				continue;
			endif;
			
			if ti.myPrimaryActualLocation.isVehicle 
			or ti.myPrimaryActualLocation.isMachineController
			or ti.myPrimaryActualLocation.isYardInterchangeAreaLocation then
				continue;
			endif;				
			assignedTIs.add(ti);			
		endforeach; */
	endif;	

	foreach ti in self.allTrackedItems discreteLock do : outerLoop
		// Don't count tis that have already been used.
		if _yaAgent.myCurrentCMIFYAAutoPlan.allKeepTrackedTis.includes(ti) then
			_yaAgent.addLogEntry(AP_Log_YA_Default,'Item ' &amp; ti.id &amp; ' has already been allocated.', true);
			totalFound := totalFound + 1;
			continue;
		endif;
		
		if not ti.allQueuedFutureMoves.isEmpty() then
			foreach fMove in ti.allQueuedFutureMoves do
				wle := fMove.myWorkListEntry;
				if wle = null then
					_yaAgent.addLogEntry(AP_Log_YA_Default,'Could not determine wle from queued move skipping..', true);
					continue outerLoop;
				elseif wle.job = _yaAgent.myCurrentJob then
					_yaAgent.addLogEntry(AP_Log_YA_Default,'Item (' &amp; ti.id &amp; ') is already queued to job, skipping ... ' &amp; wle.job.jobId, true);
					continue outerLoop;
				else
					_yaAgent.addLogEntry(AP_Log_YA_Default,'Item (' &amp; ti.id &amp; ') is queued to a different job stopping...', true);
					continue outerLoop;
				endif;
			endforeach;
		endif;
		
		if testIds then
			tiId := ti.id.trimRight;
			if cmifRequest.ids.compareIds(tiId) then
				_yaAgent.addLogEntry(AP_Log_YA_Default,"Identification Masking, " &amp; tiId  &amp; " passed mask test, testing potentially good Item..", true);
			else
				continue;
			endif;
		endif;
		
			
		if bulkRelease &lt;&gt; null then
			if not assignedTIs.isEmpty then //cnwrd1 par 31623 
				if (not assignedTIs.includes(ti)) then
					_yaAgent.addLogEntry(AP_Log_YA_Default,'Item ' &amp; ti.id  &amp; ' is not allocated to bulk release', true);
					// Par 11819 DVB changed 25/05/2006
					//return false;
					continue;
				endif;	
			endif;
			
			// Par 12270
			if (not ti.allBulkReleasesAssigned.isEmpty()) and (not ti.allBulkReleasesAssigned.includes(bulkRelease)) then
			//	if (not ti.allBulkReleasesAssigned.includes(bulkRelease)) then
				_yaAgent.addLogEntry(AP_Log_YA_Default,'Item ' &amp; ti.id  &amp; ' is assigned to another bulk release', true);
				// Par 11819 DVB changed 25/05/2006
				//return false;
				continue;
			endif;
		endif;
		
		if ti.testAutoPlanRequestYA(_yaAgent) then
			_yaAgent.myCurrentCMIFYAAutoPlan.allKeepTrackedTis.add(ti);
			_yaAgent.addLogEntry(AP_Log_YA_Default,'Item ' &amp; ti.id &amp; ' matched criteria.', true);
			totalFound := totalFound + 1;
		endif;
		
		if totalFound &gt;= totalWeNeed then
			_yaAgent.addLocationToAgent(self, CM_YAAutoplanAgent.Locations_Found);
			return true;
		endif;
 	endforeach; 
  	
	// TFS 3045
	if totalFound &lt;  totalWeNeed and totalFound &gt; 0 then
		_yaAgent.addLogEntry(AP_Log_YA_Default,"Insufficient items in '" &amp; self.getFullId() &amp; "' to satisfy request (need " &amp; totalWeNeed.String &amp; ", area contains " &amp;   totalFound.String &amp; ".. Skipping.", true);
	
	endif;
	
 	return false;
epilog 
	delete assignedTIs;
end;</source>
        <Parameter name="_yaAgent" type="CM_YAAutoplanAgent" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="testIsControllerFull" id="0167f9be-9d8f-45db-b464-bd598ea2f40e">
        <source>testIsControllerFull(obj: CMIF_AutoMovePlan input);
//19 Feb 2025	navhl20 Bug MTN-19298: MTN - Performance issue when discharging the cargo items on the Complete job form for Ship jobs
vars
	maxCap 		: Integer;
	enforce 	: Boolean;	//30 Aug 2011	NDL	Par 28076
	numPlanned 	: Integer;	//07 Aug 2019	NDl	TFS 45971
	numQueued 	: Integer;	//07 Aug 2019	NDl	TFS 45971
	fmp 		: CM_FutureMove;	//07 Aug 2019	NDl	TFS 45971
	ti 			: CM_TrackedItem;	//07 Aug 2019	NDl	TFS 45971
	tA			: CM_TerminalArea;
begin
	if obj.isTestToBeDone(TI_Test_Capacity, self) = false then
		return;
	endif;
	
	tA := self.myTerminalArea;									//19.02.2025 navhl20 #19298

	// CCMS 1095
	//test the blockstack isFull flag also - this flag manually set
	if tA.testIsFull() then										//19.02.2025 navhl20 #19298
		obj.addVerboseLogEntry(app.getErrorString(Location_Flagged_Full), IsError, Location_Flagged_Full);
		obj.updateController(null);
		return;
	endif;			
	
	maxCap := tA.getMaxCapacity();								//19.02.2025 navhl20 #19298
	enforce :=  tA.getEnforceMaxCapacity();	//30 Aug 2011	NDL	Par 28076	//19.02.2025 navhl20 #19298
	
	//07 Aug 2019	NDl	TFS 45971
	ti := obj.myTrackedItem;
	if ti &lt;&gt; null then
		if maxCap &lt;&gt; 0 then										//19.02.2025 navhl20 #19298
			foreach fmp in self.allPlannedFutureMoves discreteLock do
				if ti = fmp.CM_FutureMovePlanned.myTrackedItem then
					continue;
				endif;
				if fmp.myWorkListEntry = null then
					continue;
				endif;
				numPlanned := numPlanned + fmp.myWorkListEntry.quantity;
			endforeach;
			foreach fmp in self.allQueuedFutureMoves discreteLock do
				if ti = fmp.CM_FutureMoveQueued.myTrackedItem then
					continue;
				endif;
				if fmp.myWorkListEntry = null then
					continue;
				endif;
				numQueued := numQueued + fmp.myWorkListEntry.quantity;
			endforeach;
		endif;
	else
		numPlanned := self.numPlannedTIs;
		numQueued := self.numQueuedTIs;
		
	endif;
	
	if maxCap &lt;&gt; 0 then
	//	if (self.numTIs + self.numPlannedTIs + self.numQueuedTIs) &gt;= maxCap then	// PAR 18831
		if ( self.numTIs + numPlanned + numQueued ) &gt;= maxCap then	//07 Aug 2019	NDl	TFS 45971
			//obj.addVerboseLogEntry("Area only has capacity for " &amp; maxCap.String &amp; " it will be exceeded if this is selected as a target", IsWarning, 0); //- cnwmd1, Par 20524
			if enforce then	//30 Aug 2011	NDL	Par 28076
				obj.addVerboseLogEntry(app.getErrorString1(Area_only_capac_will_excee_thi,maxCap.String), IsError, Area_only_capac_will_excee_thi);
			else
				obj.addVerboseLogEntry(app.getErrorString1(Area_only_capac_will_excee_thi,maxCap.String), IsWarning, Area_only_capac_will_excee_thi);
			endif;
			obj.updateController(null);
			return;
		endif;
	endif;
			
	if self.testIsControllerFullTAMax(obj) then
		return;
	endif;
			
			
	obj.updateController(self);
end;</source>
        <Parameter name="obj" type="CMIF_AutoMovePlan" usage="input"/>
    </JadeMethod>
    <JadeMethod name="testIsControllerFullYA" id="5c59b4dc-7bc0-420e-af20-4889038d77eb">
        <source>testIsControllerFullYA(_yaAgent : CM_YAAutoplanAgent input) : Boolean;

vars
	maxCap : Integer;
	currentCount : Integer;
	testPlannedCount : Integer;
	hasSomeCapacity : Boolean;
begin



	// CCMS 1095
	//test the blockstack isFull flag also - this flag manually set
	if self.myTerminalArea.testIsFull() then
		_yaAgent.addLogEntry(AP_Log_YA_Default,app.getErrorString(Location_Flagged_Full), true);
		return true;
	endif;			
	
	maxCap := self.myTerminalArea.getMaxCapacity();
	
	if maxCap &lt;&gt; 0 then
		testPlannedCount := _yaAgent.getTestPlannedCargoCountFor( self );	//18 Jul 2013	NDL	Par 31899
		currentCount := (self.numTIs + self.numPlannedTIs + self.numQueuedTIs + testPlannedCount);
		if currentCount &gt;= maxCap then	// PAR 18831
			_yaAgent.addLogEntry(AP_Log_YA_Default,"Area only has capacity for " &amp; maxCap.String &amp; " it will be exceeded if this is selected as a target", true);
			return true;
		endif;
	endif;
	
	//epr CCMS 1366 bulk
	if self.testIsControllerFullTAMaxYA(_yaAgent, hasSomeCapacity) then	
		if hasSomeCapacity then
			_yaAgent.myCMIFYAAutoPlan.addLocationForSplitQ( _yaAgent.myCurrentAllocation, self);	//15 Jun 2016	NDL	TFS 2172
		endif;
		return true;
	endif;
	
	return false;			

end;</source>
        <Parameter name="_yaAgent" type="CM_YAAutoplanAgent" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="testIsControllerLabrRestricted" id="63600b94-3f87-4729-b3db-e7331f3d26f7">
        <source>testIsControllerLabrRestricted(obj: CMIF_AutoMovePlan input);
//implimented in Yard controller super-class
//Returns true if this LC has a labour restriction.
vars

begin
	if obj.isTestToBeDone(TI_Test_LabourRest, self) = false then
		return;
	endif;

	obj.updateController(null);
	
	if obj.myTrackedItem = null then
		app.raiseCMException2(MethodWithNullParam, method.name, "No TI Reference", null, null);
		return;
	endif;
	
	if not hasRestrictions(LABOUR_RESTRICTION) then
		obj.updateController(self); 
  endif;
end;</source>
        <Parameter name="obj" type="CMIF_AutoMovePlan" usage="input"/>
    </JadeMethod>
    <JadeMethod name="testLocationYA" id="64a6b801-6910-4e42-82be-f633ccb9bc8d">
        <source>testLocationYA(_yaAgent : CM_YAAutoplanAgent input; _isIn : Boolean) : Boolean;
// -------------------------------------------
// Created 30 March 2005 by cnwdvb1
// -------------------------------------------
vars

begin
	
	if not inheritMethod(_yaAgent, _isIn) then
		return false;
	endif;
	
	/* autoPlanTest settings deimplimented
	if self.myTerminalArea.autoPlanTest.testLabourRestriction and self.hasRestrictions(LABOUR_RESTRICTION) then
		_yaAgent.addLogEntry(self.getFullId &amp; " has labour restriction(s) in place", true);
		return false;
	endif;
	*/
	//cnwrd1 par 28295 13.10.2011
	if self.hasRestrictions(LABOUR_RESTRICTION) then
		_yaAgent.addLogEntry(AP_Log_YA_Default,self.getFullId &amp; " has labour restriction(s) in place", true);
		//return false;
		_yaAgent.addToPassedWithRestrictionLoc(self); //cnwrd1 par 29269 14.3.2012
	endif;
	
	if not _isIn and 
			_yaAgent.myCurrentCMIFYAAutoPlan.CMIF_YARequest.isDeliveryRequest and
			self.myTerminalArea = _yaAgent.myCurrentCMIFYAAutoPlan.CMIF_YARequest.myDeliveryRequest.myTargetTA then
		_yaAgent.addLogEntry(AP_Log_YA_Default,"Block stacks do not source item from target " &amp; self.getFullId, true);
		return false;
	endif;
	
	if _isIn then
		if  self.testIsControllerFullYA(_yaAgent) then
			return false;
		endif;
	
	endif;
	
	return true;


end;</source>
        <Parameter name="_yaAgent" type="CM_YAAutoplanAgent" usage="input"/>
        <Parameter name="_isIn" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateMoveTo" id="e8898632-87be-4748-905a-012e7fdec02b">
        <source>validateMoveTo(_controller: CMIF_MoveController input);
/*
 ------------------------------------------------------------------------
Created:			27 November 2001 by cnwdwq1
Purpose:			
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------	--------------	-----------------------------------------
29/04/2013		cnwcs5			par 30475 - remove location restrictions	
---------------------------------------------------------------------------
*/
vars
	tAutoPlanMove 	: CMIF_AutoMovePlan;
	ti 			 	: CM_TrackedItem;
	termArea		: CM_TerminalArea;
begin

	//04 Nov 2013	NDL	Par 32837
	if self.isLogicalDeleteArea then
		if not app.getMyUser.canDo( self.myTerminal, PmAdmCargoDelete ) then
			app.raiseCMException1(NoPermission, app.getErrorString(Logically_delete_cargo), null, null);
			return;
		endif;
	endif;
	
	if _controller.isForcedMove then
		return;
	endif;
	
	inheritMethod(_controller);
	
	termArea := self.myTerminalArea;
	
	if (not termArea.isTIAbleToLand(_controller.myTrackedItem)) then
		app.raiseCMException(ERR_STATE_FOR_LDA, null, null);
		return;	
	endif;
	
	//------------&gt;
	//CCMS1505 23/1/2007 Mohammad
	ti := _controller.myTrackedItem;

	if (ti &lt;&gt; null and ti.isContainer()) and termArea &lt;&gt; null then
		if ti.CM_Container.offsitePreTrip and termArea.myType.type = TA_TYPE_PTI then
			app.raiseCMWarning1(ERR_OffsitePTIStatus, ti.id, null,  null, ti);
		endif;
	endif;	
	
	//------------------
	//  Create a transient automoveplan from our moveController so we can share
	//  same code as the autoPlan tests.
	//------------------
	tAutoPlanMove := _controller.createAsAutoMovePlan();
	
	tAutoPlanMove.setOriginatingController(self);
		
	//------------------------
	//	Full?	CCMS 1095
	//------------------------	
	self.testIsControllerFull(tAutoPlanMove);
	
	//------------------
	//Thats it!	
	//------------------

epilog
	delete tAutoPlanMove;
end;</source>
        <Parameter name="_controller" type="CMIF_MoveController" usage="input"/>
    </JadeMethod>
</Class>
