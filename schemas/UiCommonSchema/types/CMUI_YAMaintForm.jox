    <JadeMethod name="setYardAllocation" id="ed5ffee5-0445-4a7b-8224-0e505dbd306e">
        <updating/>
        <source>setYardAllocation(_yas: ObjectArray) updating;

/*

Purpose:		This method will make transient proxies of the whole Yard Allocation
				structure (i.e. the Yard Allocation, the Location Blocks, and the
				Criteria) and store them on this form.  When the "Save" button is
				clicked, the original Yard Allocation object will be discarded, and
				the modified Yard Allocation structure will be persisted anew.

Parameters:		_yas - A collection of yard allocations to edit, if null then add a new ya
Return Value:	None


Date			Who		Reason
05 August 2008	consw1	Initial creation

*/
// adm 190509 Par 19238
vars
	ya, proxyObj		: CM_YardAllocation;
	blockGroupObj	: CM_YABlockGroup;
	isLoadSet		: Boolean;
	criteria		: CM_YACriteria;
	imex			: CM_YACriteria;
	proxyCriteria	: CM_YACriteria;
	imexStatus		: CM_IMEXStatus;
	yaIMEXConfig	: CM_YAIMEXConfig;
	criteriaType: CM_YACriteriaType;
	opCriteria: CM_YACriteriaArray;
begin
	self.doClearCurrentYA();

	if _yas = null then
		create proxyObj transient;
		create blockGroupObj transient;
		proxyObj.allYABlockGroupsIn.add(blockGroupObj);
		proxyObj.allYABlockGroupsOut.add(blockGroupObj);
		self.myProxyYA	:=	proxyObj;
		self.myProxyYA.setTerminal(self.myTerminal);
	elseif _yas.size = 1 then
		ya := _yas.first.CM_YardAllocation;
		proxyObj	:=	app.createUpdateProxy(ya).CM_YardAllocation;
		//  Also save off flag indicating if template criteria has been modified
		self.isTemplateModified := ya.isTemplateModified;
		self.myProxyYA			:=	proxyObj;
		self.myYardAllocation	:=	ya;
	else
		_yas.copy(self.allBulkEditYAs);
	endif;
	self.setCmbYATemplateBehaviour();
epilog
	delete opCriteria;
end;</source>
        <Parameter name="_yas" type="ObjectArray"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="f8a31362-54d5-40d5-aca6-4345c439d218">
        <updating/>
        <source>setupForm() updating;

vars
begin
	self.initializeControls();

	inheritMethod();
	self.centreOverParent(100);

	self.populateForm(); 
	
	if self.isBulkEdit() then
		self.initializeBulkEdit();
	else
		//self.populateForm();  //don't need to populate form if its a multi select
	endif;
	
	btnNext.tag := "";
	if self.myYardAllocation &lt;&gt; null or self.isBulkEdit() then
		btnNext.caption := "Save &amp;As";
		btnNext.tag := "SaveAs";
	endif;
	
	//04 Jan 2012	NDL	Par 28889
	if self.initialSheetIndex &gt; 0 then
		if self.initialSheetIndex = 1 then
			self.fldYardAlloc.topSheet := self.shtCriteria;
		elseif self.initialSheetIndex = 2 then
			self.fldYardAlloc.topSheet := self.shtLocation;
		elseif self.initialSheetIndex = 3 then
			self.fldYardAlloc.topSheet := self.shtOptions;
		elseif self.initialSheetIndex = 4 then
			self.fldYardAlloc.topSheet := self.shtRemarks;
		endif;
	endif;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="showTblGCQuantity" id="e5a1bf53-bd36-4a88-b70d-58135c54a09c">
        <source>showTblGCQuantity( _ya : CM_YardAllocation );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 March 2021	navndl1	Initial creation	TFS 49912
18 May 2021	NDL	TFS 51156 - Make it handle multiple TAs

*/

vars

	cargoType : CM_CargoType;
	product : CM_Product;
	measureType : CM_MeasurementType;
	convertedAmount : String;
	cmifObj : CMIF_Object;
	cmif : CMIF_YACriteriaPriority;
	yaCrit : CM_YACriteria;
	amount : Real;
	allTransientCriteriaObj	: CMIF_Array;
	ta : CM_TerminalArea;
	rowIndex : Integer;
	locationsStr : String;
	taStr : String;
	startPos : Integer;
	
	nonGcTacount : Integer;
	gcAllocCount : Integer;
	irregTaCount : Integer;

begin

	if _ya &lt;&gt; null then
		cargoType := _ya.getCargotype;
		product := _ya.getCargoSubtype;
	else
	
		create allTransientCriteriaObj transient;
		self.getCriteriaAllCMIF( allTransientCriteriaObj );
		
		if not allTransientCriteriaObj.isEmpty then
			foreach cmifObj in allTransientCriteriaObj do
				cmif := cmifObj.CMIF_YACriteriaPriority;
				yaCrit := cmif.myProxy.CM_YACriteria;
				if yaCrit &lt;&gt; null and yaCrit.myYACriteriaType.isKindOf( CM_YATypeCargoType ) then
					if yaCrit.myYAData &lt;&gt; null then
						cargoType := yaCrit.myYAData.CM_YADataObjects.allObjects.first().CM_CargoType;
					endif;
				elseif yaCrit &lt;&gt; null and yaCrit.myYACriteriaType.isKindOf( CM_YATypeProduct ) then
					if yaCrit.myYAData &lt;&gt; null then
						product := yaCrit.myYAData.CM_YADataObjects.allObjects.first().CM_Product;
					endif;
				endif;
			endforeach;
		endif;
	endif;

	if self.myYardAllocation = null then
	
	elseif self.myProxyYA &lt;&gt; null then	
		amount := self.myProxyYA.projectedGC;
			
	endif;
	
	if self.tblGCQuantity.visible or self.txtProjectedGC.visible then
		//its already been set, get the data alreday entered to re-show it in case we rebuild it below. 
		amount := self.getTblGCQuantity();
	endif;
	
	//default behaviour, is quantity so measurement table is not used
	self.tblGCQuantity.visible := false;
	self.txtProjectedGC.text := amount.Integer.String;
	
	//Find the first terminal area used, so we can check if we have to display projected GC as "volume, weight or Qty" or just as "Qty".	
	if self.tblLocation.rows &gt; 0 then
		foreach rowIndex in 1 to self.tblLocation.rows do
			if self.tblLocation.accessRow(rowIndex).visible then
				locationsStr := self.tblLocation.accessCell(rowIndex, 1).text.trimBlanks;
				if locationsStr &lt;&gt; null then
					startPos := 1;
					taStr := locationsStr.scanUntil(" ", startPos);
					if taStr &lt;&gt; null then
						ta := self.myTerminal.allTerminalAreas[taStr];
						if ta &lt;&gt; null then
							if ta.isIrregularBlockArea then
								irregTaCount := irregTaCount + 1;
							elseif ta.isGeneralCargoAllocArea then
								gcAllocCount := gcAllocCount + 1;
							else
								nonGcTacount:= nonGcTacount + 1;
							endif;
						endif;
					endif;
				endif;
			endif;
		endforeach;
	endif;
	
	if cargoType &lt;&gt; null and gcAllocCount &gt; 0 and irregTaCount = 0 and nonGcTacount = 0 then
		//We have a cargo type AND GC Alloc areas only
		if cargoType.isBulkMulti then
			//we are going to use the measurement table
			self.tblGCQuantity.visible := true;
			self.tblGCQuantity.left := self.txtProjectedGC.left;
			
			if cargoType.isTrackByWeight then
				self.tblGCQuantity.setup(Type_Weight, self.backColor);
				measureType := app.getDefaultMeasurementForType(Type_Weight);
				if cargoType.myWeightMeasurementType &lt;&gt; null then
					measureType := cargoType.myWeightMeasurementType;
				endif;
				
			elseif cargoType.isTrackByVolume then
				self.tblGCQuantity.setup(Type_Volume, self.backColor);
				measureType := app.getDefaultMeasurementForType(Type_Volume);
				if cargoType.myVolumeMeasurementType &lt;&gt; null then
					measureType := cargoType.myVolumeMeasurementType;
				endif;
				
			endif;
			convertedAmount := app.convertMeasurementForDisplay( measureType.shortName, amount );
			self.tblGCQuantity.setValues( convertedAmount &amp; " " &amp; measureType.shortName );
		endif;
	endif;
	
	if nonGcTacount &gt; 0	//We have an invalid termal area - no go.
	or ( gcAllocCount = 0 and irregTaCount = 0 )	//Or we have no TAs - no go
	or ( gcAllocCount &gt; 0 and irregTaCount &gt; 0 and cargoType &lt;&gt; null and cargoType.isBulkMulti ) //Or we have a mix of valid TA types and need decimal values - no go
	then	
		self.tblGCQuantity.visible := false;
		self.txtProjectedGC.visible := false;
		self.lblProjectedGC.visible := false;
	elseif gcAllocCount &gt; 0 or irregTaCount &gt; 0 then
		//We have TAs and they are either Genaral Alloc or Irregular block areas. All good
		self.txtProjectedGC.visible := not self.tblGCQuantity.visible;
		self.lblProjectedGC.visible := true;
	endif;

epilog

	if allTransientCriteriaObj &lt;&gt; null then
		allTransientCriteriaObj.purge;
	endif;
	delete allTransientCriteriaObj;

end;</source>
        <Parameter name="_ya" type="CM_YardAllocation"/>
    </JadeMethod>
