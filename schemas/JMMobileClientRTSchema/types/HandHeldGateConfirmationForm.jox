    <JadeMethod name="btnDamage_click" id="9770a376-ff0b-467c-9134-c97673f0f7f7">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnDamage_click(btn: Button input) updating;
// ---------------------------------------------------------------------------
// Created:     21 August 2006 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	containerInfo			: MobileHandHeldThin::DTO_ContainerInfo;
begin

	containerInfo := self.allContainerInfo[self.showingContainerNum];
	
	containerInfo.containerId 		:= self.txtId.text.trimBlanks.toUpper();
	containerInfo.customsSeal 		:= self.txtSealCust.text.trimBlanks.toUpper();
	containerInfo.operatorSeal 		:= self.txtSealOp.text.trimBlanks.toUpper();
	containerInfo.shipperSeal 		:= self.txtSealShip.text.trimBlanks.toUpper();
	containerInfo.hazardousChecked 	:= self.chkHaz.value;
	
	self.doShowFrmDamage();
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
