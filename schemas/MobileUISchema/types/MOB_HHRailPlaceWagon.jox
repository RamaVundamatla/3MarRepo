    </JadeMethod>
    <JadeMethod name="setupPositionBtns" id="b4fb1958-ed57-4c82-85ff-1ded33f7b1e6">
        <updating/>
        <source>setupPositionBtns() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 August 2010	cnwndl1	Initial creation	Par 25215
14 Oct 2014	NDL	Par 35040

*/

vars

	btnLeft : Real;
	btnTop : Real;
	btnHeight : Real;
	btnWidth : Real;
	wagon : CM_Wagon;
	wagCont : CM_WagonController;
	btn : Button;
	btn2 : Button;
	index : Integer;
	pos : Integer;
	allowUpdate : Boolean;
	x : Real;
	y1 : Real;
	y2 : Real;
	
begin

	lblMessage.caption := null;
	
	btnHeight := self.frmCargoBtns.height - 12;
	btnLeft := 1;
	btnTop := 6;
	
	wagon := self.cmbWagon.listObject.CM_Wagon;
	self.setMultiStackWagon( wagon );
	
	if wagon = null then
		allowUpdate := false;
	else
		allowUpdate := self.checkWagonIsForTrain( wagon, true );	//also sets lblMessage.
	endif;
	
	self.setFormCaption(wagon);
	self.btnWagonChecks.enabled := allowUpdate;
	self.drawEmptyWagonChassis(y1, y2);
	
	// find or create a button for each wagon position that is available.
	if wagon &lt;&gt; null and not wagon.allLocationsControllersArray.isEmpty then
	
		self.drawWagonWheels();
		
		btnWidth := ( self.frmCargoBtns.width / wagon.allLocationsControllersArray.size ) - 2;
		foreach wagCont in wagon.allLocationsControllersArray do
			index := index + 1;
			btn := self.btnWagonPos.getControl(index).Button;
			if btn = null then
				btn := self.btnWagonPos.loadControl(index).Button;
				btn.backColor := Gray;
				self.maxPosBtnCount := index;
			endif;
			btn.userObject := wagCont;
			btn.parent := frmCargoBtns;
			btn.tabStop := false;
			btn.enabled := true;
			if wagon.isBoxcar then	//20 Mar 2013	NDL	Par 31278
				btn.caption := null;
				btn.enabled := false; // we dont confirm cargo that is in a boxcar.
			else
				btn.caption := wagCont.getLabel();
			endif;
			btn.visible := allowUpdate and self.isInward;
			btn.move(	btnLeft,
						btnTop,
						btnWidth,
						btnHeight );
						
			if self.multiStackWagon then
				btn2 := self.btnWagonPos2.getControl(index).Button;
				if btn2 = null then
					btn2 := self.btnWagonPos2.loadControl(index).Button;
					btn2.backColor := Gray;
				endif;
				btn2.userObject := wagCont;
				btn2.parent := frmCargoBtns2;
				btn2.tabStop := false;
				btn2.enabled := true;
				btn2.caption := wagCont.getLabel();
				btn2.visible := allowUpdate and self.isInward;
				btn2.move(	btnLeft,
							btnTop,
							btnWidth,
							btnHeight );
			endif;
						
			btnLeft := btnLeft + btnWidth + 2;
			
			
			//draw the scale on the wagon, i.e. the 10 foot marks on the chassis.
			if index &lt;&gt; wagon.allLocationsControllersArray.size then
				x := btnLeft - 1;
				self.frmWagonGraphic.drawLine(x, y1, x, y2, Black);
			else
				// the last one.
				if wagCont.offsetFlexi &gt; 0 then
					// the last position has less than 10 foot available.
					btn.visible := false;
					if self.multiStackWagon then
						btn2.visible := false;
					endif;
				endif;
			endif;
		endforeach;
	endif;
	
	//hide the excess buttons if this wagon has less positions than the previous one shown.
	if self.maxPosBtnCount &gt; index then
		index := index + 1;
		foreach pos in index to self.maxPosBtnCount do
			btn := self.btnWagonPos.getControl(pos).Button;
			if btn &lt;&gt; null then
				btn.visible := false;
			endif;
			btn2 := self.btnWagonPos2.getControl(pos).Button;
			if btn2 &lt;&gt; null then
				btn2.visible := false;
			endif;
		endforeach;
	endif;
	
	if not self.multiStackWagon then
		foreach pos in 1 to self.maxPosBtnCount do
			btn2 := self.btnWagonPos2.getControl(pos).Button;
			if btn2 &lt;&gt; null then
				btn2.visible := false;
			endif;
		endforeach;
	endif;
	
	self.setupCargoBtns( allowUpdate );

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="shuffleControls" id="3d812cdc-f70f-4784-91a0-50240dfa326d">
        <updating/>
        <source>shuffleControls() protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 October 2014	cnwndl1	Initial creation	Par 35040

*/

vars

	top : Real;
	stdHeight : Real;

begin

	self.setResizeableMarginAndFontSize();
	stdHeight := self.getStdControlHeight;
	
	if self.multiStackWagon then
		self.frmCargoBtns2.visible := true;
		
		top := self.cmbWagon.top + cmbWagon.height + self.resizedMargin;
		self.lblMessage.top := top;
							
		top := self.lblMessage.top + self.lblMessage.height + self.resizedMargin;
		self.frmCargoBtns2.top := top;
								
		top := self.frmCargoBtns2.top + self.frmCargoBtns2.height;
		self.frmCargoBtns.top := top;
								
															
		top := self.frmCargoBtns.top + self.frmCargoBtns.height + self.resizedMargin;
		self.frmWagonGraphic.top := top;
		
		top := self.frmWagonGraphic.top + self.frmWagonGraphic.height + self.resizedMargin;
												
	else
		self.frmCargoBtns2.visible := false;
		
		top := self.cmbWagon.top + cmbWagon.height + ( stdHeight / 2 )  + self.resizedMargin;
		self.lblMessage.top := top;

		top := self.lblMessage.top + self.lblMessage.height + self.resizedMargin;
		self.frmCargoBtns.top := top;

		top := self.frmCargoBtns.top + self.frmCargoBtns.height + self.resizedMargin;
		self.frmWagonGraphic.top := top;
		
		top := self.frmWagonGraphic.top + self.frmWagonGraphic.height + (stdHeight / 2);
															
	endif;
	
	self.btnRakeBack.top := top;
	self.btnWagonChecks.top := top;
	self.btnRakeForward.top := top;

	top := self.btnWagonChecks.top + self.btnWagonChecks.height + self.resizedMargin;
	self.btnConfirmWagon.top := top;

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="swapWagonPositions" id="08bdc7c0-22ed-4885-a83a-e86cc792e55e">
        <updating/>
        <source>swapWagonPositions(_selectedWagon : CM_Wagon io; _newPosition : Integer):Boolean updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
26 August 2010	cnwndl1	Initial creation

*/

vars

	otherWagon : CM_Wagon;
	currentRailLine : CM_RailLine;
	currentRailPosString : String;
	fromRailLine : CM_RailLine;
	fromRailPos : Integer;
	fromRailPosString : String;
	errorMess : String;
	train : CM_Train;
	
	pxyWagon : CM_Wagon;
	wagonUpdateCtrl : CMIF_WagonUpdateController;
	loadState : Boolean;


begin

	app.mousePointer :=	Busy;

	if _selectedWagon = null then
		app.mousePointer :=	Idle;
		errorMess := app.getErrorString(No_Wagon_selected) &amp; CrLf &amp; app.getErrorString(Contact_developer);
		self.msgBox( errorMess, app.getErrorString(Error) , MsgBox_OK_Only, true);
		return false;
	endif;
	
	if _newPosition &lt; 1 then
		app.mousePointer :=	Idle;
		errorMess := app.getErrorString(No_Selected_position) &amp; CrLf &amp; app.getErrorString(Contact_developer);
		self.msgBox( errorMess, app.getErrorString(Error) , MsgBox_OK_Only, true);
		return false;
	endif;
	
	if self.isWagonConfirmed(_selectedWagon) then
		app.mousePointer :=	Idle;
		fromRailLine := _selectedWagon.myRailLine;
		if fromRailLine &lt;&gt; null then
			fromRailPos := fromRailLine.allWagons.indexOf(_selectedWagon);
			fromRailPosString := fromRailLine.getIdString &amp; " " &amp; fromRailPos.padLeadingWith("0",2);
		else
			fromRailPosString := app.getErrorString(Unknown);
		endif;
		errorMess := app.getErrorString2(Already_confirmed, _selectedWagon.id, fromRailPosString);//_selectedWagon.id &amp; " already confirmed to '" &amp; fromRailPosString &amp; "'.";
		errorMess := errorMess &amp; CrLf &amp; app.getErrorString(Swap_not_allowed);//
		self.msgBox( errorMess, app.getErrorString(Error) , MsgBox_OK_Only, true);
		return false;
	endif;
	
	train := self.myMobileGenericAgent.myCurrentTrain;

	// find the wagon currently in this position.
	currentRailLine := self.myMobileGenericAgent.myCurrentRailLine;
	otherWagon := currentRailLine.getWagonAtPosition(_newPosition);
	if self.isWagonConfirmed(otherWagon) then
		app.mousePointer :=	Idle;
		if currentRailLine &lt;&gt; null then
			currentRailPosString := currentRailLine.getIdString &amp; " " &amp; _newPosition.padLeadingWith("0",2);
		else
			currentRailPosString := app.getErrorString(Unknown);
		endif;
		errorMess := app.getErrorString2(Already_confirmed, otherWagon.id, currentRailPosString);//otherWagon.id &amp; " already confirmed to '" &amp; currentRailPosString &amp; ".";
		errorMess := errorMess &amp; CrLf &amp; app.getErrorString(Swap_not_allowed);//"Swap not allowed.";
		self.msgBox( errorMess, app.getErrorString(Error) , MsgBox_OK_Only, true);
		return false;
	endif;
	
	if otherWagon = null then
		// not a real swap because we are just moving a wagon from somewhere else to here.
		//shouldn't really happen, but just in case.
		app.cmsBeginLoad(loadState);
		pxyWagon :=	_selectedWagon.pxyCreateUpdateProxy();
		app.cmsEndLoad(loadState);
		
		create wagonUpdateCtrl transient;
		wagonUpdateCtrl.setBasicDetails(CMIF_WagonUpdateController.Mode_Update,	//_mode : Integer;
										currentRailLine,// rake
										train,	//_train : CM_Train;
										_newPosition, //_wagonPosition : Integer;
										false	// isTrainMode
										);										
		wagonUpdateCtrl.myProxyWagon := pxyWagon;
		wagonUpdateCtrl.expectedEditionWagon := _selectedWagon.edition;
		wagonUpdateCtrl.populateFromExistingWagonAddTi( _selectedWagon, null, 0 );
		
		app.myPassport.clearErrorsWarnings();
		app.myPassport.setWarningsIgnored(true);
		app.myTrxUA.trxUpdateWagonFromCMIF(wagonUpdateCtrl, false, app.myPassport);
	
		if app.myPassport.hasErrors then
			//errorMess := app.myPassport.getErrorsAsString;
			errorMess := app.myPassport.getAllErrorsWarningsAsString;	// 10 Aug 2012	NDL	Par 29885
			self.msgBox(errorMess ,app.getErrorString(Error) &amp; " [" &amp; _selectedWagon.id &amp; "]" , MsgBox_OK_Only, true);
			return false;
		endif;
		
		return true;	// re-position was successful.
	
	else
	
		app.myPassport.clearErrorsWarnings();
		app.myPassport.setWarningsIgnored(true);
		app.myTrxUA.trxUpdateWagonRakePositionSwap(otherWagon, _selectedWagon, app.myPassport);
		
		if app.myPassport.hasErrors then
			app.mousePointer :=	Idle;
			//errorMess := app.myPassport.getErrorsAsString;
			errorMess := app.myPassport.getAllErrorsWarningsAsString;	// 10 Aug 2012	NDL	Par 29885
			self.msgBox(errorMess, app.getErrorString(Error), MsgBox_OK_Only, true);
			return false;
		endif;
		
		return true;	// swap was successful.

	endif;
	


epilog

	app.cmsEndLoad(loadState);
	delete pxyWagon;
	app.mousePointer :=	Idle;

end;</source>
        <Parameter name="_selectedWagon" type="CM_Wagon" usage="io"/>
        <Parameter name="_newPosition" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
