    <JadeMethod name="cmbAgent_displayEntry" id="3e95a547-a230-4913-bb1a-feddb232aa28">
        <controlMethod name="CMUI_ComboBox::displayEntry"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbAgent_displayEntry(combobox: ComboBox input; obj: Any; lstIndex: Integer):String updating;
// clearing agent is customs agent or consignee
vars
	display	: String;
begin
	if obj.isKindOf(CM_CustomsAgent) then
		 display := obj.CM_CustomsAgent.code &amp; ' ' &amp; obj.CM_CustomsAgent.name;
	elseif obj.isKindOf(CM_ConsigneeConsignor) then
		display := obj.CM_ConsigneeConsignor.code &amp; ' ' &amp; obj.CM_ConsigneeConsignor.description;
	endif;
	return display;
end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
        <Parameter name="obj" type="Any"/>
        <Parameter name="lstIndex" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="cmbAgent_lostFocus" id="931f68d0-8447-40ec-8e36-053b61584721">
        <controlMethod name="CMUI_ComboBox::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbAgent_lostFocus(combobox: ComboBox input) updating;
// clearing agent is customs agent or consignee
vars
	obj	: Object;
begin
	obj := combobox.listObject;
	if obj &lt;&gt; null then
		if obj.isKindOf(CM_CustomsAgent) then
			self.myReportAgent.setValueByControlName(combobox.name, obj.CM_CustomsAgent.code);
		elseif obj.isKindOf(CM_ConsigneeConsignor) then
			self.myReportAgent.setValueByControlName(combobox.name, obj.CM_ConsigneeConsignor.code);
		endif;
	else
		self.myReportAgent.setValueByControlName(combobox.name, combobox.text);
	endif;

end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
