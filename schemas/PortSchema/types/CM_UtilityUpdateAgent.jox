end;</source>
        <Parameter name="_root" type="CM_Root" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateRootConfigFromString" id="5a71e1cb-e161-4dcd-a9d9-e05c7315bb82">
        <source>utlUpdateRootConfigFromString(	_cmif : CMIF_ConfigOptionsDisplay input;
								_newValue : String;
								_passport : CM_Passport input
								);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 August 2014	cnwndl1	Initial creation

*/

vars

	oldValue : Any;
	root : CM_Root;

begin

	if _cmif = null or _cmif.appliesToTerm then
		return;
	endif;
	root := app.myRoot;
	if root = null then
		return;
	endif;
	

	self.initialiseActivity();
	exclusiveLock( root );
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(root, true);
	endif;
	
	oldValue := root.getConfig( _cmif.constantName );
	if ( oldValue &lt;&gt; null and oldValue.isKindOf(String) and oldValue.String = _cmif.currentValue )
	or ( oldValue = null and _newValue = "true" or _newValue.isReal )
	then
		root.setConfig( _cmif.constantName, _newValue, true );
		if _newValue &lt;&gt; root.getConfig( _cmif.constantName ).String then
			app.raiseCMException(Failed_update, _cmif.optionName, null );
		else
			_cmif.currentValue := _newValue;
		endif;
	else
		app.raiseCMException(Failed_update, _cmif.optionName, null );
	endif;
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(root, false);
	endif;

epilog

end;</source>
        <Parameter name="_cmif" type="CMIF_ConfigOptionsDisplay" usage="input"/>
        <Parameter name="_newValue" type="String"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateRootStateData" id="cb5d3fd7-053c-4fb1-be60-4439bb4331e1">
        <source>utlUpdateRootStateData(pKey : String; pValue : Any);
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
