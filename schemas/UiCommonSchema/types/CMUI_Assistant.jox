    <JadeMethod name="showAPMTrouble" id="3f77500d-5cef-4836-8683-55a235b974ef">
        <source>showAPMTrouble(_parent : CM_BaseForm; _vvRec : CM_VehicleVisitRecord; _tranNum : String; _viewMode : Boolean);
// ---------------------------------------------------------------------------
// Created:     24 July 2008 by cnwab1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

	form : CMUI_TroubleResolver;
begin
	form := app.loadForm(CMUI_TroubleResolver, CMUI_Assistant, false, false, false, app.getMyTerminalDO_NOT_USE(), null).CMUI_TroubleResolver;
	
	if form &lt;&gt; null then
		form.setParentForm(_parent);
		form.tranNum := _tranNum;
		form.myVehicleVisit := _vvRec;
		form.viewMode := _viewMode;
		form.show;
	endif;


epilog

end;</source>
        <Parameter name="_parent" type="CM_BaseForm"/>
        <Parameter name="_vvRec" type="CM_VehicleVisitRecord"/>
        <Parameter name="_tranNum" type="String"/>
        <Parameter name="_viewMode" type="Boolean"/>
