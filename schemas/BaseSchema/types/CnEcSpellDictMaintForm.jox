        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtStartFrom_firstChange(textbox: TextBox input) updating;
// --------------------------------------------------------------------------------
// Created:		27 March 2006 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.cnEcResetFormChangedFlag();
end;</source>
        <Parameter name="textbox" type="TextBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="unload" id="948b1e9a-6eed-42c6-a7d7-5a98f141d42d">
        <controlMethod name="Form::unload"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>unload() updating;

begin
	self.closeForm();
end;</source>
    </JadeMethod>
    <JadeMethod name="updateWordFromDictionary" id="858e3f60-5d29-4795-83d7-49193a515e2e">
        <source>updateWordFromDictionary() protected;

begin
	if self.aMySpellCheckForm &lt;&gt; null then
		if txtEditWord.text &lt;&gt; "" then
			self.aMySpellCheckForm.aWordFromDictionary	:=	txtEditWord.text; 
		endif;
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
</GUIClass>
