        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>jdtCurrent_click(table: Table input) updating;

begin
	btnEdit.enabled	:=	(table.row &gt; table.fixedRows and table.row &lt;= table.rows);
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="jdtCurrent_dblClick" id="9fe7ca04-072e-47c3-a4c2-471af595ed90">
        <controlMethod name="Table::dblClick"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>jdtCurrent_dblClick(_table: Table input) updating;
// ---------------------------------------------------------------------------
// Created:     
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	_table.column := 1;
	_table.bubbleHelp := "Select row to display more details.";
	
//	if not app.computerName = app.getServerCompName() or app.isSDSSecondaryDB() then
	if not app.computerName = app.getServerCompName() then
//	else
		return;
	endif;
	
	if _table.row &gt; 1
	and _table.itemObject.JACBackupSchedule.status = JACBackupScheduled
	then
		btnEdit.enabled		:=	true;
		btnDel.enabled		:=	true;
		btnReset.enabled	:=	true;
	elseif _table.row &gt; 1 then	
		btnEdit.enabled		:=	false;
		btnDel.enabled		:=	true;
		btnReset.enabled	:=	true;
	else
		btnEdit.enabled		:=	false;
		btnDel.enabled		:=	false;
		btnReset.enabled	:=	false;
	endif;

end;</source>
        <Parameter name="_table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="jdtCurrent_displayEntry" id="c07a2de3-f11f-48c2-87cc-9abcf5095f40">
        <controlMethod name="CnEcDesignTable::displayEntry"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>jdtCurrent_displayEntry(_table: CnEcDesignTable input; _obj: Any; _columnHeading: String input):String updating;
// ---------------------------------------------------------------------------
// Created:     
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 24/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
// ---------------------------------------------------------------------------

constants
	True: String = true.String;
	False: String = false.String;

vars
            //  Table
begin
	if not global.isValidObject(_obj.Object) or // during SDS catchup the schedules may have been deleted
	   _obj = null then
		return null;
	endif;
	
	if _columnHeading = 'Start Date' then
		return(_obj.JACBackupSchedule.getStartTS.Date.format("dd/MM/yyyy"));
	elseif _columnHeading = 'Start Time' then
		return(_obj.JACBackupSchedule.getStartTS.Time.format("HH:mm"));
	elseif _columnHeading = 'Splits' then
		return(_obj.JACBackupSchedule.numSplits.String);
	elseif _columnHeading = 'Recur' then
		return(_obj.JACBackupSchedule.recur);
	elseif _columnHeading = 'Verify' then
		if _obj.JACBackupSchedule.verify then
			return(True);
		else
			return(False);
		endif;
	elseif _columnHeading = 'Overwrite' then
		if _obj.JACBackupSchedule.overwrite then
			return(True);
		else
			return(False);
		endif;
	elseif _columnHeading = 'Exclude' then
		if _obj.JACBackupSchedule.exclude then
			return(True);
		else
			return(False);
		endif;   
	elseif _columnHeading = 'Quiesce' then
		if _obj.JACBackupSchedule.quiesce then
			return(True);
		else
			return(False);
		endif;
	elseif _columnHeading = 'Compress' then
		if _obj.JACBackupSchedule.compress then
			return(True);
		else
			return(False);
		endif;
	elseif _columnHeading = 'Status' then
		if _obj.JACBackupSchedule.status = JACBackupComplete then
			if _obj.JACBackupSchedule.runOnSecondary then
				return("Completed at " &amp; _obj.JACBackupSchedule.endTS.String&amp;" on SDS Sec.");
			else
				return("Completed at " &amp; _obj.JACBackupSchedule.endTS.String&amp;'.');
			endif;
		elseif _obj.JACBackupSchedule.status = JACBackupFailed then
			return("Failed." &amp; _obj.JACBackupSchedule.endTS.String);
		elseif _obj.JACBackupSchedule.status = JACBackupAborted then
			return("Aborted." &amp; _obj.JACBackupSchedule.endTS.String);
		elseif _obj.JACBackupSchedule.status = JACBackupRunning then
			if _obj.JACBackupSchedule.runOnSecondary then
				return("Running on SDS Sec.");
			else
				return("Running.");
			endif;
		elseif _obj.JACBackupSchedule.status = JACBackupScheduled then
			return("Scheduled.");
		elseif _obj.JACBackupSchedule.status = JACBackupActivated then
			return("Activated.");
		else
			return("Unknown - " &amp; _obj.JACBackupSchedule.status);
		endif;
	endif;
end;</source>
        <Parameter name="_table" type="CnEcDesignTable" usage="input"/>
        <Parameter name="_obj" type="Any"/>
        <Parameter name="_columnHeading" type="String" usage="input"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="jdtCurrent_excludeObject" id="622c4f1a-028e-4efd-9bd6-f22c6aa92d33">
        <controlMethod name="CnEcDesignTable::excludeObject"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>jdtCurrent_excludeObject(_obj: Object):Boolean updating;
// ---------------------------------------------------------------------------
// Created:     
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	if not chkShowAll.value then
		if _obj.JACBackupSchedule.status = JACBackupComplete and
		  not chkCompleted.value then
			return(true);
		elseif _obj.JACBackupSchedule.status = JACBackupFailed and 
		  not chkFailed.value then
			return(true);
		elseif _obj.JACBackupSchedule.status = JACBackupAborted and 
		  not chkFailed.value then
			return(true);
		elseif _obj.JACBackupSchedule.status = JACBackupRunning and
		  not chkRunning.value then
			return(true);
		elseif _obj.JACBackupSchedule.status = JACBackupScheduled and 
		  not chkScheduled.value then
			return(true);
		endif;
	endif;

	return (false);

end;</source>
        <Parameter name="_obj" type="Object"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="jdtCurrent_rowColumnChg" id="3ea55c80-bedb-455d-8c26-5f19a1026feb">
        <controlMethod name="Table::rowColumnChg"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>jdtCurrent_rowColumnChg(_table: Table input) updating;
// ---------------------------------------------------------------------------
// Created:     
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 04/08/2006	cnwdad1		Change to allow the edit form when not running on
//							the server - the edit form has been changed to NOT
//							allow any updates in this case.
// ---------------------------------------------------------------------------
vars
	isOnServerMachine	: Boolean;
	
begin
	_table.column		:=	1;
	_table.bubbleHelp	:=	"Select row to display more details.";
	isOnServerMachine	:=	app.computerName = app.getServerCompName();
	
//	if not app.computerName = app.getServerCompName() or app.isSDSSecondaryDB() then
	if not isOnServerMachine then
		return;
	endif;
	
	if _table.row &gt; 1
	and _table.itemObject.JACBackupSchedule.status = JACBackupScheduled
	then
		if isOnServerMachine and not app.isSDSSecondaryDB() then
//			btnEdit.enabled	:=	true;
			btnDel.enabled	:=	true;
		endif;
		
		btnReset.enabled	:=	true;
		
	elseif _table.row &gt; 1 then	
		if _table.itemObject.JACBackupSchedule.finalMessage &lt;&gt; null then
			_table.bubbleHelp	:=	_table.itemObject.JACBackupSchedule.finalMessage;
		endif;
		
		if isOnServerMachine and not app.isSDSSecondaryDB() then
//			btnEdit.enabled	:=	false;
			btnDel.enabled	:=	true;
		endif;
		
		btnReset.enabled	:=	true;
		
	else
		if isOnServerMachine and not app.isSDSSecondaryDB() then
//			btnEdit.enabled	:=	false;
			btnDel.enabled	:=	false;
		endif;
		
		btnReset.enabled	:=	false;
	endif;
	
// cnwdad1 07/08/2006 - The edit form has been change to not allow update where appropriate.
	btnEdit.enabled		:=	true;
end;</source>
        <Parameter name="_table" type="Table" usage="input"/>
    </JadeMethod>
