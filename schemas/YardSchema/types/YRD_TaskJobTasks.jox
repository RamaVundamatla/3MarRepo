    <JadeMethod name="checkAndDeleteProxies" id="d8bf602d-1504-44cb-982b-ee7a5eabd3b1">
        <source>checkAndDeleteProxies() protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 19/06/2018	jlgdap1		Initial creation TFS 38560 PEL1 Voyage Work Orders fix ups
//
vars
	woDtl : CM_WorkOrderDtl;
	woDtlsToDelete : ObjectArray;

begin
	create woDtlsToDelete transient;
	if self.myProxyWorkOrder &lt;&gt; null then
		foreach woDtl in self.myProxyWorkOrder.allWoDtls do
			if woDtl.pxyGetRealObject() = null and woDtl.isOKToDelete then
				woDtlsToDelete.add(woDtl);
			endif;
		endforeach;
	endif;
	woDtlsToDelete.purge;
epilog
	delete woDtlsToDelete;
end;</source>
        <access>protected</access>
    </JadeMethod>
