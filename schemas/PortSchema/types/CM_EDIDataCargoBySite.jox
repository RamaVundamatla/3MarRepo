    <JadeMethod name="canBeDBLoaded" id="8e3c1dc1-165c-4747-9bfc-855de5bdac09">
        <source>canBeDBLoaded(): Boolean;
//
// 15 Jan 2018	jlgrs1	TFS 36636 STW Cargo By Site to be partial loading
//
vars
	result : Boolean;
begin
	result := inheritMethod();
	if not result and
	   self.getMyTerminal.getConfig(EdiCargoByAllowPartial).Boolean then
		result := status = CM_EDIFile.EDI_STATUS_LOADED or self.status = CM_EDIFile.EDI_STATUS_VERIFIED_ERRORS;
	endif;
	return result;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="canBePartiallyLoaded" id="6ae9e828-43b3-4893-aa8a-37d2545951b3">
        <source>canBePartiallyLoaded(): Boolean protected;
//
// 15 Jan 2018	jlgrs1	TFS 36636 STW Cargo By Site to be partial loading
//
vars

begin
	if self.getMyTerminal.getConfig(EdiCargoByAllowPartial).Boolean then
		return true;
	else
		return false;
	endif;
epilog

end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="canBeReprocessedByBGP" id="167d3c01-4510-42bf-a35f-0377e5956384">
        <source>canBeReprocessedByBGP() : Boolean;
//
// 15 Jan 2018	jlgrs1	TFS 36636 STW Cargo By Site to be partial loading
//
vars
	result		:Boolean;
	status		:Integer;
	purgeDate	:Date;
	createTS	:TimeStamp;
begin
	result := inheritMethod();
	
	if not result then
		status := self.status;
		
		if status = CM_EDIFile.EDI_STATUS_LOADED or	
			status = CM_EDIFile.EDI_STATUS_VERIFIED_ERRORS or 
			status = CM_EDIFile.EDI_STATUS_VERIFIED or 
	        status = CM_EDIFile.EDI_STATUS_LOCKERROR or
			status = CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS then
			
			if self.canBePartiallyLoaded then	
				result := true;
			endif;
		endif;
	endif;

	if result then
		if self.getEDIAction = CM_EDITrackedItem.EDI_ACTION_DELETE then
			result := false;
		endif;
	endif;

	return result;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
