<Class name="CM_QAccumTypeLookupMethod" id="50a4cb2d-2212-4be0-af05-f48a61ca04b9">
    <superclass name="CM_QIntegerLookupMethod"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
