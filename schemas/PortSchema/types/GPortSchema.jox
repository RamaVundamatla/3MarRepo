	elseif _class = CM_WOToDo_Truck then
		return TRANS_TYPE_WO_TODO_TRK_CREATED;
	elseif _class = CM_WOToDo_Train then
		return TRANS_TYPE_WO_TODO_TRN_CREATED;
	elseif _class = CM_WOToDo_VBS then
		return TRANS_TYPE_WO_TODO_VBS_CREATED;
	elseif _class = CM_WOToDo_Voyage then
		return TRANS_TYPE_WO_TODO_VOY_CREATED;
	elseif _class = CM_WOToDo_Wagon then
		return TRANS_TYPE_WO_TODO_WGN_CREATED;
	elseif _class = CM_WOTI_Pack then
		return TRANS_TYPE_WO_TIPACK_CREATED;
	elseif _class = CM_WOTI_Unpack then
		return TRANS_TYPE_WO_TIUNPACK_CREATED;
	elseif _class = CM_SOHTransaction then
		return TRANS_TYPE_SOH_FIXUP;
	elseif _class = CM_BOLInScalerTransaction then
		return TRANS_TYPE_BOLIN_SCALER;
	elseif _class = CM_HazardsCheck then
		return TRANS_TYPE_HAZ_CHECK;
	elseif _class = CM_OverLanded then
		return TRANS_TYPE_OVERLANDED;		//28/03/2023	navkc1	CR 56430 TASK 56433
	elseif _class = CM_ShortLanded then
		return TRANS_TYPE_SHORTLANDED;		//28/03/2023	navkc1	CR 56430 TASK 56433
	elseif _class = CM_ShipDescrepancy then
		return TRANS_TYPE_DISCREPANCY_SHIP;	//28/03/2023	navkc1	CR 56430 TASK 56433
	elseif _class = CM_OwnershipChanged then //02/06/2023 navmv20 CR 58213 Task 58214
		return TRANS_TYPE_OWNERSHIP_CHANGED; //02/06/2023 navmv20 CR 58213 Task 58214
	elseif _class = CM_CustomDocAdded then //05/09/2023	navkc1	CR 59934 Task 59935
		return TRANS_TYPE_CUSTDOCADDED;
	elseif _class = CM_CustomDocCancelled then //05/09/2023	navkc1	CR 59934 Task 59935
		return TRANS_TYPE_CUSTDOCCANCEL;
	elseif _class = CM_CustomDocDeleted then //05/09/2023	navkc1	CR 59934 Task 59935
		return TRANS_TYPE_CUSTDOCDELETE;
	elseif _class = CM_CustomDocUpdated then //05/09/2023	navkc1	CR 59934 Task 59935
		return TRANS_TYPE_CUSTDOCUPDATED;
	elseif _class = CM_LoadBooked then		// ### TFS N/A 27Feb2024 NAVPW1 - Unit test Fix
		return TRANS_TYPE_LOADBOOKED;
	elseif _class = CM_LoadCancelled then	// ### TFS N/A 27Feb2024 NAVPW1 - Unit test Fix
		return TRANS_TYPE_LOADCANCELLED;
	elseif _class = CM_PriorityChanged then 
		return TRANS_TYPE_PRIORITY_CHANGED;
	elseif _class = CM_TIJobDetail then //13/03/2024	navkc1 CR 62890 Task 62891
		return TRANS_TYPE_TIJOBSTART;
	elseif _class = CM_WOJobDetail then //13/03/2024	navkc1 CR 62890 Task 62892
		return TRANS_TYPE_WOJOBSTART;
	elseif _class = CM_CargoReturned then		// 26/08/2025	navcs2	MTN-35846
		return TRANS_TYPE_CARGORETURNED;		// 26/08/2025	navcs2	MTN-35846
	elseif _class = CM_CargoAddedToVVR then		// 26/08/2025	navcs2	MTN-35846
		return TRANS_TYPE_CARGOADDEDTOVVR;		// 26/08/2025	navcs2	MTN-35846
	// MTN-36569
	elseif _class = CM_CO2ReadingTransaction then
		return TRANS_TYPE_CO2READING;
	elseif _class = CM_O2ReadingTransaction then
		return TRANS_TYPE_O2READING;
	// MTN-36569 end
	endif;
	
	if app.isDevelopmentSystem() then
		app.raiseCMException1(ERR_INVALID_TRANSTYPE, _class.name, 'class', null); //par25665 cnwrs1 7 sept 2010
	endif;
	
	return null;
end;
</source>
        <Parameter name="_class" type="Class"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getTiTxnTypeForClassName" id="67cf3729-af23-4f01-ba53-19bdee4cab9e">
        <source>getTiTxnTypeForClassName(_className: String):Integer;
// ---------------------------------------------------------------------------
// Created:		15 May 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------
vars
	class	: Class;
begin

	class := currentSchema.getClass(_className);
	 
	if class = null then
		return 0;
	endif;
	
	return self.getTiTxnTypeForClass(class);

end;</source>
        <Parameter name="_className" type="String"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getTxnTypesOfType" id="81e834f1-b16d-4853-8b13-dfff4e2311b2">
        <source>getTxnTypesOfType(_type : Integer; _typesArr : IntegerArray input);
// ---------------------------------------------------------------------------
// Created:		18 February 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------
begin
	// IMPORTANT - if you make changes here they should probably also be made in GPortSchema::isTiTxnOfType

	// add the passed in type 
	_typesArr.add(_type);
	
	if _type = TRANS_TYPE_MOVE then
		_typesArr.add(TRANS_TYPE_MOVE_PICKUP);
		_typesArr.add(TRANS_TYPE_MOVE_SETDOWN);

	elseif _type = TRANS_TYPE_RECEIVE then
	//	_typesArr.add(TRANS_TYPE_CREATED);
		_typesArr.add(TRANS_TYPE_REASSEMBLY);
	   	_typesArr.add(TRANS_TYPE_REC_RAIL);
	   	_typesArr.add(TRANS_TYPE_REC_RAIL_INTER_TERM);
	   	_typesArr.add(TRANS_TYPE_REC_ROAD);
	   	_typesArr.add(TRANS_TYPE_REC_ROAD_INTER_TERM);
	   	_typesArr.add(TRANS_TYPE_REC_SHIP);
	   	_typesArr.add(TRANS_TYPE_EXPORT_RETURNED);	   	
	   	_typesArr.add(TRANS_TYPE_ReinstateReject);
	   	_typesArr.add(TRANS_TYPE_REC_TRANSHIP);

	elseif _type = TRANS_TYPE_RELEASE then
		_typesArr.add(TRANS_TYPE_REJECT);
		_typesArr.add(TRANS_TYPE_DISASSEMBLY);
		_typesArr.add(TRANS_TYPE_REL_RAIL);
		_typesArr.add(TRANS_TYPE_REL_RAIL_INTER_TERM);
		_typesArr.add(TRANS_TYPE_REL_ROAD);
		_typesArr.add(TRANS_TYPE_REL_ROAD_INTER_TERM);
		_typesArr.add(TRANS_TYPE_REL_SHIP);
		_typesArr.add(TRANS_TYPE_REL_TRANSHIP);

	elseif _type = TRANS_TYPE_CONNECT then
		_typesArr.add(TRANS_TYPE_CONNECT_POWER);
		_typesArr.add(TRANS_TYPE_CONNECT_TOWER);

	elseif _type = TRANS_TYPE_REJECT then
   		_typesArr.add(TRANS_TYPE_DISASSEMBLY);

	elseif _type = TRANS_TYPE_WASH then
	   	_typesArr.add(TRANS_TYPE_SWEEP);
		
// CCMS 1875 - add in sub-terminal transactions
	elseif _type = TRANS_TYPE_RECEIVE_ST_DEPOT then
		_typesArr.add(TRANS_TYPE_REC_ST_DEPOT_INT);
		_typesArr.add(TRANS_TYPE_REC_ST_DEPOT_ROAD);
		_typesArr.add(TRANS_TYPE_REC_ST_DEPOT_RAIL);
		_typesArr.add(TRANS_TYPE_REC_ST_DEPOT_SHIP);

	elseif _type = TRANS_TYPE_RECEIVE_ST_MARINE then
		_typesArr.add(TRANS_TYPE_REC_ST_MARINE_INT);
		_typesArr.add(TRANS_TYPE_REC_ST_MARINE_ROAD);
		_typesArr.add(TRANS_TYPE_REC_ST_MARINE_RAIL);
		_typesArr.add(TRANS_TYPE_REC_ST_MARINE_SHIP);

	elseif _type = TRANS_TYPE_RECEIVE_ST_WHOUSE then
		_typesArr.add(TRANS_TYPE_REC_ST_WHOUSE_INT);
		_typesArr.add(TRANS_TYPE_REC_ST_WHOUSE_ROAD);
		_typesArr.add(TRANS_TYPE_REC_ST_WHOUSE_RAIL);
		_typesArr.add(TRANS_TYPE_REC_ST_WHOUSE_SHIP);

	elseif _type = TRANS_TYPE_RELEASE_ST_DEPOT then
		_typesArr.add(TRANS_TYPE_REL_ST_DEPOT_INT);
		_typesArr.add(TRANS_TYPE_REL_ST_DEPOT_ROAD);
		_typesArr.add(TRANS_TYPE_REL_ST_DEPOT_RAIL);
		_typesArr.add(TRANS_TYPE_REL_ST_DEPOT_SHIP);

	elseif _type = TRANS_TYPE_RELEASE_ST_MARINE then
		_typesArr.add(TRANS_TYPE_REL_ST_MARINE_INT);
		_typesArr.add(TRANS_TYPE_REL_ST_MARINE_ROAD);
		_typesArr.add(TRANS_TYPE_REL_ST_MARINE_RAIL);
		_typesArr.add(TRANS_TYPE_REL_ST_MARINE_SHIP);

	elseif _type = TRANS_TYPE_RELEASE_ST_WHOUSE then
		_typesArr.add(TRANS_TYPE_REL_ST_WHOUSE_INT);
		_typesArr.add(TRANS_TYPE_REL_ST_WHOUSE_ROAD);
		_typesArr.add(TRANS_TYPE_REL_ST_WHOUSE_RAIL);
		_typesArr.add(TRANS_TYPE_REL_ST_WHOUSE_SHIP);

   	endif;
end;</source>
        <Parameter name="_type" type="Integer"/>
        <Parameter name="_typesArr" type="IntegerArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="initKeepConnectionAlive" id="a6f958c8-da5d-4b3c-a3a0-eabb3d677a10">
        <source>initKeepConnectionAlive(_timerIntervalMilliSeconds : Integer);
// -------------------------------------------
// Created 08 December 2004 by cnwdvb1
// -------------------------------------------
vars

begin


	app.writeLog('Starting keep alive timer', LogINFO);
	self.beginTimer(_timerIntervalMilliSeconds, Timer_Continuous, Keep_Alive_Timer);


end;</source>
        <Parameter name="_timerIntervalMilliSeconds" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="isMike" id="e791f40a-a9b5-4a6f-80a3-072a6a3ff805">
        <source>isMike() : Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21 December 2009	cnwmd1	Initial creation

*/

vars
	passport : CM_Passport;
begin
	passport := app.myPassport;
	return passport &lt;&gt; null and passport.userCode.toLower() = "cnwmd1";
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isTiTxnOfType" id="c968899d-69d4-43b6-8e67-4565e3d186f8">
        <source>isTiTxnOfType(_txnType, _likeType : Integer) : Boolean;
// ---------------------------------------------------------------------------
// Created:     19 September 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
begin
	// IMPORTANT - if you make changes here they should probably also be made in GPortSchema::getTxnTypesOfType
	
	if _likeType = _txnType then
		return true;
	endif;

	if _likeType = TRANS_TYPE_MOVE then
		if _txnType = TRANS_TYPE_MOVE_PICKUP or
		   _txnType = TRANS_TYPE_MOVE_SETDOWN then
		   	return true;
		 endif;
		 return false;
	endif;

	if _likeType = TRANS_TYPE_RECEIVE then
		if _txnType = TRANS_TYPE_CREATED or
		   _txnType = TRANS_TYPE_REASSEMBLY or
		   _txnType = TRANS_TYPE_REC_RAIL or
		    _txnType = TRANS_TYPE_REC_RAIL_INTER_TERM or
		   _txnType = TRANS_TYPE_REC_ROAD or
		   _txnType = TRANS_TYPE_REC_ROAD_INTER_TERM or
		   _txnType = TRANS_TYPE_REC_SHIP or
		   _txnType = TRANS_TYPE_EXPORT_RETURNED or		   
		   _txnType = TRANS_TYPE_ReinstateReject then
		   	return true;
		 endif;
		 return false;
	endif;

	if _likeType = TRANS_TYPE_RELEASE then
		if _txnType = TRANS_TYPE_REJECT or
		   _txnType = TRANS_TYPE_DISASSEMBLY or
		   _txnType = TRANS_TYPE_REL_RAIL or
		   _txnType = TRANS_TYPE_REL_RAIL_INTER_TERM or
		   _txnType = TRANS_TYPE_REL_ROAD or
		   _txnType = TRANS_TYPE_REL_ROAD_INTER_TERM or
		   _txnType = TRANS_TYPE_REL_SHIP or
		   _txnType = TRANS_TYPE_REL_TRANSHIP then 
		   	return true;
		 endif;
		 return false;
	endif;

	if _likeType = TRANS_TYPE_REJECT then
   		if _txnType = TRANS_TYPE_DISASSEMBLY then
   			return true;
   		endif;
   		return false;
   	endif;

	if _likeType = TRANS_TYPE_WASH then
   		if _txnType = TRANS_TYPE_SWEEP then
   			return true;
   		endif;
   		return false;
   	endif;

	// CCMS 1875 - add in sub-terminal transactions
	if _likeType = TRANS_TYPE_RECEIVE_ST_DEPOT then
   		if _txnType = TRANS_TYPE_REC_ST_DEPOT_INT or
		   _txnType = TRANS_TYPE_REC_ST_DEPOT_ROAD or
		   _txnType = TRANS_TYPE_REC_ST_DEPOT_RAIL or
		   _txnType = TRANS_TYPE_REC_ST_DEPOT_SHIP 
		   then
   			return true;
   		endif;
   		return false;
   	endif;

	if _likeType = TRANS_TYPE_RECEIVE_ST_MARINE then
   		if _txnType = TRANS_TYPE_REC_ST_MARINE_INT or
		   _txnType = TRANS_TYPE_REC_ST_MARINE_ROAD or
		   _txnType = TRANS_TYPE_REC_ST_MARINE_RAIL or
		   _txnType = TRANS_TYPE_REC_ST_MARINE_SHIP 
		   then
   			return true;
   		endif;
   		return false;
   	endif;

	if _likeType = TRANS_TYPE_RECEIVE_ST_WHOUSE then
   		if _txnType = TRANS_TYPE_REC_ST_WHOUSE_INT or
		   _txnType = TRANS_TYPE_REC_ST_WHOUSE_ROAD or
		   _txnType = TRANS_TYPE_REC_ST_WHOUSE_RAIL or
		   _txnType = TRANS_TYPE_REC_ST_WHOUSE_SHIP 
		   then
   			return true;
   		endif;
   		return false;
   	endif;

	if _likeType = TRANS_TYPE_RELEASE_ST_DEPOT then
   		if _txnType = TRANS_TYPE_REL_ST_DEPOT_INT or
		   _txnType = TRANS_TYPE_REL_ST_DEPOT_ROAD or
		   _txnType = TRANS_TYPE_REL_ST_DEPOT_RAIL or
		   _txnType = TRANS_TYPE_REL_ST_DEPOT_SHIP 
		   then
   			return true;
   		endif;
   		return false;
   	endif;

	if _likeType = TRANS_TYPE_RELEASE_ST_MARINE then
   		if _txnType = TRANS_TYPE_REL_ST_MARINE_INT or
		   _txnType = TRANS_TYPE_REL_ST_MARINE_ROAD or
		   _txnType = TRANS_TYPE_REL_ST_MARINE_RAIL or
		   _txnType = TRANS_TYPE_REL_ST_MARINE_SHIP 
		   then
   			return true;
   		endif;
   		return false;
   	endif;

	if _likeType = TRANS_TYPE_RELEASE_ST_WHOUSE then
   		if _txnType = TRANS_TYPE_REL_ST_WHOUSE_INT or
		   _txnType = TRANS_TYPE_REL_ST_WHOUSE_ROAD or
		   _txnType = TRANS_TYPE_REL_ST_WHOUSE_RAIL or
		   _txnType = TRANS_TYPE_REL_ST_WHOUSE_SHIP 
		   then
   			return true;
   		endif;
   		return false;
   	endif;
	
	return false;
end;</source>
        <Parameter name="_txnType" type="Integer"/>
        <Parameter name="_likeType" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isUserValid" id="c5afc40b-7af2-4442-b6d5-c4e1fa2972e2">
        <source>isUserValid(usercode: String; password: String): Boolean;
/*
Purpose:			Validate usercode and password passed in via a SQL query

Parameters:			

Return Value:		true if usercode and password are valid

Date		Who		Reason
02/11/2012	cnwdap1	Initial creation PAR #30668
*/
vars
	result : Integer;

begin
	if app.name &lt;&gt; "JMTODBCAccess" then
		return true;
	endif;
	
	if app.myCnCntrl = null then
		// Do nothing, because this is the app startup call
	else
		app.writeLog(method.qualifiedName() &amp; " usercode = " &amp; usercode, LogDEBUG);	//25 Nov 2019	NDL	TFS 47053
		
		// have to use hand-crafted usercode/password check here, as the ODBC app will not let us go in to transaction state
		result := self.odbcValidateUsercodePassword(usercode, password);
		if result &lt;&gt; 0 then
			app.writeLog(method.qualifiedName() &amp; " result = " &amp; result.String &amp; " returning false", LogDEBUG);	//25 Nov 2019	NDL	TFS 47053
	
			return false;
		endif;
		
		app.writeLog(method.qualifiedName() &amp; " result = " &amp; result.String &amp; " returning true", LogDEBUG);	//25 Nov 2019	NDL	TFS 47053
	endif;
	return true;
	
epilog

end;</source>
        <Parameter name="usercode" type="String"/>
        <Parameter name="password" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="lcStatusEnumToString" id="419e2a58-a478-4acd-a56a-1dd75b407a37">
        <source>lcStatusEnumToString(_value : Integer) : String;
// ---------------------------------------------------------------------------
// Created:     10 July 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if _value = LC_Status_Closed then
		return LC_StatusStr_Closed;
	elseif _value = LC_Status_PhysicallyEmpty then
		return LC_StatusStr_PhysicallyEmpty;
	elseif _value = LC_Status_Archived then
		return LC_StatusStr_Archived;
	else
		return LC_StatusStr_Open;
	endif;
	
end;</source>
        <Parameter name="_value" type="Integer"/>
        <ReturnType type="String"/>
