<Class name="CM_QStrVehicleRegMethod" id="6cfd0cdb-7083-4453-882c-11aec143f63e">
    <superclass name="CM_QStringLookupMethod"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="query"/>
    <JadeMethod name="setComboValues" id="58b7c1cb-bd23-4cb4-a702-1332e50db032">
        <source>setComboValues(_combo: ComboBox input; _params: CM_QueryCriteriaLineHolder; _queryOperator: CM_QueryOperator; _passport: CM_Passport);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 May 2023	navlw1	Initial creation ChangeRequest 58146: EUP - VBS MTN - [6] - Selector Query and JRW Part 2

*/

vars
	vehicle			: CM_Vehicle;
	selectStr		: String;
	storeIdx		: Integer;
	idx				: Integer;
	selectedVehicle	: CM_Vehicle;
	term 			: CM_Terminal;
begin
	_combo.clear();
	_combo.sorted := true;
	
	if CM_QStringLookup.hasInstance(_queryOperator) then
		selectStr := _queryOperator.CM_QStringLookup.selectionValue;
	elseif CM_QStringLookupNotEqual.hasInstance(_queryOperator) then
		selectStr := _queryOperator.CM_QStringLookupNotEqual.selectionValue;
	endif;
	
	term := _passport.myTerminal;
	if term &lt;&gt; null then
		foreach vehicle in term.vehicles discreteLock do
			idx := _combo.addItem(vehicle.regNumber );
			_combo.itemObject[idx] := vehicle;
			if vehicle.regNumber = selectStr then
				selectedVehicle := vehicle;
			endif;	
		endforeach;
			
		storeIdx  := _combo.findObject(selectedVehicle);
		if storeIdx &gt; 0 and storeIdx &lt; _combo.listCount then
			_combo.listIndex := storeIdx;
		endif;
	endif;
	
epilog

end;</source>
        <Parameter name="_combo" type="ComboBox" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_queryOperator" type="CM_QueryOperator"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setValuesFromList" id="9df59c09-b6f5-4b5a-aa5a-9c466f629515">
        <source>setValuesFromList(_tbl: Table input; _op: CM_QueryOperator input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 May 2023	navlw1	Initial creation ChangeRequest 58146: EUP - VBS MTN - [6] - Selector Query and JRW Part 2

*/

vars
	numRows,
	idx					: Integer;
	str 				: String;
	vehicle 			: CM_Vehicle;
	vehStrArray			: StringArray; 
begin
	create vehStrArray transient;
	
	numRows := _tbl.rows;
	foreach idx in _tbl.fixedRows + 1 to numRows do
		str := _tbl.accessCell(idx, 1).text;
		if str = TableCheckBox_Selected then
			vehicle := _tbl.accessRow(idx).itemObject.CM_Vehicle;
			vehStrArray.add(vehicle.regNumber);
		endif;
	endforeach;
	
	_op.setSearchValue(vehStrArray);
epilog
	delete vehStrArray;
end;</source>
        <Parameter name="_tbl" type="Table" usage="input"/>
        <Parameter name="_op" type="CM_QueryOperator" usage="input"/>
    </JadeMethod>
    <JadeMethod name="translateToDisplayValue" id="65185152-bed8-4d4c-92ac-5315a02dcea6">
        <source>translateToDisplayValue(_value: Any): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 May 2023	navlw1	Initial creation

*/

vars
	vehicle : CM_Vehicle;
begin
	
	if _value.isKindOf (CM_Vehicle) then	
		if _value &lt;&gt; null then
			vehicle := _value.CM_Vehicle;
			return vehicle.regNumber;
		else
			return null;
		endif;
	endif;
	
	return _value.String;
	
epilog

end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="translateToSearchValue" id="976045f6-c1d1-4a71-aa91-b216a9ff6749">
        <source>translateToSearchValue(_value: Any): Any;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 May 2023	navlw1	Initial creation

*/

vars
	invalidObj 		: Boolean;
	object			: CM_Vehicle;
	returnVal		: String;
begin
	if _value &lt;&gt; null then
		if _value.isKindOf(Collection) then	
			return _value;
		elseif _value.isKindOf(CM_Vehicle) then
			object := _value.CM_Vehicle;
		elseif _value.isKindOf(String) then
			returnVal := _value.String;
		endif;
	endif;
	
	if object &lt;&gt; null then
		on Exception do app.handleDeletedObject(exception, object, invalidObj);
		returnVal := object.regNumber;
	endif;
	
	return returnVal;
	
epilog

end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="Any"/>
    </JadeMethod>
</Class>
