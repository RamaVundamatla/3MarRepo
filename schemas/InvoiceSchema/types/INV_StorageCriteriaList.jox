    <JadeMethod name="translateForm" id="1ce6804b-0f0e-4d76-91f8-a50252194cbf">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 21 June 2016 10:08:31.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0018452, locale);
	btnConfig.translateBubbleHelp(Xlat_0020254, locale);
	btnConfig.translateCaption(Xlat_0020255, locale);
	btnFindLost.translateBubbleHelp(Xlat_0021241, locale);
	btnFindLost.translateCaption(Xlat_0021242, locale);
	btnNew.translateCaption(Xlat_0018453, locale);
	btnRefresh.translateBubbleHelp(Xlat_0021261, locale);
	btnRefresh.translateCaption(Xlat_0021262, locale);
end;</source>
    </JadeMethod>
    <JadeMethod name="userNotificationUpdate" id="12bdab12-5a97-4f5b-9f61-2e8c7984cdaa">
        <updating/>
        <source>userNotificationUpdate(_event: Integer; _obj: CM_Object; _anyObject: CM_Object) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 September 2012	cnwer1	Initial creation SFW 1295
// 10 Oct 2017    jlgrh7 TFS #7228 ADP - Storage Configuration Validation and Auditing
*/

vars

begin
	if _event = EVENT_STORAGE_CRITERIA_CREATE or 
		_event = EVENT_STORAGE_CRITERIA_UPDATE or
		_event = EVENT_STORAGE_CRITERIA_DELETE  or
		_event = EVENT_STORAGECONFI_CREATE or								//+TFS7228
		_event = EVENT_STORAGECONFI_DELETE then
		self.doQuery();
	
	endif;

epilog

end;</source>
        <Parameter name="_event" type="Integer"/>
        <Parameter name="_obj" type="CM_Object"/>
        <Parameter name="_anyObject" type="CM_Object"/>
    </JadeMethod>
</GUIClass>
