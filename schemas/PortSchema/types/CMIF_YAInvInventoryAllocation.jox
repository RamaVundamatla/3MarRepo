    <JadeMethod name="isShippingLine_Match" id="3ad08062-1be3-4749-b7cf-129a15bbfaec">
        <source>isShippingLine_Match(_yaData: CM_YADataObjects): Boolean;
/*
Purpose:			

Date		Who		Reason
08-06-2022 navgm20	ChangeRequest 53195: EUP - GEN/REP/INB - Additional Cargo Field – Shipping Line - Portschema
*/

vars
	shippingLine : CM_ShippingLine;
begin

	if self.myLocationEvent.myTrackedItem.getShippingLineCode() = null then //13/07/2022 navgm20 Tfs 53195
		return false;
	endif;
	
	// Only priorities will be empty.
	if _yaData.isEmpty() then
		return true;
	endif;
	
	
	shippingLine := self.myLocationEvent.myTrackedItem.myShippingLine; //13/07/2022 navgm20 Tfs 53195		// 14.07.2022 navsrk20 53195
	
	if shippingLine = null then
		return false;
	endif;
	return _yaData.matches(shippingLine);


end;</source>
        <Parameter name="_yaData" type="CM_YADataObjects"/>
