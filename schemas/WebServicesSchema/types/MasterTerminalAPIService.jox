        <Parameter name="_request" type="WS_FindCargoRequestObject"/>
        <Parameter name="_maxReturnItems" type="Integer"/>
        <Parameter name="_startFrom" type="Integer"/>
        <Parameter name="_enqController" type="CM_EnqControllerTI" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateLicense" id="07c7838b-6dde-4748-8cf7-5d0f60d2247c">
        <source>validateLicense(path: String): Boolean;
/*

Purpose:			Validates MasterTerminalAPI Subscription License

Parameters:			

Return Value:		

Date		Who		Reason
17 December 2021	navpw1	Initial creation TFS: 52268

*/

begin
	if app.myRoot.canDo(Sub_MasterTerminalAPI) then
		return true;
	endif;
	
	app.writeLog("Master Terminal API: Master Terminal Api Subscription not Active", LogERROR);
	if app.myPassport = null then
		app.createPassport();
	endif;
	
	app.myPassport.addErrorFull(NotLicensedToPerformAction, app.getErrorString1(NotLicensedToPerformAction, app.getPermissionName(Sub_MasterTerminalAPI)), null, null, null);
	app.raiseCMException1(NotLicensedToPerformAction, app.getPermissionName(Sub_MasterTerminalAPI), null, null);
	return false;

end;</source>
        <Parameter name="path" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
