    <JadeMethod name="xmlCreateUpdateLocation2" id="0fb7f066-3062-44af-934e-8fd07719a9a0">
        <source>xmlCreateUpdateLocation2(_action			: String;		// 'add' or 'update'
						_rowArea		: CM_LogArea;
						_logRowId		: String;
						_status			: String) : CM_LogController;
//	Nov 2011 copy of xmlCreateUpdateLocation but with fewer attributes set in the XML

// If parameter = null, its value will be taken from XmlLogRowMntRq constant

vars
	remoteManager	: CM_RemoteDataManagerExternal;
	xmlSession		: CM_XMLSession;
	struct 			: CnEcXmlStructureInstance;
	parser			: CnEcXmlParser;
	xmlStr			: String;
	tmpStruct		: CnEcXmlStructureInstance;
	userId,
	terminalCode	: String;
	xmlVersion		: String;
	location		: CM_LogController;
	
begin

	//------------------------------------------------------------------
	//				Preparing parameters for XML process
	//------------------------------------------------------------------
	xmlStr			:= self.XML_LogRowMntRq;
	userId := self.testProfile.getSetting(UT_Profile.P_USER).asString;
	if userId = null then		// 19/49/2011 cnwmh5
		userId := 'UNITTEST';
	endif;

	terminalCode	:= self.getTerminal().code;
	
	
	//------------------------------------------------------------------
	//					Creating XML structure
	//------------------------------------------------------------------
	
	create remoteManager transient;
	create xmlSession transient;
	
	create struct as CnEcXmlGroupInstance transient;
	create parser transient;
	parser.parseToMsgStructure(xmlStr, struct);
	
	//----------------------------------------------------------------------------------------------------------
	//				Setting current parameters into XML data, 
	//				I am not interested in data from XML_LogRowMntRq constant - I use it as a pattern only.
	//----------------------------------------------------------------------------------------------------------
	tmpStruct := struct.findStructure(XML_ACTION);			tmpStruct.initializeWithTagData(tmpStruct.tagName, _action,					tmpStruct.tagAttribute);
	tmpStruct := struct.findStructure(XML_LOGAREA);			tmpStruct.initializeWithTagData(tmpStruct.tagName, _rowArea.id,				tmpStruct.tagAttribute);
	tmpStruct := struct.findStructure(XML_LOGROW);			tmpStruct.initializeWithTagData(tmpStruct.tagName, _logRowId,				tmpStruct.tagAttribute);
	tmpStruct := struct.findStructure(XML_STATUS);			tmpStruct.initializeWithTagData(tmpStruct.tagName, _status,		 			tmpStruct.tagAttribute);


	//------------------------------------------------------------------
	//						setting XML session
	//------------------------------------------------------------------
	//see CM_XMLWorker::DoTheWork()
	tmpStruct := struct.findStructure(XML_DEVICEID);	tmpStruct.initializeWithTagData(tmpStruct.tagName, self.RTDeviceId, tmpStruct.tagAttribute);
	tmpStruct := struct.findStructure(XML_USERID);		tmpStruct.initializeWithTagData(tmpStruct.tagName, userId, tmpStruct.tagAttribute);
	tmpStruct := struct.findStructure(XML_TERMINAL);	tmpStruct.initializeWithTagData(tmpStruct.tagName, terminalCode, tmpStruct.tagAttribute);
	xmlVersion:= struct.findStructure(XML_VERSION).tagData;
	
	
	xmlSession.set(userId, self.RTDeviceId, terminalCode, xmlVersion, null/*_passwd*/);	
	
	self.assertNotNull(xmlSession.myTerminal);
	self.assertNotNull(xmlSession.myUser);
	self.assertNotNull(xmlSession.myDevice);
	
	
	//------------------------------------------------------------------
	//						creating / updating location
	//------------------------------------------------------------------
	remoteManager.processExternal(xmlStr, struct, xmlSession);
	self.assertNoTrxErrorsOrWarnings();
	
	location := getLogRow(_rowArea.id, _logRowId);
	self.assertNotNull(location);
	
	return location;

epilog

	delete remoteManager;
	delete xmlSession;
	delete struct;
	delete parser;
	
end;</source>
        <Parameter name="_action" type="String"/>
        <Parameter name="_rowArea" type="CM_LogArea"/>
        <Parameter name="_logRowId" type="String"/>
