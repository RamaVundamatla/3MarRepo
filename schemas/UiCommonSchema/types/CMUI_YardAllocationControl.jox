    <JadeMethod name="backColor" id="b888c069-a4bf-4cbc-85af-1392a6ea6721">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>backColor(set: Boolean; value: Integer io) updating, mapping, clientExecution;
// ---------------------------------------------------------------------------
// Created:     01 June 2005 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
begin
	inheritMethod(set, value);
	
	if self.isInPainter() then
		return;
	endif;
	
	if (not set) then
		return;
	endif;

	if self.myCtrlCriteria = null then
		// Assume that sub-controls have not been setup.
		return;
	endif;
	
	self.myCtrlCriteria.backColor			:=	value;
	self.myShtCriteria.backColor			:=	value;
	self.myShtLocations.backColor			:=	value;
	self.myShtOptions.backColor				:=	value;
	self.myGrpOptions.backColor				:=	value;
	self.myFolder.sheetBackColorSelected	:=	value;
	
	if self.form &lt;&gt; null and CM_BaseForm.hasInstance(self.form) then
		self.myFolder.sheetBackColorUnselected	:=	self.form.CM_BaseForm.colorControlBack;
	endif;
	
	self.myFolder.initSheetBackColors();		//set selected/unselected folders colours
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="value" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="delete" id="5de62b5e-1829-425c-8465-3b28f61451fe">
        <updating/>
        <executionLocation>client</executionLocation>
        <source>delete() updating, clientExecution;
// --------------------------------------------------------------------------------
// Created:		06 April 2005 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	delete self.myProxyYA;
	self.allBlockGroupsIn.purge();
	self.allBlockGroupsOut.purge();
end;</source>
    </JadeMethod>
    <JadeMethod name="doAddLocation" id="340924eb-ea6b-4784-ac70-6525aec6ca85">
        <updating/>
        <source>doAddLocation(_blockStack : CM_BlockStack) updating;
// --------------------------------------------------------------------------------
// Created:		28 February 2005 by cnwdad1
//
// Purpose:		Using the string entered by the user, add one or more locations to
//				an existing YA Block, or to a new YA Block.
//
// Parameters:	_blockStack - A reference to the Block Stack to add.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	targetLocation		: String;
	
begin
	if _blockStack = null then
		targetLocation	:=	self.myTxtLocation.cnEcString();
	else
		targetLocation	:=	_blockStack.id;
	endif;
	
	if targetLocation = null then
		app.setContinueCMExceptions(false);
		app.raiseCMException1(ERR_INVALID_LOCN_YA, "Please enter the location to add.", null, null);
		
		return;
	endif;
	
	self.doParseLocationString(targetLocation, self.myOptSortIn.value, false);
end;</source>
        <Parameter name="_blockStack" type="CM_BlockStack"/>
    </JadeMethod>
    <JadeMethod name="doCancel" id="1f5d2733-07e3-48f3-938c-23c93e043c3f">
        <updating/>
        <source>doCancel() updating;
// --------------------------------------------------------------------------------
// Created:		02 March 2005 by cnwdad1
//
// Purpose:		Cancels (unloads) the receiver's form.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.hasCancelled	:=	true;
	self.form.unloadForm();
end;</source>
    </JadeMethod>
    <JadeMethod name="doClearCurrentYA" id="43d19812-e9db-4c51-a6e8-1e907d279c6f">
        <updating/>
        <source>doClearCurrentYA() updating, protected;
// --------------------------------------------------------------------------------
// Created:		29 April 2005 by cnwdad1
//
// Purpose:		Clears the current Yard Allocation and its proxy object.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	delete self.myProxyYA;
	self.myYardAllocation	:=	null;
	self.mySelectedCP		:=	null;
	self.allBlockGroupsIn.purge();
	self.allBlockGroupsOut.purge();

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doClearLocations" id="32c719a3-a470-4798-b67e-a2367212f5bb">
        <updating/>
        <source>doClearLocations(_taObj : CM_TerminalArea) updating;
// --------------------------------------------------------------------------------
// Created:		12 May 2005 by cnwdad1
//
// Purpose:		Clears all YA Blocks from the Yard Allocation.
//
// Parameters:	_taObj - A reference to the Terminal Area who's Locations to clear.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	groupObj	: CM_YABlockGroup;
//	newGroupObj	: CM_YABlockGroup;
	blockObj	: CM_YABlock;
	blockSet	: CM_YABlockSet;
	
begin
	if _taObj = null then
		foreach groupObj in self.allBlockGroupsIn do
			groupObj.allYABlocksIn.purge();
		endforeach;
	else
		create blockSet transient;
		
		foreach groupObj in self.allBlockGroupsIn do
			foreach blockObj in groupObj.allYABlocksIn do
				if blockObj.myTerminalArea = _taObj then
					blockSet.add(blockObj);
				endif;
			endforeach;
		endforeach;
		
		foreach groupObj in self.allBlockGroupsIn do
			foreach blockObj in blockSet do
				if blockObj.myYABlockGroupIn = groupObj then
					groupObj.allYABlocksIn.remove(blockObj);
				endif;
				
				if blockObj.myYABlockGroupOut = groupObj then
					groupObj.allYABlocksOut.remove(blockObj);
				endif;
			endforeach;
		endforeach;
		
		blockSet.purge();
	endif;
	
	if self.allBlockGroupsIn.isEmpty()
	and self.allBlockGroupsOut.isEmpty()
	then
		create groupObj transient;
		self.allBlockGroupsIn.add(groupObj);
		self.allBlockGroupsOut.add(groupObj);
	endif;
	
	self.populateLocationsListbox(self.myOptSortIn.value);
	
	self.enableDeckingOptionsButtons(	self.myLstLocations.listIndex &lt;&gt; CNEC_NULL_INDEX
										and not(CM_YABlockBlock.hasInstance(self.myLstLocations.listObject))
									);
epilog
	delete blockSet;
end;</source>
        <Parameter name="_taObj" type="CM_TerminalArea"/>
    </JadeMethod>
    <JadeMethod name="doDeckingOptionsDefault" id="22cf1714-5372-43ba-bb76-ac208c1f08c5">
        <source>doDeckingOptionsDefault();
// --------------------------------------------------------------------------------
// Created:		26 April 2005 by cnwdad1
//
// Purpose:		Sets the default Decking Options for the Yard Allocation.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	groupObj			: CM_YABlockGroup;
	blockObj			: CM_YABlock;
	pxyDeckingOptions	: CM_YADeckingOptions;
	deckingOptionsObj	: CM_YADeckingOptions;
	
begin
	blockObj	:=	self.getSelectedBlock();
	
	if blockObj = null then
		app.msgBox(	"Please select the location Block who's Decking Options you wish to default.",
					"Error",
					MsgBox_Information_Icon + MsgBox_OK_Only);
		return;
	endif;
	
	if blockObj.allYardControllers.isEmpty then
		app.msgBox(	"The selected Location Block has no pad positions selected.  Delete this block or reselect the area.",
					"Error",
					MsgBox_Information_Icon + MsgBox_OK_Only);
		return;
	endif;
		
	deckingOptionsObj	:=	blockObj.myDeckingOptions;

	//pxyDeckingOptions := app.createUpdateProxy(deckingOptionsObj).CM_YADeckingOptions;
	
	//pxyDeckingOptions.setProxyRules(DeckingRule_Default, DeckingRule_Default);
	
	deckingOptionsObj.setProxyRules(DeckingRule_Default, DeckingRule_Default);
/*	
	app.myTrxUA.trxApplyDeckingRule(pxyDeckingOptions, app.myPassport);
	
	if not app.myPassport.trxCompletedOK then
		app.msgBox(	"There were errors defaulting the decking options." &amp; CrLf &amp; "",
					"Error",
					MsgBox_Exclamation_Mark_Icon + MsgBox_Yes_No);
	endif;
*/	
end;</source>
    </JadeMethod>
    <JadeMethod name="doDeckingOptionsSpecify" id="a9776d0f-1283-4515-b2ad-c518195fbb13">
        <updating/>
        <source>doDeckingOptionsSpecify() updating;
// --------------------------------------------------------------------------------
// Created:		26 April 2005 by cnwdad1
//
// Purpose:		Shows the Yard Allocation Decking Options form for the currently
//				selected YA Block on the Locations tab.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	assistantObj		: CMUI_Assistant;
	blockObj			: CM_YABlock;
	
begin
	blockObj	:=	self.getSelectedBlock();
	
	if blockObj = null then
		app.msgBox(	"Please select the location Block who's Decking Options you wish to specify.",
					"Error",
					MsgBox_Information_Icon + MsgBox_OK_Only);
		return;
	endif;
	
	if blockObj.allYardControllers.isEmpty then
		app.msgBox(	"The selected Location Block has no pad positions selected.  Delete this block or reselect the area.",
					"Error",
					MsgBox_Information_Icon + MsgBox_OK_Only);
		return;
	endif;
		
	create assistantObj transient;
	assistantObj.showDeckingOptions(blockObj.myDeckingOptions, DeckingRule_Null, null);
	
	//redraw selected block
//	self.myLstLocations.refreshEntries(blockObj);	// No longer using listCollection.
	self.populateLocationsListbox(self.myOptSortIn.value);
epilog
	delete assistantObj;
end;</source>
    </JadeMethod>
    <JadeMethod name="doDelete" id="7ae229e4-5267-46bf-89c2-749525912fd4">
        <updating/>
        <source>doDelete():Boolean updating;
// --------------------------------------------------------------------------------
// Created:		02 May 2005 by cnwdad1
//
// Purpose:		Deletes the receiver's Yard Allocation object.
//
// Parameters:	None
//
// Returns:		True if the delete was successful, otherwise fase.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	yardAllocationObj	: CM_YardAllocation;
	msgStr, code		: String;
	
begin
	
	if self.myYardAllocation = null then 
		return false;
	else
		msgStr := app.getErrorString2(ConfirmDelete, app.getErrorString(YardAllocation), self.myYardAllocation.code);
		if app.msgBox(msgStr, 'Confim Deletion',
						MsgBox_Yes_No + MsgBox_Question_Mark_Icon) = MsgBox_Return_No then
			return false;
		endif;
	endif;
	
	
	
	yardAllocationObj	:=	self.myYardAllocation;
	code := yardAllocationObj.code;
	app.myTrxDA.trxDeleteYardAllocation(yardAllocationObj, app.myPassport);
	if app.myPassport.trxCompletedOK() then
		app.createActivityHistory(ActivityHistoryGeneral, app.myPassport.myTerminal, null, 
		'Allocation ' &amp; code &amp; ' has been deleted by user ' &amp; app.myPassport.getUserCode(), false, false);
	endif;
	self.setYardAllocation(null);
	self.myDisplayWindow.yaRefreshAllocation();
	
	return true;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doDeleteLocation" id="2da08c68-9b4b-4305-9536-56a3d0fd55dd">
        <updating/>
        <source>doDeleteLocation() updating;
// --------------------------------------------------------------------------------
// Created:		28 February 2005 by cnwdad1
//
// Purpose:		Removes the currently selected YA Block from the Yard Allocation.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	groupObj			: CM_YABlockGroup;
	inGroupObj			: CM_YABlockGroup;
	outGroupObj			: CM_YABlockGroup;
	blockObj			: CM_YABlock;
	listboxObj			: ListBox;
	listPointer			: Integer;
	lstCount			: Integer;
	
begin
	listboxObj	:=	self.myLstLocations;
	lstCount	:=	listboxObj.listCount();

	if listboxObj.selectedCount() = 0 then
		app.msgBox(	"Please select at least one Yard Allocation Block to delete.",
					"Error",
					MsgBox_Exclamation_Mark_Icon + MsgBox_OK_Only);
		return;
	endif;
	
	foreach listPointer in 1 to lstCount do
		if listPointer &lt;= listboxObj.itemSelected.size() then
			if listboxObj.itemSelected[listPointer] then
				if listboxObj.itemData[listPointer] = self.LOCATION_GROUP then
					groupObj	:=	listboxObj.itemObject[listPointer].CM_YABlockGroup;
					
					if self.allBlockGroupsIn.includes(groupObj) then
						self.allBlockGroupsIn.remove(groupObj);
					endif;
					
					if self.allBlockGroupsOut.includes(groupObj) then
						self.allBlockGroupsOut.remove(groupObj);
					endif;
					
					delete groupObj;
				else
					blockObj	:=	listboxObj.itemObject[listPointer].CM_YABlock;
					inGroupObj	:=	blockObj.myYABlockGroupIn;
					outGroupObj	:=	blockObj.myYABlockGroupOut;
					
					if inGroupObj &lt;&gt; null then
						inGroupObj.allYABlocksIn.remove(blockObj);
					endif;
					
					if outGroupObj &lt;&gt; null then
						outGroupObj.allYABlocksOut.remove(blockObj);
					endif;
					
					delete blockObj;
				endif;
			endif;
		endif;
	endforeach;
	
	self.populateLocationsListbox(self.myOptSortIn.value);
	self.enableDeckingOptionsButtons(self.myLstLocations.listIndex &lt;&gt; CNEC_NULL_INDEX and not(CM_YABlockBlock.hasInstance(self.myLstLocations.listObject)));
end;</source>
    </JadeMethod>
    <JadeMethod name="doExpiryDateOptClick" id="86fe8761-527b-43bd-812e-0324f1e19de1">
        <source>doExpiryDateOptClick(pValue:Boolean);
// --------------------------------------------------------------------------------
// Created:		05 April 2005 by cnwdad1
//
// Purpose:		Called by the click event of the Expiry Type of Date.
//
// Parameters:	pValue - True if the option button value is selected for an Expiry Date.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
begin
	if pValue then
		self.myTxtExpiryDate.enabled	:=	true;
	else
		self.myTxtExpiryDate.setDate(null);
		self.myTxtExpiryDate.enabled	:=	false;
	endif;
end;</source>
        <Parameter name="pValue" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doLocationsDragDrop" id="f996b9ec-7633-4c7b-ae55-34c59e97e435">
        <updating/>
        <source>doLocationsDragDrop(_dropObject:Object; _allDraggedObjects:ObjectArray input) updating;
// --------------------------------------------------------------------------------
// Created:		18 May 2006 by cnwdad1
//
// Purpose:		Processes a drag-drop operation in the Locations listbox control.
//
//				The user can drag one or more Block Groups or Blocks, but not both at
//				the same time.
//
// Parameters:	_dropObject - A reference to the object on which the drag was dropped.
//				_allDraggedObjects - A collection of the objects that were dragged.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	newGroupObj		: CM_YABlockGroup;
	oldGroupObj		: CM_YABlockGroup;
	blockObj		: CM_YABlock;
	allGroupsObj	: CM_YABlockGroupArray;
	allBlocksObj	: CM_YABlockArray;
	draggedObj		: Object;
	dropPointer		: Integer;
	isOutList		: Boolean;
	
begin
	isOutList	:=	self.myOptSortOut.value;
	
	// The user may be dropping onto a Block Group or a Block (within a Block Group) - work out which,
	// and where within the array of Blocks to insert the dragged Blocks (if dropping onto a Block Group,
	// then we'll simply append any dragged Blocks to the end of the Block Group's array of Blocks.
	
	if _dropObject.isKindOf(CM_YABlockGroup) then
		newGroupObj	:=	_dropObject.CM_YABlockGroup;
		dropPointer	:=	0;	// Dragged objects will be appended to the end of the Block array.
	elseif _dropObject.isKindOf(CM_YABlock) then
		blockObj	:=	_dropObject.CM_YABlock;
		
		if isOutList then
			newGroupObj	:=	blockObj.myYABlockGroupOut;
			dropPointer	:=	newGroupObj.allYABlocksOut.indexOf(blockObj);	// Dragged objects will be inserted into the Block array at this index.
		else
			newGroupObj	:=	blockObj.myYABlockGroupIn;
			dropPointer	:=	newGroupObj.allYABlocksIn.indexOf(blockObj);	// Dragged objects will be inserted into the Block array at this index.
		endif;
	else
		return;
	endif;
	
	// Fetch all of the objects that were dragged.
	
	create allGroupsObj transient;
	create allBlocksObj transient;
	
	foreach draggedObj in _allDraggedObjects do
		if draggedObj.isKindOf(CM_YABlockGroup) then
			allGroupsObj.add(draggedObj.CM_YABlockGroup);
			
		elseif draggedObj.isKindOf(CM_YABlock) then
			blockObj	:=	draggedObj.CM_YABlock;
			oldGroupObj	:=	blockObj.myYABlockGroupIn;
			
			if oldGroupObj &lt;&gt; null then
				if isOutList then
					blockObj.myYABlockGroupOut.allYABlocksOut.remove(blockObj);
				else
					blockObj.myYABlockGroupIn.allYABlocksIn.remove(blockObj);
				endif;
			endif;
			
			if not allBlocksObj.includes(blockObj) then
				allBlocksObj.add(blockObj);
			endif;
		endif;
	endforeach;
	
	// Put the dragged objects in the appropriate location.
	
	if allGroupsObj.isEmpty() then
		if dropPointer = 0 then
			foreach blockObj in allBlocksObj do
				if isOutList then
					newGroupObj.allYABlocksOut.add(blockObj);
				else
					newGroupObj.allYABlocksIn.add(blockObj);
				endif;
			endforeach;
		else
			foreach blockObj in allBlocksObj reversed do
				if isOutList then
					newGroupObj.allYABlocksOut.insert(dropPointer, blockObj);
				else
					newGroupObj.allYABlocksIn.insert(dropPointer, blockObj);
				endif;
			endforeach;
		endif;
	else
		if isOutList then
			dropPointer	:=	self.allBlockGroupsOut.indexOf(newGroupObj);
			
			foreach oldGroupObj in allGroupsObj reversed do
				self.allBlockGroupsOut.remove(oldGroupObj);
				self.allBlockGroupsOut.insert(dropPointer, oldGroupObj);
			endforeach;
		else
			dropPointer	:=	self.allBlockGroupsIn.indexOf(newGroupObj);
			
			foreach oldGroupObj in allGroupsObj reversed do
				self.allBlockGroupsIn.remove(oldGroupObj);
				self.allBlockGroupsIn.insert(dropPointer, oldGroupObj);
			endforeach;
		endif;
	endif;
	
	self.populateLocationsListbox(self.myOptSortIn.value);
epilog
	delete allGroupsObj;
	delete allBlocksObj;
end;</source>
        <Parameter name="_dropObject" type="Object"/>
        <Parameter name="_allDraggedObjects" type="ObjectArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doMoveBlock" id="063da055-16b7-440a-9f91-cc097f5baf92">
        <updating/>
        <source>doMoveBlock(pIsUp:Boolean) updating;
// --------------------------------------------------------------------------------
// Created:		06 April 2005 by cnwdad1
//
// Purpose:		Moves the currently selected block up or down one element position
//				in the appropriate array.
//
// Parameters:	pIsUp - If true, the element will be moved up.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	blockObj	: CM_YABlock;
	listPointer	: Integer;
	
begin
	blockObj	:=	self.getSelectedBlock();
	
	if blockObj &lt;&gt; null then
		if self.myOptSortIn.value then
			self.allBlockGroupsIn.moveElement(blockObj, pIsUp);
			self.populateLocationsListbox(true);
		else
			self.allBlockGroupsOut.moveElement(blockObj, pIsUp);
			self.populateLocationsListbox(false);
		endif;
		
		listPointer	:=	self.myLstLocations.findObject(blockObj);
		
		if listPointer &lt;&gt; CNEC_NULL_INDEX then
			self.myLstLocations.cnEcSet(listPointer);
			self.myLstLocations.itemSelected[listPointer]	:=	true;
		endif;
	endif;
end;</source>
        <Parameter name="pIsUp" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doMoveBlocksToNewGroup" id="e7dbfb7f-2af7-4f3d-99ed-78c7e25be24c">
        <source>doMoveBlocksToNewGroup(pGroupObj:CM_YABlockGroup input; pIsInList:Boolean) protected;
// --------------------------------------------------------------------------------
// Created:		20 June 2006 by cnwdad1
//
// Purpose:		When we delete a Group, we want to hang on to its Blocks, so, we'll
//				move its Blocks to the Group above it.  If there is no Group above
//				the one being deleted, then we'll move its Blocks to the Group beneath
//				it. If there is no Group beneath it, then the Group we're deleting
//				must be the last one, so we're effectively returning to a clean slate.
//
// Parameters:	pGroupObj - A reference to the Group who's Blocks we want to move.
//				pIsInList - True if the Group is in the "IN" list, otherwise the
//					"OUT" list will be assumed.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	allBlockGroupsObj	: CM_YABlockGroupArray;
	allBlocksToMoveObj	: CM_YABlockArray;
	newGroupObj			: CM_YABlockGroup;
	blockObj			: CM_YABlock;
	groupIndex			: Integer;
	
begin
	if pIsInList then
		allBlockGroupsObj	:=	self.allBlockGroupsIn;
	else
		allBlockGroupsObj	:=	self.allBlockGroupsOut;
	endif;
	
	groupIndex	:=	allBlockGroupsObj.indexOf(pGroupObj);
	newGroupObj	:=	null;
	
	if groupIndex &gt; 1 then
		// The Group we're deleting is not first in the list, so we'll move its
		// Blocks to the Group above it.
		groupIndex	:=	groupIndex - 1;
		newGroupObj	:=	allBlockGroupsObj[groupIndex];
		
	elseif allBlockGroupsObj.size() &gt; 1 then
		// The Group we're deleting is the first one in the list, so we'll see
		// if we can move its Blocks to the Group below it.
		groupIndex	:=	groupIndex + 1;
		newGroupObj	:=	allBlockGroupsObj[groupIndex];
	endif;
	
	if newGroupObj = null then
		// The Group in question must be the only one remaining, so there's no-where
		// to move its Block to.
	else
		create allBlocksToMoveObj transient;
		
		if pIsInList then
			pGroupObj.allYABlocksIn.copy(allBlocksToMoveObj);
		else
			pGroupObj.allYABlocksOut.copy(allBlocksToMoveObj);
		endif;
		
		foreach blockObj in allBlocksToMoveObj do
			if pIsInList then
				pGroupObj.allYABlocksIn.remove(blockObj);
				newGroupObj.allYABlocksIn.add(blockObj);
			else
				pGroupObj.allYABlocksOut.remove(blockObj);
				newGroupObj.allYABlocksOut.add(blockObj);
			endif;
			
		endforeach;
	endif;
epilog
	delete allBlocksToMoveObj;
end;</source>
        <access>protected</access>
        <Parameter name="pGroupObj" type="CM_YABlockGroup" usage="input"/>
        <Parameter name="pIsInList" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doMoveMultipleBlocks" id="1aa01e5a-68d1-42b9-8099-874c4e0572e8">
        <updating/>
        <source>doMoveMultipleBlocks(pIsUp:Boolean) updating;
// --------------------------------------------------------------------------------
// Created:		14 June 2005 by cnwdad1
//
// Purpose:		Moves the currently selected blocks up or down one element position
//				in the appropriate array.
//
// Parameters:	pIsUp - If true, the element will be moved up.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	listboxObj		: ListBox;
	blockObj		: CM_YABlock;
	allBlocksObj	: CM_YABlockSet;
	listPointer		: Integer;
	listCount		: Integer;
	
begin
	listboxObj	:=	self.myLstLocations;
	listCount	:=	listboxObj.listCount;
	create allBlocksObj transient;
	
	if pIsUp then
		foreach listPointer in 1 to listCount do
			if listboxObj.itemSelected[listPointer] then
				blockObj	:=	listboxObj.itemObject[listPointer].CM_YABlock;
				
				if self.myOptSortIn.value then
					self.allBlockGroupsIn.moveElement(blockObj, pIsUp);
				else
					self.allBlockGroupsOut.moveElement(blockObj, pIsUp);
				endif;
				
				allBlocksObj.add(blockObj);
			endif;
		endforeach;
	else
		foreach listPointer in listCount to 1 step -1 do
			if listboxObj.itemSelected[listPointer] then
				blockObj	:=	listboxObj.itemObject[listPointer].CM_YABlock;
				
				if self.myOptSortIn.value then
					self.allBlockGroupsIn.moveElement(blockObj, pIsUp);
				else
					self.allBlockGroupsOut.moveElement(blockObj, pIsUp);
				endif;
				
				allBlocksObj.add(blockObj);
			endif;
		endforeach;
	endif;
	
	self.populateLocationsListbox(true);
	
	foreach blockObj in allBlocksObj do
		listPointer	:=	listboxObj.findObject(blockObj);
		
		if listPointer &lt;&gt; CNEC_NULL_INDEX then
			listboxObj.itemSelected[listPointer]	:=	true;
		endif;
	endforeach;
epilog
	delete allBlocksObj;
end;</source>
        <Parameter name="pIsUp" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doParseLocationString" id="2ce283c9-7943-4a53-a89a-c0dc5621bf5e">
        <updating/>
        <source>doParseLocationString(pLocationString:String; pIsSortForIn:Boolean; pIsRebuild:Boolean) updating;
// --------------------------------------------------------------------------------
// Created:		10 May 2005 by cnwdad1
//
// Purpose:		Using the string entered by the user, add one or more locations to
//				an existing YA Block, or to a new YA Block.
//
// Parameters:	pLocationString - A string of location Ids to parse.
//				pIsSortForIn - True if the new locations are to be sorted for "IN"
//				pIsRebuild - If true, then all existing YA Blocks will be discarded,
//					and new Blocks will be rebuilt from the Location String.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	parserObj				: CM_YAParser;
	allBlocksInObj			: CM_YABlockArray;
	allBlocksOutObj			: CM_YABlockArray;
	firstBlockGroupIn,
	firstBlockGroupOut,
	blockGroupObj			: CM_YABlockGroup;
	block					: CM_YABlock;
	targetLocation			: String;
	isInheritCriteria		: Boolean;
	isDeckingEnabled		: Boolean;
	
begin
//	blockGroupObj	:=	self.allBlockGroupsIn.first();
	targetLocation	:=	pLocationString;
	
	if targetLocation = null then
		app.setContinueCMExceptions(false);
		app.raiseCMException1(ERR_INVALID_LOCN_YA, "Please enter the location to add.", null, null);
		
		return;
	endif;
	
	create parserObj transient;
	create allBlocksInObj transient;
	create allBlocksOutObj transient;
	
/*
// cnwdad1 17/05/2006 - As part of CCMS 1010.  The rebuild flag is always false anyway.
	if pIsRebuild then
		self.allBlockGroupsIn.purge();
		self.allBlockGroupsOut.purge();
	else
		self.allBlockGroupsIn.copy(allBlocksInObj);
		self.allBlockGroupsOut.copy(allBlocksOutObj);
		parserObj.loadBlocks(allBlocksInObj, allBlocksOutObj);
	endif;
*/
	foreach blockGroupObj in self.allBlockGroupsIn do
		blockGroupObj.allYABlocksIn.copy(allBlocksInObj);
		blockGroupObj.allYABlocksOut.copy(allBlocksOutObj);
	endforeach;
	
	parserObj.loadBlocks(allBlocksInObj, allBlocksOutObj);
	
//	blockGroupObj.allYABlocksIn.copy(allBlocksInObj);
//	blockGroupObj.allYABlocksOut.copy(allBlocksOutObj);
//	parserObj.loadBlocks(allBlocksInObj, allBlocksOutObj);
	
	// Now we need to decide whether we're going to inherit YA Criteria from other
	// Yard Allocations which this new one may overlap.  We will only inherit them
	// if it's the first Location for this Yard Allocation, and if no other Criteria
	// have already been entered or inherited previously.
	
	if self.myYardAllocation = null
	and self.allBlockGroupsIn.isEmpty()
	and self.allBlockGroupsOut.isEmpty()
	and self.myCtrlCriteria.allSelectedCPs.isEmpty()
	then
		isInheritCriteria	:=	true;
	else
		isInheritCriteria	:=	false;
	endif;
	
	// Ok, now parse the location string.
	
	firstBlockGroupIn 	:= null;
	firstBlockGroupOut	:= null;
	
	if parserObj.parseLocations(self.myProxyYA, targetLocation) then
		foreach blockGroupObj in self.allBlockGroupsIn do
			if firstBlockGroupIn = null then
				firstBlockGroupIn := blockGroupObj;
			endif;
			
			foreach block in blockGroupObj.allYABlocksIn do
				if not 	parserObj.allYABlocksIn.includes(block) then
				//	blockGroupObj.allYABlocksIn.remove(block);
				else
					parserObj.allYABlocksIn.remove(block);
				endif;
			endforeach;
		endforeach;
		
		if firstBlockGroupIn &lt;&gt; null then
			parserObj.allYABlocksIn.copy(firstBlockGroupIn.allYABlocksIn);
		endif;
		
		foreach blockGroupObj in self.allBlockGroupsOut do
			if firstBlockGroupOut = null then
				firstBlockGroupOut := blockGroupObj;
			endif;
			
			foreach block in blockGroupObj.allYABlocksOut do
				if not 	parserObj.allYABlocksOut.includes(block) then
				//	blockGroupObj.allYABlocksIn.remove(block);
				else
					parserObj.allYABlocksOut.remove(block);
				endif;
			endforeach;
		endforeach;
		
		if firstBlockGroupOut &lt;&gt; null then
			parserObj.allYABlocksOut.copy(firstBlockGroupOut.allYABlocksOut);
		endif;
/*		blockGroupObj.allYABlocksIn.clear();
		blockGroupObj.allYABlocksOut.clear();
		parserObj.allYABlocksIn.copy(blockGroupObj.allYABlocksIn);
		parserObj.allYABlocksOut.copy(blockGroupObj.allYABlocksOut);*/
		self.populateLocationsListbox(pIsSortForIn);
		
		if isInheritCriteria then
			self.inheritCriteria();
		endif;
	else
		app.msgBox(parserObj.errorMessage, "Error", MsgBox_Exclamation_Mark_Icon + MsgBox_OK_Only);
		return;
	endif;
	
	// Finally, set up the Decking Options for the location block.
	
	if self.myLstLocations.listIndex &lt;&gt; CNEC_NULL_INDEX
	and (not CM_YABlockBlock.hasInstance(self.myLstLocations.listObject))
	then
		isDeckingEnabled	:=	true;
	else
		isDeckingEnabled	:=	false;
	endif;
	
	self.enableDeckingOptionsButtons(isDeckingEnabled);
//process.debug();
epilog
	delete allBlocksInObj;
	delete allBlocksOutObj;
	delete parserObj;
end;</source>
        <Parameter name="pLocationString" type="String"/>
        <Parameter name="pIsSortForIn" type="Boolean"/>
        <Parameter name="pIsRebuild" type="Boolean"/>
    </JadeMethod>
