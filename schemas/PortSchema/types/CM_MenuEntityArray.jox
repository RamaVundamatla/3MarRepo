<CollClass name="CM_MenuEntityArray" id="0891ee3a-8e69-4f8a-a90b-fb1b05acb150">
    <memberType name="CM_MenuEntity"/>
    <superclass name="CM_MenuArray"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="cmenu"/>
    <JadeMethod name="addBackSortedEntities" id="08bc5c0d-c7d3-4567-991a-98e607c56bec">
        <lockReceiver/>
        <updating/>
        <source>addBackSortedEntities(pSorterObj:CnEcSorter; pIsAddAll:Boolean; pIsParents:Boolean) updating, protected;
// --------------------------------------------------------------------------------
// Created:		31 October 2005 by cnwdad1
//
// Purpose:		Addes the sorted Menu Entities back into the receiver.
//
// Parameters:	pSorterObj - A reference to the sorter object.
//				pIsAddAll - True if all entities are to be added together (i.e.
//					regardless of whether the entity has children).
//				pIsParents - True if only the entities with children are to be added
//					back.  If false, then only entities with no children will be
//					added back.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	sortKeyObj		: Object;
	binaryData		: Binary;
	stringData		: String;
	sortedEntityObj	: Object;
	
begin
	if pIsAddAll then
		// Now, add back all of the entities...
		
		foreach sortKeyObj in pSorterObj.allKeys do
			stringData	:=	sortKeyObj.CnEcSortKey.getKeyWithObject(sortedEntityObj).String;
			self.add(sortedEntityObj.CM_MenuEntity);
		endforeach;
	else
		// Now, add back the entities...
		
		foreach sortKeyObj in pSorterObj.allKeys do
			stringData	:=	sortKeyObj.CnEcSortKey.getKeyWithObject(sortedEntityObj).String;
			
			if pIsParents then
				if sortedEntityObj.CM_MenuEntity.hasChildren() then
					self.add(sortedEntityObj.CM_MenuEntity);
				endif;
			else
				if not sortedEntityObj.CM_MenuEntity.hasChildren() then
					self.add(sortedEntityObj.CM_MenuEntity);
				endif;
			endif;
		endforeach;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="pSorterObj" type="CnEcSorter"/>
        <Parameter name="pIsAddAll" type="Boolean"/>
        <Parameter name="pIsParents" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="sortEntities" id="96a63a5e-671f-4ddf-8ef3-8dd394e519f1">
        <lockReceiver/>
        <updating/>
        <source>sortEntities(pIsDescending:Boolean; pIsParentsFirst:Boolean) updating;
// --------------------------------------------------------------------------------
// Created:		26 October 2005 by cnwdad1
//
// Purpose:		Sorts the receiver's members alphabetically.
//
// Parameters:	pIsDescending - True if the entities are to be sorted in descending
//					order.
//				pIsParentsFirst - If true, the entities with children will be placed
//					at the top or the sort order (or bottom if descending order),
//					followed by entities with no children.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	sorterObj		: CnEcSorter;
	entityObj		: CM_MenuEntity;
	
begin
	// Set up the sorter object.
	
	create sorterObj transient;
	sorterObj.setSortType(CnEcSorter.AS_STRING, pIsDescending);
	
	// Add the menu entities to the sorter (they'll be sorted as they're added).
	
	foreach entityObj in self do
		sorterObj.addKeyWithObject(entityObj.getHeading(), entityObj);
	endforeach;
	
	// Clear out the array members, then add them back in their sorted order.
	
	self.clear();
	
	if pIsParentsFirst then
		if pIsDescending then
			// Now, add back the entities with no children...
			self.addBackSortedEntities(sorterObj, false, false);
			
			// Finally, add back the entities with children...
			self.addBackSortedEntities(sorterObj, false, true);
		else
			// Now, add back the entities with children...
			self.addBackSortedEntities(sorterObj, false, true);
			
			// Finally, add back the entities with no children...
			self.addBackSortedEntities(sorterObj, false, false);
		endif;
	else
		// Now, add back all of the entities...
		self.addBackSortedEntities(sorterObj, true, null);
	endif;
epilog
	delete sorterObj;
end;</source>
        <Parameter name="pIsDescending" type="Boolean"/>
        <Parameter name="pIsParentsFirst" type="Boolean"/>
    </JadeMethod>
</CollClass>
