    <JadeMethod name="showAdditionalRemarks" id="17828fa1-b1e7-47d5-89c7-ca4219d197c9">
        <source>showAdditionalRemarks( _rem1 : String; _rem2 : String );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 Mar 2025	navcs2	MTN-34172	CUX - Additional Remarks of cargo does not pop up in Road Gate Screen during Cargo Release

*/

vars

	msg : String;

begin

	if _rem1.trimBlanks &lt;&gt; null then
		msg := app.getEntTableRowTranslation(ETRow_RemarksAdditional1,ETGrp_CargoDetails) &amp; ":" &amp; CrLf &amp; Tab &amp; _rem1;
	endif;
	if _rem2.trimBlanks &lt;&gt; null then
		if msg.trimBlanks &lt;&gt; null then
			msg := msg  &amp; CrLf;
		endif;
		msg := msg  &amp; app.getEntTableRowTranslation(ETRow_RemarksAdditional2,ETGrp_CargoDetails) &amp; ":" &amp; CrLf &amp; Tab &amp; _rem2;
	endif;

	if msg.trimBlanks &lt;&gt; null then	
		app.msgBox( msg, app.getErrorString(Attention), MsgBox_OK_Only );
	endif;

epilog

end;</source>
        <Parameter name="_rem1" type="String"/>
        <Parameter name="_rem2" type="String"/>
    </JadeMethod>
    <JadeMethod name="showCargoPicker" id="c61ec583-2c14-468a-a175-d384b5233d6b">
        <updating/>
        <source>showCargoPicker(cargoId: String) : Boolean updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 May 2013	cnwdw1	Initial creation
// 06 Sep 2016	cnwrs1	TFS 2586 dont always include archived voyages and lookup reveresed even if we found data in non reverese lookup
*/
vars
	cargoType	: CM_CargoType;
	tis			: CM_TISet;
	selectedTi	: CM_TrackedItem;
	altTI		: CM_TrackedItem;
	
begin
	cargoType := self.cmbType.getObject().CM_CargoType;
	if cargoId = null or cargoType = null or not cargoType.isBreakBulk() then
		return false;
	endif;
	
	altTI := self.myTerminal.allOnsiteTIsByAlternativeId[cargoId];		// 23/09/2014 cnwar2 #34597
	
	create tis transient;
	
	if self.myTerminal.allOnsiteTIsByCargoTypeId[cargoType.id,cargoId] = null
	and altTI = null then		// 23/09/2014 cnwar2 #34597
		return false;
	endif;
	
	self.myTerminal.lookupAllOnsiteTrackedItems(cargoType.id, cargoId, tis, false, null);
	if altTI &lt;&gt; null then
		tis.addNoDuplicates(altTI, false);		// 23/09/2014 cnwar2 #34597
	endif;
	if tis.size &lt; 2 then
		return false;
	endif;

	// Remove any that have already been selected. use vvr from mainForm
	
	//self.myAssistant.pickerWindowForBreakBulk(tis, self.myTerminal, false, selectedTi);
	self.myAssistant.pickerWindowForBreakBulk(tis, self.myTerminal, false, selectedTi, self);	//22 Dec 2016	NDL	TFS 3134
	if selectedTi &lt;&gt; null then
		self.myTI := selectedTi;
		self.txtCargoIDvalue.text := selectedTi.id;
	endif;
	
	return true;
epilog
	delete tis;
	app.mousePointer := MousePointer_Default;
end;</source>
        <Parameter name="cargoId" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="showChkAnyId" id="aa0025a6-3778-4b3c-acf3-7ecd584e5648">
        <source>showChkAnyId() protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 August 2014	cnwndl1	Initial creation	Par 34675

*/

vars

	gteRelease : CMGTE_Release;

begin
	if self.myRealGTEEntity &lt;&gt; null then
		if self.myRealGTEEntity.isKindOf(CMGTE_Release) then
			gteRelease := self.myRealGTEEntity.CMGTE_Release;
		endif;
	elseif self.myPxyGTEEntity &lt;&gt; null then
		if self.myPxyGTEEntity.isKindOf(CMGTE_Release) then
			gteRelease := self.myPxyGTEEntity.CMGTE_Release;
		endif;
	endif;
	
	if gteRelease &lt;&gt; null and gteRelease.getIsAnyId() and gteRelease.myTrackedItem = null then	//25 Feb 2016	NDL	Par 37591
		self.chkAnyId.isHidden:= false;
		self.chkAnyAmount.isHidden:= false;	//21 Mar 2017	NDL	TFS 3813
		self.chkAnyAmount.setValue(gteRelease.getIsAnyAmount);	//21 Mar 2017	NDL	TFS 3813
	else
		self.chkAnyId.isHidden:= true;
		self.chkAnyId.setValue(false);	
		self.chkAnyAmount.isHidden:= true;	//21 Mar 2017	NDL	TFS 3813
		self.chkAnyAmount.setValue(false);	//21 Mar 2017	NDL	TFS 3813
	endif;
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
