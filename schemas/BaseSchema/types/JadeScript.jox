<Class name="JadeScript">
    <JadeMethod name="aaaTestDynaDictKey" id="07672f55-caf5-4481-8b0a-cb8455ab9148">
        <source>aaaTestDynaDictKey() protected;
// --------------------------------------------------------------------------------
// Created:		26 March 2004 by cnwdad2
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	parameterObj		: CnEcDocParameter;
	docListObj			: CnEcDocModelList;
	docSchemaObj		: CnEcDocModelSchema;
	schemaObj			: Schema;
	allSchemaClasses	: ClassColl;
	classObj			: Class;
	
begin
	schemaObj	:=	currentSchema;
	
	create docListObj transient;
	create parameterObj transient;
	
	docSchemaObj		:=	docListObj.createDocSchema(schemaObj);
	allSchemaClasses	:=	schemaObj.getAllClasses(parameterObj.isIncludeJadeClasses);
	
	foreach classObj in allSchemaClasses do
		docSchemaObj.createDocClass(classObj, null);
	endforeach;
	
	parameterObj.populateClassAndFeatureLists(docListObj);
	write parameterObj.allClasses.size().String &amp; " classes loaded.";
epilog
	delete parameterObj;
	delete docListObj;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="cnwdad1_AnalyzeBaseSchema" id="a7146005-eafa-4689-b0d9-0305f46ef87e">
        <source>cnwdad1_AnalyzeBaseSchema();
// -----------------------------------------------------------------------------
// Created:		17 January 2002 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------
vars
	analyzerObj	: CnSchemaAnalyser;
	karmaObj	: CnKarmaCntrl;
	startTime	: Integer;
	
begin
	startTime	:=	app.clock();
	create karmaObj transient;
	create analyzerObj transient;
	
	analyzerObj.analyse(null, false);
epilog
	delete analyzerObj;
	delete karmaObj;
	
	write "Schema analyzed in " &amp; startTime.cnEcClockDifference().numberFormat() &amp; " seconds.";
end;</source>
    </JadeMethod>
    <JadeMethod name="cnwdad1_CheckBaseClassText" id="e61ea983-ab4e-4f12-a787-ccfa053450c6">
        <source>cnwdad1_CheckBaseClassText() protected;
// --------------------------------------------------------------------------------
// Created:		08 May 2006 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
constants
	CLASS_TEXT		: String = "P R O P R I E T A R Y   N O T I C E";
	
vars
	allClassesObj	: ClassColl;
	classObj		: Class;
	startTime		: Integer;
	classCount		: Integer;
	missingCount	: Integer;
	
begin
	startTime		:=	app.clock();
	classCount		:=	0;
	missingCount	:=	0;
	create allClassesObj transient;
	
	self.cnwdad1_GetBaseSchemaClasses(allClassesObj);
	
	write "Checking BaseSchema class text for proprietary notice...";
	
	foreach classObj in allClassesObj do
		classCount	:=	classCount + 1;
		
		if classObj.text.pos(CLASS_TEXT, 1) = 0 then
			missingCount	:=	missingCount + 1;
			write classObj.name;
		endif;
		
		//if classObj.userText &lt;&gt; null then
		//	write classObj.name;
		//endif;
	endforeach;
	
	write missingCount.cnEcNumberFormat() &amp; " BaseSchema classes of " &amp; classCount.cnEcNumberFormat() &amp; " are missing the proprietary notice.";
epilog
	delete allClassesObj;
	write "Class text checked in " &amp; startTime.cnEcClockDifference().numberFormat() &amp; " seconds.";
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="cnwdad1_CheckMethodsInError" id="be6612a1-cf52-48ea-86af-61bd01c35b75">
        <source>cnwdad1_CheckMethodsInError();
// --------------------------------------------------------------------------------
// Created:		13 August 2002 by cnwdad1
//
// Purpose:		FAQ 14918 How do I know what methods are uncompiled or in error in
//				a deployed system ?  This script checks for any methods that are
//				uncompiled or in error.  When run the relevant methods will be
//				written to the Interpreter Output Viewer window.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	methodObj			: JadeMethod;
	externalMethodObj	: ExternalMethod;
	compilerObj			: JadeCompiler;
	startTime			: Integer;
	
begin
	startTime	:=	app.clock();
	create compilerObj transient;

	write "&lt;&lt;&lt; Checking JADE Methods &gt;&gt;&gt;";
	
	foreach methodObj in JadeMethod.instances do
		if not methodObj.compiledClean() then
			write	"Schema: " &amp; methodObj.getSchema().name &amp;
					"   Class: " &amp; methodObj.schemaType.name &amp;
					"   Method: " &amp; methodObj.name  &amp;
					"   Error: " &amp; methodObj.errorCode.String &amp;
					" - " &amp; compilerObj.getErrorText(methodObj.errorCode);
		endif;
	endforeach;

	write CrLf &amp; "&lt;&lt;&lt; Checking External Methods &gt;&gt;&gt;";

	foreach externalMethodObj in ExternalMethod.instances do
		if not externalMethodObj.compiledClean() then
			write	"Schema: " &amp; externalMethodObj.getSchema().name &amp;
					"   Class: " &amp; externalMethodObj.schemaType.name &amp;
					"   Method: " &amp; externalMethodObj.name;
		endif;
	endforeach;
epilog
	delete compilerObj;
	
	write "Method check completed in " &amp; startTime.cnEcClockDifference().numberFormat() &amp; " seconds.";
end;</source>
    </JadeMethod>
    <JadeMethod name="cnwdad1_Convert_Hex_Color" id="1a470725-3fcd-4cca-82c5-1eb26a472a51">
        <source>cnwdad1_Convert_Hex_Color() protected;
// --------------------------------------------------------------------------------
// Created:		12 February 2007 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	write CNEC_HEX_BEIGE[2:end].cnEcHexValue();
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="cnwdad1_DoBackup" id="308828a7-36d7-4bde-bd46-d25e99d62031">
        <source>cnwdad1_DoBackup();
// --------------------------------------------------------------------------------
// Created:		06 February 2001 by cnwdad1
//
// Purpose:		Used as the initialize method for a backup application which backs
//				up the development environment system directory to a directory
//				specified in the ADE initialization file.
//
//				It backs up the specific d:\jade51\system directory
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	dbAdminObj			: JadeDatabaseAdmin;
	allDroppedFiles		: DbFileArray;
	dbFileObj			: DbFile;
	isIncludeSysFiles	: Boolean;
	isVerifyFiles		: Boolean;
	isCompressFiles		: Boolean;
	isAllowOverwrite	: Boolean;
	isQuiesce			: Boolean;
	backupDirectory		: String;
	messageTitle		: String;
	taskMessage			: String;
	startTime			: Integer;

begin
	startTime	:=	app.clock();
	
	create dbAdminObj transient;
	create allDroppedFiles transient;
	
	backupDirectory		:=	app.getProfileString(app.getIniFileName(), "JEDI", "JadeSystemBackupDirectory", "c:\temp\jade");

	isIncludeSysFiles	:=	true;		// Exclude system files from backup.
	isVerifyFiles		:=	false;		// Verify data during backup.
	isCompressFiles		:=	true;		// Don’t perform on-the-fly data compression.
	isAllowOverwrite	:=	true;		// Overwrite existing files in backup directory.
	isQuiesce			:=	false;		// Don't quiesce =&gt; full online backup.

	dbAdminObj.backupAllDbFiles(backupDirectory, isIncludeSysFiles, isVerifyFiles,	isCompressFiles, isAllowOverwrite, isQuiesce, allDroppedFiles);
	
	// The database backup completed without exceptions.
	messageTitle	:=	"Database Backup Complete";
epilog
	if process.isInExceptionState then
		// A fatal exception has occurred during the backup, the activated
		// exception handler aborted the current action - report the failure.
		messageTitle	:=	"Database Backup Failed";
	endif;

	// Report missing files (a missing file is only valid if it has never been created).

	if (allDroppedFiles.cnEcIsNotEmpty()) then
		taskMessage	:=	"The following files were not backed up :" &amp; CrLf;
		
		foreach dbFileObj in allDroppedFiles do
			taskMessage	:=	taskMessage &amp; dbFileObj.name &amp; ".dat" &amp; CrLf;
		endforeach;
	endif;

	if messageTitle = "Database Backup Failed" then
		app.msgBox(taskMessage &amp; Cr, messageTitle, MsgBox_Exclamation_Mark_Icon + MsgBox_OK_Only);
	endif;

	delete dbAdminObj;
	delete allDroppedFiles;
	
	write "Database Backup completed in " &amp; startTime.cnEcClockDifference().String &amp; " seconds.";
end;</source>
    </JadeMethod>
    <JadeMethod name="cnwdad1_Email_Test" id="72f47e67-1a54-4698-9847-bdcfa7b8585c">
        <source>cnwdad1_Email_Test() protected;
// --------------------------------------------------------------------------------
// Created:		21 June 2008 by cnwdad1
