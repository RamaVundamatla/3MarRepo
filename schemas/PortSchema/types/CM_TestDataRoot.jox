    <JadeMethod name="getNextBerth" id="75fde5a7-1b07-4cf2-bb37-1a3c9aafbd44">
        <updating/>
        <source>getNextBerth(_terminal : CM_Terminal) : CM_TestDataBerth updating;

vars
	tmpBerth	: CM_TestDataBerth;
	idx,
	tmpNum		: Integer;
	
begin
	
	if self.allTestDataBerths.isEmpty then
		beginTransaction;
		self.createBerths(_terminal);
		commitTransaction;
	endif;

	tmpNum := self.allTestDataBerths.size;
	if tmpNum = 0 then
		return tmpBerth;
	endif;
	
	while idx = 0 do
		idx := app.random(tmpNum);
	endwhile;

	beginTransaction;
	exclusiveLock(self.allTestDataBerths);
	//tmpBerth := self.allTestDataBerths.first.CM_TestDataBerth;
	tmpBerth := self.allTestDataBerths[idx].CM_TestDataBerth;
	//exclusiveLock(tmpBerth);
	//self.allTestDataBerths.removeAt(idx);
	//self.allTestDataBerths.add(tmpBerth);
	commitTransaction;

	return tmpBerth;

end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <ReturnType type="CM_TestDataBerth"/>
    </JadeMethod>
    <JadeMethod name="getNextMoveTI" id="d7705bc1-e11c-4170-b74a-1207fdde94e8">
        <source>getNextMoveTI(_ti : CM_TrackedItem output; _lc : CM_LocationsController output);
// ---------------------------------------------------------------------------
// Created:     21 May 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin

	exclusiveLock(self.myTestDataMove);
	beginTransaction;
	self.myTestDataMove.getNextTI(_ti, _lc);
	commitTransaction;

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem" usage="output"/>
        <Parameter name="_lc" type="CM_LocationsController" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getNextRTDevice" id="34c98c1b-7804-42e0-bcb9-c82ac1424138">
        <source>getNextRTDevice(_terminal : CM_Terminal) : CM_RadioTelemetryDevice;
// ---------------------------------------------------------------------------
// Created:     07 April 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpDevice	: CM_RadioTelemetryDevice;
	tmpTestData	: CM_TestDataRTDevice;
begin

	if _terminal = null then
		return null;
	endif;

	tmpTestData := self.allTestDataRTDevices[_terminal];
	if tmpTestData = null then
		beginTransaction;
		tmpTestData := self.createRTDevices(_terminal);
		commitTransaction;
	endif;
	
	tmpDevice := tmpTestData.getNextRTDevice();
	
	return tmpDevice;
	
end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <ReturnType type="CM_RadioTelemetryDevice"/>
    </JadeMethod>
    <JadeMethod name="getNextTestProduct" id="0b552ade-b625-4f31-acce-6ebd938ab79e">
        <updating/>
        <source>getNextTestProduct() : CM_TestDataProductCode updating;

vars
	tmpProd	: CM_TestDataProductCode;
	tmpNum,
	idx		: Integer;
	
begin

	if self.allTestProducts.isEmpty then
		beginTransaction;
		exclusiveLock(self.allTestProducts);
		self.createTestOperators();
		commitTransaction;
	endif;
	
	tmpNum := self.allTestProducts.size;
	if tmpNum = 0 then
		return tmpProd;
	endif;
	
	while idx = 0 do
		idx := app.random(tmpNum);
	endwhile;

	beginTransaction;
	exclusiveLock(self.allTestProducts);
	tmpProd := self.allTestProducts[idx].CM_TestDataProductCode;
	//tmpProd := self.allTestProducts.first.CM_TestDataProductCode;
	//self.allTestProducts.removeAt(idx);
	//self.allTestProducts.add(tmpProd);
	commitTransaction;
	
	return tmpProd;

end;</source>
        <ReturnType type="CM_TestDataProductCode"/>
    </JadeMethod>
    <JadeMethod name="getNextTiOnly" id="95d6cbef-d84f-4eed-a783-4fb6d867236a">
