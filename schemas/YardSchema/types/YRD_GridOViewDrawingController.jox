    <JadeMethod name="getGCAreaCellSize" id="65744d41-469c-4edc-a648-51761cbcdbc9">
        <source>getGCAreaCellSize() : Real protected;
/*

Date		Who		Reason
13 October 2015	cnwer1	Initial creation PAR 36616

*/

vars

begin
	return (GridCellWidth + GridBorderWidth) * self.scaleFactor ;
epilog

end;</source>
        <access>protected</access>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="getMachineWorkzoneLinePos" id="2c18d5b7-5df4-4efa-b120-c42b4a1baf4e">
        <source>getMachineWorkzoneLinePos(_cmifMachineWorkZone : CMIF_MachineWorkzone input) : Integer;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 August 2009	cnwer1	Initial creation

*/

vars
	iter : Iterator;
	otherMachineWZs : CMIF_MachineWorkzone;
	selfPosition,
	numOthers, count  : Integer;
	result : Integer;
	otherAreasToCheck,
	areaOrder : ObjectArray;
	areaToCheck  : CM_TerminalAreaMaster;
	searching : Boolean;
begin

	iter:=self.allCMIFMachineWorkzones.createIterator;
	
	
	create otherAreasToCheck transient;
	create areaOrder transient;
	if _cmifMachineWorkZone.myRTGLane.isKindOf(CM_RTGLane) then
		otherAreasToCheck.add(_cmifMachineWorkZone.myRTGLane);
		if _cmifMachineWorkZone.myRTGLane.CM_RTGLane.allTAsByTypeId.size &gt; 0 then
			_cmifMachineWorkZone.myRTGLane.CM_RTGLane.allTAsByTypeId.copy(otherAreasToCheck);
		endif;
	elseif _cmifMachineWorkZone.myRTGLane.isKindOf(CM_RTGArea) then
		if _cmifMachineWorkZone.myRTGLane.CM_RTGArea.allTerminalAreaGroups.size &gt; 0 then
			otherAreasToCheck.add(_cmifMachineWorkZone.myRTGLane.CM_RTGArea.allTerminalAreaGroups.first.CM_RTGLane);
			_cmifMachineWorkZone.myRTGLane.CM_RTGArea.allTerminalAreaGroups.first.CM_RTGLane.allTAsByTypeId.copy(otherAreasToCheck);
		else
			otherAreasToCheck.add(_cmifMachineWorkZone.myRTGLane);
		endif;
		
	endif;
	
	
	areaToCheck:=otherAreasToCheck.first.CM_TerminalAreaMaster;
	self.allCMIFMachineWorkzones.startKeyGeq(areaToCheck,null,iter);
	searching:=true;
	numOthers:=0;
	selfPosition:=0;
	count:=1;
	//global.cnwer1Write("checking machine " &amp; _cmifMachineWorkZone.myMachine.id &amp; otherAreasToCheck.size.String);
	
	while searching do :outerLoop 
		//global.cnwer1Write(areaToCheck.id);
		while iter.next(otherMachineWZs) do
			if areaOrder.includes(otherMachineWZs)	then
				continue;
			endif;
			if otherMachineWZs = _cmifMachineWorkZone then
				selfPosition:=count;
				
				
			endif;
			
			if otherMachineWZs.myRTGLane.isKindOf(CM_TerminalArea) and areaToCheck.isKindOf(CM_RTGLane) then
				if not areaToCheck.CM_RTGLane.allTAsByTypeId.includes(otherMachineWZs.myRTGLane.CM_TerminalArea) then
					break;
				endif;
			endif;
			
			if otherMachineWZs.myRTGLane.isKindOf(CM_RTGLane) and areaToCheck.isKindOf(CM_TerminalArea) then
				if not otherMachineWZs.myRTGLane.CM_RTGLane.allTAsByTypeId.includes(areaToCheck.CM_TerminalArea) then
					break;
				endif;
			endif;
			if otherMachineWZs.myRTGLane &lt;&gt; areaToCheck then
				break;
			endif;
			areaOrder.add(otherMachineWZs);
			count:=count + 1;
		endwhile;
		
		if otherAreasToCheck.size = 0 then
			break outerLoop;
		else
			areaToCheck:=otherAreasToCheck.first.CM_TerminalAreaMaster;
			iter.reset;
			self.allCMIFMachineWorkzones.startKeyGeq(areaToCheck,null,iter);
			
			otherAreasToCheck.remove(areaToCheck);
		endif;
	endwhile;
	
	//global.cnwer1Write(_cmifMachineWorkZone.myMachine.id &amp; " " &amp; selfPosition.String);
	//global.cnwer1Write(areaOrder.listString(",",CMIF_MachineWorkzone::myMachine.name));
	if selfPosition = 1 then
		return 0;
	elseif selfPosition.isEven then
			return -(selfPosition div 2);
	elseif selfPosition.isOdd then
		return (selfPosition div 2);
	endif;
	
	
	

epilog
	delete iter;
	delete otherAreasToCheck;
	delete areaOrder;
end;</source>
        <Parameter name="_cmifMachineWorkZone" type="CMIF_MachineWorkzone" usage="input"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
