    <JadeMethod name="pxyCreateUpdateProxy" id="7a438a20-be7c-4084-82e6-a2f01a951033">
        <source>pxyCreateUpdateProxy(): SelfType;
/*

Purpose:			

Parameters:			

Return Value:		


Date			Who		Reason
17 August 2009	cnwer1	Initial creation
20/04/2011		cnwmh5	PAR #27401 - Add code to handle prossible exceptions occurring when
						trying to create the proxy
*/

vars

	pxyTerminalAreaGroup : CM_TerminalAreaGroup;
	completedOK		: Boolean;
	
begin

	pxyTerminalAreaGroup := inheritMethod();
	self.allTAsByTypeId.copy(pxyTerminalAreaGroup.allTAsByTypeId);

	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return pxyTerminalAreaGroup;

epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete pxyTerminalAreaGroup;
	endif;

end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setDetails" id="47fec4ee-df43-4128-9957-d07ab0fc1542">
        <updating/>
        <source>setDetails(_id 		: String;
		_type		: Integer;
		_terminal 		: CM_Terminal;
		_label		: String) updating;
/*
----------   ----------  --------------------------------------------------
Created:	07 August 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
19 AUG		CNWER1	 	PAR 17760 Changed parameter was _area now _terminal 
									- use to just set self.myTerminal to _area.myTerminal
*/	
vars

begin
	self.id 			:= _id;
	self.type 			:= _type;
	self.myTerminal 	:= _terminal;
	self.label			:= _label;
	
	

end;</source>
        <Parameter name="_id" type="String"/>
        <Parameter name="_type" type="Integer"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_label" type="String"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="bc3809ea-0384-4f84-bf49-c529f523bf6d">
        <updating/>
        <source>setForCreate(_proxy: CM_TerminalAreaGroup input; _passport: CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
31 August 2009	cnwer1	Initial creation

*/

vars
	ta : CM_TerminalArea;
begin
	inheritMethod(_proxy, _passport);
	self.label:=_proxy.label;
	
	self.updateAllTerminalAreas(_proxy);
	
epilog

end;</source>
        <Parameter name="_proxy" type="CM_TerminalAreaGroup" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="e87aa34c-d349-415c-8fb5-a5eee64688c6">
        <updating/>
        <source>setForUpdate(_proxy: CM_TerminalAreaGroup) updating;
/*

Purpose:			

Parameters:			

