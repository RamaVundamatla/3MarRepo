    <JadeMethod name="canHaveAsChild" id="0b91a0bb-1778-41d5-aa06-6e0daaab0553">
        <source>canHaveAsChild(pProposedChild: Control; pRejectionReason: String output): Boolean;

begin
	if (not inheritMethod(pProposedChild, pRejectionReason)) then
		return false;
	endif; 

	if pProposedChild.isKindOf(BaseControl)
	or pProposedChild.isKindOf(Folder)
	or pProposedChild.isKindOf(Frame)
	or pProposedChild.isKindOf(GroupBox)
	or pProposedChild.isKindOf(ListBox)
	or pProposedChild.isKindOf(Picture)
	or pProposedChild.isKindOf(Table)
	or pProposedChild.isKindOf(TextBox)
	then
		return true;
	else
		pRejectionReason	:=	pProposedChild.class().name &amp; " controls not allowed in a CMUI_SplitContainer";
		return false;
	endif;
end;</source>
        <Parameter name="pProposedChild" type="Control"/>
        <Parameter name="pRejectionReason" type="String" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="cnEcResizeContents" id="af238ced-2001-45af-957f-40705d2b0d88">
        <updating/>
        <source>cnEcResizeContents() updating;

begin
	self.resizeChildrenAndSplitter();
end;</source>
    </JadeMethod>
    <JadeMethod name="cnEc_MouseUp" id="aa967f10-7584-48bf-b7ea-1dcc131173ea">
        <updating/>
        <source>cnEc_MouseUp(wndw: Window input; button: Integer; shift: Integer; x: Real; y: Real) updating, protected;

// Called by the splitter bar when the user mouse action is complete

begin
	// Calculate and set the new ratio, and resize the child controls

	if self.isSplitHorizontal then
		self.leftToRightRatio := (self.myHorizontalSplitter.top / self.clientHeight * 100).Integer;
	else
		self.leftToRightRatio := (self.myVerticalSplitter.left / self.clientWidth * 100).Integer;
	endif;
	
	self.pinnedPosition	:=	0;
	self.useRatio := true;

	self.resizeChildrenAndSplitter();

	// Invoke any form logic required after the move
	
	self.splitterMove(self);

	inheritMethod(wndw, button, shift, x, y);
end;</source>
        <access>protected</access>
        <Parameter name="wndw" type="Window" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="getControlByName" id="a68c5f62-99e7-4065-9354-954da393e043">
        <source>getControlByName(_name : String) : Control;
//--------------------------------------------------
// Created:	02 October 2003 By: cnwgd1
//--------------------------------------------------
vars

begin
	if _name = null then
		return null;
	endif;

	if self.myRightControl &lt;&gt; null and
	   self.myRightControl.name = _name then
		return self.myRightControl;
	endif;
	
	if self.myLeftControl &lt;&gt; null and
	   self.myLeftControl.name = _name then
		return self.myLeftControl;
	endif;
	
	return null;
				
end;</source>
        <Parameter name="_name" type="String"/>
        <ReturnType type="Control"/>
    </JadeMethod>
    <JadeMethod name="getMyRightControl" id="cb323d47-c40d-4c5d-ba4c-b8d429ccf5d5">
        <source>getMyRightControl() : Control;
//--------------------------------------------------
// Created:	02 October 2003 By: cnwgd1
//--------------------------------------------------
vars

begin
	return self.myRightControl;			
end;</source>
        <ReturnType type="Control"/>
    </JadeMethod>
    <JadeMethod name="hideLeftControl" id="eb6fbd9b-5e57-4176-82f0-026e3c0bb38c">
        <updating/>
        <source>hideLeftControl(_doResize : Boolean) updating;
// ---------------------------------------------------------------------------
// Created:     14 November 2000 by cnwrs2
//
// Purpose:     Hides the left-hand control, plus the splitter bar.
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
begin

	if self.myLeftControl &lt;&gt; null then
		self.myLeftControl.visible	:=	false;
	endif;
	
	if self.isSplitHorizontal then
		self.myHorizontalSplitter.visible	:=	false;
	else
		self.myVerticalSplitter.visible		:=	false;
	endif;

	if _doResize then
		self.setLeftToRightRatioAndResize(0);
	else
		self.setLeftToRightRatio(0);
	endif;
end;</source>
        <Parameter name="_doResize" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="hideRightControl" id="fb8b7adf-7f0f-4cd1-b9bd-d94bea49df5b">
        <updating/>
        <source>hideRightControl(_doResize : Boolean) updating;
// ---------------------------------------------------------------------------
// Created:     19 December 2000 by cnwrs2
//
// Purpose:     Hides the right-hand control, plus the splitter bar.
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
begin
	if self.myRightControl &lt;&gt; null then
		self.myRightControl.visible	:=	false;
	endif;
	
	if self.isSplitHorizontal then
		if self.myHorizontalSplitter &lt;&gt; null then
			self.myHorizontalSplitter.visible	:=	false;
		endif;
	else
		if self.myVerticalSplitter &lt;&gt; null then
			self.myVerticalSplitter.visible		:=	false;
		endif;
	endif;

	if _doResize then
		self.setLeftToRightRatioAndResize(100);
	else
		self.setLeftToRightRatio(100);
	endif;

end;</source>
        <Parameter name="_doResize" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="initializeSplitter" id="20d3c837-d2c9-47ed-abc7-168484d0e45c">
        <updating/>
        <source>initializeSplitter() protected, updating;
// Purpose:		Initial setup for the vertical splitter bar.

vars
	theVertical		: CnEcVerticalSplitter;
	theHorizontal	: CnEcHorizontalSplitter;

begin
	if self.isSplitHorizontal then
		theHorizontal	:=	self.myHorizontalSplitter;

		if theHorizontal = null then
			create theHorizontal transient;
		endif;

		theHorizontal.parent	:=	self;
		self.form.addControl(theHorizontal);
   	else
		theVertical	:=	self.myVerticalSplitter;

		if theVertical = null then
			create theVertical transient;
		endif;

		theVertical.parent	:=	self;
		self.form.addControl(theVertical);
 	endif;
 
epilog
	if isSplitHorizontal then
		self.myHorizontalSplitter	:=	theHorizontal;	
	else
		self.myVerticalSplitter		:=	theVertical;
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="leftToRightRatio" id="4f538efe-d738-4919-acfd-b4130e0dcc98">
        <methodInvocation>mapping</methodInvocation>
        <source>leftToRightRatio(set: Boolean; _value: Integer io) mapping, protected;

begin
	if set then
		if _value &lt; 0 or _value &gt; 100 then
			_value	:=	50;
		endif;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="lockBottom" id="f18f5b1d-ccd5-4a26-a667-9995fab13455">
