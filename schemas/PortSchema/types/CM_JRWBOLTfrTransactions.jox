    <JadeMethod name="addBOLTfrTransTi" id="fe27faff-3f20-4aaa-a811-fae457a72325">
        <source>addBOLTfrTransTi( _bolHistStr : String; _ti : CM_TrackedItem; _lastBolTrx : CM_BOLTransferTransaction ):CM_JRWBOLTfrTransTi;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 May 2016	cnwndl1	Initial creation	TFS 1904

*/

vars

	bolTfrTransTi : CM_JRWBOLTfrTransTi;

begin

	create bolTfrTransTi transient;  // deleted when its parent is deleted
	bolTfrTransTi.setValues( self, _bolHistStr, _ti, _lastBolTrx );
	
	return bolTfrTransTi;

epilog

end;</source>
        <Parameter name="_bolHistStr" type="String"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_lastBolTrx" type="CM_BOLTransferTransaction"/>
        <ReturnType type="CM_JRWBOLTfrTransTi"/>
    </JadeMethod>
    <JadeMethod name="copyReportItemsToCollection" id="381512eb-abab-45ed-874c-5651e2f78f6a">
        <updating/>
        <source>copyReportItemsToCollection(_collection: Collection; _collectionItem: Integer) updating;
// called from send to report code to populate for reporting
vars
	obj		: Object;
begin
	if _collection &lt;&gt; null then
		obj := _collection.first.Object;
		if obj.isKindOf(CM_BOLIn) then
			self.myStartingBOLIn := obj.CM_BOLIn;
			// populate the reporting collections now
			self.setMyPopulatingBOL(self.myStartingBOLIn);
		endif;
	endif;
end;
</source>
        <Parameter name="_collection" type="Collection"/>
        <Parameter name="_collectionItem" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="masterBillDischarge" id="e99edca1-18bb-4eee-9360-f242ffcb7baa">
        <source>masterBillDischarge():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 May 2016	cnwndl1	Initial creation	TFS	1904

*/

vars

begin

	if self.myStartingBOLIn &lt;&gt; null then
		return self.myStartingBOLIn.dischargePort;
	endif;
	
	return null;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
