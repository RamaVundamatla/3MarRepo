    <JadeMethod name="getDefaultFaultStatus" id="43ba50e8-1c8d-4cdb-b021-1191ca8754a1">
        <source>getDefaultFaultStatus() : CM_FaultStatus;
/*

Purpose:			


Return Value:		


Date		Who		Reason
14 September 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars
	iter : Iterator;
	faultStatus : CM_FaultStatus;
begin

	iter:=self.allFaultStatuses.createIterator;
	while iter.next(faultStatus) do
		if faultStatus.isDefault then
			return faultStatus;
		endif;
	endwhile;
	return null;
epilog
	delete iter;
end;</source>
        <ReturnType type="CM_FaultStatus"/>
    </JadeMethod>
    <JadeMethod name="getDefaultHandlingSubType" id="e15b03dc-9284-4e16-95ee-fa9553073a82">
        <source>getDefaultHandlingSubType( _type : CM_HandlingType ) : CM_HandlingSubType;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 March 2017	cnwndl1	Initial creation	TFS 3414

*/

vars

	startObject : CM_HandlingSubType;
	handlingSubType : CM_HandlingSubType;
	iter : Iterator;

begin

	startObject := self.allHandlingSubTypes.getAtKeyGeq( _type, null );
	
	if startObject &lt;&gt; null then
		iter := self.allHandlingSubTypes.createIterator;
		
		iter.startAtObject( startObject );
		while iter.next( handlingSubType ) do
			if handlingSubType.getMyHandlingType &lt;&gt; _type then
				break;
			endif;
			if handlingSubType.isDefault then
				return handlingSubType;
			endif;
		endwhile;
		
	endif;
	
	return null;

epilog

	delete iter;

end;</source>
        <Parameter name="_type" type="CM_HandlingType"/>
        <ReturnType type="CM_HandlingSubType"/>
    </JadeMethod>
    <JadeMethod name="getDefaultLocale" id="51012d9a-e327-4a06-b23e-aecca7bfc15f">
        <updating/>
        <source>getDefaultLocale(_createIfNotPresent : Boolean) : CM_Locale updating;
// ---------------------------------------------------------------------------
// Created:     01 April 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpLocale	: CM_Locale;
	
begin

	tmpLocale := self.allLocales[StandardTextLocaleStr];
	if tmpLocale = null and _createIfNotPresent then
		return self.createLocale(StandardTextLocaleStr);
	endif;

	return tmpLocale;
end;</source>
        <Parameter name="_createIfNotPresent" type="Boolean"/>
        <ReturnType type="CM_Locale"/>
    </JadeMethod>
    <JadeMethod name="getDefaultPaymentMethod" id="7f8c9bb1-8edb-49df-ad90-45405e5a5d44">
        <source>getDefaultPaymentMethod() : CM_PaymentMethod;
/*

Purpose:		return a payment method that does not require validation	

Parameters:			TFS 37839

Return Value:		

Date		Who		Reason
21 March 2018	jlgab1	Initial creation

*/

vars
	pm : CM_PaymentMethod;
begin
	if self.allPaymentMethods.isEmpty() then
		return null;
	endif;
	
	foreach pm in self.allPaymentMethods	discreteLock do
		if not pm.isCheque and not pm.isPOS then
			return pm;
		endif;
	endforeach;
	
	return null;
epilog

end;</source>
        <ReturnType type="CM_PaymentMethod"/>
    </JadeMethod>
