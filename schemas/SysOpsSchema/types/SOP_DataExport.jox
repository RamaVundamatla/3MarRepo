    <JadeMethod name="tblExtractClass_dblClick" id="df148bff-9065-4377-99f8-c14ca8137efd">
        <controlMethod name="CM_DataTable::dblClick"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblExtractClass_dblClick(_table: CM_DataTable input) updating;
//--------------------------------------------------
// Created:	Jan 2006 cnwrs1
//--------------------------------------------------
vars
	tmpRow,	tmpCol: Integer;
begin


	tmpRow := _table.getRowFromY(_table.origYPos);
	tmpCol := _table.column;
	if tmpRow = _table.fixedRows then
		_table.resortTableByColumn(tmpCol);
		_table.colourRows(self.colorRow1, self.colorRow2);		
	endif;
	
	
	// TFS 2734 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		return;
	endif;

	if _table.row &gt; _table.fixedRows and 
		self.myCurrentObject &lt;&gt; null and 
		self.myCurrentObject.CM_DataDumpExtractDef.extractFormat = CM_DataDumpExtractDef.FmtSQLNative then
		self.doEditJadeSQLMapping();
	endif;
end;</source>
        <Parameter name="_table" type="CM_DataTable" usage="input"/>
    </JadeMethod>
