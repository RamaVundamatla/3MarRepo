    <JadeMethod name="getAuditTextForProperty" id="7493a711-46cd-46fa-9dac-187a5e58bdf7">
        <source>getAuditTextForProperty(_property: Property): String;
/*

Date		Who		Reason
12 May 2014	cnwer1	Initial creation PAR

*/

vars

begin
	
	if _property.name = CM_EventRequest::type.name then
		return self.formatAuditText(CM_EventRequest::type.name, self.typeString);
	endif;
	return inheritMethod(_property);

epilog

end;</source>
        <Parameter name="_property" type="Property"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="11c53ab0-b564-484c-bcef-714e098c8269">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
//--------------------------------------------------
// Created:	05 May 2005 By: cnwgd1
//--------------------------------------------------
vars

begin

	if _attrName = ETRow_EnteredDT then
		return self.systemToLocalTime(self.createdTime).shortCurrentLocaleFormat();	// 18/4/16 cnwmp6 TFS 488 - Multi timezone support
	elseif _attrName = ETRow_EmailAddresses then
		return self.getEmailAddresses(null);				
	elseif _attrName = ETRow_Event then
		return null;		
	elseif _attrName = ETRow_MatchFailedReason then
		return self.actionFailedReason;
	elseif _attrName = ETRow_MyOrganisation then
		if self.myOrganisation &lt;&gt; null then
			return self.myOrganisation.name;
		else
			return null;
		endif;		
	elseif _attrName = ETRow_IsNotify then
		return null;		
	elseif _attrName = ETRow_Notify then
		return null;
	elseif _attrName = ETRow_Status then
		return self.statusString();
	elseif _attrName = ETRow_StatusDT then
		return self.systemToLocalTime(self.statusDT).shortCurrentLocaleFormat();	// 18/4/16 cnwmp6 TFS 488 - Multi timezone support
	elseif _attrName = ETRow_Stops then
		return null;				
	elseif _attrName = ETRow_UserCode then
		if self.myUser &lt;&gt; null then	
			return self.myUser.code;
		else
			return null;
		endif;
	elseif _attrName = ETRow_CreatedFromEDI then
		return self.isEDI.getYesNo();
	else
		return inheritMethod(_attrName, _short);
	endif;

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getEmailAddresses" id="e3e48b2b-b463-4a7f-b703-4919368c476e">
        <source>getEmailAddresses(_exclude : String) : String;
//--------------------------------------------------
// Created:	20 May 2005 By: cnwgd1
//--------------------------------------------------
vars
	rtnStr,
	str : String;
begin

	foreach str in self.allEmailAddresses do
		if str = _exclude then
			continue;
		endif;
		if (not str.endsWith(';')) then
			str := str &amp; ';';
		endif;
		if rtnStr = null then
			rtnStr := str;
		else
			rtnStr := rtnStr &amp; ' ' &amp; str;		
		endif;
	endforeach;
	return rtnStr;
end;</source>
        <Parameter name="_exclude" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
