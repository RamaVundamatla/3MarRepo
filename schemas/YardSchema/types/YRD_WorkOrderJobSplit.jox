    <JadeMethod name="create" id="ef7deb0a-ecad-4c09-9b7a-07ecbce2fa9e">
        <updating/>
        <source>create() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 Jul 2023	navhl20	ChangeRequest 58333: EUP | Delivery Dispatch Screen - Split Jobs

*/

vars

begin
	self.permissionView		:= PmAdmWorkOrderJobSplitView;
	self.permissionMaint	:= PmAdmWorkOrderJobSplitMaint;
	self.helpFileName 		:= HelpFile_Yard;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doOK" id="b3e35c5c-719a-47e0-bcd8-14e0af9e25ed">
        <updating/>
        <source>doOK() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 Jul 2023	navhl20	ChangeRequest 58333: EUP | Delivery Dispatch Screen - Split Jobs
24 Jul 2023 navhl20 Defect 59274: MTN - Split Jobs is not working correctly
*/

vars
	jobSheet 	: CM_WorkPointJobSheet;
	wleSet		: CM_WLESet;
	jobId		: String;
	result,
	quantity,
	count		: Integer;
	wle,
	myWle		: CM_WorkListEntry;
	response	: Boolean;
begin
	create wleSet transient;
	self.tblWLE.allSelectedObjects.copyNoDups(wleSet);
	
	//self.validateJobSplit();												//24.7.2023 navhl20 #59274
	
	if self.cmbJobSheet.listObject &lt;&gt; null then
		jobSheet 	:= self.cmbJobSheet.listObject.CM_WorkPointJobSheet;
	else
		jobSheet 	:= self.myJob.myJobSheetForWorkPoint;
	endif;
	jobId		:= self.txtJobNumber.text;
	
	foreach wle in self.tblWLE.allSelectedObjects as CM_WorkListEntry do	//22.08.2024 navhl20 #65424
		if wle.isKindOf(CM_WOPackChildWLE) and wle.quantity &gt; 1 and wle.job.status = JOB_UNACTIONED then
			count := count + 1;
			myWle := wle;
		endif;
	endforeach;
	
	if count = 1 then
		quantity := self.showSplitQuantForm(myWle);
		if quantity = -1 then
			return;
		endif;
	endif;
	
	while true do
		if wleSet.size &gt; 0 then
			app.myTrxUA.trxUpdateJobSplitWithWle(self.myJob,jobId,jobSheet,wleSet,self.myTerminal, quantity, app.myPassport);
		endif;
		
		if app.myPassport.trxCompletedOK then
			self.unloadForm();
			break;
		else
			result := app.showErrorWarningDialog(self.caption, app.myPassport, ErrWarnMode_Add + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		return;
	endwhile;
epilog
	delete wleSet;
end;</source>
    </JadeMethod>
    <JadeMethod name="loadCmbJobSheet" id="a96db148-3b45-4057-aa3b-0237cf71ffb7">
        <source>loadCmbJobSheet();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 Jul 2023 navhl20 ChangeRequest 58333: EUP | Delivery Dispatch Screen - Split Jobs
23 Sep 2024 navhl20	Bug 66211: EUP - Job Sheets should be filtered on Shift and Split Job form based on criteria of WO Operation
*/

vars
	jobSheet 	 : CM_WorkPointJobSheet;
	//term		 : CM_Terminal;
	cmb			 : CMUI_ComboBox;
begin
	//term := self.myTerminal;											//23.09.2024 navhl20 #66211
	cmb	:= self.cmbJobSheet;
	cmb.clear();
	//foreach jobSheet in  term.allJobSheetsForWorkPoints do			//23.09.2024 navhl20 #66211
	foreach jobSheet in self.allJobSheets as CM_WorkPointJobSheet do	//23.09.2024 navhl20 #66211
		cmb.addItemObject(jobSheet.externalName, jobSheet);
	endforeach;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="loadTblWle" id="0d4bbd6b-1ba5-4c3b-963d-e1c124fe1a4b">
        <source>loadTblWle();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 Jul 2023	navhl20	ChangeRequest 58333: EUP | Delivery Dispatch Screen - Split Jobs

*/

vars
	wle 		: CM_WorkListEntry;
	idx			: Integer;
	theDataLine : String;
	tbl			: CM_DataTable;
	entTableDef	: EntTableDef;
begin
	tbl := self.tblWLE;
	tbl.allSelectedObjects.clear();
	
	tbl.userInputEnabled:= false;
	tbl.selectMode 		:= CM_EntryTable.SelectMode_FixedRow;
	tbl.selectionType  	:= CM_EntryTable.SelectionType_Row;
	tbl.rows 			:= tbl.fixedRows;
	tbl.multiSelect 	:= CM_BaseTable.MultiSelect_Simple;
	
	entTableDef 		:= app.myController.getEntTableDef(ETDef_WoJobWle);
	tbl.setTblDataEntRowsFromDef(entTableDef);
	
	tbl.readOnly 	  	:= false;	
	tbl.fixedColumns 	:= 0;
	tbl.fixedRows 	  	:= 1;
	tbl.rows 		 	:= 1;
	
	foreach wle in  self.allWles do			
		if idx &gt;= JadeTableRowLimit then
			app.msgBox('Maximum number of entries in table exceeded. Only the first ' &amp; 
						JadeTableRowLimit.String &amp; ' will be shown', 'Error', MsgBox_OK_Only);
			break;
		endif;
		if wle.status = WLE_COMPLETED then
			continue;
		endif;
		theDataLine := wle.getAttributeStringForDefArray(tbl.allTblDataEntRows);
		tbl.accessRow(tbl.addItem(theDataLine)).itemObject := wle;
	endforeach;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setJobSheets" id="9a68aed3-cf3b-4c4a-9b2c-c36707d40349">
        <updating/>
        <source>setJobSheets(_jobSheetSet : CM_JobSheetSet)updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 Sep 2024 navhl20	Bug 66211: EUP - Job Sheets should be filtered on Shift and Split Job form based on criteria of WO Operation

*/

vars

begin
	self.allJobSheets.clear;
	_jobSheetSet.tryCopy(self.allJobSheets);
epilog

end;</source>
        <Parameter name="_jobSheetSet" type="CM_JobSheetSet"/>
    </JadeMethod>
    <JadeMethod name="setWorkListEntries" id="b6341d3b-60b7-4989-b3d1-41073cf4f980">
        <updating/>
        <source>setWorkListEntries(_job : CM_Job)updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 Jul 2023	navhl20	ChangeRequest 58333: EUP | Delivery Dispatch Screen - Split Jobs
06 Aug 2024 navhl20	Bug 65424: EUP | 53729 - WO Jobs - Split Pack or Unpack job issues
*/

vars
	wod : CM_WodPack;
	job	: CM_WOPackJob;
begin
	self.allWles.clear();
	if _job &lt;&gt; null then
		self.myJob := _job;
		if _job.isKindOf(CM_WOPackJob) then							//06.08.2024 navhl20 #65424
			wod := _job.myWODtl.CM_WodPack;
			foreach job in wod.allJobs as CM_WOPackJob do
				if job.id = _job.id then
					job.workListEntries.copy(self.allWles);
				endif;
			endforeach;
		else
			_job.workListEntries.copy(self.allWles);
		endif;
	endif;
epilog

end;</source>
        <Parameter name="_job" type="CM_Job"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="3aeb787c-3b17-4519-8c78-5e0c45ff9b9d">
        <updating/>
        <source>setupForm() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 Jul 2023	navhl20	ChangeRequest 58333: EUP | Delivery Dispatch Screen - Split Jobs

*/

vars

begin
	inheritMethod();
	self.btnOk.caption := app.getErrorString(Save);
	self.btnCancel.caption := app.getErrorString(Close);
	self.loadTblWle();
	self.loadCmbJobSheet();
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="showSplitQuantForm" id="08da198c-eafc-426c-a80b-aa08aa31b1b1">
        <source>showSplitQuantForm(_wle : CM_WorkListEntry):Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 Aug 2024 navhl20	Bug 65424: EUP | 53729 - WO Jobs - Split Pack or Unpack job issues
*/

vars
	form	: YRD_WOSplitAmountForm;
	quant,
	result	: Integer;
begin
	
	if _wle = null then
		return null;
	endif;
	
	form := app.loadForm(YRD_WOSplitAmountForm, YRD_Assistant, false, false, false, self.myTerminal, self.myMasterMenuAction).YRD_WOSplitAmountForm;
	
	if form = null then
		return null;
	endif;
	
	form.setMyWle(_wle);
	
	result := form.showModal();
	
	if result = IDCANCEL then
		return IDCANCEL;
	endif;
	
	return form.getQuantity();
epilog
	delete form;
end;</source>
        <Parameter name="_wle" type="CM_WorkListEntry"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="7421e54d-2ea7-48d9-8110-40ca2443f89f">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 21 July 2023 09:01:56.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0026229, locale);
	lblJobNumber.translateCaption(Xlat_0026230, locale);
	lblJobSheet.translateCaption(Xlat_0026231, locale);
end;</source>
    </JadeMethod>
    <JadeMethod name="validateJobSplit" id="377ebe03-e32f-4da0-a428-dab149d950ef">
        <source>validateJobSplit();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 Jul 2023	navhl20	Defect 59274: MTN - Split Jobs is not working correctly
28 Nov 2023 navhl20 ChangeRequest 61508: EUP | Ship Operations in DD - [54176.010] - [Release] Ship Job List 
16 Aug 2024 navhl20	Bug 65424: EUP | 53729 - WO Jobs - Split Pack or Unpack job issues
*/

vars
	wle		: CM_WorkListEntry;
	countP,
 	countC	: Integer;
begin
	if not self.myJob.isKindOf(CM_WOPackJob) then								//12.08.2024 navhl20 #65424
		if self.tblWLE.allSelectedObjects.size = 0 then
			app.raiseCMException(Atlea_work_list_entry_shoul_se, null, null);
		endif;
	else
		if self.tblWLE.allSelectedObjects.size = 1 then
			app.raiseCMException(Pleas_selec_both_paren_child_w, null, null);
		elseif self.tblWLE.allSelectedObjects.size &gt; 1 then
			countP := 0;
			countC := 0;
			foreach wle in self.tblWLE.allSelectedObjects as CM_WorkListEntry do
				if wle.isKindOf(CM_WOPackParentWLE) then
					countP := countP+1;
				endif;
				if wle.isKindOf(CM_WOPackChildWLE) then
					countC := countC+1;
				endif;
			endforeach;
			if countP = 0 or countC = 0 then
				app.raiseCMException(Pleas_selec_both_paren_child_w, null, null);
			endif;
		endif;
	endif;
	
	if self.txtJobNumber.text = null then										//28.11.2023 navhl20 #61508
		app.raiseCMException(Input_required_JobNumber,null,null);
	endif;
	
	if self.cmbJobSheet.listObject = null then									//28.11.2023 navhl20 #61508
		app.raiseCMException(Input_required_JobSheet,null,null);
	endif;
epilog

end;</source>
    </JadeMethod>
</GUIClass>
