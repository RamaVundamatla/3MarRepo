    <JadeMethod name="getPxySelf" id="c79f8c9a-b4cb-4fe6-879c-8e36430b2c51">
        <source>getPxySelf() : SelfType;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28 May 2009	cnwjk3	Initial creation

*/

vars

begin

	if self.isTransient then
		app.raiseUnexpectedProgramError(class.name, method.name, 'persistent method called for transient object');
		return null;
	endif;
	
	return app.myProxyManager.getProxyObject(self).CMGTE_Entity;

epilog

end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="getSourceTAText" id="8a0b7c01-6ea1-463c-8658-5d73274d6558">
        <source>getSourceTAText() : String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 June 2010	cnwrd1	Initial creation

*/

vars
	ta 		: CM_TerminalArea;
	aGO		: CM_GridObject;
	sep 	: String;
	result 	: String;
	count	: Integer;
begin	

	count := 1;
	foreach ta in self.allSourceTAs do
		if self.allSourceTAGridObjs &lt;&gt; null and self.allSourceTAGridObjs.size &gt;= count then
			aGO := self.allSourceTAGridObjs[count];
		else
			aGO := null;
		endif;
			
		if aGO = null then
			result := result &amp; sep &amp; ta.id;
		else
			result := result &amp; sep &amp; ta.id &amp; '(' &amp; aGO.label &amp; ')';
		endif;
		
		sep := ', ';
		count := count +1;
	endforeach;
	
	/*if self.isBestPick and
	   result &lt;&gt; "" then
		result := result &amp; " (" &amp; app.getErrorString(Best_pick) &amp; ")";
	endif;*/
	
	return result;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getStringDictKey" id="42a306cd-bcb0-48f8-99b9-73acc6ef1247">
        <source>getStringDictKey():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 November 2016	cnwndl1	Initial creation	TFS 2999 - id isn't enough when allowing
							the same prenote in a different container on the same truck!!!

*/

vars

begin

	if self.myParent = null then
		return self.id;
	else
		return self.id &amp; "/" &amp; self.myParent.getStringDictKey();
	endif;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
