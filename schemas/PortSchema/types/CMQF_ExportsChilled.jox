<Class name="CMQF_ExportsChilled" id="2419a6b3-0f48-4c3b-8530-b94ec953446b">
    <superclass name="CMQF_Container"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="query"/>
    <JadeMethod name="filterObjects" id="9eac3311-da78-44d0-b284-26a7ff8b6a21">
        <updating/>
        <source>filterObjects(_collection  : Collection input; _passport : CM_Passport) updating;
// ---------------------------------------------------------------------------
// Created:		08 January 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------

vars
	ti 				: CM_TrackedItem;
	breakOut		: Boolean;
begin
	//need a voyage
	if self.getMyVoyage &lt;&gt; null then
	
		foreach ti in self.getMyVoyage.allOnshipTIsByIdCargoType discreteLock do
			if self.checkStatusIncludesObject(ti, _passport, breakOut) then
//			if self.includesObject(ti, _passport, breakOut) then
				if not _collection.includes(ti) then
					_collection.add(ti);
					//self.sumWeight := self.sumWeight + ti.weight;					//-cnwml2 MSL CCMS 1017
					self.sumWeight := self.sumWeight + ti.totalWeight;				//+cnwml2 MSL CCMS 1017
				endif;
			endif;
//			if breakOut then
//				return;
//			endif;
	
		endforeach;
	endif;
	
	
	
	
	
end;</source>
        <Parameter name="_collection" type="Collection" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="includesObject" id="6b9cfcaf-38fa-4714-97b5-ee84daad20f9">
        <updating/>
        <source>includesObject(_ti: CM_TrackedItem; _passport : CM_Passport; _breakOut : Boolean output): Boolean updating, protected;
// ---------------------------------------------------------------------------
// Created:		08 January 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------
// 15/07/2010	cnwdap1		PAR #25021 review use of isImport/isExport for tranships
vars

begin
	if CM_Container.hasInstance(_ti) and
	   (_ti.isExport or _ti.isTranshipOutbound) and		// PAR #25021
	   _ti.CM_Container.isChilled and
	   inheritMethod(_ti, _passport, _breakOut) then
		return true;
	endif;

	return false;

end;</source>
        <access>protected</access>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <Parameter name="_breakOut" type="Boolean" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
