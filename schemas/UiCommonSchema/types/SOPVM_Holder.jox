<Class name="SOPVM_Holder" id="f5792caa-8b00-4e84-9c7e-54a333b6920d">
    <superclass name="SOP_ViewModelObject"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="cmtrans"/>
    <ExplicitInverseRef name="myHolderParent" id="f90b6f80-8645-4e50-b34a-610e390c024a">
        <kind>child</kind>
        <updateMode>manual</updateMode>
        <embedded/>
        <type name="CMUI_ViewModelObject"/>
        <Inverse name="SOPVM_LogSpecs::allHolders"/>
    </ExplicitInverseRef>
    <JadeMethod name="create" id="0dd3e4eb-9caf-425e-a6b5-4dd6438fef9e">
        <updating/>
        <source>create() updating;
// -----------------------------------------------------------------------------
// Created:		18 March 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
begin
	self.canAddChild 	:= true;
	self.canAddPeer 	:= false;
	self.canEdit 		:= false;
	self.canDelete 		:= false;

end;</source>
    </JadeMethod>
    <JadeMethod name="initializeMe" id="94aa67e1-4f79-4028-bccd-c02c8005b4b4">
        <updating/>
        <source>initializeMe(_object: CM_Object; _index: Integer; _parent: SOP_ViewModelObject) updating;
// -----------------------------------------------------------------------------
// Created:		30 April 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
begin
	inheritMethod(_object, _index, _parent);
	self.myHolderParent := _parent;
end;</source>
        <Parameter name="_object" type="CM_Object"/>
        <Parameter name="_index" type="Integer"/>
        <Parameter name="_parent" type="SOP_ViewModelObject"/>
    </JadeMethod>
    <JadeMethod name="showThumbnail" id="6a4484b1-1b78-4a45-9376-ae82155587d3">
        <updating/>
        <source>showThumbnail(_obj: CM_Object) updating;
// -----------------------------------------------------------------------------
// Created:		18 March 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
begin
	self.myForm.sptThumbEdit.enabled := false;
	self.myForm.tblInput1.clearValues;
end;</source>
        <Parameter name="_obj" type="CM_Object"/>
    </JadeMethod>
</Class>
