    <JadeMethod name="isWebMessage" id="d3b5f4e5-1422-436c-881d-915b4ba2b0fd">
        <source>isWebMessage() :Boolean;
/*

Purpose:			Used when sending EDI Web Service Monitor notifications to determine whether the file is from the web or not

Parameters:			

Return Value:		

Date		Who		Reason
19/10/2020	jlgmd1	Initial creation TFS 49971

*/

vars

begin
	if self.mode = null then
		return false;
	endif;
	
	// ... There are only 2 kinds of Modes at the moment, Synchronous and Asynchronous
	// So this check is a bit redundant
	if not self.mode.isOneOf(self.EDI_Mode_Asynchronous, self.EDI_Mode_Synchronous) then
		return false;
	endif;
	
	return true;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
