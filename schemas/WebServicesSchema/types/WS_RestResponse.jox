<Class name="WS_RestResponse" id="c92dd346-a760-4530-b15e-ce89eaa2a383">
    <superclass name="WS_InterfaceObject"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>Outgoing REST Responses (to Incoming requests)</text>
    <ImplicitInverseRef name="allErrors" id="1120e51a-f7fe-491d-8f82-f6f7c253b6b8">
        <memberTypeInverse/>
        <type name="WS_ErrorMessageArray"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="allInfo" id="c4ac6911-dda3-4fba-b2c4-5ae50fe21582">
        <memberTypeInverse/>
        <type name="WS_InfoMessageArray"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="allWarnings" id="8c7b0d72-c491-4a21-9040-c1885f834f23">
        <memberTypeInverse/>
        <type name="WS_ErrorMessageArray"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <JadeMethod name="addInfo" id="04733fb1-a2ed-4fda-ae39-25f9253b4bbd">
        <updating/>
        <source>addInfo(text : String) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 August 2021	jlier1	Initial creation 51683

*/

vars
	infoMessage			: WS_InfoMessage;
begin
	if text.trimBlanks = null then
		return;
	endif;
	create infoMessage transient;		
	infoMessage.text :=	text.trimBlanks;
	self.allInfo.add(infoMessage);

epilog

end;</source>
        <Parameter name="text" type="String"/>
    </JadeMethod>
    <JadeMethod name="delete" id="a1468ec4-a0b6-489f-9c1e-18089c6fa93d">
        <updating/>
        <source>delete() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
15 Jul 2008	cnwkpd1	PAR #17554 - Development of new RIA Web Service application

*/

vars

begin
	self.allWarnings.purge();
	self.allErrors.purge();
	self.allInfo.purge(); //06/07/2009 cnwdz2 par 20233
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="exportAsXMLInverseRef" id="c661ea19-f9d2-4872-a445-30383f74306e">
        <source>exportAsXMLInverseRef(_property: Reference): Integer protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 December 2021	jlier1	Initial creation

*/

vars

begin
	if _property = WS_Response::allErrors or _property = WS_Response::allWarnings
		or _property = WS_Response::allInfo then
		return ExportAsParent;
	endif;

	return NoExport;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_property" type="Reference"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getResponseCode" id="bb79a624-aceb-4660-bca3-f3ba1204608f">
        <source>getResponseCode(): Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
22 May 2024		navmd1	Initial creation TFS 64234

*/

vars

begin
	if not self.allErrors.isEmpty then
		return HttpResponseClientError;
	endif;
	
	return HttpResponseOK;
epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setErrorsFromPassport" id="9f6daeda-43c0-4a77-b6b6-1624680eda1e">
        <updating/>
        <source>setErrorsFromPassport() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 Jul 2008	cnwkpd1	PAR #17554 - Development of new RIA Web Service application
08 Sep 2008 cnwkao1 updated to cater for warnings (?)
27 Apr 2020 cnwma1  Bug 48757: SNO - Power disconnection
*/

vars
	passport		: CM_Passport;
	error			: CM_Error;
	errorProxy		: WS_ErrorMessage;
	
begin
	passport := app.myPassport;
	if passport = null then
		return;
	endif;
	
	foreach error in passport.allErrors do
		create errorProxy transient;
		errorProxy.setProxyFromObject(error);
		self.allErrors.add(errorProxy);
	endforeach;
	
	if not passport.warningsIgnored then
		foreach error in passport.allWarnings do
			create errorProxy transient;
			errorProxy.setProxyFromObject(error);
			self.allWarnings.add(errorProxy); //KO - do we want to distinguish between errors and warnings? Currently I'm setting CM_Passport::warningsIgnored to true for some updates
		endforeach;
	endif;
	
	// KPD - added this to ensure errors are not copied twice for nested webService
	// method calls
	passport.clearErrorsWarnings();
	
	
epilog

end;</source>
    </JadeMethod>
</Class>
