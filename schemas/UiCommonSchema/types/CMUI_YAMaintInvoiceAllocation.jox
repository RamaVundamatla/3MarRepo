    <JadeMethod name="resizeForVoyage" id="9c96992b-ff51-496c-a182-bcf0129fb21f">
        <updating/>
        <source>resizeForVoyage() updating;
/*
Date				Who		Reason
04 December 2009	cnwas3	Initial creation
13 Feb 2025			navlw1 	JIRA-12608: MTN - Invoice Cargo Allocations Review (Mapping and Extract/Load)

*/
vars

	maxIndex : Integer;
	criteriaFrame		: CMUI_YACriteriaCntl;
	index				: Integer;
	topOfLastControl 	: Real;
	topOfNextControl 	: Real;
begin


	self.minimumWidth := 420; // PAR 35325
	self.minimumHeight := 450;

	self.lblDescription.top := self.shtCriteria.clientHeight - 60;
	self.lblDescription.left := 10;	// navlw1 #JIRA-12608 13/02/2025
	self.txtDescription.left := 147; // navlw1 #JIRA-12608 13/02/2025
	self.lblDescription.parentAspect := Label.ParentAspect_AnchorBottom;
	self.txtDescription.parentAspect := TextBox.ParentAspect_AnchorBottom;
	self.txtDescription.parentBottomOffset := 30;  // navlw1 #JIRA-12608 13/02/2025
	self.lblDescription.parentBottomOffset := 35; // navlw1 #JIRA-12608 13/02/2025
	
	self.lblYAColour.top := self.shtCriteria.clientHeight - 30;
	self.clrYAColour.top := self.lblYAColour.top;
	self.lblYAColour.left := 20;
	self.clrYAColour.left := 157;
	self.clrYAColour.width := 40;
	
	self.picCriteria.height := self.lblDescription.top - 10; //jlier1 TFS 63834 14/5/24
	self.picCriteria.top := 10;
//	self.picCriteria.backColor := Red;
//	self.picCriteria.transparent := false;
	
	self.lblYAColour.parentAspect := Label.ParentAspect_AnchorBottom;
	self.clrYAColour.parentAspect := TextBox.ParentAspect_AnchorBottom;
	self.picCriteria.parentAspect := Picture.ParentAspect_StretchBoth;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="saveData" id="4cf2c6d5-fdaa-4bec-8e30-b67a1ee28678">
        <updating/>
        <source>saveData(_saveAs: Boolean): Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
//May 12 2023 navmv20 Bug Bug 57561: STWO - Code :79963. A Yard Allocation with this code () already exists- Issue 1 of 2

*/

vars
	saveOk: Boolean;

begin

	if self.myTranMap &lt;&gt; null then
		saveOk := self.saveDataCargoAllocation(_saveAs);
	elseif self.myTranMapInvent &lt;&gt; null then
		saveOk := self.saveDataInventAllocation(_saveAs);
	endif;

	if not self.isNext and not _saveAs and self.allErrorWarnings.isEmpty then
		self.unloadForm();
	endif;
	return saveOk;
epilog
	
end;</source>
        <Parameter name="_saveAs" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="saveDataCargoAllocation" id="7715b5b4-dac1-4227-8bf2-3795126d7bd0">
        <updating/>
        <source>saveDataCargoAllocation(_saveAs: Boolean): Boolean updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
15 December 2009	cnwas3	Initial creation
14 Jun 2017	cnwma1 TFS #4498 JMT - Cargo Allocation Fix Up Export Script
 // ### TFS 51219 03JUN2021 NAVAB1 - refactored
//May 12 2023 navmv20 Bug 57561: STWO - Code :79963. A Yard Allocation with this code () already exists- Issue 1 of 2
*/
vars

	proxyYAObj : CM_InvoiceCargoAllocation;
	cmif_object : CMIF_Object;
	cmif_criteria : CMIF_YACriteriaPriority;
	pxyCriteria : CM_YACriteria;
	allTransientCriteriaObj	: CMIF_Array;
	result : Integer;
	realAlloc : CM_InvoiceCargoAllocation;
	yas : ObjectArray;
	
begin

	if self.myTranMap = null then
		return false;
	endif;
	
	if self.updateMode then
	//12/05/2023 navmv20 Bug 57561 - start
		//realAlloc := self.myYardAllocation.CM_InvoiceCargoAllocation;
		//if self.myYardAllocation = null then
		//return false;
		realAlloc := self.myInvAlloc.CM_InvoiceCargoAllocation;
		if self.myInvAlloc = null then 
			return false;
		endif;
		
		delete self.myProxyYA;
		create yas transient;
		yas.add( realAlloc );
		self.setYardAllocation( yas );
	//12/05/2023 navmv20 Bug 57561 - end
	endif;
	
	//27 Oct 2017	NDL	TFS 7477
	if _saveAs and self.txtDescription.text = self.myProxyYA.code then
		self.txtDescription.text := null;
	endif;
	
	//09 Jan 2016	NDL	TFS 3174
	if self.txtDescription.text.trimBlanks = null then
		self.formatDescription();
	endif;
	
	proxyYAObj := self.myProxyYA.CM_InvoiceCargoAllocation;

	if self.updateMode then
		proxyYAObj.setServiceBroker(realAlloc.myServiceBroker);
	endif;
	
	create allTransientCriteriaObj transient;
	if _saveAs then	//27 Oct 2017	NDL	TFS 7477
		self.getSaveAsCriteria( allTransientCriteriaObj );
	else
		self.getCriteriaAllCMIF( allTransientCriteriaObj );
	endif;
	
	proxyYAObj.setProxy(self.txtDescription.text,self.txtDescription.text,
								null,
								YAFillOption_InOrder,
								YAFillOption_InOrder,
								YAExpiryType_Never,
								null,
								null,
								
								null, 
								YAOverlap_Never,
								YANoLocation_Continue,
								null,
								0, 
								false,
								false,
								null,
								null,
								true,
								self.myTerminal);

	proxyYAObj.initialiseProxy(self.myTranMap);	

	while true do
		if _saveAs then
			self.myYardAllocation := null;
			realAlloc := null;
			app.myTrxUA.trxUpdateInvoiceCargoAlloc(false,false,false,false,allTransientCriteriaObj, self.myTranMap, proxyYAObj,realAlloc);
			if realAlloc &lt;&gt; null then
				delete self.myProxyYA;
				create yas transient;
				yas.add( realAlloc );
				self.setYardAllocation( yas );
			endif;
		else
			app.myTrxUA.trxUpdateInvoiceCargoAlloc(self.updateMode,false,false,false,allTransientCriteriaObj, self.myTranMap, proxyYAObj,realAlloc);//19/06/2017 cnwma1 TFS #4498
		endif;
		if app.myPassport.trxCompletedOK then
			self.clearErrorWarnings();
//			self.updateMode := false;
//	 TFS 6536		self.unloadForm();
			break;
		else
			result := app.showErrorWarningDialog(app.getErrorString(Invoice_cargo_allocation), app.myPassport, ErrWarnMode_Add + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;

			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
		endif;
		
		break;
	endwhile;	
	
	return true and not _saveAs;	//27 Oct 2017	NDL	TFS 7477
	
epilog

	if allTransientCriteriaObj &lt;&gt; null then
		allTransientCriteriaObj.purge;
	endif;
	delete allTransientCriteriaObj;	
	delete yas;

end;</source>
        <Parameter name="_saveAs" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="saveDataInventAllocation" id="8a638da1-51ef-4a70-bee2-81b7de3573d7">
        <updating/>
        <source>saveDataInventAllocation(_saveAs: Boolean): Boolean updating;
/*
Purpose:			

Date		Who		Reason
26MAY2021	NAVAB1	TFS 51219
//May 12 2023 navmv20 Bug 57561: STWO - Code :79963. A Yard Allocation with this code () already exists- Issue 1 of 2
*/

vars

	proxyYAObj : CM_InvoiceInventoryAllocation;
	cmif_object : CMIF_Object;
	cmif_criteria : CMIF_YACriteriaPriority;
	pxyCriteria : CM_YACriteria;
	allTransientCriteriaObj	: CMIF_Array;
	result : Integer;
	realAlloc : CM_InvoiceInventoryAllocation;
	yas : ObjectArray;
	
begin

	if self.myTranMapInvent = null then
		return false;
	endif;
	
	if self.updateMode then
		//12/05/2023 navmv20 Bug 57561-start
		//realAlloc := self.myYardAllocation.CM_InvoiceInventoryAllocation;
		//if self.myYardAllocation = null then
			//return false;
		realAlloc := self.myInvAlloc.CM_InvoiceInventoryAllocation;
		if self.myInvAlloc = null then 
			return false;
		endif;
		
		delete self.myProxyYA;
		create yas transient;
		yas.add( realAlloc );
		self.setYardAllocation( yas );
	//12/05/2023 navmv20 Bug 57561 - end
	endif;
	
	if _saveAs and self.txtDescription.text = self.myProxyYA.code then
		self.txtDescription.text := null;
	endif;
	
	if self.txtDescription.text.trimBlanks = null then
		self.formatDescription();
	endif;
	
	proxyYAObj := self.myProxyYA.CM_InvoiceInventoryAllocation;

	if self.updateMode then
		proxyYAObj.setServiceBroker(realAlloc.myServiceBroker);
	endif;
	
	create allTransientCriteriaObj transient;
	if _saveAs then
		self.getSaveAsCriteria( allTransientCriteriaObj );
	else
		self.getCriteriaAllCMIF( allTransientCriteriaObj );
	endif;
	
	proxyYAObj.setProxy(self.txtDescription.text,self.txtDescription.text,
								null,
								YAFillOption_InOrder,
								YAFillOption_InOrder,
								YAExpiryType_Never,
								null,
								null,
								
								null, 
								YAOverlap_Never,
								YANoLocation_Continue,
								null,
								0, 
								false,
								false,
								null,
								null,
								true,
								self.myTerminal);

	proxyYAObj.initialiseProxy(self.myTranMapInvent);	

	while true do
		if _saveAs then
			self.myYardAllocation := null;
			realAlloc := null;
			app.myTrxUA.trxUpdateInvoiceInventAlloc(false,false,false,false,allTransientCriteriaObj, self.myTranMapInvent, proxyYAObj,realAlloc);
			if realAlloc &lt;&gt; null then
				delete self.myProxyYA;
				create yas transient;
				yas.add( realAlloc );
				self.setYardAllocation( yas );
			endif;
		else
			app.myTrxUA.trxUpdateInvoiceInventAlloc(self.updateMode,false,false,false,allTransientCriteriaObj, self.myTranMapInvent, proxyYAObj,realAlloc);
		endif;
		if app.myPassport.trxCompletedOK then
			self.clearErrorWarnings();
			break;
		else
			result := app.showErrorWarningDialog(app.getErrorString(Invoice_cargo_allocation), app.myPassport, ErrWarnMode_Add + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;

			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
		endif;
		
		break;
	endwhile;	
	
	return true and not _saveAs;
	
epilog

	if allTransientCriteriaObj &lt;&gt; null then
		allTransientCriteriaObj.purge;
	endif;
	delete allTransientCriteriaObj;	
	delete yas;

end;</source>
        <Parameter name="_saveAs" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setCriteriaResizeScrollBar" id="e8320fd6-7b21-42fb-8f02-3cc918fe1e3b">
        <updating/>
        <source>setCriteriaResizeScrollBar() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28/11/2023	navkc1 Bug 60782: FR | 54089 EUP -Invoice Contracts - Criteria screen width issues

*/

vars
	max			: Integer;
	numOfCrit	: Integer;
	config		: CM_InvoiceAllocationConfig;
	criteriaFrame	: CMUI_YACriteriaCntl;
begin
	
	if self.myTranMap &lt;&gt; null then
		config := self.myTranMap.myInvoiceAllocationConfig;		
	elseif self.myTranMapInvent &lt;&gt; null then
		config := self.myTranMapInvent.myInvoiceAllocationConfig;		
	endif;
	
	if config &lt;&gt; null then
		numOfCrit := config.allOpCriteria.size();
	endif;
	
	//jlier1 TFS 63834 13/5/24 - noticed scroll bars not working correctly
	criteriaFrame 	:= self.frmCriteria.getControl(numOfCrit).CMUI_YACriteriaCntl;
	if criteriaFrame &lt;&gt; null then
		max:= ((criteriaFrame.top - picCriteria.height).Integer + criteriaFrame.height ).Integer;
	endif;
	if max &gt; 0 then
		self.picCriteria.scrollBars := Picture.ScrollBar_Vertical;
		self.picCriteria.setScrollRange(ScrollBar_Vertical, 0, max, 20, 100);
	else
		self.picCriteria.scrollBars := 0;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setYardAllocation" id="30ded074-a8e6-4bb2-80d1-b8a5b1c0e486">
        <updating/>
        <source>setYardAllocation(_yas: ObjectArray) updating;

/* PAR 35833
Purpose:			
Date				Who			Reason
MARCH 2015		CNWAB1		Initial creation
*/

vars
	ya : CM_InvoiceAllocation;
	proxyObj		: CM_InvoiceAllocation;
	blockGroupObj	: CM_YABlockGroup;
	isLoadSet		: Boolean;
	criteria		: CM_YACriteria;
	imex			: CM_YACriteria;
	proxyCriteria	: CM_YACriteria;
	imexStatus		: CM_IMEXStatus;
	yaIMEXConfig	: CM_YAIMEXConfig;
	criteriaType: CM_YACriteriaType;
	opCriteria: CM_YACriteriaArray;
begin
	self.doClearCurrentYA();
	
	
	if _yas = null then
		if self.myTranMap &lt;&gt; null then  // ### TFS 51219 25MAY2021 NAVAB1
			create proxyObj as CM_InvoiceCargoAllocation transient; // ### TFS 51219 25MAY2021 NAVAB1
		else
			create proxyObj as CM_InvoiceInventoryAllocation transient; // ### TFS 51219 25MAY2021 NAVAB1
		endif;
		
		create blockGroupObj transient;
		proxyObj.allYABlockGroupsIn.add(blockGroupObj);
		proxyObj.allYABlockGroupsOut.add(blockGroupObj);
		self.myProxyYA	:=	proxyObj;
		self.myProxyYA.setTerminal(self.myTerminal);
		self.updateMode := false;
	else // ### TFS 51219 25MAY2021 NAVAB1if _yas.size = 1 then
		ya := _yas.first.CM_InvoiceAllocation;
		proxyObj	:=	app.createUpdateProxy(ya).CM_InvoiceAllocation;
		self.isTemplateModified := ya.isTemplateModified;
		self.myProxyYA			:=	proxyObj;
		self.myYardAllocation	:=	ya;
		self.updateMode := true;
 // ### TFS 51219 25MAY2021 NAVAB1	else
 // ### TFS 51219 25MAY2021 NAVAB1		_yas.copy(self.allBulkEditYAs);
	endif;
epilog
	delete opCriteria;
end;</source>
        <Parameter name="_yas" type="ObjectArray"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="ad9c17f8-c69f-4187-bbd7-0a8e77b889bf">
        <updating/>
        <source>setupForm() updating;
/*
Date		Who		Reason
04 December 2009	cnwas3	Initial creation
12 Jun 2013	cnwcs5	par 31712 - 
May 12 2023 navmv20 Bug 57561: STWO - Code :79963. A Yard Allocation with this code () already exists- Issue 1 of 2
04/05/2023	navkc1	Bug 57484: EUP - Cargo Allocation Transaction Map Permissions
*/

vars

begin
	inheritMethod();
	self.openWithSavedSettings();
	self.resizeForVoyage();
	self.btnMap.left 		:= 22;	
	
	self.lblYAColour.visible 	:= false;
	self.clrYAColour.visible 	:= false;

	self.grpTemplate.visible 	:= false;
	self.cmbIMEX.visible 		:= false;
	self.lblHeader.visible 		:= false;
	self.chkDisableYA.visible 	:= false;
	self.btnFindImex.visible 	:= false;
	self.shtLocation.visible 	:= false;
	self.shtOptions.visible 	:= false;
	self.txtGroupName.visible 	:= false;
	self.lblGroupName.visible 	:= false;
	self.txtImex.visible 		:= false;
//	self.btnNext.visible 		:= true; // TFS 6536
// TFS 6536	self.btnSave.left 			:= self.btnNext.left;
	
	self.btnCancel.setCaptionForTranslation("&amp;Close");
	
	self.frmHeader.transparent 	:= true;
	// must set height before fldYardAlloc height
	self.height 				:= self.fldYardAlloc.top + self.clrYAColour.top + 60 + 80;
	self.fldYardAlloc.height 	:= self.clrYAColour.top + 60;
	self.shtRemarks.visible 	:= false;
	self.fldYardAlloc.top 		:= 25;
	
	self.mnuFile.visible 		:= false;
	self.mnuHelp.visible 		:= false;
	self.mnuOptions.visible 	:= false;
	self.mnuWindows.visible 	:= false;
	self.mnuTerminal.visible 	:= false;
	self.mnuView1.visible 		:= false;
	
	self.btnMap.visible := false;
	self.myInvAlloc := self.myYardAllocation.CM_InvoiceAllocation; //12/05/2023 navmv20 Bug 57561
	
	// 04/05/2023	navkc1	Bug 57484
	self.doNoMaintPermDisableControls();
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="7c9c44b9-ae4c-44b6-b146-b5dde9240996">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 March 2015.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0020295, locale);
	btnMap.translateCaption(Xlat_0020317, locale);
	lblDescription.translateCaption(Xlat_0020318, locale);
end;</source>
    </JadeMethod>
</GUIClass>
