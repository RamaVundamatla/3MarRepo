    <JadeMethod name="convertStorageDetail" id="9f839521-4027-4973-8d41-a6ee180583d8">
        <source>convertStorageDetail();
// ---------------------------------------------------------------------------
// Created:     30 May 2013 by cnwjre1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//	Convert CM_StorageDetail freeDaysWorking to freeDaysType, and chargedDaysWorking to chargedDaysType for CCMS DPH 2278
//			allow for more options than just true/false
// 21 Jul 2017	cnwma1	TFS #5409:STWO - Storage Slab Auto Commercial Hold21 Jul 2017	cnwma1	TFS #5409:STWO - Storage Slab Auto Commercial Hold21 Jul 2017	cnwma1	TFS #5409:STWO - Storage Slab Auto Commercial Hold
// ---------------------------------------------------------------------------

vars
	detail	: CM_StorageDetail;
	freeDays	: Integer;
	chargedDays	: Integer;
begin
	app.writeLog( method.qualifiedName &amp; ' Upgrading storage detail free and charged days options from 8.1.2 to 8.2.1', LogINFO);
	beginTransaction;
	
	foreach detail in CM_StorageDetail.instances do
		if detail.chargedDaysWorking then
			chargedDays := CM_StorageDetail.Working_Days;
		else
			chargedDays := CM_StorageDetail.Calendar_Days;
		endif;
		if detail.freeDaysWorking then
			freeDays := CM_StorageDetail.Working_Days;
		else
			freeDays := CM_StorageDetail.Calendar_Days;
		endif;
		detail.setValues(chargedDays, freeDays, detail.freeStorageDays, detail.myStorageConfig, 0, detail.priorityValue, 0,0,false,null,detail.description, -1, -1, -1, -1, null, -1, -1, false, false); //21.07.2017 cnwma1 TFS #5409
	endforeach;

	commitTransaction;
	app.writeLog( method.qualifiedName &amp; ' Completed storage detail free and charged days options from 8.1.2 to 8.2.1', LogINFO);
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="convertTranMapQuantityRange" id="8ae531e0-6412-4828-9336-4f3dfa647703">
        <source>convertTranMapQuantityRange();
// ---------------------------------------------------------------------------
// Created:     15 January 2013 by cnwjre1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------
// 05/03/2015		cnwmh5			Transient Leaks
vars
	root	: CM_Root;
	mapType	: CM_TranMapInvoiceLineGroupType;
	mm,
	mapMapping	: CM_TranMapInvoiceLineMapping;
	mappingDict	: CM_TMInvLineMapByCargoAttrDict;
	qrm		: CM_QuantityRangeMap;
	ild		: CM_InvoiceLineDesc;
	iter	: Iterator;
	key		: Integer;
	count	: Integer;

begin
	app.writeLog( method.qualifiedName &amp; ' Upgrading transaction quantity map data from 8.1.2 to 8.2.1', LogINFO);
	
	// part 1 - create CM_TranMapInvoiceLineGroupType instances if not already there
	root := app.myRoot;
	if CM_TranMapInvoiceLineGroupType.instances.isEmpty() then
		beginTransaction;
		create mapType;
		mapType.update("All", TranMapInvLineGroupTypeAll, root);
		create mapType;
		mapType.update("Lowest", TranMapInvLineGroupTypeLow, root);
		create mapType;
		mapType.update("Lowest Default", TranMapInvLineGroupTypeLowDef, root);
		create mapType;
		mapType.update("Highest", TranMapInvLineGroupTypeHigh, root);
		create mapType;
		mapType.update("Highest Default", TranMapInvLineGroupTypeHighDef, root);
		commitTransaction;
		app.writeLog( method.qualifiedName &amp; ' Created Invoice Line Group Types', LogINFO);
	endif;
	
	// part 2 - convert 
	foreach mapType in CM_TranMapInvoiceLineGroupType.instances do
		if mapType.type = TranMapInvLineGroupTypeAll then
			break;
		endif;
	endforeach;

	beginTransaction;
	
	foreach qrm in CM_QuantityRangeMap.instances do
		// convert any existing CM_TranMapInvoiceLineMapping instances
		mappingDict := qrm.getAllTMInvoiceLineMaps();
		if mappingDict &lt;&gt; null then
			foreach mm in mappingDict do
				// copy to new instances which will auto belong to the CM_QuantityRangeMap in the new allTMInvoiceLineMappings reference
				create mapMapping;
				mapMapping.update(mm.mapValue, mm.myTMInvoiceLineDesc, qrm, mm.myTMInvoiceLineGroupType, mm.myTransferType, mm.myVesselCategory,mm.myCargoType, mm.myCargoSubtype, mm.myCommodity);
				count := count + 1;
			endforeach;
		endif;
			/* TFS 40620 removing all references to qrm.allInvoiceLineMaps

		if qrm.allTMInvoiceLineMappings.isEmpty() then
			// convert from existing keys plus the default mapping group type
			iter := qrm.allInvoiceLineMaps.createIterator();
			while iter.next(ild) do
				qrm.allInvoiceLineMaps.getIteratorKeys(key, iter);
				create mapMapping;
				mapMapping.update(key, ild, qrm, mapType, null, null);
				count := count + 1;
			endwhile;
			delete iter;
		endif;
		*/
	endforeach;

	commitTransaction;
	
	// delete old CM_TranMapInvoiceLineMapping instances which were in separate CM_TMInvLineMapByCargoAttrDict collections
	beginTransaction;
	foreach qrm in CM_QuantityRangeMap.instances do
		// remove the old collection and instances
		qrm.clearAllTMInvoiceLineMaps();
	endforeach;
	commitTransaction;
	
	app.writeLog( method.qualifiedName &amp; " " &amp; count.String &amp; ' Invoice Line Mapping instances created', LogINFO);
	app.writeLog( method.qualifiedName &amp; ' Completed transaction quantity map data from 8.1.2 to 8.2.1', LogINFO);
epilog
	delete iter;
end;</source>
    </JadeMethod>
    <JadeMethod name="convertUNDGHazardClass" id="247e9bb0-3224-48db-8501-d815608b8039">
        <source>convertUNDGHazardClass();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 April 2013	cnwer1	Initial creation CCMS  DPH 2280 

*/

vars
	undg : CM_UNDangerousGoods;
	hazClass : String;
	hazard : CM_HazardClass;
	root : CM_Root;
	str : String;
begin
	root := CM_Root.firstInstance;
	
	app.writeLog ('Converting UN Dangerous Good Hazard Class to reference', LogINFO);
	foreach undg in CM_UNDangerousGoods.instances do
		if undg.allClassCodes.isEmpty then
			continue;
		endif;
		if undg.myHazardClass &lt;&gt; null then
			continue;
		endif;
		
		hazard:=null;
		foreach hazClass in undg.allClassCodes do
			hazard:=root.allHazardClasses[hazClass];
			if hazard &lt;&gt; null then
				break;
			endif;
		endforeach;
		
		if hazard &lt;&gt; null then
			beginTransaction;
				undg.setMyHazardClass(hazard);
			commitTransaction;
		else
			app.writeLog ('Could not convert UNDG ' &amp; undg.code &amp; ' hazard classes ' &amp; undg.allClassCodes.concatenate(",") &amp; " do not exist" , LogINFO);
		endif;
	
	endforeach;
	
	
epilog

end;</source>
    </JadeMethod>
