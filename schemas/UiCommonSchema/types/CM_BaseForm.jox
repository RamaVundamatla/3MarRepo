    <JadeMethod name="moveTrackedItemTarget" id="10c9edfc-4443-470f-ade1-e4e698ea532d">
        <updating/>
        <source>moveTrackedItemTarget(pToLocation: CM_LocationsController) updating;
/*

Date		Who		Reason
25 March 2014	cnwer1	Initial creation CCMS 1366

*/

vars
	ti : CM_TrackedItem;
	form : CMUI_MoveAmountForm;
	quantity : Integer;
	weight : Decimal[14,4];
	modalResult : Integer;
begin

	self.mousePointer := Window.MousePointer_HourGlass;
	if app.myMoveController = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'app.myMoveController = null');
		return;
	endif;
	
	ti:= app.myMoveController.myTrackedItem;
	//make sure not discharge plan
	if not app.myMoveController.mySlotRequest &lt;&gt; null or app.myMoveController.myVoyageRequest &lt;&gt; null then
		//epr CCMS 1366 if break bulk multi show form asking for quantity if bulk multi show form asking for volume/weight
		if ti &lt;&gt; null then
			if ti.isChild and app.myMoveController.moveMode = REAL_MODE then
				//unpack the cargo to target lc
				self.myAssistant.showPackUnpackAmountForm(false,ti,null,pToLocation);
				return;
			else
				if (ti.myCargoType.isBreakBulkMulti or  ti.myCargoType.isBulkMulti) then
					//epr par 37074 19/11/15
					if app.myMoveController.moveMode &lt;&gt; REAL_MODE and
						app.myMoveController.isMoveFromVehicle and app.myMoveController.myWorkListEntry &lt;&gt; null and app.myMoveController.myWorkListEntry.job.isKindOf(CM_RoadJob) then
						if ti.myCargoType.isBreakBulkMulti then
							quantity:=app.myMoveController.myWorkListEntry.quantity;
						else
							weight :=app.myMoveController.myWorkListEntry.weight;						
						endif;					
					else
						
						//09 Dec 2019	NDL	TFS 46875 - if planning discharge from RORO GC area to Yard GC Area.
						if app.myMoveController.moveMode = PLANNING_MODE 
						and app.myMoveController.myVoyageRequest &lt;&gt; null and app.myMoveController.myVoyageRequest.isKindOf( CM_ROROGCRequest )
						and app.myMoveController.myVoyageRequest.isDischarge
						and pToLocation &lt;&gt; null and pToLocation.isKindOf(CM_IrregularBlockController) //Yard GC Area
						then
							//Coming from a graphic, cargo amount needs to be captured one at a time for break bulk.
							//so clear other Wles and other Tis.
							app.myMoveController.allOtherTrackedItems.clear();
							app.myMoveController.allOtherWLEs.clear();
						endif;
						
						create form transient;
						form.myTrackedItem:= ti;
						form.myWorkListEntry := app.myMoveController.myWorkListEntry;	//10 Dec 2019	NDL	TFS 46875
						form.targetLocation:=pToLocation.getFullId;
						if form.showModal &lt;&gt; IDOK then
							return;
						endif;
						if form.byQuantity then
							quantity:=form.getQuantity;
						else
							weight := form.getWeightMovedKgs;
						endif;
					endif;
				endif;
			endif;
		endif;
	endif;
	
	app.myMoveController.moveTrackedItemTarget(self.myTerminal,pToLocation,quantity, weight);
	
epilog
	delete form;
	self.mousePointer := Window.MousePointer_Default;

end;</source>
        <Parameter name="pToLocation" type="CM_LocationsController"/>
    </JadeMethod>
