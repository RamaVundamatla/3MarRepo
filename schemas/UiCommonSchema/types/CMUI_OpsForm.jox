        <source>initFrameRake();
// ---------------------------------------------------------------------------
// Created:		February  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin

/*	// #############################
	// TOOLBAR
	self.frmToolBar.visible := true;
	self.frmToolBar.top := 0;
	self.frmToolBar.left := 5;//self.frmLegend.width + 5;
	self.frmToolBar.height := ToolbarHeight;
	self.frmToolBar.caption := null;
	self.frmToolBar.backColor := Gray;
	self.frmToolBar.autoRedraw := true;
	self.doBtnToolBarLoadButtons();*/
	
	// #############################
	// LEFT SPLITTER FRAME
	self.frmLeftSplitter.visible := true;
	self.frmLeftSplitter.top := 0;
	self.frmLeftSplitter.left := 0; 
	
	// #############################
	// FRAME VIEW MODE
/*	self.frmViewMode.visible := true;
	self.frmViewMode.caption := "Voyage";
	self.frmViewMode.fontSize := 8;
	self.frmViewMode.alignment := Frame.Alignment_Center_Middle;
	self.frmViewMode.top := self.frmToolBar.top;
	self.frmViewMode.left := splMain.left;
	self.frmViewMode.height := self.frmToolBar.height;
	self.frmViewMode.width := self.frmLegend.width;
*/

	// #############################
	// COLOUR LEGEND TABLE
	self.frmLegend.left := 5;
	self.frmLegend.top := 0;
	self.frmLegend.doChangeViewMode(VIEW_JOB);
	self.frmLegend.doResize();	
	
	// #############################
	// SCROLLING GRID AREA
	self.mySDF.top := 0;
	self.mySDF.scrollBars := ScrollBars_Both;
	self.mySDF.labels := ScrollBars_Vertical;
	self.mySDF.setHLabelDetails(25);
	self.mySDF.setVLabelDetails(30);
	self.mySDF.labels := ScrollBars_Both;
	self.mySDF.visible := true;
	self.mySDF.displayMode := DISPLAY_MODE_ACTUAL;
	self.mySDF.viewMode := VIEW_JOB;
	self.mySDF.scaleFactor := 1.5;
	
	// #############################
	// EXTRA INFO TABLE
	self.tblInfoSmall.clear;
	self.tblInfoSmall.width := 500;
	self.tblInfoSmall.columns := 2;
	self.tblInfoSmall.visible := true;
	self.tblInfoSmall.stretchToParent := false;
	self.tblInfoSmall.rows := 0;
	self.tblInfoSmall.selectMode := Table.SelectMode_CurrentRow;
	self.tblInfoSmall.fixedRows := 0;
	self.tblInfoSmall.fixedColumns := 0;
	self.tblInfoSmall.top := 0;
	self.tblInfoSmall.accessColumn(1).backColor := ColourYellowLight;
	self.tblInfoSmall.accessedColumn.width := 150;
	self.tblInfoSmall.accessColumn(2).width := 400;
end;</source>
