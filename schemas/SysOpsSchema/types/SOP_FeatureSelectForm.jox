    <JadeMethod name="create" id="26eddd57-06be-4433-ac7f-b3969a0d1a0a">
        <updating/>
        <source>create() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 April 2010	#cnwdz2	 24641

