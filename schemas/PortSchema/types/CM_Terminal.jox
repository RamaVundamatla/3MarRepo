    <JadeMethod name="getProductMinMaxWeight" id="1b9e8c41-171b-476b-8af2-233b20e635de">
        <source>getProductMinMaxWeight(_productObj:CM_Product; _minimum:Integer output; _maximum:Integer output);
// --------------------------------------------------------------------------------
// Created:		04 March 2008 by cnwdad1
//
// Purpose:		Returns the minimum and maximum weight allowed for the receiver, for
//				the specified Product.
//
// Parameters:	_productObj - A reference to the Product who's limits we require.
//				_minimum - The minimum allowed weight.
//				_maximum - The maximum allowed weight.
//
// Returns:		The minimum and maximum allowed weight, as output parameters.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	areaObj		: CM_TerminalAreaMaster;
	minWeight	: Integer;
	maxWeight	: Integer;
	minTotal	: Integer;
	maxTotal	: Integer;
	
begin
	foreach areaObj in self.allTerminalAreaMastersById do
		areaObj.getProductMinMaxWeight(_productObj, minWeight, maxWeight);
		
		minTotal	:=	minTotal + minWeight;
		maxTotal	:=	maxTotal + maxWeight;
	endforeach;
	
	_minimum	:=	minTotal;
	_maximum	:=	maxTotal;
end;</source>
        <Parameter name="_productObj" type="CM_Product"/>
        <Parameter name="_minimum" type="Integer" usage="output"/>
        <Parameter name="_maximum" type="Integer" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getProformaItemQuery" id="ed6efc9f-8291-477d-8e43-1d31485d9db6">
        <source>getProformaItemQuery():CM_MenuUserQuery;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 January 2013	cnwndl1	Initial creation	Par 30901

*/

vars

	configString : String;
	userQuery : CM_MenuUserQuery;
	iter : Iterator;

begin

	configString := self.getConfig(ProFormaItemQuery).String;
	
	if configString &lt;&gt; null then
		iter := app.myRoot.myQueryMenuRoot.allMenuUserItemsWithAMenuItem.createIterator;
		while iter.next(userQuery) do
			if configString = userQuery.heading then
				return userQuery;
			endif;
		endwhile;
	endif;
	
	return null;

epilog

	delete iter;

end;</source>
        <ReturnType type="CM_MenuUserQuery"/>
    </JadeMethod>
