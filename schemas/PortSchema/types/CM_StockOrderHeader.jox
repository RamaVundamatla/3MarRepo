    <JadeMethod name="delete" id="41a24f17-88ff-4831-bc99-18283dd4c1b3">
        <updating/>
        <source>delete() updating;
// ---------------------------------------------------------------------------
// Created:     30 August 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	
begin
	if (not self.isTransient) then
		exclusiveLock(self);
		if self.myTerminal &lt;&gt; null then
			self.myTerminal.causeEvent(Event_StockOrderHdr_Delete, false, self.orderNo);
		endif;
	endif;
// cnwrs1 june 2006 was missing

	self.resetAuditsDuringDelete();	//21 Jan 2021	NDL	TFS 50152
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doMatch" id="608df88e-27b5-45ab-9f62-8b6e4965e48d">
        <updating/>
        <source>doMatch(_bolOut : CM_BOLOut; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     30 April 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	orderLine			: CM_StockOrderLine;
	ti					: CM_TrackedItem;
begin
	if _bolOut = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Outward docket passed into this method is null');
		return;
	endif;
	
	foreach orderLine in self.allStockOrderLines do
		orderLine.doMatch(_bolOut, _passport);		
	endforeach;
	
	self.updateFulfilledStatus(_passport);	
	app.myEventManager.createSingleObjInfoNoteEvt(self.myTerminal, Event_StockOrderHdr_Update, self);

end;</source>
        <Parameter name="_bolOut" type="CM_BOLOut"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doUnmatch" id="5ae07ede-70f0-4ed4-86cf-76580b964774">
        <updating/>
        <source>doUnmatch(_bolOut : CM_BOLOut; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     30 April 2004	cnwth2
//
// Purpose:     This will be called when the user is changing the BOLOut's accociation from
//				self. to a differnt stock order, or no stock order
//			 
// ----------   ----------  --------------------------------------------------
vars
	orderLine			: CM_StockOrderLine;
begin
	if _bolOut = null then
		return;
	endif;
	
	foreach orderLine in self.allStockOrderLines do
		orderLine.doUnmatch(_bolOut, _passport);
	endforeach;

	self.updateFulfilledStatus(_passport);
	
end;</source>
        <Parameter name="_bolOut" type="CM_BOLOut"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="fulfilledStatusDescr" id="e24c4e1e-74f0-4c41-9362-2ece743f32b9">
        <methodInvocation>mapping</methodInvocation>
        <source>fulfilledStatusDescr(set: Boolean; _value: String io) mapping;
// ---------------------------------------------------------------------------
// Created:     29 April 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin
	if set then
		app.raiseSetVirtualError(class.name, method.name);
	else
		_value := app.orderStatusEnumToString(self.fulfilledStatus);
	endif;

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getAllStockOrderLines" id="f21b61fa-e165-4254-acee-fe4c035d02fc">
        <source>getAllStockOrderLines() : String;
/*
Purpose:			
Date		Who		Reason
13 May 2014	cnwab1	Initial creation
*/

vars
	line : CM_StockOrderLine;
	lineStr : String;
begin
	foreach line in self.allStockOrderLines discreteLock do
		if lineStr = "" then
		
			lineStr := line.getOidString; // oidAsBin
		else
			lineStr := lineStr &amp; "," &amp; line.getOidString; // oidAsBin;
		endif;
 
	endforeach;
	
	return lineStr;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getAllocationForSOHLocn" id="a00842c3-1bd2-4fd4-8e9f-c456fc1da2e0">
        <source>getAllocationForSOHLocn(_sohLocn : CM_SOHLocation) : CM_StockOrderAllocation;
//-----------------------------------------
//Created: October 2002 By: cnwgd1
//-----------------------------------------
vars
	allocation : CM_StockOrderAllocation;
begin
	foreach allocation in self.allStockOrderAllocations do
		if allocation.mySOHLocation = _sohLocn then
			return allocation;
		endif;
	endforeach;
	return null;
end;</source>
        <Parameter name="_sohLocn" type="CM_SOHLocation"/>
        <ReturnType type="CM_StockOrderAllocation"/>
    </JadeMethod>
