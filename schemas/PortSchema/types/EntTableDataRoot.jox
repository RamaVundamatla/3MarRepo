// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	self.allEntTableGroups.purge;
	self.allEntTableRowHeadersByName.purge;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="createEntTableGroup" id="ec0ec2bc-ebd4-4302-842b-e8d194a591f7">
        <source>createEntTableGroup(pName, pText : String) : EntTableGroup;
// ---------------------------------------------------------------------------
// Created:     19 January 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	grp		: EntTableGroup;
	
begin

	create grp;
	grp.set(pName, pText, self);
	
	return grp;
	
end;</source>
        <Parameter name="pName" type="String"/>
        <Parameter name="pText" type="String"/>
        <ReturnType type="EntTableGroup"/>
    </JadeMethod>
    <JadeMethod name="outputConstantCategory" id="02b241d2-4939-443e-a0ee-171b5ee59700">
        <source>outputConstantCategory(_category : ConstantCategory; _file : File) protected;
// ---------------------------------------------------------------------------
// Created:     15 August 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	const 		: Constant;
	constDict	: ConstantNDict;

begin

	constDict := _category.getConstants();
	
	_file.writeLine('categoryDefinition ' &amp; _category.name);

	foreach const in constDict do
		_file.writeLine(Tab &amp; Tab &amp; const.name &amp; ': String = "' &amp; const.valueAsString &amp; '";');
		_file.writeLine(Tab &amp; 'documentationText');
		_file.writeLine('`' &amp; const.text &amp; '`');
	endforeach;

end;</source>
        <access>protected</access>
        <Parameter name="_category" type="ConstantCategory"/>
        <Parameter name="_file" type="File"/>
    </JadeMethod>
    <JadeMethod name="populateArrayFromString" id="fba30352-a5ec-4838-b292-5f9267f29a52">
        <source>populateArrayFromString(pString : String; pStringArray : StringArray input) : Boolean;
// ---------------------------------------------------------------------------
// Created:     11 June 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	str		: String;
	pos		: Integer;
	
begin

	// add a final delimiter so scanUntil will pickup last item correctly
	str := pString &amp; Delimiter;

	pStringArray.clear;
	pos := 1;
	while pos &lt;= str.length do
		pStringArray.add(str.scanUntil(Delimiter, pos));
		if pos = 0 then
			break;
		endif;
		pos := pos + 1;
	endwhile;

	if pStringArray.size &lt; 2 then
		return false;
	endif;
	
	return true;

end;</source>
        <Parameter name="pString" type="String"/>
        <Parameter name="pStringArray" type="StringArray" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="6ff97ec7-72c7-4216-b7bb-5d74de40baec">
        <updating/>
        <source>setForCreate(pName, pText, pSchema, pGroupCategory, pDefCategory, pRowCategory : String) updating;
// ---------------------------------------------------------------------------
// Created:     17 July 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	self.name		:= pName;
	self.text		:= pText;
	self.schemaName	:= pSchema;
	
	self.groupCategory	:= pGroupCategory;
	self.defCategory	:= pDefCategory;
	self.rowCategory	:= pRowCategory;
	
end;</source>
        <Parameter name="pName" type="String"/>
        <Parameter name="pText" type="String"/>
        <Parameter name="pSchema" type="String"/>
        <Parameter name="pGroupCategory" type="String"/>
        <Parameter name="pDefCategory" type="String"/>
        <Parameter name="pRowCategory" type="String"/>
    </JadeMethod>
