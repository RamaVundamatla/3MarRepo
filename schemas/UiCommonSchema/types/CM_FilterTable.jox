        <source>scrolled(table: Table input; scrollBar: Integer) updating, clientExecution;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 January 2015	cnwndl1	Initial creation

*/

vars

begin
	
	if self.tblFilterHeaders &lt;&gt; null then
		if scrollBar = 1 then
			if self.tblFilterHeaders.columns &gt;= self.leftColumn then
				self.tblFilterHeaders.leftColumn := self.leftColumn;
			endif;
		endif;
	endif;
	
	inheritMethod(table, scrollBar);

epilog

end;</source>
