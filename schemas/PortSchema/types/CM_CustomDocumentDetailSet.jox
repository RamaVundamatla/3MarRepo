    <JadeMethod name="getFirstActive" id="46c0f62a-f81a-46bc-a393-83e77022a237">
        <source>getFirstActive() : CM_CustomDocumentDetail;
/*
Purpose:			

Date		Who		Reason
14 November 2023	navab1	CR 60425 TASK 60828 
*/

vars

	cdd : CM_CustomDocumentDetail;
begin
	foreach cdd in self discreteLock do
		if cdd.isActive() then
			return cdd;
		endif;
	endforeach;
	
	return null;


epilog

end;</source>
        <ReturnType type="CM_CustomDocumentDetail"/>
    </JadeMethod>
    <JadeMethod name="getLastActive" id="b7ee0799-b836-45ad-9711-86d035fde593">
        <source>getLastActive() : CM_CustomDocumentDetail;
/*
Purpose:			

Date		Who		Reason
14 November 2023	navab1	CR 60425 TASK 60828 
*/

vars

	cdd : CM_CustomDocumentDetail;
begin
	foreach cdd in self discreteLock, reversed do
		if cdd.isActive() then
			return cdd;
		endif;
	endforeach;
	
	return null;


epilog

end;</source>
        <ReturnType type="CM_CustomDocumentDetail"/>
    </JadeMethod>
