    <JadeMethod name="trxUpdateTIExternalProfileID" id="07b13660-a4d9-4e78-a15b-d6942adebad6">
        <updating/>
        <source>trxUpdateTIExternalProfileID(_theProxyTI: CM_TrackedItem input; _profileID, _profileSecret: String; _passport: CM_Passport input) updating;

/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 November 2018	jlgmp6	Initial creation	TFS41999

*/
vars
	txn 		: CM_TITransaction;
	txnParams	: CMIF_TITransactionController;
	cargo		: CM_TrackedItem;
	id,
	secret		: String;
begin

	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportSilentExHandler(exception, _passport);
	on LockException do agtPassportSilentLockExHandler(exception, 10, _passport);

	cargo := _theProxyTI.pxyGetRealObject();
	id := cargo.externalProfileID;
	secret := cargo.externalProfileSecret;

	beginTransaction;
	app.myUtilityUA.utlUpdateTIExternalProfileID(_theProxyTI, _profileID, _profileSecret, _passport);

	create txnParams transient;
	txnParams.type := TRANS_TYPE_EDIT;
	txnParams.myTrackedItem := cargo;
	txn := cargo.createTransaction(txnParams, app.myPassport);	
	txn.CM_Edit.fieldsValues.add(CM_TrackedItem::externalProfileID.name &amp; Space &amp; id &amp; " =&gt; " &amp; _profileID &amp; CrLf);
	txn.CM_Edit.fieldsValues.add(CM_TrackedItem::externalProfileSecret.name &amp; Space &amp; secret &amp; " =&gt; " &amp; _profileSecret &amp; CrLf);

epilog
	delete txnParams;
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_theProxyTI" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_profileID" type="String"/>
        <Parameter name="_profileSecret" type="String"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxUpdateTIForCargoChecks" id="a0951373-8598-41fb-8afb-6168b62fceba">
        <updating/>
        <source>trxUpdateTIForCargoChecks(	_pxyTI : CM_TrackedItem input; 
							_comment : String;
							_updateMode : Integer;
							_txnControllerDict 	: CMIF_TITxnContrlrByTypeDTDict;
							_toDoTaskCodes : IntegerArray; 
							_addingToDos : BooleanArray;
							_passport : CM_Passport input	) updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09/03/2010	cnwdap1	Initial creation PAR #22694
08/05/2018	jlgmd1	TFS #38663 QNS - Jade Lock issue
*/
vars
	realTi	: CM_TrackedItem;
	i		: Integer;	
	
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	// Defer our actual updates until the end
	_passport.useTITransactionDeferUpdate := true;		// TFS 38663
	_passport.useTIDictDeferUpdate := true;				// TFS 38663
	
	// get the realTI for to do trask updates
	realTi := _pxyTI.pxyGetRealObject();

	beginTransaction;

	app.myUtilityUA.utlUpdateTrackedItem(_pxyTI, _comment, _updateMode, _txnControllerDict, null, null, _passport);
	
	if _passport.noErrors then
		foreach i in 1 to _toDoTaskCodes.size do
			if _addingToDos[i] then
				app.myUtilityUA.utlUpdateTIToDoTaskAdd(realTi, _toDoTaskCodes[i], _passport);
			else
				app.myUtilityUA.utlUpdateTIToDoTaskRemove(realTi, _toDoTaskCodes[i], _passport);
			endif;
		endforeach;
	endif;
	
	if _passport.noErrors then				// TFS 38663
		_passport.doDeferredUpdates();		// TFS 38663
	endif;									// TFS 38663
	
epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_pxyTI" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_comment" type="String"/>
        <Parameter name="_updateMode" type="Integer"/>
        <Parameter name="_txnControllerDict" type="CMIF_TITxnContrlrByTypeDTDict"/>
        <Parameter name="_toDoTaskCodes" type="IntegerArray"/>
        <Parameter name="_addingToDos" type="BooleanArray"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxUpdateTIFreeStorageDays" id="f023f771-8ec6-4afa-998c-8bbe194de8ff">
        <updating/>
        <source>trxUpdateTIFreeStorageDays(_theProxyTI: CM_TrackedItem input; _freeStorageDays : Integer;
					_passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:		February  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportSilentExHandler(exception, _passport);
	on LockException do agtPassportSilentLockExHandler(exception, 10, _passport);

	beginTransaction;
	app.myUtilityUA.utlUpdateTIFreeStorageDays(_theProxyTI, _freeStorageDays, _passport);
	
epilog	
	self.finaliseActivityWithPassport(_passport);
	
end;</source>
        <Parameter name="_theProxyTI" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_freeStorageDays" type="Integer"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxUpdateTIFromAPI" id="9afc51ee-9e89-4d4f-99f2-92cf753cdae4">
        <updating/>
        <source>trxUpdateTIFromAPI( _pxyTI : CM_TrackedItem input;
					_realCargo :CM_TrackedItem input;
                    _comment : String; 
                    _updateMode : Integer;
                    _txnControllerDict : CMIF_TITxnContrlrByTypeDTDict;
                    _allCMIFCargoStops : CMIF_Array input; 
                    _passport : CM_Passport input) updating;

/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 Apr 2025	navbs1	Initial creation Bug MTN-34731:CUX - API PUT cargo: 96449. A Stop with Id 200 is already applied to cargo item
19 May 2025 navsp1  JIRA-34865  MTN | PUT cargo endpoint doesn't correctly handle Stops with "Info Required On Clear"
*/

vars
	pxyParent					: CM_TrackedItem;
	pxyToDoTask,
	realToDoTask				: CM_ToDoTask;
	customsRefs					: CM_CustomsReferenceDict;
	storageDetail, pxyStorage	: CM_StorageExpiryDetail;
	pxyRef, realRef				: CM_CustomsReference;
	index						: Integer;
	stopsTable					: CM_StopsTable;
	tiSet						: CM_TISet;	
begin
	self.initialiseActivityWithPassport(_passport, method);

	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);
	
	_passport.useTITransactionDeferUpdate := true;
	_passport.useTIDictDeferUpdate := true;

	beginTransaction;

	app.myUtilityUA.utlUpdateTrackedItem(_pxyTI, _comment, _updateMode, _txnControllerDict, null, null, _passport);
	
	if _passport.hasErrors then 
		return;
	endif;
	
	
	if _realCargo &lt;&gt; null and (_realCargo.isMAFI() or _realCargo.isTrailer()) then		// TFS 65549
			// delete the proxy link otherwise we get an error
			pxyParent := app.myProxyManager.getProxyObject(_realCargo).CM_TrackedItem;
			app.myProxyManager.deleteProxyLink(pxyParent);
			// and the customs references as well if there are any
			customsRefs := _realCargo.allCustomsReferences;
			if customsRefs &lt;&gt; null and not customsRefs.isEmpty then
				foreach realRef in customsRefs do
					pxyRef := app.myProxyManager.getProxyObject(realRef).CM_CustomsReference;
					app.myProxyManager.deleteProxyLink(pxyRef);
				endforeach;
			endif;
			// TFS 64920 and storage details if there are any
			foreach storageDetail in _realCargo.allStorageExpiryDetails do
				pxyStorage := app.myProxyManager.getProxyObject(storageDetail).CM_StorageExpiryDetail;
				app.myProxyManager.deleteProxyLink(pxyStorage);
			endforeach;
			
			foreach realToDoTask in _realCargo.allToDoTasksCompleted do							//11.09.2024 navma1 #66070
				pxyToDoTask := app.myProxyManager.getProxyObject(realToDoTask).CM_ToDoTask;
				app.myProxyManager.deleteProxyLink(pxyToDoTask);
			endforeach;
			
			
			foreach realToDoTask in _realCargo.allToDoTasksToDo do								//11.09.2024 navma1 #66070
				pxyToDoTask := app.myProxyManager.getProxyObject(realToDoTask).CM_ToDoTask;
				app.myProxyManager.deleteProxyLink(pxyToDoTask);
			endforeach;
			
			app.myUtilityUA.utlDetachChildrenAndMove(_realCargo, _passport);
			
			if _passport.hasErrors then 
				return;
			endif;
	endif;
	
    app.myUtilityUA.utlUpdateCargoStops(_realCargo, _allCMIFCargoStops, _passport);     //JIRA-34865
    if _passport.hasErrors then                                                         //JIRA-34865
        return;                                                                         //JIRA-34865
    endif;                                                                              //JIRA-34865   
	
	if _passport.noErrors then
		_passport.doDeferredUpdates();		
	endif;	

	
epilog
	self.finaliseActivityWithPassport(_passport);	
	
end;</source>
        <Parameter name="_pxyTI" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_realCargo" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_comment" type="String"/>
        <Parameter name="_updateMode" type="Integer"/>
        <Parameter name="_txnControllerDict" type="CMIF_TITxnContrlrByTypeDTDict"/>
        <Parameter name="_allCMIFCargoStops" type="CMIF_Array" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxUpdateTIFromBookingDiscrep" id="511db4e2-e6d9-43d3-9402-2b282c790f94">
        <updating/>
        <source>trxUpdateTIFromBookingDiscrep(_discrepancies : CM_BookingRefDiscrepsSet; _passport : CM_Passport input) updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27/10/2011	cnwdap1	Initial creation PAR #28524 CCMS POL 2096
15 May 2023			navmk20 Bug 57886: MTN - Cannot update cargo from booking discrepancy screen
*/
vars
	discrepancy			: CMEVT_BookingRefDiscrep;
	ti, pxyTI			: CM_TrackedItem;
	booking				: CM_BookingRef;
	value				: CM_BookingRefDiscrepFieldValue;
	entTableDef			: EntTableDef;
	entTableRow			: EntTableRow;
	bookingItem			: CM_BookingRefItem;
	haz, pxyHaz			: CM_Hazard;
	pxyTIs, tis			: CM_TISet;
	updateController	: CMIF_TIUpdateController;

begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);
	
	create pxyTIs transient;
	create tis transient;
	updateController := app.createTIUpdateControl(TI_UPDMODE_NORMAL, null, null);
	
	beginTransaction;
	
	foreach discrepancy in _discrepancies do
	
		// ignore those already closed
		if discrepancy.isClosed then
			continue;
		endif;
		
		// get the TI and the booking from the discrepancy
		ti 			:= discrepancy.myTrackedItem;
		booking		:= discrepancy.myBookingRef;
		bookingItem	:= booking.getBookingRefItemForTI(ti);
		entTableDef := app.myRoot.myEntTableDataRoot.allEntTableDefs[ETDef_BookingRefDiscrep];
		
		//04 Apr 2014	NDL	Par 33760
		if booking = null or ti = null then
			continue;
		endif;
		
		// If this ti is not in our set of processed tis, create the proxy ti
		// Otherwise retrieve the proxy ti that's already in the pxyTis set so all discrepancies for this TI get applied to the proxy
		if not tis.includes(ti) then
			pxyTI := ti.pxyCreateUpdateProxy();
		else
			pxyTI := app.myProxyManager.getProxyObject(ti).CM_TrackedItem;
		endif;
		if not pxyTIs.includes(pxyTI) then
			pxyTIs.add(pxyTI);
		endif;
		
		/* work out the discrepancies - possibilities are
			Cargo Type
			Voyage
			Discharge Port
			Temperature
			Humidity
			Ventilation
			Hazardous
			Curtains In
			Destination
			Consignee
			Consignor
			Is Stock
			ISO Type
			Commodity	*/
		foreach value in discrepancy.allBookingRefDiscrepFieldVs discreteLock do
			if not value.isDiscrepancy then
				continue;
			endif;
			
			entTableRow := entTableDef.getEntTableRowByHeading(value.fieldName);
			
			if entTableRow.name = ETRow_CargoType then
				if bookingItem &lt;&gt; null then	//04 Apr 2014	NDL	Par 33760
					pxyTI.setCargoType(bookingItem.cargoType);
				else
					pxyTI.setCargoType(booking.cargoType);
				endif;
			elseif entTableRow.name = ETRow_Voyage then
				pxyTI.setVoyageCode(booking.myVoyage.code, _passport);
			elseif entTableRow.name = ETRow_DischargePort then
				pxyTI.setDischargePort(booking.dischargePort.String);
			elseif entTableRow.name = ETRow_CarriageTemperature then
				if bookingItem &lt;&gt; null then	//04 Apr 2014	NDL	Par 33760
					pxyTI.setTemperature(bookingItem.tempCelcius);
				else
					pxyTI.setTemperature(booking.temperature);
				endif;
			elseif entTableRow.name = ETRow_Humidity then
				if bookingItem &lt;&gt; null then	//04 Apr 2014	NDL	Par 33760
					pxyTI.setHumidity(bookingItem.myReeferProperties.getHumidity);
				else
					pxyTI.setHumidity(booking.getHumidity);
				endif;
			elseif entTableRow.name = ETRow_Ventilation then
				if bookingItem &lt;&gt; null then	//04 Apr 2014	NDL	Par 33760
					pxyTI.setVentilation(bookingItem.myReeferProperties.ventilation);
				else
					pxyTI.setVentilation(booking.ventilation);
				endif;
			// Start 15.5.2023 navmk20 TFS 57886
			elseif entTableRow.name = ETRow_CO2 then
				if bookingItem &lt;&gt; null then	 
					pxyTI.setOxygen(bookingItem.myReeferProperties.oxygen);
				endif;
			elseif entTableRow.name = ETRow_O2 then
				if bookingItem &lt;&gt; null then	 
					pxyTI.setCarbonDioxide(bookingItem.myReeferProperties.carbonDioxide);
				endif;
			// End 15.5.2023 navmk20 TFS 57886
			elseif entTableRow.name = ETRow_Hazardous then
				pxyTI.allTIHazards.purge;
				foreach haz in booking.allTIHazards where CM_TIHazard.hasInstance(haz) do
					pxyHaz := haz.pxyCreateUpdateProxy;
					pxyHaz.CM_TIHazard.setMyTrackedItem(pxyTI);
				endforeach;
			elseif entTableRow.name = ETRow_ContAtmosAndCurtainsIn then
				if bookingItem &lt;&gt; null then	//04 Apr 2014	NDL	Par 33760
					pxyTI.setCurtainsIn(bookingItem.isControlledAtmosphere);
				endif;
			elseif entTableRow.name = ETRow_Destination then
				pxyTI.setDestinationPort(booking.destinationPort);
			elseif entTableRow.name = ETRow_Consignee then
				pxyTI.setConsigneeByString(booking.consigneeCode);
			elseif entTableRow.name = ETRow_Consignor then
				pxyTI.setConsignorByString(booking.consignorCode);
			elseif entTableRow.name = ETRow_ISOType then
				if bookingItem &lt;&gt; null then	//04 Apr 2014	NDL	Par 33760
					pxyTI.setISOType(bookingItem.isoType);
				else
					pxyTI.setISOType(booking.isoType);
				endif;
			elseif entTableRow.name = ETRow_Commodity then
				if bookingItem &lt;&gt; null then	//04 Apr 2014	NDL	Par 33760
					pxyTI.setCommodity(bookingItem.commodity);
				else
					pxyTI.setCommodity(booking.commodity);
				endif;
				
			// Stock booking item is a special case - this shows a mismatch between the booking and booking item,
			// not the booking and tracked item, and as far as I can see, can never happen?
			elseif entTableRow.name = ETRow_IsStockBookingReference then
			endif;
		endforeach;
		
		// add the ti in to the set of processed tis
		if not tis.includes(ti) then
			tis.add(ti);
		endif;
	endforeach;
	
	// we now have a set of proxy tis which have had all their discrepancies applied to them - do the updates now
	updateController.setMyTransientTIs(pxyTIs);
	
	app.myUtilityUA.utlUpdateTrackedItems(updateController, _passport);
		
	// if the update went OK, mark the discrepancies as closed
	if _passport.noErrors() then
		foreach discrepancy in _discrepancies do
			app.myUtilityUA.utlUpdateBookingRefRemarks(discrepancy, discrepancy.myBookingRef.remarks, true, _passport);
			if not _passport.noErrors() then
				break;
			endif;
		endforeach;
	endif;
	
epilog
	pxyTIs.purge;
	delete pxyTIs;
	delete tis;
	self.finaliseActivityWithPassport(_passport);
	delete updateController;  // cnwma1 29/04/2014
end;</source>
        <Parameter name="_discrepancies" type="CM_BookingRefDiscrepsSet"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxUpdateTIGTERecRemoveToDo" id="8b38e42f-fda2-4307-9b9f-eed5034d48e3">
        <updating/>
        <source>trxUpdateTIGTERecRemoveToDo(_tiSet 		: CM_TISet input;
							_pxyGTE : CMGTE_Receival input;
							_toDoTaskDesc: CM_ToDoTaskDesc;
							_resourceUsageProxys : CM_ResourceTypeUsageSet input;
							_passport : CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
27 November 2018	jlgns1	Initial creation
28/11/2018   		JLGNS1	ChangeRequest 39691: SNO- VGM Gate Process
19 February 2019	jlgzm1	TFS43262 SNO vgm weighed transactions
04 March 2019		jlgzm1	TFS43611 SNO Weighed transaction not charged
*/

vars
	
begin
self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);
	
	app.setContinueCMExceptions(false);

	_passport.useTITransactionDeferUpdate	:= true;	//tfs43611
	_passport.useTIDictDeferUpdate			:= true;	//tfs43611

	beginTransaction;
			
	//app.myUtilityUA.utlUpdateTIToDoTaskCmpltBulk(_toDoTaskDesc, _tiSet, _resourceUsageProxys, _passport);
	app.myUtilityUA.utlUpdateTIToDoTaskCmpltGTE(_toDoTaskDesc, _tiSet, _pxyGTE, _resourceUsageProxys, _passport); //tfs43262
			
	app.myUtilityUA.utlUpdateGTERelRemoveToDo(_pxyGTE ,_toDoTaskDesc , _passport );	
	
	_passport.doDeferredUpdates();	
	
epilog
	self.finaliseActivityWithPassport(_passport);

end;</source>
        <Parameter name="_tiSet" type="CM_TISet" usage="input"/>
        <Parameter name="_pxyGTE" type="CMGTE_Receival" usage="input"/>
        <Parameter name="_toDoTaskDesc" type="CM_ToDoTaskDesc"/>
        <Parameter name="_resourceUsageProxys" type="CM_ResourceTypeUsageSet" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxUpdateTIHazChildren" id="146756c9-129b-4e83-8e38-6e268b754c67">
        <updating/>
        <source>trxUpdateTIHazChildren(	_intFaceArray : CMIF_TIObjectArray input;
						_proxyTI : CM_TrackedItem input;
						_parentCont : CM_TrackedItem input;
						_removedChildren : ObjectArray input;
						_passport : CM_Passport input	) updating;
//
// Purpose:			Update child cargo items in _parentCont with details from _proxyTI
//					Create new child cargo items for each entry in _intFaceArray
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 23/06/2015	cnwdap1		Initial creation PAR #36421 Hazardous Materials Handling
// 30/11/2015   cnwma1		PAR #36992	Hazardous Flag not cleared when Hazardous Details removed
//
vars
	ti 				: CM_TrackedItem;
	item 			: CMIF_TIObject;
	child			: CM_TrackedItem;
	realChild		: CM_TrackedItem;
	removeChildren	: CM_TISet;
	obj 			: Object;
	oldHazards		: String;
	newHazards		: String;
	strs			: CM_Strings;
	txnObj 			: CM_TITransaction;
	txnParams		: CMIF_TITransactionController;

begin
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(true);
	//-------------------------------------------------------------
	//   V A L I D A T I O N    S E C T I O N
	//-------------------------------------------------------------
	//we are making LCL, it must be in a container 
	if _parentCont = null then
		app.raiseCMException(Location_Or_Parent_Required, null, null);
		return;
	endif;
	 
	// then validate the new children
	app.myValCA.valPreNotes(_intFaceArray, _passport);

	// ensure any locks are cleared
	endLoad;

	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;

	app.setContinueCMExceptions(false);

	_passport.useTIDictDeferUpdate := true;
	_passport.useTITransactionDeferUpdate := true;
	
	oldHazards := _parentCont.getHazardsAsString;

	beginTransaction;
	
	// remove any "new" children from the proxy parent TI
	create removeChildren transient;
	foreach child in _proxyTI.allChildren do
		realChild := child.pxyGetRealObject();
		if realChild = null then
			removeChildren.add(child);
		endif;
	endforeach;
	foreach child in removeChildren do
		_proxyTI.detachChild(child);
	endforeach;
	// and remove any deleted children
	foreach obj in _removedChildren do
		child := obj.CM_TrackedItem;
		_proxyTI.detachChild(child);
	endforeach;
	
	// update each child separately so we get Edit transactions for them
	foreach child in _proxyTI.allChildren do
		app.myUtilityUA.utlUpdateTrackedItem(child, null, TI_UPDMODE_NORMAL, null, null, null, _passport);
	endforeach;
	if _passport.hasErrors then
		return;
	endif;
	
	// now attach the children to the parent TI and update the parent
	app.myUtilityUA.utlUpdateTrackedItem(_proxyTI, null, TI_UPDMODE_NORMAL, null, null, null, _passport);
	if _passport.hasErrors then
		return;
	endif;
	
	// remove deleted children from the parent TI
	foreach obj in _removedChildren do
		child := obj.CM_TrackedItem;
		realChild := child.pxyGetRealObject;
		if realChild = null or not app.isValidObject(realChild) then
			continue;
		endif;
		_parentCont.detachChild(realChild);
		realChild.erase(NORMAL_ERASE);
	endforeach;
	
	// now attach the new children
	app.myUtilityCA.utlCreatePreNotes(_intFaceArray, false, _passport);
	if _passport.hasErrors then
		return;
	endif;
	
	foreach item in _intFaceArray do
		ti := item.CMIF_PreNote.myPersistentTrackedItem;
		if ti = null or _passport.hasErrors then
			continue;
		endif;
		//creating LCL directly in a container
		ti.setFromParent(_parentCont, _passport);
	endforeach;
	
	if _passport.hasErrors then
		return;
	endif;
	
	// and update the hazards from the new children on to the parent
	_parentCont.setHazardsFromChildren();
	
	if _parentCont.allChildren.isEmpty then     //30/11/2015 cnwma1 PAR #36992
		_parentCont.allTIHazards.purge();
	endif;
	
	if _passport.hasErrors then
		return;
	endif;
	
	// create an edit transaction for any change to hazards
	newHazards := _parentCont.getHazardsAsString;
	if newHazards &lt;&gt; oldHazards then
		create txnParams transient;
		txnParams.type := TRANS_TYPE_EDIT;
		txnParams.myTrackedItem := _parentCont;
		txnObj := _parentCont.createTransaction(txnParams, _passport);
		
		strs := txnObj.CM_Edit.fieldsValues;
		strs.add(CM_Container::hazardList.name &amp; Space &amp; oldHazards &amp; " =&gt; " &amp; newHazards);
	endif;
		
	if _passport.noErrors then
		_passport.doDeferredUpdates();
	endif;
	
epilog
	self.finaliseActivityWithPassport(_passport);
	if _passport.trxCompletedOK then
		removeChildren.purge;
	endif;
	delete removeChildren;
end;</source>
        <Parameter name="_intFaceArray" type="CMIF_TIObjectArray" usage="input"/>
        <Parameter name="_proxyTI" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_parentCont" type="CM_TrackedItem" usage="input"/>
