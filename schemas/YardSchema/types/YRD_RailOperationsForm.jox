    <JadeMethod name="isStartGridPointSkeletonCar" id="da2c2987-4847-4ee5-9302-52c24066f5f7">
        <source>isStartGridPointSkeletonCar(_control: CMUI_Frame): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 October 2016	cnwmp6	Initial creation	TFS 2533

*/

vars

begin
	if _control &lt;&gt; null then
		if _control.isKindOf(CMUI_GridAreaFrame) then
			if _control.CMUI_GridAreaFrame.myStartGridPoint &lt;&gt; null then // 1090
				return _control.CMUI_GridAreaFrame.myStartGridPoint.isSkeletonCar();
			endif;
		endif;
	endif;
	
	return false;

epilog

end;</source>
