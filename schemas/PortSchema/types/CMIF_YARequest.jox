    <JadeMethod name="isInstructionType_Match" id="3be1eb16-dfaf-4f45-aece-465f66655836">
        <source>isInstructionType_Match(_yaData: CM_YADataObjects): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 Feb 2023 navhl20 ChangeRequest 61960: FR | 57937 - [TKT: 61898] - Kiosk - US.080 'c' - Coded Instructions Missing from Additional question Criteria 

*/

vars
	code 			: String;
	instruction		: CM_InstructionsIssued;
begin
	if self.myReserveSelection &lt;&gt; null then
		instruction := self.myReserveSelection.myInstructions;
	elseif self.myBookingRefItem &lt;&gt; null then
		instruction := self.myBookingRefItem.myInstructions;
	endif;
	
	if instruction = null then
		return true;
	endif;
	
	code := instruction.myInstructionType.code;
		
	// Only priorities will be empty.
	if _yaData.isEmpty() then
		return true;
	endif;
	
	return _yaData.visitObjectsUntilTrue(self, CMIF_YAAutoPlanNormal::isInstructionType_Compare, code);
epilog

end;</source>
        <Parameter name="_yaData" type="CM_YADataObjects"/>
        <ReturnType type="Boolean"/>
