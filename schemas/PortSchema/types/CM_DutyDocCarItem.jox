    <JadeMethod name="setForUpdate" id="d716d25b-2df6-470a-9817-f4b4af7a54b7">
        <updating/>
        <source>setForUpdate(_proxyDutyItem: CM_DutyDocCarItem) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 December 2012	cnwer1	Initial creation HAT 2189

*/

vars

begin
	inheritMethod(_proxyDutyItem);
	self.vccNo:=_proxyDutyItem.vccNo;
	self.vccDate:=_proxyDutyItem.vccDate;
	self.vehicleType:=_proxyDutyItem.vehicleType;
	self.vehicleMake:=_proxyDutyItem.vehicleMake;
	self.vehicleModel:=_proxyDutyItem.vehicleModel;
	self.chassisNo:=_proxyDutyItem.chassisNo;
	self.engineNo:=_proxyDutyItem.engineNo;
	self.color:=_proxyDutyItem.color;
	self.numberPlate:=_proxyDutyItem.numberPlate;
epilog

end;</source>
        <Parameter name="_proxyDutyItem" type="CM_DutyDocCarItem"/>
    </JadeMethod>
    <JadeMethod name="setProxyCar" id="ac299cc9-2da2-4643-b1c6-ed868651cd4e">
        <updating/>
        <source>setProxyCar(	_vccDate : Date;
				_vehicleType,
				_vehicleMake,
				_vehicleModel,
				_chassisNo,
				_engineNo,
				_color,
				_numberPlate : String) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 December 2012	cnwer1	Initial creation HAT 2189

*/

vars

begin
	self.vccNo:=self.getNextVCCNo();
	self.vccDate:=_vccDate;
	self.vehicleType:=_vehicleType;
	self.vehicleMake:=_vehicleMake;
	self.vehicleModel:=_vehicleModel;
	self.chassisNo:=_chassisNo;
	self.engineNo:=_engineNo;
	self.color:=_color;
	self.numberPlate:=_numberPlate;
epilog

end;</source>
        <Parameter name="_vccDate" type="Date"/>
        <Parameter name="_vehicleType" type="String"/>
        <Parameter name="_vehicleMake" type="String"/>
        <Parameter name="_vehicleModel" type="String"/>
        <Parameter name="_chassisNo" type="String"/>
        <Parameter name="_engineNo" type="String"/>
        <Parameter name="_color" type="String"/>
        <Parameter name="_numberPlate" type="String"/>
    </JadeMethod>
</Class>
