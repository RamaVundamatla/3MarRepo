    <JadeMethod name="setVoyageAllocation" id="8e366aca-43e7-4519-b1eb-a06300e546a1">
        <source>setVoyageAllocation(_update : Boolean;					
					_voyageAllocTemplate : CM_VoyageAllocation;
					_realAlloc : CM_VoyageAllocation io;
					_passport : CM_Passport input);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
15 December 2009	cnwas3	Initial creation

*/

vars
	yardAllocation		: CM_YardAllocation;
	realAlloc			: CM_VoyageAllocation;
	voyageController	: CM_VoyageController;
	yaDict				: CM_YAByPriorityDict;
	sr 					: CM_SlotRequest;
begin
	
	if not _update then
	
		create realAlloc persistent;
		
		realAlloc.setForCreateFromTemplate(_voyageAllocTemplate, null);
		self.allVoyageAllocations.add(realAlloc);
		_realAlloc := realAlloc;
	elseif _update then	
		realAlloc := _realAlloc;
		if realAlloc &lt;&gt; null then
			realAlloc.setForCreateFromTemplate(_voyageAllocTemplate, null);
		endif;		
	endif;	
	
	app.myEventManager.createSingleObjInfoNoteEvt(self, self.myTerminal.getTerminalEvent(Voyage_Update_Event), self);  
	
	
end;


</source>
        <Parameter name="_update" type="Boolean"/>
        <Parameter name="_voyageAllocTemplate" type="CM_VoyageAllocation"/>
        <Parameter name="_realAlloc" type="CM_VoyageAllocation" usage="io"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
