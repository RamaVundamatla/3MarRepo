    <JadeMethod name="doAcceptTask" id="88b2a51a-f004-4c77-882e-fdb8b273ac15">
        <updating/>
        <source>doAcceptTask(	_rtQueueEntry,
				_twinQueueEntry: CM_RTQueueEntry input;
				_sideAccessDirection : Integer input;
				_tandemLift : Boolean;
				_errorMsgs : DTO_HandHeldGateErrorDict input) updating;
/*

Purpose:		This accepts the task and does the pickup 
				- need to think about if we get twistlock info how I will choose which  rtQueueEntry it is


Return Value:		


Date				Who		Reason
14 September 2006	cnwer1	Initial creation - PAR#xxxx
10 Decemeber 2009	conkc1	Replay deadlocks
*/
vars
	rtQueueTask : CM_RTQueueTask;
	rtTwinTask : CM_RTQueueTask;
begin
	// PAR 20338 18807
	app.myPassport.setupForDeadlockReplay(-100, 2000);
	if _rtQueueEntry &lt;&gt; null then
		rtQueueTask:=_rtQueueEntry.allTasks.first;
	endif;
	if _twinQueueEntry &lt;&gt; null then
		rtTwinTask:=_twinQueueEntry.allTasks.first;
	endif;
	
	while true do

		self.doAcceptTaskBody(rtQueueTask,	rtTwinTask,_sideAccessDirection, _tandemLift,_errorMsgs);
		
		if app.myPassport.noTrxReplayAllowed() then	//15 Jan 2013	NDL	Par 30920
			break;
		endif;

	endwhile;

epilog
	process.setPersistentDeadlockPriority(0);
	app.myPassport.replayingDeadlocks := false;
end;</source>
        <Parameter name="_rtQueueEntry" type="CM_RTQueueEntry" usage="input"/>
        <Parameter name="_twinQueueEntry" type="CM_RTQueueEntry" usage="input"/>
        <Parameter name="_sideAccessDirection" type="Integer" usage="input"/>
        <Parameter name="_tandemLift" type="Boolean"/>
        <Parameter name="_errorMsgs" type="DTO_HandHeldGateErrorDict" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doAcceptTaskBody" id="d3a12751-9333-475e-a658-ce18403b648d">
        <updating/>
        <source>doAcceptTaskBody(_rtQueueTask,
				_twinQueueTask: CM_RTQueueTask input;
				_sideAccessDirection : Integer input;
				_tandemLift	: Boolean;
				_errorMsgs : DTO_HandHeldGateErrorDict input) updating, protected;
/*

Purpose:		This accepts the task and does the pickup 
				- need to think about if we get twistlock info how I will choose which  rtQueueEntry it is


Return Value:		


Date				Who		Reason
14 September 2006	cnwer1	Initial creation - PAR#xxxx
10 December 2009	conkc1	Replay deadlocks
20 January 2020	jlgka1 TFS 47394 - Tandem Movement Enhancement. Revert code back before the Tandem Movement changes.
*/
vars
	result : Boolean;
begin
	
	while true do
		self.initialiseForNewRequest(_errorMsgs);
	
		//epr TFS 995 16/5/17
		app.myTrxUA.trxMachineAcceptTask(self.myMachine,_rtQueueTask,_twinQueueTask,_sideAccessDirection,app.myPassport);	// 29/11/19 JLGNS1 TFS47394
	
		//app.myTrxRT.trxAcceptSpecifiedTaskTwin(_rtQueueEntry,_twinQueueEntry,self.myMachine,_sideAccessDirection,_tandemLift,useEntryFirstTaskForAccept,app.myPassport);
	
		if app.myPassport.hadReplayableDeadlock() then	//15 Jan 2013	NDL	Par 30920
			break;
		endif;
		
		if app.myPassport.trxCompletedOK then
			break;
		endif;
		result:= self.createErrorsFromPassport(_errorMsgs);
		if result then
			break;
		else
			continue;
		endif;
	endwhile;

	
epilog
	
end;</source>
        <access>protected</access>
        <Parameter name="_rtQueueTask" type="CM_RTQueueTask" usage="input"/>
        <Parameter name="_twinQueueTask" type="CM_RTQueueTask" usage="input"/>
        <Parameter name="_sideAccessDirection" type="Integer" usage="input"/>
        <Parameter name="_tandemLift" type="Boolean"/>
        <Parameter name="_errorMsgs" type="DTO_HandHeldGateErrorDict" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doAcceptTasks" id="177ecf8c-b286-43c5-9a52-3d653e6e5bf8">
        <updating/>
        <source>doAcceptTasks(_rtQueueTasks : CM_RTQueueTaskArray input;
				_sideAccessDirection : Integer input;
				_tandemLift	: Boolean;
				_errorMsgs : DTO_HandHeldGateErrorDict input) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date				Who		Reason
30 October 2009		cnwer1	Initial creation PAR 20701
10 Decemeber 2009	conkc1	Replay deadlocks
*/
vars
	rtQueueTask,
	twinRTQueueTask: CM_RTQueueTask;
	twinRTQueueEntry : CM_RTQueueEntry;
begin

	rtQueueTask:=_rtQueueTasks.first;
	if rtQueueTask = null then
		return;
	endif;
	if _rtQueueTasks.size &gt; 1 then
		twinRTQueueTask:=_rtQueueTasks[2];
	endif;
	// PAR 20338 18807
	app.myPassport.setupForDeadlockReplay(-100, 2000);

	while true do

		self.doAcceptTaskBody(rtQueueTask,twinRTQueueTask,_sideAccessDirection,_tandemLift, _errorMsgs);
		
		if app.myPassport.noTrxReplayAllowed() then	//15 Jan 2013	NDL	Par 30920
			break;
		endif;

	endwhile;

epilog
	process.setPersistentDeadlockPriority(0);
	app.myPassport.replayingDeadlocks := false;
end;</source>
        <Parameter name="_rtQueueTasks" type="CM_RTQueueTaskArray" usage="input"/>
        <Parameter name="_sideAccessDirection" type="Integer" usage="input"/>
        <Parameter name="_tandemLift" type="Boolean"/>
        <Parameter name="_errorMsgs" type="DTO_HandHeldGateErrorDict" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doActionCranePickup" id="a3a8bf81-b9f6-4c53-b445-8658a6f7e4ba">
        <source>doActionCranePickup(_ti, _twinTI: CM_TrackedItem input; _errorMsgs: DTO_HandHeldGateErrorDict input);
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 June 2010	cnwer1	Initial creation
15 Jan 2013	NDL	Par 30920 - code moved to doActionCranePickupBody, and dead lock handler added.

*/

vars

begin

	app.myPassport.setupForDeadlockReplay(-100, 2000);

	while true do

		self.doActionCranePickupBody(_ti, _twinTI, _errorMsgs );
		
		if app.myPassport.noTrxReplayAllowed() then	//15 Jan 2013	NDL	Par 30920
			break;
		endif;

	endwhile;

epilog
	process.setPersistentDeadlockPriority(0);
	app.myPassport.replayingDeadlocks := false;
end;
</source>
        <Parameter name="_ti" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_twinTI" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_errorMsgs" type="DTO_HandHeldGateErrorDict" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doActionCranePickupBody" id="be51a15a-d69c-46d2-ab68-6f0d330cf051">
        <source>doActionCranePickupBody(_ti: CM_TrackedItem input; 
						_twinTI: CM_TrackedItem input;
						_errorMsgs: DTO_HandHeldGateErrorDict input) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 January 2013	cnwndl1	Initial creation	Par 30920

*/

vars
	result	 : Boolean;
begin

	
	//epr par 35898 14/5/15 changed to pass in tis in the parameters

	while true do
		self.initialiseForNewRequest(_errorMsgs);
		
		//epr TFS 995 16/5/17 refactored
		app.myTrxUA.trxMachineCranePickup(self.myMachine,_ti, _twinTI, true, false, app.myPassport);
		
		//epr 8/6/10 CCMS 1099 refactoring 
		//app.myTrxRT.trxActionCranePickup(_ti, _twinTI, self.myMediator, true, false, null, app.myPassport);
		
		if app.myPassport.hadReplayableDeadlock() then	//15 Jan 2013	NDL	Par 30920
			break;
		endif;
		
		if app.myPassport.trxCompletedOK then
			break;
		endif;
		result:= self.createErrorsFromPassport(_errorMsgs);
		if result then
			break;
		else
			continue;
		endif;
	endwhile;

epilog
	
end;</source>
        <access>protected</access>
        <Parameter name="_ti" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_twinTI" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_errorMsgs" type="DTO_HandHeldGateErrorDict" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doActionDirectorTasks" id="89cbd11a-84a5-4387-953d-eea361bdf515">
        <updating/>
        <source>doActionDirectorTasks(_ti,
						_tiTwin: CM_TrackedItem ;
						_bbQuantity : Integer;
						_moveWeight : Decimal;
						_errorMsgs : DTO_HandHeldGateErrorDict input	) protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
26 April 2010	cnwer1	Initial creation
15 Jan 2013	NDL	Par 30920 - code moved to doActionDirectorTasksBody, and dead lock handler added.
14 Sep 2017 cnwer1	TFS 6863 changed to use objects instead of ids so break bulk works correctly
*/

vars

begin

	app.myPassport.setupForDeadlockReplay(-100, 2000);

	while true do

		self.doActionDirectorTasksBody(_ti, _tiTwin,_bbQuantity,_moveWeight, _errorMsgs );
		
		if app.myPassport.noTrxReplayAllowed() then	//15 Jan 2013	NDL	Par 30920
			break;
		endif;

	endwhile;

epilog
	process.setPersistentDeadlockPriority(0);
	app.myPassport.replayingDeadlocks := false;
end;</source>
        <access>protected</access>
