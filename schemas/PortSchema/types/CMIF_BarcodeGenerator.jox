*/

vars

begin
	delete self.myBarcodeGenerator;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="generatePDF417Barcode" id="8abef408-8050-4c01-a08b-d0276d261b17">
        <source>generatePDF417Barcode(_code : String) : Binary;
/*

Purpose:			Generate a PDF417 barcode from the passed in text, and return an image binary

Parameters:			Text to encode into the barcode

Return Value:		Binary image for loading into a printed control

Date		Who		Reason
29 Oct 2015	cnwkpd1	GPHA Cash Receipt Print
// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support

*/

vars
	result			: Boolean;
	imageFile		: File;
	filename		: String;
	returnValue		: Binary;
	
begin
	if self.myBarcodeGenerator &lt;&gt; null then
		if self.usePresentationClient then
			filename := app.getTempDir();
		else
			filename := app.getTempDirAppServer();
		endif;
		
		filename := filename &amp; app.actualTimeServer.getNumeralString &amp; "_" &amp; self.getInstanceIdForObject(process).String &amp; ".png";	// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support

		app.writeLog(method.qualifiedName &amp; " creating temporary file " &amp; filename, LogDEBUG);	//25 Nov 2019	NDL	TFS 47053
	
		result := self.myBarcodeGenerator.generatePDF417(_code.StringUtf8, 
														 0.1,
														 0.2,
														 6.8,
														 1.0,
														 7,
														 12,
														 0.25,
														 filename.StringUtf8);
		
		if result then
			create imageFile transient;
			imageFile.kind := File.Kind_Binary;
			imageFile.usePresentationFileSystem := self.usePresentationClient;
			
			imageFile.openInput(filename);
			
			returnValue := imageFile.readBinary(imageFile.fileLength);
			
			// Now delete the temporary file created by the .NET code
			app.writeLog(method.qualifiedName &amp; " deleting temporary file " &amp; filename, LogDEBUG);	//25 Nov 2019	NDL	TFS 47053
			imageFile.close();
			imageFile.purge();
			
			return returnValue;
		endif;
		
	endif;

epilog
	delete imageFile;

end;</source>
        <Parameter name="_code" type="String"/>
        <ReturnType type="Binary"/>
    </JadeMethod>
    <JadeMethod name="generateQRCode" id="7b2a9e89-87b9-44c6-b33c-877c2dee662a">
        <source>generateQRCode(_code : String) : Binary;
/*

Purpose:			Generate a QR Code from the passed in text, and return an image binary

Parameters:			Text to encode into the QR Code

Return Value:		Binary image for loading into a printed control

Date		Who		Reason
10 Mar 2016	cnwkpd1	TFS 1593 - Steinweg Oman Handheld for cars
// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
*/

vars
	result			: Boolean;
	imageFile		: File;
	filename		: String;
	returnValue		: Binary;
	
begin
	if self.myBarcodeGenerator &lt;&gt; null then
		if self.usePresentationClient then
			filename := app.getTempDir();
		else
			filename := app.getTempDirAppServer();
		endif;
		
		filename := filename &amp; app.actualTimeServer.getNumeralString &amp; "_" &amp; self.getInstanceIdForObject(process).String &amp; ".png";	// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support

		app.writeLog(method.qualifiedName &amp; " creating temporary file " &amp; filename, LogDEBUG);	//25 Nov 2019	NDL	TFS 47053
	
		result := self.myBarcodeGenerator.generateQRCode(_code.StringUtf8,
														 .5,
														 .5,
														 2,
														 2,
														 2,
														 2,
														 filename.StringUtf8);
		
		if result then
			create imageFile transient;
			imageFile.kind := File.Kind_Binary;
			imageFile.usePresentationFileSystem := self.usePresentationClient;
			
			imageFile.openInput(filename);
			
			returnValue := imageFile.readBinary(imageFile.fileLength);
			
			// Now delete the temporary file created by the .NET code
			app.writeLog(method.qualifiedName &amp; " deleting temporary file " &amp; filename, LogDEBUG);	//25 Nov 2019	NDL	TFS 47053
			imageFile.close();
			imageFile.purge();
			
			return returnValue;
		endif;
		
	endif;

epilog
	delete imageFile;

end;</source>
        <Parameter name="_code" type="String"/>
        <ReturnType type="Binary"/>
    </JadeMethod>
</Class>
