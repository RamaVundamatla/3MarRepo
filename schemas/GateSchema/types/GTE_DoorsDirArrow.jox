<GUIClass name="GTE_DoorsDirArrow" id="68632d26-c781-42c1-b62e-6826ad2da442">
    <superclass name="CMUI_Picture"/>
    <transient/>
    <sharedTransientAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="_usergui"/>
    <JadeMethod name="click" id="a34bd315-8d8b-4acd-9ef7-2a499bd43ef7">
        <updating/>
        <source>click(pict: Picture input) updating;
// ---------------------------------------------------------------------------
// Created:     11 April 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if self.parent.isKindOf(JadeMask) then
		self.parent.JadeMask.click(self.parent.JadeMask);
	endif;
	
end;</source>
        <Parameter name="pict" type="Picture" usage="input"/>
    </JadeMethod>
    <JadeMethod name="windowCreated" id="2e89afb6-36e2-47b1-b4b2-cfad0d46831e">
        <controlMethod name="Control::windowCreated"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>windowCreated(cntrl: Control input; persistCntrl: Control) updating, clientExecution;
// ---------------------------------------------------------------------------
// Created:     20 April 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	inheritMethod(cntrl, persistCntrl);
	
	cntrl.borderStyle	:= self.BorderStyle_None;

end;</source>
        <Parameter name="cntrl" type="Control" usage="input"/>
        <Parameter name="persistCntrl" type="Control"/>
    </JadeMethod>
