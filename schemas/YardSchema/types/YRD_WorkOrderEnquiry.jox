    <JadeMethod name="mnuUnApprove_click" id="46935f5d-8150-4cf9-b576-0bdb635c9e09">
        <controlMethod name="MenuItem::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mnuUnApprove_click(menuItem: MenuItem input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 Apr 2024 navhl20 ChangeRequest 63583: EUP | 54014 - Cargo Work Orders Enhancements - Remedial
24 Jun 2024 ChangeRequest 64770: EUP | 54014 - Cargo Work Orders Enhancements - Remedial - 1
*/

vars
	realWorkOrder 	: CM_WorkOrder;
	result			: Integer;
	job				: CM_Job;
begin
	if self.tblData.allSelectedObjects.isNotEmpty then
		realWorkOrder := self.tblData.allSelectedObjects.first.CM_WorkOrder;
	endif;
	
	if realWorkOrder &lt;&gt; null then
		
		job := realWorkOrder.getLinkedJob();				//24.06.2024 navhl20 #64770
		if job &lt;&gt; null then									//24.06.2024 navhl20 #64770
			if app.msgBox(app.getErrorString2(Selec_work_order_linke_with_jo,realWorkOrder.id,job.jobId), app.getErrorString(Confirm_unapprove), MsgBox_Question_Mark_Icon + MsgBox_Yes_No) = MsgBox_Return_No then
				return;
			endif;
		endif;
		
		app.mousePointer := MousePointer_HourGlass;
		
		while true do
			app.myTrxUA.trxWOUnApprove(realWorkOrder, app.myPassport);

			if app.myPassport.trxCompletedOK then
				return;
			else
				result := app.showErrorWarningDialog(self.caption, app.myPassport, ErrWarnMode_Add + ErrWarnMode_CanAckWarnings);
				if app.myPassport.noErrors and
				   result = IDOK then
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
			endif;

			return;
		endwhile;
	endif;
epilog
	app.mousePointer := MousePointer_Default;
end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
