		criteria := self.getAttrByType(YACriteriaType_IsFiftyThree); // PAR 23263 
		if criteria &lt;&gt; null then
			intValue := criteria.myYAData.CM_YADataBoolean.getDataValue().Integer;	//13 Apr 2015	NDL	Par 3603
			if intValue = CM_YADataBoolean.VALUE_FALSE then
				return false;
			elseif intValue = CM_YADataBoolean.VALUE_TRUE then
				return true;
			elseif intValue = CM_YADataBoolean.VALUE_EITHER then
				// do nothing here... try the other options
			endif;					
		endif;
		criteria := self.getAttrByType(YACriteriaType_ISOGroup); // PAR 23817 CHECK ISO GROUP
		if criteria &lt;&gt; null then
			//return criteria.myYAData.CM_YADataObjects.allObjects.first().CM_ISOTypeGroup.is53ftLong();								
			//cnwjo3 par 26153
			return self.getAttrCheckAllValuesCriteria(criteria.myYAData.CM_YADataObjects.allObjects,CM_ISOTypeGroup,CM_ISOTypeGroup::is53ftLong.name);
		endif;
		criteria := self.getAttrByType(YACriteriaType_ISO); // PAR 23817 CHECK ISO TYPE
		if criteria &lt;&gt; null then
			//return criteria.myYAData.CM_YADataObjects.allObjects.first().CM_ISOType.is53ftLong();								
			//cnwjo3 par 26153
			return self.getAttrCheckAllValuesCriteria(criteria.myYAData.CM_YADataObjects.allObjects,CM_ISOType,CM_ISOType::is53ftLong.name);
		endif;
	else
		return self.is53;
	endif;
	return false;

end;</source>
