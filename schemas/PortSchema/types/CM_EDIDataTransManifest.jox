    <JadeMethod name="getMessageType" id="54069d13-4bd5-4fe4-b9c6-36e61267bda7">
        <source>getMessageType(): String;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 29 September 2023
TFS#		: 60232
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/
begin
	if self.myCargoOnSite &lt;&gt; null then
		return self.type &amp; " (Unknown)";
	elseif self.myGateDocument &lt;&gt; null then
