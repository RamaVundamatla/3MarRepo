    <JadeMethod name="doPrintReport" id="9c28e574-0590-4e52-b865-1b78d5e73c50">
        <updating/>
        <source>doPrintReport():Boolean updating;
// --------------------------------------------------------------------------------
// Created:		01 April 2003 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
constants
	PAPER_SOURCE_CERT	: Integer = 262;
	
vars
	theUsedProduct		: JSSLKUsedProduct;
	theUsedComponent	: JSSLKUsedComponent;
	componentCount		: Integer;
	thePrinterDialog	: CMDPrint;
	allPaperSources		: IntegerArray;
	allSourceNames		: StringArray;
	printResult			: Integer;
	
begin
	theUsedProduct	:=	self.aMyUsedProduct;
	
	if theUsedProduct = null then
		app.msgBox("There is no Customer/Product to print a certificate for.", "Error", MsgBox_Exclamation_Mark_Icon + MsgBox_OK_Only);
		return false;
	elseif (not theUsedProduct.isLicensed) then
		app.msgBox("No license key has been generated for this Customer/Product.", "Error", MsgBox_Exclamation_Mark_Icon + MsgBox_OK_Only);
		return false;
	elseif theUsedProduct.isExpired() then
		app.msgBox("The license for this Customer/Product has expired.", "Error", MsgBox_Exclamation_Mark_Icon + MsgBox_OK_Only);
		return false;
	endif;
	
	// Let the user choose which printer they want to use.
	
	create thePrinterDialog transient;
	
	if thePrinterDialog.open &lt;&gt; 0 then
		return false;
	endif;
	
	on Exception do self.jssXHandler(exception);
	
	// Now setup other printer settings as appropriate.
	
	app.printer.title		:=	theUsedProduct.myProduct.productCode &amp; " Certificate";
	app.printer.leftMargin	:=	4;
	app.printer.orientation	:=	Print_Landscape;
	app.printer.topOfPage	:=	app.printer.topOfPage + 1;
	app.printer.copies		:=	1;
	
	create allPaperSources transient;
	create allSourceNames transient;
	app.printer.getAllPaperSources(allPaperSources, allSourceNames);
	
	if allPaperSources.includes(PAPER_SOURCE_CERT) then
		app.printer.paperSource	:=	PAPER_SOURCE_CERT;		// Stack bypass.
	endif;
	
	app.printer.printPreview	:=	true;
	
	// Now set up the certificate details.
	
	lblLicenseName.jssSet("License Name: " &amp; theUsedProduct.myCustomer.customerName);
	lblExpiryDate.jssSet("Expiry Date: " &amp; theUsedProduct.expiryDate.String);
	lblLicenseKey.jssSet("License Key: " &amp; theUsedProduct.licenseKey);
	lblProduct.jssSet("Product: " &amp; theUsedProduct.getProductName);
	lblVersion.jssSet("Version: " &amp; theUsedProduct.myProduct.productVersion);
	
	lblComponent1.jssSet(null);
	lblComponent2.jssSet(null);
	lblComponent3.jssSet(null);
	lblComponent4.jssSet(null);
	lblComponent5.jssSet(null);
	lblComponent6.jssSet(null);
	lblComponent7.jssSet(null);
	lblComponent8.jssSet(null);
	lblComponent9.jssSet(null);
	lblComponent10.jssSet(null);
	lblComponent11.jssSet(null);
	lblComponent12.jssSet(null);
	lblComponent13.jssSet(null);
	lblComponent14.jssSet(null);
	lblComponent15.jssSet(null);
	lblComponent16.jssSet(null);
	lblComponent17.jssSet(null);
	lblComponent18.jssSet(null);
	lblComponent19.jssSet(null);
	lblComponent20.jssSet(null);
	
	componentCount	:=	0;
	
	foreach theUsedComponent in theUsedProduct.allUsedComponents do
		componentCount	:=	componentCount + 1;
		
		if componentCount = 1 then
			lblComponent1.jssSet(theUsedComponent.myComponent.componentDescription);
		elseif componentCount = 2 then
			lblComponent2.jssSet(theUsedComponent.myComponent.componentDescription);
		elseif componentCount = 3 then
			lblComponent3.jssSet(theUsedComponent.myComponent.componentDescription);
		elseif componentCount = 4 then
			lblComponent4.jssSet(theUsedComponent.myComponent.componentDescription);
		elseif componentCount = 5 then
			lblComponent5.jssSet(theUsedComponent.myComponent.componentDescription);
		elseif componentCount = 6 then
			lblComponent6.jssSet(theUsedComponent.myComponent.componentDescription);
		elseif componentCount = 7 then
			lblComponent7.jssSet(theUsedComponent.myComponent.componentDescription);
		elseif componentCount = 8 then
			lblComponent8.jssSet(theUsedComponent.myComponent.componentDescription);
		elseif componentCount = 9 then
			lblComponent9.jssSet(theUsedComponent.myComponent.componentDescription);
		elseif componentCount = 10 then
			lblComponent10.jssSet(theUsedComponent.myComponent.componentDescription);
		elseif componentCount = 11 then
			lblComponent11.jssSet(theUsedComponent.myComponent.componentDescription);
		elseif componentCount = 12 then
			lblComponent12.jssSet(theUsedComponent.myComponent.componentDescription);
		elseif componentCount = 13 then
			lblComponent13.jssSet(theUsedComponent.myComponent.componentDescription);
		elseif componentCount = 14 then
			lblComponent14.jssSet(theUsedComponent.myComponent.componentDescription);
		elseif componentCount = 15 then
			lblComponent15.jssSet(theUsedComponent.myComponent.componentDescription);
		elseif componentCount = 16 then
			lblComponent16.jssSet(theUsedComponent.myComponent.componentDescription);
		elseif componentCount = 17 then
			lblComponent17.jssSet(theUsedComponent.myComponent.componentDescription);
		elseif componentCount = 18 then
			lblComponent18.jssSet(theUsedComponent.myComponent.componentDescription);
		elseif componentCount = 19 then
			lblComponent19.jssSet(theUsedComponent.myComponent.componentDescription);
		elseif componentCount = 20 then
			lblComponent20.jssSet(theUsedComponent.myComponent.componentDescription);
		endif;
	endforeach;
	
	while not app.printer.frameFits(fraCertificate) do
		fraCertificate.height	:=	fraCertificate.height - 1;
	endwhile;
	
	printResult	:=	app.printer.print(fraCertificate);
	
	if printResult = Print_Successful then
		app.printer.close();
	else
		app.printer.abort();
		app.msgBox(app.printer.jssTranslateConstant(printResult), "Print Error", MsgBox_Exclamation_Mark_Icon + MsgBox_OK_Only);
		
		return false;
	endif;
	
	return inheritMethod();
epilog
	delete allPaperSources;
	delete allSourceNames;
	delete thePrinterDialog;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setUsedProduct" id="11db59e1-ee3c-4cc8-898e-8b9ee578f837">
        <updating/>
        <source>setUsedProduct(pTheUsedProduct:JSSLKUsedProduct) updating;
// --------------------------------------------------------------------------------
// Created:		01 April 2003 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.aMyUsedProduct	:=	pTheUsedProduct;
end;</source>
        <Parameter name="pTheUsedProduct" type="JSSLKUsedProduct"/>
    </JadeMethod>
</GUIClass>
