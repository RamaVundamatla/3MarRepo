    <JadeMethod name="checkIfHeightExceeded" id="55aaae5e-11b5-4186-a265-5719eec3ce2d">
        <source>checkIfHeightExceeded(_theFrame : YRD_ContainerDrawingFrame io; _tmpNumTIs : Integer);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
05 November 2009	cnwphb1	Initial creation (PAR 21532 CCMS SFW 1025)

*/

vars
	newY1, newY2	: Real;
	obj				: Object;
	width, extra	: Integer;
	hghtExceedObj	: CMIF_YardHeightExceeded;
begin
	width := 2;
	// We will need 4 rows for the height exceeded line (2 for the solid line and 2 for the "arrows")
	newY1 := self.y1 - 5;	// Go up 5 lines so that we will leave 1 line between Red line and Stack
	newY2 := newY1 + 3;	
	// Check if a CMIF_YardHeightExceeded object exists for this Controller at this grid reference
	obj := self.gridObjectsGetAtKeyForPut(self.x1.Integer, newY1.Integer, self.x2.Integer, newY2.Integer);
	if obj &lt;&gt; null and
	   obj.isKindOf(CMIF_YardHeightExceeded) then
		hghtExceedObj := obj.CMIF_YardHeightExceeded;
	endif;
	
	extra := _tmpNumTIs - self.heightOfStack;
	if extra &gt; 0 then
		if hghtExceedObj = null then
			create hghtExceedObj transient;
			hghtExceedObj.myLocationsController := self.myLocationsController;
			hghtExceedObj.extraStackHeight := extra;
			self.allTransientsToDelete.add(hghtExceedObj);
			self.gridObjectsPutAtKey(self.x1.Integer, newY1.Integer, self.x2.Integer, newY2.Integer, hghtExceedObj);
			self.drawHeightExceededLine(_theFrame, newY2, Red, width);
		else
			// Check if the extra stack height is still correct
			if extra &lt;&gt; hghtExceedObj.extraStackHeight then
				hghtExceedObj.extraStackHeight := extra;
			endif;
		endif;
	elseif hghtExceedObj &lt;&gt; null then	// The Exceed Height no longer applies, so need to remove transient and collection entry
		self.allGridObjects.removeKeyEntry(self.x1.Integer, newY1.Integer, self.x2.Integer, newY2.Integer, hghtExceedObj);
		self.allTransientsToDelete.removeIfPresent(hghtExceedObj);
		delete hghtExceedObj;
		self.drawHeightExceededLine(_theFrame, newY2, _theFrame.backColor, width);
	endif;
epilog

end;</source>
        <Parameter name="_theFrame" type="YRD_ContainerDrawingFrame" usage="io"/>
        <Parameter name="_tmpNumTIs" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="constrainPointsToSelectBounds" id="3817e6d5-7754-4dc1-a18b-d7b97fb731fa">
        <source>constrainPointsToSelectBounds( _obj : Object; _x1, _y1, _x2, _y2 : Integer io ) : Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 Jan 2009	cnwjk3	Initial creation
04 May 2023	navdap1	TFS 57711 FR | 53485 EUP - Warehouse Yard Allocation - Satellite view location selection issues
*/

vars
	xy1, xy2	: Point;
	x1,y1,x2,y2 : Integer; 
	iter : Iterator;
	obj : Object;
	checkArray : ObjectArray;
	skipFirst : Boolean;			// TFS 57711
	ta : CM_IrregularBlockArea;		// TFS 57711
begin
	self.normaliseRectanglePoints(_x1,_y1,_x2,_y2);
	
	x1 := _x1; y1 := _y1; x2 := _x2; y2 := _y2;
	
	// TFS 57711 start
	if _obj.isKindOf(Collection) then
		if _obj.Collection.first.isKindOf(CM_IrregularBlockArea) then
			ta := _obj.Collection.first.CM_IrregularBlockArea;
			if _obj.Collection.size &lt; ta.allLocationsControllers.size and 
			self.getForm.getMyTerminal.getAutoPlanAllowFullGCArea then
				skipFirst := true;
			endif;
		endif;
	endif;
	// TFS 57711 end of this bit
	
	if _obj.isKindOf(Collection) then // PAR 34205
	/*	if self.getPointsForObject(_obj.Collection.first.Object, xy1, xy2) then // PAR 34205
			_x1 := xy1.x; // PAR 34205
			_y1 := xy1.y; // PAR 34205
			if self.getPointsForObject(_obj.Collection.last.Object, xy1, xy2) then // PAR 34205
				_x2 := xy2.x; // PAR 34205
				_y2 := xy2.y;	 // PAR 34205							
			endif;
		endif; */
		//13 May 2016	NDL TFS 1986/1909
		_x1 := _x2; _y1 := _y2; // so that if we started above and before it redraws at from the top left. 
		_x2 := 1; _y2 := 1; // so that if we have dragged bigger than the area it redraws to the max size needed.
		iter := _obj.Collection.createIterator;
		while iter.next( obj ) do
			if skipFirst and obj.isKindOf(CM_IrregularBlockArea) then	// TFS 57711
				continue;												// TFS 57711
			endif;														// TFS 57711
			self.getPointsForObject( obj, xy1, xy2 );
			if _x1 &gt; xy1.x then
				_x1 := xy1.x;
			endif;
			if _y1 &gt; xy1.y then
				_y1 := xy1.y;
			endif;
			if _x2 &lt; xy2.x then
				_x2 := xy2.x;
			endif;
			if _y2 &lt; xy2.y then
				_y2 := xy2.y;
			endif;
		endwhile;
		
		create checkArray transient;
		self.getSelectionBoundsForRect(_x1, _y1, _x2, _y2, checkArray, true);
		if checkArray.size &gt; _obj.Collection.size then
			self.constrainPointsToSelectBounds(checkArray,_x1, _y1, _x2, _y2);
		endif;
			
	else
		if self.getPointsForObject(_obj, xy1, xy2) then
			if _obj.isKindOf( CM_BlockStack ) or _obj.isKindOf( CM_IrregularBlockController ) then		
				_x1 := xy1.x;
				_y1 := xy1.y;
				_x2 := xy2.x;
				_y2 := xy2.y;								
			else
				if _x1 &lt; xy1.x then
					_x1 := xy1.x;
				endif;						
				if _y1 &lt; xy1.y then
					_y1 := xy1.y;
				endif;
				if _x2 &gt; xy2.x then
					_x2 := xy2.x;
				endif;						
				if _y2 &gt; xy2.y then
					_y2 := xy2.y;						
				endif;
			endif;
		endif;
	endif;
	
	// Indicate whether or not the points have been constrained
	return x1 &lt;&gt; _x1 or y1 &lt;&gt; _y1 or x2 &lt;&gt; _x2 or y2 &lt;&gt; _y2;
epilog
	delete iter;
	delete checkArray;
end;</source>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_x1" type="Integer" usage="io"/>
        <Parameter name="_y1" type="Integer" usage="io"/>
        <Parameter name="_x2" type="Integer" usage="io"/>
        <Parameter name="_y2" type="Integer" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
