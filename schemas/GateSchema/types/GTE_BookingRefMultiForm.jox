	multiRow := tblMain.getRowByName(ETRow_MultiItem);
	canEnable := self.myInterfaceBookingRef.allCMIF_BRItems.size &lt;= 1; 
	tblMain.accessRow(multiRow);
	tblMain.accessedRow.enabled := canEnable;
*/
end;</source>
