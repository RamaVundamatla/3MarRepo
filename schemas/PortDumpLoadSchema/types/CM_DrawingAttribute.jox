<Class name="CM_DrawingAttribute">
    <JadeMethod name="importPLXMLReference" id="a5f43a72-5a32-49f0-a845-51691d560c9d">
        <source>importPLXMLReference(_name, _theCode, _referencesBlock: String): Object;

vars

begin
	if _name = CM_DrawingAttribute::myRoot.name then
		return app.myRoot;
	else
		return null;
	endif;
end;</source>
