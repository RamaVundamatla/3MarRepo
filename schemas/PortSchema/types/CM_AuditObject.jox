    <JadeMethod name="setFromLocationActivityTemp" id="39f8f54b-8f69-48bc-8ef0-595fdc05b022">
        <updating/>
        <source>setFromLocationActivityTemp( _locAct : CMEVT_LocationActivity; _allAuditObjects : CM_AuditObjectDictByTimestamp input )updating;
/*

Purpose:			

Parameters:			Delete and use std auditing once the new version is available on production.
					See:  CMEVT_LocationActivity::createTemporaryAuditObject();

Return Value:		

Date		Who		Reason
06 May 2021	navndl1	Initial creation	TFS 50906

*/

vars

	prevAudit : CM_AuditObject;
	agent : CM_AuditAgent;
	deltaBeforeText  : String;
	deltaAfterText  : String;
	beforeText  : String;
	afterText : String;

begin

	self.timestamp := app.actualTimeServer;
	afterText := _locAct.getAuditText();
	self.subjectIdString := afterText;
	
	if not _locAct.getHasBeenEdited then
		self.type := AuditCreated;
		self.setAuditText( afterText );
		self.setPostAuditText(null);
	else
		prevAudit := _allAuditObjects.last;
		self.type := AuditUpdated;
		if prevAudit &lt;&gt; null then
			beforeText := prevAudit.subjectIdString;
		else
			beforeText := null;
		endif;
			
		create agent transient;
		if agent.doTextComparison( _locAct, beforeText, afterText, deltaBeforeText, deltaAfterText) then
			self.setAuditText( deltaBeforeText );
			self.setPostAuditText( deltaAfterText );
		else
			self.setAuditText( beforeText );
			self.setPostAuditText( afterText );
		endif;
	
	endif;
	
	self.setMyUser(app.getMyUser);
	if self.myUser &lt;&gt; null then
		self.userCode := self.myUser.code;
	else
		self.userCode := _locAct.userCode;
	endif;
	self.mySubject := _locAct;
	
	_allAuditObjects.addNoDuplicates( self, false );

epilog

	delete agent;

end;</source>
        <Parameter name="_locAct" type="CMEVT_LocationActivity"/>
        <Parameter name="_allAuditObjects" type="CM_AuditObjectDictByTimestamp" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setInfo" id="a18f5713-9c91-40d2-ad68-5e17e887eb87">
