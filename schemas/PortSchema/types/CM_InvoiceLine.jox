    <JadeMethod name="getTotalAmountInvConverted" id="f6020b62-a8b8-4781-a44b-67055dbefbcc">
        <source>getTotalAmountInvConverted() : Decimal;
/*

Purpose:			Gets the total amount converted to the currency code of the invoice

Parameters:			NONE

Return Value:		Decimal	Representing the total amount converted to the currency code

Date		Who		Reason
30 August 2022	navpw1	Initial creation TFS: 54564 (54377)

*/

vars
	effectiveDT : TimeStamp;

begin
	if self.invoice = null then
		return null;
		
	endif;
	
	if self.invoice.myCurrencyType = null then
		return null;
		
	endif;

	effectiveDT := self.invoice.getRateDateFromStatus(); //get rate date from the invocie to use for our method
	
	return self.getLineTotalConverted(self.invoice.myCurrencyType.getRate(effectiveDT));
	
end;</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
