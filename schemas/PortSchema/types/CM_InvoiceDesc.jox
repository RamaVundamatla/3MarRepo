    <JadeMethod name="canVoyageStatusMarinePre" id="2415c8da-3084-4a29-aaca-3c42fdac6b48">
        <source>canVoyageStatusMarinePre(_voyage : CM_Voyage) : Boolean;
/*

Purpose:		TFS 41539	

Parameters:			

Return Value:		

Date		Who		Reason
25 Oct 2018	jlgab1	Initial creation
10 OCt 2021 jlier1	TFS 51963 
*/

vars
	invoice : CM_Invoice;
	isopen : Boolean;
begin
	if _voyage= null then 
		return false;
	endif;
	
	if _voyage.myVoyageProcess = null then // UNIT TEST this is null
		return false;
	endif;

	//18 Feb 2019	NDL	TFS 43385 - now valid for all pelindo processes
	if not _voyage.myVoyageProcess.isMTNWOProcess() then 
		return false;
	endif;
	
	if _voyage.status.isOneOf(	Voyage_Status_ServPreInvGen, Voyage_Status_ServTaxInvGen, Voyage_Status_VesselArchived	) then
		return false;
	endif;
		
	
	foreach invoice in _voyage.allInvoices	discreteLock do
		if invoice.isMarineServiceInvoice() then
			if invoice.status = CM_Invoice.INVOICE_OPEN then
				isopen := true;
				break;
			endif;
		endif;
	endforeach;
	if not isopen then
		return true;
	endif;
	
	return false;
epilog

end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="canVoyageStatusMarineTax" id="20003ed2-f57e-4ed2-b13d-4fc65b334698">
        <source>canVoyageStatusMarineTax(_voyage : CM_Voyage) : Boolean;
/*

Purpose:		TFS 41539	

Parameters:			

Return Value:		

Date		Who		Reason
25 October 2018	jlgab1	Initial creation
10 OCt 2021 jlier1	TFS 51963
*/

vars
	invoice : CM_Invoice;
	isopen : Boolean;
begin
	if _voyage= null then 
		return false;
	endif;
	
	if _voyage.myVoyageProcess = null then // UNIT TEST this is null
		return false;
	endif;

	//18 Feb 2019	NDL	TFS 43385 - now valid for all pelindo processes
	if not _voyage.myVoyageProcess.isMTNWOProcess() then 
		return false;
	endif;
	
	if _voyage.status.isOneOf(	Voyage_Status_ServTaxInvGen, Voyage_Status_VesselArchived) then
		return false;
	endif;
	
		
	foreach invoice in _voyage.allInvoices	discreteLock do
		if invoice.isMarineServiceInvoice() then
			if invoice.status = CM_Invoice.INVOICE_OPEN 
			or invoice.status = CM_Invoice.INVOICE_DISPUTED 
			or invoice.status = CM_Invoice.INVOICE_PENDING_REVERSE   //31.10.2018 cnwma1 TFS #41703
			or invoice.status = CM_Invoice.INVOICE_POSTED_REVERSE then
				isopen := true;
				break;
			endif;
		endif;
	endforeach;
	if not isopen then
		return true;
	endif;
	
	return false;
epilog

end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="createMovementMinCharge" id="b4c56af1-7beb-45d8-ab84-566d769cdd4d">
        <source>createMovementMinCharge( _invLineSet : CM_InvoiceLineBySeqNumDict input;
						 _surChgExempt : CM_InvoiceTypeSurchargeExempt;
						 _voyage : CM_Voyage;
						 _effectiveDT : TimeStamp;
						 _conversionRate : CM_CurrencyRate;
						 _debtor : CM_Debtor;
						 _bank : CM_Bank;
						 _workOrder : CM_WorkOrder
						 );

/*

Purpose:			

Parameters:			

Return Value:		


Date			Who		Reason
26 March 2019	jlgndl1	Initial creation	TFS 43687
23 Oct 2024		navlw1	JIRA-33107: Invoice Logging Use Levels
25 Feb 2025	navah1	Story 34141: MTN - Performance Improvements - Review for invLog() Methods
*/

vars

	invLinesToProcess : CM_InvoiceLineSet;
	minGroupingsToProcess : CM_InvTypeGroupingMinChargeSet;
	invLine : CM_InvoiceLine;
	invLineType : CM_InvoiceLineDesc;
	movement : HMS_VoyageMovement;
	grpMinChg : CM_InvTypeGroupingMinCharge;
	desc : String;
	linesSubSet : CM_InvoiceLineBySeqNumDict;
	invSubSetTotal : Decimal [23,6];
	minChg : Real;
	rawDiff : Real;
	minChgInvLineType : CM_InvoiceLineDesc;
	diff : Real;
	remark : String;
	newLine : CM_InvoiceLine;
	seqNum : Integer;
	charge : CM_Charge;
	moveType : String;
	canLogExtra	: Boolean;	//27.02.2025 navah1	#34141

begin
	canLogExtra	:= app.canLogExtraDetail();				//27.02.2025 navah1	#34141
	if canLogExtra then	//27.02.2025 navah1	#34141
		app.invLog("Checking for Grouping Surcharges", LogINFO.String);
	endif;
	if _voyage = null then
		if canLogExtra then	//27.02.2025 navah1	#34141
			app.invLog("No Voyage", LogINFO.String);
		endif;
		return;
	endif;
	if _surChgExempt = null then
		if canLogExtra then	//27.02.2025 navah1	#34141
			app.invLog("No Surcharges found", LogINFO.String);
		endif;
		return;
	endif;
	if _surChgExempt.allInvTypeGroupingMinCharges.isEmpty then
		if canLogExtra then	//27.02.2025 navah1	#34141
			app.invLog("No " &amp; CM_Invoice.GrpMinCharge &amp; " found", LogINFO.String);
		endif;
		return;
	endif;
	if _invLineSet = null or _invLineSet.isEmpty then
		if canLogExtra then	//27.02.2025 navah1	#34141
			app.invLog("No Invoice Lines found", LogINFO.String);
		endif;
		return;
	endif;
	if _debtor = null then
		if canLogExtra then	//27.02.2025 navah1	#34141
			app.invLog("No Debtor", LogINFO.String);
		endif;
		return;
	endif;
	if _bank = null then
		if canLogExtra then	//27.02.2025 navah1	#34141
			app.invLog("No Bank", LogINFO.String);
		endif;
		return;
	endif;
	
	if _workOrder = null then
		if canLogExtra then	//27.02.2025 navah1	#34141
			app.invLog("No Work Order", LogINFO.String);
		endif;
		return;
	else
		if _workOrder.isWorkOrderForIMSR
		or _workOrder.isWorkOrderForExtension
		then
			moveType := app.getMoveTypeDescription(HMSMovementTypeArrival);
		elseif _workOrder.isWorkOrderForShift then
			moveType := app.getMoveTypeDescription(HMSMovementTypeShift);
		elseif _workOrder.isWorkOrderForDMSR then
			moveType := app.getMoveTypeDescription(HMSMovementTypeDeparture);
		else
			moveType := null;
		endif;
	endif;
	
	//Get a collection of the groupings we actually need to process for this invoice, and the invoice lines they match.
	create invLinesToProcess transient;
	create minGroupingsToProcess transient;
	
	foreach invLine in _invLineSet do
		invLineType := invLine.invoiceLineDesc;
		movement := _workOrder.getMyHMSVoyageMovement();
		grpMinChg := _surChgExempt.allInvTypeGroupingMinCharges.getGroupingFor( invLineType, movement, moveType );
		if grpMinChg &lt;&gt; null then
			//we found a matching grouping for this line, add it to teh collection
			invLinesToProcess.addNoDuplicates( invLine, false );
			minGroupingsToProcess.addNoDuplicates( grpMinChg, false );
		endif;
	endforeach;
	
	if minGroupingsToProcess.isEmpty or invLinesToProcess.isEmpty then
		if canLogExtra then	//27.02.2025 navah1	#34141
			app.invLog("No Matching " &amp; CM_Invoice.GrpMinCharge &amp; " found", LogINFO.String);
		endif;
		return;
	endif;
	
	//check that the lineType we would create is not also one that we should be checking for.
	//issue a warning if we do.
	if canLogExtra then	//27.02.2025 navah1	#34141
		foreach grpMinChg in minGroupingsToProcess do
			if minGroupingsToProcess.includesGrpForLineType( grpMinChg.getMinimumChargeInvLineType, desc ) then
				app.invLog( grpMinChg.getMinimumChargeInvLineType.narration &amp; " will be created by '" &amp; grpMinChg.description &amp; "' which is included in Matching Grouping Min Charges " &amp; desc, LogINFO.String);
			endif;
		endforeach;
	endif;
	
	create linesSubSet transient; // To use to hold the sub set of lines per Grouping.
	
	foreach grpMinChg in minGroupingsToProcess do
	
		linesSubSet.clear();
		grpMinChg.getMatchingLines( invLinesToProcess, linesSubSet, moveType ); // gets the sub set of lines that are relevant for this particular grouping.
		
		foreach invLine in linesSubSet discreteLock do
			invSubSetTotal := invSubSetTotal + invLine.getLineTotalConverted( _conversionRate );
		endforeach;
		
		minChg := grpMinChg.minimumChargeAmount;
		minChgInvLineType := grpMinChg.getMinimumChargeInvLineType;
		
		if _invLineSet.includesInvLineType( minChgInvLineType ) then
			if canLogExtra then	//27.02.2025 navah1	#34141
				app.invLog( grpMinChg.description &amp; " " &amp; CM_Invoice.GrpMinCharge &amp; " ignored, Invoice already includes an invoice line type of " &amp; minChgInvLineType.narration, LogINFO.String);
			endif;
		elseif invSubSetTotal &lt;= 0 then
			if canLogExtra then	//27.02.2025 navah1	#34141
				app.invLog( grpMinChg.description &amp; " " &amp; CM_Invoice.GrpMinCharge &amp; " ignored, Invoice Grouping Total = " &amp; invSubSetTotal.String, LogINFO.String);
			endif;
		elseif minChg &gt; invSubSetTotal then
			if canLogExtra then	//27.02.2025 navah1	#34141
				app.invLog("Creating Invoice line to meet " &amp; grpMinChg.description &amp; " " &amp; CM_Invoice.GrpMinCharge &amp; " ", LogINFO.String);
			endif;
			diff := minChg - invSubSetTotal;
			remark := "Invoice Grouping Total = " &amp; invSubSetTotal.String &amp; " " &amp; CM_Invoice.GrpMinCharge &amp; " = " &amp; minChg.String &amp; " Difference = " &amp; diff.String;
			if canLogExtra then	//27.02.2025 navah1	#34141
				app.invLog(remark, LogINFO.String); 
			endif;
			if minChgInvLineType.currencyConversionNotRequired or _conversionRate = null or _conversionRate.rate = 0 then
				// all good, no conversion needed, generate the line as is
			else
				// convert diff to other currency
				rawDiff := diff;
				diff := _conversionRate.convertBaseCurrencyToMe( rawDiff, 0 );	
				remark := remark &amp; " converted to " &amp; diff.String &amp; "( using " &amp; _conversionRate.getDisplayDetails(false) &amp; ")"; 
				if canLogExtra then	//27.02.2025 navah1	#34141
					app.invLog(remark, LogINFO.String);
				endif;
			endif;
			
			create newLine transient;
			seqNum := _invLineSet.getNextSeqNum( null );	//14 May 2019	NDL	TFS 43687
			newLine.setForCreate(	seqNum,
									true,
									remark,
									minChgInvLineType,
									null,
									_debtor,
									_bank,
									1,
									app.actualTimeServer()
									);
									
			create charge transient;
			charge.setForCreate(	null,
									newLine, 
									Max_Integer,
									null);
			charge.total := diff;
	
			_invLineSet.add( newLine );
		
		else
			if canLogExtra then	//27.02.2025 navah1	#34141
				app.invLog("Invoice Minimum Charge already exceeded", LogINFO.String);
			endif;
		endif; 	
		
		//remove the ones we just processed.
		foreach invLine in linesSubSet do
			invLinesToProcess.remove( invLine );
		endforeach;
		
		if invLinesToProcess.isEmpty then
			//nothing left to do here
			break;
		endif;
		
	endforeach;

epilog

	delete invLinesToProcess;
	delete minGroupingsToProcess;
	delete linesSubSet;

end;</source>
        <Parameter name="_invLineSet" type="CM_InvoiceLineBySeqNumDict" usage="input"/>
        <Parameter name="_surChgExempt" type="CM_InvoiceTypeSurchargeExempt"/>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_effectiveDT" type="TimeStamp"/>
        <Parameter name="_conversionRate" type="CM_CurrencyRate"/>
        <Parameter name="_debtor" type="CM_Debtor"/>
        <Parameter name="_bank" type="CM_Bank"/>
        <Parameter name="_workOrder" type="CM_WorkOrder"/>
    </JadeMethod>
