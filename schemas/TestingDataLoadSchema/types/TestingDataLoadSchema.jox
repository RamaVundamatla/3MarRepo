/*

Purpose:			

Parameters:			

Return Value:		


Date			Who		Reason
23 September 2011	cnwmh5	Initial creation

*/

vars
	returnVal				: Integer;
begin

	returnVal := Ex_Pass_Back;

	if _exception.errorCode = 8901 then
		returnVal := Ex_Resume_Next;	
	endif;

	return returnVal;
	
epilog

end;</source>
        <Parameter name="_exception" type="Exception"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
