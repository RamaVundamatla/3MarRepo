    <JadeMethod name="doCmd" id="caa12c96-f448-4e71-8fbe-565df456b1b0">
        <updating/>
        <executionLocation>server</executionLocation>
        <source>doCmd(cmd:String) updating, serverExecution;

vars
	result,cmdLog:String;
	i,j,retCode:Integer;
begin
	cmdLog := ' &gt;&gt; c:\thinbin\logs\doCmd_SumGen_' &amp; app.actualTimeAppServer.date.format("yyyyMMdd") &amp; '.log';
	node.createExternalProcess(null, 'cmd /c c:\cardinal\bin\datetime' &amp; cmdLog, null, null, true, true, retCode);
	node.createExternalProcess(null, 'cmd /c echo ' &amp; cmd &amp; cmdLog, null, null, true, true, retCode);
	node.createExternalProcess(null, 'cmd /c ' &amp; cmd &amp; cmdLog, null, null, true, true, retCode);
	result := cmd &amp; " retCode=" &amp; retCode.String &amp; " " &amp; process.userCode &amp; "@" &amp; process.userInfo;
	app.logMessage(result);
	addResults(result);
end;</source>
        <Parameter name="cmd" type="String"/>
    </JadeMethod>
    <JadeMethod name="doGo" id="31258ebd-0ad1-4092-a959-3de07df507a0">
        <updating/>
        <source>doGo() updating;

begin
	addResults(null);
	//doGoCreateJobChangeFile_orig;
	//doGoCreateJobFile_orig;
	doGoCreateJobFile;
end;</source>
    </JadeMethod>
    <JadeMethod name="doGoCreateJobChangeFile" id="fd18d097-dcdc-48fb-a800-cc8cda6b201c">
        <updating/>
        <source>doGoCreateJobChangeFile() updating;

vars
	folder,s,t,runid:String;
	i,j:Integer;
	ff:FileFolder;
begin
	s := txtRunid.text;
	if s.cnContains("\") then
		i := s.pos("\", 1);
		s := s[i+1:end];
	endif;
	uniqueId := cmbProduct.text &amp; '_'
			&amp; app.actualTimeAppServer.date.format('yyyyMMdd') &amp; '_'
			&amp; app.actualTimeAppServer.time.format('HHmmss') &amp; '_'
			&amp; s;
	create ff;
	folder := '\\cnwchcs118\t$\jblpcre\server\c_misc\configurationfiles';
	ff.usePresentationFileSystem := false;  // on Creator machine
	outputFile.mode := File.Mode_Output;
	ff.fileName := folder;
	if not ff.isAvailable then
		ff.make;
	endif;
	
	app.setEmailAddress;
	runid := app.actualTimeAppServer.date.format('yyyyMMdd')&amp; "_"  &amp; cmbRapHost.text[7:end] &amp; "\" &amp; txtRunid.text;
	outputFile.fileName := folder &amp; '\' &amp; uniqueId &amp; '.jobchg';
	outputFile.usePresentationFileSystem := ff.usePresentationFileSystem;
	outputFile.writeLine('&lt;uniqueid&gt;');
	outputFile.writeLine(uniqueId.asXML('name'));
	outputFile.writeLine(runid.asXML('runid'));
	outputFile.writeLine(cmbProduct.text.asXML('product'));
	outputFile.writeLine(("v:\AutoRunArchives\" &amp; cmbProduct.text &amp; "\" &amp; cmbArchive.text).asXML('archive'));
	outputFile.writeLine(cmbArchive.text[1:8].asXML('envid'));
	outputFile.writeLine(app.myEmailAddress.asXML('developeremail'));
	outputFile.writeLine(clientMachines.String.asXML('clientstostart'));
	outputFile.writeLine(cmbTotalRuns.text.asXML('baseruns'));
	outputFile.writeLine('&lt;/uniqueid&gt;');
	outputFile.close;
	
	outputFile.mode := File.Mode_Input;
	while not outputFile.endOfFile do
		addResults(outputFile.readLine);
	endwhile;
	outputFile.close;
	addResults(outputFile.fileName &amp; ' generated on ' &amp; app.computerNameAppServer.toLower);
epilog
	delete ff;
end;</source>
    </JadeMethod>
    <JadeMethod name="doGoCreateJobChangeFile_orig" id="29d68cbc-b0c4-4139-8291-cf823846e65c">
