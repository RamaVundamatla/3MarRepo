    <JadeMethod name="mnuCargoEnquiry_click" id="97521b1f-a5ed-4264-8ecc-43af381fb2f5">
        <controlMethod name="MenuItem::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mnuCargoEnquiry_click(menuItem: MenuItem input) updating;
/*
Purpose:			
Date		Who		Reason
10 June 2011	cnwab1	Initial creation
*/

vars
	theTIs : CM_TIArray;
begin
	if menuItem.userObject.isKindOf(CM_DeckItem) then
		create theTIs transient;
		//epr par 29898 28/6/12
		menuItem.userObject.CM_DeckItem.getAllTIs(REAL_MODE,theTIs, false);
		menuItem.userObject.CM_DeckItem.getAllTIs(PLANNING_MODE,theTIs, false);

		if not theTIs.isEmpty() then
			self.myAssistant.showCargoEnquiryForTIs(theTIs[1].CM_TrackedItem, theTIs, null, false);
		endif;
	
	endif;
epilog
	delete theTIs;
end;</source>
