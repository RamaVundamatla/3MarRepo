    <JadeMethod name="myCellularVesselStructure" id="e01a9a1c-71d9-42c3-9ef3-c5566e9933ae">
        <methodInvocation>mapping</methodInvocation>
        <source>myCellularVesselStructure(set : Boolean; _value : CM_CellularVesselStructure io) mapping;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
13 July 2011	cnwndl1	Initial creation	Par 27826

*/


vars

	alert: CM_SystemAlert;
	pc : ProcessStackArray;
	md : MethodCallDesc;
	meth : Method;
	str : String;
	fullStr : String;
	header : String;
	vessel : CM_Vessel;

begin

	if set then
		if not self.isTransient then
			if self.myCellularVesselStructure &lt;&gt; null and _value &lt;&gt; self.myCellularVesselStructure then
				// We have a real Vessel with an existing vessel structure and we are 
				// clearing it or we are replacing it with another one.
				// i.e. Where Par 27826 and Par24838 ended up with an orphan 
				// write out where we are..
				
				create pc transient;
				process.currentStack(pc);
				foreach md in pc do
					meth := md.method;
					str := md.display &amp; '  (' &amp; meth.class.name &amp; ')';
					if fullStr = null then
						fullStr := str;
					else
						fullStr := fullStr &amp; CrLf &amp; str;
					endif;
				endforeach;
				
				header := "CM_VesselStructure set to null on CM_Vessel";
				
				vessel := self;
				vessel.createAuditObjectInformation( header &amp; CrLf &amp; fullStr);
	
				create alert;
				alert.details := header;
				alert.addLogEntry(fullStr);
				alert.setSeverity(SEVERE_INFO);
				alert.add;
				app.commitAlert();
				
			endif;
		endif;
	endif;

epilog

	if pc &lt;&gt; null then
		pc.purge();
		delete pc;
	endif;
	
end;
</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="CM_CellularVesselStructure" usage="io"/>
    </JadeMethod>
    <JadeMethod name="operatorCode" id="f15d0f7d-386a-4be8-9d7c-3f6e79bf82b6">
