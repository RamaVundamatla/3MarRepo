<GUIClass name="CMUI_ComboCurrencySymbol" id="be1d696d-eddf-48ba-a995-94dd531e8f0f">
    <superclass name="CMUI_ComboBox"/>
    <transient/>
    <sharedTransientAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="_usergui"/>
    <JadeMethod name="init" id="3e0a6f5d-0171-4617-8038-9c8828050004">
        <updating/>
        <source>init() updating;
// ---------------------------------------------------------------------------
// Created:		23 July 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	idx : Integer;
begin
	self.clear();
	self.sorted := false;
	self.fontName := "Verdana";
	self.fontSize := 10;
	
	// The idx value now starts at 32 as the values before that just represent invalid characters that would not be used
	// 32 - 255 represents the extended ASCII table using the Windows-1252 encoding set. aka. ANSI
	foreach idx in 32 to 255 do // 2/11/2022   navcs2 ChangeRequest 54898
		
		self.addItemWithData( idx.Binary.ansiToString(),  idx); // 2/11/2022   navcs2 ChangeRequest 54898
		
		/*
		2/11/2022   navcs2 ChangeRequest 54898
		Removing this as no longer loops through the values these represent
		
		//26 Apr 2017	NDL	TFS 4203, 4204
		if idx.Character = Tab then
			self.itemText[idx] := "Tab";
			self.itemEnabled[idx] := false;
		elseif idx.Character = Lf then
			self.itemText[idx] := "Lf";
			self.itemEnabled[idx] := false;
		elseif idx.Character = Cr then
			self.itemText[idx] := "Cr";
			self.itemEnabled[idx] := false;
		endif;
		*/

	endforeach;
	
end;</source>
    </JadeMethod>
