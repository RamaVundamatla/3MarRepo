    <JadeMethod name="setForCreate" id="3449dd14-f833-48fd-8328-2c0536be06d2">
        <updating/>
        <source>setForCreate(_proxyVehicleMake : CM_VehicleMake) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 January 2013	cnwmc5	Initial creation HAT 2189

*/

vars

begin
	_proxyVehicleMake.raiseExceptionIfNotTransient(method);
	
	self.myDutyDocRoot := _proxyVehicleMake.myDutyDocRoot;
	self.setForUpdate(_proxyVehicleMake);
epilog

end;</source>
        <Parameter name="_proxyVehicleMake" type="CM_VehicleMake"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="600d7f3e-45f2-459f-9347-66d38369a17d">
