    <JadeMethod name="filterObjects" id="5622a671-5e14-46b9-8fd9-a8a1a940bd4f">
        <updating/>
        <source>filterObjects(_collection: Collection input; _passport: CM_Passport) updating;
/*
----------   ----------  --------------------------------------------------
Created:	23 July 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
----------   ----------  --------------------------------------------------

*/
vars
	terminal			: CM_Terminal;
	iter				: Iterator;
	eventByTypeDict 	: CM_EventTransByTypeDateTime;
	eventByDTDict 		: CM_EventTransByDateTime;
	eventType			: Integer;
	fromDT,
	toDT				: TimeStamp;
	breakOut			: Boolean;
begin

	//07 Jan 2020	NDL	TFS 47780
	if (not self.allQueryCriteriaHolders.isEmpty) then
		self.filterSelectorQuery(_collection, _passport);
		return;
	endif;
	
	self.needFilterEventTypes := (not self.allEventTypes.isEmpty) or (self.allEventTypes.size &gt;= app.myRoot.allEventTypesByType.size);
	self.needFilterUsers := (not self.allUsers.isEmpty) or (self.allUsers.size &gt;= app.myRoot.allUsers.size);
	
	fromDT.setDate(self.startDate);
	fromDT.setTime(self.startTime);
	
	if self.includeNoTerminal then
		//check root - only events with no terminal should be in this collection
		if self.needFilterEventTypes then
			eventByTypeDict := app.myRoot.allEventsByTypeDateTime;
			iter := eventByTypeDict.createIterator();
			foreach eventType in self.allEventTypes do
				eventByTypeDict.startKeyGeq(eventType, fromDT, iter);
				self.filterObjectsForTypeDT(_collection, eventType, eventByTypeDict, iter, breakOut, _passport);
				if breakOut then
					return;
				endif;
			endforeach;
		else
			eventByDTDict := app.myRoot.allEventsByDateTime;
			iter := eventByDTDict.createIterator();
			eventByDTDict.startKeyGeq(fromDT, iter);
			self.filterObjectsForDT(_collection, eventByDTDict, iter, breakOut, _passport);
			if breakOut then
				return;
			endif;
		endif;
	endif;
	
	//check through all selected terminals (if any)
	foreach terminal in self.allTerminals do
		delete iter;
		
		if self.needFilterEventTypes then
			eventByTypeDict := terminal.allEventsByTypeDateTime;
			iter := eventByTypeDict.createIterator();
			foreach eventType in self.allEventTypes do
				eventByTypeDict.startKeyGeq(eventType, fromDT, iter);
				self.filterObjectsForTypeDT(_collection, eventType, eventByTypeDict, iter, breakOut, _passport);
				if breakOut then
					return;
				endif;
			endforeach;
		else
			eventByDTDict := terminal.allEventsByDateTime;
			iter := eventByDTDict.createIterator();
			eventByDTDict.startKeyGeq(fromDT, iter);
			self.filterObjectsForDT(_collection, eventByDTDict, iter, breakOut, _passport);
			if breakOut then
				return;
			endif;
		endif;
	endforeach;
	
epilog
	delete iter;
	
end;




</source>
        <Parameter name="_collection" type="Collection" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="filterObjectsForDT" id="f2a57c3c-a25d-408d-a4cc-c6dfa345ea12">
        <updating/>
        <source>filterObjectsForDT(_collection		: Collection input;
				_eventByDTDict 	: CM_EventTransByDateTime; 
				_iter 			: Iterator input;
				_breakOut 		: Boolean output;
				_passport		: CM_Passport) updating, protected;
/*
----------   ----------  --------------------------------------------------
Created:	12 July 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
14/07/2025	naviv1	MTN-35226	MTN - Usage of Iterator.getCurrentKeys  		
----------   ----------  --------------------------------------------------
*/
vars
	eventTrans		: CM_EventTransaction;
	toDT			: TimeStamp;
	dtKey			: TimeStamp;
	testToDT		: Boolean;
begin
	toDT.setDate(self.endDate);
	toDT.setTime(self.endTime);
	
	testToDT := toDT &lt;&gt; null and toDT.isValid();
	
	while _iter.next(eventTrans) do : eventTransLoop
		_iter.getCurrentKeys(dtKey); //MTN-35226
		if (testToDT and dtKey &gt; toDT) then
			return;
		endif;
		
		if self.includesObject(eventTrans, _passport, _breakOut) then
			if not _collection.includes(eventTrans) then
				_collection.add(eventTrans);
			endif;
		endif;
		
		if _breakOut then
			return;
		endif;
	endwhile;

end;


</source>
        <access>protected</access>
        <Parameter name="_collection" type="Collection" usage="input"/>
        <Parameter name="_eventByDTDict" type="CM_EventTransByDateTime"/>
        <Parameter name="_iter" type="Iterator" usage="input"/>
        <Parameter name="_breakOut" type="Boolean" usage="output"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="filterObjectsForTypeDT" id="02960459-d80b-460f-a394-4563aa200486">
        <updating/>
        <source>filterObjectsForTypeDT(_collection	: Collection input;
					_eventType 		: Integer;
					_eventByTypeDict : CM_EventTransByTypeDateTime; 
					_iter 			: Iterator input;
					_breakOut 		: Boolean output;
					_passport 		: CM_Passport) protected, updating;
/*
----------   ----------  --------------------------------------------------
Created:	12 July 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
14/07/2025	naviv1	MTN-35226	MTN - Usage of Iterator.getCurrentKeys  		
----------   ----------  --------------------------------------------------
*/
vars
	eventTrans		: CM_EventTransaction;
	toDT			: TimeStamp;
	eventTypeKey	: Integer;
	dtKey			: TimeStamp;
	testToDT		: Boolean;
begin
	toDT.setDate(self.endDate);
	toDT.setTime(self.endTime);
	
	testToDT := toDT &lt;&gt; null and toDT.isValid();

	while _iter.next(eventTrans) do : eventTransLoop

		_iter.getCurrentKeys(eventTypeKey, dtKey); //MTN-35226
		if (eventTypeKey &lt;&gt; _eventType) or
		   (testToDT and dtKey &gt; toDT) then
			return;
		endif;
		
		if self.includesObject(eventTrans, _passport, _breakOut) then
			if not _collection.includes(eventTrans) then
				_collection.add(eventTrans);
			endif;
		endif;
		
		if _breakOut then
			return;
		endif;
	endwhile;

end;


</source>
        <access>protected</access>
        <Parameter name="_collection" type="Collection" usage="input"/>
        <Parameter name="_eventType" type="Integer"/>
        <Parameter name="_eventByTypeDict" type="CM_EventTransByTypeDateTime"/>
        <Parameter name="_iter" type="Iterator" usage="input"/>
        <Parameter name="_breakOut" type="Boolean" usage="output"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="filterSelectorQuery" id="d173e336-9fc0-4900-80ce-73439c10e061">
        <source>filterSelectorQuery(_collection  : Collection input;
					_passport : CM_Passport) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 January 2020	jlgndl1	Initial creation	TFS 47780

*/

vars
	criteriaHolder 		: CM_QueryCriteriaLineHolder;
	qDef				: CM_QueryDefinition;
	enqController		: CM_EnquiryController;
	queryAgent			: CM_QueryAgentFilter;

begin

	// Special one because we need the copy
	on CM_BreakOutException do app.myQAFilter.xHandlerBreakOut(exception);
	
	queryAgent := app.myQAFilter;
	if queryAgent = null then
		return;
	endif;
	
	qDef := app.myRoot.allQueryDefinitionObjects[CM_QueryDefinition.Transaction_Query_Type, self.selectorMode];
	queryAgent.createEnqControllerForMode(self.selectorMode, CM_QueryDefinition.Transaction_Query_Type, enqController);
	delete enqController.allObjects;
	create enqController.allObjects as _collection.class transient;
	
	foreach criteriaHolder in self.allQueryCriteriaHolders discreteLock do
		enqController.myCriteriaLineHolder := criteriaHolder;
		enqController.doQuery(qDef);
	endforeach;

	enqController.allObjects.copy(_collection);
	
epilog
	if enqController &lt;&gt; null then
		delete enqController.allObjects;
	endif;
	delete enqController;
end;</source>
        <access>protected</access>
        <Parameter name="_collection" type="Collection" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="dfde1c92-e44b-4733-98c3-b59bf032c733">
        <source>getDisplayStringForAttribute(_attrName: String; _getCalculatedDate: Boolean): String;
// ---------------------------------------------------------------------------
// Created:     19/07/2010 cnwdz2	
//
// Purpose:     PAR24513 extend the current existing getDisplayStringForAttribute method to return an object's oid.		 
// ----------   ----------  --------------------------------------------------
vars
	runDate	: Date;
	oid     : String;
begin
	return self.getOIDAndDescForAttribute(_attrName, _getCalculatedDate, oid);
	/*
	if _attrName = ETRow_AllEventTypes then
		return self.getEventTypesString();
	elseif _attrName = ETRow_AllUsers then
		return self.getUsersString();
	
	elseif _attrName = ETRow_DateFrom then
		if _getCalculatedDate then
			return self.setDateFromTemplate(self.startDateTplType, self.startDateTplFactor, runDate).shortFormatJMT();
		else
			return self.getTemplateDateStr(self.startDateTplType, self.startDateTplFactor);
		endif;
	
	elseif _attrName = ETRow_TimeFrom then
		if self.startTime.isValid then
			//return self.startTime.String;
			return self.startTime.asStringJMT();  //par 18944 cnwjo3
		else
			return '00:00';
		endif;
	
	elseif _attrName = ETRow_TimeTo then
		if self.endTime.isValid then
			//return self.endTime.String;
			return self.endTime.asStringJMT();  //par 18944 cnwjo3
		else
			return '00:00';
		endif;
		
	elseif _attrName = ETRow_DateTo then
		if _getCalculatedDate then
			return self.setDateFromTemplate(self.endDateTplType, self.endDateTplFactor, runDate).shortFormatJMT();
		else
			return self.getTemplateDateStr(self.endDateTplType, self.endDateTplFactor);
		endif;
	
	elseif _attrName = ETRow_FiltNoUser then
		return self.includeNoUser.cnEcGetTableCheckBoxValue();
	elseif _attrName = ETRow_FiltIncludeNoTerm then
		return self.includeNoTerminal.cnEcGetTableCheckBoxValue();
	endif;
		
	return inheritMethod(_attrName, _getCalculatedDate);

 */
end;


</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_getCalculatedDate" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getEventTypesString" id="d19051e6-ccb0-4b7c-a704-234b9278efda">
        <source>getEventTypesString(_oid : String output) : String protected;
/*
----------   ----------  --------------------------------------------------
Created:	24 July 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	eventTypeInt		: Integer;
	eventType			: CM_EventType;
	eventTypeDict		: CM_EventTypeByTypeDict;
	str					: String;
begin
	eventTypeDict := app.myRoot.allEventTypesByType;
	
	foreach eventTypeInt in self.allEventTypes do
		eventType := eventTypeDict[eventTypeInt];
		if eventTypeInt = self.allEventTypes.last then
			//_oid := _oid &amp; eventType.getOidAsString(); //21/07/2010 cnwdz2 24513
			_oid := _oid &amp; eventTypeInt.String; //28/08/2010 cnwdz2 24513 25524
			str := str &amp; eventType.name;
		else
			//_oid := _oid &amp; eventType.getOidAsString() &amp; ',';//21/07/2010 cnwdz2 24513
			_oid := _oid &amp; eventTypeInt.String &amp; ',';//25/08/2010 cnwdz2 24513 25524
			str := str &amp; eventType.name &amp; ',';
		endif;
	endforeach;
	if str = null then
		str := Any_String;
	endif;

	return str;
			
end;


</source>
        <access>protected</access>
        <Parameter name="_oid" type="String" usage="output"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getMyVoyage" id="ff9c5c4d-ca32-4b5b-9e6b-813d4ac49f9b">
        <source>getMyVoyage():CM_Voyage;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 July 2016	cnwndl1	Initial creation	TFS 2329

*/

vars

	voyage : CM_Voyage;
	edition : Integer;
	invalidObj : Boolean;

begin

	voyage := self.myVoyage;

	if voyage = null then
		return null;
	endif;
	
	on Exception do app.handleDeletedObject( exception, voyage, invalidObj );
	edition := voyage.edition;
	
	if invalidObj then
		return null;
	endif;
	
	return voyage;

epilog

end;</source>
        <ReturnType type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="getOIDAndDescForAttribute" id="22729def-ee9d-4929-9fc0-32822dd33a61">
        <source>getOIDAndDescForAttribute(_attrName: String; _getCalculatedDate: Boolean; _oid : String output): String;
// ---------------------------------------------------------------------------
// Created:     19/07/2010 cnwdz2	
//
// Purpose:     PAR24513 extend the current existing getDisplayStringForAttribute method to return an object's oid.		 
// ----------   ----------  --------------------------------------------------
vars
	runDate		: Date;
	
begin
	runDate := app.actualTimeServer().Date;	// 28/4/16 cnwmp6 TFS 488 - Multi timezone support
	
	if _attrName = ETRow_AllEventTypes then
		return self.getEventTypesString(_oid); //21/07/2010 cnwdz2 24513
	elseif _attrName = ETRow_AllUsers then
		return self.getUsersString(_oid); //21/07/2010 cnwdz2 24513
	
	elseif _attrName = ETRow_DateFrom then
		if _getCalculatedDate then
			return self.setDateFromTemplate(self.startDateTplType, self.startDateTplFactor, runDate).shortFormatJMT();
		else
			return self.getTemplateDateStr(self.startDateTplType, self.startDateTplFactor);
		endif;
	
	elseif _attrName = ETRow_TimeFrom then
		if self.startTime.isValid then
			//return self.startTime.String;
			return self.startTime.asStringJMT();  //par 18944 cnwjo3
		else
			return '00:00';
		endif;
	
	elseif _attrName = ETRow_TimeTo then
		if self.endTime.isValid then
			//return self.endTime.String;
			return self.endTime.asStringJMT();  //par 18944 cnwjo3
		else
			return '00:00';
		endif;
		
	elseif _attrName = ETRow_DateTo then
		if _getCalculatedDate then
			return self.setDateFromTemplate(self.endDateTplType, self.endDateTplFactor, runDate).shortFormatJMT();
		else
			return self.getTemplateDateStr(self.endDateTplType, self.endDateTplFactor);
		endif;
	
	elseif _attrName = ETRow_FiltNoUser then
		return self.includeNoUser.cnEcGetTableCheckBoxValue();
	elseif _attrName = ETRow_FiltIncludeNoTerm then
		return self.includeNoTerminal.cnEcGetTableCheckBoxValue();
	endif;
		
	return inheritMethod(_attrName, _getCalculatedDate, _oid);


end;


</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_getCalculatedDate" type="Boolean"/>
        <Parameter name="_oid" type="String" usage="output"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getUsersString" id="289a6347-a4bf-41fa-bd34-dfa61b44e89a">
        <source>getUsersString(_oid:String output) : String protected;
/*
----------   ----------  --------------------------------------------------
Created:	24 July 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	user				: CM_User;
	userDict			: CM_UserByCodeDict;
	str					: String;
begin
	
	foreach user in self.allUsers do
		if user = self.allUsers.last then
			_oid := _oid &amp; user.getOidAsString();//21/07/2010 cnwdz2 24513
			str := str &amp; user.code;
		else
			_oid := _oid &amp; user.getOidAsString() &amp; ',';//21/07/2010 cnwdz2 24513
			str := str &amp; user.code &amp; ',';
		endif;
	endforeach;
	
	if str = null then
		str := Any_String;
	endif;
	
	return str;
			
end;





</source>
        <access>protected</access>
        <Parameter name="_oid" type="String" usage="output"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="includesObject" id="4e6c778e-4b84-48af-8c04-5b28e662c46a">
        <updating/>
        <source>includesObject(_eventTrans 	: CM_EventTransaction; 
				_passport	: CM_Passport; 
				_breakOut	: Boolean output): Boolean updating, protected;
/*
----------   ----------  --------------------------------------------------
Created:	23 July 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	failedDAC			: CM_DataAccessController;
	booking : CMEVT_BookingRefDiscrep;
begin
	//th2  PAR 14966
	if (not _eventTrans.canUserAccessSubject(app.myPassport.myUser, failedDAC, _passport)) then
		return false;
	endif;
	
	if not self.includeNoUser then
		if _eventTrans.userCode = null then
			return false;
		endif;
	endif;
	
	if self.needFilterUsers then
		if self.allUsers[_eventTrans.userCode] = null then
			return false;
		endif;
	endif;
	
	//04 sep 2009	NDL	CCMS 1609 Par 20521
	//vvvvv
	if self.state &gt; 0 then
		if _eventTrans.getState &lt;&gt; self.state then
			return false;
		endif;
	endif;
	
	if self.getMyVoyage &lt;&gt; null then
		if  not _eventTrans.isForVoyage(self.getMyVoyage) then
			return false;
		endif;
	endif;
	
	if self.getMyCargoType &lt;&gt; null then
		if  not _eventTrans.isForCargoType(self.getMyCargoType.CM_CargoType) then
			return false;
		endif;
	endif;
	
	if self.myOperator &lt;&gt; null then
		if not _eventTrans.isForOperator(self.myOperator) then
			return false;
		endif;
	endif;
	
	if self.cargoId &lt;&gt; null then
		if not _eventTrans.hasCargoId( self.cargoId ) then
			return false;
		endif;
	endif;
	
	if self.bookingRef &lt;&gt; null then
		if not _eventTrans.hasBookingRef( self.bookingRef ) then
			return false;
		endif;
	endif;
	//^^^^^
	
	return true;

end;


</source>
        <access>protected</access>
        <Parameter name="_eventTrans" type="CM_EventTransaction"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <Parameter name="_breakOut" type="Boolean" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setFromTemplate" id="48476465-4ca4-4f57-9723-661dbe359917">
        <updating/>
        <source>setFromTemplate(_obj: CMQF_FilterReports; _runDate: Date; _allEventData: CM_EventDataByTypeDict) updating;
/*

Date		Who		Reason
10 September 2014	cnwer1	Initial creation PAR 34813

*/

vars
	eventData : CM_EventDataVoyage;

begin
	inheritMethod(_obj, _runDate, _allEventData);
	
	// This code sets the voyage for event driven schedules.
	// Have to do this for each appropriate class because they have different myVoyage references.
	eventData := _allEventData[EventDataVoyage].CM_EventDataVoyage;
	if eventData &lt;&gt; null and eventData.myVoyage &lt;&gt; null then
		self.setMyVoyage( eventData.myVoyage );
	endif;

epilog

end;</source>
        <Parameter name="_obj" type="CMQF_FilterReports"/>
        <Parameter name="_runDate" type="Date"/>
        <Parameter name="_allEventData" type="CM_EventDataByTypeDict"/>
    </JadeMethod>
    <JadeMethod name="setMyVoyage" id="dd41a13d-bd1d-4e03-ac38-9dc66eb7bdfc">
        <updating/>
        <source>setMyVoyage( _voyage : CM_Voyage ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 July 2016	cnwndl1	Initial creation	TFS 2329

*/

vars

begin

	self.myVoyage := _voyage;

epilog

end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
    </JadeMethod>
</Class>
