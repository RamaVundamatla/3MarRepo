    <JadeMethod name="handleBtnOne" id="7a71e277-75eb-4f64-9e5b-08fec6642344">
        <updating/>
        <source>handleBtnOne() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 January 2010	cnwndl1	Initial creation	CCMS MES 1005
15/12/2016 cnwns1 TFS 2867:PKT - Bulk Process - WeighBridge Integration
*/

vars

begin
	//user clicked 'Complete'
	
	//15/12/2016 cnwns1 TFS 2867:PKT - Bulk Process - WeighBridge Integration
    if	self.myMobileGenericAgent.myTruck.getCurrentVisit.isBulkGateVVR() then
		app.raiseCMException1(Vehicle_visit_Bulk_Only,app.getErrorString(Bulk_gate_out),"wrongGate", null);
		//err you cant process bulk gate job here
		return;
	endif;
	
	if not self.doComplete() then
		return;
	endif;
	
	//now return to the previous form.
	self.myMobileGenericAgent.setGateAreaLaneController( null, true );
	
	self.myMobileGenericAgent.allCargoCheckItemSelections.purge;	//28 May 2010	NDL	Par 23698
	self.doBackButtonClick();

epilog
	
end;</source>
        <access>protected</access>
    </JadeMethod>
