    <JadeMethod name="trxDeleteDamagePosition" id="c3c41beb-cb88-448b-9cf4-f21b3329d927">
        <updating/>
        <source>trxDeleteDamagePosition(_damagePosition : CM_DamagePosition io; _passport : CM_Passport input) updating;
//----------------------------------------------------------------------
//  Created by cnwsh3
//	Date 07 July 2009
//
// Implemented version: 7.7.3
// CCMS SFW1066  - Recording Damage Details Changes.
//----------------------------------------------------------------------
vars

begin
