    <JadeMethod name="initializeMe" id="2162fe5f-27c1-4ab4-add1-fe9803be2bbb">
        <updating/>
        <source>initializeMe(pTheDictionary:JSSWordDictionary; pName:String) updating; 
// --------------------------------------------------------------------------------
// Created:		04 September 2002 by cnwdad1
//
// Parameters:	This method created by JediMethodGenerator at 17:00:46 on 07 June 2001
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	// Validation

	self.validateMe(pTheDictionary, pName);

	// Attributes (Non Keys)


	// Attributes (Keys)

	self.wordName := 	pName;
	setSoundex();
	setMetaphone();

	// Singleton References

	self.myDictionary	:= 	pTheDictionary;
end;</source>
        <Parameter name="pTheDictionary" type="JSSWordDictionary"/>
        <Parameter name="pName" type="String"/>
    </JadeMethod>
    <JadeMethod name="setMetaphone" id="b428c22c-7a00-4202-a352-70206bae807a">
        <updating/>
        <source>setMetaphone() updating, protected;
// --------------------------------------------------------------------------------
// Created:		04 September 2002 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theMetaphone	: JSSMetaphone;
	
begin
	create theMetaphone transient;
	theMetaphone.updateMe(self.wordName);
	self.metaphoneName	:=	theMetaphone.getTransform(5);
epilog
	delete theMetaphone;	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setSoundex" id="4ed08ee9-e9f2-4181-96a1-73092e097c6e">
        <updating/>
        <source>setSoundex() updating, protected;
// --------------------------------------------------------------------------------
// Created:		04 September 2002 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theSoundex	: JSSSoundex;
	
begin
	create theSoundex transient;
	theSoundex.updateMe(self.wordName);
	self.soundexName	:=	theSoundex.getTransform(5);
epilog
	delete theSoundex;	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="updateMe" id="4385618c-6be2-4d15-b26f-56a019d6e4ab">
        <updating/>
        <source>updateMe(pTheDictionary:JSSWordDictionary; pName:String):String updating;
// --------------------------------------------------------------------------------
// Created:		04 September 2002 by cnwdad1
//
// Purpose:		This method created by JediMethodGenerator at 17:00:46 on 07 June 2001
//				Please add any validation required then delete this comment.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	// Validation

	self.validateMe(pTheDictionary, pName);

	// Attributes (Non Keys)


	// Attributes (Keys)

	if self.wordName &lt;&gt; pName then
		self.wordName	:=	pName;
		setSoundex();
		setMetaphone();
	endif;

	// Singleton References

	if self.myDictionary &lt;&gt; pTheDictionary then
		self.myDictionary	:=	pTheDictionary;
	endif;
	
	return null;
end;</source>
        <Parameter name="pTheDictionary" type="JSSWordDictionary"/>
        <Parameter name="pName" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="validateMe" id="4d60f213-5a5d-4c46-81be-bb947dfbd0dd">
        <updating/>
        <source>validateMe(pTheDictionary:JSSWordDictionary; pName:String) updating, protected;
// --------------------------------------------------------------------------------
// Created:		04 September 2002 by cnwdad1
//
// Purpose:		This method created by JediMethodGenerator at 17:00:46 on 07 June 2001
//				Please add any validation required then delete this comment.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	errorMessage	: String;
	attribLength	: Integer;

begin
	// Validation

	attribLength	:=	self.class.jssGetStringPropertyLength("wordName");
	
	if attribLength &gt; 0 and attribLength &lt; pName.length then
		errorMessage	:=	errorMessage &amp; pName &amp; " - text too long.  ";
	endif;
/*
	if someValue = null then
		errorMessage := errorMessage &amp; 'Some reason for the error.  ';
	endif;
*/
epilog
	if errorMessage &lt;&gt; null then
		JSSException.raise_(JSS_X_03005, errorMessage); 
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="pTheDictionary" type="JSSWordDictionary"/>
        <Parameter name="pName" type="String"/>
    </JadeMethod>
