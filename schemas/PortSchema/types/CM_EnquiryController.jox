    <PrimAttribute name="numItemsFoundLimit" id="1d94ee6f-0b2e-4e06-8df8-abce3dd42b1d">
        <embedded/>
        <type name="Integer"/>
        <text>It is used with breakOutOfSearch together.
This is the limit for numItemsFound, i.e. the limit for items to be populated in a result table. 
For example, queries for Drivers RT Thin Client.</text>
    </PrimAttribute>
    <PrimAttribute name="numItemsSearched" id="f60cd5f1-d9b5-4478-b029-e48b32049d4a">
