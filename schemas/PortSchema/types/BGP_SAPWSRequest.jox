    </JadeMethod>
    <JadeMethod name="processSAPDataTPP" id="8ec8e027-67ff-43c8-bec3-e0f2c8afdf00">
        <source>processSAPDataTPP():Boolean protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 Dec 2018	cnwma1	ChangeRequest 42036: PEL1 - SAP TPP Report
12/06/2024	navcs2	MTN-34987 MTN -  Disable SAP Integration

*/
constants
	EntityCode	: String = "TPP FTP";
vars
	tpp 		: CMIF_TPP;
	tppArr 		: CMIF_TPPArray;
	fileName 	: String;
	file 		: File;
	path        : String;
	ts          : TimeStamp;
	doFtp		: Boolean;
	ftp			: CnFtp;
	ftpEntity	: CM_FTPEntity;
	result		: String;
	resultInt	: Integer;
begin
	// No longer used 12/06/2024	navcs2	MTN-34987 MTN -  Disable SAP Integration

	return false;
	/*
	if  self.myTerminal= null then    
		return true;
	endif;
	
	if not  self.myTerminal.isSapPerformanceEnabled then
		return true;
	endif;
	
	ts := app.actualTimeServer;  
	path := self.directoryPath.normaliseDirectory().substituteDirectory();
	delete tppArr;
	create tppArr transient;

	doFtp := true;
	ftpEntity := app.myRoot.allFTPEntities[EntityCode];
	if ftpEntity = null then
		app.writeLog(method.qualifiedName() &amp; " FTP entity " &amp; EntityCode &amp; " not found", LogINFO);
		doFtp := false;
	endif;

	if doFtp then
		create ftp transient;
		ftp.setServerName(ftpEntity.getServerNameForConnect());
		ftp.portNumber := ftpEntity.getPortNumberForConnect();
		ftp.setServerType(ftpEntity.serverType);
		ftp.setUseProxy(ftpEntity.useProxy);
		ftp.setUserId(ftpEntity.userId, ftpEntity.getPwForUse(null));
		ftp.setServerGMTBias(ftpEntity.serverGMTBias);
		ftp.passive := ftpEntity.isPassive;
		ftp.setModeAscii(ftpEntity.mode.Boolean);
		result := ftp.cnConnect();
		if result &lt;&gt; CN_OK then
			app.writeLog(method.qualifiedName() &amp; " FTP error connecting to " &amp; ftp.serverName &amp; ": " &amp; result, LogINFO);
			doFtp := false;
		else
			if ftpEntity.destinationDirectory &lt;&gt; null then
				resultInt := ftp.emFtpSetCurrentDirectory(ftp.connectionHandle, ftpEntity.destinationDirectory);
				if resultInt &lt;&gt; 0 then
					app.writeLog(method.qualifiedName() &amp; " Unable to set current directory on FTP site to " &amp; ftpEntity.destinationDirectory &amp; ". " &amp; ftp.cnGetInternetError(resultInt), LogINFO);
				endif;
			endif;
		endif;

		ftp.setServerName(ftpEntity.getServerNameForConnect());
		ftp.portNumber := ftpEntity.getPortNumberForConnect();
		ftp.setServerType(ftpEntity.serverType);
		ftp.setUseProxy(ftpEntity.useProxy);
		ftp.setUserId(ftpEntity.userId, ftpEntity.getPwForUse(null));
		ftp.setServerGMTBias(ftpEntity.serverGMTBias);
		ftp.passive := ftpEntity.isPassive;
		ftp.setModeAscii(ftpEntity.mode.Boolean);
	endif;

		// Kappal
	tppArr.clear();
	self.myTerminal.getSapTPP(tppArr,"KAPAL");
	//fileName := self.myTerminal.code &amp; ts.Date.year.String &amp;ts.Date.month.padLeadingWith("0",2) &amp; "Kapal.csv";
	fileName := self.myTerminal.code &amp; ts.Date.year.String &amp;ts.Date.month.padLeadingWith("0",2) &amp; ts.Date.day().padLeadingWith("0",2) &amp; "Kapal.csv";
	create file;
	file.mode := File.Mode_Output;
	file.shareMode := File.Share_Exclusive;
	file.kind := File.Kind_Unknown_Text;
	file.fileName := path &amp; fileName; 
	file.open;
	self.createFileKapal(file,tppArr);
	file.close;
	//self.doFtpFile(file);
	if doFtp then
		result := ftp.cnPutFile(file.fileName, file.fileName, false, false);
		if result = CN_OK then
			app.writeLog(method.qualifiedName() &amp; " File " &amp; file.fileName &amp; " transferred to " &amp; ftpEntity.serverName, LogINFO);
			file.emDeleteFile(file.fileName);
		else
			app.writeLog(method.qualifiedName() &amp; " FTP transfer error: " &amp; result, LogINFO);
		endif;
	endif;
	delete file;
	
	
	//Barrang
	tppArr.clear();
	self.myTerminal.getSapTPP(tppArr,"BARANG");
	//fileName := self.myTerminal.code &amp; ts.Date.year.String &amp;ts.Date.month.padLeadingWith("0",2) &amp; "Barrang.csv";
	fileName := self.myTerminal.code &amp; ts.Date.year.String &amp;ts.Date.month.padLeadingWith("0",2) &amp; ts.Date.day().padLeadingWith("0",2) &amp; "Barang.csv";
	create file;
	file.mode := File.Mode_Output;
	file.shareMode := File.Share_Exclusive;
	file.kind := File.Kind_Unknown_Text;
	file.fileName := path &amp; fileName; 
	file.open;
	self.createFileBarang(file,tppArr);
	file.close;
//	self.doFtpFile(file);
	if doFtp then
		result := ftp.cnPutFile(file.fileName, file.fileName, false, false);
		if result = CN_OK then
			app.writeLog(method.qualifiedName() &amp; " File " &amp; file.fileName &amp; " transferred to " &amp; ftpEntity.serverName, LogINFO);
			file.emDeleteFile(file.fileName);
		else
			app.writeLog(method.qualifiedName() &amp; " FTP transfer error: " &amp; result, LogINFO);
		endif;
	endif;
	delete file;
	
	
	//Produksi
	tppArr.clear();
	self.myTerminal.getSapTPP(tppArr,"PRODUKSI");
	fileName := self.myTerminal.code &amp; ts.Date.year.String &amp;ts.Date.month.padLeadingWith("0",2) &amp; ts.Date.day().padLeadingWith("0",2) &amp; "Produksi.csv";
	create file;
	file.mode := File.Mode_Output;
	file.shareMode := File.Share_Exclusive;
	file.kind := File.Kind_Unknown_Text;
	file.fileName := path &amp; fileName; 
	file.open;
	CMIF_TPP@addFileProductionHeader(file);
	foreach tpp in tppArr discreteLock do
		tpp.addFileProductionLine(file);
	endforeach;
	file.close;
//	self.doFtpFile(file);
	if doFtp then
		result := ftp.cnPutFile(file.fileName, file.fileName, false, false);
		if result = CN_OK then
			app.writeLog(method.qualifiedName() &amp; " File " &amp; file.fileName &amp; " transferred to " &amp; ftpEntity.serverName, LogINFO);
			file.emDeleteFile(file.fileName);
		else
			app.writeLog(method.qualifiedName() &amp; " FTP transfer error: " &amp; result, LogINFO);
		endif;
	endif;
	delete file;
	
	
	//REVENUE
	tppArr.clear();
	self.myTerminal.getSapTPP(tppArr,"REVENUE");
	fileName := self.myTerminal.code &amp; ts.Date.year.String &amp;ts.Date.month.padLeadingWith("0",2) &amp; ts.Date.day().padLeadingWith("0",2) &amp; "Revenue.csv";
	create file;
	file.mode := File.Mode_Output;
	file.shareMode := File.Share_Exclusive;
	file.kind := File.Kind_Unknown_Text;
	file.fileName := path &amp; fileName; 
	file.open;
	CMIF_TPP@addFileRevenueHeader(file);
	foreach tpp in tppArr discreteLock do
		tpp.addFileRevenueLine(file);
	endforeach;
	file.close;
//	self.doFtpFile(file);
	if doFtp then
		result := ftp.cnPutFile(file.fileName, file.fileName, false, true);
		if result = CN_OK then
			app.writeLog(method.qualifiedName() &amp; " File " &amp; file.fileName &amp; " transferred to " &amp; ftpEntity.serverName, LogINFO);
			file.emDeleteFile(file.fileName);
		else
			app.writeLog(method.qualifiedName() &amp; " FTP transfer error: " &amp; result, LogINFO);
		endif;
	endif;
	delete file;
	
	if ftp &lt;&gt; null then
		ftp.cnCloseConnection();
	endif;
	return true;
epilog
	delete ftp;
	delete file;
	delete tppArr;
	*/
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="processSAPGetExchangeRate" id="ec22ffcc-8224-43d7-950d-b863936b1ebb">
        <source>processSAPGetExchangeRate(_agent : CM_SAPWSConsumerAgent input) : Boolean protected;
/*

Purpose:			
	37189.008 Request Exchange Rate
	WSDL 1.8: Foreign Exchange Rate - Get Exchange Rate
Parameters:			

Return Value:		

Date		Who		Reason7
19 Jun 2018 cnwma1	ChangeRequest 38637: PEL1 - SAP Request Exchange Rate

*/

vars
	request			: CMIF_SAPGetExchRateReq;
	response		: CMIF_SAPGetExchRateResp;
	checkDate,
	earliestDate	: Date;
	fromCurr,
	toCurr			: CM_CurrencyType;
	rate			: CM_CurrencyRate;
	pxyCurrencyRate,
	realCurrencyRate : CM_CurrencyRate;	
	msg              : String;
begin
	
	fromCurr := app.myRoot.allCurrencyTypes[self.fromCurrency];
	if fromCurr = null then
		app.writeLog(method.qualifiedName &amp; " From Currency " &amp; self.fromCurrency &amp; " not found",LogINFO);
		return true;
	endif;
	

	// Start checking from tomorrow backwards
	checkDate := app.actualTimeServer().date;
	earliestDate := checkDate - self.daysLookback ;
	
	while (checkDate &gt;= earliestDate) do
		if fromCurr.allCurrencyRates[checkDate.TimeStamp] &lt;&gt; null then
			msg := method.qualifiedName &amp; " rate found for " &amp; checkDate.asStringJMT &amp; ", exiting";
			app.writeLog(msg,LogINFO);
			
			break;
		endif;
		
		delete request;
		delete response;
		create request transient;
		request.fromCurr := self.fromCurrency;
		request.toCurr := "IDR";
		request.exRateType := "M";
		request.date := checkDate.format("yyyyMMdd").String;
		response := _agent.getExchangeRateRequest_SI(request);
		
		// Null response means SAP Web Service is not responding
		if response = null then
			// Will need to retry request later
			return false;
		endif;

		if response.status = "X" and response.exRate &lt;&gt; null then
			// Create a new rate
			delete  pxyCurrencyRate;
			create pxyCurrencyRate transient;
			pxyCurrencyRate.setProxy(checkDate.TimeStamp, fromCurr, response.exRate.Decimal);
			app.myTrxCA.trxCreateCurrencyRate(pxyCurrencyRate, realCurrencyRate, app.myPassport);			
		endif;
		
		checkDate := checkDate - 1;
	endwhile;

	return true;
	
epilog
	delete request;
	delete response;
	
end;</source>
        <access>protected</access>
        <Parameter name="_agent" type="CM_SAPWSConsumerAgent" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="processSAPPostBillEstReq" id="68d11ebe-19d6-4c91-97eb-2e0059e555e3">
        <source>processSAPPostBillEstReq(_agent : CM_SAPWSConsumerAgent input) :Boolean protected;
/*

Purpose:			
	37189.003 Perform Credit Check for Post-Billing Customer
	WSDL 1.6: Post-Billing - Credit Limit
	PaymentType_PostPay	

Return Value:		

Date		Who		Reason
12 Jul 2018	jlgrs1	ChangeRequest 38630: PEL1 - SAP Credit Check Interfaces
*/
vars
	request 	   : CMIF_SAPPostBillEstReq;
	response 	   : CMIF_SAPWSResponse;
	result  	   : Boolean;
	respStatus,
	msg     	   : String;
begin
		
	create request transient;
	request.copyToSAPPostBillEstReq(self.myCashReceipt);
	response := _agent.postBillEstimationRequest_SI(request);
	//01 Oct 2019	NDL	TFS 46758
	result := request.handleSAPResponse(	response,	//_response : CMIF_SAPWSResponse;
											self.myCashReceipt,	//_cashReceipt : CM_CashReceipt input;
											null,	//_invoice : CM_Invoice input;
											null,	//_invoiceLines : CM_InvoiceLineSet input;
											_agent.myLastActivityHistory	//_activityHistory : CM_ActivityHistoryExtInterface input
											);
	
	if response &lt;&gt; null then
		respStatus := response.status;
	endif;
	
	msg :=  method.qualifiedName &amp; 
			' ' &amp; BGP_SAPWSRequest.WSDL16    &amp;
			' ' &amp; "CashReceipt : " 	 	     &amp; self.myCashReceipt.externalInvoiceNumber &amp;
			' ' &amp; "Response Status :"   	 &amp; respStatus &amp;
			' ' &amp; "isProcessed :"       	 &amp; self.isProcessed.asStringJMT &amp;
			' ' &amp; "Result :"            	 &amp; result.asStringJMT;
	app.writeLog(msg,LogINFO);
	
	return result;
epilog
	delete request;
	delete response;
end;</source>
        <access>protected</access>
        <Parameter name="_agent" type="CM_SAPWSConsumerAgent" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
