    <JadeMethod name="loadOutNoNumberOption" id="ad9d9266-4a54-4522-a4cd-8d4b53d8751a">
        <updating/>
        <source>loadOutNoNumberOption()updating;
//--------------------------------------------------------------
//Created: 10 June 2002 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	self.tblNNData.myDynaDict.clear();
	self.tblNNData.rows := tblNNData.fixedRows;	
	self.txtNoNumbers.text := self.tblHeaderDtls.getValueByName(ETRow_Quantity).String;
	self.shtLocationDtls.visible := false;
	self.shtItemDetails.visible := false;	
	self.shtNoNumbers.visible := true;
	self.fldMain.topSheet := self.shtNoNumbers;
	self.myAssistant.LOG_Assistant.comboBoxUnitOfMeasure(self.tblHeaderDtls, ETRow_UnitOfMeasure, true);	
	self.tblHeaderDtls.setValueByName(ETRow_UnitOfMeasure, BOL_UOM_PIECE_COUNT);
	
	if self.filterVoyage &lt;&gt; null then
		self.getLocationsForNNData();	
		self.showAllocRowsForNNData();
	endif;
	self.resizeTopSheet();
end;</source>
    </JadeMethod>
