    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="query"/>
    <JadeMethod name="getControlTypeForOperator" id="9494df82-6fa4-4f8a-bf37-df8bb240f16a">
        <source>getControlTypeForOperator(_op: CM_QueryOperator): Integer;
// ---------------------------------------------------------------------------
// Created:     04 March 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars

begin
	if (_op.isKindOf(CM_QIntegerLookupEqual)) or
	   (_op.isKindOf(CM_QIntegerLookupNotEqual)) then
		return QueryControl_ComboBox;
	elseif _op.isKindOf(CM_QIntegerIsOneOf) then
		return QueryControl_MultiSelect;
	endif;


	return inheritMethod(_op);


end;</source>
        <Parameter name="_op" type="CM_QueryOperator"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getKeyLengthForXTABDictionary" id="7124b1a7-2edb-4e4a-959c-f5aef53e053c">
