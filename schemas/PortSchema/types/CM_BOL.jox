    <JadeMethod name="setCustomsReleased" id="f11bc979-c44c-4ff4-b327-6c4e6e015c06">
        <updating/>
        <source>setCustomsReleased(_quantity : Integer) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 July 2014	cnwmc5	Initial creation

*/

vars

begin
	self.customsQuantityReleased := _quantity;
