    <JadeMethod name="clearStats" id="83117a90-375c-437d-9289-789b37255109">
        <updating/>
        <source>clearStats() updating;
/*

Date		Who		Reason
14 August 2013	cnwer1	Initial creation PAR 31764

*/

vars

begin
    //set the work started time
	self.jobsCompleted:=null;
	self.jobsPartCompleted:=null;
	self.jobsUnactioned:=null;
	self.liftsCompleted:=null;
	self.liftsIncomplete:=null;
	self.movesCompleted:=null;
	self.movesIncomplete:=null;
	self.totalQuantity:=0;
	self.totalVolume:=0;
	self.totalWeight:=0;
	self.completeQuantity:=0;
	self.completeVolume:=0;
	self.completeWeight:=0;
	//self.estActualEndTime:=null;
	self.setEstActualEndTime(null);
	self.estTargetEndTime:=null;
end;
</source>
    </JadeMethod>
    <JadeMethod name="delete" id="efa09851-3c65-41b5-8632-3226d948c1ab">
        <updating/>
        <source>delete() updating;
/*
Purpose:			
Date		Who		Reason
20 March 2015	cnwab1	Initial creation
*/

vars
	jobSheet: CM_JobSheet;
	invalidObject: Boolean;
	edition: Integer;
begin
	jobSheet := self.myJobSheet;
	on Exception do app.handleDeletedObject(exception, jobSheet, invalidObject);		// TFS4389 MAP 19/5/17
	edition := jobSheet.edition;
	if invalidObject then
		return;
	elseif jobSheet &lt;&gt; null and jobSheet.isTransient then
		self.myVoyageStats.allJobSheetStats.remove(self);
		delete jobSheet;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="exportAsCSV" id="c4958a91-e134-44f7-bfef-5f44dde6ef24">
        <source>exportAsCSV() : String;
/*
Purpose:			
Date		Who		Reason
02 June 2015	cnwab1	Initial creation
*/

vars

	prop : Property;
	clas : Class;
	type : Type;
	values, value : String;
begin

	foreach prop in CMIF_JobSheetStats.getProperties discreteLock do
		type := prop.type;
		if type.isKindOf(PrimType) then
			value := self.getPropertyValue(prop.name).String; //.asDoubleQuotedString;
		
			 if values = "" then
				values := value;
			else
				values := values &amp; "," &amp; value;
			endif;
		endif;
	
	endforeach;

	return values;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getActualTime" id="20f13f01-5877-47b6-b9ce-7e02f230c4e4">
        <source>getActualTime(): TimeStamp;
/*

Purpose:			


Return Value:		


Date		Who		Reason
27 July 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars

begin
	if self.myVoyageStats &lt;&gt; null then
		return self.myVoyageStats.actualTime;
	endif;

epilog

end;</source>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="getAllJobStats" id="0c73a613-2bd3-4d57-8e1b-5f4174cf8d3e">
        <updating/>
        <source>getAllJobStats()updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
18 July 2007	cnwer1	Initial creation - PAR#xxxx
22 Jan 2018	jlgkpd1	TFS 36660 - Penn locking issues

*/
vars
	job  :CM_Job;
	voyageJob :CM_VoyageJob;
	jobActualStart,
	jobActualEnd,
	jobTargetStart,
	jobTargetEnd: TimeStamp;
	crane : CM_Crane;
	cmif_JobStats		: CMIF_JobStats;
	pJobStart, pJobEnd,
	currentActualEnd,
	currentTargetEnd : TimeStamp;
	voyage : CM_Voyage ;
	allJobs : CM_JobArray;
	returnNotSet : Boolean;
begin
	crane:=self.myJobSheet.CM_VoyageJobSheet.getMyCrane;
	foreach cmif_JobStats in self.allJobStatsByJob do
		cmif_JobStats.setMyCMIFJobSheetStatsForEnd(null);
	endforeach;

	if not self.myJobSheet.isKindOf(CM_VoyageJobSheet) then
		return;
	endif;
	voyage:= self.myJobSheet.CM_VoyageJobSheet.myVoyage;
	if voyage = null then
		return;
	endif;
	
	//self.estActualEndTime:=null;
	self.setEstActualEndTime(null);
	self.estTargetEndTime:=null;
	currentActualEnd:=self.workStarted; 
	
	currentActualEnd:=self.myVoyageStats.getJobSheetStartTimeWithDelays(self.myJobSheet.CM_VoyageJobSheet.crane,currentActualEnd);
	currentTargetEnd:=currentActualEnd;
	
	// TFS 36660	
	allJobs := self.myJobSheet.allJobsByOrder.cloneSelf(true);
	
	foreach job in  allJobs discreteLock do
		if not job.isKindOf(CM_VoyageJob) then
			continue;
		endif;

		voyageJob:=job.CM_VoyageJob;
		cmif_JobStats:=self.allJobStatsByJob[voyageJob];
		if cmif_JobStats = null then
			create cmif_JobStats transient;
			cmif_JobStats.setMyJob(job);
			job.getJobStats(cmif_JobStats,self.myVoyageStats);
		else
			cmif_JobStats.setMyCMIFJobSheetStatsForEnd(null);
			cmif_JobStats.clearStats;
			job.getJobStats(cmif_JobStats,self.myVoyageStats);
		endif;
		
		pJobStart:=null;
		pJobEnd:=null;
		voyageJob.getStartEndFromWLEs(pJobStart,pJobEnd);
		jobActualStart:= self.getJobStart(voyageJob,pJobStart,currentActualEnd);
		jobTargetStart:=self.getJobStart(voyageJob,pJobStart,currentTargetEnd);
		
		//first 
		if voyageJob.workListEntries.size = 0 and voyageJob.actualEndTs &lt;&gt; null then
			jobActualEnd:=voyageJob.actualEndTs;
			jobTargetEnd:=jobActualEnd;
			jobActualEnd:=voyageJob.getEndTsWithDelays(jobActualStart,jobActualEnd,crane,self.myVoyageStats.allVoyageDelays);
			jobTargetEnd:=voyageJob.getEndTsWithDelays(jobTargetStart,jobTargetEnd,crane,self.myVoyageStats.allVoyageDelays);
		else
			if voyageJob.status = JOB_COMPLETE then
				if voyageJob.actualEndTs &lt;&gt; null then
					jobActualEnd:=voyageJob.actualEndTs;
					jobTargetEnd:=jobActualEnd;
				elseif  pJobEnd &lt;&gt; null then
					jobActualEnd:=pJobEnd;
					jobTargetEnd:=jobActualEnd;
					jobActualEnd:=voyageJob.getEndTsWithDelays(jobActualStart,jobActualEnd,crane,self.myVoyageStats.allVoyageDelays);
					jobTargetEnd:=voyageJob.getEndTsWithDelays(jobTargetStart,jobTargetEnd,crane,self.myVoyageStats.allVoyageDelays);
				endif;
				
			else
				jobTargetEnd:=self.getJobEnd(jobTargetStart,cmif_JobStats,false,crane);
				jobActualEnd:=self.getJobEnd(jobActualStart,cmif_JobStats,true,crane);
			endif;
		endif;	
		
	
		cmif_JobStats.setDetails(	self,
									jobActualStart,
									jobActualEnd,
									jobTargetStart,
									jobTargetEnd);
		currentActualEnd:=jobActualEnd;
		currentTargetEnd:=jobTargetEnd;
		self.setEstActualEndTime(currentActualEnd);
		self.setEstTargetEndTime(currentTargetEnd);
		
		self.completeQuantity:=self.completeQuantity + cmif_JobStats.completeQuantity;
		self.completeVolume:=self.completeVolume + cmif_JobStats.completeVolume;
		self.completeWeight:=self.completeWeight + cmif_JobStats.completeWeight;
		self.totalQuantity := self.totalQuantity + cmif_JobStats.totalQuantity;
		self.totalVolume := self.totalVolume + cmif_JobStats.totalVolume;
		self.totalWeight := self.totalWeight + cmif_JobStats.totalWeight;
	endforeach;
	
	//03 Apr 2012	NDL	Par 29369
	if self.myJobSheet.CM_VoyageJobSheet.includesWPOpHrs() then
		self.setEstActualEndTime( self.calcEstActFromWPOpHrs( returnNotSet ) );
	endif;

epilog
	delete allJobs;
end;</source>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="5a62d692-8b4a-458d-b674-09c7f0d296b4">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*

Purpose:			


Return Value:		


Date		Who		Reason
07 August 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars
	crane : CM_Crane;
	tmpTS, tmpTSend : TimeStamp;
	returnNotSet : Boolean;
	measure		: CM_MeasurementType;
	unit		: String;
	converted	: String;
	actualTime :TimeStamp;
	completeDiffMins : Integer;
	wle : CM_WorkListEntry;
	delayCol : CM_DelayByStartDTDict;
	delayHours, netrate : Real;
begin

	if _attrName = ETRow_ActualRate then
		return self.actualRate.roundedTo(1).asStringJMT;
	elseif _attrName = ETRow_TargetRate then
		return self.estimatedRate.roundedTo(1).asStringJMT;
	elseif _attrName = ETRow_NetRate then
		return self.myJobSheet.CM_VoyageJobSheet.getKPINetRate(self).roundedTo(1).asStringJMT; // TFS 4133 added SELF for hold jobs

	elseif _attrName = ETRow_MovesDone then
		return self.movesCompleted.asStringJMT;
	elseif _attrName = ETRow_MovesToDo then
		return self.movesIncomplete.asStringJMT;
	elseif _attrName = ETRow_LiftsDone then
		return self.liftsCompleted.asStringJMT;
	elseif _attrName = ETRow_LiftsToDo then
		return self.liftsIncomplete.asStringJMT;
	elseif _attrName = ETRow_DepartureTargetDate then
		tmpTS := self.systemToLocalTime(self.myVoyageStats.myVoyage.departTargetDT);	// 17/5/16 cnwmp6 TFS 488 - Multi timezone support
		if tmpTS = null then
			return  app.getErrorString(Not_Set);
		endif;
		return tmpTS.asStringJMT;
	elseif _attrName = ETRow_DepartureTargetRate then
		
		return self.getWorkDepartureTargetRatePH().asStringJMT;
	elseif _attrName =  ETRow_WorkStarted then
		if self.myJobSheet.CM_VoyageJobSheet.includesWPOpHrs() then	//03 Apr 2012	NDL	Par 29369
			tmpTS := self.myJobSheet.CM_VoyageJobSheet.getWPOpHrsWorkStarted();
		else
			tmpTS := self.myJobSheet.CM_VoyageJobSheet.getStartDateFromReceiveRelease();
		endif;
		if tmpTS = null then
			if self.myJobSheet.isTransient and self.workStarted.isValid() then
				return self.systemToLocalTime(self.workStarted).asStringJMT;	// 17/5/16 cnwmp6 TFS 488 - Multi timezone support
			endif;

			return   app.getErrorString(Not_Set);
		else
			return self.systemToLocalTime(tmpTS).asStringJMT;	// 17/5/16 cnwmp6 TFS 488 - Multi timezone support
		endif;
	elseif _attrName = ETRow_WorkTime then
		//epr par 33356 28/2/14
		actualTime:=self.getActualTime;
		if self.liftsIncomplete = 0 and self.movesIncomplete = 0 and not self.myJobSheet.allCompletedWLEsByDate.isEmpty then // must be complete
			wle := self.myJobSheet.allCompletedWLEsByDate.last;
			if wle.completedDate.Date.isValid then
				actualTime := wle.completedDate; // so populate with the time it completed.
			endif;
		endif;
		
		completeDiffMins:=actualTime.getDifferenceInMinutes(self.workStarted);
		return completeDiffMins.asDaysHoursMinutesString();
		
	elseif _attrName = ETRow_EstActualCompletion then
		if self.actualRate = 0 then
			return   app.getErrorString(Not_Set);
		else
			if self.myJobSheet.CM_VoyageJobSheet.includesWPOpHrs() then	//03 Apr 2012	NDL	Par 29369
				//return self.calcEstActFromWPOpHrs.asStringJMT;
				//20 Sep 2012	NDL	Par 30389
				tmpTS := self.calcEstActFromWPOpHrs(returnNotSet);
				if returnNotSet then
					return app.getErrorString(Not_Set);
				else
					return self.systemToLocalTime(tmpTS).asStringJMT  ;	// 17/5/16 cnwmp6 TFS 488 - Multi timezone support
				endif;
			endif;
			return self.systemToLocalTime(self.estActualEndTime).asStringJMT ;	// 17/5/16 cnwmp6 TFS 488 - Multi timezone support
		endif;
	elseif _attrName = ETRow_EstTargetCompletion then
		if 	self.estTargetEndTime = null then
			return  app.getErrorString(Not_Set);
		else
			return self.systemToLocalTime(self.estTargetEndTime).asStringJMT;	// 17/5/16 cnwmp6 TFS 488 - Multi timezone support
		endif;
		
	elseif _attrName = ETRow_Cranes or
			_attrName = ETRow_WorkPoints then
		return self.description; //myJobSheet.CM_VoyageJobSheet.crane;
	//	self.myJobSheet.CM_VoyageJobSheet.getNiceName
	elseif _attrName = ETRow_WeightToMove then
		measure :=  app.getDefaultMeasurementForType(Type_Weight);
		unit := measure.shortName;
		converted := app.convertMeasurementForDisplay(unit, self.totalWeight - self.completeWeight);
		return converted &amp; Space &amp; unit;
	elseif _attrName = ETRow_WeightMoved then
		measure := app.getDefaultMeasurementForType(Type_Weight);
		unit := measure.shortName;
		converted := app.convertMeasurementForDisplay(unit, self.completeWeight);
		return converted &amp; Space &amp; unit;	
	elseif _attrName = ETRow_QuantityMoved then
		return self.completeQuantity.asStringJMT;
	elseif _attrName = ETRow_QuantityToMove then
		return (self.totalQuantity - self.completeQuantity).asStringJMT;
	elseif _attrName = ETRow_VolumeMoved then
		measure := app.getDefaultMeasurementForType(Type_Volume);
		unit := measure.shortName;
		converted := app.convertMeasurementForDisplay(unit,  self.completeVolume);
		return converted &amp; Space &amp; unit;
	elseif _attrName = ETRow_VolumeToMove then
		measure := app.getDefaultMeasurementForType(Type_Volume);
		unit := measure.shortName;
		converted := app.convertMeasurementForDisplay(unit,  self.totalVolume - self.completeVolume);
		return converted &amp; Space &amp; unit;
	else
	
		return inheritMethod(_attrName, _short);
	endif;

epilog
	delete delayCol;
end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getEstJobTime" id="99dab0fa-cb05-4ffd-8c50-0df432c64e7d">
        <source>getEstJobTime(_rate : Decimal  ;_moves : Integer) : Integer;
/*

Purpose:			


Return Value:		


Date		Who		Reason
26 Jul 2007	cnwer1	Initial creation - PAR#xxxx
03 Feb 2016	cnwkpd1	Integer overflow in JBL benchmark test

*/

vars
	numHours,
	numSecsDec		: Decimal[18,4];
	numSecs,
	jobAdditionalMins : Integer;
	
begin
	jobAdditionalMins:=self.myVoyageStats.jobAdditionalMins;//self.myJobSheet.getMyTerminal.getConfig(JobAdditionalTime).Integer;
	if _rate &lt;&gt; 0 then 
		numHours := (_moves /_rate);	
	endif;
	
	numSecsDec := numHours * SecondsPerHour;
	if numSecsDec &gt; Max_Integer then
		numSecs := SecondsPerHour;			// default to 1 hour
	else
		numSecs := numSecsDec.Integer;
	endif;
	
	return numSecs + (jobAdditionalMins * 60);


epilog

end;</source>
        <Parameter name="_rate" type="Decimal"/>
        <Parameter name="_moves" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getJobEnd" id="799ee978-40ac-4084-ad03-7dbbdc11cef0">
        <source>getJobEnd(	_jobStart : TimeStamp;
			_cmifJobStats : CMIF_JobStats; 
			_isActual : Boolean;
			_crane : CM_Crane) : TimeStamp;
/*

Purpose:			


Return Value:		


Date		Who		Reason
27 July 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars
	lastJobStat : CMIF_JobStats;
	lastJobEndTime ,actualTime, jobEndTime: TimeStamp;
	lastJobBufferMins : Integer;
	estJobTime : Integer;
	crane : CM_Crane;
	voyageJob : CM_VoyageJob;
begin
	crane:=_crane;//self.myJobSheet.CM_VoyageJobSheet.getMyCrane;
	voyageJob:=_cmifJobStats.myJob.CM_VoyageJob;
	actualTime :=self.getActualTime;
	if _isActual then
		lastJobStat:=self.allJobStatsByActualEndTime.last;
		if lastJobStat &lt;&gt; null then
			lastJobEndTime:=lastJobStat.actualEndTime;
		endif;
	else
		lastJobStat:=self.allJobStatsByTargetEndTime.last;
		if lastJobStat &lt;&gt; null then
			lastJobEndTime:=lastJobStat.targetEndTime;
		endif;
	endif;
	if lastJobStat &lt;&gt; null and lastJobEndTime &gt; _jobStart then
		lastJobBufferMins:= _jobStart.getDifferenceInMinutes( lastJobEndTime);
	endif;
	
	estJobTime:=0;
	//get the target end time from crane rates
	if _isActual then
		estJobTime:=self.getEstJobTime(self.actualRate,_cmifJobStats.incompleteMoves);
	else
		estJobTime:=_cmifJobStats.myJob.CM_VoyageJob.getEstJobTimeForJobStats(crane, _cmifJobStats, self.myVoyageStats.jobAdditionalMins);
	endif;
	if estJobTime &lt;&gt; null and _jobStart &lt;= actualTime then
		jobEndTime:=actualTime;
		jobEndTime.addSecondsInterval(estJobTime);
		jobEndTime:=voyageJob.getEndTsWithDelays(actualTime,jobEndTime,crane,self.myVoyageStats.allVoyageDelays);
	else
		jobEndTime:=_jobStart;
		jobEndTime.addSecondsInterval(estJobTime);
		jobEndTime:=jobEndTime.addMinutes(lastJobBufferMins);
		jobEndTime:=voyageJob.getEndTsWithDelays(_jobStart,jobEndTime,crane,self.myVoyageStats.allVoyageDelays);
	endif;	
	
	return jobEndTime;


epilog

end;</source>
        <Parameter name="_jobStart" type="TimeStamp"/>
        <Parameter name="_cmifJobStats" type="CMIF_JobStats"/>
        <Parameter name="_isActual" type="Boolean"/>
        <Parameter name="_crane" type="CM_Crane"/>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="getJobStart" id="9fe6f43b-86da-49ea-a563-3712e925d1c3">
        <source>getJobStart(_job : CM_VoyageJob; _wleJobStart, _priorJobEnd : TimeStamp input) : TimeStamp;
/*

Purpose:			


Return Value:		


Date		Who		Reason
26 July 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars
	jobStart : TimeStamp;
begin
	if	_job.actualStartTs &lt;&gt; null   then
			jobStart := _job.actualStartTs;
	else
		if _wleJobStart &lt;&gt; null then
			jobStart := _wleJobStart;
		else
			jobStart:=_priorJobEnd;
		endif;
	endif;
	
	return jobStart;

epilog

end;</source>
        <Parameter name="_job" type="CM_VoyageJob"/>
        <Parameter name="_wleJobStart" type="TimeStamp" usage="input"/>
        <Parameter name="_priorJobEnd" type="TimeStamp" usage="input"/>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="getMovesTotal" id="32b9adc7-6f67-40ba-a145-d6e136351386">
        <source>getMovesTotal(): Integer;
//13 October 2010	cnwdw1	
//
vars

begin
	return self.movesCompleted + self.movesIncomplete;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getMyTerminal" id="9169924e-17aa-4164-bcfa-ae733ebad27a">
        <source>getMyTerminal(): CM_Terminal;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 May 2016	cnwmp6	Initial creation

*/

vars
	voyage: CM_Voyage;
begin
	if self.myVoyageStats &lt;&gt; null then
		voyage := self.myVoyageStats.myVoyage;
		if voyage &lt;&gt; null then
			return voyage.myTerminal;
		endif;
	endif;

	return null;
epilog

end;</source>
        <ReturnType type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="getStats" id="de3ee2a9-66b3-487a-aab6-1252d69a0555">
        <updating/>
        <source>getStats(_partiallyWorked : Boolean) updating;
// ---------------------------------------------------------------------------
// Created:     24 May 2005 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	actualTime :TimeStamp;
	completeDiffMins,totalDiffMins : Integer;
	wle : CM_WorkListEntry;
	wpOpHrs : Real;
	//cnwmc5 - 28 July 2014 - PAR 34565
	calcByMoves	: Boolean;
	liftsOrMoves : Integer;
	actRateReal : Real;
begin
	if self.myJobSheet = null then
		return;
	endif;
	clearStats();
	
	self.workStarted := self.myJobSheet.getWorkStarted();
	
	//par 15485 can be null 
	if self.workStarted = null then
		self.workStarted:=self.myVoyageStats.actualTime;
	endif;
	self.myJobSheet.getWorkTotals(	self.jobsCompleted, 
									self.jobsPartCompleted,
									self.jobsUnactioned, 
									self.movesCompleted, 
									self.movesIncomplete, 
									self.liftsCompleted, 
									self.liftsIncomplete,
									self.plannedLoad,
									self.plannedDischarge,
									self.actualLoad,
									self.actualDischarge,
									self.actualLoadTEU,
									self.actualDischargeTEU,
									_partiallyWorked);
	
//	self.setActualRate();
	
	//get the actual rate
	actualTime:=self.getActualTime;
	
	//28 Mar 2011	NDL	Par 27230
	if self.liftsIncomplete = 0 and self.movesIncomplete = 0 and not self.myJobSheet.allCompletedWLEsByDate.isEmpty then // must be complete
		wle := self.myJobSheet.allCompletedWLEsByDate.last;
		if wle.completedDate.Date.isValid then
			actualTime := wle.completedDate; // so populate with the time it completed.
		endif;
	endif;
	
	completeDiffMins:=actualTime.getDifferenceInMinutes(self.workStarted);
	
	//cnwmc5 - 28 July 2014 - PAR 34565
	calcByMoves := self.myJobSheet.getMyTerminal.getConfig(CalcRatesFromMoves).Boolean;
	if calcByMoves then
		liftsOrMoves := self.movesCompleted;
	else
		liftsOrMoves := self.liftsCompleted;
	endif;
	
	//epr par 33556 28/2/14 use lifts completed rather than moves - important when  crane was doing twin lifts
	if completeDiffMins &lt;&gt; 0 then
		// LOLO actual Crane rate
		self.actualRate:=( liftsOrMoves /completeDiffMins) * 60;		//cnwmc5 - 28 July 2014 - PAR 34565
	endif;
	
	//03 Apr 2012	NDL	Par 29369
	if self.myJobSheet.CM_VoyageJobSheet.includesWPOpHrs() then
		wpOpHrs := self.myJobSheet.CM_VoyageJobSheet.getWPOpHrsGrossMins();
		if wpOpHrs &lt;&gt; 0 then
			self.actualRate := ( liftsOrMoves / wpOpHrs )* 60;			//cnwmc5 - 28 July 2014 - PAR 34565
		endif;
	endif;
	
	self.getAllJobStats;
	
	// TFS 4133 HOLD JOB ACTUAL RATE - NEEDS completeWeight from self.getAllJobStats
	if completeDiffMins &lt;&gt; 0 then
		if self.myJobSheet.isVoyageHoldJobSheet() then
			actRateReal := ( completeWeight /completeDiffMins) * 60; // 4033 error precision issue
			self.actualRate :=	actRateReal.min(99999999.9999);
		endif;
	endif;
	
	if actualTime &gt; self.workStarted then
		totalDiffMins :=self.estTargetEndTime.getDifferenceInMinutes(actualTime);
	else
		totalDiffMins :=self.estTargetEndTime.getDifferenceInMinutes(self.workStarted);
	endif;
	
	if self.myJobSheet.isVoyageHoldJobSheet() then // TFS 4133
		if self.myJobSheet.myWorkPoint &lt;&gt; null then
			if self.myJobSheet.myWorkPoint.hasDefinedCargoRates then	//08 Mar 2018	NDL TFS 37437
				estimatedRate := self.myJobSheet.myWorkPoint.getDefinedTargetRateWeight( self.myJobSheet );
			else
				estimatedRate := self.myJobSheet.myWorkPoint.targetRatePHWeight;
			endif;
		endif;
	else
		if totalDiffMins &lt;&gt; 0 then
			//epr par 21959 11/12/09 changed from movesIncomplete to lifts incomplete - i.e. for twin lifts moves will be twice the lifts
			//cnwmc5 - 29 July 2014 - PAR 34565
			if calcByMoves then
				estimatedRate:=(self.movesIncomplete/totalDiffMins) * 60;
			else
				estimatedRate:=(self.liftsIncomplete/totalDiffMins) * 60;
			endif;
		endif;	
	endif;
	self.setGraphPoints();

epilog
	// belts &amp; braces to ensure nothing left locked
	endLoad;	
end;</source>
        <Parameter name="_partiallyWorked" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getStatsFromTrackedItem" id="55d6d359-d9d7-47af-bfcf-b07b25cb7706">
        <updating/>
        <source>getStatsFromTrackedItem(_ti : CM_TrackedItem; _load : Boolean) updating;
/*
Purpose:		get the stats from the TI, means that the TI has not been moved so just add to the 'not done yet' piles.	
Date		Who		Reason
20 March 2015	cnwab1	Initial creation
*/

vars

begin


	self.movesIncomplete  := self.movesIncomplete + 1;
	self.liftsIncomplete := self.liftsIncomplete + 1;
	self.totalQuantity := self.totalQuantity + _ti.totalQuantity;
	self.totalWeight := self.totalWeight + _ti.totalWeight;
	self.totalVolume := self.totalVolume + _ti.totalVolume;
	
	if _load then
		self.plannedLoad := self.plannedLoad + 1;
	else
		self.plannedDischarge := self.plannedDischarge + 1;
	endif;

	
epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_load" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getStatsFromTransaction" id="c14e2516-6a46-4abb-94be-c4755c738c26">
        <updating/>
        <source>getStatsFromTransaction(_trans : CM_TITransaction) updating;
/*
Purpose:			
Date		Who		Reason
20 March 2015	cnwab1	Initial creation
*/

vars

begin
	self.movesCompleted := self.movesCompleted + 1; 
//	self.movesIncomplete  := self.movesIncomplete + 1;
	self.liftsCompleted := self.liftsCompleted + 1;
//	self.liftsIncomplete := self.liftsIncomplete + 1;
	self.plannedLoad := 0;
	self.plannedDischarge := 0;
	self.completeQuantity := self.completeQuantity + _trans.totalQuantity;
	self.completeWeight := self.completeWeight + _trans.totalWeight;
	self.completeVolume := self.completeVolume + _trans.totalVolume;
	self.totalQuantity := self.totalQuantity + _trans.totalQuantity;
	self.totalWeight := self.totalWeight + _trans.totalWeight;
	self.totalVolume := self.totalVolume + _trans.totalVolume;
	
	if _trans.isKindOf(CM_ReleaseShip) then
		self.actualLoad := self.actualLoad + 1;
		if _trans.myTrackedItem &lt;&gt; null then
			self.actualLoadTEU := self.actualLoadTEU  + _trans.myTrackedItem.getNumTEU().Integer;
		endif;
	elseif _trans.isKindOf(CM_ReceiveShip) then
		self.actualDischarge := self.actualDischarge + 1;
		if _trans.myTrackedItem &lt;&gt; null then
			self.actualDischargeTEU := self.actualDischargeTEU  + _trans.myTrackedItem .getNumTEU().Integer;
		endif;
	endif;
	
	// get the earliest transaction
	if not self.workStarted.isValid() then
		self.workStarted := _trans.dateTime;
	elseif _trans.dateTime &lt; self.workStarted then
		self.workStarted := _trans.dateTime;
	endif;
	
	
epilog

end;</source>
        <Parameter name="_trans" type="CM_TITransaction"/>
    </JadeMethod>
    <JadeMethod name="getWorkDepartureTargetRatePH" id="3b00dc4d-183a-41a2-bae2-dc801a354ace">
        <source>getWorkDepartureTargetRatePH() : Integer;
// ---------------------------------------------------------------------------
// Created:     24 May 2005 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	// Par 9527 Made totHours huge so no precision error.
	totHours		: Decimal[23,2];
	toDoDuration,
	aveDuration,
	duration, rate	: Integer;
	movesDone,
	movesToDo,
	movesTotal		: Integer;
	etc, endTS		: TimeStamp;
	theVoyage		: CM_Voyage;
	
begin
	theVoyage := self.myVoyageStats.myVoyage;
	endTS := app.actualTimeServer();
	if theVoyage = null then
		return null;
	endif;
	
	if theVoyage.departTargetDT.isValid() then // PAR 9475
		endTS := theVoyage.departTargetDT;
	endif;
	
	duration := theVoyage.getWorkDurationTime(endTS); // get total seconds so far worked
	movesDone := self.movesCompleted;
	movesToDo := self.movesIncomplete;
	if movesDone = 0 then
		return null;
	endif;

	
	movesTotal := movesDone + movesToDo;

	totHours := (duration / SecondsPerHour).roundedTo(2);

	if totHours &gt; 0 then	// PAR 9712
		return (movesTotal / totHours).Integer;
	else
		return (movesTotal / 1).Integer;
	endif;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getWorkETCActual" id="54415cd8-dd62-43dd-ae95-575c3b99a42b">
        <source>getWorkETCActual() : TimeStamp;
// ---------------------------------------------------------------------------
// Created:     24 May 2005 by cnwrs2
//
// Purpose:		get Estimated Time to Completion
// ---------------------------------------------------------------------------
// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
vars
	toDoDuration,aveDuration,duration : Integer;
	ratePH, movesDone,movesToDo, numSecs : Integer;
	etc : TimeStamp;
	numHours : Real;
begin

	movesDone := self.movesCompleted;
	movesToDo := self.movesIncomplete;
	if movesDone = 0 then
		return null;
	endif;
	ratePH := self.actualRate.Integer;

	if ratePH &lt;&gt; 0 then // PAR 9393
		numHours := (movesToDo /ratePH);	
	endif;
	numSecs := (numHours * SecondsPerHour).Integer;
	
	etc := app.actualTimeServer;// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	etc.addSecondsInterval(numSecs);
	return etc;
end;</source>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="getWorkETCTarget" id="24ae20c1-13ef-47f7-b4fa-3c8daf3e5017">
        <source>getWorkETCTarget(_ratePH: Integer) : TimeStamp;
// ---------------------------------------------------------------------------
// Created:     24 May 2005 by cnwrs2
//
// Purpose:		get Estimated Time to Completion using the Entered TI Per Hour Rate
// ---------------------------------------------------------------------------
// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
vars
	ratePH, movesDone,movesToDo, numSecs : Integer;
	etc : TimeStamp;
	numHours : Real;
begin

	movesDone := self.movesCompleted;
	movesToDo := self.movesIncomplete;
	if movesDone = 0 then
		return null;
	endif;
	
	//ratePH := self.myVoyageStats.myVoyage.tiPerHour;
	ratePH := _ratePH;	//from crane
	
	if ratePH &lt;&gt; 0 then // PAR 9393
		numHours := (movesToDo /ratePH);	
	endif;
	numSecs := (numHours * SecondsPerHour).Integer;
	
	etc := app.actualTimeServer;// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	etc.addSecondsInterval(numSecs);
	return etc;
end;</source>
        <Parameter name="_ratePH" type="Integer"/>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="init" id="d7669ac6-d2aa-4171-9360-101d790598f3">
        <updating/>
        <source>init(_jobSheet : CM_JobSheet) updating;
// ---------------------------------------------------------------------------
// Created:     24 May 2005 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	self.myJobSheet := _jobSheet;
	
	
	if self.myJobSheet.isTransient then
		self.description :=  self.myJobSheet.CM_VoyageJobSheet.crane;
	else
		self.description := self.myJobSheet.getNiceName();
	endif;
		
end;</source>
        <Parameter name="_jobSheet" type="CM_JobSheet"/>
    </JadeMethod>
    <JadeMethod name="setActualRate" id="66d18759-b216-4f77-b788-4ee8737a5041">
        <updating/>
        <source>setActualRate() updating, protected;
// ---------------------------------------------------------------------------
// Created:     24 May 2005 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	theRate : Integer;
	workStarted, lastWLE : TimeStamp;
	idx: Integer;
	aWLE : CM_WorkListEntry;
	numMinsSinceLastWLE : Integer;
	totalMins	: Real;
begin

	workStarted := self.myJobSheet.getWorkStarted(); // PAR 8436 take 2
	lastWLE := null;
	
	foreach aWLE in self.myJobSheet.allCompletedWLEsByDate discreteLock do
		
		if aWLE.completedDate = null then
			continue;
		endif;
		idx := idx + 1;

		// PAR 7697
		// They do not have a delays system, so if there is a gap greater than 10 minutes we will fill in the gap, else these stats stop being relevant
		if lastWLE.isValid then
			numMinsSinceLastWLE := lastWLE.cnMinutesDifference(aWLE.completedDate);
		else
			if workStarted.cnEcIsLessThanOrEqual(aWLE.completedDate) then
				numMinsSinceLastWLE := workStarted.cnMinutesDifference(aWLE.completedDate);
			else
				numMinsSinceLastWLE := 10;
			endif;
		endif;
		
		lastWLE := aWLE.completedDate;

		if numMinsSinceLastWLE &gt; 10 then
			numMinsSinceLastWLE := 10;
		endif;
	
		totalMins := totalMins + numMinsSinceLastWLE;
		//rate now is (idx/(totalMins/60)).Integer;
	endforeach;
	
	//03 Apr 2012	NDL	Par 29369
	if self.myJobSheet.CM_VoyageJobSheet.includesWPOpHrs() then
		totalMins := self.myJobSheet.CM_VoyageJobSheet.getWPOpHrsGrossMins();
	endif;

	if totalMins &gt; 0 then
		theRate := (idx/(totalMins/60)).Integer;
	else
		theRate := idx;	//assume still in the first hour 
	endif;
	
	self.actualRate := theRate;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setEstActualEndTime" id="df6a6251-c91e-4b60-a6f4-1baf14626c7c">
        <updating/>
        <source>setEstActualEndTime(_value : TimeStamp) updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
26 July 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars

begin
	if self.estActualEndTime = null or _value &gt; self.estActualEndTime then
		self.estActualEndTime:=_value;
	endif;

epilog

