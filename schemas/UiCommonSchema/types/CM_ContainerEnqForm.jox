    <JadeMethod name="tblMeasurement_lostFocus" id="6e56035e-05be-47c4-9fd5-46a234ed1139">
        <updating/>
        <source>tblMeasurement_lostFocus(table: Table input) updating;
/*

Date		Who		Reason
05 April 2016	cnwer1	Initial creation TFS 1707

*/

vars
	theTable,
	weightMeasure : CMUI_MeasurementTable;
	weightDisplayValue : String;
	volume,
	weight : Decimal[14,4];
	measureToUse : CM_MeasurementType;
	entryTable : CM_EntryTable;
	prefix, 
	rowName : String;
	cargoType : CM_CargoType;
	doWeightCalculation : Boolean;					  
begin
	inheritMethod(table);
	
	//21/02/2023	navkc1 Bug 62340
	theTable := table.CMUI_MeasurementTable;
	
	//21/02/2023	navkc1 Bug 62340
	cargoType := self.myCurrentObject.CM_TrackedItem.myCargoType;
	doWeightCalculation := cargoType &lt;&gt; null and cargoType.useTareCargoWeight and cargoType.autoTareCargoWeightCalc;		//navra1 - TFS 63624 - 15th Apr 2024
	
	if theTable.rowName = ETRow_TotalVolume and
		self.myCurrentObject &lt;&gt; null and self.myCurrentObject.isKindOf(CM_Bulk)
		and self.myCurrentObject.CM_Bulk.isNotified 
		and self.myCurrentObject.CM_Bulk.isBulkByVolume then
		entryTable:=table.parent.CM_EntryTable;
		weightMeasure:=entryTable.getMeasurementTableForRowName(ETRow_TotalWeight);
		
		if weightMeasure &lt;&gt; null then
			volume:=theTable.getConvertedValue;
			weight := volume * self.myCurrentObject.CM_Bulk.getDensity();
			measureToUse:=weightMeasure.getMeasurementType;
			weightDisplayValue:= app.convertMeasurementForDisplay(measureToUse.shortName, weight) &amp; " " &amp; measureToUse.shortName;
			self.getMultiValueConvertedString( weight, measureToUse, weightDisplayValue);
			
			prefix := app.getMeasurementPrefixFromType(measureToUse.measurementType);
			rowName := prefix &amp; ETRow_TotalWeight &amp; "_" &amp; measureToUse.shortName;
			entryTable.setValueByName(rowName, weightDisplayValue);
			weightMeasure.setValues(weightDisplayValue);
		endif;
		
	/* 09/04/2024 REVERT THIS CHANGE - FURTHER DISCUSSION REQUIRED */
	//navra1 - TFS 63624 - 15th Apr 2024 - reenable the changes for calculation - start
	elseif theTable.rowName = ETRow_WeightCargo or theTable.rowName = ETRow_WeightTare or theTable.rowName = ETRow_TotalWeight then //21/02/2023	navkc1 Bug 62340
		//21/02/2023	navkc1 Bug 62340
		if doWeightCalculation then
			self.doCalculateTotalWeight(theTable);
		endif;
	//navra1 - TFS 63624 - 15th Apr 2024 - reenable the changes for calculation - end
	
	endif;
epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="tblSeals_gotFocus" id="8e88b9d4-8ef4-4821-8fdd-7c42f9ffb172">
