    <JadeMethod name="doPurgeLockTransactions" id="61d8ad5c-ed2f-45ae-a80a-4a0f1d66fb6b">
        <updating/>
        <source>doPurgeLockTransactions(): Boolean protected, updating;
// -------------------------------------------
// Created Apr 2005 by cnwrs1
// -------------------------------------------
//9/11/17 jlgns1 TFS 6960 QNS - Disk space issues and house keeping inside JMT
vars

	alllockTransactionToPurge: DynaDictionary;
	obj: Object;
	lockTransaction: CM_LockTransaction;
	errCode: Integer;
	errTxt: String;
	rtnCode: Boolean;
	count, theSize : Integer;
begin

	on Exception do app.alertExceptionHandler(exception, null, app.getErrorString(Garbage_Collection), errCode, errTxt, true, false);
	
	create alllockTransactionToPurge transient;
	self.createActivityHistory(app.getErrorString(Database_Purging)&amp;' '&amp;"Lock Transaction", false, false);
	alllockTransactionToPurge.setMembership(CM_LockTransaction);
	alllockTransactionToPurge.addMemberKey("createdTime", false, false);
	alllockTransactionToPurge.endKeys(true);
	self.getLockTransactionOldThanDate(alllockTransactionToPurge);
	theSize := alllockTransactionToPurge.size;
	foreach obj in alllockTransactionToPurge do
		count := count + 1;
		errTxt := null;
		lockTransaction := obj.CM_LockTransaction;
		if count mod Commit_Block_Size_Large = 0 then
			if self.abort() then
				return false;
			endif;
			if count mod Activity_Progress_Count_Large = 0 then
				self.createActivityHistory("Processed "&amp;count.String&amp;" of "&amp;theSize.String, false, true);
			endif;
		endif;
		self.doInitiateProcess();
		app.myTrxDA.trxDeleteLockTransaction(lockTransaction, app.myPassport);
		// Will get here if trx has been unsuccessful due to abort.
		rtnCode := self.isToAbort or self.abort();
		if rtnCode then
			return false;
		endif;
		if errTxt &lt;&gt; null then
			self.allErrors.add(errTxt);
		endif;
		self.createActivityHistory(null, false, false);
		self.doCheckForError();
	endforeach;
	self.createActivityHistory("Purged "&amp;theSize.String&amp;" Lock transactions.", false, false);
	return true;

epilog
	delete alllockTransactionToPurge;
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doPurgeLogCheckScaleHdr" id="8a607716-b397-4d2c-943a-8ca8ec6981e7">
        <updating/>
        <source>doPurgeLogCheckScaleHdr() : Boolean protected, updating;
// -------------------------------------------
// Created Aug 2008 by cnwrs1 par17772
// -------------------------------------------
//9/11/17 jlgns1 TFS 6960 QNS - Disk space issues and house keeping inside JMT
vars
	obj : Object;
	logCheckScaleHdr : CM_LogCheckScaleHdr;
	errCode : Integer;
	errTxt : String;
	rtnCode : Boolean;
	count, theSize : Integer;
begin

	on Exception do app.alertExceptionHandler(exception, null, app.getErrorString(Garbage_Collection), errCode, errTxt, true, false);
	
	self.createActivityHistory(app.getErrorString(Database_Purging)&amp;' '&amp;"Log Scale Header for terminal "&amp;self.myTerminal.code, false, false);
	theSize := self.myTerminal.allLogChkScaleByDt.size;
	foreach obj in self.myTerminal.allLogChkScaleByDt do
		logCheckScaleHdr := obj.CM_LogCheckScaleHdr;
		if logCheckScaleHdr.dateTime &gt; self.date.TimeStamp.cnEcAddDays(1) then
			break;
		endif;
		count := count + 1;
		errTxt := null;
		self.doInitiateProcess();
		if count mod Commit_Block_Size_Large = 0 then
			if self.abort() then
				return false;
			endif;
			
			if count mod Activity_Progress_Count_Large = 0 then
				self.createActivityHistory("Processed "&amp;count.String&amp;" of "&amp;theSize.String, false, true);
			endif;
		endif;
		app.myTrxDA.trxDeleteCheckScalingBatch(logCheckScaleHdr, app.myPassport);
		// Will get here if trx has been unsuccessful due to abort.
		rtnCode := self.isToAbort or self.abort();
		if rtnCode then
			return false;
		endif;
		if errTxt &lt;&gt; null then
			self.allErrors.add(errTxt);
		endif;
		self.createActivityHistory(null, false, false);
		self.doCheckForError();
	endforeach;
	self.createActivityHistory("Purged "&amp;theSize.String&amp;" Log Check Scale Header records.", false, false);
	return true;
end;
</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doPurgeMachineHistory" id="9d9105ae-3e25-48c0-bc5e-b3092cb19c48">
        <updating/>
        <source>doPurgeMachineHistory() : Boolean protected, updating;
// -------------------------------------------
// Created 23 August 2004 by cnwdvb1
// -------------------------------------------
//9/11/17 jlgns1 TFS 6960 QNS - Disk space issues and house keeping inside JMT
vars

	machine			: CM_Machine;
	interfaceDef	: CM_InterfaceDefinition;
	errCode			: Integer;
	errTxt			: String;
	count, theSize : Integer;
begin

	on Exception do app.alertExceptionHandler(exception, null, app.getErrorString(Garbage_Collection), errCode, errTxt, true, false);
	
	self.doInitiateProcess;
	self.createActivityHistory(app.getErrorString1(Databas_purging_message_histor, 'Machines'), false, false);
	theSize := self.myTerminal.machines.size;
	foreach machine in self.myTerminal.machines do
		count := count + 1;
		if count mod Commit_Block_Size_Large = 0 then
			if self.abort() then
				return false;
			endif;
			
			if count mod self.Activity_Progress_Count_Large = 0 then
				self.createActivityHistory(app.getErrorString3(Processed_x_of_y_things, count.String, theSize.String, 'Machines'), false, true);
			endif;
		endif;
		app.myTrxDA.trxDeleteDBPurgeMachineHistory(machine, self.date.TimeStamp, self, app.myPassport);
		if self.abort() then
			return false;
		endif; 
		self.createActivityHistory(null, false, false);
	endforeach;
	self.createActivityHistory(app.getErrorString2(Processed_x_things, theSize.String, 'Machines'), false, false);
	
	//+ cnwmd1 CCMS 1014 RDT ITS Interface - Remove Messages from each Interface
	self.doInitiateProcess;
	self.createActivityHistory(app.getErrorString1(Databas_purging_message_histor, 'Interface Definitions'), false, false);
	theSize := self.myTerminal.allInterfaceDefinitions.size;
	foreach interfaceDef in self.myTerminal.allInterfaceDefinitions do
		count := count + 1;
		if count mod Commit_Block_Size_Large = 0 then
			if self.abort() then
				return false;
			endif;

			if count mod self.Activity_Progress_Count_Large = 0 then
				self.createActivityHistory(app.getErrorString3(Processed_x_of_y_things, count.String, theSize.String, 'Interface Definitions'), false, true);
			endif;
		endif;
		app.myTrxDA.trxDeleteInterfaceMssgeHistory(interfaceDef, self.date.TimeStamp, self, app.myPassport);
		if self.abort() then
			return false;
		endif;
		self.createActivityHistory(null, false, false);
	endforeach;
	self.createActivityHistory(app.getErrorString2(Processed_x_things, theSize.String, 'Interface Definitions'), false, false);
	//cnwmd1 CCMS 1014 RDT ITS Interface - End of changes
	
	return true;
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doPurgeMenuUserItems" id="290c0294-36d7-4764-bac6-b50f7d168ce3">
        <updating/>
        <source>doPurgeMenuUserItems() : Boolean protected, updating;
// -------------------------------------------
// Created Aug 2008 by cnwrs1 par17772
// -------------------------------------------
//9/11/17 jlgns1 TFS 6960 QNS - Disk space issues and house keeping inside JMT

vars

	allMenuUserItemsToPurge : DynaDictionary;
	obj : Object;
	jmtReport : CM_JadeReport;
	menuItemReport : CM_MenuUserItem;
	errCode : Integer;
	errTxt : String;
	rtnCode : Boolean;
	count, theSize : Integer;
begin

	on Exception do app.alertExceptionHandler(exception, null, app.getErrorString(Garbage_Collection), errCode, errTxt, true, false);
	create allMenuUserItemsToPurge transient;
	/*
	
	PAR 22361 - These should be deleted as part of CM_MenuUserReport deletion below
	
	
	self.createActivityHistory(app.getErrorString(Database_Purging)&amp;' '&amp;"JMT Report", false, false);
	allMenuUserItemsToPurge.setMembership(CM_JadeReport);
	allMenuUserItemsToPurge.addMemberKey(CM_JadeReport::timeStamp.name, false, false);
	allMenuUserItemsToPurge.endKeys(true);
	self.getJadeReportsOldThanDate(allMenuUserItemsToPurge);
	theSize := allMenuUserItemsToPurge.size;
	foreach obj in allMenuUserItemsToPurge do
		count := count + 1;
		errTxt := null;
		self.doInitiateProcess();
		jmtReport := obj.CM_JadeReport;
		if count mod Commit_Block_Size_Medium = 0 then
			if self.abort() then
				return false;
			endif;
			process.sleep(self.sleepInterval);
			if count mod Activity_Progress_Count_Small = 0 then
				self.createActivityHistory("Processed "&amp;count.String&amp;" of "&amp;theSize.String, false, true);
			endif;
		endif;
		app.myTrxDA.trxDeleteJMTReport(jmtReport, app.myPassport);
		// Will get here if trx has been unsuccessful due to abort.
		rtnCode := self.isToAbort or self.abort();
		if rtnCode then
			return false;
		endif;
		if errTxt &lt;&gt; null then
			self.allErrors.add(errTxt);
		endif;
		self.createActivityHistory(null, false, false);
		self.doCheckForError();
	endforeach;
	self.createActivityHistory("Purged "&amp;theSize.String&amp;" JMT Report records.", false, false);
	*/

	//allMenuUserItemsToPurge.clear;
	count := 0;
	self.createActivityHistory(app.getErrorString(Database_Purging)&amp;' '&amp;"Saved Reports", false, false);
	allMenuUserItemsToPurge.setMembership(CM_MenuUserReport);
	allMenuUserItemsToPurge.addMemberKey(CM_Object::createdTime.name, false, false);
	allMenuUserItemsToPurge.endKeys(true);
	
	self.getMenuIUserItemOlderThanDate(allMenuUserItemsToPurge, CM_MenuUserReport);
	
	theSize := allMenuUserItemsToPurge.size;
	foreach obj in allMenuUserItemsToPurge do
		count := count + 1;
		errTxt := null;
		self.doInitiateProcess();
		menuItemReport := obj.CM_MenuUserReport;
		if count mod Commit_Block_Size_Medium = 0 then
			if self.abort() then
				return false;
			endif;
			
			if count mod Activity_Progress_Count_Small = 0 then
				self.createActivityHistory("Processed "&amp;count.String&amp;" of "&amp;theSize.String, false, true);
			endif;
		endif;
		app.myTrxDA.trxDeleteMenuUserItem(menuItemReport, app.myPassport);
		// Will get here if trx has been unsuccessful due to abort.
		rtnCode := self.isToAbort or self.abort();
		if rtnCode then
			return false;
		endif;
		if errTxt &lt;&gt; null then
			self.allErrors.add(errTxt);
		endif;
		self.createActivityHistory(null, false, false);
		self.doCheckForError();
	endforeach;
	self.createActivityHistory("Purged "&amp;theSize.String&amp;" Saved Reports.", false, false);
	
	
	/*
	
	PAR 22361 - do NOT delete users queries!
	
	allMenuUserItemsToPurge.clear;
	count := 0;
	self.createActivityHistory(app.getErrorString(Database_Purging)&amp;' '&amp;"Menu User Query", false, false);
	allMenuUserItemsToPurge.setMembership(CM_MenuUserQuery); //cnwrs1 Par19335 Mar 2009
	allMenuUserItemsToPurge.addMemberKey(CM_Object::createdTime.name, false, false);
	allMenuUserItemsToPurge.endKeys(true);
	self.getMenuIUserItemOlderThanDate(allMenuUserItemsToPurge, CM_MenuUserQuery);
	theSize := allMenuUserItemsToPurge.size;
	foreach obj in allMenuUserItemsToPurge do
		count := count + 1;
		errTxt := null;
		self.doInitiateProcess();
		menuItemReport := obj.CM_MenuUserItem;
		if count mod Commit_Block_Size_Medium = 0 then
			if self.abort() then
				return false;
			endif;
			process.sleep(self.sleepInterval);
			if count mod Activity_Progress_Count_Small = 0 then
				self.createActivityHistory("Processed "&amp;count.String&amp;" of "&amp;theSize.String, false, true);
			endif;
		endif;
		app.myTrxDA.trxDeleteMenuUserItem(menuItemReport, app.myPassport);
		// Will get here if trx has been unsuccessful due to abort.
		rtnCode := self.isToAbort or self.abort();
		if rtnCode then
			return false;
		endif;
		if errTxt &lt;&gt; null then
			self.allErrors.add(errTxt);
		endif;
		self.createActivityHistory(null, false, false);
		self.doCheckForError();
	endforeach;
	
	
	self.createActivityHistory("Purged "&amp;theSize.String&amp;" Menu User Queries.", false, false);
	*/
	
	
return true;
epilog
	delete allMenuUserItemsToPurge;
end;</source>
