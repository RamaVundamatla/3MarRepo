<Class name="UC_UnitTest" id="0cf3df58-c813-4d98-9f4d-6a9f369b2cb0">
    <superclass name="UC_Controller"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="unitTest"/>
    <JadeMethod name="addClassToTree" id="c10373eb-acc9-4028-871e-21138f350fae">
        <source>addClassToTree(_klass: Class; _level: Integer; _vm: VM_UnitTest io) protected;
//02 June 2009	cnwdw1	
//
vars
	subklass: Class;
	meth: Method;
	index: Integer;
	parent: Integer;
	allSubclasses: ClassColl;
	allMethods: MethodSet;
	methodsByName: DynaDictionary;
	obj: Object;
begin
	
	_vm.testNames.add(_klass.name);
	_vm.testObjects.add(_klass);
	_vm.testLevels.add(_level);

	create allSubclasses transient;
	_klass.getSubclasses(allSubclasses);
	_klass.allSubclassesInSubschemas(allSubclasses);
	foreach subklass in allSubclasses do
		if subklass.getSuperclass = _klass then
			self.addClassToTree(subklass, _level + 1, _vm);
		endif;
	endforeach;
	
	create allMethods transient;
	self.getAllMethods(_klass, allMethods, _vm.rootTestSchemaName);
	create methodsByName transient;
	methodsByName.setMembership(Method);
	methodsByName.addMemberKey("name", false, true);
	methodsByName.endKeys(false);
	allMethods.copy(methodsByName);
	
	foreach obj in methodsByName do
		meth := obj.Method;
		if self.isUnitTest(meth) 
		or self.isIgnoreTest(meth) 
		or self.isUtilityTest(meth) then
			_vm.testNames.add(meth.name[2:end]);
			_vm.testObjects.add(meth);
			_vm.testLevels.add(_level + 1);
		endif;
	endforeach;	
	
epilog
	delete methodsByName;
	delete allMethods;
	delete allSubclasses;
end;</source>
        <access>protected</access>
        <Parameter name="_klass" type="Class"/>
        <Parameter name="_level" type="Integer"/>
        <Parameter name="_vm" type="VM_UnitTest" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getAllMethods" id="bf437065-e084-4a37-8ead-840ae0ee8e83">
        <source>getAllMethods(_klass: Class; _methods: MethodSet io; _rootTestSchemaName: String) protected;
//07 January 2009	cnwdw1	
//
vars
	baseSchema, schema: Schema;
	schemas: SchemaColl;
	klass: Class;
	methods: MethodSet;
	meth: Method;
begin
	baseSchema := rootSchema.getSchema(_rootTestSchemaName);
	if baseSchema &lt;&gt; null then
		baseSchema.withAllSubschemas(schemas);
	endif;
	
	create methods transient;
	foreach schema in schemas do
		klass := schema.getClass(_klass.name);
		if klass &lt;&gt; null then
			methods.clear;
			klass.allMethods(methods);
			foreach meth in methods do
				if _methods.includes(meth) then
					continue;
				endif;
				if app.isUnitTestMethod(meth) then
					_methods.add(meth);
				endif;
			endforeach;
		endif;
	endforeach;
	
epilog
	delete methods;
end;</source>
        <access>protected</access>
        <Parameter name="_klass" type="Class"/>
        <Parameter name="_methods" type="MethodSet" usage="io"/>
        <Parameter name="_rootTestSchemaName" type="String"/>
    </JadeMethod>
    <JadeMethod name="getTests" id="61b83790-f297-4f1e-8010-8bf54a43f44b">
        <updating/>
        <source>getTests(_rootUnitTestClass: Class; _rootSchemaName: String): VM_ViewModel updating;
//02 June 2009	cnwdw1	
//
vars
	vm: VM_UnitTest;
begin
	self.createViewModel(VM_UnitTest);
	vm := self.viewModel.VM_UnitTest;
	vm.rootTestSchemaName := "JMTUnitTest";
	self.addClassToTree(_rootUnitTestClass, 0, vm);

	return self.viewModel;

epilog
end;</source>
        <Parameter name="_rootUnitTestClass" type="Class"/>
        <Parameter name="_rootSchemaName" type="String"/>
        <ReturnType type="VM_ViewModel"/>
    </JadeMethod>
    <JadeMethod name="isIgnoreTest" id="10dc69fa-73d5-4a9a-bd56-4dd4401422f3">
        <source>isIgnoreTest(_meth: Method): Boolean;
//19 December 2008	cnwdw1	
//
begin
	return _meth.name[1] = "i" and _meth.name[2].isUpper;
end;</source>
        <Parameter name="_meth" type="Method"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isUnitTest" id="cf83abb3-4c02-4497-86e5-82342952a156">
        <source>isUnitTest(_meth: Method): Boolean;
//19 December 2008	cnwdw1	
//
begin
	return _meth.name[1] = "t" and _meth.name[2].isUpper;
end;</source>
        <Parameter name="_meth" type="Method"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isUtilityTest" id="67905997-a31f-4819-b2ed-45acaaa79d20">
        <source>isUtilityTest(_meth: Method): Boolean;
//19 December 2008	cnwdw1	
//
begin
	return _meth.name[1] = "u" and _meth.name[2].isUpper;
end;</source>
        <Parameter name="_meth" type="Method"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
