    <JadeMethod name="tblData_dblClick" id="cab381b2-85d4-445a-9a6a-f9f47a226ab9">
        <controlMethod name="CM_DataTable::dblClick"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblData_dblClick(table: Table input) updating;
/*
Purpose:	

Date		Who		Reason
19 July 2024	navab1	CR 64612 TASK 64659
*/

vars

begin

	if table.row &gt; table.fixedRows then
		return;
	endif;

	if table.sortColumn[1] &gt; 0 then
		table.accessCell(1,table.sortColumn[1]).fontBold := false;
	endif;

	table.CM_DataTable.resortTableByColumn(table.column);

	table.accessCell(1,table.column).fontBold := true;

epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="9c1c7023-78f7-475b-8e9a-29cd14260b31">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 18 March 2025 13:26:35.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0026929, locale);
	btnClear.translateCaption(Xlat_0026930, locale);
	btnClose.translateCaption(Xlat_0026931, locale);
	btnManualCompare.translateCaption(Xlat_0026992, locale);
	btnSearch.translateCaption(Xlat_0026932, locale);
	chkPauseAutoProcess.translateCaption(Xlat_0026971, locale);
	chkShowColours.translateCaption(Xlat_0026933, locale);
	lblEnd.translateCaption(Xlat_0026934, locale);
	lblOperator.translateCaption(Xlat_0026935, locale);
	lblStart.translateCaption(Xlat_0026936, locale);
	lblStatus.translateCaption(Xlat_0026937, locale);
	mnuCargoComparison.translateCaption(Xlat_0027058, locale);
	mnuColumnOrganiser.translateCaption(Xlat_0026938, locale);
	mnuCompareErrors.translateCaption(Xlat_0026993, locale);
	mnuContext.translateCaption(Xlat_0026939, locale);
	mnuInspectObject.translateCaption(Xlat_0026940, locale);
end;</source>
    </JadeMethod>
