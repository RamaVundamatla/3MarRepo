    <JadeMethod name="getDisplayStringForAttribute" id="1e405eae-2763-4903-8189-144c52094771">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
// ---------------------------------------------------------------------------
// Created:     14 January 2003		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin
	if _attrName = ETRow_TruckNumber then
		return self.truckId;
	
	elseif _attrName = ETRow_NumItems then
		return self.numPieces.String;
		
	elseif _attrName = ETRow_GradeLength then
		return null;
	
	elseif _attrName = ETRow_Suppl then
		return self.operatorCode;
		
	elseif _attrName = ETRow_Dkt then
		return self.docketNumber;
	
	elseif _attrName = ETRow_WeighDocketNo then
		return self.docketNumberWeigh;
		
	elseif _attrName = ETRow_LogLocation then
		return self.yardLocation;
		
	elseif _attrName = ETRow_RegNumber then
		return self.regNo;
		
	elseif _attrName = ETRow_Supplier then
		return self.operatorCode;
		
	elseif _attrName = ETRow_FellDate then
		return self.date.asStringJMT();
	
	elseif _attrName = ETRow_Activity then
		return self.truckCategory;

	elseif _attrName = ETRow_GradeLength then
		return self.logGradeCode &amp; ':' &amp; self.lengthRandom;
		
	elseif _attrName = ETRow_WeightGrossTonnes then
		return ((self.weightGross /1000).max(0)).asStringJMT();
		
	elseif _attrName = ETRow_WeightNetTonnes then
		return ((self.weightNett /1000).max(0)).asStringJMT();
		
	elseif _attrName = ETRow_WeightTareTonnes then
		return ((self.weightTare /1000).max(0)).asStringJMT();
		
	elseif _attrName = ETRow_PickerType then	//15 Mar 2017	NDL	TFS 3758
		return self.class.String;
		
	elseif _attrName = ETRow_PickerDescription then	//15 Mar 2017	NDL	TFS 3758
		return self.cargoBOLType.String;
		
	elseif _attrName = ETRow_PickerId then	//15 Mar 2017	NDL	TFS 3758
		return self.regNo;
		
	endif;
	
	return inheritMethod(_attrName, _short);


end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setCommonForCreateUpdate" id="6b006796-7375-41af-bc84-c902ee0653fe">
        <updating/>
        <source>setCommonForCreateUpdate(_pxyLogDocketData : SelfType) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 December 2014	cnwmc5	Initial creation

*/

vars

begin
	//cnwmc5 - 7 August 2014 - PAR 34697
	if _pxyLogDocketData.docketNumberWeigh &lt;&gt; null then
		self.docketNumberWeigh	:= _pxyLogDocketData.docketNumberWeigh;
	else
		self.docketNumberWeigh 	:= self.getOidString();
	endif;
	self.cargoBOLType 			:= _pxyLogDocketData.cargoBOLType;
	
	self.backload				:= _pxyLogDocketData.backload;
	self.carrierCode			:= _pxyLogDocketData.carrierCode;
	self.chhSupplier			:= _pxyLogDocketData.chhSupplier;
	self.compartment			:= _pxyLogDocketData.compartment;
	self.consignorCode			:= _pxyLogDocketData.consignorCode;
	self.customer				:= _pxyLogDocketData.customer;
	self.docketError			:= _pxyLogDocketData.docketError;
	self.docketNumber 			:= _pxyLogDocketData.docketNumber;
	self.driverId				:= _pxyLogDocketData.driverId;
	self.driversPieceCountError	:= _pxyLogDocketData.driversPieceCountError;
	self.date					:= _pxyLogDocketData.date;
	self.forest					:= _pxyLogDocketData.forest;
	self.isFSC					:= _pxyLogDocketData.isFSC;
	self.loggingGang			:= _pxyLogDocketData.loggingGang;
	self.logGradeCode			:= _pxyLogDocketData.logGradeCode;
	self.jasScaled				:= _pxyLogDocketData.jasScaled;
	self.lengthRandom			:= _pxyLogDocketData.lengthRandom;
	self.loaderNumber			:= _pxyLogDocketData.loaderNumber;
	self.loadingContractor		:= _pxyLogDocketData.loadingContractor;
	self.logTypeCode			:= _pxyLogDocketData.logTypeCode;
	self.loggingContractor		:= _pxyLogDocketData.loggingContractor;
	self.loggingOperation		:= _pxyLogDocketData.loggingOperation;
	self.loggingOrganisation	:= _pxyLogDocketData.loggingOrganisation;
	self.nightshift				:= _pxyLogDocketData.nightshift;
	self.numPieces				:= _pxyLogDocketData.numPieces;
	self.numberOfLifts			:= _pxyLogDocketData.numberOfLifts;
	self.operatorCode			:= _pxyLogDocketData.operatorCode;
	self.opid					:= _pxyLogDocketData.opid;
	self.percentScaled			:= _pxyLogDocketData.percentScaled;
	self.pickupPoint			:= _pxyLogDocketData.pickupPoint;
	self.pieceCountError		:= _pxyLogDocketData.pieceCountError;
	self.receiptRequired		:= _pxyLogDocketData.receiptRequired;
	self.remarks				:= _pxyLogDocketData.remarks;
	self.scalerCode				:= _pxyLogDocketData.scalerCode;
	self.logSpeciesCode			:= _pxyLogDocketData.logSpeciesCode;
	self.stand					:= _pxyLogDocketData.stand;
	self.ticketedAll			:= _pxyLogDocketData.ticketedAll;
	self.trailerNumber			:= _pxyLogDocketData.trailerNumber;
	self.logTreatmentCode		:= _pxyLogDocketData.logTreatmentCode;
	self.truckCategory			:= _pxyLogDocketData.truckCategory;
	self.truckId				:= _pxyLogDocketData.truckId;
	self.unloadPoint			:= _pxyLogDocketData.unloadPoint;
	self.regNo					:= _pxyLogDocketData.regNo;
	self.weighbridge			:= _pxyLogDocketData.weighbridge;
	self.weightGross			:= _pxyLogDocketData.weightGross;
	self.weightNett				:= _pxyLogDocketData.weightNett;
	self.weightTare				:= _pxyLogDocketData.weightTare;
	self.yardLocation			:= _pxyLogDocketData.yardLocation;
	
	self.myTerminal				:= _pxyLogDocketData.myTerminal;
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_pxyLogDocketData" type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="88a84b9e-6368-4b09-a8cf-e0b88fe4fbaa">
        <updating/>
        <source>setForCreate(_pxyLogDocketData : SelfType) updating;
// ---------------------------------------------------------------------------
// Created:     13 January 2003		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	pxyTicketSeqeunceData,
	ticketSeqeunceData		: CM_TicketSequenceData;
begin
	
	self.setCommonForCreateUpdate(_pxyLogDocketData);
	
	foreach pxyTicketSeqeunceData in _pxyLogDocketData.allTicketSequenceData do
		create ticketSeqeunceData persistent;
		ticketSeqeunceData.setForCreate(pxyTicketSeqeunceData);
		ticketSeqeunceData.setMyLogDocketData(self);
	endforeach;
	
epilog

end;</source>
        <Parameter name="_pxyLogDocketData" type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="86bd8a28-52aa-4f91-8ba1-320e17057739">
        <updating/>
        <source>setForUpdate(_pxyLogDocketData : SelfType) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 December 2014	cnwmc5	Initial creation

*/

vars
	pxyTicketSequenceData,
	ticketSequenceData			: CM_TicketSequenceData;
	
	ticketSequenceDataDelete	: CM_TicketSequenceDataSet;
	
begin
	
	self.setCommonForCreateUpdate(_pxyLogDocketData);
	
	create ticketSequenceDataDelete transient;
	self.allTicketSequenceData.copy(ticketSequenceDataDelete);
	
	foreach pxyTicketSequenceData in _pxyLogDocketData.allTicketSequenceData do
		ticketSequenceData := pxyTicketSequenceData.pxyGetRealObject();
		if ticketSequenceData &lt;&gt; null then
			ticketSequenceData.setForCreate(pxyTicketSequenceData);
			ticketSequenceDataDelete.remove(ticketSequenceData);
		else
			create ticketSequenceData persistent;
			ticketSequenceData.setForCreate(pxyTicketSequenceData);
			ticketSequenceData.setMyLogDocketData(self);
		endif;
	endforeach;
	
	foreach ticketSequenceData in ticketSequenceDataDelete do
		ticketSequenceData.erase(NORMAL_ERASE);
	endforeach;
	
epilog
	delete ticketSequenceDataDelete;
end;</source>
        <Parameter name="_pxyLogDocketData" type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setIntFaceBOLIn" id="16c5f36e-0862-42cd-a2d9-43dfb6ff95fe">
        <source>setIntFaceBOLIn(_intFaceBOLIn : CMIF_BOLIn input; _pxyBOL : CM_BOLIn);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 November 2014	cnwmc5	Initial creation

mySubTermial
consigneeCode

*/

vars
	operator 			: CM_Operator;
	tmpDocketErrorType 	: CM_DocketErrorType;
	pxyDocketError		: CM_DocketError;
	foundHeight			: Integer;
	
	species				: CM_LogSpecies;
	grade				: CM_LogGrade;
	length				: CM_LogLength;
	logType				: CM_LogType;
	treament			: CM_LogTreatment;
	
	tmpCompare			: CMIF_SearchTypes;
	allLogLocations		: CM_LCByIdExtKeyDict;
	logLocation			: CM_LocationsController;
	
	realBlock			: CM_TerminalArea;
	
	yardTokens			: StringArray;
	block				: String;
	row					: String;
	
	ticketSequenceData	: CM_TicketSequenceData;
	ticketSequence		: CM_TicketSequence;
	
	quantity			: Integer;
	
begin
	_intFaceBOLIn.bolType 		:= BOLType_Log;
	_intFaceBOLIn.transportMode := TI_TRANSMODE_ROAD;
	
	//_intFaceBOLIn := self.cargoBOLType;
	//_intFaceBOLIn. := self.pieceCountError;
	_intFaceBOLIn.backload 				:= self.backload;
	_intFaceBOLIn.carrierCode 			:= self.carrierCode;
	_intFaceBOLIn.chhSupplier 			:= self.chhSupplier;
	_intFaceBOLIn.compartment 			:= self.compartment;
	_intFaceBOLIn.consignorCode 		:= self.consignorCode;
	_intFaceBOLIn.customer 				:= self.customer;
	_intFaceBOLIn.fellDate 				:= self.date;
	_intFaceBOLIn.bolNumber 			:= self.docketNumber;
	_intFaceBOLIn.weighbridge 			:= self.docketNumberWeigh;
	_intFaceBOLIn.driversPieceCount 	:= self.driversPieceCountError;
	_intFaceBOLIn.forest 				:= self.forest;
	_intFaceBOLIn.isFSC 				:= self.isFSC;
	_intFaceBOLIn.jasScaled 			:= self.jasScaled;
	_intFaceBOLIn.lengthRandom 			:= self.lengthRandom;
	_intFaceBOLIn.loaderNumber 			:= self.loaderNumber;
	_intFaceBOLIn.handlingContractor1 	:= self.loadingContractor;
	_intFaceBOLIn.logGradeCode 			:= self.logGradeCode;
	_intFaceBOLIn.logSpeciesCode 		:= self.logSpeciesCode;
	_intFaceBOLIn.logTreatmentCode 		:= self.logTreatmentCode;
	_intFaceBOLIn.logTypeCode 			:= self.logTypeCode;
	_intFaceBOLIn.handlingContractor2 	:= self.loggingContractor;
	_intFaceBOLIn.gangNumber 			:= self.loggingGang;
	_intFaceBOLIn.loggingOperation 		:= self.loggingOperation;
	_intFaceBOLIn.loggingOrganisation 	:= self.loggingOrganisation;
	_intFaceBOLIn.myTerminal 			:= self.myTerminal;
	_intFaceBOLIn.nightshift 			:= self.nightshift;
	_intFaceBOLIn.numItems 				:= self.numPieces;
	_intFaceBOLIn.numberOfLifts 		:= self.numberOfLifts;
	_intFaceBOLIn.operatorCode 			:= self.operatorCode;
	_intFaceBOLIn.opid 					:= self.opid;
	_intFaceBOLIn.percentScaled 		:= self.percentScaled;
	_intFaceBOLIn.pickupPoint 			:= self.pickupPoint;
	_intFaceBOLIn.regNumber 			:= self.regNo;
	_intFaceBOLIn.remarks 				:= self.remarks;
	_intFaceBOLIn.scalerCode 			:= self.scalerCode;
	_intFaceBOLIn.stand 				:= self.stand;
	_intFaceBOLIn.ticketedAll 			:= self.ticketedAll;
	_intFaceBOLIn.trailerNumber 		:= self.trailerNumber;
	_intFaceBOLIn.activity 				:= self.truckCategory;
	_intFaceBOLIn.truckNumber 			:= self.truckId;
	_intFaceBOLIn.unloadPoint 			:= self.unloadPoint;
	_intFaceBOLIn.weighbridge 			:= self.weighbridge;
	_intFaceBOLIn.weightGrossTonnes 	:= self.weightGross / 1000;		//cnwmc5 - 3 Oct 2016 - TFS 
	_intFaceBOLIn.weightNetTonnes 		:= self.weightNett / 1000;		//cnwmc5 - 3 Oct 2016 - TFS 
	_intFaceBOLIn.weightTareTonnes 		:= self.weightTare / 1000;		//cnwmc5 - 3 Oct 2016 - TFS 
	_intFaceBOLIn.logLocation 			:= self.yardLocation;
	
	_intFaceBOLIn.sourceLocation		:= _intFaceBOLIn.forest;
	_intFaceBOLIn.sourceSubLocation		:= _intFaceBOLIn.compartment;
	_intFaceBOLIn.sourceSubSubLocation	:= _intFaceBOLIn.stand;		
	operator := app.myRoot.allOperators[self.operatorCode];
	if operator &lt;&gt; null then
		_intFaceBOLIn.myOperator := operator;
	endif;
	
	if self.logSpeciesCode &lt;&gt; null then
		species := operator.getLogSpecies(self.logSpeciesCode);
	endif;
	
	if species &lt;&gt; null and self.logGradeCode &lt;&gt; null then
		grade := operator.getLogGrade(species.code, self.logGradeCode);
	endif;
	
	if species &lt;&gt; null and grade &lt;&gt; null then
		if self.lengthRandom &lt;&gt; null then
			length := operator.getLogLengthForGrade(species.code, grade.code, self.lengthRandom);
		endif;
		
		if self.logTypeCode &lt;&gt; null then
			logType := operator.getLogTypeForGrade(species.code, grade.code, self.logTypeCode);
		endif;
		
		if self.logTreatmentCode &lt;&gt; null then
			treament := operator.getLogTreatmentForGrade(species.code, grade.code, self.logTreatmentCode);
		endif;
	endif;
	
	if self.yardLocation &lt;&gt; null then
		create yardTokens transient;
		self.yardLocation.getTokensForDelimiter(" ", yardTokens);
		
		if yardTokens.size &gt; 1 then
			block := yardTokens[1];
			row := yardTokens[2];
			
			create tmpCompare transient;
			create allLogLocations transient;
			
			tmpCompare.myOperator	:= operator;
			tmpCompare.mySpecies	:= species;
			tmpCompare.myGrade		:= grade;
			tmpCompare.myType 		:= logType;
			tmpCompare.myTreatment	:= treament;
			tmpCompare.myLength		:= length;
			
			realBlock := self.myTerminal.allTerminalAreas[block];
			if realBlock &lt;&gt; null then
				realBlock.availableLocationsForType(tmpCompare, allLogLocations);
			endif;
			
			if allLogLocations.size &gt; 0 then
				logLocation := allLogLocations[row];
				if logLocation &lt;&gt; null then
					_intFaceBOLIn.myPlannedLocation := logLocation;
				endif;
			endif;
		endif;
	endif;
	
	if _pxyBOL &lt;&gt; null then
		tmpDocketErrorType := app.myRoot.allDocketErrorTypes[self.docketError];
		if tmpDocketErrorType = null then
			_pxyBOL.allDocketErrors.purge;
		else
			pxyDocketError := _pxyBOL.allDocketErrors.first;	// if proxy docket error exists, then we will update existing real docket error
			if pxyDocketError = null then						// if proxy docket error = null, it means - user created a new docket error
				create pxyDocketError transient;
				pxyDocketError.setMyBol(_pxyBOL);
				
			endif;
			_intFaceBOLIn.allDocketErrors.add(pxyDocketError);
			pxyDocketError.setMyDocketErrorType(tmpDocketErrorType);	// setting docket error type according to UI screen
		endif;
	else
		tmpDocketErrorType := app.myRoot.allDocketErrorTypes[self.docketError];
		if tmpDocketErrorType &lt;&gt; null then
			create pxyDocketError transient;
			pxyDocketError.setMyDocketErrorType(tmpDocketErrorType);	
			_intFaceBOLIn.allDocketErrors.add(pxyDocketError);    // 28/10/2016 cnwma1 TFS #2838:PAR38327 
		endif;
	endif;
	
	foreach ticketSequenceData in self.allTicketSequenceData do
		create ticketSequence transient;
		quantity := (ticketSequenceData.toId.Integer - ticketSequenceData.fromId.Integer) + 1;
		ticketSequence.setProxy(ticketSequenceData.fromId,
								ticketSequenceData.toId,
								quantity,
								ticketSequenceData.scale);
		_intFaceBOLIn.allTicketSequences.add(ticketSequence);
	endforeach;
	
epilog
	//cnwmc5 - 18 Dec 2014 - PAR 35436
	delete yardTokens;
	delete tmpCompare;
	delete allLogLocations;
end;</source>
        <Parameter name="_intFaceBOLIn" type="CMIF_BOLIn" usage="input"/>
        <Parameter name="_pxyBOL" type="CM_BOLIn"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="cadde571-79fb-47f3-b3d7-50969d5ebd0a">
        <updating/>
        <source>setProxy(	_backload : String;
			_carrierCode : String;
			_chhSupplier : String;
			_compartment : String;
			_consignorCode : String;
			_customer : String;
			_docketError : String;
			_docketNumber : String;
			_driverId : String;
			_driversPieceCountError : Integer;
			_fellingDate : Date;
			_forest : String;
			_fsc : Boolean;
			_gangNumber : String;
			_grade : String;
			_jasScaled : Boolean;
			_length : String;
			_loaderNumber : String;
			_loadingContractor : String;
			_logType : String;
			_loggingContractor : String;
			_loggingOperation : String;
			_loggingOrganisation : String;
			_nightshift : Boolean;
			_numItems : Integer;
			_numberOfLifts : Integer;
			_operatorCode : String;
			_opid : String;
			_percentScaled : Integer;
			_pickupPoint : String;
			_pieceCountError : Boolean;
			_receiptRequired : Boolean;
			_remarks : String;
			_scalerCode : String;
			_species : String;
			_stand : String;
			_ticketedAll : Boolean;
			_trailerNumber : String;
			_treatment : String;
			_truckCategory : String;
			_truckNumber : String;
			_unloadPoint : String;
			_vehicleID : String;
			_weighbridge : String;
			_weightGross : Integer;
			_weightNet : Integer;
			_weightTare : Integer;
			_yardLocation : String;
			_terminal : CM_Terminal) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 March 2014	cnwmc5	Initial creation		CCMS C3 1127

*/

vars
	// cnwmc5 - 5 September 2014 - PAR 34853
	newYardLocation : String;
	pos				: Integer;
	
begin
	//self.docketNumberWeigh 		:= self.getOidString();			//cnwmc5 - 7 August 2014 - PAR 34697
	self.cargoBOLType 			:= BOLType_Log;
	
	self.backload				:= _backload;
	self.carrierCode			:= _carrierCode;
	self.chhSupplier			:= _chhSupplier;
	self.compartment			:= _compartment;
	self.consignorCode			:= _consignorCode;
	self.customer				:= _customer;
	self.docketError			:= _docketError;
	self.docketNumber 			:= _docketNumber;
	self.driverId				:= _driverId;
	self.driversPieceCountError	:= _driversPieceCountError;
	self.date					:= _fellingDate;
	self.forest					:= _forest;
	self.isFSC					:= _fsc;
	self.loggingGang			:= _gangNumber;
	self.logGradeCode			:= _grade;
	self.jasScaled				:= _jasScaled;
	self.lengthRandom			:= _length;
	self.loaderNumber			:= _loaderNumber;
	self.loadingContractor		:= _loadingContractor;
	self.logTypeCode			:= _logType;
	self.loggingContractor		:= _loggingContractor;
	self.loggingOperation		:= _loggingOperation;
	self.loggingOrganisation	:= _loggingOrganisation;
	self.nightshift				:= _nightshift;
	self.numPieces				:= _numItems;
	self.numberOfLifts			:= _numberOfLifts;
	self.operatorCode			:= _operatorCode;
	self.opid					:= _opid;
	self.percentScaled			:= _percentScaled;
	self.pickupPoint			:= _pickupPoint;
	self.pieceCountError		:= _pieceCountError;
	self.receiptRequired		:= _receiptRequired;
	self.remarks				:= _remarks;
	self.scalerCode				:= _scalerCode;
	self.logSpeciesCode			:= _species;
	self.stand					:= _stand;
	self.ticketedAll			:= _ticketedAll;
	self.trailerNumber			:= _trailerNumber;
	self.logTreatmentCode		:= _treatment;
	self.truckCategory			:= _truckCategory;
	self.truckId				:= _truckNumber;
	self.unloadPoint			:= _unloadPoint;
	self.regNo					:= _vehicleID;
	self.weighbridge			:= _weighbridge;
	self.weightGross			:= _weightGross;
	self.weightNett				:= _weightNet;
	self.weightTare				:= _weightTare;
	
	// cnwmc5 - 5 September 2014 - PAR 34853
	newYardLocation := _yardLocation.trimBlanks();
	if newYardLocation.cnContains(Space) then
		pos := 1;
		newYardLocation := newYardLocation.scanUntil(Space, pos);
		newYardLocation := newYardLocation &amp; Space &amp; _yardLocation.trimBlanks()[pos:end].trimBlanks();
	endif;
	self.yardLocation			:= newYardLocation;
	
	self.myTerminal				:= _terminal;
	
epilog

end;</source>
