    <JadeMethod name="txtTrailerNumber_lostFocus" id="1e2f084d-b828-4503-a99d-0f2e194aeb09">
        <controlMethod name="TextBox::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtTrailerNumber_lostFocus(textbox: TextBox input) updating;
// -----------------------------------------------------------------------------
// Created:		29 April 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
vars
	txtStr	: String;
begin
	txtStr := textbox.text;
	if self.origValueStr &lt;&gt; txtStr then
		self.getVehicleInfo(txtStr);
	endif;
end;</source>
