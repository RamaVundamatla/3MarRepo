    <JadeMethod name="createAlert" id="61b5517c-f801-405d-a3d8-7bb3d5206f24">
        <source>createAlert(_severity : Integer; _details : String);

vars
	string : String;
begin
	string := _details;
	
	app.myPassport.createAlert(_severity, string, EVENT_AT_ExternalInterface, null);
	app.commitAlert();
epilog

