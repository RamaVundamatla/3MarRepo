	return null;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getOtherFieldsStr" id="8859af48-0327-4ff5-9b57-120ed2c4f892">
        <source>getOtherFieldsStr(): String;
//----------------------------------------------------------------
//	Created:	10 December 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	obj		: Object;
	str		: String;
begin
	
	//key
	str := "(" &amp; self.getFieldKey.String;
	foreach obj in self.allFieldAdditionals do
		str := str &amp; "," &amp; obj.CM_EDIItemField.getFieldKey.String;
	endforeach;
	str := str &amp; ")";
	
	//name
	str := str &amp; " " &amp; self.name;
	foreach obj in self.allFieldAdditionals do
		str := str &amp; obj.CM_EDIItemField.name;
	endforeach;
	str := str &amp; " ";
	
	//return str plus the rest
	return str &amp; " &gt;&gt; " &amp; self.systemName &amp; "  {" &amp; self.stringFormatMethodName &amp; "}";

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="resetFieldsAdditional" id="57e383a8-c908-4c81-b01f-24d11057fd98">
        <updating/>
        <source>resetFieldsAdditional() updating;
//----------------------------------------------------------------
//	Created:	10 December 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin

	self.allFieldAdditionals.purge();

end;</source>
    </JadeMethod>
    <JadeMethod name="setFieldAdditionalFromXML" id="5809ece0-4cab-4ed6-bfb6-3be3fcafb368">
        <source>setFieldAdditionalFromXML(_xmlElement: JadeXMLElement);
//----------------------------------------------------------------
//	Created:	10 December 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	addItemField	: SelfType;
begin
	
	create addItemField as self.class persistent;
	
	addItemField.setFromXML(_xmlElement);
	//dont set myFileFormatEDI on this one - is set on the parent
	self.addFieldAdditional(addItemField);
	
end;</source>
        <Parameter name="_xmlElement" type="JadeXMLElement"/>
    </JadeMethod>
    <JadeMethod name="setFileFormat" id="4451d6f0-dcd8-441e-a290-0889bacb5121">
        <updating/>
        <source>setFileFormat(_fileFormat: CM_FileFormatEDI) updating;
//----------------------------------------------------------------
//	Created:	16 November 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin
	self.myFileFormatEDI := _fileFormat;

end;</source>
        <Parameter name="_fileFormat" type="CM_FileFormatEDI"/>
    </JadeMethod>
    <JadeMethod name="setFromXML" id="b05030c9-e909-42a9-9bfb-6284f5323e95">
        <updating/>
        <source>setFromXML(_xmlElement: JadeXMLElement) updating;
//----------------------------------------------------------------
//	Created:	16 November 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	xmlElement		: JadeXMLElement;
	addElements		: JadeXMLElementArray;
begin
	
	inheritMethod(_xmlElement);

	xmlElement := _xmlElement.getElementByTagName('AdditionalFields');
	if xmlElement &lt;&gt; null then
		create addElements transient;
		xmlElement.getAllElementsByTagName('AdditionalField', addElements);
		foreach xmlElement in addElements do
			self.setFieldAdditionalFromXML(xmlElement);
		endforeach;
	endif;


epilog
	delete addElements;
end;</source>
        <Parameter name="_xmlElement" type="JadeXMLElement"/>
    </JadeMethod>
