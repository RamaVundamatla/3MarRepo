    <JadeMethod name="testCommodityGroup" id="82981cac-c6bc-417f-82fa-91c52bd29d68">
        <source>testCommodityGroup(): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 December 2008	cnwer1	Initial creation

*/

vars
	commodityGroup : CM_CommodityGroup; 
begin
	if self.mySlotRequest = null then
		if self.myRORORequest = null then
			return false;
		else
			return self.myRORORequest.testCommodityGroup();
		endif;
	else
		return self.mySlotRequest.testCommodityGroup();
	endif;

	return false;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="testHazardous" id="2bd81178-c720-4149-92e0-27865aae9f85">
        <source>testHazardous(): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 December 2008	cnwer1	Initial creation

*/

vars

begin

	if self.mySlotRequest &lt;&gt; null and not self.mySlotRequest.getAttrHazardous() then
		return false;
	
	elseif self.myRORORequest &lt;&gt; null and not self.myRORORequest.getAttrHazardous() then
		return false;
	endif;
	
	
	return true;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="testHeavies" id="73c4fe3a-55fe-4e68-ba52-51753b93ea54">
        <source>testHeavies(): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 December 2008	cnwer1	Initial creation

*/

vars

begin
	if self.mySlotRequest = null then
		return false;
	endif;
	
	if self.myCMIF_ShipPlanner = null then
		return false;
	endif;
	
	if not self.myCMIF_ShipPlanner.getUseWeights then
		return false;
	endif;
	
	if not self.mySlotRequest.myJob.CM_VoyageJob.hasJobGotHeavies()  then
		return false;
	endif;
	
	return true;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="testOverDim" id="2c20d625-928a-4b55-9308-35127b1bcdd8">
