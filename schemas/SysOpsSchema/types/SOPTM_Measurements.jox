    <JadeMethod name="doSave" id="0b3b2058-7f1f-4b3d-a66b-24de9257f14b">
        <updating/>
        <source>doSave(): Boolean updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14 Feb 2013	cnwrd1	Initial creation
14 Mar 2014	cnwdap1	PAR #33603 Can't typecast as a Decimal, as we lose data if locale uses a non-period decimal separator
14 Nov 2022	navma1	ChangeRequest 55381: MTN - Store format's decimal precision on Measurement Type
*/

vars
	proxyMeasurementType	: CM_MeasurementType;
	theForm					: SOP_TableMaintForm;
	lConversionRate			: Decimal[18,10];
	lFormat 				: Decimal[3,1];
	lIsAvailable,
	lIsDefault,
	lIsDisplay,
	lIsSystemType			: Boolean;
	lSName,
	lType,
	lName					: String;
	tbl 					: CM_EntryTable;
	lformatPrecision        : Integer;
begin
	
    theForm := self.myForm; 
	tbl     := theForm.tblInput1;
	
	lConversionRate := tbl.getValueByName(ETRow_Conversion).String.asDecimalJMT;			// APR #33603
	lFormat 		:= tbl.getValueByName(ETRow_Format).String.asDecimalJMT;				// APR #33603
	
	lIsAvailable 	:= tbl.getValueByName(ETRow_Available).Boolean;
	lIsDefault 		:= tbl.getValueByName(ETRow_Default).Boolean;
	lIsDisplay 		:= tbl.getValueByName(ETRow_Display).Boolean;
	
	lName			:= tbl.getValueByName(ETRow_MeasurementName).String;
	lSName			:= tbl.getValueByName(ETRow_ShortName).String;
	lType 			:= tbl.getValueByName(ETRow_Unit).String;
	
	
	if theForm.myProxyObject = null then
		if theForm.mode = theForm.Mode_Add then
			create theForm.myProxyObject as CM_MeasurementType transient;
		else
			app.raiseUnexpectedProgramError(class.name, method.name, 'Proxy object is null for update');
			return false;
		endif;
	elseif theForm.myProxyObject.isKindOf(CM_MeasurementType) then
		lIsSystemType := theForm.myProxyObject.CM_MeasurementType.isSystemType;
	endif;
  
	
	
	proxyMeasurementType := theForm.myProxyObject.CM_MeasurementType;
	lformatPrecision     :=  proxyMeasurementType.calculateFormatPrecision(lFormat);   //14.11.2022 navma1 #55381			 
	
	proxyMeasurementType.setProxy(lConversionRate,
								  lFormat, 
								  lIsAvailable, 
								  lIsDefault, 
								  lIsDisplay, 
								  lIsSystemType, 
								  lSName,
								  lType, 
								  lName,
								  lformatPrecision);                                  //14.11.2022 navma1 #55381	
			
			
	if theForm.mode = theForm.Mode_Add then
		app.myTrxCA.trxCreateMeasurementType(proxyMeasurementType, theForm.myCurrentObject,app.myPassport);
	elseif theForm.mode = theForm.Mode_Update then
		app.myTrxUA.trxUpdateMeasurementType(proxyMeasurementType, app.myPassport);
	else
		app.raiseUnexpectedProgramError(class.name, method.name, '  Invalid mode (' &amp; theForm.mode.String &amp; ')');
		return false;
	endif;
	return app.myPassport.trxCompletedOK;


epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
