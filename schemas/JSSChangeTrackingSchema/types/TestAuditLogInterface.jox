<Class name="TestAuditLogInterface" id="c9ec12b8-35ba-4cee-bed2-73f2658d5803">
    <superclass name="Object"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="jsscore_default"/>
    <JadeMethod name="buildDocumentFromAuditLog" id="463f5a80-59ca-4703-ac2d-41b2b9859234">
        <source>buildDocumentFromAuditLog(pFrom: TimeStamp): String;

vars
	returnString: String;
	dialog: CMDFileOpen;
	auditLog: File;
	line: String;
	tsFrom: TimeStamp;
	document: JSSXmlDocument;
	element: JSSXmlElement;
	date: Date;
	dateString: String;
	timeString: String;
	oid: String;
	action: String;
	seq: String;
	pos: Integer;
begin
	create dialog;
	if dialog.open = 0 then

		create document transient;
		document.addElement("JADE_AuditLog", null);

		create auditLog transient;
		auditLog.kind := File.Kind_Unknown_Text;	// 25/2/16 cnwmp6 PAR 36286 unicode version
		auditLog.fileName := dialog.fileName;

		while not auditLog.endOfFile() do
			line := auditLog.readLine() ;

			if line[1:4] = "+++ " then
				pos := line.pos(")", 5) + 2;
				date := line[pos:line.pos(",", pos) - pos].Date;
				dateString := date.format("yyyMMdd");
				tsFrom.setDate(date);
			endif;
			if line.pos("Obj=", 1) &gt; 0 and line.pos("&lt;before&gt;", 1) = 0 then
				tsFrom.setTime(line[1:8].Time);
			//	check if this line is within the date range
				if tsFrom &gt;= pFrom then
				//	get the values from the line
					timeString := line[1:2] &amp; line[4:2] &amp; line[7:2];
					pos := line.pos(")", 11) - 11;
					seq := line[11:pos];
					pos := line.pos("Obj=", 11) + 4;
					oid := line[pos:line.pos("|", pos) - pos];
					pos := line.pos("&lt;", pos) + 1;
					action := line[pos:line.pos("&gt;", pos) - pos];
					if action = "after" then
						action := "update";
					endif;
				//	add the elements
					element := document.addElement("JADE_RecordType", null);
					element.addAttribute("Type", "01");

					element.addElement("JADE_TimeStamp", dateString &amp; timeString);
					element.addElement("JADE_ObjectID", oid);
					element.addElement("JADE_Action", action);
					element.addElement("JADE_SequenceNumber", seq);
				endif;
			endif;
		endwhile;

	endif;
epilog
	delete dialog;
	if document &lt;&gt; null then
		returnString := document.buildXmlString();
		delete document;
	endif;
	return (returnString);
end;</source>
        <Parameter name="pFrom" type="TimeStamp"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getAuditLogDetails" id="ac9ed8b5-4cbf-4f57-8ffc-ac2fd8eae5c6">
        <source>getAuditLogDetails(pFrom: TimeStamp): String;

begin
	return (self.buildDocumentFromAuditLog(pFrom));
end;</source>
        <Parameter name="pFrom" type="TimeStamp"/>
        <ReturnType type="String"/>
    </JadeMethod>
</Class>
