        <Parameter name="_terminalAreas" type="CM_TerminalAreaArray"/>
        <ReturnType type="CM_TerminalAreaStorageGroup"/>
    </JadeMethod>
    <JadeMethod name="addTidalClass" id="48970948-d63a-406c-bacb-2b36e6fc3633">
        <source>addTidalClass(_tidalClassId, _tidalClassDesc : String; _maxFloodTideArrival, _maxEbbTideArrival, _maxFloodTideDept, _maxEbbTideDept : Decimal ) : HMS_TidalClass;

/*

Purpose:		Add Tidal Class

Date			Who		Reason
21/12/2011		cnwmh5	Initial creation

*/

vars

	pxyTidalClass			: HMS_TidalClass;
	tidalClass				: HMS_TidalClass;
	conflictManager	 		: CMIF_HMS_ConflictsManager;

begin

	self.deleteTidalClass(_tidalClassId);

	create pxyTidalClass transient;
	pxyTidalClass.setProxy(app.myRoot);
	
	pxyTidalClass.setPropertyValue("code", _tidalClassId);
	pxyTidalClass.setPropertyValue("description", _tidalClassDesc);
	
	app.myTrxCA.trxCreateTidalClass(pxyTidalClass, tidalClass, conflictManager, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	// must be in this order
	beginTransaction;
	tidalClass.allMaximumCurrents.add(_maxFloodTideArrival);
	tidalClass.allMaximumCurrents.add(_maxEbbTideArrival);
	tidalClass.allMaximumCurrents.add(_maxFloodTideDept);
	tidalClass.allMaximumCurrents.add(_maxEbbTideDept);
	commitTransaction;
	
	return tidalClass;
	
epilog

	delete pxyTidalClass;

end;</source>
        <Parameter name="_tidalClassId" type="String"/>
        <Parameter name="_tidalClassDesc" type="String"/>
        <Parameter name="_maxFloodTideArrival" type="Decimal"/>
        <Parameter name="_maxEbbTideArrival" type="Decimal"/>
        <Parameter name="_maxFloodTideDept" type="Decimal"/>
        <Parameter name="_maxEbbTideDept" type="Decimal"/>
        <ReturnType type="HMS_TidalClass"/>
    </JadeMethod>
    <JadeMethod name="addTidalModel" id="a1c1b109-577f-458a-84ec-41e1ca2324e5">
        <source>addTidalModel(_tidalModelId, _tidalModelDesc, _dataSource, _tideFileName : String; _dataType : Integer; _highestValue, _lowestValue, 
			_declaredDepth, _underKeelClearance : Real) : HMS_TidalModelDefinition;

/*

Purpose:		Create a Tidal Model Definition		

Date			Who		Reason
22 December 2011	cnwmh5	Initial creation

*/

vars

	pxyTidalModelDef				: HMS_TidalModelDefinition;
	tidalModelDef					: HMS_TidalModelDefinition;

begin

	self.deleteTidalModel(_tidalModelId);

	create pxyTidalModelDef transient;
	pxyTidalModelDef.setProxy(_tidalModelId,				// code
							 _tidalModelDesc,				// desc : String;
							 _dataType,						// data type	: Integer;
							 _dataSource,					// data source 	: String;
							 _highestValue,					// highest value  : Real
							 _lowestValue,					// lowest value : Real
							 _declaredDepth,				// declared depth : Real
							 _underKeelClearance,			// under keel clearance : Real;
							 false,							// has gaps	: Boolean;
							 app.myRoot,					// root 			: CM_Root;
							 _tideFileName);				// tide file name : String				
	
	app.myTrxCA.trxCreateTidalModelDef(pxyTidalModelDef, tidalModelDef, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	return tidalModelDef;
	
epilog

	delete pxyTidalModelDef;

end;</source>
        <Parameter name="_tidalModelId" type="String"/>
        <Parameter name="_tidalModelDesc" type="String"/>
        <Parameter name="_dataSource" type="String"/>
        <Parameter name="_tideFileName" type="String"/>
        <Parameter name="_dataType" type="Integer"/>
        <Parameter name="_highestValue" type="Real"/>
        <Parameter name="_lowestValue" type="Real"/>
        <Parameter name="_declaredDepth" type="Real"/>
        <Parameter name="_underKeelClearance" type="Real"/>
        <ReturnType type="HMS_TidalModelDefinition"/>
    </JadeMethod>
    <JadeMethod name="addToDoTask" id="a6420d10-01e0-4803-8250-931569c632e4">
        <source>addToDoTask(_taskDesc : CM_ToDoTaskDesc; _tiSet : CM_TISet input);
//18 December 2009	cnwml2
// 07/02/2014	cnwmh5	Change so that can also call trxUpdateTIToDoAdd based on _tiSet size

vars

begin
	if _tiSet.size = 1 then
		app.myTrxUA.trxUpdateTIToDoTaskAdd(_tiSet.first.CM_TrackedItem, _taskDesc.code, app.myPassport);
	else
		app.myTrxUA.trxUpdateTIToDoTaskAddBulk(_taskDesc, _tiSet, app.myPassport);
	endif;
	self.assertNoTrxErrorsOrWarnings;
epilog

end;</source>
        <Parameter name="_taskDesc" type="CM_ToDoTaskDesc"/>
        <Parameter name="_tiSet" type="CM_TISet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="addToDoTaskResource" id="f42d110a-f336-47ae-8c97-f865546524c9">
        <source>addToDoTaskResource(_resourceCode, _resourceDesc, _unitDescription : String; _numDecimals : Integer; _hasBeenUsed, _isAvailable : Boolean; _toDoTasks : CM_ToDoTaskDescBySortKey) : CM_ResourceType;

/*

Purpose:		Add To Do Task Resource

Date			Who		Reason
05/02/2012		cnwmh5	Initial creation
02/11/2022 		navds20 ChangeRequest 56635:[54261] EUP - Todo Task Resources Maintenance
23/12/2022      navds21 ChangeRequest 54349[54262]: EUP - Enable Is Mandatory for ToDo Task Resources
*/

vars

	pxyResourceType				: CM_ResourceType;
	resourceType				: CM_ResourceType;
	
	transTypeSet 				: CM_TransactionTypeSet;
	transResourceBrokers 		: CM_TransSBByTransTypeType;
	eventTypes 					: CM_EventTypeByTypeDict;

begin
	
	self.deleteResourceType(_resourceCode);
	
	create transTypeSet transient;
	create transResourceBrokers transient;
	create eventTypes transient;
	
	create pxyResourceType transient;
	pxyResourceType.setProxy(_resourceCode,					// code
						     _resourceDesc, 				// description
							 _numDecimals,					// number of decimals
							 _unitDescription,				// unit descriptoin
							 _hasBeenUsed, 					// has been used
							 _isAvailable,					// is avaiabile
							 _toDoTasks,				 	// CM_ToDoTaskDescBySortKey;
							 eventTypes,					// CM_EventTypeByTypeDict;
							 transTypeSet,					// CM_TransactionTypeSet;
							 transResourceBrokers,			// CM_TransSBByTransTypeType/
							 false,							//cnwmc5 - 22 Sep 2015 - PAR 36920
							 self.opts.str(JadeCode), 		//cnwmc5 - 22 Sep 2015 - PAR 36920
							 null,
							 self.opts.str(UserCode),		//cnwmc5 - 22 Sep 2015 - PAR 36920	
							 TODO_TYPE_GROUP_TI,			//02/11/2022 navds20 TFS #56635[54261]
							 false,							//23.12.2022 navds21 TFS #54349[54262]
							 null,							// ### TFS 58761 (60739) 16Nov2023 NAVPW1
							 null							// ### TFS 58761 (60739) 16Nov2023 NAVPW1
							 );
	
	app.myTrxCA.trxCreateResourceType(pxyResourceType, resourceType, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
		
	return resourceType;
	
epilog

	delete pxyResourceType;
	delete transTypeSet;
	delete transResourceBrokers;
	delete eventTypes;
	
end;</source>
        <Parameter name="_resourceCode" type="String"/>
        <Parameter name="_resourceDesc" type="String"/>
        <Parameter name="_unitDescription" type="String"/>
        <Parameter name="_numDecimals" type="Integer"/>
        <Parameter name="_hasBeenUsed" type="Boolean"/>
        <Parameter name="_isAvailable" type="Boolean"/>
        <Parameter name="_toDoTasks" type="CM_ToDoTaskDescBySortKey"/>
        <ReturnType type="CM_ResourceType"/>
    </JadeMethod>
    <JadeMethod name="addToDoTemplate" id="34904e92-748e-40ba-9bcd-d34ee4b5b33d">
        <source>addToDoTemplate(_id : String ) : CM_ToDoTemplate;
/*

Purpose:	Create To Do Template		

Date		Who		Reason
10/04/2014	cnwma1	Initial creation

*/

vars
	pxyToDoTemplate : CM_ToDoTemplate;
	toDoTemplate	: CM_ToDoTemplate;
	operatorDict	: CM_OperatorByCodeDict;
	todoTasksDict	: CM_ToDoTaskDescByCode;
	availDict		: CM_MTGradeByCodeDict;
	isoGroupDict		: CM_ISOTypeGroupByCodeDict;
	isoTypeDict     : CM_ISOTypeByCodeDict;
begin

	// Delete ToDo Terminal 
	
	deleteToDoTemplate(_id);
	
	// create operator
	create operatorDict transient;
	operatorDict.add(self.getOperator("APL"));
	operatorDict.add(self.getOperator("CMA"));
	
	// create ToDo Task
	create todoTasksDict transient;
	todoTasksDict.add(app.myRoot.allToDoTaskDescriptions[10]);
	
	// create AvailabilityGrades
	create availDict transient;
	availDict.add(app.myRoot.allAvailabilityGrades[66]);
	
	// create ISOGroup
	create isoGroupDict transient;
	isoGroupDict.add(app.myRoot.allISOTypeGroups["GEN4"]);
	
	// create ISO Type
	create isoTypeDict transient;

	
	create pxyToDoTemplate transient;
	pxyToDoTemplate.setProxy(_id,  		// ID
							false,      // Empties
							false, 		// Exports
							true, 		// Imports
							true,  		// Full 
							false, 		// Storage
							false,	    // tranships
							availDict,  		// AvailabilityGrades
							isoGroupDict,  		// Iso Groups
							isoTypeDict,       // ISo Types
							operatorDict,   // Opreators
							todoTasksDict , // To Do Tasks
							null);		// MT Grade
	
	app.myTrxCA.trxCreateToDoTemplate(pxyToDoTemplate,toDoTemplate,app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	return toDoTemplate;
epilog

	delete pxyToDoTemplate;
	delete operatorDict;
	delete todoTasksDict;
	delete availDict;
	delete isoGroupDict;
	delete isoTypeDict;

end;</source>
        <Parameter name="_id" type="String"/>
        <ReturnType type="CM_ToDoTemplate"/>
    </JadeMethod>
    <JadeMethod name="addToDoTemplate2" id="35ef5a76-ec76-4b5b-9efc-7f944f453f10">
        <source>addToDoTemplate2(_id : String ) : CM_ToDoTemplate;
/*

Purpose:	Create To Do Template		

Date		Who		Reason
9/12/2014	cnwjre1	Initial creation for 35362
					Template that applies to Storage empties, operators
*/

vars
	pxyToDoTemplate : CM_ToDoTemplate;
	toDoTemplate	: CM_ToDoTemplate;
	operatorDict	: CM_OperatorByCodeDict;
	todoTasksDict	: CM_ToDoTaskDescByCode;
	availDict		: CM_MTGradeByCodeDict;
	isoGroupDict	: CM_ISOTypeGroupByCodeDict;
	isoTypeDict     : CM_ISOTypeByCodeDict;
begin

	// Delete ToDo Terminal 
	
	deleteToDoTemplate(_id);
	
	// create operators, 
	create operatorDict transient;
	operatorDict.add(self.getOperator("APL"));
	operatorDict.add(self.getOperator("CMA"));
	operatorDict.add(self.getOperator("MSK"));
	
	// create ToDo Task, Survey
	create todoTasksDict transient;
	todoTasksDict.add(app.myRoot.allToDoTaskDescriptions[10]);
	
	// create AvailabilityGrades, none
	create availDict transient;
	
	// create ISOGroup, none
	create isoGroupDict transient;
	
	// create ISO Type, none
	create isoTypeDict transient;

	
	create pxyToDoTemplate transient;
	pxyToDoTemplate.setProxy(_id,  		// ID
							false,      // Empties
							false, 		// Exports
							true, 		// Imports
							true,  		// Full 
							false, 		// Storage
							false,	    // tranships
							availDict,  		// AvailabilityGrades
							isoGroupDict,  		// Iso Groups
							isoTypeDict,       // Iso Types
							operatorDict,   // Operators
							todoTasksDict , // To Do Tasks
							null);		// MT Grade
	
	app.myTrxCA.trxCreateToDoTemplate(pxyToDoTemplate,toDoTemplate,app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	return toDoTemplate;
epilog

	delete pxyToDoTemplate;
	delete operatorDict;
	delete todoTasksDict;
	delete availDict;
	delete isoGroupDict;
	delete isoTypeDict;

end;</source>
        <Parameter name="_id" type="String"/>
        <ReturnType type="CM_ToDoTemplate"/>
    </JadeMethod>
    <JadeMethod name="addTrackClearance" id="727047dc-63c8-4755-a466-dc276ae4dcdf">
        <source>addTrackClearance( gcId : String ) : CM_TrackClearance;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
15 July 2009	cnwndl1	Initial creation

*/
vars
	existingGaugeClearance : CM_TrackClearance;
	loadState : Boolean;
	
	trackClearance : CM_TrackClearance;
	proxyGaugeClearance : CM_TrackClearance;
	
	
begin


	existingGaugeClearance := app.myRoot.allTrackClearances.getAtKey(gcId);
	self.assertTrueMsg(existingGaugeClearance = null, "Track clearance '" &amp; gcId &amp; "' already exists !!");
	
	app.cmsBeginLoad(loadState);
	
	create proxyGaugeClearance transient;
	
	proxyGaugeClearance.setProxy(	false,	//_allowHiCube : Boolean;
									gcId,	//_code : String;
									"Test track clearance",	//_description : String;
									450,	//_maxHeight : Decimal;
									20000,	//_maxWeightWagon : Decimal;
									260,	//_maxWidth : Decimal;
									false,	//_isNotAvailableForEntry : Boolean
									0, // max weight for train
									false // no empty wagons
									);
								
	app.myTrxCA.trxCreateTrackClearance(proxyGaugeClearance, trackClearance, app.myPassport);
	self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());
	self.assertTrueMsg(trackClearance &lt;&gt; null, "Track Clearance '" &amp; gcId &amp; "' not created.");

	
	
	
	
epilog

	app.cmsEndLoad(loadState);
	delete proxyGaugeClearance;
	return trackClearance;

end;</source>
        <Parameter name="gcId" type="String"/>
        <ReturnType type="CM_TrackClearance"/>
    </JadeMethod>
    <JadeMethod name="addTrade" id="7b3cf5ee-96a9-466a-88f5-9a7b482655e3">
        <source>addTrade(_tradeId, _tradeDesc: String; _notAvailable : Boolean; _shippingLines : CM_ShippingLineByCodeDict; _operatorArray : ObjectArray) : CM_Trade;

/*

Purpose:		Add a Trade

Date			Who		Reason
30/11/2011		cnwmh5	Initial creation

*/

vars

	pxyTrade				: CM_Trade;
	trade					: CM_Trade;
	obj						: Object;
	portRotation			: CM_PortRotation;
	
	portArray				: ObjectArray;
	debtorArray				: ObjectArray;
	
begin

	self.deleteTrade(_tradeDesc);

	create pxyTrade transient;
		
	pxyTrade.setProxy(_tradeId,				 		// id/code
					  _tradeDesc, 					// desription
					  0,							// order
					  _operatorArray,				// operatorArray
					  _notAvailable,
					  _shippingLines);						// shipping lines
	
	app.myTrxCA.trxCreateTrade(pxyTrade, trade, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	delete pxyTrade;
						  
	if self.opts.includesKey("PortsOfRotation") then
		portArray := self.opts.obj("PortsOfRotation").ObjectArray;
		create debtorArray transient;
		beginTransaction;
		trade.setCopyToTrade(trade, portArray, debtorArray);
		commitTransaction;
	endif;
	
	return trade;

epilog
	delete pxyTrade;
	delete debtorArray;
end;</source>
        <Parameter name="_tradeId" type="String"/>
        <Parameter name="_tradeDesc" type="String"/>
        <Parameter name="_notAvailable" type="Boolean"/>
        <Parameter name="_shippingLines" type="CM_ShippingLineByCodeDict"/>
        <Parameter name="_operatorArray" type="ObjectArray"/>
        <ReturnType type="CM_Trade"/>
    </JadeMethod>
    <JadeMethod name="addTrailerAtLocation" id="2535be00-3242-4da6-bcf4-1b08dcc4961d">
        <source>addTrailerAtLocation(_id: String;
					_cargoType: CM_CargoType;
					_trailerType : CM_TILCType;
					_operator: CM_Operator; 
					_location: CM_LocationsController) : CM_TILC;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 July 2013	cnwer1	Initial creation CCMS DPH 2274

*/

vars
	pxyTI , realTI: CM_TrackedItem;
	moveController : CMIF_MoveController;
begin
	
	if _cargoType = null or _trailerType = null then
		return null;
	endif;
	
	if _cargoType.myClassToCreate &lt;&gt; CM_TILC then
		return null;
	endif;
	
	
	pxyTI := self.getTerminal.createTI(_cargoType, true);
	self.assertTrue(pxyTI.isKindOf(CM_TILC));
	pxyTI.setPxyFromDefaultTI(self.getTerminal, _cargoType.id, _id, null, _operator);
	pxyTI.changeState(TI_STATE_NORMAL, app.myPassport);
	pxyTI.setTotalWeight(4000, null, null);	
	pxyTI.CM_TILC.setMyType(_trailerType);
	pxyTI.zSetPxyImexStatus(TI_IMEX_STATUS_STORAGE);
	pxyTI.zSetPxyRemarks(self.createdByUnitTest(null));					// 10/09/2015 cnwmh5
	self.ignoreTrxWarnings(true);
	create moveController transient;
	moveController.isForcedMove := true;
	moveController.setMyToPrimaryLocation( _location);
	moveController.setMoveMode(REAL_MODE);
	
	app.myTrxCA.trxCreateTIWithMove(pxyTI, realTI, moveController, app.myPassport);

	self.assertNoTrxErrors();
	self.assertNotNull(realTI);
	self.assertTrue(realTI.isKindOf(CM_TILC));
	self.assertEqual(realTI.CM_TILC.allLCs.size, _trailerType.numControllers);
	return realTI.CM_TILC;
epilog

	delete moveController;
end;</source>
        <Parameter name="_id" type="String"/>
        <Parameter name="_cargoType" type="CM_CargoType"/>
        <Parameter name="_trailerType" type="CM_TILCType"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_location" type="CM_LocationsController"/>
        <ReturnType type="CM_TILC"/>
    </JadeMethod>
    <JadeMethod name="addTrailerType" id="c5ef6c06-b105-4f4e-8167-848a6658fd44">
        <source>addTrailerType(_tilcTypeCode, _tilcTypeDesc : String;  _tilcCargoType : CM_CargoType; _length, _numControllers, _maxHeight, _maxWeight, _tareWeight : Integer) : CM_TILCType;

/*

Purpose:			Add a tailer type

Parameters:			

Return Value:		


Date		Who		Reason
15 October 2010	cnwndl1	Initial creation
10 Mar 2023		jlika1	TFS 56923 - Add width to Trailer
*/

vars

	pxyTrailerType		: CM_TILCType;
	trailerType			: CM_TILCType;
		
begin

	if _tilcCargoType = null then
		return null;
	endif;

	//trailerType := _tilcCargoType.allTILCTypes[_tilcTypeCode];
	trailerType := app.myRoot.allTILCTypes[null, _tilcTypeCode];
	self.deleteTrailerType(trailerType);
	trailerType := null;

	create pxyTrailerType transient;
	pxyTrailerType.setProxy(_tilcTypeCode,										// code : String;
							_tilcTypeDesc,										// description : String;
							_tilcCargoType,										// cargoType : CM_CargoType;
							_length,											// length : Integer;
							_numControllers,									// numControllers : Integer
							_maxHeight,											// maxHeight : Integer;
							_maxWeight, 										// maxWeight : Integer;
							_tareWeight, 										
							null,												// colour : Integer
							false,
							null,
							0,
							null,
							null,												// par 30852 Dec 2012
							false												//15/10/2025	navkc1 JIRA 36057					
							);
	app.myTrxCA.trxCreateTILCType(pxyTrailerType, trailerType, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	return trailerType;

epilog

	delete pxyTrailerType;

end;</source>
        <Parameter name="_tilcTypeCode" type="String"/>
        <Parameter name="_tilcTypeDesc" type="String"/>
        <Parameter name="_tilcCargoType" type="CM_CargoType"/>
        <Parameter name="_length" type="Integer"/>
        <Parameter name="_numControllers" type="Integer"/>
        <Parameter name="_maxHeight" type="Integer"/>
        <Parameter name="_maxWeight" type="Integer"/>
        <Parameter name="_tareWeight" type="Integer"/>
        <ReturnType type="CM_TILCType"/>
    </JadeMethod>
    <JadeMethod name="addTrain" id="1a64ca6b-d3b7-4b88-a37a-10aa830f3967">
        <source>addTrain(	_code: String;	// mandatory
			_myTrackClearance : CM_TrackClearance // optional
			): CM_Train;
//09 July 2009	cnwmd1	
//
// 12 May 2016		cnwns1			TFS 488 - Multi Timezone Support
// 02 Oct 2020      cnwma1 			ChangeRequest 50112: ASPA - GCI Stevedores
vars
	proxyTrain, train : CM_Train;
	carrier : CM_Carrier;
begin
	carrier := app.myRoot.allCarriers.first.CM_Carrier;
	
	create proxyTrain transient;
	proxyTrain.setProxy(_code,
						_code,
						null,
						null,
						null,
						null,
						app.myPassport.myTerminal,
						null,
						null, //navsp1 17MAY2022 TFS#53619
						null,
						null,
						null,
						null,
						null,
						null,
						null,
						carrier,
						app.actualTimeServer,	// 12 May 2016		cnwns1			TFS 488 - Multi Timezone Support
						null,
						null,
						null,
						null,
						_myTrackClearance,	//_myTrackClearance : CM_TrackClearance
						false,
						null,               //02.10.2020 cnwma1 TFS #50112
						null);              //02.10.2020 cnwma1 TFS #50112
						
	
	app.myTrxCA.trxCreateTrain(proxyTrain, train, false, app.myPassport);
	
	self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());
	return train;
	
epilog
	delete proxyTrain;
end;</source>
        <Parameter name="_code" type="String"/>
        <Parameter name="_myTrackClearance" type="CM_TrackClearance"/>
        <ReturnType type="CM_Train"/>
    </JadeMethod>
    <JadeMethod name="addTrainUserEvent" id="50c131d9-c132-4025-93ea-b4a58d61d52b">
        <source>addTrainUserEvent(_train : CM_Train io; _eventTypeNo : Integer) : Boolean;
// --------------------------------------------------------------------------------
// Created:		03 November 2009 by cnwjo3
//
// Purpose:		Add Train User Event
vars
	now : TimeStamp;
	success : Boolean;
	firstEventType : CM_EventType;
	eventType : CM_EventType;
	iter : Iterator;
	foundEventType : Boolean;
	//pxyET : CM_EventType;
	pxyET : CM_Object;
	realTransaction : CM_EventTransaction;
begin

	now := app.actualTimeServer();	// 16 Sept 2016	cnwns1	TFS 488 - Multi Timezone Support
		
	iter := app.myRoot.allEventTypesByCategory.createIterator;
	firstEventType := app.myRoot.allEventTypesByCategory.getAtKeyGeq(CM_EventType.TRAIN_EVENT,null);

	if firstEventType &lt;&gt; null then
		iter.startAtObject(firstEventType);
		while iter.next( eventType ) do
			if eventType.category &lt;&gt; CM_EventType.TRAIN_EVENT then
				break;
			endif;
			
			if eventType.type = _eventTypeNo then
				foundEventType := true;
				break;
			endif;
		endwhile;
	endif;	
	
	if foundEventType then
		create pxyET as eventType.myClassToCreate transient;  //don't like doing it this way, but i have no choice
		pxyET.CM_EventTransaction.setDetails(eventType, now, _train.getTerminal(), app.myPassport.myUser.code, false,0);
		
		app.myTrxCA.trxCreateTrainEvent(pxyET.CM_EventTransaction, realTransaction, _train, app.myPassport);
		
		if app.myPassport.trxCompletedOK then
			success := true;
		endif;
	endif;
	
	return success;
	
epilog

	delete pxyET;
	delete iter;
	
end;
</source>
        <Parameter name="_train" type="CM_Train" usage="io"/>
        <Parameter name="_eventTypeNo" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="addTransactionType" id="421836b5-3d3c-44d7-b997-e5764fe8d8d4">
        <source>addTransactionType(_transactionTypeDesc, _classNameToCreate	: String; _type, _group : Integer; _canCompleteToDoTask : Boolean) : CM_TransactionType;

/*

Purpose:		Add Transaction Type

Date			Who		Reason
15/02/2012		cnwmh5	Initial creation

*/

vars
	
	pxyTransactionType			: CM_TransactionType;
	transactionType				: CM_TransactionType;
	
begin

	self.deleteTransactionType(_type);

	create pxyTransactionType transient;
	pxyTransactionType.setProxy(_transactionTypeDesc, 			// description
								_type,							// Type
								_group,							// group : Integer
								_classNameToCreate,				// class name to create : String
								_canCompleteToDoTask, 			// can complete to do task : Boolean
								app.myRoot);
								
	app.myTrxCA.trxCreateTransactionType(pxyTransactionType, transactionType, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	return transactionType;
	
epilog

	delete pxyTransactionType;

end;</source>
        <Parameter name="_transactionTypeDesc" type="String"/>
        <Parameter name="_classNameToCreate" type="String"/>
        <Parameter name="_type" type="Integer"/>
        <Parameter name="_group" type="Integer"/>
        <Parameter name="_canCompleteToDoTask" type="Boolean"/>
        <ReturnType type="CM_TransactionType"/>
    </JadeMethod>
    <JadeMethod name="addUNDangerousGoods" id="19d98185-314b-414b-afd4-39e3e4265247">
        <source>addUNDangerousGoods(_code, _description : String) : CM_UNDangerousGoods;

vars

	dangerousGoods					: CM_UNDangerousGoods;
	pxyDangerousGoods				: CM_UNDangerousGoods;
	hazClass						: CM_HazardClass;
	
	tokens							: StringArray;
	secondaryClasses				: CM_StringArray;
	packingGroups					: StringArray;
	
	str								: String;
	index							: Integer;

begin

	self.deleteUNDangerousGoods(_code);
	
	create secondaryClasses transient;
	create packingGroups transient;
	create tokens transient;
	
	if self.opts.includesKey("hazardClasses") then
		
		tokens.purge();
		self.opts.str("hazardClasses").getTokensForDelimiter(";", tokens);
		foreach index in 1 to tokens.size do
		
			if hazClass = null  then
				hazClass := app.myRoot.allHazardClasses[tokens[index]];
			else
				secondaryClasses.add(tokens[index]);
			endif;
		
		endforeach;
	
	endif;
	
	if self.opts.includesKey("packingGroups") then

		tokens.purge();
		self.opts.str("packingGroups").getTokensForDelimiter(";", tokens);
		foreach index in 1 to tokens.size do
			packingGroups.add(tokens[index]);
		endforeach;
	
	endif;
	
	
	create pxyDangerousGoods transient;
	pxyDangerousGoods.setForProxy(_code, _description, false, hazClass, packingGroups, null, null, null, 0, false, null, 
		secondaryClasses, false);
	
	
	app.myTrxCA.trxCreateUNDGCode(pxyDangerousGoods, dangerousGoods, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	return dangerousGoods;
	
epilog

	delete secondaryClasses;
	delete packingGroups;
	delete tokens;

	delete pxyDangerousGoods;

end;
</source>
        <Parameter name="_code" type="String"/>
        <Parameter name="_description" type="String"/>
        <ReturnType type="CM_UNDangerousGoods"/>
    </JadeMethod>
    <JadeMethod name="addUser" id="aa835159-4220-464a-9db7-07e80ac5d655">
        <source>addUser(_name, _code: String): CM_User;
/*

Purpose:			Add User	

Date				Who		Reason
28 November 2011	cnwmh5	Initial creation

*/
vars
	pxyUser,
	user			: CM_User;
	sysSecurityRole	: CM_SecurityRoleSystem;
	organisation	: CM_Organisation;
	
	daSet 			: CM_DataAccessControllerSet; 
	passedInDACSet : CM_DataAccessControllerSet; 
	
	password		: String;
	status			: Integer;
	pwdNeverExpires	: Boolean;
	
begin
	
	self.deleteUser(_code);							// 14/09/2012 cnwmh5
	
	create daSet transient;
	create pxyUser transient;
	
	organisation := app.myRoot.allOrganisations["UnitTestTerminal"];
	if organisation = null then
		organisation := app.myRoot.allOrganisations["UNIT TEST"];
	endif;
	if self.opts.includesKey("Organisation") then
		organisation := app.myRoot.allOrganisations[self.opts.str("Organisation")];
	endif;
	if self.opts.includesKey("DAC") then
		passedInDACSet := self.opts.obj("DAC").CM_DataAccessControllerSet;
		if passedInDACSet &lt;&gt; null then
			passedInDACSet.copy( daSet );
		endif;
	endif;
	
	// 18/05/2015 cnwmh5
	password := "u^1tTest";
	if self.opts.includesKey("UserPassword") then
		password := self.opts.str("UserPassword");
	endif;
	
	sysSecurityRole := app.myRoot.allRoles['System Root'].CM_SecurityRoleSystem;
	if self.opts.includesKey("SysSecurityRole") then					// 03/02/2016 cnwmh5
		sysSecurityRole := self.opts.obj("SysSecurityRole").CM_SecurityRoleSystem;
	endif;	
	
	status := EnabledNormalUser;
	if self.opts.includesKey("Status") then
		status := self.opts.int("Status");
	endif;
	
	pwdNeverExpires := false;
	if self.opts.includesKey("PasswordNeverExpires") then
		pwdNeverExpires := self.opts.bool("PasswordNeverExpires");
	endif;
	
	pxyUser.setProxy(_code, 
					 _name,									// Name 
					 status,								// Status
					 organisation, 							// Organisation;
					 app.myRoot,							// Root
					 true,									// Persistent Password
					 false,									// Radio Telemetry Only
					 false,									// Is Not Available For Entry
					 false,									// Allow Automatic Disability
					 null, 									// Last Log in TS
					 daSet,									// Data Access Controller Set
					 sysSecurityRole, 						// Security Role System
					 null,									// Email Entity
					 app.myRoot.allEmailEntities,			// Email Entity By Type Name Dict
					 null, 									// System Alert Types 
					 null, 									// Event Types
					 app.myRoot.getDefaultLocale(true),		// Locale
					 false,									// single user signon only
					 false									// Single User Session Allow Override
					 );
	
	app.myTrxCA.trxCreateUser(pxyUser, password, user, app.myPassport);
	self.assertNoTrxErrorsOrWarnings;
	
	return user;
epilog
	delete pxyUser;
	delete daSet;
end;</source>
        <Parameter name="_name" type="String"/>
        <Parameter name="_code" type="String"/>
        <ReturnType type="CM_User"/>
    </JadeMethod>
    <JadeMethod name="addUserHookCode" id="3cbaf49a-4541-4832-99d5-5ae213ead9d2">
        <source>addUserHookCode(_userHookCode, _jadeCode : String; _userHookCodeType : Integer) : CM_HookCode;

/*

Purpose:		Add User Hook Code	

Date			Who		Reason
31/01/2012		cnwmh5	Initial creation

*/

vars

	pxyUserHookCode				: CM_HookCode;
	cmifHookCode				: CMIF_HookCode;
	userHookCode				: CM_HookCode;
	userHookCodeType			: CM_HookType;
	
begin

	self.deleteUserHookCode(_userHookCode);

	userHookCodeType := app.myRoot.allHookTypes[_userHookCodeType];

	create pxyUserHookCode transient;
	create cmifHookCode transient;
	cmifHookCode.myProxyHookCode := pxyUserHookCode;
	cmifHookCode.code := "Fonterra";
	cmifHookCode.allLinkObjects.add(CM_Root.firstInstance);
	cmifHookCode.myHookType := userHookCodeType;
	cmifHookCode.jadeCode := _jadeCode;	
	
	cmifHookCode.allLinkObjects.add(self.getTerminal());
	cmifHookCode.setForUpdate();
	
	app.myTrxCA.trxCreateHookCode(cmifHookCode, userHookCode, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
//	beginTransaction;
//	userHookCode.createProxyHookLinkForParent(_userHookCodeType, self.getTerminal());
//	commitTransaction;
	
	return userHookCode;
	
epilog

	delete pxyUserHookCode;
	delete cmifHookCode;

end;</source>
        <Parameter name="_userHookCode" type="String"/>
        <Parameter name="_jadeCode" type="String"/>
        <Parameter name="_userHookCodeType" type="Integer"/>
        <ReturnType type="CM_HookCode"/>
    </JadeMethod>
    <JadeMethod name="addUserTerminalToUser" id="be3f7f69-e157-4b61-bf96-22b2d1319702">
        <source>addUserTerminalToUser(_cargoType: CM_CargoType);
/*
Adds a user terminal reference to the current user if required

Date		Who		Reason
18 February 2009	cnwcp2	Initial creation
18/05/2015	cnwmh5	CHnage to allow passing of user via opts
*/

vars
	term : CM_Terminal;
	userTerm : CM_UserTerminal;
	pxyUser : CM_User;
	found : Boolean;
	user		: CM_User;
	obj			: Object;
	secRoleTerm   : CM_SecurityRoleTerminal;
	
	objArray	: ObjectArray;
	
	userId		: String;
	password	: String;
begin

	
	// 08/05/2015 cnwmh5
	if self.opts.includesKey("RequestedUser") then
		userId := self.opts.str("RequestedUser");
		self.assertNotNull(userId);
		user := app.myRoot.allUsers[userId].CM_User;
		self.assertNotNull(user);
	else
		user := app.getMyUser();
	endif;
	
	// 18/05/2015 cnwmh5
	term := self.getTerminal();
	self.assertNotNull(term);
	
	// 18/05/2015 cnwmh5
	password := "password"; 
	if self.opts.includesKey("UserPassword") then
		password := self.opts.str("UserPassword");
	endif;
	
	// Need to see if the current user has a User Terminal for the current terminal
	//foreach userTerm in app.getMyUser.allUserTerminals do
	//	if userTerm.myTerminal = self.getTerminal then
	foreach userTerm in user.allUserTerminals do
		if userTerm.myTerminal = term then
			found := true;
			break;
		endif;
	endforeach;

	if not found then
		///pxyUser := app.createUpdateProxy(app.getMyUser).CM_User;
		pxyUser := app.createUpdateProxy(user).CM_User;
		///term := self.getTerminal();//app.createUpdateProxy(self.getTerminal).CM_Terminal;
		app.myPassport.setMyTerminal(term);
		create userTerm transient;
		
		// 03/02/2016 cnwmh5
		secRoleTerm := CM_SecurityRoleTerminalRoot.firstInstance;
		if self.opts.includesKey("TermSecurityRole") then
			secRoleTerm := self.opts.obj("TermSecurityRole").CM_SecurityRoleTerminal;
		endif;
		
		//userTerm.setForProxy(self.getTerminal,pxyUser, CM_SecurityRoleTerminalRoot.firstInstance, 
		userTerm.setForProxy(term, pxyUser, secRoleTerm, 
			_cargoType,	CM_BOLType.firstInstance, CM_CargoBOLType.firstInstance);
		
		app.myTrxUA.trxUpdateUser(pxyUser,password,app.myPassport);
		self.assertNoTrxErrorsOrWarnings();
	endif;
epilog
	if not found then
		delete userTerm;
		pxyUser.allSubSystemStateObjects.removeInvalidObjects();
		create objArray transient;
		pxyUser.allSubSystemStateObjects.copy(objArray);
		foreach obj in objArray do
			delete obj;
		endforeach;
		delete objArray;
		delete pxyUser;
	endif;
end;</source>
        <Parameter name="_cargoType" type="CM_CargoType"/>
    </JadeMethod>
    <JadeMethod name="addVbsTimeslotType" id="942b3f16-83c8-4a07-90e0-7c1dc8644c01">
        <source>addVbsTimeslotType( _code : String; _desc : String ): CM_VehicleBookingTimeSlotType;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 October 2014	cnwndl1	Initial creation	Par 35008
21 Jun 2022 navsrk20 ChangeRequest 53697: EUP - VBS MTN - [1] - VBS Slot Types
25 Nov 2024	navhl20 CR MTN-33483: TPT | Vehicle Truck Booking Auto Associate with Release Request
*/

vars

	isNotAvailableForEntry	: Boolean;
	code : String;
	desc : String;
	proxyType : CM_VehicleBookingTimeSlotType;
	real : CM_VehicleBookingTimeSlotType;
	rtnValue : Boolean;
	term	 : CM_Terminal;		//21.06.2022 navsrk20 TFS 53697
	startTime : Time;		//22-06-2022 navtnr20 TFS 53697
	duration : Integer;
	gracePeriod: Integer;
	entryOutsideSlotType : Integer;
	pregateInCheck : Boolean;
	pregateOutCheck : Boolean;
	kioskCheck : Boolean;
	vbsProcess : String;
	externelReference	: Boolean;
begin
	
	isNotAvailableForEntry := false;
	term := app.myPassport.getMyTerminal();		//21.06.2022 navsrk20 TFS 53697
	
	create proxyType transient;
	proxyType.setForProxy(	_code,	//_code : String;
							_desc,	//_description : String;
							isNotAvailableForEntry,	//_notAvailableForEntry : Boolean
							term,				//21.06.2022 navsrk20 TFS 53697	
							startTime,
							duration,
							gracePeriod,
							entryOutsideSlotType,
							pregateInCheck,
							pregateOutCheck,
							kioskCheck,
							externelReference,			//22-06-2022 navtnr20 TFS 53697
							false);						//25.11.2024 navhl20 #33483

	
	app.myTrxCA.trxCreateVBTimeSlotType(proxyType, real, app.myPassport);
	self.assertTrueMsg(real &lt;&gt; null, "VehicleBookingTimeSlotype not created for '" &amp; _code &amp; "'  " &amp; app.myPassport.getAllErrorsWarningsAsString);
	
epilog

	delete proxyType;
	return real;

end;</source>
        <Parameter name="_code" type="String"/>
        <Parameter name="_desc" type="String"/>
        <ReturnType type="CM_VehicleBookingTimeSlotType"/>
    </JadeMethod>
    <JadeMethod name="addVehicle" id="8306d2bf-4ed3-4ce8-8c4e-bae7fda3a4a6">
        <source>addVehicle( _regNo : String ; _carrier : CM_Carrier; _term : CM_Terminal) : CM_Vehicle;

/*

Purpose: for inter terminal stuff

Parameters:			

Return Value:		


Date		Who		Reason
25 February 2010	cnwrd1	Initial creation

*/

vars
	pProxyVehicle, 
	pNewVehicle :CM_Vehicle;
begin

	create pProxyVehicle transient;
		
	pProxyVehicle.setProxy(
							_regNo,
							'',
							2000, //tareweight
							0, // max laden weight
							_carrier,
							'', //state
							false, //isavail
							_term
							);
	
	app.myTrxCA.trxCreateVehicle(pProxyVehicle, pNewVehicle, app.myPassport);

	return pNewVehicle;
epilog
	delete pProxyVehicle;
end;
</source>
        <Parameter name="_regNo" type="String"/>
        <Parameter name="_carrier" type="CM_Carrier"/>
        <Parameter name="_term" type="CM_Terminal"/>
        <ReturnType type="CM_Vehicle"/>
    </JadeMethod>
    <JadeMethod name="addVehicleVisitItem" id="6378fcd8-7d55-437f-8a64-e4aac7b15a9b">
        <source>addVehicleVisitItem(_vvr: CM_VehicleVisitRecord io; _container: CM_Container; _empty: Boolean; _taId : String): CM_VehicleVisitRecord;
//30 July 2009	cnwdw1	
// 08/02/2010 	cwjre1 terminal area id parameter added for CCMS 1101 MT release handling
//23/06/2023	navkc1	CR 58406 Task 58408: Jade - Release Request All Tracked Items
vars
	controller : CMIF_FlexiGateController;
	pxyGateEntity, gateEntity: CMGTE_Entity;
	release: CM_BulkRelease;
	gateName: String;
	releaseType : Integer;
	bestPick: Boolean;
	customsNumber : String;
	deliveryNumber : String;
	operImportReleasePin : String;
	releaseByType : Boolean;
	clientRef: String;
	reserveDetail: CM_ReserveDetail;
	reserveTI: CM_ReserveTI;
	relRemarks : String;
	subTerm : CM_SubTerminal;
	firstTi	: CM_TrackedItem;
begin
	
	bestPick := self.opts.bool("BestPick");

	// Create the GTE Entity and add to VVR
	create controller transient;
	create pxyGateEntity as CMGTE_Release transient;
	controller.myTerminal := self.getTerminal();
	if _empty then
		controller.jobType := CMGTE_Entity.JobType_EmptyOUT;   // MT
	else
		controller.jobType := CMGTE_Entity.JobType_FullOUT;   // MT
	endif;
	
	controller.numItems := 1;
	
	if _container &lt;&gt; null then
		controller.id := _container.id;
		controller.isoTypeCode := _container.isoType;
		controller.operatorCode := _container.operatorCode;
		controller.consigneeCode	:= _container.consignee;	// par 29480 April 2012
		if self.opts.includesKey("RelRemarks") then    //cnwma1 30/10/2014 PAR #35088
			controller.remarks :=self.opts.str("RelRemarks");
		endif;
		
	
	endif;
	controller.cargoType := TI_CargoType_Container;
	controller.myVehicleVisitRecord := _vvr;
	controller.yardLocationTxt :=  _taId;
	
	releaseType := null;
	release := self.opts.obj("release").CM_BulkRelease;
	if release &lt;&gt; null then 
		controller.myBulkRelease := release;
		if _container &lt;&gt; null then
			// Release by Id so try to find a matching reserve TI
			foreach reserveDetail in release.allReserveDetails do
				if reserveDetail.isKindOf(CM_ReserveTI) then
					reserveTI := reserveDetail.CM_ReserveTI;
					firstTi := reserveTI.getFirstTI(false); //23/06/2023	navkc1	CR 58406 Task 58408
					if firstTi &lt;&gt; null and firstTi.id = _container.id then
						controller.myReserveDetail := reserveDetail;
						break;
					endif;
				endif;
			endforeach;
		endif;
		if controller.myReserveDetail = null then
			controller.myReserveDetail := release.allReserveDetails.first;
		endif;
		controller.deliveryReason	:= release.deliveryReasonDescr;	// cnwcs5 June2012
		
		if controller.myReserveDetail &lt;&gt; null then
			controller.isoTypeCode := controller.myReserveDetail.getISOTypeCode;
			controller.isoGroup := controller.myReserveDetail.getISOGroupCode;
			controller.operatorCode := controller.myReserveDetail.getOperatorCode;
			if release.myVoyage &lt;&gt; null then
				controller.voyageCode := release.myVoyage.code;
			endif;
			if controller.myReserveDetail.isKindOf(CM_ReserveSelection) then
				controller.myReserveDetail.CM_ReserveSelection.allTerminalAreas.copy(controller.allSourceTAs);
				controller.billOfLading := controller.myReserveDetail.getBOLNumber;
			endif;
			if not opts.includesKey("BestPick") then
				bestPick := controller.myReserveDetail.bestPick;
			endif;
		endif;
		
		controller.mtOnly := not release.fullRelease;
		if controller.mtOnly then
			controller.commodity := "MT";
		endif;
		releaseType := release.type;
		releaseByType := release.releaseByType;
	endif;
	
	if app.isSubTerminalsOn(self.getTerminal) then
		subTerm := self.getTerminal.getDefaultSubTerminal(	CM_SubTerminal.Type_BulkRelease,
															releaseType,	// cnwdad1 27/01/2010 - PAR #22205.
															0,
															null,
															false);
		if subTerm &lt;&gt; null then
			controller.subTerminalCode := subTerm.code;
		endif;
	endif;

	pxyGateEntity.setPXYFromController(controller); 
	if _container &lt;&gt; null or not releaseByType then
		pxyGateEntity.CMGTE_Release.setIsReleaseById(true);
	else
		pxyGateEntity.CMGTE_Release.setIsReleaseById(false);
	endif;
	pxyGateEntity.CMGTE_Release.setBestPick(bestPick);
	
	//+cnwml2 PAR25757
	customsNumber := self.opts.str("customsNumber");
	if customsNumber &lt;&gt; null then
		pxyGateEntity.CMGTE_Release.setCustomsEntryNumber(customsNumber);
	endif;
	
	//+cnwml2 PAR25757
	deliveryNumber:= self.opts.str("deliveryNumber");
	if deliveryNumber &lt;&gt; null then
		pxyGateEntity.CMGTE_Release.setDeliveryNumber(deliveryNumber);
	endif;
	
	// cnwrl1 07/10/2010 PAR 25958 - start of coding
	operImportReleasePin	:= self.opts.str("operImportReleasePin");
	if operImportReleasePin &lt;&gt; null then
		pxyGateEntity.CMGTE_Release.setImportReleasePIN( operImportReleasePin );
	endif;
	// cnwrl1 07/10/2010 PAR 25958 - end of coding

	clientRef	:= self.opts.str("clientRef");
	if clientRef &lt;&gt; null then
		pxyGateEntity.setClientRef( clientRef );
	endif;
	
	self.ignoreTrxWarnings(true);
	app.myTrxCA.trxCreateInOutFlexiGateEntity(_vvr, pxyGateEntity, gateEntity, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	delete pxyGateEntity;
	delete controller;
	
	return _vvr;

epilog
	delete pxyGateEntity;
	delete controller;
end;</source>
        <Parameter name="_vvr" type="CM_VehicleVisitRecord" usage="io"/>
        <Parameter name="_container" type="CM_Container"/>
        <Parameter name="_empty" type="Boolean"/>
        <Parameter name="_taId" type="String"/>
        <ReturnType type="CM_VehicleVisitRecord"/>
    </JadeMethod>
    <JadeMethod name="addVehicleVisitRecord" id="a35f94aa-8e7e-4729-a9b8-1e64e0db24a5">
        <source>addVehicleVisitRecord(_truck, _state, _driver, _gateName: String): CM_VehicleVisitRecord;
//30 July 2009	cnwdw1
//13/05/2022 navhl20 TFS 53430  EUP - Sub Carrier registration in MTN	
//
vars
	pxyVVR, vVR: CM_VehicleVisitRecord; 
	gate: CM_Gate;
	adminGate: CM_GateArea;
	now: TimeStamp;
	yic: String;
	carrier				: String;
begin

	// Create the Vehicle Visit Record
	gate := self.getGate(_gateName);
	if gate &lt;&gt; null then
		adminGate := gate.getFirstAGate_IN();
	endif;	
	yic := self.opts.str("YardInterchangeArea");
	
	carrier := self.getProfileStr(UT_Profile.P_CARRIER);
	if self.opts.includesKey('Carrier') then
		carrier := self.opts.str("Carrier");
	endif;	
	
	create pxyVVR transient;
	//pxyVVR.setProxyFlexiGate(_driver, _driver, carrier, _truck, _state, yic, self.getTerminal(), gate,self.getGateLane(adminGate, 1), "");		//13/05/2022 navhl20 TFS 53430
	pxyVVR.setProxyFlexiGate(_driver, _driver, carrier, null, _truck, _state, yic, self.getTerminal(), gate,self.getGateLane(adminGate, 1), "");	//13/05/2022 navhl20 TFS 53430  
				
	pxyVVR.setAutoComplete(self.opts.bool("AutoComplete"));
	now := app.actualTimeAppServer();
	pxyVVR.setTimeIn(now.date, now.time);
	
	pxyVVR.setMyTerminal(self.getTerminal());
	
	app.myTrxCA.trxCreateVehicleVisitFlexi(pxyVVR, vVR, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	return vVR;

epilog
	delete pxyVVR;
end;</source>
        <Parameter name="_truck" type="String"/>
        <Parameter name="_state" type="String"/>
        <Parameter name="_driver" type="String"/>
        <Parameter name="_gateName" type="String"/>
        <ReturnType type="CM_VehicleVisitRecord"/>
    </JadeMethod>
    <JadeMethod name="addVesselBays" id="af3e5ba1-3e92-4d13-82b1-e83ce66cfa5c">
        <source>addVesselBays(_vesselName : String) : CM_Vessel;
//26 March 2010 cnwrs1	
// 29/07/2011	cnwmh5	Change to use UT_UnitTest.opts
// 17/8/11 CNWAB1 add in decks
//
vars
	vessel					: CM_Vessel;
	pxyCellularVessel		: CM_CellularVesselStructure;
	pxyCellDefn				: CM_CellDefn;
	pxyTierDefn				: CM_TierDefn;
	bay						: CM_BayDefn;
	bays, b, b1, b2 : Integer;
	vesselName, baysString: String;
	big: Boolean;
begin
	vesselName:=_vesselName ;	
	vessel	:= self.getVessel( vesselName );

	assertNotNull(vessel);

	// Create the Bays
	pxyCellularVessel := app.createUpdateProxy(vessel.myCellularVesselStructure).CM_CellularVesselStructure;
	
	pxyCellularVessel.setProxyCellularVessel(null, true, true, false, 0); // PAR 32286
	
	// pxyCellularVessel.createProxyBaysFromString("01 03" &amp; CM_CellularVesselStructure.HoldSeperator &amp; "05 07"&amp; CM_CellularVesselStructure.HoldSeperator &amp; "09 11");
	
	big := self.opts.bool("big");
	bays := self.opts.intDef( "Bays" , 3);
	foreach b in 1 to bays do
		if b &gt; 1 then
			baysString := baysString &amp; CM_CellularVesselStructure.HoldSeperator;
		endif;
		b1 := ((b - 1) * 4) + 1;
		b2 := b1 + 2;
		baysString := baysString &amp; b1.stringWithLeadingZeros(2) &amp; " " &amp; b2.stringWithLeadingZeros(2);
	endforeach;
	pxyCellularVessel.createProxyBaysFromString(baysString);
	
	foreach bay in pxyCellularVessel.allBaysByOrdinal do
		// OD Cells
		if big then
			bay.allCellsOnDeck.purge;
			create pxyCellDefn transient;
			pxyCellDefn.setProxy("08", 1, 1, bay, null, 0);
			create pxyCellDefn transient;
			pxyCellDefn.setProxy("06", 2, 2, bay, null, 0);
			create pxyCellDefn transient;
			pxyCellDefn.setProxy("04", 3, 3, bay, null, 0);
			create pxyCellDefn transient;
			pxyCellDefn.setProxy("02", 4, 4, bay, null, 0);
			create pxyCellDefn transient;
			pxyCellDefn.setProxy("01", 5, 5, bay, null, 0);
			create pxyCellDefn transient;
			pxyCellDefn.setProxy("03", 6, 6, bay, null, 0);
			create pxyCellDefn transient;
			pxyCellDefn.setProxy("05", 7, 7, bay, null, 0);
			create pxyCellDefn transient;
			pxyCellDefn.setProxy("07", 8, 8, bay, null, 0);
			// UD Cells
			bay.allCellsUnderDeck.purge;
			create pxyCellDefn transient;
			pxyCellDefn.setProxy("08", 1, 1, null, bay, 0);
			create pxyCellDefn transient;
			pxyCellDefn.setProxy("06", 2, 2, null, bay, 0);
			create pxyCellDefn transient;
			pxyCellDefn.setProxy("04", 3, 3, null, bay, 0);
			create pxyCellDefn transient;
			pxyCellDefn.setProxy("02", 4, 4, null, bay, 0);
			create pxyCellDefn transient;
			pxyCellDefn.setProxy("01", 5, 5, null, bay, 0);
			create pxyCellDefn transient;
			pxyCellDefn.setProxy("03", 6, 6, null, bay, 0);
			create pxyCellDefn transient;
			pxyCellDefn.setProxy("05", 7, 7, null, bay, 0);
			create pxyCellDefn transient;
			pxyCellDefn.setProxy("07", 8, 8, null, bay, 0);
	
			// OD Tiers
			bay.allTiersOnDeck.purge;
			create pxyTierDefn transient;
			pxyTierDefn.setProxy("82", 1, 1, bay, null);
			create pxyTierDefn transient;
			pxyTierDefn.setProxy("84", 2, 2, bay, null);
			create pxyTierDefn transient;
			pxyTierDefn.setProxy("86", 3, 3, bay, null);
			create pxyTierDefn transient;
			pxyTierDefn.setProxy("88", 4, 4, bay, null);
			create pxyTierDefn transient;
			pxyTierDefn.setProxy("90", 5, 5, bay, null);
			create pxyTierDefn transient;
			pxyTierDefn.setProxy("92", 6, 6, bay, null);
	
			// UD Tiers
			bay.allTiersUnderDeck.purge;
			create pxyTierDefn transient;
			pxyTierDefn.setProxy("02", 1, 1, null, bay);
			create pxyTierDefn transient;
			pxyTierDefn.setProxy("04", 2, 2, null, bay);
			create pxyTierDefn transient;
			pxyTierDefn.setProxy("06", 3, 3, null, bay);
			create pxyTierDefn transient;
			pxyTierDefn.setProxy("08", 4, 4, null, bay);
			create pxyTierDefn transient;
			pxyTierDefn.setProxy("10", 5, 5, null, bay);
			create pxyTierDefn transient;
			pxyTierDefn.setProxy("12", 6, 6, null, bay);
		else
			bay.allCellsOnDeck.purge;
			create pxyCellDefn transient;
			pxyCellDefn.setProxy("06", 1, 1, bay, null, 0);
			create pxyCellDefn transient;
			pxyCellDefn.setProxy("04", 2, 2, bay, null, 0);
			create pxyCellDefn transient;
			pxyCellDefn.setProxy("02", 3, 3, bay, null, 0);
			create pxyCellDefn transient;
			pxyCellDefn.setProxy("01", 4, 4, bay, null, 0);
			create pxyCellDefn transient;
			pxyCellDefn.setProxy("03", 5, 5, bay, null, 0);
			create pxyCellDefn transient;
			pxyCellDefn.setProxy("05", 6, 6, bay, null, 0);
			// UD Cells
			bay.allCellsUnderDeck.purge;
			create pxyCellDefn transient;
			pxyCellDefn.setProxy("04", 1, 1, null, bay, 0);
			create pxyCellDefn transient;
			pxyCellDefn.setProxy("02", 2, 2, null, bay, 0);
			create pxyCellDefn transient;
			pxyCellDefn.setProxy("01", 3, 3, null, bay, 0);
			create pxyCellDefn transient;
			pxyCellDefn.setProxy("03", 4, 4, null, bay, 0);
	
			// OD Tiers
			bay.allTiersOnDeck.purge;
			create pxyTierDefn transient;
			pxyTierDefn.setProxy("82", 1, 1, bay, null);
			create pxyTierDefn transient;
			pxyTierDefn.setProxy("84", 2, 2, bay, null);
			create pxyTierDefn transient;
			pxyTierDefn.setProxy("86", 3, 3, bay, null);
			create pxyTierDefn transient;
			pxyTierDefn.setProxy("88", 4, 4, bay, null);
	
			// UD Tiers
			bay.allTiersUnderDeck.purge;
			create pxyTierDefn transient;
			pxyTierDefn.setProxy("02", 1, 1, null, bay);
			create pxyTierDefn transient;
			pxyTierDefn.setProxy("04", 2, 2, null, bay);
			create pxyTierDefn transient;
			pxyTierDefn.setProxy("06", 3, 3, null, bay);
		endif;
	endforeach;

	app.myTrxUA.trxUpdateVesselStructure(pxyCellularVessel, app.myPassport);
	assertNoTrxErrorsOrWarnings();
	
	return vessel;
	
epilog

	delete pxyCellularVessel;
	
end;
</source>
        <Parameter name="_vesselName" type="String"/>
        <ReturnType type="CM_Vessel"/>
    </JadeMethod>
    <JadeMethod name="addVesselCellular" id="a7fb22b2-6bc6-4fb2-923a-34023966e434">
        <source>addVesselCellular( _name : String; _operator : CM_Operator ) : CM_Vessel;
//29 August 2008	cnwdw1	
//
vars

begin
	return self.addVesselCellularWithCode(_name, _name, _operator); 
end;
</source>
        <Parameter name="_name" type="String"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <ReturnType type="CM_Vessel"/>
    </JadeMethod>
    <JadeMethod name="addVesselCellularNoHMS" id="08215588-8850-4600-b0ad-5ceb3183a998">
        <source>addVesselCellularNoHMS( _name : String; _operator : CM_Operator) : CM_Vessel;

/* Changes

Date		Name	TFS#		Description
============================================================================
29/08/2008	cnwdw1	
12 2010		cnwgb1 				Modified 
29/07/2011	cnwmh5				Change to use UT_UnitTest.opts
04/03/2019	jlgka1	37102		STWR CAMS STANDARD CODECO Add isBarge Flag.
============================================================================*/
vars
	vessel					: CM_Vessel;
	pxyVessel				: CM_Vessel;
	pxyCellVessel			: CM_CellularVesselStructure;
	//pxyHMSVesselData		: HMS_VesselData;
	pxyCellularVessel		: CM_CellularVesselStructure;
	pxyCellDefn				: CM_CellDefn;
	pxyTierDefn				: CM_TierDefn;
	bay						: CM_BayDefn;
	conflictManager			: CMIF_HMS_ConflictsManager;
	tidalClassArrival		: HMS_TidalClass;				// cnwrl1 20/05/2010 PAR 24012
	tidalClassDept			: HMS_TidalClass;				// cnwrl1 20/05/2010 PAR 24012
	hms_VesselDataHarbour	: HMS_VesselDataHarbour;		// cnwrl1 20/05/2010 PAR 24012
	hlid : CM_HatchLidVessel;
	allHolds : CM_VesselHoldSet; 
	baySet: CM_BaySet;
begin
	
	create pxyVessel transient;
	
	pxyVessel.setProxyForVessel(null,
								_name,
								_name,
								self.opts.str( ETRow_CallSign ),
								"",
								self.createdByUnitTest(null),							// 18/08/2015 cnwmh5
								"",
								self.opts.str( ETRow_LloydsNumber ),
								1,
								0,
								0,
								VESSEL_TYPE_LOLO,
								2000,
								null,
								null,
								null,
								null,
								null,
								null,
								null,
								true,
								false,
								_operator,
								null,
								false);

	create pxyCellVessel transient;
	pxyVessel.setProxyVesselStructures(null, pxyCellVessel, null);

	//create pxyHMSVesselData transient;
	//pxyVessel.setHMSVesselData(pxyHMSVesselData);
	
	// cnwrl1 20/05/2010 PAR 24012 - start of coding
	/*
	create hms_VesselDataHarbour transient;	// NOTE: the delete is handled by the delete on the pxyVessel
	
	tidalClassArrival	:= app.myRoot.allTidalClasses[ 'A' ];
	tidalClassDept		:= app.myRoot.allTidalClasses[ 'C' ];
	
	hms_VesselDataHarbour.setProxy(	null,
									false,
									false,
									null,
									null,
									null,
									null,
									null,
									null,
									null,
									self.getTerminal().myHarbour,
									null,
									null,
									null,
									null,
									tidalClassArrival,
									tidalClassDept );
	pxyHMSVesselData.allVesselDataForHarbour.add( hms_VesselDataHarbour );
	// cnwrl1 20/05/2010 PAR 24012 - end of coding
	
	pxyHMSVesselData.setProxy(app.myRoot,
							false,
							false,
							false,
							false,
							false,
							false,
							"",
							"",
							"",
							0,
							0,
							0,
							100,
							20000,
							20000,
							0,
							0,
							0,
							0,
							0,
							null,
							app.myRoot.allVesselTypes["C"]);
	*/
	app.myTrxCA.trxCreateVessel(pxyVessel, vessel, conflictManager, app.myPassport);
	assertNoTrxErrorsOrWarnings();
	delete pxyVessel;
	
	// Create the Bays
	pxyCellularVessel := app.createUpdateProxy(vessel.myCellularVesselStructure).CM_CellularVesselStructure;
	
	pxyCellularVessel.setProxyCellularVessel(null,true,true,false, 0); // PAR 32286
	pxyCellularVessel.createProxyBaysFromString("01 03" &amp; CM_CellularVesselStructure.HoldSeperator &amp; "05 07"&amp; CM_CellularVesselStructure.HoldSeperator &amp; "09 11");

	create allHolds transient;
	create baySet transient;

	foreach bay in pxyCellularVessel.allBaysByOrdinal do
	
		bay.setForUpdateWeights(999000,999000,999000,999000,999000);
		// OD Cells
		bay.allCellsOnDeck.purge;
		create pxyCellDefn transient;
		pxyCellDefn.setProxy("06", 1, 1, bay, null, 0);
		create pxyCellDefn transient;
		pxyCellDefn.setProxy("04", 2, 2, bay, null, 0);
		create pxyCellDefn transient;
		pxyCellDefn.setProxy("02", 3, 3, bay, null, 0);
		create pxyCellDefn transient;
		pxyCellDefn.setProxy("01", 4, 4, bay, null, 0);
		create pxyCellDefn transient;
		pxyCellDefn.setProxy("03", 5, 5, bay, null, 0);
		create pxyCellDefn transient;
		pxyCellDefn.setProxy("05", 6, 6, bay, null, 0);

		// UD Cells
		bay.allCellsUnderDeck.purge;
		create pxyCellDefn transient;
		pxyCellDefn.setProxy("04", 1, 1, null, bay, 0);
		create pxyCellDefn transient;
		pxyCellDefn.setProxy("02", 2, 2, null, bay, 0);
		create pxyCellDefn transient;
		pxyCellDefn.setProxy("01", 3, 3, null, bay, 0);
		create pxyCellDefn transient;
		pxyCellDefn.setProxy("03", 4, 4, null, bay, 0);

		// OD Tiers
		bay.allTiersOnDeck.purge;
		create pxyTierDefn transient;
		pxyTierDefn.setProxy("82", 1, 1, bay, null);
		create pxyTierDefn transient;
		pxyTierDefn.setProxy("84", 2, 2, bay, null);
		create pxyTierDefn transient;
		pxyTierDefn.setProxy("86", 3, 3, bay, null);
		create pxyTierDefn transient;
		pxyTierDefn.setProxy("88", 4, 4, bay, null);

		// UD Tiers
		bay.allTiersUnderDeck.purge;
		create pxyTierDefn transient;
		pxyTierDefn.setProxy("02", 1, 1, null, bay);
		create pxyTierDefn transient;
		pxyTierDefn.setProxy("04", 2, 2, null, bay);
		create pxyTierDefn transient;
		pxyTierDefn.setProxy("06", 3, 3, null, bay);

		// HATCH LID
		create hlid transient;
		allHolds.clear;
		baySet.clear;
		allHolds.add(bay.myHold);
		baySet.add(bay);
		hlid.setProxy(bay.ordinalBay, bay.ordinalBay, 1,6,1,4,false, false,allHolds, baySet);
		hlid.setMyVessel(pxyCellularVessel);
	endforeach;

	app.myTrxUA.trxUpdateVesselStructure(pxyCellularVessel, app.myPassport);
	assertNoTrxErrorsOrWarnings();
	
	return vessel;
	
epilog
	delete pxyVessel;
	delete pxyCellularVessel;
	delete allHolds;
	delete baySet;

end;
</source>
        <Parameter name="_name" type="String"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <ReturnType type="CM_Vessel"/>
    </JadeMethod>
    <JadeMethod name="addVesselCellularWithCode" id="081d4b9f-060b-4f42-aabd-84c7c9fde995">
        <source>addVesselCellularWithCode(_code, _name : String; _operator : CM_Operator) : CM_Vessel;
/* Changes

Date		Name	TFS#		Description
============================================================================
29/08/2008	cnwdw1	
11/02/2014	cnwma1				Add missing details for clone test
04/03/2019	jlgka1	37102		STWR CAMS STANDARD CODECO Add isBarge Flag.
============================================================================*/
vars
	vessel						: CM_Vessel;
	pxyVessel					: CM_Vessel;
	pxyCellVessel				: CM_CellularVesselStructure;
	pxyCellularVessel			: CM_CellularVesselStructure;
	pxyCellDefn					: CM_CellDefn;
	pxyTierDefn					: CM_TierDefn;
	bay							: CM_BayDefn;
	hlid 						: CM_HatchLidVessel;
	allHolds 					: CM_VesselHoldSet; 
	conflictManager				: CMIF_HMS_ConflictsManager;
	groupLabelCriteriaColl  	: CM_YACriteriaTypeArray;
	pxyStructuralElements		: CM_VesselStructuralElements;
	vslSection 			    	: CM_VesselSectionVessel;
	vslrealSection				: CM_VesselSection;
	vslTank						: CM_VesselTankVessel;
	vslRealTank 				: CM_VesselTank;
	pxyVoyageAllocationConfig 	: CM_VoyageAllocationConfig;
	harbour					 	: HMS_Harbour;
	tidalClassArrival			: HMS_TidalClass;				// cnwrl1 20/05/2010 PAR 24012
	tidalClassDept				: HMS_TidalClass;				// cnwrl1 20/05/2010 PAR 24012
	hms_VesselDataHarbour		: HMS_VesselDataHarbour;		// cnwrl1 20/05/2010 PAR 24012
	resourceType				: HMS_ResourceType;
	pxyResourceType				: HMS_ResourceTypeForMovement;
	pxyVesselDataHarbour 	 	: HMS_VesselDataHarbour;
	pxyHMSVesselData			: HMS_VesselData;
	realHarbourBerthPreference  : HMS_BerthPreferenceVesselData;
	harbourBerthPrefArray		: ObjectArray;
	objj							: Object;
	coll	 					: ObjectArray;
	resourceTypeArray			: StringArray;
	baySet						: CM_BaySet;
	holds 						: Integer;
	idx 						: Integer;
	str 						: String;
	name						: String;
	yearOfBuild					: Integer;
	lengthOverall				: Decimal[6,2];
	deadWeight					: Integer;
	grossRegTonnes				: Integer;
	tmpStr						: String;
	numTugs 					: Integer;
	moveType 					: String;
	
begin
	
	name := _name;
	if self.opts.includesKey("VesselName") then
		name := self.opts.str("VesselName");
	endif;
	
	yearOfBuild := 2000;
	if self.opts.includesKey("YearOfBuild") then
		yearOfBuild := self.opts.int("YearOfBuild");
	endif;
	
	create pxyVessel transient;
	
	pxyVessel.setProxyForVessel(null,
								_code,
								name,
								self.opts.str(ETRow_CallSign),
								self.opts.str("ClassLabel"),
								self.createdByUnitTest(null),							// 18/08/2015 cnwmh5
								"",
								self.opts.str(ETRow_LloydsNumber),
								1,
								self.opts.int("DispatchRate"),
								self.opts.int("CraneClearance"),
								VESSEL_TYPE_LOLO,
								yearOfBuild,
								self.opts.dec("LOAWithRampsDown"),
								self.opts.dec("AirDraft"),
								self.opts.dec("MaxVesselBeam"),
								self.opts.dec("DraftBow"),
								self.opts.dec("DraftStern"),
								null,
								null,
								true,
								false,
								_operator,
								self.opts.obj("VesselTrade").CM_Trade,
								false);

	create pxyCellVessel transient;
	pxyVessel.setProxyVesselStructures(null, pxyCellVessel, null);

	create pxyHMSVesselData transient;
	pxyVessel.setHMSVesselData(pxyHMSVesselData);
	
	// cnwrl1 20/05/2010 PAR 24012 - start of coding
	create hms_VesselDataHarbour transient;	// NOTE: the delete is handled by the delete on the pxyVessel
	
	tidalClassArrival	:= app.myRoot.allTidalClasses[ 'A' ];
	if self.opts.includesKey("TidalClassDept") then
		tidalClassDept := app.myRoot.allTidalClasses[self.opts.str("TidalClassDept")];
	else
		tidalClassDept		:= app.myRoot.allTidalClasses[ 'C' ];
	endif;
	
	if self.opts.includesKey("Harbour") then
		harbour := self.opts.obj("Harbour").HMS_Harbour;
	else	
		harbour := self.getTerminal().myHarbour;
	endif;
	
	hms_VesselDataHarbour.setProxy(	self.opts.str("PilotRemarks"),
									false,
									false,
									self.opts.int("EstTieUpTime"),
									self.opts.int("CrewLetGo"),
									self.opts.int("CrewTieUp"),
									self.opts.int("NoTugsIn"),
									self.opts.int("NoTugsOut"),
									self.opts.int("BerthPriority"),
									self.opts.int("NumHistVst"),
									harbour,
									self.opts.obj("LineCompany").HMS_LineCompany,
									self.opts.obj("ShippingAgent").CM_ShippingAgent,
									self.opts.obj("CategoryIn").HMS_VesselCategory,
									self.opts.obj("CategoryOut").HMS_VesselCategory,
									tidalClassArrival,
									tidalClassDept );
	pxyHMSVesselData.allVesselDataForHarbour.add( hms_VesselDataHarbour );
	// cnwrl1 20/05/2010 PAR 24012 - end of coding
	
	if self.opts.includesKey("DimLengthOverall") then
		lengthOverall := self.opts.dec("DimLengthOverall");
	else
		lengthOverall := 100;
	endif;
	
	if self.opts.includesKey("DeadWeight") then
		deadWeight := self.opts.int("DeadWeight");
	else	
		deadWeight := 20000;
	endif;
	
	if self.opts.includesKey("GrossRegTonnes") then
		grossRegTonnes := self.opts.int("GrossRegTonnes");
	else	
		grossRegTonnes := 20000;
	endif;
	
	pxyHMSVesselData.setProxy(app.myRoot,
							self.opts.bool("coastalService"),
							false,
							false,
							false,
							false,
							false,
							false,
							false,
							self.opts.str("RemarksGeneral"),
							self.opts.str("PreviousName"),
							self.opts.str("CountryCode"),
							self.opts.dec("DimBeam"),
							self.opts.dec("DimDraftAft"),
							self.opts.dec("DimDraftFore"),
							lengthOverall,
							deadWeight,
							grossRegTonnes,
							19000,
							0,
							150,
							50,
							0,
							0,
							self.opts.obj("ShippingLine").CM_ShippingLine,
							app.myRoot.allVesselTypes["C"]);
							
							
							
	if self.opts.includesKey("VoyageAllocationsCriteria") then
		create pxyVoyageAllocationConfig transient;
		create groupLabelCriteriaColl transient;
		pxyVoyageAllocationConfig.setProxyVoyage(self.opts.obj("VoyageAllocationsCriteria").CM_YACriteriaTypeArray,
			groupLabelCriteriaColl, Red, CM_YATypeCommodityGroup.firstInstance, null, null);
		pxyVessel.setVoyageAllocationConfig(pxyVoyageAllocationConfig);
	endif;
	
	
	// create the resource type coll
	if self.opts.includesKey("ResourceTypes") then
		// setup resource types we want
		create resourceTypeArray transient;
		resourceTypeArray.add("TUGS");
		resourceTypeArray.add("PILOT");
		
		create coll transient; 
		foreach tmpStr in resourceTypeArray do
			resourceType := app.myRoot.allResourceTypes[tmpStr];
			if resourceType &lt;&gt; null then
				coll.add(resourceType);
			endif;
		endforeach;
		
		// set default resources for the arrival movement
		moveType := HMSMovementTypeArrival;
		numTugs := 3;
		//harbour := hms_VesselDataHarbour.myHarbour;
		pxyResourceType := hms_VesselDataHarbour.allMovementResourcesByMovement[moveType];
		if pxyResourceType = null then
			create pxyResourceType transient;
			hms_VesselDataHarbour.allMovementResourcesByMovement.add(pxyResourceType);  
			//coll.add(_resourceType);
		endif;
		pxyResourceType.setProxy(moveType, numTugs, harbour, coll);
	endif;
	
	
	create pxyStructuralElements transient;
	pxyVessel.setMyStructuralElements(pxyStructuralElements);
	
	
	app.myTrxCA.trxCreateVessel(pxyVessel, vessel, conflictManager, app.myPassport);
	assertNoTrxErrorsOrWarnings();
	delete pxyVessel;
	
	
	// Add Vessel Section
	if self.opts.includesKey("VesselSection") then
	pxyStructuralElements:=vessel.myStructuralElements;
	create vslSection transient;
	vslSection.setProxy( self.opts.str("vslSectionCode"), self.opts.dec("vslSectionPostion") , self.opts.str("vslSectionDesc"));
	vslSection.setMyVesselStructure(pxyStructuralElements);
	app.myTrxCA.trxCreateVesselSection(vslSection,vslrealSection,app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	endif;

	// Add Vessel Tank
	if self.opts.includesKey("VesselTank") then
	create vslTank transient;
	vslTank.setProxy( self.opts.str("VslTankCode"), self.opts.str("VslTankDesc"), self.opts.str("VslTankRemarks"), self.opts.dec("VslTankVolume") ,  self.opts.obj("vslTankContentType").CM_VesselTankContentsType );
	vslTank.setMyVesselStructure(pxyStructuralElements);
	app.myTrxCA.trxCreateVesselTank(vslTank,vslRealTank,app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	endif;
	
	
	
	
	
	// Create Berth Prefrences 
	if self.opts.includesKey("HarbourPrefrencesArray") then
	
		pxyHMSVesselData := vessel.myHMSVesselData;
		if 	pxyHMSVesselData = null then
			create pxyHMSVesselData transient;
			vessel.setHMSVesselData(pxyHMSVesselData);
		endif;
				
		pxyVesselDataHarbour := pxyHMSVesselData.allVesselDataForHarbour[harbour];
		if pxyVesselDataHarbour = null then
			create pxyVesselDataHarbour transient;
			pxyHMSVesselData.allVesselDataForHarbour.add(pxyVesselDataHarbour);
		endif;
		
		beginTransaction;
		harbourBerthPrefArray := self.opts.obj("HarbourPrefrencesArray").ObjectArray;
		foreach objj in harbourBerthPrefArray do
			create realHarbourBerthPreference persistent;
			realHarbourBerthPreference.setForCreate(objj.HMS_BerthPreferenceVesselData, app.myPassport); 
			pxyVesselDataHarbour.addBerthPreference(realHarbourBerthPreference);
		endforeach;
		commitTransaction;
		self.assertNoTrxErrorsOrWarnings();	
	endif;
	

	
	
	// Create the Bays
	pxyCellularVessel := app.createUpdateProxy(vessel.myCellularVesselStructure).CM_CellularVesselStructure;
	
	pxyCellularVessel.setProxyCellularVessel(null, true, true, false, 0); // PAR 32286
	if self.opts.includesKey(UTVS_Bays) then
		holds := self.opts.int(UTVS_Bays);
		foreach idx in 1 to holds step 4 do
			if str = null then
				str := idx.padLeadingWith("0",2)&amp;' '&amp;(idx+2).padLeadingWith("0",2);
			else
				str := str &amp; CM_CellularVesselStructure.HoldSeperator &amp; idx.padLeadingWith("0",2)&amp;' '&amp;(idx+2).padLeadingWith("0",2);
			endif;
		endforeach;
		pxyCellularVessel.createProxyBaysFromString(str);
	else
		pxyCellularVessel.createProxyBaysFromString("01 03" &amp; CM_CellularVesselStructure.HoldSeperator &amp; "05 07"&amp; CM_CellularVesselStructure.HoldSeperator &amp; "09 11");
	endif;

	create allHolds transient;
	create baySet transient;

	foreach bay in pxyCellularVessel.allBaysByOrdinal do
	
		bay.setForUpdateWeights(999000,999000,999000,999000,999000);
		// OD Cells
		bay.allCellsOnDeck.purge;
		create pxyCellDefn transient;
		pxyCellDefn.setProxy("06", 1, 1, bay, null, 0);
		create pxyCellDefn transient;
		pxyCellDefn.setProxy("04", 2, 2, bay, null, 0);
		create pxyCellDefn transient;
		pxyCellDefn.setProxy("02", 3, 3, bay, null, 0);
		create pxyCellDefn transient;
		pxyCellDefn.setProxy("01", 4, 4, bay, null, 0);
		create pxyCellDefn transient;
		pxyCellDefn.setProxy("03", 5, 5, bay, null, 0);
		create pxyCellDefn transient;
		pxyCellDefn.setProxy("05", 6, 6, bay, null, 0);

		// UD Cells
		bay.allCellsUnderDeck.purge;
		create pxyCellDefn transient;
		pxyCellDefn.setProxy("04", 1, 1, null, bay, 0);
		create pxyCellDefn transient;
		pxyCellDefn.setProxy("02", 2, 2, null, bay, 0);
		create pxyCellDefn transient;
		pxyCellDefn.setProxy("01", 3, 3, null, bay, 0);
		create pxyCellDefn transient;
		pxyCellDefn.setProxy("03", 4, 4, null, bay, 0);

		// OD Tiers
		bay.allTiersOnDeck.purge;
		create pxyTierDefn transient;
		pxyTierDefn.setProxy("82", 1, 1, bay, null);
		create pxyTierDefn transient;
		pxyTierDefn.setProxy("84", 2, 2, bay, null);
		create pxyTierDefn transient;
		pxyTierDefn.setProxy("86", 3, 3, bay, null);
		create pxyTierDefn transient;
		pxyTierDefn.setProxy("88", 4, 4, bay, null);

		// UD Tiers
		bay.allTiersUnderDeck.purge;
		create pxyTierDefn transient;
		pxyTierDefn.setProxy("02", 1, 1, null, bay);
		create pxyTierDefn transient;
		pxyTierDefn.setProxy("04", 2, 2, null, bay);
		create pxyTierDefn transient;
		pxyTierDefn.setProxy("06", 3, 3, null, bay);

		// HATCH LID
		create hlid transient;
		allHolds.clear;
		baySet.clear;
		allHolds.add(bay.myHold);
		baySet.add(bay);
		hlid.setProxy(bay.ordinalBay, bay.ordinalBay, 1,6,1,4,false, false,allHolds, baySet);
		hlid.setMyVessel(pxyCellularVessel);
	endforeach;

	app.myTrxUA.trxUpdateVesselStructure(pxyCellularVessel, app.myPassport);
	assertNoTrxErrorsOrWarnings();
	
	return vessel;
	
epilog
	delete pxyVessel;
	delete pxyCellularVessel;
	delete allHolds;
	delete baySet;
	delete pxyVoyageAllocationConfig;
	delete groupLabelCriteriaColl;
	delete resourceTypeArray;
	delete vslSection;
	delete vslTank;
	delete coll;
end;
</source>
        <Parameter name="_code" type="String"/>
        <Parameter name="_name" type="String"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <ReturnType type="CM_Vessel"/>
    </JadeMethod>
    <JadeMethod name="addVesselCellularWithCode_OLD" id="20a32570-c639-462d-b7b8-06e86f724fd5">
        <source>addVesselCellularWithCode_OLD(_code, _name : String; _operator : CM_Operator) : CM_Vessel;

/* Changes

Date		Name	TFS#		Description
============================================================================
29/08/2008	cnwdw1	
04/03/2019	jlgka1	37102		STWR CAMS STANDARD CODECO Add isBarge Flag.
============================================================================*/
vars
	vessel					: CM_Vessel;
	pxyVessel				: CM_Vessel;
	pxyCellVessel			: CM_CellularVesselStructure;
	pxyHMSVesselData		: HMS_VesselData;
	pxyCellularVessel		: CM_CellularVesselStructure;
	pxyCellDefn				: CM_CellDefn;
	pxyTierDefn				: CM_TierDefn;
	bay						: CM_BayDefn;
	conflictManager			: CMIF_HMS_ConflictsManager;
	tidalClassArrival		: HMS_TidalClass;				// cnwrl1 20/05/2010 PAR 24012
	tidalClassDept			: HMS_TidalClass;				// cnwrl1 20/05/2010 PAR 24012
	hms_VesselDataHarbour	: HMS_VesselDataHarbour;		// cnwrl1 20/05/2010 PAR 24012
	hlid : CM_HatchLidVessel;
	allHolds : CM_VesselHoldSet; 
	baySet: CM_BaySet;
	holds : Integer;
	idx : Integer;
	str : String;
begin
	
	create pxyVessel transient;
	
	pxyVessel.setProxyForVessel(null,
								_code,
								_name,
								self.opts.str(ETRow_CallSign),
								"",
								self.createdByUnitTest(null),							// 18/08/2015 cnwmh5
								"",
								self.opts.str(ETRow_LloydsNumber),
								1,
								0,
								0,
								VESSEL_TYPE_LOLO,
								2000,
								null,
								null,
								null,
								null,
								null,
								null,
								null,
								true,
								false,
								_operator,
								null,
								false);

	create pxyCellVessel transient;
	pxyVessel.setProxyVesselStructures(null, pxyCellVessel, null);

	create pxyHMSVesselData transient;
	pxyVessel.setHMSVesselData(pxyHMSVesselData);
	
	// cnwrl1 20/05/2010 PAR 24012 - start of coding
	create hms_VesselDataHarbour transient;	// NOTE: the delete is handled by the delete on the pxyVessel
	
	tidalClassArrival	:= app.myRoot.allTidalClasses[ 'A' ];
	tidalClassDept		:= app.myRoot.allTidalClasses[ 'C' ];
	
	hms_VesselDataHarbour.setProxy(	null,
									false,
									false,
									null,
									null,
									null,
									null,
									null,
									null,
									null,
									self.getTerminal().myHarbour,
									null,
									null,
									null,
									null,
									tidalClassArrival,
									tidalClassDept );
	pxyHMSVesselData.allVesselDataForHarbour.add( hms_VesselDataHarbour );
	// cnwrl1 20/05/2010 PAR 24012 - end of coding
	
	pxyHMSVesselData.setProxy(app.myRoot,
							false,
							false,
							false,
							false,
							false,
							false,
							false,
							false,
							"",
							"",
							"",
							0,
							0,
							0,
							100,
							20000,
							20000,
							19000,
							0,
							0,
							0,
							0,
							0,
							null,
							app.myRoot.allVesselTypes["C"]);
	
	app.myTrxCA.trxCreateVessel(pxyVessel, vessel, conflictManager, app.myPassport);
	assertNoTrxErrorsOrWarnings();
	delete pxyVessel;
	
	// Create the Bays
	pxyCellularVessel := app.createUpdateProxy(vessel.myCellularVesselStructure).CM_CellularVesselStructure;
	
	pxyCellularVessel.setProxyCellularVessel(null, true, true, false, 0); // PAR 32286
	if self.opts.includesKey(UTVS_Bays) then
		holds := self.opts.int(UTVS_Bays);
		foreach idx in 1 to holds step 4 do
			if str = null then
				str := idx.padLeadingWith("0",2)&amp;' '&amp;(idx+2).padLeadingWith("0",2);
			else
				str := str &amp; CM_CellularVesselStructure.HoldSeperator &amp; idx.padLeadingWith("0",2)&amp;' '&amp;(idx+2).padLeadingWith("0",2);
			endif;
		endforeach;
		pxyCellularVessel.createProxyBaysFromString(str);
	else
		pxyCellularVessel.createProxyBaysFromString("01 03" &amp; CM_CellularVesselStructure.HoldSeperator &amp; "05 07"&amp; CM_CellularVesselStructure.HoldSeperator &amp; "09 11");
	endif;

	create allHolds transient;
	create baySet transient;

	foreach bay in pxyCellularVessel.allBaysByOrdinal do
	
		bay.setForUpdateWeights(999000,999000,999000,999000,999000);
		// OD Cells
		bay.allCellsOnDeck.purge;
		create pxyCellDefn transient;
		pxyCellDefn.setProxy("06", 1, 1, bay, null, 0);
		create pxyCellDefn transient;
		pxyCellDefn.setProxy("04", 2, 2, bay, null, 0);
		create pxyCellDefn transient;
		pxyCellDefn.setProxy("02", 3, 3, bay, null, 0);
		create pxyCellDefn transient;
		pxyCellDefn.setProxy("01", 4, 4, bay, null, 0);
		create pxyCellDefn transient;
		pxyCellDefn.setProxy("03", 5, 5, bay, null, 0);
		create pxyCellDefn transient;
		pxyCellDefn.setProxy("05", 6, 6, bay, null, 0);

		// UD Cells
		bay.allCellsUnderDeck.purge;
		create pxyCellDefn transient;
		pxyCellDefn.setProxy("04", 1, 1, null, bay, 0);
		create pxyCellDefn transient;
		pxyCellDefn.setProxy("02", 2, 2, null, bay, 0);
		create pxyCellDefn transient;
		pxyCellDefn.setProxy("01", 3, 3, null, bay, 0);
		create pxyCellDefn transient;
		pxyCellDefn.setProxy("03", 4, 4, null, bay, 0);

		// OD Tiers
		bay.allTiersOnDeck.purge;
		create pxyTierDefn transient;
		pxyTierDefn.setProxy("82", 1, 1, bay, null);
		create pxyTierDefn transient;
		pxyTierDefn.setProxy("84", 2, 2, bay, null);
		create pxyTierDefn transient;
		pxyTierDefn.setProxy("86", 3, 3, bay, null);
		create pxyTierDefn transient;
		pxyTierDefn.setProxy("88", 4, 4, bay, null);

		// UD Tiers
		bay.allTiersUnderDeck.purge;
		create pxyTierDefn transient;
		pxyTierDefn.setProxy("02", 1, 1, null, bay);
		create pxyTierDefn transient;
		pxyTierDefn.setProxy("04", 2, 2, null, bay);
		create pxyTierDefn transient;
		pxyTierDefn.setProxy("06", 3, 3, null, bay);

		// HATCH LID
		create hlid transient;
		allHolds.clear;
		baySet.clear;
		allHolds.add(bay.myHold);
		baySet.add(bay);
		hlid.setProxy(bay.ordinalBay, bay.ordinalBay, 1,6,1,4,false, false,allHolds, baySet);
		hlid.setMyVessel(pxyCellularVessel);
	endforeach;

	app.myTrxUA.trxUpdateVesselStructure(pxyCellularVessel, app.myPassport);
	assertNoTrxErrorsOrWarnings();
	
	return vessel;
	
epilog
	delete pxyVessel;
	delete pxyCellularVessel;
	delete allHolds;
	delete baySet;

end;
</source>
        <Parameter name="_code" type="String"/>
        <Parameter name="_name" type="String"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <ReturnType type="CM_Vessel"/>
    </JadeMethod>
    <JadeMethod name="addVesselDeckLayerLayoutCargo" id="d7361a0f-e1b4-42f8-9942-1e5cf521a402">
        <source>addVesselDeckLayerLayoutCargo(_deck : CM_DeckVessel; _locations : Boolean);
// ---------------------------------------------------------------------------
// Created:     24 March 2011 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

	pxyLayerLayout, realLayerLayout: CM_DeckLayerLayout;
	newDeckItems : ObjectArray;
	obj : Object;
	itemLayout : CM_DeckItemLayout;
begin
	// ## PROXY
	create pxyLayerLayout transient;
	if _locations then
		pxyLayerLayout.setProxy("Containers", "Layer Containers", null, _deck.myDeckLayout, true,ROROLayerType_Cargo);
	else	
		pxyLayerLayout.setProxy("Lanes", "Layer Lanes", null, _deck.myDeckLayout, true,ROROLayerType_Lanes);
	endif;
	self.assertNotNullMsg(pxyLayerLayout.myDeckLayout,_deck.code &amp;  " pxyLayerLayout myDeckLayout ");
	
	// ## CREATE
	app.myTrxCA.trxCreateDeckLayerLayout(pxyLayerLayout, realLayerLayout, false, app.myPassport); 
	self.assertNoTrxErrorsOrWarnings();
	self.assertNotNullMsg(realLayerLayout, _deck.code &amp; " realLayerLayout ");
	self.assertNoTrxErrorsOrWarnings();
	self.assertNotNullMsg(realLayerLayout.myDeckLayout,_deck.code &amp;  " myDeckLayout ");
	
	app.myTrxUA.trxUpdateROROLayerToTop(realLayerLayout, app.myPassport); 
	
	self.assertNoTrxErrorsOrWarnings();
	
	create newDeckItems transient;
	pxyLayerLayout := app.createUpdateProxy(realLayerLayout).CM_DeckLayerLayout;
	
	if _locations then
		app.myTrxUA.trxUpdateROROLayerQuickDraw(pxyLayerLayout, 100, 100, 7, 5, true, DeckItemLayoutType_Locn, 1, newDeckItems, app.myPassport);
		foreach obj in newDeckItems do
			itemLayout := obj.CM_DeckItemLayout;
			itemLayout.setMyDeckLayer(null);
		endforeach;
		app.myTrxUA.trxUpdateROROLayerQuickDraw(pxyLayerLayout, 450, 100, 7, 5, false, DeckItemLayoutType_Locn, 1, newDeckItems, app.myPassport); 
	else
		app.myTrxUA.trxUpdateROROLayerQuickDraw(pxyLayerLayout, 50, 100, 5, 1, true, DeckItemLayoutType_Lane, 1, newDeckItems, app.myPassport); 
	endif;
	
	self.assertNoTrxErrorsOrWarnings();
	

epilog
	delete pxyLayerLayout;
	delete newDeckItems;

end;</source>
        <Parameter name="_deck" type="CM_DeckVessel"/>
        <Parameter name="_locations" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="addVesselDecks" id="163502eb-5a1f-40e8-9140-530336398298">
        <source>addVesselDecks(_vesselName : String);
/*
Purpose:			
Date		Who		Reason
17 August 2011	cnwab1	Initial creation
*/

vars

	vessel : CM_Vessel;
	vesselName : String;
	pxyDeck, parentDeck  : CM_DeckVessel;
	pxySubDeck : CM_DeckVesselSub;
	realDeck : CM_Deck;
	code : String;
	description : String;
	remarks : String;
	maxClearHeight,
	totalArea : Decimal[12,2];
	ordinal: Integer;
	totalVolume : Decimal[12,2];
	totalTEU : Integer;
	totalLM,
	maxLoadStack20,
	maxLoadStack40,
	maxLoadAxel,
	maxLoadM2   : Decimal[12,2];
	numTier : Integer;
	heightFromBL : Decimal[12,2];
	newDeckItems : ObjectArray;
	pxyLayerLayout : CM_DeckLayerLayout;
begin
	vesselName:=_vesselName ;	
	vessel	:= self.getVessel( vesselName );

	assertNotNull(vessel);
	
	create pxyDeck transient;
	
	code:=DECK1;
	description:="DECK1 Description";
	remarks:="Some decking remarks";
	maxClearHeight:=20.5;
	totalArea:=30000.67;
	totalVolume:=234.89;
	totalTEU:=10000;
	totalLM:=23423.45;
	maxLoadStack20:=50000;
	maxLoadStack40:=80000;
	maxLoadAxel:=87534.45;
	maxLoadM2:=234.56;
	numTier:=3;
	heightFromBL:=63455.67;
	ordinal:=1;
	
	pxyDeck.setProxy(	code ,
						description,
						remarks,
						maxClearHeight,
						totalArea,
						totalVolume,
						totalTEU,
						totalLM,
						maxLoadStack20,
						maxLoadStack40,
						maxLoadAxel,
						maxLoadM2 ,
						numTier ,
						heightFromBL );
	pxyDeck.setMyROROStructure(vessel.myROROVesselStructure);
	
	
	
	app.myTrxCA.trxCreateRORODeck(pxyDeck,realDeck,false,app.myPassport);
	
	self.assertNoTrxErrorsOrWarnings();
	
	self.assertNotNullMsg(realDeck, " Real deck = null");
	self.assertTrueMsg(realDeck.isKindOf(CM_DeckVessel),"real deck created class not CM_DeckVessel"); 
	self.assertEqualMsg(realDeck.CM_DeckVessel.myROROStructure, vessel.myROROVesselStructure, " myROROStructure ref = null");
	self.assertEqualMsg(realDeck.code, code,"code !=");
	self.assertEqualMsg(realDeck.description, description,"description !=");
	self.assertEqualMsg(realDeck.remarks, remarks,"remarks !=");
	self.assertEqualMsg(realDeck.maxClearHeight, maxClearHeight,"maxClearHeight !=");
	self.assertEqualMsg(realDeck.totalArea, totalArea,"totalArea !=");
	self.assertEqualMsg(realDeck.ordinal, ordinal,"ordinal !=");
	self.assertEqualMsg(realDeck.totalVolume, totalVolume,"totalVolume !=");
	self.assertEqualMsg(realDeck.totalTEU, totalTEU,"totalTEU !=");
	self.assertEqualMsg(realDeck.totalLM, totalLM,"totalLM !=");
	self.assertEqualMsg(realDeck.maxLoadStack20, maxLoadStack20,"maxLoadStack20 !=");
	self.assertEqualMsg(realDeck.maxLoadStack40, maxLoadStack40,"maxLoadStack40 !=");
	self.assertEqualMsg(realDeck.maxLoadAxel, maxLoadAxel,"maxLoadAxel !=");
	self.assertEqualMsg(realDeck.maxLoadM2, maxLoadM2,"maxLoadM2 !=");
	self.assertEqualMsg(realDeck.numTier, numTier,"numTier !=");
	self.assertEqualMsg(realDeck.heightFromBL, heightFromBL,"heightFromBL !=");
	self.assertNotNullMsg(realDeck.myDeckLayout, "d1 myDeckLayout ");

	delete pxyDeck;
	
	pxyDeck := app.createUpdateProxy(realDeck).CM_DeckVessel;
	
	self.addVesselDeckLayerLayoutCargo(pxyDeck.CM_DeckVessel, true); // container positions
 	
	
	delete pxyDeck;
	
	
// ############
	parentDeck := realDeck.CM_DeckVessel;
	create pxySubDeck transient;
	pxySubDeck.setMyParentDeck(parentDeck);

	code:=DECK1 &amp; "S";
	description:="DECK1 SUB Description";
	remarks:="Some SUB decking remarks";
	maxClearHeight:=20.5;
	totalArea:=30000.67;
	totalVolume:=234.89;
	totalTEU:=10000;
	totalLM:=23423.45;
	maxLoadStack20:=50000;
	maxLoadStack40:=80000;
	maxLoadAxel:=87534.45;
	maxLoadM2:=234.56;
	numTier:=3;
	heightFromBL:=63455.67;
	ordinal:=1;
	
	pxySubDeck.setProxy(	code ,
						description,
						remarks,
						maxClearHeight,
						totalArea,
						totalVolume,
						totalTEU,
						totalLM,
						maxLoadStack20,
						maxLoadStack40,
						maxLoadAxel,
						maxLoadM2 ,
						numTier ,
						heightFromBL );
	pxySubDeck.setMyROROStructure(vessel.myROROVesselStructure);
	
	
	
	app.myTrxCA.trxCreateRORODeck(pxySubDeck,realDeck,false,app.myPassport);
	
	self.assertNoTrxErrorsOrWarnings();
	
	self.assertNotNullMsg(realDeck, " Real deck = null");
	self.assertTrueMsg(realDeck.isKindOf(CM_DeckVessel),"real deck created class not CM_DeckVessel"); 
	self.assertEqualMsg(realDeck.CM_DeckVessel.myROROStructure, null, " myROROStructure ref should be null"); // SUB DECKS DO NOT HAVE THIS REF
	self.assertEqualMsg(realDeck.CM_DeckVesselSub.myParentDeck, parentDeck, " myParentDeck ref = null");
	self.assertEqualMsg(realDeck.code, code,"code !=");
	self.assertEqualMsg(realDeck.description, description,"description !=");
	self.assertEqualMsg(realDeck.remarks, remarks,"remarks !=");
	self.assertEqualMsg(realDeck.maxClearHeight, maxClearHeight,"maxClearHeight !=");
	self.assertEqualMsg(realDeck.totalArea, totalArea,"totalArea !=");
	self.assertEqualMsg(realDeck.ordinal, ordinal,"ordinal !=");
	self.assertEqualMsg(realDeck.totalVolume, totalVolume,"totalVolume !=");
	self.assertEqualMsg(realDeck.totalTEU, totalTEU,"totalTEU !=");
	self.assertEqualMsg(realDeck.totalLM, totalLM,"totalLM !=");
	self.assertEqualMsg(realDeck.maxLoadStack20, maxLoadStack20,"maxLoadStack20 !=");
	self.assertEqualMsg(realDeck.maxLoadStack40, maxLoadStack40,"maxLoadStack40 !=");
	self.assertEqualMsg(realDeck.maxLoadAxel, maxLoadAxel,"maxLoadAxel !=");
	self.assertEqualMsg(realDeck.maxLoadM2, maxLoadM2,"maxLoadM2 !=");
	self.assertEqualMsg(realDeck.numTier, numTier,"numTier !=");
	self.assertEqualMsg(realDeck.heightFromBL, heightFromBL,"heightFromBL !=");
	self.assertNotNullMsg(realDeck.myDeckLayout, "d1 myDeckLayout ");
	
	delete pxySubDeck;
// ############	
	
	
	// AKB added this - 17/6/11
	pxyDeck := app.createUpdateProxy(realDeck).CM_DeckVessel;
	
	self.addVesselDeckLayerLayoutCargo(pxyDeck.CM_DeckVessel, true); // container positions
 	
	
	delete pxyDeck;
	
	create pxyDeck transient;
	code:=DECK2;
	description:="DECK2 Description";
	remarks:="Some deck 2 remarks";
	ordinal:=2;
	pxyDeck.setProxy(	code ,
						description,
						remarks,
						maxClearHeight,
						totalArea,
						totalVolume,
						totalTEU,
						totalLM,
						maxLoadStack20,
						maxLoadStack40,
						maxLoadAxel,
						maxLoadM2 ,
						numTier ,
						heightFromBL );
	pxyDeck.setMyROROStructure(vessel.myROROVesselStructure);
	
	app.myTrxCA.trxCreateRORODeck(pxyDeck,realDeck,false,app.myPassport);
	
	self.assertNoTrxErrorsOrWarnings();
	
	self.assertNotNullMsg(realDeck, " Real deck2 = null");
	self.assertEqualMsg(realDeck.CM_DeckVessel.myROROStructure, vessel.myROROVesselStructure, "d2 myROROStructure ref = null");
	self.assertEqualMsg(realDeck.code, code,"d2 code !=");
	self.assertEqualMsg(realDeck.description, description,"d2 description !=");
	self.assertEqualMsg(realDeck.remarks, remarks,"d2 remarks !=");
	self.assertEqualMsg(realDeck.maxClearHeight, maxClearHeight,"d2 maxClearHeight !=");
	self.assertEqualMsg(realDeck.totalArea, totalArea,"d2 totalArea !=");
	self.assertEqualMsg(realDeck.ordinal, ordinal,"d2 ordinal !=");
	self.assertEqualMsg(realDeck.totalVolume, totalVolume,"d2 totalVolume !=");
	self.assertEqualMsg(realDeck.totalTEU, totalTEU,"d2 totalTEU !=");
	self.assertEqualMsg(realDeck.maxLoadStack20, maxLoadStack20,"d2 maxLoadStack20 !=");
	self.assertEqualMsg(realDeck.maxLoadStack40, maxLoadStack40,"d2 maxLoadStack40 !=");
	self.assertEqualMsg(realDeck.maxLoadAxel, maxLoadAxel,"d2 maxLoadAxel !=");
	self.assertEqualMsg(realDeck.maxLoadM2, maxLoadM2,"d2 maxLoadM2 !=");
	self.assertEqualMsg(realDeck.numTier, numTier,"d2 numTier !=");
	self.assertEqualMsg(realDeck.heightFromBL, heightFromBL,"d2 heightFromBL !=");
	self.assertNotNullMsg(realDeck.myDeckLayout, "d2 myDeckLayout ");
	
	delete pxyDeck;
	// AKB added this - 17/6/11
	pxyDeck := app.createUpdateProxy(realDeck).CM_DeckVessel;
	self.assertNotNullMsg(pxyDeck.myDeckLayout, "d2 proxy myDeckLayout ");
	
	self.addVesselDeckLayerLayoutCargo(pxyDeck.CM_DeckVessel, false); // container positions
 	
epilog
	delete pxyDeck;
	delete pxySubDeck;
	delete newDeckItems;
end;</source>
        <Parameter name="_vesselName" type="String"/>
    </JadeMethod>
    <JadeMethod name="addVesselDefnReefer40" id="cda29b49-57e3-48c3-a81e-e2f1b28573c2">
        <updating/>
        <source>addVesselDefnReefer40(_vessel : CM_Vessel) updating;
// ---------------------------------------------------------------------------
// Created:     31 May 2010 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	theStructure : CM_CellularVesselStructure;
	theBay : CM_Bay;
	theSlot : CM_SlotDefn;
	tmp : String;
begin
	tmp := CM_SlotRequest.Attribute_Forty;
	
	theStructure := _vessel.myCellularVesselStructure;
	
	foreach theBay in theStructure.allBaysByOrdinal discreteLock do
		beginTransaction;
		foreach theSlot in theBay.allSlotsByOrdinal discreteLock do
		
			theSlot.setPropertyValue("reefer",true);
			theSlot.setPropertyValue("power",true);
			
			// ### BACKEND
			if theBay.isAftBay then
				theSlot.setPropertyValue("fortyFront",false);
				theSlot.setPropertyValue("fortyBack",true);
				if theSlot.ordinalTier = 4 or theSlot.ordinalTier = 1 then
					theSlot.setPropertyValue("is30",true);
					theSlot.setPropertyValue("isBackend",true);
				endif;
				if theSlot.ordinalTier = 3 then
					theSlot.setPropertyValue("is45",true);
					theSlot.setPropertyValue("isBackend",true);
				endif;
				if theSlot.ordinalTier = 2 then
					theSlot.setPropertyValue("is53",true);
					theSlot.setPropertyValue("isBackend",true);
				endif;
			// ### FORWARD
			else
				theSlot.setPropertyValue("fortyFront",true);
				theSlot.setPropertyValue("fortyBack",false);
 				if theSlot.ordinalTier = 4 or theSlot.ordinalTier = 1 then
					theSlot.setPropertyValue("is30",true);
					theSlot.setPropertyValue("isBackend",false);
				endif;
				if theSlot.ordinalTier = 3 then
					theSlot.setPropertyValue("is45",true);
					theSlot.setPropertyValue("isBackend",false);
				endif;
				if theSlot.ordinalTier = 2 then
					theSlot.setPropertyValue("is53",true);
					theSlot.setPropertyValue("isBackend",false);
				endif;
			endif;
		endforeach;
		commitTransaction;
	
	endforeach;
	
	assertNoTrxErrorsOrWarnings();

epilog
end;</source>
        <Parameter name="_vessel" type="CM_Vessel"/>
    </JadeMethod>
    <JadeMethod name="addVesselGeneralCargo" id="336e5979-6168-4dae-947f-ca9a23b3bc2a">
        <source>addVesselGeneralCargo( _name : String; _operator : CM_Operator; _numberOfHatches : Integer) : CM_Vessel;
//----------------------------------------------------------------------
// Created by 	cnwsh3
// Date 		29 October 2009
//
// Implemented version: JMT 7.7.3
/* Changes

Date		Name	TFS#		Description
============================================================================
29/07/2011	cnwmh5				Change to use UT_UnitTest.opts
04/03/2019	jlgka1	37102		STWR CAMS STANDARD CODECO Add isBarge Flag.
============================================================================*/
vars
	pxyVessel,
	vessel					: CM_Vessel;
	pxyGCVesselStructure 	: CM_GeneralCargoVesselStructure;
	conflictManager			: CMIF_HMS_ConflictsManager;
	pxyHMSVesselData		: HMS_VesselData;				// cnwrl1 21/05/2010 PAR 24012
	tidalClassArrival		: HMS_TidalClass;				// cnwrl1 21/05/2010 PAR 24012
	tidalClassDept			: HMS_TidalClass;				// cnwrl1 21/05/2010 PAR 24012
	hms_VesselDataHarbour	: HMS_VesselDataHarbour;		// cnwrl1 21/05/2010 PAR 24012
	
begin

	create pxyVessel transient;
	
	pxyVessel.setProxyForVessel(null,
								_name,
								_name,
								"",
								"",
								"",	
								"",
								"",
								1,
								0,
								0,
								VESSEL_TYPE_LOLO,
								2000,
								null,
								null,
								null,
								null,
								null,
								null,
								null,
								true,
								false,
								_operator,
								null,
								false);
								
	
	// cnwrl1 21/05/2010 PAR 24012 - start of coding
	create pxyHMSVesselData transient;
	pxyVessel.setHMSVesselData(pxyHMSVesselData);
	
	create hms_VesselDataHarbour transient;	// NOTE: the delete is handled by the delete on the pxyVessel
	
	tidalClassArrival	:= app.myRoot.allTidalClasses[ 'E' ];
	tidalClassDept		:= app.myRoot.allTidalClasses[ 'C' ];
	
	hms_VesselDataHarbour.setProxy(	null,
									false,
									false,
									null,
									null,
									null,
									null,
									null,
									null,
									null,
									self.getTerminal().myHarbour,
									null,
									null,
									null,
									null,
									tidalClassArrival,
									tidalClassDept );
	pxyHMSVesselData.allVesselDataForHarbour.add( hms_VesselDataHarbour );
	
	pxyHMSVesselData.setProxy(	app.myRoot,
								false,
								false,
								false,
								false,
								false,
								false,
								false,
								false,
								"",
								"",
								"",
								0,
								0,
								0,
								100,
								20000,
								20000,
								19000,
								0,
								0,
								0,
								0,
								0,
								null,
								app.myRoot.allVesselTypes["G"] );
	// cnwrl1 21/05/2010 PAR 24012 - end of coding
	
	create pxyGCVesselStructure transient;
	pxyGCVesselStructure.setProxyGCVessel(self.getRoot(), _numberOfHatches);
	
	pxyVessel.setProxyVesselStructures(pxyGCVesselStructure, null, null);
	app.myTrxCA.trxCreateVessel(pxyVessel, vessel, conflictManager, app.myPassport);
	
	assertNoTrxErrorsOrWarnings();
	
	return vessel;
	
epilog
	delete pxyVessel;
	
end;
</source>
        <Parameter name="_name" type="String"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_numberOfHatches" type="Integer"/>
        <ReturnType type="CM_Vessel"/>
    </JadeMethod>
    <JadeMethod name="addVesselHolds" id="b6cf51fb-b4d3-4578-aff9-1dd1948aede8">
        <source>addVesselHolds(_vesselName : String);
/*
Purpose:			
Date		Who		Reason
05/02/2014	cnwab1	Initial creation
27/08/2015	cnwdap1	PAR #36766 CCMS SFW 1334 Bulk Graphical Representation - new parameters
*/

vars	

	vessel : CM_Vessel;
	vesselName : String;
	gcHoldLocnDefn : CM_GCHoldLocationDefn;
	gcVesselStructure : CM_GeneralCargoVesselStructure;
	i, j, holds, decks: Integer;
	loadState : Boolean;
begin
	vesselName:=_vesselName ;	
	vessel	:= self.getVessel( vesselName );

	assertNotNull(vessel);
	
	gcVesselStructure := vessel.myGeneralCargoVesselStructure;
	if gcVesselStructure = null then
		self.addGCStructureDefn(vessel);
		gcVesselStructure := vessel.myGeneralCargoVesselStructure;
	endif;
	
	holds := 4;
	decks := 3;
	
	foreach i in 1 to holds do
		foreach j in 1 to decks do
			self.addGCHoldDefn(gcVesselStructure,	
						i,	//_holdNum: Integer;
						j,	//_placeNum: Integer;
						false,	//_isOnDck : Boolean;			// PAR #36766
						null, 	// _maxWeight : Integer;		// PAR #36766
						null,	// _maxVolume: Decimal;			// TFS 1601
						0,	// _maxHeight: Decimal;	//07 Feb 2017	NDL	TFS 3216
						1,		// _onShipCrane: Integer;		// TFS 1601
						"Hold" &amp; i.String &amp; " Deck" &amp; j.String
						);
		endforeach;
	endforeach;
	


epilog

end;</source>
        <Parameter name="_vesselName" type="String"/>
    </JadeMethod>
    <JadeMethod name="addVesselLOLOholdsRORO" id="b2483368-d0ea-4d0b-8ac5-98ee04b12e62">
        <source>addVesselLOLOholdsRORO( _name : String; _operator : CM_Operator) : CM_Vessel;
/* Changes

Date		Name	TFS#		Description
============================================================================
26/03/2010 	cnwrs1	
29/07/2011	cnwmh5				Change to use UT_UnitTest.opts
17/08/2011 	CNWAB1 				add in decks
04/03/2019	jlgka1	37102		STWR CAMS STANDARD CODECO Add isBarge Flag.
============================================================================*/
vars
	vessel					: CM_Vessel;
	pxyVessel				: CM_Vessel;
	pxyCellVessel			: CM_CellularVesselStructure;
	pxyHMSVesselData		: HMS_VesselData;
	pxyCellularVessel		: CM_CellularVesselStructure;
	pxyCellDefn				: CM_CellDefn;
	pxyTierDefn				: CM_TierDefn;
	bay						: CM_BayDefn;
	conflictManager			: CMIF_HMS_ConflictsManager;
	tidalClassArrival		: HMS_TidalClass;				// cnwrl1 20/05/2010 PAR 24012
	tidalClassDept			: HMS_TidalClass;				// cnwrl1 20/05/2010 PAR 24012
	hms_VesselDataHarbour	: HMS_VesselDataHarbour;		// cnwrl1 20/05/2010 PAR 24012
	pxyROROVessel 			: CM_ROROVesselStructure;
	pxyStructElements		: CM_VesselStructuralElements;
	bays, b, b1, b2 : Integer;
	baysString: String;
	big: Boolean;
begin
	create pxyVessel transient;
	big := self.opts.bool("Big");
	
	pxyVessel.setProxyForVessel(null,
								_name,
								_name,
								self.opts.str( ETRow_CallSign ),
								"",
								"",	
								"",
								self.opts.str( ETRow_LloydsNumber ),
								1,
								0,
								0,
								VESSEL_TYPE_LOLO,
								2000,
								null,
								null,
								null,
								null,
								null,
								null,
								null,
								true,
								false,
								_operator,
								null,
								false);
	
	create pxyCellVessel transient;
	pxyCellVessel.setType(CellularStructureRORO);
	pxyCellVessel.setPropertyValue("isImported",true); // AKB do not set default cell weights and heights
	pxyVessel.setProxyVesselStructures(null, pxyCellVessel, null);

	create pxyROROVessel transient;
	pxyVessel.setMyROROVesselStructure(pxyROROVessel);
	
	create pxyStructElements transient;
	pxyVessel.setMyStructuralElements(pxyStructElements);
	
	create pxyHMSVesselData transient;
	pxyVessel.setHMSVesselData(pxyHMSVesselData);
	pxyHMSVesselData.setProxy(app.myRoot,
							false,
							false,
							false,
							false,
							false,
							false,
							false,
							false,
							"",
							"",
							"",
							0,
							0,
							0,
							100,
							20000,
							20000,
							19000,
							0,
							0,
							0,
							0,
							0,
							null,
							app.myRoot.allVesselTypes["CONRO"]);
	
	// cnwrl1 20/05/2010 PAR 24012 - start of coding
	create hms_VesselDataHarbour transient;	// NOTE: the delete is handled by the delete on the pxyVessel
	
	tidalClassArrival	:= app.myRoot.allTidalClasses[ 'B' ];
	tidalClassDept		:= app.myRoot.allTidalClasses[ 'E' ];
	
	hms_VesselDataHarbour.setProxy(	null,
									false,
									false,
									null,
									null,
									null,
									null,
									null,
									null,
									null,
									self.getTerminal().myHarbour,
									null,
									null,
									null,
									null,
									tidalClassArrival,
									tidalClassDept );
	pxyHMSVesselData.allVesselDataForHarbour.add( hms_VesselDataHarbour );
	// cnwrl1 20/05/2010 PAR 24012 - end of coding
	
	app.myTrxCA.trxCreateVessel(pxyVessel, vessel, conflictManager, app.myPassport);
	assertNoTrxErrorsOrWarnings();
	delete pxyVessel;

	// Create Decks
	self.addVesselDecks(_name);
	// Create the Bays
	self.addVesselBays(_name);
	// Create Holds
	self.addVesselHolds(_name);
	

	assertNoTrxErrorsOrWarnings();
	
	return vessel;
	
epilog
	delete pxyVessel;
	delete pxyCellularVessel;
	
end;
</source>
        <Parameter name="_name" type="String"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <ReturnType type="CM_Vessel"/>
    </JadeMethod>
    <JadeMethod name="addVesselRamp" id="dccaebba-61d7-4f17-92d3-c3314081aab6">
        <source>addVesselRamp(_vesselStructure :  CM_VesselStructuralElements; _code : String) : CM_RORORampExternalVessel;
// ---------------------------------------------------------------------------
// Created:     27 January 2014 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	
	pxyRamp, realRamp : CM_RORORampExternalVessel;
	realDeckItem : CM_DeckItem;
	
	description,
	remarks  :String;
	isMovable : Boolean;
	length,
	maxClearHeight,
	maxLoadAxel ,
	maxLoadM2,
	maxLoadTotal ,
	width : Decimal[12,2];

begin
	create pxyRamp transient;
	description :="External Ramp description";
	remarks:="Some External Ramp remarks blah blah blah";
	pxyRamp.setProxyDeckItem(_code,description,remarks,null,null);
	
	isMovable :=false;
	length :=23123;
	maxClearHeight:=2341;
	maxLoadAxel:=456.34;
	maxLoadM2:=234.11;
	maxLoadTotal:=2134.66;
	width:=1234.12;
	
	pxyRamp.setProxyRamp(isMovable,length,maxClearHeight,maxLoadAxel,maxLoadM2,maxLoadTotal,width);
	
	pxyRamp.setMyRampPosition(null);
	pxyRamp.setMyROROStructure(_vesselStructure);
	
	app.myTrxCA.trxCreateRORODeckItem(pxyRamp,realDeckItem,app.myPassport);
	
	self.assertNoTrxErrorsOrWarnings();
	self.assertNotNullMsg(realDeckItem,"realRamp is null");
	self.assertTrueMsg(realDeckItem.isKindOf(CM_RORORampExternalVessel), "realRamp is kindOf CM_RORORampExternalVessel");
	realRamp:=realDeckItem.CM_RORORampExternalVessel;
	
	return realRamp;
epilog
	delete pxyRamp;
end;</source>
        <Parameter name="_vesselStructure" type="CM_VesselStructuralElements"/>
        <Parameter name="_code" type="String"/>
        <ReturnType type="CM_RORORampExternalVessel"/>
    </JadeMethod>
    <JadeMethod name="addVesselSection" id="603bde57-2a64-4c5f-bcb7-1f25eb45e9b6">
        <source>addVesselSection(_vesselStructure :  CM_VesselStructuralElements; _code : String; _pos : Real) : CM_VesselSection;
// ---------------------------------------------------------------------------
// Created:     27 January 2014 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	
	pxySection, realSection : CM_VesselSection;
	
	description,
	remarks  :String;

begin
	create pxySection as CM_VesselSectionVessel transient ;
	

	description :="Section description";
	remarks:="Some Section remarks blah blah blah";
	
	pxySection.setProxy(_code,_pos,remarks);

	pxySection.CM_VesselSectionVessel.setMyVesselStructElements(_vesselStructure);
	
	app.myTrxCA.trxCreateVesselSection(pxySection,realSection,app.myPassport);
	
	self.assertNoTrxErrorsOrWarnings();
	self.assertNotNullMsg(realSection,"realSection is null");
	self.assertTrueMsg(realSection.isKindOf(CM_VesselSectionVessel), "realSection is kindOf CM_VesselSectionVessel");
	

	

	
	return realSection;
epilog
	delete pxySection;
end;</source>
        <Parameter name="_vesselStructure" type="CM_VesselStructuralElements"/>
        <Parameter name="_code" type="String"/>
        <Parameter name="_pos" type="Real"/>
        <ReturnType type="CM_VesselSection"/>
    </JadeMethod>
    <JadeMethod name="addVesselTank" id="26a9a0b0-c863-44ea-af2a-eb6961e7e76c">
        <source>addVesselTank(_vesselStructure :  CM_VesselStructuralElements; _code : String; _type : CM_VesselTankContentsType) : CM_VesselTank;
// ---------------------------------------------------------------------------
// Created:     27 January 2014 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	
	pxyTank, realTank : CM_VesselTank;
	
	description,
	remarks  :String;

begin
	create pxyTank as CM_VesselTankVessel transient ;
	

	description :="Tank description";
	remarks:="Some Tank remarks blah blah blah";
	
	pxyTank.setProxy(_code,description,remarks,0,_type);

	pxyTank.CM_VesselTankVessel.setMyVesselStructElements(_vesselStructure);
	
	app.myTrxCA.trxCreateVesselTank(pxyTank,realTank,app.myPassport);
	
	self.assertNoTrxErrorsOrWarnings();
	self.assertNotNullMsg(realTank,"realTank is null");
	self.assertTrueMsg(realTank.isKindOf(CM_VesselTankVessel), "realTank is kindOf CM_VesselTankVessel");
	

	

	
	return realTank;
epilog
	delete pxyTank;
end;</source>
        <Parameter name="_vesselStructure" type="CM_VesselStructuralElements"/>
        <Parameter name="_code" type="String"/>
        <Parameter name="_type" type="CM_VesselTankContentsType"/>
        <ReturnType type="CM_VesselTank"/>
    </JadeMethod>
    <JadeMethod name="addVesselTankContentType" id="8095c2db-40ec-4b0c-8989-c2eeaae8e03d">
        <source>addVesselTankContentType(_code : String) : CM_VesselTankContentsType;
/*
Date		    Who			Reason
15 April 2011	cnwas3	  Initial creation: CCMS 1031
*/

vars
	proxyVesselTankContentType,newVesselTankContentType : CM_VesselTankContentsType;
begin
	create proxyVesselTankContentType transient;
	
	proxyVesselTankContentType.setProxyForTankContentsType(_code,null,null,false,app.myRoot);
	
	app.myTrxCA.trxCreateVesselTankContentType(proxyVesselTankContentType,newVesselTankContentType,app.myPassport);
	
	assertNoTrxErrorsOrWarnings();
	
	return newVesselTankContentType;
epilog
	delete proxyVesselTankContentType;
end;</source>
        <Parameter name="_code" type="String"/>
        <ReturnType type="CM_VesselTankContentsType"/>
    </JadeMethod>
    <JadeMethod name="addVesselWithHolds" id="16afdcf7-276f-4c27-a320-feeae6c4cf96">
        <source>addVesselWithHolds(name: String; holds: Integer; decks: Integer): CM_Vessel;
// Changed On	By			Reason
// ----------	--------	-------------------------------------------------
// 27/08/2015	cnwdap1		PAR #36766 CCMS SFW 1334 Bulk Graphical Representation - new parameters
vars
	vessel: CM_Vessel;
	gcHoldLocnDefn : CM_GCHoldLocationDefn;
	i, j: Integer;
	loadState : Boolean;
begin
	self.deleteVessel(name);
	
	//Create a general cargo vessel
	vessel := self.addVesselGeneralCargo(name, self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString), 0);
	self.assertNotNullMsg(vessel, "Add vessel failed");
	
	foreach i in 1 to holds do
		foreach j in 1 to decks do
			self.addGCHoldDefn(vessel.myGeneralCargoVesselStructure,	//_gcVesselStruct: CM_GeneralCargoVesselStructure;
						i,	//_holdNum: Integer;
						j,	//_placeNum: Integer;
						false,	//_isOnDeck : Boolean;			// PAR #36766
						null, 	// _maxWeight : Integer;		// PAR #36766
						null,	// _maxVolume: Decimal;			// TFS 1601
						0,	// _maxHeight: Decimal;	//07 Feb 2017	NDL	TFS 3216
						1,		// _onShipCrane: Integer;		// TFS 1601
						"Hold" &amp; i.String &amp; " Deck" &amp; j.String
						);
		endforeach;
	endforeach;
	
	return vessel;
	
epilog
end;</source>
        <Parameter name="name" type="String"/>
        <Parameter name="holds" type="Integer"/>
        <Parameter name="decks" type="Integer"/>
        <ReturnType type="CM_Vessel"/>
    </JadeMethod>
    <JadeMethod name="addVoyageAllocation" id="1efe57fe-5624-4673-81fc-d0ce67c0af4b">
        <updating/>
        <source>addVoyageAllocation(_voyage : CM_Voyage input): CM_VoyageAllocation updating;
/*
Purpose:			
Date				Who			Reason
AUGUST 2011		CNWAB1		Initial creation
05/04/2013		cnwmh5		Change to pass commodity rather than commodity group, because if the commodity changes group and
							you can potentionaly pass the wrong commodity group so now use the commodity group for the commodity
							Change is being made becuase it has happened an is hard to track down especially if test is UT_KPIVoyage::tMain
14/11/2017		jlgmh5		Rewritten specifically for the data loading
								
NOTES:						To get the Commodity Group - Pass a Commodity from the group you want and in opts use either
							CommodityGroupOnly or SetCommodityGroup to specify that you want the Commodity Group
*/


vars
	proxyYAObj				: CM_VoyageAllocation;
	cmif_object : CMIF_Object;
	cmif_criteria : CMIF_YACriteriaPriority;
	pxyCriteria : CM_YACriteria;
	allTransientCriteriaObj	: CMIF_Array;
	realAlloc 				: CM_VoyageAllocation;
	voyCode, desc : String;
	objSet : ObjectSet;
	imexStatus : CM_IMEXStatus;
	port : CM_Port;
	isoGrp : CM_ISOTypeGroup;
	ct : CM_CargoType;
	comGrp : CM_CommodityGroup;
	portColor 	: Integer;
	anOperator : CM_Operator;
	isoTypeString,
	commodityString : String;
	isoType			: CM_ISOType;
	aCommodity 		: CM_Commodity;
	imexId : Integer; // PAR 37111
	portCode			: String;
	isoGroup			: String;
	commodity			: String;
	cargoType			: Integer;
	reqPwr				: Boolean;
	isOD				: Boolean;
	terminal			: CM_Terminal;
begin

	terminal := app.myPassport.myTerminal;
	app.myPassport.setMyTerminal(self.getTerminal());

	if _voyage = null then
		return null;
	else
		voyCode := _voyage.code;
	endif;
	
	create proxyYAObj transient;
	create objSet transient;
	proxyYAObj.setProxyProjectedValues(0,0,0,0,0,0);
	create allTransientCriteriaObj transient;
	
	
	imexId := TI_IMEX_STATUS_EXPORT; // PAR 37111
	if self.opts.includesKey(UTTI_IMEX) then // PAR 37111
		imexId := self.opts.int(UTTI_IMEX); // PAR 37111
	endif;
	

	// ### IMEX
	objSet.clear();
	imexStatus := app.myRoot.allImexStatuses[imexId]; // PAR 37111
	objSet.add( imexStatus );
	self.getCriteriaSingleCMIF( allTransientCriteriaObj, app.myRoot.allYACriteriaTypes[YACriteriaType_ImexStatus], objSet );
	
	// port code
	portCode := self.opts.str("Discharge Port");	
	portColor:=Red;
	// ### DISPORT
	if portCode &lt;&gt; null then
		objSet.clear();
		port := app.myRoot.allPorts[portCode];
		if port &lt;&gt; null then
			if port.colour &lt;&gt; null then
				portColor:=port.colour;
			endif;
			objSet.add( port );
			self.getCriteriaSingleCMIF( allTransientCriteriaObj, app.myRoot.allYACriteriaTypes[YACriteriaType_DischargePort], objSet );
		else
			self.assertTrueMsg(port &lt;&gt; null, "Port Code '" &amp; portCode &amp; "' does not exist! Cannot create voyage allocation");
		endif;
	endif;
	// ### ISOGroup
	isoGroup := self.opts.str("ISO Group");
	if isoGroup &lt;&gt; null then
		objSet.clear();
		isoGrp := app.myRoot.allISOTypeGroups[isoGroup];
		self.assertTrueMsg(isoGrp &lt;&gt; null, "ISOGroup Code '" &amp; isoGroup &amp; "' does not exist! Cannot create voyage allocation");
		objSet.add( isoGrp );
		self.getCriteriaSingleCMIF( allTransientCriteriaObj, app.myRoot.allYACriteriaTypes[YACriteriaType_ISOGroup], objSet );
	endif;
	// ### CargoType
	cargoType := self.opts.int("Cargo Type");
	objSet.clear();
	ct := app.myRoot.allCargoTypesById[cargoType];
	self.assertTrueMsg(ct &lt;&gt; null, "Cargotype Code '" &amp; cargoType.String &amp; "' does not exist! Cannot create voyage allocation");
	objSet.add( ct );
	self.getCriteriaSingleCMIF( allTransientCriteriaObj, app.myRoot.allYACriteriaTypes[YACriteriaType_CargoType], objSet );

	/*
	05/04/2013 cnwmh5 - See Commodity
	// ### CommodityGroup
	if _comGrpCode &lt;&gt; null then
		objSet.clear();
		comGrp := app.myRoot.allCommodityGroups[_comGrpCode];
		self.assertTrueMsg(comGrp &lt;&gt; null, "Commodity Group Code '" &amp; _comGrpCode.String &amp; "' does not exist! Cannot create voyage allocation");
		objSet.add(comGrp );
		self.getCriteriaSingleCMIF( allTransientCriteriaObj, app.myRoot.allYACriteriaTypes[YACriteriaType_CommodityGroup], objSet );
	endif;
	*/

	// ### RequiresPower
	reqPwr := self.opts.str("Requires Power").Boolean;
	if reqPwr then
		self.getCriteriaSingleCMIF(allTransientCriteriaObj, app.myRoot.allYACriteriaTypes[YACriteriaType_RequiresPower], CM_YADataBoolean.VALUE_TRUE );
	else
		self.getCriteriaSingleCMIF(allTransientCriteriaObj, app.myRoot.allYACriteriaTypes[YACriteriaType_RequiresPower], CM_YADataBoolean.VALUE_FALSE );
	endif;
	// ### IS Over Dimensional
	isOD := self.opts.str("Is Over Dimension").Boolean;
	if isOD then
		self.getCriteriaSingleCMIF(allTransientCriteriaObj, app.myRoot.allYACriteriaTypes[YACriteriaType_IsOverDimension], CM_YADataBoolean.VALUE_TRUE );
	else
		self.getCriteriaSingleCMIF(allTransientCriteriaObj, app.myRoot.allYACriteriaTypes[YACriteriaType_IsOverDimension], CM_YADataBoolean.VALUE_FALSE );
	endif;
	
	// ### operator
	if self.opts.includesKey("Operator (Item)") then 
		objSet.clear();		
		anOperator := app.myRoot.allOperators[self.opts.str("Operator (Item)")].CM_Operator;
		self.assertTrueMsg(anOperator &lt;&gt; null, "Operator does not exist! Cannot create voyage allocation");
		objSet.add(anOperator );
		self.getCriteriaSingleCMIF( allTransientCriteriaObj, app.myRoot.allYACriteriaTypes[YACriteriaType_OperatorItem], objSet );
	endif;
	
	// ### ISO Type
	if self.opts.includesKey("ISO Type") then	
		isoTypeString := self.opts.str('ISO Type').String;
		objSet.clear();
		isoType := app.myRoot.allISOTypes[isoTypeString];
		self.assertTrueMsg(isoType &lt;&gt; null, "ISOType Code '" &amp; isoTypeString &amp; "' does not exist! Cannot create voyage allocation");
		objSet.add( isoType );
		self.getCriteriaSingleCMIF( allTransientCriteriaObj, app.myRoot.allYACriteriaTypes[YACriteriaType_ISO], objSet );
	endif;
	
	
	// ### Commodity
	// 05/04/2013 cnwmh5 - Rewritten so that uses Commodity to get Commodity Group
	commodity := self.opts.str("Commodity");
	if commodity &lt;&gt; null then	
		objSet.clear();
		aCommodity := app.myRoot.allCommodities[commodity];
		self.assertTrueMsg(aCommodity &lt;&gt; null, "Commodity Code '" &amp; commodity &amp; "' does not exist! Cannot create voyage allocation");
		if not self.opts.includesKey("CommodityGroupOnly") then
			objSet.add( aCommodity );
			self.getCriteriaSingleCMIF( allTransientCriteriaObj, app.myRoot.allYACriteriaTypes[YACriteriaType_Commodity], objSet );
		endif;
		if self.opts.includesKey("CommodityGroupOnly") or self.opts.includesKey("SetCommodityGroup") then
			comGrp := aCommodity.myCommodityGroup;
			self.assertTrueMsg(comGrp &lt;&gt; null, "Commodity " &amp; commodity &amp; " does not have a Commodity Group!  Cannot create voyage allocation");
			objSet.add(comGrp );
			self.getCriteriaSingleCMIF( allTransientCriteriaObj, app.myRoot.allYACriteriaTypes[YACriteriaType_CommodityGroup], objSet );
		endif;
	endif;
	
	// ## isFiftyThree											// 18/07/2013 cnwmh5 
	if self.opts.includesKey("Is Fifty Three") then
		isoTypeString := self.opts.str('Is Fifty Three');
		objSet.clear();
		self.getCriteriaSingleCMIF( allTransientCriteriaObj, app.myRoot.allYACriteriaTypes[YACriteriaType_IsFiftyThree], true );
	endif;
	
	// ## isFortyFive											// 18/07/2013 cnwmh5 
	if self.opts.includesKey("Is Forty Five") then
		isoTypeString := self.opts.str('Is Forty Five');
		objSet.clear();
		self.getCriteriaSingleCMIF( allTransientCriteriaObj, app.myRoot.allYACriteriaTypes[YACriteriaType_IsFortyFive], true );
	endif;
	
	// ## isForty												// 18/07/2013 cnwmh5 
	if self.opts.includesKey("Is Forty") then
		isoTypeString := self.opts.str('Is Forty');
		objSet.clear();
		self.getCriteriaSingleCMIF( allTransientCriteriaObj, app.myRoot.allYACriteriaTypes[YACriteriaType_IsForty], true );
	endif;
	
	// ## isThirty												// 18/07/2013 cnwmh5 
	if self.opts.includesKey("Is Thirty") then
		isoTypeString := self.opts.str('Is Thirty');
		objSet.clear();
		self.getCriteriaSingleCMIF( allTransientCriteriaObj, app.myRoot.allYACriteriaTypes[YACriteriaType_IsThirty], true );
	endif;
	
	// ## Colour												// 18/07/2013 cnwmh5 
	if self.opts.includesKey("Colour") then
		portColor := self.opts.int("Colour");
	endif;
	
	
	/*
	// 05/04/2013 cnwmh5 - Replaced by above code
	if self.opts.includesKey("Commodity") then	
		commodityString := self.opts.str('Commodity');
		objSet.clear();
		aCommodity := app.myRoot.allCommodities[commodityString];
		self.assertTrueMsg(aCommodity &lt;&gt; null, "Commodity Code '" &amp; commodityString &amp; "' does not exist! Cannot create voyage allocation");
		objSet.add( aCommodity );
		self.getCriteriaSingleCMIF( allTransientCriteriaObj, app.myRoot.allYACriteriaTypes[YACriteriaType_Commodity], objSet );
	endif;
	*/
	
	foreach cmif_object in allTransientCriteriaObj do
		cmif_criteria := cmif_object.CMIF_YACriteriaPriority;
		pxyCriteria := cmif_criteria.myProxy.CM_YACriteria;
		pxyCriteria.setYardAllocation(proxyYAObj);
	endforeach;

	desc := proxyYAObj.getDefaultDescription();
	proxyYAObj.setProxy(desc,desc,
								null,
								YAFillOption_InOrder,
								YAFillOption_InOrder,
								YAExpiryType_Never,
								null,
								portColor, 			
								null,  //cnwjo3 par 24145
								YAOverlap_Never,//allow others
								YANoLocation_Continue,
								null,
								0, //priority adjustment
								false,
								false,
								null,
								null,
								true,
								_voyage.myTerminal);

	app.myTrxUA.trxUpdateVoyageAlloc(false,_voyage, proxyYAObj,realAlloc,app.myPassport);
	self.assertNotNull( realAlloc );

	return realAlloc;

epilog	
	app.myPassport.setMyTerminal(terminal);
	allTransientCriteriaObj.purge();
	delete allTransientCriteriaObj;
	delete proxyYAObj;
	delete objSet;
end;</source>
        <Parameter name="_voyage" type="CM_Voyage" usage="input"/>
        <ReturnType type="CM_VoyageAllocation"/>
    </JadeMethod>
    <JadeMethod name="addVoyageAllocation2" id="48f45b8e-6c2f-4745-8702-b84a7a0c3b3e">
        <updating/>
        <source>addVoyageAllocation2(_voyage : CM_Voyage input; _portCode, _isoGrpCode, _comCode : String; _cargoType : Integer; _reqPwr, _isOD : Boolean): CM_VoyageAllocation updating;
/*
Purpose:			
Date				Who			Reason
AUGUST 2011		CNWAB1		Initial creation
05/04/2013			cnwmh5		Change to pass commodity rather than commodity group, because if the commodity changes group and
								you can potentionaly pass the wrong commodity group so now use the commodity group for the commodity
								Change is being made becuase it has happened an is hard to track down especially if test is UT_KPIVoyage::tMain
								
NOTES:							To get the Commodity Group - Pass a Commodity from the group you want and in opts use either
								CommodityGroupOnly or SetCommodityGroup to specify that you want the Commodity Group
*/


vars
	proxyYAObj				: CM_VoyageAllocation;
	cmif_object : CMIF_Object;
	cmif_criteria : CMIF_YACriteriaPriority;
	pxyCriteria : CM_YACriteria;
	allTransientCriteriaObj	: CMIF_Array;
	realAlloc 				: CM_VoyageAllocation;
	voyCode, desc : String;
	objSet : ObjectSet;
	imexStatus : CM_IMEXStatus;
	port : CM_Port;
	isoGrp : CM_ISOTypeGroup;
	ct : CM_CargoType;
	comGrp : CM_CommodityGroup;
	portColor 	: Integer;
	anOperator : CM_Operator;
	isoTypeString,
	commodityString : String;
	isoType			: CM_ISOType;
	aCommodity 		: CM_Commodity;
	imexId : Integer; // PAR 37111
begin
	if _voyage = null then
		return null;
	else
		voyCode := _voyage.code;
	endif;
	
	create proxyYAObj transient;
	create objSet transient;
	proxyYAObj.setProxyProjectedValues(0,0,0,0,0,0);
	create allTransientCriteriaObj transient;
	
	
	imexId := TI_IMEX_STATUS_EXPORT; // PAR 37111
	if self.opts.includesKey(UTTI_IMEX) then // PAR 37111
		imexId := self.opts.int(UTTI_IMEX); // PAR 37111
	endif;
	

	// ### IMEX
	objSet.clear();
	imexStatus := app.myRoot.allImexStatuses[imexId]; // PAR 37111
	objSet.add( imexStatus );
	self.getCriteriaSingleCMIF( allTransientCriteriaObj, app.myRoot.allYACriteriaTypes[YACriteriaType_ImexStatus], objSet );
	
	portColor:=Red;
	// ### DISPORT
	if _portCode &lt;&gt; null then
		objSet.clear();
		port := app.myRoot.allPorts[_portCode];
		if port &lt;&gt; null then
			if port.colour &lt;&gt; null then
				portColor:=port.colour;
			endif;
			objSet.add( port );
			self.getCriteriaSingleCMIF( allTransientCriteriaObj, app.myRoot.allYACriteriaTypes[YACriteriaType_DischargePort], objSet );
		else
			self.assertTrueMsg(port &lt;&gt; null, "Port Code '" &amp; _portCode &amp; "' does not exist! Cannot create voyage allocation");
		endif;
	endif;
	// ### ISOGroup
	if _isoGrpCode &lt;&gt; null then
		objSet.clear();
		isoGrp := app.myRoot.allISOTypeGroups[_isoGrpCode];
		self.assertTrueMsg(isoGrp &lt;&gt; null, "ISOGroup Code '" &amp; _isoGrpCode &amp; "' does not exist! Cannot create voyage allocation");
		objSet.add( isoGrp );
		self.getCriteriaSingleCMIF( allTransientCriteriaObj, app.myRoot.allYACriteriaTypes[YACriteriaType_ISOGroup], objSet );
	endif;
	// ### CargoType
	objSet.clear();
	ct := app.myRoot.allCargoTypesById[_cargoType];
	self.assertTrueMsg(ct &lt;&gt; null, "Cargotype Code '" &amp; _cargoType.String &amp; "' does not exist! Cannot create voyage allocation");
	objSet.add( ct );
	self.getCriteriaSingleCMIF( allTransientCriteriaObj, app.myRoot.allYACriteriaTypes[YACriteriaType_CargoType], objSet );

	/*
	05/04/2013 cnwmh5 - See Commodity
	// ### CommodityGroup
	if _comGrpCode &lt;&gt; null then
		objSet.clear();
		comGrp := app.myRoot.allCommodityGroups[_comGrpCode];
		self.assertTrueMsg(comGrp &lt;&gt; null, "Commodity Group Code '" &amp; _comGrpCode.String &amp; "' does not exist! Cannot create voyage allocation");
		objSet.add(comGrp );
		self.getCriteriaSingleCMIF( allTransientCriteriaObj, app.myRoot.allYACriteriaTypes[YACriteriaType_CommodityGroup], objSet );
	endif;
	*/

	// ### RequiresPower
	if _reqPwr then
		self.getCriteriaSingleCMIF(allTransientCriteriaObj, app.myRoot.allYACriteriaTypes[YACriteriaType_RequiresPower], CM_YADataBoolean.VALUE_TRUE );
	else
		self.getCriteriaSingleCMIF(allTransientCriteriaObj, app.myRoot.allYACriteriaTypes[YACriteriaType_RequiresPower], CM_YADataBoolean.VALUE_FALSE );
	endif;
	// ### IS Over Dimensional
	if _isOD then
		self.getCriteriaSingleCMIF(allTransientCriteriaObj, app.myRoot.allYACriteriaTypes[YACriteriaType_IsOverDimension], CM_YADataBoolean.VALUE_TRUE );
	else
		self.getCriteriaSingleCMIF(allTransientCriteriaObj, app.myRoot.allYACriteriaTypes[YACriteriaType_IsOverDimension], CM_YADataBoolean.VALUE_FALSE );
	endif;
	
	// ### operator
	if self.opts.includesKey("Operator") then 
		objSet.clear();		
		anOperator := self.opts.obj("Operator").CM_Operator;
		self.assertTrueMsg(anOperator &lt;&gt; null, "Operator does not exist! Cannot create voyage allocation");
		objSet.add(anOperator );
		self.getCriteriaSingleCMIF( allTransientCriteriaObj, app.myRoot.allYACriteriaTypes[YACriteriaType_OperatorItem], objSet );
	endif;
	
	// ### ISO Type
	if self.opts.includesKey("ISOType") then	
		isoTypeString := self.opts.str('ISOType');
		objSet.clear();
		isoType := app.myRoot.allISOTypes[isoTypeString];
		self.assertTrueMsg(isoType &lt;&gt; null, "ISOType Code '" &amp; isoTypeString &amp; "' does not exist! Cannot create voyage allocation");
		objSet.add( isoType );
		self.getCriteriaSingleCMIF( allTransientCriteriaObj, app.myRoot.allYACriteriaTypes[YACriteriaType_ISO], objSet );
	endif;
	
	
	// ### Commodity
	// 05/04/2013 cnwmh5 - Rewritten so that uses Commodity to get Commodity Group
	if _comCode &lt;&gt; null then	
		objSet.clear();
		aCommodity := app.myRoot.allCommodities[_comCode];
		self.assertTrueMsg(aCommodity &lt;&gt; null, "Commodity Code '" &amp; _comCode &amp; "' does not exist! Cannot create voyage allocation");
		if not self.opts.includesKey("CommodityGroupOnly") then
			objSet.add( aCommodity );
			self.getCriteriaSingleCMIF( allTransientCriteriaObj, app.myRoot.allYACriteriaTypes[YACriteriaType_Commodity], objSet );
		endif;
		if self.opts.includesKey("CommodityGroupOnly") or self.opts.includesKey("SetCommodityGroup") then
			comGrp := aCommodity.myCommodityGroup;
			self.assertTrueMsg(comGrp &lt;&gt; null, "Commodity " &amp; _comCode &amp; " does not have a Commodity Group!  Cannot create voyage allocation");
			objSet.add(comGrp );
			self.getCriteriaSingleCMIF( allTransientCriteriaObj, app.myRoot.allYACriteriaTypes[YACriteriaType_CommodityGroup], objSet );
		endif;
	endif;
	
	// ## isFiftyThree											// 18/07/2013 cnwmh5 
	if self.opts.includesKey("Is53Ft") then
		isoTypeString := self.opts.str('Is53Ft');
		objSet.clear();
		self.getCriteriaSingleCMIF( allTransientCriteriaObj, app.myRoot.allYACriteriaTypes[YACriteriaType_IsFiftyThree], true );
	endif;
	
	// ## isFortyFive											// 18/07/2013 cnwmh5 
	if self.opts.includesKey("Is45Ft") then
		isoTypeString := self.opts.str('Is45Ft');
		objSet.clear();
		self.getCriteriaSingleCMIF( allTransientCriteriaObj, app.myRoot.allYACriteriaTypes[YACriteriaType_IsFortyFive], true );
	endif;
	
	// ## isForty												// 18/07/2013 cnwmh5 
	if self.opts.includesKey("Is40Ft") then
		isoTypeString := self.opts.str('Is40Ft');
		objSet.clear();
		self.getCriteriaSingleCMIF( allTransientCriteriaObj, app.myRoot.allYACriteriaTypes[YACriteriaType_IsForty], true );
	endif;
	
	// ## isThirty												// 18/07/2013 cnwmh5 
	if self.opts.includesKey("Is30Ft") then
		isoTypeString := self.opts.str('Is30Ft');
		objSet.clear();
		self.getCriteriaSingleCMIF( allTransientCriteriaObj, app.myRoot.allYACriteriaTypes[YACriteriaType_IsThirty], true );
	endif;
	
	// ## Colour												// 18/07/2013 cnwmh5 
	if self.opts.includesKey("Colour") then
		portColor := self.opts.int("Colour");
	endif;
	
	
	/*
	// 05/04/2013 cnwmh5 - Replaced by above code
	if self.opts.includesKey("Commodity") then	
		commodityString := self.opts.str('Commodity');
		objSet.clear();
		aCommodity := app.myRoot.allCommodities[commodityString];
		self.assertTrueMsg(aCommodity &lt;&gt; null, "Commodity Code '" &amp; commodityString &amp; "' does not exist! Cannot create voyage allocation");
		objSet.add( aCommodity );
		self.getCriteriaSingleCMIF( allTransientCriteriaObj, app.myRoot.allYACriteriaTypes[YACriteriaType_Commodity], objSet );
	endif;
	*/
	
	foreach cmif_object in allTransientCriteriaObj do
		cmif_criteria := cmif_object.CMIF_YACriteriaPriority;
		pxyCriteria := cmif_criteria.myProxy.CM_YACriteria;
		pxyCriteria.setYardAllocation(proxyYAObj);
	endforeach;

	desc := proxyYAObj.getDefaultDescription();
	proxyYAObj.setProxy(desc,desc,
								null,
								YAFillOption_InOrder,
								YAFillOption_InOrder,
								YAExpiryType_Never,
								null,
								portColor, 			
								null,  //cnwjo3 par 24145
								YAOverlap_Never,//allow others
								YANoLocation_Continue,
								null,
								0, //priority adjustment
								false,
								false,
								null,
								null,
								true,
								_voyage.myTerminal);

	app.myTrxUA.trxUpdateVoyageAlloc(false,_voyage, proxyYAObj,realAlloc,app.myPassport);
	self.assertNotNull( realAlloc );

	return realAlloc;

epilog	
	allTransientCriteriaObj.purge();
	delete allTransientCriteriaObj;
	delete proxyYAObj;
	delete objSet;
end;</source>
        <Parameter name="_voyage" type="CM_Voyage" usage="input"/>
        <Parameter name="_portCode" type="String"/>
        <Parameter name="_isoGrpCode" type="String"/>
        <Parameter name="_comCode" type="String"/>
        <Parameter name="_cargoType" type="Integer"/>
        <Parameter name="_reqPwr" type="Boolean"/>
        <Parameter name="_isOD" type="Boolean"/>
        <ReturnType type="CM_VoyageAllocation"/>
    </JadeMethod>
    <JadeMethod name="addVoyageAllocation_OLD" id="302fe270-3c4c-4f69-90ae-66bf8be90641">
        <updating/>
        <source>addVoyageAllocation_OLD(_voyage : CM_Voyage input; _portCode, _isoGrpCode, _comCode : String; _cargoType : Integer; _reqPwr, _isOD : Boolean): CM_VoyageAllocation updating;
/*
Purpose:			
Date				Who			Reason
AUGUST 2011		CNWAB1		Initial creation
05/04/2013			cnwmh5		Change to pass commodity rather than commodity group, because if the commodity changes group and
								you can potentionaly pass the wrong commodity group so now use the commodity group for the commodity
								Change is being made becuase it has happened an is hard to track down especially if test is UT_KPIVoyage::tMain
								
NOTES:							To get the Commodity Group - Pass a Commodity from the group you want and in opts use either
								CommodityGroupOnly or SetCommodityGroup to specify that you want the Commodity Group
*/


vars
	proxyYAObj				: CM_VoyageAllocation;
	cmif_object : CMIF_Object;
	cmif_criteria : CMIF_YACriteriaPriority;
	pxyCriteria : CM_YACriteria;
	allTransientCriteriaObj	: CMIF_Array;
	realAlloc 				: CM_VoyageAllocation;
	voyCode, desc : String;
	objSet : ObjectSet;
	imexStatus : CM_IMEXStatus;
	port : CM_Port;
	isoGrp : CM_ISOTypeGroup;
	ct : CM_CargoType;
	comGrp : CM_CommodityGroup;
	portColor 	: Integer;
	anOperator : CM_Operator;
	isoTypeString,
	commodityString : String;
	isoType			: CM_ISOType;
	aCommodity 		: CM_Commodity;
	imexId : Integer; // PAR 37111
begin
	if _voyage = null then
		return null;
	else
		voyCode := _voyage.code;
	endif;
	
	create proxyYAObj transient;
	create objSet transient;
	proxyYAObj.setProxyProjectedValues(0,0,0,0,0,0);
	create allTransientCriteriaObj transient;
	
	
	imexId := TI_IMEX_STATUS_EXPORT; // PAR 37111
	if self.opts.includesKey(UTTI_IMEX) then // PAR 37111
		imexId := self.opts.int(UTTI_IMEX); // PAR 37111
	endif;
	

	// ### IMEX
	objSet.clear();
	imexStatus := app.myRoot.allImexStatuses[imexId]; // PAR 37111
	objSet.add( imexStatus );
	self.getCriteriaSingleCMIF( allTransientCriteriaObj, app.myRoot.allYACriteriaTypes[YACriteriaType_ImexStatus], objSet );
	
	portColor:=Red;
	// ### DISPORT
	if _portCode &lt;&gt; null then
		objSet.clear();
		port := app.myRoot.allPorts[_portCode];
		if port &lt;&gt; null then
			if port.colour &lt;&gt; null then
				portColor:=port.colour;
			endif;
			objSet.add( port );
			self.getCriteriaSingleCMIF( allTransientCriteriaObj, app.myRoot.allYACriteriaTypes[YACriteriaType_DischargePort], objSet );
		else
			self.assertTrueMsg(port &lt;&gt; null, "Port Code '" &amp; _portCode &amp; "' does not exist! Cannot create voyage allocation");
		endif;
	endif;
	// ### ISOGroup
	if _isoGrpCode &lt;&gt; null then
		objSet.clear();
		isoGrp := app.myRoot.allISOTypeGroups[_isoGrpCode];
		self.assertTrueMsg(isoGrp &lt;&gt; null, "ISOGroup Code '" &amp; _isoGrpCode &amp; "' does not exist! Cannot create voyage allocation");
		objSet.add( isoGrp );
		self.getCriteriaSingleCMIF( allTransientCriteriaObj, app.myRoot.allYACriteriaTypes[YACriteriaType_ISOGroup], objSet );
	endif;
	// ### CargoType
	objSet.clear();
	ct := app.myRoot.allCargoTypesById[_cargoType];
	self.assertTrueMsg(ct &lt;&gt; null, "Cargotype Code '" &amp; _cargoType.String &amp; "' does not exist! Cannot create voyage allocation");
	objSet.add( ct );
	self.getCriteriaSingleCMIF( allTransientCriteriaObj, app.myRoot.allYACriteriaTypes[YACriteriaType_CargoType], objSet );

	/*
	05/04/2013 cnwmh5 - See Commodity
	// ### CommodityGroup
	if _comGrpCode &lt;&gt; null then
		objSet.clear();
		comGrp := app.myRoot.allCommodityGroups[_comGrpCode];
		self.assertTrueMsg(comGrp &lt;&gt; null, "Commodity Group Code '" &amp; _comGrpCode.String &amp; "' does not exist! Cannot create voyage allocation");
		objSet.add(comGrp );
		self.getCriteriaSingleCMIF( allTransientCriteriaObj, app.myRoot.allYACriteriaTypes[YACriteriaType_CommodityGroup], objSet );
	endif;
	*/

	// ### RequiresPower
	if _reqPwr then
		self.getCriteriaSingleCMIF(allTransientCriteriaObj, app.myRoot.allYACriteriaTypes[YACriteriaType_RequiresPower], CM_YADataBoolean.VALUE_TRUE );
	else
		self.getCriteriaSingleCMIF(allTransientCriteriaObj, app.myRoot.allYACriteriaTypes[YACriteriaType_RequiresPower], CM_YADataBoolean.VALUE_FALSE );
	endif;
	// ### IS Over Dimensional
	if _isOD then
		self.getCriteriaSingleCMIF(allTransientCriteriaObj, app.myRoot.allYACriteriaTypes[YACriteriaType_IsOverDimension], CM_YADataBoolean.VALUE_TRUE );
	else
		self.getCriteriaSingleCMIF(allTransientCriteriaObj, app.myRoot.allYACriteriaTypes[YACriteriaType_IsOverDimension], CM_YADataBoolean.VALUE_FALSE );
	endif;
	
	// ### operator
	if self.opts.includesKey("Operator") then 
		objSet.clear();		
		anOperator := self.opts.obj("Operator").CM_Operator;
		self.assertTrueMsg(anOperator &lt;&gt; null, "Operator does not exist! Cannot create voyage allocation");
		objSet.add(anOperator );
		self.getCriteriaSingleCMIF( allTransientCriteriaObj, app.myRoot.allYACriteriaTypes[YACriteriaType_OperatorItem], objSet );
	endif;
	
	// ### ISO Type
	if self.opts.includesKey("ISOType") then	
		isoTypeString := self.opts.str('ISOType');
		objSet.clear();
		isoType := app.myRoot.allISOTypes[isoTypeString];
		self.assertTrueMsg(isoType &lt;&gt; null, "ISOType Code '" &amp; isoTypeString &amp; "' does not exist! Cannot create voyage allocation");
		objSet.add( isoType );
		self.getCriteriaSingleCMIF( allTransientCriteriaObj, app.myRoot.allYACriteriaTypes[YACriteriaType_ISO], objSet );
	endif;
	
	
	// ### Commodity
	// 05/04/2013 cnwmh5 - Rewritten so that uses Commodity to get Commodity Group
	if _comCode &lt;&gt; null then	
		objSet.clear();
		aCommodity := app.myRoot.allCommodities[_comCode];
		self.assertTrueMsg(aCommodity &lt;&gt; null, "Commodity Code '" &amp; _comCode &amp; "' does not exist! Cannot create voyage allocation");
		if not self.opts.includesKey("CommodityGroupOnly") then
			objSet.add( aCommodity );
			self.getCriteriaSingleCMIF( allTransientCriteriaObj, app.myRoot.allYACriteriaTypes[YACriteriaType_Commodity], objSet );
		endif;
		if self.opts.includesKey("CommodityGroupOnly") or self.opts.includesKey("SetCommodityGroup") then
			comGrp := aCommodity.myCommodityGroup;
			self.assertTrueMsg(comGrp &lt;&gt; null, "Commodity " &amp; _comCode &amp; " does not have a Commodity Group!  Cannot create voyage allocation");
			objSet.add(comGrp );
			self.getCriteriaSingleCMIF( allTransientCriteriaObj, app.myRoot.allYACriteriaTypes[YACriteriaType_CommodityGroup], objSet );
		endif;
	endif;
	
	// ## isFiftyThree											// 18/07/2013 cnwmh5 
	if self.opts.includesKey("Is53Ft") then
		isoTypeString := self.opts.str('Is53Ft');
		objSet.clear();
		self.getCriteriaSingleCMIF( allTransientCriteriaObj, app.myRoot.allYACriteriaTypes[YACriteriaType_IsFiftyThree], true );
	endif;
	
	// ## isFortyFive											// 18/07/2013 cnwmh5 
	if self.opts.includesKey("Is45Ft") then
		isoTypeString := self.opts.str('Is45Ft');
		objSet.clear();
		self.getCriteriaSingleCMIF( allTransientCriteriaObj, app.myRoot.allYACriteriaTypes[YACriteriaType_IsFortyFive], true );
	endif;
	
	// ## isForty												// 18/07/2013 cnwmh5 
	if self.opts.includesKey("Is40Ft") then
		isoTypeString := self.opts.str('Is40Ft');
		objSet.clear();
		self.getCriteriaSingleCMIF( allTransientCriteriaObj, app.myRoot.allYACriteriaTypes[YACriteriaType_IsForty], true );
	endif;
	
	// ## isThirty												// 18/07/2013 cnwmh5 
	if self.opts.includesKey("Is30Ft") then
		isoTypeString := self.opts.str('Is30Ft');
		objSet.clear();
		self.getCriteriaSingleCMIF( allTransientCriteriaObj, app.myRoot.allYACriteriaTypes[YACriteriaType_IsThirty], true );
	endif;
	
	// ## Colour												// 18/07/2013 cnwmh5 
	if self.opts.includesKey("Colour") then
		portColor := self.opts.int("Colour");
	endif;
	
	
	/*
	// 05/04/2013 cnwmh5 - Replaced by above code
	if self.opts.includesKey("Commodity") then	
		commodityString := self.opts.str('Commodity');
		objSet.clear();
		aCommodity := app.myRoot.allCommodities[commodityString];
		self.assertTrueMsg(aCommodity &lt;&gt; null, "Commodity Code '" &amp; commodityString &amp; "' does not exist! Cannot create voyage allocation");
		objSet.add( aCommodity );
		self.getCriteriaSingleCMIF( allTransientCriteriaObj, app.myRoot.allYACriteriaTypes[YACriteriaType_Commodity], objSet );
	endif;
	*/
	
	foreach cmif_object in allTransientCriteriaObj do
		cmif_criteria := cmif_object.CMIF_YACriteriaPriority;
		pxyCriteria := cmif_criteria.myProxy.CM_YACriteria;
		pxyCriteria.setYardAllocation(proxyYAObj);
	endforeach;

	desc := proxyYAObj.getDefaultDescription();
	proxyYAObj.setProxy(desc,desc,
								null,
								YAFillOption_InOrder,
								YAFillOption_InOrder,
								YAExpiryType_Never,
								null,
								portColor, 			
								null,  //cnwjo3 par 24145
								YAOverlap_Never,//allow others
								YANoLocation_Continue,
								null,
								0, //priority adjustment
								false,
								false,
								null,
								null,
								true,
								_voyage.myTerminal);

	app.myTrxUA.trxUpdateVoyageAlloc(false,_voyage, proxyYAObj,realAlloc,app.myPassport);
	self.assertNotNull( realAlloc );

	return realAlloc;

epilog	
	allTransientCriteriaObj.purge();
	delete allTransientCriteriaObj;
	delete proxyYAObj;
	delete objSet;
end;</source>
        <Parameter name="_voyage" type="CM_Voyage" usage="input"/>
        <Parameter name="_portCode" type="String"/>
        <Parameter name="_isoGrpCode" type="String"/>
        <Parameter name="_comCode" type="String"/>
        <Parameter name="_cargoType" type="Integer"/>
        <Parameter name="_reqPwr" type="Boolean"/>
        <Parameter name="_isOD" type="Boolean"/>
        <ReturnType type="CM_VoyageAllocation"/>
    </JadeMethod>
    <JadeMethod name="addVoyageCargoLOLO" id="200f9877-2224-45b5-9c0a-84b1e2c77b08">
        <source>addVoyageCargoLOLO(_voyage : CM_Voyage; _startingSlotID : String; _numberOfSlots : Integer; _slotsToFill : StringArray);

/*

Purpose:		Create cargo on a LOLO Voyage

Date			Who		Reason
10/03/2014		cnwmh5	Initial creation

*/

vars

	theSlot							: CM_LocationsController;
	slot							: CM_SlotController;
	bay								: CM_BayVoyage;

	strs							: StringArray;
	slotsToFill						: CM_LCArray;
	
	iter							: Iterator;

	index 							: Integer;
	numberOfSlotToFill				: Integer;
	alreadyHaveSlots				: Boolean;
	idx								: Integer;
	
begin

	/*********************************************************************
	 * Get the slots to fill
	 *********************************************************************/
	create slotsToFill transient;
	
	if _slotsToFill &lt;&gt; null and not _slotsToFill.isEmpty then
		numberOfSlotToFill := _slotsToFill.size;
		alreadyHaveSlots := true;
	else
		numberOfSlotToFill := _numberOfSlots;
	endif;

	create strs transient;
	
	foreach index in 1 to numberOfSlotToFill step 1 do
	
		strs.clear;
		
		if alreadyHaveSlots then
			strs.add(_slotsToFill[index]);
		else
			if iter = null then
				strs.add(_startingSlotID);
			else
				//iter.next(slot);
				while iter.next(slot) and slot.mySlotDefnVoyage.unavailable do
				endwhile;
				if slot = null then
					break;
				endif;
				strs.add(slot.getFullId()[_voyage.code.length+1:end].trimBlanks);
			endif;
		endif;
		
		_voyage.findLocation(strs, false, theSlot, idx);
		slotsToFill.add(theSlot);
		
	///	write strs[1] &amp; Tab &amp; theSlot.String &amp; Tab &amp; self.opts.includesKey("ISOType").String &amp; Tab &amp; 
	///		self.opts.includesKey("Is40").String;
		
		if theSlot.isKindOf(CM_SlotController) and (self.opts.includesKey("ISOType") or 
				self.opts.includesKey("Is40")) then
			//self.xMakeSureSlotCanAccept(slotsToFill[slotsToFill.size]);
		//	aftSlot := slot.CM_SlotController.myAftSlot;
		//	self.xMakeSureSlotCanAccept(aftSlot);
		endif;
		
		if _startingSlotID &lt;&gt; null and iter = null then
			bay := _voyage.myCellularVoyageStructure.allBayVoyagesById[_startingSlotID[1:2]];
			delete iter;
			iter := bay.allSlotControllersByOrdinal.createIterator;
			while iter.next(slot) do
				//app.writeLog('slot: ' &amp; slot.String &amp; Tab &amp; slot.getID() &amp; Tab &amp; 'theSlot: ' &amp; theSlot.String &amp; Tab &amp; 
				///	theSlot.getID(), LogAlways);
				if slot = theSlot then
					///app.writeLog("Found so breaking Out", LogAlways);
					break;
				endif;
			endwhile;
		
		endif;
	
	endforeach;
	
	self.xCreateTIsForVoyCargoMeths(_voyage, slotsToFill);
	self.assertNoTrxErrorsOrWarnings();	

epilog

	delete slotsToFill;
	delete strs;
	delete iter;

end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_startingSlotID" type="String"/>
        <Parameter name="_numberOfSlots" type="Integer"/>
        <Parameter name="_slotsToFill" type="StringArray"/>
    </JadeMethod>
    <JadeMethod name="addVoyageCargoRORO" id="afe22e2c-0854-48e3-bbfa-450bb47b151f">
        <source>addVoyageCargoRORO(_voyage : CM_Voyage; _startingSlotLocnID : String; _numberOfSlots : Integer; _slotsLocnsToFill : StringArray);

/*

Purpose:		Create cargo on a RORO Voyage

Date			Who		Reason
11/03/2014		cnwmh5	Initial creation

*/

vars

	theSlot							: CM_LocationsController;
	slotDefn						: CM_ROROSlotDefn;
	locnDefn						: CM_ROROLocnDefn;
	aftSlotDefn						: CM_ROROSlotDefn;
	bay								: CM_BayVoyage;
	deck							: CM_DeckVoyage;
	deckItem						: CM_DeckItem;
	slotController					: CM_ROROSlotController;
	isoType							: CM_ISOType;

	strs							: StringArray;
	slotsToFill						: CM_LCArray;
	slotsLocnsToFill				: StringArray;
	
	iter							: Iterator;

	index 							: Integer;
	numberOfSlotToFill				: Integer;
	alreadyHaveSlots				: Boolean;
	idx								: Integer;
	totalNumberOfSlotsFound			: Integer;
	slotLocn						: String;
	timeToExitLoop					: Boolean;
	firstTime						: Boolean;
	getNextLocn						: Boolean;
	not20Foot						: Boolean;
	
begin
	
	/*********************************************************************
	 * Get the slots to fill
	 *********************************************************************/
	create slotsToFill transient;
	create strs transient;
	create slotsLocnsToFill transient;
	
	if _slotsLocnsToFill &lt;&gt; null and not _slotsLocnsToFill.isEmpty() then
		_slotsLocnsToFill.copy(slotsLocnsToFill);
	elseif _startingSlotLocnID &lt;&gt; null then
		slotsLocnsToFill.add(_startingSlotLocnID);
	endif;
	
	getNextLocn := true;
	
	if self.opts.includesKey("ISOType") then
		isoType := app.myRoot.allISOTypes[self.opts.str("ISOType")];
	endif;
	if (isoType &lt;&gt; null and not isoType.is20ftLong) or self.opts.includesKey("Is40") then
		not20Foot := true;
	endif;	
	
	while true do
	
		if getNextLocn then
			getNextLocn := false;
			index := index + 1;
			if not _slotsLocnsToFill.isEmpty() and index &gt; slotsLocnsToFill.size then
				break;
			endif;
			slotLocn := slotsLocnsToFill[index];
			write 'slotLocn: ' &amp; slotLocn;
			foreach deck in _voyage.myROROStructure.allDecks do
				delete iter;
				iter := deck.allROROLocnDefnByOrdinal.createIterator;
				while iter.next(locnDefn) do
					if locnDefn.code = slotLocn then
						break;
					endif;
				endwhile;
				if locnDefn &lt;&gt; null then
					break;
				endif;
			endforeach;
		else
			iter.next(locnDefn);
		endif;
			
		if locnDefn &lt;&gt; null then
			write Tab &amp; "locnDefn";
			if locnDefn.isKindOf(CM_ROROLaneDefnVoyage) then
				slotsToFill.add(deckItem.CM_ROROLaneDefnVoyage.myLaneController);
			elseif locnDefn.isKindOf(CM_ROROGCDefnVoyage) then
				slotsToFill.add(deckItem.CM_ROROGCDefnVoyage.myGCController);
			elseif locnDefn.isKindOf(CM_ROROLocnDefnVoyage) then
				foreach slotDefn in locnDefn.CM_ROROLocnDefnVoyage.allROROSlotDefnByOrdinal discreteLock do
					if slotDefn.isAvailable and slotDefn.CM_ROROSlotDefnVoyage.mySlotController.allTrackedItems.isEmpty()  then
						slotsToFill.add(slotDefn.CM_ROROSlotDefnVoyage.mySlotController);
						if not20Foot then
							aftSlotDefn :=  slotDefn.CM_ROROSlotDefnVoyage.getAftSlotDefn();
							if slotDefn.CM_ROROSlotDefnVoyage.mySlotController.getFwdLC() &lt;&gt; null then
								slotsToFill[slotsToFill.size] := slotDefn.CM_ROROSlotDefnVoyage.mySlotController.getFwdLC();
							endif;
						endif;
						if _numberOfSlots &gt; 0 and _numberOfSlots = slotsToFill.size then
							timeToExitLoop := true;
							break;
						endif;
					endif;
				endforeach;
			endif;
		else
			theSlot := _voyage.getLocationByID(slotLocn);
			write Tab &amp; 'theSlot: ' &amp; theSlot.String;
			if theSlot &lt;&gt; null then
				slotsToFill.add(theSlot);
				if not20Foot then
					if theSlot.getFwdLC() &lt;&gt; null then
						slotsToFill[slotsToFill.size] := theSlot.getFwdLC();
					endif;
				endif;
				if _slotsLocnsToFill.isEmpty() then
					timeToExitLoop := true;
				endif;
			endif;
		endif;
		
		if timeToExitLoop or (_numberOfSlots = 0 and _slotsLocnsToFill.isEmpty()) then 
			break;
		endif;
		
		if not _slotsLocnsToFill.isEmpty() then
			getNextLocn := true;
		endif;
		
	endwhile;
	
	self.xCreateTIsForVoyCargoMeths(_voyage, slotsToFill);
	self.assertNoTrxErrorsOrWarnings();	

epilog

	delete slotsToFill;
	delete strs;
	delete iter;
	delete slotsLocnsToFill;
	
end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_startingSlotLocnID" type="String"/>
        <Parameter name="_numberOfSlots" type="Integer"/>
        <Parameter name="_slotsLocnsToFill" type="StringArray"/>
    </JadeMethod>
    <JadeMethod name="addVoyageCraneQueue" id="6b893412-781d-4f7f-9bae-be1e225f2a1c">
        <source>addVoyageCraneQueue(_voyage: CM_Voyage input; _voyageQueue: CM_VoyageQueue input; _crane: CM_Machine input) : CM_VoyageCraneQueue;
//24 November 2011	cnwdw1	
//
vars
	queue: CM_RadioTelemetryQueue;
begin
	self.deleteQueue(_voyageQueue.id &amp; ' ' &amp; _crane.id.trimBlanks);
	
	beginTransaction;
	_crane.setPropertyValue(CM_Crane::myPrimaryQueue.name, _voyageQueue);
	_voyageQueue.createCraneQueue(_crane.CM_Crane, queue);
	queue.CM_VoyageCraneQueue.setPropertyValue("dischargeMachinesMode", self.opts.int("DischargeMachineHandOver"));
	queue.CM_VoyageCraneQueue.setPropertyValue("loadMachinesMode", self.opts.int("LoadMachineHandOver"));
	commitTransaction;
	self.assertNoTrxErrorsOrWarnings();
	return queue.CM_VoyageCraneQueue;

epilog
	abortTransaction;
end;</source>
        <Parameter name="_voyage" type="CM_Voyage" usage="input"/>
        <Parameter name="_voyageQueue" type="CM_VoyageQueue" usage="input"/>
        <Parameter name="_crane" type="CM_Machine" usage="input"/>
        <ReturnType type="CM_VoyageCraneQueue"/>
    </JadeMethod>
    <JadeMethod name="addVoyageJob" id="ab48d80d-20bc-42c3-acc1-cad1d28498b8">
        <source>addVoyageJob(_voyage : CM_Voyage; _craneId :String; _allSlots : CM_SlotControllerArray; isDischarge : Boolean) : CM_VoyageJob;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 December 2008	cnwer1	Initial creation

*/

vars
	theJobParams : CMIF_VoyageJobParams;
	theVoyageJS : CM_VoyageJobSheet;
	crane 		: CM_Crane;
	theRealVJob : CM_VoyageJob;
	slot 		: CM_SlotController;
	terminal	: CM_Terminal;
begin
	
	// 29099 Mar 2012
	terminal := self.getTerminal();
	if terminal &lt;&gt; null then
		crane := terminal.machines[_craneId].CM_Crane;
	endif;

	self.assertTrueMsg(crane &lt;&gt; null, "Crane " &amp; _craneId &amp; " does not exist!");
	
	create theJobParams transient;
	theJobParams.useNewMethod := true; //IMPORTANT TO SET THIS
	theJobParams.isDischarge		:=	isDischarge;
	theJobParams.jobNumLinkedLoad	:=null;
	theJobParams.craneID			:=	_craneId;
	theJobParams.myVoyage			:=	_voyage;
	theJobParams.myProxyJob			:=	null;
	theJobParams.resquence			:=	true;		//set true whenever there's the posibility of slots added/removed from a job
	theJobParams.isSeqForJob		:=	false;

	
	if self.opts.includesKey("OutOfOrder") then
		theJobParams.allowOutOfOrderLoading := self.opts.bool("OutOfOrder");
	endif;
	
	theVoyageJS :=  _voyage.allJobSheets[_craneId];
	theJobParams.id := self.opts.strDef("JobId", _voyage.getNextJobNumber(theVoyageJS, crane.IF_VoyageWorkPoint)); //
	//theJobParams.myBay := self.mnuGridNewJob.userObject.CM_Bay;
	_allSlots.copy(theJobParams.allSlotControllers);

	//can't just copy - this is an external key dict
	foreach slot in _allSlots do
		theJobParams.allObjectEditions.add(slot);
	endforeach;
	
	app.myPassport.setWarningsIgnored(true); // PAR 28968
	app.myTrxCA.trxCreateVoyageJob(theJobParams, theRealVJob, app.myPassport);
	self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());
	

	return theRealVJob;
epilog
	
	if theJobParams &lt;&gt; null then
		delete theJobParams.myProxyJob;
	endif;
	delete theJobParams;

end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_craneId" type="String"/>
        <Parameter name="_allSlots" type="CM_SlotControllerArray"/>
        <Parameter name="isDischarge" type="Boolean"/>
        <ReturnType type="CM_VoyageJob"/>
    </JadeMethod>
    <JadeMethod name="addVoyageNonPlannedNonWorked" id="7cd79513-1d63-4f91-876b-03c601e1f4fc">
        <source>addVoyageNonPlannedNonWorked(	_code : String; _vesselCode : String; _operatorName : String; _shippingLine : String) : CM_Voyage;
	
//16 December 2008	cnwdw1	
begin
    return self.addVoyageWithInwardCode( _code, "", _vesselCode, _operatorName, _shippingLine); //PAR 32247 cnwgb1 13.8.2013
end;</source>
        <Parameter name="_code" type="String"/>
        <Parameter name="_vesselCode" type="String"/>
        <Parameter name="_operatorName" type="String"/>
        <Parameter name="_shippingLine" type="String"/>
        <ReturnType type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="addVoyageQueue" id="001f8c1f-1a0c-42e8-a944-90f2774b7977">
        <source>addVoyageQueue(_voyage: CM_Voyage input): CM_VoyageQueue;
//24 November 2011	cnwdw1	
//
vars
	queue: CM_RadioTelemetryQueue;
begin
	self.deleteQueue(_voyage.code);

	beginTransaction;
	app.myPassport.clearErrorsWarnings();
	self.getTerminal.radioTelemetry.masterQueue.createVoyageQueue(_voyage, queue);
	commitTransaction;
	self.assertNoTrxErrorsOrWarnings();
	return queue.CM_VoyageQueue;

epilog
	abortTransaction;
end;</source>
        <Parameter name="_voyage" type="CM_Voyage" usage="input"/>
        <ReturnType type="CM_VoyageQueue"/>
    </JadeMethod>
    <JadeMethod name="addVoyageROROJob" id="6a89e405-8e8d-41e9-a753-a9bb4f84517d">
        <source>addVoyageROROJob(_voyage : CM_Voyage; _deck : CM_DeckVoyage; _workPoint :String; _allSlots : CM_LCArray; isDischarge : Boolean) : CM_VoyageJob;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 December 2008	cnwer1	Initial creation

*/

vars
	theJobParams : CMIF_VoyageJobParams;
	theVoyageJS : CM_VoyageJobSheet;
	theRealVJob : CM_VoyageJob;
	slot 		: CM_VoyageROROController;
	workPoint : CM_WorkPoint;
	voyage 		: CM_Voyage;
	operator 		: CM_Operator;
	vessel 			: CM_Vessel;
	lc : CM_LocationsController;
begin
	
	workPoint:=self.addWorkPoint(_workPoint, false);
	self.assertTrue(workPoint &lt;&gt; null);
	
	create theJobParams transient;

	theJobParams.useNewMethod := true; //IMPORTANT TO SET THIS
	theJobParams.isDischarge		:=	isDischarge;
	theJobParams.jobNumLinkedLoad	:=null;
	theJobParams.craneID			:=	_workPoint;
	theJobParams.myVoyage			:=	_voyage;
	theJobParams.myProxyJob			:=	null;
	theJobParams.resquence			:=	true;		//set true whenever there's the posibility of slots added/removed from a job
	theJobParams.isSeqForJob		:=	false;
	theJobParams.myDeck				:= _deck;
	theJobParams.myWorkPoint		:= workPoint;
		
	theJobParams.allowOutOfOrderLoading := self.opts.bool( 'OutOfSequenceVJ' );
	
	
	theVoyageJS :=  _voyage.allJobSheets[_workPoint];
	theJobParams.myJobSheet := theVoyageJS;
	theJobParams.id := _voyage.getNextJobNumber(theVoyageJS, workPoint.IF_VoyageWorkPoint); 
	_allSlots.copy(theJobParams.allROROControllers);

	//can't just copy - this is an external key dict
	foreach lc  in _allSlots do
		slot := lc.CM_VoyageROROController;
		
		theJobParams.allObjectEditions.add(slot);
	endforeach;
	
	
	app.myTrxCA.trxCreateVoyageJob(theJobParams, theRealVJob, app.myPassport);
	self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());
	
	return theRealVJob;
epilog
	
	if theJobParams &lt;&gt; null then
		delete theJobParams.myProxyJob;
	endif;
	delete theJobParams;


end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_deck" type="CM_DeckVoyage"/>
        <Parameter name="_workPoint" type="String"/>
        <Parameter name="_allSlots" type="CM_LCArray"/>
        <Parameter name="isDischarge" type="Boolean"/>
        <ReturnType type="CM_VoyageJob"/>
    </JadeMethod>
    <JadeMethod name="addVoyageToEDIProcessing" id="19f11deb-5d04-45e7-8bec-f58be61879a9">
        <source>addVoyageToEDIProcessing(_voyage : CM_Voyage);
// ---------------------------------------------------------------------------
// Created:	15 September 2010 By Graeme Black cnwgb1
// Purpose:	Puts the voyage in the terminal collection of voyages available for EDI processing
// ---------------------------------------------------------------------------
vars
	terminal : CM_Terminal;
	ediConfig : CM_EDIConfig;
	addedVoyToEDI : Boolean;
begin
	terminal := self.getTerminal();
	ediConfig := terminal.myEdiConfig;
	
	self.assertNotNull( ediConfig );
	
	//all we need to do here is add this voyage to the ediConfigs voyage list...
	beginTransaction;
	addedVoyToEDI := ediConfig.addVoyageToProcessing(_voyage, _voyage.code); 
	commitTransaction;
	assertTrueMsg( addedVoyToEDI, "Couldn't add voyage to edi processing collection" );
epilog
end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="addVoyageWithConRORO" id="0e09ba11-74e4-4091-9993-038e9dfc30b8">
        <source>addVoyageWithConRORO(_code : String; _vesselCode : String; _operatorName : String; _shippingLine : String; _tradeCode : String; _numberHatches : Integer; _isNonPlannedVoyage : Boolean; _isNonWorkedVoyage : Boolean) : CM_Voyage;
/****Changes

Date		Name	TFS#			Description
============================================================================	
29/03/2010 	cnwrs1	
29/07/2011	cnwmh5					Change to use UT_UnitTest.opts
26/03/2013	PJS		PAR # 31232
05/03/2015	cnwdap1	PAR #35826 
					CCMS SFW 1410 	Added expected arrival/departure date/time
11/04/2017	cnwdap1	TFS 4050 		LNX Job ID Enhancements
05/12/2018	jlgka1	TFS 37102		STWR - Add isBarges Flag.
============================================================================*/
vars
	vessel				  	: CM_Vessel;
	pxyVoyage			  	: CM_Voyage;
	voyage				  	: CM_Voyage;
	pxyCellStructure	  	: CM_CellularVoyageStructure;
	now					  	: TimeStamp;
	arrivalDate		  	  	: TimeStamp;
	departureDate		  	: TimeStamp;
	pilotOnBoard		  	: TimeStamp;
	labourOnBoard		  	: TimeStamp;
	shipPilotReturnDT	  	: TimeStamp;
	labourOnShore 		  	: TimeStamp;
	pxyGlobalVoyage		  	: CM_VoyageGlobal;
	trade				  	: CM_Trade;
	pxyVoyagePortRotation 	: CM_PortRotation;
	portRotation		  	: CM_PortRotation;
	outOfSequenceVJ 	  	: Boolean;
	portRotationToDelete  	: CM_PortRotationArray;						// 24/02/2014 cnwmh5
	
	
	inwardCode 			  	: String;
	estArrivalDate			: TimeStamp;
	estDepartureDate		: TimeStamp;
	
begin
	
	vessel := getRoot.allVessels[_vesselCode];
	self.assertNotNullMsg(vessel, "Vessel");                // 04/10/2013 cnwmh5
	
	create portRotationToDelete transient;
	
	if _tradeCode = null then
		trade := getTrade();
	else
		trade := self.getRoot.allTradesByDescription[_tradeCode];
	endif;
	create pxyVoyage transient;							

	// PAR # 31232
	//pxyVoyage.setProxyForVoyageType(vessel.myCellularVesselStructure.type,vessel);

	pxyVoyage.setProxyForVoyageType(vessel.structureIncludesLOLO,
									vessel.structureIncludesRORO,
									vessel.structureIncludesHolds,
									vessel);

	create pxyGlobalVoyage transient;
	pxyGlobalVoyage.setProxy(_code, _vesselCode, null, null, null, null, null, 0, null, app.myRoot);
	
	pxyVoyage.setMyVoyageGlobalArrival(pxyGlobalVoyage);
	
	arrivalDate.setDate(now.date());
	arrivalDate.setTime(now.time());
	departureDate := arrivalDate.addDays(2);
	
	outOfSequenceVJ	:= self.opts.bool( 'OutOfSequenceVJ' );
	
	if self.opts.includesKey("InwardCode") then
		inwardCode := self.opts.str("InwardCode");
	else
		inwardCode := null;
	endif;
	
	estArrivalDate := null;
	estDepartureDate := null;
	if self.getTerminalConfig(EtaEtdMandatory).Boolean = true then
		if self.opts.includesKey("estimatedArrivalDate") then
			estArrivalDate.setDate(self.opts.date("estimatedArrivalDate"));
		else
			estArrivalDate.setDate(arrivalDate.date);
		endif;
		if self.opts.includesKey("estimatedDepartureDate") then
			estDepartureDate.setDate(self.opts.date("estimatedDepartureDate"));
		else
			estDepartureDate.setDate(departureDate.date);
		endif;
	endif;
	
	pxyVoyage.setProxyVoyage(	null,
								self.opts.str( ETRow_CallSign ),
								_code,
								inwardCode,
								self.createdByUnitTest(null),					// 18/08/2015 cnwmh5
								vessel.code,
								vessel.name,
								self.opts.str( ETRow_LloydsNumber ),
								false,
/*		PAR 33644						_isNonPlannedVoyage,
								_isNonWorkedVoyage, */
								false,
								false,
								0,
								VoyageDisplayAlways,
								0,
								pxyVoyage.status,
								vessel.vesselType,
								null,
								arrivalDate,
								departureDate,
								pxyVoyage.loadStartDT,
								pxyVoyage.loadEndDT,
								null,
								null,
								null,
								null,
								getRoot.allOperators[_operatorName],
								trade,
								getRoot.allShippingLines[_shippingLine],
								self.getTerminal,
								pxyVoyage.myVoyageGlobalArrival,
								null,
								null,
								null,
								null,
								null,
								0,
								false,									// 27/05/2009 cnwar2 CCMS1040
								pxyVoyage.allOperators,
								pxyVoyage.allReceivalCutoffs,		// 27/05/2009 cnwar2 CCMS1040
								true, // use Voyage Allocations
								null, 
								null,
								null,
								null,
								null,
								null,
								null,
								null,
								null,
								outOfSequenceVJ,
								estArrivalDate,							// PAR #35826
								estDepartureDate,
								null,	//_generalLandingDate : Date	//14 Mar 2016	TFS 1407
								null, 				// TFS 4050
								pxyVoyage.paymentType,
								pxyVoyage.isBarge,	//jlgka1 TFS 37102
								pxyVoyage.voyageGroupCode,
								false	// 31.Aug.2023 navsp1 TFS 57809
								);							
								
	// PAR # 31232 - RORO vessel - for consistenty with prior mode mark as LOLO vessel as well							
	//	pxyVoyage.setProxyForVoyageType(CellularStructureRORO,vessel);
	//pxyVoyage.setProxyForVoyageType(true,true,false,vessel);
	pxyVoyage.setProxyForVoyageType(vessel.structureIncludesLOLO,vessel.structureIncludesRORO,vessel.structureIncludesHolds,vessel);

	if not self.opts.includesKey("CopyVoyageVAConfig") then					// 29/01/2014 cnwmh5
		self.setProxyVoyageVAConfig(pxyVoyage); // AKB ADDED 18/8/11 RORO KPI
	endif;
	
	// Set the Port Rotations from the Trade
	foreach portRotation in trade.allPortRotations do
		create pxyVoyagePortRotation transient;
		portRotation.allTranshipPorts.copy(pxyVoyagePortRotation.allTranshipPorts);
		pxyVoyagePortRotation.setProxy(portRotation.myPort, pxyVoyage);
		portRotationToDelete.add(pxyVoyagePortRotation);
	endforeach;
	
	//cnwmc5 - 3/12/2012 - add all the trade operators to the voyage
	trade.operators.copyNoDuplicates(pxyVoyage.allOperators, false);
	
	//10 Apr 2012	NDL	Par 29369
	pilotOnBoard := arrivalDate.cnEcAddMinutes( -2 );
	pxyVoyage.setPropertyValue( CM_Voyage::pilotOnBoardDT.name, pilotOnBoard );
	labourOnBoard := arrivalDate;
	pxyVoyage.setPropertyValue( CM_Voyage::labourOnBoard.name, labourOnBoard );
	labourOnShore := arrivalDate.cnEcAddDays( 1 );
	pxyVoyage.setPropertyValue( CM_Voyage::labourOnShore.name, labourOnShore );
	shipPilotReturnDT := departureDate.cnEcAddMinutes( -2 );
	pxyVoyage.setPropertyValue( CM_Voyage::shipPilotReturnDT.name, shipPilotReturnDT );
	
	self.ignoreTrxWarnings(true);
	//app.myPassport.setWarningsIgnored(true);
	app.myTrxCA.trxCreateVoyage(pxyVoyage, voyage, vessel, null, true, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();

	return voyage;
epilog
	/*
	foreach pxyVoyagePortRotation in portRotationToDelete do						// 24/02/2014 cnwmh5 - Transient leaks
		delete pxyVoyagePortRotation;
	endforeach;
	*/
	if portRotationToDelete &lt;&gt; null then	// 11/07/2019 jlgzm1 1090 error
		portRotationToDelete.purge();
	endif;
	delete portRotationToDelete;

	if pxyVoyage &lt;&gt; null then
		delete pxyVoyage.myROROStructure;
		delete pxyVoyage.myCellularVoyageStructure;
		delete pxyVoyage.myGeneralCargoVoyage;
		delete pxyVoyage.myStructuralElements;
		delete pxyVoyage;
	endif;

	if global.isValidObject(pxyGlobalVoyage) then
		delete pxyGlobalVoyage; //cnwrs1 par23228 10 Mar 2010 now done in CM_Voayge setForCreate
	endif;
end;</source>
        <Parameter name="_code" type="String"/>
        <Parameter name="_vesselCode" type="String"/>
        <Parameter name="_operatorName" type="String"/>
        <Parameter name="_shippingLine" type="String"/>
        <Parameter name="_tradeCode" type="String"/>
        <Parameter name="_numberHatches" type="Integer"/>
        <Parameter name="_isNonPlannedVoyage" type="Boolean"/>
        <Parameter name="_isNonWorkedVoyage" type="Boolean"/>
        <ReturnType type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="addVoyageWithContainerStructur" id="c6fd79cf-4537-4bf2-9a72-d8f1f18baf70">
        <source>addVoyageWithContainerStructur(	_code : String; _vesselCode : String; _operatorName : String; _shippingLine : String ) : CM_Voyage;
/****Changes

Date		Name	TFS#			Description
============================================================================	
16/12/2008	cnwdw1	
05/03/2015 	cnwdap1	PAR #35826 
					CCMS SFW 1410 	Added expected arrival/departure date/time
11/04/2017	cnwdap1	TFS 4050 		LNX Job ID Enhancements
05/12/2018	jlgka1	TFS 37102		STWR - Add isBarges Flag.
// 10 Sep 2019	cnwrs1	TFS 46030
============================================================================*/
vars
	useHMSData				 : Boolean;
	vessel					 : CM_Vessel;
	pxyVoyage				 : CM_Voyage;
	voyage					 : CM_Voyage;
	inwardCode				 : String;
	cusresAltVoyageStr		 : String;							// cnwrl1 28/04/2010 PAR 23854
	cusresAltVoyage			 : CM_Voyage;						// cnwrl1 28/04/2010 PAR 23854
	pxyCellStructure		 : CM_CellularVoyageStructure;
	now						 : TimeStamp;
	arrivalDate				 : TimeStamp;
	departureDate 			 : TimeStamp;
	pxyGlobalVoyage			 : CM_VoyageGlobal;
	pxyHMSData				 : HMS_VoyageData;
	trade					 : CM_Trade;
	pxyVoyagePortRotation	 : CM_PortRotation;
	portRotation			 : CM_PortRotation;
	berth					 : HMS_Berth;
	term					 : CM_Terminal;
	useAllocations			 : Boolean;
	pxyPortRotationsToDelete : CM_PortRotationArray;				// 24/02/2014 cnwmh5 - transient leaks
	obj						 : Object;
	bank 					 : CM_Bank;
begin
	term := self.getTerminal();
	if self.opts.includesKey("dischargeCompany") then
		bank := self.opts.obj("dischargeCompany").CM_Bank;
	endif;
	//opts := self.getOpts(_opts);
	
//	vessel := getRoot.allVessels[_vesselCode];		// cnwrl1 14/05/2010 PAR 24216 - what it was
	vessel := self.getVessel( _vesselCode );
	self.assertNotNullMsg(vessel, "Vessel");                // 04/10/2013 cnwmh5
	 
	create pxyPortRotationsToDelete transient;
	
	if self.opts.includesKey("Trade") then
		trade := app.myRoot.allTradesByDescription[self.opts.str("Trade")];
	else
		trade := getTrade;
	endif;
	
	create pxyVoyage transient;							
	
	create pxyCellStructure transient;
	pxyVoyage.setProxyVoyageCellullStructure(pxyCellStructure);
	pxyCellStructure.setProxyCellularVoyage(vessel.myCellularVesselStructure.bridgeAfterBay, 
											vessel.myCellularVesselStructure.isoHalfHeights,
											vessel.myCellularVesselStructure.use40Id, 
											vessel.myCellularVesselStructure.useBayCellTierNumbering);
	
	create pxyGlobalVoyage transient;
	pxyGlobalVoyage.setProxy(_code, _vesselCode, null, null, null, null, null, 0, null, app.myRoot);
	pxyVoyage.setMyVoyageGlobalArrival(pxyGlobalVoyage);
	
	arrivalDate.setDate(now.date());
	arrivalDate.setTime(now.time());
	departureDate := arrivalDate.addDays(2);

	if self.opts.includesKey("tsArrival") then // whole time stamp
		arrivalDate := self.opts.timestamp("tsArrival");
	elseif self.opts.includesKey("dateArrival") then // just a date
		arrivalDate.setDate(self.opts.date("dateArrival"));
	endif;
	
	if self.opts.includesKey("tsDeparture") then // whole time stamp
		departureDate := self.opts.timestamp("tsDeparture");
	elseif self.opts.includesKey("dateDeparture") then // just a date
		departureDate.setDate(self.opts.date("dateDeparture"));
	endif;
	inwardCode := self.opts.str('inwardCode');
	
	// cnwrl1 28/04/2010 PAR 23854 - start of coding
	cusresAltVoyageStr	:= self.opts.str( 'myCusresAltVoyage' );
	if cusresAltVoyageStr &lt;&gt; null then
		cusresAltVoyage	:=  self.getVoyage( cusresAltVoyageStr );
	endif;
	// cnwrl1 28/04/2010 PAR 23854 - end of coding
	

	useAllocations	:= self.opts.bool( 'UseAllocations' );

	pxyVoyage.setProxyVoyage(	null,
								self.opts.str( ETRow_CallSign ),
								_code.toUpper(),								// 23/01/2014 cnwmh5
								inwardCode,
								self.createdByUnitTest(null),					// 18/08/2015 cnwmh5
								vessel.code,
								vessel.name,
								self.opts.str( ETRow_LloydsNumber ),
								false,
/* PAR 33644								false,
								false, */
								false,
								false,
								0,
								VoyageDisplayAlways,
								0,
								pxyVoyage.status,
								vessel.vesselType,
								null,
								arrivalDate,
								departureDate,
								pxyVoyage.loadStartDT,
								pxyVoyage.loadEndDT,
								null,
								null,
								null, 
								bank,// BANK
								getRoot.allOperators[_operatorName],
								trade,
								getRoot.allShippingLines[_shippingLine],
								self.getTerminal,
								pxyVoyage.myVoyageGlobalArrival,
								null,
								null,
								null,
								null,
//								null,							// cnwrl1 28/04/2010 PAR 23854 - what it was
								cusresAltVoyage,
								0,
								false,									// 27/05/2009 cnwar2 CCMS1040
								pxyVoyage.allOperators,
								pxyVoyage.allReceivalCutoffs,		// 27/05/2009 cnwar2 CCMS1040
								useAllocations, //use voyage allocations
								null,
								null,
								null,
								null,
								null,
								null,
								null,
								null,null,null,
								null,null,
								null,	//_generalLandingDate : Date	//14 Mar 2016	TFS 1407
								null,			// TFS 4050
								pxyVoyage.paymentType,
								pxyVoyage.isBarge, 	//jlgka1 TFS 37102
								pxyVoyage.voyageGroupCode,
								false	// 31.Aug.2023 navsp1 TFS 57809
								);					// PAR #35826
	
	
	self.createExchangeDates(pxyVoyage); // AKB 2010 AUG
	
	if self.opts.includesKey("useHMSData") then
		useHMSData := self.opts.bool("useHMSData");
	endif;
//	9/9/19 MAP always create HMS object
//	if useHMSData then
		berth := self.opts.obj("berth").HMS_Berth;
		create pxyHMSData transient;
		pxyHMSData.setPxyFromVessel(vessel, term);
		pxyHMSData.setMyBerth(berth);
		pxyHMSData.setTidalClasses(app.myRoot.allTidalClasses['A'], app.myRoot.allTidalClasses['B']);	//10 Sep 2019	cnwrs1	TFS 46030
		pxyVoyage.setHMSVoyageData(pxyHMSData);
		pxyHMSData.setProxyDefaultVoyageMovements(berth, null, app.myPassport);
//	endif;
	
	// Set the Port Rotations from the Trade
	foreach portRotation in trade.allPortRotations do
		create pxyVoyagePortRotation transient;
		portRotation.allTranshipPorts.copy(pxyVoyagePortRotation.allTranshipPorts);
		pxyVoyagePortRotation.setProxy(portRotation.myPort, pxyVoyage);
		pxyPortRotationsToDelete.add(pxyVoyagePortRotation);
	endforeach;
	
	
	if not self.opts.includesKey("CopyVoyageVAConfig") then					// 29/01/2014 cnwmh5
		self.opts.addAssoc("UseVesselAllocations", true);
		self.opts.addAssoc("Vessel", vessel);
		self.setProxyVoyageVAConfig(pxyVoyage); // AKB ADDED 18/8/11 RORO KPI
	endif;
	
	
	//cnwmc5 - 3/12/2012 - add all the trade operators to the voyage
	trade.operators.copyNoDuplicates(pxyVoyage.allOperators, false);

	self.ignoreTrxWarnings(true);
	//app.myPassport.setWarningsIgnored(true);
	app.myTrxCA.trxCreateVoyage(pxyVoyage, voyage, vessel, null, true, app.myPassport);
	
	self.assertNoTrxErrorsOrWarnings();

	return voyage;
epilog

	delete pxyCellStructure;											// 24/02/2014 ccnwmh5 - Transient Leaks
	
	foreach pxyVoyagePortRotation in pxyPortRotationsToDelete do		// 24/02/2014 ccnwmh5 - Transient Leaks
		delete pxyVoyagePortRotation;
	endforeach;
	delete pxyPortRotationsToDelete;
	
	delete pxyVoyage;													// 24/02/2014 ccnwmh5 - Transient Leaks

	if global.isValidObject(pxyGlobalVoyage) then
		delete pxyGlobalVoyage; //cnwrs1 par23228 10 Mar 2010 now done in CM_Voayge setForCreate
	endif;
end;
</source>
