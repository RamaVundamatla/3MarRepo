    <JadeMethod name="listTableStopsTable" id="48733188-49be-43e8-8bdb-e65f928056a9">
        <source>listTableStopsTable(pListTable : CMUI_ListTable input; 
					_terminal : CM_Terminal;
					_toMaintain : Boolean);
// ---------------------------------------------------------------------------
// Created:		07 January 2003  by Jason Chapman  (cnwjc2)
// Date			Who		Reason
// 18 April 2023	navmk20	Bug 56980: MTN - Additional details form not displayed
// ---------------------------------------------------------------------------
vars
	stopsTables : CM_StopsTableByIdDict;
	stop		: CM_StopsTable; 		// 18.4.2023 navmk20 TFS 56980
	assist		: CMUI_Assistant; 		// 18.4.2023 navmk20 TFS 56980
	index		: Integer;				// 18.4.2023 navmk20 TFS 56980
	
begin
	if _terminal = null then
		return;
	endif;
	
	if _toMaintain then
		stopsTables := app.getMyUser.getStopsToMaintForTerminal(_terminal);
	else
		stopsTables := app.getMyUser.getStopsToViewForTerminal(_terminal);
	endif;
	
	if stopsTables = null then
		return;
	endif;
	// Start - 18.4.2023 navmk20 TFS 56980
	//pListTable.displayCollection(stopsTables, false, Table.DisplayCollection_Forward, null);
	pListTable.sortColumn[1] := 2;   
	pListTable.sortAsc[1]    := true;
	pListTable.sortCased[1]  := false;
	
	create assist transient;
	foreach stop in stopsTables do
		index := pListTable.addItem(assist.displayEntryStopsTableList(stop, false, true));	// TFS4085 MAP 12/4/17
		pListTable.accessRow(index).itemObject := stop;
	endforeach;
	// End - 18.4.2023 navmk20 TFS 56980
end;</source>
        <Parameter name="pListTable" type="CMUI_ListTable" usage="input"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_toMaintain" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="listTableStopsTable2" id="0f2e2dff-4673-49cc-a25d-d34b12f9c208">
        <source>listTableStopsTable2(
	_stopsListTable	: CMUI_StopsListTable input; 
	_terminal		: CM_Terminal;
	_toMaintain		: Boolean );
	
/*
Purpose:	Get all of the possiblly allowed StopsTable instances depending on security.

Date				Who		Reason
21 December 2009	cnwrl1	Initial creation as part of PAR 21889 - CCMS 1002 = Stops and Italian Customs - T1015 = Expiry Date for Stops Clearance
*/
	
vars
	stopsTables	: CM_StopsTableByIdDict;
	
begin
	if _terminal = null then
		return;
	endif;
	
	if _toMaintain then
		stopsTables	:= app.getMyUser.getStopsToMaintForTerminal( _terminal );
	else
		stopsTables := app.getMyUser.getStopsToViewForTerminal( _terminal );
	endif;
	
	if stopsTables = null or stopsTables.isEmpty then
		// usually because do not have permission to view / maintain the stops on the terminal.
		_stopsListTable.setCellText(	_stopsListTable.rows,
										_stopsListTable.headingColumn,
										app.getString( NoPermissionToMaintainTheStops ) );
		return;
	endif;
	
	_stopsListTable.displayCollection( stopsTables, false, Table.DisplayCollection_Forward, null );
	
epilog
	
end;
</source>
        <Parameter name="_stopsListTable" type="CMUI_StopsListTable" usage="input"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_toMaintain" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="listTableStopsTableSys" id="8587905d-6dc8-4dfb-a725-bc0d3e26793c">
        <source>listTableStopsTableSys(pListTable : CMUI_ListTable input);
// ---------------------------------------------------------------------------
// Created:		03 June 2004 by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------
vars
	stopTables : CM_StopsTableByIdDict; 
begin
	
	// DVB CCMS 1235
//	stopsTables := app.myRoot.allStopsTable;
	stopTables := app.myRoot.allAvailableStopsTables;
	
	if stopTables = null then
		return;
	endif;
	
	pListTable.displayCollection(stopTables, false, Table.DisplayCollection_Forward, null);

end;</source>
        <Parameter name="pListTable" type="CMUI_ListTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="listTableStopsTableSysUser" id="ee0a3364-eda7-4a59-bf48-0b3a6cb6dcab">
        <source>listTableStopsTableSysUser( _listTable : CMUI_ListTable input; _cargoType : CM_CargoType; _allStopsForUser : CM_StopsTableByIdDict input; _toMaintain : Boolean);
/* ---------------------------------------------------------------------------
Created:	19 August 2008	by cnwvu1

Purpose:	all stops that are avialable for a user from all terminals
  
Change Date		Who		Reason
27 Jul 2022	navsj20	TFS 53862	EUP - WMS - Damage Recording Extra Details
------------------------------------------------------------------------------*/
vars
	ut			: CM_UserTerminal;
	stopsTables : CM_StopsTableByIdDict; 
	stop		: CM_StopsTable;
	user		: CM_User;
	criteria : CM_YACriteria;	//20 Jul 2022	navsj20	TFS 53862
	
begin

	user := app.getMyUser();
	_listTable.clear();
	
	foreach ut in user.allUserTerminals do
		
		if _toMaintain then
			stopsTables := user.getStopsToMaintForTerminal(ut.myTerminal);
		else
			stopsTables := user.getStopsToViewForTerminal(ut.myTerminal);
		endif;
	
		foreach stop in stopsTables do
			if not _allStopsForUser.includes(stop) then
				//if stop.allCargoTypesNew.includes(_cargoType) then	//20 Jul 2022	navsj20	TFS 53862
				if stop.myStopCriteria &lt;&gt; null then 
					foreach criteria in stop.myStopCriteria.allCriteria where criteria.myYACriteriaType.type = YACriteriaType_CargoType 
					and criteria.myYAData.CM_YADataObjects.allObjects.includes(_cargoType) do	//27 Jul 2022	navsj20	TFS 53862
						_allStopsForUser.add(stop);
					endforeach;			//27 Jul 2022	navsj20	TFS 53862
				endif;
			endif;
		endforeach;
	
	endforeach;
	
	_listTable.displayCollection( _allStopsForUser, false, Table.DisplayCollection_Forward, null );

epilog
//	delete allStops;

end;</source>
        <Parameter name="_listTable" type="CMUI_ListTable" usage="input"/>
        <Parameter name="_cargoType" type="CM_CargoType"/>
        <Parameter name="_allStopsForUser" type="CM_StopsTableByIdDict" usage="input"/>
        <Parameter name="_toMaintain" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="listTableTerminal" id="d96c41a1-299d-4fd3-bcb1-62814d7f2a93">
        <source>listTableTerminal(_lstTbl : CMUI_ListTable input;
					_displayCode,
					_displayDescription : Boolean;
					_termCol : CM_TerminalByCodeDict;
					_terminalsToSelect : CM_TerminalByCodeDict);
//-----------------------------------------
// Created: May 2004 By: cnwgd1
//-----------------------------------------
vars
	user		: CM_User;
	term		: CM_Terminal;
	rowStr		: String;
	row			: Integer;
	passport	: CM_Passport;
	failedDAC  :CM_DataAccessController;
begin
	_lstTbl.clearSelected();
	_lstTbl.rows := 0;
	
	if _termCol = null then //don't just return - this is an error
		app.raiseUnexpectedProgramError(class.name, method.name, '_termCol dictionary passed in was null');
		return;
	endif;	

	passport := app.myPassport;
	user := passport.myUser;

	foreach term in _termCol do
		if (not term.canUserAccessSelf(user, failedDAC, passport)) then
			continue;
		endif;
		if _terminalsToSelect &lt;&gt; null then
			if _terminalsToSelect.includesKey(term.code) then
				rowStr := '1' &amp; Tab;
				_lstTbl.allSelectedObjects.add(term);
			else
				rowStr := '0' &amp; Tab;		
			endif;
		else
			rowStr := '0' &amp; Tab;		
		endif;
		
		if _displayCode then
			rowStr := rowStr &amp; term.code &amp; '   ';
		endif;
		
		if _displayDescription then
			rowStr := rowStr &amp; term.name;
		endif;
		
		_lstTbl.accessRow(_lstTbl.addItem(rowStr)).itemObject := term;
	endforeach;


end;</source>
        <Parameter name="_lstTbl" type="CMUI_ListTable" usage="input"/>
        <Parameter name="_displayCode" type="Boolean"/>
        <Parameter name="_displayDescription" type="Boolean"/>
        <Parameter name="_termCol" type="CM_TerminalByCodeDict"/>
        <Parameter name="_terminalsToSelect" type="CM_TerminalByCodeDict"/>
    </JadeMethod>
