    <JadeMethod name="getOtherLocnControllerFor40TI" id="1e5f288b-8375-4da8-bd19-672815f2f6a3">
        <source>getOtherLocnControllerFor40TI() : CM_VoyageROROController;

/*

Purpose:			

Date			Who		Reason
27 July 2012	cnwmh5	Initial creation #30018

*/

vars

	lc					: CM_VoyageROROController;

begin

	lc := self.getAftLC();
	if lc = null or lc = self then
		lc := self.getFwdLC();
		if lc &lt;&gt; null and lc = self then
			lc := null;
		endif;
	endif;
	
	return lc;

epilog

end;</source>
        <ReturnType type="CM_VoyageROROController"/>
    </JadeMethod>
    <JadeMethod name="getProposedTIs" id="6cbd2823-100c-4672-989c-54746095c2f6">
        <source>getProposedTIs(_tis : CM_TIArray input);
/*
Purpose:			
Date				Who			Reason
AUGUST 2011		CNWAB1		Initial creation
*/


vars

begin
	if _tis = null then
		app.raiseCMException2(MethodWithNullParam, method.name, "No TI Array Reference", null, null);
		return;
	endif;
	//------------------------
	//Always clear 1st.
	//------------------------
	_tis.clear();
	
	if self.allTrackedItems.isEmpty then
	
		if self.allRequestsLoad.isEmpty then
			//if we are empty and nothing is being loaded here it is 
			//not possible for anything to be discharged - return with _tis empty
			return;
		endif;

	else
	
		self.allTrackedItems.copy(_tis);
		
		if self.allRequestsDischarge.isEmpty and self.allRequestsLoad.isEmpty then
			//if we have TIs and nothing is being discharged/loaded
			//here we return with the current TIs
			return;
		endif;
	endif;
	//we have some loads and/or discharges - work out the final situation...
	self.getMyFutureTIs(_tis);
	
end;</source>
        <Parameter name="_tis" type="CM_TIArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getQueueTasks" id="8bcfac41-0de3-478b-8873-9b8fbbf5f5aa">
        <source>getQueueTasks(arbiter: CM_RTQueueArbiter io; _isSource: Boolean);
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 August 2011	cnwer1	Initial creation CCMS MES 1033

*/

vars
	task	: CM_RTQueueTask;
begin

	if _isSource then
		create task;
		//parent will be set higher up.
		task.setDetails(	self,
							arbiter.ti.getPrimaryLocation(QUEUE_MODE),
							TASK_UNACTIONED,
							TASK_PICKUP,
							arbiter.ti);
		task.isOverstowTask := false;
		arbiter.entry.addTask(task);
		
	else 
		create task;
		task.setDetails(	arbiter.ti.getPrimaryLocation(REAL_MODE),
							self,
							TASK_UNACTIONED,
							TASK_SETDOWN,
							arbiter.ti);
		task.isOverstowTask := false;
		arbiter.entry.addTask(task);	
	
	endif;

epilog

end;</source>
        <Parameter name="arbiter" type="CM_RTQueueArbiter" usage="io"/>
        <Parameter name="_isSource" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getQueues" id="21748d83-c8c6-4324-ab37-e51f312e5d42">
        <source>getQueues(_queueSet: CM_RTQueueSet io);
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
12 August 2011	cnwer1	Initial creation CCMS MES 1033

*/

vars

	queueObj : CM_RadioTelemetryQueue;
	queueItem	: CM_RadioTelemetryQueue;
	term : CM_Terminal;
begin
	_queueSet.clear;
	queueObj := self.myVoyage.myQueue;

	if queueObj = null then
		//Master Queue time
		term := self.myTerminal;	
		if term.radioTelemetry = null then
			return;
		endif;
		_queueSet.add(term.radioTelemetry.masterQueue);
		return;
	endif;
	//--------------
	//Return the Voyage queue
	//--------------
 	_queueSet.add(queueObj);
	//--------------
	//ALSO return any subCraneQueues
	//--------------
	if queueObj.allSubQueuesById.isEmpty then
		return;
	endif;

	foreach queueItem in queueObj.allSubQueuesById do
 		_queueSet.add(queueItem);
 	endforeach;

epilog

end;</source>
        <Parameter name="_queueSet" type="CM_RTQueueSet" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getROB" id="72590663-4726-4acc-aaa0-6f2c9a6964a8">
        <source>getROB(_tis : CM_TIArray input; _clear : Boolean; _ediProposed : Boolean);
/*
Purpose:  Has Remain On Board, double check has no discharge CC			
Date		Who		Reason
08 February 2012	cnwab1	Initial creation

15 Jan 2013	cnwrs1	Par30951 include Exports as ROBs for EDI Proposed 
04 Feb 2013	cnwrs1	Par 31119 include tranship for proposed deck plan
14 Oct 2022 navma1	Bug 54935: MSL - Roro planning - Slow on big decks/large vessels
*/
vars
	ti 		: CM_TrackedItem;
	imex	: Integer;
begin

	if _tis = null then
		return;
	endif;
	
	if _clear then
		_tis.clear();
	endif;
	
	if  self.myRORORequestDischarge = null then
		foreach	ti in self.allTrackedItems discreteLock do
			imex := ti.getImExStatus();						//14.10.2022 navma1 #54935
			
			if imex = TI_IMEX_STATUS_REMAINONBOARD  		// Remain On Board
			or imex = TI_IMEX_STATUS_TRANSHIP  				// TRANSHIP  31459
			// PAR 29467 we include imports this because when RoB are colour coded they change to imports, 
			// when the colour coding is erased they stay as imports
			or imex = TI_IMEX_STATUS_IMPORT then // Import 
				if _ediProposed and			 	//15 Jan 2013	cnwrs1	Par30951 dont include discharge Imports as ROBs for EDI Proposed 
				   ti.isToBeDischargedHere() then
				else
					_tis.add(ti);
				endif;
			endif;
			if _ediProposed and	//15 Jan 2013	cnwrs1	Par30951 include Exports as ROBs for EDI Proposed 
			   (imex = TI_IMEX_STATUS_EXPORT or
				ti.isTranshipInbound()		 or		//04 Feb 2013	cnwrs1	Par 31119 include tranship for proposed deck plan
				ti.isTranshipOutbound()) 	then	//04 Feb 2013	cnwrs1	Par 31119 include tranship for proposed deck plan
				_tis.add(ti);
			endif;
		endforeach;
	endif;
epilog

end;</source>
        <Parameter name="_tis" type="CM_TIArray" usage="input"/>
        <Parameter name="_clear" type="Boolean"/>
        <Parameter name="_ediProposed" type="Boolean"/>
    </JadeMethod>
