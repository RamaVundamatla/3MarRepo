    <JadeMethod name="setLogAreaGrades" id="b5648a31-efcc-454b-85a9-ae463388f8fa">
        <updating/>
        <source>setLogAreaGrades() protected, updating;

vars
	logGrade		: CM_LogGrade;
	tmpCodeGroup	: CM_CodesByCodeDict;
	code			: CM_Code;
	codeSet			: CM_CodeSet;
	logSpecies      : CM_Code;
	coll			: CM_CodesByCodeDict;
	
begin
	// Set multi group box.
	if self.isMixedRow then		
		create tmpCodeGroup transient;
		create coll transient;	//PAR 24006 30/04/2010
		
		if self.myCurrentLogRestriction = null then
			self.myViewer.setMultiGroupBox(self.multiThree, 'Grades', 'Log grades', tmpCodeGroup); 
			return;
		endif;
			
		codeSet := 	myCurrentLogRestriction.allLogGrades;
		foreach logSpecies in self.myCurrentLogRestriction.allLogSpecies do
			//coll := logSpecies.CM_LogSpecies.allLogGrades;	comented by PAR 24006 30/04/2010
			coll.clear;											//PAR 24006 30/04/2010
			logSpecies.CM_LogSpecies.allLogGrades.copy(coll);	//PAR 24006 30/04/2010
			self.getAvailableCodesForRestrict(coll,codeSet);
			foreach code in coll do
				tmpCodeGroup.addNoDuplicates(code,false);
			endforeach;
		endforeach;
			
		self.myViewer.setMultiGroupBox(self.multiThree, 'Grades', 'Log grades', tmpCodeGroup);  //26/08/2009 cnwdz2 PAR20519
	else
		if self.myLogSpecies &lt;&gt; null then
			// Load grade combo box.
			self.cmbLogGrade.setObjectAndSpecies(null, self.myLogSpecies);
			// If we have a valid restriction.
			if self.myCurrentLogRestriction &lt;&gt; null then
				// Get selected grade.
				logGrade := self.myCurrentLogRestriction.allLogGrades.first.CM_LogGrade;
				// Load combos.
				if self.myLogSpecies.allLogGrades.includes(logGrade) then 
//					if this grade valide for what is in species combo then carry on else cmbSpecies must have change so do nothing as they have current restrictions.  
					doLoadLogCombos(logGrade);	
				endif;
			endif;
		else
			self.shtThree.visible := false;
			resetTblInput1(false);
		endif;
	endif;
epilog
	delete tmpCodeGroup;
	delete coll;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setLogGroupBoxesByOperator" id="70458a70-b998-4101-bd1c-1160fbfff8df">
        <source>setLogGroupBoxesByOperator() protected;

vars
	tmpCodeGroup	: CM_CodesByCodeDict;
	code			: CM_Code;
	codeSet			: CM_CodeSet;
	operator 		: CM_Operator;
	coll	: CM_CodesByCodeDict;	
	operatorLogTypes : CM_LogTypeByCodeDict;
	operatorLogTreatments : CM_LogTreatmentsByCodeDict;
	operatorLogLengths : CM_LogLengthsByCode;
begin

	if self.isMixedRow then
		create tmpCodeGroup transient;
		create coll transient;
		
		if self.myCurrentLogRestriction &lt;&gt; null then 
			codeSet := 	self.myCurrentLogRestriction.allLogTypes;
		
			foreach operator in self.myCurrentLogRestriction.allOperators do
				coll.clear();
				//epr par 36720 31/8/15
				operatorLogTypes:=operator.getAllLogTypes();
				if operatorLogTypes = null then
					continue;
				endif;
				operatorLogTypes.copy(coll);
				
				self.getAvailableCodesForRestrict(coll,codeSet);
				// check not available for entry for Types
				foreach code in coll do
					tmpCodeGroup.addNoDuplicates(code,false);
				endforeach;
			endforeach;
		endif;
		self.myViewer.setMultiGroupBox(self.multiFour, 'Types', 'Log types',tmpCodeGroup); //26/08/2009 cnwdz2 PAR20519
		
		// check not available for entry for Treatments
		tmpCodeGroup.clear();
		if self.myCurrentLogRestriction &lt;&gt; null then 
			codeSet := 	myCurrentLogRestriction.allLogTreatments;
			foreach operator in self.myCurrentLogRestriction.allOperators do
				coll.clear();
				operatorLogTreatments:=operator.getAllLogTreatments();
				if operatorLogTreatments = null then
					continue;
				endif;
				operatorLogTreatments.copy(coll);		// cnwmc5 - 1 June 2016 - TFS 2063 - problem appeared to be copy paste issue, was using 'operatorLogTypes' 
				
				self.getAvailableCodesForRestrict(coll,codeSet);
				// check not available for entry for Types
				foreach code in coll do
					tmpCodeGroup.addNoDuplicates(code,false);
				endforeach;
			endforeach;	
		endif;
		self.myViewer.setMultiGroupBox(self.multiFive, 'Treatments', 'Log treatments', tmpCodeGroup);//26/08/2009 cnwdz2 PAR20519

		// check not available for entry for Lengths
		tmpCodeGroup.clear();
		if self.myCurrentLogRestriction &lt;&gt; null then 
			codeSet := 	myCurrentLogRestriction.allLogLengths;
			foreach operator in self.myCurrentLogRestriction.allOperators do
				coll.clear();
				operatorLogLengths:=operator.getAllLogLengths();
				if operatorLogLengths = null then
					continue;
				endif;
				operatorLogLengths.copy(coll);
				
				self.getAvailableCodesForRestrict(coll,codeSet);
				// check not available for entry for Types
				foreach code in coll do
					tmpCodeGroup.addNoDuplicates(code,false);
				endforeach;
			endforeach;
		endif;

		self.myViewer.setMultiGroupBox(self.multiSix, 'Lengths', 'Log lengths', tmpCodeGroup);//26/08/2009 cnwdz2 PAR20519
	endif;
	
epilog
	delete tmpCodeGroup;
	delete coll;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setMyDataClass" id="c487a53c-36d9-42cd-99b2-418971f19e8f">
        <updating/>
        <source>setMyDataClass() updating;
// ---------------------------------------------------------------------------
// Created:     30 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
begin

	if myViewer = null then
		self.myDataClass := CM_LogController;
	else
		self.myDataClass := myViewer.getDataClass();
	endif;
	self.useTblDataContextMenu := app.myAA.isAnAuditedClass(self.myDataClass);	
	
	
end;</source>
    </JadeMethod>
    <JadeMethod name="setOperators" id="8349bbbf-d58c-40c1-8a19-5bea73aff8a7">
        <updating/>
        <source>setOperators() protected, updating;
// 26/08/2009	cnwdz2	PAR20519
// 22/09/2014	cnwdap1	PAR #34908 exclude operators not available for entry
vars
	operator	    : CM_Operator;
	allOperators : CM_OperatorByCodeDict;
begin

	create allOperators transient;
	
	if self.isMixedRow then	
		//foreach operator in app.myRoot.allOperators do											// PAR #34908
		foreach operator in app.myRoot.allOperators where not operator.isNotAvailableForEntry do	// PAR #34908
			if operator.allCodeGroups[CodeGroup_LogSpecs] &lt;&gt; null then
				allOperators.add(operator);
			endif;
		endforeach;
		self.myViewer.setMultiGroupBox(self.multiOne, 'Operators', 'Operators', allOperators); //26/08/2009 cnwdz2 PAR20519
	else
		// Get operator.  //09/10/2009 cnwdz2 par20866	
		self.myOperator := self.myCurrentLogRestriction.allOperators.first;
		if self.myOperator &lt;&gt; null then
			self.tblInput1.setValueByName(ETRow_Operator, self.myOperator.code);
			self.cmbOperator.setObject(self.myOperator);
		else
			self.tblInput1.setValueByName(ETRow_Operator, null);
		endif;
	endif;
	
epilog
	delete allOperators;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setPreviousControllerFromId" id="ad0954cd-6638-434e-8c61-a198db406c08">
        <source>setPreviousControllerFromId(_label : String io) protected;

vars

begin

	// Convert label to upper case.
	_label := _label.toUpper;
	
	if self.myCurrentLogArea &lt;&gt; null and self.myCurrentLogArea.isMarkedUp then
		// Can we find this string in our starting label combo.
		if self.cmbStartingLabel.findString(1, _label) &lt;&gt; -1 then
			self.tblInput1.setValueByName(ETRow_StartRow, _label);
			self.cmbStartingLabel.text := _label;
			// Get previous data based on distance.
			doGetPreviousData(_label,CM_RowArea.SEARCH_DISTANCE);
		else
			// Get previous data based on alphabetical search.
			self.tblInput1.setValueByName(ETRow_StartRow, null);
			doGetPreviousData(_label,CM_RowArea.SEARCH_ALPHABETICAL);
		endif;	
	else
		// Just get previous data based on alphabetical search.
		doGetPreviousData(_label,CM_RowArea.SEARCH_ALPHABETICAL);
	endif;
		
end;</source>
        <access>protected</access>
        <Parameter name="_label" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="setSelected" id="c3a95168-7ba9-4c87-a955-4d9c8aa92ff7">
        <source>setSelected(_locationRestriction : CM_LocationRestriction; _clear : Boolean) protected;

vars

begin

	if _clear then
		//	multiOther.setSelected
		self.multiOne.setSelected(null);
		self.multiTwo.setSelected(null);
		self.multiThree.setSelected(null);
		self.multiFour.setSelected(null);
		self.multiFive.setSelected(null);
		self.multiSix.setSelected(null);
		self.multiSeven.setSelected(null);
		self.multiEight.setSelected(null);
	else
		self.myViewer.setSelected(_locationRestriction, self.multiOne,self.multiTwo,self.multiThree,self.multiFour,
								  self.multiFive,self.multiSix,self.multiSeven,self.multiEight);
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="_locationRestriction" type="CM_LocationRestriction"/>
        <Parameter name="_clear" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setSpecies" id="82a74cb3-39e8-4765-bd55-6147bdc51793">
        <updating/>
        <source>setSpecies() protected, updating;
//26/08/2009 cnwdz2 PAR20519
vars
	operatorCodes,
	coll,
	tmpColl		: CM_CodesByCodeDict;
	code		: CM_Code;
	codeSet		: CM_CodeSet;
	operator	: CM_Operator;
	
begin

	self.allCodes.clear;
	self.myLogSpecies := null;
	
	//if self.myCurrentLogRestriction = null and self.myOperator &lt;&gt; null then
	if not self.isMixedRow and self.myOperator &lt;&gt; null then
		// Get species for this operator.
		coll := self.myOperator.getAllLogSpecies();
		if coll = null then
			app.msgBox('Log code group has not been selected for this operator','Error',0);
			return;
		endif;
		
		coll.copy(self.allCodes);
		self.cmbLogSpecies.setObjectAndOperator(null,self.myOperator);
		if self.myCurrentLogRestriction &lt;&gt; null then
			// Get correct species from restriction.
			self.myLogSpecies := self.myCurrentLogRestriction.allLogSpecies.first.CM_LogSpecies;
			if self.myLogSpecies &lt;&gt; null then
				self.tblInput1.setValueByName(ETRow_LogSpecies, self.myLogSpecies.code);
		
				self.cmbLogSpecies.setObject(self.myLogSpecies);
			endif;
		else
			self.cmbLogSpecies.listObject := null;
			self.tblInput1.setValueByName(ETRow_LogSpecies, null);
		endif;
		// Use found species to load grades and other specs.
		setLogAreaGrades();
		setLogGroupBoxesByOperator();
		
	endif;
	
	if self.isMixedRow then
		if self.myCurrentLogRestriction &lt;&gt; null then
			create tmpColl transient;	// #24340 01/06/2010
			codeSet	:= self.myCurrentLogRestriction.allLogSpecies;
			foreach operator in self.myCurrentLogRestriction.allOperators do
				// Get species for this operator.
				//epr par 36720 31/8/15
				operatorCodes := operator.getAllLogSpecies(); //commented by #24340 01/06/2010
				if operatorCodes = null then
					continue;
				endif;
				tmpColl.clear;		//#24340 01/06/2010
				operatorCodes.copy(tmpColl);

				self.getAvailableCodesForRestrict(tmpColl,codeSet);
				foreach code in tmpColl do
					self.allCodes.addNoDuplicates(code,false);
				endforeach;
			endforeach;
		endif;
		self.myViewer.setMultiGroupBox(self.multiTwo, 'Species', 'Log species', self.allCodes);
		// Use found species to load grades and other specs.
		self.setLogAreaGrades();
		self.setLogGroupBoxesByOperator();
	endif;
	
epilog
	delete tmpColl;	//#24340 01/06/2010
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setTblInput1ViewForLogs" id="6acc24ab-7617-430f-9899-6607ac76e990">
        <source>setTblInput1ViewForLogs() protected;

vars
	splitValue		: Integer;
begin
	splitValue := self.tblInput1.getValueByName(ETRow_RowSplit).Integer;
	
	
	if self.isMixedRow then
		self.tblInput1.showHideRowsByViewName('viewLogMixed', CM_EntryTable.ShowHideRows, false); 
		
		if splitValue &lt;&gt; 1 then
			self.tblInput1.hideRowByName(ETRow_RowToSplit, false);
		endif;
	else
		self.tblInput1.showHideRowsByViewName('viewLog', CM_EntryTable.ShowHideRows, false); 
			
		if splitValue &lt;&gt; 1 then
			self.tblInput1.hideRowByName(ETRow_RowToSplit, false);
		endif;
	endif;

	self.tblInput1.adjustHeight(1000);

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setTransportMode" id="80a9a4db-b1e3-4017-b8e4-4fa7e7238942">
        <source>setTransportMode(_preset : Integer)  protected;

vars

	value 	: Integer;
	display	: String;

begin


	if self.myCurrentLogRestriction &lt;&gt; null and self.myCurrentLogRestriction.transportMode &lt;&gt; 0 then
		value := self.myCurrentLogRestriction.transportMode;
	else
		value := _preset;
	endif;
	self.tblInput1.setValueByName(ETRow_TransportMode, value);
	if value = 1 then
		display := '1' &amp; Tab &amp; 'Road';
	elseif value = 2 then
		display := '2' &amp; Tab &amp; 'Rail';
	elseif value =3 then
		display := '3' &amp; Tab &amp; 'Both';
	endif;
	self.cmbTransport.text := display;
	
end;</source>
        <access>protected</access>
        <Parameter name="_preset" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setVisibility" id="2ac43a66-af8c-4336-8d4f-fbf3a567b9e3">
        <source>setVisibility(_new : Boolean) protected;

vars

	view 	: String;

begin

	self.shtTblInput1.visible := false;
	if self.myCurrentLogRow &lt;&gt; null or _new then
		self.shtTblInput1.visible := true;
		self.tblInput1.adjustHeight(1000);
		self.tblInput1.optimiseHeadingColumn();
		self.tblInput1.cnEcResizeContents();
	endif;
	if  self.mode &lt;&gt; self.Mode_Add and self.mode &lt;&gt; self.Mode_Update then
		self.doEnableControls(false);
	endif;
	self.tblInput1.setFocus;
end;</source>
        <access>protected</access>
        <Parameter name="_new" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="728340b7-1a60-4344-98b4-e007903377fa">
        <updating/>
        <source>setupForm() updating;
// ---------------------------------------------------------------------------
// Created:		September  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	rowIdx : Integer;
begin
	inheritMethod();

	
	if (not app.getMyUser.canDo(self.myTerminal, self.permissionMaint)) then
		self.allowArchive := false;
	endif;

	if  self.myCurrentObject &lt;&gt; null then
		if self.tblData.findObjectInRow(self.myCurrentObject,rowIdx) then
			self.tblData.row := rowIdx;
			self.tblData.refresh();
			if self.myCurrentObject.isKindOf(CM_LocationsController) then
				self.showThumbnailData(self.myCurrentObject.CM_LocationsController);
				self.tblThumb.cnAdjustColumnWidths();
			endif;
		endif;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="showFilterViewForStatus" id="f282dd37-e14a-40a6-b2e7-ce9cd0240a8b">
        <updating/>
        <source>showFilterViewForStatus() updating;
// ---------------------------------------------------------------------------
// Created:     18 November 2002		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	entDef			: EntTableDef;
	entView			: EntTableView;
	table			: CM_EntryTable;
	rowHeight		: Integer;
begin
	self.filterStatus := self.cmbFiltStatus.text;
	table := self.tblSearch;
	entDef := table.myEntTableDef;
	if entDef = null then
		return;
	endif;
	rowHeight := table.accessRow(1).height.Integer;
	if self.filterStatus = Status_Archived then
		entView := entDef.allEntTableViews['rowSearchArchived'];
	elseif self.filterStatus = Status_Empty then
		entView := entDef.allEntTableViews['rowSearchEmpty'];
	else
		entView := entDef.allEntTableViews['rowSearchNormal'];
	endif;
	
	table.showHideRowsByView(entView, CM_EntryTable.ShowHideRows, false);
	
	table.cnEcResizeContents();
	
	// Par 9974 - Resize searcher tdepending on table size
	if not self.isSearcherFloating then // if already docked then 
		self.searcherDockUndock(true); // use exsisting code : (Re-dock Searcher)
	else
		self.tblSearch.adjustHeight(self.clientHeight); // is floating so just resize frm
		self.frmSearch.height := tblSearch.height + tblSearch.top + 15;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="showThumbnailData" id="0fa766c4-402f-40a4-ae37-02d3bfacb7da">
        <updating/>
        <source>showThumbnailData(obj: CM_LocationsController) updating;
// ---------------------------------------------------------------------------
// Created:     30 March 2001 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	soh			: CM_SOHLocation;
	allocation	: CM_StockOrderAllocation;
	idx			: Integer;
	str			: String;
	totPcsIdx	: Integer;
	mixedRow	: Boolean;
	pieces		: Integer;
	totalPieces	: Integer;
	stkOrdLine	: CM_StockOrderLine;
	stkOrdSum	: CM_StockOrderSummary;
	failedDAC  :CM_DataAccessController;

begin
	tblThumb.rows := 0;

	self.showThumbnailForDef(ETDef_LogRowThumbnail, obj);
	
	tblThumb.addItem(null);
	idx := tblThumb.addItem('Totals');
	tblThumb.accessCell(idx, 1).fontBold := true;
	totPcsIdx := tblThumb.addItem('Pieces'); // &amp; Tab &amp; obj.numTIs.String);
//	tblThumb.addItem('Volume' &amp; Tab &amp; obj.jasVolumeString.String);

	if obj.allProductLocations.isEmpty then
		// Hmm....
		tblThumb.accessCell(totPcsIdx, 2).text := obj.numTIs.String;
	else
		foreach soh in obj.allProductLocations do
			if soh.allTrackedItems.isEmpty and
			   soh.allStockOrderAllocations.isEmpty then
				continue;
			endif;
			if not soh.canUserAccessSelf(null, failedDAC, app.myPassport) then
				mixedRow := true;
				continue;
			endif;
			tblThumb.addItem(null);
			idx :=  tblThumb.addItem('Specs' &amp; Tab &amp; soh.myProduct.getDisplayStringForAttribute(ETRow_OperatorCode, true) &amp; ':' &amp; soh.myProduct.code);
			tblThumb.accessRow(idx).fontBold := true;
			pieces := soh.allTrackedItems.size;
			totalPieces := totalPieces + pieces;
			tblThumb.addItem('Pieces' &amp; Tab &amp; pieces.String);
			tblThumb.addItem('Volume' &amp; Tab &amp; soh.currentVolume.jasVolumeString);
			tblThumb.addItem('Weight (kgs)' &amp; Tab &amp; soh.currentWeightKgs.String);		
	
			if (not soh.allStockOrderAllocations.isEmpty) then
				str := 'Allocated to:' &amp; Tab;
				foreach allocation in soh.allStockOrderAllocations do
					if (not allocation.isKindOf(CM_StockOrderSummaryAlloc)) then
						continue;
					endif;
					str := str &amp; 
						'Voyage ' &amp; allocation.myStockOrderHeader.myVoyage.code &amp; '  ( ' &amp;
						allocation.getAllocQuantityDisplayStr &amp; ')';

					tblThumb.addItem(str);
					
					// par 13318 Mohammad 26/2/2007
					stkOrdSum := allocation.CM_StockOrderSummaryAlloc.myStockOrderSummary;	
					foreach stkOrdLine in stkOrdSum.allStockOrderLines do
						str := Tab &amp; '    Lot ' &amp; stkOrdLine.CM_LogStockOrderLine.lotNo &amp; '  (' &amp;
							stkOrdLine.CM_LogStockOrderLine.reqdQuantity.asStringJMTWithPrecision($CM_Decimal3LeadingZero.decimalPlaces, true) &amp; ')';
						tblThumb.addItem(str);
					endforeach;
			
					str := Tab;
				endforeach;
			endif;
		endforeach;
		
		tblThumb.accessCell(totPcsIdx, 2).text := totalPieces.String;
	endif;
	
	if mixedRow then
		tblThumb.addItemAt("Warning: row contains items you do not have access to view", totPcsIdx+1);
		tblThumb.accessRow(totPcsIdx+1).foreColor := Red;
		tblThumb.accessCell(totPcsIdx+1, 1).mergeCells := Table.MergeCells_Merge;
	endif;
	
	self.setNavigatorHeading(obj.getID);

	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.btnDeleteTV.enabled:= false;
		self.btnEditTV.enabled:= false;
		self.btnNewTV.enabled:= false;
		
	endif;
	
end;</source>
        <Parameter name="obj" type="CM_LocationsController"/>
    </JadeMethod>
    <JadeMethod name="tblInput1_cellInputReady" id="e582c357-af71-4328-ac5f-31ee806aa05f">
        <controlMethod name="Table::cellInputReady"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblInput1_cellInputReady(table: Table; inputControl: Control input; cleft: Real io; ctop: Real io; cwidth: Real io; cheight: Real io) updating;

vars

begin

	if inputControl.isKindOf(ComboBox) then
//		inputControl.ComboBox.text := table.text;
	endif;

end;</source>
        <Parameter name="table" type="Table"/>
