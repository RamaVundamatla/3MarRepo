    <ImplicitInverseRef name="allRequestTypes" id="cffb4fa4-cfc2-4c98-b19b-c2d230b4c2fb">
        <memberTypeInverse/>
        <type name="WS_RequestTypeArray"/>
    </ImplicitInverseRef>
    <PrimAttribute name="event" id="4ff81b06-cf25-4da5-9add-c9b807a7cf21">
        <type name="String"/>
        <access>readonly</access>
        <text>A pipe (|) separated list of all requests to be added. (E.g. Add: Requires Base Wash|Add: Requires Internal Clean).</text>
    </PrimAttribute>
    <JadeMethod name="delete" id="ea3857fd-cc26-476f-9afd-eb64e486d18f">
        <updating/>
        <source>delete() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21 July 2008	cnwkpd1	PAR #17554 - Development of new RIA Web Service application

*/

vars

begin
	self.allRequestTypes.purge();
	

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="event" id="b4c0da73-500a-422d-a6d6-e3ca3b547dc8">
        <methodInvocation>mapping</methodInvocation>
        <source>event(set : Boolean; _value : String io) mapping;

/*

Purpose: Mapping method to create event request objects			

Parameters:			

Return Value:		


Date		Who		Reason
28 August 2008	cnwcrs2	Initial creation
30 Sep 2008	cnwkao1	reworked
*/

vars
	requestTypes: StringArray;
	str:		String;
	reqType:	WS_RequestType;
begin

	if set then
		create requestTypes transient;
		_value.getTokensForDelimiter("|", requestTypes);
		foreach str in requestTypes do
			create reqType transient;
			reqType.description := str;
			allRequestTypes.add(reqType);
		endforeach;	
	endif;	
epilog
	delete requestTypes;	
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getActivityType" id="b92ed61b-1152-4b98-b7cd-d18d8361c123">
        <source>getActivityType() : String protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 September 2008	cnwkao1	Initial creation

*/

vars
	retVal : String;
begin
	if not self.allRequestTypes.isEmpty() then
		retVal := self.allRequestTypes.first().description;
	endif;
	return retVal;
epilog

end;</source>
        <access>protected</access>
        <ReturnType type="String"/>
    </JadeMethod>
