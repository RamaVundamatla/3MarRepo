<Class name="CM_QTiSiteLookupProperty" id="4505e0a9-3fed-4a36-bd98-f19e1c36c54f">
    <superclass name="CM_QIntegerLookupProperty"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
