    <JadeMethod name="validateForDelete" id="9ee4723c-0b96-4bb0-b22a-30f88a569e2c">
        <source>validateForDelete();
// ---------------------------------------------------------------------------
// Created:		December 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

	theID : String;
begin
	if self.type = TA_TYPE_COU_STORE_AREA then
		theID := app.myPassport.myTerminal.getConfig(DefCOUArea).String;
		if theID = self.id then
			app.raiseCMException3(ERR_USED_IN_CONFIG,"Block Stack", self.id,"Terminal " &amp; app.myPassport.myTerminal.code,null, null);
			return;
		endif;
	endif;
	
	inheritMethod();

end;</source>
    </JadeMethod>
    <JadeMethod name="yaFindLCs" id="8ebb66d8-65b1-438e-9673-5d28e2bdcdca">
        <source>yaFindLCs(pFromId: String; pToId: String; pAllControllersObj: CM_LCArray input);
// --------------------------------------------------------------------------------
// Created:		14 April 2005 by cnwdad1:2
//
// Purpose:		Refer to superclass implementation.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	controllerObj	: CM_LocationsController;
	
begin
	controllerObj	:=	self.myLocationsController;
	
	// For Block Stacks, we won't bother checking for a sub-Block Stack.
	
	if controllerObj &lt;&gt; null 
	and CM_YardController.hasInstance(controllerObj)
	then
		pAllControllersObj.add(controllerObj);
	endif;
end;</source>
        <Parameter name="pFromId" type="String"/>
        <Parameter name="pToId" type="String"/>
        <Parameter name="pAllControllersObj" type="CM_LCArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="yaGetBlockType" id="95a04c98-353b-4ad7-a842-95e710ac778d">
        <source>yaGetBlockType(): Class;
// --------------------------------------------------------------------------------
// Created:		06 May 2005 by cnwdad1
//
// Purpose:		Refer to superclass implementation.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	
	//jlier1 TFS 54675 18/10/22
	if self.type = TA_TYPE_MAFI then
		return CM_YABlockMAFI;
	else

		return CM_YABlockBlock;
	endif;
end;</source>
        <ReturnType type="Class"/>
    </JadeMethod>
</Class>
