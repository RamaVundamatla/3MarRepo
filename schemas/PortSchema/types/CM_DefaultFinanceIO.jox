    <DbClassMap file="invoice"/>
    <JadeMethod name="createExportFiles" id="95b43a39-30a0-4146-8dcb-77a9acb48db4">
        <source>createExportFiles(fileNameBase: String io);

vars
	headerFile, detailsFile: File;
	today: Date;
	dateStr: String;
	path: String;
	i: Integer;
	lEexportPath:    String;
begin
	
	create headerFile;
	create detailsFile;
	headerFile.allowReplace := false;
	detailsFile.allowReplace := false;
	headerFile.kind  := File.Kind_Unknown_Text; // 3/3/16  cnwns1 PAR 36286 unicode version
	detailsFile.kind := File.Kind_Unknown_Text; // 3/3/16  cnwns1 PAR 36286 unicode version
	headerFile.mode  := File.Mode_Input;
	detailsFile.mode := File.Mode_Input;

	lEexportPath := self.getExportFileNameBase(true);
	if lEexportPath[lEexportPath.length:1] = '\' then
		path := lEexportPath;
	else
		path := lEexportPath &amp; "\";
	endif;

	dateStr := today.userFormat($CM_YearFormat);

	i := 1;
	headerFile.fileName := path &amp; "InvHead" &amp; dateStr &amp; "_" &amp; i.String&amp; ".txt";
	while true do
		// next line will raise an exception if file exists hence exception handler
		// above
		// headerFile.open;
		if headerFile.isAvailable then
			i := i + 1;
			headerFile.fileName := path &amp; "InvHead" &amp; dateStr &amp; "_" &amp; i.String&amp; ".txt";
		else
			break;
		endif;
	endwhile;

	headerFile.mode := File.Mode_Output;
	headerFile.open;
	headerFile.close;

	detailsFile.mode := File.Mode_Output;
	detailsFile.fileName := path &amp; "InvDetl" &amp; dateStr &amp; "_" &amp; i.String&amp; ".txt";
	detailsFile.open;
	detailsFile.close;

	fileNameBase := dateStr &amp; "_" &amp; i.String;
epilog
	delete headerFile;
	delete detailsFile;
end;</source>
        <Parameter name="fileNameBase" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="export" id="04e52464-0cb8-4f55-8821-aa1328f5c469">
        <updating/>
        <source>export(invoice: CM_Invoice input) updating;

vars
begin
	self.exportCSV(invoice);
epilog
end;</source>
        <Parameter name="invoice" type="CM_Invoice" usage="input"/>
    </JadeMethod>
    <JadeMethod name="exportCSV" id="fabae98c-62a3-4091-a299-712b43adf35f">
        <updating/>
        <source>exportCSV(invoice: CM_Invoice input) updating;

vars
	fileNameBase:  String;
	fileEx:        FileException;
begin
	on FileException do self.fileExceptionHandler(fileEx);

	if invoice = null then
		app.setContinueCMExceptions(false);
		app.raiseCMException(VB_USER_CANCELED_TRANS, null, null);
		return;
	else
		fileNameBase := "";
		createExportFiles(fileNameBase);
		exportToFileCSV(invoice, fileNameBase);
	endif;

epilog

end;</source>
        <Parameter name="invoice" type="CM_Invoice" usage="input"/>
    </JadeMethod>
    <JadeMethod name="exportToFile" id="6cdc7fcb-ae32-4ff7-bc83-23da812954df">
        <source>exportToFile(invoice: CM_Invoice input; fileNameBase: String);
// ---------------------------------------------------------------------------
// Created:		27 September 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
begin
	self.exportToFileCSV(invoice, fileNameBase);

end;</source>
        <Parameter name="invoice" type="CM_Invoice" usage="input"/>
        <Parameter name="fileNameBase" type="String"/>
    </JadeMethod>
    <JadeMethod name="exportToFileCSV" id="c2c74880-aa8a-4018-8d35-5205c5381349">
        <source>exportToFileCSV(invoice: CM_Invoice input; fileNameBase: String);
//
// 27 Oct 2016	cnwrs1	TFS allow this directory to be assigned %MiscDir% insrtead of D:\qnsPjmt\server\c_misc
// 22 Jul 2019	cnwma1	ChangeRequest 45577: ASPA - JMT Interface to AR Oracle
vars
	fs:          CMDFileSave;
	today:       Date;
	headerFile:  File;
	linesFile:   File;
	path:        String;
	i:           Integer;
	fileEx:      FileException;
	fFolder : FileFolder;
	message : String;
begin
	on FileException do self.fileExceptionHandler(fileEx);

	create fFolder;
	fFolder.fileName := self.exportPath.normaliseDirectory().substituteDirectory();
	if not fFolder.isAvailable then
		path := self.exportPath.normaliseDirectory().substituteDirectory();
		message := app.getErrorString2(Expor_path_does_not_exist_cann,path,invoice.sequenceNum.String);
		app.msgBox(message,app.getErrorString(Export_error), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
		return;
	endif;


	create headerFile;
	create linesFile;
	headerFile.allowReplace := true;
	headerFile.mode := File.Mode_Output;	// 25/2/16 cnwmp6 PAR 36286 unicode version
	linesFile.allowReplace := true;
	linesFile.mode := File.Mode_Output;	// 25/2/16 cnwmp6 PAR 36286 unicode version

	// who called us?
	if fileNameBase[2:2] = ":\" or fileNameBase[1:2] = "\\" then
		// we have been called with a fully specified file
		headerFile.fileName := fileNameBase;
		i := fileNameBase.length;
		while true do
			if fileNameBase[i:1] = '\' then
				break;
			else
				i := i - 1;
			endif;
		endwhile;
		create fs;
		fs.dialogTitle := "Specify file for details export";
		fs.resetCurrentPath := true;
		fs.initDir := fileNameBase[1: i];
		fs.fileName := "InvDetl" &amp; today.userFormat($CM_YearFormat) &amp; "_" &amp; invoice.sequenceNum.String &amp; ".txt";
		if fs.open = 0 then
			linesFile.fileName := fs.fileName;
		else
			return;
		endif;
	else
		// we have been called by export
		path := self.getExportFileNameBase(true);
		
		 if path[path.length:1] &lt;&gt; "\" then
		 	path := path &amp; "\";
		 endif;
		headerFile.allowCreate := false;
		linesFile.allowCreate := false;
		headerFile.fileName := path &amp; "InvHead" &amp; fileNameBase &amp; ".txt";
		linesFile.fileName := path &amp; "InvDetl" &amp; fileNameBase &amp; ".txt";
	endif;

	headerFile.open;
	linesFile.open;

	writeHeaderToFile(headerFile, invoice);
	writeInvoiceLinesToFile(linesFile, invoice);

	invoice.incrementExportCount(false);		//22.07.2019 cnwma1 TFS #45577
epilog
	delete fFolder;
	delete headerFile;
	delete linesFile;
end;</source>
        <Parameter name="invoice" type="CM_Invoice" usage="input"/>
        <Parameter name="fileNameBase" type="String"/>
    </JadeMethod>
    <JadeMethod name="exportToFileXML" id="b52101d1-f5ea-48fe-aafc-662b60325e82">
        <source>exportToFileXML(invoice: CM_Invoice input; fileNameBase: String);
//22 July 2019	cnwma1	ChangeRequest 45577: ASPA - JMT Interface to AR Oracle
constants
	XMLTAG_XML = '&lt;?xml version="1.0" encoding="utf-8" ?&gt;';
	XMLTAG_INV = "Invoice";
	XMLTAG_HEADER = "InvoiceHeader";
	XMLTAG_SEQ = "No.";
	XMLTAG_DEBTOR = "Sell-toCustomerNo.";
	XMLTAG_DATE = "DocumentDate";
	XMLTAG_CURR = "CurrencyCode";
	XMLTAG_DETAIL = "InvoiceDetail";
	XMLTAG_ITEM = "Item";
	XMLTAG_QTY = "L.p.";
	XMLTAG_SERVICE = "Name";
	XMLTAG_AMT = "Amount";

vars
	file		: File;
	path, 
	detailXML,
	headerXML 	: String;
	pos			: Integer;
	fileEx		: FileException;
	fFolder 	: FileFolder;
	message 	: String;
begin
	on FileException do self.fileExceptionHandler(fileEx);

	pos := fileNameBase.reversePos("\");
	path := fileNameBase;
	if pos &gt; 0 then
		path := fileNameBase[1:pos];
	endif;
	create fFolder;
	fFolder.fileName := path;
	if not fFolder.isAvailable then
		message := app.getErrorString2(Expor_path_does_not_exist_cann,path,invoice.sequenceNum.String);
		app.msgBox(message,app.getErrorString(Export_error), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
		return;
	endif;

	create file;
	file.mode := File.Mode_Output;	// 25/2/16 cnwmp6 PAR 36286 unicode version
	file.fileName := fileNameBase; 
	file.allowReplace := true;
	
	headerXML := self.getInvoiceHeaderXML(invoice);
	detailXML := self.getInvoiceLinesXML(invoice);
	 	
	file.writeLine(XMLTAG_XML);
	file.writeLine(app.formatAsXML(XMLTAG_INV,headerXML &amp; CrLf &amp; detailXML));
	file.close;


	invoice.incrementExportCount(false);		//22.07.2019 cnwma1 TFS #45577
	
	global.beep;
epilog
	delete fFolder;
	delete file;
	
end;</source>
        <Parameter name="invoice" type="CM_Invoice" usage="input"/>
        <Parameter name="fileNameBase" type="String"/>
    </JadeMethod>
    <JadeMethod name="exportXML" id="0b0e7bef-e5f3-40a3-8f89-a5f4495a21cb">
        <updating/>
        <source>exportXML(_invoice: CM_Invoice input) updating;
// ---------------------------------------------------------------------------
// Created:		02 July 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// 27 Oct 2016	cnwrs1	TFS allow this directory to be assigned %MiscDir% insrtead of D:\qnsPjmt\server\c_misc
// 22 Jul 2019	cnwma1	ChangeRequest 45577: ASPA - JMT Interface to AR Oracle
constants
	XMLTAG_XML = '&lt;?xml version="1.0" encoding="utf-8" ?&gt;';
	XMLTAG_INV = "Invoice";
	XMLTAG_HEADER = "InvoiceHeader";
	XMLTAG_SEQ = "No.";
	XMLTAG_DEBTOR = "Sell-toCustomerNo.";
	XMLTAG_DATE = "DocumentDate";
	XMLTAG_CURR = "CurrencyCode";
	XMLTAG_DETAIL = "InvoiceDetail";
	XMLTAG_ITEM = "Item";
	XMLTAG_QTY = "L.p.";
	XMLTAG_SERVICE = "Name";
	XMLTAG_AMT = "Amount";

vars	
	file,
	tmpFile 	: File;
	path, 
	detailXML, 
	headerXML 	: String;
	fFolder 	: FileFolder;
	message 	: String;
begin
	path := self.exportPath.normaliseDirectory().substituteDirectory();
	create fFolder;
	fFolder.fileName := path;
	if not fFolder.isAvailable then
		message := app.getErrorString2(Expor_path_does_not_exist_cann,path,_invoice.sequenceNum.String);
		app.msgBox(message,app.getErrorString(Export_error), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);			
		return;
	endif;

	create file;
	file.mode := File.Mode_Output;	// 25/2/16 cnwmp6 PAR 36286 unicode version
	file.fileName := path &amp; _invoice.sequenceNum.String &amp; ".xml"; 
	file.allowReplace := true;
	
	headerXML := self.getInvoiceHeaderXML(_invoice);
	detailXML := self.getInvoiceLinesXML(_invoice);
	 	
	file.writeLine(XMLTAG_XML);
	file.writeLine(app.formatAsXML(XMLTAG_INV, headerXML &amp; CrLf &amp; detailXML));
	file.close;

	_invoice.incrementExportCount(false);	//22.07.2019 cnwma1 TFS #45577
epilog
	delete fFolder;
	delete tmpFile;
	delete file;
	

end;</source>
        <Parameter name="_invoice" type="CM_Invoice" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getExternalCreditNumber" id="380c287a-8daa-400f-b185-e7cf0014d80d">
        <source>getExternalCreditNumber(_cashCredit : CM_CashCredit) : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 April 2018	jlgrh7	Initial creation

*/

vars
	sequenceYear : String;
	sequenceKey :  String;
	sequenceNum : Integer;
	externalNumber : String;
begin
	sequenceYear := _cashCredit.dateTime.date.year.padLeadingWith('0', 4);
	sequenceKey := SN_CashCredit &amp; sequenceYear[3:2];	// last 2 digits
	sequenceNum := _cashCredit.myBank.getSeqNum(sequenceKey);
	externalNumber := "JMT/CN/" &amp; sequenceNum.padLeadingWith('0', 6) &amp; "/" &amp; sequenceYear;
	return externalNumber;
epilog

end;</source>
        <Parameter name="_cashCredit" type="CM_CashCredit"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getExternalReciptNumber" id="92bba83d-6821-463b-9892-3d05c3d2c870">
        <source>getExternalReciptNumber(_cashReceipt: CM_CashReceipt): String;

/*
Purpose:			
Parameters:			
Return Value:		
Date		Who		Reason
27 April 2018	jlgrh7	TFS38181 PKT - Report Fields Not Working
*/

vars
	sequenceNumber : String;
	externalNumber  : String;
	terminalCode : String;
	terminal : CM_Terminal;
	bank : CM_Bank;
begin
	bank := _cashReceipt.myBank;
	
	sequenceNumber := bank.getSeqNum(SN_CashReceipt).String;
	terminal := bank.getMyTerminal();
	
	if terminal &lt;&gt; null then
		terminalCode := terminal.code;
	endif;
	externalNumber := 	terminalCode &amp; " " &amp; sequenceNumber;
	return externalNumber;
epilog

end;</source>
        <Parameter name="_cashReceipt" type="CM_CashReceipt"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getInvoiceHeaderXML" id="c4049417-2e1f-4f5e-b4dc-b07428b0f349">
        <source>getInvoiceHeaderXML(_theInvoice : CM_Invoice) : String;
// ---------------------------------------------------------------------------
// Created:		April 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
constants
	XMLTAG_XML = '&lt;?xml version="1.0" encoding="utf-8" ?&gt;';
	XMLTAG_INV = "Invoice";
	XMLTAG_HEADER = "InvoiceHeader";
	XMLTAG_SEQ = "HeaderNo";
	XMLTAG_DEBTOR = "CustomerNo";
	XMLTAG_DATE = "DocumentDate";
	XMLTAG_DESC = "DocumentDesc"; // PAR 21945
	XMLTAG_CURR = "CurrencyCode";
	XMLTAG_DETAIL = "InvoiceDetail";
	XMLTAG_ITEM = "Item";
	XMLTAG_QTY = "L.p.";
	XMLTAG_SERVICE = "Name";
	XMLTAG_AMT = "Amount";
	DELIMITER = ",";


vars
	item, output, invDate : String;
	invL : CM_InvoiceLine; // PAR 18405
begin

	//invL := _theInvoice.invoiceLines.last;
	invL := _theInvoice.invoiceLinesByDateTime.last;		// 24241 get latest transaction by date not sequence number
	if invL &lt;&gt; null then // PAR 18405
		invDate := invL.chargeTime.Date.day.String &amp; "-" &amp; invL.chargeTime.Date.month.padLeadingWith("0",2) &amp; "-" &amp; invL.chargeTime.Date.year.padLeadingWith("0",2); // PAR 18405
	else // PAR 18405
//		invDate := _theInvoice.postedDT.Date.year.String &amp; "-" &amp; _theInvoice.postedDT.Date.month.padLeadingWith("0",2) &amp; "-" &amp; _theInvoice.postedDT.Date.day.padLeadingWith("0",2);
		invDate := _theInvoice.postedDT.Date.day.String &amp; "-" &amp; _theInvoice.postedDT.Date.month.padLeadingWith("0",2) &amp; "-" &amp; _theInvoice.postedDT.Date.year.padLeadingWith("0",2);
	endif;
	
	item := app.formatAsXML(XMLTAG_SEQ,_theInvoice.sequenceNum.padLeadingWith("0",6))
//			&amp; app.formatAsXML(XMLTAG_DEBTOR, _theInvoice.debtor.name) // PAR 18405
			&amp; app.formatAsXML(XMLTAG_DEBTOR, _theInvoice.debtor.decfinName) // PAR 18405
			&amp; app.formatAsXML(XMLTAG_DATE,invDate)
			&amp; app.formatAsXML(XMLTAG_CURR,_theInvoice.debtor.getCurrency())
			&amp; app.formatAsXML(XMLTAG_DESC,_theInvoice.invoiceType.description) // PAR 21945
			;

	output := app.formatAsXML(XMLTAG_HEADER,item);
	
	return output;
epilog
end;</source>
        <Parameter name="_theInvoice" type="CM_Invoice"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getInvoiceLinesXML" id="6b61a025-b7b1-4ace-a624-3a6f6cbb57ee">
        <source>getInvoiceLinesXML(_theInvoice : CM_Invoice) : String;
// ---------------------------------------------------------------------------
// Created:		April 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
constants
	XMLTAG_XML = '&lt;?xml version="1.0" encoding="utf-8" ?&gt;';
	XMLTAG_INV = "Invoice";
	XMLTAG_HEADER = "InvoiceHeader";
	XMLTAG_GL = "GLCode";
	XMLTAG_SEQ = "No";
	XMLTAG_DEBTOR = "Sell-toCustomerNo.";
	XMLTAG_REMARKS = "Description";
	XMLTAG_DATE = "DocumentDate";
	XMLTAG_CURR = "CurrencyCode";
	XMLTAG_DETAIL = "InvoiceDetail";
	XMLTAG_ITEM = "Item";
	XMLTAG_QTY = "Quantity";
	XMLTAG_SERVICE = "ServiceCode";
	XMLTAG_UNITPRICE = "UnitPrice";
	DELIMITER = ",";


vars
	// ### DETAIL FIELDS
	strService,
	strAccCode,
	strUnitNarration,
	strServiceName,
	strNarration,
	strUnitPrice,
	strQuantity,
	strLineTotal,
	strGLCode,
	strTaxCode,
	strNoTax,
	strTax,
	theService,
	theHeader, theDetail, theLine : String;
//	totalAmount, lineAmount, taxAmount : Decimal[10,2];
//	invTotalNoTax, invTax, invTotalWithTax :   Decimal[12,2];
//	theQty,taxRate : Decimal[10,4];
	aService : CM_Service;
	charge: CM_Charge;
	glSumm : CM_GLSummaryByGLCodeRateDict;
	glStat : CM_GLSummary;
	aLineDesc : CM_InvoiceLineDesc;
	theInvoiceLine : CM_InvoiceLine;
	isZeroRatedTax : Boolean;
	codes : StringArray; 
	rates  : RealArray; 
	amounts : RealArray;
	tmpPos, idx : Integer;
	theBank : CM_Bank;
	multiTax : Boolean;
	aTR : CM_TaxRate;
	aTC : CM_TaxCode;
	item, output : String;
	dpl : Integer;
	voyage : CM_Voyage;
	totalAmount, lineAmount, taxAmount : Decimal[14,2];		//11 May 2018	NDL	TFS 38528
	invTotalNoTax, invTax, invTotalWithTax :   Decimal[16,2];		//11 May 2018	NDL	TFS 38528
	theQty,taxRate : Decimal[14,4];		//11 May 2018	NDL	TFS 38528
begin

	create codes transient;
	create rates transient;
	create amounts transient;

	theBank := _theInvoice.bank;
	multiTax := _theInvoice.myTerminal.getConfig(InvoiceMultiTaxRates).Boolean;
	totalAmount := _theInvoice.getTotalAmount();
	isZeroRatedTax := _theInvoice.isZeroRatedTax or _theInvoice.debtor.isZeroRatedTax; // CCMS 1269		19/10/17 MAP TFS7357
	
	// TFS 37562 exempt by voyage
	voyage := _theInvoice.myVoyage;
	if voyage &lt;&gt; null then
		isZeroRatedTax := app.myRoot.getVoyageTaxExempt( voyage.myTerminal, voyage ).Boolean;
	endif;
	
	 // CCMS 1172
	if isZeroRatedTax then
		taxRate := 0;
	else
		taxRate := theBank.parentCompany.taxPercentageRate / 100;
	endif;

	strAccCode := _theInvoice.debtor.decfinName.trimBlanks; 
	
	dpl := self.getRateEntryDecimalPlaces; // TFS 36954 MPD 20 Feb 2018

	create glSumm transient;
	foreach theInvoiceLine in _theInvoice.invoiceLines do
		foreach charge in theInvoiceLine.charges do
			charge.getGLRateSummaryStats(glSumm);
		endforeach;
	endforeach;

	
	foreach glStat in glSumm do
		
		aTC := null;
//		aService := theBank.services[glStat.serviceName]; // PAR 18347
		aService := theBank.services.getAtKeyGeq(glStat.serviceName); // PAR 18347
		if aService &lt;&gt; null then
			aTC := aService.myTaxCode;
		endif;
		
		if aTC &lt;&gt; null then
			strTaxCode := aTC.code &amp; DELIMITER;
			aTR := aTC.getTimeRate(_theInvoice.toDT);
			if isZeroRatedTax then
				taxRate := 0;
			elseif aTR &lt;&gt; null then
				taxRate := aTR.rate / 100;
			endif;
		else
			 // CCMS 1172
			if isZeroRatedTax then
				taxRate := 0;
			else
				taxRate := theBank.parentCompany.taxPercentageRate / 100;
			endif;
			strTaxCode := theBank.taxNumber &amp; DELIMITER; 
		endif;

		codes.clear;
		rates.clear;
		amounts.clear;
		glStat.getTaxForInvoice(multiTax, codes, rates, amounts);

		strQuantity := glStat.quantity.asStringJMTWithPrecision($CM_Decimal2NoComma.decimalPlaces, false); 
		strQuantity.replaceChar(".",",");
		strUnitNarration := glStat.myInvoiceLine.invoiceLineDesc.unitNarration; 
//		strUnitPrice := glStat.rate.asStringJMTWithPrecision($CM_Decimal2NoComma.decimalPlaces, false) ; // PAR 19465
		//strUnitPrice := glStat.rate.asStringJMTWithPrecision($CM_RateEntry.decimalPlaces, false) ; // PAR 19465
		strUnitPrice := glStat.rate.asStringJMTWithPrecision(dpl, false); // TFS 36954 MPD 20 Feb 2018
		
		strUnitPrice.replaceChar(".",",");
		strLineTotal := glStat.amount.asStringJMTWithPrecision($CM_Decimal2NoComma.decimalPlaces, false);
		strLineTotal.replaceChar(".",",");
		strNarration := glStat.myInvoiceLine.invoiceLineDesc.narration; 
		
		strServiceName := aService.name;
		// GLCODE - this is prefixed on the front of the service name at DCTG
		strGLCode := null;
		tmpPos := strServiceName.pos("-",1);
		
		if tmpPos &gt; 0 then
			tmpPos := tmpPos - 1;
			strGLCode := strServiceName[1:tmpPos];
			strGLCode := strGLCode.trimBlanks();
		endif;
		strServiceName := strServiceName[1:50]; // PAR 14627

		invTotalNoTax := glStat.amount;
		invTax := invTotalNoTax * taxRate;
		invTotalNoTax := glStat.amount;
		invTotalWithTax := (invTotalNoTax + invTax);
		strTax := invTax.asStringJMTWithPrecision($CM_Decimal2NoComma.decimalPlaces, false) &amp; DELIMITER;
		strNoTax := invTotalNoTax.asStringJMTWithPrecision($CM_Decimal2NoComma.decimalPlaces, false) &amp; DELIMITER; 

		strTax.replaceChar(".",",");
		strNoTax.replaceChar(".",",");

		idx := idx + 1;
		item := 
		app.formatAsXML(XMLTAG_SEQ, idx.padLeadingWith("0",3))
			&amp; 
		app.formatAsXML(XMLTAG_GL,strGLCode)
			&amp; 
//		app.formatAsXML(XMLTAG_SERVICE,strServiceName) // PAR 18405
		app.formatAsXML(XMLTAG_SERVICE,strGLCode) // PAR 18405
			&amp; 
//		app.formatAsXML(XMLTAG_REMARKS,aService.remarks.trimBlanks()) // PAR 18405
		app.formatAsXML(XMLTAG_REMARKS,"") // PAR 18405
			&amp;
		app.formatAsXML(XMLTAG_QTY,strQuantity)
			&amp; 
		app.formatAsXML(XMLTAG_UNITPRICE,strUnitPrice);
			
		output := output &amp; app.formatAsXML(XMLTAG_ITEM,item);

	endforeach;
	output := app.formatAsXML(XMLTAG_DETAIL,output);
	
	return output;
epilog
	delete codes;
	delete rates;
	delete amounts;

	glSumm.purge;
	delete glSumm;
end;</source>
        <Parameter name="_theInvoice" type="CM_Invoice"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getNiceName" id="78e7cd95-3f0c-4db0-a3a5-4ae1395adac8">
        <source>getNiceName(): String;
// ---------------------------------------------------------------------------
