    <JadeMethod name="doSave" id="ad1f0706-5528-44e0-b549-fb17549a88c9">
        <updating/>
        <source>doSave(): Boolean updating;
/*
----------   ----------  --------------------------------------------------
Created:	19 September 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	theForm 			: SOP_TableMaintForm;
	tbl					: CM_EntryTable;
	code,
	description			: String;
	pxyDamageCode 		: CM_DamageDefinitionCode;
	allCargoTypes		: CM_ObjectSet;
	allMachineTypes		: CM_MachineTypeByTypeDict;
begin

	theForm := self.myForm;
	tbl := theForm.tblInput1;
	
	code := tbl.getValueByName(ETRow_Code).String;
	description := tbl.getValueByName(ETRow_Description).String;
	//theForm.
	create allCargoTypes transient;
	theForm.mulSelect1.getSelected(allCargoTypes);
	
	create allMachineTypes transient;
	theForm.mulSelect2.getSelected(allMachineTypes);
	
	if theForm.myProxyObject = null then
		if theForm.mode = theForm.Mode_Add then
			create theForm.myProxyObject as CM_DamageDefinitionCode transient;
		endif;
		if theForm.myProxyObject = null then
			app.raiseUnexpectedProgramError(class.name, method.name, 'Proxy object is null for update');
			return false;
		endif;
	endif;

	pxyDamageCode := theForm.myProxyObject.CM_DamageDefinitionCode;
	pxyDamageCode.setProxy(code,description, allCargoTypes,allMachineTypes);
	
	if theForm.mode = theForm.Mode_Add then
		app.myTrxCA.trxCreateDamageDefCode(pxyDamageCode,
									 theForm.myCurrentObject,
									app.myPassport);
	else
		app.myTrxUA.trxUpdateDamageDefCode(pxyDamageCode,
									app.myPassport);
	endif;
	
	return app.myPassport.trxCompletedOK;
epilog
	delete allCargoTypes;
	delete allMachineTypes;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
