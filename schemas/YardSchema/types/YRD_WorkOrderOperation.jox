    <JadeMethod name="showShipFilter" id="1a4674b8-ec35-433e-b313-ea62d5b41a54">
        <updating/>
        <source>showShipFilter(_show : Boolean) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 Oct 2023 navhl20 ChangeRequest 60033: EUP | Ship Operations in DD - [54176.010] - [Receive] Ship Job List 
02 Apr 2024 navhl20 ChangeRequest 63302: EUP - Bulk Moves in Retrospective Screen
17 Jun 2024 navhl20 ChangeRequest 64684: EUP - Add new filter criteria in Work Order Operations.
*/

vars

begin
	if _show then
		self.chkCurrentVoyage.visible 	:= true;
		self.lblVessel.visible 			:= true;
		self.cmbVessel.visible 			:= true;
		self.chkBulkMode.visible 		:= true;		//02.04.2024 navhl20 #63302
	else
		self.chkCurrentVoyage.visible 	:= false;
		self.lblVessel.visible 			:= false;
		self.cmbVessel.visible 			:= false;
		self.chkBulkMode.visible 		:= false;		//02.04.2024 navhl20 #63302
		self.chkBulkMode.value 			:= false;
		self.chkJobDetail.enabled		:= true;
	endif;
epilog

end;</source>
        <Parameter name="_show" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="showTransFilter" id="c063e126-a227-4d91-bac3-b021a1b15b34">
        <source>showTransFilter(_mode : Integer);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 Jun 2024	navhl20	ChangeRequest 64684: EUP - Add new filter criteria in Work Order Operations.

*/

vars

begin
	self.lblCommodity.visible 		:= false;
	self.lblTransport.visible 		:= false;
	self.cmbTransport.visible 		:= false;
	self.cmbCommodity.visible 		:= false;
	if _mode = YRD_WorkOrderOperation.Mode_ROAD then	
		self.lblCommodity.visible 		:= true;
		self.cmbCommodity.visible 		:= true;
	elseif _mode = YRD_WorkOrderOperation.Mode_RAIL then
		self.lblTransport.caption 		:= "Train";	
		self.lblCommodity.visible 		:= true;
		self.cmbCommodity.visible 		:= true;
		self.lblTransport.visible 		:= true;
		self.cmbTransport.visible 		:= true;
	elseif _mode = YRD_WorkOrderOperation.Mode_SHIP then
		self.lblTransport.caption 		:= "Voyage";	
		self.lblCommodity.visible 		:= true;
		self.lblTransport.visible 		:= true;
		self.cmbTransport.visible 		:= true;
		self.cmbCommodity.visible 		:= true;
	endif;
epilog

end;</source>
        <Parameter name="_mode" type="Integer"/>
    </JadeMethod>
