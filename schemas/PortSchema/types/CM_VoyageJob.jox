//--------------------------------------------------------------
//Created: 23 April 2003 By: cnwgd1
//--------------------------------------------------------------
vars

begin

	_value := self.getJobTypeDescription();
	
	
	if _value = null then
		inheritMethod(set, _value);
	endif;
	


end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="myDeck" id="994fc801-3c02-44c8-ba96-0fd96e5d817d">
        <methodInvocation>mapping</methodInvocation>
        <source>myDeck(set: Boolean; _value: CM_DeckVoyage io) mapping;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 July 2011	cnwer1	Initial creation CCMS MES 1033

*/

vars

begin
	if set then
		// set code here
		return;
	else
		// get code here
		/*get job sheet if the job sheet is for a crane can return null
			if the job sheet isKindOf CM_VoyageDeckJobSheet then can get the deck from the bayId 
			note using bayId to also store deckId
		*/
		//epr par 31094 job can be unassigned so job sheet will be null
		if self.isKindOf(CM_VoyageDeckJob) then
		
		//if self.myVoyageJobSheet.isKindOf(CM_VoyageDeckJobSheet) then
// PAR 28985			_value:= self.myVoyage.myROROStructure.allDecksByCode[self.bayId];
			_value:= self.myVoyage.myROROStructure.getDeckFromCode(self.bayId);
			
		else
			_value:=null;
		endif;
	endif;


epilog

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="CM_DeckVoyage" usage="io"/>
    </JadeMethod>
