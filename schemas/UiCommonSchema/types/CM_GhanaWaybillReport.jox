	adjustedHeight := self.adjustHeight(self.lbl26);
	bottomOfPrint := self.lbl26.top + self.lbl26.height;
	
	self.lblMarks.top := self.lbl25.top + self.lbl25.height + 1;
	self.lblMarks.left := 1;
	
	topPixels := self.lblMarks.top + self.lblMarks.height + 1;
	heightPixels := self.lblMarks.height; // initial height
	leftMMs := 1;
	rightMMs := 79;
	self.moveDataLabel( frame, self.lbl27, topPixels, heightPixels, leftMMs, rightMMs, Label.Alignment_Left_Top, _doLayoutCheck );
	adjustedHeight := self.adjustHeight(self.lbl27);
	bottomOfPrint := bottomOfPrint.max( self.lbl27.top + self.lbl27.height );
	
	frame.height := bottomOfPrint + 1;
	
	self.addNewPageFrameIfRequired( frame );
	
	self.frmSect5.top := frame.top + frame.height + 1;
	self.frmSect5.left := frame.left;
	self.frmSect5.width := frame.width;
	
epilog

