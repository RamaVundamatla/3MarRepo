    <JadeMethod name="browseTidalData" id="437c2e97-4afe-4c59-b1f7-874e0a9578e5">
        <source>browseTidalData();

//--------------------------------------------------------------
//Created: 06/10/2006 By: cnwmo1
//--------------------------------------------------------------
vars
	file : CMDFileOpen;
begin
	create file transient;
	if file.open = 0 then
	    self.txtLoadFile.text := file.fileName;
	endif;
epilog
	delete file;

end;</source>
