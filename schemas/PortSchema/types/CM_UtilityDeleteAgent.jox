    <JadeMethod name="utlDeleteEDIData" id="75989e9b-61fa-4f71-a55d-f5d62d9fe53d">
        <source>utlDeleteEDIData(_ediData:CM_EDIData input; _passport : CM_Passport input);
//--------------------------------------------------------------
//Created: August 2002 By: cnwgd1
//--------------------------------------------------------------
// 08/08/2012	cnwcs5	par 30136 -  change usage of ediData parameter
// 19 Sep 2018	jlgrs1	TFS 40627 STWR Make EDI MultiThreaded Stage3
// 24 Oct 2018	jlgrs1	TFS 40627 STWR Make EDI MultiThreaded Stage 5

vars
	ediFileType : CM_EDIFileType;
	tmpAuditConfig : CM_AuditConfig;
begin

	self.initialiseActivity();
	app.setContinueCMExceptions(true);
	
	app.myValDA.valEDIData(_ediData);
	
	if (not self.checkValidationWithPassport(_passport)) then // Show any Errors and Warnings in a list
		return;
	endif;

	app.setContinueCMExceptions(false);
	
	// Lock things in the same order as create to avoid deadlocks
	// 1. Lock config
		// No longer required here
		
	// 2. Lock file type
// 16 Oct 2018	jlgrs1	TFS 40627 STWR Make EDI MultiThreaded Stage 5
//	ediFileType := _ediData.getEDIFileType();
//	if ediFileType &lt;&gt; null then
//		self.exclusiveLock(ediFileType);
//	endif;
//	if not self.tryLock(ediFileType, Exclusive_Lock, Transaction_Duration, LockTimeout_Immediate) then
//		abortTransaction;
//		return;
//	endif;
	if not self.tryLock(_ediData.ediConfig.allEDIFilesByEdiClientRef, Exclusive_Lock, Transaction_Duration, LockTimeout_Immediate) then
//		abortTransaction;
		return;
	endif;
	if not self.tryLock(_ediData.ediConfig.allEDITrackedItemsByIdStatus, Exclusive_Lock, Transaction_Duration, LockTimeout_Immediate) then
//		abortTransaction;
		return;
	endif;
	if not self.tryLock(_ediData.ediConfig.ediFiles, Exclusive_Lock, Transaction_Duration, LockTimeout_Immediate) then
//		abortTransaction;
		return;
	endif;
	
	// 3. Lock Audits
	app.myAA.getAuditConfigForClass( _ediData, _ediData.class, tmpAuditConfig);
	if tmpAuditConfig &lt;&gt; null then
// 16 Oct 2018	jlgrs1	TFS 40627 STWR Make EDI MultiThreaded Stage 5
//		self.exclusiveLock(tmpAuditConfig.allAuditObjects);
		if not self.tryLock(tmpAuditConfig.allAuditObjects, Exclusive_Lock, Transaction_Duration, LockTimeout_Immediate) then
//			abortTransaction;
			return;
		endif;
	endif;
	
	if _passport.noErrors then
		self.myDeleteAuditAgent.audDeleteGeneric(_ediData);
	endif;

	if _passport.noErrors then
		_ediData.erase(NORMAL_ERASE);
	endif;

epilog
	return;

end;</source>
        <Parameter name="_ediData" type="CM_EDIData" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
