vars

	file : File;
	binary : Binary;
	string : String;
	
	maxString : String;
	
	form : NDLTestForm;

begin


	app.initialize();
	app.myPassport.setMyUserFromCode("SUPERUSER");
//	term := "2351.53".asOid.CM_Terminal;	// NDL Terminal
//	app.myPassport.setMyTerminal( term );

create form transient;
form.show();

process.sleep(1000);

//write form.picPDF147.picture.Binary.String;
maxString := form.picPDF147.picture.Binary.asHex;
write maxString.length;
	
form.unload;
	
epilog

	delete form;

end;</source>
