<Class name="CMIF_InvoiceLineMapping" id="d241f78c-6ff3-4483-aa79-9e3464453a34">
    <superclass name="CMIF_Object"/>
    <transient/>
    <sharedTransientAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="invoice"/>
    <ImplicitInverseRef name="allDebtors" id="c5d2835e-7e89-484e-b9d1-eba71ef9a28c">
        <embedded/>
        <type name="CM_DebtorNodeByNameDict"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <JadeMethod name="create" id="a848556f-3b53-4e30-976a-df91fbf95a64">
        <updating/>
        <source>create() updating;
/*

Purpose:			Creates the Invoice Line Mapping Agent

Parameters:			NONE

Return Value:		NONE

Date		Who		Reason
06 October 2022	navpw1	Initial creation TFS: 54566

*/

begin
	//Collection used on Import/Export of data to hold all the debtors. Saves us getting them multpile times
	create self.allDebtors transient;
	app.myRoot.myRootCompany.rootDebtorGroup.getDebtors(self.allDebtors);
	
end;</source>
    </JadeMethod>
    <JadeMethod name="delete" id="e361cb4d-837a-448b-9acb-bd717491113b">
        <updating/>
        <source>delete() updating;
/*

Purpose:			Deletes the Invoice Line Mapping Agent

Parameters:			NONE

Return Value:		NONE

Date		Who		Reason
06 October 2022	navpw1	Initial creation TFS: 54566

*/

begin
	//Remove our collection as it is no longer needed
	delete self.allDebtors;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doExtractInvLnMappingCsvFile" id="81fe4d96-55a5-4819-a60a-fa64ca8289b5">
        <updating/>
        <source>doExtractInvLnMappingCsvFile(_file : File input; _bank : CM_Bank input; _selectedDebtors : CM_DebtorNodeByNameDict input; _selectedInvLineTypes : CM_InvLineDescByNarrDupsADict input; _cmifMonitor : CMIF_Monitor io) : Integer updating;
/*

Purpose:			Extracts Invoice Line Mappings to a CSV File

Parameters:			_file					File							The file to extract the data to
					_bank					CM_Bank							The bank to use to get the data from
					_selectedDebtors		CM_DebtorNodeByNameDict			The debtors that were selected on the form
					_selectedInvLineTypes	CM_InvLineDescByNarrDupsADict	The invoice line types that were selected on the form
					_cmifMonitor			CMIF_Monitor					The monitor to use to show update on the UI

Return Value:		Integer	Representing how many records were extracted

Date		Who		Reason
06 October 2022	navpw1	Initial creation TFS: 54566
20 March 2023	navmk20	Bug 56954: FR | 53978 - EUP - Invoicing - Configuration Enhancements - User Story 050 issues
*/

vars
	count,
	totalCount				: Integer;
	headers,
	msg						: String;
	terminal				: CM_Terminal;
	terminalCode			: String;
	theDebtors				: CM_DebtorNodeByNameDict;
	selectedInvLineTypes	: CM_InvLineDescByNarrDupsADict;
	allInvLineDescMappings	: CM_InvLineDescMapByDebtorLType;
	invoiceLineTypeMapping	: CM_InvoiceLineDescMapping;
	
begin
	if _bank = null then
		app.raiseCMException(Bank_selected, null, null);
	endif;
	
	headers := "mode,terminalCode,businessUnit,debtorName,invoiceLineTypeNarration,invoiceTypeNarration";
	_file.writeLine(headers);
	
	if _selectedDebtors.isEmpty or _selectedInvLineTypes.isEmpty then
		return 0;
	endif;
	
	create allInvLineDescMappings transient;
	_bank.allInvoiceLineDescMappings.copy(allInvLineDescMappings);
	
	//totalCount := allInvLineDescMappings.size; // 20.3.2023 navmk20 TFS 56954
	
	create theDebtors transient;
	_selectedDebtors.copy(theDebtors);
	
	create selectedInvLineTypes transient;
	_selectedInvLineTypes.copy(selectedInvLineTypes);
	
	totalCount := selectedInvLineTypes.size;  // 20.3.2023 navmk20 TFS 56954
	
	terminalCode := null;
	terminal := _bank.terminal;
	if terminal &lt;&gt; null then
		terminalCode := terminal.code;
	endif;
	
	foreach invoiceLineTypeMapping in allInvLineDescMappings discreteLock do
		// Start - 20.3.2023 navmk20 TFS 56954
		/*if not theDebtors.includes(invoiceLineTypeMapping.myDebtor) and not selectedInvLineTypes.includes(invoiceLineTypeMapping.myInvoiceLineDesc) then
			continue;
		endif;
		
		count += count;
		
		msg := "," &amp; terminalCode &amp; "," &amp; _bank.code &amp; "," &amp; invoiceLineTypeMapping.myDebtor.name &amp; "," &amp; invoiceLineTypeMapping.myInvoiceLineDesc.narration &amp; "," &amp; invoiceLineTypeMapping.myInvoiceType.description;
		
		_file.writeLine(msg);
		
		if _cmifMonitor &lt;&gt; null then
			_cmifMonitor.updateProgress(app.getErrorString(Writing_export_file), totalCount, count);
		endif;*/
		if theDebtors.includes(invoiceLineTypeMapping.myDebtor) and selectedInvLineTypes.includes(invoiceLineTypeMapping.myInvoiceLineDesc) then
			count += count;
			msg := "," &amp; terminalCode &amp; "," &amp; _bank.code &amp; "," &amp; invoiceLineTypeMapping.myDebtor.name.asDoubleQuotedString() &amp; "," &amp; invoiceLineTypeMapping.myInvoiceLineDesc.narration.asDoubleQuotedString() &amp; "," &amp; invoiceLineTypeMapping.myInvoiceType.description.asDoubleQuotedString();
			_file.writeLine(msg);
			if _cmifMonitor &lt;&gt; null then
				_cmifMonitor.updateProgress(app.getErrorString(Writing_export_file), totalCount, count);
			endif;
		endif;
		// End - 20.3.2023 navmk20 TFS 56954
	endforeach;
	
	return count;
	
epilog
	delete theDebtors;
	delete selectedInvLineTypes;
	delete allInvLineDescMappings;
	
end;</source>
        <Parameter name="_file" type="File" usage="input"/>
        <Parameter name="_bank" type="CM_Bank" usage="input"/>
        <Parameter name="_selectedDebtors" type="CM_DebtorNodeByNameDict" usage="input"/>
        <Parameter name="_selectedInvLineTypes" type="CM_InvLineDescByNarrDupsADict" usage="input"/>
        <Parameter name="_cmifMonitor" type="CMIF_Monitor" usage="io"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doExtractInvLnTypMapXmlFile" id="de62658b-453c-4385-9086-e3b10adf52c7">
        <source>doExtractInvLnTypMapXmlFile(_file : File input; _bank : CM_Bank input) : Integer;
/*

Purpose:			Extracts Invoice Line Mappings to a XML File

Parameters:			_file			File			The file to extract the data to
					_bank			CM_Bank			The bank to use to get the data from

Return Value:		Integer	Representing how many records were extracted

Date		Who		Reason
07 October 2022	navpw1	Initial creation TFS: 54566

*/

vars
	count				: Integer;
	msg					: String;
	invLineTypeMapping	: CM_InvoiceLineDescMapping;
	terminal			: CM_Terminal;
	terminalCode		: String;
	
begin
	msg := '&lt;invoiceLineMappings&gt;';
	_file.writeLine(msg);
	foreach invLineTypeMapping in _bank.allInvoiceLineDescMappings discreteLock do
		count := count + 1;
		msg := '&lt;invoiceLineMapping&gt;';
		_file.writeLine(msg);
		
		msg := self.formatAsXML("mode", "");
		_file.writeLine(msg);
		
		terminalCode := null;
		terminal := _bank.terminal;
		if terminal &lt;&gt; null then
			terminalCode := terminal.code;
		endif;
		
		msg := self.formatAsXML("terminalCode", terminalCode);
		_file.writeLine(msg);
		msg := self.formatAsXML("businessUnit", _bank.code);
		_file.writeLine(msg);
		msg := self.formatAsXML("debtorName", invLineTypeMapping.myDebtor.name);
		_file.writeLine(msg);
		msg := self.formatAsXML("invoiceLineTypeNarration", invLineTypeMapping.myInvoiceLineDesc.narration);
		_file.writeLine(msg);
		msg := self.formatAsXML("invoiceTypeNarration", invLineTypeMapping.myInvoiceType.description);
		_file.writeLine(msg);
		
		msg := '&lt;/invoiceLineMapping&gt;';
		_file.writeLine(msg);
	endforeach;
	
	msg := '&lt;/invoiceLineMappings&gt;';
	_file.writeLine(msg);
	
	return count;
	
end;</source>
        <Parameter name="_file" type="File" usage="input"/>
        <Parameter name="_bank" type="CM_Bank" usage="input"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doExtractQueriedMappingCSVFile" id="ee1747aa-04f8-4e16-bb23-ac49afc6be90">
        <updating/>
        <source>doExtractQueriedMappingCSVFile(_file : File input; _bank : CM_Bank input; _selectedDebtors : CM_DebtorNodeByNameDict input;_selectedInvLineTypes : CM_InvLineDescByNarrDupsADict input; _cmifMonitor : CMIF_Monitor io) : Integer updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
20 March 2023	navmk20	Bug 56954: FR | 53978 - EUP - Invoicing - Configuration Enhancements - User Story 050 issues

*/

vars
	count,
	totalCount			: Integer;
	headers,
	invoiceLineTypeValue,
	invTypeName,
	msg, terminalCode					: String;
	caption				: String;
	theDebtors			: CM_DebtorNodeByNameDict;
	selectedInvLineTypes	: CM_InvLineDescByNarrDupsADict;
	selectedInvoiceLineDesc		: CM_InvoiceLineDesc;
	invoiceLineDesc		: CM_InvoiceLineDesc;
	debtorNode			: CM_DebtorNode;
	invoiceType			: CM_InvoiceDesc;
	rootDebtorGroup		: CM_RootDebtorGroup;
	terminal : CM_Terminal;
begin
	if _bank = null then
		app.raiseCMException(Bank_selected, null, null);
	endif;
	
	terminalCode := null;
	terminal := _bank.terminal;
	if terminal &lt;&gt; null then
		terminalCode := terminal.code;
	endif;
	
	create theDebtors transient;
	_selectedDebtors.copy(theDebtors);
	
	if theDebtors.isEmpty then
		rootDebtorGroup := _bank.getRootDebtorGroup();
		rootDebtorGroup.getDebtors(theDebtors);
	endif;
	
	create selectedInvLineTypes transient;
	_selectedInvLineTypes.copy(selectedInvLineTypes);
	
	if selectedInvLineTypes.isEmpty then
		foreach selectedInvoiceLineDesc in _bank.invoiceLineDescriptors do
			selectedInvLineTypes.add(selectedInvoiceLineDesc);
		endforeach;
	endif;
	
	if not theDebtors.isEmpty then
		foreach debtorNode in theDebtors do
			caption &amp;= debtorNode.name &amp; ", ";
		endforeach;
	endif;
	
	headers := "mode,terminalCode,businessUnit,debtorName,invoiceLineTypeNarration,invoiceTypeNarration";
	_file.writeLine(headers);
	
	
	totalCount :=_selectedInvLineTypes.size; 
	
	foreach invoiceLineDesc in selectedInvLineTypes where not invoiceLineDesc.isNotAvailableForEntry do
		count += count;
		invoiceLineTypeValue := invoiceLineDesc.narration;
		foreach debtorNode in theDebtors do
			invTypeName := null;
			invoiceType := invoiceLineDesc.getInvoiceType(debtorNode.CM_Debtor);
			if invoiceType &lt;&gt; null then
				invTypeName := invoiceType.description;
			else 
				invTypeName := "UNKNOW";
			endif;
			
			msg := "," &amp; terminalCode &amp; "," &amp; _bank.code &amp; "," &amp; debtorNode.name.asDoubleQuotedString() &amp; "," &amp; invoiceLineDesc.narration.asDoubleQuotedString() &amp; "," &amp; invTypeName.asDoubleQuotedString();
			_file.writeLine(msg);	
			
		endforeach;
		
		
		if _cmifMonitor &lt;&gt; null then
			_cmifMonitor.updateProgress(app.getErrorString(Writing_export_file), totalCount, count);
		endif;
	endforeach;
	return count;
	
epilog
	delete theDebtors;
	delete selectedInvLineTypes;
end;</source>
        <Parameter name="_file" type="File" usage="input"/>
        <Parameter name="_bank" type="CM_Bank" usage="input"/>
        <Parameter name="_selectedDebtors" type="CM_DebtorNodeByNameDict" usage="input"/>
        <Parameter name="_selectedInvLineTypes" type="CM_InvLineDescByNarrDupsADict" usage="input"/>
        <Parameter name="_cmifMonitor" type="CMIF_Monitor" usage="io"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doLoadInvLnTypMapCsvFile" id="d85439f2-03f2-4baf-91d3-a6c2564bf22d">
        <source>doLoadInvLnTypMapCsvFile(_file : File; _proxyCArray, _proxyUArray, _proxyDArray : ObjectArray input; 
							   _errorStore : CM_ErrorSet input; _bank : CM_Bank; _noLines : Integer io);
/*

Purpose:			Loads Invoice Line Mappings from a CSV file

Parameters:			_file			File		The file to load the data from
					_proxyCArray	ObjectArray	The objects we need to create
					_proxyUArray	ObjectArray	The objects we need to update
					_proxyDArray	ObjectArray	The objects we need to delete
					_errorStore		CM_ErrorSet	Holds all the errors encountered
					_bank			CM_Bank		The bank to use to load the data to
					_noLines		Integer		The amount of lines processed

Return Value:		NONE

Date		Who		Reason
06 October 2022	navpw1	Initial creation TFS: 54566

*/

vars
	fileLine 				: String;
	fieldArray 				: StringArray;
	mode,
	terminalCode,
	businessUnit,
	debtorName,
	invLnTypNarration,
	invTypeNarration		: String;
	
begin
	//ignore first line
	fileLine 	:= _file.readLine();
	_noLines	:= 1;
	
	create fieldArray transient;
	
	while not _file.endOfFile() do
		fileLine := _file.readLine();
		
		if fileLine = null then
			continue;
		endif;
		
		fieldArray.clear();
		
		fileLine.csvToStringArray(fieldArray, ",");
		
		if fieldArray.isEmpty then
			continue;
		endif;
		
		//Set fields default to null
		mode					:= null;
		terminalCode			:= null;
		businessUnit			:= null;
		debtorName				:= null;
		invLnTypNarration		:= null;
		invTypeNarration		:= null;
		
		/*
		The import layout for this table is exactly (or similar) to the column organiser "JMT Default".
		This is what has been supplied to Messina in document CCMS MES 1008, 1010 Interfaces Messages,
		also see the JMT User Guide section for System Codes Reference.
		*/
		if fieldArray.size &lt; 6 then
			//Incorrect file format
			app.raiseCMException(ERR_LineFormatInvalidFile, null, null);
		endif;
		
		mode 					:= fieldArray[1].trimBlanks();
		terminalCode 			:= fieldArray[2].trimBlanks();
		businessUnit			:= fieldArray[3].trimBlanks();
		debtorName				:= fieldArray[4].trimBlanks();
		invLnTypNarration		:= fieldArray[5].trimBlanks();
		invTypeNarration		:= fieldArray[6].trimBlanks();
		
		self.processInvoiceLineMapping(_proxyCArray, _proxyUArray, _proxyDArray, _errorStore, _bank, mode, terminalCode, businessUnit, debtorName, 
												invLnTypNarration, invTypeNarration);
		_noLines += 1;
		
	endwhile;
	
epilog
	delete fieldArray;
	
end;</source>
        <Parameter name="_file" type="File"/>
        <Parameter name="_proxyCArray" type="ObjectArray" usage="input"/>
        <Parameter name="_proxyUArray" type="ObjectArray" usage="input"/>
        <Parameter name="_proxyDArray" type="ObjectArray" usage="input"/>
        <Parameter name="_errorStore" type="CM_ErrorSet" usage="input"/>
        <Parameter name="_bank" type="CM_Bank"/>
        <Parameter name="_noLines" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="doLoadInvLnTypMapXmlFile" id="3603a5e6-60f8-4c1d-b3c2-42079e3a22a6">
        <source>doLoadInvLnTypMapXmlFile(_file : File; _proxyCArray, _proxyUArray, _proxyDArray : ObjectArray input; 
							   _errorStore : CM_ErrorSet input; _bank : CM_Bank; _noLines : Integer io);
/*

Purpose:			Loads Invoice Line Mappings from a XML file

Parameters:			_file			File		The file to load the data from
					_proxyCArray	ObjectArray	The objects we need to create
					_proxyUArray	ObjectArray	The objects we need to update
					_proxyDArray	ObjectArray	The objects we need to delete
					_errorStore		CM_ErrorSet	Holds all the errors encountered
					_bank			CM_Bank		The bank to use to load the data to
					_noLines		Integer		The amount of lines processed

Return Value:		NONE

Date		Who		Reason
06 October 2022	navpw1	Initial creation TFS: 54566

*/

vars
	xmlDocumentParser 		: JadeXMLDocumentParser;
	rootElement 			: JadeXMLElement;
	rootNode				: JadeXMLNode;
	childElement			: JadeXMLElement;
	xmlDocument				: JadeXMLDocument;
	iter					: Iterator;
	xmlNode					: JadeXMLNode;
	xmlElement				: JadeXMLElement;
	mode,
	terminalCode,
	businessUnit,
	debtorName,
	invLnTypNarration,
	invTypeNarration		: String;
	
begin
	create xmlDocumentParser transient;
	create xmlDocument transient;
	xmlDocumentParser.parseDocumentFile(xmlDocument,_file.fileName);
	rootElement := xmlDocument.rootElement;
	
	foreach rootNode in rootElement.childNodes do
		if rootNode.isKindOf(JadeXMLElement) then
			childElement := rootNode.JadeXMLElement;
			if childElement = null then
				continue;
			endif;
			
			mode 					:= null;
			terminalCode			:= null;
			businessUnit			:= null;
			debtorName				:= null;
			invLnTypNarration 		:= null;
			invTypeNarration		:= null;
			
			iter := childElement.childNodes.createIterator;
			while iter.next(xmlNode) do
				if not xmlNode.isKindOf(JadeXMLElement) then
					continue;
				endif;
				
				xmlElement := xmlNode.JadeXMLElement;
				// property values for this invoice line type translations
				if xmlElement.tagName = "mode" then
					mode := xmlElement.textData.String;
					
				elseif xmlElement.tagName = "terminalCode" then
					terminalCode := xmlElement.textData.String;
					
				elseif xmlElement.tagName = "businessUnit" then
					businessUnit := xmlElement.textData.String;
					
				elseif xmlElement.tagName = "debtorName" then
					debtorName := xmlElement.textData.String;
					
				elseif xmlElement.tagName = "invoiceLineTypeNarration" then
					invLnTypNarration := xmlElement.textData.String;
					
				elseif xmlElement.tagName = "invoiceTypeNarration" then
					invTypeNarration := xmlElement.textData.String;
					
				endif;
				
			endwhile;
			
			self.processInvoiceLineMapping(_proxyCArray, _proxyUArray, _proxyDArray, _errorStore, _bank, mode, terminalCode, businessUnit, debtorName, 
												invLnTypNarration, invTypeNarration);
			_noLines += 1;
		endif;
		
	endforeach;
	
epilog
	delete xmlDocumentParser;
	delete xmlDocument;
	delete iter;
	
end;</source>
        <Parameter name="_file" type="File"/>
        <Parameter name="_proxyCArray" type="ObjectArray" usage="input"/>
        <Parameter name="_proxyUArray" type="ObjectArray" usage="input"/>
        <Parameter name="_proxyDArray" type="ObjectArray" usage="input"/>
        <Parameter name="_errorStore" type="CM_ErrorSet" usage="input"/>
        <Parameter name="_bank" type="CM_Bank"/>
        <Parameter name="_noLines" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="processInvoiceLineMapping" id="955a28ab-4b51-45cb-a73c-e7642ddfb19e">
        <source>processInvoiceLineMapping(_proxyCArray,
							_proxyUArray,
							_proxyDArray							: ObjectArray input;
							_errorStore								: CM_ErrorSet input;
							_bank									: CM_Bank;
							_mode, _terminalCode,
							_businessUnit, _debtorName,
							_invLnTypNarration, _invTypeNarration	: String) protected;
/*

Purpose:			Processes an Invocie Line Mapping and checks whether it needs creating/updating or deleting

Parameters:			_proxyCArray		ObjectArray	The collection we need to populate with objects that need creating
					_proxyUArray		ObjectArray	The collection we need to populate with objects that need updating
					_proxyDArray		ObjectArray	The collection we need to populate with objects that need deleting
					_errorStore			CM_ErrorSet	Holds all the errors encountered
					_bank				CM_Bank		The bank to use to load the data to
					_mode				String		The mode we need to use either (U: Create/Update | D: Delete)
					_terminalCode		String		The terminal code to use
					_businessUnit		String		The business unit to use
					_debtorName			String		The debtor to use
					_invLnTypNarration	String		The invoice line type narration to use
					_invTypeNarration	String		The invoice type narration to use

Return Value:		NONE

Date		Who		Reason
06 October 2022	navpw1	Initial creation TFS: 54566

*/

vars
	realILM,
	proxyILM				: CM_InvoiceLineDescMapping;
	terminal 				: CM_Terminal;
	myBuisnessUnit 			: CM_Bank;
	debtor					: CM_Debtor;
	invoiceDescLoop,
	invoiceDesc, invoiceType : CM_InvoiceDesc;
	invoiceLineDesc 		: CM_InvoiceLineDesc;
	errorDetailMessage		: String;
	
begin
	errorDetailMessage := "Debtor: " &amp; _debtorName &amp; " | Line Type: " &amp; _invLnTypNarration;
	
	// don't error from these being null, just skip them and sort out manually later
	if _terminalCode &lt;&gt; null then
		terminal := app.myRoot.allTerminals[_terminalCode];
		
	endif;
	
	if terminal = null then
		app.raiseCMException2(Imp_inv_line_type_map_err, errorDetailMessage, app.getErrorString1(Err_InvalidTerminal, _terminalCode), null, null);
		
	endif;
	
	if _businessUnit &lt;&gt; null then
		myBuisnessUnit := terminal.companies[_businessUnit];
		
	endif;
	
	if myBuisnessUnit = null then
		app.raiseCMException2(Imp_inv_line_type_map_err, errorDetailMessage, app.getErrorString1(Business_unit_invalid, _businessUnit), null, null);
		
	elseif not myBuisnessUnit.isBusinessUnit then
		app.raiseCMException2(Imp_inv_line_type_map_err, errorDetailMessage, app.getErrorString1(Business_unit_invalid, _businessUnit), null, null);
		
	endif;
	
	if _debtorName &lt;&gt; null then
		debtor := self.allDebtors[_debtorName].CM_Debtor;
		
	endif;
	
	if debtor = null then
		app.raiseCMException2(Imp_inv_line_type_map_err, errorDetailMessage, "Debtor is invalid", null, null);
		
	endif;
	
	if _invTypeNarration &lt;&gt; null then
		foreach invoiceDescLoop in myBuisnessUnit.invoiceTypes discreteLock do
			if invoiceDescLoop.description &lt;&gt; _invTypeNarration then
				continue;
			endif;
			
			invoiceDesc := invoiceDescLoop;
			break;
		endforeach;
		
	endif;
	
	if invoiceDesc = null then
		app.raiseCMException2(Imp_inv_line_type_map_err, errorDetailMessage, "Invoice Type invalid", null, null);
		
	endif;
	
	if _invLnTypNarration &lt;&gt; null then
		invoiceLineDesc := myBuisnessUnit.invoiceLineDescriptors[_invLnTypNarration];
		
	endif;
	
	if invoiceLineDesc = null then
		app.raiseCMException2(Imp_inv_line_type_map_err, errorDetailMessage, "Invoice Line Type invalid", null, null);
		
	endif;
	
	if _mode = "U" then
		// add if new otherwise update existing object
		realILM := myBuisnessUnit.allInvoiceLineDescMappings.getAtKeyGeq(debtor, invoiceLineDesc, null);
		invoiceType := invoiceLineDesc.invoiceType; // 20 March 2023	navmk20	Bug 56954
		
		if realILM &lt;&gt; null and realILM.myDebtor = debtor and realILM.myInvoiceLineDesc = invoiceLineDesc then
			if invoiceType = invoiceDesc then  // 20 March 2023	navmk20	Bug 56954-  changing back to non mapped inv type - delete the mapping
				_proxyDArray.add(realILM); // 20 March 2023	navmk20	Bug 56954
				return; // 20 March 2023	navmk20	Bug 56954
			else
				//Update the mapping
				proxyILM := app.createUpdateProxy(realILM).CM_InvoiceLineDescMapping;
				_proxyUArray.add(proxyILM); //Add to update array
			endif;
		else
			if invoiceType = invoiceDesc then // 20 March 2023	navmk20	Bug 56954 - do not create a mapping for the configured invoice type
				return;// 20 March 2023	navmk20	Bug 56954
			else
				//Create
				create proxyILM as CM_InvoiceLineDescMapping transient;
				_proxyCArray.add(proxyILM); //Add to create array
			endif; // 20 March 2023	navmk20	Bug 56954
		endif;
		
		proxyILM.setProxy(myBuisnessUnit, debtor, invoiceLineDesc, invoiceDesc);
		
	elseif _mode = "D" then
		realILM := myBuisnessUnit.allInvoiceLineDescMappings[debtor, invoiceLineDesc, invoiceDesc];
		
		if realILM = null then
			app.raiseCMException2(Imp_inv_line_type_map_err, errorDetailMessage, "Real Invoice Line Mapping not found", null, null);
		endif;
		
		_proxyDArray.add(realILM);
		
	else
		app.raiseCMException2(Imp_inv_line_type_map_err, errorDetailMessage, "Mode is invalid must either be 'U' or 'D'", null, null);
	endif;
	
end;</source>
