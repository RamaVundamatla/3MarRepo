    <JadeMethod name="isOtherFooterForReports" id="58c69c5c-ec16-483d-835e-e51a788d83d2">
        <source>isOtherFooterForReports() : Boolean;
// ---------------------------------------------------------------------------
// Created:		22 May 2008 By cnwvu1
//
// Purpose:		Defines whether 30, 45 and 53 footers should be included for 
//				reports in the "Other" column.
// ---------------------------------------------------------------------------

vars
	isOwn : Boolean;
	
begin

	if self.getAttrIs30() then
		if app.is30IncludedForReportsAsColumn( isOwn ) then
			if not isOwn then
				return true;	// it is included as part in the "Other" column
			endif;
		endif;
		
	elseif self.getAttrIs45() then
		if app.is45IncludedForReportsAsColumn( isOwn ) then
			if not isOwn then
				return true;	// it is included as part in the "Other" column
			endif;
		endif;

	elseif self.getAttrIs53() then
		if app.is53IncludedForReportsAsColumn( isOwn ) then
			if not isOwn then
				return true;	// it is included as part in the "Other" column
			endif;
		endif;
	
	endif;

	return false;
	
end;
</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isOversizedFrontend" id="e9098931-bdcc-46a7-a022-6e68af4a596d">
        <source>isOversizedFrontend() : Boolean;
// ---------------------------------------------------------------------------
// Created:		22 May 2008 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// ---- WHO --- WHEN ----- WHY---------------------------------------------
// ---------------------------------------------------------------------------
//       AKB    21MAY2008     PAR 16415 CCMS 1029 30,45,53s
// ---------------------------------------------------------------------------
vars
begin

	if self.isBackend then
		if self.getAttrIs53() then
			return true;
		else
			return false;
		endif;
	endif;
	
	if self.getAttrIs30() or self.getAttrIs45() or self.getAttrIs53() then
		return true;
	endif;
	
	return false;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isPlanned" id="342b22f4-aac7-468f-8e06-7523e82fca44">
        <source>isPlanned() : Boolean;
/*
Purpose:			Only for load
Date		Who		Reason
12 January 2015	cnwab1	Initial creation
*/

vars
	wle : CM_VoyageWLE;
	ti : CM_TrackedItem;
begin
	wle := self.allWorkListEntries.first.CM_VoyageWLE;
	if wle = null then
		return false;
	endif;
	
	if self.isLoad then
		return wle.isPlanned();
	else
		ti := self.getTIofMode(PLANNING_MODE);
		return ti &lt;&gt; null;
	endif;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
