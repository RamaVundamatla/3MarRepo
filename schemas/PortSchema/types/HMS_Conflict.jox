    <JadeMethod name="getDisplayStringForAttribute" id="b4382675-47f9-490c-8c25-8daef224c824">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*

Purpose:			


Return Value:		


Date		Who		Reason
08 March 2008	cnwer1	Initial creation - PAR#xxxx

*/
vars

begin
	if _attrName = ETRow_OccursOnDT then
		return self.systemToLocalTime(self.occursOnDT).asStringJMT;	// 25/5/16 cnwmp6 TFS 488 - Multi timezone support
	elseif _attrName = ETRow_VesselName then
		return self.vesselName;
	elseif _attrName = ETRow_HmsMovementVoyage then
		return self.voyageCode;
	elseif _attrName = ETRow_DraftAft then
		return self.draftAft;
	elseif _attrName = ETRow_DraftFwd then	
		return self.draftFwd;
	elseif _attrName = ETRow_HmsMovementLOA then
		return self.movementLOA;
	
	elseif _attrName = ETRow_BowMarkTo then
		return self.bowMarkTo;
	elseif _attrName = ETRow_SternMarkTo then	
		return self.sternMarkTo;
	elseif _attrName = ETRow_HmsMovementClearance then
		return self.clearanceFwd;
	elseif _attrName = ETRow_HmsMovementClearanceA then
		return self.clearanceAft;
	elseif _attrName = ETRow_MyTidalClass then
		return self.tidalClass;
	elseif _attrName = ETRow_ConflictType then
		return self.conflictTypeString;
	elseif _attrName = ETRow_ConflictDescription then
		return self.conflictDescription;
	elseif _attrName = ETRow_ExtraDetail then
		return self.extraDetail;
	elseif _attrName = ETRow_MoveType then
		return self.movementType;
	elseif _attrName = ETRow_MyBerth then
		return self.berthName;
	else	
		return inheritMethod(_attrName, _short);
	endif;

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setFromCMIF_HMS_Conflict" id="4ea67f63-e054-44a4-b45c-434fc026e1aa">
        <updating/>
        <source>setFromCMIF_HMS_Conflict(_cmif_hms_conflict : CMIF_HMS_Conflict input) updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
06 March 2008	cnwer1	Initial creation - PAR#xxxx

*/
vars

begin
	self.conflictDescription:= _cmif_hms_conflict.conflictTypeDescription;
	self.conflictTypeString		:= _cmif_hms_conflict.conflictTypeString;
	self.extraDetail		:= _cmif_hms_conflict.extraDetail;
	
	self.occursOnDT:= _cmif_hms_conflict.getDisplayStringForAttribute(ETRow_OccursOnDT,false).TimeStamp;
	self.vesselName:=_cmif_hms_conflict.getDisplayStringForAttribute(ETRow_VesselName,false).String;
	self.voyageCode:=_cmif_hms_conflict.getDisplayStringForAttribute(ETRow_HmsMovementVoyage,false).String;
		
	if _cmif_hms_conflict.myVoyageMovement &lt;&gt; null then
		self.berthName:=_cmif_hms_conflict.myVoyageMovement .getMyBerth().code;	
		self.movementType:=_cmif_hms_conflict.myVoyageMovement.getMoveTypeName;
	endif;
	
	self.draftAft:=_cmif_hms_conflict.getDisplayStringForAttribute(ETRow_DraftAft,false);
	self.draftFwd:=_cmif_hms_conflict.getDisplayStringForAttribute(ETRow_DraftFwd,false);
	self.movementLOA:=_cmif_hms_conflict.getDisplayStringForAttribute(ETRow_HmsMovementLOA,false);
	self.bowMarkTo:=_cmif_hms_conflict.getDisplayStringForAttribute(ETRow_BowMarkTo,false);
	self.sternMarkTo:=_cmif_hms_conflict.getDisplayStringForAttribute(ETRow_SternMarkTo,false);
	self.clearanceFwd:=_cmif_hms_conflict.getDisplayStringForAttribute(ETRow_HmsMovementClearance,false);
	self.clearanceAft:=_cmif_hms_conflict.getDisplayStringForAttribute(ETRow_HmsMovementClearanceA,false);
	self.tidalClass:=_cmif_hms_conflict.getDisplayStringForAttribute(ETRow_MyTidalClass,false);
epilog

end;</source>
        <Parameter name="_cmif_hms_conflict" type="CMIF_HMS_Conflict" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setMySavedConflcitReport" id="c550a82c-d96e-4c09-b6cb-11020cda17a5">
        <updating/>
        <source>setMySavedConflcitReport(_value : HMS_SavedConflictReport) updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
08 March 2008	cnwer1	Initial creation - PAR#xxxx

*/
vars

begin
	self.mySavedConflictReport :=_value;

epilog

end;</source>
        <Parameter name="_value" type="HMS_SavedConflictReport"/>
    </JadeMethod>
</Class>
