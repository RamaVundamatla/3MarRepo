    <JadeMethod name="getTotalRemaining" id="dda0bf9d-7979-4228-81bd-d7b935d49c64">
        <source>getTotalRemaining(): Integer;
/*

Date		Who		Reason
06 September 2013	cnwer1	Initial creation PAR 32408

*/

vars
	numReleased,
	numRequested,
	numCurrentlyActioned : Integer;
begin
	numReleased := self.getTotalReleased(); 
	numRequested := self.getTotalRequested(); 
	numCurrentlyActioned := self.getNumItemsBeingActioned(null);
	if numRequested &lt;= 0 then
		return 0;
	endif;
	return  numRequested - (numReleased + numCurrentlyActioned);
epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getTotalRequested" id="4a396019-5764-4d2e-99c1-8b542bad71a1">
