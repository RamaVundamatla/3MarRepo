    <JadeMethod name="createCashCredit1" id="b13ea7d9-fbd1-4c8b-9778-b2d0d026aff6">
        <source>createCashCredit1(_file : File input; _cashCredit : CM_CashCredit);
/*

Purpose:			
		Mapping RA_INTERFACE_LINES_ALL , 100 Col
		Mandatory Col: 4
Parameters:			

Return Value:		

Date		Who		Reason
13 Dec 2019 cnwma1 ChangeRequest 47851: QTS - Integration with Oracle Fusion Cloud

*/

vars
	str,			 
	strGL2,
	strGL3,
	strGL4		 : String;
	creditDetail : CM_CashCreditDetail;
	glCode       : CM_GLCode;
	fileEx		 : FileException;
begin
	
	on FileException do self.fileExceptionHandler(fileEx);
	
	foreach creditDetail in _cashCredit.allDerivedFromCreditDetails do
		
		//Clearing First 
		
		strGL2 := null;
		strGL3 := null;
		strGL4 := null;
		
		if creditDetail.myCashPayment &lt;&gt; null then
			if creditDetail.myCashPayment.getServiceGL &lt;&gt; null then
				glCode := creditDetail.myCashPayment.getServiceGL;
				strGL2 := glCode.getSegmentValue('.',2);
				strGL3 := glCode.getSegmentValue('.',3);
				strGL4 := glCode.getSegmentValue('.',4);
			endif;
		endif;
		
		str := 
		Space                  &amp; Comma &amp;                   //01 - Business Unit Identifier
		Space                  &amp; Comma &amp;                   //02 - Account Class
		Space                  &amp; Comma &amp;                   //03 - Amount
		Space                  &amp; Comma &amp;                   //04 - Percent
		Space                  &amp; Comma &amp;                   //05 - Accounted Amount in Ledger Currency
		Space                  &amp; Comma &amp;                   //06 - Line Transactions Flexfield Context
		mapper(_cashCredit,"sequenceNum")    &amp; Comma &amp;     //07 - Line Transactions Flexfield Segment 1     - Mandatory
		Space                  &amp; Comma &amp;                   //08 - Line Transactions Flexfield Segment 2
		Space                  &amp; Comma &amp;                   //09 - Line Transactions Flexfield Segment 3
		Space                  &amp; Comma &amp;                   //10 - Line Transactions Flexfield Segment 4
		Space                  &amp; Comma &amp;                   //11 - Line Transactions Flexfield Segment 5
		Space                  &amp; Comma &amp;                   //12 - Line Transactions Flexfield Segment 6
		Space                  &amp; Comma &amp;                   //13 - Line Transactions Flexfield Segment 7
		Space                  &amp; Comma &amp;                   //14 - Line Transactions Flexfield Segment 8
		Space                  &amp; Comma &amp;                   //15 - Line Transactions Flexfield Segment 9
		Space                  &amp; Comma &amp;                   //16 - Line Transactions Flexfield Segment 10
		Space                  &amp; Comma &amp;                   //17 - Line Transactions Flexfield Segment 11
		Space                  &amp; Comma &amp;                   //18 - Line Transactions Flexfield Segment 12
		Space                  &amp; Comma &amp;                   //19 - Line Transactions Flexfield Segment 13
		Space                  &amp; Comma &amp;                   //20 - Line Transactions Flexfield Segment 14
		Space                  &amp; Comma &amp;                   //21 - Line Transactions Flexfield Segment 15
		Space                  &amp; Comma &amp;                   //22 - Accounting Flexfield Segment 1
		strGL2                 &amp; Comma &amp;                   //23 - Accounting Flexfield Segment 2            - Mandatory
		strGL3                 &amp; Comma &amp;                   //24 - Accounting Flexfield Segment 3            - Mandatory
		strGL4                 &amp; Comma &amp;                   //25 - Accounting Flexfield Segment 4            - Mandatory
		Space                  &amp; Comma &amp;                   //26 - Accounting Flexfield Segment 5
		Space                  &amp; Comma &amp;                   //27 - Accounting Flexfield Segment 6
		Space                  &amp; Comma &amp;                   //28 - Accounting Flexfield Segment 7
		Space                  &amp; Comma &amp;                   //29 - Accounting Flexfield Segment 8
		Space                  &amp; Comma &amp;                   //30 - Accounting Flexfield Segment 9
		Space                  &amp; Comma &amp;                   //31 - Accounting Flexfield Segment 10
		Space                  &amp; Comma &amp;                   //32 - Accounting Flexfield Segment 11
		Space                  &amp; Comma &amp;                   //33 - Accounting Flexfield Segment 12
		Space                  &amp; Comma &amp;                   //34 - Accounting Flexfield Segment 13
		Space                  &amp; Comma &amp;                   //35 - Accounting Flexfield Segment 14
		Space                  &amp; Comma &amp;                   //36 - Accounting Flexfield Segment 15
		Space                  &amp; Comma &amp;                   //37 - Accounting Flexfield Segment 16
		Space                  &amp; Comma &amp;                   //38 - Accounting Flexfield Segment 17
		Space                  &amp; Comma &amp;                   //39 - Accounting Flexfield Segment 18
		Space                  &amp; Comma &amp;                   //40 - Accounting Flexfield Segment 19
		Space                  &amp; Comma &amp;                   //41 - Accounting Flexfield Segment 20
		Space                  &amp; Comma &amp;                   //42 - Accounting Flexfield Segment 21
		Space                  &amp; Comma &amp;                   //43 - Accounting Flexfield Segment 22
		Space                  &amp; Comma &amp;                   //44 - Accounting Flexfield Segment 23
		Space                  &amp; Comma &amp;                   //45 - Accounting Flexfield Segment 24
		Space                  &amp; Comma &amp;                   //46 - Accounting Flexfield Segment 25
		Space                  &amp; Comma &amp;                   //47 - Accounting Flexfield Segment 26
		Space                  &amp; Comma &amp;                   //48 - Accounting Flexfield Segment 27
		Space                  &amp; Comma &amp;                   //49 - Accounting Flexfield Segment 28
		Space                  &amp; Comma &amp;                   //50 - Accounting Flexfield Segment 29
		Space                  &amp; Comma &amp;                   //51 - Accounting Flexfield Segment 30
		Space                  &amp; Comma &amp;                   //52 - Comments
		Space                  &amp; Comma &amp;                   //53 - Interim Tax Segment 1
		Space                  &amp; Comma &amp;                   //54 - Interim Tax Segment 2
		Space                  &amp; Comma &amp;                   //55 - Interim Tax Segment 3
		Space                  &amp; Comma &amp;                   //56 - Interim Tax Segment 4
		Space                  &amp; Comma &amp;                   //57 - Interim Tax Segment 5
		Space                  &amp; Comma &amp;                   //58 - Interim Tax Segment 6
		Space                  &amp; Comma &amp;                   //59 - Interim Tax Segment 7
		Space                  &amp; Comma &amp;                   //60 - Interim Tax Segment 8
		Space                  &amp; Comma &amp;                   //61 - Interim Tax Segment 9
		Space                  &amp; Comma &amp;                   //62 - Interim Tax Segment 10
		Space                  &amp; Comma &amp;                   //63 - Interim Tax Segment 11
		Space                  &amp; Comma &amp;                   //64 - Interim Tax Segment 12
		Space                  &amp; Comma &amp;                   //65 - Interim Tax Segment 13
		Space                  &amp; Comma &amp;                   //66 - Interim Tax Segment 14
		Space                  &amp; Comma &amp;                   //67 - Interim Tax Segment 15
		Space                  &amp; Comma &amp;                   //68 - Interim Tax Segment 16
		Space                  &amp; Comma &amp;                   //69 - Interim Tax Segment 17
		Space                  &amp; Comma &amp;                   //70 - Interim Tax Segment 18
		Space                  &amp; Comma &amp;                   //71 - Interim Tax Segment 19
		Space                  &amp; Comma &amp;                   //72 - Interim Tax Segment 20
		Space                  &amp; Comma &amp;                   //73 - Interim Tax Segment 21
		Space                  &amp; Comma &amp;                   //74 - Interim Tax Segment 22
		Space                  &amp; Comma &amp;                   //75 - Interim Tax Segment 23
		Space                  &amp; Comma &amp;                   //76 - Interim Tax Segment 24
		Space                  &amp; Comma &amp;                   //77 - Interim Tax Segment 25
		Space                  &amp; Comma &amp;                   //78 - Interim Tax Segment 26
		Space                  &amp; Comma &amp;                   //79 - Interim Tax Segment 27
		Space                  &amp; Comma &amp;                   //80 - Interim Tax Segment 28
		Space                  &amp; Comma &amp;                   //81 - Interim Tax Segment 29
		Space                  &amp; Comma &amp;                   //82 - Interim Tax Segment 30
		Space                  &amp; Comma &amp;                   //83 - Interface Distributions Flexfield Context
		Space                  &amp; Comma &amp;                   //84 - Interface Distributions Flexfield Segment 1
		Space                  &amp; Comma &amp;                   //85 - Interface Distributions Flexfield Segment 2
		Space                  &amp; Comma &amp;                   //86 - Interface Distributions Flexfield Segment 3
		Space                  &amp; Comma &amp;                   //87 - Interface Distributions Flexfield Segment 4
		Space                  &amp; Comma &amp;                   //88 - Interface Distributions Flexfield Segment 5
		Space                  &amp; Comma &amp;                   //89 - Interface Distributions Flexfield Segment 6
		Space                  &amp; Comma &amp;                   //90 - Interface Distributions Flexfield Segment 7
		Space                  &amp; Comma &amp;                   //91 - Interface Distributions Flexfield Segment 8
		Space                  &amp; Comma &amp;                   //92 - Interface Distributions Flexfield Segment 9
		Space                  &amp; Comma &amp;                   //93 - Interface Distributions Flexfield Segment 10
		Space                  &amp; Comma &amp;                   //94 - Interface Distributions Flexfield Segment 11
		Space                  &amp; Comma &amp;                   //95 - Interface Distributions Flexfield Segment 12
		Space                  &amp; Comma &amp;                   //96 - Interface Distributions Flexfield Segment 13
		Space                  &amp; Comma &amp;                   //97 - Interface Distributions Flexfield Segment 14
		Space                  &amp; Comma &amp;                   //98 - Interface Distributions Flexfield Segment 15
		Space                  &amp; Comma &amp;                   //99 - *Business Unit Name
		Space                  ;		                   //100 - END
	
		_file.writeLine(str);
	endforeach;
epilog

end;</source>
        <Parameter name="_file" type="File" usage="input"/>
        <Parameter name="_cashCredit" type="CM_CashCredit"/>
    </JadeMethod>
    <JadeMethod name="createCashCredit2" id="41b2fee0-492f-4d9f-bb0b-b4572c34d840">
        <source>createCashCredit2(_file : File input; _cashCredit : CM_CashCredit);
/*

Purpose:			
		Mapping RaInterfaceLinesAll , 331 Col
		Mandatory Col: 13
Parameters:			

Return Value:		

Date		Who		Reason
13 Dec 2019 cnwma1 ChangeRequest 47851: QTS - Integration with Oracle Fusion Cloud

*/

vars
	str,
	strBillTo,
	strLineDesc,
	strQty,
	strRate,
	strTaxAmt,
	strVoyCode,
	strVslName,
	strUserCode,
	strInvNbr,
	strCustName,
	strComments,
	strCashRec,
	strDate			: String;
	   
	date 			: Date;
	cashRec         : CM_CashReceipt;
	cashPayment     : CM_CashPayment;
	creditDetail    : CM_CashCreditDetail;
	voyage          : CM_Voyage;
	fileEx			: FileException;
begin
	
	on FileException do self.fileExceptionHandler(fileEx);
	date    	:= _cashCredit.createdTime.Date;
	strDate  	:= date.asStringForWebInterface;
	
	foreach creditDetail in _cashCredit.allDerivedFromCreditDetails discreteLock do
		
		//Clear First 
		strBillTo 	:= null;
		strLineDesc := null;
		strQty      := null;
		strRate     := null;
		strCustName := null;
		strTaxAmt   := null;
		strVoyCode  := null;
		strVslName  := null;
		strUserCode := null;
		strCashRec  := null;
		voyage      := null;
		cashRec     := null;
		
		if creditDetail.myCashPayment &lt;&gt; null then
			strQty 	  := creditDetail.myCashPayment.getPaymentQuantity().String;
			strRate   := creditDetail.myCashPayment.getPaymentRate().String;
			strTaxAmt := creditDetail.myCashPayment.getTaxAmountForPayment().String;
			if creditDetail.myCashPayment.getPaymentnvoiceLineType &lt;&gt; null then
				strLineDesc := creditDetail.myCashPayment.getPaymentnvoiceLineType.narration;
			endif;
			
			if creditDetail.myCashPayment.myCashReceipt &lt;&gt; null then
				cashRec 	:= creditDetail.myCashPayment.myCashReceipt;
				
				if cashRec &lt;&gt; null then
					strBillTo   := cashRec.getDebtor.decfinName;
					strCustName := cashRec.getDebtor.name;
					strCashRec  := cashRec.externalInvoiceNumber;
					if cashRec.myVoyage &lt;&gt; null then
						voyage 		 := cashRec.myVoyage;
						strVoyCode   := voyage.code;
						
						if voyage.getMyVessel &lt;&gt; null then
							strVslName := voyage.getMyVessel.name;
						endif;
					endif;
					if cashRec.myUser &lt;&gt; null then
						strUserCode := cashRec.myUser.code;
					endif;
					
					if cashRec.myCashInvoice &lt;&gt; null then
						//strInvNbr 	:= cashRec.myCashInvoice.externalFinancialId;
						strInvNbr 	:= cashRec.myCashInvoice.getExternalFinancialId(); //08/12/2025	navkc1 JIRA 36262
						strComments := cashRec.myCashInvoice.narration;
					endif;
				endif;
			endif;
		endif;
		
		str := 
		Space                  &amp; Comma &amp;                   //001 - Business Unit Identifier
		Space                  &amp; Comma &amp;                   //002 - Transaction Batch Source Name
		self.Type_Credit_Memo               &amp; Comma &amp;      //003 - Transaction Type Name										- Mandatory
		Space                  &amp; Comma &amp;                   //004 - Payment Terms
		strDate                &amp; Comma &amp;                   //005 - Transaction Date                                             - Mandatory
		Space                  &amp; Comma &amp;                   //006 - Accounting Date
		mapper(_cashCredit,"sequenceNum")   &amp; Comma &amp;      //007 - Transaction Number                                           - Mandatory
		Space                  &amp; Comma &amp;                   //008 - Original System Bill-to Customer Reference
		Space                  &amp; Comma &amp;                   //009 - Original System Bill-to Customer Address Reference
		Space                  &amp; Comma &amp;                   //010 - Original System Bill-to Customer Contact Reference
		Space                  &amp; Comma &amp;                   //011 - Original System Ship-to Customer Reference
		Space                  &amp; Comma &amp;                   //012 - Original System Ship-to Customer Address Reference
		Space                  &amp; Comma &amp;                   //013 - Original System Ship-to Customer Contact Reference
		Space                  &amp; Comma &amp;                   //014 - Original System Ship-to Customer Account Reference
		Space                  &amp; Comma &amp;                   //015 - Original System Ship-to Customer Account Address Reference
		Space                  &amp; Comma &amp;                   //016 - Original System Ship-to Customer Account Contact Reference
		Space                  &amp; Comma &amp;                   //017 - Original System Sold-to Customer Reference
		Space                  &amp; Comma &amp;                   //018 - Original System Sold-to Customer Account Reference
		strBillTo              &amp; Comma &amp;                   //019 - Bill-to Customer Account Number                              - Mandatory
		"TBC"                  &amp; Comma &amp;                   //020 - Bill-to Customer Site Number                                 - Mandatory
		Space                  &amp; Comma &amp;                   //021 - Bill-to Contact Party Number
		Space                  &amp; Comma &amp;                   //022 - Ship-to Customer Account Number
		Space                  &amp; Comma &amp;                   //023 - Ship-to Customer Site Number
		Space                  &amp; Comma &amp;                   //024 - Ship-to Contact Party Number
		Space                  &amp; Comma &amp;                   //025 - Sold-to Customer Account Number
		Space                  &amp; Comma &amp;                   //026 - Transaction Line Type
		strLineDesc            &amp; Comma &amp;                   //027 - Transaction Line Description                                 - Mandatory
		Space                  &amp; Comma &amp;                   //028 - Currency Code
		Space                  &amp; Comma &amp;                   //029 - Currency Conversion Type
		Space                  &amp; Comma &amp;                   //030 - Currency Conversion Date
		Space                  &amp; Comma &amp;                   //031 - Currency Conversion Rate
		creditDetail.cashValue.String      &amp; Comma &amp;       //032 - Transaction Line Amount                                      - Mandatory
		strQty                 &amp; Comma &amp;                   //033 - Transaction Line Quantity                                    - Mandatory
		Space                  &amp; Comma &amp;                   //034 - Customer Ordered Quantity 
		strRate                &amp; Comma &amp;                   //035 - Unit Selling Price                                           - Mandatory
		Space                  &amp; Comma &amp;                   //036 - Unit Standard Price
		Space                  &amp; Comma &amp;                   //037 - Line Transactions Flexfield Context
		_cashCredit.sequenceNum.String	   &amp; Comma &amp;  	   //038 - Line Transactions Flexfield Segment 1                        - Mandatory
		Space                  &amp; Comma &amp;                   //039 - Line Transactions Flexfield Segment 2
		Space                  &amp; Comma &amp;                   //040 - Line Transactions Flexfield Segment 3
		Space                  &amp; Comma &amp;                   //041 - Line Transactions Flexfield Segment 4
		Space                  &amp; Comma &amp;                   //042 - Line Transactions Flexfield Segment 5
		Space                  &amp; Comma &amp;                   //043 - Line Transactions Flexfield Segment 6
		Space                  &amp; Comma &amp;                   //044 - Line Transactions Flexfield Segment 7
		Space                  &amp; Comma &amp;                   //045 - Line Transactions Flexfield Segment 8
		Space                  &amp; Comma &amp;                   //046 - Line Transactions Flexfield Segment 9
		Space                  &amp; Comma &amp;                   //047 - Line Transactions Flexfield Segment 10
		Space                  &amp; Comma &amp;                   //048 - Line Transactions Flexfield Segment 11
		Space                  &amp; Comma &amp;                   //049 - Line Transactions Flexfield Segment 12
		Space                  &amp; Comma &amp;                   //050 - Line Transactions Flexfield Segment 13
		Space                  &amp; Comma &amp;                   //051 - Line Transactions Flexfield Segment 14
		Space                  &amp; Comma &amp;                   //052 - Line Transactions Flexfield Segment 15
		Space                  &amp; Comma &amp;                   //053 - Primary Salesperson Number
		Space                  &amp; Comma &amp;                   //054 - Tax Classification Code
		Space                  &amp; Comma &amp;                   //055 - Legal Entity Identifier
		Space                  &amp; Comma &amp;                   //056 - Accounted Amount in Ledger Currency
		Space                  &amp; Comma &amp;                   //057 - Sales Order Number
		Space                  &amp; Comma &amp;                   //058 - Sales Order Date
		Space                  &amp; Comma &amp;                   //059 - Actual Ship Date
		Space                  &amp; Comma &amp;                   //060 - Warehouse Code
		Space                  &amp; Comma &amp;                   //061 - Unit of Measure Code
		Space                  &amp; Comma &amp;                   //062 - Unit of Measure Name
		Space                  &amp; Comma &amp;                   //063 - Invoicing Rule Name
		Space                  &amp; Comma &amp;                   //064 - Revenue Scheduling Rule Name
		Space                  &amp; Comma &amp;                   //065 - Number of Revenue Periods
		Space                  &amp; Comma &amp;                   //066 - Revenue Scheduling Rule Start Date
		Space                  &amp; Comma &amp;                   //067 - Revenue Scheduling Rule End Date
		Space                  &amp; Comma &amp;                   //068 - Reason Code Meaning
		Space                  &amp; Comma &amp;                   //069 - Last Period to Credit
		Space                  &amp; Comma &amp;                   //070 - Transaction Business Category Code
		Space                  &amp; Comma &amp;                   //071 - Product Fiscal Classification Code
		Space                  &amp; Comma &amp;                   //072 - Product Category Code
		Space                  &amp; Comma &amp;                   //073 - Product Type
		Space                  &amp; Comma &amp;                   //074 - Line Intended Use Code
		Space                  &amp; Comma &amp;                   //075 - Assessable Value
		Space                  &amp; Comma &amp;                   //076 - Document Sub Type
		Space                  &amp; Comma &amp;                   //077 - Default Taxation Country
		Space                  &amp; Comma &amp;                   //078 - User Defined Fiscal Classification
		Space                  &amp; Comma &amp;                   //079 - Tax Invoice Number
		Space                  &amp; Comma &amp;                   //080 - Tax Invoice Date
		Space                  &amp; Comma &amp;                   //081 - Tax Regime Code
		Space                  &amp; Comma &amp;                   //082 - Tax
		Space                  &amp; Comma &amp;                   //083 - Tax Status Code
		Space                  &amp; Comma &amp;                   //084 - Tax Rate Code
		Space                  &amp; Comma &amp;                   //085 - Tax Jurisdiction Code
		Space                  &amp; Comma &amp;                   //086 - First Party Registration Number
		Space                  &amp; Comma &amp;                   //087 - Third Party Registration Number
		Space                  &amp; Comma &amp;                   //088 - Final Discharge Location
		Space                  &amp; Comma &amp;                   //089 - Taxable Amount
		Space                  &amp; Comma &amp;                   //090 - Taxable Flag
		Space                  &amp; Comma &amp;                   //091 - Tax Exemption Flag
		Space                  &amp; Comma &amp;                   //092 - Tax Exemption Reason Code
		Space                  &amp; Comma &amp;                   //093 - Tax Exemption Reason Code Meaning
		Space                  &amp; Comma &amp;                   //094 - Tax Exemption Certificate Number
		Space                  &amp; Comma &amp;                   //095 - Line Amount Includes Tax Flag
		Space                  &amp; Comma &amp;                   //096 - Tax Precedence
		Space                  &amp; Comma &amp;                   //097 - Credit Method To Be Used For Lines With Revenue Scheduling Rules
		Space                  &amp; Comma &amp;                   //098 - Credit Method To Be Used For Transactions With Split Payment Terms
		Space                  &amp; Comma &amp;                   //099 - Reason Code
		Space                  &amp; Comma &amp;                   //100 - Tax Rate
		Space                  &amp; Comma &amp;                   //101 - FOB Point
		Space                  &amp; Comma &amp;                   //102 - Carrier
		Space                  &amp; Comma &amp;                   //103 - Shipping Reference
		Space                  &amp; Comma &amp;                   //104 - Sales Order Line Number
		Space                  &amp; Comma &amp;                   //105 - Sales Order Source
		Space                  &amp; Comma &amp;                   //106 - Sales Order Revision Number
		Space                  &amp; Comma &amp;                   //107 - Purchase Order Number
		Space                  &amp; Comma &amp;                   //108 - Purchase Order Revision Number
		Space                  &amp; Comma &amp;                   //109 - Purchase Order Date
		Space                  &amp; Comma &amp;                   //110 - Agreement Name
		Space                  &amp; Comma &amp;                   //111 - Memo Line Name
		Space                  &amp; Comma &amp;                   //112 - Document Number
		Space                  &amp; Comma &amp;                   //113 - Original System Batch Name
		Space                  &amp; Comma &amp;                   //114 - Link-to Transactions Flexfield Context
		Space                  &amp; Comma &amp;                   //115 - Link-to Transactions Flexfield Segment 1
		Space                  &amp; Comma &amp;                   //116 - Link-to Transactions Flexfield Segment 2
		Space                  &amp; Comma &amp;                   //117 - Link-to Transactions Flexfield Segment 3
		Space                  &amp; Comma &amp;                   //118 - Link-to Transactions Flexfield Segment 4
