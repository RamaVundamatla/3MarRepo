vars

begin
	unloadForm;
end;</source>
        <Parameter name="jadeMask" type="JadeMask" usage="input"/>
    </JadeMethod>
    <JadeMethod name="mskWWW_click" id="bea401a8-cbe4-49ed-87fc-f3c534bdab36">
        <controlMethod name="JadeMask::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mskWWW_click(jadeMask: JadeMask input) updating;
/*

Date		Who		Reason
10 Oct 2016	cnwkpd1	TFS JMT 2805 - JADE 7.1.08 upgrade
	
*/

vars
	result :	Integer;
begin
	result := call josShellExecute(null, 'open', 'http://www.jadeworld.com', null, null, 1);
	if result &lt;= 32 then
		app.msgBox('You do not have a default browser or the URL http://www.jadeworld.com could not be found', 'Error', MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
end;</source>
        <Parameter name="jadeMask" type="JadeMask" usage="input"/>
    </JadeMethod>
    <JadeMethod name="unload" id="17caf286-3ee1-4e6e-9a04-e94ec823331c">
        <controlMethod name="Form::unload"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>unload() updating;

begin
	endTimer(0);
	formUnloaded := true;
end;</source>
    </JadeMethod>
