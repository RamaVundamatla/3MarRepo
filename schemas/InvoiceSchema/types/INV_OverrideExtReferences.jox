    <JadeMethod name="populateInvoiceDetails" id="116ab49e-a3b1-444e-8d64-d03b40990dd4">
        <source>populateInvoiceDetails();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
//08/12/2025	navkc1 JIRA 36262 ROS - 1 - External Reference updates in MTN 

*/

vars
	cmif		: CMIF_InvoiceExternalRefHeader;
begin

	cmif := self.myCMIFHeader;
	
	self.lblInvoiceIDData.caption 		:= cmif.invoiceID;
	self.lblInvoiceLinesData.caption 	:= cmif.numberOfLines.String;
	self.lblTotalData.caption			:= cmif.total.asStringJMTWithPrecision(2, true);
	
	self.txtExtFinID.text				:= cmif.externalFinancialID;
	self.txtExtNumber.text				:= cmif.externalNumber;
	self.txtExtTaxNum.text				:= cmif.externalTaxNumber;
epilog

end;</source>
