    <JadeMethod name="setUsage" id="f84a7611-a72c-4320-8d49-e18f8a0a274b">
        <updating/>
        <source>setUsage(_type, _terminalAreaType : Integer; _picture : Picture ) updating;

vars
	gapWidth : Real;
begin
	
	gapWidth := self.myGridController.width;					//preserve width for gap controllers
	
	// cnwjk3 CCMS 1032 15/12/2008
	//self.myPicture := _picture;
	
	// cnwjk3 CCMS 1032 15/12/2008
	//self.letter := null;
	
	if _terminalAreaType = TA_TYPE_RTG or
		_terminalAreaType = TA_TYPE_RMG then //epr par 23014 9/3/10 
		if self.myGridController.isKindOf(CM_RTGLaneController) then
			return;
		endif;
		//epr par 18187 23/10/08
		if self.myGridController.isKindOf(CM_GapController) and self.myGridController.myGridRow.hasGap then
			return;
		endif;
		self.setControllerType(CM_RTGController);
	else
		if not (_type = LOC_Display_HasPower and self.myGridController.isKindOf(CM_GapController)) then // if we have set the location already to a gap controller and set power we want a powered gap controller so dont reset to stack controller , cnwrd1 31313 
			self.setControllerType(CM_StackController);	
		endif;
	endif;

	
	// cnwjk3 CCMS 1032 15/12/2008
	if _type &lt;&gt; LOC_Display_DoorFwd and _type &lt;&gt; LOC_Display_DoorAft and _type &lt;&gt; LOC_Display_TwinLift then
		self.myGridController.setUsage(NORMAL_USE);
		self.letter := null;
		self.myGridController.setAvailability(PAD_AVAILABLE);
		self.myGridController.setWidth(DefaultWidth);
		self.myPicture := _picture;
	endif;
	
	// cnwjk3 CCMS 1032 15/12/2008
	//self.myGridController.setAvailability(PAD_AVAILABLE);
	//self.myGridController.setUsage(NORMAL_USE);
	//self.myGridController.setWidth(DefaultWidth);
//	self.setPower(self.myGridController.power);

	if _type = LOC_Display_Available then
		self.myGridController.setIs45ft(false);
		self.myGridController.setOffset45ft(null);
		self.myGridController.setIs30ft(false); // PAR 16415 CCMS 1029
		self.myGridController.setOffset30ft(null); // PAR 16415 CCMS 1029
		self.myGridController.setIs53ft(false); // PAR 16415 CCMS 1029
		self.myGridController.setOffset53ft(null); // PAR 16415 CCMS 1029
		self.myGridController.setIs40ft(false); // PAR 18682 CCMS SFW 1055
		self.myGridController.setOffset40ft(null); // PAR 18682 CCMS SFW 1055
		self.myGridController.setIs20ft(false);		// 20ft has been missed. Par 18997 Mar 2009
		self.setPower(false);
		
		// cnwjk3 CCMS 1032 15/12/2008
		self.myGridController.setDoorDirection(0);
		self.myGridController.setCanTwinLiftWithNext(false); 
		self.myGridController.setCanTwinLiftWithPrev(false); 

	else
		self.setPower(self.myGridController.power);
	endif;
	
	if _type = LOC_Display_Unavailable then
		self.myGridController.setAvailability(PAD_UNAVAILABLE);
		self.myGridController.setUsage(UNAVAILABLE_USE);
		self.letter := PicTIUnavail;
		self.setPower(false);
	elseif _type = LOC_Display_HasPower then
		// AKB2009MAR this is correct, please leave this.
		// In Fork Lift Stacks (Gridded Block Stacks) power only has to be available somewhere, but it is not on a stack controller it is always in a gap.
		// So if we have power in a FLS (GBS) it is always on a gap. The idea is that the area has a whole column specified as a gap, although individual locations can also be specified as gaps.
		// This is how it was designed and this is how it works. 
		// For Fork Lift Stacks the move code checks that there is power some where in the area, removing the following code breaks that.
		// For Fork Lift Stacks the connect to power dialogue and hand helds use methods that gather the power points in the area, removing the following code breaks that.
		
		//cnwrd1 par 31313 NFS we are changing GBS power to work like straddle stacks but keeping the old method also. If they (mainly Nelson) want it to work as it did you need to set a location as a gap before adding power.
		/*if _terminalAreaType = TA_TYPE_FORK_LIFT_STACK then	// exception for gridded block stack. Par 19190
			self.setControllerType(CM_GapController);
		endif;*/
		
		
		
		
		self.myGridController.setAvailability(PAD_AVAILABLE);
		self.myGridController.setUsage(NORMAL_USE);
		self.setPower(true);
		self.letter := PicTIPower;
	
	elseif _type = LOC_Display_45ft then // and _terminalAreaType = TA_TYPE_RTG then
		self.myGridController.setAvailability(PAD_AVAILABLE);
		self.myGridController.setUsage(NORMAL_USE);
		self.myGridController.setIs45ft((not self.myGridController.is45ft));
		// PAR 18682
	elseif _type = LOC_Display_40ft then
		self.myGridController.setAvailability(PAD_AVAILABLE);
		self.myGridController.setUsage(NORMAL_USE);
		self.myGridController.setIs40ft((not self.myGridController.is40ft));
		// PAR 18682
	elseif _type = LOC_Display_20ft then
		self.myGridController.setAvailability(PAD_AVAILABLE);
		self.myGridController.setUsage(NORMAL_USE);
		self.myGridController.setIs20ft((not self.myGridController.is20ft));
	elseif _type = LOC_Display_30ft then
		self.myGridController.setAvailability(PAD_AVAILABLE);
		self.myGridController.setUsage(NORMAL_USE);
		self.myGridController.setIs30ft((not self.myGridController.is30ft));
	elseif _type = LOC_Display_53ft then
		self.myGridController.setAvailability(PAD_AVAILABLE);
		self.myGridController.setUsage(NORMAL_USE);
		self.myGridController.setIs53ft((not self.myGridController.is53ft));
		
	elseif _type = LOC_Display_ReeferGantry then
		self.myGridController.setUsage(REEFERGANTRY_USE);
		self.setPower(true);
		self.letter := PicTIReeferGantry;
	
	elseif _type = LOC_Display_LightTower then
		self.myGridController.setAvailability(PAD_UNAVAILABLE);
		self.myGridController.setUsage(LIGHT_TOWER_USE);
		self.letter := PicTILight;

	elseif _type = LOC_Display_Building then
		self.myGridController.setUsage(BUILDING_USE);
		self.letter := PicTIBuilding;
			
	elseif _type= LOC_Display_Gap then
		self.setControllerType(CM_GapController);
		self.myGridController.setAvailability(PAD_UNAVAILABLE);
		self.myGridController.setUsage(UNAVAILABLE_USE);
		self.myGridController.setWidth(gapWidth);
		self.letter := PicTIGap;
		self.setPower(false);
	elseif _type= LOC_Display_Overhang then
		self.setControllerType(CM_OverhangController);
		self.myGridController.setAvailability(PAD_UNAVAILABLE);
		self.myGridController.setUsage(UNAVAILABLE_USE);
		self.myGridController.setWidth(7);
		self.setPower(false);
		
	elseif _type = LOC_Display_PowerTower then
		self.setControllerType(CM_GapController);
		self.myGridController.setAvailability(PAD_UNAVAILABLE);
		self.myGridController.setUsage(UNAVAILABLE_USE);
		self.setPower(true);
		// Used for fork lift stacks.
		self.letter := PicTIPower;
		
	elseif _type = LOC_Display_RTG then
		self.setControllerType(CM_RTGController);
		self.myGridController.setAvailability(PAD_AVAILABLE);
		self.myGridController.setUsage(NORMAL_USE);
		self.letter := null;

	// cnwjk3 CCMS 1032 15/12/2008
	elseif _type = LOC_Display_DoorFwd then
			self.myGridController.setDoorDirection(DoorDirectionForward);
	elseif _type = LOC_Display_DoorAft then
			self.myGridController.setDoorDirection(DoorDirectionAft);
	endif;

	
end;

</source>
        <Parameter name="_type" type="Integer"/>
