    <JadeMethod name="isOnSiteOnShip" id="7dbfb500-1b94-439e-adaa-80325900ca83">
        <source>isOnSiteOnShip(): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 August 2023 navmv20 Bug 59697: EUP - Change of Ownership Cargo Review - Able to create COO for Offsite Cargo

*/

vars
	cgDtl : CM_CargoGroupDetail;
		ti : CM_TrackedItem;
begin
	// ### JIRA 34108 28FEB2025 NAVAB1 - only EUP have cargo group details.
	if self.allCargoGroupDetails.isEmpty() then
		foreach ti in self.allAssignedTrackedItems discreteLock do
			if ti.isOnSiteOnShip then
				return true;
			endif;
		endforeach;
	else
		foreach cgDtl in self.allCargoGroupDetails do
			if cgDtl.site = TI_SITE_ONSITE or cgDtl.site = TI_SITE_ONSHIP then
				return true;
			endif;
		endforeach;
	endif;
	
	return false;
epilog

end;</source>
