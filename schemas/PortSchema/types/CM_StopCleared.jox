    <JadeMethod name="setClearanceExpiryDate" id="493ad040-2af6-44dc-a617-b93552b4b756">
        <updating/>
        <source>setClearanceExpiryDate( _value : Date ) updating;

/*
Date			Who		Reason
31 August 2010	cnwrl1	Initial creation as part of PAR 23697 - CCMS 1097 - Stop Expiry - retain info after expiry.
*/
	
vars
	
begin
	if self.clearanceExpiryDate &lt;&gt; _value then
		self.clearanceExpiryDate	:= _value;
