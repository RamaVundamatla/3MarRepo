	self.frT.boundaryWidth := 0;
	self.frT.borderStyle := 0;
	
	self.frE.caption := null;
	self.frE.bevelInner := 0;
	self.frE.bevelOuter := 0;
	self.frE.bevelInnerWidth := 0;
	self.frE.boundaryWidth := 0;
	self.frE.borderStyle := 0;
	/*	
	create self.lblM transient;
	
	self.form.addControl(self.lblM);
	self.lblM.parent := self;
	self.lblM.move(50, 50, 100, 100);	//self.width, self.height);
	self.lblM.visible := true;*/
	

