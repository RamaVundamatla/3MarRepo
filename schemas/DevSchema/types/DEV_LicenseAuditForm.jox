	self.setupForm();

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="mnuInspect_click" id="9628a1a0-8310-4e04-9508-75eccd928fb7">
        <controlMethod name="MenuItem::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mnuInspect_click(menuItem: MenuItem input) updating;
/*
Purpose:	

Date		Who		Reason
15 January 2026	navab1	JIRA 35465
*/

vars

begin
	if self.tblData.row &lt;= self.tblData.fixedRows then
		return;
	endif;
	
	self.tblData.accessRow(self.tblData.row).itemObject.inspect;
epilog

end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="1d7164bc-ce4a-4d7c-ba11-d062ca3842ff">
        <updating/>
        <source>setupForm() updating;
/*
Purpose:	

Date		Who		Reason
07 January 2026	navab1	JIRA 35465
*/

vars

begin
	app.initialize();
	self.initTable();
	self.displayAudits();
		
	self.caption := self.caption &amp; " " &amp; app.dbPath;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="tblData_contextMenu" id="01ec273e-c052-4dd7-91a8-d7fbe78c4243">
        <controlMethod name="Table::contextMenu"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblData_contextMenu(table: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating;
/*
Purpose:	

Date		Who		Reason
15 January 2026	navab1	JIRA 35465
*/

vars
	x1 : Real;
	y1 : Real;
	
begin
	x1 := x;
	y1 := y;
	
	if not mouse then
		// if keyboard, default to a known position offset from the control with focus.
	    x1	:= 20;
        y1	:= 20;
	endif;
	conwin.windowToScreen( x1, y1 );
	
	// The screenToWindow method of the Window class converts an absolute screen position into a
	// position relative to the top and left of the window. For example, this method can be used in
	// conjunction with the windowToScreen method to calculate a position of one window relative to another.
	self.screenToWindow( x1, y1);			// convert x, y relative to form
	self.popupMenu( mnuContext, x, y );
	
	return false;                  // cancel further processing

epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="tblData_dblClick" id="14d3bbea-8668-4295-8d7a-5f1f059f0ffe">
        <controlMethod name="CM_DataTable::dblClick"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblData_dblClick(table: Table input) updating;
/*
Purpose:	

Date		Who		Reason
15 January 2026	navab1	JIRA 36920
*/

vars

begin
	if table.row &gt; table.fixedRows then
		return;
	endif;

	if table.sortColumn[1] &gt; 0 then
		table.accessCell(1,table.sortColumn[1]).fontBold := false;
	endif;

	table.sortColumn[1]	:= table.column;    
	if table.column = 1 then
		table.sortType[1] := Table.SortType_TimeStamp;
	else
		table.sortType[1] := Table.SortType_Alpha;
	endif;
	table.sortAsc[1]		:= not table.sortAsc[1];
	table.sortCased[1]	:= false;
	table.resort();
	
	table.accessCell(1,table.column).fontBold := true;
epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
</GUIClass>
