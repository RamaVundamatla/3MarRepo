    <JadeMethod name="movePromotePlannedToQueued" id="e9eb1288-7b9e-44f3-a41e-b101ef6ebeb0">
        <source>movePromotePlannedToQueued(_ti : CM_TrackedItem; _wle : CM_WorkListEntry input );
/*
Purpose:			
Date				Who			Reason
JUNE 2015		CNWAB1		Initial creation
*/

vars

	moveController : CMIF_MoveController;

begin

	create moveController transient;
	moveController.setMyTrackedItem(_ti);
	moveController.setMyOriginatingLocation(_ti.myPrimaryActualLocation);
	moveController.setMoveMode(QUEUE_MODE);	
	moveController.setMyToPrimaryLocation(_ti.myPrimaryPlannedLocation);
	moveController.setMyWorkListEntry(_wle);

	// update the cargo item with the queued move
	app.myPassport.setWarningsIgnored(true);
	app.myTrxUA.trxMoveTrackedItem(moveController, app.myPassport);

epilog

	delete moveController;

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_wle" type="CM_WorkListEntry" usage="input"/>
    </JadeMethod>
    <JadeMethod name="moveQueueUnplannedUnworkCargo" id="71473c5f-1053-4984-9e06-1060aedadd93">
        <source>moveQueueUnplannedUnworkCargo(  _ti : CM_TrackedItem;
								_job : CM_VoyageJob output;
								_wle : CM_WorkListEntry output;
								_quantity : Integer;
								_weight  : Decimal);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 May 2010	cnwndl1	Initial creation	Par 23603

*/

vars

	targetLocn : CM_LocationsController;
	moveController : CMIF_MoveController;
	tiArray	: CM_TIArray;
	params : CMIF_AutoplanParams;
	
begin

	//establish our target location
	if _ti.myPrimaryQueuedLocation &lt;&gt; null then
		targetLocn := _ti.myPrimaryQueuedLocation;
	elseif _ti.myPrimaryPlannedLocation &lt;&gt; null then
		targetLocn := _ti.myPrimaryPlannedLocation;
	else
		// no target known, do an autoplan
		create tiArray transient;
		create params transient;
		params.allTrackedItems.add(_ti);
		params.moveMode := PLANNING_MODE;
		params.myTerminalArea := null;
		params.showWarningWhenNoPlan := false;
		app.myTrxUA.trxUpdateAutoplanTrackedItems(params, app.myPassport);
		if _ti.myPrimaryPlannedLocation &lt;&gt; null then
			targetLocn := _ti.myPrimaryPlannedLocation;
		endif;
	endif;

	// set up the move controller for a queued move
	create moveController transient;
	moveController.setMyTrackedItem(_ti);
	moveController.setMyOriginatingLocation(_ti.myPrimaryActualLocation);
	moveController.setMoveMode(QUEUE_MODE);	
	moveController.setMyToPrimaryLocation(targetLocn);
	//moveController.transferType := VESSEL_TYPE_RORO; // CNWAB1 MAY17 1; // 0 = LOLO 1 = RORO  TFS 4435
	moveController.setTransferTypeFromJob( _job, VESSEL_TYPE_RORO );	//12 Mar 2018	NDL	TFS 37444
	moveController.isNonCraneVoyageMove := true; 
	//epr par 35862 13/3/15
	moveController.setQuantity(_quantity);
	moveController.setWeight(_weight);
	// update the cargo item with the queued move
	app.myPassport.setWarningsIgnored(true);
	app.myTrxUA.trxMoveTrackedItem(moveController, app.myPassport);
	
	if not app.myPassport.trxCompletedOK then
		return;
	endif;
	
	//return the job that was created.
	if moveController.myWorkListEntry &lt;&gt; null then
		_wle := moveController.myWorkListEntry;
		_job := _wle.job.CM_VoyageJob;
	endif;

epilog

	delete moveController;
	delete tiArray;
	delete params;
	
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_job" type="CM_VoyageJob" usage="output"/>
        <Parameter name="_wle" type="CM_WorkListEntry" usage="output"/>
        <Parameter name="_quantity" type="Integer"/>
        <Parameter name="_weight" type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="moveRePlanTi" id="10191433-223c-45c4-8b33-09abf109322b">
        <source>moveRePlanTi( _trackedItem : CM_TrackedItem; _job : CM_Job ): Boolean;
/*
Purpose:			
Date				Who			Reason
JULY 2015		CNWAB1		Initial creation
*/
vars

	tiArray	: CM_TIArray;
	str		: String;
	result	: Integer;
	ti		: CM_TrackedItem;
	params : CMIF_AutoplanParams;

begin

	create tiArray transient;
	create params transient;
	
	if _trackedItem = null then
		return false;
	endif;
	
	if _trackedItem.myPrimaryQueuedLocation &lt;&gt; null then
		if not self.moveUnPlanTi( _trackedItem ) then
			return false;
		endif;
	endif;
	
	params.allTrackedItems.add(_trackedItem);
	params.moveMode := QUEUE_MODE;
	params.myTerminalArea := null;
	params.myJob := _job;	
	params.showWarningWhenNoPlan := true;
		
	app.myTrxUA.trxUpdateAutoplanTrackedItems(params, app.myPassport);
	return app.myPassport.trxCompletedOK;

epilog

	delete tiArray;
	delete params;
end;</source>
        <Parameter name="_trackedItem" type="CM_TrackedItem"/>
        <Parameter name="_job" type="CM_Job"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="moveTI" id="a808e711-b6ab-4744-a127-c5a51eeb0c07">
        <source>moveTI(_ti : CM_TrackedItem; _targetId : String; _targetLc : CM_LocationsController; _wle : CM_WorkListEntry; _skipVerifyQuestion : Boolean; _quantity : Integer; _weight : Decimal) :Boolean;
/*
// ---------------------------------------------------------------------------
// Created:	14 January 2009 By Graeme Black cnwgb1
// Purpose:	Moves a tracked item to a new location
//			PNL CCMS 1658 PAR 18787
// ---------------------------------------------------------------------------
//04Sep2012	cnwrs1	Par30321	if the trx is to be retried then setup the effective date again
	02 Apr 2014 NDL	CCMS 1366
*/
vars
	targetLocn	:CM_LocationsController;
	lcnStr	:String;
	moveController	: CMIF_MoveController;
	result	: Integer;
	foundHeight : Integer;
	rtQueEntry : CM_RTQueueEntry;
	futureMove : CM_FutureMove;
	hideMoveConfirmation : Boolean;
	packToTI 	: CM_TrackedItem;
begin

	if _ti = null then
		return false;
	endif;
	
	if _ti &lt;&gt; null then
		if _ti.isOffSite() then
			app.raiseCMException1(Cargo_offsite_cannot_moved, _ti.id,null,null);
			return false;
		endif;
	endif;

	
	on CM_Exception do app.validationExHandler(exception, app.myPassport);
	app.setContinueCMExceptions(true);
//	app.myPassport.clearErrorsWarnings();

	// If the user selected the location from the combo boxes, then we already have the 
	// location controller. However they may have simply typed the location. In that case
	// we have to find the location controller.
	if _targetLc &lt;&gt; null then
		targetLocn := _targetLc;
	else
		app.myPassport.myTerminal.findLocationFromString(_targetId, false, targetLocn, foundHeight);
	endif;

	// An error occurred finding the location controller
	if app.myPassport.hasErrors then
		return false;
	endif;
	
	if targetLocn &lt;&gt; null then
		lcnStr := targetLocn.getFullId();
	else
		lcnStr := app.getErrorString(Unknown);
		if _wle &lt;&gt;  null and   _wle.isReleaseToPack then
			packToTI:=_wle.getTargetTIForPack;
			if packToTI &lt;&gt; null then
				lcnStr:=packToTI.id;
			endif;
		endif;
	endif;
	
	if targetLocn = null and packToTI = null then
			app.raiseCMException1(Err_InvalidLocation, _targetId,null,null);
		return false;
		
	endif;

	//Check the user really wants to do the move...
	
	create moveController transient;
	moveController.setMyTrackedItem( _ti);
	moveController.setMyToPrimaryLocation(targetLocn);
	moveController.setMoveMode(REAL_MODE); //Instant moves only in the first release
	
	
	// 08 Mar 2010	NDL Par 22657
	if _wle &lt;&gt; null then
		moveController.setMyWorkListEntry(_wle);
		moveController.setJobForMove(_wle.job);
		//25 Mar 2010	NDL Par 23316
		if not _wle.allRTQueueEntries.isEmpty then
			rtQueEntry := _wle.allRTQueueEntries.last;
		endif;
		if rtQueEntry &lt;&gt; null then
			moveController.isRTMultiMove := true;	
			//epr par 36010 14/4/15 seems this just causes issues not needed
			//moveController.myRTQueueEntry := rtQueEntry.getLastRTQueueEntry; //epr par 35702 4/3/15
			moveController.isRadioTelemetryMove := true;
			futureMove := _wle.myFutureMove;
		endif;
	endif;
	
	hideMoveConfirmation := app.myPassport.myTerminal.getConfig(HhMoveConfirmation).Boolean;	// 14/8/17 MAP TFS4719
	if not hideMoveConfirmation then
		moveController.nonWorkedInstantPreMove();	//01 Aug 2013	NDL	Par 32140
	endif;

	if moveController.priority = 888 then		// 28/6/17 MAP TFS4719
		return false;		// user has cancelled attempt to move cargo already planned
	endif;

	while true do
		moveController.setMyTrackedItem( _ti);
		moveController.setMyWorkListEntry(_wle);
		//Do the move
		app.myTrxUA.trxMoveTrackedItemAndUnQueue(moveController, futureMove, null, app.myPassport);
		if app.myPassport.trxCompletedOK then
			app.myPassport.clearErrorsWarnings();
			return true;
		endif;
		return false;
	endwhile;
		
epilog

	delete moveController;
	
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_targetId" type="String"/>
        <Parameter name="_targetLc" type="CM_LocationsController"/>
        <Parameter name="_wle" type="CM_WorkListEntry"/>
        <Parameter name="_skipVerifyQuestion" type="Boolean"/>
        <Parameter name="_quantity" type="Integer"/>
        <Parameter name="_weight" type="Decimal"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
