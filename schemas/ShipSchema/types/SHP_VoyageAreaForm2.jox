//	Created:	12 August 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin
	if self.displayMode = ShpDisplayMode_EDI then
		self.doMnuWorkEDIActClick();
	elseif self.displayMode = ShpDisplayMode_VoyGlobActual 
	or self.displayMode = ShpDisplayMode_VoyGlobProposed then
		self.doMnuGlobalVoyMakeActual(null);
	endif;
end;</source>
