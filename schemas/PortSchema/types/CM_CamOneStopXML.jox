    <JadeMethod name="makeBOLCargoSectionXML" id="3b94b60c-64ed-4cfb-80ab-bf9a38523c5f">
        <source>makeBOLCargoSectionXML( _voyageEvent : CMEVT_VoyageEvent; _messTypeDesc : String; _parentElem : JadeXMLElement input ) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 October 2017	jlgndl1	Initial creation	TFS 6940

*/

vars

	rootElem : JadeXMLElement;
	xmlElem : JadeXMLElement;
	workStr : String;
	isoType : CM_ISOType;
	imexStatus : Integer;
	term : CM_Terminal;
	bol : CM_BOL;

begin

	rootElem := _parentElem.addElement('Cargo');
	
	if _voyageEvent = null or _voyageEvent.myBOL = null then
		return;
	endif;
	
	bol := _voyageEvent.myBOL;
	term := bol.myTerminal;
	
	workStr := "N";
	xmlElem := rootElem.addElement(self.XMLTag_CargoType);
	xmlElem.setText( workStr );
	
	xmlElem := rootElem.addElement('CTO_ReferenceKey');
	xmlElem.setText( bol.getOidString );
	
	workStr := "B/B";
	xmlElem := rootElem.addElement('Status');
	xmlElem.setText( workStr );
	
	workStr := "VESSEL";
	xmlElem := rootElem.addElement('ArrivalCarrierMode');
	xmlElem.setText( workStr );
	
	xmlElem := rootElem.addElement('UN_DischargePortCode');
	xmlElem.setText( term.getConfig(PortDestCode).String.trimBlanks );
	
	xmlElem := rootElem.addElement('OceanBill');
	xmlElem.setText( bol.number );
	
	xmlElem := rootElem.addElement('VesselDischargeIndicator');
	xmlElem.setText( self.getVesselDischargeInd( _messTypeDesc, bol ) );
	
		
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_voyageEvent" type="CMEVT_VoyageEvent"/>
        <Parameter name="_messTypeDesc" type="String"/>
        <Parameter name="_parentElem" type="JadeXMLElement" usage="input"/>
    </JadeMethod>
    <JadeMethod name="makeBOLCommoditySectionXML" id="da4b7c20-c901-4d3e-a3de-c4cb2ef7199c">
        <source>makeBOLCommoditySectionXML( _voyageEvent : CMEVT_VoyageEvent; _messTypeDesc : String; _parentElem : JadeXMLElement input ) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 October 2017	jlgndl1	Initial creation	TFS 6940

*/

vars

	rootElem : JadeXMLElement;
	xmlElem : JadeXMLElement;
	workStr : String;
	bol : CM_BOL;
	
	changeInTotalQuantity : Integer;
	changeInTotalWeight : Decimal [16,3];
	over : Boolean;
	currentTotalQuantity : Integer;
	currentTotalWeight : Decimal [16,3];
	
begin

	rootElem := _parentElem.addElement('Commodity');
	
	if _voyageEvent = null or _voyageEvent.myBOL = null or not _voyageEvent.isVoyBolOutturn then
		return;
	endif;
	
	bol := _voyageEvent.myBOL;
	bol.getOutturnData( changeInTotalQuantity, changeInTotalWeight, over, currentTotalQuantity, currentTotalWeight );
	
	xmlElem := rootElem.addElement('Packages');
//	xmlElem.setText( currentTotalQuantity.String );
	//08 Jan 2018	NDL	TFS 8165
	if changeInTotalQuantity &lt;&gt; 0 then
		xmlElem.setText( changeInTotalQuantity.String );
	endif;
	
	workStr := 'PK';
	xmlElem := rootElem.addElement('PackageType');
	xmlElem.setText( workStr );
	
	if currentTotalQuantity = 1 then
		xmlElem := rootElem.addElement('GrossWeight');
		xmlElem.setText( currentTotalWeight.Integer.String );
	endif;
	
	workStr := 'NIL';
//	if changeInTotalQuantity &lt;&gt; 0 or changeInTotalWeight &lt;&gt; 0 then
	if changeInTotalQuantity &lt;&gt; 0 then	//09 Jan 2018	NDL	TFS 8165
		if over then
			workStr := 'SU'; // Surplus
		else
			workStr := 'SH'; // Shortage
		endif;
	endif;
	xmlElem := rootElem.addElement('OutturnType');
	xmlElem.setText( workStr );
	
	workStr := 'N';
	xmlElem := rootElem.addElement('DamagedIndicator');
	xmlElem.setText( workStr );
	
	workStr := 'N';
	xmlElem := rootElem.addElement('PillagedIndicator');
	xmlElem.setText( workStr );
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_voyageEvent" type="CMEVT_VoyageEvent"/>
        <Parameter name="_messTypeDesc" type="String"/>
        <Parameter name="_parentElem" type="JadeXMLElement" usage="input"/>
    </JadeMethod>
    <JadeMethod name="makeCargoSectionXML" id="8e89b4f7-f8bb-4d2c-9c3f-b630f6925ad8">
        <source>makeCargoSectionXML( _ti : CM_TrackedItem; _messTypeDesc : String; _parentElem : JadeXMLElement input ) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 Aug 2016	cnwndl1	Initial creation	TFS 2561 / 2277
04 Dec 2018 jlggb1  OneStop Discharged messages using outwards voyage code when there is an inwrds code. 42351
20 Jan 2025 naviv1	JIRA MTN-19155 - AAT - Swire Gate Out EDI Mapping
*/

vars

	rootElem : JadeXMLElement;
	xmlElem : JadeXMLElement;
	workStr : String;
	isoType : CM_ISOType;
	imexStatus : Integer;
	term : CM_Terminal;
	
begin

	rootElem := _parentElem.addElement('Cargo');
	
	if _ti = null then
		return;
	endif;
	
	term := _ti.myTerminal;
	
	if _ti.isContainer then
		workStr := "C";
	else
		workStr := "N";
	endif;
	xmlElem := rootElem.addElement(self.XMLTag_CargoType);
	xmlElem.setText( workStr );
	
	xmlElem := rootElem.addElement('CargoNumber');
	xmlElem.setText( _ti.id );
	
	xmlElem := rootElem.addElement('CTO_ReferenceKey');
	xmlElem.setText( _ti.getOidString );
/*	
	xmlElem := rootElem.addElement('OldCTO_ReferenceKey');
	xmlElem.setText( null );
*/	
	//21 Sep 2016	NDL	TFS 2277 - Email to Alison from One Stop. 
	if _messTypeDesc = self.TCHG85 
	or  _messTypeDesc = self.TCHG82
	then
		workStr := _ti.getPreviousId();	
		if workStr &lt;&gt; null then
			xmlElem := rootElem.addElement('OldNumber');
			xmlElem.setText( workStr );
		endif;
	endif;
	
	isoType := _ti.getISOTypeObject;
	if isoType &lt;&gt; null then
		xmlElem := rootElem.addElement('ISO_Code');
		xmlElem.setText( isoType.code );
		
		xmlElem := rootElem.addElement('ISO_Description');
		xmlElem.setText( isoType.description );
	endif;
/*	
	xmlElem := rootElem.addElement('NOR');
	xmlElem.setText( null );
	
	xmlElem := rootElem.addElement('Type');
	xmlElem.setText( null );
	
	xmlElem := rootElem.addElement('ServiceType');
	xmlElem.setText( null );
	
	xmlElem := rootElem.addElement('Tynes');
	xmlElem.setText( null );
	
	xmlElem := rootElem.addElement('TareWeight');
	xmlElem.setText( _ti.weightTare );
*/	
	xmlElem := rootElem.addElement('GrossWeight');
	xmlElem.setText( _ti.totalWeight.Integer.String );
/*	
	xmlElem := rootElem.addElement('NetWeight');
	xmlElem.setText( _ti.cargoWeight );
*/	
	workStr := null;
	if _ti.isContainer then
		if _ti.CM_Container.contentsStatus = 3 then
			workStr := "E";
		elseif _ti.CM_Container.contentsStatus = 2 then
			workStr := "LCL";
		elseif _ti.CM_Container.contentsStatus = 1 then
			workStr := "FCL";
		endif;
	elseif _ti.myCargoType.isBulkByQuantity or _ti.myCargoType.isBulkByWeight or _ti.myCargoType.isBulkByVolume  then
		workStr := "BLK";
	elseif _ti.myCargoType.isBreakBulk then
		workStr := "B/B";
	endif;
	xmlElem := rootElem.addElement('Status');
	xmlElem.setText( workStr );
	
	workStr := null;
	imexStatus := _ti.getImExStatus();
	// E-Export, I-Import, H-Storage, S-StayOnBoard, T-Transshipment, R-Restow, D-Domestic.
	if imexStatus = 1 then
		workStr := "I";
	elseif imexStatus = 2 then
		workStr := "E";
	elseif imexStatus = 3 then
		workStr := "H";
	elseif imexStatus = 6 then
		workStr := "S";
	elseif imexStatus = 7 then
		workStr := "T";
	endif;
	xmlElem := rootElem.addElement('Category');
	xmlElem.setText( workStr );
	
	workStr := null;
	if _ti.isContainer then
		if _ti.isEmpty then
			workStr := "E";
		else
			workStr := "F";
		endif;
	endif;
	xmlElem := rootElem.addElement('FullEmptyStatus');
	xmlElem.setText( workStr );
/*	
	xmlElem := rootElem.addElement('DamagedCondition');
	xmlElem.setText( null );
	
	xmlElem := rootElem.addElement('LineOperator');
	xmlElem.setText( null );
*/	
	workStr := null;
	if _ti.receiptTransportMode = 1 then
		workStr := "TRUCK";
	elseif _ti.receiptTransportMode = 3 then
		workStr := "VESSEL";
	elseif _ti.receiptTransportMode = 2 then
		workStr := "RAIL";
	endif;
	xmlElem := rootElem.addElement('ArrivalCarrierMode');
	xmlElem.setText( workStr );
	
	workStr := null;
	if _ti.releasedTransportMode = 1 then
		workStr := "TRUCK";
	elseif _ti.releasedTransportMode = 3 then
		workStr := "VESSEL";
	elseif _ti.releasedTransportMode = 2 then
		workStr := "RAIL";
	endif;
	xmlElem := rootElem.addElement('DepartureCarrierMode');
	xmlElem.setText( workStr );
/*	
	// we don't have this
	xmlElem := rootElem.addElement('OriginCode');
	xmlElem.setText( null );
	
	// we don't have this
	xmlElem := rootElem.addElement('OriginEstID');
	xmlElem.setText( null );
	
	// we don't have this
	xmlElem := rootElem.addElement('OriginDescription');
	xmlElem.setText( null );
*/	
	xmlElem := rootElem.addElement('UN_LoadPortCode');
	xmlElem.setText( _ti.loadPort );
/*	
	xmlElem := rootElem.addElement('UN_TransshipPortCode');
	xmlElem.setText( null );
*/	
	xmlElem := rootElem.addElement('UN_DischargePortCode');
	xmlElem.setText( _ti.dischargePort );
	
	xmlElem := rootElem.addElement('UN_FinalDischargePortCode');
	if term.getConfig(UseAddRemInOneStop).Boolean then		//20-Jan-2025 naviv1 #19155 - Added a config check to use additional remarks as final destination port in OneStop messages
		xmlElem.setText(_ti.remarksAdditional1);
	else													
		xmlElem.setText( _ti.destinationTerminal );
	endif;
/*	
	xmlElem := rootElem.addElement('UN_FinalInlandDestinationCode');
	xmlElem.setText( null );
	
	xmlElem := rootElem.addElement('EmptyPlaceOfReturnCode');
	xmlElem.setText( null );
	
	xmlElem := rootElem.addElement('EmptyPlaceOfReturnDescription');
	xmlElem.setText( null );
	
	xmlElem := rootElem.addElement('NextPlannedMove');
	xmlElem.setText( null );
	
	xmlElem := rootElem.addElement('StorageDollarsOwing');
	xmlElem.setText( null );
	
	xmlElem := rootElem.addElement('StorageDateCalcTo');
	xmlElem.setText( null );
*/	
	workStr := null;
	if _ti.myVoyage &lt;&gt; null and _ti.myVoyage &lt;&gt; term.getNullVoyage then
		if ( _messTypeDesc = self.BDIS  or _messTypeDesc = self.TDIS ) and _ti.myVoyage.inwardCode &lt;&gt; null then // 4 Dec 2018 jggb1 42351 "DISCHARGE" Message needs inward code
			workStr := _ti.myVoyage.inwardCode;
		else
			workStr := _ti.myVoyage.code; // 4 Dec 2018 jggb1 42351 
		endif;
	endif;
	xmlElem := rootElem.addElement('SCA_Client_ID');
	xmlElem.setText( workStr );
/*	
	xmlElem := rootElem.addElement('SCA_DeliveryLocation');
	xmlElem.setText( null );
	
	xmlElem := rootElem.addElement('ManufactureDate');
	xmlElem.setText( null );
	
	xmlElem := rootElem.addElement('MaterialCode');
	xmlElem.setText( null );
	
	xmlElem := rootElem.addElement('Comments');
	xmlElem.setText( null );
	
	xmlElem := rootElem.addElement('StowRequirement');
	xmlElem.setText( null );
*/	
	self.makeVGMCertStatSubSectXML( _ti, rootElem );

	workStr := null;
	if _ti.isContainer then
		//do nothing
	else
		workStr := _ti.totalQuantity.String;
	endif;
	xmlElem := rootElem.addElement('Quantity');
	xmlElem.setText( workStr );
	
	workStr := null;
	if _ti.isContainer then
		//do nothing
	else
		workStr := "Items";
	endif;
	xmlElem := rootElem.addElement('QuantityUnits');
	xmlElem.setText( workStr );
	
	workStr := null;
	if _ti.isContainer then
		//do nothing
	else
		workStr := _ti.totalVolume.String;
	endif;
	xmlElem := rootElem.addElement('Volume');
	xmlElem.setText( workStr );
/*	
	xmlElem := rootElem.addElement('VolumeUnits');
	xmlElem.setText( null );
*/	
	xmlElem := rootElem.addElement('Marks');
	xmlElem.setText( _ti.mark );
	
	xmlElem := rootElem.addElement('Descriptions');
	xmlElem.setText( _ti.remarks );
	
	xmlElem := rootElem.addElement('OceanBill');
	xmlElem.setText( _ti.billOfLading );
	
	xmlElem := rootElem.addElement('HouseBill');
	xmlElem.setText( _ti.houseBillOfLading );
/*	
	xmlElem := rootElem.addElement('UnderbondReason');
	xmlElem.setText( null );
	
	xmlElem := rootElem.addElement('DischargeEstID');
	xmlElem.setText( null );
	
	xmlElem := rootElem.addElement('UN_OSRoutingPortCode');
	xmlElem.setText( null );
*/	
	xmlElem := rootElem.addElement('VesselDischargeIndicator');
	xmlElem.setText( self.getVesselDischargeInd( _messTypeDesc, null ) );
	
	xmlElem := rootElem.addElement('QuantityRemaining');
	xmlElem.setText( self.getQtyRemaining( _ti, _messTypeDesc ) );
		
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_messTypeDesc" type="String"/>
        <Parameter name="_parentElem" type="JadeXMLElement" usage="input"/>
    </JadeMethod>
    <JadeMethod name="makeCommoditySectionXML" id="54daa0e7-9134-4bca-9c91-6ca634e9db12">
        <source>makeCommoditySectionXML( _ti : CM_TrackedItem; _messTypeDesc : String; _parentElem : JadeXMLElement input ) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 August 2016	cnwndl1	Initial creation	TFS 2561 / 2277
07 Aug 2017		NDL		Add 'OUTTURN' values

*/

vars

	rootElem : JadeXMLElement;
	xmlElem : JadeXMLElement;
	comm : CM_Commodity;
	workStr : String;
	
	qty : Integer;
	weight : Decimal [16,3];
	over : Boolean;
	
begin

	rootElem := _parentElem.addElement('Commodity');
	
	if _ti = null then
		return;
	endif;
	
	comm := _ti.getCommodityObject;
	if comm &lt;&gt; null then
	
		xmlElem := rootElem.addElement('Code');
		xmlElem.setText( comm.code );
		
		xmlElem := rootElem.addElement('Description');
		xmlElem.setText( comm.description );
		
		xmlElem := rootElem.addElement('SendersCode');
		xmlElem.setText( comm.code );
		
		xmlElem := rootElem.addElement('SendersDescription');
		xmlElem.setText( comm.description );
		
	endif;
/*	
	xmlElem := rootElem.addElement('CustomsReportable');
	xmlElem.setText( null );
	
	xmlElem := rootElem.addElement('PackingCompanyName');
	xmlElem.setText( null );
	
	xmlElem := rootElem.addElement('WherePacked');
	xmlElem.setText( null );
	
	xmlElem := rootElem.addElement('DatePacked');
	xmlElem.setText( null );
	
	xmlElem := rootElem.addElement('DateLoaded');
	xmlElem.setText( null );
*/	
	xmlElem := rootElem.addElement('Packages');
	xmlElem.setText( _ti.totalQuantity.String );
	
	if _messTypeDesc = self.OUTTURN then 
		workStr := 'PK';
		xmlElem := rootElem.addElement('PackageType');
		xmlElem.setText( workStr );
	endif;
/*	
	xmlElem := rootElem.addElement('Remarks');
	xmlElem.setText( null );
	
	xmlElem := rootElem.addElement('MarksAndNumbers');
	xmlElem.setText( null );
	
	xmlElem := rootElem.addElement('AHECC_Code');
	xmlElem.setText( null );
*/	
	xmlElem := rootElem.addElement('GrossWeight');
	xmlElem.setText( _ti.totalWeight.Integer.String );
	
	workStr := 'N';
	if _ti.damaged then
		workStr := 'Y';
	endif;
	xmlElem := rootElem.addElement('DamagedIndicator');
	xmlElem.setText( workStr );
	
	if _messTypeDesc = self.OUTTURN then
		workStr := 'NIL';
		if _ti.getBulkBreakBulkOverUnder( qty, weight, over ) then
			if over then
				workStr := 'SC';
			else
				workStr := 'SH';
			endif;
		endif;
		xmlElem := rootElem.addElement('OutturnType');
		xmlElem.setText( workStr );
		
	endif;
	
	workStr := 'N';
	xmlElem := rootElem.addElement('PillagedIndicator');
	xmlElem.setText( workStr );
	
/*	
	xmlElem := rootElem.addElement('OffloadIndicator');
	xmlElem.setText( null );
*/

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_messTypeDesc" type="String"/>
        <Parameter name="_parentElem" type="JadeXMLElement" usage="input"/>
    </JadeMethod>
    <JadeMethod name="makeConsigneeAddrSubSectXML" id="244eccc7-ea90-4935-9fa7-f36371b2c1d6">
        <source>makeConsigneeAddrSubSectXML( _consignee : CM_ConsigneeConsignor; _parentElem : JadeXMLElement input ) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 August 2016	cnwndl1	Initial creation	TFS 2561 / 2277

*/

vars

	rootElem : JadeXMLElement;
	xmlElem : JadeXMLElement;
	
	subRootElement : JadeXMLElement;

begin

