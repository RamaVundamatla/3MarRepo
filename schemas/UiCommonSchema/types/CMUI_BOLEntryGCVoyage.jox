    <JadeMethod name="doSaveBol" id="121d50bc-6132-4d1c-815e-05b83bc7adb5">
        <updating/>
        <source>doSaveBol() : Boolean updating;
// ---------------------------------------------------------------------------
// Created:     03 February 2006	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars
	newBOL, 
	pxyBOL 			: CM_BOLIn;
	operator		: CM_Operator;
	voyageGC			: CM_GeneralCargoVoyageStructure;
	passport		: CM_Passport;
	cargoTypeId,
	result		 	: Integer;
	manifestId,
	strCode,
	headingStr,
	idStr			: String;
	intFaceBOL 		: CMIF_BOLIn;
	intFaceObj 		: CMIF_TIObject;
	cmifAttach 		: CMIF_InOutAttachment;
	proxyLocation 	: CM_GeneralCargoController;
	pxyManifest,
	manifest 		: CM_Manifest;
	tmpRowDtl		: CMUI_RowFrame;
	
begin
	passport := app.myPassport;
	
	create intFaceBOL transient;	
	self.setCMIFObj(intFaceBOL);
		
	voyageGC := self.myCurrentVoyage.myGeneralCargoVoyage;
	intFaceBOL.myPlannedLocation := self.cmbHatch.listObject.CM_LocationsController;
	
	if voyageGC &lt;&gt; null then
		manifest := voyageGC.allManifestsById.first();

		if manifest = null then 
			create pxyManifest as CM_Manifest transient;
			pxyManifest.setProxy(voyageGC.myVoyage.code, null ,null, voyageGC);
			app.myTrxCA.trxCreateManifest(pxyManifest, manifest, passport);
			if (not passport.trxCompletedOK) then
				app.raiseUnexpectedProgramError(Class.name, method.name,'Manifest creation error');
				return false;
			endif;
		endif;
	endif;
		
	intFaceBOL.myManifest := manifest;
	intFaceBOL.numItems := 	0;

	foreach tmpRowDtl in self.frmRowScroll.allRowFrames do
		cmifAttach := tmpRowDtl.CMUI_RowFrameGCBOLItem.myCMIFAttach;
		if cmifAttach = null then
			create cmifAttach transient;
		endif;
		cmifAttach.setMasterItem(intFaceBOL);
		tmpRowDtl.CMUI_RowFrameGCBOLItem.saveToCMIF(cmifAttach);
		//th2 - 19/03/2007 - sigh!! 
		//intFaceBOL.numItems := intFaceBOL.numItems + cmifAttach.quantity;
		intFaceBOL.numItems := intFaceBOL.numItems + 1;
	endforeach;	

	if self.mode = self.Mode_Edit then 
		pxyBOL := self.myPxyBOL;
		//pxyBOL.setPxyFromCMIF_BOL(intFaceBOL, passport);
		intFaceBOL.setMyProxyBOL(pxyBOL);
	endif;
	
	//intFaceObj := intFaceBOL;???

	while true do
		if self.mode = self.Mode_Add then
			headingStr := 'Creating BOL';
			app.myTrxCA.trxCreateBOLInGeneralCargo(intFaceBOL, passport);
		elseif self.mode = self.Mode_Edit then
			headingStr := 'Updating BOL';
			app.myTrxUA.trxUpdateBOLandTIs(intFaceBOL, pxyBOL, passport);
		endif;
		
		if passport.trxCompletedOK then
			self.clearErrorWarnings();
			return true;
		else
			result := app.showErrorWarningDialog(headingStr, app.myPassport, ErrWarnMode_Add + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			// DVB this form has become redundant. 
			//self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
		endif;
		return false;
	endwhile;
	
epilog
	if passport.trxCompletedOK then
		delete pxyBOL;
		intFaceBOL.deleteSubItemProxies();
	else
		intFaceBOL.allSubItems.clear();
	endif;	
	delete intFaceBOL;
	delete proxyLocation; 
	delete pxyManifest;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doTxtQuantityLostFocus" id="a41f737f-9930-4253-8789-6d28bb14b9fc">
        <source>doTxtQuantityLostFocus();

vars
	quant : Integer;
	weight :  Integer;
	prod	: CM_Product;
begin
	if self.cmbProduct.myObject &lt;&gt; null then
		prod := self.cmbProduct.myObject.CM_Product;
				
		//if prod.myWeight &lt;&gt; null and prod.myWeight.value &lt;&gt; null then //30.1.09 cnwrd1 par #18821 --
		if prod.getMyWeight() &lt;&gt; null and prod.getWeightValue() &lt;&gt; null then //30.1.09 cnwrd1 par #18821 ++
			quant := self.txtQuantity.text.Integer;
			//weight :=  prod.myWeight.value;
			weight :=  prod.getWeightValue().Integer;//30.1.09 cnwrd1 par #18821 
			self.txtWeight.text := (quant * weight).String[1:12];// only 12 
		endif;
	endif;
end;</source>
    </JadeMethod>
