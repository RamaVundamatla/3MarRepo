        <source>utlDeleteInvoiceUnitOfMeasure(_invoiceUnitOfMeasure : CM_InvoiceUnitOfMeasure io; _passport : CM_Passport input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06/12/2022 navvt20  TFS CR 55621 Task 55693: Jade - UOM TRX

*/

vars

begin
