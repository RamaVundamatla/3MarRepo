<Class name="ProcessLogger" id="f5d04a79-7cb3-48bd-a908-23e86eaf1b8b">
    <superclass name="Misc"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="JetPlusMap"/>
    <ImplicitInverseRef name="commandProcessor" id="2e090655-4f7b-4890-a799-f1b6589d7175">
        <embedded/>
        <type name="CommandProcessor"/>
    </ImplicitInverseRef>
    <PrimAttribute name="doingJdbutil" id="01304135-9cae-443a-ba0b-fc279a7ddf6e">
        <embedded/>
        <type name="Boolean"/>
    </PrimAttribute>
    <PrimAttribute name="doingSchemaExtract" id="d49a00bb-f066-43bb-8133-c89ad3c28e31">
        <embedded/>
        <type name="Boolean"/>
    </PrimAttribute>
    <PrimAttribute name="doingWinZip" id="2fc50ae7-4d35-40ea-a4bf-f75de5cf8918">
        <embedded/>
        <type name="Boolean"/>
    </PrimAttribute>
    <ImplicitInverseRef name="logFile" id="ab1a0371-8e4c-487b-83e8-5e54e1e187fc">
        <embedded/>
        <type name="File"/>
    </ImplicitInverseRef>
    <PrimAttribute name="saveString" id="e35ae9af-f6e8-4a2b-9a7b-f5c09d4f5e05">
        <type name="String"/>
    </PrimAttribute>
    <JadeMethod name="setUp" id="fa184da8-f5f8-4486-b68f-4057ceec67f0">
        <updating/>
        <source>setUp() updating;
// Used by app.processLoggerInitialize ..
begin
	self.beginNotification(commandProcessor, Process_Std_Out_Event, 0, 0);
	self.beginNotification(commandProcessor, Process_Logger_End, 0, 0);

	if commandProcessor.logFileName&lt;&gt;null then
		create logFile;
		logFile.kind := File.Kind_Unknown_Text; // 1/3/16  cnwns1 PAR 36286 unicode version
		logFile.fileName:=commandProcessor.logFileName;
		logFile.mode:=File.Mode_Append;
		logFile.usePresentationFileSystem:=false;
//		logFile.writeLine(app.actualTimeAppServer.logFormat);
	endif;
	doingWinZip:=commandProcessor.doingWinZip;
	doingSchemaExtract:=commandProcessor.doingSchemaExtract;
	doingJdbutil:=commandProcessor.doingJdbutil;

	beginTransientTransaction;
	commandProcessor.stdOut:=Process_Logger_Ready;
	commitTransientTransaction;
end;</source>
    </JadeMethod>
    <JadeMethod name="userNotification" id="c7a76ffd-c18d-46d5-b218-a12db4bceaf6">
        <updating/>
        <source>userNotification(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;

// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support

vars
	s:String;
begin
//	write self.class.name &amp; "::" &amp;  method.name &amp; " = " &amp; eventType.String;
//	terminate;
	if theObject = commandProcessor then
		if eventType = Process_Std_Out_Event then
			s:=userInfo.String[5:end];
//			write s.Binary.display;
			if doingWinZip then
				saveString:=saveString&amp;s;
				if saveString.cnContains(CrLf) or saveString[1:12]="creating" then
					s:=saveString;
					s:=s.replace(#"08 20 08","");		// edit out wzzip stuff
					s:=s.replace("..","");
//					write s.Binary.display;
					saveString:=null;
				else
					return;
				endif;
				if global.isValidObject(commandProcessor) then
					if s.pos("Error:",1)&lt;&gt;0 then
						beginTransientTransaction;
						commandProcessor.errors:=commandProcessor.errors+1;
						commitTransientTransaction;
					elseif s.pos("Warning:",1)&lt;&gt;0 then
						beginTransientTransaction;
						commandProcessor.warnings:=commandProcessor.warnings+1;
						commitTransientTransaction;
					endif;
				endif;
			elseif doingJdbutil then
				s:=s.replace(Cr&amp;"Backup",CrLf&amp;"Backup");
				s:=s.replace(Cr&amp;" ",CrLf&amp;" ");
//				write s.Binary.display;
			endif;
			if logFile&lt;&gt;null then
//				write s;
				if doingSchemaExtract then
					if s="Database opened"&amp;CrLf
					or s="Closing database..."&amp;CrLf
					or s="Database closed"&amp;CrLf
					or s="Load completed"&amp;CrLf then
						return;
					else
						s:=app.actualTimeServer.logFormat&amp;" "&amp;s;// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
					endif;
				else
					if global.isValidObject(commandProcessor) and commandProcessor.stdOut=null then
						s:=app.actualTimeServer.logFormat&amp;" "&amp;s;// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
					endif;
					s:=s.replace(CrLf,CrLf&amp;app.actualTimeServer.logFormat&amp;" ");// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
				endif;
				logFile.writeString(s);
				logFile.close;
			endif;
			if global.isValidObject(commandProcessor) then
				beginTransientTransaction;
				commandProcessor.stdOut := commandProcessor.stdOut&amp;s;
				commitTransientTransaction;
			endif;

		elseif eventType = Process_Logger_End then
			delete logFile;
			terminate;
		endif;		
	endif;
end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
</Class>
