    <JadeMethod name="isControlledAtmosphere" id="40eafe72-a659-482e-b58e-b9c09b3be160">
        <methodInvocation>mapping</methodInvocation>
        <source>isControlledAtmosphere(set: Boolean; _value: Boolean io) mapping;
/*
Purpose:			CCMS 1007 - indicate whether tracked item has controlled atmosphere

Parameters:			

Return Value:		

Date		Who		Reason
25/11/2009	cnwdap1	Initial creation
*/
vars

begin
	if set then
		// set code here
		app.raiseSetVirtualError(class.name, method.name);
		return;
	else
		// get code here
		if ( self.getOxygen &lt;&gt; NULL_OXYGEN )
		or ( self.getCarbonDioxide &lt;&gt; NULL_CARBON_DIOXIDE )
		or self.curtainsIn then
			_value := true;
		else
			_value := false;
		endif;
		
	endif;

epilog

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Boolean" usage="io"/>
    </JadeMethod>
