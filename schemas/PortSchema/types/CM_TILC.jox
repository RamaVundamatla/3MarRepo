    <JadeMethod name="getVoyOpsLiveCheckStatus" id="5c57e290-52d6-47f3-b681-3ba2a6a57cd5">
        <source>getVoyOpsLiveCheckStatus(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
07 August 2024		jlizm1	Initial creation TFS 65494 Discharged MAFI not showing for reload with new cargo

*/

vars
	onboardTIs 	: CM_TISet;
	ti 			: CM_TrackedItem;
	returnValue : String;
	context		: Integer;
	
begin

	if self.hasBeenReleasedToShip then
		context := CARGO_CHECK_CONTEXT_VOYOP_LOAD;
		
	elseif self.isOnSite and self.hasBeenReceivedFromVoyage(self.myVoyage) then
		create onboardTIs transient;
		self.getAllOnboardTIs(onboardTIs);
		ti := onboardTIs.first;
		if ti = null or ti.hasBeenReceivedFromVoyage(self.myVoyage) then
			context := CARGO_CHECK_CONTEXT_VOYOP_DISC;
		endif;
		
	elseif self.isOnShip and not self.hasBeenReceivedFromShip then
		context := CARGO_CHECK_CONTEXT_VOYOP_DISC;
	endif;
	
	if context = null then
		returnValue := app.getErrorString(NotApplicable);
	else
		if self.cargoChecksCompleted.size &gt;= context and self.cargoChecksCompleted[context] then
			returnValue := app.getErrorString(Complete);		
		else
			if self.hasCargoChecksByContext(context) then
				returnValue := app.getErrorString(Pending);
			else 
				returnValue := app.getErrorString(NotApplicable);
			endif;
		endif;
	endif;	
	
	return returnValue;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
