<CollClass name="CM_VoyageROROControllerArray" id="c86395e1-4fae-4d94-a5e7-8254518ac85a">
    <loadFactor>66</loadFactor>
    <memberType name="CM_VoyageROROController"/>
    <superclass name="ObjectArray"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="voyageStructures"/>
    <JadeMethod name="getHeightOfSlots" id="5e3da087-42a1-43d0-9303-1af18fb15b28">
        <source>getHeightOfSlots(_currentSlot : CM_VoyageROROController; _countExistingOnes : Boolean):Real;

/*
Purpose:			
Date				Who			Reason
JULY 2011		CNWAB1		Initial creation
*/



vars
	slot : CM_VoyageROROController;
	height : Real;
begin
	if _countExistingOnes then			//when switching the hi-cube pen for the selected cells in the colour coding screen 
		foreach slot in self where (slot.isKindOf(CM_ROROSlotController) and (slot.CM_ROROSlotController.mySlotDefn.myROROLocnDen = _currentSlot.CM_ROROSlotController.mySlotDefn.myROROLocnDen)) do  ///only the cells from underneath the current one, on the same cell-column and deck
			
			if slot.myRORORequestLoad = null then
				height := height + HEIGHT_FULL_HIGH_CUBE;
			else
				if slot.myRORORequestLoad.getAttrHiCubed() then
					height := height + HEIGHT_FULL_NORMAL - HEIGHT_FULL_HIGH_CUBE;
				else
					height := height + HEIGHT_FULL_HIGH_CUBE - HEIGHT_FULL_NORMAL;
				endif;
			endif;
		endforeach;
	else								//asigning a colour code to selected cells
		foreach slot in self where (slot.isKindOf(CM_ROROSlotController) and (slot.CM_ROROSlotController.mySlotDefn.myROROLocnDen = _currentSlot.CM_ROROSlotController.mySlotDefn.myROROLocnDen)) do
			if slot.myRORORequestLoad = null then 
				height := height + HEIGHT_FULL_NORMAL;
			endif;		
		endforeach;
	endif;
	return height;
epilog

end;</source>
        <Parameter name="_currentSlot" type="CM_VoyageROROController"/>
        <Parameter name="_countExistingOnes" type="Boolean"/>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="hasNonContainerLCs" id="6f7a2273-849d-407e-8def-2856bec9a6e5">
        <source>hasNonContainerLCs() : Boolean;
/*
Purpose:			
Date		Who		Reason
04 August 2011	cnwab1	Initial creation
*/

vars
	vlc : CM_VoyageROROController;
begin

	foreach vlc in self  discreteLock do
		if not vlc.isContainerLC() then
			return true;
		endif;
	endforeach;
	
	return false;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</CollClass>
