    <JadeMethod name="doDFStatusLine" id="d1cc6e39-719e-4e09-b2ba-b9f92fd1db0f">
        <source>doDFStatusLine();
// ---------------------------------------------------------------------------
// Created:		11 August 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
begin
	if self.myGridOverviewForm &lt;&gt; null then
		self.myGridOverviewForm.frmStatusLine.myFrameCaption.caption := null;
		self.myGridOverviewForm.frmStatusLine.myFrameCaption.caption := " Selected: " &amp; self.allSelectedObjects.size.String;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="drawBackendAttForFM" id="584353f3-faa8-43c9-bec4-3a87c8e4a541">
        <source>drawBackendAttForFM(_theTI : CM_TrackedItem; _frame : CMUI_GridAreaDrawingFrame input; _x1, _y1, _x2, _y2 : Real; _colour : Integer) protected;
// ---------------------------------------------------------------------------
// Created:		May 2008 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
// ---- WHO --- WHEN ----- WHY---------------------------------------------
// ---------------------------------------------------------------------------
//       AKB    22MAY2008     PAR 16415 CCMS 1029 30,45,53s
// ---------------------------------------------------------------------------
vars
	theDrawingAttribute : CM_DrawingAttribute;
	tmpX, tmpY	: Real;
	theAttributePosition, theColour : Integer;
	theCharacter : Character;
	theFrame: CMUI_Frame;
	lDisplayMode	: Integer;
	is45, is40, is30, is53 : Boolean; // PAR 17649
	drawingAttributes : CM_DrawingAttributesByCodeDict;
begin

	theFrame := _frame;
	drawingAttributes := app.myRoot.allDrawingAttributes;
	
	tmpX := _x1 + ((_x2 - _x1) / 2);
	tmpY := _y1 + (self.scaleFactor * 2);
	
	lDisplayMode := self.displayMode;

	if _theTI.isAttributeTrue(TI_Attrib_IsForty) 
	or _theTI.isTwenty()  then 
		theDrawingAttribute := drawingAttributes[PicTI40FooterBackEnd]; 
	elseif _theTI.isAttributeTrue(TI_Attrib_IsThirty) then
		theDrawingAttribute := drawingAttributes[PicTI30FooterBE]; 
	elseif _theTI.isAttributeTrue(TI_Attrib_IsFiftyThree) then
		theDrawingAttribute := drawingAttributes[PicTI53FooterBE]; 
	elseif _theTI.isAttributeTrue(TI_Attrib_IsFortyFive) then
		theDrawingAttribute := drawingAttributes[PicTI45FooterBackEnd]; 
	endif;
	
	if theDrawingAttribute = null then
		return;
	endif;
	
	theFrame.drawFontName := theDrawingAttribute.fontName;
	// #######################
	// DRAW THE CHARACTER
	theFrame.drawTextAlign := Frame.DrawTextAlign_Center;
	theFrame.drawFontSize := (self.scaleFactor * 6);
	theCharacter := theDrawingAttribute.fontCharacter.Character;
	theFrame.drawTextAt(theCharacter, tmpX, tmpY, _colour);
epilog
	if theFrame &lt;&gt; null then 
		self.setDefaultFont(theFrame);
	endif;
	

end;</source>
        <access>protected</access>
        <Parameter name="_theTI" type="CM_TrackedItem"/>
        <Parameter name="_frame" type="CMUI_GridAreaDrawingFrame" usage="input"/>
        <Parameter name="_x1" type="Real"/>
        <Parameter name="_y1" type="Real"/>
        <Parameter name="_x2" type="Real"/>
        <Parameter name="_y2" type="Real"/>
        <Parameter name="_colour" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="drawBlankSpaceAfterOSBackend" id="0289fb47-55cb-4c01-b937-652d55bab15a">
        <updating/>
        <source>drawBlankSpaceAfterOSBackend(_osTI : CM_TrackedItem; _stackPos : Integer; _startY, _endY : Real) : Boolean updating;
// ---------------------------------------------------------------------------
// Created:		09 May 2008 By Andrew Bishop cnwab1
//
// Purpose:		PAR 16415 if the LC is defined for oversized containers e.g. 30, 45 or 53 then draw an adjusted blank space if necessary.
//
// ---------------------------------------------------------------------------
// ---- WHO --- WHEN ----- WHY---------------------------------------------
// ---------------------------------------------------------------------------
//       AKB    19MAY2008     PAR 17067 30,45,53s
// ---------------------------------------------------------------------------
vars
	theTI, overhangTI : CM_TrackedItem; 
	pixelsDiv, offsetsDiv,tmpX1, tmpX2,tmpDiff, numOfOffsets, pixelsPerOffset, origX1 : Real;
	osOffSet, theFillColour, lTIColour, theInverseColour : Integer;
	stdColWidth : Real;
	rtgLC : CM_RTGController;
	myLC : CM_LocationsController;
	tmpSR : CM_SlotRequest;
begin
	self.myDrawingFrame.drawWidth	:= 1;
	myLC := self.myLocationsController;
//if process.isCnwab1 and myLC.CM_GridController.name = "&lt;2&gt;0505" then
//write "";
//endif;
	
	if myLC.hasPower() then 
		theFillColour := self.POWER_FILL_COLOUR;
	else
		theFillColour := Gray;
		if myLC.is45ft 
		or myLC.is30ft
		or myLC.is53ft then
//			theFillColour := self.getGrayScale(3);
		endif;
	endif;
	stdColWidth := self.columnWidth;

	overhangTI := _osTI;
	if  overhangTI &lt;&gt; null then
		self.myTrackedItem := overhangTI;
		lTIColour := self.getFillColourForTI(overhangTI);
		if self.useSelectorObjects and not self.allSelectorTIs.includes(overhangTI) then
			lTIColour := White;
		endif;
		
		theInverseColour := lTIColour.getInverseColour();
	
		self.drawBackground(self.myDrawingFrame,self.x1, _startY, self.x2, _endY);
	
		self.myDrawingFrame.drawWidth := 2;
		self.myDrawingFrame.drawLine(self.x1 + 4, _startY + 4,self.x2 - 4, _endY - 4,  theInverseColour);
		self.myDrawingFrame.drawLine(self.x2 - 4, _startY + 4, self.x1 + 4, _endY - 4,  theInverseColour);
		self.myDrawingFrame.drawWidth := 1;
	
	endif;

	
	return false;
end;</source>
        <Parameter name="_osTI" type="CM_TrackedItem"/>
        <Parameter name="_stackPos" type="Integer"/>
        <Parameter name="_startY" type="Real"/>
        <Parameter name="_endY" type="Real"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="drawFMLetter" id="ffc17e6b-3515-404c-85a4-793d74a6cedf">
        <source>drawFMLetter(_theLetter: String; _isP40: Boolean; _isQ40: Boolean; _isA40: Boolean; _theX1: Real; _theY1: Real; _theX2: Real; _theY2: Real; _theFill: Integer; _mode: Integer);
// ---------------------------------------------------------------------------
// Created:     25 August 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	theFrame	: CMUI_GridAreaDrawingFrame;
	offset, yOffsetFnt : Integer;
	aReal : Real;
	theLetter : String;
begin

	theFrame := self.myDrawingFrame;
	theLetter := _theLetter.trimBlanks;

	theFrame.drawFontName := "Arial";
	theFrame.drawTextAlign := Frame.DrawTextAlign_Center;
	theFrame.drawWidth := 2;
	if self.scaleFactor = 1 then
		theFrame.drawWidth := 1;
		yOffsetFnt := 1;

		theFrame.drawFontSize := 6;
	elseif self.scaleFactor = 1.5 then
		theFrame.drawWidth := 1;
		yOffsetFnt := 2;
		theFrame.drawFontSize := 8;
	elseif self.scaleFactor = 2 then
		theFrame.drawWidth := 1;
		yOffsetFnt := 4;
		theFrame.drawFontSize := 10;
	elseif self.scaleFactor = 3 then
		yOffsetFnt := 6;
		theFrame.drawFontSize := 14;
	elseif self.scaleFactor = 4 then
		yOffsetFnt := 8;
		theFrame.drawFontSize := 20;
	elseif self.scaleFactor = 6 then
		yOffsetFnt := 8;
		theFrame.drawFontSize := 30;
	elseif self.scaleFactor = 9 then
		yOffsetFnt := 20;
		theFrame.drawFontSize := 40;
	endif;

	theFrame.drawStyle := Frame.DrawStyle_Solid;
	theFrame.drawFillColor := White;
	if self.scaleFactor &gt; 2 then
		offset := (self.scaleFactor + 2).Integer;
	else
		offset := self.scaleFactor.Integer;
	endif;
	theFrame.drawFilledRectangle(_theX1 + offset, _theY1 + offset, _theX2 - offset, _theY2 - offset,  Black);

	aReal :=  _theX1 + ((_theX2 - _theX1) / 2);
	offset := aReal.Integer;
	theFrame.drawTextAt(theLetter, offset, _theY1 + yOffsetFnt, Black); 
epilog
	theFrame.drawWidth := 1;
	theFrame.drawFontBold := false;

end;</source>
        <Parameter name="_theLetter" type="String"/>
        <Parameter name="_isP40" type="Boolean"/>
        <Parameter name="_isQ40" type="Boolean"/>
        <Parameter name="_isA40" type="Boolean"/>
        <Parameter name="_theX1" type="Real"/>
        <Parameter name="_theY1" type="Real"/>
        <Parameter name="_theX2" type="Real"/>
        <Parameter name="_theY2" type="Real"/>
        <Parameter name="_theFill" type="Integer"/>
        <Parameter name="_mode" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="drawFMLetterGraphic" id="f0c19900-cc81-4148-9932-c2820df32efd">
        <source>drawFMLetterGraphic(_frame: CMUI_GridAreaDrawingFrame; _theLetter: String; _theX1: Real; _theY1: Real; _theX2: Real; _theY2: Real; _theFill: Integer);
