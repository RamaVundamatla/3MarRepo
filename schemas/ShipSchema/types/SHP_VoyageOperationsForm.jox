        <controlMethod name="CM_DataTable::rowColumnChg"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblWorkEntries_rowColumnChg(table: Table input) updating;

// Created by cnwdvb1 on 02 May 2006

vars

begin

	self.setMyCurrentControls(table.CM_DataTable, true);
	if self.myCurrentTableWLE &lt;&gt; null then			
		if myCurrentTableWLE.row &gt; myCurrentTableWLE.fixedRows then
			self.tblWLEChange(myCurrentTableWLE.CM_DataTable, table.row);
		endif;
	endif;
	
end;</source>
