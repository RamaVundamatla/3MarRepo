	self.cmbCargoTypeInvP.style := 2;
	self.cmbCargoVoyage_.style := 2;
	self.cmbCnee.style := 2;
	self.cmbDebtor.style := 2;
	self.cmbDebtorAddressProp.style := 2;
	self.cmbDebtorInvProp.style := 2;
	self.cmbInvoiceStatus.style := 2;
