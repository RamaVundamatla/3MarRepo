    <JadeMethod name="setCurrentTiMaster" id="23219ef3-dc20-4b12-bc26-164bc59735d4">
        <updating/>
        <source>setCurrentTiMaster(_tiMaster : CM_Object) updating, protected;
// -------------------------------------------
// Created 29 November 2005 by cnwdvb1
// -------------------------------------------
vars

begin

	if self.isWagonMaster then	// 03 Jul 2009	NDL	CCMS 1067
		self.myCurrentWagonMaster := _tiMaster.CM_WagonMaster;
		self.myCurrentTiMaster := null;
	else
		self.myCurrentWagonMaster := null;
		self.myCurrentTiMaster := _tiMaster.CM_TIMaster;
	endif;
