    <JadeMethod name="isNullColourCoded" id="d807b15c-50db-47c4-b236-121fc235346a">
        <source>isNullColourCoded() : Boolean;
// ---------------------------------------------------------------------------
// Created:		July 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars
	amNull : Boolean;
begin

	if self.moveType = NULL_MOVETYPE then
		amNull := true;
	elseif self.isLoad or
		   self.isDischarge then	//+cnwas3 PAR 24273
		if self.getAttrCommodityGroup() = null and self.getAttrDischargePort() = null and self.myJob = null and self.getAttrCargoType() = null then		
			amNull := true;
		endif;
		
	/*elseif self.isDischarge then
		if self.getAttrCommodityGroup() = null and self.getAttrDischargePort() = null and self.myJob = null and self.getAttrCargoType() = null then
			amNull := true;
		endif;*/ //-cnwas3 PAR 24273 
	else
		amNull := true;
	endif;
	
	return amNull;
end;</source>
