<Class name="CM_WorkOrderNullVoyage" id="2d763b74-4629-418a-9fd2-cb34ee1f829e">
    <superclass name="CM_WorkOrderAssign"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="workorder"/>
    <JadeMethod name="getDisplayStringForAttribute" id="831c1d47-445e-404a-83cf-8baf8b0f4e39">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 15/05/2018	jlgdap1		Initial creation TFS 38501 PEL1 Work Order Changes
//
vars
	workOrder : CM_WorkOrderTI;
	invalidWO : Boolean;
	returnStr : String;

begin
	if _attrName = ETRow_Details  then
		if self.deleted then
			return self.getDeletedDetails();		// 15/10/18 MAP TFS41191
		else
			on Exception do app.handleDeletedObject(exception, workOrder, invalidWO); 
			workOrder := self.myWorkOrder;
			if workOrder &lt;&gt; null then
				returnStr := "Assigned to " &amp; workOrder.id &amp; " : Voyage " &amp; workOrder.getNewVoyage.code;
			endif;
			return returnStr;			
		endif;
	endif;
	
	return inheritMethod(_attrName, _short);
epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
</Class>
