    </ImplicitInverseRef>
    <JadeMethod name="displayEntry" id="2d52f667-7cf1-4929-bb7e-5556f0e84ef8">
        <controlMethod name="ComboBox::displayEntry"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>displayEntry(combobox: ComboBox input; _ti: CM_TrackedItem; lstIndex: Integer): String updating, clientExecution;
// ---------------------------------------------------------------------------
// Created:     28 July 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars
	ti : CM_TrackedItem;
begin

	ti := _ti;
	
	if ti = null then
		return null;
	endif;	
	
	if self.myCargoType &lt;&gt; null and ti.myCargoType &lt;&gt; self.myCargoType then 
		return null;
	endif;

	if self.myProduct &lt;&gt; null and ti.myProduct &lt;&gt; self.myProduct then 
		return null; 
	endif;
	
	if ti.state = TI_STATE_DELETED then 
		return null;
	endif;

	if ti.myParent &lt;&gt; null or ti.myStockOrderTILine &lt;&gt; null then
		return null;
	endif;
		
	return ti.id;


end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="lstIndex" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getCollectionJMT" id="4d096624-5334-4d02-913d-5fabc69efde8">
        <source>getCollectionJMT(): Collection protected;
// ---------------------------------------------------------------------------
// Created:     28 July 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars

begin
	
	if self.myTerminal = null then 
		return null;
	else 
		return self.myTerminal.allOnsiteTIsByCargoTypeId;
	endif;
end;</source>
        <access>protected</access>
        <ReturnType type="Collection"/>
    </JadeMethod>
    <JadeMethod name="setCargoType" id="806f7b64-2586-4a36-a7eb-27b87fdf804f">
        <updating/>
        <source>setCargoType(_cargoType : CM_CargoType) updating;
// ---------------------------------------------------------------------------
// Created:     28 July 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars

begin
	if self.myCargoType &lt;&gt; _cargoType then 
		self.myCargoType := _cargoType;
		self.amInitialised := false; // so will re populate on next gotfocus. 
	endif;		
end;</source>
        <Parameter name="_cargoType" type="CM_CargoType"/>
    </JadeMethod>
