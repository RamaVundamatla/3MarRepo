<Class name="FindJmtLiterals" id="30224e21-4168-41ab-a01c-9a4c80a72321">
    <superclass name="LocalisationSupportAgents"/>
    <transient/>
    <subclassTransientAllowed/>
    <subschemaFinal/>
    <transientAllowed/>
    <DbClassMap file="dev"/>
    <JadeMethod name="filterClass" id="4fd4206e-687b-4457-bc76-7c738a8d727c">
        <source>filterClass(cls : Class):Boolean protected;

// class filters

begin
	return 
		cls.name.toUpper.pos('OLD',1) &lt;&gt; null
		or cls.name[1:3] = 'BGP' 
		or cls.name.toUpper.pos('EDI',1) &lt;&gt; null 
		or cls.name.toUpper.pos('BACKUP',1) &lt;&gt; null 
		or cls.name.toUpper.pos('RJS',1) &lt;&gt; null 
		or cls.name.toUpper.pos('XML',1) &lt;&gt; null 
		or cls.name.toUpper.pos('TEXT',1) &lt;&gt; null 
		or cls.name.toUpper.pos('TMP',1) &lt;&gt; null 
		or cls.name.toUpper.pos('TEMP',1) &lt;&gt; null 
		or cls.name.toUpper.pos('TEST',1) &lt;&gt; null 
		or cls.name.toUpper.pos('CM_Cam',1) &lt;&gt; null 		
		or cls = CM_ExternalDatabaseAgent
		or cls = CM_ExtKeyDynaDictionary
		or cls = CM_LogVoyageRowDownload
		or cls = CM_EntryTable
		or cls = SetSkinForm
		or cls.name = 'INV_ListInvoices'
		or cls.name[1:5] = 'CM_RT'
		or cls.name.pos('RadioTele',1) &lt;&gt; null 
		or cls.name.pos('Teklogix',1) &lt;&gt; null 
		or cls.name.pos('CM_DataDump',1) &lt;&gt; null 
		or cls.name[1:2] = 'Cn'
		or cls.name[1:2] = 'I_'
		or cls.name[1:3] = 'JSS'
		or cls.name[1:3] = 'NR_'
		or cls.name[1:3] = 'RFC'
		or cls.name[1:3] = 'TST'
		or cls.name = 'CMUI_BOLFormatForm'
		or cls.name = 'CMUI_DeckingOptions'
		or cls.name = 'HMS_TGACustomReport'
		or cls = PortSchemaRelease 
		or cls.name.pos('PortSchema_',1) &lt;&gt; null
		or cls.name.pos('GTE_Kiosk', 1) &lt;&gt; null
		or cls.name = 'TekLogixRTInterface'
		or cls.name = 'YRD_GridAreaForm'		// only logs
		or cls.name = 'CMUI_RptControllerShipLogList'
		or cls.name = 'CMUI_SysPerformAgent'
		;
end;</source>
        <access>protected</access>
        <Parameter name="cls" type="Class"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="filterLiteral" id="467e7124-b678-4fad-9ed0-c12ff27fd266">
        <source>filterLiteral(str, contextItem : String):Boolean protected;

// literals filters

begin
	return
		str.containsAlphas = false	
		or str.toUpper.pos('CNW',1) &lt;&gt; null
		or str.toUpper.pos('HTTP',1) &lt;&gt; null
		or str.toUpper.pos('SCHEMA',1) &lt;&gt; null
		or str[1:3].toUpper = 'TAG'
		or str[1:3].toUpper = 'TXT'	// control txt..
		or str[1:3].toUpper = 'CMB'	// control cmb..
		or str[1:3].toUpper = 'TBL'	// control tbl..
		or str[1:3].toUpper = 'CM_'
		or str[1:4].toUpper = 'SHP_'
		or str[1:4].toUpper = 'YRD_'
		or str[1:4].toUpper = 'HMS_'
		or str[1:5].toUpper = 'MYLOG'
		or str[1:2].toUpper = 'ZZ'
		or str[1:2].toUpper = 'XX'
		or str[1:2].toUpper = 'GD'
		or str = 'Jmaster2006'
		or str = 'Set skin to JMTxpx2006'
		or str = 'JMTxpx2006'
		or str = 'Do you wish to use test level'
		or str.toUpper = 'HH:MM:SS'
		or str.toUpper = 'H:MM'
		or str.toUpper = 'HH:MM'
		or str.toUpper = "HH:MM"
		or str.toUpper = 'DD/MM'
		or str = 'EDITEST'
		or str = 'JtdDriverSchema'
		or str = 'SUPERUSER'
		or str = "Click 'Yes' to print POE, 'No' for WLG else 'Cancel' for Default."	// Invoice schema
		or str.toUpper.pos('REIMPLIMENT', 1) &lt;&gt; null
		or contextItem = 'app.getForm'
		or contextItem = 'write'
		or contextItem = 'app.raiseUnexpectedProgramError'
		or contextItem = 'app.writeLog'
		or contextItem = 'app.writeStatement'
		or contextItem.pos('app.createExternalProcess', 1) &lt;&gt; null
		or contextItem.pos('sendMsg', 1) &lt;&gt; null
		or contextItem.pos('showHideRowsByViewName', 1) &lt;&gt; null
		or contextItem.pos('setTblDataEntRowsFromView', 1) &lt;&gt; null
		or contextItem.pos('setEntTableDef', 1) &lt;&gt; null
		or contextItem.pos('getSelectedString', 1) &lt;&gt; null
		or contextItem.pos('setValueByName', 1) &lt;&gt; null
		or contextItem.pos('getValueByName', 1) &lt;&gt; null
		or contextItem.pos('mainExtraListTableLostFocus', 1) &lt;&gt; null
		or contextItem.pos('listTableLostFocus', 1) &lt;&gt; null
		or contextItem.pos('showRowByName', 1) &lt;&gt; null
		or contextItem.pos('getPropertyValue', 1) &lt;&gt; null
		or contextItem.pos('setPropertyValue', 1) &lt;&gt; null
		or contextItem.pos('setObjectFromTable', 1) &lt;&gt; null
		or contextItem.pos('setTableFromObject', 1) &lt;&gt; null
		or contextItem.pos('setValuesFromOtherTable', 1) &lt;&gt; null
		or contextItem.pos('getControlByName', 1) &lt;&gt; null
		or contextItem.pos('cnEcGetTagValueOfName', 1) &lt;&gt; null
		or contextItem.pos('helpKeyword', 1) &lt;&gt; null
		or contextItem = 'logStr'
		or contextItem.toUpper.pos('FILE', 1) &lt;&gt; null
		or contextItem = 'app.myRoot.getQryReport'
		or contextItem.pos('getRow', 1) &lt;&gt; null 
		or contextItem.pos('mainExtraSetValue', 1) &lt;&gt; null 
		or contextItem.pos('warningMethod', 1) &lt;&gt; null 
		or contextItem = 'inputControl.name'
		or contextItem.pos('tblFilterCellInputReady', 1) &lt;&gt; null
		or contextItem = 'entTableSetObjectWarning'
		or contextItem = 'getTopSheetControl'
		or contextItem = 'viewName'
		or contextItem.pos('jrwDesignName', 1) &lt;&gt; null
		or contextItem.pos('enableEvent', 1) &lt;&gt; null
		or contextItem.toUpper.pos('FONT', 1) &lt;&gt; null
		or contextItem.toUpper.pos('LETTER', 1) &lt;&gt; null		// Yard Areas forms
		or contextItem = 'global.stillToDoRJS'
		;
		

end;</source>
        <access>protected</access>
        <Parameter name="str" type="String"/>
        <Parameter name="contextItem" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="filterMethod" id="d7aa0aec-536f-4969-b493-a1632ce574b7">
        <source>filterMethod(meth : Method):Boolean protected;

// method filters

begin
	return 
		meth.name.toUpper.pos('OLD',1) &lt;&gt; null 	
		or meth.name.toUpper.pos('XML',1) &lt;&gt; null 
		or meth.name.toUpper.pos('TEST',1) &lt;&gt; null 
		or meth.name.toUpper.pos('TMP',1) &lt;&gt; null 
		or meth.name.toUpper.pos('TEMP',1) &lt;&gt; null 
		or meth.name.pos('cellInputReady',1) &lt;&gt; null 
		or meth.name.pos('makeMessage',1) &lt;&gt; null 
		or meth.name.pos('outputFile',1) &lt;&gt; null
		or meth.name = 'createActivityHistory'
		or meth.name = 'log'
		or meth.name = 'initForDemo'
		or meth.name = 'initTblRowsForDemo'
		or meth.name.pos('writeLog',1) &lt;&gt; null
		or meth.name = 'goToErrorItem'
		or meth.name = 'initEntryTable'
		or meth.name.toUpper.pos('KIOSK', 1) &lt;&gt; null
		or meth.name = 'showQueryView'	// CMUI_StockMovementsForm
		or meth.name = 'setupClient'	// PortSchema
		or meth.name = 'setupCarterNote'	// PortSchema
		or meth.name = 'getDateEditMaskForShortFormat'	// PortSchema
		or meth.name = 'getDateShortFormat'	// PortSchema
		or meth.name = 'setRowColFromArray'	// CM_BaseTable
		or meth.name = 'getNarrationExample'	// INV_InvoiceTypes
		or meth.name = 'writeHTMLReportToFile'	//HMS_ShippingReport
		or meth.name = 'receival_ShowDocketRows'	// GTE_Assistant
		or meth.name = 'receival_ShowRows'		// GTE_Assistant
		or meth.name = 'showPrintFrame'		// GTE_ReleaseRequestForm
		;

end;</source>
        <access>protected</access>
        <Parameter name="meth" type="Method"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="findJmtLiterals" id="67798405-7831-47d1-9b81-a6631a9eee25">
        <source>findJmtLiterals();

// find literals in all methods in the JMT application schemas

vars
	fileSave		: CMDFileSave;
	file			: File;
	lsSchema		: LSschema;
	cls				: Class;
	lsClass			: LSclass;
	methSet			: MethodSet;
	meth			: Method;
	lsMethod		: LSmethod;
	str				: String;
	idx				: Integer;
	literals 		: HugeStringArray;
	startPositions	: IntegerArray;
	start			: Time;
	finish			: Time;
	contextType		: String;
	contextItem		: String;
	literalsCount	: Integer;
	literalsTotal	: Integer;
	literalColl : LSliteralDictionary;
	lsLiteral : LSliteral;
begin
	create literalColl transient;
	app.writeStatement( 'Starting');
	
	// Setup output file
	create fileSave transient;
	fileSave.defaultExt := '.csv';
	fileSave.fileTitle := 'literals';
	fileSave.fileName := 'c:\tmp\literals.csv';
	if fileSave.open &lt;&gt; 0 then 
		return; 
	endif;
	
	// get JMT application schema list
	self.fillSchemas();

	create literals transient;
	create startPositions transient;
	create methSet transient;

	foreach lsSchema in allSchemas do
		app.writeStatement( Tab&amp;lsSchema.name);

		literalsCount := 0;
		initFile(file, fileSave.fileName, lsSchema.name);

		foreach cls in lsSchema.mySchema.getAllClasses(false) where cls.rootType.schema = lsSchema.mySchema do	// skip subschema copies
			
			if filterClass(cls) then 
				continue;
			endif;

			methSet.clear;
			cls.allMethods(methSet);

			foreach meth in methSet do

				if filterMethod(meth) then
					continue;
				endif;

				literals.clear;
				startPositions.clear;
				meth.findLiterals(literals, startPositions);

				foreach idx in 1 to literals.size do

					str := literals[idx];

					meth.getContextInCode(startPositions[idx], contextType, contextItem);

					if filterLiteral(str, contextItem) then
						continue;
					endif;

					create lsLiteral transient;
					lsLiteral.text := str[1:500];
					if not literalColl.includesKey(lsLiteral.text) then
						literalColl.add(lsLiteral);
					endif;
					literalsCount := literalsCount + 1;
					file.writeLine(lsSchema.name &amp;',' &amp; cls.name &amp;','&amp; meth.name &amp;','&amp; str &amp;','&amp; contextType &amp;','&amp; contextItem);
					file.writeLine(',,,'&amp; generateName(str) &amp;',,');
				endforeach; // literal
			endforeach; // method
		endforeach; // class
		app.writeStatement( Tab&amp; literalsCount.String);

		literalsTotal := literalsTotal + literalsCount;
	endforeach; // schema
	
		
epilog
	finish := app.actualTimeServer.time;	// 12 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	app.writeStatement( 'Literals: ' &amp; literalsTotal.String);
	app.writeStatement (Tab &amp; literalColl.size.String);
	app.writeStatement( 'Complete ' &amp; finish.String &amp; ' (' &amp; ((finish - start)/1000).roundedTo(1).String &amp; ' secs)');
	if file &lt;&gt; null then
		file.close;
	endif;
	delete fileSave;
	delete file;
	delete literals;
	delete startPositions;
	delete methSet;
end;</source>
    </JadeMethod>
    <JadeMethod name="generateName" id="56d42a3c-e94c-4374-8871-701b25ffd943">
        <source>generateName(literal : String) : String;

vars
	name : String;
	first, last : Integer;
	idx : Integer;
	char : Character;
	underscoreMode : Boolean;
begin
	// Find the first and the last characters of the literal.
	first := 1;
	last := literal.length; 
	while first &lt; last do
		char := literal[first];
		if char.isAlpha then
			break;
		endif;
		first := first + 1;
	endwhile;
	
	while last &gt; first do
		char := literal[last];
		if char.isAlpha or char.isNumeric then
			break;
		endif;
		last := last - 1;
	endwhile;
	
	foreach idx in first to last do
		char := literal[idx];
		if char.isAlpha or char.isNumeric then
			underscoreMode := false;
			name := name &amp; literal[idx];
		elseif underscoreMode = false then
			underscoreMode := true;
			name := name &amp; "_";
		endif;
	endforeach;

	name.firstCharToUpper;
	return name;
end;
</source>
        <Parameter name="literal" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="initFile" id="456bfe12-8df9-4bda-8ccd-92a8a97f21da">
        <source>initFile(file : File io; fname, scmName : String) protected;

vars
	pos : Integer;
	fileName : String;
begin
	if file &lt;&gt; null then
		file.close;
	endif;
	delete file;
	create file transient;
	file.usePresentationFileSystem := true;
	pos := fname.reversePos('.csv');
	fileName := fname[1:pos-1]&amp;'-'&amp;scmName&amp;'.csv';
	file.openOutput(fileName);
	file.writeLine('Schema,Class,Method,Literal');

end;</source>
        <access>protected</access>
        <Parameter name="file" type="File" usage="io"/>
        <Parameter name="fname" type="String"/>
        <Parameter name="scmName" type="String"/>
    </JadeMethod>
</Class>
