<Class name="CM_CamAgGatewayDesc" id="b61a68a1-f4db-4cd3-8b4d-2e2472e1d6ff">
    <superclass name="CM_CamProtocolDesc"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="cams"/>
    <JadeMethod name="addCamsMsg" id="1bcc0295-327e-4b3d-a113-c2baae1054e0">
        <source>addCamsMsg(_camMsg : CM_CamMessage io; _msg : String);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 Sep 2025 navnk30 JIRA 35756: 8 - Create a new Cams protocol to handle Truck Departure events and generate "Ship Notice" Messages

*/

vars
	msgLen	: Integer;	
	strVal	: String;
begin
	strVal := _msg;
	msgLen := strVal.length;
	
	while msgLen &gt; 2047 do
		_camMsg.group3.add(strVal[1:2047]);	
		strVal := strVal[2048:msgLen];
		msgLen := strVal.length;
	endwhile;
	
	_camMsg.group3.add(strVal);
epilog

end;</source>
        <Parameter name="_camMsg" type="CM_CamMessage" usage="io"/>
        <Parameter name="_msg" type="String"/>
    </JadeMethod>
    <JadeMethod name="availableCargoTypes" id="effb23f6-d3c4-4e21-9e5e-ef89f05f6dd3">
        <source>availableCargoTypes(_classColl: ClassColl input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 August 2025	navra1	Initial creation

*/

vars

begin
	inheritMethod(_classColl);
	
	_classColl.add(CM_BreakBulk);
	_classColl.add(CM_BreakBulkGeneric);
	_classColl.add(CM_Bulk);
	_classColl.add(CM_Cargo);

epilog

end;</source>
        <Parameter name="_classColl" type="ClassColl" usage="input"/>
    </JadeMethod>
