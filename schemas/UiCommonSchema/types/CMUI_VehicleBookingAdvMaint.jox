    <JadeMethod name="setupCarrierCombo" id="2c24a5cd-5493-4017-903d-8ff982b64071">
        <source>setupCarrierCombo();
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
20 Sep 2022		navcs2	ChangeRequest 53899: EUP - VBS MTN - [3] - Maintaining VBS Slot

*/

vars
	carrier : CM_Carrier;
	driver : CM_DriverDetails;
	vehicle : CM_Vehicle;
begin

	self.cmbCarrier.clear();
	
	if self.myProxyVehicleBookingTimeSlot &lt;&gt; null then
		carrier := self.myProxyVehicleBookingTimeSlot.myCarrier;
		driver := self.myProxyVehicleBookingTimeSlot.myDriver;
		vehicle := self.myProxyVehicleBookingTimeSlot.myVehicle;
	endif;
		
	self.populateCarrierCombo();
	
	self.setupDriverCombo( carrier, driver );
	
	self.setupVehicleCombo( driver, vehicle );

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupDriverCombo" id="e87e0ca4-5b69-4141-b2ef-c0c2dbdc47d9">
        <source>setupDriverCombo( _carrier : CM_Carrier; _driver : CM_DriverDetails );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 Sep 2022	navcs2	ChangeRequest 53899: EUP - VBS MTN - [3] - Maintaining VBS Slot
26 Dec 2022	navak20 Task 55979: EUP - VBS MTN - [3] - Maintaining VBS Slot - Review Changes
27 Apr 2023 navma1  ChangeRequest 57716:[57718] EUP - VBS changes MTN - Bulk Edit and Linking of slots [Refinement - 01]
03 Aug 2023	navma1	Bug 59263: Error 1090 when validating VBS Slots Criteria
18 Jun 2024	jlizm1	TFS 63908 Allow duplicate driver names
*/

vars

	iter    	: Iterator;
	driver  	: CM_DriverDetails;
	idx			: Integer;				// 26.12.2022 navak20 TFS 55979
	allowDups 	: Boolean;
	driverStr	: String;
	
begin

	if _carrier = null then
		self.cmbDriver.enabled := false;
	else
		self.cmbDriver.clear();
		self.cmbDriver.enabled := true;
		iter 		:= _carrier.allDrivers.createIterator;
		allowDups	:= self.myTerminal.getConfig(AllowDupDriverNames).Boolean;
		
		self.cmbDriver.addItem( null );
		
		while iter.next( driver ) do
			
			if driver.myTerminal &lt;&gt; self.myTerminal then
				continue;
			endif;
			
			if driver.status &lt;&gt; CM_DriverDetails.Status_Allowed then				     //27.04.2023 navma1 #57716:[57718]
				continue;
			endif;
			
			if allowDups then
				driverStr := driver.code &amp; Space &amp; driver.name;
			else
				driverStr := driver.name;
			endif;
			
			idx 						   := self.cmbDriver.addItem(driverStr);		// 26.12.2022 navak20 TFS 55979
			self.cmbDriver.itemObject[idx] := driver;									// 26.12.2022 navak20 TFS 55979
		endwhile;
		
		if _driver &lt;&gt; null then
			self.cmbDriver.listIndex := self.cmbDriver.findObject(_driver);
		endif;
	endif;

	if self.myProxyVehicleBookingTimeSlot &lt;&gt; null then
		self.myProxyVehicleBookingTimeSlot.setCarrier(_carrier); 						//03.08.2023 navma1 #59263
	endif;
	
epilog
	delete iter;
end;</source>
        <Parameter name="_carrier" type="CM_Carrier"/>
        <Parameter name="_driver" type="CM_DriverDetails"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="510e4d0a-54a3-465d-bc62-f3692bf42a97">
        <updating/>
        <source>setupForm() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
08 July 2022	navcs2	ChangeRequest 53899: EUP - VBS MTN - [3] - Maintaining VBS Slot Initial Creation
24 Apr 2023 	navhl20	ChangeRequest 57716:[57718] EUP - VBS changes MTN - Bulk Edit and Linking of slots [Refinement - 01]
26 Feb 2025		navpw1	JIRA: MTN-34070 - Fixed VBS Item Table column organiser this is read automatically no need to do it manually.

*/

vars
	tsNow 				: TimeStamp;
	isSubCarrierEnabled : Boolean;
	term				: CM_Terminal;
	
begin
	inheritMethod();
	
	term 						  := self.myTerminal;
	isSubCarrierEnabled 		  := term.getConfig(IsSubCarrierEnabled).Boolean;			//27.04.2023 navma1 #57716:[57718]
	
	self.cmbSubCarrier.visible := false;
	self.lblSubCarrier.visible := false;
	
	if isSubCarrierEnabled then																//27.04.2023 navma1 #57716:[57718]
		self.cmbSubCarrier.visible := true;
		self.lblSubCarrier.visible := true;
	endif;
	
	self.txtCopySlots.text := "1";															//24.4.2023 navhl20 #57716[57718]
	if self.vehicleBookingMode = self.MODE_UPDATE then										//24.4.2023 navhl20 #57716[57718]
		self.adjustControlsForEdit();
	endif;
	
	if self.myProxyVehicleBookingTimeSlot &lt;&gt; null then
		self.setControls();
		return;
	endif;
	
	self.populateCombos();
	
	self.txtId.enabled := false;
	
	tsNow := self.systemToLocalTime(app.actualTimeServer);
	self.startDT.setDate(tsNow.date());
	self.startTM.setTime(tsNow.time());
	
	self.endDT.setDate(tsNow.date());
	
	self.initTblSlotItems();									// ### JIRA: MTN-34070 05Mar2025 NAVPW1
	
	self.populateTableBookingItems();
	
	self.createPxyVehicleBookTimeSlot();
	
	self.btnSave.enabled := false;
	
	self.cmbVbsSlotType_click(cmbVbsSlotType);
	
	if not self.allVehicleBookingTimeSlots.isEmpty then
		self.cmbVbsSlotType.listObject := self.allVehicleBookingTimeSlots.first.myVBTimeSlotType;
	endif;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="setupVehicleCombo" id="cddafd30-9fbf-423a-a990-6b3523a77b1c">
        <source>setupVehicleCombo( _driver : CM_DriverDetails; _vehicle : CM_Vehicle );
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
20 Sep 2022		navcs2	ChangeRequest 53899: EUP - VBS MTN - [3] - Maintaining VBS Slot
26 Dec 2022	navak20 Task 55979: EUP - VBS MTN - [3] - Maintaining VBS Slot - Review Changes
*/

vars

	vehicle : CM_Vehicle;
	iter : Iterator;
	idx : Integer;	// 26.12.2022 navak20 TFS 55979
begin

	if _driver = null then
		self.cmbVehicle.enabled := false;
		
	else
		self.cmbVehicle.enabled := true;
		self.cmbVehicle.clear();
		
		self.cmbVehicle.addItem( app.getErrorString(AnyString) );
		iter := _driver.allVehicleMachines.createIterator;
		while iter.next( vehicle ) do
			idx := self.cmbVehicle.addItem( vehicle.regNumber );	// 26.12.2022 navak20 TFS 55979
			//self.cmbVehicle.itemObject[self.cmbVehicle.addItem( vehicle.regNumber )] := vehicle;		// 26.12.2022 navak20 TFS 55979
			self.cmbVehicle.itemObject[idx] := vehicle;		// 26.12.2022 navak20 TFS 55979
		endwhile;
		
		if _vehicle &lt;&gt; null then
			self.cmbVehicle.listIndex := self.cmbVehicle.findObject(_vehicle);
		endif;
		
	endif;

epilog
	delete iter;

end;</source>
        <Parameter name="_driver" type="CM_DriverDetails"/>
        <Parameter name="_vehicle" type="CM_Vehicle"/>
    </JadeMethod>
