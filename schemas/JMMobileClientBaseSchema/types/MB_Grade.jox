<Class name="MB_Grade" id="347b680e-8b3f-447c-bb10-99bb5c13de41">
    <superclass name="MB_Transient"/>
    <transient/>
    <sharedTransientAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <access>protected</access>
    <DbClassMap file="mbTransient"/>
    <PrimAttribute name="code" id="57a56fa9-1966-4eab-a914-5b6e7a0e843d">
        <embedded/>
        <type name="Integer"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="description" id="0c9c1861-e2e4-41a4-af75-045fd2f98428">
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="isCurrentGrade" id="d5ec272f-73ec-4bba-be33-d19df639443a">
        <embedded/>
        <type name="Boolean"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="isNewGrade" id="515aaead-add8-4c38-aae2-0775aa9436df">
        <embedded/>
        <type name="Boolean"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="setNewGrade" id="2c4d819f-de8a-41ce-9f8d-ac88862e6b88">
        <updating/>
        <source>setNewGrade(_isNewGrade:Boolean) updating;
// --------------------------------------------------------------------------------
// Created:		03 February 2006 by cnwdad1
//
// Purpose:		Sets/resets the flag to indicate whether the receiver is the new
//				Grade.
//
// Parameters:	_isNewGrade - True if the receiver is the new Grade, otherwise false.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.isNewGrade	:=	_isNewGrade;
end;</source>
        <Parameter name="_isNewGrade" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="translateFromPackage" id="96f17901-09d0-4380-8482-287d70257859">
        <updating/>
        <source>translateFromPackage(_gradeObj:DTO_Grade) updating;
// --------------------------------------------------------------------------------
// Created:		23 January 2006 by cnwdad1
//
// Purpose:		Translates the property values from a Grade object received via the
//				DTO package.
//
// Parameters:	_gradeObj - A reference to the package Grade object.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.updateMe(_gradeObj.code, _gradeObj.description, _gradeObj.isCurrentGrade);
end;</source>
        <Parameter name="_gradeObj" type="MobileServerRTThin::DTO_Grade"/>
    </JadeMethod>
    <JadeMethod name="translateFromWebServices" id="73b5554e-af00-47c1-8d56-8c13ba29a4e7">
        <updating/>
        <source>translateFromWebServices(_gradeObj:WebSrv_DTO_Grade) updating;
// --------------------------------------------------------------------------------
// Created:		23 January 2006 by cnwdad1
//
// Purpose:		Translates the property values from a Grade object received via a
//				Web Services SOAP message.
//
// Parameters:	_gradeObj - A reference to the SOAP Grade object.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.updateMe(_gradeObj.code, _gradeObj.description, _gradeObj.isCurrentGrade);
end;</source>
        <Parameter name="_gradeObj" type="WebSrv_DTO_Grade"/>
    </JadeMethod>
    <JadeMethod name="translateToPackage" id="75c4f733-1bce-46bb-ac0e-aaaef2c7918d">
        <updating/>
        <source>translateToPackage(_gradeObj:DTO_Grade input) updating;
// --------------------------------------------------------------------------------
// Created:		23 January 2006 by cnwdad1
//
// Purpose:		Translates the property values from the receiver to a Grade object
//				received via the DTO package.
//
// Parameters:	_gradeObj - A reference to the package Grade object.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	_gradeObj.code				:=	self.code;
	_gradeObj.description		:=	self.description;
	_gradeObj.isCurrentGrade	:=	self.isCurrentGrade;
end;</source>
        <Parameter name="_gradeObj" type="MobileServerRTThin::DTO_Grade" usage="input"/>
    </JadeMethod>
    <JadeMethod name="translateToWebServices" id="231b221a-c799-4047-ba0f-076fb33010eb">
        <updating/>
        <source>translateToWebServices(_gradeObj:WebSrv_DTO_Grade input) updating;
// --------------------------------------------------------------------------------
// Created:		23 January 2006 by cnwdad1
//
// Purpose:		Translates the property values from the receiver to a Grade object
//				received via a Web Services SOAP message.
//
// Parameters:	_gradeObj - A reference to the SOAP Grade object.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	_gradeObj.code				:=	self.code;
	_gradeObj.description		:=	self.description;
	_gradeObj.isCurrentGrade	:=	self.isCurrentGrade;
end;</source>
        <Parameter name="_gradeObj" type="WebSrv_DTO_Grade" usage="input"/>
    </JadeMethod>
    <JadeMethod name="updateMe" id="7a58db75-e8e5-47c7-b7dd-b98ada1c2550">
        <updating/>
        <source>updateMe(_code:Integer; _description:String; _isCurrentGrade:Boolean) updating;
// --------------------------------------------------------------------------------
// Created:		23 January 2006 by cnwdad1
//
// Purpose:		Sets the receiver's property values.
//
// Parameters:	_code - The Grade's unique code.
//				_description - A description of the Grade.
//				_isCurrentGrade - True if the receiver is the current grade.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.code			:=	_code;
	self.description	:=	_description;
	self.isCurrentGrade	:=	_isCurrentGrade;
	self.isNewGrade		:=	_isCurrentGrade;
end;</source>
        <Parameter name="_code" type="Integer"/>
        <Parameter name="_description" type="String"/>
        <Parameter name="_isCurrentGrade" type="Boolean"/>
    </JadeMethod>
</Class>
