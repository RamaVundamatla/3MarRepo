<GUIClass name="Window">
    <Constant name="MB_MODAL_CANCEL" id="d3bc736b-44f9-4b88-ab9b-1adc8f9e8d35">
        <source>0</source>
        <type name="Integer"/>
        <text>Set the "modalResult" of your modal forms to this value when
a User is returning from a Modal form without having made
any changes.</text>
    </Constant>
    <Constant name="MB_MODAL_CLOSE" id="f3b51a8d-394d-4ff7-8963-fcecaf8927a0">
        <source>1</source>
        <type name="Integer"/>
        <text>Set the "modalResult" of your modal forms to this value when
a User is returning from a Modal form without any action.</text>
    </Constant>
    <Constant name="MB_MODAL_CREATE" id="7b37d44c-54f1-48a4-8f5d-d9dbc112e3da">
        <source>2</source>
        <type name="Integer"/>
        <text>Set the "modalResult" of your modal forms to this value when
a User is returning from a Modal form after creating an
object.</text>
    </Constant>
    <Constant name="MB_MODAL_SELECT" id="554cadbb-84b9-4a5a-9f1a-32f13e293219">
        <source>4</source>
        <type name="Integer"/>
        <text>Set the "modalResult" of your modal forms to this value when
a User is returning from a Modal form after selecting one or
more objects.</text>
    </Constant>
    <Constant name="MB_MODAL_UPDATE" id="2362d4d4-6cd7-4920-bbeb-d5b04c4f8157">
        <source>5</source>
        <type name="Integer"/>
        <text>Set the "modalResult" of your modal forms to this value when
a User is returning from a Modal form after updating an
object.</text>
    </Constant>
    <Constant name="MB_MODFAL_DELETE" id="6ffb5e6d-2220-4773-b1e0-831beea59747">
        <source>3</source>
        <type name="Integer"/>
        <text>Set the "modalResult" of your modal forms to this value when
a User is returning from a Modal form after deleting an
object.</text>
    </Constant>
</GUIClass>
