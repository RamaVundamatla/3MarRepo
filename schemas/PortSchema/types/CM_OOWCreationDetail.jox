    <JadeMethod name="addJob" id="b1b0fb03-fd34-4eb5-9e5e-f4f1f14d7e27">
        <updating/>
        <source>addJob(_job: CM_VoyageJob) updating;
// ---------------------------------------------------------------------------
// Created:		25 May 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
    req : CM_Request;
    sreq : CM_SlotRequest;
	isBackend : Boolean;
begin

    foreach req in _job.allRequests do
        if req.isKindOf(CM_SlotRequest) then
            sreq := req.CM_SlotRequest;
			isBackend := sreq.getAttrIsBackend(); // PAR 21746
			
            if sreq.myBay = self.myBay
           // PAR 21746  and self.is40 = (sreq.fortyBack or sreq.getAttrIs40()) then
            and self.is40 = isBackend then
				inheritMethod(_job);
				break;
            endif;          
        endif;
    endforeach;

end;</source>
        <Parameter name="_job" type="CM_VoyageJob"/>
    </JadeMethod>
    <JadeMethod name="calculateNumberOfLifts" id="b46f254d-41ec-4400-8352-0e8eae5edb95">
        <source>calculateNumberOfLifts() : Real;
// ---------------------------------------------------------------------------
// Created:		29 February 2008 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	sr : CM_SlotRequest;
	vwle : CM_VoyageWLE;
	wle : CM_WorkListEntry;
	done, notDone : Real;
begin
	foreach sr in self.allSlotRequests discreteLock do
		foreach wle in sr.allWorkListEntries discreteLock do
			wle.CM_VoyageWLE.getLiftTotals(done, notDone);
		endforeach;
	endforeach;
	return done + notDone;
end;</source>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="clear" id="4b874f98-b192-4eba-bc3e-45ba098f521e">
        <updating/>
        <source>clear() updating;
// ---------------------------------------------------------------------------
// Created:		28 April 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
begin
	inheritMethod();
	
	self.discDLR20 := null;
	self.discIMP20 := null;
	self.discREF20 := null;
	self.discSOB20 := null;
	self.discTSH20 := null;

	self.loadDLR20 := null;
	self.loadEXP20 := null;
	self.loadREF20 := null;
	self.loadSOB20 := null;
	self.loadTSH20 := null;

	self.discDLR40 := null;
	self.discIMP40 := null;
	self.discREF40 := null;
	self.discSOB40 := null;
	self.discTSH40 := null;
 // PAR 16415 CCMS 1029
	self.loadDLR30 := null;
	self.loadEXP30 := null;
	self.loadREF30 := null;
	self.loadSOB30 := null;
	self.loadTSH30 := null;

	self.discDLR30 := null;
	self.discIMP30 := null;
	self.discREF30 := null;
	self.discSOB30 := null;
	self.discTSH30 := null;

	self.loadDLR30 := null;
	self.loadEXP30 := null;
	self.loadREF30 := null;
	self.loadSOB30 := null;
	self.loadTSH30 := null;

	
	

	self.loadDLR53 := null;
	self.loadEXP53 := null;
	self.loadREF53 := null;
	self.loadSOB53 := null;
	self.loadTSH53 := null;

	self.discDLR53 := null;
	self.discIMP53 := null;
	self.discREF53 := null;
	self.discSOB53 := null;
	self.discTSH53 := null;

	self.loadDLR53 := null;
	self.loadEXP53 := null;
	self.loadREF53 := null;
	self.loadSOB53 := null;
	self.loadTSH53 := null;
	
	
	self.allSlotRequests.clear;
	
		

end;</source>
    </JadeMethod>
    <JadeMethod name="getDescription" id="5d577b4e-c16f-4232-bb72-137a644d64c7">
        <source>getDescription() : String;
// ---------------------------------------------------------------------------
// Created:		18 September 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	tmpStr : String;
begin
	if self.myCraneJobSheet &lt;&gt; null then
		tmpStr := tmpStr &amp; self.myCraneJobSheet.crane &amp; " ";
	endif;
	if self.myBay &lt;&gt; null then
		tmpStr := tmpStr &amp; "Bay " &amp; self.myBay.id &amp; ", ";
	endif;
	
	tmpStr := tmpStr &amp; self.getTotalItems().String &amp; " ";
	if self.isDischarge() then
		if self.isOnDeck() then
			tmpStr := tmpStr &amp; "discharge items OD";
		else
			tmpStr := tmpStr &amp; "discharge items UD";
		endif;
	else
		if self.isOnDeck() then
			tmpStr := tmpStr &amp; "load items OD";
		else
			tmpStr := tmpStr &amp; "load items UD";
		
		endif;
	endif;
	
	return tmpStr;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="3ff50e88-2fb8-4d8e-be96-97db97a06a55">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
05 September 2011	cnwer1	Initial creation CCMS MES 1033

*/

vars
		str, jStr, tlStr : String;
aJob : CM_VoyageJob;
begin

	if _attrName = ETRow_Deck then
	
		return self.id;
		
	elseif _attrName = ETRow_DeckOridinal then
		return self.getDeckCode;
	elseif _attrName = ETRow_Job then
		foreach aJob in self.allJobs do
			tlStr := null;
			if aJob.isTwinLift then
				tlStr := " TL";
			endif;
			if jStr = "" then
				jStr := aJob.jobNum &amp; tlStr;
			else
				jStr := jStr &amp; ", " &amp; aJob.jobNum &amp; tlStr;
			endif; 
		endforeach;
		return jStr;
	elseif  _attrName = ETRow_Discharge20 then
		return self.discIMP20.zeroNotAllowed;
	elseif _attrName = ETRow_Discharge40 then
		return self.discIMP40.zeroNotAllowed;
	elseif _attrName = ETRow_DischDLR20 then
		return self.discDLR20.zeroNotAllowed;
	elseif _attrName = ETRow_DischDLR40 then
		return self.discDLR40.zeroNotAllowed;	
	elseif _attrName = ETRow_Load20 then
		return self.loadEXP20.zeroNotAllowed;
	elseif _attrName = ETRow_Load40 then
		return self.loadEXP40.zeroNotAllowed;
	elseif _attrName = ETRow_LoadDLR20 then
		return self.loadDLR20.zeroNotAllowed;
	elseif _attrName = ETRow_LoadDLR40 then
		return self.loadDLR40.zeroNotAllowed;
	elseif _attrName = ETRow_Sob20 then
		return (self.discSOB20 + self.loadSOB20 ).zeroNotAllowed();
	elseif _attrName = ETRow_Sob40 then
		return	(self.discSOB40 + self.loadSOB40).zeroNotAllowed();
	elseif _attrName = ETRow_Refeer20 then
		return	(self.discREF20 + self.loadREF20).zeroNotAllowed();
	elseif _attrName = ETRow_Reefer40 then
		return	(self.discREF40 + self.loadREF40).zeroNotAllowed();
	elseif _attrName = ETRow_DeckTotal then
		return self.getTotalItems.zeroNotAllowed();
	elseif _attrName = ETRow_Lifts then
		return null;
	elseif _attrName = ETRow_FwdAft then
		return null;
	elseif _attrName = ETRow_AftFwd then
		return null;
		
	elseif _attrName = ETRow_WorkPointTotal then
		return null;
	else
		return inheritMethod(_attrName, _short);
	endif;
epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getIs40" id="71d20734-3404-4286-ba74-bd53c4199bdf">
