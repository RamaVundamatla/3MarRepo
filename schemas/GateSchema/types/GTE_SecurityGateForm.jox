    <JadeMethod name="doCancelVisit" id="4f6e6395-a3c7-4684-b1f7-3648c38b472e">
        <updating/>
        <source>doCancelVisit(_visit : CM_VehicleVisitRecord input) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 31/12/2013	cnwdap1		Initial creation PAR #32849 CCMS PEN 2321 Security Gate
//
vars
	form	: GTE_VehicleTurnaroundReason;
	result,
	cancel	: Integer;
	bat : String;
begin
	if not app.myCurrentUserCan(self.myTerminal, PmGteGateCanCancelFlexiJob) then
		return;
	endif;
	
	if _visit &lt;&gt; null and _visit.isUpdatable and _visit.status &lt;&gt; _visit.Status_Cancelled then
		form := app.loadForm(GTE_VehicleTurnaroundReason, 
							GTE_Assistant, 
							false, false, true, 
							self.myTerminal, null).GTE_VehicleTurnaroundReason;
							
		bat := _visit.getBatNumber(); // PAR 34269
		if bat &lt;&gt; null then
			form.setTitle("( BAT " &amp;  bat &amp; ")"); // PAR 34269
		endif;
		
		result := form.showModal();
		if result = IDOK then
		
			while true do
				app.myTrxUA.trxUpdateVVRCancel(_visit, form.txtReason.text, app.myPassport);
				
				if app.myPassport.trxCompletedOK then
					// Clear errors/warnings from form and err/warnings window
					self.clearErrorWarnings();
					break;
				else
					cancel := app.showErrorWarningDialog(app.getErrorString(GateInOut), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
					if app.myPassport.noErrors and cancel = IDOK then
						// there must have just been warnings that the user has acknoledged so ..
						app.myPassport.warningsAcknowledged := true;
						continue;
					endif;
					self.setAllErrorWarnings(app.myPassport);       // copies errors to this form and shows in err/warnings window
					return;
				endif;
				break;
			endwhile;
			
		else
			return;
		endif;
	endif;
	
epilog

end;</source>
        <Parameter name="_visit" type="CM_VehicleVisitRecord" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doCompleteVisit" id="3b27747c-cd4e-4961-be48-f62b4f0a22e5">
        <source>doCompleteVisit();
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 17/12/2013	cnwdap1		Initial creation PAR #32849 CCMS PEN 2321 Security Gate
//
vars
	form	: GTE_SecurityGateVisitExit;
	vvr		: CM_VehicleVisitRecord;

begin
	if not self.tblData.allSelectedObjects.isEmpty then // PAR 34269
		vvr := self.tblData.allSelectedObjects.first.CM_VehicleVisitRecord; // PAR 34269
	endif;
	if vvr = null then
		return;
	endif;
	
	form := app.loadForm(	GTE_SecurityGateVisitExit, 
							self.myAssistant.class, 
							false, false, true, 
							self.myTerminal, null).GTE_SecurityGateVisitExit;
	
	if form &lt;&gt; null then
		form.setMyVehicleVisitRecord(vvr);
		form.showModal;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doFindBATNumber" id="c8e82c6a-24af-4ee5-ab75-c73d7f4923d0">
        <source>doFindBATNumber();
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 14/05/2014	cnwdap1		Initial creation PAR #34117 Security Gate
//
vars
	row	: Integer;
	obj : Object;
	vvr : CM_VehicleVisitRecord;
	bat : String;

begin
	self.tblData.clearAllSelected(); // PAR 34269
	self.tblData.row := self.tblData.fixedRows; // PAR 34269
	
	foreach row in self.tblData.fixedRows + 1 to self.tblData.rows do
		obj := self.tblData.accessRow(row).itemObject;
		if obj &lt;&gt; null then
			vvr := obj.CM_VehicleVisitRecord;
			bat := vvr.getBatNumber;
			if bat.toUpper = self.txtFindBAT.text.toUpper then
				self.tblData.selectRow(row, true); // PAR 34269
				break; // PAR 34269
			endif;
		endif;
	endforeach;
	
epilog

end;</source>
    </JadeMethod>
