<GUIClass name="CMUI_FieldGeneric" id="b90156b1-4c4b-4c5e-917a-e30ba585f77b">
    <superclass name="CMUI_FieldFrame"/>
    <transient/>
    <sharedTransientAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <access>protected</access>
    <DbClassMap file="_usergui"/>
    <JadeMethod name="buildSelf" id="f564946f-7557-44b3-9705-11c2806d5b53">
        <updating/>
        <source>buildSelf() updating, protected;
// --------------------------------------------------------------------------------
// Created:		16 February 2006 by cnwdad1
//
// Purpose:		Instantiates the appropriate controls, and sets them all up.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	controlWidth	: Real;
	controlLeft		: Real;
	textboxObj		: TextBox;
	
begin
	inheritMethod();
	self.doAlignCtrls(self);
end;</source>
        <access>protected</access>
    </JadeMethod>
    <ExternalMethod name="doAlignCtrls" id="d57a4448-a7d5-43c9-9b04-af339a5993bb">
        <updating/>
        <entrypoint>CallControlEvent</entrypoint>
        <library name="jadpmap"/>
        <source>doAlignCtrls(_fieldGeneric:CMUI_FieldGeneric input) is CallControlEvent in jadpmap updating;
// --------------------------------------------------------------------------------
// Created:		24 February 2006 by cnwdad1
//
// Purpose:		Code this method on your form to handle aligning your generic
//				controls contained on the receiver.
// --------------------------------------------------------------------------------</source>
        <Parameter name="_fieldGeneric" type="CMUI_FieldGeneric" usage="input"/>
    </ExternalMethod>
    <ExternalMethod name="doEnabled" id="52126e75-db6b-42ab-8e5f-42db55e842cc">
        <updating/>
        <entrypoint>CallControlEvent</entrypoint>
        <library name="jadpmap"/>
        <source>doEnabled(_isEnabled:Boolean) is CallControlEvent in jadpmap updating;
// --------------------------------------------------------------------------------
// Created:		01 March 2006 by cnwdad1
//
// Purpose:		Code this method on your form to handle enabling your generic
//				controls contained on the receiver.
// --------------------------------------------------------------------------------</source>
        <Parameter name="_isEnabled" type="Boolean"/>
    </ExternalMethod>
    <ExternalMethod name="doTabOrder" id="ef7d7000-296f-4e5c-97cd-67deb943aba2">
        <entrypoint>CallControlEvent</entrypoint>
        <library name="jadpmap"/>
        <source>doTabOrder(_startTab:Integer):Integer is CallControlEvent in jadpmap protected;
// --------------------------------------------------------------------------------
// Created:		27 February 2006 by cnwdad1
//
// Purpose:		Code this method on your form to handle setting up the tab order of
//				your generic controls contained on the receiver.
// --------------------------------------------------------------------------------</source>
        <access>protected</access>
        <Parameter name="_startTab" type="Integer"/>
        <ReturnType type="Integer"/>
    </ExternalMethod>
    <ExternalMethod name="doUpdateValue" id="7d2cb849-3522-471b-aea3-a75e09704bdc">
        <updating/>
        <entrypoint>CallControlEvent</entrypoint>
        <library name="jadpmap"/>
        <source>doUpdateValue(_value:Any) is CallControlEvent in jadpmap updating;
// --------------------------------------------------------------------------------
// Created:		22 February 2006 by cnwdad1
//
// Purpose:		Code this method on your form to handle setting data/values on your
//				generic controls contained on the receiver.
// --------------------------------------------------------------------------------</source>
        <Parameter name="_value" type="Any"/>
    </ExternalMethod>
    <JadeMethod name="setIsEnabled" id="35462a5d-d3b3-4515-8cce-83d8a87c8e27">
        <updating/>
        <source>setIsEnabled(_isEnabled: Boolean) updating;
// --------------------------------------------------------------------------------
// Created:		01 March 2006 by cnwdad1
//
// Purpose:		Refer to the superclass implementation.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.doEnabled(_isEnabled);
end;</source>
        <Parameter name="_isEnabled" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setTabOrder" id="a287cd3f-343d-412d-8a5b-f726670a0215">
        <source>setTabOrder(_tabOrder: Integer):Integer;
// --------------------------------------------------------------------------------
// Created:		27 February 2006 by cnwdad1
//
// Purpose:		Refer to superclass implementation.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	tabOrder	: Integer;
	
begin
	tabOrder	:=	inheritMethod(_tabOrder);
	tabOrder	:=	tabOrder + 1;
	
	return self.doTabOrder(tabOrder);
end;</source>
        <Parameter name="_tabOrder" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setValue" id="fa7734af-3d42-4af6-a890-abbda5968c10">
        <updating/>
        <source>setValue(_value: Any) updating;
// --------------------------------------------------------------------------------
// Created:		22 February 2006 by cnwdad1
//
// Purpose:		Sets the receiver's field value.
//
// Parameters:	_value - The field value to set.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.doUpdateValue(_value);
end;</source>
        <Parameter name="_value" type="Any"/>
    </JadeMethod>
    <JadeMethod name="setWidths" id="b88e1e3e-3833-4bfa-b888-73db05653b1a">
        <updating/>
        <source>setWidths(_controlWidth: Integer; _labelWidth: Integer) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 July 2009	cnwdap1	Initial creation

*/

vars

begin
	inheritMethod(_controlWidth, _labelWidth);
epilog

end;</source>
        <Parameter name="_controlWidth" type="Integer"/>
        <Parameter name="_labelWidth" type="Integer"/>
    </JadeMethod>
    <DevControlTypes name="CMUI_FieldGeneric">
        <bitmap></bitmap>
        <windowClass>AlFrame</windowClass>
        <DevControlProperties name="alignChildren">
            <cntrlType>list</cntrlType>
            <optionsList>
                <value>0 - None</value>
                <value>1 - Align Width</value>
                <value>2 - All</value>
            </optionsList>
        </DevControlProperties>
        <DevControlProperties name="alignContainer">
            <cntrlType>list</cntrlType>
            <optionsList>
                <value>0 - None</value>
                <value>1 - Align Top</value>
                <value>2 - Align Bottom</value>
                <value>3 - Align Width</value>
                <value>4 - Stretch to next control below</value>
                <value>5 - Align All Horizontal</value>
                <value>6 - Align All Vertical</value>
            </optionsList>
        </DevControlProperties>
        <DevControlProperties name="alignment">
            <cntrlType>list</cntrlType>
            <optionsList>
                <value>0 - Left  justify - TOP</value>
                <value>1 - Left  justify - MIDDLE</value>
                <value>2 - Left  justify - BOTTOM</value>
                <value>3 - Right justify - TOP</value>
                <value>4 - Right justify - MIDDLE</value>
                <value>5 - Right justify - BOTTOM</value>
                <value>6 - Center - TOP</value>
                <value>7 - Center - MIDDLE</value>
                <value>8 - Center - BOTTOM</value>
            </optionsList>
        </DevControlProperties>
        <DevControlProperties name="allowDocking">
            <cntrlType>integer</cntrlType>
        </DevControlProperties>
        <DevControlProperties name="backBrush">
            <cntrlType>picture</cntrlType>
        </DevControlProperties>
        <DevControlProperties name="backBrushStyle">
            <cntrlType>list</cntrlType>
            <optionsList>
                <value>0 - tile</value>
                <value>1 - stretch</value>
                <value>2 - center</value>
                <value>3 - stretch proportional</value>
            </optionsList>
        </DevControlProperties>
        <DevControlProperties name="backColor">
            <cntrlType>color</cntrlType>
        </DevControlProperties>
        <DevControlProperties name="bevelColor">
            <cntrlType>color</cntrlType>
        </DevControlProperties>
        <DevControlProperties name="bevelInner">
