begin
	self.validateMe();
end;</source>
    </JadeMethod>
    <JadeMethod name="validateMe" id="7adc4135-0e8b-4ba4-8fbf-67ec50df72d6">
        <source>validateMe() protected;
// -----------------------------------------------------------------------------
// Created:		17 June 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
vars
	qryParam		: CM_QueryReportParam;
begin
	
	if self.reportType = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Report Type', ETRow_ReportType, null);
		app.raiseCMException(Input_required_field_reprtType, ETRow_ReportType, null); // cnwdb2	PAR 35364
	endif;
	
	if (self.reportType = self.ReportType_Selector) and (self.mySelectorQuery = null) then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Selector Query', ETRow_SelectorQuery, null);
		app.raiseCMException(Input_required_field_selectQue, ETRow_SelectorQuery, null); // cnwdb2	PAR 35364
	endif;
	
	foreach qryParam in self.allQueryReportParams do
		qryParam.validateMe();
	endforeach;
end;</source>
        <access>protected</access>
    </JadeMethod>
</Class>
