    <JadeMethod name="setCmbs" id="0c8fbaf5-ca2f-4ff1-88f4-31f0ead47376">
        <source>setCmbs();
// -------------------------------------------
// Created 06 October 2004 by cnwdvb1
// -------------------------------------------
//9/11/17 jlgns1 TFS 6960 QNS - Disk space issues and house keeping inside JMT
vars

begin
	
	self.myAssistant.comboBoxTerminal(self.cmbTerminals, null, null);
	if self.cmbTerminals.listCount &gt; 0 then
		self.cmbTerminals.listIndex := 1;
		self.tblDatabasePurge.setValueByName(ETRow_Terminal, self.cmbTerminals.text);
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="setColorsFromController" id="4982d549-564d-40d4-8e64-780c912daa4f">
        <updating/>
        <source>setColorsFromController(_colorControl: CM_ColorController) updating;
// ---------------------------------------------------------------------------
// Created:     30 July 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

	colorControl	: CM_ColorController;

begin

	create colorControl transient;
	inheritMethod(colorControl);

	self.setColorsForEntryTable(self.tblDatabasePurge);
	self.setColorsForTable(self.tblActivity);
	self.setColorsForTable(self.tblBGP);
	self.fldPurge.backColor 		:= colorControl.formBackColor;
	self.sptActivity.backColor 		:= colorControl.formBackColor;

epilog
	delete colorControl;
end;</source>
        <Parameter name="_colorControl" type="CM_ColorController"/>
    </JadeMethod>
    <JadeMethod name="setSortColumnsForFirstTime" id="41873a0d-1cfe-4ca1-b90c-9a7a1c15f626">
        <source>setSortColumnsForFirstTime() protected;
/* ---------------------------------------------------------------------------
Created:	18 March 2009	by cnwvu1

Purpose:	Par 18316 Mar 2009
   
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars

begin

	if app.getUserWindow(self.name, false) = null then	// the first start for a new user
		// Sorting by Terminal and Activity DateTime.
		self.tblActivity.zAddSortColumn(ETRow_Terminal, false);
		self.tblActivity.zAddSortColumn(ETRow_ActivityDateTime, false);
	endif;

end;</source>
        <access>protected</access>
    </JadeMethod>
