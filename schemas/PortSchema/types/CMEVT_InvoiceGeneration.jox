    <JadeMethod name="printInvoiceGeneration" id="8f108284-9a87-4a67-ab95-ddf73f9065fe">
        <source>printInvoiceGeneration();
/* ---------------------------------------------------------------------------
Created:	10 November 2008	by cnwvu1

Purpose:	ccms jmt 1772. Printing Invoice Generation details
   
Change Date		Who		Reason

------------------------------------------------------------------------------*/
constants
	DebtorMaxLength : Integer = 30;

vars
	tmpPrnTable		: CM_GenericTablePrint;
	tmpJadeReport	: JadeReport;
	tmpColorControl	: CM_ColorController;
	colour1, colour2,
	colourHeading	: Integer;
	tmpSheet		: JadeTableSheet;
	invoicesUpdated	: CM_InvoiceSet;
	invoicesNumber	: Integer;
	inv				: CM_Invoice;
	totalInvLine	: Integer;
	totalAmount,
	invAmount		: Decimal[12,2];
	theRow			: JadeTableRow;
	theColumn		: JadeTableColumn;
	i				: Integer;
	debtorName		: String;
	
begin

	app.mousePointer := MP_HOURGLASS;

	app.printer.printPreview := false;
	app.printer.suppressDialog := true;
	app.printer.setMargins(Print_Portrait,0,0,10,10);
	//app.printer.setMargins(Print_Landscape,0,0,10,10);
	
	create tmpPrnTable transient;
	tmpPrnTable.whiteBackground := true;
	
	create tmpJadeReport transient;
	tmpJadeReport.description := "Invoice Generation";
	app.printer.setReport(tmpJadeReport);

	// setup the report header
	tmpPrnTable.frHeader.width := app.printer.pageWidth;
	tmpPrnTable.lblHeader1.visible := true;
	tmpPrnTable.lblHeader2.visible := true;
	tmpPrnTable.setHeaders(	app.getErrorString(Invoice_generation) &amp; ": " &amp; self.dateFrom.asStringJMT() &amp; " - " &amp; self.dateFrom.asStringJMT(),
							app.getErrorString(Invoice_type) &amp; ": " &amp; self.myInvoiceType.description);
	tmpPrnTable.lblHeader1.centreHorizontallyInParent();
	app.printer.setHeader(tmpPrnTable.frHeader);

	// setup the report footer
	tmpPrnTable.frFooter.width := app.printer.pageWidth;
	tmpPrnTable.lblTheDatePrinted.caption := self.systemToLocalTime(app.actualTimeServer).String;	// 10/6/16 cnwmp6 TFS 488 - Multi timezone support
	tmpPrnTable.lblTheUser.caption := app.getMyUserCode();
	tmpPrnTable.useOrigTableColumnWidths := true;
	app.printer.setFooter(tmpPrnTable.frFooter);

	invoicesUpdated := self.getInvoicesUpdated();
	if invoicesUpdated = null then
		invoicesNumber := 0;
	else
		invoicesNumber := invoicesUpdated.size;
	endif;
	
	// -----------------------------------------------------------------------
	// 							 CREATING DATA
	// -----------------------------------------------------------------------
	tmpPrnTable.table.rows := 0;

	if invoicesNumber = 0 then
		tmpPrnTable.table.columns := 1;
		tmpPrnTable.addRowToTable( app.getErrorString(INFO_ThereAreNoInvoicesUpdated) );
	
	else
	
		tmpPrnTable.table.columns := 7;
		tmpPrnTable.addRowToTable(	app.getErrorString(CM_Number) &amp;  Tab &amp; 
									app.getErrorString(CM_Status) &amp;  Tab &amp; 
									app.getErrorString(INV_Debtor) &amp; Tab &amp; 
									app.getErrorString(Invoice_lines) &amp; Tab &amp; 
									app.getErrorString(Total_value) &amp; Tab &amp; 
									app.getErrorString(Start_date) &amp; Tab &amp;
									app.getErrorString(EndDate) );
		totalInvLine:= 0;
		totalAmount	:= 0.0;

		foreach inv in invoicesUpdated do
			totalInvLine:= totalInvLine + inv.invoiceLines.size;
			tmpPrnTable.addRowToTable( inv.getStringForPrintInvGeneration(invAmount, DebtorMaxLength));
			totalAmount := totalAmount + invAmount;
		endforeach;
		// total section
		tmpPrnTable.addRowToTable(null);
		tmpPrnTable.addRowToTable(app.getErrorString(Total) &amp; Tab &amp; Tab &amp; Tab &amp; totalInvLine.asStringJMT() &amp; Tab &amp; totalAmount.asStringJMT() &amp; Tab);
		tmpPrnTable.addRowToTable(" " &amp; Tab &amp; Tab &amp; invoicesNumber.asStringJMT() );

	endif;

	// -----------------------------------------------------------------------
	//							ALIGNMENT
	// -----------------------------------------------------------------------
	if invoicesNumber &gt; 0 then
		//tmpPrnTable.table.setMargins();
		tmpSheet := tmpPrnTable.table.accessSheet(1);
		tmpSheet.marginLeft := 2;
		tmpSheet.marginRight := 2;
		tmpSheet.marginTop := 1;
		foreach i in 1 to tmpPrnTable.table.columns do
			theColumn	:=	tmpPrnTable.table.accessColumn( i );
			theColumn.width := theColumn.width + 4;	// to have column wider, because of margins
		endforeach;
		// alignment - numbers to the right
		theColumn := tmpPrnTable.table.accessColumn(4);
		theColumn.alignment := Table.Alignment_Right_Middle;
		theColumn := tmpPrnTable.table.accessColumn(5);
		theColumn.alignment := Table.Alignment_Right_Middle;
		//Merge the second row in total
		tmpSheet.accessCell(tmpPrnTable.table.rows,1).mergeCells:= Table.MergeCells_Available;
		tmpSheet.accessCell(tmpPrnTable.table.rows,3).mergeCells:= Table.MergeCells_NotAvailable;
		tmpSheet.accessCell(tmpPrnTable.table.rows,1).mergeCells:= Table.MergeCells_MergeSelectable;
		tmpSheet.accessCell( tmpPrnTable.table.rows,1).text 	:= app.getErrorString(Number_of_invoices);
		tmpSheet.accessCell( tmpPrnTable.table.rows,3).alignment:= Table.Alignment_Right_Middle;

	endif;
	
	// -----------------------------------------------------------------------
	//							CREATING COLOURS
	// -----------------------------------------------------------------------
	if invoicesNumber &gt; 0 then
		create tmpColorControl transient;
		colour1			:= tmpColorControl.rowColor1;
		colour2			:= tmpColorControl.rowColor2;
		colourHeading	:= LightGray;
		theRow := tmpPrnTable.table.accessRow(1);
		theRow.backColor := colourHeading;
		//theRow.fontBold := true;
		foreach i in 2 to tmpPrnTable.table.rows - 2 do
			theRow	:=	tmpPrnTable.table.accessRow( i );
			if i.isEven() then
				theRow.backColor := colour1;
			else
				theRow.backColor := colour2;
			endif;
			
		endforeach;
		//Total section
		theRow	:=	tmpPrnTable.table.accessRow( i );
		theRow.backColor := colourHeading;
		theRow	:=	tmpPrnTable.table.accessRow( i + 1 );
		theRow.backColor := colourHeading;
		// adding null row at the end to have bold line
		tmpPrnTable.addRowToTable(null);
		theRow	:=	tmpPrnTable.table.accessRow( i + 2 );
		theRow.height := 3;
	endif;
	
	// printing
	tmpPrnTable.printTable(null, true, null);
	app.printer.close();
	app.printPreview(tmpJadeReport, true);
	
	
epilog
	app.printer.close;
	delete tmpPrnTable;
	delete tmpColorControl;
	
//	delete tmpJadeReport;
	app.mousePointer := MP_DEFAULT;


end;</source>
    </JadeMethod>
    <JadeMethod name="set" id="a37f4470-7fcb-4e63-b6c2-19fcb1f05410">
        <updating/>
        <source>set( _myInvoiceType : CM_InvoiceDesc; _dateFrom, _dateTo : Date; _statusToBeSetTo : Integer;
		_invoiceUpdatedSet : CM_InvoiceSet  ) updating;
/* ---------------------------------------------------------------------------
Created:	17 September 2008	by cnwvu1

Purpose:	
   
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars

begin

	self.myInvoiceType := _myInvoiceType;
	self.dateFrom := _dateFrom;
	self.dateTo := _dateTo;
	self.statusToBeSetTo := _statusToBeSetTo;

	self.setInvoicesUpdated(_invoiceUpdatedSet);
	
end;</source>
        <Parameter name="_myInvoiceType" type="CM_InvoiceDesc"/>
        <Parameter name="_dateFrom" type="Date"/>
        <Parameter name="_dateTo" type="Date"/>
        <Parameter name="_statusToBeSetTo" type="Integer"/>
        <Parameter name="_invoiceUpdatedSet" type="CM_InvoiceSet"/>
    </JadeMethod>
    <JadeMethod name="setDetailsFromCMIF" id="9e745bb1-819d-442d-ad4a-7bcb23a970af">
        <updating/>
        <source>setDetailsFromCMIF(_eventType: CM_EventType; _cmifEventTrx: CMIF_InvoiceGenerationCtrl) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
//17/02/2025	navkc1 JIRA Bug MTN-33582: MTN | Event Charging Refactor

*/

vars

begin

	self.set(_cmifEventTrx.myInvoiceType, _cmifEventTrx.dateFrom, _cmifEventTrx.dateTo, _cmifEventTrx.statusToBeSetTo, _cmifEventTrx.allInvoicesUpdated);
	
	
	// Keep this at the bottom so it calculate the charges after all details are entered
	inheritMethod(_eventType, _cmifEventTrx);

epilog

end;</source>
        <Parameter name="_eventType" type="CM_EventType"/>
        <Parameter name="_cmifEventTrx" type="CMIF_InvoiceGenerationCtrl"/>
    </JadeMethod>
    <JadeMethod name="setInvoicesUpdated" id="13330aad-40e3-4649-adba-4cae897c0c7d">
        <source>setInvoicesUpdated(_invoiceSet : CM_InvoiceSet);
/* ---------------------------------------------------------------------------
Created:     31 October 2008 by cnwrs2

Purpose:     
        
Change Date	Who		Reason

------------------------------------------------------------------------------*/
vars
	//tmpInvSet		: CM_InvoiceSet;
	
begin

	self.allInvoicesUpdated.clear;
	
	if _invoiceSet &lt;&gt; null then
		_invoiceSet.copy(self.allInvoicesUpdated);
	endif;

epilog

end;</source>
        <Parameter name="_invoiceSet" type="CM_InvoiceSet"/>
    </JadeMethod>
</Class>
