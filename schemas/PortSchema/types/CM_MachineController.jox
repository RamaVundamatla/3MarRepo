    <JadeMethod name="getQueueTasks" id="47e6c152-3f88-4876-9c04-7c43f1b89fbf">
        <source>getQueueTasks(arbiter: CM_RTQueueArbiter io; _isSource : Boolean);
/*

Purpose:			


Return Value:		


Date		Who		Reason
15 November 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars
	isPickup : Boolean;
	isTurnaround : Boolean;
	pickupTask,
	setdownTask	: CM_RTQueueTask;
	taskType	: Integer;
begin
	if arbiter.sourceLocation = self and arbiter.targetLocation = self then
		isTurnaround:=true;
		isPickup:=arbiter.entry.getTaskOfType(TASK_PICKUP,null) = null;
			
	else
		if arbiter.ti.getPrimaryLocation(REAL_MODE) = self then
			isPickup := true;			//we must be the source locn
		endif;
	endif;

	if isPickup then
		taskType:=TASK_PICKUP;	
	else
		taskType:=TASK_SETDOWN;
	endif;

	create pickupTask;
	pickupTask.setDetails(self,self,TASK_UNACTIONED,taskType,arbiter.ti);
	arbiter.entry.addTask(pickupTask);
epilog

end;</source>
        <Parameter name="arbiter" type="CM_RTQueueArbiter" usage="io"/>
        <Parameter name="_isSource" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getQueues" id="1c8cdcfc-04b5-41ad-9be6-e4f61d405d92">
