vars

begin

	app.mousePointer := Window.MousePointer_HourGlass;
	self.scrollTo(self.myHScroll.max, self.myVScroll.max);
	
epilog 
	app.mousePointer := Window.MousePointer_Default;

end;</source>
    </JadeMethod>
    <JadeMethod name="scrollControl" id="2de9b653-cfff-449d-8b6b-3a82b887bf5f">
        <source>scrollControl(pDirection : Integer; pValue : Integer);
// ---------------------------------------------------------------------------
// Created:     29 January 2002 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpValue	: Integer;

begin
	if pDirection = ScrollBar_Horizontal then
		if self.myVLabels.visible then
			tmpValue := self.myVLabels.width.Integer;
		endif;
		tmpValue := tmpValue - pValue;
		if self.myScrollingFrame &lt;&gt; null then
			self.myScrollingFrame.left := tmpValue;
		endif;
		if self.myHLabels &lt;&gt; null then
			self.myHLabels.left := tmpValue;
		endif;
	else
		if self.myHLabels.visible and (not self.hLabelsAlignBottom) then
			tmpValue := self.myHLabels.height.Integer;
		endif;
		tmpValue := tmpValue - pValue;
		if self.myScrollingFrame &lt;&gt; null then
			self.myScrollingFrame.top := tmpValue;
		endif;
		if self.myVLabels &lt;&gt; null then
			self.myVLabels.top := tmpValue;
		endif;
	endif;
	
	if self.scrolledCallbackMethod &lt;&gt; null and
	   self.form &lt;&gt; null then
	   	self.form.sendMsg(self.scrolledCallbackMethod);
	endif;

	
end;</source>
        <Parameter name="pDirection" type="Integer"/>
        <Parameter name="pValue" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="scrollResetScrollValues" id="2675e97e-c5e5-4279-81a9-07a8bc59521b">
        <source>scrollResetScrollValues();
// ---------------------------------------------------------------------------
// Created:		May 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	self.scrollTo(self.myHScroll.value, self.myVScroll.value);
end;</source>
    </JadeMethod>
    <JadeMethod name="scrollTo" id="2ee1f71b-4265-452d-a9b4-2b514684cf67">
        <source>scrollTo(_x, _y : Integer);
// ---------------------------------------------------------------------------
// Created:     08 March 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin

	self.myHScroll.value := _x;
	self.myVScroll.value := _y;
	self.repositionScrollBars();

	if self.scrolledCallbackMethod &lt;&gt; null and
	   self.form &lt;&gt; null then
	   	self.form.sendMsg(self.scrolledCallbackMethod);
	endif;

end;</source>
        <Parameter name="_x" type="Integer"/>
        <Parameter name="_y" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="scrollToFromPercentage" id="325b7b08-bc4a-40e3-a3d1-8b08d87d62bb">
        <source>scrollToFromPercentage(_x, _y : Real);
// ---------------------------------------------------------------------------
// Created:     14 May 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	hScroll	: CMUI_ScrollableHScroll;
	vScroll	: CMUI_ScrollableVScroll;

begin

	hScroll := self.myHScroll;
	vScroll	:= self.myVScroll;
	
	if hScroll = null or vScroll = null then
		return;
	endif;
	
	self.scrollTo((hScroll.max * _x / 100).rounded,
				  (vScroll.max * _y / 100).rounded);
	
end;</source>
        <Parameter name="_x" type="Real"/>
        <Parameter name="_y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="scrollTopLeft" id="bf6a4b7f-81cd-46dd-9cbe-c2cf15df0df9">
