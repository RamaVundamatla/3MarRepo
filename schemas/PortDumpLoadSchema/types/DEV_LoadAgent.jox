    <JadeMethod name="loadDelay" id="5bb6c0f4-fed8-4455-8845-3a5f214eef59">
        <source>loadDelay(_delayProxy:HMS_Delay io) :Boolean protected;

vars
	realObject: HMS_Object;
	proxyObject: HMS_Delay;
	error: CM_Error;
	countError,countOK: Integer;
begin
	realObject := app.myRoot.allHMSDelays[_delayProxy.code];
	if realObject = null then
		app.myTrxCA.trxCreateHMSObject(_delayProxy, realObject, app.myPassport);
	else
		app.writeLog(class.name&amp;'::'&amp;method.name&amp;' '&amp;_delayProxy.code&amp;" ERROR: "&amp;"Delay already exists.",0);
		return false;
	endif;
	if app.myPassport.trxCompletedOK and
	   app.myPassport.allErrorWarnings.size = 0 then
		return true;
	else
		foreach error in app.myPassport.allWarnings do
			app.writeLog(class.name&amp;'::'&amp;method.name&amp;' '&amp;_delayProxy.code&amp;" WARNING: "&amp;error.text,0);
		endforeach;
		foreach error in app.myPassport.allErrors do
			app.writeLog(class.name&amp;'::'&amp;method.name&amp;' '&amp;_delayProxy.code&amp;" ERROR: "&amp;error.text,0);
		endforeach;
		return false;
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_delayProxy" type="HMS_Delay" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="loadDepot" id="73a04f42-8aba-4081-88ac-9b2c6b3cc4c1">
        <source>loadDepot(_proxyObject:CM_Object io):Boolean protected;

vars
	 proxyObject: CM_TerminalArea;
	error: CM_Error;
	theUser: CM_User;
	result: Boolean;
	yaDeckingOptions: CM_YADeckingOptionsTA;
	controller : CMIF_TerminalArea;
		realObject : CM_TerminalAreaMaster;
begin
	create controller transient;


	result := false;
	proxyObject := _proxyObject.CM_TerminalArea;
	create yaDeckingOptions transient;
	yaDeckingOptions.setProxy(false, true, proxyObject);
	yaDeckingOptions.setProxyRules(DeckingRule_Default, DeckingRule_Default);
	controller.myPxyTerminalAreaMaster := proxyObject;
	app.myTrxCA.trxCreateTerminalArea(proxyObject, realObject,  app.myPassport);
	
	if app.myPassport.trxCompletedOK and
	   app.myPassport.allErrorWarnings.size = 0 then
//		write class.name&amp;'::'&amp;method.name&amp;' '&amp;proxyObject.id&amp;" OK";
