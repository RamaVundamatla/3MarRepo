    <JadeMethod name="hmsTransactionSearch" id="fe7af86c-7cdd-474a-9152-6ba561c5d07b">
        <updating/>
        <source>hmsTransactionSearch() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
   Jan 2012	cnwjre1	CCMS 1262  transaction enquiry and selector queries, cargo transactions
12 Dec 2019 cnwma1	Bug 47966: STWO - Transaction Enquiry ignores midnight 'Time To'
14/07/2025	naviv1	MTN-35226	MTN - Usage of Iterator.getCurrentKeys  	
*/
vars
	type			: Integer;
	iter			: Iterator;
	transObj		: HMS_Transaction;
	vtmisTrans		: HMS_VTMISTransaction;
	typeDateDict	: HMS_TransactionByTypeDateDict;
	keyTimeStamp	: TimeStamp;
	startTimeStamp	: TimeStamp;
	endTimeStamp	: TimeStamp;
	keyType			: Integer;
	atLimit			: Boolean;
	breakOut		: Boolean;
	passport		: CM_Passport;
	user			: CM_User;
	
begin
	passport := app.myPassport;
	user := app.getMyUser();

	startTimeStamp.setDate(self.filterDateFrom);
	startTimeStamp.setTime(self.filterTimeFrom);
	
	endTimeStamp.setDate(self.filterDateTo);
	endTimeStamp.setTime(self.filterTimeTo);
	
	type 		 := self.filterTransactionType.trxType;
	typeDateDict := self.myTerminal.allHMSTransactionsByTypeDate;
	iter 		 :=	typeDateDict.createIterator();
	typeDateDict.startKeyGeq(type, startTimeStamp, iter);
	
	while iter.next(transObj) do
		iter.getCurrentKeys(keyType, keyTimeStamp);  //MTN-35226
	
		if type &lt;&gt; keyType then
			break;
		endif;
			
		if endTimeStamp.isValid  and keyTimeStamp &gt; endTimeStamp then
			break;
		endif;
			
		if not transObj.isKindOf(HMS_VTMISTransaction) then
			continue;
		endif;

		vtmisTrans := transObj.HMS_VTMISTransaction;
	
		if self.includesHMSObject(vtmisTrans, breakOut, passport) then
			atLimit := self.addObjectToCollection(vtmisTrans, user);
		endif;
		
		if atLimit or  breakOut then
			break;
		endif;
	endwhile;
	self.searchCancelled := breakOut;

epilog
	delete iter;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="includesEventObject" id="a043f686-4205-4598-bc7c-e56322625af0">
        <updating/>
        <source>includesEventObject(_trans: CM_EventTransaction; _breakOut : Boolean output; _passport : CM_Passport): Boolean protected, updating;
//  CCMS 1262 Jan 2012 transaction enquiry and selector queries
// 	date and event type filtering has already been done in the iterator processing
constants
	TimeBetweenUpdates		= 2000;
	
vars
	failedDAC		: CM_DataAccessController;
	invoiceLine		: CM_InvoiceLine;
	found			: Boolean;
	invalidTrans	: Boolean;
	now				: Decimal[20];
	
begin
	on Exception do app.handleDeletedObject(exception, _trans, invalidTrans);
	
	now := app.relativeMachineTime();
	if (now - self.lastQueryTime) &gt; TimeBetweenUpdates then
		self.lastQueryTime:= now;
		self.checkSearchReturnOption(self.numItemsShown);
		if self.modalDialogReturnValue &lt;&gt; ModalDialogReturn_Null then
			_breakOut := true;
		endif;
	endif;
	self.numItemsSearched := self.numItemsSearched + 1;

	if self.filterVoyage &lt;&gt; null then
		if _trans.getMyVoyage() &lt;&gt; self.filterVoyage then
			return false;
		endif;
	endif;
	
	if self.filterUser &lt;&gt; null then
		if _trans.userCode &lt;&gt; self.filterUser.code then
			return false;
		endif;
	endif;

	//if self.filterBusinessUnit &lt;&gt; null then
	//	if _trans.companyCode &lt;&gt; self.filterBusinessUnit.code then
	//		return false;
	//	endif;
	//endif;	
	
	if self.filterDebtor &lt;&gt; null then
		if not _trans.myDebtor = self.filterDebtor then
			return false;
		endif;
	endif;
	
	if self.filterInvoiceNumber &gt; 0 then
		found := false;
		foreach invoiceLine in _trans.allInvoiceLines do
			if invoiceLine.invoice.sequenceNum = self.filterInvoiceNumber then
				found := true;
				break;
			endif;
		endforeach;
		return found;
	endif;
	
	if self.filterCharged &gt; 0 then
		if _trans.isCharged() and self.filterCharged = Not_Charged then
			return false;
		elseif not _trans.isCharged() and self.filterCharged = Is_Charged then
			return false;
		endif;
	endif;
	
	if (not _trans.canUserAccessSelf(null, failedDAC, _passport)) then
		return false;
	endif;
	
	if invalidTrans then
		return false;
	endif;
	
	return true;
end;</source>
        <access>protected</access>
        <Parameter name="_trans" type="CM_EventTransaction"/>
        <Parameter name="_breakOut" type="Boolean" usage="output"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="includesHMSObject" id="710ae549-04a5-4c8e-b22a-77aae21475c3">
        <updating/>
        <source>includesHMSObject(_trans: HMS_VTMISTransaction; _breakOut : Boolean output; _passport : CM_Passport): Boolean protected, updating;
//  CCMS 1262 Jan 2012 transaction enquiry and selector queries
// 	date and transaction type filtering has already been done in the iterator processing
constants
	TimeBetweenUpdates		= 2000;
	
vars
	failedDAC		: CM_DataAccessController;
	found			: Boolean;
	invalidTrans	: Boolean;
	invoiceLine		: CM_InvoiceLine;
	now				: Decimal[20];
	
begin
	on Exception do app.handleDeletedObject(exception, _trans, invalidTrans);
	
	now := app.relativeMachineTime();
	if (now - self.lastQueryTime) &gt; TimeBetweenUpdates then
		self.lastQueryTime:= now;
		self.checkSearchReturnOption(self.numItemsShown);
		if self.modalDialogReturnValue &lt;&gt; ModalDialogReturn_Null then
			_breakOut := true;
		endif;
	endif;
	self.numItemsSearched := self.numItemsSearched + 1;

	if self.filterVoyage &lt;&gt; null then
		if _trans.getVoyage() &lt;&gt; self.filterVoyage then
			return false;
		endif;
	endif;
	
	if self.filterUser &lt;&gt; null then
		if _trans.userCode &lt;&gt; self.filterUser.code then
			return false;
		endif;
	endif;

	//if self.filterBusinessUnit &lt;&gt; null then
	//	if _trans.companyCode &lt;&gt; self.filterBusinessUnit.code then
	//		return false;
	//	endif;
	//endif;	
	
	if self.filterDebtor &lt;&gt; null then
		if not _trans.myDebtor = self.filterDebtor then
			return false;
		endif;
	endif;
	
	if self.filterInvoiceNumber &gt; 0 then
		found := false;
		foreach invoiceLine in _trans.allInvoiceLines do
			if invoiceLine.invoice.sequenceNum = self.filterInvoiceNumber then
				found := true;
				break;
			endif;
		endforeach;
		return found;
	endif;
	
	if self.filterCharged &gt; 0 then
		if _trans.isCharged() and self.filterCharged = Not_Charged then
			return false;
		elseif not _trans.isCharged() and self.filterCharged = Is_Charged then
			return false;
		endif;
	endif;
	
	if (not _trans.canUserAccessSelf(null, failedDAC, _passport)) then
		return false;
	endif;
	
	if invalidTrans then
		return false;
	endif;
	
	return true;
end;</source>
        <access>protected</access>
        <Parameter name="_trans" type="HMS_VTMISTransaction"/>
        <Parameter name="_breakOut" type="Boolean" usage="output"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="includesTransObject" id="8936620d-74d3-4b57-8f40-1bb924213e29">
        <updating/>
        <source>includesTransObject(_trans: CM_TITransaction; _breakOut : Boolean output; _passport : CM_Passport): Boolean protected, updating;
//  CCMS 1262 Jan 2012 transaction enquiry and selector queries
// 	date and transaction type filtering has already been done in the iterator processing
//21/04/2016 cnwma1 PAR #37681  QNS - locking issue
constants
	TimeBetweenUpdates		= 2000;
	
vars
	failedDAC		: CM_DataAccessController;
	found			: Boolean;
	invalidTrans	: Boolean;
	invoiceLine		: CM_InvoiceLine;
	now				: Decimal[20];
	
begin
	on Exception do app.handleDeletedObject(exception, _trans, invalidTrans);
	
	now := app.relativeMachineTime();
	if (now - self.lastQueryTime) &gt; TimeBetweenUpdates then
		self.lastQueryTime:= now;
		self.checkSearchReturnOption(self.numItemsShown);
		if self.modalDialogReturnValue &lt;&gt; ModalDialogReturn_Null then
			_breakOut := true;
		endif;
	endif;
	self.numItemsSearched := self.numItemsSearched + 1;

	if self.filterVoyage &lt;&gt; null then
		if _trans.getVoyage() &lt;&gt; self.filterVoyage then
			return false;
		endif;
	endif;
	
	if self.filterUser &lt;&gt; null then
		if _trans.userId &lt;&gt; self.filterUser.code then
			return false;
		endif;
	endif;

	if self.filterBusinessUnit &lt;&gt; null then
		if _trans.companyCode &lt;&gt; self.filterBusinessUnit.code then
			return false;
		endif;
	endif;	
	
	if self.filterDebtor &lt;&gt; null then
	//	if not _trans.allDebtorsByType.includes(self.filterDebtor) then
	//		return false;
	//	endif;
		//23 Oct 2015	NDL	Par 36694
		if _trans.getDebtorForSearch &lt;&gt; self.filterDebtor then
			return false;
		endif;
	endif;
	
	if self.filterInvoiceNumber &gt; 0 then
		found := false;
		//foreach invoiceLine in _trans.allInvoiceLines do
		foreach invoiceLine in _trans.allInvoiceLines discreteLock do    //21/04/2016 cnwma1 PAR #37681 
			if invoiceLine.invoice.sequenceNum = self.filterInvoiceNumber then
				found := true;
				break;
			endif;
		endforeach;
		return found;
	endif;
	
	if self.filterCharged &gt; 0 then
		if _trans.isCharged() and self.filterCharged = Not_Charged then
			return false;
		elseif not _trans.isCharged() and self.filterCharged = Is_Charged then
			return false;
		endif;
	endif;
	
	if (not _trans.canUserAccessSelf(null, failedDAC, _passport)) then
		return false;
	endif;
	
	if invalidTrans then
		return false;
	endif;
	
	return true;
end;</source>
        <access>protected</access>
        <Parameter name="_trans" type="CM_TITransaction"/>
        <Parameter name="_breakOut" type="Boolean" usage="output"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="includesWOObject" id="7a55f9bd-d9ef-46ac-aaed-544657a03cd6">
        <updating/>
        <source>includesWOObject(_trans: CM_WOTransaction; _breakOut : Boolean output; _passport : CM_Passport): Boolean protected, updating;
/*
Purpose:	TFS 39237		
Date				Who			Reason
JUNE 2018		CNWAB1		Initial creation
*/

constants
	TimeBetweenUpdates		= 2000;
	
vars
	failedDAC		: CM_DataAccessController;
	invoiceLine		: CM_InvoiceLine;
	found			: Boolean;
	invalidTrans	: Boolean;
	now				: Decimal[20];
	
begin
	on Exception do app.handleDeletedObject(exception, _trans, invalidTrans);
	
	now := app.relativeMachineTime();
	if (now - self.lastQueryTime) &gt; TimeBetweenUpdates then
		self.lastQueryTime:= now;
		self.checkSearchReturnOption(self.numItemsShown);
		if self.modalDialogReturnValue &lt;&gt; ModalDialogReturn_Null then
			_breakOut := true;
		endif;
	endif;
	self.numItemsSearched := self.numItemsSearched + 1;

	if self.filterVoyage &lt;&gt; null then
		if _trans.getMyVoyageObject() &lt;&gt; self.filterVoyage then
			return false;
		endif;
	endif;
	
	if self.filterUser &lt;&gt; null then
		if _trans.getMyUserCode() &lt;&gt; self.filterUser.code then
			return false;
		endif;
	endif;

	if self.filterBusinessUnit &lt;&gt; null then
		if _trans.getMyBank() &lt;&gt; self.filterBusinessUnit then
			return false;
		endif;
	endif;
	
	if self.filterDebtor &lt;&gt; null then
		if not _trans.getMyDebtor() = self.filterDebtor then
			return false;
		endif;
	endif;
	
	if self.filterInvoiceNumber &gt; 0 then
		found := false;
		foreach invoiceLine in _trans.allInvoiceLines do
			if invoiceLine.invoice.sequenceNum = self.filterInvoiceNumber then
				found := true;
				break;
			endif;
		endforeach;
		return found;
	endif;
	
	if self.filterCharged &gt; 0 then
		if _trans.isCharged() and self.filterCharged = Not_Charged then
			return false;
		elseif not _trans.isCharged() and self.filterCharged = Is_Charged then
			return false;
		endif;
	endif;
	
	if (not _trans.canUserAccessSelf(null, failedDAC, _passport)) then
		return false;
	endif;
	
	if invalidTrans then
		return false;
	endif;
	
	return true;
end;</source>
        <access>protected</access>
        <Parameter name="_trans" type="CM_WOTransaction"/>
        <Parameter name="_breakOut" type="Boolean" usage="output"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
