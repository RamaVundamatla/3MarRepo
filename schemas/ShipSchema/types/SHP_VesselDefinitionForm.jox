        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblPrefBerth_dragDrop(table: Table input; win: Window input; x: Real; y: Real) updating;
//--------------------------------------------------
// Created:	23 September 2005 By: cnwgd1
//--------------------------------------------------
vars

begin
	if self.tblPrefBerth.dragRow &lt;&gt; self.lastValidRow then
		// Row has changed - move row to new position
		if self.tblPrefBerth.dragRow &gt; 1 then
			self.tblPrefBerth.moveRow(self.lastValidRow, self.tblPrefBerth.dragRow);
			self.lastValidRow := self.tblPrefBerth.dragRow;
		endif;
	endif;
end;</source>
