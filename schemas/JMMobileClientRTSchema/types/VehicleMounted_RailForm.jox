vars

begin
	self.setMode();
	self.setupTable();
	inheritMethod(userInfo);


epilog

end;</source>
        <Parameter name="userInfo" type="String"/>
    </JadeMethod>
    <JadeMethod name="doFind" id="14d41666-c27c-41d7-b941-680e14ed299d">
        <updating/>
        <source>doFind() updating, protected;

/*

Purpose:			


Return Value:		


Date			Who		Reason
16 June 2008	concms1	PAR 17123 (CCMS GCT Gdansk 1671) - RDT Screen to relocate container
*/

vars
	tiId,
	errorStr		: String;
	state			: Integer;	
begin
	self.clearErrors;
	
	// clear values from any previous search
	self.clearMoveDetails;
	
	tiId := self.txtContainer.text.trimRight();
	
	if app.myVehicleMountedRailGuiAgent.findTrackedItem(self, tiId, self.allErrorMsgs, state) then
		// details will be loaded using loadFormFromThinClientObj
	else
		if not self.checkErrors_msgBox then
			// no errors  so multiple containers must have been found
			app.msgBox('Please enter a valid container ID','Errors occurred', MsgBox_Exclamation_Mark_Icon);
		endif;
		txtContainer.setFocus;
	endif;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doKeyDown" id="8d4e1746-5642-4635-859f-80090c07f419">
        <updating/>
        <source>doKeyDown(keyCode: Integer io; shift: Integer) updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
14 September 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars

begin
	inheritMethod(keyCode, shift);
	
	if keyCode = J_key_F2 then
		self.btnAccept.click(self.btnAccept);
	elseif keyCode = J_key_F6 then
		self.isPrimaryQueue:=false;
		self.setupChangeQueue();
	elseif keyCode = J_key_F7 then
		self.btnJobOrder.click(self.btnJobOrder);
	endif;
	
epilog

end;</source>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doMove" id="ee5997c6-9117-4d0d-a46b-a4093290e895">
        <updating/>
        <source>doMove() protected, updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
15 September 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars
	_type,
	_containerId,
	_fromLoc,
	_toLoc: String;
	_ostow,
	_canEdit,
	_toIsVehicle: Boolean;
	errorMsg : MobileHandHeldThin::DTO_HandHeldGateError;
	theTable 	: Table;
begin
	app.mousePointer	:=	Busy;
	theTable 	:=tblJobs;
	self.clearErrors;
	if app.myVehicleMountedRailGuiAgent.hasCurrentOverstowTI then
		//move that overstow object ;
		app.myVehicleMountedRailGuiAgent.doMoveCurrentOversowTI(currentContainerId,txtRow.text,allErrorMsgs);
		
		if self.checkErrors() then
			return;
		endif;
		
		app.myVehicleMountedRailGuiAgent.getMoveDetails(_type,_containerId,_fromLoc,_toLoc,_ostow,_canEdit,_toIsVehicle,allErrorMsgs);
		if self.checkErrors then
			app.myVehicleMountedRailGuiAgent.doCancelTask( null,allErrorMsgs);
			return;
		endif;
		self.setupMsgFrameNew(_type,_containerId,_fromLoc,_toLoc,_ostow,_canEdit,_toIsVehicle);
		return;
	else
		//easy move the current rt task ti to value in the txt field
		if txtRow.visible then
			app.myVehicleMountedRailGuiAgent.doMoveCurrentTaskTI(currentContainerId,txtRow.text,allErrorMsgs);
		else
			app.myVehicleMountedRailGuiAgent.doMoveCurrentTaskTI(currentContainerId,toLocationId,allErrorMsgs);
		endif;	
		
		if self.checkErrors() then
			return;
		endif;
	endif;
	self.frmAccept.visible := false;
	self.changeDefaultButtons(btnMsgOK,btnAccept);
	self.changeCancelButtons(btnMsgCancel,btnLogoff);
	
	theTable.selectMode:=Table.SelectMode_WholeRows;
epilog
	app.mousePointer	:=	Idle;	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doMoveTI" id="89e012bc-d3b9-4905-b5e8-d318ca97b68d">
        <updating/>
        <source>doMoveTI()updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date			Who		Reason
16 June 2008	concms1	PAR 17123 (CCMS 1671) DCT GDansk RDT Screen to relocate containers

*/

vars

begin
	self.clearErrors;
	
	if self.currentContainerId_forMove = null or self.currentContainerId_forMove &lt;&gt; txtContainer.text.trimRight then
		app.msgBox('You must find a container before attempting to move it','Errors occurred', MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	
	app.myVehicleMountedRailGuiAgent.moveTI(self, txtMoveTo.text, self.currentContainerId_forMove, self.allErrorMsgs);
		
	if self.checkErrors_msgBox() then
		return;
	endif;
	
	self.clearMoveDetails;
epilog
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doSetDownOnGround" id="6aa8bde6-2cc7-4cf5-b7ed-b3f3f4a691b6">
        <updating/>
        <source>doSetDownOnGround() updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
11 December 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars

begin
	app.myVehicleMountedRailGuiAgent.doSetCurrentTaskToGround(self.allErrorMsgs);
	
	if not self.checkErrors then
		self.doCancelTask();
	endif;
epilog

end;</source>
    </JadeMethod>
