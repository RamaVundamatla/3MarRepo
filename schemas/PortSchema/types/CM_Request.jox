    <JadeMethod name="splitWLEs" id="e9be3b20-b456-4d1a-8477-d49bffef210c">
        <updating/>
        <source>splitWLEs(_newJob : CM_VoyageJob ) protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 August 2011	cnwer1	Initial creation CCMS MES 1033 - refactored into own method from splitUnactionedWLEs

*/

vars
	newJob, oldJob : CM_VoyageJob;
	voyage : CM_Voyage;
	tmpVoyCode : String;
	iter : Iterator;
	ti			: CM_TrackedItem;
	wle 		: CM_WorkListEntry;
	receiveShipTrans : CM_ReceiveShip;
	rtEntry: CM_RTQueueEntry;
begin

	newJob := _newJob;
	
	voyage:=self.getVoyage;
	if voyage &lt;&gt; null then
		tmpVoyCode := voyage.code;
	endif;
	
	// set my new job	
	self.myJob := newJob;
	// update wle and job collections
	iter := self.allWorkListEntries.createIterator;
	while iter.next(wle) do
		sharedLock(wle);
		oldJob := wle.job.CM_VoyageJob;
		wle.setJob(newJob);
		ti := wle.myTrackedItem;
		if ti &lt;&gt; null then
			if oldJob &lt;&gt; null then
				oldJob.updateTICollectionsUnassign(ti);
			endif;
			newJob.updateTICollections(ti, wle); // par 2338
			
			oldJob.setRemarks(null); // pass in null will get auto remarks
			newJob.setRemarks(null); // pass in null will get auto remarks
			
			//CCMS 1033 epr moved code from CM_VoyageJob::splitCompletedJobs update the Recieve Ship transanction
			//"KPI's are generated from the Ship Release TI transactions.  When the cargo is moved the Ship Release Transaction for this voyage will  also be updated."
			if  wle.status = WLE_COMPLETED then
				receiveShipTrans := ti.getLastTransOfType(TRANS_TYPE_REC_SHIP).CM_ReceiveShip;
				if receiveShipTrans &lt;&gt; null then
					receiveShipTrans.setJSFromJob(newJob);
				endif;
			endif;
			
			self.myTerminal.createAndCommitStringAlert(app.getErrorString1(NewJobCreated_Heading,tmpVoyCode),app.getErrorString4(NewJobCreated_Info,tmpVoyCode,ti.id,newJob.jobId,app.myPassport.userCode));
			wle.changeQueueForEntry();

			foreach rtEntry in wle.allRTQueueEntries do	// TFS3272 MAP 13/3/17
				rtEntry.sendNotesForRelatedEntry();
			endforeach;
		endif;
	endwhile;

epilog
	delete iter;

end;</source>
        <access>protected</access>
        <Parameter name="_newJob" type="CM_VoyageJob"/>
    </JadeMethod>
    <JadeMethod name="testCandidateTI" id="414cdb67-827c-478e-82d8-a64f20627c54">
        <source>testCandidateTI(ti: CM_TrackedItem;
				machine : CM_Machine;
				task : CM_RTQueueTask): Boolean;

/*

Purpose:			Test the passed in TI against the receiver to see if it matches the request

Parameters:			TI to test, machine, and task

Return Value:		True if it matches, false otherwise


Date		Who		Reason
13 Feb 2009	cnwkpd1	PAR #18743 - CCMS 1784 - Voice Directed Changes for Twin Lift
					Signature change to allow refactoring of Director methods
					Also change to handle ignored warnings
					
*/
				
vars

begin
	if ti = null then
		return false;
	endif;
	ti.testAgainstRequest(self);
	if app.myPassport.hasErrorsOrNonIgnoredWarnings() then
		return false;
	endif;
	return true;
	
end;</source>
        <Parameter name="ti" type="CM_TrackedItem"/>
        <Parameter name="machine" type="CM_Machine"/>
        <Parameter name="task" type="CM_RTQueueTask"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
