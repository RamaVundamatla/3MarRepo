    <JadeMethod name="superseded" id="a18de42e-8e36-4ec9-91f4-df820586c3dd">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <source>superseded(set: Boolean; _value: Boolean io) mapping, updating;
/*
 ------------------------------------------------------------------------
Created:			05 April 2002 by cnwdwq1
Purpose:			
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/
begin
	if set then
		if _value then
			flags := flags.bitOr(SupersededFlag);
		else
			flags := flags.getValueWithBitUnset(SupersededFlag);
		endif;
	else
		_value := (flags.bitAnd(SupersededFlag) &lt;&gt; 0);
	endif;
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Boolean" usage="io"/>
    </JadeMethod>
    <JadeMethod name="systemGenerated" id="620b6e6c-eb4d-46fe-acd8-08a639c403a9">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <source>systemGenerated(set: Boolean; _value: Boolean io) updating, mapping;
begin
	if set then
		if _value then
			flags := flags.bitOr(SystemGeneratedFlag);
		else
			flags := flags.getValueWithBitUnset(SystemGeneratedFlag);
		endif;
	else
		_value := (flags.bitAnd(SystemGeneratedFlag) &lt;&gt; 0);
	endif;

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Boolean" usage="io"/>
    </JadeMethod>
    <JadeMethod name="trackedItemTEU" id="e9a628ba-796f-4f51-9138-c1c06b5f92d2">
        <source>trackedItemTEU() : Real;
/*

