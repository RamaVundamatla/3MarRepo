    <JadeMethod name="btnDelete_click" id="44218443-92b5-43f7-8ad9-89ef4f4a416a">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnDelete_click(btn: Button input) updating;

vars

begin
	self.edtMain.text := null;
	self.modalResult := IDOK;
	self.unloadForm();
end;
</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doOK" id="934693a2-bf53-4374-a3cf-dda2daf5a20d">
        <updating/>
        <source>doOK() updating;
// compile the source and show any error
vars
	meth			: JadeMethod;
	methodSource	: String;
	errorCode, errorPos, errorLen 	: Integer;
	compiler		: JadeCompiler;
begin

	methodSource := self.getJadeCode();
	if not self.edtMain.readOnly and
	   self.parentClass &lt;&gt; null then
		// allow blank source as a way of removing hook code
		if methodSource &lt;&gt; null then
			meth := process.createTransientMethod(self.methodName, self.parentClass, currentSchema, methodSource, false, null, 
													errorCode, errorPos, errorLen);
		endif;
	endif;

	if errorCode &lt;&gt; 0 then
		create compiler transient;
		lblStatus.caption := "Error: " &amp; compiler.getErrorText(errorCode);
//		self.edtMain.sendMsgWithParams("setHighlightText", errorPos, errorLen);
		self.edtMain.sendMsgWithParams("moveCaret",JadeTextEdit.MVCRT_WORDSTART, errorPos, errorLen);
	else
		lblStatus.caption :=  'ok';
		inheritMethod();
	endif;
epilog
	process.deleteTransientMethod(meth);
	delete compiler;
end;</source>
    </JadeMethod>
    <JadeMethod name="getJadeCode" id="cf3b0364-25a5-4df3-bba9-f267c96b7834">
        <source>getJadeCode() : String;
// ---------------------------------------------------------------------------
// Created:     15 January 2008 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	
	return self.edtMain.text;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="init" id="dc59d561-bd35-49ea-9927-e3701f2a3599">
        <updating/>
        <source>init(_hookType : CM_HookType; _jadeCode : String; _readOnly : Boolean) updating;
// ---------------------------------------------------------------------------
// Created:     15 January 2008 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------

vars

begin

	self.myHookType := _hookType;
	
	self.edtMain.initializeJadeEditor(false);
	self.edtMain.configureFor_Jade;
	self.edtMain.setCurrentSchema(rootSchema.getSchema(PortSchemaName));
	self.edtMain.folding			:=	true;
	self.edtMain.foldFlags			:=	16;
	self.edtMain.foldSymbols		:=	JadeTextEdit.SC_FOLDSYM_TREESQUARE;//SC_FOLDSYM_PLUSMINUS;
	self.edtMain.viewLinenumbers	:=	true;
	
	self.lblStatus.caption := "";
	if _jadeCode = null then
		self.edtMain.text := _hookType.hookMethodTemplate.trimBlanks();
		self.lblStatus.caption := "* Default Code *";
		self.showDelete := false;
	else
		self.edtMain.text := _jadeCode.trimBlanks();
		self.lblStatus.caption := null;
	endif;
	
	self.btnOk.default := false;
	
	if _readOnly then
		self.edtMain.readOnly := _readOnly;
		self.btnCancel.visible := false;
		self.showDelete := false;
	endif;
	self.btnDelete.visible := self.showDelete;
	
	// set minimum form size
	self.minimumHeight := 250;
	self.minimumWidth := 450;

end;</source>
        <Parameter name="_hookType" type="CM_HookType"/>
        <Parameter name="_jadeCode" type="String"/>
        <Parameter name="_readOnly" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="load" id="4aefe942-92b5-4039-bac5-95d6387f3232">
        <controlMethod name="Form::load"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>load() updating;
// --------------------------------------------------------------------------------
// Created:		17 September 2008 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	inheritMethod;
	self.caption := self.caption &amp; ":" &amp; self.formCaption;
epilog
	app.mousePointer	:=	Idle;
end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="74f7ea07-09f5-4f73-a8e5-b00c41362577">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0007773, locale);
	btnDelete.translateCaption(Xlat_0016074, locale);
	// status line has already been set in 'init' method, don't do it again here
	///lblStatus.translateCaption(Xlat_0016075, locale);
end;</source>
    </JadeMethod>
</GUIClass>
