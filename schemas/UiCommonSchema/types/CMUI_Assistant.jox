    <JadeMethod name="comboBoxDocketType" id="69c13ef7-836f-45fa-a301-186707e5a543">
        <source>comboBoxDocketType(pCmb : ComboBox input; pDocketType : Integer);
//--------------------------------------------------------------
//Created: 23 January 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	theDocType : CM_BOLType;
begin
	pCmb.listCollection(app.myRoot.allBOLTypes, false, 0);
	
	/*th2 - 3/07/06 wtf? this is must have been Glenys
	if pDocketType = TI_CargoType_Null then
		theDocType := null;
	elseif pDocketType = null then
		theDocType := app.myRoot.allBOLTypes[BOLType_Log];
	elseif pDocketType = BOLType_Log then
		theDocType := app.myRoot.allBOLTypes[BOLType_Log];
	elseif pDocketType = BOLType_GeneralDocket then
		theDocType := app.myRoot.allBOLTypes[BOLType_GeneralDocket];
	else
		theDocType := app.myRoot.allBOLTypes[pDocketType];
	endif;
	*/
	theDocType := app.myRoot.allBOLTypes[pDocketType];
	//Set the combobox data
	if theDocType &lt;&gt; null then
		pCmb.text := self.displayEntryDocketType(theDocType);
		pCmb.listObject := theDocType;
	endif;

end;</source>
