    <JadeMethod name="isStorageDetailMatch" id="34602ee7-4e9c-4446-915c-8f4575146597">
        <source>isStorageDetailMatch(_criteria: CM_YACriteria; _ti: CM_TrackedItem; _tiTrx : CM_TITransaction): Boolean;
// CCMS 1295 free storage days
vars

begin
	//epr TFS 37176 21/2/18
	//return _criteria.myYAData.CM_YADataBoolean.doesValueMatch( _ti.isHazardousNotLimited);
	
	if _tiTrx &lt;&gt; null and _tiTrx.myTrackedItem &lt;&gt; null then	//13 Nov 2019	NDL	TFS 47344
		return _criteria.myYAData.CM_YADataBoolean.doesValueMatch( _tiTrx.myTrackedItem.isHazardousNotLimited );// is Hazardous NOT Limited not kept on the generic transaction
	else
		return _criteria.myYAData.CM_YADataBoolean.doesValueMatch( _ti.isHazardousNotLimited );
	endif;

end;
</source>
        <Parameter name="_criteria" type="CM_YACriteria"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_tiTrx" type="CM_TITransaction"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
