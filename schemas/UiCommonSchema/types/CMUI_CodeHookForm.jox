    <JadeMethod name="addObjectsToTable" id="a31f179f-e42b-4424-9641-04f6f33299ed">
        <updating/>
        <source>addObjectsToTable(_numItems: Integer io) updating;
// -------------------------------------------
// Created 04 February 2005 by cnwdvb1
// -------------------------------------------
vars

	iter		: Iterator;
	code		: CM_HookCode;
	passport	: CM_Passport;
	breakOut	: Boolean;
	
begin
	inheritMethod(_numItems);
	passport := app.myPassport;
	iter := app.myRoot.allHookCodes.createIterator();
	
	while iter.next(code) do
		if self.includeObject(code, passport) then
			self.addObjectToTable(code, _numItems, breakOut);
		endif;
		if breakOut then
			break;
		endif;
	endwhile;

epilog
	delete iter;
end;</source>
        <Parameter name="_numItems" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="clearDetailFrame" id="d2149646-b844-470c-a8d5-35ac158a9418">
        <source>clearDetailFrame() protected;
// -------------------------------------------
// Created 04 February 2005 by cnwdvb1
// -------------------------------------------
vars

begin

	self.cmbHookType.listIndex := -1;
	
	self.allSelectedLinkObjects.clear();
	self.lstTblLinks.clear();
	self.lstTblLinks.setSelected(self.allSelectedLinkObjects);
	
	
	self.txtJadeCode.text	:= null;
	self.txtCode.text		:= null;


end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="cmbHookType_click" id="a3383d8c-ec58-46f2-a65b-df6b447ca797">
        <controlMethod name="CMUI_ComboBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbHookType_click(combobox: ComboBox input) updating;
// -------------------------------------------
// Created 04 February 2005 by cnwdvb1
// -------------------------------------------
vars

	hookType	: CM_HookType;

begin

	self.lstTblLinks.enabled := true;	//10 Nov 2010	NDL Par 25530
	
	if self.mode = self.Mode_Add then
		hookType := combobox.listObject.CM_HookType;
		if hookType &lt;&gt; null then
			self.loadLstTblLinks(hookType);
			self.txtJadeCode.text := hookType.hookMethodTemplate;
		endif;
	endif;
	


end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="cmbHookType_displayEntry" id="c142aa21-e951-4d06-acf6-c5ac25537194">
        <controlMethod name="CMUI_ComboBox::displayEntry"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbHookType_displayEntry(combobox: ComboBox input; _hookType: CM_HookType; lstIndex: Integer):String updating;
// -------------------------------------------
// Created 04 February 2005 by cnwdvb1
// -------------------------------------------
begin
	// ### CNWAB1 MARCH2016 added detail
	if _hookType.hookType  = HookType_InvoiceQuantity 
	or _hookType.hookType  = HookType_InvoiceRate then
		return _hookType.description &amp; " " &amp; app.getErrorString(Cargo);
	elseif _hookType.hookType  = HookType_HMSInvoiceQuantity 
	or _hookType.hookType  = HookType_HMSInvoiceRate then
		return _hookType.description &amp; " " &amp; app.getErrorString(HMS);
	endif;
	
	return _hookType.description;
end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
        <Parameter name="_hookType" type="CM_HookType"/>
        <Parameter name="lstIndex" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
