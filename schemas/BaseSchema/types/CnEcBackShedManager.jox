    <JadeMethod name="getTaskCounts" id="6c606182-4717-4b15-8214-5a9364ea2607">
        <source>getTaskCounts(	pPrequeued:Integer output;
				pPrequeuedReady:Integer output;
				pQueued:Integer output;
				pActive:Integer output;
				pCompleted:Integer output;
				pFailed:Integer output);
// -----------------------------------------------------------------------------
// Created:		16 December 2001 by cnwdad1
//
// Purpose:		Sets the specified parameters to the corresponding task counts.
//
// Parameters:	pPrequeued - The number of pre-queued tasks.
//				pPrequeuedReady - The number of pre-queued ready tasks.
//				pQueued - The number of queued tasks.
//				pActive - The number of active tasks.
//				pCompleted - The number of completed tasks.
//				pFailed - The number of failed tasks.
//
// Returns:		The task counts as IO parameters.
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------
vars
	prequeued		: Integer;
	prequeuedReady	: Integer;
	queued			: Integer;
	active			: Integer;
	completed		: Integer;
	failed			: Integer;
	taskObj			: CnEcBackShedTask;
	currentDate		: Date;
	
begin
	foreach taskObj in self.allBackShedTasks do
		if taskObj.isRunning then
			active	:=	active + 1;
			
		elseif taskObj.isScheduled then
			queued	:=	queued + 1;
			
		elseif taskObj.completedTimeStamp.isValid then
			if taskObj.isFailed then
				failed	:=	failed + 1;
			else
				completed	:=	completed + 1;
			endif;
		else
			currentDate	:=	app.actualTimeServer().Date;// 12 May 2016	cnwns1	TFS 488 - Multi Timezone Support
			
			if currentDate &lt; taskObj.scheduleTimeStamp.Date then
				prequeued	:=	prequeued + 1;
			else
				prequeuedReady	:=	prequeuedReady + 1;
			endif;
		endif;
	endforeach;
	
	pPrequeued		:=	prequeued;
	pPrequeuedReady	:=	prequeuedReady;
	pQueued			:=	queued;
	pActive			:=	active;
	pCompleted		:=	completed;
	pFailed			:=	failed;
end;</source>
        <Parameter name="pPrequeued" type="Integer" usage="output"/>
        <Parameter name="pPrequeuedReady" type="Integer" usage="output"/>
        <Parameter name="pQueued" type="Integer" usage="output"/>
        <Parameter name="pActive" type="Integer" usage="output"/>
        <Parameter name="pCompleted" type="Integer" usage="output"/>
        <Parameter name="pFailed" type="Integer" usage="output"/>
    </JadeMethod>
    <JadeMethod name="startApplication" id="383648b7-bb87-40bf-a288-1410fc4236b2">
        <source>startApplication();

vars
	taskObj	: CnEcBackShedTask;
	iterObj	: Iterator;
	
begin
	beginNotification(self, CNEC_SHED_MANAGER_STOP, Response_Continuous, 0);
	iterObj := self.allBackShedTasks.createIterator();
	
	beginTransaction;
	
	while iterObj.next(taskObj) do
	
		if not taskObj.isRunning and taskObj.completedTimeStamp = null then	
			if taskObj.scheduleTimeStamp &lt;&gt; null then	// was scheduled when app taken down, re-schedule.
				taskObj.rescheduleMe();
			endif;		
		elseif taskObj.isRunning then
			taskObj.setInterrupted();
		endif;
		
	endwhile;
	
	self.doScheduleJobs();	
	commitTransaction;
epilog
	delete iterObj;
end;</source>
    </JadeMethod>
    <JadeMethod name="timerEvent" id="0a05b312-4c7f-4778-aa86-7a82fffc11cd">
        <updating/>
        <source>timerEvent(eventTag: Integer) updating;

begin
	if eventTag = self.SCHEDULE_JOBS then
		beginTransaction;
		self.doScheduleJobs();
		commitTransaction;
	endif;
end;</source>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="userNotification" id="c0c4c8fc-f125-4953-b159-7c189612ec2c">
        <updating/>
        <source>userNotification(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;
// -----------------------------------------------------------------------------
// Created:		17 December 2001 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------
vars
	managerOid	: String;
	
begin
	if eventType = CNEC_SHED_MANAGER_STOP then
		managerOid	:=	userInfo.String;
		
		if managerOid = process.getOidString() then
			if theObject = self then
				terminate;
			endif;
		endif;
	else
		inheritMethod(eventType, theObject, eventTag, userInfo);
	endif;
end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
</Class>
