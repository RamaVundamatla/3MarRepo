    </JadeMethod>
    <JadeMethod name="moveControl" id="4801616f-989c-40cb-9bcd-2c940a466293">
        <updating/>
        <source>moveControl(pX, pY, _loa : Real; _controlMoveStyle : Integer) updating;
// ---------------------------------------------------------------------------
// Created:     29 October 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpWharfDrawControl,
	otherWharfDrawControl	: HMS_WharfDrawControl;
	tmpWidth,
	tmpLeft,
	tmpHeight,
	tmpTop,
	amt,amt2, r1,r2,r3, i1,i2 : Real;
begin

	// allow for movement only in direction selected in controlMoveStyle - see superclass method for full implementation as this
	// reimplemented method allows movement in a limited number of directions/modes
	tmpTop 		:= self.top;
	tmpLeft		:= self.left;
	tmpHeight	:= self.height;
	tmpWidth	:= self.width;
		

	tmpWharfDrawControl := self.myCurrentWharfDrawControl;
		
	if self.origEdge = HMS_Edge_Top then
		amt := self.saveTop - (tmpTop + pY - origYOffset);
		r1  := tmpTop + pY - origYOffset;
		if (r1 &gt;= self.edgeTopMin) and (r1 &lt;= edgeTopMax) then
			tmpHeight := self.saveHeight + amt;						
			self.move(self.saveLeft, r1, self.saveWidth, tmpHeight);
		endif;
	elseif self.origEdge = HMS_Edge_Bottom then
		amt := self.saveHeight - origYOffset;
		r1  := self.saveTop + pY + amt;
		if (r1 &lt;= self.edgeBottomMax) and (r1 &gt;= self.edgeBottomMin) then
			tmpHeight := pY + amt;						
			self.move(self.saveLeft, self.saveTop, self.saveWidth, tmpHeight);
		endif;
	else
		// if not dragging an edge (therefore not resizing) check the lower edge of the sprite stays within bounds

		if _controlMoveStyle = HMS_GraphicalViewX.Move_NS or
		   _controlMoveStyle = HMS_GraphicalViewX.Move_NESW then
			// we are moving picture up &amp; down 
			r2 := tmpTop + pY - origYOffset + tmpHeight;
			if (r2 &gt;= self.edgeBottomMin) and (r2 &lt;= self.edgeBottomMax) then
				tmpTop := tmpTop + pY - self.origYOffset;			
			endif;
		endif;
		
		if _controlMoveStyle = HMS_GraphicalViewX.Move_WE or
		   _controlMoveStyle = HMS_GraphicalViewX.Move_NESW then

			r3 := tmpLeft + pX - origXOffset;
			i1 := (r3 * tmpWharfDrawControl.metersPerPixel);
			i2 := i1 + _loa;

			if i1 &gt; 0 and i2 &lt;= tmpWharfDrawControl.wharfTotalLength then
				tmpLeft := r3;
			elseif i2 &gt; tmpWharfDrawControl.wharfTotalLength then
				otherWharfDrawControl := self.myGraphicalViewForm.getNextWharfDrawControl(tmpWharfDrawControl);
				if otherWharfDrawControl &lt;&gt; null then
					// move to next wharf
					tmpWharfDrawControl.showHideLabels(false, null, null);
					self.setCurrentWharfDrawControl(otherWharfDrawControl);
					tmpLeft := 1;
					tmpWharfDrawControl := otherWharfDrawControl;
					tmpWharfDrawControl.showHideLabels(true, tmpLeft, tmpWidth);
				endif;
			elseif i2 &lt; 0 then
				otherWharfDrawControl := self.myGraphicalViewForm.getPreviousWharfDrawControl(tmpWharfDrawControl);
				if otherWharfDrawControl &lt;&gt; null then
					// move to previous wharf
					tmpWharfDrawControl.showHideLabels(false, null, null);
					//tmpWharfDrawControl.movePointers(false, 0, 0);
					self.setCurrentWharfDrawControl(otherWharfDrawControl);
					tmpLeft := self.myCurrentWharfDrawControl.myScrollingFrame.width - tmpWidth;
					tmpWharfDrawControl := otherWharfDrawControl;
					tmpWharfDrawControl.showHideLabels(true, tmpLeft, tmpWidth);
				endif;
			endif;

		endif;
		
		self.move(tmpLeft, tmpTop, tmpWidth, tmpHeight);

	endif;	

	// move any other controls that move in conjunction with the selected control
	if self.myDragPicturePrevious &lt;&gt; null then
		amt := self.myDragPicturePrevious.top + self.myDragPicturePrevious.height;
		self.myDragPicturePrevious.move(self.myDragPicturePrevious.left, tmpTop + tmpHeight, self.myDragPicturePrevious.width, amt - (tmpTop + tmpHeight));
	endif;
	if self.myDragPictureNext &lt;&gt; null then
		amt := tmpTop - self.myDragPictureNext.top;
		self.myDragPictureNext.move(self.myDragPictureNext.left, self.myDragPictureNext.top, self.myDragPictureNext.width, amt);
	endif;

	self.myGraphicalViewForm.myDrawTimeLabel.movePointer(true, self.top, tmpTop + tmpHeight);
	self.myCurrentWharfDrawControl.movePointers(true, tmpLeft, tmpLeft + tmpWidth);
	
end;</source>
        <Parameter name="pX" type="Real"/>
        <Parameter name="pY" type="Real"/>
        <Parameter name="_loa" type="Real"/>
        <Parameter name="_controlMoveStyle" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="moveToSavePosition" id="fcda0ba8-5ccc-4681-8537-99163fbb4b80">
        <updating/>
        <source>moveToSavePosition() updating;
// ---------------------------------------------------------------------------
// Created:     29 October 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	self.setCurrentWharfDrawControl(self.saveWharfDrawControl);
	self.height := self.saveHeight;
	self.left	:= self.saveLeft;
	self.top	:= self.saveTop;
	self.width	:= self.saveWidth;
end;</source>
