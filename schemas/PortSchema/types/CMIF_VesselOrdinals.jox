<Class name="CMIF_VesselOrdinals" id="4115a9b2-6132-43c7-bc3d-f46492d324cf">
    <superclass name="CMIF_Object"/>
    <transient/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <abstract/>
    <text>Used in the getOrdinals calls on either a Vessel or Bay
to extract ordinals based on labels passed in.
Use this to locate a particular position on the vessel
eg. a particular bay, cell, tier or slot leave the other fields blank</text>
    <PrimAttribute name="onDeck" id="9c808b5c-c24e-4242-acf5-c3fb105c165b">
        <embedded/>
        <type name="Boolean"/>
    </PrimAttribute>
    <PrimAttribute name="ordinalBay" id="5d2fc773-1142-4bb8-b8de-2e7ac9f88343">
        <embedded/>
        <type name="Integer"/>
    </PrimAttribute>
    <PrimAttribute name="ordinalCell" id="2c40395d-8f8e-4865-b781-149e733be02e">
        <embedded/>
        <type name="Integer"/>
    </PrimAttribute>
    <PrimAttribute name="ordinalSlot" id="b56bc228-6483-4655-877a-4a1f12df623b">
        <embedded/>
        <type name="Integer"/>
    </PrimAttribute>
    <PrimAttribute name="ordinalTier" id="18897be0-2596-4a08-bbf3-8ee8f87fda7c">
        <embedded/>
        <type name="Integer"/>
    </PrimAttribute>
</Class>
