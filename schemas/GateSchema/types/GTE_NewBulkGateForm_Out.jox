        <source>stub_SendWeight(_newWeight : Decimal);

	/*
		this method stub has been automatically generated by Jade to satisfy interface implementation requirements for the IF_TCPWeightCallerInterface interface 
	*/
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 July 2021	navndl1	Initial creation	TFS 51575

*/

vars

	msg : String;

begin

	if self.myOtherWeightIntController &lt;&gt; null then
	
		if _newWeight &lt; 0 then
			msg := app.getErrorString1( Weigh_bridge_return_negati_wei, _newWeight.asStringJMT );
			app.msgBox( msg, app.getErrorString(Error), MsgBox_OK_Only + MsgBox_Stop_Icon );
			return;
		endif;

		//weight is always returned in kgs set to the default weight
		self.txtWeightOUT.setValueDefault( _newWeight.String );
