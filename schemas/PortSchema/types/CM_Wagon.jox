    <JadeMethod name="validateDepartureProcess" id="848e73f6-7c1d-4185-8edb-843703c2740d">
        <source>validateDepartureProcess();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22/08/2023	navkc1	CR 59610 Task 59611: Jade - Stop Prevention
21 Oct 2024	navbs1  Story MTN-14791: EUP | 53856 - New Scanning App - Unpack mode issue
30 Jun 2025 navma1  MTN-34090  MTN | Dead lock (1081) on CM_TIByIdCargoTypeRelseDictRev
*/

vars
	ti				: CM_TrackedItem;
	tisOnBoard		: CM_TIArray;
begin
	
	create tisOnBoard transient;
	
	// Outwards - Confirmed
	self.getAllTrackedItems(false, tisOnBoard, true);
	// Outwards - not confirmed
	self.getAllTrackedItems(false, tisOnBoard, false);
	
	foreach ti in tisOnBoard discreteLock do						//30.06.2025 navma1 #MTN-34090
		app.myPassport.setContext(Context_Pass_CUST_FullyCleared);  // ### TFS CR 60424 TASK 60549 16OCT2023 NAVAB1			//21.10.2024  navbs1  #14791
		ti.checkStopsToBePrevented(StopPreventTrainDeparture, null, true);
		app.myPassport.setContext(Context_Pass_Null); 				// ### TFS CR 60424 TASK 60549 17OCT2023 NAVAB1			//21.10.2024  navbs1  #14791
	endforeach;
epilog
	app.myPassport.setContext(Context_Pass_Null); 					// ### TFS CR 60424 TASK 60549 17OCT2023 NAVAB1			//21.10.2024  navbs1  #14791
	delete tisOnBoard;
end;</source>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="afed58e1-16f0-4d72-83a2-5bda20993afd">
        <updating/>
        <source>validateForCreate() updating;
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 29/03/2010	cnwdad1		PAR #22698 - For a Train Consist, we may not yet have a real train object.
//
// 31/03/2010	cnwdad1		PAR #23489 - Added the use of the Scheduled Arrival
//							date when looking up the real train.
// ---------------------------------------------------------------------------
vars
	realTrain	: CM_Train;
	
begin
	if self.myTrainInwards &lt;&gt; null and self.myTrainInwards.isTransient() then
// cnwdad1 31/03/2010 - PAR #23489.
		//realTrain	:=	self.myTerminal.allTrainsOnTerminal.getAtKeyGeq(self.myTrainInwards.code, null);
		realTrain	:=	self.myTerminal.allTrainsOnTerminal.getAtKeyGeq(self.myTrainInwards.code, self.myTrainInwards.scheduledArrivalDT);
		
// cnwdad1 29/03/2010 - PAR #22698 - For a Train Consist, the real train won't exist yet.
		if realTrain = null then
			realTrain	:=	self.myTrainInwards;
		else
			if realTrain.code &lt;&gt; self.myTrainInwards.code then
				//realTrain	:=	null;
				realTrain	:=	self.myTrainInwards;
			endif;
		endif;
	else
		realTrain	:=	self.myTrainInwards;
	endif;
	
	//if self.myTrainInwards = null then //11 Aug 2009 NDL Par 20499
	if realTrain = null then //11 Aug 2009 NDL Par 20499
		app.raiseCMException(Wagon_must_have_inward_train, null, null);
		return;
	endif;
	
	//if self.myTrainInwards.allWagonsByIdInward[self.id] &lt;&gt; null then //+ cnwmd1, CCMS 1067, Par 19913 - Moved from CMIF_WagonUpdateController::validate
//	if realTrain.allWagonsByIdInward[self.id] &lt;&gt; null then //+ cnwmd1, CCMS 1067, Par 19913 - Moved from CMIF_WagonUpdateController::validate
// cnwdad1 29/03/2010 - PAR #22698 - Commented out above, and replaced with:
	if not realTrain.isTransient() and realTrain.allWagonsByIdInward[self.id] &lt;&gt; null then //+ cnwmd1, CCMS 1067, Par 19913 - Moved from CMIF_WagonUpdateController::validate
		app.raiseCMException2(Wagon_with_alread_exists_train, self.id, self.myTrainInwards.code, null, null);
		return;
	endif;
	
	self.validateMe();
end;</source>
    </JadeMethod>
    <JadeMethod name="validateForDelete" id="3ff13c27-a984-4e46-a93e-0443225b7685">
        <source>validateForDelete(_isTrainConsistVerify:Boolean);
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	job : CM_Job;
	incompleteJobsExist : Boolean;
	incompleteJobList : String;
	trackedItemList : String;
	newTI : String;
	lcForWagon : CM_LocationsController;
	ti : CM_TrackedItem;
	futuerMovesList : String;
begin
	if app.isJMTUnitTest then
		return;
	endif;
	
	if self.myTerminalDeparted &lt;&gt; null then // PAR 20607
		app.raiseCMException1(WAGON_NO_DELETE_DEPARTED, self.id, null, self); // PAR 20607
	endif;
	if self.confirmedOutwards then // PAR 20607
		app.raiseCMException1(WAGON_NO_DELETE_CONFIRMEDOUT, self.id, null, self); // PAR 20607
	endif;
	
	if self.confirmed then
		//app.raiseCMException(ERR_DEL_CONFIRMED, "Deleting Wagon " &amp; self.id, null);	//- cnwmd1, CCMS 1067, Par 19710
		//app.raiseCMException(ERR_DEL_CONFIRMED, app.getErrorString1(Deleting_wagon, self.id), null); //+ cnwmd1, CCMS 1067, Par 19710
		app.raiseCMException1(WAGON_NO_DELETE_CONFIRMEDIN, self.id, null, self); // PAR 20607
	endif;
	
	if self.hasInvoices() then
		app.raiseCMException1(ERR_Wagon_Has_Charges, self.id,null, null);
	endif;
	
	//cnwjo3 par 21524
	if self.allRailJobs.size &gt; 0 then
		incompleteJobsExist := false;
		foreach job in self.allRailJobs do
			if not job.isJobComplete then
				incompleteJobsExist := true;
				incompleteJobList := incompleteJobList &amp; job.jobId &amp; ", ";
			endif;
		endforeach;
		
		if incompleteJobsExist then
			incompleteJobList := incompleteJobList[1:incompleteJobList.length-2];
			app.raiseCMException2(WAGON_NO_DELETE_INCOMPLETEJOBS,self.id,incompleteJobList,null,self);
		endif;
	endif;
	
	//cnwjo3 par 21524
	if self.hasTrackedItems and (not _isTrainConsistVerify) then
		//foreach lcForWagon in self.allLocationsControllers do
		foreach lcForWagon in self.allLocationsControllersArray do	//04 Dec 2014	NDL	Par 35345
			foreach ti in lcForWagon.allTrackedItems do
				newTI := ti.id &amp; ", ";
				if trackedItemList.pos(newTI,1) &lt; 1 then
					trackedItemList := trackedItemList &amp; newTI;
				endif;
			endforeach;
		endforeach;	
	
		trackedItemList := trackedItemList[1:trackedItemList.length-2];
		app.raiseCMException2(WAGON_NO_DELETE_HAS_TIS,self.id,trackedItemList,null,self);
	endif;
	
	//25 Feb 2014	NDL	Par 33490
	//foreach lcForWagon in self.allLocationsControllers do
	foreach lcForWagon in self.allLocationsControllersArray do	//04 Dec 2014	NDL	Par 35345
		if not lcForWagon.allQueuedFutureMoves.isEmpty or not lcForWagon.allPlannedFutureMoves.isEmpty then
			app.raiseCMException1( Wagon_has_future_moves, self.id, null, self );
		endif;
	endforeach;
	
end;</source>
        <Parameter name="_isTrainConsistVerify" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="25f0f242-74af-486b-bc30-dd1a869cb3be">
        <updating/>
        <source>validateForUpdate() updating;
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

	realWagon : CM_Wagon;
	
begin
	/* this needs to look at the link between real and proxy. Self is a proxy and this simple finds the real one so they are different
	if app.getMyTerminal().allWagons[self.id] &lt;&gt; self then
		app.raiseCMException1(VB_DUPLICATED_ITEM, self.id, null, null);
	endif;
	*/
	self.validateMe;
	
	if self.isTransient then
		realWagon := self.pxyGetRealObject;
		if realWagon &lt;&gt; null and self.id &lt;&gt; realWagon.id then
			if realWagon.hasTrackedItems then
				app.raiseCMException(NO_ID_change_has_cargo, null, self);
			endif;
		endif;
	endif;	
	
end;</source>
    </JadeMethod>
    <JadeMethod name="validateMaxLoadWeight" id="2909752d-256f-41a6-85ea-dff1df966e8f">
        <source>validateMaxLoadWeight(control: CMIF_MoveController);
/*
 ------------------------------------------------------------------------
Created:			12 September 2001 by cnwdwq1
Purpose:			Test to be sure we dont overload the wagon.
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
25 July	 2022	jlika1	TFS 54050 - EUP- Max Wagon Payload
---------------------------------------------------------------------------
*/
vars
	array 				: CM_TIArray;
	moveTI,
	ti 					: CM_TrackedItem;
	weight 				: Decimal[14,4];
	weightToValidate	: Decimal[12,2];
	terminal 			: CM_Terminal;
	raiseError 			: Boolean;
begin
	terminal := control.getMyTerminal();
	if terminal  &lt;&gt; null then
		raiseError := self.myTerminal.getConfig(RaiseErrorMaxLoadWeight).Boolean;
	endif;
	
	moveTI := control.myTrackedItem;
	create array transient;
	self.getTIs(array, control.moveMode);
	foreach ti in array do
		if ti = moveTI then
			continue;
		endif;
		weight := weight + ti.totalWeight;
	endforeach;
	//weight := weight + ti.totalWeight;
	weight := weight + control.getWeightForValidation();	//13 Sep 2013	NDL	 Par 32452
	//par 18423 No validation for 0 max weight
	
	//jlier1 TFS 58104 23/5/23
	weightToValidate := self.maxCargoWeight;
		
	if weight &gt; weightToValidate and weightToValidate &lt;&gt; 0 then
		if raiseError then
			app.raiseCMException(WARN_MAX_LOAD_WEIGHT, null, null);
		else
			app.raiseCMWarning(WARN_MAX_LOAD_WEIGHT, null, null, self);
		endif;
	endif;
epilog
	array.clear;
	delete array;	
end;</source>
        <Parameter name="control" type="CMIF_MoveController"/>
    </JadeMethod>
    <JadeMethod name="validateMe" id="2dc39c66-292d-4c50-a5c2-1902d1ed170b">
        <updating/>
        <source>validateMe() updating, protected;

vars
	lWagonClass : CM_WagonClass;
	wagonClassId : String;
	realWagon : CM_Wagon;
	existingWagon : CM_Wagon;
begin
	if self.id = null then
	//	app.raiseCMException1(REQUIRED_FIELD, app.getErrorString(Wagon_code), null, null);
		app.raiseCMException1(Input_required_field_Required, app.getErrorString(Wagon_code), null, null); // cnwdb2	PAR 35364
		return;
	endif;	
	
	// cnwrl1 13/10/2009 PAR 21049 - start of coding
	// must be upper case only.
	if self.id &lt;&gt; self.id.toUpper then
		app.raiseCMException1( Name_Must_Be_Upper_Case_Only, self.id, null, self );
	endif;
	// cnwrl1 13/10/2009 PAR 21049 - end of coding
	
	lWagonClass := self.myWagonClass;	//29 Jul 2009 NDL CCMS 1067
	if lWagonClass = null then
		wagonClassId := app.myRoot.getWagonClassViaHookCode(self.myTerminal,self.id,self.myCarrier); //20 Jul 2009 NDL CCMS 1067
		if wagonClassId = null then
			app.raiseCMException(ERR_UNKNOWN_WAGON_CLASS,"",null);
			return;
		endif;
		lWagonClass := self.myTerminal.myRoot.allWagonClasses[wagonClassId];
		self.myWagonClass := lWagonClass;		// cnwjre1 04/2011 27069 edit wagon id
	endif;
	
	if lWagonClass = null then
		//app.raiseCMException2(ERR_KEY_NOT_FOUND, wagonClassId, "Wagon Classes","", null); //- cnwmd1, CCMS 1067, Par 19710
		app.raiseCMException2(ERR_KEY_NOT_FOUND, wagonClassId, app.getErrorString(Wagon_classes),"", null); //+ cnwmd1, CCMS 1067, Par 19710
		return;
	endif;
	
	if lWagonClass.isNotAvailableForEntry then
		//epr par 32648 32648
		app.raiseCMException1(NotAvailableForEntry,app.getErrorString(Wagon_class) &amp; " " &amp; wagonClassId,null, null); 
	endif;
	
	if self.myTrainInwards = null then
		// PAR 16643 - add wagon to error message and as parameter
		//app.raiseCMWarning2(ERROR_NO_TRAIN,self.id, null,ETRow_Train, null,self); //+ 19/05/2009, cnwmd1, CCMS 1067, Par 20009 //- cnwmd1, CCMS 1067, Par 19913 - Changed to an excpetion
		app.raiseCMException2(ERROR_NO_TRAIN, self.id, null, null,self); //+ cnwmd1, CCMS 1067, Par 19913
		return;
	endif;
	if self.myTrainOutwards = null then	//06 Oct 2009	NDL	Par 20794
		app.raiseCMException2(ERR_NO_OUT_TRAIN, self.id, null, null,self);
		return;
	endif;
	
	//10 Jun 2015	NDL	Par 36425
	if self.confirmedOutwards and not self.confirmed then
		app.raiseCMException1(Wagon_must_confi_inwar_befor_c, self.id ,null, null);
	endif;
	
	//12 Nov 2014	NDL	Par 35164
	realWagon := self.pxyGetRealObject;
	if self.getTerminal &lt;&gt; null then
		existingWagon := self.getTerminal.allWagons.getAtKeyGeq(id, "31,12,3001".Date.TimeStamp);
		if existingWagon &lt;&gt; null and existingWagon &lt;&gt; realWagon and existingWagon.id = self.id then
			app.raiseCMException2(Wagon_already_site_termina, self.id, self.getTerminal.code, null, existingWagon);
		endif;
	endif;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="validateMoveFrom" id="39af0ee4-1c5d-4c62-99fd-3124a6df1d8a">
        <source>validateMoveFrom(_control : CMIF_MoveController);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 November 2012	cnwndl1	Initial creation	Par 30522

*/

vars

	theTI : CM_TrackedItem;

begin

	if self.isDeparted then
		// Don't allow cargo moves of any type from a departed wagon.
		app.raiseCMException(Unabl_perfo_move_from_depar_wa, null, self);
	endif;
	
	if not self.confirmed then	// The wagon is NOT confirmed INWARDS
		// If the wagon is NOT confirmed inwards you are allowed to do a real move of a pre-note from the wagon to another wagon.
		// If the wagon is NOT confirmed inwards you are allowed to Plan moves from the wagon.
		// If the wagon is NOT confirmed inwards you can NOT queue any moves from the wagon,
		//      cos that would try to add a task to the RTQ form that couldn't be processed.
		
		if _control.moveMode = QUEUE_MODE then
			app.raiseCMException(Not_queue_moves_wagon_that_not, null, self);
			
		elseif _control.moveMode = REAL_MODE then
			theTI := _control.myTrackedItem;
			if not theTI.isPreNote then
				app.raiseCMException(Unabl_perfo_move_wagon_not_bee, null, self);
			elseif _control.myToPrimaryLocation = null or not _control.myToPrimaryLocation.isWagon then
				app.raiseCMException(Unabl_perfo_move_wagon_not_bee, null, self);
			endif;
		endif;
		
	endif;
	
epilog

end;</source>
        <Parameter name="_control" type="CMIF_MoveController"/>
    </JadeMethod>
    <JadeMethod name="validateMoveLabourRestriction" id="d5ce2383-6d0f-4292-9717-a07f28e8c8a2">
        <source>validateMoveLabourRestriction(control : CMIF_MoveController);
/*
 ------------------------------------------------------------------------
Created:			27 July 2001 by cnwdwq1
Purpose:			Checks our restrictions
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/
begin
	if self.myRailLine &lt;&gt; null then
		self.myRailLine.validateMoveLabourRestriction(control);
	endif;
end;</source>
        <Parameter name="control" type="CMIF_MoveController"/>
    </JadeMethod>
    <JadeMethod name="validateMoveTo" id="fbf9356a-446f-42f3-8114-4e6d5a23f34d">
        <source>validateMoveTo(_control : CMIF_MoveController);
//--------------------------------------------------
// Created:	01 September 2003 By: cnwgd1
//--------------------------------------------------
/* Changes

Date		Name	TFS#		Description
============================================================================
24/7/2017	jlgns1 	TFS 4994:MSL - Planning cntr still on board on Rail Line
25/07/2022	jlika1	TFS 54050 EUP  - Max Wagon Payload
============================================================================*/
vars
	checkVoy 			: Boolean;
	weight 				: Decimal[14,4];
	array 				: CM_TIArray;
	tmpTI,
	theTI 				: CM_TrackedItem;
	str 				: String;
	trackClearance 		: CM_TrackClearance;
	rulesMet 			: CM_WagonPositionalRuleSet;
	asError 			: Boolean;
	weightToValidate	: Decimal[12,2];
	terminal			: CM_Terminal;
	raiseError			: Boolean;
begin
	//jlier1 TFS 56772 13/3/22
	terminal := self.getMyTerminal();
	
	if terminal &lt;&gt; null then
		raiseError := terminal.getConfig(RaiseErrorMaxLoadWeight).Boolean;
	endif;
	
	theTI := _control.myTrackedItem;
	
	
	//02 Nov 2012	NDL	Par 30522
	if self.isDeparted then
		app.raiseCMException(Unable_perfor_move_depart_wago, null, self);
	endif;
	if not theTI.isOnSite() and _control.moveMode = QUEUE_MODE then
		app.raiseCMWarning1(No_Q_move_not_on_site, theTI.id, null, self,self);	//TFS 4994
	//	app.raiseCMException1(No_Q_move_not_on_site, theTI.id, null, self);		//TFS 4994
	endif;
	
	//--------------------------------
	// Validate consignee restriction
	//--------------------------------
	str := theTI.consignee.trimBlanks;
	if str &lt;&gt; null then
		if self.myWagonClass.allConsigneeCodesRestricted.includes(str) then
			app.raiseCMWarning2(WARN_WAGON_CONSIGN, theTI.id, str, null, null, self);
		endif;
	endif; 
	
	// PAR 26899 Do not allow on site cargo to be moved to a wagon that is not confirmed inwards
	// This does allow prenotes to be moved.
	// The issue was that if onsite cargo are moved to the wagon and then they try to confirm outwards, we show an error cos the wagon is not confirmed inward.
	// if they then confirm the wagon in we will create receival transaction which is incorrect.
	// All wagons, even those that arrive with no cargo, must be confirmed inwards.
	if not self.confirmed // NOT confirmed INWARDS
	and _control.moveMode &lt;&gt; PLANNING_MODE		// 28812 Dec 2011 allow planned moves still
 	and theTI.isOnSite() then // Cargo is Onsite
		app.raiseCMException2(Canno_move_wagon_becau_wagon_n,theTI.id,  self.id, null, self);	
	endif;

	//--------------------------------
	// Validate same Voyage
	//--------------------------------		
	checkVoy := true;
	
	if theTI.myVoyage = null then
		// no voyage to validate 
		checkVoy := false;
	elseif theTI.isStorage then
		//Validate same voyage if not an empty
		checkVoy := (not theTI.isAttributeTrue(TI_Attrib_IsEmpty));
	endif;

	// Get all the TIs on the wagon
	create array transient;
	self.getTIs(array, _control.moveMode);
		
	foreach tmpTI in array do
		
		//+cnwml2 PAR24678
		if tmpTI = theTI then
			continue;
		endif;
		// Validate same consignee
		if tmpTI.consignee &lt;&gt; theTI.consignee then
			app.raiseCMWarning3(WARN_WAGON_DIFF_CONSIGNEE, theTI.consignee, theTI.id, tmpTI.consignee, null, null, theTI);
		endif;

		// removed for par 26224 validate against the releases assigned to wagon.
		
		if checkVoy and tmpTI.myVoyage &lt;&gt; null then
		//Voyage validation is not required on the Generator Cargo Types. Par 6653 cnwsh3 17112003
			if tmpTI.cargoType &lt;&gt; TI_CargoType_Generator then			
				if tmpTI.myVoyage &lt;&gt; theTI.myVoyage then
					app.raiseCMWarning3(WARN_DIFF_VOYAGE, theTI.myVoyage.code, theTI.id, tmpTI.myVoyage.code, null, null, theTI);
				endif;		
			endif;
		endif;
		// acumulate weight
		weight := weight + tmpTI.totalWeight;
	endforeach;

	//----------------------------------------------
	//Validate weight, so we dont overload the wagon
	//----------------------------------------------
	//weight := weight + theTI.totalWeight;
	weight := weight + _control.getWeightForValidation();	//13 Sep 2013	NDL	 Par 32452
	
	//par 18423 no validation for max weight of 0
	
	//jlier1 TFS 58104 23/5/23
	weightToValidate := self.maxCargoWeight;
	
	if weight &gt; weightToValidate and weightToValidate &lt;&gt; 0 then
		if raiseError then
			app.raiseCMException(WARN_MAX_LOAD_WEIGHT, null, null);
		else
			app.raiseCMWarning(WARN_MAX_LOAD_WEIGHT, null, null, self);
		endif;		
	endif;
	
	//08 Jul 2009	NDL	CCMS 1076
	if self.myWagonMaster &lt;&gt; null then
		self.myWagonMaster.getPositionalLoadError(_control, self, rulesMet);
	endif; 
	
	//16 Jul 2009	NDL CCMS 1076
	if self.myTrainOutwards &lt;&gt; null then
		trackClearance := self.myTrainOutwards.myTrackClearance;
		if trackClearance &lt;&gt; null then
			asError := self.myTerminal.getConfig(RailTrackClearErr).Boolean;
			self.validateUsingTrackClearance(_control, trackClearance, _control.moveMode, true, asError);
		endif;
		
		// PAR 19913 train has not arrived at terminal yet so can only plan cargo in yard to wagon
		if theTI.myPrimaryActualLocation &lt;&gt; null and theTI.myPrimaryActualLocation.isYardLocation() and self.myRailLine = null and _control.moveMode &lt;&gt; PLANNING_MODE then
			app.raiseCMException(Invoi_move_mode_speci_only_pla, null, self);
		endif;
	endif;
	


epilog
	if array &lt;&gt; null then	//02 Sep 2011	NDL	If early error raised array may not have been created
		array.clear;
	endif;
	delete array;			
end;</source>
        <Parameter name="_control" type="CMIF_MoveController"/>
    </JadeMethod>
    <JadeMethod name="validateSameConsignees" id="390e5b18-09b2-4702-b3c9-cf371a2dc94e">
        <source>validateSameConsignees(control: CMIF_MoveController);
/*
 ------------------------------------------------------------------------
Created:			12 September 2001 by cnwdwq1
Purpose:			Test to ensure the incoming TI fits with the other TI's on this wagon
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/
vars
	array : CM_TIArray;
	tmpMoveTI,
	tmpTI : CM_TrackedItem;
begin
	create array transient;
	self.getTIs(array, control.moveMode);
	
	tmpMoveTI := control.myTrackedItem;
	
	foreach tmpTI in array do
		if tmpTI.consignee &lt;&gt; tmpMoveTI.consignee then
			app.raiseCMWarning3(WARN_WAGON_DIFF_CONSIGNEE, tmpMoveTI.consignee, tmpMoveTI.id, tmpTI.consignee, null, null, tmpTI);
		endif;
	endforeach;
epilog
	array.clear;
	delete array;	
end;</source>
        <Parameter name="control" type="CMIF_MoveController"/>
    </JadeMethod>
    <JadeMethod name="validateTIsForConfirm" id="2bf4c361-36de-465a-885d-f564d6e33108">
        <source>validateTIsForConfirm(_passport : CM_Passport input) : Boolean;
//--------------------------------------------------
// Created:	03 June 2004 By: cnwgd1
//02 May navma1	ChangeRequest 63936: MTN - Use Deferred Updates When Confirm Wagons
//--------------------------------------------------
vars
	lc 			   : CM_LocationsController;
	lastTi,
	ti 			   : CM_TrackedItem;
	term 		   : CM_Terminal;
	weight ,
	maxCargoWeight : Decimal[14,4]; 
	idx 		   : Integer;
	wagonClass	   : CM_WagonClass;
	wagonLenUnit   : Integer;
begin

	term := _passport.myTerminal;

	foreach lc in self.allLocationsControllersArray discreteLock do	//04 Dec 2014	NDL	Par 35345
		foreach ti in lc.allTrackedItems discreteLock do
			if ti &lt;&gt; lastTi and 
			   ti.state &lt;&gt; TI_STATE_NORMAL then
				if term.allOnsiteTIsByCargoTypeId[ti.cargoType, ti.id.trimBlanks] &lt;&gt; null then
					app.raiseCMException1(ERR_TI_ONSITE, ti.id, null, null);
				endif;
				weight := weight + ti.totalWeight;
				
			endif;
			lastTi := ti;
		endforeach;
		//par 18423 no validation for max weight of 0
		//jlier1 TFS 58104 23/5/23
		maxCargoWeight := self.maxCargoWeight;
		if weight &gt; maxCargoWeight	 and maxCargoWeight &lt;&gt; 0 then
			app.raiseCMWarning(WARN_MAX_LOAD_WEIGHT, null, null, self);
		endif;
		
		if lc.CM_WagonController.isStackFull(REAL_MODE, null) then
			app.raiseCMException1(ERR_TOO_MUCH_ON_WAGON, null, null, self);
		endif;
	endforeach;
	
	if not self.isBoxcar then
		wagonClass 		:= self.myWagonClass;				//02.05.2024 navma1 #63936
		wagonLenUnit	:= wagonClass.getLenInUnits();		//02.05.2024 navma1 #63936
		
		foreach idx in 1 to wagonClass.maxNumInStack do
			foreach lc in self.allLocationsControllersArray discreteLock do						//04 Dec 2014	NDL	Par 35345
				if lc.CM_WagonController.getLengthOfTIs(REAL_MODE, idx) &gt; wagonLenUnit then		//02.05.2024 navma1 #63936
					app.raiseCMException1(ERR_TOO_MUCH_ON_WAGON, null, null, self);
				endif;
			endforeach;
		endforeach;
	endif;
	
	return _passport.noErrors;

end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateTIsTrackClearance" id="c2a552f6-b52e-4505-89fa-736e32008280">
        <source>validateTIsTrackClearance(_trackClearance : CM_TrackClearance; raiseWarning : Boolean; _asError : Boolean):String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
12 March 2010	cnwas3	par 23112

*/
vars

	maxWagonHeight : Decimal [12,2];
	maxWagonWeight : Decimal [12,2];
	maxWagonWidth : Decimal [12,2];
	
	wagonHeight : Decimal [12,2];
	wagonWeight : Decimal [12,2];
	wagonWidth : Decimal [12,2];
	
begin

	if _trackClearance &lt;&gt; null then
	
		maxWagonHeight := _trackClearance.maxHeight;
		maxWagonWeight := _trackClearance.maxWeightWagon;
		maxWagonWidth := _trackClearance.maxWidth;
		
		if not self.getTotalWeightWidthHeight(wagonWeight, wagonWidth, wagonHeight) then // PAR 23176
			if self.myTrainOutwards.noEmptyWagons then // PAR 23176
				if _asError then	//24 Nov 2010	NDL	Par 23883
					app.raiseCMException2(Track_clear_error_wagon_empty_, self.id, self.myTrainOutwards.code, null, self);
				else
					app.raiseCMWarning2(Track_clear_error_wagon_empty_, self.id, self.myTrainOutwards.code, null, null, self); // PAR 23176
				endif;
			endif;
		endif;
		
		if maxWagonHeight &lt;&gt; 0 and maxWagonHeight &lt; wagonHeight then

			if raiseWarning then
				if _asError then	//24 Nov 2010	NDL	Par 23883
					app.raiseCMException1(Track_clearance_exceeded,self.id &amp; " " &amp; app.getErrorString(Exceeds_maximum_height), null, self);
				else
					app.raiseCMWarning1(Track_clearance_exceeded,self.id &amp; " " &amp; app.getErrorString(Exceeds_maximum_height),null, null, self);
				endif;
			else
				return app.getErrorString(Exceeds_maximum_height);
			endif;
		endif;
		if maxWagonWeight &lt;&gt; 0 and maxWagonWeight &lt; wagonWeight then

			if raiseWarning then
				if _asError then	//24 Nov 2010	NDL	Par 23883
					app.raiseCMException1(Track_clearance_exceeded,self.id &amp; " " &amp; app.getErrorString(Exceeds_maximum_weight), null, self);
				else
					app.raiseCMWarning1(Track_clearance_exceeded,self.id &amp; " " &amp; app.getErrorString(Exceeds_maximum_weight), null, null, self);
				endif;
			else
				return app.getErrorString(Exceeds_maximum_weight);
			endif;
		endif;
		if maxWagonWidth &lt;&gt; 0 and maxWagonWidth &lt; wagonWidth then

			if raiseWarning then
				if _asError then	//24 Nov 2010	NDL	Par 23883
					app.raiseCMException1(Track_clearance_exceeded,self.id &amp; " " &amp; app.getErrorString(Exceeds_maximum_width), null, self);
				else
					app.raiseCMWarning1(Track_clearance_exceeded,self.id &amp; " " &amp; app.getErrorString(Exceeds_maximum_width), null, null, self);
				endif;
			else
				return app.getErrorString(Exceeds_maximum_width);
			endif;
		endif;
			
	endif;
	
	return null;
	
epilog

end;</source>
        <Parameter name="_trackClearance" type="CM_TrackClearance"/>
        <Parameter name="raiseWarning" type="Boolean"/>
        <Parameter name="_asError" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="validateUnConfirmWagonIn" id="295014f5-31b0-490a-a7b3-d4e80334eda9">
        <source>validateUnConfirmWagonIn();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 June 2011	cnwndl1	Initial creation	Par 27411 - Don't allow unconfirm inwards if wagon has been worked in any way.

*/

vars

	allReceivedTIs	: CM_TIArray;
	allCurrentTis	: CM_TIArray;
	lController : CM_LocationsController;
	lTI : CM_TrackedItem;
	cargoHasChanged : Boolean;

begin

	create allReceivedTIs transient;
	self.getAllTrackedItems(true, allReceivedTIs, true);	//The items received.
	
	create allCurrentTis transient;
	//foreach lController in self.allLocationsControllers discreteLock do
	foreach lController in self.allLocationsControllersArray discreteLock do	//04 Dec 2014	NDL	Par 35345
		foreach lTI in lController.allTrackedItems discreteLock do
			if (not allCurrentTis.includes(lTI)) then
				allCurrentTis.add(lTI);
			endif;
		endforeach;
	endforeach;
	
	if allCurrentTis.size &lt;&gt; allReceivedTIs.size then
		cargoHasChanged := true;
	else
		foreach lTI in allReceivedTIs discreteLock do
			if (not allCurrentTis.includes(lTI)) then
				cargoHasChanged := true;
				break;
			endif;
		endforeach;
	endif;
	
	if cargoHasChanged then
		app.raiseCMException1(Wagon_worked_No_unconfirm,self.id, null, self);
	endif;

epilog

	delete allReceivedTIs;
	delete allCurrentTis;

end;</source>
    </JadeMethod>
    <JadeMethod name="validateUsingTrackClearance" id="90a662ee-2971-4f46-b62d-8be19e07c586">
        <source>validateUsingTrackClearance(_control : CMIF_MoveController; _trackClearance : CM_TrackClearance; _moveMode : Integer; raiseWarning : Boolean; _asError : Boolean):String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
15 July 2009	cnwndl1	Initial creation

*/

vars

	maxWagonHeight : Decimal [12,2];
	maxWagonWeight : Decimal [12,2];
	maxWagonWidth : Decimal [12,2];
	
	wagonHeight : Decimal [12,2];
	wagonWeight : Decimal [12,2];
	wagonWidth : Decimal [12,2];
	
begin

	if _trackClearance &lt;&gt; null then
	
		maxWagonHeight := _trackClearance.maxHeight;
		maxWagonWeight := _trackClearance.maxWeightWagon;
		maxWagonWidth := _trackClearance.maxWidth;
		
		self.getActualWidthAndHeight(_control, _moveMode, wagonWidth, wagonHeight);
		wagonWeight := self.getTotalWeight(_control);
		
//write method.qualifiedName() &amp; " : max wagon weight " &amp; maxWagonWeight.String &amp; " / actual " &amp; wagonWeight.String;
//write method.qualifiedName() &amp; " : max wagon height " &amp; maxWagonHeight.String &amp; " / actual " &amp; wagonHeight.String;
//write method.qualifiedName() &amp; " : max wagon width " &amp; maxWagonWidth.String &amp; " / actual " &amp; wagonWidth.String;
		
		if maxWagonHeight &lt;&gt; 0 and maxWagonHeight &lt; wagonHeight then
//write method.qualifiedName() &amp; " Warning raised : max wagon weight " &amp; maxWagonWeight.String &amp; " / actual " &amp; wagonWeight.String;
			if raiseWarning then
				if _asError then		//24 Nov 2010	NDL	Par 23883
					app.raiseCMException1(Track_clearance_exceeded,self.id &amp; " " &amp; app.getErrorString(Exceeds_maximum_height), null, self);
				else
					app.raiseCMWarning1(Track_clearance_exceeded,self.id &amp; " " &amp; app.getErrorString(Exceeds_maximum_height), null,null, self);
				endif;
			else
				return app.getErrorString(Exceeds_maximum_height);
			endif;
		endif;
		if maxWagonWeight &lt;&gt; 0 and maxWagonWeight &lt; wagonWeight then
//write method.qualifiedName() &amp; " Warning raised : max wagon height " &amp; maxWagonHeight.String &amp; " / actual " &amp; wagonHeight.String;
			if raiseWarning then
				if _asError then		//24 Nov 2010	NDL	Par 23883
					app.raiseCMException1(Track_clearance_exceeded,self.id &amp; " " &amp; app.getErrorString(Exceeds_maximum_weight), null, self);
				else
					app.raiseCMWarning1(Track_clearance_exceeded,self.id &amp; " " &amp; app.getErrorString(Exceeds_maximum_weight), null,null, self);
				endif;
			else
				return app.getErrorString(Exceeds_maximum_weight);
			endif;
		endif;
		if maxWagonWidth &lt;&gt; 0 and maxWagonWidth &lt; wagonWidth then
//write method.qualifiedName() &amp; " Warning raised : max wagon width " &amp; maxWagonWidth.String &amp; " / actual " &amp; wagonWidth.String;
			if raiseWarning then
				if _asError then		//24 Nov 2010	NDL	Par 23883
					app.raiseCMException1(Track_clearance_exceeded,self.id &amp; " " &amp; app.getErrorString(Exceeds_maximum_width), null, self);
				else
					app.raiseCMWarning1(Track_clearance_exceeded,self.id &amp; " " &amp; app.getErrorString(Exceeds_maximum_width), null,null, self);
				endif;
			else
				return app.getErrorString(Exceeds_maximum_width);
			endif;
		endif;
			
	endif;
	
	return null;
	
epilog

end;</source>
        <Parameter name="_control" type="CMIF_MoveController"/>
        <Parameter name="_trackClearance" type="CM_TrackClearance"/>
        <Parameter name="_moveMode" type="Integer"/>
        <Parameter name="raiseWarning" type="Boolean"/>
        <Parameter name="_asError" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="wagonClassCode" id="c0d5416c-7b32-4ccc-9560-4244879879c1">
        <methodInvocation>mapping</methodInvocation>
        <source>wagonClassCode(set: Boolean; _value: String io) mapping;
/*
 ------------------------------------------------------------------------
Created:			09 July 2001 by cnwdwq1
Purpose:			!     
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/
vars

begin
	if set then
		app.raiseSetVirtualError(class.name, method.name);
		return;
	endif;
	_value := null;
	if self.myWagonClass = null then
		return;
	endif;
	_value := self.myWagonClass.code;
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="zDdoFindEmptyPosition" id="b4b3e021-78c6-4b8c-85c4-c484e5be8768">
        <source>zDdoFindEmptyPosition(_tiLength : Integer) : Integer;
// ---------------------------------------------------------------------------


	//changed to z in 8.2.1 Can't find and use of this.
	// remove in later release if still here.




// Created:		June  2002 By Andrew Bishop cnwab1
//
// Purpose:		Pass in a length, i.e. how many wagon controlers does our TI need
//				Then work out if there is room for it on us

//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	thePosition : Integer;
	theController, theNextController : CM_WagonController;
	theWagonHeight, theWagonLength, theContainerLength, theLevel, theControllerPosition, idx : Integer;
begin
	if _tiLength = null then
		return null;
	endif;
	
	theWagonHeight := self.myWagonClass.maxNumInStack;
	if theWagonHeight = 0 then
		theWagonHeight := 1;
	endif;
	theWagonLength := self.myWagonClass.getLenInUnits;
	if theWagonLength = 0 then
		theWagonLength := 5;
	endif;

	foreach theLevel in 1 to theWagonHeight do
		foreach theController in self.allLocationsControllersArray do : controllerBlock
			theControllerPosition := theControllerPosition + 1;
			// is it empty?
			if not theController.allTrackedItems.isEmpty or theController.allTrackedItems[theLevel] = null then
			
				// this one is empty but what about the ones next to us?
				if _tiLength &gt; 1 then
					foreach idx in 1 to _tiLength - 1 do
						theNextController := self.allLocationsControllersArray[theControllerPosition + idx];
						if theNextController &lt;&gt; null then
							// its got something, cannot fit our TI in here, move onto the next
							if theNextController.allTrackedItems[theLevel] &lt;&gt; null then
								continue controllerBlock;
							endif;
						endif;
					endforeach;
				endif;
				return theControllerPosition;
			endif;
		endforeach;
	endforeach;

	return null;
end;</source>
        <Parameter name="_tiLength" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
</Class>
