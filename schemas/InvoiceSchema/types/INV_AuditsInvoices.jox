    <JadeMethod name="addToolbarControls" id="ff658356-60d5-49de-818c-122495dd359a">
        <updating/>
        <source>addToolbarControls() updating, protected;
// ---------------------------------------------------------------------------
// Created:		March 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

	frm				: CMUI_Toolbar;
begin	
	inheritMethod();
	frm := self.frmToolbar;
	frm.addButton(self.btnPrint, CMUI_Toolbar.Control_Alignment_Left);
	frm.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnQueryUnQual, CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnQueryQual, CMUI_Toolbar.Control_Alignment_Left);
	frm.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnQualAll, CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnQualify, CMUI_Toolbar.Control_Alignment_Left);

	frm.positionToolbarControls();
	frm.visible := true;


	frm := self.frmQualToolbar;
	frm.addButton(self.btnQualSave, CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnQualCancel, CMUI_Toolbar.Control_Alignment_Right);
	frm.positionToolbarControls();
	frm.visible := true;

end;</source>
        <access>protected</access>
    </JadeMethod>
