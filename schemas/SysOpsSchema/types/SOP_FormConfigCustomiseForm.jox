    <JadeMethod name="doMouseMove" id="81349dfd-2b5e-4e38-9742-c87805c0b103">
        <updating/>
        <source>doMouseMove(_control: Control input; button: Integer; shift: Integer; _x: Real; _y: Real)updating, protected;
// ---------------------------------------------------------------------------
// Created:     02 September 2008 by concms1:1
//
// Purpose:     User definable forms - CCMS 1011
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	
begin
	if button = 1 then
		self.dragOffsetX	:= _x;
		self.dragOffsetY	:= _y;
	
		_control.dragMode 	:= DragMode_Drag;
		_control.dragCursor	:= self.picMvInstantCur.picture;
		
		self.drawDraggingRectangle (_control, _control, _x, _y);
	endif;
epilog

end;</source>
