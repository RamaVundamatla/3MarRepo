    <JadeMethod name="getLocationForRow" id="20fc4084-6458-4c2d-8514-2c31eaa1cbe5">
        <source>getLocationForRow(): CM_LocationsController;
/*
	Created on 20 May 2008
	
	by Debby Hutchison
	
	Purpose:
	---------------------------------------------------------------------------
	05/08/2010	cnwdap1		PAR #25291 Objects in tbl_Items are CM_SOHLocation objects, NOT CM_SOHLocation 
	12/08/2010	cnwdap1		PAR #25407 Objects in tbl_Items can be CM_SOHLocation OR CM_SOHLocation 
*/

vars
	obj : Object;
	cmif : CMIF_TIGenCargo;	
	sohLoc : CM_SOHLocation;	// PAR #25291
begin
	obj := self.tbl_Items.accessRow(tbl_Items.row).itemObject;
	//if obj &lt;&gt; null then											// PAR #25407
	if obj &lt;&gt; null and CM_SOHLocation.hasInstance(obj) then			// PAR #25407
		sohLoc := obj.CM_SOHLocation;
		return sohLoc.myLocationsController;
		
	elseif obj &lt;&gt; null and CMIF_TIGenCargo.hasInstance(obj) then	// PAR #25407
		cmif := obj.CMIF_TIGenCargo;								// PAR #25407
		return cmif.myNewLocation;									// PAR #25407
	endif;
	return null;
	/* PAR #25291 what it was
	obj := tbl_Items.accessRow(tbl_Items.row).itemObject;
	
	if obj &lt;&gt;  null then
		cmif := obj.CMIF_TIGenCargo;
		return cmif.myNewLocation;
	endif;*/
end;</source>
        <ReturnType type="CM_LocationsController"/>
    </JadeMethod>
