    <JadeMethod name="aValSample" id="97ba93e9-4fa3-439e-974c-c9aa5d6a5c71">
        <source>aValSample(_pxyObject : CM_TrxTestObject; _controller : CM_TrxTestController);
// ---------------------------------------------------------------------------
// Created:     03 February 2003 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	self.raiseExceptionIfNull(_pxyObject, 'Test Object');
	
	_pxyObject.validateForUpdate(_controller);

end;</source>
        <Parameter name="_pxyObject" type="CM_TrxTestObject"/>
        <Parameter name="_controller" type="CM_TrxTestController"/>
    </JadeMethod>
    <JadeMethod name="doProformaValidation" id="273f58b8-95e9-4bed-bcf7-e55de11e7722">
        <source>doProformaValidation( 	_vvr : CM_VehicleVisitRecord input;
						_forReceival : Boolean;
						_forRelease	: Boolean;
						_allProformaLines : ObjectSet input;
						_inTranState : Boolean;
						_passport : CM_Passport input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 December 2016	cnwndl1	Initial creation	TFS 2867 - migrate part of the validation away

*/

vars
	ti		 : CM_TrackedItem;
	gteEntity 	: CMGTE_Entity;
	terminal : CM_Terminal;
	status		: Integer;
	allErrorMsgs : StringArray512;
	isError : Boolean;
	isWarning : Boolean;
	isIgnore : Boolean;
	error : String;
	exObj	: CM_Exception;
	theCargoType	: CM_CargoType;
	proformaLines : CM_InvoiceLineBySeqNumDict;
	processedTis : CM_TISet;	//11 Jan 2013	NDL	Par 30921
	tiSet : CM_TISet;	//11 Jan 2013	NDL	Par 30921
begin
	
	if _vvr = null or _vvr.allGateEntities.isEmpty  then
		return;
	endif;
	
	terminal:=_vvr.myTerminal;
	
	if not terminal.isCashOnlyEnabled then
		return;
	endif;
	
	// ### JIRA 33806 15JAN2025 NAVAB1
	if terminal.getConfig(CashOnlyInDebtOption).Integer = CashOnlyInDebtOption_NOACTION then // NO ACTION
		return;
	endif;
	
	
	create proformaLines transient;
	create allErrorMsgs transient;
	//receivals have to use the GTE entities because the VVR allReceivedTrackedItems collection is not populated at the time of validation
	
	// unfortunately for releases while the VVR has GTE_Release objects the myTI reference may not be populated if the receival was by type and the TI 
	// was assigned while in the yard
	if _forReceival then
		foreach gteEntity in _vvr.allGateEntities discreteLock do			
			if not gteEntity.isKindOf(CMGTE_Receival) then
				continue;
			endif;		
			ti:=gteEntity.getTI;
			
			// no prenote 
			if ti = null then
				//first recheck if there is a prenote
				theCargoType := app.myRoot.allCargoTypesById[gteEntity.CMGTE_Receival.cargoType];
				if theCargoType = null then
				//	allErrorMsgs.add(app.getErrorString1(REQUIRED_FIELD, 'cargo type'));
					allErrorMsgs.add(app.getErrorString(Input_required_field_cargoType)); // cnwdb2	PAR 35364
					break;
				endif;
				//check again if there is a prenote
				ti := terminal.lookupTrackedItem(gteEntity.id, theCargoType.id, TI_STATE_NOTIFIED, null, false);
				if ti = null then
					ti:=terminal.createTI(theCargoType,true);
					//create ti transient;
					ti.setPxyFromCMGTE_Receival(gteEntity.CMGTE_Receival, _passport);
				endif;
			endif;
			
			self.valCashCollectionForTI(ti,true,proformaLines,_inTranState,allErrorMsgs);	
			if _allProformaLines &lt;&gt; null then
				proformaLines.copy(_allProformaLines);
				proformaLines.clear;		
			endif;
			proformaLines.purge;
			if ti.isTransient then
				delete ti;
			endif;
		endforeach;
	endif;
	
	if _forRelease then
		create processedTis transient;
		if _vvr.allReleasedTrackedItems.isEmpty then
			foreach gteEntity in _vvr.allGateEntities discreteLock do
			
				if not gteEntity.isKindOf(CMGTE_Release) then
					continue;
				endif;
				ti := gteEntity.CMGTE_Release.myTrackedItem;
				if ti = null and gteEntity.CMGTE_Release.id &lt;&gt; null and gteEntity.CMGTE_Release.cargoType &lt;&gt; null then
					ti := gteEntity.CMGTE_Release.findCargo(gteEntity.CMGTE_Release.id, gteEntity.CMGTE_Release.cargoType);
				endif;
				if ti = null then
					continue;
				endif;
				if processedTis.includes(ti) then
						continue;
				endif;
				processedTis.add(ti);	//11 Jan 2013	NDL	Par 30921
				self.valCashCollectionForTI(ti,false,proformaLines,_inTranState,allErrorMsgs);
				//don't care about these for release;
				proformaLines.purge;
			
			endforeach;
		else
			foreach ti in _vvr.allReleasedTrackedItems discreteLock do
				processedTis.add(ti);	//11 Jan 2013	NDL	Par 30921
				self.valCashCollectionForTI(ti,false,proformaLines,_inTranState,allErrorMsgs);
				//don't care about these for release;
				proformaLines.purge;
			
			endforeach;
		endif;
		
		//11 Jan 2013	NDL	Par 30921 - catch cargo added on the fly via hand held without a release obj...
		create tiSet transient;
		_vvr.getAllLoadedCargo( tiSet );
		
		foreach ti in tiSet do
			if not processedTis.includes(ti) then
				// it was loaded to the truck during this visit
				if not _vvr.vehicle.locationsController.allTrackedItems.includes(ti) then
					continue;
				endif;
				// and is still on the truck.
				self.valCashCollectionForTI(ti,false,proformaLines,_inTranState,allErrorMsgs);
				//don't care about these for release;
				proformaLines.purge;
			endif;
		endforeach;
		
	endif;
	
	//isError:=terminal.getConfig(CashProcUnderpayIsError).Boolean;
	//30 May 2018	NDL	TFS 3852
	terminal.handleCashDebtorInDebt( isError, isWarning, isIgnore );
	if not isIgnore then
		foreach error in allErrorMsgs do
			create exObj transient;
				if isError then
					exObj.set(Cash_cargo_not_paid, error, false, null, null, null);
				elseif isWarning then
					exObj.set(Cash_cargo_not_paid, error, true, null, null, null);
				endif;
			raise exObj;
		endforeach;
	endif;

	
epilog

	if proformaLines &lt;&gt; null then
		proformaLines.purge;
	endif;
	delete proformaLines;
	delete processedTis;
	delete tiSet;
	delete allErrorMsgs;
	
end;</source>
        <Parameter name="_vvr" type="CM_VehicleVisitRecord" usage="input"/>
        <Parameter name="_forReceival" type="Boolean"/>
        <Parameter name="_forRelease" type="Boolean"/>
        <Parameter name="_allProformaLines" type="ObjectSet" usage="input"/>
        <Parameter name="_inTranState" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
