    <JadeMethod name="adjustEndXForCargoGetNumLCs" id="50d8b304-cb08-46eb-8898-bada1cb981c8">
        <updating/>
        <source>adjustEndXForCargoGetNumLCs(_theTI: CM_TrackedItem; _x1: Real io; _x2: Real io): Real updating;
// ---------------------------------------------------------------------------
// Created:		May 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// ---- WHO --- WHEN ----- WHY---------------------------------------------
// ---------------------------------------------------------------------------
//       AKB    30JUN2008     PAR 17263
// ---------------------------------------------------------------------------

vars
	numLCs   : Integer;
	lcMultiplier, tmpX : Real;
	offSet : Real;
begin
	if _theTI = null then
		return 0;
	endif;
	
	offSet := (_x2 - _x1) * 2;

	lcMultiplier := _theTI.getMultiplierForDrawing();
	_x2 := _x1 + ((lcMultiplier *  2) * (_x2 - _x1)) ;
	
	if lcMultiplier &gt; 1 then
		if self.myGridArea.flipHorizontal then
			_x1 := _x1 - offSet;
			_x2 := _x2 - offSet;
		endif;
	endif;

	return lcMultiplier;


end;</source>
        <Parameter name="_theTI" type="CM_TrackedItem"/>
        <Parameter name="_x1" type="Real" usage="io"/>
        <Parameter name="_x2" type="Real" usage="io"/>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="adjustEndXForCargoMultiStack" id="5e1c550b-b2af-4f9b-9a19-7d500e19fa97">
        <updating/>
        <source>adjustEndXForCargoMultiStack(_theTI: CM_TrackedItem; _x1: Real io; _x2: Real io): Real updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 December 2014	cnwndl1	Initial creation	Par 35346

*/

vars
	numLCs   : Integer;
	lcMultiplier, tmpX : Real;
	offSet : Real;
begin
	if _theTI = null then
		return 0;
	endif;

	if _theTI.CM_Container.is20 then
		lcMultiplier := 1;
	else
		lcMultiplier := 2;
		offSet := (_x2 - _x1) * 2;
	endif;
	
	_x2 := _x1 + ((lcMultiplier *  2) * (_x2 - _x1)) ;
	
	if self.myGridArea.flipHorizontal and lcMultiplier = 2 then
		_x1 := _x1 - offSet;
		_x2 := _x2 - offSet;
	endif;

	return lcMultiplier;


end;</source>
        <Parameter name="_theTI" type="CM_TrackedItem"/>
        <Parameter name="_x1" type="Real" usage="io"/>
        <Parameter name="_x2" type="Real" usage="io"/>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="disabledAppearance" id="585f604c-7c12-4ccf-ba02-eba5de27fea8">
        <source>disabledAppearance() : Boolean;
/*
----------   ----------  --------------------------------------------------
Created:	10 November 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	return self.myGridArea.YRD_WagonArea.disabledAppearance;

end;


</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="drawBoxcarCargo" id="99de27c7-9ef0-4b80-8872-eaf5076ddfc4">
        <updating/>
        <source>drawBoxcarCargo( _theFrame : CMUI_GridAreaFrame input; numTIs : Integer ) protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 March 2013	cnwndl1	Initial creation	Par 31278

*/

vars

	startY : Real;
	endY : Real;
	
	xOffset : Integer;
	yOffset : Integer;
	yOffsetFnt : Integer;
	xOffsetFnt : Integer;
	lFactor : Real;
	
	increment : Real;
	newY : Real;
	
	
begin

	startY 	:= self.getYPosFromIdx(1);
	endY	:= startY + self.cellHeight + 2;
	
	if not self.myGridArea.YRD_WagonArea.myWagon.confirmed then
		_theFrame.drawFillColor := YRD_WagonArea.DisabledGrey_Light;
	else
		_theFrame.drawFillColor := CM_BoxcarVisit.BoxcarDrawColour;
	endif;
	_theFrame.drawFillStyle := Frame.DrawFillStyle_Solid;
	_theFrame.drawFilledRectangle(self.x1, startY, self.x2, endY,  Black); 
	
	
	if self.isBoxcarDoor then
		//draw doors
		if not self.drawOpenDoor( _theFrame, startY ) then
			increment := ( endY - startY ) / 6;
			newY := startY + increment;
			while newY &lt; y2 do
				_theFrame.drawLine(self.x1, newY, self.x2, newY, Black);
				newY := newY + increment;
			endwhile;
		endif;
	elseif self.boxcarLocIndex.isOdd then
		_theFrame.drawLine(self.x1, startY, self.x2, endY,  Black); 
	else
		_theFrame.drawLine(self.x1, endY, self.x2, startY,  Black);
	endif;
	
	if self.boxcarLocIndex = 1 then
	
		_theFrame.drawFontName := "Arial";
		_theFrame.drawFontBold := false;
		
		lFactor := self.myGridArea.scaleXFactor;	
		if lFactor &lt; 2.5 then
			_theFrame.drawWidth := 1;
		else
			_theFrame.drawWidth := 2;
		endif;
		
		_theFrame.drawFontSize := (4 * lFactor); 
		_theFrame.fontSize := _theFrame.drawFontSize;
		_theFrame.drawTextAlign := _theFrame.DrawTextAlign_Left;
		_theFrame.drawTextAt(numTIs.String, self.x1, startY, White);
	
	endif;
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_theFrame" type="CMUI_GridAreaFrame" usage="input"/>
        <Parameter name="numTIs" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="drawBulkCar" id="e5e98736-f8f4-43da-88ec-6443ebb035d9">
        <updating/>
        <source>drawBulkCar( _theFrame : CMUI_GridAreaFrame input; numTIs : Integer; _displayMode : Integer 
															; numTIs2 : Integer; _displayMode2 : Integer
															; numTIs3 : Integer; _displayMode3 : Integer) protected, updating;
/*

Purpose:			TFS 49523

						The wagon length is based on X number of 10 foot lengths
						We draw in multiples of this unit, but we do not have to.

Return Value:		

Date		Who		Reason
4JUN2020 JLGAB1

*/

vars

	startY : Real;
	endY : Real;
	startX , endX : Real;
	
	xOffset : Integer;
	yOffset : Integer;
	yOffsetFnt : Integer;
	xOffsetFnt : Integer;
	lFactor : Real;
	numTI2Str, numTI3Str : String;
	increment : Real;
	newY : Real;
	pointsArray : RealArray;
	colour1, colour2, colour3 : Integer;
	wagonWidth, totalCols, controllerWidth, numMiddle : Integer;

begin

	if self.myGridArea.allGridPoints.first &lt;&gt; self then
		return;
	endif;
	
    self.getNumTIString(_displayMode2, numTI2Str, _displayMode3, numTI3Str);
	
	
	lFactor := self.myGridArea.scaleXFactor;	

	startY 	:= self.getYPosFromIdx(1);
	endY	:= startY + self.cellHeight;
	startX := self.x1;
	endX := self.x2;
	
	_theFrame.drawWidth := 1;
	
	totalCols := self.myGridArea.allGridColumns.size;
	controllerWidth := (endX - startX).Integer;
	wagonWidth := (controllerWidth * totalCols).Integer;
	
	if not self.myGridArea.YRD_WagonArea.myWagon.confirmed then
		_theFrame.drawFillColor := YRD_WagonArea.DisabledGrey_Light;
	else
		_theFrame.drawFillColor := CM_BoxcarVisit.BulkcarDrawColour;
	endif;
	_theFrame.drawFillStyle := Frame.DrawFillStyle_Solid;

	// ### LEFT END
	create pointsArray transient;
	pointsArray.add(startX + 2 * lFactor); pointsArray.add(startY);
	pointsArray.add(startX); pointsArray.add(startY + 2 * lFactor);
	pointsArray.add(startX + 4 * lFactor);	pointsArray.add(endY);
	pointsArray.add(endX);	pointsArray.add(endY);
	pointsArray.add(endX);	pointsArray.add(startY);
	pointsArray.add(startX + 2 * lFactor); pointsArray.add(startY);
	_theFrame.drawFilledPolygon(pointsArray,_theFrame.drawFillColor);
	
	_theFrame.drawWidth := lFactor.Integer;
	if lFactor = 4 then
		xOffset := 2;
	elseif lFactor &lt;= 1.5 then
		xOffset := 0;
	elseif lFactor &lt;= 3.5 then
		xOffset := 1;
	endif;
	_theFrame.drawLine(startX + xOffset, startY + 2 * lFactor, startX + xOffset, endY + 1,  _theFrame.drawFillColor);
	_theFrame.drawWidth := 1;
	
	pointsArray.clear;
	
	// ### MIDDLE
	numMiddle := totalCols - 2;
	
	if numMiddle &gt; 0 then
		startX := endX;
		endX := startX + (numMiddle * controllerWidth);
		
		_theFrame.drawFilledRectangle(startX, startY, endX, endY + 1,  _theFrame.drawFillColor); 
	endif;
	
	// ### RIGHT END
	startX := endX;
	endX := startX + controllerWidth;

	pointsArray.add(startX); pointsArray.add(startY);
	pointsArray.add(startX); pointsArray.add(endY);
	pointsArray.add(endX - 4 * lFactor);	pointsArray.add(endY);
	pointsArray.add(endX -1);	pointsArray.add(startY +  2 * lFactor);
	pointsArray.add(endX - 2 * lFactor);	pointsArray.add(startY);
	pointsArray.add(startX); pointsArray.add(startY);
	_theFrame.drawFilledPolygon(pointsArray,_theFrame.drawFillColor);
	
	_theFrame.drawWidth := lFactor.Integer;
	if lFactor = 4 then
		xOffset := 2;
	elseif lFactor &lt;= 1.5 then
		xOffset := 0;
	elseif lFactor &lt;= 2.5 then
		xOffset := 1;
	elseif lFactor &lt;= 3.5 then
		xOffset := 2;
	endif;
	_theFrame.drawLine(endX - xOffset, startY + 2 * lFactor, endX -  xOffset, endY + 1,  _theFrame.drawFillColor);
	_theFrame.drawWidth := 1;
	
	_theFrame.drawWidth := 1;
	_theFrame.drawLine(self.x1, startY + 2 * lFactor, endX, startY + 2 * lFactor,  Grey);
	
	// ### ACTUAL PLANNED
	_theFrame.drawFontName := "Arial";
	_theFrame.drawFontBold := false;
	
	if lFactor &lt; 2.5 then
		_theFrame.drawWidth := 1;
	else
		_theFrame.drawWidth := 2;
	endif;
	
	_theFrame.drawFontSize := (3 * lFactor); 
	_theFrame.fontSize := _theFrame.drawFontSize;
	_theFrame.drawTextAlign := _theFrame.DrawTextAlign_Left;
	
	
   self.drawNumTIs(numTIs2, numTI2Str, numTIs3, numTI3Str, _theFrame, numTIs, lFactor, self.x1+ (5 * lFactor), startY + (5 * lFactor), White);
	
	self.drawGraffitiBish(_theFrame,(totalCols - 2.5) * controllerWidth,startY + 1, wagonWidth);
	
epilog
	delete pointsArray;
end;</source>
        <access>protected</access>
        <Parameter name="_theFrame" type="CMUI_GridAreaFrame" usage="input"/>
        <Parameter name="numTIs" type="Integer"/>
        <Parameter name="_displayMode" type="Integer"/>
        <Parameter name="numTIs2" type="Integer"/>
        <Parameter name="_displayMode2" type="Integer"/>
        <Parameter name="numTIs3" type="Integer"/>
        <Parameter name="_displayMode3" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="drawGraffitiBish" id="85cdb4c2-69c1-4a2b-9029-69efa2caee21">
        <updating/>
        <source>drawGraffitiBish(  _theFrame : CMUI_GridAreaFrame input; startX : Real; startY : Real; width : Real ):Boolean updating, protected;
/*
Purpose:	TFS 49523		
Date				Who			Reason
JUNE 2020		JLGAB1 initial creation
*/



vars

	bin : Binary;
	pic : CMUI_Picture;

begin

	
	if not app.isSpecial 
	or self.myGridArea.scaleXFactor &lt; 4 
	or width &lt; 180 then
		if self.graffitiBish &lt;&gt; null then
			self.graffitiBish.visible := false;
		endif;
		return false;
	endif;
	
	if self.graffitiBish = null then
		create pic transient;
		bin := app.myRoot.getConfig(PicGraffitiBish).Binary;
		pic.width := 100;
		pic.height := 40;
		pic.stretch := 4;
		pic.picture := bin;
		pic.transparent := true;
		pic.left := startX;
		pic.top := startY;
		pic.borderStyle := Picture.BorderStyle_None;
		_theFrame.form.addControl(pic);
		pic.parent := _theFrame;
		self.setGraffitiBish(pic);
	endif;
	
	self.graffitiBish.visible := true;
	self.graffitiBish.zOrder(1);
	return true;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_theFrame" type="CMUI_GridAreaFrame" usage="input"/>
        <Parameter name="startX" type="Real"/>
        <Parameter name="startY" type="Real"/>
        <Parameter name="width" type="Real"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
