    <JadeMethod name="isCMIFDataMatch" id="cc65f69b-7ad6-45af-b942-c79372ea56d4">
        <source>isCMIFDataMatch(_cmifAutoPlan : CMIF_YAAutoPlan; _yaData: CM_YADataString): Boolean;
// -------------------------------------------
// Created 10 May 2005 by cnwdvb1
// -------------------------------------------
vars

begin

	return _cmifAutoPlan.isColour_Match(_yaData);

end;</source>
        <Parameter name="_cmifAutoPlan" type="CMIF_YAAutoPlan"/>
        <Parameter name="_yaData" type="CM_YADataString"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
