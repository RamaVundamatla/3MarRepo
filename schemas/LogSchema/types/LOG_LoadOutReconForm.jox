    <JadeMethod name="getSelectedErrors" id="1257ddf8-187b-4847-96c0-b2ef85310135">
        <source>getSelectedErrors(_intFaceLogLoad : CMIF_LogLoadOutReconDtl input);
// ---------------------------------------------------------------------------
// Created:     03 September 2002 by cnwth2
//
// Purpose:     
//
// ----------   ----------  --------------------------------------------------
vars
	row			: Integer;
	table		: CM_DataTable;
	checkValue	: String;
	loadError	: CM_LogLoadError;
begin
	table := self.tblLogError;
	foreach row in 2 to table.rows do
		checkValue := table.accessCell(row, 1).text;
		if checkValue = Row_Checked then
			if _intFaceLogLoad.mode = CMIF_LogLoadOutReconDtl.Mode_ChangeToNoNumber or
				_intFaceLogLoad.mode = CMIF_LogLoadOutReconDtl.Mode_DeleteSelected then
				_intFaceLogLoad.allLogLoadErrors.add(table.accessRow(row).itemObject.CM_LogLoadError);
			else
				loadError := table.accessRow(row).itemObject.CM_LogLoadError;
				sharedLock(loadError);
				_intFaceLogLoad.myMasterLoadError := loadError;
				_intFaceLogLoad.expectedEditionLoadError := loadError.edition;
				if loadError.myLog &lt;&gt; null then
					_intFaceLogLoad.expectedEditionLog := loadError.myLog.edition;
				endif;
				break;
			endif;	
		endif;
	endforeach;
				
end;</source>
        <Parameter name="_intFaceLogLoad" type="CMIF_LogLoadOutReconDtl" usage="input"/>
    </JadeMethod>
    <JadeMethod name="initForm" id="3d7aa89b-c6ae-4295-8899-4cb8ff444cf0">
        <updating/>
        <source>initForm() updating;
// ---------------------------------------------------------------------------
// Created:     26 August 2002 by cnwth2
//
// Purpose:     
//
// ----------   ----------  --------------------------------------------------
vars

begin
	self.setupControls();
	self.setupBOLExtDynaDict();
	self.setupLogErrorDynaDict();
	
	self.initTblBOLExt();
	self.initTblLogError();
	self.initTblData(ETDef_LoadOutReconEdit);	

	// sgp 30 May 2003 : moved to loadDataForFirstTime
//	self.loadCmbVoyages();
//	self.optEdit.click(optEdit);

	self.resize();
	
	
end;</source>
    </JadeMethod>
    <JadeMethod name="initTblBOLExt" id="98069580-f773-499f-823e-a8868fc57d28">
        <updating/>
        <source>initTblBOLExt() updating;
// ---------------------------------------------------------------------------
// Created:     26 August 2002 by cnwth2
//
// Purpose:     
//
// ----------   ----------  --------------------------------------------------
vars
	entTableDef		: EntTableDef;
begin
	self.tblBOLExt.setTerminologyRelevant(app.myRoot.allBOLTypes[BOLType_Log], self.myTerminal);
	entTableDef := app.myController.getEntTableDef(ETDef_TALoadOutReconTblOne);
	self.tblBOLExt.setTblDataEntRowsFromDef(entTableDef);
	self.tblBOLExt.selectionType := CM_BaseTable.SelectionType_Row;
	self.tblBOLExt.autoSize := Table.AutoSize_Column;
	self.tblBOLExt.userInputEnabled := false;
	tblBOLExt.accessColumn(tblBOLExt.getColumnByRowName(ETRow_NoNumber)).alignment := Table.Alignment_Right_Middle;
	tblBOLExt.accessColumn(tblBOLExt.getColumnByRowName(ETRow_Pieces)).alignment := Table.Alignment_Right_Middle;	
	tblBOLExt.accessColumn(tblBOLExt.getColumnByRowName(ETRow_PartiallyLoaded)).alignment := Table.Alignment_Center_Middle;		
end;</source>
