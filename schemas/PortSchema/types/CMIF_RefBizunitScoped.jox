    <JadeMethod name="initializeForActivity" id="9b73befe-8b24-4d52-b45e-b039dbdd18d0">
        <updating/>
        <source>initializeForActivity(_any : Any; _ewsOpsView : CM_EWSActivityOpsview) updating;
/*
Purpose:			

Date		Who		Reason
26AUG2021	NAVAB1	TFS 51853
*/

vars
	op : CM_Operator;
	carr : CM_Carrier;
	con : CM_ConsigneeConsignor;
begin
	 // ### TFS 51853 26AUG2021 NAVAB1
	self.tableName := self.Ref_bizunit_scoped;
	
	if _ewsOpsView.dataAction = BGP_OpsViewWSRequest.OPS_ACTION_DELETE then // ### TFS 53105 31MAY2022 NAVAB1
		self.gkey := self.generateFullGKey(_any, "").Integer64; // ### TFS 53105 31MAY2022 NAVAB1
		return; // ### TFS 53105 31MAY2022 NAVAB1
	endif;

	if _any.isKindOf(CM_Operator) then // ### TFS 51853 08DEC2021 NAVAB1
		op := _any.CM_Operator; // ### TFS 53569 10MAY2022 NAVAB1
		op.initializeForActivity(_ewsOpsView, self); // ### TFS 53569 10MAY2022 NAVAB1
		return;
		
	elseif _any.isKindOf(CM_Carrier) then // ### TFS 51853 08DEC2021 NAVAB1
		carr := _any.CM_Carrier; // ### TFS 53569 10MAY2022 NAVAB1
		carr.initializeForActivity(_ewsOpsView, self); // ### TFS 53569 10MAY2022 NAVAB1
		return;
	elseif _any.isKindOf(CM_ConsigneeConsignor) then // ### TFS 53105 31MAY2022 NAVAB1
		con := _any.CM_ConsigneeConsignor; // ### TFS 53105 31MAY2022 NAVAB1
		con.initializeForActivity(_ewsOpsView, self); // ### TFS 53105 31MAY2022 NAVAB1
		return;

	endif;
	
epilog

end;</source>
        <Parameter name="_any" type="Any"/>
        <Parameter name="_ewsOpsView" type="CM_EWSActivityOpsview"/>
    </JadeMethod>
</Class>
