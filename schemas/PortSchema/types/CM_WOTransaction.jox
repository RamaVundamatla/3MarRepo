    <JadeMethod name="getCargoSubTypes" id="746d1461-f35c-4af8-8016-94a9eda83187">
        <source>getCargoSubTypes():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 Jan 2023	navhl20	ChangeRequest 54350:[54269] EUP - VAS Work Orders Selector Query
08 Feb 2023 navma1  ChangeRequest 56457:[56458] EUP - Allowing different sets of cargo items per work order task [Refactor]
04 Aug 2023	navlw1	ChangeRequest 59284:[59660] EUP | FR - VAS Work Order Transactions - Fixing Duplicate Values 
*/

vars
	ti 	 	: CM_TrackedItem;
	str,
	attrStr	: String;
begin
	
	if not self.hasCargoWorkOrderDetails  then
		return null;
	endif;
	
	foreach ti in self.myWorkOrderDetail.CM_WorkOrderTIDtl.allSelectedTIs do	//08.02.2023 navma1 #56457:[56458]
		// 04.08.2023 navlw1 tfs #59284:#59660
		attrStr :=  ti.getCargoSubTypeDescr();
		
		if not str.cnContains(attrStr)then
			if str &lt;&gt; null then
				str :=  str &amp; Comma &amp; attrStr;
			
			else
				str := attrStr;
			endif;
		endif;
	endforeach;
	return str;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getCargoTypes" id="897ce9a5-f406-4c15-a664-e328db9854ab">
