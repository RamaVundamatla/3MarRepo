    <JadeMethod name="doDelete" id="8dfb6699-7a0e-45db-a099-0aeb09f5a6d7">
        <updating/>
        <source>doDelete(pObj: CM_Object io) updating;
// ---------------------------------------------------------------------------
// Created:     03 January 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	// 06 Apr 2010	NDL	Par 22342
	if pObj.pxyGetProxyObject &lt;&gt; null then
		app.raiseCMException1(ProxyAlreadyExists, pObj.getName(), null, null);
		return;
	endif;

	app.myTrxDA.trxDeleteWagonClass(pObj.CM_WagonClass, app.myPassport);

end;</source>
        <Parameter name="pObj" type="CM_Object" usage="io"/>
    </JadeMethod>
    <JadeMethod name="doEnableControls" id="ca62750b-406e-433c-ab08-553162e613a9">
        <source>doEnableControls( _enable : Boolean );

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 July 2009	cnwndl1	Initial creation

*/

vars

	theForm : SOP_TableMaintForm;
	
begin

	theForm := self.myForm;	
	
	theForm.btnNewWc.enabled := _enable;
	theForm.btnEditWc.enabled := _enable;
	
	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(null, self.permissionMaint) then
		theForm.btnNewWc.enabled := false;
	endif;
	
epilog

end;</source>
