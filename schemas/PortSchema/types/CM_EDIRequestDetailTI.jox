    <JadeMethod name="assignValueSpecial" id="19bce816-baca-414d-90b5-9146cc91b6c4">
        <updating/>
        <source>assignValueSpecial(_propName: String; _processedValue: String; _xlationOperator: CM_Operator): Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 Nov 2022	navma1	ChangeRequest 55424: MTN - Improve the performance of Edi file loading
07 Dec 2022 navma1	ChangeRequest 55783: MTN - Removing unnecessary calls for Class::getPropertyInHTree() method while setting EDI property values
//16 Jan 2024	jlirs1	TFS 61640 EUP Release Request by Type by Weight
//30 Jan 2024	jlirs1	TFS 59172 User Defined CallOff
*/

vars

begin
	if _propName = ETRow_CargoMtchClientReference then
		//self.setStringValue("cargoMatchClientReference", _processedValue);
		self.cargoMatchClientReference := _processedValue[1:30];						//07.12.2022 navma1 #55783
		return true;
	elseif _propName = ETRow_ByTypeByWeight then		//16 Jan 2024	jlirs1	TFS 61640 EUP Release Request by Type by Weight
		self.setByTypeByWeight(_processedValue.asBooleanJMT());
		return true;
	elseif _propName = ETRow_ReleaseRequestNumber then	//30 Jan 2024	jlirs1	TFS 59172 User Defined CallOff
		if self.myEDIData.isKindOf(CM_EDIDataRequestMultiLine) and
		   self.myEDIData.CM_EDIDataRequestMultiLine.myEDIDataCallOff &lt;&gt; null then
			self.releaseRequestNumber := self.myEDIData.CM_EDIDataRequestMultiLine.myEDIDataCallOff.manifestNumber;
			return true;
		endif;
	endif;
	
	return inheritMethod(_propName, _processedValue, _xlationOperator);

epilog

end;</source>
        <Parameter name="_propName" type="String"/>
        <Parameter name="_processedValue" type="String"/>
        <Parameter name="_xlationOperator" type="CM_Operator"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doTranslations" id="23826da0-8f3e-4920-8e66-b8228755bf90">
        <updating/>
        <source>doTranslations(_xlationOperator: CM_Operator) updating;
//25 Jun 2015	cnwrs1	Par 33901/36027 - Default booking commodity
// 17 Oct 2017	jlgrs1	TFS 5705 - SNO - EDIDataBooking Prenote release Req
// 19 Mar 2019	jlgrs1	TFS 41913 STWR - Reconfiguration of the EDI Operation form to better handle EDI collection locks while loading 
// 28 May 2025	naviv1	MTN-34391 - POL - EDI Data Translation - Availability Grade Temperature Issue
vars
	criteria : String;
	grade : String;
	text : String;
	code : String;
	foundMatch : Boolean;
	temp : Real;
	isZeroTemp : Boolean;
begin
	inheritMethod(_xlationOperator);
	
	grade := self.availabilityGrades;
	if grade = null then 
		return;
	endif;
	
	global.getExtraData(self.getAllExtraData, ETRow_AvailabilityGrade, text);	
	
	global.getExtraData(self.getAllExtraData, ETRow_Temperature, criteria);
	
	isZeroTemp := self.remarks.cnContains("CEL") or self.remarks.cnContains("FAH"); //MTN-34391

	if criteria = null then
		if isZeroTemp then	//MTN-34391
			temp := null;
		else
			temp := NULL_TEMPERATURE;
		endif;
		if text &lt;&gt; null then
			grade := text;
			text := null;
		endif;
	else
		temp := criteria.Real;
	endif;
	// currently there is only one MT Grade stored
	if _xlationOperator &lt;&gt; null then
		code := _xlationOperator.getXlationSystemCode_MTGrade(grade, foundMatch, temp, text); 
		if foundMatch then
			self.availabilityGrades := code;
		else
			//epr TFS 4275 8/5/17 there was something stored in the text that was different to the grade
			//and there was a temp
			if text &lt;&gt; null and text &lt;&gt; grade then
				grade := text;
				text := null;
				code := _xlationOperator.getXlationSystemCode_MTGrade(grade, foundMatch, temp, text); 
				if foundMatch then
					self.availabilityGrades := code;
				endif;
			endif;
			
		endif;
	endif;
end;
</source>
        <Parameter name="_xlationOperator" type="CM_Operator"/>
    </JadeMethod>
    <JadeMethod name="findMyEDITIHeader" id="3deb8e78-3f1b-4dfa-ba81-6e639377c239">
        <source>findMyEDITIHeader() : CM_EDIRequestHeaderTI;
//
// 05 Dec 2017	jlgrs1	TFS 8195 - SNO - EDI Release Comparison add support for ReleaseRequestMulti
// 04 Mar 2019	jlgrs1	TFS 41913 STWR - Reconfiguration of the EDI Operation form to better handle EDI collection locks while loading 
//
vars
	ediTi : CM_EDITrackedItem;
begin
	if self.myParent &lt;&gt; null and
	   self.myParent.id &lt;&gt; null and 
	   self.myParent.isKindOf(CM_EDIRequestHeaderTI) then
		return self.myParent.CM_EDIRequestHeaderTI;
	endif;
	foreach ediTi in self.myEDIData.allEDITrackedItems do
		if ediTi.isKindOf(CM_EDIRequestHeaderTI) and
		   ediTi.CM_EDIRequestHeaderTI.releaseRequestNumber = self.releaseRequestNumber then
			return ediTi.CM_EDIRequestHeaderTI;
		endif;
	endforeach;
	return null;
epilog

end;</source>
        <ReturnType type="CM_EDIRequestHeaderTI"/>
    </JadeMethod>
    <JadeMethod name="getAllAvailabilityGrades" id="3d40d3b0-1842-45bb-95b3-963e5d16b2b4">
        <source>getAllAvailabilityGrades(_allAvailabilityGrades : IntegerArray input);
//
//16 Dec 2015	cnwrs1	Par 37402 TFS 1192 MultiLine Release Request
//
vars
	allStrings : HugeStringArray;
	element : String;
	availGrade : Integer;
begin
	create allStrings transient;
	
	if self.availabilityGrades.trimBlanks() &lt;&gt; null then
		_allAvailabilityGrades.clear();
		self.availabilityGrades.trimBlanks().getHugeTokensForDelimiter(Space.Character, allStrings);
		
		foreach element in allStrings do
			if element.trimBlanks() = null then
				continue;
			endif;
			
			if element.isInteger() then
				availGrade	:=	element.Integer;
				_allAvailabilityGrades.add(availGrade);
			else
				app.raiseCMException1(Avail_Grade_Must_B_Integer, element, ETRow_AvailabilityGrades, self);
			endif;
		endforeach;
	endif;
epilog
	delete allStrings;
end;</source>
        <Parameter name="_allAvailabilityGrades" type="IntegerArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getAllStopsToApply" id="b6ec354d-d8b7-4598-8a0a-b28b8fc7c20d">
        <source>getAllStopsToApply( _stopsToApply : ObjectSet input );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 September 2016	cnwndl1	Initial creation	TFS 2646 / 2001

*/

vars
	allStrings : HugeStringArray;
	str : String;
	selectedStopTable : CM_StopsTable;
	stopTable : CM_StopsTable;
	iter : Iterator;
begin
	create allStrings transient;
	
	if self.stopsToApply.trimBlanks() &lt;&gt; null then
		_stopsToApply.clear();
		self.stopsToApply.trimBlanks().getHugeTokensForDelimiter(Space.Character, allStrings);
		
		iter := app.myRoot.allStopsTable.createIterator;
		
		foreach str in allStrings do
			if str.trimBlanks() = null then
				continue;
			endif;
			selectedStopTable := null;
			
			if str.isInteger() then
				selectedStopTable := app.myRoot.allStopsTable[str.Integer];
			else
				iter.reset();
				str := str.toUpper;
				while iter.next(stopTable) do
					if str = stopTable.code
					or str = stopTable.shortHeading
					then
						selectedStopTable := stopTable;
						break;
					endif;
				endwhile;
			endif;
			
			if selectedStopTable = null then
				app.raiseCMException1(Stops_Id_Does_Not_Exist, str, ETRow_StopsToApply, self);	//22 Sep 2016	NDL
				continue;
			endif;
			
			_stopsToApply.add(selectedStopTable);
			
		endforeach;
	endif;
epilog
	delete allStrings;
	delete iter;
end;</source>
        <Parameter name="_stopsToApply" type="ObjectSet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getByTypeByWeight" id="cb7accde-090e-473a-99ed-4babcd77685e">
