    <JadeMethod name="setOffsetFlexi" id="67403abc-99b4-4eda-921d-997772d403c5">
        <updating/>
        <source>setOffsetFlexi(_ti : CM_TrackedItem; _control : CMIF_MoveController; _check : Boolean) updating;
// ---------------------------------------------------------------------------
// Created:     18 December 2008 by cnwab1
//
//					PAR 18682 CCMS SFW 1055
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	tiLen, lcLen, taLocnLen, tmpOffset, primaryPortion, overHangPortion, offset : Integer;
	overHangLC, primLC : CM_LocationsController;
	oldOffset : Integer;
begin
	oldOffset :=self.offsetFlexi;
	if _ti = null or _control = null then
		return;
	endif;
	
	if _control.moveMode = REAL_MODE and _ti.myOSBackEndLocation = null then
		return;
	elseif _control.moveMode = QUEUE_MODE and _ti.myOSBackEndLocationQd = null then
		return;
	elseif _control.moveMode = PLANNING_MODE and _ti.myOSBackEndLocationPd = null then
		return;
	endif;
	
	if _check then
		// added this in incase have a 53 and then another container, butted up together.
		// the other container has an offset of 13 foot. When the 53 is moved away the offset stays at 13
		// When a 45 is placed where the 53 was the offset was changing to be 5
		// Added this to stop that
		if self.offsetFlexi &lt;&gt; 0 then
			return;
		endif;
	endif;
	
	tiLen := _ti.getActualLength().Integer;

	if self.myTerminalArea = null then // SLOT CONTROLLERS 
		if self.isWagon then
			taLocnLen := 10;
		else
			taLocnLen := 20;
		endif;
	else
		taLocnLen := self.myTerminalArea.locationLength.Integer;
	endif;
	// RIGHT ALIGNED YARD
	if self.myTerminalArea &lt;&gt; null and self.myTerminalArea.isRightAligned() then
		if _control.moveMode = REAL_MODE then
			overHangLC := _ti.myOSBackEndLocation;
		elseif _control.moveMode = QUEUE_MODE then
			overHangLC := _ti.myOSBackEndLocationQd;
		elseif _control.moveMode = PLANNING_MODE then
			overHangLC := _ti.myOSBackEndLocationPd;
		endif;
		
		
		if overHangLC &lt;&gt; null then
			overHangPortion := overHangLC.offsetFlexi;
		endif;
		if overHangPortion = 0 then
			overHangPortion := taLocnLen;
		endif;
		
		if _control.isShiftLeft() then
			primaryPortion := taLocnLen;
			overHangPortion := tiLen - primaryPortion;
			if overHangPortion &gt; taLocnLen then
				overHangPortion := overHangPortion - taLocnLen;
			endif;
		else
			primaryPortion := tiLen - overHangPortion;
		endif;
		if primaryPortion &gt; taLocnLen then
			primaryPortion := primaryPortion - taLocnLen;
		endif;
		
		primaryPortion := taLocnLen - primaryPortion;
		
		self.offsetFlexi := primaryPortion;
		overHangLC.offsetFlexi := overHangPortion;
	else // LEFT ALIGNED YARD AND SLOT CONTROLLERS
		if _control.moveMode = REAL_MODE then
			primLC := _ti.myPrimaryActualLocation;
		elseif _control.moveMode = QUEUE_MODE then
			primLC := _ti.myPrimaryQueuedLocation;
		elseif _control.moveMode = PLANNING_MODE then
			primLC := _ti.myPrimaryPlannedLocation;
		endif;
	
	
	
		if primLC &lt;&gt; null then
			offset := primLC.offsetFlexi;
			if offset = 0 then
				offset := primLC.getStrictOffsetForTI(_ti);
			endif;
//			primaryPortion := (taLocnLen - primLC.offsetFlexi);
			primaryPortion := (taLocnLen - offset);
		endif;
		if primaryPortion = 0 then
			primaryPortion := taLocnLen;
		endif;
//app.writeStatement( class.name &amp; '::' &amp; method.name &amp; ' 1. taLocnLen: ' &amp; taLocnLen.String &amp; "tiLen: " &amp; tiLen.String &amp; " primaryPortion: " &amp; primaryPortion.String  &amp; " offset: " &amp; offset.String); 
		
		overHangPortion := (tiLen - primaryPortion);
		if overHangPortion &gt; taLocnLen then
			overHangPortion := (overHangPortion - taLocnLen);
			if overHangPortion &gt; taLocnLen then
				overHangPortion := (overHangPortion - taLocnLen);
				if overHangPortion &gt; taLocnLen then // PAR 22750 need to keep going for wagon controller as they are only 10 foot in length
					overHangPortion := (overHangPortion - taLocnLen); // PAR 22750
					if overHangPortion &gt; taLocnLen then // PAR 22750
						overHangPortion := (overHangPortion - taLocnLen); // PAR 22750
					endif;
				endif;
			endif;
		endif;
		self.offsetFlexi := overHangPortion;
	endif;
	
	
epilog
	

	
//app.writeStatement( "AKB " &amp; self.class.name &amp; "::" &amp; method.name &amp; " 1. " &amp; self.getFullId() &amp; " " &amp; self.offsetFlexi.String);	
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_control" type="CMIF_MoveController"/>
