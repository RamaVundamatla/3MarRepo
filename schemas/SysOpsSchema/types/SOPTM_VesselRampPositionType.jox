    <JadeMethod name="setControlsForAddEdit" id="5ce97c2a-e1a2-451a-9715-50be28d68cf3">
        <updating/>
        <source>setControlsForAddEdit() updating;
/*
Date		    Who			Reason
11 April 2011	cnwas3	  Initial creation: CCMS 1031
*/

vars

theForm : SOP_TableMaintForm;

begin
  
	theForm := self.myForm;
	theForm.tblInput1.userInputEnabled := true;

	if theForm.mode = theForm.Mode_Add then
		theForm.tblInput1.clearValues;
	
		theForm.tblInput1.setFocus;
		theForm.tblInput1.moveFirst();
		
	else
		// refresh the data from the newly created proxy
		self.showThumbnail(theForm.myProxyObject.CM_VesselRampPositionType);
	
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setCtrlsForView" id="addd7fe5-62e4-4a57-aaff-3995f9535725">
