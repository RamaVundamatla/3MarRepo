    <JadeMethod name="setPxyFromTI" id="39a5d8ae-0b39-43c0-b32f-d4b57868fcf9">
        <updating/>
        <source>setPxyFromTI( _ti : CM_TrackedItem ) updating;
//Purpose:			

//Parameters:			

//Return Value:		
//Date		Who		Reason
//01 March 2010	cnwjk3	PAR 22502

vars
	childGTE 	: CMGTE_Entity;
	childTI		: CM_TrackedItem;
	gteClass	: Class;
	bookingRefItem : CM_BookingRefItem;
begin
	self.raiseExceptionIfNotTransient(method);

	self.myTerminal					:= _ti.myTerminal;
	self.myProduct					:= _ti.myProduct;
	self.myBookingRefItem   		:= _ti.myBookingRefItem;
	self.description				:= _ti.description;
	self.eirNumber					:= _ti.eirNumber;
	self.freightForwarderCode		:= _ti.freightForwarderCode;
	self.height						:= _ti.height;
	self.id							:= _ti.id;
	self.mark						:= _ti.mark;
	self.markNumber					:= _ti.markNumber;	
	self.length						:= _ti.length;
	self.width						:= _ti.width;	
	self.quantity 					:= _ti.quantity;
	self.voyageCode 				:= _ti.voyageCode;
	self.operatorCode 				:= _ti.operatorCode;
	
	self.directDelivery := _ti.directDelivery;	//31 Jan 2013	NDL	Par 31102
	
	self.clientRef					:= _ti.clientRef; //cnwrd1 par 23337 19.5.2010
	if _ti.mySubTerminal &lt;&gt; null then
		self.subTerminalCode := _ti.mySubTerminal.code;
	endif;
	
	if _ti.companyOid &lt;&gt; null then
		self.companyCode :=  _ti.companyOid.code;
	else
		self.companyCode := _ti.companyCode;
	endif;	
	//create children transient;//PAR 22954
	//_ti.getAllChildren(children);//PAR 22954
	//foreach childTI in children do
	if not self.isCMGTE_Release then	//15 Dec 2015	NDL	Par 37288 - Don't need to declare children on a release...
		foreach childTI in _ti.allChildren do //cnwsh3 - PAR25103 - allChildren collection has been unprotected reversing the need for changes from PAR22954
			gteClass := childTI.getGTEClassToCreate();
			create childGTE	as gteClass transient;
			childGTE.setPxyFromTI(childTI);
			childGTE.setParentObject(self);
		endforeach;
	endif;
	
	
	
epilog
	
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
