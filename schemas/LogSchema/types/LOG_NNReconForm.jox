    <JadeMethod name="loadCmbLots" id="bb910889-9881-47b1-9a67-37a5155d1ac2">
        <source>loadCmbLots();
// ---------------------------------------------------------------------------
// Created:     29 August 2002 by cnwth2
//
// Purpose:     
//
// ----------   ----------  --------------------------------------------------
vars
	voy		: CM_Voyage;
	logLot	: CM_LogLot;
	idx		: Integer;
begin
	voy := cmbVoyage.listObject.CM_Voyage;
	if voy = null or voy.myLogVoyageStructure = null  then
		return;
	endif;
	
	idx := 1;
	cmbLot.clear();
	cmbLot.sorted := false;
	cmbLot.listCollectionWithAny(voy.myLogVoyageStructure .allLogLots, 'lotNo');

	/*
	cmbLot.addItemAt('**Any**', idx);
	
	foreach logLot in voy.allLogLots do
		idx := idx + 1;
		cmbLot.addItemAt(logLot.lotNo, idx);
		cmbLot.itemObject[idx] := logLot;
	endforeach;

	cmbLot.listIndex := 1;
	*/
end;</source>
    </JadeMethod>
    <JadeMethod name="loadCmbOperators" id="ba4a1709-9f1a-4591-be36-65dbb6aafeb0">
        <source>loadCmbOperators();
// ---------------------------------------------------------------------------
// Created:     29 August 2002 by cnwth2
//
// Purpose:     
//
// ----------   ----------  --------------------------------------------------
vars
	voy		: CM_Voyage;
	voyOp		: CM_VoyageOperator;
	idx		: Integer;
begin
	voy := self.myFiltLogVoyage;
	if voy = null then
		return;
	endif;
	
	idx := 1;
	cmbOperator.clear();
	cmbOperator.addItemAt('**Any**', idx);
	
	foreach voyOp in voy.allVoyageIOperators do
		idx := idx + 1;
		cmbOperator.addItemAt(voyOp.myOperator.code, idx);
		cmbOperator.itemObject[idx] := voyOp;
	endforeach;
	
	cmbOperator.listIndex := 1;
end;</source>
    </JadeMethod>
    <JadeMethod name="loadDataForFirstTime" id="b1822254-ddbc-4eac-a5c3-42b7e2924aaa">
        <updating/>
        <source>loadDataForFirstTime() updating, protected;
// ---------------------------------------------------------------------------
// Created:      30 May 2003 by cnwsgp1
// ---------------------------------------------------------------------------
//19 Jan 2017	cnwrs1	TFS 3137 - resize the form when show captions is on
vars
	showCaptions : Boolean;
begin
	self.loadCmbLogVoyages();
	self.doCmbVoyageClick();
	
	//self.doUpdateOptionClick();
	self.tblData.enabled := false;
	
	self.cmbVoyage.setFocus();
	if self.frmToolbar.showCaptions then
		showCaptions := self.frmToolbar.showCaptions;
		self.frmToolbar.showCaptions := false;	 //turn it off 
		self.toolbarShowCaptions(showCaptions);	// turn back on and get sizeDeiff in toolbarShowCaptions
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="loadEntCombos" id="231a6c63-936a-47f2-9728-e7b4e467998f">
        <source>loadEntCombos();
// ---------------------------------------------------------------------------
// Created:     30 August 2002 by cnwth2
//
// Purpose:     
//
// ----------   ----------  --------------------------------------------------
vars
	logAss 	: LOG_Assistant;
	hatch	: Integer;
	lot		: CM_LogLot;
begin
	self.cmbEntPlace.clear();
	self.cmbEntHatch.clear();
	self.cmbEntPlace.clear();
	self.cmbEntRejCode.clear();
	self.cmbEntRecover.clear();
	
	if self.myFiltLogVoyage = null then
		return;
	endif;
	logAss := self.myAssistant.LOG_Assistant;
	logAss.comboBoxLogVoyageLots(cmbEntLot, self.myFiltLogVoyage, null);
	logAss.comboBoxPlace(self.tblData, ETRow_Place);
	foreach hatch in 1 to self.myFiltLogVoyage.myLogVoyageStructure.numHatches do
		self.cmbEntHatch.addItem(hatch.String);
	endforeach;	
	
	self.cmbEntPlace.addItem('Hold');
	self.cmbEntPlace.addItem('Deck');
	
	self.myAssistant.comboBoxGeneral(self.cmbEntRejCode, app.myRoot.allLogRejectCodes);
	self.myAssistant.comboBoxGeneral(self.cmbEntRecover, app.myRoot.allLogRejectRecoveryCodes);

	self.loadLogLocations();	
end;</source>
    </JadeMethod>
    <JadeMethod name="loadLogLocations" id="c4624315-058d-407f-9a93-482502c743ec">
        <source>loadLogLocations();
// ---------------------------------------------------------------------------
// Created:     02 September 2002 by cnwth2
//
// Purpose:     
//
// ----------   ----------  --------------------------------------------------
vars
	logArea			: CM_LogArea;
	logController	: CM_LogController;
	tmpLCSearch		: CMIF_SearchTypes;
	logProduct		: CM_ProductLog;
begin
	if self.myCurrentCMIFNNReconDtl = null then
		return;
	endif;
	if self.myCurrentCMIFNNReconDtl.myProductLog = null then
		return;
	else
		logProduct := self.myCurrentCMIFNNReconDtl.myProductLog;
	endif;
	
	create tmpLCSearch transient;
	
	tmpLCSearch.myOperator := logProduct.myOperator;
	tmpLCSearch.mySpecies := logProduct.myLogSpecies;
	tmpLCSearch.myGrade := logProduct.myLogGrade;
	tmpLCSearch.myType := logProduct.myLogType;
	tmpLCSearch.myTreatment := logProduct.myLogTreatment;
	tmpLCSearch.myLength := logProduct.myLogLength;
	
	self.myTerminal.availableLocationsForType(tmpLCSearch, self.allLocations, TA_TYPE_LOGAREA);
	self.myAssistant.comboBoxAddLocationsWithNull(self.cmbEntLocation, self.allLocations);

epilog
	delete tmpLCSearch;

end;</source>
    </JadeMethod>
    <JadeMethod name="loadNNDtlsMatchSpec" id="267e1f79-b4f0-426c-9acd-ebb4463d011f">
        <updating/>
        <source>loadNNDtlsMatchSpec() updating;
// ---------------------------------------------------------------------------
// Created:     05 September 2002 by cnwth2
//
// Purpose:     
//
// ----------   ----------  --------------------------------------------------
// 24/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
vars
	sohLoc			: CM_SOHLocation;
	row				: Integer;
	rowsInError,
	errorMsg		: String;
	ls,
	hasLoadError	: Boolean;
	sa		: StringArray;
	s,
	errStr	: String;
	counter : Integer;
begin

	create sa transient;

	app.cmsBeginLoad(ls);

	self.loadNNReconDetails();
	foreach row in 2 to tblLocations.rows do
		if tblLocations.accessCell(row, 1).text = Row_Checked then
			sohLoc := (tblLocations.accessRow(row).itemObject.CM_SOHLocation);
			
			self.matchSpecs(sohLoc, hasLoadError, sa);
			if hasLoadError then
				rowsInError := tblLocations.accessCell(row, 2).text &amp; ', ' &amp; rowsInError;
			endif;
		endif;
	endforeach;
	
	self.displaySummaryNNlogs();
	counter := 0;
	if (not sa.isEmpty) then
		foreach s in sa do
			if errStr = null then
				errStr := '  ' &amp; s;
			else
				errStr := errStr &amp; CrLf &amp; '  ' &amp; s;
			endif;
			counter := counter +1;
			if counter = 10 then // if there are more than 10 dockets break so the error window wont be big!
				errStr := errStr &amp; CrLf &amp; '  ....... ' &amp; CrLf &amp; '  ....... ';
				break;
			endif;
		endforeach;
		app.cmsEndLoad(ls);
		
		app.msgBox('Logs in these rows are on dockets for other voyages and' &amp; CrLf &amp;
					'are not included in the residual values' &amp; CrLf &amp; CrLf &amp; errStr,
					'Residual Values', MsgBox_OK_Only);
	endif;


	if rowsInError &lt;&gt; null then 
		errorMsg := app.getErrorString1(LogLoadError, rowsInError);
		self.displayWarning(errorMsg);
	endif;
	
epilog
	app.cmsEndLoad(ls);
	delete sa;
end;</source>
    </JadeMethod>
    <JadeMethod name="loadNNReconDetails" id="d614a28b-424c-49a1-86b7-55ad7f2ceae5">
        <updating/>
        <source>loadNNReconDetails() updating;
// ---------------------------------------------------------------------------
// Created:     29 August 2002 by cnwth2
//
// Purpose:     
//
// ----------   ----------  --------------------------------------------------
vars

begin
	self.allCMIF_LogNNReconDtls.purge();

	if self.myFiltLogVoyage &lt;&gt; null then
		self.myFiltLogVoyage.myLogVoyageStructure.getAllCMIF_LogNNReconDtls(self.myFiltLogLot, self.myFiltOperator, self.allCMIF_LogNNReconDtls);
	else
		return;
	endif;
	
	self.displaySummaryNNlogs();
end;</source>
    </JadeMethod>
    <JadeMethod name="matchSpecs" id="559c7fb8-ab50-48ee-ba28-039e27703a60">
        <source>matchSpecs(_sohLoc : CM_SOHLocation; _hasLoadError : Boolean output; _sa : StringArray input);
// ---------------------------------------------------------------------------
// Created:     05 September 2002 by cnwth2
//
// Purpose:     
//
// ----------   ----------  --------------------------------------------------
// 24/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
vars
	row			: Integer;
	table		: CM_DataTable;
	nnLog		: CMIF_LogNNReconDtl;
	pro			: CM_ProductLog;
	found		: Boolean;
	ti			: CM_TrackedItem;
	errStr		: String;
	tmpBOL		: CM_BOLOut;
begin
	//loop through and update the CMIFs
	_hasLoadError 	:= false;
	pro 			:=  _sohLoc.myProduct.CM_ProductLog;
	

	foreach nnLog in self.allCMIF_LogNNReconDtls do
	
		if nnLog.myProductLog = pro then
			foreach ti in _sohLoc.allTrackedItems do
				
				tmpBOL := ti.myReleaseBOL;
				if tmpBOL &lt;&gt; null then
					//Already on another release docket (in load out recon)
					errStr := self.getMatchSpecsErrorStr(tmpBOL, _sohLoc);
					if (not _sa.includes(errStr)) then
						_sa.add(errStr);
					endif;
					continue;
				endif;			
				if (not nnLog.myDynaDict.includes(ti.CM_Log)) then
					nnLog.myDynaDict.add(ti.CM_Log);
					if ti.getMyTotalVolume &gt; 0 then					
						nnLog.residualVolume := nnLog.residualVolume + ti.getMyTotalVolume;
					endif;
				endif;
			endforeach;
			nnLog.residualPieceCount := nnLog.myDynaDict.size;
			found := true;
			if nnLog.residualPieceCount &lt;&gt; _sohLoc.numTIs then
				_hasLoadError := true;
			endif;		
		endif;
	endforeach;
	
	if (not found) then
		create nnLog transient;
		nnLog.myOperator := _sohLoc.myOperator;
		nnLog.myProductLog := pro;
		foreach ti in _sohLoc.allTrackedItems do
			
			tmpBOL := ti.myReleaseBOL;
			if tmpBOL &lt;&gt; null then
				errStr := self.getMatchSpecsErrorStr(tmpBOL, _sohLoc);
				if (not _sa.includes(errStr)) then
					_sa.add(errStr);
				endif;
				continue;
			endif;
			if (not nnLog.myDynaDict.includes(ti.CM_Log)) then
				nnLog.myDynaDict.add(ti.CM_Log);
				nnLog.residualVolume := nnLog.residualVolume + ti.getMyTotalVolume;
			endif;
		endforeach;
		nnLog.residualPieceCount := nnLog.myDynaDict.size;
		if nnLog.residualPieceCount &lt;&gt; _sohLoc.numTIs then
			_hasLoadError := true;
		endif;							
		self.allCMIF_LogNNReconDtls.add(nnLog);	
	endif;

end;</source>
        <Parameter name="_sohLoc" type="CM_SOHLocation"/>
        <Parameter name="_hasLoadError" type="Boolean" usage="output"/>
        <Parameter name="_sa" type="StringArray" usage="input"/>
    </JadeMethod>
