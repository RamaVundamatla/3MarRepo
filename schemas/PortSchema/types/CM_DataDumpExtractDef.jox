    <JadeMethod name="getOIDCasting" id="ba0e9fdf-1740-4a67-881f-86f5dc017dda">
        <source>getOIDCasting() : String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
26 April 2010	conkc1	Initial creation

*/

vars

begin

	if self.oidFormat = CM_DataDumpExtractDef.OIDFormatHex then
		return "Binary";
	elseif self.oidFormat = CM_DataDumpExtractDef.OIDFormatString then
		return "String";
	else
		write "Not currently supported";
		return null;
	endif;
epilog

end;</source>
