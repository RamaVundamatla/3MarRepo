    <JadeMethod name="delete" id="18e09565-cd53-40f8-82ff-4557ce77e485">
        <updating/>
        <source>delete() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 December 2014	cnwmc5	Initial creation

*/

vars

begin

	self.allLogGrades.purge();
	self.allLogLengths.purge();
	self.allLogSpecies.purge();
	self.allLogTreatments.purge();
	self.allLogTypes.purge();
	self.allOperators.purge();
	
	delete self.myTerminalArea;			//cnwmc5 - 7 Jan 2015 - PAR 35446
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setProxyFromObject" id="f04d52bc-9da5-495e-87ce-ca0eea162950">
        <updating/>
        <source>setProxyFromObject(_object : CM_LocationRestriction) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 December 2014	cnwmc5	Initial creation

*/

vars
	logRestrict 	: CM_LocationRestrictLog;
	
	wsGrade			: WS_LogGrade;
	wsLength		: WS_LogLength;
	wsSpecies		: WS_LogSpecies;
	wsTreatment		: WS_LogTreatment;
	wsType			: WS_LogType;
	wsOperator		: WS_Operator;
	wsTerminalArea	: WS_TerminalAreaMaster;
	
	grade			: CM_LogGrade;
	length			: CM_LogLength;
	species			: CM_LogSpecies;
	treatment		: CM_LogTreatment;
	type			: CM_LogType;
	code			: CM_Code;
	operator		: CM_Operator;
	invalidCode 	: Boolean;
	codeString 			: String;
begin
	inheritMethod(_object);
	
	if not _object.isKindOf(CM_LocationRestrictLog) then
		return;
	endif;
	
	logRestrict := _object.CM_LocationRestrictLog;
	
	on Exception do app.handleDeletedObject(exception,code,invalidCode);
	
	foreach code in logRestrict.allLogSpecies do
		if not code.isKindOf(CM_LogSpecies) then
			continue;
		endif;
		
		codeString:= code.code;
		if invalidCode then
			invalidCode:=false;
			continue;
		endif;
		
		species := code.CM_LogSpecies;
		
		create wsSpecies transient;
		//epr par 37234 7/1/16
		wsSpecies.setProxyFromObjectBase(species);
		//wsSpecies.setProxyFromObject(species);
		self.allLogSpecies.add(wsSpecies);
	endforeach;
	
	foreach code in logRestrict.allLogLengths do
		if not code.isKindOf(CM_LogLength) then
			continue;
		endif;
		
		codeString:= code.code;
		if invalidCode then
			invalidCode:=false;
			continue;
		endif;
		
		length := code.CM_LogLength;
		
		create wsLength transient;
		//epr par 37234 7/1/16

		wsLength.setProxyFromObjectBase(length);
		//wsLength.setProxyFromObject(length);
		self.allLogLengths.add(wsLength);
	endforeach;
	
	foreach code in logRestrict.allLogTreatments do
		if not code.isKindOf(CM_LogTreatment) then
			continue;
		endif;
		
		codeString:= code.code;
		if invalidCode then
			invalidCode:=false;
			continue;
		endif;
		
		treatment := code.CM_LogTreatment;
		
		create wsTreatment transient;
		//epr par 37234 7/1/16
		wsTreatment.setProxyFromObjectBase(treatment);
		//wsTreatment.setProxyFromObject(treatment);
		self.allLogTreatments.add(wsTreatment);
	endforeach;
	
	foreach code in logRestrict.allLogTypes do
		if not code.isKindOf(CM_LogType) then
			continue;
		endif;
		
		codeString:= code.code;
		if invalidCode then
			invalidCode:=false;
			continue;
		endif;
		
		type := code.CM_LogType;
		
		create wsType transient;
		//epr par 37234 7/1/16
		wsType.setProxyFromObjectBase(type);
		//wsType.setProxyFromObject(type);
		self.allLogTypes.add(wsType);
	endforeach;
	
	foreach code in logRestrict.allLogGrades do
		if not code.isKindOf(CM_LogGrade) then
			continue;
		endif;
		
		codeString:= code.code;
		if invalidCode then
			invalidCode:=false;
			continue;
		endif;
		
		grade := code.CM_LogGrade;
		
		create wsGrade transient;
		//epr par 37234 7/1/16
		wsGrade.setProxyFromObjectBase(grade);
		//wsGrade.setProxyFromObject(grade);
		self.allLogGrades.add(wsGrade);
	endforeach;
	
	foreach operator in logRestrict.allOperators do
		create wsOperator transient;
		wsOperator.setProxyFromObject(operator);
		self.allOperators.add(wsOperator);
	endforeach;
	
	if logRestrict.myTerminalArea &lt;&gt; null then
		create wsTerminalArea transient;
		wsTerminalArea.setProxyFromObject(logRestrict.myTerminalArea);
		self.myTerminalArea := wsTerminalArea;
	endif;
	
	self.estimatedMaxVolume := logRestrict.estimatedMaxVolume;
	self.id					:= logRestrict.id;
	self.maxLogLength		:= logRestrict.maxLogLength;
	self.mixedRow			:= logRestrict.mixedRow;
	self.transportMode		:= logRestrict.transportMode;
	
epilog

end;</source>
        <Parameter name="_object" type="CM_LocationRestriction"/>
    </JadeMethod>
</Class>
