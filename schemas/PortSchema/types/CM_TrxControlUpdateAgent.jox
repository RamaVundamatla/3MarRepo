    <JadeMethod name="trxUpdateVoyageManualETMAL" id="8db70116-e617-4447-a292-6d6cbcd8cceb">
        <updating/>
        <source>trxUpdateVoyageManualETMAL(_voyage : CM_Voyage input;
							_remarks : String;
							_lengthOfStay : Decimal;
							_passport : CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 April 2018	jlger1	Initial creation 37922

*/

vars
	nextStatus,
	voyageStatus : CM_VoyageStatus;
	statusDesc : String;
	departureTS : TimeStamp;
begin
		// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);


	app.setContinueCMExceptions(false);

	voyageStatus := _voyage.getVoyageStatusObject;
	if voyageStatus = null or  voyageStatus.id &lt;&gt; Voyage_Status_VoyRequested then
		if voyageStatus &lt;&gt; null then
			statusDesc:=voyageStatus.description;
		endif;
		app.raiseCMException1(Voyag_statu_not_allow_ETMAL,statusDesc,null,null);
		return ;
	endif;
	
	beginTransaction;
	
	_voyage.setRemarks(_remarks,true);
	_voyage.setTotalTimeInPort(_lengthOfStay);
	
	if _voyage.arrivedDT.isValid then
		departureTS := _voyage.arrivedDT.addDecimalDays(_lengthOfStay);
		_voyage.setDepartureDT(departureTS);
	endif;
	
	if _voyage.myVoyageProcess = null then
		return;
	endif;

	nextStatus:= _voyage.getNextUpdateStatus(voyageStatus.id);
	if nextStatus &lt;&gt; null then
		_voyage.setStatusFromObject(nextStatus);
	endif;
	
epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_voyage" type="CM_Voyage" usage="input"/>
        <Parameter name="_remarks" type="String"/>
        <Parameter name="_lengthOfStay" type="Decimal"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
