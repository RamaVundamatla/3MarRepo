    <JadeMethod name="updateStatusWoWLE" id="4d734359-0a1f-45d9-9775-75e274dd3e06">
        <source>updateStatusWoWLE(_status : Integer;
				  _voyage     : CM_Voyage);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20/11/2022	navcs2	ChangeRequest 54344: EUP - VAS Work Orders - Jobs

*/

vars
	woJob	:	CM_Job;
	wle		:	CM_WorkListEntry;
begin
	foreach woJob in self.allJobs do
		if woJob &lt;&gt; null then
			foreach wle in woJob.workListEntries do
					if wle.CM_WOVoyageToDoWLE.myVoyage &lt;&gt; _voyage then
						continue;
					endif;
					if wle.status = JOB_COMPLETE then
						continue;
					endif;
					wle.setStatus(_status);
				endforeach;
			endif;
	endforeach;
epilog

end;</source>
        <Parameter name="_status" type="Integer"/>
        <Parameter name="_voyage" type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="validate" id="91cabeab-5291-4739-92b0-c4321b89c9e4">
        <source>validate()protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date			Who		Reason
04 October 2022	navcs2  ChangeRequest 54344: EUP - VAS Work Orders - Jobs
28 Dec 2022		navhl20	Task 56057(54344): WodToDoDetail validation
*/

vars

begin
	//Start 28.12.2022 navhl20 TFS 56057(54344)
	inheritMethod();
	if self.allVoyages.isEmpty() then
		app.raiseCMException1(Input_required_field_Required, app.getErrorString(Voyage), null, null); 
	endif;
	//End 28.12.2022 navhl20 TFS 56057(54344)
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
