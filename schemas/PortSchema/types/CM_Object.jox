    <JadeMethod name="qrySelector" id="c5996ae0-1d60-4330-ba3b-58094581c56b">
        <source>qrySelector(_criteriaLineHolder : CM_QueryCriteriaLineHolder) : Boolean;
// -----------------------------------------------------------------------------
// Created:		08 May 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
// 11/10/2022	navmd1		TFS 55110 Check criteria in priority order, not name
//
// -----------------------------------------------------------------------------
vars
	returnValue 			: Boolean;
	criteriaLine 			: CM_SelectorCriteriaLine;
	tmp : String;
	
begin

	//if _criteriaLineHolder.allCriteriaByPropertyName.isEmpty then					// TFS 55110
	if _criteriaLineHolder.allCriteriaLines.isEmpty then							// TFS 55110 Both collections are inversed, but for the sake of clarity
		return true;
	endif;
	
	//foreach criteriaLine in _criteriaLineHolder.allCriteriaByPropertyName do		// TFS 55110
	foreach criteriaLine in _criteriaLineHolder.allCriteriaLines do					// TFS 55110
		returnValue := self.qrySelectorCriteria(criteriaLine);
		if (not returnValue) then
			break;
		endif;
	endforeach;
	
	return returnValue;
end;</source>
        <Parameter name="_criteriaLineHolder" type="CM_QueryCriteriaLineHolder"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="qrySelectorCriteria" id="aef9a896-f9e5-4fb7-a717-a123a222ccf5">
        <source>qrySelectorCriteria(_criteria : CM_SelectorCriteriaLine) : Boolean ;
// -----------------------------------------------------------------------------
// Created:		08 May 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
// 25 Nov 2019 jlger1		TFS 47132 - removed protected
vars
	propValue : Any; 
	retval : Boolean;
	oper : CM_QueryOperator;
begin
	oper := _criteria.myQueryOperator;
	propValue := _criteria.myQueryProperty.getValueForObject(self, oper);

	retval := _criteria.myQueryOperator.doMatch(propValue);
	
	return retval;

end;</source>
        <Parameter name="_criteria" type="CM_SelectorCriteriaLine"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="raiseExceptionIfNotProxy" id="5a509783-0616-4992-b41c-00190e2c1e40">
        <source>raiseExceptionIfNotProxy(callingMethod : Method);
// ---------------------------------------------------------------------------
// Created:     22 February 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	mthName : String;

begin

	if self.pxyIsProxy() then
		return;
	endif;
	
	if callingMethod &lt;&gt; null then
		mthName := callingMethod.name;
	else
		mthName := "unknown method";
	endif;

	app.setContinueCMExceptions(false);
	app.raiseCMException1(NotAProxyObject, mthName &amp; '  ' &amp; self.String, null, null);

end;</source>
        <Parameter name="callingMethod" type="Method"/>
    </JadeMethod>
    <JadeMethod name="raiseExceptionIfNotTransient" id="c412a821-0db8-4aec-8b0b-877b606843d4">
        <source>raiseExceptionIfNotTransient(callingMethod : Method);
// ---------------------------------------------------------------------------
// Created:     18 January 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	mthName : String;
	
begin

	if self.isTransient then
		return;
	endif;

	if callingMethod &lt;&gt; null then
		mthName := callingMethod.name;
	else
		mthName := "unknown method";
	endif;

	app.setContinueCMExceptions(false);
	app.raiseCMException2(MethodCalledForNonTransient, mthName, self.class.String &amp; "/" &amp; self.class.name, null, null);
	
end;</source>
        <Parameter name="callingMethod" type="Method"/>
    </JadeMethod>
    <JadeMethod name="raiseExceptionIfTransient" id="e1496ba3-094d-4cb8-94f2-7bf0189177c1">
        <source>raiseExceptionIfTransient(_callingMethod : Method);
// ---------------------------------------------------------------------------
// Created:     18 January 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 08 Jan 2026  navma1 		MTN-36897 PEN - Transient File Growth in PEN Production Environment 
// ---------------------------------------------------------------------------
vars
	mthName			: String;
	callStackObj	: ProcessStackArray;
	callObj			: MethodCallDesc;
	
begin
	if not self.isTransient() then
		return;
	endif;

	if _callingMethod &lt;&gt; null then
		mthName := class.name &amp; "::" &amp; _callingMethod.name;
	else
		mthName := "unknown method";
	endif;
	
	create callStackObj transient;
	self.cnEcGetPreviousMethods(callStackObj);
	app.writeLog("Method called on transient: " &amp; mthName, LogINFO);
	app.writeLog("CallStack:", LogINFO);
	
	foreach callObj in callStackObj do
		app.writeLog(callObj.getReceiver().class.name &amp; "::" &amp; callObj.getName(), LogINFO);
	endforeach;
	
	app.setContinueCMExceptions(false);
	app.raiseCMException1(DbUpdateMthCalledForTransient, mthName, null, null);
epilog
	if callStackObj &lt;&gt; null then
		callStackObj.purge();	//08.01.2026 navma1 #MTN-36897
		delete callStackObj;
	endif;
end;</source>
        <Parameter name="_callingMethod" type="Method"/>
    </JadeMethod>
    <JadeMethod name="rebuildMyCollections" id="1175cb96-43d0-41a7-93c1-416c1ce6140d">
        <updating/>
        <source>rebuildMyCollections() updating;
// ---------------------------------------------------------------------------
// Created:     11 April 2003 by cnwrs1
//
// Purpose:     To allow serialisation of properties of each class     
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	property:Property;
	popColl:PropertyNDict;
	object: Object;
	str,message: String;
	preRebuildSize: Integer;
begin
	popColl := self.class.getProperties;
	foreach property in popColl do
		if property.isKindOf(Attribute) then
		else
			object := self.getPropertyValue(property.getName).Object;
			if not global.isValidObject(object) then
				app.writeStatement( "Invalid reference "&amp;self.class.name&amp;"::"&amp;property.getName);
				self.setPropertyValue(property.getName,null);
			endif;
			if object &lt;&gt; null then
				if object.isKindOf(CM_Object) then
				elseif object.isKindOf(Collection) then

					preRebuildSize := object.Collection.size;
					object.Collection.rebuild;
					if preRebuildSize &lt;&gt; object.Collection.size then
						app.writeStatement( "Size missmatch on "&amp;self.class.name&amp;"::"&amp;property.getName);
					endif;
				endif;
			endif;
		endif;	
	endforeach;
end;</source>
    </JadeMethod>
