<GUIClass name="CMUI_ComboCommodity" id="2376d916-49da-4221-aa35-5b368c948ed9">
    <superclass name="CMUI_ComboBoxObject"/>
    <transient/>
    <sharedTransientAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="_usergui"/>
    <JadeMethod name="displayEntry" id="b5a98315-e2fb-427b-9255-964d412c3163">
        <updating/>
        <executionLocation>client</executionLocation>
        <source>displayEntry(combobox: ComboBox input; _commodity : CM_Commodity; lstIndex: Integer): String updating, clientExecution;
// -------------------------------------------
// Created 07 September 2004 by cnwdvb1
// -------------------------------------------
vars

	 failedDAC  :CM_DataAccessController;

begin

	if _commodity = null then
		return null;
	endif;
	
	if (not _commodity.canUserAccessSelf(null, failedDAC, app.myPassport)) then
		return null;
	endif;
	
	if _commodity.isNotAvailableForEntry then
		if self.myObject &lt;&gt; _commodity then
			return null;
		else
			self.hasDirtyObject := true;
		endif;
	endif;
		
	return _commodity.code &amp; Tab &amp; _commodity.description;

end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
        <Parameter name="_commodity" type="CM_Commodity"/>
        <Parameter name="lstIndex" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getCollectionJMT" id="e88e119b-47a1-4528-8839-c25f0ec19975">
        <source>getCollectionJMT(): Collection protected;
// -------------------------------------------
// Created 30 September 2004 by cnwdvb1
// -------------------------------------------
vars

begin
	return app.myRoot.allCommodities;


end;</source>
        <access>protected</access>
        <ReturnType type="Collection"/>
    </JadeMethod>
