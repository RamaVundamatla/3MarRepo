    <DbClassMap file="_usergui"/>
    <ImplicitInverseRef name="myDragControl" id="c615ec5a-f197-4d92-8145-43e41170379d">
        <embedded/>
        <type name="Control"/>
        <access>protected</access>
    </ImplicitInverseRef>
    <JadeMethod name="mouseDown" id="35144f8e-40e6-4356-8a8d-6c4e2b23e624">
        <updating/>
        <source>mouseDown(frame : Frame input; button : Integer; shift : Integer; x : Real; y : Real) updating;
// --------------------------------------------------------------------------------
// Created:		11 August 1999 -  mouseDown
// By:			cnwdad1
//
// Purpose:		
//
// Parameters:	None
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 14 Nov 00	cnwrs2		Add if self.myDragControl = null.  Copy fix from JAS for
//							problem with lost mouseup when app focus is lost (by KPD)
// --------------------------------------------------------------------------------
vars

begin
	if (button = MouseButton_Left) then
		if self.myDragControl = null then
			self.myDragControl := self.loadControl(form.controlCount + 1);
		endif;
		
		self.myDragControl.visible	:=	true;
		self.myDragControl.move(self.left, self.top, self.width, self.height);
		self.myDragControl.JSSVerticalSplitter.caption	:=	'';
		self.myDragControl.zOrder(1);
	endif;

	inheritMethod(frame, button, shift, x, y);
end;</source>
        <Parameter name="frame" type="Frame" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="mouseMove" id="643f127f-513c-4b21-8b48-4b4578a6ded5">
        <updating/>
        <source>mouseMove(frame : Frame input; button : Integer; shift : Integer; x : Real; y : Real) updating;
// --------------------------------------------------------------------------------
// Created:		11 August 1999 -  mouseMove
// By:			cnwdad1
//
// Purpose:		
//
// Parameters:	None
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars

begin
	if (button = MouseButton_Left) then
		if (self.myDragControl &lt;&gt; null) then
			self.myDragControl.move((self.left + x), self.myDragControl.top, self.myDragControl.width, self.myDragControl.height);
		endif;
	endif;

	inheritMethod(frame, button, shift, x, y);
end;</source>
        <Parameter name="frame" type="Frame" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="mouseUp" id="f92b13e0-7191-4197-9028-4c5fcf931769">
        <updating/>
        <source>mouseUp(frame : Frame input; button : Integer; shift : Integer; x : Real; y : Real) updating;
// --------------------------------------------------------------------------------
// Created:		11 August 1999 -  mouseUp
// By:			cnwdad1
//
// Purpose:		
//
// Parameters:	None
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars

begin
	if (button = MouseButton_Left) then
		if (self.myDragControl &lt;&gt; null) then
			self.move(self.myDragControl.left, self.top, self.width, self.height);
			delete self.myDragControl;
			self.visible	:=	true;
			self.zOrder(1);
//			self.parent.cnEc_MouseUp(self, button, shift, x, y);
			self.parent.sendMsgWithParams("mouseUp", self, button, shift, x, y);
		endif;
	endif;

	inheritMethod(frame, button, shift, x, y);
end;</source>
        <Parameter name="frame" type="Frame" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="windowCreated" id="69667e64-b5bf-4d6a-bc0d-1f5d13e9c012">
        <updating/>
        <source>windowCreated(cntrl : Control input; persistCntrl : Control) updating;
// --------------------------------------------------------------------------------
// Created:		11 August 1999 -  windowCreated
// By:			cnwdad1
//
// Purpose:		
//
// Parameters:	None
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars

begin
	self.height				:=	self.parent.height;
	self.borderStyle		:=	BorderStyle_None;
	self.bevelInner			:=	Bevel_None;
	self.bevelInnerWidth	:=	0;
	self.bevelOuter			:=	Bevel_Raised;
	self.bevelOuterWidth	:=	1;
	self.boundaryBrush		:=	BoundaryBrush_Solid;
	self.boundaryWidth		:=	0;
	self.caption			:=	'';
	self.width				:=	5;
	self.mousePointer		:=	MousePointer_WE;
	inheritMethod(cntrl, persistCntrl);
end;</source>
        <Parameter name="cntrl" type="Control" usage="input"/>
        <Parameter name="persistCntrl" type="Control"/>
    </JadeMethod>
