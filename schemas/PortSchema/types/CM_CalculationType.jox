    <JadeMethod name="isUsingBlock" id="af794e8f-21cb-465e-81d8-d23fc93c5971">
        <source>isUsingBlock() : Boolean;
/*

Purpose:			calculation types that get a quantity and then multiple that by a second 'block unit'.

Parameters:			

Return Value:		

Date		Who		Reason
13 September 2017	jlgab1	Initial creation

*/

vars

begin

	// these are 'days' multiplied by a cargo value.
	if self.calculationType = INV_CALC_TYPE_DAYS_WEIGHT 
	or self.calculationType = INV_CALC_TYPE_DAYS_VOLUME 
	or self.calculationType = INV_CALC_TYPE_DAYSINCE_REC_RT	//08 May 2018	NDL	TFS 38525
	or self.calculationType = INV_CALC_TYPE_DAYSINCE_REC_TEU then
	
		return true;
	endif;
	
	if self.theCalcTypeUnit &gt; 0 then
		return true;
	
	endif;
	
	return false;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
