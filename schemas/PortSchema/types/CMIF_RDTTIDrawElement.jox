    <JadeMethod name="highlightGridHeight" id="59806b8e-9f6c-42f1-8ee0-1a411f8909e5">
        <source>highlightGridHeight(_frame : Frame input; _x1,_y1,_x2,_y2 : Integer; _scaleFactor : Real) protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 March 2011	#cnwdz2	 ccms 2005 par25644

*/
vars
	picture,
	pictureTop,
	pictureLeft,
	pictureBottom,
	pictureRight    : Picture;
	
begin
	picture := _frame.form.IF_RDTYardForm.getPicHighlightVBar();
	// left
	_frame.drawPictureIn(picture.picture, _x1, _y1, _x1+4, _y2);
	/*
	create pictureLeft;
	pictureLeft.parent := _frame;
	pictureLeft.picture := picture.picture;
	pictureLeft.width := 4;
	pictureLeft.height := _y2 - _y1;
	pictureLeft.left := _x1;
	pictureLeft.top := _y1;
	pictureLeft.stretch := Picture.Stretch_CenterPicture;
	_frame.form.addControl(pictureLeft);
	//
	*/	
	// right
	_frame.drawPictureIn(picture.picture, _x2-4, _y1, _x2, _y2);
	/*
	create pictureRight;
	pictureRight.parent := _frame;
	pictureRight.picture := picture.picture;
	pictureRight.width := 4;
	pictureRight.height := _y2 - _y1;
	pictureRight.left := _x2-4;
	pictureRight.top := _y1;
	pictureRight.stretch := Picture.Stretch_CenterPicture;
	_frame.form.addControl(pictureRight);
	
	*/
	
	picture := _frame.form.IF_RDTYardForm.getPicHighlightHBar();	
	//top
	_frame.drawPictureIn(picture.picture, _x1, _y1, _x2, _y1+4);
	/*
	create pictureTop;
	pictureTop.parent := _frame;
	pictureTop.picture := picture.picture;
	pictureTop.width := _x2 - _x1;
	pictureTop.height := 4;
	pictureTop.left := _x1;
	pictureTop.top := _y1;
	pictureTop.stretch := Picture.Stretch_CenterPicture;
	_frame.form.addControl(pictureTop);
*/
	// bottom
	_frame.drawPictureIn(picture.picture, _x1, _y2-4, _x2, _y2);
	/*
	create pictureBottom;
	pictureBottom.parent := _frame;
	pictureBottom.picture := picture.picture;
	pictureBottom.width := _x2 - _x1;
	pictureBottom.height := 4;
	pictureBottom.left := _x1;
	pictureBottom.top := _y2-4;
	pictureBottom.stretch := Picture.Stretch_CenterPicture;
	_frame.form.addControl(pictureBottom);
	//_frame.drawPictureIn(picture.picture, _x1, _y2-4, _x2, _y2);
	*/	
epilog
	
end;</source>
