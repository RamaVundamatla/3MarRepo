/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 July 2018	jlgrh7	Initial creation TFS39468 STWO - Issue with moving vessels to berth ANCHOR

*/

vars

begin
	self.sternMarkTo := _stermMark;
epilog

end;</source>
        <Parameter name="_stermMark" type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="setTidalClass" id="aea977b0-75f7-4700-bf48-462a952c52ba">
        <updating/>
