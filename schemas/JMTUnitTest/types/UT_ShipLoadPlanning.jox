    <JadeMethod name="unitTestBefore" id="468feca8-f7cc-49b0-aa90-20ea6f69a416">
        <source>unitTestBefore()  protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
30 July 2009	cnwer1	Initial creation

*/

vars
	voyage : CM_Voyage;
	jobSheet : CM_VoyageJobSheet;
	job : CM_VoyageJob;
begin
	
	voyage := self.getVoyage(self.getVoyageName);
	self.assertNotNullMsg(voyage, "Voyage PTNUTSP is null");
	jobSheet:=voyage.allJobSheets[self.getCraneID];
	self.assertNotNullMsg(jobSheet, "Job sheet for crane J10 does not exist for voyage PTNUTSP");
	
	//there's only one job
	job:=self.getJob;
	self.assertNotNullMsg(job, "No jobs exist for voyage PTNUTSP");
	//needs to be Unactioned
	
	self.assertEqualMsg(job.status ,JOB_UNACTIONED, "Job status not UNACTIONED");
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
