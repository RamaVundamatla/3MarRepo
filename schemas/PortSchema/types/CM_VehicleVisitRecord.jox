    <JadeMethod name="setDwellTime" id="599580bd-e0fc-4b91-bb0c-2ce4101d6ba0">
        <updating/>
        <source>setDwellTime(_time : Integer) updating;
/*
Purpose:			

Date		Who		Reason
24 August 2006	cnwer1	Initial creation - PAR#xxxx

// PAR 16390 - changes for dwell to minutes and tidy up

*/
vars

begin
	if self.dwellTimeMinutes &lt;&gt; _time then
		self.dwellTimeMinutes := _time;
	endif;

epilog

end;</source>
        <Parameter name="_time" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setErrorsFromPassport" id="434b0eb1-a0d4-4333-b32e-3d167a7351f4">
        <updating/>
        <source>setErrorsFromPassport(_passport : CM_Passport; _gateEntity : CMGTE_Entity) updating;
// ---------------------------------------------------------------------------
// Created:     08 September 2008 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	tranNum : String;
	err : CM_Error;
	vvError : CM_ErrorPersistent;
begin
	tranNum := self.visitNumber;
	
	foreach err in _passport.allErrorWarnings discreteLock do : outerLoop
		// NO DUPLICATES
		foreach vvError in self.allErrorsWarningsByTranNum discreteLock do
			if vvError.text = err.text then
				continue outerLoop;
			endif;
		endforeach;
		
		create vvError;
		
		vvError.init(self, tranNum, _gateEntity);
		vvError.setFromError(err);

		self.addError(vvError);
	endforeach;

epilog
end;</source>
        <Parameter name="_passport" type="CM_Passport"/>
        <Parameter name="_gateEntity" type="CMGTE_Entity"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="70b0cb77-2c34-40c4-bf6e-efadf98dad0c">
        <updating/>
        <source>setForCreate(_dwellTime : Integer; _numTIsIn, _numTIsOut : Integer;
			 _timeIn, _timeOut : TimeStamp;
			 _transferAreaId : String; _vehicle : CM_Vehicle;
			 _carrierCode, _gate, _driver, _gatePass, _workNumber, _clerk, _loadingCompanyCode, _jobNumber, _remarks : String;
			 _releasedTIs : CM_TISet; _receivedTIs : CM_TISet; _terminal : CM_Terminal) updating;
/*
------------------------------------------------------------------------
Created:			08 July 2003 by cnwdwq1
Purpose:			Dave Q's code
Changed On		Changed By		Reason
------------	------------	-----------------------------------------
18 Jun 2013		cnwcs5			par 31670 - new _context parameter for createVehicleVisitDetail method------------------------------------------------------------------------
22/06/2017		cnwdap1			TFS 4912 Expose Additional Report Attributes
20/06/2024		jlizm1			TFS 63908 Allow duplicate driver names
*/
vars
	vvrDetail 	: CM_VehicleVisitRecordDetail;
begin
	self.dwellTimeMinutes := _dwellTime;		// PAR 16390
	self.numTIsIn := _numTIsIn;
	self.numTIsOut := _numTIsOut;
	self.timeIn := _timeIn;
	self.timeOut := _timeOut;
	self.transferAreaId := _transferAreaId;
	self.vehicle := _vehicle;
	
	self.setMyTerminal(_terminal);
//	if self.vehicle &lt;&gt; null then
//		self.setMyTerminal(_vehicle.myTerminal);
//	endif;
	// New field for PASHA bulk release
	self.carrierCode := _carrierCode;
	self.departureGate := _gate;
	self.driverCode := _driver;
	
	//cnwrd1 ccms 1862 par 27435 2.5.2011
	if _gatePass &lt;&gt; null then
		self.visitNumber := _gatePass;
	else
		self.visitNumber := _terminal.getNextGateTransactionNumber();
	endif;
	
	self.loadingCompanyCode := _loadingCompanyCode;
	self.remarks := _remarks;
	self.verificationNumber := _workNumber;
	self.verifiedByUserCode := _clerk;
	self.jobNumber := _jobNumber;
	
	if _releasedTIs &lt;&gt; null then
		self.allReleasedTrackedItems.clear();
		_releasedTIs.copy(self.allReleasedTrackedItems);
	endif;
	
	if _receivedTIs &lt;&gt; null then
		self.allReceivedTrackedItems.clear();
		_receivedTIs.copy(self.allReceivedTrackedItems);
	endif;

	if self.myTerminal &lt;&gt; null then
		self.myDriverDetails := self.myTerminal.findDriver(_driver);
	endif;
	
	// PAR 17703
	if self.myDriverDetails &lt;&gt; null then
		if self.driversName = null then
			self.driversName := self.myDriverDetails.name;
		endif;
		//if self.secondaryCode.trimBlanks() = null then					// TFS 4912
		//	self.secondaryCode := self.myDriverDetails.secondaryCode;		// TFS 4912
		//endif;															// TFS 4912
		if self.driverCode.trimBlanks() = null then
			self.driverCode := self.myDriverDetails.code;
		endif;
	endif;
	
	// CCMS1035 cnwjk3 - Set initial status to unverified 
	self.changeStatus(self.Status_Unverified);
	
	//cnwrd1 ccms 1862 par 27435 2.5.2011 - this isnt going to work because we dont have a gatelanecontroller?!
	vvrDetail := self.createVisitRecordDetail(VisitRecord_Create, self.myGateLaneController, null);	// par 31670 
	
end;</source>
        <Parameter name="_dwellTime" type="Integer"/>
        <Parameter name="_numTIsIn" type="Integer"/>
        <Parameter name="_numTIsOut" type="Integer"/>
        <Parameter name="_timeIn" type="TimeStamp"/>
        <Parameter name="_timeOut" type="TimeStamp"/>
        <Parameter name="_transferAreaId" type="String"/>
        <Parameter name="_vehicle" type="CM_Vehicle"/>
        <Parameter name="_carrierCode" type="String"/>
        <Parameter name="_gate" type="String"/>
        <Parameter name="_driver" type="String"/>
        <Parameter name="_gatePass" type="String"/>
        <Parameter name="_workNumber" type="String"/>
        <Parameter name="_clerk" type="String"/>
        <Parameter name="_loadingCompanyCode" type="String"/>
        <Parameter name="_jobNumber" type="String"/>
        <Parameter name="_remarks" type="String"/>
        <Parameter name="_releasedTIs" type="CM_TISet"/>
        <Parameter name="_receivedTIs" type="CM_TISet"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="setForCreateFlexi" id="1fc4af8f-ba7c-40fe-8035-aafdc360523c">
        <updating/>
        <source>setForCreateFlexi(_proxy : CM_VehicleVisitRecord; _batNumber : String) updating;
// ---------------------------------------------------------------------------
// Created:     04 November 2008 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
// 19/05/2009		concms1			Par 19715 - VVRD updating
// 15/09/2009		cnwcs1			ccms 1061 - change VVRD from 'complete a-gate' to create
// 10/06/2013		cnwcs5			par 31690 - use server timestamp NOT local timestamp
// 18 Jun 2013		cnwcs5			par 31670 - new _context parameter for createVehicleVisitDetail method
// 15/10/12		cnwer1				par 32445 removed allContainer lengths
// 17/12/2013		cnwdap1			PAR #32849 CCMS PEN 2321 Security Gate - create different vehicle visit detail
// 25/02/2014		cnwdap1			PAR #33582 set up regnumber and carrier when we don't have a vehicle
// 12/03/2014		cnwdap1			PAR #33639 Align times for visit details with vehicle visit time for security gate visits
// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
// 06/12/2016 cnwrh7	TFS	3032
// 27 Feb 2018		cnwma1 			ChangeRequest 36813: PEN - Gen Sets, Chassis &amp; Reefers
// 12/02/2022		navdap1			TFS 52268 AAT 1-Stop VBS Integration
// 13/05/2022 		navhl20 		TFS 53430  EUP - Sub Carrier registration in MTN
// 07Dec2022		navsp1			TFS ChangeRequest 55580: EUP - Inspection App checks - Interface and MTN changes
// 15/05/2023		navdap1			TFS 54049 Changes to inerses between CM_VehicleVisitRecord and CM_VehicleBookingTimeSlot
// 08 Feb 2024 		navhl20 		ChangeRequest 62084:[62379] EUP | Retrospective Operations - [54177.010] - Road Entry
// 14/06/2024		jlizm1			TFS 63908 Allow duplicate driver names
// 17 Oct 2024 		navsck1 		MTN-19665 EUP |  Kiosk -save truck visit on final confirmation webservice
// ---------------------------------------------------------------------------

vars
	vvrDetail 	: CM_VehicleVisitRecordDetail;
	chassis   	: CMGTE_Entity;	
	bat			: CM_RFIDTag;										// PAR #32849
	reg			: String;											// PAR #33582
	pos			: Integer;											// PAR #33582
	timeIn		: TimeStamp;										// PAR #33639
	time		: Time;												// PAR #33639
	
	pxyGTEItem,
	realGTEItem		: CMGTE_Entity;
	pxyChildGTEItem,
	realChildGTEItem : CMGTE_Entity;
	realGTEGen,pxyGTEGen : CMGTE_Entity;
	generator, tmpEntity : CMGTE_Entity;
	justATrailer : Boolean;
	tmpTimeIn : TimeStamp;	//07 Oct 2020	NDL	TFS 49189
	tsi : TimeStampInterval;	//07 Oct 2020	NDL	TFS 49189
	tranNum : String;
begin
	self.timeIn 				:= app.actualTimeServer;			// par 31690 June 2013// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	self.myDriverDetails 		:= _proxy.myTerminal.findDriver(_proxy.driverCode);
	self.vehicle				:= _proxy.myTerminal.vehicles[_proxy.regNumber, _proxy.state];	
	self.carrierCode 			:= _proxy.carrierCode;
	self.subCarrierCode			:= _proxy.subCarrierCode;				//13/05/2022 navhl20 TFS 53430	
	self.driversName 			:= _proxy.driversName;
	self.driverCode 			:= _proxy.driverCode;
	//self.regNumber 				:= _proxy.regNumber;											//-TFS3032		
	self.regNumber 		:= _proxy.regNumber.removeTabCrLfs();				//+TFS3032
	self.state 					:= _proxy.state;
	self.remarks 				:= _proxy.remarks;
	self.transferAreaId 		:= _proxy.transferAreaId;
	self.myGateIn 				:= _proxy.myGateIn;
	self.myGateLaneController 	:= _proxy.myGateLaneController;
	self.visitType				:= _proxy.visitType;								// PAR #32849
	self.gateInCheckStatus		:= _proxy.gateInCheckStatus;	//15Dec2022 navsp1 TFS 55580
	self.gateInCheckTS			:= _proxy.gateInCheckTS;		//15Dec2022 navsp1 TFS 55580
	self.gateOutCheckStatus		:= _proxy.gateOutCheckStatus;	//15Dec2022 navsp1 TFS 55580
	self.gateOutCheckTS			:= _proxy.gateOutCheckTS;		//15Dec2022 navsp1 TFS 55580
	
	if _proxy.visitNumber &lt;&gt; null then
		self.visitNumber := _proxy.visitNumber;
	else
		self.visitNumber := _proxy.myTerminal.getNextGateTransactionNumber();		// 08/11/2010 cnwmh5 #26250
	endif;
	
	self.myTerminal 		:= _proxy.myTerminal;						// 08/11/2010 cnwmh5 #26250
	self.verifiedByUserCode := app.myPassport.getUserCode();
	self.remarks 			:= _proxy.remarks;
	self.ownerTrailerID 	:= _proxy.ownerTrailerID;
	// TFS 54049 changes to inverses
	//if _proxy.myVehicleBookingTimeslot &lt;&gt; null then						//14Dec2022 navsp1 TFS 55580
	//	self.myVehicleBookingTimeslot := _proxy.myVehicleBookingTimeslot; 
	//endif;
	if not _proxy.allVehicleBookingSlots.isEmpty then
		_proxy.allVehicleBookingSlots.copyNoDuplicates(self.allVehicleBookingSlots, false);
	endif;
	// TFS 54049 end
	self.setAutoComplete(_proxy.isRoadJobAutoComplete);///autocompletecnwas3
	self.setIsUpdatable(true);
	
	//if _proxy.isRoadJobAutoComplete then
	if _proxy.isRoadJobAutoComplete or ( _proxy.myTerminal &lt;&gt; null and _proxy.myTerminal.roadProcessIsASPA ) then	//06 Oct 2020	NDL	TFS 49189
		//If the time off the screen is captured it is only unique to the minute, protect against duplicates
		tmpTimeIn := _proxy.timeIn;
		if self.vehicle &lt;&gt; null then
			while self.vehicle.visitRecords.getAtKey( tmpTimeIn ) &lt;&gt; null do
				tsi.set(0,60000); // 1 minute
				tmpTimeIn := tmpTimeIn + tsi;
			endwhile;
		endif;
		self.timeIn := tmpTimeIn;
	endif;
	
	if self.myTerminal.getConfig(IsRetrospectiveMode).Boolean then						//08.02.2023 navhl20 #62084[62379]
		if _proxy.timeIn.isValid and _proxy.timeIn &lt; app.actualTimeServer then
			self.timeIn := _proxy.timeIn;
			self.retrospectiveDT := _proxy.timeIn;
		endif;
	endif;
	
	self.changeStatus(self.Status_Unverified);
	
	self.set1StopBookingsFromProxy(_proxy);				// TFS 52268
	
	// PAR #32849 if terminal is set up for a security gate, create a "Security Gate Arrival" detail
	if self.myTerminal.getConfig(SiteHasSecurityGate).Boolean and self.visitType = self.VisitType_SecurityGate then	// PAR #32849
		// set time in to the value on the proxy					// PAR #33639
		self.timeIn := _proxy.timeIn;								// PAR #33639
		vvrDetail := self.createVisitRecordDetail(VisitRecord_ArriveSecurityGate, _batNumber, null);				// PAR #32849
		vvrDetail.setTimeForSecurityGateExit(_proxy.timeIn);		// PAR #33639
		// mark the bat number as not available for entry temporarily, so no one else can use it					// PAR #32849
		bat := self.myTerminal.allRFIDTagsByCode[_batNumber];														// PAR #32849
		if bat &lt;&gt; null then																							// PAR #32849
			// create an "Assign Bat Number" detail																	// PAR #32849
			vvrDetail := self.createVisitRecordDetail(VisitRecord_AssignRFIDTag, bat, null);						// PAR #32849
			// PAR #33639 Make sure BAT detail is dated after Arrival detail		// PAR #33639
			timeIn.setDate(_proxy.timeIn.Date);										// PAR #33639
			time.setTime(_proxy.timeIn.Time.hour, _proxy.timeIn.Time.minute, 1, 0);	// PAR #33639
			timeIn.setTime(time);													// PAR #33639
			vvrDetail.setTimeForSecurityGateExit(timeIn);							// PAR #33639
			global.causeEvent(self.myTerminal.getTerminalEvent(Event_RFIDTagInUse), false, bat);					// PAR #32849
			bat.setIsAvailableForEntry(false);																		// PAR #32849
		endif;																										// PAR #32849
		// if we don't have a registration number here, create a dummy one							// PAR #33582
		if self.vehicle = null then
			//epr par 36362 16/6/15
			if self.regNumber = null then																	// PAR #33582
				reg := self.getOidString;																// PAR #33582
				pos := reg.pos(".", 1);																	// PAR #33582
				reg := Unknown_Truck_Prefix &amp; reg[pos+1:end].padLeadingZeros(9);						// PAR #33582
				self.regNumber := reg;																	// PAR #33582
			endif;
			self.carrierCode := NULL_CARRIER_CODE;													// PAR #33582
		endif;																						// PAR #33582
	else																											// PAR #32849
		if _proxy.myTerminal &lt;&gt; null and _proxy.myTerminal.roadProcessIsASPA then	//06 Oct 2020	NDL	TFS 49189
			vvrDetail := self.createVisitRecordDetail(VisitRecord_Create, self.myGateLaneController, self.timeIn);
		else
			vvrDetail := self.createVisitRecordDetail(VisitRecord_Create, self.myGateLaneController, null);	// par 31670 cnwcs5 15/09/2009
		endif;
	endif;																											// PAR #32849
	
	if _proxy.myInCMGTE_Chassis &lt;&gt; null then
		create chassis as _proxy.myInCMGTE_Chassis.class persistent;

		chassis.setForCreate(_proxy.myInCMGTE_Chassis, self); // will add to real VVR's myInCMGTE_Chassis
		//27.02.2018 cnwma1 ChangeRequest #36813
		if not _proxy.myInCMGTE_Chassis.allChildren.isEmpty then
			if _proxy.myInCMGTE_Chassis.allChildren.first.isKindOf(CMGTE_Generator) then
				create realGTEGen as CMGTE_Generator persistent;
					realGTEGen.setParentObject(chassis);	
					realGTEGen.setForCreate(_proxy.myInCMGTE_Chassis.allChildren.first.CMGTE_Generator, self);
			endif;
		endif;
		
		
		if _proxy.myInCMGTE_Chassis &lt;&gt; null and _proxy.myInCMGTE_Chassis.allChildren.size = 1 then	
			generator := _proxy.myInCMGTE_Chassis.allChildren.first;
			justATrailer := false;
			foreach tmpEntity in _proxy.allGateEntities do
				if tmpEntity = generator or tmpEntity = _proxy.myInCMGTE_Chassis then
					justATrailer := true;
				else
					justATrailer := false;
					break;
				endif;
			endforeach;
			if justATrailer then
				self.setIsUpdatable(false);
			endif;
		endif;
		//27.02.2018 cnwma1 ChangeRequest #36813
	endif;
	
	if _proxy.myOutCMGTE_Chassis &lt;&gt; null then
		create chassis as _proxy.myOutCMGTE_Chassis.class persistent;
		
		chassis.setForCreate(_proxy.myOutCMGTE_Chassis, self); // will add to real VVR's myOutCMGTE_Chassis
		//27.02.2018 cnwma1 ChangeRequest #36813
		if _proxy.myOutCMGTE_Chassis &lt;&gt; null and _proxy.myOutCMGTE_Chassis.allChildren.size = 1 then	
			generator := _proxy.myOutCMGTE_Chassis.allChildren.first;
			justATrailer := false;
			foreach tmpEntity in _proxy.allGateEntities do
				if tmpEntity = generator or tmpEntity = _proxy.myOutCMGTE_Chassis then
					justATrailer := true;
				else
					justATrailer := false;
					break;
				endif;
			endforeach;
			if justATrailer then
				self.setIsUpdatable(false);
			endif;
		endif;
		//27.02.2018 cnwma1 ChangeRequest #36813
		
	endif;
	
	//07Dec2022 navsp1 TFS 55580
	if self.myVehicleBookingTimeslot &lt;&gt; null then
		if self.gateInCheckStatus = null then
			if self.myVehicleBookingTimeslot.preGateInCheck then
				self.gateInCheckStatus := self.InspectionPending;
			else
				self.gateInCheckStatus := self.InspectionNA;
		  endif;
		endif;
		if self.gateOutCheckStatus = null then
			if self.myVehicleBookingTimeslot.preGateOutCheck then
				self.gateOutCheckStatus := self.InspectionPending;
			else
				self.gateOutCheckStatus := self.InspectionNA;
			endif;
		endif;
	endif;

	//cnwmc5 - 20 Jan 2015 - CCMS 2435
	//Needed for the web service because we need to create everything in one TRX. 
	//In JMT, the realVVR is already created before it trys to add the GTE Entities so it always hits update.
	//This means there was no code to handle creating GTE Entities from one single create.
	
	//19 May 2025	jlier1	MTN-34221 refactoring validation so is before trx - this can be done for everyone - save calling extra trxs
	
	foreach pxyGTEItem in _proxy.allGateEntities  discreteLock do
						// #navsck1 17/10/24 19665
			if (pxyGTEItem.isChassisIn or pxyGTEItem.isChassisOut) then
				continue;
			endif;				
			tranNum:=null;																																					// #navsck1 17/10/24 19665
			create realGTEItem as pxyGTEItem.class persistent;
			realGTEItem.setForCreate(pxyGTEItem, self);
			if tranNum = null then
				tranNum := self.getNextTranNumForFlexiGate(); 
			endif;
			realGTEItem.setTranNumber(tranNum);	
			
			//22 Oct 2015	NDL	Par 37084
			foreach pxyChildGTEItem in pxyGTEItem.allChildren discreteLock do
				create realChildGTEItem as pxyChildGTEItem.class persistent;
				realChildGTEItem.setForCreateIfSubItem(pxyChildGTEItem, realGTEItem, tranNum);
			endforeach;
	endforeach;
	
end;</source>
        <Parameter name="_proxy" type="CM_VehicleVisitRecord"/>
        <Parameter name="_batNumber" type="String"/>
    </JadeMethod>
    <JadeMethod name="setForUpdateFlexi" id="f96a9dc1-42f0-4a30-a9bd-5faed76438ad">
        <updating/>
        <source>setForUpdateFlexi(_pxyMe : CM_VehicleVisitRecord) updating;
// ---------------------------------------------------------------------------
// Created:     04 November 2008 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
// 22/09/2009		cnwcs5			Removed code to reate VVRDs as it was only needed for cancels
//									and they are being created elsewhere now
// 15/10/12			cnwer1				par 32445 removed allContainer lengths
// 06/12/2016 		cnwrh7			TFS	3032
// 22/06/2017		cnwdap1			TFS 4912 Expose Additional Report Attributes
// 22/08/2018		jlgrh7			TFS39817 PEN - ROB Chassis (Ticket 39628)
// 02/10/2020   	cnwma1 			ChangeRequest 50112: ASPA - GCI Stevedores
// 12/01/2022		navdap1			TFS 52268 AAT 1-Stop VBS Integration
// 13/05/2022 		navhl20 		TFS 53430  EUP - Sub Carrier registration in MTN
// 07Dec2022		navsp1			TFS ChangeRequest 55580: EUP - Inspection App checks - Interface and MTN changes
// 07/03/2023		navdap1			TFS 57001 FR | 53667 - EUP - Inspection App checks - New Fields in Column Organiser
// 11/05/2023		navpw1			TFS: 54049 (55840) - Associates vehicle booking time slots on the proxy vehicle visit to the real one
// 15/05/2023		navdap1			TFS 56801 EUP - EDI Message Type - Transport Status Message Processing
// 23 Feb 2024 		navhl20 		ChangeRequest 62525: EUP | Retrospective Operations - [54177.060] - Cargo &amp; Truck Checks
// 14/06/2024		jlizm1			TFS 63908 Allow duplicate driver names
// 08/01/2026 		navma1 			MTN-36897 PEN - Transient File Growth in PEN Production Environment 
// ---------------------------------------------------------------------------

vars	
	chassis,	
	pxyGTEItem,
	realGTEItem		: CMGTE_Entity;
	iterPxy			: Iterator;
	newIdx 			: Integer;
	deleteSet		: CMGTE_EntitySet;
	gte				: CMGTE_Entity;
	realGTEGen 		: CMGTE_Generator;					//+TFS39817
	stevedore       : CM_Stevedore;
	sendEvent		: Boolean;							// TFS 57001
	vbts			: CM_VehicleBookingTimeSlot;	// ### TFS 54049 (55840) 08May2023 NAVPW1
	vvrDtl			: CM_VehicleVisitRecordDetail;
	now				: TimeStamp;
begin
	sendEvent := self.gateInCheckStatus &lt;&gt; _pxyMe.gateInCheckStatus or self.gateInCheckTS &lt;&gt; _pxyMe.gateInCheckTS or	// TFS 57001
				 self.gateOutCheckStatus &lt;&gt; _pxyMe.gateOutCheckStatus or self.gateOutCheckTS &lt;&gt; _pxyMe.gateOutCheckTS;	// TFS 57001
	
	self.myDriverDetails 	  := _pxyMe.myTerminal.findDriver(_pxyMe.driverCode);
	self.carrierCode 		  := _pxyMe.carrierCode;
	self.subCarrierCode		  := _pxyMe.subCarrierCode; 		//13/05/2022 navhl20 TFS 53430 
	self.driversName 		  := _pxyMe.driversName;
	self.driverCode 		  := _pxyMe.driverCode;
	self.remarks 			  := _pxyMe.remarks;
	self.transferAreaId 	  := _pxyMe.transferAreaId;
	self.myGateIn 			  := _pxyMe.myGateIn;
	self.myGateLaneController := _pxyMe.myGateLaneController;
	self.ownerTrailerID 	  := _pxyMe.ownerTrailerID;
	self.setAutoComplete(_pxyMe.isRoadJobAutoComplete);///autocompletecnwas3
	self.setIsUpdatable(_pxyMe.isUpdatable);
	self.gateInCheckStatus	  := _pxyMe.gateInCheckStatus;	//15Dec2022 navsp1 TFS 55580
	self.gateInCheckTS	 	  := _pxyMe.gateInCheckTS;		//15Dec2022 navsp1 TFS 55580
	self.gateOutCheckStatus	  := _pxyMe.gateOutCheckStatus;	//15Dec2022 navsp1 TFS 55580
	self.gateOutCheckTS		  := _pxyMe.gateOutCheckTS;		//15Dec2022 navsp1 TFS 55580
	// cnwjk3 12/10/09 PAR 20915
	self.vehicle:= self.myTerminal.vehicles[_pxyMe.regNumber, _pxyMe.state];
	//self.regNumber := _pxyMe.regNumber;											//-TFS3032
	self.regNumber := _pxyMe.regNumber.removeTabCrLfs();		//+TFS3032
	self.state:= _pxyMe.state;

	//11 Nov 2020	NDL	TFS 50329
	if self.myTerminal.roadProcessIsASPA then
		if self.visitNumber &lt;&gt; _pxyMe.visitNumber then
			//User has changed the value on the screen
			self.setVisitNumber( _pxyMe.visitNumber );
		endif;
	endif;
	
	if self.myTerminal.getConfig(IsRetrospectiveMode).Boolean then						//23.02.2024 navhl20 #62525
		now := app.actualTimeServer();													//08.01.2026 navma1 #MTN-36897
		if _pxyMe.timeIn.isValid and _pxyMe.timeIn &lt; now then
			self.timeIn := _pxyMe.timeIn;
			self.retrospectiveDT := _pxyMe.timeIn;
		endif;
		foreach vvrDtl in self.allVehicleVisitRecordDetails do							//23.02.2024 navhl20 #62525
			if vvrDtl.timeStart.Date = now.Date and self.retrospectiveDT.isValid then	//08.01.2026 navma1 #MTN-36897
				vvrDtl.setTimeStart(self.retrospectiveDT);
			endif;
		endforeach;
	endif;

	self.changeStatus(_pxyMe.status);
	
	if self.myDriverDetails &lt;&gt; null then
		if self.driversName = null then
			self.driversName := self.myDriverDetails.name;
		endif;
		//if self.secondaryCode.trimBlanks() = null then					// TFS 4912
		//	self.secondaryCode := self.myDriverDetails.secondaryCode;		// TFS 4912
		//endif;															// TFS 4912
		if self.driverCode.trimBlanks() = null then
			self.driverCode := self.myDriverDetails.code;
		endif;
	endif;
	
	// ### TFS 54049 (55840) 08May2023 NAVPW1
	foreach vbts in _pxyMe.allVehicleBookingSlots do
		if self.allVehicleBookingSlots.includes(vbts) then
			continue;
		endif;
		
		self.allVehicleBookingSlots.add(vbts);
		
	endforeach;
	// ### TFS 54049 (55840) 08May2023 NAVPW1
	
	//07Dec2022 navsp1 TFS 55580
	if self.myVehicleBookingTimeslot &lt;&gt; null then
		if self.gateInCheckStatus = null then
			if self.myVehicleBookingTimeslot.preGateInCheck then
				self.gateInCheckStatus := self.InspectionPending;
			else
				self.gateInCheckStatus := self.InspectionNA;
		  endif;
		endif;
		if self.gateOutCheckStatus = null then
			if self.myVehicleBookingTimeslot.preGateOutCheck then
				self.gateOutCheckStatus := self.InspectionPending;
			else
				self.gateOutCheckStatus := self.InspectionNA;
			endif;
		endif;
	endif;
	
	create deleteSet transient;
	self.allGateEntities.copy(deleteSet);
	
	// Move 'em all out the way to avoid key clashes
	foreach realGTEItem in self.allGateEntities do
		realGTEItem.setJobQueueNum(-realGTEItem.jobQueueNum);
	endforeach;
		
	// Re-order the real's gate entities to match the proxy's 
	newIdx := 0;//cnwas3 begin
	iterPxy := _pxyMe.allGateEntities.createIterator();
	while iterPxy.next(pxyGTEItem) do

		newIdx := newIdx + 1;

		realGTEItem := pxyGTEItem.pxyGetRealObject().CMGTE_Entity;
		if realGTEItem &lt;&gt; null then
			if deleteSet.includes(realGTEItem) then
				deleteSet.remove(realGTEItem);
			endif;
			
			// This will also set the jobNumber from the proxy, and therefore re-order the real accordingly
			realGTEItem.setForUpdate(pxyGTEItem, self);
		else
			// Should never happen really...
			create realGTEItem as pxyGTEItem.class persistent;
			realGTEItem.setForCreate(pxyGTEItem, self);
			if pxyGTEItem.isKindOf(CMGTE_TILC) and  not pxyGTEItem.CMGTE_TILC.allChildren.isEmpty then																			//+TFS39817					
				if pxyGTEItem.allChildren.first.isKindOf(CMGTE_Generator) then
					create realGTEGen as CMGTE_Generator persistent;
						realGTEGen.setParentObject(chassis);	
						realGTEGen.setForCreateIfSubItem(pxyGTEItem.allChildren.first.CMGTE_Generator, realGTEItem, self.getNextTranNumForFlexiGate);
				endif;
			endif;
		endif;
	endwhile;
	
	// Remove any real GTEEntities which are no longer on the proxy
	if (not deleteSet.isEmpty()) then
		deleteSet.purge();
	endif;
	//epr par 34612 22/7/14 chassis stuff is in the VVR allGateEntities so no need to update again for chassis in and out
	
	//02.10.2020 cnwma1 TFS #50112
	stevedore := self.getStevedore();
	if stevedore &lt;&gt; null then           
		self.myStevedore := stevedore;
	endif;
	//02.10.2020 cnwma1 TFS #50112
	
	self.set1StopBookingsFromProxy(_pxyMe);			// TFS 52268
	
	if sendEvent and self.myRoadJob &lt;&gt; null then																	// TFS 57001
		self.myRoadJob.causeEvent(self.myTerminal.getTerminalEvent(RoadJob_Update_Event), true, self.myRoadJob);	// TFS 57001
	endif;																											// TFS 57001
epilog
	delete iterPxy;
	delete deleteSet;
end;</source>
        <Parameter name="_pxyMe" type="CM_VehicleVisitRecord"/>
    </JadeMethod>
    <JadeMethod name="setForUpdateSecurityGateExit" id="4edad8bf-826b-4790-af4d-949cb33a5b0a">
        <updating/>
        <source>setForUpdateSecurityGateExit(_exitTime : TimeStamp; _passport : CM_Passport input) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 19/12/2013	cnwdap1		Initial creation PAR #32849 CCMS PEN 2321 Security Gate
// 12/03/2014	cnwdap1		PAR #33639 Correct "BAT number unassign" visit detail time
// 31/05/2022	jlier1		TFS 53650 - refactored schedule packages now called from vvr.departureProcess
//
vars
	arrival		: CM_VehicleVisitRecordDetail;
	depart		: CM_VehicleVisitRecordDetail;
	unassign	: CM_VehicleVisitRecordDetail;
	batNbr		: String;
	bat			: CM_RFIDTag;
	second		: TimeStampInterval;
begin
	// do we have a job still? - need to perform a Road Exit and complete the job
	if self.myRoadJob &lt;&gt; null then		
		self.myRoadJob.departureProcess(_passport);
		self.doExitForNoJobCargoLoads();		
	endif;
	
	// release any assigned bat number
	arrival := self.getSecurityGateArrivedDetail;
	// TFS 2185 check for no such detail
	if arrival &lt;&gt; null then
		batNbr := arrival.getExtraInfo_AssignRFIDTag;
		if batNbr &lt;&gt; null then
			bat := self.myTerminal.allRFIDTagsByCode[batNbr];
			if bat &lt;&gt; null then
				bat.setIsAvailableForEntry(true);
				global.causeEvent(self.myTerminal.getTerminalEvent(Event_RFIDTagFree), false, bat);
				// create an "Unassign BAT detail" record
				unassign := self.createVisitRecordDetail(VisitRecord_DeassignRFIDTag, bat, null);
				if unassign &lt;&gt; null then	//09 Dec 2015	NDL testing TFS 292/10
					unassign.setTimeForSecurityGateExit(_exitTime);										// PAR #33639
				endif;
			endif;
		endif;
	endif;
	// create a "Security Gate Exit" detail record
	self.createVisitRecordDetail(VisitRecord_DepartSecurityGate, null, null);
	// and change its dateTime to the _exitTime
	depart := self.getSecurityGateExitDetail();
	depart.setTimeForSecurityGateExit(_exitTime);
	if unassign &lt;&gt; null and unassign.timeStart &gt; depart.timeStart then
		second.set(null, 1000);
		unassign.setTimeForSecurityGateExit(depart.timeStart - second);
	endif;
	
	// mark myself as complete
	if not self.status = self.Status_Complete then
		self.status := self.Status_Complete;
	endif;
	// and set timeOut
	if self.timeOut = null then
		self.timeOut := _exitTime;
	endif;
	
epilog


end;</source>
        <Parameter name="_exitTime" type="TimeStamp"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setForUpdateStevedore" id="914d89a3-ca17-4771-a926-d328e6771118">
        <updating/>
        <source>setForUpdateStevedore(_stevedore : CM_Stevedore ; _passport : CM_Passport input)updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 Nov 2020 cnwma1 ChangeRequest 50112: ASPA - GCI Stevedores
16 Nov 2020 cnwma1 Bug 50343: Bug from Functional Review of 49179 - Road Gate &amp; Vehicle Visit
*/

vars
	gte 				: CMGTE_Entity;
	pxyTi,
	ti  				: CM_TrackedItem;
	newStevedoreCode	: String;
	tit                 : CM_TITransaction;
	controller 			: CMIF_TiTransactionResync;
	doResync            : Boolean;
	tiSet               : CM_TISet;
begin
	self.myStevedore	 := _stevedore;
	newStevedoreCode     := _stevedore.code;
	
	create tiSet transient;
	foreach gte in self.allGateEntities  do
		
		//Update Gate Entity
		if gte.isCMGTE_Receival then
			gte.CMGTE_Receival.setStevedoreCode(newStevedoreCode);
			ti := gte.CMGTE_Receival.myTrackedItem;
			tiSet.addNoDuplicates(ti,false);
		elseif gte.isCMGTE_Release then
			gte.CMGTE_Release.setStevedoreCode(newStevedoreCode);
			ti := gte.CMGTE_Release.myTrackedItem;
			if ti &lt;&gt; null then                                                // 16.11.2020 cnwma1 #50343
				tiSet.addNoDuplicates(ti,false);
			else
				if gte.CMGTE_Release.myBOLDtl &lt;&gt; null then
					foreach ti in gte.CMGTE_Release.myBOLDtl.allTrackedItems do
						tiSet.addNoDuplicates(ti,false);
					endforeach;
				endif;
			endif;
		endif;
	endforeach;
	
	foreach ti in tiSet do                                       // 16.11.2020 cnwma1 #50343
		//Update Tracked Item
		pxyTi := ti.pxyCreateUpdateProxy();
		
		if gte.isCMGTE_Receival then
			pxyTi.setStevedoreCodeRecieve(newStevedoreCode);
		elseif gte.isCMGTE_Release then
			pxyTi.setStevedoreCodeRelease(newStevedoreCode);
		endif;
		
		app.myUtilityUA.utlUpdateTrackedItem( pxyTi, null, TI_UPDMODE_NORMAL, null, null, null, app.myPassport );
		
		//Update Transaction &amp; Resync 
		foreach tit in ti.allTransactions do
			if tit.isKindOf(CM_ReceiveRoad) or tit.isKindOf(CM_ReleaseRoad)  then
				if tit.stevedoreCode &lt;&gt; newStevedoreCode then
					doResync := true;
					tit.updateStevedoreCode(newStevedoreCode);
					
					if doResync then
						if app.myPassport.noErrors then
							if tit.allInvoiceLines.isNotEmpty then
								create controller transient;
								controller.allTransactions.add(tit);
								controller.myTrackedItem   := ti;
								controller.updateStevedore := true;
								app.myUtilityUA.utlUpdateResyncTrans(controller, _passport);
								delete controller;
							endif;
						endif;
					endif;
					doResync := false;
				endif;
			endif;
		endforeach;
		delete pxyTi;
	endforeach;
epilog		 
	delete tiSet;
end;</source>
        <Parameter name="_stevedore" type="CM_Stevedore"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setFromJob" id="de005a1f-c165-4cf8-bd64-bb355a2e1258">
        <updating/>
        <source>setFromJob(_timeIn : TimeStamp; _roadJob : CM_RoadJob) updating;  // _dwellTime : Integer; _timeIn, _timeOut : TimeStamp;_roadJob : CM_RoadJob) updating;
// ---------------------------------------------------------------------------
// Created:     August 2008 ANDREW BISHOP
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
// 10/02/2011		cnwmh5			PAR26925 - Signature changed and appropriate lines commented out
// 09/03/2011		cnwkpd1			PAR #27164 - issue with exception handler resuming through inverse maintenance
//									on a deleted CM_DriverDetails object
// 04/05/2015		cnwdap1			PAR #36079 Extra logging to try adn establish how bat number is overwriting vvr number
// 18/05/2017		cnwkpd1			TFS 4485 - Performance changes for synchronising the released and received 
//									items with the job
// 22/06/2017		cnwdap1			TFS 4912 Expose Additional Report Attributes
// 14/11/2017       cnwma1			TFS #7610 PKT - REQUIRED FIELD FOR REPORTING
//	24 Feb 2021	NDL	TFS 50849 - Remove deug messages relative to Par 36079
//	14/05/2022 		navhl20 		TFS 53430  EUP - Sub Carrier registration in MTN
// ---------------------------------------------------------------------------

vars
	pass 			: String;
	theVehicle 		: CM_Vehicle;
	theVisitRecord	: CM_VehicleVisitRecord;
	invalidObj		: Boolean;
	driverDetails	: CM_DriverDetails;
	
begin
	theVisitRecord 	:= _roadJob.myVehicleVisit;
	theVehicle 		:= _roadJob.myVehicle;
	
	self.setMyTerminal(theVehicle.myTerminal); // PAR 17703
	
	pass 	:= theVisitRecord.visitNumber;
	
//	app.writeLog(method.qualifiedName &amp; " roadJob vvr number is '" &amp; pass &amp; "'", LogDEBUG);		// PAR #36079
	if pass = null and app.getMyTerminalConfigDO_NOT_USE(GateInAutoVisitNo).Boolean then
		///pass := self.myTerminal.gatePassNextSeqNumber;
		pass := self.myTerminal.getNextGateTransactionNumber();		// 11/11/2010 cnwmh5 #26250
//		app.writeLog(method.qualifiedName &amp; " GateInAutoVisitNo is true, pass is now '" &amp; pass &amp; "'", LogDEBUG);	// PAR #36079
	endif;

	///self.dwellTimeMinutes 	:= _dwellTime;			// 10/02/2011 cnwmh5 #26925
	self.timeIn 			:= _timeIn;
	// ### TFS 52631 10Jan2022 NAVPW1
	if theVisitRecord.isRoadJobAutoComplete then
		self.timeOut := self.timeIn;
	endif;
	// ### TFS 52631 10Jan2022 NAVPW1
	//self.timeOut 			:= _timeOut;				// 10/02/2011 cnwmh5 #26925
	
//	self.transferAreaId 	:= _roadJob.roadTransAreaId.trimBlanks;
	// Move the vehicle to the AGate lane
	self.myGateIn 			:= _roadJob.myGate;
	
	if not  self.isBulkGateVVR then					//14.11.2017 cnwma1 TFS #7610
		if self.myGateIn &lt;&gt; null then
			self.myGateLaneController := self.myGateIn.getFirstAGateLane_IN;
		endif;
	endif;
	self.vehicle 			:= theVehicle;
	
	// PAR #27164 - 1048 exceptions were occurring because our exception handler was trying to resume through
	// an invalid CM_DriverDetails object during JADE inverse maintenance, which is not allowed/
	// To resolve the issue, we will take a reservelock on the CM_DriverDetails to check it is valid
	driverDetails := _roadJob.myDriver; // PAR 17703, PAR #27164
	if driverDetails &lt;&gt; null then
		on Exception do app.handleDeletedObject(exception, driverDetails, invalidObj);
		reserveLock(driverDetails);
		if invalidObj then
			driverDetails := null;
		endif;
		on Exception do null;
	endif;
	
	// PAR #27164 - This line of code performs the inverse maintenance, so we need the driverDetails to be valid
	self.myDriverDetails 	:= driverDetails;
	
	self.numTIsIn := _roadJob.allReceiveTrackedItems.size;
	self.numTIsOut := _roadJob.allReleaseTrackedItems.size;
	self.carrierCode := theVehicle.carrierCode;
	self.subCarrierCode := theVisitRecord.subCarrierCode;			//14/05/2022 navhl20 TFS 53430
	self.departureGate := theVisitRecord.departureGate;
	self.driversName := theVisitRecord.driversName;
//	app.writeLog(method.qualifiedName &amp; " Setting visitNumber to '" &amp; pass &amp; "'", LogDEBUG); 			// PAR #36079
	self.visitNumber := pass;
	self.loadingCompanyCode := theVisitRecord.loadingCompanyCode;
	self.remarks := theVisitRecord.remarks;
	self.verificationNumber := theVisitRecord.verificationNumber;
	self.verifiedByUserCode := theVisitRecord.verifiedByUserCode;
	self.jobNumber := _roadJob.jobNumber;
	
	// TFS 4485 - Old code was clearing both collections and copying them again, which was causing a very large number of updates
	// to the inversed collections on the linked tracked items, especially when the net change of this transaction was just to 
	// add one new tracked item to the collection.  Change to use new synchroniseContents method, which will only make the minimum
	// required update changes
	if _roadJob.allReleaseTrackedItems &lt;&gt; null then
		self.allReleasedTrackedItems.synchroniseContents(_roadJob.allReleaseTrackedItems);	// TFS 4485
	endif;
	
	if _roadJob.allReceiveTrackedItems &lt;&gt; null then
		self.allReceivedTrackedItems.synchroniseContents(_roadJob.allReceiveTrackedItems);	// TFS 4485
	endif;
		
	// PAR 17703
	if self.myDriverDetails &lt;&gt; null then
		if self.driversName = null then
			self.driversName := self.myDriverDetails.name;
		endif;
		//if self.secondaryCode.trimBlanks() = null then					// TFS 4912
		//	self.secondaryCode := self.myDriverDetails.secondaryCode;		// TFS 4912
		//endif;															// TFS 4912
		if self.driverCode.trimBlanks() = null then
			self.driverCode := self.myDriverDetails.code;
		endif;
	endif;

	// sfw1035 cnwjk3 - removed to stop flexi-gate main screen jumping in front of others when job status has changed
	/*
	if self.myTerminal &lt;&gt; null then
		self.causeEvent(self.myTerminal.getTerminalEvent(EVENT_VEHICLEVISIT_UPDATE), false, self); // PAR 17703
	endif;
	*/
end;</source>
        <Parameter name="_timeIn" type="TimeStamp"/>
        <Parameter name="_roadJob" type="CM_RoadJob"/>
    </JadeMethod>
    <JadeMethod name="setIsUpdatable" id="f2de911c-f79e-4f53-80d9-f47ba2504ef7">
        <updating/>
        <source>setIsUpdatable(_value : Boolean) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 September 2009	cnwas3	Initial creation

*/
begin

	self.isUpdatable := _value;

end;</source>
        <Parameter name="_value" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setMoveAmountToUndo" id="dc0d6d6e-a7ac-486f-ba45-fd53c983c160">
        <source>setMoveAmountToUndo( _moveController : CMIF_MoveController input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 October 2020	jlgndl1	Initial creation	TFS 49189

*/

vars

	ti : CM_TrackedItem;
	total : Decimal[14,4];
	
begin

	if _moveController = null then
		return;
	endif;

	ti := _moveController.myTrackedItem;
	
	if ti = null then
		return;
	endif;
	
	//the default position.
	_moveController.setWeight( ti.totalWeight );
	_moveController.setQuantity( ti.totalQuantity );
	
	total := self.getMoveTotalForTIID( ti.id );
	
	if ti.isBulkByVolume then
		if total &gt; 0 and ( total * ti.getDensity ) &lt;  ( ti.totalVolume * ti.getDensity ) then
			//it looks like its been merged into some existing yard cargo
			_moveController.setWeight( total * ti.getDensity );
		endif;
	elseif ti.isBulkByWeight then
		if total &gt; 0 and total &lt; ti.totalWeight then
			//it looks like its been merged into some existing yard cargo
			_moveController.setWeight( total );
		endif;
	else
		if total.Integer &gt; 0 and total &lt; ti.totalQuantity then
			//it looks like its been merged into some existing yard cargo
			_moveController.setWeight( ti.totalWeight * ( total.Integer / ti.totalQuantity ) );
			_moveController.setQuantity( total.Integer );
		endif;
	endif;

epilog

end;</source>
        <Parameter name="_moveController" type="CMIF_MoveController" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setMyBarrierCodeIn" id="de7af08d-38b2-4755-960b-02fb7506b093">
        <updating/>
        <source>setMyBarrierCodeIn(_barrierCode : CM_BarrierCode) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 May 2023	jlier1	Initial creation 57936

*/

vars

begin
	self.myBarrierCodeIn:=_barrierCode;
epilog

end;</source>
        <Parameter name="_barrierCode" type="CM_BarrierCode"/>
    </JadeMethod>
    <JadeMethod name="setMyBarrierCodeOut" id="415139ac-af89-4068-87c4-305bcafa5f55">
        <updating/>
        <source>setMyBarrierCodeOut(_barrierCode : CM_BarrierCode) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 May 2023	jlier1	Initial creation 57936

*/

