    <JadeMethod name="createStevedoreDebtorType" id="dc805b96-64c9-4586-a24a-64c214f5aed2">
        <source>createStevedoreDebtorType(_updController : CnEcReleaseController);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 30/05/2019	jlgdap1		Initial creation TFS 44554 AAT Stevedore Data Access
//
vars
	debtorType : CM_DebtorType;

begin
	if self.hasScriptBeenRunAtAll(method.name, _updController) then
		return;
	endif;
	// create the new Debtor Type of "Stevedore"
	if app.myRoot.allDebtorTypes["SDT10"] &lt;&gt; null then
		self.addScriptRun(method.name);
		return;
	endif;
	
	app.writeLog(method.qualifiedName &amp; " Creating Stevedore Debtor Type", LogINFO);
	if _updController &lt;&gt; null then
		_updController.logEntry(" Creating Stevedore Debtor Type") ;	
	endif;
	
	beginTransaction;
	create debtorType;
	debtorType.setForCreateParam("SDT10", "Stevedore");
	commitTransaction;
	
	app.writeLog(method.qualifiedName &amp; " Creating Stevedore Debtor Type complete", LogINFO);
	if _updController &lt;&gt; null then
		_updController.logEntry(" Creating Stevedore Debtor Type complete") ;	
	endif;
	
	self.addScriptRun(method.name);
epilog

end;</source>
