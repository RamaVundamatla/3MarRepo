    <JadeMethod name="toolbarShowCaptions" id="c17199e7-9aab-497f-b2eb-77bf34c69ae5">
        <updating/>
        <source>toolbarShowCaptions(_showCaptions: Boolean) updating;
//
//20 Jan 2017	cnwrs1	TFS 3137 - resize the find/trplace form when show captions is on
//16 Aug 2023 	navhl20 Bug 59665: EUP - Work Order - View Transactions - Not displaying anything 
//
vars
	currentHeight : Real;
	newHeight : Real;
	heightDiff : Real;
begin
	currentHeight := self.frmToolbar.height;
	inheritMethod(_showCaptions);
	newHeight := self.frmToolbar.height;
	heightDiff := newHeight - currentHeight;
	self.frmSearchCrit.top := self.frmSearchCrit.top + heightDiff;
	self.fldTrans.top := self.fldTrans.top + heightDiff;
	self.tblTransactions.top := self.tblTransactions.top + heightDiff;
	self.tblTransactions.height := self.tblTransactions.height - heightDiff;
	//self.doResize();																	//16.8.2023 navhl20 #59665
end;
</source>
        <Parameter name="_showCaptions" type="Boolean"/>
    </JadeMethod>
