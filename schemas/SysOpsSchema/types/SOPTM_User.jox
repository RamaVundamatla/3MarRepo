    <JadeMethod name="doLoadCmbCargoBOLType" id="37b1187d-4254-4f58-91a2-3370c8633432">
        <source>doLoadCmbCargoBOLType(_cmb : CMUI_ComboBox input; _terminal : CM_Terminal; _column : Integer);
// ---------------------------------------------------------------------------
// Created:     24 August 2004	cnwth2
//
// Purpose:     re-populates the combo every time they click to a new row in user maint - we need to
//				only allow them to choose valid cargoBOLTypes for the given terminal
//			 
// ----------   ----------  --------------------------------------------------
vars
	cbType		: CM_CargoBOLType;
begin
	if _cmb = null or _terminal = null then
		return;
	endif;
	
	_cmb.clear();
	_cmb.addItem(null);
	
	foreach cbType in _terminal.allCargoBOLTypes do
		if (_column = self.Column_BOLType and (not CM_BOLType.hasInstance(cbType))) or
		   (_column = self.Column_CargoType and (not CM_CargoType.hasInstance(cbType))) then
			continue;
		endif;
		
		_cmb.itemObject[_cmb.addItem(cbType.description)] := cbType;
	endforeach;

end;</source>
        <Parameter name="_cmb" type="CMUI_ComboBox" usage="input"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_column" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doMnuContext1Click" id="1952d1f4-3616-4d3c-82a5-5ed60bf53304">
        <updating/>
        <source>doMnuContext1Click(theMenuItem: MenuItem) updating;

/*

Purpose:	NFS 30581 		

Parameters:			

Return Value:		


Date		Who		Reason
11 March 2013	cnwrd1	Initial creation

*/

vars
	theForm 	: SOP_TableMaintForm;
	aUser		: CM_User;
	expectedEdition : Integer;
begin

	theForm := self.myForm;

	if theForm.mode &lt;&gt; theForm.Mode_View then	//only in view mode
		return;
	endif;
	
	if theForm.myCurrentObject &lt;&gt; null and theForm.myCurrentObject.isKindOf(CM_User) then
		aUser := theForm.myCurrentObject.CM_User;
		expectedEdition := aUser.edition;
		//reset user status
		app.myTrxUA.trxUpdateUserStatus(aUser,expectedEdition, EnabledNormalUser, app.myPassport); // update the user to enabled normal
	endif;

epilog

end;</source>
        <Parameter name="theMenuItem" type="MenuItem"/>
    </JadeMethod>
    <JadeMethod name="doMnuContext2Click" id="6019aa06-2f52-4a37-85ca-91ae5e8455ab">
        <updating/>
        <source>doMnuContext2Click(theMenuItem: MenuItem) updating;
/*

Date		Who		Reason
10 April 2017	cnwer1	Initial creation TFS 3596

*/

vars
	
begin

	if self.myForm.myCurrentObject &lt;&gt; null and self.myForm.myCurrentObject.isKindOf(CM_User) then		
		//no way of clearing saved windows settings saved on app thats open because out of scope
	
		app.myTrxUA.trxClearSavedWindowSettings( self.myForm.myCurrentObject.CM_User, app.myPassport);
		if app.myPassport.noErrors then
			app.msgBox(app.getErrorString(Saved_window_setting_cleared), app.getErrorString(Info), MsgBox_OK_Only + MsgBox_Information_Icon);
		else
			app.showErrorsAsMsgBox(app.myPassport.allErrorWarnings, app.myPassport.noErrors);
		endif;
	endif;
epilog

end;</source>
        <Parameter name="theMenuItem" type="MenuItem"/>
    </JadeMethod>
    <JadeMethod name="doMnuContext3Click" id="b73ab4bc-6665-4370-90d4-2a16ced49025">
        <updating/>
        <source>doMnuContext3Click(theMenuItem: MenuItem) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 May 2018	jlgndl1	Initial creation	TFS 38768
04 Feb 2025	navah1	Story 14660: MTN - New option to disable users from changing their own passwords
*/

vars

	newTempPassword : String;
	theForm : SOP_TableMaintForm;
	aUser : CM_User;
	result : Integer;

begin
	
	newTempPassword := app.myRoot.generateRandomPassword(); 
	
	theForm := self.myForm;

	if theForm.mode &lt;&gt; theForm.Mode_View then	//only allowed in view mode
		return;
	endif;
	
	if theForm.myCurrentObject &lt;&gt; null and theForm.myCurrentObject.isKindOf(CM_User) then
		aUser := theForm.myCurrentObject.CM_User;
	endif;
	
	if aUser = null then
		return;
	endif;
	
	if not aUser.canChangePassword() then  //04.02.2025 navah1 #14660
		app.raiseCMException1(PasswordChangeProhibited, aUser.code, null, null);
		return;
	endif;
	
	while true do
		app.myTrxUA.trxUpdateUserTempPW( aUser, newTempPassword, app.myPassport );
		
		if app.myPassport.trxCompletedOK() then
			theForm.clearErrorWarnings();
			return;
			
		else
			result := app.showErrorWarningDialog('User Password Reset and Email', app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors()
			and result = IDOK
			then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			
		endif;
		
		return;
	
	endwhile;

epilog

end;</source>
        <Parameter name="theMenuItem" type="MenuItem"/>
    </JadeMethod>
    <JadeMethod name="doMnuContext4Click" id="f492b628-612c-4587-8893-b27cb90aa694">
        <updating/>
        <source>doMnuContext4Click(theMenuItem: MenuItem) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 July 2022 navam1 ChangeRequest 52824: EUP - Azure Active Directory Single Sign On - MTN
*/

vars
	theForm : SOP_TableMaintForm;
	proxyUser, aUser : CM_User;
	result : Integer;
begin
	//inheritMethod(theMenuItem);
	theForm := self.myForm;

	if theForm.mode &lt;&gt; theForm.Mode_View then	//only allowed in view mode
		return;
	endif;
	
	if theForm.myCurrentObject &lt;&gt; null and theForm.myCurrentObject.isKindOf(CM_User) then
		aUser := theForm.myCurrentObject.CM_User;
	endif;
	
	if aUser = null then
		return;
	endif;

	if app.msgBox(app.getErrorString1(CONFIRM_UNLINK_SSO_ACCT, aUser.code),app.getErrorString(Unlink_SSO_account),MsgBox_Yes_No + MsgBox_Question_Mark_Icon) &lt;&gt; MsgBox_Return_Yes then
		return;
	endif;
	
	proxyUser	:= app.createUpdateProxy(aUser).CM_User;
	
	while true do
		app.myTrxUA.trxUpdateUserSSOUniqueId(proxyUser, null, app.myPassport);
		
		if app.myPassport.trxCompletedOK then
			break;
		else
			result := app.showErrorWarningDialog(app.getErrorString1(CONFIRM_UNLINK_SSO_ACCT, null), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				// there must have just been warnings that the user has acknowledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		break;
	endwhile;
	
epilog
	delete proxyUser;
end;</source>
        <Parameter name="theMenuItem" type="MenuItem"/>
    </JadeMethod>
    <JadeMethod name="doSave" id="825021b0-cf84-4720-bf69-a4234dafea9a">
        <updating/>
        <source>doSave(): Boolean updating;

// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 10/09/2008	concms1		par 17903/ccms 1741 Welcome form interim solution
// 04/06/2009	concms1		par 19803 - not saving sub-terminal DAC
// 19/12/2018	jlgdap1		TFS 42542 PEL1 Freight Forwarder Access and Visibility
// 30/05/2019	jlgdap1		TFS 44554 AAT Stevedore Data Access
// 05/08/2021	navmd1		TFS 51226 Allow users with permission to force off old sessions
// 04 Feb 2025	navah1		Story 14660: MTN - New option to disable users from changing their own passwords
// 05 Dec 2025  navlc30     JIRA 36748 CUX - Enforce SSO Login
// ---------------------------------------------------------------------------

vars
	daSet						: CM_DataAccessControllerSet;
//	roleSet						: CM_SecurityRoleSet;
	password					: String;
	proxyUser					: CM_User;
	isExternal,
	rtnValue,
	isNotAvailableForEntry		: Boolean;
	_allowAutomaticDisability	: Boolean;
	theForm 					: SOP_TableMaintForm;
	pxyUserTerm					: CM_UserTerminal;
	sysSecurityRole				: CM_SecurityRoleSystem;
	row							: Integer;
	tbl							: CM_DataTable;
	obj							: Object;
	emailTitle, newEmail,
	userCode					: String;
	emailAddress				: CM_EmailEntity;
	locale                      : CM_Locale;
	allEmailAddresses			: CM_EmailEntityByTypeNameDict;
	selectedEventTypes,
	selectedAlertTypes 			: ObjectArray;
	msg : String;
	isUserFreightForwarder		: Boolean;			// TFS 42542
	ssoMatchingId, ssoUniqueId		: String;	//20.07.2022 navam1 #52824
begin

	theForm := self.myForm; 
	
	create selectedAlertTypes transient;
	create selectedEventTypes transient;
	create allEmailAddresses transient;
	
	theForm.mulSelect1.getSelected(selectedAlertTypes);
	theForm.mulSelect2.getSelected(selectedEventTypes);	
	theForm.mulSelect3.getSelected(allEmailAddresses);
	
	if theForm.mode = theForm.Mode_Add then
		if global.isValidObject(theForm.myProxyObject) then
			// delete and re-create as may be of wrong type
			theForm.myProxyObject.erase(NORMAL_ERASE);
		endif;

// 		no diff between internal/external user so this removed hg 24/02/06 re par10732
//		isExternal := theForm.tblInput1.getValueByName('isExternal').Boolean;

//		if isExternal then
//			create theForm.myProxyObject as CM_UserExternal transient;
//		else
			create theForm.myProxyObject as CM_User transient;
//		endif;
	endif;

	emailAddress := theForm.cmbEmailAddress.listObject.CM_EmailEntity;
	emailTitle := theForm.tblInput1.getValueByName(ETRow_UserName).String;
	locale     := theForm.cmbLocale.listObject.CM_Locale;
	userCode := theForm.tblInput1.getValueByName(ETRow_Code).String;
	if emailTitle = null then
		emailTitle := userCode;
	endif;
	newEmail := theForm.tblInput1.getValueByName(ETRow_NewEmailAddress).String;
	
	
	if newEmail &lt;&gt; null
	and emailAddress = null then
		emailAddress := app.myRoot.getEmailEntity(emailTitle);
		if emailAddress = null then
			emailAddress := app.myRoot.getEmailEntity(userCode);
		endif;
		if emailAddress = null then
			emailAddress := app.myRoot.getEmailEntity(newEmail);
		endif;
		if emailAddress = null then
			emailAddress := self.createNewEmailForUser(emailTitle, newEmail);
		endif;
	endif;

	proxyUser := theForm.myProxyObject.CM_User;
	
	password := theForm.enteredPassword;	//tblInput1.getValueByName('currentPassword').String;
	//07 Jul 2017	NDL	TFS 5235
	if password.length &gt; CM_User.MaxPasswordLength then
		msg := app.getErrorString2( ERR_STRING_TO_LONG, app.getErrorString(Password), CM_User.MaxPasswordLength.String);
		app.msgBox("User " &amp; msg, app.getErrorString(Warning), MsgBox_OK_Only );
	endif;

	create daSet transient;

	if theForm.cmbDACarrier.myObject &lt;&gt; null then
		daSet.add(theForm.cmbDACarrier.myObject.CM_DataAccessController);
	endif;
	if theForm.cmbDAConsignee.myObject &lt;&gt; null then
		daSet.add(theForm.cmbDAConsignee.myObject.CM_DataAccessController);
	endif;
	if theForm.cmbDAOperator.myObject &lt;&gt; null then
		daSet.add(theForm.cmbDAOperator.myObject.CM_DataAccessController);
	endif;	
	if theForm.cmbDAOrg.myObject &lt;&gt; null then
		daSet.add(theForm.cmbDAOrg.myObject.CM_DataAccessController);
	endif;	
	if theForm.cmbDASubTerminal.myObject &lt;&gt; null then							// par 19803
		daSet.add(theForm.cmbDASubTerminal.myObject.CM_DataAccessController);	// par 19803
	endif;																		// par 19803
	if theForm.cmbDAAgent.myObject &lt;&gt; null then			// TFS 525
		daSet.add(theForm.cmbDAAgent.myObject.CM_DataAccessController);
	endif;	
	if theForm.cmbDAStevedore.myObject &lt;&gt; null then								// TFS 44554
		daSet.add(theForm.cmbDAStevedore.myObject.CM_DataAccessController);		// TFS 44554
	endif;																		// TFS 44554
	//get the system security role for user
	sysSecurityRole	:= app.myRoot.allRoles[theForm.tblInput1.getValueByName(ETRow_SystemSecurityRole).String].CM_SecurityRoleSystem;

	isNotAvailableForEntry		:= theForm.tblInput1.getValueByName(ETRow_NotAvailableForEntry).Boolean;
	_allowAutomaticDisability	:= theForm.tblInput1.getValueByName(ETRow_AllowAutomaticDisability).Boolean; // cnwvu1	20/11/2006	ccms1051
	
	isUserFreightForwarder := theForm.tblInput1.getValueByName(ETRow_UserIsFreightForwarder).Boolean;	// TFS 42542
	
	proxyUser.setProxy(userCode, 
						theForm.tblInput1.getValueByName(ETRow_UserName).String,
						app.userStatusStringToEnum(theForm.tblInput1.getValueByName(ETRow_Status).String),
						theForm.cmbOrganisation.listObject.CM_Organisation,
						app.myRoot,
						theForm.tblInput1.getValueByName(ETRow_PersistentPassword).Boolean,
						theForm.tblInput1.getValueByName(ETRow_RadioTelemetryOnly).Boolean,
						isNotAvailableForEntry,
						_allowAutomaticDisability,				// cnwvu1	20/11/2006	ccms1051
						proxyUser.lastLoginTS,					// cnwvu1	20/11/2006	ccms1051
						daSet, sysSecurityRole,
						emailAddress, allEmailAddresses,
						selectedAlertTypes,
						selectedEventTypes,
						locale,
						theForm.tblInput1.getValueByName(ETRow_SingleSignOnOnly).Boolean,
						theForm.tblInput1.getValueByName(ETRow_SingleSignOnOverride).Boolean	// navmd1 05/08/2021 TFS 51226
						);
	
	proxyUser.setShowWelcomeScreen (theForm.tblInput1.getValueByName (ETRow_ShowWelcomeScreen).Boolean);	// par 17903
	
	proxyUser.setStateData(ConfigGrp_ExtraData, UserIsFreightForwarder, isUserFreightForwarder);		// TFS 42542
	
	//20.07.2022 navam1 #52824
	ssoMatchingId	:= theForm.tblInput1.getValueByName(ETRow_SsoMatchingId).String;
	proxyUser.setSSOMatchingId(ssoMatchingId);
	ssoUniqueId	:= theForm.tblInput1.getValueByName(ETRow_SsoLinkedIdentifier).String;
	if ssoUniqueId = '--' &amp; app.getErrorString(SSO_Account_Not_linked) &amp;  '--' then
		proxyUser.setSSOUniqueId("");
	else
		proxyUser.setSSOUniqueId(ssoUniqueId);
	endif;
	
	proxyUser.setPreventPasswordChange(theForm.tblInput1.getValueByName(ETRow_PreventPasswordChange).Boolean);   //04.02.2025 navah1 #14660
	
	proxyUser.setLocalMTNLoginAllowed(theForm.tblInput1.getValueByName(ETRow_SsoAllowLocalLogin).Boolean);		 //05.12.2025 navlc30 #36748
	
	self.saveTerminalsTable(proxyUser);
	/*
	else
		pxyUserTerm := theForm.myProxyObject.CM_User.allUserTerminals.first;
		if pxyUserTerm = null then
			create pxyUserTerm transient;
		endif;
		pxyUserTerm.setForProxy(theForm.myTerminal, theForm.myProxyObject.CM_User,
								theForm.cmbSecurityRole.listObject.CM_SecurityRole);
	endif;
*/
	if theForm.mode = theForm.Mode_Add then
		app.myTrxCA.trxCreateUser(proxyUser, password, theForm.myCurrentObject, app.myPassport);
		rtnValue := app.myPassport.trxCompletedOK;
	elseif theForm.mode = theForm.Mode_Update then
		app.myTrxUA.trxUpdateUser(proxyUser, password, app.myPassport);
		rtnValue := app.myPassport.trxCompletedOK;		
	else
		app.raiseUnexpectedProgramError(class.name, method.name, '  Invalid mode (' &amp; theForm.mode.String &amp; ')');
	endif;
	
	theForm.myProxyObject := proxyUser;
	return rtnValue;

epilog
	if daSet &lt;&gt; null then
		delete daSet;
	endif;
	if selectedAlertTypes &lt;&gt; null then
		delete selectedAlertTypes;
	endif;
	delete selectedEventTypes;		// PAR #27874
	delete allEmailAddresses;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="enableDACBySecurityRole" id="9f4d302e-e5b4-49aa-b03d-2c2e27a435ca">
