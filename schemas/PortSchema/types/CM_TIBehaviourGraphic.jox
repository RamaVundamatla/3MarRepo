    <JadeMethod name="drawFills" id="78ed80ea-4a95-4c53-bd82-b5f9e4d4aa66">
        <source>drawFills(_frame : Frame input; _type : Integer; _scale : Real;_offsetX, _offsetY : Integer;_flippedH : Boolean);
// ---------------------------------------------------------------------------
// Created:		November 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

	aGraphic : CM_Graphic;
	theCommands : CM_GraphicArray;
	aCommand : CM_GraphicCommand;
	theX, theY : Integer;
	maxX,oMaxX : Integer;
begin
	theCommands := self.getCommands(_type);
	oMaxX := (self.maxX * _scale).Integer ;

	foreach aGraphic in theCommands do
		aCommand := aGraphic.CM_GraphicCommand;
		
		if aCommand.type = CM_GraphicCommand.TYPE_FILL then
			theX := (aCommand.x1 * _scale).Integer + _offsetX;
			theY := (aCommand.y1 * _scale).Integer + _offsetY;
		
			if _flippedH then
				theX := (aCommand.x1 * _scale).Integer;
				theX := oMaxX - theX;
				theX := theX +  _offsetX;
				theX := theX - oMaxX;
			endif;

			_frame.drawFillColor := aCommand.lineColour;
			_frame.drawFloodFill(theX,theY, 0,Black);
		endif;
	endforeach;
end;</source>
        <Parameter name="_frame" type="Frame" usage="input"/>
        <Parameter name="_type" type="Integer"/>
        <Parameter name="_scale" type="Real"/>
        <Parameter name="_offsetX" type="Integer"/>
        <Parameter name="_offsetY" type="Integer"/>
        <Parameter name="_flippedH" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="drawGraphic" id="3cd3ca9d-3e83-4d90-89d3-8609af2fa8da">
        <source>drawGraphic(_frame: Frame input; 
			_scale: Real;
			_offsetX: Integer; 
			_offsetY: Integer; 
			_flippedH: Boolean; 
			_maxX 	: Integer;
			_clear : Boolean; 
			_text : String; 
			_ti 	: CM_TrackedItem;
			_fillColour : Integer);
// ---------------------------------------------------------------------------
// Created:		02 December 2005  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	aCommand,txtCommand : CM_GraphicCommand;
	aGraphic : CM_Graphic;
	theGraphics : CM_GraphicArray;
	maxX : Integer;
	stretchXPosStart,
	stretchYPosStart,
	stretchOffset	: Integer;
	newOffsetX ,theMaxXScaled: Integer;
	stretchCommand : CM_GraphicCommand;
begin
	if _clear then
		_frame.clearGraphics;
	endif;
	
	maxX := self.maxX;
	// get stretch Offset
	stretchCommand:=self.getStretchXY(null,stretchXPosStart, stretchYPosStart); // the point from which to stretch
	theMaxXScaled :=(self.maxX  *_scale).Integer;
	
	if stretchCommand &lt;&gt; null and theMaxXScaled &lt; _maxX then
		stretchOffset := _maxX - theMaxXScaled;
		if _flippedH then
			stretchOffset :=-stretchOffset;
		endif;
	elseif stretchCommand &lt;&gt; null and theMaxXScaled &gt; _maxX then
		
		stretchOffset :=  _maxX - theMaxXScaled;
		if _flippedH then
			stretchOffset :=-stretchOffset;
		endif;
	endif;
	
	self.drawPolygonsForRoRo(_frame,_scale,_offsetX,_offsetY, _flippedH,_maxX,stretchOffset, stretchXPosStart,_fillColour);

	self.drawFills(_frame,0,_scale,_offsetX,_offsetY,_flippedH);
	
	
	foreach aGraphic in self.allCommands do
		aCommand := aGraphic.CM_GraphicCommand;
		
		//cnwjo3 par 22965
		newOffsetX := _offsetX;
		if aCommand.x1 &gt; stretchXPosStart then
			newOffsetX := _offsetX + stretchOffset;
		endif;
		aCommand.drawMeRoRo(_frame,_scale,newOffsetX ,_offsetY,_flippedH,_maxX);
		

	endforeach;

	
end;</source>
        <Parameter name="_frame" type="Frame" usage="input"/>
        <Parameter name="_scale" type="Real"/>
        <Parameter name="_offsetX" type="Integer"/>
        <Parameter name="_offsetY" type="Integer"/>
        <Parameter name="_flippedH" type="Boolean"/>
        <Parameter name="_maxX" type="Integer"/>
        <Parameter name="_clear" type="Boolean"/>
        <Parameter name="_text" type="String"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_fillColour" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="drawPolygonsForRoRo" id="08c2ab7f-1a33-44fe-a614-99c5758f1261">
        <source>drawPolygonsForRoRo(_frame: Frame;
					_scale: Real; 
					_offsetX: Integer; 
					_offsetY: Integer; 
					_flippedH: Boolean; 
					_max : Integer; 
					_stretchOffset : Integer;
					_stretchStartPointX : Integer;
					_fillColour : Integer) protected;
// ---------------------------------------------------------------------------
// Created:		9 March 2010  By Jared cnwjo3
//
// Purpose:		direct copy from drawPolygons.  This is for the RoRo areas since offset is calculated differently
//
// ---------------------------------------------------------------------------

vars
	theFrame : Frame;
	aGraphic : CM_Graphic;
	aCommand : CM_GraphicCommand;
	thePoints : RealArray;
	theX, theY : Integer;
	stretchStartPointX : Integer;

begin
	theFrame := _frame;
	create thePoints transient;
	foreach aGraphic in self.allCommands do
		aCommand := aGraphic.CM_GraphicCommand;
		if aCommand.type = CM_GraphicCommand.TYPE_STOP then
			theFrame.drawPolygon(thePoints,aCommand.lineColour);
			thePoints.clear;
		elseif aCommand.type = CM_GraphicCommand.TYPE_STOP_FILL then
		//cnwjo3 ccms 1018. terrible hack.  If the label/description is 'NoChange'
		//then don't attempt to change the fillcolour (for example for
		//consignee's, iso types, voyages etc...)
			if _fillColour = NullColour or aCommand.label = app.getErrorString(Nochange) then
				theFrame.drawFillColor := aCommand.fillColour;
			else
				theFrame.drawFillColor := _fillColour;
			endif;
			
			theFrame.drawFilledPolygon(thePoints,aCommand.lineColour);
			thePoints.clear;
		elseif aCommand.type = CM_GraphicCommand.TYPE_DRAW then
			if _flippedH then
				//cnwjo3
				theX := _offsetX + (_max - (_scale * aCommand.x1)).Integer  ;
				theY := (_scale * aCommand.y1).Integer + _offsetY;
			else
				theX := (_scale * aCommand.x1).Integer + _offsetX;
				theY := (_scale * aCommand.y1).Integer + _offsetY;
			endif;
			
			//cnwjo3 par 22965
			if  aCommand.x1 &gt; _stretchStartPointX then		
				theX := theX + _stretchOffset;	
			endif;
			
			thePoints.add(theX);
			thePoints.add(theY);
			
		endif;
	endforeach;
epilog
	delete thePoints;


end;</source>
        <access>protected</access>
        <Parameter name="_frame" type="Frame"/>
        <Parameter name="_scale" type="Real"/>
        <Parameter name="_offsetX" type="Integer"/>
        <Parameter name="_offsetY" type="Integer"/>
        <Parameter name="_flippedH" type="Boolean"/>
        <Parameter name="_max" type="Integer"/>
        <Parameter name="_stretchOffset" type="Integer"/>
        <Parameter name="_stretchStartPointX" type="Integer"/>
        <Parameter name="_fillColour" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="drawText" id="8e0ad6f4-9fc1-4d85-b649-60c3c9e6b686">
        <source>drawText(	_frame : Frame input; 
			_txtCommand : CM_GraphicCommand;
			_text : String;
			_ti 	: CM_TrackedItem;
			_offsetX: Integer; 
			_offsetY: Integer; 
			_scale: Real; 
			_fillColour : Integer);
// ---------------------------------------------------------------------------
// Created:		06 December 2005  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// 10/11/2011	cnmwh5 	#28439 - Font size can't be &lt; 1 so add .max(1) when calculating font size
vars
	theLine : String;
	fntSize : Integer;
//	icons : StringArray;
begin
	if _txtCommand = null then	
		return;
	endif;
	return;
	theLine := _text;
	if theLine = null then
		theLine := _txtCommand.label;
	endif;
	_frame.drawTextAlign := Frame.DrawTextAlign_Left;
	_frame.fontName := "Arial";	
	_frame.drawFontSize := (((_txtCommand.y1-_txtCommand.y2).abs * _scale)*.5).max(1);		// 10/11/2011 cnwmh5 #28439
	_frame.fontBold := true;
	
//	if _ti &lt;&gt; null then
//		create icons transient;
//		//_ti.getAllDrawingIcons(icons);
//		_ti.getAllDrawingIconsByPriority(icons);		// 8/12/17 MAP TFS7493
//	endif;
	
	_frame.drawTextAt(theLine,((_txtCommand.x1  * _scale) + _offsetX),(_offsetY  + (_txtCommand.y1  * _scale)) ,_fillColour.getInverseColour());

epilog
//	delete icons;
end;</source>
        <Parameter name="_frame" type="Frame" usage="input"/>
        <Parameter name="_txtCommand" type="CM_GraphicCommand"/>
        <Parameter name="_text" type="String"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_offsetX" type="Integer"/>
        <Parameter name="_offsetY" type="Integer"/>
        <Parameter name="_scale" type="Real"/>
        <Parameter name="_fillColour" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getClearWidth" id="a78c714c-baf7-43db-aafd-704c34135e5f">
        <source>getClearWidth(): Integer;
// --------------------------------------------------------------------------------
// Created:		10 March 2010 by cnwjo3
//
// Purpose:		Trailers have a GraphicCommand called 'Clear Width'.  It appears
//				This value should be ignored when stretching....  need to get this
//				value for YRD_RoRoLaneDrawingController::drawTIBehaviourGraphic
//
vars
	aGraphic : CM_Graphic;
	aCommand : CM_GraphicCommand;
	theCommands : CM_GraphicArray;
begin
	theCommands := self.allCommands;
	
	foreach aGraphic in theCommands do
		aCommand := aGraphic.CM_GraphicCommand;
		
		if aCommand.type = CM_GraphicCommand.TYPE_CLEARWIDTH then
			return aCommand.x1;
		endif;
	endforeach;

	return 0;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getCommands" id="f74e571a-ce74-4f51-a1cf-bc9564a4eea9">
        <source>getCommands(theType: Integer): CM_GraphicArray;
// ---------------------------------------------------------------------------
// Created:		01 December 2005  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	return self.allCommands;

end;</source>
        <Parameter name="theType" type="Integer"/>
        <ReturnType type="CM_GraphicArray"/>
    </JadeMethod>
    <JadeMethod name="getDrawHeight" id="b4eb1e56-de39-4622-ac7f-54e947450c4d">
        <source>getDrawHeight() : Integer;
// ---------------------------------------------------------------------------
// Created:		05 December 2005  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

	aGraphic : CM_Graphic;
	theCommands : CM_GraphicArray;
	aCommand : CM_GraphicCommand;
	theX, theY : Integer;
	clearHeight : Integer;
begin
	theCommands := self.getCommands(0);
	foreach aGraphic in theCommands do
		aCommand := aGraphic.CM_GraphicCommand;
		
		if aCommand.type = CM_GraphicCommand.TYPE_CLEARHEIGHT then
			clearHeight := aCommand.y1;
		endif;
	endforeach;	
	
	if clearHeight = 0 then
		clearHeight := self.maxY;
	endif;
	return clearHeight;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getDrawWidth" id="1cc44152-af3e-4d96-9cc4-f4d872be4bee">
        <source>getDrawWidth() : Integer;
// ---------------------------------------------------------------------------
// Created:		7 December 2005  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

	aGraphic : CM_Graphic;
	theCommands : CM_GraphicArray;
	aCommand : CM_GraphicCommand;
	theX, theY : Integer;
	clearHeight : Integer;
begin
	theCommands := self.getCommands(0);
	foreach aGraphic in theCommands do
		aCommand := aGraphic.CM_GraphicCommand;
		
		if aCommand.type = CM_GraphicCommand.TYPE_CLEARWIDTH then
			clearHeight := aCommand.x1;
			break;
		endif;
	endforeach;	
	
	if clearHeight = 0 then
		clearHeight := self.maxX;
	endif;
	return clearHeight;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getStretchXY" id="eff1c5f3-16ef-496a-a6d5-521e7366616e">
        <source>getStretchXY(theType: Integer; _stretchX: Integer output; _stretchY: Integer output) : CM_GraphicCommand;

vars
	aGraphic : CM_Graphic;
	aCommand : CM_GraphicCommand;
	theCommands : CM_GraphicArray;
begin
	theCommands := self.allCommands;
	
	foreach aGraphic in theCommands do
		aCommand := aGraphic.CM_GraphicCommand;
		
		if aCommand.type = CM_GraphicCommand.TYPE_STRETCHXY then
			_stretchX := aCommand.x1;
			_stretchY := aCommand.y1;
			return aCommand;
		endif;
	endforeach;
	
	return null;
end;</source>
        <Parameter name="theType" type="Integer"/>
        <Parameter name="_stretchX" type="Integer" usage="output"/>
        <Parameter name="_stretchY" type="Integer" usage="output"/>
        <ReturnType type="CM_GraphicCommand"/>
    </JadeMethod>
    <JadeMethod name="getTextCommand" id="9124a507-7e7d-411b-a4e6-540ef715dc36">
        <source>getTextCommand() : CM_GraphicCommand;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 May 2012	cnwer1	Initial creation CCMS MES 1035

*/

vars
	command : CM_Graphic;
begin
	foreach command in self.allCommands do
		if command.CM_GraphicCommand.type = CM_GraphicCommand.TYPE_TEXT_POS then
			return command.CM_GraphicCommand;
		endif;
	endforeach;
	
	return null;
epilog

end;</source>
        <ReturnType type="CM_GraphicCommand"/>
    </JadeMethod>
    <JadeMethod name="getXMLData" id="cf0a3080-8f3f-41f1-9037-1b531d053d8f">
        <source>getXMLData() : String;
// ---------------------------------------------------------------------------
// Created:		November 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	theCommands : CM_GraphicArray;
	aGraphic : CM_Graphic;
	aCommand : CM_GraphicCommand;
	theAML,theBML,theFML,theXML : String;
begin
	theXML := "";
	theXML := "&lt;maxX&gt;" &amp; self.maxX.String &amp; "&lt;/maxX&gt;";
	theXML := theXML &amp; "&lt;maxY&gt;" &amp; self.maxY.String &amp; "&lt;/maxY&gt;";
	theXML := theXML &amp; "&lt;TIBTYPE&gt;" &amp; self.myTIBehaviour.behaviourType.String &amp; "&lt;/TIBTYPE&gt;";
	
	theXML := theXML &amp; "&lt;COMMANDS&gt;";
	foreach aGraphic in self.allCommands do
		aCommand := aGraphic.CM_GraphicCommand;
		theXML := theXML &amp; aCommand.getXMLData();
	endforeach;
	theXML := theXML &amp; "&lt;/COMMANDS&gt;";
	
	
	return theXML;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setForUpdateGraphic" id="62f66fb1-f3b5-4be2-be67-d859a82edb90">
        <updating/>
        <source>setForUpdateGraphic(_theController : CMIF_GraphicCommandController ) updating;
// ---------------------------------------------------------------------------
// Created:		November 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	theType : Integer;
	theCommands : CM_GraphicArray;
	pxyCommand : CM_Graphic;
	aCommand : CM_GraphicCommand;
	maxX, maxY : Integer;
begin
	theType := _theController.type;
	
	theCommands := self.allCommands;

	if theCommands = null then
		return;
	endif;
	
	theCommands.purge;
	
	foreach pxyCommand in _theController.allGraphicCommands do
		aCommand := pxyCommand.cloneSelf(false).CM_GraphicCommand;
		aCommand.myTIBehaviourGraphic := self;

		if aCommand.type = CM_GraphicCommand.TYPE_DRAW 
		or aCommand.type = CM_GraphicCommand.TYPE_CLEARHEIGHT then
			maxX := maxX.max(aCommand.x1);
			maxY := maxY.max(aCommand.y1);
		else
			maxX := maxX.max(aCommand.x2);
			maxY := maxY.max(aCommand.y2);
		endif;
	endforeach;

	self.maxX := maxX;
	self.maxY := maxY;
end;</source>
        <Parameter name="_theController" type="CMIF_GraphicCommandController"/>
    </JadeMethod>
    <JadeMethod name="setXMLData" id="1ef11cf6-7d74-4050-90ed-dab5bc81aaa1">
        <updating/>
        <source>setXMLData(_theXMLData : String) updating;
// ---------------------------------------------------------------------------
// Created:		November 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
//	PAR 1896 - remove begin/commit
//
// ---------------------------------------------------------------------------

vars
	theXMLTagValue, theXMLData : String;
	pos: Integer;
	aCommand : CM_GraphicCommand;
	newXMLTagValue : String;
	i : Integer;
	char : Character;	
begin
	self.allCommands.purge;

	theXMLTagValue := _theXMLData.cnEcGetTagValueOfName("maxX"); 
	self.maxX := theXMLTagValue.Integer;
	theXMLTagValue := _theXMLData.cnEcGetTagValueOfName("maxY"); 
	self.maxY := theXMLTagValue.Integer;

	theXMLData := _theXMLData.cnEcGetTagValueOfName("COMMANDS"); 

	pos := 1;
	while (pos &gt; 0) do
		theXMLTagValue := theXMLData.cnEcGetNextTagValueOfName("CMD",pos); 
		if theXMLTagValue = null then
			break;
		endif;
		
		create aCommand;
		
		//cnwjo3 par 22609
		foreach i in 1 to theXMLTagValue.length do
			char := theXMLTagValue[i:1].Character;
			if char = Lf or char = Cr then
				//ignore it, don't put new line characters in XML Tag value
			else
				newXMLTagValue := newXMLTagValue &amp; char;
			endif;
		endforeach;
		aCommand.setXMLData(newXMLTagValue);
		newXMLTagValue := "";
		//aCommand.setXMLData(theXMLTagValue);
		
		aCommand.myTIBehaviourGraphic := self;
	endwhile;

end;</source>
        <Parameter name="_theXMLData" type="String"/>
    </JadeMethod>
</Class>
