    <JadeMethod name="loadInterfaceHistory" id="88b9a5d5-5dbf-485e-a327-57a931051f61">
        <source>loadInterfaceHistory( _size : Integer ) protected;

/*

Purpose:		This method will load up to the required number of CM_InterfaceHistory instances for this machine

Date				Who		Reason
18 May 2009			cnwrl1	Initial creation as part of PAR 19668 - CCMS 1814 - Interface History

*/
	
vars
	theForm		: SOP_TableMaintForm;
	machine		: CM_Machine;
	
begin
	// use local copies to decrease dereferencing
	theForm	:= self.myForm;
	machine	:= theForm.myCurrentObject.CM_Machine;
	
	self.populateInterfaceHistoryColl( machine, _size );

	
	theForm.shtViewTable3.caption	:= app.getErrorString2(	Interface_History_Of,
															self.allMachineInterfaceHistories.size.display,
															machine.allInterfaceHistories.size.display );
	
	self.displayInterfaceHistory;
	
	if machine &lt;&gt; null then
		self.myForm.btnPrintHistory.enabled	:= not machine.allInterfaceHistories.isEmpty;
		self.myForm.btnExtractHist.enabled	:= not machine.allInterfaceHistories.isEmpty;
	endif;
	
epilog
	
end;
</source>
        <access>protected</access>
        <Parameter name="_size" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="loadMoveHistory" id="add9f867-662d-44e9-a20c-b890667065ac">
        <source>loadMoveHistory( _size : Integer ) protected;

vars
	theForm	: SOP_TableMaintForm;
	machine	: CM_Machine;
	
begin
	theForm := self.myForm;
	machine := theForm.myCurrentObject.CM_Machine;
	
	//cnwmc5 - added 'if' statement for par 29955
	if machine = null then
		return;
	endif;
	
	self.populateMoveHistoryColl( machine.history, _size );
	
	theForm.shtViewTable1.caption	:= app.getErrorString2(	Move_History_Of,
															self.allMachineMoveHistory.size.display,
															machine.history.size.display );
	
	self.displayMoveHistory();
	
	if machine &lt;&gt; null then
		self.myForm.btnPrintHistory.enabled	:= not machine.history.isEmpty;
		self.myForm.btnExtractHist.enabled	:= not machine.history.isEmpty;
	endif;
	
end;</source>
        <access>protected</access>
        <Parameter name="_size" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="populateInterfaceHistoryColl" id="3ee34c7c-50e7-4a34-9e8b-86421a4a831d">
        <source>populateInterfaceHistoryColl( _machine : CM_Machine; _size : Integer ) protected;

/*

Purpose:		This method will load up to the required instances of CM_InterfaceHistory.

Date				Who		Reason
18 May 2009			cnwrl1	Initial creation as part of PAR 19668 - CCMS 1814 - Interface History

*/
	
vars
	count				: Integer;
	isAll				: Boolean;
	iter				: Iterator;
	interfaceHistory	: CM_InterfaceHistory;
	
begin
	self.allMachineInterfaceHistories.clear;
	if _machine = null then
		return;
	endif;
	
	isAll	:= _size = null;
	iter	:= _machine.allInterfaceHistories.createIterator;
	
	// read in reverse order to get the latest at the top of the form.
	while iter.back( interfaceHistory ) do
		count := count + 1;
		if count &gt; _size and not isAll then
			break;
		endif;
		self.allMachineInterfaceHistories.add( interfaceHistory );
	endwhile;
	
epilog
	delete iter;
	
end;
</source>
        <access>protected</access>
        <Parameter name="_machine" type="CM_Machine"/>
        <Parameter name="_size" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="populateMoveHistoryColl" id="fd8c529b-8159-4292-b0e7-8758f8196018">
        <source>populateMoveHistoryColl( _allHistory : CM_MachineHistoryByDateTime; _size : Integer ) protected;

// cnwdvb1 09 July 2003 
vars
	iter 	: Iterator;
	history	: CM_MachineHistory;
	count,
	size	: Integer;
	isAll	: Boolean;
	
begin
	size := _size;
	if size = 0 then
		size := JadeTableRowLimit;
		//isAll := true;
	endif;

	self.allMachineMoveHistory.clear();
	iter := _allHistory.createIterator();
	while iter.back(history) do 
		count := count + 1;
		if (count &gt; size and (not isAll)) then
			break;
		endif;
		self.allMachineMoveHistory.add(history);
	endwhile;
	
epilog
	delete iter;
end;</source>
        <access>protected</access>
        <Parameter name="_allHistory" type="CM_MachineHistoryByDateTime"/>
        <Parameter name="_size" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="populateTAMaster" id="1712fc5e-bcc4-44a7-b168-12e1e11a01fc">
        <source>populateTAMaster();
/*

Purpose:			


Return Value:		


Date		Who		Reason
12 Sep 2006	cnwer1	Initial creation - PAR#xxxx
13 Dec 2011	cnwer1	PAR 28714 - in terminal Area maint RTG areas can add IMVS - so here IMVs should be able to see RTG areas
*/
vars
	ta : CM_TerminalAreaMaster;
	machineType : CM_MachineType;
begin
	machineType:=self.myForm.cmbMachineType.listObject.CM_MachineType;
	self.allTerminalAreaMasters.clear;
	foreach ta in self.myForm.myTerminal.allTerminalAreas discreteLock do
		
		if machineType &lt;&gt; null and machineType.type = MACHINETYPE_RMG then
			if not ta.type = TA_TYPE_RMG and
				not ta.type = TA_TYPE_RAILWAY_TRACK then
				continue;
			endif;
		endif;
		
		if machineType &lt;&gt; null and machineType.type = MACHINETYPE_RTG then
			if not ta.type = TA_TYPE_RTG then
				continue;
			endif;
		endif;
		
		//epr par 28714 13/12/11
		if machineType &lt;&gt; null  then
			
			if ta.type = TA_TYPE_RTG and (machineType.type &lt;&gt; MACHINETYPE_RTG and machineType.type &lt;&gt; MACHINETYPE_IMV) then
				continue;
			endif;
			
			if ta.type = TA_TYPE_RMG and (machineType.type  &lt;&gt; MACHINETYPE_RMG and machineType.type &lt;&gt; MACHINETYPE_IMV) then
				continue;
			endif;
		endif;
		

		
		// 14/03/2011 cnwar2 #27062
		if not app.isSpecial()
		and ta.type = TA_TYPE_SWAP then
			continue;
		endif;
		
		self.allTerminalAreaMasters.add(ta);
	endforeach;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setControlsForAddEdit" id="f24c8e1f-4c47-40c4-931a-f3fbdabc94c1">
        <updating/>
        <source>setControlsForAddEdit() updating;

vars
	theForm : SOP_TableMaintForm;	
	visibleRows 	: EntTableRowArray;	//11 July 2016	NDL	TFS 2118
begin
    theForm := self.myForm;
	
	theForm.tblInput1.userInputEnabled := true;
	theForm.tblInput2.userInputEnabled := true;
	
	theForm.mulSelect1.userInputEnabled := true;
	theForm.mulSelect2.userInputEnabled := true;
	
	// CMS 1438
	theForm.mulSelect3.userInputEnabled := true;	
	theForm.mulAlign1.readOnly	:= false;
	theForm.btnSetDefault1.enabled := true;
	theForm.btnSetDefault2.enabled := true;
			
	//ccms 1750 cnwrd1 23.12.2008
	theForm.tblInput1.disableRowByName(ETRow_LastKnownLocation);
	theForm.tblInput1.disableRowByName(ETRow_LastKnownTimestamp);
	
	theForm.cmbMachPhyStart.clear;
	theForm.cmbMachPhysEnd.clear;
	
	if theForm.mode = theForm.Mode_Add then
	
		theForm.myAssistant.comboBoxMachineType(theForm.cmbMachineType, null);
		theForm.myAssistant.comboBoxCraneArea(theForm.cmbCraneArea, null, theForm.myTerminal);
		theForm.myAssistant.comboBoxRFIDTag(theForm.cmbRFIDTag, theForm.myTerminal,null);
		//ccms 1595
		theForm.myAssistant.comboBoxMchLiftType(theForm.cmbMchLiftType, null, null);
		theForm.tblInput1.clearValues;
		theForm.tblInput2.clearValues;
		theForm.tblInput1.enableRowByName(ETRow_Id);
		theForm.tblInput1.enableRowByName(ETRow_Description);
		theForm.tblInput1.disableRowByName(ETRow_Ports);
		theForm.tblInput1.enableRowByName(ETRow_MachineType);
		theForm.shtViewTable1.visible := false;
		theForm.shtViewTable2.visible := false;
		theForm.shtViewTable3.visible := false;			// cnwrl1 19/05/2009 PAR 19668 - CCMS 1814
		theForm.btnPrintHistory.enabled	:= false;		// cnwrl1 20/05/2009 PAR 19668 - CCMS 1814
		theForm.btnExtractHist.enabled	:= false;		// cnwrl1 20/05/2009 PAR 19668 - CCMS 1814
		theForm.mulSelect1.setSelected(null);
		theForm.mulSelect2.setSelected(null);
		// CMS 1438
		theForm.mulSelect3.setSelected(null);
		theForm.mulAlign1.setSelected(null);
//		theForm.tblInput1.setFocus;
		theForm.tblInput1.moveFirst();
		// call this last as sets cell input type (case etc)
		// if not called can get problems with case on entry. 
		theForm.tblInput1.gotFocus(theForm.tblInput1);		
		self.showHideRowsForRT(false,null);
	//	theForm.myAssistant.comboBoxMachineType(theForm.cmbMachineType, app.myRoot.allMachineTypes[0]);
	
		//11 July 2016	NDL	TFS 2118
		theForm.resetMeasurementRows( theForm.tblInput1 );
		self.setConvertedDisplayValue( theForm.tblInput1, ETRow_MaxLiftWeight,  0, self.weightType );
		self.setConvertedDisplayValue( theForm.tblInput1, ETRow_TareWeight,  0, self.weightType );
		self.setConvertedDisplayValue( theForm.tblInput1, ETRow_WeightDifference,  0, self.weightType ); 
		self.setConvertedDisplayValue( theForm.tblInput1, ETRow_BucketVolume,  0, app.getDefaultMeasurementForType(Type_Volume) );
		create visibleRows transient;
		theForm.tblInput1.myEntTableDef.allEntTableRows.copy( visibleRows );
		theForm.loadMeasurementTypes( theForm.tblInput1, theForm.tblInput1.myEntTableDef.name, visibleRows, true );
	
	else
		// refresh the data from the newly created proxy
		self.showThumbnail(theForm.myProxyObject.CM_Machine);
		// cannot update code		
		theForm.tblInput1.disableRowByName(ETRow_Id);
		theForm.tblInput1.enableRowByName(ETRow_Description);
		theForm.tblInput1.disableRowByName(ETRow_Ports);
		theForm.tblInput1.disableRowByName(ETRow_MachineType);
		theForm.shtViewTable1.visible := false;
		theForm.shtViewTable2.visible := false;
		theForm.shtViewTable3.visible := false;			// cnwrl1 19/05/2009 PAR 19668 - CCMS 1814
		theForm.btnPrintHistory.enabled	:= false;		// cnwrl1 20/05/2009 PAR 19668 - CCMS 1814
		theForm.btnExtractHist.enabled	:= false;		// cnwrl1 20/05/2009 PAR 19668 - CCMS 1814
	endif;

epilog

	delete visibleRows;	//11 July 2016	NDL	TFS 2118
	
end;</source>
    </JadeMethod>
    <JadeMethod name="setCtrlsForView" id="14c09a4a-94bc-4af2-8f9e-48f4ac44d270">
        <updating/>
        <source>setCtrlsForView() updating;

vars

	theForm : SOP_TableMaintForm;

begin
	inheritMethod();    
	theForm := self.myForm;
	theForm.tblInput1.userInputEnabled := false;
	theForm.tblInput2.userInputEnabled := false;
	theForm.shtViewTable1.visible := true;
	theForm.shtViewTable2.visible := true;
	theForm.shtViewTable3.visible := not theForm.myTerminal.allInterfaceDefinitions.isEmpty;	// cnwrl1 21/05/2009 PAR 19668 - CCMS 1814
	theForm.mulAlign1.readOnly  := true;	
	theForm.btnSetDefault1.enabled := false;
	theForm.btnSetDefault2.enabled := false;
end;</source>
    </JadeMethod>
    <JadeMethod name="setupContextMenuItems" id="526e292a-2ac7-4f6a-8a3c-00c0bb165b36">
        <updating/>
        <source>setupContextMenuItems( conwin : Window input ) updating;


vars
	tempStr		: String;
	theForm 	: SOP_TableMaintForm;
	tmpMenu		: MenuItem;
	bVisible	: Boolean;
	machine : CM_Machine;
	errMsg : String;	//08 Jan 2018	NDL	TFS 36437

begin
	inheritMethod( conwin );
	theForm := self.myForm;
	
	theForm.mnuPrintHistory.visible		:= false;			// cnwrl1 14/05/2009 PAR 19668 - CCMS 1814
	theForm.mnuExtractHistory.visible	:= false;
	
	if conwin = theForm.tblView2 then
	   theForm.mnuContext4.visible := true;
	   theForm.mnuContext4.caption := app.getErrorString( Clear_Selected_RT_Task );
	elseif conwin = theForm.tblDataView1 or conwin = theForm.tblDataView3 then
		if conwin = theForm.tblDataView1 then
			tempStr		:= app.getErrorString( Moves );
			bVisible	:= theForm.tblDataView1.rows &gt; theForm.tblDataView1.fixedRows;
			theForm.mnuPrintHistory.visible	:= bVisible;
		else
			tempStr		:= app.getErrorString( Messages );
			bVisible	:= theForm.tblDataView3.rows &gt; theForm.tblDataView3.fixedRows;
			theForm.mnuExtractHistory.visible	:= bVisible;
			theForm.mnuPrintHistory.visible		:= bVisible;
		endif;
		theForm.mnuContext1.visible	:= true;
		theForm.mnuContext1.caption	:= app.getErrorString2( Display_Last, self.Last_500.display, tempStr );
		theForm.mnuContext2.visible	:= true;
		theForm.mnuContext2.caption	:= app.getErrorString2( Display_Last, self.Last_5000.display, tempStr );
		theForm.mnuContext3.visible	:= true;
		theForm.mnuContext3.enabled	:= true;	// par 23801 - this guy was expecting menu to always be enabled &amp;^&amp;*^*^*^&amp;*^
		theForm.mnuContext3.caption	:= app.getErrorString1( Display_All, tempStr );
	// cnwrl1 19/05/2009 PAR 19668 - CCMS 1814 - end of coding
	endif;
	
	theForm.mnuContext5.enabled := false;
	theForm.mnuContext5.visible := true;
	theForm.mnuContext5.caption := app.getErrorString(Weigh_machine);
	if theForm.mode &lt;&gt; theForm.Mode_Add then
		machine := theForm.myProxyObject.CM_Machine;
		if machine = null then
			machine := theForm.myCurrentObject.CM_Machine;
		endif;
		if machine &lt;&gt; null and machine.isWeighBridgeWeighable( null, errMsg ) then
			theForm.mnuContext5.enabled := true;
		endif;
	endif;
	
	//06 Apr 2016	NDL	TFS 1667
	theForm.mnuContext6.enabled := false;
	theForm.mnuContext6.visible := false;
//	theForm.mnuContext6.caption := app.getErrorString1(LogOffMachine,machine.id);
	machine := theForm.myProxyObject.CM_Machine;
	if machine = null then
		machine := theForm.myCurrentObject.CM_Machine;
	endif;
	if machine &lt;&gt; null and not machine.hasRadioTelemetry and machine.loggedOn then
		theForm.mnuContext6.enabled := true;
		theForm.mnuContext6.visible := true;
	endif;
	
	if machine &lt;&gt; null then //20 Feb 2017	NDL	- observed 1090
		theForm.mnuContext6.caption := app.getErrorString1(LogOffMachine,machine.id);
	endif;
	
		// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(theForm.myTerminal, self.permissionMaint) then
		return;
	endif;

	tmpMenu := theForm.cloneMenu( theForm.mnuTblVCloneDataTbl, theForm.mnuContext6, false );	
	
	tmpMenu := theForm.cloneMenu( theForm.mnuTblVCloneDataTbl, theForm.mnuContext5, false ); 
	tmpMenu := theForm.cloneMenu( theForm.mnuTblVCloneDataTbl, theForm.mnuContext4, false ); 	
	tmpMenu := theForm.cloneMenu( theForm.mnuTblVCloneDataTbl, theForm.mnuContext3, false ); 	
	tmpMenu := theForm.cloneMenu( theForm.mnuTblVCloneDataTbl, theForm.mnuContext2, false ); 	
	tmpMenu := theForm.cloneMenu( theForm.mnuTblVCloneDataTbl, theForm.mnuContext1, false ); 	
	tmpMenu := theForm.cloneMenu( theForm.mnuTblVCloneDataTbl, theForm.mnuExtractHistory, false );	// cnwrl1 20/05/2009 PAR 19668 - CCMS 1814 - start of coding
	tmpMenu := theForm.cloneMenu( theForm.mnuTblVCloneDataTbl, theForm.mnuPrintHistory, false );
	
end;</source>
        <Parameter name="conwin" type="Window" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setupInterfaceHistorySheet" id="9fa5e478-7bcc-48dd-82d0-f39890695157">
        <source>setupInterfaceHistorySheet( _theForm : SOP_TableMaintForm io ) protected;

/*

Purpose:		
Parameters:		
Return Value:	

Date				Who		Reason
15 May 2009			cnwrl1	Initial creation as part of PAR 19668 - CCMS 1814 - Interface History

*/
	
vars
	table		: CM_DataTable;
	fixedRow	: Integer;
	column		: Integer;
	
begin
	_theForm.shtViewTable3.caption	:= app.getErrorString( InterfaceHistory );
	table							:= _theForm.tblDataView3;
	table.clear;
	table.visible					:= true;
	table.readOnly					:= true;
	table.fixed3D					:= false;
	table.optimiseRowHeight			:= true;
	table.stretchHeight				:= true;
	table.stretchWidth				:= true;	
	table.fixedRows					:= 1;
	table.rows						:= table.fixedRows + 1;
	table.fixedColumns				:= 0;
	table.columns					:= table.fixedColumns + 9;
	table.stretchToParent			:= true;
	table.wordWrap					:= true;
	
	// table headings
	fixedRow									:= table.fixedRows;
	column										:= table.fixedColumns + 1;
	table.accessCell( fixedRow, column ).text	:= app.getErrorString( Request_DateTime );
	table.accessColumn( column ).alignment		:= Table.Alignment_Right;
	column										:= column + 1;
	table.accessCell( fixedRow, column ).text	:= app.getErrorString( Response_Time );
	table.accessColumn( column ).alignment		:= Table.Alignment_Right;
	column										:= column + 1;
	table.accessCell( fixedRow, column ).text	:= app.getErrorString( Elapsed_Time_msec );
	table.accessColumn( column ).alignment		:= Table.Alignment_Right;
	column										:= column + 1;
	table.accessCell( fixedRow, column ).text	:= app.getErrorString( Response_Status );
	table.accessColumn( column ).alignment		:= Table.Alignment_Center;
	column										:= column + 1;
	table.accessCell( fixedRow, column ).text	:= app.getErrorString( Interface );
	column										:= column + 1;
	table.accessCell( fixedRow, column ).text	:= app.getErrorString( CM_User_Code );
	column										:= column + 1;
	table.accessCell( fixedRow, column ).text	:= app.getErrorString( Interface_Function );
	column										:= column + 1;
	table.accessCell( fixedRow, column ).text	:= app.getErrorString( Request_Data );
	column										:= column + 1;
	table.accessCell( fixedRow, column ).text	:= app.getErrorString( Response_Data );
	
epilog
	
end;
</source>
        <access>protected</access>
        <Parameter name="_theForm" type="SOP_TableMaintForm" usage="io"/>
    </JadeMethod>
    <JadeMethod name="setupPhysicalLimitCombos" id="48627c53-d96f-4a4a-9fa2-8ac3b52f47ad">
        <source>setupPhysicalLimitCombos(pMachine : CM_Machine);
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
23 September 2009	cnwer1	Initial creation

*/

vars
	theForm : SOP_TableMaintForm;
begin
	theForm:=self.myForm;
	self.doComboPhysicalLimits(theForm.cmbMachPhyStart);
	self.doComboPhysicalLimits(theForm.cmbMachPhysEnd);
	if pMachine = null then
		return;
	endif;
	
	if pMachine.myPhysicalStartBay &lt;&gt; null then
		theForm.cmbMachPhyStart.findObjectFromListCollection( pMachine.myPhysicalStartBay);
		theForm.tblInput1.setValueByName(ETRow_PhysicalLimitStart, pMachine.myPhysicalStartBay.getFullID(false));
	endif;
	if pMachine.myPhysicalEndBay &lt;&gt; null then
		theForm.cmbMachPhysEnd.findObjectFromListCollection( pMachine.myPhysicalEndBay);
		theForm.tblInput1.setValueByName(ETRow_PhysicalLimitEnd, pMachine.myPhysicalEndBay.getFullID(false));
	endif;
epilog

end;</source>
        <Parameter name="pMachine" type="CM_Machine"/>
    </JadeMethod>
    <JadeMethod name="setupThumbnailDefaults" id="10cc1af0-8f28-4249-a0b5-779c8641498d">
        <source>setupThumbnailDefaults();
// ---------------------------------------------------------------------------
// Created:     10 January 2006	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars
	form	:SOP_TableMaintForm;
begin
	form := self.myForm;
	
	inheritMethod();
	
	form.btnPrintHistory.visible	:= true;
	form.btnExtractHist.visible		:= true;			// cnwrl1 20/05/2009 PAR 19668 - CCMS 1814
	form.btnTwistlock.visible		:= true;
	form.btnAddDelay.visible		:= true;			// cnwcs5 01/04/2011 ccms 1132
	form.btnAddDelay.enabled		:= true;			// cnwcs5 01/04/2011 ccms 1132
	form.btnDelaysEnquiry.visible	:= true;			// cnwcs5 01/04/2011 ccms 1132
	form.btnDelaysEnquiry.enabled	:= true;			// cnwcs5 01/04/2011 ccms 1132

	
	form.frmToolbar.positionToolbarControls();
		

end;</source>
    </JadeMethod>
    <JadeMethod name="setupThumbnailDetails" id="b3113021-81b9-4c00-82e4-68c3528bdeba">
        <source>setupThumbnailDetails();

/*

Date		Who		Reason
11 Jun 2009	cnwkpd1	PAR #19844 - Correct spelling on Machine maintenance form
24/11/2010	cnwcs5	par 23714/ccms 1132 - extra column for machine histopry remarks
07/12/2010	cnwcs5	par 23714/ccms 1132 - selection style for history table
*/

vars
	form 	: SOP_TableMaintForm;
	table	: CM_DataTable;
begin
	form := self.myForm;
	
	form.useProxyObject := true;
	form.setTblDataEntRows(ETDef_MachineTbl);
	//12/01/2011 cnwdz2 25840
	//form.zClearSortColumns();
	//form.zAddSortColumn(ETRow_Id, false);

	form.shtTblInput1.caption := app.getErrorString( Machine_Details );		// cnwrl1 20/05/2009 PAR 19668 - CCMS 1814
	form.initTblInput(form.tblInput1, ETDef_MachineMaint);
	form.shtTblInput1.visible := true;

	form.shtTblInput2.caption := app.getErrorString( CM_Radio_Telemetry );	// cnwrl1 20/05/2009 PAR 19668 - CCMS 1814
	form.initTblInput(form.tblInput2, ETDef_MachineRT);
	form.shtTblInput2.visible := true;

	form.shtViewTable1.caption := app.getErrorString( Move_History );		// cnwrl1 20/05/2009 PAR 19668 - CCMS 1814
	
	table := form.tblDataView1;
	
	table.visible := true;
	table.readOnly := true;

	table.clear;
	table.fixed3D 			:= false;
	table.optimiseRowHeight := true;
	table.stretchHeight 	:= true;
	table.stretchWidth 		:= true;	
	table.rows 				:= 2;
	table.fixedRows 		:= 1;
	table.columns 			:= 8;	// cnwcs5 24/11/2010 par 23714/ccms 1132
	table.fixedColumns 		:= 0;
	table.stretchToParent 	:= true;

	table.selectionType 	:= CM_DataTable.SelectionType_Row;
	table.selectMode 		:= CM_DataTable.SelectMode_FixedRow;
	table.multiSelect 		:= CM_DataTable.MultiSelect_Simple;
		
	self.doColumnHeadingsHistoryTbl();
	
	// Interface History sheet is set up in this method.
	self.setupInterfaceHistorySheet( form );	// cnwrl1 14/05/2009 PAR 19668 - CCMS 1814
	
	form.shtViewTable2.caption := app.getErrorString( Rejected_Tasks );		// cnwrl1 20/05/2009 PAR 19668 - CCMS 1814
	form.initTblView(form.tblView2);
	form.tblView2.visible := true;
	form.tblView2.columns := 3;
	form.tblView2.selectMode := Table.SelectMode_Row;
	form.tblView2.accessMode := Table.AccessMode_Row;
	form.tblView2.multiSelect := CM_BaseTable.MultiSelect_Simple;
	form.tblView2.selectionType := CM_BaseTable.SelectionType_Row;
	
	form.fldInput.topSheet := form. shtTblInput1;
		
	
	form.shtMultiAlign.caption := app.getErrorString( Secondary_Queues );	// cnwrl1 20/05/2009 PAR 19668 - CCMS 1814
	form.shtMultiAlign.visible := true;
	form.mulAlign1.availableHeading := app.getErrorString(Secondary_queues_available);		//cnwmc5
	form.mulAlign1.selectedHeading  := app.getErrorString(Secondary_queues_selected);		// PAR #19844	//cnwmc5
	form.mulAlign1.formDisplayEntryMethodName := SOP_TableMaintForm::displayEntryRTQueues.name;
	form.mulAlign1.displayOrderBtns(true, true);
	form.mulAlign1.myBaseForm	:= form;
	form.mulAlign1.mySelectedListBox.sorted := false;
	form.mulAlign1.cnEcResizeContents();
	form.mulAlign1.myAvailableListBox.listObject := null; 
	
	form.btnSetDefault1.caption := app.getErrorString(Default_machine_type);		//cnwmc5
	form.btnSetDefault2.caption := app.getErrorString(Default_machine_type);		//cnwmc5
	
	form.shtTblInput1.tabIndex		:= 0;
	form.shtTblInput2.tabIndex		:= 1;
	form.shtViewTable1.tabIndex		:= 2;
	form.shtViewTable3.tabIndex		:= 3;
	form.shtViewTable2.tabIndex		:= 4;
	form.shtMultiSelect1.tabIndex	:= 5;
	form.shtMultiSelect2.tabIndex	:= 6;
	form.shtMultiAlign.tabIndex		:= 7;
	
	form.shtTblInput1.cnEcResizeContents();
	form.shtTblInput2.cnEcResizeContents();
	form.shtViewTable2.cnEcResizeContents();
end;</source>
    </JadeMethod>
    <JadeMethod name="sheetChange" id="731a79e4-e119-4e80-b3a9-11c666adea97">
        <updating/>
        <source>sheetChange( folder : Folder input ) updating;
// ---------------------------------------------------------------------------
// Created:     16 June 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	theTable	: CM_DataTable;
	theForm		: SOP_TableMaintForm;
	
begin

	theForm							:= self.myForm;
	theForm.shtViewTable1.caption	:= app.getErrorString(	Move_History );
	theForm.shtViewTable3.caption	:= app.getErrorString(	InterfaceHistory );
	
	if folder.topSheet &lt;&gt; theForm.shtViewTable1 and folder.topSheet &lt;&gt; theForm.shtViewTable3 then
		theForm.btnPrintHistory.enabled	:= false;
		theForm.btnExtractHist.enabled	:= false;
		return;
	endif;
	
	if folder.topSheet = theForm.shtViewTable1 then
		theForm.btnExtractHist.enabled	:= false;
		self.loadMoveHistory( self.Last_500 );
		theTable	:= theForm.tblDataView1;
	else
		self.loadInterfaceHistory( self.Last_500 );
		theTable	:= theForm.tblDataView3;
	endif;
	
	theTable.parent	:= folder.topSheet;
	folder.topSheet.cnEcResizeContents();
	
end;</source>
        <Parameter name="folder" type="Folder" usage="input"/>
    </JadeMethod>
    <JadeMethod name="showHideRowsForMachine" id="a1d8c8b4-370a-4249-86b2-90c53dbd61b9">
        <source>showHideRowsForMachine(_machine : CM_Machine);
// ---------------------------------------------------------------------------
// Created:		25 March 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------

vars
	ta 			: CM_TerminalAreaMaster;

begin
	self.showHideRowsForMachineType(_machine.machineType);							
	// cnwrd1 30953 - for RMG/RTG etc we have limited the list of allowable TA's, but these machines can be added on the TA confic side of the relationship
	// if we dont add them back  in here when we save we remove them from the TA and this causes issues for things like road jobs
	foreach ta in _machine.allowedTAMasters discreteLock do
		if not self.allTerminalAreaMasters.includes(ta) then
			self.allTerminalAreaMasters.add(ta);
		endif;
	endforeach;		
	self.setupMultiSelect1(	app.getErrorString( Terminal_Areas_Access ),
							self.allTerminalAreaMasters,
							SOP_TableMaintForm::displayEntryTerminalArea.name );
	
	
	self.showHideRowsForRT(_machine.hasRadioTelemetry,_machine.machineType);
	self.showRowsForTwinLift(_machine.machineLiftType = TWIN_LIFT,_machine.machineType);
end;</source>
        <Parameter name="_machine" type="CM_Machine"/>
    </JadeMethod>
    <JadeMethod name="showHideRowsForMachineType" id="74aa39cf-40e2-4f8b-9903-d2342c5e8d89">
        <source>showHideRowsForMachineType(_type : Integer);
/*

Purpose:			

Parameters:			

Return Value:		


Date			Who		Reason
21 August 2009	cnwer1	Initial creation
14 May 2018		jlgmd1	TFS #38555 MSL - Portainer Crane in RT

*/

vars
	machineType : CM_MachineType;
	tbl1 : CM_EntryTable;
	theForm : SOP_TableMaintForm;	
begin
	theForm := self.myForm;
	tbl1 := self.myForm.tblInput1;

	machineType:= app.myRoot.allMachineTypes[_type];
	theForm.shtTblInput2.enabled := machineType.supportsRT;	// TFS 38555
	
	
	tbl1.hideRowByName(ETRow_MaxLiftWeightTL, false);	// CCMS 1061 CentrePort
	tbl1.hideRowByName(ETRow_MinItemsForTLJob, false);
	tbl1.hideRowByName(ETRow_WeightDifference, false);	//CCMS JMT 1032, Par18649. Dec 2008
	tbl1.hideRowByName(ETRow_RmgInteraction, false);
	tbl1.hideRowByName(ETRow_LoadingPosition, false);
	tbl1.hideRowByName(ETRow_BucketVolume,false);
	
	if _type = MACHINETYPE_PORTAINER_CRANE then//CCMS 1595
		
		tbl1.showRowByName(ETRow_TransferAreaId, false);
		tbl1.showRowByName(ETRow_MachineLiftType, false);
		tbl1.showRowByName(ETRow_WeightDifference, false);	//14 June 2010	NDL Par 24108
		
		tbl1.showRowByName(ETRow_RatePerHourOvD, false);//par 22065 begin
		tbl1.showRowByName(ETRow_RatePerHourSLOD, false);
		tbl1.showRowByName(ETRow_RatePerHourSLUD, false);
		tbl1.showRowByName(ETRow_RatePerHourTLOD, false);
		tbl1.showRowByName(ETRow_RatePerHourTLUD, false);//par 22065 end
		
		tbl1.showRowByName(ETRow_TargetRatePH, false);
		tbl1.showRowByName(ETRow_JobSeed, false);
		
		tbl1.showRowByName(ETRow_JobTypeBoomUp, false);
		tbl1.showRowByName(ETRow_JobTypeLidRemove, false);
		tbl1.showRowByName(ETRow_JobTypeLidReplace, false);
		tbl1.showRowByName(ETRow_JobTypeLongTravel, false); // PAR 20474

		tbl1.hideRowByName(ETRow_MaxStackHeightFull, false);
		tbl1.hideRowByName(ETRow_MaxStackHeightEmpty, false);

		
	
	else
		tbl1.showRowByName(ETRow_MaxStackHeightFull, false);
		tbl1.showRowByName(ETRow_MaxStackHeightEmpty, false);
		
	
		tbl1.hideRowByName(ETRow_TransferAreaId, false);
		tbl1.hideRowByName(ETRow_MachineLiftType, false);
		
		tbl1.hideRowByName(ETRow_RatePerHourOvD, false);//par 22065 begin
		tbl1.hideRowByName(ETRow_RatePerHourSLOD, false);
		tbl1.hideRowByName(ETRow_RatePerHourSLUD, false);
		tbl1.hideRowByName(ETRow_RatePerHourTLOD, false);
		tbl1.hideRowByName(ETRow_RatePerHourTLUD, false);//par 22065 end
		
		tbl1.hideRowByName(ETRow_TargetRatePH, false);
		tbl1.hideRowByName(ETRow_JobSeed, false);
		tbl1.hideRowByName(ETRow_JobTypeBoomUp, false);
		tbl1.hideRowByName(ETRow_JobTypeLidRemove, false);
		tbl1.hideRowByName(ETRow_JobTypeLidReplace, false);
		tbl1.hideRowByName(ETRow_JobTypeLongTravel, false); // PAR 20474
		tbl1.hideRowByName(ETRow_AccessMaxHeightDiff, false); // epr tfs 37584 27/4/18
		tbl1.hideRowByName(ETRow_AccessMaxLocationReach, false); // epr tfs 37584 27/4/18
		tbl1.hideRowByName(ETRow_AccessMaxOverstowHeight, false); // epr tfs 37584 27/4/18
		
		if machineType.hasMachineLiftType then	//CCMS JMT 1032, Par18649. Dec 2008
			tbl1.showRowByName(ETRow_MachineLiftType, false);
			tbl1.showRowByName(ETRow_WeightDifference, false);
		endif;
		if _type = MACHINETYPE_RMG then
			tbl1.showRowByName(ETRow_RmgInteraction, false);
			tbl1.showRowByName(ETRow_LoadingPosition, false);
		elseif _type = MACHINETYPE_FORK_LIFT then //epr par 20429 16/10/09
			tbl1.showRowByName(ETRow_MachineLiftType, false);
			tbl1.showRowByName(ETRow_BucketVolume,false);
			tbl1.showRowByName(ETRow_AccessMaxHeightDiff, false); // epr tfs 37584 27/4/18
			tbl1.showRowByName(ETRow_AccessMaxLocationReach, false); // epr tfs 37584 27/4/18
			tbl1.showRowByName(ETRow_AccessMaxOverstowHeight, false); // epr tfs 37584 27/4/18
		elseif _type = MACHINETYPE_TOP_LIFT or _type = MACHINETYPE_SIDE_LOADER then
			tbl1.showRowByName(ETRow_AccessMaxHeightDiff, false); // epr tfs 37584 27/4/18
			tbl1.showRowByName(ETRow_AccessMaxLocationReach, false); // epr tfs 37584 27/4/18
			tbl1.showRowByName(ETRow_AccessMaxOverstowHeight, false); // epr tfs 37584 27/4/18
		endif;
		
	endif;	
	
	//ccms 1076 2/9/09 rmg machines can only see rmg areas so need to change the list when machine type changes
	self.initShtMultiSelect1();

epilog

end;</source>
        <Parameter name="_type" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="showHideRowsForRT" id="335f0b3c-7835-4e5b-a400-b3b2571ba479">
        <source>showHideRowsForRT(_hasRadioTelemetry : Boolean; _machineType : Integer);
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21 August 2009	cnwer1	Initial creation

*/

vars
	tbl2,tbl1 : CM_EntryTable;
	theForm : SOP_TableMaintForm;	
begin
	theForm := self.myForm;
	tbl2 := theForm.tblInput2;
	tbl1:=	theForm.tblInput1;
	theForm.btnTwistlock.enabled:=_machineType = MACHINETYPE_RTG and _hasRadioTelemetry;
	theForm.shtViewTable2.enabled := _hasRadioTelemetry;
	theForm.shtMultiSelect1.enabled := _hasRadioTelemetry;
	theForm.shtMultiSelect2.enabled := _hasRadioTelemetry;
	// CCMS 1438
	theForm.shtMultiSelect3.enabled := _hasRadioTelemetry;
	theForm.shtMultiAlign.enabled := _hasRadioTelemetry;
	tbl2.disableRowByName(ETRow_RadioTelemetryDevice);
	if _hasRadioTelemetry then
		tbl2.enableRowByName(ETRow_MaxRejectedTasks);	
		if _machineType =  MACHINETYPE_RMG then
			tbl1.showRowByName(ETRow_PhysicalLimitStart,false);
			tbl1.showRowByName(ETRow_PhysicalLimitEnd,false);
		else
			tbl1.hideRowByName(ETRow_PhysicalLimitStart,false);
			tbl1.hideRowByName(ETRow_PhysicalLimitEnd,false);
		endif;
	else

		tbl2.disableRowByName(ETRow_MaxRejectedTasks);
		tbl2.setValueByName(ETRow_MaxRejectedTasks, 0);
		tbl1.hideRowByName(ETRow_PhysicalLimitStart,false);
		tbl1.hideRowByName(ETRow_PhysicalLimitEnd,false);
	endif;
	tbl2.optimiseTableHeight;
	tbl1.optimiseTableHeight;
	
	
epilog

end;</source>
        <Parameter name="_hasRadioTelemetry" type="Boolean"/>
        <Parameter name="_machineType" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="showRowsForTwinLift" id="4d7569f4-e4c5-4836-9695-3afe4c3c76b0">
        <source>showRowsForTwinLift(_isTwinLift : Boolean; _machineType : Integer);
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21 August 2009	cnwer1	Initial creation

*/

vars

	tbl1 : CM_EntryTable;
	theForm : SOP_TableMaintForm;	
begin
	theForm := self.myForm;
	tbl1 := self.myForm.tblInput1;
		/*
	// CCMS 1061 CentrePort*/

	if _machineType = MACHINETYPE_PORTAINER_CRANE and 
		_isTwinLift then
		tbl1.showRowByName(ETRow_MaxLiftWeightTL, false);
		tbl1.showRowByName(ETRow_MinItemsForTLJob, false);
	endif;
	
	
	
	
epilog

end;</source>
        <Parameter name="_isTwinLift" type="Boolean"/>
        <Parameter name="_machineType" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="showThumbnail" id="4626f8ee-f2e6-4718-9975-db3184fca221">
        <updating/>
        <source>showThumbnail(pMachine : CM_Machine) updating;
// 27/11/2014   cnwma1      PAR #35281 Terminal Admin Machines
// 17/12/2015   cnwma1      PAR #37329 System is not saving ship delays and we have a ship in and working
//02 Oct  2018    cnwma1  ChangeRequest 41234: SAP Integration - Mapping fields
vars
	tmpJT			: CM_JobType;
	area			: CM_CraneTransferArea;	
	rt		 		: CM_RadioTelemetry;
	tempArray		: CM_RTQueueArray;
	vRFIDTag		: CM_RFIDTag;
	realMachine		: CM_Machine;
	theForm			: SOP_TableMaintForm;
	moveRates 		: CM_CraneMoveRates;
	
begin
   	theForm := self.myForm;
	theForm.tblInput1.clearValues;
	theForm.tblInput2.clearValues;
	
	theForm.tblInput1.setValueByName(ETRow_Id, pMachine.id);
	theForm.tblInput1.setValueByName(ETRow_Description,	pMachine.description);
	theForm.tblInput1.setValueByName(ETRow_MachineType, app.myRoot.allMachineTypes[pMachine.machineType].description);
	theForm.tblInput1.setValueByName(ETRow_CanLift40Foot, pMachine.canLift40Foot);
	theForm.tblInput1.setValueByName(ETRow_CanLift30Foot, pMachine.canLift30Foot); // PAR 16415 CCMS 1029
	theForm.tblInput1.setValueByName(ETRow_CanLift45Foot, pMachine.canLift45Foot); // PAR 16415 CCMS 1029
	theForm.tblInput1.setValueByName(ETRow_CanLift53Foot, pMachine.canLift53Foot); // PAR 16415 CCMS 1029

	theForm.tblInput1.setValueByName(ETRow_Colour, pMachine.colour);
	self.colourColumn := theForm.tblData.getColumnByRowName(ETRow_Colour);	
	theForm.tblInput1.setValueByName(ETRow_Available, pMachine.available);
	
	theForm.tblInput1.setValueByName(ETRow_MaxStackHeightFull, pMachine.maxHeightFull);
	theForm.tblInput1.setValueByName(ETRow_MaxStackHeightEmpty, pMachine.maxHeightMT);
	theForm.tblInput1.setValueByName(ETRow_NotAvailableForEntry, pMachine.isNotAvailableForEntry);
	theForm.tblInput1.setValueByName(ETRow_LastKnownTimestamp,pMachine.lastKnownTimeStamp.asStringJMT);
	theForm.tblInput1.setValueByName(ETRow_LastKnownLocation, pMachine.getLastKnowLocationString);
	
	//13 Mar 2014	NDL	Par 33268
	self.setConvertedDisplayValue( theForm.tblInput1, ETRow_MaxLiftWeight,  pMachine.maxLiftWeight, self.weightType );
	self.setConvertedDisplayValue( theForm.tblInput1, ETRow_TareWeight,  pMachine.tareWeight, self.weightType );
	self.setConvertedDisplayValue( theForm.tblInput1, ETRow_WeightDifference,  pMachine.weightDifference, self.weightType );  // + cnwma1 28/11/2014  PAR 335281
	self.setConvertedDisplayValue( theForm.tblInput1, ETRow_BucketVolume,  pMachine.bucketVolume, app.getDefaultMeasurementForType(Type_Volume) );
	//epr Tfs 37584 27/4/18
	theForm.tblInput1.setValueByName(ETRow_AccessMaxHeightDiff, pMachine.accessMaxHeightDiff);
	theForm.tblInput1.setValueByName(ETRow_AccessMaxLocationReach, pMachine.accessMaxLocationReach);
	theForm.tblInput1.setValueByName(ETRow_AccessMaxOverstowHeight, pMachine.accessMaxOverstowHeight);
	theForm.tblInput1.setValueByName(ETRow_ExternalRef,	pMachine.externalRef);  //02.10.2018 cnwma1 TFS #41234
	vRFIDTag:=pMachine.myRFIDTag;
	if pMachine.isTransient then 
		realMachine:=app.myProxyManager.getRealObject(pMachine).CM_Machine;
		if realMachine &lt;&gt; null then
			vRFIDTag:=realMachine.myRFIDTag;
		endif;
	endif;
	
	//if pMachine.machineType = MACHINETYPE_PORTAINER_CRANE then
	if self.myForm.cmbJobType_3.listCount() = 0 then
		self.doComboJobTypeBuild(self.myForm.cmbJobType_1);
		self.doComboJobTypeBuild(self.myForm.cmbJobType_2);
		self.doComboJobTypeBuild(self.myForm.cmbJobType_3);
		self.doComboJobTypeBuild(self.myForm.cmbJobType_4); // PAR 20474
	endif;
	
	self.myForm.cmbOrganisation.setObject( pMachine.myOwner );	//15 May 2018	NDL	TFS 38570
	self.myForm.tblInput1.setValueByName(ETRow_Owner, self.myForm.cmbOrganisation.text );	//15 May 2018	NDL	TFS 38570
	
	if pMachine.isKindOf(CM_Crane) then
		theForm.tblInput1.setValueByName(ETRow_MinItemsForTLJob, pMachine.CM_Crane.minItemsForTLJob);
		theForm.tblInput1.setValueByName(ETRow_MaxLiftWeightTL, pMachine.CM_Crane.maxLiftWeightTL);
		area := pMachine.CM_Crane.transferArea;		
		if area &lt;&gt; null then 
			theForm.tblInput1.setValueByName(ETRow_TransferAreaId, area.id);	
		endif;
		theForm.tblInput1.setValueByName(ETRow_JobSeed, pMachine.CM_Crane.jobSeed);
		theForm.tblInput1.setValueByName(ETRow_TargetRatePH, pMachine.CM_Crane.targetRatePH);
		
		moveRates := pMachine.CM_Crane.myMoveRate;		//par 22065 begin
		if moveRates &lt;&gt; null then
			theForm.tblInput1.setValueByName(ETRow_RatePerHourOvD, moveRates.getRatePerHourOD);
			theForm.tblInput1.setValueByName(ETRow_RatePerHourSLOD, moveRates.getRatePerHourSLOD);
			theForm.tblInput1.setValueByName(ETRow_RatePerHourSLUD, moveRates.getRatePerHourSLUD);
			theForm.tblInput1.setValueByName(ETRow_RatePerHourTLOD, moveRates.getRatePerHourTLOD);
			theForm.tblInput1.setValueByName(ETRow_RatePerHourTLUD, moveRates.getRatePerHourTLUD);
		endif;		//par 22065 end

		tmpJT := pMachine.CM_Crane.allHatchJobTypes.getAtKey(CM_Crane.HatchJobType_BoomUp);
		if tmpJT &lt;&gt; null then
			theForm.tblInput1.setValueByName(ETRow_JobTypeBoomUp, tmpJT.name);
		endif;
		theForm.cmbJobType_1.listObject := tmpJT;


		tmpJT := pMachine.CM_Crane.allHatchJobTypes.getAtKey(CM_Crane.HatchJobType_LidRemove);
		if tmpJT &lt;&gt; null then
			theForm.tblInput1.setValueByName(ETRow_JobTypeLidRemove, tmpJT.name);
		endif;
		theForm.cmbJobType_2.listObject := tmpJT;

		tmpJT := pMachine.CM_Crane.allHatchJobTypes.getAtKey(CM_Crane.HatchJobType_LidReplace);
		if tmpJT &lt;&gt; null then
			theForm.tblInput1.setValueByName(ETRow_JobTypeLidReplace, tmpJT.name);
		endif;
		theForm.cmbJobType_3.listObject := tmpJT;

		tmpJT := pMachine.CM_Crane.allHatchJobTypes.getAtKey(CM_Crane.HatchJobType_LongTravel);
		if tmpJT &lt;&gt; null then
			theForm.tblInput1.setValueByName(ETRow_JobTypeLongTravel, tmpJT.name);
		endif;
		theForm.cmbJobType_4.listObject := tmpJT;
	endif;

	theForm.tblInput2.setValueByName(ETRow_HasRadioTelemetry, pMachine.hasRadioTelemetry);
	theForm.tblInput2.setValueByName(ETRow_MaxRejectedTasks, pMachine.maxRejectedTasks);
	theForm.tblInput2.setValueByName(ETRow_CanWeighBoxes, pMachine.canWeighCargo);
	theForm.tblInput2.setValueByName(ETRow_CanCertifyWeight, pMachine.canCertifyWeight);		// TFS 2357 14/07/2016
	theForm.tblInput2.setValueByName(ETRow_RadioTelemetryDevice, pMachine.getRTDeviceId());
		
	theForm.myAssistant.comboBoxCraneArea(theForm.cmbCraneArea, area, theForm.myTerminal);
	theForm.myAssistant.comboBoxMachineType(theForm.cmbMachineType, app.myRoot.allMachineTypes[pMachine.machineType]);
	theForm.myAssistant.comboBoxRFIDTag(theForm.cmbRFIDTag,theForm.myTerminal,vRFIDTag);
	
	//ccms 1595
	//epr ccms 1032 12/2/09 load the combo before setting the lift type value
	theForm.myAssistant.comboBoxMchLiftType(theForm.cmbMchLiftType, pMachine.machineType, pMachine.machineLiftType);
	theForm.tblInput1.setValueByName(ETRow_MachineLiftType, theForm.myAssistant.getMachineLiftType(pMachine.machineLiftType, null));
	
	theForm.myAssistant.comboBoxMachLoadingPos(theForm.cmbMchLoadPos,pMachine.loadingPosition);
	theForm.tblInput1.setValueByName(ETRow_LoadingPosition, pMachine.loadingPosition.toMachLoadingPosString);
	theForm.myAssistant.comboBoxMachInteractionType(theForm.cmbRMGInter,pMachine.interchangeType);
	theForm.tblInput1.setValueByName(ETRow_RmgInteraction, pMachine.interchangeType.toGantryInterchangePosString);
	
	if vRFIDTag &lt;&gt; null then
		theForm.tblInput1.setValueByName(ETRow_RfidTag, vRFIDTag.code);
	endif;
	
	
	if theForm.fldInput.topSheet = self.myForm.shtViewTable1 then
		self.loadMoveHistory( self.Last_500 );
	endif;
	theForm.shtViewTable3.visible:=pMachine.allInterfaceHistories.first &lt;&gt; null;
	// cnwrl1 18/05/2009 PAR 19668 - CCMS 1814 - start of coding
	if theForm.fldInput.topSheet = self.myForm.shtViewTable3 then
		self.loadInterfaceHistory( self.Last_500 );
	endif;
	// cnwrl1 18/05/2009 PAR 19668 - CCMS 1814 - end of coding
	
	theForm.tblView2.displayCollection(pMachine.rejectedRTQueueTasks, false, Table.DisplayCollection_Reversed, null);
	theForm.tblView2.allSelectedObjects.clear;
	
	if pMachine.hasRadioTelemetry then
		rt := theForm.myTerminal.radioTelemetry;
	if rt &lt;&gt; null then
		create tempArray transient;
		theForm.allQueues.clear();
		rt.masterQueue.getAllQueuesForMachineType(pMachine.machineType,tempArray);   //getAllQueues(tempArray);
		tempArray.copy(theForm.allQueues);
		theForm.mulAlign1.setAvailable(theForm.allQueues, true);
	endif;
		theForm.mulAlign1.setSelected(pMachine.allQueues);
	else
		theForm.mulAlign1.setSelected(null);
	endif;
	
	
	
	theForm.mulSelect2.setSelected(pMachine.allAllowedCargoTypes);
	
	// CCMS 1438
	
	theForm.mulSelect3.setSelected(pMachine.allAllowableContentsStatuses);
	
	
	self.showHideRowsForMachine(pMachine);
	
	//epr 14/9/06 changed from allowedTerminalAreas to allowedTAMasters
	theForm.mulSelect1.setSelected(pMachine.allowedTAMasters);
	if pMachine.machineType = MACHINETYPE_RMG then
		self.setupPhysicalLimitCombos(pMachine);
	endif;
	
	if pMachine.isNotAvailableForEntry then        // 17/12/2015  cnwma1 PAR #37329
		theForm.btnAddDelay.enabled := false;
	else
		theForm.btnAddDelay.enabled := true;
	endif;
		// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(theForm.myTerminal, self.permissionMaint) then
		theForm.btnPrintHistory.enabled	:= false;
		theForm.btnExtractHist.enabled		:= false;	
		theForm.btnTwistlock.enabled		:= false;
		theForm.btnAddDelay.enabled		:= false;		
		theForm.btnDelaysEnquiry.enabled	:= false;	

	endif;

	theForm.tblInput1.optimiseTableHeight;
	theForm.resize;
epilog
	delete tempArray;
end;</source>
        <Parameter name="pMachine" type="CM_Machine"/>
    </JadeMethod>
    <JadeMethod name="tblDataShowDataSpecial" id="d8e860af-53c8-4a01-b2cb-c8693b52b5d7">
        <source>tblDataShowDataSpecial(_idxRow: Integer; _obj: Object);
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 October 2009	cnwer1	Initial creation Par 20429

*/

vars
	machine : CM_Machine;
	cell : JadeTableCell;
begin

	machine := _obj.CM_Machine;
	if(_idxRow &lt;&gt; 1) then
		if colourColumn &gt; 0 then	
			cell := myForm.tblData.accessCell(_idxRow,colourColumn);
			cell.text := null;
			cell.backColor := machine.colour;	
		endif;
	endif;

epilog

end;</source>
        <Parameter name="_idxRow" type="Integer"/>
        <Parameter name="_obj" type="Object"/>
    </JadeMethod>
    <JadeMethod name="tblView1DisplayRow" id="f69a7d4b-081d-495b-8e1a-899b479e86fa">
        <updating/>
        <source>tblView1DisplayRow(table: Table input; theSheet: Integer; obj: Object; theRow: Integer; bcontinue: Boolean io): String updating;
// ---------------------------------------------------------------------------
// Created:     26 October 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	hist	: CM_MachineHistory;
begin

	hist := obj.CM_MachineHistory;

	return hist.getDisplayString();
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="theSheet" type="Integer"/>
        <Parameter name="obj" type="Object"/>
        <Parameter name="theRow" type="Integer"/>
        <Parameter name="bcontinue" type="Boolean" usage="io"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="tblView2DisplayRow" id="717e514d-2d57-4a84-a5db-ed70e4edfca8">
        <updating/>
        <source>tblView2DisplayRow(table: Table input; theSheet: Integer; obj: Object; theRow: Integer; bcontinue: Boolean io): String updating;
// ---------------------------------------------------------------------------
// Created:     26 October 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	task	: CM_RTQueueTask;

begin

	task := obj.CM_RTQueueTask;
	if not global.isValidObject(task) then
		return null;
	endif;
	
	return task.queueId &amp; Tab &amp;
		   task.tiId &amp; Tab &amp;
		   task.taskTypeId &amp; Tab &amp;
		   task.sourceLocationId &amp; Tab &amp;
		   task.targetLocationId &amp; Tab &amp;
		   task.statusString;

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="theSheet" type="Integer"/>
        <Parameter name="obj" type="Object"/>
        <Parameter name="theRow" type="Integer"/>
        <Parameter name="bcontinue" type="Boolean" usage="io"/>
        <ReturnType type="String"/>
    </JadeMethod>
</Class>
