    <JadeMethod name="resizeCheckButtons" id="b939a6a2-4723-4be1-98cc-37d72abb160f">
        <source>resizeCheckButtons() protected;
/*

Date		Who		Reason
20 August 2014	cnwer1	Initial creation PAR

*/
constants
	Margin = 5;
vars
	allButtons : ObjectArray;
	buttonObj	: Object;
	theHeight,
	theWidth 	: Integer;
	row : Integer;
begin
	create allButtons transient;
	
	if app.myCurrentUserCan(app.myVMAgent.myTerminal,PmHHDamageReport) then
		allButtons.add(self.btnDamage);
		self.btnDamage.visible:=true;
	else 
		self.btnDamage.visible:=false;
	endif;
	//epr par 25049 15/7/10
	if app.myCurrentUserCan(app.myVMAgent.myTerminal, PmHHGrading) then
		allButtons.add(self.btnGrading);
		self.btnGrading.visible:=true;
	else 
		self.btnGrading.visible:=false;
	endif;
	if app.myCurrentUserCan(app.myVMAgent.myTerminal,PmHHMaintainStops) then
		allButtons.add(self.btnStops);
		self.btnStops.visible:=true;
	else 
		self.btnStops.visible:=false;
	endif;
	
	if app.myCurrentUserCan(app.myVMAgent.myTerminal,PmHHMaintainTasks) then
		allButtons.add(self.btnToDo);
		self.btnToDo.visible:=true;
	else 
		self.btnToDo.visible:=false;
	endif;
	
	if allButtons.isEmpty then
		self.shtChecks.visible:=false;
		return;
		
	endif;
	
	theHeight:=self.btnAccept.clientHeight;
	theWidth:=self.btnDamage.getTextExtent(self.btnDamage.caption) + (Margin * 8);
	row:=1;
	foreach buttonObj in allButtons do
		buttonObj.Button.width:=theWidth;
		buttonObj.Button.height:=theHeight;
		buttonObj.Button.top:=((row-1) * theHeight) + (row * 5);
		row:=row+1;
	endforeach;
	
epilog
	delete allButtons;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="resizeControls" id="156635cc-cf0f-468e-8c91-1214299584c1">
        <source>resizeControls();
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 June 2010	cnwer1	Initial creation

*/
constants
	Margin = 5;
vars
	theHeight,
	theWidth,
	newTop 	: Integer;
	acceptCaption : String;
begin
		
	acceptCaption:=app.getErrorString(Accept);
	theHeight:=self.btnAccept.getTextHeight(acceptCaption);
	theHeight:= theHeight + (Margin *2);
	//ACCEPT &amp; REJECT BUTTONS should be same width;
	theWidth:=self.btnAccept.getTextExtent(acceptCaption).max(theWidth);
	theWidth:=self.btnAccept.getTextExtent(app.getErrorString(GetNext)).max(theWidth);
	theWidth:=self.btnAccept.getTextExtent(app.getErrorString(Pickup)).max(theWidth);
	theWidth:=self.btnAccept.getTextExtent(app.getErrorString(Setdown)).max(theWidth);
	theWidth:=theWidth + (Margin *2);
	// bottom frame buttons
	// don't have to set top position these are center aligned
	self.btnAccept.height:=theHeight;
	self.btnReject.height:=theHeight;
	self.btnLogoff.height:=theHeight;
	self.btnPickup.height:=theHeight;
	self.btnSetdown.height:=theHeight;
	self.frmBottom.height:=theHeight + (Margin *2);
	self.btnCanDir.height:=theHeight;
	self.btnPickupDir.height:=theHeight;
	self.frmDirector.height:=theHeight + (Margin *2);

	self.grpAccept.height:= self.frmBottom.height;
	self.grpWorking.height:=self.grpAccept.height;
	self.grpAccept.left:=0;
	self.grpWorking.left:=0;
	self.btnMoreTasks.height:=theHeight;
	self.btnWorking.height:=theHeight;
	//epr CCMS HAT 2200 26/10/12
	//buttons on the top frame
	// set top because these are bottom aligned
	newTop:=self.frmTop.clientHeight - theHeight - Margin;

	self.btnSearch.height:=theHeight;
	self.btnSearch.top:=newTop;
	self.btnSearchReset.height:=theHeight;
	self.btnSearchReset.top:=newTop;
	self.txtSearch.height:=theHeight;
	self.txtSearch.top:=newTop;
	
	self.frmTop.height:= + theHeight + (Margin *2);
	self.frmTopDirector.height:=self.frmTop.clientHeight;

	self.btnAccept.width:=theWidth;
	//self.btnMoreTasks.left:= self.btnAccept.left + theWidth + Margin;
	self.btnWorking.left:= self.btnAccept.left + theWidth + Margin;
	self.btnLogoff.width:=theWidth;
	self.btnPickup.width:=theWidth;
	self.btnReject.width:=theWidth;
	self.btnSetdown.width:=theWidth;
	self.btnPickupDir.width:=theWidth;
	self.btnCanDir.width:=theWidth;
	self.btnCanDir.left:=self.btnPickupDir.left + theWidth + Margin;

	self.btnSearchMode.height:=self.btnSearch.height;
	self.btnSearchMode.top := self.btnSearch.top;
	self.btnSearchDir.height:=self.btnSearch.height;
	self.btnSearchDir.top := self.btnSearch.top;
	
	self.tblDirector.top:= self.frmTopDirector.clientHeight + Margin;
	self.tblDirector.parentAspect:=Table.ParentAspect_None;

	self.resizeCheckButtons();
	self.resizeTaskDetails();
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="resizeTaskDetails" id="d3e1270a-a87f-470d-82d4-da33e48b406e">
        <source>resizeTaskDetails();
/*

Date		Who		Reason
21 August 2014	cnwer1	Initial creation PAR

*/
constants
	Margin = 10;
vars
	theWidth : Integer;
	leftValue : Integer;
begin
	theWidth:=self.lblAmount.getTextExtent(self.lblAmount.caption);
	theWidth:=theWidth + (Margin );
	self.lblAmount.width :=  theWidth;
	self.lblSource.width := theWidth;
	self.lblTarget.width:=theWidth;
	
	leftValue:=self.lblAmount.left.Integer + theWidth + Margin;
	self.lblTaskSource.left:= leftValue;
	self.lblTaskTarget.left:=leftValue;
	self.txtTarget.left:=leftValue;
	self.txtQuantity.left:=leftValue;
	self.tblWeight.left:=leftValue;
	self.doResizeTaskDetails();
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="searchDirectorTasks" id="882e8002-9135-4d52-a469-43947aae95e4">
        <source>searchDirectorTasks() protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
30 Apr 2010	cnwer1	Initial creation
20 Sep 2010 cnwer1	PAR 25542 
*/

vars
	id : String;
	firstFoundRow,
	row : Integer;
	ti 		: CM_TrackedItem;
begin
	id:=self.txtSearchDir.text.toUpper;
	
	if self.tblDirector.rows = self.tblDirector.fixedRows then
		//self.checkIDForDirectorTask(id); //cnwrd1 par 27812 2.8.2011
		return;
	endif;
	self.tblDirector.row:=1;
	row := 2;
	while row &lt;= self.tblDirector.rows do
		
		ti :=self.tblDirector.accessRow(row).itemObject.CM_TrackedItem;
		if ti = null then
			row := row + 1;
			continue;
		endif;
		if id.length &lt;= ti.id.length then
		//epr par 25004 14/7/10
			if not ti.id.pos(id,1) &gt; 0 then
				self.tblDirector.accessRow(row).visible:=false;
			else
				if firstFoundRow = 0 then
					firstFoundRow:=row;
				endif;
				self.tblDirector.accessRow(row).visible:=true;
			endif;
		
		endif;
		row := row + 1;
	endwhile;

	if firstFoundRow &lt;&gt; 0 then
		self.tblDirector.row:=firstFoundRow;
		self.tblDirector.click(self.tblDirector);
	else
		//self.checkIDForDirectorTask(id); //cnwrd1 par 27812 2.8.2011
	endif;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="searchEnquiry" id="84ff23e3-7e49-4add-a65e-40a53a6278ba">
        <updating/>
        <source>searchEnquiry() updating;
/*

Date		Who		Reason
18 August 2014	cnwer1	Initial creation PAR

*/

vars
	searchTIs		: CM_TISet;
	 maxSearchResults : Integer;
	rtConfig		: CM_RTVehicleConfig;
	ti 				: CM_TrackedItem;
	searchTxt : String;
begin
	self.isEnquiryMode :=true;
	
	if self.frmDirector.visible then
		searchTxt:=self.txtSearchDir.text;
	else
		searchTxt:=self.txtSearch.text;
	endif;
	
	create searchTIs transient;
	//self.getSessionAgent().doSearchItem(self.txtSearch.text, false,true,false , searchTIs );
	self.getSessionAgent().doSearchItem(searchTxt, false,true,false ,0, self.myMachine,searchTIs );//02 Dec 2010	NDL Par 26417
	
	if searchTIs.size = 0 then
		self.txtSearch.setFocus;  //cnwrd1 11.1.11 par 26715
		self.addInfoDisplay(app.getErrorString(No_Matchin_cargo_found_onsite));
		self.isEnquiryMode :=false;
		return;
	endif;
	
	rtConfig := self.myVMAgent.getMyRTVehicleConfig();
	maxSearchResults:=rtConfig.maxNumberSearchResults ;
	if maxSearchResults &gt; 0 and searchTIs.size &gt; maxSearchResults then
		while searchTIs.size &gt; maxSearchResults do
			searchTIs.remove(searchTIs.last);
		endwhile;
	endif;
	
	self.showDirectorFrame();
	
	self.btnPickupDir.visible:= rtConfig.allowNonRTMoves;
	
	foreach ti in searchTIs do
		app.myVMAgent.loadRTTableFromDTORTEntry(self.tblDirector,ti);
	endforeach;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="searchSelectTasks" id="230ebec2-5597-44b4-aa03-5f441d7767d6">
        <source>searchSelectTasks(_table : Table input) protected;
/*

Date		Who		Reason
15 August 2014	cnwer1	Initial creation PAR

*/

vars

	rtConfig			: CM_RTVehicleConfig;
	machine 			: CM_Machine;
	allFoundRTQEntries 	: CM_RTQueueEntryArray;
	queue 				: CM_RadioTelemetryQueue;
	rowCount : Integer;
begin
	rtConfig := self.myVMAgent.getMyRTVehicleConfig();
	machine:= self.myMachine;
	
	create allFoundRTQEntries transient;
	//check primary queue first
	machine.myPrimaryQueue.findEntryForTIorRegNum(self.txtSearch.text, null,self.myMachine,rtConfig.maxNumberSearchResults,allFoundRTQEntries);
	
	//if showing secondary queues check secondary
	if rtConfig.showSecondaryQueues then
		foreach queue in self.myMachine.allQueues do
			if queue = machine.myPrimaryQueue then
				continue;
			endif;
			queue.findEntryForTIorRegNum(self.txtSearch.text, null,self.myMachine,rtConfig.maxNumberSearchResults,allFoundRTQEntries);
		endforeach;
	endif;
	
	if  allFoundRTQEntries.isEmpty then
		self.txtSearch.setFocus;
		self.setSearchModeText();
		app.msgBox( app.getErrorString1(Found_matchin_queued_cargo,0.asStringJMT),"Search Results",MsgBox_OK_Only);
		return;
	endif;
	
	self.clearTableData(_table);
	
	
	app.myVMAgent.loadTableFromRTQueueEntries(_table,allFoundRTQEntries);

	if _table.rows &gt; _table.fixedRows then	 // 21 Dec 2010	NDL	Par 26617
		rowCount := _table.fixedRows + 1;
		self.displayVMTableRow(_table, rowCount, true);
		_table.setFocus;	 // 21 Dec 2010	NDL	Par 26617  
	endif;
epilog
	delete allFoundRTQEntries;

end;</source>
        <access>protected</access>
        <Parameter name="_table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="searchWorkingTasks" id="cf297b20-3309-404a-a08f-d68a70d2f823">
        <source>searchWorkingTasks(_table : Table input) protected;
/*

Date		Who		Reason
18 August 2014	cnwer1	Initial creation PAR

*/

vars
	
	machine 			: CM_Machine;
	rtQueueTask			: CM_RTQueueTask;
	rtQueueEntry 		: CM_RTQueueEntry;
	allFoundRTQEntries 	: CM_RTQueueEntryArray;
	queue 				: CM_RadioTelemetryQueue;
	rowCount : Integer;
begin

	machine:= self.myMachine;

	create allFoundRTQEntries transient;
	if self.txtSearch.text &lt;&gt; null then
		foreach rtQueueTask in self.myMachine.allCurrentQueueTasks do
			if rtQueueTask.matchesTIorRegNum(self.txtSearch.text, null,self.myMachine) then
				allFoundRTQEntries.add(rtQueueTask.myEntry);
			endif;		
		endforeach;
	endif;
	
	if  allFoundRTQEntries.isEmpty then
		self.txtSearch.setFocus;
		self.setSearchModeText();
		app.msgBox( app.getErrorString1(Found_matchin_queued_cargo,0.asStringJMT),"Search Results",MsgBox_OK_Only);
		return;
	endif;
	
	self.clearTableData(_table);
	
	
	app.myVMAgent.loadTableFromRTQueueEntries(_table,allFoundRTQEntries);

	if _table.rows &gt; _table.fixedRows then	 // 21 Dec 2010	NDL	Par 26617
		rowCount := _table.fixedRows + 1;
		self.displayVMTableRow(_table, rowCount, false);
		_table.setFocus;	 // 21 Dec 2010	NDL	Par 26617  
	endif;
epilog
	delete allFoundRTQEntries;

end;</source>
        <access>protected</access>
        <Parameter name="_table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setCaption" id="200b225d-330d-4194-a953-5936d4244b41">
        <updating/>
        <source>setCaption() updating;
/*

Date		Who		Reason
15 July 2016	cnwer1	Initial creation TFS

*/

vars

begin
	self.caption:= self.myMachine.machineTypeString &amp; " " &amp; self.myMachine.id.asStringJMT &amp; " " &amp; app.myVMAgent.myRTQueue.id;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setSearchModeText" id="ca0fdfa4-4f15-4a5a-a318-d3b6cf926b3a">
        <source>setSearchModeText() protected;
/*

Date		Who		Reason
18 August 2014	cnwer1	Initial creation PAR

*/

vars

begin
	if self.searchMode = 0 then
		self.txtSearch.text:="Search Tasks";
	else
		self.txtSearch.text:="Search Cargo";
	endif;
	self.txtSearch.foreColor:=self.txtSearch.getSystemColor(Window.Color_3DShadow);
epilog

end;</source>
