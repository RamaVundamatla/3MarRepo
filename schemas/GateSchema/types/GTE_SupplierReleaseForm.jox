    <JadeMethod name="transferHiding" id="79667cc9-4934-468c-8055-8507c5d011b7">
        <source>transferHiding(_row : Integer) protected;

// cnwdvb1 22 October 2002 

vars

	row : Integer;

begin

	row := self.tblInput1.getRow(ETRow_Transfer);
	if self.myCargoType.id = TI_CargoType_Log then
		if _row = row or self.tblInput1.row =  row then
			self.tblInput1.row := row;
			if self.tblInput1.text.Integer = 0 then
				self.tblInput1.showRowByName(ETRow_MyConsignee, false);
				self.tblInput1.hideRowByName(ETRow_Terminal, false);
			else
				self.tblInput1.hideRowByName(ETRow_MyConsignee, false);
				self.tblInput1.showRowByName(ETRow_Terminal, false);
			endif;
		endif;
		self.tblInput1.adjustHeight(1000);
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="_row" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="d964b4a3-55ac-4e17-bd1f-14afd3ebbe3f">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0005500, locale);
end;</source>
    </JadeMethod>
</GUIClass>
