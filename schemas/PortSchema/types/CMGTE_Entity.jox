    <JadeMethod name="actionForCreate" id="ef54f3ec-a2b2-4828-ac01-85827751a668">
        <updating/>
        <source>actionForCreate(_vvRec : CM_VehicleVisitRecord input; _passport: CM_Passport input; _pxyTI : CM_TrackedItem input): Boolean updating;
// ---------------------------------------------------------------------------
// Created:     25 September 2008 by cnwab1
//
// Changed On   	Changed By  	Reason
// 11/01/2022		navpw1			TFS: 52631 Added Backdating for VVR transactions
//
// ---------------------------------------------------------------------------

vars

begin

	if not self.actionForCreateInternal(_vvRec, _passport, _pxyTI) then	// ### TFS 52631 11Jan2022 NAVPW1
		if _passport.noErrors() and _passport.noWarnings() then // PAR 26482 //cnwrd1 par 26901 7.2.2011 need to check warnings as well as errors
		//if _passport.noErrors() then // PAR 26482 Some has gone wrong but no error created
			app.raiseUnexpectedProgramError(class.name, method.name, 'Failed to create road job, but no user error was created');
		endif;
		self.setForUpdateErrorsFromPassport(_vvRec, _passport);
	endif;
	
	if _passport.hasErrors() then
		return false;
	endif;
	self.changeStatus(CMGTE_Entity.Status_Unactioned);

	return true;

epilog

end;</source>
        <Parameter name="_vvRec" type="CM_VehicleVisitRecord" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <Parameter name="_pxyTI" type="CM_TrackedItem" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="actionForCreateChildren" id="d6076324-798e-4c90-a38e-398c77200c4a">
        <updating/>
        <source>actionForCreateChildren(_vvRec : CM_VehicleVisitRecord input; _passport : CM_Passport input; _pxyTI : CM_TrackedItem input; _moveToParentTrailer : Boolean) : Boolean updating, protected;
//03 September 2009	cnwdw1	
//02 March 2017	cnwma1 TFS #3442:PAR38624 STWR - DoAutoGatein webservice creates duplicate prenoted child items for non-container cargo type
//27 Feb 2018	cnwma1  ChangeRequest 36813: PEN - Gen Sets, Chassis &amp; Reefers
//08 Nov 2019	jlgsl4	TFS 46767 - PEN - GenSet Trailer Linking
//11/01/2022	navpw1	TFS: 52631 Added Backdating for VVR transactions
// 27/03/2023	navkc1	Task CR#57036 57221: Jade - Move New Cargo to Trailer Not Pack
vars
	parentTI, myTI: CM_TrackedItem; // TFS 46767
	info : StringArray512;
begin
	if not self.actionForCreateInternal(_vvRec, _passport, _pxyTI) then
		self.setForUpdateErrorsFromPassport(_vvRec, _passport);
	endif;
	
	if _passport.hasErrors() then
		return false;
	endif;
  
	parentTI := self.myParent.getTI();
	myTI := self.getTI; // TFS 46767 - localise self.getTI
	
	//27.02.2018 cnwma1 ChangeRequest #36813
	if /*self.isKindOf(CMGTE_Generator) and self.getTI*/ myTI &lt;&gt; null then // TFS 46767
		if self.isKindOf(CMGTE_Generator) and parentTI &lt;&gt; null and (parentTI.isReefer or parentTI.isPowered or parentTI.isChassis()) then // TFS 46767 - attach to reefer/powered/ 12/11/2019 - chassis
			parentTI.attachGenerator(/*self.getTI*/ myTI.CM_Generator, _passport); // TFS 46767
			create info transient;
			info.add(app.getErrorString(CM_Generator_GC) &amp;"   "&amp; /*self.getTI*/ myTI.id &amp;app.getErrorString(Attached)); // TFS 46767
			/*self.getTI*/ myTI.createInfomationTransaction( app.getErrorString(CM_Generator_GC) &amp;"   " &amp; /*self.getTI*/ myTI.id &amp;app.getErrorString(Attached) , info, null, _passport); // TFS 46767
			parentTI.createInfomationTransaction( app.getErrorString(CM_Generator_GC)&amp;"   " &amp;/*self.getTI*/ myTI.id &amp;app.getErrorString(Attached), info, null, _passport); // TFS 46767
		//endif; //TFS 46767
	//27.02.2018 cnwma1 ChangeRequest #36813
	//else // TFS 46767
	// cnwjk3 PAR 22502 02/03/10 - only attach if not alredy attached (i.e we are updating)
		elseif _moveToParentTrailer then // 27/03/2023	navkc1	#57221
			myTI.moveToLocation(parentTI.CM_TILC.allLCs.first, null,null,null,0, true,true,false,false,false,true,0,0,null,null,null, app.myPassport);
		elseif /*self.getTI &lt;&gt; null and self.getTI*/ myTI.myParent = null then // TFS 46767
			parentTI.attachChild(/*self.getTI*/ myTI, _passport); // TFS 46767
		endif;
	endif;
	return true;
epilog
delete info;
end;</source>
        <access>protected</access>
        <Parameter name="_vvRec" type="CM_VehicleVisitRecord" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <Parameter name="_pxyTI" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_moveToParentTrailer" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="actionForCreateInternal" id="0db5c3d4-ca7f-43c5-9e37-8097a882c071">
        <updating/>
        <source>actionForCreateInternal(_vvRec : CM_VehicleVisitRecord input; _passport: CM_Passport input; _pxyTI : CM_TrackedItem input): Boolean updating, protected;
// ---------------------------------------------------------------------------
// Created:     25 September 2008 by cnwab1
//
// Changed On   	Changed By  	Reason
// 11/01/2022		navpw1			TFS: 52631 Added Backdating for VVR transactions
//
// ---------------------------------------------------------------------------

vars

begin

	//05 Apr 2013	NDL	Par 31102
	if _passport.noErrors then
		if _pxyTI &lt;&gt; null and _pxyTI.directDelivery then
			app.raiseCMWarning1(Is_Direct_delivery, _pxyTI.id, null, null, null);
		endif;
	endif;
	
	return true;
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_vvRec" type="CM_VehicleVisitRecord" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <Parameter name="_pxyTI" type="CM_TrackedItem" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
