    <JadeMethod name="initialiseCellControl" id="0d9f00d1-42d4-4955-b906-13aff8215764">
        <source>initialiseCellControl(pCell : JadeTableCell input);
// ---------------------------------------------------------------------------
// Created:     08 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	txtBox	: TextBox;

begin

	if pCell.cellControl &lt;&gt; null and pCell.cellControl.isKindOf(TextBox) then
		txtBox := pCell.cellControl.TextBox;
		txtBox.selectionStyle := TextBox.SelectionStyle_SelectAll;
		// This following code is as currently the selectionStyle_SelectAll does
		// not select the text if the user clicks in the cell, only occurs if
		// the user tabs to the cell - RJS 18/9/2002
//		txtBox.selStart  := 0;
//		txtBox.selLength := -1;		// select all the text
		/*		
		if txtBox.maxLength = 0 then
			txtBox.selLength := -1; //txtBox.text.length; - cannot use as still the text for the pervious cell
									  // so set to something large
		else
			txtBox.selLength := txtBox.maxLength;
		endif;
		*/
	endif;

end;</source>
        <Parameter name="pCell" type="JadeTableCell" usage="input"/>
    </JadeMethod>
