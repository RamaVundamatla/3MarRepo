    <JadeMethod name="clearThumbnailData" id="bc5ec809-95eb-4f23-aa94-cb663f054d02">
        <updating/>
        <source>clearThumbnailData() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
					cnwml2 	PAR23715 SFW CCMS 1131
06 April 2023		jlizm1	TFS 57098 EUP Seal numbers on trucks

*/
vars

	theForm : SOP_TableMaintForm;
	coll 		: CM_WagonClassByCodeDict;
	wagonClass 	: CM_WagonClass;

begin
  
	theForm := self.myForm;
	theForm.tblInput1.clearValues();
	self.setupMultiSelect1(app.getString(CargoTypes), app.myRoot.allCargoTypesById, SOP_TableMaintForm::displayEntryCargoType.name);
	
	create coll transient;
	foreach wagonClass in app.myRoot.allWagonClasses where not wagonClass.isNotAvailableForEntry do
		coll.add(wagonClass);
	endforeach;
	
	self.setupMultiSelect2(app.getErrorString(Wagon_class), coll, SOP_TableMaintForm::displayEntryWagonClass.name);

epilog
	delete coll;
	
end;</source>
    </JadeMethod>
