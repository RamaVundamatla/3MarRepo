    <JadeMethod name="doClickShowPosiForm" id="82b9bdca-35b4-4512-aaff-44aa0fbd5904">
        <source>doClickShowPosiForm( wagonClass : CM_WagonClass );

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 July 2009	cnwndl1	Initial creation

*/

vars

	form : SOP_WagonPositionRuleForm;
	
begin

	create form;
	form.setMyRealWagonClass(wagonClass);
	if wagonClass = null then
		form.setParentForm(self.myForm);
	endif;
	form.show;
	
epilog

end;</source>
