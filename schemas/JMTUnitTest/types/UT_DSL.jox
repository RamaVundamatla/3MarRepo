    <JadeMethod name="setInvoiceFinancialClass" id="599e03ae-b506-458e-9645-b64beefa4125">
        <source>setInvoiceFinancialClass(_ioCLass : Class; _exportPath : String);
// setup the current financial export class and optionally export path
vars
	cls : Class;
	extFinance	: CM_ExtFinanceIO;
	theTerminal : CM_Terminal;
begin

	cls := _ioCLass;
	if cls = null then
		cls := CM_DefaultFinanceIO;
	endif;	
	extFinance := cls.firstInstance().CM_ExtFinanceIO;
	if extFinance = null then
		beginTransaction;
		create extFinance as cls persistent;
		extFinance.initialise(app.myRoot.myRootCompany, cls.getNiceName());
		commitTransaction;
	endif;

	beginTransaction;
	if _exportPath &lt;&gt; null then
		extFinance.exportPath := _exportPath;
	endif;
	commitTransaction;
	self.setTerminalConfig(FinancialIOClass, extFinance);
end;</source>
        <Parameter name="_ioCLass" type="Class"/>
        <Parameter name="_exportPath" type="String"/>
    </JadeMethod>
    <JadeMethod name="setManualRate" id="33bf0e09-8fa9-4955-9299-427e7c31646d">
        <source>setManualRate(_charge : CM_Charge; _newRate : Real);
// set the rate on a CM_Charge to a specific value, overriding the debtor/service rate
vars
	theController : CMIF_ChargesController;
	pxyCharge	: CM_Charge;
begin

	create theController transient;
	
	pxyCharge := app.createUpdateProxy(_charge).CM_Charge;
	pxyCharge.setProxyRateNew(_newRate);
	theController.allCharges.add(pxyCharge);

	app.myTrxUA.trxUpdateChargesManual(theController, app.myPassport);

epilog
	foreach pxyCharge in theController.allCharges do 
		delete pxyCharge;
	endforeach;
	
	delete theController;
end;</source>
        <Parameter name="_charge" type="CM_Charge"/>
        <Parameter name="_newRate" type="Real"/>
    </JadeMethod>
    <JadeMethod name="setProxyVoyageVAConfig" id="d74d350d-015f-459c-9fdb-1c3c8d4cebb7">
        <source>setProxyVoyageVAConfig(_pxyVoyage : CM_Voyage);
/*
Purpose:			
Date				Who			Reason
AUGUST 2011		NAVAB1		Initial creation
*/

vars
	opCriteriaColl : CM_YACriteriaTypeArray;
	groupLabelCriteriaColl : CM_YACriteriaTypeArray;
	pxyVoyageAllocationConfig : CM_VoyageAllocationConfig;
	ct :  CM_YACriteriaType;
	ret : Integer;
	vessel				: CM_Vessel;
begin
	if not _pxyVoyage.useVoyageAllocations then  //do create the objects if not needed
		return;
	endif;
	
	create opCriteriaColl transient;
	create groupLabelCriteriaColl transient;
	
	if not self.opts.includesKey("UseVesselAllocations") then				// 25/02/2014 cnwma1 - Copy voyage allocation
	
		ct := CM_YATypeCargoType.firstInstance;
		opCriteriaColl.add(ct);
		ct := CM_YATypeISOGroup.firstInstance;
		opCriteriaColl.add(ct);
		ct := CM_YATypeCommodityGroup.firstInstance;
		opCriteriaColl.add(ct);
		ct := CM_YATypeRequiresPower.firstInstance;
		opCriteriaColl.add(ct);
		ct := CM_YATypeIsOverDimensional.firstInstance;
		opCriteriaColl.add(ct);
		ct := CM_YATypeDischargePort.firstInstance; // this is last so it will be used for the colour
		opCriteriaColl.add(ct);
		
	else
		vessel := self.opts.obj("Vessel").CM_Vessel;
		if vessel = null then
			return;
		endif;
		vessel.myVoyageAllocationConfig.allOpCriteria.copy(opCriteriaColl);
	endif;
	
	if _pxyVoyage.allVoyageAllocationConfigs.isEmpty() then
		create pxyVoyageAllocationConfig transient;
	else
		pxyVoyageAllocationConfig := app.createUpdateProxy(_pxyVoyage.allVoyageAllocationConfigs.first).CM_VoyageAllocationConfig;
	endif;
	
	pxyVoyageAllocationConfig.setProxyVoyage(opCriteriaColl,groupLabelCriteriaColl,Red,ct,_pxyVoyage, null);
	
epilog
	delete opCriteriaColl;
	delete groupLabelCriteriaColl;
end;</source>
        <Parameter name="_pxyVoyage" type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="setServiceRate" id="0a60e5ea-3d89-4e3a-9d4f-e85012b095df">
        <source>setServiceRate(_service : CM_Service; _debtor : CM_DebtorNode; _startDate : Date; _rateValue : Decimal);
// create or update a debtor/service rate for the given start date and rate value
vars
	start,
	expiry : TimeStamp;
	ignoreEntry : Boolean;
	ls : Boolean;
	costs : DecimalArray;
	debtorRate : CM_DebtorRate;
	rateEntry,
	proxyRateEntry	: CM_RateEntry;

begin

	// set service rate
	start.setDate(_startDate);
	start.setTime("00:00".Time);
	debtorRate := _debtor.serviceRates[_service];
	if debtorRate &lt;&gt; null then
		rateEntry := debtorRate.rateEntries[start];
	endif;
	create costs transient;

	if rateEntry = null then
		if debtorRate = null then
			create debtorRate transient;
			debtorRate.setProxy(_service, _debtor);
		endif;
		costs.add(_rateValue);
		expiry := null;
		rateEntry := self.addInvoiceRateEntry(debtorRate, start, expiry, ignoreEntry, costs, 0, 0, null, null);
		if debtorRate.isTransient then
			delete debtorRate;
		endif;
	else		
		app.cmsBeginLoad(ls);
		proxyRateEntry := app.createUpdateProxy(rateEntry).CM_RateEntry;
		app.cmsEndLoad(ls);

		costs.add(_rateValue);
		proxyRateEntry.setProxy(costs, _rateValue, rateEntry.rate, app.myPassport.myUser.code, start, null, false, 0, 0, null);
	
		app.myTrxUA.trxUpdateRateEntry(proxyRateEntry, app.myPassport);

	endif;

epilog
	app.cmsEndLoad(ls);
	if debtorRate &lt;&gt; null and
	   debtorRate.isTransient then
		delete debtorRate;
	endif;
	delete proxyRateEntry;
	delete costs;
end;</source>
        <Parameter name="_service" type="CM_Service"/>
        <Parameter name="_debtor" type="CM_DebtorNode"/>
        <Parameter name="_startDate" type="Date"/>
        <Parameter name="_rateValue" type="Decimal"/>
    </JadeMethod>
