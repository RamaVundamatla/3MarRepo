    <JadeMethod name="doItemDelete" id="77f274d8-b458-41d5-a934-821755759271">
        <updating/>
        <source>doItemDelete() updating;
// ---------------------------------------------------------------------------
// Created:     06 April 2011 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	pxyGraphic : CM_DeckItemLayout;
	theReturn  : Integer;
	delObjs : ObjectArray;
	obj : Object;
	invalid : Boolean;
begin
	create delObjs transient;
	
	self.frmScrollable.myDrawingFrame.CMUI_PointDrawingFrame.allPointGraphics.copy(delObjs);
	
	if delObjs.size = 0 then
		return;
	endif;
	
	theReturn := app.msgBox(app.getErrorString(Sure_that_want_delete) &amp; " " &amp; delObjs.size.String &amp; " " &amp; app.getErrorString(Selected_graphics),app.getErrorString(Confirm_delete),MsgBox_Yes_No + MsgBox_Question_Mark_Icon);
	if theReturn = MsgBox_Return_Yes then
		self.myCurrentProxyItemLayout := null;
		on Exception do app.handleDeletedObject(exception, pxyGraphic, invalid);
		foreach obj in delObjs  discreteLock do
			pxyGraphic := obj.CM_DeckItemLayout;
			pxyGraphic.cleanupPxyReferences();
			delete pxyGraphic;
		endforeach;
		self.myCurrentProxyLayerLayout.causeEvent(EVENT_RORO_LAYER_UPDATE,true,null);
		
	endif;
epilog
	delete delObjs;
end;</source>
    </JadeMethod>
