        <type name="Integer"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="getDebtorForInvoiceLine" id="8d7405ac-65f5-4fc4-b34f-987df11cba1f">
        <source>getDebtorForInvoiceLine(_invLineDesc: CM_InvoiceLineDesc): CM_Debtor;
/*

Purpose:				For Future Storage transaction, we check whether there is a COO done in the TI.
						If so, get the debtor from COO

Parameters:			

Return Value:		

Date		Who		Reason
08/12/2023	navkc1 ChangeRequest 58261 Task 58262: Jade - COO Storage Debtor

*/

vars
	ti				: CM_TrackedItem;
	debtorToUse		: CM_Debtor;
	trans			: CM_TITransaction;
	cooTrans		: CM_OwnershipChanged;
	operator		: CM_Operator;
	incoCode,
	storageOpsCode	: String;
	incoTerm		: CM_InvoiceINCOTerm;
	bank			: CM_Bank;
	incoMapping		: CM_InvoiceINCOMapping;
	debtorType		: CM_DebtorType;
begin
			return inheritMethod(_invLineDesc);
			
			
			
			// # DELETE THIS METHOD IN Dmast and Wmast. Move up to CM_Storage
			
			
			
			
/* // ### TFS CR 58263 TASK 58264 15JAN2024 NAVAB1 
	ti := self.myTrackedItem;
	
	trans := ti.getLastTransOfType(TRANS_TYPE_OWNERSHIP_CHANGED);
	
	if trans = null then
		return inheritMethod(_invLineDesc);
	endif;
	
	cooTrans := trans.CM_OwnershipChanged;
	
	storageOpsCode := cooTrans.operatorStorageCode;
	
	if storageOpsCode = null then
		// Do Incoterm
		incoCode := cooTrans.incoTermCode;
		if incoCode = null then
			return inheritMethod(_invLineDesc);
		endif;
		
		bank := self.getBusinessUnitObject();
		
		if bank = null then
			return inheritMethod(_invLineDesc);
		endif;
		
		incoTerm := bank.allInvoiceINCOTerms[incoCode];
		
		if incoTerm &lt;&gt; null then
			incoMapping := incoTerm.allINCOTermMappingsByInvLnType[_invLineDesc];
			
			if incoMapping &lt;&gt; null then
				debtorType := incoMapping.myDebtorType;
				
				if debtorType &lt;&gt; null then
					debtorToUse := _invLineDesc.getDebtorFromTI(ti, debtorType);
				endif;
				
			endif;
		endif;
	else
		operator := app.myRoot.allOperators[storageOpsCode];
		
		if operator &lt;&gt; null then
			debtorToUse := operator.debtor;
		endif;
		
	endif;
	
	if debtorToUse = null then
		return inheritMethod(_invLineDesc);
	else
		return debtorToUse;
	endif;
	*/
epilog

end;</source>
        <Parameter name="_invLineDesc" type="CM_InvoiceLineDesc"/>
        <ReturnType type="CM_Debtor"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="1517c536-415d-442e-a570-3f43803e37a7">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
// 31986 use the 'daysCharged' value as the 'stored for ' value

vars

	lDetail : String;
begin

	if _attrName = ETRow_Details or
	   _attrName = ETRow_Storage then
		if self.deleted then
			return self.getDeletedDetails();		// 15/10/18 MAP TFS41191
			
		else
			lDetail := "Stored for " &amp; self.daysCharged.String;
			if self.daysCharged = 1 then
				lDetail := lDetail  &amp; " day";
			else
				lDetail := lDetail  &amp; " days";
			endif;
			if self.allInvoiceLines.isEmpty then
				lDetail := lDetail &amp; ", no charge.";
			endif;
			lDetail := lDetail &amp; " " &amp; self.urNumber.String;
			
			return lDetail;
		endif;
							
	else
		return inheritMethod(_attrName, _short);
	
	endif;

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getMyTerminalArea" id="41a82df5-eb54-4151-8eb4-4acf0dd3f56c">
        <source>getMyTerminalArea():CM_TerminalArea;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 November 2019	jlgndl1	Initial creation	TFS 47344

*/

vars

	lc : CM_LocationsController;
	height : Integer;

begin

	if self.location = null then
		return null;
	endif;
	
	self.myTerminal.findLocationFromString( self.location, true, lc, height );
	
	if lc &lt;&gt; null then
		return lc.myTerminalArea;
	endif;
	
	return null;

epilog

end;</source>
        <ReturnType type="CM_TerminalArea"/>
    </JadeMethod>
