    <PrimAttribute name="fleetDisposition" id="59807816-7929-4b04-9108-c09e5d6d4dbe">
        <length>4</length>
        <embedded/>
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="hireType" id="b98f2aaf-235a-4621-b058-54c8d15a7a3b">
        <length>31</length>
        <embedded/>
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="messageStatus" id="70d8c3f6-0bbb-4fbf-8c87-41b65334eb5a">
        <length>5</length>
        <embedded/>
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="otherParty" id="d64e1f9d-165a-49e5-bfb3-a445123c87b3">
