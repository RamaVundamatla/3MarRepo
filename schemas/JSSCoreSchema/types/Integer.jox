    <JadeMethod name="jssBinaryMatch" id="c42b0388-a695-4f52-922d-425a4d072ba5">
        <source>jssBinaryMatch(pMask:Integer) : Boolean;
// Does the integer contain (match with) the binary pMask, e.g. pMask may be 1, 2, 4, 8, 16, ...
vars
    dividend	: Integer;

begin
	dividend := self div pMask;

	if dividend = 0 then
		return false;
	endif;

	if dividend mod 2 = 0 then
		return false;
	endif;

	return true;
end;</source>
        <text>___________________________________________________________________________

              P R O P R I E T A R Y   N O T I C E

This software, in whole and in every part, is proprietary to Jade Software
Corporation Limited at Christchurch, New Zealand and is not to be
reproduced, used or disclosed except upon prior written permission of Jade
Software Corporation Limited.

  COPYRIGHT © JADE SOFTWARE CORPORATION LIMITED 2002 - ALL RIGHTS RESERVED
____________________________________________________________________________</text>
        <Parameter name="pMask" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="jssClockDifference" id="09464c2f-c064-4d33-a7de-3d1bc7718c91">
        <source>jssClockDifference():Real;
// --------------------------------------------------------------------------------
// Created:		22 January 2002 by cnwdad1
//
// Purpose:		Returns the difference between the receiver and the app.clock
//				value, in seconds.
//
// Parameters:	None
//
// Returns:		The number of seconds difference between the receiver and app.clock.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return ((app.clock - self) / 1000);
end;</source>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="jssDaysInMonth" id="62a709b8-c5c1-4b6c-b1b8-865b458f34d3">
        <source>jssDaysInMonth(pIsLeapYear:Boolean):Integer;
// --------------------------------------------------------------------------------
// Created:		02 November 2000 by cnwdad1
//
// Purpose:		Returns the number of days of the month number.
//
// Parameters:	pIsLeapYear (Boolean) - Flag to indicate whether the month number
//				is within a leap year.
//
// Returns:		Integer - The number of days, or zero if the month number is invalid.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
constants
	IS_UNICODE_SYS	: Boolean = (-1).Character.Integer = 65535;
	DAYS_IN_MONTH	: Binary = #"1F 1C 1F 1E 1F 1E 1F 1F 1E 1F 1E 1F".Binary;	// Construct a compile-time value array.

begin
	if self &lt; 1 or self &gt; 12 then
		return null;
	endif;
	
    if self = 2 and pIsLeapYear then
        return 29;
    endif;

	if IS_UNICODE_SYS then
		return DAYS_IN_MONTH[(self*2-1):2].Integer;
	endif;

	return DAYS_IN_MONTH[self];
end;</source>
        <text>___________________________________________________________________________

              P R O P R I E T A R Y   N O T I C E

This software, in whole and in every part, is proprietary to Jade Software
Corporation Limited at Christchurch, New Zealand and is not to be
reproduced, used or disclosed except upon prior written permission of Jade
Software Corporation Limited.

  COPYRIGHT © JADE SOFTWARE CORPORATION LIMITED 2002 - ALL RIGHTS RESERVED
____________________________________________________________________________</text>
        <Parameter name="pIsLeapYear" type="Boolean"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="jssGetDayName" id="cb479d27-9d2e-4fec-af2a-ee5a4189e14e">
        <source>jssGetDayName():String;
// --------------------------------------------------------------------------------
// Created:		13 January 2001 by cnwdad1
//
// Purpose:		Returns the name of the week day base upon the receiver day
//				number. If the receiver is &lt; 1 or &gt; 7 then a null value is returned.
//
// Parameters:	None
//
// Returns:		String - The name of the week day.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	weekDayNumber	: Integer;
	
begin
	weekDayNumber	:=	self;
	
	if weekDayNumber = 1 then
		return $JSS_DAY_MONDAY;
	elseif weekDayNumber = 2 then
		return $JSS_DAY_TUESDAY;
	elseif weekDayNumber = 3 then
		return $JSS_DAY_WEDNESDAY;
	elseif weekDayNumber = 4 then
		return $JSS_DAY_THURSDAY;
	elseif weekDayNumber = 5 then
		return $JSS_DAY_FRIDAY;
	elseif weekDayNumber = 6 then
		return $JSS_DAY_SATURDAY;
	elseif weekDayNumber = 7 then
		return $JSS_DAY_SUNDAY;
	else
		return null;
	endif;
end;</source>
        <text>___________________________________________________________________________

              P R O P R I E T A R Y   N O T I C E

This software, in whole and in every part, is proprietary to Jade Software
Corporation Limited at Christchurch, New Zealand and is not to be
reproduced, used or disclosed except upon prior written permission of Jade
Software Corporation Limited.

  COPYRIGHT © JADE SOFTWARE CORPORATION LIMITED 2002 - ALL RIGHTS RESERVED
____________________________________________________________________________</text>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="jssGetEasterSundayForYear" id="a26e6097-42d1-46d6-abc1-7cc2c3918b97">
        <source>jssGetEasterSundayForYear():Date;
// --------------------------------------------------------------------------------
// Created:		07 November 2000 by cnwdad1
//
// Purpose:		Returns the date of Easter Sunday for a (receiver) year.
//
// Parameters:	None
//
// Returns:		Date - The date Easter Sunday for the (receiver) year.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
/*

This method computes the date on which Easter Sunday occurs for the year passed as
a parameter.

The Gregorian calendar officially started in September 1752, so the formula shouldn't
be applied to 1752 and has been coded to return a null date for years prior to 1753.

The formula implemented by this method was devised by Christophorus Clavius under 
commission from Pope Gregory XIII. Basically it works out the date of the Paschal
Full moon, which is supposed to be the first full moon following the Vernal Equinox.
The formula here was worked out so that the new moon calculated always falls on, or
one, or two days after the true mean astronomical new moon. The full moon is then
considered to occur on the fourteenth day of the lunar month and Easter Sunday is
the first Sunday following that. In fact the formula is quite rough and ready as is
the Gregorian Calendar.

*/
constants	
	MARCH_21		: Integer = 31 + 28 + 21;
	GREGORY_START	: Integer = 1753;

vars
	yearNum			: Integer;
	century			: Integer;
	clavius			: Integer;
	dominical		: Integer;
	easter			: Integer;
	epact			: Integer;
	golden			: Integer;
	leap			: Integer;
	metonic_error	: Integer;
	moon			: Integer;
	paschal			: Integer;
	easter_sunday	: Date;

begin
	yearNum	:=	self;
	
	if (yearNum &lt; GREGORY_START) then
		easter_sunday.setDate(0, 0, 0);
		return easter_sunday;
	endif;

	century	:=	yearNum div 100;

	if (yearNum mod 4 = 0) and (yearNum mod 100 &lt;&gt; 0) or (yearNum mod 400 = 0) then
		leap	:=	1;
	else
		leap	:=	0;
	endif;				

	dominical		:=	7 - (yearNum + yearNum div 4 - century + century div 4 - 1 - leap) mod 7;
	golden			:=	yearNum mod 19 + 1;
	metonic_error	:=	(century - century div 4 - (century - (century - 17) div 25) div 3 - 8) mod 30;
	epact			:=	(11 * (golden - 1) - metonic_error) mod 30;
	moon			:=	31 - epact + 59 + leap;
	paschal			:=	moon + 13;	           // We got it - unless . .. .

	if (paschal &lt; (MARCH_21 + leap)) then	// It was before the Equinox.
		if (golden &gt; 11) then
			clavius	:=	26;
		else
			clavius	:=	25;
		endif;

		if (epact &lt; clavius) then
			moon	:=	moon + 29;
		else
			moon	:=	moon + 30;
		endif;

		paschal	:=	moon + 13;
	endif;	 				 			

	easter			:=	paschal + 7 - (paschal - dominical) mod 7;	// Sunday after Paschal full moon.
	easter_sunday.setDate(1, 1, yearNum);
	easter_sunday	:=	easter_sunday + easter - 1;

	return easter_sunday;
end;</source>
        <text>___________________________________________________________________________

              P R O P R I E T A R Y   N O T I C E

This software, in whole and in every part, is proprietary to Jade Software
Corporation Limited at Christchurch, New Zealand and is not to be
reproduced, used or disclosed except upon prior written permission of Jade
Software Corporation Limited.

  COPYRIGHT © JADE SOFTWARE CORPORATION LIMITED 2002 - ALL RIGHTS RESERVED
____________________________________________________________________________</text>
        <ReturnType type="Date"/>
    </JadeMethod>
    <JadeMethod name="jssGetHexColor" id="0a1f411c-480f-44be-976a-33ab891ad1ee">
        <source>jssGetHexColor():String;
// --------------------------------------------------------------------------------
// Created:		06 June 2001 by cnwdad1
//
// Purpose:		Converts the receiver into an hexadecimal color, such as for HTML.
//				For example: FF0000
//
// Parameters:	None
//
// Returns:		The hexadecimal color value.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	colorRed	: Integer;
	colorGreen	: Integer;
	colorBlue	: Integer;
	hexValue	: String;
	
begin
	self.jssGetRGBValues(colorRed, colorGreen, colorBlue);
	
	hexValue	:=	colorRed.Character.toHex &amp;
					colorGreen.Character.toHex &amp;
					colorBlue.Character.toHex;
epilog
	return hexValue;
end;</source>
        <text>___________________________________________________________________________

              P R O P R I E T A R Y   N O T I C E

This software, in whole and in every part, is proprietary to Jade Software
Corporation Limited at Christchurch, New Zealand and is not to be
reproduced, used or disclosed except upon prior written permission of Jade
Software Corporation Limited.

  COPYRIGHT © JADE SOFTWARE CORPORATION LIMITED 2002 - ALL RIGHTS RESERVED
____________________________________________________________________________</text>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="jssGetRGBValues" id="1ae286fe-5810-4da0-b0c9-78461cb1e2c8">
        <source>jssGetRGBValues(pColorRed:Integer output; pColorGreen:Integer output; pColorBlue:Integer output);
// --------------------------------------------------------------------------------
// Created:		06 June 2001 by cnwdad1
//
// Purpose:		Get the RGB values which make up the receiver's colour value.
//
// Parameters:	pColorRed (Integer) - The red part of the color.
//				pColorGreen (Integer) - The green part of the color.
//				pColorBlue (Integer) - The blue part of the color.
//
// Returns:		The red, green and blue values as output parameters.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	workValue	: Integer;
	
begin
	workValue	:=	self;	
	pColorRed	:=	workValue mod 256;
	workValue	:=	workValue div 256;
	pColorGreen	:=	workValue mod 256;
	workValue	:=	workValue div 256;
	pColorBlue	:=	workValue mod 256;
end;</source>
        <text>___________________________________________________________________________

              P R O P R I E T A R Y   N O T I C E

This software, in whole and in every part, is proprietary to Jade Software
Corporation Limited at Christchurch, New Zealand and is not to be
reproduced, used or disclosed except upon prior written permission of Jade
Software Corporation Limited.

  COPYRIGHT © JADE SOFTWARE CORPORATION LIMITED 2002 - ALL RIGHTS RESERVED
____________________________________________________________________________</text>
        <Parameter name="pColorRed" type="Integer" usage="output"/>
        <Parameter name="pColorGreen" type="Integer" usage="output"/>
        <Parameter name="pColorBlue" type="Integer" usage="output"/>
    </JadeMethod>
    <JadeMethod name="jssIsAltKey" id="bf5c3de2-012d-4964-ac77-3e0a344bede4">
        <source>jssIsAltKey():Boolean;
// --------------------------------------------------------------------------------
// Created:		24 January 2003 by cnwdad2
//
// Purpose:		Returns a boolean flag to indicate whether the ALT key is pressed.
//				This method assumes that the receiver is the value of the "shift"
//				parameter of various GUI object event methods, such as the keyDown,
//				keyUp, mouseDown, mouseMove and mouseUp events.
//
// Parameters:	None
//
// Returns:		True if the ALT key is pressed, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return (self.bitAnd(4) &lt;&gt; 0);
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="jssIsBetween" id="369b343e-0c4f-4c90-ba9f-7150f3d49344">
        <source>jssIsBetween(pLowerValue:Integer; pUpperValue:Integer):Boolean;
// --------------------------------------------------------------------------------
// Created:		09 April 2002 by cnwdad1
//
// Purpose:		Returns a boolean flag to indicate whether the receiver is within
//				(or equal to) to supplied range of values.
//
// Parameters:	pLowerValue - The lower limit of the range.
//				pUpperValue - The upper limit of the range.
//
// Returns:		True if the receiver is within the range, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return (self &gt;= pLowerValue and self &lt;= pUpperValue);
end;</source>
        <Parameter name="pLowerValue" type="Integer"/>
        <Parameter name="pUpperValue" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="jssIsCtrlKey" id="9c501b70-32d9-4bdf-a2dd-378b942790f1">
        <source>jssIsCtrlKey():Boolean;
// --------------------------------------------------------------------------------
// Created:		24 January 2003 by cnwdad2
//
// Purpose:		Returns a boolean flag to indicate whether the CTRL key is pressed.
//				This method assumes that the receiver is the value of the "shift"
//				parameter of various GUI object event methods, such as the keyDown,
//				keyUp, mouseDown, mouseMove and mouseUp events.
//
// Parameters:	None
//
// Returns:		True if the CTRL key is pressed, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return (self.bitAnd(2) &lt;&gt; 0);
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="jssIsLeapYear" id="9f4579be-eeb3-427d-b362-24f60481af96">
        <source>jssIsLeapYear():Boolean;
// --------------------------------------------------------------------------------
// Created:		02 November 2000 by cnwdad1
//
// Purpose:		Determines if the receiver year is a leap year.
//
// Parameters:	None
//
// Returns:		True if the receiver is a leap year, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
    return (self mod 4 = 0 and self mod 100 &lt;&gt; 0) or self mod 400 = 0;
end;</source>
        <text>___________________________________________________________________________

              P R O P R I E T A R Y   N O T I C E

This software, in whole and in every part, is proprietary to Jade Software
Corporation Limited at Christchurch, New Zealand and is not to be
reproduced, used or disclosed except upon prior written permission of Jade
Software Corporation Limited.

  COPYRIGHT © JADE SOFTWARE CORPORATION LIMITED 2002 - ALL RIGHTS RESERVED
____________________________________________________________________________</text>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="jssIsShiftKey" id="5d0d9bd7-3601-4f69-b870-a9bdc1958341">
        <source>jssIsShiftKey():Boolean;
// --------------------------------------------------------------------------------
// Created:		24 January 2003 by cnwdad2
//
// Purpose:		Returns a boolean flag to indicate whether the Shift key is pressed.
//				This method assumes that the receiver is the value of the "shift"
//				parameter of various GUI object event methods, such as the keyDown,
//				keyUp, mouseDown, mouseMove and mouseUp events.
//
// Parameters:	None
//
// Returns:		True if the Shift key is pressed, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return (self.bitAnd(1) &lt;&gt; 0);
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="jssNumberFormat" id="40b3fa4f-e7a2-4d19-be42-a22f03744f48">
        <source>jssNumberFormat():String;
// -----------------------------------------------------------------------------
// Created:		20 January 2002 by cnwdad1
//
// Purpose:		Formats the receiver as a string value, i.e. 1234 will be
//				returned as "1,234".
//
// Parameters:	None
//
// Returns:		The receiver formatted as a string.
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------
begin
	return self.userNumberFormat($CNEC_NO_DECIMALS);
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="jssSetColorFromRGB" id="1b49624b-8449-4db1-8919-986e7e0b1479">
        <updating/>
        <source>jssSetColorFromRGB(pColorRed:Integer; pColorGreen:Integer; pColorBlue:Integer) updating;
// --------------------------------------------------------------------------------
// Created:		06 June 2001 by cnwdad1
//
// Purpose:		Sets the receiver to the JADE (Windows) color number corresponding
//				to the passed RGB values.
//
// Parameters:	pColorRed (Integer) - The red part of the color.
//				pColorGreen (Integer) - The green part of the color.
//				pColorBlue (Integer) - The blue part of the color.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self	:=	((pColorBlue * 256) + pColorGreen) * 256 + pColorRed;
end;</source>
        <text>___________________________________________________________________________

              P R O P R I E T A R Y   N O T I C E

This software, in whole and in every part, is proprietary to Jade Software
Corporation Limited at Christchurch, New Zealand and is not to be
reproduced, used or disclosed except upon prior written permission of Jade
Software Corporation Limited.

  COPYRIGHT © JADE SOFTWARE CORPORATION LIMITED 2002 - ALL RIGHTS RESERVED
____________________________________________________________________________</text>
        <Parameter name="pColorRed" type="Integer"/>
        <Parameter name="pColorGreen" type="Integer"/>
        <Parameter name="pColorBlue" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="jssTake" id="ceac283f-5a09-43e7-8129-20f9109a15ca">
        <updating/>
        <source>jssTake(pDecrement:Integer):Integer updating;
// --------------------------------------------------------------------------------
// Created:		05 February 2001 by cnwdad1
//
// Purpose:		Decrements the receiver by the value specified by the parameter,
//				and returns the result.
//
//				*************************************************************
//				* NOTE: Do not use this method to decrement a loop counter. *
//				*************************************************************
//
// Parameters:	pDecrement (Integer) - The amount by which to decrement the receiver.
//
// Returns:		The result of the decrement.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self &gt;= (Min_Integer + pDecrement) then
		self := self - pDecrement;
	endif;
epilog
	return self;
end;</source>
        <Parameter name="pDecrement" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
</PrimType>
