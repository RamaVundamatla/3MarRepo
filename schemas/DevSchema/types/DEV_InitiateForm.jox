    <JadeMethod name="createAdminSecurityRoles" id="c9242eea-6873-4de6-86c3-8093f371784e">
        <source>createAdminSecurityRoles() :Boolean;
// -----------------------------------------------------------------------------
// Created:		Mar 2004  by cnwrs1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
// 22/03/2018	jlgdap1		TFS 37445 PEL1 Voyage Status Security
// -----------------------------------------------------------------------------
// create admin terminal and system security roles
vars
	securityRoleProxy,securityRoleReal: CM_SecurityRole;
	permissionAgent: CM_PermissionAgent;
	error: CM_Error;
	permissions: BooleanArray;
	theUser: CM_User;
	returnCode: Boolean;
begin
	returnCode := false;
	app.initialize;
//	theUser := CM_Terminal.firstInstance.users["SUPERUSER"];
	if theUser = null then
		theUser := CM_Root.firstInstance.allUsers["SUPERUSER"];
	endif;
	app.myPassport.setMyUser(theUser);
	app.myPassport.warningsAcknowledged	:= true;
	create permissions transient;
	create permissionAgent transient;
	permissionAgent.populatePermissionDict(true, true, 0);
	permissionAgent.setAllPermissionValues(true);
	permissionAgent.getPermissionValues(permissions, true, true);

	create securityRoleProxy as CM_SecurityRoleSystem transient;
	
	securityRoleProxy.setProxy(	"Admin System",
								CM_SecurityRoleSystemRoot.firstInstance,
								permissions,
								true,
								app.myRoot,
								null,
								null,
								null,
								null,
								null,
								null,
								null,
								null,	// TFS 39618
								null,				// TFS 37445
								null,
								null,	//09 Mar 2020	NDL	TFS 48784
								null	//02/11/2022 navds20 TFS 54253
								);
	
	app.myTrxCA.trxCreateSecurityRole(securityRoleProxy, permissionAgent, securityRoleReal, app.myPassport);
	if app.myPassport.trxCompletedOK and
	   app.myPassport.allErrorWarnings.size = 0 then

	else
		foreach error in app.myPassport.allWarnings do
			app.writeStatement( class.name&amp;'::'&amp;method.name&amp;' '&amp;securityRoleProxy.name&amp;" WARNING: "&amp;error.text);
		endforeach;
		foreach error in app.myPassport.allErrors do
			app.writeStatement( class.name&amp;'::'&amp;method.name&amp;' '&amp;securityRoleProxy.name&amp;" ERROR: "&amp;error.text);
		endforeach;
		return returnCode;
	endif;
	
	delete securityRoleProxy;
	permissionAgent.getPermissionValues(permissions, false, true);
	create securityRoleProxy as CM_SecurityRoleTerminal transient;
	securityRoleProxy.setProxy(	"Admin Terminal",
								CM_SecurityRoleTerminalRoot.firstInstance,
								permissions,
								true,
								app.myRoot,
								null,
								null,
								null,
								null,
								null,
								null,
								null,
								null,	// TFS 39618								
								null,				// TFS 37445
								null,
								null,	//09 Mar 2020	NDL	TFS 48784
								null	//02/11/2022 navds20 TFS 54253
								);
	app.myTrxCA.trxCreateSecurityRole(securityRoleProxy, permissionAgent, securityRoleReal, app.myPassport);
	
	if app.myPassport.trxCompletedOK and
	   app.myPassport.allErrorWarnings.size = 0 then
		app.writeStatement( class.name&amp;'::'&amp;method.name&amp;' '&amp;securityRoleProxy.name&amp;" OK");
		returnCode := true;
	else
		foreach error in app.myPassport.allWarnings do
			app.writeStatement( class.name&amp;'::'&amp;method.name&amp;' '&amp;securityRoleProxy.name&amp;" WARNING: "&amp;error.text);
		endforeach;
		foreach error in app.myPassport.allErrors do
			app.writeStatement( class.name&amp;'::'&amp;method.name&amp;' '&amp;securityRoleProxy.name&amp;" ERROR: "&amp;error.text);
		endforeach;
	endif;
epilog
	delete permissions;
	delete permissionAgent;
	delete securityRoleProxy;
	return returnCode;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="createAdminUser" id="91a8aa09-0a74-4dac-89f0-3a2ffdf29ace">
        <source>createAdminUser() :Boolean;
// -----------------------------------------------------------------------------
// Created:		Mar 2004  by cnwrs1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
// create admin terminal and system security roles
vars
	userProxy,userReal: CM_User;
	error: CM_Error;
	daSet:CM_DataAccessControllerSet;
	theUser: CM_User;
	terminal:CM_Terminal;
	pxyUserTerm: CM_UserTerminal;
	returnCode: Boolean;
	secRoleTerminal: CM_SecurityRoleTerminal;
	secRoleSystem: CM_SecurityRoleSystem;
	allEmailsICanSee : CM_EmailEntityByTypeNameDict;
begin
	returnCode := false;
	app.initialize;
//	theUser := CM_Terminal.firstInstance.users["SUPERUSER"];
	if theUser = null then
		theUser := CM_Root.firstInstance.allUsers["SUPERUSER"];
	endif;
	app.myPassport.setMyUser(theUser);
	app.myPassport.warningsAcknowledged	:= true;

	secRoleSystem := app.myRoot.mySecurityRoleSystem;
//	secRoleSystem := app.myRoot.allRoles["Admin System"].CM_SecurityRoleSystem;
	if secRoleSystem = null then
		return null;
	endif;
	secRoleTerminal := app.myRoot.mySecurityRoleTerminal;
//	secRoleTerminal := app.myRoot.allRoles["Admin Terminal"].CM_SecurityRoleTerminal;
	if secRoleTerminal = null then
		return null;
	endif;
	create allEmailsICanSee transient;
	create userProxy as CM_User transient;
	userProxy.setProxy("ADMIN", "Admin User", 0, CM_InternalOrganisation.firstInstance, app.myRoot,
	                   true, false, false, false, null, daSet, secRoleSystem, null, allEmailsICanSee,
					   null, null, app.myRoot.getDefaultLocale(true), false, false); //cnwrs1 Par 23153 11 Mar 2010
	foreach terminal in app.myRoot.allTerminals do
		pxyUserTerm := userProxy.allUserTerminals[terminal];
		if pxyUserTerm = null then
			create pxyUserTerm transient;
		endif;
		pxyUserTerm.setForProxy(terminal, userProxy, secRoleTerminal, null, null, null);
	endforeach;
	app.myTrxCA.trxCreateUser(userProxy,"Pa55word_", userReal, app.myPassport);
	if app.myPassport.trxCompletedOK and
	   app.myPassport.allErrorWarnings.size = 0 then

		returnCode := true;
	else
		foreach error in app.myPassport.allWarnings do
			app.writeStatement( class.name&amp;'::'&amp;method.name&amp;' '&amp;userProxy.code&amp;" WARNING: "&amp;error.text);
		endforeach;
		foreach error in app.myPassport.allErrors do
			app.writeStatement(class.name&amp;'::'&amp;method.name&amp;' '&amp;userProxy.code&amp;" ERROR: "&amp;error.text);
		endforeach;
	endif;
epilog
	delete userProxy;
	delete allEmailsICanSee;
	return returnCode;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="createInitialUser" id="09c9a408-1053-4e09-8483-8a595d069871">
        <updating/>
        <source>createInitialUser(_userName, __password: String): Boolean updating;
// -----------------------------------------------------------------------------
// Created:		Mar 2004  by cnwrs1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
