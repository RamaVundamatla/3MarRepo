    <JadeMethod name="trxCreateTerminalArea" id="8ee719da-0a49-44fd-9885-118dc315ef61">
        <updating/>
        <source>trxCreateTerminalArea(_proxyTAMaster : CM_TerminalAreaMaster input; _realTAMaster : CM_TerminalAreaMaster output; _passport : CM_Passport input) updating;
//trxCreateTerminalArea( _pxyTA : CM_TerminalArea input; _newTA : CM_TerminalArea output; _ignoreWarnings : Boolean; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:		July 2001 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	realTA,proxyTA : CM_TerminalArea;
	pxyTA : CM_TerminalArea;
	 newTA : CM_TerminalAreaMaster;
	 pxyDeckingOptions : CM_YADeckingOptionsTA;
begin

	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);
	

	beginTransaction;

//	pxyTA := _controller.myPxyTerminalArea;
	
//	app.myUtilityCA.utlCreateTerminalArea(_pxyTA, _newTA, _passport);
	app.myUtilityCA.utlCreateTerminalArea(_proxyTAMaster,_realTAMaster, _passport);
	//newTA := _controller.myTerminalArea;
	//_controller.myTerminalAreaMaster:=newTA;
	if _passport.hasErrors then
		return;
	endif;
	
	if (_realTAMaster &lt;&gt; null and _realTAMaster.isKindOf(CM_TerminalArea)) then
		realTA:=_realTAMaster.CM_TerminalArea;
		proxyTA:=_proxyTAMaster.CM_TerminalArea;
	
	endif;
	//epr par 1/7/10 24724
	if proxyTA &lt;&gt; null then
		pxyDeckingOptions:=proxyTA.myYADeckingOptions; 
	endif;
	
	if realTA &lt;&gt; null 
	and pxyDeckingOptions &lt;&gt; null then
		
		app.myUtilityCA.utlCreateDeckOptionsApplyRules(realTA, pxyDeckingOptions, DeckingLevel_TA, _passport);
		
		if _passport.hasErrors then
			return;
		endif;
		
		realTA.setGridObjectsForDecking(_passport);
	endif;
	

epilog
	//epr par 24724 1/7/10 make sure the proxy TA is the same as when it arrived in this method - i.e. if we have warnings and get back here need the proxyTA to have a reference to pxyDeckingOptions
	if pxyDeckingOptions &lt;&gt; null then
		pxyDeckingOptions.setProxy(pxyDeckingOptions.showHeightsForCustom, pxyDeckingOptions.useReverseOfIn, proxyTA);
	endif;

	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_proxyTAMaster" type="CM_TerminalAreaMaster" usage="input"/>
        <Parameter name="_realTAMaster" type="CM_TerminalAreaMaster" usage="output"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
