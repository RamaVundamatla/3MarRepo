    <JadeMethod name="convertBaseToTarget" id="77a9fa6c-cc35-40dc-be92-f30fc051276c">
        <source>convertBaseToTarget(pMeasure: Real; pUnitTo: Integer): Real protected;
// --------------------------------------------------------------------------------
// Created:		02 June 2001 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	convertedMeasure	: Real;
	
begin
	if pUnitTo = self.CUBIC_FEET_PER_ACRE then
		convertedMeasure	:=	pMeasure * 142.913;

	elseif pUnitTo = self.CUBIC_INCHES_PER_SQUARE_YARD then
		convertedMeasure	:=	pMeasure * 51.024;
		
	elseif pUnitTo = self.CUBIC_METRES_PER_HECTARE then
		convertedMeasure	:=	pMeasure * 10;
		
	elseif pUnitTo = self.CUBIC_METRES_PER_SQUARE_KM then
		convertedMeasure	:=	pMeasure * 1000;
		
	elseif pUnitTo = self.CUBIC_METRES_PER_SQUARE_METRE then
		convertedMeasure	:=	pMeasure / 1000;
		
	elseif pUnitTo = self.CUBIC_YARDS_PER_SQUARE_MILE then
		convertedMeasure	:=	pMeasure * 3387.577;
		
	elseif pUnitTo = self.FL_OUNCES_UK_PER_SQUARE_YARD then
		convertedMeasure	:=	pMeasure * 29.428;
		
	elseif pUnitTo = self.GALLONS_UK_PER_ACRE then
		convertedMeasure	:=	pMeasure * 890.184;
		
	elseif pUnitTo = self.GALLONS_UK_PER_HECTARE then
		convertedMeasure	:=	pMeasure * 2199.692;
		
	elseif pUnitTo = self.GALLONS_US_PER_ACRE then
		convertedMeasure	:=	pMeasure * 1069.066;
		
	elseif pUnitTo = self.GALLONS_US_PER_HECTARE then
		convertedMeasure	:=	pMeasure * 2641.721;
		
	elseif pUnitTo = self.INCHES_OF_RAINFALL then
		convertedMeasure	:=	pMeasure / 25.4;
		
	elseif pUnitTo = self.LITRES_PER_HECTARE then
		convertedMeasure	:=	pMeasure * 10000;
		
	elseif pUnitTo = self.LITRES_PER_SQUARE_METRE then
		convertedMeasure	:=	pMeasure;
		
	elseif pUnitTo = self.MILLILITRES_PER_SQUARE_METRE then
		convertedMeasure	:=	pMeasure * 1000;
		
	elseif pUnitTo = self.MILLIMETRES_OF_RAINFALL then
		convertedMeasure	:=	pMeasure;
		
	else
		CnEcBaseSchemaException.raise_(CNEC_X_12004, "[" &amp; pUnitTo.String &amp; "] is an unknown unit of Spread Rate (by volume) to convert to.");

	endif;
epilog
	return convertedMeasure;
end;</source>
        <access>protected</access>
        <Parameter name="pMeasure" type="Real"/>
        <Parameter name="pUnitTo" type="Integer"/>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="convertToBaseUnit" id="08444880-e274-4d4e-91b8-704a1c2ab332">
        <source>convertToBaseUnit(pUnitFrom: Integer): Real protected;
// --------------------------------------------------------------------------------
// Created:		02 June 2001 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	convertedMeasure	: Real;
	
begin
	if pUnitFrom = self.CUBIC_FEET_PER_ACRE then
		convertedMeasure	:=	self.measure / 142.913;

	elseif pUnitFrom = self.CUBIC_INCHES_PER_SQUARE_YARD then
		convertedMeasure	:=	self.measure / 51.024;
		
	elseif pUnitFrom = self.CUBIC_METRES_PER_HECTARE then
		convertedMeasure	:=	self.measure / 10;
		
	elseif pUnitFrom = self.CUBIC_METRES_PER_SQUARE_KM then
		convertedMeasure	:=	self.measure / 1000;
		
	elseif pUnitFrom = self.CUBIC_METRES_PER_SQUARE_METRE then
		convertedMeasure	:=	self.measure * 1000;
		
	elseif pUnitFrom = self.CUBIC_YARDS_PER_SQUARE_MILE then
		convertedMeasure	:=	self.measure / 3387.577;
		
	elseif pUnitFrom = self.FL_OUNCES_UK_PER_SQUARE_YARD then
		convertedMeasure	:=	self.measure / 29.428;
		
	elseif pUnitFrom = self.GALLONS_UK_PER_ACRE then
		convertedMeasure	:=	self.measure / 890.184;
		
	elseif pUnitFrom = self.GALLONS_UK_PER_HECTARE then
		convertedMeasure	:=	self.measure / 2199.692;
		
	elseif pUnitFrom = self.GALLONS_US_PER_ACRE then
		convertedMeasure	:=	self.measure / 1069.066;
		
	elseif pUnitFrom = self.GALLONS_US_PER_HECTARE then
		convertedMeasure	:=	self.measure / 2641.721;
		
	elseif pUnitFrom = self.INCHES_OF_RAINFALL then
		convertedMeasure	:=	self.measure * 25.4;
		
	elseif pUnitFrom = self.LITRES_PER_HECTARE then
		convertedMeasure	:=	self.measure / 10000;
		
	elseif pUnitFrom = self.LITRES_PER_SQUARE_METRE then
		convertedMeasure	:=	self.measure;
		
	elseif pUnitFrom = self.MILLILITRES_PER_SQUARE_METRE then
		convertedMeasure	:=	self.measure / 1000;
		
	elseif pUnitFrom = self.MILLIMETRES_OF_RAINFALL then
		convertedMeasure	:=	self.measure;
		
	else
		CnEcBaseSchemaException.raise_(CNEC_X_12003, "[" &amp; pUnitFrom.String &amp; "] is an unknown unit of Spread Rate (by volume) to convert from.");

	endif;
epilog
	return convertedMeasure;
end;</source>
        <access>protected</access>
        <Parameter name="pUnitFrom" type="Integer"/>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="getAllUnits" id="699d2554-0333-45ec-974c-909c1f0475fd">
        <source>getAllUnits(pAllUnits: IntegerArray input);
// --------------------------------------------------------------------------------
// Created:		10 May 2008 by Darrell
//
// Purpose:		Refer to superclass implementation.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	pAllUnits.add(self.CUBIC_FEET_PER_ACRE);
	pAllUnits.add(self.CUBIC_INCHES_PER_SQUARE_YARD);
	pAllUnits.add(self.CUBIC_METRES_PER_HECTARE);
	pAllUnits.add(self.CUBIC_METRES_PER_SQUARE_KM);
	pAllUnits.add(self.CUBIC_METRES_PER_SQUARE_METRE);
	pAllUnits.add(self.CUBIC_YARDS_PER_SQUARE_MILE);
	pAllUnits.add(self.FL_OUNCES_UK_PER_SQUARE_YARD);
	pAllUnits.add(self.GALLONS_UK_PER_ACRE);
	pAllUnits.add(self.GALLONS_UK_PER_HECTARE);
	pAllUnits.add(self.GALLONS_US_PER_ACRE);
	pAllUnits.add(self.GALLONS_US_PER_HECTARE);
	pAllUnits.add(self.INCHES_OF_RAINFALL);
	pAllUnits.add(self.LITRES_PER_HECTARE);
	pAllUnits.add(self.LITRES_PER_SQUARE_METRE);
	pAllUnits.add(self.MILLILITRES_PER_SQUARE_METRE);
	pAllUnits.add(self.MILLIMETRES_OF_RAINFALL);
end;</source>
        <Parameter name="pAllUnits" type="IntegerArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getUnitName" id="21b829bd-8119-4d43-b9f9-789383008247">
        <source>getUnitName(pUnit: Integer): String;
// --------------------------------------------------------------------------------
// Created:		09 May 2008 by Darrell
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if pUnit = self.CUBIC_FEET_PER_ACRE then
		return "Cubic Feet per Acre";
	elseif pUnit = self.CUBIC_INCHES_PER_SQUARE_YARD then
		return "Cubic Inches per Square Yard";
	elseif pUnit = self.CUBIC_METRES_PER_HECTARE then
		return "Cubic Metres per Hectare";
	elseif pUnit = self.CUBIC_METRES_PER_SQUARE_KM then
		return "Cubic Metre per Square Kilometre";
	elseif pUnit = self.CUBIC_METRES_PER_SQUARE_METRE then
		return "Cubic Metre per Square Metre";
	elseif pUnit = self.CUBIC_YARDS_PER_SQUARE_MILE then
		return "Cubic Yards per Square Mile";
	elseif pUnit = self.FL_OUNCES_UK_PER_SQUARE_YARD then
		return "Fluid Ounces (UK) per Square Yard";
	elseif pUnit = self.GALLONS_UK_PER_ACRE then
		return "Gallons (UK) per Acre";
	elseif pUnit = self.GALLONS_UK_PER_HECTARE then
		return "Gallons (UK) per Hectare";
	elseif pUnit = self.GALLONS_US_PER_ACRE then
		return "Gallons (US) per Acre";
	elseif pUnit = self.GALLONS_US_PER_HECTARE then
		return "Gallons (US) per Hectare";
	elseif pUnit = self.INCHES_OF_RAINFALL then
		return "Inches of Rainflall";
	elseif pUnit = self.LITRES_PER_HECTARE then
		return "Litres per Hectare";
	elseif pUnit = self.LITRES_PER_SQUARE_METRE then
		return "Litres per Square Metre";
	elseif pUnit = self.MILLILITRES_PER_SQUARE_METRE then
		return "Millilitres per Square Metre";
	elseif pUnit = self.MILLIMETRES_OF_RAINFALL then
		return "Millimetres of Rainfall";
	else
		CnEcBaseSchemaException.raise_(CNEC_X_12003, "[" &amp; pUnit.String &amp; "] is an unknown unit of Spread Rate by Volume to convert from.");
		return null;
	endif;
end;</source>
        <Parameter name="pUnit" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
</Class>
