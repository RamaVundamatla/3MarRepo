    <JadeMethod name="pxyCreateUpdateProxy" id="016986df-db82-4d9a-b473-c25d7654ad41">
        <source>pxyCreateUpdateProxy(): SelfType;
// --------------------------------------------------------------------------------
// Created:		20 March 2005 by cnwdad1
//
// Purpose:		Deep clone the receiver.
//
// Parameters:	None
//
// Returns:		A reference to a transient clone of the receiver.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy
// --------------------------------------------------------------------------------
vars
	proxyObj		: SelfType;
	completedOK		: Boolean;
	
begin
	proxyObj					:=	inheritMethod();
	proxyObj.myYardAllocation	:=	self.myYardAllocation;
	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return proxyObj;
	
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete proxyObj;
	endif;	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="2dcce5ac-32c9-4f49-9a75-3a0779f866e6">
        <updating/>
        <source>setForCreate(pProxyObj:SelfType) updating;
// --------------------------------------------------------------------------------
// Created:		07 March 2005 by cnwdad1
//
// Purpose:		Sets the receiver's property values from the proxy object.
//
// Parameters:	pProxyObj - A reference to the proxy object.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.setForUpdate(pProxyObj);
	
	
	if pProxyObj.myYardAllocation &lt;&gt; null and not pProxyObj.myYardAllocation.isTransient then
		self.myYardAllocation	:=	pProxyObj.myYardAllocation;
	endif;
end;</source>
        <Parameter name="pProxyObj" type="SelfType"/>
    </JadeMethod>
