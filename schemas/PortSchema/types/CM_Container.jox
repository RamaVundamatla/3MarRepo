    <JadeMethod name="isHeavyDuty" id="91befaa8-a936-4197-b2ff-f918a68fef93">
        <methodInvocation>mapping</methodInvocation>
        <source>isHeavyDuty(set: Boolean; _value: Boolean io) mapping;
//Returns TRUE if container is A HEAVY DUTY type, we determine this by looking up
//the container range table, and checking the instvar held for it. DQ 10/4/95
// Only relates to containers..
//  19/08/2010   cnwer1		PAR 25501 - removed the sharedLocks -were not being released
//  31 Oct 2023  navma1 	ChangeRequest 60920: EUP | Cargo Enquiry Performance - Work Packet 1
vars
	cr	 :	CM_ContRange;
	mstr : CM_TIMasterContainer;
	root : CM_Root;
begin
	if set then
		app.raiseSetVirtualError(class.name, method.name);
		return;
	endif;
	
	_value := false;

	// PAR 17703
	root := app.myRoot;																				//31.10.2023 navma1 #60920
	mstr := root.findTIMasterByCargoType(TI_CargoType_Container, self.id).CM_TIMasterContainer;		//31.10.2023 navma1 #60920
	if mstr &lt;&gt; null then
		//--------------
		//Is it heavy Lift?
		//--------------
		_value := mstr.isHeavyLift;
		return;
	endif;
	
	cr := root.lookupContainerRange(self.id);														//31.10.2023 navma1 #60920
	if cr = null then
		return;
	endif;


	//--------------
	//Is it heavy Lift?
	//--------------
	_value := cr.heavyLift;

epilog

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Boolean" usage="io"/>
    </JadeMethod>
    <JadeMethod name="isHighCube" id="131e1a74-de7c-4027-8740-d4f26bf8a2ab">
        <source>isHighCube() : Boolean;
/*
 ------------------------------------------------------------------------
Created:			09 October 2002 by cnwdwq1
Purpose:			
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/
begin
	
	//	PAR 7241 JC 'sizeAttributes' not 'typeAttributes' 
	//	return self.typeAttributes.bitAnd(ISO_HEIGHT_96) &lt;&gt; 0;

	return self.sizeAttributes.bitAnd(ISO_HEIGHT_96) &lt;&gt; 0;
end;</source>
