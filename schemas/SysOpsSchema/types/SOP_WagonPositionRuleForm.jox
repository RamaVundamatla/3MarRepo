    <JadeMethod name="doRefreshTableRow" id="38f264aa-6016-47e6-b886-e993f4e3ce92">
        <updating/>
        <source>doRefreshTableRow( rule : CM_WagonPositionalRule ) updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30/06/2009	cnwndl1	Initial creation
13/03/2013	cnwdap1	PAR #31155 CCMS SFW 1321 Imperial Measurements
11 Sep 2013	NDL	Par 32172
*/
vars
	row : Integer;
	pos : Integer;
	position : CM_WagonPosition;
	base : Integer;
	
	
begin

	row := getRowForRule( rule );
	
	if row = 0 then
		// have added a new rule that needs a new row to be added to the table.
		tblWagonPos.addItem("New");
		tblWagonPos.accessRow(tblWagonPos.rows).itemObject := rule;
		row := self.tblWagonPos.rows;
	endif;
	
	// re-display the data for this line.
	base := 0;
	foreach pos in 1 to numberOfPositions do
		position := rule.allWagonPositions.getAtKey(pos);
		base := base + 1;
		if position = null then
			tblWagonPos.setCellText( row, base, " ");
			base := base + 1;
			tblWagonPos.setCellText( row, base, " ");
			base := base + 1;
			tblWagonPos.setCellText( row, base, " ");
		else
			tblWagonPos.setCellText( row, base, position.cargoLength.asStringJMT.nullWhenZero);
			base := base + 1;
			tblWagonPos.setCellText( row, base, app.convertMeasurementForDisplay(weightType.shortName, position.maxWeight));	// PAR #31155
			base := base + 1;
			tblWagonPos.setCellText( row, base, app.convertMeasurementForDisplay(heightType.shortName, position.deckHeight));	// PAR #31155
		endif;
	endforeach;
	
	// show this row as selected.
	if row &gt; 0 then
		foreach pos in 1 to self.tblWagonPos.rows do
			self.tblWagonPos.accessRow(pos).selected := false;
		endforeach;
		self.tblWagonPos.accessRow(row).selected := true;
	endif;
		
epilog

end;</source>
        <Parameter name="rule" type="CM_WagonPositionalRule"/>
    </JadeMethod>
    <JadeMethod name="doRemoveRule" id="f1282c81-c7b8-459d-bb57-179b4cfc5255">
        <updating/>
        <source>doRemoveRule() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 July 2009	cnwndl1	Initial creation

*/

vars

	rule : CM_WagonPositionalRule;
	row : Integer;
	
begin

	row := self.tblWagonPos.row;
	rule := self.tblWagonPos.accessRow(row).itemObject.CM_WagonPositionalRule;
	
	doMustSelectRule(rule);
	
	if rule &lt;&gt; null then
		setControlsForEdit();
		self.tblWagonPos.removeItem(row);
		delete rule;
		btnAddRule.enabled := true;
		btnEditRule.enabled := true;
		btnDeleteRule.enabled := true;
		hasChanged := true;
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doResize" id="0f62f2c1-2fbc-46af-8fa2-40d94ca981ad">
        <updating/>
        <source>doResize() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
30 June 2009	cnwndl1	Initial creation

*/

vars

begin
	
	inheritMethod();
	
	self.grpGeneral.left := 5;
	self.grpGeneral.top := 2;
	self.grpGeneral.width := self.width - 20;
	
	/*self.grpRules.left := 5;
	self.grpRules.top := self.grpGeneral.top + self.grpGeneral.height + 2;
	self.grpRules.width := self.grpGeneral.width;
	self.grpRules.height := self.height - grpRules.top - 68;*/
	// 13/12/2010 cnwar2 #26332 - replaced above
	self.fldRules.left := 5;
	self.fldRules.top := self.grpGeneral.top + self.grpGeneral.height + 2;
	self.fldRules.width := self.grpGeneral.width - 5;
	self.fldRules.height := self.height - fldRules.top - 68;
	
	self.btnAddRule.top := 18;
	self.btnEditRule.top := self.btnAddRule.top;
	self.btnDeleteRule.top := self.btnAddRule.top;
	
	self.tblWagonPos.top := 45;
	self.tblWagonPos.left := 5;
	//self.tblWagonPos.height := self.grpRules.height - 50;
	//self.tblWagonPos.width := self.grpRules.width - 10;
	// 13/12/2010 cnwar2 #26332 - replaced above
	self.tblWagonPos.height := self.fldRules.height - 70;
	self.tblWagonPos.width := self.fldRules.width - 15;
	
	// 13/12/2010 cnwar2 #26332
	self.mulRestConsignee.cnEcResizeContents();	
	self.mulSealTypes.cnEcResizeContents();
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doSaveGeneral" id="d6af5352-a312-4f64-bf6e-9d796acdeb3b">
        <updating/>
        <source>doSaveGeneral():Boolean updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06/08/2009	cnwndl1	Initial creation
01/04/2010	NDL	Par 23556
11/03/2013	cnwdap1	PAR #31155 CCMS SFW 1321 Imperial Measurements
18 Mar 2013	NDL Par 31278
11 Sep 2013	NDL	Par 32172
12 Oct 2016	cnwkpd1	TFS 2815 - JADE 7.1.08 causeEvent changes

*/
vars
	locationIds 			: String;
	locationIdsArray,
	locationsArray 			: StringArray;
	tierIds 				: String;
	tierIdsArray,
	tiersArray 				: StringArray;
	ok 						: Boolean;
	warningsResult 			: Integer;
	string 					: String;
	consignees				: CM_ConsignByCodeDict;
	consigneeRestrictions	: CM_ConsignCodeArray;
	isAdd 					: Boolean;
	newWagonClass 			: CM_WagonClass;
	consignee 				: CM_ConsigneeConsignor;
	consigneeCode			: String;
	index 					: Integer;
	maxWeight, tareWeight	: Decimal [23,10];					// PAR #31155
	deckHeight, totalHeight	: Decimal [23,10];					// PAR #31155
	oHeightWork	: Decimal [23,10]; 
	oLengthWork	: Decimal [23,10];
	oWidthWork	: Decimal [23,10];
	iHeightWork	: Decimal [23,10]; 
	iLengthWork	: Decimal [23,10]; 
	iWidthWork	: Decimal [23,10];
	oHeight	: Decimal [23,10]; 
	oLength	: Decimal [23,10];
	oWidth	: Decimal [23,10];
	iHeight	: Decimal [23,10]; 
	iLength	: Decimal [23,10]; 
	iWidth	: Decimal [23,10];
	wagonType : Integer;
	msg : String;
	sealTypes : CM_SealTypeDict;
	theResult : Integer;	//14 Jan 2020 NDL	TFS 46815

	
begin
	
	on CM_Exception do app.validationExHandler(exception, app.myPassport);
	app.setContinueCMExceptions(true);
	app.myPassport.clearErrorsWarnings();
	
	locationIds   := txtLocations.text.trimBlanks;
	locationIds.replaceChar(',',' ');
    locationIdsArray := locationIds.getTokens();
	create locationsArray transient;
    foreach string in locationIdsArray do
    	locationsArray.add(string.trimBlanks);
    endforeach;
	
	tierIds   := txtTierIds.text.trimBlanks;
	tierIds.replaceChar(',',' ');
    tierIdsArray := tierIds.getTokens();
	create tiersArray transient;
    foreach string in tierIdsArray do
    	tiersArray.add(string.trimBlanks);
    endforeach;
	
	create consignees transient;
    create consigneeRestrictions transient;
    self.mulRestConsignee.getSelected(consignees);
    foreach consignee in consignees do
    	consigneeCode := consignee.code.trimBlanks;
     	consigneeRestrictions.add(consigneeCode);
    endforeach;
	
	create sealTypes transient;
    self.mulSealTypes.getSelected(sealTypes);
	
	if myPxyWagonClass = null then
		create myPxyWagonClass transient;
		isAdd := true;
	endif;
	
	iHeight := self.tblIHeight.getConvertedValue;
	iLength := self.tblILength.getConvertedValue;
	iWidth := self.tblIWidth.getConvertedValue;
	oHeight := self.tblOHeight.getConvertedValue;
	oLength := self.tblOLength.getConvertedValue;
	oWidth := self.tblOWidth.getConvertedValue;
	deckHeight := self.tblDeckHeight.getConvertedValue;
	totalHeight := self.tblMaxCHeight.getConvertedValue;
	maxWeight := self.tblMaxCWeight.getConvertedValue;
	tareWeight := self.tblTare.getConvertedValue;

	//18 Mar 2013	NDL	Par 31278
	if self.cmbWagonType.listIndex &gt; 0 then
		wagonType := self.cmbWagonType.itemData[self.cmbWagonType.listIndex];
	endif;
	
	//Par 35346 / CCMS 1408
	if self.myRealWagonClass &lt;&gt; null and self.myRealWagonClass.isWellcar then
		if not self.myRealWagonClass.allWagons.isEmpty then
			if self.myRealWagonClass.maxNumInStack &lt;&gt; txtStack.text.Integer
			then
				msg := app.getErrorString(Your_wagon_class_assoc_wagon_w);
				app.msgBox( msg, app.getErrorString(Error), MsgBox_OK_Only );
				return false;
			endif;
		endif;
	endif;
	
	myPxyWagonClass.setProxy(	txtCode.text,	//pCode : String;
								chkGenrator.value,	//pAcceptsGenerator : Boolean; 
								chkDoors.value,	//pDoorsAccessible : Boolean; 
								chkEntry.value,	//_isNotAvailableForEntry : Boolean; 
								maxWeight,	//pMaxLoadWeight : Decimal;														// PAR #31155
								txtStack.text.Integer,	//pMaxNumInStack : Integer;
								txt10FootUnits.text.Integer,	//pLenInUnits : Integer;
								locationsArray,	//pLocationIds : StringArray;
								consigneeRestrictions,	//pConsigneeRestrictions : CM_ConsignCodeArray;
								deckHeight,	//pDeckHeight : Decimal;														// PAR #31155
								totalHeight,	//pMaxCargoHeight : Decimal;												// PAR #31155
								tareWeight,	//pTareWeight : Decimal;														// PAR #31155
								cmbCarrier.listObject.CM_Carrier,	//pMyCarrier : CM_Carrier
								iHeight,	//pInternalHeight : Decimal;	//18 Mar 2013	NDL	Par 31278
								iLength,	//pInternalLength : Decimal;	//18 Mar 2013	NDL	Par 31278
								iWidth,	//pInternalWidth : Decimal;	//18 Mar 2013	NDL	Par 31278
								oHeight,	//pOverallHeight : Decimal;	//18 Mar 2013	NDL	Par 31278
								oLength,	//pOverallLength : Decimal;	//18 Mar 2013	NDL	Par 31278
								oWidth,	//pOverallWidth : Decimal;	//18 Mar 2013	NDL	Par 31278
								wagonType,	//pWagonType : Integer;
								tiersArray,	//pTierIds : StringArray
								sealTypes,	//pSealTypes : CM_SealTypeDict
								self.cmbWagonGraphic.itemData[cmbWagonGraphic.listIndex] // TFS 49523
								);
	
	
	//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		if isAdd then
			app.myTrxCA.trxCreateWagonClass(myPxyWagonClass, newWagonClass, app.myPassport);
		else
			app.myTrxUA.trxUpdateWagonClass(myPxyWagonClass, app.myPassport);
		endif;
	
		if app.myPassport.trxCompletedOK then
			if isAdd then
				if newWagonClass &lt;&gt; null then
					setMyRealWagonClass(newWagonClass);	
					self.loadData();	//03 Apr 2013	NDL	Par 31278
				endif;
			else
				setMyRealWagonClass(myRealWagonClass); // to refresh the edition ..
				loadTableWagonPos( myPxyWagonClass.allWagonPositionalRules ); // and table in case they changed number of positions
				loadTableWagonWells();	//10 Dec 2014	NDL	Par 35346
			endif;
			if myRealWagonClass &lt;&gt; null then
				beginTransaction;
				self.updateObjectEdition(myRealWagonClass);
				commitTransaction;
			endif;
			hasChanged := false;
			self.modalResult := IDOK;
			return true;
			
		else
			theResult := app.showErrorWarningDialog(myPxyWagonClass.code, app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		if isAdd then
			delete myPxyWagonClass;
		endif;
		return false;
		
	endwhile;
	
	
epilog

	delete locationIdsArray;
	delete locationsArray;
	delete tierIdsArray;
	delete tiersArray;
	delete consignees;
	delete consigneeRestrictions;
	delete sealTypes;
	
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSelectTableWagonRow" id="e062c202-825c-421b-b7ba-2039073161c1">
        <updating/>
        <source>doSelectTableWagonRow(isNew : Boolean) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
30 June 2009	cnwndl1	Initial creation

*/

vars

	rule : CM_WagonPositionalRule;
	form : SOP_WagonWeightPositionsForm;
	row : Integer;
	
begin
	
	row := self.tblWagonPos.row;
	rule := self.tblWagonPos.accessRow(row).itemObject.CM_WagonPositionalRule;
	
	doMustSelectRule(rule);
	
	if rule &lt;&gt; null then
		setControlsForEdit();
		create form;
		form.setMyWagonPositionalRule( rule, self );
		form.showModal;
		
		if form.modalResult = 0 then
			hasChanged := true;
			self.doRefreshTableRow( rule );
			btnAddRule.enabled := true;
			btnEditRule.enabled := true;
			btnDeleteRule.enabled := true;
		elseif isNew then
			doRemoveRule();
			hasChanged := false;
			setControlsForEdit();
			tblWagonPos.row := 1;
		else
			setControlsForEdit();
		endif;
		
	endif;
	
epilog

end;</source>
        <Parameter name="isNew" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSelectTableWagonWells" id="6f748d9c-21b6-45ea-9a7a-a2e314647f41">
        <updating/>
        <source>doSelectTableWagonWells() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 December 2014	cnwndl1	Initial creation

*/

vars

	wellDef : CM_WagonWellDefinition;
	form : SOP_WagonWellDefinitionForm;
	row : Integer;
	
begin
	
	row := self.tblWagonWells.row;
	wellDef := self.tblWagonWells.accessRow(row).itemObject.CM_WagonWellDefinition;
	
	if wellDef = null then
		app.msgBox(app.getErrorString(NOTHING_SELECTED) ,app.getErrorString(Error) ,MsgBox_OK_Only + MsgBox_Information_Icon);
	endif;
	
	
	if wellDef &lt;&gt; null then
		create form;
		form.setMyWagonWellDef( wellDef, self );
		form.showModal;
		
		if form.modalResult = 0 then
			self.loadTableWagonWells();
		else
			setControlsForEdit();
		endif;
		
	endif; 
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getRowForRule" id="50f9d3a9-fca4-4bd8-aca8-c9886df208ca">
        <source>getRowForRule( rule : CM_WagonPositionalRule ):Integer;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
01 July 2009	cnwndl1	Initial creation

*/

vars
	rows : Integer;
	pos : Integer;
	row : Integer;
begin

	rows := self.tblWagonPos.rows;

	foreach pos in 1 to rows do
		if self.tblWagonPos.accessRow(pos).itemObject = rule then
			row := pos;
		endif;
	endforeach;
	
	return row;
	
epilog

end;</source>
        <Parameter name="rule" type="CM_WagonPositionalRule"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="loadData" id="bc8a8847-7b23-4f9c-998e-8a4e3a308ff2">
        <updating/>
        <source>loadData()protected, updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30/05/2009	cnwndl1	Initial creation
07/03/2013	cnwdap1	PAR #31155 CCMS SFW 1321 Imperial Measurements
11 Sep 2013	NDL	Par 32172
*/

vars
	unitsOf10 	: Integer;
	consignee	: CM_ConsigneeConsignor;
	consignees	: CM_ConsignByCodeDict;
	code		: String;
	
begin

	self.showHideTypeDepandantFields();	//18 Mar 2013	NDL	Par 31278
		
	if myPxyWagonClass = null then
		self.setCaption( app.getErrorString(New_Wagon_class) );
		clearWagonClassFields();
		setControlsForEdit();
		txtCode.setFocus();
		
	else
		self.setCaption( app.getErrorString(Wagon_class) &amp; " " &amp; self.myRealWagonClass.CM_WagonClass.code );
		txtCode.text := myPxyWagonClass.code;
		self.cmbWagonType.listIndex := self.cmbWagonType.findStringExact(1,self.myRealWagonClass.getWagonTypeString);
		chkEntry.value := myPxyWagonClass.isNotAvailableForEntry;
		chkGenrator.value := myPxyWagonClass.acceptsGenerator; 
		chkDoors.value := myPxyWagonClass.doorsAccessible; 
		setLocationIdsText( myPxyWagonClass.locationIds, myPxyWagonClass.tierIds );
		if not self.myRealWagonClass.isBoxcar then
			txtStack.text := myPxyWagonClass.maxNumInStack.asStringJMT;
		endif;
		
		//11 Sep 2013	NDL	Par 32172
		self.tblMaxCWeight.setValues(app.convertMeasurementForDisplay(self.weightType.shortName, myPxyWagonClass.maxLoadWeight) &amp; Space &amp; self.weightType.shortName);
		self.tblTare.setValues(app.convertMeasurementForDisplay(self.weightType.shortName, myPxyWagonClass.tareWeight) &amp; Space &amp; self.weightType.shortName);
		setTotalWeight();
		
		//11 Sep 2013	NDL	Par 32172
		self.tblIHeight.setValues(app.convertMeasurementForDisplay(self.heightType.shortName, myPxyWagonClass.internalHeight) &amp; Space &amp; self.heightType.shortName);
		self.tblILength.setValues(app.convertMeasurementForDisplay(self.lengthType.shortName, myPxyWagonClass.internalLength) &amp; Space &amp; self.lengthType.shortName);
		self.tblIWidth.setValues(app.convertMeasurementForDisplay(self.widthType.shortName, myPxyWagonClass.internalWidth) &amp; Space &amp; self.widthType.shortName);
		self.tblOHeight.setValues(app.convertMeasurementForDisplay(self.heightType.shortName, myPxyWagonClass.overallHeight) &amp; Space &amp; self.heightType.shortName);
		self.tblOLength.setValues(app.convertMeasurementForDisplay(self.lengthType.shortName, myPxyWagonClass.overallLength) &amp; Space &amp; self.lengthType.shortName);
		self.tblOWidth.setValues(app.convertMeasurementForDisplay(self.widthType.shortName, myPxyWagonClass.overallWidth) &amp; Space &amp; self.widthType.shortName);
	
		self.tblMaxCHeight.setValues(app.convertMeasurementForDisplay(self.heightType.shortName, myPxyWagonClass.maxCargoHeight) &amp; Space &amp; self.heightType.shortName);
		self.tblDeckHeight.setValues(app.convertMeasurementForDisplay(self.heightType.shortName, myPxyWagonClass.deckHeight) &amp; Space &amp; self.heightType.shortName);
		
		setTotalHeight();
		
		self.myAssistant.comboBoxCarrier(self.cmbCarrier, myRealWagonClass.myCarrier);
		
		loadTableWagonPos( myPxyWagonClass.allWagonPositionalRules );
		loadTableWagonWells();
		
		create consignees  transient;
		foreach code in self.myRealWagonClass.allConsigneeCodesRestricted do
			consignee := app.myRoot.allConsigneeConsignors[code];
			if consignee &lt;&gt; null then
				if (not consignees.includes(consignee)) then
					consignees.add(consignee);
				endif;
			endif;
		endforeach;
		self.mulRestConsignee.setSelected(consignees);
		
		//10 Mar 2015	NDL	Par 35828
		if myPxyWagonClass.allSelectedSealTypes &lt;&gt; null and myPxyWagonClass.hasSelectableSealTypes then
			self.mulSealTypes.setSelected( myPxyWagonClass.allSelectedSealTypes );
		endif;
		
		// TFS 49523 wagon graphic
		self.cmbWagonGraphic.visible :=  self.cmbWagonType.itemData[self.cmbWagonType.listIndex] = CM_WagonClass.Wagon_Boxcar;
		if self.cmbWagonGraphic.visible then
			self.cmbWagonGraphic.listIndex := myPxyWagonClass.numOfTwenty + 1;
		endif;
	endif;
	
	hasChanged := false;
	
epilog
	delete consignees;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="loadTableWagonPos" id="a8b25489-56e3-49d3-81d9-e9cd73d16b7b">
        <updating/>
        <source>loadTableWagonPos( ruleSet : CM_WagonPositionalRuleSet ) updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30/06/2009	cnwndl1	Initial creation
07/03/2013	cnwdap1	PAR #31155 CCMS SFW 1321 Imperial Measurements
11 Sep 2013	NDL	Par 32172
*/
vars

	pos : Integer;
	base : Integer;
	rule : CM_WagonPositionalRule;
	position : CM_WagonPosition;
	
	length : String;
	maxWeight : String;
	deckHeight : String;
	tableLine : String;

begin

	tblWagonPos.clear();
	
	if numberOfPositions &lt; 1 then
		tblWagonPos.visible := false;
	else
		tblWagonPos.visible := true;
	endif;
	
	if numberOfPositions &gt; 0 then
	
		tblWagonPos.fixedRows := 2;
		tblWagonPos.rows := 2;
		headingRows := 2;
		tblWagonPos.columns := (numberOfPositions * 3);
		base := 0;
		foreach pos in 1 to numberOfPositions do
			base := base + 1;
			tblWagonPos.setCellText( 1, base, app.getErrorString(Position) &amp; " " &amp; pos.String);
			tblWagonPos.accessCell(1,base).mergeCells := 1;
			tblWagonPos.accessCell(1,base).backColor := LightYellow;
			base := base + 2;
		endforeach;
		base := 0;
		foreach pos in 1 to numberOfPositions do
			base := base + 1;
			//tblWagonPos.setCellText( 2, base, app.getErrorString(Length_Title) );																				// PAR #31155
			tblWagonPos.setCellText( 2, base, app.getErrorString(Length_Title) &amp; Space &amp; Left_Round_Bracket &amp; System_Type_Feet &amp; Right_Round_Bracket );		// PAR #31155
			tblWagonPos.accessCell(2,base).backColor := LightYellow;
			base := base + 1;
			//tblWagonPos.setCellText( 2, base, app.getErrorString(Max_weight_title) );																			// PAR #31155
			tblWagonPos.setCellText( 2, base, app.getErrorString(Max_weight_title) &amp; Space &amp; Left_Round_Bracket &amp; weightType.shortName &amp; Right_Round_Bracket );	// PAR #31155
			tblWagonPos.accessCell(2,base).backColor := LightYellow;
			base := base + 1;
			//tblWagonPos.setCellText( 2, base, app.getErrorString(Deck_height) );																				// PAR #31155
			tblWagonPos.setCellText( 2, base, app.getErrorString(Deck_height) &amp; Space &amp; Left_Round_Bracket &amp; lengthType.shortName &amp; Right_Round_Bracket );		// PAR #31155
			tblWagonPos.accessCell(2,base).backColor := LightYellow;
		endforeach;
	
		if ruleSet &lt;&gt; null then
		
			foreach rule in ruleSet do
				tableLine := null;
				pos := 1;
				foreach pos in 1 to numberOfPositions do
					position := rule.allWagonPositions.getAtKey(pos);
					if position = null then
						length := " ";
						maxWeight := " ";
						deckHeight := " ";
					else
						length := position.cargoLength.asStringJMT.nullWhenZero;
						//maxWeight := position.maxWeight.asStringWeightJMT.nullWhenZero;										// PAR #31155
						//deckHeight := position.deckHeight.asStringMeasurementJMT.nullWhenZero;								// PAR #31155
						maxWeight := app.convertMeasurementForDisplay(weightType.shortName, position.maxWeight).nullWhenZero;	// PAR #31155
						deckHeight := app.convertMeasurementForDisplay(lengthType.shortName, position.deckHeight).nullWhenZero;	// PAR #31155
					endif;
					if tableLine &lt;&gt; null then
						tableLine := tableLine &amp; Tab;
					endif;
					tableLine := tableLine &amp; length &amp; Tab &amp; maxWeight &amp; Tab &amp; deckHeight;
				endforeach;
				tblWagonPos.addItem( tableLine );
				tblWagonPos.accessRow(tblWagonPos.rows).itemObject := rule;
				tblWagonPos.accessRow(tblWagonPos.rows).alignment := Table.Alignment_Right;
			endforeach;
		
		endif;
		
	endif;
	
	
epilog

end;</source>
        <Parameter name="ruleSet" type="CM_WagonPositionalRuleSet"/>
    </JadeMethod>
    <JadeMethod name="loadTableWagonWells" id="fd49e32d-9ee3-4b31-b9d5-cb8ca65ccad3">
        <source>loadTableWagonWells();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 December 2014	cnwndl1	Initial creation	Par 35346 / CCMS 1408

*/

vars

	numberOfWells : Integer;
	pos : Integer;
	wagonWellDef : CM_WagonWellDefinition;
	loadWeight : Decimal [14,4];
	tareWeight : Decimal [14,4];
	loadHeight : Decimal [14,4];

begin

	if myPxyWagonClass &lt;&gt; null then
		loadWeight := myPxyWagonClass.maxLoadWeight;
		tareWeight := myPxyWagonClass.tareWeight;
		loadHeight := myPxyWagonClass.maxCargoHeight;
	endif;

	self.tblMaxCWeight.setValues(app.convertMeasurementForDisplay(self.weightType.shortName, loadWeight) &amp; Space &amp; self.weightType.shortName);
	self.tblTare.setValues(app.convertMeasurementForDisplay(self.weightType.shortName, tareWeight) &amp; Space &amp; self.weightType.shortName);
	setTotalWeight();
	
	self.tblMaxCHeight.setValues(app.convertMeasurementForDisplay(self.heightType.shortName, loadHeight) &amp; Space &amp; self.heightType.shortName);
	setTotalHeight();
	
	self.showHideTypeDepandantFields();

	tblWagonWells.clear();
	
	if self.myRealWagonClass = null or not self.myRealWagonClass.isWellcar then
		shtWells.visible := false;
		btnEditWell.visible := false;
	else
		numberOfWells := self.myRealWagonClass.allWagonWellDefArray.size;
		shtWells.visible := true;
		btnEditWell.visible := true;
	endif;
	
	if numberOfWells &gt; 0 then
	
		tblWagonWells.fixedRows := 1;
		tblWagonWells.rows := 1;
		tblWagonWells.columns := 2;
		tblWagonWells.setCellText(1,1, app.getErrorString(Wagon_well) &amp; Tab &amp; app.getErrorString(Description) );
		
		foreach wagonWellDef in self.myRealWagonClass.allWagonWellDefArray do
			pos := tblWagonWells.addItem( wagonWellDef.wellId &amp; Tab &amp; wagonWellDef.getWellDescription );
			tblWagonWells.accessRow(pos).itemObject := wagonWellDef;
		endforeach;

	endif;
	
	
epilog
	
end;</source>
    </JadeMethod>
    <JadeMethod name="queryUnload" id="621ebf85-18af-42fc-b9ea-33e437105b42">
        <controlMethod name="Form::queryUnload"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>queryUnload(cancel: Integer io; reason: Integer) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
30 June 2009	cnwndl1	Initial creation

*/

vars
	result : Integer;
begin
	
	if hasChanged then
		result := app.msgBox(app.getErrorString(EditChangedAndClosing), self.caption &amp; " " &amp; app.getErrorString(Window_closing) &amp; " !", MsgBox_Yes_No + MsgBox_Question_Mark_Icon);
		if result &lt;&gt; MsgBox_Return_Yes then
			cancel:=1;
		endif;	
	endif;
epilog

end;</source>
        <Parameter name="cancel" type="Integer" usage="io"/>
        <Parameter name="reason" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="resize" id="1e81998f-cfee-4533-8dd9-925bcb83a221">
        <controlMethod name="Form::resize"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>resize() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
05 August 2009	cnwndl1	Initial creation

*/

vars

begin
	doResize;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setControlsForEdit" id="b5895c6a-d957-47ce-a633-2f0251ba9cf3">
        <updating/>
        <source>setControlsForEdit() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06 August 2009	cnwndl1	Initial creation

*/

vars

	updateAllowed : Boolean;

	row : Integer;
	rule : CM_WagonPositionalRule;
	wellDef : CM_WagonWellDefinition;
	
begin

	updateAllowed := self.editMode &lt;&gt; self.ViewMode;
	
	self.cmbWagonType.enabled := updateAllowed and self.myRealWagonClass = null;
	self.tblOHeight.enabled := updateAllowed;
	self.tblOLength.enabled := updateAllowed;
	self.tblOWidth.enabled := updateAllowed;
	
	self.tblIHeight.enabled := updateAllowed;
	self.tblILength.enabled := updateAllowed;
	self.tblIWidth.enabled := updateAllowed;
		

	self.txtCode.enabled := updateAllowed;
	self.chkDoors.enabled := updateAllowed;
	self.chkEntry.enabled := updateAllowed;
	self.chkGenrator.enabled := updateAllowed;
	self.txt10FootUnits.enabled := updateAllowed;
	self.txtLocations.enabled := updateAllowed;
	self.tblMaxCHeight.enabled := updateAllowed;
	self.tblMaxCWeight.enabled := updateAllowed;
	self.txtStack.enabled := updateAllowed;
	self.lblTierIds.enabled := updateAllowed;
	self.txtTierIds.enabled := updateAllowed;
	self.tblTare.enabled := updateAllowed;
	self.tblDeckHeight.enabled := updateAllowed;
	self.cmbCarrier.enabled := updateAllowed;
	
	self.btnSaveBase.enabled := updateAllowed;
	self.btnCancelBase.enabled := true;
	
	row := self.tblWagonPos.row;
	if row &gt; self.headingRows and row &lt;= tblWagonPos.rows then 
		rule := self.tblWagonPos.accessRow(row).itemObject.CM_WagonPositionalRule;
	endif;
	
	self.btnAddRule.enabled := updateAllowed and myRealWagonClass &lt;&gt; null;
	self.btnEditRule.enabled := updateAllowed and myRealWagonClass &lt;&gt; null and rule &lt;&gt; null;
	self.btnDeleteRule.enabled := updateAllowed and myRealWagonClass &lt;&gt; null and rule &lt;&gt; null;
	
	//Par 35346 / CCMS 1408
	row := self.tblWagonWells.row;
	if row &gt; self.tblWagonWells.fixedRows and row &lt;= tblWagonWells.rows then 
		wellDef := self.tblWagonWells.accessRow(row).itemObject.CM_WagonWellDefinition;
	endif;
	
	self.btnEditRule.enabled := updateAllowed and myRealWagonClass &lt;&gt; null and wellDef &lt;&gt; null;
	
	self.mulRestConsignee.userInputEnabled 	:= updateAllowed;	// 13/12/2010 cnwar2 #26332
	
	self.mulSealTypes.userInputEnabled 	:= updateAllowed;	//10 Mar 2015	NDL	Par 35828
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setLocationIdsText" id="0607d1ac-3e21-458d-8c3e-184833681658">
        <source>setLocationIdsText( _locationIds : StringArray; _tierIds : StringArray ) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
05 August 2009	cnwndl1	Initial creation

*/

vars

	first : Boolean;
	str1 : String;
	str2 : String;
	
begin

	if _locationIds &lt;&gt; null then
		foreach str1 in _locationIds do
			if (not first) then
				first := true;
				str2 := str1.trimBlanks;
			else
				str2 := str2 &amp; ", " &amp; str1.trimBlanks;
			endif;
		endforeach;
	endif;
	
	txtLocations.text := str2;
	
	//Par 35346 / CCMS 1408
	first := false;
	str1 := null;
	str2 := null;
	
	if _tierIds &lt;&gt; null then
		foreach str1 in _tierIds do
			if (not first) then
				first := true;
				str2 := str1.trimBlanks;
			else
				str2 := str2 &amp; ", " &amp; str1.trimBlanks;
			endif;
		endforeach;
	endif;
	
	txtTierIds.text := str2;
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_locationIds" type="StringArray"/>
        <Parameter name="_tierIds" type="StringArray"/>
    </JadeMethod>
    <JadeMethod name="setMyRealWagonClass" id="ae663976-a3ca-4d32-a8fa-fb954962601f">
        <updating/>
        <source>setMyRealWagonClass( _wagonClass : CM_WagonClass ) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
01 July 2009	cnwndl1	Initial creation

*/

vars
	loadState : Boolean;
	rule : CM_WagonPositionalRule;
	pxyRule : CM_WagonPositionalRule;
	posi : CM_WagonPosition;
	pxyPosi : CM_WagonPosition;
	
	unitsOf10 : Integer;
begin

	app.cmsBeginLoad(loadState);
	
	if _wagonClass &lt;&gt; null then
	
		delete myPxyWagonClass;
		
		self.myRealWagonClass := _wagonClass;
		
		unitsOf10 := myRealWagonClass.lenInUnits;
		txt10FootUnits.text := unitsOf10.asStringJMT;
		if unitsOf10 &gt; 1 then
			numberOfPositions := (unitsOf10 / 2).Integer;
			lbl20FootPos.caption := app.getErrorString(Which_equates) &amp; " " &amp; numberOfPositions.asStringJMT &amp; " " &amp; app.getErrorString(Twenty_foot_positions);
		endif;
		
		myPxyWagonClass := _wagonClass.pxyCreateUpdateProxy();
		
		foreach rule in myRealWagonClass.CM_WagonClass.allWagonPositionalRules do
			create pxyRule transient;
			pxyRule.setProxy(	myPxyWagonClass,	//_myWagonClass : CM_WagonClass;
								numberOfPositions,	//_numberOfPositions : Integer;
								rule.allWagonPositions	//_allWagonPositions : CM_WagonPositionDict
								);
		endforeach;
	else
		myRealWagonClass := null;
	endif;
	
epilog

	app.cmsEndLoad(loadState);
	
end;</source>
        <Parameter name="_wagonClass" type="CM_WagonClass"/>
    </JadeMethod>
    <JadeMethod name="setTotalHeight" id="837d831c-48b6-4b4c-b26c-9dee8e9316a9">
        <source>setTotalHeight() protected;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05/08/2009	cnwndl1	Initial creation
11/03/2013	cnwdap1	PAR #31155 CCMS SFW 1321 Imperial Measurements
11 Sep 2013	NDL	Par 32172
*/

vars

	totalHeight	: Decimal [23,10];				// PAR #31155
	deckHeight	: Decimal [23,10];				// PAR #31155
	cargoHeight	: Decimal [23,10];				// PAR #31155

begin
	
	deckHeight := self.tblDeckHeight.getConvertedValue;
	cargoHeight := self.tblMaxCHeight.getConvertedValue;		// PAR #31155
	totalHeight := deckHeight + cargoHeight;
	self.tblTotHeight.setValues(app.convertMeasurementForDisplay(self.heightType.shortName, totalHeight) &amp; Space &amp; self.heightType.shortName);// PAR #31155
	self.tblTotHeight.enabled := false;

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setTotalWeight" id="7d03a041-5528-41df-951b-5fbe177aca85">
        <source>setTotalWeight();
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05/08/2009	cnwndl1	Initial creation
11/03/2013	cnwdap1	PASR #31155 CCMS SFW 1321 Imperial Measurements
11 Sep 2013	NDL	Par 32172
*/
vars

	totalWeight	: Decimal [23,10];						// PAR #31155

begin
	
	totalWeight :=self.tblMaxCWeight.getConvertedValue + self.tblTare.getConvertedValue;
	self.tblTotWeight.setValues(app.convertMeasurementForDisplay(self.weightType.shortName, totalWeight) &amp; Space &amp; self.weightType.shortName);
	self.tblTotWeight.enabled := false;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="1ccbe693-ee97-4f72-aa43-f8eef792368f">
        <updating/>
        <source>setupForm() updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30/06/2009	cnwndl1	Initial creation
07/03/2013	cnwdap1	PAR #31155 CCMS SFW 1321 Imperial Measurements
*/
vars

	tmpSheet	: JadeTableSheet;

begin
	create self.myAssistant transient;

	// starting size
	self.width := self.minimumWidth;
	self.height := self.minimumHeight;
	
	self.displayMeasurementFields();

	inheritMethod();
	
	self.centreOverParent(0);
	
	// same as setMargions on CM_Table
	tmpSheet := tblWagonPos.accessSheet(1);
	tmpSheet.marginLeft := 2;
	tmpSheet.marginRight := 2;
	tmpSheet.marginTop := 1;
	//RS &amp; DQ don't want fixed rows to be 3D
	tmpSheet.fixed3D := false;
	
	// 13/12/2010 cnwar2 #26332
	self.mulRestConsignee.setSelected(null);
	self.mulRestConsignee.multiSelect 		:= ListBox.MultiSelect_Extended;
	self.mulRestConsignee.userInputEnabled 	:= false;
	self.mulRestConsignee.formDisplayEntryMethodName := SOP_WagonPositionRuleForm::displayEntryConsignee.name;
	self.mulRestConsignee.availableHeading := app.getErrorString(Consignees);
	self.mulRestConsignee.selectedHeading  := app.getErrorString(Restricted_consignees);
	self.mulRestConsignee.setAvailable(app.myRoot.allConsigneeConsignors, true);
	self.mulRestConsignee.move(10, 10, self.mulRestConsignee.parent.width-10 , self.mulRestConsignee.parent.height-10); 		
	self.mulRestConsignee.parentAspect:=GroupBox.ParentAspect_StretchBoth;
	
	//10 Mar 2015	NDL	Par 35828
	self.mulSealTypes.setSelected(null);
	self.mulSealTypes.multiSelect 		:= ListBox.MultiSelect_Extended;
	self.mulSealTypes.userInputEnabled 	:= false;
	
	self.mulSealTypes.formDisplayEntryMethodName :=SOP_WagonPositionRuleForm::displayEntrySealType.name;
	self.mulSealTypes.availableHeading := app.getErrorString(Availab_wagon_seal_types);
	self.mulSealTypes.selectedHeading  := app.getErrorString(Selecte_wagon_seal_types);
	self.mulSealTypes.setAvailable(app.myRoot.allSealTypes, true);
	self.mulSealTypes.move(10, 10, self.mulSealTypes.parent.width-10 , self.mulSealTypes.parent.height-10); 		
	self.mulSealTypes.parentAspect:=GroupBox.ParentAspect_StretchBoth;
	
	if self.editMode = 0 then
		if app.getMyUser.canDo(self.myTerminal, self.permissionMaint) then
			if self.myRealWagonClass = null then
				self.editMode := self.AddMode;
			else
				self.editMode := self.EditMode;
			endif;
		elseif app.getMyUser.canDo(self.myTerminal, self.permissionView) then
			self.editMode := self.ViewMode;
		endif;
	endif;
	
	//18 Mar 2013	NDL	Par 31278
	self.cmbWagonType.clear();
	self.cmbWagonType.addItem(" ");
	self.cmbWagonType.itemData[self.cmbWagonType.addItem(app.getErrorString(Flatcar))] := CM_WagonClass.Wagon_Flatcar;
	self.cmbWagonType.itemData[self.cmbWagonType.addItem(app.getErrorString(Boxcar))] := CM_WagonClass.Wagon_Boxcar;
	self.cmbWagonType.itemData[self.cmbWagonType.addItem(app.getErrorString(Wellcar))] := CM_WagonClass.Wagon_Wellcar;	//Par 35346 / CCMS 1408
	self.cmbWagonType.itemData[self.cmbWagonType.addItem(app.getErrorString(Skeleton))] := CM_WagonClass.Wagon_SkeletonCar;	// TFS 2533
	
	// TFS 49523
	self.cmbWagonGraphic.visible := false;// TFS 49523
	self.doBuildWagonGraphicCombo(); // TFS 49523
	
	
	setControlsForEdit();
	loadData();
	
	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.grpGeneral.enabled:= false;
	endif;

epilog
	
end;</source>
    </JadeMethod>
    <JadeMethod name="showHideTypeDepandantFields" id="9ccffd60-6253-4cca-8d5d-2bfd74d682cc">
        <source>showHideTypeDepandantFields() protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 March 2013	cnwndl1	Initial creation	Par 31278
11 Sep 2013	NDL	Par 32172
12 Dec 2014	Par 35346 / CCMS 1408

*/

vars

	treatAsBoxcar : Boolean;
	treatAsFlatcar : Boolean;
	treatAsWellcar : Boolean;
	treatAsSkeletonCar: Boolean;
	treatAsNeither : Boolean;
	index : Integer;

begin

	if self.myRealWagonClass &lt;&gt; null then
		self.cmbWagonType.enabled := false;
		if self.myRealWagonClass.isFlatcar then
			treatAsFlatcar := true;
		elseif self.myRealWagonClass.isBoxcar then
			treatAsBoxcar := true;
		elseif self.myRealWagonClass.isWellcar then
			treatAsWellcar := true;
		elseif self.myRealWagonClass.isSkeletonCar then
			treatAsSkeletonCar := true;
		else
			treatAsNeither := true;
		endif;
	else
		index := self.cmbWagonType.listIndex;
		if index &lt; 1 or self.cmbWagonType.itemData[index] = 0 then
			treatAsNeither := true;
		elseif self.cmbWagonType.itemData[index] = CM_WagonClass.Wagon_Flatcar then
			treatAsFlatcar := true;
		elseif self.cmbWagonType.itemData[index] = CM_WagonClass.Wagon_Boxcar then
			treatAsBoxcar := true;
		elseif self.cmbWagonType.itemData[index] = CM_WagonClass.Wagon_Wellcar then
			treatAsWellcar := true;
		elseif self.cmbWagonType.itemData[index] = CM_WagonClass.Wagon_SkeletonCar then
			treatAsSkeletonCar := true;
		else
			//not coded for
			treatAsNeither := true;
		endif;
	endif;
	
	if treatAsWellcar then
		self.lblLocations.caption := app.getErrorString(Well_ids) &amp; ":";
	else
		self.lblLocations.caption := app.getErrorString(Location_ids) &amp; ":";
	endif;
	
	//default enabling...
	self.lblCWeight.enabled := true;
	self.tblMaxCWeight.enabled := true;
	self.lblTare.enabled := true;
	self.tblTare.enabled := true;
	self.lblTotWeight.enabled := true;
	self.tblTotWeight.enabled := true;
	self.tblMaxCHeight.enabled := true;
	self.lblMaxCHeight.enabled := true;
	self.txtLocations.enabled := true;
	self.lblLocations.enabled := true;
	self.lblStack.enabled := ( self.myRealWagonClass = null or self.myRealWagonClass.allWagons.isEmpty );
	self.txtStack.enabled := ( self.myRealWagonClass = null or self.myRealWagonClass.allWagons.isEmpty );
	self.cmbWagonGraphic.visible := false; // TFS 49523
	
	
	if treatAsNeither then
	
		self.cmbWagonType.enabled := true;
		
		self.chkDoors.visible := false;
		self.lblDoors.visible := false;
		self.chkGenrator.visible := false;
		self.lblGenerator.visible := false;
		self.txt10FootUnits.visible := false;
		self.lblLength.visible := false;
		self.lbl20FootPos.visible := false;
		self.txtLocations.visible := false;
		self.lblLocations.visible := false;
		self.txtStack.visible := false;
		self.lblStack.visible := false;
		self.lblTierIds.visible := false;
		self.txtTierIds.visible := false;
		self.lblCWeight.visible := true;
		self.tblMaxCWeight.visible := true;
		self.lblTare.visible := true;
		self.tblTare.visible := true;
		self.lblTotWeight.visible := true;
		self.tblTotWeight.visible := true;
		self.tblMaxCHeight.visible := false;
		self.lblMaxCHeight.visible := false;
		self.tblDeckHeight.visible := false;
		self.lblHeight.visible := false;
		self.shtPositRules.visible := false;
		self.lblMaxHeight.visible := false;
		self.tblTotHeight.visible := false;
		self.tblOHeight.visible := false;
		self.lblOHeight.visible := false;
		self.tblOLength.visible := false;
		self.lblOLength.visible := false;
		self.tblOWidth.visible := false;
		self.lblOWidth.visible := false;
		self.tblIHeight.visible := false;
		self.lblIHeight.visible := false;
		self.tblILength.visible := false;
		self.lblILength.visible := false;
		self.tblIWidth.visible := false;
		self.lblIWidth.visible := false;
		
	elseif treatAsFlatcar then
		self.chkDoors.visible := true;
		self.lblDoors.visible := true;
		self.chkGenrator.visible := true;
		self.lblGenerator.visible := true;
		self.txt10FootUnits.visible := true;
		self.lblLength.visible := true;
		self.lbl20FootPos.visible := true;
		self.txtLocations.visible := true;
		self.lblLocations.visible := true;
		self.txtStack.visible := true;
		self.lblStack.visible := true;
		self.lblTierIds.visible := true;
		self.txtTierIds.visible := true;
		self.lblCWeight.visible := true;
		self.tblMaxCWeight.visible := true;
		self.lblTare.visible := true;
		self.tblTare.visible := true;
		self.lblTotWeight.visible := true;
		self.tblTotWeight.visible := true;
		self.tblMaxCHeight.visible := true;
		self.lblMaxCHeight.visible := true;
		self.tblDeckHeight.visible := true;
		self.lblHeight.visible := true;
		self.shtPositRules.visible := true;
		if self.tblWagonPos.visible then
			self.fldRules.topSheet := self.shtPositRules;
		endif;
		self.lblMaxHeight.visible := true;
		self.tblTotHeight.visible := true;
		self.tblOHeight.visible := false;
		self.lblOHeight.visible := false;
		self.tblOLength.visible := false;
		self.lblOLength.visible := false;
		self.tblOWidth.visible := false;
		self.lblOWidth.visible := false;		
		self.tblIHeight.visible := false;
		self.lblIHeight.visible := false;
		self.tblILength.visible := false;
		self.lblILength.visible := false;
		self.tblIWidth.visible := false;
		self.lblIWidth.visible := false;
	
	
	elseif treatAsWellcar then
		self.chkDoors.visible := false;
		self.lblDoors.visible := false;
		self.chkGenrator.visible := false;
		self.lblGenerator.visible := false;
		self.txt10FootUnits.visible := false;
		self.lblLength.visible := false;
		self.lbl20FootPos.visible := false;
		self.txtLocations.visible := true;		self.txtLocations.enabled := ( self.myRealWagonClass = null or self.myRealWagonClass.allWagons.isEmpty );
		self.lblLocations.visible := true;		self.lblLocations.enabled := ( self.myRealWagonClass = null or self.myRealWagonClass.allWagons.isEmpty );
		self.txtStack.visible := true;			
		self.lblStack.visible := true;
		self.lblTierIds.visible := true;
		self.txtTierIds.visible := true;
		self.lblCWeight.visible := true;		self.lblCWeight.enabled := false;
		self.tblMaxCWeight.visible := true;		self.tblMaxCWeight.enabled := false;
		self.lblTare.visible := true;			self.lblTare.enabled := false;
		self.tblTare.visible := true;			self.tblTare.enabled := false;
		self.lblTotWeight.visible := true;		self.lblTotWeight.enabled := false;
		self.tblTotWeight.visible := true;		self.tblTotWeight.enabled := false;
		self.tblMaxCHeight.visible := true;		self.tblMaxCHeight.enabled := false;
		self.lblMaxCHeight.visible := true;		self.lblMaxCHeight.enabled := false;
		self.tblDeckHeight.visible := false;
		self.lblHeight.visible := false;
		self.shtPositRules.visible := false;
		if self.tblWagonWells.visible and self.shtWells.visible then
			self.fldRules.topSheet := self.shtWells;
		endif;
		self.lblMaxHeight.visible := false;	
		self.tblTotHeight.visible := false;
		self.tblOHeight.visible := false;
		self.lblOHeight.visible := false;
		self.tblOLength.visible := false;
		self.lblOLength.visible := false;
		self.tblOWidth.visible := false;
		self.lblOWidth.visible := false;		
		self.tblIHeight.visible := false;
		self.lblIHeight.visible := false;
		self.tblILength.visible := false;
		self.lblILength.visible := false;
		self.tblIWidth.visible := false;
		self.lblIWidth.visible := false;
	
	elseif treatAsBoxcar then
		self.chkDoors.visible := false;
		self.lblDoors.visible := false;
		self.chkGenrator.visible := false;
		self.lblGenerator.visible := false;
		self.txt10FootUnits.visible := false;
		self.lblLength.visible := false;
		self.lbl20FootPos.visible := false;
		self.txtLocations.visible := false;
		self.lblLocations.visible := false;
		self.txtStack.visible := false;
		self.lblStack.visible := false;
		self.lblTierIds.visible := false;
		self.txtTierIds.visible := false;
		self.lblCWeight.visible := true;
		self.tblMaxCWeight.visible := true;
		self.lblTare.visible := true;
		self.tblTare.visible := true;
		self.lblTotWeight.visible := true;
		self.tblTotWeight.visible := true;
		self.tblMaxCHeight.visible := false;
		self.lblMaxCHeight.visible := false;
		self.tblDeckHeight.visible := false;
		self.lblHeight.visible := false;
		self.shtPositRules.visible := false;
		self.lblMaxHeight.visible := false;
		self.tblTotHeight.visible := false;
		self.tblOLength.visible := true;
		self.tblOWidth.visible := true;
		self.tblOHeight.visible := true;
		self.tblIHeight.visible := true;
		self.tblILength.visible := true;
		self.tblIWidth.visible := true;
		self.lblOHeight.visible := true;
		self.lblOLength.visible := true;
		self.lblOWidth.visible := true;
		self.lblIHeight.visible := true;
		self.lblILength.visible := true;
		self.lblIWidth.visible := true;
		self.cmbWagonGraphic.visible := true; // TFS 49523
	
	elseif treatAsSkeletonCar then		// TFS 2533
		self.chkDoors.visible := false;
		self.lblDoors.visible := false;
		self.chkGenrator.visible := false;
		self.lblGenerator.visible := false;
		self.txt10FootUnits.visible := false;
		self.lblLength.visible := false;
		self.lbl20FootPos.visible := false;
		self.txtLocations.visible := false;
		self.lblLocations.visible := false;
		self.txtStack.visible := false;
		self.lblStack.visible := false;
		self.lblTierIds.visible := false;
		self.txtTierIds.visible := false;
		self.lblCWeight.visible := true;
		self.tblMaxCWeight.visible := true;
		self.lblTare.visible := true;
		self.tblTare.visible := true;
		self.lblTotWeight.visible := true;
		self.tblTotWeight.visible := true;
		self.tblMaxCHeight.visible := true;
		self.lblMaxCHeight.visible := true;
		self.tblDeckHeight.visible := true;
		self.lblHeight.visible := true;
		self.shtPositRules.visible := false;
		self.lblMaxHeight.visible := true;
		self.tblTotHeight.visible := true;
		self.tblOLength.visible := true;
		self.tblOWidth.visible := true;
		self.tblOHeight.visible := false;
		self.tblIHeight.visible := false;
		self.tblILength.visible := false;
		self.tblIWidth.visible := false;
		self.lblOHeight.visible := false;
		self.lblOLength.visible := true;
		self.lblOWidth.visible := true;
		self.lblIHeight.visible := false;
		self.lblILength.visible := false;
		self.lblIWidth.visible := false;
	endif;

epilog

end;</source>
