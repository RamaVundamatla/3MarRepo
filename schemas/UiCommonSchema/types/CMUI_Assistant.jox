    <JadeMethod name="showInvoiceCargoAllocMapping" id="00528678-66ab-42e6-8781-05c083df8094">
        <source>showInvoiceCargoAllocMapping(_alloc : CM_InvoiceAllocation; _qrm : CM_QuantityRangeMap; _allocClass : Class);
/*
Purpose:			
Date				Who			Reason
MARCH 2015		CNWAB1		Initial creation
*/

vars
	tmpForm : CMUI_InvoiceCargoAllocMapping;
begin

	if _alloc = null then
		return;
	endif;
	
	if _allocClass = CM_InvoiceCargoAllocation
	or _allocClass = CM_InvoiceInventoryAllocation then // ### TFS 51219 25MAY2021 NAVAB1
		tmpForm := app.loadForm(CMUI_InvoiceCargoAllocMapping, CMUI_Assistant, false, false, true, self.myTerminal, null).CMUI_InvoiceCargoAllocMapping;
	elseif _allocClass = CM_InvoiceAllocation then
		tmpForm := app.loadForm(CMUI_InvoiceSSAllocMapping, CMUI_Assistant, false, false, true, self.myTerminal, null).CMUI_InvoiceSSAllocMapping;
	endif;
	
	if tmpForm = null then
		return;
	endif;
	
	tmpForm.myAllocation := _alloc;
	tmpForm.myCurrentQuantityRangeMap := _qrm;
	
	tmpForm.updateMode := _qrm &lt;&gt; null;
	
	if tmpForm.showModal() = IDOK then
	endif;

epilog

end;</source>
        <Parameter name="_alloc" type="CM_InvoiceAllocation"/>
        <Parameter name="_qrm" type="CM_QuantityRangeMap"/>
        <Parameter name="_allocClass" type="Class"/>
    </JadeMethod>
    <JadeMethod name="showInvoiceForm" id="f4f78444-1ee8-4ce0-810a-051453c517f3">
        <source>showInvoiceForm(_object : Object; _masterMenuAction : CMUI_MenuAction);
// ---------------------------------------------------------------------------
// Created:		May 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	invoiceForm : Form;
	menuAction : CMUI_MenuAction;
	inv : CM_Invoice;
begin
	
	if _object = null then
		return;
	endif;
	
	if not _object.isKindOf(CM_InvoiceLine) 
	and not _object.isKindOf(CM_Invoice) then
		return;
	endif;
	menuAction := app.myController.createMenuAction(PmAdmInvoicelistView, null, _masterMenuAction, self.myTerminal);
	if menuAction = null then
		return;
	endif;
	
	invoiceForm := menuAction.goToObject(null, null, false, null);
	if invoiceForm = null then
		return;
	endif;

	if _object.isKindOf(CM_InvoiceLine) then
		inv := 	_object.CM_InvoiceLine.invoice;
	elseif _object.isKindOf(CM_Invoice) then
		inv := 	_object.CM_Invoice;
	else
		return;
	endif;
	
	invoiceForm.setPropertyValue("myCurrentInvoice", inv);
	
	invoiceForm.show(); 

end;</source>
        <Parameter name="_object" type="Object"/>
        <Parameter name="_masterMenuAction" type="CMUI_MenuAction"/>
    </JadeMethod>
