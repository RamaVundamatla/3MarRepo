    <JadeMethod name="utlUpdateMenuUserReportErrMsg" id="5e690e16-bbc4-47a6-804a-6109f705565d">
        <source>utlUpdateMenuUserReportErrMsg(_reportTemplate  : CM_ReportTemplate input; _err : String;
							_passport : CM_Passport input);

// cnwdvb1 31 October 2002 

vars

	userReport	: CM_MenuUserItem;
	report		: CM_MenuUserReport;
	
begin

	if _reportTemplate = null then
		// This valid for auto background reports.
		return;
	endif;
	self.initialiseActivity();
	app.setContinueCMExceptions(false);
	_reportTemplate.setErrorString(_err);
	foreach userReport in _reportTemplate.allMenuUserReports do
		report := userReport.CM_MenuUserReport;
		report.sendEvent(CM_User.BGP_REPORT_CREATED, false);
	endforeach;
	
end;</source>
        <Parameter name="_reportTemplate" type="CM_ReportTemplate" usage="input"/>
        <Parameter name="_err" type="String"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateMobileCompleteTruck" id="e78b4fd6-8c67-4e65-8440-78142321fa5d">
        <updating/>
        <source>utlUpdateMobileCompleteTruck(_job : CM_RoadJob io; _passport : CM_Passport input)updating;

vars
	moveController 	: CMIF_MoveController;
	ti 				: CM_TrackedItem;
	truckLoc 		: CM_LocationsController;
	firstTime		: Boolean;
	wle 			: CM_WorkListEntry;
begin
	truckLoc := _job.myVehicle.locationsController;
	create moveController transient;
	moveController.setMoveMode(REAL_MODE);
	moveController.setMyToPrimaryLocation(_job.myVehicle.locationsController);
	moveController.setJobForMove(_job);
	firstTime := true;
	foreach ti in _job.allReleaseTrackedItems do
		if ti.myPrimaryActualLocation &lt;&gt; truckLoc then
			wle := _job.getWLEForTI(ti);
			if firstTime then
				moveController.setMyTrackedItem(ti);
				moveController.setMyWorkListEntry(wle);
				firstTime := false;
			else
				moveController.allOtherTrackedItems.add(ti);
				if wle &lt;&gt; null then
					moveController.allOtherWLEs.add(wle);
				endif;
			endif;
		endif;
	endforeach;
	
	if moveController.myTrackedItem &lt;&gt; null then
		app.myUtilityUA.utlUpdateMoveTrackedItem(moveController, _passport);
	endif;
	
end;
</source>
        <Parameter name="_job" type="CM_RoadJob" usage="io"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateMoveMap" id="96544086-eefd-4204-abf6-bcdf64533de3">
        <source>utlUpdateMoveMap(pProxyMoveMap:CM_MoveMap;  _passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:		October  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	cancelSave		: Boolean;
	realMoveMap		: CM_MoveMap;
	expectedEdition	: Integer;
	
begin

	self.initialiseActivity();

	pProxyMoveMap.raiseExceptionIfNotProxy(method);

	app.setContinueCMExceptions(true);

	pProxyMoveMap.pxyGetRealObjectAndEdition(realMoveMap, expectedEdition);
	
	if realMoveMap = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_MoveMap.name, null, null);
		return;
	endif;

	app.myValUA.valMoveMap(realMoveMap, pProxyMoveMap);
	
	if (not self.checkValidationWithPassport(_passport)) then
		return;		// note that this gets "ignored" in the eplog
	endif;

	app.setContinueCMExceptions(false);

	exclusiveLock(realMoveMap);

	if _passport.noErrors and realMoveMap.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'MoveMap', null, null);
		return;
	endif;
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realMoveMap, true);
	endif;
	
	if _passport.noErrors then
		realMoveMap.setForUpdate(pProxyMoveMap);
	endif;


	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realMoveMap, false);
	endif;

epilog
	
	
end;</source>
