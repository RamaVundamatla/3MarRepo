    <JadeMethod name="setContractFromTI" id="ee466e30-2652-4f95-a821-f68b135f4e5c">
        <updating/>
        <source>setContractFromTI(_ti : CM_TrackedItem) updating;
/*
Purpose:			

Date		Who		Reason
12 April 2023	navab1	TFS 57512
*/

vars
	contractId : String;
begin
	if self.useSourceTI() then
		if _ti.myMasterTi &lt;&gt; null then
			contractId := _ti.myMasterTi.contractId;
		endif;
	endif;
	
	if contractId = null then
		contractId := _ti.contractId;
	endif;
	
	if contractId &lt;&gt; null then // ### TFS CR 54345 TASK 54267 01JUN2023 NAVAB1 - might have been set previously from the work order, so do not overwrite with a blank
		self.contractId := contractId;
	endif;
epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
