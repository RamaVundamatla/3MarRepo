    <JadeMethod name="delete" id="36be704d-0835-4f0b-95f1-cace0f9e08c7">
        <updating/>
        <source>delete() updating;
// -------------------------------------------
// Created 14 February 2005 by cnwdvb1
// -------------------------------------------

vars

	user 	: CM_User;
	report	: CM_MenuUserItem;
	theNote	: Integer;

begin
	
	theNote := CM_User.BGP_REPORT_DELETED;
	
	if self.isTransient() then
		return;
	endif;
	
	if global.isValidObject(self.myReportTemplate) then
		if self.myReportTemplate.myUserToRunAs &lt;&gt; null then
			theNote := EVENT_QRYREPORTUSER_UPDATE;
		endif;
		
		if self.myReportTemplate.allMenuUserReports.size = 1 then
			self.myReportTemplate.erase(NORMAL_ERASE);
		endif;
	endif;
	
	user := self.getMyUser();
	
	if global.isValidObject(user) then
		user.causeEvent(theNote, false, self);
	endif;

end;</source>
    </JadeMethod>
