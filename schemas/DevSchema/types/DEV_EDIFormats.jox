    <JadeMethod name="lstMatchedFields_click" id="ed2667d1-6a7d-4115-90ed-7de54c39a2ef">
        <controlMethod name="CMUI_ListBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>lstMatchedFields_click(listbox: ListBox input) updating;
//----------------------------------------------------------------
//	Created:	08 October 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	str			: String;
	xmlElem		: JadeXMLElement;
	xmlDoc		: JadeXMLDocument;
	field : CM_EDIItemField;
begin
	
	field := listbox.listObject.CM_EDIItemField;

	field.getFileFormatXML(str);
	
	if field.className = "CM_EDIFile" then
		self.lstEDIFileFields.listObject := field;
		self.lstEDITIFields.listObject := null;
		self.doSysFieldListClick(self.lstEDIFileFields);
		self.lstEDIFileFields.topIndex := self.lstEDIFileFields.listIndex;
	else
		self.lstEDITIFields.listObject := field;
		self.lstEDIFileFields.listObject := null;
		self.doSysFieldListClick(self.lstEDITIFields);
		self.lstEDITIFields.topIndex := self.lstEDITIFields.listIndex - 5;
	endif;
	

	
	self.cmbFormatMethod.text := field.stringFormatMethodName;
	
	
	create xmlDoc transient;
	
	xmlElem := xmlDoc.addElement('FormatField');
	
	
	listbox.listObject.CM_EDIItemField.setXMLElement(xmlElem);
	
	
epilog
	delete xmlDoc;	
	
end;</source>
        <Parameter name="listbox" type="ListBox" usage="input"/>
    </JadeMethod>
