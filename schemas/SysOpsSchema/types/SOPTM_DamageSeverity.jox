    <JadeMethod name="doSave" id="12fc2243-c579-47bb-ab9e-90d13e5044b8">
        <updating/>
        <source>doSave(): Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 June 2022	navhl20	ChangeRequest 53862: EUP - WMS - Damage Recording Extra Details

*/

vars
	theForm 				: SOP_TableMaintForm;
	tbl						: CM_EntryTable;
	code,
	description				: String;
	level					: Integer;
	isNotAvailableForEntry 	: Boolean;
	pxyDamageSeverity,
	newDamageSeverity		: CM_DamageSeverity;
	terminal				:CM_Terminal;
begin
	theForm := self.myForm;
	tbl := theForm.tblInput1;
	
	code := tbl.getValueByName(ETRow_Code).String;
	description := tbl.getValueByName(ETRow_Description).String;
	level := tbl.getValueByName(ETRow_DamageSeverity).Integer;
// ### TFS 55249 01NOV2022 NAVAB1 if level &lt; 1 or level &gt; 9999 then
// ### TFS 55249 01NOV2022 NAVAB1 		app.raiseUnexpectedProgramError(class.name, method.name, 'Invalid damage severity (' &amp; level.String &amp; ')');
// ### TFS 55249 01NOV2022 NAVAB1 		return false;
// ### TFS 55249 01NOV2022 NAVAB1 	endif;
	isNotAvailableForEntry := tbl.getValueByName(ETRow_IsNotAvailableForEntry).Boolean;
	terminal			   := self.myForm.myTerminal;
	
	if theForm.myProxyObject = null then
		if theForm.mode = theForm.Mode_Add then
			create theForm.myProxyObject as CM_DamageSeverity transient;
		else
			app.raiseUnexpectedProgramError(class.name, method.name, 'Proxy object null for update');
			return false;
		endif;
	endif;
	
	pxyDamageSeverity := theForm.myProxyObject.CM_DamageSeverity;
	pxyDamageSeverity.setProxy(code, description, isNotAvailableForEntry,level,terminal);
	
	if theForm.mode = theForm.Mode_Add then
		app.myTrxCA.trxCreateDamageSeverity(pxyDamageSeverity, newDamageSeverity, app.myPassport);
	elseif theForm.mode = theForm.Mode_Update then
		app.myTrxUA.trxUpdateDamageSeverity(pxyDamageSeverity, app.myPassport);
	endif;
	
	return app.myPassport.trxCompletedOK();
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getCollection" id="71c96890-7785-4256-ba5b-7c083338306d">
