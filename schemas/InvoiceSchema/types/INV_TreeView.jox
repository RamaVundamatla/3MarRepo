    <JadeMethod name="setupForm" id="97accc35-5f5e-4c2c-8a2c-b2b9fbaccd58">
        <updating/>
        <source>setupForm() updating;
// ---------------------------------------------------------------------------
// Created:		May 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
begin
	inheritMethod();
	self.splMain.setLeftToRightRatio(85);

	self.toolbarStyle := self.ToolbarStyle_ShowNoHide;
	self.showToolbar := true;
//	self.lstData.stretchHeight := true;
	self.lstData.stretchToParent := true;
	self.lstData.cnEcResizeContents();
	self.doResize();
	
	self.fldProperties.useSheetBackColors := true;
	self.fldProperties.setDefaultSheetBackColors();
	self.fldProperties.initSheetBackColors();
	
	self.setNavigatorHeading(self.caption);
end;</source>
    </JadeMethod>
    <JadeMethod name="showExtraInfo" id="43a5b91b-8611-4699-b23d-92580ffd57e7">
        <source>showExtraInfo(_object : CM_Object);
// ---------------------------------------------------------------------------
// Created:		27 February 2006  By Andrew Bishop cnwab1
// ---------------------------------------------------------------------------
// 24/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls

vars

	dataContainer : CM_DataContainer;
	theTI	: CM_TrackedItem;
	numberOfColumns,idx,theIndex,theTIIndex,lDisplayMode,theWidth : Integer;
	theLine,theAttibuteString : String;
	theSingle : Boolean;
	anObject : Object;
	theAttributeArray : ObjectArray;
	theObject : Object;
	
begin
	if not self.tblExtraInfo.visible then
		return;
	endif;
	
	self.tblExtraInfo.rows := 0;
	numberOfColumns := 4;

	if _object &lt;&gt; null then
		self.tblExtraInfo.alignment := Table.Alignment_Left_Top;

		//######################
		// DISPLAY INFO
		create dataContainer transient;
		dataContainer.headerColour := self.colorHeadingColumn;
		dataContainer.valueColour := self.colorValueColumn;
		

		self.tblExtraInfo.userObject := _object; // this is used to redraw this info
		_object.getExtraInfo(dataContainer);
		self.showExtraInformation(dataContainer, self.tblExtraInfo, true, false, 4, 1, 1, 1, 1);
			
		self.doResizeColumnWidths(self.tblExtraInfo, true);
	endif;

epilog
	if dataContainer &lt;&gt; null then
		delete dataContainer;
	endif;


end;</source>
        <Parameter name="_object" type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="showPropertyFrame" id="268dc635-7f83-4552-ad63-957b80f3513f">
        <updating/>
        <source>showPropertyFrame(_entTableView : String; _mode : Integer; _actualHeight : Integer) updating;
// ---------------------------------------------------------------------------
// Created:		March 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	theFolder : CMUI_Folder;
	theTable : CM_EntryTable;
	theFrame : Frame;
	theHeight : Integer;
begin
//	self.currentView := _entTableView;
	theFolder := self.fldProperties;
	theFrame := self.frmProperties;
	theTable := self.tblProperties;
	if _entTableView &lt;&gt; null then
		theTable.showHideRowsByViewName(_entTableView, CM_EntryTable.ShowHideRows, false); //ShowRowsOnly or ShowHideRows or HideRowsOnly
	endif;
	self.displayPropData();
	
	if _actualHeight &lt;&gt; null then
		theHeight := _actualHeight;
	else
		theHeight := theTable.getMaxHeight();//   (theTable.rows * 16);
	endif;

	theTable.height := theHeight;
	if theFolder.tabsHeight = 0 then
		theHeight:=theHeight + theFolder.getTextHeight(self.shtPropOne.caption);
	else
		theHeight:=theFolder.tabsHeight + theHeight;
	
	endif;
	theFolder.height:=theHeight + 10; //epr 4/7/06  folder wasn't resizing so part of table wasn't showing
	theFolder.top := self.frmPropToolbar.clientHeight;

	theTable.width := theFolder.clientWidth;
	theTable.left := 0;
	theTable.top := 0;
	
	theTable.accessColumn(1).width := 125;
	theTable.accessColumn(2).width := (theTable.width - 125).Integer;
	
	
	theFrame.height := self.frmPropToolbar.clientHeight + theFolder.clientHeight ;
	theFrame.zOrder(1);
	theFrame.centreWindow();
	theFrame.visible := true;
	self.tblProperties.setFocus();
	self.tblProperties.moveFirst();
end;</source>
        <Parameter name="_entTableView" type="String"/>
        <Parameter name="_mode" type="Integer"/>
        <Parameter name="_actualHeight" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="showSearchFrame" id="088b7900-3476-48c1-9f50-9730431a432f">
        <updating/>
        <source>showSearchFrame() updating;
// ---------------------------------------------------------------------------
// Created:		August 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

	theFrame : CMUI_MoveableFrame;
begin
	self.txtSearch.text := null;
	theFrame := self.frmSearch;
	theFrame.zOrder(1);
	theFrame.centreWindow();
	theFrame.visible := true;
	// 35872
	if self.cmbBank.visible then
		self.cmbBank.setFocus();
	else
		self.txtSearch.setFocus();
	endif;
	self.lstData.enabled := false;

end;</source>
    </JadeMethod>
