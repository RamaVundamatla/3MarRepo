    <JadeMethod name="setControlsForAddEdit" id="560c7378-821c-4f20-9a1f-11800de98662">
        <updating/>
        <source>setControlsForAddEdit() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 November 2023	navpw1	Initial creation TFS: 58761 (60739)

*/

vars
	theForm			: SOP_TableMaintForm;
	resourceTypes	: CM_ResourceTypeDict;
	iter			: Iterator;
	obj				: Object;
	
begin
	theForm := self.myForm;
	theForm.tblInput1.userInputEnabled := true;
	theForm.mulSelect1.userInputEnabled := true;
	
	if theForm.mode = theForm.Mode_Add then
		theForm.tblInput1.clearValues;
		theForm.tblInput1.enableRowByName(ETRow_Code);
		theForm.tblInput1.enableRowByName(ETRow_Description);
		theForm.tblInput1.enableRowByName(ETRow_IsNotAvailableForEntry);		
		theForm.tblInput1.setFocus;
		theForm.tblInput1.moveFirst();
		theForm.mulSelect1.setSelected(null);
		
	else
		// refresh the data from the newly created proxy
		self.showThumbnail(theForm.myProxyObject.CM_ResourceTypeGroup);
		
		theForm.tblInput1.enableRowByName(ETRow_Code);
		theForm.tblInput1.enableRowByName(ETRow_Description);
		theForm.tblInput1.enableRowByName(ETRow_IsNotAvailableForEntry);	
		
		create resourceTypes transient;
		iter := theForm.myProxyObject.CM_ResourceTypeGroup.allResourceTypes.createIterator;
		while iter.next (obj ) do
			if obj.isKindOf(CM_ResourceType) then
				resourceTypes.add( obj.CM_ResourceType );
			endif;
		endwhile;
		
		theForm.mulSelect1.setSelected(resourceTypes);
		
	endif; 
	
	self.enableMulSelect1Contents();
	
epilog
	delete iter;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="setCtrlsForView" id="d4219ef2-8d06-44e1-bf89-445756c2431f">
        <updating/>
        <source>setCtrlsForView() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
