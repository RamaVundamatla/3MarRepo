    <JadeMethod name="displayEntryBank" id="fe6b35d8-e891-4602-b2db-3f4c04c6860f">
        <source>displayEntryBank(_bank : CM_Bank) : String;
//--------------------------------------------------------------
//Created: June 2002 By: cnwgd1
//--------------------------------------------------------------
vars

	failedDAC  :CM_DataAccessController;

begin

	if _bank = null then
		return null;
	endif;

	if (not _bank.canUserAccessSelf(null, failedDAC, app.myPassport)) then
		return null;
	endif;
	
	if not _bank.isBusinessUnit then
		return null;
	endif;
	
	return _bank.code;
	
end;</source>
        <Parameter name="_bank" type="CM_Bank"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="displayEntryBatNumber" id="e0ae6f68-8833-4095-abc2-40e958a29a52">
        <source>displayEntryBatNumber(pBatNumber : CM_BatNumber; pAvailable : Boolean) : String;
// ---------------------------------------------------------------------------
// Created:     10 January 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if pBatNumber &lt;&gt; null then
		if (pAvailable and (not pBatNumber.testInUse(self.myTerminal))) or
		   (not pAvailable) then
			return pBatNumber.code;
		endif;
	endif;

	return null;
	
end;</source>
        <Parameter name="pBatNumber" type="CM_BatNumber"/>
        <Parameter name="pAvailable" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="displayEntryBulkRelease" id="8b9d95a2-f36e-4bdb-a795-318876a2d647">
        <source>displayEntryBulkRelease(pRelease : CM_BulkRelease) : String;
// ---------------------------------------------------------------------------
// Created:     10 January 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	tmpBR : CM_BulkRelease;
begin

	if pRelease &lt;&gt; null then
//			return pRelease.code;

		tmpBR := pRelease.myTerminal.getBulkReleaseFromCode(pRelease.code); // ### AKB2005MAY - cope with duplicate codes.
		if tmpBR = pRelease then
			return pRelease.code;
		else
			return pRelease.code &amp; Tab &amp; pRelease.dateRequested.date.String; // ### AKB2005MAY - cope with duplicate codes.
		endif;
	else
		return null;
	endif;
	
end;</source>
        <Parameter name="pRelease" type="CM_BulkRelease"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="displayEntryBulkTiAudit" id="7df680e7-4406-4d47-971d-97eccfa97e99">
