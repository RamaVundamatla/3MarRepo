    <JadeMethod name="getRadioTelemetryDisplay" id="0db6a040-ac56-4d95-9a4a-ef74c161b588">
        <source>getRadioTelemetryDisplay() : String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 Jul 2010	cnwrd1	Initial creation
06 Mar 2025 navma1  MTN-34179 MTN | Dead Lock (1081) on CM_WLEArray
*/

vars
	result   : String;
	request  : CM_Request;
	wle 	 : CM_WorkListEntry;
begin

	foreach request in self.allRequests discreteLock do					//06.03.2025 navma1 #MTN-34179
		foreach wle in request.allWorkListEntries discreteLock do		//06.03.2025 navma1 #MTN-34179
			result :=  wle.getDisplayStringForAttribute(ETRow_RadioTelemetry, true);
			if result &lt;&gt; null then
				break;
			endif;
		endforeach;
		
		if result &lt;&gt; null then
			break;
		endif;		
	endforeach;


	return result;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
