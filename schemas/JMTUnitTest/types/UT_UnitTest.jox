    <JadeMethod name="assertIncludesExceptions" id="538f14ed-3f9c-4dde-9dd4-1fa8a656019b">
        <source>assertIncludesExceptions() protected;
/*

Purpose:			

Parameters:			To cxheck that all of the expected errors are there, and don't care about any extras.

Return Value:		

Date				Who		Reason
23 June 2020		jlgndl1	Initial creation
19 November 2025	navpw1	 JIRA: MTN-36370 - Made method protected

*/

vars

	int : Integer;

begin

	if self.expectedTrxErrors.size &gt; 0 then
		foreach int in self.expectedTrxErrors do
			if not app.myPassport.allErrorWarnings.includesErrorCode(int) then
				self.assertTrueMsg(false, int.String &amp; " expected but not raised");
				return;
			endif;
		endforeach;
	else
		self.assertTrueMsg(false, "'expectedErrors' not set, nothing to check for!");
		return;
	endif;

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="assertIncludesWarnings" id="6fae6398-864f-4134-b722-887704d64ebb">
        <source>assertIncludesWarnings() protected;
/*

Purpose:			To check that all of the expected warnings are there, and don't care about any extras. (Assumption we kinda want to in some cases)

Parameters:			NONE

Return Value:		NONE

Date				Who		Reason
17 November 2025	navpw1	Initial creation JIRA: MTN-36370

*/

vars
	int : Integer;

begin

	if self.expectedTrxWarnings.size &gt; 0 then
		foreach int in self.expectedTrxWarnings do
			if not app.myPassport.allWarnings.includesErrorCode(int) then
				self.assertTrueMsg(false, int.String &amp; " expected but not raised");
				return;
			endif;
		endforeach;
	else
		self.assertTrueMsg(false, "'expectedWarnings' not set, nothing to check for!");
		return;
	endif;
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
