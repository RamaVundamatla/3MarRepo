<CollClass name="CM_TIByTimeStampDict" id="d8ba617d-8450-48dd-8019-d58114d954fa">
    <duplicatesAllowed/>
    <loadFactor>66</loadFactor>
    <memberType name="CM_TrackedItem"/>
    <superclass name="CM_ExtKeyDictionary"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="cmtrans"/>
    <ExternalKey name="timestamp">
        <type name="TimeStamp"/>
        <descending/>
    </ExternalKey>
    <JadeMethod name="add" id="40be7d0f-1b24-435e-9402-f7786347958d">
        <lockReceiver/>
        <updating/>
        <source>add(_ti: MemberType) updating, lockReceiver;
// ---------------------------------------------------------------------------
// Created:     29 August 2007 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpTS	: TimeStamp;
begin

	if _ti = null then
		app.raiseCMException2(MethodWithNullParam, method.name, '_ti', null, null);
		return;
	endif;
	
	tmpTS := _ti.receivedDT;
	if (not tmpTS.isValid) then
		if _ti.isOnShip and (not _ti.isInTransitOnShip) then
			tmpTS := _ti.myVoyage.arrivedDT;
		endif;
		if (not tmpTS.isValid) then
			tmpTS := _ti.createdTime;
		endif;
	endif;
	
	self.putAtKey(tmpTS, _ti);

end;</source>
        <Parameter name="_ti" type="MemberType"/>
    </JadeMethod>
</CollClass>
