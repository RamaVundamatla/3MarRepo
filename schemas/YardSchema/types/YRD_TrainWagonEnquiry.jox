    <JadeMethod name="doShowCargoReview" id="4e2b4849-eeb1-4729-a62e-c4221962d4f1">
        <source>doShowCargoReview();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27/09/2023	navkc1	CR 60428 Task 60702: UI - Cargo Review Option in Transport UI

*/

vars
	cgReviewForm			: CMUI_CargoReview;
	criteriaLine			: CM_SelectorCriteriaLine;
	qdef					: CM_QueryDefinition;
	wagon					: CM_Wagon;
	sa						: StringArray;
	criteriaLines			: CM_SelectorCriteriaLineArray;
begin
	
	if self.tblData.allSelectedObjects.isEmpty() then
		return;
	endif;
	
	cgReviewForm := app.loadForm(CMUI_CargoReview, CMUI_Assistant, true, true, false, self.getMyTerminal(), null).CMUI_CargoReview;
	
	if cgReviewForm = null then
		return;
	endif;
	
	qdef := app.myRoot.allQueryDefinitionObjects[CM_QueryDefinition.TrackedItem_Query_Type, CM_QueryDefinition.TrackedItem_Query_Mode];
	
	if qdef = null then
		return;
	endif;
	
	create criteriaLines transient;
	create sa transient;
	
	foreach wagon in self.tblData.allSelectedObjects as CM_Wagon do
		sa.add(wagon.id);
	endforeach;
	
	criteriaLine := qdef.createCriteriaLine(CM_TrackedItem::wagon.name, CM_QueryOperator.Operator_IsOneOf, sa);
	criteriaLines.add(criteriaLine);
	
	criteriaLine := qdef.createCriteriaLine(CM_TrackedItem::site.name, CM_QueryOperator.Operator_Equal, TI_SITE_ONSITE_str);
	criteriaLines.add(criteriaLine);
	
	cgReviewForm.createCriteriaLinesFromParent(criteriaLines);
	cgReviewForm.setParentForm(self);
	cgReviewForm.show();
	cgReviewForm.autoDoCustDocFromParent(); //23/02/2023	navkc1 CR 62580 Task 62581
epilog
	delete sa;
	delete criteriaLines;
end;</source>
    </JadeMethod>
