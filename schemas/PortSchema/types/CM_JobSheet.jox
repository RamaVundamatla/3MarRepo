    <JadeMethod name="setWorkStartedForOOW" id="a7b3b81e-1519-49e4-afc8-414da4da27d7">
        <updating/>
        <source>setWorkStartedForOOW(_workStartedDate : TimeStamp; _oldShipExchangeDate : TimeStamp) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 October 2013	cnwmc5	Initial creation PAR 32793

*/

vars

begin
	if _oldShipExchangeDate.isValid then 
		if _workStartedDate &gt;= _oldShipExchangeDate then
			if self.workStarted &lt; _workStartedDate then 
				self.workStarted := _workStartedDate;
			endif;
		elseif  self.workStarted = _oldShipExchangeDate then
				self.workStarted := _workStartedDate;
		endif;		
	elseif self.workStarted &lt;&gt; _workStartedDate then
		self.workStarted := _workStartedDate;
	endif;
epilog

end;</source>
        <Parameter name="_workStartedDate" type="TimeStamp"/>
        <Parameter name="_oldShipExchangeDate" type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="validateForDelete" id="6c98231b-085c-4b32-ae11-b156a4bde62b">
        <source>validateForDelete();
// ---------------------------------------------------------------------------
// Created:     06 June 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
19 May 2010	cnwkpd1	PAR #20728 - remove isValidObject calls for performance

*/

vars
	job 	: CM_Job;
	invalid 		: Boolean;
	
begin
	if app.isGarbageCollectionProcess then
		return;
	endif;
	
	on Exception do app.handleDeletedObject(exception, job, invalid);
	foreach job in self.allJobsByOrder do
//		if not global.isValidObject(job) then
//			continue;
//		endif;
  		job.validateForDelete();
 	endforeach;

end;</source>
    </JadeMethod>
</Class>
