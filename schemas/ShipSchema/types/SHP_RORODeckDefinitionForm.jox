    <JadeMethod name="doBaseFormSave" id="ed66cdf5-0bea-4251-962a-1e2adb3cc965">
        <updating/>
        <source>doBaseFormSave() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 March 2011	cnwer1	Initial creation

*/

vars
	realDeck 	: CM_Deck;
	result  	: Integer;
begin

	self.doSaveProxy();
	
	while true do
	
		self.doSaveTrx(realDeck);
		
		if app.myPassport.trxCompletedOK then
			
			if realDeck &lt;&gt; null then
				self.myCurrentDeck:=realDeck.CM_Deck;
			else
				self.myCurrentDeck:=self.myCurrentProxyDeck.pxyGetRealObject.CM_Deck;
			endif;
			
			self.startDeckItemNotes();
			self.startDeckNotes();
			break;
				
		else
			result := app.showErrorWarningDialog(app.getErrorString(Vessel_deck_definition), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		break;
	endwhile;
	
	
	if app.myPassport.trxCompletedOK then
		self.doChangeMode(self.Mode_View);
	endif;
epilog
	self.isSubDeck:=false;	
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doBtnDrawSaveClick" id="7e4f669e-cc89-47ce-bf03-6996430c5d66">
        <source>doBtnDrawSaveClick(_graphicSave : Boolean);
// ---------------------------------------------------------------------------
// Created:		May 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars
	theFrame : CMUI_PointDrawingFrame;
	pxyGraphic,theDrawingGraphic : CM_DeckItemLayout;
	scale, upScale : Real;
	newPoints : PointArray;
	aPoint : Point;
begin
	theFrame := self.frmScrollable.myDrawingFrame.CMUI_PointDrawingFrame;
	scale := self.scaleFactor;
	if scale = 0 then
		scale := 1;
	endif;
	upScale := (1/scale);
	
	// the combo box is populated from a proxy terminal and its proxy graphics
	pxyGraphic := self.myCurrentProxyItemLayout;
	
	if pxyGraphic = null then
		return;
	endif;
	// the top SDF only has one polygon at a time. It is the polygon that we are drawing/changing
	//that is a dummy graphic. All we are interested in is it's polygon
	if theFrame.allPointGraphics.isEmpty then
		return;
	endif;
	
	theDrawingGraphic := theFrame.allPointGraphics.first.CM_DeckItemLayout;
	if theDrawingGraphic &lt;&gt; null then
		if _graphicSave then
			// points should be stored at scale 1
			create newPoints transient;
			foreach aPoint in theDrawingGraphic.pointsPolygon do
				aPoint.setX((aPoint.x * upScale).Integer);
				aPoint.setY((aPoint.y * upScale).Integer);
				newPoints.add(aPoint);
			endforeach;
			pxyGraphic.setPointsPolygon(newPoints);
		endif;
		
//		self.doListGraphics(self.myCurrentLayer);
//		self.doDisplayGraphic();

	endif;
	theFrame.dataChanged := false;
	global.beep;
epilog

	delete newPoints;
end;</source>
        <Parameter name="_graphicSave" type="Boolean"/>
    </JadeMethod>
