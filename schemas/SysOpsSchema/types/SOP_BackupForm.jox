    <JadeMethod name="create" id="8912795e-20a2-4f90-9278-72eb68c416f1">
        <updating/>
        <executionLocation>client</executionLocation>
        <source>create() updating, clientExecution;
// ---------------------------------------------------------------------------
// Created:     Aug 2004 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	self.permissionView	:= PmAdmBackupView;
	self.permissionMaint := PmAdmBackupMaint;
	
	self.helpFileName := HelpFile_Admin;

	beginClassNotification(CM_Backup, false, Any_System_Event, Response_Continuous, 0);
	beginClassNotification(CM_BackupHistoryJournal, false, Any_System_Event, Response_Continuous, 0);
	beginClassNotification(CM_BackupHistoryDB, false, Any_System_Event, Response_Continuous, 0);

end;</source>
    </JadeMethod>
    <JadeMethod name="displayDBHistory" id="523c322d-e0d2-4e0e-a029-2be38bd630ea">
        <source>displayDBHistory(_backupHistory : CM_BackupHistory) protected;
// ---------------------------------------------------------------------------
// Created:     Aug 2004 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 21 Oct 2008	cnwkpd1		PAR #18315 - remove unnecessary table resort for performance
// ---------------------------------------------------------------------------
vars
	tmpSeverity, idx, colour: Integer;
	tmpStr,	terminalD: String;
	isSystem: Boolean;
begin
	idx := self.tblDBHistory.addItemObject(_backupHistory, _backupHistory.getAttributeStringForDefArray(self.tblDBHistory.allTblDataEntRows));

//	self.tblDBHistory.resort();		PAR #18315
end;</source>
        <access>protected</access>
        <Parameter name="_backupHistory" type="CM_BackupHistory"/>
    </JadeMethod>
