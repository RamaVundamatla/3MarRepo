    <JadeMethod name="auditIdDisplay" id="94400fc0-8e09-49d0-a060-a2a0e67080a7">
        <source>auditIdDisplay(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 May 2018	jlgmp6	Initial creation	TFS 37718

*/

vars
	auditIdStr : String;
begin
	
	auditIdStr := self.auditId();
	
	if auditIdStr &lt;&gt; null then
		return app.getErrorString(INV_Debtor) &amp; " - " &amp; auditIdStr;
	else
		return app.getErrorString(INV_Debtor);
	endif;


epilog

end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
