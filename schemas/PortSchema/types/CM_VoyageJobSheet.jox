begin
	foreach job in self.allJobsByOrder do
		job.getHatchLashStats(_aCandHRpt);
	endforeach;

end;</source>
        <Parameter name="_aCandHRpt" type="CMIF_CandHRpt" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getHoldOrdinalForOOW" id="2245d675-1146-48bf-a6b2-b19172bcb625">
        <source>getHoldOrdinalForOOW(_actualOrdinal : Integer) : Integer;
// ---------------------------------------------------------------------------
// Created:		January 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	aBay : CM_Bay;
	structure : CM_CellularVoyageStructure;
	minBay,maxBay : Integer;
	startHold : Integer;
	endHold : Integer;
	oowc : CM_OOWCreation;
begin
	if not self.oowReversed or self.allOOWCreations.isEmpty then
		return _actualOrdinal;
	endif;
	
	if self.myVoyage &lt;&gt; null then
		structure := self.myVoyage.myCellularVoyageStructure;
	endif;
	if structure = null then
		return _actualOrdinal;
	endif;
	
	// ### work out the min and max hold for this JOB SHEET
	minBay := 9999;
	foreach oowc in self.allOOWCreations discreteLock do
		aBay := oowc.myBay;
		if aBay &lt;&gt; null then
			minBay := minBay.min(aBay.ordinalBay);	
			maxBay := maxBay.max(aBay.ordinalBay);	
		endif;
	endforeach;
	
	aBay := structure.allBayVoyagesByOrdinal[minBay];
	startHold := aBay.myHold.ordinalHold;
	aBay := structure.allBayVoyagesByOrdinal[maxBay];
	endHold := aBay.myHold.ordinalHold;
	
	// return reversed hold ordinal
	return ((endHold - _actualOrdinal) + startHold);
end;</source>
        <Parameter name="_actualOrdinal" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getKPINetRate" id="db954f7b-5487-490f-87d1-b99f71fc7dab">
        <source>getKPINetRate(_jsStats : CMIF_JobSheetStats) : Decimal;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 September 2011	cnwer1	Initial creation CCMS MES 1239 par 27328

*/

vars

	kpiShift : CM_KPIVoyageJobSheetShift;
	kpi : CM_KPI;
	totalTIs,
	totatlNetHours : Real;
	
	iter : Iterator;
	opHr : CM_WorkPointOperatingHours;
	timeStampInt : TimeStampInterval;
	totTimeStampInt : TimeStampInterval;
	
	jc : Integer;
	jpc : Integer;
	ju : Integer;
	mi : Integer;
	lc : Integer;
	li : Integer;
	
	pl	: Integer;
	pd	: Integer;
	al 	: Integer;
	ad	: Integer;
	alt	: Integer;
	adt	: Integer;
begin

	foreach kpi in self.allVoyageKPICraneShifts discreteLock do
		kpiShift:= kpi.CM_KPIVoyageJobSheetShift;
		
		totalTIs:=totalTIs + kpiShift.movesTI;
		//totatlNetHours:=totatlNetHours + kpiShift.hoursNet;
		totatlNetHours:=totatlNetHours + kpiShift.getHoursNetLessDownTime;//04 Apr 2012	NDL	Par 29369
	endforeach;

	//02 Oct 2012	NDL	Par 30454 - If there are no kpis because the user is not licensed for KPIs, get the number
	//                              of moves by counting the completed jobs
//	if self.allVoyageKPICraneShifts.isEmpty and not app.myPassport.myUser.canDo(self.getMyTerminal, PmKPIModule) then
	if self.allVoyageKPICraneShifts.isEmpty and not app.myPassport.myUser.canDo(self.getMyTerminal, Mod_BaseSystem) then //07 Oct 2019	NDL	TFS 46169
		self.getWorkTotals(	jc,	//_jobCompleted,
							jpc,	//_jobPartCompleted,
							ju,	//_jobUnactioned,
							totalTIs,	//_moveCompleted,
							mi,	//_moveIncomplete,
							lc,	//_liftCompleted,
							li,	//_liftIncomplete
							pl, pd, al, ad, alt, adt, true);
	endif;
	
	//03 Apr 2012	NDL	Par 29369
	if self.includesWPOpHrs() then
		iter := self.myVoyage.allWorkPointOperatingHours.createIterator;
		while iter.next( opHr ) do
			if self.crane = opHr.craneWorkPointId then
				timeStampInt := opHr.getNetExchangeInterval();
				if timeStampInt &lt;&gt; null then
					totTimeStampInt := totTimeStampInt + timeStampInt;
				endif;
			endif;
		endwhile;
		totatlNetHours := totTimeStampInt.asHours().Decimal;
	endif;
	
//	if totatlNetHours = 0 then
	if totatlNetHours &lt;= 0 then	//07 Aug 2012	NDL	Par 30161 - just in case...
		return 0;
	endif;
	
	return (totalTIs/totatlNetHours).Decimal.roundedTo(2);
	
epilog

	delete iter;

end;</source>
        <Parameter name="_jsStats" type="CMIF_JobSheetStats"/>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="getKPIStringsForTableDetailNEW" id="81565abd-4386-4f62-a3d1-656bc6309d15">
        <source>getKPIStringsForTableDetailNEW(_table : Table input; _lineColour : Integer io);
// ---------------------------------------------------------------------------
// Created:     June 2010 ANDREW BISHOP
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
// 12 Sep 2011 		cnwer1			CCMS 1239 changes to how net rate is calculated
// ---------------------------------------------------------------------------

vars
	idx , totLIDS, totTIS, cnt : Integer;
	totTEUS : Real;
	colStr, craneStr, voyCode : String;
	kpiVoy : CM_KPIVoyageCraneShift;
	kpi : CM_KPI;
	totMinC, totMaxC,
	totGrossHours, totDelayHours, 
	totNetHours,
	totalNetRate,totalGrossRate : Real;
	totDownHours : Real;
begin
	if self.allVoyageKPICraneShifts.isEmpty then
		return ;
	endif;
	
	if self.isVoyageROROJobSheet then
		return;
	endif;
	
	totMinC := 9999999;
	voyCode := self.myVoyage.code;
	craneStr := self.crane;
	
	foreach kpi in self.allVoyageKPICraneShifts discreteLock do
		kpiVoy := kpi.CM_KPIVoyageCraneShift;
		colStr := 	voyCode &amp; Tab &amp; craneStr  &amp; Tab &amp; kpiVoy.getStringForTable();
		idx := _table.addItem(colStr);
		_table.accessRow(idx).itemObject := kpi;
		cnt := cnt +1; // PAR 16592
		totGrossHours := totGrossHours + kpiVoy.hoursGross;
		totDownHours := totDownHours + kpiVoy.hoursDown;	//04 Apr 2012	NDL	Par 29369
		totDelayHours := totDelayHours + kpiVoy.hoursDelay;
		//totNetHours := totNetHours + kpiVoy.hoursNet;
		totNetHours := totNetHours + kpiVoy.getHoursNetLessDownTime;	//04 Apr 2012	NDL	Par 29369
		totMinC := totMinC.min(kpiVoy.liftMinPerHour);
		totMaxC := totMaxC.max(kpiVoy.liftMaxPerHour);
		totTEUS := totTEUS + kpiVoy.movesTEU;
		totTIS := totTIS + kpiVoy.movesTI.Integer;
		totLIDS := totLIDS + kpiVoy.movesLid.Integer;
	
	endforeach;

	if totNetHours &lt;&gt; 0 then
		totalNetRate := totTIS/totNetHours; //epr CCMS 1239 par 27328
	endif;
	if totGrossHours &lt;&gt; 0 then
		totalGrossRate:=totTIS/totGrossHours; //epr CCMS 1239 par 27328
	endif;
	// PAR 22125 changed CM_Decimal1LeadingZero to CM_Decimal2LeadingZero
	colStr := self.myVoyage.code &amp; Tab &amp; craneStr &amp; " Total" &amp; Tab &amp; "" &amp; Tab &amp; "" &amp; Tab &amp; "" &amp; Tab &amp; 
				"" &amp; Tab &amp; // GAP 1
				totTIS.String &amp; Tab &amp; 
				totTEUS.asStringJMTWithPrecision(1,false) &amp; Tab &amp; 
				totLIDS.String &amp; Tab &amp; 
				"" &amp; Tab &amp; // GAP 2
				totGrossHours.asStringJMTWithPrecision($CM_Decimal2LeadingZero.decimalPlaces, true).String &amp; Tab &amp; 
				totDownHours.asStringJMTWithPrecision($CM_Decimal2LeadingZero.decimalPlaces, true).String &amp; Tab &amp;	//04 Apr 2012	NDL	Par 29369
				totDelayHours.asStringJMTWithPrecision($CM_Decimal2LeadingZero.decimalPlaces, true).String &amp; Tab &amp; 
				totNetHours.asStringJMTWithPrecision($CM_Decimal2LeadingZero.decimalPlaces, true).String &amp; Tab &amp; 
				"" &amp; Tab &amp; // GAP 3
				totalGrossRate.asStringJMTWithPrecision($CM_Decimal2LeadingZero.decimalPlaces, true).String &amp; Tab &amp; Tab &amp;
				totalNetRate.asStringJMTWithPrecision($CM_Decimal2LeadingZero.decimalPlaces, true).String &amp; Tab &amp; Tab &amp;
				"" &amp; Tab &amp; // GAP 4
				totMinC.asStringJMTWithPrecision($CM_Decimal2LeadingZero.decimalPlaces, true).String &amp; Tab &amp; Tab &amp;
				totMaxC.asStringJMTWithPrecision($CM_Decimal2LeadingZero.decimalPlaces, true).String;

	_table.addItem(colStr);
	_lineColour := _lineColour + 1;
end;</source>
        <Parameter name="_table" type="Table" usage="input"/>
        <Parameter name="_lineColour" type="Integer" usage="io"/>
    </JadeMethod>
