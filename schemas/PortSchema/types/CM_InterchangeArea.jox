    <JadeMethod name="pxyCreateUpdateProxy" id="e4b25787-1f1f-4405-bd25-9a09a371830a">
        <source>pxyCreateUpdateProxy(): SelfType;
// ---------------------------------------------------------------------------
// Created:     22 June 2009 by concms1:1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy
// ---------------------------------------------------------------------------
vars
	proxy		: SelfType;
	ta, taProxy	: CM_TerminalArea;
	completedOK		: Boolean;
	
begin
	proxy := inheritMethod();
	
	// do not set proxy.myInTransitFromLocation - it is never maintained
	
	proxy.myDefaultOutGate := self.myDefaultOutGate;
	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return proxy;
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete proxy;
	endif;

end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
