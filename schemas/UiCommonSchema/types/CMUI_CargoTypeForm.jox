    <JadeMethod name="setProxyCargoType" id="6dd38d18-6db6-498b-8d37-9bf13ae4fdbb">
        <source>setProxyCargoType(_cargoType : CM_CargoType input; _isCargoSubtypeRequired : Boolean);
// ---------------------------------------------------------------------------
// Created:     02 October 2002 by cnwth2
//
// Purpose:     This method populates the input string array with all the 'Viewable
//				product Attributes' row names that have been checked by the user.
//				Also sets default values on cargo type
//
//				R Barr 2/11/2006 Comalco	Rewrite to cater for truncated attribute list (iterate table rows rather than EntTableRows)
// ----------   ----------  --------------------------------------------------
vars
	table			: CM_DataTable;
	row,
	checkValue		: Integer;
	entDef			: EntTableDef;
	entRow			: EntTableRow;
	defaultValue	: Any;
	prodAttr		: CM_ProductAttr;

begin
	
	entDef := self.getAllAttributesDef;
	
	if _isCargoSubtypeRequired then 	// when cargo subtype required, then visible attributes to be included from tblDefault according to the flags values
	
		table := self.tblDefaultValues;
	
		foreach row in table.fixedRows + 1 to table.rows do
		
			entRow := table.accessRow(row).itemObject.EntTableRow;
			defaultValue := table.getCellText(row, table.getColumnByRowName(ETRow_DefaultProdValue));
			checkValue := table.getCellText(row, table.getColumnByRowName(ETRow_IsViewable)).Integer;
			_cargoType.setDefaultValue(entRow.name, defaultValue);
			// check whether is it viewable
			if checkValue = 1 then
				_cargoType.allAttributesOnProduct.add(entRow.name);
			endif;
		
		endforeach;
		
	else // when not cargo subtype required, then visible attributes to be included from pxySystemProductType according to the visibility of attributes. PAR 21339 Oct 2009
	
		if self.pxySystemProductType = null then	// for system cargo types and for trailers and vehicles, there are no prod attributes at all and there is no the system dummy product type, too.
			return;
		endif;
		
		foreach entRow in entDef.allEntTableRows do
			prodAttr := self.pxySystemProductType.getProdAttrFromName(entRow.name);
			//epr TFS 7756 16/2/18 don't set if not displayed in table
			if not tblAttributes.findObjectInRow(prodAttr,row) then
				prodAttr.setIsViewable(false);
			endif;
			if prodAttr.isViewable then
				_cargoType.allAttributesOnProduct.add(entRow.name);			
			endif;
		endforeach;
	
	endif;
	
end;</source>
        <Parameter name="_cargoType" type="CM_CargoType" usage="input"/>
        <Parameter name="_isCargoSubtypeRequired" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setProxyCargoTypeTEU" id="3b4f8d7e-dba6-4810-8fb2-a48d3aa4650f">
        <updating/>
        <source>setProxyCargoTypeTEU(_cargoType : CM_CargoType input) updating;
/*
Purpose:			
Date		Who		Reason
05 March 2015	cnwab1	Initial creation
*/
// 21 July 2022 navvt20 ChangeRequest 53917: MTN - Cargo Types TEUs for GC
vars
	conv : DecimalArray;

begin
	create conv transient;
	
	if _cargoType.id = TI_CargoType_Container then
		conv[TEUConversionIndex20] := self.tblEntDetail.getValueByName(ETRow_TeuConversion20).Decimal;
		conv[TEUConversionIndex30] := self.tblEntDetail.getValueByName(ETRow_TeuConversion30).Decimal;
		conv[TEUConversionIndex40] := self.tblEntDetail.getValueByName(ETRow_TeuConversion40).Decimal;
		conv[TEUConversionIndex45] := self.tblEntDetail.getValueByName(ETRow_TeuConversion45).Decimal;
		conv[TEUConversionIndex53] := self.tblEntDetail.getValueByName(ETRow_TeuConversion53).Decimal;
		
		// Start 14 July 2022 navvt20 53917
	//elseif self.cmbProductType.listIndex = 2 or self.cmbProductType.listIndex=3 then
	    //conv[TEUConversionIndexGCBreakBulk] := self.tblEntDetail.getValueByName(ETRow_TeuConversionGC13).Decimal;
		// End  14 July 2022 navvt20 53917
		
		// Start 21 July 2022 navvt20 53917
	elseif self.cmbProductType.listIndex = 2 then
	    conv[TEUConversionIndexGCBreakBulk] := self.tblEntDetail.getValueByName(ETRow_TeuConversionGCBreakBulk).Decimal;
	elseif self.cmbProductType.listIndex = 3 then
		conv[TEUConversionIndexGCBulk] := self.tblEntDetail.getValueByName(ETRow_TeuConversionGCBulk).Decimal;
		// End  21 July 2022 navvt20 53917
	else
		conv[TEUConversionIndexGC] := self.tblEntDetail.getValueByName(ETRow_TeuConversionGC).Decimal;
	endif;

	_cargoType.setForUpdateTEUSettings(self.cmbTEUMulti.listIndex,conv);
epilog
	delete conv;
end;</source>
        <Parameter name="_cargoType" type="CM_CargoType" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setProxySystemProduct" id="b01d83f6-1522-448a-8043-8ca5d73f1279">
        <updating/>
        <source>setProxySystemProduct(_pxyCargoType : CM_CargoType) updating, protected;
/* ---------------------------------------------------------------------------
Created:	25 May 2009	by cnwvu1

Purpose:	
   
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars
	pxyProduct		: CM_Product;
	
begin
	
	if self.pxySystemProductType = null then
		self.getSystemProduct(true);	// creating pxySystemProduct for user-defined cargo type that doesn't require sub-cargo types
	endif;
	
	pxyProduct := self.pxySystemProductType;
	
	pxyProduct.setProxyAsSystemDummyProduct(_pxyCargoType);
	
end;</source>
