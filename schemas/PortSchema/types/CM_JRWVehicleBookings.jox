    <JadeMethod name="getCarrierParamString" id="314d020e-edc3-4463-aff5-49e1bce61ed4">
        <source>getCarrierParamString():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 April 2013	cnwndl1	Initial creation	Par 31393

*/

vars

begin

	if self.myCarrier = null then
		return Any_String;
	else
		return self.myCarrier.description;
	endif;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDateFromLocalTZ" id="49bcf7f2-0d3b-486c-bcb8-08f645e3aad2">
        <source>getDateFromLocalTZ(): Date;
/*

Purpose:			Return the local timezone version of the receiver's dateTime (for JRW)

Parameters:			None

Return Value:		

Date		Who		Reason
03 Jun 2016	cnwmp6	TFS 488 - Multi Timezone Support

*/
vars
	ts: TimeStamp;
begin
	ts.setDate(self.dateFrom);
	ts.setTime(TimeStartOfDay);
	return self.systemToLocalTime(ts).Date;
epilog

end;</source>
        <ReturnType type="Date"/>
    </JadeMethod>
    <JadeMethod name="getDateToLocalTZ" id="ceb52549-69a3-46c5-a86e-e4653baa9e8f">
        <source>getDateToLocalTZ(): Date;
/*

Purpose:			Return the local timezone version of the receiver's dateTime (for JRW)

Parameters:			None

Return Value:		

Date		Who		Reason
03 Jun 2016	cnwmp6	TFS 488 - Multi Timezone Support
24 Nov 2022 navhl20 Bug 55445: MTN - Found date issue in CM_VehicleBookings Report screen

*/
vars
	ts: TimeStamp;
begin
	//ts.setDate(self.dateFrom);	//24.11.2022 navhl20 TFS 55445
	ts.setDate(self.dateTo);	//24.11.2022 navhl20 TFS 55445
	ts.setTime(TimeEndOfDay);
	return self.systemToLocalTime(ts).Date;
epilog

end;</source>
        <ReturnType type="Date"/>
    </JadeMethod>
    <JadeMethod name="getUnbookedParamString" id="9fa1dd73-e3ab-4ef9-b382-85eff0294c34">
        <source>getUnbookedParamString():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 April 2013	cnwndl1	Initial creation	Par 31393

*/

vars

begin

	if self.inclUnBooked then
		return "Include unbooked slots";
	else
	
		return "Exclude unbooked slots";
	endif;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="noOutputReturned" id="76c7f29c-a5be-4950-9fb1-edc2fa42d6a4">
        <source>noOutputReturned(): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 April 2013	cnwndl1	Initial creation	Par 31393

*/

vars

begin

	if self.allVehicleBookings.isEmpty then
		return true;
	endif;
	
	return false;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
