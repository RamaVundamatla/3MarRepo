    <JadeMethod name="getWeightLoaded" id="f14ac7f1-3456-4926-814b-bf688a6e06c3">
        <source>getWeightLoaded(): Decimal;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
06 March 2017	cnwndl1	Initial creation	TFS 3477
01 Mar 2018		NDL		TFS 37377 - Performance
14 Nov 2022		jlizm1	TFS 54118 Assigning Releases to Wagons
23/06/2023		navkc1	CR 58406 Task 58408: Jade - Release Request All Tracked Items
25 Mar 2024 	navma1	ChangeRequest 63141: MTN - Code Refactor to improve finding matching cargo items using reserve details
*/

vars

	ti 			 : CM_TrackedItem;
	lc 			 : CM_LocationsController;
	loadedWeight : Decimal[16,4];
	iter 		 : Iterator;
	allTis		 : CM_TISet; 
	bulkRelease	 : CM_BulkRelease;
begin
	create allTis transient; 									//23/06/2023	navkc1	CR 58406 Task 58408
	self.getAllTrackedItems(allTis, false); 					//23/06/2023	navkc1	CR 58406 Task 58408
	//if self.myReserveHeader &lt;&gt; null then
	//	iter := self.myReserveHeader.allTrackedItemsAssigned.createIterator;
		//iter := self.allTrackedItems.createIterator;			//01 Mar 2018	NDL	TFS 37377
		iter := allTis.createIterator(); 						//23/06/2023	navkc1	CR 58406 Task 58408
		
		bulkRelease := self.myReserveHeader; 					//25.03.2024 navma1 #63141
		while iter.next( ti ) do
			if not ti.isOnSite then
				continue;
			endif;
			if ti.isChild then
				continue;
			endif;
		//	if not self.allTrackedItems.includes( ti ) then
			if bulkRelease &lt;&gt; null and not bulkRelease.allTrackedItemsAssigned.includes( ti ) then	//01 Mar 2018	NDL	TFS 37377
				continue;
			endif;
			
			lc := ti.myPrimaryActualLocation;				    //25.03.2024 navma1 #63141
			if lc &lt;&gt; null then
				if lc.isVehicle or lc.isTILCController or lc.isWagon then
					loadedWeight := loadedWeight + ti.totalWeight;
				endif;
			endif;
		endwhile;
	//endif;
	
	return loadedWeight;

epilog
	
	delete iter;
	delete allTis; //23/06/2023	navkc1	CR 58406 Task 58408
end;</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="getWeightStaged" id="6ca3c353-54fb-4b00-b478-a097c2cade2a">
        <source>getWeightStaged():Decimal;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 December 2015	cnwndl1	Initial creation	Par 37288
01 Mar 2018	NDL		TFS 37377 - Performance
23/06/2023	navkc1	CR 58406 Task 58408: Jade - Release Request All Tracked Items
*/

vars

	ti : CM_TrackedItem;
	ta : CM_TerminalArea;
	stagedWeight : Decimal[16,4];
	iter : Iterator;
	reason : String;
	allTis	: CM_TISet; 
begin
	create allTis transient;//23/06/2023	navkc1	CR 58406 Task 58408
	self.getAllTrackedItems(allTis, false); //23/06/2023	navkc1	CR 58406 Task 58408
	//if self.myReserveHeader &lt;&gt; null then
	//	iter := self.myReserveHeader.allTrackedItemsAssigned.createIterator;
		//iter := self.allTrackedItems.createIterator;	//01 Mar 2018	NDL	TFS 37377
		iter := allTis.createIterator(); //23/06/2023	navkc1	CR 58406 Task 58408
		while iter.next( ti ) do
			if not ti.isOnSite then
				continue;
			endif;
			if ti.isChild then
				continue;
			endif;
		//	if not self.allTrackedItems.includes( ti ) then
			if self.myReserveHeader &lt;&gt; null and not self.myReserveHeader.allTrackedItemsAssigned.includes( ti ) then	//01 Mar 2018	NDL	TFS 37377
				continue;
			endif;
			if ti.myPrimaryActualLocation &lt;&gt; null then
				ta := ti.myPrimaryActualLocation.myTerminalArea;
				if ta &lt;&gt; null then
					if ta.type = TA_TYPE_YARD_INTERCHANGE then
						// Its actually already staged
						stagedWeight := stagedWeight + ti.totalWeight;
						continue;
					endif;
				endif;
			endif;
		endwhile;
	//endif;
	
	return stagedWeight;

epilog
	
	delete iter;
	delete allTis; //23/06/2023	navkc1	CR 58406 Task 58408
end;</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="getWidth" id="4d227da2-2eac-4780-8a2b-16975d4bf4ab">
        <source>getWidth(): Decimal;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 Sep 2024	navnk30	Bug 66204: EUP | 53308 - 1011 error when using and dimensions field in the Grouping criteria URGENT

*/

vars
	relCriteria			: CM_ReleaseByTypeCriteria;
	widthCriteria	: CM_YACriteria;
begin
	relCriteria := self.myReleaseCriteria;
	if relCriteria = null then
		return self.widthSelection;
	endif;
	widthCriteria := relCriteria.getCriteriaFor(YACriteriaType_CargoWidth);
	if widthCriteria = null then
		return self.widthSelection;
	endif;
	return widthCriteria.myYAData.CM_YADataString.value.Decimal;
epilog

end;</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
