    <JadeMethod name="getIdxfromYPos" id="f1295e55-3140-45f4-94f7-f9707261daf7">
        <source>getIdxfromYPos(_y2 : Real) : Integer;
// ---------------------------------------------------------------------------
// Created:		March  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	idx, lCellPos : Integer;
begin
	lCellPos := (_y2 - self.y1).Integer;
	
	idx := lCellPos div self.cellHeight;
//	if self.myLocationsController.myTerminalArea.id = "W" then
//		write "ID: W " &amp; self.myLocationsController.CM_StackController.getID &amp; " CH: " &amp; self.cellHeight.String &amp; " y1: " &amp; y1.String &amp; " y2: " &amp; y2.String
//			&amp; " _y2: " &amp; _y2.String &amp; " idx: " &amp; idx.String;
//	endif;
	return idx;

end;</source>
