    <JadeMethod name="getCurrentQtyAccum" id="efe7bf11-0828-436c-a17a-eae24b118133">
        <source>getCurrentQtyAccum() : Integer;
/*

Purpose:			This method go through all COO details and accumulate the current quantity

Parameters:			

Return Value:		

Date		Who		Reason
23/10/2024	navkc1 JIRA Task MTN-19369: EUP | Ownership Change Enquiry missing fields - All Quantity, Weight, Volume fields

*/

vars
	currentQty 		: Integer;
	subTi,
	ti					: CM_TrackedItem;
	
	subCooDetails,
	cooDetails			: CM_OwnershipChangeDetail;
begin
	
	foreach cooDetails in self.allDetails discreteLock where cooDetails.isIncluded() do
		
		ti := cooDetails.myTrackedItem;
		
		if ti = null then
			continue;
		endif;
		
		if ti.isCargoGroupItem() then
			foreach subCooDetails in cooDetails.allSubDetails discreteLock where subCooDetails.isIncluded() do
				subTi := subCooDetails.myTrackedItem;
				
				if subTi = null then
					continue;
				endif;
				
				currentQty += subTi.totalQuantity;
			endforeach;
		else
			currentQty += ti.totalQuantity;
		endif;
	endforeach;
	
	return currentQty;
	
epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
