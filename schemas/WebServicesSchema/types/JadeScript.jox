    <JadeMethod name="eprTestEDIPrenoteLoad" id="9829e228-6fac-4297-a380-fe9081ba3a63">
        <source>eprTestEDIPrenoteLoad();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 May 2018	jlger1	Initial creation
03 Sep 2019 jlgka1 	TFS 45332 	STWR - Better Forms and Interfaces for EDI Module
*/

vars
	file : File;
	documentBytes : Byte;
	message : Binary;
	voyage : CM_Voyage;
	ediFormat : String;
	ediConfig			: CM_EDIConfig;
	ediFileType : CM_EDIFileType;
	realEdiFile 	: CM_EDIFile;
	realEdiData : CM_EDIData;
	fileData : String;
	ediControllerAgent	: CM_EDIControllerAgent;
	ediTI : CM_EDITrackedItem;
	ediTIsByBooking : DynaDictionary;
	iter : Iterator;
	pxyBookingRef,
	bookingRef : CM_BookingRef;
	pxyBookingRefItem : CM_BookingRefItem;
	allProxyBookings :CM_BookingRefSet;
	operator 	: CM_Operator;
newBulkRelease : CM_BulkRelease;
	bookingRefQuantity : Integer;
begin
	app.initialize;
	app.myPassport.setMyUserFromCode("CNWER1");
	app.myPassport.setMyTerminal(app.myRoot.allTerminals["JBL"]);
	message:="MRTU2163985,BB01239,22G1,MTY,MRT,IDJKT,IDJKT,MT,20,,,,,,6565
MRTU2125120,BB01239,22G1,MTY,MSL,NZLYT,NZLYT,MT,20,,,,,,6565
MRTU2044712,BB01239,22G1,MTY,MSL,NZLYT,NZLYT,MT,20,,,,,,6565
MRTU2138093,BB01239,22G1,MTY,MSL,NZLYT,NZLYT,MT,20,,,,,,6565
MRTU2109222,BB01239,22G1,MTY,MSL,NZLYT,NZLYT,MT,20,,,,,,6565
MRLU2376997,BB01239,22G1,MTY,MSL,NZLYT,NZLYT,MT,20,,,,,,6565
CRXU3389255,BB01239,22G1,MTY,MSL,NZLYT,NZLYT,MT,20,,,,,,6565
CRSU1140678,BB01239,22G1,MTY,MSL,NZLYT,NZLYT,MT,20,,,,,,6565
TEMU2468629,BB01239,22G1,MTY,MSL,NZLYT,NZLYT,MT,20,,,,,,6565
DFSU2204500,BB01239,2200,MTY,MSL,NZLYT,NZLYT,MT,20,,,,,,6565
CRSU1083942,BB01239,2200,MTY,MSL,NZLYT,NZLYT,MT,20,,,,,,6565
CRXU3404920,BB01239,2200,MTY,MSL,NZLYT,NZLYT,MT,20,,,,,,6565
MRLU2389340,BB01239,2200,MTY,MSL,NZLYT,NZLYT,MT,20,,,,,,6565
MRLU2340799,BB01239,2200,MTY,MSL,NZLYT,NZLYT,MT,20,,,,,,6565
MRLU2354473,BB01239,22G1,MTY,MSL,NZLYT,NZLYT,MT,20,,,,,,6565
MRLU2385073,BB01239,22G1,MTY,MSL,NZLYT,NZLYT,MT,20,,,,,,6565".Binary;

	voyage:= app.myPassport.myTerminal.allVoyagesByExternalCode["BRSM"];
	
	ediFormat:=voyage.myVoyageProcess.ediPrenoteFormat;
		app.myPassport.setWarningsIgnored(true); 
	app.myPassport.warningsAcknowledged := true;
	create ediControllerAgent transient;
	ediControllerAgent.setTerminal( app.myPassport.myTerminal );
	//fileData :=  message.String; //.compressToBinary(Binary.Compression_ZLib);
	ediControllerAgent.getDataTypeCreateEDIObjects(message.Binary, ediControllerAgent.ediClientRef,null,app.actualTimeServer,true,ediFormat,ediFileType,realEdiFile,realEdiData, false, null); // jlgka1 	TFS 45332
	
	if app.myPassport.hasErrors or realEdiFile = null then
		//completedOK := true;
		return ;
	endif;
	//have to process file first because this will translate operator 
	ediControllerAgent.processFileData(realEdiFile,app.myPassport);

	if realEdiFile &lt;&gt; null and realEdiFile.ediData &lt;&gt; null then
		app.myTrxUA.trxUpdateEDIPrenoteWithVoyage(voyage,realEdiFile.ediData,app.myPassport);
	endif;
	
	app.myPassport.dumpErrorWarnings;
		
	ediControllerAgent.processVerifyDbLoad(realEdiFile, app.myPassport.myTerminal,true,true);
			

epilog
	delete ediControllerAgent;
	

end;</source>
    </JadeMethod>
    <JadeMethod name="eprTestEntryRKBM" id="1f4cf93c-5af2-4368-989f-4cb1848bbd7e">
        <source>eprTestEntryRKBM();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 July 2018	jlger1	Initial creation

*/

vars
	soap : String;
	parseError		: Boolean;
	documentChanged	: Boolean;
	xmlHelper 		: CM_XmlHelperAgent;
	xml 			: JadeXMLDocument;
begin
soap :='&lt;soapenv:Envelope xmlns:soapenv="http://schemas.xmlsoap.org/soap/envelope/" xmlns:jmt="urn:JadeWebServices/JMTExternalInterfaceService/"&gt;
   &lt;soapenv:Header/&gt;
   &lt;soapenv:Body&gt;
      &lt;jmt:entryRKBM&gt;
         &lt;jmt:RequestEntryRKBM&gt;
            &lt;!--Optional:--&gt;
            &lt;jmt:password&gt;1&lt;/jmt:password&gt;
            &lt;!--Optional:--&gt;
            &lt;jmt:user&gt;jlger1&lt;/jmt:user&gt;
            &lt;!--Optional:--&gt;
            &lt;jmt:portCode&gt;NZPOE&lt;/jmt:portCode&gt;
          
               &lt;!--Zero or more repetitions:--&gt;
               &lt;jmt:DetailRKBM&gt;
                  &lt;!--Optional:--&gt;
                  &lt;jmt:bahaya&gt;?&lt;/jmt:bahaya&gt;
                  &lt;!--Optional:--&gt;
                  &lt;jmt:blNo&gt;BOL2343&lt;/jmt:blNo&gt;
                  &lt;!--Optional:--&gt;
                  &lt;jmt:consignee&gt;00826&lt;/jmt:consignee&gt;
                  &lt;!--Optional:--&gt;
                  &lt;jmt:gang&gt;?&lt;/jmt:gang&gt;
                  &lt;!--Optional:--&gt;
                  &lt;jmt:ganggu&gt;?&lt;/jmt:ganggu&gt;
                  &lt;!--Optional:--&gt;
                  &lt;jmt:kade&gt;WP1&lt;/jmt:kade&gt;
                  &lt;!--Optional:--&gt;
                  &lt;jmt:kegiatan&gt;MUAT&lt;/jmt:kegiatan&gt;
                  &lt;!--Optional:--&gt;
                  &lt;jmt:m3&gt;&lt;/jmt:m3&gt;
                  &lt;!--Optional:--&gt;
                  &lt;jmt:namaBarang&gt;WIDGETS&lt;/jmt:namaBarang&gt;
                  &lt;!--Optional:--&gt;
                  &lt;jmt:noRkbmBongkar&gt;?&lt;/jmt:noRkbmBongkar&gt;
                  &lt;!--Optional:--&gt;
                  &lt;jmt:noRkbmMuat&gt;?&lt;/jmt:noRkbmMuat&gt;
                  &lt;!--Optional:--&gt;
                  &lt;jmt:npwpPbm&gt;?&lt;/jmt:npwpPbm&gt;
                  &lt;!--Optional:--&gt;
                  &lt;jmt:npwpShipper&gt;SIND&lt;/jmt:npwpShipper&gt;
                  &lt;!--Optional:--&gt;
                  &lt;jmt:palka&gt;?&lt;/jmt:palka&gt;
                  &lt;!--Optional:--&gt;
                  &lt;jmt:pbm&gt;?&lt;/jmt:pbm&gt;
                  &lt;!--Optional:--&gt;
                  &lt;jmt:penyaluran&gt;?&lt;/jmt:penyaluran&gt;
                  &lt;!--Optional:--&gt;
                  &lt;jmt:rencanaBongkar&gt;?&lt;/jmt:rencanaBongkar&gt;
                  &lt;!--Optional:--&gt;
                  &lt;jmt:rencanaMuat&gt;?&lt;/jmt:rencanaMuat&gt;
                  &lt;!--Optional:--&gt;
                  &lt;jmt:shipper&gt;?&lt;/jmt:shipper&gt;
                  &lt;!--Optional:--&gt;
                  &lt;jmt:ton&gt;1&lt;/jmt:ton&gt;
                  &lt;!--Optional:--&gt;
                  &lt;jmt:unit&gt;10&lt;/jmt:unit&gt;
               &lt;/jmt:DetailRKBM&gt;
           
            &lt;!--Optional:--&gt;
            &lt;jmt:nomorPKK&gt;?&lt;/jmt:nomorPKK&gt;
         &lt;/jmt:RequestEntryRKBM&gt;
      &lt;/jmt:entryRKBM&gt;
   &lt;/soapenv:Body&gt;
&lt;/soapenv:Envelope&gt;';

	create xml transient;
	xml.parseString(soap);

	
	
	create xmlHelper transient;
	
	// Firstly convert INAPORTNET names to JMT names
	xmlHelper.translateElementNames(xml, "urn:JadeWebServices/JMTExternalInterfaceService/","RequestEntryRKBM", "requestEntryRKBM", documentChanged);
	xmlHelper.translateElementNames(xml,"urn:JadeWebServices/JMTExternalInterfaceService/", "DetailRKBM", WS_DetailRKBM.name, documentChanged);
	
	// Ensure any WS_DetailRKBM are correctly parented
	xmlHelper.reparentElements(xml, WS_DetailRKBM.name, WS_EntryRKBMRequest::allDetailRKBM.name, documentChanged);
	
	write xml.writeToString;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="eprTestFindUnpackCargo" id="4862d62c-7923-4f28-985c-c44c0be6ea53">
