    <JadeMethod name="jssFindObjectRowNo" id="dcc6a94a-090f-491e-8902-f0533301bf48">
        <updating/>
        <source>jssFindObjectRowNo(pTheObject:Object):Integer updating;
// --------------------------------------------------------------------------------
// Created:		16 April 2001 by cnwdad1
//
// Purpose:		Searches the itemObject property values for each JadeTableRow in
//				the table for the specified pTheObject parameter.  If the specified
//				object is found, then it's row number is returned.
//
// Parameters:	pTheObject (Object) - The object to find.
//
// Returns:		The row number where the object was found, or zero it it's not found.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
//
// ****************************************************************************
// * NOTE THAT THIS METHOD ONLY USES THE "itemObject" PROPERTY OF THE TABLE's *
// * "JadeTableRow".  IT DOES NOT CHECK THE "itemObject" PROPERTY OF ANY      *
// * INDIVIDUAL TABLE CELLS.                                                  *
// ****************************************************************************
//
vars
	rowPointer	: Integer;
	tableRowObj	: JadeTableRow;
	startRow	: Integer;
	rowCount	: Integer;
	
begin
	rowCount	:=	self.rows;
	startRow	:=	self.fixedRows + 1;
	
	foreach rowPointer in startRow to rowCount do
		tableRowObj	:=	self.accessRow(rowPointer);
		
		if tableRowObj.itemObject = pTheObject then
			return rowPointer;
		endif;
	endforeach;
	
	return 0;
end;</source>
        <text>___________________________________________________________________________

              P R O P R I E T A R Y   N O T I C E

This software, in whole and in every part, is proprietary to Jade Software
Corporation Limited at Christchurch, New Zealand and is not to be
reproduced, used or disclosed except upon prior written permission of Jade
Software Corporation Limited.

  COPYRIGHT © JADE SOFTWARE CORPORATION LIMITED 2002 - ALL RIGHTS RESERVED
____________________________________________________________________________</text>
        <Parameter name="pTheObject" type="Object"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="jssFindStringCell" id="e03a608b-69c8-4a92-b902-b60eb79e0d3e">
        <updating/>
        <source>jssFindStringCell(pValue:String):JadeTableCell updating;
// --------------------------------------------------------------------------------
// Created:		04 August 2001 by cnwdad1
//
// Purpose:		This method scans the receiver's cells and returns the first
//				JadeTableCell who's text matches the pValue parameter.
//
// Parameters:	pValue - The string to search for.
//
// Returns:		The JadeTableCell for the (first) cell with text matching pValue,
//				or null if the string isn't found.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	rowIndex		: Integer;
	columnIndex		: Integer;
	startRow		: Integer;
	startColumn		: Integer;
	rowCount		: Integer;
	columnCount		: Integer;
	tableCellObj	: JadeTableCell;
	
begin
	startRow	:=	self.fixedRows + 1;
	startColumn	:=	self.fixedColumns + 1;
	rowCount	:=	self.rows;
	columnCount	:=	self.columns;
	
	foreach rowIndex in startRow to rowCount do
		foreach columnIndex in startColumn to columnCount do
			tableCellObj	:=	self.accessCell(rowIndex, columnIndex);
			
			if tableCellObj.text = pValue then
				return tableCellObj;
			endif;
		endforeach;
	endforeach;
end;</source>
        <text>___________________________________________________________________________

              P R O P R I E T A R Y   N O T I C E

