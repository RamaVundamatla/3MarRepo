// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	self.clearSelf();

end;</source>
    </JadeMethod>
    <JadeMethod name="getArrayIndexForMoveType" id="edf8392b-3c20-4554-bdc4-3ca387d4d874">
        <source>getArrayIndexForMoveType(_moveType : Integer; _idx : Integer output);
// ---------------------------------------------------------------------------
// Created:     22 August 2002 by cnwth2
//
// Purpose:     
//
// ----------   ----------  --------------------------------------------------
vars

begin
	
	if _moveType = StkMove_MoveIn or
	   _moveType = StkMove_MoveOut or
	   _moveType = StkMove_LogNoNumberOffLoad then
	   	_idx := Index_RecRel;

	elseif _moveType = StkMove_Reject then
		_idx := Index_Reject;

	elseif _moveType = StkMove_OperatorChangeIn or
	   _moveType = StkMove_OperatorChangeOut then
	   	_idx := Index_OperatorChange;
	   	
	elseif _moveType = StkMove_ProdChangeIn or
	   _moveType = StkMove_ProdChangeOut then
	   	_idx := Index_ProductChange;

	elseif _moveType = StkMove_Reassembly then
		_idx := Index_Reassembly;
	
	elseif _moveType = StkMove_ValueUpdateIn or
	   _moveType = StkMove_ValueUpdateOut then
	   	_idx := Index_ValueChange;

	elseif _moveType = StkMove_Fixup then
	   	_idx := Index_Fixup;
	
	else
		app.raiseUnexpectedProgramError(class.name, method.name, 'Unhandled move type ' &amp; _moveType.String);
	endif;
	
	
end;</source>
        <Parameter name="_moveType" type="Integer"/>
        <Parameter name="_idx" type="Integer" usage="output"/>
    </JadeMethod>
    <JadeMethod name="totalQuantities" id="7ee8a06d-ab3f-40cd-bd95-40c186618395">
        <source>totalQuantities(_bucket	: CM_StockMoveBucket);
// ---------------------------------------------------------------------------
// Created:     22 August 2002 by cnwth2
//
// Purpose:     
//
// ----------   ----------  --------------------------------------------------
vars
	stockMovement	: CM_StockMovement;
	idx				: Integer;
	stkMoveDtl		: CMIF_StockMoveDtl;

begin

	foreach stockMovement in _bucket.allStockMovements do
		self.getArrayIndexForMoveType(stockMovement.type, idx);
		stkMoveDtl := self.allStockMoveDtls[idx];
		stkMoveDtl.addStockMovement(stockMovement);
	endforeach;

end;</source>
        <Parameter name="_bucket" type="CM_StockMoveBucket"/>
    </JadeMethod>
</Class>
