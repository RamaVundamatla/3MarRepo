    <JadeMethod name="translateForm" id="758bd4cf-4832-4d13-a930-d8443be55783">
        <updating/>
        <source>translateForm(locale : CM_Locale) updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	
begin
	// Determine the locale for translations.
	inheritMethod(locale);
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0018471, locale);
end;</source>
        <Parameter name="locale" type="CM_Locale"/>
    </JadeMethod>
    <JadeMethod name="validatePackItem" id="621e3fc4-9544-448a-92e4-c80f09907b18">
        <updating/>
        <source>validatePackItem(_isForRepack : Boolean; _ti : CM_TrackedItem) : Boolean protected, updating;
// ---------------------------------------------------------------------------
// Created:     20 February 2003		cnwth2	
//
// Purpose:     
//			 
// adm 270509 Par 19483 myTerminal
vars
 	idx				: Integer;
	isEmpty			: Boolean;
	cargoType		: CM_CargoType;
	ti				: CM_TrackedItem;
	maxWeight 		: Integer;
	isoTypeString	: String;
	packingRequest  : CM_BulkRelease;
	tiBookingRef	: CM_BookingRef;
	reserve			: CM_ReserveDetail;
	hasRequest		: Boolean;
	
begin
	if _ti = null then
		return false;
	endif;

	if _ti = self.myCargoTI then
		app.msgBox(app.getErrorString(Pack_in_self), 
				null, MsgBox_OK_Only);
		return false;	
	endif;
	
	cargoType := app.myRoot.allCargoTypesById[_ti.cargoType];

	if cargoType = null or not cargoType.allowDuplicates then
		//if self.myCargoTI.allChildren.includes(_ti) then//PAR 22954
		if self.myCargoTI.hasChild(_ti) then
			app.msgBox(app.getErrorString(Item) &amp; _ti.id &amp; app.getErrorString(Alread_packed) &amp; self.myCargoTI.id, null, MsgBox_OK_Only);
			return false;
		endif;
	endif;	
	// validate against isoType weight.
	if self.myCargoTI.isKindOf(CM_Container) then
		isoTypeString   := self.myCargoTI.CM_Container.isoType;
		maxWeight := app.myRoot.allISOTypes[isoTypeString].maxTotalWeight;
		if maxWeight &lt;&gt; 0 and (self.myCargoTI.totalWeight + _ti.totalWeight) &gt; maxWeight then
			app.msgBox("Adding this cargo exceeds the weight limit ("&amp; maxWeight.String &amp;") for container ISO Type.", 
				null, MsgBox_OK_Only);
			return false;
		endif;
	endif;
	
	// validate against packing request
	packingRequest := self.allBulkReleases.first();
	// PAR 19705 Ony allow packing of items that are assigned to the release
	if (not _ti.allBulkReleasesAssigned.includes(packingRequest)) then
		if _ti.allBulkReleasesAssigned.size() &lt;&gt; 0 then
			app.msgBox(	"The cargo " &amp; _ti.id &amp; " is assigned to a different packing release request - "&amp;  _ti.allBulkReleasesAssigned.first().code, null, MsgBox_OK_Only);
		elseif self.myTerminal().getConfig(OnlyPackAssignedItems).Boolean then // adm 220509 Par 19741
			app.msgBox(	"The cargo " &amp; _ti.id &amp; " is not assigned to the current packing release request - "&amp;  packingRequest.code, null, MsgBox_OK_Only);
		endif;
		return false;
	endif;
	// 08/04/2009 cnwar2 #19428 - should be checking reserve details collection also
	if _ti.allReserveDetails.size() &lt;&gt; 0 then
		foreach reserve in _ti.allReserveDetails do
			if reserve.myReserveHeader = packingRequest then
				hasRequest := true;
			endif;
		endforeach;
		if not hasRequest then
			app.msgBox(	"The cargo " &amp; _ti.id &amp; " is attached to a different packing release request - "&amp;  _ti.allReserveDetails.first().myReserveHeader.code, null, MsgBox_OK_Only);
			return false;
		endif;
	endif;
	
	if self.myCargoTI &lt;&gt; null   // dh 10/7/2008 par 16976
	and self.myCargoTI.isTransient()
	and _ti.myOperator &lt;&gt; packingRequest.myOperator
	then
		app.msgBox("This cargo has a different operator from that on the packing request.", null, MsgBox_OK_Only);
		return false;	
	endif;
	
	return true;
end;</source>
        <access>protected</access>
        <Parameter name="_isForRepack" type="Boolean"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</GUIClass>
