    <JadeMethod name="doTblAllQueryRowColChange" id="4563db3c-4288-4a89-997a-e9a96b02bd2e">
        <updating/>
        <source>doTblAllQueryRowColChange(_table: CM_DataTable): Boolean updating, protected;
// ---------------------------------------------------------------------------
// Created:     09 November 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	result 			: Integer;
begin
	if (not self.tblItem.hasChanged) then
		return true;
	endif;
	
	result := app.msgBox('You have not updated the changes for this item. Do wish to save first?', 'Save changes?', MsgBox_Yes_No_Cancel + MsgBox_Exclamation_Mark_Icon);

	if result = MsgBox_Return_Yes then
		return self.updateItem();
	elseif result = MsgBox_Return_No then
		return true;
	elseif result = MsgBox_Return_Cancel then
		return false;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_table" type="CM_DataTable"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doTblItemCellInputReady" id="390b45fb-b40a-428b-9345-cc231f62681f">
        <updating/>
        <source>doTblItemCellInputReady(table: CM_BaseTable input; inputControl: Control input; cleft: Real io; ctop: Real io; cwidth: Real io; cheight: Real io) updating, protected;
/*
----------   ----------  --------------------------------------------------
Created:	07 June 2006 By cnwth2

Purpose:	

Changed On  Changed By  Reason
----------  ----------  --------------------------------------------------
10/05/2013	cnwdap1		PAR #31155 CCMS SFW 1321 Imperial Measurements
13/08/2013	cnwdap1		AR #32123 Added Colour Picker
*/
vars

begin
	if inputControl = self.lstHazardList then
		self.myAssistant.listTableCellInputReady(table, cheight, saveRowHeight);
	endif;
	
	// PAR #31155 measurement tables
	if CMUI_MeasurementTable.hasInstance(inputControl) and not inputControl = self.tblMeasurement then	// PAR #31155
		app.doMeasureTableCellInputReady(table, inputControl);											// PAR #31155
	endif;																								// PAR #31155
	
	if inputControl = self.lstColour then																// PAR #32123
		self.myAssistant.listTableCellInputReady(table, cheight, saveRowHeight);						// PAR #32123
	endif;																								// PAR #32123
end;</source>
        <access>protected</access>
        <Parameter name="table" type="CM_BaseTable" usage="input"/>
        <Parameter name="inputControl" type="Control" usage="input"/>
        <Parameter name="cleft" type="Real" usage="io"/>
        <Parameter name="ctop" type="Real" usage="io"/>
        <Parameter name="cwidth" type="Real" usage="io"/>
        <Parameter name="cheight" type="Real" usage="io"/>
    </JadeMethod>
    <JadeMethod name="doTblItemQueryRowColChange" id="411256a0-411f-48fd-82a7-819d71398590">
        <source>doTblItemQueryRowColChange() : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 May 2022	jlier1	Initial creation 53515

*/

vars
	table : CM_EntryTable;
begin
	table := self.tblItem;
	if table.row = table.getRowByName(ETRow_CargoGroupId) then
		self.doCargoGroupRowChange(table);
	endif;

	return true;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doTblItemRowColChange" id="26a14b1a-c97a-42a0-ba04-505e418d3393">
        <source>doTblItemRowColChange();
// ---------------------------------------------------------------------------
// Created:     23 October 2002		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	prodAttr		: CM_ProductAttr;
	pro				: CM_Product;
	jCell			: JadeTableCell;
	table			: CM_EntryTable;
begin
	pro := self.cmbProduct.listObject.CM_Product;
	if pro = null then
		return;
	endif;
	
	table := self.tblItem;
	
	jCell := table.accessCell(table.row, 1);
	prodAttr := pro.getProdAttrFromName(jCell.text);
	if prodAttr = null or prodAttr.validationType &lt;&gt; CM_ProductAttr.ValidationType_Codes then
		return;
	endif;
	
	if prodAttr.name = ETRow_MyWidthString then
		table.accessCell(table.row, table.ColumnValue).cellControl := self.cmbWidthCodes;
	elseif prodAttr.name = ETRow_MyHeightString then
		table.accessCell(table.row, table.ColumnValue).cellControl := self.cmbHeightCodes;
	elseif prodAttr.name = ETRow_MyLengthString then
		table.accessCell(table.row, table.ColumnValue).cellControl := self.cmbLengthCodes;
	elseif prodAttr.name = ETRow_MyType then
		table.accessCell(table.row, table.ColumnValue).cellControl := self.cmbTypeCodes;
	endif;
	
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doTxtBookingLostFocus" id="ca715950-9656-4b47-bbb3-805a8e40d9c1">
        <source>doTxtBookingLostFocus();
//02 June 2010	cnwml2
//+cnwml2 PAR24347
//
// Changed On	By			Reason
//-----------	--------	---------------------------------------------------------
// 07/09/2011	cnwdap1		PAR #28089 Make sure we only look at Active bookings
vars

	booking : CM_BookingRef;
	bookingString : String;
	port : CM_Port;
	consig : CM_ConsigneeConsignor;
//	commodity : CM_Commodity;
	iter : Iterator;			// PAR #28089
	bkg	: CM_BookingRef;		// PAR #28089
begin
	bookingString := self.txtBooking.text;
	// PAR #28089 ignore Complete and Archived bookings, return the first Pending/Active booking found
	// for the entered booking reference
	//booking := self.myTerminal.allBookingRefsByRef[bookingString];
	iter := self.myTerminal.allBookingRefsByRef.createIterator;
	self.myTerminal.allBookingRefsByRef.startKeyGeq(bookingString, iter);
	while iter.next(bkg) do
		if bkg.bookingReference.toUpper &lt;&gt; bookingString.toUpper then
			break;
		endif;
		if bkg.status &lt;&gt; BOOKING_REF_PENDING and bkg.status &lt;&gt; BOOKING_REF_ACTIVE then
			continue;
		endif;
		booking := bkg;
		break;
	endwhile;
	// PAR #28089 end
	
	self.tblItem.setValueByName(ETRow_BookingRef, self.txtBooking.text);

	if booking &lt;&gt; null then
		self.tblItem.setValueByName(ETRow_Volume, booking.volume.Decimal.asStringMeasurementJMT());
//		self.tblItem.setValueByName(ETRow_TotalWeight, booking.getTotalWeight.asStringMeasurementJMT());	// cnwrl1 02/11/2010 PAR 26167 - what it was
		
		if booking.myVoyage &lt;&gt; null then
			self.tblItem.setValueByName(ETRow_Voyage, booking.myVoyage.code);
			self.cmbVoyage.listObject := booking.myVoyage;
		else
			self.cmbVoyage.listObject := null;
			self.tblItem.setValueByName(ETRow_Voyage, null);
		endif;
		
		if booking.destinationPort &lt;&gt; null then
			port := app.myRoot.allPorts[booking.destinationPort];
			self.tblItem.setValueByName(ETRow_DestPort, booking.destinationPort); // note myCountry is mandatory, can't be null;
			self.cmbDestPort.setObject(port);
		else
			self.cmbDestPort.setObject(null);
			self.tblItem.setValueByName(ETRow_DestPort, null);
		endif;

		if booking.dischargePort &lt;&gt; null then
			port := app.myRoot.allPorts[booking.dischargePort];
			self.tblItem.setValueByName(ETRow_DisPort, booking.dischargePort);
			self.cmbDisPort.setObject(port);
		else
			self.cmbDisPort.setObject(null);
			self.tblItem.setValueByName(ETRow_DisPort, null);
		endif;
			
		if booking.consigneeCode &lt;&gt; null then
			consig := app.myRoot.allConsigneeConsignors[booking.consigneeCode];
			self.tblItem.setValueByName(ETRow_Consignee, booking.consigneeCode);
			self.cmbConsignee.setObject(consig);
		else
			self.cmbConsignee.setObject(null);
			self.tblItem.setValueByName(ETRow_Consignee, null);
		endif;
		
		if booking.consignorCode &lt;&gt; null then
			consig := app.myRoot.allConsigneeConsignors[booking.consignorCode];
			self.tblItem.setValueByName(ETRow_Consignor, booking.consignorCode);
			self.cmbConsignor.setObject(consig);
		else
			self.cmbConsignor.setObject(null);
			self.tblItem.setValueByName(ETRow_Consignor, null);
		endif;
		
		self.loadBookingItems(booking, booking.allBookingRefItems.first);			//+cnwml2 PAR25895
	else
		self.tblItem.setValueByName(ETRow_Volume, null);
//		self.tblItem.setValueByName(ETRow_TotalWeight, null);	// cnwrl1 02/11/2010 PAR 26167 - what it was
		self.cmbVoyage.setIndexFromObject(null);
		self.tblItem.setValueByName(ETRow_Voyage, null);
		self.cmbDestPort.setObject(null);
		self.tblItem.setValueByName(ETRow_DestPort, null);
		self.cmbDisPort.setObject(null);
		self.tblItem.setValueByName(ETRow_DisPort, null);
		self.cmbConsignee.setObject(null);
		self.tblItem.setValueByName(ETRow_Consignee, null);
		self.cmbConsignee.setObject(null);
		self.tblItem.setValueByName(ETRow_Consignor, null);
		/*self.cmbCommodity.setObject(null);
		self.tblItem.setValueByName(ETRow_Commodity, null);*/
	endif;
	
epilog
	delete iter;		// PAR #28089
end;
</source>
    </JadeMethod>
    <JadeMethod name="getAllAttributesDef" id="32edfd7a-9e05-4a25-ac92-1b964b8c5f1b">
