    <JadeMethod name="showOOWConfirmation" id="cfe8b963-da05-4f2d-9eb2-e8124e3ff9cd">
        <source>showOOWConfirmation(_voyage: CM_Voyage): Boolean;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 23/04/2018	jlgdap1		Initial creation TFS 38215 PEl1 OOW Confirmation Changes
//
vars

begin
	return _voyage.status = Voyage_Status_ICargoRequested;

epilog

end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
