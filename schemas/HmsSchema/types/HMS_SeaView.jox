    <JadeMethod name="tblMouseDown" id="333442c8-cf9c-42d8-a628-27d8318b1ae1">
        <updating/>
        <source>tblMouseDown(button: Integer; shift: Integer; x: Real; y: Real) updating;

vars
	table :	Table;
begin
	self.myCurrentWorkingMovement := null;
	self.origXPos := x;
	self.origYPos := y;
	// popup menu
	self.frmMeterMarks.visible := false;
	
	table := self.tblMovement;
	if table.row &lt;= table.fixedRows then
		return;
	endif;
	
	self.myCurrentWorkingMovement := table.accessRow(table.row).itemObject.CMIF_HMS_WorkingMovement;

end;</source>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="tblMovement_contextMenu" id="3d649c69-49c1-4e70-8c5a-4fa438726ca1">
        <controlMethod name="Table::contextMenu"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblMovement_contextMenu(table: CM_DataTable input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating;
//--------------------------------------------------
// Created:	22 July 2004 By: cnwgd1
//--------------------------------------------------
vars
	xLeft 	: Real;
	yTop	: Real;
	obj		: Object;
	voyCode : String;
begin
	self.frmMeterMarks.visible := false;
	self.mnuBerthMarks.userObject := null;
	self.mnuBerthMarks.caption := BerthMarks;
	self.mnuRemarks.userObject := null;
	self.mnuRemarks.caption := Remarks;	
		
	if table.row &lt;= table.fixedRows then
		return false;
	endif;
	
	obj := table.accessRow(table.row).itemObject;
	
	if obj = null then
		return false;
	endif;
	
	voyCode := table.accessCell(table.row, table.getColumnByRowName(ETRow_HmsMovementVoyage)).text;
	
	self.mnuBerthMarks.userObject := obj;
	self.mnuBerthMarks.caption := voyCode &amp; BerthMarks;
	self.mnuBerthMarks.userObject := obj;
	self.mnuBerthMarks.caption := voyCode &amp; BerthMarks;	
	
	xLeft := x;
	yTop := y;

	conwin.windowToScreen(xLeft, yTop);
	self.screenToWindow(xLeft, yTop);   // convert x, y relative to form

	self.popupMenu(self.mnuTableContext, xLeft.Integer, yTop.Integer);

	return true;

end;</source>
        <Parameter name="table" type="CM_DataTable" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
