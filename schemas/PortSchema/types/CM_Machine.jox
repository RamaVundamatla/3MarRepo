    <JadeMethod name="getMeasurementStringForAttrib" id="7c299222-db4a-4c33-a081-4251ceaf06b4">
        <source>getMeasurementStringForAttrib(_attrName: String; _measureType: String; _short: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 March 2014	cnwndl1	Initial creation	Par 33268
28 Nov 2014     cnwma1     				    Par 35281   Terminal Admin Machines
*/

vars

begin

	if _attrName = ETRow_TareWeight then
		return app.convertMeasurementForDisplay(_measureType, self.tareWeight);
	elseif _attrName = ETRow_MaxLiftWeight then
		return app.convertMeasurementForDisplay(_measureType, self.maxLiftWeight);
	elseif _attrName = ETRow_WeightDifference then									// + cnwma1 PAR #35281    28/11/2014 
		return app.convertMeasurementForDisplay(_measureType, self.weightDifference);
	endif;
	
	return inheritMethod(_attrName, _measureType, _short);

epilog

end;</source>
