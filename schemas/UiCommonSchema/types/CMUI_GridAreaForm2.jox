    <JadeMethod name="setupForm" id="e270d71f-ec1c-420d-9d37-76132df62b72">
        <updating/>
        <source>setupForm() updating;
// ---------------------------------------------------------------------------
// Created:     21 January 2002 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	// cnwrl1 236/02/2009 - (CCMS SFW 1047 - Totals Only Lists)
	// The user can access the summarise functionality only if they have at least view security role.
	self.bAllowSummaryDefn	:= app.myCurrentUserCan( self.myTerminal, PmSummaryDefView );
	
	inheritMethod();
	
 	if not self.myTerminal.getConfig(ShowCargoPicture).Boolean and 
 	   (not self.areaType = self.Area_Type_Log) then
 		//self.sptBottom.hideRightControl(true);
 	endif;
	self.mnuGridAreaContext.visible := false;
	self.doInitInfoTable();
	// this sets the captions for some menus
	self.getXMLSettingsForSetup();
	
	if self.areaType = self.Area_Type_Log then
		if self.xmlLegend then // we are hiding
			self.mnuGridHideLegend.caption := self.MNU_LEGEND_SHOW;
			self.mnuWorkDisplayHideLgnd.caption := self.MNU_LEGEND_SHOW;
			self.dkbColorLegend.visible := false;
		else
			self.mnuGridHideLegend.caption := self.MNU_LEGEND_HIDE;
			self.mnuWorkDisplayHideLgnd.caption := self.MNU_LEGEND_HIDE;
		endif;
	else
		if self.xmlLegend then
			self.mnuGridHideLegend.caption := self.MNU_LEGEND_HIDE;
			self.mnuWorkDisplayHideLgnd.caption := self.MNU_LEGEND_HIDE;
		else
			self.dkbColorLegend.visible := false;
			self.mnuGridHideLegend.caption := self.MNU_LEGEND_SHOW;
			self.mnuWorkDisplayHideLgnd.caption := self.MNU_LEGEND_SHOW;
		endif;
	endif;
	self.mnuGridHideLegend_click(self.mnuGridHideLegend); // this reverses the lines above and sets things correctly
	// must set the width AFTER the click call above
	self.dkbColorLegend.width := 100;

	if self.xmlMacro then
		self.mnuGridHideMacro.caption := self.MNU_MACRO_HIDE;
	else
		self.mnuGridHideMacro.caption := self.MNU_MACRO_SHOW;
	endif;
	self.mnuGridHideMacro_click(self.mnuGridHideMacro); // this reverses the lines above and sets things correctly

	self.dkbGridArea.setScrolledCallbackMethod('handleGridAreaScrolledEvent');

	self.frmStatusLine.initFrame();
	
//	self.picCargo.stretch := Picture.Stretch_CenterPicture;  // ### TFS 50421 08NOV2021 NAVAB1
	
end;</source>
    </JadeMethod>
    <JadeMethod name="showCargoPicture" id="6473acd8-4d4a-41f9-8690-9c9341e96323">
        <source>showCargoPicture(_theTI : CM_TrackedItem) : Binary;
// ---------------------------------------------------------------------------
// Created:		January 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	thePicture : Binary;
begin
	
	
	if _theTI = null then
		return null;
	endif;
 	if not self.myTerminal.getConfig(ShowCargoPicture).Boolean then
 		return null;
 	endif;

	thePicture := _theTI.getPicture;
	return thePicture;
	
	
end;</source>
        <Parameter name="_theTI" type="CM_TrackedItem"/>
        <ReturnType type="Binary"/>
    </JadeMethod>
    <JadeMethod name="showExtraAttributesDisplay" id="2928af48-2c37-4b7b-9202-08729065a218">
        <updating/>
        <source>showExtraAttributesDisplay(_theTIIndex : Integer;_theAttributeArray : CMUI_GridAttributesArray input;
		_dataContainer : CM_DataContainer) updating;
// ---------------------------------------------------------------------------
// Created:     22 January 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//17 Oct 2017	cnwma1  TFS #7431 JMT - Refactoring - Drawing Attributes Labels
// ---------------------------------------------------------------------------
vars
	theAttibuteString : String;
	aDrawingAttribute : CM_DrawingAttribute;
	aGridAttribute : CMIF_GridAttributes;
	block : CM_DataContainerBlock;
	
begin
	if _theTIIndex &lt; 1 then // see AKB. If you click on a point that is part of a TI that covers more than 1 point, the right hand points have no attributes
		return;
	endif;
	
	if _theAttributeArray = null then
		return;
	endif;
	
	if _theTIIndex &gt; _theAttributeArray.size then
		return;
	endif;
	aGridAttribute := _theAttributeArray[_theTIIndex];
	foreach theAttibuteString in aGridAttribute.allDisplayIcons do
		if theAttibuteString = null then
			continue;
		endif;
		aDrawingAttribute := app.myRoot.allDrawingAttributes[theAttibuteString];

		if aDrawingAttribute = null then
			continue;
		endif;
		if block = null then	
			block := _dataContainer.addNewBlock();
		endif;

		//block.addNewItem(aDrawingAttribute.getLabel(), DC_IconLabel, 1, null);   //17.10.2017	cnwma1  TFS #7431
		block.addNewItem(aDrawingAttribute.label, DC_IconLabel, 1, null);          //17.10.2017	cnwma1  TFS #7431
		block.addNewIcon(aDrawingAttribute.fontCharacter.Character, 1, null,
						aDrawingAttribute.fontName, aDrawingAttribute.colour);
	endforeach;

end;</source>
        <Parameter name="_theTIIndex" type="Integer"/>
        <Parameter name="_theAttributeArray" type="CMUI_GridAttributesArray" usage="input"/>
        <Parameter name="_dataContainer" type="CM_DataContainer"/>
    </JadeMethod>
    <JadeMethod name="showExtraInfo" id="3a3be307-0fa1-42f8-b9b3-38ba5aad4029">
        <updating/>
        <source>showExtraInfo(_obj : Object) updating;
// ---------------------------------------------------------------------------
// Created:     22 January 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 25 June 2003 sgp			Use transient CM_DataContainer instead of arrays
//							to pass data around.
// ---------------------------------------------------------------------------

vars
	dataContainer : CM_DataContainer;
	numberOfColumns,idx,theIndex,lDisplayMode,theWidth : Integer;
	theLine,theAttibuteString : String;
	theSingle : Boolean;
	anObject : Object;
	theAttributeArray : ObjectArray;
	aLeftDrawingAttribute,aRightDrawingAttribute : CM_DrawingAttribute;
	theObject : Object;
	
begin

	self.tblGridAreaInfo.rows := 0;
	numberOfColumns := self.getNumberOfColumns();
	
	if _obj = null then
		return;
	endif;

	self.tblGridAreaInfo.alignment := Table.Alignment_Left_Top;
	
	//######################
	// DISPLAY INFO
	create dataContainer transient;
	dataContainer.headerColour := self.colorHeadingColumn;
	dataContainer.valueColour := self.colorValueColumn;
	
	dataContainer.displayMode := self.myCurrentDrawingController.displayMode;
	self.getExtraInfoForObject(_obj, dataContainer);
	self.tblGridAreaInfo.userObject := _obj; // this is used to redraw this info
	
	self.showExtraInformation(dataContainer, self.tblGridAreaInfo, false,
			self.mnuGridBigFont.checked, numberOfColumns, self.getNumberOfColsForData,
			self.getNumberOfColsForHeader, self.getNumberOfColsForIcon,
			self.getNumberOfColsForLabel);

//	self.showExtraInformation(dataContainer, self.tblGridAreaInfo, false,
//			self.mnuGridBigFont.checked, 4,1,4,1,1);

	self.doResizeColumnWidths(self.tblGridAreaInfo, true);

epilog
	if dataContainer &lt;&gt; null then
		delete dataContainer;
	endif;
end;</source>
        <Parameter name="_obj" type="Object"/>
    </JadeMethod>
    <JadeMethod name="showExtraInfoForObject" id="b74a892d-7ff5-44f0-9cbd-8fe79def1a8b">
        <updating/>
        <source>showExtraInfoForObject(_theObject : Object input) updating;
// ---------------------------------------------------------------------------
// Created:		May 2003 By Andrew Bishop cnwab1
//
// Purpose:		This is used to update the macro info if a note comes thru for the object being displayed there
// ---------------------------------------------------------------------------
vars

begin
	self.tblGridAreaInfo.rows := 0;
	if _theObject &lt;&gt; null then
		self.showExtraInfo(_theObject);
	endif;
epilog
end;</source>
        <Parameter name="_theObject" type="Object" usage="input"/>
    </JadeMethod>
