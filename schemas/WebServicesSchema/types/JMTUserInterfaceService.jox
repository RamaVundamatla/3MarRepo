    <JadeWebServicesMethod name="setCurrentTerminal" id="0abda71f-e282-47ad-b9fa-49bf17fe57a2">
        <usesRPC>default</usesRPC>
        <source>setCurrentTerminal(terminal : WS_Terminal) : WS_TerminalResponse webService;

/*

Purpose:			Set the Terminal in the current session to the passed in Terminal.

Parameters:			Terminal info (only code used)

Return Value:		Terminal response populated


Date		Who		Reason
28 Jan 2009	cnwkpd1	PAR #17554 - Development of new RIA Web Service application

*/

vars
	response		: WS_TerminalResponse;
	completedOK		: Boolean;
	user			: CM_User;
	realTerminal	: CM_Terminal;
	userTerminal	: CM_UserTerminal;
	
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);

	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
	
	// Validate the input
	realTerminal := app.myRoot.allTerminals[terminal.code];
	if realTerminal = null then
		app.raiseCMException1(Err_InvalidTerminal,
							  terminal.code,
							  null, 
							  null);
							  
		completedOK := true;
		return response;
	endif;
	
	user := app.getMyUser();
	userTerminal := user.allUserTerminals[realTerminal];
	if userTerminal = null then
		app.raiseCMException(ERR_dontHaveAccessToThisItem,
							 null, 
							 null);
							  
		completedOK := true;
		return response;
	endif;
		
	// Update the session if required
	if currentSession.myCurrentTerminal &lt;&gt; realTerminal then
		beginTransaction;
		currentSession.setMyCurrentTerminal(realTerminal);
		commitTransaction;
		app.myPassport.setMyTerminal(realTerminal);
	endif;
	
	if  user &lt;&gt; app.myPublicUser then
		app.myTrxUA.trxUpdateUserStateData(app.getMyUser(), ConfigGrp_Web, UserCurrentTerminal, realTerminal.code, app.myPassport);
	endif;
	
	// And finally construct the reply		
	create response.terminal transient;
	response.terminal.setProxyFromObject(realTerminal);

	
	// Got to here, everything is ok
	completedOK := true;
	return response;
	

epilog
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
	
end;</source>
        <text>Set the Terminal in the current session to the passed in Terminal.</text>
        <wsdlName>setCurrentTerminal</wsdlName>
        <Parameter name="terminal" type="WS_Terminal"/>
        <ReturnType type="WS_TerminalResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="setCurrentUser" id="c65c9279-a5ef-4a7e-880c-bc0acdf68ca3">
        <source>setCurrentUser(userId : String) : WS_Response webService;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 October 2014	cnwmc5	Initial creation

*/

vars
	response		: WS_Response;
	completedOK		: Boolean;
	user			: CM_User;
	
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	// In particular this sets passport myUser and myTerminal
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;

	// Check security access to this message, if required
	app.checkCurrentUserHasAccess(PmAdmUserImpersonation);		// Replace with appropriate permission
	if app.myPassport.hasErrors then
		app.raiseCMException(Err_InsufficientPermission, null, null);
		completedOK := true;
		return response;
	endif;
	
	//cnwmc5 - Cannot change to superuser..
	if userId.toUpper &lt;&gt; SUPERUSER_Str then
		user := app.myRoot.allUsers[userId.toUpper];
	endif;	
	
	if user &lt;&gt; null then
		beginTransaction;
		currentSession.setMyUser(user);
		currentSession.setAppName( DefaultAppName );	//04 Mar 2021	NDL	TFS 50833
		commitTransaction;
	else
		app.raiseCMException1(ERR_REST_INV_USER, userId, null, null);
	endif;
	
	// Got to here, everything is ok
	completedOK := true;
	return response;
	
epilog
	
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
	
end;</source>
        <Parameter name="userId" type="String"/>
        <ReturnType type="WS_Response"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="setPreference" id="1a6b9c88-c213-479c-8502-08ba13c6fd98">
        <source>setPreference(preference : WS_PreferenceUpdateRequest) : WS_PreferenceResponse webService;

/*

Purpose:			

Parameters:			Terminal info (only code used)

Return Value:		Terminal response populated


Date		Who		Reason
28 Jan 2009	cnwkpd1	PAR #17554 - Development of new RIA Web Service application

*/

vars
	response		: WS_PreferenceResponse;
	completedOK		: Boolean;
	user			: CM_User;
	realTerminal	: CM_Terminal;
	userTerminal	: CM_UserTerminal;
	
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);

	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
	
	
	// Validate the input
	realTerminal := app.myRoot.allTerminals[preference.terminal];
	if realTerminal = null then
		app.raiseCMException1(Err_InvalidTerminal,
							  preference.terminal,
							  null, 
							  null);
							  
		completedOK := true;
		return response;
	endif;
	
	user := app.getMyUser();
	userTerminal := user.allUserTerminals[realTerminal];
	if userTerminal = null then
		app.raiseCMException(ERR_dontHaveAccessToThisItem,
							 null, 
							 null);
							  
		completedOK := true;
		return response;
	endif;
	
	// Update the session if required
	if currentSession.myCurrentTerminal &lt;&gt; realTerminal then
		beginTransaction;
		currentSession.setMyCurrentTerminal(realTerminal);
		commitTransaction;
		app.myPassport.setMyTerminal(realTerminal);
	endif;
	
	//epr 4/10/17 webportal changes
	if user &lt;&gt; app.myPublicUser then
		app.myTrxUA.trxUpdateUserStateData(app.getMyUser(), ConfigGrp_Web, UserCurrentTerminal, realTerminal.code, app.myPassport);
	endif;
	
	// And finally construct the reply		
	create response.preference transient;
	response.preference.setProxyFromObject(realTerminal);

	
	// Got to here, everything is ok
	completedOK := true;
	return response;
	

epilog
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
	
end;</source>
        <text>This method is designed for the JMT RIA.</text>
        <wsdlName>setPreference</wsdlName>
        <Parameter name="preference" type="WS_PreferenceUpdateRequest"/>
        <ReturnType type="WS_PreferenceResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="setPushEventsConfiguration" id="2910957e-991d-4858-9215-aeb61002f1c9">
        <source>setPushEventsConfiguration(request : WS_PushEventsConfigRequest) : WS_PushEventsConfigResponse webService;
/*

Purpose:			Save the configuration details in the Push Events root object

Parameters:			

Return Value:		

Date		Who		Reason
10 Mar 2017	cnwkpd1	TFS 3369 - Push Events application
01 Nov 2017	jlgkpd1	TFS 7141 - Add in replay identifier mechanism

*/

vars
	response		: WS_PushEventsConfigResponse;
	completedOK		: Boolean;
	pushEventsRoot,
	pxyRoot			: CM_PushEventsRoot;
	
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	// In particular this sets passport myUser and myTerminal
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
		
// Check security access to this message, if required
	app.checkCurrentUserHasAccess(PmPushEventsMaint);
	// Check for any errors
	if app.myPassport.hasErrors then
		completedOK := true;
		return response;
	endif;
	
	// Perform validation, start populate response
	pushEventsRoot := CM_PushEventsRoot.firstInstance();
	if pushEventsRoot = null then
		app.raiseCMException(Push_Events_not_running, null, null);
		completedOK := true;
		return response;
	endif;
	
	pxyRoot := app.createUpdateProxy(pushEventsRoot).CM_PushEventsRoot;
	pxyRoot.setProxy(request.configurationDetails, pxyRoot.replayStartTS, pxyRoot.replayEndTS, pxyRoot.replayIdentifier);
	
	if not app.myPassport.hasErrors then
		app.myTrxUA.trxUpdatePushEventsRoot(pxyRoot, app.myPassport);
	endif;
	
	response.configurationDetails := pushEventsRoot.configurationDetails;
	
	// Got to here, everything is ok
	completedOK := true;
	return response;
	

epilog
	delete pxyRoot;
	
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
	
end;</source>
        <text>Save the configuration details for the JMTPushEvents mechanism.</text>
        <Parameter name="request" type="WS_PushEventsConfigRequest"/>
        <ReturnType type="WS_PushEventsConfigResponse"/>
    </JadeWebServicesMethod>
