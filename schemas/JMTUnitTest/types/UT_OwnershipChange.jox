    <JadeMethod name="loadTransMapRange" id="70bb086d-3e6d-4370-b304-1675c94c65f0">
        <source>loadTransMapRange(_mapName : String; 
						_transactionName : String);
/*
Purpose - 	
Who - NAVAB1
Date - 2JULY2024
ADO -  BUG BUG 64965
*/

vars
	fileContent : String;
	fileName : String;
	bank : CM_Bank;
	tranMap : CM_TranMap;

begin
	fileName := "CargoReceive";
	
	fileContent := 'TranMap Type,TranMap Name,CargoType,Cargo Subtype Group,Cargo Subtype,IMEX,Contents Status,Commodity,Transaction,MoveType,Debtor,Quantity Type,Quantity Range,Quantity Sub Type,Quantity Sub Range,Transfer Type,Grouping,Invoice Line,Over Dimsn?,Trans Ship?,Is 40?,Is Reefer?,Req Temp?,,Is 45?,Is 30?,Is 53?,Is Child?,Is Haz?,Direct Delivery?,Is Work Order Requested?' &amp; CrLf &amp;
					'Cargo,' &amp; _mapName &amp; ',(Default),(Default),(Default),(Default),(Default),(Default),(Default),,(Default),(Default) ›,(Default),,,**Any**,All,VOID'&amp; CrLf &amp;
					'Cargo,' &amp; _mapName &amp; ',(Default),(Default),(Default),(Default),(Default),(Default),' &amp;_transactionName &amp; ',,(Default),|CCT06|Days Since Receival »,08 to 14,,,**Any**,All,UT_COOSTO08-14' &amp; CrLf &amp; 
					'Cargo,' &amp; _mapName &amp; ',(Default),(Default),(Default),(Default),(Default),(Default),' &amp;_transactionName &amp; ',,(Default),|CCT06|Days Since Receival »,15 to MAX,,,**Any**,All,UT_COOSTO15-MAX' &amp; CrLf;

	// DELETE TRAN MAP
	bank := app.myPassport.myTerminal.getDefaultCompanyBank();
	tranMap := bank.myCurrentTranMapCargo[_mapName];
 	if tranMap &lt;&gt; null then
		app.myTrxDA.trxDeleteInvoiceTranMap(tranMap, app.myPassport);
	endif;
	
	// CREATE TRAN MAP
	self.transactionMapLoad(fileContent, fileName);
	self.assertNoTrxErrorsOrWarnings();
	
	bank := app.myPassport.myTerminal.getDefaultCompanyBank();
	tranMap := bank.myCurrentTranMapCargo[_mapName];
	self.assertNotNullMsg(tranMap, "Transaction map should not be null");

	app.myTrxUA.trxUpdateBankTMActive(tranMap, app.myPassport);
end;
</source>
        <Parameter name="_mapName" type="String"/>
        <Parameter name="_transactionName" type="String"/>
    </JadeMethod>
    <JadeMethod name="outputDetailsFuture" id="fb49b074-a837-4122-9827-d3ca49c3fcd0">
        <source>outputDetailsFuture(_ti : CM_TrackedItem);
/*
Purpose:	During the change to 22.0.24 some combo boxes had their STYLE set to zero, this is a patchable way to fix that.				

Date		Who		Reason
21 June 2024	navab1	BUG 64680
*/

vars
	sed : CM_StorageExpiryDetail;
	coo : CM_OwnershipChange;
	bgpfa :CM_FutureStorageProcess;
		actor : CM_OfflineFutureActor;
	actors : CM_OfflineFutureActorDict;

begin
	write "REC: " &amp;  _ti.receivedDT.String;
	
	foreach coo in _ti.allOwnershipChange discreteLock do
		write "COO: " &amp; coo.dateTimeCOO.date.String &amp; " OP OLD: " &amp; coo.myOperatorOld.code &amp; " OP NEW: " &amp; coo.myOperatorNew.code &amp; " ADD DAYS: " &amp; coo.freeDaysAdditional.String;
	
	endforeach;
	
	foreach sed in _ti.allStorageExpiryDetails discreteLock do
		write "SED: " &amp; sed.freeStorageExpiry.date.String &amp; " OP: " &amp; sed.operatorCode;
	
	endforeach;
	
	create actors transient;
	actors.clear();
	app.myRoot.getFutureActors(_ti, CM_FutureStorageProcess,actors);
	
	foreach actor in actors do : actorloop
		write "ACT: " &amp; actor.actionTimeStamp.date.String;
	endforeach;		

	delete actors;

epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="tOwnershipChange" id="efce4311-4a72-4142-af8b-1387f3060df5">
        <source>tOwnershipChange();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 June 2023 navtnr20	TFS CR 58507	Task 58211: Jade - Unit Test Ownership Change

*/
constants
	DEBTOR 		= "UT_DEBTOR_AB";
vars
	realOwnershipChange,
	pxyOwnershipChange : CM_OwnershipChange;
	dateTimeCOO,dateTimeApproved,storageExpriryOperatorNew	: TimeStamp;
	transferedWeight, transferedVolume : Decimal[23,4];
	myOperatorOid,
	myOperatorOrig,
	myOperatorStorage,myOperatorNew			: CM_Operator;
	myFreightForward			: CM_ConsigneeConsignor;
	debtor1 : CM_Debtor;
	remarks : String;
	myiNCOTerm : CM_InvoiceINCOTerm;
	terminal : CM_Terminal;
begin
	//self.deleteOwnershipChange(realOwnershipChange);
	self.createOwnerShip(realOwnershipChange);
	dateTimeCOO		:= app.actualTimeAppServer();
	storageExpriryOperatorNew := app.actualTimeAppServer();
	transferedWeight		:= 65.2578;
	transferedVolume		:= 98.4974;
	terminal := self.getTerminal;
	if self.opts.includesKey("DtRequiredUp") then
		dateTimeApproved := self.opts.str("DtRequiredUp").TimeStamp;
	endif;
	if self.opts.includesKey("RemarksUpdate") then
		remarks := self.opts.str("RemarksUpdate");
	endif;
	self.deleteInvINCOTerm("abcd");
	self.contractINCOCreate(myiNCOTerm, "abcd");
	self.deleteDebtor(DEBTOR);
	debtor1 := self.addDebtor(DEBTOR, PaymentType_PostPay).CM_Debtor;
	self.deleteOperator("ABCO");
	self.deleteOperator("MNB");
	self.deleteOperator("lkj");
	self.deleteOperator("OPD");
	self.deleteConsigneeConsignor("UTFreightForward");
	myOperatorNew := self.addOperator("ABCO", "Ownership Change OperatorNew", false, 0, 0, debtor1, false, false, false, false, false, false, false, false, false, false, null, null, null, false, false, false, null, null, 0, null, false, false);
	self.assertNotNullMsg(myOperatorNew,"Operator Create Failed");
	myOperatorOid := self.addOperator("MNB", "Ownership Change Operatoroid", false, 0, 0, debtor1, false, false, false, false, false, false, false, false, false, false, null, null, null, false, false, false, null, null, 0, null, false, false);
	self.assertNotNullMsg(myOperatorOid,"Operator Create Failed");
	myOperatorOrig := self.addOperator("lkj", "Ownership Change OperatorOrig", false, 0, 0, debtor1, false, false, false, false, false, false, false, false, false, false, null, null, null, false, false, false, null, null, 0, null, false, false);
	self.assertNotNullMsg(myOperatorOrig,"Operator Create Failed");
	myFreightForward := self.addConsigneeConsignor("UTFr", "FreightForward", true, false, false);
	myOperatorStorage := self.addOperator("OPD", "Ownership Change OperatorStorage", false, 0, 0, debtor1, false, false, false, false, false, false, false, false, false, false, null, null, null, false, false, false, null, null, 0, null, false, false);
	self.assertNotNullMsg(myOperatorStorage,"Operator Create Failed");
	//Update Ownership Change
	
	beginTransaction;
	pxyOwnershipChange := realOwnershipChange.pxyCreateUpdateProxy();
	commitTransaction;
	pxyOwnershipChange.setProxy( pxyOwnershipChange.refNumber, app.getMyUserCode(),"bad",app.getMyUserCode(),dateTimeCOO,dateTimeApproved,
		storageExpriryOperatorNew,55,99,66,5835,transferedWeight,transferedVolume,remarks,myFreightForward,myiNCOTerm,myOperatorNew,
				myOperatorOid,myOperatorOrig,myOperatorStorage,pxyOwnershipChange,terminal, null);	//navra1 - TFS 64874 - 14th Aug 2024
	self.updateOwnershipChange(pxyOwnershipChange);
	self.assertNotEqualMsg(self.checkErrorWarningHasOccurred(), true, "Unexpected Ownership change input field errors");
	realOwnershipChange := app.myProxyManager.getRealObject(pxyOwnershipChange).CM_OwnershipChange;
	self.assertEqual(realOwnershipChange.refNumber, pxyOwnershipChange.refNumber);
	self.assertEqual(realOwnershipChange.userCodeApproved,app.getMyUserCode());
	self.assertEqual(realOwnershipChange.condition,"bad");
	self.assertEqual(realOwnershipChange.userCode,app.getMyUserCode());
	self.assertEqual(realOwnershipChange.dateTimeCOO,dateTimeCOO);
	self.assertEqual(realOwnershipChange.dateTimeApproved,dateTimeApproved);
	self.assertEqual(realOwnershipChange.storageExpiryOperatorNew,storageExpriryOperatorNew);
	self.assertEqual(realOwnershipChange.freeDaysAdditional,55);
	self.assertEqual(realOwnershipChange.freeDaysOperatorNew,99);
	self.assertEqual(realOwnershipChange.freeDaysOperatorOld,66);
	self.assertEqual(realOwnershipChange.transferredQuantity,5835);
	self.assertEqual(realOwnershipChange.transferredWeight,transferedWeight);
	self.assertEqual(realOwnershipChange.transferredVolume,transferedVolume);
	self.assertEqual(realOwnershipChange.remarks,remarks);
	self.assertEqual(realOwnershipChange.myFreightForwarder,myFreightForward);
	self.assertEqual(realOwnershipChange.myIncoterm,myiNCOTerm);
	self.assertEqual(realOwnershipChange.myOperatorNew,myOperatorNew);
	self.assertEqual(realOwnershipChange.myOperatorOld,myOperatorOid);
	self.assertEqual(realOwnershipChange.myOperatorOrig,myOperatorOrig);
	self.assertEqual(realOwnershipChange.myOperatorStorage,myOperatorStorage);
	self.assertEqual(realOwnershipChange.myOwnershipChangePrevious,null);
	self.assertEqual(realOwnershipChange.myTerminal,terminal);
	process.sleep(2000);
	
	delete pxyOwnershipChange;
	self.deleteOwnershipChange(realOwnershipChange);
epilog
	delete pxyOwnershipChange;
end;</source>
    </JadeMethod>
    <JadeMethod name="tOwnershipChangeAndDtls" id="99f2f054-6dfb-48ae-9277-3bbd143b4e66">
        <source>tOwnershipChangeAndDtls();
/*

Purpose:			

Parameters:			

