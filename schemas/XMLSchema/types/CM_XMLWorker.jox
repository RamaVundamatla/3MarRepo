<Class name="CM_XMLWorker" id="6636feb9-ef76-49c2-8b2a-d31b4a7b4478">
    <superclass name="CM_TCPIPAgentWorker"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="jmtxml"/>
    <ImplicitInverseRef name="myManager" id="67762ede-bc5b-4bc4-bb4d-f838389eb4b1">
        <embedded/>
        <type name="CM_RemoteDataManagerExternal"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="myXMLSession" id="c1029ad9-e360-4c88-a1fa-529217702bce">
        <embedded/>
        <type name="CM_XMLSession"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <JadeMethod name="checkPermissions" id="3ca060c5-a5ef-43f1-bcd5-76cd90f9932c">
        <source>checkPermissions(_msgType :String ; _session : CM_XMLSession; _errorCode:Integer output) : String protected;
// -----------------------------------------------------------------------------
// Created:		12 August 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
// 06/03/2009	cnwdad1		Added a check for an unknown message type.
// -----------------------------------------------------------------------------
vars
	doesExist	: Boolean;
	
begin
	if _session.checkPermission(_msgType, doesExist) then
		_errorCode	:=	0;
		return null;
	endif;
	
	if doesExist then
		_errorCode	:=	Err_InsufficientPermission;
		return app.getErrorString(Err_InsufficientPermission);
	else
		_errorCode	:=	XML_Message_Unknown;
		return app.getErrorString1(XML_Message_Unknown, _msgType);
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_msgType" type="String"/>
        <Parameter name="_session" type="CM_XMLSession"/>
        <Parameter name="_errorCode" type="Integer" usage="output"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="checkSession" id="e1178d85-e85d-4191-b141-21528f600f99">
        <updating/>
        <source>checkSession(_session : CM_XMLSession io; _userId, _device, _passwd, _terminal, _version : String; _error : String output) : Boolean updating, protected;
// -----------------------------------------------------------------------------
// Created:		12 August 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
begin

	_session.set(_userId, _device, _terminal, _version, _passwd);	
	
	if _session.myTerminal = null then
		_error := 'terminal id (' &amp; _terminal &amp;')';
		return false;
	elseif _session.myUser = null then
		_error := 'user id (' &amp; _userId &amp; ')';
		return false;
	elseif _session.myDevice = null then
		_error := 'device id (' &amp; _device &amp; ')';
		return false;	
	endif;
	
	if _session.theVersion &gt;= 2 then
		if not _session.myDevice.isPasswordCompulsory then
			return true;
		endif;
	endif;
	
	if not app.validateUserPassword(_userId.toUpper, _passwd) = 0 then 
		_error := 'password';
		return false;
	endif;

		
	return true;
end;</source>
        <access>protected</access>
        <Parameter name="_session" type="CM_XMLSession" usage="io"/>
        <Parameter name="_userId" type="String"/>
        <Parameter name="_device" type="String"/>
        <Parameter name="_passwd" type="String"/>
        <Parameter name="_terminal" type="String"/>
        <Parameter name="_version" type="String"/>
        <Parameter name="_error" type="String" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="delete" id="fbb42639-b10f-48e6-becb-c501172f2028">
        <updating/>
        <source>delete() updating;

// cnwdvb1 13 November 2002 

vars

begin

	delete self.myManager;
	delete self.myXMLSession;

end;</source>
    </JadeMethod>
    <JadeMethod name="doTheWork" id="a07b1dff-366d-4ed9-bb94-9e40878e2d72">
        <updating/>
        <source>doTheWork(_xml : String) : String updating, protected;
// -----------------------------------------------------------------------------
// Created:		01 August 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
vars
	struct 		: CnEcXmlStructureInstance;
	theParser	: CnEcXmlParser;
	response	: String;

begin

	self.logIt(self.LogLevel_Trace,  class.name&amp; '::' &amp; method.name &amp; '- XML Worker starting...') ;
	create theParser transient;
	create struct as CnEcXmlGroupInstance transient;
	theParser.parseToMsgStructure(_xml, struct);

	response := self.processSession(struct, self.myXMLSession);
	if response = null then
		response :=  self.myManager.processExternal(_xml, struct, self.myXMLSession);
	endif;
	
	return response;
epilog
	self.logIt(self.LogLevel_Trace, class.name&amp; '::' &amp; method.name &amp; '- XML Worker has finished.') ;
	delete struct;
	delete theParser;
end;</source>
        <access>protected</access>
        <Parameter name="_xml" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="finish" id="bf5c08d3-44e2-448a-a8b6-9165b02bf89a">
        <updating/>
        <source>finish() updating;

vars

begin

	delete self.myManager;
	delete self.myXMLSession;
	inheritMethod();
end;</source>
    </JadeMethod>
    <JadeMethod name="init" id="3dbe123c-e3aa-49ca-8494-9dc81b131e30">
        <updating/>
        <source>init() updating;

// cnwdvb1 13 November 2002 

vars

begin
	inheritMethod();
	create self.myManager transient; 
	create self.myXMLSession transient;

end;</source>
    </JadeMethod>
    <JadeMethod name="processSession" id="b9bbc6d4-104e-48fa-ae5d-d88af67e74fd">
        <updating/>
        <source>processSession(_struct : CnEcXmlStructureInstance; _session : CM_XMLSession io) : String updating, protected;
// -----------------------------------------------------------------------------
// Created:		08 August 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
vars
	error		: String;
	userCode	: String;
	password	: String;
	deviceId	: String;
	msgType		: String;
	msgId		: String;
	terminal	: String;
	version		: String;
	errString	: String;
	errString2	: String;
	errorCode	: Integer;
	errNumber	: Integer;
	struct2		: CnEcXmlStructureInstance;
	
begin
	msgId := null;

	on SystemException do self.xHandleNull(exception, errString, errNumber);
	msgType 	:= _struct.findStructure(XML_MSGTYPE).tagData;
	userCode 	:= _struct.findStructure(XML_USERID).tagData.toUpper();
	msgId		:= _struct.findStructure(XML_MSGID).tagData;
	deviceId 	:= _struct.findStructure(XML_DEVICEID).tagData;
	terminal	:= _struct.findStructure(XML_TERMINAL).tagData;
	version		:= _struct.findStructure(XML_VERSION).tagData;
	
	struct2		:= _struct.findStructure(XML_PSWD);
	if  struct2 &lt;&gt; null then
// cnwdad1 19/11/2008 - PAR #18503.
//		password := struct2.tagData.toUpper();
		password := struct2.tagData;
	endif;

	if errString &lt;&gt; null then
		return self.createXmlError(errNumber, errString, msgType, msgId, deviceId, version);
	endif;
	
	if not self.checkSession(_session, userCode, deviceId, password, terminal, version, error) then
		if errString.length &gt; 0 then
			error := errString;
		endif;
		
		return self.createXmlError(	Err_InvalidSessionDetails,
									app.getErrorString1(Err_InvalidSessionDetails, error),
									msgType,
									msgId,
									deviceId,
									version);
	endif;
	
	errString2 := self.checkPermissions(msgType, _session, errorCode);
	
	if errString2 &lt;&gt; null then
		return self.createXmlError(	errorCode,
									errString2,
									msgType,
									msgId,
									deviceId,
									version);
	endif;
	
//	if errString &lt;&gt; null then
//		return self.createXmlError(	errNumber,
//									errString,
//									msgType,
//									msgId,
//									deviceId,
//									version);
//	endif;
	
	return null;
end;</source>
        <access>protected</access>
        <Parameter name="_struct" type="CnEcXmlStructureInstance"/>
        <Parameter name="_session" type="CM_XMLSession" usage="io"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="processStartOfMessage" id="98b9ff20-07fd-48d1-8e44-74100c3dd83b">
        <updating/>
        <source>processStartOfMessage(_newBuffer : String) : Boolean updating, protected;

vars
	pos 		: Integer;
	newBuffer	: String;

begin
	self.addToBuffer(_newBuffer);
	pos :=  self.buffer.pos(XML_STARTOFMSG, 1);
	
	if pos &gt; 0 then
		newBuffer := self.buffer;
		self.clearBuffer();
		self.addToBuffer(newBuffer[pos:end]);
		return true;
	endif;
	
	return false;
end;</source>
        <access>protected</access>
        <Parameter name="_newBuffer" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="processToEndOfMessage" id="b97836f7-045e-45db-bda9-bf73d480b36d">
        <updating/>
        <source>processToEndOfMessage(_newBuffer : String) : Boolean updating, protected;

vars

	startPos,
	endPos,
	workStringEndPos,
	pos 		: Integer;
	workString	: String;
	

begin

	if _newBuffer = null then
		startPos := 1;
	else
		startPos := (self.buffer.length - XML_ENDOFMSG.length).max(1);
	endif;
	
	workString := self.buffer &amp; _newBuffer;
	pos := workString.pos(XML_ENDOFMSG, startPos);
	if pos &gt; 0 then
		self.clearBuffer();
		self.addToBuffer(workString[1:(pos + XML_ENDOFMSG.length)]);
		return true;
	endif;
	self.addToBuffer(_newBuffer);
	return false;

end;</source>
        <access>protected</access>
        <Parameter name="_newBuffer" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
