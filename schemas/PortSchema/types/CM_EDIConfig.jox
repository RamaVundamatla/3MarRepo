        <source>removeVoyageFromProcessing(_voyage: CM_Voyage);
//----------------------------------------------------------------
//	Created:	15 February 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin

	if self.allVoyagesToProcess.includes(_voyage) then
		self.allVoyagesToProcess.remove(_voyage);
	endif;

end;</source>
