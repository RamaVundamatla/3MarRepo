    <JadeMethod name="erase" id="197d3416-1c19-4c6a-a866-c73d3c675fcc">
        <updating/>
        <source>erase(_eraseLevel: Integer) updating;
/*
	Created on 11 January 2008
	
	by Debby Hutchison
	
	Purpose: Copied from CM_BookingRef for CCMS 1618
*/
vars
	br : CM_BookingRef;
	haz : CM_TIHazard;
begin
	if not self.isTransient then
		self.allTIHazards.purge();
	endif;
	
	if self.myBookingReference &lt;&gt; null then
		myBookingReference.allTIHazards.rebuild;
	endif;
	inheritMethod(_eraseLevel);
end;</source>
        <Parameter name="_eraseLevel" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="findProspects" id="37356fac-5534-456c-a7b9-d1ae708b7bad">
        <source>findProspects( _tiArray : CM_TIArray io );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 September 2016	cnwndl1	Initial creation	TFS 2649 / 2001
// 11 Jan 2018	cnwrs1	TFS 36603 STW fix locking issue
*/

vars

	oper : CM_Operator;
	operTerm : CM_OperatorTerminal;
	iter : Iterator;
	cargoType : CM_CargoType;
	startObject : CM_TrackedItem;
	ti : CM_TrackedItem;

begin

	if _tiArray = null or self.myBookingReference = null then
		return;
	endif;
	
	oper := self.myBookingReference.myOperator;
	if oper = null then
		return;
	endif;
	
	operTerm := self.getMyTerminal.allOperatorTerminals.getAtKey( oper );
	if operTerm = null then
		return;
	endif;
	
	cargoType := self.myCargoType;
	if cargoType = null then
		return;
	endif;
	
	iter := operTerm.allOnsiteTIsByCargoTypeId.createIterator;
	startObject := operTerm.allOnsiteTIsByCargoTypeId.getAtKeyGeq( cargoType.id, null );
	if startObject &lt;&gt; null then
		iter.startAtObject( startObject );
		while iter.next( ti ) do
			if ti.cargoType &lt;&gt; cargoType.id then
				break;
			endif;
			if not self.cargoIsProspect( ti ) then
				continue;
			endif;
			_tiArray.addExclusive( ti );
		endwhile;
	endif;

epilog
	delete iter;
end;</source>
        <Parameter name="_tiArray" type="CM_TIArray" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getAmountDisplay" id="676bd306-b391-4b16-b02d-c461145c2ebc">
        <source>getAmountDisplay() : String;
/*

Date		Who		Reason
23 September 2014	cnwer1	Initial creation PAR 34935

*/

vars

begin
	if self.isBulkMulti then
		return self.getWeightDisplay();
	else
		return self.getQuantity.asStringJMT;
	endif;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getAssignedIDs" id="d069fc3a-0319-4d14-a33a-a686d5233a68">
        <source>getAssignedIDs(): String;
/*

Purpose:			Copied from CM_BookingRef for CCMS 1618

Parameters:			

Return Value:		List of all tracked items

Date		Who		Reason
11 Jan 2008	Debby Hutchison	Initial Creation
04 Apr 2019	jlgzm1	TFS43864 Booking screen performance

*/
vars
	str,
	strNote,
	strNonNote : String;
	blnNote,
	blnNonNote : Boolean;
	ti	: CM_TrackedItem;
	iter : Iterator;

begin
	//tfs43864 start
	if self.allTIs.size &gt; 300 then
		return app.getErrorString(Too_many_items_display);
	endif;

	iter := self.allTIsByState.createIterator();
	while iter.next(ti) do
		if iter.getCurrentKey(1).Integer = TI_STATE_NOTIFIED then
			if strNote &lt;&gt; null then
				//ti.id
				strNote := iter.getCurrentKey(2).String &amp; ', ' &amp; strNote;
			else
				//ti.id
				strNote := iter.getCurrentKey(2).String;
			endif;
			blnNote := true;
		else
			if strNonNote &lt;&gt; null then
				//ti.id
				strNonNote := iter.getCurrentKey(2).String &amp; ', ' &amp; strNonNote;
			else
				//ti.id
				strNonNote := iter.getCurrentKey(2).String;
			endif;
			blnNonNote := true;
		endif;
	endwhile;
	//tfs43864 end
	
	if blnNote then
		str := strNote &amp; ' (pre-noted)';
		if blnNonNote then
			str := str &amp; '; ';
		endif;
	endif;
	if blnNonNote then
		str := str &amp; strNonNote;
		if blnNote then
			str := str &amp; ' (received)'; // only need this if have both types
		endif;
	endif;
	
	
	return str ;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
