    <JadeMethod name="parseSnapshots" id="dc03dc5e-7a41-4e53-a7d8-2a4531a6341f">
        <source>parseSnapshots(_items: StringArray; _objs: CM_ObjectSetActual io) : Boolean;

vars
	tokens: StringArray;
	ta: CM_TerminalArea;
	voyage: CM_Voyage;
	train: CM_Train;
	gate: CM_Gate;
	item: String;
	token: String;
	objStr: String;
	idx: Integer;
begin

	foreach item in _items do
		tokens := item.getTokens();
		
		if tokens.size &gt; 2 then
			foreach idx in 2 to tokens.size() do
				token := tokens[idx];
				objStr := objStr &amp; token &amp; " ";
			endforeach;
			objStr := objStr[1:objStr.length-1];
		else 
			objStr := tokens.last;
		endif;
		
		objStr := tokens.last;
		
		if tokens.first = "YARD" then
			ta := app.myPassport.myTerminal.allTerminalAreas[objStr];
			if ta = null then
				app.writeLog(app.getErrorString1(KEA_ERROR, "Invalid Yard: " &amp; objStr), LogINFO);
				continue;
			else
				_objs.add(ta);
			endif;
		elseif tokens.first = "VOYAGE" then
			voyage := app.myPassport.myTerminal.lookupVoyage(objStr, null, false);
			if voyage = null then
				app.writeLog(app.getErrorString1(KEA_ERROR, "Invalid Voyage: " &amp; objStr), LogINFO);
				continue;
			else
				_objs.add(voyage);
			endif;
		elseif tokens.first = "TRAIN" then
			train := app.myPassport.myTerminal.allTrainsOnTerminal.getAtKeyGeq(objStr, null);
			if train = null or train.code &lt;&gt; objStr then
				train := app.myPassport.myTerminal.allTrainsDeparted.getAtKeyGeq(objStr, null);
			endif;
			if train = null or train.code &lt;&gt; objStr then
				app.writeLog(app.getErrorString1(KEA_ERROR, "Invalid Train: " &amp; objStr), LogINFO);
				continue;
			else
				_objs.add(train);
			endif;
		elseif tokens.first = "ROAD" then
			gate := app.myPassport.myTerminal.allGates[objStr];
			if gate = null then
				app.writeLog(app.getErrorString1(KEA_ERROR, "Invalid Gate: " &amp; objStr), LogINFO);
				continue;
			else
				_objs.add(gate);
			endif;
		endif;
		delete tokens;
	endforeach;
	
	return true;

epilog
	delete tokens;
end;
</source>
        <Parameter name="_items" type="StringArray"/>
        <Parameter name="_objs" type="CM_ObjectSetActual" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="txFilter" id="38cf5145-7daa-48d0-8dee-ce30be832984">
        <source>txFilter(_trans: CM_TITransaction; _passport: CM_Passport; _breakOut: Boolean ) : Boolean;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 January 2014	cnwdw1	Initial creation
*/
vars

begin
	return self.isKeaMove(_trans);
epilog

end;</source>
        <Parameter name="_trans" type="CM_TITransaction"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <Parameter name="_breakOut" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
