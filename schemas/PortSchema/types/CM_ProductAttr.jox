    <JadeMethod name="setProxy" id="58b1dc26-f10d-4aa8-8524-623871864f5a">
        <updating/>
        <source>setProxy(_realProdAttr : CM_ProductAttr) updating;
// ---------------------------------------------------------------------------
// Created:     11 October 2002 by cnwth2
//
// Purpose:     name and validation types, and myType (primative) are set in the create and
//				are not changed - so are not set here. 
//				The allCodes dict is also cloned here - the only reference that needs to be 
//				set on the code is the myProduct - not the myCodeGroup - as CM_ProductAttributeCode 
//				instances should never have one
//
// ----------   ----------  --------------------------------------------------
vars
	code,
	loopCode		: CM_ProductAttributeCode;
	
begin
	self.isViewable		:= _realProdAttr.isViewable;
	self.displayName	:= _realProdAttr.displayName;	
	self.validationType := _realProdAttr.validationType;	
	
	foreach loopCode in _realProdAttr.allCodes do
		create code transient;
		code := loopCode.cloneSelf(true);
		self.allCodes.add(code);
	endforeach;
	
	if _realProdAttr.myCode &lt;&gt; null then
		self.myCode	:= _realProdAttr.myCode.cloneSelf(true);
	endif;
	
	
		
	
end;</source>
        <Parameter name="_realProdAttr" type="CM_ProductAttr"/>
    </JadeMethod>
