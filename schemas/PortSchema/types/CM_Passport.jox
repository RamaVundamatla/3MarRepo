        <source>getUserCode() : String;
// -------------------------------------------
// Created 13 September 2004 by cnwdvb1
// -------------------------------------------
//12 Nov 2013	cnwrs1	32983 crash after user deleted.
vars
	isInvalid : Boolean;
begin
	if self.myUser &lt;&gt; null then
		on Exception do app.handleDeletedObject(exception, self.myUser, isInvalid);
		return self.myUser.code;
		if isInvalid then
			return self.userCode;
		endif;
	endif;
	return null;
