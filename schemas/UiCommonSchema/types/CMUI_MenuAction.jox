// ---------------------------------------------------------------------------
// Created:     15 July 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	self.goToObject(self.myWindowControl, null, true, null);

end;</source>
    </JadeMethod>
    <JadeMethod name="setFromController" id="4dd23296-17f2-4bd4-951e-abad64febcaa">
        <updating/>
        <source>setFromController(_menuDtl : CM_MenuDtlNav; _parent : CM_MenuEntity; _terminal : CM_Terminal) updating;
// ---------------------------------------------------------------------------
// Created:     17 July 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	self.attr1			:= _menuDtl.attr1;
	self.extraTableDef	:= _menuDtl.extraTableDef;
	if _parent &lt;&gt; null then
		// need to determine something better here as we can get
		// a null parent when a window is not opened from the navigator
		// or a menu (eg. from dblClick on an object). 
		self.level			:= _parent.getLevel + 1;
	endif;
	self.mainTableDef	:= _menuDtl.mainTableDef;
	self.myMenuDtl		:= _menuDtl;
	
	// Set the following if we can because if this is not set
	// then the window cannot be saved for re-opening on
	// saveSettingsOnExit
	if _parent.isKindOf(CM_MenuUserDtl) then
		self.myMenuUserDtl	:= _parent.CM_MenuUserDtl;
	endif;
	self.myParent		:= _parent;
	self.myTerminal		:= _terminal;
	self.param1			:= _menuDtl.param1;
	
	self.myController	:= app.myController;

end;</source>
        <Parameter name="_menuDtl" type="CM_MenuDtlNav"/>
        <Parameter name="_parent" type="CM_MenuEntity"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
