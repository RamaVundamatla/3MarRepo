begin
	app.initialize();
	beginTransaction;
	if CM_YATypeIsChild.instances.isEmpty() then
		create proxyObj as CM_YATypeIsChild transient;
		proxyObj.setProxy(proxyObj.getTypeName, true, YACriteriaType_IsChild);
		create isChildObj;
		isChildObj.setForCreate(proxyObj);
		delete proxyObj;
	endif;
	commitTransaction;
epilog

end;</source>
