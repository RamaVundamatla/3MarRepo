    <JadeMethod name="setErrorInfo" id="68e2cda4-32f1-4a2d-b700-a1a7a87b13b6">
        <updating/>
        <source>setErrorInfo(_errorStr : String; _state : Integer) updating;
/*
	Created on 01 April 2008
	
	by Debby Hutchison
	
	Purpose:
*/

vars

begin
	errorString := _errorStr;
	guiState	:= _state;
end;</source>
        <Parameter name="_errorStr" type="String"/>
        <Parameter name="_state" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setExtraInfo" id="f17ce68c-c31d-4841-b9a5-c9c4028536db">
        <updating/>
        <source>setExtraInfo(_info : Integer) updating;
/*
	Created on 01 April 2008
	
	by Debby Hutchison
	
	Purpose:
*/

vars

begin
