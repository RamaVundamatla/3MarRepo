        <updating/>
        <source>utlUpdateInvLineChrgMapCopy(_bank : CM_Bank; _newParent : CM_Object; _maps : CM_InvLineChargingMapsDict; _purge : Boolean; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:		Feb 2008 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	
begin

	self.initialiseActivity();

	if _purge then
		_bank.deleteInvoiceLineChargeMapping(_newParent);
