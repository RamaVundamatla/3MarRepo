    <JadeMethod name="calAllocatedAmount" id="ec8e6cb9-e42c-4c17-9037-fb3e5d65aa47">
        <source>calAllocatedAmount() : Real;
//--------------------------------------------------------------
//Created: 26 July 2002 By: cnwgd1
//--------------------------------------------------------------
// 29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
vars
	rtnQty : Real;
	allocation : CM_StockOrderAllocation;
begin

	foreach allocation in self.allStockAllocations do
		rtnQty := rtnQty + allocation.allocQuantity;
	endforeach;

	return rtnQty;
end;</source>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="calAllocatedSoFar" id="e150d35b-6432-4b17-8be7-0329ff2608ae">
        <source>calAllocatedSoFar(): Real;
//--------------------------------------------------------------
//Created: 09 August 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	allocation : CM_StockOrderAllocation;
	numAllocSoFar : Real;
begin

	foreach allocation in self.allStockAllocations do
		numAllocSoFar := numAllocSoFar + allocation.allocQuantity;
	endforeach;
	
	return numAllocSoFar;

end;</source>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="calLineOnlyAllocations" id="5bbc6fc3-2770-47f3-a623-73067cd517e7">
        <source>calLineOnlyAllocations(): Real;
//--------------------------------------------------
// Created:	08 July 2004 By: cnwgd1
//--------------------------------------------------
// 29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
vars
	rtnQty : Real;
	allocation : CM_StockOrderLineAlloc;
begin

	foreach allocation in self.allStockAllocations do
		if allocation.myStockOrderSummaryAlloc = null then
			rtnQty := rtnQty + allocation.allocQuantity;
		endif;
	endforeach;

	return rtnQty;

end;</source>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="callAllocOfRemAll" id="870e2033-1f9b-44e1-aabc-dfbe97ed66af">
        <source>callAllocOfRemAll(_sohLocn : CM_SOHLocation): Real;
//--------------------------------------------------------------
//Created: 09 August 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	allocation : CM_StockOrderAllocation;
	numAllocSoFar : Real;
begin

	foreach allocation in self.allStockAllocations where allocation.mySOHLocation = _sohLocn do
		if allocation.allocType &lt;&gt; allocation.AllocType_Quantity then
			numAllocSoFar := numAllocSoFar + allocation.allocQuantity;
		endif;
	endforeach;
	
	return numAllocSoFar;

end;</source>
        <Parameter name="_sohLocn" type="CM_SOHLocation"/>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="clearAllocatedForSummary" id="7d0193b5-4ed1-4cb1-bb5e-4f86b87f2002">
        <updating/>
        <source>clearAllocatedForSummary() updating;
//--------------------------------------------------------------
//Created: 09 August 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	allocation : CM_StockOrderAllocation;
	event : Integer;
begin

	event := self.myStockOrderHeader.myTerminal.getTerminalEvent(StockOrderAlloc_Delete_Event);
	
	foreach allocation in self.allStockAllocations do
		global.causeEvent(event, false, allocation);									
		delete allocation;
	endforeach;

end;</source>
    </JadeMethod>
    <JadeMethod name="doMatch" id="1849c4df-555b-4ec6-839f-449e2ec53e94">
        <updating/>
        <source>doMatch(_bolOut: CM_BOLOut; _passport: CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     30 April 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	ti					: CM_TrackedItem;
	bolOutOrderLine		: CM_BOLOutStockOrderLineTI;
begin
	
	foreach ti in _bolOut.allTrackedItems do :tiLoop
		if ti.myProduct &lt;&gt; self.myProduct or
		   ti.myBOLOutStockOrderTI &lt;&gt; null then
			continue;
		endif;
	
		//we've found a TI that matches our product - now find a bolOutOrderLine
		//that hasn't yet been filled - 
		foreach bolOutOrderLine in self.allBOLOutStockOrderTIs do : bolOutLineLoop
			if bolOutOrderLine.isFulfilled then
				continue bolOutLineLoop;
			endif;
			
			bolOutOrderLine.setForUpdate(_bolOut, self, ti);
			continue tiLoop;
		endforeach;
	endforeach;

end;</source>
        <Parameter name="_bolOut" type="CM_BOLOut"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getAllocatedLocations" id="670ff92d-1c82-4ba6-b7a7-0a6f1cbe75d2">
        <source>getAllocatedLocations(_locnSet : CM_LCSet input);
//--------------------------------------------------------------
//Created: 19 August 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	allocation : CM_StockOrderAllocation;
begin
	foreach allocation in self.allStockAllocations do
		if (not _locnSet.includes(allocation.myLocationsController)) then
			_locnSet.add(allocation.myLocationsController);
		endif;
	endforeach;
end;</source>
        <Parameter name="_locnSet" type="CM_LCSet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="312110f2-9f25-4798-8430-9d3e48454d82">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
// ---------------------------------------------------------------------------
// Created:     28 June 2002 by cnwth2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if _attrName = ETRow_MyCargoType then
		if self.myProduct &lt;&gt; null then
			return self.myProduct.myCargoType.description;
		else
			return null;
		endif;
	elseif _attrName = ETRow_AllocVolume then
		return self.calAllocatedAmount().roundedUp.String;		
	
	elseif _attrName = ETRow_Id then
		return 'N/A';
		
	elseif _attrName = ETRow_LineType then
		return StockOrderLine_Product_Descr;
	
	elseif _attrName = ETRow_MyOperator then
		if self.myProduct &lt;&gt; null then
			return self.myProduct.getDisplayStringForAttribute(_attrName, _short);
		else
			return null;
		endif;
	
	elseif _attrName = ETRow_MyProduct then	
		if self.myProduct &lt;&gt; null then
			return self.myProduct.code;
		else
			return null;
		endif;
		
	elseif _attrName = ETRow_ProductDescription then
		if self.myProduct &lt;&gt; null then
			return self.myProduct.description;
		else 
			return null;
		endif;
	 
	elseif _attrName = ETRow_RequiredID then //returns quantity if product line, or TI id if TI line type
		return self.reqdQuantity.Integer.String;
	
	endif;
	 	 
	return inheritMethod(_attrName, _short);

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getErrorString" id="b8922828-0822-4d4b-aa84-9875543ed12c">
        <source>getErrorString(): String;
//--------------------------------------------------------------
//Created: 08 July 2002 By: cnwsb1
