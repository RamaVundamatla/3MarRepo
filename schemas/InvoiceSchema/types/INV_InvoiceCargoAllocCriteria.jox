    <JadeMethod name="initialiseMSG" id="0ed325bc-7496-4743-81a6-c8bebd977981">
        <source>initialiseMSG();
/*
Purpose:			
Date		Who		Reason
11 March 2015	cnwab1	Initial creation
*/

vars

begin
	self.msgCriteria.userInputEnabled 			:= true;
	self.msgCriteria.availableHeading := app.getErrorString(Available_attributes);
	self.msgCriteria.selectedHeading := app.getErrorString(Selected_attributes);
	self.msgCriteria.caption := "";
	self.msgCriteria.formDisplayEntryMethodName 	:= INV_InvoiceCargoAllocCriteria::displayCriteria.name;
	self.msgCriteria.displayOrderBtns(true, false);
	self.msgCriteria.multiSelect					:= ListBox.MultiSelect_Extended;
	self.msgCriteria.myAvailableListBox.sorted 	:= true;		
	self.msgCriteria.mySelectedListBox.sorted 	:= false;
	self.msgCriteria.setTabIndex();
	self.msgCriteria.displayAddRemoveBtns(true, false);		
	self.msgCriteria.myBaseForm := self;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="populateDebtorCombo" id="a97e8776-c3bf-4d72-bf7b-8fcfbe4e8dce">
        <updating/>
        <source>populateDebtorCombo() updating;


vars
	indx	: Integer;
	dt, savedDT : CM_DebtorType;
	oa		: ObjectArray;
	obj		: Object;
	
	qp		: CM_YACriteriaType;
	allGroupProps : CM_QueryPropertyArray;

begin
	create oa transient;
	self.msgCriteria.getSelected( oa );
	if oa.size = 0 then
		self.msgCriteria.getAvailable( oa );
	endif;
	
	if self.cmbDebtorType.listIndex &gt; 0 then
		savedDT := self.cmbDebtorType.itemObject[self.cmbDebtorType.listIndex].CM_DebtorType;
	endif;

	self.cmbDebtorType.clear();
	
	
	foreach obj in oa do
		qp := obj.CM_YACriteriaType;
		dt := null;
		
		if qp.type = YACriteriaType_OperatorItem then
			dt := app.myRoot.allDebtorTypes["SDT1"];
		elseif qp.type = YACriteriaType_Consignee then
			dt := app.myRoot.allDebtorTypes["SDT2"];
		elseif qp.type = YACriteriaType_Consignor then
			dt := app.myRoot.allDebtorTypes["SDT3"];
		elseif qp.type = YACriteriaType_FreightForward then
			dt := app.myRoot.allDebtorTypes["SDT7"];
		elseif qp.type = YACriteriaType_Carrier then
			dt := app.myRoot.allDebtorTypes["SDT9"];
		endif;	
		if dt &lt;&gt; null then
			self.cmbDebtorType.addItemObject(dt.description, dt);
		endif;
	endforeach;
	
	// restore any previous selection, if still present
	if self.myCurrentTransactionMap &lt;&gt; null then  // ### TFS 51219 25MAY2021 NAVAB1
		dt := self.myCurrentTransactionMap.myInvoiceAllocationConfig.myDebtorTypeForDerivation; // ### TFS 51219 25MAY2021 NAVAB1
	elseif self.myCurrentTanMapInventory &lt;&gt; null then
		dt := self.myCurrentTanMapInventory.myInvoiceAllocationConfig.myDebtorTypeForDerivation; // ### TFS 51219 25MAY2021 NAVAB1
	endif;
	
	
	
	
	if dt &lt;&gt; null then
		indx := self.cmbDebtorType.findObject(dt);
		if indx &gt; 0 then
			self.cmbDebtorType.listIndex := indx;
		endif;
	endif;
	
	if savedDT &lt;&gt; null then
		indx := self.cmbDebtorType.findObject(savedDT);
		if indx &gt; 0 then
			self.cmbDebtorType.listIndex := indx;
		endif;
	endif;
	
	// if only one entry, select it
	if self.cmbDebtorType.listCount = 1 then
		self.cmbDebtorType.listIndex := 1;
	endif;
epilog
	delete oa;
end;</source>
    </JadeMethod>
    <JadeMethod name="populateMSG" id="354282b9-3924-4938-816c-786c6f3d3d05">
        <source>populateMSG();
/*
Purpose:			
Date		Who		Reason
11 March 2015	cnwab1	Initial creation
26/04/2016  	cnwma1  PAR #36914 TFS1768 Communicating/NonCommunciating Reefer Yard Allocation Criteria
*/

vars
	criteriaTypes: ObjectArray;
	criteria : CM_YACriteriaType;
begin
	
	/*  // ### TFS 51219 25MAY2021 NAVAB1 - Refactored
	create criteriaTypes transient;
	foreach criteria in app.myRoot.allYACriteriaTypes discreteLock do
		if not criteria.isUsed then		//26/04/2016 cnwma1 PAR #36914 TFS1768 
			continue;
		endif;
		if criteria.isForCargo() then
			criteriaTypes.add(criteria);
		endif;
 
	endforeach;
*/
	
	
	
 // ### TFS 51219 25MAY2021 NAVAB1	self.msgCriteria.setAvailable(criteriaTypes, true); 
	
	if self.myCurrentTransactionMap &lt;&gt; null then  // ### TFS 51219 25MAY2021 NAVAB1
		criteriaTypes := self.myCurrentTransactionMap.getYACriteriaTypes(); // ### TFS 51219 25MAY2021 NAVAB1
		self.msgCriteria.setAvailable(criteriaTypes, true);  // ### TFS 51219 25MAY2021 NAVAB1
		self.msgCriteria.setSelected(self.myCurrentTransactionMap.myInvoiceAllocationConfig.allOpCriteria);
	elseif self.myCurrentTanMapInventory &lt;&gt; null then // ### TFS 51219 25MAY2021 NAVAB1
		criteriaTypes := self.myCurrentTanMapInventory.getYACriteriaTypes(); // ### TFS 51219 25MAY2021 NAVAB1
		self.msgCriteria.setAvailable(criteriaTypes, true);  // ### TFS 51219 25MAY2021 NAVAB1
		self.msgCriteria.setSelected(self.myCurrentTanMapInventory.myInvoiceAllocationConfig.allOpCriteria); // ### TFS 51219 25MAY2021 NAVAB1
	endif;
	
	
	self.msgCriteria.setFocus();
epilog
	delete criteriaTypes;
end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="c204e927-82c0-456f-b275-74bb58f9e7aa">
        <updating/>
        <source>setupForm() updating;
/*
Purpose:			
Date		Who		Reason
11 March 2015	cnwab1	Initial creation
04/05/2023	navkc1	Bug 57484: EUP - Cargo Allocation Transaction Map Permissions
*/

vars
	caption : String;
	tranmap : CM_Object;
begin
	inheritMethod();
	
	 // ### TFS 51219 25MAY2021 NAVAB1
	if self.myCurrentTransactionMap &lt;&gt; null then
		caption := self.myCurrentTransactionMap.description &amp; " - " &amp; app.getErrorString(Cargo_invoice_allocation);
		tranmap := self.myCurrentTransactionMap;
	elseif self.myCurrentTanMapInventory &lt;&gt; null then
		caption := self.myCurrentTanMapInventory.description &amp; " - " &amp; app.getErrorString(Inventory_allocations);
		tranmap := self.myCurrentTanMapInventory;
	endif;
	
	self.setCaption(caption); // ### TFS 51219 25MAY2021 NAVAB1

	
//	self.setCaption(self.myCurrentTransactionMap.description &amp; " - Cargo Invoice Allocation");
	
	initialiseMSG();
	populateMSG();
	populateDebtorCombo();
	
	self.lblDebtorType.visible := false;
	self.cmbDebtorType.visible := false;
	
	// 04/05/2023	navkc1	Bug 57484
	self.doNoMaintPermDisableControls();
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="c3d232ca-a43f-4e31-8ff7-9bf81dab049e">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 12 March 2015.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0020297, locale);
	btnClose.translateCaption(Xlat_0020298, locale);
	btnSave.translateCaption(Xlat_0020299, locale);
	lblDebtorType.translateCaption(Xlat_0020300, locale);
	msgCriteria.translateCaption(Xlat_0020301, locale);
end;</source>
    </JadeMethod>
