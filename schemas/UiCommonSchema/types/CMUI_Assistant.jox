    <JadeMethod name="showPackagingBulkForm" id="59f91ba4-8901-4c4f-b3b6-71ca4e793e25">
        <source>showPackagingBulkForm( _ti : CM_TrackedItem );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 April 2014	cnwndl1	Initial creation

*/

vars

	form : CMUI_PackagingBulkForm;
	msg : String;

begin

	if _ti = null then
		msg := app.getErrorString(No_Cargo_selected);
	elseif not _ti.canSplitTotalQuantity then
		msg := app.getErrorString(No_split_cargo_not_BB);
	elseif not _ti.isOnSite then	//14 Jun 2013	NDL	Par 31826
		msg := app.getErrorString1(ERR_TI_NOT_ONSITE,_ti.id);
	endif;
	if msg &lt;&gt; null then
		app.msgBox(msg,app.getErrorString(Error),MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
		return;
	endif;

	form := app.loadForm(CMUI_PackagingBulkForm, CMUI_Assistant, false, false, true, self.myTerminal, null).CMUI_PackagingBulkForm;
	if form = null then
		return;
	endif;	
	
	if form.setMyTrackedItem(_ti) then
		form.showModal();
	endif;

epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="showPhotosForm" id="32c6784b-6831-4015-828b-89875b797070">
        <source>showPhotosForm(	_ti : CM_TrackedItem input; 
				_hazardClass : CM_HazardClass input;						// PAR #36421
				_terminalArea : CM_TerminalArea;
				_visit			: CM_VehicleVisitRecord;	
				_allTransientPhotos : ObjectArray input;
				_masterMenuAction : CMUI_MenuAction);
/*

Date		Who		Reason
24/10/2013	cnwer1	Initial creation PAR 31845
15/06/2015	cnwdap1	PAR #36421 Hazardous Materials Handling
05 Dec 2024 navlc30 JIRA 33478 Match functionality in the thin client for Damage Recording Improvement
08 Aug 2025	navhl20 Story MTN-35650: TPT | Uploading of Photos into MTN Production | 2 | Thin Client Changes
*/

vars

	photoForm : CMUI_CargoPhotosForm;
	user : CM_User;							// PAR #36421
	terminal : CM_Terminal;					// PAR #36421
	showModal : Boolean;

begin	
	//if _ti = null and  (_allTransientPhotos = null)then							// PAR #36421
	if _ti = null 
	and _hazardClass = null 
	and _allTransientPhotos = null	// PAR #36421
	and _terminalArea = null	// ### TFS CR 58499 TASK 61459 28DEC2023 NAVAB1
	and _visit = null then															//08.08.2025 navhl20 #35650
		return;
	endif;
	
	if self.myTerminal = null then													// PAR #36421
		user := app.getMyUser();													// PAR #36421
		terminal := user.allUserTerminals.first.myTerminal;							// PAR #36421
	else																			// PAR #36421
		terminal := self.myTerminal;												// PAR #36421
	endif;																			// PAR #36421
	
	if _masterMenuAction &lt;&gt; null and _masterMenuAction.myForm &lt;&gt; null then			//05.12.2024 navlc30 #33478
		if _masterMenuAction.myForm.name = "CMUI_DamageCodesAdvanceForm" or 			
		_masterMenuAction.myForm.name = "CMUI_DamageCodesForm" then
			showModal := true;
		endif;
	endif;
	
	if _allTransientPhotos &lt;&gt; null  or showModal then
		photoForm := app.loadForm(CMUI_CargoPhotosFormModal, 
							CMUI_Assistant, 
							false, 
							false,
							true, 
							//self.myTerminal,										// PAR #36421
							terminal,												// PAR #36421
							_masterMenuAction).CMUI_CargoPhotosForm;	
	// ### TFS CR 58499 TASK 61459 28DEC2023 NAVAB1
	elseif _terminalArea &lt;&gt; null then
		photoForm := app.loadForm(CMUI_TerminalAreaPhoto, 
							CMUI_Assistant, 
							false, 
							false,
							false, 
							terminal, 
							_masterMenuAction).CMUI_TerminalAreaPhoto;		
	else
		
		photoForm := app.loadForm(CMUI_CargoPhotosForm, 
							CMUI_Assistant, 
							false, 
							false,
							false, 
							//self.myTerminal,										// PAR #36421
							terminal, 												// PAR #36421
							_masterMenuAction).CMUI_CargoPhotosForm;	
	endif;
	if photoForm = null then
		return;
	endif;
	
	if _ti &lt;&gt; null then
		photoForm.myTrackedItem := _ti;
		photoForm.caption := "Photos For " &amp; _ti.id ;
		if showModal then															//05.12.2024 navlc30 #33478
			photoForm.showModal;
		else
			photoForm.show;
		endif;
	// ### TFS CR 58499 TASK 61459 28DEC2023 NAVAB1
	elseif _terminalArea &lt;&gt; null then
		photoForm.CMUI_TerminalAreaPhoto.myTerminalArea := _terminalArea;
		photoForm.caption := "Photos For " &amp; _terminalArea.id ;
		photoForm.show;	
	elseif _hazardClass &lt;&gt; null then								// PAR #36421
		photoForm.myHazardClass := _hazardClass;					// PAR #36421
		photoForm.caption := "Symbols For " &amp; _hazardClass.code;	// PAR #36421
		photoForm.show;												// PAR #36421
	elseif _visit &lt;&gt; null then										//08.08.2025 navhl20 #35650
		photoForm.myVisit := _visit;
		photoForm.caption := "Photos For " &amp; _visit.visitNumber ;
		photoForm.show;	
	else
		_allTransientPhotos.copy(photoForm.allPhotos);
		photoForm.showModal;
		_allTransientPhotos.clear;
		photoForm.allPhotos.copy(_allTransientPhotos);
	endif;
		

epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_hazardClass" type="CM_HazardClass" usage="input"/>
        <Parameter name="_terminalArea" type="CM_TerminalArea"/>
        <Parameter name="_visit" type="CM_VehicleVisitRecord"/>
        <Parameter name="_allTransientPhotos" type="ObjectArray" usage="input"/>
        <Parameter name="_masterMenuAction" type="CMUI_MenuAction"/>
    </JadeMethod>
    <JadeMethod name="showPrenoteForm" id="111463cb-9746-4af5-99ee-776db025a926">
        <source>showPrenoteForm(_object : CM_Object; _masterMenuAction : CMUI_MenuAction;
				_thumbnailOnly, _doEdit : Boolean);
//--------------------------------------------------------------
//Created: June 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	prenoteFrm : CM_TableViewForm;
	menuAction : CMUI_MenuAction;
begin

	menuAction := app.myController.createMenuAction(PmGtePreNoteView, _object, _masterMenuAction, self.myTerminal);
	if menuAction = null then
		return;
	endif;
	
	prenoteFrm := menuAction.goToObject(null, null, false, null).CM_TableViewForm;
	if prenoteFrm = null then
		return;
	endif;

	if _object &lt;&gt; null then
		prenoteFrm.showWithObject(_object, _thumbnailOnly, _doEdit);
	else
		prenoteFrm.show();
	endif;

end;</source>
        <Parameter name="_object" type="CM_Object"/>
        <Parameter name="_masterMenuAction" type="CMUI_MenuAction"/>
        <Parameter name="_thumbnailOnly" type="Boolean"/>
        <Parameter name="_doEdit" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="showPrenoteFormForVoyage" id="7e409f5c-2d6e-44fa-94fe-23f2d9fc27a3">
        <updating/>
        <source>showPrenoteFormForVoyage(_voyage : CM_Voyage; _masterMenuAction : CMUI_MenuAction) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 07/01/2015	cnwdap1		Initial creation PAR #35397 CCMSFW 1394 Voyage Rationalisation
//
vars
	theForm		: Form;
	theClass 	: Class;
	assistClass : Class;
	jrw 		: Schema;
	prenote		: CM_TrackedItem;
	numItems	: Integer;
	menuAction	: CMUI_MenuAction;
	
begin
	jrw 		:= rootSchema.getSchema("GateSchema");
	theClass 	:= jrw.getClass("GTE_PreNoteForm");
	assistClass := jrw.getClass("GTE_Assistant");
	
	theForm := app.loadForm(theClass, assistClass, false, false, true, self.myTerminal, _masterMenuAction);
	if theForm = null then
		return;
	endif;
	
	if _masterMenuAction &lt;&gt; null then
		menuAction := _masterMenuAction;
		menuAction.setPropertyValue("myFormWhenMaster", theForm);
	endif;
	
	theForm.show;
	theForm.setPropertyValue("isFirstActivateComplete", true);
	if _voyage &lt;&gt; null then
		foreach prenote in _voyage.allNotifiedTIsByIdCargoType discreteLock do
			theForm.sendMsgWithParams("addPreNote", prenote);
		endforeach;
	endif;
	theForm.setPropertyValue("viewTransportMode", app.getErrorString(View_Additions));
	theForm.sendMsgWithParams("zGetDataForTable", null);
epilog

end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_masterMenuAction" type="CMUI_MenuAction"/>
    </JadeMethod>
    <JadeMethod name="showPrintScanPlan" id="82afba88-79db-42fd-8ca3-beea02d3a097">
        <source>showPrintScanPlan(	_caller : CM_BaseForm; 	
					_voyage : CM_Voyage input;
					_selectedHolds : CM_HoldByOrdinalDict;
					_selectedBays : CM_BayVoyageByOrdinalBayDict;
					_displayMode : Integer;
					_colourMode : Integer
					);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 September 2020	jlgndl1	Initial creation	TFS 49963

*/

vars

	scanPlanReportForm : CMUI_ScanPlanReportForm;
	selectedBays : CM_BayVoyageByIdDict;
	hold : CM_Hold;
	bay : CM_Bay;

begin

	create selectedBays transient;
	if _selectedHolds &lt;&gt; null and not _selectedHolds.isEmpty then
		foreach hold in _selectedHolds do
			foreach bay in hold.allBays where bay.isKindOf(CM_BayVoyage) do
				selectedBays.addNoDuplicates( bay.CM_BayVoyage, false );
			endforeach;
		endforeach;
	endif;
	
	if _selectedBays &lt;&gt; null and not _selectedBays.isEmpty then
		foreach bay in _selectedBays where bay.isKindOf(CM_BayVoyage) do
			selectedBays.addNoDuplicates( bay.CM_BayVoyage, false );
		endforeach;
	endif;

	scanPlanReportForm := app.loadForm(CMUI_ScanPlanReportForm, CMUI_Assistant, false, false, true, self.myTerminal, null).CMUI_ScanPlanReportForm;
	scanPlanReportForm.setFromCaller( _caller, _voyage, selectedBays, _displayMode, _colourMode );
	
	scanPlanReportForm.showModal();
	
epilog

	delete selectedBays;

end;</source>
        <Parameter name="_caller" type="CM_BaseForm"/>
        <Parameter name="_voyage" type="CM_Voyage" usage="input"/>
        <Parameter name="_selectedHolds" type="CM_HoldByOrdinalDict"/>
        <Parameter name="_selectedBays" type="CM_BayVoyageByOrdinalBayDict"/>
        <Parameter name="_displayMode" type="Integer"/>
        <Parameter name="_colourMode" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="showProductForm" id="5cbcc5bd-fbf3-45fa-a2fe-168c7269361f">
        <source>showProductForm(_cargoType : CM_CargoType; _masterMenuAction : CMUI_MenuAction);
// ---------------------------------------------------------------------------
// Created:     08 February 2006	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars
	productFrm : CM_TableViewForm;
	menuAction : CMUI_MenuAction;
begin

	menuAction := app.myController.createMenuAction(PmGCProductView, null, _masterMenuAction, self.myTerminal);
	if menuAction = null then
		return;
	endif;
	
	productFrm := menuAction.goToObject(null, null, false, null).CM_TableViewForm;

	if productFrm = null then
		return;
	endif;
	
	if _cargoType &lt;&gt; null then
		productFrm.showWithObject(_cargoType, false, false);
	else
		productFrm.show();
	endif;

end;</source>
        <Parameter name="_cargoType" type="CM_CargoType"/>
        <Parameter name="_masterMenuAction" type="CMUI_MenuAction"/>
    </JadeMethod>
