    <JadeMethod name="getCargoCountAmount" id="2431b7dc-254c-4b49-9ebf-a509f2a22345">
        <source>getCargoCountAmount(count : Integer io; ti : CM_TrackedItem input; _fm : CM_FutureMove);
/*

Purpose:		// TFS 49523	

Parameters:			

Return Value:		

Date		Who		Reason
04 June 2020	jlgab1	Initial creation

*/

vars

begin
	   if self.myWagonClass.numOfTwenty = CM_BoxcarVisit.BoxcarGraphicBulk then
			if ti.myCargoType.allowDuplicates 
	//		and _fm &lt;&gt; null then
			and _fm &lt;&gt; null and _fm.myWorkListEntry &lt;&gt; null then //02 Dec 2020	NDL	TFS 50164
				count := count + _fm.myWorkListEntry.weight.Integer;
			else
				count := count + ti.totalWeight.Integer;
			endif;
			
		elseif self.myWagonClass.numOfTwenty = CM_BoxcarVisit.BoxcarGraphicTransporter
		or self.myWagonClass.numOfTwenty = CM_BoxcarVisit.BoxcarGraphicBreakBulk then 
			if ti.myCargoType.allowDuplicates 
		//	and _fm &lt;&gt; null then
			and _fm &lt;&gt; null and _fm.myWorkListEntry &lt;&gt; null then //02 Dec 2020	NDL	TFS 50164
				count := count + _fm.myWorkListEntry.quantity;
			else
				count := count + ti.totalQuantity;
			endif;
		endif;
	

end;
</source>
        <Parameter name="count" type="Integer" usage="io"/>
        <Parameter name="ti" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_fm" type="CM_FutureMove"/>
    </JadeMethod>
    <JadeMethod name="getCargoCountForBoxcarGraphic" id="a7f065ba-2e7d-499d-8025-dad56595f20b">
        <source>getCargoCountForBoxcarGraphic( _displayMode : Integer ):Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 August 2013	cnwndl1	Initial creation	Par 32174

*/

vars

	wc : CM_WagonController;
	ti : CM_TrackedItem;
	tiArray : CM_TIArray;
	invalidTI : Boolean;
	edition : Integer;
	fm : CM_FutureMove;
	invalidFM : Boolean;
	count : Integer;
	countRounded : Decimal [23,0];
begin

	on Exception do app.handleDeletedObject(exception, ti, invalidTI);

	//wc := self.allLocationsControllers.first.CM_WagonController;
	wc := self.allLocationsControllersArray[1].CM_WagonController;	//04 Dec 2014	NDL	Par 35345
	create tiArray transient;

	if _displayMode = DISPLAY_MODE_ACTUAL then
		foreach ti in wc.allTrackedItems discreteLock do
			invalidTI := false;
			edition := ti.edition;
			if invalidTI then
				continue;
			endif;
			if (not tiArray.includes(ti)) then
				tiArray.add(ti);
				// TFS 49523 count := count + ti.totalQuantity;
				self.getCargoCountAmount(count, ti, null); // TFS 49523
			endif;
		endforeach;
					
	elseif _displayMode = DISPLAY_MODE_QUEUE then
		on Exception do app.handleDeletedObject(exception, fm, invalidFM);
		foreach fm in wc.allQueuedFutureMoves discreteLock do
			invalidFM := false;
			ti := fm.CM_FutureMoveQueued.myTrackedItem;
			if invalidFM or ti = null then
				continue;
			endif;
			invalidTI := false;
			edition := ti.edition;
			if invalidTI then
				continue;
			endif;
			if (not tiArray.includes(ti)) then
				tiArray.add(ti);
				// TFS 49523 count := count + ti.totalQuantity;
				self.getCargoCountAmount(count, ti, fm); // TFS 49523
			endif;
		endforeach;
				
	elseif _displayMode = DISPLAY_MODE_PLAN then
		on Exception do app.handleDeletedObject(exception, fm, invalidFM);
		foreach fm in wc.allPlannedFutureMoves discreteLock do
			invalidFM := false;
			ti := fm.CM_FutureMovePlanned.myTrackedItem;
			if invalidFM or ti = null then
				continue;
			endif;
			invalidTI := false;
			edition := ti.edition;
			if invalidTI then
				continue;
			endif;
			if (not tiArray.includes(ti)) then
				tiArray.add(ti);
				// TFS 49523 count := count + ti.totalQuantity;
				self.getCargoCountAmount(count, ti, fm); // TFS 49523
			endif;
		endforeach;
				
	endif;

	if self.myWagonClass.numOfTwenty = CM_BoxcarVisit.BoxcarGraphicBulk then // TFS 49523 do at end so no rounding on each cargo item
		countRounded := (count / 1000);
		
		return countRounded.rounded().Integer;// TFS 49523
	else
		return count;
	endif;
	
epilog

	delete tiArray;

end;</source>
        <Parameter name="_displayMode" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
