    <JadeMethod name="utlDeleteEDIBookingRef" id="2ef73136-75f2-46c0-bea7-d7d2271bb425">
        <source>utlDeleteEDIBookingRef(_bookingRef : CM_BookingRef; _extraInfo : String; _passport : CM_Passport input);
//
//13 May 2015	cnwrs1	Par 36099 - never create an error when deleting EDI booking ref
// 27/06/2018	cnwma1		Bug 39441: Getting 1090 when searching for work orders
//
vars
	toDelete:CM_BookingRef;
begin
	self.initialiseActivity();
	toDelete := _bookingRef;
	
	if not self.exclusiveLockObjectToDelete(toDelete) then
	    // toDelete is null, invalid or has already been deleted
	    return;
	endif;
	toDelete.validateForDelete(); // 27/06/2018	cnwma1		Bug 39441
	if _passport.noErrors then
		if _extraInfo &lt;&gt; null then
			self.myDeleteAuditAgent.audDeleteGenericWithExtraInfo(toDelete, _extraInfo);
		else
			self.myDeleteAuditAgent.audDeleteGeneric(toDelete);
		endif;
	endif;

	if _passport.noErrors then
		toDelete.handleOpsView(BGP_OpsViewWSRequest.OPS_ACTION_DELETE); // ### TFS 53105 31MAY2022 NAVAB1

		toDelete.erase(NORMAL_ERASE);
	endif;
epilog
	return;

end;</source>
        <Parameter name="_bookingRef" type="CM_BookingRef"/>
        <Parameter name="_extraInfo" type="String"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
