    <JadeMethod name="doTblDataDragOver" id="650eae9b-38ad-429b-a587-5a208179a041">
        <updating/>
        <source>doTblDataDragOver(table: Table input; win: Window input; x: Real; y: Real; state: Integer) updating;
// ---------------------------------------------------------------------------
// Created:		May 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	diffX, diffY		: Real;
	rowInc, left, top	: Integer;
	
begin
//	inheritMethod(table, win, x, y, state);

	if self.useCtrlScroll then
		rowInc := ( (self.tblData.rows * 18) / self.tblData.clientHeight).Integer;
		
		if rowInc &lt; 1 then
			rowInc := 1;
		endif;
		
		if app.isControlKeyDown()
		and not app.isAltKeyDown()
		and not app.isShiftKeyDown()
		then
			diffX := x - self.origXPos;
			diffY := y - self.origYPos;
			self.origXPos := x;
			self.origYPos := y;
			
			if diffX &lt; 0 then
				left := self.tblData.leftColumn - 1;
				if left &lt; 1 then 
					left := 1;
				endif;
			else
				left := self.tblData.leftColumn + 1;
				if left &gt; self.tblData.columns then 
					left := self.tblData.columns;
				endif;
			endif;
			if diffY &lt; 0 then
				top := self.tblData.topRow - rowInc;
				if top &lt; 1 then
					top := 1;
				endif;
			else
				top := self.tblData.topRow + rowInc;
				if top &gt; self.tblData.rows then
					top := self.tblData.rows;
				endif;
			endif;
	//app.writeStatement( "AKB " &amp; self.class.name &amp; "::" &amp; method.name &amp; " 1. self.origXPos: " &amp; self.origXPos.String &amp; " self.origYPos: " &amp; self.origYPos.String
	//						&amp; " X: " &amp; x.String &amp; " Y: " &amp; y.String &amp; " diffX: " &amp; diffX.String &amp; " diffY: " &amp; diffY.String
	//						&amp; " left: " &amp; left.String &amp; " top: " &amp; top.String &amp; " leftCol: " &amp; self.tblData.leftColumn.String 
	//							&amp; " topRow: " &amp; self.tblData.topRow.String);		
			self.tblData.leftColumn := left;
			self.tblData.topRow := top;
		endif;
	endif;
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="win" type="Window" usage="input"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
        <Parameter name="state" type="Integer"/>
    </JadeMethod>
