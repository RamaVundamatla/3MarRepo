<Class name="SOPTM_DataAccessCustomsAgent" id="c13fa423-c73d-47f9-a301-957a2e4b3b7b">
    <superclass name="SOPTM_DataAccess"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="sysops"/>
    <JadeMethod name="create" id="6606091f-aad5-49b3-96c9-ee73b07a423b">
        <updating/>
        <source>create() updating;

vars

begin
	self.name := SOP_TableMaintForm.Table_DataAccessCustomsAgents;
	// TEMP or for real reuse the consignee permissions ...
	self.permissionView	 := PmCmpDAConsigneeOrTableView;
	self.permissionMaint := PmCmpDAConsigneeOrTableMaint;

end;
</source>
    </JadeMethod>
    <JadeMethod name="getMultiGroupHeading" id="4d05ce17-93a5-42c1-a3b7-f8d9a06db9b3">
        <source>getMultiGroupHeading(): String;

vars

begin
	return 'Customs Agents';
end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setupThumbnailDetails" id="7439813f-25d8-41a1-89c7-072ba965c4ec">
        <source>setupThumbnailDetails();

vars
	theForm : SOP_TableMaintForm;

begin
  
	theForm := self.myForm;
	theForm.setupForDataAccessController('Customs Agents', SOP_TableMaintForm::displayEntryCustomsAgent.name, CM_CustomsAgent);
	theForm.mulSelect1.setAvailable(app.myRoot.allCustomsAgents, true);

end;</source>
    </JadeMethod>
    <JadeMethod name="showThumbnail" id="ff241038-40ea-42fe-98dd-0c2ef33830ae">
        <updating/>
        <source>showThumbnail(pDataAccess : CM_DataAccessController) updating;

vars

	theForm : SOP_TableMaintForm;

begin

    theForm := self.myForm;
  	theForm.chkIncludeNotSet.visible := true;
    theForm.myDataAccessClass := CM_CustomsAgent;
	theForm.shtMultiSelect1.caption := "Customs Agents";
	theForm.chkIncludeNotSet.value := pDataAccess.includeIfNull;
	theForm.txtName.text := pDataAccess.name;
	theForm.optAllow.value	:= (not pDataAccess.mustNotBeIncluded);
	theForm.optDisallow.value := pDataAccess.mustNotBeIncluded;
	theForm.setMSHeadingsForDataAccess();
    theForm.mulSelect1.setSelected(pDataAccess.allObjects);
	self.disableMulSelect1Contents();
end;</source>
        <Parameter name="pDataAccess" type="CM_DataAccessController"/>
    </JadeMethod>
    <JadeMethod name="tblDataDisplayRow" id="076955df-dd9a-4a5a-b42e-434d8dab210e">
        <source>tblDataDisplayRow(table: Table input; obj: Object): String;

vars

begin
	if obj.CM_DataAccessController.classContainedName = CM_CustomsAgent.name then
		return inheritMethod(table, obj);
	else
		return null;
	endif;

end;
</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="obj" type="Object"/>
        <ReturnType type="String"/>
    </JadeMethod>
</Class>
