    <JadeMethod name="trxUpdateLoggingOrganisation" id="05cdc84d-7c73-4600-950c-8f8c7bc92f0c">
        <updating/>
        <source>trxUpdateLoggingOrganisation(pProxyLogOrg:CM_LoggingOrganisation; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	realLogOrg:CM_LoggingOrganisation;
	expectedEdition:Integer;

begin

	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(false);

	beginTransaction;

	pProxyLogOrg.raiseExceptionIfNotProxy(method);

	app.setContinueCMExceptions(true);

	pProxyLogOrg.pxyGetRealObjectAndEdition(realLogOrg, expectedEdition);
	
	if realLogOrg = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_LoggingOrganisation.name, null, null);
		return;
	endif;

	self.raiseExceptionIfNull(pProxyLogOrg, 'Log Condition Code Proxy');
	self.raiseExceptionIfNull(realLogOrg, "Log Condition Code Existing");
	pProxyLogOrg.raiseExceptionIfNotProxy(method);
	if realLogOrg.code = pProxyLogOrg.code then
		pProxyLogOrg.validateForUpdate();
	else
		pProxyLogOrg.validateForCreate();
	endif;
	
	if (not self.checkValidationWithPassport(_passport)) then
		return;		// note that this gets "ignored" in the eplog
	endif;


	app.setContinueCMExceptions(false);

	exclusiveLock(realLogOrg);

	if _passport.noErrors and realLogOrg.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'Log Condition Code', null, null);
		return;
	endif;
	
	if _passport.noErrors then
		app.myUtilityUA.myUpdateAuditAgent.audUpdateGeneric(realLogOrg, true);
	endif;
	
	if _passport.noErrors then
		realLogOrg.setForUpdate(pProxyLogOrg);
	endif;

	if _passport.noErrors then
		app.myUtilityUA.myUpdateAuditAgent.audUpdateGeneric(realLogOrg, false);
	endif;

epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="pProxyLogOrg" type="CM_LoggingOrganisation"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxUpdateLogoff" id="a31a26c5-e1cc-4403-8723-0ee29facf065">
        <updating/>
        <source>trxUpdateLogoff(_machine : CM_Machine input; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     Logoff a user.  
//
// Changed On	By			Reason
// 18/07/2025	navdap1		MTN-34430 MTN - Deferred Updates For Event Required For Login and Logout Trxs
// ---------------------------------------------------------------------------
vars
	
begin

	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);
	
	app.setContinueCMExceptions(false);
	
	_passport.useEventDeferUpdate := true;		// MTN-34430
	
	beginTransaction;
	
	_passport.recordLogoffEvent(_machine);		// MTN-34430
	
	if _machine &lt;&gt; null then
		process.changeUserCode( process.signOnUserCode ); //23 Jul 2021	NDL	TFS 49955
		_machine.executeLogoff;	
	endif;
	
	if _passport.noErrors then					// MTN-34430
		_passport.doDeferredUpdates();			// MTN-34430
	endif;										// MTN-34430
	
epilog
	self.finaliseActivityWithPassport(_passport);
	
end;</source>
        <Parameter name="_machine" type="CM_Machine" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxUpdateLogon" id="04eef801-0bb7-4181-bf61-c4402c95f4e8">
        <updating/>
        <source>trxUpdateLogon(_userCode : String; _userPassword : String; _machineToIgnore : CM_Machine;  _passport : CM_Passport io) : Integer updating;
/* ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     Login a user.  Always delete and recreate the passport.
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 15/11/2005	cnwdad1		Changed password encryption to use a new method
//							rather than the old DLL library.
//
// 10/07/2008	cnwdad1		PAR #17506. This transaction was not checking for
//							errors after performing each function, hence errors
//							were occuring (such as after a lock exception).
// 08/02/2011	cnwer1  	PAR 26908 - now passing in machine = null to utlUpdateLogon
// 21/06/2011	cnwrs1		CCMS1150 - Change JMT to enable logon SDS Secondary database
// 28/09/2022	navmd1		TFS 54959 Added additional exception handler to dump the stack
							when a JADE exception (eg, 1090) occurs
// 05/03/2024	jlier1 		TFS 62428 - Vehicle Apps logging on to Cargo Apps have to ignore the machine they are logged on to
// 18/07/2025	navdap1		MTN-34430 MTN - Deferred Updates For Event Required For Login and Logout Trxs
// ---------------------------------------------------------------------------*/
vars
	result 		: Integer;
begin
	_passport	:=	app.createPassport();	// This deletes and recreates

	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do dumpStackExHandler(exception);		// TFS 54959 navmd1 28/09/2022
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);
	
	app.setContinueCMExceptions(false);
	
	_passport.useEventDeferUpdate := true;		// MTN-34430
	
	beginTransaction;	// CCMS1150 cnwrs1 21 June 2011

	result := app.myUtilityUA.utlUpdateLogon(_userCode, _userPassword, null, _machineToIgnore, _passport);
	
	if _passport.noErrors then					// MTN-34430
		_passport.doDeferredUpdates();			// MTN-34430
	endif;										// MTN-34430
epilog

	self.finaliseActivityWithPassport(_passport);	// CCMS1150 cnwrs1 21 June 2011

	return result;
end;</source>
        <Parameter name="_userCode" type="String"/>
        <Parameter name="_userPassword" type="String"/>
        <Parameter name="_machineToIgnore" type="CM_Machine"/>
        <Parameter name="_passport" type="CM_Passport" usage="io"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="trxUpdateLogonJMTSSO" id="d994af87-c230-4721-ae72-9285fb6a637a">
        <updating/>
        <source>trxUpdateLogonJMTSSO(_user : CM_User; _machineToIgnore : CM_Machine; _passport : CM_Passport io) : Integer updating;
/*

Purpose:			
	Implements logon for Cargo applications using a JWT token generated by Vehicle applications.
Parameters:			

Return Value:		

Date		Who		Reason
27 May 2025	navnk30	JIRA 34707: SSO Implementation for Mobile App - Jade Portion
18 Jul 2025	navdap1	MTN-34430 MTN - Deferred Updates For Event Required For Login and Logout Trxs
*/

vars
	result : Integer;
begin
	_passport := app.createPassport();
	
	self.initialiseActivityWithPassport(_passport, method);
	
	on Exception do dumpStackExHandler(exception);
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);
	
	app.setContinueCMExceptions(false);
	
	_passport.useEventDeferUpdate := true;		// MTN-34430
	
	beginTransaction;
	
	result := app.myUtilityUA.utlUpdateLogonJMTSSO(_user, null, _machineToIgnore, _passport);
	
	if _passport.noErrors then					// MTN-34430
		_passport.doDeferredUpdates();			// MTN-34430
	endif;										// MTN-34430
epilog
	self.finaliseActivityWithPassport(_passport);
	return result;
end;</source>
        <Parameter name="_user" type="CM_User"/>
        <Parameter name="_machineToIgnore" type="CM_Machine"/>
        <Parameter name="_passport" type="CM_Passport" usage="io"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="trxUpdateLogonSSO" id="9e7b9d12-ca2b-4e6f-8535-3e89f507b0f2">
        <updating/>
        <source>trxUpdateLogonSSO(_upn, _uid : String; _passport : CM_Passport io) : Integer updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who			Reason
20 July 2022 		navam1 		ChangeRequest 52824: EUP - Azure Active Directory Single Sign On - MTN
28 September 2022	navmd1		TFS 54959 Added additional exception handler to dump the stack
								when a JADE exception (eg, 1090) occurs
18 July 2025		navdap1		MTN-34430 MTN - Deferred Updates For Event Required For Login and Logout Trxs
*/

vars
	result	: Integer;

begin
	
	_passport	:=	app.createPassport();	// This deletes and recreates

	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do dumpStackExHandler(exception);		// TFS 54959 navmd1 28/09/2022
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);
	
	app.setContinueCMExceptions(false);
	
	_passport.useEventDeferUpdate := true;		// MTN-34430
	
	beginTransaction;
	
	result := app.myUtilityUA.utlUpdateLogonSSO(_upn, _uid, null, _passport);

	if _passport.noErrors then					// MTN-34430
		_passport.doDeferredUpdates();			// MTN-34430
	endif;										// MTN-34430
epilog
	self.finaliseActivityWithPassport(_passport);

	return result;
end;</source>
        <Parameter name="_upn" type="String"/>
        <Parameter name="_uid" type="String"/>
        <Parameter name="_passport" type="CM_Passport" usage="io"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="trxUpdateLogonSSOWithMachine" id="7c802909-3a72-4120-89ed-f5b7d5066b98">
        <updating/>
        <source>trxUpdateLogonSSOWithMachine(_upn, _uid : String; _machine : CM_Machine input; _passport : CM_Passport io) : Integer updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who			Reason
13 August 2022 		navam1 		ChangeRequest 53986: EUP - Azure Active Directory Single Sign On - Web
28 September 2022	navmd1		TFS 54959 Added additional exception handler to dump the stack
								when a JADE exception (eg, 1090) occurs
18 July 2025		navdap1		MTN-34430 MTN - Deferred Updates For Event Required For Login and Logout Trxs
*/

vars
	result : Integer;
	machineUserCode : String;
	userCode	: String;
begin
	_passport	:=	app.createPassport();	// This deletes and recreates

	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do dumpStackExHandler(exception);		// TFS 54959 navmd1 28/09/2022
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);
	
	app.setContinueCMExceptions(false);
	
	_passport.useEventDeferUpdate := true;		// MTN-34430
	
	beginTransaction;

	result := app.myUtilityUA.utlUpdateLogonSSO(_upn, _uid,_machine, _passport);
	
	//epr tfs 4973 19/7/17
	if _passport.hasErrors then
		result:=_passport.getFirstErrorNonWarning.errorCode;
		return result;
	endif;
	
	if result = 0 then
		
		app.myPassport.setMyTerminal(_machine.myTerminal); 
		app.myPassport.setMyMachine(_machine); 

		if _machine.user &lt;&gt; null then
			machineUserCode:=_machine.user.code;
		endif;
		
		// This check doesn't do what you think it does, the usercode must be a case sensitive match
		// Changing this to uppercase also allows Single Session users to log into the .net app
		// So leaving as-is for now
		userCode := app.getMyUserCode();
		if _machine.loggedOn and machineUserCode &lt;&gt; userCode then
			app.writeLog("Machine " &amp; _machine.code &amp; " already logged in as " &amp; machineUserCode, LogERROR);
			result := ERR_MACHINE_ALREADY_LOGGED;
		else
			_machine.executeLogon(_passport.myUser);
			if _passport.allErrors.size &gt; 0 then
				result := _passport.allErrors.first.errorCode;
			else		
				process.changeUserCode(_machine.code); 
			endif;
		endif;

	endif;
	
	if _passport.noErrors then					// MTN-34430
		_passport.doDeferredUpdates();			// MTN-34430
	endif;										// MTN-34430
	
	return result;

epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_upn" type="String"/>
        <Parameter name="_uid" type="String"/>
        <Parameter name="_machine" type="CM_Machine" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="io"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="trxUpdateLogonWithMachine" id="d1fa747e-8cfb-467f-abee-3b0691ec5d78">
        <updating/>
        <source>trxUpdateLogonWithMachine(_userCode : String; _userPassword : String; _machine : CM_Machine input; _passport : CM_Passport io) : Integer updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 Feb 2009	cnwer1	Initial creation par 18256 - need the machine logon done in the transaction layer
					also both trxUpdateLogon and machine.executeLogon whould be done in same transaction
08 Feb 2011 cnwer1  PAR 26908 - now passing in machine to utlUpdateLogon and only giving an errror if the machine user is different
22 May 2012	cnwkpd1	PAR #29612 - 1090 errors in logon followed by 1048 exceptions
16 Aug 2021 navmd1	TFS 51226 Added additonal logging to record machine logged in errors in the web
28 Sep 2022	navmd1	TFS 54959 Added additional exception handler to dump the stack when a JADE exception (eg, 1090) occurs
18 Jul 2025	navdap1	MTN-34430 MTN - Deferred Updates For Event Required For Login and Logout Trxs
*/

vars
	result : Integer;
	machineUserCode : String;
begin
	_passport	:=	app.createPassport();	// This deletes and recreates

	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do dumpStackExHandler(exception);		// TFS 54959 navmd1 28/09/2022
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);
	
	app.setContinueCMExceptions(false);
	
	_passport.useEventDeferUpdate := true;		// MTN-34430
	
	beginTransaction;

	result := app.myUtilityUA.utlUpdateLogon(_userCode, _userPassword,_machine,null, _passport);
	
	//epr tfs 4973 19/7/17
	if _passport.hasErrors then
		result:=_passport.getFirstErrorNonWarning.errorCode;
		return result;
	endif;
	
	if result = 0 then
	
		app.myPassport.setMyTerminal(_machine.myTerminal); //this needs to be set if we are working a road release for some reason it isnt //cnwrd1 19.1.2012
		app.myPassport.setMyMachine(_machine); //16/12/21 jlier1  TFS 52595
		//epr par 26908 8/2/2011
		if _machine.user &lt;&gt; null then
			machineUserCode:=_machine.user.code;
		endif;
		
		// This check doesn't do what you think it does, the usercode must be a case sensitive match
		// Changing this to uppercase also allows Single Session users to log into the .net app
		// So leaving as-is for now
		if _machine.loggedOn and machineUserCode &lt;&gt; _userCode then
			app.writeLog("Machine " &amp; _machine.code &amp; " already logged in as " &amp; machineUserCode, LogERROR);
			result := ERR_MACHINE_ALREADY_LOGGED;
		else
			_machine.executeLogon(_passport.myUser);
			if _passport.allErrors.size &gt; 0 then
				result := _passport.allErrors.first.errorCode;
			else		// PAR #29612 - only set process usercode if logon had no errors
				//epr par 25979 8/10/10
				process.changeUserCode(_machine.code); 
			endif;
		endif;

	endif;
	
	if _passport.noErrors then					// MTN-34430
		_passport.doDeferredUpdates();			// MTN-34430
	endif;										// MTN-34430
	
	return result;

epilog
	self.finaliseActivityWithPassport(_passport);

end;</source>
        <Parameter name="_userCode" type="String"/>
        <Parameter name="_userPassword" type="String"/>
        <Parameter name="_machine" type="CM_Machine" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="io"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="trxUpdateMTPoolParty" id="52f6081f-d0c6-46fc-93a2-4117ccf6ebdc">
        <updating/>
        <source>trxUpdateMTPoolParty(_proxyPoolParty : CM_MTPoolingParty; _passport : CM_Passport input) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 02/12/2016	cnwdap1		Initial creation TFS 3039 SNO MT Container Pool Management
//
vars

begin
	// Always initialize the activity first
