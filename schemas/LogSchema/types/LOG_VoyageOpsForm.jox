//--------------------------------------------------------------
//Created: 12 August 2002 By: cnwgd1
// 26/10/2022	navkc1 	Bug 55232: C3L - Export Log and Ship Files from Log Voyage Operations
//--------------------------------------------------------------
vars
	file : CMDFileOpen;
begin
