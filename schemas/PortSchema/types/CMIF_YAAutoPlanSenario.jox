    <JadeMethod name="hasChildren_Match" id="3e8db685-50ee-47f6-a450-5985021b0ca2">
        <source>hasChildren_Match(_yaData: CM_YADataBoolean): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 September 2020	jlgndl1	Initial creation	TFS 49984

*/

vars

begin

	return _yaData.doesValueMatch( self.myTrackedItem.hasChildren );


epilog

end;</source>
        <Parameter name="_yaData" type="CM_YADataBoolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="hasSameUnderStowAttribute" id="b4786fd4-7a37-4b83-b113-97d1444b6e89">
        <source>hasSameUnderStowAttribute(tiToCompareTo: CM_TrackedItem; testType: Integer): Boolean;
// -------------------------------------------
// Created 31 May 2005 by cnwdvb1
// -------------------------------------------
vars

begin

	sharedLock(tiToCompareTo);
	
	if testType = TI_Test_CommodityGroup then
		if  self.myCommodity &lt;&gt; null and self.myCommodity.myCommodityGroup &lt;&gt; null then
			return  self.myCommodity.myCommodityGroup.code.trimBlanks() = tiToCompareTo.commodityGroup.trimBlanks;
		endif;
		
	elseif testType = TI_Test_Consignee then
		if self.myConsignee &lt;&gt; null then
			return self.myConsignee.code.trimBlanks() = tiToCompareTo.consignee.trimBlanks();
		endif;
	elseif testType = TI_Test_Carrier then
		if self.myCarrier &lt;&gt; null then
		//	return self.myCarrier.code.trimBlanks() = tiToCompareTo.carrier.trimBlanks();
			return self.myCarrier.code.trimBlanks() = tiToCompareTo.releaseCarrier.trimBlanks();	// 04 Aug 2011	NDL	Par 27953
		endif;
		
	elseif testType = TI_Test_DischargePort then
		if self.myDischargePort &lt;&gt; null then
			return self.myDischargePort.code.trimBlanks() = tiToCompareTo.dischargePort.trimBlanks;
		endif;
		
	elseif testType = TI_Test_ImExStatus then
		//Imex is also contents for this I think. DQ
		if self.myIMEXStatus &lt;&gt; null then
			return self.myIMEXStatus.code &lt;&gt; tiToCompareTo.getImExStatus();
		endif;
		
	elseif testType = TI_Test_Operator then
		if self.myOperator &lt;&gt; null then
			return self.myOperator = tiToCompareTo.myOperator;
		endif;
		
	elseif testType = TI_Test_Voyage then
		if self.myVoyage &lt;&gt; null then
			return self.myVoyage = tiToCompareTo.myVoyage;
		endif;
		
	elseif testType = TI_Test_Temperature then
		/*if not tiToCompareTo.isKindOf(CM_Container) then
			return false;
		endif;
		if tiToCompareTo.CM_Container.temperature = NULL_TEMPERATURE then
			return true;
		endif;
		return self.temperature = tiToCompareTo.CM_Container.temperature;*/
		
	elseif testType = TI_Test_CmdtyTemp then
		//---------------------
		//The ti MUST be a container
		//---------------------
	/*	if not tiToCompareTo.isKindOf(CM_Container) then
			return false;
		endif;
		cont := tiToCompareTo.CM_Container;
		if cont.temperature = NULL_TEMPERATURE then
			return true;
	  	endif;
 	 	if (cont.temperature &lt; cmdty.minTemp) or (cont.temperature &gt; cmdty.maxTemp) then
			return false;
		endif;*/
	endif;
	
	return true;
epilog
	unlock(tiToCompareTo);
end;</source>
        <Parameter name="tiToCompareTo" type="CM_TrackedItem"/>
        <Parameter name="testType" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="is30" id="d49765b3-8621-48eb-99d3-74779281a53b">
        <source>is30() : Boolean;
// ---------------------------------------------------------------------------
// Created:		May 2008 By Andrew Bishop cnwab1
//
// Purpose:		 // PAR 16415 CCMS 1029
//
// ---------------------------------------------------------------------------
vars

begin

	if self.myTrackedItem.isContainer then
