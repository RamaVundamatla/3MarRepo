    <JadeMethod name="erase" id="4ca76fec-798f-42a8-b797-57f8fe28b7c3">
        <updating/>
        <source>erase(_eraseLevel: Integer) updating;
/*

Date		Who		Reason
01 Jul 2013	cnwkpd1	PAR #31929 - Tidy up Yard Allocations using the receiver before deleting

*/

vars
	yaType : CM_YATypeSrcTermArea;
	
	//15 Jul 2016	NDL	TFS 2329
	iter : Iterator;
	cmqfC : CMQF_Container;
	cmqfFR : CMQF_FilterReports;

begin
	exclusiveLock(self);
	//--------------------
	//Test to see if its being used in a Queue task somewhere
	//--------------------
	if (not self.isTransient) then // AKB JULY 2001. Because of TRX proxy clear up
		//AJA 2/9/99: Is it referenced in any attribute area of any atribute plan ?
		self.checkRTQueueTaskUsage();
	endif;
	//------------------
	//nuke swapstack
	//------------------
	self.eraseSwapStack();
	//------------------
	//clear from any machines, and the machine types table, and any yard allocations
	//------------------
	if (not self.isTransient) then
		self.eraseFromMachines();
	
		// PAR #31929
		yaType := CM_YATypeSrcTermArea.firstInstance;
		if yaType &lt;&gt; null then
			yaType.removeMyDataObject(self);
		endif;
	else
	// delete transients created for proxy
		if self.myYADeckingOptions &lt;&gt; null and self.myYADeckingOptions.isTransient then
		// delete manual references
			self.myYADeckingOptions.erase(_eraseLevel);
		endif;
	endif;
	
	iter := CMQF_Container.instances.createIterator;
	while iter.next(cmqfC) do
		if cmqfC.allQryPackAreas.includes(self) then
			cmqfC.allQryPackAreas.remove(self);
		endif;
	endwhile; 
	delete iter;
	
	iter := CMQF_FilterReports.instances.createIterator;
	while iter.next(cmqfFR) do
		if cmqfFR.allQryTerminalAreas.includes(self) then
			cmqfFR.allQryTerminalAreas.remove(self);
		endif;
	endwhile; 
	delete iter;

	inheritMethod(_eraseLevel);

epilog
	delete iter;
end;</source>
        <Parameter name="_eraseLevel" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="eraseFromMachines" id="9c7e4fc3-d676-4b3b-9dc3-7f59db123a8b">
        <updating/>
        <source>eraseFromMachines() updating;
//Make sure no machines reference us. Called from the erase C++ code.
vars
	mach	:	CM_Machine;
	machType	:	CM_MachineType;
begin
	foreach mach in self.myTerminal.machines do
		if mach.allowedTAMasters.includes(self) then
			mach.allowedTAMasters.remove(self);
		endif;
	endforeach;
	//-----------------
	//Also do the machine types tabl as wellr	
	//-----------------
	foreach machType in app.myRoot.allMachineTypes do
		machType.unsetTerminalArea(self);
	endforeach;
end;</source>
    </JadeMethod>
    <JadeMethod name="eraseSwapStack" id="8e346d35-44bf-4ca5-abf6-9a66977c8eb7">
        <updating/>
        <source>eraseSwapStack() updating;
//Erase a SwapStack.
vars
	bc			: CM_BlockController;
	st			: CM_SwapStack;
	yaType 		: CM_YATypeSrcTermArea;
	
begin
	exclusiveLock(self);
 	if self.swapStack = null then
 		return;
 	endif;
 	bc := swapStack.myLocationsController;
 	if bc &lt;&gt; null then
	 	if bc.numTIs &gt; 0 then
			app.setContinueCMExceptions(false);
			app.raiseCMException(ERR_SWAP_LC_HAS_TIS, null, null);
			return;		
	 	endif;
	 	if bc.numPlannedTIs &gt; 0 then
			app.setContinueCMExceptions(false);
			app.raiseCMException(ERR_SWAP_LC_HAS_TIS, null, null);
			return;		
	 	endif;
	 	if bc.numQueuedTIs &gt; 0 then
			app.setContinueCMExceptions(false);
			app.raiseCMException(ERR_SWAP_LC_HAS_TIS, null, null);
			return;
	 	endif;
	 	//--------------
	 	//Safe to nuke
	 	//--------------
		delete bc;	//AJA 15/3/01: Don't leave the controller orphaned !
	
		// 	delete swapStack; // Cannot manually update an automatic inverse so...
	endif;
	st := swapStack;
	
	if (not self.isTransient) then
		yaType := CM_YATypeSrcTermArea.firstInstance;
		if yaType &lt;&gt; null then
			yaType.removeMyDataObject(st);
		endif;
	endif;
	delete st;
end;</source>
    </JadeMethod>
    <JadeMethod name="findLocation" id="c580c55e-dd95-4011-8a35-41edc8af4083">
        <source>findLocation(_strs : StringArray; _noException : Boolean; _foundLC : CM_LocationsController io; _foundHeight : Integer io);
