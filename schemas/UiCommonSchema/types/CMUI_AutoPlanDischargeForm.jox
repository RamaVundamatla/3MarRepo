    <JadeMethod name="translateForm" id="24196a65-8a0f-47fd-8f84-7ff2f69cd2ec">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0007260, locale);
	btnAutoplan.translateCaption(Xlat_0000067, locale);
	btnPrint.translateCaption(Xlat_0000068, locale);
	btnUnplanJob.translateCaption(Xlat_0000066, locale);
	mnuColumnOrganiser.translateCaption(Xlat_0007261, locale);
	mnuContextTbl.translateCaption(Xlat_0007262, locale);
	mnuInspectObj.translateCaption(Xlat_0007263, locale);
end;</source>
    </JadeMethod>
</GUIClass>
