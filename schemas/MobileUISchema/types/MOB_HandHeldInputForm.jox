    <JadeMethod name="handleTableChange" id="433146e6-da1f-494b-a13a-de699f74d3a7">
        <source>handleTableChange() protected;
// ---------------------------------------------------------------------------
// Created:	18 January 2009 By Graeme Black cnwgb1
// Status: 	Unfinished
// Purpose:	
// ---------------------------------------------------------------------------
vars
	index : Integer;
begin
	//If there is something in every field, enable the OK button
	foreach index in 1 to self.tblInfo.rows do
		if self.tblInfo.accessCell(index, 2).text.trimBlanks() = null then
			return;
		endif;
	endforeach;
	self.btnOne.enabled := true;
epilog
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="init" id="4609e162-c8f4-439a-9291-e73184ddd9ef">
        <source>init( _fieldNames : IntegerArray );
// ---------------------------------------------------------------------------
// Created:	18 January 2009 By Graeme Black cnwgb1
// Status: 	Unfinished
// Purpose:	
// ---------------------------------------------------------------------------
//06 May 2013	cnwrs1	Par 31508 set maxlength of Import release Pin to 11
//15 May 2013	cnwrs1	par31549 stop removal of unused options
vars
	index : Integer;
begin
	self.tblInfo.rows := _fieldNames.size();
	foreach index in 1 to _fieldNames.size do
		if     _fieldNames[index] = CEDO then
			self.tblInfo.accessCell(index, 1).text := app.myRoot.getTranslatedRequiredInfoType(CEDO);
		elseif _fieldNames[index] = CustomsEntryNumber then
			self.tblInfo.accessCell(index, 1).text := app.myRoot.getTranslatedRequiredInfoType(CustomsEntryNumber);
		elseif _fieldNames[index] = ImportReleasePIN then
			self.tblInfo.accessCell(index, 1).text := app.myRoot.getTranslatedRequiredInfoType(ImportReleasePIN);
			self.tblInfo.accessCell(index, 2).maxLength := 11;
		elseif _fieldNames[index] = ExportReleaseNumber then
			self.tblInfo.accessCell(index, 1).text := app.myRoot.getTranslatedRequiredInfoType(ExportReleaseNumber);
			self.tblInfo.accessCell(index, 2).maxLength := 20;
		elseif _fieldNames[index] = DeliveryRelease then
			self.tblInfo.accessCell(index, 1).text := app.myRoot.getTranslatedRequiredInfoType(DeliveryRelease);
			self.tblInfo.accessCell(index, 2).maxLength := 25;
		elseif _fieldNames[index] = CustomsReference then	//30 Jun 2015	NDL	Par 36543
			self.tblInfo.accessCell(index, 1).text := app.myRoot.getTranslatedRequiredInfoType(CustomsReference);
			self.tblInfo.accessCell(index, 2).maxLength := 30;
		endif;
	endforeach;
epilog
end;</source>
        <Parameter name="_fieldNames" type="IntegerArray"/>
    </JadeMethod>
    <JadeMethod name="setupCaption" id="9b8e9fb4-b0a6-45ed-886b-4cfc5df4415a">
        <updating/>
        <source>setupCaption() updating, protected;
// ---------------------------------------------------------------------------
// Created:	19 January 2009 By Graeme Black cnwgb1
// Status: 	Unfinished
// Purpose:	
// ---------------------------------------------------------------------------
vars

begin

	self.lblCaption.move( self.resizedMargin, 
	                      2, 
						  self.clientWidth - (2 * self.resizedMargin), 
						  63);
						  
epilog
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupForm" id="570d12ca-2866-4acc-b5fd-41985b540a3d">
        <updating/>
        <source>setupForm() updating, protected;
// ---------------------------------------------------------------------------
// Created:	18 January 2009 By Graeme Black cnwgb1
// Status: 	Unfinished
// Purpose:	
// ---------------------------------------------------------------------------
vars
begin

	self.doResize();
	inheritMethod();
	self.setupCmdButtons( 2, app.getErrorString(CM_OK) ,app.getErrorString(Cancel), "", "", "" );
	self.setupCaption();
	self.setupTable();
	self.tblInfo.row := 1;
	self.tblInfo.column := 2;
	self.btnOne.enabled := false;
	
epilog
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupTable" id="74b2be7c-42c1-49cd-843a-514ab6e77779">
        <updating/>
        <source>setupTable() updating, protected;
// ---------------------------------------------------------------------------
// Created:	19 January 2009 By Graeme Black cnwgb1
// Status: 	Unfinished
// Purpose:	
// ---------------------------------------------------------------------------
vars
begin
epilog
	self.tblInfo.move( self.MARGIN, 
	                       65, 
						  self.clientWidth - 2*self.MARGIN, 
						  (self.tblInfo.accessRow(1).height+1)*self.tblInfo.rows );
	self.tblInfo.parentAspect:=Table.ParentAspect_StretchRight;
	self.tblInfo.fontName := "Tahoma";
	//self.tblInfo.fontSize := 10;
	self.tblInfo.inputType := Table.InputType_TextBox;
	self.tblInfo.fitColumnWidth(1,10); //epr 2/7/10 par 24807
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="tblInfo_change" id="0b119f59-8deb-4d1c-ae7a-7fa107230d3a">
        <controlMethod name="Table::change"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblInfo_change(table: Table input) updating;
// ---------------------------------------------------------------------------
// Created:	18 January 2009 By Graeme Black cnwgb1
// Status: 	Unfinished
// Purpose:	
// ---------------------------------------------------------------------------
vars
begin
	self.handleTableChange();
epilog
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="a6a5f1aa-0a2b-4d5e-b4ec-2b018b3a90a4">
        <updating/>
        <source>translateForm(locale : CM_Locale) updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	
begin
	// Determine the locale for translations.
	inheritMethod(locale);
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0013036, locale);
	lblCaption.translateCaption(Xlat_0013037, locale);
end;</source>
        <Parameter name="locale" type="CM_Locale"/>
    </JadeMethod>
</GUIClass>
