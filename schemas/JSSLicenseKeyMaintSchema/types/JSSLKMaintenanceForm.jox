    <JadeMethod name="mnuCustomerCertificate_click" id="4f01b8b8-da3d-4056-8555-649eab52189d">
        <controlMethod name="MenuItem::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mnuCustomerCertificate_click(menuItem: MenuItem input) updating;
// --------------------------------------------------------------------------------
// Created:		21 January 2003 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theUsedProduct		: JSSLKUsedProduct;
	theCertificateForm	: JSSLKCertificate;
	
begin
	app.mousePointer	:=	Busy;
	
	theUsedProduct	:=	self.listGetSelectedUsedProduct(lstProdUsed);
	
	if lstProdUsed.listIndex = JSS_NULL_INDEX then
		app.msgBox("Please select the Used Product to generate the Certificate for.", "Error", MsgBox_Exclamation_Mark_Icon + MsgBox_OK_Only);
	else
		if theUsedProduct.isExpired then
			app.msgBox("This license has expired.", "Error", MsgBox_Exclamation_Mark_Icon + MsgBox_OK_Only);
		elseif (not theUsedProduct.isLicensed) then
			app.msgBox("A license key has not been generated for this product.", "Error", MsgBox_Exclamation_Mark_Icon + MsgBox_OK_Only);
		else
//			write theUsedProduct.licenseKey;
			create theCertificateForm;
			theCertificateForm.setUsedProduct(theUsedProduct);
			theCertificateForm.doPrintReport();
		endif;
	endif;
epilog
	delete theCertificateForm;
	app.mousePointer	:=	Idle;
end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
