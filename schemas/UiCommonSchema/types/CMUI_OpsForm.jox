    <JadeMethod name="doMove_Autoplan" id="4475c4cc-748f-4695-80e9-3886c9343a8f">
        <updating/>
        <source>doMove_Autoplan(_all : Boolean) updating;
//--------------------------------------------------------------
//Created: 28 February 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	wle : CM_WorkListEntry;
	wlesWithWarnings,	
	wleArray : CM_WLEArray;
	result	: Integer;
begin
	app.mousePointer := MousePointer_HourGlass;
	
	create wleArray transient;
	
	if _all then
		self.getAllWLEsInTable(wleArray);
	else
		self.getAllWLEsInTableSelected(wleArray);
	endif;

	create wlesWithWarnings transient;

	while true do
		//09/08/2010 cnwdz2 25314
		app.myTrxUA.trxUpdateWLEsAutoplan(wleArray, wlesWithWarnings, QUEUE_MODE, app.myPassport);			//+cnwml2 PAR25974
		//app.myTrxUA.trxUpdateWLEsAutoplan(wleArray, wlesWithWarnings, PLANNING_MODE, app.myPassport);		//-cnwml2 PAR25974
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			break;
		else
			if app.myPassport.allErrorWarnings.size = 1 and app.myPassport.returnCode = INFO_NO_AUTOPLAN then
				//do show it here, ask Q below.
				result := 1;				
			else
				result := app.showErrorWarningDialog(self.caption, app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnSkipErr);
			endif;
			if result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				// only reprocess the wles that had warnings.
				wleArray.clear;
				wlesWithWarnings.copy(wleArray);
				wlesWithWarnings.clear;	
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
		endif;
		break;
	endwhile;	

	//if app.myPassport.returnCode = Full_Replacement_Message then //- cnwmd1, Par 20524
	if app.myPassport.returnCode = Request_failed_auto_plan then
		/*if app.msgBox("The Item(s) failed to auto plan. Do you wish to view the alerts screen?", "Information",
					 MsgBox_Information_Icon + MsgBox_Yes_No) = MsgBox_Return_Yes then */ //- cnwmd1, Par 20524
		//if app.msgBox(app.getErrorString(Item_faile_auto_plan_wagon_wi), app.getErrorString(Information), MsgBox_Information_Icon + MsgBox_Yes_No) = MsgBox_Return_Yes then
		if app.msgBox(app.getErrorString(Item_faile_auto_plan_wish_vi), app.getErrorString(Information), MsgBox_Information_Icon + MsgBox_Yes_No) = MsgBox_Return_Yes then   // 14/07/2010 cnwmh5 #24966
			app.showSystemAlertsWindow(self.myMasterMenuAction, self.myTerminal, null);			
		endif;
	endif;
	
epilog
	delete wlesWithWarnings;
	delete wleArray;
	app.mousePointer := MousePointer_Default;
end;</source>
        <Parameter name="_all" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doMove_AutoplanForTrain" id="ae4bb909-7032-4eb7-b76d-b4d216dd48a2">
