    <JadeMethod name="doLoadCmbOperator" id="93c32652-be6e-4e50-93a9-59edfe84e756">
        <updating/>
        <source>doLoadCmbOperator(_cmbBox: CMUI_ComboBox) updating, protected;
// ---------------------------------------------------------------------------
// Created:		August  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 03/08/2022   navds20		Bug 54202: EUP - Combo Boxes not adhereing to configuration (operator and Stevedore)
// ---------------------------------------------------------------------------
vars
	iter			: Iterator;
	tmpStr			: String;
	selectedOp		: CM_Operator;
	foundMatch		: Boolean;
	voy 			: CM_Voyage;
	op				: CM_Operator;
	idx				: Integer;
	byName			: Boolean;
begin

	selectedOp := self.cmbOperatorRight.listObject.CM_Operator;				//+cnwml2 PAR22785
	self.cmbOperatorRight.clear();
	
	voy := self.cmbVoyageRight.listObject.CM_Voyage;
	
	if voy &lt;&gt; null then
		iter := voy.allOperators.createIterator;
	else	
		iter := app.myRoot.allOperators.createIterator;
	endif;
	
	byName := app.myRoot.getConfig(ComboByNameOperator).Boolean;
	while iter.next(op) do
		
		// start 03/08/2022 navds20 TFS 54202
		if byName then
			tmpStr := op.description;
		else
			tmpStr := op.code &amp; Tab &amp; op.description;
		endif;
		// end 03/08/2022 navds20 TFS 54202
		
		idx := self.cmbOperatorRight.addItem(tmpStr);
		self.cmbOperatorRight.itemObject[idx] := op;
		
		if selectedOp = op then  
			foundMatch := true;   
		endif;
		
	endwhile;
			
	if foundMatch then
		self.cmbOperatorRight.listObject := selectedOp;
	else
		self.cmbOperatorRight.listObject := null;
	endif;

epilog
	delete iter;
end;</source>
        <access>protected</access>
        <Parameter name="_cmbBox" type="CMUI_ComboBox"/>
    </JadeMethod>
    <JadeMethod name="doLoadCmbQryCargoTypes" id="d1e69e48-b3c6-445a-8f42-4ef55683209f">
        <source>doLoadCmbQryCargoTypes() protected;
// ---------------------------------------------------------------------------
// Created:     24 February 2003		cnwth2	
//
// Purpose:   		
//
// Changed On	By			Reason
// ----------   ----------  --------------------------------------------------
// 07/05/2020	jlgdap1		TFS 49252 CPL Cargo Types not showing in System Admin
vars
	idx				: Integer;
	cargoBOLType	: CM_CargoBOLType;
	cmb				: CMUI_ComboBox;
	canDoGeneralCargo	: Boolean;
	
begin
	cmb := self.cmbQryCargoType;
	cmb.addItem(Any_String);
	
	canDoGeneralCargo := app.myRoot.canDo(Mod_GeneralCargo);
	
	foreach cargoBOLType in self.myTerminal.allCargoBOLTypes do
		if cargoBOLType.isKindOf(CM_BOLType) then //we only want cargo types
			continue;
		endif;
		
		if ((not canDoGeneralCargo) and 
		   cargoBOLType.id &gt; TI_CargoBOLType_Max) or
		   //(cargoBOLType.id &gt; TI_CargoBOLType_JMTMax) then										// TFS 49252
		   (cargoBOLType.id &gt; TI_CargoBOLType_JMTMax and not app.myRoot.isClientCentrePort) then	// TFS 49252
			continue;
		endif;
		
		cmb.itemObject[cmb.addItem(cargoBOLType.description)] := cargoBOLType;
	endforeach;	
	cmb.text := Any_String;
	self.tblQuery.setValueByName(ETRow_CargoType, Any_String);
end;</source>
        <access>protected</access>
    </JadeMethod>
