        <updating/>
        <source>setNumberOfPackagesStr( _tiSet : CM_TISet )updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 August 2015	cnwndl1	Initial creation	Par 36777

*/

vars

	count : Integer;
	ti : CM_TrackedItem;
	child : CM_TrackedItem;

begin

	foreach ti in _tiSet do
		if ti.isContainer then
			if  ti.allChildren.isEmpty then
				count := count + 1;
			else
				foreach child in ti.allChildren do
					count := count + child.totalQuantity.max(1);
				endforeach;
			endif;
		else
			count := count + ti.totalQuantity.max(1);
		endif;
	endforeach;

	self.numberOfPackagesStr := count.String;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_tiSet" type="CM_TISet"/>
    </JadeMethod>
    <JadeMethod name="setOperativeIdNumberStr" id="5060fb40-e3de-40de-9ba5-ba5dfe7ae3ac">
        <updating/>
        <source>setOperativeIdNumberStr( _tiSet : CM_TISet; _delim : String ) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 August 2015	cnwndl1	Initial creation	Par 36777

*/

vars

	cusAgent : CM_CustomsAgent;
	allCusAgents : CM_CustomsAgentByCodeDict;
	ti : CM_TrackedItem;
	cusAgentStr : String;
	completeStr : String;

begin

	create allCusAgents transient;
	
	foreach ti in _tiSet do
		cusAgent := ti.myCustomsAgent;
		if cusAgent &lt;&gt; null then
			allCusAgents.addNoDuplicates( cusAgent, false );
		endif;
	endforeach;
	
	foreach cusAgent in allCusAgents do
		cusAgentStr  := cusAgent.code;
		if cusAgentStr.trimBlanks &lt;&gt; null then
			if completeStr = null then
				completeStr := cusAgentStr;
			else
				completeStr := completeStr &amp; _delim &amp; cusAgentStr;
			endif;
		endif;
	endforeach;
	
	self.operativeIdNumberStr := completeStr;

epilog

	delete allCusAgents;

end;</source>
