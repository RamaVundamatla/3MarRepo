    <JadeMethod name="getTrackedItem" id="617f96eb-5b3b-4be6-b789-c2f576d317c4">
        <source>getTrackedItem() : CM_TrackedItem;
/*

Date		Who		Reason
20 March 2014	cnwer1	Initial creation PAR

*/

vars
	trx		:CM_TITransaction;
	ti		:CM_TrackedItem;
	result	:CM_ISOType;
begin
	trx 	:= self.myMoveTransaction;
	
	if trx = null then
		// machine must be a crane
		trx := self.myShipReceiveReleaseTrx;
	endif;
	
	if trx &lt;&gt; null then
		ti := trx.myTrackedItem;		
	endif;
	
	return ti;
epilog

