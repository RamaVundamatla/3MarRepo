    <JadeMethod name="optBtnBooking_click" id="8fc58077-04fd-47cd-9af6-9e2d68313930">
        <controlMethod name="OptionButton::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>optBtnBooking_click(optionbutton: OptionButton input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 Mar 023	navcs2	ChangeRequest 55440:[54990]: EUP - Release Cargo Work Order - Enhancement
04 Jul 2023	navma1	Bug 58952: MTN - Unable to add the tracked item when using the Export Booking for Release Cargo Work Order
11 Jul 2023 navma1	11 Jul 2023 navma1  Defect 59095: EUP - Able to save the Receive Cargo Work Order without the Booking selected when the VAS Subscription is on/off
19 Jul 2023 navhl20 Bug 59175: MTN - Issues with selected cargo items when Loading cargo Receive and Release work orders 
19 Jul 2023 navhl20 Bug 59200: MTN - Release Rail Work order showing Prenote Button
27 Feb 2024	navpw1	TFS: 59411 (61864) - Made create cargo button only show for receival

*/

vars
	voyage	 : CM_Voyage;
begin
	self.initTableItems(ETDef_BookReqItem);
	self.cmbReleaseRequest.clear();							//06.7.2023 navhl20 #58952
	
	if self.cmbTransport.listObject.isKindOf(CM_Voyage) &lt;&gt; null then
		voyage := self.cmbTransport.listObject.CM_Voyage;
	endif;
	
	self.buildCmbBooking(voyage);						//11.07.2023 navma1 #59095
	self.cmbReleaseRequest.visible			:= false;
	self.lblReleaseRequest.visible 			:= false;
	self.btnMaintainRelease.visible 		:= false;
	self.cmbReserveDetail.visible 			:= false;
	self.lblReserveDetail.visible 			:= false;
	self.cmbBooking.visible 				:= true;	//04.07.2023 navma1 #58952
	self.lblBookingItem.visible 			:= true;	//04.07.2023 navma1 #58952
	self.cmbBookingItem.visible 			:= true;	//04.07.2023 navma1 #58952
	self.lblBookingItem.parent				:= self.grpReleaseDetails;
	self.cmbBooking.parent					:= self.grpReleaseDetails;
	self.cmbBookingItem.parent				:= self.grpReleaseDetails;
	self.lblBooking.visible					:= true;
	self.lblBooking.parent					:= self.grpReleaseDetails;
	self.lblBooking.top						:= self.optBtnBooking.top + self.optBtnBooking.height + 10;
	self.cmbBooking.top						:= self.optBtnBooking.top + self.optBtnBooking.height + 10;
	self.lblBookingItem.top 				:= self.cmbBooking.top    + self.cmbBooking.height + 10;
	self.cmbBookingItem.top 				:= self.cmbBooking.top    + self.cmbBooking.height + 10;
	
	self.btnMaintainBooking.visible 		:= true;
	self.btnMaintainBooking.parent 			:= self.grpReleaseDetails;
	self.btnMaintainBooking.top				:= self.cmbBooking.top;
	self.grpReleaseItems.caption			:= app.getErrorString(Booking_Items);
	self.cmbBooking_click(self.cmbBooking);				//19.7.2023 navhl20 #59175
	if self.myPxyTask.isWodReceive then
		self.btnCreateCargo.visible 		:= true;				//19.7.2023 navhl20 #59200
	endif;
	self.maintainBtnAttachCargo();
epilog

end;</source>
        <Parameter name="optionbutton" type="OptionButton" usage="input"/>
    </JadeMethod>
    <JadeMethod name="optBtnRelease_click" id="b62b2e7b-b5a5-4b81-a81c-3be98f2d32d3">
        <controlMethod name="OptionButton::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>optBtnRelease_click(optionbutton: OptionButton input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 Mar 2023	navcs2	ChangeRequest 55440:[54990]: EUP - Release Cargo Work Order - Enhancement
04 Jul 2023	navma1	Bug 58952: MTN - Unable to add the tracked item when using the Export Booking for Release Cargo Work Order
19 Jul 2023 navhl20 Bug 59175: MTN - Issues with selected cargo items when Loading cargo Receive and Release work orders 
*/

vars

begin
	self.initTableItems(ETDef_ResDetails);
	self.cmbBooking.clear();							//04.07.2023 navma1 #58952
	self.buildCmbRelease();
	self.cmbReleaseRequest.visible			:= true;
	self.lblReleaseRequest.visible 			:= true;
	self.btnMaintainRelease.visible 		:= true;
	self.grpReleaseItems.caption			:= app.getErrorString(Released_items);
	
	/*
	Hide Booking Details 
	04.07.2023 navma1 #58952
	*/
	self.lblBooking.visible 			:= false;
	self.lblBookingItem.visible				:= false;
	self.cmbBooking.visible 				:= false;	//04.07.2023 navma1 #58952
	self.cmbBookingItem.visible				:= false;	
	self.btnMaintainBooking.visible 	:= false;
	self.cmbReleaseRequest_click(self.cmbReleaseRequest);	//19.7.2023 navhl20 #59175
	
	self.maintainBtnAttachCargo();
epilog

end;</source>
        <Parameter name="optionbutton" type="OptionButton" usage="input"/>
    </JadeMethod>
    <JadeMethod name="popTblResources" id="20be3ce0-d41d-42b7-befb-2ad15f3a99f6">
        <source>popTblResources( _table : CM_DataTable input; _woVoyDtl : CM_WorkOrderVoyageDtl; _context : Object  );
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
23 April 2022	navhl20	ChangeRequest 52351: MTN - Work Order Maintenance Refactor - UI

*/

vars
	entDef : EntTableDef;
	resource : HMS_Resource;
	resourceType : HMS_ResourceType;
	
	rowIndex : Integer;
	inclColIndex : Integer;
	rtColIndex : Integer;
	rColIndex : Integer;
	uColIndex : Integer;
	qColIndex : Integer;
	fdColIndex : Integer;
	ftColIndex : Integer;
	tdColIndex : Integer;
	ttColIndex : Integer;
	
	noEntryColour : Integer;
	wodMarineServiceDet : CM_WodMarineServiceDetail;
	localFromDT : TimeStamp;
	localToDT : TimeStamp;
	
	dateMask : CMUI_DateMask;
	
	wodShiftMovement : CM_WodShiftMovement;
	isWodShiftMovement : Boolean;
	marineServiceDepart : CM_WodMarineServicesDepart;
	isMarineServiceDepart : Boolean;
	marineServiceInitial : CM_WodMarineServicesInitial;
	isMarineServiceInitial : Boolean;
	localResourceDict : HMS_ResourceByTypeDict;

begin
	if _woVoyDtl.isKindOf(CM_WodShiftMovement) then
		wodShiftMovement := _woVoyDtl.CM_WodShiftMovement;
	elseif _woVoyDtl.isKindOf(CM_WodMarineServicesInitial) then
		marineServiceInitial := _woVoyDtl.CM_WodMarineServicesInitial;
	elseif _woVoyDtl.isKindOf(CM_WodMarineServicesDepart) then
		marineServiceDepart := _woVoyDtl.CM_WodMarineServicesDepart;
	else
		return;
	endif;
	
	if self.dateMaskArray &lt;&gt; null and not self.dateMaskArray.isEmpty then
		self.dateMaskArray.purge;
	endif;
	_table.clear();
	
	entDef := app.myController.getEntTableDef(ETDef_HmsWoResourcesUsed);
	_table.setMyEntTableDef(entDef);	
	_table.setTblDataEntRowsFromDef(entDef);
	_table.hideColumnByColName( ETRow_Debtor );
	
	_table.tabKey := J_key_Tab;
	
	inclColIndex := _table.getColumnByRowName( ETRow_Include );
	rtColIndex := _table.getColumnByRowName( ETRow_MyResourceType );
	rColIndex := _table.getColumnByRowName( ETRow_MyResource );
	uColIndex := _table.getColumnByRowName( ETRow_UnitsUsed );
	qColIndex := _table.getColumnByRowName( ETRow_QuantityUnits );
	fdColIndex := _table.getColumnByRowName( ETRow_FromDate );
	ftColIndex := _table.getColumnByRowName( ETRow_FromTime );
	tdColIndex := _table.getColumnByRowName( ETRow_ToDate );
	ttColIndex := _table.getColumnByRowName( ETRow_ToTime );
	
	noEntryColour := _table.accessCell(1,1).backColor;
	
	if _context &lt;&gt; null then
		if _context.isKindOf( CM_VoyageStatus )then
			create localResourceDict transient;
			_context.CM_VoyageStatus.allHMSResourcesAllowed.copy( localResourceDict );
		elseif _context.isKindOf( HMS_ResourceType )then
			create localResourceDict transient;
			_context.HMS_ResourceType.allResources.copy( localResourceDict );
		elseif _context.isKindOf( HMS_ResourceByTypeDict ) then	
			_context.HMS_ResourceByTypeDict.copy( localResourceDict );
		endif;
	endif;
	
	
	if localResourceDict &lt;&gt; null and not localResourceDict.isEmpty then
		foreach resource in localResourceDict do
			if resource.myHarbour &lt;&gt; self.myTerminal.myHarbour then
				continue;
			endif;
			if resource.isNotAvailableForEntry then
				continue;
			endif;
		
		
			resourceType := resource.myResourceType;
			_table.rows := _table.rows + 1;
			rowIndex := _table.rows;
			
			if wodShiftMovement &lt;&gt; null and not wodShiftMovement.allMarineServiceDetails.isEmpty then
				wodMarineServiceDet :=  wodShiftMovement.allMarineServiceDetails.findWodMarineServiceDet( resource );
			elseif marineServiceInitial &lt;&gt; null and not marineServiceInitial.allMarineServiceDetails.isEmpty then
				wodMarineServiceDet :=  marineServiceInitial.allMarineServiceDetails.findWodMarineServiceDet( resource );
			elseif marineServiceDepart &lt;&gt; null and not marineServiceDepart.allMarineServiceDetails.isEmpty then
				wodMarineServiceDet :=  marineServiceDepart.allMarineServiceDetails.findWodMarineServiceDet( resource );
			endif;
			
			_table.accessCell( rowIndex, rtColIndex ).text := resourceType.description;
			_table.accessCell( rowIndex, rtColIndex ).itemObject := resourceType;
			_table.accessCell( rowIndex, rColIndex ).text := resource.description;
			_table.accessCell( rowIndex, rColIndex ).itemObject := resource;
			if resourceType.isQuantityRequired then
				_table.accessCell( rowIndex, uColIndex ).inputType := Table.InputType_TextBox;
				_table.accessCell( rowIndex, uColIndex ).cellControl.TextBox.dataType := TextBox.DataType_Numeric;
				if resourceType.numDecimalPlaces &gt; 0 then
					_table.accessCell( rowIndex, uColIndex ).cellControl.TextBox.decimals := resourceType.numDecimalPlaces;
				endif;
			else
				_table.accessCell( rowIndex, uColIndex ).inputType := Table.InputType_None;
				_table.accessCell( rowIndex, uColIndex ).backColor := noEntryColour;	
			endif;
			if resourceType.quantityUnits &lt;&gt; null then
				_table.accessCell( rowIndex, qColIndex ).text := resourceType.quantityUnits;
			endif;
			_table.accessCell( rowIndex, qColIndex ).inputType := Table.InputType_None;
			_table.accessCell( rowIndex, qColIndex ).backColor := noEntryColour;
				
			if resourceType.isActionDateTimeRequired or resourceType.isFromToDateTimeRequired then
				dateMask := self.addCalendarControl();
				_table.accessCell( rowIndex, fdColIndex ).cellControl := dateMask;	
				_table.initCellForTime( _table.accessCell( rowIndex, ftColIndex ) );
			else
				_table.accessCell( rowIndex, fdColIndex ).inputType := Table.InputType_None;
				_table.accessCell( rowIndex, fdColIndex ).backColor := noEntryColour;
				_table.accessCell( rowIndex, ftColIndex ).inputType := Table.InputType_None;
				_table.accessCell( rowIndex, ftColIndex ).backColor := noEntryColour;
			endif;
			if resourceType.isActionDateTimeRequired or resourceType.isFromToDateTimeRequired then
				dateMask := self.addCalendarControl();
				_table.accessCell( rowIndex, tdColIndex ).cellControl := dateMask;
				_table.initCellForTime( _table.accessCell( rowIndex, ttColIndex ) );
			else
				_table.accessCell( rowIndex, tdColIndex ).inputType := Table.InputType_None;
				_table.accessCell( rowIndex, tdColIndex ).backColor := noEntryColour;
				_table.accessCell( rowIndex, ttColIndex ).inputType := Table.InputType_None;
				_table.accessCell( rowIndex, ttColIndex ).backColor := noEntryColour;
			endif;
			
			_table.accessCell( rowIndex, uColIndex ).text := null;
			_table.accessCell( rowIndex, fdColIndex ).text := null;
			_table.accessCell( rowIndex, ftColIndex ).text := null;
			_table.accessCell( rowIndex, tdColIndex ).text := null;
			_table.accessCell( rowIndex, ttColIndex ).text := null;
			_table.accessCell( rowIndex, uColIndex ).itemObject := wodMarineServiceDet;
			if wodMarineServiceDet &lt;&gt; null then
				_table.accessCell( rowIndex, inclColIndex ).text := "1"; //Selected
				if wodMarineServiceDet.unitsUsed &gt; 0 then
					_table.accessCell( rowIndex, uColIndex ).text := wodMarineServiceDet.unitsUsed.asStringJMTWithPrecision( resourceType.numDecimalPlaces, false);
				endif;
				if wodMarineServiceDet.fromDateTime.date.isValid then
					localFromDT := self.systemToLocalTime( wodMarineServiceDet.fromDateTime );
					_table.accessCell( rowIndex, fdColIndex ).cellControl.CMUI_DateMask.setDate( localFromDT.date );
					_table.accessCell( rowIndex, fdColIndex ).text := localFromDT.date.asStringJMT;
					_table.accessCell( rowIndex, ftColIndex ).text := localFromDT.time.asStringJMT;
				endif;
				if wodMarineServiceDet.toDateTime.date.isValid then
					localToDT := self.systemToLocalTime( wodMarineServiceDet.toDateTime );
					_table.accessCell( rowIndex, tdColIndex ).cellControl.CMUI_DateMask.setDate( localToDT.date );
					_table.accessCell( rowIndex, tdColIndex ).text := localToDT.date.asStringJMT;
					_table.accessCell( rowIndex, ttColIndex ).text := localToDT.time.asStringJMT;
				endif;
			else
				_table.accessCell( rowIndex, inclColIndex ).text := "0"; // NOT Selected
			endif;
			
		endforeach;
	endif;

epilog

	delete localResourceDict;
	
end;</source>
        <Parameter name="_table" type="CM_DataTable" usage="input"/>
        <Parameter name="_woVoyDtl" type="CM_WorkOrderVoyageDtl"/>
        <Parameter name="_context" type="Object"/>
    </JadeMethod>
    <JadeMethod name="popTblResourcesCrV3" id="14f3b122-ec5e-4659-824c-36a27a4d760f">
        <source>popTblResourcesCrV3( _table : CM_DataTable input; _woVoyDtl : CM_WorkOrderVoyageDtl; _harbour : HMS_Harbour );
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
26 April 2022	navgm20 ChangeRequest 52351: MTN - Work Order Maintenance Refactor - UI

*/

vars
	entDef : EntTableDef;
	resource : HMS_Resource;
	resourceType : HMS_ResourceType;
	
	rowIndex : Integer;
	rtColIndex : Integer;
	rColIndex : Integer;
	uColIndex : Integer;
	qColIndex : Integer;
	fdColIndex : Integer;
	ftColIndex : Integer;
	tdColIndex : Integer;
	ttColIndex : Integer;
	drColIndex : Integer;
	
	noEntryColour : Integer;
	wodMarineServiceDet : CM_WodMarineServiceDetail;
	localFromDT : TimeStamp;
	localToDT : TimeStamp;
	
	dateMask : CMUI_DateMask;

	wodVoyageCargoRequest : CM_WodVoyageCargoRequest;
	drIndex : Integer;
	debtor : CM_Debtor;
	resourceList: String;
	resIndex : Integer;
	
	wodPermitRequest : CM_WodPermitRequest;
	iter : Iterator;

begin

	if _woVoyDtl.CM_WodCargoRequest.myVoyageCargoRequest = null and _woVoyDtl.CM_WodCargoRequest.myPermitRequest = null then
		return;
	else
		wodVoyageCargoRequest := _woVoyDtl.CM_WodCargoRequest.myVoyageCargoRequest;
		wodPermitRequest := _woVoyDtl.CM_WodCargoRequest.myPermitRequest;
	endif;
	
	if self.dateMaskArray &lt;&gt; null and not self.dateMaskArray.isEmpty then
		self.dateMaskArray.purge;
	endif;
	_table.clear();
	
	entDef := app.myController.getEntTableDef(ETDef_HmsWoResourcesUsed);
	_table.setMyEntTableDef(entDef);	
	_table.setTblDataEntRowsFromDef(entDef);
	_table.hideColumnByColName( ETRow_Include );	//23 NOV 2018	NDL	TFS 41980
	
	_table.tabKey := J_key_Tab;
	
	rtColIndex := _table.getColumnByRowName( ETRow_MyResourceType );
	rColIndex := _table.getColumnByRowName( ETRow_MyResource );
	uColIndex := _table.getColumnByRowName( ETRow_UnitsUsed );
	qColIndex := _table.getColumnByRowName( ETRow_QuantityUnits );
	fdColIndex := _table.getColumnByRowName( ETRow_FromDate );
	ftColIndex := _table.getColumnByRowName( ETRow_FromTime );
	tdColIndex := _table.getColumnByRowName( ETRow_ToDate );
	ttColIndex := _table.getColumnByRowName( ETRow_ToTime );
	drColIndex := _table.getColumnByRowName( ETRow_Debtor );
	
	noEntryColour := _table.accessCell(1,1).backColor;
	
	if wodVoyageCargoRequest &lt;&gt; null then
		iter := wodVoyageCargoRequest.allMarineServiceDetails.createIterator;
	elseif wodPermitRequest &lt;&gt; null then
		iter := wodPermitRequest.allMarineServiceDetails.createIterator;
	endif;
	
	while iter.next( wodMarineServiceDet ) do
	
		resourceType := wodMarineServiceDet.myHMSResourceType;
		if resourceType = null then
			continue;
		else
			resourceList := resourceType.getResourcesForCmbList( self.cmbResource, _harbour );
			resource := wodMarineServiceDet.myHMSResource;
		endif;
		
		debtor := wodMarineServiceDet.myDebtor;
		drIndex := -1;
		resIndex := -1;
		
		_table.rows := _table.rows + 1;
		rowIndex := _table.rows;
		
		_table.accessCell( rowIndex, rtColIndex ).text := resourceType.description;
		_table.accessCell( rowIndex, rtColIndex ).itemObject := resourceType;
		
		_table.accessCell( rowIndex, rColIndex ).inputType := Table.InputType_ComboBox;
		_table.accessCell( rowIndex, rColIndex ).comboList := resourceList;
		if resource &lt;&gt; null then
			resIndex := self.cmbResource.findObject( resource );
			if resIndex &gt; 0 then
				_table.accessCell( rowIndex, rColIndex ).text := resource.description;
			endif;
		endif;
		
		if resourceType.isQuantityRequired then
			_table.accessCell( rowIndex, uColIndex ).inputType := Table.InputType_TextBox;
			_table.accessCell( rowIndex, uColIndex ).cellControl.TextBox.dataType := TextBox.DataType_Numeric;
			if resourceType.numDecimalPlaces &gt; 0 then
				_table.accessCell( rowIndex, uColIndex ).cellControl.TextBox.decimals := resourceType.numDecimalPlaces;
			endif;
		else
			_table.accessCell( rowIndex, uColIndex ).inputType := Table.InputType_None;
			_table.accessCell( rowIndex, uColIndex ).backColor := noEntryColour;	
		endif;
		if resourceType.quantityUnits &lt;&gt; null then
			_table.accessCell( rowIndex, qColIndex ).text := resourceType.quantityUnits;
		endif;
		_table.accessCell( rowIndex, qColIndex ).inputType := Table.InputType_None;
		_table.accessCell( rowIndex, qColIndex ).backColor := noEntryColour;
			
		if resourceType.isActionDateTimeRequired or resourceType.isFromToDateTimeRequired then
			dateMask := self.addCalendarControl();
			_table.accessCell( rowIndex, fdColIndex ).cellControl := dateMask;	
			_table.initCellForTime( _table.accessCell( rowIndex, ftColIndex ) );
		else
			_table.accessCell( rowIndex, fdColIndex ).inputType := Table.InputType_None;
			_table.accessCell( rowIndex, fdColIndex ).backColor := noEntryColour;
			_table.accessCell( rowIndex, ftColIndex ).inputType := Table.InputType_None;
			_table.accessCell( rowIndex, ftColIndex ).backColor := noEntryColour;
		endif;
		
		if resourceType.isActionDateTimeRequired or resourceType.isFromToDateTimeRequired then
			dateMask := self.addCalendarControl();
			_table.accessCell( rowIndex, tdColIndex ).cellControl := dateMask;
			_table.initCellForTime( _table.accessCell( rowIndex, ttColIndex ) );
		else
			_table.accessCell( rowIndex, tdColIndex ).inputType := Table.InputType_None;
			_table.accessCell( rowIndex, tdColIndex ).backColor := noEntryColour;
			_table.accessCell( rowIndex, ttColIndex ).inputType := Table.InputType_None;
			_table.accessCell( rowIndex, ttColIndex ).backColor := noEntryColour;
		endif;
		
		_table.accessCell( rowIndex, uColIndex ).text := null;
		_table.accessCell( rowIndex, fdColIndex ).text := null;
		_table.accessCell( rowIndex, ftColIndex ).text := null;
		_table.accessCell( rowIndex, tdColIndex ).text := null;
		_table.accessCell( rowIndex, ttColIndex ).text := null;
		_table.accessCell( rowIndex, uColIndex ).itemObject := wodMarineServiceDet;
	
		if wodMarineServiceDet.unitsUsed &gt; 0 then
			_table.accessCell( rowIndex, uColIndex ).text := wodMarineServiceDet.unitsUsed.asStringJMTWithPrecision( resourceType.numDecimalPlaces, false);
		endif;
		if wodMarineServiceDet.fromDateTime.date.isValid then
			localFromDT := self.systemToLocalTime( wodMarineServiceDet.fromDateTime );
				_table.accessCell( rowIndex, fdColIndex ).cellControl.CMUI_DateMask.setDate( localFromDT.date );
				_table.accessCell( rowIndex, fdColIndex ).text := localFromDT.date.asStringJMT;
				_table.accessCell( rowIndex, ftColIndex ).text := localFromDT.time.asStringJMT;
		endif;
		if wodMarineServiceDet.toDateTime.date.isValid then
			localToDT := self.systemToLocalTime( wodMarineServiceDet.toDateTime );
				_table.accessCell( rowIndex, tdColIndex ).cellControl.CMUI_DateMask.setDate( localToDT.date );
				_table.accessCell( rowIndex, tdColIndex ).text := localToDT.date.asStringJMT;
				_table.accessCell( rowIndex, ttColIndex ).text := localToDT.time.asStringJMT;
		endif;
		
		_table.accessCell( rowIndex, drColIndex ).inputType := Table.InputType_ComboBox;
		_table.accessCell( rowIndex, drColIndex ).comboList := debtorListForCombo;
		if debtor &lt;&gt; null then
			drIndex := self.cmbDebtor.findObject( debtor );
			if drIndex &gt; 0 then
				_table.accessCell( rowIndex, drColIndex ).text := debtor.name;
			endif;
		endif;
		
	endwhile;
	
epilog

	delete iter;
end;</source>
        <Parameter name="_table" type="CM_DataTable" usage="input"/>
        <Parameter name="_woVoyDtl" type="CM_WorkOrderVoyageDtl"/>
        <Parameter name="_harbour" type="HMS_Harbour"/>
    </JadeMethod>
    <JadeMethod name="popTblResourcesForShift" id="06a6c76a-841f-4639-a7c6-759dc493e7c7">
        <source>popTblResourcesForShift(	_table : CM_DataTable input; 
							_wodShiftMovement : CM_WodShiftMovement; 
							_wodExtension : CM_WodExtension;
							_resources : HMS_ResourceByTypeDict	);
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
23 April 2022	navhl20	ChangeRequest 52351: MTN - Work Order Maintenance Refactor - UI

*/

vars
entDef : EntTableDef;
	rowIndex : Integer;
	inclColIndex : Integer;
	rtColIndex : Integer;
	rColIndex : Integer;
	uColIndex : Integer;
	qColIndex : Integer;
	fdColIndex : Integer;
	ftColIndex : Integer;
	tdColIndex : Integer;
	ttColIndex : Integer;
	noEntryColour : Integer;
	resource : HMS_Resource;
	resourceType : HMS_ResourceType;
	wodMarineServiceDet : CM_WodMarineServiceDetail;
	dateMask : CMUI_DateMask;
	localFromDT : TimeStamp;
	localToDT : TimeStamp;

begin
	if self.dateMaskArray &lt;&gt; null and not self.dateMaskArray.isEmpty then
		self.dateMaskArray.purge;
	endif;
	_table.clear();
	
	entDef := app.myController.getEntTableDef(ETDef_HmsWoResourcesUsed);
	_table.setMyEntTableDef(entDef);	
	_table.setTblDataEntRowsFromDef(entDef);
	_table.hideColumnByColName( ETRow_Debtor );	//23 NOV 2018	NDL	TFS 41980
	
	_table.tabKey := J_key_Tab;
	
	inclColIndex := _table.getColumnByRowName( ETRow_Include );
	rtColIndex := _table.getColumnByRowName( ETRow_MyResourceType );
	rColIndex := _table.getColumnByRowName( ETRow_MyResource );
	uColIndex := _table.getColumnByRowName( ETRow_UnitsUsed );
	qColIndex := _table.getColumnByRowName( ETRow_QuantityUnits );
	fdColIndex := _table.getColumnByRowName( ETRow_FromDate );
	ftColIndex := _table.getColumnByRowName( ETRow_FromTime );
	tdColIndex := _table.getColumnByRowName( ETRow_ToDate );
	ttColIndex := _table.getColumnByRowName( ETRow_ToTime );
	
	noEntryColour := _table.accessCell(1,1).backColor;
	
	if _resources = null or _resources.isEmpty then 
		return;
	endif;
	
	foreach resource in _resources do
		//epr 3/7/18 don't show resources not for the terminals harbour
		if resource.myHarbour &lt;&gt; self.myTerminal.myHarbour then
			continue;
		endif;
		if resource.isNotAvailableForEntry then
			continue;
		endif;
		
		resourceType := resource.myResourceType;
		_table.rows := _table.rows + 1;
		rowIndex := _table.rows;
		
		if _wodExtension &lt;&gt; null then	
			wodMarineServiceDet := _wodExtension.allMarineServiceDetails.findWodMarineServiceDet(resource);
		elseif _wodShiftMovement &lt;&gt; null then
			wodMarineServiceDet := _wodShiftMovement.allMarineServiceDetails.findWodMarineServiceDet(resource);
		endif;
		
		_table.accessCell( rowIndex, rtColIndex ).text := resourceType.description;
		_table.accessCell( rowIndex, rtColIndex ).itemObject := resourceType;
		_table.accessCell( rowIndex, rColIndex ).text := resource.description;
		_table.accessCell( rowIndex, rColIndex ).itemObject := resource;
		if resourceType.isQuantityRequired then
			_table.accessCell( rowIndex, uColIndex ).inputType := Table.InputType_TextBox;
			_table.accessCell( rowIndex, uColIndex ).cellControl.TextBox.dataType := TextBox.DataType_Numeric;
			if resourceType.numDecimalPlaces &gt; 0 then
				_table.accessCell( rowIndex, uColIndex ).cellControl.TextBox.decimals := resourceType.numDecimalPlaces;
			endif;
		else
			_table.accessCell( rowIndex, uColIndex ).inputType := Table.InputType_None;
			_table.accessCell( rowIndex, uColIndex ).backColor := noEntryColour;	
		endif;
		if resourceType.quantityUnits &lt;&gt; null then
			_table.accessCell( rowIndex, qColIndex ).text := resourceType.quantityUnits;
		endif;
		_table.accessCell( rowIndex, qColIndex ).inputType := Table.InputType_None;
		_table.accessCell( rowIndex, qColIndex ).backColor := noEntryColour;
			
		if resourceType.isActionDateTimeRequired or resourceType.isFromToDateTimeRequired then
			dateMask := self.addCalendarControl();
			_table.accessCell( rowIndex, fdColIndex ).cellControl := dateMask;	
			_table.initCellForTime( _table.accessCell( rowIndex, ftColIndex ) );
		else
			_table.accessCell( rowIndex, fdColIndex ).inputType := Table.InputType_None;
			_table.accessCell( rowIndex, fdColIndex ).backColor := noEntryColour;
			_table.accessCell( rowIndex, ftColIndex ).inputType := Table.InputType_None;
			_table.accessCell( rowIndex, ftColIndex ).backColor := noEntryColour;
		endif;
		if resourceType.isActionDateTimeRequired or resourceType.isFromToDateTimeRequired then
			dateMask := self.addCalendarControl();
			_table.accessCell( rowIndex, tdColIndex ).cellControl := dateMask;
			_table.initCellForTime( _table.accessCell( rowIndex, ttColIndex ) );
		else
			_table.accessCell( rowIndex, tdColIndex ).inputType := Table.InputType_None;
			_table.accessCell( rowIndex, tdColIndex ).backColor := noEntryColour;
			_table.accessCell( rowIndex, ttColIndex ).inputType := Table.InputType_None;
			_table.accessCell( rowIndex, ttColIndex ).backColor := noEntryColour;
		endif;
		
		_table.accessCell( rowIndex, uColIndex ).text := null;
		_table.accessCell( rowIndex, fdColIndex ).text := null;
		_table.accessCell( rowIndex, ftColIndex ).text := null;
		_table.accessCell( rowIndex, tdColIndex ).text := null;
		_table.accessCell( rowIndex, ttColIndex ).text := null;
		_table.accessCell( rowIndex, uColIndex ).itemObject := wodMarineServiceDet;
		if wodMarineServiceDet &lt;&gt; null then
			_table.accessCell( rowIndex, inclColIndex ).text := "1"; //Selected
			if wodMarineServiceDet.unitsUsed &gt; 0 then
				_table.accessCell( rowIndex, uColIndex ).text := wodMarineServiceDet.unitsUsed.asStringJMTWithPrecision( resourceType.numDecimalPlaces, false);
			endif;
			if wodMarineServiceDet.fromDateTime.date.isValid then
				localFromDT := self.systemToLocalTime( wodMarineServiceDet.fromDateTime );
					_table.accessCell( rowIndex, fdColIndex ).cellControl.CMUI_DateMask.setDate( localFromDT.date );
					_table.accessCell( rowIndex, fdColIndex ).text := localFromDT.date.asStringJMT;
					_table.accessCell( rowIndex, ftColIndex ).text := localFromDT.time.asStringJMT;
			endif;
			if wodMarineServiceDet.toDateTime.date.isValid then
				localToDT := self.systemToLocalTime( wodMarineServiceDet.toDateTime );
					_table.accessCell( rowIndex, tdColIndex ).cellControl.CMUI_DateMask.setDate( localToDT.date );
					_table.accessCell( rowIndex, tdColIndex ).text := localToDT.date.asStringJMT;
					_table.accessCell( rowIndex, ttColIndex ).text := localToDT.time.asStringJMT;
			endif;
		else
			_table.accessCell( rowIndex, inclColIndex ).text := "0"; // NOT Selected
		endif;
		
		if _wodExtension = null then	//19 Feb 2019	
			if _wodShiftMovement = null or _wodShiftMovement.allMarineServiceDetails.isEmpty then
				_table.accessCell( rowIndex, inclColIndex ).text := "1"; //Selected
			endif;
		endif;
	endforeach;
epilog

end;</source>
        <Parameter name="_table" type="CM_DataTable" usage="input"/>
        <Parameter name="_wodShiftMovement" type="CM_WodShiftMovement"/>
        <Parameter name="_wodExtension" type="CM_WodExtension"/>
        <Parameter name="_resources" type="HMS_ResourceByTypeDict"/>
    </JadeMethod>
    <JadeMethod name="populateAvailableWORels" id="d48fe132-9af4-46d6-afcf-37a3cc69219a">
        <source>populateAvailableWORels( _wodtl : CM_WodReleaseExtension );
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
08 April 2022	navhl20	ChangeRequest 52351: MTN - Work Order Maintenance Refactor - UI

*/

vars

	wodDetail : CM_WorkOrderDtl;
	wo : CM_WorkOrder;
	iter : Iterator;
	startObject : CM_WorkOrder;
	prospects : CM_WorkOrderByIdDict;
	index : Integer;

begin

	self.cmbRelExtWORel.clear();
	self.cmbRelExtWORel.enabled := true;
	
	create prospects transient;  // The Cargo Release Work Orders that are seemingly in the right state to be allowed to be extended.
								// i.e. Cargo Releases that are Approvced or Part Complete 
	
	iter := self.myTerminal.allWorkOrdersByStatus.createIterator;
	startObject := self.myTerminal.allWorkOrdersByStatus.getAtKeyGeq( WO_STATUS_APPROVED );
	if startObject &lt;&gt; null then
		iter.startAtObject( startObject );
		while iter.next( wo ) do
			if wo.taskStatus &lt;&gt; WO_STATUS_APPROVED then
				break;
			endif;
			if wo.isWorkOrderForRelease then
				prospects.addNoDuplicates( wo, false );
			endif;
		endwhile;
	endif;
	delete iter;
	
	iter := self.myTerminal.allWorkOrdersByStatus.createIterator;
	startObject := self.myTerminal.allWorkOrdersByStatus.getAtKeyGeq( WO_STATUS_PARTCOMPLETE );
	if startObject &lt;&gt; null then
		iter.startAtObject( startObject );
		while iter.next( wo ) do
			if wo.taskStatus &lt;&gt; WO_STATUS_PARTCOMPLETE then
				break;
			endif;
			if wo.isWorkOrderForRelease then
				prospects.addNoDuplicates( wo, false );
			endif;
		endwhile;
	endif;
	delete iter;
	
	
	foreach wo in prospects discreteLock  do
		
		if not wo.allWoDtls.first.CM_WodRelease.isAvailableForExtension() then
			continue;
		endif;
		
		index := self.cmbRelExtWORel.addItem( wo.id );
		self.cmbRelExtWORel.itemObject[index] := wo.allWoDtls.first;
		
	endforeach;
	
	// And lastly include the one associated with the current Cargo Release Extension work order 
	// Because we may just be displaying one that is past the available for adding state. 
	if _wodtl &lt;&gt; null and _wodtl.myReleaseWorkOrder &lt;&gt; null then
		self.cmbRelExtWORel.enabled := false;
		index := self.cmbRelExtWORel.findObject( _wodtl.myReleaseWorkOrder );
		if index &lt; 1 then
			index := self.cmbRelExtWORel.addItem( _wodtl.getMyParent.id );
			self.cmbRelExtWORel.itemObject[index] := _wodtl.myReleaseWorkOrder;
		endif;
	endif;

epilog

	delete iter;
	delete prospects;

end;</source>
        <Parameter name="_wodtl" type="CM_WodReleaseExtension"/>
    </JadeMethod>
    <JadeMethod name="populateCmbDebtor" id="00f84993-573a-4e34-8cc6-e82a6481dede">
        <updating/>
        <source>populateCmbDebtor() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 May 2022	navhl20	ChangeRequest 52351: MTN - Work Order Maintenance Refactor - UI

*/

vars
	debtor : CM_Debtor;
	drIndex : Integer;

begin

	self.debtorListForCombo := null;

	self.cmbDebtor.clear();
	foreach debtor in app.myRoot.myRootCompany.debtors do
		if debtor.consignors.isEmpty then
			continue;
		endif;
		self.cmbDebtor.itemObject[ self.cmbDebtor.addItem( debtor.name ) ] := debtor;
	endforeach;
	
	if self.cmbDebtor.listCount &gt; 0 then
		foreach drIndex in 1 to self.cmbDebtor.listCount do
			if drIndex &gt; 1 then
				self.debtorListForCombo := self.debtorListForCombo &amp; Tab;
			endif;
			self.debtorListForCombo := self.debtorListForCombo &amp; self.cmbDebtor.itemText[ drIndex ];
		endforeach;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="populateCmbDebtors" id="7410afd2-ba51-4816-aea4-eae6a5652e89">
        <updating/>
        <source>populateCmbDebtors(_combo : CMUI_ComboBox input; _debtor : CM_Debtor) updating;
/*
Purpose:			

Date		Who		Reason
// ### TFS CR 56814 TASK 56813 06JUL2023 NAVAB1
*/

vars
	debtor : CM_Debtor;
	dterm : CM_DebtorTerminal;
	drIndex : Integer;

begin


	_combo.clear();
	_combo.sorted := true;
	foreach dterm in self.myTerminal.allDebtorTerminals discreteLock do
		debtor := dterm.myDebtor;
		_combo.itemObject[ _combo.addItem( debtor.name ) ] := debtor;
	endforeach;
	
	_combo.sorted := false;
	_combo.addItemAt("",1);
	
	if _debtor &lt;&gt; null then
		if _combo.findObject(_debtor) &gt; 0 then
			_combo.listObject := _debtor;
		endif;
	
	endif;
epilog

end;</source>
        <Parameter name="_combo" type="CMUI_ComboBox" usage="input"/>
        <Parameter name="_debtor" type="CM_Debtor"/>
    </JadeMethod>
    <JadeMethod name="populateOOWConfirm" id="3abce311-8e23-4733-bed3-54c2521c63dd">
        <source>populateOOWConfirm();
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
25 April 2022	navhl20	ChangeRequest 52351: MTN - Work Order Maintenance Refactor - UI

*/

vars
	dynaDict : DynaDictionary;
	holdId : String;
	obj : Object;
	job : CM_Job;
	holdJob : CM_VoyageHoldJob;
	comboValues : String; 
begin
	self.setupOOWConfirmTable();
	
	create dynaDict transient;
	dynaDict.setMembership( CM_VoyageHoldJob );
	dynaDict.addExternalKey(String, 100, false, false);
	dynaDict.endKeys(true);
	
	foreach job in self.myVoyage.allVoyageJobs do
		if job.isKindOf(CM_VoyageHoldJob) then
			if job.status &lt;&gt; JOB_COMPLETE then
				dynaDict.putAtKey(job.CM_VoyageHoldJob.getHoldId, job);
			endif;
		endif;
	endforeach;
	
	foreach obj in dynaDict do
		holdJob := obj.CM_VoyageHoldJob;
		if holdId &lt;&gt; null then
			//we have loaded at least one
			if holdId &lt;&gt; holdJob.getHoldId then
				self.addHoldSubTotalLine( holdId );
			endif;
		endif;
		self.addHoldJobToOOWConfrm( holdJob, comboValues );
		holdId := holdJob.getHoldId;
	endforeach;
	
	if holdId &lt;&gt; null then
		self.addHoldSubTotalLine( holdId );
	endif;
	
	self.setPermitTotalDays(false);
epilog
	delete dynaDict;
end;</source>
    </JadeMethod>
    <JadeMethod name="queryUnload" id="2a52bf98-61e1-43d1-8700-680297100fcb">
        <controlMethod name="Form::queryUnload"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>queryUnload(cancel: Integer io; reason: Integer) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 Oct 2023 navhl20 Bug 60373: MTN - Expected to see a validation message to save the changes before closing the work order form.

*/

vars

begin
	if reason = self.QueryUnload_User and not self.doCancel() then
		cancel := 1;
	endif;
epilog

end;</source>
        <Parameter name="cancel" type="Integer" usage="io"/>
        <Parameter name="reason" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="releaseRequestAddOrUpdate" id="834e7802-0bd2-462d-ae9f-57b484206a14">
        <source>releaseRequestAddOrUpdate(_releaseRequest : CM_BulkRelease input; _defaultType : Integer; _masterMenuAction : CMUI_MenuAction; _context : Integer; _mode :Integer);
/*
----------   ----------  --------------------------------------------------
Purpose:	_mode should equal one of 	CMUI_TreeViewForm.Mode_Add
										CMUI_TreeViewForm.Mode_Update
										CMUI_TreeViewForm.Mode_View


Changed On   Changed By  Reason
----------   ----------  --------------------------------------------------
23 Dec 2024	navbs1	Initial creation Bug MTN-33524: MTN - Notifications in the work order details screen update the release request assigned as a new work order is created
*/
vars
	frm				: CMUI_TreeViewForm;
	scm				: Schema;
	assistantClass,
	frmClass		: Class;
	
begin
	scm 			:= rootSchema.getSchema('GateSchema');
	frmClass 		:= scm.getClass('GTE_ReleaseRequests');
	assistantClass  := scm.getClass('GTE_Assistant');
	
	frm := app.loadForm(frmClass, assistantClass, false, false, false, self.myTerminal, _masterMenuAction).CMUI_TreeViewForm;
	if frm = null then
		return;
	endif;
	
	if _mode = CMUI_TreeViewForm.Mode_Add then 
	
		if _defaultType &lt; 1 then
			frm.setPropertyValue('defaultReleaseType', BR_TYPE_PACKING);
		else
			frm.setPropertyValue('defaultReleaseType', _defaultType);		
		endif;
		
		if  _releaseRequest.allReserveDetails.isEmpty then
			frm.setDefaultsForNewMaster(_releaseRequest);
		endif;
	endif;
	
	frm.myParentForm := self;
	frm.setContext(_context);										 
	frm.showForObject(_releaseRequest, _mode);
end;</source>
        <Parameter name="_releaseRequest" type="CM_BulkRelease" usage="input"/>
        <Parameter name="_defaultType" type="Integer"/>
        <Parameter name="_masterMenuAction" type="CMUI_MenuAction"/>
        <Parameter name="_context" type="Integer"/>
        <Parameter name="_mode" type="Integer"/>
    </JadeMethod>
