// ---------------------------------------------------------------------------
// Created:		10 September 2007 By Andrew Bishop cnwab1
// ---------------------------------------------------------------------------
// 17/08/2011	cnwcs5	CCMS MES 1033 RORO KPI
vars

begin
	if self.fldMain.topSheet = self.shtMoves then
		self.kpiDetail := self.kpiDetail + 1;
		
		if self.kpiDetail &gt; self.KPIDetail_Totals then
			self.kpiDetail := self.KPIDetail_ALL;
		endif;
		
		self.showHideDetail();
	elseif self.fldMain.topSheet = self.shtBays then
		self.hideDetail := not self.hideDetail;
		
		self.showBayStats();
	endif;
end;</source>
