    <JadeMethod name="getDisplayStringForAttribute" id="af460b67-d087-4fee-b1ba-74022c18c510">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 09/04/2020	jlgdap1		Initial creation TFS 49003 MTN API Inline Agent
// 13/07/2020   cnwma1  	Bug 49243: MTN - Cargo Chain Web Service Callback INI value
// 21 Sep 2020  cnwma1      ChangeRequest 49906: MTN - Ops View External Webservice
// 15/03/2021	navmd1		TFS 49052 MACS3 Vessel Library API

vars

begin
	if _attrName = ETRow_WebServiceType then
		return ExternalWebServiceNavisMACS3;
	endif;
	
	if _attrName = ETRow_CreditWarning then
		return self.creditWarnThreshold.String;
	elseif _attrName = ETRow_FeedID then
		return self.feedId;
	endif;
	
	return inheritMethod(_attrName, _short);
epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setExtras" id="50d994ad-ef51-4e56-a197-7ca0b9ff1ba1">
        <updating/>
        <source>setExtras(	_creditValue: Integer; _feedId: String) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
15 March 2021	navmd1	Initial creation TFS 49052 MACS3 Vessel Library API

*/

vars

begin

	self.raiseExceptionIfNotTransient(method);

	self.creditWarnThreshold := _creditValue;
	self.feedId := _feedId;
	
epilog

end;</source>
        <Parameter name="_creditValue" type="Integer"/>
        <Parameter name="_feedId" type="String"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="5a7c3eab-9dad-40c1-9db9-78647397d12f">
        <updating/>
        <source>setForUpdate(_extWebService: CM_ExternalWebServiceDef) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 09/04/2020	jlgdap1		Initial creation TFS 49003 API Inline Agent
//
vars

begin
	inheritMethod(_extWebService);
	
	self.apiKey := _extWebService.CM_NavisMACS3Service.apiKey;
	self.creditWarnThreshold := _extWebService.CM_NavisMACS3Service.creditWarnThreshold;
	self.feedId := _extWebService.CM_NavisMACS3Service.feedId;
	self.valIMOOnCreate := _extWebService.CM_NavisMACS3Service.valIMOOnCreate;
epilog

end;</source>
        <Parameter name="_extWebService" type="CM_ExternalWebServiceDef"/>
    </JadeMethod>
    <JadeMethod name="validateMe" id="220965d7-1ab0-4969-bc35-635df8baf31a">
        <source>validateMe() protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 09/04/2020	jlgdap1		Initial creation TFS 49003 API Inline Agent
// 02/02/2021	jlgmd1		TFS 49052 MACS3 Vessel Library API
//
vars
	wsDef	: CM_ExternalWebServiceDef;
	realObj : SelfType;
begin
	inheritMethod();
	
	// There can be only one
	wsDef := app.myRoot.allExternalWebServices[self.getExternalWebServiceType];
	if wsDef &lt;&gt; null then
		//Only one active at a time.
		if self.isTransient then
			realObj := self.pxyGetRealObject();
		else
			realObj := self;
		endif;
		if wsDef &lt;&gt; realObj then
			app.raiseCMException2( ERR_Active_ExtWebDef, self.getExternalWebServiceType , wsDef.name, null, null );
		endif;
	endif;
	
	if self.apiKey = null then
		app.raiseCMException(API_Key_Required, null, null);
	endif;
epilog

end;
</source>
        <access>protected</access>
    </JadeMethod>
</Class>
