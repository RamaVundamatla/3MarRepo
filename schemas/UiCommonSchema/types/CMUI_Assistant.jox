    <JadeMethod name="showMasterDifferenceWarning" id="bc6a429a-4ecf-4300-ad1c-3cad8d9636c9">
        <source>showMasterDifferenceWarning(_field, _desc1, _desc2 : String) : Integer;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21 September 2009	cnwjk3	sfw1035

*/

vars

begin
	return app.msgBox(app.getErrorString3(WARN_FLEETFILE_DISCREP, _field, _desc1, _desc2) &amp; Cr &amp; 
		app.getErrorString(WARN_FLEETFILE_OK) ,
