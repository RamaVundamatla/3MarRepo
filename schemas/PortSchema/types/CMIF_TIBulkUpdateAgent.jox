    <JadeMethod name="setupAgentForSimpleUpdate" id="5fc164fc-c710-4105-9c2f-39afca66ea7e">
        <updating/>
        <source>setupAgentForSimpleUpdate(_changedFieldsDict : CMIF_EditObjectByAttrNameDict; _masterTI: CM_TrackedItem; _allProxyObjects : CM_ObjectSet) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 May 2024	navra1	Initial creation for //navra1 - TFS 64033 - 28th May 2024

*/

vars
	tiSet : CM_TISet;
	obj : Object;
	fieldChanged : CMIF_EditObject;	
	changedFieldsDict : CMIF_EditObjectByAttrNameDict;
	ti, pxyTi : CM_TrackedItem;
	value : String;	
	stopTableTemplate : CM_StopTableTemplate;					//navra1 - BUG 64464 - 17th June 2024	
	stopCriteria : CM_StopCriteria;								//navra1 - BUG 64464 - 17th June 2024
	allCrit : CM_YACriteriaArray;								//navra1 - BUG 64464 - 17th June 2024
	crit : CM_YACriteria;										//navra1 - BUG 64464 - 17th June 2024
	critTypeArrString : StringArray;							//navra1 - BUG 64464 - 17th June 2024
	allStopTableTemplates : CM_StopTableTplByStopTableDict;		//navra1 - BUG 64464 - 17th June 2024
begin	
	if _masterTI = null then
		app.writeLog("MasterTI was null, so returning", LogERROR);
		return;
	endif;	
	
	//create agent to pass to the trx
	//put all to be updated objects into a TISet
	create tiSet transient;
	foreach obj in _allProxyObjects do
		if obj.isKindOf(CM_TrackedItem) then
			ti := obj.CM_Object.pxyGetRealObject().CM_TrackedItem;
			tiSet.add(ti);
		endif;
	endforeach;	
	
	if _masterTI.customExportEntryNumber &lt;&gt; null then
		self.masterHasCustomsEntryNumber := true;
	endif;
	
	if not tiSet.isEmpty() then
		self.init(tiSet);
	endif;
	
	//navra1 - BUG 64464 - 17th June 2024 - start	
	create critTypeArrString transient;
	if _masterTI.myTerminal &lt;&gt; null then
		allStopTableTemplates := _masterTI.myTerminal.allStopTableTemplates;
		foreach stopTableTemplate in allStopTableTemplates do
			if stopTableTemplate.myStopTable &lt;&gt; null then
				stopCriteria := stopTableTemplate.myStopTable.myStopCriteria;
				if stopCriteria &lt;&gt; null then
					if stopCriteria.allCriteria &lt;&gt; null then
						allCrit := stopCriteria.allCriteria;
						foreach crit in allCrit do
							if crit.myYACriteriaType.isKindOf(CM_YATypeColour) then
								if not critTypeArrString.includes("COLOUR") then
									critTypeArrString.add("COLOUR");
								endif;
							elseif crit.myYACriteriaType.isKindOf(CM_YATypeMark) then
								if not critTypeArrString.includes("MARK") then
									critTypeArrString.add("MARK");
								endif;
							elseif crit.myYACriteriaType.isKindOf(CM_YATypeServiceOrder) then
								if not critTypeArrString.includes("SERVICEORDER") then
									critTypeArrString.add("SERVICEORDER");
								endif;
							elseif crit.myYACriteriaType.isKindOf(CM_YATypeInvoiceContractId) then
								if not critTypeArrString.includes("CONTRACTID") then
									critTypeArrString.add("CONTRACTID");
								endif;
							elseif crit.myYACriteriaType.isKindOf(CM_YASpecialStow) then
								if not critTypeArrString.includes("SPLSTOW") then
									critTypeArrString.add("SPLSTOW");
								endif;
							endif;
						endforeach;
					endif;
				endif;
			endif;
		endforeach;		
	endif;
	self.canStopBeAffected := false;
	foreach fieldChanged in _changedFieldsDict do
		if fieldChanged.attrName = ETRow_Colour then
			if critTypeArrString.includes("COLOUR") then
				self.canStopBeAffected := true;
				break;				
			endif;
		elseif fieldChanged.attrName = ETRow_Mark then
			if critTypeArrString.includes("MARK") then
				self.canStopBeAffected := true;
				break;
			endif;		
		elseif fieldChanged.attrName = ETRow_ServiceOrder then
			if critTypeArrString.includes("SERVICEORDER") then
				self.canStopBeAffected := true;
				break;
			endif;
		elseif fieldChanged.attrName = ETRow_InvoiceContractId then
			if critTypeArrString.includes("CONTRACTID") then
				self.canStopBeAffected := true;
				break;
			endif;
		elseif fieldChanged.attrName = ETRow_SpecialStow then
			if critTypeArrString.includes("SPLSTOW") then
				self.canStopBeAffected := true;
				break;
			endif;		
		endif;
	endforeach;
	//navra1 - BUG 64464 - 17th June 2024 - end
	
	//init the fields and values for the agent	
	changedFieldsDict := _changedFieldsDict;
	
	foreach fieldChanged in changedFieldsDict do		
		if fieldChanged.attrName = ETRow_Mark then
			value := _masterTI.getPropertyValue(CM_TrackedItem::mark.name).String;
			self.addProperty(ETRow_Mark, CM_TrackedItem::mark, value);
		elseif fieldChanged.attrName = ETRow_MarkNumber then
			value := _masterTI.getPropertyValue(CM_TrackedItem::markNumber.name).String;
			self.addProperty(ETRow_MarkNumber, CM_TrackedItem::markNumber, value);
		elseif fieldChanged.attrName = ETRow_Colour then
			if _masterTI.isKindOf(CM_Car) then
				value := _masterTI.getPropertyValue(CM_Car::colour.name).String;
				self.addProperty(ETRow_Colour, CM_Car::colour, value);
			elseif _masterTI.isKindOf(CM_BreakBulkGeneric) then
				value := _masterTI.getPropertyValue(CM_BreakBulkGeneric::colour.name).String;
				self.addProperty(ETRow_Colour, CM_BreakBulkGeneric::colour, value);
			endif;	
		elseif fieldChanged.attrName = ETRow_Remarks then
			value := _masterTI.getPropertyValue(CM_TrackedItem::remarks.name).String;
			self.addProperty(ETRow_Remarks, CM_TrackedItem::remarks, value);
		elseif fieldChanged.attrName = ETRow_PurchaseOrder then
			value := _masterTI.getPropertyValue(CM_TrackedItem::purchaseOrder.name).String;
			self.addProperty(ETRow_PurchaseOrder, CM_TrackedItem::purchaseOrder, value);
		elseif fieldChanged.attrName = ETRow_ServiceOrder then
			value := _masterTI.getPropertyValue(CM_TrackedItem::serviceOrder.name).String;
			self.addProperty(ETRow_ServiceOrder, CM_TrackedItem::serviceOrder, value);
		elseif fieldChanged.attrName = ETRow_InvoiceContractId then														//navra1 - TFS 64368/Task 64370 - 4th June 2024
			value := _masterTI.getPropertyValue(CM_TrackedItem::contractId.name).String;								//navra1 - TFS 64368/Task 64370 - 4th June 2024
			self.addProperty(ETRow_InvoiceContractId, CM_TrackedItem::contractId, value);								//navra1 - TFS 64368/Task 64370 - 4th June 2024
		elseif fieldChanged.attrName = ETRow_SpecialStow then															//navra1 - TFS 64368/Task 64379 - 4th June 2024
			value := _masterTI.getPropertyValue(CM_TrackedItem::specialStow.name).String;								//navra1 - TFS 64368/Task 64379 - 4th June 2024
			self.addProperty(ETRow_SpecialStow, CM_TrackedItem::specialStow, value);									//navra1 - TFS 64368/Task 64379 - 4th June 2024
		elseif fieldChanged.attrName = ETRow_CustomExportEntryNumber then												//navra1 - TFS 64368/Task 64378 - 4th June 2024
			value := _masterTI.getPropertyValue(CM_TrackedItem::customExportEntryNumber.name).String;					//navra1 - TFS 64368/Task 64378 - 4th June 2024
			self.addProperty(ETRow_CustomExportEntryNumber, CM_TrackedItem::customExportEntryNumber, value);			//navra1 - TFS 64368/Task 64378 - 4th June 2024			
		endif;
	endforeach;
	
	//navra1 - BUG 64464 - 8th July 2024 - start
	//update the proxies to have the updated values - required for updating stops
	foreach ti in self.allTIs discreteLock do
		pxyTi := ti.pxyGetProxyObject();
		if pxyTi = null then
			continue;
		endif;
		self.updateChangedPropertiesOfTI(pxyTi);
	endforeach;
	//navra1 - BUG 64464 - 8th July 2024 - end

epilog
	delete tiSet;	
	delete critTypeArrString;						//navra1 - BUG 64464 - 17th June 2024
end;</source>
        <Parameter name="_changedFieldsDict" type="CMIF_EditObjectByAttrNameDict"/>
        <Parameter name="_masterTI" type="CM_TrackedItem"/>
        <Parameter name="_allProxyObjects" type="CM_ObjectSet"/>
    </JadeMethod>
    <JadeMethod name="updateChangedPropertiesOfTI" id="44729cd1-3a4a-4899-a47c-3d528c56ac9f">
        <updating/>
        <source>updateChangedPropertiesOfTI(_ti : CM_TrackedItem input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 Jul 2024	navra1	Initial creation for //navra1 - BUG 64464 - 8th July 2024
24 Feb 2025	navhl20 Bug MTN-34042: POL - Can't Bulk Edit Customs Export Delivery Order on Tracked Items
*/

vars
	customsEntryAdded 	: Boolean;
	tisCompleted 		: Integer;
	editTrn 			: CM_Edit;
	propAgent 			: CMIF_TIBulkUpdateProperty;
	beforeStr, 
	afterStr, 
	fieldValue 			: String;
	prop    			: Property;
	propName 			: String;
begin

	if _ti = null then
		return;
	endif;	
	
	foreach propAgent in self.allProperties discreteLock do
		
		prop := propAgent.myProperty;			//24.02.2024 navma1 #MTN-34042
		
		if prop = null then
			continue;
		endif;

		propName := prop.name;				  //24.02.2024 navma1 #MTN-34042
		
		if propName = ETRow_SpecialStow then												//navra1 - TFS 64368/Task 64379 - 4th June 2024
			_ti.setSpecialStow(propAgent.valueStr);											//navra1 - TFS 64368/Task 64379 - 4th June 2024
			continue;																		//navra1 - TFS 64368/Task 64379 - 4th June 2024
		endif;																				//navra1 - TFS 64368/Task 64379 - 4th June 2024
		
		if propName = ETRow_CustomExportEntryNumber then									//navra1 - TFS 64368/Task 64378 - 4th June 2024
			_ti.setCusExpEntryNumberWithMyVoy(propAgent.valueStr);							//navra1 - TFS 64368/Task 64378 - 4th June 2024
			continue;																		//navra1 - TFS 64368/Task 64378 - 4th June 2024
		endif;																				//navra1 - TFS 64368/Task 64378 - 4th June 2024
		
		if propName = ETRow_ContractId then													//navra1 - TFS 64368/Task 64370 - 3rd July 2024
			_ti.setContractId(propAgent.valueStr);											//navra1 - TFS 64368/Task 64370 - 3rd July 2024
			_ti.validateContractId();														//navra1 - TFS 64368/Task 64370 - 3rd July 2024
			if app.myPassport.hasErrors() then												//navra1 - TFS 64368/Task 64370 - 3rd July 2024
				break;																		//navra1 - TFS 64368/Task 64370 - 3rd July 2024
			endif;																			//navra1 - TFS 64368/Task 64370 - 3rd July 2024
			
			continue;																		//navra1 - TFS 64368/Task 64370 - 3rd July 2024
		endif;																				//navra1 - TFS 64368/Task 64370 - 3rd July 2024
		
		beforeStr := _ti.getPropertyValue(propName).String;		
		afterStr  := propAgent.valueStr;
		_ti.setPropertyValue(propName, afterStr);
		
		
		//this method is called to update thew real object and also the proxy, create transactions only while updating the real objects not while updating proxies
		if not _ti.pxyIsProxy() then
			fieldValue := app.formatForEditTransaction( propName , beforeStr, afterStr);
	
			if editTrn = null then
				editTrn := _ti.createEditTransaction(fieldValue);
			else
				editTrn.addFieldValue(fieldValue);
			endif;
		endif;
	endforeach;	
epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="updateStopsForTI" id="c749759a-fc17-4287-b6cc-3fb28b3d78b4">
        <source>updateStopsForTI(_ti : CM_TrackedItem input; _stopsBeforeChanges : IntegerArray; _customsEntryNumberAdded : Boolean; _passport : CM_Passport input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 July 2024	navra1	Initial creation for //navra1 - BUG 64464 - 1st July 2024

*/

vars
	stop, pxyStop : CM_Stops;
	allStops : CM_StopsByIdDict;
	stopsToBeApplied,
	stopsAfterChanges : IntegerArray;
	isStopSame, hasAllStopsApplied,
	hasCancelledStops : Boolean;
	pxyTI : CM_TrackedItem;
begin	
	create stopsAfterChanges transient;
	create stopsToBeApplied transient;
	
	if _customsEntryNumberAdded then		
		_ti.removeStopsToBeProcessed(StopProcessEDICustomImport); //cnwrs1 July 2007 par 14494 stops
	endif;
	
	//if nothing in the criteria that can affect stops changed, so return
	if not self.canStopBeAffected then
		return;
	endif;
	
	pxyTI := _ti.pxyGetProxyObject();
	if pxyTI = null then
		pxyTI := _ti.pxyCreateUpdateProxy();
	endif;	
		
	pxyTI.checkProxyStopApplicable();	
	
	_ti.updateProxyStops(pxyTI.getAllStops(), null, false, _passport);	// pars 28390 and 28930 // TFS 39133
	
	create stopsAfterChanges transient;
	create stopsToBeApplied transient;
	
	_ti.getAllMatchingStopIDs(stopsAfterChanges, stopsToBeApplied);
	
	// Are the stops that matches the TI same as before?
	isStopSame := _stopsBeforeChanges.compareTheSame(stopsAfterChanges); //07/02/2023	navkc1 CR 61168 Task 62372
	
	// Check are the stops to be applied have been processed earlier in this method 
	_ti.checkHasStopBeenProcessed(stopsToBeApplied, pxyTI, hasCancelledStops);
	
	// Have all the stops to be applied processed earlier?
	hasAllStopsApplied := stopsToBeApplied.isEmpty();
	
	if (not isStopSame
		or not hasAllStopsApplied)
		and not hasCancelledStops
			then
		
		if _ti.isTranshipItem then
			_ti.setStopsForTranship();
		elseif _ti.isExport then
			_ti.setStopsForExport();
		elseif _ti.isImport then
			_ti.setStopsForImport();
		endif;
	endif;
	
	stopsAfterChanges.clear();
	stopsToBeApplied.clear();

epilog
	delete allStops;	
	delete stopsAfterChanges;
	delete stopsToBeApplied;
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_stopsBeforeChanges" type="IntegerArray"/>
        <Parameter name="_customsEntryNumberAdded" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
