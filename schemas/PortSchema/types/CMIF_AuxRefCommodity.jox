    <JadeMethod name="initializeForActivity" id="2208bfe7-f236-40f0-8d43-142a7eb02b63">
        <updating/>
        <source>initializeForActivity(_any: Any; _ewsOpsView: CM_EWSActivityOpsview) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 May 2022	navsp1	Initial creation TFS#53104

*/

vars
	cargoType : CM_CargoType;
begin
	inheritMethod(_any, _ewsOpsView);
	self.tableName		:= self.Aux_Ref_Commodity;
	
	if _ewsOpsView.dataAction = BGP_OpsViewWSRequest.OPS_ACTION_DELETE then
		self.gkey		:= self.generateFullGKey(_any, "");
		return;
	endif;
	
	if _any.isKindOf(CM_CargoType) then
		cargoType	:= _any.CM_CargoType;
		cargoType.initializeForActivity(_ewsOpsView,self);
	endif;
epilog

end;</source>
        <Parameter name="_any" type="Any"/>
        <Parameter name="_ewsOpsView" type="CM_EWSActivityOpsview"/>
    </JadeMethod>
</Class>
