Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28/01/2011	cnwdap1	Initial creation PAR #26785 - reminplemented at the CMUI_ReceiveCargoForm leve
*/
vars

begin

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setColumnsAndControlWidth" id="818e7366-3ac6-44cc-9a7d-af62e2bc4e54">
        <updating/>
        <source>setColumnsAndControlWidth(_columns, _controlWidth : Integer) updating;
/*
Purpose:			Set the number of columns that controls will be displayed in,
					and the default maximum width for the controls embedded in CMUI_FieldFrame controls

Parameters:			_columns - number of columns to display controls in
					_controlWidth - default maximum control width

Return Value:		None

Date		Who		Reason
15 July 2009	cnwdap1	Initial creation
*/
vars

begin
	self.numberOfColumns 		:= _columns;
	self.defaultControlWidth 	:= _controlWidth;
epilog

end;</source>
        <Parameter name="_columns" type="Integer"/>
        <Parameter name="_controlWidth" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setIsNewItem" id="aca7a92a-156e-43c3-9726-ad9026253aa3">
