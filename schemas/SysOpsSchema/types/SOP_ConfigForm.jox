    <JadeMethod name="tblConfig_dblClick" id="0434e17d-cd3d-4029-a4c3-f4cf7d0a30fe">
        <controlMethod name="CM_EntryTable::dblClick"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblConfig_dblClick(table: CM_EntryTable input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 May 2018	jlgndl1	Initial creation	TFS 38768

*/

vars

	row : Integer;
	form : CMUI_UserPasswordEmailForm;
	real : CM_UserPasswordDefaultEmail;
	proxy : CM_UserPasswordDefaultEmail;
	load : Boolean;

begin

	row := self.tblConfig.row;

	if row = self.tblConfig.getRowByName( ETRow_UserEmailTemplate ) then
	
		real := self.myIntFaceConfig.CMIF_ConfigRoot.userEmailTemplate;
		
		create form transient;
		
		if real = null then
			create proxy transient;
		else
			app.cmsBeginLoad( load );
			proxy := self.myIntFaceConfig.CMIF_ConfigRoot.userEmailTemplate.pxyCreateUpdateProxy;
			app.cmsEndLoad( load );
		endif;
		
		create form.myAssistant as SOP_Assistant;
		form.setUserPasswordDefaultEmail( proxy );
		form.centreWindow;
		form.showModal();
		
		if real = null
		and proxy &lt;&gt; null
		and form.modalResult = IDOK then
			real := form.myReal;
			if real &lt;&gt; null then
				self.myIntFaceConfig.CMIF_ConfigRoot.userEmailTemplate := real;
				self.setTableFromObjectSpecial( self.tblConfig, ETRow_UserEmailTemplate, row, self.myIntFaceConfig);
			endif;
		endif;
		
	endif;

epilog

	delete proxy;

end;</source>
        <Parameter name="table" type="CM_EntryTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="tblConfig_queryRowColChg" id="67ad57f3-add1-4fd9-9d12-11a0a9b71c8f">
