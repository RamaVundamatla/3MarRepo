    <JadeMethod name="trxUpdateOverstows" id="4a653651-fe67-48de-a950-f432a4d9d5c4">
        <updating/>
        <source>trxUpdateOverstows(_fromLC, _toLC : CM_LocationsController; _ti : CM_TrackedItem input; _passport : CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 August 2025	jlier1	Initial creation 35636

*/

vars
	iter: Iterator;
	allTIs : CM_TIArray;
	ti : CM_TrackedItem;
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);


	app.setContinueCMExceptions(false);

	beginTransaction;

		
	if _fromLC &lt;&gt; null and _fromLC.isKindOf(CM_GridController) then
		if _fromLC.myTerminalArea.CM_GridArea.useSideAccessRules then
			create allTIs transient;
			_fromLC.CM_GridController.myGridColumn.getTIs(allTIs, REAL_MODE);
			iter :=allTIs.createIterator;
		else
			iter:=_fromLC.allTrackedItems.createIterator;
		endif;
		while iter.next(ti) do
			ti.calcNumOverstows;
		endwhile;
		
		delete iter;
	endif;
	
	if _toLC &lt;&gt; null  and _toLC.isKindOf(CM_GridController) then
		if _toLC.myTerminalArea.CM_GridArea.useSideAccessRules then
			create allTIs transient;
			_toLC.CM_GridController.myGridColumn.getTIs(allTIs, REAL_MODE);
			iter :=allTIs.createIterator;
		else
			iter:=_toLC.allTrackedItems.createIterator;
		endif;
		while iter.next(ti) do
			ti.calcNumOverstows;
		endwhile;
		
		delete iter;
	else
		if _ti &lt;&gt; null then
			//moved somewhere null then
			_ti.setNumOverstows(0);
		endif;
	endif;

epilog
	self.finaliseActivityWithPassport(_passport);
	delete allTIs;
	delete iter;

end;</source>
        <Parameter name="_fromLC" type="CM_LocationsController"/>
        <Parameter name="_toLC" type="CM_LocationsController"/>
        <Parameter name="_ti" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
