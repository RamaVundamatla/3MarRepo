    <JadeMethod name="getMyTerminalObject" id="0f4f0cd3-a959-4db7-ac20-3edea4bc6135">
        <source>getMyTerminalObject() : CM_Object;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 November 2018	jlger1	Initial creation 42095

*/

vars
	terminal : CM_Terminal;
begin

	terminal:= self.myXlationTable.myTerminal;
	if terminal = null then
		return null;
	endif;
	
	if self.myXlationTable.type = XLATION_TYPE_WORKPOINT then
		return terminal.allWorkPointsByCode[self.systemCode];
	endif;
	
	return null;
		
	
epilog

end;</source>
        <ReturnType type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="getObjectForSystemCode" id="4757c013-fc61-4750-8283-b45509b89fdd">
        <source>getObjectForSystemCode(_type :Integer; _terminal :CM_Terminal ):CM_Object;
/*
Date		Who		Reason
27 Mar 2013	cnwcs5	Initial Creation - CCMS POL 2097/par 31259
01 Jun 2013	cnwrs1	JMT821 cut, upgrade failing in Xlation conversion
15 Jul 2014	Par 34567	CCMS 2346 add EDI Xlation for Cargo Type and Cargo Sub Type
23 May 2016	cnwrs1	TFS 1987 CargoSubType EDI Xlation
07 Jun 2023	jlika1	TFS 58320 58319 | Jade work for Translations
08 Jun 2023	navpw1	TFS: 57813 (58438) - Added sorting method to if statement
12 Jun 2023	jlizm1	TFS 58500 add EDI Xlation for Operational Instruction and trailer type
08 Nov 2023	jlika1	TFS 61129 61013 CUX | Cargo Priority - EDI Translation
*/
vars
	cargoSubTypes : CM_ProductByCargoTypeCodeDict; //CM_ProductByCodeDict;
	product : CM_Product;
	operator : CM_Operator;
	cargoType : CM_CargoType;
	iter : Iterator;
	operTerm : CM_OperatorTerminal;
begin
	if _type = XLATION_TYPE_CUSTPRIORITY_BYOP then
		return app.myRoot.allCustomerPriorities[self.systemCode];
	elseif _type = XLATION_TYPE_CARGOSUBTYPE_BYOP then
		cargoType := self.myXlationTable.myCargoType.CM_CargoType;
		operator := self.getMyOperator;
		create cargoSubTypes transient;
		if operator &lt;&gt; null and 
		   cargoType &lt;&gt; null then
			foreach product in cargoType.allProducts do
				if cargoSubTypes[cargoType.id, product.code] = null then
				if product.myOperator = null or
				   product.myOperator = operator then
					cargoSubTypes.add(product);
				endif;
				endif;
			endforeach;
		else	
			foreach product in CM_Product.instances do
				cargoSubTypes.add(product);
			endforeach;
		endif;
		if cargoType = null then
			foreach product in cargoSubTypes do
				if product.code = self.systemCode then
					return product;
				endif;
			endforeach;
			return null; //app.myRoot.allCargoTypesById[self.systemCode.Integer];
		else
			return cargoSubTypes[cargoType.id, self.systemCode];
		endif;

	elseif _type = XLATION_TYPE_CARGOTYPE_BYOP then
		cargoType := app.myRoot.getCargoTypeFromAbbrevOrDescr(self.systemCode);
		if cargoType = null then
			cargoType := app.myRoot.allCargoTypesById[self.systemCode.Integer];
		endif;
		return cargoType;
	elseif _type = XLATION_TYPE_CARRIER_BYOP then
		return app.myRoot.allCarriers[self.systemCode];
	elseif _type = XLATION_TYPE_COMMODITY_BYOP then
		return app.myRoot.allCommodities[self.systemCode];
	elseif _type = XLATION_TYPE_CONSIGNEE_BYOP then
		return app.myRoot.allConsigneeConsignors[self.systemCode];
	elseif _type = XLATION_TYPE_CUSTOMSAGENT then
		return app.myRoot.allCustomsAgents[self.systemCode];
	elseif _type = XLATION_TYPE_ISOTYPE_BYOP then
		return app.myRoot.allISOTypes[self.systemCode];
	elseif _type = XLATION_TYPE_INSTRUCTTERMINAL then
		if _terminal = null then
			if not app.isConverting then
				app.raiseUnexpectedProgramError(class.name, method.name, 'terminal is null for terminal translation');
			endif;
			return null;
		else
			return _terminal.allInstructionTypes[self.systemCode];
		endif;
	elseif _type = XLATION_TYPE_MTGRADE_BYOP then
		return app.myRoot.allAvailabilityGrades[self.systemCode.Integer];
	elseif _type = XLATION_TYPE_OPERATOR then
		return app.myRoot.allOperators[self.systemCode];
	elseif _type = XLATION_TYPE_OPERATOR_BYOP then  // cnwrd1 par 19675 14.5.09
		return app.myRoot.allOperators[systemCode];	
	elseif _type = XLATION_TYPE_PORT_BYOP then
		return app.myRoot.allPorts[self.systemCode];
	elseif _type = XLATION_TYPE_SHIPINGAGENT_BYOP then
		return app.myRoot.allShippingAgentsByCode[self.systemCode];	
	elseif _type = XLATION_TYPE_SHIPPINGLINE then
		return app.myRoot.allShippingLines[self.systemCode];
	elseif _type = XLATION_TYPE_SHIPPINGLINE_BYOP then
		return app.myRoot.allShippingLines[self.systemCode];
	elseif _type = XLATION_TYPE_TERMINAL_BYOP then 
		return app.myRoot.allTerminals[self.systemCode];
	elseif _type = XLATION_TYPE_TRAILER_TYPE then
		return app.myRoot.allTILCTypes[null, self.systemCode];
	elseif _type = XLATION_TYPE_VESSEL_TYPE then	//11 Sep 2018	NDL	TFS 40778
		return app.myRoot.allVesselTypes[self.systemCode];
	elseif _type = XLATION_TYPE_VESSEL then
		return app.myRoot.allVessels[self.systemCode];
	elseif _type = XLATION_TYPE_VESSEL_BYOP then
		return app.myRoot.allVessels[self.systemCode];
	elseif _type = XLATION_TYPE_VOYAGETERMINAL then
		if _terminal = null then
			if not app.isConverting then
				app.raiseUnexpectedProgramError(class.name, method.name, 'terminal is null for voyage/terminal translation');
			endif;
			return null;
		else
			if self.systemCode &lt;&gt; null then //Par 18029 cnwrs1 Feb 2009
				return _terminal.lookupVoyage(self.systemCode, null, true);
				// archived voyages are checked in the the lookupVoyage call above  22/11/2005  JC
				// above call also will match on inward code if no match on voyage code found.
			endif;
		endif;
	elseif _type = XLATION_TYPE_COUNTRYTERMINAL then //jlier1 TFS 54846 11/10/22
		return app.myRoot.allCountries[self.systemCode];
	// ### TFS 57813 (58438) 08Jun2023 NAVPW1
	elseif _type = XLATION_TYPE_SORTINGMETHD_BYOP then
		return app.myRoot.allSortingMethods[self.systemCode];
	// ### TFS 57813 (58438) 08Jun2023 NAVPW1	
	elseif _type = XLATION_TYPE_OPERATOR_BYTERM then				//TFS 63842
		if _terminal &lt;&gt; null then									//TFS 63842
			iter := _terminal.allOperatorTerminals.createIterator;	//TFS 63842
			while iter.next(operTerm) do							//TFS 63842
				if operTerm.myOperator.code = self.systemCode then	//TFS 63842
					return operTerm.myOperator;						//TFS 63842
				endif;												//TFS 63842
			endwhile;												//TFS 63842	
		endif;														//TFS 63842
	endif;															//TFS 63842
	
	return null;
epilog
	delete cargoSubTypes;
end;</source>
        <Parameter name="_type" type="Integer"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <ReturnType type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="getSystemCodeDesc" id="f86c738f-9cb3-4b34-b23b-28692bc25b71">
        <source>getSystemCodeDesc():String;
/*
Date		Who		Reason
11 Mar 2013	cnwcs5	Initial Creation - CCMS PNL 2243 / par 31185 
15 Jul 2014	Par 34567	CCMS 2346 add EDI Xlation for Cargo Type and Cargo Sub Type
19 May 2016	cnwrs1	TFS 1987 CargoSubType EDI Xlation
07 Jun 2023	jlika1	TFS 58320 58319 | Jade work for Translations
12 Jun 2023	jlizm1	TFS 58500 add EDI Xlation for Operational Instruction and trailer type
08 Nov 2023	jlika1	TFS 61129 61013 CUX | Cargo Priority - EDI Translation
*/
vars
	type			: Integer;
	obj				: Object;
	gotException	: Boolean;
	terminal		: CM_Terminal;
begin
	type 	:= self.myXlationTable.type;
	obj		:= self.mySystemObject;
	
	if obj = null then
		return null;
	endif;
	
	on Exception do app.handleDeletedObject (exception, obj, gotException);
	
	if type = XLATION_TYPE_CUSTPRIORITY_BYOP then
		return obj.CM_CustomerPriority.description;
	elseif type = XLATION_TYPE_CARGOSUBTYPE_BYOP then
		return obj.CM_Product.description;
	elseif type = XLATION_TYPE_CARGOTYPE_BYOP then
		return obj.CM_CargoType.description;
	elseif type = XLATION_TYPE_CARRIER_BYOP then
		return obj.CM_Carrier.description;
	elseif type = XLATION_TYPE_COMMODITY_BYOP then
		return obj.CM_Commodity.description;
	elseif type = XLATION_TYPE_CONSIGNEE_BYOP then
		return obj.CM_ConsigneeConsignor.description;
	elseif type = XLATION_TYPE_COUNTRYTERMINAL then //jlier1 TFS 54846 11/10/22
		return obj.CM_Country.description;	
	elseif type = XLATION_TYPE_CUSTOMSAGENT then
		return obj.CM_CustomsAgent.name;
	elseif type = XLATION_TYPE_ISOTYPE_BYOP then
		return obj.CM_ISOType.description;
	elseif type = XLATION_TYPE_INSTRUCTTERMINAL then
		return obj.CM_InstructionType.description;
	elseif type = XLATION_TYPE_MTGRADE_BYOP then
		return obj.CM_MTGrade.description;
	elseif type = XLATION_TYPE_OPERATOR then
		return obj.CM_Operator.description;
	elseif type = XLATION_TYPE_OPERATOR_BYOP then  
		return obj.CM_Operator.description;
	elseif type = XLATION_TYPE_PORT_BYOP then
		return obj.CM_Port.description;
	elseif type = XLATION_TYPE_SHIPINGAGENT_BYOP then
		return obj.CM_ShippingAgent.description;	
	elseif type = XLATION_TYPE_SHIPPINGLINE then
		return obj.CM_ShippingLine.description;
	elseif type = XLATION_TYPE_SHIPPINGLINE_BYOP then
		return obj.CM_ShippingLine.description;
	elseif type = XLATION_TYPE_TERMINAL_BYOP then
		return obj.CM_Terminal.code;
/*	elseif type = XLATION_TYPE_TERMINAL_BYOP then
		obj := app.myRoot.allTerminals[self.systemCode];
		if obj &lt;&gt; null then
			return obj.CM_Terminal.name;
		endif;
		return null;*/
	elseif type = XLATION_TYPE_TRAILER_TYPE then
		return obj.CM_TILCType.description;
	elseif type = XLATION_TYPE_VESSEL then
		return obj.CM_Vessel.name;
	elseif type = XLATION_TYPE_VESSEL_TYPE then	//11 Sep 2018	NDL	TFS 40778
		return obj.HMS_VesselType.description;
	elseif type = XLATION_TYPE_VESSEL_BYOP then
		return obj.CM_Vessel.name;
	elseif type = XLATION_TYPE_VOYAGETERMINAL then
		return obj.CM_Voyage.description;	
	else
		return null;
	endif;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getSystemCodeDisplay" id="238e416b-e208-4df4-a87b-c96c7a1cd17e">
        <source>getSystemCodeDisplay() : String;
//
//16 Apr 2015	cnwrs1	Par 36065 Check cargotype and subtype
//
vars
	type : Integer;
	obj	: Object;
begin
	type := self.myXlationTable.type;
	obj := self.mySystemObject;
	if type = XLATION_TYPE_CARGOTYPE_BYOP then
		if global.isValidObject(obj) then
			return obj.CM_CargoType.abbreviation;
		else
			return null;
		endif;
	else
		return self.systemCode;
	endif;
end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getSystemCodeDisplayStr" id="5cf2c34c-9dac-46ef-a0a6-2ecbf472448e">
        <source>getSystemCodeDisplayStr(_codeFirst : Boolean) : String;

// 11/03/2012	cnwcs5	CCMS POL 2097 / par 31259
vars
	type 		: Integer;
	obj			: CM_Object;
	str 		: String;
	terminal 	: CM_Terminal;
begin
	type 	:= self.myXlationTable.type;
	
	if type = XLATION_TYPE_TERMINAL_BYOP then
		obj := app.myRoot.allTerminals[self.systemCode];
		
		if terminal &lt;&gt; null then
			return app.myRoot.allTerminals[self.systemCode].displayForXlation(_codeFirst);
		endif;
	else
		obj	:= self.mySystemObject;	
	endif;
	
	if obj &lt;&gt; null then
		return obj.displayForXlation(_codeFirst);
	endif;
epilog

end;
</source>
        <Parameter name="_codeFirst" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="isSameAs" id="46b366bd-c646-478a-967f-b5857dc37588">
        <source>isSameAs(_xlation :CM_Xlation):Boolean;
/*
Date		Who		Reason
03 Apr 2013	cnwcs5	Initial Creation - CCMS POL 2097/par 31259
*/
vars

begin
	return self.foreignCode = _xlation.foreignCode and
			self.systemCode = _xlation.systemCode and
			self.mySystemObject = _xlation.mySystemObject;
		
epilog

end;</source>
        <Parameter name="_xlation" type="CM_Xlation"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="d765f447-aae4-44c2-80d4-1b9a4d2c0793">
        <source>pxyCreateUpdateProxy(): SelfType;

// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when	trying to create the proxy
// 02/07/2013	cnwcs5		par 31261 - remove redundant properties
vars
	proxy 			: SelfType;
	completedOK		: Boolean;
begin
	proxy := inheritMethod();
	
	proxy.myXlationTable 		:= self.myXlationTable;
		
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	
	return proxy;
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete proxy;
	endif;	
end;
</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="b454a11a-d91c-487a-9000-d30ae70f0ef7">
        <updating/>
        <source>setForCreate(_proxy : CM_Xlation; _xlationTable : CM_XlationTable) updating;
/*
------------------------------------------------------------------------
Created:			23 July 2003 by cnwdwq1

Changed On		Changed By		Reason
------------	------------	-----------------------------------------
13/03/2013		cnwcs5			CCMS POL 2097 / par 31259														
------------------------------------------------------------------------
//19 May 2016	cnwrs1	TFS 1987 CargoSubType EDI Xlation
15/02/2023		jlizm1			TFS 56604 CSV Import of translation terms - improve error messages
*/
vars

begin
	self.exclusiveLock(self);
	
	self.systemCode 	:= _proxy.systemCode;
	self.foreignCode 	:= _proxy.foreignCode.toUpper().removeTabCrLfs(); //cnwrs1 par12352 aug 2006
	self.myXlationTable := _xlationTable;
	
	self.setSystemObject(_xlationTable.type, _xlationTable.getMyTerminal);
	if _xlationTable.requiresSystemObj then
		if self.mySystemObject = null then
			app.raiseUnexpectedProgramError(self.class.name, method.name, 'Xlation parent (SystemObject) is null');
		endif;
	endif;
	
end;










</source>
        <Parameter name="_proxy" type="CM_Xlation"/>
        <Parameter name="_xlationTable" type="CM_XlationTable"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="1d7706c8-7c35-45d8-88c1-26b4c12677d3">
        <updating/>
        <source>setForUpdate(_proxy: CM_Xlation) updating;
/*
------------------------------------------------------------------------
Created:			23 July 2003 by cnwdwq1
			
Changed On		Changed By		Reason
------------	------------	-----------------------------------------
13/03/2013		cnwcs5			CCMS POL 2097 / par 31259														
------------------------------------------------------------------------
*/
vars
	xlationTable	:CM_XlationTable;
begin
	self.exclusiveLock(self);
	
	self.systemCode 	:= _proxy.systemCode;
	self.foreignCode 	:= _proxy.foreignCode.toUpper().removeTabCrLfs(); //cnwrs1 par12352 aug 2006
	
	xlationTable := self.myXlationTable;
	
	self.setSystemObject(xlationTable.type, xlationTable.getMyTerminal);
epilog

end;</source>
        <Parameter name="_proxy" type="CM_Xlation"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="02d1874f-a29c-41d6-bf2d-2b2d5eecab8e">
        <updating/>
        <source>setProxy(_systemCode, _foreignCode : String; _xlationTable : CM_XlationTable) updating;
/*
------------------------------------------------------------------------
Created:			24 July 2003 by cnwdwq1

Changed On		Changed By		Reason
------------	------------	-----------------------------------------
19/03/2013		cnwcs5			CCMS 2097 / par 31259														
------------------------------------------------------------------------
*/
vars

begin
	// This method should be used only to update transient
	self.raiseExceptionIfNotTransient(method);
	
	self.systemCode 	:= _systemCode;
	self.foreignCode 	:= _foreignCode.toUpper().removeTabCrLfs(); //cnwrs1 par12352 aug 2006 par19496 Apr 2009
	self.myXlationTable := _xlationTable;							// This may be REAL or proxy
	
	self.setSystemObject(_xlationTable.type, _xlationTable.getMyTerminal);
end;</source>
        <Parameter name="_systemCode" type="String"/>
        <Parameter name="_foreignCode" type="String"/>
        <Parameter name="_xlationTable" type="CM_XlationTable"/>
    </JadeMethod>
    <JadeMethod name="setSystemCode" id="6778fde9-34b7-4ed4-91b7-9b909788d7f0">
        <updating/>
        <source>setSystemCode(_code : String) updating;

vars

begin
	self.systemCode := _code;
end;
</source>
        <Parameter name="_code" type="String"/>
    </JadeMethod>
    <JadeMethod name="setSystemObject" id="9ce864a9-1450-4fa2-a58e-9e4ffdce80cf">
        <updating/>
        <source>setSystemObject(_type: Integer; _terminal: CM_Terminal) updating;
// ---------------------------------------------------------------------------
// Created:     02 July 2003 by cnwrs1
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//	22/11/2005	CNWJC2		Remove null checks so you can update the system object
// 19/03/2013	cnwcs5		CCMS POL 2097 / par 31259
// ---------------------------------------------------------------------------

vars
	obj :CM_Object;
begin
	if self.isTransient then
		return;
	endif;
	
	obj := self.getObjectForSystemCode (_type, _terminal); 
	
	self.mySystemObject	:= obj;
epilog

end;</source>
        <Parameter name="_type" type="Integer"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
