/*

Purpose:			
//cnwrd1 ccms 1303 14.11.2012
Parameters:			

Return Value:		


Date		Who		Reason
13 November 2012	cnwrd1	Initial creation

*/

vars

begin
	return not self.myAllocation = null;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="hasChildren_Match" id="54464f6a-d07a-477c-8461-6a568789cfa9">
        <source>hasChildren_Match(_yaData: CM_YADataBoolean): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 September 2020	jlgndl1	Initial creation	TFS 49984

*/

vars

	yaData : CM_YAData;
	yaDataBoolean : CM_YADataBoolean;
	booleanValue : Boolean;

begin

	yaData := self.getExtraCriteriaMatchData( YACriteriaType_HasChildren );

	if yaData &lt;&gt; null and yaData.isKindOf(CM_YADataBoolean) then
		yaDataBoolean := yaData.CM_YADataBoolean;
		if yaDataBoolean &lt;&gt; null then
			if yaDataBoolean.value =  CM_YADataBoolean.VALUE_EITHER then
				return true;
			endif;
			booleanValue := yaDataBoolean.getValueAsBoolean();
			return _yaData.doesValueMatch( booleanValue );
		endif;
	endif;
		
	return true;	

end;</source>
        <Parameter name="_yaData" type="CM_YADataBoolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="initializeForRoadGateCargoChk" id="9893ebed-5d11-4d05-b636-604c336b37e3">
        <updating/>
        <source>initializeForRoadGateCargoChk(	_term : CM_Terminal; 
								_cargoType : CM_CargoType;
								_operator : CM_Operator;
								_product : CM_Product
								) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 October 2019	jlgndl1	Initial creation	TFS 46911

*/

vars

begin

	self.myTerminal := _term;
	self.myCargoType := _cargoType;
	self.myProduct := _product;
	
	if _operator &lt;&gt; null then
		self.operatorCode := _operator.code;
	endif;

epilog

end;</source>
        <Parameter name="_term" type="CM_Terminal"/>
        <Parameter name="_cargoType" type="CM_CargoType"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_product" type="CM_Product"/>
    </JadeMethod>
    <JadeMethod name="initializeFromBookingItems" id="6741a958-7e8e-4191-93d5-f5fa452083ab">
        <updating/>
        <source>initializeFromBookingItems(_terminal : CM_Terminal;  _item : CM_BookingRefItem) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 Feb 2023 navhl20 ChangeRequest 61960: FR | 57937 - [TKT: 61898] - Kiosk - US.080 'c' - Coded Instructions Missing from Additional question Criteria 

*/

vars
	
begin

	self.myTerminal		:= _terminal;
	self.myBookingRefItem := _item;
	if self.myTerminal = null then
		self.myTerminal:=_item.getMyTerminal();
	endif;
	
	self.myBookingRef := _item.myBookingReference;
	
	if self.myBookingRef &lt;&gt; null then
		self.operatorCode	:= self.myBookingRef.operatorCode;
	endif;
		
	self.myCommodity	:= app.myRoot.allCommodities[_item.commodity];
	self.consigneeCode	:= _item.consigneeCode;
	
	if _item.myISOType &lt;&gt; null then
		self.isoType := _item.myISOType.code;
	endif;
	self.clean := _item.clean;
	self.myCargoType := _item.myCargoType;
	self.isoGroup := _item.isoTypeGroup; 
	self.totalRequested := 1;
	
	self.colour := _item.colour;   
	self.mark := _item.markNumber;
epilog

end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_item" type="CM_BookingRefItem"/>
    </JadeMethod>
    <JadeMethod name="initializeFromBulkRelease" id="dd8f1771-9cd2-47bf-94eb-56a6465bd939">
        <updating/>
        <source>initializeFromBulkRelease(_terminal : CM_Terminal; _request : CM_Request) updating;
// -------------------------------------------
// Created 10 May 2005 by cnwdvb1
// -------------------------------------------
// Date			Who		Reason
// 28/10/2025	jlizm1	MTN 36255 Rotabox Assign Release To Vessel
// -------------------------------------------
vars
	bulkRelease		: CM_BulkRelease;
	reserveDetail	: CM_ReserveDetail;
	reserveSel		: CM_ReserveSelection;
	commodity		: String;
	string			: CM_String;
	tempStrArray	: StringArray;
	cmifRequest		: CMIF_YARequest;
	isoTypeObj		: CM_ISOType;
	
begin
	bulkRelease := _request.getBulkRelease;
	
	if bulkRelease &lt;&gt; null then
		self.myTerminal		:= _terminal;
		
		if not bulkRelease.fullRelease then
			commodity 			:= _terminal.getDefaultEmptyCommodity();
			self.myCommodity	:= app.myRoot.allCommodities[commodity];
		endif;
		
		// get the valid imex status(es) for the type of bulk release
		cmifRequest := self;
		bulkRelease.setIMEXStatusArrayDetails(cmifRequest);	// 10/09/2010 cnwmh5 #25696		// 13/09/2010 cnwmh5 #25696
		
		self.operatorCode	:= bulkRelease.getOperatorCode;
		
		//12 Mar 2012	NDL	Par 29248
		if self.operatorCode = null then
			self.myOperatorGroup := bulkRelease.myOperatorGroup;
		endif;
		
		if bulkRelease.getConsignee &lt;&gt; null then
			self.consigneeCode	:= bulkRelease.getConsignee.code;
		endif;

		if bulkRelease.myVoyage &lt;&gt; null then
			self.voyageCode 	:= bulkRelease.myVoyage.code;
		endif;
		//epr par 36012 14/4/15
		bulkRelease.allAvailabilityGrades.copy(self.allAvailabilityGrades);
	
		// todo GET ANY IDS associated with the release
		//tempStrArray := self.ids;
		//_request.getIds(tempStrArray);
		self.mySubTerminal		:= bulkRelease.mySubTerminal;		// PAR 22127
		self.myCargoType 		:= bulkRelease.myCargoType; // cnwrd1 par 22929 9.3.2010
		self.totalRequested		:= 1; // Always one at this stage cause the code else where is really screwy.
		
		//12 Aug 2016	NDL	TFS 2527 to allow for full matching of YAs
		self.myBookingRef := bulkRelease.myBookingRefStock;
	endif;
	
	reserveDetail := _request.getBulkReleaseReserveDetail;
	if reserveDetail &lt;&gt; null and reserveDetail.isKindOf(CM_ReserveSelection) then   // PAR 25283
		reserveSel := reserveDetail.CM_ReserveSelection;
		self.isoType :=reserveSel.getISOCode;		// PAR 30676 
		if reserveSel.getISOGroup &lt;&gt; null then
			self.isoGroup := reserveSel.getISOGroup.code;
		endif;
		
		isoTypeObj := reserveSel.getISOType;
		if isoTypeObj &lt;&gt; null and isoTypeObj.isRotatable then
			self.myCargoTypeForContents := reserveSel.myContentsCargoType;
			self.myProduct := reserveSel.myProduct;
			// voyage isn't used as a criteria for matching for rotatable container loading
			self.voyageCode := null;
		endif;

		self.allTerminalAreas.clear;
		reserveSel.allTerminalAreas.copy(self.allTerminalAreas);
		
		self.myCargoType := reserveSel.myCargoType; //cnwrd1 
		//cnwrd1 par 32823 test bol
		if reserveDetail.myBOLIn &lt;&gt; null then
			self.bolNumber := reserveDetail.myBOLIn.number;
		endif;
		
		//epr par 36012 14/4/15
		self.heavyRated:=reserveDetail.getHeavyRated();
		self.clean:=reserveDetail.getClean();
		reserveSel.allAvailabilityGrades.copy(self.allAvailabilityGrades);
		
		self.myReserveSelection := reserveSel;	//30 Oct 2015	NDL	Par 37094
	
	endif;
	
end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_request" type="CM_Request"/>
    </JadeMethod>
    <JadeMethod name="initializeFromDeliveryRequest" id="a8aa0bf6-cd91-4c34-9586-748c9edfe2ec">
        <updating/>
        <source>initializeFromDeliveryRequest(_terminal : CM_Terminal; _request : CM_DeliveryRequest) updating;
// -------------------------------------------
// Created 10 May 2005 by cnwdvb1
// 3 Nov 2022 navsks20 ChangeRequest 52721: PNL - Delivery Requests - Assign Cargo to Specified Release Request
// -------------------------------------------
vars
	commodity		: String;
	string			: CM_String;
	tempStrArray	: StringArray;
	cmifRequest		: CMIF_YARequest;
	bulkRelease		: CM_BulkRelease;
	reserveDetail	: CM_ReserveDetail;
	sourceLocn 		: CM_LocationsController;
	aGLC			: CM_GridController;	
	aGA				: CM_GridArea;
	gte             : CMGTE_Release;
begin
	self.myTerminal		:= _terminal;

	self.imexStatus		:=_request.imexStatus;
	// 23676 take the incoming commodity if present, to handle release empty and full by type
	if _request.commodity &lt;&gt; null then
		self.myCommodity := app.myRoot.allCommodities[_request.commodity];
	endif;

	if _request.bulkRelease &lt;&gt; null then
		self.bulkReleaseCode := _request.bulkRelease.code;
	endif;
	
	self.bolNumber := _request.billOfLading;	//18 Feb 2014	NDL	Par 33524
	
	// 10/09/2010 cnwmh5 #25696 - Start
	if _request.myOriginatingBulkRelease &lt;&gt; null then
		cmifRequest := self;
		bulkRelease := _request.myOriginatingBulkRelease;
		bulkRelease.setIMEXStatusArrayDetails(cmifRequest);
	else
		if _request.imexStatus &lt;&gt; 0 then
			self.imexStatusArray.add(_request.imexStatus);	
		endif;
	endif;
	// 10/09/2010 cnwmh5 #25696 - End
	
	self.isoType 		:= _request.isoType;
	self.operatorCode	:= _request.operatorCode;
	self.consigneeCode	:= _request.consignee;
	
	self.voyageCode 	:= _request.voyageCode;
	self.clean			:= _request.clean;
	
	_request.allAvailabilityGrades.copy(self.allAvailabilityGrades);
	// from CCMS 1101 testing, the incoming CM_YardDeliveryRequest can have two '0' entries in allAvailabilityGrades
	//  which stops otherwise valid container selection later.  Clear these out.
	if self.allAvailabilityGrades.size = 2 and
	   self.allAvailabilityGrades[1] = 0 and
	   self.allAvailabilityGrades[2] = 0 then
		self.allAvailabilityGrades.clear;
	endif;
	
	tempStrArray := self.ids;
	_request.getIds(tempStrArray);
	
	self.heavyRated			:= _request.heavyRated;
	self.isoGroup 			:= _request.isoGroup; // cnwrd1 par 22929 9.3.2010
	self.myCargoType 		:= _request.myCargoType; // cnwrd1 par 22929 9.3.2010	
	
	//epr par 32261 21/8/13
	self.myTILCType:=	_request.myTILCType;
	if self.myTILCType &lt;&gt; null then
		self.myCargoType:= self.myTILCType.myCargoType;
	endif;
	
	self.totalRequested		:= 1; // Always one at this stage cause the code else where is really screwy.
	self.myDeliveryRequest	:= _request;
	self.mySubTerminal		:= _request.mySubTerminalSource;		// PAR 22127
	
	// 23/09/2010 cnwmh5 #25696 - Start
	self.allTerminalAreas.clear;
	reserveDetail := _request.myReserveDetail;	
	
	//cnwrd1 par 31354 2.4.13
	if not _request.allTerminalAreas.isEmpty then
		_request.allTerminalAreas.copy(self.allTerminalAreas);
		_request.allTerminalAreaGridObj.copy(self.allTerminalAreaGridObjects);		
	else
		if reserveDetail &lt;&gt; null and reserveDetail.isKindOf(CM_ReserveSelection) then  
			reserveDetail.CM_ReserveSelection.allTerminalAreas.copy(self.allTerminalAreas);
			self.myReserveSelection := reserveDetail.CM_ReserveSelection;	//30 Oct 2015	NDL	Par 37094
		endif;
	endif;
	
	//28 Aug 2019	NDL	TFS 46163
	if _request.colour &lt;&gt; null then
		self.colour := _request.colour;      // PAR 32190
	elseif reserveDetail &lt;&gt; null and reserveDetail.isKindOf(CM_ReserveSelection) then
		self.colour := reserveDetail.CM_ReserveSelection.colour;
	endif;
	if _request.mark &lt;&gt; null then
		self.mark := _request.mark;
	elseif reserveDetail &lt;&gt; null and reserveDetail.isKindOf(CM_ReserveSelection) then
		self.mark := reserveDetail.CM_ReserveSelection.markSelection;
	endif;
	
	//04.11.2020 cnwma1 TFS #50112
	if _request.myGateEntity &lt;&gt; null and _request.myGateEntity.isCMGTE_Release then
		gte := _request.myGateEntity.CMGTE_Release;
		self.stevedore := gte.stevedoreCode;
	endif;
	
	//Start 3.11.2022	navsks20 TFS 52721
	if _request.isKindOf(CM_YardDeliveryRequest) then
		self.isAvailable := _request.CM_YardDeliveryRequest.isAvailable;	
	endif;
	//End 3.11.2022	navsks20 TFS 52721
end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_request" type="CM_DeliveryRequest"/>
    </JadeMethod>
    <JadeMethod name="initializeFromMoveRequest" id="e58f9632-66ac-4c3b-a1ec-e856c359db40">
        <updating/>
        <source>initializeFromMoveRequest(_terminal : CM_Terminal; _request : CM_YardMoveRequest) updating;
// -------------------------------------------
// Created 19/03/2010	by cnwjre1 for CCMS 1101/par 23098 to handle internal move requests
// -------------------------------------------
vars
	commodity		: String;
	string			: CM_String;
	tempStrArray	: StringArray;
	cmifRequest		: CMIF_YARequest;
	bulkRelease		: CM_BulkRelease;
	reserveDetail	: CM_ReserveDetail;
	sourceLocn 		: CM_LocationsController;
	aGLC			: CM_GridController;	
	aGA				: CM_GridArea;
begin
	self.myTerminal		:= _terminal;
	self.totalRequested	:= 1;
end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_request" type="CM_YardMoveRequest"/>
    </JadeMethod>
    <JadeMethod name="initializeFromReserveDetails" id="ae12f83d-fb2a-4aec-bf12-026f5dc62d44">
        <updating/>
        <source>initializeFromReserveDetails(_terminal : CM_Terminal;  _reserve : CM_ReserveSelection) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 June 2015	cnwndl1	Initial creation
13 May 2024 navlc30 Task 63817: EUP | FR 53984 - Kiosk - Additional Questions JADE changes
*/

vars
	bulkRelease : CM_BulkRelease;
	cmifRequest : CMIF_YARequest;
	commodity		: String;
	reserveCommodity : CM_StringArray;	
begin

	self.myTerminal		:= _terminal;
	self.myReserveSelection := _reserve;
	//jlier1 TFS 59732 6/9/23 
	if self.myTerminal = null then
		self.myTerminal:=_reserve.getMyTerminal();
	endif;
	
	bulkRelease := _reserve.myReserveHeader;
	
	
	if bulkRelease &lt;&gt; null then
	
		self.bulkReleaseCode := bulkRelease.code;
		
		if not bulkRelease.fullRelease then
			commodity 			:= self.myTerminal.getDefaultEmptyCommodity();																
			self.myCommodity	:= app.myRoot.allCommodities[commodity];
		else																			//03.07.2024 navlc30 #63817	
			reserveCommodity 	:= _reserve.getMyCommodityCriteria();
			if reserveCommodity &lt;&gt; null then
				commodity := reserveCommodity.first;
				self.myCommodity	:= app.myRoot.allCommodities[commodity];
			endif;
		endif;
		
		cmifRequest := self;
		bulkRelease.setIMEXStatusArrayDetails(cmifRequest);	
		
		self.operatorCode	:= bulkRelease.getOperatorCode;
		if self.operatorCode = null then
			self.myOperatorGroup := bulkRelease.myOperatorGroup;
		endif;
		
		self.consigneeCode	:= bulkRelease.consigneeCode;
		if bulkRelease.getConsignee &lt;&gt; null then
			self.consigneeCode	:= bulkRelease.getConsignee.code;
		endif;
		
		if bulkRelease.myVoyage &lt;&gt; null then
			self.voyageCode 	:= bulkRelease.myVoyage.code;
		endif;
		self.mySubTerminal		:= bulkRelease.mySubTerminal;
		
	endif;
	
	if _reserve.myISOType &lt;&gt; null then
		self.isoType := _reserve.myISOType.code;
	endif;
	self.bolNumber := _reserve.getBOLNumber;
	self.clean := _reserve.clean;
	_reserve.allAvailabilityGrades.copy(self.allAvailabilityGrades);
	self.myCargoType := _reserve.myCargoType;
	//Cargo SubType
	self.myProduct	 :=	_reserve.myProduct;											//13.05.2024 navlc30 #63817
	
	if self.allAvailabilityGrades.size = 2 and
	   self.allAvailabilityGrades[1] = 0 and
	   self.allAvailabilityGrades[2] = 0 then
		self.allAvailabilityGrades.clear;
	endif;
	self.heavyRated := _reserve.heavyRated;
	self.isoGroup := _reserve.getISOGroupCode; 
	self.totalRequested := 1;	// just checking for at least one.
	
	_reserve.allTerminalAreas.copy(self.allTerminalAreas);
	
	self.colour := _reserve.colour;   
	self.mark := _reserve.markSelection;
epilog
	delete reserveCommodity;														//17.05.2024 navlc30 #63817
end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_reserve" type="CM_ReserveSelection"/>
    </JadeMethod>
    <JadeMethod name="isAvGrade_Compare" id="eaca879f-f8c9-4a13-81af-4a2acbb65615">
        <source>isAvGrade_Compare(mtGrade: Object; void: Any): Boolean;
begin
	return self.allAvailabilityGrades.includes(mtGrade.CM_MTGrade.code);
end;</source>
        <Parameter name="mtGrade" type="Object"/>
