    <JadeMethod name="getData" id="768c8b39-2286-441f-806e-f964db65c140">
        <updating/>
        <source>getData(pText: String input; _type: Integer input) updating;
// ---------------------------------------------------------------------------
// Created:		SEPT 2013 By Andrew Bishop cnwab1
//
// Purpose:		CALLED by CMUI_GetData -  no references. See doGetQuantity()
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	obj : Object;
	theReturn, numItems : Integer;
	newWeight : Real;
	shelf : CM_RackShelfController;
begin

	app.mousePointer := Window.MousePointer_HourGlass;

	if _type = self.GetData_Capacity then
		numItems := pText.Integer;
		if numItems &lt;= 0 then
			numItems := 1;
		endif;
	endif;
	if _type = self.GetData_Weight then
		newWeight := pText.asRealJMT;		// 36603 was .Real
		if newWeight &lt;= 0 then
			newWeight := 1;
		endif;
	endif;

	// ### Update the proxies
	foreach obj in self.frmBlkArea.myDrawingController.allSelectedObjects discreteLock do
		if obj.isKindOf(CM_RackShelfController) then
			shelf := obj.CM_RackShelfController;
			if _type = self.GetData_Capacity then
				shelf.setForUpdateMaximums(shelf.maxCapacity, shelf.maximumWeight, numItems);
			elseif _type = self.GetData_Weight then
				shelf.setForUpdateMaximums(shelf.maxCapacity, newWeight, shelf.defaultCapacity);
			endif;
				
		elseif obj.isKindOf(CM_IrregularBlockController) then
			if  obj.CM_IrregularBlockController.locationType = GC_GroundLocation then
				if _type = self.GetData_Capacity then
					obj.CM_IrregularBlockController.setDefaultCapacity( numItems);
				elseif _type = self.GetData_Weight then
					obj.CM_IrregularBlockController.setMaximumWeight( newWeight);
				endif;				
			else		
				foreach shelf in obj.CM_IrregularBlockController.allSubLocations discreteLock do
	 
					if _type = self.GetData_Capacity then
						shelf.setForUpdateMaximums(shelf.maxCapacity, shelf.maximumWeight, numItems);
					elseif _type = self.GetData_Weight then
						shelf.setForUpdateMaximums(shelf.maxCapacity, newWeight, shelf.defaultCapacity);
					
					endif;
	
				endforeach;
			endif;
		endif;
	endforeach;

epilog
	app.mousePointer := Window.MousePointer_Default;
end;</source>
        <Parameter name="pText" type="String" usage="input"/>
        <Parameter name="_type" type="Integer" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getPicture" id="6d985fec-9fe5-4b3c-a9d6-994cffd77a96">
        <source>getPicture(_pictureType : Integer) : Picture;

vars

	picture	: Picture;

begin


	if _pictureType = LOC_Display_Unavailable then
		picture := self.tAUnavailPic;
	elseif	_pictureType = LOC_Display_Building then
		picture := self.tABuildingPic;
	elseif _pictureType = LOC_Display_LightTower then
		picture := self.tALightPic;
	elseif _pictureType = LOC_Display_ReeferGantry then
		picture := self.tAReeferPic;
	elseif _pictureType = LOC_Display_HasPower or _pictureType = LOC_Display_PowerTower or _pictureType = LOC_Display_PowerDamaged then
		picture := self.tAPowerPic;
	
	endif;
	return picture;
	
	

end;</source>
        <Parameter name="_pictureType" type="Integer"/>
        <ReturnType type="Picture"/>
    </JadeMethod>
    <JadeMethod name="getPrinterByDescription" id="0fc60461-f34f-4fdf-ab91-5b1afa9ff923">
        <source>getPrinterByDescription(_printerDesc : String) : CM_PrinterDef;
// --------------------------------------------------------------------------------
// Created:		2 September 2009 by cnwjo3, par 20582
//
// Purpose:		For some reason when the gate table is first populated it doesn't place
//				an object for the printer into the cell/row so getting printDef from description
//
vars
	printer	: CM_PrinterDef;	
begin
	foreach printer in app.myRoot.allPrinterDefsByLogicalName do
		if printer.description = _printerDesc then
			break;
		endif;
		printer := null;
	endforeach;
	
	return printer;
end;</source>
        <Parameter name="_printerDesc" type="String"/>
        <ReturnType type="CM_PrinterDef"/>
    </JadeMethod>
    <JadeMethod name="getProxyObject" id="245b36d3-d85b-423d-b59b-9dbe4cbe98fa">
        <updating/>
        <source>getProxyObject(_class : Class) : Boolean updating;
// ---------------------------------------------------------------------------
// Created:     03 March 2003 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if self.myProxyObject = null then
		if self.mode = Mode_Add then
			create self.myProxyObject as _class transient;
		else
			app.raiseUnexpectedProgramError(class.name, method.name, 'Proxy object is null for update');
			return false;
		endif;
	endif;

	return true;	
	
end;</source>
        <Parameter name="_class" type="Class"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getRFIDTagReaderByDescOrCode" id="f380cd1c-0a1f-4f9a-9cd0-3b019d977fce">
        <source>getRFIDTagReaderByDescOrCode(_descOrCode : String) : CM_RFIDTagReader;
// --------------------------------------------------------------------------------
// Created:		2 September 2009 by cnwjo3, par 20582
//
// Purpose:		Find an RFIDTagReader by its code or description
//
vars
	reader	: CM_RFIDTagReader;	
begin
	foreach reader in self.myTerminal.allRFIDTagReadersByCode where reader.context = TagReaderContext_LaneDevice do
		if reader.description = _descOrCode or reader.code = _descOrCode then
			break;
		endif;
		reader := null;
	endforeach;
	
	return reader;
end;</source>
        <Parameter name="_descOrCode" type="String"/>
        <ReturnType type="CM_RFIDTagReader"/>
    </JadeMethod>
    <JadeMethod name="getTAStringToType" id="d79b52e0-2687-4443-b22f-b3fa5864e8ef">
        <source>getTAStringToType(typeString : String) : CM_TerminalAreaType protected;
// ---------------------------------------------------------------------------
// Created:		July 2001 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	ta 					: CM_TerminalAreaType;
	iter 				: Iterator;
	str 				: String;	

begin
	iter := app.myRoot.allTerminalAreaTypes.createIterator;
	while iter.next(ta) do
		if typeString.trimBlanks = ta.description.trimBlanks then
			return ta;
		endif;
	endwhile;
	return null;
epilog
	delete iter;

end;</source>
        <access>protected</access>
        <Parameter name="typeString" type="String"/>
        <ReturnType type="CM_TerminalAreaType"/>
    </JadeMethod>
    <JadeMethod name="getValidInterchangeAreas" id="0f3df003-3ea1-4f19-b102-6f04518e6527">
        <source>getValidInterchangeAreas(_interchangeAreas : CM_TerminalAreaSet input) ;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
12 February 2010	cnwer1	Initial creation

*/

vars
	combo 		: ComboBox;
	ta, saveTA	: CM_TerminalArea;
	idx			: Integer;
	iter 		: Iterator;
begin

	iter:=self.myTerminal.allTerminalAreasByTypeId.createIterator;
	self.myTerminal.allTerminalAreasByTypeId.startKeyGeq(TA_TYPE_YARD_INTERCHANGE,null,iter);
	
	while iter.next(ta) do

		if ta.type &lt;&gt; TA_TYPE_YARD_INTERCHANGE then
			break;
		endif;
		_interchangeAreas.add(ta);
	endwhile;
	
epilog
	delete iter;
end;</source>
        <Parameter name="_interchangeAreas" type="CM_TerminalAreaSet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getValidTerminalAreas" id="e06f5144-b4d4-4c19-84a0-c5489e088d8e">
        <source>getValidTerminalAreas(_currentTA : CM_TerminalArea): CM_TerminalAreaSet;

/*
Date			Who		Reason
14 August 2009	cnwar2	Initial creation
13/10/2009		cbwcs5	par 21285 - filter out yard interchange areas
11 Jan 2011		cnwkpd1	PAR #26678 - Tidy up transient leaks

*/
vars
	terminalAreas 		: CM_TerminalAreaSet;
	isInterTermMulti	: Boolean;
	iter				: Iterator;
	ta					: CM_TerminalArea;
	invalidTA 			: Boolean;
	taID				: String;
begin
	create terminalAreas transient;
	isInterTermMulti := app.myRoot.isInterTerminalTransferEnabled();
	iter 			 := self.myTerminal.allTerminalAreas.createIterator;
	
	on Exception do app.handleDeletedObject(exception,ta,invalidTA);
	while iter.next(ta) do
		taID:=ta.id; //purely to check valid ta
		if invalidTA then
			invalidTA:=false;
			continue;
		endif;
		
		if (not self.isValidType(ta.type, isInterTermMulti) and ta.type &lt;&gt; TA_TYPE_SUBBLOCK_STACK)or //12/07/2010 cnwdz2 24889
			ta.type = TA_TYPE_RTG or 
			ta.type = TA_TYPE_RMG or 
			ta.type = TA_TYPE_YARD_INTERCHANGE or	// par 21285
			(_currentTA &lt;&gt; null and _currentTA.id = ta.id) then
			continue;
		endif;
		terminalAreas.add(ta);
	endwhile;

	return terminalAreas;
	
epilog
	delete iter;		// PAR #26678
	
end;</source>
        <Parameter name="_currentTA" type="CM_TerminalArea"/>
        <ReturnType type="CM_TerminalAreaSet"/>
    </JadeMethod>
    <JadeMethod name="initDataTable" id="d2218296-cde8-446f-934d-8ca6d8fe8ac3">
        <updating/>
        <source>initDataTable() updating;
// ---------------------------------------------------------------------------
// Created:		July 2001 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	self.setTblDataEntRows(ETDef_TAData);
	// set the initial sort column(s)
	self.zClearSortColumns();
	self.zAddSortColumn('id', false);
	self.zAddSortColumn('typeString', false);
	
end;</source>
    </JadeMethod>
    <JadeMethod name="initExtraTable" id="104ec40d-4b50-47ff-975e-b6448444e2ed">
        <updating/>
        <source>initExtraTable( _taType : CM_TerminalAreaType ) updating;
// ---------------------------------------------------------------------------
// Created:		July 2001 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 23 sep 2014	cnwma1 		PAR# 34720 Problems while Deleting Cargo Type from Block Stack
// 23 Jun 2020	jlgdap1		TFS 49453 ASPA Satellite View Screen for Flexible Terminal Areas
// ---------------------------------------------------------------------------
vars
	entTableDef		: EntTableDef;
	theRow			: Integer;
	theDataTable	: CM_EntryTable;
	ta 				: CM_TerminalAreaType;
	str 			: String;	
	prodMinMax		: CM_TerminalAreaProductMinMax;
	entTableView	: EntTableView;						// TFS 49453
	gridStackHeight : CM_GriddedTAStackHeight;
	
begin

	self.sptThumbEdit.showRightControl(60, true);

	theDataTable := tblExtra;
	theDataTable.warningMethod := 'entTableWarning';
	
	theDataTable.optimiseRowHeight := true;
	
	theDataTable.top 	:= self.frmTBExtra.height + 1;
	theDataTable.left	:= 1;
	theDataTable.parentTopMargin	:= theDataTable.top;
	theDataTable.parentLeftMargin	:= theDataTable.left;
	theDataTable.parentRightMargin	:= 15;
	theDataTable.parentBottomMargin := 10;

	theDataTable.lockBottom := false;
	theDataTable.lockRight	:= false;
	theDataTable.stretchHeight := true;
	theDataTable.stretchWidth := true;
	theDataTable.changeMode := theDataTable.ChangeMode_FirstOnly;
	
	theDataTable.userObject:=null;			//23/09/2014 cnwma1 PAR #34720
	
	if _taType.allowsGriddedStackHeightCrit() then	//07 Sep 2020	NDL	TFS 49984
	
		self.frmTBExtra.visible := true;
		self.initExtraTableList( _taType );
		self.frmDetailsBottom.cnEcResizeContents();
		
		self.tblExtraList.visible := true;
		self.tblExtraList.top := self.tblExtra.top -1;
		self.tblExtraList.left := self.tblExtra.left;
		self.tblExtraList.width := self.tblExtra.width;
		// 34353 set it up regardless but only show on the Definition tab
		if self.fldDefinition.topSheet &lt;&gt; self.shtDefData then
			self.sptThumbEdit.hideRightControl(true);
		endif;
		
		return;
		
	else
		// TFS 49453 Use view instead of def 
		entTableDef := app.myController.getEntTableDef(ETDef_TAExtra);
		if entTableDef &lt;&gt; null then
			entTableView := entTableDef.allEntTableViews[ETView_Default];
			if self.terminalAreaType &lt;&gt; null and self.terminalAreaType = TA_TYPE_GEN_CARGO_ALLOC_ROW then
				entTableView := entTableDef.allEntTableViews[ETView_GCArea];
			endif;
			theDataTable.setEntTableFromView(entTableDef, entTableView, null, 'entTableDefSetupWarning');
		endif;
		//theDataTable.setEntTableDef(entTableDef, null, 'entTableDefSetupWarning');
		// TFS 49453
	endif;
	
	if self.myCurrentObject &lt;&gt; null then
		prodMinMax:= self.myCurrentObject.CM_TerminalArea.allProductMinMax.first;
		if prodMinMax &lt;&gt; null then
			theDataTable.userObject:=prodMinMax;
		endif;	
	endif;
	
	self.resetMeasurementRows(self.tblExtra);																								// PAR #31155
	self.loadMeasurementTypes(theDataTable, theDataTable.myEntTableDef.name, theDataTable.myEntTableDef.allEntTableRows, true);	// PAR #31155
	
	theDataTable.optimiseHeadingColumn();
	theDataTable.cnEcResizeContents();

	self.initExtraTableList( _taType );
	self.frmDetailsBottom.cnEcResizeContents();
	
	self.tblExtraList.visible := true;
	self.tblExtraList.top := self.tblExtra.top + self.tblExtra.height + 10;
	// 34353 set it up regardless but only show on the Definition tab
	if self.fldDefinition.topSheet &lt;&gt; self.shtDefData then
		self.sptThumbEdit.hideRightControl(true);
	endif;
	
end;</source>
        <Parameter name="_taType" type="CM_TerminalAreaType"/>
    </JadeMethod>
    <JadeMethod name="initExtraTableList" id="44ef1a44-2e89-42a6-83f6-9c4cf0089e45">
        <updating/>
        <source>initExtraTableList( _taType : CM_TerminalAreaType ) updating;
// ---------------------------------------------------------------------------
// Created:		March 2008 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------
// 23/06/2020	jlgdap1	TFS 49453 ASPA Satellite View Screen fro Flexible Terminal Areas
vars
entTableView	: EntTableView;
	entTableDef		: EntTableDef;
	theTable		: CM_DataTable;
	viewName		: String;			// TFS 49453
begin
	theTable := self.tblExtraList;
	
	theTable.userInputEnabled := false;
	theTable.selectMode := CM_EntryTable.SelectMode_FixedRow;
	theTable.selectionType := CM_EntryTable.SelectionType_Row;
	theTable.rows := theTable.fixedRows;
	theTable.cnEcResizeContents();
	
	if _taType.allowsGriddedStackHeightCrit() then	//07 Sep 2020	NDL	TFS 49984
		self.btnStackEdit.visible := true;
		self.btnExtraSave.enabled := false;
		entTableDef := app.myController.getEntTableDef(ETDef_TAExtraStackHeight);
		theTable.setTblDataEntRowsFromView(entTableDef, viewName);
	else
		entTableDef := app.myController.getEntTableDef(ETDef_TAExtra);
		if entTableDef &lt;&gt; null then
			// TFS 49453 use view instead of def
			viewName := ETRow_Default;
			if self.myCurrentObject &lt;&gt; null and self.myCurrentObject.CM_TerminalArea.isGeneralCargoAllocArea() then
				viewName := ETView_GCArea;
			endif;
			theTable.setTblDataEntRowsFromView(entTableDef, viewName);
			//theTable.setTblDataEntRowsFromDef(entTableDef);
			// TFS 49453 end
		endif;
	endif;
	
//	theTable.autoSize := self.splMain.size;
	theTable.readOnly := false;	
	theTable.fixedColumns := 0;
	theTable.show3D := Table.Show3D_Not3D;
	theTable.scrollBars := Window.ScrollBars_Both;
	// 34353 to get horizontal scroll bar showing
	theTable.parentAspect := 1;

end;</source>
        <Parameter name="_taType" type="CM_TerminalAreaType"/>
    </JadeMethod>
    <JadeMethod name="initFilterTable" id="7c29d901-68f5-4de8-aa61-6d209853fd70">
        <updating/>
        <source>initFilterTable() updating;
// ---------------------------------------------------------------------------
// Created:		July 2001 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
// cnwcs5	23/07/2009	ccms1061 - set default terminal are type to show when for first displayed
vars
	entTableDef		: EntTableDef;
	theRow			: Integer;
	theTable		: CM_EntryTable;
	controller		: CMUI_Controller;
	
begin
	cmbTATypeFilter.automaticCellControl := true;
	setComboBoxTAType(cmbTATypeFilter, null);
	theTable := tblSearch;
	
	
	controller := app.myController;
	entTableDef := controller.getEntTableDef(ETDef_TAFind);
	
	if entTableDef &lt;&gt; null then
		theTable.setEntTableDef(entTableDef, null, 'entTableDefSetupWarning');
		theTable.adjustHeight(200);
	else
		app.raiseUnexpectedProgramError(class.name, method.name, 'EntTableDef TAFind not found');
	endif;
	
	self.setFilterDefaults;	// cnwcs5 23/07/2009 ccms 1061
end;</source>
    </JadeMethod>
    <JadeMethod name="initForm" id="0b1f2cf1-aa7b-463e-b649-17cb694b342f">
        <updating/>
        <source>initForm() updating;
// ---------------------------------------------------------------------------
// Created:		July 2001 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 21/09/2009	cnwcs5		par 20582 - make sure gate lane table is initialised b4 we try to use it
// 12/10/2009	cnwcs5		par 21173 - makes terminal areas tab multi-select
// 22/08/2011	cnwdap1		PAR #28047 CCMS POL 2095 Maintain machines for terminal area
// ---------------------------------------------------------------------------
vars
	iter 				: Iterator;
	terminalAreas		: CM_TerminalAreaSet;
	machines			: CM_MachineSet;		// PAR #28047
	
begin

	allowSearch 						:= true;
	frmDetailsBottom.visible 			:= true;
	useTblThumb 						:= false;
	allowPrint 							:= true;
	self.allowExportCSV					:= true;
	fldDefinition.stretchToParent 		:= true;
	fldDefinition.tabsStyle 			:= Folder.TabsStyle_RightSloped;
	fldDefinition.useSheetBackColors 	:= true;
	
	fldDefinition.setDefaultSheetBackColors();
	fldDefinition.initSheetBackColors();
	
	
//cnwer1 18/3/09 put the auto plan options back in this are used in auto planning and when validating move to - i can't see any other way of setting these so i am re-implementing them
	shtAutoPlan.visible			:=	true;
	
	shtTerminalAreas.visible	:=	false;
	
	frmGrdArea.borderStyle := BorderStyle_None;
	frmMain.myParentForm := self;
	frmMain.scaleFactor := 2;
	frmMain.setHLabelDetails(30);
	frmMain.setVLabelDetails(30);
	frmMain.setupDrawingAttributes();
	frmMain.labels := ScrollBars_Both;
	initMainTable();

	//initTableGateLanes(tblGateLanes, TA_TYPE_YARD_INTERCHANGE);  //cnwjo3 par 20582 ccms 1061, commented out // cnwcs5 21/09/2009 par 20582 - added back in
		
	flipHorizontal := false;
	fldDefinition.topSheet := shtDefData;

// #################3
	
	doBuildCombos();
	setTerminalsForTransfer();
	initTableAPYardStack();
	
	self.listsTermAreas.myBaseForm	:= self;
	self.listsTermAreas.multiSelect	:= ListBox.MultiSelect_Extended;	// par 21173
	self.listsTermAreas.setupControl(app.getErrorString (TerminalAreas), terminalAreas, SOP_TerminalAreaDefForm::listsTermAreasDisplayEntry.name);
	
	self.doResizeTerminalAreasSheet;
	
	// PAR #28047 start
	self.listsMachines.myBaseForm := self;
	self.listsMachines.multiSelect := ListBox.MultiSelect_Extended;
	self.listsMachines.setupControl(app.getErrorString(Machines), machines, SOP_TerminalAreaDefForm::listsMachinesDisplayEntry.name);
	self.listsMachines.setVisibleButtons(true, true, false);
	self.doResizeMachinesSheet;
	// PAR #28047 end

epilog
	delete iter;
	delete terminalAreas;
end;</source>
    </JadeMethod>
    <JadeMethod name="initMainTable" id="1d9885e1-38fa-44b9-aa21-9e4bd855388b">
        <updating/>
        <source>initMainTable() updating;
// ---------------------------------------------------------------------------
// Created:		July 2001 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	entTableDef		: EntTableDef;
	theRow			: Integer;
	theDataTable	: CM_EntryTable;
	ta 				: CM_TerminalAreaType;
	str 			: String;	
begin

	theDataTable := tblMain;
	theDataTable.warningMethod := 'entTableWarning';
	
	theDataTable.optimiseRowHeight := true;
	entTableDef := app.myController.getEntTableDef(ETDef_TAMain);
	theDataTable.setEntTableDef(entTableDef, null, 'entTableDefSetupWarning');

	theDataTable.top 	:= 5;
	theDataTable.left	:= 5;
	theDataTable.parentTopMargin	:= theDataTable.top;
	theDataTable.parentLeftMargin	:= theDataTable.left;
	theDataTable.parentRightMargin	:= 15;
	theDataTable.parentBottomMargin := 10;

	theDataTable.lockBottom := false;
	theDataTable.lockRight	:= false;
	theDataTable.stretchHeight := true;
	theDataTable.stretchWidth := true;
	//Par 5846 23092003 CNWSH3	
	//Used in doCancel method to check if a change has occured on the CM_EntryTable control
	theDataTable.changeMode := theDataTable.ChangeMode_FirstOnly;
	
	// Setup the Combo Boxes
	setComboBoxTAType(cmbTAType, null);

	theDataTable.optimiseHeadingColumn();
	theDataTable.cnEcResizeContents();

end;</source>
    </JadeMethod>
