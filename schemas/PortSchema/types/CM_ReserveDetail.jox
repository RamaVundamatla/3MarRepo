    <JadeMethod name="validate" id="6faae5fe-b351-4fe4-92ba-6114f9e9e9ef">
        <source>validate(_userObject: Object);
// ---------------------------------------------------------------------------
// Created:		November 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------
// 06/12/2016	cnwdap1		TFS 3039 SNO Empty Container Pool Management
// 23/06/2023	navkc1	CR 58406 Task 58408: Jade - Release Request All Tracked Items
// ---------------------------------------------------------------------------
vars
	poolParty : CM_MTPoolingParty;					// TFS 3039
	ti : CM_TrackedItem;							// TFS 3039
	allTis	: CM_TISet; 
begin
	create allTis transient; //23/06/2023	navkc1	CR 58406 Task 58408
	
	if self.myReserveDetailActions &lt;&gt; null then
		self.myReserveDetailActions.validateForUpdate();
	endif;
	
	poolParty := self.myReserveHeader.myPoolingParty;													// TFS 3039
	if poolParty &lt;&gt; null then																			// TFS 3039
		self.getAllTrackedItems(allTis, false); //23/06/2023	navkc1	CR 58406 Task 58408
		//foreach ti in self.allTrackedItems do															// TFS 3039
		foreach ti in allTis do																			//23/06/2023	navkc1	CR 58406 Task 58408
			if poolParty &lt;&gt; ti.myPoolingParty then														// TFS 3039
				app.raiseCMException2(Cont_Not_In_Pooling_Party, ti.id, poolParty.code, null, null);	// TFS 3039
			endif;																						// TFS 3039
		endforeach;																						// TFS 3039
	endif;																								// TFS 3039
epilog
	delete allTis; //23/06/2023	navkc1	CR 58406 Task 58408
end;</source>
        <Parameter name="_userObject" type="Object"/>
    </JadeMethod>
    <JadeMethod name="validateAgainstOwnershipChange" id="2ce74ed9-a1c2-48a0-9395-dc28f75acd6a">
        <source>validateAgainstOwnershipChange();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 Aug 2023 navmv20 CR 59440 Task 59441: Jade - Ownership Change Release Request Validation
13 September 2023 navmv20 Bug 60217: EUP - COO - Release Request - Message not displaying weight as per measurement type displayed
07 Mar 2024 navrv30 Bug 61941: FR | 53383 - Release Request by Type - Cargo Group (part II)
15 Apr 2024 navrv30 Bug 63658: TPT|[Consulting] Cargo Review Screen - Release Request Quantity
12 Dec 2024 navrv30 JIRA 33097: MTN - Invalid reserved amount value while creating release request
*/

vars
	totalAvailWeight,
	totalAvailVol,
	totalRequestWeight,
	totalREquestVol,
	reservedWeight,
	reserveVolume,
	otherTransferedWt,
	otherTransferedVol,
	myVolume: Decimal[14,4];
	totalRequestLocal,
	totalAvailQty,
	otherTransferedQty : Integer;
	reserveDetail : CM_ReserveDetail;
	measurementType : String;
	tiInCG,
	myTI            : CM_TrackedItem;
	reserveHeaderCode ,
	reservedStr,
	ownershipChangeStr : String;
	myTISet : CM_TISet;
	ct : CM_CargoType;
	term : CM_Terminal;
	density : Decimal[23,4];
	weightRequestedStr,
	volumeRequestedStr : String; //13/09/2023 navmv20 Bug 60217
	cargoGroup : CM_CargoGroup;
	reason		: String;
	reserveHeader : CM_BulkRelease; //11/07/2024	navkc1 Bug 65177
	isTotalCalculated : Boolean;
begin
	// No ownership changes, nothing to do
	term := self.getMyTerminal();
	//15 Apr 2024 navrv30 Bug 63658
	/*if term.allOwnershipChangeOpOld.isEmpty() then
		return;
	endif;*/
	
	//11/07/2024	navkc1 Bug 65177
	reserveHeader := self.myReserveHeader;
	if reserveHeader &lt;&gt; null and not reserveHeader.context = RelReqContext_CargoGroupReview then
		return;
	endif;
	
	ct := self.getCargoType();
	create myTISet transient;
	if self.isKindOf(CM_ReserveTI) then
		self.CM_ReserveTI.allTrackedItems.copy(myTISet);
	elseif self.isKindOf(CM_ReserveSelection) then
		if self.CM_ReserveSelection.myCargoGroup &lt;&gt; null then
			cargoGroup := self.CM_ReserveSelection.myCargoGroup; //21/05/2024	navkc1 Bug 64182
			myTISet.add(cargoGroup);
		endif;
	endif;
	
	foreach myTI in myTISet do
		/*if myTI.allOwnershipChange.isEmpty() then       //07 Mar 2024 navrv30 Bug 61941
			continue;
		endif;*/
		
		if ct &lt;&gt; null and ct.isBulk then
			if ct.isBulkByVolume() then
				reserveVolume := myTI.getReservedVolume(self);
				//17 Dec 2024 navrv30 JIRA 33097
				if reserveVolume &lt;&gt; 0 then
					isTotalCalculated := true;
				endif;
				otherTransferedVol := myTI.getOwnershipChangeVolume(null);
				reserveDetail := self; //13/09/2023 navmv20 Bug 60217
				// ### TFS BUG60216 04SEP2023 NAVAB1
				if reserveDetail.isKindOf(CM_ReserveSelection) then
					density:= reserveDetail.getDensity();
				else
					density:= myTI.getDensity();
				endif;
				if density = 0 then
					density := 1;
				endif;
				myVolume := myVolume + (self.weightRequested /density);
				
				totalAvailVol := myTI.totalVolume; //21/05/2024	navkc1 Bug 64182
				
				//21/05/2024	navkc1 Bug 64182 - Go through individual TI to check COO amount and Release amount
				if cargoGroup &lt;&gt; null and reserveVolume = null or otherTransferedVol = null and myTI.isCargoGroupItem() then
					totalAvailVol := 0;
					//reserveVolume := 0;	// NAVKC1 04/06/2024 BUG 64423
					otherTransferedVol := 0;
					foreach tiInCG in cargoGroup.allAssignedTrackedItems discreteLock do
						if self.isReserveSelection() then
							if not tiInCG.testAgainstReserveSelection(self.CM_ReserveSelection, reason, false, null) then
								continue;
							endif;
						endif;
						
						totalAvailVol += tiInCG.totalVolume;
						if isTotalCalculated = false then        //17 Dec 2024 navrv30 JIRA 33097
							reserveVolume += tiInCG.getReservedVolume(self);
						endif;
						otherTransferedVol += tiInCG.getOwnershipChangeVolume(null);
					endforeach;
				endif;
				
				//if (reserveVolume &gt; 0 or otherTransferedVol &gt;0)and myVolume + reserveVolume + otherTransferedVol  &gt; myTI.totalVolume then
				if (reserveVolume &gt; 0 or otherTransferedVol &gt;0)and myVolume + reserveVolume + otherTransferedVol  &gt; totalAvailVol then	//21/05/2024	navkc1 Bug 64182
					if reserveVolume &lt;&gt; null then
						//12 Dec 2024 navrv30 JIRA 33097
						reservedStr := ct.getConvertedVolumeDisplay(reserveVolume,true) &amp; " of " &amp; ct.getConvertedVolumeDisplay(myTI.totalVolume,true); //13/09/2023 navmv20 Bug 60217
					endif;
					if otherTransferedVol &lt;&gt; null then
						ownershipChangeStr := ct.getConvertedVolumeDisplay(otherTransferedVol,true); //13/09/2023 navmv20 Bug 60217
					endif;
					//13/09/2023 navmv20 Bug 60217 - start
					volumeRequestedStr := ct.getConvertedVolumeDisplay(myVolume,true);
					self.raiseExceptionForReserved(myTI.id,reservedStr,ownershipChangeStr,volumeRequestedStr);
					//13/09/2023 navmv20 Bug 60217 - end
				endif;

			else
				reservedWeight := myTI.getReservedWeight(self);
				//17 Dec 2024 navrv30 JIRA 33097
				if reservedWeight &lt;&gt; 0 then
					isTotalCalculated := true;
				endif;
				otherTransferedWt := myTI.getOwnershipChangeWeight(null);
				
				totalAvailWeight := myTI.totalWeight; //21/05/2024	navkc1 Bug 64182
				
				//21/05/2024	navkc1 Bug 64182 - Go through individual TI to check COO amount and Release amount
				if cargoGroup &lt;&gt; null and reservedWeight = null or otherTransferedWt = null and myTI.isCargoGroupItem() then
					totalAvailWeight := 0;
					//reservedWeight := 0;	// NAVKC1 04/06/2024 BUG 64423
					otherTransferedWt := 0;
					foreach tiInCG in cargoGroup.allAssignedTrackedItems discreteLock do
						if self.isReserveSelection() then
							if not tiInCG.testAgainstReserveSelection(self.CM_ReserveSelection, reason, false, null) then
								continue;
							endif;
						endif;
						
						totalAvailWeight += tiInCG.totalWeight;
						if isTotalCalculated = false then        //17 Dec 2024 navrv30 JIRA 33097
							reservedWeight += tiInCG.getReservedWeight(self);
						endif;
						otherTransferedWt += tiInCG.getOwnershipChangeWeight(null);
					endforeach;
				endif;
				
				//if (reservedWeight &gt; 0 or otherTransferedWt&gt;0)  and self.weightRequested + reservedWeight + otherTransferedWt &gt; myTI.totalWeight then
				if (reservedWeight &gt; 0 or otherTransferedWt&gt;0)  and self.weightRequested + reservedWeight + otherTransferedWt &gt; totalAvailWeight then //21/05/2024	navkc1 Bug 64182
					if reservedWeight &lt;&gt; null then
						//12 Dec 2024 navrv30 JIRA 33097
						reservedStr := ct.getConvertedWeightDisplay(reservedWeight,true)  &amp; " of " &amp; ct.getConvertedWeightDisplay(myTI.totalWeight,true); //13/09/2023 navmv20 Bug 60217
					endif;
					if otherTransferedWt &lt;&gt; null then
						ownershipChangeStr := ct.getConvertedWeightDisplay(otherTransferedWt, true); //13/09/2023 navmv20 Bug 60217
					endif;
					//13/09/2023 navmv20 Bug 60217 - start
					weightRequestedStr := ct.getConvertedWeightDisplay(self.weightRequested, true);
					self.raiseExceptionForReserved(myTI.id,reservedStr ,ownershipChangeStr,weightRequestedStr);
					//13/09/2023 navmv20 Bug 60217 - end
				endif;
			endif;
		else
			totalRequestLocal := myTI.getReserveQuantity(self);
			//12 Dec 2024 navrv30 JIRA 33097
			if totalRequestLocal &lt;&gt; 0 then
				isTotalCalculated := true;
			endif;
			otherTransferedQty := myTI.getOwnershipChangeQuantity(null);
			
			totalAvailQty := myTI.totalQuantity; //21/05/2024	navkc1 Bug 64182
			
			//21/05/2024	navkc1 Bug 64182 - Go through individual TI to check COO amount and Release amount
			if cargoGroup &lt;&gt; null and totalRequestLocal = 0 or otherTransferedQty = 0 and myTI.isCargoGroupItem() then
				totalAvailQty := 0;
				//totalRequestLocal := 0;	// NAVKC1 04/06/2024 BUG 64423
				otherTransferedQty := 0;
				foreach tiInCG in cargoGroup.allAssignedTrackedItems discreteLock do
					if self.isReserveSelection() then
						if not tiInCG.testAgainstReserveSelection(self.CM_ReserveSelection, reason, false, null) then
							continue;
						endif;
					endif;
					
					totalAvailQty += tiInCG.totalQuantity;
					if isTotalCalculated = false then        //12 Dec 2024 navrv30 JIRA 33097
						totalRequestLocal += tiInCG.getReserveQuantity(self);
					endif;
					otherTransferedQty += tiInCG.getOwnershipChangeQuantity(null);
				endforeach;
			endif;
			
			//if (totalRequestLocal &gt; 0 or otherTransferedQty &gt;0 )and self.totalRequested + totalRequestLocal + otherTransferedQty &gt; myTI.totalQuantity then
			if (totalRequestLocal &gt; 0 or otherTransferedQty &gt;0 )and self.totalRequested + totalRequestLocal + otherTransferedQty &gt; totalAvailQty then //21/05/2024	navkc1 Bug 64182
				if totalRequestLocal &lt;&gt; null then	
					reservedStr := totalRequestLocal.String &amp; " of " &amp; myTI.totalQuantity.String &amp; " " &amp; app.getErrorString(Items);   //12 Dec 2024 navrv30 JIRA 33097
				endif;
				if otherTransferedQty &lt;&gt; null then
					ownershipChangeStr := otherTransferedQty.String &amp; " " &amp;  app.getErrorString(Items);
				endif;
				self.raiseExceptionForReserved(myTI.id,reservedStr ,ownershipChangeStr,self.totalRequested.String &amp; " " &amp; app.getErrorString(Items));
			endif;
		endif;
	endforeach;
epilog
	delete myTISet;
end;</source>
    </JadeMethod>
