    <JadeMethod name="calcBestZoom" id="89af27a4-1930-4f2b-b10a-0694fe124e05">
        <updating/>
        <source>calcBestZoom() updating, protected;

/*

Purpose:			
	Calculate the best zoom level, based on the drawing frame's height
Parameters:			

Return Value:		


Date		Who		Reason
10 May 2010	cnwjk3	Initial creation

*/

vars
	height : Integer;
begin
	height := self.myViewportFrame.height.Integer;
	if height &gt;= 210 then
		self.scaleFactor := 2.5;
	elseif height &gt;= 190 then
		self.scaleFactor := 2.25;
	elseif height &gt;= 170 then
		self.scaleFactor := 2;
	elseif height &gt;= 150 then
		self.scaleFactor := 1.75;
	elseif height &gt;= 130 then 
		self.scaleFactor := 1.5;
	else
		self.scaleFactor := 1.25;
	endif;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="calcCenteredColumnsFlipped" id="4496e5ad-af51-43a9-a7ea-c6988674980d">
        <updating/>
        <source>calcCenteredColumnsFlipped() updating, protected;

/*

Purpose:			

Parameters:			
Return Value:		


Date		Who		Reason
12 May 2010	cnwjk3	Initial creation

*/

vars
	spareSpace,
	lcWidthPixels,
	gridWidthPixels,
	leftSpare,
	rightSpare,
	frameWidth,
	spareSpaceAtLeft,
	labelOffset,
	cx 				: Real;
	numColsAvailRight,
	numColsFitLeft,
	numColsFitRight,
	numCols,
	oldRightGridCol,
	spareSpaceAtRight,
	numColsFitSpareSpace	: Integer;
begin
	frameWidth := self.myDrawingFrame.clientWidth();
	gridWidthPixels := self.getGridWidth();
	lcWidthPixels := self.getLCWidth();
	
	cx := frameWidth/2;

	// calculate the right offset
	// New
	self.rightOffset := cx.Integer;
	if self.isLandscape then
		self.rightOffset := self.rightOffset - self.getSizeInPixels(self.lcYGridOffsetFt).Integer;
	else
		self.rightOffset := self.rightOffset - self.getSizeInPixels(self.lcXGridOffsetFt).Integer;
	endif;
	self.rightOffset := (self.rightOffset - lcWidthPixels/2).Integer;
	//
			
	// calculate the number of grid columns that will fit to the left (fully in view)
	leftSpare := frameWidth - (self.rightOffset + gridWidthPixels);
	numColsFitLeft := (leftSpare / gridWidthPixels).Integer;

	// calculate the number of columns that will fit to the right (fully in view)
	rightSpare := self.rightOffset-1;
	numColsFitRight := (rightSpare / gridWidthPixels).Integer;
			
	// calc max number of rows/columns
	self.calcMaxRowsCols();
	

	// Calculate the left col
	self.leftGridCol := self.colLC + numColsFitLeft;
	if self.leftGridCol &gt; self.maxGridCol then
		self.leftGridCol := self.maxGridCol;
	endif;
	
	// calculate the right col
	self.rightGridCol := self.colLC - numColsFitRight;
	if self.rightGridCol &lt; 1 then
		self.rightGridCol := 1;
	endif;
	
	// Calculate the number of grid cols available to the right of the  highlighted location
	numColsAvailRight := self.colLC - 1;
	if numColsAvailRight &gt; numColsFitRight then
		numCols := self.leftGridCol - self.rightGridCol + 1;
		
		// Calculate the spare space betwwen the RHS of the frame and the first column that fits fully.
		spareSpace := rightOffset - (numColsFitRight * gridWidthPixels);
		if spareSpace &gt; 0 then
			if self.rightGridCol &gt; 1 then
				// We can display one more grid column, partially, do this by adjusting the hScroll ofset
				self.rightGridCol := self.rightGridCol - 1;
				self.hScrollOffset := (gridWidthPixels - spareSpace).Integer;
				self.rightOffset := 0;
			endif;
		endif;	
		
		if self.myLeftVLabelsFrame &lt;&gt; null then
			labelOffset := self.myLeftVLabelsFrame.left + self.myLeftVLabelsFrame.width;
		endif;
		
		spareSpaceAtLeft := frameWidth - spareSpace - self.rightOffset - numCols*gridWidthPixels - self.myDrawingFrame.left.abs() - labelOffset;
		if spareSpaceAtLeft &gt; 0 then
			numCols := (spareSpaceAtLeft/gridWidthPixels).Integer;
			oldRightGridCol := self.rightGridCol;
			self.rightGridCol := self.rightGridCol - numCols;
			if self.rightGridCol &lt; 1 then
				self.rightGridCol := 1;
				self.rightOffset := self.rightOffset + (spareSpaceAtLeft - (oldRightGridCol-1)*gridWidthPixels).Integer;
			else
				self.rightOffset := self.rightOffset + (spareSpaceAtLeft - numCols*gridWidthPixels).Integer;
			endif;
		endif;
	else
		//09/11/2010 cnwdz2 26196
		if self.myRightVLabelsFrame &lt;&gt; null then
			labelOffset := self.myRightVLabelsFrame.width;
		endif;
		
		// Adjust for the actual number of columns which fit to the right 
		self.rightOffset := (self.myDrawingFrame.left.abs() + labelOffset).Integer;
		numCols := ((frameWidth - self.rightOffset)/gridWidthPixels).Integer;
		self.leftGridCol := self.rightGridCol + numCols - 1;
		if self.leftGridCol &gt; self.maxGridCol then
			self.leftGridCol := self.maxGridCol;
		endif;			
	endif;
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="calcCenteredColumnsUnflipped" id="78079307-5af8-4f9b-9735-8decedeb0caa">
        <updating/>
        <source>calcCenteredColumnsUnflipped() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
12 May 2010	cnwjk3	Initial creation

*/

vars
	spareSpace,
	lcWidthPixels,
	gridWidthPixels,
	leftSpare,
	rightSpare,
	leftSpaceFitLabelAndLeftOffset,
	spareSpaceAtRight,
	labelOffset,
	frameWidth,
	cx 					: Real;
	numColsAvailLeft,
	numColsFitLeft,
	numColsFitLabelAndLeftOffset,	
	numColsFitRight,
 	numCols,
	oldLeftGridCol		: Integer;
begin
	frameWidth := self.myDrawingFrame.clientWidth();
	gridWidthPixels := self.getGridWidth();
	lcWidthPixels := self.getLCWidth();
	
	cx := frameWidth/2;
	
	// New  
	// Calculate the left offset
	self.leftOffset := cx.Integer;
	if self.isLandscape then
		self.leftOffset := self.leftOffset - self.getSizeInPixels(self.lcYGridOffsetFt).Integer;
	else
		self.leftOffset := self.leftOffset - self.getSizeInPixels(self.lcXGridOffsetFt).Integer;
	endif;
	self.leftOffset := (self.leftOffset - lcWidthPixels/2).Integer;
	//
	
	// calculate the number of grid columns that will fit to the left (fully in view)
	leftSpare := self.leftOffset-1;	
	numColsFitLeft := (leftSpare / gridWidthPixels).Integer;

	// calculate the number of columns that will fit to the right (fully in view)
	rightSpare := frameWidth - (self.leftOffset + gridWidthPixels);
	numColsFitRight := (rightSpare / gridWidthPixels).Integer;
	
	self.calcMaxRowsCols();
	
	// Calculate the left col
	self.leftGridCol := self.colLC - numColsFitLeft;
	if self.leftGridCol &lt; 1 then
		self.leftGridCol := 1;
	endif;
	
	// calculate the right col
	self.rightGridCol := self.colLC + numColsFitRight;
	if self.rightGridCol &gt; self.maxGridCol then
		self.rightGridCol := self.maxGridCol;
	endif;		
	
	
	// Calculate the number of grid cols available to the left of the  highlighted location
	numColsAvailLeft := self.colLC - 1;
	if numColsAvailLeft &gt;  numColsFitLeft then
		numCols := self.rightGridCol - self.leftGridCol + 1;
		
		// Calculate the spare space betwwen the RHS of the frame and the first column that fits fully.
		spareSpace := leftOffset - (numColsFitLeft * gridWidthPixels);
		if spareSpace &gt; 0 then
			if self.leftGridCol &gt; 1 then
				// We can display one more grid column, partially, do this by adjusting the hScroll ofset
				self.leftGridCol := self.leftGridCol - 1;
				self.hScrollOffset := (spareSpace - gridWidthPixels).Integer;
				self.leftOffset := 0;
			endif;
		endif;	
		
		if self.myRightVLabelsFrame &lt;&gt; null then
			labelOffset := self.myRightVLabelsFrame.width;
		endif;
		
		spareSpaceAtRight := frameWidth - spareSpace - self.leftOffset - numCols*gridWidthPixels - self.myDrawingFrame.left.abs() - labelOffset;
		if spareSpaceAtRight &gt; 0 then
			numCols := (spareSpaceAtRight/gridWidthPixels).Integer;
			oldLeftGridCol := self.leftGridCol;
			self.leftGridCol := self.leftGridCol - numCols;
			if self.leftGridCol &lt; 1 then				
				self.leftGridCol := 1;	
				self.leftOffset := self.leftOffset + (spareSpaceAtRight - (oldLeftGridCol-1)*gridWidthPixels).Integer;
			else
				self.leftOffset := self.leftOffset + (spareSpaceAtRight - numCols*gridWidthPixels).Integer;
			endif;
		endif;
	else
		//28/09/2010 cnwdz2 25641
		if self.myLeftVLabelsFrame &lt;&gt; null then
			labelOffset := self.myLeftVLabelsFrame.left + self.myLeftVLabelsFrame.width;
		endif;
		
		self.leftOffset := (self.myDrawingFrame.left.abs() + labelOffset).Integer;
		
		numCols := ((frameWidth - self.leftOffset)/gridWidthPixels).Integer;
		self.rightGridCol := self.leftGridCol + numCols - 1;
		if self.rightGridCol &gt; self.maxGridCol then
			self.rightGridCol := self.maxGridCol;
		endif;	
	endif;
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="calcCenteredRowsFlipped" id="44fa0f68-a2c0-458a-8a4a-e3dafdb9ba35">
        <updating/>
        <source>calcCenteredRowsFlipped() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
12 May 2010	cnwjk3	Initial creation

*/

vars
	spareSpace,
	lcHeightPixels,
	gridHeightPixels,
	topSpare,
	bottomSpare,
	frameHeight,
	labelOffset,
	spareSpaceAtTop,
	cy 				: Real;
	numRowsAvailBottom,
	numRowsFitTop,
	numRowsFitBottom,
	numRows,
	oldBottomGridRow,
	spareSpaceAtBottom	: Integer;
begin
	frameHeight := self.myDrawingFrame.clientHeight();
	gridHeightPixels := self.getGridHeight();
	lcHeightPixels := self.getLCHeight();
	
	cy := frameHeight/2;

	// calculate the bottom offset
	// New
	self.bottomOffset := cy.Integer;
	if self.isLandscape then
		self.bottomOffset := self.bottomOffset - self.getSizeInPixels(self.lcXGridOffsetFt).Integer;
	else
		self.bottomOffset := self.bottomOffset - self.getSizeInPixels(self.lcYGridOffsetFt).Integer;
	endif;
	self.bottomOffset := (self.bottomOffset - lcHeightPixels/2).Integer;
	//

	// calculate the number of grid rows that will fit to the top (fully in view)
	topSpare := frameHeight - (self.bottomOffset + gridHeightPixels);
	numRowsFitTop := (topSpare / gridHeightPixels).Integer;

	// calculate the number of rows that will fit to the bottom (fully in view)
	bottomSpare := self.bottomOffset-1;
	numRowsFitBottom := (bottomSpare / gridHeightPixels).Integer;
			
	// calc max number of rows/columns
	self.calcMaxRowsCols();

	// Calculate the top row
	self.topGridRow := self.rowLC + numRowsFitTop;
	if self.topGridRow &gt; self.maxGridRow then
		self.topGridRow := self.maxGridRow;
	endif;
	
	// calculate the bottom row
	self.bottomGridRow := self.rowLC - numRowsFitBottom;
	if self.bottomGridRow &lt; 1 then
		self.bottomGridRow := 1;
	endif;

	// Calculate the number of grid rows available to the bottom of the  highlighted location
	numRowsAvailBottom := self.rowLC - 1;
	if numRowsAvailBottom &gt; numRowsFitBottom then	
		
		numRows := self.topGridRow - self.bottomGridRow + 1;
		
		// Calculate the spare space between the bottom of the frame and the first row that fits fully.
		spareSpace := self.bottomOffset - (numRowsFitBottom * gridHeightPixels).Integer;
		if spareSpace &gt; 0 then
			if self.bottomGridRow &gt; 1 then
				// We can display one more grid row, partially, do this by adjusting the vScroll ofset
				self.bottomGridRow := self.bottomGridRow - 1;
				self.vScrollOffset := (gridHeightPixels - spareSpace).Integer;
				self.bottomOffset := 0;
			endif;
		endif;	
				
		//28/09/2010 cnwdz2 25641
		if self.myTopHLabelsFrame &lt;&gt; null then
			labelOffset := self.myTopHLabelsFrame.top + self.myTopHLabelsFrame.height;
		endif;
		
		spareSpaceAtTop := frameHeight - spareSpace - self.bottomOffset - numRows*gridHeightPixels - self.myDrawingFrame.top.abs() - labelOffset;
		if spareSpaceAtTop &gt; 0 then
			numRows := (spareSpaceAtTop/gridHeightPixels).Integer;
			oldBottomGridRow := self.bottomGridRow;
			self.bottomGridRow := self.bottomGridRow - numRows;
			if self.bottomGridRow &lt; 1 then
				self.bottomGridRow := 1;
				self.bottomOffset := self.bottomOffset + (spareSpaceAtTop - (oldBottomGridRow-1)*gridHeightPixels).Integer;
			else
				self.bottomOffset := self.bottomOffset + (spareSpaceAtTop - numRows*gridHeightPixels).Integer;
			endif;			
		endif;
	else
		//09/11/2010 cnwdz2 26196
		if self.myBottomHLabelsFrame &lt;&gt; null then
			labelOffset := self.myBottomHLabelsFrame.height;
		endif;
		
		self.bottomOffset := self.getScrollOffsetSize() + labelOffset.Integer;
		numRows := ((frameHeight - self.bottomOffset)/gridHeightPixels).Integer;
		self.topGridRow := self.bottomGridRow + numRows - 1;
		if self.topGridRow &gt; self.maxGridRow then
			self.topGridRow := self.maxGridRow;
		endif;	
	endif;			
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="calcCenteredRowsUnflipped" id="6dade58b-403d-4c03-946c-9e1b7d4c0ad0">
        <updating/>
        <source>calcCenteredRowsUnflipped() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
12 May 2010	cnwjk3	Initial creation

*/

vars
	spareSpace,
	lcHeightPixels,
	gridHeightPixels,
	topSpare,
	bottomSpare,
	frameHeight,
	labelOffset,
	spareSpaceAtTop,
	numColsFitTopSpareSpace,
	spareSpaceAtBottom,
	cy 					: Real;
	numRowsAvailTop,
	numRowsFitTop,
	numRowsFitBottom,
 	numRows,
	oldTopGridRow	: Integer;
begin
	frameHeight := self.myDrawingFrame.clientHeight();
	gridHeightPixels := self.getGridHeight();
	lcHeightPixels := self.getLCHeight();
	
	cy := frameHeight/2;

	// New 
	// calculate the left offset
	self.topOffset := cy.Integer;
	if self.isLandscape then
		self.topOffset := self.topOffset - self.getSizeInPixels(self.lcXGridOffsetFt).Integer;
	else
		self.topOffset := self.topOffset - self.getSizeInPixels(self.lcYGridOffsetFt).Integer;
	endif;
	self.topOffset := (self.topOffset - lcHeightPixels/2).Integer;
	//

	// calculate the number of grid rows that will fit to the top (fully in view)
	topSpare := self.topOffset-1;	
	numRowsFitTop := (topSpare / gridHeightPixels).Integer;

	// calculate the number of rows that will fit to the bottom (fully in view)
	bottomSpare := frameHeight - (self.topOffset + gridHeightPixels);
	numRowsFitBottom := (bottomSpare / gridHeightPixels).Integer;
	
	self.calcMaxRowsCols();

	// Calculate the top row
	self.topGridRow := self.rowLC - numRowsFitTop;
	if self.topGridRow &lt; 1 then
		self.topGridRow := 1;
	endif;
	
	// calculate the bottom row
	self.bottomGridRow := self.rowLC + numRowsFitBottom;
	if self.bottomGridRow &gt; self.maxGridRow then
		self.bottomGridRow := self.maxGridRow;
	endif;		
	
	// Calculate the number of grid rows available to the top of the  highlighted location
	numRowsAvailTop := self.rowLC - 1;
	if numRowsAvailTop &gt;  numRowsFitTop then
		numRows := self.bottomGridRow - self.topGridRow + 1;
		
		// Calculate the spare space betwwen the top of the frame and the first row that fits fully.
		spareSpace := topOffset - (numRowsFitTop * gridHeightPixels).Integer;
		if spareSpace &gt; 0 then
			if self.topGridRow &gt; 1 then
				// We can display one more grid row, partially, do this by adjusting the vScroll ofset
				self.topGridRow := self.topGridRow - 1;
				self.vScrollOffset := (spareSpace - gridHeightPixels).Integer;
				self.topOffset := 0;
			endif;
		endif;
		
		if self.myBottomHLabelsFrame &lt;&gt; null then
			labelOffset := self.myBottomHLabelsFrame.height;
		endif;
		
		spareSpaceAtBottom := frameHeight - spareSpace - self.topOffset - numRows*gridHeightPixels - self.getScrollOffsetSize() - labelOffset;
		if spareSpaceAtBottom &gt; 0 then
			numRows := (spareSpaceAtBottom/gridHeightPixels).Integer;
			oldTopGridRow := self.topGridRow;
			self.topGridRow := self.topGridRow - numRows;
			if self.topGridRow &lt; 1 then
				self.topGridRow := 1;
				self.topOffset := self.topOffset + (spareSpaceAtBottom - (oldTopGridRow-1)*gridHeightPixels).Integer;
			else
				self.topOffset := self.topOffset + (spareSpaceAtBottom - numRows*gridHeightPixels).Integer;
			endif;			
		endif;
	else
		//28/09/2010 cnwdz2 25641
		if self.myTopHLabelsFrame &lt;&gt; null then
			labelOffset := self.myTopHLabelsFrame.top + self.myTopHLabelsFrame.height;
		endif;
			
		self.topOffset := (self.myDrawingFrame.top.abs() + labelOffset).Integer;
		
		numRows := ((frameHeight - self.topOffset)/gridHeightPixels).Integer;
		self.bottomGridRow := self.topGridRow + numRows - 1;
		if self.bottomGridRow &gt; self.maxGridRow then
			self.bottomGridRow := self.maxGridRow;
		endif;	
	endif;
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="calcDrawCols" id="e0c283ac-d027-42c4-9fca-e5acac0eb5ad">
        <updating/>
        <source>calcDrawCols() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 April 2010	cnwjk3	Initial creation

*/

vars

begin
	if self.flipH then
		self.calcGridDrawColsFlipped();
	else
		self.calcGridDrawColsUnflipped();
	endif;
	
	// Keep things in range
	if self.leftGridColDraw &gt; self.maxGridCol then
		self.leftGridColDraw := self.maxGridCol;
	endif;
	
	if self.leftGridColDraw &lt; 1 then
		self.leftGridColDraw := 1;
	endif;

	if self.rightGridColDraw &gt; self.maxGridCol then
		self.rightGridColDraw := self.maxGridCol;
	endif;
	
	if self.rightGridColDraw &lt; 1 then
		self.rightGridColDraw := 1;
	endif;

	if self.leftGridCol &gt; self.maxGridCol then
		self.leftGridCol := self.maxGridCol;
	endif;
	
	if self.leftGridCol &lt; 1 then
		self.leftGridCol := 1;
	endif;

	if self.rightGridCol &gt; self.maxGridCol then
		self.rightGridCol := self.maxGridCol;
	endif;
	
	if self.rightGridCol &lt; 1 then
		self.rightGridCol := 1;
	endif;
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="calcDrawRows" id="e2864a1f-6b6f-4b3f-99b7-23217f80dc59">
        <updating/>
        <source>calcDrawRows() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 April 2010	cnwjk3	Initial creation

*/

vars

begin
	if self.flipV then
		self.calcGridDrawRowsFlipped();
	else
		self.calcGridDrawRowsUnflipped();
	endif;
	
	// Keep things in range
	if self.topGridRowDraw &gt; self.maxGridRow then
		self.topGridRowDraw := self.maxGridRow;
	endif;
	
	if self.topGridRowDraw &lt; 1 then
		self.topGridRowDraw := 1;
	endif;

	if self.bottomGridRowDraw &gt; self.maxGridRow then
		self.bottomGridRowDraw := self.maxGridRow;
	endif;
	
	if self.bottomGridRowDraw &lt; 1 then
		self.bottomGridRowDraw := 1;
	endif;

	if self.topGridRow &gt; self.maxGridRow then
		self.topGridRow := self.maxGridRow;
	endif;
	
	if self.topGridRow &lt; 1 then
		self.topGridRow := 1;
	endif;

	if self.bottomGridRow &gt; self.maxGridRow then
		self.bottomGridRow := self.maxGridRow;
	endif;
	
	if self.bottomGridRow &lt; 1 then
		self.bottomGridRow := 1;
	endif;

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="calcGridDrawColsFlipped" id="727e6c48-3bd7-4a29-8c6c-e87922493282">
        <updating/>
        <source>calcGridDrawColsFlipped() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 April 2010	cnwjk3	Initial creation

*/

vars
 
begin
	if self.numGridColsFit &lt; self.maxGridCol and self.leftGridCol &lt; self.maxGridCol then
		self.leftGridColDraw := self.leftGridCol + 1;
	else
		self.leftGridColDraw := self.leftGridCol;
	endif;
	self.rightGridColDraw := self.rightGridCol;
	
	
	self.xDrawOffset := 0;
	if self.hScrollOffset &lt; 0 then
		if self.rightGridColDraw &gt; 1 then  
			self.rightGridColDraw := self.rightGridColDraw -1;
			self.xDrawOffset := (self.hScrollOffset + self.getGridWidth()).Integer;
		endif;
	else
		self.xDrawOffset := self.hScrollOffset;
	endif;
			
	self.numGridColsToDraw := self.leftGridColDraw - self.rightGridColDraw + 1;	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="calcGridDrawColsUnflipped" id="58a4679c-67ec-4c79-8eff-fc38fc9e4758">
        <updating/>
        <source>calcGridDrawColsUnflipped() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21 April 2010	cnwjk3	Initial creation

*/

vars

begin
	// Calculate how many columns we want to draw. This may be 1 more than fits,
	// to allow drawing of items which don't quite fit, rather than leaving a blank space
	// at the right of the viewport
	
	if self.numGridColsFit &lt; self.maxGridCol and self.rightGridCol &lt; self.maxGridCol then
		self.rightGridColDraw := self.rightGridCol + 1;
	else
		self.rightGridColDraw := self.rightGridCol;
	endif;
	self.leftGridColDraw := self.leftGridCol;
	
	// Adjust for partial scroll, where LHS column should be partially drawn
	self.xDrawOffset := 0;
	if self.hScrollOffset &gt; 0 then
		if self.leftGridColDraw &gt; 1 then
			self.leftGridColDraw := self.leftGridColDraw - 1;
			self.xDrawOffset := (self.hScrollOffset - self.getGridWidth()).Integer;
		endif;
	elseif self.hScrollOffset &lt; 0 then
		self.xDrawOffset := self.hScrollOffset;
	endif;
		
	self.numGridColsToDraw := self.rightGridColDraw - self.leftGridColDraw + 1;

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="calcGridDrawRowsFlipped" id="774faa40-4805-4181-a9f6-8120d45564f6">
        <updating/>
        <source>calcGridDrawRowsFlipped() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 April 2010	cnwjk3	Initial creation

*/

vars

begin
	if self.numGridRowsFit &lt; self.maxGridRow and self.topGridRow &lt; self.maxGridRow then
		self.topGridRowDraw := self.topGridRow + 1;
	else
		self.topGridRowDraw := self.topGridRow;
	endif;
	self.bottomGridRowDraw := self.bottomGridRow;
	
	
	self.yDrawOffset := 0;
	if self.vScrollOffset &lt; 0 then
		if self.bottomGridRowDraw &gt; 1 then  
			self.bottomGridRowDraw := self.bottomGridRowDraw -1;
			self.yDrawOffset := (self.vScrollOffset + self.getGridHeight()).Integer;
		endif;
	else
		self.yDrawOffset := self.vScrollOffset;
	endif;
			
	self.numGridRowsToDraw := self.topGridRowDraw - self.bottomGridRowDraw + 1;	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="calcGridDrawRowsUnflipped" id="3b17a7da-8982-40a8-bb2e-c635e60bdc09">
        <updating/>
        <source>calcGridDrawRowsUnflipped() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 April 2010	cnwjk3	Initial creation

*/

vars

begin
	// Calculate how many rows we want to draw. This may be 1 more than fits,
	// to allow drawing of items which don't quite fit, rather than leaving a blank space
	// at the bottom of  the viewport
	if self.numGridRowsFit &lt; self.maxGridRow  and  self.bottomGridRow &lt; self.maxGridRow then
		self.bottomGridRowDraw := self.bottomGridRow + 1;
	else
		self.bottomGridRowDraw := self.bottomGridRow;
	endif;
	self.topGridRowDraw := self.topGridRow;	

	// Adjust for partial scroll, where TOP row should be partially drawn
	self.yDrawOffset := 0;
	if self.vScrollOffset &gt; 0 then
		if self.topGridRowDraw &gt; 1 then
			self.topGridRowDraw := self.topGridRowDraw - 1;
			self.yDrawOffset := (self.vScrollOffset - self.getGridHeight()).Integer;
		endif;
	elseif self.vScrollOffset &lt; 0 then
		self.yDrawOffset := self.vScrollOffset;
	endif;
	
	self.numGridRowsToDraw := self.bottomGridRowDraw - self.topGridRowDraw + 1;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="calcMaxRowsCols" id="468387f0-4d62-4f8b-90c5-81462cae6a18">
        <updating/>
        <source>calcMaxRowsCols() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 May 2010	cnwjk3	Initial creation

*/

vars

begin
	if self.isLandscape then
		if self.isLocationInGriddedArea(self.myTargetLocation) and self.myGridArea &lt;&gt; null then
			if self.drawMode = CMIF_RDTDrawElement.MODE_TOPDOWN then
				self.maxGridRow := self.myGridArea.numberOfRows;
				self.maxGridCol := self.myGridArea.numberOfColumns;
			elseif self.drawMode = CMIF_RDTDrawElement.MODE_FACE then
				self.maxGridRow := self.myGridArea.getHeightOfStack();
				self.maxGridCol := self.myGridArea.numberOfColumns;				
			else
				// End view
				self.maxGridRow := self.myGridArea.getHeightOfStack();
				self.maxGridCol := self.myGridArea.numberOfRows;								
			endif;
		else
			self.maxGridRow := self.myDisplayBuilder.getMaxGridRow();
			self.maxGridCol := self.myDisplayBuilder.getMaxGridCol();			
		endif;
	else
		if self.isLocationInGriddedArea(self.myTargetLocation) and self.myGridArea &lt;&gt; null then
			if self.drawMode = CMIF_RDTDrawElement.MODE_TOPDOWN then
				self.maxGridRow := self.myGridArea.numberOfColumns;
				self.maxGridCol := self.myGridArea.numberOfRows;
			elseif self.drawMode = CMIF_RDTDrawElement.MODE_FACE then
				// Portrait on FACE view is not supported as it doesn't make sense
			else
				// Portrait on END view is not supported as it doesn't make sense
			endif;
		else
			self.maxGridRow := self.myDisplayBuilder.getMaxGridCol();
			self.maxGridCol := self.myDisplayBuilder.getMaxGridRow();		
		endif;
	endif;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="calcNumFullyVisibleGridCols" id="7b277b91-0c6d-4723-bffb-060f277979ca">
        <source>calcNumFullyVisibleGridCols() : Integer protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
07 April 2010	cnwjk3	Initial creation

*/

vars
	maxX,
	gridWidth : Real;
	numFullyVisibleCols : Integer; 
begin
	if self.flipH then
		maxX := self.myDrawingFrame.clientWidth() + self.hScrollOffset - self.rightOffset;
	else
		maxX := self.myDrawingFrame.clientWidth() - self.hScrollOffset - self.leftOffset;
	endif;
	
	gridWidth := self.getGridWidth();
	
	// Remember drawing portrait for now, so width and length are swapped
	numFullyVisibleCols := (maxX div gridWidth).Integer;
	
	return numFullyVisibleCols;
	
epilog

end;</source>
        <access>protected</access>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="calcNumFullyVisibleGridRows" id="533bde7e-b42b-49e1-92b2-4e390aff4646">
        <source>calcNumFullyVisibleGridRows() : Integer protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
07 April 2010	cnwjk3	Initial creation

*/

vars
	maxY,
	gridHeight : Real;
	numFullyVisibleRows : Integer; 
begin
	if self.flipV then
		maxY := self.myDrawingFrame.clientHeight() + self.vScrollOffset - self.bottomOffset;
	else
		maxY := self.myDrawingFrame.clientHeight() - self.vScrollOffset - self.topOffset;
	endif;
	
	gridHeight := self.getGridHeight();
	
	// Remember drawing portrait for now, so width and length are swapped
	numFullyVisibleRows := (maxY div gridHeight).Integer;

	return numFullyVisibleRows;
	
epilog

end;</source>
        <access>protected</access>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="calcViewSizes" id="9ed91e11-cf22-4c11-baa9-b0d41635bc45">
        <updating/>
        <source>calcViewSizes() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 April 2010	cnwjk3	Initial creation

*/

vars

begin
	self.calcMaxRowsCols();
	
	// Calculate the number of rows we can fit on screen
	self.numGridRowsFit := self.calcNumFullyVisibleGridRows();
	if self.numGridRowsFit &gt; self.maxGridRow then
		self.numGridRowsFit := self.maxGridRow;
	endif;
	
	// Calculate the number of columns we can fit on screen
	self.numGridColsFit := self.calcNumFullyVisibleGridCols();
	if self.numGridColsFit &gt; self.maxGridCol then
		self.numGridColsFit := self.maxGridCol;
	endif;
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="canBottomRowFitOnScreen" id="c5b427b9-4d0e-4cfe-a622-665fe48ee2d0">
        <source>canBottomRowFitOnScreen( _row : Integer) : Boolean protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
12 April 2010	cnwjk3	Initial creation

*/

vars

begin
	if self.flipV then
		if _row &gt; self.topGridRow - self.numGridRowsFit then
			return true;
		else
			return false;
		endif;
	else
		if _row &lt; self.topGridRow + self.numGridRowsFit then
			return true;
		else
			return false;
		endif;
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_row" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="canDrawForkLiftStackBottom" id="a44439fc-eab1-48c5-9da1-4dca3c7286cf">
        <source>canDrawForkLiftStackBottom() : Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 June 2011	#cnwdz2	 27732

*/

vars
	forkLiftStack : CM_ForkLiftStack;
begin
	if not self.isDrawForkLiftStack(self.myTargetLocation) then
		return false;
	endif;
	
	forkLiftStack := self.myTargetLocation.myTerminalArea.CM_ForkLiftStack;
	if not forkLiftStack.accessFront then
		return false;
	endif;
	
	return true;
epilog

end;</source>
        <ReturnType type="Boolean"/>
