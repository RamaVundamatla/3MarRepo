    <JadeMethod name="initializeSelf" id="5ea2ff11-c09a-481e-9676-cfe476b6e3de">
        <updating/>
        <source>initializeSelf(_taViewInterface : IF_CM_TerminalAreaViews; _taView :CM_TerminalAreaView) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 November 2010	cnwer1	Initial creation

*/

vars

begin
	self.setMyTAViewInterface(_taViewInterface);
	self.setMyTerminalAreaView(_taView);
epilog

end;</source>
