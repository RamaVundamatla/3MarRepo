<Class name="CMIF_ReportDateSorter" id="11800b91-88f8-472d-ac8f-4185eb63531b">
    <superclass name="CMIF_Object"/>
    <transient/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="query"/>
    <PrimAttribute name="dateTime" id="16758667-5903-4907-a2a6-ca474f89bbab">
        <embedded/>
        <type name="TimeStamp"/>
    </PrimAttribute>
    <JadeMethod name="getDateTimeLocalTZ" id="6aeea318-2fe5-4766-b9e8-a74cb574459a">
        <source>getDateTimeLocalTZ() : TimeStamp;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 June 2016	cnwns1	Initial creation
// 02 June 2016	cnwns1	TFS 488 - Multi Timezone Support
*/

vars

begin
	return self.systemToLocalTime(self.dateTime);
epilog

end;</source>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="getWeek" id="22186d8c-0655-438c-a172-dc3edd81606c">
        <source>getWeek() : String;
// --------------------------------------------------------------------------------
// Created:		19 November 2009 by cnwjo3
//
// Purpose:		Return week number.  Week 1 is Saturday 3 January 2009 to Firday 9 January 2009.  Week 2 is Saturday 10 Jan to Friday 16 Jan 2009, etc
//				CCMS 1869
vars
	d : Date;
	weekCount : Integer;
begin
	d.setDate(1,1,dateTime.date.year);

	while d &lt; dateTime.date do
		if d.dayOfWeek = 5 then
			weekCount := weekCount + 1;
		endif;
		d := d.addDays(1);
	endwhile;
	
	return "Week " &amp; weekCount.String;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
</Class>
