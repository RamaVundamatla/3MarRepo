    <JadeMethod name="filterObjects" id="492bca58-278b-4f8c-9fe7-54d401e274ef">
        <updating/>
        <source>filterObjects(_collection: Collection input; _passport: CM_Passport)updating;
// -------------------------------------------
// Created 12/08/2008 by comcms1
// -------------------------------------------
// 27/05/2009	concms1	par 19768 - new shipping line/voyage parameters
vars
	terminal	: CM_Terminal;
	iter,
	iterVoy		: Iterator;
	voyage		: CM_Voyage;
	startTs, endTs	:TimeStamp;
begin 
	startTs	:= null;
	endTs	:= null;
	
	inheritMethod (_collection, _passport);

	if self.getMyVoyage &lt;&gt; null then			// par 19768
		/* we are running for just one voyage */
		_collection.add (self.getMyVoyage);	// par 19768
		return;										// par 19768
	endif;											// par 19768
	
	if self.arriveDateFrom.isValid() and self.arriveDateTo.isValid() then
		startTs.setDate(self.arriveDateFrom);
		startTs.setTime(self.arriveTimeFrom.Time);	
		endTs.setDate(self.arriveDateTo);
		endTs.setTime(self.arriveTimeTo);
	endif;
	
	iter := self.allTerminals.createIterator();
	
	// Go through all selected terminals
	while iter.next(terminal) do
	
		// Set up starting point in voyages dict.
		delete iterVoy;
				
		// if we are only looking for one vessel then position the iterator at that vessel
		if self.getMyVessel &lt;&gt; null then
			iterVoy := terminal.allVoyagesByVesselCodeArrivDT.createIterator;	// par 19768

			terminal.allVoyagesByVesselCodeArrivDT.startKeyGeq(self.getMyVessel.code,startTs, iterVoy); // par 19768
		else																	// par 19768
			iterVoy := terminal.allVoyagesByArrivalDTCode.createIterator;		// par 19768
				
			if startTs &lt;&gt; null then												// par 19768
				terminal.allVoyagesByArrivalDTCode.startKeyGeq (startTs, null, iterVoy);	// par 19768
			endif;																// par 19768
		endif;																	// par 19768

		while (iterVoy.next(voyage)) do
			if self.getMyVessel &lt;&gt; null and voyage.vesselCode &lt;&gt; self.getMyVessel.code then
				// we are only looking for one vessel and we have gone past that vessel in the collection
				break;
			endif;			
			
			if startTs &lt;&gt; null and voyage.arrivedDT &lt; startTs then
				continue;
			endif;
			
			if endTs &lt;&gt; null and voyage.arrivedDT &gt; endTs then
				break;	// par 19768
			endif;
			
			if self.getMyShippingLine &lt;&gt; null and	// par 19768
				voyage.myShippingLine &lt;&gt; self.getMyShippingLine then	// par 19768
				continue;						// par 19768
			endif;
			
			_collection.add(voyage);
		endwhile;
	endwhile;	

epilog	
	delete iterVoy;
	delete iter;
end;</source>
        <Parameter name="_collection" type="Collection" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="getMyShippingLine" id="7f51497d-3017-4f84-b9a3-ec12c5caf8f4">
        <source>getMyShippingLine():CM_ShippingLine;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 July 2016	cnwndl1	Initial creation	TFS 2329

*/

vars

	object : CM_ShippingLine;
	edition : Integer;
	invalidObj : Boolean;

begin

	object := self.myShippingLine;

	if object = null then
		return null;
	endif;
	
	on Exception do app.handleDeletedObject( exception, object, invalidObj );
	edition := object.edition;
	
	if invalidObj then
		return null;
	endif;
	
	return object;

epilog

end;</source>
        <ReturnType type="CM_ShippingLine"/>
    </JadeMethod>
