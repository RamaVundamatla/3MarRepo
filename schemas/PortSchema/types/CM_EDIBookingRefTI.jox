    <JadeMethod name="assignValueSpecial" id="7565ff86-a48d-4954-b79d-6283333251f3">
        <updating/>
        <source>assignValueSpecial(_propName: String; _processedValue: String; _xlationOperator: CM_Operator): Boolean updating;
/*
Date		Who		Reason
20/04/2012	cnwdap1	Initial creation PAR #29475 CCMS PNL 2155 Handle container types and number of containers
18/09/2012	cnwcs5	par 30316 - changed parameter usage for _processedValue
07 Mar 2013	cnwcs5	CCMS POL 2097 / par 31259 - move hazards code from setEDITIProperty
10 May 2013	cnwcs5	par 31626 - make method public so can be used for hook code
*/
vars
	isoType	 	: String;
	foundMatch	: Boolean;
begin
	// check for translations for operator
	if _propName.isOneOf(ETRow_ContainerType1, ETRow_ContainerType2) then
		if _xlationOperator = null then
			isoType := _processedValue;
		else
			isoType := _xlationOperator.getXlationSystemCode(_processedValue, XLATION_TYPE_ISOTYPE_BYOP, foundMatch);	// par 31259 March 2013
		endif;
	endif;
	
	if _propName = ETRow_ContainerType1 then
		self.containerTypes.atPut(1, isoType);
		return true;
		
	elseif _propName = ETRow_ContainerType2 then
		self.containerTypes.atPut(2, isoType);
		return true;
		
	elseif _propName = ETRow_ContainerNbr1 then
		self.containerNbrs.atPut(1, _processedValue.Integer);
		return true;
		
	elseif _propName = ETRow_ContainerNbr2 then
		self.containerNbrs.atPut(2, _processedValue.Integer);
		return true;
		
	elseif  _propName = CM_EDIBookingRefTI::imCodes.name then	// this is a string array
		// par 31259 - moveed from setEDITIProperty
		self.setImCodes(_processedValue.String);
		return true;
	endif;
	
	return inheritMethod(_propName, _processedValue, _xlationOperator);
epilog

end;</source>
        <Parameter name="_propName" type="String"/>
        <Parameter name="_processedValue" type="String"/>
        <Parameter name="_xlationOperator" type="CM_Operator"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="canUserSet" id="6de3ca35-73df-4f9a-941d-4c2dbe8efa58">
        <source>canUserSet(_propName: String): Boolean;
//
// 30 Jun 2014	cnwrs1	Par 34702 - Add support for JMT XML
//
// 15 Jun 2017	cnwrs1	TFS 4462 SNO add Terminal Operator, Unknown Seal and support multiple seals
vars

begin
	if _propName = CM_EDIBookingRefTI::myBookingRefItem.name or
	   _propName = CM_EDIBookingRefTI::groupCodeForEDIMultiItem.name or
	   _propName = CM_EDIBookingRefTI::containerTypes.name or 
	   _propName = CM_EDIBookingRefTI::imCodes.name or 
	   _propName = CM_EDIBookingRefTI::containerNbrs.name or 
	   _propName = CM_EDIBookingRefTI::myBookingRef.name then	// Hide myBookingRef from being listed in the XSDs
		return false;
	elseif _propName = CM_EDITrackedItem::subTerminalCode.name then	// Booking Item/Release Request is allowed to use this field
		return true;
	else
		return inheritMethod(_propName);
	endif;
end;
</source>
        <Parameter name="_propName" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="cargoTypeDescr" id="0ad44f1a-222e-46ac-9bf6-2791d944ad06">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <source>cargoTypeDescr(set : Boolean; _value : String io) mapping, updating;
// ---------------------------------------------------------------------------
// Created:     24 April 2008 by cnwaer1
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	cType : CM_CargoType;
	int : Integer;
begin
	if set then
		int := app.myRoot.getCargoTypeIDFromDescription(_value);
		if int &lt;&gt; 0 then
			self.cargoType := int;
		endif;
	else
		cType := app.myRoot.allCargoTypesById[self.cargoType];
		if cType &lt;&gt; null then
			_value := cType.description;
		endif;
	endif;
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="create" id="ba3bf624-63b2-49d0-983e-88aff5266bec">
        <updating/>
        <source>create() updating;

vars

begin
	self.messageMode := null; //par 21396 cnwrs1 oct 2009
	self.temperature := NULL_TEMPERATURE;
	self.setCarbonDioxide( NULL_CARBON_DIOXIDE );
	self.setHumidity( NULL_HUMIDITY );
	self.setOxygen( NULL_OXYGEN );
	self.vent := NULL_VENTILATION; //par19252 cnwrs1 may 2009
end;
</source>
    </JadeMethod>
    <JadeMethod name="delete" id="b4b803ea-798a-4156-af36-5ecf968b82fa">
        <updating/>
        <source>delete() updating;

/*
Date			Who		Reason
14 June 2010	cnwrl1	Initial creation as part of PAR 24299 - SFW 1118 EDI Form to allow searching of EDI file by Container / Voyage
*/
	
vars
	voyageCodeStr	: String;
	
begin
	// remove this EDITrackedItem from the manual collection on myEDIConfig if it is there
	if self.myEDIConfig = null then
		return;
	endif;
	
	voyageCodeStr	:= self.getRawVoyageCode();
	if voyageCodeStr &lt;&gt; null then
		if self.myEDIConfig.allEDITrackedItemsByVoyageCode.includesKey( voyageCodeStr.toUpper, self ) then
			self.myEDIConfig.allEDITrackedItemsByVoyageCode.removeKeyEntry( voyageCodeStr.toUpper, self, self );
		endif;
	endif;
	
epilog
	
end;
</source>
    </JadeMethod>
    <JadeMethod name="destinationPort" id="16a7ad8a-aacd-4c40-9d2b-9e41ebb024da">
        <methodInvocation>mapping</methodInvocation>
        <source>destinationPort(set: Boolean; _value: String io) mapping;
// cnwrs1 June 2006 protected the old 3 digit codes
vars
	port : CM_Port;
begin
	if not set then
		if self.destinationPort.length = 3 then
			port := app.myRoot.allLocodesByShortCode.getAtKeyGeq(self.destinationPort, null);
			if port &lt;&gt; null and port.portCode = self.destinationPort then
				_value := port.code;
			else
				_value := self.destinationPort;
			endif;
		else
			_value := self.destinationPort;
		endif;
	endif;
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="dischargePort" id="64c482b3-80d9-477e-a4cc-d48dd481eaf9">
        <methodInvocation>mapping</methodInvocation>
        <source>dischargePort(set: Boolean; _value: String io) mapping;
// cnwrs1 June 2006 protected the old 3 digit codes
vars
	port : CM_Port;
begin
	if not set then
		if self.dischargePort.length = 3 then
			port := app.myRoot.allLocodesByShortCode.getAtKeyGeq(self.dischargePort, null);
			if port &lt;&gt; null and port.portCode = self.dischargePort then
				_value := port.code;
			else
				_value := self.dischargePort;
			endif;
		else
			_value := self.dischargePort;
		endif;
	endif;
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="findRealBookingRef" id="e62c6bac-5870-43d3-b7ab-e8a3250e1e78">
        <source>findRealBookingRef(_terminal : CM_Terminal) : CM_BookingRef;
/* ---------------------------------------------------------------------------
Created:	19 January 2009	by cnwvu1

Purpose:	
   
Change Date		Who		Reason
13 Mar 2009     cnwrs1  Par 19160 - total rewrite to allow for records with an invalid operatorCode
04/04/2012		cnwcs5	par 29326 - unique bookings by operator
------------------------------------------------------------------------------*/
vars
	br, brTemp 				: CM_BookingRef;
	operator 				: CM_Operator;
	voyage 					: CM_Voyage;
	iterator 				: Iterator;
	lOperatorCode , 
	lVoyageCode 			: String;
	misVersionBookingRef 	: Boolean; //ccms 1855 cnwrs1 sept 2009
begin
	misVersionBookingRef 	:= _terminal.getConfig(ProcessMISVersionBkRef).Boolean; //cnwrs1 ccms 1855 Sept 2009
	voyage 					:= _terminal.lookupVoyage(self.getVoyageCode().trimBlanks, null, false);

	if voyage &lt;&gt; null then
		lVoyageCode := self.getVoyageCode().trimBlanks;
	endif;

	operator := app.myRoot.allOperators[self.operatorCode];
	
	if operator &lt;&gt; null then
		lOperatorCode := self.operatorCode.trimBlanks;
	endif;
	
	if lVoyageCode = null and lOperatorCode &lt;&gt; null then //cnwrs1
		//br := _terminal.allBookingRefsByOperatorRef[lOperatorCode, self.getId(misVersionBookingRef), null];
		br := _terminal.getBookingReference (lOperatorCode, self.getId(misVersionBookingRef), null);	// par 29326
	else
		if lOperatorCode = null then
			iterator := _terminal.allBookingRefsByRef.createIterator;
			
			_terminal.allBookingRefsByRef.startKeyGeq(self.getId(misVersionBookingRef).trimBlanks, iterator);
			
			while iterator.next(brTemp) do
				if brTemp.bookingReference &lt;&gt; self.id.trimBlanks then
					break;
				endif;
				
				if brTemp.bookingReference = self.id.trimBlanks and brTemp.myOperator = null and brTemp.voyageCode = lVoyageCode then
					br := brTemp;
					return br;
				endif;
			endwhile;
		endif;
		
		if voyage &lt;&gt; null then
			//br := voyage.allBookingRefs[lOperatorCode, self.getId(misVersionBookingRef).trimBlanks];
			br := _terminal.getBookingReference (lOperatorCode, self.getId(misVersionBookingRef), voyage);	// par 29326
		endif;
	endif;
	
	return br;
epilog
	delete iterator;
end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <ReturnType type="CM_BookingRef"/>
    </JadeMethod>
    <JadeMethod name="getCarbonDioxide" id="f736c1f5-f41e-4ea3-8d50-c5af902ee3ff">
        <source>getCarbonDioxide():Decimal;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 April 2020	jlgndl1	Initial creation	TFS 47958

*/

vars

begin

	//All Carbon Dioxide display fields are limited to Decimal 6,2  so don't returm bigger than that
	if self.carbonDioxide &gt; 999.99 then
		return 999.99;
	endif;

	return self.carbonDioxide;

epilog

end;</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="0d5b2408-7d22-4ca8-93d0-f0fdc05634e2">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
//----------------------------------------------------------------
//	Created:	12 September 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
//05 Apr 2012	cnwrs1		Par 29391 - EDI RORO Stowage Advice hazard codes
//23 Apr 2012	cnwdap1		PAR #29475 CCMS PNL 2155 add container types and numebrs of containers
//23/04/2014	cnwdap1		PAR #33005 CCMS SFW 1381 Imperial measurements for EDI user defined layouts
//21 Nov 2022	navma1		ChangeRequest 55424: MTN - Improve the performance of Edi file loading
vars
	str,
	strReturn	: String;
	rowName, type	: String;												// PAR #33005
begin
	if _attrName = ETRow_Temperature then
		if self.temperature = NULL_TEMPERATURE then
			return null;
		endif;
	elseif _attrName = ETRow_CarbonDioxide then
		if self.getCarbonDioxide = NULL_CARBON_DIOXIDE then
			return null;
		endif;
	elseif _attrName = ETRow_Humidity then
		if self.getHumidity = NULL_HUMIDITY then
			return null;
		endif;
	elseif _attrName = ETRow_Oxygen then
		if self.getOxygen = NULL_OXYGEN then
			return null;
		endif;
	elseif _attrName = ETRow_Vent then
		if self.vent = NULL_VENTILATION then
			return null;
		endif;
	//elseif _attrName = ETRow_Weight then					//-cnwml2 MSL CCMS 1017
	elseif _attrName = ETRow_TotalWeight then				//+cnwml2 MSL CCMS 1017
	    if self.weight = NULL_WEIGHT then
			return null;
		endif;
		return self.weight.asStringWeightJMT(); 			//cnwrd1 par  19701 18.5.09
	elseif _attrName = ETRow_Height then					//cnwrd1 par  19701 18.5.09
		return self.height.asStringMeasurementJMT();		
	elseif _attrName = ETRow_Width then
		return self.width.asStringMeasurementJMT();		
	elseif _attrName = ETRow_Length then
		return self.length.asStringMeasurementJMT();						
	elseif _attrName = ETRow_BookingRemarks then
		return self.bookingRemarks;
	elseif _attrName = ETRow_Number then
		return self.number.String;
	elseif _attrName = ETRow_Density then						// MES1008 JMH 28/9/09
		return self.density.String;
	elseif _attrName = ETRow_MarkNumber then					// MES1008 JMH 28/9/09
		return self.markNumber.String;
	elseif _attrName = ETRow_GeneratorType then					// MES1008 JMH 28/9/09
		return self.generatorType.String;
	elseif _attrName = ETRow_VentilationUnits then				// MES1008 JMH 28/9/09
		return self.ventilationUnits.String;
	elseif _attrName = ETRow_IsoTypeGroup then					// MES1008 JMH 28/9/09
		return self.isoTypeGroup.String;
	elseif _attrName = ETRow_ProductVolume then					// MES1008 JMH 28/9/09
		return self.productVolume.String;
	elseif _attrName = ETRow_ProductWeight then					// MES1008 JMH 28/9/09
		return self.productWeight.String;
	
	// PAR #29475 CMS PNL 2155
	elseif _attrName = ETRow_ContainerType1 then
		if self.containerTypes.size &gt;= 1 then	// 25/09/2014 cnwar2 #34907
			return self.containerTypes[1];
		else
			return null;
		endif;
	elseif _attrName = ETRow_ContainerType2 then
		if self.containerTypes.size &gt;= 2 then	// 25/09/2014 cnwar2 #34907
			return self.containerTypes[2];
		else
			return null;
		endif;
	elseif _attrName = ETRow_ContainerNbr1 then
		if self.containerNbrs.size &gt;= 1 then	// 25/09/2014 cnwar2 #34907
			return self.containerNbrs[1].String;
		else
			return null;
		endif;
	elseif _attrName = ETRow_ContainerNbr2 then
		if self.containerNbrs.size &gt;= 2 then	// 25/09/2014 cnwar2 #34907
			return self.containerNbrs[2].String;
		else
			return null;
		endif;
	elseif _attrName = ETRow_ImCodes or _attrName = ETRow_Hazards or _attrName = ETRow_Hazardous then  //21.11.2022 navma1 #55424
		return self.getHazardsAsString();
	elseif _attrName.isMeasurementType then									// PAR #33005
		_attrName.getRowNameMeasureType(rowName, type);						// PAR #33005
		return self.getMeasurementStringForAttrib(rowName, type, _short);	// PAR #33005
		
	endif;
	
	return inheritMethod(_attrName, _short);

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getHazardsAsString" id="d89ef332-3fe6-49c5-8a6c-a3a549f53269">
        <source>getHazardsAsString(): String;
//
//02 Feb 2012	cnwrs1	Par 29076 Fix up Hazard Processing in EDI
//
vars
	tmpHazards : ObjectArray;
	hazards : CM_HazardByCodeDict;
	haz : CM_Hazard;
	str : String;
begin
	create tmpHazards transient;
	create hazards transient;
	if self.imCodes.isEmpty then
		return null;
	endif;
	self.getProxyHazards(self.imCodes, tmpHazards, false);
	tmpHazards.copy(hazards);
	if hazards.isEmpty then
		return null;
	endif;
	foreach haz in hazards do
		str := str &amp; haz.getTableDisplay(false, true) &amp; ", ";
	endforeach;
	str := str[1:str.length - 2];
	return str;
epilog
	tmpHazards.purge();
	delete tmpHazards;
	delete hazards;
end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getHumidity" id="46c0917b-8aad-448a-9e54-1c18474dbfec">
        <source>getHumidity():Decimal;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 April 2020	jlgndl1	Initial creation	TFS 47958

*/

vars

begin

	//All Humidity display fields are limited to Decimal 6,2  so don't returm bigger than that
	if self.humidity &gt; 999.99 then
		return 999.99;
	endif;

	return self.humidity;

epilog

end;</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="getId" id="b71f32cb-11a3-4f90-821c-f11a31d0d461">
        <source>getId(_misVersioned : Boolean) : String;
//
// cnwrs1 CCMS1855 Sept 2009 need to change id if MIS versioned
//
vars
	pos : Integer;
	newID : String;
begin
	if _misVersioned and 
	   self.operatorCode = "MIS" then
		pos := self.id.pos('-', 1);
		if pos = 0 then
			newID := self.id;
		else
			newID := self.id[1:pos-1];
		endif;
	else
		newID := self.id;
	endif;
//	write class.name&amp;'::'&amp;method.name&amp;' '&amp;newID;
	return newID;
end;
</source>
        <Parameter name="_misVersioned" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getMeasurementStringForAttrib" id="694ef275-ee41-4152-bfe5-ab6e12f9a6c6">
        <source>getMeasurementStringForAttrib(_attrName: String; _measureType: String; _short: Boolean): String;
//
// Purpose:			
//
// Parameters:			
