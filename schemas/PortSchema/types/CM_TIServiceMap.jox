    <JadeMethod name="getProductGroupMap" id="bad20736-9e16-4b7e-9e34-23a8d82942eb">
        <source>getProductGroupMap(_ti : CM_TrackedItem) : CM_ProductGroupMap;
// ---------------------------------------------------------------------------
// Created:		09 February 2006  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
//Date			Who		Reason;
//23 Oct 2024 	navlw1	JIRA-33107: Invoice Logging Use Levels
//
vars
	prdGrp : CM_ProductGroup;
	prdGrpMap : CM_ProductGroupMap;
begin
	if _ti.myProduct = null then
		app.invLog("Sub Cargo Type Group map for DEFAULT, cargo has no product", LogTRACE.String);// TFS 37994
		return self.allProductGroupMaps[null]; // DEFAULT?
	endif;
			
	prdGrp := _ti.myProduct.myProductGroup;
	if prdGrp = null then
		app.invLog("Sub Cargo Type map for DEFAULT, cargo has no product group", LogTRACE.String);// TFS 37994
		return self.allProductGroupMaps[null]; // DEFAULT?
	endif;
	
	prdGrpMap := self.allProductGroupMaps[prdGrp.code];
	if prdGrpMap &lt;&gt; null then
		app.invLog("Sub Cargo Type map found for " &amp; prdGrp.code, LogTRACE.String);// TFS 37994
	endif;
	if prdGrpMap = null then
		app.invLog("Sub Cargo Type map for DEFAULT", LogTRACE.String);// TFS 37994
		return self.allProductGroupMaps[null]; // DEFAULT?
	endif;
	return prdGrpMap;
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="CM_ProductGroupMap"/>
    </JadeMethod>
    <JadeMethod name="getTIClassName" id="bb3b54b4-71d9-4c48-a931-fb9953aeed32">
        <source>getTIClassName(): String;
// ---------------------------------------------------------------------------
// Created:		November 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars

begin
	if self.myCargoType &lt;&gt; null then
		return self.myCargoType.description;
	elseif self.className &lt;&gt; null then 
		return self.className[4:end];
	else
		return "Default (Cargo Type)";
	endif;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
