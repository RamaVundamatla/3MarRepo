    <JadeMethod name="addDays" id="72ea53b9-358e-4649-a712-ec5ac4270fd9">
        <updating/>
        <source>addDays(pDays:Integer) updating;
// --------------------------------------------------------------------------------
// Created:		24 May 2001 by cnwdad1
//
// Purpose:		Add the specified number of days to the receiver's timestamp.
//
// Parameters:	pDays - A +ve or -ve number of days.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.timestampClient	:=	self.timestampClient.cnEcAddDays(pDays);
end;</source>
        <Parameter name="pDays" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="addHours" id="e4652f05-9669-4c66-a60d-a3a0f02e1288">
        <updating/>
        <source>addHours(pHours:Integer) updating;
// --------------------------------------------------------------------------------
// Created:		24 May 2001 by cnwdad1
//
// Purpose:		Add the specified number of days to the receiver's timestamp.
//
// Parameters:	pHours - A +ve or -ve number of hours.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.timestampClient	:=	self.timestampClient.cnEcAddHours(pHours);
end;</source>
        <Parameter name="pHours" type="Integer"/>
    </JadeMethod>
