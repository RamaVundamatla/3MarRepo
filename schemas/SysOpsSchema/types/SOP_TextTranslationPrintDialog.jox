    <JadeMethod name="cmbLocale_displayRow" id="ef894940-5f2e-4373-bc25-0d150d4b7c8d">
        <controlMethod name="ComboBox::displayRow"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbLocale_displayRow(
			combobox: ComboBox input; 
			obj: Object; 
			lstIndex: Integer; 
			bcontinue: Boolean io):String updating;

vars

begin
	return obj.CM_Locale.vLocaleIdAndDescription;
end;
</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
