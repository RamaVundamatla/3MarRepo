    <JadeMethod name="addListBoxItemsSTW" id="be94235b-06b7-42d7-b3be-38c88c5eda3e">
        <source>addListBoxItemsSTW(	_jobIndex : Integer;
					_level : Integer;
					_dynaDict : DynaDictionary;
					_critArray : IntegerArray;
					_allKeysArrays : ObjectArray;
					_expandedObjects : ObjectSet input
					);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 December 2016	cnwndl1	Initial creation	TFS 3123

*/

vars

	listbox : CMUI_ListBox;
	jobIndex : Integer;
	critInt : Integer;
	obj : Object;
	wle : CM_WorkListEntry;
	keysArray : StringArray;
	keysSize : Integer;
	prevKeysArray : StringArray;
	keyInt : Integer;
	str : String;
	lastStr : String;
	noMatch : Boolean;
	newLevel : Integer;
	criteriaType : CM_YACriteriaType;
	critTypeName : String;
	critTypeNames : StringArray;
	wleOidStr : String;
	strArrayObj : Object;
	foundIt: Boolean;

begin

	listbox := self.lstJobs;
	jobIndex := _jobIndex;
	
	// An ordered collection of criteria names
	create critTypeNames transient;
	critTypeNames.add( "WLE oid" ); // to keep the size in sync with the keys dict size...
	foreach critInt in _critArray do
		criteriaType := app.myRoot.allYACriteriaTypes[ critInt ];
		if criteriaType &lt;&gt; null then
			critTypeName := criteriaType.description;
		else
			critTypeName := null;
		endif;
		critTypeNames.add( critTypeName );
	endforeach;
	
	foreach obj in _dynaDict do
		prevKeysArray := keysArray;  // the keys of the previous item processed. (first time will be null)
	
		//find the set of key values for the wle we are processing
		foundIt := false;
		wleOidStr := obj.CM_WorkListEntry.getOidAsString;
		foreach strArrayObj in _allKeysArrays do
			if strArrayObj.StringArray.first = wleOidStr then
				keysArray := strArrayObj.StringArray;
				foundIt := true;
				break;
			endif;
		endforeach;
		if not foundIt then
			continue;
		endif;
		keysSize := keysArray.size;  
		
		if prevKeysArray = null then
			//create a dummy index line for each key value
			//first time thru will be one for every key.
			foreach keyInt in 2 to keysSize do	//(the first value is teh oid of the wle.)
				str := keysArray[keyInt];
				if str = null then
					str := "null";
				endif;
				str := critTypeNames[keyInt] &amp; "-" &amp; str;
				jobIndex := jobIndex + 1;
				listbox.addItemAt(str, jobIndex);
				newLevel := _level + keyInt - 2;
				listbox.itemLevel[jobIndex] := newLevel;	
			endforeach;
			
		else
			//create a dummy index line for each key value after the first key change
			// from the previous set of data
			noMatch := false;
			foreach keyInt in 2 to keysSize do	//(the first value is teh oid of the wle.)
				str  := keysArray[keyInt];
				lastStr := prevKeysArray[keyInt];
				if (lastStr &lt;&gt; str ) then
					noMatch := true;
				endif;
				if str = null then
					str := "null";
				endif;
				if noMatch then
					str := critTypeNames[keyInt] &amp; "-" &amp; str;
					jobIndex := jobIndex + 1;
					listbox.addItemAt(str, jobIndex);
					newLevel := _level + keyInt - 2;
					listbox.itemLevel[jobIndex] := newLevel;
				endif;
			endforeach;
			
		endif;
		
		// now write the real data
		wle := obj.CM_WorkListEntry;
		str  := wle.getTreeDescription_Full;
		jobIndex := jobIndex + 1;
		
		listbox.addItemAt(str, jobIndex);
		listbox.itemObject[jobIndex] := wle;
		newLevel := _level + keysSize - 1;
		listbox.itemLevel[jobIndex] := newLevel;	
		
		if wle.status = WLE_COMPLETED then
			listbox.itemPicture[jobIndex] := self.picJobComp.picture;
		elseif wle.status = WLE_PART_COMPLETE then
			listbox.itemPicture[jobIndex] := self.picJobPartComp.picture;		
		else //Unactioned
			listbox.itemPicture[jobIndex] := self.picJobWLEs.picture;
		endif;
		
		if _expandedObjects &lt;&gt; null and _expandedObjects.includes( wle ) then
			if not listbox.itemVisible(jobIndex) then
				listbox.expandParentsUntilVisible( jobIndex );
			endif;
		endif;

	endforeach;

epilog

	delete critTypeNames;

end;</source>
        <Parameter name="_jobIndex" type="Integer"/>
        <Parameter name="_level" type="Integer"/>
        <Parameter name="_dynaDict" type="DynaDictionary"/>
        <Parameter name="_critArray" type="IntegerArray"/>
        <Parameter name="_allKeysArrays" type="ObjectArray"/>
        <Parameter name="_expandedObjects" type="ObjectSet" usage="input"/>
    </JadeMethod>
