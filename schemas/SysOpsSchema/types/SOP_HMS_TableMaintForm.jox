end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doControlEvent" id="8017b7cb-8909-407f-8a68-9450dde42caa">
        <updating/>
        <source>doControlEvent(_control: Control) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 June 2008	cnwer1	Initial creation par 16928 if the selected berths for the region has changed need to update the combo

*/

vars
	preferredBerth : HMS_Berth;
	allBerths 	: HMS_BerthArray;
begin
	
	if self.myCurrentTableItem.isKindOf(SOPTM_HMS_HarbourRegion) then
		if  _control = self.mulSelect1.myAddSelectedBtn or  _control = self.mulSelect1.myRemoveSelectedBtn  then
			preferredBerth := self.cmbPrefBerth.listObject.HMS_Berth;
			create allBerths transient;
			self.mulSelect1.getSelected(allBerths);
			self.myAssistant.comboBoxHMSBerthsForColl(self.cmbPrefBerth,allBerths,preferredBerth);
		
		endif;
	endif;
	inheritMethod(_control);

epilog
	if allBerths &lt;&gt; null then
		delete allBerths;
	endif;
end;</source>
        <Parameter name="_control" type="Control"/>
    </JadeMethod>
    <JadeMethod name="doCurrentTableChange" id="1c34ba0b-d532-4dd6-8153-c457070ae751">
        <updating/>
        <source>doCurrentTableChange(_showData: Boolean) updating;
//--------------------------------------------------------------
//Created: 09 July 2003 By: cnwgd1
//--------------------------------------------------------------
/*

Date		Who		Reason
28 Mar 2008	cnwkpd1	PAR #16261 - Hide Harbour filter combo for Route Template table

*/

begin
	if self.myCurrentTableItem = null then
		return;
	endif;
	
	inheritMethod(_showData);

	if self.myCurrentTableItem.isKindOf(SOPTM_HMS_Harbour)
	or self.myCurrentTableItem.isKindOf(SOPTM_HMS_Delay)
	or self.myCurrentTableItem.isKindOf(SOPTM_HMS_Tug)
	or self.myCurrentTableItem.isKindOf(SOPTM_HMS_Pilot)
	or self.myCurrentTableItem.isKindOf(SOPTM_HMS_PilotLaunch)
	or self.myCurrentTableItem.isKindOf(SOPTM_HMS_ResourceType)
//	or self.myCurrentTableItem.isKindOf(SOPTM_HMS_LineCompany)
	or self.myCurrentTableItem.isKindOf(SOPTM_HMS_VesselCategory)
	or self.myCurrentTableItem.isKindOf(SOPTM_HMS_VesselType)
	or self.myCurrentTableItem.isKindOf(SOPTM_HMS_VesselUnavailCode)
	or self.myCurrentTableItem.isKindOf(SOPTM_HMS_VisitType)
//	or self.myCurrentTableItem.isKindOf(SOPTM_HMS_WharfLockout)
	or self.myCurrentTableItem.isKindOf(SOPTM_HMS_TidalClass)
	or self.myCurrentTableItem.isKindOf(SOPTM_HMS_HarbourRegion)
	or self.myCurrentTableItem.isKindOf(SOPTM_HMS_CheckPoint)
	or self.myCurrentTableItem.isKindOf(SOPTM_HMS_PathSegment)
	or self.myCurrentTableItem.isKindOf(SOPTM_HMS_MovementPath)
	or self.myCurrentTableItem.isKindOf(SOPTM_HMS_RouteTemplate)			// PAR #16261
	then
		self.cmbFiltHarbour.visible	:=	false;
		self.lblHarbour.visible		:=	false;			
	else
		self.lblHarbour.visible		:=	true;
		self.cmbFiltHarbour.visible	:=	true;
//		self.cmbFiltHarbour.left	:=	self.cmbFiltHarbour.left +10;
//		self.lblHarbour.visible		:=	true;	
	endif;
end;</source>
        <Parameter name="_showData" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doDefaultPathSegmenDescription" id="f18dfb20-6386-45fe-88b2-989a4e2ba6cc">
        <source>doDefaultPathSegmenDescription();

// if Path Segment description not already set, then set default based on region names

vars
	regionTo 	: HMS_HarbourRegion;
	regionFrom 	: HMS_HarbourRegion;
	description	: String;
begin
	description := tblInput1.getValueByName(ETRow_Description).String.trimBlanks;

	if description &lt;&gt; null then
		return;
	endif;
	
	
	regionTo 	:= cmbRegionTo.listObject.HMS_HarbourRegion;
	regionFrom	:= cmbRegionFrom.listObject.HMS_HarbourRegion;

	if regionTo = null or regionFrom = null then
		return;
	endif;

	description := regionFrom.code &amp; '-' &amp; regionTo.code[1:HMS_PathSegment::description.length - 1];
	tblInput1.setValueByName(ETRow_Description, description);

end;
</source>
    </JadeMethod>
    <JadeMethod name="doDelete" id="d497cf8f-424f-45f9-a43f-38590e97fe79">
        <updating/>
        <source>doDelete(): Boolean updating;
//--------------------------------------------------------------
//Created: 10 July 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	result : Boolean;
begin

	result := inheritMethod();
	
	if result then
		if app.myRoot.allHarbours.isEmpty then
			self.initForm();
		endif;
	endif;
	
	return result;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doResize" id="2c3120b0-b3bd-44be-8ab4-ceb9d7d37024">
        <updating/>
        <source>doResize()updating;
//--------------------------------------------------------------
//Created: 09 July 2003 By: cnwgd1
//--------------------------------------------------------------
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 30/07/2021	navmd1		TFS 51320 - Add filter to Sys/Terminal Admin tables
// ---------------------------------------------------------------------------
vars

begin
	inheritMethod();
//	self.lblHarbour.move(cmbTable.left + cmbTable.width + VerticalSpacing, cmbTable.top, lblHarbour.width, lblHarbour.height);
//	self.cmbFiltHarbour.move(lblHarbour.left + lblHarbour.width + VerticalSpacing, lblTable.top, cmbFiltHarbour.width, cmbFiltHarbour.height);

	self.lblHarbour.top			:=	self.cmbTable.top;
	//self.lblHarbour.left		:=	self.cmbTable.left + cmbTable.width + self.HorizontalSpacing + self.HorizontalSpacing + self.HorizontalSpacing + self.HorizontalSpacing;
	//self.cmbFiltHarbour.top		:=	self.cmbTable.top;
	//self.lblHarbour.left		:=	self.txtFilterBox.left + txtFilterBox.width + (self.HorizontalSpacing * 4);//25/06/2024	navkc1 CR 64823 Task 64824
	self.lblHarbour.left		:=	self.cmbTable.left + cmbTable.width + (self.HorizontalSpacing * 4);
	//self.cmbFiltHarbour.top		:=	self.txtFilterBox.top;
	self.cmbFiltHarbour.top		:=	self.cmbTable.top;
	self.cmbFiltHarbour.left	:=	self.lblHarbour.left + lblHarbour.width + self.HorizontalSpacing + 3;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doResourceTypeActionFromDT" id="772d3475-5ea7-4c8b-aa06-2731f11c3738">
        <source>doResourceTypeActionFromDT(_table: CM_EntryTable input);
//--------------------------------------------------
// Created:	20 December 2004 By: cnwgd1
//--------------------------------------------------
vars
	typeStr : String;
	rowActionDT,	
	rowFromDT	: Integer;
begin
    if self.mode = self.Mode_View then
    	return;
    endif;  

	rowFromDT := _table.getRow(ETRow_IsFromToDateTimeRequired);	
	rowActionDT := _table.getRow(ETRow_IsActionDateTimeRequired);
	
	if _table.row = rowFromDT then 
		_table.setValueByName(ETRow_IsActionDateTimeRequired, false);
	elseif _table.row = rowActionDT then
		_table.setValueByName(ETRow_IsFromToDateTimeRequired, false);
	endif;

end;</source>
        <Parameter name="_table" type="CM_EntryTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doSave" id="4bd5c905-1865-4150-86a3-5ea375799740">
        <updating/>
        <source>doSave(): Boolean updating;
//--------------------------------------------------------------
//Created: 10 July 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	refresh,
	rtnValue : Boolean;
begin
	
	if app.myRoot.allHarbours.isEmpty and
		self.myCurrentTableItem.isKindOf(SOPTM_HMS_Harbour) then
		refresh := true;
	endif;
	
	rtnValue := inheritMethod();

	if rtnValue and refresh then
		self.setHarbourCombos();
		self.setAllTblItems(Mode_Harbour);	
	 	//self.myCurrentTableItem := self.getTableItemForClass(HMS_Harbour);
	 	self.setCurrentTableItem(self.getTableItemForClass(HMS_Harbour));
	 	self.amInitialisingWithObject := true;
		self.initComboTable();
		self.doCurrentTableChange(true);
	 	self.amInitialisingWithObject := false;	
	 	// these need to check permissions 
		//self.allowAdd := true;
		//self.allowDelete := true;	 		
	endif;

	return rtnValue;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doTblInput1Change" id="d77085ce-b007-4e3e-b58b-8cfbc4d770f8">
        <updating/>
        <source>doTblInput1Change(_table: CM_EntryTable input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		    Who		Reason
14 April 2023	navmp20	Bug 57583: CAL - Master Field from the HSM error when creating a new entry.

*/

vars
	textbox : TextBox;
begin
	inheritMethod(_table);
	if _table.row = _table.fixedRows + 1 and self.myCurrentTableItem.isKindOf(SOPTM_HMS_Master) and self.mode.isOneOf(self.Mode_Add, self.Mode_Update) then
		if _table.accessCell(_table.row, _table.column).text.length &gt; 6 then
			textbox := _table.accessedCell.cellControl.TextBox;
			textbox.text := _table.accessedCell.text[1:6];
			textbox.selStart := textbox.text.length;
			global.beep;
		endif;
	endif;

epilog

end;</source>
        <Parameter name="_table" type="CM_EntryTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doTblInput1Click" id="36d56b0c-da29-4a04-91f7-0ceaf3c2f89a">
        <updating/>
        <source>doTblInput1Click(table: Table input) updating;
//--------------------------------------------------
// Created:	17 February 2005 By: cnwgd1
//--------------------------------------------------
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 14/11/2012	cnwdap1		PAR #30741 CCMS 2232 Display Resoruce Codes on Harbour View
vars
	rowInTable	: Integer;			// PAR #30741

begin
	if table.row &lt;= table.fixedRows then
		return;
	endif;
    if self.mode = self.Mode_View then
    	return;
    endif;  

	if self.myDataClass = HMS_CheckPoint then
		//self.doCheckPointRVTideLocation(self.tblInput1);
	elseif self.myDataClass = HMS_ResourceType then
		self.doResourceTypeActionFromDT(self.tblInput1);
		
		// PAR #30741 if "Icon Visible On View" option is unticked, untick and disable "Display Code On view" option
		if self.myDataClass = HMS_ResourceType then
			rowInTable := table.CM_EntryTable.getRow(ETRow_IconVisibleOnView);
			if table.row = rowInTable and rowInTable &gt; 0 then
				if (tblInput1.getValueByName(ETRow_IconVisibleOnView).Boolean = true) then
					tblInput1.enableRowByName(ETRow_DisplayCodeOnView);
				else
					tblInput1.disableRowByName(ETRow_DisplayCodeOnView);
					tblInput1.setValueByName(ETRow_DisplayCodeOnView, false);
				endif;
			endif;
		endif;
		// PAR #30741 end
	else
		inheritMethod(table);
	endif;

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
