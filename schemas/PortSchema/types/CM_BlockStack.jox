    <JadeMethod name="initializeForActivity" id="52ef1b23-83ff-4223-9f38-00ea4d0080cf">
        <updating/>
        <source>initializeForActivity(_ewsOpsView: CM_EWSActivityOpsview; _opsViewTable : CMIF_OpsViewTables) updating;
/*
Purpose:			

Date		Who		Reason
12 APRIL 2022	navab1	TFS 53369
*/

vars
	opsviewtable : CMIF_SpatialBins;

begin
	opsviewtable := _opsViewTable.CMIF_SpatialBins;
	
	opsviewtable.gkey := opsviewtable.generateFullGKey(self, "");
	
	opsviewtable.bin_level := opsviewtable.SpatialBinLevel_2;
	opsviewtable.bin_subclass := "SBL";
	opsviewtable.block_type_enum := opsviewtable.n4BlockType(self);
	opsviewtable.internal_pos_name := self.id;
	opsviewtable.label_scheme_full_position := self.id; 
	opsviewtable.life_cycle_state := opsviewtable.n4LifeCycleState(self); 
	opsviewtable.heap_classification := opsviewtable.getHeapTypeClassification(self);	//navra1 - TFS 54034 - MTN - Opsview Container Yard - Block Stacks - 4th Nov 2022	
	opsviewtable.parent_bin_gkey := opsviewtable.generateFullGKey(self.myTerminal,"");
	opsviewtable.yard_gkey := 0;  // ### TFS 53369 28APR2022 NAVAB1 only for the terminal - bin_level 1 //  opsviewtable.generateFullGKey(self.myTerminal, ""); 
	opsviewtable.z_index_last := 0; // not set at this level

epilog

end;</source>
        <Parameter name="_ewsOpsView" type="CM_EWSActivityOpsview"/>
        <Parameter name="_opsViewTable" type="CMIF_OpsViewTables"/>
    </JadeMethod>
    <JadeMethod name="initializeForActivityCOL" id="96713d24-e4cb-4e00-97a9-12e662a9d829">
        <updating/>
        <source>initializeForActivityCOL(_ewsOpsView: CM_EWSActivityOpsview; _opsViewTable : CMIF_OpsViewTables;_gKey:String) updating;
/*
Purpose:	N4 SECTION		

Date		Who		Reason
27 MAY 2022	navsp1	TFS#53700
*/

vars
	opsviewtable : CMIF_SpatialBins;
	gKey	: String;
begin
	opsviewtable := _opsViewTable.CMIF_SpatialBins;	
	opsviewtable.gkey := opsviewtable.generateFullGKey(self, "COL");		
	opsviewtable.bin_level := opsviewtable.SpatialBinLevel_3; 
	opsviewtable.bin_subclass := "YSN";
	opsviewtable.block_type_enum := ""; 
	opsviewtable.internal_pos_name := self.id; 
	opsviewtable.label_scheme_full_position := self.id;
	opsviewtable.life_cycle_state := opsviewtable.n4LifeCycleState(self); 	
	opsviewtable.heap_classification := opsviewtable.getHeapTypeClassification(self);	//navra1 - TFS 54034 - MTN - Opsview Container Yard - Block Stacks - 4th Nov 2022	

	if _gKey &lt;&gt; null then
		opsviewtable.parent_bin_gkey := _gKey.Integer64;
	else
		opsviewtable.parent_bin_gkey :=opsviewtable.generateFullGKey(self.myTerminal,"");
	endif;
	opsviewtable.yard_gkey := 0;  
	opsviewtable.z_index_last := 0;
epilog

end;</source>
        <Parameter name="_ewsOpsView" type="CM_EWSActivityOpsview"/>
        <Parameter name="_opsViewTable" type="CMIF_OpsViewTables"/>
        <Parameter name="_gKey" type="String"/>
    </JadeMethod>
