    <JadeMethod name="getIndexForXmlStrTblDataArray" id="902fe6eb-2624-41cf-a648-121a9c6f7c9d">
        <source>getIndexForXmlStrTblDataArray(): Integer;
// ---------------------------------------------------------------------------
// Created:		May 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// Changed on	By			Reason
// ----------	--------	--------------------------------------------------
// 11/08/2011	cnwdap1		PAR #27972 Bulk release type no longer translatable, replaced with string constants
// 23/11/2011	cnwcs5		CCMS POL 2122 / PAR 28696 - NEW TYEP uNKNOWN
vars

begin
	if self.typeMode = BR_TYPE_ROAD_STR then									// PAR #27972
		return BR_TYPE_ROAD;
	
	elseif self.typeMode = BR_TYPE_RAIL_STR then								// PAR #27972
		return BR_TYPE_RAIL;
	
	elseif self.typeMode = BR_TYPE_PACKING_STR then								// PAR #27972
		return BR_TYPE_PACKING;
	
	elseif self.typeMode = BR_TYPE_SHIP_STR then								// PAR #27972
		return BR_TYPE_SHIP;
		
	elseif self.typeMode = BR_TYPE_UNKNOWN_STR then	// par 28696
		return BR_TYPE_UNKNOWN;						// par 28696
		
	else
		return BR_TYPE_BOL; // ALL
	endif;

	return inheritMethod();

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getReleasesToPrint" id="cc049e38-dc23-4521-92cb-4e2f6323c5cb">
        <source>getReleasesToPrint(_releases : CM_BulkReleaseSet input);
/*
----------   ----------  --------------------------------------------------
Created:	31 January 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	
	row,
	numRows					: Integer;
	obj						: Object;
	bulkRelease				: CM_BulkRelease;
	tbl						: CM_DataTable;
begin

	if self.tblData.rows &lt;= self.tblData.fixedRows then
		return;
	endif;
	
	tbl := self.tblData;
	numRows := tbl.rows;
	if self.chkSelectedOnly.value then
		foreach obj in tbl.allSelectedObjects where CM_BulkRelease.hasInstance(obj) do
			if _releases.includes(obj.CM_BulkRelease) then
				continue;
			endif;
			
			_releases.add(obj.CM_BulkRelease);
		endforeach;
	else
		foreach row in tbl.fixedRows + 1 to numRows do
			bulkRelease := tbl.accessRow(row).itemObject.CM_BulkRelease;
			if bulkRelease = null or _releases.includes(bulkRelease) then
				continue;
			endif;
			
			_releases.add(tbl.accessedRow.itemObject.CM_BulkRelease);
		endforeach;
	endif;


end;

</source>
        <Parameter name="_releases" type="CM_BulkReleaseSet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getReserveDetails" id="26b07bec-e319-459c-85c3-2d6c35623475">
        <source>getReserveDetails(_reserveDetails : CM_ReserveDetailSet input);
/*
----------   ----------  --------------------------------------------------
Created:	4 March 2008 By cnwar2

Purpose:	Fills a collection with CM_ReserveSelection objects (not CM_ReserveTI)
			i.e. reserves by ISO type

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	row,
	numRows		: Integer;
	obj			: Object;
	bulkRelease	: CM_BulkRelease;
	res			: CM_ReserveDetail;
	tbl			: CM_DataTable;
	
begin
	if self.tblData.rows &lt;= self.tblData.fixedRows then
		return;
	endif;
	
	tbl := self.tblData;
	numRows := tbl.rows;
	if self.chkSelectedOnly.value then
		foreach obj in tbl.allSelectedObjects where CM_BulkRelease.hasInstance(obj) do
			foreach res in obj.CM_BulkRelease.allReserveDetails do
				if not _reserveDetails.includes(res) then
					_reserveDetails.add(res);
				endif;				
			endforeach;
		endforeach;
	else
		foreach row in tbl.fixedRows + 1 to numRows do
			bulkRelease := tbl.accessRow(row).itemObject.CM_BulkRelease;
			if bulkRelease = null then
				continue;
			endif;
			
			foreach res in bulkRelease.allReserveDetails do
				if not _reserveDetails.includes(res) and
				   not CM_ReserveTI.hasInstance(res) then
					_reserveDetails.add(res);
				endif;
			endforeach;
		endforeach;
	endif;
end;</source>
        <Parameter name="_reserveDetails" type="CM_ReserveDetailSet" usage="input"/>
    </JadeMethod>
