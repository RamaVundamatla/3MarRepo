        <source>fldPurge_sheetChg(folder: Folder input) updating;
/*
Date		Who		Reason
27 May 2013	cnwcs5	Initial Creation - par 29777
*/
vars

begin
	if self.fldPurgeSheet2.tag = self.RELOAD_TABLE then
		self.doRefresh;
	endif;
epilog

end;</source>
        <Parameter name="folder" type="Folder" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getXMLSettingsForSave" id="1500aa61-1eb6-4efc-95fa-ab113436477d">
        <updating/>
        <source>getXMLSettingsForSave() : String updating;


vars

	xmlStr,
	tblActivity	: String;
begin
	
	xmlStr := inheritMethod();

	tblActivity	:= self.tblActivity.getXmlStrForColumns(true);
	
	xmlStr		:= xmlStr &amp; tblActivity;

	return xmlStr;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="loadParametersTable" id="05e7a3d6-7d47-4a0e-ac94-a86f8340dd9b">
        <updating/>
        <source>loadParametersTable() updating, protected;
// -------------------------------------------
// Created 06 October 2004 by cnwdvb1
// -------------------------------------------
// 23/05/2012	cnwrs1	Par 29613
// 30/04/2013	cnwcs5	par 29777 - improve performance
//9/11/17 jlgns1 TFS 6960 QNS - Disk space issues and house keeping inside JMT
//20 September 2022 navmv20 ChangeRequest 53403: MTN - Garbage Collection of Release Request
//13 Feb 2023 	navhl20 ChangeRequest 54900:[56518] EUP - Garbage Collection for Document Attachments
//21 Jul 2023 navhl20 ChangeRequest 58158: EUP | [Framework] - Delivery Dispatch Garbage Collection
//11 Aug 2025 navhl20 Story MTN-35650: TPT | Uploading of Photos into MTN Production | 2 | Thin Client Changes
vars
	request			: BGP_DatabasePurgeRequest;
	terminal		: CM_Terminal;
	table			: CM_EntryTable;
	combo			: CMUI_ComboBox;
	gotException	: Boolean;
	oldIndex,
	index 			: Integer;
begin

	on Exception do app.handleDeletedObject (exception, request, gotException);
	
	request 	:= self.myCurrentRequest;
	terminal	:= request.myTerminal;
	
	if gotException then
		return;
	endif;
	
	combo 		:= self.cmbTerminals;
	table		:= self.tblDatabasePurge;
	oldIndex 	:= combo.listIndex;
	index 		:= combo.findObject(terminal);
		
	if index &lt;&gt; -1 then
		combo.listIndex := index;
		table.setValueByName(ETRow_Terminal, combo.text);
	endif;
	
	table.setValueByName(ETRow_Date, request.archiveDate);
	table.setValueByName(ETRow_ArchivedVoyages, request.purgeArchivedVoyages);
	table.setValueByName(ETRow_ArchivedLocations, request.purgeArchivedLocations);
	table.setValueByName(ETRow_ReceivalDockets, request.purgeEmptyBOLIns);
	table.setValueByName(ETRow_OffsiteTrackedItems, request.purgeOffsiteTis);
	table.setValueByName(ETRow_Prenotes, request.purgePrenotedTis);
	table.setValueByName(ETRow_BookingRef, request.purgeBookingRefTis);
	table.setValueByName(ETRow_Discrepancies, request.purgeNonContainerDiscrepancies);
	table.setValueByName(ETRow_NavisSmartActivity, request.purgeNavisSmartActivity); 		// ### TFS 50669 06AUG2021 NAVAB1
	table.setValueByName(ETRow_MachineHistory, request.purgeMachineHistory);
	table.setValueByName(ETRow_CargoPhotos, request.purgeCargoPhotos);						// 01/12/2009 cnwdz2 par21808
	table.setValueByName(ETRow_EventRequest, request.purgeEventRequests);					// 23/05/2012	cnwrs1	Par 29613
	table.setValueByName(ETRow_DdExtractHistory, request.purgeDDExtractHistory);			//25 Jul 2013	NDL Par 31691
	table.setValueByName(ETRow_EdiData, request.purgeDDExtractHistory);						//25 Jul 2013	NDL Par 31691
	table.setValueByName(ETRow_LockTransactions, request.purgeLockTransactions);			//25 Jul 2013	NDL Par 31691
	table.setValueByName(ETRow_LogCheckScaleHdr, request.purgeLockTransactions);			//25 Jul 2013	NDL Par 31691
	table.setValueByName(ETRow_OffsiteTrackedItems, request.purgeLockTransactions);			//25 Jul 2013	NDL Par 31691
	table.setValueByName(ETRow_ReceivalDockets, request.purgeLockTransactions);				//25 Jul 2013	NDL Par 31691
	table.setValueByName(ETRow_Sundry, request.purgeSundry);								//25 Jul 2013	NDL Par 31691
	table.setValueByName(ETRow_MenuUserItems, request.purgeMenuUserItems);					//25 Jul 2013	NDL Par 31691
	table.setValueByName(ETRow_Xlation, request.purgeXlations);								//25 Jul 2013	NDL Par 31691
	table.setValueByName(ETRow_YardAllocationLogs, request.purgeYardAllocationLogTrans);	//25 Jul 2013	NDL Par 31691
	table.setValueByName(ETRow_InterTermRailBOLs, request.purgeInterTerminalRailBOLs);		//28/4/17 epr TFS 4157
	table.setValueByName(ETRow_TruncateEDIInfoXML, request.truncateEDIInfoXML);				//13 Sep 2021	NDL	TFS 51718
	table.setValueByName(ETRow_SecGateUnknTrucks, request.purgeSecGateUnknTrucks);			// ### TFS 51994 29Sep2021 NAVPW1
	table.setValueByName(ETRow_ReleaseRequests, request.purgeReleaseRequests);              //16/09/2022 navmv20 TFS 53403	 
	table.setValueByName(ETRow_AttachFilesCargoTypes, request.purgeAttachmentCargoTypes);   // 13/02/2023 navhl20 #54900[56518]	
	table.setValueByName(ETRow_AttachFilesContracts, request.purgeAttachmentContract);   	// 13/02/2023 navhl20 #54900[56518]	
	table.setValueByName(ETRow_AttachFilesInvoices, request.purgeAttachmentInvoices);   	// 13/02/2023 navhl20 #54900[56518]	
	table.setValueByName(ETRow_AttachFilesVoyages, request.purgeAttachmentVoyages);   		// 13/02/2023 navhl20 #54900[56518]	
	table.setValueByName(ETRow_AttachFilesWorkOrders, request.purgeAttachmentWorkOrders);   // 13/02/2023 navhl20 #54900[56518]	 
	table.setValueByName(ETRow_VisitPhotos, request.purgeVisitPhotos);   					//11.08.2025 navhl20 #35650	
	table.setValueByName(ETRow_AgGatewayMessages, request.purgeAgGatewayMessages);   		//navra1 - MTN-35875- 5th Sep 2025-2
		
	if app.isDutyDocEnabled then
		table.setValueByName(ETRow_DutyDocs, request.purgeDutyDocs);						// 21 Dec 2012	NDL	Par 30901
	else
		table.hideRowByName(ETRow_DutyDocs,false);
	endif;
	if app.isVehicleBookingEnabled then
		table.setValueByName(ETRow_VehicleBookingSlots, request.purgeVehicleBookings);		// 25 Jul 2013	NDL	Par 31691
	else
		table.hideRowByName(ETRow_VehicleBookingSlots,false);
	endif;
	
	if app.isCargoGroupEnabled then	 														//22 Jun 2015	NDL	Par 36338
		table.setValueByName(ETRow_ReleasedCargoGroups, request.purgeReleasedCargoGroups);
	else
		table.hideRowByName(ETRow_ReleasedCargoGroups,false);
	endif;
	
	if app.myPassport.isVASEnabled then	 													//21.7.2023 navhl20 #58158
		table.setValueByName(ETRow_WorkOrderJobSheets, request.purgeWorkOrderJobSheets);
	else
		table.hideRowByName(ETRow_WorkOrderJobSheets,false);
	endif;
	
	//	TFS 6960
	table.setValueByName( ETRow_MaxDurationMinutes,request.maxDurationMinutes);

	if oldIndex &lt;&gt; index then
		combo.click(combo);
	endif;

end;</source>
        <access>protected</access>
    </JadeMethod>
