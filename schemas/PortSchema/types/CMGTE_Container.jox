    <JadeMethod name="actionForCreateInternal" id="a9ec6c5c-f376-4a07-925e-6f029bad479a">
        <updating/>
        <source>actionForCreateInternal(_vvRec : CM_VehicleVisitRecord input; _passport: CM_Passport input; _pxyTI: CM_TrackedItem input): Boolean updating, protected;
/*

Date		Who		Reason
10 July 2014	cnwer1	Initial creation PAR
11/01/2022		navpw1	TFS: 52631 Added Backdating for VVR transactions
*/

vars
	
	result : Boolean;
begin
	result:= inheritMethod(_vvRec, _passport, _pxyTI);
	
	if not result then
		return false;
	endif;
	
	return true;
	
	
epilog

	

end;</source>
        <access>protected</access>
        <Parameter name="_vvRec" type="CM_VehicleVisitRecord" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <Parameter name="_pxyTI" type="CM_TrackedItem" usage="input"/>
        <ReturnType type="Boolean"/>
