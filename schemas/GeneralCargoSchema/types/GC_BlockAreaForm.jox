    <JadeMethod name="getRackYALocationString" id="c4ed35fb-a26b-4fc3-8bed-624a144bd4c4">
        <source>getRackYALocationString() : String;
/*
Purpose:			
Date		Who		Reason
04 September 2013	cnwab1	Initial creation
*/

vars
	idx, x1, y1, z1 : Integer;
	rack : CM_IrregularBlockController;
	obj : Object;
	objs : ObjectSet;
	allRacks : CM_IrregularBlockLCsByRegion;
begin
	create allRacks transient;
	foreach obj in self.myDrawingController.allSelectedObjects discreteLock do
		rack := obj.CM_IrregularBlockController;
		
		rack.getSortKeys(x1, y1, z1);

		allRacks.putAtKey(x1, y1, z1,rack);
	endforeach;
	
	return allRacks.getYALocationString();
	
epilog
	delete allRacks;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getXMLSettingsForExit" id="250750aa-40c2-4fa7-b0b9-123da7b71c15">
        <updating/>
        <source>getXMLSettingsForExit(): String updating;

/*

Purpose:			


Return Value:		


Date		Who		Reason
16 May 2008	cnwkpd1	PAR #16753 - CCMS SFW 1003 - General Cargo Graphical Screens

*/

vars
	xml		: String;
begin
	xml := inheritMethod();
	
	if self.myCurrentTerminalArea &lt;&gt; null then
		xml := xml &amp; global.formatAsXML(XML_TA, self.myCurrentTerminalArea.id);
	endif;
	
	return xml;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getXMLSettingsForSave" id="5a8e425b-b4b8-438e-9e36-046d4d5c150e">
        <updating/>
        <source>getXMLSettingsForSave(): String updating;

/*

Purpose:			


Return Value:		


Date		Who		Reason
16 May 2008	cnwkpd1	PAR #16753 - CCMS SFW 1003 - General Cargo Graphical Screens

*/
// adm 250509 Par 19575
vars
	theXML		: String;
	hideMacro	: Boolean;
	
begin
	theXML := inheritMethod();

	// NOTE if these menus have a caption saying SHOW it means that the item is hidden
	hideMacro :=  (self.mnuGridHideMacro.caption = self.MNU_MACRO_SHOW);
	
	theXML	:=	theXML &amp;
				global.formatAsXML(XML_FH, self.xmlFlipH.Integer.String) &amp;
				global.formatAsXML(XML_FV, self.xmlFlipV.Integer.String) &amp;
				global.formatAsXML(XML_ZS, self.xmlZoomFactor.String) &amp;
				global.formatAsXML(XML_BF, self.mnuGridBigFont.checked.Integer.String) &amp;
				global.formatAsXML(XML_HM, hideMacro.Integer.String) &amp;
				global.formatAsXML(XML_HT, (self.mnuGridHideToolbar.caption = self.MNU_TOOLBAR_SHOW).Integer.String) &amp;
				global.formatAsXML(XML_HL, (self.mnuGridHideLegend.caption = self.MNU_LEGEND_SHOW).Integer.String) &amp;
				global.formatAsXMLPrefix(XMLTag_Splitter &amp; ' name="splMain"') &amp;
				global.formatAsXML(XMLTag_Ratio, self.splMain.leftToRightRatio.String) &amp;
				global.formatAsXMLSuffix(XMLTag_Splitter &amp; ' name="splMain"') &amp;
				global.formatAsXMLPrefix(XMLTag_Splitter &amp; ' name="sptGridArea01"') &amp;
				global.formatAsXML(XMLTag_Ratio, self.sptGridArea01.leftToRightRatio.String) &amp;
				global.formatAsXMLSuffix(XMLTag_Splitter &amp; ' name="sptGridArea01"');
	if self.myCurrentTerminalArea &lt;&gt; null then
				theXML	:=	theXML &amp;
				global.formatAsXML(XML_TA, self.myCurrentTerminalArea.id);
	endif;
	
	return theXML;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getXMLSettingsForSetup" id="d3ce09b6-d656-4ab8-8bd7-774c652b85ac">
        <updating/>
        <source>getXMLSettingsForSetup() updating, protected;

/*

Purpose:			Get the user preferences from the user details for this form


Return Value:		


Date		Who		Reason
16 May 2008	cnwkpd1	PAR #16753 - CCMS SFW 1003 - General Cargo Graphical Screens

*/
// adm 250509 Par 19575
vars
	userWindow		: CM_UserWindow;
	theXML			: String;
	theXMLValue		: String;
	flipH			: Boolean;
	flipV			: Boolean;
	bigFont			: Boolean;
	hideL			: Boolean;
	hideT			: Boolean;
	hideM			: Boolean;
	zoomScale		: Real;
	splitRatioMain,
	splitRatioGridArea01 : Integer;
	theFrame		: CMUI_GridAreaFrame;
	str				: String;
begin
	userWindow := app.getUserWindow(self.name, false);
	
	if userWindow = null then
		return;
	endif;
	
	theXML := userWindow.xmlInfo;
	
	// #### BIG FONT
 	theXMLValue := theXML.cnEcGetTagValueOfName(XML_BF);
 	bigFont := false;
 	
 	if theXMLValue &lt;&gt; null then
 		bigFont := theXMLValue.Integer.Boolean;
 	endif;
 	
 	// #### HIDE LEGEND
 	theXMLValue := theXML.cnEcGetTagValueOfName(XML_HL);
 	hideL := false;
 	
 	if theXMLValue &lt;&gt; null then
 		hideL := theXMLValue.Integer.Boolean;
 	endif;
 	
 	// #### HIDE MACRO
 	theXMLValue := theXML.cnEcGetTagValueOfName(XML_HM);
 	hideM := false;
 	
 	if theXMLValue &lt;&gt; null then
 		hideM := theXMLValue.Integer.Boolean;
 	endif;
 	
 	// #### HIDE TOOLBAR
 	theXMLValue := theXML.cnEcGetTagValueOfName(XML_HT);
 	hideT  := false;
 	
 	if theXMLValue &lt;&gt; null then
 		hideT := theXMLValue.Integer.Boolean;
 	endif;
 	
	// #### FLIP HORIZONTAL
 	theXMLValue := theXML.cnEcGetTagValueOfName(XML_FH);
 	flipH := false;
 	
 	if theXMLValue &lt;&gt; null then
 		flipH := theXMLValue.Integer.Boolean;
 	endif;
 	
 	// #### FLIP VERTICAL
 	theXMLValue := theXML.cnEcGetTagValueOfName(XML_FV);
 	flipV := false;
 	
 	if theXMLValue &lt;&gt; null then
 		flipV := theXMLValue.Integer.Boolean;
 	endif;

	// #### ZOOM SCALE
 	zoomScale := theXML.cnEcGetTagValueOfName(XML_ZS).Real;
 	
 	if zoomScale = null 
	or zoomScale  &lt;= 0 then // PAR 32836
		zoomScale := 1;
	endif;
	
	// #### SPLITTERS RATIO
	str := theXML.cnEcGetTagValueOfName(XMLTag_Splitter &amp; ' name="splMain"');
	if str &lt;&gt; null then
		splitRatioMain	:= str.cnEcGetTagValueOfName(XMLTag_Ratio).Integer;
	endif;
	str := theXML.cnEcGetTagValueOfName(XMLTag_Splitter &amp; ' name="sptGridArea01"');
	if str &lt;&gt; null then
		splitRatioGridArea01	:= str.cnEcGetTagValueOfName(XMLTag_Ratio).Integer;
	endif;
		
 	// ### SET CONTROLS
	 
	self.xmlFlipH := flipH;
	self.xmlFlipV := flipV;
	self.xmlBigFont := bigFont;
	self.mnuGridBigFont.checked := bigFont;
	self.xmlLegend := hideL;
	self.xmlToolbar := hideT;
	self.xmlMacro := hideM;
	self.xmlZoomFactor := zoomScale;
	self.xmlSplitMain	:= splitRatioMain;
	self.xmlSplitGridArea01	:= splitRatioGridArea01;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="initFromUserWindow" id="dd7e49bd-1db2-4e9c-a124-816c19dac8b2">
        <updating/>
        <source>initFromUserWindow(_userWindow: CM_UserWindow) updating;

/*

Purpose:			


Return Value:		


Date		Who		Reason
16 May 2008	cnwkpd1	PAR #16753 - CCMS SFW 1003 - General Cargo Graphical Screens

*/

vars
	str		: String;
	pos		: Integer;
	tmpTA	: CM_TerminalArea;
	
begin
	inheritMethod(_userWindow);
	pos := 1;
	
	while true do
		str := _userWindow.xmlInfo.cnEcGetNextTagValueOfName(XML_TA, pos);
		if pos &lt;= 0 then
			break;
		endif;
		
		tmpTA := self.myTerminal.allTerminalAreas[str];
		if tmpTA = null then
			continue;
		endif;

		self.myCurrentTerminalArea := tmpTA;
	endwhile;
end;</source>
        <Parameter name="_userWindow" type="CM_UserWindow"/>
    </JadeMethod>
    <JadeMethod name="initSelectAreasCollection" id="97be28a5-7338-45fc-afa4-9e5fd18b431e">
        <source>initSelectAreasCollection() protected;

/*

Purpose:			


Return Value:		


Date		Who		Reason
16 May 2008	cnwkpd1	PAR #16753 - CCMS SFW 1003 - General Cargo Graphical Screens

*/

vars
	terminalArea	: CM_TerminalArea;
	iter01			: Iterator;
	isLoadData		: Boolean;
	theTAs			: CM_TAByTypeIdDict;
	
begin
	
	self.allAvailableAreas.clear();
	
	theTAs	:=	self.myTerminal.allTerminalAreasByTypeId;
	iter01	:=	theTAs.createIterator();

	theTAs.startKeyGeq(TA_TYPE_IRREGULAR_BLOCK_AREA, null, iter01);
	
	while iter01.next(terminalArea) do
		if terminalArea.type &lt;&gt; TA_TYPE_IRREGULAR_BLOCK_AREA then
			break;
		endif;
		self.allAvailableAreas.add(terminalArea);
	endwhile;
	
	// Keep combobox for single area in sync with multi group box
	self.cmbSelectedArea.clear;
	self.cmbSelectedArea.listCollection(self.allAvailableAreas, false, 0);
	
	
epilog
	delete iter01;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="keyDown" id="aef91179-237a-40f0-81d0-36d817630df6">
        <controlMethod name="Form::keyDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>keyDown(keyCode: Integer io; shift: Integer) updating;

/*
Date		      Who		Reason
16 June 2008	cnwdz2	    Par17057 - F3 key should hide/show the searcher of the select areas.
*/

vars

begin
	if keyCode = CMUI_Key_F3 then 
		app.mousePointer	:=	Busy;
		if self.frmSelectAreas.visible then
		   self.showAreaSelectorEnable(false);
		else
		   self.showAreaSelector();
		endif;
		return;
	endif;
	
	inheritMethod(keyCode, shift);
	
epilog
	app.mousePointer	:=	Idle;
end;</source>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="loadDataForFirstTime" id="7aa93350-76aa-48bf-9888-432713499cb5">
        <updating/>
        <source>loadDataForFirstTime() updating, protected;

/*

Purpose:			


Return Value:		


Date		Who		Reason
16 May 2008	cnwkpd1	PAR #16753 - CCMS SFW 1003 - General Cargo Graphical Screens

*/

vars
	regKeys			: IntegerArray;
begin
	inheritMethod();
		
	self.isSelectorCapable := true;
	
   	self.btnViewOperator.value := true;
	
	if self.myCurrentTerminalArea &lt;&gt; null then
		// have setup in initFromUserWindow
		self.setupFormFromAreaSelector();

	else
		if self.myInitializeObject &lt;&gt; null then
			if self.myInitializeObject.isKindOf(CM_IrregularBlockArea) then
				self.myCurrentTerminalArea := self.myInitializeObject;
				self.setupFormFromAreaSelector();
			endif;
		else
			self.showAreaSelector(); 
		endif;
	endif;

	self.initSelectAreasCollection();

	create regKeys transient;
	regKeys.add(CMUI_Key_Esc);
	self.addRegisteredKeys(regKeys);
	
	
epilog
	delete regKeys;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="mnuGridBigFont_click" id="b0e3b361-fc3e-4185-bc9a-ed30c8cb1268">
