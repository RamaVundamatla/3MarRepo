<Class name="CM_RemoteRejectHdr" id="8ecf97b4-3376-4abc-88ac-f52f890c874d">
    <superclass name="CM_RemoteDataHdr"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>&lt;display&gt;Rejects&lt;/display&gt;</text>
    <DbClassMap file="remoteDataProcessing"/>
    <JadeMethod name="getDescription" id="2219ca8c-f599-49c7-9998-d640e78214b7">
        <source>getDescription(): String;

vars

begin
	return 'Rejection';
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getMessageResponseType" id="da9326d3-f379-435a-859f-40bf75bc0aba">
        <source>getMessageResponseType(): String;

vars

begin
	return CM_RemoteDataManager.REJECTRSP;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="processExternal" id="30aea3f3-f1aa-430e-92ea-fa41bc80931e">
        <updating/>
        <source>processExternal(_parseAgent: CM_RemoteParseAgent io): String updating;

vars

	response		: String;
	err				: Integer;
	errTxt			: String;
	realRemoteHdr	: CM_RemoteDataHdr;
	headerCast		: CM_RemoteDataHdr;

begin
	
	response := inheritMethod(_parseAgent);
	if response = null then
		if _parseAgent.createRejectDetail(self) then
			app.myTrxCA.trxCreateRemoteData(self, realRemoteHdr, true, app.myPassport);
			if app.myPassport.trxCompletedOK then
				return self.doBuildMessage(self.xmlResponse(err, errTxt));
			endif;
		endif;
		response := app.getErrorString1(Err_XML, 'reject');
		return self.doBuildMessage(self.xmlResponse(Err_XML , response));
	endif;
	headerCast := self;
	return self.doBuildMessage(self.xmlDefaultResponse(headerCast, Err_XML , response));
end;</source>
        <Parameter name="_parseAgent" type="CM_RemoteParseAgent" usage="io"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="processInternal" id="d189d4e3-2165-4f82-a676-58265efd9448">
        <updating/>
        <source>processInternal(_cmif: CMIF_Remote; _passport : CM_Passport input): Boolean updating;

// cnwdvb1 20 November 2002 

vars
	detail				: CM_RemoteRejectDtl;
	extra				: CM_RemoteRejectExtra;
	id					: String;
	realRemoteHdr		: CM_RemoteDataHdr;
	

begin

	inheritMethod(_cmif, _passport);
	create detail transient;
	detail.setProxyForReject(self, _cmif.reason, _cmif.recovery, '"LOG"');
	foreach id in _cmif.allTis do
		create extra transient;
		extra.setProxyForRejectExtra(detail, id, _cmif.reason, _cmif.recovery);
	endforeach;
	
	app.myTrxCA.trxCreateRemoteData(self, realRemoteHdr, true, _passport);
	return _passport.trxCompletedOK;

end;</source>
        <Parameter name="_cmif" type="CMIF_Remote"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="runProcess" id="921ca9f7-8bf4-4de1-9e0a-5e37e96753b4">
        <source>runProcess(_errorSet : CM_ErrorSet input; _isBackGround : Boolean) : Boolean;

vars

	rejectDetail				: CM_RemoteDataDtl;
		

begin

	foreach rejectDetail in self.allRemoteDataDtl where not rejectDetail.isProcessed do
		rejectDetail.CM_RemoteRejectDtl.doRejection(_errorSet);
	endforeach;
	return inheritMethod(_errorSet, _isBackGround);

end;</source>
        <Parameter name="_errorSet" type="CM_ErrorSet" usage="input"/>
        <Parameter name="_isBackGround" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
