    <JadeMethod name="setForRedraw" id="0eef0d3e-2143-443c-aac6-b3ed12ead70e">
        <updating/>
        <source>setForRedraw(_obj: Object; _x1: Integer; _y1: Integer; _x2: Integer; _y2: Integer) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date				Who		Reason
26 November 2008	consw1	Initial creation

*/

vars
	taViewPosition : CM_TerminalAreaViewPosition;
begin
	if self.isForSatelliteView then
		self.myTerminalArea := null;
		if _obj &lt;&gt; null then
			if _obj.isKindOf(CM_TrackedItem) then
				self.myTerminalArea := _obj.CM_TrackedItem.myTerminalArea;
			elseif _obj.isKindOf(CM_LocationsController) then
				self.myTerminalArea := _obj.CM_LocationsController.myTerminalArea;
			elseif _obj.isKindOf(CM_BlockStack) then
				self.myTerminalArea := _obj.CM_BlockStack;
			endif;
		endif;
		taViewPosition:=self.myTerminalAreaView.findViewPositionForTA(self.myTerminalArea.CM_TerminalArea);
		self.setOrientation( taViewPosition );
	endif;
	
	if self.myDrawingFrame.swapXY then
		inheritMethod(_obj,	_y1 - self.myDrawingFrame.swapXadjustment, _x1 - self.myDrawingFrame.swapYadjustment, 
							_y2 - self.myDrawingFrame.swapXadjustment, _x2 - self.myDrawingFrame.swapYadjustment	);
	else
		inheritMethod(_obj, _x1, _y1, _x2, _y2);
	endif;

epilog

end;</source>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_x1" type="Integer"/>
        <Parameter name="_y1" type="Integer"/>
        <Parameter name="_x2" type="Integer"/>
        <Parameter name="_y2" type="Integer"/>
    </JadeMethod>
