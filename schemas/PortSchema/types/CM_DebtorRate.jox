    <JadeMethod name="appliesToDebtor" id="670142f4-5f04-4c76-a873-7a2e6516871d">
        <source>appliesToDebtor(_theDebtor: CM_Object): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14 May 2009	cnwer1	Initial creation

*/

vars

begin


	
	return self.debtorNode = _theDebtor;

epilog

end;</source>
        <Parameter name="_theDebtor" type="CM_Object"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="auditIdDisplay" id="b2542720-236b-42ba-a2d5-bdd9e1892499">
        <source>auditIdDisplay(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 October 2019	jlgndl1	Initial creation	TFS 47013

*/

vars
	auditIdStr : String;
begin

	auditIdStr := self.auditId();
	
	if auditIdStr &lt;&gt; null then
		return app.getErrorString(Rate) &amp; Space &amp; Hyphen &amp; Space &amp; app.getErrorString(INV_Debtor) &amp; ": "&amp; auditIdStr;
	else
		return app.getErrorString(Rate);
	endif;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getCode" id="b9742d21-73d8-4fb9-b5f4-0eb2481bcba0">
        <source>getCode(): String;
// ---------------------------------------------------------------------------
// Created:		September 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

	invalidObject : Boolean;
	edition : Integer;

begin
	if self.debtorNode &lt;&gt; null then
		on Exception do app.handleDeletedObject( exception, self.debtorNode, invalidObject );
		edition := self.debtorNode.edition;
		if invalidObject then
			return null;
		endif;
		return self.debtorNode.name;
	endif;
	
	return null;	//16 Oct 2019	NDL	TFS 47013
	
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
