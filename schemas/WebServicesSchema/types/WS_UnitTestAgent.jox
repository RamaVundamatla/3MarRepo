    <JadeMethod name="wsRESTPutPackComplete" id="e4330a42-0ab0-4721-b070-5e19762ba928">
        <source>wsRESTPutPackComplete(_parentCargo: CM_TrackedItem; _release: CM_BulkRelease): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 Aug 2024	navbs1	Initial creation
16 Oct 2024 navbs1 	Bug MTN-12500: EUP | No warning message on the work order operations app after packing part of one child line

*/

vars
	webService 			: MTNInternalAPIService;
	terminalCode  		: String;
	token 				: String;
	loginJson 			: String;
	request				: WS_PackCompleteRequest;
	response			: WS_Response; 
	ref 				: String;
	
begin
	// Web service call
	create webService transient;
	
	terminalCode := self.UT_TERMINAL_CODE;
	
	if app.myRoot.allTerminals[terminalCode] = null then
		return "UT Terminal not found!";
	endif;	
	
	loginJson := '{
   "userId": "' &amp; self.USERCODE &amp; '",
   "password": "' &amp; self.PASSWORD &amp; '",
    "applicationId" : "internalAPI",
    "scope" : {
        "complexId" : "Master Terminal",
		"facilityId": "' &amp; terminalCode &amp; '",
        "operatorId" : "Navis",
        "yardId" : "MTN"
    }}';
	
	self.wsRESTLogin(loginJson, token);
	
	if token &lt;&gt; null then				
		webService.unitTestData.addAssoc("HTTP_AUTHORIZATION", token);
	endif;
	
	create request transient;
	request.setPropertyValue('parentCargoOid',_parentCargo.getOidAsString());
	request.setPropertyValue('releaseOid',_release.getOidAsString());
	request.setPropertyValue("warningsAcknowledged", true);					//16.10.2024  navbs1  #12500			
	
	response := webService.putPackComplete(request);
	if response.hasErrors then
		return  response.getErrorsAsStringForTesting;
	endif;
	
	return null;
	
	// Not used,just to provide a reference from the super schema super class method 
	ref := CM_UnitTestAgent::wsRESTPutPackComplete.name;
epilog
	webService.unitTestData.removeAssoc("HTTP_AUTHORIZATION");	
	delete request;
	delete response;
	delete webService;
end;</source>
        <Parameter name="_parentCargo" type="CM_TrackedItem"/>
        <Parameter name="_release" type="CM_BulkRelease"/>
        <ReturnType type="String"/>
    </JadeMethod>
