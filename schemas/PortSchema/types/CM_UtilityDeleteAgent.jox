        <source>utlDeleteWorkOrder(_workOrder : CM_WorkOrder input; _passport : CM_Passport input);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 August 2009	cnwmd1	Initial creation

*/

vars

begin
	self.initialiseActivity();

