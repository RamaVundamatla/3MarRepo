<Class name="CMQF_VoyageGeneralCargoSummary" id="1edec478-6e0f-4cf0-bbd2-30d05fa916dc">
    <superclass name="CMQF_VoyageLoadListSummary"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="query"/>
    <ImplicitInverseRef name="allBOLTypes" id="7a199b53-d6cf-44f8-8cbe-fbbaf6a40a5e">
        <memberTypeInverse/>
        <type name="CM_BOLTypesByIdDict"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="allBOLs" id="29a5f345-74c9-4c79-af8b-306309d47d07">
        <memberTypeInverse/>
        <type name="CM_BOLByTypeNumberDTDict"/>
    </ImplicitInverseRef>
