    <JadeMethod name="getFullXMLForEvent" id="533e5121-3415-49ec-ad15-3bfdfe5faaed">
        <source>getFullXMLForEvent( _camProtocol: CM_CamProtocol; _transaction: CM_EventTransaction;  _messHdrEventType : String; _messTypeDesc : String; _xmlDoc : JadeXMLDocument input );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 August 2016	cnwndl1	Initial creation	TFS 2561 / 2277
9/11/2018 	JLGNS1	Bug 41923: AAT - Time Issue in EDI Message
*/

vars

	rootElem : JadeXMLElement;
	term : CM_Terminal;
	voyage : CM_Voyage;
	
	debugElement : JadeXMLElement;
	voyageEvent : CMEVT_VoyageEvent;

begin

	term := _transaction.myTerminal;

	rootElem := _xmlDoc.addElement('CargoMessage');
	
	if _transaction &lt;&gt; null and app.isDevelopmentSystem then
		debugElement := rootElem.addElement('JMTTransClass');
		debugElement.setText( _transaction.class.name );
	endif;

	self.makeMessageHeaderSectXML( term, _camProtocol, _transaction.dateTime, _messHdrEventType, rootElem );
	
	if _transaction.isKindOf(CMEVT_VoyageEvent) then	//25 Oct 2017	NDL	TFS 6940
		voyageEvent := _transaction.CMEVT_VoyageEvent;
		voyage := voyageEvent.myVoyage;
	endif;
	
	
	if voyageEvent.isVoyBolOutturn then	//25 Oct 2017	NDL	TFS 6940
		self.makeBOLCargoSectionXML( voyageEvent, _messTypeDesc, rootElem );
		self.makeBOLCommoditySectionXML( voyageEvent, _messTypeDesc, rootElem );
	endif;
	
	self.makeTimeStampsSectXML( _transaction.dateTime, null, rootElem , term );//Bug 41923
	
	self.makeArrCarrSectXML( null, voyage, rootElem );

epilog

end;</source>
        <Parameter name="_camProtocol" type="CM_CamProtocol"/>
        <Parameter name="_transaction" type="CM_EventTransaction"/>
        <Parameter name="_messHdrEventType" type="String"/>
        <Parameter name="_messTypeDesc" type="String"/>
        <Parameter name="_xmlDoc" type="JadeXMLDocument" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getFullXMLForTiTrx" id="ca226f60-6427-437b-b064-c06de79b7b22">
        <source>getFullXMLForTiTrx( _camProtocol: CM_CamProtocol; ti : CM_TrackedItem input; _trx : CM_TITransaction; _messHdrEventType : String; _messTypeDesc : String; _xmlDoc : JadeXMLDocument input );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 August 2016	cnwndl1	Initial creation		TFS 2561 / 2277
26 Jan    2018  cnwma1 ChangeRequest 36753: AAT - 1-Stop XML cargo movement message LineOperatorCode
9/11/2018 	JLGNS1	Bug 41923: AAT - Time Issue in EDI Message
*/

vars

	rootElem : JadeXMLElement;
	
	commodity : CM_Commodity;
	term : CM_Terminal;
	operator : CM_Operator;
	cusAgent : CM_CustomsAgent;
	consignor : CM_ConsigneeConsignor;
	consignee : CM_ConsigneeConsignor;
	arrivalCarrier : CM_Carrier;
	
	debugElement : JadeXMLElement;

begin

	term := ti.myTerminal;

	rootElem := _xmlDoc.addElement('CargoMessage');
	
	if _trx &lt;&gt; null and app.isDevelopmentSystem then
		debugElement := rootElem.addElement('JMTTransClass');
		debugElement.setText( _trx.class.name );
	endif;

	self.makeMessageHeaderSectXML( term, _camProtocol, _trx.dateTime, _messHdrEventType, rootElem );
	
	self.makeCargoSectionXML( ti, _messTypeDesc, rootElem );
	
	self.makeCommoditySectionXML( ti, _messTypeDesc, rootElem );
	
	/* 26/01/2018 cnwma1 TFS #36753
	if ti.myVoyage &lt;&gt; null and ti.myVoyage &lt;&gt; term.getNullVoyage then
		operator := ti.myVoyage.myOperator;	
	endif;
	self.makeLineOperatorSectXML( operator, rootElem );
	*/
	self.makeLineOperatorSectXML( ti.myOperator, rootElem );  //26/01/2018 cnwma1 TFS #36753
	
	cusAgent := ti.myCustomsAgent;
	self.makeShippingAgentSectXML( cusAgent, rootElem );
	
	consignor := ti.getConsignorObject;
	self.makeConsignorSectXML( consignor, rootElem );
	
	consignee := ti.getConsigneeObject;
	self.makeConsigneeSectXML( consignee, rootElem );
	
	self.makeNotifyPartySectXML( null, rootElem );
	
	self.makeTimeStampsSectXML( _trx.dateTime, _trx, rootElem , term );//Bug 41923
	
	self.makeRefNumbersSectXML( ti, rootElem );
	
	self.makeStopSectXML( ti, rootElem );
	
	self.makeArrCarrSectXML( ti, null, rootElem );
	
	self.makeDepartCarrSectXML( ti, rootElem );
	
	self.makeCurrentLocSectXML( ti, rootElem );
	
	self.makeSealSectXML( ti, rootElem );
	
	self.makeOverDimensionSectXML( ti, rootElem );
	
	self.makeReeferInfoSectXML( ti, rootElem );
	
	self.makeHazardousSectXML( ti, rootElem );
	
	self.makeCustomsSectXML( ti, rootElem );
	
	self.makeAttachSectXML( ti, rootElem );

epilog

end;</source>
        <Parameter name="_camProtocol" type="CM_CamProtocol"/>
        <Parameter name="ti" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_trx" type="CM_TITransaction"/>
        <Parameter name="_messHdrEventType" type="String"/>
        <Parameter name="_messTypeDesc" type="String"/>
        <Parameter name="_xmlDoc" type="JadeXMLDocument" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getMessHdrTypeFromTrx" id="b0855a56-9f84-409a-893b-bbecf842a2b3">
        <updating/>
        <source>getMessHdrTypeFromTrx(	_trx : CM_Transaction;
						_ti : CM_TrackedItem;
						_messHdrEventType : String output;
						_messTypeDesc : String output
						) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 August 2016	cnwndl1	Initial creation	TFS 2277 / 2561

*/

vars

	trxType : Integer;
	oldId : String;

begin

	if _trx = null then
		return;
	endif;
	
	if _trx.isKindOf(CM_EventTransaction) then
	
		if _trx.CMEVT_VoyageEvent.isVoyBolOutturn then	//25 Oct 2017	NDL	TFS 6940
			_messHdrEventType := self.TypeOUTTURN;
			_messTypeDesc := self.OUTTURN;
			return;
		endif;
		
		_messHdrEventType := self.TypeFINAL;
		_messTypeDesc := self.COMPLETE;
		return;
		
	endif;
	
	if _ti = null or not _trx.isKindOf(CM_TITransaction) then
		return;
	endif;
	
	trxType := _trx.CM_TITransaction.type;
	
	if trxType = TRANS_TYPE_EDIT and  _ti.isContainer and _trx.CM_Edit.isChangedId(oldId) then
		_messHdrEventType := self.TypeUPDATE;
		_messTypeDesc := self.TCHG85;
/*	elseif _ti.hasBeenMerged then
		_messHdrEventType := self.TypeREMOVE;
		_messTypeDesc := self.BRMV;
	elseif _ti.isDeleted then
		_messHdrEventType := self.TypeDELETE;
		if _ti.isContainer then
			_messTypeDesc := self.TRMV;
		else
			_messTypeDesc := self.BRMV;
		endif;	*/
	
	//04 Aug 2017	NDL	TFS 5679
	elseif ( trxType = TRANS_TYPE_Logical_Delete and _ti.getImExStatus = TI_IMEX_STATUS_IMPORT ) then
		_messHdrEventType := self.TypeDELETE;
		if _ti.isContainer then
			_messTypeDesc := self.TRMV;
		else
			_messTypeDesc := self.BRMV;
		endif;
	
	//04 Aug 2017	NDL	TFS 5679
	elseif ( trxType = TRANS_TYPE_Logical_Delete and _ti.getImExStatus = TI_IMEX_STATUS_EXPORT ) then
		_messHdrEventType := self.TypeREMOVE;
		if _ti.isContainer then
			_messTypeDesc := self.TRMV;
		else
			_messTypeDesc := self.BRMV;
		endif;
	
	elseif trxType = TRANS_TYPE_REL_SHIP then
		_messHdrEventType := self.TypeLOAD;
		if _ti.isContainer then
			_messTypeDesc := self.TLOD;
		else
			_messTypeDesc := self.BLOD;
		endif;
	elseif trxType = TRANS_TYPE_REC_SHIP then
		_messHdrEventType := self.TypeDISCHARGE;
		if _ti.isContainer then
			_messTypeDesc := self.TDIS;
		else
			_messTypeDesc := self.BDIS;
		endif;
	elseif _trx.CM_TITransaction.isReceivalTypeForStorage then // all the other receive types, create etc.
		_messHdrEventType := self.TypeGATEIN;
		if _ti.isContainer then
			_messTypeDesc := self.TREC;
		else
			_messTypeDesc := self.BREC;
		endif;
	elseif app.isReleaseTypeTransaction( trxType ) then	// all the other release types
		_messHdrEventType := self.TypeGATEOUT;
		if _ti.isContainer then
			_messTypeDesc := self.TDEL;
		else
			_messTypeDesc := self.BDEL;
		endif;
	
	//07 Aug 2017	NDL	TFS 5701  - and now AAT say they do use it
	elseif trxType = TRANS_TYPE_OUTTURN then
		_messHdrEventType := self.TypeOUTTURN;
		_messTypeDesc := self.OUTTURN;
	
	else
		// OK its a generic update
		_messHdrEventType := self.TypeUPDATE;
		if _ti.isContainer then
			_messTypeDesc := self.TCHG82;
		else
			_messTypeDesc := self.BCHG;
		endif;
	endif;
	
	//There is also an "OUTTURN" messTypeDesc where an oversuppliy of Import is sent back,
	//but not sure how we ever represent one of these, apparently noyt used by AAT

epilog

end;</source>
        <Parameter name="_trx" type="CM_Transaction"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_messHdrEventType" type="String" usage="output"/>
        <Parameter name="_messTypeDesc" type="String" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getQtyRemaining" id="8e74bdb0-52c2-4b35-bf44-70da5039dfc0">
        <source>getQtyRemaining( _ti : CM_TrackedItem; _messTypeDesc : String ):String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 August 2016	cnwndl1	Initial creation	TFS 2277 / 2561

*/

vars

	trx : CM_Split;
	parentTi : CM_TrackedItem;

begin

	if _messTypeDesc = self.BCHG then
		return _ti.totalQuantity.String;
		
	elseif _messTypeDesc = self.BDEL then
		//_ti is going out the gate, find out how much of his parent is left onsite.

		trx := _ti.allTransactions.getLastTransOfType( TRANS_TYPE_SPLIT, null).CM_Split;	// 7/11/16 cnwmp6 TFS 2891
		if trx &lt;&gt; null and trx.myParentSplit &lt;&gt; null then	//21 Sep 2016	NDL	TFS 2277
			parentTi := trx.myParentSplit.myTrackedItem;
		endif;
	
		if parentTi &lt;&gt; null and not parentTi.hasBeenMerged() and parentTi.isOnSite then
			return parentTi.totalQuantity.String;
		endif;
		
	endif;
	
	//re implemented
	return null;

epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_messTypeDesc" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getVesselDischargeInd" id="00f30e9c-5e31-4457-b5ff-07063df023ac">
        <source>getVesselDischargeInd( _messTypeDesc : String; _bol : CM_BOL ):String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 August 2016	cnwndl1	Initial creation	TFS 2277 / 2561

*/

vars

	iter : Iterator;
	ti : CM_TrackedItem;

begin
	
	if _messTypeDesc = self.TypeOUTTURN then	//10 Jan 2018	NDL	TFS 8165
		if _bol &lt;&gt; null then
			iter := _bol.allTrackedItems.createIterator;
			while iter.next(ti) do
				if ti.hasBeenMerged then	//18 Jan 2018	TFS 36698
					//ignore zombies
					continue;
				endif;
				if ti.isContainer then
					//ignore containers
					continue;
				endif;
				if ti.isChild and ti.myParent.isContainer then
					//ignore things in containers...
					continue;
				endif;
				if ti.isUnderBondOneStop then
					return "U";
				endif;
			endwhile;
		endif;
		return "V";
	endif;
	
	if _messTypeDesc = self.BDIS then
		return "V";
	endif;
	
	
	return null;

epilog

	delete iter;

end;</source>
        <Parameter name="_messTypeDesc" type="String"/>
        <Parameter name="_bol" type="CM_BOL"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="handle70084" id="26e9cd5a-67be-4cce-9efc-8303d38c4fbf">
        <source>handle70084(_exc : Exception; _skip : Boolean io) : Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 August 2016	cnwndl1	Initial creation	TFS 2277 / 2561


*/

vars

	returnVal		: Integer;

begin

	returnVal := Ex_Pass_Back;
	
	if _exc.errorCode = 70084 then
		_skip := true;
		returnVal := Ex_Resume_Next;
	endif;
	
	return returnVal;

epilog

end;</source>
        <Parameter name="_exc" type="Exception"/>
        <Parameter name="_skip" type="Boolean" usage="io"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="includeEvent" id="0b7632fc-e250-495f-a49f-ac991b843f82">
        <source>includeEvent(_eventTransaction: CM_EventTransaction; _camProtocol: CM_CamProtocol; _camAgent: CM_CamControllerAgent): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 September 2016	cnwndl1	Initial creation	TFS 2276 / 2565

*/

vars
	
begin
	
	if not _eventTransaction.isKindOf(CMEVT_VoyageEvent) then
		if _camAgent.logExcludedTransactions then
			_camAgent.logReasonForExclusion(_eventTransaction, 'Event transaction ' &amp; _eventTransaction.getDisplayID &amp;  ' does not match cam group oprerator');
		endif;
		return false;
	endif;
	
	return true;
	
end;
</source>
        <Parameter name="_eventTransaction" type="CM_EventTransaction"/>
        <Parameter name="_camProtocol" type="CM_CamProtocol"/>
        <Parameter name="_camAgent" type="CM_CamControllerAgent"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="includeTransaction" id="5558646c-cbc1-4f6d-a92c-8aef2421c1e6">
        <source>includeTransaction(_transaction: CM_Transaction; _camsTS: TimeStamp; _startTS: TimeStamp; _endTS: TimeStamp; _camProtocol: CM_CamProtocol; _camGroup: CM_CamGroup; _camAgent: CM_CamControllerAgent; _logExcluded: Boolean; _event : CM_EventTransaction): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 August 2016	cnwndl1	Initial creation	TFS 2561 / 2277
05 Jun 2018	jlgsl4	TFS 38884 - SNO - no CAMS output for TIs in Logical Delete areas
01 Apr 2019	jlgsl4	TFS 42671 - AAT - no edit transactions output by CAMS for prenote cargo
12 Mar 2020	jlgdap1	TFS 48785 SNO COARRI Issue - new parameter for CM_CamProtocolDesc includeTransaction
*/
vars
	ti			:CM_TrackedItem;
	isInvalid	:Boolean;
begin
	
	on Exception do app.handleDeletedObject(exception, ti, isInvalid);
			
	ti := _transaction.CM_TITransaction.myTrackedItem;
	
	if ti = null then
		_camAgent.logReasonForExclusion (_transaction, 'Transaction does not have a cargo item');
		return false;
	endif;
	
	if _transaction.isKindOf(CM_Edit) and ti.isPreNote() then // TFS 42671
		_camAgent.logReasonForExclusion(_transaction, 'Transaction is edit of prenote item'); // TFS 42671
		return false; // TFS 42671
	endif; // TFS 42671

	if ti.isDeleted then // TFS 38884
		_camAgent.logReasonForExclusion (_transaction, 'Transaction is for deleted cargo item'); // TFS 38884
		return false; // TFS 38884
	endif; // TFS 38884

	if not _camProtocol.includeCargoType(ti.cargoType, _transaction, _camAgent, _logExcluded) then
		return false;
	endif;
	
	if isInvalid then
		_camAgent.logReasonForExclusion (_transaction, 'Transaction has an invalid cargo item');
	
		return false;
	endif;
	
	if not _camProtocol.isCAMGroupMatch (_transaction.CM_TITransaction, _camAgent, _logExcluded) then
		return false;
	endif;
	
	if _transaction.isKindOf(CM_Edit) and 
		_camProtocol.allEditTriggerFields.size &gt; 0 and 
		not _transaction.CM_Edit.hasCamProtocolTrigger (_camProtocol.allEditTriggerFields) then
		// an edit trx for a field we are NOT interested in
		
		_camAgent.logReasonForExclusion (_transaction, 'Edit Transaction does not match any CAM protocol trigger fields');
		
		return false;		
	endif;
	
	return true;
epilog

end;</source>
