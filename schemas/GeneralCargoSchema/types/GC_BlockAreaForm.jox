    <JadeMethod name="displaySelectAreas" id="c54fa786-f81e-4af9-b070-2fb1818e13ec">
        <source>displaySelectAreas(_theObject : Object) : String protected;

/*

Purpose:			


Return Value:		


Date		Who		Reason
16 May 2008	cnwkpd1	PAR #16753 - CCMS SFW 1003 - General Cargo Graphical Screens

*/

vars
	terminalAreaObj	: CM_TerminalArea;
	displayVal		: String;
	
begin
	if _theObject &lt;&gt; null then
		terminalAreaObj	:=	_theObject.CM_TerminalArea;
		displayVal		:=	terminalAreaObj.id.trimBlanks &amp; " - " &amp;
							terminalAreaObj.myType.description.trimBlanks();
	endif;
	
	return displayVal;
end;</source>
        <access>protected</access>
        <Parameter name="_theObject" type="Object"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="displaySelectorResults" id="941f5dbc-ae9b-4f73-8b8c-8631929d3c8e">
        <updating/>
        <source>displaySelectorResults(_resultCollection: Collection; _mode: Integer) updating;

/*

Purpose:			


Return Value:		


Date		Who		Reason
16 May 2008	cnwkpd1	PAR #16753 - CCMS SFW 1003 - General Cargo Graphical Screens

*/

begin
	if _mode &gt; TI_CargoType_Max then
		app.msgBox('The grid area screen cannot display item for the selected mode (' &amp; _mode.String &amp; ')', 'Invalid selector mode', MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	
	self.myDrawingController.allSelectorTIs.clear;
	_resultCollection.copy(self.myDrawingController.allSelectorTIs);
	self.frmBlockArea.drawSelf();	
	self.mnuGridSelectorClear.visible := not self.myDrawingController.allSelectorTIs.isEmpty;

end;</source>
        <Parameter name="_resultCollection" type="Collection"/>
        <Parameter name="_mode" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doBlockAreaDragDropEvent" id="5c176909-f4df-4c8d-8e01-f51900afe874">
        <updating/>
        <source>doBlockAreaDragDropEvent(_frame: CMUI_BlockAreaFrame input; _win: Window input; _location : CM_LocationsController) updating, protected;

/*

Purpose:			


Return Value:		


Date		Who		Reason
16 May 2008	cnwkpd1	PAR #16753 - CCMS SFW 1003 - General Cargo Graphical Screens

*/

vars
	
begin
	if _win &lt;&gt; null then
		if _win.userObject &lt;&gt; null then
			if _win.userObject.class.name = "SHP_LoadList" then
				app.raiseCMException1(INVALID_MOVE_REQUEST, 'Cannot drag drop from Load List form.', null, null);
				return;
			endif;
		endif;
	endif;	

	if _win.isKindOf(CMUI_GridAreaForm) or 
	   _win.isKindOf(CMUI_GridAreaFrame) or
	   _win.isKindOf(CMUI_GridAreaForm2) or
	   _win.isKindOf(CMUI_GridAreaDrawingFrame) then
	   
		self.doDropFromBlockAreaForm(_frame, _win, _location);

	elseif _win.isRoadOpsForm() or _win.isKindOf(CM_DataTable) then 
		self.doDropFromBlockAreaForm(_frame,_win, _location);
	endif;
	
	self.frmBlockArea.refresh();
	
	if app.myPassport.trxCompletedOK then
		app.isDragging := true;
	else
		app.isDragging := false;
	endif;
	
	_frame.dragMode := DragMode_None;
epilog
	_frame.enableEvent("mouseMove",false);
end;</source>
        <access>protected</access>
        <Parameter name="_frame" type="CMUI_BlockAreaFrame" usage="input"/>
        <Parameter name="_win" type="Window" usage="input"/>
        <Parameter name="_location" type="CM_LocationsController"/>
    </JadeMethod>
    <JadeMethod name="doBlockAreaMouseContextEvent" id="622bdc72-7b0c-485d-9586-089b2d117efc">
        <updating/>
        <source>doBlockAreaMouseContextEvent(_cntrl: Frame input;
							_conwin: Window input;
							_mouse: Boolean;
							_x: Integer;
							_y: Integer):Boolean updating, protected;
vars
	blockAreaFrame : CMUI_BlockAreaFrame;
	obj 		: Object;
	showRacks 			: Boolean;
begin
	if self.myDrawingController = null then //PAR17125 cnwgb1
		return false;
	endif;
	self.doTurnOffContextMenus();
	
	blockAreaFrame := _cntrl.CMUI_BlockAreaFrame;
	if blockAreaFrame &lt;&gt; null then
		self.myCurrentTerminalArea := blockAreaFrame.getTerminalArea();
		self.mnuYardAllocations.visible := true;
		//epr par 34995 29/10/14
		showRacks:=false;
		foreach obj in self.myDrawingController.allSelectedObjects do
			if obj.isKindOf(CM_LocationsController) and obj.CM_LocationsController.isRack then
				showRacks:=true;
				break;
			endif;
		endforeach;
		
		self.mnuShowRackShelves.visible := showRacks;
	
		self.mnuGridBigFont.visible := true;
		self.doMnuYardAllocBuild(self.mnuYardAllocations);
		self.doBuildMnuZoom(self.mnuZoomSub);
		self.mnuGridAreaContext.visible := false;
		self.mnuGridAreaContext.enabled := false;
		self.doBuildMnuLocationStatus(_x, _y);
	endif;
	
	return self.showContextMenu(mnuGridAreaContext, _cntrl, _conwin, _mouse, _x, _y);
end;</source>
        <access>protected</access>
        <Parameter name="_cntrl" type="Frame" usage="input"/>
        <Parameter name="_conwin" type="Window" usage="input"/>
        <Parameter name="_mouse" type="Boolean"/>
        <Parameter name="_x" type="Integer"/>
        <Parameter name="_y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doBtnEditYardAlloc" id="78202655-0537-4ca2-946e-a03021c608a6">
        <updating/>
        <source>doBtnEditYardAlloc() updating;
//27 May 2008	cnwdw1	
// User has clicked the yard allocation edit button
vars
	yardAllocation : CM_YardAllocation;
	selectedRow : JadeTableRow;
begin
	if self.btnViewYardAllEd.value then
		//epr par 35915 25/3/15
		if self.frmColLegendTIs.myLegendTable.row &gt; 1 then
			selectedRow:=self.frmColLegendTIs.myLegendTable.accessRow(self.frmColLegendTIs.myLegendTable.row);
		endif;
		if selectedRow &lt;&gt; null then
			yardAllocation :=selectedRow.itemObject.CM_YardAllocation;
		endif;
		if yardAllocation = null then
			return;
		endif;
		self.doDisplayYardAllocationForm(yardAllocation, true);
	endif;
end;</source>
    </JadeMethod>
