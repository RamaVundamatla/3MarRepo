    <JadeMethod name="setupTable" id="af495839-cbfb-43ca-b64a-d465e7cbf7c8">
        <source>setupTable();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 May 2017	cnwndl1	Initial creation	TFS 4460

*/

vars

	ti : CM_TrackedItem;
	index : Integer;

begin

	self.tblLoaded.visible := self.myTruck &lt;&gt; null;

	self.tblLoaded.clear();
	
	self.tblLoaded.parentAspect:=Table.ParentAspect_StretchBoth;
	self.tblLoaded.columns := 2;
	self.tblLoaded.fixedColumns := 0;
	self.tblLoaded.rows := 1;
	self.tblLoaded.fixedRows := 2;
	self.tblLoaded.accessColumn(1).inputType := Table.InputType_None;
	self.tblLoaded.accessColumn(2).inputType := Table.InputType_None;
	
	self.tblLoaded.accessCell(1,1).text := "Already Loaded";
	self.tblLoaded.accessCell(1,1).mergeCells := Table.MergeCells_Merge;
	self.tblLoaded.accessCell(1,1).alignment := Table.Alignment_Center;
	
	self.tblLoaded.accessCell(2,1).text := app.getErrorString(AlternativeID);
	self.tblLoaded.accessCell(2,2).text := app.getErrorString(CargoId);
	
	self.tblLoaded.accessSheet(1).scrollMode := Table.ScrollMode_HorzPixel_VertCell;
	
	if self.myTruck &lt;&gt; null then
		foreach ti in self.myTruck.locationsController.allTrackedItems do
			if ti.isCar then
				index := self.tblLoaded.addItem( ti.alternativeId &amp; Tab &amp; ti.id );
			endif;
		endforeach;
		if index = 0 then
			index := self.tblLoaded.addItem( "Nothing already loaded" );
			self.tblLoaded.accessCell(index,1).mergeCells := Table.MergeCells_Merge;
			self.tblLoaded.accessCell(index,1).alignment := Table.Alignment_Center;
			self.tblLoaded.accessRow(index).height := self.tblLoaded.height.Integer - ( self.tblLoaded.accessRow(index).height * 3 ).Integer;
		endif;
	endif;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="5126603d-3c5a-4962-b354-d1d7f9d12829">
        <updating/>
        <source>translateForm(locale : CM_Locale) updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 18 May 2017 11:15:22.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	
begin
	// Determine the locale for translations.
	inheritMethod(locale);
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0021997, locale);
	lblScanTxt.translateCaption(Xlat_0021998, locale);
	lblTruck.translateCaption(Xlat_0021999, locale);
end;</source>
        <Parameter name="locale" type="CM_Locale"/>
    </JadeMethod>
    <JadeMethod name="txtScanTxt_gotFocus" id="adbdd3f9-8e4d-4f2d-82f7-800405865380">
        <controlMethod name="TextBox::gotFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtScanTxt_gotFocus(textbox: TextBox input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 May 2017	cnwndl1	Initial creation

*/

vars

begin

	if self.txtScanTxt.text = self.lblScanTxt.caption.toUpper then
		self.txtScanTxt.selStart := 0;
		self.txtScanTxt.selLength := self.lblScanTxt.caption.length;
	endif;

epilog

end;</source>
        <Parameter name="textbox" type="TextBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="txtScanTxt_keyDown" id="bc3a1ae8-d14c-432b-b86d-a989896fe553">
        <controlMethod name="TextBox::keyDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtScanTxt_keyDown(textbox: TextBox input; keyCode: Integer io; shift: Integer) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 May 2017	cnwndl1	Initial creation

*/

vars

	errMsg : String;

begin

	if keyCode = J_key_Enter then
		// If we get an &lt;enter&gt;, treat it like a &lt;tab&gt;.
		keyCode := J_key_Tab;
		
	endif;

epilog

end;</source>
        <Parameter name="textbox" type="TextBox" usage="input"/>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="txtScanTxt_lostFocus" id="481487d2-3f72-433d-98bd-d5c51571239a">
        <controlMethod name="TextBox::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtScanTxt_lostFocus(textbox: TextBox input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 May 2017	cnwndl1	Initial creation	TFS 4460

*/

vars

	errMsg : String;

begin

	if self.txtScanTxt.text.trimBlanks = null then
		self.txtScanTxt.text := self.lblScanTxt.caption.toUpper;
		self.txtScanTxt.selStart := 0;
		self.txtScanTxt.selLength := 0;
	elseif self.txtScanTxt.text = self.lblScanTxt.caption.toUpper then
		self.txtScanTxt.selStart := 0;
		self.txtScanTxt.selLength := 0;
		// nothing to do
	else
		self.processVehicleScanText( errMsg );
		if errMsg &lt;&gt; null then	
			self.msgBox( errMsg, app.getErrorString(Error), MsgBox_OK_Only, true );
		else
			self.setupTable();
		endif;
		self.txtScanTxt.text := self.lblScanTxt.caption.toUpper; 
		self.txtScanTxt.setFocus();
		
	endif;

epilog

end;</source>
        <Parameter name="textbox" type="TextBox" usage="input"/>
    </JadeMethod>
