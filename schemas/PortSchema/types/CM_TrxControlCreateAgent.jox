	// Start the transaction
	beginTransaction;
	
	app.myUtilityCA.utlCreateROROVesselDeck(_proxyDeck ,
											_realDeck ,
											_copyDeckItems,
											_passport);
	
	
	
epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
