    <JadeMethod name="tblDimensions_queryRowColChg" id="1950133a-84da-4b1e-9d11-e168c7a57167">
        <controlMethod name="CM_DataTable::queryRowColChg"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblDimensions_queryRowColChg(table: Table input; newSheet: Integer; newRow: Integer; newCol: Integer):Boolean updating;
// ---------------------------------------------------------------------------
// Created:     05 April 2011 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	idx : Integer;
	length : Decimal[12,1];
	invalid, isResizable : Boolean;
begin
	on Exception do app.handleDeletedObject(exception, self.myCurrentProxyItemLayout, invalid);

	// PAR 31671
	if self.myCurrentProxyItemLayout &lt;&gt; null then
		isResizable := self.myCurrentProxyItemLayout.isResizeable();
	endif;
	if invalid then
		self.myCurrentProxyItemLayout := null;
		self.myCurrentProxyLayer := null;
		return true;
	endif;
	
	if table.column &lt;= table.columns 
	and table.row &lt;= table.rows 
// PAR 31671	and self.myCurrentProxyItemLayout &lt;&gt; null then
// PAR 31671		if self.myCurrentProxyItemLayout.isResizeable() then // PAR 28013
	and isResizable then // PAR 31671
		
			idx := (self.tblDimensions.accessCell(table.row, table.column).maxLength / 100).Integer;
			length := self.tblDimensions.accessCell(table.row, table.column).text.asDecimalJMT;	// 28785 Jan 2012 was .Decimal
			self.myCurrentProxyItemLayout.setPolyCMsByIndex(idx, length);
	//	endif;
	endif;

	return true;
	
epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="newSheet" type="Integer"/>
        <Parameter name="newRow" type="Integer"/>
        <Parameter name="newCol" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="tblDimensions_rowColumnChg" id="b35deb93-b955-4017-9aa2-4fd96fc88965">
        <controlMethod name="CM_DataTable::rowColumnChg"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblDimensions_rowColumnChg(table: Table input) updating;
/*
Purpose:			
Date		Who		Reason
15 August 2011	cnwab1	Initial creation
*/

vars
	idx : Integer;
begin

		// PAR 28008
		idx := table.row;
		
		if idx &gt; 0 and self.myParentForm.isKindOf(SHP_RORODeckDefinitionForm) then
			self.myParentForm.SHP_RORODeckDefinitionForm.doMarkPointOnCurrentPoly(idx, self.myCurrentProxyItemLayout);

		endif;

epilog

end;</source>
