    <JadeMethod name="doCashOnlyValidation" id="dbb45701-7a8f-42a1-9ec6-3e5dd773e89b">
        <source>doCashOnlyValidation(_allProformaLines : ObjectSet input) : Boolean protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason

*/

vars
	result : Integer;
begin
	
	while true do
		//could of got warnings must clear this
		_allProformaLines.clear;
		app.myValUA.valCashCollectionForVVR(self.myBulkGateAgent.myRealVVR,true,true,_allProformaLines,app.myPassport);
		if not app.myPassport.trxCompletedOK then
			result := app.showErrorWarningDialog(app.getErrorString(Errors), app.myPassport, ErrWarnMode_AddUpdate+ ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
				result = IDOK then
				app.myPassport.warningsAcknowledged := true;
				continue;
			else
				return false;
			endif;
		endif;
		break;
	endwhile;
	
	return true;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_allProformaLines" type="ObjectSet" usage="input"/>
        <ReturnType type="Boolean"/>
