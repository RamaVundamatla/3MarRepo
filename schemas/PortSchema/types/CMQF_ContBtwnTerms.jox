<Class name="CMQF_ContBtwnTerms" id="f4d0d961-4d89-4aa0-8db4-e38723251b91">
    <superclass name="CMQF_Transactions"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="query"/>
    <PrimAttribute name="dateTimeFrom" id="9e581d0b-e015-4578-9bd4-8983b7f74f38">
        <embedded/>
        <type name="TimeStamp"/>
    </PrimAttribute>
    <PrimAttribute name="dateTimeTo" id="f01bec42-9a39-4e18-866f-92b8ec340bff">
        <embedded/>
        <type name="TimeStamp"/>
    </PrimAttribute>
    <ImplicitInverseRef name="fromTerminal" id="3a9daf74-366b-4b0c-9663-c07969942678">
        <embedded/>
        <type name="CM_Terminal"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="toTerminal" id="47d78aa2-95f4-472e-8cc7-4f4c38861e0c">
        <embedded/>
        <type name="CM_Terminal"/>
    </ImplicitInverseRef>
    <JadeMethod name="filterObjects" id="14e8e200-5074-40f3-91fc-87dfd4d48e73">
        <updating/>
        <source>filterObjects(_collection: Collection input; _passport: CM_Passport) updating;
//22 February 2010	cnwml2
/*

Date		Who		Reason
25/08/2010 	cnwdad1	Iterator was not being deleted.

*/

vars
	trans : CM_TITransaction;
	inter : CM_InterTerminalMove;
	terminal : CM_Terminal;
	breakOut : Boolean;
	
	expectedDT : TimeStamp;
	timeDiff : Integer;
	collection : CM_TITransactionByDateTypeDict;
	iterator : Iterator;
begin
	create collection transient;
	foreach terminal in self.allTerminals do
		collection.clear();
		terminal.getTITxnsForTypeAdvanced(	TRANS_TYPE_REL_ROAD_INTER_TERM,
											dateTimeFrom,
											dateTimeTo, 
											null, 
											self,
											collection);
												
		terminal.getTITxnsForTypeAdvanced(	TRANS_TYPE_REC_ROAD_INTER_TERM,
											dateTimeFrom,
											dateTimeTo, 
											null, 
											self,
											collection);
		iterator := collection.createIterator();

		while iterator.next(trans) do
			if self.checkStatusIncludesObject(trans, _passport, breakOut) then
				
				if self.dateTimeFrom &lt;&gt; null and self.dateTimeTo &lt;&gt; null then
					if not trans.dateTime &gt; dateTimeFrom and not trans.dateTime &lt; self.dateTimeTo then
						continue;
					endif;
				endif;
				
				if self.myOperator &lt;&gt; null then
					if not trans.myTrackedItem.myOperator = self.myOperator then
						continue;
					endif;
				endif;
				
				if self.fromTerminal &lt;&gt; null then
					if trans.isKindOf(CM_ReceiveRoadInterTerminal) then
						if not trans.myTrackedItem.myMoveCloneFromTI.myTerminal = self.fromTerminal then
							continue;
						endif;
					elseif trans.isKindOf(CM_ReleaseRoadInterTerminal) then
						if not trans.myTrackedItem.myTerminal = self.fromTerminal then
							continue;
						endif;
					endif;
				endif;
				
				if self.toTerminal &lt;&gt; null then
					if trans.isKindOf(CM_ReceiveRoadInterTerminal) then
						if not trans.myTrackedItem.myTerminal = self.toTerminal then
							continue;
						endif;
					elseif trans.isKindOf(CM_ReleaseRoadInterTerminal) then
						if not trans.myTrackedItem.myMoveCloneToTI.myTerminal = self.toTerminal then
							continue;
						endif;
					endif;
				endif;
				
				if not trans.myTrackedItem.myCargoType.id = TI_CargoType_Container then
					continue;
				endif;
				
			endif;
				
			if self.includesObject(trans, _passport, breakOut) then
				if not _collection.includes(inter) then
					_collection.add(trans);
				endif;
			endif;
		//	if breakOut then
		//		return;
		//	endif;
		endwhile;
		
		delete iterator;		// cnwdad1 25/08/2010.
	endforeach;
epilog
	delete iterator;		// cnwdad1 25/08/2010.
end;</source>
        <Parameter name="_collection" type="Collection" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="includesObject" id="d8eeb3f3-ce0a-4a6e-9fd0-c19a115cf1f7">
        <updating/>
        <source>includesObject(_trx: CM_Transaction; _passport: CM_Passport; _breakOut: Boolean output): Boolean updating, protected;
//23 February 2010	cnwml2


vars

begin
	return inheritMethod(_trx, _passport, _breakOut);

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_trx" type="CM_Transaction"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <Parameter name="_breakOut" type="Boolean" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
