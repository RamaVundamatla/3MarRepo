    <JadeMethod name="btnOk_click" id="5a04ba65-7038-4391-9ec8-4773ab1415ff">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnOk_click(btn: Button input) updating;
// --------------------------------------------------------------------------------
// Created:		30 January 1999 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.statusMsg('Updating object selection criteria...');

	if self.formValidate() then
		self.formUpdate();
		modalResult	:=	1;
		unloadForm();
	endif;
epilog
	self.statusMsg('');
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnRemove_click" id="b9d954a9-5a32-4f3a-b06e-a7d4e7282f2a">
