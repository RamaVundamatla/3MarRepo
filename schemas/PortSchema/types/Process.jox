    <JadeMethod name="isSarge" id="cbaed10e-d806-4b26-a196-0d3ef9e1d61c">
        <source>isSarge() : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 January 2024	jlirs1	Initial creation

*/

vars
	user : CM_User;	
begin

	executeWhen JMTDevelopmentEnvironment;
	
	// JMT
	if app.myPassport &lt;&gt; null then
		user := app.myPassport.myUser;
		
		if user &lt;&gt; null and
		  (user.code.toUpper = "CNWRS1" or user.code.toUpper = "JLGRS1" or user.code.toUpper = "JLIRS1" or user.code.toUpper = "SARGE") and
		  user.userName.toUpper = "SARGE" then
			return true;
		endif;
	endif;
	
	endExecuteWhen;
	
	return false;
end;</source>
