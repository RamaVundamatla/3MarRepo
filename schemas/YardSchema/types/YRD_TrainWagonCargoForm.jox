    <JadeMethod name="setDefaultCargoPosition" id="5c326b47-bdfb-493b-9faf-45a0d2664e89">
        <source>setDefaultCargoPosition() protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 August 2009	cnwndl1	Initial creation

*/

vars
	controller : CM_WagonController;
begin
	if self.myTerminal.getConfig( RailDefaultWCIdFormat ).Integer = Rail_UPSP_Int then
		self.cmbCargoPosition.listIndex := 1;
		return;
	endif;
	if self.myCurrentWagon &lt;&gt; null then
		if self.myCurrentWagon.isBoxcarVisit then
			self.cmbCargoPosition.listIndex := 1;
		endif;
		//foreach controller in self.myCurrentWagon.allLocationsControllers do
		foreach controller in self.myCurrentWagon.allLocationsControllersArray discreteLock do	//04 Dec 2014	NDL	Par 35345
			if controller.allTrackedItems.isEmpty then
				self.cmbCargoPosition.listObject := controller;
				break;
			endif;
		endforeach;
	endif;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setDefaults" id="18980ccd-e023-4375-87c0-46c3d8a0413e">
        <source>setDefaults() protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 July 2009	cnwmd1	Initial creation

*/

vars
	idx : Integer;
begin
	self.cmbWagon.listObject := self.myCurrentWagon;
	self.cmbWagon.click(self.cmbWagon);
	self.setDefaultCargoPosition();

	if self.myCurrentWagon &lt;&gt; null and ( self.myCurrentWagon.isFlatcar or self.myCurrentWagon.isWellcarVisit ) then	//25 Mar 2013	NDL	Par 31278
		//self.cmbCargoType.listObject := app.myPassport.getDefaultCargoBOLType();
		self.cmbCargoType.listIndex := self.cmbCargoType.findObject( app.myPassport.getDefaultCargoBOLType() );	//10 Sep 2015	NDL	Par 36390
		self.cmbCargoType.click(self.cmbCargoType);
	endif;
	
	if self.myCurrentTI &lt;&gt; null then
		if self.cmbCargoID.findObject(self.myCurrentTI) &gt; 0 then
			self.cmbCargoID.listObject := self.myCurrentTI;
		else
			self.cmbCargoID.addItemObject(self.myCurrentTI.id, self.myCurrentTI);
			self.cmbCargoID.listObject := self.myCurrentTI;
		endif;
		
		if self.myCurrentWagon &lt;&gt; null then
			idx := self.myCurrentWagon.getTIWagonPosition(self.myCurrentTI, REAL_MODE);
			
			if idx &gt; 0 and idx &lt;= self.cmbCargoPosition.listCount() then
				self.cmbCargoPosition.listIndex := idx;
			endif;
		endif;	
		
		self.btnAddCargo.enabled := false;
	endif;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setEmptyWagonPositions" id="bb664eaa-c839-4c8f-92f4-61a8f66e1cd0">
        <updating/>
        <source>setEmptyWagonPositions(_theWagonContainers : CMIF_TIWagonPositionArray input; _wagonPositions : CMIF_TIWagonPositionArray input) updating, protected;
//-----------------------------------------
//Created: April 2003 By: cnwgd1
//-----------------------------------------

//cnwmd1, CCMS 1067, Par 19913 Method copied from YRD_WagonForm and modified to suit
vars
	wagonLength,
	pos : Integer;
	found : Boolean;
	wagonPosition : CMIF_TIWagonPosition;
	wagonClass : CM_WagonClass;
begin
	wagonClass := self.myCurrentWagon.myWagonClass;
	if wagonClass = null then
		return;
	endif;
	
	wagonLength := wagonClass.getLenInUnits;
	
	foreach pos in 1 to wagonLength do
		found := false;
		foreach wagonPosition in _wagonPositions do
			if wagonPosition.position = pos then
				found := true;
				break;
			endif;
		endforeach;
		
		if found then
			continue;
		endif;
		
		create wagonPosition transient;
		_theWagonContainers.add(wagonPosition);
		wagonPosition.myRailLine := self.myCurrentWagon.myRailLine;
		wagonPosition.position := pos;
		wagonPosition.available := self.myCurrentWagon.allLocationsControllersArray[pos].isAvailable;//self.controllerAvailable[pos];
		wagonPosition.hasTwistLocks := self.myCurrentWagon.allLocationsControllersArray[pos].hasTwistlocks; //self.controllerHasTLs[pos];
		wagonPosition.twistLocksAreUp := self.myCurrentWagon.allLocationsControllersArray[pos].twistlocksAreUp; //self.controllerTLUp[pos];
	endforeach;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_theWagonContainers" type="CMIF_TIWagonPositionArray" usage="input"/>
        <Parameter name="_wagonPositions" type="CMIF_TIWagonPositionArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="e50d84ab-0c3a-43f6-9187-3eb75263a741">
        <updating/>
        <source>setupForm() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 July 2009	cnwmd1	Initial creation

*/

vars

begin
	inheritMethod();
	
	self.centreOverParent(100);
	self.buildComboTrain();
	self.buildComboCargoType();
	
	//self.doCargoDisplay(); //- cnwmd1, Par 22812 No need to do here, done further on.  Also in update mode not showing the current item.
	
	self.addToolbarControls();

	if self.mode = self.Mode_Update then //Either Updating or Adding items
		self.doCargoEdit();
	elseif self.mode = self.Mode_Add then
		self.doCargoAdd();
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="d7c4d420-bd65-40ea-a33e-1b8c6fb12fec">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0012715, locale);
	btnAddCargo.translateCaption(Xlat_0012716, locale);
	btnEditCargo.translateBubbleHelp(Xlat_0012717, locale);
	btnEditCargo.translateCaption(Xlat_0012718, locale);
	btnNewCargo.translateBubbleHelp(Xlat_0012719, locale);
	btnNewCargo.translateCaption(Xlat_0012720, locale);
	btnNextCargo.translateCaption(Xlat_0012721, locale);
	grpDetails.translateCaption(Xlat_0012722, locale);
	lblCargoDetail.translateCaption(Xlat_0012723, locale);
	lblCargoID.translateCaption(Xlat_0012724, locale);
	lblCargoPosition.translateCaption(Xlat_0012725, locale);
	lblCargoType.translateCaption(Xlat_0012726, locale);
	lblTrain.translateCaption(Xlat_0012727, locale);
	lblWagon.translateCaption(Xlat_0012728, locale);
	mnuCargoEdit.translateCaption(Xlat_0012729, locale);
	mnuCargoEnquiry.translateCaption(Xlat_0012730, locale);
	mnuColumnOrganiser.translateCaption(Xlat_0012731, locale);
	mnuContext.translateCaption(Xlat_0012732, locale);
	mnuInspectObject.translateCaption(Xlat_0012733, locale);
end;</source>
    </JadeMethod>
</GUIClass>
