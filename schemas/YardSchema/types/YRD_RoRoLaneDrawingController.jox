    <JadeMethod name="drawCurrentObject" id="4eb90d42-c6c3-4744-ba23-56333f700f43">
        <updating/>
        <source>drawCurrentObject(_frame: CMUI_GridAreaDrawingFrame input) updating;
// ---------------------------------------------------------------------------
// Created:		December 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	theTI 		: CM_TrackedItem;
	frame		: CMUI_GridAreaDrawingFrame;
	fx1, fy1 	: Real;
begin

	if self.myCurrentObject.isKindOf(CM_RoRoController) then
				
		if self.flipHorizontal then
			fx1 := self.x2;
			fx1 := self.flipPointX(self.taXPos, self.myTerminalArea.CM_RoRoLaneArea.getGLVDrawWidthInPixels(self.scaleFactor), fx1);
		else
			fx1 := self.x1;
		endif;
	
		fy1 := self.y1;

			
		self.drawRoRoLane(fx1.Integer, fy1.Integer, self.myCurrentObject.CM_RoRoController, self.flipHorizontal, self.flipVertically, self.myTerminalArea, self.taXPos, self.taYPos);
	elseif self.myCurrentObject.isKindOf(CM_TrackedItem) then
	
		theTI := self.myCurrentObject.CM_TrackedItem;
		self.drawTI(theTI, null, self.x1, self.y1, self.x2, self.y2,self.myDrawingFrame, null);	// cnwjk3 PAR 23875 23/04/10
	endif;

end;</source>
        <Parameter name="_frame" type="CMUI_GridAreaDrawingFrame" usage="input"/>
    </JadeMethod>
    <JadeMethod name="drawDoubleArrowLine" id="e8e26964-8624-4886-ad8f-37b13a4fb956">
        <source>drawDoubleArrowLine(_x1, _y1, _x2, _y2 : Real; _colour : Integer;_frame : CMUI_Frame) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
07 December 2009	cnwjk3	Initial creation

*/

vars

begin
	_frame.drawLine(_x1, _y1, _x2, _y2, _colour);
	_frame.drawLine(_x1, _y1, _x1 + self.ARROW_XOFFSET, _y1 - self.ARROW_YOFFSET, _colour);
	_frame.drawLine(_x1, _y1, _x1 + self.ARROW_XOFFSET, _y1 + self.ARROW_YOFFSET, _colour);
	_frame.drawLine(_x2 - self.ARROW_XOFFSET, _y1 - self.ARROW_YOFFSET, _x2, _y1, _colour);
	_frame.drawLine(_x2 - self.ARROW_XOFFSET, _y1 + self.ARROW_YOFFSET, _x2, _y1, _colour);
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_x1" type="Real"/>
        <Parameter name="_y1" type="Real"/>
        <Parameter name="_x2" type="Real"/>
        <Parameter name="_y2" type="Real"/>
        <Parameter name="_colour" type="Integer"/>
        <Parameter name="_frame" type="CMUI_Frame"/>
    </JadeMethod>
    <JadeMethod name="drawFMLetterGraphic" id="3b58c8a7-f559-46f2-800d-997ff4cc61af">
        <source>drawFMLetterGraphic(_frame: CMUI_GridAreaDrawingFrame; _theLetter: String; _theX1: Real; _theY1: Real; _theX2: Real; _theY2: Real; _backColour: Integer);
// ---------------------------------------------------------------------------
// Created:     25 August 2004 by cnwrs2
//
// Purpose:     PAR 19468 NEW
// ---------------------------------------------------------------------------
// ---- WHO --- WHEN ----- WHY---------------------------------------------
// ---------------------------------------------------------------------------
// ---------------------------------------------------------------------------
vars
	theFrame	: CMUI_GridAreaDrawingFrame;
	xOffset, yOffset,yOffsetFnt,xOffsetFnt,xWidth, theFillColour : Integer;
	aReal : Real;
	aGridAttribute : CMIF_GridAttributes;
	theLetter : String;
begin

	theFrame := _frame;
	if _backColour = NullColour then
		if self.myLocationsController.hasPower() then 
			theFillColour := self.POWER_FILL_COLOUR;
		else
			theFillColour := Gray;
			if self.myLocationsController.isOverhang() then
				theFillColour := theFrame.backColor;
			endif;
		endif;
	else
		theFillColour := _backColour;
	endif;
	
	theFrame.drawTextAlign := Frame.DrawTextAlign_Center;
	theLetter := _theLetter.trimBlanks;
	theFrame.drawFillColor := theFillColour;

	theFrame.drawFontName := "Arial";
	theFrame.drawStyle := Frame.DrawStyle_Solid;
	theFrame.drawFilledRectangle(_theX1, _theY1, _theX2, _theY2,  Black);

	theFrame.drawWidth := 2;
	xWidth := 0;
	
	if self.scaleFactor = .5 then
		xWidth := 4;
		theFrame.drawWidth := 1;
		xOffset := 2;
		yOffset := 3;
		//yOffsetFnt := -1;
		yOffsetFnt := -1;

		if theLetter.length = 1 then
			xOffsetFnt := 7;
		else
			xOffsetFnt := 4;
		endif;
		theFrame.drawFontSize := 6;
		theFrame.drawFontBold := false;
	elseif self.scaleFactor = .75 then
		xWidth := 4;
		theFrame.drawWidth := 1;
		xOffset := 2;
		yOffset := 3;
		//yOffsetFnt := -1;
		yOffsetFnt := 2;

		if theLetter.length = 1 then
			xOffsetFnt := 7;
		else
			xOffsetFnt := 4;
		endif;
		theFrame.drawFontSize := 6;
		theFrame.drawFontBold := false;
	elseif self.scaleFactor = 1 then
		xWidth := 4;
		theFrame.drawWidth := 1;
		xOffset := 2;
		yOffset :=3;
		yOffsetFnt := 3;

		if theLetter.length = 1 then
			xOffsetFnt := 7;
		else
			xOffsetFnt := 4;
		endif;
		theFrame.drawFontSize := 8;
		theFrame.drawFontBold := true;
	elseif self.scaleFactor = 1.5 then
		xWidth := 4;
		theFrame.drawWidth := 1;
		xOffset := 2;
		yOffset :=6;
		yOffsetFnt := 8;
		if theLetter.length = 1 then
			xOffsetFnt := 10;
		else
			xOffsetFnt := 3;
		endif;
		theFrame.drawFontSize := 10;
		theFrame.drawFontBold := true;
	elseif self.scaleFactor = 2 then
		xWidth := 6;
		xOffset := 2;
		yOffset := 8;
		yOffsetFnt := 10;
		if theLetter.length = 1 then
			xOffsetFnt := 14;
		else
			xOffsetFnt := 8;
		endif;
		theFrame.drawFontSize := 16;
	elseif self.scaleFactor = 3 then
		xWidth := 8;
		xOffset := 6;
		yOffset := 12;
		yOffsetFnt := 0;
		theFrame.drawFontSize := 24;
		if theLetter.length = 1 then
			xOffsetFnt := 22;
		else
			xOffsetFnt := 11;
		endif;
	elseif self.scaleFactor = 4 then
		xWidth := 10;
		xOffset := 8;
		yOffset := 15;
		yOffsetFnt := 0;
		if theLetter.length = 1 then
			xOffsetFnt := 30;
		else
			xOffsetFnt := 15;
		endif;
		theFrame.drawFontSize := 32;
	endif;
	theFrame.drawStyle := Frame.DrawStyle_Solid;
	theFrame.drawFillColor := White;

	aReal :=  _theX1 + ((_theX2 - _theX1) / 2);
	xOffsetFnt := aReal.Integer;

	theFrame.drawFilledRectangle(_theX1 + xOffset, _theY1 + yOffset, _theX2 - xOffset, _theY2 - yOffset,  Black);
	theFrame.drawTextAt(theLetter, xOffsetFnt, _theY1 + yOffsetFnt, Black); 
epilog
	theFrame.drawWidth := 1;
	theFrame.drawFontBold := false;

end;</source>
        <Parameter name="_frame" type="CMUI_GridAreaDrawingFrame"/>
        <Parameter name="_theLetter" type="String"/>
        <Parameter name="_theX1" type="Real"/>
        <Parameter name="_theY1" type="Real"/>
        <Parameter name="_theX2" type="Real"/>
        <Parameter name="_theY2" type="Real"/>
        <Parameter name="_backColour" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="drawFreeSpaceMetricsForLane" id="950bc0fc-30ea-421a-a06a-9807eca8cf64">
        <source>drawFreeSpaceMetricsForLane(_lc : CM_RoRoController; _x, _y : Real;  _flipHorizontal : Boolean; _tx, _ty, _taDrawWidth : Real) protected;

/*

Purpose:			

Parameters:			
		_x				: X pos of lane start (un-scaled)
		_y				: Y pos of lane start (un-scaled)
		_tx				: X pos of terminal area
		_ty				: Y pos of terminal area
		_taDrawWidth	: width of terminal area (scaled)
Return Value:		


Date		Who		Reason
07 December 2009	cnwjk3	Initial creation

*/
vars
	freedLength,
	startOffset,
	usedLength,
	laneLength,
	laneWidth,
	fx1, fx2,
	fy1, fy2,
	tix1, tiy1,
	tix2, tiy2		: Real;
begin
	if _lc.spareLength = 0 then
		return;
	endif;
	
	self.myDrawingFrame.drawWidth := 1;
	startOffset := _lc.startOffset * _lc.myRoRoLaneArea.GLV_RORO_PIXELS_PER_METRE * self.scaleFactor;
	freedLength := _lc.freedLength * _lc.myRoRoLaneArea.GLV_RORO_PIXELS_PER_METRE * self.scaleFactor;
	laneLength := _lc.getGLVDrawLengthInPixels(self.scaleFactor);
	usedLength := _lc.getGLVDrawUsedLengthInPixels(self.scaleFactor);
	laneWidth := self.getLaneHeight;
	
	tix1 := _x;

	// Adjust start x for first TI based on the lane startOffset
	tix1 := tix1 + startOffset;
	tix1 := tix1 + usedLength;
	tix1 := tix1 + freedLength;
	
	//tix2 := tix1 + laneLength - usedLength - freedLength;  
	tix2 := tix1 + laneLength - usedLength - freedLength - startOffset;  
	
	tiy1 := _y + laneWidth-1 + self.TI_METRIC_OFFSET;
	tiy2 := tiy1;
		
	fx1 := tix1;
	fx2 := tix2;
	fy1 := tiy1;
	fy2 := tiy2;

	// If we need to draw right-to-left then we can just flip the TI x points
	// relative to the lane length.
	if _lc.isDrawRightToLeft()then		
		fx1 := self.flipPointX(_x + startOffset, laneLength - startOffset, fx1);
		fx2 := self.flipPointX(_x + startOffset, laneLength - startOffset, fx2);
	endif;
	
	if _flipHorizontal then
		fx1 := self.flipPointX(_tx, _taDrawWidth, fx1)-1;  
		fx2 := self.flipPointX(_tx, _taDrawWidth, fx2)-1;  
	endif;
	
	self.normaliseRealRectanglePoints(fx1, fy1, fx2, fy2);
	self.drawDoubleArrowLine(fx1, fy1, fx2, fy2, Black, self.myDrawingFrame);
	
	// Draw actual measurement
	self.drawMetricLabel(fx1, fy1, fx2, _lc.getSpareLength().roundedTo(1).String);
	
epilog
end;</source>
        <access>protected</access>
        <Parameter name="_lc" type="CM_RoRoController"/>
        <Parameter name="_x" type="Real"/>
        <Parameter name="_y" type="Real"/>
        <Parameter name="_flipHorizontal" type="Boolean"/>
        <Parameter name="_tx" type="Real"/>
        <Parameter name="_ty" type="Real"/>
        <Parameter name="_taDrawWidth" type="Real"/>
    </JadeMethod>
    <JadeMethod name="drawFreedUpSpaceMetricsForLane" id="3b26c2dd-b9d5-4034-b407-ba97303380bf">
        <source>drawFreedUpSpaceMetricsForLane(_lc : CM_RoRoController; _x, _y : Real;  _flipHorizontal : Boolean; _tx, _ty, _taDrawWidth : Real) protected;

/*

Purpose:			
		Draws metrics for space that has been created by moving TI's out the front of the lane
Parameters:			
		_x				: X pos of lane start (un-scaled)
		_y				: Y pos of lane start (un-scaled)
		_tx				: X pos of terminal area
		_ty				: Y pos of terminal area
		_taDrawWidth	: width of terminal area (scaled)
Return Value:		


Date		Who		Reason
07 December 2009	cnwjk3	Initial creation

*/
vars
	laneLength,
	freedLength,
	startOffset,
	laneWidth,
	fx1, fx2,
	fy1, fy2 : Real;
begin	
	if _lc.freedLength = 0 then
		return;
	endif;
	
	self.myDrawingFrame.drawWidth := 1;
	startOffset := _lc.startOffset * _lc.myRoRoLaneArea.GLV_RORO_PIXELS_PER_METRE * self.scaleFactor;
	freedLength := _lc.freedLength * _lc.myRoRoLaneArea.GLV_RORO_PIXELS_PER_METRE * self.scaleFactor;
	laneLength := _lc.getGLVDrawLengthInPixels(self.scaleFactor);
	laneWidth :=self.getLaneHeight;
	
	fx1 := _x + startOffset;
	fx2 := fx1 + freedLength;
	fy1 := _y + laneWidth/2;
	fy2 := fy1;
			
	// If we need to draw right-to-left then we can just flip the TI x points
	// relative to the lane length.
	if _lc.isDrawRightToLeft()then
		fx1 := self.flipPointX(_x + startOffset, laneLength - startOffset, fx1);
		fx2 := self.flipPointX(_x + startOffset, laneLength - startOffset, fx2);
	endif;
	
	if _flipHorizontal then
		fx1 := self.flipPointX(_tx, _taDrawWidth, fx1)-1;  
		fx2 := self.flipPointX(_tx, _taDrawWidth, fx2)-1;  
	endif;
	
	self.normaliseRealRectanglePoints(fx1, fy1, fx2, fy2);
	self.drawDoubleArrowLine(fx1, fy1, fx2, fy2, Red, self.myDrawingFrame);
	
	// Draw actual measurement
	self.drawMetricLabel(fx1, fy1, fx2, _lc.freedLength.roundedTo(1).String);
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_lc" type="CM_RoRoController"/>
        <Parameter name="_x" type="Real"/>
        <Parameter name="_y" type="Real"/>
        <Parameter name="_flipHorizontal" type="Boolean"/>
        <Parameter name="_tx" type="Real"/>
        <Parameter name="_ty" type="Real"/>
        <Parameter name="_taDrawWidth" type="Real"/>
    </JadeMethod>
    <JadeMethod name="drawLeftArrowLine" id="374f33de-f4fd-41e4-8a19-aa70c97c97ee">
        <source>drawLeftArrowLine(_x1, _y1, _x2, _y2 : Real; _colour : Integer; _frame : CMUI_Frame) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
07 December 2009	cnwjk3	Initial creation

*/

constants
	XOFFSET = 4;
	YOFFSET = 2;
vars

begin
	_frame.drawLine(_x1, _y1, _x2, _y2, _colour);
	_frame.drawLine(_x1, _y1, _x1 + XOFFSET, _y1 - YOFFSET, _colour);
	_frame.drawLine(_x1, _y1, _x1 + XOFFSET, _y1 + YOFFSET, _colour);
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_x1" type="Real"/>
        <Parameter name="_y1" type="Real"/>
        <Parameter name="_x2" type="Real"/>
        <Parameter name="_y2" type="Real"/>
        <Parameter name="_colour" type="Integer"/>
        <Parameter name="_frame" type="CMUI_Frame"/>
    </JadeMethod>
    <JadeMethod name="drawMetricLabel" id="78eedfdf-d42d-4f25-8011-456567ceb6c2">
        <source>drawMetricLabel(_x1, _y1, _x2 : Real; _label : String) protected;

/*

Purpose:			
	Draw a metric label in the middle of a double-headed metric arrow
Parameters:			
	_x1, _x2, y1 : position of metric arrow
Return Value:		


Date		Who		Reason
08 December 2009	cnwjk3	Initial creation

*/
constants
	MAGIC_NUMBER = 8;
vars
	lx1, ly1,
	labelWidth	: Real;
begin
	self.myDrawingFrame.drawTextAlign := Frame.DrawTextAlign_Center;	
	self.myDrawingFrame.drawFontSize := self.getMetricFontSize();
	self.myDrawingFrame.drawFontBold := false;

	
	labelWidth := self.myDrawingFrame.drawTextWidth(_label);
	lx1 := _x1 + (((_x2 - _x1) - labelWidth) / 2) + MAGIC_NUMBER;

	ly1 := _y1-1;
	
	if _label.length() = 1 then
		lx1 := lx1 - 4 * self.scaleFactor;
	endif;
	
	// draw the label
	self.myDrawingFrame.drawTextAt(_label, lx1, ly1, Black);
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_x1" type="Real"/>
        <Parameter name="_y1" type="Real"/>
        <Parameter name="_x2" type="Real"/>
        <Parameter name="_label" type="String"/>
    </JadeMethod>
    <JadeMethod name="drawObject" id="ca578a04-0bfb-4d71-a2f9-90fc979e05a6">
        <updating/>
        <source>drawObject(_frame : CMUI_GridAreaDrawingFrame input; _obj: Object) updating;
// ---------------------------------------------------------------------------
// Created:		09 December 2005  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	points : PointArray;
begin
	if _obj = null then
		return;
	endif;
	
	points := self.allDrawnObjects.getPolygonForObject(_obj);
	if points = null then
		app.writeStatement( "AKB " &amp; self.class.name &amp; "::" &amp; method.name &amp; " 1. could not find object " &amp; _obj.String &amp; ". Cannot draw");
		return;
	endif;
	
	self.myDrawingFrame.drawRoRoObjectAtPolygon(_obj, points, self);

end;</source>
        <Parameter name="_frame" type="CMUI_GridAreaDrawingFrame" usage="input"/>
        <Parameter name="_obj" type="Object"/>
    </JadeMethod>
    <JadeMethod name="drawOffsetMetricsForLane" id="d837d6f8-30b7-40d4-9b70-ffe9af095ebc">
        <source>drawOffsetMetricsForLane(_lc : CM_RoRoController; _x, _y : Real; _flipHorizontal : Boolean; _tx, _ty, _taDrawWidth : Real) protected;

/*

Purpose:			

Parameters:			
		_x				: X pos of lane start (un-scaled)
		_y				: Y pos of lane start (un-scaled)
		_tx				: X pos of terminal area
		_ty				: Y pos of terminal area
		_taDrawWidth	: width of terminal area (scaled)

Return Value:		


Date		Who		Reason
07 December 2009	cnwjk3	Initial creation

*/

vars
	startOffset,
	laneWidth,
	sx1, sy1,
	sx2, sy2	: Real;
begin
	if _lc.startOffset &lt;= 1 then // No point trying to draw the label as it won't fit.
		return;
	endif;

	self.myDrawingFrame.drawWidth := 1;
	laneWidth := self.getLaneHeight; 
	
	startOffset := _lc.getGLVDrawStartOffsetInPixels(self.scaleFactor);
	
	// Clear the rectangle that we are going to draw in (needed when drawing frmo notes)\
	self.clearStartOffsetLabels(_x, _y, laneWidth, startOffset, _flipHorizontal, _tx, _ty, _taDrawWidth);
	
	sx1 := _x;
	sx2 := sx1 + startOffset;
	sy1 := _y + (laneWidth/2);
	sy2 := sy1;	

	if _flipHorizontal then
		sx1 := self.flipPointX(_tx, _taDrawWidth, sx1);  
		sx2 := self.flipPointX(_tx, _taDrawWidth, sx2);  
	endif;

	self.normaliseRealRectanglePoints(sx1, sy1, sx2, sy2);
		
	self.drawDoubleArrowLine(sx1, sy1, sx2, sy2, Black, self.myDrawingFrame);
	
	// Draw actual measurement
	self.drawMetricLabel(sx1, sy1, sx2, _lc.startOffset.roundedTo(1).String);
epilog
end;</source>
        <access>protected</access>
        <Parameter name="_lc" type="CM_RoRoController"/>
        <Parameter name="_x" type="Real"/>
        <Parameter name="_y" type="Real"/>
        <Parameter name="_flipHorizontal" type="Boolean"/>
        <Parameter name="_tx" type="Real"/>
        <Parameter name="_ty" type="Real"/>
        <Parameter name="_taDrawWidth" type="Real"/>
    </JadeMethod>
    <JadeMethod name="drawOverQueuedPlannedLine" id="a56b1a57-f3f2-4037-b32e-2cdf92344dbe">
        <source>drawOverQueuedPlannedLine(_x1, _y1, _x2, _y2 : Real; _width, _colour : Integer; _flippedHorizontal : Boolean ) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
12 January 2010	cnwjk3	Initial creation

*/

vars

begin
	self.myDrawingFrame.drawWidth := _width;
	self.myDrawingFrame.drawLine(_x1, _y1, _x2, _y2, _colour);
	
	if _flippedHorizontal then
		self.myDrawingFrame.drawLine(_x1, _y1, _x1-3, _y1+3, _colour);
		self.myDrawingFrame.drawLine(_x1, _y2-1, _x1-3, _y2-3, _colour);
	else
		self.myDrawingFrame.drawLine(_x1, _y1, _x1+3, _y1+3, _colour);
		self.myDrawingFrame.drawLine(_x1, _y2-1, _x1+3, _y2-3, _colour);	
	endif;
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_x1" type="Real"/>
        <Parameter name="_y1" type="Real"/>
        <Parameter name="_x2" type="Real"/>
        <Parameter name="_y2" type="Real"/>
        <Parameter name="_width" type="Integer"/>
        <Parameter name="_colour" type="Integer"/>
        <Parameter name="_flippedHorizontal" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="drawPositionLabel" id="e88c15b1-30dc-437c-8ceb-5ed84768260c">
        <source>drawPositionLabel(_x1, _y1, _x2 : Real; _label : String ) protected;

/*

Purpose:			
	Draw a metric label in the middle of a double-headed metric arrow
Parameters:			
	_x1, _x2, y1, y2 : position of TI
Return Value:		


Date		Who		Reason
08 December 2009	cnwjk3	Initial creation

*/
constants
	MAGIC_NUMBER = 8;
vars
	lx1, ly1,
	labelWidth	: Real;
begin
	self.myDrawingFrame.drawTextAlign := Frame.DrawTextAlign_Center;	
	self.myDrawingFrame.drawFontSize := self.getMetricFontSize();
	self.myDrawingFrame.drawFontBold := false;

	
	labelWidth := self.myDrawingFrame.drawTextWidth(_label);
	lx1 := _x1 + (((_x2 - _x1) - labelWidth) / 2) + MAGIC_NUMBER;
	ly1 := _y1 - self.getMetricFontSize() - 4;
	
	// draw the label
	self.myDrawingFrame.drawTextAt(_label, lx1, ly1, Black);
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_x1" type="Real"/>
        <Parameter name="_y1" type="Real"/>
        <Parameter name="_x2" type="Real"/>
        <Parameter name="_label" type="String"/>
    </JadeMethod>
    <JadeMethod name="drawRightArrowLine" id="420498f7-f218-4e75-b946-79a2312adf18">
        <source>drawRightArrowLine(_x1, _y1, _x2, _y2 : Real; _colour : Integer; _frame : CMUI_Frame) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
07 December 2009	cnwjk3	Initial creation

*/

constants
	XOFFSET = 4;
	YOFFSET = 2;
vars

begin
	_frame.drawLine(_x1, _y1, _x2, _y2, _colour);
	_frame.drawLine(_x2 - XOFFSET, _y1 - YOFFSET, _x2, _y1, _colour);
	_frame.drawLine(_x2 - XOFFSET, _y1 + YOFFSET, _x2, _y1, _colour);
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_x1" type="Real"/>
        <Parameter name="_y1" type="Real"/>
        <Parameter name="_x2" type="Real"/>
        <Parameter name="_y2" type="Real"/>
        <Parameter name="_colour" type="Integer"/>
        <Parameter name="_frame" type="CMUI_Frame"/>
    </JadeMethod>
    <JadeMethod name="drawRoRoDirectionLabels" id="9800ed36-115e-4b47-ac4b-d15273774ac5">
        <source>drawRoRoDirectionLabels(_x, _y : Integer; _ta : CM_RoRoLaneArea; _flipHorizontal, _flipVertical : Boolean) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 December 2009	cnwjk3	Initial creation

*/
constants
	PADDING = 4;
vars
	label,
	rightLabel,
	leftLabel	: String;
	lane 		: CM_RoRoController;
	taDrawHeight,
	drawWidth,
	laneWidth,
	fontSize	: Real;
	laneNum,
	lx, ly,
	tmpFrame	: CMUI_Frame;
begin
	tmpFrame := self.myDockBar.myScrollableFrame.myTopLeftFillerFrame;
	tmpFrame.visible := true;
	tmpFrame.drawFontSize := self.RORO_DIRECTION_FONT_SIZE;
	tmpFrame.drawFontBold := true;
	self.drawLeftArrowLine(_x, _y, _x + self.RORO_DIRECTION_ARROW_LEN, _y, Red, tmpFrame);	
	
	if _flipHorizontal then
		leftLabel 	:= _ta.rightLabel;
		rightLabel 	:= _ta.leftLabel;
	else
		leftLabel 	:= _ta.leftLabel;
		rightLabel 	:= _ta.rightLabel;	
	endif;
	
	label := leftLabel &amp; " - " &amp; rightLabel;
	
	drawWidth := tmpFrame.drawTextWidth(label);
	
	self.drawRightArrowLine(_x + self.RORO_DIRECTION_ARROW_LEN + drawWidth + PADDING * 2, _y, drawWidth + 2 * (self.RORO_DIRECTION_ARROW_LEN + PADDING), _y, Red, tmpFrame);	
	
	tmpFrame.drawTextAt(label, self.RORO_DIRECTION_ARROW_LEN + PADDING, 8, Black);
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_x" type="Integer"/>
        <Parameter name="_y" type="Integer"/>
        <Parameter name="_ta" type="CM_RoRoLaneArea"/>
        <Parameter name="_flipHorizontal" type="Boolean"/>
        <Parameter name="_flipVertical" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="drawRoRoLane" id="0be2a689-8d68-418d-9e0d-ef7d9b176886">
        <updating/>
        <source>drawRoRoLane(_x, _y : Integer; _lc : CM_RoRoController; _flipHorizontal, _flipVertical : Boolean; _ta : CM_RoRoLaneArea; _tx, _ty : Real) : Integer updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
07 December 2009	cnwjk3	Initial creation

*/

vars
	startOffset,
	taDrawWidth,
	fx1, fy1, fx2, fy2,
	x1, y1, x2, y2 	
	,laneHeight: Real;
	yaHeight,
	heightUsed				: Integer;
	laneExceeded			: CMIF_RoRoLaneLenExceeded;
begin 
	startOffset := _lc.startOffset * _lc.myRoRoLaneArea.GLV_RORO_PIXELS_PER_METRE * self.scaleFactor;
	taDrawWidth := _ta.getGLVDrawWidthInPixels(self.scaleFactor);

	// Form the rectangle for this lane
	x1 := _x + _lc.getGLVDrawStartOffsetInPixels(self.scaleFactor);
	y1 := _y;

	x2 := x1 + _lc.getGLVDrawLengthInPixels(self.scaleFactor) - startOffset;
	y2:=_y + self.getLaneHeight;
	
	if _flipHorizontal then
		fx1 := self.flipPointX(_tx, taDrawWidth, x1);
		fx2 := self.flipPointX(_tx, taDrawWidth, x2);		
	else
		fx1 := x1;
		fx2 := x2;
	endif;

	fy1 := y1;
	fy2 := y2;
	
	self.normaliseRealRectanglePoints(fx1, fy1, fx2, fy2);
	
	self.myDrawingFrame.drawStyle := Frame.DrawStyle_Solid;
	self.myDrawingFrame.drawFillStyle := Frame.DrawFillStyle_Solid;
	self.myDrawingFrame.drawFillColor := Gray;
	self.myDrawingFrame.drawFontBold := false;
	
	// Remove any objects sitting within the LC rectangle from the drawing dict.
	// This is needed when drawing from notes and you re-drawing a lane which has had something moved
	// out of it  (otherwise the item that has moved will still be sitting in the collection at the old position)
	if not self.isDrawFromAreaSelect then
		self.allDrawnObjects.removeObjectsInDict(fx1.Integer, fy1.Integer, fx2.Integer, fy2.Integer);
	endif;
	
	// Draw the LC
	if not self.isDrawFromAreaSelect then
		self.myDrawingFrame.drawSolidRectangle(fx1, fy1,fx2, fy2, Gray);
	endif;
	
	// Draw free up space metrics  (from TIs moving out of the lane front)
	self.drawFreedUpSpaceMetricsForLane(_lc, _x, _y, _flipHorizontal, _tx, _ty, taDrawWidth);
	
	// Record the positions of the location controller
	self.addToDrawnObjects(fx1.Integer, fy1.Integer, fx2.Integer, fy2.Integer, _lc);

	// Draw the TIS
	self.drawTIsForLane(_lc, _x, _y, _flipHorizontal, _tx, _ty, taDrawWidth);
	
	// Draw TI measurements  (need to do this one first, as it clears space on the screen)
	self.drawTIMetricsForLane(_lc, _x, _y, _flipHorizontal, _tx, _ty, taDrawWidth);
	
	// Draw start offset metrics
	self.drawOffsetMetricsForLane(_lc, _x, _y, _flipHorizontal, _tx, _ty, taDrawWidth); 
	
		
	// Draw the Yard Allocation Lines
	if not self.allYARows.includes( _lc ) then
		yaHeight := self.drawYardAllocationLinesForRow( _lc, fx1.Integer, fy1.Integer, fx2.Integer, fy2.Integer);
	endif;	
	
	
	if not _lc.isOverQueuedPlanned() then
		// Draw free space metrics
		self.drawFreeSpaceMetricsForLane(_lc, _x, _y, _flipHorizontal, _tx, _ty, taDrawWidth);
		
		// Clear any previously drawn over-queued/Planned line  (needed when drawing from notes)
		if _flipHorizontal then		
			self.clearRectangle(fx1 - 1,  fy1, fx1 - 8, fy2, self.myDrawingFrame);
		else
			self.clearRectangle(fx2 + 1,  fy1, fx2 + 8, fy2, self.myDrawingFrame);
		endif;
	
	else
		create laneExceeded transient;
		laneExceeded.myLocationsController := _lc;
		
		// Draw a line to indicate that this lane is over queued/Planned
		if _flipHorizontal then		
			self.drawOverQueuedPlannedLine(fx1 - 2, fy1, fx1 - 2, fy2, 2, Red, _flipHorizontal);
			//self.myDrawingFrame.drawRectangle(fx1 - 8, fy1, fx1 - 2, fy2,Blue);
			self.addToTransientDrawnObjects((fx1 - 8).Integer, fy1.Integer, (fx1 - 2).Integer, fy2.Integer, laneExceeded, true);
		else
			self.drawOverQueuedPlannedLine(fx2 + 2, fy1, fx2 + 2, fy2, 2, Red, _flipHorizontal);		
			//self.myDrawingFrame.drawRectangle(fx2 + 2, fy1, fx2 + 8, fy2,Blue);
			self.addToTransientDrawnObjects((fx2 + 2).Integer, fy1.Integer, (fx2 + 8).Integer, fy2.Integer, laneExceeded, true);
		endif;
	endif;
//_lc.getGLVDrawWidthInPixels(self.scaleFactor)
	heightUsed := self.getLaneHeight.Integer + _ta.GLV_RORO_LANE_GAP + yaHeight;
	return heightUsed;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_x" type="Integer"/>
        <Parameter name="_y" type="Integer"/>
        <Parameter name="_lc" type="CM_RoRoController"/>
        <Parameter name="_flipHorizontal" type="Boolean"/>
        <Parameter name="_flipVertical" type="Boolean"/>
        <Parameter name="_ta" type="CM_RoRoLaneArea"/>
        <Parameter name="_tx" type="Real"/>
        <Parameter name="_ty" type="Real"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="drawRoRoLaneArea" id="75f17dde-aadd-4574-8bf5-43775b3418a7">
        <updating/>
        <source>drawRoRoLaneArea(_endX, _endY : Integer output) protected, updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
07 Dec 2009	cnwjk3	Initial creation
18 Jan 2011 cnwer1	par  26725
*/

constants
	TopMargin		: Integer = 20;
vars
	
	tay				: Integer;
begin	
	if self.myTerminalArea = null then
		return;
	endif;
	self.taXPos := self.LABELGAP;
	self.taYPos := TopMargin;
	tay:=self.drawRoRoRows(self.taXPos, self.taYPos, self.myTerminalArea, self.flipHorizontal, self.flipVertically);
	self.drawRoRoLaneLabels(self.taXPos, self.taYPos, self.myTerminalArea, self.flipHorizontal, self.flipVertically);
	self.drawRoRoDirectionLabels(0, 16, self.myTerminalArea, self.flipHorizontal, self.flipVertically);
	_endX := self.taXPos + self.myTerminalArea.getGLVDrawWidthInPixels(self.scaleFactor);
	
	//epr  18/1/2011 par 26725 now return the last height from drawRoRoRows this will also take into account yard allocation lines drawn
	_endY:= tay;
	//_endY := self.taYPos + self.myTerminalArea.getGLVDrawHeightInPixels(self.scaleFactor);
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_endX" type="Integer" usage="output"/>
        <Parameter name="_endY" type="Integer" usage="output"/>
    </JadeMethod>
    <JadeMethod name="drawRoRoLaneAreaFromSelect" id="8ff11d66-3570-4849-9415-db594dd0773f">
        <updating/>
        <source>drawRoRoLaneAreaFromSelect(_endX, _endY : Integer output) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
01 February 2010	cnwjk3	Initial creation

*/

vars

begin
	self.clearCollectionsForReDraw();
	self.drawRoRoLaneArea(_endX, _endY);
epilog

end;</source>
        <Parameter name="_endX" type="Integer" usage="output"/>
        <Parameter name="_endY" type="Integer" usage="output"/>
    </JadeMethod>
    <JadeMethod name="drawRoRoLaneLabel" id="76ccc813-cbc6-451a-a9d7-cc8d38167305">
        <source>drawRoRoLaneLabel(_lane : CM_RoRoController; _x, _y : Integer) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21 January 2010	cnwjk3	Initial creation

*/

vars
	label		: String;
	drawWidth,
	laneWidth	: Real;
	ly			: Integer;
begin
	self.myVLabels.drawFontBold := false;
	// Draw the lane ID
	laneWidth := self.getLaneHeight; // _lane.getGLVDrawWidthInPixels(self.scaleFactor);
	self.myVLabels.drawFontSize := self.RORO_LABEL_ID_FONT_SIZE;
	drawWidth := self.myVLabels.drawTextWidth(_lane.id);
	if self.myRoRoLaneAreaForm.xmlDirections then
		ly := _y + ((laneWidth - self.RORO_LABEL_ID_FONT_SIZE)/5).Integer;
	else
		ly := _y + ((laneWidth - self.RORO_LABEL_ID_FONT_SIZE)/2).Integer;
	endif;
	self.myVLabels.drawTextAt(_lane.id, _x, ly, Black);
	
	// Draw the measurement in a smaller font
	label := " (" &amp; _lane.length.roundedTo(1).String &amp; "m)";
	self.myVLabels.drawFontSize := self.RORO_LABEL_LEN_FONT_SIZE;
	if self.myRoRoLaneAreaForm.xmlDirections then
		ly := _y + ((laneWidth - self.RORO_LABEL_LEN_FONT_SIZE)/5).Integer;
	else
		ly := _y + ((laneWidth - self.RORO_LABEL_LEN_FONT_SIZE)/2).Integer;
	endif;
	self.myVLabels.drawTextAt(label, _x + drawWidth, ly, Black);
	
	// Draw the access directions
	if self.myRoRoLaneAreaForm.xmlDirections then
		ly := _y + ((laneWidth - self.RORO_LABEL_ID_FONT_SIZE) * 4 / 5).Integer;
		if _lane.accessDirection = _lane.ACCESS_DIRECTION_BOTH then
			self.drawDoubleArrowLine(_x, ly, self.myVLabels.width, ly, Black, self.myVLabels);
		elseif (_lane.accessDirection = _lane.ACCESS_DIRECTION_RIGHT and not self.flipHorizontal) or (_lane.accessDirection = _lane.ACCESS_DIRECTION_LEFT and self.flipHorizontal) then
			self.drawLeftArrowLine(_x, ly, self.myVLabels.width, ly, Black, self.myVLabels);
		elseif (_lane.accessDirection = _lane.ACCESS_DIRECTION_LEFT and not self.flipHorizontal) or (_lane.accessDirection = _lane.ACCESS_DIRECTION_RIGHT and self.flipHorizontal) then
			self.drawRightArrowLine(_x, ly, self.myVLabels.width, ly, Black, self.myVLabels);
		endif;
	endif;
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_lane" type="CM_RoRoController"/>
        <Parameter name="_x" type="Integer"/>
        <Parameter name="_y" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="drawRoRoLaneLabels" id="d21c5622-9041-4b23-b1dc-790af4bd2082">
        <source>drawRoRoLaneLabels(_x, _y : Integer; _ta : CM_RoRoLaneArea; _flipHorizontal, _flipVertical : Boolean) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 December 2009	cnwjk3	Initial creation
//19/09/2017	cnwma1  TFS #4177 -STWO - RORO Lane Details

*/

vars
	lane 		: CM_RoRoController;
	taDrawHeight,
	laneWidth	: Real;
	index,
	x, y		: Integer;
begin
	taDrawHeight := _ta.getGLVDrawHeightInPixels(self.scaleFactor);
	x := 4;
	y := _y;
	laneWidth := self.getLaneHeight; 
	if _flipVertical then 
		index := 1;
		foreach lane in _ta.allLanesByLaneNumber reversed do
			
			//19/09/2017	cnwma1  TFS #4177 
			if self.allSelectedRoRoLanes.size &gt; 0 then
				if not self.allSelectedRoRoLanes.includes(lane) then
					continue;
				endif;
			endif;
			
			self.drawRoRoLaneLabel(lane, x, y);
			y := y + laneWidth.Integer;
			y := y + _ta.GLV_RORO_LANE_GAP;
			y := y + self.allYARowHeights[index];
			index := index + 1;
		endforeach;
	else
		index := 1;
		foreach lane in _ta.allLanesByLaneNumber do
			
			//19/09/2017	cnwma1  TFS #4177 
			if self.allSelectedRoRoLanes.size &gt; 0 then
				if not self.allSelectedRoRoLanes.includes(lane) then
					continue;
				endif;
			endif;
			
			self.drawRoRoLaneLabel(lane, x, y);
			y := y + laneWidth.Integer;
			y := y + _ta.GLV_RORO_LANE_GAP;
			y := y + self.allYARowHeights[index];
			index := index + 1;
		endforeach;
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_x" type="Integer"/>
        <Parameter name="_y" type="Integer"/>
        <Parameter name="_ta" type="CM_RoRoLaneArea"/>
        <Parameter name="_flipHorizontal" type="Boolean"/>
        <Parameter name="_flipVertical" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="drawRoRoRows" id="5226dc83-f677-4309-9782-a39763e52452">
        <updating/>
        <source>drawRoRoRows(_x , _y : Integer; _ta : CM_RoRoLaneArea; _flipHorizontal, _flipVertical : Boolean) : Integer updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
07 Dec 2009	cnwjk3	Initial creation
18 Jan 2011 cnwer1	par 26725 
19 Sep 2017 cnwma1  TFS #4177 -STWO - RORO Lane Details
*/

vars
	lane 	: CM_RoRoController;
	x, y	: Integer;
begin
	x := _x;
	y := _y;
	if _flipVertical then
		foreach lane in _ta.allLanesByLaneNumber reversed do
			//19/09/2017	cnwma1  TFS #4177 
			if self.allSelectedRoRoLanes.size&gt; 0 then
				if not self.allSelectedRoRoLanes.includes(lane) then
					continue;
				endif;
			endif;
			
			y:= y + self.drawRoRoLane(x, y, lane, _flipHorizontal, _flipVertical, _ta, _x, _y);
		endforeach;
	else
		foreach lane in _ta.allLanesByLaneNumber do
			//19/09/2017	cnwma1  TFS #4177 
			if self.allSelectedRoRoLanes.size&gt; 0 then
				if not self.allSelectedRoRoLanes.includes(lane) then
					continue;
				endif;
			endif;
			y:= y + self.drawRoRoLane(x, y, lane, _flipHorizontal, _flipVertical, _ta, _x, _y);			
		endforeach;
	endif;	
	
	//epr  18/1/2011 par 26725 now return the last height from drawRoRoRows this will also take into account yard allocation lines drawn
	return y;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_x" type="Integer"/>
        <Parameter name="_y" type="Integer"/>
        <Parameter name="_ta" type="CM_RoRoLaneArea"/>
        <Parameter name="_flipHorizontal" type="Boolean"/>
        <Parameter name="_flipVertical" type="Boolean"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="drawSelf" id="c623548c-2293-4bd4-9096-ab7230460c2e">
        <updating/>
        <source>drawSelf(_clearSelected: Boolean) updating;
// ---------------------------------------------------------------------------
// Created:		November 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//19/09/2017	cnwma1  TFS #4177 -STWO - RORO Lane Details
// ---------------------------------------------------------------------------
constants
	FillerExtra		: Integer = 400;
	TopMargin		: Integer = 20;
	BottomMargin	: Integer = 70;
	RightMargin		: Integer = 10;
vars
	tmpDrawingController	: YRD_RoRoLaneDrawingController;
	maxX,
	maxY					: Integer;
	yPos1, yPos2,
	xPos1, xPos2			: Real;	
	tmpFrame				: CMUI_Frame;	//YRD_ContainerDrawingFrame;
	topLeftFiller 			: Frame;
	roroLane : Object;
begin
	if self.myTerminalArea = null then
		return;
	endif;	

	self.drawFromNote := false;
		
	inheritMethod(_clearSelected);
	useSelectorObjects := self.myRoRoLaneAreaForm.useSelector;
	self.allPolygons.purge;
	self.allDrawnObjects.clear;
	self.clearCollectionsForReDraw();
	
	self.myDrawingFrame.clearGraphics();
	self.myDrawingFrame.visible := false;
	
	self.myVLabels.clearGraphics();
	self.myVLabels.width := self.RORO_VLABEL_WIDTH;
	self.myVLabels.top := self.RORO_VLABEL_WIDTH + 1;
	self.myVLabels.autoRedraw := true;
	
	self.myHLabels.clearGraphics();
	self.myHLabels.height := YRD_ContainerDrawingController.LABEL_WIDTH;
	self.myHLabels.autoRedraw := true;
	self.setFontDefaults();

	topLeftFiller := self.myDockBar.myScrollableFrame.myTopLeftFillerFrame;
	topLeftFiller.clearGraphics();
	topLeftFiller.autoRedraw := true;
	topLeftFiller.visible := true;
	topLeftFiller.move(0,0,self.myDockBar.myScrollableFrame.myVLabels.clientWidth + FillerExtra,self.myDockBar.myScrollableFrame.myHLabels.height);
	
	tmpDrawingController := self;
	tmpFrame := self.myDrawingFrame;
	tmpFrame.caption := null;			
	//19/09/2017	cnwma1  TFS #4177 
	if self.myRoRoLaneAreaForm.allSelectedRoRoLanes.size &gt; 0 then
		self.allSelectedRoRoLanes.clear;
		foreach roroLane in self.myRoRoLaneAreaForm.allSelectedRoRoLanes do 
			self.allSelectedRoRoLanes.addExclusive(roroLane);
		endforeach;
	endif;
	
	self.drawRoRoLaneArea(xPos2, yPos2); 
	
	maxX := (xPos2 + RightMargin).Integer ;
	maxY := (yPos2 + BottomMargin).Integer;

	self.myDockBar.resizeScrollingFrame(maxX, maxY);
	self.myDockBar.myScrollingFrame.left := self.LABEL_WIDTH + 1;
	self.myDockBar.myScrollingFrame.top := self.LABEL_WIDTH + 1;
	self.myDockBar.resetScrollValues();

epilog
	self.myDrawingFrame.visible := true;
end;</source>
        <Parameter name="_clearSelected" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="drawSelfYardAllocationLine" id="c8bb43a1-1a95-4616-a521-03fbab4bab7b">
        <source>drawSelfYardAllocationLine(	_yardAlloc : CM_YardAllocation;
							_x, _y, _len : Integer;
							_lineHeight : Integer;
							_yaHeight : Integer io) protected;
/*

Purpose:			Draw a line to represent a Yard Allocation.

Parameters:			
Return Value:		


Date				Who		Reason
12 November 2008	consw1	SWF1030 - Initial creation

*/

constants 
	Padding = 2;
vars
	xPos1,
	xPos2, 
	yPos1, 
	yPos2		: Integer;
	tmpObj 		: Object;
begin
	xPos1 := _x;
	yPos1 := _y + Padding;
	xPos2 := _x + _len;
	yPos2 := yPos1 + _lineHeight;
		
	tmpObj := self.allYAObjects.getAtKey( xPos1, yPos1, xPos2, yPos2);
	
	self.myDrawingFrame.drawWidth := _lineHeight - 1;
	
	self.myDrawingFrame.drawLine( xPos1, yPos1, xPos2, yPos1, _yardAlloc.color );

	if tmpObj = null then
		self.allYAObjects.putAtKey( xPos1, yPos1, xPos2, yPos2, _yardAlloc );
	endif;
	
	_yaHeight := _lineHeight + Padding;	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_yardAlloc" type="CM_YardAllocation"/>
        <Parameter name="_x" type="Integer"/>
        <Parameter name="_y" type="Integer"/>
        <Parameter name="_len" type="Integer"/>
        <Parameter name="_lineHeight" type="Integer"/>
        <Parameter name="_yaHeight" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="drawTI" id="fc64392a-3677-45e0-a7ce-a21cbac6c8e1">
        <updating/>
        <source>drawTI(_theTI: CM_TrackedItem; _theGridAttributes: CMUI_GridAttributes input; _x1: Real; _y1: Real; _x2: Real; _y2: Real; _frame: CMUI_GridAreaDrawingFrame input;  _lc : CM_LocationsController) updating, protected;
// ---------------------------------------------------------------------------
// Created:		02 December 2005  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	yBase 	: Integer;
	oldFlipHorizontal : Boolean;
begin
	yBase := _y2.Integer;
	if _theTI.hasTIBehaviourGraphic()  then
		self.drawTIBehaviourGraphic(_theTI, _x1.Integer, _y1.Integer, _x2.Integer, yBase, _frame, _lc);	// cnwjk3 PAR 23875 23/04/10
	else 	//if there are no commands to draw TI then draw a BOX, which kind of looks like a container.
		// Hack alert
		// This ensures that the TI's Icons display correctly when the area is flipped horizontally
		oldFlipHorizontal := self.flipHorizontal;
		self.flipHorizontal := false; 
		self.setIconPositions(0, _y1, _x2, _y2); 
		self.setMaxNumIcons(_theTI);				// cnwjk3 PAR 23760 19/04/2010
		inheritMethod(_theTI, _theGridAttributes,  _x1, _y1, _x2, _y2, _frame, _lc);
		self.flipHorizontal := oldFlipHorizontal;

		self.addToDrawnObjects( _x1.Integer, _y1.Integer, _x2.Integer, _y2.Integer, _theTI);
	endif;
epilog
end;</source>
        <access>protected</access>
        <Parameter name="_theTI" type="CM_TrackedItem"/>
        <Parameter name="_theGridAttributes" type="CMUI_GridAttributes" usage="input"/>
        <Parameter name="_x1" type="Real"/>
        <Parameter name="_y1" type="Real"/>
        <Parameter name="_x2" type="Real"/>
        <Parameter name="_y2" type="Real"/>
        <Parameter name="_frame" type="CMUI_GridAreaDrawingFrame" usage="input"/>
        <Parameter name="_lc" type="CM_LocationsController"/>
    </JadeMethod>
    <JadeMethod name="drawTIBehaviourGraphic" id="ee2c3ce8-f009-415b-8c90-e2129d9edfba">
        <updating/>
        <source>drawTIBehaviourGraphic(	_theTI: CM_TrackedItem; 
						_x1: Integer; _y1: Integer; _x2: Integer; _y2: Integer io;
						_frame: CMUI_GridAreaDrawingFrame input;
						_lc : CM_LocationsController) updating, protected;
// ---------------------------------------------------------------------------
// Created:		02 December 2005  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	graphic 		: CM_TIBehaviourGraphic;
	tmpColour	: Integer;
	tiWidth, 
	scale,
	fy1, fy2: Real;
	rc				: CM_RoRoController;
	drawGraphicFlipped ,drawWithoutOffset : Boolean;
	textCommand : CM_GraphicCommand;
begin
	graphic :=_theTI.getTIBehaviourGraphic;
	if graphic = null then
		return;
	endif;
	
	tmpColour := self.getFillColourForTI(_theTI);
	
	if self.useSelectorObjects and not self.allSelectorTIs.includes(_theTI) then
		tmpColour := White;
	endif;
	
	self.getTIBehaviourGraphicYOffsets(_theTI,_x1,_y1,_x2,_y2,fy1,fy2,scale);
	drawWithoutOffset:=not self.drawFromNote and ( self.allSelectedObjects.includes(_theTI) or self.myCurrentObject &lt;&gt; null);
	
	// Calculate scale dynamically based on the width/height of the rectangle points passed in.  
	tiWidth := _x2 - _x1;

	_frame.drawWidth := 1;																// cnwjk3 PAR 23875 23/04/10
	rc := _lc.CM_RoRoController;																								// cnwjk3 PAR 23875 23/04/10
	if rc = null then	
		// cnwjk3 PAR 23875 23/04/10
		// This can happen when we are drawing the TI in response to a mouse click on a TI.  									// cnwjk3 PAR 23875 23/04/10	
		// So, we try to get the location from the TI itself																	// cnwjk3 PAR 23875 23/04/10
		if self.displayMode = DISPLAY_MODE_ACTUAL then																			// cnwjk3 PAR 23875 23/04/10
			if _theTI.myPrimaryActualLocation.isKindOf(CM_RoRoController) then													// cnwjk3 PAR 23875 23/04/10
				rc := _theTI.myPrimaryActualLocation.CM_RoRoController;															// cnwjk3 PAR 23875 23/04/10		
			endif;																												// cnwjk3 PAR 23875 23/04/10
		elseif self.displayMode = DISPLAY_MODE_QUEUE then																		// cnwjk3 PAR 23875 23/04/10
			if _theTI.myPrimaryQueuedLocation.isKindOf(CM_RoRoController) then  // Could be queued to more than one place 		// cnwjk3 PAR 23875 23/04/10
				rc := _theTI.myPrimaryQueuedLocation.CM_RoRoController;															// cnwjk3 PAR 23875 23/04/10
			endif;																												// cnwjk3 PAR 23875 23/04/10
		elseif self.displayMode = DISPLAY_MODE_PLAN then																		// cnwjk3 PAR 23875 23/04/10	
			if _theTI.myPrimaryPlannedLocation.isKindOf(CM_RoRoController) then  // Could be planned to more than one place 	// cnwjk3 PAR 23875 23/04/10
				rc := _theTI.myPrimaryPlannedLocation.CM_RoRoController;														// cnwjk3 PAR 23875 23/04/10
			endif;																												// cnwjk3 PAR 23875 23/04/10
		endif;																													// cnwjk3 PAR 23875 23/04/10
	endif;																														// cnwjk3 PAR 23875 23/04/10		
		
	if rc &lt;&gt; null then																											// cnwjk3 PAR 23875 23/04/10
		drawGraphicFlipped := not (rc.parkDirection = rc.PARK_DIRECTION_LEFT_TO_RIGHT);											// cnwjk3 PAR 23875 23/04/10
	else																														// cnwjk3 PAR 23875 23/04/10
		drawGraphicFlipped := false;																							// cnwjk3 PAR 23875 23/04/10
	endif;																														// cnwjk3 PAR 23875 23/04/10
	
	if self.flipHorizontal = true then
		drawGraphicFlipped := not drawGraphicFlipped;
	endif;
	
	if _theTI.isKindOf(CM_TILC) then
		//+5 is the difference between the top of the trailer graphic and the trailer tray where cargo sits
		self.clearTIBehaviourSelectionRect(_x1, fy1.Integer+5, _x2.Integer, fy2.Integer);
	else
		self.clearTIBehaviourSelectionRect(_x1, fy1.Integer, _x2.Integer, fy2.Integer);
	endif;
	graphic.drawGraphic(_frame,scale,_x1, fy1.Integer, drawGraphicFlipped,tiWidth.Integer,false,_theTI.id, _theTI,tmpColour);
	
	textCommand:=graphic.getTextCommand;
	if textCommand &lt;&gt; null then
		self.drawTIBehaviourGraphicText(_theTI,textCommand ,scale,_x1, fy1.Integer,drawGraphicFlipped,tmpColour.getInverseColour);
	endif;
	// Key in based on the whole rectangle, as passed into this method			 //(22  * self.scaleFactor)).Integer	
	self.addToDrawnObjects(_x1,  fy1.Integer, _x2, fy2.Integer, _theTI);
		
	if _theTI.isKindOf(CM_TILC) then
		if not drawWithoutOffset then
			self.drawTILCs(_theTI.CM_TILC,_x1.Integer, _y1.Integer,tiWidth.Integer,drawGraphicFlipped );			
		endif;
	endif;
	
	if self.allSelectedObjects.includes(_theTI) then
		if _theTI.isKindOf(CM_TILC) then
			
			self.drawTIBehaviourSelectionRect(_x1,  fy1.Integer+5, _x2.Integer, fy2.Integer);
			
		else
			self.drawTIBehaviourSelectionRect(_x1,  fy1.Integer, _x2.Integer, fy2.Integer);
		endif;
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_theTI" type="CM_TrackedItem"/>
        <Parameter name="_x1" type="Integer"/>
        <Parameter name="_y1" type="Integer"/>
        <Parameter name="_x2" type="Integer"/>
        <Parameter name="_y2" type="Integer" usage="io"/>
        <Parameter name="_frame" type="CMUI_GridAreaDrawingFrame" usage="input"/>
        <Parameter name="_lc" type="CM_LocationsController"/>
    </JadeMethod>
    <JadeMethod name="drawTIBehaviourGraphicText" id="e2c532fe-d25b-46df-bbe7-71a8b8f88303">
        <updating/>
        <source>drawTIBehaviourGraphicText( _ti : CM_TrackedItem;
							_textCommand : CM_GraphicCommand;
							_scale : Real; 
							_xOffset, _yOffset : Integer;
							_flipped : Boolean;
							_textColor :Integer) protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 May 2012	cnwer1	Initial creation CCMS MES 1035
11 Nov 2019	jlgdap1	TFS 46405 AAT Flat Rack and OOG in LOLO Planning Screen
*/

vars
	 x1, x2, y1, y2 : Real;
	textWidth 	: Integer;
begin
	if _textCommand = null then
		return;
	endif;

	x1:=(_textCommand.x1  * _scale) + _xOffset;
	x2:=(_textCommand.x2  * _scale) + _xOffset;
	y1:=(_textCommand.y1  * _scale) + _yOffset;
	y2:=(_textCommand.y2  * _scale) + _yOffset;
	if _flipped then
		x1:=_xOffset + ((_textCommand.myTIBehaviourGraphic.maxX - _textCommand.x2)* _scale);	
	endif;
	//do this ourselves max 4 icons one after another 
	self.defaultFontSizeForAttributes:=((y2 - y1).abs * 72 / 96).Integer;
	//write self.defaultFontSizeForAttributes;
	self.myDrawingFrame.fontSize:=self.defaultFontSizeForAttributes;
	textWidth:=self.myDrawingFrame.getTextExtent("W");
	
	self.attrX1 := 0;
	self.attrY1 := 0;
	self.attrX2 := textWidth ;
	self.attrY2 := 0;
	self.attrX3 :=( textWidth * 2);
	self.attrY3 := 0;
	self.attrX4 :=(textWidth* 3);
	self.attrY4 := 0;
	self.attrMaxNum := 4;
	
	//self.drawIcons(_ti,self.myDrawingFrame,x1, y1, _textColor);			// TFS 46405
	self.drawIcons(_ti,self.myDrawingFrame,x1, y1, _textColor, false);		// TFS 46405

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_textCommand" type="CM_GraphicCommand"/>
        <Parameter name="_scale" type="Real"/>
        <Parameter name="_xOffset" type="Integer"/>
        <Parameter name="_yOffset" type="Integer"/>
        <Parameter name="_flipped" type="Boolean"/>
        <Parameter name="_textColor" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="drawTIBehaviourSelectionRect" id="c1a924dd-e507-47b4-9268-c42ff1bbc395">
        <source>drawTIBehaviourSelectionRect(_x1, _y1, _x2, _y2 : Integer ) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 March 2010	cnwjk3	PAR 22733
*/

vars
	oldDrawWidth : Integer;
begin
	oldDrawWidth := self.myDrawingFrame.drawWidth;
	self.myDrawingFrame.drawWidth := TI_SELECT_DRAW_WIDTH;
	self.myDrawingFrame.drawRectangle(_x1+TI_SELECT_DRAW_WIDTH/2, _y1 + TI_SELECT_DRAW_WIDTH/2, _x2 - TI_SELECT_DRAW_WIDTH/2, _y2 - TI_SELECT_DRAW_WIDTH/2, White);
	self.myDrawingFrame.drawWidth := oldDrawWidth;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_x1" type="Integer"/>
        <Parameter name="_y1" type="Integer"/>
        <Parameter name="_x2" type="Integer"/>
        <Parameter name="_y2" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="drawTILCs" id="27ee3d90-e56e-4767-b65e-ee73e83ec30b">
        <updating/>
        <source>drawTILCs(	_tiLC : CM_TILC; 
			_x1, _y1: Integer;
			_maxX 	: Integer;
			_drawGraphicFlipped : Boolean) protected, updating;
/*
Date		Who		Reason
10/06/2013	cnwer1	Initial creation PAR
03/03/2016	cnwdap1	PAR #37532 Use actual number of cargo positions instead of theoretical 20' length
					when calculating the width of each drawing controller
*/

vars

	x1, x2, tix2, tiy2 : Integer;
	numLCs : Integer;
	anLC : CM_TILCController;
	ti : CM_TrackedItem;
	lenMetres,
	len	, 
	twentyLength,containerHeight : Real;
	qdTis : CM_TIArray;
	theFMLetter : String;
	drawnTI 	: Boolean;
begin
	
	create qdTis transient;
	numLCs := _tiLC.allLCs.size;
	if numLCs = 0 then
		return;
	else
		containerHeight:=self.getContainerHeight();
		//twentyLength:=self.getLengthPerFoot(20);				// PAR #37532
		twentyLength := _maxX / numLCs;							// PAR #37532
		//write containerHeight;
		if _drawGraphicFlipped then
			x1:=(_x1 + _maxX);
		else
			x2:=_x1;
			x1 := _x1;
		endif;
		tiy2:=_y1 + containerHeight.Integer - 1;		
		
		foreach anLC in _tiLC.allLCs discreteLock do
			drawnTI:=false;
			if _drawGraphicFlipped then	
				x2:=x1;
				x1:=x2 - twentyLength.Integer;
			else
				x1:=x2;
				x2 := x1 + twentyLength.Integer; // PAR 20984 epr 8/10/09 we need the x2 for the locations on the trailer not just the tis
			endif;
					
			self.addToDrawnObjects(x1,_y1, x2,tiy2, anLC);
			
			foreach ti in anLC.allTrackedItems discreteLock do	
				lenMetres :=  self.getTILengthInMetres(ti);
				len := lenMetres * CM_RoRoLaneArea.GLV_RORO_PIXELS_PER_METRE * self.scaleFactor;
				tix2 := x1 + len.Integer;
				
				self.drawTI(ti, null,x1, _y1, tix2,tiy2,self.myDrawingFrame, null);	// cnwjk3 PAR 23875 23/04/10
				drawnTI:=true;
			endforeach;
			
			if drawnTI then
				continue;
			endif;
			//draw queued &amp; or planned 
			qdTis.clear;
			anLC.getAllQueuedTrackedItems(qdTis,true);
			foreach ti in qdTis discreteLock do
				lenMetres :=  self.getTILengthInMetres(ti);
				len := lenMetres * CM_RoRoLaneArea.GLV_RORO_PIXELS_PER_METRE * self.scaleFactor;
				tix2 := x1 + len.Integer;
				theFMLetter:="Q";
				ti.getFMLetter(theFMLetter);
				self.doDrawFMLetterForTI(theFMLetter,ti,true,x1, _y1, tix2,tiy2);		
			endforeach;
			
			if drawnTI then
				continue;
			endif;
			
			qdTis.clear;
			anLC.getAllPlannedTrackedItems(qdTis,true,false);
			foreach ti in qdTis discreteLock do
				lenMetres :=  self.getTILengthInMetres(ti);
				len := lenMetres * CM_RoRoLaneArea.GLV_RORO_PIXELS_PER_METRE * self.scaleFactor;
				tix2 := x1 + len.Integer;
				theFMLetter:="P";
				ti.getFMLetter(theFMLetter);
				self.doDrawFMLetterForTI(theFMLetter,ti,true,x1, _y1, tix2,tiy2);		
			endforeach;
		endforeach;
	endif;

epilog
	delete qdTis;
end;</source>
        <access>protected</access>
        <Parameter name="_tiLC" type="CM_TILC"/>
        <Parameter name="_x1" type="Integer"/>
        <Parameter name="_y1" type="Integer"/>
        <Parameter name="_maxX" type="Integer"/>
        <Parameter name="_drawGraphicFlipped" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="drawTIMetricsForLane" id="e99d7259-b5f9-4794-8286-a810a944aa81">
        <source>drawTIMetricsForLane(_lc : CM_RoRoController; _x, _y : Real;  _flipHorizontal : Boolean; _tx, _ty, _taDrawWidth : Real) protected;
/*

Parameters:			
		_x				: X pos of lane start (un-scaled)
		_y				: Y pos of lane start (un-scaled)
		_tx				: X pos of terminal area
		_ty				: Y pos of terminal area
		_taDrawWidth	: width of terminal area (scaled

Date		Who		Reason
07 December 2009	cnwjk3	Initial creation

*/
vars
	freedLength,
	startOffset,
	laneLength,
	laneWidth,
	standardGap,
	cx1, cx2,
	cy1, cy2,
	fx1, fx2,
	fy1, fy2,
	tix1, tiy1,
	tix2, tiy2,
	lenMetres,
	len			: Real;
	ti 			: CM_TrackedItem;
	arrTIs		: CM_TIArray;	
begin
	create arrTIs transient;	
	
	 _lc.allTrackedItems.copy(arrTIs);
	 _lc.getAllQueuedTrackedItems(arrTIs, false);
	 _lc.getAllPlannedTrackedItems(arrTIs, false, false);

	self.myDrawingFrame.drawWidth := 1;
	startOffset := _lc.startOffset * _lc.myRoRoLaneArea.GLV_RORO_PIXELS_PER_METRE * self.scaleFactor;
	freedLength := _lc.freedLength * _lc.myRoRoLaneArea.GLV_RORO_PIXELS_PER_METRE * self.scaleFactor;
	laneLength := _lc.getGLVDrawLengthInPixels(self.scaleFactor);
	laneWidth:=self.getLaneHeight();
	standardGap := _lc.myRoRoLaneArea.standardGap * _lc.myRoRoLaneArea.GLV_RORO_PIXELS_PER_METRE * self.scaleFactor;
		
	tix1 := _x;
	
	// Adjust start x for first TI based on the lane startOffset
	tix1 := tix1 + startOffset;

	// Adjust for any space freed from the front of the lane
	tix1 := tix1 + freedLength;

	tiy1 := _y + laneWidth-1 + self.TI_METRIC_OFFSET;
	tiy2 := tiy1;
	
	// Clear the area that we are going to draw arrows over
	cx1 := _tx;
	cx2 := _tx + _taDrawWidth - 1;
	cy1 := tiy1;
	cy2 := cy1+1;

	if _flipHorizontal then
		self.clearRectangle(cx1-1, cy1-self.ARROW_YOFFSET, cx1+_taDrawWidth-1, cy2+self.ARROW_YOFFSET, self.myDrawingFrame);
	else
		self.clearRectangle(cx1, cy1-self.ARROW_YOFFSET, cx1+_taDrawWidth, cy2+self.ARROW_YOFFSET, self.myDrawingFrame);
	endif;
	
	// Clear the area that we are going to draw metric labels in
	self.clearMetricLabels(_tx, tiy1, _taDrawWidth);
	
	
	foreach ti in arrTIs do
		
		lenMetres := _lc.getTILengthInMetres(ti);
		len := lenMetres * _lc.myRoRoLaneArea.GLV_RORO_PIXELS_PER_METRE * self.scaleFactor;
		
		if tix1 + len - startOffset  - _x &gt; _lc.getGLVPhysicalLaneLengthPixels(self.scaleFactor) + 1 then
			// Stop drawing, we are over queued/planned.
			// This is allowed, but we don't want to draw the stuff that doesn't fit.
			break;
		endif;
		
		// Calculate end x for TI
		tix2 := tix1 + len;
		
		fx1 := tix1;
		fx2 := tix2;
		fy1 := tiy1;
		fy2 := tiy2;

		// If we need to draw right-to-left then we can just flip the TI x points
		// relative to the lane length.
		if  _lc.isDrawRightToLeft() then
			fx1 := self.flipPointX(_x + startOffset, laneLength - startOffset, fx1)-1;
			fx2 := self.flipPointX(_x + startOffset, laneLength - startOffset, fx2)-1;
		endif;
		
		if _flipHorizontal then
			fx1 := self.flipPointX(_tx, _taDrawWidth, fx1)-1;  
			fx2 := self.flipPointX(_tx, _taDrawWidth, fx2)-1;  
		endif;
	
		self.normaliseRealRectanglePoints(fx1, fy1, fx2, fy2);
		self.drawDoubleArrowLine(fx1, fy1, fx2, fy2, Black, self.myDrawingFrame);
		
		// Draw actual measurement
		self.drawMetricLabel(fx1, fy1, fx2, lenMetres.roundedTo(1).String);
					
		// Calculate start x for next TI
		tix1 := tix2 + standardGap;
	endforeach;
	
epilog
	delete arrTIs;
end;</source>
        <access>protected</access>
        <Parameter name="_lc" type="CM_RoRoController"/>
        <Parameter name="_x" type="Real"/>
        <Parameter name="_y" type="Real"/>
        <Parameter name="_flipHorizontal" type="Boolean"/>
        <Parameter name="_tx" type="Real"/>
        <Parameter name="_ty" type="Real"/>
        <Parameter name="_taDrawWidth" type="Real"/>
    </JadeMethod>
    <JadeMethod name="drawTIsForLane" id="9aadff42-27f0-4f70-b532-0b8affd8ce52">
        <updating/>
        <source>drawTIsForLane(_lc : CM_RoRoController; _x, _y : Real;  _flipHorizontal : Boolean; _tx, _ty, _taDrawWidth : Real) updating, protected;

/*
Parameters:			
		_x				: X pos of lane start (un-scaled)
		_y				: Y pos of lane start (un-scaled)
		_tx				: X pos of terminal area
		_ty				: Y pos of terminal area
		_taDrawWidth	: width of terminal area (scaled)
Return Value:		


Date		Who		Reason
07 December 2009	cnwjk3	Initial creation

*/
vars
	freedLength,
	startOffset,
	laneWidth,
	laneLength,
	standardGap,
	fx1, fx2,
	fy1, fy2,
	tix1, tiy1,
	tix2, tiy2,
	lenMetres,
	len	, 
	laneHeight,
	containerHeight,
	trailerHeight : Real;
	theDisplayMode,
	position	: Integer;
	ti			: CM_TrackedItem;
	numberLtoR	: Boolean;
	drawSolid	: Boolean;
	theFMLetter : String;
	graphic : CM_TIBehaviourGraphic;
begin
	self.myCurrentObject:=null;
	theDisplayMode := self.displayMode;
	self.myLocationsController := _lc;
	self.setTICollections();
	
	self.myDrawingFrame.drawWidth := 1;
	startOffset := _lc.startOffset * _lc.myRoRoLaneArea.GLV_RORO_PIXELS_PER_METRE * self.scaleFactor;
	freedLength := _lc.freedLength * _lc.myRoRoLaneArea.GLV_RORO_PIXELS_PER_METRE * self.scaleFactor;
	laneLength := _lc.getGLVDrawLengthInPixels(self.scaleFactor);
	laneWidth := self.getLaneHeight;//.getGLVDrawWidthInPixels(self.scaleFactor);
	standardGap := _lc.myRoRoLaneArea.standardGap * _lc.myRoRoLaneArea.GLV_RORO_PIXELS_PER_METRE * self.scaleFactor;	
	numberLtoR := _lc.numberingDirection = _lc.NUMBERING_DIRECTION_L_TO_R; 
	
	tix1 := _x;
	
	// Adjust start x for first TI based on the lane startOffset
	tix1 := tix1 + startOffset;
	
	// Adjust for any space freed from the front of the lane
	tix1 := tix1 + freedLength;
	
	tiy1 := _y;// + YOFFSET;
	tiy2 := _y + laneWidth-1;   //- (YOFFSET+1);
	containerHeight:=self.getContainerHeight();

	laneHeight:=self.getLaneHeight();
	
	tiy2 := _y + laneHeight-1;
	// Clear the position labels rectangle
	self.clearPositionLabels(_x, _y,  _taDrawWidth);
	
	if not _lc.isDrawRightToLeft() then
		if numberLtoR then
			position := 1;
		else
			position :=  self.allTempTIs.size();
		endif;
	else
		if numberLtoR then
			position :=  self.allTempTIs.size();
		else
			position := 1;
		endif;	
	endif;
			
	foreach ti in self.allTempTIs do 
		lenMetres :=  _lc.getTILengthInMetres(ti);
		len := lenMetres * _lc.myRoRoLaneArea.GLV_RORO_PIXELS_PER_METRE * self.scaleFactor;
		
		if tix1 + len - startOffset - _x &gt; _lc.getGLVPhysicalLaneLengthPixels(self.scaleFactor) + 1 then
			// Stop drawing, we are over queued/planned.
			// This is allowed, but we don't want to draw the stuff that doesn't fit.
			break;
		endif;
	
		// Calculate end x for TI
		tix2 := tix1 + len;		
		
		fx1 := tix1;
		fx2 := tix2;
		fy1 := tiy1;
		graphic:=ti.getTIBehaviourGraphic();
		if ti.isKindOf(CM_Container) then
			fy2:=_y + laneHeight-1;
			fy1 := fy2 - containerHeight-1;
		elseif graphic &lt;&gt; null then
			
			if ti.isKindOf(CM_TILC) then
				trailerHeight:=16* self.scaleFactor;
			else			
				trailerHeight:=containerHeight ;
			endif;
			fy2 := _y + trailerHeight-1;
			
		else
			fy2 := tiy2;
		endif;
		// If we need to draw right-to-left then we can just flip the TI x points
		// relative to the lane length.
		if _lc.isDrawRightToLeft() then
			fx1 := self.flipPointX(_x + startOffset, laneLength - startOffset, fx1)-1;
			fx2 := self.flipPointX(_x + startOffset, laneLength - startOffset, fx2)-1;
		endif;
		
		if _flipHorizontal then
			fx1 := self.flipPointX(_tx, _taDrawWidth, fx1)-1;  
			fx2 := self.flipPointX(_tx, _taDrawWidth, fx2)-1;  
		endif;
		
		self.normaliseRealRectanglePoints(fx1, fy1, fx2, fy2);
		
		// Okay, we now have the bounding rectangle of the TI, flipped accordingly
		
		// Let's see if we need to draw the actual TI, or the Queued or Planned symbol
		drawSolid := 	(theDisplayMode = DISPLAY_MODE_ACTUAL and self.allTIsA.includes(ti))
			or			(theDisplayMode = DISPLAY_MODE_QUEUE and self.allTIsQ.includes(ti))
			or			(theDisplayMode = DISPLAY_MODE_PLAN and self.allTIsP.includes(ti));
		
	
		if not self.isDrawFromAreaSelect then
			if drawSolid then
				self.drawTI(ti, null, fx1, fy1, fx2, fy2, self.myDrawingFrame, _lc);	// cnwjk3 PAR 23875 23/04/10
			else
				self.getFMLetter(ti, theFMLetter);
				self.doDrawFMLetterForTI(theFMLetter, ti, false, fx1, fy1, fx2, fy2);
			endif;
		endif;
			
		// Draw the position number of the TI
		// Note that we rely on getTILengths() returning the correct order
		self.drawPositionLabel(fx1, _y, fx2,  position.String);
		
		if not _lc.isDrawRightToLeft() then
			if numberLtoR then
				position := position + 1;
			else
				position := position - 1;
			endif;
		else		
			if numberLtoR then
				position := position - 1;
			else
				position := position + 1;
			endif;
		endif;
		
		// Calculate start x for next TI
		tix1 := tix2 + standardGap;
	endforeach;
	
epilog
end;</source>
        <access>protected</access>
        <Parameter name="_lc" type="CM_RoRoController"/>
        <Parameter name="_x" type="Real"/>
        <Parameter name="_y" type="Real"/>
        <Parameter name="_flipHorizontal" type="Boolean"/>
        <Parameter name="_tx" type="Real"/>
        <Parameter name="_ty" type="Real"/>
        <Parameter name="_taDrawWidth" type="Real"/>
    </JadeMethod>
    <JadeMethod name="drawYardAllocationLinesForRow" id="5c956792-8c12-4754-a37d-43479f817c5f">
        <source>drawYardAllocationLinesForRow(_row : CM_RoRoController; _x1, _y1, _x2, _y2 : Integer) : Integer protected;

/*

Purpose:			Draw Yard Allocations for given Lane.
					Yard Allocations are also added to associated YAMTable.

Parameters:			_row 	- the row to show the YAs for
					_x1, _y1, _x2, _y2 - rectangle for row (flipped if need be)
Return Value:		The extra height taken up by the YA lines.

*/

constants
	LineHeight 		= 3;
	Padding = 2;
vars
	idx				: Integer;
	usedHeight,
	usedHeightTotal	: Integer;
	ya				: CM_YardAllocation;
	yaSet			: CM_YardAllocationSet;
	yaByPriority	: CM_YAByPriorityDict;
	len,
	lx1,
	ly1, ly2		: Integer;
begin
	create yaSet transient;
	create yaByPriority transient;
	
	if _row.allYardAllocations.size() = 0 then 
		self.allYARowHeights.add(0);
		return usedHeight;
	endif;
	
	//  Get Yard Allocations for row
	foreach ya in _row.allYardAllocations where ya.myTerminal &lt;&gt; null and not ya.isDisabled and not yaSet.includes(ya) do
			yaSet.add(ya);
	endforeach;
	
	//  Update associated YAM table
	
	if self.myYAMTable &lt;&gt; null then
		foreach ya in yaSet where not self.myYAMTable.allYardAllocationsByPriority.includes(ya) do
			self.myYAMTable.addItemYardAllocation(ya);
		endforeach;
	endif;

	
	yaSet.copy(yaByPriority);

	
	//  Display Yard Allocations
	
	idx := 0;
	usedHeight := 0;
		
	ly1 := _y2 + _row.getGLVDrawWidthInPixels(self.scaleFactor); 
	ly1 := ly1 - (4 * self.scaleFactor).Integer;
	lx1 := _x1;
	foreach ya in yaByPriority do
		idx := idx + 1;
		if _row.allYardAllocations.includes(ya) then
			
			len := _x2 - _x1;
			
			if self.allYardAllocationsFilter.isEmpty
			or self.allYardAllocationsFilter.includes(ya) then
				self.drawSelfYardAllocationLine( ya, lx1, ly1, len, LineHeight, usedHeight );
			endif;
			ly1 :=  ly1 + Padding + LineHeight;
			usedHeightTotal := usedHeightTotal + Padding + LineHeight;
		endif;
	endforeach;

	
	self.allYARows.putAtKey(_x1, _y1, _x2, _y2, _row);	
	self.allYARowHeights.add(usedHeightTotal);

	return usedHeightTotal; // Total height used to draw all YA lines

epilog
	self.myDrawingFrame.drawWidth := 1; // PAR 18682
	delete yaSet;
	delete yaByPriority;
end;</source>
        <access>protected</access>
        <Parameter name="_row" type="CM_RoRoController"/>
        <Parameter name="_x1" type="Integer"/>
        <Parameter name="_y1" type="Integer"/>
        <Parameter name="_x2" type="Integer"/>
        <Parameter name="_y2" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="filterYardAllocationLines" id="bc9b5eb0-5a67-40cf-94eb-29911ec33703">
        <updating/>
        <source>filterYardAllocationLines( _filter : CM_YardAllocationSet ) updating;
/*

Purpose:		Filter the Yard Allocations lines displayed on the frame

Parameters:		Collection of Yard Allocations for filter.  Null/none means no filtering to be applied.

Return Value:	None

Date				Who		Reason
12 November 2008	consw1	Initial creation

*/
begin
	if _filter = null then
		if self.allYardAllocationsFilter.isEmpty() then
			return;
		endif;
	elseif _filter.membersSame(self.allYardAllocationsFilter) then
		return;
	endif;

	self.allYardAllocationsFilter.clear();
	_filter.copy(self.allYardAllocationsFilter);
	
	self.refreshYardAllocationLines();
end;</source>
        <Parameter name="_filter" type="CM_YardAllocationSet"/>
    </JadeMethod>
    <JadeMethod name="getContainerHeight" id="cff99a22-3ea3-4fbc-853f-e6cfa8984c13">
        <source>getContainerHeight() : Real protected;
/*

Date		Who		Reason
10 July 2013	cnwer1	Initial creation PAR

*/

constants
	ContainerHeightFt = 8.5;
	ContainerFactorToMetres = 0.3048;

begin
	return ((ContainerHeightFt * ContainerFactorToMetres) * CM_RoRoLaneArea.GLV_RORO_PIXELS_PER_METRE) * self.scaleFactor;
epilog

end;</source>
        <access>protected</access>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="getFMLetter" id="c7d98198-4d22-40f3-8aa1-5abb5b179ac5">
        <source>getFMLetter(_ti : CM_TrackedItem; theFMLetter : String output);
/*

Date		Who		Reason
12 July 2013	cnwer1	Initial creation PAR

*/

vars

begin
    if self.allTIsQ.includes(_ti) then
		theFMLetter := theFMLetter &amp; "Q";
		if self.allTIsP.includes(_ti) then
			theFMLetter := theFMLetter &amp; "P";	
		endif;
		_ti.getFMLetter(theFMLetter);
	elseif self.allTIsP.includes(_ti) and not self.allTIsQ.includes(_ti) then
		theFMLetter := theFMLetter &amp; "P";
		_ti.getFMLetter(theFMLetter);
	elseif self.allTIsA.includes(_ti) then
		theFMLetter := theFMLetter &amp; "A";
		_ti.getFMLetter(theFMLetter);
	else
		return;
	endif;
end;
</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="theFMLetter" type="String" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getLaneHeight" id="c9cb309f-7055-4ad8-8e7d-35e0f80af520">
        <source>getLaneHeight() : Real protected;
/*

Date		Who		Reason
11 July 2013	cnwer1	Initial creation PAR

*/
constants
	ContainerHeightFt = 8.5;
	ContainerFactorToMetres = 0.3048;
	TrailerHeightPixels = 16;
vars
	containerHeight,
	trailerHeight,
	laneHeight : Real;
begin
	containerHeight:=((ContainerHeightFt * ContainerFactorToMetres) * CM_RoRoLaneArea.GLV_RORO_PIXELS_PER_METRE) * self.scaleFactor;
	trailerHeight:=16* self.scaleFactor;
	laneHeight:=trailerHeight + containerHeight;
	return laneHeight;
epilog

end;</source>
        <access>protected</access>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="getLengthPerFoot" id="ad2609d3-2d12-4c3e-809e-f5b3160965cb">
        <source>getLengthPerFoot(_feet: Integer ) : Integer protected;
/*

Date		Who		Reason
10 July 2013	cnwer1	Initial creation PAR

*/
constants
	ContainerFactorToMetres = 0.3048;
vars

begin
	return (((_feet * ContainerFactorToMetres) * CM_RoRoLaneArea.GLV_RORO_PIXELS_PER_METRE) * self.scaleFactor).Integer;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_feet" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getMetricFontSize" id="9b7cf102-1772-4ba6-9645-21230503b192">
        <source>getMetricFontSize()  : Real protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 December 2009	cnwjk3	Initial creation

*/

vars
	size : Real;
begin
	size := (self.METRIC_LABEL_FONT_SIZE * self.scaleFactor);
	if size &gt; self.METRIC_MAX_LABEL_FONT_SIZE then
		size := self.METRIC_MAX_LABEL_FONT_SIZE;
	elseif size &lt; self.METRIC_MIN_LABEL_FONT_SIZE then
		size := self.METRIC_MIN_LABEL_FONT_SIZE;
	endif;

	return size;
epilog

end;</source>
        <access>protected</access>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="getOverlayFrame" id="566ab0af-3d00-49e5-b17f-380e3632048b">
        <source>getOverlayFrame(_drawing : Boolean) : YRD_ContainerOverDrawingFrame;
// ---------------------------------------------------------------------------
// Created:		November 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
