    <JadeMethod name="canHaveAsChild" id="777d8677-c3ef-42f0-a11f-5a390abd2131">
        <source>canHaveAsChild(pProposedChildObj: Control; pRejectionReason: String output): Boolean;

begin
	if (not inheritMethod(pProposedChildObj, pRejectionReason)) then
		return false;
	endif; 

	if pProposedChildObj.isKindOf(BaseControl)
	or pProposedChildObj.isKindOf(Folder)
	or pProposedChildObj.isKindOf(Frame)
	or pProposedChildObj.isKindOf(GroupBox)
	or pProposedChildObj.isKindOf(ListBox)
	or pProposedChildObj.isKindOf(Picture)
	or pProposedChildObj.isKindOf(Table)
	or pProposedChildObj.isKindOf(TextBox)
	then
		return true;
	else
		pRejectionReason	:=	pProposedChildObj.class().name &amp; " controls not allowed in a CnEcSplitContainer";
		return false;
	endif;
end;</source>
        <Parameter name="pProposedChildObj" type="Control"/>
        <Parameter name="pRejectionReason" type="String" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="cnEcResizeContents" id="3d0f39b9-dd40-4137-a883-68833924da89">
        <updating/>
        <source>cnEcResizeContents() updating;

begin
	self.resizeChildrenAndSplitter(true);
end;</source>
    </JadeMethod>
    <JadeMethod name="cnEc_MouseUp" id="341c9048-7626-4612-8343-715660a48d68">
        <updating/>
        <source>cnEc_MouseUp(wndw: Window input; button: Integer; shift: Integer; x: Real; y: Real) updating, protected;

// Called by the splitter bar when the user mouse action is complete

begin
	// Calculate and set the new ratio, and resize the child controls
	
	if isSplitHorizontal then
		self.leftToRightRatio := (self.myHorizontalSplitter.top / self.clientHeight * 100).Integer;
	else
		self.leftToRightRatio := (self.myVerticalSplitter.left / self.clientWidth * 100).Integer;
	endif;
	
	self.resizeChildrenAndSplitter(false);

	// Invoke any form logic required after the move
	
	self.splitterMove(self);

	inheritMethod(wndw, button, shift, x, y);
end;</source>
        <access>protected</access>
        <Parameter name="wndw" type="Window" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="hideLeftControl" id="c66d68c6-3985-4f54-b66d-75f1f8c7ce1d">
        <updating/>
        <source>hideLeftControl() updating;
// ---------------------------------------------------------------------------
// Created:     14 November 2000 by cnwrs2
//
// Purpose:     Hides the left-hand control, plus the splitter bar.
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
begin
	self.myLeftControl.visible	:=	false;
	
	if self.isSplitHorizontal then
		self.myHorizontalSplitter.visible	:=	false;
	else
		self.myVerticalSplitter.visible		:=	false;
	endif;

	self.setLeftToRightRatio(0);
end;</source>
    </JadeMethod>
    <JadeMethod name="hideRightControl" id="d4e41a32-855b-4556-b556-92eda1151c49">
        <updating/>
        <source>hideRightControl() updating;
// ---------------------------------------------------------------------------
// Created:     19 December 2000 by cnwrs2
//
// Purpose:     Hides the right-hand control, plus the splitter bar.
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
begin
	self.myRightControl.visible	:=	false;
	
	if self.isSplitHorizontal then
		self.myHorizontalSplitter.visible	:=	false;
	else
		self.myVerticalSplitter.visible		:=	false;
	endif;

	self.setLeftToRightRatio(100);
end;</source>
    </JadeMethod>
    <JadeMethod name="initializeSplitter" id="cef06611-f613-4ea0-9505-11918695443c">
        <updating/>
        <source>initializeSplitter() protected, updating;
// Purpose:		Initial setup for the vertical splitter bar.

vars
	verticalObj		: CnEcVerticalSplitter;
	horizontalObj	: CnEcHorizontalSplitter;

begin
	if self.isSplitHorizontal then
		horizontalObj	:=	self.myHorizontalSplitter;

		if horizontalObj = null then
			create horizontalObj transient;
		endif;

		horizontalObj.parent	:=	self;
		self.form.addControl(horizontalObj);
   	else
		verticalObj	:=	self.myVerticalSplitter;

		if verticalObj = null then
			create verticalObj transient;
		endif;

		verticalObj.parent	:=	self;
		self.form.addControl(verticalObj);
 	endif;
epilog
	if isSplitHorizontal then
		self.myHorizontalSplitter	:=	horizontalObj;	
	else
		self.myVerticalSplitter		:=	verticalObj;
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="leftToRightRatio" id="a101ad5d-ed1e-4b5b-90d6-1f9752c76ba4">
        <methodInvocation>mapping</methodInvocation>
        <source>leftToRightRatio(set: Boolean; _value: Integer io) mapping, protected;

begin
	if set then
		if _value &lt; 0 or _value &gt; 100 then
			_value	:=	50;
		endif;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="lockBottom" id="00830848-f7cb-4759-8fb7-e0e75baca2e5">
