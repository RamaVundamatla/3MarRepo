    <JadeMethod name="btnExport_click" id="41017fcf-8498-4c9d-b374-da992bb27390">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnExport_click(btn: Button input) updating;
// ---------------------------------------------------------------------------
// Created:     11 February 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin
	self.doExport();

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doExport" id="3dd7d094-e349-4e64-9c42-a8ca361b9154">
        <source>doExport();
// ---------------------------------------------------------------------------
// Created:     11 February 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	js			: JadeScript;
	str,
	dirStr		: String;
	stage		: Integer;
begin
	create js transient;
	self.lblStatus.caption := null;
	self.lblStatus.visible := true;
	dirStr := self.txtDirectory.text.toLower;
	if (not dirStr.isFoldername) then
		str := 'Invalid directory path.';
		return;
	endif;
	
	if app.msgBox('Are you sure you to commence EXPORTATION of warehouse data from this environment','Are you sure', MsgBox_OK_Cancel + MsgBox_Exclamation_Mark_Icon) &lt;&gt; MB_OK then
		return;
	endif;
	return;
	self.lblStatus.caption := 'Exporting data...';
	self.lblStatus.doWindowEvents(0);
	str := 'A fatal exception has occured' &amp; CrLf &amp;
				'Please check log files';
	if self.txtStage.visible then
		stage := self.txtStage.text.Integer;
	endif;
//	cnwjr2  -  commented out next line as it called a JadeScript method - these methods were deleted 12/12/2011 - temporarily in DummySchema	
//	js.thExportWarehouseData(dirStr, stage);
	
	str := 'Extraction completed successfully';
	
epilog
	self.lblStatus.caption := str;
	delete js;
end;</source>
    </JadeMethod>
