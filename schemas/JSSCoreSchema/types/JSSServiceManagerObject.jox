    <JadeMethod name="getManager" id="2d8b88df-12fa-45ab-8d28-dd26d353c899">
        <source>getManager():JSSServiceManagerObject;
// --------------------------------------------------------------------------------
// Created:		03 April 2002 by cnwdad2
//
// Purpose:		Returns the receiver - this should be reimplemented on the peer
//				schema's subclass, to cast the subclass instance to the relevant
//				type.
//
// Parameters:	None
//
// Returns:		The receiver, recast as its subclass type.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return self;
end;</source>
        <ReturnType type="JSSServiceManagerObject"/>
    </JadeMethod>
    <JadeMethod name="getTA" id="c9eef8bf-4500-4d1a-90c1-828e267fbeae">
        <source>getTA():JSSTransactionAgent;
// --------------------------------------------------------------------------------
// Created:		04 April 2002 by cnwdad2
//
// Purpose:		Return the receiver's transaction agent object.
//
// Parameters:	None
//
// Returns:		The transaction agent object.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return self.myTA;
end;</source>
        <ReturnType type="JSSTransactionAgent"/>
    </JadeMethod>
    <JadeMethod name="getTAClass" id="268dcdb0-2609-4389-a8ab-8122b1de4d4f">
        <source>getTAClass():Class protected;
// --------------------------------------------------------------------------------
// Created:		04 April 2002 by cnwdad2
//
// Purpose:		This method must be reimplemented on the Package schema's subclass
