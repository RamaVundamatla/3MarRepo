		frame.caption := null;
		frame.borderStyle := 0;	
//	endif;
	
//	if not _doLayoutCheck then
		self.lbl20.caption := myWaybillPrintDetail.containerNumberStr;
		self.lbl21.caption := myWaybillPrintDetail.numberOfPackagesStr;
		self.lbl22.caption := myWaybillPrintDetail.packageTypeStr;
		self.lbl23.caption := myWaybillPrintDetail.loadingCommencedStr;
		self.lbl24.caption := myWaybillPrintDetail.loadingCompletedStr;
		self.lbl25.caption := myWaybillPrintDetail.remarksStr;
		self.lbl26.caption := myWaybillPrintDetail.goodsDescriptionStr;
		self.lbl27.caption := myWaybillPrintDetail.marksAndNumbersStr;
//	endif;
	
	self.lblLine4.left := 1;
	self.lblLine4.width := parentWidth;
	self.lblLine4.top := -10;
	
	self.lblContainerNo.top := 2;
	self.lblContainerNo.left := 1;
	
	self.lblNumPacks.top := 2;
	self.lblNumPacks.left := 27 * self.pixelsPerMM;
	
	self.lblPackType.top := 2;
	self.lblPackType.left := 51 * self.pixelsPerMM;
	
	self.lblLoadComm.top := 2;
	self.lblLoadComm.left := 80 * self.pixelsPerMM;
	
	self.lblLoadCompl.top := 2;
	self.lblLoadCompl.left := 129 * self.pixelsPerMM;
	
	topPixels := self.lblContainerNo.top + self.lblContainerNo.height + 1;
	heightPixels := self.lblContainerNo.height; // initial height
	leftMMs := 1;
	rightMMs := 26;
	self.moveDataLabel( frame, self.lbl20, topPixels, heightPixels, leftMMs, rightMMs, Label.Alignment_Left_Top, _doLayoutCheck );
	adjustedHeight := self.adjustHeight(self.lbl20);
	commonMaxHeight := adjustedHeight;
	
	leftMMs := 27;
	rightMMs := 50;
	self.moveDataLabel( frame, self.lbl21, topPixels, heightPixels, leftMMs, rightMMs, Label.Alignment_Left_Top, _doLayoutCheck );
	adjustedHeight := self.adjustHeight(self.lbl21);
	commonMaxHeight := commonMaxHeight.max(adjustedHeight);
	
	leftMMs := 51;
	rightMMs := 79;
	self.moveDataLabel( frame, self.lbl22, topPixels, heightPixels, leftMMs, rightMMs, Label.Alignment_Left_Top, _doLayoutCheck );
	adjustedHeight := self.adjustHeight(self.lbl22);
	commonMaxHeight := commonMaxHeight.max(adjustedHeight);
	
	leftMMs := 80;
	rightMMs := 128;
	self.moveDataLabel( frame, self.lbl23, topPixels, heightPixels, leftMMs, rightMMs, Label.Alignment_Left_Top, _doLayoutCheck );
	adjustedHeight := self.adjustHeight(self.lbl23);
	commonMaxHeight := commonMaxHeight.max(adjustedHeight);
	
	leftMMs := 129;
	rightMMs := 179;
	self.moveDataLabel( frame, self.lbl24, topPixels, heightPixels, leftMMs, rightMMs, Label.Alignment_Left_Top, _doLayoutCheck );
	adjustedHeight := self.adjustHeight(self.lbl24);
	commonMaxHeight := commonMaxHeight.max(adjustedHeight);
	
	self.lblRemarks.top := self.lbl20.top + commonMaxHeight + 1;
	self.lblRemarks.left := 1;
	
	self.lblGoodsDesc.top := self.lblRemarks.top;
	self.lblGoodsDesc.left := self.lblLoadComm.left;
	
	topPixels := self.lblRemarks.top + self.lblRemarks.height + 1;
	heightPixels := self.lblRemarks.height; // initial height
	leftMMs := 1;
	rightMMs := 79;
	self.moveDataLabel( frame, self.lbl25, topPixels, heightPixels, leftMMs, rightMMs, Label.Alignment_Left_Top, _doLayoutCheck );
	adjustedHeight := self.adjustHeight(self.lbl25);

	leftMMs := 80;
