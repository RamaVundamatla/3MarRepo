//	Date		Who		Reason
//	16/02/2022	NAVCS2	Bug 52844
// 	23/02/2022	NAVCS2	Bug 52844
//	24/02/2022	NAVCS2	Bug 52844
vars

begin
	//self.unloadForm;	
	self.showSheet(fldConfig.topSheet.CMUI_Sheet); //	23/02/2022	NAVCS2	Bug 52844
	self.setControlState(false); //	16/02/2022	NAVCS2	Bug 52844
	tblConfig.userInputEnabled := false; //	24/02/2022	NAVCS2	Bug 52844
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doBaseFormSave" id="151c2fbc-3fc2-4530-bf00-ae3a299b1501">
        <updating/>
        <source>doBaseFormSave() updating, protected;
// ---------------------------------------------------------------------------
// Created:     27 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 27 May 2014	cnwkpd1		PAR #34210 - CCMS SFW 1350 - Online Documentation
// 19 Sep 2022 	navam1 		ChangeRequest 52824: EUP - Azure Active Directory Single Sign On - MTN
// ---------------------------------------------------------------------------
vars
	newBackColor,
	saveBackColor	: Integer;
	theResult : Integer;	//14 Jan 2020 NDL	TFS 46815
	
begin
	app.mousePointer := MousePointer_HourGlass;
	saveBackColor := app.mainForm.backColor;
	
	self.saveSheet(fldConfig.topSheet);
	
	//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxUA.trxUpdateConfig(self.myIntFaceConfig, app.myRoot, self.expectedEdition,app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			break;
		else
			theResult := app.showErrorWarningDialog('System Config', app.myPassport, ErrWarnMode_Update);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		break;
		
	endwhile;
	
	
	
	if app.myPassport.noErrors then
	
		if app.mainForm.isKindOf(CMUI_SuperAppForm2) then
			newBackColor := app.myRoot.getConfig(AppBackgroundColor).Integer;
			
			if newBackColor &lt;&gt; saveBackColor then
				if newBackColor = 0 then
					newBackColor := self.backColor;
				endif;
				
				app.mainForm.CMUI_SuperAppForm2.setBackColor(newBackColor);
			endif;
			
			app.handleHelpFormatChange();				// PAR #34210
		endif;
		if self.selectedConfigRow &gt; 0 then
			self.tblConfig.cnEcSetCellBackColor(self.selectedConfigRow, 1, newBackColor); // TFS 52235 2NOV2021 NAVLW1
		endif;
		self.setControlState(false);
	else
		//54854, AjitM, navam1
		tblConfig.userInputEnabled := true;
		self.setControlState(true);
		self.tblConfig.setFocus();		
	endif;
	
	
	
epilog	
   //54854, AjitM, navam1
   if app.myPassport.noErrors then
		self.tblConfig.userInputEnabled := false;
		self.tblConfig.setFocus();					// TFS 54857
	endif;
	app.mousePointer := MousePointer_Default;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doEdit" id="13bf30d8-7297-447a-a396-5e093cce52d0">
        <updating/>
        <source>doEdit() updating;
// ---------------------------------------------------------------------------
// Created:     07 August 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 18/10/2022	navpw1		TFS: 55144 - Fixing row selection for config options selection
// ---------------------------------------------------------------------------
vars
	loadState : Boolean;
	
begin
	self.tblConfig.userInputEnabled := true;
	self.setControlState(true);
	
	self.tblConfig.clearAllSelected();	// ### TFS 55144 31Oct2022 NAVPW1
	
	if self.selectedConfigRow &gt; 0 then
		self.tblConfig.accessRow(self.selectedConfigRow).selected := true;			// TFS 52235 2NOV2021 NAVLW1
		self.tblConfig.cnEcSetCellBackColor(self.selectedConfigRow, 1, LightRed);	// TFS 52235 2NOV2021 NAVLW1
		self.tblConfig.topRow := self.selectedConfigRow;							// ### TFS 55144 18Oct2022 NAVPW1
		self.tblConfig.row := self.selectedConfigRow;								// ### TFS 55144 18Oct2022 NAVPW1
	elseif self.currentSelectedRow &gt; 0 then
		self.tblConfig.accessRow(self.currentSelectedRow).selected := true;			// TFS 52235 2NOV2021 NAVLW1
		self.tblConfig.cnEcSetCellBackColor(self.currentSelectedRow, 1, LightRed);	// TFS 52235 2NOV2021 NAVLW1
		self.tblConfig.topRow := self.currentSelectedRow;							// ### TFS 55144 18Oct2022 NAVPW1
		self.tblConfig.row := self.currentSelectedRow;								// ### TFS 55144 18Oct2022 NAVPW1
	endif;
	
	app.cmsBeginLoad(loadState);
	sharedLock(app.myRoot);
	self.expectedEdition := app.myRoot.edition;
	unlock(app.myRoot);		// cnwdad1 12/01/2007.
epilog
	app.cmsEndLoad(loadState);
end;</source>
    </JadeMethod>
