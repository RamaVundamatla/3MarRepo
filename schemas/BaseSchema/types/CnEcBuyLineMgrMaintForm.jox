    <JadeMethod name="btnUpdate_click" id="4f71a39d-1c22-42e2-97e1-2844cd41416e">
        <controlMethod name="JadeMask::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnUpdate_click(jadeMask: JadeMask input) updating;

begin
	self.updateMgr();
end;</source>
        <Parameter name="jadeMask" type="JadeMask" usage="input"/>
    </JadeMethod>
    <JadeMethod name="displayMgr" id="3bd5f5e5-d580-4983-a7a1-c264155b6397">
        <source>displayMgr(pManagerObj : CnEcBNZBuyLineMgr);

begin
	if pManagerObj &lt;&gt; null then
		txtEmail.text		:=	pManagerObj.buyLineAdminEmailAddress;
		txtETLPassword.text	:=	pManagerObj.buyLineETLpassword;
		txtOPSId.text		:=	pManagerObj.buyLineOPSId.String;
		txtPath.text		:=	pManagerObj.buyLinePath;
		txtRPassword.text	:=	pManagerObj.buyLineRpassword;
		txtServer.text		:=	pManagerObj.buyLineServer;
		txtSequence.text	:=	pManagerObj.buyLineSequenceNumber.String;
		txtVPassword.text	:=	pManagerObj.buyLineVpassword;
		txtTimeOut.text		:=	pManagerObj.timeOut.String;
		btnUpdate.enabled	:=	true;
	else
		btnUpdate.enabled := false;
	endif;
end;</source>
        <Parameter name="pManagerObj" type="CnEcBNZBuyLineMgr"/>
    </JadeMethod>
    <JadeMethod name="fileVisibility" id="bbc8517d-a952-4d4c-bbda-f15fd915d0c1">
        <source>fileVisibility();

begin
	mnuFile.enabled := false;
end;</source>
    </JadeMethod>
    <JadeMethod name="loadForm" id="8829e242-1df1-443c-aada-b553f8ffcbc3">
        <updating/>
        <source>loadForm() updating;

vars
	rootObj			: CnEcBaseRoot;
	managerObj		: CnEcBNZBuyLineMgr;
	agentObj		: CnEcBuyLineAgent;
	errorMessage	: String;
	
begin
	inheritMethod();
	
	rootObj	:=	app.myBaseRoot;
	
	if rootObj = null then
		app.msgBox("Base Root not set, has Application been initialized ??","Error",MsgBox_OK_Only);
		self.closeForm();
		return;
	endif;
	 
	managerObj	:=	app.myBaseRoot.myBuyLineMgr;
	
	if managerObj = null then
		create agentObj transient;
		errorMessage := agentObj.trxBNZBuyLineMgrCreate(rootObj,	//pMyBaseRoot : CnEcBaseRoot io; 
														null,	//pBuyLineAdminEmailAddress : String;
														null,	//pBuyLineETLpassword : String;
														null,	//pBuyLineOPSId : Integer;
														null,	//pBuyLinePath : String;
														null,	//pBuyLineRpassword : String;
														null,	//pBuyLineServer : String;
														null,	//pTimeOut : Integer;
														null,	//pBuyLineVpassword : String;
														managerObj	//pBNZBuyLineMgrNew : CnEcBNZBuyLineMgr output
														);
		if errorMessage &lt;&gt; null then
			app.msgBox("myTA.trxBNZBuyLineMgrCreate returned : '" &amp; errorMessage &amp; "'.","Error",MsgBox_OK_Only);
			closeForm();
		endif;												 
	endif;
	
	self.displayMgr(managerObj);
epilog
	delete agentObj;	
end;</source>
    </JadeMethod>
    <JadeMethod name="updateMgr" id="0891e4ae-1a49-4a05-9032-a6a1e91fd0eb">
        <source>updateMgr();
// 24/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls

vars
	rootObj			: CnEcBaseRoot;
	managerObj		: CnEcBNZBuyLineMgr;
	agentObj		: CnEcBuyLineAgent;
	errorMessage	: String;
	
begin
	rootObj		:=	app.myBaseRoot;
	managerObj	:=	app.myBaseRoot.myBuyLineMgr;
	
	if managerObj &lt;&gt; null then
		create agentObj transient;
		errorMessage := agentObj.trxBNZBuyLineMgrUpdate(managerObj,	//pBNZBuyLineMgrNew : CnEcBNZBuyLineMgr io;
														managerObj.edition(),	//edition : Integer;
														txtEmail.text,	//pBuyLineAdminEmailAddress : String;
														txtETLPassword.text,	//pBuyLineETLpassword : String;
														txtOPSId.text.Integer,	//pBuyLineOPSId : Integer;
														txtPath.text,	//pBuyLinePath : String;
														txtRPassword.text,	//pBuyLineRpassword : String;
														txtServer.text,	//pBuyLineServer : String;
														txtTimeOut.text.Integer,	//pTimeOut : Integer;
														txtVPassword.text	//pBuyLineVpassword : String;
														);
		if errorMessage &lt;&gt; null then
			app.msgBox("myTA.trxBNZBuyLineMgrUpdate returned : '" &amp; errorMessage &amp; "'.","Error",MsgBox_OK_Only);
			return;
		endif;
		
	endif;
	
	self.displayMgr(managerObj);
epilog
	delete agentObj;	
end;</source>
    </JadeMethod>
</GUIClass>
