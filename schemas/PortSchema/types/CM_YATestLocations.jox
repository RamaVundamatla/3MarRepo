epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="deleteData" id="7398a2aa-0c16-4bce-9ff9-617954392053">
        <source>deleteData();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 July 2013	cnwndl1	Initial creation	Par 32049

*/

vars

begin

	if not self.isEmpty then
		self.purge();
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getTestPlannedCargoCountFor" id="71e32729-49c2-457f-b2c9-fa0d47cdeb25">
        <source>getTestPlannedCargoCountFor( _selectedLC : CM_YardController ):Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 July 2013	cnwndl1	Initial creation	Par 32049
20 Oct 2022		jlier1  TFS 54675 20/10/22 - can autoplan to a trailer location which is not a yard location
*/

vars

	iter : Iterator;
	firstTestLoc : CM_YATestLocation;
	testLoc : CM_YATestLocation;
	count :	Integer;
	lc : CM_LocationsController;
	
begin

	if self.isEmpty or _selectedLC = null then
		return 0;
	endif;

	firstTestLoc := self.getAtKey( _selectedLC );
	if firstTestLoc = null then
		return 0;
	endif;
	
	iter := self.createIterator;
	iter.startAtObject( firstTestLoc );
	
	while iter.next( testLoc ) do
		lc := testLoc.myLocation;
		if lc = _selectedLC then
			//epr par 37319 13/1/16
			if testLoc.endOffset = 0 then
// TFS 43424				count := count + 1;
				count := count + testLoc.getTestCount(); // TFS 43424 use the quantity of the TI if necessary
			endif;
		else
			break;
		endif;
	endwhile;
	
	return count;
	
epilog

	delete iter;
	
end;</source>
        <Parameter name="_selectedLC" type="CM_YardController"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getTestPlannedCargoHeightFor" id="55f06fe0-5d86-41f1-9d6a-21c0b1432a2b">
        <source>getTestPlannedCargoHeightFor( _selectedLC : CM_YardController ):Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 July 2013	cnwndl1	Initial creation	Par 32049
20 Oct 2022		jlier1  TFS 54675 20/10/22 - can autoplan to a trailer location which is not a yard location
*/

vars

	iter : Iterator;
	firstTestLoc : CM_YATestLocation;
	testLoc : CM_YATestLocation;
	totalHeight	:	Integer;
	lc : CM_LocationsController;
	ti : CM_TrackedItem;
	
begin

	if self.isEmpty or _selectedLC = null then
		return 0;
	endif;

	firstTestLoc := self.getAtKey( _selectedLC );
	if firstTestLoc = null then
		return 0;
	endif;
	
	iter := self.createIterator;
	iter.startAtObject( firstTestLoc );
	
	while iter.next( testLoc ) do
		lc := testLoc.myLocation;
		
		if lc = _selectedLC then
			//epr par 37319 13/1/16
			if testLoc.endOffset = 0 then
				ti := testLoc.myTrackedItem;
				totalHeight := totalHeight + ti.getHeightOfTI();
			endif;
		else
			break;
		endif;
	endwhile;
	
	if totalHeight &lt; 0 then
		totalHeight := 0;
	endif;
	
	return totalHeight;
	
epilog

	delete iter;
	
end;
</source>
        <Parameter name="_selectedLC" type="CM_YardController"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getTestPlannedCargoLengthFor" id="fa02b04f-387f-4099-ba74-a95a8a0f772b">
        <source>getTestPlannedCargoLengthFor( _selectedLC : CM_YardController ):Decimal;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 July 2013	cnwndl1	Initial creation	Par 32049
20 Oct 2022		jlier1  TFS 54675 20/10/22 - can autoplan to a trailer location which is not a yard location
*/

vars

	iter : Iterator;
	firstTestLoc : CM_YATestLocation;
	testLoc : CM_YATestLocation;
	totalLength : Decimal[6,2];
	lc : CM_LocationsController;
	ti : CM_TrackedItem;
	
begin

	if self.isEmpty or _selectedLC = null then
		return 0;
	endif;

	firstTestLoc := self.getAtKey( _selectedLC );
	if firstTestLoc = null then
		return 0;
	endif;
	
	iter := self.createIterator;
	iter.startAtObject( firstTestLoc );
	
	while iter.next( testLoc ) do
		lc := testLoc.myLocation;
		ti := testLoc.myTrackedItem;
		if lc = _selectedLC then
			//epr par 37319 13/1/16
			if testLoc.endOffset = 0 then
				if _selectedLC.isKindOf(CM_RoRoController) then
					totalLength := totalLength + _selectedLC.CM_RoRoController.getTILengthInMetres(ti);
				else
					totalLength := totalLength + ti.getLengthInMetres();
				endif;
			endif;
		else
			break;
		endif;
	endwhile;
	
	if totalLength &lt; 0 then
		totalLength := 0;
	endif;
	
	return totalLength;
	
epilog

	delete iter;
	
end;
</source>
        <Parameter name="_selectedLC" type="CM_YardController"/>
        <ReturnType type="Decimal"/>
    </JadeMethod>
</CollClass>
