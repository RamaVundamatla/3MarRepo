    <JadeMethod name="init" id="d71786e9-fa09-433d-85b6-9be7ceccda5c">
        <updating/>
        <source>init(_obj : CM_Object) : Boolean updating;
// ---------------------------------------------------------------------------
// Created:     27 January 2003 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	
	if _obj = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Null license object');
		return false;
	endif;
	
	if _obj.class.name &lt;&gt; CM_Root.name and
	   _obj.class.name &lt;&gt; CM_Terminal.name then
		app.raiseCMException(ErrInvalidLicenseClass, null, null);
		return false;
	endif;

	self.myLicenseObject := _obj;
	
	return true;

end;</source>
        <Parameter name="_obj" type="CM_Object"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
