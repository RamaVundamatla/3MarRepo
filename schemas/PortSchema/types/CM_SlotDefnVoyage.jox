    <JadeMethod name="useBayCellTierNumbering" id="7b14d8f6-72a6-4dd3-b4d8-790b94ce8e6b">
        <source>useBayCellTierNumbering() : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
11 May 2009	cnwer1	Initial creation

*/

vars
	voyage : CM_Voyage;
	structure : CM_CellularVoyageStructure;
begin
	voyage:=self.getVoyage;
	if voyage = null then
		return false;
	endif;
	structure :=voyage.myCellularVoyageStructure;
	if structure = null then
		return false;
	endif;
	return structure.useBayCellTierNumbering;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
