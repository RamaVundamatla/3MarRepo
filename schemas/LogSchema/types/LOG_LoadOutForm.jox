    <JadeMethod name="doReleaseByRoad" id="daa8ab21-7251-4c6f-9964-6a4dee7a86e3">
        <updating/>
        <source>doReleaseByRoad(_intFaceItem : LOGIF_BOLOut input)updating;
//--------------------------------------------------------------
//Created: 22 October 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	bolOutHdr,
	pxyHdr		: CM_BOLOutHeader;
	now 		: TimeStamp;
	logId		: String;
begin
	now := app.actualTimeServer();	// 21/4/16 cnwmp6 TFS 488 - Multi timezone support
	
	create pxyHdr transient;
	
	pxyHdr.setProxy(_intFaceItem.bolType, _intFaceItem.bolNumber, _intFaceItem.operatorCode, _intFaceItem.scalerCode, now, self.myTerminal);
	self.allLogIds.copy(pxyHdr.allTrackedItemIDs);
	
	app.myTrxCA.trxCreateBOLOutHdr(pxyHdr, bolOutHdr, app.myPassport);

epilog
	delete pxyHdr;
end;</source>
        <Parameter name="_intFaceItem" type="LOGIF_BOLOut" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doResize" id="5540ac89-897f-425d-b093-f1a47a3a9a9c">
        <updating/>
        <source>doResize()updating;
//--------------------------------------------------------------
//Created: 10 June 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	tmpTop : Real;
begin

	if self.frmToolbar.visible then
		self.frmToolbar.repositionAfterResize;
	endif;

	tmpTop := self.topMargin + VerticalSpacing;
	self.optLoadOutItem.top := tmpTop;
	self.optLoadOutLocn.top := tmpTop;
	self.optNoNumber.top := tmpTop;
	
	tmpTop := tmpTop + optLoadOutItem.height + WinTopMargin;
	//Folder
	self.fldMain.top := tmpTop;
	self.fldMain.width := (self.width - WinLeftMargin - WinRightMargin);
	self.fldMain.height := (self.height - self.fldMain.top - WinBottomMargin - VerticalSpacing);
	self.fldMain.left := (WinLeftMargin);
	self.fldMain.cnEcResizeContents();

	// Bottom Buttons
/*	btnCancel.top	:= self.height - WinBottomMargin - btnCancel.height;
	btnCancel.left	:= self.width - WinRightMargin - btnCancel.width;
	
	btnSave.top		:= btnCancel.top;
	btnSave.left	:= btnCancel.left - HorizontalSpacing - btnSave.width;
	
	btnNext.top		:= btnCancel.top;
	btnNext.left	:= btnSave.left - HorizontalSpacing - btnNext.width;	*/

	//Sheets
	self.resizeTopSheet();	
end;</source>
    </JadeMethod>
    <JadeMethod name="doSave" id="617ee6f1-23f0-4724-8163-f2ee7d63c6aa">
        <updating/>
        <source>doSave() : Boolean updating;
//--------------------------------------------------------------
//Created: 11 June 2002 By: cnwgd1
//--------------------------------------------------------------
// 24/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
vars
	amount 		: Real;
	intFaceItem : LOGIF_BOLOut;
	newBOL		: CM_BOL;
	errorSet	: CM_ErrorSet;
	docketNum	: String;
	theResult : Integer;	//15 Jan 2020 NDL	TFS 46815
	
begin
	// Sep 2011 28082 don't allow save for closed etc voyages
	if self.filterVoyage &lt;&gt; null and
	   self.filterVoyage.isClosedStatus() then
		app.msgBox("This voyage status is " &amp; self.filterVoyage.statusDescription &amp; "," &amp; CrLf &amp; "no updates are allowed.", "Error", 0);
		return false;
	endif;

	app.mousePointer := MousePointer_HourGlass;
	
	if self.mode = Mode_Update then
		return self.doEdit();
	endif;
	
	docketNum := self.tblHeaderDtls.getValueByName(ETRow_DocketNumber).String;
		
	on CM_Exception do app.validationExHandler(exception, app.myPassport);
	app.setContinueCMExceptions(true);
	app.myPassport.clearErrorsWarnings();
	
	create intFaceItem transient;
	intFaceItem.setDataFromTable(tblHeaderDtls, null, null, self.myAssistant.LOG_Assistant);	
	intFaceItem.transportMode := self.transportMode;		
	intFaceItem.userCode := app.getMyUserCode;
	intFaceItem.bolType := BOLType_Log;
		
	if intFaceItem.myOperator = null and self.filterOperator &lt;&gt; null then
		intFaceItem.operatorCode := self.filterOperator.code;
		intFaceItem.myOperator := self.filterOperator;
	endif;
	
	//Do save by Item IDs Sheet
	if self.optLoadOutItem.value then
		self.saveByItem();
		//Do save by Location Details Sheet		
	elseif self.optLoadOutLocn.value then
		if self.optLocnDtlsLogs.value then
			self.saveByLocationLogIds();
		elseif self.optLocnDockets.value then
			self.saveByLocationDockets();
		else
			self.saveByLocation();
		endif;
		//Do save by No Number Sheet	
	elseif self.optNoNumber.value then
		self.saveByNoNumber(intFaceItem);
	endif;

	self.validate();
	
	if (not app.myPassport.noErrors) then
		app.showErrorWarningDialog('Loadout', app.myPassport, ErrWarnMode_Add);
		self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
		return false;
	else
		self.clearErrorWarnings();
		on CM_Exception do null;	// disarm the validation ex handler
	endif;

	amount := tblHeaderDtls.getValueByName(ETRow_Quantity).Real;
	self.allTrackedItems.copy(intFaceItem.allTrackedItems);
	self.allLogIds.copy(intFaceItem.allLogIds);
	
	if self.optLoadOutLocn.value then	
		//volume and weight only applicable to location
		if intFaceItem.unitOfMeasure = BOL_UOM_PIECE_COUNT then
			intFaceItem.numItems := amount.Integer;
		elseif intFaceItem.unitOfMeasure =  BOL_UOM_VOLUME then
			intFaceItem.reqdAmount := amount;
			intFaceItem.numItems := intFaceItem.allTrackedItems.size;		
		elseif intFaceItem.unitOfMeasure = BOL_UOM_WEIGHT then
			intFaceItem.weightNetTonnes := amount;
			intFaceItem.weightGrossTonnes := amount;
			intFaceItem.numItems := intFaceItem.allTrackedItems.size;				
		endif;
	else	//by item can only be piece count option
		intFaceItem.numItems := amount.Integer;
	endif;
	
	if self.transportMode = TI_TRANSMODE_ROAD then
		self.doReleaseByRoad(intFaceItem);			
	elseif self.transportMode = TI_TRANSMODE_RAIL then
		self.doReleaseByRail(intFaceItem);		
	elseif self.transportMode = TI_TRANSMODE_SHIP then
		if self.setForReleaseByVoyage(intFaceItem) then//changed by cnwyl1 for par 15294
			intFaceItem.doNotMoveAsPartOfCreate := true;
			
			//15 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
			while true do
			
				app.myTrxCA.trxCreateBOLOutAndLoadOutLogs(intFaceItem, app.myPassport);	
			
				if app.myPassport.trxCompletedOK then
					break;
				else
					theResult := app.showErrorWarningDialog('Load Out', app.myPassport, ErrWarnMode_AddUpdate);
					if app.myPassport.noErrors and theResult = IDOK then
						app.myPassport.warningsAcknowledged	:= true;
						continue;
					endif;
				endif;
				
				return false;
				
			endwhile;
		endif;
	endif;
	
	if not app.myPassport.trxCompletedOK or
	   app.myPassport.hasErrors() then		// 27694 errors to report from failed trx (may be completed OK from delete BOL)
		app.showErrorWarningDialog('Load Out', app.myPassport, ErrWarnMode_AddUpdate);
		self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
		return false;
	else
		self.clearErrorWarnings();
	endif;

	self.allLogIds.clear;
	self.allTrackedItems.clear;
	self.allTIArray.clear;
	return true;

epilog
	app.mousePointer := MousePointer_Default;
	delete intFaceItem;
	delete errorSet;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="filterOnBoard" id="23f68eed-7272-47f2-8bc2-2db3ee4e193e">
        <source>filterOnBoard();
//--------------------------------------------------------------
//Created: 06 September 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	lot : CM_LogLot;
	placeStr : String;
	hatch, place : Integer;
begin
	app.mousePointer := MousePointer_HourGlass;
	if cmbFilterLot.itemObject &lt;&gt; null then
		lot := cmbFilterLot.listObject.CM_LogLot;
	endif;
	if cmbFilterHatch.text &lt;&gt; null then
		hatch := cmbFilterHatch.text.Integer;
	endif;
	if cmbFilterPlace.text &lt;&gt; null then
		placeStr := cmbFilterPlace.text;
		place := app.vesselPlaceStrToEnum(placeStr);
	endif;

	self.showLogsOnBoard(lot, hatch, place);

epilog
	app.mousePointer := MousePointer_Default;

end;</source>
    </JadeMethod>
    <JadeMethod name="fldMain_sheetChg" id="ebdf9c05-73b9-4577-b9d5-583baec779b6">
        <controlMethod name="Folder::sheetChg"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>fldMain_sheetChg(folder: Folder input) updating;
//--------------------------------------------------------------
//Created: 11 June 2002 By: cnwgd1
//--------------------------------------------------------------
vars

begin

	//Par13895 cnwsh3 17/04/2007 Product code was only be rebuilt on the length lost focus.  This was a problem when other specs were being changed as the new
	//values were not being reflected in the filter product code and therefore returning incorrect Row allocations.
	self.setFilterProductCode();
	
	if folder.topSheet = self.shtItemDetails then
		self.setupShtItemDetails();
	elseif folder.topSheet = self.shtLocationDtls then
		self.setupShtLocationDtls();
	elseif folder.topSheet = self.shtNoNumbers then
		self.setupShtNoNumbers();		
	elseif folder.topSheet = self.shtOnBoard then
		self.setupShtOnBoard();				
	endif;
	self.resizeTopSheet();
end;</source>
        <Parameter name="folder" type="Folder" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getBOLDict" id="07bc36a9-a43a-424e-9382-0f5ba3b9f28a">
        <source>getBOLDict(_dict : CM_BOLByTypeNumberDTDict input);
//--------------------------------------------------------------
//Created: June 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	lc	: CM_LocationsController;
	lcSet : CM_LCSet;
	ti : CM_TrackedItem;
	iter : Iterator;
	sohLocn : CM_SOHLocation;
begin
	
	if self.filterLogLocation = null then
		app.raiseCMException3(UNEXPECTED_PROGRAM_ERROR, class.name, method.name, 
							  'Filtering by BOL. Location is null.', null, null);
		return;
	endif;	
	//Filter by log location controller 
	foreach sohLocn in self.filterLogLocation.allProductLocations do
		iter := sohLocn.allTrackedItemsByReceivalBOL.createIterator;
		sohLocn.allTrackedItemsByReceivalBOL.startKeyGtr(null, iter);
		while iter.next(ti) do
			if ti.myReceivalBOL &lt;&gt; null and not _dict.includes(ti.myReceivalBOL) then
				_dict.add(ti.myReceivalBOL);
			endif;
		endwhile;
		delete iter;
	endforeach;

epilog
	delete iter;
end;</source>
        <Parameter name="_dict" type="CM_BOLByTypeNumberDTDict" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getBOLsForDict" id="3d20d530-cfd8-4d9f-b28a-646c39cea1e5">
        <source>getBOLsForDict();
//--------------------------------------------------------------
//Created: June 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	dict : CM_BOLByTypeNumberDTDict;
	iter : Iterator;
	bol : CM_BOL;
begin

	create dict transient;
	if self.filterLogLocation &lt;&gt; null then
		self.getBOLDict(dict);
	else
		self.myTerminal.allBOLsReceivedByTypeNumberDT.copy(dict);
	endif;

	iter := dict.createIterator;
	dict.startKeyGeq(BOLType_Log, null, null, iter);

	while iter.next(bol) do
		if bol.bolType &lt;&gt; BOLType_Log then
			continue;
		endif;
		self.myDynaDict.add(bol);
	endwhile;

epilog
	delete iter;
	delete dict;
end;</source>
    </JadeMethod>
    <JadeMethod name="getLocationsForNNData" id="4697c1a7-32ed-4125-ba1b-801138746d6a">
        <source>getLocationsForNNData();
//--------------------------------------------------------------
//Created: 12 June 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	sohLocn : CM_SOHLocation;
	locnController : CM_LocationsController;
	lcSet : CM_LCSet;
begin

	if self.filterVoyage = null or tblNNData.myDataClass &lt;&gt; CM_SOHLocation then
		app.raiseCMException3(UNEXPECTED_PROGRAM_ERROR, class.name, method.name, 
							  'Filtering by Voyage. Voyage is null.', null, null);
		return;
	endif;
	self.tblNNData.myDynaDict.clear();
	self.tblNNData.rows := 	self.tblNNData.fixedRows;
	create lcSet transient;
	self.filterVoyage.getAllAllocatedRows(lcSet);

	foreach locnController in lcSet do
		foreach sohLocn in locnController.allProductLocations do
			if self.filterProductCode = sohLocn.myProduct.code then
				tblNNData.myDynaDict.add(sohLocn);
			endif;
		endforeach;
	endforeach;
	
epilog
	delete lcSet;
end;</source>
    </JadeMethod>
    <JadeMethod name="getTIsForArray" id="848f94f1-52e2-4e03-9cda-86c4c1e363a8">
        <source>getTIsForArray();
// ---------------------------------------------------------------------------
// Created:     30 March 2006	cnwhjg1
//
// Purpose:     //	created for Par9691 - was not adding right speced logs first. 
// ----------   ----------  --------------------------------------------------
// 24/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
vars
	haveId	: Boolean;
	str,
	strReleaseDkt,	
	strLogCode,
	tmpId : String;
	idLength : Integer;
	iter : Iterator;
	ti : CM_TrackedItem;
	dict : CM_LogByFellDateDict;
	//count : Integer;
	strArray : StringArray;	
	log : CM_Log;
	tiSet : CM_TISet;
begin

	if self.filterLogLocation = null then
		return;
	endif;
	
	create dict transient;
	create strArray transient;
	create tiSet transient;
	foreach ti in self.filterLogLocation.allTrackedItemsById do
		if ti.myReleaseBOL = null then
			dict.add(ti.CM_Log);
		else
			if ti.myReleaseBOL.number &lt;&gt; self.tblHeaderDtls.getValueByName(ETRow_DocketNumber).String then 
			// if bol is same then docket already entered. dont raise error as this method gets called after a save and shows error msg. 
			// later validation will check for dup dockets - PAR 11618
				if ti.myReleaseBOL.myVoyage &lt;&gt; null then		
					str :=  'Dkt: ' &amp; ti.myReleaseBOL.number &amp; ' Voyage: ' &amp; ti.myReleaseBOL.myVoyage.code;
				else
					str :=  'Dkt: ' &amp; ti.myReleaseBOL.number;			
				endif;
				if (not strArray.includes(str)) then
					strArray.add(str);			
					strReleaseDkt := str &amp; '; ' &amp; strReleaseDkt;		
				endif;
			endif;
		endif;
	endforeach;

	//count := self.tblHeaderDtls.getValueByName(ETRow_Quantity).Integer;
	haveId := (self.txtIdFilter.text &lt;&gt; null);
	if dict &lt;&gt; null then
		if haveId then
			tmpId	 := self.txtIdFilter.text;
			idLength := tmpId.length;
			iter := dict.createIterator;
			while iter.next(ti) do
				if ti.id[1 : idLength] &lt;&gt; tmpId then
					break;
				endif;
				if ti.cargoType = TI_CargoType_Log then
					self.myDynaDict.add(ti);
				endif;
			endwhile;
		else
			iter := dict.createIterator;
			while iter.next(ti) do
					log := ti.CM_Log;
					if self.filterProductCode &lt;&gt; null then // sort and add to allTIArray
						strLogCode := app.buildLogProductCode(log.speciesCode, log.gradeCode, log.typeCode, log.treatmentCode,log.lengthCode);
						if self.filterProductCode = strLogCode then
							self.allTIArray.add(log);
							tiSet.add(log); 
							if not self.myDynaDict.includes(ti) then
								self.myDynaDict.add(ti); // add in hear as well just to satisfy latter requiremnts
							endif;
						endif;							
					else
						self.myDynaDict.add(ti); 
					endif;
			endwhile;
			iter.reset;  
			while iter.next(ti) do // put rest in array after sorted ones
				if not tiSet.includes(ti) then 
					self.allTIArray.add(ti);
					if not self.myDynaDict.includes(ti) then
						self.myDynaDict.add(ti); // add in hear as well just to satisfy latter requiremnts
					endif;
				endif;
			endwhile;					

		endif;
	endif;

	if self.myDynaDict.isEmpty then
		if strReleaseDkt &lt;&gt; null then
			app.raiseCMException2(LogAlreadyAssignedToBOL, self.filterLogLocation.getID(), strReleaseDkt, null, null);
		endif;
	endif;
	
epilog
	delete strArray;
	delete iter;
	delete dict;
	delete tiSet;
end;</source>
    </JadeMethod>
    <JadeMethod name="getTIsForDict" id="b00e9ab6-a8ed-4983-bce8-d7626a2adf01">
        <source>getTIsForDict();
//--------------------------------------------------------------
//Created: June 2002 By: cnwgd1
//--------------------------------------------------------------
// 24/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
vars
	haveId	: Boolean;
	str,
	strReleaseDkt,	
	tmpId : String;
	idLength : Integer;
	iter : Iterator;
	ti : CM_TrackedItem;
	dict : CM_LogByFellDateDict;
	//count : Integer;
	strArray : StringArray;	
begin

	if self.filterLogLocation = null then
		return;
	endif;
	
	create dict transient;
	create strArray transient;
	foreach ti in self.filterLogLocation.allTrackedItemsById do
		if ti.myReleaseBOL = null then
			dict.add(ti.CM_Log);
		else
			if ti.myReleaseBOL.number &lt;&gt; self.tblHeaderDtls.getValueByName(ETRow_DocketNumber).String then 
			// if bol is same then docket already entered. dont raise error as this method gets called after a save and shows error msg. 
			// later validation will check for dup dockets - PAR 11618
				if ti.myReleaseBOL.myVoyage &lt;&gt; null then
					str :=  'Dkt: ' &amp; ti.myReleaseBOL.number &amp; ' Voyage: ' &amp; ti.myReleaseBOL.myVoyage.code;
				else
					str :=  'Dkt: ' &amp; ti.myReleaseBOL.number;			
				endif;
				if (not strArray.includes(str)) then
					strArray.add(str);			
					strReleaseDkt := str &amp; '; ' &amp; strReleaseDkt;		
				endif;
			endif;
		endif;
	endforeach;

	//count := self.tblHeaderDtls.getValueByName(ETRow_Quantity).Integer;
	haveId := (self.txtIdFilter.text &lt;&gt; null);
	if dict &lt;&gt; null then
		if haveId then
			tmpId	 := self.txtIdFilter.text;
			idLength := tmpId.length;
			iter := dict.createIterator;
			while iter.next(ti) do
				if ti.id[1 : idLength] &lt;&gt; tmpId then
					break;
				endif;
				if ti.cargoType = TI_CargoType_Log then
					self.myDynaDict.add(ti);
				endif;
			endwhile;
			delete iter;
		/*elseif self.optLocnDtlsLocn.value then
			iter := dict.createIterator;
			while iter.next(ti) do
				if count = 0 then
					break;
				endif;
				self.myDynaDict.add(ti);
				count := (count - 1);
			endwhile;
			delete iter;*/
		else
			iter := dict.createIterator;
			while iter.next(ti) do
				self.myDynaDict.add(ti);
			endwhile;
			delete iter;
		endif;
	endif;

	if self.myDynaDict.isEmpty then
		if strReleaseDkt &lt;&gt; null then
			app.raiseCMException2(LogAlreadyAssignedToBOL, self.filterLogLocation.getID(), strReleaseDkt, null, null);
		endif;
	endif;
	
epilog
	delete strArray;
	delete iter;
	delete dict;
end;</source>
    </JadeMethod>
    <JadeMethod name="getXMLSettingsForSave" id="f2e733f9-567f-49b2-8c46-b7e1d863b363">
        <updating/>
        <source>getXMLSettingsForSave(): String updating;
// ---------------------------------------------------------------------------
// Created:     15 April 2005	cnwhjg1
//
// Purpose:     Par 9691 - sorting rows. Column organiser added
// ----------   ----------  --------------------------------------------------
vars
	str,
	mainRatio,
	rtnStr		: String;
begin
	rtnStr := inheritMethod();

//	if self.optLocnDockets.value then
		str := self.tblLocationDock.getXmlStrForColumns(true);
//	elseif self.optLocnDtlsLogs.value then
		// saves columns only for log location dtls. 
		//extra code needed to deal with dockets which use same table
		str := str &amp; self.tblLocationDtls.getXmlStrForColumns(true);
//	endif;

	return rtnStr &amp; str;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="handleTableTab" id="8ef2792e-4d6a-475a-a306-47d91d92107b">
        <updating/>
        <source>handleTableTab(keyCode: Integer io; shift: Integer) updating;
//--------------------------------------------------------------
//Created: 25 June 2002 By: cnwgd1
//--------------------------------------------------------------
vars	
	theTable : LOG_BulkTable;
	theActiveControl : Control;
	theSheet : JadeTableSheet;
	topSheetNo	: Integer;
	
begin

	if self.fldMain.topSheet = self.shtItemDetails then
		if keyCode &lt;&gt; J_key_Tab then 
			return;
		endif;
		theActiveControl := app.activeControl;
		if theActiveControl.isKindOf(LOG_BulkTable) then
			theTable := theActiveControl.LOG_BulkTable;
		elseif theActiveControl.parent.isKindOf(LOG_BulkTable) then
			theTable := theActiveControl.parent.LOG_BulkTable;
		else
		endif;

		tblItems01.handleFormTab(keyCode, shift, tbRequired, tblItems02);
		tblItems02.handleFormTab(keyCode, shift, tblItems01, tblItems03);
		tblItems03.handleFormTab(keyCode, shift, tblItems02, tblItems04);
		tblItems04.handleFormTab(keyCode, shift, tblItems03, tblItems05);
		tblItems05.handleFormTab(keyCode, shift, tblItems04, tblItems06);
		tblItems06.handleFormTab(keyCode, shift, tblItems05, tblItems01);															


		if theTable = null then
			return;
		endif;

		theTable.handleTableTab(shift);
		if theTable = tblItems06 and shift = 0 and
		   theTable.accessSheet(theTable.topSheet).row = theTable.rows then
			self.doNextPrevSheetTblItems(true);
			
			topSheetNo := tblItems01.topSheet;
			tblItems01.accessSheet(topSheetNo).row := 1;
			tblItems01.accessSheet(topSheetNo).column := 1;
			tblItems01.setFocus();
		endif;
		self.calculateItems();
	endif;		
end;</source>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="initForReleaseByRoad" id="3ffda1d1-8613-4042-9005-4e9542d315c6">
        <updating/>
        <source>initForReleaseByRoad(_selectedHdr : CM_BOLOutHeader input) updating;
//--------------------------------------------------------------
//Created: October 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	entTableDef : EntTableDef;
	view		: EntTableView;
	ls			: Boolean;
begin

	self.caption				:= self.myTerminal.code &amp; ' ' &amp; 'Domestic Load Out';
	self.transportMode 			:= TI_TRANSMODE_ROAD;		
	self.shtOnBoard.visible 	:= false;
	self.optNoNumber.visible 	:= false;		
	self.optLoadOutLocn.visible := false;
	
//	self.tblHeaderDtls.warningMethod := 'entTableWarning';
	entTableDef := app.myController.getEntTableDef(ETDef_LoadOutHeader);
//	self.tblHeaderDtls.setEntTableDef(entTableDef, null, 'entTableDefSetupWarning');
//	This code already run in initTableHeader. Running twice causes enttabledef to have double up rows. 


	view := entTableDef.allEntTableViews['LogLoadOutDomestic'];	

	if view &lt;&gt; null then
		self.tblHeaderDtls.showHideRowsByView(view, CM_EntryTable.ShowHideRows, false);
	else
		self.tblHeaderDtls.showHideRowsByList(null, CM_EntryTable.ShowHideRows, false);
	endif;

	if _selectedHdr &lt;&gt; null then
		app.cmsBeginLoad(ls);	
		sharedLock(_selectedHdr);
		self.mode 				:= Mode_Update;
		self.objectEdition 		:= _selectedHdr.edition();
		self.myCurrentObject 	:= _selectedHdr;
		self.setTblHdrValues(_selectedHdr);
		self.setTblItemValues(_selectedHdr);		
	else
	// bothe controls populate on gotfocus of CMUI_comboBoxObject
//		self.myAssistant.comboBoxSupplier(self.cmbOperator, null);	
//		self.myAssistant.comboBoxUser(self.cmbUser, null);		
	endif;
	
	self.btnNextT.visible := false;
	self.tblHeaderDtls.goToRowByName(ETRow_Supplier);
	self.tblHeaderDtls.setFocus();
	self.tblHeaderDtls.moveFirst();
	
epilog
	app.cmsEndLoad(ls);
end;</source>
        <Parameter name="_selectedHdr" type="CM_BOLOutHeader" usage="input"/>
    </JadeMethod>
    <JadeMethod name="initTableHeader" id="3daa1ddc-0e9a-456a-94d2-899f8192d4f7">
        <source>initTableHeader();
//--------------------------------------------------------------
//Created: 10 June 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	view		: EntTableView;
	entTableDef : EntTableDef;
	voyCode		: String;
begin

	self.tblHeaderDtls.setTerminologyRelevant(app.myRoot.allBOLTypes[BOLType_Log], self.myTerminal);
	self.tblHeaderDtls.stretchToParent := true;
	self.tblHeaderDtls.warningMethod := 'entTableWarning';
	entTableDef := app.myController.getEntTableDef(ETDef_LoadOutHeader);
	self.tblHeaderDtls.setEntTableDef(entTableDef, null, 'entTableDefSetupWarning');

	view := entTableDef.allEntTableViews['LogLoadOut'];	
	if view &lt;&gt; null then
		self.tblHeaderDtls.showHideRowsByView(view, CM_EntryTable.ShowHideRows, false);
	else
		self.tblHeaderDtls.showHideRowsByList(null, CM_EntryTable.ShowHideRows, false);
	endif;

	self.myAssistant.comboBoxVoyageCode(self.cmbVoyage, null, false, true);
	self.myAssistant.comboBoxStevedore(self.cmbStevedore, null);
	self.myAssistant.LOG_Assistant.comboBoxPlace(self.tblHeaderDtls, ETRow_Place);
	self.myAssistant.LOG_Assistant.comboBoxUnitOfMeasure(self.tblHeaderDtls, ETRow_UnitOfMeasure, true);
	
	self.tblHeaderDtls.setValueByName(ETRow_UnitOfMeasure, BOL_UOM_PIECE_COUNT);		
	self.tblHeaderDtls.goToRowByName(ETRow_Voyage);
	self.tblHeaderDtls.setFocus();
	self.tblHeaderDtls.moveFirst();

end;</source>
    </JadeMethod>
    <JadeMethod name="initTablesItems" id="bf455e1e-b465-4d83-af88-3aae086710f3">
        <source>initTablesItems();
//--------------------------------------------------------------
//Created: 11 June 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	sheets, count : Integer;
	theSheet : JadeTableSheet;
begin
	self.tblItems01.inputType := Table.InputType_TextBox;
	self.tblItems02.inputType := Table.InputType_TextBox;
