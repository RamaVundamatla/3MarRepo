    <JadeMethod name="amIAvailable" id="fe23725b-6397-4a2f-b784-a5f783320a28">
        <source>amIAvailable() : Boolean;
// ---------------------------------------------------------------------------
// Created:		September 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	if ( (usage &lt;&gt; NORMAL_USE and usage &lt;&gt; REEFERGANTRY_USE) or (availability = PAD_UNAVAILABLE) or (availability = PAD_USER_UNAVAILABLE) ) then
		return false;
	endif;
	return true;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
