    <JadeMethod name="getDisplayStringForAttribute" id="3e22cddf-d21b-41e6-ac75-77a7b10af0f6">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 January 2010	cnwdap1	Initial creation
*/
vars
	str		: String;
	item	: CM_CargoCheckItem;

begin
	if _attrName = ETRow_Context then
		return app.cargoCheckContextENumToString(self.context);
		
	elseif _attrName = ETRow_AllCargoCheckItems then
		foreach item in self.allCargoCheckItems do
			str := str &amp; item.name&amp; "; ";
		endforeach;
		return str;
	
	else
		return inheritMethod(_attrName, _short);
	endif;

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="replaceCargoCheckItemSet" id="d3c67726-6f18-4c29-8a86-fbdd9c1852ef">
        <updating/>
        <source>replaceCargoCheckItemSet(_withSet : CM_CargoCheckItemSet) updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 January 2010	cnwdap1	Initial creation
*/
vars

begin
	self.allCargoCheckItems.clear;
	_withSet.copy(self.allCargoCheckItems);
epilog

end;</source>
        <Parameter name="_withSet" type="CM_CargoCheckItemSet"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="a22b944e-73d7-4914-b858-f914b3713133">
        <updating/>
        <source>setForCreate(_proxyCargoCheck : CM_CargoCheck; _passport : CM_Passport input) updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 January 2010	cnwdap1	Initial creation
*/
vars

begin
	_proxyCargoCheck.raiseExceptionIfNotTransient(method);
	
	self.setForUpdate(_proxyCargoCheck);
	self.myTerminal := _passport.myTerminal;
epilog

end;</source>
        <Parameter name="_proxyCargoCheck" type="CM_CargoCheck"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="28ef0d7b-f1e9-49fb-8df1-38d4ec2b712d">
        <updating/>
        <source>setForUpdate(_proxyCargoCheck : CM_CargoCheck) updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 January 2010	cnwdap1	Initial creation
*/
vars

begin
	self.context := _proxyCargoCheck.context;
epilog

end;</source>
        <Parameter name="_proxyCargoCheck" type="CM_CargoCheck"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="8d074261-5328-4b13-9d8d-1f5f3d813525">
        <updating/>
        <source>setProxy(_context : Integer; _isNotAvailable : Boolean; _cargoCheckItems : CM_CargoCheckItemSet; _passport : CM_Passport input) updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 January 2010	cnwdap1	Initial creation
*/
vars

begin
	self.raiseExceptionIfNotTransient(method);

	self.context	:= _context;
	self.myTerminal	:= _passport.myTerminal;
epilog

end;</source>
        <Parameter name="_context" type="Integer"/>
        <Parameter name="_isNotAvailable" type="Boolean"/>
        <Parameter name="_cargoCheckItems" type="CM_CargoCheckItemSet"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
