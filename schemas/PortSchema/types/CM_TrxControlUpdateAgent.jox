    <JadeMethod name="trxUpdateRailClearRake" id="6894228d-77eb-43b1-9f90-67f46ad07aee">
        <updating/>
        <source>trxUpdateRailClearRake(_cmifRakeRegion : CMIF_RakeRegion input; _passport : CM_Passport input) updating;
//-----------------------------------------
//Created: April 2003 By: cnwgd1
// 25 Oct 2024 navma1 MTN-33231 MTN - Enable Deferred Updates For Train and Wagon Events 
// 17 Mar 2025 navma1 MTN-34120 MTN | Dead Lock (1081) on CM_OfflineFutureActorParentDct
//-----------------------------------------
begin

	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(true);
	
	// do validation
	self.raiseExceptionIfNull(_cmifRakeRegion, '_cmifRakeRegion');
	
	_cmifRakeRegion.validate(_passport);

	app.setContinueCMExceptions(false);
	
	if (not self.checkValidationWithPassport(_passport)) then
		return;
	endif;

	beginTransaction;
	
	_passport.useTIDictDeferUpdate		  	:= true;
	_passport.useTITransactionDeferUpdate 	:= true;
	_passport.useEventDeferUpdate		  	:= true;			//25.10.2024 navma1 #MTN-33231
	_passport.useOfflineFutureActorDeferDel := true;			//17.03.2025 navma1 #MTN-34120
	
	app.myUtilityUA.utlUpdateRailClearRake(_cmifRakeRegion, _passport);
	
	if _passport.noErrors then								
		_passport.doDeferredUpdates();
	endif;

epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_cmifRakeRegion" type="CMIF_RakeRegion" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxUpdateRailJobsRakeTransfer" id="4556c5f4-94a1-4931-b168-e5473250a277">
        <updating/>
        <source>trxUpdateRailJobsRakeTransfer(_railJobArray : CM_RailJobArray; _jobsWithWarnings : CM_RailJobArray input;
							_targetIORake : CM_RailJSInOutRake; _doAutoPlan : Boolean;
							_targetIOType : Integer; _passport : CM_Passport input) updating;
//-----------------------------------------
//Created: December 2004 By: cnwgd1
//-----------------------------------------
vars
	tmpRailJob : CM_RailJob;
	alertCreated : Boolean;
	errorSet	: CM_ErrorSet;
begin

	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);
	app.myEventManager.setMultiTransactionTrx();
	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(false);
	
	create errorSet transient;
	
	foreach tmpRailJob in _railJobArray do
		//th2 PAR 14772 - rail job may be deleted if associated with the same release request as another that has already
		//been tranfered
		if (not app.isValidObject(tmpRailJob)) then
			continue;
		endif;
		
		exclusiveLock(tmpRailJob);
		beginTransaction;
		
		app.myUtilityUA.utlUpdateJobRailOps(tmpRailJob, _targetIORake, _doAutoPlan, _targetIOType, _passport);

		if _passport.isOkToCommit(false) then
			app.cmsCommitTransaction(_passport);
		else
			app.cmsAbortTransaction;
			if _passport.hasErrors then
				app.convertErrorsWarningsToAlert('Rail Job ' &amp; tmpRailJob.jobId &amp; ' could not be transfered to rake ' &amp; _targetIORake.rake, _passport.allErrorWarnings);		
				alertCreated := true;
			elseif _passport.hasWarnings then
				_jobsWithWarnings.add(tmpRailJob);
			endif;

			_passport.moveErrorsToSet(errorSet);
			_passport.initialiseTransaction();	
		endif;
	endforeach;

	if _passport.noErrors and (not process.isInTransactionState) then
		// Done so that finaliseActivityWithPassport will commit correctly
		beginTransaction;
	endif;
	
	_passport.addErrorsFromSet(errorSet);

	if alertCreated then
		app.raiseCMException1(SystemAlertCreated, 'Rail Jobs', null, self);
	endif;	

epilog
	self.finaliseActivityWithPassport(_passport);
	delete errorSet;
end;</source>
        <Parameter name="_railJobArray" type="CM_RailJobArray"/>
        <Parameter name="_jobsWithWarnings" type="CM_RailJobArray" usage="input"/>
        <Parameter name="_targetIORake" type="CM_RailJSInOutRake"/>
        <Parameter name="_doAutoPlan" type="Boolean"/>
        <Parameter name="_targetIOType" type="Integer"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
