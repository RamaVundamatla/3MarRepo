    <JadeMethod name="atcgGetControlOptions" id="d8e2eec7-fccd-4768-a376-73e32d50ea62">
        <source>atcgGetControlOptions(genSchema,genSuperSchema,genSuperClass,logMessageMethod:String output; targetSchemas,noiseMethods:StringArray input);
//	This is an example of what your version of this method might look like.
begin
	// what schema to generate profile classes into, and its superschema
	genSchema:="JtdWebDriverSchema";
	genSuperSchema:="JtdWebCommonSchema";
	
	// what class to generate profile classes under
	genSuperClass:="JmtTransactionGenerator";
	//global.atcgMyControl.targetProcessName:="JMTVehicleMountedLogon";
	
	// what logging method to use
	logMessageMethod:="logMessage";
	
	// list of schemas to be tracked during recording
	targetSchemas.add("JtdWebDriverSchema");
	//targetSchemas.add("JMMobileClientRTSchema");
	//targetSchemas.add("JMMobileClientBaseSchema");
	//targetSchemas.add("MobileServerSchema");

	// list of methods to ignore - these will not be tracked at all during recording, mainly to reduce unwanted verbosity in the rrmsg.log
	// do not list any control or form event methods here, as that may affect code generation
	noiseMethods.add("isSpecial");
	noiseMethods.add("getYesNo");
	noiseMethods.add("getDateShortFormat");
	noiseMethods.add("getIMEXStringFromIMEXStatus");
	noiseMethods.add("getErrorString");
	noiseMethods.add("zGetTranslatedText");
	noiseMethods.add("getYesBlank");
	noiseMethods.add("temperatureDisplay");
	noiseMethods.add("temperatureConversion");
	noiseMethods.add("getPicLogoPort");
	noiseMethods.add("getPicLogoProduct");
	noiseMethods.add("convertRGBtoHSL");
	noiseMethods.add("excludeRow");
	noiseMethods.add("yaFillOptionToString");
	noiseMethods.add("convertRGBToColor");
	noiseMethods.add("bookingRefStatusEnumToString");
end;
</source>
        <Parameter name="genSchema" type="String" usage="output"/>
        <Parameter name="genSuperSchema" type="String" usage="output"/>
        <Parameter name="genSuperClass" type="String" usage="output"/>
        <Parameter name="logMessageMethod" type="String" usage="output"/>
        <Parameter name="targetSchemas" type="StringArray" usage="input"/>
        <Parameter name="noiseMethods" type="StringArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="atcgHandleShowModal" id="906e0356-1ee1-4af0-a20f-e54490f86032">
        <source>atcgHandleShowModal():Integer;

begin
	if jtdMyTransactionGenerator &lt;&gt; null and (atcgRunningAtcgReplay or runningBenchmark) then
		return jtdMyTransactionGenerator.handleShowModal;  // reimplement in profile class to perform modal actions and return the right code
	else
		return 99999;
	endif;
end;
</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="atcgRecordAppInit" id="0849f08a-733f-43eb-9673-2df446855516">
        <updating/>
        <source>atcgRecordAppInit() updating;
//	The class name below should be a non-abstract superclass of the generated profile classes.
//	It may be the same class declared for genSuperClass in your control options.
begin
	atcgRunningAtcg:=true;
	app.initialize;
	inheritMethod;
	create jtdMyTransactionGenerator as currentSchema.getClass("JmtTransactionGenerator");
	jtdMyTransactionGenerator.startup;
	system.causeEvent(1149, true, "RecordAppReady");
end;
</source>
    </JadeMethod>
    <JadeMethod name="atcgReplayAppInit" id="852a951a-92d5-4688-af99-5352813a1e63">
        <updating/>
        <source>atcgReplayAppInit() updating;

vars
	proc:Process;
begin
	atcgRunningAtcg:=true;
	atcgRunningAtcgReplay:=true;
	inheritMethod;
	app.initialize;
	create jtdMyTransactionGenerator as currentSchema.getClass(global.atcgReplayClassName);
	jtdMyTransactionGenerator.startup;
	jtdMyTransactionGenerator.runTest;
	jtdMyTransactionGenerator.stop;
	
	terminate;
epilog
	foreach proc in Process.instances do
		if proc.persistentApp.name = "AtcgControlApp" then //proc &lt;&gt; process then
			proc.causeEvent(1148, true, null);
		endif;
	endforeach;
	delete jtdMyTransactionGenerator;
end;
</source>
    </JadeMethod>
