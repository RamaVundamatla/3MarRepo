    <JadeMethod name="btnFind_click" id="8dda2d45-5f49-4f5c-b122-a3cfa18774fb">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnFind_click(btn: Button input) updating;
// --------------------------------------------------------------------------------
// Created:		27 January 1999 cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.statusMsg('Searching for class name...');
	self.findClass();
epilog
	self.statusMsg('');
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="findClass" id="5ead55ab-c933-4b1b-9be2-a644c6ac62d6">
        <updating/>
        <source>findClass() updating, protected;
// --------------------------------------------------------------------------------
// Created:		27 January 1999 by cnwdad1
//
// Purpose:		Searches for the entered class name in the listbox of the Class
//				Browser form.
//
// Parameters:	None
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 13/02/1999	cnwdad1		The class list box (CnEcClassBrowser form) is no longer
//							fully populated at once, but instead subclasses are only
//							loaded when the folder is opened by the User.  Therefore,
//							if the class the User is finding is not in the listbox,
//							but does exist in the schema, then we need to add it and
//							the associated class hierarchy to the listbox, and then
//							select the class's item in the listbox.
//
// 20/02/1999	cnwdad1		Now enables the 'btnBrowse' button on the Class Browser
//							form if the sought class is found and selected.
//
// 11/07/1999	cnwdad1		Added checks for classes that are subschema copies, and
//							loading the class from the schema where it was implemented
//							instead of simply loading the 'currentSchema' copy.
//
// 25/07/1999	cnwdad1		When doing a 'findString' of the class name in the listbox,
//							now doing a 'findStringExact'.
//
// 14/01/2003	cnwdad1		Added a check for theClass being null before checking
//							whether it's a subschema copy.
// --------------------------------------------------------------------------------
vars
	index			: Integer;
	parent			: Integer;
	className		: String;
	theClass		: Class;
	superClass		: Class;
	hierarchyClass	: Class;
	class			: Class;
	listClass		: Class;
	classColl		: ClassColl;
	subClasses		: ClassColl;
	allSchemas		: Boolean;
	includeSystem	: Boolean;
	mdiForm			: Form;
	level			: Integer;

begin
	className	:=	txtClassName.text.trimBlanks;
	index		:=	self.myListBox.findStringExact(1, className);

	if index = CNEC_NULL_INDEX then

		// The class is not in the listbox, so we'll look for it in the schema.

		theClass	:=	currentSchema.getClass(className);
		
//		if theClass._isSubschemaCopy() then							// cnwdad1 14/01/2003.
		if theClass &lt;&gt; null and theClass._isSubschemaCopy() then	// cnwdad1 14/01/2003.
			theClass	:=	theClass.cnEcGetImplementationSchema().getClass(theClass.name);
		endif;
		
		if theClass = null then
			app.msgBox(	"Class name not found: " &amp; className &amp; CrLf &amp; CrLf &amp; "Note that class names are case sensitive.",
						"Find Class", MsgBox_Information_Icon + MsgBox_OK_Only);
		else
			create classColl transient;
			classColl.add(theClass);
			superClass	:=	theClass;

			// Load the class hierarchy into a class collection.

			while (not superClass = null) do
				superClass	:=	superClass.getSuperclass();

				if superClass &lt;&gt; null then
					if (superClass._isSubschemaCopy) then
						superClass	:=	superClass.cnEcGetImplementationSchema().getClass(superClass.name);
					endif;

					classColl.add(superClass);

					if self.myListBox.findObject(superClass) &lt;&gt; CNEC_NULL_INDEX then
						break;
					endif;
				endif;
			endwhile;

			// Now load the class hierarchy into the listbox.

			mdiForm			:=	self.myForm.getMdiFrame();
			includeSystem	:=	mdiForm.CnEcJDBrowserMdi.mnuClassSystem.checked;
			allSchemas		:=	mdiForm.CnEcJDBrowserMdi.mnuClassSuper.checked;
			create subClasses transient;

			foreach superClass in classColl reversed do
				index	:=	self.myListBox.findObject(superClass);

				if index = CNEC_NULL_INDEX then
					index	:=	self.myListBox.findObject(superClass.getSuperclass);

					if index &lt;&gt; CNEC_NULL_INDEX then
						level	:=	self.myListBox.itemLevel[index] + 1;

						if self.myListBox.itemText[index + 1] = self.DUMMY_FOLDER then
							self.myListBox.removeItem(index + 1);
						endif;

						hierarchyClass	:=	currentSchema.getClass(superClass.getSuperclass.name);

						if hierarchyClass &lt;&gt; null then
							if allSchemas then
								hierarchyClass.getSubclasses(subClasses);
							else
								hierarchyClass.getSubclassesUpToSchema(currentSchema, subClasses);
							endif;
						endif;

						foreach class in subClasses do
							if	includeSystem				or
								((not includeSystem)		and
								(not class.isSystemObject))	then

								if class._isSubschemaCopy then
									listClass	:=	class.cnEcGetImplementationSchema().getClass(class.name);
								else
									listClass	:=	class;
								endif;

								index		:=	index + 1;
								self.myListBox.addItemAt(self.classString(listClass), index);
								self.myListBox.itemObject[index]	:=	listClass;
								self.myListBox.itemLevel[index]		:=	level;
								self.myForm.beginClassNotification(listClass, false, Any_System_Event, Response_Continuous, 1);
								self.classForeColor(listClass, self.myListBox, index);

								if class.hasSubclasses then
									index	:=	index + 1;
									self.myListBox.addItemAt(self.DUMMY_FOLDER, index);
									self.myListBox.itemLevel[index]	:=	level + 1;
								endif;
							endif;
						endforeach;

						if subClasses.cnEcIsNotEmpty() then
							subClasses.clear();
						endif;
					endif;
				endif;
			endforeach;

			// Now open up the folders in the class hierarchy.

			index	:=	self.myListBox.findObject(theClass);
			parent	:=	self.findListParent(self.myListBox, index);

			while parent &lt;&gt; 0 do
				if (not self.myListBox.itemExpanded[parent]) then
					self.myListBox.itemExpanded[parent]	:=	true;
				endif;

				parent	:=	self.findListParent(self.myListBox, parent);
				self.myForm.CnEcClassBrowserForm.btnBrowse.enabled	:=	true;
			endwhile;

			self.myListBox.listIndex	:=	index;
			unloadForm();
		endif;
	else
		// Now open up the folders in the class hierarchy.

		parent	:=	self.findListParent(self.myListBox, index);

		while parent &lt;&gt; 0 do
			if (not self.myListBox.itemExpanded[parent]) then
				self.myListBox.itemExpanded[parent]	:=	true;
			endif;

			parent	:=	self.findListParent(self.myListBox, parent);
			self.myForm.CnEcClassBrowserForm.btnBrowse.enabled	:=	true;
		endwhile;

		self.myListBox.listIndex	:=	index;
		unloadForm();
	endif;
epilog
	delete classColl;
	delete subClasses;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="formLoad" id="3aa3668f-f7e8-4f2a-aa1f-28bf4cbfc89a">
        <updating/>
        <source>formLoad() updating, protected;
// --------------------------------------------------------------------------------
// Created:		15 July 1999 by cnwdad1
//
// Purpose:		Standard form load method.
//
// Parameters:	None
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	btnFind.enabled	:=	false;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="load" id="01dcba7a-b9ef-463f-b33c-a33285049b3e">
        <controlMethod name="Form::load"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>load() updating;
// --------------------------------------------------------------------------------
// Created:		27 January 1999 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	centreWindow();
	self.formLoad();
epilog
	self.statusMsg("");
end;</source>
    </JadeMethod>
    <JadeMethod name="setMyForm" id="75d937ad-981a-45c9-b795-5f40c6fe1291">
        <updating/>
        <source>setMyForm(pValue: Form) updating;
// --------------------------------------------------------------------------------
// Created:		13 February 1999 by cnwdad1
//
// Purpose:		Sets a reference the the parent MDI form.
//
// Parameters:	pValue - The arent MDI form.
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.myForm &lt;&gt; pValue then 
		self.myForm := pValue;
	endif;
end;</source>
        <Parameter name="pValue" type="Form"/>
    </JadeMethod>
    <JadeMethod name="setMyListBox" id="f4d7f0c5-e8e6-4499-abf5-23aad6d7b7e2">
        <updating/>
        <source>setMyListBox(pValue: ListBox) updating;
// --------------------------------------------------------------------------------
// Created:		27 January 1999 by cnwdad1
//
// Purpose:		Sets a reference to the listbox control to search (for a class).
//
// Parameters:	pValue - The listbox control.
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.myListBox &lt;&gt; pValue then 
		self.myListBox := pValue;
	endif;
end;</source>
        <Parameter name="pValue" type="ListBox"/>
    </JadeMethod>
    <JadeMethod name="txtClassName_change" id="441ca1e4-7d35-4519-bd75-5a8b9922fbcb">
        <controlMethod name="TextBox::change"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtClassName_change(textbox: TextBox input) updating;
// --------------------------------------------------------------------------------
// Created:		17 November 2000 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	position	: Integer;

begin
	if (textbox.text.trimBlanks.length = 0) then
		btnFind.enabled	:=	false;
	else
		position			:=	textbox.selStart;
		textbox.text.firstCharToUpper;
		textbox.selStart	:=	position;
		btnFind.enabled		:=	true;
	endif;
end;</source>
        <Parameter name="textbox" type="TextBox" usage="input"/>
    </JadeMethod>
</GUIClass>
