    <JadeMethod name="getLastTransactionOfType" id="2f8a610b-9a44-4424-8d56-7ad0e7892bdd">
        <source>getLastTransactionOfType( _type : Integer ):CMEVT_WagonTransaction;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 March 2015	cnwndl1	Initial creation	Par 35828

*/

vars

	eventTransaction : CM_EventTransaction;
	bigDate : Date;
	ts : TimeStamp;

begin

	bigDate := "01/01/3000".Date;
	ts.setDate(bigDate);

	eventTransaction := self.allTransactions.getAtKeyLeq( _type, ts );
	if eventTransaction &lt;&gt; null and eventTransaction.type = _type then
		return eventTransaction.CMEVT_WagonTransaction;
	endif;
	
	return null;

epilog

end;</source>
        <Parameter name="_type" type="Integer"/>
        <ReturnType type="CMEVT_WagonTransaction"/>
    </JadeMethod>
