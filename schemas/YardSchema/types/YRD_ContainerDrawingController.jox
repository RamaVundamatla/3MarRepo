    <JadeMethod name="drawBackground" id="70efa8c6-8647-4ab7-93ed-2d20575f9719">
        <updating/>
        <source>drawBackground(_frame: CMUI_GridAreaDrawingFrame input; _x1: Real; _y1: Real; _x2: Real; _y2: Real) updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 May 2010	cnwndl1	Initial creation	Par 24044 - migrated up a class

*/

vars
	theFrame: CMUI_GridAreaDrawingFrame;
	tmpColour,
	lOuterColourUpper,
	lOuterColourLower, 
	tmpDrawFillColor	: Integer;
	myX2, myX1, myY1, myY2	: Real;
	drawTI 	: Boolean;
	theTI	: CM_TrackedItem;
begin
	theTI := self.myTrackedItem;
	if theTI = null then
		return;
	endif; 

	theFrame := _frame;
	drawTI := true;

	if self.viewMode = VIEW_HEIGHT then
		tmpColour := self.myLocationsController.CM_GridController.getStackHeightOfTIsColour();
		tmpDrawFillColor := self.myDrawingAttrController.yardStackColours[tmpColour];
	else
		tmpDrawFillColor:= self.getFillColourForTI(theTI);
		if self.useSelectorObjects and not self.allSelectorTIs.includes(theTI) then
			tmpDrawFillColor := White;
		endif;
	endif;
	if tmpDrawFillColor = NullColour then
		tmpDrawFillColor := White;
	endif;
	theFrame.drawFillStyle := Frame.DrawFillStyle_Solid;
	theFrame.drawStyle := Frame.DrawFillStyle_Solid;
	theFrame.drawWidth := 1;

	lOuterColourLower := DarkGray;
	lOuterColourUpper := White;

	theFrame.drawFillColor := tmpDrawFillColor;

	myX1 := _x1;
	myX2 := _x2;
	myY1 := _y1;
	myY2 := _y2;

	if self.allSelectedObjects.includes(theTI) then
		self.drawRectangle(theFrame, myX1, myY1, myX2, myY2, lOuterColourLower, lOuterColourUpper);
		self.drawTIBox(theFrame,lOuterColourLower,lOuterColourUpper, myX1.Integer, myY1.Integer, myX2.Integer, myY2.Integer);
	else
		self.drawRectangle(theFrame, myX1, myY1, myX2, myY2, lOuterColourUpper, lOuterColourLower);
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_frame" type="CMUI_GridAreaDrawingFrame" usage="input"/>
        <Parameter name="_x1" type="Real"/>
        <Parameter name="_y1" type="Real"/>
        <Parameter name="_x2" type="Real"/>
        <Parameter name="_y2" type="Real"/>
    </JadeMethod>
    <JadeMethod name="drawBetweenColumns" id="13eb0cb9-039f-4d0d-bab1-1e67540d3e77">
        <updating/>
        <source>drawBetweenColumns(_frame: CMUI_GridAreaDrawingFrame) updating;
// ---------------------------------------------------------------------------
// Created:		January 2005 By Andrew Bishop cnwab1
//
// Purpose:		If a 40 is moved or unplanned - basically it is removed from the screen this little rectangle wiil get rid of a stripe left between the pads
//
// ---------------------------------------------------------------------------

vars
	theFrame : Frame;
begin

	if self.isForSatelliteView then
		return;
	endif;
	theFrame := _frame;
	theFrame.drawFillColor := theFrame.backColor;
	if self.flipHorizontal then
		theFrame.drawFilledRectangle(self.x1 , self.y1, self.x1 - 2, self.y2,  theFrame.backColor);
	else
		theFrame.drawFilledRectangle(self.x2  , self.y1, self.x2 + 2, self.y2, theFrame.backColor);
	endif;
end;</source>
        <Parameter name="_frame" type="CMUI_GridAreaDrawingFrame"/>
    </JadeMethod>
    <JadeMethod name="drawBlankRow" id="210e7c67-c59b-407d-9c44-edbbeba1c2c1">
        <source>drawBlankRow(_y1, _y2 : Real);
// ---------------------------------------------------------------------------
// Created:		23 August 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
constants
	BottomMargin	: Integer = 10;
	LeftMargin		: Integer = 10;
vars
	theFrame : CMUI_GridAreaDrawingFrame;
	tX1, tY1, tX2, tY2 : Integer;
begin
	theFrame := self.myDrawingFrame;

	tX1 := LeftMargin;
	tY1 := _y1.Integer;
	tX2 := (theFrame.width- LeftMargin).Integer;
	tY2 := _y2.Integer;
	

	theFrame.drawStyle := Frame.DrawStyle_Solid;
	theFrame.drawFillColor := theFrame.backColor;
	theFrame.drawWidth := 1;
	theFrame.drawFilledRectangle(tX1, tY1, tX2, tY2, theFrame.backColor);

	self.gridObjectsRemove(tX1, tY1, tX2, tY2);

end;</source>
        <Parameter name="_y1" type="Real"/>
        <Parameter name="_y2" type="Real"/>
    </JadeMethod>
    <JadeMethod name="drawBlankSpace" id="1e6e78b7-8fd0-4295-86fe-441d78e5971a">
        <source>drawBlankSpace(_frame : CMUI_GridAreaDrawingFrame; pColor: Integer; pHeight: Integer; pX1: Real; pY1: Real; pX2: Real; pY2: Real; _checkForItems : Boolean) protected;
// ---------------------------------------------------------------------------
// Created:     25 August 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
// ---- WHO --- WHEN ----- WHY---------------------------------------------
// ---------------------------------------------------------------------------
//       AKB    19MAY2008     PAR 16415 CCMS 1029 30,45,53s
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
13 Mar 2009	cnwkpd1	PAR #19154 - User self.myTerminal instead of app.getMyTerminal to prevent
					1090 exceptions when processing notes "in the background"

8 Apr 2009		cnwab1		PAR #19215 - draw the strict offset lines when flipped
*/

vars
	theFrame : CMUI_GridAreaDrawingFrame;
	edgeColour : Integer;
	py1, px2, py2 : Real;
begin
	theFrame := _frame;

// PAR 18682	theFrame := self.myDrawingFrame;
	theFrame := _frame;
	theFrame.drawWidth := 1;
	// PAR 17588 AKB2008JUL
	if _checkForItems and self.hasGotItemAtHeight(pHeight, false) then
		return;
	endif;

	edgeColour := Black;
	py1 := pY1;
	px2 := pX2;
	py2 := pY2;
	
	if process.isJLGAB1() then  // ### TFS 50421 05NOV2021 NAVAB1
		edgeColour := pColor;
		py1 := pY1;
		px2 := pX2 - 1;
		py2 := pY2 - 2;
	endif;

	theFrame.drawStyle := Frame.DrawStyle_Solid;

	theFrame.drawFillColor := pColor;
	if pColor &lt;&gt; theFrame.backColor then
		if self.isForSatelliteView then
			theFrame.drawFilledRectangle(pX1, pY1, pX2, pY2,  self.satelliteViewGridColour);
		else
			theFrame.drawFilledRectangle(pX1, pY1, px2, py2,  edgeColour); // ### TFS 50421 05NOV2021 NAVAB1
		endif;
	endif;

	theFrame.drawStyle := Frame.DrawStyle_Solid;
	
	if self.showOSGrid then
		self.drawBlankSpaceStrictGrid(_frame, pColor, pHeight, pX1, pY1, pX2, pY2); // PAR 19283
	endif;
	
epilog
	theFrame.drawWidth := 1;
	theFrame.drawStyle := Frame.DrawStyle_Solid;
end;</source>
        <access>protected</access>
        <Parameter name="_frame" type="CMUI_GridAreaDrawingFrame"/>
        <Parameter name="pColor" type="Integer"/>
        <Parameter name="pHeight" type="Integer"/>
        <Parameter name="pX1" type="Real"/>
        <Parameter name="pY1" type="Real"/>
        <Parameter name="pX2" type="Real"/>
        <Parameter name="pY2" type="Real"/>
        <Parameter name="_checkForItems" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="drawBlankSpaceForOffsetFlexi" id="9c571e93-8810-4586-a309-0844ca22cfe8">
        <source>drawBlankSpaceForOffsetFlexi(_theTIIndex : Integer;
								_x1, _y1, _x2, _y2 :Real) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 October 2012	cnwer1	Initial creation PAR 30524

*/

vars
	gridController : CM_GridController;
	oldBC  : Integer;
begin
	if not self.drawFromNote then
		return;
	endif;
	
	if self.myLocationsController.offsetFlexi = 0 or _theTIIndex = 0 then
		return;
	endif;
	
	if not self.myLocationsController.isKindOf(CM_GridController) then
		return;
	endif;
	
	gridController:=self.myLocationsController.CM_GridController;
	
	if gridController.myPreviousController = null then
		return;
	endif;
		
	//is there something drawn where this ti is i.e. q'd, p'd or actual
	
	if self.myLocationsController.CM_GridController.myPreviousController.allTrackedItems.size +
					self.myLocationsController.CM_GridController.myPreviousController.allQueuedFutureMoves.size +
					self.myLocationsController.CM_GridController.myPreviousController.allPlannedFutureMoves.size &gt;= _theTIIndex then
		return;
	endif;
	
	oldBC:=	self.myDrawingFrame.drawFillColor;		
	self.myDrawingFrame.drawFillColor := self.myDrawingFrame.backColor;
	if self.flipHorizontal then
		self.myDrawingFrame.drawFilledRectangle(_x2  + ( (self.myLocationsController.offsetFlexi + 2.5) * self.scaleFactor) + 2  , _y1,_x2 , _y2+1, self.myDrawingFrame.backColor);

	else
		self.myDrawingFrame.drawFilledRectangle(_x1  -((self.myLocationsController.offsetFlexi + 2.5) * self.scaleFactor) , _y1,_x1, _y2+1, self.myDrawingFrame.backColor);
	endif;
	self.myDrawingFrame.drawFillColor:=oldBC;			
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_theTIIndex" type="Integer"/>
        <Parameter name="_x1" type="Real"/>
        <Parameter name="_y1" type="Real"/>
        <Parameter name="_x2" type="Real"/>
        <Parameter name="_y2" type="Real"/>
    </JadeMethod>
    <JadeMethod name="drawBlankSpaceNEW" id="48fdd6b7-9775-4dc8-8127-846d837a1696">
        <source>drawBlankSpaceNEW(_frame : CMUI_GridAreaDrawingFrame; pColor: Integer; pHeight: Integer; pX1: Real; pY1: Real; pX2: Real; pY2: Real; _checkForItems : Boolean) protected;
// ---------------------------------------------------------------------------
// Created:     25 August 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
// ---- WHO --- WHEN ----- WHY---------------------------------------------
// ---------------------------------------------------------------------------
//       AKB    19MAY2008     PAR 16415 CCMS 1029 30,45,53s
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
13 Mar 2009	cnwkpd1	PAR #19154 - User self.myTerminal instead of app.getMyTerminal to prevent
					1090 exceptions when processing notes "in the background"

8 Apr 2009		cnwab1		PAR #19215 - draw the strict offset lines when flipped
*/

vars
	theFrame : CMUI_GridAreaDrawingFrame;
		tmpX, tmpColor, offset : Integer;
begin


// PAR 18682	theFrame := self.myDrawingFrame;
	theFrame := _frame;
	theFrame.drawWidth := 1;
	// PAR 17588 AKB2008JUL
	if _checkForItems and self.allTempTIs.size &gt;= pHeight then //self.hasGotItemAtHeight(pHeight, false) then
		return;
	endif;

	theFrame.drawStyle := Frame.DrawStyle_Solid;

	theFrame.drawFillColor := pColor;
	if pColor &lt;&gt; theFrame.backColor then
		if self.isForSatelliteView then
			theFrame.drawFilledRectangle(pX1, pY1, pX2, pY2,  self.satelliteViewGridColour);
		else
			theFrame.drawFilledRectangle(pX1, pY1, pX2, pY2,  Black);
		endif;
	endif;
//if self.myLocationsController.getFullId() = "S1 H09" then
//	theFrame.refreshNow();
//	write "";
//endif;	
	theFrame.drawStyle := Frame.DrawStyle_Solid;
	
	
	
	self.drawBlankSpaceStrictGrid(_frame, pColor, pHeight, pX1, pY1, pX2, pY2); // PAR 19283
	

epilog
	theFrame.drawWidth := 1;
	theFrame.drawStyle := Frame.DrawStyle_Solid;
end;</source>
        <access>protected</access>
        <Parameter name="_frame" type="CMUI_GridAreaDrawingFrame"/>
        <Parameter name="pColor" type="Integer"/>
        <Parameter name="pHeight" type="Integer"/>
        <Parameter name="pX1" type="Real"/>
        <Parameter name="pY1" type="Real"/>
        <Parameter name="pX2" type="Real"/>
        <Parameter name="pY2" type="Real"/>
        <Parameter name="_checkForItems" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="drawBlankSpaceOverhang" id="259b65fb-f974-4d5b-8428-e25742ed053d">
        <source>drawBlankSpaceOverhang(_frame : CMUI_GridAreaDrawingFrame; pColor: Integer; pHeight: Integer; pX1: Real; pY1: Real; pX2: Real; pY2: Real) protected;
// ---------------------------------------------------------------------------
// Created:     January 2009 ANDREW BISHOP
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	theFrame : CMUI_GridAreaDrawingFrame;
	noStackFrom, tmpHeight, tmpX, tmpColor, tmpSides: Integer;
begin
	/* PAR 19283
	if self.isForSatelliteView then
		return;
	endif;
	*/
	theFrame := _frame;
//if self.myLocationsController.getFullId() = "53BISH A09" then
//app.writeStatement( "AKB " &amp; self.class.name &amp; "::" &amp; method.name &amp; " 1. " &amp;  self.myLocationsController.getFullId());
//endif;

	tmpColor := theFrame.backColor;
	theFrame.drawWidth := 1;
	tmpSides := tmpColor;
	theFrame.drawFillColor := tmpColor;
	
//app.writeStatement( "AKB " &amp; self.class.name &amp; "::" &amp; method.name &amp; " 1. " &amp; self.flipHorizontal.String &amp; " " &amp; (self.x1 = pX1).String &amp; " X1: " &amp;  pX1.String &amp; "  X2: " &amp; pX2.String);
	if pX1 = self.x1 then
		theFrame.drawFilledRectangle(pX1 - 2, pY1, pX2, pY2 + 1,  tmpSides);
	else
		if self.flipHorizontal then // PAR 19215
			theFrame.drawFilledRectangle(pX1 + 2, pY1, pX2, pY2 + 1,  tmpSides); // PAR 19215
		else
			theFrame.drawFilledRectangle(pX1 - 1, pY1, pX2, pY2 + 1,  tmpSides); // PAR 19215
		endif;
	endif;
	if self.isForSatelliteView then // PAR 19283
		return; // PAR 19283
	endif;
	
	noStackFrom := self.myLocationsController.CM_GridController.getHeightNoStackFrom();
	if noStackFrom &gt; 0 then
		tmpHeight := noStackFrom - 1;
		if pHeight &gt;= noStackFrom then
			self.drawHeight(_frame, "X", Red, pX1, pY1, pX2, pY2);
		endif;
	else
		tmpHeight := self.getHeightOfStack;	// PAR 21532 CCMS SFW 1025
	endif;
	
	if pHeight = tmpHeight then
		if self.myLocationsController.myTerminalArea.isRightAligned() then
			if self.myLocationsController.CM_GridController.myGridRow.allControllersByColumn.first = self.myLocationsController then
				if self.flipHorizontal then
						theFrame.drawFontName := "Wingdings 3";
						theFrame.drawFontSize := 12;
						theFrame.drawTextAt(63.Character, pX2 - 5, pY1 + 3, DarkGray); //224
						/*
						theFrame.drawLine(pX1, pY1, pX1, pY2, Black);
						theFrame.drawLine(pX1, pY1, pX1 - 4, pY1, Black);
						theFrame.drawLine(pX1, pY2, pX1 - 4, pY2, Black);
					*/
				else
						theFrame.drawFontName := "Wingdings 3";
						theFrame.drawFontSize := 12;
						theFrame.drawTextAt(62.Character, pX2 - 5, pY1 + 3, DarkGray); //224
						/*
						theFrame.drawLine(pX1, pY1, pX1, pY2, Black);
						theFrame.drawLine(pX1, pY1, pX1 + 4, pY1, Black);
						theFrame.drawLine(pX1, pY2, pX1 + 4, pY2, Black);
					*/
				endif;
			
			endif;
		else
			if self.myLocationsController.CM_GridController.myGridRow.allControllersByColumn.last = self.myLocationsController then
				if self.flipHorizontal then
						theFrame.drawFontName := "Wingdings 3";
						theFrame.drawFontSize := 12;
//	PAR 19283					theFrame.drawTextAt(62.Character, pX1 + 5, pY1 + 3, DarkGray);
						theFrame.drawTextAt(62.Character, pX2 - 5, pY1 + 3, DarkGray); // PAR 19283
				else
						theFrame.drawFontName := "Wingdings 3";
						theFrame.drawFontSize := 12;
						theFrame.drawTextAt(63.Character, pX2 - 5, pY1 + 3, DarkGray); //224
				endif;
			
			endif;
		endif;
	endif;
epilog
	if theFrame &lt;&gt; null then
		theFrame.drawWidth := 1;
		theFrame.drawStyle := Frame.DrawStyle_Solid;
		theFrame.drawFillStyle := Frame.DrawFillStyle_Solid;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_frame" type="CMUI_GridAreaDrawingFrame"/>
        <Parameter name="pColor" type="Integer"/>
        <Parameter name="pHeight" type="Integer"/>
        <Parameter name="pX1" type="Real"/>
        <Parameter name="pY1" type="Real"/>
        <Parameter name="pX2" type="Real"/>
        <Parameter name="pY2" type="Real"/>
    </JadeMethod>
    <JadeMethod name="drawBlankSpaceStrictGrid" id="32083fc9-0df7-4fa1-b4e2-45121308afbd">
        <source>drawBlankSpaceStrictGrid(_frame : CMUI_GridAreaDrawingFrame; pColor: Integer; pHeight: Integer; pX1: Real; pY1: Real; pX2: Real; pY2: Real);
// ---------------------------------------------------------------------------
// Created:     14 April 2009 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

	theFrame : CMUI_GridAreaDrawingFrame;
	tmpX, tmpColor, offset : Integer;
begin
	theFrame := _frame;

	if self.showOSGrid then
		theFrame.drawWidth := self.scaleFactor.Integer;
		theFrame.drawStyle := Frame.DrawStyle_Dot;
		
		// #### 45
		if self.myLocationsController.is45ft then
			if self.myLocationsController.offset45 &gt; 0 then
				offset := ((self.myLocationsController.offset45/20) * self.columnWidth).Integer;
				if self.flipHorizontal then
					tmpX := (self.x2 - offset).Integer;
				else
					tmpX := (self.x1 + offset).Integer;
				endif;
			elseif self.myLocationsController.offset45 = 0 then
				if self.flipHorizontal then
					tmpX := self.x2.Integer;
				else
					tmpX := (self.x1 + 1).Integer;
				endif;
			endif;
			tmpColor := Green;
		// #### 30
		elseif self.myLocationsController.is30ft then
			tmpColor := Blue;
			if self.myLocationsController.offset30 = 0 then
				if self.flipHorizontal then
					tmpX := self.x2.Integer;
				else
					tmpX := self.x1.Integer;
				endif;
				theFrame.drawLine(tmpX,pY1, tmpX, pY2, tmpColor);
			else
				offset := ((self.myLocationsController.offset30/20) * self.columnWidth).Integer;
				if self.flipHorizontal then
					tmpX := (pX2 + offset).Integer;
				else
					tmpX := (self.x1 + offset).Integer;
				endif;
			endif;
		// #### 20
		elseif self.myLocationsController.is20ft then
			tmpColor := Blue;
			tmpX := self.x1.Integer;
			theFrame.drawLine(tmpX,pY1, tmpX, pY2, tmpColor);
		// #### 40
		elseif self.myLocationsController.is40ft then
			tmpColor := Blue;
			if self.myLocationsController.offset40 = 0 then
				tmpX := self.x1.Integer;
				theFrame.drawLine(tmpX,pY1, tmpX, pY2, tmpColor);
			endif;
		// #### 53
		elseif self.myLocationsController.is53ft then
			tmpColor := Red;
			if self.myLocationsController.offset53 &gt; 0 then
				offset := ((self.myLocationsController.offset53/20) * self.columnWidth).Integer;
				if self.flipHorizontal then
					tmpX := (self.x2 - offset).Integer;
				else
					tmpX := (self.x1 + offset).Integer;
				endif;
			elseif self.myLocationsController.offset53 = 0 then
				if self.flipHorizontal then
					tmpX := (self.x2).Integer;
				else
					tmpX := (self.x1 + 1).Integer;
				endif;
			endif;
		endif;
		if self.flipHorizontal then
			if tmpX &gt; pX2 then
				theFrame.drawLine(tmpX,pY1, tmpX, pY2, tmpColor);	
			endif;
		else
			if tmpX &gt; pX1 then
				theFrame.drawLine(tmpX,pY1, tmpX, pY2, tmpColor);	
			endif;
		endif;
	endif;
epilog

end;</source>
        <Parameter name="_frame" type="CMUI_GridAreaDrawingFrame"/>
        <Parameter name="pColor" type="Integer"/>
        <Parameter name="pHeight" type="Integer"/>
        <Parameter name="pX1" type="Real"/>
        <Parameter name="pY1" type="Real"/>
        <Parameter name="pX2" type="Real"/>
        <Parameter name="pY2" type="Real"/>
    </JadeMethod>
    <JadeMethod name="drawBuilding" id="9ef5f15b-3f0f-403f-a2e1-2ed33b111dbb">
        <source>drawBuilding() protected;
// ---------------------------------------------------------------------------
// Created:     25 August 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	theFrame : CMUI_GridAreaDrawingFrame;
	aSlotHeight, aWindowHeight, idx : Integer;
	aHeight, tmpx1, tmpx2, tmpy1, tmpy2, hght : Integer;
begin

	theFrame := self.myDrawingFrame;
	
	theFrame.drawStyle := Frame.DrawStyle_Solid;
	// #######################
	// DRAW ROOF
	hght := self.getHeightOfStack;	// PAR 21532 CCMS SFW 1025
	if hght = 1 then
		aHeight := 2;
	else
		aHeight := hght;
	endif;
//	aSlotHeight := ((self.x2 - self.x1) / aHeight).Integer; PAR 16415
	aSlotHeight := (self.columnWidth / aHeight).Integer; // PAR 16415
	tmpx1 := self.x1.Integer;
	tmpy1 := self.y1.Integer + aSlotHeight;
//	tmpx2 := (self.x1 + ((self.x2 - self.x1) / 2)).Integer;PAR 16415
	tmpx2 := (self.x1 + (self.columnWidth / 2)).Integer; // PAR 16415
	tmpy2 := self.y1.Integer;
	theFrame.drawLine(tmpx1, tmpy1, tmpx2, tmpy2, DarkBlue);

	tmpx1 := tmpx2;
	tmpy1 := tmpy2;
//	tmpx2 :=  (self.x1 + (self.x2 - self.x1)).Integer; // PAR 16415
	tmpx2 :=  (self.x1 + self.columnWidth).Integer; // PAR 16415
	tmpy2 := self.y1.Integer + aSlotHeight;
	theFrame.drawLine(tmpx1, tmpy1, tmpx2, tmpy2, DarkBlue);

	tmpx1 := tmpx2;
	tmpy1 := tmpy2;
	tmpx2 := self.x1.Integer;
	tmpy2 := self.y1.Integer + aSlotHeight;
	theFrame.drawLine(tmpx1, tmpy1, tmpx2, tmpy2, DarkBlue);

	// #######################
	// DRAW Building

	theFrame.drawFillColor := Green;
	theFrame.drawFillStyle := Frame.DrawFillStyle_Cross;

	tmpx1 := tmpx2;
	tmpy1 := tmpy2;
	tmpx2 := self.x2.Integer;
	tmpy2 := self.y2.Integer;
	theFrame.drawFilledRectangle(tmpx1, tmpy1, tmpx2, tmpy2, Green);

	// #######################
	// DRAW Windows
	theFrame.drawFillColor := White;
	theFrame.drawFillStyle := Frame.DrawFillStyle_Solid;

	aWindowHeight := (aSlotHeight / 3).Integer;
	
	// ####
	// LEFT
	tmpy1 := (self.y1 + aSlotHeight + 10).Integer;
	tmpx1 := (self.x1 + 10).Integer;	
	while tmpy1 &lt; self.y2 - 10 do
		tmpy2 := tmpy1 + 10;
		tmpx2 := tmpx1 + 10;
		theFrame.drawFilledRectangle(tmpx1, tmpy1, tmpx2, tmpy2, Green);
	
		tmpy1 := tmpy1 + 15;
	endwhile;

	// ####
	// RIGHT
	tmpy1 := (self.y1 + aSlotHeight + 10).Integer;
	tmpx1 := (self.x2 - 20).Integer;	
	while tmpy1 &lt; self.y2 - 10 do
		tmpy2 := tmpy1 + 10;
		tmpx2 := tmpx1 + 10;
		theFrame.drawFilledRectangle(tmpx1, tmpy1, tmpx2, tmpy2, Green);
	
		tmpy1 := tmpy1 + 15;
	endwhile;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="drawCar" id="e7e269a3-be12-4fb5-92fc-c68f6bc0058a">
        <source>drawCar(_frame : Frame input; _offsetX, _offsetY : Real; _fill : Integer);
// ---------------------------------------------------------------------------
// Created:		10 July 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	theScale : Real;
	theX, theY, theX2, theY2, idx, endIDX : Integer;
begin
	theScale := (self.scaleFactor / 2);

	if self.scaleFactor &lt;=2 then
		_frame.drawWidth := 1;
	elseif self.scaleFactor =3 then
		_frame.drawWidth := 2;
	else
		_frame.drawWidth := 3;
	
	endif;
	_frame.drawFillColor := _fill;
	_frame.drawFilledRectangle((1 * theScale) + _offsetX, (2 * theScale) + _offsetY, (43 * theScale) + _offsetX, (22 * theScale) + _offsetY,_fill);
	_frame.drawFillColor := White;
	_frame.drawFilledRectangle((7 * theScale) + _offsetX, (6 * theScale) + _offsetY, (13 * theScale) + _offsetX, (18 * theScale) + _offsetY,White);
	_frame.drawFillColor := White;
	_frame.drawFilledRectangle((27 * theScale) + _offsetX, (6 * theScale) + _offsetY, (34 * theScale) + _offsetX, (18 * theScale) + _offsetY,White);

	_frame.drawLine((31 * theScale) + _offsetX, (6 * theScale) + _offsetY, (34 * theScale) + _offsetX, (6 * theScale) + _offsetY,_fill);
	_frame.drawLine((31 * theScale) + _offsetX, (18 * theScale) + _offsetY, (34 * theScale) + _offsetX, (18 * theScale) + _offsetY,_fill);
	
	_frame.drawLine((18 * theScale) + _offsetX, (3 * theScale) + _offsetY, (27 * theScale) + _offsetX, (3 * theScale) + _offsetY,White);
	_frame.drawLine((18 * theScale) + _offsetX, (21 * theScale) + _offsetY, (27 * theScale) + _offsetX, (21 * theScale) + _offsetY,White);

	_frame.drawLine((5 * theScale) + _offsetX, (1 * theScale) + _offsetY, (11 * theScale) + _offsetX, (1 * theScale) + _offsetY,Black);
	_frame.drawLine((5 * theScale) + _offsetX, (23 * theScale) + _offsetY, (11 * theScale) + _offsetX, (23 * theScale) + _offsetY,Black);
	_frame.drawLine((34 * theScale) + _offsetX, (1 * theScale) + _offsetY, (40 * theScale) + _offsetX, (1 * theScale) + _offsetY,Black);
	_frame.drawLine((34 * theScale) + _offsetX, (23 * theScale) + _offsetY, (40 * theScale) + _offsetX, (23 * theScale) + _offsetY,Black);
	

	_frame.drawLine((5 * theScale) + _offsetX, (2 * theScale) + _offsetY, (11* theScale) + _offsetX, (2 * theScale) + _offsetY,DarkGray);
	_frame.drawLine((34 * theScale) + _offsetX, (2 * theScale) + _offsetY, (40* theScale) + _offsetX, (2 * theScale) + _offsetY,DarkGray);
	_frame.drawLine((5 * theScale) + _offsetX, (22 * theScale) + _offsetY, (11* theScale) + _offsetX, (22 * theScale) + _offsetY,DarkGray);
	_frame.drawLine((34 * theScale) + _offsetX, (22 * theScale) + _offsetY, (40* theScale) + _offsetX, (22 * theScale) + _offsetY,DarkGray);
	_frame.drawLine((34 * theScale) + _offsetX, (6 * theScale) + _offsetY, (43* theScale) + _offsetX, (6 * theScale) + _offsetY,DarkGray);
	_frame.drawLine((34 * theScale) + _offsetX, (18 * theScale) + _offsetY, (43* theScale) + _offsetX, (18 * theScale) + _offsetY,DarkGray);
	_frame.drawLine((1 * theScale) + _offsetX, (6 * theScale) + _offsetY, (6* theScale) + _offsetX, (6 * theScale) + _offsetY,DarkGray);
	_frame.drawLine((1 * theScale) + _offsetX, (18 * theScale) + _offsetY, (6* theScale) + _offsetX, (18 * theScale) + _offsetY,DarkGray);

	
	_frame.drawLine((1 * theScale) + _offsetX, (7 * theScale) + _offsetY, (6* theScale) + _offsetX, (7 * theScale) + _offsetY,Gray);
	_frame.drawLine((1 * theScale) + _offsetX, (17 * theScale) + _offsetY, (6* theScale) + _offsetX, (17 * theScale) + _offsetY,Gray);
	_frame.drawLine((6 * theScale) + _offsetX, (7 * theScale) + _offsetY, (6* theScale) + _offsetX, (17 * theScale) + _offsetY,Gray);
	_frame.drawLine((34 * theScale) + _offsetX, (7 * theScale) + _offsetY, (43* theScale) + _offsetX, (7 * theScale) + _offsetY,Gray);
	_frame.drawLine((34 * theScale) + _offsetX, (17 * theScale) + _offsetY, (43* theScale) + _offsetX, (17 * theScale) + _offsetY,Gray);

	_frame.drawLine((11 * theScale) + _offsetX, (4 * theScale) + _offsetY, (27* theScale) + _offsetX, (4 * theScale) + _offsetY,Gray);
	_frame.drawLine((11 * theScale) + _offsetX, (20 * theScale) + _offsetY, (27* theScale) + _offsetX, (20 * theScale) + _offsetY,Gray);
	_frame.drawLine((11 * theScale) + _offsetX, (4 * theScale) + _offsetY, (11* theScale) + _offsetX, (3* theScale) + _offsetY,Gray);
	_frame.drawLine((11 * theScale) + _offsetX, (20 * theScale) + _offsetY, (11* theScale) + _offsetX, (21 * theScale) + _offsetY,Gray);

	_frame.drawPoint((42 * theScale) + _offsetX, (2 * theScale) + _offsetY, _frame.backColor);
	_frame.drawPoint((42 * theScale) + _offsetX, (21 * theScale) + _offsetY, _frame.backColor);
epilog
	_frame.drawWidth := 1;

end;</source>
        <Parameter name="_frame" type="Frame" usage="input"/>
        <Parameter name="_offsetX" type="Real"/>
        <Parameter name="_offsetY" type="Real"/>
        <Parameter name="_fill" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="drawCarPoly" id="08c1f3f2-a214-4249-88df-72a0f89b34fe">
        <source>drawCarPoly(_frame : Frame input; _offsetX, _offsetY : Real; _fill : Integer);
// ---------------------------------------------------------------------------
// Created:		10 July 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	theScale : Real;
	theX, theY, theX2, theY2, idx, endIDX : Integer;
	allPoints : RealArray;
begin
	_frame.drawFilledRectangle(_offsetX, _offsetY, _offsetX + 60,_offsetY + 20,Black);

	theScale := (self.scaleFactor / 2);
	create allPoints transient;
	// ### CAR BODY	
	endIDX := self.allCarBody.size;
	foreach idx in 1 to endIDX do
		if idx mod 2 = 0 then
			theY := (self.allCarBody[idx] * theScale).Integer;
			allPoints.add(theX + _offsetX);
			allPoints.add(theY + _offsetY);
		else
			theX := (self.allCarBody[idx] * theScale).Integer;
		endif;
	endforeach;
	
	_frame.drawFillColor := _fill;
	_frame.drawFilledPolygon(allPoints,Black);

	// ### CAR WINDOWS	
	allPoints.clear;
	endIDX := self.allCarOther.size;
	foreach idx in 1 to endIDX do
		if idx mod 2 = 0 then
			theY := (self.allCarOther[idx] * theScale).Integer;
			allPoints.add(theX + _offsetX);
			allPoints.add(theY + _offsetY);
		else
			theX := (self.allCarOther[idx] * theScale).Integer;
		endif;
	endforeach;
	
	_frame.drawFillColor := White;
	_frame.drawFilledPolygon(allPoints,Black);
	
	// ### CAR WHEELS
	
	theX := ((6 * theScale) + _offsetX).Integer ;
	theY := ((16 * theScale)  + _offsetY).Integer;
	theX2 := theX + (7 * theScale).Integer;
	theY2 := theY + (7 * theScale).Integer;
	_frame.drawEllipse1(theX,theY,theX2, theY2,Black);

	
	theX := ((35 * theScale) + _offsetX).Integer ;
	theY := ((16 * theScale)  + _offsetY).Integer;
	theX2 := theX + (7 * theScale).Integer;
	theY2 := theY + (7 * theScale).Integer;
	_frame.drawEllipse1(theX,theY,theX2, theY2,Black);
	
	
epilog
	delete allPoints;
end;</source>
        <Parameter name="_frame" type="Frame" usage="input"/>
        <Parameter name="_offsetX" type="Real"/>
        <Parameter name="_offsetY" type="Real"/>
        <Parameter name="_fill" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="drawCurrentObject" id="28c72b63-2b82-4625-8bcd-91cbc7fde1e8">
        <updating/>
        <source>drawCurrentObject(_frame: CMUI_GridAreaDrawingFrame input) updating;
// ---------------------------------------------------------------------------
// Created:		December 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	tmpTIs	: CM_TIArray;
	theTI, theOSTI : CM_TrackedItem;
	frame: CMUI_GridAreaDrawingFrame;
	idx, theDisplayMode : Integer;
	startX, endX : Real;
	myLC : CM_LocationsController;
	drawSolid, isFlipped : Boolean;
begin
	theDisplayMode := self.displayMode;
	self.drawBackEnd := false;
	
	if self.myCurrentObject.isKindOf(CM_LocationsController) then
		if self.myCurrentObject.isKindOf(CM_RoRoController) then	// cnwjk3 ccms 1018 26/01/10
			self.drawRoRoLaneFromNote();
		elseif self.myCurrentObject.isKindOf(CM_YardICAreaLaneController) then
			self.drawYardInterchangeFromNote(self.myCurrentObject.CM_YardICAreaLaneController.myTerminalArea.CM_YardInterchangeArea);
			
		elseif self.myCurrentObject.isKindOf(CM_RackShelfController) then // PAR 32308
			
			self.drawShelfFromNote(self.myCurrentObject.CM_RackShelfController);
		else															// cnwjk3 ccms 1018 26/01/10
			self.drawLC(self.myCurrentObject.CM_GridController);	// cnwjk3 ccms 1018 26/01/10
		endif;														// cnwjk3 ccms 1018 26/01/10

	elseif self.myCurrentObject.isKindOf(CM_TrackedItem) then
	
		theTI := self.myCurrentObject.CM_TrackedItem;
		self.tiHeight := theTI.getHeightOfTI();
		self.tiLength := theTI.getLengthInUnits().Integer;
		
		isFlipped:= self.flipHorizontal; // PAR 18110
		self.flipHorizontal := false; // PAR 18110
		self.setIconPositions(self.x1, self.y1, self.x2, self.y2);
		self.flipHorizontal := isFlipped; // PAR 18110

		if self.drawFromNote then
			self.drawBetweenColumns(_frame);
		endif;
		
		// We only store ACTUAL TIs so if we are here they must have clicked on an actual TI
		self.myLocationsController := theTI.myPrimaryActualLocation;
		self.setTICollections();
		drawSolid := 	(theDisplayMode = DISPLAY_MODE_ACTUAL and self.allTIsA.includes(theTI))
					or		(theDisplayMode = DISPLAY_MODE_QUEUE and self.allTIsQ.includes(theTI))
					or		(theDisplayMode = DISPLAY_MODE_PLAN and self.allTIsP.includes(theTI));

//		if self.displayMode = DISPLAY_MODE_ACTUAL then
		if drawSolid then
			//self.drawTI(theTI, null, self.x1, self.y1, self.x2, self.y2,self.myDrawingFrame); // PAR 19505 	// cnwjk3 PAR 23875 23/04/10
			self.drawTI(theTI, null, self.x1, self.y1, self.x2, self.y2,self.myDrawingFrame, null);				// cnwjk3 PAR 23875 23/04/10
		else
			self.doDrawFMLetterForTI(_frame, theTI, NullColour, self.x1, self.y1, self.x2, self.y2);
		endif;
	endif;

end;</source>
        <Parameter name="_frame" type="CMUI_GridAreaDrawingFrame" usage="input"/>
    </JadeMethod>
    <JadeMethod name="drawFMLetter" id="f7880853-1043-4246-b86b-59001e69f2f7">
        <source>drawFMLetter(_theLetter: String; _isP40: Boolean; _isQ40: Boolean; _isA40: Boolean; _theX1: Real; _theY1: Real; _theX2: Real; _theY2: Real; _theFill: Integer; _mode: Integer);
// ---------------------------------------------------------------------------
// Created:     25 August 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
// ---- WHO --- WHEN ----- WHY---------------------------------------------
// ---------------------------------------------------------------------------
//       AKB    19MAY2008     PAR 16415 CCMS 1029 30,45,53s
// ---------------------------------------------------------------------------
vars
	theFrame	: CMUI_GridAreaDrawingFrame;
	is40, hasA, hasQ, hasP : Boolean;
	xOffset, yOffset,yOffsetFnt,xOffsetFnt,xWidth : Integer;
	aReal : Real;
	aGridAttribute : CMIF_GridAttributes;
	theLetter : String;
	edgecolour : Integer;
begin

	theFrame := self.myDrawingFrame;

	if _mode = 1 then
		hasP := true;
	elseif _mode = 2 then
		hasQ := true;
	elseif _mode = 6 then
		hasA := true;
	elseif _mode = 3 then
		hasP := true;
		hasQ := true;
	elseif _mode = 7 then
		hasP := true;
		hasA := true;
	elseif _mode = 8 then
		hasQ := true;
		hasA := true;
	elseif _mode = 9 then
		hasQ := true;
		hasP := true;
		hasA := true;
	else
		app.writeStatement( "AKB " &amp; self.class.name &amp; "::" &amp; method.name &amp; " 1. UNKNOWN MODE " &amp; _mode.String);
		return;
	endif;
	
	theFrame.drawTextAlign := Frame.DrawTextAlign_Center;
	theLetter := _theLetter.trimBlanks;

	theFrame.drawFontName := "Arial";
	theFrame.drawStyle := Frame.DrawStyle_Solid;
	theFrame.drawFillColor := _theFill;
	if self.isForSatelliteView then
		theFrame.drawFilledRectangle(_theX1, _theY1, _theX2, _theY2,  LightGray);
	else
		edgecolour := Black;
		if process.isJLGAB1() then
			 edgecolour:= _theFill;
		endif;
		
		theFrame.drawFilledRectangle(_theX1, _theY1, _theX2, _theY2,  edgecolour);

		theFrame.drawWidth := 2;
		xWidth := 0;
		if self.scaleFactor = 1 then
			xWidth := 4;
			theFrame.drawWidth := 1;
			xOffset := 2;
			yOffset :=3;
			yOffsetFnt := -1;
	
			if theLetter.length = 1 then
				xOffsetFnt := 7;
			else
				xOffsetFnt := 4;
			endif;
			theFrame.drawFontSize := 8;
			theFrame.drawFontBold := true;
		elseif self.scaleFactor = 1.5 then
			xWidth := 4;
			theFrame.drawWidth := 1;
			xOffset := 2;
			yOffset :=6;
			yOffsetFnt := 0;
			if theLetter.length = 1 then
				xOffsetFnt := 10;
			else
				xOffsetFnt := 3;
			endif;
			theFrame.drawFontSize := 10;
			theFrame.drawFontBold := true;
		elseif self.scaleFactor = 2 then
			xWidth := 6;
			xOffset := 2;
			yOffset := 8;
			yOffsetFnt := 0;
			if theLetter.length = 1 then
				xOffsetFnt := 14;
			else
				xOffsetFnt := 8;
			endif;
			theFrame.drawFontSize := 16;
		elseif self.scaleFactor = 3 then
			xWidth := 8;
			xOffset := 6;
			yOffset := 12;
			yOffsetFnt := 0;
			theFrame.drawFontSize := 24;
			if theLetter.length = 1 then
				xOffsetFnt := 22;
			else
				xOffsetFnt := 11;
			endif;
		elseif self.scaleFactor = 4 then
			xWidth := 10;
			xOffset := 8;
			yOffset := 15;
			yOffsetFnt := 0;
			if theLetter.length = 1 then
				xOffsetFnt := 30;
			else
				xOffsetFnt := 15;
			endif;
			theFrame.drawFontSize := 32;
		endif;
		theFrame.drawStyle := Frame.DrawStyle_Solid;
		theFrame.drawFillColor := White;
	
		aReal :=  _theX1 + ((_theX2 - _theX1) / 2);
		xOffsetFnt := aReal.Integer;
	
		if _isQ40 or _isP40 or _isA40  then // the dummy side of a 40
			theFrame.drawFilledRectangle(_theX1 + xOffset, _theY1 + yOffset, _theX2 - xOffset, _theY2 - yOffset,  Black);
			theFrame.drawTextAt(theLetter, xOffsetFnt, _theY1 + yOffsetFnt, Black); 
		else
			if is40 then
				theFrame.drawFilledRectangle(_theX1 + xOffset, _theY1 + yOffset, _theX2 - xOffset, _theY2 - yOffset,  Black);
			else
				theFrame.drawFilledRectangle(_theX1 + xOffset, _theY1 + yOffset, _theX2 - xOffset, _theY2 - yOffset,  Black);
			endif;
			theFrame.drawTextAt(theLetter, xOffsetFnt, _theY1 + yOffsetFnt, Black); 
		endif;
	endif;
epilog
	theFrame.drawWidth := 1;
	theFrame.drawFontBold := false;

end;</source>
        <Parameter name="_theLetter" type="String"/>
        <Parameter name="_isP40" type="Boolean"/>
        <Parameter name="_isQ40" type="Boolean"/>
        <Parameter name="_isA40" type="Boolean"/>
        <Parameter name="_theX1" type="Real"/>
        <Parameter name="_theY1" type="Real"/>
        <Parameter name="_theX2" type="Real"/>
        <Parameter name="_theY2" type="Real"/>
        <Parameter name="_theFill" type="Integer"/>
        <Parameter name="_mode" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="drawFMLetterBackend" id="5c7ec29c-fde8-42f9-be72-f4e66eacb92c">
        <source>drawFMLetterBackend(_theX1: Real; _theY1: Real; _theX2: Real; _theY2: Real);
// ---------------------------------------------------------------------------
// Created:     25 August 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
// ---- WHO --- WHEN ----- WHY---------------------------------------------
// ---------------------------------------------------------------------------
//       AKB    19MAY2008     PAR 16415 CCMS 1029 30,45,53s
// ---------------------------------------------------------------------------
vars
	theFrame	: CMUI_GridAreaDrawingFrame;
	is40, hasA, hasQ, hasP : Boolean;
	xOffset, yOffset,yOffsetFnt,xOffsetFnt,xWidth : Integer;
	aReal : Real;
	aGridAttribute : CMIF_GridAttributes;
begin

	theFrame := self.myDrawingFrame;

	theFrame.drawTextAlign := Frame.DrawTextAlign_Center;

	theFrame.drawFontName := "Arial";
	theFrame.drawStyle := Frame.DrawStyle_Solid;

	theFrame.drawWidth := 2;
	xWidth := 0;
	if self.scaleFactor = 1 then
		xWidth := 4;
		theFrame.drawWidth := 1;
		xOffset := 2;
		yOffset :=3;
		yOffsetFnt := -1;

		xOffsetFnt := 7;
		theFrame.drawFontSize := 8;
		theFrame.drawFontBold := true;
	elseif self.scaleFactor = 1.5 then
		xWidth := 4;
		theFrame.drawWidth := 1;
		xOffset := 2;
		yOffset :=2;
		yOffsetFnt := 2;
		xOffsetFnt := 10;
		theFrame.drawFontSize := 10;
		theFrame.drawFontBold := true;
	elseif self.scaleFactor = 2 then
		xWidth := 6;
		xOffset := 2;
		yOffset := 2;
		yOffsetFnt := 0;
		xOffsetFnt := 14;
		theFrame.drawFontSize := 16;
	elseif self.scaleFactor = 3 then
		xWidth := 8;
		xOffset := 6;
		yOffset := 6;
		yOffsetFnt := 6;
		theFrame.drawFontSize := 16;
		xOffsetFnt := 22;
	elseif self.scaleFactor = 4 then
		xWidth := 10;
		xOffset := 8;
		yOffset := 8;
		yOffsetFnt := 4;
		xOffsetFnt := 30;
		theFrame.drawFontSize := 26;
	elseif self.scaleFactor = 6 then
		xWidth := 10;
		xOffset := 8;
		yOffset := 8;
		yOffsetFnt := 6;
		xOffsetFnt := 30;
		theFrame.drawFontSize := 36;
	elseif self.scaleFactor = 9 then
		xWidth := 10;
		xOffset := 10;
		yOffset := 10;
		yOffsetFnt := 12;
		xOffsetFnt := 30;
		theFrame.drawFontSize :=48;
	endif;
	theFrame.drawStyle := Frame.DrawStyle_Solid;
	theFrame.drawFillColor := White;
	
	aReal :=  _theX1 + ((_theX2 - _theX1) / 2);
	xOffsetFnt := aReal.Integer;
	
	theFrame.drawFilledRectangle(_theX1 + xOffset, _theY1 + yOffset, _theX2 - xOffset, _theY2 - yOffset,  Black);
	theFrame.drawTextAt("X", xOffsetFnt, _theY1 + yOffsetFnt, Black); 
epilog
	theFrame.drawWidth := 1;
	theFrame.drawFontBold := false;

end;</source>
        <Parameter name="_theX1" type="Real"/>
        <Parameter name="_theY1" type="Real"/>
        <Parameter name="_theX2" type="Real"/>
        <Parameter name="_theY2" type="Real"/>
    </JadeMethod>
    <JadeMethod name="drawFMLetterGraphic" id="448f2e33-598e-487d-a12f-b9a05c0495f5">
        <source>drawFMLetterGraphic(_frame: CMUI_GridAreaDrawingFrame; _theLetter: String; _theX1: Real; _theY1: Real; _theX2: Real; _theY2: Real; _backColour: Integer);
// ---------------------------------------------------------------------------
// Created:     25 August 2004 by cnwrs2
//
// Purpose:     PAR 19468 NEW
// ---------------------------------------------------------------------------
// ---- WHO --- WHEN ----- WHY---------------------------------------------
// ---------------------------------------------------------------------------
// ---------------------------------------------------------------------------
vars
	theFrame	: CMUI_GridAreaDrawingFrame;
	xOffset, yOffset,yOffsetFnt,xOffsetFnt,xWidth, theFillColour : Integer;
	aReal: Real;
	theLetter : String;
	edgecolour: Integer;
begin

	theFrame := _frame;
	if _backColour = NullColour then
		if self.myLocationsController.hasPower() then 
			theFillColour := self.POWER_FILL_COLOUR;
		else
			theFillColour := Gray;
			if self.myLocationsController.isOverhang() then
				theFillColour := theFrame.backColor;
			endif;
		endif;
	else
		theFillColour := _backColour;
	endif;
	
	theFrame.drawTextAlign := Frame.DrawTextAlign_Center;
	theLetter := _theLetter.trimBlanks;
	theFrame.drawFillColor := theFillColour;

	theFrame.drawFontName := "Arial";
	theFrame.drawStyle := Frame.DrawStyle_Solid;
	if self.isForSatelliteView then
		theFrame.drawFilledRectangle(_theX1, _theY1, _theX2, _theY2,  LightGray);
	else
		// ### TFS 50421 05NOV2021 NAVAB1
		edgecolour := Black;
		if process.isJLGAB1() then
			 edgecolour:= theFillColour;
		endif;
			
		theFrame.drawFilledRectangle(_theX1, _theY1, _theX2, _theY2,  edgecolour); // ### TFS 50421 05NOV2021 NAVAB1

		theFrame.drawWidth := 2;
		xWidth := 0;
		if self.scaleFactor = 1 then
			xWidth := 4;
			theFrame.drawWidth := 1;
			xOffset := 2;
			yOffset :=3;
			yOffsetFnt := -1;
	
			if theLetter.length = 1 then
				xOffsetFnt := 7;
			else
				xOffsetFnt := 4;
			endif;
			theFrame.drawFontSize := 8;
			theFrame.drawFontBold := true;
		elseif self.scaleFactor = 1.5 then
			xWidth := 4;
			theFrame.drawWidth := 1;
			xOffset := 2;
			yOffset :=6;
			yOffsetFnt := 0;
			if theLetter.length = 1 then
				xOffsetFnt := 10;
			else
				xOffsetFnt := 3;
			endif;
			theFrame.drawFontSize := 10;
			theFrame.drawFontBold := true;
		elseif self.scaleFactor = 2 then
			xWidth := 6;
			xOffset := 2;
			yOffset := 8;
			yOffsetFnt := 0;
			if theLetter.length = 1 then
				xOffsetFnt := 14;
			else
				xOffsetFnt := 8;
			endif;
			theFrame.drawFontSize := 16;
		elseif self.scaleFactor = 3 then
			xWidth := 8;
			xOffset := 6;
			yOffset := 12;
			yOffsetFnt := 0;
			theFrame.drawFontSize := 24;
			if theLetter.length = 1 then
				xOffsetFnt := 22;
			else
				xOffsetFnt := 11;
			endif;
		elseif self.scaleFactor = 4 then
			xWidth := 10;
			xOffset := 8;
			yOffset := 15;
			yOffsetFnt := 0;
			if theLetter.length = 1 then
				xOffsetFnt := 30;
			else
				xOffsetFnt := 15;
			endif;
			theFrame.drawFontSize := 32;
		endif;
		theFrame.drawStyle := Frame.DrawStyle_Solid;
		theFrame.drawFillColor := White;
	
		aReal :=  _theX1 + ((_theX2 - _theX1) / 2);
		xOffsetFnt := aReal.Integer;

		// ### TFS 50421 05NOV2021 NAVAB1
		edgecolour := Black;
		if process.isJLGAB1() then
			 edgecolour:= White;
		endif;
		
		theFrame.drawFilledRectangle(_theX1 + xOffset, _theY1 + yOffset, _theX2 - xOffset, _theY2 - yOffset,  edgecolour); // ### TFS 50421 05NOV2021 NAVAB1
		theFrame.drawTextAt(theLetter, xOffsetFnt, _theY1 + yOffsetFnt, Black); 
	endif;
epilog
	theFrame.drawWidth := 1;
	theFrame.drawFontBold := false;

end;</source>
        <Parameter name="_frame" type="CMUI_GridAreaDrawingFrame"/>
        <Parameter name="_theLetter" type="String"/>
        <Parameter name="_theX1" type="Real"/>
        <Parameter name="_theY1" type="Real"/>
        <Parameter name="_theX2" type="Real"/>
        <Parameter name="_theY2" type="Real"/>
        <Parameter name="_backColour" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="drawHaveTIs" id="3ac482a8-f968-48e8-9127-312828d4281d">
        <updating/>
        <source>drawHaveTIs(_tis : CM_TIArray; _idx : Integer; _startY : Real) updating, protected;
// ---------------------------------------------------------------------------
// Created:     25 August 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
// -- WHEN ------ WHO -------- WHY--------------------------------------------
// ---------------------------------------------------------------------------
// 12/05/2010	cnwdap1		CCMS 1116 Tranship changes
// ---------------------------------------------------------------------------
constants
	FONTSIZE = 6;
vars
	startY,endX, endY, startX, origX	: Real;
	idx, theFrameHeight					: Integer;
	theOSTI, theTI						: CM_TrackedItem;
	theDisplayMode, aColour, 
	theFillColour 						: Integer;
	aLetter		 						: String;
	tmpTIs								: CM_TIArray;
	theCellHeight, numHalfHeights  		: Integer;
	theFrame							: YRD_ContainerDrawingFrame;
	tmpPrimaryLC						: CM_LocationsController;
begin

	tmpTIs := _tis;
	idx := _idx;
	startY := _startY;
	
	if self.flipHorizontal then
		origX := self.x2;
	else
		origX := self.x1;
	endif;

	theFrame := self.myDrawingFrame;
	
	theDisplayMode := self.displayMode;
	

	theFrame.drawFontName := "Arial";
	theFrame.drawFontSize := FONTSIZE * self.scaleFactor;
	theFrame.drawTextAlign := Frame.DrawTextAlign_Left;
	if self.myLocationsController.hasPower() then 
		theFillColour := self.POWER_FILL_COLOUR;
	else
		theFillColour := Gray;
		if self.myLocationsController.isOverhang() then
			theFillColour := theFrame.backColor;
		endif;
	endif;

	theFrameHeight	:= theFrame.height.Integer;

	aColour := self.colour;
	aLetter := self.letter;
	
		theTI := tmpTIs[idx];
		theOSTI := self.myLocationsController.hasOversizedBackendsByMode(self.displayMode, 1, self.allTrackedItems, false);
		startX := self.adjustStartX(theOSTI, self.myLocationsController, idx);
		endX := self.adjustEndX(theTI, startX);

		self.tiHeight := theTI.getHeightOfTI();
		if self.myDockBar.isForEndView then
			self.tiLength := 1;
		else
			self.tiLength := theTI.getLengthInUnits().Integer;
		endif;

		if theDisplayMode = DISPLAY_MODE_ACTUAL then
			tmpPrimaryLC := theTI.myPrimaryActualLocation;
		elseif theDisplayMode = DISPLAY_MODE_QUEUE then
//					tmpPrimaryLC := theTI.myPrimaryQueuedLocation;// PAR 18596
			if self.myLocationsController.isPrimaryLocationForFM(QUEUE_MODE, idx) then // PAR 18596
				tmpPrimaryLC := self.myLocationsController;// PAR 18596
			endif;
		elseif theDisplayMode = DISPLAY_MODE_PLAN then
			// PAR 15340
			if theTI.isRehandle 
			and (not theTI.myPrimaryPlannedLocation.isGridLocation) 
			and theTI.allPlannedFutureMoves.size = 2 then
				tmpPrimaryLC := theTI.allPlannedFutureMoves.last.CM_FutureMovePlanned.allLocationsControllers.first; // LAST FM
				if tmpPrimaryLC &lt;&gt; null then
					if not tmpPrimaryLC.isGridLocation then
						tmpPrimaryLC := theTI.allPlannedFutureMoves.first.CM_FutureMovePlanned.allLocationsControllers.first; // FIRST FM
					endif;
				endif;
			endif;

			if tmpPrimaryLC = null then
				tmpPrimaryLC := theTI.myPrimaryPlannedLocation;
			endif;
		endif;
		// NEVER draw a tranship import in the yard. switch to the tranship export.
		// PAR #23645 CCMS 1116 tranships are now just one TI, not two
		//if theTI.isTranshipImport() then		// PAR #23645 CCMS 1116
		//	theTI := theTI.myTranshipExport;	// PAR #23645 CCMS 1116
		//endif;								// PAR #23645 CCMS 1116

		
		if self.tiHeight = Ti_Half_Height then
			numHalfHeights := numHalfHeights + 1;
			theCellHeight := (self.cellHeight / 2).Integer;
		else
			theCellHeight := self.cellHeight.Integer;
		endif;
		startY 	:= startY - theCellHeight ; 
		endY	:= startY + theCellHeight;

		if startY &lt;=0 then// PAR 11143 
			return;
		endif;
		if startY &lt; self.y1 then
			return;
		endif;

		self.drawBackEnd := false;
		
		if tmpPrimaryLC &lt;&gt; self.myLocationsController then
			if self.myDockBar.isForEndView then
				self.drawBackEnd := true;
				//self.drawTI(theTI, null, startX, startY, self.x2, endY, theFrame); 		// cnwjk3 PAR 23875 23/04/10
				self.drawTI(theTI, null, startX, startY, self.x2, endY, theFrame, null); 	// cnwjk3 PAR 23875 23/04/10
				return;
			else
				// the TI will be drawn when its primary location is drawn
				return;
			endif;
		endif;


		self.setIconPositions(startX, startY, endX, endY);
		// PAR 18682
		if self.myLocationsController.offsetFlexi &gt; 0 
		and self.myLocationsController.hasOversizedBackendsByMode(self.displayMode, idx, self.allTrackedItems, false) = null then
			self.drawBlankSpace(theFrame, theFillColour, idx, origX, startY, startX, endY + 1, false);
		endif;
		//self.drawTI(theTI, null, startX, startY, endX, endY, theFrame); 		// cnwjk3 PAR 23875 23/04/10
		self.drawTI(theTI, null, startX, startY, endX, endY, theFrame, null); 	// cnwjk3 PAR 23875 23/04/10
			

epilog
end;</source>
        <access>protected</access>
        <Parameter name="_tis" type="CM_TIArray"/>
        <Parameter name="_idx" type="Integer"/>
        <Parameter name="_startY" type="Real"/>
    </JadeMethod>
    <JadeMethod name="drawHeight" id="8d856a88-0762-4488-8483-db687bbd101e">
        <source>drawHeight(_frame : CMUI_GridAreaDrawingFrame; _label: String; _colour: Integer; _theX1: Real; _theY1: Real; _theX2: Real; _theY2: Real) protected;
// ---------------------------------------------------------------------------
// Created:     25 August 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	theFrame 	: CMUI_GridAreaDrawingFrame;
	scaleFactor,
	fontSize, tmpX1, tmpX2, tmpX3 	: Real;
begin
	theFrame := _frame;

	fontSize := theFrame.drawFontSize;
	scaleFactor := self.scaleFactor;
	
	theFrame.drawFontBold := true;
	if scaleFactor &lt;= ScaleFactor_1_5 then
		theFrame.drawFontSize := 8;
	elseif scaleFactor = ScaleFactor_2 then
		theFrame.drawFontSize := 10;
	elseif scaleFactor = ScaleFactor_3 then
		theFrame.drawFontSize := 18;
	elseif scaleFactor = ScaleFactor_4 then
		theFrame.drawFontSize := 22;
	endif;
	theFrame.drawFontName := "Arial";
	
	tmpX1 := _theX1;
	tmpX2 := _theX2;
	if self.flipHorizontal then
		if tmpX1 &gt; tmpX2 then
			tmpX3 := tmpX1;
			tmpX1 := tmpX2;
			tmpX2 := tmpX3;
		endif;
	endif;
//	theFrame.drawTextAt("X", _theX1+((_theX2-_theX1)/2)-5, _theY1+((_theY2-_theY1)/2)-6, _colour);
	theFrame.drawTextAt("X", tmpX1+((tmpX2-tmpX1)/2)-5, _theY1+((_theY2-_theY1)/2)-6, _colour);
	theFrame.drawFontBold := false;
	theFrame.drawFontSize := fontSize;

end;</source>
        <access>protected</access>
        <Parameter name="_frame" type="CMUI_GridAreaDrawingFrame"/>
        <Parameter name="_label" type="String"/>
        <Parameter name="_colour" type="Integer"/>
        <Parameter name="_theX1" type="Real"/>
        <Parameter name="_theY1" type="Real"/>
        <Parameter name="_theX2" type="Real"/>
        <Parameter name="_theY2" type="Real"/>
    </JadeMethod>
    <JadeMethod name="drawHeightExceededLine" id="df41926c-1f5d-4928-bf00-1b810d68f001">
        <source>drawHeightExceededLine(_theFrame : YRD_ContainerDrawingFrame io; _newY1 : Real; _color, _width : Integer);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06 November 2009	cnwphb1	Initial creation (PAR 21532 CCMS SFW 1025)

*/

vars

begin
	// Draw a solid line, and then put an arrow on top at each side
	// First the solid line
	_theFrame.drawWidth := _width;
	_theFrame.drawLine(self.x1, _newY1, self.x2, _newY1, _color);
	
	// Now the arrows
	_theFrame.drawWidth := 1;
	_theFrame.drawLine(self.x1+1, _newY1-2, self.x1+5, _newY1-2, _color);
	_theFrame.drawLine(self.x1+2, _newY1-3, self.x1+4, _newY1-3, _color);
	
	_theFrame.drawLine(self.x2-5, _newY1-2, self.x2-1, _newY1-2, _color);
	_theFrame.drawLine(self.x2-4, _newY1-3, self.x2-2, _newY1-3, _color);
epilog

end;</source>
        <Parameter name="_theFrame" type="YRD_ContainerDrawingFrame" usage="io"/>
        <Parameter name="_newY1" type="Real"/>
        <Parameter name="_color" type="Integer"/>
        <Parameter name="_width" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="drawLC" id="3fb5e92b-0788-41e2-ab07-4d71c5442e16">
        <updating/>
        <source>drawLC(_lc : CM_GridController) updating, protected;
// ---------------------------------------------------------------------------
// Created:     25 August 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
// ---- 	WHO --- WHEN ----- 	WHY---------------------------------------------
// ---------------------------------------------------------------------------
//       	AKB    	19MAY2008     PAR 16415 CCMS 1029 30,45,53s
//			###		########	######################
//			AKB		01SEP2009		PAR 19468. This method was changed to always draw the actual TIs on 
//											the bottom of the LC graphic, then the Qs, then the Ps
//											So it does not use the display mode to draw the TIs in an order.
//											It always draws A, Q, P
//			DMP		13052010	CCMS 1116 Tranship changes
//			DMP		06102010	PAR #25971 Tranship drawing icon is also dependent on Tranship Imex Status, not just isTranship flag
//			jlgmd1	28062018	TFS #37853 - Fix drawing spaces around containers whos length doesn't fit the standard 20ft grid
// ---------------------------------------------------------------------------
constants
	FONTSIZE = 6;
vars
	startY,endX,
	endY, startX, origX	: Real;
	idx,
	tmpNumTIs, tmpNumQTIs, tmpNumPTIs,tmpNumATIs	: Integer;
	theOSTI, theTI: CM_TrackedItem;
	theDisplayMode,
	aColour, 
	theFillColour	: Integer;
	aLetter : String;
	theCellHeight, numHalfHeights, stackHght  : Integer;
	theFrame	: YRD_ContainerDrawingFrame;
	tmpLabourRestriction	: CM_LabourRestriction;
	tmpUsage,
	tmpAvail,
	tmpHeightNoStackFrom	: Integer;
	tmpBlockStack	: CM_BlockStack;
	isUnavailable,
	drawSolid, hasHeightRestriction, isPlaceholder	: Boolean;
	tmpPrimaryLC	: CM_LocationsController;
	tmpObj : Object;
	hasYA : Boolean;
	hatchedYA : CM_YardAllocation;
begin
	beginLoad;
	
	if self.flipHorizontal then
		origX := self.x2;
	else
		origX := self.x1;
	endif;
	
	theFrame := self.myDrawingFrame;

	stackHght := self.getHeightOfStack;	// PAR 21532 CCMS SFW 1025
	if self.drawFromNote then
		// ### PAR 20119 added '+ self.columnSpacing'
		// ### PAR 20244 removed '+ self.columnSpacing'
		self.gridObjectsRemove(self.x1.Integer,self.y1.Integer,self.x2.Integer,self.y2.Integer);
		// ### PAR 10593. Make an adjustment for the TI and the LC being the same size.
		if stackHght = 1 then
			self.y1 := self.y1 + 1;
		endif;

		self.drawBetweenColumns(theFrame);
	endif;
	self.myLocationsController := _lc;

	if self.yardGridAreaTranshipMark &lt;&gt; null then// CCMS 1574
		self.hasTranshipYardAllocation := _lc.includesYardAllocationCriteria(CM_YATypeIsTransShip, true, false) // CCMS 1574
										or _lc.includesYardAllocationCriteria(CM_YATypeImexStatus, app.myRoot.allImexStatuses[TI_IMEX_STATUS_TRANSHIP], false);	// PAR #25971
	endif;
	
	if _lc = null or stackHght = 0 then
		// Nothing to draw
		return;
	endif;
	theDisplayMode := self.displayMode;
	
	tmpLabourRestriction 	:= _lc.allLabourRestrictions.first;
	tmpHeightNoStackFrom 	:= _lc.getHeightNoStackFrom();
	tmpBlockStack			:= _lc.mySubBlockStack;
	
	//cnwjo3 par 24145
	hasYA := (_lc.allYardAllocations.size &gt; 0);
	if hasYA then
		hatchedYA := _lc.allYardAllocations.findHatchedYA();
		if hatchedYA = null then
			hasYA := false;
		endif;
	endif;
	
	_lc.getAvailUsageHeight(tmpUsage, tmpAvail, hasHeightRestriction);
	isUnavailable := (tmpUsage = UNAVAILABLE_USE or 
						 tmpAvail = PAD_USER_UNAVAILABLE or 
		   				 tmpAvail = PAD_UNAVAILABLE);

	theFrame.drawFontName := "Arial";
	theFrame.drawFontSize := FONTSIZE * self.scaleFactor;
	theFrame.drawTextAlign := Frame.DrawTextAlign_Left;
	if self.myLocationsController.hasPower() then 
		theFillColour := self.POWER_FILL_COLOUR;
	else
		theFillColour := Gray;
		if self.myLocationsController.isOverhang() then
			theFillColour := theFrame.backColor;
		endif;
	endif;

//	if theDisplayMode = DISPLAY_MODE_ACTUAL then

	self.setTICollections();
	
	tmpNumTIs := self.allTempTIs.size;
	theFrame.drawWidth	:= 1;
	tmpNumQTIs := self.allTIsQ.size;
	tmpNumPTIs := self.allTIsP.size;
	tmpNumATIs := self.allTIsA.size; 

	aColour := self.colour;
	aLetter := self.letter;
	
	if tmpBlockStack &lt;&gt; null then
		self.drawSubBlockStack(tmpBlockStack);
	elseif tmpUsage = BUILDING_USE then // BUILDING
		self.drawBuilding();

	elseif tmpUsage = LIGHT_TOWER_USE then // LIGHT
		self.drawLight();

	else
		self.cellHeight := ((self.y2 - self.y1) / stackHght).Integer;
		numHalfHeights := 0;
		startY := self.y2;

		while true do
			idx := idx + 1;

			// PAR 11143 just incase of continious loop
			if idx &gt; 100 then
				break;
			endif;
			tmpPrimaryLC := null; // PAR 22614
			
			theTI := null;
			
			//15/06/2011 cnwdz2 27732
			if self.drawForkLiftNoFrontAccess then					
				theOSTI := self.myLocationsController.hasOversizedBackendsByMode(self.displayMode, idx, self.allTrackedItems, false);
				startX := self.adjustStartX(theOSTI, self.myLocationsController, idx);
				endX := self.adjustEndX(null, startX);
				
				self.myDrawingFrame.drawWidth := 2;
				//17/10/2011 cnwdz2 28121
				if self.myDockBar.isForEndView then
					self.myDrawingFrame.drawLine(startX-3,self.y1,startX-3,self.y2,Red);
				else
					self.myDrawingFrame.drawLine(startX,self.y1-3,endX,self.y1-3,Red);												
				endif;
			endif;
			
			//15/06/2011 cnwdz2 27732
			if self.drawForkLiftNoBackAccess then							
				theOSTI := self.myLocationsController.hasOversizedBackendsByMode(self.displayMode, idx, self.allTrackedItems, false);
				startX := self.adjustStartX(theOSTI, self.myLocationsController, idx);
				endX := self.adjustEndX(null, startX);
				
				self.myDrawingFrame.drawWidth := 2;
				//17/10/2011 cnwdz2 28121
				if self.myDockBar.isForEndView then
					self.myDrawingFrame.drawLine(endX+3,self.y1,endX+3,self.y2,Red);
				else
					self.myDrawingFrame.drawLine(startX,self.y2+3,endX,self.y2+3,Red);												
				endif;
			endif;
			
			if idx &lt;= tmpNumTIs then
				theTI := self.allTempTIs[idx];
				isPlaceholder := (	theTI = self.myTrackedItem and (self.myTrackedItem &lt;&gt; null and self.myTrackedItem.id = "DUMMY")); // PAR 23409

				if isPlaceholder then
					startX := origX;
					if self.flipHorizontal then
						endX := self.x1;
					else
						endX := self.x2;
					endif;
					tmpPrimaryLC := _lc;
				else
					theOSTI := self.myLocationsController.hasOversizedBackendsByMode(self.displayMode, 1, self.allTrackedItems, false);
					startX := self.adjustStartX(theOSTI, self.myLocationsController, idx);
					endX := self.adjustEndX(theTI, startX);
	
	// #########
	
					self.tiHeight := theTI.getHeightOfTI();
					if self.myDockBar.isForEndView then
						self.tiLength := 1;
					else
						self.tiLength := theTI.getLengthInUnits().Integer;
					endif;
	
					//if theDisplayMode = DISPLAY_MODE_ACTUAL then
					if self.allTIsA.includes(theTI) then
						tmpPrimaryLC := theTI.myPrimaryActualLocation;
					elseif self.allTIsQ.includes(theTI) then
						if _lc.isPrimaryLocationForFM(QUEUE_MODE, idx) then // PAR 18596
							tmpPrimaryLC := _lc;// PAR 18596
						endif;
					elseif self.allTIsP.includes(theTI) then
						// PAR 15340
						if theTI.isRehandle 
						and (not theTI.myPrimaryPlannedLocation.isGridLocation) 
						and theTI.allPlannedFutureMoves.size = 2 then
							tmpPrimaryLC := theTI.allPlannedFutureMoves.last.CM_FutureMovePlanned.allLocationsControllers.first; // LAST FM
							if tmpPrimaryLC &lt;&gt; null then
								if not tmpPrimaryLC.isGridLocation then
									tmpPrimaryLC := theTI.allPlannedFutureMoves.first.CM_FutureMovePlanned.allLocationsControllers.first; // FIRST FM
								endif;
							endif;
						endif;
	
						if tmpPrimaryLC = null then
							tmpPrimaryLC := theTI.myPrimaryPlannedLocation;
							//if tmpPrimaryLC = null and theTI.isTranshipExport() then // PAR 22614				// PAR #23645 CCMS 1116
							//	tmpPrimaryLC := theTI.myTranshipImport.myPrimaryPlannedLocation; // PAR 22614	// PAR #23645 CCMS 1116
							//endif;																			// PAR #23645 CCMS 1116
						endif;
					endif;
					// NEVER draw a tranship import in the yard. switch to the tranship export.
					// PAR #23645 CCMS 1116 Tranships are now just one TI, not two
					//if theTI.isTranshipImport() then		// PAR #23645 CCMS 1116
					//	theTI := theTI.myTranshipExport;	// PAR #23645 CCMS 1116
					//endif;								// PAR #23645 CCMS 1116
	
				endif;						
					if self.tiHeight = Ti_Half_Height then
						numHalfHeights := numHalfHeights + 1;
						theCellHeight := (self.cellHeight / 2).Integer;
					else
						theCellHeight := self.cellHeight.Integer;
					endif;
					startY 	:= startY - theCellHeight ; 
					endY	:= startY + theCellHeight;
	
					if startY &lt;=0 then// PAR 11143 
						break;
					endif;
					if startY &lt; self.y1 then
						break;
					endif;

					drawSolid := 	(theDisplayMode = DISPLAY_MODE_ACTUAL and self.allTIsA.includes(theTI))
								or		(theDisplayMode = DISPLAY_MODE_QUEUE and self.allTIsQ.includes(theTI))
								or		(theDisplayMode = DISPLAY_MODE_PLAN and self.allTIsP.includes(theTI));
	
					self.drawBackEnd := false;
					
					if tmpPrimaryLC &lt;&gt; _lc then
						if self.myDockBar.isForEndView then
							self.drawBackEnd := true;
							if drawSolid then
								//self.drawTI(theTI, null, startX, startY, self.x2, endY, theFrame);		// cnwjk3 PAR 23875 23/04/10
								self.drawTI(theTI, null, startX, startY, self.x2, endY, theFrame, _lc);	// cnwjk3 PAR 23875 23/04/10
							else
								self.doDrawFMLetterForTI(theFrame, theTI, theFillColour, startX, startY,endX, endY);
							endif;
							continue;
						else
							// the TI will be drawn when its primary location is drawn
							continue;
						endif;
					endif;

				
// ##########

				if drawSolid then
	
					self.setIconPositions(startX, startY, endX, endY);
					// PAR 18682
					if isPlaceholder then
						self.drawBlankSpace(theFrame, theFillColour, idx, startX, startY, endX, endY + 1, false);
					else
						//self.drawTI(theTI, null, startX, startY, endX, endY, theFrame);		// cnwjk3 PAR 23875 23/04/10
						self.drawTI(theTI, null, startX, startY, endX, endY, theFrame, _lc);	// cnwjk3 PAR 23875 23/04/10
					endif;
				else // no solid, draw A, Q, P
					if isPlaceholder then
						self.drawBlankSpace(theFrame, theFillColour, idx, startX, startY, endX, endY + 1, false);
					else
						self.doDrawFMLetterForTI(theFrame, theTI, theFillColour, startX, startY,endX, endY);
					endif;
				endif;
/*				
				if self.drawFromNote
				and theTI.myOSBackEndLocation &lt;&gt; null and theTI.myOSBackEndLocation.allTrackedItems.isEmpty() then
					self.drawBlankSpaceAfterOSBEndFlexi(theTI, idx, startY, endY + 1, theTI.myOSBackEndLocation);
				endif;
	*/			
			// ###################################
			// ###################################
			// ###################################
			// ###################################
			// NO TIS JUST BLANKS AND RESTRICTIONS
			else
				theOSTI := self.myLocationsController.hasOversizedBackendsByMode(self.displayMode, idx, self.allTrackedItems, false);
				startX := self.adjustStartX(theOSTI, self.myLocationsController, idx);
				endX := self.adjustEndX(null, startX);
				
				// #######################
				// OK if going in here then we do not have any TIs in this view mode
				
				if not self.myDockBar.isForEndView then
					if (startX &gt; endX and not self.flipHorizontal)
					or (startX &lt; endX and self.flipHorizontal)  then
						// We're normally drawing left to right, so don't do something silly by trying to draw right to left
						// Unless we're flipped, then make sure we're not drawing left to right...
						break;
					endif;
				endif;
				
				if numHalfHeights mod 2 = 0 then
					theCellHeight := self.cellHeight.Integer; // there have been an even number of 1/2s so reset now
				else
					theCellHeight := (self.cellHeight / 2).Integer;
				endif;

				numHalfHeights := 0;				
				startY 	:= startY - theCellHeight; 
	
				if startY &lt;=0 then// PAR 11143 
					break;
				endif;

				if startY &lt; self.y1 then
					break;
				endif;
				endY	:= startY + theCellHeight + 1;
				theCellHeight := self.cellHeight.Integer; // this may be half height to fill in, so reset it for next time
				
				// PAR 18682
				if self.myLocationsController.offsetFlexi &gt; 0 
				and self.hasGotItemAtHeight(idx, false) 
				and (self.myLocationsController.allTrackedItemOSBackEnds.isEmpty()
						and self.myLocationsController.allTrackedItemOSBackEndsQd.isEmpty()
						and self.myLocationsController.allTrackedItemOSBackEndsPd.isEmpty()) then
					self.drawBlankSpace(theFrame, theFillColour, idx, origX, startY, startX, endY, false);
				endif;

				// ## GAP	
				if self.myLocationsController.isKindOf(CM_GapController) then
					if self.myLocationsController.isKindOf(CM_OverhangController) then // PAR 18682
						self.drawBlankSpaceOverhang(theFrame, self.myDrawingFrame.backColor, idx, startX -1, startY, endX, endY - 1); 
					else
					
						if theFillColour &lt;&gt; POWER_FILL_COLOUR then
							theFillColour := self.myDrawingFrame.backColor;
						endif;
						self.drawBlankSpace(theFrame, theFillColour, idx, startX, startY, endX, endY - 1, true); 
					endif;
				// ## HEIGHT or LABOUR RESTRICTION
				elseif tmpLabourRestriction &lt;&gt; null and (not isUnavailable) then
					if hasHeightRestriction then // HEIGHT RESTRICTION
						if idx &gt;= tmpHeightNoStackFrom then
							self.drawBlankSpace(theFrame, theFillColour, idx, startX, startY, endX, endY - 1, true); 
							self.drawHeight(theFrame, aLetter, Red, startX, startY, endX, endY);
						else
							aColour := tmpLabourRestriction.colour;
							if idx &gt; (tmpNumQTIs + tmpNumPTIs + tmpNumTIs) then // PAR 18229
								self.drawBlankSpace(theFrame, theFillColour, idx, startX, startY, endX, endY - 1, true); 
								self.drawTranshipMark(theFrame, startX, startY, idx);
								self.drawLabour(theFrame, tmpLabourRestriction, startX, startY, endX, endY);
							endif;
						endif;
					else
						aColour := tmpLabourRestriction.colour;
						if idx &gt; (tmpNumQTIs + tmpNumPTIs + tmpNumTIs) then // PAR 18229
							self.drawBlankSpace(theFrame, theFillColour, idx, startX, startY, endX, endY - 1, true); 
							self.drawTranshipMark(theFrame, startX, startY, idx);
							self.drawLabour(theFrame, tmpLabourRestriction, startX, startY, endX, endY);
						endif;
					endif;
				// ## HEIGHT RESTRICTION
				elseif hasHeightRestriction then // HEIGHT RESTRICTION
					if idx &gt; (tmpNumQTIs + tmpNumPTIs + tmpNumTIs) then // PAR 17825			// 20/11/2012 cnwmh5 #30758
						self.drawBlankSpace(theFrame, theFillColour,idx, startX, startY , endX, endY, true); 
					endif;
					if idx &gt;= tmpHeightNoStackFrom then
						self.drawBlankSpace(theFrame, theFillColour,idx, startX, startY , endX, endY, true);				// 21/11/2012 cnwmh5 #30758
						self.drawHeight(theFrame, aLetter, Red, startX, startY, endX, endY);
					else
						self.drawTranshipMark(theFrame, startX, startY, idx);
					endif;
				elseif theDisplayMode &lt;&gt; DISPLAY_MODE_ACTUAL 
				and idx &lt;= tmpNumTIs 
				and tmpNumTIs &gt; 0 then
						self.drawLetter(theFrame,"A", (startX+((self.x2-startX)/2)-5).Integer, (startY + 2).Integer, Black,startX, startY, self.x2, endY,theFillColour,REAL_MODE,idx);
				//cnwjo3 par 24145
				elseif hasYA then
					self.drawBlankSpace(theFrame, theFillColour,idx,startX,startY,endX,endY,true);
					self.drawSelfYardAllocationHatch(theFrame, hatchedYA, startX, startY, endX, endY);
				else
					if isUnavailable then
						theFillColour := theFrame.backColor;
					endif;
					
					// draw a back end cross for the overhang.
					if theOSTI &lt;&gt; null and self.myDockBar.isForEndView and tmpNumTIs = 0 then
						if theDisplayMode &lt;&gt; DISPLAY_MODE_ACTUAL  then
							self.drawFMLetterBackend(startX, startY, self.x2, endY);
						else
							self.drawBackEnd := true;
							//self.drawTI(theOSTI, null, startX, startY, self.x2, endY, theFrame);		// cnwjk3 PAR 23875 23/04/10
							self.drawTI(theOSTI, null, startX, startY, self.x2, endY, theFrame, _lc);	// cnwjk3 PAR 23875 23/04/10
						endif;
						continue;
					endif;
					self.drawBlankSpace(theFrame, theFillColour, idx, startX, startY, endX, endY, true ); 

					if not isUnavailable then
						self.drawTranshipMark(theFrame, startX, startY, idx);
					endif;
				endif;
				
				// draw the Ps and Qs in addition to the actual TI graphic
//				letterIndex := letterIndex + 1;
//				self.doDrawFMLetter(theDisplayMode, idx, theFillColour, startX, startY, endY);
			endif;

		endwhile;
	endif;
	
	self.checkIfHeightExceeded(theFrame, tmpNumTIs);	// PAR 21532 CCMS SFW 1025 - Check if height exceeded
epilog
	endLoad;

	if not self.allGridObjects.includes(self.myLocationsController) and tmpBlockStack = null then
		// if the stack height is 1 then the LC rectangle and a 20 foot rectangle have the same Xs and Ys so need to jig the LC to be 1 pixel out
		// ### PAR 20119 added '+ self.columnSpacing'
		// ### PAR 20244 removed '+ self.columnSpacing'
		tmpObj := self.gridObjectsGetAtKeyForPut(self.x1.Integer,self.y1.Integer,self.x2.Integer,self.y2.Integer);
		if tmpObj = null then
			// ### PAR 10593. Make an adjustment for the TI and the LC being the same size. But the LC now being empty
			if self.drawFromNote and stackHght = 1 then
				self.y1 := self.y1 - 1;
			endif;

			self.gridObjectsPutAtKey(self.x1.Integer,self.y1.Integer,self.x2.Integer,self.y2.Integer, self.myLocationsController);
		else
			if not tmpObj.isKindOf(CM_LocationsController) then
				// ### PAR 10593 - the 'self.y1.Integer - 1' was 'self.y1.Integer + 1'
				// ### PAR 10593. Make an adjustment for the TI and the LC being the same size.
				self.gridObjectsPutAtKey(self.x1.Integer,self.y1.Integer - 1,self.x2.Integer,self.y2.Integer, self.myLocationsController); //
			endif;
		endif;
	endif;
	
	if theFrame &lt;&gt; null then
		theFrame.drawFontName := "Arial";
		theFrame.drawFontSize := FONTSIZE * self.scaleFactor;
		theFrame.drawTextAlign := Frame.DrawTextAlign_Left;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_lc" type="CM_GridController"/>
    </JadeMethod>
    <JadeMethod name="drawLabour" id="0fa842e0-6ce3-4692-9f83-5a0d26a83dc8">
        <source>drawLabour(_frame : CMUI_GridAreaDrawingFrame; _tmpLabourRestriction: CM_LabourRestriction;_theX1: Real; _theY1: Real; _theX2: Real; _theY2: Real) protected;
// ---------------------------------------------------------------------------
// Created:     25 August 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	theFrame : CMUI_GridAreaDrawingFrame;
	label : String; 
	colour : Integer;
	anOffset1, anOffset2, aSlotHeight, aWindowHeight, idx : Integer;
	aHeight, tmpx1, tmpx2, tmpy1, tmpy2 : Integer;

	aPrevGridPoint : YRD_GridPoint;
	theSamePrev, theSameAbove : Boolean;
	aRest : CM_Restriction;
begin
	// This is so that we can clear up when a restriction is deleted
	self.addLCbyOID(_tmpLabourRestriction);
	
// PAR 18682	theFrame := self.myDrawingFrame;
	theFrame := _frame;
	theFrame.drawFillColor := _tmpLabourRestriction.colour;
	theFrame.drawFillStyle := Frame.DrawFillStyle_DownDiagonal;

	theFrame.drawFilledRectangle(_theX1, _theY1, _theX2, _theY2, _tmpLabourRestriction.colour);
epilog
	theFrame.drawFillStyle := Frame.DrawFillStyle_Solid;

end;</source>
        <access>protected</access>
        <Parameter name="_frame" type="CMUI_GridAreaDrawingFrame"/>
        <Parameter name="_tmpLabourRestriction" type="CM_LabourRestriction"/>
        <Parameter name="_theX1" type="Real"/>
        <Parameter name="_theY1" type="Real"/>
        <Parameter name="_theX2" type="Real"/>
        <Parameter name="_theY2" type="Real"/>
    </JadeMethod>
    <JadeMethod name="drawLetter" id="150d7ee3-7d03-4f52-9fd5-fef9017af36a">
        <updating/>
        <source>drawLetter(_theFrame: CMUI_GridAreaDrawingFrame input; _theLetter: String; _theX: Integer; _theY: Integer; _theColour: Integer; _theX1: Real; _theY1: Real; _theX2: Real; _theY2: Real; _theFill: Integer; _mode: Integer; _tiIndex: Integer) updating;
// ---------------------------------------------------------------------------
// Created:     25 August 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	is40 : Boolean;
	xOffset, yOffset,yOffsetFnt,xOffsetFnt,xWidth : Integer;
	theLetter : String;
begin

	_theFrame.drawFillColor := _theFill;
	_theFrame.drawFilledRectangle(_theX1, _theY1, _theX2, _theY2,  _theFill);
	_theFrame.drawTextAt(_theLetter, _theX, _theY, _theColour);

end;</source>
        <Parameter name="_theFrame" type="CMUI_GridAreaDrawingFrame" usage="input"/>
        <Parameter name="_theLetter" type="String"/>
        <Parameter name="_theX" type="Integer"/>
        <Parameter name="_theY" type="Integer"/>
        <Parameter name="_theColour" type="Integer"/>
        <Parameter name="_theX1" type="Real"/>
        <Parameter name="_theY1" type="Real"/>
        <Parameter name="_theX2" type="Real"/>
        <Parameter name="_theY2" type="Real"/>
        <Parameter name="_theFill" type="Integer"/>
        <Parameter name="_mode" type="Integer"/>
        <Parameter name="_tiIndex" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="drawLight" id="6e07f24b-e341-4211-8c62-710d771c0d8f">
        <updating/>
        <source>drawLight() updating, protected;
// ---------------------------------------------------------------------------
// Created:     25 August 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	theFrame : CMUI_GridAreaDrawingFrame;
	anOffset1, anOffset2, aSlotHeight, aWindowHeight,aColour, idx : Integer;
	aHeight, tmpx1, tmpx2, tmpy1, tmpy2 : Integer;
	aLetter : String;
	aPrevGridPoint : YRD_GridPoint;
	theSamePrev, theSameAbove : Boolean;
	lPicture : Binary;
begin
	theFrame := self.myDrawingFrame;

	self.drawOverLappingRectangle(theSamePrev, theSameAbove, DarkGray, Yellow, theFrame);

	if self.isForSatelliteView and self.scaleFactor &lt; 1 then
		return;
	endif;
	
	lPicture := app.myRoot.getConfig(PicLightBulb).Binary;
	theFrame.drawPictureAt(lPicture, self.x1 + 1, self.y1 + 1);

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="drawMainCode" id="14e0c9a1-2030-4b08-a7bb-22ae7abd5292">
        <updating/>
        <source>drawMainCode(_theTI: CM_TrackedItem; 
			_x1: Real; _y1: Real; _x2: Real; _y2: Real; 
			_frame: CMUI_GridAreaDrawingFrame input;
			_textColour	: Integer) updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 May 2010	cnwndl1	Initial creation	Par 24044 - migrated up a class

*/

vars
	theFrame: CMUI_GridAreaDrawingFrame;
	lTIColour : Integer;
	lDisplayMode,lViewMode : Integer;
	lFactor : Real;
	tmpStr,
	theMainCode, tmpDPort, tmpLPort : String;
	theTI : CM_TrackedItem ;
	theWeight : Decimal[8,2];
	tmpNum		: Integer;
	theISOCode : String;
	theTempString, theJN : String;
	tmpTemp		: Real;
	grade : CM_MTGrade;
	fm : CM_FutureMove;
begin
	lFactor := self.scaleFactor;
	lDisplayMode := self.displayMode;
	lViewMode := self.viewMode;
	// #############
	if lFactor &lt; 2 then
		return;
	endif;

	theTI := _theTI;
	
	if theTI = null then
		return;
	endif;

	theFrame := _frame;
	theFrame.drawTextAlign := Frame.DrawTextAlign_Left;
	
	if CM_Container.hasInstance(theTI) then
		tmpTemp := theTI.CM_Container.getTemperature;
		if tmpTemp &lt;&gt; NULL_TEMPERATURE then
			if theTI.myOperator.displayTempFahrenheit then
				theTempString := theTI.getDisplayTemperature(false, false);
			else
				theTempString := theTI.getDisplayTemperature(false, true); 
			endif;
		endif;
	endif;
		
	theISOCode := theTI.getISOType();
	
	lTIColour:= _frame.drawFillColor; //epr 9/2/2011 have already set the background colour and called the self.getFillColourForTI method
									  // which correctly handles if it is null and sets it to white
	//lTIColour := self.getFillColourForTI(theTI);
	
	//theInverseColour := lTIColour.getInverseColour();
	
	//theFrame.drawFillColor := lTIColour;

	theWeight := theTI.totalWeight / 1000;
	tmpDPort := theTI.dischargePort;
	if tmpDPort.length &gt; 3 then
		tmpDPort := tmpDPort[3:3];
	endif;
	tmpLPort := theTI.loadPort;
	if tmpLPort.length &gt; 3 then
		tmpLPort := tmpLPort[3:3];
	endif;
	 
	if lViewMode = VIEW_COMMODITY then
		theMainCode := theTI.commodityGroup;
	elseif lViewMode = TI_ColourMode_ISOTypeGroup  then
		theMainCode := theISOCode; 
	elseif lViewMode = VIEW_HEIGHT  then
	elseif lViewMode = VIEW_HAZ  then
		//theMainCode := theTI.getHazardsAsString(false); 
		theMainCode := theTI.getHazardsFirstAsString(); 
	elseif lViewMode = VIEW_IMEX  then
		theMainCode := theTI.getImExStatusStringDesc(false); 
	elseif lViewMode = VIEW_VOYAGE  then
		theMainCode := theTI.voyageCode[1:3]; 
	elseif lViewMode = VIEW_OPERATOR then
		theMainCode := theTI.operatorCode;
	elseif lViewMode = VIEW_DISPORT then
		theMainCode := tmpDPort;
	elseif lViewMode = VIEW_LOADPORT then
		theMainCode := theTI.loadPort;
		if theMainCode.length &gt;= 5 then
			theMainCode := theMainCode[3:end];
		endif;
	elseif lViewMode = VIEW_WEIGHT then
		theWeight := theTI.totalWeight / 1000;
		theMainCode := tmpDPort;
	elseif lViewMode = VIEW_STATUS then
		if CM_Container.hasInstance(theTI) then
			theMainCode := theTI.CM_Container.contentsStatusCode();
		endif;
	elseif lViewMode = VIEW_TEMPERATURE then
		if CM_Container.hasInstance(theTI) then
			tmpTemp := theTI.CM_Container.getTemperature;
			if tmpTemp &lt;&gt; NULL_TEMPERATURE then
				theMainCode := 	theTempString; 
			endif;
		endif;
	//20 Jul 2011	NDL	Par 27890
	elseif lViewMode = VIEW_DWELL_DAYS then
		if theTI.getMyDwellDayRange &lt;&gt; null then
			theMainCode := theTI.getMyDwellDayRange.getDisplayValue;
		endif;
	//29 Jul 2011	NDL	Par 27890
	elseif lViewMode = VIEW_MTGRADE then
		if theTI.isContainer then
			grade := theTI.cargoIF_GetObjectForETRow(ETRow_AvailabilityGradeCode).CM_MTGrade;
		endif;
		if grade &lt;&gt; null then
			theMainCode := grade.description;
		endif;
	elseif lViewMode = VIEW_CARRIERIN then		// 12/6/17 MAP TFS4209
		theMainCode := theTI.carrier;
	elseif lViewMode = VIEW_CARRIEROUT then		// 12/6/17 MAP TFS4209
		theMainCode := theTI.releaseCarrier;
		
	else
		theMainCode := theTI.commodityGroup;
	endif;	
	
	if lFactor = 9  then
		theFrame.drawFontSize :=10;
		theFrame.drawTextAt(theISOCode &amp; "   " &amp; theTI.operatorCode &amp; "  " &amp; theWeight.rounded.String,_x1 + 4, _y1 + 2, _textColour);
		theFrame.drawTextAt(theTI.id, _x1 + 2, _y1 + 15,_textColour);

		tmpStr := theTempString; 
		if tmpStr &lt;&gt; null then 
			theFrame.drawTextAt(theTI.commodity, _x1 + 2, _y1 + 30, _textColour);
			theFrame.drawTextAt(tmpStr, _x1 + 40, _y1 + 30, _textColour);
		else
			theFrame.drawTextAt(theTI.commodityGroup, _x1 + 2, _y1 + 30, _textColour);
		endif;

		theFrame.drawTextAt(tmpDPort &amp; " X " &amp; tmpLPort ,_x1 + 2 , _y1 + 45, _textColour);
	
		// PAR 26193
		if _theTI.getPrimaryLocation(QUEUE_MODE) = null and _theTI.allPlannedFutureMoves.size &gt;= 1 then
			// PAR 33336	theJN := _theTI.loadJobNum.String;
			theJN := self.getTILoadJobNumber(_theTI); // PAR 33336
		
			// PAR 30320 theJN := theJN[theJN.reversePos(",") + 1: end];
			theFrame.drawTextAt(theJN &amp; "/" &amp; _theTI.loadSeqNumber,_x1 + 2 , _y1 + 93, _textColour);
		endif;
		

	elseif lFactor = 6 then
		theFrame.drawFontSize := 10;
		theFrame.drawTextAt(theISOCode &amp; " " &amp; theTI.operatorCode,_x1 + 4, _y1 + 2, _textColour);
		tmpStr := theTI.id;
		tmpNum := tmpStr.length;
		if tmpNum &lt;= 4 then
			theFrame.drawTextAt(tmpStr,_x1 + 2, _y1 + 15, _textColour);
		else
			if theTempString.length &gt; 5 then
				theTempString := theTempString[1:5];
			endif;
			theFrame.drawTextAt(tmpStr[1:4] &amp; " " &amp; theTempString,_x1 + 2, _y1 + 15, _textColour);
			theFrame.drawTextAt("- " &amp; tmpStr[5:end],_x1 + 5, _y1 + 27, _textColour);
		endif;
		theFrame.drawTextAt(theWeight.rounded.String,_x1 + 55, _y1 + 50, _textColour);

	elseif lFactor = 4 then
		theFrame.drawFontSize := 9;
		if theMainCode.length &gt; 6 then
			theMainCode := theMainCode[1:6];
		endif;
		theFrame.drawTextAt(theMainCode &amp; " " &amp; theWeight.rounded.String,_x1 + 2, _y1 + 2, _textColour);
		
		// PAR 26193
		if _theTI.getPrimaryLocation(QUEUE_MODE) = null and _theTI.allPlannedFutureMoves.size &gt;= 1 then
			theFrame.drawFontSize := 8;
			// PAR 33336	theJN := _theTI.loadJobNum.String;
			theJN := self.getTILoadJobNumber(_theTI); // PAR 33336

			// PAR 30320 theJN := theJN[theJN.reversePos(",") + 1: end];
			theFrame.drawTextAt(theJN &amp; "/" &amp; _theTI.loadSeqNumber,_x1 + 2 , _y1 + 36, _textColour);
		endif;

	elseif lFactor = 3 then
		theFrame.drawFontSize := 7;
		if theMainCode.length &gt; 5 then
			theMainCode := theMainCode[1:5];
		endif;
		theFrame.drawTextAt(theMainCode &amp; " " &amp; theWeight.rounded.String,_x1 + 2, _y1 + 2, _textColour);
	elseif lFactor = 2   then
		theFrame.drawFontSize := 7;
		theMainCode := theWeight.rounded.String;
		theFrame.drawTextAt(theMainCode,_x1 + 5, _y1 + 1, _textColour);
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_theTI" type="CM_TrackedItem"/>
        <Parameter name="_x1" type="Real"/>
        <Parameter name="_y1" type="Real"/>
        <Parameter name="_x2" type="Real"/>
        <Parameter name="_y2" type="Real"/>
        <Parameter name="_frame" type="CMUI_GridAreaDrawingFrame" usage="input"/>
        <Parameter name="_textColour" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="drawMelons" id="2c932a28-56a6-4a03-90f7-c04202d31115">
        <source>drawMelons(_frame : Frame input; _offsetX, _offsetY : Real; _fill : Integer);
// ---------------------------------------------------------------------------
// Created:		10 July 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	theScale : Real;
	theX, theY, theX2, theY2, idx, endIDX : Integer;
	allPoints : RealArray;
	edgecolour: Integer;
begin
	theScale := (self.scaleFactor / 2);


	// ### TFS 50421 05NOV2021 NAVAB1
	edgecolour := Black;
	if process.isJLGAB1() then
		 edgecolour:= _fill;
	endif;
	
	_frame.drawFillColor := _fill;
	_frame.drawFilledRectangle((4 * theScale) + _offsetX, (3 * theScale) + _offsetY, (43 * theScale) + _offsetX, (15 * theScale) + _offsetY,edgecolour);  // ### TFS 50421 05NOV2021 NAVAB1

	_frame.drawFillColor := 4210816; // Brown
	
	// ### TFS 50421 05NOV2021 NAVAB1
	edgecolour := Black;
	if process.isJLGAB1() then
		 edgecolour:= _frame.drawFillColor;
	endif;
	
	_frame.drawFilledRectangle((4 * theScale) + _offsetX, (16 * theScale) + _offsetY, (43 * theScale) + _offsetX, (19 * theScale) + _offsetY,edgecolour);
	_frame.drawFilledRectangle((4 * theScale) + _offsetX, (19 * theScale) + _offsetY, (8 * theScale) + _offsetX, (22 * theScale) + _offsetY,edgecolour);
	_frame.drawFilledRectangle((22 * theScale) + _offsetX, (19 * theScale) + _offsetY, (26 * theScale) + _offsetX, (22 * theScale) + _offsetY,edgecolour);
	_frame.drawFilledRectangle((39 * theScale) + _offsetX, (19 * theScale) + _offsetY, (43 * theScale) + _offsetX, (22 * theScale) + _offsetY,edgecolour);

	
	
epilog
	delete allPoints;
end;</source>
        <Parameter name="_frame" type="Frame" usage="input"/>
        <Parameter name="_offsetX" type="Real"/>
        <Parameter name="_offsetY" type="Real"/>
        <Parameter name="_fill" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="drawMinature" id="860f79c3-d720-4291-9d92-6a2aa0ced021">
        <source>drawMinature(_frame: Frame input; _tmpDkbPos	: CMUI_JadeDockBar input);
// ---------------------------------------------------------------------------
// Created:     08 March 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
constants
	OFFSET = 4;
	ANGLE = 6;
vars
	tmpBayDrawingFrame	: YRD_ContainerDrawingFrame;
	tmpBay				: CM_Bay;
	lastLeft, lastTop,
	tmpLeft, tmpTop,
	theHatchY,
	theX1, theY1,
	theX2, theY2		: Real;
	thePoly 			: RealArray;
	colNum,
	rowNum				: Integer;
	grdRow : CM_GridRow;
	grdCol : CM_GridColumn;
	anLC : CM_LocationsController;
begin

	_frame.drawFillColor := 16764573;
	_frame.drawFontSize := 8;
	_frame.drawFontName := Font_MicrosoftSansSerif;
	_frame.drawTextAlign := Frame.DrawTextAlign_Center;


	theX1 := OFFSET;
	theY1 := OFFSET;
	
	foreach grdRow in self.myTerminalArea.CM_GridArea.allGridRows do
		theY2 := theY1 + self.POSFRM_HEIGHT;
		foreach anLC in grdRow.allControllersByColumn do

			colNum := anLC.CM_GridController.myGridColumn.column;
			rowNum := grdRow.row;
			theX2 := theX1 + self.POSFRM_WIDTH;
			
			_frame.drawFilledRectangle(theX1,theY1,theX2,theY2,Black);
			_frame.drawTextAt(anLC.ident,(((theX2 - theX1) / 2) + theX1),theY1 + 1,Black);
//app.writeStatement( "AKB " &amp; self.class.name &amp; "::" &amp; method.name &amp; " 1. " &amp; anLC.ident &amp; " theX2: " &amp; theX2.String &amp; " theY2: " &amp; theY2.String);


			theX1 := theX2 + OFFSET;

		endforeach;
		theY1 := theY2 + OFFSET;
		theX1 := OFFSET;
	endforeach;

	_tmpDkbPos.width := theX2 + OFFSET; //((self.myDrawingFrame..width / _scale) + 15);
	_tmpDkbPos.height := theY2 + OFFSET; //(self.myDrawingFrame.height / _scale) + 15 + 25;
	
epilog

end;</source>
        <Parameter name="_frame" type="Frame" usage="input"/>
        <Parameter name="_tmpDkbPos" type="CMUI_JadeDockBar" usage="input"/>
    </JadeMethod>
    <JadeMethod name="drawObject" id="5de9404b-bd42-424d-bc66-f38af3561a49">
        <updating/>
        <source>drawObject(_frame : CMUI_GridAreaDrawingFrame input; _obj: Object) updating;
// ---------------------------------------------------------------------------
// Created:		December 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
begin
	if _obj = null then
		return;
	endif;

	self.myDrawingFrame.drawObject(_obj, self);

end;</source>
        <Parameter name="_frame" type="CMUI_GridAreaDrawingFrame" usage="input"/>
        <Parameter name="_obj" type="Object"/>
    </JadeMethod>
    <JadeMethod name="drawOverLappingRectangle" id="9fe347b6-560c-4096-8af6-df79bd562319">
        <source>drawOverLappingRectangle(_theSamePrev, _theSameAbove: Boolean; _backColour, _foreColour : Integer; _frame: CMUI_GridAreaDrawingFrame input);
// ---------------------------------------------------------------------------
// Created:		June  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	theFrame : CMUI_GridAreaDrawingFrame;
	anOffset1, anOffset2,anOffset3,anOffset4,aSlotHeight, aWindowHeight, idx : Integer;
	aHeight, tmpx1, tmpx2, tmpy1, tmpy2 : Integer;
begin
	theFrame := _frame;
	
	theFrame.drawStyle := Frame.DrawStyle_Solid;
	theFrame.drawFillStyle := Frame.DrawFillStyle_Solid;

	tmpx1 := self.x1.Integer;
	tmpy1 := self.y1.Integer;
	anOffset4 := 2;
	tmpx2 := self.x2.Integer;
	tmpy2 := self.y2.Integer;
	if _theSameAbove then
		anOffset3 := 8;
	else
		anOffset3 := 0;
	endif;
	if _theSamePrev then // the previous point is also the same sub block
		anOffset1:= 2;
		anOffset2 := 4;
	else
		anOffset1:= 0;
		anOffset2 := 2;
	endif;

	theFrame.drawFillColor := _backColour;
	theFrame.drawFilledRectangle(tmpx1 - anOffset1 , tmpy1 - 2 - anOffset3 , tmpx2 , tmpy2,_backColour);
	theFrame.drawFillColor := _foreColour;
	theFrame.drawFilledRectangle(tmpx1 - anOffset2, tmpy1 - 4 - anOffset3, tmpx2 - anOffset4, tmpy2 - 2,_foreColour);

end;</source>
        <Parameter name="_theSamePrev" type="Boolean"/>
        <Parameter name="_theSameAbove" type="Boolean"/>
        <Parameter name="_backColour" type="Integer"/>
        <Parameter name="_foreColour" type="Integer"/>
        <Parameter name="_frame" type="CMUI_GridAreaDrawingFrame" usage="input"/>
    </JadeMethod>
    <JadeMethod name="drawOverSizedMark" id="5348b7cf-0421-41f9-989c-5fca4ea090e2">
        <source>drawOverSizedMark(_frame: CMUI_GridAreaDrawingFrame; _theTI: CM_TrackedItem; _color: Integer; _x1: Real; _y1: Real; _x2: Real; _y2: Real) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 May 2010	cnwndl1	Initial creation	Par 24044 - migrated up a class
15 Nov 2010 cnwer1 	PAR 26189 removed unused height parameter
*/
vars
	theFrame : CMUI_GridAreaDrawingFrame;
	lineY, thick : Integer;
begin
	if self.scaleFactor &lt; 3 then
		return;
	endif;
/* PAR 17067 WAS
	theFrame := self.myDrawingFrame;
	thick := 1;
	theFrame.drawStyle := Frame.DrawStyle_Solid;
	theFrame.drawWidth := 1;

	lineY := (_y2 - (self.scaleFactor + 1 )).Integer;
	theFrame.drawLine(_x1,lineY,_x2, lineY, _color.getInverseColour());
NOW */
	theFrame := _frame;
	thick := 1;
	theFrame.drawStyle := Frame.DrawStyle_Solid;
	theFrame.drawWidth := 1;
	lineY := (_y2 - 3).Integer;

	theFrame.drawLine(self.x1, lineY, self.x2, lineY,  _color.getInverseColour());
	
	if _theTI.isAttributeTrue(TI_Attrib_IsThirty) then
		return;
	endif;
	lineY := (_y2 - 6).Integer;
	
	theFrame.drawLine(self.x1,lineY, self.x2, lineY,  _color.getInverseColour());
	
	if _theTI.isAttributeTrue(TI_Attrib_IsFortyFive) then
		return;
	endif;
	lineY := (_y2 - 9).Integer;

	theFrame.drawLine(self.x1, lineY, self.x2, lineY,  _color.getInverseColour());
	
		
end;</source>
        <access>protected</access>
        <Parameter name="_frame" type="CMUI_GridAreaDrawingFrame"/>
        <Parameter name="_theTI" type="CM_TrackedItem"/>
        <Parameter name="_color" type="Integer"/>
        <Parameter name="_x1" type="Real"/>
        <Parameter name="_y1" type="Real"/>
        <Parameter name="_x2" type="Real"/>
        <Parameter name="_y2" type="Real"/>
    </JadeMethod>
    <JadeMethod name="drawRectangle" id="7dc5fdc1-574a-43d4-9361-5fd8eb57049c">
        <source>drawRectangle(_frame: Frame input; x1: Real; y1: Real; x2: Real; y2: Real; _outerColourUpper: Integer; _outerColourLower: Integer) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 May 2010	cnwndl1	Initial creation	Par 24044 - migrated up a class

*/

vars
	tmpColor	: Integer;
begin

	_frame.drawFilledRectangle(x1, y1, x2, y2, Black); 

	_frame.drawLine(x1, y1, x2, y1, _outerColourUpper);
	_frame.drawLine(x1, y1, x1, y2 - 1, _outerColourUpper);
	_frame.drawLine(x2 - 1, y1 + 1, x2 - 1, y2, _outerColourLower);
	_frame.drawLine(x1, y2 - 1, x2 - 1, y2 - 1, _outerColourLower);

end;</source>
        <access>protected</access>
        <Parameter name="_frame" type="Frame" usage="input"/>
        <Parameter name="x1" type="Real"/>
        <Parameter name="y1" type="Real"/>
        <Parameter name="x2" type="Real"/>
        <Parameter name="y2" type="Real"/>
        <Parameter name="_outerColourUpper" type="Integer"/>
        <Parameter name="_outerColourLower" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="drawRoRoLaneFromNote" id="64c6494c-a688-4c68-a497-8af93c329378">
        <source>drawRoRoLaneFromNote() protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 January 2010	cnwjk3	ccms 1018

*/

vars

begin

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="drawSelf" id="2883ce49-f98c-448a-90bf-f02b542957bb">
        <updating/>
        <source>drawSelf(_clearSelected: Boolean) updating;
/* ---------------------------------------------------------------------------
// Created:     25 August 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
// Date			Who		Reason
// 12 Nov 2008	consw1	SFW1030 - Yard Allocation enhancements
// ################################################
//	22/12/2008		cnwab1	SFW1055 - 30,45, 53 handling
//						From 771 we draw the background grid first and then in a seperate frame we draw the TIs.
//						The TI frame (myDrawingFrame) is transparent, and the back ground frame (myBackgroundFrame) is behind it.
29 May 2012 	cnwer1	PAR 29588 - no access from front means the bottom, no access from back means the top
*/
vars
	maxX,
	maxY	: Integer;
	tmpTA	: CM_GridArea;
	tmpRow	: CM_GridRow;
	tmpCol	: CM_GridColumn;
	rowIdx,
	colIdx	: Integer;
	theRowHeight,
	theColWidth,
	yPos1, yPos2,
	xPos1, xPos2	: Real;	
	tmpLbl	: String;
	topLeftFiller : Frame;
	firstONE : Boolean;
	drawGap : Boolean;
	forkLiftStack : CM_ForkLiftStack;
begin

//write class.name &amp; '::' &amp; method.name;
//beginTransaction;
	self.drawFromNote := false;
	create self.myTrackedItem as CM_Container transient; // dummy placeholder
	self.myTrackedItem.setPropertyValue("id","DUMMY");
	
	self.allTempTIs.clear;

	if self.myTerminalArea = null then
		return;
	endif;

	inheritMethod(_clearSelected);
	
	tmpTA := self.myTerminalArea.CM_GridArea;
	self.heightOfStack := tmpTA.getHeightOfStack();
	if self.myYardGridAreaForm &lt;&gt; null then
		useSelectorObjects := self.myYardGridAreaForm.useSelector;
	endif;
	
	self.allGridObjects.clear;
	self.allYARows.clear;

	self.myDrawingFrame.clearGraphics();

	self.myVLabels.clearGraphics();
	self.myVLabels.width := self.LABEL_WIDTH;
	self.myVLabels.top := self.LABEL_WIDTH + 1;
	self.myVLabels.autoRedraw := true;
	
	self.myHLabels.clearGraphics();
	self.myHLabels.height := self.LABEL_WIDTH;
	self.myHLabels.autoRedraw := true;
	self.setFontDefaults();
	
	topLeftFiller := self.myDockBar.myScrollableFrame.myTopLeftFillerFrame;
	topLeftFiller.ignoreSkin := true;
	topLeftFiller.clearGraphics();
	topLeftFiller.autoRedraw := true;
	topLeftFiller.drawFontSize := 10; // ### PAR 10555
	
	tmpLbl := tmpTA.getID();
	if tmpLbl.length &lt; 3 then // ### PAR 10555
		topLeftFiller.drawFontSize := 16; // ### PAR 10555
	elseif tmpLbl.length &lt; 6 then // ### PAR 10555
		topLeftFiller.drawFontSize := 8; // ### PAR 10555
	else
		topLeftFiller.drawFontSize := 6; 
	endif;
	
	topLeftFiller.drawTextAt(tmpLbl, 1, 8, Black); // ### PAR 10555
	
	if tmpTA.isRightAligned() then
		topLeftFiller.drawFontSize := 8; 
		topLeftFiller.drawTextAt("RIGHT", 1, 30, Red); 
	endif;
	topLeftFiller.visible := true;
	topLeftFiller.move(0,0,self.myDockBar.myScrollableFrame.myVLabels.clientWidth,self.myDockBar.myScrollableFrame.myHLabels.height);

	self.myDrawingFrame.caption := null;
	theRowHeight := self.getRowHeightForScale();
	theColWidth	 := self.getColumnWidthForScale();
	self.columnWidth := theColWidth.Integer; // PAR 16415
	
	// draw the column headings
	colIdx := 0;
	xPos1 := self.LABELGAP;

	if self.flipHorizontal then
		foreach tmpCol in tmpTA.allGridColumns reversed where tmpCol.column &lt;= self.maxColumn do
			if tmpCol.column &lt; self.minColumn then
				break;
			endif;
			self.drawSelfColumn(tmpCol,xPos1); // &lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;
		endforeach;
	else
		foreach tmpCol in tmpTA.allGridColumns where tmpCol.column &gt;= self.minColumn do
			if tmpCol.column &gt; self.maxColumn then
				break;
			endif;
			self.drawSelfColumn(tmpCol,xPos1); // &lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;
		endforeach;
	endif;	

	yPos1 := 5; //TopMargin;
	yPos2 := yPos1 + theRowHeight;
	firstONE := true;
	//15/06/2011 cnwdz2 27732
	if tmpTA.isKindOf(CM_ForkLiftStack) then
		forkLiftStack := tmpTA.CM_ForkLiftStack;
	endif;
	
	if self.flipVertically then
		foreach tmpRow in tmpTA.allGridRows reversed where tmpRow.row &lt;= self.maxRow do
			if tmpRow.row &lt; self.minRow then
				break;
			endif;
		
			if tmpRow.hasGap then
				drawGap := true;
				continue;
			endif;
			if drawGap and not firstONE then
				yPos1 := yPos1 + 20;
				yPos2 := yPos1 + theRowHeight;
			endif;
			
			//15/06/2011 cnwdz2 27732
			if forkLiftStack &lt;&gt; null then
				if tmpRow.row = tmpTA.allGridRows.size and
				   not forkLiftStack.accessFront then		// was accessBack														
					self.drawForkLiftNoFrontAccess := true;
				endif;				
				if tmpRow.row = 1 and 				   
				   not forkLiftStack.accessBack then //was accessFront
					self.drawForkLiftNoBackAccess := true;
				endif;
			endif;
			
			self.drawSelfRow(tmpRow,yPos1,yPos2,xPos2,rowIdx); // &lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;
						
			//15/06/2011 cnwdz2 27732
			self.drawForkLiftNoFrontAccess := false;
			self.drawForkLiftNoBackAccess := false;
			
			drawGap := false;
			firstONE := false;
		endforeach;
	else
		foreach tmpRow in tmpTA.allGridRows where tmpRow.row &gt;= self.minRow do
			if tmpRow.row &gt; self.maxRow then
				break;
			endif;
			if tmpRow.hasGap then
				drawGap := true;
				continue;
			endif;
			if drawGap and not firstONE then
				yPos1 := yPos1 + 20;
				yPos2 := yPos1 + theRowHeight;
			endif;
			
			//15/06/2011 cnwdz2 27732
			if forkLiftStack &lt;&gt; null then
				if tmpRow.row = 1 and				
				   not forkLiftStack.accessBack then		// was accessFront															
					self.drawForkLiftNoFrontAccess := true;	
					
				endif;
				if tmpRow.row = tmpTA.allGridRows.size and
				   not forkLiftStack.accessFront then // was accessBack	
				    self.drawForkLiftNoBackAccess := true;
					
				endif;
			endif;
			
			self.drawSelfRow(tmpRow,yPos1,yPos2,xPos2,rowIdx); // &lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;
			
			//15/06/2011 cnwdz2 27732
			self.drawForkLiftNoFrontAccess := false;
			self.drawForkLiftNoBackAccess := false;
			
			drawGap := false;
			firstONE := false;
		endforeach;
	endif;	
	xPos2 := xPos2 + theColWidth;
	maxX := (xPos2 + self.Margin - theColWidth).Integer ;
	maxY := (yPos2 + self.Margin - theRowHeight).Integer;


	self.drawSubBlockStackLabels();
	self.myDockBar.resizeScrollingFrame(maxX, maxY);
	self.myDockBar.myScrollingFrame.left := self.LABEL_WIDTH + 1;
	self.myDockBar.myScrollingFrame.top := self.LABEL_WIDTH + 1;

	self.myDockBar.resetScrollValues();

epilog

end;</source>
        <Parameter name="_clearSelected" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="drawSelfALL" id="3c86df8a-1d90-4097-ace8-bf32f1e7a4fe">
        <updating/>
        <source>drawSelfALL() updating;
// ---------------------------------------------------------------------------
// Created:		13 August 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
begin
	inheritMethod();
end;</source>
    </JadeMethod>
    <JadeMethod name="drawSelfColumn" id="866a0286-95d5-441f-8224-240c747dff93">
        <updating/>
        <source>drawSelfColumn(_col : CM_GridColumn; _xpos1 : Real io) updating;
/* ---------------------------------------------------------------------------
// Created:		January 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
29 May 2012 	cnwer1	PAR 29588 - no access from front means the bottom, no access from back means the top
*/
vars
	topTextMargin	: Integer;
	tmpX, 
	theColWidth,
	xPos1, xPos2	: Real;	
	tmpCaption	: String;
	tmpFrame	: CMUI_Frame;	//YRD_ContainerDrawingFrame;
	tmpTA	: CM_GridArea;
begin

	if self.myTerminalArea = null then
		return;
	endif;
	tmpTA := self.myTerminalArea.CM_GridArea;
	
	tmpFrame := self.myHLabels;
	theColWidth	 := self.getColumnWidthForScale();

	if _col.hasGap then
		theColWidth := self.getGapDrawWidth(_col);
	endif;
	if theColWidth = 0 then
		return;
	endif;
	
	xPos1 := _xpos1;
	xPos2 := xPos1 + theColWidth;
	
	tmpCaption := _col.label;

	if tmpCaption[1:1] = "_" then
		tmpCaption := null;
	endif;
	
	if tmpCaption = null then
		//don't return without updating _xpos1  PAR 10662
		xPos1 := xPos1 + self.columnSpacing + theColWidth;
		_xpos1 := xPos1;
		return;
	endif;
	
	tmpX := (xPos1 + ((xPos2 - xPos1) / 2)); 
	tmpFrame.drawTextAlign := Frame.DrawTextAlign_Center;
	
	//20/06/2011 cnwdz2 27732 start
	topTextMargin := 10;
	if tmpTA.isKindOf(CM_ForkLiftStack) or tmpTA.isKindOf(CM_StraddleStack) then
		if not self.flipVertically and tmpTA.topLabel &lt;&gt; null then
			topTextMargin := topTextMargin + 5;	
			if (self.flipHorizontal and  _col.column = tmpTA.allGridColumns.size ) or
			   (not self.flipHorizontal and _col.column = 1 ) then
				tmpFrame.drawTextAt(tmpTA.topLabel, tmpX, 1, Red);
			endif;
		endif;
		
		if  self.flipVertically and tmpTA.bottomLabel &lt;&gt; null then
			topTextMargin := topTextMargin + 5;	
			if (self.flipHorizontal and _col.column = tmpTA.allGridColumns.size) or 
			   (not self.flipHorizontal and _col.column = 1 ) then
				tmpFrame.drawTextAt(tmpTA.bottomLabel, tmpX, 1, Red);
			endif;
		endif;					
	endif;
	//20/06/2011 cnwdz2 27732 end
	
	tmpFrame.drawTextAt(tmpCaption, tmpX + 1, topTextMargin + 1, White);
	tmpFrame.drawTextAt(tmpCaption, tmpX, topTextMargin, Black);
	xPos1 := xPos1 + self.columnSpacing + theColWidth;

	_xpos1 := xPos1;
epilog
	tmpFrame.drawTextAlign := Frame.DrawTextAlign_Left;

end;</source>
        <Parameter name="_col" type="CM_GridColumn"/>
        <Parameter name="_xpos1" type="Real" usage="io"/>
    </JadeMethod>
    <JadeMethod name="drawSelfLC" id="1b98fe31-ba41-401f-8b6e-f38bfb0f077a">
        <updating/>
        <source>drawSelfLC(_lc: CM_GridController; _xpos1,_xpos2 : Real io; _colIdx	: Integer io) updating;
// ---------------------------------------------------------------------------
// Created:		January 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	theColWidth : Real;
begin

	theColWidth	 := self.ColumnWidth * self.scaleFactor;
	if _lc.myGridColumn.hasGap then
		theColWidth := self.getGapDrawWidth(_lc.myGridColumn);
	endif;
	_colIdx := _colIdx + 1;
	_xpos1 := _xpos2 + self.columnSpacing;
	_xpos2 := _xpos1 + theColWidth;

	self.x1 := _xpos1;
	self.x2 := _xpos2;

	self.drawLC(_lc);
end;</source>
        <Parameter name="_lc" type="CM_GridController"/>
        <Parameter name="_xpos1" type="Real" usage="io"/>
        <Parameter name="_xpos2" type="Real" usage="io"/>
        <Parameter name="_colIdx" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="drawSelfRow" id="49aef88d-68ab-4b7f-bffa-38580314b1d3">
        <updating/>
        <source>drawSelfRow(_row : CM_GridRow; _yPos1 : Real io; _yPos2 : Real io; _xPos2 : Real io; _rowIdx : Integer io) updating;
// ---------------------------------------------------------------------------
// Created:		January 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// Date			Who		Reason
// 12 Nov 2008	consw1	SFW1030 - Yard Allocation enhancements

constants
	TopTextMargin	: Integer = 10;
	LeftTextMargin	: Integer = 5;

	TopMargin		: Integer = 10;
	BottomMargin	: Integer = 10;
	LeftMargin		: Integer = 10;
	RightMargin		: Integer = 10;
	RowSpacing		: Integer = 10;

vars
	tmpDrawingController	: YRD_ContainerDrawingController;
	maxX,
	maxY	: Integer;
	tmpTA	: CM_GridArea;
	tmpRow	: CM_GridRow;
	tmpCol	: CM_GridColumn;
	tmpLC	: CM_GridController;
	rowIdx,
	colIdx	: Integer;
	tmpX, tmpY,
	theRowHeight,
	theColWidth,
	yPos1, yPos2,
	xPos1, xPos2	: Real;	
	tmpCaption	: String;
	tmpFrame	: CMUI_Frame;
	yaHeight	: Integer;

begin
	tmpTA := self.myTerminalArea.CM_GridArea;
	if  tmpTA = null then
		return;
	endif;
	
	yPos1 := _yPos1;
	yPos2 := _yPos2;
	tmpRow := _row;
	tmpFrame := self.myVLabels;
	theColWidth	 := self.getColumnWidthForScale();
	theRowHeight := self.getRowHeightForScale();
	
	xPos1 := LeftMargin;
	xPos2 := xPos1 + theColWidth;
	// Draw the row label
	tmpCaption := tmpRow.getLabel;
	if tmpCaption[1:1] = "_" then
		tmpCaption := null;
	endif;
	//if tmpCaption &lt;&gt; null then
		
	tmpCaption:= tmpRow.getLabel;
	tmpX := 10;// PAR 10484
	tmpY := (yPos1 + ((yPos2 - yPos1) / 2)) - 10; // the 10 is half the height of the text in pixels
	
	//20/06/2011 cnwdz2 27732
	if tmpTA.isKindOf(CM_ForkLiftStack) or tmpTA.isKindOf(CM_StraddleStack) then
		if self.flipHorizontal and tmpTA.rightLabel &lt;&gt; null then
			tmpX := tmpX + 5;	
			if (self.flipVertically and _row.row = tmpTA.allGridRows.size) or 
			   (not self.flipVertically and _row.row = 1) then
				tmpFrame.drawTextRotation := 270;
				tmpFrame.drawTextCharRotation := 270;
				tmpFrame.drawTextAt(tmpTA.rightLabel, 16, tmpY-tmpFrame.getTextExtent(tmpTA.rightLabel)/2+5, Red);
				tmpFrame.drawTextCharRotation := 0;
				tmpFrame.drawTextRotation := 0;
			endif;
		endif;
		
		if not self.flipHorizontal and tmpTA.leftLabel &lt;&gt; null then
			tmpX := tmpX + 5;	
			if (self.flipVertically and _row.row = tmpTA.allGridRows.size) or 
			   (not self.flipVertically and _row.row = 1) then
				tmpFrame.drawTextRotation := 270;
			    tmpFrame.drawTextCharRotation := 270;				
				tmpFrame.drawTextAt(tmpTA.leftLabel, 16, tmpY-tmpFrame.getTextExtent(tmpTA.leftLabel)/2+5, Red);
				tmpFrame.drawTextCharRotation := 0;
				tmpFrame.drawTextRotation := 0;
			endif;
		endif;					
	endif;
	
	tmpFrame.drawTextAt(tmpCaption, tmpX + 1, tmpY + 1, White);
	tmpFrame.drawTextAt(tmpCaption, tmpX, tmpY, Black);
		
	//endif;	

	self.y1 := yPos1;
	self.y2 := yPos2;

	xPos1 := self.LABELGAP - theColWidth;
	xPos2 := self.LABELGAP;

	colIdx := 0;
	/*
	// ### CCMS 1509 - draw a red line if no access
	if not self.myTerminalArea.CM_GridArea.hasAccessLeft() then
		self.myDrawingFrame.drawWidth := 2;
		self.myDrawingFrame.drawLine(xPos2,yPos1,xPos2,yPos2 + RowSpacing,Red);
	endif;
	*/
	if self.flipHorizontal then
		if not self.myTerminalArea.CM_GridArea.hasAccessRight() then
			self.myDrawingFrame.drawWidth := 2;
			self.myDrawingFrame.drawLine(xPos2,yPos1,xPos2,yPos2 + RowSpacing,Red);
		endif;
		foreach tmpLC in tmpRow.allControllersByColumn reversed where tmpLC.column &lt;= self.maxColumn do
			if tmpLC.column &lt; self.minColumn then
				break;
			endif;
			self.drawSelfLC(tmpLC, xPos1,xPos2,colIdx);
		endforeach;
		if not self.myTerminalArea.CM_GridArea.hasAccessLeft() then
			self.myDrawingFrame.drawWidth := 2;
			self.myDrawingFrame.drawLine(xPos2 + 3,yPos1,xPos2 + 3,yPos2 + RowSpacing,Red);
		endif;
	else
		// ### CCMS 1509 - draw a red line if no access
		if not self.myTerminalArea.CM_GridArea.hasAccessLeft() then
			self.myDrawingFrame.drawWidth := 2;
			self.myDrawingFrame.drawLine(xPos2,yPos1,xPos2,yPos2 + RowSpacing,Red);
		endif;
		foreach tmpLC in tmpRow.allControllersByColumn where tmpLC.column &gt;= self.minColumn do
			if tmpLC.column &gt; self.maxColumn then
				break;
			endif;
			self.drawSelfLC(tmpLC, xPos1,xPos2,colIdx);
		endforeach;
			// ### CCMS 1509 - draw a red line if no access
		if not self.myTerminalArea.CM_GridArea.hasAccessRight() then
			self.myDrawingFrame.drawWidth := 2;
			self.myDrawingFrame.drawLine(xPos2 + 3,yPos1,xPos2 + 3,yPos2 + RowSpacing,Red);
		endif;
	endif;
	self.hasTranshipYardAllocation := false;
	/*
	// ### CCMS 1509 - draw a red line if no access
	if not self.myTerminalArea.CM_GridArea.hasAccessRight() then
		self.myDrawingFrame.drawWidth := 2;
		self.myDrawingFrame.drawLine(xPos2 + 3,yPos1,xPos2 + 3,yPos2 + RowSpacing,Red);
	endif;*/

	//if not self.allYARows.includes( tmpRow ) then
		yaHeight := self.drawYardAllocationLinesForRow( tmpRow, yPos2.Integer + 1, 0 );
	//endif;

	yPos1 := yPos1 + RowSpacing + theRowHeight + yaHeight;
	yPos2 := yPos1 + theRowHeight;

	_rowIdx := _rowIdx + 1;

	_yPos1 := yPos1;
	_yPos2 := yPos2;
	_xPos2 := xPos2;
end;</source>
        <Parameter name="_row" type="CM_GridRow"/>
        <Parameter name="_yPos1" type="Real" usage="io"/>
        <Parameter name="_yPos2" type="Real" usage="io"/>
        <Parameter name="_xPos2" type="Real" usage="io"/>
        <Parameter name="_rowIdx" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="drawSelfRowDrawStackDir" id="e2e2a977-68f4-4b5b-9bbb-fc52805a7eba">
        <updating/>
        <source>drawSelfRowDrawStackDir(_row : CM_GridRow; _frame : Frame input; _x,_y,_y1,_y2 : Integer) updating;
// ---------------------------------------------------------------------------
// Created:		May 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
//				ONly call this for rows with decking options
//
// ---------------------------------------------------------------------------
constants
	RowHeight = 12;
vars
	tmpCaption 			: String;
	tmpX, tmpY,cellY1,cellY2,cellIdx,theRowHeight,char, yOffset : Integer;
	dirArray			: IntegerArray;
	deckingOptions		: CM_YADeckingOptions;
	stackHght			: Integer;
begin
	if not self.configAutoPlanUseAllocations then
		return;
	endif;

	deckingOptions := _row.myDeckingOptions;
	if deckingOptions = null then
		deckingOptions := _row.myGridArea.myYADeckingOptions;
	endif;
	
	stackHght := self.getHeightOfStack;	// PAR 21532 CCMS SFW 1025
	theRowHeight := (RowHeight * stackHght * self.scaleFactor).Integer;
	cellHeight := (theRowHeight / stackHght).Integer;

	// ##### ROW STACKING DIRECTION 
	if deckingOptions.isDeckingDirectionDown(_row) then
		if self.flipVertically then
			tmpCaption := 225.Character; //"^"
		else
			tmpCaption := 226.Character; // "\/"
		endif;
	elseif deckingOptions.isDeckingDirectionUp(_row) then
		if self.flipVertically then
			tmpCaption := 226.Character; // "\/"
		else
			tmpCaption := 225.Character; //"^"
		endif;
	elseif deckingOptions.isDeckingLeftToRight() then
		if self.flipHorizontal then
			tmpCaption := 223.Character; // "&lt;--"
		else
			tmpCaption := 224.Character; // "--&gt;"
		endif;
	else
		if self.flipHorizontal then
			tmpCaption := 224.Character; // "--&gt;"
		else
			tmpCaption := 223.Character; // "&lt;--"
		endif;
	endif;		

	_frame.drawFontName := "Wingdings";

	tmpX := _x;
	tmpY := _y;
	_frame.drawTextAt(tmpCaption, tmpX + 1, tmpY + 1, White);
	_frame.drawTextAt(tmpCaption, tmpX, tmpY, Black);
	
	
	// ##### ROW and STACK POSITION DECKING DIRECTION UP, LEFT or RIGHT
	dirArray := self.deckingArray;
	dirArray.clear;
	deckingOptions.getHeightDirections(dirArray); // Decking_Left

	if dirArray.isEmpty then
		return;
	endif;

	tmpX := _x + 31;
	yOffset  := 8;

	if self.scaleFactor = self.ScaleFactor_1 then
		yOffset := 3;
	elseif self.scaleFactor = self.ScaleFactor_1_5 then
		yOffset := 3;
	elseif self.scaleFactor = self.ScaleFactor_2 then
		yOffset := 5;
	endif;
	cellY1 := _y2;
	foreach cellIdx in 1 to stackHght do : cellLoop
		cellY2 := cellY1 - cellHeight;
		
		char := dirArray[cellIdx];
		if char = Decking_Left then
			if self.flipHorizontal then
				tmpCaption := 224.Character; // "--&gt;"
			else
				tmpCaption := 223.Character; // "&lt;--"
			endif;
		elseif char = Decking_Right then
			if self.flipHorizontal then
				tmpCaption := 223.Character; // "&lt;--"
			else
				tmpCaption := 224.Character; // "--&gt;"
			endif;
		elseif char = Decking_Up then
			tmpCaption := 225.Character; //"^"
		elseif char = Decking_Down then
			tmpCaption := 226.Character; // "\/"
		else
			tmpCaption := 243.Character; // "&lt;-&gt;" = custom or no particular direction
		endif;

		tmpY := (((cellY1 - cellY2) / 2) + cellY2).Integer;
		
		tmpY := tmpY - yOffset;
		_frame.drawTextAt(tmpCaption, tmpX + 1, tmpY + 1, White);
		_frame.drawTextAt(tmpCaption, tmpX, tmpY, Black);


		cellY1 := cellY2;
	endforeach;
	

epilog
	_frame.drawFontName := "Arial"; // PAR 20182 was Ariel

end;</source>
        <Parameter name="_row" type="CM_GridRow"/>
        <Parameter name="_frame" type="Frame" usage="input"/>
        <Parameter name="_x" type="Integer"/>
        <Parameter name="_y" type="Integer"/>
        <Parameter name="_y1" type="Integer"/>
        <Parameter name="_y2" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="drawSelfVLabels" id="c7645d71-7152-464b-8b0d-df1e4cb0bf8f">
        <updating/>
        <source>drawSelfVLabels() updating;
// ---------------------------------------------------------------------------
// Created:		April 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
constants
	TopTextMargin	: Integer = 10;
	LeftTextMargin	: Integer = 5;

	TopMargin		: Integer = 10;
	BottomMargin	: Integer = 10;
	LeftMargin		: Integer = 10;
	RightMargin		: Integer = 10;
	RowSpacing		: Integer = 10;

	RowHeight		: Integer = 12;
	ColWidth		: Integer = 24;

vars
	tmpTA	: CM_GridArea;
	tmpRow	: CM_GridRow;
	rowIdx,
	colIdx,rowNum,colNum	: Integer;
	tmpX, tmpY,
	theRowHeight,
	theColWidth,
	yPos1, yPos2,
	xPos1, xPos2,tmpRowIdx	: Integer;	
	tmpCaption	: String;
	tmpFrame	: CMUI_Frame;	//YRD_ContainerDrawingFrame;

begin

	tmpTA := self.myTerminalArea.CM_GridArea;
	if tmpTA = null then
		return;
	endif;

	tmpFrame := self.myVLabels;
	tmpFrame.clearGraphics();
	
	colNum := tmpTA.allGridColumns.size;
	rowNum := tmpTA.allGridRows.size;
	theColWidth	 := (ColWidth * self.scaleFactor).Integer;
	theRowHeight := (RowHeight * self.getHeightOfStack * self.scaleFactor).Integer;	// PAR 21532 CCMS SFW 1025

	xPos1 := self.LABELGAP;
	xPos2 := (colNum * theColWidth).Integer + self.LABELGAP + ((colNum - 1) * self.columnSpacing).Integer;

	foreach rowIdx in 1 to rowNum do
		yPos1 :=  yPos2;
		yPos2 := yPos1 + theRowHeight + RowSpacing;
		

		if self.flipVertically then
			tmpRowIdx := (rowNum - rowIdx) + 1;
			tmpRow := tmpTA.allGridRows[tmpRowIdx];
		else
			tmpRow := tmpTA.allGridRows[rowIdx];
		endif;
		
		if tmpRow &lt;&gt; null then
			// Draw the row label
			tmpCaption := tmpRow.label;
			if tmpCaption[1:1] = "_" then
				tmpCaption := null;
			endif;
			if tmpCaption &lt;&gt; null then
// PAR 10484	tmpX := ((tmpFrame.width / 2) - ((tmpCaption.length * 7) / 2)).Integer;
				tmpX := 11;// PAR 10484
				tmpY := ((yPos1 + ((yPos2 - yPos1) / 2)) - 10).Integer; // the 10 is half the height of the text in pixels
				tmpFrame.drawTextAt(tmpCaption, tmpX + 1, tmpY + 1, White);
				tmpFrame.drawTextAt(tmpCaption, tmpX, tmpY, Black);
				
			endif;	
		
			if tmpTA.isStraddleStack() and not self.myDockBar.isForOverview then	
				self. drawSelfRowDrawStackDir(tmpRow,tmpFrame,(tmpX - 12).Integer,tmpY.Integer, yPos1,yPos2-8);// PAR 10484 minus 12 was minus 14
			endif;
		endif;

	endforeach;
end;</source>
    </JadeMethod>
    <JadeMethod name="drawSelfYardAllocationHatch" id="b1098256-442c-4752-b1c4-03ae16ddd0bf">
        <source>drawSelfYardAllocationHatch(_frame : CMUI_GridAreaDrawingFrame; _ya: CM_YardAllocation;_theX1: Real; _theY1: Real; _theX2: Real; _theY2: Real) protected;
// --------------------------------------------------------------------------------
// Created:		10 June 2010 by cnwjo3
//
// Purpose:		draw the hatches (diagonal lines cross) on LC
//
vars
	theFrame : CMUI_GridAreaDrawingFrame;
	label : String; 
	colour : Integer;
	
	origFillColour : Integer;
	origStyle : Integer;
	origFillStyle : Integer;
begin
	theFrame := _frame;

	origFillColour := theFrame.drawFillColor;
	origStyle := theFrame.drawStyle;
	origFillStyle := theFrame.drawFillStyle;

	theFrame.drawFillColor := _ya.color;
	
	theFrame.drawStyle := Frame.DrawStyle_Transparent;
	theFrame.drawFillStyle := Frame.DrawFillStyle_DiagonalCross;

	theFrame.drawFilledRectangle(_theX1, _theY1, _theX2, _theY2, _ya.color);

	theFrame.drawFillColor := origFillColour;
	theFrame.drawStyle := origStyle;
	theFrame.drawFillStyle := origFillStyle;
end;</source>
        <access>protected</access>
        <Parameter name="_frame" type="CMUI_GridAreaDrawingFrame"/>
        <Parameter name="_ya" type="CM_YardAllocation"/>
        <Parameter name="_theX1" type="Real"/>
        <Parameter name="_theY1" type="Real"/>
        <Parameter name="_theX2" type="Real"/>
        <Parameter name="_theY2" type="Real"/>
    </JadeMethod>
    <JadeMethod name="drawSelfYardAllocationLine" id="68603f01-9da1-46d4-9890-400262a94bb0">
        <source>drawSelfYardAllocationLine(	_yardAlloc : CM_YardAllocation;
							_lc1, _lc2 : CM_GridController; 
							_yaTop : Integer; _depth : Integer;  _lineHeight : Integer;
							_yaHeight : Integer io );
/*

Purpose:			Draw a line to represent a Yard Allocation.

Parameters:			_lc1 and _lc2 are the first and last controllers for the Yard Allocation line being drawn.

Return Value:		_yaHeight is maintained with the height of the draw area for the lines


Date				Who		Reason
12 November 2008	consw1	SWF1030 - Initial creation

*/

constants 
	Padding = 2;
vars
	key1, key2, key3, key4 : Point;
	xPos1, xPos2, yPos, yOffset,startX : Integer;
	tmpObj : Object;
begin

	if not self.allGridObjects.findObjectInDictGetXY( _lc1, key1, key2 )
		or not self.allGridObjects.findObjectInDictGetXY( _lc2, key3, key4 ) then
		return;
	endif;

	
	

	xPos1 := key1.x.min( key2.x.min( key3.x.min( key4.x )));
	xPos2 := key1.x.max( key2.x.max( key3.x.max( key4.x )));

	// PAR 19142
	//yOffset := _depth * _lineHeight;
	yOffset := _depth * _lineHeight + Padding * _depth;
	yPos := _yaTop + yOffset;

	
	tmpObj := self.gridObjectsGetAtKeyForPut( xPos1, yPos, xPos2, yPos + _lineHeight); // PAR 18682
	if tmpObj = null then // PAR 18682
		self.myDrawingFrame.drawWidth := _lineHeight - 1;
		self.myDrawingFrame.drawLine( xPos1, yPos, xPos2, yPos, _yardAlloc.color );
		//PAR 19142
		//self.allGridObjects.putAtKey( xPos1, yPos, xPos2, yPos + _lineHeight, _yardAlloc );
		self.allGridObjects.putAtKey( xPos1, yPos, xPos2, yPos + _lineHeight, _yardAlloc );
	endif;
	

	_yaHeight := _yaHeight.max( yOffset + _lineHeight );
	
epilog

end;</source>
        <Parameter name="_yardAlloc" type="CM_YardAllocation"/>
        <Parameter name="_lc1" type="CM_GridController"/>
        <Parameter name="_lc2" type="CM_GridController"/>
        <Parameter name="_yaTop" type="Integer"/>
        <Parameter name="_depth" type="Integer"/>
        <Parameter name="_lineHeight" type="Integer"/>
        <Parameter name="_yaHeight" type="Integer" usage="io"/>
    </JadeMethod>
