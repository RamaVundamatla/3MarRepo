    <JadeMethod name="clearForNew" id="b63d545d-34f3-4f94-83da-c212305e60a9">
        <updating/>
        <source>clearForNew() updating, protected;
/*
----------   ----------  --------------------------------------------------
Created:	31 July 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
23/09/2009	cnwcs5		par20320 - multiple record types
13/10/2009	cnwcs5		par21242 - clear sheets after delete
*/
vars
	int		:Integer;
	sheet	:CMUI_Sheet;
begin
	self.cmbEDIDataType.listIndex	:= -1;	// par 21242
	self.loadEDITDataType;					// par 21242
	
	self.cmbFileDef.listObject 	:= null;
	self.txtName.text 			:= null;
	self.cmbFormatType.listIndex := 1;
	self.cmbFormatType.click(self.cmbFormatType);
	self.txtDelim.text 			:= ',';
	self.txtIgnore.text 		:= null;
	self.tblSampleData.rows 	:= null;
	self.tblSampleData.columns 	:= null;
	self.txtFileName.text 		:= null;
	self.txtLoadLines.text 		:= '3';
	self.txtSearchWords.text 	:= null;
	self.myFileLineHookCode 	:= null; 	// cnwrd1 30.10.08 #18402
	self.allSelectedErrors.clear(); 		// cnwrd1 ccms 1660 8.8.2008
	
	//cnwmc5 - 7 Dec 2015 - PAR 37241 - start
	self.cmbXlationOp.clear();
	self.chkXlations.value			:= false;
	self.chkActive.value			:= false;
	self.txtNumSearch.text			:= null;
	self.cmbDateFormat.listIndex 	:= 1;
	self.cmbDateDelimiter.listIndex	:= 1;
	self.txtControlCol.text			:= null;
	self.showSettings();
	self.blnSettingPin				:= false;
	self.blnSettingSkip				:= false;
	self.blnSettingsBookings 		:= false;
	self.blnSettingsVoyage 			:= false;	//03 Jan 2019	NDL	TFS 42303
	//cnwmc5 - 7 Dec 2015 - PAR 37241 - end
	
// par 20320 - start	
	while true do
		sheet := self.shtFieldMapping.getControl (int);
		if sheet = null then
			break;
		endif;
		
		self.clearForNew_Sheet (sheet);
		
		if int &gt; 0 then
			sheet.visible := false;
		endif;
		
		int := int + 1;
	endwhile;
// par 20320 - end
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="clearForNew_Sheet" id="660b62de-8b52-4c2e-922b-258eacef5e92">
        <source>clearForNew_Sheet(_sheet :CMUI_Sheet) protected;
// ---------------------------------------------------------------------------
// Created:     23 September 2009 by cnwcs5:1
// Purpose:     Par 20320 - multiple user record types  
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	index	:Integer;
	table	:CM_DataTable;
begin
	index := _sheet.index;
	
	self.txtControlColVal.getControl(index).text	:= null;
	self.txtNumFields.getControl(index).text		:= null;
	self.tblFieldMap.getControl(index).rows 		:= self.tblFieldMap.fixedRows;
	
	table		:= self.tblUserFieldCode.getControl(index);

	self.clearUserCodeHooks (table);
	
	table.rows 	:= table.fixedRows;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_sheet" type="CMUI_Sheet"/>
    </JadeMethod>
    <JadeMethod name="clearUserCodeHooks" id="7761963b-6efb-4ad5-ae09-a00e12e3cfe5">
        <source>clearUserCodeHooks(_table :CM_DataTable input) protected;
/*
Purpose:			
Parameters:			
Return Value:		

Date		Who		Reason
08 September 2008	cnwrd1	Initial creation
14 Mar 2011	cnwkpd1	PAR #27142 - Correct handleDeletedObject exception arming

*/

vars
	row,numRows			: Integer;
	fieldHookCode 		: CM_EDIFieldHookCode;	
	invalidObject		: Boolean;
begin
	on Exception do app.handleDeletedObject(exception, fieldHookCode, invalidObject);

	numRows := _table.rows;
	
	foreach row in _table.fixedRows + 1 to numRows do
		fieldHookCode :=  _table.accessRow(row).itemObject.CM_EDIFieldHookCode;

		if fieldHookCode &lt;&gt;  null then
			delete fieldHookCode;
		endif;
	endforeach;

	_table.rows 	:= _table.fixedRows;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_table" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="cloneMappingSheet" id="a855e814-22f9-4ccf-a613-9cdc0efe1899">
        <updating/>
        <source>cloneMappingSheet(_index :Integer):CMUI_Sheet protected, updating;
// ---------------------------------------------------------------------------
// Created:     23 September 2009 by cnwcs5:1
// Purpose:     Par 20320 - multiple user record types  
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 17/03/2010 	cnwmh5		PAR 23205 - When loading make sure that if not
//								add/update then is view mode
// ---------------------------------------------------------------------------
vars
	startTab	:Integer;
	sheet		:CMUI_Sheet;
	groupbox	:CMUI_GroupBox;
	control		:Control;
begin
	// we need to manufacture a tab index for each new control
	// each sheet will use a range of tabIndex values 100 greater than the previous cloned sheet
	startTab	:= self.shtFieldMapping.tabIndex;
	startTab	:= startTab + (100*_index);
	
	sheet 		:= self.cloneMappingSheetControl (self.shtFieldMapping, self.fldDetails, _index, startTab).CMUI_Sheet;	
	groupbox	:= self.cloneMappingSheetControl (self.grpMappings, sheet, _index, startTab).CMUI_GroupBox;	

	control := self.cloneMappingSheetControl (self.lblControlColVal, groupbox, _index, startTab);
	control := self.cloneMappingSheetControl (self.txtControlColVal, groupbox, _index, startTab);
	control := self.cloneMappingSheetControl (self.lblNoFields, groupbox, _index, startTab);
	control := self.cloneMappingSheetControl (self.txtNumFields, groupbox, _index, startTab);
	
	control := self.cloneMappingSheetControl (self.tblFieldMap, groupbox, _index, startTab);
	
	self.initTblFieldMap (control.CM_DataTable);
	
	control := self.cloneMappingSheetControl (self.cmbFieldType, sheet, _index, startTab);	// combo that gets used in table
	control.automaticCellControl := true;
	
	groupbox	:= self.cloneMappingSheetControl (self.grpHookCode, sheet, _index, startTab).CMUI_GroupBox;	

	//control := self.cloneMappingSheetControl (self.lLineCode, groupbox, _index, startTab);
	//control := self.cloneMappingSheetControl (self.btnLineHookAdd, groupbox, _index, startTab);
	//control := self.cloneMappingSheetControl (self.btnLineHookDel, groupbox, _index, startTab);
	//control := self.cloneMappingSheetControl (self.btnLineHookView, groupbox, _index, startTab);
	
	control := self.cloneMappingSheetControl (self.tblUserFieldCode, groupbox, _index, startTab);
	
	self.initTblFieldUserCode (control.CM_DataTable);
	
	// 22/03/2010 cnwmh5 #23205
	if self.mode &lt;&gt; self.MODE_ADD and self.mode &lt;&gt; self.MODE_UPDATE then
		self.setControlsForView();					// 17/03/2010 cnwmh5 #23205
	endif;
	
	return sheet;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_index" type="Integer"/>
        <ReturnType type="CMUI_Sheet"/>
    </JadeMethod>
    <JadeMethod name="cloneMappingSheetControl" id="5763e7e0-80c5-4938-bd86-f6939a95f1f6">
        <source>cloneMappingSheetControl(_control,_parent :Control; _index :Integer; _tabIndex :Integer io):Control protected;
// ---------------------------------------------------------------------------
// Created:     23 September 2009 by cnwcs5:1
// Purpose:     Par 20320 - multiple user record types  
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	control	:Control;
begin
	control				:= _control.loadControl (_index);
	control.tabIndex	:= _tabIndex;
	control.parent		:= _parent;
	_tabIndex			:= _tabIndex + 1;
	
	return control;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_control" type="Control"/>
        <Parameter name="_parent" type="Control"/>
        <Parameter name="_index" type="Integer"/>
        <Parameter name="_tabIndex" type="Integer" usage="io"/>
        <ReturnType type="Control"/>
    </JadeMethod>
