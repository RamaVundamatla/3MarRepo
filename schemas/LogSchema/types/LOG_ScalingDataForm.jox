    <JadeMethod name="doEdit" id="4ef5694c-fcfb-4006-ab12-2eaecdc68259">
        <updating/>
        <source>doEdit()updating, protected;
//--------------------------------------------------------------
//Created: 18 April 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	scalerCode,
	operCode 	: String;
	now 		: TimeStamp;
	result		: Integer;
begin

	app.mousePointer := MousePointer_HourGlass;

	operCode := self.tblHeader.getValueByName(ETRow_Supplier).String;
	scalerCode := self.tblHeader.getValueByName(ETRow_ScalerCode).String;

	self.myCurrentTicket.setProxy(tblHeader.getValueByName(ETRow_DocketNumber).String,
							      operCode, scalerCode, self.myCurrentTicket.inputDateTime, self.myTerminal);

	while true do
		app.myTrxUA.trxUpdateLogScalingHdr(self.myCurrentTicket, app.myPassport);
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			self.setMyCurrentTicket(null);	
			break;
		else
			result := app.showErrorWarningDialog('Scaling Data', app.myPassport, ErrWarnMode_Update + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;

			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
		endif;
		break;
	endwhile;

epilog
	app.mousePointer := MousePointer_Default;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doSave" id="4da428c5-8b4e-4115-b266-9fbcac962d65">
        <updating/>
        <source>doSave() : Boolean updating;
//--------------------------------------------------------------
//Created: 12 April 2002 By: cnwgd1
//
// Changed On	Changed By	Reason
// ----------	----------	------------------------------------
// 27/06/2022	navdap1		TFS 53362 EUP Master Data Interface Customers Between TOS and ERP
//--------------------------------------------------------------
vars
	logScaleHdrPxy,
	hdr 			: CM_LogScalingHdr;
	logScaleExtraPxy: CM_LogScalingExtra;
	logDetailPxy,
	dtl				: CM_LogScalingDtl;
	now 			: TimeStamp;
	log				: CM_LogScalingDtl;
	operator 		: CM_Operator;
	scalerCode,
	operCode 		: String;
	result			: Integer;
begin

	app.mousePointer := MousePointer_HourGlass;

	on CM_Exception do addExceptionHandler(exception, app.myPassport);
	app.setContinueCMExceptions(true);
	app.myPassport.clearErrorsWarnings();		//there may be some from the Add
	
	self.validate();	
	
	if app.myPassport.hasErrors then
		app.showErrorWarningDialog('Scaling Data', app.myPassport, ErrWarnMode_Add);
		self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
		return false;
	endif;
	on CM_Exception do null;	// disarm the validation ex handler

	if self.mode = UPDATE_MODE then
		self.doEdit();
		inheritMethod();
		return true;
	endif;

	if app.myRoot.getConfig(ComboByNameOperator).Boolean then	// TFS 53362
		operator := self.cmbSupplier.listObject.CM_Operator;	// TFS 53362
	else														// TFS 53362
		operCode := self.tblHeader.getValueByName(ETRow_Supplier).String;
		operator := app.myRoot.allOperators[operCode];	
	endif;														// TFS 53362
	
	create logScaleHdrPxy transient;
	logScaleHdrPxy.setProxy(tblHeader.getValueByName(ETRow_DocketNumber).String,
							operator.code, null, now, self.myTerminal);

	create logScaleExtraPxy transient;	// creating logScaleExtraPxy. PAR 27133, ccms 1118 03.03.2011  Purged in epilog when deleting parent object
	logScaleExtraPxy.setProxy(logScaleHdrPxy, self.cmbScaler.text, logScaleHdrPxy.inputDateTime, logScaleHdrPxy.inputDateTime);	// PAR 27133, ccms 1118 03.03.2011
							
	foreach log in self.allScalingDtls do
		create logDetailPxy transient; //Purged in epilog when deleting parent object
		logDetailPxy.setProxy(log.logID, log.conditionCode, log.minSED, log.maxSED, logScaleHdrPxy, log.scalerCode);
	endforeach;
	
	while true do
		app.myTrxCA.trxCreateLogScalingData(logScaleHdrPxy, app.myPassport);
		if app.myPassport.trxCompletedOK then
			break;
		else
			result := app.showErrorWarningDialog('Log Scaling Data', app.myPassport, ErrWarnMode_Add + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
		endif;
		return false;
	endwhile;

	// The update was successful

	self.setMyCurrentTicket(null);	
	self.allScalingDtls.purge();

	inheritMethod();
	return true;
epilog
	//logScaleHdr is the parent of logScaleExtraPxy and logDetailPxy so these objects are purged when logScaleHdr is deleted in epilog
	delete logScaleHdrPxy;  
	app.mousePointer := MousePointer_Default;	
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doTblAllClick" id="0ab8f55c-b1b0-4273-a9b7-37f078e8f9e4">
        <updating/>
        <source>doTblAllClick(table: Table input) updating;
//--------------------------------------------------------------
//Created: 02 July 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	theObject : Object;
begin
	if table.row &lt;= table.fixedRows then
		return;
	endif;

	table.accessRow(table.row).selected := true;
	self.mySelectedScalingDtl := table.accessRow(table.row).itemObject.CM_LogScalingDtl;
	self.showSelectedScalingDtl();
	self.selectedRow := table.row;
	self.setEnableObjects();
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doTblHeaderLostFocus" id="06d2117e-d312-471f-bd71-2399f3c29263">
        <updating/>
        <source>doTblHeaderLostFocus()updating;
//--------------------------------------------------------------
//Created: 02 July 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	pieceCntChanged : Boolean;
begin
	self.totalRequired := self.tblHeader.getValueByName(ETRow_NumItems).Integer;
	if self.myCurrentTicket &lt;&gt; null then
		if self.totalRequired &lt;&gt; self.myCurrentTicket.allLogScalingDtls.size then
			pieceCntChanged := true;
		endif;
	endif;
	self.calcRemaining(pieceCntChanged);
end;</source>
    </JadeMethod>
    <JadeMethod name="initTables" id="45828bbe-0b88-49f2-831a-613b6770dcba">
        <updating/>
        <source>initTables(pCargoType:Integer; _selectedTicket : CM_LogScalingHdr io) updating;
//--------------------------------------------------------------
//Created: 11 April 2002 By: cnwgd1
//  DATE            WHO   REASON
//11 August 2022 navmv20  TFS 52740 : MTN - Docket Reconciliation Log Conditions
//--------------------------------------------------------------
vars
	entTableDef 		: EntTableDef;
	scalingDtl			: CM_LogScalingDtl;
	roundMax, roundMin 	: Integer;
	defaultConditionCode : String; //11/08/2022 navmv20 TFS 52740 
begin
	
	if global.isValidObject(_selectedTicket) then
		self.setMyCurrentTicket(_selectedTicket);
		if self.myCurrentTicket.allLogScalingDtls.size &gt; 0 then
			self.setMySelectedScalingDtl(self.myCurrentTicket.allLogScalingDtls.first);
		endif;
	endif;

	tblItem.warningMethod := 'entTableWarning';
	entTableDef := app.myController.getEntTableDef(ETDef_Attachment);
	tblItem.setEntTableDef(entTableDef, null, 'entTableDefSetupWarning');

	self.myCurrentView := entTableDef.allEntTableViews['Log'];	
	if self.myCurrentView &lt;&gt; null then
		tblItem.showHideRowsByView(self.myCurrentView, CM_EntryTable.ShowHideRows, false);
	else
		tblItem.showHideRowsByList(null, CM_EntryTable.ShowHideRows, false);
	endif;
	tblAll.columns := 5;
	tblAll.addItemAt('Number' &amp; Tab &amp; 'Min SED' &amp; Tab &amp; 'Max SED' &amp; Tab &amp; 'Condition' &amp; Tab &amp; 'Scaler Code', 1);
	tblAll.rows := 1;
	self.caption := 'Log Scaling Data';
	tblAll.selectMode := self.tblAll.SelectMode_WholeRows;
	
	self.btnAdd.default := true;

	self.myAssistant.LOG_Assistant.comboBoxLogCondition(tblItem, ETRow_LogCondition);
	//11/08/2022 navmv20 TFS 52740  - START
	defaultConditionCode:= self.myTerminal.getConfig(LogDefaultConditionCode).String;
	
	if app.myRoot.allLogConditionCodes[defaultConditionCode] &lt;&gt; null then
        self.setFieldConditionCode(defaultConditionCode);
    endif;
	//11/08/2022 navmv20 TFS 52740  - END
	
	//self.setFieldConditionCode(self.myTerminal.getConfig(LogDefaultConditionCode).String); 11/08/2022 navmv20 TFS 52740 

	if self.mySelectedScalingDtl &lt;&gt; null then		
		self.tblAll.accessRow(1).selected := true;
		self.selectedRow := 1;
		self.showSelectedScalingDtl();
	endif;
	
	self.tblHeader.setTerminologyRelevant(app.myRoot.allBOLTypes[BOLType_Log], self.myTerminal);
	entTableDef := app.myController.getEntTableDef(ETDef_DocketHeader);
	tblHeader.setEntTableDef(entTableDef, null, 'entTableDefSetupWarning');

	if self.myCurrentTicket &lt;&gt; null then
		self.mode := UPDATE_MODE;
		self.showSelectedTicket();
		self.myCurrentTicket.allLogScalingDtls.copy(self.allScalingDtls);
	else
//		self.myAssistant.comboBoxSupplier(cmbSupplier, null);
//		self.myAssistant.comboBoxUser(cmbScaler, null);	
		self.mode := ADD_MODE;
	endif;				
	
	self.setFieldSEDs(roundMin, roundMax);
	self.calcRemaining(false);
	self.setEnableObjects();	

	self.tblHeader.setFocus();
	self.tblHeader.moveFirst();
	self.tblHeader.goToRowByName(ETRow_DocketNumber);

end;</source>
        <Parameter name="pCargoType" type="Integer"/>
        <Parameter name="_selectedTicket" type="CM_LogScalingHdr" usage="io"/>
    </JadeMethod>
    <JadeMethod name="keyDown" id="b229f1fe-ad9f-4c45-b094-5307f16e2e54">
        <controlMethod name="Form::keyDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>keyDown(keyCode: Integer io; shift: Integer) updating;
//--------------------------------------------------------------
//Created: 12 June 2002 By: cnwgd1
//--------------------------------------------------------------
/*
Date		      Who		Reason
17 June 2008	cnwdz2	    Par17127 - Function key &lt;CTRL&gt;-F12 is enabled to show the "Active GUI Info" window.
*/
vars
	theActiveControl	: Control;
	
begin

	if keyCode = J_key_Tab then

		tblHeader.handleFormTab(keyCode, shift, btnCancelBase, tblItem);
		tblItem.handleFormTab(keyCode, shift, tblHeader, btnAdd);


		theActiveControl := app.activeControl;
		if theActiveControl.parent.isKindOf(CM_EntryTable) then
			theActiveControl := theActiveControl.parent.Control;
		endif;
		if theActiveControl.isKindOf(CM_EntryTable) then
			theActiveControl.CM_EntryTable.handleTableTab(shift);
		endif;
	endif;
	
	inheritMethod(keyCode, shift); //To corrent Par17127

end;</source>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="removeItem" id="0abb9f21-09ca-43ab-9d87-7a57bd889311">
        <updating/>
        <source>removeItem() updating, protected;
//--------------------------------------------------------------
//Created: 17 April 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	obj		: Object;
	tblRows,row,  int : Integer;
	cntChanged : Boolean;
begin

	row := 2;
	tblRows := self.tblAll.rows;
	
	if row &gt;  tblRows then 
		return;
	endif;
	
	while row &lt;= tblRows do
		if tblAll.accessRow(row).selected then 
			obj := tblAll.accessRow(row).itemObject;
			if obj &lt;&gt; null then
				self.allScalingDtls.remove(obj.CM_LogScalingDtl);
				delete obj;
			endif;
			tblAll.removeItem(row);
			tblRows := tblRows - 1;
		else
			row := row + 1;	
		endif;
	endwhile;

	 tblItem.clearValues;
	self.setFieldConditionCode(self.myTerminal.getConfig(LogDefaultConditionCode).String);  
	self.setFieldSEDs(int, int); 
	self.setEnableObjects();

	if self.myCurrentTicket &lt;&gt; null then
		if self.totalRequired &lt;&gt; self.myCurrentTicket.allLogScalingDtls.size then
			cntChanged := true;
		endif;
	endif;
	
	self.calcRemaining(cntChanged);
	tblItem.setFocus();
end;
/*
	if tblAll.row &gt; 1 and tblAll.row &lt;= tblAll.rows then
		obj := tblAll.accessRow(tblAll.row).itemObject;
		row:=tblAll.row;
		if obj &lt;&gt; null then
			self.allScalingDtls.remove(obj.CM_LogScalingDtl);
			delete obj;
		endif;
		tblAll.removeItem(tblAll.row);
		if tblAll.rows &lt;&gt; 1 then
	    		original := tblAll.rows + 1;
			if row = original then	        
//		        	row := 2;
				row :=  tblAll.rows; // last row
		    	endif;   
			self.setMySelectedScalingDtl(tblAll.accessRow(row).itemObject.CM_LogScalingDtl);
			tblAll.accessRow(row).selected := true;
			selectedRow := row;
			tblAll.row := row; //	Par 9743 when reached end of list would display details of first entry but if remove 
		 					//	clicked would remove last entry as table row not reset. HJG 31/03/05
			if self.mySelectedScalingDtl &lt;&gt; null then
			      	self.showSelectedScalingDtl();
	    		endif;
	  else 
	     tblItem.clearValues;
	     self.setFieldConditionCode(self.myTerminal.getConfig(LogDefaultConditionCode).String);  
	     self.setFieldSEDs(int, int); 
	  endif;  
	endif;
	self.setEnableObjects();

	if self.myCurrentTicket &lt;&gt; null then
		if self.totalRequired &lt;&gt; self.myCurrentTicket.allLogScalingDtls.size then
			cntChanged := true;
		endif;
	endif;
	
	self.calcRemaining(cntChanged);
	tblItem.setFocus();
end;
*/</source>
        <access>protected</access>
    </JadeMethod>
