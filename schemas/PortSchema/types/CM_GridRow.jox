    <JadeMethod name="testForFreeSpaceYA" id="a5462dae-5b74-442f-8661-35cd0c41c014">
        <source>testForFreeSpaceYA(_yaAgent: CM_YAAutoplanAgent input): Boolean;

// Created by cnwdvb1 on 08 May 2006

vars

	controller		: CM_GridController;
	numFree,
	count			: Integer;
	numControllers	: Real;

begin

	numFree := _yaAgent.numberOfFreeSpacesRequired;
	
	if numFree = 0 then
		return true;
	endif;
	
	numControllers := _yaAgent.numControllers;
	
	foreach controller in self.allControllersByColumn discreteLock do
	
		// 01/02/2011 cnwmh5 #26129 - Gaps aren't free space so skip if Gap Controller
		if controller.isGap() then
			continue;
		endif;
	
		// This set holds locations which should automatically pass
		// because they are the spot the ti is sitting on intially at this point.
		// Once the item moves then the space will be free.
		if _yaAgent.myCurrentCMIFYAAutoPlan.allFailedLocations.includes(controller) then
			// Add self to count as will be moving.
			count := count + 1;
		endif;
		
		// Get how many spaces not including the box to be placed.
		count := count + controller.testForFreeSpaceYA(_yaAgent);
		
		// If count is equal then jump out. We have enough free space.
		if (not (count - numControllers) &lt; numFree) then
			return true;
		endif;
		
	endforeach;
	
	_yaAgent.addLogEntry(AP_Log_YA_Default,'Row ' &amp; self.label &amp; ' would have broken the 20 foot free space requirement of ' &amp; numFree.String, false);
	
	return false;
end;</source>
        <Parameter name="_yaAgent" type="CM_YAAutoplanAgent" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
