    <JadeMethod name="doBtnCancel" id="4a989dac-a9ee-4893-9f71-52ff652eeef8">
        <updating/>
        <source>doBtnCancel() updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 29/05/2015	cnwdap1		Initial creation PAR #36231
// 10/07/2015	cnwdap1		PAR #36484 Don't change sub-terminal, but do remove container from release and booking
//
vars
	warehouse, storageMT : CM_SubTerminal;
	ti, pxyTI : CM_TrackedItem;
	result : Integer;
	booking : CM_BookingRef;							// PAR #36484
	release : CM_BulkRelease;							// PAR #36484

begin
	if not self.myMainObject = null then
		ti := self.myMainObject.CM_TrackedItem;
		
		// if container is in the warehouse terminal area, put it back in the storage MT subterminal	// PAR #36484
		//if self.myTerminal.isSubTerminalsOn then														// PAR #36484
		//	storageMT := self.myTerminal.getConfig(MySubTerminalForStorageMTY).CM_SubTerminal;			// PAR #36484
		//	warehouse := self.myTerminal.getConfig(MySubTerminalForTargetBulk).CM_SubTerminal;			// PAR #36484
			
		//	if ti.mySubTerminal = warehouse then														// PAR #36484
				pxyTI := self.myMainObject.pxyGetProxyObject().CM_TrackedItem;							// PAR #36484
				if pxyTI = null then																	// PAR #36484
					pxyTI := app.createUpdateProxy(ti).CM_TrackedItem;
				endif;																					// PAR #36484
		//		pxyTI.setMySubTerminal(storageMT.code);													// PAR #36484
				
				while true do
					//app.myTrxUA.trxUpdateTrackedItem(pxyTI, null, TI_UPDMODE_NORMAL, null, app.myPassport);	// PAR #36484
					app.myTrxUA.trxUpdateTIUnassignPack(pxyTI, app.myPassport);									// PAR #36484
					
					if app.myPassport.trxCompletedOK then
						break;
					else
						//If there were warnings, give the user a chance to see them. If there are no errors they may decide to acknowledge
						//them and update anyway.
						result := app.showErrorWarningDialog('Tracked Item Update', app.myPassport, ErrWarnMode_Add + ErrWarnMode_CanAckWarnings);
						if app.myPassport.noErrors and
						   result = IDOK then
							app.myPassport.warningsAcknowledged	:= true;
							continue;
						endif;
					endif;
					break;
				endwhile;
		//	endif;																						// PAR #36484
		//endif;																						// PAR #36484
	endif;
	
	self.doCloseForm();
				
epilog
	delete pxyTI;
end;</source>
    </JadeMethod>
    <JadeMethod name="doBtnPackOK" id="27532e7c-63ab-4a87-b34c-1ed0ccc20ab2">
        <updating/>
        <source>doBtnPackOK() updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 30/03/2015	cnwdap1		Initial creation PAR #35895 CCMS PNL 2461
// 29/05/2015	cnwdap1		PAR #36231 Assign to do tasks once container is marked as packed and full
// 10/07/2015	cnwdap1		PAR #36484 new trx to do all updates in one hit instead of 3 goes (and to get things in the right order)
// 27/11/2015	cnwdap1		PAR #37210 Avoid "Input required for the Temperature field" errors
//
vars
	pxyTI 				: CM_TrackedItem;
	bookingItem 		: CM_BookingRefItem;
	result 				: Integer;
	cargo, childCargo 	: CM_TrackedItem;
	iter 				: Iterator;
	cargoId 			: String;
	packTIs, unpackTIs 	: CM_TIArray;
	controller 			: CMIF_MoveController;
	marine 				: CM_SubTerminal;
	taskToComplete		: CM_ToDoTaskDesc;					// PAR #36231
	resourcesUsed		: CM_ResourceTypeUsageSet;			// PAR #36231
	proxyLink			: CM_ProxyLink;						// PAR #37210

begin
	cargoId := self.txt_CargoID.text.trimBlanks;
	
	// tare weight, cargo weight, seal number and commodity are required
	if self.txt_Tare.text.trimBlanks = null or self.txt_Tare.text.trimBlanks.Integer = null then
		app.msgBox(app.getErrorString(Tare_weight_required), app.getErrorString(Error), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	if self.txt_CargoWeight.text.trimBlanks = null or self.txt_CargoWeight.text.trimBlanks.Integer = null then
		app.msgBox(app.getErrorString(Cargo_weight_required), app.getErrorString(Error), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	if self.txt_SealNumber.text.trimBlanks = null then
		app.msgBox(app.getErrorString(Seal_number_required), app.getErrorString(Error), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	if self.cmb_Commodity.listIndex = -1 then
		app.msgBox(app.getErrorString(Commodity_required), app.getErrorString(Error), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	
	// set parent container details from screen
	pxyTI := self.myMainObject.pxyGetProxyObject().CM_TrackedItem;
	if pxyTI = null then
		pxyTI := app.createUpdateProxy(self.myMainObject).CM_TrackedItem;
	endif;
	self.setProxyDetails(pxyTI);							// PAR #37210
	/*pxyTI.setWeightTare(self.txt_Tare.text.Decimal);
	pxyTI.setWeightCargo(self.txt_CargoWeight.text.Decimal);
	pxyTI.setTotalWeight(pxyTI.weightCargo + pxyTI.weightTare, null, null);
	pxyTI.setSealNumShippers(self.txt_SealNumber.text);
	if self.cmb_Commodity.listIndex &gt; 0 then
		pxyTI.setCommodity(self.cmb_Commodity.listObject.CM_Commodity.code);
	endif;
	pxyTI.setRemarks(self.cmb_Remarks.text, true);
	pxyTI.setDescription(cargoId);
	
	// and set Export imex status, and voyage, discharge port and destination port from booking
	pxyTI.setImExStatus(TI_IMEX_STATUS_EXPORT);
	pxyTI.setMyVoyage(self.myBooking.myVoyage, app.myPassport);
	pxyTI.setDischargePort(self.myBooking.dischargePort);
	pxyTI.setDestinationPort(self.myBooking.destinationPort);
	
	// and mark as full container load and move to marine sub-terminal
	pxyTI.CM_Container.zSetPxyContentsStatus(TI_CONTENTS_STATUS_FCL);
	if self.myTerminal.isSubTerminalsOn then
		marine := self.myTerminal.getConfig(MySubTerminalForExportFull).CM_SubTerminal;
		pxyTI.setSubTerminal(marine);
	endif;
	
	// PAR #37210 A bit of a hack to avoid "Input required for Temperature" error				// PAR #37210
	// This is what the Pack/Unpack screen (accidentalyl) does when used the way Nelson use it	// PAR #37210
	pxyTI.setTemperature(null);	*/																// PAR #37210
	
	create packTIs transient;
	create unpackTIs transient;
	create controller transient;
	controller.setMoveMode(REAL_MODE);
	controller.isSystemMove := true;
	controller.isForcedMove := true;
	
	while true do
		//app.myTrxUA.trxUpdatePackUnpack(controller, false, packTIs, unpackTIs, false, pxyTI, app.myPassport);	// PAR #36484
		app.myTrxUA.trxPackToDoCompleteSubTerm(	controller,								// PAR #36484
												false,									// PAR #36484
												packTIs,								// PAR #36484
												unpackTIs,								// PAR #36484
												false,									// PAR #36484
												pxyTI,									// PAR #36484
												self.tasksToAdd,						// PAR #36484
												self.tasksToComplete,					// PAR #36484
												self.allProxyResourceUsages,			// PAR #36484
												app.myPassport	);						// PAR #36484
		
		if app.myPassport.trxCompletedOK then
			break;
		else
			result := app.showErrorWarningDialog(app.getString(Complete_TDTask), app.myPassport, ErrWarnMode_Add + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				// there must have just been warnings that the user has acknowledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				
				// reset the edition number on the proxy link - this has been updated in the 	// PAR #37210
				// trx above because we rebuild the proxy in a couple of places, so need to 	// PAR #37210
				// restore it																	// PAR #37210
				proxyLink := app.myProxyManager.allProxies[pxyTI];								// PAR #37210
				if proxyLink &lt;&gt; null then														// PAR #37210
					proxyLink.originalRealEdition := self.myMainObject.edition;					// PAR #37210
				endif;																			// PAR #37210
				self.setProxyDetails(pxyTI);													// PAR #37210
				continue;
			endif;
		endif;
		
		break;
	endwhile;
	
	if app.myPassport.trxCompletedOK then
		self.myCallingForm.clearContainerDetails();
		self.unloadForm();
	endif;
		
	// PAR #36484 these two extra trxs are now combined in to the one trx above
	// create a pack complete transaction
	/*if app.myPassport.trxCompletedOK then
		delete pxyTI;
		pxyTI := app.createUpdateProxy(self.myMainObject).CM_TrackedItem;
		
		while true do																// PAR #36231
			app.myTrxUA.trxUpdateTIPackComplete(pxyTI, app.myPassport);
			if app.myPassport.trxCompletedOK then									// PAR #36231
				break;																// PAR #36231
			else																	// PAR #36231
				result := app.showErrorWarningDialog(app.getString(PackComplete), app.myPassport, ErrWarnMode_Add + ErrWarnMode_CanAckWarnings);	// PAR #36231
				if app.myPassport.noErrors and										// PAR #36231
				   result = IDOK then												// PAR #36231
					// there must have just been warnings 							// PAR #36231
					app.myPassport.warningsAcknowledged	:= true;					// PAR #36231
					continue;														// PAR #36231
				endif;																// PAR #36231
			endif;																	// PAR #36231
			break;																	// PAR #36231
		endwhile;																	// PAR #36231
		
		
		// And add and complete any to do tasks that have been attached					// PAR #36231
		if app.myPassport.trxCompletedOK then											// PAR #36231
			delete pxyTI;																// PAR #36231
			pxyTI := app.createUpdateProxy(self.myMainObject).CM_TrackedItem;			// PAR #36231
			while true do 																// PAR #36231
																						// PAR #36231
				app.myTrxUA.trxUpdateToDoTasksWarehouse(	self.tasksToAdd,			// PAR #36231
															self.tasksToComplete, 		// PAR #36231
															pxyTI, 						// PAR #36231
															self.allProxyResourceUsages,// PAR #36231
															app.myPassport	);			// PAR #36231
																						// PAR #36231
				if app.myPassport.trxCompletedOK then									// PAR #36231
					break;																// PAR #36231
				else																	// PAR #36231
					result := app.showErrorWarningDialog(app.getString(Complete_TDTask), app.myPassport, ErrWarnMode_Add + ErrWarnMode_CanAckWarnings);	// PAR #36231
					if app.myPassport.noErrors and										// PAR #36231
					   result = IDOK then												// PAR #36231
						// there must have just been warnings 							// PAR #36231
						app.myPassport.warningsAcknowledged	:= true;					// PAR #36231
						continue;														// PAR #36231
					endif;																// PAR #36231
				endif;																	// PAR #36231
				break;																	// PAR #36231
			endwhile;																	// PAR #36231
		endif;																			// PAR #36231
		
		if app.myPassport.trxCompletedOK then
			self.myCallingForm.clearContainerDetails();
			self.unloadForm();
		endif;
	endif;	*/
	
epilog
	delete pxyTI;
	delete packTIs;
	delete unpackTIs;
	delete controller;
end;</source>
    </JadeMethod>
    <JadeMethod name="doBtnTasksClick" id="e3990701-552e-4d24-b40f-0a5a76a5cf67">
        <updating/>
        <source>doBtnTasksClick() updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 26/03/2015	cnwdap1		Initial creation PAR #35895 CCMS PNL 2461
// 02/06/2015	cnwdap1		PAR #36231 Correct errors in form handling
//
vars
	form	: MOB_RecordTasksForm;
	pxyTI	: CM_TrackedItem;

begin
	pxyTI := self.myMainObject.pxyGetProxyObject().CM_TrackedItem;
	if pxyTI = null then
		pxyTI := app.createUpdateProxy(self.myMainObject).CM_TrackedItem;
	endif;
	form := app.myMobileGUIAgent.findOrShowForm(MOB_RecordTasksForm, pxyTI, true).MOB_RecordTasksForm;
	form.myCallingForm := self;												// PAR #36231
	self.allProxyResourceUsages.copy(form.allProxyResourceTypeUsages);		// PAR #36231
	self.tasksToAdd.copy(form.tasksToAdd);									// PAR #36231
	self.tasksToComplete.copy(form.tasksToComplete);						// PAR #36231
	form.showModal;
	
	if form.modalResult = IDCANCEL then
		delete pxyTI;
		return;
	endif;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setProxyDetails" id="7379bc55-0f50-4d78-806f-6e28510eb7da">
        <source>setProxyDetails(_pxyTI : CM_TrackedItem input) protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 30/11/2015	cnwdap1		Initial creation PAR #37210 Refactor to new method
// 03/04/2020	jlgdap1		TFS 48952 PNL - Terminal Queuing Used Quaypack Bespoke App
//
vars
	cargoId : String;
	marine : CM_SubTerminal;
	taskId : Integer;					// TFS 48952
	toDoTaskDesc : CM_ToDoTaskDesc;		// TFS 48952
	toDoTask : CM_ToDoTask;				// TFS 48952
	existingToDoTask : CM_ToDoTask;		// TFS 48952
	found : Boolean;					// TFS 48952

begin
	cargoId := self.txt_CargoID.text.trimBlanks;
	
	_pxyTI.setWeightTare(self.txt_Tare.text.Decimal);
	_pxyTI.setWeightCargo(self.txt_CargoWeight.text.Decimal);
	_pxyTI.setTotalWeight(_pxyTI.weightCargo + _pxyTI.weightTare, null, null);
	_pxyTI.setSealNumShippers(self.txt_SealNumber.text);
	if self.cmb_Commodity.listIndex &gt; 0 then
		_pxyTI.setCommodity(self.cmb_Commodity.listObject.CM_Commodity.code);
	endif;
	_pxyTI.setRemarks(self.cmb_Remarks.text, true);
	_pxyTI.setDescription(cargoId);
	
	// and set Export imex status, and voyage, discharge port and destination port from booking
	_pxyTI.setImExStatus(TI_IMEX_STATUS_EXPORT);
	_pxyTI.setMyVoyage(self.myBooking.myVoyage, app.myPassport);
	_pxyTI.setDischargePort(self.myBooking.dischargePort);
	_pxyTI.setDestinationPort(self.myBooking.destinationPort);
	
	// and mark as full container load and move to marine sub-terminal
	_pxyTI.CM_Container.zSetPxyContentsStatus(TI_CONTENTS_STATUS_FCL);
	if self.myTerminal.isSubTerminalsOn then
		marine := self.myTerminal.getConfig(MySubTerminalForExportFull).CM_SubTerminal;
		_pxyTI.setSubTerminal(marine,null);
	endif;
	
	// PAR #37210 A bit of a hack to avoid "Input required for Temperature" error				// PAR #37210
	// This is what the Pack/Unpack screen (accidentally) does when used the way Nelson use it	// PAR #37210
	if _pxyTI.getCommodityObject.hasTemp then													// PAR #37210
		_pxyTI.setTemperature(null);															// PAR #37210
	else																						// PAR #37210
		_pxyTI.setTemperature(NULL_TEMPERATURE);												// PAR #37210
	endif;																						// PAR #37210
	
	// TFS 48952 rebuild to do tasks on proxy if they're not there
	foreach taskId in self.tasksToAdd do
		found := false;
		toDoTaskDesc := app.myRoot.allToDoTaskDescriptions[taskId];
		foreach existingToDoTask in _pxyTI.allToDoTasksToDo do
			if existingToDoTask.toDoTaskDesc = toDoTaskDesc then
				found := true;
				break;
			endif;
		endforeach;
		if found then
			continue;
		endif;
		
		create toDoTask as CM_TiToDoTask transient;
		toDoTask.setForCreateToDoTask(STATUS_TODO, toDoTaskDesc, null, app.getMyUserCode);
		toDoTask.CM_TiToDoTask.setMyTrackedItem(_pxyTI);
	endforeach;
	// TFS 48952 end
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_pxyTI" type="CM_TrackedItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="406425e6-2be0-458e-8673-2f22ad3585c5">
        <updating/>
        <source>setupForm() updating, protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 25/03/2015	cnwdap1		Initial creation PAR #35895 CCMS PNL 2461 New Packing Screens
//
vars
	commodity 	: CM_Commodity;
	idx			: Integer;
	remark		: CM_PredefinedRemark;

begin
	inheritMethod();
	
	// load commodities
	foreach commodity in app.myRoot.allCommodities discreteLock do
		if commodity.isNotAvailableForEntry or not commodity.isUsedForPacking then
			continue;
		endif;
		idx := self.cmb_Commodity.addItem(commodity.code &amp; Tab &amp; commodity.description);
		self.cmb_Commodity.itemObject[idx] := commodity;
	endforeach;
	self.lbl_Container.caption := self.myMainObject.CM_TrackedItem.id;
	//self.lbl_Booking.caption := self.myBooking.bookingReference;
	
	// load remarks
	self.cmb_Remarks.listCollection(app.myRoot.allPreDefinedRemarks, true, 0);
	
	self.txt_Tare.setFocus;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="translateForm" id="c9fb1655-6bff-4987-b190-a806e2f03dd9">
        <updating/>
        <source>translateForm(locale : CM_Locale) updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 25 March 2015.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	
begin
	// Determine the locale for translations.
	inheritMethod(locale);
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0020364, locale);
	btn_Cancel.translateCaption(Xlat_0020365, locale);
	btn_PackOK.translateCaption(Xlat_0020366, locale);
	btn_Tasks.translateCaption(Xlat_0020367, locale);
	lbl_Booking.translateCaption(Xlat_0020368, locale);
	lbl_CargoID.translateCaption(Xlat_0020369, locale);
	lbl_CargoWeight.translateCaption(Xlat_0020370, locale);
	lbl_Commodity.translateCaption(Xlat_0020371, locale);
	lbl_Container.translateCaption(Xlat_0020372, locale);
	lbl_Remarks.translateCaption(Xlat_0020373, locale);
	lbl_SealNumber.translateCaption(Xlat_0020374, locale);
	lbl_Tare.translateCaption(Xlat_0020375, locale);
end;</source>
        <Parameter name="locale" type="CM_Locale"/>
    </JadeMethod>
    <JadeMethod name="txt_CargoWeight_lostFocus" id="77a9cdc7-b54c-4fa0-99cc-cbbe976e73eb">
        <controlMethod name="TextBox::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txt_CargoWeight_lostFocus(textbox: TextBox input) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 26/03/2015	cnwdap1		Initial creation PAR #35895 CCMS PNL 2461
//
vars

begin
	self.lbl_TotalWeight.caption := (self.txt_CargoWeight.text.Integer + self.txt_Tare.text.Integer).String;
epilog

end;</source>
