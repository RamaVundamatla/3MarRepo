    <JadeMethod name="mnuSelCurrFailures_click" id="5ab5190c-bed3-4572-b36d-69d3c67f2fbb">
        <controlMethod name="MenuItem::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mnuSelCurrFailures_click(menuItem: MenuItem input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 March 2025	NAVRV30	JIRA 33943 MTN | Unit Test Runner Select Failed Tests

*/
vars
	root 				: UM_Root;
	classMethod			: UM_UnitTestClassMethod;
	classSelected 		: Object;
	index 				: Integer;
	meth 				: Method;
	testResult			: UM_UnitTestResult;
	methods 			: MethodNDict;
	
begin
	classSelected := self.lbxTests.listObject;	
	root := self.myRoot ;	
	if root = null then // if there is no first instance of root then leave.
		return ; 
	endif ; 
	
	create methods transient;
	classSelected.Class.getMethods(methods);
	foreach meth in methods do
		classMethod := root.allRunnableUTClassesMethods.getAtKeyGeq(classSelected.getName(), meth.name);
		testResult := classMethod.allUnitTestResults.first;
		if testResult &lt;&gt; null and testResult.hasFailed then			
			index := lbxTests.findObject(meth);
			if index &gt; 0 then
				lbxTests.itemSelected[index] := true;
			endif;
		endif;					
	endforeach;	
	
	self.recalcCurrentRunTotals();
	self.showTotals();
			
epilog
	delete methods;
end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="populateCategories" id="3fbf0335-6de4-4bef-aebe-d2799ace1d80">
        <source>populateCategories();

/*

Purpose:		Get all Categories	

Parameters:			

Return Value:		


Date			Who		Reason
23 August 2011	cnwmh5	Initial creation

*/

vars

	category				: UM_Category;

begin

	self.cmbCategories.clear();
	self.cmbCategories.enabled := false;
	self.btnSelectCat.enabled := false;
	self.btnSaveCateg.enabled := true;
	
	foreach category in app.allCategories do
		self.cmbCategories.addItem(category.name);	
	endforeach;

	self.cmbCategories.enabled := self.cmbCategories.listCount &gt; 0 or self.cmbCategories.text &lt;&gt; null;
	
	// set dummy category
	//create category transient;					// 13/09/2012 cnwmc5
	self.cmbCategories.addItemAt("", 1);	
	
epilog

end;
</source>
    </JadeMethod>
    <JadeMethod name="populateClassSearch" id="8523f135-426a-4c05-83aa-1e06f5fcf3aa">
        <source>populateClassSearch();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 February 2011	cnwndl1	Initial creation

*/

vars

	root : UM_Root;
	classArray : StringArray;
	classStr : String;
	
begin

	self.cmbClass.clear();
	self.cmbMethod.clear();
	
	self.cmbMethod.enabled := false;
	self.btnSelect.enabled := false;
	
	root := UM_Root.firstInstance;
	if root = null then
		return;
	endif;
	
	create classArray transient;
	root.getAllClassesForSearch( classArray );
	
	foreach classStr in classArray do
		self.cmbClass.addItem(classStr);
	endforeach;
	
	self.cmbMethod.enabled := self.cmbClass.listCount &gt; 0;
	
epilog

	delete classArray;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="populateMethodSearch" id="caee4fe7-b01b-4c1a-b794-4e93766be5db">
        <source>populateMethodSearch();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 February 2011	cnwndl1	Initial creation

*/

vars

	root : UM_Root;
	classStr : String;
	methodArray : StringArray;
	methodStr : String;
	
begin

	
	self.cmbMethod.clear();
	self.cmbMethod.enabled := false;
	self.btnSelect.enabled := false;
	
	root := UM_Root.firstInstance;
	if root = null then
		return;
	endif;
	
	classStr := cmbClass.text;
	if classStr = null then
		return;
	endif;
	
	create methodArray transient;
	root.getAllMethodsForClassSearch( methodArray, classStr );

	foreach methodStr in methodArray do
		self.cmbMethod.addItem(methodStr);
	endforeach;
	
	self.cmbMethod.enabled := cmbMethod.listCount &gt; 0;
	
epilog

	delete methodArray;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="populateProfiles" id="c9ae14a7-fa30-4f35-b640-ea0fcf9ff6be">
        <source>populateProfiles();
//04 April 2009	cnwdw1	
//
vars
	schema: Schema;
	profileClass: Class;
	classes: ClassColl;
	klass: Class;
	saveIndex,
	index: Integer;
	userName,
	displayName : String;
	
	
begin
	self.cmbProfiles.clear;
	create classes transient;
	schema := rootSchema.getSchema("JMTUnitTest");
	profileClass := schema.getClass(UT_Profile.name);
	if profileClass &lt;&gt; null then
		profileClass.allSubclasses(classes);
		
		userName := app.userName.toUpper();
		
		foreach klass in classes do
			displayName := klass.name[11:end];
			index := self.cmbProfiles.addItem(displayName);
			self.cmbProfiles.itemObject[index] := klass;
			
			if displayName.toUpper = userName then
				saveIndex := index;
			else
				if saveIndex = 0 and klass.name = UT_ProfileUnitTest.name then
					saveIndex := index;
				endif;
			endif;
		endforeach;

		if saveIndex &lt;&gt; 0 then
			self.cmbProfiles.listIndex := saveIndex;
		endif;		
	endif;
	
epilog
	delete classes;
end;</source>
    </JadeMethod>
    <JadeMethod name="recalcCurrentRunTotals" id="6027f0e2-d9a2-4674-b5f2-2e0dc4f17a14">
        <updating/>
        <source>recalcCurrentRunTotals() updating;
//19 December 2008	cnwdw1	
//
vars
	index: Integer;
	obj: Object;
	meth: Method;
	levelToCheck	: Integer;
	
	category : UM_Category;
	firstIndex : Integer;
	
	classMethod				: UM_UnitTestClassMethod;
begin
	
	self.currentSelectedCount := 0;
	self.currentRunCount := 0;
	self.currentPassedCount := 0;
	self.currentFailedCount := 0;
	self.estimatedRunTime := null;

	foreach index in 1 to lbxTests.listCount do
		//cnwmc5
		if self.chkExCategory.value = true then
			if self.cmbCategories.text &lt;&gt; null then
				category := app.allCategories[self.cmbCategories.text];
				foreach obj in category.allCategoryClassMethods do
					self.doUnselectClassMethod(obj);
					if firstIndex = -1 then
						firstIndex := self.lbxTests.newIndex;
					endif;
				endforeach;
			endif;
		endif;
		obj := lbxTests.itemObject[index];
		
		if lbxTests.itemSelected[index] = true then
			// if method then update the selected count
			if obj.isKindOf(Method) then
				meth := obj.Method;
				//if self.isUtilityTest(meth) then
					//continue;
				//endif;
				//if self.isUnitTest(meth) then
					if lbxTests.itemSelected[index] = true then
						//cnwmc5
						if self.chkExCategory.value = true and category &lt;&gt; null then
							if category.allCategoryClassMethods.includes(obj) then
								index := index + 1;
								continue;
							endif;
						endif;
						
						self.currentSelectedCount := self.currentSelectedCount + 1;
						// 11/12/2015 cnwmh5 
						if meth.isRunnableUnitTestMethod() then
							classMethod := self.myRoot.allRunnableUTClassesMethods[meth.getSchemaType().name, meth.name];
							if classMethod &lt;&gt; null and not classMethod.allUnitTestResults.isEmpty() then
								self.estimatedRunTime := self.estimatedRunTime + 
									classMethod.allUnitTestResults.first.UM_UnitTestResult.elapsedTime.Real;
							endif;
						endif;
					endif;
				//endif;	
				continue;
			endif;
			
			levelToCheck := lbxTests.itemLevel[index];
			index := index + 1;
			while lbxTests.itemLevel[index] &gt; levelToCheck do
				obj := lbxTests.itemObject[index];
				if obj.isKindOf(Method) then
					meth := obj.Method;
					if self.isUnitTest(meth) then
						//cnwmc5
						if self.chkExCategory.value = true and category &lt;&gt; null then
							if category.allCategoryClassMethods.includes(obj) then
								index := index + 1;
								continue;
							endif;
						endif;
						
						self.currentSelectedCount := self.currentSelectedCount + 1;
						// 11/12/2015 cnwmh5 
						if meth.isRunnableUnitTestMethod() then
							classMethod := self.myRoot.allRunnableUTClassesMethods[meth.getSchemaType().name, meth.name];
							if classMethod &lt;&gt; null and not classMethod.allUnitTestResults.isEmpty() then
								self.estimatedRunTime := self.estimatedRunTime + 
									classMethod.allUnitTestResults.first.UM_UnitTestResult.elapsedTime.Real;
							endif;
						endif;
					endif;	
				endif;
				if index = lbxTests.listCount then
					break;
				endif;
				index := index + 1;
			endwhile;
			index := index - 1;
						
		endif;
		
	endforeach;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="recalcTotals" id="16a24407-ff7d-442d-8996-ee72ab1d8d6b">
        <updating/>
        <source>recalcTotals() updating;
//19 December 2008	cnwdw1	
//
vars
	index: Integer;
	obj: Object;
	meth: Method;
begin
	self.testCount := 0;
	self.passedCount := 0;
	self.failedCount := 0;
	self.notRunCount := 0;
	self.ignoredCount := 0;
	foreach index in 1 to lbxTests.listCount do
		obj := lbxTests.itemObject[index];
		if obj.isKindOf(Class) then
			continue;
		endif;
		if obj.isKindOf(Method) then
			meth := obj.Method;
			if self.isUtilityTest(meth) then
				continue;
			endif;
			self.testCount := self.testCount + 1;
			if self.isIgnoreTest(meth) then
				self.ignoredCount := self.ignoredCount + 1;
			elseif self.isUnitTest(meth) then
				if lbxTests.itemPicture[index] = self.picSuccess.picture then
					self.passedCount := self.passedCount + 1;
				elseif lbxTests.itemPicture[index] = self.picFailed.picture then
					self.failedCount := self.failedCount + 1;
				else
					self.notRunCount := self.notRunCount + 1;
				endif;
			endif;	
		endif;
	endforeach;
end;</source>
    </JadeMethod>
    <JadeMethod name="registerNotes" id="43b61afc-1d51-44cd-936c-789c0f1aca82">
