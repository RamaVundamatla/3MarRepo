    <JadeMethod name="setMyTransaction" id="f1e59d5b-f48a-41c7-858c-b5d2b2e27520">
        <updating/>
        <source>setMyTransaction(_tiTransaction : CM_TITransaction) updating;
// ---------------------------------------------------------------------------
// Created:     23 September 2002 by cnwth2
//
// Purpose:     
//
// Changed On	By			Reason
// ----------   ----------  --------------------------------------------------
// 30/08/2017	cnwdap1		TFS 6879 Issues with resyncing invoice lines after setting up cargo allocation amp
// 08/06/2020   cnwma1      ChangeRequest 49400: ASPA - Invoice Enhancements for Barges
// 13/01/2023	navvt20		TFS CR 55625 Task 55658: Jade - Contract Id TRX
vars

begin
	if self.myTransactionTI &lt;&gt; _tiTransaction then
		self.myTransactionTI := _tiTransaction;
		
		//if _tiTransaction.myTrackedItem &lt;&gt; null 								// TFS 6879  //03/06/2020 cnwma1 Tfs #49400
		//and _tiTransaction.myTrackedItem.myCargoType &lt;&gt; null 					// TFS 6879  //03/06/2020 cnwma1 Tfs #49400
		//and _tiTransaction.myTrackedItem.myCargoType.isAllowDuplicates then	// TFS 6879  //03/06/2020 cnwma1 Tfs #49400
			self.trackedItemLength := _tiTransaction.totalLength;				// TFS 6879
			self.trackedItemQuantity := _tiTransaction.totalQuantity;			// TFS 6879
			self.trackedItemVolume := _tiTransaction.totalVolume;				// TFS 6879
			self.trackedItemWeight := _tiTransaction.totalWeight;				// TFS 6879
			//self.setContractId(_tiTransaction.contractId);				// 13/01/2023 navvt20 TFS 55658 // ### TFS CR 55648 TASK 56818 15MAR2023 NAVAB1			//navra1 - 13th March 2024 - BUG 62681
		//endif;																// TFS 6879  //03/06/2020 cnwma1 Tfs #49400
	endif;
	
end;</source>
        <Parameter name="_tiTransaction" type="CM_TITransaction"/>
    </JadeMethod>
