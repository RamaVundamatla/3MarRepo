    <JadeMethod name="loadDiskOldIcons" id="3b8af4ed-9a64-470f-9586-8ef9ea5dea2e">
        <source>loadDiskOldIcons();
/*
Purpose:			

Date		Who		Reason
05 August 2021	navab1	TFS 50669
*/

vars
	folder : FileFolder;
	file : File;
	localfiles : FileNodeArray;
	bin : Binary;
begin

	create folder;
//	create files;
	folder.fileName := "F:\TeamStuff\AndrewBishop\JMT\Jade2020NewSkin\NewIcons\VoyageEnqIcons48x48";
	folder.mask := "*.png";

	localfiles := folder.files();
	
	foreach file in localfiles as File do
//		write file.name;
	//	write file.fileName;
		
	//	file.inspectModal;
	file.kind := File.Kind_Binary;
    file.openInput(file.fileName);
    bin := file.readBinary(file.fileLength);
    write bin;

		
		break;
	endforeach;
	
	
	
	
epilog

//	delete localfiles;
//	delete folder;

end;</source>
    </JadeMethod>
