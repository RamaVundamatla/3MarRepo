vars

begin
	return 10;

epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getSortType" id="21b8649a-76b3-480d-8157-f0d625248299">
        <source>getSortType(): Integer;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
