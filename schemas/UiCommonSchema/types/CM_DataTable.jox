    <JadeMethod name="applyColumnFilter" id="5a939df3-ca62-431b-9dac-73aabb9001d1">
        <updating/>
        <source>applyColumnFilter( _filters : CM_ColumnFilterDict ):Integer updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21 December 2011	cnwndl1	Initial creation	Par 28889

*/

vars

	startRow : Integer;
	endRow : Integer;
	rowIndex : Integer;
	myFilters : CM_ColumnFilterDict;
	colFilter : CM_ColumnFilter;
	row : JadeTableRow;
	col : Integer;
	count : Integer;

begin

	create myFilters transient;

	if _filters &lt;&gt; null then
		// just get the filters that are for me. (could be some for other tables on the form)
		_filters.cloneFiltersForTable( self, myFilters );
	endif;
	
	foreach col in 1 to self.columns do
		self.accessCell(1,col).fontBold := false;
	endforeach;
	
	startRow := self.fixedRows + 1;
	endRow := self.rows;
	
	//if endRow &lt;= startRow then
	if endRow &lt; startRow then				// was ignoring filters on a single line in the table
		return count;
	endif;

	if myFilters.isEmpty then
		foreach rowIndex in startRow to endRow do
			self.accessRow(rowIndex).visible := true;
			count := count + 1;
		endforeach;
	else
		foreach colFilter in myFilters do
			col := colFilter.columnIndex;
			self.accessCell(1,col).fontBold := true;
		endforeach;
		foreach rowIndex in startRow to endRow do
			row := self.accessRow(rowIndex);
			count := count + myFilters.applyFiltersToRow( self, rowIndex, row ).Integer;
		endforeach;
	endif;

	return count;

epilog

	delete myFilters;

end;</source>
        <Parameter name="_filters" type="CM_ColumnFilterDict"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="areAllSelected" id="73ba6e04-235d-45b6-a211-d218d9e6b1a1">
        <updating/>
        <source>areAllSelected() : Boolean updating;
// ---------------------------------------------------------------------------
// Created:		February 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	stRow,numRows,
	rowIdx		: Integer;
	jRow		: JadeTableRow;
begin
	numRows := self.rows;
	stRow := self.fixedRows + 1;

	foreach rowIdx in stRow to numRows do
		jRow := self.accessRow(rowIdx);
		if not jRow.selected then
			return false;
		endif;
	endforeach;
	return true;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="clearAllData" id="596ff72f-0a1d-46f1-be99-76054f0c945b">
        <updating/>
        <source>clearAllData() updating;
// ---------------------------------------------------------------------------
// Created:     10 October 2003 by cnwrs2
//
// Purpose:     
// 13 Mar 2025	navnk30	JIRA 34245: Develop a generic solution to show data in a CM_DataTable using "Pagination"
// ---------------------------------------------------------------------------
vars

begin

		//13.03.2025 navnk30 JIRA 34245
	if self.isPaginated() then			//13.03.2025 navnk30 JIRA 34245
		if self.getCollection() &lt;&gt; null then
			self.getCollection().clear();
		endif;
		
		self.doPaginatedNoteClear(); //23/06/2025	navkc1 JIRA MTN 34973 - Clear notification
		
		//jlier1 9/6/25 JIRA 34771
		//self.displayRowsPaginated(self.getCollection(), self.form.CM_BaseForm);
		self.refreshEntries(null);
	else
		self.rows := self.fixedRows;	
	endif;
	
	self.clearAllSelected();
end;</source>
    </JadeMethod>
    <JadeMethod name="clearAllSelected" id="9e150f18-b990-4e3d-a1af-80bcbcf7779e">
        <source>clearAllSelected();
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
15 March 2010	cnwer1	Initial creation

*/

vars
	dtInterface : IF_CM_DataTable;
begin
	dtInterface:= self.getIF_CM_DataTable;
	if dtInterface &lt;&gt; null then
		dtInterface.clearAllSelected(self);
	endif;

	inheritMethod();

epilog

end;</source>
