    <JadeMethod name="pxyCreateUpdateProxy" id="f9ced138-69d8-4b19-97a0-cd127d20ebc1">
        <source>pxyCreateUpdateProxy(): SelfType;
// ---------------------------------------------------------------------------
// Created:     06 June 2002 by cnwsb1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy
// ---------------------------------------------------------------------------
vars
	proxy 	: CM_Product;
	completedOK		: Boolean;
	
begin
	proxy := inheritMethod();
	
	proxy.myCargoType 				:=	self.myCargoType;
	proxy.myOperator 				:=	self.myOperator;
	proxy.myProductGroup			:=	self.myProductGroup;
	proxy.myHandlingType 			:=	self.myHandlingType;
	proxy.myHandlingSubType 			:=	self.myHandlingSubType;	//31 Mar 2017	NDL	TFS 3414
	proxy.storageCharge 			:=	self.storageCharge;
	proxy.myCargoTypeExtBreakBulkGen:=	self.myCargoTypeExtBreakBulkGen;

	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return proxy;
	
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete proxy;
	endif;	
	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="selectValueQVW" id="a46e21be-5a25-4fce-8aca-1bc8b26f6947">
        <source>selectValueQVW(_quantity:Integer; _volume:Decimal; _weight:Decimal; _returnD:Decimal output; _returnI:Integer output):Boolean;
// --------------------------------------------------------------------------------
// Created:		07 December 2006 by cnwdad1
//
// Purpose:		Determines whether the receiver uses a quantity value, a volume value,
//				or a weight value, and returns the result accordingly.
//
// Parameters:	_quantity - The quantity for the receiver.
//				_volume - The volume for the receiver.
//				_weight - The weight for the receiver.
//				_returnD - Returns a decimal value (i.e. for volume).
//				_returnI - Returns an integer value (i.e. quantity or weight).
//
// Returns:		True if a value was able to be returned, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.isAttributeValidForCargoType(ETRow_MyQuantity) then
		_returnI	:=	_quantity;
		return true;
		
	elseif self.isAttributeValidForCargoType(ETRow_MyVolume) then
		_returnD	:=	_volume;
		return true;
		
	elseif self.isAttributeValidForCargoType(ETRow_MyWeight) then
		_returnI	:=	_weight.Integer;
		return true;
		
	endif;
	
	return false;
end;</source>
        <Parameter name="_quantity" type="Integer"/>
        <Parameter name="_volume" type="Decimal"/>
        <Parameter name="_weight" type="Decimal"/>
        <Parameter name="_returnD" type="Decimal" usage="output"/>
        <Parameter name="_returnI" type="Integer" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
