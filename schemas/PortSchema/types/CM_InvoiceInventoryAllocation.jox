epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getInventoryTypes" id="a24b4056-cc28-41c6-b903-4af8d9360a52">
        <source>getInventoryTypes(_types : IntegerArray input);
/*
Purpose:			

Date		Who		Reason
25MAY2021	NAVAB1	TFS 51219
*/

vars
	criteria		: CM_YACriteria;
	yaObjects		: CM_YADataObjects;
	transactionType	: CM_EventType;
	iter			: Iterator;
	
begin
	criteria := self.getCriteriaOfTypeValue(YACriteriaType_InventoryType);
	if criteria = null then
		return;
	endif;
	
	if criteria.myYAData &lt;&gt; null and criteria.myYAData.isKindOf(CM_YADataObjects) then
		yaObjects := criteria.myYAData.CM_YADataObjects;
		iter := yaObjects.allObjects.createIterator();
		while iter.next(transactionType) do
			_types.add(transactionType.type);
		endwhile;
	endif;		
	
epilog
	delete iter;
	
end;</source>
        <Parameter name="_types" type="IntegerArray" usage="input"/>
    </JadeMethod>
