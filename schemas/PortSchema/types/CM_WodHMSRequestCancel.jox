    <JadeMethod name="validateForUpdate" id="703c84d4-1184-48ed-948d-159820c51511">
        <source>validateForUpdate();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 May 2018	jlgndl1	Initial creation	TFS 38560

*/

vars

begin

	inheritMethod();
	
	if self.myWorkOrderToCancel = null then
		app.raiseCMException(Must_select_work_order_cancel, null, null);
		return;
	endif;

	if not self.myWorkOrderToCancel.canCancel then
		app.raiseCMException(Cancel_workorder_complete_task, null, null);
	endif;
	

epilog

end;</source>
    </JadeMethod>
</Class>
