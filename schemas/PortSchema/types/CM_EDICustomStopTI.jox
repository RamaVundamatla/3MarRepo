    <JadeMethod name="responseStatusVerify" id="b72c207d-0da1-47a9-adb9-757c008773d6">
        <source>responseStatusVerify(_terminal : CM_Terminal):String;
//----------------------------------------------------------------
//	Created:	17 February 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
//11 Jul 2018	jlgsl4	TFS 39133 - Trade Single Window

vars
	value	: Integer;
	message	: String;
begin
	value := WARNING;
	
	if self.responseStatus = Customs_Export_Cleared 
	or self.responseStatus = Customs_Import_Cleared 
	or self.responseStatus = Customs_Deliver_BreakBulk 
	or self.responseStatus = Customs_Tranship_Cleared 
	or self.responseStatus = Customs_Export_Cancel 
	or self.responseStatus = Customs_Import_Cancel  
	or self.responseStatus = Customs_Tranship_Cancel 
	or self.responseStatus = MAF_ContainerCancellation  
	or self.responseStatus = MAF_ActionRequired 
	or self.responseStatus = SEP_ContainerCancellation 
	or self.responseStatus = SEP_ContainerRelease  
	or self.responseStatus = SEP_InspectionRequired
	or self.responseStatus = CustomsX12_Hold1H 
	or self.responseStatus = CustomsX12_DispCode69
	or self.responseStatus = CustomsX12_Hold1C
	or self.responseStatus = EDIFileType_XMLOneStopCust.String
	or self.hasValidTSWResponse(true) // then // TFS 39133
	or self.hasValidTSWResponse(false) then // TFS 39133 - test both imp/exp cases 16/08/18	
		value := VALID;
	else
		message := "Response status is not valid.";
	endif;
	
	return value.String &amp; message;
end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="roleCode" id="c3a07f1a-8e27-4824-971f-0ddf29ae4344">
