    <JadeMethod name="setMyFormConfiguration" id="ef365bd9-4a08-4974-97ac-97dd281047fe">
        <updating/>
        <source>setMyFormConfiguration(_config :CM_FormConfigForm)updating;
// ---------------------------------------------------------------------------
