    <JadeMethod name="setProxy" id="7ae0582f-761e-4b6e-874e-8bf8f3a70061">
        <updating/>
        <source>setProxy(	_duration : Integer;
			_numberOfSlots : Integer;
			_remarks : String;
			_startTime : Time;
			_myDayTemplate : CM_VehicleBookingDayTemplate;
			_myVBTimeslotType : CM_VehicleBookingTimeSlotType	//01 Oct 2014	NDL	Par 35008
			) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 April 2013	cnwndl1	Initial creation	Par 31393

*/

vars

begin

	self.duration := _duration;
	self.numberOfSlots := _numberOfSlots;
	self.remarks := _remarks;
	self.startTime := _startTime;
	self.endTime := self.startTime.cnEcAddMinutes( self.duration );
	self.myVBTimeslotType := _myVBTimeslotType;	//01 Oct 2014	NDL	Par 35008
	
	self.myVehicleBookingDayTemplate := _myDayTemplate;
	

epilog

end;</source>
