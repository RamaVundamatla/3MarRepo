    <JadeMethod name="auditIdDisplay" id="b0b4b4c2-3980-4b04-a2e8-92e0c339569e">
        <source>auditIdDisplay(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 January 2017	cnwma1	Initial creation
31 Mar 2025 navma1  MTN-34387 MTN - Removing Unnecessary Audits
*/


vars
	auditIdStr : String;
begin
	auditIdStr := self.auditId();								//31.03.2025 navma1 #MTN-34387
	
	if auditIdStr &lt;&gt; null then
		return 'Cargo Resource Map' &amp; ' - ' &amp; auditIdStr;
	else
		return 'Cargo Resource Map';
	endif;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getAllMappedInvoiceLineTypes" id="346fc749-d1f4-430f-ae22-799121f93789">
        <source>getAllMappedInvoiceLineTypes() : CM_InvoiceLineDescSet;
// TFS 40620 getAllMappedInvoiceLineTypes() : CM_InvoiceLineDescMapDict;
/*
Purpose:			
Date		Who		Reason
19 October 2016	cnwab1	Initial creation
*/

vars

	qtyMap	: CM_QuantityMap;
	qtyMapRange : CM_QuantityRange;
	qtyMapRangeMap : CM_QuantityRangeMap;
	invLineDesc : CM_InvoiceLineDesc;
	calctype : CM_CalculationType;
// TFS 40620	invLineDescs : CM_InvoiceLineDescMapDict;
	invLineDescs : CM_InvoiceLineDescSet;// TFS 40620
	alloc : CM_InvoiceAllocation;
	broker : CM_CargoServiceBroker;
	mapping : CM_TranMapInvoiceLineMapping;
begin


	create invLineDescs transient;
	
		qtyMap := self.myChildQuantityMap;
		
		foreach qtyMapRangeMap in qtyMap.allQuantityRanges do
			// TFS 40620 foreach invLineDesc in qtyMapRangeMap.allInvoiceLineMaps do
			foreach mapping in qtyMapRangeMap.allTMInvoiceLineMappings do // TFS 40620
				invLineDesc := mapping.myTMInvoiceLineDesc; // TFS 40620
			
			
				invLineDescs.addNoDuplicates(invLineDesc,false);
			endforeach;
		endforeach;
	
	
	

	
	return invLineDescs;
epilog

end;</source>
        <ReturnType type="CM_InvoiceLineDescSet"/>
    </JadeMethod>
    <JadeMethod name="getAuditText" id="3ea71664-0d5a-471c-9926-0e9fec7bb7d9">
        <source>getAuditText(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 January 2017	cnwma1	Initial creation

*/

vars
	txt,
	tmpStr	: String;
begin
	txt[10000] 	:= '*';
	txt 		:= null;
	txt 		:= inheritMethod();

	if self.getMyTerminal &lt;&gt; null then
		tmpStr := self.getMyTerminal.name;
		txt := txt &amp; app.getErrorString(Terminal) &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp;tmpStr &amp; AuditStringSeparator;
	endif;
	
	tmpStr := null;
	if self.myTransServiceBroker &lt;&gt; null then
		tmpStr := self.myTransServiceBroker.getBank.mailingName;
		txt := txt &amp; app.getErrorString(CM_Business_Unit) &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp;tmpStr &amp; AuditStringSeparator;
	endif;
	return txt;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
