    <JadeMethod name="doResize" id="ff522151-8d78-405f-8ee3-9b5e317a47f0">
        <updating/>
        <source>doResize() updating;
//--------------------------------------------------
// Created:	21 August 2003 By: cnwgd1
//--------------------------------------------------
vars
	tmpLeft,
	tmpTop : Real;
	
begin
	
	self.fldMain.top := self.frmToolbar.height; // ### TFS 50421 17SEP2021 NAVAB1
	self.fldMain.height := self.btnResetJMT.top - self.fldMain.top - 10; // ### TFS 50421 17SEP2021 NAVAB1

	// cnwrl1 20/03/2009 PAR 19174 - start of coding
	self.fldMain.cnEcResizeContents;
//	inheritMethod();			// this does not work properly.
	// cnwrl1 20/03/2009 PAR 19174 - end of coding
	
	tmpTop	:= self.btnResetJMT.top;
	tmpLeft	:= self.mulColumnSorter.myBottomSelectedBtn.left;
	tmpTop	:= self.mulColumnSorter.myBottomSelectedBtn.top + self.mulColumns.myBottomSelectedBtn.height + VerticalSpacing;
	
	// make sure the "AD" button is in the correct place.
	self.btnAscDesc.left	:= tmpLeft;
	self.btnAscDesc.top		:= tmpTop;
	
	//Column Filter sheet	- 21 Dec 2011	NDL Par 28889
	self.doResizeFilterSheet();
	

end;</source>
    </JadeMethod>
    <JadeMethod name="doResizeFilterSheet" id="59c8fdab-9bb6-44b0-ba0d-94e2a90377e8">
        <source>doResizeFilterSheet() protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 December 2011	cnwndl1	Initial creation	Par 28889

*/

vars

	tmpLeft : Real;
	tmpTop : Real;
	tmpWidth : Real;
	tmpHeight : Real;
	gap : Real;
	startGap : Real;
	endGap : Real;
	totalGap : Real;
	btnGap : Real;

begin

	//work down from the top, until we reach the table.
	tmpLeft := 0;
	tmpTop := 0;
	tmpWidth := shtColumnFilter.width;
	tmpHeight := shtColumnFilter.height;
	gap := 5;	
	self.frmFilter.move(	tmpLeft,
							tmpTop,
							tmpWidth,
							tmpHeight );
	
	tmpLeft := 1;
	tmpHeight := 23;
	tmpTop := gap;
	tmpWidth := 145;
	self.btnClearAll.move(	tmpLeft,
							tmpTop,
							tmpWidth,
							tmpHeight );
	
	tmpLeft := self.btnClearAll.left + self.btnClearAll.width + gap;
	tmpWidth := shtColumnFilter.width - ( tmpLeft + 2 ) ;
	self.btnShow.move(	tmpLeft,
						tmpTop,
						tmpWidth,
						tmpHeight );
	
	tmpLeft := 1;
	tmpHeight := 20;
	tmpTop := self.btnClearAll.top + btnClearAll.height + gap;
	tmpWidth := self.frmFilter.width - 2;
		
	self.cmbColumnFilter.move(	tmpLeft,
								tmpTop,
								tmpWidth,
								tmpHeight );
								
	tmpLeft := 0;
	tmpTop := self.cmbColumnFilter.top + cmbColumnFilter.height + gap;
	tmpWidth := frmFilter.width;
	tmpHeight := frmFilter.height - tmpTop;	
	self.frmFilterValues.move(	tmpLeft,
								tmpTop,
								tmpWidth,
								tmpHeight );
								
//	self.lblShowFilter.visible := false;
	self.lblShowFilter.move(	tmpLeft,
								tmpTop,
								tmpWidth,
								tmpHeight );
									
	tmpHeight := 17;
	tmpTop := gap;
	tmpWidth := ( self.frmFilter.width - 4 ) / 2;
	self.optTableData.move(	tmpLeft,
							tmpTop,
							tmpWidth,
							tmpHeight );
							
	tmpLeft := tmpWidth + 2;
	self.optUserData.move(	tmpLeft,
							tmpTop,
							tmpWidth,
							tmpHeight );
							
	
	tmpLeft := 1;
	tmpWidth := self.frmFilter.width - 2;
	tmpHeight := 21;
	tmpTop := self.optTableData.top + self.optTableData.height + gap;
	self.txtFilter.move(	tmpLeft,
							tmpTop,
							tmpWidth,
							tmpHeight );
							
	//work up from bottom until we reach the table.	
	
	tmpHeight := 23;
	tmpTop := self.frmFilterValues.height - ( tmpHeight + gap );
	tmpWidth := 110;
	self.btnUnselectAll.move(	tmpLeft,
						tmpTop,
						tmpWidth,
						tmpHeight );
						
	tmpLeft := self.frmFilter.width - ( tmpWidth + 1 );
	self.btnUpdFilter.move(	tmpLeft,
							tmpTop,
							tmpWidth,
							tmpHeight );
	
	startGap := self.btnUnselectAll.left + self.btnUnselectAll.width;
	endGap := self.btnUpdFilter.left;
	totalGap := endGap - startGap;
	btnGap :=  (( totalGap - ( tmpWidth * 2 ) ) / 3 );
	
	tmpLeft := startGap + btnGap;
	self.btnSelectAll.move(	tmpLeft,
							tmpTop,
							tmpWidth,
							tmpHeight );
							
	tmpLeft := self.btnSelectAll.left + tmpWidth + btnGap;
	self.btnRemFilter.move(	tmpLeft,
							tmpTop,
							tmpWidth,
							tmpHeight );
													
	tmpLeft := 1;
	tmpTop := self.txtFilter.top;
	tmpWidth := self.frmFilter.width - 2;
	tmpHeight := self.btnUnselectAll.top - ( gap + tmpTop );
	
	self.tblFilterValues.move(	tmpLeft,
								tmpTop,
								tmpWidth,
								tmpHeight );
								
	

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doSave" id="8e53d753-822c-4012-938f-28c155977c23">
        <updating/>
        <source>doSave() :Boolean updating, protected;
//--------------------------------------------------------------
//Created: 14 January 2003 By: cnwgd1
// 02 March 2018	jlgrh7 TFS #36564 AAT - Missing Stevedore field from Column Organiser in Voyage Operations
//--------------------------------------------------------------
vars
	oldIdx,
	newIdx : Integer;
	entRow : EntTableRow;
	sortChanged,
	changed : Boolean;
	oldEntRows : EntTableRowArray;	
	pos : Integer;
	parentForm : Form;
begin
	
	app.mousePointer := MousePointer_HourGlass;

	//epr par 33900 3/4/14 leaking transients;
	parentForm :=getParentForm;
	foreach entRow in self.allTblDataEntRows do
		if entRow.isKindOf(EntTableRowProxy) and not self.allAvailableMeasurementRows.includes(entRow) then
			if parentForm &lt;&gt; null and parentForm.isKindOf(CM_TableViewForm) then
				if parentForm.CM_TableViewForm.allTblDataTransientRows.includes(entRow) then
					continue;
				endif;
			elseif parentForm.CM_BaseForm.isVoyageOpsForm() and parentForm.CM_BaseForm.allEntRowsIncludes(entRow) then									//+TFS36564
					continue;
			endif;
			
			if self.myDataTable &lt;&gt; null and self.myDataTable.allTblDataEntRows.includes(entRow) then
				continue;
			endif;
			
			self.allAvailableMeasurementRows.add(entRow.EntTableRowProxy);		
			
			
		endif;
	endforeach;
	
	self.allTblDataEntRows.clear;
	self.mulColumns.getSelected(self.allTblDataEntRows);

	if self.cbxSystem.value then
		self.doSaveSystemDefault();
	endif;

	if self.allowSort then
		// set the sort order
		self.doSaveSortOrder(sortChanged);
	endif;
	
	// check for column removed
	if myDataTable &lt;&gt; null then
		oldEntRows := self.myDataTable.allTblDataEntRows;
	elseif myTextTable &lt;&gt; null then
		oldEntRows := self.myTextTable.allDisplayEntTableRows;
	endif;
	foreach entRow in oldEntRows do
		oldIdx := oldIdx+1;
		newIdx := self.allTblDataEntRows.indexOf(entRow);
		if newIdx &lt;&gt; oldIdx then
			// visible column has changed
			changed := true;
			break;
		endif;
	endforeach;
	
	if (not changed) then
		// check for any new column
		newIdx := 0;
		oldIdx := 0;
		foreach entRow in self.allTblDataEntRows do
			newIdx := newIdx+1;
			oldIdx := oldEntRows.indexOf(entRow);
			if newIdx &lt;&gt; oldIdx then
				// visible column has changed
				changed := true;
				break;
			endif;
		endforeach;
	endif;	

	if changed then
		// set the columns and resorts the table
		if myDataTable &lt;&gt; null then
			self.myDataTable.setColumnsFromOrganiser(self.allTblDataEntRows,self.allTblHiddenEntRows);
		else
			self.myTextTable.setDisplayFromOrganiser(self.allTblDataEntRows);
		endif;
	elseif sortChanged then
		// resort only handled here
		if myDataTable &lt;&gt; null then
			self.myDataTable.setSortColumnsForMaxNumCols();
			changed := true;
		endif;
	endif;
	
	//21 Dec 2011	NDL	Par 28889
	if columnFiltersUpdated then
		self.myDataTable.form.updateTableColumnFilters( self.myDataTable, self.allFilterColumns );
	endif;
	
	return changed; // form handles visible column changes
	
epilog
	app.mousePointer := MousePointer_Default;	
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSaveSortOrder" id="8b28c78e-21b1-4b72-966c-e4f1061abffe">
        <source>doSaveSortOrder(_sortChanged : Boolean output)protected;
//--------------------------------------------------
// Created:	28 October 2003 By: cnwgd1
//--------------------------------------------------
vars
	lstCnt,
	oldIdx,
	idx : Integer;
	entRow : EntTableRow;
	tmpTable : CM_DataTable;
	lstBox : CM_MultiSelectListBox;
	oldDescending,
	descending : Boolean;
	rowName : String;
	oldOrder : StringArray;
	oldDesc : BooleanArray;
begin
	if (not self.allowSort) or myDataTable = null then
		return;
	endif;
	
	tmpTable := self.myDataTable;
	lstBox := self.mulColumnSorter.mySelectedListBox;
	lstCnt := lstBox.listCount;
	
	create oldOrder transient;
	create oldDesc transient;
	
	tmpTable.allTblDataSortColumns.copy(oldOrder);
	tmpTable.allTblDataSortDescending.copy(oldDesc);	
	
	tmpTable.allTblDataSortColumns.clear();
	tmpTable.allTblDataSortDescending.clear();
	
	foreach idx in 1 to lstCnt do
		entRow := lstBox.itemObject[idx].EntTableRow;
		descending  := lstBox.itemText[idx].cnContains(Descending);
		tmpTable.zAddSortColumn(entRow.name, descending);
		if (not _sortChanged) then
			// check to see if sort order has changes
			oldIdx := oldOrder.indexOf(entRow.name);
			if oldIdx &lt;&gt; idx then
				_sortChanged := true;
			else
				oldDescending := oldDesc[oldIdx];
				_sortChanged := oldDescending &lt;&gt; descending;
			endif;
		endif;
	endforeach;
	

	if (not _sortChanged) then
		// check for removed
		foreach rowName in oldOrder do
			if (not tmpTable.allTblDataSortColumns.includes(rowName)) then
				_sortChanged := true;
				break;
			endif;				
		endforeach;
	endif;	

epilog
	delete oldOrder;
	delete oldDesc;	
end;</source>
        <access>protected</access>
        <Parameter name="_sortChanged" type="Boolean" usage="output"/>
    </JadeMethod>
    <JadeMethod name="doSaveSystemDefault" id="9d5887a9-a9ab-4c64-ac46-4fc7a629b073">
        <updating/>
        <source>doSaveSystemDefault()updating, protected;
//--------------------------------------------------------------
//Created: 09 May 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	row  	  : EntTableRow;
	view 	  : EntTableView;
	tmpArray  : EntTableRowArray;
	theResult : Integer;	//13 Jan 2020 NDL	TFS 46815
begin
	executeWhen JMTDevelopmentEnvironment;
		// navmd1 - Prevent Altimetrik from constantly overwriting the system default when they're just trying to undate their own columns *facepalm*
		/*if app.myPassport.myUser.code.endsWith__("20") then
			app.msgBox("Access Denied. Unable to save system default", method.qualifiedName, MsgBox_OK_Only);
			return;
		endif;*/
	endExecuteWhen;
	
	view := myEntTableDef.allEntTableViews[SystemDefault];
	if view = null then
		create view transient;
		view.setProxy(SystemDefault, 'System Default');		
	endif;
	
	create tmpArray transient;
	// only save the persistent rows, others are created at run time
	foreach row in self.allTblDataEntRows do
		if row.isTransient then
			continue;
		endif;
		tmpArray.add(row);
	endforeach;
	
// cnwdad1 17/09/2009 - PAR 20426.
	foreach row in self.allTblHiddenEntRows do
		if not tmpArray.includes(row) then
			tmpArray.add(row);
		endif;
	endforeach;
	
	//13 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxUA.trxResetSystemDefForView(view, tmpArray, myEntTableDef, app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			break;
		else
			theResult := app.showErrorWarningDialog('System Default', app.myPassport, ErrWarnMode_Update);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		break;
		
	endwhile;
		
epilog
	delete tmpArray;
	if view &lt;&gt; null and view.isTransient then
		delete view;
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doSelectColumnToFilter" id="4b89c8e6-0028-45c3-83f8-d925c136583b">
        <updating/>
        <source>doSelectColumnToFilter()protected, updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 December 2011	cnwndl1	Initial creation	Par 28889

*/

vars

	pos : Integer;
	str : String;
	strArray : StringArray;
	intArray : IntegerArray;
	index : Integer;
	column : Integer;
	entableRowHeading : String;
	colFilter : CM_ColumnFilter;

begin

	self.selectFilterUpdated := false;
	self.txtFilter.text := null;
	self.optTableData.value := true;
	self.optUserData.value := false;
	self.changeFilterOptions();

	//set up the table for the filter values
	self.tblFilterValues.fixedRows := 1;
	self.tblFilterValues.rows := 1;
	self.tblFilterValues.fixedColumns := 0;
	self.tblFilterValues.columns := 3;
	self.tblFilterValues.accessColumn(1).inputType := Table.InputType_CheckBox;
	
	// set up the column headings for the table of filter values
	self.tblFilterValues.accessCell(1,1).inputType := Table.InputType_None;
	self.tblFilterValues.setCellText(1,1, "Include" &amp; Tab &amp; "Value" &amp; Tab &amp; "Items");
	
	self.tblFilterValues.zAddSortColumn("Value", false);	
	
	// get the data values from the data table.	
	if self.myDataTable = null then
		return;
	endif;
	
	if self.cmbColumnFilter.text.trimBlanks = null then
		return;
	endif;

	if self.cmbColumnFilter.listIndex &gt; 0 then
		entableRowHeading := self.cmbColumnFilter.itemObject[ self.cmbColumnFilter.listIndex ].EntTableRow.getHeading(self.myDataTable.myTerminologyCargoBOLType, self.myDataTable.myTerminologyTerminal, app.myCurrentLocale);
	endif;
	column := self.myDataTable.getColumnByHeading( self.cmbColumnFilter.text );
	if column = 0 and self.cmbColumnFilter.listIndex &gt; 0 then
		// maybe its using the short description...
		column := self.myDataTable.allTblDataEntRows.indexOf( self.cmbColumnFilter.itemObject[ self.cmbColumnFilter.listIndex ].EntTableRow );
	endif;
		
	create strArray transient;
	create intArray transient;
	self.getFilterValuesFromSource( column, strArray, intArray );
	
	if strArray.isEmpty then
		 return;
	endif;
	
	// find the current Column Filter if there is one.
	colFilter := self.allFilterColumns.getColumnFilter( self.myDataTable, column, entableRowHeading);
	
	// add in the filter value lines
	pos := 0;
	foreach str in strArray do
		pos := pos + 1;
		if colFilter &lt;&gt; null and not colFilter.userEntered and colFilter.includesFilterValue( str ) then
			index := self.tblFilterValues.addItem( "1" &amp; Tab &amp; str &amp; Tab &amp; intArray[pos].String);
		else
			index := self.tblFilterValues.addItem( "0" &amp; Tab &amp; str &amp; Tab &amp; intArray[pos].String);
		endif;
	endforeach;	
	self.tblFilterValues.sortAscending := true;
	self.tblFilterValues.resortTableByColumn(2);
	
	
	if colFilter &lt;&gt; null and colFilter.userEntered then
		//user entered value.
		self.txtFilter.text := colFilter.filterValues.first;
		self.optUserData.value := true;
		self.optTableData.value := false;
		self.changeFilterOptions();
	endif;


epilog

	self.lblShowFilter.visible := self.cmbColumnFilter.listIndex &lt; 1;

	self.enabledFilterButtons();
	delete strArray;
	delete intArray;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="enabledFilterButtons" id="0eb40eda-5042-4c34-8dca-c95d30f20b32">
        <source>enabledFilterButtons();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 December 2011	cnwndl1	Initial creation	Par 28889

*/

vars

begin

	if self.cmbColumnFilter.listIndex &gt; 0 then
		self.btnSelectAll.enabled := true;
		self.btnUnselectAll.enabled := true;
		self.btnUpdFilter.enabled := self.selectFilterUpdated;
		if self.cmbColumnFilter.itemForeColor[self.cmbColumnFilter.listIndex] = Red then
			self.btnRemFilter.enabled := true;
		else
			self.btnRemFilter.enabled := false;
		endif;
	else
		self.btnSelectAll.enabled := false;
		self.btnUnselectAll.enabled := false;
		self.btnUpdFilter.enabled := false;
		self.btnRemFilter.enabled := false;
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="fldMain_sheetChg" id="43b72000-0351-443e-824e-790dcf76e1eb">
        <controlMethod name="Folder::sheetChg"/>
