    <JadeMethod name="addHeading" id="cca289dd-f257-44f8-a457-24cb51bdfe7d">
        <updating/>
        <source>addHeading() updating;
//16 February 2009	cnwdw1	
//
vars
	col: Integer;
	sizes: StringArray;
	attrNameArray : StringArray;
	attrName : String;
	entTableDef : EntTableDef;
	entTableRow : EntTableRow;
	heading : String;
	savedWidth : Integer;
	estWidth : Integer;
begin
	self.addItemAt("", 1);

	create sizes transient;
	sizes.add(ETRow_Total20); sizes.add(ETRow_Total30); sizes.add(ETRow_Total40); sizes.add(ETRow_Total45); sizes.add(ETRow_Total53); sizes.add(ETRow_ColTotalTotal); 
	// PAR 19249
	//self.adjustStatHeading("Total", sizes);
	self.adjustStatHeading(app.getErrorString(YAM_Stats_Total), sizes,getTitleWidth(sizes,app.getErrorString(YAM_Stats_Total)));
		
	sizes.clear;	
	sizes.add(ETRow_Used20); sizes.add(ETRow_Used30); sizes.add(ETRow_Used40); sizes.add(ETRow_Used45); sizes.add(ETRow_Used53); sizes.add(ETRow_ColTotalUsed); 
	// PAR 19249
	//self.adjustStatHeading("Used", sizes);
	self.adjustStatHeading(app.getErrorString(YAM_Stats_Used), sizes,getTitleWidth(sizes,app.getErrorString(YAM_Stats_Used)));

	sizes.clear;	
	sizes.add(ETRow_QueuedIn20); sizes.add(ETRow_QueuedIn30); sizes.add(ETRow_QueuedIn40); sizes.add(ETRow_QueuedIn45); sizes.add(ETRow_QueuedIn53); sizes.add(ETRow_ColTotalQIn); 
	// PAR 19249
	//self.adjustStatHeading("Q In", sizes);
	self.adjustStatHeading(app.getErrorString(YAM_Stats_QueuedIn), sizes,getTitleWidth(sizes,app.getErrorString(YAM_Stats_QueuedIn)));

	sizes.clear;	
	sizes.add(ETRow_QueuedOut20); sizes.add(ETRow_QueuedOut30); sizes.add(ETRow_QueuedOut40); sizes.add(ETRow_QueuedOut45); sizes.add(ETRow_QueuedOut53); sizes.add(ETRow_ColTotalQOut); 
	// PAR 19249
	//self.adjustStatHeading("Q Out", sizes);
	self.adjustStatHeading(app.getErrorString(YAM_Stats_QueuedOut), sizes,getTitleWidth(sizes,app.getErrorString(YAM_Stats_QueuedOut)));
	
	sizes.clear;	
	sizes.add(ETRow_Free20); sizes.add(ETRow_Free30); sizes.add(ETRow_Free40); sizes.add(ETRow_Free45); sizes.add(ETRow_Free53); sizes.add(ETRow_ColTotalFree); 
	// PAR 19249
	//self.adjustStatHeading("Free", sizes);
	self.adjustStatHeading(app.getErrorString(YAM_Stats_Free), sizes,getTitleWidth(sizes,app.getErrorString(YAM_Stats_Free)));

	sizes.clear;	
	sizes.add(ETRow_Projected20); sizes.add(ETRow_Projected30); sizes.add(ETRow_Projected40); sizes.add(ETRow_Projected45); sizes.add(ETRow_Projected53); sizes.add(ETRow_ColTotalProjected); 
	// PAR 19249
	//self.adjustStatHeading("Projected", sizes);
	self.adjustStatHeading(app.getErrorString(YAM_Stats_Projected), sizes,getTitleWidth(sizes,app.getErrorString(YAM_Stats_Projected)));

	sizes.clear;	
	sizes.add(ETRow_PlannedIn20); sizes.add(ETRow_PlannedIn30); sizes.add(ETRow_PlannedIn40); sizes.add(ETRow_PlannedIn45); sizes.add(ETRow_PlannedIn53); sizes.add(ETRow_ColTotalPlanIn); 
	// PAR 19249
	//self.adjustStatHeading("Plan In", sizes);
	self.adjustStatHeading(app.getErrorString(YAM_Stats_PlanIn), sizes,getTitleWidth(sizes,app.getErrorString(YAM_Stats_PlanIn)));

	sizes.clear;	
	sizes.add(ETRow_PlannedOut20); sizes.add(ETRow_PlannedOut30); sizes.add(ETRow_PlannedOut40); sizes.add(ETRow_PlannedOut45); sizes.add(ETRow_PlannedOut53); sizes.add(ETRow_ColTotalPlanOut); 
	// PAR 19249
	//self.adjustStatHeading("Plan Out", sizes);
	self.adjustStatHeading(app.getErrorString(YAM_Stats_PlanOut), sizes,getTitleWidth(sizes,app.getErrorString(YAM_Stats_PlanOut)));

	// Merge all headings
	foreach col in 3 to self.columns do
		if self.accessCell(1, col).text &lt;&gt; "" then
			self.accessCell(1, col).mergeCells := Table.MergeCells_Merge;
			self.accessCell(1, col).alignment := Table.Alignment_Center_Middle;
		endif;
	endforeach;
	
	sizes.clear();  //cnwjo3 ccms 1018.  need this here for getTitleWidth
	
	if self.cnEcIsValidColumn(self.getColumnByRowName(ETRow_Code)) then
		self.accessCell(1, self.getColumnByRowName(ETRow_Code)).text := self.accessCell(2, self.getColumnByRowName(ETRow_Code)).text;
		// PAR 19249
		//self.accessCell(2, self.getColumnByRowName(ETRow_Code)).text := "  Range";
		self.accessCell(2, self.getColumnByRowName(ETRow_Code)).text := "  " &amp; app.getErrorString(YAM_Stats_Range);
		self.accessRow(1).backColor := self.backColor; 
		self.accessRow(2).backColor := self.backColor; 
		self.accessColumn(1).width := 20;  //we aren't going to saving Code at this point since it resizes nicely
		self.accessCell(2, 1).text := "";
	endif;
	
	col := self.getColumnByRowName(ETRow_DeckingSequence);
	if col &gt; 0 then
		self.accessCell(1, col).text := self.accessCell(2, col).text;
		self.accessCell(2, col).text := "";
		self.accessColumn(col).width := self.getTitleWidth(sizes,"Seq");
	endif;

	col := self.getColumnByRowName(ETRow_Stacking);
	if col &gt; 0 then
		self.accessCell(1, col).text := self.accessCell(2, col).text;
		self.accessCell(1, col).alignment := Table.Alignment_Center_Middle;
		self.accessCell(2, col).text := "";
		//self.accessColumn(col).width := 60;
		self.accessColumn(col).width := self.getTitleWidth(sizes,"Decking");  //cnwjo3 ccms 1018
	endif;
	
	col := self.getColumnByRowName(ETRow_PriorityValue);
	if col &gt; 0 then
		self.accessCell(1, col).text := self.accessCell(2, col).text;
		self.accessColumn(col).alignment := Table.Alignment_Right;
		self.accessCell(2, col).text := "";
		//self.accessColumn(col).width := 60;
		self.accessColumn(col).width := self.getTitleWidth(sizes,"Priority"); //cnwjo3 ccms 1018
	endif;

	//cnwjo3 par 20135
	col := self.getColumnByRowName(ETRow_AllowOthers);
	if col &gt; 0 then
		self.accessCell(1, col).text := self.accessCell(2, col).text;
		self.accessColumn(col).alignment := Table.Alignment_Center_Middle;
		self.accessCell(2, col).text := "";
		//self.accessColumn(col).width := 80;
		self.accessColumn(col).width := self.getTitleWidth(sizes,"Allow Others"); //cnwjo3 ccms 1018
	endif;

	//cnwjo3 par 20135
	col := self.getColumnByRowName(ETRow_IfNoLocationFound);
	if col &gt; 0 then
		self.accessCell(1, col).text := self.accessCell(2, col).text;
		self.accessColumn(col).alignment := Table.Alignment_Center_Middle;
		self.accessCell(2, col).text := "";
		//self.accessColumn(col).width := 100;
		self.accessColumn(col).width := self.getTitleWidth(sizes,"If No Loc Found"); //cnwjo3 ccms 1018
	endif;	

	//cnwjo3 par 20135
	col := self.getColumnByRowName(ETRow_OverstowRule);
	if col &gt; 0 then
		self.accessCell(1, col).text := self.accessCell(2, col).text;
		self.accessColumn(col).alignment := Table.Alignment_Center_Middle;
		self.accessCell(2, col).text := "";
		//self.accessColumn(col).width := 130;
		self.accessColumn(col).width := self.getTitleWidth(sizes,"Overstow Rule"); //cnwjo3 ccms 1018
	endif;
	
	//05 Jan 2012	NDL	Par 28889
	create attrNameArray transient;
	self.getGenFilterableColumns( attrNameArray );
	entTableDef := app.myRoot.myEntTableDataRoot.allEntTableDefs[ETDef_YAMDataTbl];
	foreach attrName in attrNameArray do

		heading := attrName;
		col := self.getColumnByRowName(attrName);
		if col &gt; 0 then
			self.accessCell(1, col).text := self.accessCell(2, col).text;
			self.accessColumn(col).alignment := Table.Alignment_Left;
			self.accessCell(2, col).text := "";
			if entTableDef &lt;&gt; null then
				entTableRow := entTableDef.getEntTableRow(attrName);
				if entTableRow &lt;&gt; null then
					heading := entTableRow.getHeading(	self.myTerminologyCargoBOLType,
														self.myTerminologyTerminal,
														app.myCurrentLocale);
				endif;
			endif;
			savedWidth := self.getTitleWidth(sizes,"YAMTable_" &amp; attrName &amp; "Width");
			if savedWidth = 35 then
				// this is the default setting. (I.e. nothing has been saved.)  So, calculate the width required by the heading.
				estWidth := self.getTextExtent( heading );
				if estWidth &gt; savedWidth then
					savedWidth := estWidth;
				endif;
			endif;
			self.accessColumn(col).width := savedWidth;
		endif;
	endforeach;

epilog
	delete sizes;
	delete attrNameArray;
end;</source>
    </JadeMethod>
    <JadeMethod name="addItemYAAt" id="a9867f43-ea46-48f0-884f-94514dd88aca">
        <updating/>
        <source>addItemYAAt(_ya: CM_YardAllocation; _row: Integer): Integer updating;
//15 August 2008	cnwdw1	
// Add the ya and yablocks to the table. 
//09 Nov 2010	epr	 par 26189  -  Hide show and code columns can never change don't go throgh the array to find them.
vars
	block: CM_YABlock;
	group: CM_YABlockGroup;
	rowStr		: String;
	rowString: String;
	yaRow: Integer;
	yaBlockRow: Integer;
	groups: CM_YABlockGroupArray;
	blocks: CM_YABlockArray;
begin
	// Add the YA
	rowString	:=	_ya.getAttributeStringForDefArray(self.allTblDataEntRows);

	if _row &gt; 0 then
		self.addItemObjectAt(_ya, rowString, _row);
		yaRow := _row;
	else
		yaRow := self.addItemObject(_ya, rowString);
	endif;
	self.accessRow(yaRow).backColor := self.myForm.CM_BaseForm.colorHeadingColumn;
	self.accessRow(yaRow).height := 18;
	self.accessCell(yaRow,self.HideShowColumn).backColor := _ya.color;

	// Add the YABlocks
	self.setExpanded(yaRow, NoRows);

	if self.hasGroups then
		// Display with groups
		if self.isIN then
			groups := _ya.allYABlockGroupsIn;
		else
			groups := _ya.allYABlockGroupsOut;
		endif;
		yaBlockRow := yaRow + 1;

		foreach group in groups do
			self.addItemYABlockGroupAt(group, yaBlockRow);

			self.setExpanded(yaRow, Collapse);
			yaBlockRow := yaBlockRow + 1;
			if self.isIN then
				blocks := group.allYABlocksIn;
			else
				blocks := group.allYABlocksOut;
			endif;
			foreach block in blocks do
				self.addItemYABlockAt(block, yaBlockRow);
				yaBlockRow := yaBlockRow + 1;
				self.setExpanded(yaRow, Collapse);
			endforeach;
		endforeach;
		
	else
		// Display without groups
		yaBlockRow := yaRow + 1;
		foreach block in _ya.allYABlocksIn do
			self.addItemYABlockAt(block, yaBlockRow);
			yaBlockRow := yaBlockRow + 1;
			self.setExpanded(yaRow, Collapse);
		endforeach;
	endif;
	self.recalcYATotals(_ya,yaRow);  //this is where numbers are placed next to Default Group
	
	//par 19909 cnwjo3
	if self.isYASelected() then
		self.expandYALocations(_ya,false);
	endif;	
	
	return yaRow;
end;</source>
        <Parameter name="_ya" type="CM_YardAllocation"/>
        <Parameter name="_row" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="addItemYABlockAt" id="2202276b-8f07-402a-a5b3-0cf2182131da">
        <updating/>
        <source>addItemYABlockAt(_yaBlock: CM_YABlock; _row: Integer) : Integer updating;
//15 August 2008	cnwdw1	
// Add the yablock to the table. If _row is zero append to end of table otherwise insert
//09 Nov 2010	epr	 par 26189  -  Hide show and code columns can never change don't go throgh the array to find them.
vars
	rowString: String;
	yaBlockRow: Integer;
	column: Integer;
	indent: String;
begin
	rowString := _yaBlock.getAttributeStringForDefArray(self.allTblDataEntRows);
	
	if _row &gt; 0 then
		self.addItemObjectAt(_yaBlock, rowString, _row);
		yaBlockRow := _row;
	else
		yaBlockRow := self.addItemObject(_yaBlock, rowString);
	endif;
	self.accessRow(yaBlockRow).height := 18;
	self.colourAddedRow(yaBlockRow, self.myForm.CM_BaseForm.colorRow1, self.myForm.CM_BaseForm.colorRow2);
	self.accessCell(yaBlockRow,self.HideShowColumn).backColor := _yaBlock.myYardAllocationIn.color;
	column := self.CodeColumn;
	indent := "  ";
	if self.hasGroups then
		indent := indent &amp; indent;
	endif;

	self.accessCell(yaBlockRow, column).text := indent &amp; self.accessCell(yaBlockRow, column).text;
	if _yaBlock.isOpen then
		self.accessCell(yaBlockRow, column).foreColor := Black;
	else
		self.accessCell(yaBlockRow, column).foreColor := "128,128,128".asRGB;
	endif;
	self.showDecking(_yaBlock, yaBlockRow);
	
	return yaBlockRow;
end;</source>
        <Parameter name="_yaBlock" type="CM_YABlock"/>
        <Parameter name="_row" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="addItemYABlockGroupAt" id="c221de7f-36e2-4021-b05a-712f8fa0e4bf">
        <updating/>
        <source>addItemYABlockGroupAt(_yaBlockGroup: CM_YABlockGroup; _row: Integer) : Integer updating;
//15 August 2008	cnwdw1	
// Add the yablock to the table. If _row is zero append to end of table otherwise insert
//09 Nov 2010	epr	 par 26189  -  Hide show and code columns can never change don't go throgh the array to find them.
vars
	rowString: String;
	yaBlockRow: Integer;
	column: Integer;
begin
	rowString := _yaBlockGroup.getAttributeStringForDefArray(self.allTblDataEntRows);

	if _row &gt; 0 then
		self.addItemObjectAt(_yaBlockGroup, rowString, _row);
		yaBlockRow := _row;
	else
		yaBlockRow := self.addItemObject(_yaBlockGroup, rowString);
	endif;
	self.accessRow(yaBlockRow).height := 18;
	//cnwjo3 par 20291
	self.accessRow(yaBlockRow).gridRight := false;
	self.accessRow(yaBlockRow).gridBottom := false;
	
	self.colourAddedRow(yaBlockRow, self.myForm.CM_BaseForm.colorRow1, self.myForm.CM_BaseForm.colorRow2);
	self.accessCell(yaBlockRow,self.HideShowColumn).backColor := _yaBlockGroup.myYardAllocationIn.color;
	column := self.CodeColumn;
	self.accessCell(yaBlockRow, column).text := "  " &amp; self.accessCell(yaBlockRow, column).text;

	return yaBlockRow;
end;</source>
        <Parameter name="_yaBlockGroup" type="CM_YABlockGroup"/>
        <Parameter name="_row" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="addItemYardAllocation" id="46ed76f9-6ab0-42e2-959b-35e6770398b9">
        <updating/>
        <source>addItemYardAllocation( _ya: CM_YardAllocation ) : Integer updating;

/*

Purpose:			Adds a Yard Allocation and blocks to table.

Parameters:			

Return Value:		Row of Yard Allocation line


Date				Who		Reason
12 November 2008	consw1	Initial creation

*/

vars
	iter		: Iterator;
	rowYA		: Integer;
	rowNext		: Integer;
	yaNext		: CM_YardAllocation;

begin
	
	if self.findObjectInRow(_ya, rowYA) then
		return 0;
	endif;
	
	if self.isManuallyMaintained or not self.mySearchParameters.allSearchCriteriaResolved.isEmpty() then
		//epr par 31525 20/1/14 make sure same object is not in dict twice
		if not self.allYardAllocationsByPriority.includes(_ya) then
			self.allYardAllocationsByPriority.add(_ya);
		endif;
		yaNext := self.allYardAllocationsByPriority.getAtKeyGtr(_ya.priorityValue);
	else
		iter := self.getTerminal.allYardAllocations.createIterator;
		self.getTerminal.allYardAllocations.startKeyGtr(_ya.priorityValue, iter);
		while iter.next(yaNext) do
			if self.mySearchParameters.isMatchingYA(yaNext) then
				break;
			endif;
		endwhile;
	endif;
	
	self.findObjectInRow(yaNext, rowNext);
	
	return self.addItemYAAt(_ya, rowNext);
epilog
	delete iter;
end;</source>
        <Parameter name="_ya" type="CM_YardAllocation"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="adjustStatHeading" id="9e281769-c090-400d-ae8f-99dcabd05ea4">
        <updating/>
        <source>adjustStatHeading(_text: String; _sizes: StringArray; _titleWidth : Integer) updating;
//17 February 2009	cnwdw1	
//
vars
	i, col, minCol: Integer;
	columnCount : Integer;
	newWidth : Integer;
begin
	//cnwjo3 ccms 1018
	foreach i in 1 to _sizes.size() do
		if self.getColumnByRowName(_sizes[i]) &gt; 0 then
			columnCount := columnCount + 1;
		endif;
	endforeach;
	
	foreach i in 1 to _sizes.size do
		col := self.getColumnByRowName(_sizes[i]);
		if col &gt; 0 then
			newWidth := (_titleWidth/columnCount).Integer;
			self.accessColumn(col).width := newWidth;
			self.accessColumn(col).alignment := Table.Alignment_Right_Middle;
			if minCol = 0 then
				minCol := col;
			else
				minCol := minCol.min(col);
			endif;
		endif;
	endforeach;
	if minCol &gt; 0 then
		self.accessCell(1,minCol).text := _text;
	endif;

end;</source>
        <Parameter name="_text" type="String"/>
        <Parameter name="_sizes" type="StringArray"/>
        <Parameter name="_titleWidth" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="applyColumnFilter" id="45b53ec1-c2de-4a82-b22b-6e0c22de58e6">
        <updating/>
        <source>applyColumnFilter(_filters: CM_ColumnFilterDict):Integer updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 January 2012	cnwndl1	Initial creation	Par 28889 - YAM table version skips over expanded rows....

*/

vars

	startRow : Integer;
	endRow : Integer;
	rowIndex : Integer;
	myFilters : CM_ColumnFilterDict;
	colFilter : CM_ColumnFilter;
	row : JadeTableRow;
	col : Integer;
	yardAllocation : CM_YardAllocation;
	yardAllocationVisible : Boolean;
	childWasVisible : Boolean;
	isChild : Boolean;
	count : Integer;

begin

	create myFilters transient;

	if _filters &lt;&gt; null then
		// just get the filters that are for me. (could be some for other tables on the form)
		_filters.cloneFiltersForTable( self, myFilters );
	endif;
	
	foreach col in 1 to self.columns do
		self.accessCell(1,col).fontBold := false;
	endforeach;
	
	startRow := self.fixedRows + 1;
	endRow := self.rows;
	
	//if endRow &lt;= startRow then
	if endRow &lt; startRow then				// was ignoring filters on a single line in the table
		return count;
	endif;

	if myFilters.isEmpty then
		foreach rowIndex in startRow to endRow do
			row := self.accessRow(rowIndex);
			if row.itemObject.isKindOf( CM_YardAllocation ) then
				row.visible := true;
				count := count + 1;
			endif;
		endforeach;
	else
		foreach colFilter in myFilters do
			col := colFilter.columnIndex;
			self.accessCell(1,col).fontBold := true;
		endforeach;
		foreach rowIndex in startRow to endRow do
			row := self.accessRow(rowIndex);
			if not row.itemObject.isKindOf( CM_YardAllocation ) then
				childWasVisible := row.visible;
				isChild := true;
			else
				count := count + myFilters.applyFiltersToRow( self, rowIndex, row ).Integer;
				isChild := false;
				yardAllocation := row.itemObject.CM_YardAllocation;
				yardAllocationVisible := row.visible;
			endif;
			if isChild then
				row.visible := childWasVisible and yardAllocationVisible;
			endif;
		endforeach;
	endif;

	return count;

epilog

	delete myFilters;

end;</source>
        <Parameter name="_filters" type="CM_ColumnFilterDict"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="clearAllData" id="edae02e3-64f6-48c5-b375-eaf7d5254fa6">
