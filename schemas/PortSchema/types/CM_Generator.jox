    <JadeMethod name="setPxyFromTIMaster" id="adc3822b-6035-43b9-a7e6-60ff05fea4f8">
        <updating/>
        <source>setPxyFromTIMaster(_genMaster : CM_TIMasterGenerator; _ti: CM_TrackedItem) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 Feb 2018	cnwma1  ChangeRequest 36813: PEN - Gen Sets, Chassis &amp; Reefers

*/

vars
	toDoTaskDesc : CM_ToDoTaskDesc;
	stopArray    : IntegerArray;
	stopTable : CM_StopsTable;
begin

	self.setMyGeneratorType(_genMaster.myGeneratorType);				
	self.setCargoType(_genMaster.cargoType);
	self.id := _genMaster.id;
	self.description := _genMaster.description;
	self.setMyOperator(_genMaster.myOperatorNew);
	self.setWeightTare(_genMaster.getTareWeight);
	self.setISOType(_genMaster.isoType);
	self.myTerminal := _ti.myTerminal;
	self.dischargePort := _ti.dischargePort;
	self.totalWeight := _genMaster.tWeight;
	self.setWeightTare (_genMaster.getTareWeight);
	self.setMyTiMaster();
	self.isValid := true;

	foreach toDoTaskDesc in _genMaster.allToDoTaskDesc do
			self.addToDoTask(toDoTaskDesc.description, app.myPassport);
	endforeach;
	
	if not _genMaster.allStopsNew.isEmpty then
		create stopArray transient;
		
		foreach stopTable in _genMaster.allStopsNew do
			stopArray.add(stopTable.id);
		endforeach;
		self.createStopsProxy(stopArray);

	endif;
epilog
	delete stopArray;
end;</source>
        <Parameter name="_genMaster" type="CM_TIMasterGenerator"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
