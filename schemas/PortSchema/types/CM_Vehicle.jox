    <JadeMethod name="getVehicleInfo" id="c10dfdb1-a769-4d14-bcf2-8dacaa6c53eb">
        <source>getVehicleInfo(_array : HugeStringArray input);
//--------------------------------------------------------------
//Created: 19 February 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	jobId,
	releaseNum	: String;
	job		: CM_Job;
	req		: CM_Request;
	ti		: CM_TrackedItem;
begin

	_array.add("Vehicle ID" &amp; Tab &amp; self.regNumber);
	_array.add("Carrier" &amp; Tab &amp; self.carrier.description);

	if self.batNumber &lt;&gt; null then
		_array.add("Bat Number" &amp; Tab &amp; self.batNumber);
	endif;
	
	_array.add("Number of Jobs" &amp; Tab &amp; self.allRoadJobs.size.String);	

	foreach job in self.allRoadJobs do
		if job.CM_RoadJob.isRelease then
			foreach req in job.allRequests do
				releaseNum := req.CM_YardRequest.deliveryNumber;
				if not _array.includes("Release Number" &amp; Tab &amp; releaseNum) then
					_array.add("Release Number" &amp; Tab &amp; releaseNum);
				endif;
			endforeach;
		endif;
	endforeach;

end;</source>
        <Parameter name="_array" type="HugeStringArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="hasDirectDeliveryTask" id="d5e5f7b3-734a-448c-bde6-c16f2a2860b2">
        <source>hasDirectDeliveryTask():Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 April 2013	cnwndl1	Initial creation

*/

vars

	wleArray: CM_WLEArray;
	wle : CM_WorkListEntry;

begin

	create wleArray transient;
	self.getAllWLEs( wleArray );
	
	if wleArray.isEmpty then
		return false;
	endif;
	
	foreach wle in wleArray do
		if wle.isDirectDelivery then
			return true;
		endif;
	endforeach;
	
	return false;

epilog

	delete wleArray;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="hasIncompleteRelease" id="5150670d-77fb-4a68-867d-9d97bded1f5d">
        <source>hasIncompleteRelease()	:Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28 November 2013	cnwrd1	Initial creation

*/

vars

	wleArray: CM_WLEArray;
	wle : CM_WorkListEntry;

begin

	create wleArray transient;
	self.getAllWLEs( wleArray );
	
	if wleArray.isEmpty then
		return false;
	endif;
	
	foreach wle in wleArray do
		if not wle.isReceipt and not wle.isCompleteForJob then
			return true;
		endif;
	endforeach;
	
	return false;

epilog

	delete wleArray;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="hasIncompleteRoadJobs" id="53ca3011-bef7-4f19-8e70-a87d2cfeca30">
        <source>hasIncompleteRoadJobs():Boolean;
/*
Date		Who		Reason
23 Oct 2012	cnwcs5	Initial creation - par 29653
*/
vars
	job		:CM_Job;
begin
	foreach job in self.allRoadJobs do
		if not job.CM_RoadJob.isJobComplete then
			return true;
		endif;
	endforeach;
	
	return false;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isInGateLocation" id="7968b3c9-9397-4e58-abcf-6b06be8f1d5e">
        <source>isInGateLocation(_gate: CM_Gate): Boolean;
/*
----------   ----------  --------------------------------------------------
Created:	13 September 2006 By cnwth2

Purpose:	Return true if the vehicle is in a lane for the _Gate

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	gateController: CM_YardController;
begin
	if _gate = null then
		return self.myPrimaryActualLocation.isKindOf(CM_GateAreaLaneController);
	else
		gateController := self.myPrimaryActualLocation.CM_YardController;
		if gateController &lt;&gt; null then
			return gateController.isLocationForGate(_gate);
		endif;
	endif;

end;


</source>
        <Parameter name="_gate" type="CM_Gate"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isInPreGate" id="64d84a34-2481-46b3-b48d-f5cb3f73678a">
        <source>isInPreGate() : Boolean;
/*

Date		Who		Reason
07 April 2017	cnwer1	Initial creation TFS

*/

vars

	lc 		: CM_YardController;
	area	: CM_TerminalArea;

begin
	lc	 := self.myPrimaryActualLocation;
	
	if lc = null then
		return false;	// vehicle not in terminal
	endif;	
	
	area := lc.myTerminalArea;

	if area  = null then
		return false;
	endif;
	
	if area.isKindOf (CM_GateArea) then
		if area.CM_GateArea.laneCount &gt; 0 and lc.isKindOf(CM_GateAreaLaneController) then
			return false;
		else
			return true;
		endif;
	endif;
	
	return false;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isOnsite" id="936aead5-b75b-451a-9ba7-b3f688b9329a">
        <source>isOnsite(): Boolean;
//03 September 2009	cnwdw1	
//
vars

begin
	return self.myPrimaryActualLocation &lt;&gt; null;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isUnknownVehicle" id="091079ef-cbbc-4ff5-9d08-bc6fa493ef14">
        <source>isUnknownVehicle() : Boolean;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 26/02/2014	cnwdap1		Initial creation PAR #33582 Is this vehicle one without a real registration number
//
vars

begin
	return self.regNumber[1:3] = Unknown_Truck_Prefix;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isWeighBridgeWeighable" id="cdfd5c77-a742-4fac-bfe8-0fcd48daee4b">
        <source>isWeighBridgeWeighable( _objs : ObjectArray input; _errStr : String output ): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 March 2014	cnwndl1	Initial creation	Par 33268
08 Jan 2018	NDL	TFS 36437
*/

vars

	ti : CM_TrackedItem;
	trailer : CM_TILC;
	tiSet : CM_TISet;
	weighBridge : CM_WeighBridgeObj;
	vvr : CM_VehicleVisitRecord;
	returnValue : Boolean;

begin

	returnValue := false;
	if self.myTerminal= null or self.myTerminal.allWeighBridges.isEmpty then
		// No weigh bridges, can't weigh it.
		_errStr := "No weigh bridges found, can't weigh it!";
		app.writeLog(method.qualifiedName &amp;  " " &amp; _errStr, LogINFO);
	elseif self.locationsController.allTrackedItems.size &gt; 1 then
		//too many cargo items to weigh on the truck.
		_errStr := "Too many cargo items to weigh on the truck!";
		app.writeLog(method.qualifiedName &amp;  " " &amp; _errStr, LogINFO);
	elseif self.locationsController.allTrackedItems.isEmpty then
		// just the truck, all good.
		if _objs &lt;&gt; null then
			_objs.addExclusive( self );
		endif;
		returnValue := true;
	elseif self.locationsController.allTrackedItems.size = 1 then
		// one item on the truck
		ti := self.locationsController.allTrackedItems.first;
		if ti.isKindOf( CM_TILC ) then
			trailer := ti.CM_TILC;
			create tiSet transient;
			trailer.getAllOnboardTIs( tiSet );
			if tiSet.size &gt; 1 then
				//too many cargo items to weigh on the truck and trailer.
				_errStr := "Too many cargo items to weigh on the truck and trailer!";
				app.writeLog(method.qualifiedName &amp;  " " &amp; _errStr, LogINFO);
			elseif tiSet.size = 1 then
				// just the truck and trailer and one cargo item on teh trailer, all good.
				if _objs &lt;&gt; null then
					_objs.addExclusive( self );
					_objs.addExclusive( trailer );
					_objs.addExclusive( tiSet.first );
				endif;
				returnValue := true;
			elseif tiSet.isEmpty then
				// just the truck and trailer, all good.
				if _objs &lt;&gt; null then
					_objs.addExclusive( self );
					_objs.addExclusive( trailer );
				endif;
				returnValue := true;
			endif;
			
		else
			//its not a trailer
			if _objs &lt;&gt; null then
				_objs.addExclusive( self );
				_objs.addExclusive( ti );
			endif;
			returnValue := true;
		endif;
		
	endif;
	
	if returnValue then
		if _objs &lt;&gt; null then
			vvr := self.getCurrentVisit();
			if vvr &lt;&gt; null and self.isOnsite then
				_objs.addExclusive( vvr );
			endif;
			if self.myPrimaryActualLocation.isKindOf( CM_GateAreaLaneController ) then
				weighBridge := self.myPrimaryActualLocation.CM_GateAreaLaneController.getWeighBridge;
				if weighBridge &lt;&gt; null then
					_objs.addExclusive( weighBridge );
				endif;
			elseif self.myPrimaryActualLocation.isKindOf( CM_BlockController ) then
				if not self.myPrimaryActualLocation.CM_BlockController.isInsideYard then
					//at pregate.
					if vvr &lt;&gt; null and vvr.myGateLaneController &lt;&gt; null and vvr.myGateLaneController.isKindOf(CM_GateAreaLaneController) then
						weighBridge := vvr.myGateLaneController.CM_GateAreaLaneController.getWeighBridge;
						if weighBridge &lt;&gt; null then
							_objs.addExclusive( weighBridge );
						endif;
					endif;
				endif;
			endif;
		endif;
	endif;
	
	return returnValue;

epilog

	delete tiSet;

end;</source>
        <Parameter name="_objs" type="ObjectArray" usage="input"/>
        <Parameter name="_errStr" type="String" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="lastVisitDT" id="8735709f-4282-4b86-8eff-1aa6ae98b8b9">
        <source>lastVisitDT() : TimeStamp;
//Just provides the time of the last visit. Intended for use in garbage collect
//eventually to allow purging of obsolete vehicle records
vars

begin
	if visitRecords.size &gt; 0 then
		return visitRecords.last.CM_VehicleVisitRecord.timeIn;
	endif;
end;</source>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="lastVisitDTLocalTZ" id="add1ae9d-cc75-4701-866f-81a2a9aaf96c">
        <source>lastVisitDTLocalTZ() :TimeStamp;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 May 2016	cnwns1	Initial creation
// 31 May 2016	cnwns1	TFS 488 - Multi Timezone Support
*/

vars

begin
	if visitRecords.size &gt; 0 then
		return self.systemToLocalTime(visitRecords.last.CM_VehicleVisitRecord.timeIn);
	endif;
end;
</source>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="purgeVisitRecords" id="6b4eadfc-ee63-42cf-8f56-4f1f45d1e6c7">
        <source>purgeVisitRecords(_ts : TimeStamp; _agent : CM_DBPurgeAgent input);
// -------------------------------------------
// Created 24 August 2004 by cnwdvb1
//
// PAR18151 - cnwsh3 14/10/2008 Added check to only log a db purge entry if a visit record was deleted
//								otherwise the number of stats is huge.
// -------------------------------------------
vars
	iter : Iterator;
	visitRecord : CM_VehicleVisitRecord;
	completed : Integer;
begin
	iter := self.visitRecords.createIterator();
	self.visitRecords.startKeyLeq(_ts, iter);
	while iter.back(visitRecord) do
		self.exclusiveLock(visitRecord);
		delete visitRecord;
		completed := completed + 1;
	endwhile;
	//PAR18151 - cnwsh3
	if completed &gt; 0 then
		_agent.setStats(app.getErrorString(Purged)&amp;' for '&amp;self.code&amp;' '&amp;completed.String&amp;' '&amp;app.getErrorString(Vehicle_visit_records)&amp;' '&amp;"0"&amp;' '&amp;app.getErrorString(Errors));
	endif;
epilog	
	delete iter;
end;</source>
        <Parameter name="_ts" type="TimeStamp"/>
        <Parameter name="_agent" type="CM_DBPurgeAgent" usage="input"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="65000470-834e-41e5-a791-3de56130c079">
        <source>pxyCreateUpdateProxy(): SelfType;

// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy

vars
	tmpVehicle : CM_Vehicle;
	completedOK		: Boolean;
begin
	tmpVehicle := inheritMethod();
	tmpVehicle.carrier := self.carrier;
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return tmpVehicle;
	
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete tmpVehicle;
	endif;	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="resetLocationController" id="3500d994-9f5e-40df-b301-867183b1bc76">
        <updating/>
        <source>resetLocationController(_passport : CM_Passport input) updating;
//--------------------------------------------------------------
//Created: 01 March 2002 By: cnwgd1
//--------------------------------------------------------------
//Called from the CM_RoadJob::erase, clears up the LC ready for next job
// 01 Feb 2017	cnwrs1	TFS 3256 38585 vehcile stuck in Road Exit with queued merged cargo
// 23/05/2017 	cnwrh7  TFS4500       #Code :75768. Unexpected Program Error in DPHPJMT5 (similar to TFS4385)
vars
	tmpLC			: CM_VehicleController;
	moveController	: CMIF_MoveController;
	ti,
	prevTi			: CM_TrackedItem;
	idx				: Integer;
	bat				: CM_BatNumber;
	counter : Integer;
	lastReceiveRoad : CM_TITransaction;
	vvr				: CM_VehicleVisitRecord;
	cancelledReason : String;
	infoReason		: StringArray512;
	stillInPregate	: Boolean;
	detail	: CM_VehicleVisitRecordDetail;
	futurePlanQueueMoveSize		: Integer;	
	fm : CM_FutureMove;	//05 Dec 2017	NDL	TFS 7937
	fmIndex : Integer;	//05 Dec 2017	NDL	TFS 7937
	invalid : Boolean;
	edition : Integer;
begin
	
	if self.batNumber &lt;&gt; null then
		bat := self.myTerminal.allBatNumbersInUse[self.batNumber];
		if bat &lt;&gt; null then
			bat.setMyTerminal(null);
		endif;
	endif;
	
	self.batNumber := null;

	tmpLC := self.locationsController;
	if tmpLC = null then
		return;
	endif;

	// need to change this to move off (check ti is offsite first??)
	// Look at shifting these to the locationsController ...
	create moveController transient;
	// ignore any warnings on the move
	moveController.isForcedMove := true;

	if (not tmpLC.allPlannedFutureMoves.isEmpty) then
		//Unplan TIs that are planned to vehicle	
		moveController.setMoveMode(PLANNING_MODE);
		idx := 1;
		prevTi := null;
		while tmpLC.allPlannedFutureMoves.isEmpty = false do
			ti := tmpLC.getTIAtIndex(PLANNING_MODE, idx);
			if ti = null then
				break;
			endif;
			if ti.hasBeenMerged then
				idx := idx + 1;
				continue;
			endif;
			moveController.setMyTrackedItem(ti);
			app.myUtilityUA.utlUpdateMoveTIUndo(moveController, _passport);
			if _passport.hasErrors then
				break;
			endif;
			
			if prevTi &lt;&gt; null and prevTi = ti then
				// something has happened
				counter := counter + 1;	//multiple planned moves now allowed per ti..... found during testing NDL 20 May 2015
				if counter &gt; 5 then
					app.raiseUnexpectedProgramError(class.name, method.name, 'Looping (planned future moves) (' &amp; tmpLC.String &amp; '; ' &amp; ti.String);
					break;
				endif;
			endif; 
			prevTi := ti;
		endwhile;
	endif;
	counter := 0;
	if (not tmpLC.allQueuedFutureMoves.isEmpty) then
		//Unqueue TIs that are queued to vehicle
		moveController.setMoveMode(QUEUE_MODE);
		idx := 1;
		prevTi := null;
		while tmpLC.allQueuedFutureMoves.size &gt; 0 do
			futurePlanQueueMoveSize := tmpLC.allQueuedFutureMoves.size;																							//+TFS4500
			ti := tmpLC.getTIAtIndex(QUEUE_MODE, idx);
			if ti = null then
				break;
			endif;
			if ti.hasBeenMerged then
				idx := idx + 1;
				continue;
			endif;
			moveController.setMyTrackedItem(ti);
			
			//05 Dec 2017	NDL	TFS 7937
			moveController.setMoveIndex( 0 );
			if tmpLC.allQueuedFutureMoves.size &gt;= idx then
				fm := tmpLC.allQueuedFutureMoves[idx];
				if fm &lt;&gt; null then
					fmIndex := ti.allQueuedFutureMoves.indexOf(fm);
					if fmIndex &gt; 0 then
						moveController.setMoveIndex( fmIndex );
					endif;
				endif;
			endif;
				
			app.myUtilityUA.utlUpdateMoveTIUndo(moveController, _passport);
			if _passport.hasErrors then
				break;
			endif;
																																														//- TFS4500
			if futurePlanQueueMoveSize = tmpLC.allQueuedFutureMoves.size then																						//+TFS4500
				app.raiseUnexpectedProgramError(class.name, method.name, 'Looping (queued future moves) (' &amp; tmpLC.String &amp; '; ' &amp; ti.String);
				break;
			//endif;
			endif;
			prevTi := ti;
		endwhile;
	endif;
	
	on Exception do app.handleDeletedObject( exception, ti, invalid );	//14 April 2020	NDL	Unit Test issue during Truck delete
	
	//Need to change for multi terminal as TI could be a transfer between terminals		
	if (not tmpLC.allTrackedItems.isEmpty) then
		//Move TIs from vehicle to off site
		// Par 13202
		moveController.setIsUndoMove(false);
		moveController.setMoveMode(REAL_MODE);
		idx := 1;
		prevTi := null;
		while tmpLC.allTrackedItems.size &gt; 0 do
			ti := tmpLC.getTIAtIndex(REAL_MODE, idx);
			if ti = null then
				break;
			endif;
			edition := ti.edition; //14 April 2020	NDL
			if ti.hasBeenMerged or invalid then
				invalid := false;	//14 April 2020	NDL
				idx := idx + 1;
				continue;
			endif;
			moveController.setMyTrackedItem(ti);
			moveController.setQuantity( ti.totalQuantity );	//20 May 2015	NDL	Par 36127
			moveController.setWeight(ti.totalWeight);		//cnwmc5 - 18 Mar 2016 - PAR 37581
			
			lastReceiveRoad:=ti.getLastTransOfTypeDeleted(TRANS_TYPE_REC_ROAD);
			if lastReceiveRoad &lt;&gt; null then
				//this is because of the delete current entry 3988
				//TFS 3988 7/4/16 do not charge for this also add info entry 
				
				vvr:=self.getCurrentVisit();
				if vvr &lt;&gt; null then
					cancelledReason:=vvr.getCancelledReason();
					if cancelledReason &lt;&gt; null then
						create infoReason transient;
						infoReason.add(app.getErrorString1(Vehicle_visit_for_job, vvr.jobNumber));
						infoReason.add(app.getErrorString2(Vehicle_visit_cancel_reason,vvr.visitNumber ,cancelledReason));	
						
						stillInPregate:= true;
						foreach detail in vvr.allVehicleVisitRecordDetails do
							if detail.recordType = VisitRecord_Yard or detail.recordType = VisitRecord_Arrive_PGate_In then
								stillInPregate:=false;
								break;
							endif;
						endforeach;
						
						if  stillInPregate then
						
							infoReason.add(app.getErrorString(Vehicle_Visit_Cancel_NoCharge));
							moveController.isNoChargeMove:=true;
						endif;
					
						ti.createInfomationTransaction(app.getErrorString(VehicleVisit_cancelled),infoReason, null,_passport);
					endif;
				endif;
			endif;
			
																																								//
			app.myUtilityUA.utlUpdateMoveTrackedItem(moveController, _passport);				
			if _passport.hasErrors then
				break;
			endif;
			if prevTi &lt;&gt; null and prevTi = ti then
				// something has happened
				app.raiseUnexpectedProgramError(class.name, method.name, 'Looping (' &amp; tmpLC.String &amp; '; ' &amp; ti.String);
				break;
			endif;
			prevTi := ti;
			
			if app.myPassport.isOpsViewEnabled(self.myTerminal) then // ### TFS 52914 25FEB2022 NAVAB1
				ti.createOpsViewEWSActivity(BGP_OpsViewWSRequest.OPS_ACTION_UPDATE,BGP_OpsViewWSRequest.OPS_TYPE_TRACKEDITEM, ti);	 // ### TFS 52914 25FEB2022 NAVAB1
			endif;
		endwhile;
	endif;		

	tmpLC.setMyTerminalArea(null);
	//epr par 12747 12/10/06

	self.setMyPrimaryActualLocation(null,true);
	
epilog
	delete moveController;
	delete infoReason;
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="roadExitProcess" id="232f9437-b2fd-4638-b8eb-6d6f017de116">
        <updating/>
        <source>roadExitProcess(_passport : CM_Passport input)updating;
//--------------------------------------------------------------
//Created: 15 August 2002 By: cnwgd1
//--------------------------------------------------------------
//16 Feb 2016		cnwrs1	TFS 3488 3337 - sometimes a vehicle is left with a roadjob but with a myPrimaryActualLocation so will not exit
// 31/05/2022		jlier1	TFS 53650 - refactored schedule packages now called from vvr.departureProcess
//07 February 2023	navmp20	ChangeRequest 56443: AAT - 1Stop VBS Messages Road Exit Screen
vars
	job					: CM_Job;
	found				: Boolean;								// PAR 16188
	visit				: CM_VehicleVisitRecord;
	ti					: CM_TrackedItem;						// TFS 52268
	needsBooking		: Integer;								// TFS 52268
	roadExitMsg			: CMIF_1StopRoadExitRequest;			// TFS 52268
	response			: CMIF_Object;							// TFS 52268
	roadExitResponse	: CMIF_1StopRoadExitResponse;			// TFS 52268
	talkedTo1Stop		: Boolean;								// TFS 52268
	
begin
	visit := self.visitRecords.last;
	
	foreach job in self.allRoadJobs discreteLock do
		if job.isCompleteForExit then
		//	if job.status = JOB_COMPLETE then
			found := true;
			job.departureProcess(_passport);
			
		endif;
	endforeach;
	
	//11 Jan 2013	NDL	Par 30921
	//Cargo can be added on the fly.  This will not have an associated job so check for these
	//and add to the released cargo of the vehicle visit record if required.
//	visit := self.visitRecords.last;

	if visit &lt;&gt; null then  // NAVAB1 15SEP2021 - bad data in DMAST
		visit.doExitForNoJobCargoLoads();
		
		// TFS 52268 check number of released / received items against the number of VBS booking slots
		// and send a road exit message to 1-Stop
		/*if visit.myTerminal.is1STOPVBS then
			foreach ti in visit.allReceivedTrackedItems where ti.requires1StopVehicleBooking do
				needsBooking := needsBooking + 1;
			endforeach;
			foreach ti in visit.allReleasedTrackedItems where ti.requires1StopVehicleBooking do
				needsBooking := needsBooking + 1;
			endforeach;
			if visit.all1StopExtVehicleBookings.size &lt; needsBooking then
				// raise exception
				app.raiseCMException2(Not_enough_vehicle_book_slots, visit.all1StopExtVehicleBookings.size.String, needsBooking.String, null, null);
				return;
			endif;
			if needsBooking &lt;&gt; null then
				if visit.myTerminal.is1STOPVBSConfigured then
					create roadExitMsg transient;
					roadExitMsg.myVehicleVisit := visit;
					talkedTo1Stop := visit.myTerminal.roadExit1StopVBS(roadExitMsg, response);
					roadExitResponse := response.CMIF_1StopRoadExitResponse;
				endif;
				if not visit.myTerminal.is1STOPVBSConfigured then
					// create alert - 1-Stop VBS interface not configured
					self.doRaiseAlert(app.getErrorString(OneStop_VBS_not_configured));
				elseif not talkedTo1Stop or roadExitResponse = null then 
					// create alert - no response from 1-Stop VBS
					self.doRaiseAlert(app.getErrorString(OneStop_VBS_no_response));
				elseif roadExitResponse &lt;&gt; null and roadExitResponse.errorCode &lt;&gt; null then
					// cerate alert - 1-Stop VBS returned an error code
					self.doRaiseAlert(app.getErrorString1(OneStop_VBS_returned_error, roadExitResponse.errorCode &amp; Space &amp; roadExitResponse.errorDescription));
				endif;
			endif;
		endif;*/
		visit.do1StopRoadExit(); //07.02.2023 navmp20 TFS 56443
		// TFS 52268 end
	endif;
	
	if not found then // PAR 16188 if nothing to do needs message in GUI
		if self.myPrimaryActualLocation &lt;&gt; null then	// TFS 3337
		//	self.myPrimaryActualLocation := null;
			self.setMyPrimaryActualLocation(null,true);	//21 Nov 2017	NDL	TFS 7460
		endif;
		app.raiseCMWarning(Complete_road_exit, null, null, self); // PAR 16188
	endif;
	
epilog
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="set" id="feed75b4-1463-422a-8b38-e6d272972ccc">
        <updating/>
        <source>set(pRegNumber : String; pCarrier : CM_Carrier) updating;
// ---------------------------------------------------------------------------
// Created:     05 January 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 06/12/2016 cnwrh7	TFS	3032
// ---------------------------------------------------------------------------
vars
	vehicleController : CM_VehicleController;
begin

	//self.regNumber	:= pRegNumber												//-TFS3032
	self.regNumber	:= pRegNumber.removeTabCrLfs();		//+TFS3032
	// ccms1035 cnwjk3 
	//self.setCode(self.regNumber);
	self.setCode(self.regNumber &amp; self.state);
	self.carrier	:= pCarrier;
	if self.locationsController = null then
		create vehicleController persistent;
		self.locationsController := vehicleController;		//Also sets inverse 'vehicle'
	endif;
	
end;</source>
        <Parameter name="pRegNumber" type="String"/>
        <Parameter name="pCarrier" type="CM_Carrier"/>
    </JadeMethod>
    <JadeMethod name="setBatNumber" id="d83dc85e-fa06-4000-a6cf-7ff304977c7c">
        <updating/>
        <source>setBatNumber(pBatNumber : String) updating;
// ---------------------------------------------------------------------------
// Created:     19 January 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	self.batNumber := pBatNumber;

end;</source>
