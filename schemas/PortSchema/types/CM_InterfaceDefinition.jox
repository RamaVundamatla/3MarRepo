    <JadeMethod name="pxyCreateUpdateProxy" id="176cb41c-fd3d-4fb0-901a-607833f6715f">
        <source>pxyCreateUpdateProxy(): SelfType;
// --------------------------------------------------------------------------------
// Created:		04 September 2008 by cnwdad1
//
// Purpose:		Standard method to instantiate and return a proxy of the receiver.
//
// Parameters:	None
//
// Returns:		A reference to the transient proxy object.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy
// --------------------------------------------------------------------------------
vars
	proxyObj		: SelfType;
	translationObj	: CM_InterfaceTranslationTA;
	proxyTransObj	: CM_InterfaceTranslationTA;
	completedOK		: Boolean;
	
begin
	proxyObj	:=	inheritMethod();
	
	proxyObj.myLocale	:=	self.myLocale;
	proxyObj.myTerminal	:=	self.myTerminal;
	
	foreach translationObj in self.allInterfaceTranslationTAs do
		proxyTransObj	:=	translationObj.pxyCreateUpdateProxy();
		proxyTransObj.setInterfaceDefinition(proxyObj);
	endforeach;
	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return proxyObj;
	
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete proxyObj;
	endif;	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="f9aa1c61-5caf-466c-acda-3a0875f367c9">
        <updating/>
        <source>setForCreate(_proxyObj:SelfType) updating;
// --------------------------------------------------------------------------------
// Created:		04 September 2008 by cnwdad1
//
// Purpose:		Standard method that is invoked from a transaction when the receiver
//				is created.
//
// Parameters:	_proxyObj - A reference to a proxy of the receiver.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	// Set any non-key properties, and non-inverse references.
	
	// Set any key property values.
	
	// Set any inverse references.
	
	self.setForUpdate(_proxyObj);
end;</source>
        <Parameter name="_proxyObj" type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="645fd68e-0c3b-41ea-8b4d-71e26d7c2215">
        <updating/>
        <source>setForUpdate(_proxyObj:SelfType) updating;
// --------------------------------------------------------------------------------
// Created:		04 September 2008 by cnwdad1
//
// Purpose:		Standard method that is invoked from a transaction when the receiver
//				is created.
//
// Parameters:	_proxyObj - A reference to a proxy of the receiver.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	proxyTAObj			: CM_InterfaceTranslationTA;
	translationTAObj	: CM_InterfaceTranslationTA;
	
begin
	// Set any non-key properties, and non-inverse references.
	
	// Set any key property values.
	
	self.name		:=	_proxyObj.name;
	
	// Set any inverse references.
	
	self.myTerminal	:=	_proxyObj.myTerminal;
	self.myLocale	:=	_proxyObj.myLocale;
	
	// The following will automatically purge and re-populate the allInterfaceTranslations set.
	
	self.allInterfaceTranslationTAs.purge();
	
	foreach proxyTAObj in _proxyObj.allInterfaceTranslationTAs do
		create translationTAObj persistent;
		translationTAObj.setInterfaceDefinition(self);
		translationTAObj.setForCreate(proxyTAObj);
	endforeach;
end;</source>
        <Parameter name="_proxyObj" type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="ea750963-fd7e-497f-ade5-5d0dd0c437c0">
