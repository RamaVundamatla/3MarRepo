    <JadeMethod name="addActivity" id="87d8c224-852e-4804-8743-f5afd2286d54">
        <source>addActivity(pTheActivity : CnEcTActivity);

begin
	if self.allActivities.includes(pTheActivity) then
	else
		self.allActivities.add(pTheActivity);
	endif;
end;</source>
        <Parameter name="pTheActivity" type="CnEcTActivity"/>
    </JadeMethod>
    <JadeMethod name="clearActivities" id="2c0e737a-ebfb-43f9-a043-83a52ad41ee1">
        <source>clearActivities();

begin
	self.allActivities.clear();
end;</source>
    </JadeMethod>
    <JadeMethod name="clearActivity" id="3cea3af4-8322-4b96-9603-58192d65e50d">
        <source>clearActivity(pTheActivity : CnEcTActivity) : String;

vars
	index	: Integer;

begin
	if pTheActivity = null then
		return "Activity is null";
	endif;

	index := 1;
	
	while index &lt;= self.allActivities.size() do
		if pTheActivity = self.allActivities[index] then
			self.allActivities.remove(pTheActivity);
			break;
		endif;
		
		index := index + 1;
	endwhile;

	return "";
end;</source>
        <Parameter name="pTheActivity" type="CnEcTActivity"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getActivityByNumber" id="73373304-488b-403a-b32e-0dafd9cd69d5">
        <source>getActivityByNumber(pNumber : Integer) : CnEcTActivity;

vars
	activity	: CnEcTActivity;

begin
//	write( "looking for " &amp; number.String &amp; " of " &amp; activities.size.String );

	if pNumber &lt;= 0 or pNumber &gt; self.allActivities.size() then
		return null;
	endif;

	activity := self.allActivities[pNumber].CnEcTActivity;
	return activity;
end;</source>
        <Parameter name="pNumber" type="Integer"/>
        <ReturnType type="CnEcTActivity"/>
    </JadeMethod>
    <JadeMethod name="getName" id="5f58e5db-1f25-45e9-a9f6-cbb2f590a2ce">
        <source>getName(): String;

//	nextLessonName is stored in this form - do not change (or do the conversion!) 

begin
	return self.formName &amp; "/" &amp; self.name;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getNextActivity" id="be85046d-fd99-4402-a2c8-461d85a04e0b">
        <source>getNextActivity(pSequence : Integer io) : CnEcTActivity;

vars
	activity	: CnEcTActivity;

begin
	pSequence := pSequence + 1;
	activity := self.getActivityByNumber(pSequence);

	return activity;
end;</source>
        <Parameter name="pSequence" type="Integer" usage="io"/>
        <ReturnType type="CnEcTActivity"/>
    </JadeMethod>
    <JadeMethod name="initializeMe" id="d2dd7fc0-6aa4-430b-8ba0-4a9cb9e0bea3">
        <updating/>
        <source>initializeMe(	pName 				: String;
				pFormName 			: String;
				pNextLessonName 	: String;
				pText 				: String;
				pCheckControlEnabled: Boolean;
				pCheckControlValue 	: Boolean;
				pCheckControlVisible: Boolean;
				pControlHasAValue 	: Boolean;
				pControlIsEnabled 	: Boolean;
				pControlIsVisible 	: Boolean;
				pControlName 		: String;
				pLogDirectory 		: String	) updating;

// --------------------------------------------------------------------------------
// Created:		10 June 2000 by cnwsmc1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if app.myBaseRoot = null then
		CnEcBaseSchemaException.raise_(CNEC_X_12000, "BaseRoot is null or missing.");
	elseif pFormName = null or pName = null then
		CnEcBaseSchemaException.raise_(CNEC_X_12002, "The name of Form and/or Lesson cannot be null.");
	endif;

	// Set the property values...

	self.nextLessonName 		:= pNextLessonName;
	self.text					:= pText;
	self.checkControlEnabled 	:= pCheckControlEnabled;
	self.checkControlValue		:= pCheckControlValue;
	self.checkControlVisible	:= pCheckControlVisible;
	self.controlHasAValue		:= pControlHasAValue;
	self.controlIsEnabled		:= pControlIsEnabled;
	self.controlIsVisible		:= pControlIsVisible;
	self.controlName			:= pControlName;
	self.logDirectory 			:= pLogDirectory;

	// Now set any key property values...

	self.formName				:= pFormName;
	self.name					:= pName;

	// Last, set any references...

	self.myBaseRoot				:= app.myBaseRoot;
end;</source>
        <Parameter name="pName" type="String"/>
        <Parameter name="pFormName" type="String"/>
        <Parameter name="pNextLessonName" type="String"/>
        <Parameter name="pText" type="String"/>
        <Parameter name="pCheckControlEnabled" type="Boolean"/>
        <Parameter name="pCheckControlValue" type="Boolean"/>
        <Parameter name="pCheckControlVisible" type="Boolean"/>
        <Parameter name="pControlHasAValue" type="Boolean"/>
        <Parameter name="pControlIsEnabled" type="Boolean"/>
        <Parameter name="pControlIsVisible" type="Boolean"/>
        <Parameter name="pControlName" type="String"/>
        <Parameter name="pLogDirectory" type="String"/>
    </JadeMethod>
    <JadeMethod name="readFromFile" id="ea3d1d10-fd5c-4e6f-a695-18d9b912feef">
        <updating/>
        <source>readFromFile(pTheFile : File io; pInStr : String) : String updating;

vars
	fullLine		: String;
	chunk			: String;
	error			: String;
	activityCount	: Integer;
	index			: Integer;
	activity		: CnEcTActivity;

begin
	fullLine := pInStr;

	chunk := "";
	
	while chunk &lt;&gt; self.LESSON_FLAG do
		chunk := self.getNextChunk(fullLine);

		if chunk = self.EOF or pTheFile.endOfFile() then	// end of file
			return "";
		endif;

		if chunk &lt;&gt; self.LESSON_FLAG then
			fullLine := pTheFile.readLine;
		endif;
	endwhile;

//	name, formName, nextLessonName, controlName, logDirectoryName, checkControl, checkVisible, isVisible, checkValue, hasValue, activities
//	text
//	activities...


	error	:=	update(	self.getNextChunk(fullLine),		// name
						self.getNextChunk(fullLine),		// formName
						self.getNextChunk(fullLine),		// nextLessonName
						self.getNextChunk(fullLine),		// controlName
						self.getNextChunk(fullLine),		// logDirectoryName
						self.isNextChunk(fullLine, "check enabled"), self.isNextChunk(fullLine, "is enabled"),	// checkEnabled
						self.isNextChunk(fullLine, "check visible"), self.isNextChunk(fullLine, "is visible"),	// checkVisible
						self.isNextChunk(fullLine, "check value"), self.isNextChunk(fullLine, "has a value"));	// checkValue

	activityCount := self.getNextChunk(fullLine).Integer;

	fullLine := pTheFile.readLine;
	self.addError(error, updateText(self.doReplaceCrLf(fullLine)));

	foreach index in 1 to activityCount do
		fullLine	:=	pTheFile.readLine();

		create activity;
		
		self.addError(error, activity.readFromFile(pTheFile, self, fullLine));
	endforeach;

	return error;
end;</source>
        <Parameter name="pTheFile" type="File" usage="io"/>
        <Parameter name="pInStr" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="removeActivities" id="fe63dbc0-fcd1-4f06-aee7-94d55ff09fe0">
        <source>removeActivities();

vars
	activity	: CnEcTActivity;
	theObject	: Object;

begin
	foreach theObject in self.allActivities do
		activity := theObject.CnEcTActivity;
		
		if activity &lt;&gt; null then
			delete activity;
		endif;
	endforeach;
	
	self.clearActivities();
end;</source>
    </JadeMethod>
    <JadeMethod name="update" id="e91d6f4f-ca57-4b94-a8a6-58d0e5f9543a">
        <updating/>
        <source>update( pName:String;
		pForm:String;
		pNextLessonName:String;
		pStartControl:String;
		pDirectory:String;
		pIsCheckEnabled:Boolean;
		pIsEnabled:Boolean;
		pIsCheckVisible:Boolean;
		pIsVisible:Boolean;
		pIsCheckValue:Boolean;
		pHasAValue:Boolean) : String updating;

vars
	lesson	: CnEcTLesson;

begin
	name				:=	pName.trimBlanks;
	formName			:=	pForm.trimBlanks;
	nextLessonName		:=	pNextLessonName.trimBlanks;
	logDirectory		:=	pDirectory.trimBlanks;
	controlName			:=	pStartControl.trimBlanks;
	checkControlEnabled	:=	pIsCheckEnabled;
	controlIsEnabled	:=	pIsEnabled;
	checkControlVisible	:=	pIsCheckVisible;
	controlIsVisible	:=	pIsVisible;
	checkControlValue	:=	pIsCheckValue;
	controlHasAValue	:=	pHasAValue;
	myBaseRoot			:=	app.myBaseRoot;

	if name.length &gt; 40 then
		return "Update Lesson: name too long '" &amp; pName &amp; "'" ;
	elseif name.length &lt;= 0 then
		return "Update Lesson: name not defined";
	endif;
	if formName.length &lt;= 0 then
		return "Update Lesson: form not defined for " &amp; name;
	endif;

	foreach lesson in CnEcTLesson.instances do
		if (lesson.getName = formName &amp; "/" &amp; name) and (lesson &lt;&gt; self) then
			return "Update Lesson: lesson '" &amp; lesson.getName &amp; "' already exists";
		endif;
	endforeach;

	if controlName.length = 0 then
		if checkControlVisible or checkControlEnabled or checkControlValue then
			return "Update Lesson: form set checking is enabled, but no control is specified";
		endif;
	else
		if not (checkControlVisible or checkControlEnabled or checkControlValue) then
			return "Update Lesson: no form set up checking is specified for " &amp; controlName;
		endif;
	endif;

	return "";
end;</source>
        <Parameter name="pName" type="String"/>
        <Parameter name="pForm" type="String"/>
        <Parameter name="pNextLessonName" type="String"/>
        <Parameter name="pStartControl" type="String"/>
        <Parameter name="pDirectory" type="String"/>
        <Parameter name="pIsCheckEnabled" type="Boolean"/>
        <Parameter name="pIsEnabled" type="Boolean"/>
        <Parameter name="pIsCheckVisible" type="Boolean"/>
        <Parameter name="pIsVisible" type="Boolean"/>
        <Parameter name="pIsCheckValue" type="Boolean"/>
        <Parameter name="pHasAValue" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="updateMe" id="ccaf6082-28ab-4fd8-b612-48b11999610b">
        <updating/>
        <source>updateMe(	pName 				: String;
			pFormName 			: String;
			pNextLessonName 	: String;
			pText 				: String;
			pCheckControlEnabled: Boolean;
			pCheckControlValue 	: Boolean;
			pCheckControlVisible: Boolean;
			pControlHasAValue 	: Boolean;
			pControlIsEnabled 	: Boolean;
			pControlIsVisible 	: Boolean;
			pControlName 		: String;
			pLogDirectory 		: String) updating;

// --------------------------------------------------------------------------------
// Created:		08 June 2000 by cnwsmc1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	// Set the property values...

	self.nextLessonName 		:= pNextLessonName;
	self.text					:= pText;
	self.checkControlEnabled 	:= pCheckControlEnabled;
	self.checkControlValue		:= pCheckControlValue;
	self.checkControlVisible	:= pCheckControlVisible;
	self.controlHasAValue		:= pControlHasAValue;
	self.controlIsEnabled		:= pControlIsEnabled;
	self.controlIsVisible		:= pControlIsVisible;
	self.controlName			:= pControlName;
	self.logDirectory 			:= pLogDirectory;

	// Now set any key property values...

	self.formName				:= pFormName;
	self.name					:= pName;

	// Last, set any references...

	self.myBaseRoot				:= app.myBaseRoot;
end;</source>
        <Parameter name="pName" type="String"/>
        <Parameter name="pFormName" type="String"/>
        <Parameter name="pNextLessonName" type="String"/>
        <Parameter name="pText" type="String"/>
        <Parameter name="pCheckControlEnabled" type="Boolean"/>
        <Parameter name="pCheckControlValue" type="Boolean"/>
        <Parameter name="pCheckControlVisible" type="Boolean"/>
        <Parameter name="pControlHasAValue" type="Boolean"/>
        <Parameter name="pControlIsEnabled" type="Boolean"/>
        <Parameter name="pControlIsVisible" type="Boolean"/>
        <Parameter name="pControlName" type="String"/>
        <Parameter name="pLogDirectory" type="String"/>
    </JadeMethod>
    <JadeMethod name="updateText" id="ebb89ef1-f520-4f71-bfd9-904e7e0d6b06">
        <updating/>
        <source>updateText(pText : String) : String updating;

begin
	self.text := pText.trimBlanks();
	
	if self.text.length() &lt;= 0 then
		return "Update Lesson: lesson outline not defined for " &amp; name;
	endif;
	
	return "";
end;</source>
        <Parameter name="pText" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="writeToFile" id="4ba142c5-5a8b-4848-bb7b-2677eea49d79">
        <updating/>
        <source>writeToFile(pTheFile:File io) updating;

//	name, formName, nextLessonName, controlName, logDirectoryName, checkEnabled, isEnabled, checkVisible, isVisible, checkValue, hasValue, activities
//	text
//	activities...

vars
	object	: Object;
	outputLine	: String;

begin
	outputLine	:=	self.LESSON_FLAG &amp; Tab &amp;
					self.name &amp; Tab &amp;
					self.formName &amp; Tab &amp;
					self.nextLessonName &amp; Tab &amp;
					self.controlName &amp; Tab &amp;
					self.logDirectory &amp; Tab;

	if self.checkControlEnabled then
		outputLine := outputLine &amp; "check enabled" &amp; Tab;
	else
		outputLine := outputLine &amp; "no check for enabled" &amp; Tab;
	endif;

	if self.controlIsEnabled then
		outputLine := outputLine &amp; "is enabled" &amp; Tab;
	else
		outputLine := outputLine &amp; "not enabled" &amp; Tab;
	endif;

	if self.checkControlVisible then
		outputLine := outputLine &amp; "check visible" &amp; Tab;
	else
		outputLine := outputLine &amp; "not check for visible" &amp; Tab;
	endif;

	if self.controlIsVisible then
		outputLine := outputLine &amp; "is visible" &amp; Tab;
	else
		outputLine := outputLine &amp; "not visible" &amp; Tab;
	endif;

	if self.checkControlValue then
		outputLine := outputLine &amp; "check value" &amp; Tab;
	else
		outputLine := outputLine &amp; "not check for value" &amp; Tab;
	endif;

	if self.controlHasAValue then
		outputLine := outputLine &amp; "has a value" &amp; Tab;
	else
		outputLine := outputLine &amp; "has no value" &amp; Tab;
	endif;

	outputLine := outputLine &amp; self.allActivities.size().String;

	pTheFile.writeLine(outputLine);
	self.text.cnEcRemoveCrLf();
	pTheFile.writeLine(self.text);

	foreach object in self.allActivities do
		object.CnEcTActivity.writeToFile(pTheFile);
	endforeach;
end;</source>
        <Parameter name="pTheFile" type="File" usage="io"/>
    </JadeMethod>
</Class>
