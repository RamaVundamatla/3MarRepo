    <JadeMethod name="createEmptyPeer" id="6582c91b-b4b1-4c55-af5b-4204ac103163">
        <updating/>
        <source>createEmptyPeer(_parent: SOP_ViewModelObject) updating;
// -----------------------------------------------------------------------------
// Created:		30 April 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
vars
	proxyLogLength: CM_LogLength;
begin
	create proxyLogLength transient;
	proxyLogLength.setProxy(null, null, false, _parent.myObject.CM_CodeGroupLogSpecs);
	self.myObject := proxyLogLength;	
	self.myParent := _parent;
end;</source>
        <Parameter name="_parent" type="SOP_ViewModelObject"/>
