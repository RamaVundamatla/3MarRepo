    <JadeMethod name="refreshYardAllocationLines" id="80c689e8-58ff-47f0-ae01-6cc0c8eb2fcb">
        <updating/>
        <source>refreshYardAllocationLines() updating;

/*

Purpose:			Re-draw Yard Allocation lines

Parameters:			

Return Value:		


Date				Who		Reason
12 November 2008	consw1	SWF1030 - Initial creation

*/

vars
	obj 		: Object;
	iter 		: Iterator;
	newHeight	: Integer;
	oldHeight	: Integer;
	x1, x2		: Integer;
	y1, y2 		: Integer;
	
begin

	//  Remove old Yard Allocation lines

	iter := self.allGridObjects.createIterator();

	while iter.next(obj) do
		self.allGridObjects.getIteratorKeys(x1, y1, x2, y2, iter);
		if obj.isKindOf(CM_YardAllocation) then
			self.myDrawingFrame.drawWidth := y2 - y1;
			self.myDrawingFrame.drawLine( x1, y1, x2, y1, self.myDrawingFrame.backColor );
			self.allGridObjects.removeKeyEntry(x1, y1, x2, y2, obj);
		endif;
	endwhile;
	
	delete iter;

	//  Draw new Yard Allocation lines
	
	iter := self.allYARows.createIterator();
	
	while iter.next(obj) do
		self.allYARows.getIteratorKeys(x1, y1, x2, y2, iter);
		self.allYARows.removeKeyEntry(x1, y1, x2, y2, obj);
		oldHeight := y2 - y1;
		newHeight := self.drawYardAllocationLinesForRow( obj.CM_GridObject, y1, oldHeight );
		if newHeight &gt; oldHeight then
			self.drawSelf(true);
			break;
		endif;
	endwhile;
	
epilog
	delete iter;
end;</source>
    </JadeMethod>
    <JadeMethod name="removeObjectFromDict" id="1c4be489-3936-4627-9d5c-0fafb4c85c7d">
        <updating/>
        <source>removeObjectFromDict(_obj : Object) : Boolean updating;
// ---------------------------------------------------------------------------
// Created:     January 2009 ANDREW BISHOP
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
// 11 Jan 2011		cnwkpd1			PAR #26678 - Tidy up transient leaks
// ---------------------------------------------------------------------------

vars
	tmpObj		: Object;
	x1, y1,
	x2, y2		: Integer;
	tmpIterator	: Iterator;
begin
	tmpIterator := self.allGridObjects.createIterator;
	
	tmpIterator.startAtObject(_obj);
	
	while tmpIterator.next(tmpObj) do
		self.allGridObjects.getIteratorKeys(x1, y1, x2, y2, tmpIterator);
		self.allGridObjects.removeKeyEntry(x1, y1, x2, y2, tmpObj);
		return true;
	endwhile;

	return false;

epilog
	delete tmpIterator;		// PAR #26678
	
end;</source>
        <Parameter name="_obj" type="Object"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
