    <JadeMethod name="getNumberOfTasks" id="92aad435-c5e7-489f-a50b-8ae5dc1512bf">
        <source>getNumberOfTasks(): Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
18 July 2024	navcs2	ChangeRequest 63797: EUP | CAMS Search for outgoing messages - CAMS Message Enquiry

*/

vars
	count	: Integer;
	prot	: CM_CamProtocol;
begin
	foreach prot in self.allFilterCamProtocols do
		count := count + prot.taskHistoryByProtocolSeq.size;
	endforeach;
	
	return count;
