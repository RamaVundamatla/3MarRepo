    <JadeMethod name="doBuildMnuTasksAdd" id="0e0462fc-bccc-4ef3-9fed-52aacd750697">
        <updating/>
        <source>doBuildMnuTasksAdd(_menuMaster: MenuItem io; _theTI : CM_TIMaster input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 September 2008	cnwrd1	Initial creation

*/

// ---------------------------------------------------------------------------
// Created:		August 2003 By Jason Chapman
// ---------------------------------------------------------------------------
vars
	task				: CM_ToDoTaskDesc;
	taskDesc			: CM_ToDoTaskDesc;
	mnuChild,mnuMaster	: MenuItem;	
	itemEnabled			: Boolean;
	taskDict		: CM_ToDoTaskDescByCode;
	idx : Integer;

begin
	// ##############################################
	// Build up menu of ToDo Tasks that can be set
	
	idx := 2;
	while true do
		mnuChild := self.mnuAddTaskSub.getMenuItem(idx);
		if mnuChild = null then
			//break; // cnwrd1 par 18399 13.3.09
		endif;
		delete mnuChild;
		idx := idx + 1;
		
		if idx = 100 then break; endif;// cnwrd1 par 18399 13.3.09
	endwhile;
	
	
	create taskDict transient;
	
	app.myPassport.myUser.getToDoTasksSys(  app.myRoot.allCargoTypesById[_theTI.cargoType], taskDict);
	
	if taskDict.isEmpty then
		_menuMaster.visible := false;
		return;
	endif;
		

	mnuMaster := _menuMaster;
	mnuMaster.visible := true;
	mnuMaster.enabled := true;
	mnuMaster.caption := "Add Tasks";

	self.mnuAddTaskSub.visible := false;
	//self.mnuAddTaskSub.caption := "No Tasks";


	idx := 1;
	foreach taskDesc in taskDict do
		idx := idx+1;	
		itemEnabled := true;
		
		foreach task in _theTI.allToDoTaskDesc do
			if task = taskDesc then
				itemEnabled := false;
			endif;
		endforeach;

		if taskDesc.description = null then 
			itemEnabled := false;
		endif;
		
		// DVB added to screen for cargo type.
		if itemEnabled and not taskDesc.isAvailableForCargoType(_theTI.cargoType) then
			continue;
		endif;
		
		// Par 18032. Jan 2009
		if itemEnabled and not taskDesc.isValidForGenSet( _theTI ) then	
			if _theTI.isKindOf(CM_TIMasterContainer) and not _theTI.canHaveGeneratorAttached() then
				continue;	// for non-reefer iso type hiding menu item Attach/Detach Generator
			else
				itemEnabled := false;
			endif;
		endif;
		
		//keep cloning until all tasks represented
		mnuChild := self.mnuAddTaskSub.getMenuItem(idx);
		if mnuChild = null then
			mnuChild := self.mnuAddTaskSub.loadMenu(idx); // Clone menu	
			mnuChild.caption := taskDesc.description;
			mnuChild.visible := true;
			mnuChild.enabled := itemEnabled;
			mnuChild.helpKeyword := taskDesc.description;
			mnuChild.userObject := taskDesc;
		
		endif;
	endforeach;
	
epilog
	delete taskDict;
end;</source>
        <Parameter name="_menuMaster" type="MenuItem" usage="io"/>
        <Parameter name="_theTI" type="CM_TIMaster" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doBuildMnuTasksRemove" id="981c129f-e7f1-4dab-8b60-62c4ab771d23">
        <updating/>
        <source>doBuildMnuTasksRemove(_menuMaster: MenuItem input; _theTI : CM_TIMaster input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 September 2008	cnwrd1	Initial creation

*/


//----------------------------------------------------------------
//	Created:	11 August 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------

vars
	task				: CM_ToDoTaskDesc;
	taskDesc			: CM_ToDoTaskDesc;
	tmpMenu,
	mnuChild,mnuMaster	: MenuItem;
	mnuIndex			: Integer;
	itemEnabled			: Boolean;
	lTI					: CM_TrackedItem;
	taskDict		: CM_ToDoTaskDescByCode;
	idx : Integer;
begin

	idx := 2;
	while true do
		mnuChild := self.mnuRemoveTasksSub.getMenuItem(idx);
		if mnuChild = null then
		//	break;
		endif;
		delete mnuChild;
		idx := idx + 1;
		
		if idx = 100 then break; endif;// cnwrd1 par 18399 13.3.09
	endwhile;
	
	// ##############################################
	// Build up menu of ToDo Tasks that have been set, but are uncomplete
	
	create taskDict transient;

	app.myPassport.myUser.getToDoTasksSys(  app.myRoot.allCargoTypesById[_theTI.cargoType], taskDict);
	
	if taskDict.isEmpty then
		_menuMaster.visible := false;
		return;
	endif;

	mnuMaster := _menuMaster;//self.mnuCargoTaskComplete;
	mnuMaster.visible := true;
	mnuMaster.enabled := true;
	mnuMaster.caption := "Remove Tasks";
	self.mnuRemoveTasksSub.visible := false;
	self.mnuRemoveTasksSub.caption := "No Tasks";
	
	tmpMenu := self.mnuRemoveTasksSub;

	//show todos that can be completed
	idx := 1;
	foreach taskDesc in taskDict do
		idx := idx + 1;
		itemEnabled := false;
		
		if taskDesc.isForGenSetAttachDetach() and not _theTI.canHaveGeneratorAttached() then	//Par18032 Jan 2009. Attach/Detach GenSet should be visible only for reefers and trailers
			continue;	// hide the menu item 
				
		else
			foreach task in _theTI.allToDoTaskDesc do
				if task = taskDesc then
					itemEnabled := true;
				endif;
			endforeach;

		endif;
		
		//keep cloning until all tasks represented
		
		mnuChild := self.mnuRemoveTasksSub.getMenuItem(idx);
		if mnuChild = null then		
			mnuChild := self.mnuRemoveTasksSub.loadMenu(idx); //self.cloneMenu(mnuMaster, tmpMenu, true); 
			mnuChild.caption := taskDesc.description;
			mnuChild.visible := true;
			mnuChild.enabled := itemEnabled;
			mnuChild.helpKeyword := taskDesc.description;
			mnuChild.userObject := taskDesc;
		endif;
	endforeach;
epilog
	delete taskDict;
end;</source>
        <Parameter name="_menuMaster" type="MenuItem" usage="input"/>
        <Parameter name="_theTI" type="CM_TIMaster" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doBuildMnuViewTis" id="34aab0e0-f4d5-4612-bb54-bde3bca7f39b">
        <source>doBuildMnuViewTis();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 November 2008	cnwrd1	Initial creation

*/

vars
	tmpTi 	: CM_TrackedItem;
	loc		: CM_LocationsController;
	canView : Boolean;
	showView : Boolean;
begin

	showView := false;
	
	if self.doBuildMnuViewTisUserTerms() then
		showView := true;
	endif;
		
		
	tmpTi := self.myCurrentTiMaster.getCurrentTi();

	if tmpTi = null then
	// no current , no history
		self.mnuShowAll.visible := false;
		self.mnuShowOnSite.visible := false;
	else
		//have at least one
		//	self.mnuShowAll.visible := true;
	
		
		//is it on site?
		loc := tmpTi.myPrimaryActualLocation;
		
		canView := app.myPassport.myUser.getUserTerminal(tmpTi.myTerminal) &lt;&gt; null;
	
		if loc &lt;&gt; null and canView then
			showView := true;
			self.mnuShowOnSite.visible := true;
			self.mnuShowOnSite.caption := 'On Site (' &amp; tmpTi.myTerminal.name &amp; ')';
		else
			self.mnuShowOnSite.visible := false;
			//self.mnuShowOnSite.userObject
		endif;
		
	endif;
	

	self.mnuShowReal.visible := showView;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doBuildMnuViewTisUserForTerm" id="1597aa4a-bcd9-44de-84b7-1a96440f1a0d">
        <source>doBuildMnuViewTisUserForTerm( _terminal : CM_Terminal ; _count : Integer ; _menuIdx : Integer);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 December 2008	cnwrd1	Initial creation

*/

vars
	idx 		: Integer;
	mnuChild	: MenuItem;	
begin


		mnuChild := self.mnuShowAll.getMenuItem(_menuIdx);
		if mnuChild = null then
			mnuChild := self.mnuShowAll.loadMenu(_menuIdx); // Clone menu	
		endif;
			mnuChild.caption := 'Terminal ' &amp; _terminal.name &amp; ' (' &amp; _count.String &amp; ')';
			mnuChild.visible := true;
			mnuChild.enabled := true;
			//mnuChild.helpKeyword := taskDesc.description;
			mnuChild.userObject := _terminal;		
		

epilog

end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_count" type="Integer"/>
        <Parameter name="_menuIdx" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doBuildMnuViewTisUserTerms" id="ef6f8223-91c2-44b3-8c9d-3c75fc458d2f">
        <source>doBuildMnuViewTisUserTerms() : Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 December 2008	cnwrd1	Initial creation

*/

vars
	user 					: CM_User;
	userTermDict 			: CM_UserTerminalByTerminalDict;
	ut						: CM_UserTerminal;
	tiCount					: Integer;
	iter					: Iterator;
	ti						: CM_TrackedItem;
	idx 					: Integer;
	mnuChild				: MenuItem;	
	result 					: Boolean;
begin
	
	result := false;
	
	
	idx := 2;
	while true do
		mnuChild := self.mnuShowAll.getMenuItem(idx);
		if mnuChild = null then
			break;
		endif;
		delete mnuChild;
		idx := idx + 1;
	endwhile;

	idx := 2 ;
	
	self.mnuShowAll.visible := false;
		
	// something to step though the ti's
	iter :=	self.myCurrentTiMaster.allTis.createIterator;

		userTermDict := app.myPassport.myUser.allUserTerminals;
		foreach ut in userTermDict do
		//step through all the user terminals
			tiCount := 0;			
			
			iter.reset();
			
			while iter.next(ti) do
				if ti.myTerminal = ut.myTerminal then
				// we have one
				tiCount := tiCount +1;
				endif;
			endwhile;
			
			if tiCount &gt; 0 then
				//we have some for this terminal so build the menu
				self.doBuildMnuViewTisUserForTerm(ut.myTerminal, tiCount, idx ) ;
				result := true;
				idx := idx + 1;
			endif;
		
		endforeach;
		
		return result;
epilog
	delete iter;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doCargoTypeChange" id="f011b023-5f34-41b3-a2b3-affcaba6d528">
        <updating/>
        <source>doCargoTypeChange() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 September 2008	cnwrd1	Initial creation
15/05/2025	navcs2	MTN-34843  Development - Fleet file Form implementation
*/

vars

begin
	self.setCargoType( self.cmbFleetItemType.listIndex  );
	
	self.initTblData();	
	self.setSearchType();
	
	if self.isWagonMaster() then	// 03 Jul 2009	NDL	CCMS 1067
		self.setCaption( app.getErrorString(Wagon_master) &amp; " " &amp; app.getErrorString(Maintenance) );
	elseif self.isTILC() then
		self.setCaption(app.getErrorString(Trailer) &amp; " " &amp; app.getErrorString(Maintenance));
	elseif self.isGenerator() then
		self.setCaption(app.getErrorString(CM_Generator_GC) &amp; " " &amp; app.getErrorString(Maintenance));
	elseif self.isMAFI() then																			// 15/05/2025	navcs2	MTN-34843
		self.setCaption(app.getErrorString(Mafi) &amp; " " &amp; app.getErrorString(Maintenance));				// 15/05/2025	navcs2	MTN-34843
	else
		self.setCaption(app.getErrorString(ISO_Container) &amp; " " &amp; app.getErrorString(Maintenance));
	endif;
	self.setNavigatorHeading(self.caption);
	
	self.setStatusCaption();

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doClonedMenuClickSpecial" id="edb05a17-2901-4668-b492-faec89cf98fc">
        <updating/>
        <source>doClonedMenuClickSpecial(menuItem: MenuItem input) updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date				Who		Reason
10 September 2008	cnwrd1	Initial creation
17/06/2010			cnwcs5	par 24342 - no context menu for stops
*/

vars
	obj	: Object;
begin
	//We need to be a TrackedItem to go through here as opposed to a CM_BOL object.
	obj := menuItem.userObject;
	/*
	if not self.isMyCurrentObjectTrackedItem and 
	   not CM_StopsTable.hasInstance(obj) then //ccms 1017 cnwrs1 Aug 2007
		app.raiseCMException1(ERR_Item_Not_TrackedItem, self.myCurrentObject.getName, null, null);
	endif;
	*/
	
	//if menuItem.helpKeyword = "LOAD" or menuItem.helpKeyword = "DISCHARGE" or menuItem.helpKeyword = "QUEUE" then
	//	self.doMnuUnplanClick(menuItem);
		
/* par 24342
	if CM_StopsTable.hasInstance(obj) then
			self.doMnuTiMastStopsClick(obj.CM_StopsTable, menuItem);
		return;
	else */
	if CM_ToDoTaskDesc.hasInstance(obj) then
		if self.todoTaskMode = TASK_MODE_ADD then
			self.doMenuTaskAddClick(obj.CM_ToDoTaskDesc);
		elseif self.todoTaskMode = TASK_MODE_REMOVE then
			self.doMenuTaskRemoveClick(obj.CM_ToDoTaskDesc);
		else
			app.raiseUnexpectedProgramError(class.name, method.name, 'invalid todoTaskMode');
		endif;
		return;	
	endif;

	
	inheritMethod(menuItem);
	

epilog

end;</source>
        <access>protected</access>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doDelete" id="1ee0bd98-ad63-45dd-9a77-7f8077dbbd84">
        <updating/>
        <source>doDelete()updating;
//--------------------------------------------------
// Created:	13 April 2005 By: cnwgd1
//--------------------------------------------------
vars

	result			: Integer;
	msgStr			: String;
	selectedObj 	: CM_Object;
	objectArray		: CM_ObjectArrayActual;
	
begin

	if self.tblData.allSelectedObjects.size &gt; 1 then
	   	msgStr := app.getErrorString2(ConfirmDelete, app.getErrorString(TheSelected), 'Master Items');
	elseif self.myCurrentWagonMaster &lt;&gt; null then	// 06 Jul 2009	NDL	CCMS 1067
		selectedObj := self.myCurrentWagonMaster;
		msgStr := app.getErrorString2(ConfirmDelete, app.getErrorString(TheSelected), app.getErrorString(Wagon_master) &amp; ' ' &amp; self.myCurrentWagonMaster.id);
	elseif self.myCurrentTiMaster &lt;&gt; null then
		selectedObj := self.myCurrentTiMaster;
		msgStr := app.getErrorString2(ConfirmDelete, app.getErrorString(TheSelected), 'Master Item ' &amp; self.myCurrentTiMaster.id);
	else
		app.msgBox(app.getErrorString(Please_Select_An_Item_Fiirst), self.caption, MsgBox_OK_Only+MsgBox_Stop_Icon);
		return;	
	endif;

	if app.msgBox(msgStr, self.caption, MsgBox_Yes_No + MsgBox_Question_Mark_Icon + MsgBox_Default_Second) = MsgBox_Return_No then
		return;
	endif;
	
	
	while true do
		if selectedObj &lt;&gt; null then
		  	app.myTrxDA.trxDeleteCMObject(selectedObj, app.myPassport);
		else
			create objectArray transient;
			self.tblData.allSelectedObjects.copy(objectArray);
		  	app.myTrxDA.trxDeleteCMObjects(objectArray, app.myPassport);	
		endif;		  	  
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			self.doRefresh();
			break;
		else
			result := app.showErrorWarningDialog(self.caption, app.myPassport, ErrWarnMode_Delete + ErrWarnMode_CanAckWarnings);
			if result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
	
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
		endif;
		break;
	endwhile;	

epilog
	delete objectArray;
end;</source>
    </JadeMethod>
    <JadeMethod name="doMenuTaskAddClick" id="7c2ee7bb-ae83-436b-9147-c148a440be90">
        <updating/>
        <source>doMenuTaskAddClick(_taskDesc: CM_ToDoTaskDesc) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 September 2008	cnwrd1	Initial creation

*/

vars
	ti				: CM_TIMaster;
	tiSet			: CM_TIMasterSet;
	obj				: Object;
	result			: Integer;
begin

	ti := self.myCurrentTiMaster.CM_TIMaster;
	// get all selected cargo items to add or remove stop from all.
	create tiSet transient;
	foreach obj in self.tblData.allSelectedObjects do
		if CM_TIMaster.hasInstance(obj) then
			tiSet.add(obj.CM_TIMaster);
		endif;
	endforeach;
	
	if (not tiSet.includes(ti)) then
		tiSet.add(ti);
	endif;
	
	while true do
		app.myTrxUA.trxUpdateTIMastToDoTaskAddBulk(_taskDesc, tiSet, app.myPassport);
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			if self.ackTodoStop then
				app.msgBox('Task ' &amp; _taskDesc.description &amp; ' added to ' &amp; tiSet.size.String &amp; ' item(s).', 'Info', MsgBox_OK_Only + MsgBox_Information_Icon);
			endif;
			break;
		else
			result := app.showErrorWarningDialog('Add Todo Task', app.myPassport, ErrWarnMode_Add + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				// there must have just been warnings that the user has acknowledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
		endif;
		
		break;
	endwhile;

epilog
	delete tiSet;
end;</source>
        <Parameter name="_taskDesc" type="CM_ToDoTaskDesc"/>
    </JadeMethod>
    <JadeMethod name="doMenuTaskRemoveClick" id="91bd4932-7bd1-4363-8db6-03f3ec0097a8">
        <updating/>
        <source>doMenuTaskRemoveClick(_taskDesc: CM_ToDoTaskDesc) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 September 2008	cnwrd1	Initial creation

*/


vars
	ti				: CM_TIMaster;
	tiSet			: CM_TIMasterSet;
	obj				: Object;
	result			: Integer;
begin
	
	ti := self.myCurrentTiMaster.CM_TIMaster;
	// get all selected cargo items to add or remove stop from all.
	create tiSet transient;
	foreach obj in self.tblData.allSelectedObjects do
		if CM_TIMaster.hasInstance(obj) then
			tiSet.add(obj.CM_TIMaster);
		endif;
	endforeach;
	
	if (not tiSet.includes(ti)) then
		tiSet.add(ti);
	endif;

	//result := app.msgBox(app.getErrorString(TaskRemoveConfirm), app.getErrorString(Remove_Task), MsgBox_Yes_No + MsgBox_Question_Mark_Icon);
	result := app.msgBox('Are you sure you want to remove task ' &amp;
			_taskDesc.description &amp; ' from ' &amp; tiSet.size.String &amp; ' item(s)?', 
			app.getErrorString(Remove_Task), MsgBox_Yes_No + MsgBox_Question_Mark_Icon);
	
	if result = MsgBox_Return_No then
		return;
	endif;

	while true do
		app.myTrxUA.trxUpdateTIMastToDoTaskRemBulk(_taskDesc, tiSet, app.myPassport);
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			if self.ackTodoStop then
				app.msgBox('Task ' &amp; _taskDesc.description &amp; ' removed from ' &amp; tiSet.size.String &amp; ' item(s).', 'Info', MsgBox_OK_Only + MsgBox_Information_Icon);
			endif;
			break;
		else
			result := app.showErrorWarningDialog('Remove Todo Task', app.myPassport, ErrWarnMode_Add + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				// there must have just been warnings that the user has acknowledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
		endif;
		
		break;
	endwhile;


epilog
	delete tiSet;
end;</source>
        <Parameter name="_taskDesc" type="CM_ToDoTaskDesc"/>
    </JadeMethod>
