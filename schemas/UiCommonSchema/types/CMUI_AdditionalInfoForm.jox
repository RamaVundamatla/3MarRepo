    <JadeMethod name="tblExtraInfo_contextMenu" id="4d6df38e-0753-4fca-922f-d8b952ca9ce0">
        <controlMethod name="Table::contextMenu"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblExtraInfo_contextMenu(table: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating;
//--------------------------------------------------
// Created:	04 January 2006 By: cnwgd1
//--------------------------------------------------
vars
	xLeft 	: Real;
	yTop	: Real;
begin

	xLeft := x;
	yTop := y;

	conwin.windowToScreen(xLeft, yTop);
	self.screenToWindow(xLeft, yTop);   // convert x, y relative to form

	
	self.popupMenu(self.mnuTblContext, xLeft.Integer, yTop.Integer);

	return false;
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="36a83933-36c6-4d5e-849d-98dea6fbb9fd">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0007247, locale);
	lblNoDetails.translateCaption(Xlat_0000034, locale);
	mnuColEight.translateCaption(Xlat_0007248, locale);
	mnuColFour.translateCaption(Xlat_0007249, locale);
	mnuColSix.translateCaption(Xlat_0007250, locale);
	mnuColTen.translateCaption(Xlat_0007251, locale);
	mnuColTwo.translateCaption(Xlat_0007252, locale);
	mnuColumns.translateCaption(Xlat_0007253, locale);
	mnuTblContext.translateCaption(Xlat_0007254, locale);
end;</source>
    </JadeMethod>
    <JadeMethod name="unload" id="c22a918e-1673-40c9-a8e1-9a8864db24d0">
        <controlMethod name="Form::unload"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>unload() updating;
//--------------------------------------------------
// Created:	16 December 2005 By: cnwgd1
//--------------------------------------------------
vars
	realUserWindow : CM_UserWindowForOpen;
begin
	delete self.myDataContainer;
	inheritMethod();
	
	realUserWindow := app.getUserWindow(self.name, false);
end;</source>
    </JadeMethod>
