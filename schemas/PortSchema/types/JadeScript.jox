    <JadeMethod name="keaGetMovements" id="a41e7706-c014-47dc-ab09-b5eb1ed370d5">
        <source>keaGetMovements();
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 June 2012	cnwdw1	Initial creation
*/
vars
	agent: CM_KEAAgent;
	movements: CM_KPIMovementDtlArray;
	movement: CM_KPIMovementDtl;
	leg: CM_KPIMovementLegDtl;
	message: String;
	errorCount: Integer;
	lastTarget: String;
	errorList: StringArray;
	from, too: TimeStamp;
	terminal: CM_Terminal;
	txn: CM_Transaction;
begin
	create agent transient;
	create movements transient;
	
	app.initialize();
	terminal := app.myRoot.allTerminals["POE"];
	from := "27/10/2012 10:08:20".TimeStamp;
	too := "27/10/2012 10:08:24".TimeStamp;
	
	agent.getMovements(from, too, terminal, movements);
	//movements.inspectModal;
	
	write "*********Movements************";
	foreach movement in movements do
		message := "";
	    if movement.allMovementLegs.size = 0  or 
		   //movement.source = null or movement.sourceType = null or movement.target = null or movement.targetType = null or
		   (not movement.isInstantMove and movement.sourceType = "SHIP" and movement.allMovementLegs.size &lt; 2) or
		   (not movement.isInstantMove and movement.targetType = "SHIP" and movement.allMovementLegs.size &lt; 2) then		   
			message := "****";
			errorCount := errorCount + 1;
		endif;
		write message &amp; movement.displayString;
		lastTarget := null;
		foreach leg in movement.allMovementLegs do
			message := "";
			if //leg.source = null or leg.sourceType = null or leg.target = null or leg.targetType = null or
			   (lastTarget &lt;&gt; null and leg.source &lt;&gt; lastTarget) or
			   not leg.finishTime.isValid or not leg.startTime.isValid then
				message := "****";
				errorCount := errorCount + 1;
		   endif;
		   lastTarget := leg.target;
			write "  "&amp; message &amp; leg.displayString;
		endforeach;
		foreach txn in movement.allTransactions do
			if not app.isValidObject(txn) then
				continue;
			endif;
		    message := txn.String;
		    message := message &amp; " Source: " &amp; txn.CM_Move.sourceLocn;
			message := message &amp; " Target: " &amp; txn.CM_Move.targetLocn;
			message := message &amp; " Time: " &amp; txn.CM_Move.dateTime.asStringJMT;
			write "   " &amp; message;
		endforeach;
		
	endforeach;
	write "Found " &amp; errorCount.String &amp; " Errors";

epilog
	delete agent;
	movements.purge;
	delete movements;
end;</source>
    </JadeMethod>
    <JadeMethod name="keaGetSnapshots" id="2bb3bb58-e546-4170-a7af-28c26e46fb71">
        <source>keaGetSnapshots();
vars
	agent: CM_KEAAgent;
	terminal: CM_Terminal;
	str, item, error: String;
	yard: CM_TerminalArea;
	snapshots: CM_KPISnapshotDtlArray;
	snapshot: CM_KPISnapshotDtl;
	requestItems: StringArray;
	items: CM_ObjectSetActual;
	movements: CM_KPIMovementDtlArray;
	movement: CM_KPIMovementDtl;

	at, now: TimeStamp;
	
	t: String;
	
	startTime, finishTime: TimeStamp;
	
	profiler: JadeProfiler;
begin

	create agent transient;
	create snapshots transient;
	create items transient;
	create requestItems transient;
	create movements transient;
	
	app.initialize();
	terminal := app.myRoot.allTerminals["MCT1"];
	app.myPassport.setMyTerminal(terminal);

	//str := "VOYAGE RHLS05N;GATE GATE_VTA;YARD B;YARD DW;YARD PD;YARD D27;YARD RTA;YARD GEN;YARD F;YARD D28;YARD D34R;YARD PE;YARD D48;YARD PACKCN;YARD C;YARD RP;YARD WHARF2;YARD W1;YARD J12;YARD H22;YARD DT;YARD D38C;YARD G1409;YARD J16;YARD PACKCS;YARD LRA;YARD A;YARD H09;YARD J5;YARD PTR1;YARD D22;YARD D14;YARD W3;YARD CUSTOM;YARD D34C;YARD PTR2;YARD FNC;YARD B105;YARD K7;YARD B1010;YARD PF;YARD PTR3;YARD W2;YARD VTA;YARD D105;YARD J20;YARD D106;YARD PACKA;YARD D36;YARD F7;YARD G1009;YARD D26;YARD PTR4;YARD K4;YARD K6;YARD B1013;YARD LDA;YARD B104;YARD D103;YARD D101;YARD D104;YARD F120;YARD WHARF1;YARD B106;YARD D102;YARD F10;YARD D40;YARD F13;YARD K2;YARD D18;YARD D46C;YARD K5;YARD C3TA;YARD H07;YARD C4TA;YARD K3;YARD D108;YARD D24;YARD MP40;YARD F1;YARD D33;YARD H05;YARD PBD;YARD BS3;YARD J4;YARD W4;YARD D44R;YARD G18N;YARD CWALL;YARD H11;YARD J2;YARD BEACH;";
	//str := "YARD B;YARD DW;YARD PD;YARD D27;YARD RTA;YARD GEN;YARD F;YARD D28;YARD D34R;YARD PE;YARD D48;YARD PACKCN;YARD C;YARD RP;YARD WHARF2;YARD W1;YARD J12;YARD H22;YARD DT;YARD D38C;YARD G1409;YARD J16;YARD PACKCS;YARD LRA;YARD A;YARD H09;YARD J5;YARD PTR1;YARD D22;YARD D14;YARD W3;YARD CUSTOM;YARD D34C;YARD PTR2;YARD FNC;YARD B105;YARD K7;YARD B1010;YARD PF;YARD PTR3;YARD W2;YARD VTA;YARD D105;YARD J20;YARD D106;YARD PACKA;YARD D36;YARD F7;";
	//str := "YARD D38C;";
	str := "VOYAGE V130315A";
	str := "VOYAGE MJC_NEW_JOLLY";
	str:="YARD GEN"; //;YARD RTA;YARD B;YARD C";
	str := "TRAIN S003330";
	if str &lt;&gt; null then
		str.getTokensForDelimiter(";", requestItems);
		agent.parseSnapshots(requestItems, items);
	else
		item := "PACKCS";
		read item;
		//yard := self.getTerminalArea(item);
		items.add(yard);
	endif;

	startTime := app.actualTimeServer;
	profiler := process.profiler;
	profiler.fileName := "KEAProfile11.txt";
	profiler.start;
	
	now := app.actualTimeServer;
	at := " 27/10/2012 20:00:00".TimeStamp;
	//at := now; 
	//read at;

	if str = null then
		write "Snapshot now " &amp; now.asStringForWebInterface;
		agent.getSnapshots(items, now, app.myPassport.myTerminal, snapshots);
		foreach snapshot in snapshots do
			write snapshot.displayString;
		endforeach;
		
		write "Movements from " &amp; at.asStringForWebInterface &amp; " to " &amp; now.asStringForWebInterface;
		agent.getMovements(at, now, app.myPassport.myTerminal, movements);
		foreach movement in movements reversed do
			if yard = null or 
			   movement.isYardSource and movement.getPrimeSource = yard.id or
			   movement.isYardTarget and movement.getPrimeTarget = yard.id then
				write movement.displayString;
			endif;
		endforeach;
		
		snapshots.purge;
	endif;
	
	write "Snapshot at " &amp; at.asStringForWebInterface;
	agent.getSnapshots(items, at, app.myPassport.myTerminal, snapshots);
	foreach snapshot in snapshots do
		if snapshot.isKindOf(CM_KPIYardSnapshotDtl) then
			if snapshot.CM_KPIYardSnapshotDtl.freeTEU &lt; 0 or 
			   snapshot.CM_KPIYardSnapshotDtl.usedTEU &lt; 0 then
				error := "*****";
			else
				error := "";
			endif;
		endif;
		write "Snapshot at " &amp; at.asStringForWebInterface &amp; " " &amp; error &amp; snapshot.displayString;
	endforeach;
	
	finishTime := app.actualTimeServer;
	
	write "Elapsed Time" &amp; (finishTime - startTime).String;
	
	profiler.report;

epilog
	delete agent;
	snapshots.purge;
	delete snapshots;
	delete items;
	delete requestItems;
	movements.purge;
	delete movements;
	delete profiler;
end;
</source>
    </JadeMethod>
    <JadeMethod name="keaGetTrainVisits" id="0afefc99-70e4-4491-ad1b-fd597e85fd65">
        <source>keaGetTrainVisits();
vars
