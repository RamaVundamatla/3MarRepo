Parameters:			

Return Value:		

Date		Who		Reason
24/07/2009	cnwdap1	Initial creation
17/11/2016	cnwdap1	TFS 2842 STWR Hazardous Details Enhancements
*/
vars
	labelLeft : Real;
	
begin
	//txtHazards.move(self.widestCaptionExtent + _fieldGeneric.HORIZONTAL_SPACING, 0, self.defaultControlWidth, lstHazards.height);				// TFS 2842
	labelLeft := _fieldGeneric.myLabel.width + _fieldGeneric.HORIZONTAL_SPACING;																// TFS 2842
	txtHazards.move(self.widestCaptionExtent + _fieldGeneric.HORIZONTAL_SPACING, 0, self.btnHazards.left - labelLeft - 5, lstHazards.height);	// TFS 2842
	btnHazards.top := txtHazards.top;																											// TFS 2842
	// list box invisible for now
	lstHazardList.visible := false;
epilog

end;</source>
