vars

begin
	if self.numGridRowsFit &lt; self.maxGridRow  and  self.bottomGridRow &gt; 1 then
		//self.bottomRowDraw := self.bottomRow - 1;
		self.bottomGridRowDraw := self.topGridRow - self.numGridRowsFit;
