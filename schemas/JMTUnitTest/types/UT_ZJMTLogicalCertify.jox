    <JadeMethod name="xSendEmail" id="dad857ee-e18b-4b12-9610-cab9e91d4f85">
        <source>xSendEmail( _to : String; _subject : String; _message : String );
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
15 January 2020		jlgndl1	Initial creation	TFS 46815
28 April 2025		navmd1	Listen for 'complete' notifications from CnSmtpConnection to handle SMTP responses a bit better

*/

vars

	sm		: CM_SmtpConnection;
	i		: Integer;
	str		: String;
	timeout	: TimeStamp;
	isOk	: Boolean;
	
begin
	
	str := app.myRoot.getConfig(SystemTitle).String;
	
	create sm;	
	sm.name			:= "smtp.cnw.co.nz";
	
	str := app.cnGetServerMiscPath()[3:end];
	i := 2;
	str := str[1:end].scanUntil("\", i) &amp; "@jadeworld.com";
	
	sm.sendFrom := str;
	sm.sendTo := _to;
	str := app.myRoot.getConfig(SystemTitle).String;
	
	self.beginNotification(sm, CnSmtpConnection.Completion_Event_Type, Response_Cancel, 0);
	
	sm.subject := str &amp; " - " &amp; _subject;
    sm.message := _message;
    sm.send; 
	
	timeout := app.actualTime().addSeconds(10);
	while global.isValidObject(sm) do
		app.doWindowEvents(10);
		if app.actualTime() &gt; timeout then
			return;
		endif;
	endwhile;
	
	isOk := true;
		
epilog
	// Now taken care of in userNotification
	if not isOk then
		delete sm;
	endif;
	
end;</source>
        <Parameter name="_to" type="String"/>
        <Parameter name="_subject" type="String"/>
        <Parameter name="_message" type="String"/>
    </JadeMethod>
</Class>
