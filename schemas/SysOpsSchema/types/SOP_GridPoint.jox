    <JadeMethod name="draw" id="76cfb5ec-769d-4feb-b725-a894a12f03fe">
        <updating/>
        <source>draw(pFrame: CMUI_GridAreaFrame input) updating, protected;
// ---------------------------------------------------------------------------
// Created:     31 December 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	startY,
	endY				: Real;
	idx, offsetColour					: Integer;
	tmpGridController	: CM_LocationsController;
	theTI				: CM_TrackedItem;
	int					: Integer;
	offsetLabel	:String;
	originalFont : String;
begin
	if self.myGridController.myTerminalArea.CM_GridArea.heightOfStack = 0 then
		return;//nothing to draw
	endif;
	
	pFrame.drawWidth	:= 1;	
	self.cellHeight := (self.y2 - self.y1);
	idx := 1;
	startY 	:= self.getYPosFromIdx(idx);
	endY	:= startY + self.cellHeight;
	originalFont:=	pFrame.drawFontName;
	pFrame.drawTextAlign := Frame.DrawTextAlign_Center;
	pFrame.drawFilledRectangle(self.x1, startY, self.x2, endY, Gray);
	
	if self.myGridController.isOverhang then
		pFrame.drawTextAt('| O |', self.x1+((self.x2-self.x1)/2), startY+((endY-startY)/2)-6, Blue);
	elseif self.myGridController.isGap and not power then
		pFrame.drawTextAt('| G |', self.x1+((self.x2-self.x1)/2), startY+((endY-startY)/2)-6, Blue);//pFrame.drawFillColor.getInverseColour);
	// PAR 16415 CCMS 1029
	elseif (self.myGridController.is45ft or self.myGridController.is30ft or self.myGridController.is53ft or self.myGridController.is40ft or self.myGridController.is20ft) then // PAR 18682
		offsetLabel := self.myGridController.getOffsetLabel(offsetColour);
		
//		pFrame.drawTextAt(offsetLabel, self.x1+((self.x2-self.x1)/2)-15, startY+((endY-startY)/2)-6, offsetColour);
		pFrame.drawTextAt(offsetLabel, self.x1+((self.x2-self.x1)/2), startY+((endY-startY)/2)-6, offsetColour);
	elseif self.myPicture &lt;&gt; null then
		self.drawAttribute(-1,self.letter,pFrame);
	endif;

	// cnwjk3 CCMS 1032 15/12/2008
	pFrame.drawTextAlign := Frame.DrawTextAlign_Center;

	// cnwjk3 CCMS 1032 15/12/2008
	// Draw door direction
	if self.myGridController.doorDirection = DoorDirectionForward then
		self.drawExtraAttribute(pFrame, PicTADoorFwd, self.x1+4, startY+(endY-startY)/2-2 ); 
	elseif self.myGridController.doorDirection = DoorDirectionAft then
		self.drawExtraAttribute(pFrame, PicTADoorAft, self.x2-4, startY+(endY-startY)/2-2 ); 
	endif;

	// cnwjk3 CCMS 1032 15/12/2008
	// Draw Twin Lift chars
	if self.myGridController.canTwinLiftWithPrevController then
		self.drawExtraAttribute(pFrame, PicTATwinLiftPrev, self.x1+6, endY-12); 
		self.drawExtraAttribute(pFrame, PicTATwinLiftArrows, self.x1+16, endY-12); 
	endif;

	if self.myGridController.canTwinLiftWithNextController then
		self.drawExtraAttribute(pFrame, PicTATwinLiftArrows, self.x2-16, endY-12); 
		self.drawExtraAttribute(pFrame, PicTATwinLiftNext, self.x2-6, endY-12); 
	endif;
	
	if app.isSpecial 
	and self.myLocationsController &lt;&gt; null then
		//draw decking sequence for us - debuging
		foreach int in 1 to self.myGridController.myTerminalArea.CM_GridArea.heightOfStack do
			pFrame.drawTextAt(self.myLocationsController.CM_YardController.getTAIndexForYALocnCell(int, true).String, self.x1+((self.x2-self.x1)/2)-28, startY+((endY-startY)/2)+(15-(int*10)), Blue);//pFrame.drawFillColor.getInverseColour);
			pFrame.drawTextAt(self.myLocationsController.CM_YardController.getTAIndexForYALocnCell(int, false).String, self.x1+((self.x2-self.x1)/2)+10, startY+((endY-startY)/2)+(15-(int*10)), Red);//pFrame.drawFillColor.getInverseColour);
		endforeach;	
	endif;
	
end;</source>
        <access>protected</access>
        <Parameter name="pFrame" type="CMUI_GridAreaFrame" usage="input"/>
    </JadeMethod>
    <JadeMethod name="drawAttribute" id="83a265e3-4972-4d15-9d9d-f03ccb800b97">
        <source>drawAttribute(_theAttColour : Integer; _theAttribute : String;_theFrame: CMUI_GridAreaFrame input) ;
// ---------------------------------------------------------------------------
// Created:		August 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	theDrawingAttribute		 : CM_DrawingAttribute;
	theX,theY,theColour		 :Integer;
	origFontName,theFontName,theGFontName : String;
	origFontSize,theFontSize : Real;
	theCharacter , theGChar			 : Character;
	theGridArea				 : SOP_GridArea;
begin
	origFontName := _theFrame.drawFontName;
	origFontSize := _theFrame.drawFontSize;
	theGridArea := self.myGridArea.SOP_GridArea;
	if self.isGap and _theAttribute &lt;&gt; PicTIGap then
		theDrawingAttribute := theGridArea.mySDF.allDrawingAttributes[PicTIGap];
		if theDrawingAttribute &lt;&gt; null then
			theGChar := theDrawingAttribute.fontCharacter.Character;
			theGFontName := theDrawingAttribute.fontName;
		endif;
	endif;
	
	theDrawingAttribute := theGridArea.mySDF.allDrawingAttributes[_theAttribute];

	if theDrawingAttribute &lt;&gt; null then
		theCharacter := theDrawingAttribute.fontCharacter.Character;
		_theFrame.drawFontName := theDrawingAttribute.fontName;
	else
		theCharacter := '!'.Character;
	endif;
	
	//check for gaps
	if self.isGap and _theAttribute &lt;&gt; PicTIGap  then
		theX := (self.x1 + 1).Integer;
		theY := (self.y1 + 2).Integer;
	else
		theX := (self.x1 + ((self.x2 - self.x1)/ 3)).Integer;
		theY := (self.y1 + ((self.y2 - self.y1)/ 2)).Integer -10;
	endif;
	_theFrame.drawFontSize := 12;
	_theFrame.drawTextAlign := Frame.DrawTextAlign_Left; //DrawTextAlign_Center;
	
	if theDrawingAttribute &lt;&gt; null then
		theColour := theDrawingAttribute.colour;
	else
		theColour := Red;
	endif;
	_theFrame.drawTextAt(theCharacter, theX,theY,theColour);
	if self.isGap and _theAttribute &lt;&gt; PicTIGap  then
		theX := (self.x1 + ((self.x2 - self.x1)/ 2)).Integer ;
		_theFrame.drawFontName := theGFontName;
		_theFrame.drawTextAt(theGChar, theX,theY,theColour);
	endif;
		
epilog
	_theFrame.drawFontName := origFontName;
	_theFrame.drawFontSize := origFontSize;
end;</source>
        <Parameter name="_theAttColour" type="Integer"/>
        <Parameter name="_theAttribute" type="String"/>
        <Parameter name="_theFrame" type="CMUI_GridAreaFrame" usage="input"/>
    </JadeMethod>
    <JadeMethod name="drawExtraAttribute" id="32874434-df00-4cce-9bb1-b6141030189f">
        <source>drawExtraAttribute( _pFrame : CMUI_GridAreaFrame input; _id : String; _x : Real; _y : Real );

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
11 December 2008	cnwjk3	CCMS 1032

*/

vars
	theDrawingAttribute	: CM_DrawingAttribute;
	originalFont 		: String;
begin
	theDrawingAttribute := self.myGridArea.mySDF.allDrawingAttributes[_id];
	if theDrawingAttribute &lt;&gt; null then
		originalFont := _pFrame.drawFontName;
		_pFrame.drawFontName := theDrawingAttribute.fontName;
		_pFrame.drawTextAt(theDrawingAttribute.fontCharacter.Character, _x, _y, theDrawingAttribute.colour);
		_pFrame.drawFontName := originalFont;
	endif;
end;</source>
        <Parameter name="_pFrame" type="CMUI_GridAreaFrame" usage="input"/>
        <Parameter name="_id" type="String"/>
        <Parameter name="_x" type="Real"/>
        <Parameter name="_y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="drawSelf" id="c43340b3-5db8-4770-bc40-03a01ce59628">
        <updating/>
        <source>drawSelf(pFrame: CMUI_GridAreaFrame input) updating;
// ---------------------------------------------------------------------------
// Created:     31 December 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
begin


	if self.myGridArea.SOP_GridArea.selectedAreaIncludes(self) then//allSelectedPoints.includes(self) then
		self.setSelectedDrawingAttributes(false, pFrame);
	else
		self.setUnselectedDrawingAttributes(false, pFrame, 0);	// _isTI
	endif;
	self.draw(pFrame);
end;</source>
        <Parameter name="pFrame" type="CMUI_GridAreaFrame" usage="input"/>
    </JadeMethod>
