    <JadeMethod name="cnEcCopyFontSettings" id="b59b9fd6-688a-432d-a8ac-6c9c134626f3">
        <updating/>
        <source>cnEcCopyFontSettings(pControlObj:Control) updating;
// --------------------------------------------------------------------------------
// Created:		02 November 2000 by cnwdad1
//
// Purpose:		Copy all of the font-related settings from the parameter control to
//				the receiver.
//
// Parameters:	pControlObj - The control from which to copy the font settings.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if pControlObj.fontName = null then
		self.fontName 	:= app.fontName;
	else
		self.fontName	:= pControlObj.fontName;
	endif;

	self.fontBold 		:= pControlObj.fontBold;
	self.fontItalic 	:= pControlObj.fontItalic;
	self.fontSize		:= pControlObj.fontSize;
	self.fontStrikethru	:= pControlObj.fontStrikethru;
	self.fontUnderline	:= pControlObj.fontUnderline;
end;</source>
        <Parameter name="pControlObj" type="Control"/>
    </JadeMethod>
    <JadeMethod name="cnEcGetAccelerator" id="3fcf47be-a2e0-42aa-8b23-122e0df26657">
        <source>cnEcGetAccelerator():Character;
// --------------------------------------------------------------------------------
// Created:		07 November 2000 by cnwdad1
//
// Purpose:		Return the character after the first "&amp;" in the receiver control's
//				caption.
//
// Parameters:	None
//
// Returns:		The accelerator character found, or null if there are none.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
constants
	AMPERSAND_CHAR	: Character = "&amp;";
	
vars
	captionValue	: String;
	captionLength	: Integer;
	ampersandPos	: Integer;

begin
	on Exception do self.xHandlerGetPropertyValue(exception);
	
	captionValue	:=	self.getPropertyValue("caption").String;
	
	if captionValue = null then
		return null;
	endif;
	
 	captionLength	:=	captionValue.length();
	ampersandPos	:=	captionValue.pos(AMPERSAND_CHAR, 1);
	
	if ampersandPos &gt; 0 and ampersandPos &lt; captionLength then
		return captionValue[(ampersandPos + 1):1].Character;
	else
		return null;
	endif;
end;</source>
        <ReturnType type="Character"/>
    </JadeMethod>
    <JadeMethod name="cnEcGetAllChildControls" id="53e7f9c1-b4cb-422b-b6f7-cee66c04064c">
        <source>cnEcGetAllChildControls(pAllChildControls: CnEcControlArray io; pIsGetTheirChildren:Boolean);
// --------------------------------------------------------------------------------
// Refer to the Window class abstraction for a description etc.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	controlIndex		: Integer;
	numberOfControls	: Integer;
	parentFormObj		: Form;
	controlObj			: Control;
	
begin
	parentFormObj		:=	self.form;
	numberOfControls	:=	parentFormObj.controlCount;
	
	foreach controlIndex in 1 to numberOfControls do
		controlObj	:=	parentFormObj.controls(controlIndex);
		
		if controlObj.parent = self then
			pAllChildControls.add(controlObj);
			
			if pIsGetTheirChildren then
				controlObj.cnEcGetAllChildControls(pAllChildControls, pIsGetTheirChildren);
			endif;
		endif;
	endforeach;
end;</source>
        <Parameter name="pAllChildControls" type="CnEcControlArray" usage="io"/>
        <Parameter name="pIsGetTheirChildren" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="cnEcGetCaption" id="72298da3-573e-4d6c-a52a-88ffc0abbc44">
        <source>cnEcGetCaption():String;
// --------------------------------------------------------------------------------
// Created:		28 February 2007 by cnwdad1
//
// Purpose:		Return the receiver's caption.
//
// Parameters:	None
//
// Returns:		The receiver's caption, or null if the receiver Type doesn't have one.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	on Exception do self.xHandlerGetPropertyValue(exception);
	
	return self.getPropertyValue(Label::caption.name).String;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="cnEcGetDescription" id="3e232353-7656-4619-a241-08205cfe433a">
        <source>cnEcGetDescription():String;
// --------------------------------------------------------------------------------
// Created:		13 December 2005 by cnwdad1
//
// Purpose:		Returns a description of the receiver.
//
// Parameters:	None
//
// Returns:		A string containing the description.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	returnValue	: String;
	
begin
	returnValue	:=	self.name &amp; " (" &amp; self.class.schema.name &amp; "::" &amp; self.class.name &amp; ")";
	
	return returnValue;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="cnEcGetText" id="abbe4a34-ee39-4852-a870-f683a8b4281d">
        <source>cnEcGetText():String;
// --------------------------------------------------------------------------------
// Created:		28 February 2007 by cnwdad1
//
// Purpose:		Return the receiver's text.
//
// Parameters:	None
//
// Returns:		The receiver's text, or null if the receiver Type doesn't have text.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	on Exception do self.xHandlerGetPropertyValue(exception);
	
	return self.getPropertyValue(TextBox::text.name).String;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
