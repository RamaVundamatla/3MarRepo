        <Parameter name="_isGapCol" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="drawGridBottomColumnHeader" id="7386b152-2c0d-4e27-a83b-dd0f6df6ec43">
        <source>drawGridBottomColumnHeader(_x1, _y1, _x2, _y2 : Real io; _frame : Frame input; _scaleFactor : Real;  _isLandscape, _flipH, _flipV : Boolean; _mode : Integer; _isGapCol : Boolean);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21/06/2011	cnwdz2	Initial creation 27732

*/

vars
begin
	if _mode = self.MODE_TOPDOWN then
		self.drawGridBottomColHeaderTopDown(_x1, _y1, _x2, _y2, _frame, _scaleFactor, _isLandscape, _flipH, _flipV, _mode, _isGapCol);
	elseif _mode = self.MODE_FACE then		
		self.drawGridBottomColHeaderTopDown(_x1, _y1, _x2, _y2, _frame, _scaleFactor, _isLandscape, _flipH, _flipV, _mode, _isGapCol);
	elseif _mode = self.MODE_END then
		self.drawGridBottomColumnHeaderEnd(_x1, _y1, _x2, _y2, _frame,_scaleFactor, _isLandscape, _flipH, _flipV, _mode, _isGapCol);	
	else
		app.raiseUnexpectedProgramError(class.name, method.name, "unsupported drawing mode specified");
	endif;
epilog

end;</source>
        <Parameter name="_x1" type="Real" usage="io"/>
        <Parameter name="_y1" type="Real" usage="io"/>
        <Parameter name="_x2" type="Real" usage="io"/>
        <Parameter name="_y2" type="Real" usage="io"/>
        <Parameter name="_frame" type="Frame" usage="input"/>
        <Parameter name="_scaleFactor" type="Real"/>
        <Parameter name="_isLandscape" type="Boolean"/>
