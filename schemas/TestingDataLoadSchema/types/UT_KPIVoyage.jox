    <JadeMethod name="addVoyageJob" id="631e4182-ced0-4c20-af22-854fb9499762">
        <source>addVoyageJob(_voyage : CM_Voyage; _craneId: String; _allSlots: CM_SlotControllerArray; isDischarge: Boolean): CM_VoyageJob;
/*
Purpose:			
Date		Who		Reason
16 March 2015	cnwab1	Initial creation
*/

vars
	craneTA :CM_CraneTransferArea;
	crane 		: CM_Crane;
	terminal	: CM_Terminal;
	taAccess: StringArray;
begin
	
	terminal := self.getTerminal();
	if terminal &lt;&gt; null then
		crane := terminal.machines[_craneId].CM_Crane;
	endif;

	if crane = null then
	
		craneTA := self.addCraneTransferArea(_craneId &amp; "TA");
		self.opts.addAssoc("CraneTransferArea", craneTA);
		self.opts.addAssoc("CanLift", "1111");
		self.opts.addAssoc("BaseJobNumber", 100);
		
		create taAccess transient;
		taAccess.add(craneTA.id);
		self.addCrane(_craneId,10,taAccess,null);
		
	endif;

	return inheritMethod(voyage, _craneId, _allSlots, isDischarge);

epilog
	delete taAccess;
end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_craneId" type="String"/>
        <Parameter name="_allSlots" type="CM_SlotControllerArray"/>
        <Parameter name="isDischarge" type="Boolean"/>
        <ReturnType type="CM_VoyageJob"/>
    </JadeMethod>
    <JadeMethod name="checkKPIMessage" id="056531f4-f973-4666-82ae-ce5a40d0474e">
        <source>checkKPIMessage(_actual, _sbe : Integer; _label : String; _checkOK : Boolean io);
/*
Purpose:			
Date				Who			Reason
MAY 2012		CNWAB1		Initial creation
*/

vars
begin
	if _actual &lt;&gt; _sbe then
		//app.writeStatement("KPI Check, " &amp; _label &amp; " Are Wrong, is " &amp; _actual.String &amp; "  expecting " &amp; _sbe.String);
		
		_checkOK := false;
	endif;

epilog

end;</source>
        <Parameter name="_actual" type="Integer"/>
        <Parameter name="_sbe" type="Integer"/>
        <Parameter name="_label" type="String"/>
        <Parameter name="_checkOK" type="Boolean" usage="io"/>
    </JadeMethod>
    <JadeMethod name="checkKPIs" id="be1c3e3e-3062-4271-9f1c-3f0c95eeba79">
        <source>checkKPIs(_voy : CM_Voyage);
// ---------------------------------------------------------------------------
