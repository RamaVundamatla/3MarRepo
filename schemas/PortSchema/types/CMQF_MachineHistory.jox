    <JadeMethod name="cloneReferences" id="20521fe4-caa9-4d8f-b5f6-c0f3c4c6cd25">
        <updating/>
        <source>cloneReferences(_obj: CMQF_MachineHistory; _transient: Boolean) updating;
//----------------------------------------------------------------------
// Created by 	cnwsh3 - 24 November 2010
//
// Implemented version: JMT 7.9.1
// Date  		User  		Change
// 24/11/2010	cnwsh3		1132 - allow updates to template filter values.
// 11 Oct 2019	jlgdi1	46878 Added back the call to inheritMethod to retain the report definition 
//						like selected terminals
//----------------------------------------------------------------------
begin
	inheritMethod(_obj, _transient);
	
	_obj.allDelayTypes.copy(self.allDelayTypes);
	_obj.allDelayTypeGroups.copy(self.allDelayTypeGroups);
	
	self.allDelayTypes.removeInvalidObjects();	//18 July 2016	NDL	TFS 2329
	self.allDelayTypeGroups.removeInvalidObjects();	//18 July 2016	NDL	TFS 2329
	
	self.setMyMachine(_obj.getMyMachine);
	self.setMyMachineType(_obj.getMyMachineType);
	self.myUser := _obj.myUser;
end;</source>
        <Parameter name="_obj" type="CMQF_MachineHistory"/>
        <Parameter name="_transient" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="filterObjects_AllColls" id="25f86517-1895-4784-8012-ddb81374f8af">
        <updating/>
        <source>filterObjects_AllColls(_history: Collection input; _dateColl :CM_KPIMachineByDateUserDict input; 
				_shiftColl:CM_KPIMachineByShiftUserDict input; _garbage :ObjectSet input; _passport: CM_Passport) updating;
// ---------------------------------------------------------------------------
// Created:     01 November 2010 by cnwcs5 par 23714/ccms 1132
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	tsFrom, tsTo,
	tsShiftsFrom, 
	tsShiftsTo	:TimeStamp;
	terminal	:CM_Terminal;
	machine		:CM_Machine;
	shiftColl	:CM_ShiftStartDateCodeDict;
begin
	self.setDefaultStartEndDates (tsFrom, tsTo);

	create shiftColl transient;

	machine := self.getMyMachine;
	
	if machine &lt;&gt; null then
		terminal := machine.myTerminal;
		
		self.kpiGetShiftsForDateRange (terminal, tsFrom, tsTo, shiftColl, _garbage, tsShiftsFrom, tsShiftsTo);
		self.kpiGenerate (tsFrom, tsTo, tsShiftsFrom, tsShiftsTo, shiftColl, machine.myTerminal, machine, _history, _dateColl, _shiftColl, _garbage);
	else
		// reporting on &gt; 1 machine
		foreach terminal in self.allTerminals do
			shiftColl.clear;
			self.kpiGetShiftsForDateRange (terminal, tsFrom, tsTo, shiftColl, _garbage, tsShiftsFrom, tsShiftsTo); 

			foreach machine in terminal.machines discreteLock do
				if self.getMyMachineType &lt;&gt; null and machine.getMachineType &lt;&gt; self.getMyMachineType then
					// does not match machine type
					continue;
				endif; 
				self.kpiGenerate (tsFrom, tsTo, tsShiftsFrom, tsShiftsTo, shiftColl, terminal, machine, _history, _dateColl, _shiftColl, _garbage);
			endforeach;
		endforeach;
	endif; 
epilog
	delete shiftColl;
end;</source>
        <Parameter name="_history" type="Collection" usage="input"/>
        <Parameter name="_dateColl" type="CM_KPIMachineByDateUserDict" usage="input"/>
        <Parameter name="_shiftColl" type="CM_KPIMachineByShiftUserDict" usage="input"/>
        <Parameter name="_garbage" type="ObjectSet" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="getDelayTypeCriteria" id="7f05f3e6-537c-41f7-a6b1-564e08621a4e">
        <source>getDelayTypeCriteria():String;
// ---------------------------------------------------------------------------
// Created:     01 December 2010 by cnwcs5 par 23714/ccms 1132
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

	type	:CM_DelayType;
	str		:String;
	edition : Integer;	//18 July 2016	NDL	TFS 2329
	invalid : Boolean;	//18 July 2016	NDL	TFS 2329
	
begin

	on Exception do app.handleDeletedObject( exception, type, invalid );	//18 July 2016	NDL	TFS 2329
	
	foreach type in self.allDelayTypes do
		
		//18 July 2016	NDL	TFS 2329
		invalid := false;
		edition := type.edition;
		if invalid then
			continue;
		endif;
		
		if str = null then
			str := type.description;
		else
			str := str &amp; CNEC_COMMA &amp; Space &amp; type.description;
		endif;
	endforeach;
	return str;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
