    <JadeMethod name="unloadForm" id="f33fa546-f13b-4ff5-8f6b-6e59f670edda">
        <updating/>
        <executionLocation>client</executionLocation>
        <source>unloadForm(): Boolean updating, clientExecution;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 August 2022	navcs2	Initial creation
25 Apr 2023 	navhl20 ChangeRequest 57733:[57734] EUP - VBS changes MTN - Bulk Edit and Linking of slots [Refinement - 02]
24 Apr 2023 	navhl20	ChangeRequest 57716:[57718] EUP - VBS changes MTN - Bulk Edit and Linking of slots [Refinement - 01]
*/

vars
	invalid : Boolean;
	vbsSlot	: CM_VehicleBookingTimeSlot;
	vbsItem	: CM_VehicleBookingTimeSlotItem;
	proxy	: CM_ProxyLink;
begin
	on Exception do app.handleDeletedObject(exception, self.myProxyVehicleBookingTimeSlot, invalid);			//24.4.2023 navhl20 #57716[57718]
	
	if self.myProxyVehicleBookingTimeSlot &lt;&gt; null then															//24.4.2023 navhl20 #57716[57718]
		self.myProxyVehicleBookingTimeSlot.edition;
		
		if invalid then		
			if self.myProxyVehicleBookingTimeSlot.pxyGetRealObject = null then
				delete self.myProxyVehicleBookingTimeSlot;
			endif;
		endif;
	endif;
	
	if self.myProxyVehicleBookingTimeSlot &lt;&gt; null then															//24.4.2023 navhl20 #57733[57734]
		foreach vbsItem in self.myProxyVehicleBookingTimeSlot.allVehicleBookingItems do							//24.4.2023 navhl20 #57733[57734]
			delete vbsItem;
		endforeach;
		self.myProxyVehicleBookingTimeSlot.allVehicleBookingItems.purge;
		delete self.myProxyVehicleBookingTimeSlot;
	endif;
	app.myProxyManager.allProxies.purge;
	return inheritMethod();
epilog
	if myParentForm.isKindOf(CMUI_VehicleBookingAdvSearch) then
		myParentForm.CMUI_VehicleBookingAdvSearch.populateVBSSlotTable();
	endif;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="updateVbsChecks" id="038c4a6f-714f-45fd-9ac2-009a541d05d5">
        <source>updateVbsChecks();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 Jul 2022	navcs2	ChangeRequest 53899: EUP - VBS MTN - [3] - Maintaining VBS Slot
25 Nov 2024	navhl20 CR MTN-33483: TPT | Vehicle Truck Booking Auto Associate with Release Request
*/

vars
	proxyVbsSlotType : CM_VehicleBookingTimeSlotType; 
	realVbsSlotType  : CM_VehicleBookingTimeSlotType;
	ls : Boolean;
begin
	realVbsSlotType := self.cmbVbsSlotType.getCurrentItemObject.CM_VehicleBookingTimeSlotType;
	
	proxyVbsSlotType := app.createUpdateProxy(realVbsSlotType).CM_VehicleBookingTimeSlotType;
	
	proxyVbsSlotType.setForProxy(realVbsSlotType.code,
								 realVbsSlotType.description, 
								 realVbsSlotType.notAvailableForEntry,
								 realVbsSlotType.myTerminal, 
								 realVbsSlotType.startTime,
								 realVbsSlotType.duration,
								 realVbsSlotType.gracePeriod,
								 realVbsSlotType.outsideSlotTimeAction,
								 self.chkPreGateIn.value,
								 self.chkPreGateOut.value,
								 self.chkKiosk.value,
								 realVbsSlotType.isExternelRefUpdateAllowed,
								 false);															//25.11.2024 navhl20 #33483
								 
	app.myTrxUA.trxUpdateVBTimeSlotType(proxyVbsSlotType, app.myPassport);
	
epilog
	delete proxyVbsSlotType;
	
end;</source>
    </JadeMethod>
</GUIClass>
