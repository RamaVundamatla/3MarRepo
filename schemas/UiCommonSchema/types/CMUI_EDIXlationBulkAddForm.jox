    <JadeMethod name="initTable" id="67846fa1-3d1d-4730-9a2b-e985092f5dcd">
        <updating/>
        <source>initTable(_table: CM_DataTable input) updating;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 01 April 2022
TFS#		: 53181
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

vars
	columnIndex : Integer;
	rowIndex  : Integer;
	headerRow : Integer;
begin
	_table.allTblDataColHeadings.purge();
	_table.columns := 1;	
	_table.rows := 1;
	
	columnIndex := 1;
	rowIndex  := 1;
	headerRow := 1;	
	_table.accessCell(headerRow,columnIndex).text := app.getErrorString(Terminal);	
	_table.allTblDataColHeadings.add(app.getErrorString(Terminal));
	_table.inputType := Table.InputType_TextBox;	
	_table.fixedColumns := 1;
	_table.fixedRows := 1;	
epilog
	
end;</source>
        <Parameter name="_table" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="isVoyageIncluded" id="5031e336-65a1-4c47-bb51-e6feb15b8d81">
        <source>isVoyageIncluded(_voyage : CM_Voyage) : Boolean;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 01 April 2022
TFS#		: 53181
Function	:

*** Changes ***
Date			Name		TFS#		Description
15/07/2022		jlizm1		53964		Include inland voyages in voyage bulk translation screen
****************************************************/
vars
	currentDate		: Date;
	departureDate	: Date;
	arriveDate		: Date;
	
begin
	currentDate	:=	app.actualTimeServer().date();	
	arriveDate	:=	_voyage.arrivedDT.date();
	departureDate :=  _voyage.departedDT.date();
	
	if _voyage.isNullVoyage then
		return false;
	endif;
	
	if _voyage.archived then
		return false;
	endif;	
	
	if arriveDate &gt;= currentDate or currentDate &lt;= departureDate then
		return true;
	endif;	
	
	return false;
end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="mnuInspectObject_click" id="db8c7215-972d-425d-bf55-8bbb527042fe">
