    <JadeMethod name="addGrade" id="564380e4-e2e3-4a52-b742-1e06af6cd4b2">
        <updating/>
        <source>addGrade(_gradeObj:MB_Grade input) updating;
// --------------------------------------------------------------------------------
// Created:		31 January 2006 by cnwdad1
//
// Purpose:		Adds a Grade to the reciver.
//
// Parameters:	_gradeObj - A reference to the Grade object.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	rowPointer	: Integer;
	rowObj		: JadeTableRow;
	
begin
	rowPointer			:=	self.addItem(_gradeObj.description);
	rowObj				:=	self.accessRow(rowPointer);
	rowObj.itemObject	:=	_gradeObj;
	
	if rowPointer.isEven() then
		rowObj.backColor	:=	self.alternateColor;
	endif;
	
	self.setCellImage(rowPointer);
end;</source>
        <Parameter name="_gradeObj" type="MB_Grade" usage="input"/>
    </JadeMethod>
    <JadeMethod name="cleanUpGrades" id="5503a755-1d2f-48a6-8326-7044b81e0a53">
        <updating/>
        <source>cleanUpGrades() updating;
// --------------------------------------------------------------------------------
// Created:		03 February 2006 by cnwdad1
//
// Purpose:		Purges any transient Grade objects in the receiver's rows.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	rowPointer	: Integer;
	startRow	: Integer;
	lastRow		: Integer;
	gradeObj	: MB_Grade;
	
begin
	startRow	:=	self.fixedRows + 1;
	lastRow		:=	self.rows;
	
	foreach rowPointer in startRow to lastRow do
		gradeObj	:=	self.accessRow(rowPointer).itemObject.MB_Grade;
		
		if gradeObj &lt;&gt; null then
			delete gradeObj;
		endif;
	endforeach;
end;</source>
    </JadeMethod>
    <JadeMethod name="click" id="23ec12c4-e723-4916-ba59-25b6970fe774">
        <controlMethod name="Table::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>click(table: Table input) updating, clientExecution;
// --------------------------------------------------------------------------------
// Created:		31 January 2006 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if (not self.userInputEnabled) or
	   self.readOnly or
	   (not self.enabled) then
		return;
	endif;
	
	app.mousePointer	:=	Busy;
	inheritMethod(table);
	self.doCellClick(self.row, self.column);
epilog
	app.mousePointer	:=	Idle;
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="delete" id="a5ed63e1-44c9-4648-9ad8-0dec649d6e82">
        <updating/>
        <executionLocation>client</executionLocation>
        <source>delete() updating, clientExecution;
// --------------------------------------------------------------------------------
// Created:		03 February 2006 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.isTransient() then
		self.cleanUpGrades();
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="doCellClick" id="6a84e243-07b0-4449-9e6b-a47e2fddbd8d">
        <updating/>
        <source>doCellClick(_rowPointer:Integer; _colPointer:Integer) updating, protected;
// --------------------------------------------------------------------------------
// Created:		30 January 2006 by cnwdad1
//
// Purpose:		Action a cell click to determine whether we need to tick or cross
//				it.
//
// Parameters:	_rowPointer - The row of the cell that was clicked.
//				_colPointer - The column of the cell that was clicked.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	gradeObj	: MB_Grade;
	isChanged	: Boolean;
	currentRow	: Integer;
	startRow	: Integer;
	lastRow		: Integer;
	
begin
	if _colPointer &lt;&gt; self.Column_Select then
		return;
	endif;
	
	isChanged	:=	false;
	startRow	:=	self.fixedRows + 1;
	lastRow		:=	self.rows;
	
	foreach currentRow in startRow to lastRow do
		gradeObj	:=	self.accessRow(currentRow).itemObject.MB_Grade;
		
		if gradeObj &lt;&gt; null then
			if currentRow = _rowPointer and (not gradeObj.isNewGrade) then
				gradeObj.setNewGrade(true);
				self.setCellImage(currentRow);
				
				if not isChanged then
					isChanged	:=	true;
				endif;
				
			elseif gradeObj.isNewGrade then
				gradeObj.setNewGrade(false);
				self.setCellImage(currentRow);
				
				if not isChanged then
					isChanged	:=	true;
				endif;
			endif;
		endif;
	endforeach;
	
	if isChanged then
		self.mbSetIsSaveRequired(true);
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_rowPointer" type="Integer"/>
        <Parameter name="_colPointer" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getAlternateColor" id="036117c3-2730-4d9d-8397-8a0615634d7e">
        <source>getAlternateColor() : Integer;
// ----------------------------
// Created:	09 May 2008 by cnwvu1
// ----------------------------

vars

begin
	return self.alternateColor;
end;
</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getCurrentGradeCode" id="588e1dd0-e162-409f-9da3-5a7dbed31208">
        <updating/>
        <source>getCurrentGradeCode():Integer updating;
// --------------------------------------------------------------------------------
// Created:		03 February 2006 by cnwdad1
//
// Purpose:		Returns the code of the Grade which is flagged as current.
//
// Parameters:	None
//
// Returns:		The code of the current Grade, otherwise null.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	gradeObj	: MB_Grade;
	currentRow	: Integer;
	startRow	: Integer;
	lastRow		: Integer;
	
begin
	startRow	:=	self.fixedRows + 1;
	lastRow		:=	self.rows;
	
	foreach currentRow in startRow to lastRow do
		gradeObj	:=	self.accessRow(currentRow).itemObject.MB_Grade;
		
		if gradeObj &lt;&gt; null and gradeObj.isNewGrade then
			return gradeObj.code;
		endif;
	endforeach;
	
	return null;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="mbSetIsSaveRequired" id="73acdf34-eba6-4ade-a12c-590966fee668">
        <updating/>
        <source>mbSetIsSaveRequired(_isRequired: Boolean) updating, protected;
// --------------------------------------------------------------------------------
// Created:		31 January 2006 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.isSaveRequired	:=	_isRequired;
	self.form.mbSetIsSaveRequired(_isRequired);
end;</source>
        <access>protected</access>
        <Parameter name="_isRequired" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setCellImage" id="938b57e4-3403-46c8-ad92-76247de20c42">
        <updating/>
        <source>setCellImage(_rowPointer:Integer) updating, protected;
// --------------------------------------------------------------------------------
// Created:		23 January 2006 by cnwdad1
//
// Purpose:		Sets the image for the specified cell.
//
// Parameters:	_rowPointer - The row of the cell.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	rowObj		: JadeTableRow;
	cellObj		: JadeTableCell;
	gradeObj	: MB_Grade;
	
begin
	rowObj		:=	self.accessRow(_rowPointer);
	gradeObj	:=	rowObj.itemObject.MB_Grade;
	cellObj		:=	self.accessCell(_rowPointer, self.Column_Select);
	
	if gradeObj &lt;&gt; null and gradeObj.isNewGrade then
		cellObj.picture	:=	self.imageTick;
	else
		cellObj.picture	:=	null;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_rowPointer" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="windowCreated" id="3cff4579-59aa-41f4-bb24-9879bf095e3b">
        <controlMethod name="Control::windowCreated"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>windowCreated(cntrl: Control input; persistCntrl: Control) updating, clientExecution;
// --------------------------------------------------------------------------------
// Created:		03 February 2006 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	inheritMethod(cntrl, persistCntrl);
	
	self.fixed3D				:=	false;
	self.partialTextIndication	:=	true;
end;</source>
        <Parameter name="cntrl" type="Control" usage="input"/>
        <Parameter name="persistCntrl" type="Control"/>
    </JadeMethod>
