    <JadeMethod name="displayExtraInfo" id="abb8deed-cdfe-4e65-836b-c95155cb610a">
        <source>displayExtraInfo()protected;
//--------------------------------------------------
// Created:	15 July 2005 By: cnwgd1
//--------------------------------------------------
vars

	dataContainer : CM_DataContainer;
	wle 		: CM_WorkListEntry;
	strArray	: HugeStringArray;
	cargoType	: CM_CargoType;
	x1, x2, 
	y1, y2,
	tmpYOffset,
	scaleFactor	: Integer;
	graphic		: CM_TIBehaviourGraphic;
	
begin
	
	self.tblInfo.rows := 0;
	if self.myCurrentTiLCType = null then
		return;
	endif;
	
	create dataContainer transient;
	dataContainer.headerColour := self.colorHeadingColumn;
	dataContainer.valueColour := self.colorValueColumn;
	
	self.myCurrentTiLCType.getExtraInfo(dataContainer);

	self.tblInfo.userObject	:=	self.myCurrentTiLCType; // this is used to redraw this info
	self.showExtraInformation(dataContainer, self.tblInfo, true,false,4,1,4,1,1);
	scaleFactor := 1;
/*	cargoType	:= self.myCurrentTiLCType.getCargoType();
	if cargoType &lt;&gt; null and cargoType.myTIBehaviourType.myGraphic &lt;&gt; null then
		graphic := cargoType.myTIBehaviourType.myGraphic;
		x1	:= 0;
		x2	:= self.frmPictureActual.width.Integer;
		y1	:= 0;
		y2	:= self.frmPictureActual.height.Integer;

		tmpYOffset := (y2 - (graphic.maxY * scaleFactor).Integer);
		graphic.drawGraphic(self.frmPictureActual, 0, scaleFactor, x1, tmpYOffset, false, 0, graphic.maxX, true, true,null, NullColour);

	endif;*/
	
//	self.tblInfo.fitColumnWidths();
	self.doResizeColumnWidths(self.tblInfo, true);
	
epilog
	delete dataContainer;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="displayTiMasters" id="010b63e1-2575-402c-9963-4954ff258512">
        <updating/>
        <source>displayTiMasters()updating, protected;
//--------------------------------------------------
// Created:	18 July 2005 By: cnwgd1
//--------------------------------------------------
// Changed On	By			Reason
// ----------	--------	-------------------------------------------
// 31/03/2016	cnwdap1		PAR #35843 Make monitor time based rather than object-count based
vars

	passport		: CM_Passport;
	cmifMonitor		: CMIF_Monitor;
	master			: CM_TIMaster;
	obj				: Object;
	cnt,
	partsInJob,
	partsDone		: Integer;
	str				: String;
	tiLCType		: CM_TILCType;
	lastUpdated		: Decimal [20];								// PAR #35843
begin
	app.mousePointer := self.MousePointer_HourGlass;				
	passport := app.myPassport;
	self.tblData.rows := self.tblData.fixedRows;
	self.tblInfo.rows := 0;
	self.tblData.clearAllSelected();

	cmifMonitor := passport.myCMIFMonitor;
	if cmifMonitor &lt;&gt; null then
		delete cmifMonitor;
	endif;
	create cmifMonitor transient;
	cmifMonitor.myParent := self;
	passport.setMyCMIFMonitor(cmifMonitor);

	self.modalDialogReturnValue := self.ModalDialogReturn_Null;	
	self.modalDialogShow(null, 'Cancel' , null, null, 'Loading Master Items',  'Please Wait....');
	self.pbProgressBar.visible := true;
	
	
//	foreach obj in self.lstMasterTypes.allSelectedObjects do
//		type := obj.CM_TILCType;
//		partsInJob := partsInJob + type.allTILCs.size;
//		str := str &amp; ', ' &amp;  group.description;
//	endforeach;
	
	if str.length &gt; 2 then
		str := str[3:end];
	endif;

//	self.caption := 'Master Item Maintenance - ' &amp; str;
	
	foreach tiLCType in app.myRoot.allTILCTypes do
		//if not self.lstType.allSelectedObjects.includes(master.getCurrentTi().CM_TILC.myTILCType) then
		//	continue;
		//endif;
		cnt := cnt + 1;
		partsDone := partsDone + 1;
		self.tblDataDisplayRow(tiLCType);
		//if cnt = 100 then																				// PAR #35843
		if (app.relativeMachineTime - lastUpdated) &gt; CMIF_Monitor.Monitor_TimeBetweenUpdates then		// PAR #35843
			if (not cmifMonitor.updateProgress(cmifMonitor.message, partsInJob, partsDone)) then
				break;
			endif;
			cnt := 0;
			lastUpdated := app.relativeMachineTime;														// PAR #35843
		endif;
	endforeach;

epilog
	app.mousePointer := self.MousePointer_Default;									
	delete cmifMonitor;
	app.myPassport.setMyCMIFMonitor(null);
	self.tblData.colourRows(self.colorRow1, self.colorRow2);
	if self.tblData.rows &gt; self.tblData.fixedRows then
		self.tblData.selectRow(self.tblData.fixedRows + 1, false);		
		//self.setCurrentTiMaster(self.tblData.accessRow(self.tblData.row).itemObject.CM_TIMaster);
	endif;
	self.frmModalDialog.visible := false;	
	return;
end;</source>
        <access>protected</access>
    </JadeMethod>
