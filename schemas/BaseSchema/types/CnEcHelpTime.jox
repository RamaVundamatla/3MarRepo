    <DbClassMap file="BaseHelp"/>
    <PrimAttribute name="date" id="3489fd5d-8395-4c5c-ba48-96eaef9120c0">
        <embedded/>
        <type name="TimeStamp"/>
        <access>readonly</access>
    </PrimAttribute>
    <ImplicitInverseRef name="myHelp" id="3735d8c6-1224-431e-b2dc-e194a4435d9c">
        <embedded/>
        <type name="CnEcHelp"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <PrimAttribute name="project" id="13db3b33-9135-4c27-a10e-101f50ca2767">
        <length>21</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="timeEstimate" id="cf2af261-c247-4dd2-a313-06de720dd92b">
        <embedded/>
        <type name="Real"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="timeUsed" id="e93c208d-fda8-42ff-9d79-f5c6e5d9aac6">
        <embedded/>
        <type name="Real"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="displayDetails" id="affdecba-77ec-4bb5-9fde-984112c821f4">
        <source>displayDetails() : String;

begin
	return self.project &amp; Tab &amp; "(" &amp; self.timeEstimate.String &amp; ")" &amp; Tab &amp; self.timeUsed.String;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getName" id="1b663d14-e441-44f3-a67e-391b1ab4306d">
        <source>getName(): String;

begin
	if self.myHelp &lt;&gt; null then
		return self.myHelp.name &amp; "/" &amp; self.displayDetails();
	else
		return "ERROR - null help schema" &amp; "/" &amp; self.displayDetails();
	endif;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="update" id="fea40ee6-4ceb-40cb-9c01-44b8281864fa">
        <updating/>
        <source>update(pHelp : CnEcHelp; pProject : String; pDate : TimeStamp; pEstimate, pTime : Real) : String updating;

vars
	projStr	: String;

begin
	if pHelp = null then
		return "No help schema supplied";
	endif;

	projStr := pProject.trimBlanks;

	if projStr.length &gt; 20 then
		return "Project length too long (" &amp; pProject &amp; ")";
	elseif projStr.length = 0 then
		return "No project supplied";
	elseif projStr &lt;&gt; self.project then
		self.project := projStr;
	endif;

	if pDate &lt;&gt; self.date then
		self.date := pDate;
	endif;

	if pEstimate &gt; 0 and pEstimate &lt;&gt; self.timeEstimate then
		self.timeEstimate := pEstimate;
	endif;

	if pTime &lt;&gt; self.timeUsed then
		self.timeUsed := pTime;
	endif;

	if self.myHelp &lt;&gt; pHelp then
		self.myHelp := pHelp;
	endif;

	return "";
end;</source>
        <Parameter name="pHelp" type="CnEcHelp"/>
        <Parameter name="pProject" type="String"/>
        <Parameter name="pDate" type="TimeStamp"/>
        <Parameter name="pEstimate" type="Real"/>
        <Parameter name="pTime" type="Real"/>
        <ReturnType type="String"/>
    </JadeMethod>
</Class>
