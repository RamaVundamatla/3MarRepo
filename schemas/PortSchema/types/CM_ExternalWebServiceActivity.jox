    <JadeMethod name="validate" id="67d15621-6624-4659-a7ac-eaeedc90489c">
        <source>validate();
/*
Purpose:			

Date		Who		Reason
26JUL2021	NAVAB1	TFS 50669
*/

vars

begin

	if self.myRoot = null and self.myTerminal = null then		
		app.raiseCMException(Input_required_field_cmRotCmTr, null, null);
		return;
	endif;

	if not self.created.isValid then
		app.raiseCMException1(ERR_INVALID_TIMESTAMP, null,  null, null);
		return;
	endif;
	
	if self.description = null then
		app.raiseCMException1(Input_required_field_Required, app.getErrorString(Description), null, null); 
		return;
	endif;


end;</source>
    </JadeMethod>
