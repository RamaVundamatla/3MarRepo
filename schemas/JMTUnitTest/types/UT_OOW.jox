    <JadeMethod name="tGetOOWJobIndex" id="89c81da7-927a-4fd5-ae93-350f2f2f8118">
        <source>tGetOOWJobIndex();
// cnwer1
/*

Purpose:			

Parameters:			

Return Value:		


Date			Who		Reason
29 October 2008	cnwer1	Initial creation
20/02/2012		cnwmh5	Change so that doesn't use the oid
*/

vars
	voyage : CM_Voyage;
	terminal : CM_Terminal;
	testStringDesc : String;
	index : Integer;
	job  : CM_VoyageJob;
	obj		: Object;
begin
	terminal := self.getTerminal;
	assertTrueMsg(terminal.code = "JBL", "Terminal &lt;&gt; JBL");
	voyage := terminal.lookupVoyage("PTN010010",null,false);
	assertTrueMsg(voyage &lt;&gt; null, "Failed to find PTN010010 voyage");
	
	if voyage = null then
		return;
	endif;
	
	foreach obj in voyage.allVoyageJobs discreteLock do
		job := obj.CM_VoyageJob;
		if job.id = "320" then
			break;
		endif;
	endforeach;
	self.assertNotNull(job);
	
	//job:="2271.1591".asOid.CM_VoyageJob; //job 320
	
	index:=voyage.getOOWJobIndex(CMQF_VoyageOrderOfWork.JobType_All,false,job);
	testStringDesc:="Test all  OOW jobs get index : ";
	assertTrueMsg(index = 10, testStringDesc &amp; "index &lt;&gt; 10 index = " &amp; index.String);

	
	index:=voyage.getOOWJobIndex(CMQF_VoyageOrderOfWork.JobType_All,true,job);
	testStringDesc:="Test all  OOW jobs  hide boom and hatch jobs get index : ";
	assertTrueMsg(index = 7, testStringDesc &amp; "index &lt;&gt; 7 index = " &amp; index.String);
	
	
	index:=voyage.getOOWJobIndex(CMQF_VoyageOrderOfWork.JobType_Crane,false,job);
	testStringDesc:="Test all crane OOW jobs get index : ";
	assertTrueMsg(index = 5, testStringDesc &amp; "index &lt;&gt; 5 index = " &amp; index.String);
	
	index:=voyage.getOOWJobIndex(CMQF_VoyageOrderOfWork.JobType_Crane,true,job);
	testStringDesc:="Test all crane OOW jobs  hide boom and hatch jobs get index : ";
	assertTrueMsg(index = 4, testStringDesc &amp; "index &lt;&gt; 4 index = " &amp; index.String);
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="tGetOOWJobs" id="46e44835-9c70-45c0-b3ce-54a21713cd52">
        <source>tGetOOWJobs();
// cnwer1
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 October 2008	cnwer1	Initial creation

*/

vars
	voyage : CM_Voyage;
	terminal : CM_Terminal;
	allJobs : CM_JobArray;
	testStringDesc : String;
begin
	terminal := self.getTerminal;
	assertTrueMsg(terminal.code = "JBL", "Terminal &lt;&gt; JBL");
	voyage := terminal.lookupVoyage("PTN010010",null,false);
	assertTrueMsg(voyage &lt;&gt; null, "Failed to find PTN010010 voyage");
	
	if voyage = null then
		return;
	endif;
	
	create allJobs transient;
	//Test 1 get all jobs
	voyage.getOOWJobs(CMQF_VoyageOrderOfWork.JobType_All,null,false,allJobs);
	
	testStringDesc:="Test all OOW jobs : ";
	assertTrueMsg(allJobs.size = 13, testStringDesc &amp; "size &lt;&gt; 13 size = " &amp; allJobs.size.String);
	if allJobs.size = 13 then
		assertTrueMsg(allJobs[1].CM_Job.id = "100", testStringDesc &amp; "1st job id &lt;&gt; 100");
		assertTrueMsg(allJobs[2].CM_Job.id = "105", testStringDesc &amp; "2nd job id &lt;&gt; 105");
		assertTrueMsg(allJobs[3].CM_Job.id = "110", testStringDesc &amp; "3rd job id &lt;&gt; 110");
		assertTrueMsg(allJobs[4].CM_Job.id = "115", testStringDesc &amp; "4th job id &lt;&gt; 115");
		assertTrueMsg(allJobs[5].CM_Job.id = "120", testStringDesc &amp; "5th job id &lt;&gt; 120");
		assertTrueMsg(allJobs[6].CM_Job.id = "300", testStringDesc &amp; "6th job id &lt;&gt; 300");
		assertTrueMsg(allJobs[7].CM_Job.id = "305", testStringDesc &amp; "7th job id &lt;&gt; 305");
		assertTrueMsg(allJobs[8].CM_Job.id = "310", testStringDesc &amp; "8th job id &lt;&gt; 310");
		assertTrueMsg(allJobs[9].CM_Job.id = "315",testStringDesc &amp; "9th job id &lt;&gt; 315");
		assertTrueMsg(allJobs[10].CM_Job.id = "320", testStringDesc &amp; "10th job id &lt;&gt; 320");
		assertTrueMsg(allJobs[11].CM_Job.id = "325", testStringDesc &amp; "11th job id &lt;&gt; 325");
		assertTrueMsg(allJobs[12].CM_Job.id = "330", testStringDesc &amp; "12th job id &lt;&gt; 330");
		assertTrueMsg(allJobs[13].CM_Job.id = "335", testStringDesc &amp; "13th job id &lt;&gt; 335");
	endif;
	
	allJobs.clear;
	
	//Test 2 get crane jobs
	voyage.getOOWJobs(CMQF_VoyageOrderOfWork.JobType_Crane,"J12",false,allJobs);
	testStringDesc:="Test crane OOW jobs : ";
	assertTrueMsg(allJobs.size = 7, testStringDesc &amp; " size &lt;&gt; 7 size = " &amp; allJobs.size.String);
	if allJobs.size = 7 then
		assertTrueMsg(allJobs[1].CM_Job.id = "300", testStringDesc &amp; " 1st  job id &lt;&gt; 300");
		assertTrueMsg(allJobs[2].CM_Job.id = "305", testStringDesc &amp; "2nd job id &lt;&gt; 305");
		assertTrueMsg(allJobs[3].CM_Job.id = "310", testStringDesc &amp; " 3rd job id &lt;&gt; 310");
		assertTrueMsg(allJobs[4].CM_Job.id = "315", testStringDesc &amp; "4th job id &lt;&gt; 315");
		assertTrueMsg(allJobs[5].CM_Job.id = "320", testStringDesc &amp; " 5th job id &lt;&gt; 320");
		assertTrueMsg(allJobs[6].CM_Job.id = "325", testStringDesc &amp; "6th job id &lt;&gt; 325");
		assertTrueMsg(allJobs[7].CM_Job.id = "330", testStringDesc &amp; "7th job id &lt;&gt; 330");
	endif;
	
	allJobs.clear;
	
	//Test 3 get all complete jobs
	voyage.getOOWJobs(CMQF_VoyageOrderOfWork.JobType_Complete,null,false,allJobs);
	testStringDesc:="Test complete OOW jobs : ";
	assertTrueMsg(allJobs.size = 8, testStringDesc &amp; " size &lt;&gt; 8 size = " &amp; allJobs.size.String);
	if allJobs.size = 8 then
		assertTrueMsg(allJobs[1].CM_Job.id = "105", testStringDesc &amp; "1nd job id &lt;&gt; 105");
		assertTrueMsg(allJobs[2].CM_Job.id = "115", testStringDesc &amp; "2nd job id &lt;&gt; 115");
		assertTrueMsg(allJobs[3].CM_Job.id = "120", testStringDesc &amp; "3rd job id &lt;&gt; 120");
		assertTrueMsg(allJobs[4].CM_Job.id = "305", testStringDesc &amp; "4th job id &lt;&gt; 305");
		assertTrueMsg(allJobs[5].CM_Job.id = "310", testStringDesc &amp; "5th job id &lt;&gt; 310");
		assertTrueMsg(allJobs[6].CM_Job.id = "315",testStringDesc &amp; "6th job id &lt;&gt; 315");
		assertTrueMsg(allJobs[7].CM_Job.id = "320", testStringDesc &amp; "7th job id &lt;&gt; 320");
		assertTrueMsg(allJobs[8].CM_Job.id = "330", testStringDesc &amp; "8th job id &lt;&gt; 330");
	endif;
	
	allJobs.clear;
	
	//Test 4 get all part complete jobs
	voyage.getOOWJobs(CMQF_VoyageOrderOfWork.JobType_PartComplete,null,false,allJobs);
	testStringDesc:="Test part complete OOW jobs : ";
	assertTrueMsg(allJobs.size = 0, testStringDesc &amp; " size &lt;&gt; 0 size = " &amp; allJobs.size.String);
	
	allJobs.clear;
	
	//Test 5 get all unallocated jobs
	voyage.getOOWJobs(CMQF_VoyageOrderOfWork.JobType_Unallocated,null,false,allJobs);
	testStringDesc:="Test unallocated OOW jobs : ";
	assertTrueMsg(allJobs.size = 0, testStringDesc &amp; " size &lt;&gt; 0 size = " &amp; allJobs.size.String);
	
	allJobs.clear;
	
	//Test 6 get crane jobs hide boom and hatch
	voyage.getOOWJobs(CMQF_VoyageOrderOfWork.JobType_Crane,"J10",true,allJobs);
	testStringDesc:="Test crane no boom or hatch OOW jobs : ";
	assertTrueMsg(allJobs.size = 3, testStringDesc &amp; " size &lt;&gt; 3 size = " &amp; allJobs.size.String);
	if allJobs.size = 3 then
		assertTrueMsg(allJobs[1].CM_Job.id = "105", testStringDesc &amp; "1nd job id &lt;&gt; 105");
		assertTrueMsg(allJobs[2].CM_Job.id = "115", testStringDesc &amp; "2nd job id &lt;&gt; 115");
		assertTrueMsg(allJobs[3].CM_Job.id = "120", testStringDesc &amp; "3rd job id &lt;&gt; 120");
	endif;
	allJobs.clear;
epilog
	delete allJobs;
end;</source>
    </JadeMethod>
</Class>
