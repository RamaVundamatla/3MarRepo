    <JadeMethod name="getExtractFormatDescrToFmt" id="52aff80c-c89a-48f3-82e7-27b7289e6193">
        <source>getExtractFormatDescrToFmt(_str : String) : Integer protected;
// ---------------------------------------------------------------------------
// Created:		05 August 2003 by cnwsb1
// ---------------------------------------------------------------------------
vars
	int : Integer;

begin
	foreach int in CM_DataDumpExtractDef.FmtMin to CM_DataDumpExtractDef.FmtMax where
			global.getExtractFormatDescr(int) = _str do
		return int;
	endforeach;
	
	return null;
end;</source>
        <access>protected</access>
        <Parameter name="_str" type="String"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
