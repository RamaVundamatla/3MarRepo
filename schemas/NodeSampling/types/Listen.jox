    <JadeMethod name="load" id="d3583336-ab82-4248-ae74-4c780661a5e7">
        <controlMethod name="Form::load"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>load() updating;

vars

begin

	jdbMisc.parentAspect := Control.ParentAspect_StretchBoth ;
	jdcControl.parentAspect := Control.ParentAspect_StretchBoth ;

	left := 0;
	top  := 0;

	create v_tcpHandler;
	create v_tcpHandler.v_sample transient;
	app.myListener := self;

	v_root := Root.firstInstance;
	if v_root = null then
		firstTimeInitialize;
		return;
	endif;

	loadingForm;
end;</source>
    </JadeMethod>
    <JadeMethod name="loadNodes" id="81c94e87-24b8-479e-b48a-df708639c883">
        <updating/>
        <source>loadNodes() updating;
constants

vars
	n     : Node;
	st    : String;
	index : Integer;
begin
	beginClassNotification(Node, false, Any_System_Event, Response_Continuous, 1);
	lbx_Nodes.multiSelect := 2;
	foreach n in system.nodes do

		v_nodeArray.add( n );

	endforeach;
	refreshNodeDisplay;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="loadPrinters" id="c6666fb0-fe54-4372-bb7c-91d8a5715a6b">
        <updating/>
        <source>loadPrinters() updating;

vars

	defaultPrinter : String;
	defaultIndex   : Integer;
	i       : Integer;
	index   : Integer;
	printerArray : StringArray;

begin
	//
	//	Get the default printer
	//
    defaultPrinter := app.printer.getPrinterName;
	//
	//	Get all the printers I can see
	//
	create printerArray transient;
	i := app.printer.getAllPrinters(printerArray);

	foreach index in 1 to i do
		lbx_Printers.addItem(printerArray [ index ]);
		if printerArray [ index ] = defaultPrinter then
			defaultIndex := index;
		endif;
	endforeach;
	if defaultIndex &lt;&gt; 0 then
		lbx_Printers.listIndex := defaultIndex;
		lbx_Printers.topIndex  := defaultIndex;
	endif;
epilog
	delete printerArray;
end;</source>
    </JadeMethod>
    <JadeMethod name="loadingForm" id="0c5050dc-7812-49fb-9fba-c9660eaf7e3d">
        <updating/>
        <source>loadingForm() updating;

vars
	scrollWidth : Integer;
begin

	chx_Increments.value := false;
	handleIncrementColumn(chx_Increments.value);

	v_tcpHandler.includeInstances  := chx_Instances.value;
	v_tcpHandler.dropSystemClasses := chx_DropSystem.value;
	v_tcpHandler.showIncrements    := chx_Increments.value;
	v_tcpHandler.v_remote          := chx_Remote.value;
	v_tcpHandler.v_outputMethodName:= chx_Output.value;
	v_tcpHandler.v_Get             := true;
	v_tcpHandler.v_Lock            := true;
	v_tcpHandler.v_Unlock          := true;
	v_tcpHandler.v_Update          := true;
	v_tcpHandler.v_Note            := true;
	v_tcpHandler.v_Create          := true;
	v_tcpHandler.v_Delete          := true;
	v_tcpHandler.v_GetEdn          := true;
	tbx_InstId.visible             := v_tcpHandler.includeInstances;
	l_InstId.visible               := v_tcpHandler.includeInstances;

	lbx_System.listCollection(v_root.allEnvironments, true, 0);
	setupTables;
	loadNodes;
	v_environment := v_root.allEnvironments.first;
	if v_environment &lt;&gt; null then
		caption := 'Using ' &amp; "'" &amp; v_environment.name &amp; "' System";
		lbx_System.listIndex := 1;	
	endif;

	loadPrinters;
	setupSkins;
	v_tcpHandler.v_environment := v_environment;
	l_Title.caption := l_Title.caption &amp; ' ( ' &amp; node.String &amp; '  ' &amp; node.name &amp; ' )';
	registerNotifications;

	processCommandline;

	scrollWidth := getSystemMetrics(Window.SM_cxVScroll) + 1;
	tbl_Messages.columnWidth [ 1 ] := (tbl_Messages.width - scrollWidth).Integer;

	if app.isUnicode() then	// 16/3/16 cnwmp6 PAR 36286 unicode version
		sl_Status.caption := 'Unicode ' &amp; app.getSystemVersion &amp; '.' &amp; rootSchema.patchVersion.String;
	else
		sl_Status.caption := 'Ansi ' &amp; app.getSystemVersion &amp; '.' &amp; rootSchema.patchVersion.String;
	endif;

	sl_Status.caption := sl_Status.caption &amp; ', Sampling version ' &amp; app.appVersion;
	getIniSettings;
	getMonitorStatistics;
	getJadeVersion;
	tbx_CacheCon.text := '';
	v_sampleIterator := v_tcpHandler.v_sampleMessageSet.createIterator;
end;</source>
    </JadeMethod>
    <JadeMethod name="outputWaitInformation" id="dce2159c-8ca6-491e-a6c8-5d32e5b5be6b">
        <updating/>
        <source>outputWaitInformation(row : JadeTableRow) updating;

vars
	sampleObject : SampleObjects;
	output       : String;
begin

	sampleObject := row.itemObject.SampleObjects;
	if sampleObject = null then
		return;
	endif;

	if sampleObject.type = Lock_Request then
		output := 'Lock ';
	elseif sampleObject.type = Get_Request then
		output := 'Get ';
	else
		output := 'unknown ';
	endif;
	sl_Status.caption := output &amp; 
	                     'Times waited ' &amp; sampleObject.queuedCount.String &amp; ', ' &amp;
	                     'Total wait time ' &amp; sampleObject.queuedTime.String &amp; ' milli seconds';

end;</source>
        <Parameter name="row" type="JadeTableRow"/>
    </JadeMethod>
    <JadeMethod name="printOutput" id="c5e4b10a-a836-4f5b-bd7f-b7aa6dbda26d">
        <updating/>
        <source>printOutput() updating;
constants
	PaleTurquoise : Integer = 15658671;
	Lavender      : Integer = 16443110;
vars
	footerDesc    : String;
	sampleMessage : SampleMessages;
	text          : String;
	type          : String;
	result        : Integer;
	limit         : Integer;
begin

	limit := tbx_limit.text.Integer;
	if v_tcpHandler.includeInstances = true then
		footerDesc := 'Including instances, ';
	else
		footerDesc := 'Classes only,  ';
	endif;
	
	if v_tcpHandler.dropSystemClasses = true then
		footerDesc := footerDesc &amp; 'Excluding System classes';
	else
		footerDesc := footerDesc &amp; 'Including System classes';
	endif;

	footerDesc := footerDesc &amp; ', Counts &gt;= ' &amp; limit.String;
	if tbx_PrintMessage.text.trimBlanks &lt;&gt; null then
		footerDesc := footerDesc &amp; CrLf &amp; tbx_PrintMessage.text.trimBlanks;
	endif;

	create v_tcpHandler.printForm transient;
	v_tcpHandler.printForm.l_FooterDesc.caption := footerDesc;

	if lbx_Printers.listIndex &gt; 0 then
		app.printer.setPrinter(lbx_Printers.text);
		if lbx_Printers.text.toLower = 'win2pdf' then
			if tbx_PrintMessage.text.trimBlanks &lt;&gt; null then
				app.printer.setPrintFileName (tbx_PrintMessage.text.trimBlanks &amp; '.pdf');
			endif;
		endif;
	endif; 

	if chx_Preview.value = true then
		app.printer.printPreview := true;
	endif;
	//
	// Print creates
	//
	if chx_Create.value = true then
		result := v_tcpHandler.printOutput(v_environment, v_sampleByCountCreate, 'Creates', limit);
		if result &lt;&gt; 0 then
			return;
		endif;
		app.printer.newPage;
	endif;
	//
	// Print deletes
	//
	if chx_Delete.value = true then
		result := v_tcpHandler.printOutput(v_environment, v_sampleByCountDelete, 'Deletes', limit);
		if result &lt;&gt; 0 then
			return;
		endif;
		app.printer.newPage;
	endif;
	//
	// Print updates
	//
	if chx_Update.value = true then
		result := v_tcpHandler.printOutput(v_environment, v_sampleByCountUpdate, 'Updates', limit);
		if result &lt;&gt; 0 then
			return;
		endif;
		app.printer.newPage;
	endif;
	//
	// Print gets
	//
	if chx_Get.value = true then
		result := v_tcpHandler.printOutput(v_environment, v_sampleByCountGet,    'Gets', limit);
		if result &lt;&gt; 0 then
			return;
		endif;
		app.printer.newPage;
	endif;
	//
	// Print locks
	//
	if chx_Lock.value = true then
		result := v_tcpHandler.printOutput(v_environment, v_sampleByCountLock,   'Locks', limit);
		if result &lt;&gt; 0 then
			return;
		endif;
		app.printer.newPage;
		result := v_tcpHandler.printOutput(v_environment, v_sampleByCountQLock,  'Queued Locks', limit);
		if result &lt;&gt; 0 then
			return;
		endif;
		app.printer.newPage;
	endif;
	//
	// Print unlocks
	//
	if chx_Unlock.value = true then
		result := v_tcpHandler.printOutput(v_environment, v_sampleByCountUnlock, 'Unlocks', limit);
		if result &lt;&gt; 0 then
			return;
		endif;
		app.printer.newPage;
	endif;
	//
	// Print get editions
	//
	if chx_GetEdn.value = true then
		result := v_tcpHandler.printOutput(v_environment, v_sampleByCountGetEdition, 'Gets Editions', limit);
		if result &lt;&gt; 0 then
			return;
		endif;
		app.printer.newPage;
	endif;
	//
	// Print notes
	//
	if chx_Note.value = true then
		result := v_tcpHandler.printOutput(v_environment, v_sampleByCountNote,   'Notifications', limit);
		if result &lt;&gt; 0 then
			return;
		endif;
	endif;
	//
	// Print methods
	//
	if v_tcpHandler.v_sampleMessageSet.size &gt; 0 then

		v_tcpHandler.printForm.tbl_1_1.row := 1;
		v_tcpHandler.printForm.tbl_1_1.text := '' &amp; Tab &amp; '' &amp; Tab &amp; '' &amp; Tab &amp; '';
		v_tcpHandler.printForm.tbl_1_1.row := 2;
		v_tcpHandler.printForm.tbl_1_1.text := 'Time' &amp; Tab &amp; '' &amp; Tab &amp; '' &amp; Tab &amp; '';
		v_tcpHandler.printForm.l_title.caption := 'Methods where action occurred';
		app.printer.newPage;
		foreach sampleMessage in v_tcpHandler.v_sampleMessageSet do
			type := sampleMessage.type;
			v_tcpHandler.printForm.fr_methodInfor.backColor := White;
			if type = 'BT ' then
				v_tcpHandler.printForm.fr_methodInfor.backColor := Yellow;
			elseif type = 'ET ' then
				v_tcpHandler.printForm.fr_methodInfor.backColor := PaleTurquoise;
			endif;
			v_tcpHandler.printForm.fr_methodInfor.caption := sampleMessage.time.String &amp; 
			    '.' &amp; sampleMessage.time.milliSecond.padLeadingWith('0', 3) &amp; ' ' &amp; type &amp; 
			    sampleMessage.message;
			result := app.printer.print(v_tcpHandler.printForm.fr_methodInfor);
			if result &lt;&gt; 0 then
				return;
			endif;
		endforeach;
	endif;
	app.printer.close;
epilog

	if result = Print_Cancelled then
		app.printer.close;
	endif;
	delete v_tcpHandler.printForm;
	app.printer.abort;

end;</source>
    </JadeMethod>
    <JadeMethod name="processCommandline" id="3ff80385-2919-4ba1-a5c5-c0cd79debe1b">
        <updating/>
        <source>processCommandline() updating;

vars
	commandLine : String;
	pos         : Integer;
	data        : String;
	command     : String;
	value       : String;
	jadeSkin    : JadeSkin;
	jsColl      : JadeSkinsColl;
begin

	if IsUnicodeSystem then
		commandLine := call getCommandLineU;
	else
		commandLine := call getCommandLine;
	endif;

	pos := 1;
	pos := commandLine.pos('endJade', pos);
	if  pos &gt; 0 then
		data := commandLine [ pos + 7 : end ].trimBlanks;
	else
		return;
	endif;
	pos := 1;
	while true do

		command := data.getToken(pos);
		if command = null then 
			break;
		endif;
		value := data.getToken(pos);
		if value = null then 
			app.msgBox('No value for command - ' &amp; command, 'Warning', MsgBox_OK_Only);
			return;
		endif;
		if command.toLower = 'port' then
			tbx_Port.text := value;
		endif;

		if command.toLower = 'dropsystem' then
			chx_DropSystem.value := value.toLower.Boolean;
		endif;

		if command.toLower = 'skin' then
			jsColl := JadeSkinsColl.firstInstance;
			if jsColl &lt;&gt; null then
				if value = 'first' then
					app.setSkin(jsColl.first);
				elseif value = 'last' then
					app.setSkin(jsColl.last);
				else
					foreach jadeSkin in jsColl do
						if jadeSkin.name.toLower = value.toLower then
							app.setSkin(jadeSkin);
							break;
						endif;
					endforeach;
				endif;
			endif;
		endif;
	endwhile;
end;</source>
    </JadeMethod>
    <JadeMethod name="refreshNodeDisplay" id="6f3b2e22-c944-49b8-9c94-bc388c10205d">
        <updating/>
        <source>refreshNodeDisplay() updating;
constants

vars
	o     : Object;
	n     : Node;
	st    : String;
	index : Integer;
begin
	lbx_Nodes.clear;

	foreach o in v_nodeArray do
		n  := o.Node;
		st := 'Node- ' &amp; n.name;
		if n.isServerNode then
			st := st &amp; ' &lt; server &gt;';
		elseif n.isApplicationServer then
			st := st &amp; ' &lt; app server &gt;';
		endif;
		
		if n = node then
			st := st &amp; ' Sampler Node ';
		endif;
		
		index := lbx_Nodes.addItem( st );
		lbx_Nodes.itemObject[index] := n;
		lbx_Nodes.itemBackColor[index] := White;
		if v_selectedNodeArray.includes(n) then
			lbx_Nodes.itemSelected[index]  := true;
		endif;
		if n = node then
			lbx_Nodes.itemBackColor[index] := LightYellow;
		endif;
	endforeach;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="refreshTables" id="07c3828d-cd4f-4361-88c2-b6ce1f70738d">
        <updating/>
        <source>refreshTables(_update : Boolean) updating;

vars

	sampleObject  : SampleObjects;
	scrollWidth   : Integer;
	total         : Integer;
	qtotal        : Integer;
	increment     : Integer; // Current not outputted
	qincrement    : Integer; // Current not outputted
begin

	v_sampleByCountGet.clear;
	total     := 0;
	increment := 0;
	foreach sampleObject in app.myListener.v_sampleGets do
		if _update then
			calculateFigures (sampleObject, total, increment);
		endif;
		v_sampleByCountGet.add(sampleObject);
	endforeach;
	l_get_total.caption := total.String;

	tbl_Stats_Get.displayCollection(v_sampleByCountGet, false, 0, null);
	//
	//  Process Locks
	//
	v_sampleByCountLock.clear;
	v_sampleByCountQLock.clear;
	total     := 0;
	increment := 0;
	foreach sampleObject in app.myListener.v_sampleLocks do
		if _update then
			calculateFigures (sampleObject, total, increment);
		endif;
		v_sampleByCountLock.add(sampleObject);
		if sampleObject.queuedCount &gt; 0 then
			v_sampleByCountQLock.add(sampleObject);
			qtotal     := qtotal + sampleObject.queuedCount;
			qincrement := qincrement + sampleObject.countIncrement;
		endif;
	endforeach;

	l_lock_total.caption  := total.String;
	l_qlock_total.caption := qtotal.String;

	tbl_Stats_Lock.displayCollection(v_sampleByCountLock, false, 0, null);
	tbl_Stats_QLock.displayCollection(v_sampleByCountQLock, false, 0, null);
	//
	//  Process Unlocks
	//
	v_sampleByCountUnlock.clear;
	total     := 0;
	increment := 0;
	foreach sampleObject in app.myListener.v_sampleUnlocks do
		if _update then
			calculateFigures (sampleObject, total, increment);
		endif;
		v_sampleByCountUnlock.add(sampleObject);
	endforeach;

	l_unlock_total.caption := total.String;

	tbl_Stats_Unlock.displayCollection(v_sampleByCountUnlock, false, 0, null);
	//
	//  Process Notifications
	//
	v_sampleByCountNote.clear;
	total     := 0;
	increment := 0;
	foreach sampleObject in app.myListener.v_sampleNotifications do
		if _update then
			calculateFigures (sampleObject, total, increment);
		endif;
		v_sampleByCountNote.add(sampleObject);
	endforeach;
	
	l_note_total.caption := total.String;

	tbl_Stats_Note.displayCollection(v_sampleByCountNote, false, 0, null);
	//
	// Process Updates
	//
	v_sampleByCountUpdate.clear;
	total     := 0;
	increment := 0;
	foreach sampleObject in app.myListener.v_sampleUpdates do
		if _update then
			calculateFigures (sampleObject, total, increment);
		endif;
		v_sampleByCountUpdate.add(sampleObject);
	endforeach;
	
	l_update_total.caption := total.String;

	tbl_Stats_Update.displayCollection(v_sampleByCountUpdate, false, 0, null);
	//
	// Process Creates
	//
	v_sampleByCountCreate.clear;
	total     := 0;
	increment := 0;
	foreach sampleObject in app.myListener.v_sampleCreates do
		if _update then
			calculateFigures (sampleObject, total, increment);
		endif;
		v_sampleByCountCreate.add(sampleObject);
	endforeach;

	l_create_total.caption := total.String;

	tbl_Stats_Create.displayCollection(v_sampleByCountCreate, false, 0, null);
	//
	// Process Deletes
	//
	v_sampleByCountDelete.clear;
	total     := 0;
	increment := 0;
	foreach sampleObject in app.myListener.v_sampleDeletes do
		if _update then
			calculateFigures (sampleObject, total, increment);
		endif;
		v_sampleByCountDelete.add(sampleObject);
	endforeach;
	
	l_delete_total.caption := total.String;

	tbl_Stats_Delete.displayCollection(v_sampleByCountDelete, false, 0, null);
	//
	// Process Get Editions
	//
	v_sampleByCountGetEdition.clear;
	total     := 0;
	increment := 0;
	foreach sampleObject in app.myListener.v_sampleGetEditions do
		if _update then
			calculateFigures (sampleObject, total, increment);
		endif;
		v_sampleByCountGetEdition.add(sampleObject);
	endforeach;
	l_getedn_total.caption := total.String;

	tbl_Stats_GetEdn.displayCollection(v_sampleByCountGetEdition, false, 0, null);


	scrollWidth := getSystemMetrics(Window.SM_cxVScroll) + 1;
	tbl_Messages.columnWidth [ 1 ] := (tbl_Messages.width - scrollWidth).Integer;
	tbl_Messages.displayCollection(v_tcpHandler.v_sampleMessageSet, false, 0, null);

end;</source>
        <Parameter name="_update" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="registerNotifications" id="1525ba2c-799a-4ee2-82a7-874c47bca676">
        <updating/>
        <source>registerNotifications() updating;

vars

begin
	beginNotification(app, Statusline_Message, Response_Continuous, process.number);
end;</source>
    </JadeMethod>
    <JadeMethod name="saveToCSVFile" id="e9b55eac-c87c-4644-bf16-3d6f2466f03e">
        <source>saveToCSVFile();

vars

	csvFile             : File;
	saveDialog			: CMDFileSave;
	row					: Integer;
	col					: Integer;
	pos                 : Integer;
	str					: String;
	output              : String;
	hsa					: HugeStringArray;
	sampleMessage       : SampleMessages;
begin
	//
	// Check if we have any output
	//
	if tbl_cache.rows &lt; 2 then
		app.msgBox('Save NOT Completed','Snap Shot Save', MsgBox_OK_Only);
		return;
	endif;

	create saveDialog transient;
	saveDialog.initDir 	:= 'C:\temp';
//	if opt_transient.value = true then
//		saveDialog.fileName	:= 'Transient Cache Statistics.csv';
//else
		saveDialog.fileName	:= 'Persistent Cache Statistics.csv';
//	endif;
	if saveDialog.open &lt;&gt; 0 then
		return;
	endif;

	app.mousePointer := Window.MousePointer_HourGlass;
	create csvFile;	
	csvFile.mode := File.Mode_Output; // 3/3/16  cnwns1 PAR 36286 unicode version
	csvFile.fileName:= saveDialog.fileName;
	csvFile.open;
	if chkSSNoDup.value = true then
		create hsa transient;
	endif;
	//setup file heading
	row := 1;
	str:= null;
	foreach col in 1 to tbl_cache.columns do
		if str = null then
			str:= tbl_cache.getCellText(row,col);
		else
			str:= str &amp; ',' &amp; tbl_cache.getCellText(row,col);
		endif;
	endforeach;
	//
	
	//
	csvFile.writeLine(str);
	foreach sampleMessage in v_tcpHandler.v_snapshotMessageSet do

		output := sampleMessage.message;
		output.replaceChar(Tab, ',');
		if chkSSNoDup.value then
			pos := 1;
			str := output.getToken(pos);
			if not hsa.includes(str) then
				hsa.add(output);
			endif;
		else
			csvFile.writeLine(output);
		endif;
	endforeach;
	if hsa &lt;&gt; null then
		foreach str in hsa do
			csvFile.writeLine(str);
		endforeach;
		delete hsa;
	endif;
	csvFile.close;
	app.msgBox('Save of Cache snapshot has Completed','Snap Shot Save', MsgBox_OK_Only);
	
epilog
	delete saveDialog;
	delete csvFile;
	app.mousePointer := Window.MousePointer_Default;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="saveToFile" id="b227823f-6df6-4a95-ade6-bea2d310900b">
        <updating/>
        <source>saveToFile() updating;
constants

vars
	file          : File;
	sampleMessage : SampleMessages;
	text          : String;
	type          : String;
	result        : Integer;
	limit         : Integer;
	timeData      : String;	
	saveDialog    : CMDFileSave;
begin

	limit := tbx_limit.text.Integer;
	create saveDialog transient;
	saveDialog.initDir 	:= 'C:\temp';
	saveDialog.fileName	:= 'Sampling Statistics.txt';		
	if saveDialog.open &lt;&gt; 0 then
		return;
	endif;

	app.mousePointer := Window.MousePointer_HourGlass;
	create file transient;
	file.fileName := saveDialog.fileName;
	file.mode     := File.Mode_Output;
	file.open;
	//
	// Save creates
	//
	if chx_Create.value = true then
		v_tcpHandler.saveToFile(v_environment, v_sampleByCountCreate, 'Creates', limit, file);
	endif;
	//
	// Save deletes
	//
	if chx_Delete.value = true then
		v_tcpHandler.saveToFile(v_environment, v_sampleByCountDelete, 'Deletes', limit, file);
	endif;
	//
	// Save updates
	//
	if chx_Update.value = true then
		v_tcpHandler.saveToFile(v_environment, v_sampleByCountUpdate, 'Updates', limit, file);
	endif;
	//
	// Save gets
	//
	if chx_Get.value = true then
		v_tcpHandler.saveToFile(v_environment, v_sampleByCountGet,    'Gets', limit, file);
	endif;
	//
	// Save locks
	//
	if chx_Lock.value = true then
		v_tcpHandler.saveToFile(v_environment, v_sampleByCountLock,   'Locks', limit, file);

		v_tcpHandler.saveToFile(v_environment, v_sampleByCountQLock,  'Queued Locks', limit, file);

	endif;
	//
	// Save unlocks
	//
	if chx_Unlock.value = true then
		v_tcpHandler.saveToFile(v_environment, v_sampleByCountUnlock, 'Unlocks', limit, file);
	endif;
	//
	// Save get editions
	//
	if chx_GetEdn.value = true then
		v_tcpHandler.saveToFile(v_environment, v_sampleByCountGetEdition, 'Gets Editions', limit, file);
	endif;
	//
	// Save notes
	//
	if chx_Note.value = true then
		v_tcpHandler.saveToFile(v_environment, v_sampleByCountNote,   'Notifications', limit, file);
	endif;
	//
	// Save methods
	//
	if v_tcpHandler.v_sampleMessageSet.size &gt; 0 then

		file.writeLine('Methods where action occurred' &amp; Tab &amp; '' &amp; Tab &amp; '' &amp; Tab &amp; '');
		file.writeLine('Time' &amp; Tab &amp; '' &amp; Tab &amp; '' &amp; Tab &amp; '');
		foreach sampleMessage in v_tcpHandler.v_sampleMessageSet do
			type := sampleMessage.type;
			timeData := sampleMessage.time.String &amp; '.' &amp; 
			            sampleMessage.time.milliSecond.padLeadingWith('0', 3) &amp; Tab &amp; type &amp; Tab &amp; sampleMessage.message;
			file.writeLine(timeData);
		endforeach;
	endif;
	file.close;
epilog
	app.mousePointer := Window.MousePointer_Default;
	delete file;

end;</source>
    </JadeMethod>
    <JadeMethod name="setupEachTable" id="ae557e9b-d143-479e-b885-83a5cc530ac7">
        <updating/>
        <source>setupEachTable(_table : Table io; _color : Integer) updating;
constants
vars
	column  : JadeTableColumn;
begin
	_table.fontName  := "Arial";
	_table.fontSize  := 8;
	_table.column    := 1;
	_table.row       := 1;
	column           := _table.accessColumn(1);
	column.backColor := _color;
	column           := _table.accessColumn(2);
	column.alignment := Table.Alignment_Right_Middle;
	column.backColor := _color;
	column           := _table.accessColumn(3);
	column.alignment := Table.Alignment_Right_Middle;
	column.backColor := _color;

	_table.text    := 'Class' &amp; Tab &amp; 'Count' &amp; Tab &amp; 'Inc';
	
epilog

end;</source>
        <Parameter name="_table" type="Table" usage="io"/>
        <Parameter name="_color" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setupInitialStatusline" id="d1fd7e24-add5-405c-8ba5-ead309b65f44">
        <updating/>
        <source>setupInitialStatusline() updating;

vars

begin
	if IsUnicodeSystem then
		sl_Status.caption := 'Unicode ' &amp; app.getSystemVersion &amp; '.' &amp; rootSchema.patchVersion.String;
	else
		sl_Status.caption := 'Ansi ' &amp; app.getSystemVersion &amp; '.' &amp; rootSchema.patchVersion.String;
	endif;

	sl_Status.caption := sl_Status.caption &amp; ', Sampling version ' &amp; app.appVersion;

end;</source>
    </JadeMethod>
    <JadeMethod name="setupSkins" id="bcaf4b65-3cbf-4e83-beeb-b0b0d02b2a9a">
        <updating/>
        <source>setupSkins() updating;

vars

	jsa:JadeSkinApplication;
begin

	foreach jsa in JadeSkinApplication.instances do
		if jsa.name = 'Aquatic' then
//		if jsa.name="Jarman_grey" then
			app.setApplicationSkin(jsa);
			break;
		endif;
	endforeach;

end;</source>
    </JadeMethod>
    <JadeMethod name="setupTables" id="7fd399c3-4664-461a-a6ee-32a1b1d669d9">
        <updating/>
        <source>setupTables() updating;

vars
	column  : JadeTableColumn;
	color   : Integer;
begin
	color := 16777200;
	setupEachTable(tbl_Stats_Get, color);
	setupEachTable(tbl_Stats_Lock, color);
	setupEachTable(tbl_Stats_Unlock, color);
	setupEachTable(tbl_Stats_Note, color);
	setupEachTable(tbl_Stats_Update, color);
	setupEachTable(tbl_Stats_Create, color);
	setupEachTable(tbl_Stats_Delete, color);
	setupEachTable(tbl_Stats_QLock, color);
	setupEachTable(tbl_Stats_GetEdn, color);
	refreshTables(true);
end;</source>
    </JadeMethod>
    <JadeMethod name="sl_Status_dblClick" id="34096ea0-b488-47f2-96ba-0b46e583f303">
        <controlMethod name="StatusLine::dblClick"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>sl_Status_dblClick(statusline: StatusLine input) updating;

vars

begin
	if process.isInLoadState then
		endLoad;
	else
		beginLoad;
	endif;
	sl_Status.caption := 'Time to connect - ' &amp; v_tcpHandler.numberOfOpens.String &amp; 
	                     " connections took " &amp; (v_tcpHandler.latestOpen - v_tcpHandler.firstOpen).String;
end;</source>
        <Parameter name="statusline" type="StatusLine" usage="input"/>
    </JadeMethod>
    <JadeMethod name="sysNotify" id="cce5fe64-bd9e-4841-9fa0-fe0ef8424f5e">
        <controlMethod name="Form::sysNotify"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>sysNotify(eventType: Integer; theObject: Object; eventTag: Integer) updating;
constants

vars

begin
	on Exception do handleNodeExceptions(exception);

	if eventType = Object_Create_Event then
		v_nodeArray.add(theObject);
	elseif eventType = Object_Delete_Event then
		v_nodeArray.remove(theObject);
	endif;
	refreshNodeDisplay;
epilog

end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="tbl_Messages_displayRow" id="bfe7ff76-1912-4335-9afb-8a449caa709d">
        <controlMethod name="Table::displayRow"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tbl_Messages_displayRow(table: Table input; theSheet: Integer; obj: Object; theRow: Integer; bcontinue: Boolean io):String updating;

vars
	sample : SampleMessages;
begin
	sample := obj.SampleMessages;
	return sample.type &amp; ' ' &amp; sample.message;
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="theSheet" type="Integer"/>
        <Parameter name="obj" type="Object"/>
        <Parameter name="theRow" type="Integer"/>
        <Parameter name="bcontinue" type="Boolean" usage="io"/>
        <ReturnType type="String"/>
    </JadeMethod>
