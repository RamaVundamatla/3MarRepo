    <JadeMethod name="getDateFormat" id="cc2d6726-10fe-4382-b429-4ac880ee77ac">
        <source>getDateFormat(pDateFormatObj:DateFormat io);
// -----------------------------------------------------------------------------
// Created:		24 December 2001 by cnwdad1
//
// Purpose:		Copies the property values from the receiver to the specified
//				DateFormat.
//
// Parameters:	pDateFormatObj - The DateFormat to update.
//
// Returns:		The DateFormat as an IO parameter.
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------
begin
	pDateFormatObj.activeCalendarType	:=	self.activeCalendarType;
	pDateFormatObj.dayHasLeadingZeros	:=	self.dayHasLeadingZeros;
	pDateFormatObj.firstDayOfWeek		:=	self.firstDayOfWeek;
	pDateFormatObj.firstWeekOfYear		:=	self.firstWeekOfYear;
	
	pDateFormatObj.longDayNames.purge();
	self.longDayNames.copy(pDateFormatObj.longDayNames);
	
	pDateFormatObj.longFormat			:=	self.longFormat;
	pDateFormatObj.longFormatOrder		:=	self.longFormatOrder;
	
	pDateFormatObj.longMonthNames.purge();
	self.longMonthNames.copy(pDateFormatObj.longMonthNames);
	
	pDateFormatObj.monthHasLeadingZeros	:=	self.monthHasLeadingZeros;
	pDateFormatObj.optionalCalendarType	:=	self.optionalCalendarType;
	pDateFormatObj.separator			:=	self.separator;
	
	pDateFormatObj.shortDayNames.purge();
	self.shortDayNames.copy(pDateFormatObj.shortDayNames);
	
	pDateFormatObj.shortFormat			:=	self.shortFormat;
	pDateFormatObj.shortFormatOrder		:=	self.shortFormatOrder;
	
	pDateFormatObj.shortMonthNames.purge();
	self.shortMonthNames.copy(pDateFormatObj.shortMonthNames);
	
	pDateFormatObj.showFullCentury		:=	self.showFullCentury;
end;</source>
        <Parameter name="pDateFormatObj" type="DateFormat" usage="io"/>
    </JadeMethod>
    <JadeMethod name="updateMe" id="7bc5dd1a-b342-43d7-a57d-1516a52e1356">
        <updating/>
        <source>updateMe(pDateFormatObj:DateFormat) updating;
// -----------------------------------------------------------------------------
// Created:		24 December 2001 by cnwdad1
//
// Purpose:		Copies the property values from the specified DateFormat to the
//				receiver.
//
// Parameters:	pDateFormatObj - The DateFormat, who's property values to copy.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------
begin
	self.activeCalendarType		:=	pDateFormatObj.activeCalendarType;
	self.dayHasLeadingZeros		:=	pDateFormatObj.dayHasLeadingZeros;
	self.firstDayOfWeek			:=	pDateFormatObj.firstDayOfWeek;
	self.firstWeekOfYear		:=	pDateFormatObj.firstWeekOfYear;
	
	self.longDayNames.purge();
	pDateFormatObj.longDayNames.copy(self.longDayNames);
	
	self.longFormat				:=	pDateFormatObj.longFormat;
	self.longFormatOrder		:=	pDateFormatObj.longFormatOrder;
	
	self.longMonthNames.purge();
	pDateFormatObj.longMonthNames.copy(self.longMonthNames);
	
	self.monthHasLeadingZeros	:=	pDateFormatObj.monthHasLeadingZeros;
	self.optionalCalendarType	:=	pDateFormatObj.optionalCalendarType;
	self.separator				:=	pDateFormatObj.separator;
	
	self.shortDayNames.purge();
	pDateFormatObj.shortDayNames.copy(self.shortDayNames);
	
	self.shortFormat			:=	pDateFormatObj.shortFormat;
	self.shortFormatOrder		:=	pDateFormatObj.shortFormatOrder;
	
	self.shortMonthNames.purge();
	pDateFormatObj.shortMonthNames.copy(self.shortMonthNames);
	
	self.showFullCentury		:=	pDateFormatObj.showFullCentury;
end;</source>
        <Parameter name="pDateFormatObj" type="DateFormat"/>
    </JadeMethod>
</Class>
