    <JadeMethod name="isTrouble" id="40d13e9a-2e63-43d0-829f-67a739ca984c">
        <source>isTrouble() : Boolean;
// ---------------------------------------------------------------------------
// Created:     26 September 2008 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	if self.isStatement() then
		return false;
	endif;
	if self.isOpen() then
		return true;
	endif;
	
	return false;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
