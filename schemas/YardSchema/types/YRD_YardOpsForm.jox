    <JadeMethod name="initTblJobs" id="2a414081-e654-41de-b629-92489e44540d">
        <updating/>
        <source>initTblJobs() updating;
// -----------------------------------------------------------------------------
// Created:		21 July 2009 by consw1
//
// Purpose:		Initialise Jobs table
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------

vars
	theDef : EntTableDef;

begin
	self.tblJobs.userInputEnabled := false;
	self.tblJobs.multiSelect := self.tblWorkEntries.multiSelect;
	self.tblJobs.selectMode := Table.SelectMode_CurrentRow;
	self.tblJobs.selectionType := self.tblJobs.SelectionType_Row;	
	self.tblJobs.stretchToParent := true;				
	self.tblJobs.selectMode := Table.SelectMode_FixedRow;

	theDef := app.myController.getEntTableDef(ETDef_YardOpsJobs);

	self.tblJobs.setTerminologyRelevant(null,self.myTerminal);
	self.tblJobs.setTblDataEntRowsFromDef(theDef);

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="initTblWorkEntries" id="46d37eac-46dd-4e89-a285-ee91ab2763e8">
        <updating/>
        <source>initTblWorkEntries() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 July 2009	cnwrd1	Initial creation

*/

vars
	theDef : EntTableDef;
begin

	inheritMethod();	
	theDef := app.myController.getEntTableDef(ETDef_YardOpsWLE);

	self.tblWorkEntries.setTerminologyRelevant(null,self.myTerminal);
	//If there is no user window then we sort by dwell time
	self.tblWorkEntries.zAddSortColumn(ETRow_DwellTimeStr, true);
	self.tblWorkEntries.setTblDataEntRowsFromDef(theDef);
//	self.tblWorkEntries.allTblDataSortColumns.clear();
//	self.tblWorkEntries.allTblDataSortDescending.clear();

	self.tblWorkEntries.selectMode := Table.SelectMode_FixedRow;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="keyDown" id="f2d59bdc-198c-440e-bfc2-e93daab89e52">
        <controlMethod name="Form::keyDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>keyDown(keyCode: Integer io; shift: Integer) updating;
// -----------------------------------------------------------------------------
// Created:		21 July 2009 by consw1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------

vars

begin
	if keyCode = CMUI_Key_F3 then
		if app.isControlKeyDown()
		and not app.isAltKeyDown()
		and not app.isShiftKeyDown() then
			inheritMethod(keyCode, shift);
		else
			self.showSearcher(self.frmSearcher.visible);
		endif;
		return;
	endif;
	
	inheritMethod(keyCode, shift);

epilog

end;</source>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="loadDataForFirstTime" id="c449f47d-7326-4b1f-ae80-1d66fede7c55">
        <updating/>
        <source>loadDataForFirstTime() updating, protected;
// -----------------------------------------------------------------------------
// Created:		21 July 2009 by consw1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------

vars
	wleArray : CM_WLEArray;

begin
	if CM_Job.hasInstance(self.myCurrentJob) then
		if self.myCurrentJob.id &lt;&gt; null then
			self.txtJobId.text := self.myCurrentJob.id;
		else
			self.txtJobId.text := self.myCurrentJob.jobId;
		endif;
		self.filterJobId := self.txtJobId.text.trimBlanks();
		if self.filterJobId &lt;&gt; null then
			self.filterDateFrom := null;
			self.mskDateFrom.setDate(null);
		endif;
		
		
		self.doShowSearch();
		/*
		create wleArray transient;
		self.myCurrentJob.getAllWLEs(wleArray);		
		self.displayWLEs(wleArray);
		*/
	else
		self.showSearcher(false);
	endif;

epilog
	delete wleArray;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="loadShippingLine" id="7e467e68-5e16-4f81-9b2d-755e4cbbce57">
        <source>loadShippingLine();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 May 2022	navtnr20	ChangeRequest 53204: EUP - GEN/REP/INB - Additional Cargo Field – Shipping Line - UI

*/

vars
	shippingLine : CM_ShippingLine;
	combo : CMUI_ComboBox;
begin
	combo := self.cmbShippingLine;
	combo.clear();
	foreach shippingLine in app.myRoot.allShippingLines do
		combo.addItemObject(shippingLine.code &amp;"   "&amp; shippingLine.description, shippingLine);
	endforeach;	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="loadTaskTypes" id="1a560f07-9db2-4c7c-a31f-b93b75e47e03">
        <source>loadTaskTypes();
// -----------------------------------------------------------------------------
// Created:		25 August 2009 by consw1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
// 09/05/2018	jlgdap1		TFS 38501 PEL1 Work Order Changes
// 16/09/2019	jlgsl4		TFS 46517 - POL - Yard Operations security access error
// 08 Feb 2023	navcs2		ChangeRequest 56318:[56319] EUP - Enable ToDo Work Order job on Yard Operation Screen
// 29 Mar 2023  navma1		Bug 57384: EUP - Error 1300 when opening Yard Ops Screen
// -----------------------------------------------------------------------------
vars
	taskDict 			: CM_ToDoTaskDescByCode;
begin
	
	self.mltTasks.userInputEnabled 				:= true;
	self.mltTasks.formDisplayEntryMethodName 	:= YRD_YardOpsForm::displayTask.name;
	self.mltTasks.multiSelect					:= ListBox.MultiSelect_Extended;
	self.mltTasks.myAvailableListBox.sorted 	:= false;		
	self.mltTasks.mySelectedListBox.sorted 		:= false;
	self.mltTasks.setTabIndex();
	self.mltTasks.myBaseForm 					:= self;

	//  Set up all Task Types in standard sequence
	//29.03.2023 navma1 #57384
	self.allTaskTypes.clear;
	self.allTaskTypes.add(CM_WodMove);
	self.allTaskTypes.add(CM_WodPack);
	self.allTaskTypes.add(CM_WodUnpack);
	self.allTaskTypes.add(CM_WodExportReturn);		
	self.allTaskTypes.add(CM_WodNullVoyage);			
	self.allTaskTypes.add(CM_WodReceive);				
	self.allTaskTypes.add(CM_WodRelease);
	self.allTaskTypes.add(CM_WodReleaseExtension);					
	self.allTaskTypes.add(CM_WodToDo);				//29.03.2023 navma1 #57384
	
	if app.myPassport.isVASEnabled() then										
		self.allTaskTypes.add(CM_WodToDoNonOperational); 	
		self.allTaskTypes.add(CM_WodToDoTrain);				
		self.allTaskTypes.add(CM_WodToDoVehicleVisit);		
		self.allTaskTypes.add(CM_WodToDoWagon);				
		self.allTaskTypes.add(CM_WodToDoVoyage);			
		self.allTaskTypes.add(CM_WodToDoVBS);					
	endif;
	
	
	create taskDict transient;
	app.myPassport.myUser.getToDoTasksAddRemoveForWOTerm(self.myTerminal, null, taskDict );
	taskDict.copy( self.allTaskTypes );
	//29.03.2023 navma1 #57384
	
	/*
	29.03.2023 navma1 #57384
	self.allTaskTypes.insert(WO_TASK_MOVE, 		    	CM_WodMove);
	self.allTaskTypes.insert(WO_TASK_PACK, 		    	CM_WodPack);
	self.allTaskTypes.insert(WO_TASK_UNPACK, 	    	CM_WodUnpack);
	self.allTaskTypes.insert(WO_TASK_EXPORTRETURN,  	CM_WodExportReturn);		// TFS 38501
	self.allTaskTypes.insert(WO_TASK_CHANGEVOYAGE,  	CM_WodNullVoyage);			// TFS 38501
	self.allTaskTypes.insert(WO_TASK_RECEIVE, 	    	CM_WodReceive);				// TFS 38501
	self.allTaskTypes.insert(WO_TASK_RELEASE, 	    	CM_WodRelease);				// TFS 38501 
	self.allTaskTypes.insert(WO_TASK_RELEASEEXTENSION,  CM_WodReleaseExtension);					
	
	if app.myPassport.isVASEnabled() then											// 13 Feb 2023	navcs2 #56318:[56319])
		self.allTaskTypes.insert(WO_TASK_ToDo_NONOPS, CM_WodToDoNonOperational); 	
		self.allTaskTypes.insert(WO_TASK_ToDo_TRAIN,  CM_WodToDoTrain);				
		self.allTaskTypes.insert(WO_TASK_ToDo_TRUCK,  CM_WodToDoVehicleVisit);		
		self.allTaskTypes.insert(WO_TASK_ToDo_WAGON,  CM_WodToDoWagon);				
		self.allTaskTypes.insert(WO_TASK_ToDo_VOYAGE, CM_WodToDoVoyage);			
		self.allTaskTypes.insert(WO_TASK_ToDo_VBS,    CM_WodToDoVBS);					
	endif;																			// 13 Feb 2023	navcs2 #56318:[56319]
	*/
	
	self.mltTasks.setAvailable(self.allTaskTypes, true); 
	self.mltTasks.setSelected(self.allTaskTypes); 
	
epilog
	delete taskDict;
end;</source>
    </JadeMethod>
