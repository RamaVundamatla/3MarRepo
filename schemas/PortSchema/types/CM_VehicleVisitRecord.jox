/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
12 August 2008	conkc1	Initial creation

*/

vars
	instructions : String;
	error        : CM_ErrorPersistent;
	count        : Integer;
begin

	foreach error in self.allErrorsWarningsByTranNum where error.type = Message_Statement do
		if error.status = Error_Status_Open then
			count := count + 1;
			if count &gt; 1 then
				instructions := instructions &amp; CrLf;
			endif;
			instructions := instructions &amp; error.errorCode.String &amp; ' : ' &amp; error.text;
		endif;
	endforeach;
	return instructions;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getGateTicketLoadType_JRW" id="fcfe36fc-7a45-42db-9153-2ecc6b2993d5">
        <updating/>
        <source>getGateTicketLoadType_JRW() : String updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
12 August 2008	conkc1	Initial creation

*/

vars
	gate : CMGTE_Entity;
begin

	foreach gate in self.allGateEntities discreteLock do		
		if gate.isReceipt() then
			return 'LOAD IN';
		else
			return 'LOAD OUT';
		endif;
	endforeach;
	
	return null;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getGateTicketTILC" id="022d80b8-2ed7-496f-b3f7-fe9de3227a59">
        <updating/>
        <source>getGateTicketTILC() : CM_TILC updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
12 August 2008	conkc1	Initial creation

*/

vars
	trackedItem : CM_TrackedItem;

begin
	// find first container
	foreach trackedItem in self.allReceivedTrackedItems do
		if trackedItem.isKindOf(CM_TILC) then
			break;
		endif;
	endforeach;

	// if we dont have a received container it must be released
	if trackedItem = null then
		foreach trackedItem in self.allReleasedTrackedItems do
			if trackedItem.isKindOf(CM_TILC) then
				break;
			endif;
		endforeach;
	endif;

	return trackedItem.CM_TILC;

end;</source>
        <ReturnType type="CM_TILC"/>
    </JadeMethod>
