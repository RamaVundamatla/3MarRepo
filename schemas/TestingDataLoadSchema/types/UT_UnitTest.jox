    <JadeMethod name="raiseTestException" id="c8432904-5209-4dd2-9eee-77f35f3db115">
        <source>raiseTestException(value : Boolean ; message : String; _errorCode: Integer) protected;
//16 July 2008	cnwdw1	
//
vars
	failException : UT_TestFailureException;
begin
	create failException transient;
	failException.message := message;
	failException.errorCode := _errorCode;
	self.getAssertMethodCall(failException.methodName, failException.methodPosition);
