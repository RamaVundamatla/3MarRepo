<Class name="CM_ReinstateReject" id="6351e43e-e95f-40ec-856d-e0ee2123b6f3">
    <superclass name="CM_Receive"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="receive"/>
    <PrimAttribute name="myLocationTo" id="c7ada7e8-229a-4744-bc24-08d0f0c0a44c">
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="reasonCode" id="e99c5cad-9b8f-4db4-88af-abbc8de8d72a">
