    <JadeMethod name="setInitialValues" id="d99fe304-5f36-4439-a4c0-7f3fcb112aba">
        <updating/>
        <source>setInitialValues(_task : CM_RTQueueTask) updating;
// -------------------------------------------
// Created 10 November 2003 by cnwdvb1
// -------------------------------------------
vars

begin

	self.myTask				:= _task;
	self.mySourceLocation	:= self.myTask.sourceLocation;
	
	if self.mySourceLocation = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Source Location', null, null);
		app.raiseCMException(Input_required_field_sourLocn, null, null); // cnwdb2	PAR 35364


	endif;
	if  self.myTask = null or not self.myTask.taskType = TASK_DIRECTOR then
	//	app.raiseCMException1(REQUIRED_FIELD, 'RT Director Task', null, null);
		app.raiseCMException(Input_required_field_RTDirect, null, null); // cnwdb2	PAR 35364
	endif;
	
	self.myMachine := self.myTask.machine;
	if self.myMachine = null then
//		app.raiseCMException1(REQUIRED_FIELD, 'Machine', null, null);
	endif;
	
	self.myWle := self.myTask.myEntry.myWorkListEntry;
	
//	self.lblDisplay.caption := app.getErrorString2(TestAgainstTiAndMachine, self.myTask.myEntry.id, self.myMachine.id);
	self.lblDisplay.caption := app.getErrorString2(TestAgainstTiAndMachine, self.myTask.taskDescription, self.myMachine.id);
	
//	pObj.CM_RTQueueEntry.id;
	
	

end;</source>
        <Parameter name="_task" type="CM_RTQueueTask"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="865a0a53-7c48-4402-a9ab-41ac800f6c37">
        <updating/>
        <source>setupForm() updating;
// ---------------------------------------------------------------------------
// Created:     28 July 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars

	ta	: CM_TerminalArea;

begin
	inheritMethod();
	
	self.toolbarStyle	:= self.ToolbarStyle_ShowNoHide;
	self.showToolbar	:= true;
	
	if self.mySourceLocation &lt;&gt; null then
		ta := self.mySourceLocation.myTerminalArea;
		if ta.isKindOf(CM_BlockStack) then
			ta.getTIs(self.availableTis, REAL_MODE);
		else
			self.mySourceLocation.getTIs(self.availableTis, REAL_MODE, true); // PAR 27749
		endif;
		
		self.cmbTi.listCollection(self.availableTis, false, 0);
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="2893013a-34d6-4cb4-8157-41acdcbb6be3">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0008207, locale);
	chkForce.translateCaption(Xlat_0001068, locale);
	lblDisplay.translateCaption(Xlat_0001069, locale);
	lblDisplay2.translateCaption(Xlat_0001070, locale);
	lblDisplay3.translateCaption(Xlat_0001071, locale);
end;</source>
    </JadeMethod>
</GUIClass>
