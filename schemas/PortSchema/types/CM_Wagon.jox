    <JadeMethod name="getReleaseOperator" id="7f6dfba8-a5a1-4795-aa94-6135905009a2">
        <source>getReleaseOperator():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 November 2022	navhl20	ChangeRequest 54281: EUP - Wagon Track Planning
02-May-2023 navtnr20	Bug 57780: EUP -FR 53740 | Wagon Track Planning - Multiple Values
03 May 2023	navmk20	Bug 57779: EUP -FR 53740 | Wagon Track Planning - Release Info
*/

vars
	//ti 					: CM_TrackedItem;			// 3.5.2023 navmk20 TFS 57779
	cont 					: CM_WagonController;
	data 					: String;
	wle 					: CM_WorkListEntry;			// 3.5.2023 navmk20 TFS 57779
	request					: CM_Request;				// 3.5.2023 navmk20 TFS 57779
	reserveDetail			: CM_ReserveDetail;			// 3.5.2023 navmk20 TFS 57779
	reserveHeader			: CM_BulkRelease;			// 3.5.2023 navmk20 TFS 57779
	operator				: CM_Operator;				// 3.5.2023 navmk20 TFS 57779
begin
	foreach cont in self.allLocationsControllers do
		//foreach ti in cont.allTrackedItems do
			//if ti.releaseRequest &lt;&gt; null then
				//return ti.releaseRequest.getOperatorCode;	// Start navtnr20 02-05-2023 Bug : 57780
		// Start 3.5.2023 navmk20 TFS 57779
		foreach wle in cont.CM_WagonController.allRailWLELoad do
			request := wle.myRequest;
			if request &lt;&gt; null then
				reserveDetail	:= request.myReserveDetail;
				if reserveDetail &lt;&gt; null then
					reserveHeader := reserveDetail.myReserveHeader;
					if reserveHeader &lt;&gt; null then
						operator := reserveHeader.myOperator;
						if operator &lt;&gt; null and operator.description &lt;&gt; null then
							/*
							if data.pos(operator.description,1) = 0 then	// Start navtnr20 02-05-2023 Bug : 57780
								if data = null then
									data := operator.description;
								else
									data := data &amp; ", " &amp; operator.description;
								endif;
							endif;// End navtnr20 02-05-2023 Bug : 57780
							*/
							
							data.addStringToList(operator.description, ", ");//04/04/2025	navkc1 JIRA Story MTN-33940
						endif;
					endif;
				endif;
			endif;  
		endforeach;
			//endif;
		//endforeach;
		// End 2.5.2023 navmk20 TFS 57779
	endforeach;
	return data;		//navtnr20 02-05-2023 Bug : 57780
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getReleaseOperatorCode" id="b58de861-72b8-40b5-85ea-85999a3e1983">
        <source>getReleaseOperatorCode() : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 May 2023	navmk20	Bug 57779: EUP -FR 53740 | Wagon Track Planning - Release Info

*/

vars
	cont 					: CM_WagonController;
	data 					: String;
	wle 					: CM_WorkListEntry;	
	request					: CM_Request;
	reserveDetail			: CM_ReserveDetail;
	reserveHeader			: CM_BulkRelease;	
	operator				: CM_Operator;	
begin
	foreach cont in self.allLocationsControllers do 
		foreach wle in cont.CM_WagonController.allRailWLELoad do
			request := wle.myRequest;
			if request &lt;&gt; null then
				reserveDetail	:= request.myReserveDetail;
				if reserveDetail &lt;&gt; null then
					reserveHeader := reserveDetail.myReserveHeader;
					if reserveHeader &lt;&gt; null then
						operator := reserveHeader.myOperator;
						if operator &lt;&gt; null and operator.code &lt;&gt; null then
							/*
							if data.pos(operator.code,1) = 0 then
								if data = null then
									data := operator.code;
								else
									data := data &amp; ", " &amp; operator.code;
								endif;
							endif;
							*/
							
							data.addStringToList(operator.code, ", "); //04/04/2025	navkc1 JIRA Story MTN-33940
						endif;
					endif;
				endif;
			endif;  
		endforeach;
	endforeach;
	return data;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getSealCheckTypeForContext" id="45f93cba-9dbf-495a-baad-b53cf038f1a4">
        <source>getSealCheckTypeForContext( _context : Integer):Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 March 2015	cnwndl1	Initial creation	Par 35828

*/

vars

	terminal : CM_Terminal;
	returnType : Integer;

begin

	if _context = 0 then
		// No context
		return SEAL_CHECK_NONE;
	endif;
	
	terminal := self.myTerminal;
	if terminal &lt;&gt; null then
		returnType := terminal.getSealCheckTypeForContext( _context );
	endif;
	
	if returnType &lt;&gt; SEAL_CHECK_DEFAULT.Integer then
		return returnType;
	endif;
	
	// never allowed to return default.
	return SEAL_CHECK_NONE;

epilog

end;</source>
        <Parameter name="_context" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getSealNumbersOnly" id="4ebab584-6f83-4742-b89d-818496b131a0">
        <source>getSealNumbersOnly():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 March 2015	cnwndl1	Initial creation	Par 35828

*/

vars

	iter : Iterator;
	wagonSeal : CM_WagonSeal;
	str : String;
	value : String;

begin

	iter := self.allWagonSeals.createIterator;
	while iter.next( wagonSeal ) do
		value := wagonSeal.getSealValueAsString().trimBlanks;
		if value = null then
			continue;
		endif;
		if str &lt;&gt; null then
			str := str &amp; ", ";
		endif;
		str := str &amp; value;
	endwhile;
	
	return str;

epilog

	delete iter;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getSealsDetailCurrentForReport" id="adef60f8-31c9-4e38-b642-f90b92e312f7">
        <source>getSealsDetailCurrentForReport():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 March 2015	cnwndl1	Initial creation	Par 35828

*/

vars

	iter : Iterator;
	wagonSeal : CM_WagonSeal;
	str : String;
	value : String;

begin

	iter := self.allWagonSeals.createIterator;
	while iter.next( wagonSeal ) do
		value := wagonSeal.getSealValueAsString().trimBlanks;
		if value = null then
			continue;
		endif;
		value := wagonSeal.sealType &amp; "=" &amp; value;	//29 Jul 2015	NDL	Par 36658
		if str &lt;&gt; null then
			str := str &amp; " : ";
		endif;
		str := str &amp; value;
	endwhile;
	
	return str;

epilog

	delete iter;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getSealsDetailHistoryForReport" id="fe8addf4-d3ac-43f8-adc1-15d08e89b3ad">
        <source>getSealsDetailHistoryForReport():String;
/*

Purpose:			

Parameters:			//Provided for Report writer.

Return Value:		

Date		Who		Reason
18 March 2015	cnwndl1	Initial creation	Par 35828

*/

vars

	iter : Iterator;
	eventTransaction : CM_EventTransaction;
	wagonEventTrx : CMEVT_WagonTransaction;
	dynaDict : DynaDictionary;
	obj : Object;
	str : String;

begin

	create dynaDict transient;
	dynaDict.setMembership( CMEVT_WagonTransaction );
	dynaDict.addMemberKey( CMEVT_WagonTransaction::dateTime.name, false, false );
	dynaDict.addMemberKey( CMEVT_WagonTransaction::type.name, true, false );  // list deletes first, if the times are the same.
	dynaDict.endKeys(true);

	iter := self.allTransactions.createIterator;
	while iter.next( eventTransaction ) do
		if eventTransaction.type.isOneOf( EVT_WagonSealAdd, EVT_WagonSealDelete ) then
			dynaDict.add( eventTransaction );
		endif;
	endwhile;
	
	delete iter;
	iter := dynaDict.createIterator;
	while iter.next( obj ) do
		if str &lt;&gt; null then
			str := str &amp; CrLf;
		endif;
		str := str &amp; obj.CMEVT_WagonTransaction.extraDescription.trimBlanks;
	endwhile;
	
	return str;

epilog

	delete iter;
	delete dynaDict;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getSelectableSealTypes" id="c7ab1f68-160f-4ac0-b52e-5c86c6e85b9e">
        <source>getSelectableSealTypes( _allSealTypes : CM_SealTypeSet input );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 March 2015	cnwndl1	Initial creation	Par 35828

*/

vars

begin

	if self.myWagonClass &lt;&gt; null then
		self.myWagonClass.getSelectableSealTypes( _allSealTypes );
	
	endif;

epilog

end;</source>
        <Parameter name="_allSealTypes" type="CM_SealTypeSet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getSetdownTasks" id="8da9e55d-2b7b-485e-8b0f-0ab257945212">
        <source>getSetdownTasks(arbiter: CM_RTQueueArbiter input);
/*
	method that returns the work required to set TI to the wagon.
*/
vars
	task	: CM_RTQueueTask;
begin
	create task;
	//parent will be set higher up.
	if arbiter.job.isKindOf(CM_YardInternalJob) then
		if arbiter.job.CM_YardInternalJob.isSwapJob then
			//SwapJob! PANIC!
			return;
		endif;
	endif;
	
	task.setDetails(	arbiter.ti.getPrimaryLocation(REAL_MODE),
						arbiter.ti.getPrimaryLocation(QUEUE_MODE),
						TASK_UNACTIONED,
						TASK_SETDOWN,
						arbiter.ti);
	
	arbiter.entry.addTask(task);
	
end;</source>
        <Parameter name="arbiter" type="CM_RTQueueArbiter" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getSpecialStow" id="7ac026b2-660b-4a9b-a1b3-75b2ee4df134">
        <source>getSpecialStow():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 November 2022	navhl20	ChangeRequest 54281: EUP - Wagon Track Planning
02-May-2023 navtnr20	Bug 57780: EUP -FR 53740 | Wagon Track Planning - Multiple Values
*/

vars
	ti : CM_TrackedItem;
	cont : CM_WagonController;
	data : String;
	code : String;
begin
	foreach cont in self.allLocationsControllers do
		foreach ti in cont.allTrackedItems do
			//return ti.specialStow;		// Start navtnr20 02-05-2023 Bug : 57780
			code := ti.specialStow;
			if code &lt;&gt; null then
				/*
				if data.pos(code,1) = 0 then
					if data = null then
						data := code;
					else	
						data := data &amp; ", " &amp; code;
					endif;
				endif;	// End navtnr20 02-05-2023 Bug : 57780
				*/
				
				data.addStringToList(code, ", "); //04/04/2025	navkc1 JIRA Story MTN-33940
			endif;
		endforeach;
	endforeach;
	return data;		//navtnr20 02-05-2023 Bug : 57780
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getStatus" id="75687189-3219-42cf-83a1-5ab487440c15">
        <source>getStatus() : String;
// ---------------------------------------------------------------------------
// Created:		January  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	lStatus : String;
	lController : CM_LocationsController;
	lAvail, lNotAvail : Integer;
begin
	//lStatus := 'Available'; //- cnwmd1, CCMS 1067, Par 19710
	lStatus := app.getErrorString(Available);	//+ cnwmd1, CCMS 1067, Par 19710
	//foreach lController in self.allLocationsControllers do
	foreach lController in self.allLocationsControllersArray do	//04 Dec 2014	NDL	Par 35345
		if not lController.CM_WagonController.isAvailable then
			lNotAvail := lNotAvail + 1;
		else
			lAvail := lAvail + 1;
		endif;
	endforeach;

	if lNotAvail &lt;&gt; 0 then
		//lStatus := "Partially Available"; //- cnwmd1, CCMS 1067, Par 19710
		lStatus := app.getErrorString(Partially_available); //+ cnwmd1, CCMS 1067, Par 19710
	else
		//lStatus := "Totally Available"; //- cnwmd1, CCMS 1067, Par 19710
		lStatus := app.getErrorString(Totally_available); //+ cnwmd1, CCMS 1067, Par 19710
	endif;
	return lStatus;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getStevedoreCodeReceive" id="1f8cf9bd-d0c9-4825-9d28-d4154cef4ef3">
        <source>getStevedoreCodeReceive():String;
/*

Purpose:			

Parameters:			

