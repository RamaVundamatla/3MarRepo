    <JadeMethod name="getConvertedTotalWeight" id="397ae74e-6926-4898-94ae-30215e44a170">
        <source>getConvertedTotalWeight(_shortName : String) : String;
/*
Purpose:			For JRW reports - to return the total weight in the measurement unit specified

Parameters:			_units - a valid length measurement type short name

Return Value:		The total weight converted to the specified measurement type

Changed On	By			Reason
----------	--------	-----------------------------------------------------
9/10/2013	cnwjre1		Initial creation PAR #32751 additional reporting fields
*/
vars
	weight : Decimal [12,4];
	measurementType		: CM_MeasurementType;

begin
	measurementType := app.myRoot.allMeasurementTypesByShortName[_shortName];
	if measurementType = null or not measurementType.isWeight() then
		return app.getErrorString(Invalid);
	endif;

	if self.myTrackedItem &lt;&gt; null then
		weight := self.myTrackedItem.totalWeight;
	elseif self.myBookingRef &lt;&gt; null then
		weight := self.myBookingRef.getTotalWeight;
	elseif self.myBOL &lt;&gt; null then
		weight := self.myBOL.getTotalTIWeight;
	elseif self.myGateReceival &lt;&gt; null then
		weight := self.myGateReceival.weight;
	elseif self.myGateReceivalByType &lt;&gt; null then
		weight := self.myGateReceivalByType.weight;
	endif;
	
	return app.convertMeasurementForDisplay(measurementType.shortName, weight);
	
epilog

end;</source>
        <Parameter name="_shortName" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
