    <JadeMethod name="getAuditText" id="dd59837c-89f5-4015-ae46-c7377842fbfc">
        <source>getAuditText(): String;
// ---------------------------------------------------------------------------
// Created:     19 April 2007 by cnwaer1
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	txt		: String;
	tmpStr	: String;
	email	: CM_EmailAddress2;
begin
	txt[10000] := '*';
	txt := null;
	txt := inheritMethod();

	foreach email in self.allContacts do
		if tmpStr = null then
			tmpStr := email.name;
		else
			tmpStr := tmpStr &amp; ', ' &amp; email.name;
		endif;
	endforeach;
	txt := txt &amp; 'Contacts selected ' &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;	
	
	return txt;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
