    <JadeMethod name="valCO2Reading" id="d293c8ca-d97f-4ba3-bde7-30a1aaa37f0f">
        <source>valCO2Reading(_co2Params : CMIF_CO2Reading);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 16/12/2025	navdap1		Initial creation MTN-36569 CPL Reefer Runner Integration
//
vars

begin
	if _co2Params.myTrackedItem = null then
		app.raiseCMException2(MethodWithNullParam, method.name, 'tempParams.myContainer', 'myContainer', null);
		return;
	endif;

	if not _co2Params.dateTime.isValid then
		app.raiseCMException2(ERR_INVALID_VALUE, "date/time", "Make sure the date and time fields are valid.", 'dateTime',null);
		return;
	endif;
	
	if not _co2Params.dateTime.date &lt;= app.actualTimeServer().date then
		app.raiseCMException2(ERR_INVALID_VALUE, "date", "You cannot add a temperature reading later than today.", 'dateTime',null);
		return;
	endif;
epilog

end;</source>
        <Parameter name="_co2Params" type="CMIF_CO2Reading"/>
    </JadeMethod>
