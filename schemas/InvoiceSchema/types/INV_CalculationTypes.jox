    <JadeMethod name="cmbCalcTypes_lostFocus" id="0b18ca2c-29d2-4f07-8768-97b244801481">
        <controlMethod name="CMUI_ComboBox::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbCalcTypes_lostFocus(combobox: ComboBox input) updating;
// ---------------------------------------------------------------------------
// Created:		January 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
02 Jul 2008	cnwkpd1	PAR #17262 - Ensure that data is not cleared if value of the combo hasn't
					been changed

*/

vars
	calcRow			: Integer;
	valueChanged	: Boolean;
	calculationType : CM_CalculationType;
begin
	calcRow := self.tblEntDetail.getRowByControlName(combobox.name);
	if calcRow &lt;&gt; 0 then
		valueChanged := combobox.text &lt;&gt; self.tblEntDetail.getValue(calcRow).String;
	else
		valueChanged := true;
	endif;

	self.tblEntDetail.setValueByControlName(combobox.name,combobox.text);
	if self.cmbCalcTypes.listIndex &gt; 0 then
		self.handleViews(self.cmbCalcTypes.itemData[self.cmbCalcTypes.listIndex], valueChanged);
		
		calculationType := self.myCurrentObject.CM_CalculationType; // PAR 31615
		if calculationType &lt;&gt; null then // PAR 31615
			self.cmbMesType.listObject := calculationType.myMeasurementType; // PAR 31615
			self.setBlockUnitCombo(calculationType); // PAR 31615
			self.setCmbWeightToUse(calculationType); //02/10/2025	navkc1 JIRA 36144 
		endif;
		
		
	endif;
end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
