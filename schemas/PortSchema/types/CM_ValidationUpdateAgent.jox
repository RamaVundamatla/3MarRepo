    <JadeMethod name="valEDIPrenote" id="76c18db9-c0ff-4f5f-8906-1fbe4fcb79c2">
        <source>valEDIPrenote(_interFace : CMIF_PreNote; _ediData :CM_EDIData; _passport :CM_Passport input);
/*
Date		Who		Reason
18 Sep 2012	cnwcs5	Initial creation - par 30316
// 13 Oct 2017	jlgrs1	TFS 5705 - SNO - EDIDataBooking Prenote release Req
// 02 Feb 2018	jlgrs1	TFS 36951 JMT Prenote Partial for GateDoc
*/
vars
	itemObj	: CMIF_TIObject;
	obj	: Object;
	ediTI : CM_EDIPrenoteTI;
	limit : Integer;
	terminal : CM_Terminal;
begin
	terminal := _passport.myTerminal;
	
	if terminal &lt;&gt; null then
		limit := terminal.getConfig(EDIVerificationErrorLimit).Integer;
	endif;
	
	on CM_Exception do _ediData.xHandlerCMExceptionUserObject(exception, ediTI);	
	
	itemObj := _interFace;
	obj := itemObj.myUserObject;												
	if obj &lt;&gt; null and obj.isKindOf(CM_EDIPrenoteTI) then						
		ediTI := obj.CM_EDIPrenoteTI;											
	else																		
		ediTI := null;															
	endif;																		
	if app.isSubTerminalsOn(_interFace.myTerminal) then
		if _interFace.mySubTerminal = null then
			itemObj.setSubTerminalDefault();
		endif;
	endif;
	itemObj.validateForProcess(_passport);		//Also does the sub items
	// use terminal config limit instead of hard coding 100
	if limit &lt;&gt; 0 and _passport.allErrors.size() &gt; limit then
		return;
	endif;
epilog

end;</source>
        <Parameter name="_interFace" type="CMIF_PreNote"/>
        <Parameter name="_ediData" type="CM_EDIData"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="valEDIPrenotes" id="25754b90-ad34-4354-83fb-90d3ec0a8699">
        <source>valEDIPrenotes(_intFaceArray : CMIF_PrenoteSet; _ediData :CM_EDIData; _passport :CM_Passport input);
/*
Date		Who		Reason
18 Sep 2012	cnwcs5	Initial creation - par 30316
// 13 Oct 2017	jlgrs1	TFS 5705 - SNO - EDIDataBooking Prenote release Req
*/
vars
	itemObj		: CMIF_TIObject;
	obj			: Object;
	ediTI		: CM_EDIPrenoteTI;
	limit		: Integer;
	terminal	: CM_Terminal;
begin
	terminal := _passport.myTerminal;
	
	if terminal &lt;&gt; null then
		limit := terminal.getConfig (EDIVerificationErrorLimit).Integer;
	endif;
	
	on CM_Exception do _ediData.xHandlerCMExceptionUserObject (exception, ediTI);	
	
	foreach itemObj in _intFaceArray do
		obj := itemObj.myUserObject;												
		
		if obj &lt;&gt; null and obj.isKindOf (CM_EDIPrenoteTI) then						
			ediTI := obj.CM_EDIPrenoteTI;											
		else																		
			ediTI := null;															
		endif;																		
		
		if not itemObj.isKindOf(CMIF_PreNote) then
			app.raiseUnexpectedProgramError(class.name, method.name, 'Item is not a preNote (' &amp; itemObj.String &amp; ')');
			return;
		endif;
		
		if app.isSubTerminalsOn(itemObj.myTerminal) then
			if itemObj.mySubTerminal = null then
				itemObj.setSubTerminalDefault();
			endif;
		endif;
		
		itemObj.validateForProcess(_passport);		//Also does the sub items
		
		// use terminal config limit instead of hard coding 100
		if limit &lt;&gt; 0 and _passport.allErrors.size() &gt; limit then
			break;
		endif;
	endforeach;
epilog

end;</source>
        <Parameter name="_intFaceArray" type="CMIF_PrenoteSet"/>
        <Parameter name="_ediData" type="CM_EDIData"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="valEDIProcessEDITrackedItem" id="dfcecee5-7698-45b2-bf92-202b3d9d363a">
        <source>valEDIProcessEDITrackedItem(_coll :CM_EDITISet);
/*
Date		Who		Reason
22 Aug 2013	cnwcs5	CCMS POL 2221 / par 32094(2)
*/
vars
	ediTI	:CM_EDITrackedItem;
begin
	foreach ediTI in _coll do
		if ediTI.status &lt;&gt; CM_EDITrackedItem.EDI_STATUS_SKIP_PROCESSING and
			ediTI.status &lt;&gt; CM_EDITrackedItem.EDI_STATUS_SKIP_PROCESSING_X then
			app.raiseCMException1 (INVALID_STATUS_PROCESS, ediTI.displayStatus, null, null);
		endif;
	endforeach;
epilog

end;</source>
        <Parameter name="_coll" type="CM_EDITISet"/>
    </JadeMethod>
