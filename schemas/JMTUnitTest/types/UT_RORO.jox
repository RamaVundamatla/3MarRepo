    <JadeMethod name="tRORODeckPlanActualPrpsd2" id="f1055cb9-1482-48ae-b307-723124329e7f">
        <updating/>
        <source>tRORODeckPlanActualPrpsd2() updating;

/*

Purpose:			

Notes:			If you put a 20' into the back end of a rotated 40' OOTL then in actual it doesn't extract out the rotated cell detail so
				when it's loaded again it only shows a non rotated 20' OOTL

Date			Who		Reason
23/01/2013		cnwmh5	Initial creation

*/

constants

	VesselId					: String = "JROSO";
	VoyageId 					: String = "VOYSHIP30863_1";					// Master Voyage
	VoyageId2 					: String = "VOYSHIP30863_2";					// Loaded Actual from _1 and Planning details added
	VoyageId3 					: String = "VOYSHIP30863_3";					// Loaded Proposed from _2
	VoyageId4					: String = "VOYSHIP30863_4";					// Loaded Actual from _1 and Discharge details added
	VoyageId5					: String = "VOYSHIP30863_5";					// Loaded Actual from _4
	VoyageId6					: String = "VOYSHIP30863_6";					// Loaded Proposed from _4 
	TestOperator				: String = "MSL";
	CargoID						: String = "MDHUT2301";
	BlockStackName				: String = "UTMHBS7";
	YardAllocationId			: String = "UTMHYA_30863";
	
vars

	voyage1						: CM_Voyage;
	voyage2						: CM_Voyage;
	voyage3						: CM_Voyage;
	voyage4						: CM_Voyage;
	voyage5						: CM_Voyage;
	voyage6						: CM_Voyage;
	operator					: CM_Operator;
	bs							: CM_BlockStack;
	cargo						: CM_TrackedItem;
	
	tiSet						: CM_TISet;
		
	cargoCount					: Integer;

begin

	// defaults
	operator := app.myRoot.allOperators[TestOperator];
	self.assertNotNull(operator);
	cargoCount := 1;
	
	// setup block stack
	self.deleteTerminalArea( BlockStackName );
	bs := self.addBlockStack(BlockStackName, 99, null);
	self.assertNotNull(bs);	
	
	// create yard allocation
	self.deleteYA(YardAllocationId);
	
	/*********************************************************************
		Setup the original voyage that we extract and reload
	**********************************************************************/
	
	app.writeLog("***Setting up initial voyage***", LogINFO);
		
	// delete the voyage and recreate
	self.deleteVoyage(VoyageId);
	voyage1 := self.getVoyage(VoyageId);
	self.assertIsDeleted(voyage1);
	voyage1 := self.addVoyageWithConRORO(VoyageId, VesselId, operator.code, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString, null, 0, false, true);
	self.assertNotNull(voyage1);
	
	// setup deck 3
	app.writeLog("***Setting up Deck 3***", LogINFO);		
	self.xSetupDeck3_30863(voyage1, CargoID, cargoCount);
		
	/*********************************************************************
		LOAD
	**********************************************************************/
	
	app.writeLog("***Setting up load voyage***", LogINFO);
	
	// create voyage 2
	self.deleteVoyage(VoyageId2);
	voyage2 := self.getVoyage(VoyageId2);
	self.assertIsDeleted(voyage2);
	voyage2 := self.addVoyageWithConRORO(VoyageId2, VesselId, operator.code, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString, null, 0, false, true);
	self.assertNotNull(voyage2);
	
	// extract out the actual deck plan and load into voyage 2
	app.writeLog("***Extracting Actual from  voyage1, loading into voyage2***", LogINFO);		
	self.xExtractLoadActual1_30863(voyage1, voyage2);

	// delete and recreate voyage 3
	self.deleteVoyage(VoyageId3);
	voyage3 := self.getVoyage(VoyageId3);
	self.assertIsDeleted(voyage3);
	voyage3 := self.addVoyageWithConRORO(VoyageId3, VesselId, operator.code, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString, null, 0, false, true);
	self.assertNotNull(voyage3);
	
	// setup deck 2 with load only
	app.writeLog("***Setting up Deck 2, for voyage2***", LogINFO);		
	self.xSetupDeck2_30863(voyage2, CargoID, cargoCount);
		
	// extract the proposed deck pland and load into voyage 3
	app.writeLog("***Extracting Proposed from  voyage2, loading into voyage3***", LogINFO);		
	self.xExtractLoadProposed1_30863(voyage2, voyage3);
	
	/*********************************************************************
		DISCHARGE
	**********************************************************************/
	
	app.writeLog("***Setting up discharge voyage***", LogINFO);
	
	// delete and recreate voyage 4
	self.deleteVoyage(VoyageId4);
	voyage4 := self.getVoyage(VoyageId4);
	self.assertIsDeleted(voyage4);
	voyage4 := self.addVoyageWithConRORO(VoyageId4, VesselId, operator.code, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString, null, 0, false, true);
	self.assertNotNull(voyage4);
	
	// create yard allocation
	self.deleteYA(YardAllocationId);
	self.addYA1(YardAllocationId, YACriteriaType_Voyage, voyage4, bs.allLocationsControllers.first);
	
	app.writeLog("***Extracting Actual from  voyage1, loading into voyage4***", LogINFO);		
	self.xExtractLoadActual1_30863(voyage1, voyage4);
	
	// setup deck 2 for voyage 4 for discharge
	app.writeLog("***Setting up Deck 2, for voyage4***", LogINFO);		
	self.xSetupDeck2_Voy4_30863(voyage4);
	
	// delete and recreate voyage 5
	self.deleteVoyage(VoyageId5);
	voyage5 := self.getVoyage(VoyageId5);
	self.assertIsDeleted(voyage5);
	voyage5 := self.addVoyageWithConRORO(VoyageId5, VesselId, operator.code, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString, null, 0, false, true);
	self.assertNotNull(voyage5);
		
	app.writeLog("***Extracting Actual from voyage4, loading into voyage5***", LogINFO);		
	self.xExtractLoadActual1_30863(voyage4, voyage5);
	
	// delete and recreate voyage 6
	self.deleteVoyage(VoyageId6);
	voyage6 := self.getVoyage(VoyageId6);
	self.assertIsDeleted(voyage6);
	voyage6 := self.addVoyageWithConRORO(VoyageId6, VesselId, operator.code, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString, null, 0, false, true);
	self.assertNotNull(voyage6);
	
	app.writeLog("***Extracting Proposed from voyage4, loading into voyage6***", LogINFO);		
	self.xExtractLoadProposed1_30863(voyage4, voyage6);
	
	// 14/09/2015 cnwmh5
	create tiSet transient;
	voyage1.getAllTrackedItems(tiSet);
	voyage2.getAllTrackedItems(tiSet);
	voyage3.getAllTrackedItems(tiSet);
	voyage4.getAllTrackedItems(tiSet);
	voyage5.getAllTrackedItems(tiSet);
	voyage6.getAllTrackedItems(tiSet);
	beginTransaction;
	foreach cargo in tiSet do
		cargo.setRemarks(self.createdByUnitTest(cargo.remarks), true);
	endforeach;
	commitTransaction;
	
	self.deleteTerminalArea( BlockStackName );
	
epilog
//	self.deleteVoyage(VoyageId4);
	// delete yard allocation
	self.deleteYA(YardAllocationId);
	delete tiSet;

end;</source>
