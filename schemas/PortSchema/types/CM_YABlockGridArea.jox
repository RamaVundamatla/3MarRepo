    <JadeMethod name="getGridControllersForDecking" id="fe70f7cf-0a16-41a7-a181-c3fa85d72808">
        <source>getGridControllersForDecking(_gridCntrlDict: CM_MemberKeyDictionary output);
//----------------------------------------------------------------
//	Created:	27 April 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
begin
	if self.myYardAllocationIn.getBlockMode = CM_YardAllocation.ROW_MODE then
		create _gridCntrlDict as CM_GridControllersByColumn transient;
	else
		create _gridCntrlDict as CM_GridControllersByRowColumn transient;
	endif;

	self.allYardControllers.copy(_gridCntrlDict);
end;</source>
        <Parameter name="_gridCntrlDict" type="CM_MemberKeyDictionary" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getGridRow" id="da20bbd9-efd8-436b-87c2-f4042257908c">
        <source>getGridRow() : CM_GridRow;
// ---------------------------------------------------------------------------
// Created:     22 April 2005 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpYC	: CM_YardController;
begin
	tmpYC := self.allYardControllers.first;
	if tmpYC = null then
//	or (not global.isValidObject(tmpYC)) then		//remove when inverse inplace on self.allYardControllers
		return null;
	endif;
	if (not CM_GridController.hasInstance(tmpYC)) then
		return null;
	endif;
	
	return tmpYC.CM_GridController.myGridRow;
end;</source>
        <ReturnType type="CM_GridRow"/>
    </JadeMethod>
