    <JadeMethod name="validateForUpdate" id="d156190a-abda-4798-889b-1e6a5b3d01b0">
        <source>validateForUpdate();
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
//
