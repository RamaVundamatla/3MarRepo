epilog

end;</source>
        <Parameter name="_weight" type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="33835348-89e7-46a4-b992-3c9f3d70e889">
        <updating/>
        <source>setForCreate(_bank : CM_Bank; _invoiceLine : CM_InvoiceLine; _sequenceNum : Integer; _service : CM_Service) updating;
// ---------------------------------------------------------------------------
// Created:     01 July 2005 by cnwrs2
//12 November 2018	cnwma1	ChangeRequest 41945: PEL1 - SAP - Invoice changes restriction
// Purpose:     
// ---------------------------------------------------------------------------
// Changed On	By		Reason
// 18 Oct 2024	navlw1	JIRA-33107: Invoice Logging Use Levels
vars

begin

	self.sequenceNum := _sequenceNum;
	self.service := _service;
	self.bank := _bank;
	self.invoiceLine := _invoiceLine;
	
	//12.11.2018 cnwma1 TFS #41945
	if not app.isInProformaMode then
		if _invoiceLine.invoice &lt;&gt; null then
			if not _invoiceLine.invoice.canUpdate then
				app.raiseCMException(ERR_Cannot_update_invoice, null, null);
				return;
			endif;
		endif;
	endif;
	//12.11.2018 cnwma1 TFS #41945

	// CCMS 1264 Apr 2012 rate is no longer dynamic
	// do manual invoice rate here, do from-tran map invoice rate in CM_InvoiceLine setFromQuantityRangeMap once quantity has been derived
	if _invoiceLine.manual then
		// TFS 42084
		app.invLog(method.qualifiedName &amp; " Calling CM_Charge.evaluateRate", LogINFO.String);
		self.evaluateRate();
	endif;
end;</source>
        <Parameter name="_bank" type="CM_Bank"/>
        <Parameter name="_invoiceLine" type="CM_InvoiceLine"/>
        <Parameter name="_sequenceNum" type="Integer"/>
        <Parameter name="_service" type="CM_Service"/>
    </JadeMethod>
    <JadeMethod name="setForCreateWeb" id="7b1928a2-81f5-475d-8edf-90c67e1685ee">
        <updating/>
        <source>setForCreateWeb(_bank : CM_Bank; _invoiceLine : CM_InvoiceLine; _sequenceNum : Integer; _service : CM_Service; _taxCode : CM_TaxCode; _rate : Real) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
31 August 2023	navcs2	Bug 59959: EUP | TAS Invoicing - Invoice API doesn't match whats defined in API spec
18 Oct 2024		navlw1	JIRA-33107: Invoice Logging Use Levels

*/
vars

begin

	self.sequenceNum := _sequenceNum;
	self.service := _service;
	self.bank := _bank;
	self.invoiceLine := _invoiceLine;
	self.myOverrideTaxCode := _taxCode;
	self.rate := _rate;
	
	if not app.isInProformaMode then
		if _invoiceLine.invoice &lt;&gt; null then
			if not _invoiceLine.invoice.canUpdate then
				app.raiseCMException(ERR_Cannot_update_invoice, null, null);
				return;
			endif;
		endif;
	endif;

	// do manual invoice rate here, do from-tran map invoice rate in CM_InvoiceLine setFromQuantityRangeMap once quantity has been derived
	if _invoiceLine.manual then
		app.invLog(method.qualifiedName &amp; " Calling CM_Charge.evaluateRate", LogINFO.String);
		self.evaluateRate();
	endif;
end;</source>
        <Parameter name="_bank" type="CM_Bank"/>
        <Parameter name="_invoiceLine" type="CM_InvoiceLine"/>
        <Parameter name="_sequenceNum" type="Integer"/>
        <Parameter name="_service" type="CM_Service"/>
        <Parameter name="_taxCode" type="CM_TaxCode"/>
        <Parameter name="_rate" type="Real"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="695722fe-1cbe-49d1-a04b-cec8ec098982">
        <updating/>
        <source>setForUpdate(_pxyCharge : CM_Charge) updating;
// ---------------------------------------------------------------------------
// Created:		April 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//12 November 2018	cnwma1	ChangeRequest 41945: PEL1 - SAP - Invoice changes restriction
// ---------------------------------------------------------------------------

vars

begin
	_pxyCharge.raiseExceptionIfNotTransient(method);
	
	//12.11.2018 cnwma1 TFS #41945
	if not app.isInProformaMode then
		if self.invoiceLine &lt;&gt; null then
			if self.invoiceLine.invoice &lt;&gt; null then
				if not self.invoiceLine.invoice.canUpdate then
					app.raiseCMException(ERR_Cannot_update_invoice, null, null);
					return;
				endif;
			endif;
		endif;
	endif;
	
	if _pxyCharge.overridden then
		self.overrideRate(_pxyCharge.rate);
	else
		self.releaseRate();
	endif;
end;</source>
        <Parameter name="_pxyCharge" type="CM_Charge"/>
    </JadeMethod>
    <JadeMethod name="setForUpdateTax" id="2916ad37-1364-4b06-9d49-d0f8308c10ec">
        <updating/>
        <source>setForUpdateTax(_pxyCharge : CM_Charge) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 October 2022	navmv20	ChangeRequest 55005: EUP - Invoicing - Invoice Line TAX Maintenance

*/

vars

begin
	_pxyCharge.raiseExceptionIfNotTransient(method);

	if not app.isInProformaMode then
		if self.invoiceLine &lt;&gt; null then
			if self.invoiceLine.invoice &lt;&gt; null then
				if not self.invoiceLine.invoice.canUpdate then
					app.raiseCMException(ERR_Cannot_update_invoice, null, null);
					return;
				endif;
			endif;
		endif;
	endif;
	
	if _pxyCharge.overriddenTax then
		self.overrideTax(_pxyCharge.myOverrideTaxCode);
	else
		self.releaseTax();
	endif;
epilog

end;</source>
        <Parameter name="_pxyCharge" type="CM_Charge"/>
    </JadeMethod>
