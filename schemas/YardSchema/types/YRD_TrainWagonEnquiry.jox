    <JadeMethod name="btnConfirmSave_click" id="90df438f-c22f-48eb-a136-677256a873c9">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnConfirmSave_click(btn: Button input) updating;
// ---------------------------------------------------------------------------
// Created:     08 June 2009 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

	integerArray : IntegerArray;
	wagonSet : CM_WagonSet;
	errString : String;
	wagon : CM_Wagon;
	
begin

	if txtWagonRange.text.trimBlanks &lt;&gt; null then
		// User has entered a range value, attempt to set up the selection from the range.
		if not self.tblData.allSelectedObjects.isEmpty() then
			// give a warning that the Wagon range will overwrite the table selection...
			if app.msgBox(app.getErrorString(Override_wagon_selection),app.getErrorString(SHP_Do_You_Want_To_Continue),MsgBox_Yes_No) &lt;&gt; MsgBox_Return_Yes then
				return;
			endif;
		endif;
			
		// get the position values form the txtWagonRange.text
		create integerArray transient;
		self.getPositionDataFromText( integerArray );
		
		// get a list of the wagons from the position data
		create wagonSet transient;
		self.getWagonsFromPositions( integerArray, wagonSet, errString );
		if errString &lt;&gt; null then
			app.msgBox(app.getErrorString(No_wagons_position) &amp; " " &amp; errString &amp; ".",app.getErrorString(Error),MsgBox_OK_Only);
			txtWagonRange.setFocus();
			return;
		endif;
		
		//clear then add the selected wagons to self.tblData.allSelectedObjects
		self.tblData.clearAllSelected();
		foreach wagon in wagonSet do
			self.tblData.selectObject(wagon,false);
		endforeach;
		
	endif;
	
	if self.cmbAreas.listIndex &lt; 1 then
		app.msgBox(app.getErrorString(Must_enter_rail_positio), app.getErrorString(Error), MsgBox_Exclamation_Mark_Icon);
		cmbAreas.setFocus();
		return;
	endif;
	
	if self.cmbPosition.listIndex &lt; 1 then
		app.msgBox(app.getErrorString(Must_enter_rail_positio), app.getErrorString(Error), MsgBox_Exclamation_Mark_Icon);
		cmbPosition.setFocus();
		return;
	endif;
	
	self.doUpdateWagonConfirmToRail();
	
epilog

	delete integerArray;
	
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
