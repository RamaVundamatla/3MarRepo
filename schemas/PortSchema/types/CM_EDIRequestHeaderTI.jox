    <JadeMethod name="getFreightPayerCode" id="895e4e6e-0a37-4272-9bbc-7f032a1eb043">
        <source>getFreightPayerCode() : String;
/*
Date		Who		Reason
15/022012	cnwcs5	Initial creation - par 29137 Coparn release requests
// 17 Oct 2017	jlgrs1	TFS 5705 - SNO - EDIDataBooking Prenote release Req
*/
vars
	operator : CM_Operator;
	result : String;
begin
	operator := app.myRoot.allOperators[self.operatorCode];
	
	if operator &lt;&gt; null then
		result := operator.getConfig(DefaultFreightPayerCode).String;
	endif;
	
	return result;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
