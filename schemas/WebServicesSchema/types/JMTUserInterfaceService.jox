        <wsdlName>getISOTypesForCargoType</wsdlName>
        <Parameter name="cargoType" type="Integer"/>
        <ReturnType type="WS_ISOTypesResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="getInterTerminalMovesForTruck" id="c927c692-d78a-4f29-87d4-a4342b54d5ee">
        <source>getInterTerminalMovesForTruck(request : WS_InterTerminalQueryRequest) : WS_InterTerminalResponse webService;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 February 2017	cnwam15	Initial creation

*/

vars
	interTerminalJob		: CM_InterTermVehicleJob;
	interTerminalMoveArray 	: WS_InterTerminalMoveArray;
	interTerminalMoveProxy 	: WS_InterTerminalMove;
	interTerminalMove 		: CM_InterTerminalMove;
	response 				: WS_InterTerminalResponse;
	completedOK				: Boolean;
	terminal				: CM_Terminal;
	truck 					: CM_Vehicle;
begin
	
	//Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);

	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	create response transient;
	truck := app.myPassport.myTerminal.vehicles[request.truckId.toUpper, ""];
		
	if truck = null then
		completedOK := true;
		return response;
	endif;
	
	interTerminalJob := app.myRoot.allInterTerminalVehicleJobs.getAtKey(request.truckId.toUpper, "");
	
	create interTerminalMoveArray transient;

	terminal := app.myPassport.myTerminal;
	
	foreach interTerminalMove in interTerminalJob.allInterTerminalMoves do
		if request.isUnloadJob = false then 
			if interTerminalMove.myTargetTerminal &lt;&gt; terminal then
				//Can only load Inter terminal job at the source terminal
				continue;
			endif;
		else 
			if interTerminalMove.mySourceTerminal &lt;&gt; terminal then 
				//Can only unload Inter terminal job at the target terminal
				continue;
			endif;
		endif;

		create interTerminalMoveProxy transient;
		interTerminalMoveProxy.setProxyFromObject(interTerminalMove);
		response.allInterTerminalMoves.addExclusive(interTerminalMoveProxy);
	endforeach;
	
	completedOK := true;
	return response;
epilog
if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
end;</source>
        <Parameter name="request" type="WS_InterTerminalQueryRequest"/>
        <ReturnType type="WS_InterTerminalResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="getInterTerminalTruckLoads" id="4de1afc5-3f92-41a4-8b7c-101caa2a3d51">
        <source>getInterTerminalTruckLoads(request : WS_InterTerminalQueryRequest) : WS_InterTerminalResponse webService;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 Feb 2017	cnwam15	Initial creation
08 Jan 2026 navma1  MTN-36897 PEN - Transient File Growth in PEN Production Environment 
*/

vars
	interTerminalJob		: CM_InterTermVehicleJob;
	proxyArray				: CM_InterTerminalMoveArray;
	interTerminalMoveArray 	: WS_InterTerminalMoveArray;
	interTerminalMoveProxy 	: WS_InterTerminalMove;
	interTerminalMove 		: CM_InterTerminalMove;
	response 				: WS_InterTerminalResponse;
	completedOK				: Boolean;
	terminal				: CM_Terminal;
	truck 					: CM_Vehicle;
begin
	
	//Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);

	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	create response transient;
	truck := app.myPassport.myTerminal.vehicles[request.truckId.toUpper, ""];
		
	if truck = null then
		completedOK := true;
		return response;
	endif;
	
	interTerminalJob := app.myRoot.allInterTerminalVehicleJobs.getAtKey(request.truckId.toUpper,"");
	
	if interTerminalJob = null then			//08.01.2026 navma1 #MTN-36897
		completedOK := true;
		return response;
	endif;
	
	create interTerminalMoveArray transient;	
	terminal := app.myPassport.myTerminal;
	
	create proxyArray transient;
	
	foreach interTerminalMove in interTerminalJob.allInterTerminalMoves do 
		if interTerminalMove.mySourceTerminal = terminal then
			proxyArray.add(interTerminalMove);
		endif;
	endforeach;
	
	foreach interTerminalMove in proxyArray do 
		create interTerminalMoveProxy transient;
		interTerminalMoveProxy.setProxyFromObject(interTerminalMove);
		response.allInterTerminalMoves.addExclusive(interTerminalMoveProxy);
	endforeach;	

	completedOK := true;
	return response;
epilog

	delete proxyArray;
	delete interTerminalMoveArray;

	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
end;</source>
        <Parameter name="request" type="WS_InterTerminalQueryRequest"/>
        <ReturnType type="WS_InterTerminalResponse"/>
    </JadeWebServicesMethod>
