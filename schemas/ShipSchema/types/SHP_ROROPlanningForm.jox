    <JadeMethod name="activate" id="f91ffc9b-636c-4d27-a57c-a8e05450d143">
        <controlMethod name="Form::activate"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>activate() updating;
/*
Purpose:			
Date		Who		Reason
11 July 2011	cnwab1	Initial creation
*/

vars

	doShow : Boolean;
	doShowCargoSideView : Boolean;
begin
	inheritMethod();
	self.amActive := true;
	
	doShow := (self.modeView = ShpDisplayMode_ColCodeLoad or  self.modeView = ShpDisplayMode_ColCodeDisch); // and self.workingMode = self.WorkMode_None ;
	doShowCargoSideView := self.mySideViewForm &lt;&gt; null;
	if self.myCurrentVoyage &lt;&gt; null and 
		global.isValidObject(self.myCurrentVoyage)  then	
		self.causeEvent(self.myTerminal.getTerminalEvent(ShowHide_VoyageAllocationsCC),true,doShow);		
	endif;
	self.causeEvent(self.myTerminal.getTerminalEvent(ShowHide_CargoSideView),true,doShowCargoSideView);
	

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="addPillarsToTopFrame" id="3726d2e6-4f2c-435d-b153-caa7f500b35b">
        <source>addPillarsToTopFrame() : Boolean;
/*
Purpose:			
Date		Who		Reason
24 August 2011	cnwab1	Initial creation
*/

vars
	layer : CM_DeckLayerLayout;
	item : CM_DeckItemLayout;
	obj : Object;
	objs : ObjectSet;
	hasPillars : Boolean;
begin
	if self.myCurrentDeck = null then
		return false;
	endif;

	create objs transient;
	
	// Take them off the top
	foreach obj in self.frmDeck.myDrawingFrame.CMUI_PointDrawingFrame.allPointGraphics discreteLock do
		if obj.CM_DeckItemLayout.isPillar() then
			objs.add(obj);
		endif;
	endforeach;
	
	foreach obj in objs  discreteLock do
			self.frmDeck.myDrawingFrame.CMUI_PointDrawingFrame.doRemoveGraphic(obj.CM_DeckItemLayout);
	
	endforeach;
	
	// add them to the top, so that they are on top of all other graphics
	foreach layer in self.myCurrentDeck.myDeckLayout.allDeckLayerLayouts discreteLock where layer.type = ROROLayerType_Structure do
		foreach item in layer.allDeckItemLayouts discreteLock do
			if item.isPillar() then
				hasPillars := true;
				self.frmDeck.myDrawingFrame.CMUI_PointDrawingFrame.doAddToArraysForProxy(item);
			endif;
		endforeach;
	endforeach;
	
	return hasPillars;
epilog
	delete objs;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="addToolbarControls" id="02a454c5-312c-4d7d-8fc4-84afbfc1f755">
        <updating/>
        <source>addToolbarControls() protected, updating;
// ---------------------------------------------------------------------------
// Created:     27 August 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	toolbar			: CMUI_Toolbar;
	showCaptions	: Boolean;
	
begin
	inheritMethod();

	toolbar := self.frmToolbar;

	showCaptions := toolbar.showCaptions;

	toolbar.addButton(self.btnPrint,CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addFrame(self.frmTBVoyage, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnViewDefn, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnViewActual, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnViewProposed, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnViewDischarge, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnViewExport, CMUI_Toolbar.Control_Alignment_Left); // PAR 31073
	
	toolbar.addButton(self.btnViewLoad, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addFrame(self.frmTBActualSub, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnWorkJob, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
//	toolbar.addButton(self.btnWorkSeq, CMUI_Toolbar.Control_Alignment_Left);
//	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnWorkPlan, CMUI_Toolbar.Control_Alignment_Left);

	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);

	toolbar.addButton(self.btnCCPalette, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnCCModeDisch, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnCCModeDLR, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnCCModeSOB, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnCCModeErase, CMUI_Toolbar.Control_Alignment_Left);
	
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	//make actual and auto discharge colour code buttons
//	toolbar.addButton(self.btnMakeActual, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnAutoDischCC, CMUI_Toolbar.Control_Alignment_Left);
//	toolbar.addButton(self.btnImportTasks, CMUI_Toolbar.Control_Alignment_Left);
//	toolbar.addButton(self.btnCustomsEDI, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnTranship,CMUI_Toolbar.Control_Alignment_Left); 
	self.btnTranship.visible := true;
	
	toolbar.addButton( self.btnSummarise, CMUI_Toolbar.Control_Alignment_Left );
	toolbar.addButton( self.btnCapacity, CMUI_Toolbar.Control_Alignment_Left );
	
	toolbar.addButton(self.btnSideView, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnROROConfig, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnCraneShifts,CMUI_Toolbar.Control_Alignment_Left); // TFS 3472
	
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	
	if app.isSpecial() then
		toolbar.addButton(self.btnAftFwdLinks, CMUI_Toolbar.Control_Alignment_Left);
		self.btnAftFwdLinks.enabled := true;
	endif;
	
	
	toolbar.positionToolbarControls();
	toolbar.visible := true;	

	
	toolbar := self.frmTBLoadCC;
	showCaptions := toolbar.showCaptions;
	toolbar.addButton(self.btnRefreshLoadCC, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.positionToolbarControls();
	toolbar.visible := true;
	
	toolbar := self.frmJobsToolbar;
	showCaptions := toolbar.showCaptions;
	toolbar.addButton(self.btnEditJob, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnPrintJobs, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnPrintJobsCSV, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnRefreshJobs, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.positionToolbarControls();
	toolbar.visible := true;
	

	toolbar := self.frmToolbar2;
	showCaptions := toolbar.showCaptions;
	
		toolbar.addButton(self.btnJobSave, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnJobEdit, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnJobDelete, CMUI_Toolbar.Control_Alignment_Left);
	
	toolbar.addFrame(self.frmTBWorkPoints, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);	

	toolbar.addButton(self.btnRefesh, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addFrame(self.frmTBScale, CMUI_Toolbar.Control_Alignment_Left);
	
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);


	
	toolbar.addFrame(self.frmTBArea, CMUI_Toolbar.Control_Alignment_Left);
	
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);	
	toolbar.addButton(self.btnDeselect, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnDrawRemarks, CMUI_Toolbar.Control_Alignment_Left);	// par 29124 July 2012
	
// PAR 30227 noticed during testing. We do not want these on the planning screen	
//	toolbar.addButton(self.btnDrawAlignLeft, CMUI_Toolbar.Control_Alignment_Left);
//	toolbar.addButton(self.btnDrawAlignRght, CMUI_Toolbar.Control_Alignment_Left);
//	toolbar.addButton(self.btnDrawAlignTop, CMUI_Toolbar.Control_Alignment_Left);
//	toolbar.addButton(self.btnDrawAlignBot, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);	
	
	//toolbar.addButton(self.btnEditJob, CMUI_Toolbar.Control_Alignment_Left);
	//toolbar.addButton(self.btnPrintJobs, CMUI_Toolbar.Control_Alignment_Left);
	//toolbar.addButton(self.btnPrintJobsCSV, CMUI_Toolbar.Control_Alignment_Left);
	//toolbar.addButton(self.btnRefreshJobs, CMUI_Toolbar.Control_Alignment_Left);
	
	
 	toolbar.positionToolbarControls();
	toolbar.visible := true;	
	

end;</source>
        <access>protected</access>
    </JadeMethod>
