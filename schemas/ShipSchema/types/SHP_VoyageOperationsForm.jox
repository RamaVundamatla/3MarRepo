    <JadeMethod name="doNotableAdd" id="ece064a7-98f0-441e-a4b8-23d20ef6b0a2">
        <source>doNotableAdd(_ti : CM_TrackedItem);
//--------------------------------------------------
// Created:	12 January 2004 By: cnwgd1
//--------------------------------------------------
vars

begin
	if _ti = null then
		return;
	endif;
	
	if (not global.isValidObject(_ti)) then
		return;
	endif;
	
	if (not self.allNotableTIs.includes(_ti)) then
		self.allNotableTIs.add(_ti);
		beginNotification(_ti, Object_Update_Event, Response_Continuous, null);
	endif;
	
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="doNotableClear" id="3c0a651b-5d82-420b-9cf6-edcbb820b5ab">
        <source>doNotableClear();
//--------------------------------------------------
// Created:	12 January 2004 By: cnwgd1
//--------------------------------------------------
vars
	ti : CM_TrackedItem;
begin

	foreach ti in self.allNotableTIs do
		endNotification(ti, Object_Update_Event);
	endforeach;

	self.allNotableTIs.clear;

end;</source>
    </JadeMethod>
    <JadeMethod name="doNotificationStorage" id="755187af-a587-435a-aa3a-b290ddf72501">
        <updating/>
        <source>doNotificationStorage(_wle : CM_WorkListEntry input; _mode : Integer) protected, updating;

// Created by cnwdvb1 on 26 February 2007

vars

	randomNumber : Integer;

begin

	if not self.startedTimer then
		randomNumber := 0;
		randomNumber := app.random(10);
		
		self.beginTimer(randomNumber * 100 , Timer_OneShot, 1);
		self.startedTimer := true;
	endif;
	
	
	
	if _mode = self.Mode_Add then
		if not self.allAddedWles.includes(_wle) then
			self.allAddedWles.add(_wle);
		endif;
	elseif _mode = self.Mode_Update then
		if not self.allUpdatedWles.includes(_wle) and not self.allAddedWles.includes(_wle) then
			self.allUpdatedWles.add(_wle);
		endif;
	elseif _mode = self.Mode_Delete then
		if not self.allDeletedWles.includes(_wle) then
			self.allDeletedWles.add(_wle);
		endif;
	else
		// Invalid mode
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="_wle" type="CM_WorkListEntry" usage="input"/>
        <Parameter name="_mode" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doOpenMoveCargoFromJobForm" id="75ca531b-a382-4c93-956c-730a2ad8eecb">
        <source>doOpenMoveCargoFromJobForm();
// --------------------------------------------------------------------------------
// Created:		01 September 2010 by cnwjo3
//
// Purpose:		This method will open CMUI_SplitOrTransWorkCraneForm.
//				CCMS 1178 PAR 23366
//
// Updated:		par 25983.  Need to work with the currently selected WLE and get the job from that.
//
vars
	voyageJob : CM_VoyageJob;
	obj : Object;
	voyageWLE : CM_VoyageWLE;
	selectedWLEs : CM_WLESet;
begin
	create selectedWLEs transient;

	if self.myCurrentWLE &lt;&gt; null then
		voyageJob := self.myCurrentWLE.job.CM_VoyageJob;
	endif;

	if voyageJob = null then
		voyageJob := self.myCurrentJob;
	endif;
	
	foreach obj in self.myCurrentTableWLE.allSelectedObjects discreteLock do
		voyageWLE := obj.CM_VoyageWLE;
		if voyageWLE.job = voyageJob then
			selectedWLEs.add(voyageWLE);
		endif;
	endforeach;

	self.myAssistant.showMoveCargoFromJobForm(voyageJob,selectedWLEs);
epilog
	delete selectedWLEs;
end;</source>
    </JadeMethod>
    <JadeMethod name="doOpenMoveCargoFromJobForm2" id="549927fe-1422-44fd-b9ff-02e77182bd45">
        <source>doOpenMoveCargoFromJobForm2();
// --------------------------------------------------------------------------------
// Created:		24 September 2010 by cnwjo3
//
// Purpose:		This method will open CMUI_SplitOrTransWorkCraneForm.
//				CCMS 1178 PAR 23366.  Note: this menu item is accessed from popup frame
//
vars
	voyageJob : CM_VoyageJob;
	obj : Object;
	voyageWLE : CM_VoyageWLE;
	selectedWLEs : CM_WLESet;
begin
	voyageJob := self.lstJobs.listObject.CM_VoyageJob;
	
	if voyageJob = null then
		return;
	endif;
	
	create selectedWLEs transient;
	
	self.myAssistant.showMoveCargoFromJobForm(voyageJob,selectedWLEs);
epilog
	delete selectedWLEs;
end;</source>
    </JadeMethod>
    <JadeMethod name="doOpenSplitWorkCraneFrm" id="a2186f5e-ad3f-467b-a7d3-2223b6ef10ee">
        <source>doOpenSplitWorkCraneFrm();
// --------------------------------------------------------------------------------
// Created:		01 September 2010 by cnwjo3
//
// Purpose:		This method will open CMUI_SplitOrTransWorkCraneForm.
//				CCMS 1178 PAR 23366
//
// Updated:		par 25983.  Need to work with the currently selected WLE and get the job from that.
//
// Changed On	By			Reason
// ----------	----------	-------------------------------------------------------
// 18/12/2019	jlgdap1		TFS 47144 JMT Refactor OOW Job Split Transfer - renamed from doOpenSplitOrTransWorkCraneFrm
vars
	voyageJob : CM_VoyageJob;
	obj : Object;	
	voyageWLE : CM_VoyageWLE;
	selectedWLEs : CM_WLESet;
begin
	create selectedWLEs transient;

	if self.myCurrentWLE &lt;&gt; null then
		voyageJob := self.myCurrentWLE.job.CM_VoyageJob;
	endif;
	
	if voyageJob = null then
		voyageJob := self.myCurrentJob;
	endif;
	
	foreach obj in self.myCurrentTableWLE.allSelectedObjects discreteLock do
		voyageWLE := obj.CM_VoyageWLE;
		if voyageWLE.job = voyageJob then
			selectedWLEs.add(voyageWLE);
		endif;
	endforeach;
	
	self.myAssistant.showSplitWorkCraneForm(voyageJob,selectedWLEs,null);
epilog
	delete selectedWLEs;
end;</source>
    </JadeMethod>
