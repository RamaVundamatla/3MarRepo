    <JadeMethod name="tRORODeckPlanMSL3" id="1b866da4-c766-42e1-91be-8cdee98a7de1">
        <source>tRORODeckPlanMSL3();
// cnwrs1
//
// cnwcs5 par 29533 - copied from tLoadDeckPlanMSl
//
//	
constants
	VoyageName 				= 'CRORO29533';
	ShipName 				= 'JROSO';
	TestOperator 			= 'MSL';
	UserDefinedShipManifest	= 'Unit Test RORO Baplie MSL';
vars
	clientRef : String;
	messageType : String;
	ediText : String;
	fileTypeUser : CM_EDIFileTypeUser;
	pxyFileTypeUser : CM_EDIFileTypeUser;
	voyage : CM_Voyage;
	ediFile : CM_EDIFile;
	binaryMsg : Binary;
	ediControllerAgent : CM_EDIControllerAgent;
	operator : CM_Operator;
	ediDataParams : CMIF_EDIDataDetails;
	idx : Integer;
begin
	create ediControllerAgent transient;
	create pxyFileTypeUser transient;
	
	ediControllerAgent.setTerminal( self.getTerminal );	
		
	// create the required user definition format.
	app.myTrxCA.trxCreateEDIFileTypeUser(fileTypeUser, pxyFileTypeUser, app.myPassport);
	fileTypeUser := app.myRoot.allEDIFileTypes.getAtKey(EDIFileType_UserDefined, UserDefinedShipManifest).CM_EDIFileTypeUser;
	self.assertNotNullMsg(fileTypeUser, 'User Type ' &amp; UserDefinedShipManifest &amp; ' is missing');
	self.assertEqualMsg (fileTypeUser.delimiter, ';', 'Delimiter');

	self.deleteVoyage(VoyageName);
	voyage := self.getVoyage(VoyageName);
	self.assertIsDeleted(voyage);
	
//	self.deleteVessel(ShipName);
//	vessel := self.getVessel(ShipName);
//	self.assertIsDeleted(vessel);
	operator := app.myRoot.allOperators[TestOperator];
	
	// now set up cleanly
//	vessel := self.addVesselConRORO(ShipName, operator);
//	self.assertNotNullMsg(vessel, 'Add vessel failed');
	voyage := self.addVoyageWithConRORO(VoyageName, ShipName, TestOperator, TestOperator, "MSL East Africa", 0, false, true);

	self.assertNotNullMsg( voyage, 'Add voyage failed' );
	voyage := self.getVoyage(VoyageName);
	self.assertNotNull(voyage);

//  now add the ship manifest via EDI
	delete ediControllerAgent;
	create ediControllerAgent transient;
	ediControllerAgent.setTerminal( self.getTerminal );	// cnwrl1 24/05/2010 PAR 24276
	
	// setup the add ship manifest here
	ediText := self.uRORODeckPlanMSL3(VoyageName, ShipName, TestOperator);
	// take the edi Data string make it binary and set up the required EDI Message Type.
	binaryMsg 	:= ediText.Binary;
	messageType := UserDefinedShipManifest[1 : fileTypeUser.name.maxLength];  // ie 63
	idx 		:= idx + 1;
	clientRef 	:= method.name[1 : ediControllerAgent.ediClientRef.maxLength-1] &amp; idx.String;		// ie 30
	
	ediControllerAgent.setEdiClientRef(clientRef);
	
	// make sure all of the objects are deleted and created correctly.
	ediFile := self.ediLoadFileName(ediText, EDIFileType_UserDefined, UserDefinedShipManifest, UserDefinedShipManifest&amp;method.name);
	
	self.assertNotNull(ediFile);
	
	self.ediVerify (ediFile);
	// we expect verify errors here
	self.assertEqualMsg (ediFile.fileStatus, CM_EDIFile.EDI_STATUS_VERIFIED_ERRORS, 'Status should be verify errors');
	//self.assertTrxErrorMsg (ERR_CARGO_FIELD, 'Expecting invalid cargo type error');
	self.assertTrxErrorMsg(Cargot_not_valid_cargot_system, 'Expecting cargo not valid for system error');
	return;
	self.ediDBLoad (ediFile);
	
epilog
	delete ediControllerAgent;
	delete pxyFileTypeUser;
	delete ediDataParams;
end;

</source>
    </JadeMethod>
    <JadeMethod name="tRORODeckPlanMSL4" id="7f82a43e-08db-44a6-875d-63df6a81143c">
        <source>tRORODeckPlanMSL4();
// cnwrs1
//
// cnwcs5 par 29533 - copied from tLoadDeckPlanMSl
//
// 20 Jun 2013 	cnwcs5	par 31854 - add check for voyage xlations	
constants
	VoyageName 				= 'CRORO29533A';
	ShipName 				= 'JROSO';
	TestOperator 			= 'MSL';
	UserDefinedShipManifest	= 'Unit Test RORO Baplie MSL';
vars
	clientRef : String;
	messageType : String;
	ediText : String;
	fileTypeUser : CM_EDIFileTypeUser;
	pxyFileTypeUser : CM_EDIFileTypeUser;
	voyage : CM_Voyage;
	ediFile : CM_EDIFile;
	binaryMsg : Binary;
	ediControllerAgent : CM_EDIControllerAgent;
	operator : CM_Operator;
	ediDataParams : CMIF_EDIDataDetails;
	idx : Integer;
	xmlBlock :String;
	ediTI	:CM_EDITrackedItem;
begin
	create ediControllerAgent transient;
	create pxyFileTypeUser transient;
	
	ediControllerAgent.setTerminal( self.getTerminal );	
	// the block string below represents the XML of the required user file type definition format.
	xmlBlock := self.xmlDef_DeckPlanMSL(UserDefinedShipManifest);
	
	// break up the XML into the proxy CM_EDIFileTypeUser
	pxyFileTypeUser.importMeXML(xmlBlock);
	
	// make sure the required definition name does not already exist.
	fileTypeUser := app.myRoot.allEDIFileTypes[EDIFileType_UserDefined, UserDefinedShipManifest].CM_EDIFileTypeUser;
	
	if fileTypeUser &lt;&gt; null then
		//if it does exist then delete it.
		app.myTrxDA.trxDeleteEDIFileTypeUser(fileTypeUser, app.myPassport);
		self.assertIsDeleted(fileTypeUser);
		self.assertTrue(app.myPassport.trxCompletedOK());
	endif;

	// create the required user definition format.
	app.myTrxCA.trxCreateEDIFileTypeUser(fileTypeUser, pxyFileTypeUser, app.myPassport);
	
	fileTypeUser := app.myRoot.allEDIFileTypes.getAtKey(EDIFileType_UserDefined, UserDefinedShipManifest).CM_EDIFileTypeUser;
	
	self.assertNotNullMsg(fileTypeUser, 'User Type ' &amp; UserDefinedShipManifest &amp; ' is missing');
	self.assertEqualMsg (fileTypeUser.delimiter, ';', 'Delimiter');

	operator := app.myRoot.allOperators[TestOperator];

	// set translation operator for this file
	beginTransaction;
		fileTypeUser.setPropertyValue (CM_EDIFileTypeUser::applyTranslations.name, true);
		fileTypeUser.setPropertyValue (CM_EDIFileTypeUser::myXlationOperator.name, operator);
	commitTransaction;
	
	self.deleteVoyage(VoyageName);
	voyage := self.getVoyage(VoyageName);
	self.assertIsDeleted(voyage);
	
//	self.deleteVessel(ShipName);
//	vessel := self.getVessel(ShipName);
//	self.assertIsDeleted(vessel);
	
	// now set up cleanly
//	vessel := self.addVesselConRORO(ShipName, operator);
//	self.assertNotNullMsg(vessel, 'Add vessel failed');
	voyage := self.addVoyageWithConRORO(VoyageName, ShipName, TestOperator, TestOperator, "MSL East Africa", 0, false, true);

	self.assertNotNullMsg( voyage, 'Add voyage failed' );
	voyage := self.getVoyage(VoyageName);
	self.assertNotNull(voyage);

//  now add the ship manifest via EDI
	delete ediControllerAgent;
	create ediControllerAgent transient;
	ediControllerAgent.setTerminal( self.getTerminal );	// cnwrl1 24/05/2010 PAR 24276
	
	// setup the add ship manifest here
	ediText := self.uRORODeckPlanMSL4(VoyageName, ShipName, TestOperator);
	// take the edi Data string make it binary and set up the required EDI Message Type.
	binaryMsg 	:= ediText.Binary;
	messageType := UserDefinedShipManifest[1 : fileTypeUser.name.maxLength];  // ie 63
	idx 		:= idx + 1;
	clientRef 	:= method.name[1 : ediControllerAgent.ediClientRef.maxLength-1] &amp; idx.String;		// ie 30
	
	ediControllerAgent.setEdiClientRef(clientRef);
	
	// make sure all of the objects are deleted and created correctly.
	ediFile := self.ediLoadFileName(ediText, EDIFileType_UserDefined, UserDefinedShipManifest, UserDefinedShipManifest&amp;method.name);
	
	self.assertNotNull(ediFile);
	
	// check that voyage has been updated
	foreach ediTI in ediFile.ediData.allEDITrackedItems do
		if ediTI.isKindOf (CM_EDICargoTI) then
			self.assertNotNullMsg (ediTI.CM_EDICargoTI.getPropertyValue (CM_EDICargoTI::voyageCode.name), 'Cargo voyage');
		elseif ediTI.isKindOf (CM_EDIVoyageConsistTI) then
			self.assertNotNullMsg (ediTI.CM_EDIVoyageConsistTI.getPropertyValue (CM_EDIVoyageConsistTI::voyageCode.name), 'Voyage voyage');
		endif;
	endforeach;
	
	self.ediVerify (ediFile);
	// we expect verify errors here
	self.assertEqualMsg (ediFile.fileStatus, CM_EDIFile.EDI_STATUS_VERIFIED_ERRORS, 'Status should be verify errors');
	self.assertTrxErrorMsg (CargoType_NotRequire_Commodity, 'Expecting cargo type does not require commodity error');
	return;
	self.ediDBLoad (ediFile);
	
epilog
	delete ediControllerAgent;
	delete pxyFileTypeUser;
	delete ediDataParams;
end;

</source>
    </JadeMethod>
    <JadeMethod name="tRORODeckPlanMSL5" id="e1e73ca0-fbb1-438e-88ed-52e0deacb8ab">
        <source>tRORODeckPlanMSL5();
//
//11 Jul 2012	cnwrs1		Par 29988 EDI When loading a Deck Plan file with OOTLs needa unique name
//
//	
constants
	VoyageName 				= 'CRORO29533A';
	ShipName 				= 'JROSO';
	TestOperator 			= 'MSL';
	UserDefinedShipManifest	= 'Unit Test RORO Baplie MSL';
vars
	clientRef : String;
	messageType : String;
	ediText : String;
	fileTypeUser : CM_EDIFileTypeUser;
	pxyFileTypeUser : CM_EDIFileTypeUser;
	voyage : CM_Voyage;
	ediFile : CM_EDIFile;
	binaryMsg : Binary;
	ediControllerAgent : CM_EDIControllerAgent;
	operator : CM_Operator;
	ediDataParams : CMIF_EDIDataDetails;
	idx : Integer;
	tempStr : String;
begin
	create ediControllerAgent transient;
	create pxyFileTypeUser transient;
	
	ediControllerAgent.setTerminal( self.getTerminal );	
		
	// create the required user definition format.
	app.myTrxCA.trxCreateEDIFileTypeUser(fileTypeUser, pxyFileTypeUser, app.myPassport);
	fileTypeUser := app.myRoot.allEDIFileTypes.getAtKey(EDIFileType_UserDefined, UserDefinedShipManifest).CM_EDIFileTypeUser;
	self.assertNotNullMsg(fileTypeUser, 'User Type ' &amp; UserDefinedShipManifest &amp; ' is missing');

	self.deleteVoyage(VoyageName);
	voyage := self.getVoyage(VoyageName);
	self.assertIsDeleted(voyage);
	
//	self.deleteVessel(ShipName);
//	vessel := self.getVessel(ShipName);
//	self.assertIsDeleted(vessel);
	operator := app.myRoot.allOperators[TestOperator];
	
	// now set up cleanly
//	vessel := self.addVesselConRORO(ShipName, operator);
//	self.assertNotNullMsg(vessel, 'Add vessel failed');
	voyage := self.addVoyageWithConRORO(VoyageName, ShipName, TestOperator, TestOperator, "MSL East Africa", 0, false, true);

	self.assertNotNullMsg(voyage, 'Add voyage failed');
	voyage := self.getVoyage(VoyageName);
	self.assertNotNull(voyage);

//  now add the ship manifest via EDI
	delete ediControllerAgent;
	create ediControllerAgent transient;
	ediControllerAgent.setTerminal( self.getTerminal );	// cnwrl1 24/05/2010 PAR 24276
	
	// setup the add ship manifest here
	ediText := self.uRORODeckPlanMSL5(VoyageName, ShipName, TestOperator);
	// take the edi Data string make it binary and set up the required EDI Message Type.
	binaryMsg 	:= ediText.Binary;
	messageType := UserDefinedShipManifest[1 : fileTypeUser.name.maxLength];  // ie 63
	idx 		:= idx + 1;
	clientRef 	:= method.name[1 : ediControllerAgent.ediClientRef.maxLength-1] &amp; idx.String;		// ie 30
	
	ediControllerAgent.setEdiClientRef(clientRef);
	
	// make sure all of the objects are deleted and created correctly.
	ediFile := self.ediLoadFileName(ediText, EDIFileType_UserDefined, UserDefinedShipManifest, UserDefinedShipManifest&amp;method.name);
	
	self.assertNotNull(ediFile);
	
	self.ediVerify(ediFile);
	// we expect verify errors here
	tempStr	:= 'Verify Failed' &amp; CrLf &amp; app.myPassport.getAllErrorsWarningsAsString;
	self.assertEqualMsg(ediFile.fileStatus, CM_EDIFile.EDI_STATUS_VERIFIED, tempStr);
//	self.assertTrxErrorMsg(CargoType_NotRequire_Commodity, 'Expectingg cargo type does not require commodity error');
//	return;
	self.ediDBLoad(ediFile);
	tempStr	:= 'DBLoad Failed' &amp; CrLf &amp; app.myPassport.getAllErrorsWarningsAsString;
	self.assertEqualMsg(ediFile.fileStatus, CM_EDIFile.EDI_STATUS_DBLOADED, tempStr);
	
epilog
	delete ediControllerAgent;
	delete pxyFileTypeUser;
	delete ediDataParams;
end;

</source>
        <text>&lt;?xml version="1.0"?&gt;
&lt;UT_Additional&gt;
  &lt;Categories&gt;
    &lt;Category CanDelete="true"&gt;Michael_PAR31258&lt;/Category&gt;
  &lt;/Categories&gt;
&lt;/UT_Additional&gt;</text>
