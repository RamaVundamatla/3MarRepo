    <JadeMethod name="lockExceptionHandlerMsgBox" id="693da3d9-8925-4a4a-8aa3-d845e66bfc2c">
        <source>lockExceptionHandlerMsgBox(lockExObj : LockException) : Boolean;
// --------------------------------------------------------------------------------
// Method:		lockExceptionHandlerMsgBox
//
// Purpose:		Display a message box allowing the user to retry a lock
//
// Parameters:	LockException object
//
// Returns:		True if we obtain the lock, otherwise false
// --------------------------------------------------------------------------------
vars
	user, msg, title : String;
	retries : Integer;

begin
	retries := 0;

	user := app.getUserForException(lockExObj);
	app.writeLogLockException(lockExObj);

	msg := "Your current operation requires data that is already locked and in use by user: " &amp;
		user &amp; "." &amp; CrLf &amp; CrLf &amp; "Number of Retries so far: ";
	// ### JIRA 19932 21OCT2024 NAVAB1
	msg := "The system is busy at the moment,"  &amp; CrLf &amp; "your changes will pause momentarily,"  &amp; CrLf &amp; "before retrying; or you can click cancel.";

	// ### JIRA 19932 21OCT2024 NAVAB1
	title := "Data Locked by another user";
	title := "System Retry";

	while true do
		// Prompt the user
		if msgBox(msg &amp; retries.String &amp; CrLf &amp; CrLf &amp; "Do you want to retry, or cancel and re-attempt later?", // the lock, or cancel and re-attempt later?",
			title, MsgBox_Retry_Cancel + MsgBox_Exclamation_Mark_Icon) = MsgBox_Return_Retry then
        	// We're to retry the lock
			retries := retries + 1;
			// tryLock attempts to lock an object but returns a boolean indicating success or
			// failure instead of raising an exception
			if tryLock(lockExObj.lockTarget, lockExObj.lockType, lockExObj.lockDuration, LockTimeout_Immediate) then
				// We got the lock
				return true;
			endif;
		else
			// Had enough of retrying
			break;
		endif;
	endwhile;

	return false;
end;</source>
        <Parameter name="lockExObj" type="LockException"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="lockKeeperNotifyEndActivity" id="d1f9be6c-88e7-4813-8659-a91435f8f31f">
        <source>lockKeeperNotifyEndActivity(_startTime : TimeStamp; _isOK : Boolean; _passport : CM_Passport input) : Boolean;
// ---------------------------------------------------------------------------
// Created:     10 February 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	userInfo	: String;
	tmpId		: Integer;

begin

	userInfo := app.userInfoStringEndTrxEncode(process, _startTime, app.actualTimeServer, _isOK, _passport);
	system.causeEvent(LockKeeper_EndTrx_Event, true, userInfo);

	// the following only does something if the ini file
	// options to turn on CardSchema transaction logging
	// have been turned on
	if self.allCnTransactionIds.size &gt; 0 then
		tmpId := self.allCnTransactionIds.last;
		self.cnEndTransactionEx(tmpId);
		self.allCnTransactionIds.remove(tmpId);
	endif;
	
	return true;

end;</source>
        <Parameter name="_startTime" type="TimeStamp"/>
        <Parameter name="_isOK" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="lockKeeperNotifyStartActivity" id="7e959548-9060-4b16-9756-999eb5a54651">
        <source>lockKeeperNotifyStartActivity(_startTime : TimeStamp; _exMethod : Method; _exTerminal : CM_Terminal; 
				_info : String; _passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:     10 February 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpStr,
	userInfo	: String;
	tmpId		: Integer;
	
begin

	//	notify the LockKeeper that a transaction is starting
	userInfo := app.userInfoStringStartTrxEncode(process, _startTime, _exMethod, _exTerminal, _info);
	system.causeEvent(LockKeeper_StartTrx_Event, true, userInfo);

	// the following only does something if the ini file
	// options to turn on CardSchema transaction logging
	// have been turned on
	if _info &lt;&gt; null then
		tmpStr := _info;
	elseif _exMethod &lt;&gt; null then
		//tmpStr := _exMethod.name &amp; '(' &amp; _exMethod.class.name &amp; ')';
		tmpStr := _exMethod.qualifiedName();
	else
		tmpStr := '&lt;unknown&gt;';
	endif;
   	if tmpStr.length &gt; 50 then
   		tmpStr := tmpStr[1:50];
   	endif;
	tmpId := self.cnStartTransaction(tmpStr);
	
	if tmpId &gt; 0 then
		self.allCnTransactionIds.add(tmpId);
	endif;
	
end;</source>
        <Parameter name="_startTime" type="TimeStamp"/>
        <Parameter name="_exMethod" type="Method"/>
        <Parameter name="_exTerminal" type="CM_Terminal"/>
        <Parameter name="_info" type="String"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
