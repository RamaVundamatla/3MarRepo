    <JadeMethod name="getWagon" id="7235d5f6-61a9-4e4f-8024-e465bb55be2e">
        <source>getWagon():CM_Wagon;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 Jan 2023 navhl20 ChangeRequest 62166: EUP | 53729 - Delivery Dispatch Screen - outstanding issues

*/

vars
	wagon : CM_Wagon;
begin
	wagon := self.getMyWagon();
	
	if wagon = null then				
		wagon := self.getWagonFromTrain();
	endif;
	
	if wagon = null then
		wagon := self.getWagonFromWle();
	endif;
	
	return wagon;
epilog

end;</source>
