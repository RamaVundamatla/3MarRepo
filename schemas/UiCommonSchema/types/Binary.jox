<PrimType name="Binary">
    <JadeMethod name="abBinaryKey" id="b689b5c4-4ce8-4687-9c3d-405b2c73af64">
        <source>abBinaryKey() : Binary;
/*
Purpose:			

Date		Who		Reason
05AUG2021	NAVAB1	TFS 50669
*/

vars
	part1, part2, whole : Binary;
	len : Integer;
		lenth : Integer;
begin
	if self.length &gt;= 500 then
	
		len := self.length - 245;
		
		part1 := self[1:245];
		part2 := self[len:end];
		
		whole := part1 &amp; part2;
		lenth := whole.length;
		
//		write lenth.String &amp; " " &amp; len.String &amp; " " &amp; self.length.String;
		
		return whole;
	else
		return self;
	endif;
end;
</source>
        <ReturnType type="Binary"/>
    </JadeMethod>
</PrimType>
