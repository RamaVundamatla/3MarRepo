    <JadeMethod name="pwMapFiles" id="bb8e275b-9b3f-4947-8d2f-6e0427052e19">
        <source>pwMapFiles();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 November 2025	navpw1	Initial creation

*/

constants
  COUNT_INSTANCES    = true;
vars
  dbfile    : DbFile;
  classMaps  : UserDbClassMapSet;
  classMap  : DbClassMap;
  className  : String;
  cls      : Class;
  scm      : Schema;
  str      : String;
begin  
  foreach dbfile in DbFile.instances do
    if dbfile.name.isOneOf("containr", "") then
      write dbfile.name &amp; Tab &amp; (dbfile.getFileLength() / 1024 / 1024).numberFormat() &amp; " MB";
      classMaps := dbfile.getPropertyValue("classMapRefs").UserDbClassMapSet;
      foreach classMap in classMaps do
        scm := classMap.sendMsg("_getSchema").Schema;
        className := classMap.getName().getTokens()[1];
        cls := scm.getClass(className);
        str := cls.name;

        if COUNT_INSTANCES then
          str &amp;= Tab &amp; cls.instances.size64.String;
        endif;

        write str;
      endforeach;
    endif;
  endforeach;

  write "done";
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="pwMethodSetText" id="2d49fb1a-c578-403b-9575-5f2f69d1ea83">
