    <JadeMethod name="deleteVoyageAllocation" id="b4ecbc7d-fa3b-4db4-ad30-7736918b8716">
        <source>deleteVoyageAllocation();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 November 2015	cnwma1	PAR #36753 Colour Coding Criteria not getting deleted when voyage deleted
*/

vars
		ya : CM_YACriteria;
		count : Integer;
		total : Integer;
begin
	if self.hasScriptBeenRunAtAll(method.name, null) then
		return;
	endif;
	app.writeLog(method.qualifiedName &amp; " Deleting Voyage allocation for deleted voyages", LogINFO);
	
	beginTransaction;
	foreach ya in CM_YACriteria.instances do
			if ya.myYardAllocation.isKindOf(CM_VoyageAllocation)then
				if ya.myYardAllocation.CM_VoyageAllocation.myVoyage = null then
					ya.erase(NORMAL_ERASE);
					count := count + 1;
					total := total +1;
					if count &gt; 5000 then
						commitTransaction;
						count := 0;
						beginTransaction;
					endif;
				endif;
			endif;
	endforeach;
	if count &gt;= 0 then
		commitTransaction;
	endif;
	app.writeLog(method.qualifiedName &amp; " Completed deleting Voyage Allocation for deleted voyages , " &amp; total.String &amp; " Deleted", LogINFO);
	
	
	self.addScriptRun(method.name);
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="fixCargoAndProductAttributes" id="2a3acbf3-b105-448d-9c45-353b837756da">
        <source>fixCargoAndProductAttributes(_controller: CnEcReleaseController);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 February 2018	jlger1	Initial creation tfs 7756

*/

vars
	cargoType : CM_CargoType;
	entDef : EntTableDef;
	entRow : EntTableRow;
	prodAttr : CM_ProductAttr;
	product : CM_Product;
begin
	if self.hasScriptBeenRunAtAll(method.name, _controller) then
		return;
	endif;
	
	app.writeLog(method.qualifiedName &amp; " Fixing Bulk and Vehicle cargo attributes", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry(" Fixing Bulk and Vehicle cargo attributes") ;	
	endif;
	
	entDef := CM_EntTableDataRoot.firstInstance.allEntTableDefs[ETDef_AllAttributes];
	foreach cargoType in CM_CargoType.instances do
		if cargoType.isSystemCargoBOLType or							// PAR #33606
		   cargoType.id &gt; TI_CargoBOLType_JMTMax then
			if cargoType.allAttributesOnProduct.size  &gt;0 then
				//write cargoType.description &amp; " is system should not have attrs";
				beginTransaction;
					cargoType.allAttributesOnProduct.clear;
				commitTransaction;
			endif;
		elseif cargoType.isTrailer or cargoType.isCargoGroup then
			if cargoType.allAttributesOnProduct.size  &gt;0 then
				//write cargoType.description &amp; " is trailer/cargo group should not have attrs";
				beginTransaction;
					cargoType.allAttributesOnProduct.clear;
				commitTransaction;
			endif;
		else
			if cargoType.productType = ProductType_Vehicle or cargoType.isBulk then
				foreach entRow in entDef.allEntTableRows do
					if cargoType.isBulk then
						//this stuff never gets saved
						if  not (entRow.name = ETRow_MyType or entRow.name =ETRow_MyLengthString or entRow.name = ETRow_MyWidthString or entRow.name = ETRow_MyHeightString)   then
							continue;					
						endif;
					else
						//vehicle
						if  (entRow.name = ETRow_MyLength or entRow.name = ETRow_MyWidth or entRow.name = ETRow_MyHeight) then
							continue;									
						endif;
					endif;
					beginTransaction;
					if cargoType.allAttributesOnProduct.includes(entRow.name) then
						//write cargoType.description &amp; " should not have " &amp; entRow.name;
						while cargoType.allAttributesOnProduct.includes(entRow.name) do
							cargoType.allAttributesOnProduct.remove(entRow.name);
						endwhile;
					endif;	
					if cargoType.mySystemProductType &lt;&gt; null then
						prodAttr:=cargoType.mySystemProductType.getProdAttrFromName( entRow.name);
						if prodAttr &lt;&gt; null then
							if prodAttr.isViewable then
								prodAttr.setIsViewable(false);
							//	write prodAttr.name &amp; " should not be viewable";
							endif;
						endif;
					else 
						foreach product in cargoType.allProducts do
								prodAttr:=product.getProdAttrFromName( entRow.name);
								if prodAttr &lt;&gt; null then
									if prodAttr.isViewable then
										prodAttr.setIsViewable(false);
									//	write prodAttr.name &amp; " should not be viewable";
									endif;
								endif;
						endforeach;
					endif;
					commitTransaction;
				endforeach;
			endif;
		endif;
	endforeach;
	
	self.addScriptRun(method.name);
	
	app.writeLog(method.qualifiedName &amp; " Finished fixing Bulk and Vehicle cargo attributes", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry(" Finished fixing Bulk and Vehicle cargo attributes") ;	
	endif;
epilog	

end;</source>
        <Parameter name="_controller" type="CnEcReleaseController"/>
    </JadeMethod>
    <JadeMethod name="fixContainerTEU" id="56011a12-722a-4821-a631-d2ae9aebf204">
        <source>fixContainerTEU(_controller: CnEcReleaseController);
/*

Date		Who		Reason
07 July 2016	cnwer1	Initial creation TFS 2290

*/

vars
	root : CM_Root;
	contCargoType : CM_CargoType;
	finishString : String;
begin
	
	app.writeLog(method.qualifiedName &amp; " Fixing Containers without TEU conversions", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry("Fixing Containers without TEU conversions") ;	
	endif;
	finishString:= "Fixing Containers without TEU conversions finsihed.";
	root :=CM_Root.firstInstance;
	contCargoType:= root.allCargoTypesById[TI_CargoType_Container];
	if contCargoType.teuConversion.size &lt; 5 then
		beginTransaction;
		contCargoType.setForUpdateTEUSettings(contCargoType.teuMultiplier,null);
		commitTransaction;
		finishString := finishString &amp; " ISO Container fixed";
	else
		finishString := finishString &amp; " Nothing to fix";
	endif;
	
	app.writeLog(method.qualifiedName &amp; " " &amp;finishString ,LogINFO );
	if _controller &lt;&gt; null then
		_controller.logEntry(finishString) ;	
	endif;
epilog

end;</source>
        <Parameter name="_controller" type="CnEcReleaseController"/>
    </JadeMethod>
    <JadeMethod name="fixGLDate" id="cda1f6d8-7c3b-403b-9f0b-d0f45adaea7e">
        <source>fixGLDate(_controller: CnEcReleaseController);
/*
Purpose:			
Date				Who			Reason
JUNE 2017		CNWAB1		Initial creation
*/

vars
	root : CM_Root;
	term : CM_Terminal;
	config : CM_StorageConfig;

begin
	if self.hasScriptBeenRunAtAll(method.name, _controller) then
		return;
	endif;
	
	app.writeLog(method.qualifiedName &amp; " Removing General Landing Date from Storage Configuration for Ship Releases", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry(" Removing General Landing Date from Storage Configuration for Ship Releases") ;	
	endif;
	
	root := CM_Root.firstInstance();
	
	foreach term in root.allTerminals discreteLock do
		config := term.myStorageConfig;
		if config &lt;&gt; null then
			if config.shipReleaseType = Voyage_General_Landing then
				beginTransaction;
					config.setPropertyValue("shipReleaseType", Voyage_Actual_Load);
				commitTransaction;
			endif;
		endif;
	endforeach;
	
	app.writeLog(method.qualifiedName &amp; " Removing General Landing Date from Storage Configuration for Ship Releases complete", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry(" Removing General Landing Date from Storage Configuration for Ship Releases complete") ;	
	endif;
	
	self.addScriptRun(method.name);

epilog

end;</source>
        <Parameter name="_controller" type="CnEcReleaseController"/>
    </JadeMethod>
    <JadeMethod name="fixImportConfirmedListReport" id="59640c82-c670-4971-8f5b-c9549061841b">
        <source>fixImportConfirmedListReport(_controller : CnEcReleaseController);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 May 2018	jlgns1	Initial creation
Bug 38250: SNO - Issue with the output of a JMT standard report
*/

vars
	menuAgent	: CM_MenuAgent;
	menuRoot	: CM_MenuRootReportForRoot;
	report		: GlobalConstant;
	theMenuId 	: String;
	qryReport	: CM_QryReportSystem;
begin

	if self.hasScriptBeenRunAtAll(method.name, _controller) then
		return;
	endif;
	
	app.writeLog(method.qualifiedName &amp; "Repairing Import Confirmed List Report Object", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry("Repairing Import Confirmed List Report Object") ;	
	endif;

	
	create menuAgent transient;
		
	report 	 := currentSchema.getConstant('CM_RepImportConfirmList');
	menuRoot := app.myRoot.myReportMenuRoot;
	
	//Find the qryReport
	theMenuId := '_rpt' &amp; report.valueAsInteger.String;
	qryReport := menuRoot.allMenuItems[MenuType_DetailSystem, theMenuId].CM_QryReportSystem;
		
	beginTransaction;
	//Clear the jrwReportName collection or else the setFromXML method wont touch it
	qryReport.jrwReportName.clear();
	
	menuAgent.loadJMTMenuReportDetails(report, menuRoot);
	commitTransaction;
  
    write CM_RepImportConfirmList;
	
	
	app.writeLog(method.qualifiedName &amp; "Repairing Import Confirmed List Report Object Completed", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry("Repairing Import Confirmed List Report Object Completed") ;
	endif;
	
	self.addScriptRun(method.name);
	
	
epilog
 	delete menuAgent;

end;</source>
        <Parameter name="_controller" type="CnEcReleaseController"/>
    </JadeMethod>
    <JadeMethod name="fixInvoiceAllocations" id="133c709d-e0a0-4d17-a0f3-1b3ad4ca0cd5">
        <source>fixInvoiceAllocations(_controller: CnEcReleaseController);
/*

Purpose:			Fix the Invoice Allocations and rebuild the manual dictionaries of them
					
Parameters:			Release Controller

Return Value:		None

Date		Who		Reason
31 May 2017	cnwkpd1	TFS 4542 - Invoice performance issues

*/

vars
	tranMap			: CM_TranMapCargoAllocation;

begin
	if self.hasScriptBeenRunAtAll(method.name, _controller) then
		return;
	endif;
	
	app.writeLog(method.qualifiedName &amp; " Rebuilding Invoice Allocations", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry(" Rebuilding Invoice Allocations") ;	
	endif;
	
	beginTransaction;
	foreach tranMap in CM_TranMapCargoAllocation.instances do
		tranMap.recalcAllocationPriorities();
	endforeach;
	commitTransaction;
	
	app.writeLog(method.qualifiedName &amp; " Rebuilding Invoice Allocations complete", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry(" Rebuilding Invoice Allocations complete") ;	
	endif;
	
	self.addScriptRun(method.name);

epilog

end;</source>
