    <JadeMethod name="createInvoiceLineAndRate" id="b408a3d0-9835-4467-9075-6d1934d1a72b">
        <source>createInvoiceLineAndRate(_invType : CM_InvoiceDesc; _serviceNarr : String; _invLineNarr : String; _calcTypeCode : String;
										_debtorTypeCode : String; _rateValue : Decimal);
/*

Purpose:			TFS 41427

Parameters:			

Return Value:		

Date		Who		Reason
16 October 2018	NAVAB1	Initial creation

*/

vars

	invLineType1 : CM_InvoiceLineDesc;
	debtorType : CM_DebtorType;
	debtorName : String;
	debtor : CM_DebtorNode;
	service : CM_Service;
	ild : CM_InvoiceLineDesc;
begin
	foreach ild in CM_InvoiceLineDesc.instances do
		if ild.narration = _invLineNarr then	
			beginTransaction;
			ild.erase(FORCED_ERASE);
			commitTransaction;
	endif;
	endforeach;
	
	self.deleteService(_serviceNarr);
	
	// SERVICE AND INVOICE LINE TYPE
	self.addIfNewServiceILD(_serviceNarr, _calcTypeCode, _invLineNarr, null, _invType);

	// SET DEBTOR TYPE
	invLineType1 := self.myBank.invoiceLineDescriptors[_invLineNarr];
	debtorType := app.myRoot.allDebtorTypes[_debtorTypeCode];	
	beginTransaction;
	invLineType1.setPropertyValue("myDebtorType", debtorType);
	commitTransaction;
	
	// DEBTOR RATE FOR SERVICE
	debtorName := "RDG";
	debtor := app.myRoot.myRootCompany.debtorNodes[debtorName];
	service := self.myBank.services[_serviceNarr];	
	self.updateDefaultServiceRate(service, debtor, "01/01/2013".Date, _rateValue);	

epilog

end;</source>
        <Parameter name="_invType" type="CM_InvoiceDesc"/>
        <Parameter name="_serviceNarr" type="String"/>
        <Parameter name="_invLineNarr" type="String"/>
        <Parameter name="_calcTypeCode" type="String"/>
        <Parameter name="_debtorTypeCode" type="String"/>
        <Parameter name="_rateValue" type="Decimal"/>
    </JadeMethod>
