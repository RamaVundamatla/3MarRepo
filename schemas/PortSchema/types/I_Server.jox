    <JadeMethod name="messageObject" id="9bb9cd46-f724-4a99-8b3e-707066571cac">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <source>messageObject(set_:Boolean; value_:IDispatch io) updating, mapping;
	// Returns a reference to an Active Messaging Message object.

vars
	v : IDispatch;

begin
	if not set_ then
		_jadeActiveXProperty('MessageObject', '', set_, v);
		if v = null then
			value_ := null;
		else
			value_ := v.IDispatch._morph(IDispatch).IDispatch;
		endif;
	else
		_jadeActiveXProperty('MessageObject', '', set_, value_);
	endif;
end;
</source>
        <Parameter name="set_" type="Boolean"/>
        <Parameter name="value_" type="IDispatch" usage="io"/>
    </JadeMethod>
