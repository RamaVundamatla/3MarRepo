    <JadeMethod name="addCargoChildToTable" id="c81c99a2-1f91-48ee-b359-c14c96f1c0e7">
        <updating/>
        <source>addCargoChildToTable(tbl : CM_MobTable io; item : CM_TrackedItem; count : Integer input) updating;
// ---------------------------------------------------------------------------
// Created:     by cnwaer1
//
// Purpose:     
// ---------------------------------------------------------------------------
constants
	TableEntryPos = 2;
vars

begin
	if item &lt;&gt; null then
		tbl.addItemAt(getCargoDisplay(item,count), TableEntryPos);
		tbl.accessRow(TableEntryPos).itemObject := item;
	endif;
end;</source>
        <Parameter name="tbl" type="CM_MobTable" usage="io"/>
        <Parameter name="item" type="CM_TrackedItem"/>
        <Parameter name="count" type="Integer" usage="input"/>
    </JadeMethod>
    <JadeMethod name="addReserveToTable" id="5783be86-b7a1-40e9-9cba-0dbc9d005fe9">
        <updating/>
        <source>addReserveToTable(_tbl : CM_MobTable io; _reserve : CM_ReserveDetail; currentRow : Integer io) updating;
// ---------------------------------------------------------------------------
// Created:     16 April 2008 by cnwaer1
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	row, 
	col,colour	: Integer;
	cell 		: JadeTableCell;
begin
	if _reserve &lt;&gt; null then
		currentRow := currentRow + 1;
		_tbl.addItemAt(getReserveDisplay(_reserve), currentRow);
		_tbl.accessRow(currentRow).itemObject := _reserve;
		
		colour := self.getColorForRequestLine(_reserve);
		_tbl.accessRow(currentRow).backColor := colour;
		_tbl.accessRow(currentRow).foreColor := colour.getInverseColour;
	endif;
end;</source>
        <Parameter name="_tbl" type="CM_MobTable" usage="io"/>
        <Parameter name="_reserve" type="CM_ReserveDetail"/>
        <Parameter name="currentRow" type="Integer" usage="io"/>
    </JadeMethod>
