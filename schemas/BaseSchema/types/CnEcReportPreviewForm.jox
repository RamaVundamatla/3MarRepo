<GUIClass name="CnEcReportPreviewForm" id="0f3ec8e6-817c-43a2-99ca-a41946f557d7">
    <superclass name="CnEcReportPreviewSuper"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>___________________________________________________________________________

              P R O P R I E T A R Y   N O T I C E

