    <JadeMethod name="mnuColumnOrg_click" id="43d0acae-988c-4776-a325-537ca9d5f471">
        <controlMethod name="MenuItem::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mnuColumnOrg_click(menuItem: MenuItem input) updating;
//-----------------------------------------------------------------------
//
//  Created by: cnwsh3
//
//	Date: 18 September 2003
