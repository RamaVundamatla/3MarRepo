    <JadeMethod name="getDebtor" id="4894b7e3-efa5-4d1f-aac3-93bc9b366e85">
        <source>getDebtor(): CM_Debtor;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 August 2017	jlgndl1	Initial creation	TFS 5646

*/

vars

	op : CM_Operator;
	dr : CM_Debtor;

begin

	if self.myTrackedItem &lt;&gt; null then
		op := self.myTrackedItem.myOperator;
		if op &lt;&gt; null then
			dr := op.debtor;
			if dr &lt;&gt; null then
				return dr;
			endif;
		endif;
	endif;
	
	return inheritMethod();

epilog

end;</source>
        <ReturnType type="CM_Debtor"/>
    </JadeMethod>
    <JadeMethod name="getDescription" id="acd7517b-1e1b-4b30-b8ab-f4a6d4e3f411">
        <source>getDescription(): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 August 2009	cnwndl1	Initial creation	CCMS 1609 Par 20521

*/

vars

	retString : String;	
	discrepancyText : String;
	
begin

	retString := self.getId &amp; " - ";
	
	discrepancyText := self.getDiscrepancyText;
	if discrepancyText &lt;&gt; null then
		retString := retString &amp; app.getErrorString(Discrepancies) &amp; ":" &amp; discrepancyText;
	else
		retString := retString &amp; app.getErrorString(No_Remaining_discrepancies);
	endif;
	retString := "[" &amp; self.getClosedPendingString &amp; "] " &amp; retString;

	return retString; 


epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDiscrepancyText" id="073df1d0-1f3f-4ce2-a41a-ca816446988a">
        <source>getDiscrepancyText():String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
07 September 2009	cnwndl1	Initial creation	CCMS 1609 Par 20521

*/

vars

	retString : String;	
	bookingRefDiscrepFieldValue : CM_BookingRefDiscrepFieldValue;
	foundOne : Boolean;
	
begin

	foreach bookingRefDiscrepFieldValue in self.allBookingRefDiscrepFieldVs do
		if bookingRefDiscrepFieldValue.isDiscrepancy then
			if foundOne then 
				retString := retString &amp; ", ";
			endif;
			retString := retString &amp; bookingRefDiscrepFieldValue.fieldName &amp; " (" &amp; bookingRefDiscrepFieldValue.bookingRefFieldValue &amp; "," &amp; bookingRefDiscrepFieldValue.tiFieldValue &amp; ")";
			foundOne := true;
		endif;
	endforeach;

	return retString; 


epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="78ce3d61-bea7-4494-be7c-c8f272fde2c8">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26/08/2009	cnwndl1	Initial creation	CCMS 1609 Par 20521
27/10/2011	cnwdap1	PAR #28524 CCMS POL 2096 Add "Closed" 
//19 Apr 2016	cnwns1	TFS 488 - Multi Timezone Support
14 Oct 2022 navrk21 ChangeRequest 55087: PNL - Booking Discrepancies - Can 'CA Curtains and Curtains' be renamed?
*/
vars

begin

	if _attrName = ETRow_OperatorTi
	or _attrName = ETRow_VoyageTi
	or _attrName = ETRow_DischargeTi
	or _attrName = ETRow_DestTi
	or _attrName = ETRow_ConsigneeTi
	or _attrName = ETRow_ConsignorTi
	or _attrName = ETRow_IsStockTi
	or _attrName = ETRow_CargoTypeTi
	or _attrName = ETRow_IsoTypeTi
	or _attrName = ETRow_IsoGroupTi		// 19/02/2014 cnwar2 #33139
	or _attrName = ETRow_CommodityTi
	or _attrName = ETRow_TempTi
	or _attrName = ETRow_HumidityTi
	or _attrName = ETRow_VentilationTi
	or _attrName = ETRow_CurtainsTi
	or _attrName = ETRow_HazardTi
	or _attrName = ETRow_OperatorBref
	or _attrName = ETRow_VoyageBref
	or _attrName = ETRow_DischargeBref
	or _attrName = ETRow_DestBref
	or _attrName = ETRow_ConsigneeBref
	or _attrName = ETRow_ConsignorBref
	or _attrName = ETRow_IsStockBref
	or _attrName = ETRow_CargoTypeBref
	or _attrName = ETRow_IsoTypeBref
	or _attrName = ETRow_IsoGroupBref	// 19/02/2014 cnwar2 #33139
	or _attrName = ETRow_CommodityBref
	or _attrName = ETRow_TempBref
	or _attrName = ETRow_HumidityBref
	or _attrName = ETRow_VentilationBref
	or _attrName = ETRow_CurtainsBref
	or _attrName = ETRow_HazardBref
	or _attrName = ETRow_CO2Bref		// 14.10.22 navrk21 TFS 55087
	or _attrName = ETRow_CO2Ti			// 14.10.22 navrk21 TFS 55087
	or _attrName = ETRow_O2Bref			// 14.10.22 navrk21 TFS 55087
	or _attrName = ETRow_O2Ti			// 14.10.22 navrk21 TFS 55087
	then
		return self.getDisplayStringFromFieldValue(_attrName, _short);

	elseif _attrName = ETRow_Prenotified then
		if self.myBookingRef &lt;&gt; null then
			return self.systemToLocalTime(self.myBookingRef.createdTime).asStringJMT;
		else
			return null;
		endif;
		
	elseif _attrName = ETRow_Received then
		if self.myTrackedItem &lt;&gt; null then
			return self.systemToLocalTime(self.myTrackedItem.receivedDT).asStringJMT;
		else
			return null;
		endif;
		
	elseif _attrName = ETRow_Discrepancy then
		return self.getDiscrepancyText;
		
	elseif _attrName = ETRow_BookingRef or _attrName = ETRow_BookingReference or _attrName = ETRow_Booking then		//+cnwml2 PAR20869
		if self.bookingRefId &lt;&gt; null then
			return self.bookingRefId;
		elseif self.myBookingRef &lt;&gt; null then
			return self.myBookingRef.bookingReference;
		elseif self.myTrackedItem &lt;&gt; null then
			return self.myTrackedItem.getDisplayStringForAttribute(ETRow_BookingRef,_short);
		else
			return null;
		endif;
		
	elseif ( _attrName = ETRow_CargoId 
	or _attrName = ETRow_CargoType
	or _attrName = ETRow_Commodity
	or _attrName = ETRow_Consignee
	or _attrName = ETRow_Consignor
	or _attrName = ETRow_Destination
	or _attrName = ETRow_DischargePort
	or _attrName = ETRow_Hazardous
	or _attrName = ETRow_Humidity
	or _attrName = ETRow_Ventilation
	or _attrName = ETRow_Voyage
	) then
		if self.myTrackedItem &lt;&gt; null then
			return self.myTrackedItem.getDisplayStringForAttribute(_attrName,_short);
		else
			return null;
		endif;
	
	elseif _attrName = ETRow_CarriageTemperature then
		if self.myTrackedItem &lt;&gt; null then
			return self.myTrackedItem.getDisplayStringForAttribute(ETRow_Temperature,_short);
		else
			return null;
		endif;
	
	elseif _attrName = ETRow_ContAtmosAndCurtainsIn then
		if self.myTrackedItem &lt;&gt; null then
			return self.myTrackedItem.getDisplayStringForAttribute(ETRow_CurtainsIn,_short);
		else
			return null;
		endif;
	
	elseif _attrName = ETRow_DateFrom then
		return null;
	
	elseif _attrName = ETRow_DateTo then
		return null;
	
	elseif _attrName = ETRow_ISOType then
		if self.myTrackedItem &lt;&gt; null then
			return self.myTrackedItem.getDisplayStringForAttribute(ETRow_IsoType,_short);
		else
			return null;
		endif;
	
	elseif _attrName = ETRow_IsStock or _attrName = ETRow_IsStockBookingReference then
		if self.myBookingRef &lt;&gt; null then
			return self.myBookingRef.getDisplayStringForAttribute(ETRow_IsStockBookingRef,_short);
		else
			return false.getYesNo;
		endif;
	
	elseif _attrName = ETRow_Operator then
		if self.myTrackedItem &lt;&gt; null then
			return self.myTrackedItem.getDisplayStringForAttribute(ETRow_OperatorCode,_short);
		else
			return null;
		endif;
	elseif _attrName = ETRow_ErrorCode then
		return self.getClosedPendingString;
	elseif _attrName = ETRow_Status then
		return self.getStateString;
	
	elseif _attrName = ETRow_ErrorText then
		return self.getDescription;
	elseif _attrName = ETRow_ErrorField then
		return null;
	elseif _attrName = ETRow_Entity then
		if self.myTrackedItem &lt;&gt; null then
			return self.myTrackedItem.getName;
		elseif CM_BookingRef.hasInstance(self.myBookingRef) then
			return self.myBookingRef.getName;
		else
			return self.bookingRefId;
		endif;
	elseif _attrName = ETRow_Closed then		// PAR #28524
		return self.isClosed.getYes;			// PAR #28524
	else
	
		return inheritMethod(_attrName, _short);
	
	endif;

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringFromFieldValue" id="f9442286-4792-4ec6-b4ec-2335a003b7ec">
        <source>getDisplayStringFromFieldValue( _attrName: String; _short: Boolean ):String protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 Sep 2009	cnwndl1	Initial creation	CCMS 1609 Par 20521
03 Feb 2022	jlika1	TFS 52486 PNL-Booking Discrepancy - Ventiliation Showing Incorrectly
14 Oct 2022 navrk21 ChangeRequest 55087: PNL - Booking Discrepancies - Can 'CA Curtains and Curtains' be renamed?
*/

vars

	entTableDef : EntTableDef;
	rowName : String;
	entTableRow : EntTableRow;
	fieldName : String;
	retValue : String;
	bookingRefDiscrepFieldValue : CM_BookingRefDiscrepFieldValue;
	
begin

	// get the entable used for the field names.
	entTableDef := app.myRoot.myEntTableDataRoot.allEntTableDefs[ETDef_BookingRefDiscrep];
	
	//find the name of the stored field name relative to the column name we are dealing with
	if _attrName = ETRow_OperatorTi or _attrName = ETRow_OperatorBref then
		rowName := ETRow_Operator;
		
	elseif _attrName = ETRow_VoyageTi or _attrName = ETRow_VoyageBref then
		rowName := ETRow_Voyage;
		
	elseif _attrName = ETRow_DischargeTi or _attrName = ETRow_DischargeBref then
		rowName := ETRow_DischargePort;
		
	elseif _attrName = ETRow_DestTi or _attrName = ETRow_DestBref then
		rowName := ETRow_Destination;
		
	elseif _attrName = ETRow_ConsigneeTi or _attrName = ETRow_ConsigneeBref then
		rowName := ETRow_Consignee;
		
	elseif _attrName = ETRow_ConsignorTi or _attrName = ETRow_ConsignorBref then
		rowName := ETRow_Consignor;
		
	elseif _attrName = ETRow_IsStockTi or _attrName = ETRow_IsStockBref then
		rowName := ETRow_IsStockBookingReference;
		
	elseif _attrName = ETRow_CargoTypeTi or _attrName = ETRow_CargoTypeBref then
		rowName := ETRow_CargoType;
		
	elseif _attrName = ETRow_IsoTypeTi or _attrName = ETRow_IsoTypeBref then
		rowName := ETRow_ISOType;
		
	// 19/02/2014 cnwar2 #33139
	elseif _attrName = ETRow_IsoGroupTi or _attrName = ETRow_IsoGroupBref then
		rowName := ETRow_ISOGroup;
		
	elseif _attrName = ETRow_CommodityTi or _attrName = ETRow_CommodityBref then
		rowName := ETRow_Commodity;
		
	elseif _attrName = ETRow_TempTi or _attrName = ETRow_TempBref then
		rowName := ETRow_CarriageTemperature;
		
	elseif _attrName = ETRow_HumidityTi or _attrName = ETRow_HumidityBref then
		rowName := ETRow_Humidity;
		
	elseif _attrName = ETRow_VentilationTi or _attrName = ETRow_VentilationBref then
		rowName := ETRow_Ventilation;
		
	elseif _attrName = ETRow_CurtainsTi or _attrName = ETRow_CurtainsBref then
		rowName := ETRow_ContAtmosAndCurtainsIn;
		
	elseif _attrName = ETRow_HazardTi or _attrName = ETRow_HazardBref then
		rowName := ETRow_Hazardous;
	// Start 14.10.2022 navrk21 TFS 55087
	elseif _attrName = ETRow_CO2Ti or _attrName = ETRow_CO2Bref then
		rowName := ETRow_CO2;
		
	elseif _attrName = ETRow_O2Ti or _attrName = ETRow_O2Bref then
		rowName := ETRow_O2;
	// End 14.10.2022 navrk21 TFS 55087
	endif;

	//if we have identified the matching entable row used to hold the field name, get the stored name.
	if rowName = null then
		return null;
	else
		entTableRow := entTableDef.getEntTableRow(rowName);
	endif;
	
	if entTableRow = null then
		return null;
	else
		fieldName := entTableRow.getHeading(null,null,app.myCurrentLocale);
		//identify the attribute and its stored discrepancies.
		if fieldName &lt;&gt; null then
			bookingRefDiscrepFieldValue := self.getBookingRefDiscrepFieldValue(fieldName);
			if bookingRefDiscrepFieldValue = null then
				// we didn't find it
				return null;
			endif;
		endif;
	endif;

	if _attrName = ETRow_OperatorTi
	or _attrName = ETRow_VoyageTi
	or _attrName = ETRow_DischargeTi
	or _attrName = ETRow_DestTi
	or _attrName = ETRow_ConsigneeTi
	or _attrName = ETRow_ConsignorTi
	or _attrName = ETRow_IsStockTi
	or _attrName = ETRow_CargoTypeTi
	or _attrName = ETRow_IsoTypeTi
	or _attrName = ETRow_IsoGroupTi		// 20/02/2014 cnwar2 #33139
	or _attrName = ETRow_CommodityTi
	or _attrName = ETRow_TempTi
	or _attrName = ETRow_HumidityTi	
	or _attrName = ETRow_CurtainsTi
	or _attrName = ETRow_HazardTi
	or _attrName = ETRow_CO2Ti		//14.10.2022 navrk21 TFS 55087
	or _attrName = ETRow_O2Ti		//14.10.2022 navrk21 TFS 55087
	then	// its the ti value we want
		return bookingRefDiscrepFieldValue.tiFieldValue; 
	elseif _attrName = ETRow_VentilationTi then				
		if bookingRefDiscrepFieldValue.tiFieldValue.Integer = NULL_VENTILATION then
			return null;
		endif;
		
		return bookingRefDiscrepFieldValue.tiFieldValue; 		
	elseif _attrName = ETRow_OperatorBref
	or _attrName = ETRow_VoyageBref
	or _attrName = ETRow_DischargeBref
	or _attrName = ETRow_DestBref
	or _attrName = ETRow_ConsigneeBref
	or _attrName = ETRow_ConsignorBref
	or _attrName = ETRow_IsStockBref
	or _attrName = ETRow_CargoTypeBref
	or _attrName = ETRow_IsoTypeBref
	or _attrName = ETRow_IsoGroupBref	// 20/02/2014 cnwar2 #33139
	or _attrName = ETRow_CommodityBref
	or _attrName = ETRow_TempBref
	or _attrName = ETRow_HumidityBref
	or _attrName = ETRow_VentilationBref
	or _attrName = ETRow_CurtainsBref
	or _attrName = ETRow_HazardBref
	or _attrName = ETRow_CO2Bref		//14.10.2022 navrk21 TFS 55087
	or _attrName = ETRow_O2Bref			//14.10.2022 navrk21 TFS 55087
	then	// its the booking ref value we want.
		return bookingRefDiscrepFieldValue.bookingRefFieldValue; 
	endif; 
	
	return null;
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getId" id="3a2b9d08-fc7a-4b0a-9a3b-37caf8b9f845">
        <source>getId():String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 September 2009	cnwndl1	Initial creation	CCMS 1609 Par 20521

*/

vars
	retString : String;
begin

	retString := app.getErrorString(CargoId) &amp; ": " &amp; myTrackedItem.id &amp; "   " &amp; 
					app.getErrorString(Booking_reference) &amp; ": " &amp; self.bookingRefId;

	return retString;

epilog

end;</source>
