epilog

end;</source>
        <ReturnType type="CM_VoyageGlobal"/>
    </JadeMethod>
    <JadeMethod name="getOIDAndDescForAttribute" id="d2b02d1f-b3f1-4cbb-b983-67668b841c08">
        <source>getOIDAndDescForAttribute(_attrName: String; _getCalculatedDate : Boolean; _oid : String output): String;
// ---------------------------------------------------------------------------
// Created:     19/07/2010 cnwdz2	
//
// Purpose:     PAR24513 extend the current existing getDisplayStringForAttribute method to return an object's oid.		 
// ----------   ----------  --------------------------------------------------
vars

begin
	if _attrName = ETRow_VoyageAllocated then //18/05/2009 cnwdz2 par19257 changed ETRow_Voyage to ETRow_VoyageAllocated
		if self.getMyVoyageGlobalAllocated &lt;&gt; null then
			_oid := self.getMyVoyageGlobalAllocated.getOidAsString(); //20/07/2010 cnwdz2 24513
			return self.getMyVoyageGlobalAllocated.code;
		else
			return Any_String;
		endif;
	elseif _attrName = ETRow_VoyageActual then
		if self.getMyVoyageGlobal &lt;&gt; null then
			_oid := self.getMyVoyageGlobal.getOidAsString(); //20/07/2010 cnwdz2 24513
			return self.getMyVoyageGlobal.code;
		else
			return Any_String;
		endif;
	
	endif;
	
	return inheritMethod(_attrName, _getCalculatedDate, _oid);


end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_getCalculatedDate" type="Boolean"/>
        <Parameter name="_oid" type="String" usage="output"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setFromTemplate" id="7f17ce5b-cc76-4065-a5fd-1d443b252d76">
        <updating/>
        <source>setFromTemplate(_obj: CMQF_FilterReports; _runDate: Date; _allEventData: CM_EventDataByTypeDict) updating;
/*

Date		Who		Reason
10 September 2014	cnwer1	Initial creation PAR 34813

*/

vars
	eventData : CM_EventDataVoyage;
begin
	inheritMethod(_obj, _runDate, _allEventData);
	
	//epr par 34813 10/9/14 
	eventData := _allEventData[EventDataVoyage].CM_EventDataVoyage;
	if eventData &lt;&gt; null and eventData.myVoyage &lt;&gt; null then
		self.setMyVoyageGlobal( eventData.myVoyage.myVoyageGlobalArrival );
	endif;
epilog

end;</source>
        <Parameter name="_obj" type="CMQF_FilterReports"/>
        <Parameter name="_runDate" type="Date"/>
        <Parameter name="_allEventData" type="CM_EventDataByTypeDict"/>
    </JadeMethod>
    <JadeMethod name="setMyVoyageGlobal" id="a71a39dd-c0e1-4445-9e1d-5c96c1e58c88">
        <updating/>
        <source>setMyVoyageGlobal( _object : CM_VoyageGlobal ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 July 2016	cnwndl1	Initial creation	TFS 2329

*/

vars

begin

	self.myVoyageGlobal := _object;

epilog

end;</source>
        <Parameter name="_object" type="CM_VoyageGlobal"/>
    </JadeMethod>
