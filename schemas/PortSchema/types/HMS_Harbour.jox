    <JadeMethod name="setForUpdate" id="be18d94e-8559-4043-8375-2461c9d50a0e">
        <updating/>
        <source>setForUpdate(_pxyHarbour : HMS_Harbour; _passport : CM_Passport input) updating;
//--------------------------------------------------------------
//Created: 04 July 2003 By: cnwgd1
//--------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	---------------------------------------------------------
// 27/01/2014	cnwdap1		PAR #33337 CCMS PTR 2214 HMS Enhancements
	// 21/05/2014	cnwdap1		PAR #34176 Work Order Report dates option
// 04/09/2024	navhn30		Bug 61636: NSW | Tech Debt - POB QShips Port Authority Config	
vars

begin
	inheritMethod(_pxyHarbour, _passport);

	self.code 			:= _pxyHarbour.code.toUpper.trimBlanks;
	self.description 	:= _pxyHarbour.description;
	self.myRoot			:= _pxyHarbour.myRoot;
	
	self.allTerminalsByCode.clear();
	_pxyHarbour.allTerminalsByCode.copy(self.allTerminalsByCode);
	
	self.activateSystemSound 	:= _pxyHarbour.activateSystemSound;
	self.baseTimeArrive 		:= _pxyHarbour.baseTimeArrive;
	self.baseTimeDepart 		:= _pxyHarbour.baseTimeDepart;
	self.baseTimeShift 			:= _pxyHarbour.baseTimeShift;
	self.chartDatum 			:= _pxyHarbour.chartDatum;
	self.defaultArrvBerth 		:= _pxyHarbour.defaultArrvBerth;
	self.defaultDepartBerth 	:= _pxyHarbour.defaultDepartBerth;
	self.defFileNameShipRpt 	:= _pxyHarbour.defFileNameShipRpt;
		
	self.defaultOrderTimesArrive.clear();
	_pxyHarbour.defaultOrderTimesArrive.copy(self.defaultOrderTimesArrive);
	self.defaultOrderTimesDepart.clear();
	_pxyHarbour.defaultOrderTimesDepart.copy(self.defaultOrderTimesDepart);
	self.defaultOrderTimesShift.clear();
	_pxyHarbour.defaultOrderTimesShift.copy(self.defaultOrderTimesShift);

	self.eMailSendAccount 			:= _pxyHarbour.eMailSendAccount;
	self.eMailServer 				:= _pxyHarbour.eMailServer;
	self.minimumClearance 			:= _pxyHarbour.minimumClearance;
	self.numHoursOutForWarnings		:= _pxyHarbour.numHoursOutForWarnings;
	self.ofBunkersGroup 			:= _pxyHarbour.ofBunkersGroup;
	self.ofPhoneGroup 				:= _pxyHarbour.ofPhoneGroup;
	self.pathResourceIconDown 		:= _pxyHarbour.pathResourceIconDown;
	self.pathResourceIconUp 		:= _pxyHarbour.pathResourceIconUp;
	self.pathResourceLocationIcon 	:= _pxyHarbour.pathResourceLocationIcon;
	self.pathShippingReportFile 	:= _pxyHarbour.pathShippingReportFile;
	self.plannedNoteColour			:= _pxyHarbour.plannedNoteColour;
	self.shippingReportOffsetDays 	:= _pxyHarbour.shippingReportOffsetDays;
	self.midnightLineColour 		:= _pxyHarbour.midnightLineColour;
	self.movConfirmFromPlanInHrs 	:= _pxyHarbour.movConfirmFromPlanInHrs;
	self.movConfirmSearchBackDays 	:= _pxyHarbour.movConfirmSearchBackDays;
	self.stdSteamingTimeMins 		:= _pxyHarbour.stdSteamingTimeMins;
	//self.tidalModelType				:= _pxyHarbour.tidalModelType;
	self.tidalTimeTypeArrival 		:= _pxyHarbour.tidalTimeTypeArrival;
	self.tidalTimeTypeDeparture 	:= _pxyHarbour.tidalTimeTypeDeparture;
	self.tidalTimeTypeShift 		:= _pxyHarbour.tidalTimeTypeShift;
	self.timeNowLineColour 			:= _pxyHarbour.timeNowLineColour;
	self.timePositonLabelColour 	:= _pxyHarbour.timePositonLabelColour;
	
	// 28/6/2006 Lorcan New attributes
	self.exemptMasterExpiryPeriod 	:= _pxyHarbour.exemptMasterExpiryPeriod;
	self.exemptMasterMovementReq 	:= _pxyHarbour.exemptMasterMovementReq;
	self.exemptMasterRequiredGTR 	:= _pxyHarbour.exemptMasterRequiredGTR;
	
	self.isDoClearanceCheck			:=	_pxyHarbour.isDoClearanceCheck;
	self.isSplitVesselNames			:=	_pxyHarbour.isSplitVesselNames;
	self.isTidalClassValidated		:=	_pxyHarbour.isTidalClassValidated;
	self.showRelativeTimesOnTidal	:=	_pxyHarbour.showRelativeTimesOnTidal;	//Par17906 Feb 2009
	
	self.allWharfDisplayOrderArray.clear();
	_pxyHarbour.allWharfDisplayOrderArray.copy(self.allWharfDisplayOrderArray);
	
	self.myDefaultTerminal	:= _pxyHarbour.myDefaultTerminal;	
	self.myEmailGroup 		:= _pxyHarbour.myEmailGroup;
	self.timezone 		:= _pxyHarbour.timezone;	// 29 Mar 2012	NDL	Par 28251
	
	self.maximumDraft				:= _pxyHarbour.maximumDraft;					// PAR #33337
	self.suppressTidalWarnings		:= _pxyHarbour.suppressTidalWarnings;			// PAR #33337
			
	self.woDateTimeSameAsView		:= _pxyHarbour.woDateTimeSameAsView;			// PAR #34176
	self.ignoreBerthLOAErrors		:= _pxyHarbour.ignoreBerthLOAErrors;			// 04.09.24	 navhn30  TFS 61636
			
end;</source>
        <Parameter name="_pxyHarbour" type="HMS_Harbour"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
