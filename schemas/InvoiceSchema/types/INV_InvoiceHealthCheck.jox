    <JadeMethod name="create" id="3a2c9d24-ec74-43eb-9c9c-0bc9b7a10c8a">
        <updating/>
        <executionLocation>client</executionLocation>
        <source>create() updating, clientExecution;
// ---------------------------------------------------------------------------
// Created:		May 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	if not shouldIShow then
		return;
	endif;
	self.permissionView  := PmAdmInvoiceSDSysDefaultsView;
	self.permissionMaint := PmAdmFinancialsystemdefauMaint;
	
	self.helpFileName := HelpFile_Invoicing;

end;</source>
    </JadeMethod>
    <JadeMethod name="doMnuInspectObject" id="eb9eaf60-cd91-42a4-844c-c080ba15c96a">
        <source>doMnuInspectObject();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 November 2017	jlgab1	Initial creation

*/

vars
	anObject : Object;
begin
	if self.tblData.row &gt; self.tblData.fixedRows then
		anObject := self.tblData.accessRow(self.tblData.row).itemObject;
		if anObject &lt;&gt; null then
			anObject.CMIF_InvoiceHealthAgentDetail.mySubject.inspect;
		endif;
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="doQuery" id="70aa70c6-3ad1-481e-aa64-6f3612e69bbe">
        <updating/>
        <source>doQuery() updating;
/*
Purpose:			
Date		Who		Reason
14 September 2016	cnwab1	Initial creation
*/

vars
	agent : CMIF_InvoiceHealthAgent;
	detail : CMIF_InvoiceHealthAgentDetail;
	theDataLine : String;
	idx : Integer;
begin
	self.tblData.rows := self.tblData.fixedRows;
	
	delete self.myAgent;
	create agent transient;
	self.myAgent := agent;
	
	self.initHealthAgent(agent);
		
	agent.doHealthCheck();
	
	
	
	if not agent.itemTypesToQuery.isEmpty() // TFS 2682 - 17JAN18
	and not agent.checkTypesToQuery.isEmpty() then // TFS 2682 - 17JAN18

		if agent.allHealthCheckDetails.isEmpty() then
			app.msgBox("Good Health 100%","Health Check",MsgBox_OK_Only);
			
		endif;
	endif;
	
	foreach detail in agent.allHealthCheckDetails discreteLock do
		theDataLine := detail.getAttributeStringForDefArray(self.tblData.allTblDataEntRows);
	
		idx := self.tblData.addItem(theDataLine);
		self.tblData.accessRow(idx).itemObject := detail;
		self.tblData.accessedRow.backColor := detail.getRowColour();
	
	endforeach;

	
	inheritMethod();

epilog
end;</source>
    </JadeMethod>
    <JadeMethod name="doResize" id="b66daf6c-651f-4ec4-ba74-0418075d43aa">
        <updating/>
