    <JadeMethod name="doUpdateOrNew" id="e4123312-9976-4922-9ad4-617c63ccca6a">
        <updating/>
        <source>doUpdateOrNew() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
24th Jan 2024 	navra1  TFS 62081 - CUX | Auto-setdown of cargo that doesn't require a machine move

*/

vars
	newRoadGateAutoCompleteForm : CMUI_RoadGateAutoCompleteEdit;
begin
	newRoadGateAutoCompleteForm := app.loadForm(CMUI_RoadGateAutoCompleteEdit,
		CMUI_Assistant, false, false, false, self.getMyTerminal, null).CMUI_RoadGateAutoCompleteEdit;	
	if newRoadGateAutoCompleteForm = null then
		return;
	endif;
	newRoadGateAutoCompleteForm.myProxyObject := self.myCurrentCriteria;
	newRoadGateAutoCompleteForm.myParentForm := self;
	newRoadGateAutoCompleteForm.isUpdate := self.isUpdate;
	newRoadGateAutoCompleteForm.setMyTerminal(self.myTerminal);
	newRoadGateAutoCompleteForm.showModal;
	
	self.setNavigatorHeading(self.MenuCaption);

epilog
	//update the view since we are not listening to events
	self.refreshTableView();
	delete self.myCurrentCriteria; // delete the proxy
end;</source>
    </JadeMethod>
