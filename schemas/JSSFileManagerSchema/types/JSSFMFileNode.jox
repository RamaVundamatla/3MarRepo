<Class name="JSSFMFileNode" id="d35334f2-6b3b-468c-be1e-68f1107cb87e">
    <superclass name="JSSFMTransientModel"/>
    <transient/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <abstract/>
    <access>protected</access>
