    <JadeMethod name="setupForm" id="7c34ad82-262e-46d1-aeb1-6078d8fff833">
        <updating/>
        <source>setupForm() updating, protected;
// --------------------------------------------------------------------------------
// Created:		29 June 2006 by cnwdad1
//
// Purpose:		Standard form setup method.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	inheritMethod();
	
	self.setBackgroundImage(picImage.picture);
	btnDone.visible			:=	true;
	btnDone.move(btnDone.left, btnNext.top, btnDone.width, btnDone.height);
	btnNext.visible			:=	false;
	lblCarrier.cnEcSet(self.aMyProxyLoad.myCarrier.code);
	lblRegoNo.cnEcSet(self.aMyProxyLoad.regoNumber);
	lblReceive1.visible	:=	false;
	picReceive1.visible	:=	false;
	lblReceive2.visible	:=	false;
	picReceive2.visible	:=	false;
	lblReceive3.visible	:=	false;
	picReceive3.visible	:=	false;
	lblReceive4.visible	:=	false;
	picReceive4.visible	:=	false;
	lblRelease1.visible	:=	false;
	picRelease1.visible	:=	false;
	lblRelease2.visible	:=	false;
	picRelease2.visible	:=	false;
	lblRelease3.visible	:=	false;
	picRelease3.visible	:=	false;
	lblRelease4.visible	:=	false;
	picRelease4.visible	:=	false;
	txtPinNo.maxLength	:=	CM_PinNo::pinNo.length - 1;
	
	self.doEnableControls();
	self.centreBackground();
	
	self.caption := "KIOSK - PIN Entry";	//10 Sep 2021	NDL	TFS 51934
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="updateForm" id="c4e83769-f2e6-46fc-9981-fba20924b588">
        <updating/>
        <source>updateForm(_isDelete:Boolean): Boolean updating, protected;
// --------------------------------------------------------------------------------
// Created:		16 August 2006 by cnwdad1
//
// Purpose:		Refer to supeclass implementation.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	proxyLoadObj	: GTE_KioskProxyLoad;
	proxyCargoObj	: GTE_KioskProxyCargo;
	allErrorsObj	: CnEcArray;
	errorMsg		: String;
	
begin
	create allErrorsObj transient;
	proxyLoadObj	:=	self.aMyProxyLoad;
	
	if self.createRoadJob(allErrorsObj) then
		return inheritMethod(false);
	else
		app.doRaiseAlertForKiosk("Kiosk error - refer to extra info.", allErrorsObj);
		app.msgBox("Unexpected error - contact the gate office", "Error", MsgBox_Exclamation_Mark_Icon + MsgBox_OK_Only);
		self.doRestart();		// 25/01/2011 cnwmh5 #26803
		return false;
	endif;
epilog
	delete allErrorsObj;
end;</source>
        <access>protected</access>
        <Parameter name="_isDelete" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateBulkRelease" id="f3bd2521-7b44-4d4c-943d-ae1bd9de42b9">
        <source>validateBulkRelease(_releaseObj:CM_BulkRelease; _pinNumber:String):Boolean protected;
// --------------------------------------------------------------------------------
// Created:		02 October 2006 by cnwdad1
//
// Purpose:		Validates whether a Bulk Release is valid.  A Bulk Release can have
//				one or more Tracked Items.  It has the total number of items that
//				were requested, and it has two collections of Items that are either
//				released or are being actioned.
//
// Parameters:	_releaseObj - A reference to the Bulk Release object to validate.
//				_pinNumber - The pin number used to identify the Bulk Release.
//
// Returns:		True if the Bulk Release is valid, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars

	itemsRemaining	: Integer;
	itemsFound		: Integer;
	usedPin			: String;
	errorMsg		: String;
	
begin

	if self.isAAAI then	//20 May 2020	NDL	TFS 49167
		itemsRemaining := _releaseObj.allTrackedItemsAssigned.size;
	else
		itemsRemaining	:=	_releaseObj.getTotalOutstanding;
	endif;
	
	if itemsRemaining = 0 then
		errorMsg	:=	"There are no outstanding items for the requested release.";
		return false;
	endif;
	
	foreach usedPin in self.aAllPinNumbers do
		if usedPin = _pinNumber then
			itemsFound	:=	itemsFound + 1;
		endif;
	endforeach;
	
	if itemsFound &gt;= itemsRemaining then
		errorMsg	:=	"There are no more outstanding items for the requested release.";
		return false;
	endif;
	
	return true;
epilog
	if errorMsg &lt;&gt; null then
		app.msgBox(errorMsg, app.getErrorString(Error), MsgBox_Exclamation_Mark_Icon + MsgBox_OK_Only);
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_releaseObj" type="CM_BulkRelease"/>
        <Parameter name="_pinNumber" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateForm" id="b4840f38-1ffa-4706-b90d-eda6665dd55b">
        <updating/>
        <source>validateForm(_isDelete: Boolean): Boolean updating, protected;
// --------------------------------------------------------------------------------
// Created:		01 August 2006 by cnwdad1
//
// Purpose:		Refer to superclass implementation.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	pinNoObj	: CM_PinNo;
	pinNumber	: String;
	
begin
	if self.aMyTerminal = null then
		app.raiseUnexpectedProgramError(class.name, method.name, "A Terminal has not been set for this system - contact System Administrator.");
	endif;

	pinNumber	:=	txtPinNo.cnEcString();
	
	if pinNumber = null then
		app.msgBox("Please enter the cargo's Pin Number.", "Error", MsgBox_Exclamation_Mark_Icon + MsgBox_OK_Only);
		return false;
	endif;
	
	pinNoObj	:=	self.aMyTerminal.allPinNos[pinNumber];
	
//	if self.aAllPinNumbers.includes(pinNumber) then
//		app.msgBox("Pin Number '" &amp; pinNumber &amp; "' has already been entered.", $Error, MsgBox_Exclamation_Mark_Icon + MsgBox_OK_Only);
//		return false;
//	endif;
	
	if pinNoObj = null then
		app.msgBox("'" &amp; pinNumber &amp; "' is not a known Pin Number.", app.getErrorString(Error), MsgBox_Exclamation_Mark_Icon + MsgBox_OK_Only);
		return false;
	endif;
	
	return inheritMethod(_isDelete);
end;</source>
        <access>protected</access>
        <Parameter name="_isDelete" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateTrackedItem" id="794fd894-848d-41ec-be56-18c331552f04">
        <source>validateTrackedItem(_trackedItemObj:CM_TrackedItem io; _pinNumber:String):Boolean protected;
// --------------------------------------------------------------------------------
// Created:		04 October 2006 by cnwdad1
//
// Purpose:		Validates whether Tracked Item is valid.
//
// Parameters:	_trackedItemObj - A reference to the Tracked Item object to validate.
//				_pinNumber - The pin number used to identify the Tracked Item.
//
// Returns:		True if the Tracked Item is valid, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//	10/05/2023	navcs2		Bug 57915: PNL - Gate Kiosk - Doesn't stop cargo being pinned through before Earliest Receival
// --------------------------------------------------------------------------------
vars
	pinNoObj		: CM_PinNo;
	pinNumber		: String;
	itemsFound		: Integer;
	usedPin			: String;
	errorMsg		: String;
	terminal		: CM_Terminal;
	cutoffPreNote	: Boolean;//07/03/2025	navkc1 JIRA Story MTN-34225
	tiId			: String; //07/03/2025	navkc1 JIRA Story MTN-34225
	cutoffTS		: TimeStamp; //07/03/2025	navkc1 JIRA Story MTN-34225
	earliestTS		: TimeStamp; //07/03/2025	navkc1 JIRA Story MTN-34225
	theVoy			: CM_Voyage; //07/03/2025	navkc1 JIRA Story MTN-34225
begin
	terminal	:=  self.aMyTerminal;				// 10/05/2023 navcs2 Bug 57915
	
	pinNumber	:=	txtPinNo.cnEcString();
	pinNoObj	:=	terminal.allPinNos[pinNumber];	// 10/05/2023 navcs2 Bug 57915
	
	theVoy := terminal.lookupVoyage(_trackedItemObj.voyageCode, null, false); //07/03/2025	navkc1 JIRA Story MTN-34225
	
//	if self.aAllPinNumbers.includes(pinNumber) then
//		app.msgBox("Pin Number '" &amp; pinNumber &amp; "' has already been entered.", $Error, MsgBox_Exclamation_Mark_Icon + MsgBox_OK_Only);
//		return false;
//	endif;
	
	foreach usedPin in self.aAllPinNumbers do
		if usedPin = _pinNumber then
			itemsFound	:=	itemsFound + 1;
		endif;
	endforeach;
	
	if itemsFound &gt;= pinNoObj.allItems.size() then
		errorMsg	:=	"There are no more outstanding items for the requested pin number.";
		return false;
	endif;
	
	// 24/05/2010 cnwar2 #22015 - if onsite ti, check if truck already in terminal for this item
	if _trackedItemObj.state = TI_STATE_NORMAL then
		if _trackedItemObj.jobRoadRelease &lt;&gt; null then
			errorMsg := app.getErrorString2(Cargo_item_being_released, _trackedItemObj.id, _trackedItemObj.jobRoadRelease.regNumber);
			return false;
		endif;
	endif;
	
	cutoffPreNote := theVoy &lt;&gt; null and theVoy.shipCutoffsForPrenotes; //07/03/2025	navkc1 JIRA Story MTN-34225
	tiId := _trackedItemObj.id; //07/03/2025	navkc1 JIRA Story MTN-34225
	
	// 10/05/2023 navcs2 Bug 57915 Start
	if _trackedItemObj.originallyCreatedAfterCutOff(cutoffTS) then
		if _trackedItemObj.isPreNote() then //07/03/2025	navkc1 JIRA Story MTN-34225
			if cutoffPreNote then
				if terminal.getConfig(ShipCutoffsShowError).Boolean = true then
					errorMsg := app.getErrorString2(Receival_Outside_CutoffPN, tiId, cutoffTS.asStringJMT()); 
					return false;
				endif;
			endif;
		else
			if terminal.getConfig(ShipCutoffsShowError).Boolean = true then
				errorMsg := app.getErrorString1(Receival_Outside_Cutoff, tiId); 
				return false;
			endif;
		endif;
	else
		//25/03/2025	navkc1 JIRA Defect Sub-task MTN-34476 - This is a prenote created way before. Validate the cutoff time
		_trackedItemObj.validateForPrenoteCutoff();
	endif;
	if _trackedItemObj.myVoyage &lt;&gt; null then
		earliestTS := _trackedItemObj.earliestReceivalTS; //07/03/2025	navkc1 JIRA Story MTN-34225
		
		if (earliestTS.isValid()
		and earliestTS &gt; app.actualTimeServer())
		then
			if _trackedItemObj.isPreNote() then //07/03/2025	navkc1 JIRA Story MTN-34225
				if cutoffPreNote then
					if terminal.getConfig(ShipCutoffsShowError).Boolean = true then
						errorMsg := app.getErrorString2(Receival_Outside_EarliestPN, tiId, earliestTS.asStringJMT()); 
						return false;
					endif;
				endif;
			else
				if terminal.getConfig(ShipCutoffsShowError).Boolean = true then 
					errorMsg := app.getErrorString1(Receival_Outside_Earliest, tiId);
					return false;
				endif;
			endif;
		endif;
	endif;
	// 10/05/2023 navcs2 Bug 57915 End
	
	
	// 03/02/2012 cnwar2 #28799
	if _trackedItemObj.carrier &lt;&gt; aMyProxyLoad.myCarrier.code 
	and aMyProxyLoad.isReceivalItem(_trackedItemObj) then		// 06/08/2012 cnwar2 #30121/#30156
	//	errorMsg := app.getErrorString2(ReceivalCarrierMismatch, _trackedItemObj.id, aMyProxyLoad.myCarrier.code);
	//	return false;
		beginTransaction;													// 18/09/2012 cnwmh5 #30233
		_trackedItemObj.setCarrier(aMyProxyLoad.myCarrier.code);
		commitTransaction;
	endif;
	
	return true;
epilog
	if errorMsg &lt;&gt; null then
		app.msgBox(errorMsg, app.getErrorString(Error), MsgBox_Exclamation_Mark_Icon + MsgBox_OK_Only);
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_trackedItemObj" type="CM_TrackedItem" usage="io"/>
        <Parameter name="_pinNumber" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</GUIClass>
