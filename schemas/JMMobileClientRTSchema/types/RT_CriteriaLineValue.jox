    <JadeMethod name="getDtoDefinitionFromRT" id="1b588ded-f7f8-4c6b-9c98-78923c1a36da">
        <source>getDtoDefinitionFromRT(	_queryOperatorOid, _propClassName, _propName : String output;
						_searchValueA, _searchValueB : String output; _searchValueBoolean : Boolean output );
// -----------------------------------------------------------------------------------------------
// Created 07 may 2008 by cnwvu1
// -----------------------------------------------------------------------------------------------

vars

begin

	inheritMethod(_queryOperatorOid, _propClassName, _propName, _searchValueA, _searchValueB, _searchValueBoolean);

	_queryOperatorOid	:= self.queryOperatorOid;
	_propClassName		:= self.propClassName;
	_propName			:= self.propName;

end;
</source>
        <Parameter name="_queryOperatorOid" type="String" usage="output"/>
        <Parameter name="_propClassName" type="String" usage="output"/>
        <Parameter name="_propName" type="String" usage="output"/>
        <Parameter name="_searchValueA" type="String" usage="output"/>
        <Parameter name="_searchValueB" type="String" usage="output"/>
        <Parameter name="_searchValueBoolean" type="Boolean" usage="output"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="c38e3967-8b34-4c47-84f2-407fcf7c53fe">
        <updating/>
        <source>setForCreate( _form : RadioTelemetryMainForm; 
				_propClassName, _propName, _queryOperatorOid : String;
				_lblCriteriaCaption, _searchValueA, _searchValueB : String; 
				_optBtnValue : Boolean;
				_slip : Real; _tabIndex : Integer ) updating;
// -----------------------------------------------------------------------------------------------
// Created 08 may 2008 by cnwvu1
// -----------------------------------------------------------------------------------------------

vars

begin

	inheritMethod(_form, _propClassName, _propName, _queryOperatorOid, _lblCriteriaCaption, _searchValueA, _searchValueB, _optBtnValue, _slip, _tabIndex );

	self.queryOperatorOid	:= _queryOperatorOid;
	self.propClassName		:= _propClassName;
	self.propName			:= _propName;

end;
</source>
        <Parameter name="_form" type="RadioTelemetryMainForm"/>
        <Parameter name="_propClassName" type="String"/>
        <Parameter name="_propName" type="String"/>
        <Parameter name="_queryOperatorOid" type="String"/>
