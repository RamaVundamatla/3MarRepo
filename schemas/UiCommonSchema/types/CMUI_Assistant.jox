begin

	sch := rootSchema.getSchema("YardSchema");
	aClass := sch.getClass("YRD_RackShelvesForm");
	assistClass := sch.getClass("YRD_Assistant");
	
	enqForm := app.loadForm(aClass, assistClass, false, false, true, self.myTerminal, _masterMenuAction);
