    <JadeMethod name="initShtMultiSelect" id="89d73244-305b-454b-b799-da147b4600d4">
        <source>initShtMultiSelect();
// ---------------------------------------------------------------------------
// Created:     11 September 2002 by cnwdf1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
/* Changes

Date		Name	TFS#			Description
============================================================================
18 May 2014	cnwcs5	CCMS SCT 2058 
					/ par 27460 	user defined special charac	ters
15 May 2014	cnwrs1	Par 34159 		include Chassis in Codeco
18 Nov 2014 cnwgb1  PAR 35255 
					CCMS JMT 2405 	Remove Reference to allTrainEventTypes
28 Jun 2016 cnwma1  TFS #2226 		POL - Update to VERMAS structure from Ship Operators
05 Oct 2016	cnwma1	TFS #2712 		CPL - Container Number in VERMAS DOC segment
13 Dec 2016 cnwma1	TFS #2801*		Special Protocol Settings sheet display issues 
12 Jul 2017	jlgrs1	TFS 4465 		SNO standard Codedo/Coarri
29 Aug 2017	jlgrs1	TFS 6772 		resize damage repair fields
19 Sep 2017	jlgrs1	TFS 6957 		Codeco/Coarri VGM extra details
15 Mar 2019	jlgka1  TFS 41641		SSL - X12 322 Equipment ID Check.
24 Apr 2019 jlgka1	TFS 43785		STWR - CAMS STANDARD CODECO for Non-Structure Voyage.
07 Jul 2023	jlika1	TFS 58636		EUP - Goods Receipt - Move Transaction area triggers
============================================================================*/
vars
	theForm	: SOP_TableMaintForm;
//	currentTop : Real;	//	31 Jan 2018	NDL	TFS 36466 - remove
	terminology : String;
begin
	inheritMethod;
	theForm := self.myForm;	
//	theForm.chkNonPlanned.visible := true;	//31 Jan 2018	NDL	TFS 36466
// PAR 33644	theForm.chkNonWorked.visible := true;
	theForm.chkNullVoyage.visible := true;
	theForm.chkPandoRInUnPck.visible := true;
	theForm.chkPandoSntPack.visible := true;
	theForm.chkPonOperator.visible := true;
	theForm.chkMSCForNZPOE.visible := true;
	theForm.chkDaysLookBack.visible := true;
	theForm.chkTempFormat.visible := true;
	theForm.chkEDIXlatCtn.visible := true;	// cnwrl1 06/07/2009 PAR 20192 - CCMS 1818
	theForm.chkIncludeChild.visible	:=	true;	// cnwdad1 26/01/2010 - PAR #22199.
	
	theForm.chkSendCarrier.visible := true;	// par 27460 cnwcs5
	theForm.chkUseCarrierRef.visible := true;	// par 27460 cnwcs5
	theForm.lblDelayMins.visible	:= true;	//08 Sep 2015	NDL	Par 36876
	theForm.txtDelayMins.visible	:= true;	//08 Sep 2015	NDL	Par 36876
	
	theForm.chkRelaxedIdChecking.visible := true;	// jlgka1 TFS 41641
	theForm.chkUseCodecoNonStruc.visible := true;	// jlgka1 TFS 43785
	theForm.chkDGSDetailsInGroup14.visible := true;	//JIRA-20814
	theForm.chkCliRefBooking.visible := true; // cnwrd par 34369
	
	//hard code this - we need to be able to set this to half the size of the sheet for todo templates and CAM protocols
	//set to true in inheritMethod
	theForm.mulSelect41.stretchHeight := false;	

	self.setupMultiSelect1('Copy Email Addresses',app.myRoot.allEmailEntities,SOP_TableMaintForm::displayEntryEmailAddress.name);
	
	if theForm.myCurrentObject &lt;&gt; null and theForm.myCurrentObject.isKindOf(CM_CamProtocol) and (theForm.myCurrentObject.CM_CamProtocol.isGoodsReceipt() or theForm.myCurrentObject.CM_CamProtocol.isLoadConfirmation()) then
		if theForm.myCurrentObject.CM_CamProtocol.hasMoveTransaction() then		
			theForm.btnTransactionFilter.visible := true;
		else
			theForm.btnTransactionFilter.visible := true;
		endif;
		theForm.lblName3.visible := false;
		theForm.cmbCargoType2.visible := false;
	else
		theForm.btnTransactionFilter.visible := false;
		theForm.cmbCargoType2.visible := true;
		theForm.myAssistant.comboBoxUserQuery(theForm.cmbCargoType2,null,CM_QueryDefinition.CargoTransaction_Query_Mode,false);
		theForm.lblName3.visible := true;
		theForm.lblName3.caption := app.getErrorString(Selector_query_txt);
	endif;
	
	self.setupMultiSelect2(app.getErrorString(Transactions),null,SOP_TableMaintForm::displayEntryTransactionType.name);
	self.setupMultiSelect3('Coarri Import Ports',app.myRoot.allActivePorts,SOP_TableMaintForm::displayEntryCoarriPort.name);
	self.setupMultiSelect6("Edit Settings", allCamEditTriggerFields, SOP_TableMaintForm::displayEntryCamEditTriggField.name);
	theForm.cmbMul7.visible := true;
	theForm.myAssistant.comboBoxUserQuery(theForm.cmbMul7,null,CM_QueryDefinition.EventTransaction_Query_Mode,false);
	theForm.lblMul7.caption := app.getErrorString(Selector_query_txt);
	theForm.lblMul7.visible := true;
	theForm.mulSelect7.top := theForm.cmbMul7.height + 10;
	self.setupMultiSelect7(app.getErrorString(Events), null, SOP_TableMaintForm::displayEntryEventTypeGroup.name);	// Par 35255 cnwgb1 CCMS 2405 AST 18.11.2014
	self.setupMultiSelect8("Cargo Types", null, SOP_TableMaintForm::displayEntryCargoType.name);	// PAR 21905 CCMS MES 1008 - PHB
	terminology := app.getTerminologyAlternate(null,theForm.myTerminal, CM_TerminologyOperator, CM_TermExpressionPlural, 'Operators');
	
	self.setupMultiSelect4('For Pack Warehouse',terminology,'Consignees',
							app.myRoot.allOperators,
							app.myRoot.allConsigneeConsignors,
							SOP_TableMaintForm::displayEntryOperator.name,
							SOP_TableMaintForm::displayEntryConsignee.name);
							
	theForm.shtMultiSelect5.visible := true;
	theForm.shtMultiAlign.visible := false;
	theForm.shtSingleSelect2.visible := true;
	theForm.shtSingleSelect1.visible := false;
	theForm.lstSingleSelect1.visible := false;	
	
	//31 Jan 2018	NDL	TFS 36466
	self.setLocalControlsOnForm( theForm );
	
end;</source>
    </JadeMethod>
    <JadeMethod name="initShtTblInput2" id="38536422-2d3c-438c-a0cd-27ffb3ebb92e">
        <updating/>
        <source>initShtTblInput2() updating;

constants
	LeftMargin		: Integer = 10;
	TopMargin		: Integer = 10;
	VerticalSpacing	: Integer = 5;

vars
	currentTop	: Real;
	d			: Date;	
begin
	inheritMethod();

	// need to setup sizing
	self.myForm.shtTblInput2.visible := true;
	self.myForm.mulSelIn21.visible := false; //cnwrs1 ccms1912 27 jan 2010 the Pack areas is being withdrawn and all references in 782 will be deleted.
	self.myForm.tblInput2.visible := true;
	//self.myForm.cmbConsignee.visible := true;
	
	currentTop := self.myForm.tblInput2.top + self.myForm.tblInput2.height + VerticalSpacing;
	
	if (self.myForm.lblName1.visible) and (self.myForm.comboBox1.visible) then	
		self.myForm.lblName1.top		:= currentTop;
		self.myForm.lblName1.left	:= LeftMargin;
		self.myForm.lblName1.width  := (self.myForm.mulSelIn21.parent.width/2).Integer - 10;
		self.myForm.comboBox1.top := currentTop - 4;
		self.myForm.comboBox1.left := (self.myForm.mulSelIn21.parent.width/2).Integer + 25;
		self.myForm.comboBox1.width := 100;
		currentTop := currentTop + self.myForm.lblName1.height + VerticalSpacing;
	endif;


end;
</source>
    </JadeMethod>
