    <JadeMethod name="create" id="0aaec096-00d8-49ad-8524-c4cbd1ad51b7">
        <updating/>
        <source>create() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 Feb 2017	cnwkpd1	TFS 3369 - Push Events application


*/

vars

begin
	create self.myPushEventsAgent transient;
	
	create self.myJadeLog transient;
	self.myJadeLog.fileName := self.class.name;
	
	self.logMessage(self.String &amp; " created");
	
	create self.myEventPublisherHelper transient;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="delete" id="15c1ee8a-59d4-4a05-bdef-6638ea771457">
        <updating/>
        <source>delete() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 Feb 2017	cnwkpd1	TFS 3369 - Push Events application

*/

vars

begin
	self.logMessage(self.String &amp; " deleted");
	
	delete self.myPushEventsAgent;
	delete self.myJadeLog;
	delete self.myEventPublisherHelper;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doCheckAndPushObject" id="35e5a7f3-e760-404c-ae16-c2bb43a8c48f">
        <updating/>
        <source>doCheckAndPushObject(_object : CM_Object; _replayIdentifier : String) protected, updating;
/*

Purpose:			Check to see of the passed in object can be serialised, and if it is then push it out

Parameters:			Object to be serialised and pushed
					Optional replay identifier

Return Value:		None

Date		Who		Reason
17 Feb 2017	cnwkpd1	TFS 3369 - Push Events application
01 Nov 2017	jlgkpd1	TFS 7141 - Add in replay identifier mechanism

*/

vars
	invalid			: Boolean;
	
begin
	on Exception do app.handleDeletedObject(exception, _object, invalid);
		
	if self.myPushEventsAgent.ignoreObject(_object) then
		//07 Jul 2020	NDL	TFS 49590
		if _object &lt;&gt; null then
			self.logMessage("Ignored " &amp; _object.String);
			app.writeLog(method.qualifiedName &amp; " ignored " &amp; _object.String, LogINFO);
		endif;
	else
		// Serialise the object, and push it
		if _object &lt;&gt; null then	//14 Jul 2020	NDL	TFS 49747
			app.writeLog(method.qualifiedName &amp; " pushing " &amp; _object.String, LogDEBUG);
		endif;
		self.doPushObject(_object, _replayIdentifier);
	endif;
	
epilog

end;
</source>
        <access>protected</access>
        <Parameter name="_object" type="CM_Object"/>
        <Parameter name="_replayIdentifier" type="String"/>
    </JadeMethod>
    <JadeMethod name="doClearReplayRequest" id="6a1617ae-14e8-42df-883f-45fd1c801d5d">
        <source>doClearReplayRequest() protected;
/*

Purpose:			Clear any current pending replay request

Parameters:			

Return Value:		

Date		Who		Reason
13 Mar 2017	cnwkpd1	TFS 3369 - Push Events application
01 Nov 2017	jlgkpd1	TFS 7141 - Add in replay identifier mechanism

*/

vars
	pxyRoot			: CM_PushEventsRoot;
	
begin
	pxyRoot := app.createUpdateProxy(self.myPushEventsRoot).CM_PushEventsRoot;
	pxyRoot.setProxy(pxyRoot.configurationDetails, null, null, null);
	
	app.myTrxUA.trxUpdatePushEventsRoot(pxyRoot, app.myPassport);
	
epilog
	delete pxyRoot;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doConnectToEventStream" id="d5685b92-cbf9-4b35-943f-699344e8d06c">
        <source>doConnectToEventStream() protected;
/*

Purpose:			Make the initial connection to the Events Streaming service.  Use connectionTimeout
					to determine how long to wait for a successful connection

Parameters:			None

Return Value:		None

Date		Who		Reason
29 Mar 2017	cnwkpd1	TFS 3369 - Push Events application
03 Apr 2017	cnwkpd1	Handle false return value from connect, and terminate
04 Sep 2017	jlgkpd1	TFS 6615 - Raise Alert before terminating

*/

vars
	connectEndTime	: Decimal[20];
	msg				: String;
		
begin
	if self.pushEnabled then
	
		// Setup connection end time
		connectEndTime := app.relativeMachineTime() + (self.connectionTimeout * 1000);
		
		// Retry until connected or the timeout is reached
		while true do
			if self.myEventPublisherHelper.connect(self.eventStreamURI) then
				return;
			endif;
			
			if app.relativeMachineTime() &gt; connectEndTime then
				msg := "Connect to Events Stream failed, terminating";
				app.writeLog(msg, LogFATAL);	//25 Nov 2019	NDL	TFS 47053
				
				app.createAlert(app.name &amp; ' - ' &amp; msg, true);				
				terminate;
			endif;
			app.writeLog("Connect to Events Stream failed, retrying", LogINFO);	//25 Nov 2019	NDL	TFS 47053
			
		endwhile;
	endif;
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doCreatePushEventsRoot" id="ce7458ff-d7d9-431c-aa42-ada856c9adf9">
        <updating/>
        <source>doCreatePushEventsRoot() updating, protected;
/*

Purpose:			One time only code to create Push Events Root

Parameters:			None

Return Value:		None

Date		Who		Reason
10 Mar 2017	cnwkpd1	TFS 3369 - Push Events application

*/

vars
	globalLocked	: Boolean;
	
begin
	// need to ensure this is single-threaded
	self.reserveLock(GPortSchema.firstInstance());
	globalLocked := true;
	
	// Check again inside protected section
	self.myPushEventsRoot := CM_PushEventsRoot.firstInstance();
	if self.myPushEventsRoot = null then
		beginTransaction;
		create self.myPushEventsRoot;
		commitTransaction;
		globalLocked := false;
	endif;

epilog
	if globalLocked then
		self.unlock(GPortSchema.firstInstance());
	endif;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doDisableDefinitions" id="c6328540-f855-412c-b73e-7c154cf52ce4">
        <source>doDisableDefinitions(_subscriptions : String);
/*

Purpose:			Disables EventStreamDefinitons from the passed in list, and sends an email to the
					admin email adress attached to the subscription

Parameters:			list of subscriptions and associated error messages 
					in the format name1::disabledTS1^^message1||name2::disabledTS2^^message2||

Return Value:		

Date				Who		Reason
27 January 2020		jlgzm1	Initial creation TFS 47920 Event Stream Admin JMT UI
22 January 2024		jlizm1	MTN 33782 Set disabled ts at first fail not at disabled time

*/

vars
	subsArray	: CnStringArray;
	sub 		: String;
	name		: String;
	message		: String;
	message64	: String;
	disabledStr	: String;
	disabledTS	: TimeStamp;
	sender		: String;
	subject 	: String;
	bin			: Binary;
	pos, pos2	: Integer;
	definition 	: CM_EventStreamDefinition;
	proxyDef 	: CM_EventStreamDefinition;
	eventTypes 	: CM_EventStreamEventTypeDict;
	
begin
	create subsArray transient;
	
	if _subscriptions = null then
		return;
	endif;
	
	pos := 1;
	while pos &lt;&gt; 0 do
		name := _subscriptions.cnGetToken(pos, "::");
		if pos &gt; 0 then
			pos2 := pos;
			disabledTS := null;
			disabledStr := _subscriptions.cnGetToken(pos2, "^^");
			if pos2 &lt;&gt; 0 then
				pos := pos2;
				disabledTS := disabledStr.asTimeStampFromJSON;
				if disabledTS &lt;&gt; null then
					disabledTS := app.myTimeZoneHelper.convertTimeFromUtc(disabledTS, app.myTimeZoneHelper.getSystemTimeZoneID);
				endif;
			endif;
			
			message64 := _subscriptions.cnGetToken(pos, "||");
			message := message64.base64Decode().String;
		endif;
		
		definition := self.myPushEventsRoot.allEventStreamDefinitions[name];
		if definition &lt;&gt; null and definition.isActive then
			// Send email to admin
			sender := app.myRoot.getConfig(AutoSendersEmailAddress).String;
			subject := "[JMT Events streaming] Subscription " &amp; definition.name &amp; " failure";
			app.myTrxCA.trxCreateEmailSendRequest(	subject,			//_alertDescription : String;
													definition.email,	//_toAddress : String;
													sender,				//_fromAddress : String;
													null,				//_ccAddresses : String;
													null,				//_bccAddresses : String;
													subject,			//_sendSubject : String;
													message,			//_sendMessage : String;
													null,				//_allAttachedFilePaths : HugeStringArray;
													null,				//_allFileData : CM_FileDataStorageHdrSet input;
													null,				//_blob : Binary;
													null,				//_blobFileName : String;
													EmailSource_System,	//_sourceOfEmail : Integer;
													null,				//_updateCallbackObj : Object;
													app.myPassport		//_passport : CM_Passport input
													);
													
			proxyDef := app.createUpdateProxy(definition).CM_EventStreamDefinition;
			proxyDef.disable(disabledTS);
			create eventTypes transient;
			definition.allEventStreamEventTypes.copy(eventTypes);
			app.myTrxUA.trxUpdateEventStreamDef(proxyDef, eventTypes, app.myPassport);
			delete proxyDef;
			delete eventTypes;
		endif;
	endwhile;
	

epilog
	if proxyDef &lt;&gt; null then
		delete proxyDef;
	endif;
	if eventTypes &lt;&gt; null then
		delete eventTypes;
	endif;
	
	delete subsArray;
end;</source>
        <Parameter name="_subscriptions" type="String"/>
    </JadeMethod>
    <JadeMethod name="doProcessRootNotification" id="e8b408a1-73b2-441b-b7f4-b27c4903c075">
        <updating/>
        <source>doProcessRootNotification(_notifiedObject: Object) updating, protected;
/*

Purpose:			Process a change notification received for the Push Events root.  Could
					be a configuration change or a replay request

Parameters:			None

Return Value:		None

Date		Who		Reason
03 Apr 2017	cnwkpd1	TFS 3369 - Push Events application
27 Jan 2020	jlgzm1	TFS 47920 Event Stream Admin JMT UI

*/

vars

begin
	app.writeLog(method.qualifiedName &amp; " " &amp; _notifiedObject.String, LogTRACE);	//25 Nov 2019	NDL	TFS 47053
	
	// TFS 47920
	if _notifiedObject.isKindOf(CM_EventStreamDefinition) then
		// Definitions have been changed in some way. Restart dispatching so Events Stream gets the updated configs
		app.writeLog("Restarting Events Stream", LogTRACE);
		self.doStopDispatching();
		self.doStartDispatching();
		
	elseif _notifiedObject.isKindOf(CM_PushEventsRoot) then
		// Check and process a pending replay request
		app.writeLog("Replaying Events", LogTRACE);
		self.doReplayPushEvents();
	
	endif;	

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_notifiedObject" type="Object"/>
    </JadeMethod>
    <JadeMethod name="doPushObject" id="dfa09abb-96c8-4b7f-a0ff-e48aa47507ed">
        <updating/>
        <source>doPushObject(_object : CM_Object; _replayIdentifier : String) protected, updating;
/*

Purpose:			Serialise the passed in object, then push it out

Parameters:			Object to be serialised and pushed
					Optional replay identifier
					
Return Value:		None

Date		Who		Reason
30 Mar 2017	cnwkpd1	TFS 3369 - Push Events application
19 Jun 2017	cnwkpd1	Refactor of event push, so add code to build log message
27 Jul 2017	jlgkpd1	Add check for failure and terminate
25 Aug 2017	jlgkpd1	Fix logging of header info to produce valid JSON
04 Sep 2017	jlgkpd1	TFS 6615 - Raise Alert before terminating
01 Nov 2017	jlgkpd1	TFS 7141 - Add in replay identifier mechanism
19 Mar 2024 navmd1	TFS 63011 Added quotes around dateTime to fix bad JSON formatting

*/

vars
	dateTime 		: TimeStamp;
	source 			: String;
	environment		: String;
	terminal		: CM_Terminal;
	aType 			: String;
	subType			: String;
	eventJSON		: String;
	logEventJSON	: String;
	logMsg			: String;
	dateTimeStr,
	terminalStr,
	terminalCode	: String;
	msg				: String;
	
begin
	eventJSON := self.myPushEventsAgent.getPushEventsDetailForObject(_object,
																dateTime,
																source,
																environment,
																terminal,
																aType,
																subType);
	
	// Check there was a valid serialisation
	if eventJSON = null then
		return;
	endif;
	
	dateTimeStr := dateTime.asJSONFormat();
	if terminal &lt;&gt; null then
		terminalStr := self.getOidStringForObject(terminal);
		terminalCode := terminal.code;
	endif; 
		
	// If we are logging this push, then build up a logMsg
	eventCount := eventCount + 1;
	if eventCount mod eventLogFrequency = 0 then
		logMsg := 'eventCount=' &amp; eventCount.asStringJSON();
		
		// Create a log message with the header info as well as the body
		logEventJSON := '{';
	
		logEventJSON := logEventJSON &amp; CrLf &amp; '"dateTime" : "' &amp; dateTimeStr &amp; '"';
		logEventJSON := logEventJSON &amp; ',' &amp; CrLf &amp; '"source" : ' &amp; source.asStringJSON();
		logEventJSON := logEventJSON &amp; ',' &amp; CrLf &amp; '"environment" : ' &amp; environment.asStringJSON();
	
		if terminal &lt;&gt; null then
			logEventJSON := logEventJSON &amp; ',' &amp; CrLf &amp; '"terminal" : ' &amp; terminalStr.asStringJSON();
			logEventJSON := logEventJSON &amp; ',' &amp; CrLf &amp; '"terminalCode" : ' &amp; terminalCode.asStringJSON();
		endif;
	
		logEventJSON := logEventJSON &amp; ',' &amp; CrLf &amp; '"type" : ' &amp; aType.asStringJSON();
		logEventJSON := logEventJSON &amp; ',' &amp; CrLf &amp; '"subtype" : ' &amp; subType.asStringJSON();

		if _replayIdentifier &lt;&gt; null then
			logEventJSON := logEventJSON &amp; ',' &amp; CrLf &amp; '"replayIdentifier" : ' &amp; _replayIdentifier.asStringJSON();
		endif;
		
		// And now insert the serialised object as the "body"
		logEventJSON := logEventJSON &amp; ',' &amp; CrLf &amp; '"body" : ' &amp; eventJSON;
			
		logEventJSON := logEventJSON &amp; CrLf &amp; '}';

		logMsg := logMsg &amp; CrLf &amp; 'event=' &amp; logEventJSON;
	
		self.logMessage(logMsg);
	endif;
	
	// And if push is enabled, then push the details using the EventPublisher
	if self.pushEnabled then
		if not self.myEventPublisherHelper.publishEvent(dateTimeStr,
														source,
														environment,
														terminalStr,
														terminalCode,
														aType,
														subType,
														_replayIdentifier,
														eventJSON) then
			msg := "Publish Event failed, terminating";
			app.writeLog(msg, LogFATAL);	//26 Nov 2019	NDL	TFS 47053
			app.createAlert(app.name &amp; ' - ' &amp; msg, true);
			terminate;
		endif;
	endif;
		
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_object" type="CM_Object"/>
        <Parameter name="_replayIdentifier" type="String"/>
    </JadeMethod>
    <JadeMethod name="doRegisterForNotes" id="e8e31d2c-6e91-40a6-8e5e-07e6b9500efe">
        <source>doRegisterForNotes() protected;
/*

Purpose:			Register for notifcations for events that need to be pushed out

Parameters:			None

Return Value:		None

Date		Who		Reason
17 Feb 2017	cnwkpd1	TFS 3369 - Push Events application
27 Jan 2020 jlgzm1	TFS 47920 Event Stream Admin JMT UI

*/

vars

begin
	
	app.writeLog(method.qualifiedName &amp; " registering for notifications", LogINFO);	//25 Nov 2019	NDL	TFS 47053
	
	self.beginNotification(self.myPushEventsRoot, Object_Update_Event, Response_Continuous, 0);
	self.beginClassNotification(CM_EventStreamDefinition, false, Object_Create_Event, Response_Continuous, 0);	// TFS42920
	self.beginClassNotification(CM_EventStreamDefinition, false, Object_Update_Event, Response_Continuous, 0);	// TFS42920
	self.beginClassNotification(CM_EventStreamDefinition, false, Object_Delete_Event, Response_Continuous, 0);	// TFS42920

	self.beginClassNotification(CM_TITransaction, false, Object_Create_Event, Response_Continuous, 0);
	self.beginClassNotification(CM_TITransaction, false, Object_Update_Event, Response_Continuous, 0);
	
	self.beginClassNotification(CM_EventTransaction, false, Object_Create_Event, Response_Continuous, 0);
	self.beginClassNotification(CM_EventTransaction, false, Object_Update_Event, Response_Continuous, 0);

	self.beginClassNotification(HMS_Transaction, false, Object_Create_Event, Response_Continuous, 0);
	self.beginClassNotification(HMS_Transaction, false, Object_Update_Event, Response_Continuous, 0);

	self.beginClassNotification(CM_AuditObject, false, Object_Create_Event, Response_Continuous, 0);
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doReplayPushEvents" id="ba166696-8e55-46d7-afa7-13f81b565523">
        <updating/>
        <source>doReplayPushEvents() protected, updating;
/*

Purpose:			Using the replay values on the Push Events root, replay all the events	
					in the range

Parameters:			

Return Value:		

Date		Who		Reason
13 Mar 2017	cnwkpd1	TFS 3369 - Push Events application
01 Nov 2017	jlgkpd1	TFS 7141 - Add in replay identifier mechanism

*/

vars
	pxyRoot			: CM_PushEventsRoot;
	fromTS,
	toTS			: TimeStamp;
	replayIdentifier : String;
	
begin
	if self.myPushEventsRoot.replayStartTS = null and self.myPushEventsRoot.replayEndTS = null then
		// Nothing to do
		return;
	endif;
	
	// Save off the range, and then clear it for a subsequent request
	fromTS := self.myPushEventsRoot.replayStartTS;
	toTS := self.myPushEventsRoot.replayEndTS;
	replayIdentifier := self.myPushEventsRoot.replayIdentifier;
	
	self.doClearReplayRequest();
	
	// And then initiate the replay
	self.pushEventsForRange(fromTS, toTS, replayIdentifier);
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doSetupFromIniFile" id="a73ea748-51da-48a4-b0d8-4b7ee2ea8943">
        <updating/>
        <source>doSetupFromIniFile() updating, protected;
/*

Purpose:			Read all the required settings from the ini file

Parameters:			None

Return Value:		None

Date		Who		Reason
28 Mar 2017	cnwkpd1	TFS 3369 - Push Events application
04 Sep 2017	jlgkpd1	TFS 6615 - Raise Alert before terminating
29 May 2020 cnwma1  Bug 49181: MTN - Push Events still references old data
04 Nov 2020 jlgmd1	Move environment checking code to centralised place
*/

constants
	SectionName			= "JMTPushEvents";
	EventStreamURI		= "EventStreamURI";
	EventLogFrequency	= "EventLogFrequency";
	PushEnabled			= "PushEnabled";
	ConnectTimeout		= "ConnectTimeout";
	DummyValue			= "Dummy";

vars
	iniValue,
	iniFileName		: String;
	msg				: String;
	
begin
	iniFileName := app.getIniFileName;
	
	// Get each of the required values
	
	// Event Log Frequency 
	iniValue := app.getProfileString(iniFileName, SectionName, EventLogFrequency, DummyValue);
	if iniValue = DummyValue or not iniValue.isInteger() then
		if app.isInternalEnvironment(false) then
			self.eventLogFrequency := 1;		// default for internal systems
		else
			self.eventLogFrequency := 1000;		// default for user systems
		endif;
		app.setProfileString(iniFileName, SectionName, EventLogFrequency, self.eventLogFrequency.String);
	else 
		self.eventLogFrequency := iniValue.Integer.max(1);			// KPD 14/12/2017 - was min
	endif;

	// Push Enabled - default to false
	iniValue := app.getProfileString(iniFileName, SectionName, PushEnabled, DummyValue);
	if iniValue = DummyValue then
		app.setProfileString(iniFileName, SectionName, PushEnabled, false.String);
		self.pushEnabled := false;
	else
		self.pushEnabled := iniValue.Boolean;
	endif;
	
	// Connect Timeout - default to 120 (seconds)
	iniValue := app.getProfileString(iniFileName, SectionName, ConnectTimeout, DummyValue);
		if iniValue = DummyValue or not iniValue.isInteger() then
		app.setProfileString(iniFileName, SectionName, ConnectTimeout, 120.String);
		self.connectionTimeout := 120;
	else
		self.connectionTimeout := iniValue.Integer;
	endif;
	
	// Event Stream URI
	if process.sendMsg("_isBeingDebugged").Boolean then
		iniValue := "127.0.0.1:5050";
	else
		iniValue := app.getProfileString(iniFileName, SectionName, EventStreamURI, DummyValue);
	endif;
	
	if iniValue = DummyValue then
		app.setProfileString(iniFileName, SectionName, EventStreamURI, null);
		self.eventStreamURI := null;
	else
		self.eventStreamURI := iniValue;
	endif;
		
	// Now validate mandatory settings if PushEnabled is true
	if self.pushEnabled then
	
		//14 Apr 2020	NDL	TFS 49069
		if self.eventStreamURI = null then
			msg := "[" &amp; SectionName &amp; '] ' &amp; PushEnabled &amp; ' is set to true, so ' &amp;
				   EventStreamURI &amp; ' is mandatory, terminating';
			
			app.writeLog(msg, LogFATAL);
			app.createAlert(app.name &amp; ' - ' &amp; msg, true);
			terminate;
		endif;
	endif;
		
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doStartDispatching" id="8e7b2877-1d8f-4ae5-a9ba-1456176d66f7">
        <updating/>
        <source>doStartDispatching() protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 Mar 2017	cnwkpd1	TFS 3369 - Push Events application
27 Jul 2017	jlgkpd1	Check for failure and terminate
04 Sep 2017	jlgkpd1	TFS 6615 - Raise Alert before terminating
28 Jan 2019	jlgzm1	TFS 47920 Event Stream Admin JMT UI
31 Aug 2020 jlgmd1	Handle starting up while a definition is being deleted

*/
vars
	msg				: String;
	json			: String;
	invalidRef		: Boolean;
begin

	if self.myPushEventsRoot.allEventStreamDefinitions.size &lt;&gt; 0 then
		// If a definition is deleted while we're starting up, then the deserializeJSON will get an error 4 when referencing us
		on Exception do self.handleJSONSerialisationErrors(exception, invalidRef);
		
		self.myPushEventsRoot.deserializeJSON(json); // TFS 47920
		if invalidRef then
			json := null;
		endif;
		
		on Exception do null;
	endif;
	
	if self.pushEnabled then
		if not self.myEventPublisherHelper.startDispatching(json) then // TFS 47920
			msg := "Start Dispatching failed, terminating";
			app.writeLog(msg, LogFATAL);	//26 Nov 2019	NDL	TFS 47053
			app.createAlert(app.name &amp; ' - ' &amp; msg, true);
			terminate;
		endif;
	endif;
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doStopDispatching" id="bef64636-0b80-455d-9f9b-98b5c2e94790">
        <source>doStopDispatching() protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
29 March 2017		cnwkpd1	TFS 3369 - Push Events application
08 September 2020	jlgmd1	Don't send a stop message, if there is nothing to stop


*/

vars

begin
	if self.pushEnabled and self.myPushEventsRoot.allEventStreamDefinitions.size &gt; 0 then 
		self.myEventPublisherHelper.stopDispatching();
	endif;
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="finish" id="87e92f0d-9092-454f-a4f6-65494f0784c5">
        <updating/>
        <source>finish() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 Feb 2017	cnwkpd1	TFS 3369 - Push Events application


*/

vars

begin
	inheritMethod();
	
	self.endTimer(CM_PushEventsController.Handshake_Event_Tag); // TFS 47920 jlgzm1 22/01/2020
	
	self.endNotificationForSubscriber(self);
	
	self.doStopDispatching();

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="handleJSONSerialisationErrors" id="65a5ebe7-6601-4448-bea3-439939a01015">
        <source>handleJSONSerialisationErrors(_exc : Exception; _hadError : Boolean io) : Integer protected;
/*

Purpose:			Ignore Error 4s when serialising our Event Stream Fefinitions

Parameters:			

Return Value:		

Date				Who		Reason
03 September 2020	jlgmd1	Initial creation - Unit Tests

*/

constants
	ObjectNotFound	= 4;
vars
	returnVal		: Integer;
	
begin
	returnVal := Ex_Pass_Back;

	if _exc.errorCode = ObjectNotFound then
		_hadError := true;
		if _exc.resumable then
			returnVal := Ex_Resume_Next;
		endif;
	endif;
epilog
	return returnVal;

end;</source>
        <access>protected</access>
        <Parameter name="_exc" type="Exception"/>
        <Parameter name="_hadError" type="Boolean" usage="io"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="logMessage" id="445094ff-b234-40ec-8f49-9397c06f4cc3">
        <source>logMessage(_msg : String) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 Feb 2017	cnwkpd1	TFS 3369 - Push Events application

*/

vars

begin
	if self.myJadeLog &lt;&gt; null then
		self.myJadeLog.info(_msg);
	endif;
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_msg" type="String"/>
    </JadeMethod>
    <JadeMethod name="pushEventsForRange" id="168296ce-2002-47be-9c82-758253eb5fc2">
        <updating/>
        <source>pushEventsForRange(_fromTS, _toTS : TimeStamp; _replayIdentifier : String) updating;
/*

Purpose:			Push out all the events for the passed in time range

Parameters:			Starting timestamp (can be null to start from the beginning of time)
					Ending timestamp (can be null to push all up to now
					Optional replay identifier

Return Value:		None

Date		Who		Reason
17 Feb 2017	cnwkpd1	TFS 3369 - Push Events application
25 Sep 2017	jlgkpd1	TFS 7141 - rework to use MergeIterator to preserve order in a replay
01 Nov 2017	jlgkpd1	TFS 7141 - Add in replay identifier mechanism and include non-Terminal Events

*/

vars
	auditConfig		: CM_AuditConfig;
	terminal		: CM_Terminal;
	mergeIter1,
	mergeIter2		: MergeIterator;
	object1,
	object2			: CM_Object;
	iter1Next,
	iter2Next		: Boolean;
	keyTime1,
	keyTime2		: TimeStamp;
	keyType2		: Integer;
	
begin

	app.writeLog(  method.qualifiedName &amp; 
					" extract _fromTS=" &amp; _fromTS.asStringJSON() &amp;
					" _toTS=" &amp; _toTS.asStringJSON() &amp; 
					" _replayIdentifier=" &amp; _replayIdentifier.asStringJSON(), LogINFO);	//25 Nov 2019	NDL	TFS 47053
	
	
	// See JADE PAR #65423 - MergeIterator startKey methods do not work if the dictionaries have different
	// numbers of keys, so need to create 2 MergeIterators (one for 1 key dicts and one for 2 key dicts) and
	// manually merge the results
	create mergeIter1 transient;
	create mergeIter2 transient;
	
	// Get all audit collections
	foreach auditConfig in app.myRoot.allAuditConfigs discreteLock do
		mergeIter1.addCollection(auditConfig.allAuditObjectsForClass);	//21 Jan 2021	NDL	TFS 50152
	endforeach;
		
	// And now transaction and event collections for all Terminals
	foreach terminal in app.myRoot.allTerminals discreteLock do
		mergeIter2.addCollection(terminal.allTITransactions);
		mergeIter1.addCollection(terminal.allEventsByDateTime);
		mergeIter2.addCollection(terminal.allHMSTransactions);
	endforeach;

	// And add in the Root Event collection
	mergeIter1.addCollection(app.myRoot.allEventsByDateTime);
	
	// Now initiate the extract
	mergeIter1.startKeyGeq(_fromTS);
	mergeIter2.startKeyGeq(_fromTS, null);
	
	iter1Next := mergeIter1.next(object1);
	if iter1Next then
		mergeIter1.getCurrentKeys(keyTime1);
	endif;
	iter2Next := mergeIter2.next(object2);
	if iter2Next then
		mergeIter2.getCurrentKeys(keyTime2, keyType2);
	endif;
	
	while iter1Next or iter2Next do
	
		// Keep reading all mergeIter1 until we've passed the start of mergeIter2
		while iter1Next do
			if _toTS &lt;&gt; null and keyTime1 &gt; _toTS then
				iter1Next := false;		// Stop checking mergeIter1 as we've passed the end time
				break;
			endif;
			
			// Have read past the start of mergeIter2, so hand over to those dicts
			if iter2Next and keyTime1 &gt; keyTime2 then
				break;
			endif;
			
			// All good, so extract this object
			self.doCheckAndPushObject(object1, _replayIdentifier);
			
			// And postition on the next object
			iter1Next := mergeIter1.next(object1);
			if iter1Next then
				mergeIter1.getCurrentKeys(keyTime1);
			endif;
		endwhile;
		
		// Keep reading all mergeIter2 until we've passed the start of mergeIter1
		while iter2Next do
			if _toTS &lt;&gt; null and keyTime2 &gt; _toTS then
				iter2Next := false;		// Stop checking mergeIter2 as we've passed the end time
				break;
			endif;
			
			// Have read past the start of mergeIter1, so hand back to those dicts
			if iter1Next and keyTime2 &gt; keyTime1 then
				break;
			endif;
			
			// All good, so extract this object
			self.doCheckAndPushObject(object2, _replayIdentifier);
			
			// And postition on the next object
			iter2Next := mergeIter2.next(object2);
			if iter2Next then
				mergeIter2.getCurrentKeys(keyTime2, keyType2);
			endif;
		endwhile;
	
	endwhile;

	app.writeLog(method.qualifiedName &amp; " extract complete", LogINFO);	//25 Nov 2019	NDL	TFS 47053
					
epilog
	delete mergeIter1;
	delete mergeIter2;
	
end;</source>
        <Parameter name="_fromTS" type="TimeStamp"/>
        <Parameter name="_toTS" type="TimeStamp"/>
        <Parameter name="_replayIdentifier" type="String"/>
    </JadeMethod>
    <JadeMethod name="start" id="1bb068b3-8871-4c36-8966-55c0e8ecc4d1">
        <updating/>
        <source>start() updating;
/*

Purpose:			Start up the Push Events application

Parameters:			

Return Value:		None

Date		Who		Reason
13 Feb 2017	cnwkpd1	TFS 3369 - Push Events application

*/

vars
		
begin
	inheritMethod();
	
	// Set up Push Events Root
	self.myPushEventsRoot := CM_PushEventsRoot.firstInstance();
	
	// First time only
	if self.myPushEventsRoot = null then
		self.doCreatePushEventsRoot();
	endif;
	
	// Read configuration from ini file
	self.doSetupFromIniFile();
	
	// On restart, clear any unfulfilled replay request
	self.doClearReplayRequest();
	
	self.doRegisterForNotes();
	
	// Finally connect to the Events Stream application and start dispatching
	self.doConnectToEventStream();
	self.doStartDispatching();
	
	// TFS 47920 jlgzm1 27/01/2020
	//set a timer to keep active subscriptions up to date
	self.beginTimer(CM_PushEventsController.Handshake_Interval, Timer_Continuous, CM_PushEventsController.Handshake_Event_Tag);
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="sysNotification" id="9edf4ce4-2117-4478-ad15-c752b2a4d52f">
        <updating/>
        <source>sysNotification(eventType: Integer; theObject: Object; eventTag: Integer) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 Feb 2017	cnwkpd1	TFS 3369 - Push Events application
01 Nov 2017	jlgkpd1	TFS 7141 - Add in replay identifier mechanism

*/

vars

begin
	// Check first for a replay request
	if theObject.isKindOf(CM_PushEventsRoot)
	or theObject.isKindOf(CM_EventStreamDefinition) then // TFS 47920
		self.doProcessRootNotification(theObject);
	elseif theObject.isKindOf(CM_Object) then
		self.doCheckAndPushObject(theObject.CM_Object, null);
	endif;
	
epilog

end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="timerEvent" id="2ecb513e-e811-497e-8856-6ba74939a881">
        <updating/>
        <source>timerEvent(eventTag: Integer) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
28 January 2020		jlgzm1	Initial creation TFS 47920 Event Stream Admin JMT UI

*/

vars
	subs : String;
begin
	
	if eventTag = CM_PushEventsController.Handshake_Event_Tag then
		// get subscriptions disabled by event stream then update in JMT
		if self.myPushEventsRoot.allEventStreamDefinitions.size &lt;&gt; 0 and 
		self.myEventPublisherHelper.getDisabledSubscriptions(subs) then
			self.doDisableDefinitions(subs);
		endif;
		
	endif;
	
epilog

end;</source>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
</Class>
