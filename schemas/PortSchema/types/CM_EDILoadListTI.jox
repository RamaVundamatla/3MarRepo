    <JadeMethod name="setProxy" id="b8cd3146-e1bd-49fb-80ef-29b3f3f56c50">
        <source>setProxy(_poxyContainer: CM_TrackedItem input);
//----------------------------------------------------------------
//	Created:	22 October 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
// 04 Mar 2019	jlgrs1	TFS 41913 STWR - Reconfiguration of the EDI Operation form to better handle EDI collection locks while loading 
//
vars
	voyageCode	: String;
	voyage		: CM_Voyage;
begin

	voyageCode := self.myEDIData.CM_EDIDataLoadList.voyageCode;
	voyage := self.getMyTerminal.lookupVoyage(voyageCode, null, false);
//	app.setContinueCMExceptions(false);
	if voyage = null then
		app.raiseCMException1(ERR_INVALID_VOYAGE, voyageCode, 'voyageCode', self.myEDIData);
		return;
	endif;
	
	_poxyContainer.setPxyFromEDILoadListTI(self, voyage, app.myPassport);
//	app.setContinueCMExceptions(true);
	

end;</source>
        <Parameter name="_poxyContainer" type="CM_TrackedItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setReeferDetails" id="9faf412e-e428-4db8-b9c6-2412c81f3ad2">
        <updating/>
        <source>setReeferDetails(_tempCarr: Real; _humidity: Decimal; _ventilation: Decimal; _expiryDate: Date; _remarks: String; _coolingType, _voltageType : Integer; _oxygen, _carbonDioxide: Decimal;
			_curtainsIn: Boolean; _packDate: Date; _packTime: Time; _remaining: Decimal; _packTemp: Real; _extMonitor: Boolean) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 October 2019	jlgmp6	Initial creation	TFS 45590

*/

vars
	packDT: TimeStamp;

begin
	self.temperature := _tempCarr;
	self.setHumidity( _humidity );
	self.vent := _ventilation;
	self.expiryDate := _expiryDate;
	self.reeferRemarks := _remarks;
	self.cooledType := _coolingType;
	self.voltageType := _voltageType;
	self.setOxygen( _oxygen );
	self.setCarbonDioxide( _carbonDioxide );
	self.curtainsIn := _curtainsIn;
	if _packDate.isValid() then
		packDT.setDate(_packDate);
		if _packTime.isValid() then
			packDT.setTime(_packTime);
		else
			packDT.setTime(null);
		endif;
		self.packDT := packDT;
	endif;
	self.remainingTimeOffPower := _remaining;
	self.packTemp := _packTemp;
	self.hasExternalMonitoring := _extMonitor;
epilog

end;</source>
        <Parameter name="_tempCarr" type="Real"/>
        <Parameter name="_humidity" type="Decimal"/>
        <Parameter name="_ventilation" type="Decimal"/>
        <Parameter name="_expiryDate" type="Date"/>
        <Parameter name="_remarks" type="String"/>
        <Parameter name="_coolingType" type="Integer"/>
        <Parameter name="_voltageType" type="Integer"/>
        <Parameter name="_oxygen" type="Decimal"/>
        <Parameter name="_carbonDioxide" type="Decimal"/>
        <Parameter name="_curtainsIn" type="Boolean"/>
        <Parameter name="_packDate" type="Date"/>
        <Parameter name="_packTime" type="Time"/>
        <Parameter name="_remaining" type="Decimal"/>
        <Parameter name="_packTemp" type="Real"/>
        <Parameter name="_extMonitor" type="Boolean"/>
    </JadeMethod>
