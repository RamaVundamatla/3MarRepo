    <JadeMethod name="cmbStatus_click" id="61714eb1-485a-4fac-abf4-c24b831a8317">
        <controlMethod name="CMUI_ComboBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbStatus_click(combobox: ComboBox input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 Dec 2018	jlgsl4	TFS 39618
13 Dec 2019 cnwma1	Bug 48012: JMT - Invoice List 1090 clicking status when no invoice selected
29 Nov 2023	navra1	TFS 54090 - EUP | EUP | Interface - MTN Invoicing Oracle &lt;&lt;54090&gt;&gt;TFS 54090 - CR-61386/Task-61564
05 Jun 2025 navma1  MTN-34114  MTN - Performance Improvements - Remove Class::FirstInstance usage  
*/

vars
	status 		: CM_InvoiceStatus;
	invProcess	: CM_InvoiceProcess;
	currInvoice	: CM_Invoice;
begin
	
	currInvoice := self.myCurrentInvoice;		//05.06.2025 navma1 #MTN-34114
	
	if currInvoice = null then    	//13.12.2019 cnwma1 #48012
		return;
	endif;
	
	status := combobox.listObject.CM_InvoiceStatus;
	
	if status = null then
		app.msgBox("Please select a valid invoice status,","Invoice Status Error",MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
		combobox.listIndex := -1;
		return;
	endif;
	
	if status.id = currInvoice.status then
		return; // chose current status so do nothing
	endif;
	
	invProcess := currInvoice.getMyInvoiceProcess();						//05.06.2025 navma1 #MTN-34114
	
	if invProcess.isDefaultProcessJMT() then
		if status.id = CM_Invoice.INVOICE_VOID then
			self.doBtnStatusVoidClick();
		elseif status.id = CM_Invoice.INVOICE_PENDING then
			self.doBtnStatusCloseClick(); // TFS 39618 861.010
		elseif status.id = CM_Invoice.INVOICE_POSTED then
			self.doBtnStatusPostedClick();// TFS 39618  861.010
		elseif status.id = CM_Invoice.INVOICE_POSTED_REVERSE then
			self.doBtnStatusReturnClick();
		endif;
	elseif invProcess.isPelindo1Process() then
		if status.id = CM_Invoice.INVOICE_VOID then
			self.doBtnStatusVoidClick();
		elseif status.id = CM_Invoice.INVOICE_PENDING then
			self.doBtnStatusCloseClick(); // TFS 39618 861.010
		elseif status.id = CM_Invoice.INVOICE_POSTED then
			self.doBtnStatusPostedClick();// TFS 39618  861.010
		elseif status.id = CM_Invoice.INVOICE_POSTED_REVERSE then
			self.doBtnStatusReturnClick();
		elseif status.id = CM_Invoice.INVOICE_PREPEND then
			self.doBtnStatusPrependClick();
		elseif status.id = CM_Invoice.INVOICE_DISPUTED then
			self.doBtnStatusDisputedClick();
		endif;
	elseif invProcess.isLinxProcess() then
		if status.id = CM_Invoice.INVOICE_VOID then
			self.doBtnStatusVoidClick();
		elseif status.id = CM_Invoice.INVOICE_PENDING then
			self.doBtnStatusCloseClick(); // TFS 39618 861.010
		elseif status.id = CM_Invoice.INVOICE_POSTED then
			self.doBtnStatusPostedClick();// TFS 39618  861.010
		elseif status.id = CM_Invoice.INVOICE_POSTED_REVERSE then
			self.doBtnStatusReturnClick();
		elseif status.id = CM_Invoice.INVOICE_PREPEND then
			self.doBtnStatusPrependClick();
		elseif status.id = CM_Invoice.INVOICE_DISPUTED then
			self.doBtnStatusDisputedClick();
		elseif status.id = CM_Invoice.INVOICE_PENDING_APPROVAL then
			self.doBtnStatusPendingApproval();
		elseif status.id = CM_Invoice.INVOICE_POSTED_DRAFT then  // ### JIRA 35468 28JUL2025 NAVAB1
			self.doBtnStatusPostedDraftClick();
		elseif status.id = CM_Invoice.INVOICE_APPROVED then
			self.doBtnStatusApprovedClick();
		elseif status.id = CM_Invoice.INVOICE_APPROVEDRETURNED then
			self.doBtnStatusApprovedReturned();
		endif;
	//navra1 - TFS 54090 - CR - 61386/Task - 61564 - start
	elseif invProcess.isInvoiceAPIProcess() then
		if status.id = CM_Invoice.INVOICE_VOID then
			self.doBtnStatusVoidClick();
		elseif status.id = CM_Invoice.INVOICE_PENDING then
			self.doBtnStatusCloseClick(); 
		elseif status.id = CM_Invoice.INVOICE_POSTED then
			self.doBtnStatusPostedClick();// TFS 39618  861.010
		elseif status.id = CM_Invoice.INVOICE_POSTED_ERROR then
			self.doBtnStatusPostedErrorClick();
		elseif status.id = CM_Invoice.INVOICE_POSTED_REVERSE then
			self.doBtnStatusReturnClick();	
		elseif status.id = CM_Invoice.INVOICE_POSTED_CREDIT then
			self.doBtnStatusPostedCreditClick();
		endif;
	//navra1 - TFS 54090 - CR - 61386/Task - 61564 - end
	endif;
epilog

end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
