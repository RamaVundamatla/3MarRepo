    <JadeMethod name="handleInUseEx" id="7a069fdc-43af-4d60-8fae-c2d49202ecc4">
        <source>handleInUseEx(_exc : Exception; _object : Any ): Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 July 2019	jlgns1	Initial creation
23/07/2019 	JLGNS1	Bug 45588: PNL - To Do Task Description no Planning / Queueing when To Do Task Terminals setup
*/

vars
begin

	if _exc.errorCode.isOneOf(Not_remov_alrea_been_compl_aga,Not_remov_alrea_been_appli_car)  then
		app.msgBox(_exc.extendedErrorText, "Error!", MsgBox_Stop_Icon + MsgBox_OK_Only); 
	
		return Ex_Abort_Action ;
	endif;

	return Ex_Pass_Back ;
		
epilog

end;</source>
        <Parameter name="_exc" type="Exception"/>
        <Parameter name="_object" type="Any"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
