    <JadeMethod name="getDisplayString" id="71db5e47-152e-4ef1-b2ba-eff90910d896">
        <source>getDisplayString():String;
// --------------------------------------------------------------------------------
// Created:		06 January 2006 by cnwdad1
//
// Purpose:		Returns a display string for the receiver.
//
// Parameters:	None
//
// Returns:		The receiver's display string.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return self.description &amp; ' (' &amp; self.code &amp; ')';
end;</source>
