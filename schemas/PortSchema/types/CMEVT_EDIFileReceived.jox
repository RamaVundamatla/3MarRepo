    <JadeMethod name="set" id="f2d110fc-1a70-4432-a4d8-0a870b1145f8">
        <updating/>
        <source>set(_dateTimeReceived : TimeStamp; _fileNumber : String; _fileType : Integer) updating;
//
//11 Jul 2014	cnwrs1	Par 34566 CCMS 2346 Suzano - Viagram Prenote file 
//
vars

begin
	self.dateTimeReceived := _dateTimeReceived;
	self.fileNumber := _fileNumber[1:30];
	self.fileType := _fileType;
end;
</source>
        <Parameter name="_dateTimeReceived" type="TimeStamp"/>
        <Parameter name="_fileNumber" type="String"/>
        <Parameter name="_fileType" type="Integer"/>
