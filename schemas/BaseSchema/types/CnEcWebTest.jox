    <JadeMethod name="cnEcReportDisplay" id="ff81c28d-c7ef-4673-af7e-f96a1e7f4486">
        <source>cnEcReportDisplay(): String;
// --------------------------------------------------------------------------------
// Created:		13 August 2000 by cnwdad1
//
