    <JadeMethod name="setMyTrackedItem" id="56e13365-b7ca-4f8e-8e41-691e4cd0c9dd">
        <updating/>
        <source>setMyTrackedItem(pTI: CM_TrackedItem; _tiTransCntrl: CMIF_TITransactionController ) updating;
//
// cnwrs1 May 2007 
// 08/09/2016   cnwma1  TFS #2589:PAR38142 STWR - TFS2239 " Double assign to release" -fix not OK
vars
	bulkRelease : CM_BulkRelease;
	reserveSelection : CM_ReserveSelection;
	pxyTi: CM_TrackedItem;
	information : StringArray512;
begin
	//	19/2/19 MAP TFS43243
	pxyTi := pTI;
	if pxyTi.isContainer() and _tiTransCntrl.bulkCompleteContainer then
		pxyTi.setImExStatus(TI_IMEX_STATUS_EXPORT);
		pxyTi.setContentsStatus(TI_CONTENTS_STATUS_FCL); // 7/9/22 	jlier1	TFS 54700

		create information transient;
		information.addTruncated("Terminal Configuration 'Bulk Pack/Unpack Complete Transaction Container Processing'"); // TFS 41613
		information.addTruncated("ImEx and Contents Status automatically changed to " &amp; app.getErrorString(Export).toUpper() &amp; " and " &amp; app.getErrorString(PackAs_FCL).toUpper()); // TFS 41613
		pxyTi.createInfomationTransaction("Automatic Status Change", information, null, app.myPassport);
	endif;

	inheritMethod(pTI, _tiTransCntrl);
	//cnwjo3 par 20707
	self.location := pTI.locationId;
	if _tiTransCntrl.myBulkRelease &lt;&gt; null then //08/09/2016 cnwma1 TFS #2589
		self.documentName :=_tiTransCntrl.myBulkRelease.code;
		self.documentContext :=  app.releaseRequestTypeEnumToString( _tiTransCntrl.myBulkRelease.type );
	endif;

epilog
	delete information;
end;
</source>
        <Parameter name="pTI" type="CM_TrackedItem"/>
        <Parameter name="_tiTransCntrl" type="CMIF_TITransactionController"/>
    </JadeMethod>
    <JadeMethod name="updateTI" id="50e598dc-1dd6-4277-970f-e4c746fcc1de">
        <updating/>
        <source>updateTI(_passport: CM_Passport input) updating;
// --------------------------------------------------------------------------------
// Created:		7 August 2009 by cnwjo3
//
// Purpose:		Creating updateTI so that when this transaction occurs we can set the
//				ti's packDT.  Originally it was set in CM_Pack but now in CM_Pack
//				it only sets the packDT for the child item, not parent
//				par 20271
//
vars
	tmpTI	: CM_TrackedItem;
begin
	inheritMethod(_passport);			//cnwmc5 - 17 April 2015 - PAR 35925
	
	tmpTI := self.myTrackedItem;
	
	if tmpTI = null then
		return;
	endif;
	
	tmpTI.setPackedDT(self.dateTime);
	///tmpTI.setUnpackedDT(null);		// 32065 keep the unpack date for reporting/selector query
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
</Class>
