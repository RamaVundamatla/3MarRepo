    <JadeMethod name="isBerthVisibleOnView" id="fcc01328-258c-4955-8368-1bff0104269e">
        <source>isBerthVisibleOnView() : Boolean;
//--------------------------------------------------
// Created:	16 June 2005 By: cnwgd1
//--------------------------------------------------
vars

begin
	if self.myBerth &lt;&gt; null then
		if self.myBerth.isLogicalBerth() then
			if self.myBerth.myWharf &lt;&gt; null then
				return self.myBerth.myWharf.isVisibleOnView;
			endif;
		else
			// always return true if wharf not logical
			// so that berth marks will be calculated
			return true;
		endif;
	endif;
	return false;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isCancelled" id="72573db6-ba4e-456f-815b-bbd5800531cd">
        <source>isCancelled():Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 November 2018	jlgndl1	Initial creation	TFS 42043

*/

vars

begin

	if self.myPersistentMovement &lt;&gt; null then
		return self.myPersistentMovement.isCancelled();
	endif;
	
	if self.moveType.isOneOf( HMSMovementTypeCanceledArrival, HMSMovementTypeCanceledShift, HMSMovementTypeCanceledDepart ) then
		return true;
	endif;

	return false;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isLogicalBerth" id="7f66053b-7d7a-498b-b88f-61ed628d3f98">
        <source>isLogicalBerth() : Boolean;
//--------------------------------------------------
// Created:	23 July 2004 By: cnwgd1
//--------------------------------------------------
vars

begin
	if self.myBerth &lt;&gt; null then
		return self.myBerth.isLogicalBerth();
	endif;
	return true;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="movement_CheckDateIsValid" id="0728e2d8-3fad-4897-9650-e86fc4fd8f3d">
        <updating/>
        <source>movement_CheckDateIsValid(movementType:String; moveDate: Date; moveTime: Time; selectedVoyage: CMIF_HMS_WorkingVoyage):Boolean updating;


vars
   	moveToCheck:	CMIF_HMS_WorkingMovement;
   	arrvMove:		CMIF_HMS_WorkingMovement;
   	deptMove:		CMIF_HMS_WorkingMovement;
   	msgBoxType:		Integer;
   	moveDT:			TimeStamp;
begin
	moveDT:=(moveDate.String &amp; "," &amp; moveTime.String).TimeStamp;
 	// This method checks that the movement date is valid

 	if movementType=HMSMovementTypeArrival then
 		// Arrival Movement - must occur before all other movements
 		arrvMove:=selectedVoyage.allWorkingMovements.first;
 		// Get first movement in voyage.allWorkingMovements collection directly after the arrival movement
 		moveToCheck:=selectedVoyage.allWorkingMovements.getAtKeyGtr(arrvMove.occursOnDT);
        if moveToCheck.occursOnDT&lt;moveDT then
        	// Error - arrival movement must occur before all other movements
        	msgBoxType:=MsgBox_OK_Only+MsgBox_Exclamation_Mark_Icon+MsgBox_Default_First;
			app.msgBox(app.getErrorString(MSGBOX_ArrvDTError), app.getErrorString(MSGBOX_MoveDTInvalidTitle), msgBoxType);
			return false;
        endif;
        return true;
	elseif movementType=HMSMovementTypeShift then
 		// Shift Movement - must occur after arrival and before departure movements
 		if moveDT&lt;selectedVoyage.arrivedDT then
 			// Error - The shift movement cannot occur before the arrival movement
 			msgBoxType:=MsgBox_OK_Only+MsgBox_Exclamation_Mark_Icon+MsgBox_Default_First;
			app.msgBox(app.getErrorString(MSGBOX_ShiftADTError), app.getErrorString(MSGBOX_MoveDTInvalidTitle), msgBoxType);
			return false;
 		elseif moveDT&gt;selectedVoyage.departedDT then
 			// Error - The shift movement cannot occur after the departure movement
 			msgBoxType:=MsgBox_OK_Only+MsgBox_Exclamation_Mark_Icon+MsgBox_Default_First;
			app.msgBox(app.getErrorString(MSGBOX_ShiftDDTError), app.getErrorString(MSGBOX_MoveDTInvalidTitle), msgBoxType);
			return false;
 		endif;
 		return true;
	elseif movementType=HMSMovementTypeDeparture then
		// Departure Movement - must occur after all other movements
		deptMove:=selectedVoyage.allWorkingMovements.last;
 		// Get first movement in voyage.allWorkingMovements collection directly before the departure movement
 		moveToCheck:=selectedVoyage.allWorkingMovements.getAtKeyLss(deptMove.occursOnDT);
        if moveToCheck.occursOnDT&gt;moveDT then
        	// Error - departure movement must occur after all other movements
        	msgBoxType:=MsgBox_OK_Only+MsgBox_Exclamation_Mark_Icon+MsgBox_Default_First;
			app.msgBox(app.getErrorString(MSGBOX_DeptDTError), app.getErrorString(MSGBOX_MoveDTInvalidTitle), msgBoxType);
			return false;
        endif;
        return true;
 	endif;

end;</source>
        <Parameter name="movementType" type="String"/>
        <Parameter name="moveDate" type="Date"/>
        <Parameter name="moveTime" type="Time"/>
        <Parameter name="selectedVoyage" type="CMIF_HMS_WorkingVoyage"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="newMovementAsClone" id="ecfb0450-2a28-45e4-b1f7-be0c698115dc">
        <updating/>
        <source>newMovementAsClone(_clonedVoyage: CMIF_HMS_WorkingVoyage; _movementType: String; moveDT: TimeStamp; _viewController : CMIF_HMS_ViewController) updating;
//14 Sep 2022 navgm20	ChangeRequest 54739: EUP - PLAN - Berth planning by bollards

vars
	arrvMove:			CMIF_HMS_WorkingMovement;
	nextMove:			CMIF_HMS_WorkingMovement;
	numOfHours:			Integer;
	defaultDTForMove:	TimeStamp;
	defaultTideClass:	HMS_TidalClass;	// Modified by Russell 29/03/99
	agent:				CM_ShippingAgent;
	shippingLine:		CM_ShippingLine;
	agentIsDefault:		Boolean;
	contact:			CM_EmailAddress2;
	pLaunchLocation:	Integer;
	tugsLocation:		Integer;
	timePilot:			Integer;
	timeTugs:			Integer;
	timeLines:			Integer;
	
begin
 	// This method populates a new movement in the fashion of a clone
 	// ADD mode:
 	// Set key properties for new movement	
	self.notYetSaved := true;
	self.moveType := _movementType;

 	// Set move occursOnDT if not supplied
	arrvMove := _clonedVoyage.allClonedMovements.first;
	if arrvMove &lt;&gt; null then
		nextMove := _clonedVoyage.allClonedMovements.getAtKeyGtr(arrvMove.occursOnDT);
	endif;
	
 	if (not moveDT.isValid())
 	and arrvMove &lt;&gt; null
 	and nextMove &lt;&gt; null then
 		// Set default DT to be half way between the arrival movement and the next movement for the voyage
		// Calculate the number of hours between the arrival move and the next move for the voyage
		numOfHours := arrvMove.occursOnDT.differenceInHours(nextMove.occursOnDT);
		
		// if the length of stay is less than two days then set the movement time to be
		// the arrival time + one hour, otherwise problems occur when trying to set date and time
		defaultDTForMove := arrvMove.occursOnDT.changeByXXHours((numOfHours/2).Integer);
	else
		defaultDTForMove := moveDT;
	endif;
	
	self.occursOnDT := defaultDTForMove;

	// Add movement to collections
	self.myWorkingVoyage := _clonedVoyage.ofClonedVoyage;
	self.myClonedVoyage := _clonedVoyage;
	self.myClonedMovement := null;
	self.myHarbour := _clonedVoyage.ofHarbour;
	self.myPersistentMovement := null;
	self.myViewController := _viewController;
	
	if self.myWorkingVoyage &lt;&gt; null then
		self.myHMSVoyageData := self.myWorkingVoyage.myHMSVoyageData;
		if self.myHMSVoyageData = null then
			self.myHMSVoyageData := self.myWorkingVoyage.ofPermanentVoyage.myHMSVoyageData;
		endif;
	endif;
	// Set initialise values
    // ------------------------------------------------------------------------------

    // Orientation
	if arrvMove &lt;&gt; null then
		self.sideTo := arrvMove.sideTo;
		if nextMove &lt;&gt; null
		and nextMove.moveType = HMSMovementTypeShift then
			// default to original arrival berth
			self.myBerth := arrvMove.myBerth;
			self.bowMarkTo := arrvMove.bowMarkTo;
			self.sternMarkTo := arrvMove.sternMarkTo;
			//21/09/2022 navgm20 TFS 54739- Start
			self.myBowBollard := arrvMove.myBowBollard;
			self.mySternBollard := arrvMove.mySternBollard;
			self.myBridgeBollard := arrvMove.myBridgeBollard;
			self.bowToBollard	:= arrvMove.bowToBollard;
			self.sternToBollard	:= arrvMove.sternToBollard;
			self.bridgeToBollard := arrvMove.bridgeToBollard;
			//21/09/2022 navgm20 TFS 54739- End
		else
			// next move is a departure self.init_Berth() will set berth default berth		
		endif;
	else
		self.sideTo := self.init_Orientation;	
	endif;

	// Set default berth
	if self.myBerth = null then
		self.myBerth := self.init_Berth;
	endif;

	// Number of lines crew
	self.numLineCrewRequired := self.init_NumLinesCrewReqd;

	// Set default tidal class for movement
	self.myMoveTidalClass := self.init_MoveTidalClass;

	// Set pilot exempt status
	self.pilotExempt := self.init_IsPilotExempt;

	// Set pilot launch PAR 10455 do not default to first pilot launch
	//self.myPilotLaunch := self.init_PilotLaunch;

	// Set pilot PAR 10455 do not default to first pilot
	//self.myPilot := self.init_Pilot;

	// Set line company PAR 10455 do not default to first line company
	//self.myLineCompany := self.init_LineCompany;

	// Set customer for movement
	self.init_CustomerForMove(agent, shippingLine, agentIsDefault, contact);
	self.myShippingAgent := agent;
	self.myShippingLine := shippingLine;
	self.isAgentDefault := agentIsDefault;
	self.myContact := contact;
	
	if arrvMove &lt;&gt; null then
		if self.myShippingLine = null then
			self.myShippingLine := arrvMove.myShippingLine;
		endif;
		if self.myShippingAgent = null then
			self.myShippingAgent := arrvMove.myShippingAgent;
		endif;		
	endif;
	
	self.chargeForMove := (self.myShippingAgent &lt;&gt; null or self.myShippingLine &lt;&gt; null);

	// Set Marine Service order locations (Pilot Launch, Tugs)
	self.init_MarineServOrderLocations(pLaunchLocation,tugsLocation);
	self.locationPilotLaunch := pLaunchLocation;
	self.locationTug := tugsLocation;


	// Set relative order times for marine services
	self.init_MarineServOrderTimes(timePilot,timeTugs,timeLines);
	self.relativeOrderTimeLines := timeLines;
	self.relativeOrderTimePlaunch := timePilot;
	self.relativeOrderTimeTugs := timeTugs;

	// Create default resourcesUsed objects
	self.createResourcesUsed();
	
	self.createPxyMarineServiceTimings( null );	//19 Jun 2018	NDL	TFS 39215
	
end;</source>
        <Parameter name="_clonedVoyage" type="CMIF_HMS_WorkingVoyage"/>
        <Parameter name="_movementType" type="String"/>
        <Parameter name="moveDT" type="TimeStamp"/>
        <Parameter name="_viewController" type="CMIF_HMS_ViewController"/>
    </JadeMethod>
    <JadeMethod name="raiseClearanceWarnings" id="e157a26a-a60c-4076-9978-4a3387a3849d">
        <source>raiseClearanceWarnings() : Boolean;
//--------------------------------------------------
// Created:	15 June 2005 By: cnwgd1
//--------------------------------------------------
vars
	checkWarnPeriod : Boolean;
	warnDT : TimeStamp;
begin

	checkWarnPeriod := self.myHarbour.checkWarningPeriod(warnDT);

	if checkWarnPeriod then
		if self.occursOnDT &gt; warnDT then
			//CCMS 1011 only raise clearnace warnings if movement is within warn period
			return false;
		endif;
	endif;
	
	return true;	 	 	

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="requiresMarineServices" id="f028665c-e789-4042-8132-6d5d21f4b288">
        <methodInvocation>mapping</methodInvocation>
        <source>requiresMarineServices(set: Boolean; _value: Boolean io) mapping;
//Determine if we need marine services (pilot and tugs) based on where we
//are going from and to
//
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------------------
// 05/02/2014	cnwdap1		PAR #33337 CCMS PTR 2214 Also check if we're going to somewhere that requires marine services
vars
   priorMove : CMIF_HMS_WorkingMovement;
   nextMove	 : CMIF_HMS_WorkingMovement;					// PAR #33337
begin
	if set = false then
   		if self.myBerth &lt;&gt; null and self.myBerth.noMarineServices = true then	
   			//Don't need MS to go here
   			_value := false;
   			priorMove := self.getMovementPrevious;

   			if priorMove &lt;&gt; null 
   			and priorMove.myBerth &lt;&gt; null 
   			and priorMove.myBerth.noMarineServices = false then
   				//We are moving from somewhere that requires MS
   				_value := true;
   			endif;
			
			nextMove := self.getMovementNext();						// PAR #33337
			if nextMove &lt;&gt; null 									// PAR #33337
			and nextMove.myBerth &lt;&gt; null 							// PAR #33337
			and nextMove.myBerth.noMarineServices = false then		// PAR #33337
				// we are moving to somewhere that requires MS		// PAR #33337
				_value := true;										// PAR #33337
			endif;													// PAR #33337
   		else
   			_value := true;		//By default we DO need MS
   		endif;
	endif;
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Boolean" usage="io"/>
    </JadeMethod>
