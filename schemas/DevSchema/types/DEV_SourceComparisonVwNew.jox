        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>qlbClassData_keyDown(listbox: CM_QueueListBox input; keyCode: Integer io; shift: Integer) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 December 2024	navpw1	Initial creation

*/

begin
	if keyCode = J_key_RightArrow then
		listbox.expandItem(listbox.listIndex);
	elseif keyCode = J_key_LeftArrow then
		listbox.itemExpanded[listbox.listIndex] := false;
	endif;
	
end;</source>
        <Parameter name="listbox" type="CM_QueueListBox" usage="input"/>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="qlbDifferentMethods_click" id="15b89e21-bc62-46f3-a030-b9a678ce5245">
        <controlMethod name="CMUI_ListBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>qlbDifferentMethods_click(listbox: ListBox input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 December 2024	navpw1	Initial creation

*/

vars
	currentClass	: DEV_Class;
	cm_Method		: DEV_Method;
	level 			: Integer;
	
begin
	if listbox.text &lt;&gt; null then
		level := listbox.itemLevel[listbox.listIndex];
		if level = 3 then
			cm_Method := listbox.itemObject[listbox.listIndex].DEV_Method;
			self.loadedMethod := cm_Method;
			self.compareMethod(cm_Method);
			listbox.setFocus();
			
			if self.isWinMergeAvailable then
				self.btnOpenInWinMerge.enabled := true;
			endif;
			
			if self.isNppAvailable then
				self.btnOpenInNpp.enabled := true;
			endif;
			
		endif;
	endif;
	
end;</source>
        <Parameter name="listbox" type="ListBox" usage="input"/>
    </JadeMethod>
