    <JadeMethod name="addRowToTable" id="dc7fc6fa-1fe1-4f95-a87d-29173e9615c4">
        <source>addRowToTable(_ownership : CM_OwnershipChange);
/*
Purpose:			

Date		Who		Reason
20 June 2023 navtnr20	TFS CR 58224	Task 58225: UI - Change of Ownership Enquiry
*/

vars
	theDataLine : String;
	
begin
		theDataLine := _ownership.getAttributeStringForDefArray(self.tblData.allTblDataEntRows);
		self.tblData.accessRow(self.tblData.addItem(theDataLine)).itemObject := _ownership;
		self.doNotableAdd(_ownership);	//navtnr20 12-07-2023 58237
epilog

end;</source>
        <Parameter name="_ownership" type="CM_OwnershipChange"/>
    </JadeMethod>
    <JadeMethod name="btnAdd_click" id="f28cd1f7-3514-4683-af8b-9cf9ffaaadea">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnAdd_click(btn: Button input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 July 2023 navtnr20	TFS CR 58233	Task 58235: UI - Change of Ownership Maint
*/

vars
	form : CMUI_OwnershipChangeMaint;
	
begin
	form := app.loadForm(CMUI_OwnershipChangeMaint, CMUI_Assistant, false, false,false, self.myTerminal,null).CMUI_OwnershipChangeMaint;
	if form &lt;&gt; null then
		form.updateMode	:= false;
		form.btnRemove.enabled := false;
		form.btnAddItems.enabled := false;
		form.btnUpdate.enabled := false;
		form.btnAttachment.enabled := false;
		form.btnApprove.enabled	:= false;
		form.btnInvoiceIssus.enabled := false;
		form.btnAudits.enabled := false;
		//form.txtFilCOODetail.enabled := false; //25/06/2024	navkc1 CR 64823 Task 64824
		form.centreWindow();
		self.myMaintForm := form; // ### TFS BUG 64115 13MAY2024 NAVAB1
		form.myEnquiryForm := self; // ### TFS BUG 64115 13MAY2024 NAVAB1
		form.show(); // ### TFS BUG 64115 13MAY2024 NAVAB1   .showModal;
	endif;
epilog

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
