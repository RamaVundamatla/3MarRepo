<Class name="Script">
    <JadeMethod name="jssSetSource" id="694c2110-bdb0-42d7-9618-23c8638a3d6f">
        <updating/>
        <source>jssSetSource(pSource:String) updating;
// --------------------------------------------------------------------------------
// Created:		16 August 2001 by cnwdad1
//
// Purpose:		Updates the source of the receiver.
//
// Parameters:	pSource - The receiver's (new) source.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.source &lt;&gt; pSource then
		self.source	:=	pSource;
	endif;
end;</source>
        <Parameter name="pSource" type="String"/>
    </JadeMethod>
</Class>
