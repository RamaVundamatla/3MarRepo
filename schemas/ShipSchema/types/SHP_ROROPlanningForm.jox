    <JadeMethod name="initScrollableFrame" id="afa69f34-1ec3-468f-be79-63ff40f83492">
        <updating/>
        <source>initScrollableFrame(_sdf : CMUI_ScrollableDrawingFrame input; _scale : Decimal; _frames : ObjectArray ) updating;
/*
Purpose:			
Date		Who		Reason
03 June 2011	cnwab1	Initial creation
*/

vars

begin
	//_sdf.setConfig(self.myConfig.CMIF_ConfigUserVoyagePlanning);
	_sdf.myDrawingFrame.transparent := true;
	_sdf.myDrawingFrame.backColor := Red;
	_sdf.myDrawingFrame.name := "ROROPLAN"; //##### DO NOT TRANSLATE
	_sdf.myDrawingFrame.CMUI_PointDrawingFrame.mode := CMUI_PointDrawingFrame.Mode_Work; //Mode_Work;
	_sdf.transparent := true;
	_sdf.myHLabels.backColor := _sdf.backColor;
	_sdf.myVLabels.backColor := _sdf.backColor;
	_sdf.myVLabels.visible := true;
	_sdf.caption := null;
	
	_sdf.myTopLeftFillerFrame.autoRedraw := true;
	_sdf.myTopLeftFillerFrame.drawPictureAt(self.picJade.picture,0,0);
	_sdf.myTopLeftFillerFrame.backColor := White;
	_sdf.myTopLeftFillerFrame.visible := true;
	_sdf.myTopLeftFillerFrame.move(0,0,50,50);
	
	
	_sdf.myParentForm := self;
	_sdf.myHLabels.zOrder(1);
	_sdf.myVLabels.zOrder(1);

//	self.frameLabelLineH.zOrder(1);
//	self.frameLabelLineV.zOrder(1);
	_sdf.myHScroll.zOrder(1);
	_sdf.myVScroll.zOrder(1);
	_sdf.myTopLeftFillerFrame.zOrder(1);
	// PAR 27513
//	self.frameLabelLineH.ignoreSkin := true;
//	self.frameLabelLineV.ignoreSkin := true;
	_sdf.myHLabels.ignoreSkin := true;
	_sdf.myVLabels.ignoreSkin := true;
	_sdf.myTopLeftFillerFrame.ignoreSkin := true;
	
//	self.doDrawLabelV();
//	self.doDrawLabelH();
//	self.initFrmLabelLine();
	self.setScale(_scale, _sdf, _frames);

epilog

end;</source>
        <Parameter name="_sdf" type="CMUI_ScrollableDrawingFrame" usage="input"/>
        <Parameter name="_scale" type="Decimal"/>
        <Parameter name="_frames" type="ObjectArray"/>
    </JadeMethod>
    <JadeMethod name="keyDown" id="b5234ee1-811c-421b-9aaa-894577274c62">
        <controlMethod name="Form::keyDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>keyDown(keyCode: Integer io; shift: Integer) updating;
/*
Purpose:			
Date		Who		Reason
07 February 2012	cnwab1	Initial creation
*/

vars

begin


	if keyCode = CMUI_Key_F4 then
		if not app.isControlKeyDown()
		and not app.isAltKeyDown()
		and not app.isShiftKeyDown()
		then
			self.showHideTipsFrame();
		endif;
	else
		inheritMethod(keyCode, shift);
	endif;
epilog

end;</source>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
