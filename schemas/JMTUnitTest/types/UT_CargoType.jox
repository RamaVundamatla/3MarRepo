<Class name="UT_CargoType" id="29329603-1248-43e4-81b1-d584de55f1b2">
    <superclass name="UT_DSL"/>
    <transient/>
    <sharedTransientAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="unitTest"/>
    <JadeMethod name="assignedTeam" id="b2c48252-52ed-4944-9e39-0061d37422b1">
        <options>4</options>
        <source>assignedTeam(): String typeMethod;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 March 2025	navsp1	Initial creation JIRA-34202

*/

vars

begin
	return UT_UnitTest.Team_Mohamed;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="deleteUnitTestFiles" id="6d18c0e0-1ff7-4a04-b2ef-75d2d9045c3f">
        <source>deleteUnitTestFiles(_cargoTypeAbbr : String);
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
25 February 2022	navpw1	Initial creation TFS: 52821

*/

vars
	cargoType 	: CM_CargoType;
	fileData	: CM_FileData;
	
begin
	cargoType := getRoot.getCargoTypeFromAbbrevOrDescr(_cargoTypeAbbr);
	beginTransaction;
	foreach fileData in cargoType.allFiles do
		delete fileData;
	endforeach;
	commitTransaction;
	
epilog

end;</source>
        <Parameter name="_cargoTypeAbbr" type="String"/>
    </JadeMethod>
