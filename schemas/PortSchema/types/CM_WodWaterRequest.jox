    <JadeMethod name="validateForUpdate" id="eb269a7a-26b4-4426-ad59-5c8537831293">
        <source>validateForUpdate();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 May 2018	jlgndl1	Initial creation	TFS 38560

*/

vars

begin
	inheritMethod();
	
	if self.myHMSResource = null then
		app.raiseCMException(Input_require_resourc_field, null, null);
	endif;
	
	if self.myHMSResourceType = null then
		app.raiseCMException(Input_required_field_resorceTy, null, null);
		
	else
		if self.myHMSResourceType.isFromToDateTimeRequired then
			if not self.fromDateTime.date.isValid then
				app.raiseCMException(ERR_Valid_From_DT, null, null);
			endif;
			if not self.toDateTime.date.isValid then
				app.raiseCMException(Input_required_field_dateTo, null, null);
			endif;
	
		endif;
		
		if self.myHMSResourceType.isQuantityRequired then
			if self.unitsUsed &lt;= 0 then
				app.raiseCMException(Input_required_field_untsUsed, null, null);
			endif;
			
		endif;
		
		if self.myHMSResourceType.isActionDateTimeRequired then
			if not self.fromDateTime.date.isValid then
				app.raiseCMException(ERR_Valid_From_DT, null, null);
			endif;
			
		endif;
		
	endif;
	
epilog

end;</source>
    </JadeMethod>
</Class>
