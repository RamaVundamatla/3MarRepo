    <JadeMethod name="getTheSelectedJob" id="5a3dfe80-37cb-4ac1-985e-f48c3eb57fe7">
        <source>getTheSelectedJob() : CM_VoyageJob protected;
// ---------------------------------------------------------------------------
// Created:		April 2003 By Andrew Bishop cnwab1
//
// Purpose:		the job id may not be in the combo cos it has not been allocated to the crane so go to the point to get the job id
// ---------------------------------------------------------------------------
vars
	theJob 		: CM_VoyageJob;
	theSlot		: CM_SlotController;
	theROROSlot : CM_ROROSlotController;
	theRequest	: CM_Request;
	theObj		: Object;
	
begin

	theObj := self.myROROPlanDrawController.allSelectedObjects.first;
	if theObj = null then
		return null;
	endif;

	if theObj.isKindOf(CM_SlotController) then	
		theSlot := theObj.CM_SlotController;
		if self.modeView = ShpDisplayMode_ColCodeDisch then
			theRequest := theSlot.mySlotRequestDischarge;
		else
			theRequest := theSlot.mySlotRequestLoad;
		endif;
		if theRequest &lt;&gt; null then
			theJob := theRequest.myJob.CM_VoyageJob;
		endif;
	elseif theObj.isKindOf(CM_ROROSlotController) then	
		theROROSlot := theObj.CM_ROROSlotController;
		if self.modeView = ShpDisplayMode_ColCodeDisch then
			theRequest := theSlot.mySlotRequestDischarge;
		else
			theRequest := theSlot.mySlotRequestLoad;
		endif;
		if theRequest &lt;&gt; null then
			theJob := theRequest.myJob.CM_VoyageJob;
		endif;
	endif;

	return theJob;

end;</source>
        <access>protected</access>
        <ReturnType type="CM_VoyageJob"/>
    </JadeMethod>
    <JadeMethod name="getWlesForSelectedArea" id="1e1e4331-abee-4c67-abf9-410a307f94d0">
        <source>getWlesForSelectedArea( _wles : CM_WLEArray input);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 April 2012	cnwndl1	Initial creation	Par 29405

*/

vars

	anObj : Object;
	aReq : CM_RORORequest;
	tmpWLE : CM_WorkListEntry;
	otherRoRoLocn : CM_ROROLocnDefn;
	otherRoRoLocnVoy : CM_ROROLocnDefnVoyage;
	slotDefn : CM_ROROSlotDefn;
	slotDefnVoy : CM_ROROSlotDefnVoyage;
	isLoad, is40 : Boolean;

begin

	foreach anObj in self.myROROPlanDrawController.allSelectedObjects do
		if anObj.isKindOf(CM_RORORequest) then
			aReq := anObj.CM_RORORequest;
			if aReq.myJob = null then
				continue;
			endif;
//			is40 := (aReq.getAttrIs40() or aReq.getAttrIs30() or aReq.getAttrIs45() or aReq.getAttrIs53()); // PAR 30022 
			is40 := aReq.getAttrIsNOT20(); // PAR 30253
			if is40 then // PAR 30022 
//			if aReq.getAttrIs40() then
				isLoad := aReq.isReleaseType;
				otherRoRoLocn := aReq.getAftLocnDefn;
				if otherRoRoLocn.isKindOf(CM_ROROLocnDefnVoyage) then
					otherRoRoLocnVoy := otherRoRoLocn.CM_ROROLocnDefnVoyage;
				endif;
			endif;
			foreach tmpWLE in aReq.allWorkListEntries discreteLock do
				_wles.add( tmpWLE );
			endforeach;
			
			// PAR 30792
			if otherRoRoLocnVoy &lt;&gt; null then	
				foreach slotDefn in otherRoRoLocnVoy.allROROSlotDefnByOrdinal discreteLock do
					if not slotDefn.isKindOf(CM_ROROSlotDefnVoyage ) then
						continue;
					else
						slotDefnVoy := slotDefn.CM_ROROSlotDefnVoyage;
					endif;
					if slotDefnVoy.mySlotController = null then
						continue;
					endif;
					aReq := null;
					if isLoad then
						aReq := slotDefnVoy.mySlotController.myRORORequestLoad;
					else
						aReq := slotDefnVoy.mySlotController.myRORORequestDischarge;
					endif;
					if aReq = null then
						continue;
					endif;
					foreach tmpWLE in aReq.allWorkListEntries discreteLock do
						if not _wles.includes( tmpWLE ) then
							_wles.add( tmpWLE );
						endif;
					endforeach;
				
				endforeach; 
			endif;	
		endif;
	endforeach;
	
/*	PAR 30792 moved up into the loop	
	if otherRoRoLocnVoy &lt;&gt; null then	
		foreach slotDefn in otherRoRoLocnVoy.allROROSlotDefnByOrdinal discreteLock do
			if not slotDefn.isKindOf(CM_ROROSlotDefnVoyage ) then
				continue;
			else
				slotDefnVoy := slotDefn.CM_ROROSlotDefnVoyage;
			endif;
			if slotDefnVoy.mySlotController = null then
				continue;
			endif;
			aReq := null;
			if isLoad then
				aReq := slotDefnVoy.mySlotController.myRORORequestLoad;
			else
				aReq := slotDefnVoy.mySlotController.myRORORequestDischarge;
			endif;
			if aReq = null then
				continue;
			endif;
			foreach tmpWLE in aReq.allWorkListEntries discreteLock do
				if not _wles.includes( tmpWLE ) then
					_wles.add( tmpWLE );
				endif;
			endforeach;
		
		endforeach; 
	endif;	
*/
epilog

end;</source>
        <Parameter name="_wles" type="CM_WLEArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getXMLSettingsForSave" id="e70e6fc4-f1e0-4000-a78d-a0caf5adaed6">
        <updating/>
        <source>getXMLSettingsForSave(): String updating;
// ---------------------------------------------------------------------------
// Created:		June 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars

	xmlStr	: String;
//	entRow	: EntTableRow;	
begin
	xmlStr := inheritMethod();

	xmlStr := xmlStr &amp; global.formatAsXML(XML_TagShowExports,self.btnViewExport.value.Integer.String);

	return xmlStr;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="giveCustSeqNeedSaveWarning" id="50bb4f5a-3cce-42ed-99d9-3378aebde46c">
        <updating/>
        <source>giveCustSeqNeedSaveWarning(_frame: SHP_BayDrawingFrame input;
			_slot : CM_SlotController;
			button: Integer; shift: Integer; x: Real; y: Real) : Boolean updating, protected;
// ---------------------------------------------------------------------------
// Created:     17 August 2004 by cnwrs2
//
// Purpose:     returns TRUE if can carry on with action that triggered this call
// ---------------------------------------------------------------------------

vars
	rtnCode			: Integer;
	theCurrentJob	: CM_VoyageJob;
	tmpStr			: String;
	invalidJob 		: Boolean;
begin
	//14/02/2011 cnwdz2 par26989
	on Exception do app.handleDeletedObject(exception, theCurrentJob, invalidJob);

	if self.modeWork &lt;&gt; self.WorkMode_CustomSeq or 
	   (not self.hasChanged) then
		return true;
	endif;

	theCurrentJob := self.myCurrentJob; 

	if theCurrentJob = null then
		return true;
	endif;

	tmpStr := app.getErrorString1(Have_update_sequen_have_not,theCurrentJob.jobNum) &amp; CrLf &amp;
			  app.getErrorString(Saved_these_changes) &amp; CrLf &amp; CrLf &amp;
			  app.getErrorString(Select) &amp; ":" &amp; CrLf &amp;
			  app.getErrorString(Yes_save_these_changes) &amp; CrLf &amp; CrLf &amp;
			  app.getErrorString(Not_save_these_changes) &amp; CrLf &amp; CrLf &amp;
			  app.getErrorString(Cancel_not_save_these_changes);
	
	//14/02/2011 cnwdz2 par26989 start
	if invalidJob then
		return true;
	endif;
	//14/02/2011 cnwdz2 par26989 end
	
	rtnCode := app.msgBox(tmpStr, app.getErrorString(Sequencing) &amp; " " &amp; app.getErrorString(Error), MsgBox_Yes_No_Cancel);

	if rtnCode = MsgBox_Return_Yes then
		app.mousePointer := MousePointer_HourGlass;
//		self.doSaveSequence();
		app.mousePointer := MousePointer_Default;
		
		return true;

	elseif rtnCode = MsgBox_Return_No then
		self.hasChanged := false;
		// the user wants to throw away any changes to the
		// existing job.
//		self.doPicSeqUndoClick();
//		self.currentSeqNumber := 0;
		theCurrentJob := null;

		if _frame &lt;&gt; null then
			// need to call the handleMoueseUp as the display of
			// the message box here prevents this from firing
			_frame.handleMouseUp(_slot, button, shift, x, y);
		endif;

		return true;
	else
		// rtnCode = MsgBox_Return_Cancel
		return false;
	endif;

epilog
	app.mousePointer := MousePointer_Default;

end;</source>
        <access>protected</access>
        <Parameter name="_frame" type="SHP_BayDrawingFrame" usage="input"/>
        <Parameter name="_slot" type="CM_SlotController"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="hideCCP" id="eeaede8e-bf1c-48d2-87d2-9d4c99321b02">
        <updating/>
        <source>hideCCP(_unload : Boolean) updating;

// ---------------------------------------------------------------------------
// Created:     MARCH 2010 ANDREW BISHOP
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	invalidProcess : Boolean;
begin
	on Exception do app.handleDeletedObject(exception, self.myCCPalette, invalidProcess); // PAR 34069
	on Exception do app.handleDeletedObject(exception, self.myCCPaletteLoad, invalidProcess); // PAR 34069
	on Exception do app.handleDeletedObject(exception, self.myCCScreen, invalidProcess); // PAR 34069

	if _unload and self.myCCPalette &lt;&gt; null then
		self.myCCPalette.unloadForm();
	endif;
	//24 Jan 2012	NDL	Par 28896
	if _unload and self.myCCPaletteLoad &lt;&gt; null then
		self.myCCPaletteLoad.unloadForm();
	endif;
	
	self.myCCPalette := null;
	self.myCCPaletteLoad := null;	//24 Jan 2012	NDL	Par 28896
	
	if self.myCCScreen &lt;&gt; null and self.myConfig.shipCCLinkPaletteAttributes then
		self.myCCScreen.unloadForm();
		self.myCCScreen := null;
	endif;
epilog

end;</source>
        <Parameter name="_unload" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="hideLAC" id="6d772ef4-4a96-4a07-9016-205179618845">
        <updating/>
        <source>hideLAC(_unload : Boolean) updating;

// ---------------------------------------------------------------------------
// Created:     MARCH 2010 ANDREW BISHOP
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

	invalidProcess : Boolean;
begin
	on Exception do app.handleDeletedObject(exception, self.myCCPalette, invalidProcess); // PAR 34069
	on Exception do app.handleDeletedObject(exception, self.myCCPaletteLoad, invalidProcess); // PAR 34069
	on Exception do app.handleDeletedObject(exception, self.myCCScreen, invalidProcess); // PAR 34069
	
	if self.myCCScreen &lt;&gt; null and _unload then
		self.myCCScreen.unloadForm();
	endif;
	
	self.myCCScreen := null;
	
	if self.myCCPalette &lt;&gt; null and self.myConfig.shipCCLinkPaletteAttributes then
		self.myCCPalette.unloadForm();
		self.myCCPalette := null;
	endif;
	//24 Jan 2012	NDL	Par 28896
	if self.myCCPaletteLoad &lt;&gt; null and self.myConfig.shipCCLinkPaletteAttributes then
		self.myCCPaletteLoad.unloadForm();
		self.myCCPaletteLoad := null;
	endif;
epilog

end;</source>
        <Parameter name="_unload" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="initCmbCrane" id="93260cbd-2932-43ac-90fb-3de061c94e11">
        <source>initCmbCrane() protected;
/*
Purpose:			
Date				Who			Reason
AUGUST 2011		CNWAB1		Initial creation
*/

vars

	aVoyage : CM_Voyage;
	idx : Integer;
	theVoyageJS : CM_VoyageJobSheet;
	aCrane : CM_Machine;
	wp : CM_WorkPoint;
begin
	
	self.cmbWorkPoint.clear;
	
	self.cmbWorkPoint.sorted := true;
	
	self.cmbWorkPoint.addItem(app.getErrorString(Unallocated_jobs));
	
	foreach wp in self.myTerminal.allWorkPointsByCode where not wp.isNotAvailableForEntry do
			idx := self.cmbWorkPoint.addItem(wp.code &amp; " - " &amp; wp.description);
			self.cmbWorkPoint.itemObject[idx] := wp;
	endforeach;
/*
	foreach aCrane in self.myTerminal.machines where not aCrane.isNotAvailableForEntry do
		if aCrane.machineType = MACHINETYPE_PORTAINER_CRANE then 
			idx := self.cmbWorkPoint.addItem(aCrane.id &amp; " - " &amp; aCrane.description);
			self.cmbWorkPoint.itemObject[idx] := aCrane;
		endif;
	endforeach;
	
*/
end;</source>
        <access>protected</access>
    </JadeMethod>
