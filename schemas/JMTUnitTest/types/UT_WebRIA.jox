    <JadeMethod name="tC3LogTrans1_OpnClsdLogRow" id="bc28b38d-745a-435b-888e-ccdcbeb2ac6e">
        <source>tC3LogTrans1_OpnClsdLogRow();
/*

Purpose:			Test for REST Api Method: MasterTerminalAPIService::putTransferRq
					Description: This is to test that logs can be moved to an open or closed log row when called from a web service

Parameters:			

Return Value:		

Date		Who		Reason
18 January 2022	navpw1	Initial creation TFS: 52572

*/

//1. //Tests that logs can be moved to an open and closed log row - No Errors

constants
	Ref						: String 	= UT_DSL.TFS52572;
	BOLNUMBER 				: String 	= "BOL5257201";
	NUMBOLITEMS				: Integer	= 5;
	
	TERMINAL 				: String	= "UT";
	SOURCELOGROWID 			: String	= "LGR2";
	TARGETLOGAREA 			: String	= "UTLOG";
	TARGETOPENLOGROWID 		: String	= "LGR3";
	TARGETCLOSEDLOGROWID 	: String	= "LGR4";
	USERCODE 				: String	= "UNITTEST";
	TILOG01 				: String	= "LOG" &amp; Ref &amp; "_1";
	TILOG02 				: String	= "LOG" &amp; Ref &amp; "_2";
	TILOG03 				: String	= "LOG" &amp; Ref &amp; "_3";
	TILOG04 				: String	= "LOG" &amp; Ref &amp; "_4";
	TILOG05 				: String	= "LOG" &amp; Ref &amp; "_5";
	
vars
	terminal 			: CM_Terminal;
	logArea 			: CM_LogArea;
	sourceLogRow,
	openLogRow,
	closedLogRow		: CM_LogController; //LogRow
	logController		: CMIF_LogController;
	tiLog01,
	tiLog02,
	tiLog03,
	tiLog04,
	tiLog05				: CM_TrackedItem;
	tisToProcess,
	errSet				: CM_TISet;
	
	utLogTests			: UT_LogTests;
	utBolIn				: CM_BOLIn;
	cmif_SourceLogRow,
	cmif_OpenLogRow,
	cmif_ClosedLogRow	: CMIF_LogRowRestriction;
	loopVar				: Integer;
	logId				: String;
	logArray			: StringArray;
	
begin
	app.setIsWebApp(true); //Need to execute our methods like we are a web app
	//Tests that logs can be moved to an open log row

	create utLogTests transient;
	create logArray transient;
	
	//Validate Supplied Terminal
	terminal := app.myRoot.allTerminals[TERMINAL];
	if terminal = null then
		self.assertTrueMsg(false, "[Pre Test Validation] Terminal : " &amp; TERMINAL &amp; " does not exist therefore test cannot continue"); //Terminal does not exist so fail
	endif;
	
	//Validate Supplied Log Area
	logArea := terminal.allTerminalAreasByTypeId[TA_TYPE_LOGAREA, TARGETLOGAREA].CM_LogArea;
	if logArea = null then
		self.assertTrueMsg(false, "[Pre Test Validation] Log Area : " &amp; TARGETLOGAREA &amp; " does not exist therefore test cannot continue"); //Log Area does not exist so fail
	endif;
	
	//Validate Source Open Log Row
	sourceLogRow := logArea.findLogRow(SOURCELOGROWID);
	if sourceLogRow = null then
		create cmif_SourceLogRow transient;
		cmif_SourceLogRow.myRowArea := logArea;
		cmif_SourceLogRow.id := SOURCELOGROWID;
		cmif_SourceLogRow.transport := 3;  // there is no constant
		cmif_SourceLogRow.status := LC_Status_Open;
		cmif_SourceLogRow.width := 12;  //see LOG_LogRowMaintForm :: setRowWidth();
		cmif_SourceLogRow.user := app.getMyUserCode;
		sourceLogRow := utLogTests.addLogRow(cmif_SourceLogRow);
		if sourceLogRow = null then
			self.assertTrueMsg(false, "[Pre Test Validation] Log Row : " &amp; SOURCELOGROWID &amp; " does not exist therefore test cannot continue"); //Log Row does not exist so fail
		endif;
	elseif sourceLogRow.status &lt;&gt; LC_Status_Open then
		self.assertTrueMsg(false, "[Pre Test Validation] Log Row : " &amp; SOURCELOGROWID &amp; ", This log row should have an 'Open' status"); //Log Row status is not open
	endif;
	
	//Validate Target Open Log Row
	openLogRow := logArea.findLogRow(TARGETOPENLOGROWID);
	if openLogRow = null then
		create cmif_OpenLogRow transient;
		cmif_OpenLogRow.myRowArea := logArea;
		cmif_OpenLogRow.id := TARGETOPENLOGROWID;
		cmif_OpenLogRow.transport := 3;  // there is no constant
		cmif_OpenLogRow.status := LC_Status_Open;
		cmif_OpenLogRow.width := 12;  //see LOG_LogRowMaintForm :: setRowWidth();
		cmif_OpenLogRow.user := app.getMyUserCode;
		openLogRow := utLogTests.addLogRow(cmif_OpenLogRow);
		if openLogRow = null then
			self.assertTrueMsg(false, "[Pre Test Validation] Log Row : " &amp; TARGETOPENLOGROWID &amp; " does not exist therefore test cannot continue"); //Log Row does not exist so fail
		endif;
	elseif openLogRow.status &lt;&gt; LC_Status_Open then
		self.assertTrueMsg(false, "[Pre Test Validation] Log Row : " &amp; TARGETOPENLOGROWID &amp; ", This log row should have an 'Open' status"); //Log Row status is not open
	endif;
	
	//Validate Target Closed Log Row
	closedLogRow := logArea.findLogRow(TARGETCLOSEDLOGROWID);
	if closedLogRow = null then
	create cmif_ClosedLogRow transient;
		cmif_ClosedLogRow.myRowArea := logArea;
		cmif_ClosedLogRow.id := TARGETCLOSEDLOGROWID;
		cmif_ClosedLogRow.transport := 3;  // there is no constant
		cmif_ClosedLogRow.status := LC_Status_Closed;
		cmif_ClosedLogRow.width := 12;  //see LOG_LogRowMaintForm :: setRowWidth();
		cmif_ClosedLogRow.user := app.getMyUserCode;
		closedLogRow := utLogTests.addLogRow(cmif_ClosedLogRow);
		if closedLogRow = null then
			self.assertTrueMsg(false, "[Pre Test Validation] Log Row : " &amp; TARGETCLOSEDLOGROWID &amp; " does not exist therefore test cannot continue"); //Log Row does not exist so fail
		endif;
		
	elseif closedLogRow.status &lt;&gt; LC_Status_Closed then
		self.assertTrueMsg(false, "[Pre Test Validation] Log Row : " &amp; TARGETCLOSEDLOGROWID &amp; ", This log row should have a 'Closed' status"); //Log Row status is not closed
	endif;
	
	self.opts.addAssoc("Terminal", TERMINAL);
	utLogTests.opts.addAssoc("Terminal", TERMINAL);
	utLogTests.setActiveProfile();
	
	/*
	*	Delete leftover Test Data
	*/
	//Should delete/tidy up created cargo/logs created via road gate
	utBolIn := utLogTests.getBOLIn(BOLNUMBER, utLogTests.OperatorCode);
	if utBolIn &lt;&gt; null then
		utLogTests.deleteBOL(BOLNUMBER, utBolIn);
	endif;
	
	//Should delete/tidy up created receipt/docket reconciliation
	tiLog01 := terminal.allOnsiteTIsByIdCargoType[TILOG01, TI_CargoType_Log];
	if tiLog01 &lt;&gt; null then
		utLogTests.deleteTrackedItem(tiLog01, true);
	endif;
	
	tiLog02 := terminal.allOnsiteTIsByIdCargoType[TILOG02, TI_CargoType_Log];
	if tiLog02 &lt;&gt; null then
		utLogTests.deleteTrackedItem(tiLog01, true);
	endif;

	//Should delete/tidy up created receipt/docket reconciliation
	tiLog03 := terminal.allOnsiteTIsByIdCargoType[TILOG03, TI_CargoType_Log];
	if tiLog03 &lt;&gt; null then
		utLogTests.deleteTrackedItem(tiLog03, true);
	endif;
	
	//Should delete/tidy up created receipt/docket reconciliation
	tiLog04 := terminal.allOnsiteTIsByIdCargoType[TILOG04, TI_CargoType_Log];
	if tiLog04 &lt;&gt; null then
		utLogTests.deleteTrackedItem(tiLog04, true);
	endif;
	
	//Should delete/tidy up created receipt/docket reconciliation
	tiLog05 := terminal.allOnsiteTIsByIdCargoType[TILOG05, TI_CargoType_Log];
	if tiLog05 &lt;&gt; null then
		utLogTests.deleteTrackedItem(tiLog05, true);
	endif;
	
	/*
	*	Start Creating Test Data
	*/
	//Should create cargo/logs via road gate
	utLogTests.createBOLIn(SOURCELOGROWID, BOLNUMBER, "LOG", NUMBOLITEMS);
	
	utBolIn := utLogTests.getBOLIn(BOLNUMBER, utLogTests.OperatorCode);
	
	//Should create a receipt/do docket reconciliation
	logId := "LOG52572_";
	foreach loopVar in 1 to utBolIn.numItems do
		logArray.add( 	logId &amp; loopVar.String &amp;Tab&amp;	// logId
						(loopVar*10).String &amp;Tab&amp;		// minSED
						(loopVar*10).String );		// maxSED
	endforeach;
	
	utLogTests.addLogsFromScaleData(BOLNUMBER, logArray, utLogTests.OperatorCode);
	
	/*
	*	Pre Test Validation
	*/
	create logController transient;
	create tisToProcess transient;
	create errSet transient;
	
	tiLog01 := terminal.allOnsiteTIsByIdCargoType[TILOG01, TI_CargoType_Log];
	if tiLog01 = null then
		self.assertTrueMsg(false, "[Pre Test Validation] CargoId: " &amp; TILOG01 &amp; " does not exist therefore test cannot continue"); //Tracked Item LOG01 does not exist so fail
		
	elseif tiLog01.locationId &lt;&gt; SOURCELOGROWID then
		self.assertTrueMsg(false, "[Pre Test Validation] CargoId: " &amp; TILOG01 &amp; " is not located in " &amp; SOURCELOGROWID &amp; " therefore test cannot continue"); //Tracked Item LOG01 does not exist so fail
		
	endif;
	
	tiLog02 := terminal.allOnsiteTIsByIdCargoType[TILOG02, TI_CargoType_Log];
	if tiLog02 = null then
		self.assertTrueMsg(false, "[Pre Test Validation] CargoId: " &amp; TILOG02 &amp; " does not exist therefore test cannot continue"); //Tracked Item LOG02 does not exist so fail
		
	elseif tiLog02.locationId &lt;&gt; SOURCELOGROWID then
		self.assertTrueMsg(false, "[Pre Test Validation] CargoId: " &amp; TILOG02 &amp; " is not located in " &amp; SOURCELOGROWID &amp; " therefore test cannot continue"); //Tracked Item LOG02 does not exist so fail
		
	endif;
	
	tiLog03 := terminal.allOnsiteTIsByIdCargoType[TILOG03, TI_CargoType_Log];
	if tiLog03 = null then
		self.assertTrueMsg(false, "[Pre Test Validation] CargoId: " &amp; TILOG03 &amp; " does not exist therefore test cannot continue"); //Tracked Item LOG03 does not exist so fail
		
	elseif tiLog03.locationId &lt;&gt; SOURCELOGROWID then
		self.assertTrueMsg(false, "[Pre Test Validation] CargoId: " &amp; TILOG03 &amp; " is not located in " &amp; SOURCELOGROWID &amp; " therefore test cannot continue"); //Tracked Item LOG03 does not exist so fail
		
	endif;
	
	tiLog04 := terminal.allOnsiteTIsByIdCargoType[TILOG04, TI_CargoType_Log];
	if tiLog04 = null then
		self.assertTrueMsg(false, "[Pre Test Validation] CargoId: " &amp; TILOG04 &amp; " does not exist therefore test cannot continue"); //Tracked Item LOG04 does not exist so fail
		
	elseif tiLog04.locationId &lt;&gt; SOURCELOGROWID then
		self.assertTrueMsg(false, "[Pre Test Validation] CargoId: " &amp; TILOG04 &amp; " is not located in " &amp; SOURCELOGROWID &amp; " therefore test cannot continue"); //Tracked Item LOG04 does not exist so fail
		
	endif;
	
	tiLog05 := terminal.allOnsiteTIsByIdCargoType[TILOG05, TI_CargoType_Log];
	if tiLog05 = null then
		self.assertTrueMsg(false, "[Pre Test Validation] CargoId: " &amp; TILOG05 &amp; " does not exist therefore test cannot continue"); //Tracked Item LOG05 does not exist so fail
		
	elseif tiLog05.locationId &lt;&gt; SOURCELOGROWID then
		self.assertTrueMsg(false, "[Pre Test Validation] CargoId: " &amp; TILOG05 &amp; " is not located in " &amp; SOURCELOGROWID &amp; " therefore test cannot continue"); //Tracked Item LOG05 does not exist so fail
		
	endif;
	
	/*
	* Start Testing
	*/
	//Add Ti's to list of Ti's to process
	tisToProcess.add(tiLog01);
	tisToProcess.add(tiLog02);
	
	logController.doTransferLogs(terminal, openLogRow, tisToProcess, errSet);
	
	//Check Trx has no errors
	self.assertNoTrxErrorsOrWarnings();
	
	//Check Error set has no errors
	if errSet.size &gt; 0 then
		self.assertTrueMsg(false, "Errors exist in the error set"); //Error set contains errors so fail.
	endif;
	
	//Check TI still exists and has been moved to correct location
	tiLog01 := terminal.allOnsiteTIsByIdCargoType[TILOG01, TI_CargoType_Log];
	if tiLog01 = null then
		self.assertTrueMsg(false, "CargoId: " &amp; TILOG01 &amp; " does not exist therefore test cannot continue"); //Tracked Item LOG01 does not exist so fail
		
	elseif tiLog01.locationId &lt;&gt; TARGETOPENLOGROWID then
		self.assertTrueMsg(false, "CargoId: " &amp; TILOG01 &amp; " is not located in " &amp; TARGETOPENLOGROWID &amp; " therefore test cannot continue"); //Tracked Item LOG01 does not exist so fail
		
	endif;
	
	//Check TI still exists and has been moved to correct location
	tiLog02 := terminal.allOnsiteTIsByIdCargoType[TILOG02, TI_CargoType_Log];
	if tiLog02 = null then
		self.assertTrueMsg(false, "CargoId: " &amp; TILOG02 &amp; " does not exist therefore test cannot continue"); //Tracked Item LOG02 does not exist so fail
		
	elseif tiLog02.locationId &lt;&gt; TARGETOPENLOGROWID then
		self.assertTrueMsg(false, "CargoId: " &amp; TILOG02 &amp; " is not located in " &amp; TARGETOPENLOGROWID &amp; " therefore test cannot continue"); //Tracked Item LOG01 does not exist so fail
		
	endif;
	
	
	
	tisToProcess.clear();
	
	tisToProcess.add(tiLog03);
	tisToProcess.add(tiLog04);
	tisToProcess.add(tiLog05);
	logController.doTransferLogs(terminal, closedLogRow, tisToProcess, errSet);
	
	//Check Trx has no errors
	self.assertNoTrxErrorsOrWarnings();
	
	//Check Error set has no errors
	if errSet.size &gt; 0 then
		self.assertTrueMsg(false, "Errors exist in the error set"); //Error set contains errors so fail.
	endif;
	
	//Check TI still exists and has been moved to correct location
	tiLog03 := terminal.allOnsiteTIsByIdCargoType[TILOG03, TI_CargoType_Log];
	if tiLog03 = null then
		self.assertTrueMsg(false, "CargoId: " &amp; TILOG03 &amp; " does not exist therefore test cannot continue"); //Tracked Item LOG03 does not exist so fail
		
	elseif tiLog03.locationId &lt;&gt; TARGETCLOSEDLOGROWID then
		self.assertTrueMsg(false, "CargoId: " &amp; TILOG03 &amp; " is not located in " &amp; TARGETCLOSEDLOGROWID &amp; " therefore test cannot continue"); //Tracked Item LOG03 does not exist so fail
		
	endif;
	
	//Check TI still exists and has been moved to correct location
	tiLog04 := terminal.allOnsiteTIsByIdCargoType[TILOG04, TI_CargoType_Log];
	if tiLog04 = null then
		self.assertTrueMsg(false, "CargoId: " &amp; TILOG04 &amp; " does not exist therefore test cannot continue"); //Tracked Item LOG04 does not exist so fail
		
	elseif tiLog04.locationId &lt;&gt; TARGETCLOSEDLOGROWID then
		self.assertTrueMsg(false, "CargoId: " &amp; TILOG04 &amp; " is not located in " &amp; TARGETCLOSEDLOGROWID &amp; " therefore test cannot continue"); //Tracked Item LOG04 does not exist so fail
		
	endif;
	
	//Check TI still exists and has been moved to correct location
	tiLog05 := terminal.allOnsiteTIsByIdCargoType[TILOG05, TI_CargoType_Log];
	if tiLog05 = null then
		self.assertTrueMsg(false, "CargoId: " &amp; TILOG05 &amp; " does not exist therefore test cannot continue"); //Tracked Item LOG05 does not exist so fail
		
	elseif tiLog05.locationId &lt;&gt; TARGETCLOSEDLOGROWID then
		self.assertTrueMsg(false, "CargoId: " &amp; TILOG05 &amp; " is not located in " &amp; TARGETCLOSEDLOGROWID &amp; " therefore test cannot continue"); //Tracked Item LOG05 does not exist so fail
		
	endif;
	
epilog
	delete utLogTests;
	delete logController;
	delete tisToProcess;
	delete errSet;
	delete logArray;
	delete cmif_OpenLogRow;
	delete cmif_SourceLogRow;
	delete cmif_ClosedLogRow;
	app.setIsWebApp(false); //We always want to set this to false
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tC3LogTrans2_OpnLogRowErrCon" id="463c4166-f061-4399-9547-fb73da79817a">
        <source>tC3LogTrans2_OpnLogRowErrCon();
/*

Purpose:			Test for REST Api Method: MasterTerminalAPIService::putTransferRq
					Description: This is to test that logs can be moved to an open log row, when one ti given to us is already located there. 
									Should return an error for the ti already located there and move the rest when called from a web service.

Parameters:			

Return Value:		

Date		Who		Reason
18 January 2022	navpw1	Initial creation TFS: 52572

*/

//2. //Tests that logs can be moved to an open log row where one log is already located there (To Test that it continues processing next ti on error) - No Errors

constants
	Ref						: String 	= UT_DSL.TFS52572;
	BOLNUMBER1 				: String	= "BOL" &amp; Ref &amp; "02";
	NUMBOLITEMS1			: Integer	= 1;
	
	BOLNUMBER2 				: String	= "BOL" &amp; Ref &amp; "03";
	NUMBOLITEMS2			: Integer	= 2;
	
	TERMINAL 				: String	= "UT";
	SOURCELOGROWID1 		: String	= "LGR2";
	SOURCELOGROWID2 		: String	= "LGR3";
	TARGETLOGAREA 			: String	= "UTLOG";
	TARGETLOGROWID 			: String	= "LGR2";
	USERCODE 				: String	= "UNITTEST";
	TILOG01 				: String	= "LOG" &amp; Ref &amp; "_6";
	TILOG02 				: String	= "LOG" &amp; Ref &amp; "_7";
	TILOG03 				: String	= "LOG" &amp; Ref &amp; "_8";
	
vars
	terminal 			: CM_Terminal;
	logArea 			: CM_LogArea;
	sourceLogRow,
	sourceLogRow2,
	targetLogRow		: CM_LogController; //LogRow
	cmif_SourceLogRow,
	cmif_SourceLogRow2,
	cmif_TargetLogRow	: CMIF_LogRowRestriction;
	logController		: CMIF_LogController;
	tiLog01,
	tiLog02,
	tiLog03				: CM_TrackedItem;
	tisToProcess,
	errSet				: CM_TISet;
	
	utLogTests			: UT_LogTests;
	utBolIn1,
	utBolIn2			: CM_BOLIn;
	loopVar				: Integer;
	logId				: String;
	logArray			: StringArray;
	error				: CM_Error;
	foundError 			: Boolean;
	
begin
	app.setIsWebApp(true); //Need to execute our methods like we are a web app
	//Tests that logs can be moved to an open log row

	create utLogTests transient;
	create logArray transient;
	
	//Validate Supplied Terminal
	terminal := app.myRoot.allTerminals[TERMINAL];
	if terminal = null then
		self.assertTrueMsg(false, "[Pre Test Validation] Terminal : " &amp; TERMINAL &amp; " does not exist therefore test cannot continue"); //Terminal does not exist so fail
	endif;
	
	//Validate Supplied Log Area
	logArea := terminal.allTerminalAreasByTypeId[TA_TYPE_LOGAREA, TARGETLOGAREA].CM_LogArea;
	if logArea = null then
		self.assertTrueMsg(false, "[Pre Test Validation] Log Area : " &amp; TARGETLOGAREA &amp; " does not exist therefore test cannot continue"); //Log Area does not exist so fail
	endif;
	
	//Validate Source Open Log Row
	sourceLogRow := logArea.findLogRow(SOURCELOGROWID1);
	if sourceLogRow = null then
		create cmif_SourceLogRow transient;
		cmif_SourceLogRow.myRowArea := logArea;
		cmif_SourceLogRow.id := SOURCELOGROWID1;
		cmif_SourceLogRow.transport := 3;  // there is no constant
		cmif_SourceLogRow.status := LC_Status_Open;
		cmif_SourceLogRow.width := 12;  //see LOG_LogRowMaintForm :: setRowWidth();
		cmif_SourceLogRow.user := app.getMyUserCode;
		sourceLogRow := utLogTests.addLogRow(cmif_SourceLogRow);
		if sourceLogRow = null then
			self.assertTrueMsg(false, "[Pre Test Validation] Log Row : " &amp; SOURCELOGROWID1 &amp; " does not exist therefore test cannot continue"); //Log Row does not exist so fail
		endif;
	elseif sourceLogRow.status &lt;&gt; LC_Status_Open then
		self.assertTrueMsg(false, "[Pre Test Validation] Log Row : " &amp; SOURCELOGROWID1 &amp; ", This log row should have an 'Open' status"); //Log Row status is not open
	endif;
	
	//Validate Target Open Log Row
	sourceLogRow2 := logArea.findLogRow(SOURCELOGROWID2);
	if sourceLogRow2 = null then
		create cmif_SourceLogRow2 transient;
		cmif_SourceLogRow2.myRowArea := logArea;
		cmif_SourceLogRow2.id := SOURCELOGROWID2;
		cmif_SourceLogRow2.transport := 3;  // there is no constant
		cmif_SourceLogRow2.status := LC_Status_Open;
		cmif_SourceLogRow2.width := 12;  //see LOG_LogRowMaintForm :: setRowWidth();
		cmif_SourceLogRow2.user := app.getMyUserCode;
		sourceLogRow2 := utLogTests.addLogRow(cmif_SourceLogRow2);
		if sourceLogRow2 = null then
			self.assertTrueMsg(false, "[Pre Test Validation] Log Row : " &amp; SOURCELOGROWID2 &amp; " does not exist therefore test cannot continue"); //Log Row does not exist so fail
		endif;
	elseif sourceLogRow2.status &lt;&gt; LC_Status_Open then
		self.assertTrueMsg(false, "[Pre Test Validation] Log Row : " &amp; SOURCELOGROWID2 &amp; ", This log row should have an 'Open' status"); //Log Row status is not open
	endif;
	
	//Validate Target Closed Log Row
	targetLogRow := logArea.findLogRow(TARGETLOGROWID);
	if targetLogRow = null then
	create cmif_TargetLogRow transient;
		cmif_TargetLogRow.myRowArea := logArea;
		cmif_TargetLogRow.id := TARGETLOGROWID;
		cmif_TargetLogRow.transport := 3;  // there is no constant
		cmif_TargetLogRow.status := LC_Status_Closed;
		cmif_TargetLogRow.width := 12;  //see LOG_LogRowMaintForm :: setRowWidth();
		cmif_TargetLogRow.user := app.getMyUserCode;
		targetLogRow := utLogTests.addLogRow(cmif_TargetLogRow);
		if targetLogRow = null then
			self.assertTrueMsg(false, "[Pre Test Validation] Log Row : " &amp; TARGETLOGROWID &amp; " does not exist therefore test cannot continue"); //Log Row does not exist so fail
		endif;
		
	elseif targetLogRow.status &lt;&gt; LC_Status_Open then
		self.assertTrueMsg(false, "[Pre Test Validation] Log Row : " &amp; TARGETLOGROWID &amp; ", This log row should have a 'Open' status"); //Log Row status is not closed
	endif;
	
	self.opts.addAssoc("Terminal", TERMINAL);
	utLogTests.opts.addAssoc("Terminal", TERMINAL);
	utLogTests.setActiveProfile();
	
	/*
	*	Delete leftover Test Data
	*/
	//Should delete/tidy up created cargo/logs created via road gate
	utBolIn1 := utLogTests.getBOLIn(BOLNUMBER1, utLogTests.OperatorCode);
	if utBolIn1 &lt;&gt; null then
		utLogTests.deleteBOL(BOLNUMBER1, utBolIn1);
	endif;
	
	//Should delete/tidy up created cargo/logs created via road gate
	utBolIn2 := utLogTests.getBOLIn(BOLNUMBER2, utLogTests.OperatorCode);
	if utBolIn2 &lt;&gt; null then
		utLogTests.deleteBOL(BOLNUMBER2, utBolIn2);
	endif;
	
	//Should delete/tidy up created receipt/docket reconciliation
	tiLog01 := terminal.allOnsiteTIsByIdCargoType[TILOG01, TI_CargoType_Log];
	if tiLog01 &lt;&gt; null then
		utLogTests.deleteTrackedItem(tiLog01, true);
	endif;
	
	tiLog02 := terminal.allOnsiteTIsByIdCargoType[TILOG02, TI_CargoType_Log];
	if tiLog02 &lt;&gt; null then
		utLogTests.deleteTrackedItem(tiLog01, true);
	endif;

	//Should delete/tidy up created receipt/docket reconciliation
	tiLog03 := terminal.allOnsiteTIsByIdCargoType[TILOG03, TI_CargoType_Log];
	if tiLog03 &lt;&gt; null then
		utLogTests.deleteTrackedItem(tiLog03, true);
	endif;
	
	/*
	*	Start Creating Test Data
	*/
	//Should create cargo/logs via road gate BOL1
	utLogTests.createBOLIn(SOURCELOGROWID1, BOLNUMBER1, "LOG", NUMBOLITEMS1);
	
	utBolIn1 := utLogTests.getBOLIn(BOLNUMBER1, utLogTests.OperatorCode);
	
	//Should create a receipt/do docket reconciliation
	logId := "LOG52572_";
	logArray.add(logId &amp; 6.String &amp;Tab&amp;	// logId
						(6*10).String &amp;Tab&amp;		// minSED
						(6*10).String );
	
	utLogTests.addLogsFromScaleData(BOLNUMBER1, logArray, utLogTests.OperatorCode);
	
	logArray.clear();
	
	//Should create cargo/logs via road gate BOL2
	utLogTests.createBOLIn(SOURCELOGROWID2, BOLNUMBER2, "LOG", NUMBOLITEMS2);
	
	utBolIn2 := utLogTests.getBOLIn(BOLNUMBER2, utLogTests.OperatorCode);
	
	//Should create a receipt/do docket reconciliation
	logId := "LOG52572_";
	logArray.add(logId &amp; 7.String &amp;Tab&amp;	// logId
						(7*10).String &amp;Tab&amp;		// minSED
						(7*10).String );
	logArray.add(logId &amp; 8.String &amp;Tab&amp;	// logId
						(8*10).String &amp;Tab&amp;		// minSED
						(8*10).String );
	
	utLogTests.addLogsFromScaleData(BOLNUMBER2, logArray, utLogTests.OperatorCode);
	
	/*
	*	Pre Test Validation
	*/
	create logController transient;
	create tisToProcess transient;
	create errSet transient;

	//Validate Supplied Log Area
	logArea := terminal.allTerminalAreasByTypeId[TA_TYPE_LOGAREA, TARGETLOGAREA].CM_LogArea;
	if logArea = null then
		self.assertTrueMsg(false, "[Pre Test Validation] Log Area : " &amp; TARGETLOGAREA &amp; " does not exist therefore test cannot continue"); //Log Area does not exist so fail
	endif;
	
	//Validate Supplied Log Row
	targetLogRow := logArea.findLogRow(TARGETLOGROWID);
	if targetLogRow = null then
		self.assertTrueMsg(false, "[Pre Test Validation] Log Row : " &amp; TARGETLOGROWID &amp; " does not exist therefore test cannot continue"); //Log Row does not exist so fail
	elseif targetLogRow.status &lt;&gt; LC_Status_Open then
		self.assertTrueMsg(false, "[Pre Test Validation] Log Row : " &amp; TARGETLOGROWID &amp; " is closed, This log row should have an 'Open' status"); //Log Row status is not open
	endif;
	
	tiLog01 := terminal.allOnsiteTIsByIdCargoType[TILOG01, TI_CargoType_Log];
	if tiLog01 = null then
		self.assertTrueMsg(false, "[Pre Test Validation] CargoId: " &amp; TILOG01 &amp; " does not exist therefore test cannot continue"); //Tracked Item LOG01 does not exist so fail
		
	elseif tiLog01.locationId &lt;&gt; SOURCELOGROWID1 then
		self.assertTrueMsg(false, "[Pre Test Validation] CargoId: " &amp; TILOG01 &amp; " is not located in " &amp; SOURCELOGROWID1 &amp; " therefore test cannot continue"); //Tracked Item LOG01 does not exist so fail
		
	endif;
	
	tiLog02 := terminal.allOnsiteTIsByIdCargoType[TILOG02, TI_CargoType_Log];
	if tiLog02 = null then
		self.assertTrueMsg(false, "[Pre Test Validation] CargoId: " &amp; TILOG02 &amp; " does not exist therefore test cannot continue"); //Tracked Item LOG02 does not exist so fail
		
	elseif tiLog02.locationId &lt;&gt; SOURCELOGROWID2 then
		self.assertTrueMsg(false, "[Pre Test Validation] CargoId: " &amp; TILOG02 &amp; " is not located in " &amp; SOURCELOGROWID2 &amp; " therefore test cannot continue"); //Tracked Item LOG02 does not exist so fail
		
	endif;
	
	tiLog03 := terminal.allOnsiteTIsByIdCargoType[TILOG03, TI_CargoType_Log];
	if tiLog03 = null then
		self.assertTrueMsg(false, "[Pre Test Validation] CargoId: " &amp; TILOG03 &amp; " does not exist therefore test cannot continue"); //Tracked Item LOG03 does not exist so fail
		
	elseif tiLog03.locationId &lt;&gt; SOURCELOGROWID2 then
		self.assertTrueMsg(false, "[Pre Test Validation] CargoId: " &amp; TILOG03 &amp; " is not located in " &amp; SOURCELOGROWID2 &amp; " therefore test cannot continue"); //Tracked Item LOG03 does not exist so fail
		
	endif;
	
	/*
	* Start Testing
	*/
	//Add Ti's to list of Ti's to process
	tisToProcess.add(tiLog01);
	tisToProcess.add(tiLog02);
	tisToProcess.add(tiLog03);
	
	logController.doTransferLogs(terminal, targetLogRow, tisToProcess, errSet);
	
	//Check Error set has no errors
	self.assertTrueMsg(app.myPassport.allErrors.size = 1, "Too many errors present in Passport. Expecting 1 error of type ERR_Already_Here. Actual " &amp; app.myPassport.allErrors.size.asStringJMT() &amp; CrLf &amp; "Error List:" &amp; CrLf &amp; app.myPassport.getAllErrorsAndWarnsFullAsStr());
	
	self.assertTrueMsg(errSet.size = 1, "Error Set returned does not match what it should be. Expecting 1 tracked item in error when moving logs. Actual " &amp; errSet.size.asStringJMT());
	
	foreach error in app.myPassport.allErrors do
		if error.text.cnContains(TILOG01) then
			foundError := true;
			break;
		endif;
	endforeach;
	
	self.assertTrueMsg(foundError, "Expected movement of " &amp; TILOG01 &amp; " to fail, instead it succeeded"); //Error set contains errors so fail.
	
	//Check TI still exists and has been moved to correct location
	tiLog01 := terminal.allOnsiteTIsByIdCargoType[TILOG01, TI_CargoType_Log];
	if tiLog01 = null then
		self.assertTrueMsg(false, "CargoId: " &amp; TILOG01 &amp; " does not exist therefore test cannot continue"); //Tracked Item LOG01 does not exist so fail
		
	elseif tiLog01.locationId &lt;&gt; TARGETLOGROWID then
		self.assertTrueMsg(false, "CargoId: " &amp; TILOG01 &amp; " is not located in " &amp; TARGETLOGROWID &amp; " therefore test cannot continue"); //Tracked Item LOG01 does not exist so fail
		
	endif;
	
	//Check TI still exists and has been moved to correct location
	tiLog02 := terminal.allOnsiteTIsByIdCargoType[TILOG02, TI_CargoType_Log];
	if tiLog02 = null then
		self.assertTrueMsg(false, "CargoId: " &amp; TILOG02 &amp; " does not exist therefore test cannot continue"); //Tracked Item LOG02 does not exist so fail
		
	elseif tiLog02.locationId &lt;&gt; TARGETLOGROWID then
		self.assertTrueMsg(false, "CargoId: " &amp; TILOG02 &amp; " is not located in " &amp; TARGETLOGROWID &amp; " therefore test cannot continue"); //Tracked Item LOG02 does not exist so fail
		
	endif;
	
	//Check TI still exists and has been moved to correct location
	tiLog03 := terminal.allOnsiteTIsByIdCargoType[TILOG03, TI_CargoType_Log];
	if tiLog03 = null then
		self.assertTrueMsg(false, "CargoId: " &amp; TILOG03 &amp; " does not exist therefore test cannot continue"); //Tracked Item LOG03 does not exist so fail
		
	elseif tiLog03.locationId &lt;&gt; TARGETLOGROWID then
		self.assertTrueMsg(false, "CargoId: " &amp; TILOG03 &amp; " is not located in " &amp; TARGETLOGROWID &amp; " therefore test cannot continue"); //Tracked Item LOG03 does not exist so fail
		
	endif;
	
epilog
	delete utLogTests;
	delete logController;
	delete tisToProcess;
	delete errSet;
	delete logArray;
	app.setIsWebApp(false); //We always want to set this to false
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tC3LogTrans3_MveClsdRowSts" id="f046051e-e514-405a-94ef-323896bed372">
        <source>tC3LogTrans3_MveClsdRowSts();
/*

Purpose:			Test for REST Api Method: MasterTerminalAPIService::putTransferRq
					Description: This is to test that logs can be moved to an closed log row. When moved the Log Row Status should not change from closed. 

Parameters:			

Return Value:		

Date		Who		Reason
18 January 2022	navpw1	Initial creation TFS: 52572

*/

//3. //Tests that logs can be moved to a closed row and the status does not change. For example a closed row does not become open etc.

constants
	Ref				: String 	= UT_DSL.TFS52572;
	BOLNUMBER 		: String	= "BOL" &amp; Ref &amp; "04";
	NUMBOLITEMS		: Integer	= 3;
	
	TERMINAL 		: String	= "UT";
	SOURCELOGROWID 	: String	= "LGR2";
	TARGETLOGAREA 	: String	= "UTLOG";
	TARGETLOGROWID 	: String	= "LGR4";
	USERCODE 		: String	= "UNITTEST";
	TILOG01 		: String	= "LOG" &amp; Ref &amp; "_10";
	TILOG02 		: String	= "LOG" &amp; Ref &amp; "_11";
	TILOG03 		: String	= "LOG" &amp; Ref &amp; "_12";
	
vars
	terminal 			: CM_Terminal;
	logArea 			: CM_LogArea;
	sourceLogRow,
	logRow				: CM_LogController; //LogRow
	logController		: CMIF_LogController;
	tiLog01,
	tiLog02,
	tiLog03				: CM_TrackedItem;
	tisToProcess,
	errSet				: CM_TISet;
	
	utLogTests			: UT_LogTests;
	utBolIn				: CM_BOLIn;
	cmif_SourceLogRow,
	cmif_LogRow			: CMIF_LogRowRestriction;
	logId				: String;
	logArray			: StringArray;
	
begin
	app.setIsWebApp(true); //Need to execute our methods like we are a web app
	//Tests that logs can be moved to an closed log row without changing the status
	create utLogTests transient;
	create logArray transient;
	
	//Validate Supplied Terminal
	terminal := app.myRoot.allTerminals[TERMINAL];
	if terminal = null then
		self.assertTrueMsg(false, "[Pre Test Validation] Terminal : " &amp; TERMINAL &amp; " does not exist therefore test cannot continue"); //Terminal does not exist so fail
	endif;
	
	//Validate Supplied Log Area
	logArea := terminal.allTerminalAreasByTypeId[TA_TYPE_LOGAREA, TARGETLOGAREA].CM_LogArea;
	if logArea = null then
		self.assertTrueMsg(false, "[Pre Test Validation] Log Area : " &amp; TARGETLOGAREA &amp; " does not exist therefore test cannot continue"); //Log Area does not exist so fail
	endif;
	
	//Validate Source Open Log Row
	sourceLogRow := logArea.findLogRow(SOURCELOGROWID);
	if sourceLogRow = null then
		create cmif_SourceLogRow transient;
		cmif_SourceLogRow.myRowArea := logArea;
		cmif_SourceLogRow.id := SOURCELOGROWID;
		cmif_SourceLogRow.transport := 3;  // there is no constant
		cmif_SourceLogRow.status := LC_Status_Open;
		cmif_SourceLogRow.width := 12;  //see LOG_LogRowMaintForm :: setRowWidth();
		cmif_SourceLogRow.user := app.getMyUserCode;
		sourceLogRow := utLogTests.addLogRow(cmif_SourceLogRow);
		if sourceLogRow = null then
			self.assertTrueMsg(false, "[Pre Test Validation] Log Row : " &amp; SOURCELOGROWID &amp; " does not exist therefore test cannot continue"); //Log Row does not exist so fail
		endif;
	elseif sourceLogRow.status &lt;&gt; LC_Status_Open then
		self.assertTrueMsg(false, "[Pre Test Validation] Log Row : " &amp; SOURCELOGROWID &amp; ", This log row should have an 'Open' status"); //Log Row status is not open
	endif;
	
	//Validate Supplied Log Row
	logRow := logArea.findLogRow(TARGETLOGROWID);
	if logRow = null then
		create cmif_LogRow transient;
		cmif_LogRow.myRowArea := logArea;
		cmif_LogRow.id := TARGETLOGROWID;
		cmif_LogRow.transport := 3;  // there is no constant
		cmif_LogRow.status := LC_Status_Closed;
		cmif_LogRow.width := 12;  //see LOG_LogRowMaintForm :: setRowWidth();
		cmif_LogRow.user := app.getMyUserCode;
		logRow := utLogTests.addLogRow(cmif_LogRow);
		if logRow = null then
			self.assertTrueMsg(false, "[Pre Test Validation] Log Row : " &amp; TARGETLOGROWID &amp; " does not exist therefore test cannot continue"); //Log Row does not exist so fail
		endif;
	elseif logRow.status &lt;&gt; LC_Status_Closed then
		self.assertTrueMsg(false, "[Pre Test Validation] Log Row : " &amp; TARGETLOGROWID &amp; ", This log row should have a 'Closed' status"); //Log Row status is not open
	endif;
	
	self.opts.addAssoc("Terminal", TERMINAL);
	utLogTests.opts.addAssoc("Terminal", TERMINAL);
	utLogTests.setActiveProfile();
	
	/*
	*	Delete leftover Test Data
	*/
	//Should delete/tidy up created cargo/logs created via road gate
	utBolIn := utLogTests.getBOLIn(BOLNUMBER, utLogTests.OperatorCode);
	if utBolIn &lt;&gt; null then
		utLogTests.deleteBOL(BOLNUMBER, utBolIn);
	endif;
	
	//Should delete/tidy up created receipt/docket reconciliation
	tiLog01 := terminal.allOnsiteTIsByIdCargoType[TILOG01, TI_CargoType_Log];
	if tiLog01 &lt;&gt; null then
		utLogTests.deleteTrackedItem(tiLog01, true);
	endif;
	
	tiLog02 := terminal.allOnsiteTIsByIdCargoType[TILOG02, TI_CargoType_Log];
	if tiLog02 &lt;&gt; null then
		utLogTests.deleteTrackedItem(tiLog01, true);
	endif;

	//Should delete/tidy up created receipt/docket reconciliation
	tiLog03 := terminal.allOnsiteTIsByIdCargoType[TILOG03, TI_CargoType_Log];
	if tiLog03 &lt;&gt; null then
		utLogTests.deleteTrackedItem(tiLog03, true);
	endif;
	
	/*
	*	Start Creating Test Data
	*/
	//Should create cargo/logs via road gate
	utLogTests.createBOLIn(SOURCELOGROWID, BOLNUMBER, "LOG", NUMBOLITEMS);
	
	utBolIn := utLogTests.getBOLIn(BOLNUMBER, utLogTests.OperatorCode);
	
	//Should create a receipt/do docket reconciliation
	logId := "LOG52572_";
	logArray.add(logId &amp; 10.String &amp;Tab&amp;	// logId
					(10*10).String &amp;Tab&amp;		// minSED
					(10*10).String );		// maxSED
	logArray.add(logId &amp; 11.String &amp;Tab&amp;	// logId
					(11*10).String &amp;Tab&amp;		// minSED
					(11*10).String );		// maxSED
	logArray.add(logId &amp; 12.String &amp;Tab&amp;	// logId
					(12*10).String &amp;Tab&amp;		// minSED
					(12*10).String );		// maxSED
					
	utLogTests.addLogsFromScaleData(BOLNUMBER, logArray, utLogTests.OperatorCode);
	
	/*
	*	Pre Test Validation
	*/
	create logController transient;
	create tisToProcess transient;
	create errSet transient;
	
	tiLog01 := terminal.allOnsiteTIsByIdCargoType[TILOG01, TI_CargoType_Log];
	if tiLog01 = null then
		self.assertTrueMsg(false, "[Pre Test Validation] CargoId: " &amp; TILOG01 &amp; " does not exist therefore test cannot continue"); //Tracked Item LOG01 does not exist so fail
		
	elseif tiLog01.locationId &lt;&gt; SOURCELOGROWID then
		self.assertTrueMsg(false, "[Pre Test Validation] CargoId: " &amp; TILOG01 &amp; " is not located in " &amp; SOURCELOGROWID &amp; " therefore test cannot continue"); //Tracked Item LOG01 does not exist so fail
		
	endif;
	
	tiLog02 := terminal.allOnsiteTIsByIdCargoType[TILOG02, TI_CargoType_Log];
	if tiLog02 = null then
		self.assertTrueMsg(false, "[Pre Test Validation] CargoId: " &amp; TILOG02 &amp; " does not exist therefore test cannot continue"); //Tracked Item LOG02 does not exist so fail
		
	elseif tiLog02.locationId &lt;&gt; SOURCELOGROWID then
		self.assertTrueMsg(false, "[Pre Test Validation] CargoId: " &amp; TILOG02 &amp; " is not located in " &amp; SOURCELOGROWID &amp; " therefore test cannot continue"); //Tracked Item LOG02 does not exist so fail
		
	endif;
	
	tiLog03 := terminal.allOnsiteTIsByIdCargoType[TILOG03, TI_CargoType_Log];
	if tiLog03 = null then
		self.assertTrueMsg(false, "[Pre Test Validation] CargoId: " &amp; TILOG03 &amp; " does not exist therefore test cannot continue"); //Tracked Item LOG03 does not exist so fail
		
	elseif tiLog03.locationId &lt;&gt; SOURCELOGROWID then
		self.assertTrueMsg(false, "[Pre Test Validation] CargoId: " &amp; TILOG03 &amp; " is not located in " &amp; SOURCELOGROWID &amp; " therefore test cannot continue"); //Tracked Item LOG03 does not exist so fail
		
	endif;
	
	/*
	* Start Testing
	*/
	//Add Ti's to list of Ti's to process
	tisToProcess.add(tiLog01);
	tisToProcess.add(tiLog02);
	tisToProcess.add(tiLog03);
		
	logController.doTransferLogs(terminal, logRow, tisToProcess, errSet);
	
	//Check Trx has no errors
	self.assertNoTrxErrorsOrWarnings();
	
	//Check Error set has no errors
	if errSet.size &gt; 0 then
		self.assertTrueMsg(false, "Errors exist in the error set"); //Error set contains errors so fail.
	endif;
	
	//Check TI still exists and has been moved to correct location
	tiLog01 := terminal.allOnsiteTIsByIdCargoType[TILOG01, TI_CargoType_Log];
	if tiLog01 = null then
		self.assertTrueMsg(false, "CargoId: " &amp; TILOG01 &amp; " does not exist therefore test cannot continue"); //Tracked Item LOG01 does not exist so fail
		
	elseif tiLog01.locationId &lt;&gt; TARGETLOGROWID then
		self.assertTrueMsg(false, "CargoId: " &amp; TILOG01 &amp; " is not located in " &amp; TARGETLOGROWID &amp; " therefore test cannot continue"); //Tracked Item LOG01 does not exist so fail
		
	endif;
	
	//Check TI still exists and has been moved to correct location
	tiLog02 := terminal.allOnsiteTIsByIdCargoType[TILOG02, TI_CargoType_Log];
	if tiLog02 = null then
		self.assertTrueMsg(false, "CargoId: " &amp; TILOG02 &amp; " does not exist therefore test cannot continue"); //Tracked Item LOG02 does not exist so fail
		
	elseif tiLog02.locationId &lt;&gt; TARGETLOGROWID then
		self.assertTrueMsg(false, "CargoId: " &amp; TILOG02 &amp; " is not located in " &amp; TARGETLOGROWID &amp; " therefore test cannot continue"); //Tracked Item LOG01 does not exist so fail
		
	endif;
	
	//Check TI still exists and has been moved to correct location
	tiLog03 := terminal.allOnsiteTIsByIdCargoType[TILOG03, TI_CargoType_Log];
	if tiLog03 = null then
		self.assertTrueMsg(false, "CargoId: " &amp; TILOG03 &amp; " does not exist therefore test cannot continue"); //Tracked Item LOG02 does not exist so fail
		
	elseif tiLog03.locationId &lt;&gt; TARGETLOGROWID then
		self.assertTrueMsg(false, "CargoId: " &amp; TILOG03 &amp; " is not located in " &amp; TARGETLOGROWID &amp; " therefore test cannot continue"); //Tracked Item LOG01 does not exist so fail
		
	endif;
	
	//Validate Supplied Log Area
	logArea := terminal.allTerminalAreasByTypeId[TA_TYPE_LOGAREA, TARGETLOGAREA].CM_LogArea;
	if logArea = null then
		self.assertTrueMsg(false, "[Pre Test Validation] Log Area : " &amp; TARGETLOGAREA &amp; " does not exist therefore test cannot continue"); //Log Area does not exist so fail
	endif;
	
	//Validate Supplied Log Row
	logRow := logArea.findLogRow(TARGETLOGROWID);
	if logRow = null then
		self.assertTrueMsg(false, "Log Row : " &amp; TARGETLOGROWID &amp; " does not exist therefore test cannot continue"); //Log Row does not exist so fail
	
	elseif logRow.status &lt;&gt; LC_Status_Closed then
		self.assertTrueMsg(false, "Log Row : " &amp; TARGETLOGROWID &amp; " does not have an 'Closed' status. The status should not change when Logs are moved to a closed row"); //Log Row does not exist so fail
	
	endif;
	
epilog
	delete utLogTests;
	delete logController;
	delete tisToProcess;
	delete errSet;
	delete logArray;
	delete cmif_LogRow;
	delete cmif_SourceLogRow;
	app.setIsWebApp(false); //We always want to set this to false
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tC3LogTrans4_MveDiffCrit" id="21a1c195-e7f1-4e27-a578-2f2e13db5099">
        <source>tC3LogTrans4_MveDiffCrit();
/*

Purpose:			Test for REST Api Method: MasterTerminalAPIService::putTransferRq
					Description: Tests that logs can be moved to a row that has different criteria

Parameters:			

Return Value:		

Date		Who		Reason
25 January 2022	navpw1	Initial creation TFS: 52572

*/

//4. //Tests that logs can be moved to a row that has different criteria

constants
	Ref				: String 	= UT_DSL.TFS52572;
	BOLNUMBER 		: String	= "BOL" &amp; Ref &amp; "04";
	NUMBOLITEMS		: Integer	= 3;
	
	//Code Group Stuff
	OPERATOR		: String	= "ULOG";
	LOGSPECIES		: String	= "OAK";
	LOGTREATMENT 	: String	= "UTT";
	LOGTYPE 		: String	= "BOFFUT";
	LOGLENGTH 		: String	= "6.0";
	LOGGRADE		: String	= "GL";
	
	TERMINAL 		: String	= "UT";
	SOURCELOGROWID 	: String	= "LGR2";
	TARGETLOGAREA 	: String	= "UTLOG";
	TARGETLOGROWID 	: String	= "LGR5";
	USERCODE 		: String	= "UNITTEST";
	TILOG01 		: String	= "LOG" &amp; Ref &amp; "_13";
	TILOG02 		: String	= "LOG" &amp; Ref &amp; "_14";
	TILOG03 		: String	= "LOG" &amp; Ref &amp; "_15";
	
vars
	terminal 			: CM_Terminal;
	codeGroup			: CM_CodeGroupLogSpecs;
	operator			: CM_Operator;
	logSpecies			: CM_LogSpecies;
	logTreatment		: CM_LogTreatment;
	logType				: CM_LogType;
	logLength			: CM_LogLength;
	logGrade 			: CM_LogGrade;
	logArea 			: CM_LogArea;
	sourceLogRow,
	logRow				: CM_LogController; //LogRow
	logController		: CMIF_LogController;
	tiLog01,
	tiLog02,
	tiLog03				: CM_TrackedItem;
	tisToProcess,
	errSet				: CM_TISet;
	
	utLogTests			: UT_LogTests;
	utBolIn				: CM_BOLIn;
	cmif_SourceLogRow,
	cmif_LogRow			: CMIF_LogRowRestriction;
	logId				: String;
	logArray			: StringArray;
	
begin
	app.setIsWebApp(true); //Need to execute our methods like we are a web app
	//Tests that logs can be moved to an closed log row without changing the status
	create utLogTests transient;
	create logArray transient;
	
	//Validate Supplied Terminal
	terminal := app.myRoot.allTerminals[TERMINAL];
	if terminal = null then
		self.assertTrueMsg(false, "[Pre Test Validation] Terminal : " &amp; TERMINAL &amp; " does not exist therefore test cannot continue"); //Terminal does not exist so fail
	endif;
	
	//Check Code group exists on null operator
	//Grab values from this codeGroup
	//Grab Operator and Check code group assigned to operator
	operator := app.myRoot.allOperators[OPERATOR].CM_Operator; //Gets NULL Operator
	if operator = null then
		self.assertTrueMsg(false, "[Pre Test Validation] Operator : " &amp; OPERATOR &amp; " could not be found therefore test cannot continue"); //Operator not found so fail
	endif;
	
	//Validate Code Group (Used to create a Log Row Restriction)
	codeGroup := operator.allCodeGroups[2].CM_CodeGroupLogSpecs;
	if codeGroup = null then
		self.assertTrueMsg(false, "[Pre Test Validation] Code Group : could not be found on operator therefore test cannot continue"); //Operator not found so fail
	endif;
	
	//Validate Log Species
	logSpecies := codeGroup.allCodes[LOGSPECIES].CM_LogSpecies;
	if logSpecies = null then
		self.assertTrueMsg(false, "[Pre Test Validation] Log Species : " &amp; LOGSPECIES &amp; " could not be found therefore test cannot continue"); //Log Species not found so fail
	endif;
	
	//Validate Log Treatment
	logTreatment := codeGroup.allLogTreatments[LOGTREATMENT];
	if logTreatment = null then
		self.assertTrueMsg(false, "[Pre Test Validation] Log Treatment : " &amp; LOGTREATMENT &amp; " could not be found therefore test cannot continue"); //Log Treatment not found so fail
	endif;
	
	//Validate Log Type
	logType := codeGroup.allLogTypes[LOGTYPE];
	if logType = null then
		self.assertTrueMsg(false, "[Pre Test Validation] Log Type : " &amp; LOGTYPE &amp; " could not be found therefore test cannot continue"); //Log Type not found so fail
	endif;
	
	//Validate Log Length
	logLength := codeGroup.allLogLengths[LOGLENGTH];
	if logLength = null then
		self.assertTrueMsg(false, "[Pre Test Validation] Log Length : " &amp; LOGLENGTH &amp; " could not be found therefore test cannot continue"); //Log Length not found so fail
	endif;
	
	//Validate Log Grade
	logGrade := logSpecies.allLogGrades[LOGGRADE].CM_LogGrade;
	if logGrade = null then
		self.assertTrueMsg(false, "[Pre Test Validation] Log Grade : " &amp; LOGGRADE &amp; " could not be found therefore test cannot continue"); //Log Grade not found so fail
	endif;
	
	//Validate Supplied Log Area
	logArea := terminal.allTerminalAreasByTypeId[TA_TYPE_LOGAREA, TARGETLOGAREA].CM_LogArea;
	if logArea = null then
		self.assertTrueMsg(false, "[Pre Test Validation] Log Area : " &amp; TARGETLOGAREA &amp; " does not exist therefore test cannot continue"); //Log Area does not exist so fail
	endif;
	
	//Validate Source Open Log Row
	sourceLogRow := logArea.findLogRow(SOURCELOGROWID);
	if sourceLogRow = null then
		create cmif_SourceLogRow transient;
		cmif_SourceLogRow.myRowArea := logArea;
		cmif_SourceLogRow.id := SOURCELOGROWID;
		cmif_SourceLogRow.transport := 3;  // there is no constant
		cmif_SourceLogRow.status := LC_Status_Open;
		cmif_SourceLogRow.width := 12;  //see LOG_LogRowMaintForm :: setRowWidth();
		cmif_SourceLogRow.user := app.getMyUserCode;
		sourceLogRow := utLogTests.addLogRow(cmif_SourceLogRow);
		if sourceLogRow = null then
			self.assertTrueMsg(false, "[Pre Test Validation] Log Row : " &amp; SOURCELOGROWID &amp; " does not exist therefore test cannot continue"); //Log Row does not exist so fail
		endif;
	elseif sourceLogRow.status &lt;&gt; LC_Status_Open then
		self.assertTrueMsg(false, "[Pre Test Validation] Log Row : " &amp; SOURCELOGROWID &amp; ", This log row should have an 'Open' status"); //Log Row status is not open
	endif;
	
	//Validate Supplied Log Row
	logRow := logArea.findLogRow(TARGETLOGROWID);
	if logRow = null then
		create cmif_LogRow transient;
		cmif_LogRow.myRowArea := logArea;
		cmif_LogRow.id := TARGETLOGROWID;
		cmif_LogRow.transport := 3;  // there is no constant
		cmif_LogRow.status := LC_Status_Closed;
		cmif_LogRow.width := 12;  //see LOG_LogRowMaintForm :: setRowWidth();
		cmif_LogRow.user := app.getMyUserCode;
		cmif_LogRow.allOperators.add(operator);
		cmif_LogRow.allSpecies.add(logSpecies);
		cmif_LogRow.allTreatments.add(logTreatment);
		cmif_LogRow.allTypes.add(logType);
		cmif_LogRow.allLengths.add(logLength);
		cmif_LogRow.allGrades.add(logGrade);
		logRow := utLogTests.addLogRow(cmif_LogRow);
		if logRow = null then
			self.assertTrueMsg(false, "[Pre Test Validation] Log Row : " &amp; TARGETLOGROWID &amp; " does not exist therefore test cannot continue"); //Log Row does not exist so fail
		endif;
	elseif logRow.status &lt;&gt; LC_Status_Closed then
		self.assertTrueMsg(false, "[Pre Test Validation] Log Row : " &amp; TARGETLOGROWID &amp; ", This log row should have a 'Closed' status"); //Log Row status is not open
	endif;
	
	self.opts.addAssoc("Terminal", TERMINAL);
	utLogTests.opts.addAssoc("Terminal", TERMINAL);
	utLogTests.setActiveProfile();
	
	/*
	*	Delete leftover Test Data
	*/
	//Should delete/tidy up created cargo/logs created via road gate
	utBolIn := utLogTests.getBOLIn(BOLNUMBER, utLogTests.OperatorCode);
	if utBolIn &lt;&gt; null then
		utLogTests.deleteBOL(BOLNUMBER, utBolIn);
	endif;
	
	//Should delete/tidy up created receipt/docket reconciliation
	tiLog01 := terminal.allOnsiteTIsByIdCargoType[TILOG01, TI_CargoType_Log];
	if tiLog01 &lt;&gt; null then
		utLogTests.deleteTrackedItem(tiLog01, true);
	endif;
	
	tiLog02 := terminal.allOnsiteTIsByIdCargoType[TILOG02, TI_CargoType_Log];
	if tiLog02 &lt;&gt; null then
		utLogTests.deleteTrackedItem(tiLog01, true);
	endif;

	//Should delete/tidy up created receipt/docket reconciliation
	tiLog03 := terminal.allOnsiteTIsByIdCargoType[TILOG03, TI_CargoType_Log];
	if tiLog03 &lt;&gt; null then
		utLogTests.deleteTrackedItem(tiLog03, true);
	endif;
	
	/*
	*	Start Creating Test Data
	*/
	//Should create cargo/logs via road gate
	utLogTests.createBOLIn(SOURCELOGROWID, BOLNUMBER, "LOG", NUMBOLITEMS);
	
	utBolIn := utLogTests.getBOLIn(BOLNUMBER, utLogTests.OperatorCode);
	
	//Should create a receipt/do docket reconciliation
	logId := "LOG52572_";
	logArray.add(logId &amp; 13.String &amp;Tab&amp;	// logId
					(10*10).String &amp;Tab&amp;		// minSED
					(10*10).String );		// maxSED
	logArray.add(logId &amp; 14.String &amp;Tab&amp;	// logId
					(11*10).String &amp;Tab&amp;		// minSED
					(11*10).String );		// maxSED
	logArray.add(logId &amp; 15.String &amp;Tab&amp;	// logId
					(12*10).String &amp;Tab&amp;		// minSED
					(12*10).String );		// maxSED
					
	utLogTests.addLogsFromScaleData(BOLNUMBER, logArray, utLogTests.OperatorCode);
	
	/*
	*	Pre Test Validation
	*/
	create logController transient;
	create tisToProcess transient;
	create errSet transient;
	
	tiLog01 := terminal.allOnsiteTIsByIdCargoType[TILOG01, TI_CargoType_Log];
	if tiLog01 = null then
		self.assertTrueMsg(false, "[Pre Test Validation] CargoId: " &amp; TILOG01 &amp; " does not exist therefore test cannot continue"); //Tracked Item LOG01 does not exist so fail
		
	elseif tiLog01.locationId &lt;&gt; SOURCELOGROWID then
		self.assertTrueMsg(false, "[Pre Test Validation] CargoId: " &amp; TILOG01 &amp; " is not located in " &amp; SOURCELOGROWID &amp; " therefore test cannot continue"); //Tracked Item LOG01 does not exist so fail
		
	endif;
	
	tiLog02 := terminal.allOnsiteTIsByIdCargoType[TILOG02, TI_CargoType_Log];
	if tiLog02 = null then
		self.assertTrueMsg(false, "[Pre Test Validation] CargoId: " &amp; TILOG02 &amp; " does not exist therefore test cannot continue"); //Tracked Item LOG02 does not exist so fail
		
	elseif tiLog02.locationId &lt;&gt; SOURCELOGROWID then
		self.assertTrueMsg(false, "[Pre Test Validation] CargoId: " &amp; TILOG02 &amp; " is not located in " &amp; SOURCELOGROWID &amp; " therefore test cannot continue"); //Tracked Item LOG02 does not exist so fail
		
	endif;
	
	tiLog03 := terminal.allOnsiteTIsByIdCargoType[TILOG03, TI_CargoType_Log];
	if tiLog03 = null then
		self.assertTrueMsg(false, "[Pre Test Validation] CargoId: " &amp; TILOG03 &amp; " does not exist therefore test cannot continue"); //Tracked Item LOG03 does not exist so fail
		
	elseif tiLog03.locationId &lt;&gt; SOURCELOGROWID then
		self.assertTrueMsg(false, "[Pre Test Validation] CargoId: " &amp; TILOG03 &amp; " is not located in " &amp; SOURCELOGROWID &amp; " therefore test cannot continue"); //Tracked Item LOG03 does not exist so fail
		
	endif;
	
	/*
	* Start Testing
	*/
	//Add Ti's to list of Ti's to process
	tisToProcess.add(tiLog01);
	tisToProcess.add(tiLog02);
	tisToProcess.add(tiLog03);
		
	logController.doTransferLogs(terminal, logRow, tisToProcess, errSet);
	
	//Check Trx has no errors
	self.assertNoTrxErrorsOrWarnings();
	
	//Check Error set has no errors
	if errSet.size &gt; 0 then
		self.assertTrueMsg(false, "Errors exist in the error set"); //Error set contains errors so fail.
	endif;
	
	//Check TI still exists and has been moved to correct location
	tiLog01 := terminal.allOnsiteTIsByIdCargoType[TILOG01, TI_CargoType_Log];
	if tiLog01 = null then
		self.assertTrueMsg(false, "CargoId: " &amp; TILOG01 &amp; " does not exist therefore test cannot continue"); //Tracked Item LOG01 does not exist so fail
		
	elseif tiLog01.locationId &lt;&gt; TARGETLOGROWID then
		self.assertTrueMsg(false, "CargoId: " &amp; TILOG01 &amp; " is not located in " &amp; TARGETLOGROWID &amp; " therefore test cannot continue"); //Tracked Item LOG01 does not exist so fail
		
	endif;
	
	//Check TI still exists and has been moved to correct location
	tiLog02 := terminal.allOnsiteTIsByIdCargoType[TILOG02, TI_CargoType_Log];
	if tiLog02 = null then
		self.assertTrueMsg(false, "CargoId: " &amp; TILOG02 &amp; " does not exist therefore test cannot continue"); //Tracked Item LOG02 does not exist so fail
		
	elseif tiLog02.locationId &lt;&gt; TARGETLOGROWID then
		self.assertTrueMsg(false, "CargoId: " &amp; TILOG02 &amp; " is not located in " &amp; TARGETLOGROWID &amp; " therefore test cannot continue"); //Tracked Item LOG01 does not exist so fail
		
	endif;
	
	//Check TI still exists and has been moved to correct location
	tiLog03 := terminal.allOnsiteTIsByIdCargoType[TILOG03, TI_CargoType_Log];
	if tiLog03 = null then
		self.assertTrueMsg(false, "CargoId: " &amp; TILOG03 &amp; " does not exist therefore test cannot continue"); //Tracked Item LOG02 does not exist so fail
		
	elseif tiLog03.locationId &lt;&gt; TARGETLOGROWID then
		self.assertTrueMsg(false, "CargoId: " &amp; TILOG03 &amp; " is not located in " &amp; TARGETLOGROWID &amp; " therefore test cannot continue"); //Tracked Item LOG01 does not exist so fail
		
	endif;
	
	//Validate Supplied Log Area
	logArea := terminal.allTerminalAreasByTypeId[TA_TYPE_LOGAREA, TARGETLOGAREA].CM_LogArea;
	if logArea = null then
		self.assertTrueMsg(false, "[Pre Test Validation] Log Area : " &amp; TARGETLOGAREA &amp; " does not exist therefore test cannot continue"); //Log Area does not exist so fail
	endif;
	
	//Validate Supplied Log Row
	logRow := logArea.findLogRow(TARGETLOGROWID);
	if logRow = null then
		self.assertTrueMsg(false, "Log Row : " &amp; TARGETLOGROWID &amp; " does not exist therefore test cannot continue"); //Log Row does not exist so fail
	
	elseif logRow.status &lt;&gt; LC_Status_Closed then
		self.assertTrueMsg(false, "Log Row : " &amp; TARGETLOGROWID &amp; " does not have an 'Closed' status. The status should not change when Logs are moved to a closed row"); //Log Row does not exist so fail
	
	endif;
	
epilog
	delete utLogTests;
	delete logController;
	delete tisToProcess;
	delete errSet;
	delete logArray;
	delete cmif_LogRow;
	delete cmif_SourceLogRow;
	app.setIsWebApp(false); //We always want to set this to false
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tCargoAlreadyOnsite" id="27965c11-e0ac-41f4-9a9c-b4a39eab9cf4">
        <updating/>
        <source>tCargoAlreadyOnsite() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 February 2017	cnwmp6	Initial creation

*/
constants
	PrenoteId: String = "UTMPPRE01";
	TruckReg: String = "UTMPTR01";
	RFIDTagId: String = "UTMPRFID";
	RFIDSerial: String = "UTMPRFID";
	Prenote2Id: String = "UTMPPRE02";

vars
	ti: CM_TrackedItem;
	gateName,
	driverCode,
	carrierCode,
	extraDetail,
	batNumber,
	truckReg,
	truckState,
	pin: String;
	expectedError: Integer;
	pins: CM_StringArray;
	carrier: CM_Carrier;
	rfidTag: CM_RFIDTag;
	oldSetting: Boolean;
	ti2: CM_TrackedItem;
	
begin
	// delete leftovers
	ti := self.getTrackedItem(PrenoteId);
	if ti &lt;&gt; null then
		self.deleteTrackedItem(ti, false);
	endif;
	ti2 := self.getTrackedItem(Prenote2Id);
	if ti2 &lt;&gt; null then
		self.deleteTrackedItem(ti2, false);
	endif;
	self.deleteVehicle(TruckReg);
	
	// setup constant stuff
	oldSetting := self.setTerminalConfig(AllowPINwithoutVGM, true).Boolean;
	rfidTag := self.addRFIDTag(RFIDTagId, RFIDSerial);
	self.assertNotNullMsg(rfidTag, "Test 1 - RFID tag");
	batNumber := RFIDTagId;

	carrier := app.myRoot.allCarriers[self.getProfileSetting(UT_Profile.P_CARRIER).asString].CM_Carrier;
	self.assertNotNullMsg(carrier, "Test 2 - carrier");
	carrierCode := carrier.code;
	truckReg := TruckReg;
	
	// create prenote, first time
	ti := self.addPrenoted(PrenoteId);
	self.assertNotNullMsg(ti, "Test 3 - tracked item");	

	// gate in, first time
	create pins transient;
	pin := ti.getPinNumber().trimBlankCharacters();
	self.assertNotNullMsg(pin, "Test 4 - pin");
	pins.add(pin);
	driverCode := null;
	gateName := null;
	extraDetail := "Gate in round 1";
	expectedError := 0;
	self.webServiceCallWithParams(	CM_UnitTestAgent::wsDoAutoGateIn.name,
									truckReg,	//_rego: String;
									truckState,	//_state: String;
									batNumber,	//_batNum: String;
									driverCode,	//_driverCode: String;
									carrierCode,	//_carrierCode: String;
									gateName,	//_gateName: String;
									pins,	//_allPins: StringArray input;
									extraDetail,	//_xtraTestString : String;
									expectedError	//_expectedError : Integer
									);
	self.assertTrueMsg(ti.isOnSite, "Test 5 - " &amp; PrenoteId &amp; " should be on site");
	pins.clear();

	// exit truck
	self.webServiceCallWithParams( CM_UnitTestAgent::wsDoRoadExit.name, truckReg, truckState, batNumber, extraDetail, expectedError);

	// create prenote, second time
	ti := null;
	ti := self.addPrenoted(PrenoteId);
	self.assertNotNullMsg(ti, "Test 6 - tracked item");	

	// attempt second gate in
	pin := ti.getPinNumber().trimBlankCharacters();
	self.assertNotNullMsg(pin, "Test 7 - pin");
	pins.add(pin);
	extraDetail := "Gate in round 2";

	expectedError := ERR_ALREADY_ONSITE;
	self.webServiceCallWithParams(	CM_UnitTestAgent::wsDoAutoGateIn.name,
									truckReg,	//_rego: String;
									truckState,	//_state: String;
									batNumber,	//_batNum: String;
									driverCode,	//_driverCode: String;
									carrierCode,	//_carrierCode: String;
									gateName,	//_gateName: String;
									pins,	//_allPins: StringArray input;
									extraDetail,	//_xtraTestString : String;
									expectedError	//_expectedError : Integer
									);
	
	//18 Oct 2017	NDL	TFS 7461 - Check for duplicate on-site child pre-notes...
	ti2 := self.addPrenoted(Prenote2Id);
	self.assertNotNullMsg(ti2, "Test 9 - second tracked item");	
	beginTransaction;
	ti.setPropertyValue( "myParent", ti2 );
	commitTransaction;
	
	pins.purge();
	
	pin := ti2.getPinNumber().trimBlankCharacters();
	self.assertNotNullMsg(pin, "Test 10 - pin");
	pins.add(pin);
	extraDetail := "Gate in attempt round 3";

	expectedError := ERR_ALREADY_ONSITE;  // for the child
	self.webServiceCallWithParams(	CM_UnitTestAgent::wsDoAutoGateIn.name,
									truckReg,	//_rego: String;
									truckState,	//_state: String;
									batNumber,	//_batNum: String;
									driverCode,	//_driverCode: String;
									carrierCode,	//_carrierCode: String;
									gateName,	//_gateName: String;
									pins,	//_allPins: StringArray input;
									extraDetail,	//_xtraTestString : String;
									expectedError	//_expectedError : Integer
									);
	
	
epilog
	delete pins;
	self.setTerminalConfig(AllowPINwithoutVGM, oldSetting);
end;</source>
    </JadeMethod>
    <JadeMethod name="tCheckForTimeStampsDates" id="96a5dbbf-1b09-40b8-ad17-0f79042dfc59">
        <source>tCheckForTimeStampsDates();
// cnwns1
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 February 2016	cnwmc5	Initial creation

*/

vars
	clsColl 	: ClassColl;
	schema		: Schema;
	cls			: Class;
	prop		: Property;
	tsProps,
	dateProps	: StringArray;
	str,
	tsMsg,
	dateMsg		: String;
	propColl	: PropertyColl;
	ignoreCls,
	ignoreRestReq: Class;
	
begin
	create clsColl transient;
	create tsProps transient;
	create dateProps transient;
	
	schema := rootSchema.getSchema("WebServicesSchema");
	cls := schema.getClass("WS_Object");
	cls.allSubclasses(clsColl);
	ignoreCls := schema.getClass("WS_RestProxyObject");
	ignoreRestReq := schema.getClass("WS_RestRequest");
	
	foreach cls in clsColl do
		if cls.inheritsFrom(ignoreCls) or cls.inheritsFrom(ignoreRestReq) then
			continue;
		endif;
		propColl := cls.allProperties;
		foreach prop in propColl do
			if prop.type = TimeStamp then
				tsProps.add(cls.name &amp; "::" &amp; prop.name);
			endif;
			if prop.type = Date then
				dateProps.add(cls.name &amp; "::" &amp; prop.name);
			endif;
		endforeach;
		delete propColl;
	endforeach;
	
	if not tsProps.isEmpty then
		foreach str in tsProps do
			tsMsg := str &amp; CrLf;
		endforeach;
	endif;
	if not dateProps.isEmpty then
		foreach str in dateProps do
			dateMsg := str &amp; CrLf;
		endforeach;
	endif;
	
	self.assertEqualMsg(tsProps.size, 0, "There are TimeStamps!" &amp; CrLf &amp; tsMsg);
	self.assertEqualMsg(dateProps.size, 0, "There are Dates!" &amp; CrLf &amp; dateMsg);	
	
epilog
	delete clsColl;
	delete tsProps;
	delete dateProps;
end;</source>
    </JadeMethod>
    <JadeMethod name="tCrUpDelPrenoteCarrierDAG" id="4103f025-07d3-4ef1-9f19-02edd6e20ac3">
        <source>tCrUpDelPrenoteCarrierDAG();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 September 2018	jlgns1	Initial creation
// 10 Sep 2019	cnwrs1	TFS 46030
*/
vars

	id : String;
	ti : CM_TrackedItem;
	realBulkRelease : CM_BulkRelease ;
	isDoClearanceCheck : Boolean;
begin
	isDoClearanceCheck := self.getMyTerminal.myHarbour.isDoClearanceCheck;
	self.setHarbourIsDoClearanceCheck(false);
	id := "PREU1234564";
	self.webServiceCallWithParams(CM_UnitTestAgent::wsCrUpDelPrenoteCarrierDAG.name, id);
epilog
	self.setHarbourIsDoClearanceCheck(isDoClearanceCheck);
	realBulkRelease :=	self.getTerminal().getBulkReleaseFromCode("WebRel6") ; 

	if realBulkRelease &lt;&gt; null then
		app.myTrxDA.trxDeleteBulkRelease(realBulkRelease,app.myPassport) ; 
	endif ; 	
		
	ti := self.getTerminal.lookupPrenoteByIDExact(id);
	if ti &lt;&gt; null then
		self.deleteTrackedItem(ti, false);
	endif;
end;
</source>
    </JadeMethod>
