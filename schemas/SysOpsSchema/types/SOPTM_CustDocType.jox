    <JadeMethod name="clearThumbnailData" id="bce73f95-ba20-444e-bd63-b70e1e3ef786">
        <updating/>
        <source>clearThumbnailData() updating;
/*
Purpose:			

Date		Who		Reason
04 August 2023	navab1	CR 56093 TASK 59625
*/

vars

	theForm : SOP_TableMaintForm;

begin
  
    theForm := self.myForm;
	
	theForm.tblInput1.clearValues();
	theForm.mulSelect1.setSelected(null);
	
	theForm.tblInput2.clearValues();	
	theForm.mulSelect2.setSelected(null);	
	
	theForm.tblInput3.clearValues();	
	theForm.mulSelect3.setSelected(null);	
	
	theForm.mulSelect6.setSelected(null);	

	inheritMethod();

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="create" id="54a539e0-dd0c-40e5-b908-ae72ed9d7d93">
        <updating/>
        <source>create() updating;
/*
Purpose:			

Date		Who		Reason
04 August 2023	navab1	CR 56093 TASK 59625
*/

vars

begin
	self.name := SOP_TableMaintForm.Table_CustDocsType;
	self.permissionView	 := PmAdmCustDocTypeView;
	self.permissionMaint := PmAdmCustDocTypeMaint;
