    <JadeMethod name="getLoadedWeight" id="d70c7240-0333-47da-afa0-678299b414de">
        <source>getLoadedWeight() : Decimal;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27/02/2025	navkc1 JIRA Bug MTN-12256: MTN - Truck Loader Any Amt Any Id WLE Issue
06 Mar 2025 navma1 MTN-34179 MTN | Dead Lock (1081) on CM_WLEArray
*/

vars
	count 	: Decimal[14,4];
	wle		: CM_WorkListEntry;
begin
	foreach wle in self.workListEntries discreteLock where wle.status = WLE_COMPLETED do
		if wle.myTrackedItem &lt;&gt; null then
			count := count + wle.myTrackedItem.totalWeight;
		endif;
	endforeach;

	return count;
epilog

end;</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
