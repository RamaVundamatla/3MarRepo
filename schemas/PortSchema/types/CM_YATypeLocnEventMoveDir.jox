    <JadeMethod name="getDataDisplay" id="ebb6548b-da88-425a-afd3-c41eaaf97fd6">
        <source>getDataDisplay(_dataObj : CM_YAData): String;
/*
Purpose:			

Date		Who		Reason
24MAY2021	NAVAB1	TFS 51219
*/

vars
	int : Integer;
	displayString : String;

begin
	if _dataObj.isKindOf(CM_YADataPattern) then
		return _dataObj.CM_YADataPattern.getDataDisplay(self);
	endif;

	foreach int in _dataObj.CM_YADataInteger.allValues do
		if displayString = null then
			displayString := app.locnMoveDirEnumToString(int);
		else
			displayString := displayString &amp; ", " &amp; app.locnMoveDirEnumToString(int);
		endif;
	endforeach;
	
	return displayString;
epilog

end;</source>
        <Parameter name="_dataObj" type="CM_YAData"/>
        <ReturnType type="String"/>
    </JadeMethod>
