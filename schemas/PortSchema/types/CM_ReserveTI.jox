    <JadeMethod name="setInterfaceBP" id="dad11077-0bf9-46bb-9def-4b2f0944daa2">
        <updating/>
        <source>setInterfaceBP(_request: CMIF_Request input) updating;
// ---------------------------------------------------------------------------
// Created:		November 2004 By Andrew Bishop cnwab1
//23/06/2023	navkc1	CR 58406 Task 58408: Jade - Release Request All Tracked Items
// ---------------------------------------------------------------------------

vars
	ti : CM_TrackedItem;
begin
	inheritMethod(_request);

	_request.isTIRequest := true;
	_request.quantityTxt := 1;
		
	//ti := self.allTrackedItems.first;
	ti := self.getFirstTI(false); //23/06/2023	navkc1	CR 58406 Task 58408
	
	if ti &lt;&gt; null then
		_request.myTrackedItem 	:= ti;
		_request.isoType 		:= ti.getISOType();
		_request.operatorCode 	:= ti.operatorCode;
	endif;
	
end;</source>
        <Parameter name="_request" type="CMIF_Request" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setMyBOLDtl" id="881fdefa-4393-49a2-be6e-ae8c4a6f4c27">
        <updating/>
        <source>setMyBOLDtl(bolDtl : CM_BOLDtl) updating;
/*****************************************************
Author		: jlgka1 (Karen Alexander)
