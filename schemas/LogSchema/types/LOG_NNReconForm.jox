    <JadeMethod name="addTblLocationsRow" id="da1ccd9b-0f8c-4082-91e7-e3c212f7259e">
        <source>addTblLocationsRow(_sohLoc : CM_SOHLocation; _checked : String);
// ---------------------------------------------------------------------------
// Created:     04 September 2002 by cnwth2
//
// Purpose:     
//
// ----------   ----------  --------------------------------------------------
// 24/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
vars
	rowIdx	: Integer;
	product	: CM_ProductLog;
	operCode : String;
begin
	product := _sohLoc.myProduct.CM_ProductLog;
	
	if _sohLoc.myOperator &lt;&gt; null then
		operCode := _sohLoc.myOperator.code;
	endif;
	
	rowIdx := self.tblLocations.addItem(_checked &amp; Tab &amp;
										_sohLoc.myLocationsController.getID &amp; Tab &amp;
										operCode &amp; Tab &amp;
										product.code &amp; Tab &amp;
										_sohLoc.numTIs.String &amp; Tab &amp;
										_sohLoc.currentVolume.jasVolumeString &amp; Tab &amp;
										_sohLoc.getAllAssignedVoyageCodes);
	self.tblLocations.accessRow(rowIdx).itemObject := _sohLoc;
end;</source>
        <Parameter name="_sohLoc" type="CM_SOHLocation"/>
        <Parameter name="_checked" type="String"/>
    </JadeMethod>
    <JadeMethod name="addTblNNSummaryRow" id="c2b05918-a869-489a-991f-d66cc9c84180">
        <source>addTblNNSummaryRow(_nnLog : CMIF_LogNNReconDtl);
// ---------------------------------------------------------------------------
// Created:     30 August 2002 by cnwth2
//
// Purpose:     
//
// ----------   ----------  --------------------------------------------------
// 24/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls

vars
	operCode : String;
	rowIdx	: Integer;
begin
	if _nnLog.myOperator &lt;&gt; null then
		operCode := _nnLog.myOperator.code;
	endif;
	rowIdx := self.tblNNSummary.addItem(operCode &amp; Tab &amp;
										_nnLog.myProductLog.code &amp; Tab &amp;
										_nnLog.allNoNumberLogs.size.String &amp; Tab &amp;
										_nnLog.residualPieceCount.String &amp; Tab &amp;
										_nnLog.residualVolume.jasVolumeString);
	
	self.tblNNSummary.accessRow(rowIdx).itemObject := _nnLog;
end;</source>
        <Parameter name="_nnLog" type="CMIF_LogNNReconDtl"/>
    </JadeMethod>
    <JadeMethod name="addToolbarControls" id="c2e66e2e-968e-4c5e-a716-51589d6ffe4f">
        <updating/>
        <source>addToolbarControls() updating, protected;

vars
	toolbar	: CMUI_Toolbar;
	
begin
	inheritMethod();

	toolbar := self.frmToolbar;
	
	toolbar.addButton(self.btnSaveBase, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnNext, CMUI_Toolbar.Control_Alignment_Left);//par 11631
	toolbar.addButton(self.btnSelectAllT, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnCancelBase, CMUI_Toolbar.Control_Alignment_Right);
end;</source>
        <access>protected</access>
    </JadeMethod>
