    <JadeMethod name="checkTIUserAccessRights" id="a6f7d841-0dc5-42ab-9e68-0b99910cd19c">
        <source>checkTIUserAccessRights(ti : CM_TrackedItem ) : Boolean;

vars

begin

	if ti = null then
		return false;
	elseif app.isSpecial() then
		return true;
	elseif ( null &lt;&gt; cmsOperatorsDict.getAtKey( ti.operatorCode )) then
			return true;
	elseif ( null &lt;&gt; cmsCarriersDict.getAtKey( ti.carrier )) then
			return true;
    elseif ( null &lt;&gt; cmsConsignDict.getAtKey( ti.consignee )) or
		   ( null &lt;&gt; cmsConsignDict.getAtKey( ti.consignor )) then
			return true;
	endif;
    return false;
end;</source>
        <Parameter name="ti" type="CM_TrackedItem"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="create" id="a9192f6d-694c-4ecb-8742-22e11f970686">
        <updating/>
        <source>create() updating;

vars

begin
   webAccessIsEnabled := false;
end;</source>
    </JadeMethod>
    <JadeMethod name="displaySelf" id="fadb5cda-e286-45f7-b6c6-56c9bc540aae">
        <updating/>
        <source>displaySelf(): String updating;

vars
	x:          Integer;
    strReturn:  String;
    str:        String;
    iter:       Iterator;
    o:          Object;
	arrCodes:   StringArray;
begin
	create arrCodes transient;

	strReturn := strReturn &amp; CrLf;
	strReturn := strReturn &amp; "Your Web Access Rights are as follows : " &amp; CrLf &amp; CrLf;

/*    if getUserClassCode = SUPERCLASS_USER then		//Can see the lot regardless of set up dicts !
    	strReturn := strReturn &amp; "You have Full Superclass Access" &amp; CrLf &amp; CrLf;
		strReturn := strReturn &amp; "You can see Data for All Operators:" &amp; CrLf &amp; CrLf;
		strReturn := strReturn &amp; "You can see Data for All Carriers:" &amp; CrLf &amp; CrLf;
		strReturn := strReturn &amp; "You can see Data for All Consignor / Consignees:" &amp; CrLf &amp; CrLf;
		return strReturn;
    endif;
*/
    if cmsOperatorsDict.size &gt; 0 then
    	getOperatorCodes(arrCodes);

		strReturn := strReturn &amp; "You can see Data for Operators:" &amp; CrLf &amp; CrLf;
	    x := 1;
	    foreach str in arrCodes do
	    	strReturn := strReturn &amp; str &amp; ', ';
	    	if x mod 8 = 0 then
	    		strReturn := strReturn &amp; CrLf;
	    	endif;
	    	x := x + 1;
	    endforeach;
	    strReturn := strReturn &amp; CrLf &amp; CrLf &amp; CrLf;
    endif;

    if cmsCarriersDict.size &gt; 0 then
    	getCarrierCodes(arrCodes);

		strReturn := strReturn &amp; "You can see Data for Carriers:" &amp; CrLf &amp; CrLf;
	    x := 1;
	    foreach str in arrCodes do
	    	strReturn := strReturn &amp; str &amp; ', ';
	    	if x mod 4 = 0 then
	    		strReturn := strReturn &amp; CrLf;
	    	endif;
	    	x := x + 1;
	    endforeach;
	    strReturn := strReturn &amp; CrLf &amp; CrLf &amp; CrLf;
    endif;

    if cmsConsignDict.size &gt; 0 then
    	getConsignorCodes(arrCodes);

		strReturn := strReturn &amp; "You can see Data for Consignor/Consignee:" &amp; CrLf &amp; CrLf;
	    x := 1;
	    foreach str in arrCodes do
	    	strReturn := strReturn &amp; str &amp; ', ';
	    	if x mod 8 = 0 then
	    		strReturn := strReturn &amp; CrLf;
	    	endif;
	    	x := x + 1;
	    endforeach;
	    strReturn := strReturn &amp; CrLf &amp; CrLf &amp; CrLf;
    endif;

	return strReturn;

epilog
	delete arrCodes;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getCarrierCodes" id="1e5a43ae-d5a1-4cb6-bc14-70ab7c8af03a">
        <updating/>
        <source>getCarrierCodes(arrCodes: StringArray input) updating;

vars

begin
	on Exception do handleDictionaryException(exception);

	if getDictCodes(arrCodes, Carrier_Dict) = Dictionary_Error then
		beginTransaction;
		cmsCarriersDict.removeInvalidObjects;
		app.cmsCommitTransaction(app.myPassport);
		getDictCodes(arrCodes, Carrier_Dict);
	endif;
end;</source>
        <Parameter name="arrCodes" type="StringArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getConsignorCodes" id="c248f494-4096-4269-8501-ea7f8fcaebdd">
        <updating/>
        <source>getConsignorCodes(arrCodes: StringArray input) updating;

vars

begin
	on Exception do handleDictionaryException(exception);

	if getDictCodes(arrCodes, Consign_Dict) = Dictionary_Error then
		beginTransaction;
		cmsConsignDict.removeInvalidObjects;
		app.cmsCommitTransaction(app.myPassport);
		getDictCodes(arrCodes, Consign_Dict);
	endif;
end;</source>
        <Parameter name="arrCodes" type="StringArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getDictCodes" id="86458395-3485-4907-9425-8b6bd573ece5">
        <source>getDictCodes(arrCodes: StringArray input; dictString: String): Integer protected;

vars
	carrier:   CM_Carrier;
	consign:   CM_ConsigneeConsignor;
	operator:   CM_Operator;
begin
	arrCodes.clear;

	if dictString = Operator_Dict then
	    foreach operator in cmsOperatorsDict do
	    	arrCodes.add(operator.code);
	    endforeach;
	elseif dictString = Carrier_Dict then
	    foreach carrier in cmsCarriersDict do
	    	arrCodes.add(carrier.code);
	    endforeach;
	elseif dictString = Consign_Dict then
	    foreach consign in cmsConsignDict do
	    	arrCodes.add(consign.code);
	    endforeach;
	endif;

epilog
	if process.isInExceptionState then
		return Dictionary_Error;
	else
		return 0;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="arrCodes" type="StringArray" usage="input"/>
        <Parameter name="dictString" type="String"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getOperatorCodes" id="c380c05e-3252-4aa8-a347-d89c75df2611">
        <updating/>
        <source>getOperatorCodes(arrCodes: StringArray input) updating;

vars

begin
	on Exception do handleDictionaryException(exception);

	if getDictCodes(arrCodes, Operator_Dict) = Dictionary_Error then
		beginTransaction;
		cmsOperatorsDict.removeInvalidObjects;
		app.cmsCommitTransaction(app.myPassport);
		getDictCodes(arrCodes, Operator_Dict);
	endif;
end;</source>
        <Parameter name="arrCodes" type="StringArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getUserName" id="01c679be-2288-4d42-bda9-087a41033215">
        <source>getUserName() : String;

vars

begin
    if cmUser &lt;&gt; null then
    	return cmUser.userName;
    else
    	return "Unknown";
    endif;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="handleDictionaryException" id="dcc7fb3a-1abc-4e1f-a164-1894383f0220">
        <updating/>
        <source>handleDictionaryException(except: Exception): Integer updating;

vars

begin
	if except.errorCode = 4 then
		return Ex_Resume_Next;
	else
		return Ex_Pass_Back;
	endif;
end;</source>
        <Parameter name="except" type="Exception"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setWebAccessIsEnabled" id="60ee7cd7-9a9e-41d0-9d47-5c47b17e8f93">
        <updating/>
        <source>setWebAccessIsEnabled( setTo : Boolean ) updating;

vars

begin
    webAccessIsEnabled := setTo;
end;</source>
        <Parameter name="setTo" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setcmsCarriers" id="b3f6299d-1550-499b-8069-3c3848894549">
        <updating/>
        <source>setcmsCarriers( valuesToAdd : StringArray; refCarriers : CM_CarrierByCodeDict ) updating;

vars
	tmp     : String;
    lc,
    x       : Integer;

begin
	cmsCarriersDict.clear();
    x       := 1;
    lc      := valuesToAdd.size;
    while x &lt;= lc do
    	tmp := valuesToAdd.at(x);
    	if ( refCarriers.includesKey( tmp.String )) then
            cmsCarriersDict.add( refCarriers.getAtKey( tmp.String ));
    	endif;
    	x := x + 1;
    endwhile;
end;</source>
        <Parameter name="valuesToAdd" type="StringArray"/>
        <Parameter name="refCarriers" type="CM_CarrierByCodeDict"/>
    </JadeMethod>
