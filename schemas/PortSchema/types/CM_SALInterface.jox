    <JadeMethod name="getTaxCodeForInvoiceLine" id="8c0fd5dc-dca1-47aa-a93d-e63eb4ce50a5">
        <source>getTaxCodeForInvoiceLine(_invoiceLine : CM_InvoiceLine) : CM_TaxCode protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 March 2022	jlier1	Initial creation 53286

*/

vars
	service : CM_Service;
begin
	if _invoiceLine = null then
		return null;
	endif;
	
	if _invoiceLine.invoiceLineDesc &lt;&gt; null then
		service := _invoiceLine.invoiceLineDesc.services.first;
	endif;
	
	if service &lt;&gt; null then
		return service.myTaxCode;
	endif;
	
	return null;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_invoiceLine" type="CM_InvoiceLine"/>
        <ReturnType type="CM_TaxCode"/>
    </JadeMethod>
    <JadeMethod name="validateInvoiceToExport" id="c786fd87-87c4-4043-ad7b-184560e252d0">
        <source>validateInvoiceToExport(_status : Integer; _invoice : CM_Invoice);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 April 2022	jlier1	Initial creation 53286

*/

vars

begin
	if _status = CM_Invoice.INVOICE_POSTED or _status = CM_Invoice.INVOICE_POSTED_REVERSE then
		if _invoice.status &lt;&gt; CM_Invoice.INVOICE_POSTED and _invoice.status &lt;&gt;  CM_Invoice.INVOICE_POSTED_REVERSE   then
			//raise exeption
			app.raiseCMException1(Not_expor_invoi_must_poste_pos, _invoice.sequenceNum.String,null,null);
		endif;
	elseif _status = CM_Invoice.INVOICE_POSTED_CREDIT then
		if _invoice.status &lt;&gt; CM_Invoice.INVOICE_POSTED_CREDIT then
			//raise exeption
			app.raiseCMException1(Not_expor_invoi_must_poste_cre,_invoice.sequenceNum.String,null,null);
		endif;
	else
		//raise exception
		app.raiseCMException2(Not_export_invoic_with_status,_invoice.sequenceNum.String,_invoice.getStatusDescriptionForSelf, null,null);
	endif;

	
epilog

end;</source>
        <Parameter name="_status" type="Integer"/>
        <Parameter name="_invoice" type="CM_Invoice"/>
    </JadeMethod>
    <JadeMethod name="writeInvoiceLinesToFile" id="76aa39db-d3f1-47fd-8778-4a7541fbdee6">
        <source>writeInvoiceLinesToFile(  _file : File input; coll : Collection  input; _createISegment : Boolean) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 April 2022	jlier1	Initial creation 53286

*/

vars
	invoiceLine : CM_InvoiceLine;
	invoiceLines : CM_InvoiceLineSet;
	taxCode : CM_TaxCode;
	theTaxCode, currentTaxCode, lastTaxCode : String;
	iter : Iterator;
	itemID : Integer;
begin
	create invoiceLines transient;
	iter:=coll.createIterator;
	taxCode:=self.getTaxCodeForInvoiceLine(coll.first.CM_InvoiceLine);
	if taxCode &lt;&gt; null then
		lastTaxCode:=taxCode.externalReference1;
	endif;
	while iter.next(invoiceLine) do
		iter.getCurrentKeys(currentTaxCode);
		
		if currentTaxCode &lt;&gt; lastTaxCode then
			if _createISegment then
				self.createISegment(invoiceLines , _file,lastTaxCode);
			else
				self.createTSegment(invoiceLines , _file,lastTaxCode);
			endif;	
			invoiceLines.clear;	
			lastTaxCode:=currentTaxCode;
		endif;
		
		invoiceLines.add(invoiceLine);		
	endwhile;
	
	if invoiceLines.size &gt;  0 then
		theTaxCode:=null;
		taxCode:=self.getTaxCodeForInvoiceLine(invoiceLines.first);
		if taxCode &lt;&gt; null then
			theTaxCode:=taxCode.externalReference1;
		endif;
		if _createISegment then
			
			self.createISegment(invoiceLines , _file,theTaxCode);
		else
			self.createTSegment(invoiceLines , _file,theTaxCode);
		endif;
		invoiceLines.clear;	
	endif;
	
epilog
	delete invoiceLines;
	delete iter;
end;</source>
        <access>protected</access>
        <Parameter name="_file" type="File" usage="input"/>
        <Parameter name="coll" type="Collection" usage="input"/>
        <Parameter name="_createISegment" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="writeInvoiceToFile" id="f5cca02a-3590-446e-adb1-a8c46160b609">
        <source>writeInvoiceToFile(_invoice : CM_Invoice; _file : File input) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 Mar 2022	jlier1	Initial creation 53286
26 Apr 2022	jlier1	TFS 53477
*/

vars
	invoiceLinesByTaxCode,
	invoiceLinesByTariff : DynaDictionary;
	invoiceLine : CM_InvoiceLine;
	taxCode : CM_TaxCode;
	theTaxCode, tariff,lastTariff : String;
	iter : Iterator;
	sequence  : Integer;
	invoiceLineDesc : CM_InvoiceLineDesc;
	invoiceLines : CM_InvoiceLineSet;
	fileData : String;
begin
	if _file = null or _invoice = null then
		return;
	endif;
	
	create invoiceLinesByTaxCode transient;
	invoiceLinesByTaxCode.setMembership(CM_InvoiceLine);
	invoiceLinesByTaxCode.addExternalKey(String,200,false,true);
	invoiceLinesByTaxCode.endKeys(true);
	
	create invoiceLinesByTariff transient;
	invoiceLinesByTariff.setMembership(CM_InvoiceLine);
	invoiceLinesByTariff.addExternalKey(String,200,false,true);
	invoiceLinesByTariff.endKeys(true);
	
	foreach invoiceLine in _invoice.invoiceLinesByDateTime discreteLock  do
		if invoiceLine.lineTotal = 0 then
			continue;
		endif;
		theTaxCode:=null;
		tariff:=null;
		taxCode:=self.getTaxCodeForInvoiceLine(invoiceLine);
		if taxCode &lt;&gt; null then
			theTaxCode:=taxCode.externalReference1[1:200];
		endif;
		invoiceLinesByTaxCode.putAtKey(theTaxCode,invoiceLine);	
		invoiceLineDesc:=invoiceLine.invoiceLineDesc;
		if invoiceLineDesc &lt;&gt; null then
			tariff:=invoiceLineDesc.narration;
		endif;
		invoiceLinesByTariff.putAtKey(tariff,invoiceLine);	
	endforeach;
	
	if invoiceLinesByTaxCode.size = 0  then
		return;
	endif;
	//jlier1 TFS 53738 31/5/22
	self.createHSegment(_invoice,invoiceLinesByTariff.first.CM_InvoiceLine, _file);
	
	//write all the I segments
	self.writeInvoiceLinesToFile(_file,invoiceLinesByTaxCode, true);
	
	//write all the P segments
	iter:=invoiceLinesByTariff.createIterator;
	invoiceLineDesc:=invoiceLinesByTariff.first.CM_InvoiceLine.invoiceLineDesc;
	if  invoiceLineDesc &lt;&gt; null then
		lastTariff:=invoiceLineDesc.narration;
	endif;
	create invoiceLines transient;
	sequence:=1;
	while iter.next(invoiceLine) do
		iter.getCurrentKeys(tariff);
		if tariff &lt;&gt; lastTariff then
				
			self.createPSegment(invoiceLines,_file,sequence.asStringJMT);
			sequence:=sequence + 1;
			invoiceLines.clear;	
			lastTariff:=tariff;
		endif;	
		invoiceLines.add(invoiceLine);				
	endwhile;
	
	if invoiceLines.size &gt;  0 then
		self.createPSegment(invoiceLines,_file,sequence.asStringJMT);
		invoiceLines.clear;
	endif;
	
	//write all the T segments
	self.writeInvoiceLinesToFile(_file,invoiceLinesByTaxCode, false);
	
	/* questioning the need to get rid of the CrLf
	
	_file.seek(0);
	fileData:=_file.readString(_file.fileLength);
	if fileData[fileData.length] = Cr or 
		fileData[fileData.length] = Lf then
		fileData:=fileData[1:fileData.length-1];
	endif;
	if fileData[fileData.length] = Cr or 
		fileData[fileData.length] = Lf then
		fileData:=fileData[1:fileData.length-1];
	endif;
	_file.purge;
	_file.writeString(fileData);*/
	//_file.endOfFile:=_file.
	
epilog
	delete invoiceLinesByTaxCode;
	delete invoiceLinesByTariff;
	delete invoiceLines;
	delete iter;
end;</source>
        <access>protected</access>
        <Parameter name="_invoice" type="CM_Invoice"/>
        <Parameter name="_file" type="File" usage="input"/>
    </JadeMethod>
</Class>
