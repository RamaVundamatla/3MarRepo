    <JadeMethod name="setupContextMenuItems" id="b9a0ce48-742c-47be-9c09-1438ac7497b2">
        <updating/>
        <source>setupContextMenuItems(conwin: Window input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 July 2009	cnwndl1	Initial creation

*/

vars

	theForm : SOP_TableMaintForm;
	tmpMenu : MenuItem;
	wagonClass : CM_WagonClass;
	
begin

	inheritMethod(conwin);
	
	theForm := self.myForm;
	if theForm.mode &lt;&gt; SOP_TableMaintForm.Mode_View then
		return;
	endif;
	
	//07 Jun 2013	NDL	Par 31676
	if theForm.myCurrentObject &lt;&gt; null and theForm.myCurrentObject.isKindOf(CM_WagonClass) then
		wagonClass := theForm.myCurrentObject.CM_WagonClass;
	endif;
	if wagonClass = null or wagonClass.isBoxcar then
		theForm.mnuContext1.visible	:= false;
		return;
	endif;
		
	theForm.mnuContext1.visible	:= true;
	theForm.mnuContext1.caption	:= app.getErrorString(Edit_wagon_weigh_load_posit_ru);
	tmpMenu := theForm.cloneMenu(theForm.mnuTblVCloneDataTbl, theForm.mnuContext1, false);

epilog

end;</source>
        <Parameter name="conwin" type="Window" usage="input"/>
    </JadeMethod>
