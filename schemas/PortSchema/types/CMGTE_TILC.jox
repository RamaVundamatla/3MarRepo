    <JadeMethod name="actionForCreateInternal" id="94f8a692-cf80-49ef-a2d0-afbd21d00774">
        <updating/>
        <source>actionForCreateInternal(_vvRec : CM_VehicleVisitRecord input; _passport: CM_Passport input; _pxyTI: CM_TrackedItem input): Boolean updating, protected;

/*

 cnwjk3 CCMS1035 04/10/09
 Code added to move cargo to chassis when chassis is moved

*/
// Changed On   	Changed By  	Reason
// 11/01/2022		navpw1			TFS: 52631 Added Backdating for VVR transactions

vars
	result : Boolean;
	vvr		: CM_VehicleVisitRecord;
	pxyChasssis,
	chassis	: CMGTE_Release;
begin
	return inheritMethod(_vvRec, _passport, _pxyTI);
	
	if not result then
		return false;
	endif;
	
	if self.imexStatus &lt;&gt; TI_IMEX_STATUS_REMAINONBOARD then
		return true;
	endif;
	
	vvr:=self.myVehicleVisitRecord;
	
/*
	create pxyChasssis transient;	
	pxyChasssis.setPxyFromTI(self.myTrackedItem);
 	pxyChasssis.setJobQueueNum(2);	

	create chassis persistent;
	chassis.setForCreate(pxyChasssis, self.myVehicleVisitRecord);
	return chassis.actionForCreate(self.myVehicleVisitRecord,_passport,null);
	*/
epilog

	delete pxyChasssis;
end;</source>
        <access>protected</access>
        <Parameter name="_vvRec" type="CM_VehicleVisitRecord" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <Parameter name="_pxyTI" type="CM_TrackedItem" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
