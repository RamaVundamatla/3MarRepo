/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 Sep 2021 navma1 ChangeRequest 51002: MTN - Web Portal Cargo Work Orders
12 Apr 2023 navma1 ChangeRequest 57569:[57570] EUP - [Framework] Refactor Actioning Work Order Tasks
*/

vars

begin
	//return (self.myParent.id.String &amp; '-' &amp; self.getDisplayString(true)).String[1:30]; //12.04.2023 navma1 #57569:[57570]
	return self.taskID;																	 //12.04.2023 navma1 #57569:[57570]
	
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getLastTransOfType" id="a4e5ca8b-12f5-4741-a1f0-0e8ca98ae7f1">
        <source>getLastTransOfType(_transType : Integer) : CM_WOTransaction;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 March 2023	navhl20	ChangeRequest 56614:[56615] EUP - Allow Multi ToDo Tasks Description on Cargo ToDo Work Order

*/

vars
	trans : CM_WOTransaction;
begin
	foreach trans in self.allWODtlTransactions reversed where trans.type = _transType do
	/* // ### JIRA 14793
		 // ### TFS CR 54345 TASK 58281 14JUN2023 NAVAB1 - if it has a to do task then it is for the to to task not the work order detail
		if trans.myToDoTask &lt;&gt; null then
			continue;
		endif;
*/
		return trans;	
	endforeach;
	
	return null;
epilog

end;</source>
        <Parameter name="_transType" type="Integer"/>
        <ReturnType type="CM_WOTransaction"/>
    </JadeMethod>
    <JadeMethod name="getLongDescription" id="bc4e127d-96d8-4eb8-8495-36a0de6dfa24">
        <source>getLongDescription(_typeDesc , _extraDesc : String):String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 Sep 2021 navma1 ChangeRequest 51925: SAL - Web Portal Cargo Work Orders

*/

vars
	longDesc : String;
begin
	
	longDesc := "(" &amp; taskID.String &amp; ")" &amp; Space &amp; _typeDesc;
	
	if _extraDesc &lt;&gt; null then
		longDesc := longDesc  &amp; Space &amp; _extraDesc;
	endif;
	
	return longDesc;
epilog

end;</source>
        <Parameter name="_typeDesc" type="String"/>
        <Parameter name="_extraDesc" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getMesurementTypeValues" id="58329b1c-a857-44d3-aef5-b9e9085f3096">
        <source>getMesurementTypeValues(_type : String ;_value : Decimal) : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 Jan 2021 navma1	Bug 52681: SAL - Display of Total Weight in Kgs in macro information - Cargo/Permit request

*/

vars
	valueString 	 	  : String;
	wod				 	  : CM_WodCargoRequest;
	product	   		 	  : CM_Product;
	cargoType 		 	  : CM_CargoType;
	measurementType  	  : CM_MeasurementType;	
	measurementTypeString : String;
begin
	
	if self.isKindOf(CM_WodCargoRequest) then
		wod := self.CM_WodCargoRequest;
		
		cargoType := wod.myCargoType;
		product	  := wod.myCargoSubType;
			
		if product &lt;&gt; null then
			measurementType:=product.getDefaultMeasurementForType(_type);
		elseif cargoType &lt;&gt; null then
			measurementType:=cargoType.getDefaultMeasurementForType(_type);
		else
			measurementType:=app.getDefaultMeasurementForType(_type);
		endif;
		
		if measurementType &lt;&gt; null then
			measurementTypeString:=measurementType.shortName;
		endif;	
		
		if measurementTypeString &lt;&gt; null  then
			valueString:=app.convertMeasurementForDisplay(measurementTypeString,_value ) &amp; Space &amp; measurementTypeString;
		else
			valueString:= _value.asStringMeasurementJMT();
		endif;
		
	endif;

	return valueString ;
epilog

end;</source>
        <Parameter name="_type" type="String"/>
        <Parameter name="_value" type="Decimal"/>
        <ReturnType type="String"/>
    </JadeMethod>
