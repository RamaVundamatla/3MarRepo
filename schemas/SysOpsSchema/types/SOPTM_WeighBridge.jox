	self.loadCombos();

end;</source>
    </JadeMethod>
    <JadeMethod name="setGateLaneWeighbridge" id="982008e1-5a0a-4111-8695-977ed968b617">
        <updating/>
        <source>setGateLaneWeighbridge( _gateALaneController : CM_GateAreaLaneController; _weighbridge : CM_WeighBridgeObj ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 March 2017	cnwns1	Initial creation

*/

vars
	gate : CM_Gate;
	objectSet : CM_ObjectSetActual;
	lObject : CM_Object;
	gateLaneCont :	CM_GateAreaLaneController;
begin
	if _gateALaneController = null then
		return;
	endif;

	if _weighbridge &lt;&gt; null then
		create objectSet transient;
	
		foreach gate in self.myForm.myTerminal.allGates do
			gate.getAllGALaneControllers(objectSet,Both);
			foreach lObject in objectSet do
				gateLaneCont :=	lObject.CM_GateAreaLaneController;
				if gateLaneCont.getWeighBridge = _weighbridge then
					gateLaneCont.setWeighBridge(null);
				
				endif;
			endforeach;	
		endforeach;
		delete objectSet;
	endif;
	
	//set to Value

	_gateALaneController.setWeighBridge(_weighbridge);
	
epilog

end;</source>
        <Parameter name="_gateALaneController" type="CM_GateAreaLaneController"/>
        <Parameter name="_weighbridge" type="CM_WeighBridgeObj"/>
    </JadeMethod>
    <JadeMethod name="setupContextMenuItems" id="10de9365-aed0-4bff-9d65-115b78d4dd18">
        <updating/>
        <source>setupContextMenuItems(conwin: Window input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 March 2014	cnwndl1	Initial creation	Par 22268

*/

vars

	theForm 	: SOP_TableMaintForm;
	tmpMenu		: MenuItem;
	weighBridge : CM_WeighBridgeObj;

begin

	inheritMethod( conwin );
	theForm := self.myForm;
	
	theForm.mnuContext1.enabled := false;
	theForm.mnuContext1.visible := true;
	theForm.mnuContext1.caption := "Test Connection";
	
	if theForm.mode &lt;&gt; theForm.Mode_Add then
		weighBridge := theForm.myProxyObject.CM_WeighBridgeObj;
		if weighBridge = null then
			weighBridge := theForm.myCurrentObject.CM_WeighBridgeObj;
		endif;
		if weighBridge &lt;&gt; null and not weighBridge.isSerialPort then
			theForm.mnuContext1.enabled := true;
		endif;
	endif;
		
	tmpMenu := theForm.cloneMenu( theForm.mnuTblVCloneDataTbl, theForm.mnuContext1, false ); 	
	
	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(theForm.myTerminal, self.permissionMaint) then
		tmpMenu.enabled:= false;
	endif;

end;</source>
        <Parameter name="conwin" type="Window" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setupThumbnailDetails" id="af5698cc-ec07-4e79-b2a1-862d600fe0e8">
        <updating/>
        <source>setupThumbnailDetails() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 March 2014	cnwndl1	Initial creation	Par 33268
21 02 17 cnwns1 TFS3153:PKT - Bulk Process - WeighBridge Integration
*/

vars

	theForm : SOP_TableMaintForm;
	
begin
  
  	theForm := self.myForm;
	theForm.useProxyObject := true;
	
	theForm.setTblDataEntRows(ETDef_WeighBridge);
	
	theForm.shtTblInput1.caption := app.getErrorString(Details);
	theForm.initTblInput(theForm.tblInput1, ETDef_WeighBridge);
	theForm.shtTblInput1.visible := true;
	
	self.myForm.btnSerialConn.visible:=true;	//TFS3153

end;</source>
    </JadeMethod>
    <JadeMethod name="showThumbnail" id="77c7b11f-d9b1-4fd2-877b-2563caed5180">
        <updating/>
        <source>showThumbnail(pObj: CM_WeighBridgeObj) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 March 2014	cnwndl1	Initial creation	Par 33268
//22/01/17 cnwns1 TFS3153:PKT - Bulk Process - WeighBridge Integration
*/

vars
	theForm : SOP_TableMaintForm;
	measureType : CM_MeasurementType;
	
begin
  
    theForm := self.myForm;
	theForm.tblInput1.clearValues;
	
	theForm.loadCmbWBridgeType();
	theForm.loadCmbGateLane();

	theForm.tblInput1.setValueByName(ETRow_Name, pObj.name);
	theForm.tblInput1.setValueByName(ETRow_IpAddress, pObj.ipAddress);
	theForm.cmbWBridgeType.listIndex := theForm.cmbWBridgeType.findObject( pObj.myWeighBridgeType );
	theForm.tblInput1.setValueByName(ETRow_WeighBridgeType, pObj.myWeighBridgeType.code);
	theForm.tblInput1.setValueByName(ETRow_PortNumber, pObj.portNumber);
	theForm.tblInput1.setValueByName(ETRow_TimeOutSeconds, pObj.timeOutSeconds);
	theForm.tblInput1.setValueByName(ETRow_AutoRequest, pObj.autoRequest);		
	theForm.tblInput1.setValueByName(ETRow_ComputerName, pObj.computerName);	//TFS 3153
	theForm.tblInput1.setValueByName(ETRow_DeviceAddress, pObj.deviceAddress);	//25 May 2017	NDL	TFS 4383
	theForm.tblInput1.setValueByName(ETRow_CanUpdateRTS, pObj.canUpdateRTS);	//11 May 2020	NDL	TFS 49296
	
	if pObj.myGateLane &lt;&gt; null then																//TFS 3153
		theForm.cmbGateLane.listIndex := theForm.cmbGateLane.findObject( pObj.myGateLane);		//TFS 3153
		theForm.tblInput1.setValueByName(ETRow_MyGateLane, pObj.myGateLane.getGateLaneNumber);	//TFS 3153
	else
		theForm.cmbGateLane.listIndex := theForm.cmbGateLane.findObject( null);		//TFS 3153
		theForm.tblInput1.setValueByName(ETRow_MyGateLane, null);	//TFS 3153
	endif;																						//TFS 3153
	
	theForm.tblInput1.setValueByName(ETRow_CargoUpdateMode, pObj.getCargoUpdateModeStr);	//05 Jul 2019	NDL	TFS 44965
	theForm.cmbUpdatedAfter.listIndex := theForm.cmbUpdatedAfter.findStringExact(1,pObj.getCargoUpdateModeStr);	//05 Jul 2019	NDL	TFS 44965
	
	//16 Jul 2021	NDL	Bug found while doing TFS 51575
	measureType := pObj.myWeightType;
	if measureType &lt;&gt; null then
		theForm.cmbMeasureUnit.listIndex := theForm.cmbMeasureUnit.findObject( measureType );
	else
		theForm.cmbMeasureUnit.listIndex := -1;
	endif;
	theForm.tblInput1.setValueByName(ETRow_WeightUnit,theForm.cmbMeasureUnit.text);
	theForm.tblInput1.setValueByName(ETRow_DeviceID, pObj.deviceId);	// ### TFS 52773 1APR2022 NAVPW1
	
	self.changeViews(pObj.myWeighBridgeType.code);	
	theForm.btnSerialConn.enabled := pObj.isSerialPort;//TFS3153:PKT - Bulk Process - WeighBridge Integration
	

end;</source>
        <Parameter name="pObj" type="CM_WeighBridgeObj"/>
    </JadeMethod>
</Class>
