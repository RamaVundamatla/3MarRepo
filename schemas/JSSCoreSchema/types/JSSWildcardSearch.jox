    <DbClassMap file="jsscore_searcher"/>
    <Constant name="ASTERISK" id="e32e06d6-e9c5-4db4-8743-6c0c568334be">
        <source>"*"</source>
        <type name="String"/>
    </Constant>
    <Constant name="QUESTION_MARK" id="9b8f351a-56c8-4773-9d0d-fe48b9e8f115">
        <source>"?"</source>
        <type name="String"/>
    </Constant>
    <ImplicitInverseRef name="allSearchResults" id="e69a20ec-9f45-468b-a2f5-3f1684d8b57a">
        <memberTypeInverse/>
        <type name="JSSArray"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="allSearchValues" id="d9d1279b-9ca7-4cf9-9571-15ff70356293">
        <memberTypeInverse/>
        <type name="JSSArray"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="allWildcardTokens" id="f9892d17-9e51-4913-937d-1e5b08a2b51c">
        <memberTypeInverse/>
        <type name="JSSArray"/>
        <access>protected</access>
    </ImplicitInverseRef>
    <PrimAttribute name="isCaseSensitive" id="79256fca-0a01-4258-9998-84211133d46b">
        <embedded/>
        <type name="Boolean"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="addMultipleSearchValues" id="0d453660-c150-4131-b450-fc3d127455be">
        <source>addMultipleSearchValues(pAllSearchValues:JSSArray);
// --------------------------------------------------------------------------------
// Created:		21 January 2002 by cnwdad1
//
// Purpose:		Adds multiple search strings to the allSearchValues array.
//
// Parameters:	pAllSearchValues - The array of strings to be added to the value array.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theSearchString	: JSSElement;
	
begin
	self.allSearchValues.purge();
	
	foreach theSearchString in pAllSearchValues do
		self.allSearchValues.addString(theSearchString.stringValue);
	endforeach;
end;</source>
        <Parameter name="pAllSearchValues" type="JSSArray"/>
    </JadeMethod>
    <JadeMethod name="addSearchValue" id="f08a4a6f-2f9e-4cbf-b6a9-81acdb616d52">
        <source>addSearchValue(pSearchValue:String);
// --------------------------------------------------------------------------------
// Created:		21 January 2002 by cnwdad1
//
// Purpose:		Adds the specified search string to the allSearchValues array.
//
// Parameters:	pSearchValue - The string to be added to the value array.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.allSearchValues.addString(pSearchValue);
end;</source>
        <Parameter name="pSearchValue" type="String"/>
    </JadeMethod>
    <JadeMethod name="clearSearchValues" id="7da74086-d1b2-4041-9058-3a97ffd52a29">
        <source>clearSearchValues();
// --------------------------------------------------------------------------------
// Created:		21 January 2002 by cnwdad1
//
// Purpose:		Clears all search string values from the allSearchValues array.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.allSearchValues.purge();
end;</source>
    </JadeMethod>
    <JadeMethod name="doMultiSearch" id="87165dd1-325d-4ac8-9770-574e82a285db">
        <source>doMultiSearch():Boolean;
// --------------------------------------------------------------------------------
// Created:		21 January 2002 by cnwdad1
//
// Purpose:		Searches all string in the allSearchValues array, using the wildcards
//				that have been set up using the parseTokens() method.
//
//				All search values with a successful match will be added to the
//				allSearchResults array.
//
// Parameters:	None
//
// Returns:		True if any values were successfully matched, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	stringElementObj	: JSSElement;
	isSuccessful		: Boolean;
	
begin
	isSuccessful	:=	false;
	self.allSearchResults.purge();
	
	foreach stringElementObj in self.allSearchValues do
		if self.doSearch(stringElementObj.stringValue) then
			self.allSearchResults.add(stringElementObj);
			
			if (not isSuccessful) then
				isSuccessful	:=	true;
			endif;
		endif;
	endforeach;
epilog
	return isSuccessful;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSearch" id="6f81430c-3ea2-453e-905d-4daedbc36771">
        <source>doSearch(pInString:String):Boolean;
// --------------------------------------------------------------------------------
// Created:		21 January 2002 by cnwdad1
//
// Purpose:		Searches the specified string using the wildcards that have been
//				set up using the parseTokens() method.
//
// Parameters:	pInString - The string value to search.
//
// Returns:		True if the search was successful, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	searchFor	: String;
	posIndex	: Integer;
	charPos		: Integer;
	tokenChar	: String;
	allTokens	: JSSArray;
	tokenCount	: Integer;
	isScanAhead	: Boolean;

begin
	if self.isCaseSensitive then
		searchFor	:=	pInString.trimBlanks;
	else
		searchFor	:=	pInString.trimBlanks.toUpper;
	endif;

	if searchFor.length = 0 then
		return false;
	endif;

	allTokens	:=	self.allWildcardTokens;
	tokenCount	:=	allTokens.size();

	if tokenCount = 0 then
		return false;
	endif;

	isScanAhead	:=	false;
	charPos		:=	1;
	posIndex	:=	1;

	while (posIndex &lt;= tokenCount) do
		tokenChar	:=	allTokens[posIndex].stringValue.trimBlanks;

		if tokenChar = self.ASTERISK then
			if posIndex = tokenCount then
				return true;
			else
				isScanAhead	:=	true;
			endif;

		elseif tokenChar = self.QUESTION_MARK then
			charPos	:=	charPos + 1;
		else
			if isScanAhead then
				isScanAhead	:=	false;
				charPos		:=	searchFor.pos(tokenChar, charPos);

				if charPos = 0 then
					return false;
				else
					charPos	:=	charPos + tokenChar.length;
				endif;
			else
				if charPos &gt; searchFor.length then
					return false;
				else
					if tokenChar = searchFor[charPos:tokenChar.length] then
						charPos	:=	charPos + tokenChar.length;
					else
						return false;
					endif;
				endif;
			endif;
		endif;

		posIndex	:=	posIndex + 1;
	endwhile;

	if charPos &lt;= searchFor.length then
		return false;
	else
		return true;
	endif;
end;</source>
        <Parameter name="pInString" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="parseWildcards" id="9c26e22b-f70d-4b9e-b10c-29258b343bbb">
        <updating/>
        <source>parseWildcards(pWildcardString:String; pIsCaseSensitive:Boolean):Boolean updating;
// --------------------------------------------------------------------------------
// Created:		21 January 2002 by cnwdad1
//
// Purpose:		This method will split a wildcard search string into its individual
//				tokens, and create an array element for each token.  It will also
//				default to having an * at the end of the search string.
//
//				eg. If you search for "Ra?gi R*gir*", the array will have the
//				following elements:
//
//				1) Ra
//				2) ?
//				3) gi R
//				4) *
//				5) gir
//				6) *
//
// Parameters:	pWildcardString - The wildcard search string.
//				pIsCaseSensitive - Determines whether the pattern matching will
//					be case-sensitive.
//
// Returns:		True if the wildcards were sucessfully parsed, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	wildcards		: String;
	charPos			: Integer;
	length			: Integer;
	character		: String;
	startPos		: Integer;
	endPos			: Integer;
	allTokens		: JSSArray;

begin
	self.isCaseSensitive	:=	pIsCaseSensitive;
	
	if self.isCaseSensitive then
		wildcards	:=	pWildcardString.trimBlanks();
	else
		wildcards	:=	pWildcardString.trimBlanks().toUpper();
	endif;

	if wildcards.length = 0 then
		return false;
	endif;

	// Check whether the string has any wildcard characters.

	charPos	:=	wildcards.pos(self.ASTERISK, 1);

	if charPos = 0 then
		charPos	:=	wildcards.pos(self.QUESTION_MARK, 1);

		if charPos = 0 then
			// If there's no wildcard characters in the search pattern, then
			// we want to return everything which exactly matches, or begins
			// with the search string.
			wildcards	:=	wildcards &amp; self.ASTERISK;
		endif;
	endif;

	allTokens	:=	self.allWildcardTokens;
	allTokens.purge();

	length		:=	wildcards.length();
	startPos	:=	0;
	charPos		:=	1;

	while (charPos &lt;= length) do
		character	:=	wildcards[charPos];

		if character = self.ASTERISK or character = self.QUESTION_MARK then
			if startPos &gt; 0 then
				endPos		:=	charPos - startPos;
				allTokens.addString(wildcards[startPos:endPos]);	// Add token prior to this wildcard characrer.
				startPos	:=	0;
			endif;

			allTokens.addString(wildcards[charPos:1]);			// Add this wildcard character.
		elseif startPos = 0 then
			startPos	:=	charPos;
		endif;

		charPos	:=	charPos + 1;
	endwhile;

	if startPos &gt; 0 then
		endPos	:=	charPos - 1;
		allTokens.addString(wildcards[startPos:endPos]);			// Add the token of the remainder of the string.
	endif;

	// Default to having * at the end of the search string.

	if allTokens.size() &lt;&gt; null and allTokens.last().stringValue &lt;&gt; self.ASTERISK then
		allTokens.addString(self.ASTERISK);
	endif;

	return true;
end;</source>
        <Parameter name="pWildcardString" type="String"/>
        <Parameter name="pIsCaseSensitive" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
