    <JadeMethod name="hasDocActions" id="7f8dbfa4-7460-4afd-83ea-54ef78529f8e">
        <source>hasDocActions():Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 October 2016	cnwndl1	Initial creation	TFS 2655 / 2419

*/

vars

	iter : Iterator;
	bookingItem : CM_BookingRefItem;
	docActions : CM_DocumentActions;

begin

	iter := self.allBookingRefItems.createIterator;
	while iter.next( bookingItem) do
		docActions := bookingItem.myBookingRefItemActions;
		if docActions = null then
			continue;
		endif;
		if docActions.hasActions then
			return true;
		endif;
	endwhile;
	
	return false;

epilog

	delete iter;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="hasHazards" id="494a3dea-6996-4af5-a7a5-b5394ae37d77">
        <source>hasHazards():Boolean;
/*
	Created on 07 March 2008
	
	by Debby Hutchison
	
	Purpose:
*/

vars
	haz 	: CM_Hazard;
	brItem : CM_BookingRefItem;
begin
	foreach brItem in allBookingRefItems do
		if brItem.allTIHazards.size &gt; 0 then
			return true;
		endif;
	endforeach;
	return false;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="hasOverDimensionCargo" id="a401bbfb-77b0-4538-acb8-7935b5e6834c">
        <source>hasOverDimensionCargo() : Boolean;
//----------------------------------------------------------------------
// Created by 	cnwsh3
// Date 		01 August 2011
//
// Implemented version: JMT 7.8.2
// Date  		User  		Change
//	01/08/2011	cnwsh3		PAR27943 - New method that hunts through all current tis and checks if it is OD.  Returns true if any item is OD
//							Used in JRW reports			
//----------------------------------------------------------------------
vars
	bookingRefItem : CM_BookingRefItem;
	ti : CM_TrackedItem;
begin
	//First check any tis in the booking reference ti collection then move on to check any booking ref item ti collections.
	//Not sure if they should be the same.  
	//The rule here is, if I find anything that is OD in any of the ti collections I'm searching then return true.
	foreach ti in self.allTIs where ti.isOverDimensions do
		return true;
	endforeach;
	
	foreach bookingRefItem in self.allBookingRefItems where bookingRefItem.allTIs.isNotEmpty() do
		foreach ti in bookingRefItem.allTIs where ti.isOverDimensions do
			return true;
		endforeach;
	endforeach;
	
	return false;
end;
</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="hasReleasesOutstanding" id="069ddd09-308d-40ea-b683-db9a6dba27be">
        <source>hasReleasesOutstanding() : Boolean;
//----------------------------------------------------------------------
// Created by 	cnwsh3 - 16 August 2010
//
// Implemented version: JMT 7.8.3
// Date  		User  		Change
//----------------------------------------------------------------------
vars
	release : CM_BulkRelease;
	hasOutstandingReleases : Boolean;
begin
	hasOutstandingReleases := false;
	
	foreach release in self.allReleaseRequests where release.getTotalOutstanding &gt; 1 do
		hasOutstandingReleases := true;
		break;
	endforeach;
	
	return hasOutstandingReleases;
	
epilog
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="initializeForActivity" id="57a86b1c-ea2d-41cc-9ecb-76fa1cabd511">
        <source>initializeForActivity(_ewsOpsView: CM_EWSActivityOpsview; _opsViewTable : CMIF_OpsViewTables);
/*
Purpose: OPSVIEW			

Date		Who		Reason
30 May 2022	navab1	TFS 53105
05 Jun 2025 navma1  MTN-34114  MTN - Performance Improvements - Remove Class::FirstInstance usage  
*/

vars
	opsviewtable : CMIF_CrgBillsOfLading;
	detail : CM_BookingRefItem;
begin
	opsviewtable := _opsViewTable.CMIF_CrgBillsOfLading;
	
	opsviewtable.gkey := opsviewtable.generateFullGKey(self, "");
	opsviewtable.client_id := app.myRoot.companyCode;					//05.06.2025 navma1 #MTN-34114
	opsviewtable.nbr := self.bookingReference;
	opsviewtable.category := "EXPORT";
	opsviewtable.complex_gkey := opsviewtable.generateCpxGKey();
	opsviewtable.line_gkey := opsviewtable.generateFullGKey(self.myOperator, "");
	
	if self.myConsignee &lt;&gt; null then
		opsviewtable.consignee_name := self.myConsignee.description;
		opsviewtable.consignee_gkey := opsviewtable.generateFullGKey(self.myConsignee, "");
	endif;
	if self.myConsignor &lt;&gt; null then
		opsviewtable.shipper_name := self.myConsignor.description;
		opsviewtable.shipper_gkey := opsviewtable.generateFullGKey(self.myConsignor, "");
	endif;
	
	opsviewtable.cv_gkey := opsviewtable.generateFullGKey(self.myVoyage, "");
	opsviewtable.destination := self.dischargePort;
	opsviewtable.notes := self.bookingRefRemarks;
	opsviewtable.manifested_qty := self.getTotalQuantity();
	opsviewtable.is_direct := self.directDelivery;
	opsviewtable.bl_type := "MASTER";
	opsviewtable.docType := "BOOKING";
	
	detail := self.allBookingRefItems.first;
	if detail &lt;&gt; null then
		if detail.myCargoType &lt;&gt; null then
			opsviewtable.cargoSuperType := detail.myCargoType.getProductTypeString();
			
		endif;
	endif;
	
	opsviewtable.origin := "";
	opsviewtable.gid := 0;
	opsviewtable.pin := "";
	opsviewtable.agent_gkey := 0;
	
	
	
end;
</source>
        <Parameter name="_ewsOpsView" type="CM_EWSActivityOpsview"/>
        <Parameter name="_opsViewTable" type="CMIF_OpsViewTables"/>
    </JadeMethod>
