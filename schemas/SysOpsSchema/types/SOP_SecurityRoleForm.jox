    <JadeMethod name="initTblInput" id="c2f54d27-82a6-4d00-836b-30d034a56ff8">
        <source>initTblInput();
// ---------------------------------------------------------------------------
// Created:     30 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	entTableDef	: EntTableDef;
	theRow		: Integer;
	theTable	: CM_EntryTable;
	
begin

	theTable := tblInput;
	theTable.warningMethod := 'entTableWarning';
	
//	theTable.optimiseRowHeight := true;
	
	entTableDef := app.myController.getEntTableDef(ETDef_SecurityRoleMaint);
	theTable.setEntTableDef(entTableDef, null, 'entTableDefSetupWarning');
//	theTable.adjustHeight(200);

	theTable.top 	:= 5;
	theTable.left	:= 5;
	theTable.parentTopMargin	:= theTable.top;
	theTable.parentLeftMargin	:= theTable.left;
	theTable.parentRightMargin	:= 15;
	theTable.parentBottomMargin := 10;

	theTable.lockBottom := false;
	theTable.lockRight	:= false;
	theTable.stretchHeight := true;
	theTable.stretchWidth := true;

//	app.myController.comboBoxPowerRequirements(theTable, 'powerRequirements', POWER_NONE);

//	theTable.optimiseHeadingColumn();
	theTable.cnEcResizeContents();
		
end;</source>
    </JadeMethod>
    <JadeMethod name="initTblPermissions" id="16e8fdc3-b9e0-418c-9b48-bac502f62e5b">
        <source>initTblPermissions();
// ---------------------------------------------------------------------------
// Created:     03 April 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	theTable		: CM_BaseTable;
	theUsersTable	: CM_DataTable;
	
begin

	 theTable := tblPermissions;
	theTable.top 	:= 20;
	theTable.left	:= 21;
//	theTable.parentTopMargin	:= theTable.top;
//	theTable.parentLeftMargin	:= theTable.left;
	theTable.setDistanceFromRight(15);
	theTable.setDistanceFromBottom(btnUnselectAll.height + 9); //06/04/2006 cnwsh3 Added 2 more to allow for font changes in 7.4.2
	 theTable.lockBottom := false;
	 theTable.lockRight	:= false;
	 theTable.stretchHeight := true;
	 theTable.stretchWidth := true;
	theTable.accessMode := Table.AccessMode_Cell;
	theTable.allowResize := Table.AllowResize_Column;
	theTable.selectMode := Table.SelectMode_None;
	theTable.columnWidth[1] := 48;

	// for users there is different table
	 theUsersTable := self.tblPermUsers;
	theUsersTable.top 	:= 20;
	theUsersTable.left	:= 21;
	theUsersTable.setDistanceFromRight(15);
	theUsersTable.setDistanceFromBottom(btnUnselectAll.height + 9); //06/04/2006 cnwsh3 Added 2 more to allow for font changes in 7.4.2
	 theUsersTable.lockBottom := false;
	 theUsersTable.lockRight	:= false;
	 theUsersTable.stretchHeight := true;
	 theUsersTable.stretchWidth := true;
	theUsersTable.accessMode := Table.AccessMode_Cell;
	theUsersTable.allowResize := Table.AllowResize_Column;
	theUsersTable.selectMode := Table.SelectMode_None;
	theUsersTable.columnWidth[1] := 48;
//	 theUsersTable.multiSelect := CM_DataTable.MultiSelect_Simple;
	 theUsersTable.selectionType := CM_DataTable.SelectionType_Row;
	
	// Setup the buttons
	
//	btnUnselectAll.top := shtPermCat1.clientHeight - btnUnselectAll.height - 5;
//	btnUnselectAll.left := shtPermCat1.clientWidth - btnUnselectAll.width - 5;
	btnUnselectAll.lockRight := true;
	btnUnselectAll.lockBottom := true;
	btnUnselectAll.distanceFromRight := theTable.distanceFromRight;
	btnUnselectAll.distanceFromBottom := 7;//06/04/2006 cnwsh3 changed from 5 to 7 to allow for font changes in 7.4.2

	btnSelectAll.lockRight := true;
	btnSelectAll.lockBottom := true;
	btnSelectAll.distanceFromRight := btnUnselectAll.distanceFromRight + btnUnselectAll.width + 5;
	btnSelectAll.distanceFromBottom := 7; //06/04/2006 cnwsh3 changed from 5 to 7 to allow for font changes in 7.4.2


end;</source>
    </JadeMethod>
    <JadeMethod name="isInternalOnly" id="7bfaf27b-4b04-4412-8a24-3c9697e092d2">
