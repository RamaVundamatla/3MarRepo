	tmpProp.set('Financial Period', CM_InvoiceLine::getPostedFinancialPeriod.name, self.className);
	tmpProp.setPerformanceRating( CM_QueryProperty.Complex );	// Simple	= '1', CollKey	= '2', Complex	= '3'
