    <JadeMethod name="validateMe" id="47925828-67ec-4581-81f6-a2e9cc6bf508">
        <source>validateMe() protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 22/06/2018	jlgdap1		Initial creation TFS 39355 PEL1 Pilot Surcharges
//
vars

begin
	if self.mySurchargesAndExemptions = null then
		app.raiseCMException(Current_surcharge_exemptions, null,null);
		return;
	endif;

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
