        <ReturnType type="JadeLog"/>
    </JadeMethod>
    <JadeMethod name="damageStatusEnumToString" id="5a26ba5f-ce6a-49a5-9e76-e153d9a7b6b0">
        <source>damageStatusEnumToString(status: Integer): String; 
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
01 July 2022	navsj20 ChangeRequest 53862: EUP - WMS - Damage Recording Extra Details

*/

vars

begin

	if status = DamageStatusDamaged then
		return app.getErrorString(DamageStatusDamagedStr);
	elseif status = DamageStatusRefused then
		return app.getErrorString(DamageStatusRefusedStr);
	elseif status = DamageStatusDamageOk then
		return app.getErrorString(DamageStatusDamageOkStr);
	elseif status = DamageStatusRepaired then
		return app.getErrorString(DamageStatusRepairedStr);
	endif;
epilog

end;</source>
        <Parameter name="status" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="damageStatusStringToEnum" id="2c7cfc07-9f57-4cd8-87bf-12d8908b1adc">
        <source>damageStatusStringToEnum(str : String):Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 July 2022	navhl20	ChangeRequest 53862: EUP - WMS - Damage Recording Extra Details

*/

vars

begin
	if str = app.getErrorString(DamageStatusDamagedStr) then
		return DamageStatusDamaged;
	elseif str = app.getErrorString(DamageStatusRefusedStr) then
		return DamageStatusRefused;
	elseif str = app.getErrorString(DamageStatusDamageOkStr) then
		return DamageStatusDamageOk;
	elseif str = app.getErrorString(DamageStatusRepairedStr) then
		return DamageStatusRepaired;
	endif;
epilog

end;</source>
