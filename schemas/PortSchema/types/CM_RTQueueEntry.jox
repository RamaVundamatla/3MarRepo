    <JadeMethod name="getMultiDirectorUltimateTarget" id="1c895e9c-5048-41d1-8106-ad5f8273d3ab">
        <source>getMultiDirectorUltimateTarget() : CM_LocationsController;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
15 November 2010	cnwrd1	Initial creation
//cnwrd1 par 25681 18.11.2010 multi machine director moves
*/

vars
	nextEntry : CM_RTQueueEntry;
	bbTask : CM_RTQueueTask;
begin

	if not self.isMultiMachineDirector() then
		//epr 17/2/15 par 35702 CCMS 2457
		bbTask:=self.findTaskOfType(TASK_BREAKBULK,NULL_INTEGER);
		if bbTask &lt;&gt; null then
			return bbTask.targetLocation;
		endif;
		return null;
	endif;
	
	
	nextEntry:=self.getNextRelatedEntry(); //epr 17/2/15 par 35702 CCMS 2457
	if  nextEntry = null then
		return self.findTaskOfType(TASK_DIRECTOR, NULL_INTEGER).targetLocation;
	else
		return nextEntry.getMultiDirectorUltimateTarget();
	endif;

epilog

end;</source>
        <ReturnType type="CM_LocationsController"/>
    </JadeMethod>
