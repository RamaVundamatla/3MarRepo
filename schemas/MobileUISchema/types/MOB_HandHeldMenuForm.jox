    <JadeMethod name="setupForm" id="ecda2c87-00ea-4426-8fab-9cfe79980a9a">
        <updating/>
        <source>setupForm() updating, protected;
// ---------------------------------------------------------------------------
// Created:	31 December 2008 By Graeme Black cnwgb1
// Status: 	Unfinished
// Purpose:	
// ---------------------------------------------------------------------------
vars

	left, top, width, height : Integer;

begin

	inheritMethod();
	
	self.setupCmdButtons( 1, BACK_BUTTON, null, null, null, null );
	self.setResizeableMarginAndFontSize();
	
	self.frmMenu.move(	self.resizedMargin,
						self.resizedMargin,
						self.clientWidth - (2*self.resizedMargin),
						self.clientHeight - self.getCMDHeight() -self.resizedMargin
						);
						
	self.scrMenu.visible := false;
	self.setupMenus();

epilog
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupMenus" id="d7dbc01b-ead0-4ceb-b455-52438098db96">
        <updating/>
        <source>setupMenus() updating, protected;
// ---------------------------------------------------------------------------
// Created:	31 December 2008 By Graeme Black cnwgb1
// Status: 	Unfinished
// Purpose:	
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
07 May 2015	cnwkpd1	PAR #36168 - Speed up menu form creation
	
*/

constants
	TAB_INDEX_START = 1000;
vars
	menuButton : MOB_Button;
	buttonOffset : Integer;
	formClass : Class;
	formClassObject : Object;
	buttonNumber : Integer;
	buttonWidth : Real;
	buttonHeight : Integer;
	size : Integer;
	dynaDict : DynaDictionary;
	menuCaption : String;
	iter : Iterator;
begin

	size := self.getSessionAgent().allAvailableForms.size;

	self.setResizeableMarginAndFontSize();
	buttonHeight := self.getCMDButtonsHeight();
	buttonWidth := getButtonWidthSetScrollBar( size, self.frmMenu, buttonHeight, self.scrMenu );

	//epr TFS 37901 3/4/18 make sure alpha order by transalated button value
	create dynaDict transient;
	dynaDict.setMembership(Class);
	dynaDict.addExternalKey(String,100,false,false);
	dynaDict.endKeys(true);
	
	foreach formClassObject in self.getSessionAgent().allAvailableForms do
		menuCaption:=app.myMobileGUIAgent.getTranslationOfMenu(formClassObject.Class,app.myCurrentLocale);
		if menuCaption = null then
			 menuCaption:= method.qualifiedName;
		elseif process.isJLGAB1() then
			if formClassObject.Class = MOB_HHVehicleLanderVoyForm 
			or formClassObject.Class = MOB_HHVehicleROROArea 
			or  formClassObject.Class = MOB_HHVehicleMove then
			menuCaption := "(STWO) " &amp; menuCaption;
			endif;
		endif;
		
		//write menuCaption;
		dynaDict.putAtKey(menuCaption,formClassObject);	
	endforeach;
	
	iter:=dynaDict.createIterator;
	while iter.next(formClass) do
		dynaDict.getIteratorKeys(menuCaption, iter);
	
		buttonNumber := buttonNumber + 1;
		menuButton := self.btnMenuTemplate.loadControl( buttonNumber ).MOB_Button;
		menuButton.move(0, buttonOffset, buttonWidth, buttonHeight -( self.resizedMargin * 2) );
		menuButton.userObject:=formClass;
		menuButton.caption :=menuCaption;
		//just too make it more obvious to the developer that they having made the changed to the getTranslationOfMenu method when adding a new menu form
		if menuButton.caption = null then
			 menuButton.caption:= method.qualifiedName;
		endif;
						
		buttonOffset := buttonOffset + buttonHeight + self.resizedMargin;
		menuButton.tabIndex := TAB_INDEX_START + buttonNumber;
	endwhile;
	//endforeach;
	self.btnMenuTemplate.visible := false;
	self.frmMenu.caption := null;
	
	self.doResizeControls(true);
	
epilog
	delete dynaDict;
	delete iter;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="translateForm" id="2bf8c0ca-4475-41bc-9334-a186d7809b21">
        <updating/>
        <source>translateForm(locale : CM_Locale) updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	
begin
	// Determine the locale for translations.
	inheritMethod(locale);
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0013054, locale);
	btnMenuTemplate.translateCaption(Xlat_0013055, locale);
	frmMenu.translateCaption(Xlat_0013056, locale);
end;</source>
        <Parameter name="locale" type="CM_Locale"/>
    </JadeMethod>
</GUIClass>
