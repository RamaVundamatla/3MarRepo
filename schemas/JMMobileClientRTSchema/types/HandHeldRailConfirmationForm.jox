    <JadeMethod name="doKeyDown" id="5d01153c-b2e4-4b2c-a532-598c071227db">
        <updating/>
        <source>doKeyDown(keyCode: Integer io; shift: Integer) updating;
/*
----------   ----------  --------------------------------------------------
Created:	13 September 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	if keyCode = J_key_F2 then
		if self.fldMain.topSheet = self.shtError then
			if self.showingForInwards then
				self.fldMain.topSheet := self.shtInward;
			else
				self.fldMain.topSheet := self.shtOutward;
			endif;
			return;
		endif;
		//loop forward through pages
		if self.showingForInwards then
			if self.showingContainerNumIn &gt;= self.myDTOWagonIn.allDTOWagonPositions.size then
				return;//at the last page
			else
				self.showingContainerNumIn := self.showingContainerNumIn + 1;
				self.doShowFrmInfo(self.showingContainerNumIn);
			endif;
		else
			if self.showingContainerNumOut &gt;= self.myDTOWagonOut.allDTOWagonPositions.size then
				return;//at the last page
			else
				self.showingContainerNumOut := self.showingContainerNumOut + 1;
				self.doShowFrmInfo(self.showingContainerNumIn);
			endif;	
		endif;
		
	elseif keyCode = J_key_F3 then
		if self.fldMain.topSheet = self.shtError then
			if self.showingForInwards then
				self.fldMain.topSheet := self.shtInward;
			else
				self.fldMain.topSheet := self.shtOutward;
			endif;
			return;
		endif;
		
		if (not self.frmContInfo.visible) then
			return;//not viewing container info so can't go page backwards
		endif;
		
		//loop backward through pages
		if self.showingForInwards then
			if self.showingContainerNumIn &lt;= 1 then
				self.doShowFrmMain();
			else
				self.showingContainerNumIn := self.showingContainerNumIn - 1;
				self.doShowFrmInfo(self.showingContainerNumIn);
			endif;
		else
			if self.showingContainerNumOut &lt;= 1 then
				self.doShowFrmMain();
			else
				self.showingContainerNumOut := self.showingContainerNumOut - 1;
				self.doShowFrmInfo(self.showingContainerNumOut);
			endif;		
		endif;
		
	elseif keyCode = J_key_F4 then		
		if self.frmContInfo.visible and self.btnDamage.enabled then
			self.doShowFrmDamage();
		elseif self.frmDamage.visible then
			self.doShowFrmInfo(self.showingContainerNumIn);
		endif;
	elseif keyCode = J_key_F6 then
		if self.fldMain.topSheet = self.shtInward or  self.fldMain.topSheet = self.shtOutward then
			self.fldMain.topSheet := self.shtError;
		elseif self.showingForInwards then
			self.fldMain.topSheet := self.shtInward;
		else
			self.fldMain.topSheet := self.shtOutward;	
		endif;
		self.setLogicalFocus();
	elseif keyCode = J_key_F5 then
		self.doRefresh();
	else
		inheritMethod(keyCode, shift);
	endif;
	

end;


</source>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
