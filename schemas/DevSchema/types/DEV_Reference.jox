<Class name="DEV_Reference" id="4a46bb77-399c-499f-b86e-ad5e7bd9d1c2">
    <superclass name="DEV_SchemaObjectEntity"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="dev"/>
    <PrimAttribute name="miscData" id="ee2dbb49-09d7-4b1d-9db9-1d6c45e5a467">
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <ExplicitInverseRef name="myClass" id="a9d710c1-9502-42ab-bec8-1ef20595242b">
        <kind>child</kind>
        <updateMode>manual</updateMode>
        <embedded/>
        <type name="DEV_Class"/>
        <access>readonly</access>
        <Inverse name="DEV_Class::allReferences"/>
        <Inverse name="DEV_Class::allReferencesOrd"/>
    </ExplicitInverseRef>
    <PrimAttribute name="type" id="fa01e3cf-83a8-46ea-bee5-e1b6db59822a">
        <length>251</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="create" id="89ad6e9c-c646-47eb-a123-0b239c44ccd0">
        <updating/>
        <source>create(_name, 
		_type, 
		_miscData,
		_documentationTextData	: String;
		_reason					: Integer;
		_class					: DEV_Class) ::super(_name) updating;
/*

Purpose:			Constructor for DEV_Reference class

Parameters:			_name:					The name of the reference
					_type:					The type on the reference
					_miscData:				The data we are not interested in but needs to be written out
					_documentationTextData:	The documentation text on the reference
					_class:					The class object the reference belongs to

Return Value:		

Date		Who		Reason
08 November 2021	navpw1	Initial creation TFS: 52202

*/

begin
	//Set Attributes
	self.name 					:= _name;
	self.type 					:= _type;
	self.miscData 				:= _miscData;
	self.documentationTextData	:= _documentationTextData;
	self.reason					:= _reason;
	
	//Set References
	self.myClass := _class;
	
end;</source>
        <Parameter name="_name" type="String"/>
        <Parameter name="_type" type="String"/>
        <Parameter name="_miscData" type="String"/>
        <Parameter name="_documentationTextData" type="String"/>
        <Parameter name="_reason" type="Integer"/>
        <Parameter name="_class" type="DEV_Class"/>
    </JadeMethod>
    <JadeMethod name="getMyClass" id="b209c681-46f8-41fe-9ed8-5fafba6df31e">
        <source>getMyClass(_scm : Schema) : Class;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 November 2023	navpw1	Initial creation

*/

begin
	return _scm.getClass(self.myClass.name);
	
end;</source>
        <Parameter name="_scm" type="Schema"/>
        <ReturnType type="Class"/>
    </JadeMethod>
    <JadeMethod name="getMySchema" id="29e4dac2-b70f-454d-9102-fd578a81a895">
        <source>getMySchema(): Schema;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 November 2023	navpw1	Initial creation

*/

begin
	return rootSchema.getSchema(self.myClass.mySchema.name);
	
end;</source>
        <ReturnType type="Schema"/>
    </JadeMethod>
</Class>
