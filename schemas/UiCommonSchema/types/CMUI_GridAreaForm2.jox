    <JadeMethod name="savePreferences" id="8efe5540-99a5-4c50-a364-271fbe476cdd">
        <updating/>
        <source>savePreferences() : Boolean updating, protected;
// ---------------------------------------------------------------------------
// Created:     20 May 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin

	self.tblPreferences.setObjectFromTable(self.myConfig, CMUI_GridAreaForm2::setObjFromTblPreferSpecial.name, false);
	
	app.myTrxUA.trxUpdateUserConfig(app.getMyUser, self.myConfig, app.myPassport);
	
	if app.myPassport.trxCompletedOK then
		self.hidePreferences();
		return true;
	endif;
	
	self.tblPreferences.row := 1;
	self.tblPreferences.setFocus();
	return false;
	
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="scrollPositionFrame" id="1a1644ec-a431-4c56-bf85-fd7f7175bfef">
        <source>scrollPositionFrame() protected;
// ---------------------------------------------------------------------------
// Created:     25 August 2004 by cnwrs2
//
// Purpose:     Scrolls the position frame in the overview to the
//				currently displayed position
// ---------------------------------------------------------------------------
vars
	hScroll,
	vScroll	: Integer;
	tmpW,
	tmpH	: Real;
	viewFrame : Frame;
begin
	
	if (not self.dkbPosition.visible) then
//		return;
	endif;

	self.dkbGridArea.getCurrentScrollableFrmValues(hScroll, vScroll, tmpW, tmpH);
	
	viewFrame := self.frmPositionView;
	viewFrame.move((hScroll / self.positionScale),
					  (vScroll / self.positionScale),
					  (tmpW / self.positionScale), 
					  (tmpH / self.positionScale));
	viewFrame.clearGraphics;
	viewFrame.drawRectangle(0, 0, viewFrame.clientWidth, viewFrame.clientHeight, Red);
	viewFrame.refreshNow();
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="sdfDragDrop" id="27cd42ac-7a38-4bf2-898b-107bdc04377e">
        <updating/>
        <source>sdfDragDrop(frame: Frame input; win: Window input; x: Real; y: Real) updating, protected;
// ---------------------------------------------------------------------------
// Created:     27 August 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin

	if app.myMoveController &lt;&gt; null then
		delete app.myMoveController;
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="frame" type="Frame" usage="input"/>
        <Parameter name="win" type="Window" usage="input"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
