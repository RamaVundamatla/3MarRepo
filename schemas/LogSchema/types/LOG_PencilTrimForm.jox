    <JadeMethod name="cmbLot_click" id="1a2da47e-7e81-4fd6-a53f-291f7ccf12cd">
        <controlMethod name="CMUI_ComboBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbLot_click(combobox: ComboBox input) updating;
//--------------------------------------------------------------
//Created: 17 September 2002 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	if combobox.listObject &lt;&gt; null then
		self.myCurrentLogLot := combobox.listObject.CM_LogLot;
		self.myAssistant.LOG_Assistant.comboBoxLogLotOperators(self.cmbSupplier, self.myCurrentLogLot, null);	
		cmbSupplier.lostFocus(cmbSupplier);					
	else
		self.myCurrentLogLot := null;		
	endif;
	self.getAllLoadedSOHLocns();		

end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
