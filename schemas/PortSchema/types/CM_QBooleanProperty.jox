<Class name="CM_QBooleanProperty" id="0461715d-0477-42ce-8ce0-9b86bf7106be">
    <superclass name="CM_QueryProperty"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="query"/>
    <JadeMethod name="create" id="5d1c57aa-e0f3-4d6c-bd5a-02ed56d014c5">
        <updating/>
        <source>create() updating;
// ---------------------------------------------------------------------------
// Created:     05 March 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars
	oper : CM_QueryOperator;

begin
	if self.isTransient then 
		return;
	endif;
	
	create oper as CM_QueryBooleanOperator persistent;
	self.allAllowedOperators.add(oper);

	
	
end;</source>
    </JadeMethod>
    <JadeMethod name="getControlTypeForOperator" id="9997d08e-cfd4-4bfc-9e0e-31315cf3052f">
        <source>getControlTypeForOperator(_op: CM_QueryOperator): Integer;
// ---------------------------------------------------------------------------
// Created:     05 March 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars

begin
	if _op.isKindOf(CM_QueryBooleanOperator) then
		return QueryControl_ComboBox;
	endif;

	return inheritMethod(_op);

end;</source>
        <Parameter name="_op" type="CM_QueryOperator"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getKeyLengthForXTABDictionary" id="1b8c25df-cc32-4883-ade6-8ac6ee1a5c88">
        <source>getKeyLengthForXTABDictionary():Integer;
// ---------------------------------------------------------------------------
// Created:     04 December 2008 by concms1:1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 12/02/2010	cnwcs5	par 22140 - New functions
// ---------------------------------------------------------------------------
vars

begin
	return self.niceName.length + 3 +
			app.getTranslatedStringYes.length.max (app.getTranslatedStringNo.length); // 12/02/2010 cnwcs5 par 22140
epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
