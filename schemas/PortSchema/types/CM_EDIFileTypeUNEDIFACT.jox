    <JadeMethod name="rawDataToHSA" id="4af26336-a823-4f3e-b8c9-4b003a3e7a8e">
        <source>rawDataToHSA(_ediFile : CM_EDIFile; _theLines : HugeStringArray input);
//
//15 Jan 2015	cnwrs1	Par 35504 - Refactor EDI file load for .NET
// 28 Jul 2015	cnwrs1	Par 36683 since new data is in rawData suport old data (8.3.2) from compressedFilelines
//
//08 Oct 2015	cnwrs1	Par 36863 - make EDI consistant times when refreshing progress bar
// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
constants
	ProgressBarRefresh	: Integer = 2000;	
vars
	ediFile : CM_EDIFile;
	fileLine : String;
	theLines: HugeStringArray;
	eqdCount : Integer;
	partsInJob, partsDone : Integer;
	progressInt	: TimeStampInterval;
	progressTS : TimeStamp;
begin
	progressTS := app.actualTimeServer();// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	_theLines.clear;
	create theLines transient;
	fileLine := self.rawDataToString(_ediFile);
	if fileLine = null then
		self.compressedDataToHSD(_ediFile, _theLines);
	else
		fileLine.getHugeTokensForDelimiter(SingleQuote.Character, theLines);
		foreach fileLine in theLines do
			if fileLine.isBlank then
				continue;
			endif;
			if fileLine[1:3] = self.tiMarker() then
				eqdCount := eqdCount + 1;
			endif;
			_theLines.addTruncated(fileLine&amp; SingleQuote);
			progressInt := app.actualTimeServer() - progressTS;// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
			if app.myPassport.myCMIFMonitor &lt;&gt; null and ((progressInt.getMilliseconds &gt;= ProgressBarRefresh) or (partsDone = partsInJob)) then
				app.myPassport.myCMIFMonitor.updateProgressWithCaption('Preparing File Data ', partsInJob, partsDone, "Loading EDI file Step 2 of 3.");
				progressTS := app.actualTimeServer();// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
			endif;
		endforeach;
		ediFile := _ediFile;
		if process.isInTransactionState then
			ediFile.setNumContainers(eqdCount);
		endif;
	endif;
epilog
	delete theLines;
end;
</source>
        <Parameter name="_ediFile" type="CM_EDIFile"/>
        <Parameter name="_theLines" type="HugeStringArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="rawDataToString" id="99dac12c-39ef-498a-b4cd-b17c64e9aa81">
        <source>rawDataToString(_ediFile : CM_EDIFile) : String;
//
//19 Jan 2015	cnwrs1	Par 35504 - Refactor EDI file load for .NET
//
vars
	fileLine : String;
begin
	fileLine := _ediFile.getRawDataString();
	fileLine := fileLine.replaceString(CrLf, null);
	fileLine := fileLine.replaceString(Lf, null);
	fileLine := fileLine.replaceString(Cr, null);
	fileLine := fileLine.replaceString(ExclaimationMark, null);
	fileLine := fileLine.removeSubstringPlusExtraChars(QuestionMark, 1);
	return fileLine;
end;
</source>
        <Parameter name="_ediFile" type="CM_EDIFile"/>
        <ReturnType type="String"/>
    </JadeMethod>
