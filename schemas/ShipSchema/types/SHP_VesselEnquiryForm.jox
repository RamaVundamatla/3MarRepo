//----------------------------------------------------------------------
//
//  Created by cnwsh3
//
//	Date 19 April 2006
//
//----------------------------------------------------------------------
vars
	vessTxtTop,
	vessComboTop	: 	Real;
begin
	
	inheritMethod(_showCaptions);
		
	self.setSearchToolbar;
	
end;</source>
        <Parameter name="_showCaptions" type="Boolean"/>
