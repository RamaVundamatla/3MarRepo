end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getIsViewable" id="9549b522-5d34-47ec-93c3-e719f449c7cf">
        <source>getIsViewable() : Boolean;

/*

Purpose:			

A temporary implementation to get around the fact that isVisible is always set to true
regardless of whether or not the value has been overridden at CargoType level.  Eventually, when 
the code has been fixed up properly, this method should return the value of isVisible

Parameters:			

Return Value:		


Date		Who		Reason
18 August 2009	cnwjk3	Initial creation
2 July 2010		cnwjre1	fix for 23546 to just return self.isViewable
*/

vars

begin
	//epr 15/2/18 webportal dev this should always return if it is viewable and 
	// that also means if this is not viewable on its parent cargo type then return false
	if self.myProduct.myCargoType = null then
		return self.isViewable;
	else
		if not self.isViewable then
			return false;
		endif;
		return self.myProduct.myCargoType.allAttributesOnProduct.includes(self.name);
	endif;
	
	return self.isViewable;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getMeasurementName" id="3c816195-eb67-4b12-8a3a-7a74e280d982">
        <source>getMeasurementName(_type : String) : String;
/*
Purpose:			Return the measurement type short name associated with this product attribute

Parameters:			_type - if myMeasurementType = null, then return the default short naem for the _type

Return Value:		Measurement Type Short name

Date		Who		Reason
27/03/2013	cnwdap1	Initial creation PAR #31155 CCMS SFW 1321 Imperial Measurements
*/
vars

begin
	if self.myMeasurementType &lt;&gt; null then
		return self.myMeasurementType.shortName;
	else
		return app.getDefaultMeasurementForType(_type).shortName;
	endif;
epilog

end;</source>
        <Parameter name="_type" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
