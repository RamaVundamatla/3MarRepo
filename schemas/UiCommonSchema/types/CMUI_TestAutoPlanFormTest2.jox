    <JadeMethod name="moveTrackedItem" id="a70e6f5e-819c-4abc-bde3-e6f4648095bc">
        <updating/>
        <source>moveTrackedItem(_ti : CM_TrackedItem) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
01 March 2012	cnwndl1	Initial creation	Par 29195

*/

vars
	obj				: Object;
	moveController	: CMIF_MoveController;
	invalidProcess : Boolean;
	tmpTI			: CM_TrackedItem;
begin
	on Exception do app.handleDeletedObject(exception, app.myMoveController, invalidProcess);

	if _ti = null then
		return;
	endif;
	
	if _ti.site = TI_SITE_OFFSITE then
		app.raiseCMException1(ERR_TI_NOT_ONSITE, _ti.id, null, null);
		return;
	endif;

	delete app.myMoveController;
	
	create moveController transient;
	moveController.setMyTrackedItem(_ti);
	app.myMoveController := moveController;
	moveController.isRehandleMove := _ti.isRehandle;
	moveController.setMoveMode(PLANNING_MODE);
	

end;</source>
