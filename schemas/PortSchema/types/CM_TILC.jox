    <JadeMethod name="validateForDefault" id="0a5f93c1-d75d-4d67-887e-f340f60e773d">
        <updating/>
        <source>validateForDefault(pControl: CMIF_TIUpdateController input; _passport: CM_Passport input) updating, protected;
/*
Purpose:			

Return Value:		

Date		Who		Reason
12 April 2007	cnwer1	Initial creation - PAR#xxxx

*/
begin
	if pControl.mode &lt;&gt; TI_UPDMODE_NORMAL then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Method called for invalid mode (' &amp; pControl.mode.String &amp; ')');
		return;
	endif;
	
	self.validateTrailerType();		// PAR 18352
	self.validateCargoType(pControl);
	self.validateId(pControl);
	self.validateOperator(pControl, _passport);
	self.validateMAFIVoyage(null); //jlier1 TFS 65290 24/7/24
	
end;</source>
        <access>protected</access>
        <Parameter name="pControl" type="CMIF_TIUpdateController" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
