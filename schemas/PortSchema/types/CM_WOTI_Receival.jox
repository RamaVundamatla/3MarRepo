    <DbClassMap file="cmtrans"/>
    <JadeMethod name="getRecieveBookingRef" id="b81afc91-851c-4d75-bd94-83adb4d2dff7">
        <source>getRecieveBookingRef(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 January 2023	navhl20	ChangeRequest 54350:[54269] EUP - VAS Work Orders Selector Query

*/

vars

begin
	if self.myWorkOrderDetail = null then
		return null;
	endif;

	if self.myWorkOrderDetail.CM_WodReceive.myBookingRef = null then
		return null;
	endif;
	
	return self.myWorkOrderDetail.CM_WodReceive.myBookingRef.bookingReference;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
