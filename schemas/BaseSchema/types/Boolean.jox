<PrimType name="Boolean">
    <JadeMethod name="cnEcFormat" id="aea2ecce-77e8-45e0-bdd4-d4fcbad69f70">
        <source>cnEcFormat(pTrueValue:String; pFalseValue:String):String;
//	Returns the string appropriate for the cuurent true/false value of self.
vars
	trueString	: String;
	falseString	: String;

begin
	// If no values supplied use default.

	if pTrueValue.trimBlanks = null then
		trueString	:=	$CNEC_TRUE;
	else
		trueString	:=	pTrueValue;
	endif;

	if pFalseValue.trimBlanks = null then
		falseString	:=	$CNEC_FALSE;
	else
		falseString	:=	pFalseValue;
	endif;

	if self	then
		return trueString;
	else
		return falseString;
	endif;
end;</source>
        <Parameter name="pTrueValue" type="String"/>
        <Parameter name="pFalseValue" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="cnEcGetTableCheckBoxValue" id="2b075726-8d63-4089-a5f3-2b05eb016d83">
        <source>cnEcGetTableCheckBoxValue():String;
// --------------------------------------------------------------------------------
// Created:		08 June 2000 by cnwdad1
//
// Purpose:		Returns a value suitable for setting the contents of a table control
//				cell where the InputType for that cell is of type "Input_CheckBox".
//
// Parameters:	None
//
// Returns:		String - Either "1" (true) or "0" (false).
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self then
		return "1";
	else
		return "0";
	endif;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="cnEcGetYesNo" id="4443c435-477e-4df3-a28a-890765251641">
        <source>cnEcGetYesNo():String;
// --------------------------------------------------------------------------------
// Created:		26 July 2000 by cnwdad1
//
// Purpose:		Returns a literal (translatable) string for "Yes" or "No" based
//				upon the value of the receiver.
//
// Parameters:	None
//
// Returns:		String (translated) according to the receiver's value).
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self then
		return $CNEC_LIT_YES;
	else
		return $CNEC_LIT_NO;
	endif;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
</PrimType>
