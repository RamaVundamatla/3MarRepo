    <JadeMethod name="setProxy" id="257825b6-1337-4c89-b09d-024c7fc1090b">
        <updating/>
        <source>setProxy(_consignee		: CM_ConsigneeConsignor; 
		_operator 		: CM_Operator;
		_terminal 		: CM_Terminal; 
		_voyage 		: CM_Voyage;
		_orderDate 		: Date; 
		_deadline		: TimeStamp;
		_orderNo 		: String;
		_transportMode 	: Integer; 
		_dischargePort	: String; 
		_type, 
		_processOption 	: Integer; 
		_isAudit, 
		_isTransfer 	: Boolean;
		_transferTerminal : CM_Terminal; 
		_user			: String) updating;
//--------------------------------------------------------------
//Created: 23 July 2002 By: cnwgd1
//--------------------------------------------------------------
vars

begin

	self.setProxyForStockOrderHdrGen(_consignee,
									_dischargePort,
									_operator,
									_terminal,
									_voyage,
									_orderDate,
									_deadline,
									_orderNo,
									_transportMode,
									_type,
									_processOption,
									_isAudit,
									_isTransfer,
									_transferTerminal,
									_user);

end;</source>
        <Parameter name="_consignee" type="CM_ConsigneeConsignor"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_orderDate" type="Date"/>
        <Parameter name="_deadline" type="TimeStamp"/>
        <Parameter name="_orderNo" type="String"/>
        <Parameter name="_transportMode" type="Integer"/>
        <Parameter name="_dischargePort" type="String"/>
        <Parameter name="_type" type="Integer"/>
        <Parameter name="_processOption" type="Integer"/>
        <Parameter name="_isAudit" type="Boolean"/>
        <Parameter name="_isTransfer" type="Boolean"/>
        <Parameter name="_transferTerminal" type="CM_Terminal"/>
        <Parameter name="_user" type="String"/>
    </JadeMethod>
    <JadeMethod name="setProxyForStockOrderHdrGen" id="28ece923-ab6b-4295-8039-0f0f0c74804b">
        <updating/>
        <source>setProxyForStockOrderHdrGen(
		_consignee				: CM_ConsigneeConsignor;
		_dischargePort			: String;
		_operator				: CM_Operator;
		_terminal				: CM_Terminal;
		_voyage					: CM_Voyage;
		_orderDate				: Date;
		_deadlineDT				: TimeStamp;
		_orderNo				: String;
		_transportMode			: Integer;
		_type,
		_processOption			: Integer;
		_isAudit,
		_isTransfer				: Boolean;
		_transferTerminal		: CM_Terminal;
		_user					: String) updating, protected;
//--------------------------------------------------------------
//Created: 23 July 2002 By: cnwsb1
//--------------------------------------------------------------
vars

begin

	self.setProxyForStockOrderHdr(_dischargePort, _operator, _terminal, _voyage, _orderDate, _deadlineDT,
			_orderNo, _transportMode, _type, _processOption, _isAudit, _isTransfer);

	if _consignee &lt;&gt; null then
		self.consigneeCode	:= _consignee.code;
	else
		self.consigneeCode 	:= null;
	endif;
	
	self.myTransferTerminal	:= _transferTerminal;
	self.user				:= _user;

end;</source>
        <access>protected</access>
        <Parameter name="_consignee" type="CM_ConsigneeConsignor"/>
        <Parameter name="_dischargePort" type="String"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_orderDate" type="Date"/>
        <Parameter name="_deadlineDT" type="TimeStamp"/>
        <Parameter name="_orderNo" type="String"/>
        <Parameter name="_transportMode" type="Integer"/>
        <Parameter name="_type" type="Integer"/>
        <Parameter name="_processOption" type="Integer"/>
        <Parameter name="_isAudit" type="Boolean"/>
        <Parameter name="_isTransfer" type="Boolean"/>
        <Parameter name="_transferTerminal" type="CM_Terminal"/>
        <Parameter name="_user" type="String"/>
    </JadeMethod>
    <JadeMethod name="validateForGarbageCollection" id="f947b069-2c14-417f-850f-2d5aeecc6045">
        <source>validateForGarbageCollection();
// -------------------------------------------
// Created 24 August 2004 by cnwdvb1
// -------------------------------------------
vars

begin
	inheritMethod();
	if self.fulfilledStatus &lt;&gt; OrderStatus_Fulfilled then
		app.raiseCMException(UNEXPECTED_PROGRAM_ERROR, null, null);
		return;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="validateMe" id="2920e6cd-a4d4-4fa9-91ca-93469d695e24">
        <source>validateMe(_passport : CM_Passport input) protected;
// ---------------------------------------------------------------------------
// Created:     26 June 2002 by cnwsb1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	inheritMethod(_passport);
	
	if self.hasDamagedTIs then
		app.raiseCMWarning1(DamagedTIs, "Order " &amp; self.orderNo, null, null, self);
	endif;
	
end;</source>
        <access>protected</access>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
</Class>
