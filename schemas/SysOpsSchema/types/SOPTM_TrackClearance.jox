    <JadeMethod name="includeObject" id="a19059da-9dec-473f-8421-e25baf861fe5">
        <updating/>
        <source>includeObject(_obj: Object; _passport: CM_Passport): Boolean updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
26 June 2009	cnwndl1	Initial creation

*/

vars

begin
	
	if self.includeNotAvailableEntries then
		return true;
	else
		return not _obj.CM_TrackClearance.isNotAvailableForEntry;
	endif;

epilog

end;</source>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
