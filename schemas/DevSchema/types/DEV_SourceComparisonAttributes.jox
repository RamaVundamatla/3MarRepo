    <JadeMethod name="loadGlobalConstant" id="30a07d6f-4fad-4ed6-be78-1ef243be17fe">
        <updating/>
        <source>loadGlobalConstant(_devGlobalConstant : DEV_GlobalConstant) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 December 2021	navpw1	Initial creation TFS: 52202

*/

vars
	schema 					: Schema;
	currentConstant 		: Constant;
	
begin
	self.myConstant := _devGlobalConstant;
	schema := rootSchema.getSchema(_devGlobalConstant.myGcCategory.mySchema.name);
	currentConstant := schema.getConstant(_devGlobalConstant.name);
	
	self.caption := "Source Comparison Global Constant" &amp; " - " &amp; _devGlobalConstant.name;
	
	if currentConstant = null then
		self.slStatus.caption := "Global Constant Missing";
	elseif _devGlobalConstant.type &lt;&gt; currentConstant.type.name then
		self.slStatus.caption := "Difference: Type";
	elseif _devGlobalConstant.documentationTextData &lt;&gt; currentConstant.text then
		self.slStatus.caption := "Difference: Text";
	elseif _devGlobalConstant.value &lt;&gt; currentConstant.getSource() then
		self.slStatus.caption := "Difference: Value";
	endif;
	
	self.tblLoaded.rows := 0;
	self.tblLoaded.clearAllSelected();
	self.tblLoaded.addItemAt("Loaded", 1);
	self.tblLoaded.accessRow(1).fontBold := true;
	self.tblLoaded.fixedRows := 1;
	
	self.tblLoaded.addItemObject(_devGlobalConstant, "Name");
	self.tblLoaded.addItemObject(_devGlobalConstant, "Modified TimeStamp");
	self.tblLoaded.addItemObject(_devGlobalConstant, "Modified by");
	self.tblLoaded.addItemObject(_devGlobalConstant, "Modified version");
	//self.tblLoaded.addItemObject(_devGlobalConstant, "Documentation Text");
	self.tblLoaded.addItemObject(_devGlobalConstant, "Type");
	self.tblLoaded.addItemObject(_devGlobalConstant, "Value");
	
	self.tblLoaded.setCellText(2, 2, _devGlobalConstant.name);
	self.tblLoaded.setCellText(3, 2, _devGlobalConstant.modifiedTimeStamp.String);
	self.tblLoaded.setCellText(4, 2, _devGlobalConstant.modifiedBy);
	self.tblLoaded.setCellText(5, 2, _devGlobalConstant.modifiedVersion);
	//self.tblLoaded.setCellText(6, 2, self.cleanText(_devGlobalConstant.documentationTextData));
	self.tblLoaded.setCellText(6, 2, _devGlobalConstant.type);
	self.tblLoaded.setCellText(7, 2, self.cleanText(_devGlobalConstant.value));
	
	//self.jeLoaded.text := _devGlobalConstant.documentationTextData;
	
	self.tblCurrent.rows := 0;
	self.tblCurrent.clearAllSelected();
	self.tblCurrent.addItemAt("Current", 1);
	self.tblCurrent.accessRow(1).fontBold := true;
	self.tblCurrent.fixedRows := 1;
	
	self.tblCurrent.addItemObject(currentConstant, "Name");
	self.tblCurrent.addItemObject(currentConstant, "Modified TimeStamp");
	self.tblCurrent.addItemObject(currentConstant, "Modified by");
	self.tblCurrent.addItemObject(currentConstant, "Modified version");
	//self.tblCurrent.addItemObject(currentConstant, "Documentation Text");
	self.tblCurrent.addItemObject(currentConstant, "Type");
	self.tblCurrent.addItemObject(currentConstant, "Value");
	
	if currentConstant = null then
		return;
	endif;
	
	self.tblCurrent.setCellText(2, 2, currentConstant.name);
	self.tblCurrent.setCellText(3, 2, currentConstant.getModifiedTimestamp().String);
	self.tblCurrent.setCellText(4, 2, currentConstant.getModifiedBy());
	self.tblCurrent.setCellText(5, 2, currentConstant.version.asStringJMT());
	//self.tblCurrent.setCellText(6, 2, self.cleanText(currentConstant.text));
	self.tblCurrent.setCellText(6, 2, currentConstant.type.name);
	self.tblCurrent.setCellText(7, 2, self.cleanText(currentConstant.getSource()));
	
	//self.jeCurrent.text := currentConstant.text;
	
	self.btnOpenInWinMerge.visible := true;
	
end;</source>
