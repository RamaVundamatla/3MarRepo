    <JadeMethod name="displayPropData" id="bf2f9ddf-f120-49dd-99e7-b90ddfd443fa">
        <updating/>
        <source>displayPropData() updating;
// ---------------------------------------------------------------------------
// Created:		August 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	debtor : CM_Debtor;
	theForm : SelfType;
begin
	if self.updateMode = self.UpdateMode_New then
		self.fldProperties.topSheet := self.shtPropOne;
		self.tblProperties.clearValues();
		self.doBuildComboParents();
		self.loadTransactionTypes();
	else
		inheritMethod();
		theForm := self;
		self.fldProperties.topSheet := self.shtPropOne;
//		self.myCurrentDebtorNode.showPropertiesSub(theForm,self.viewOnly);
		self.objShowProperties(self.myCurrentDebtorNode,self.viewOnly);
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="doBtnCashBalances" id="95fcfa84-c54d-4005-9c77-46e28d066932">
        <source>doBtnCashBalances();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 August 2012	cnwndl1	Initial creation	Par 29968

*/

vars
	form : INV_CashDrBalanceEnquiry;
	debtorNode : CM_DebtorNode;
	debtor : CM_Debtor;

begin

	debtorNode := self.myCurrentDebtorNode;
	if debtorNode &lt;&gt; null and debtorNode.isKindOf( CM_Debtor ) then
		debtor := debtorNode.CM_Debtor;
		if not debtor.allDebtorTerminals.includesCashOnlyTerminals then
			debtor := null;
		endif;
	endif;
	
	form := app.getForm(INV_CashDrBalanceEnquiry.name).INV_CashDrBalanceEnquiry;
	if form = null then
		form := app.loadForm(INV_CashDrBalanceEnquiry, INV_Assistant, false, false, false, self.myTerminal, null).INV_CashDrBalanceEnquiry;
	endif;
	
	if form &lt;&gt; null then
		form.setMyDebtor( debtor );
		form.show;
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doBtnCashTrns" id="7d62da8d-8c70-4176-a564-463a7417b89e">
        <source>doBtnCashTrns();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 August 2012	cnwndl1	Initial creation	Par 29968

*/

vars

	form : INV_CashDrTransactionEnquiry;
	debtorNode : CM_DebtorNode;
	debtor : CM_Debtor;

begin

	debtorNode := self.myCurrentDebtorNode;
	if debtorNode &lt;&gt; null and debtorNode.isKindOf( CM_Debtor ) then
		debtor := debtorNode.CM_Debtor;
		if not debtor.allDebtorTerminals.includesCashOnlyTerminals then
			debtor := null;
		endif;
	endif;
	
	form := app.getForm(INV_CashDrTransactionEnquiry.name).INV_CashDrTransactionEnquiry;
	if form = null then
		form := app.loadForm(INV_CashDrTransactionEnquiry, INV_Assistant, false, false, false, self.myTerminal, null).INV_CashDrTransactionEnquiry;
	endif;
	
	if form &lt;&gt; null then
		form.setMyDebtor( debtor );
		form.show;
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doBtnDebtorSuspendClick" id="788a3c7d-13de-4bbf-a550-862935b841cf">
        <updating/>
        <source>doBtnDebtorSuspendClick() updating;
// ---------------------------------------------------------------------------
// Created:		August 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// 08/04/2011	cnwmh5	PAR #27347 - Add cmsEndLoad or endLoad to epilog so that if error occurs it will not leave it in beginLoad state
vars
	pxyDebtorNode : CM_DebtorNode;
	ls : Boolean;
	theReturn : Integer;
	debtorNodeController: CMIF_DebtorNode;
	realDN : CM_DebtorNode;
begin

	app.cmsBeginLoad(ls);
	pxyDebtorNode := app.createUpdateProxy(self.myCurrentDebtorNode).CM_DebtorNode;
	app.cmsEndLoad(ls);
	pxyDebtorNode.setProxySuspend(not pxyDebtorNode.isSuspended);
	while true do
		app.myTrxUA.trxUpdateDebtorSuspenders(pxyDebtorNode,app.myPassport);
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			global.beep;
			break;
		else
			theReturn := app.showErrorWarningDialog(app.getErrorString(INV_Debtor_Suspend), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			return;
		endif;
		break;
	endwhile;
	
	self.frmProperties.visible := false;
	self.lstData.enabled := true;
epilog
	app.cmsEndLoad(ls);		// 08/04/2011 cnwmh5 #27347
	delete pxyDebtorNode;
end;</source>
    </JadeMethod>
    <JadeMethod name="doBtnPropSaveClick" id="28c9e160-fdca-4458-85c6-0da95a56c2b1">
        <updating/>
        <source>doBtnPropSaveClick() updating;
// ---------------------------------------------------------------------------
// Created:		August 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	ls : Boolean;
	theReturn : Integer;
	debtorNodeController: CMIF_DebtorNode;
	realDN : CM_DebtorNode;
begin
	create debtorNodeController;
	self.doSetDebtorNodeController(debtorNodeController);
	
	while true do
		if self.updateMode = self.UpdateMode_New then
			app.myTrxCA.trxCreateDebtorNode(debtorNodeController,realDN,app.myPassport);
		else
			if debtorNodeController.myPxyDebtorNode.isKindOf(CM_DebtorGroup) and not app.myCurrentUserCan(self.myTerminal, PmAdmDebtorgroupMaint) then
				app.raiseCMException1(VB_SECMOVE, self.caption, null, null);
				return;
			endif;
			app.myTrxUA.trxUpdateDebtorNode(debtorNodeController,app.myPassport);
		endif;
		
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			global.beep;
			break;
		else
			theReturn := app.showErrorWarningDialog(app.getErrorString(INV_Debtor_Register), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			return;
		endif;
		break;
	endwhile;

	self.msgPropThree.setAvailable(app.myRoot.myRootCompany.rootDebtor.operators, true);
	self.myCarriersMultiSelectBox.setAvailable(app.myRoot.allCarriers, true); //+ cnwmd1, CCMS 1067, Par 19913
	
	self.frmProperties.visible := false;
	self.frmToolbar.enabled := true;
	self.lstData.enabled := true;
epilog
	delete debtorNodeController.myPxyDebtorNode;
	delete debtorNodeController;
end;</source>
    </JadeMethod>
    <JadeMethod name="doBtnSearchClick" id="ab82a412-ccc1-42b5-af60-d9d675499d38">
        <updating/>
        <source>doBtnSearchClick() updating;
// ---------------------------------------------------------------------------
// Created:		August 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

	aDebtor : CM_DebtorNode;
	idx : Integer;
	
	startIndex : Integer;
	listCount : Integer;
	strToMatch : String;
	found : Boolean;
	
begin
	

	if self.chkPartial.value then	//17 Jul 2018	NDL	TFS 38616
	
		startIndex := self.lstData.listIndex;
		listCount := self.lstData.listCount;
		if listCount = 0 then
			return;
		endif;
		aDebtor := self.lstData.itemObject[ startIndex ].CM_DebtorNode;
		strToMatch := self.txtSearch.text.trimBlanks.toUpper;
		if aDebtor = null or not aDebtor.debtorMatches( strToMatch ) then
			startIndex := 1; // go back to the begining.
		else
			//must be part way through
			startIndex := startIndex + 1; // start from the next one.
		endif;
		
		if startIndex &gt; listCount then
			startIndex := 1; // go back to the begining.
		endif;
		
		//find the next match
		foreach idx in startIndex to listCount do
			aDebtor := self.lstData.itemObject[ idx ].CM_DebtorNode;
			if aDebtor &lt;&gt; null and aDebtor.debtorMatches( strToMatch ) then
				self.lstData.itemExpanded[idx] := true;
				self.lstData.listIndex := idx;
				self.lstData.topIndex := idx;
				self.lstData.click( self.lstData );
				found := true;
				break;
			endif;
		endforeach;
		
		if not found then
			//got to the end and no more found.
			self.lstData.listIndex := 1;
			self.lstData.topIndex := 1;
			self.lstData.enabled := true;
			self.frmSearch.visible := false;
			self.txtSearch.text := null;
			self.showExtraInfo( null );
			if startIndex = 1 then
				app.msgBox( app.getErrorString(No_Matches_found), app.getErrorString(Warning) ,MsgBox_OK_Only);	//No matches found
			else
				app.msgBox( app.getErrorString(No_matches_found), app.getErrorString(Warning) ,MsgBox_OK_Only);  //No more matches found
			endif;
		endif;
	
	else
	
		inheritMethod();

		aDebtor := app.myRoot.myRootCompany.debtorNodes[self.txtSearch.text.trimBlanks];
		if aDebtor = null then
			aDebtor := app.myRoot.myRootCompany.debtorNodes[self.txtSearch.text.trimBlanks.toUpper];
			if aDebtor = null then
				return;
			endif;
		endif;
		idx := self.lstData.findObject(aDebtor);
		if idx &gt; 0 then
			self.lstData.itemExpanded[idx] := true;
			self.lstData.listIndex := idx;
			self.lstData.topIndex := idx;
		endif;
	
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="doBuildComboParents" id="0fa6dc31-b2fe-4905-b4e3-81f36461d8b7">
        <source>doBuildComboParents();
// ---------------------------------------------------------------------------
// Created:		August 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	debtorParent,
	debtorNode:   CM_DebtorNode;
	theBank : CM_Bank;
	rdg, rootRDG : CM_RootDebtorGroup;
begin
	theBank := app.myRoot.myRootCompany;
	rdg := theBank.getRootDebtorGroup();
	
	self.cmbDebtorParent.clear;
	
	foreach debtorNode in theBank.debtorNodes do
		// CCMS-1604
		//where debtorNode.isKindOf(CM_DebtorGroup) do

		if debtorNode = self.myCurrentDebtorNode and not self.updateMode = self.UpdateMode_New then
			// exclude possibility of assigning group to itself when editing
			continue;
		endif;
		if debtorNode.isRDT() then // PAR 16252
			continue;
		endif;
		
		if debtorNode = rdg then
			self.cmbDebtorParent.addItem("");
		else
			self.cmbDebtorParent.addItem(debtorNode.name);
		endif;
		self.cmbDebtorParent.itemObject[self.cmbDebtorParent.newIndex] := debtorNode;
	endforeach;

	debtorParent := self.myCurrentDebtorNode.myParentDebtorNode;				
	rootRDG := app.myRoot.myRootCompany.getRootDebtorGroup();
	
	if debtorParent &lt;&gt; null and debtorParent &lt;&gt; rootRDG then
		self.cmbDebtorParent.listObject := debtorParent;
	endif;

	self.cmbDebtorParent.lostFocus(self.cmbDebtorParent);

end;</source>
    </JadeMethod>
    <JadeMethod name="doCmbTermsTradeBuild" id="6029feb5-656c-451d-a8ea-a39874d4ebbd">
        <source>doCmbTermsTradeBuild();
/*
----------   ----------  --------------------------------------------------
Created:	18 July 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	dict		: CM_InvTermsOfTradeByCode;
	invTerm		: CM_InvoiceTermsOfTrade;
	cmb			: CMUI_ComboBox;
	debtor 		: CM_Debtor;
begin
	cmb := self.cmbTermsTrade;
	cmb.clear;
	cmb.addItem("");
	dict := app.myRoot.myRootCompany.allInvoiceTermsOfTrade;
	foreach invTerm in dict do
		cmb.addItem(invTerm.description);
		cmb.itemObject[cmb.newIndex] := invTerm;
	endforeach;

	
end;</source>
    </JadeMethod>
    <JadeMethod name="doDelete" id="61a056d3-20f0-4d25-b237-aa28dad338a6">
        <updating/>
        <source>doDelete() updating;
// ---------------------------------------------------------------------------
// Created:		August 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	anObject : Object;
	aDebtor : CM_DebtorNode;
	theReturn, idx : Integer;
	label : String;
	
	theBank : CM_Bank;
	rdg, rootRDG : CM_RootDebtorGroup;
begin
	theBank := app.myRoot.myRootCompany;
	rdg := theBank.getRootDebtorGroup();

	aDebtor := self.myCurrentDebtorNode;
	if aDebtor = null then
		app.msgBox(app.getErrorString(INV_Please_Select_A_Debtor), app.getErrorString(INV_Delete_Error), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	label := "debtor '" &amp; aDebtor.name &amp; "' ?"; 
	if app.msgBox(app.getErrorString1(Lit_Confirm_Delete,  label),app.getErrorString(Confirm_Delete),MsgBox_Yes_No + MsgBox_Question_Mark_Icon) = MsgBox_Return_No then
		return;
	endif;


	while true do
	 	app.myTrxDA.trxDeleteDebtorNode(aDebtor, app.myPassport);
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			global.beep;
			self.myCurrentDebtorNode := rdg;  //HJG added as error being returned if attempt to create new group after deleteing node
			return ;
		else
			theReturn := app.showErrorWarningDialog("Debtor Delete", app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors 
			and theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			return ;
		endif;
		break;
	endwhile;


end;</source>
    </JadeMethod>
    <JadeMethod name="doFilterTree" id="e9ceaccd-e73d-47fa-93f9-a404e83fd395">
        <updating/>
        <source>doFilterTree() updating;
/*

Purpose:			Filters the tree

Parameters:			NONE

Return Value:		NONE

Date				Who		Reason
20 September 2021	navpw1	Initial creation TFS: 51912
19 July 2022		navpw1	Bug: 53979 EUP - Text Filter in Debtor register

*/

vars
	filterText		: String;
	
begin
	filterText := self.txtFilterBox.text.toUpper();
	
	if (filterText &lt;&gt; "") then
		self.btnClearFilter.enabled := true;
		self.loadDebtorRegister(filterText);
	else
		self.btnClearFilter.enabled := false;
		self.loadDebtorRegister(null);
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="doImport" id="04033d7f-d530-4889-b7d7-d423dc98b2da">
        <updating/>
        <source>doImport(): Boolean updating;

/*

Purpose:	MES 1010		

Parameters:			

Return Value:		


Date		Who		Reason
18 August 2009	cnwjmn1	Initial creation

*/


vars
	trxResult		: Boolean;
	warningsResult	: Integer;

begin


	create self.myLoadDebtorAgent transient;
	self.myLoadDebtorAgent.setForm(self);

	if app.msgBox("Do you want to load new Debtors from File?","Update Database",MsgBox_Yes_No + MsgBox_Question_Mark_Icon)
			= MsgBox_Return_No then
		return false;
	endif;	
	
	while true do

		trxResult := self.myLoadDebtorAgent.doImport();
		
		if trxResult then
			self.clearErrorWarnings();
			break;
		endif;

		warningsResult := app.showErrorWarningDialog(self.myLoadDebtorAgent.getTableName, app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
		
		if app.myPassport.noErrors and
		   warningsResult = IDOK then
			// there must have just been warnings that the user has acknoledged so ..
			app.myPassport.warningsAcknowledged	:= true;
			continue;
		endif;

		break;

	endwhile;
	
	return trxResult;
	
epilog
	delete	self.myLoadDebtorAgent;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doLstDataClick" id="92a27c7a-523e-4020-8006-ab333e963896">
