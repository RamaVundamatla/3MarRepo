    <JadeMethod name="getDisplayStringForAttribute" id="d2b35404-62b3-463c-b5b4-d912e1c4982d">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 June 2010	cnwndl1	Initial creation	Par 23498

*/

vars
	lDetail : String;
	ti	: CM_TrackedItem;
begin

	if _attrName = ETRow_Details  then
		if self.deleted then
			return self.getDeletedDetails();		// 15/10/18 MAP TFS41191
			
		else
			if self.otherTrackedItem &lt;&gt; null
			and self.otherTrackedItem.isKindOf(CM_Generator) 
			and ( self.otherTrackedItem.CM_Generator.isNoseMounted() or self.otherTrackedItem.CM_Generator.isUnderSlung() )
			then
				
				lDetail := app.getErrorString(CM_Generator_GC);
				lDetail := lDetail &amp; " " &amp; self.otherTrackedItem.id;
				lDetail := lDetail &amp; " " &amp; app.getErrorString(Detached);
			
			else
			
				lDetail := "Detached from";
				if self.getOtherTrackedItem() &lt;&gt; null then
					lDetail := lDetail &amp; " " &amp; self.otherTrackedItem.id;
				endif;
		
			endif;
		
			lDetail := lDetail &amp; " " &amp; self.urNumber.String;			
			
			return lDetail;
			
		endif;
	
	elseif _attrName = ETRow_DetachedId then
		ti := self.getOtherTrackedItem();
		if ti &lt;&gt; null then
			return ti.id;
		else
			return null;
		endif;	

	else
		return inheritMethod(_attrName, _short);
	
	endif;

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getEnquiryRow" id="703e8323-6451-4665-ae46-9ede8932b5e8">
        <source>getEnquiryRow(): String;
// ---------------------------------------------------------------------------
// Created:  May  2001 By Andrew Bishop cnwab1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	lDetail : String;
	
begin

	lDetail := inheritMethod();

	//Par17775. ccms1045 APM - Yard Ops, new generator types.
	if self.otherTrackedItem &lt;&gt; null
	and self.otherTrackedItem.isKindOf(CM_Generator) 
	and ( self.otherTrackedItem.CM_Generator.isNoseMounted() or self.otherTrackedItem.CM_Generator.isUnderSlung() )
	then
		
		lDetail := lDetail &amp; app.getErrorString(CM_Generator_GC);
		lDetail := lDetail &amp; " " &amp; self.otherTrackedItem.id;
		lDetail := lDetail &amp; " " &amp; app.getErrorString(Detached);
	
	else
	
		lDetail := lDetail &amp; "Detached from";
		if self.getOtherTrackedItem() &lt;&gt; null then
			lDetail := lDetail &amp; " " &amp; self.otherTrackedItem.id;
		endif;

	endif;

	if lDetail &lt;&gt; "" then
		lDetail := lDetail &amp; " " &amp; self.urNumber.String;
	else
		lDetail := self.urNumber.String;
	endif;			
	
	return lDetail;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
