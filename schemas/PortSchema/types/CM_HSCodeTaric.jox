    <JadeMethod name="getDisplayStringForAttribute" id="954f7491-61f3-4a9f-8b9f-171624dd68fe">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26/02/2023	navkc1 CR 59577 Task 62410: Jade - New TRX for HS Taric

*/

vars
	heading : CM_HSCodeHeading;
	
begin
	
	if _attrName = ETRow_Type then
		return app.getErrorString(Taric_code);
	elseif _attrName = ETRow_HeadingDescription then
		heading := self.getMyHeading();
		if heading = null then
			return null;
		endif;
		
		if heading.description.length() &gt; 50 then
			return heading.description[1:50] &amp; "...";
		else
			return heading.description;
		endif;
	elseif _attrName = ETRow_HsParentSubCode then
		if self.myHSSubCode &lt;&gt; null then
			return self.myHSSubCode.id;
		endif;
		return null;
	endif;
	
	return inheritMethod(_attrName, _short);
	
epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getFullDescription" id="23040d2e-0015-49d9-9e59-2203b1a39e46">
        <source>getFullDescription(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26/02/2023	navkc1 CR 59577 Task 62410: Jade - New TRX for HS Taric

*/

vars

begin
	
	if self.myHSSubCode = null then
		return inheritMethod();
	endif;
	
	return self.myHSSubCode.getFullDescription() &amp; ": " &amp; self.description;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
