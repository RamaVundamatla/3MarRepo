    <JadeMethod name="doRejectTask" id="2b6b2844-6c1c-42f5-acff-b45ffaecc605">
        <updating/>
        <source>doRejectTask() updating, protected;
/*

Purpose:			


Return Value:		


Date		Who		Reason
18 September 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars
	obj : Object;
	errorMsg : MobileHandHeldThin::DTO_HandHeldGateError;
	theTable 	: Table;
	row : Integer;
	allRejectedTasks : CM_RTQueueTaskArray;
begin
	app.mousePointer	:=	Busy;
	theTable:=tblJobs;
	
	create allRejectedTasks transient;
	self.getAllSelectedQueueTasks(allRejectedTasks);
	
	
	if allRejectedTasks.size = 0  then
		app.msgBox("You must select an item in the list","Job",MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	self.clearErrors;
	app.myVehicleMountedSTRADGuiAgent.doCancelTasks( allRejectedTasks,allErrorMsgs);
	
	if self.checkErrors then
		return;
	endif;
	
	self.frmAccept.visible := false;
	self.changeDefaultButtons(btnMsgOK,btnAccept);
	self.changeCancelButtons(btnMsgCancel,btnLogoff);
	

epilog
	delete allRejectedTasks;
	app.mousePointer	:=	Idle;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doSetdownTask" id="241f20f4-3761-4499-aff2-ec01da9d4901">
        <source>doSetdownTask();
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 January 2009	cnwer1	Initial creation

*/

vars
	allSelectedEntries : CM_RTQueueTaskArray;
	rtTask,twinRTTask 				: CM_RTQueueTask;
	hasTwinRTEntry 	   : Boolean;
	row					: Integer;
	containerStr,
	setdownLoc: String;
begin


	
	hasTwinRTEntry:=(self.tblJobs.rows - self.tblJobs.fixedRows) = 2;
	row:=2;
	rtTask:=self.tblJobs.accessRow(2).itemObject.CM_RTQueueTask;
	containerStr:=self.tblJobs.accessCell(2,self.ColNoContainer).text;
	setdownLoc:=self.tblJobs.accessCell(2,self.ColNoTarget).text;
	self.lblSetdownTask.caption:=containerStr;
	self.txtSetdownLoc.text:=setdownLoc;
	self.txtSetdownLoc.enabled:=not app.myVehicleMountedSTRADGuiAgent.isSetdownLocationOnVoyage(rtTask);
	
	
	
	self.lblSetdownTwin.visible:=hasTwinRTEntry;
	self.lblSetdownToTwin.visible:=hasTwinRTEntry;
	self.txtSetdownTwin.visible:=hasTwinRTEntry;
	self.btnSwap.visible:=hasTwinRTEntry; // 5/3/09 epr par 18992
	if hasTwinRTEntry then
		twinRTTask:=self.tblJobs.accessRow(3).itemObject.CM_RTQueueTask;
		containerStr:=self.tblJobs.accessCell(3,self.ColNoContainer).text;
		setdownLoc:=self.tblJobs.accessCell(3,self.ColNoTarget).text;
		self.lblSetdownTwin.caption:=containerStr;
		self.txtSetdownTwin.text:=setdownLoc;
		self.txtSetdownTwin.enabled:=not app.myVehicleMountedSTRADGuiAgent.isSetdownLocationOnVoyage(twinRTTask);
	endif;
	self.frmSetdown.centreWindow();	
	self.frmSetdown.visible:=true;
	self.frmSetdown.zOrder(1);
	

	
	
epilog
	delete allSelectedEntries;
end;</source>
    </JadeMethod>
    <JadeMethod name="doSwap" id="1485b34a-d889-474b-b468-768e55571c32">
        <source>doSwap();
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 February 2009	cnwer1	Initial creation

*/

vars
	loc1,
	loc2  : String;
begin
	if not self.frmSetdown.visible then
		return;
	endif;
	
	loc1 :=self.txtSetdownLoc.text;
	loc2:=self.txtSetdownTwin.text;
	
	self.txtSetdownLoc.text:=loc2;
	self.txtSetdownTwin.text:=loc1;
epilog

end;</source>
