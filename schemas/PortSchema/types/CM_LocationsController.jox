    <JadeMethod name="getTotalVolumeActual" id="344f2f0d-d430-46d2-8cce-2fa98632f3ac">
        <source>getTotalVolumeActual() : Decimal;
//-----------------------------------------
//Created: October 2002 By: cnwgd1
//-----------------------------------------
// 29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
vars
	ti			: CM_TrackedItem;
	tot			: Decimal[16,4];
	loadState	: Boolean;
begin

	app.cmsBeginLoad(loadState);
	foreach ti in self.allTrackedItems do
		tot := tot + ti.getMyTotalVolume;
	endforeach;
	return tot;
	
epilog
	app.cmsEndLoad(loadState);
end;</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="getTotalWeightActual" id="81ef907a-9d69-49ae-b417-f115ed6d57be">
        <source>getTotalWeightActual() : Decimal;
//-----------------------------------------
//Created: October 2002 By: cnwgd1
//-----------------------------------------
vars
	ti			: CM_TrackedItem;
	tot			: Decimal[14,4];
	loadState	: Boolean;
begin

	app.cmsBeginLoad(loadState);
	sharedLock(self);
	foreach ti in self.allTrackedItems do
		sharedLock(ti);
		//tot := tot + ti.weight;					//-cnwml2 MSL CCMS 1017
		tot := tot + ti.totalWeight;				//+cnwml2 MSL CCMS 1017
	endforeach;
	return tot;
	
epilog
	app.cmsEndLoad(loadState);
end;</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="getTotalWidthRaw" id="4f18df8e-777f-4e6a-826c-3e3c02c1bacf">
        <source>getTotalWidthRaw():Decimal;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
15 July 2009	cnwndl1	Initial creation

*/

vars
	tiWidth	: Decimal [12,2];
	maxWidth	: Decimal [12,2];
	ti : CM_TrackedItem;	
begin

	maxWidth := 0;
	foreach ti in self.allTrackedItems do
		tiWidth := ti.getActualWidthRaw();
		if tiWidth &gt; maxWidth then
			maxWidth := tiWidth;
		endif;
	endforeach;

	return maxWidth;
	
end;</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
