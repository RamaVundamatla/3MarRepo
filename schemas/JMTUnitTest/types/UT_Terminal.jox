    <JadeMethod name="addBank" id="39d3b264-1db5-41f3-8344-302c7fc8c4cd">
        <source>addBank():CM_Bank;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 May 2015	cnwndl1	Initial creation

*/

vars
	term	: CM_Terminal;
	theController : CMIF_BankDetails;
	aComp, pxyComp : CM_Bank;
	comp2, pxyComp2 : CM_Bank;
	now : TimeStamp;
begin

	now := app.actualTimeServer();	// 16 Sept 2016	cnwns1	TFS 488 - Multi Timezone Support
	
	term := self.getTerminal();
	aComp := app.myRoot.myRootCompany.subCompanies[term,"UTST"];
	if aComp &lt;&gt; null then
		app.myTrxDA.trxDeleteBank(aComp, app.myPassport);
	endif;
	comp2 := app.myRoot.myRootCompany.subCompanies[term,"UTB3"];
	if comp2 &lt;&gt; null then
		app.myTrxDA.trxDeleteBank(comp2, app.myPassport);
	endif;

	
	create theController transient;
	
	// Test Create
	theController.isBU := true;
	theController.myParentCompany := app.myRoot.myRootCompany;
	
	theController.setBankDetails("BANK DETAILS");
	theController.setMailingAddress("MAILING ADDRESS");
	theController.setRemittanceAddress("REMITTANCE"); 
	
	theController.code := "UTST";
	theController.emailAddress := "EMAIL@EMAIL.COM";
	theController.faxNumber := "FAX NUMBER";
	theController.isSuspended := false;
	theController.mailingName := "MAILING NAME";
	theController.onsiteStorageChargeTime := now.time;
	theController.phoneNumber := "PHONE";
	theController.retrospectiveRates := false;
	// Note: tax details are not actually saved when isBU is true
	theController.taxNarration := "TAXCODE";
	theController.taxNumber := "TAXNUM";
	theController.taxPercentageRate := 15;
	theController.myBusinessUnitDebtor := null;
	theController.myInvoiceProcess := CM_InvoiceProcessDefault.firstInstance;
	// ####
	
	create pxyComp transient;
	theController.myProxyBank := pxyComp;
	pxyComp.setProxy(theController);

	app.myTrxCA.trxCreateBank(theController,aComp,app.myPassport);
	self.assertFalseMsg(app.myPassport.hasErrorsOrWarnings, 'Error in BANK CREATION &gt;&gt; ' &amp; CrLf &amp; app.myPassport.getAllErrorsWarningsAsString());
	self.assertEqualMsg(aComp.mailingName, "MAILING NAME", "Bank mailing name, add");

	// test Change
	delete pxyComp;
	pxyComp := app.createUpdateProxy(aComp).CM_Bank;
	theController.mailingName := "Mail to me here";
	theController.myProxyBank := pxyComp;
	pxyComp.setProxy(theController);

	app.myTrxUA.trxUpdateBank(theController, app.myPassport);
	self.assertFalseMsg(app.myPassport.hasErrorsOrWarnings, 'Error in BANK UPDATE &gt;&gt; ' &amp; CrLf &amp; app.myPassport.getAllErrorsWarningsAsString());
	self.assertEqualMsg(aComp.mailingName, "Mail to me here", "Bank mailing name, update");
	
	// create a second bank
	delete theController;
	create theController transient;
	theController.isBU := true;
	theController.myParentCompany := aComp;
	
	theController.setBankDetails("BANK DETAILS2");
	theController.setMailingAddress("MAILING ADDRESS2");
	theController.setRemittanceAddress("REMITTANCE"); 
	
	theController.code := "UTB3";
	theController.emailAddress := "EMAIL@EMAIL.COM";
	theController.faxNumber := "FAX NUMBER2";
	theController.isSuspended := false;
	theController.mailingName := "MAILING NAME2";
	theController.onsiteStorageChargeTime := now.time;
	theController.phoneNumber := "PHONE2";
	theController.retrospectiveRates := false;
	theController.myBusinessUnitDebtor := null;
	theController.myInvoiceProcess := CM_InvoiceProcessDefault.firstInstance;
	create pxyComp2 transient;
	theController.myProxyBank := pxyComp2;
	pxyComp2.setProxy(theController);

	app.myTrxCA.trxCreateBank(theController,comp2,app.myPassport);
	self.assertFalseMsg(app.myPassport.hasErrorsOrWarnings, 'Error in BANK CREATION 2 &gt;&gt; ' &amp; CrLf &amp; app.myPassport.getAllErrorsWarningsAsString());

	return comp2;
	
epilog

	delete theController;
	delete pxyComp;
	delete pxyComp2;
end;</source>
        <ReturnType type="CM_Bank"/>
    </JadeMethod>
