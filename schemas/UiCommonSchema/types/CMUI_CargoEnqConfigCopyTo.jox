    <JadeMethod name="populateUsers" id="11651578-7fd7-4ce0-9a6a-167402bddab5">
        <updating/>
        <source>populateUsers() updating, protected;
// all users into the copy-from list
vars
	idx		: Integer;
	userName	: String;
	user	: CM_User;
begin
	self.lstUserFrom.clear();
	foreach user in app.myRoot.allUsers discreteLock do
		// exclude not-for-entry and self
		if user.isNotAvailableForEntry or
		   user = app.myPassport.myUser then
			continue;
		endif;
		if user.userName = null then
			userName := user.code;
		else
			userName := user.userName; 
		endif;
		idx := self.lstUserFrom.addItem(userName);
		lstUserFrom.itemObject[idx] := user;
	endforeach;
end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupForm" id="b1cfeaa8-59d9-499a-a074-f10d48e99702">
        <updating/>
        <source>setupForm() updating;

vars

begin
	inheritMethod();
	
	self.populateUsers();
	self.btnNext.enabled := false;
end;
</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="51f119d3-c78d-4c77-b584-52ae011d3952">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0016851, locale);
	btnAdd.translateCaption(Xlat_0016852, locale);
	btnCancel.translateCaption(Xlat_0016853, locale);
	btnNext.translateCaption(Xlat_0016854, locale);
	btnRemove.translateCaption(Xlat_0016855, locale);
end;</source>
    </JadeMethod>
</GUIClass>
