    <JadeMethod name="click" id="a6642f3d-1969-4d79-97c3-62dd2f77a1b6">
        <controlMethod name="Table::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>click(table: Table input) updating, clientExecution;

vars

begin
	// sort on column heading click
	if table.row = table.fixedRows then
		table.sortColumn[1] := table.column;
		table.sortAsc[1] := not table.sortAsc[1];
		table.resort;
		return;
	endif;	

	inheritMethod(table);
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="displayTranslatableText" id="cc1b38b2-dd07-41a1-957e-1189ac537c4d">
        <updating/>
        <source>displayTranslatableText(translatableText : XLAT_TranslatableText; _existingRow : Integer; colorRow1, colorRow2 : Integer) updating;

vars
	str				 	: String;
	rowIdx				: Integer;
begin

	rowIdx := _existingRow;

	// display table row
	str := translatableText.getAttributeStringForDefArray(allTblDataEntRows);
	if rowIdx &lt;&gt; 0 then
		setCellText(rowIdx,1,str);	 // update
	else	
		rowIdx := self.addItem(str); // new
	endif;
	accessRow(rowIdx).itemObject := translatableText;

	if rowIdx mod 2 = 0 then
		accessRow(rowIdx).backColor := colorRow1;
	else
		accessRow(rowIdx).backColor := colorRow2;			
	endif;			

	// use 'decimals' to store object edition - happens to be of the correct type, and unused
	accessRow(rowIdx).JadeTableRow.decimals := translatableText.edition;	
end;</source>
        <Parameter name="translatableText" type="XLAT_TranslatableText"/>
        <Parameter name="_existingRow" type="Integer"/>
        <Parameter name="colorRow1" type="Integer"/>
        <Parameter name="colorRow2" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getSelectedText" id="f0dcbc3f-6ca4-4922-818c-c0a337e90938">
        <updating/>
        <source>getSelectedText():XLAT_TranslatableText updating;

// currently saves single selection, but could be changed to handle multiple

begin
	return accessRow(row).itemObject.XLAT_TranslatableText;
end;</source>
        <ReturnType type="XLAT_TranslatableText"/>
    </JadeMethod>
    <JadeMethod name="initialise" id="8b7fddd2-ae3d-4932-9e3d-e9f85f59fe85">
        <updating/>
        <source>initialise(_xlatCategory : String; _sheet : CMUI_DataTableSheet; _isDeveloperMode : Boolean) updating;

vars
	entTableDefinition : String;
	col : Integer;

begin
	mySheet := _sheet;
	myTranslationCategory := app.myRoot.allXLAT_Categories[_xlatCategory];	

	if myTranslationCategory.constantCategoryName = XLAT_FormCaptions then
		if _isDeveloperMode then
			entTableDefinition := ETDef_FormCaptionsDev;
		else
			entTableDefinition := ETDef_FormCaptions;
		endif;
	else
		if _isDeveloperMode then
			entTableDefinition := ETDef_TextTranslationDevMode;
		elseif myTranslationCategory.usesShortText then
			entTableDefinition := ETDef_TextTranslationShort;
		else
			entTableDefinition := ETDef_TextTranslation;
		endif;
	endif;

	setTblDataEntRowsFromDef(app.myController.getEntTableDef(entTableDefinition));
	setMyDataClass(XLAT_TranslatableText);

	// Set the row and column sizes.
	rowHeight[1] := 20;
	columnWidth[1] := 50;
	
	userInputEnabled	 := false;
	selectMode 			 := SelectMode_CurrentRow;
//	selectionType	 	 := SelectionType_None;
//	multiSelect 		 := MultiSelect_Simple;
	multiSelect 		 := MultiSelect_None;	// currently single selection, but could be changed to handle multiple
	stretchWidth 		 := true;
	stretchHeight 		 := false;
//	autoSize			 := AutoSize_Both;
end;
</source>
        <Parameter name="_xlatCategory" type="String"/>
        <Parameter name="_sheet" type="CMUI_DataTableSheet"/>
        <Parameter name="_isDeveloperMode" type="Boolean"/>
    </JadeMethod>
