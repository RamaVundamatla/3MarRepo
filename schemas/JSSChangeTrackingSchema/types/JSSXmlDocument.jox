    <JadeMethod name="setListboxColors" id="06063cd9-c0b0-472f-9bde-c0c3a099edf2">
        <updating/>
        <source>setListboxColors(pForeColorElement: Integer; pForeColorAttribute: Integer) updating;
/*
*/
begin
