    <JadeMethod name="displayString" id="c930a805-4f2d-4f83-9a09-49c9fae6d3f1">
        <methodInvocation>mapping</methodInvocation>
        <source>displayString(set: Boolean; _value: String io) mapping;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 October 2018	jlger1	Initial creation

*/

vars
	display : String;
	terminalId : String;
	extServiceName : String;
	invalidObj : Boolean;
begin
	on Exception do app.handleDeletedObject(exception,  self.myExternalWSDef, invalidObj);
	

	if not set then
		if self.myTerminal &lt;&gt; null then
			terminalId :=" (" &amp;  self.myTerminal.code &amp; ")";
		endif;
		
		if self.myExternalWSDef &lt;&gt; null then
			extServiceName:= " " &amp; self.myExternalWSDef.name;
		endif;
		
		_value:=self.name &amp;  extServiceName &amp; terminalId;
		
	else
		inheritMethod(set, _value);
	endif;
epilog

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="doCheckForRetries" id="3bbd1acd-1ef7-4d98-b369-3be0b4d344a1">
        <updating/>
        <source>doCheckForRetries() updating;
//
// 11 June 2018	jlgrs1	TFS 39013 (37190) Pelindo BGP Web Service
//
vars
	tmpClass : Class;
	className : String;
	request : BGP_Request;
	object : Object;
	now : TimeStamp;
begin
	now := app.actualTimeServer();
	foreach className in self.allRequestClassesToProcess do
		tmpClass := self.getClass(className);
		foreach object in tmpClass.instances do
			request := object.BGP_Request;
			if not request.isProcessed and
			   request.BGP_ExternalWSRequest.nextRetryTime &lt;&gt; null and
			   request.BGP_ExternalWSRequest.nextRetryTime &lt; now then
				self.processRequest(request);
			endif;
		endforeach;
	endforeach;	
epilog

end;</source>
    </JadeMethod>
