    <JadeMethod name="utlDeleteSlotRequest" id="ce540434-aaee-431b-b869-89ffa5aafebb">
        <source>utlDeleteSlotRequest(_slotRequest:CM_SlotRequest io; _continueExceptions: Boolean; _passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	
begin

	self.initialiseActivity();

	app.setContinueCMExceptions(true);	//always continue these exceptions

	app.myValDA.valSlotRequest(_slotRequest);
	
	if (not self.checkValidationWithPassport(_passport)) then // Show any Errors and Warnings in a list
		return;
	endif;

	app.setContinueCMExceptions(_continueExceptions);	//continue these exceptions for EDI, when deleting in bulk

	if _passport.noErrors then
		self.myDeleteAuditAgent.audDeleteGeneric(_slotRequest);
	endif;

	if _passport.noErrors then
		_slotRequest.mySlotController.removeSlotRequest(_slotRequest);
	endif;

epilog
	return;

end;</source>
        <Parameter name="_slotRequest" type="CM_SlotRequest" usage="io"/>
        <Parameter name="_continueExceptions" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlDeleteSlotRequests" id="345da352-b200-422f-bbdb-96a445e47671">
        <source>utlDeleteSlotRequests(_structure: CM_CellularVoyageStructure; _moveType: Integer; _deleteLinked: Boolean; _passport: CM_Passport input);
//----------------------------------------------------------------
//	Created:	20 October 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

	bay				: CM_BayVoyage;	
	linkedRequest : CM_Request;
	slotRequest,
	tmpSlotRequest
		: CM_SlotRequest;
begin
	
	//self.initialiseActivity(); //cnwgb1 30133 14.8.2012

	//app.setContinueCMExceptions(false); //cnwgb1 30133 14.8.2012

	foreach bay in _structure.allBayVoyagesByOrdinal do
		foreach slotRequest in bay.allSlotRequestByMoveType do//where slotRequest.moveType = _moveType do (will overlook linked)
			tmpSlotRequest := null;
			linkedRequest := null;
			
			if _moveType &lt;&gt; DISCHARGE_MOVETYPE and slotRequest.isLoad then
				if _deleteLinked then
					linkedRequest := slotRequest.getLinkedRequest(false); // PAR 28968 mySlotRequestDLRSOBDischarge;
				endif;
				tmpSlotRequest := slotRequest;
			
			elseif _moveType &lt;&gt; LOAD_MOVETYPE and slotRequest.isDischarge then
				if _deleteLinked then
					linkedRequest := slotRequest.getLinkedRequest(true); // PAR 28968 .mySlotRequestDLRSOBLoad;
				endif;
				tmpSlotRequest := slotRequest;
			
			else
				//app.writeStatement('CNWJC2 ' &amp; class.name &amp; " " &amp; method.name &amp;  " " &amp; slotRequest.moveType.String);
				continue;
			
			endif;
		
			if linkedRequest &lt;&gt; null then
				linkedRequest.erase(NORMAL_ERASE);
			endif;
				
			if tmpSlotRequest &lt;&gt; null then
				tmpSlotRequest.erase(NORMAL_ERASE);
			endif;
	
		endforeach;
	endforeach;

	//epr TFS 5617 23/8/17 not is from the voyage not the structure
	_structure.myVoyage.causeEvent(_structure.myVoyage.myTerminal.getTerminalEvent(EDI_ColourCode_Update), false, null);


end;</source>
        <Parameter name="_structure" type="CM_CellularVoyageStructure"/>
        <Parameter name="_moveType" type="Integer"/>
        <Parameter name="_deleteLinked" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
