        <Parameter name="_isTarget" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getFullIdTI" id="982d4d3c-e491-42aa-92f0-1b6a849c77d3">
        <source>getFullIdTI(_ti: CM_TrackedItem): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 December 2014	cnwndl1	Initial creation	Par 35345

*/

vars

	str : String;
	pos : Integer;
	
begin
		
	if self.myTerminal.getConfig( RailDefaultWCIdFormat ).Integer = Rail_UPSP_Int then
		return self.getIdUPSPformat( _ti );
	
	else
		str := inheritMethod(_ti);
		if _ti &lt;&gt; null then
			if self.myWagon &lt;&gt; null and self.myWagon.myWagonClass.maxNumInStack &gt; 1 then
				if self.allTrackedItems.includes( _ti ) then
					pos := self.allTrackedItems.indexOf(_ti);
					str := str &amp; " " &amp; pos.String;
				endif;
			endif;
		endif;
		
		return str;
		
	endif;
	
	
end;
</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="String"/>
    </JadeMethod>
