    <JadeMethod name="getYAIdentifier" id="8dd998e1-735c-4a74-84a7-8d7939846d55">
        <source>getYAIdentifier(): String;

/*

Purpose:		Returns the identifier for the criteria that is used for data entry.

Date			Who		Reason
24/02/2011		cnwmh5	Initial creation #26912
05 Apr 2017		cnwma1 TFS #3890:STWO - Add 'in transit' to Cargo allocations
*/

vars
	value: Integer;
	displayString: String;
	
begin
	if self.myYAParent.myYACriteriaType.isIntendedRelModeType then
		foreach value in self.allValues do
			displayString := displayString &amp; app.intendedReleaseModeEnum2String(value) &amp; ", ";
		endforeach;
		if displayString &lt;&gt; null then
			displayString := displayString[1:displayString.length-2];
		endif;
		return displayString.toUpper();	
	elseif self.myYAParent.myYACriteriaType.isTransportModeType then
		foreach value in self.allValues do
			displayString := displayString &amp; app.transModeToString(value) &amp; ", ";
		endforeach;
		if displayString &lt;&gt; null then
			displayString := displayString[1:displayString.length-2];
		endif;
		return displayString.toUpper();
	elseif self.myYAParent.myYACriteriaType.isTransitStatusType then //05/04/2017 cnwma1 TFS #3890
		foreach value in self.allValues do
			displayString := displayString &amp; app.transitStatusEnum2String(value) &amp; ", ";
		endforeach;
		if displayString &lt;&gt; null then
			displayString := displayString[1:displayString.length-2];
		endif;
		return displayString.toUpper();
	
	endif;
	
	return self.allValues.asCSV(false);

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
