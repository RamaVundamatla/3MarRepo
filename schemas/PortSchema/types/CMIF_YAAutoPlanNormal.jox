    <JadeMethod name="isVoyageBerth_Match" id="fe678247-2450-45dc-9215-4302459cd7ec">
        <source>isVoyageBerth_Match(_yaData: CM_YADataObjects): Boolean;
// -------------------------------------------
// Created 27 May 2005 by cnwdvb1
// -------------------------------------------
vars

	voyage 			: CM_Voyage;
	hmsVoyageData	: HMS_VoyageData;

begin

	voyage := self.myTrackedItem.myVoyage;
	
	if voyage = null or voyage.myHMSVoyageData = null then
		return false;
	endif;
	
	// Only priorities will be empty.
	if _yaData.isEmpty() then
		return true;
	endif;
	
	hmsVoyageData := voyage.myHMSVoyageData;
	
	return _yaData.matches(hmsVoyageData.getMyBerth);


end;</source>
        <Parameter name="_yaData" type="CM_YADataObjects"/>
        <ReturnType type="Boolean"/>
