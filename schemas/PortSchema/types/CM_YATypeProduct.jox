    </JadeMethod>
    <JadeMethod name="getDataDisplay" id="ce52822c-f253-4130-994d-6dac0d71bcc6">
        <source>getDataDisplay(pDataObj : CM_YAData) : String;
//01 August 2008	cnwdw1
// 12/07/2011	cnwmh5		#27772 - Get the correct string
// 09/09/2011	cnwmh5		#28095 - Change so handles product codes that look like oids correctly
vars
	subtype			: CM_Product;
	obj				: Object;
	
	tokens			: StringArray;
	productArray	: ObjectArray;
	
	iter			: Iterator;
	
	str				: String;	
begin
	
	// 09/09/2011 cnwmh5 #28095
	if pDataObj.isKindOf(CM_YADataPattern) then
		create tokens transient;
		create productArray transient;
		str := pDataObj.CM_YADataPattern.pattern;
		tokens := str.cnGetTokens(", ");
		foreach str in tokens do
			subtype := str.asObject.CM_Product;
			productArray.add(subtype);
		endforeach;
		iter := productArray.createIterator;
	elseif pDataObj.isKindOf(CM_YADataObjects) then
		iter := pDataObj.CM_YADataObjects.allObjects.createIterator;
	endif;
	
	str := null;
	while iter.next(obj) do
		if str &lt;&gt; null then
			str := str &amp; ", ";
		endif;
		subtype := obj.CM_Product;						// 09/09/2011 cnwmh5 #28095
		if subtype &lt;&gt; null then
			str := str &amp; subtype.getYADisplay();
		endif;
	endwhile;
	
	return str;
epilog
	delete tokens;
	delete iter;
	delete productArray;
end;</source>
        <Parameter name="pDataObj" type="CM_YAData"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDependentObjects" id="45cb7198-2e80-4108-b510-00f2beb6a71b">
        <source>getDependentObjects(_objs: CM_ObjectArray input; _value : Any; _type : CM_YACriteriaType);
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17/09/2013	cnwmc5	Initial creation	PAR 32155
07/04/2014	cnwdap1	PAR #33606 CCMS SFW 1366 Bulk - correct handling of dellimiters to allow for cargo type names with spaces in them
*/

vars
	cargoTypes		: CM_CargoTypeSet;
	cargoType		: CM_CargoType;
	
	strArr			: StringArray;
	str				: String;
begin
	inheritMethod(_objs, _value, _type);
	
	create strArr transient;
	create cargoTypes transient;
	//_value.String.getTokensForDelimiter(', ', strArr);				// PAR #33606
	_value.String.getTokensForDelimiter(',', strArr);					// PAR #33606
	
	if _type.isKindOf(CM_YATypeCargoType) then
		app.myRoot.allCargoTypesById.copy(cargoTypes);
		foreach cargoType in cargoTypes do
			foreach str in strArr do
				//if cargoType.abbreviation = str then					// PAR #33606
				if cargoType.abbreviation = str.trimBlanks then			// PAR #33606
					_objs.add(cargoType);
				endif;
			endforeach;
		endforeach;
	endif;
epilog
	delete strArr;
end;</source>
        <Parameter name="_objs" type="CM_ObjectArray" usage="input"/>
        <Parameter name="_value" type="Any"/>
        <Parameter name="_type" type="CM_YACriteriaType"/>
    </JadeMethod>
    <JadeMethod name="getDependentTypes" id="f97da89e-2a35-4252-ad6e-3059c6175c36">
