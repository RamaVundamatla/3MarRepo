    <JadeMethod name="setWeightCountCaptions" id="1552b23d-412b-4d15-89ae-ceba7fb1e644">
        <source>setWeightCountCaptions();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 July 2011	cnwndl1	Initial creation
20 Dec 2018	NDL	TFS 38083 - Take into account multiple parents
23/06/2023	navkc1	CR 58406 Task 58408: Jade - Release Request All Tracked Items
*/

vars

	weightStr : String;
	tiMaster : CM_TIMaster;
	tonnes : Integer;
	colour : Integer;
	prod : CM_Product;
	ti : CM_TrackedItem;
	bulkRelease : CM_BulkRelease;
	childReserve : CM_ReserveDetail;
	totalMyContPackedCount : Integer;
	totalMyContWtPacked : Decimal [14,4];
	totalMyContVolPacked : Decimal [14,4];
	totalChildrenReq : Integer;
	totalWeightReq : Decimal [14,4];
	totalVolumeReq : Decimal [14,4];
	cargoType : CM_CargoType;
	measure	: CM_MeasurementType;
	reqStr :String;
	//20 Dec 2018	NDL	TFS 38083
	totalOtherContPackedCount : Integer;
	totalOtherContWtPacked : Decimal [14,4];
	totalOtherContVolPacked : Decimal [14,4];
	
	totalChildrenAvail : Integer;
	totalWeightAvail : Decimal [14,4];
	totalVolumeAvail : Decimal [14,4];
	allTis	: CM_TISet;
begin
	create allTis transient; //23/06/2023	navkc1	CR 58406 Task 58408
	colour := Black;
	
	if self.myMobileGenericAgent.myPackStockBookingRef &lt;&gt; null then
		weightStr := myMobileGenericAgent.myPackStockBookingRef.getPackAsString &amp; "    " &amp; app.getErrorString(ParentWt) &amp; " ";
	else
		weightStr := app.getErrorString(ParentWt) &amp; " ";
	endif;
	//weightStr := weightStr &amp; self.myPackContainer.totalWeight.Integer.String;
	// cnwrd1 ccms 1321 imperial measurements
	prod := self.myPackContainer.getProductForMeasurementConv();
	weightStr := weightStr &amp; self.myMobileDataAgent.getMeasureConvertedForDisplay(prod,Type_Weight,self.myPackContainer.totalWeight) &amp; self.myMobileDataAgent.getMeasureLabelUnit(prod,Type_Weight);
	
	tiMaster := app.myRoot.allTiMasters.getAtKey( self.myPackContainer.cargoType,  self.myPackContainer.id);
	if tiMaster &lt;&gt; null then
		if tiMaster.isKindOf(CM_TIMasterContainer) then
			if tiMaster.CM_TIMasterContainer.maxKilos &gt; 0 then
				tonnes := ( tiMaster.CM_TIMasterContainer.maxKilos/1000 ).Integer;
				if tonnes &gt; 0 then
					//weightStr := weightStr &amp; " (" &amp; tonnes.String &amp; "t" &amp; ")";
					weightStr := weightStr &amp; " (" &amp; self.myMobileDataAgent.getMeasureConvertedForDisplay(null,Type_Weight,tiMaster.CM_TIMasterContainer.maxKilos) &amp; self.myMobileDataAgent.getMeasureLabelUnit(null,Type_Weight) &amp; ")";
					if tiMaster.CM_TIMasterContainer.maxKilos &lt; self.myPackContainer.totalWeight.Integer then
						colour := Red;
					endif;
				endif;
			endif;
		endif;
	endif;
	
	self.lblWeight.caption :=  weightStr;	
	self.lblWeight.foreColor := colour;
	
	// show how much requested too 18 Jan 2016	NDL	Par 37422
	bulkRelease := self.myMobileGenericAgent.myBulkRelease;
	if bulkRelease &lt;&gt; null and bulkRelease.isPackingType then
		foreach ti in self.myPackContainer.allChildren do
			//13 Jun 2016	NDL	TFS 2133
			if not ti.allBulkReleasesAssigned.includes( bulkRelease ) then
				continue;
			endif;
			cargoType := ti.myCargoType;
			if cargoType &lt;&gt; null and cargoType.isTrackByVolume then
				totalMyContVolPacked := totalMyContVolPacked + ti.totalVolume;
			elseif cargoType &lt;&gt; null and cargoType.isTrackByWeight then
				totalMyContWtPacked := totalMyContWtPacked + ti.totalWeight;
			else
				totalMyContPackedCount := totalMyContPackedCount + ti.totalQuantity.max(1);
			endif;
		endforeach;
	
		foreach childReserve in bulkRelease.allReservePackingChildren do
			cargoType := childReserve.getCargoType;
			if cargoType &lt;&gt; null and cargoType.isTrackByVolume then
				totalVolumeReq := totalVolumeReq + (childReserve.weightRequested / childReserve.getDensity);
			elseif cargoType &lt;&gt; null and cargoType.isTrackByWeight then
				totalWeightReq := totalWeightReq + childReserve.weightRequested;
			else
				totalChildrenReq := totalChildrenReq + childReserve.totalRequested;
			endif;
			childReserve.getAllTrackedItems(allTis, false); //23/06/2023	navkc1	CR 58406 Task 58408
			//20 Dec 2018	NDL	TFS 38083 - count the packed values for the other containers
			//foreach ti in childReserve.allTrackedItems do
			foreach ti in allTis do //23/06/2023	navkc1	CR 58406 Task 58408
				if self.myPackContainer.allChildren.includes( ti ) then
					continue; //already counted above.
				endif;
				if ti.myCargoType &lt;&gt; null and ti.myCargoType.isTrackByVolume then
					totalOtherContVolPacked := totalOtherContVolPacked + ti.totalVolume;
				elseif ti.myCargoType &lt;&gt; null and ti.myCargoType.isTrackByWeight then
					totalOtherContWtPacked := totalOtherContWtPacked + ti.totalWeight;
				else
					totalOtherContPackedCount := totalOtherContPackedCount + ti.totalQuantity.max(1);
				endif;
			endforeach;
		endforeach;
		
		//20 Dec 2018	NDL	TFS 38083 -
		totalChildrenAvail := totalChildrenReq - totalOtherContPackedCount;
		totalWeightAvail := totalWeightReq - totalOtherContWtPacked;
		totalVolumeAvail := totalVolumeReq - totalOtherContVolPacked;
		
		reqStr := null;
		if totalVolumeAvail &gt; 0 or totalWeightAvail &gt; 0 or totalChildrenAvail &gt; 0 then
			if totalVolumeAvail &gt; 0 then
				measure := app.getDefaultMeasurementForType(Type_Volume);
				if totalMyContVolPacked = 0 then
					reqStr := app.getErrorString(VolumeAbbrev) &amp; " 0/" &amp; app.convertMeasurementForDisplay(measure.shortName, totalVolumeAvail) &amp; "(" &amp; measure.shortName &amp; ")";
				else
					reqStr := app.getErrorString(VolumeAbbrev) &amp; " " &amp; app.convertMeasurementForDisplay(measure.shortName, totalMyContVolPacked) &amp; "/" &amp; app.convertMeasurementForDisplay(measure.shortName, totalVolumeAvail) &amp; "(" &amp; measure.shortName &amp; ")";
				endif;
			endif;
			if totalWeightAvail &gt; 0 then
				if reqStr &lt;&gt; null then
					reqStr := reqStr &amp; ", ";
				endif;
				measure := app.getDefaultMeasurementForType(Type_Weight);
				if totalMyContWtPacked = 0 then
					reqStr := reqStr &amp; app.getErrorString(WeightAbbrev) &amp; " 0/" &amp; app.convertMeasurementForDisplay(measure.shortName, totalWeightAvail) &amp; "(" &amp; measure.shortName &amp; ")";
				else
					reqStr := reqStr &amp; app.getErrorString(WeightAbbrev) &amp; " " &amp; app.convertMeasurementForDisplay(measure.shortName, totalMyContWtPacked) &amp; "/" &amp; app.convertMeasurementForDisplay(measure.shortName, totalWeightAvail) &amp; "(" &amp; measure.shortName &amp; ")";
				endif;
			endif;
			if totalChildrenAvail &gt; 0 then
				if reqStr &lt;&gt; null then
					reqStr := reqStr &amp; ", ";
				endif;
				reqStr := reqStr &amp; app.getErrorString(CountAbbrev) &amp; " " &amp; totalMyContPackedCount.String &amp; "/" &amp; totalChildrenAvail.String;
			endif;
			
		elseif totalMyContVolPacked &gt; 0 or totalMyContWtPacked &gt; 0 or totalMyContPackedCount &gt; 0 then	// None requested but some packed
			if totalMyContVolPacked &gt; 0 then
				measure := app.getDefaultMeasurementForType(Type_Volume);
				reqStr := app.getErrorString(VolumeAbbrev) &amp; " " &amp; app.convertMeasurementForDisplay(measure.shortName, totalMyContVolPacked);
			endif;
			if totalMyContWtPacked &gt; 0 then
				if reqStr &lt;&gt; null then
					reqStr := reqStr &amp; ", ";
				endif;
				measure := app.getDefaultMeasurementForType(Type_Weight);
				reqStr := reqStr &amp; app.getErrorString(WeightAbbrev) &amp; " " &amp; app.convertMeasurementForDisplay(measure.shortName, totalMyContWtPacked);
			endif;
			if totalMyContPackedCount &gt; 0 then
				if reqStr &lt;&gt; null then
					reqStr := reqStr &amp; ", ";
				endif;
				reqStr := reqStr &amp; app.getErrorString(CountAbbrev) &amp; " " &amp; totalMyContPackedCount.String;
			endif;
			
		else	//Nothing requested and nothing packed.
			reqStr := reqStr &amp; "0";
			
		endif;
		
		self.lblCount.caption := app.getErrorString(Child) &amp; ": " &amp; reqStr;
		
	else
		//01 Sep 2014	Par 34717 / CCMS 2384
		foreach ti in self.myPackContainer.allChildren do
			totalMyContPackedCount := totalMyContPackedCount + ti.totalQuantity.max(1);
		endforeach;
		self.lblCount.caption := app.getErrorString(Child) &amp; " " &amp; app.getErrorString(CountAbbrev) &amp; " " &amp; totalMyContPackedCount.String;
		
	endif;
	
	

epilog
	delete allTis; //23/06/2023	navkc1	CR 58406 Task 58408
end;</source>
    </JadeMethod>
    <JadeMethod name="setupControls" id="8a75f49b-9336-4645-b748-db507e07e383">
        <updating/>
        <source>setupControls() protected, updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 July 2011	cnwndl1	Initial creation	Par 26476

*/

vars

	sheetName : String;

begin
	
	sheetName := self.myMobileGenericAgent.stringField1;
	
	self.docActsToDisplay.clear();
	self.myMobileGenericAgent.setAllReserveDetails( null );
	self.myMobileGenericAgent.setAllBookingRefItems( null );
	self.myMobileGenericAgent.setStringField1(null);
	
	self.setupToPackBtns();
	self.setupPackedBtns();
	self.setWeightCountCaptions();
	
	self.doResizeControls(true);
	
	if sheetName = self.shtPacked.name then
		self.fldCargo.querySheetChg(self.fldCargo,self.shtPacked);
		self.fldCargo.topSheet := self.shtPacked;
	elseif sheetName = self.shtToPack.name then
		self.fldCargo.querySheetChg(self.fldCargo,self.shtToPack);
		self.fldCargo.topSheet := self.shtToPack;
	endif;
	
	self.populateLstRelItems();
	
	self.txtCargoId.setFocus();
	

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupForm" id="dfead177-8308-4a59-a9b9-da83bb43cc1a">
        <updating/>
        <source>setupForm() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 July 2011	cnwndl1	Initial creation	Par 26476

*/

vars

	isFromDocAction : Boolean;	//05 Jan 2017	NDL	TFS 3157
	sheetName : String;	//05 Jan 2017	NDL	TFS 3157
	str : String;	//19 May 2017	NDL	TFS 4016

begin
	
	self.myHandHeldCheckerAgent := app.myHandHeldCheckerAgent;
	self.myPackContainer := self.myMobileGenericAgent.myPackTi;
	self.caption := app.getErrorString(Pack) &amp; " " &amp; self.myPackContainer.id;
	
	if app.myMobileCargoFindAgent = null then
		create app.myMobileCargoFindAgent transient;
	endif;
	
	//05 Jan 2017	NDL	TFS 3157
	if self.myMobileGenericAgent.allReserveDetails &lt;&gt; null and self.myMobileGenericAgent.allBookingRefItems &lt;&gt; null then
		isFromDocAction := ( self.myMobileGenericAgent.allReserveDetails.size + self.myMobileGenericAgent.allBookingRefItems.size ) &gt; 0 and ( self.myMobileGenericAgent.stringField1 &lt;&gt; null );
	endif;
	
	//19 May 2017	NDL	TFS 4016
	self.applyTwelveStwRules :=  self.myTerminal.getConfig(UseAltSelectRulesTL).Boolean and app.isCargoGroupEnabled;
	if self.applyTwelveStwRules then
		str := self.myMobileGenericAgent.stringField1;
		if str &lt;&gt; null and str.isInteger then
			self.stwRuleNum := str.Integer;
			self.myMobileGenericAgent.setStringField1( null );
		endif;
	endif;
	
	// returning from a search initiated from the 'clickInYardItem'
	if app.myMobileCargoFindAgent.myTrackedItemToProcess &lt;&gt; null then
		self.myMobileGenericAgent.setMyNextTiToAction(app.myMobileCargoFindAgent.myTrackedItemToProcess);
		app.myMobileCargoFindAgent.clearHistory( true );
		self.myMobileGenericAgent.setMyDeliveryRequest(null);
		
		if not self.validatePreCargoChecks( self.myMobileGenericAgent.myNextTiToAction ) then
			self.myMobileGenericAgent.setMyNextTiToAction( null );
			
		else
		
			//if self.myHandHeldCheckerAgent.myTerminal.allCargoChecks[CARGO_CHECK_CONTEXT_PACK].allCargoCheckItems.size &lt;&gt; 0 then
			if not self.myMobileGenericAgent.myTerminal.hasNoCargoCheckItemsFor(CARGO_CHECK_CONTEXT_PACK) then	//31 May 2012	NDL Par 29038
				//requires checks first
				self.myMobileGenericAgent.setChecksState(self.myMobileGenericAgent.PackCargo);
				self.gotoForm(MOB_HHGateCheckCargo, false);
				return;
			else
				// drop thru to the next code
			endif;
		
		endif;
	endif;
	
	//returning from 'MOB_HHGateCheckCargo' when we have done a 'Next' (initiated from code immediately above or from the 'clickInYardItem' )
	if self.myMobileGenericAgent.myNextTiToAction &lt;&gt; null then
		//epr par 34472 3/7/14
		self.doPack(self.myMobileGenericAgent.myNextTiToAction);
		self.myMobileGenericAgent.setMyNextTiToAction(null);
	endif;
	
	self.allowPackAll := false;

	inheritMethod();
	
	//self.setupCmdButtons( 2, app.getErrorString(Complete), app.getErrorString(Back), null, null, null );
	//10 Nov 2014	NDL	Par 35146
	
	if app.getMyUser.canDo(self.myTerminal, PmHHAllowLoadAll) then
		self.allowPackAll := true;
	endif;
	
	if self.allowPackAll then
		self.setupCmdButtons( 4, app.getErrorString(Complete), "Pack All", app.getErrorString(Refresh), app.getErrorString(Back), null );
	else
		self.setupCmdButtons( 3, app.getErrorString(Complete), app.getErrorString(Refresh), app.getErrorString(Back), null, null );
	endif;
	
	self.setupControls();
	
	if isFromDocAction then
		sheetName := self.myMobileGenericAgent.stringField1;
		if sheetName = self.shtToPack.name then
			self.fldCargo.querySheetChg(self.fldCargo,self.shtToPack);
			self.fldCargo.topSheet := self.shtToPack;
		elseif sheetName = self.shtPacked.name then
			self.fldCargo.querySheetChg(self.fldCargo,self.shtPacked);
			self.fldCargo.topSheet := self.shtPacked;
		endif;
	endif;

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupPackedBtns" id="183a701e-5a1f-4eb5-86fd-293515cdef49">
        <updating/>
        <source>setupPackedBtns() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 July 2011	cnwndl1	Initial creation	Par 26476
01 Nov	2016	cnwma1	TFS #2857:PAR38311 STWR - Unhandled exception when doing a Pack All
*/

constants

	TAB_INDEX_START = 1000;
	
vars

	errMess : String;
	buttonWidth : Real;
	buttonNumber : Integer;
	menuButton : MOB_Button;
	buttonOffset : Integer;
	ti  : CM_TrackedItem;
	buttonHeight : Integer;
	
	bookingRefItem : CM_BookingRefItem;
	resDetail : CM_ReserveDetail;
	resDetailSet : CM_ReserveDetailSet;
	bookingItemSet : CM_BookingRefItemSet;
	docActions : CM_DocumentActions;
	taskAndStopStr : String;
	
begin
	
	// get the container
	if self.myPackContainer = null then
		errMess := "developer error,  no Container";
		self.msgBox( errMess, app.getErrorString(Error), MsgBox_OK_Only, true);
		return;
	endif;
	
		
	// create the buttons on the form
	self.packedSize := self.myPackContainer.allChildren.size;
	buttonHeight := self.getScrollingButtonHeight();
	self.btnPackedTemp.height := buttonHeight;
	buttonWidth := self.getButtonWidthSetScrollBar( self.packedSize, self.frmPacked, self.btnPackedTemp.height, self.scrPacked );

	//05 Jan 2016	NDL	TFS 3157/2001
	create resDetailSet transient;
	create bookingItemSet transient;

	foreach ti in self.myPackContainer.allChildren do
		
		//05 Jan 2016	NDL	TFS 3157/2001
		docActions := null;
		resDetailSet.clear;
		bookingItemSet.clear;
		if ti.hasDocumentActions( resDetailSet, bookingItemSet ) then
			if not bookingItemSet.isEmpty then
				bookingRefItem := bookingItemSet.first;
				if bookingRefItem &lt;&gt; null then
					docActions := bookingRefItem.myBookingRefItemActions;
				endif;
			elseif not resDetailSet.isEmpty then
				resDetail := resDetailSet.first;
				if resDetail &lt;&gt; null then
					docActions := resDetail.myReserveDetailActions;
				endif;
			endif;
		endif;	
		
		buttonNumber := buttonNumber + 1;
		
		menuButton := self.btnPackedTemp.getControl( buttonNumber ).MOB_Button;  //1/11/2016 cnwma1  	TFS #2857 PAR #38311
		if menuButton &lt;&gt; null then												 //1/11/2016 cnwma1  	TFS #2857 PAR #38311
			menuButton.visible := false;									     //1/11/2016 cnwma1  	TFS #2857 PAR #38311
			delete menuButton;													 //1/11/2016 cnwma1  	TFS #2857 PAR #38311
		endif;																	 //1/11/2016 cnwma1  	TFS #2857 PAR #38311
		
		menuButton := self.btnPackedTemp.loadControl( buttonNumber ).MOB_Button;
		menuButton.move(0, buttonOffset, buttonWidth, buttonHeight-4 );
		
		menuButton.userObject := ti;
		//menuButton.caption := ti.cargoTypeDescr &amp; " - " &amp; ti.id;
		//01 Sep 2014	Par 34717 / CCMS 2384
		if ti.canSplitTotalQuantity and ti.isBulkByQuantity then
			menuButton.caption := ti.cargoTypeDescr &amp; " - " &amp; ti.id &amp; "(" &amp; ti.totalQuantity.String &amp; ")";
		//elseif ti.isBulkByWeight and ti.isBulkByVolume then
		elseif ( ti.isBulkByWeight or ti.isBulkByVolume ) then	//10 Dec 2015	NDL	Par 37288
			menuButton.caption := ti.cargoTypeDescr &amp; " - " &amp; ti.id &amp; "(" &amp; ti.CM_Bulk.getBulkTrackByDisplayForWeight(true) &amp; ")";
		else
			menuButton.caption := ti.cargoTypeDescr &amp; " - " &amp; ti.id;
		endif;
		
		//05 Jan 2016	NDL	TFS 3157/2001
		if docActions &lt;&gt; null then
			taskAndStopStr := docActions.getTaskAndStopStrForTi(ti,true);
			if taskAndStopStr &lt;&gt; null then
				menuButton.caption := menuButton.caption &amp; " " &amp; taskAndStopStr;
				self.docActsToDisplay.addExclusive( docActions );
			endif;
		endif;
		
		self.addHazDetailsToButton( menuButton, ti, CrLf ); //30 May 2017	NDL	TFS 4587
		
		menuButton.enabled := true;
		
		buttonOffset := buttonOffset + buttonHeight-2;
		menuButton.tabIndex := TAB_INDEX_START + buttonNumber;
		
	endforeach;
	
	self.btnPackedTemp.visible := false;

epilog

	delete resDetailSet;
	delete bookingItemSet;

end;</source>
    </JadeMethod>
    <JadeMethod name="setupToPackBtns" id="f2c25d34-3c06-4bcf-8b98-42827ffbf273">
        <updating/>
        <source>setupToPackBtns() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 July 2011	cnwndl1	Initial creation		Par 26476

*/

constants

	TAB_INDEX_START = 1000;
	
vars

	booking : CM_BookingRef;
	bookingItem : CM_BookingRefItem;	
	errMess : String;
	buttonWidth : Real;
	tiArray : CM_TIArray;
	buttonNumber : Integer;
	menuButton : MOB_Button;
	buttonOffset : Integer;
	ti : CM_TrackedItem;
	ultParent : CM_TrackedItem;
	bulkRelease : CM_BulkRelease;
	yardLocation : CM_LocationsController;
	bulkReleaseMode : Boolean;
	buttonHeight : Integer;
	allowMoreCargo : Boolean;
	reserveSelection : CM_ReserveSelection;
	
	bookingRefItem : CM_BookingRefItem;
	resDetail : CM_ReserveDetail;
	resDetailSet : CM_ReserveDetailSet;
	bookingItemSet : CM_BookingRefItemSet;
	docActions : CM_DocumentActions;
	taskAndStopStr : String;
	targetLocn : CM_LocationsController;
	
	tempTiArray : CM_TIArray;
	
begin

	//10 Nov 2014	NDL	Par 35146
	if self.toPackSize &gt; 0 then
		foreach buttonNumber in 1 to self.toPackSize do
			menuButton := self.btnInYardTemp.getControl( buttonNumber ).MOB_Button;
			if menuButton &lt;&gt; null then
				menuButton.visible := false;
				delete menuButton;
			endif;
		endforeach;
		self.toPackSize := 0;
		buttonNumber := 0;
	endif;
	
	allowMoreCargo := self.myTerminal.getConfig(AllowPackMoreCargo).Boolean;	//07 Dec 2015	NDL	Par 36866
	
	// get the booking / booking item
	booking := self.myMobileGenericAgent.myPackStockBookingRef;
	if booking &lt;&gt; null then
		bookingItem := self.myMobileGenericAgent.myPackStockBookingItem;
	endif;
	//01 Sep 2014	Par 34717 / CCMS 2384
	bulkRelease := self.myMobileGenericAgent.myBulkRelease;
	yardLocation := self.myMobileGenericAgent.myYardLocation;
	if self.myMobileGenericAgent.myTruck &lt;&gt; null then
		targetLocn := self.myMobileGenericAgent.myTruck.locationsController;
	endif;
	
	create tiArray transient;
	
	if bookingItem &lt;&gt; null then
		foreach ti in bookingItem.allTIs do
			// 11 Nov 2014	NDL	Par 35206
			if not ti.isOnSite then
				continue;
			endif;
			if ti.myParent = null then
				tiArray.add( ti );
			else
				//11 July 2014	NDL	Par 34020
				ultParent := self.getUltimateParentIfNotPackedIn( ti, self.myPackContainer );
				if ultParent &lt;&gt; null then
					tiArray.addExclusive( ultParent );
				endif;
			endif;
		endforeach;
		
	elseif booking &lt;&gt; null then
		foreach ti in booking.allTIs do
			// 11 Nov 2014	NDL	Par 35206
			if not ti.isOnSite then
				continue;
			endif;
			if ti.myParent = null then
				tiArray.add( ti );
			else
				//11 July 2014	NDL	Par 34020
				ultParent := self.getUltimateParentIfNotPackedIn( ti, self.myPackContainer );
				if ultParent &lt;&gt; null then
					tiArray.addExclusive( ultParent );
				endif;
			endif;
		endforeach;
	
	elseif bulkRelease &lt;&gt; null then	//21 Aug 2014	NDL	Par 34717  CCMS 2384	
		bulkReleaseMode := true;
		reserveSelection := self.myMobileGenericAgent.myReserveSelection;	//11 Dec 2015	NDL	Par 37288
		//19 May 2017	NDL	TFS 4016
		create tempTiArray transient;	//20 Dec 2018	NDL	TFS 38083
		if self.applyTwelveStwRules then
			self.myMobileGenericAgent.getCargoBasedOnSTW12Rules( bulkRelease, reserveSelection, yardLocation, targetLocn, self.stwRuleNum, tempTiArray );
		else
			self.getBRPropsectiveChildCargo( bulkRelease, reserveSelection, yardLocation, targetLocn, tempTiArray );
		endif;
		
		foreach ti in tempTiArray do
			if ti.myParent = null then
				tiArray.add( ti );
			else
				ultParent := self.getUltimateParentIfNotPackedIn( ti, self.myPackContainer );
				if ultParent &lt;&gt; null then
					tiArray.addExclusive( ultParent );
				endif;
			endif;
		endforeach;
		
	endif;
		
	// create the buttons on the form
	self.toPackSize := tiArray.size;
	//if app.myRoot.getConfig(AllowPackMoreCargo).Boolean and not bulkReleaseMode then
	if allowMoreCargo and not bulkReleaseMode then	//04 Dec 2015	NDL	Par 36866
		self.toPackSize := self.toPackSize + 1;
	endif;

	buttonHeight := self.getScrollingButtonHeight();
	self.btnInYardTemp.height := buttonHeight;
	buttonWidth := self.getButtonWidthSetScrollBar( self.toPackSize, self.frmToPack, self.btnInYardTemp.height, self.scrToPack );

	//05 Jan 2016	NDL	TFS 3157/2001
	create resDetailSet transient;
	create bookingItemSet transient;

	foreach ti in tiArray do
	
		//05 Jan 2016	NDL	TFS 3157/2001
		docActions := null;
		resDetailSet.clear;
		bookingItemSet.clear;
		if ti.hasDocumentActions( resDetailSet, bookingItemSet ) then
			if not bookingItemSet.isEmpty then
				bookingRefItem := bookingItemSet.first;
				if bookingRefItem &lt;&gt; null then
					docActions := bookingRefItem.myBookingRefItemActions;
				endif;
			elseif not resDetailSet.isEmpty then
				resDetail := resDetailSet.first;
				if resDetail &lt;&gt; null then
					docActions := resDetail.myReserveDetailActions;
				endif;
			endif;
		endif;
		
		buttonNumber := buttonNumber + 1;
		menuButton := self.btnInYardTemp.loadControl( buttonNumber ).MOB_Button;
		menuButton.move(0, buttonOffset, buttonWidth, buttonHeight-4 );
		
		menuButton.userObject := ti;
		menuButton.enabled := true;
	//	menuButton.caption := ti.cargoTypeDescr &amp; " - " &amp; ti.id;
	//01 Sep 2014	Par 34717 / CCMS 2384
		if ti.canSplitTotalQuantity and ti.isBulkByQuantity then
			menuButton.caption := ti.cargoTypeDescr &amp; " - " &amp; ti.id &amp; "(" &amp; ti.totalQuantity.String &amp; ")" 
										&amp; CrLf &amp; ti.myPrimaryActualLocation.getFullId;
		//elseif ti.isBulkByWeight and ti.isBulkByVolume then
		elseif ( ti.isBulkByWeight or ti.isBulkByVolume ) then	//10 Dec 2015	NDL	Par 37288
			menuButton.caption := ti.cargoTypeDescr &amp; " - " &amp; ti.id &amp; "(" &amp; ti.CM_Bulk.getBulkTrackByDisplayForWeight(true) &amp; ")" 
										&amp; CrLf &amp; ti.myPrimaryActualLocation.getFullId;
		else
			menuButton.caption := ti.cargoTypeDescr &amp; " - " &amp; ti.id &amp; CrLf &amp; ti.myPrimaryActualLocation.getFullId;
		endif;
		
		//05 Jan 2016	NDL	TFS 3157/2001
		if docActions &lt;&gt; null then
			taskAndStopStr := docActions.getTaskAndStopStrForTi(ti,true);
			if taskAndStopStr &lt;&gt; null then
				menuButton.caption := menuButton.caption &amp; " " &amp; taskAndStopStr;
				self.docActsToDisplay.addExclusive( docActions );
			endif;
		endif;
		
		self.addHazDetailsToButton( menuButton, ti, " " ); //30 May 2017	NDL	TFS 4587
		
		buttonOffset := buttonOffset + buttonHeight-2;
		menuButton.tabIndex := TAB_INDEX_START + buttonNumber;
		
	endforeach;
	
	//if app.myRoot.getConfig(AllowPackMoreCargo).Boolean and not bulkReleaseMode then
	if allowMoreCargo and not bulkReleaseMode then	//07 Dec 2015	NDL	Par 36866
		buttonNumber := buttonNumber + 1;
		menuButton := self.btnInYardTemp.loadControl( buttonNumber ).MOB_Button;
		menuButton.move(0, buttonOffset, buttonWidth, buttonHeight-4 );
		
		menuButton.enabled := true;
		menuButton.caption := "Find Cargo to Pack...";
		
		buttonOffset := buttonOffset + buttonHeight-2;
		menuButton.tabIndex := TAB_INDEX_START + buttonNumber;
	endif;

	self.btnInYardTemp.visible := false;

epilog

	delete resDetailSet;
	delete bookingItemSet;
	delete tiArray;
	delete tempTiArray;

end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="77e32990-8178-4628-bcaf-98546b24e271">
        <updating/>
        <source>translateForm(locale : CM_Locale) updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 11 March 2019 19:49:20.
vars
	
begin
	// Determine the locale for translations.
	inheritMethod(locale);
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0023427, locale);
	btnDocActions.translateCaption(Xlat_0023428, locale);
	btnInYardTemp.translateCaption(Xlat_0023435, locale);
	btnPackedTemp.translateCaption(Xlat_0023434, locale);
	lblCargoId.translateCaption(Xlat_0023429, locale);
	lblCount.translateCaption(Xlat_0023430, locale);
	lblWeight.translateCaption(Xlat_0023431, locale);
	shtPacked.translateCaption(Xlat_0023432, locale);
	shtToPack.translateCaption(Xlat_0023433, locale);
end;</source>
        <Parameter name="locale" type="CM_Locale"/>
    </JadeMethod>
    <JadeMethod name="txtCargoId_change" id="362a5126-ae7b-424a-a65f-a6a1d638e6f6">
        <controlMethod name="TextBox::change"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtCargoId_change(textbox: TextBox input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 July 2011	cnwndl1	Initial creation	Par 26476

*/

vars

begin

	app.convertScannedCargoId( self.myTerminal, textbox, false, null );	//06 Jul 2016	NDL	TFS 2275
	
	self.doFindCargoButton();
	
epilog

end;</source>
        <Parameter name="textbox" type="TextBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="txtCargoId_gotFocus" id="0e24475b-cbab-4526-b1f5-9136bdd43492">
        <controlMethod name="TextBox::gotFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtCargoId_gotFocus(textbox: TextBox input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 July 2011	cnwndl1	Initial creation	Par 26476

*/

vars

begin

	if txtCargoId.text = lblCargoId.caption.toUpper then
		txtCargoId.selStart := 0;
		txtCargoId.selLength := lblCargoId.caption.length;
	endif;

epilog

end;</source>
        <Parameter name="textbox" type="TextBox" usage="input"/>
