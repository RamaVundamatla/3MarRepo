    <JadeMethod name="create" id="4fe76db8-87d5-4e1a-a4db-149b8e2df637">
        <updating/>
        <source>create() updating;
/* 
---------------------------------------------------------------------------
 Created:     J Harliwich 28/7/09 MES 1011              

 Purpose:     

 Parameters:  None

 Returns:     Nothing

 Changed On   Changed By  Reason
 ----------   ----------  --------------------------------------------------
 
 ---------------------------------------------------------------------------
*/

begin
	self.name := UserDefinedDescName;
	self.type := EDIFileTypeCams_UserDef;
	if not self.isTransient then
		self.setupQFCamTransactions();
	endif;
end;
</source>
    </JadeMethod>
    <JadeMethod name="getJRWAvailableReportDesigns" id="e67ca08f-717c-435b-89ed-a0303584dbfe">
        <source>getJRWAvailableReportDesigns(stringArray :StringArray input);
/*
Purpose:			
Parameters:			
Return Value:		
Date		Who		Reason
16 Mar 2010 consw1	PAR #23203 - Leaking transients
*/
//29 Jan 2015	cnwrs1	Par 35544 - Change CamMessage to use HugeStringArray
vars
	transientRep 		: JadeReportWriterReport;
	reportManager		: JadeReportWriterManager;
	folders 			: HugeStringArray;
	names 				: StringArray;
	viewName,
	reportName			: String;
	
begin
	create folders transient;
	create names transient;
	create reportManager transient;
	reportManager.getAllReportNames(folders, names);	
	
	foreach reportName in names do		
		transientRep := reportManager.getReport(reportName);
		viewName := transientRep.getReportingViewName();
		if viewName = CM_TransactionView then
			stringArray.add(reportName);
		endif;		
		delete transientRep;
	endforeach;	
	
epilog
	delete transientRep;
	delete reportManager;
	delete names;
	delete folders;
end;
</source>
        <Parameter name="stringArray" type="StringArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="includeTransaction" id="ea928759-e731-4fad-a104-853929d22ddd">
        <source>includeTransaction(_transaction: CM_TITransaction; _camsTS: TimeStamp; _startTS: TimeStamp; _endTS: TimeStamp; 
					_camProtocol: CM_CamProtocol; _camGroup: CM_CamGroup; _camAgent : CM_CamControllerAgent; _logExcluded: Boolean;
					_event : CM_EventTransaction): Boolean;
/*
Date			Who		Reason
16/07/2012		cnwcs5	Initial creation - par 29601. Log excluded transactions
18 Jul 2012		cnwrs1	CCMS 1269 CAMS remove CM_CamTask
18/12/2012		cnwcs5 CCMS SFW 1294 /par 30855
24/04/2013		cnwcs5		par 30652 - remove resynch/resynchObject method calls
05/06/2018		jlgsl4	TFS 38884 - SNO - no CAMS output for TIs in Logical Delete areas
12/03/2020		jlgdap1	TFS 48785 SNO COARRI Issue - new parameter for CM_CamProtocolDesc includeTransaction
*/
vars
	ti			:CM_TrackedItem;
	isInvalid	:Boolean;
begin
	on Exception do app.handleDeletedObject(exception, ti, isInvalid);
	on Exception do app.handleDeletedObject(exception, ti.myVoyage, isInvalid);
	
	if _transaction.type = TRANS_TYPE_CAMSAUDIT then
		// these won't end up in the report but we filter them using this same method
		if _transaction.CM_CAMSAudit.isDelete then
			if not _camProtocol.sendCancellationMessage then
				if _logExcluded then
					_camAgent.logReasonForExclusion (_transaction, 'Transaction is deleted but CAM protocol "Send cancellation messages" is false');
				endif;
				return false;
			endif;
		else
			// update
			if not _camProtocol.sendUpdateMessage then
				if _logExcluded then
					_camAgent.logReasonForExclusion (_transaction, 'Transaction is updated but CAM protocol "Send updated messages" is false');
				endif;
				return false;
			endif;
		endif;
		

	endif;
		
	// this is a because the tracked Item is sometimes not being looked up correctly	
	ti := _transaction.myTrackedItem;
	
	if ti &lt;&gt; null and not _camProtocol.isCAMGroupMatch (_transaction.CM_TITransaction, _camAgent, _logExcluded) then
		return false;
	endif;

	if ti.isDeleted then // TFS 38884
		_camAgent.logReasonForExclusion (_transaction, 'Transaction is for deleted cargo item'); // TFS 38884
		return false; // TFS 38884
	endif; // TFS 38884

	// This is the edit setting stuff. Have they changed something that the user is interested in. 
	// If they want all changes then the collection of triggers is empty
	if _transaction.isKindOf (CM_Edit) and 
		_camProtocol.allEditTriggerFields.size &gt; 0 and 
		not _transaction.CM_Edit.hasCamProtocolTrigger (_camProtocol.allEditTriggerFields) then
		// an edit trx for a field we are NOT interested in
		if _logExcluded then
			_camAgent.logReasonForExclusion (_transaction, 'Edit Transaction does not match any CAM protocol trigger fields');
		endif;
		return false;		
	endif;
	//epr CCMS 1405 par 35337
	if not self.doesMatchSelector(_camProtocol,_transaction) then
		return false;
	endif;
	
	return true; 
epilog

end;</source>
        <Parameter name="_transaction" type="CM_TITransaction"/>
        <Parameter name="_camsTS" type="TimeStamp"/>
        <Parameter name="_startTS" type="TimeStamp"/>
        <Parameter name="_endTS" type="TimeStamp"/>
