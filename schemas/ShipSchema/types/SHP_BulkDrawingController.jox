// 02/02/2016	cnwdap1		Initial creation PAR #36766 Bulk Graphical Representation
//
vars

begin
	self.actPlanQueMode := _mode;
epilog

end;</source>
        <Parameter name="_mode" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setConfig" id="c710bc7d-e13d-4687-a585-fcd6fd444139">
