    <JadeMethod name="initForm" id="3f18fca1-83cb-4188-95cc-c2b9cf88caee">
        <updating/>
        <source>initForm() updating;
// ---------------------------------------------------------------------------
// Created:		January 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	now : Time;
begin

	now := app.actualTimeServer().time();	// 16 Sept 2016	cnwns1	TFS 488 - Multi Timezone Support
	
	self.allowPrint		:= true;
	self.allowExportCSV	:= true;
	self.allowSearch	:= false;
	self.allowTblDataSearch := true;
	
	self.setNavigatorHeading(self.caption);

	self.useTblThumb := true;
	self.frmDetailsBottom.visible := false;
	self.mnuTblVPrint.enabled	:= true;	
	self.mnuTblVExportCSV.enabled:= true;	
	self.tblEntDetail.setValueByName(ETRow_TimeFrom, now.Time);
	self.tblEntDetail.setValueByName(ETRow_TimeTo, now.Time);
//	self.txtTimeFrom.setTime(now);
//	self.txtTimeTo.setTime(now);
	
	self.doCmbCalcTypesBuild();
	self.doCmbBlockUnitBuild();
	self.doCmbBuildCalendars(); // PAR 30681
	self.initTblThumb();
	self.initTblEntDetail();
	self.clearErrorWarnings();	

end;</source>
