    <JadeMethod name="getCreditedAmount" id="72f87c37-58fd-4843-b803-494864c81f2c">
        <source>getCreditedAmount() : Decimal;
/*

Purpose:		
		Get credit amount applied on the cash payment
Parameters:			

Return Value:		

Date		Who		Reason
18 Jun 2019	jlgab1	Initial creation
17 Oct 2019 cnwma1 ChangeRequest 46984: JMT - Refactor Cash Credit UI and Tax
21 Oct 2019 cnwma1 Bug 47081: JMT - Decimal amount on Cash needs to be reviewed
*/

vars
	creditDetail : CM_CashCreditDetail;
	actualValue  : Decimal [23,6];
begin
	foreach creditDetail in self.allCashCreditDetails	discreteLock do
		
		if creditDetail.myAppliedToCashCredit &lt;&gt; null then
			actualValue := actualValue - creditDetail.cashValue;
		endif;
		
	endforeach;

	return actualValue;
epilog

end;</source>
