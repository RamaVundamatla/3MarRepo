<Class name="YRD_RowAreaColumn" id="d9dbccf4-4481-4039-861f-469754c4e1c6">
    <superclass name="CMUI_GridColumn"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>
This is the equivalent of the CM_RowAreaRow because the
RowAreas are drawn with the rows as columns.</text>
    <DbClassMap file="Yard"/>
    <ImplicitInverseRef name="myRowAreaRow" id="e8bd5a9b-1820-4102-9cfa-cacd5eeeb770">
        <embedded/>
        <type name="CM_RowAreaRow"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <PrimAttribute name="width" id="b7cb3e5b-26d5-412d-ac9e-9fda3391caf8">
        <embedded/>
        <type name="Real"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="drawSelf" id="c6a1bb3a-6d18-48ff-80d9-4f0bfba746e7">
        <updating/>
        <source>drawSelf(pFrame: CMUI_Frame) updating;
// ---------------------------------------------------------------------------
