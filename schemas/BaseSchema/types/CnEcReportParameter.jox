    <JadeMethod name="cnEcGetExtractString" id="8e713674-53a3-4291-a4c4-6aaf77691fd0">
        <source>cnEcGetExtractString(): String;
// --------------------------------------------------------------------------------
// Created:		17 February 2001 by cnwdad1
//
// Purpose:		Build an extract string for the receiver's details, and return it.
//				The extract string is used when report definitions and their
//				parameters are extracted to a file, in CSV format.
//
// Parameters:	None
//
// Returns:		The extract string.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	dataString	: String;
	
begin
	dataString	:=	CNEC_DOUBLE_QUOTE &amp;
					self.parameterName &amp;
					CNEC_CSV_SEPARATOR &amp;
					self.myReportDefinition.reportName &amp;
					CNEC_CSV_SEPARATOR &amp;
					self.displayValue &amp;
					CNEC_CSV_SEPARATOR &amp;
					self.hasValueList.String &amp;
					CNEC_CSV_SEPARATOR &amp;
					self.parameterType &amp;
					CNEC_CSV_SEPARATOR &amp;
					self.sequence.String &amp;
					CNEC_DOUBLE_QUOTE;
epilog
	return dataString;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="displayTab" id="6fd9d8fd-5473-43ca-8cec-1c136f4fab8d">
        <source>displayTab():String;
// --------------------------------------------------------------------------------
// Created:		28 July 2000 by cnwdad1
//
// Purpose:		Returns a display string with the receiver's details.
//
// Parameters:	None
//
// Returns:		The display string.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return self.displayValue &amp; Tab &amp; Tab &amp; self.parameterType &amp; Tab &amp; Tab &amp; self.sequence.String;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="initializeMe" id="186b5e42-f9b4-4997-a2b9-dd5a004da8e2">
        <updating/>
        <source>initializeMe(	pReportDefinition:CnEcReportDefinition;
				pParameterName:String;
				pDisplayValue:String;
				pSequence:Integer;
				pParameterType:String;
				pHasValueList:Boolean) updating;
// --------------------------------------------------------------------------------
// Created:		23 July 2000 by cnwdad1
//
// Purpose:		Initializes the receiver's property values.
//
// Parameters:	Matching property parameters.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	// First, set any properties...

	self.displayValue		:=	pDisplayValue;
	self.sequence			:=	pSequence;
	self.parameterType		:=	pParameterType;
	self.hasValueList		:=	pHasValueList;

	// Next, set any key properties...

	self.parameterName		:=	pParameterName;

	// Finally, set any references...

	self.myReportDefinition	:=	pReportDefinition;
end;</source>
        <Parameter name="pReportDefinition" type="CnEcReportDefinition"/>
        <Parameter name="pParameterName" type="String"/>
        <Parameter name="pDisplayValue" type="String"/>
        <Parameter name="pSequence" type="Integer"/>
        <Parameter name="pParameterType" type="String"/>
        <Parameter name="pHasValueList" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isPrimitiveType" id="8fd2a455-31f5-4e03-bc9d-6f9f63b1edd7">
        <source>isPrimitiveType():Boolean;
// --------------------------------------------------------------------------------
// Created:		24 July 2000 by cnwdad1
//
// Purpose:		Returns a flag to indicate whether the parameter value is a primitive.
//
// Parameters:	None
//
// Returns:		True if the value is a primitive, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return	(parameterType = "Boolean"	or
			parameterType = "Date"		or
			parameterType = "Decimal"	or
			parameterType = "Integer"	or
			parameterType = "Real"		or
			parameterType = "String"	or
			parameterType = "Time");
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="updateMe" id="98a73f2a-39d7-4797-b3b6-4805ef57de3d">
        <updating/>
        <source>updateMe(	pReportDefinition:CnEcReportDefinition;
			pParameterName:String;
			pDisplayValue:String;
			pSequence:Integer;
			pParameterType:String;
			pHasValueList:Boolean) updating;
// --------------------------------------------------------------------------------
// Created:		23 July 2000 by cnwdad1
//
// Purpose:		Updates the receiver's property values.
//
// Parameters:	Matching property parameters.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	// First, set any properties...

	self.displayValue		:=	pDisplayValue;
	self.sequence			:=	pSequence;
	self.parameterType		:=	pParameterType;
	self.hasValueList		:=	pHasValueList;

	// Next, set any key properties...

	self.parameterName		:=	pParameterName;

	// Finally, set any references...

	self.myReportDefinition	:=	pReportDefinition;
end;</source>
        <Parameter name="pReportDefinition" type="CnEcReportDefinition"/>
        <Parameter name="pParameterName" type="String"/>
        <Parameter name="pDisplayValue" type="String"/>
        <Parameter name="pSequence" type="Integer"/>
        <Parameter name="pParameterType" type="String"/>
        <Parameter name="pHasValueList" type="Boolean"/>
    </JadeMethod>
</Class>
