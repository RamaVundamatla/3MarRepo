    <JadeMethod name="getResourceUsageQuantStringJRW" id="857cd547-beda-43fe-b508-b87a0381ff08">
        <source>getResourceUsageQuantStringJRW(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
14 March 2023	navhl20	ChangeRequest 54350:[54269] EUP - VAS Work Orders Selector Query
04 Aug 2023		navlw1	ChangeRequest 59284:[59660] EUP | FR - VAS Work Order Transactions - Fixing Duplicate Values 

*/

vars
	allResourceUsage 	: CM_ResourceTypeUsageSet;
	resourceUsage 		: CM_ResourceTypeUsage;
	str,
	attrStr				: String;
	firstTime 			: Boolean;
	dec					: Decimal[12,2];
begin
	create allResourceUsage transient;
	self.getResourceUsageSet(allResourceUsage);
	if allResourceUsage.isEmpty then
		return null;
	endif;
	firstTime := true;
	foreach resourceUsage in allResourceUsage do
		if resourceUsage.myResourceType &lt;&gt; null then
			dec := resourceUsage.quantity;
			// 04.08.2023 navlw1 tfs #59284:#59660
			attrStr :=  resourceUsage.myResourceType.code &amp; ' ('&amp; dec.String &amp; ')';
		
			if not str.cnContains(attrStr)then
				if str &lt;&gt; null then
					str :=  str &amp; Comma &amp; attrStr;
				else
					str := attrStr;
				endif;
			endif;
		endif;
	endforeach;
	return str;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getResourceUsageSet" id="021156e9-8d37-4771-ad73-bfa27afe6404">
        <source>getResourceUsageSet(_resourceUsageSet : CM_ResourceTypeUsageSet input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 March 2023		navma1	ChangeRequest 54350:[54269] EUP - VAS Work Orders Selector Query
21 March 2023 		navhl20	Defect 57232: MTN - VAS Task Resources Used field is not showing the values for Truck/Wagon/VBS/Non Operational to do work orders on the Transaction Enquiry form
*/

vars

begin
	if self.allResourceUsages &lt;&gt; null then					//21.3.2023 navhl20 #57232
		self.allResourceUsages.copy(_resourceUsageSet);
	endif;
epilog

end;</source>
        <Parameter name="_resourceUsageSet" type="CM_ResourceTypeUsageSet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getResourceUsedAmout" id="9f55d5b6-f0df-4711-a8bd-aecddff5a12f">
        <source>getResourceUsedAmout():Decimal;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 January 2023	navhl20	ChangeRequest 54350:[54269] EUP - VAS Work Orders Selector Query

*/

vars
	resourceUsage 	 : CM_ResourceTypeUsage;
	amt 			 : Decimal[12,4];	
	allResourceUsage : CM_ResourceTypeUsageSet;
begin
	create allResourceUsage transient;
	self.getResourceUsageSet(allResourceUsage);
	if allResourceUsage.isEmpty then
		return null;
	endif;
	foreach resourceUsage in allResourceUsage do
		if amt = null then
			amt := resourceUsage.quantity;
		else
			amt := amt + resourceUsage.quantity;
		endif;
	endforeach;

	return amt;
epilog
	delete allResourceUsage;
end;</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="getResourceUsedRemarks" id="1d99432f-ee6e-48b2-8c64-7d8b68890f8e">
