    <JadeMethod name="getStartOfMoveSourceLocation" id="62799fc2-3c81-4616-acd1-618d5b7a4403">
        <source>getStartOfMoveSourceLocation():String;
// ---------------------------------------------------------------------------
// Created:     18 November 2010 by cnwcs5 par 23714/ccms 1132
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	type			:Integer;
	location		:String;
	priorHistory,
	nextHistory		:CM_MachineMoveHistory;
begin
	type 			:= self.type;
	
	if type = self.Type_AcceptMove then
		location := self.sourceLocation;		
	elseif type = self.Type_PickUp then
		priorHistory := self.myPriorHistory.CM_MachineMoveHistory;
		
		if priorHistory &lt;&gt; null then
			location := priorHistory.getStartOfMoveSourceLocation;
		else
			// don't expect this to happen
			location := self.sourceLocation;
		endif;
		
	elseif type = self.Type_Amendment or type = self.Type_SetDown then
		
		priorHistory	:= self.myPriorHistory.CM_MachineMoveHistory;
		
		if priorHistory &lt;&gt; null then
			location := priorHistory.getStartOfMoveSourceLocation;
		endif;
		
	elseif type = self.Type_Move then
		// instant move
		location := self.sourceLocation;
	endif;
	
	return location;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getStartOfMoveTS" id="9ff31723-1f2d-4023-8a02-fb717bc2b3ae">
        <source>getStartOfMoveTS():TimeStamp;
// ---------------------------------------------------------------------------
// Created:     02 November 2010 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	type			:Integer;
	ts				:TimeStamp;
	priorHistory,
	nextHistory		:CM_MachineMoveHistory;
begin
	type 			:= self.type;
	ts				:= null;
	
	if type = self.Type_AcceptMove then
		nextHistory	:= self.myNextHistory.CM_MachineMoveHistory;
		if nextHistory &lt;&gt; null then
			ts := nextHistory.getStartOfMoveTS;
		endif;
		
	elseif type = self.Type_PickUp then
		ts := self.dateTime;
		
	elseif type = self.Type_Amendment or type = self.Type_SetDown then
		
		priorHistory	:= self.myPriorHistory.CM_MachineMoveHistory;
		
		if priorHistory &lt;&gt; null then
			ts := priorHistory.getStartOfMoveTS;
		endif;
		
	elseif type = self.Type_Move then
		// instant move
		ts := self.dateTime;
	endif;
	
	return ts;
epilog

end;</source>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="getStartOfMoveTSLocalTZ" id="8df4c056-eec4-4c08-b7ab-d7990cdc0fa9">
