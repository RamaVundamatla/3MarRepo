<PrimType name="TimeStamp">
    <JadeMethod name="atcgLogFormat" id="b4852c68-fd8d-4c66-8ccd-67245f6a8ea0">
        <source>atcgLogFormat():String;

vars
	s:String;
begin
	if self.time.milliSecond=0 then  // fix literalFormat bug!
		s:=".000";
	endif;
	return self.date.format("yyy/MM/dd ")&amp;self.literalFormat[12:end]&amp;s;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
</PrimType>
