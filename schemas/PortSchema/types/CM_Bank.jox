    <JadeMethod name="getVesselProforma" id="cb9b2ca7-7611-4bb3-8cb8-063a34951fe2">
        <source>getVesselProforma(_vessel : CM_Vessel) : CM_ProformaTransactionCriteria;
/*

Purpose:	// TFS 37453		

Parameters:			

Return Value:		

Date		Who		Reason
06 Mar 2018	jlgab1	Initial creation
10 Oct 2022 navma1	Bug 52967: STWO - Cargo Delivery Process &amp; System Lock Details
18 Oct 2024 navlw1	JIRA-33107: Invoice Logging Use Levels
*/

vars
	ptc 		: CM_ProformaTransactionCriteria;
	canLogExtra : Boolean;
begin
	if _vessel = null then
		return null;
	endif;
	
	canLogExtra	:= app.canLogExtraDetail();
	
	if canLogExtra then							  				 //10.10.2022 navma1 #52967
		app.invLog(method.qualifiedName &amp; " Getting Proforma Vessel Config for VESSEL " &amp; _vessel.code, LogINFO.String);
	endif;
	
	ptc := self.allProformaCriteriaByType[CM_ProformaTransactionCriteria.TypeVessel,_vessel];

	
	if ptc &lt;&gt; null then
		if canLogExtra then							  			 //10.10.2022 navma1 #52967
			app.invLog(method.qualifiedName  &amp; " Found", LogINFO.String);
		endif;
		return ptc;
	endif;
	
	if canLogExtra then							  				 //10.10.2022 navma1 #52967
		app.invLog(method.qualifiedName  &amp; " ERROR NOT Found", LogINFO.String);
	endif;
	return null;
epilog

end;</source>
        <Parameter name="_vessel" type="CM_Vessel"/>
        <ReturnType type="CM_ProformaTransactionCriteria"/>
    </JadeMethod>
    <JadeMethod name="getVesselProformaDefault" id="0876c39f-9b0f-4e90-83c6-94c28eea2d8b">
