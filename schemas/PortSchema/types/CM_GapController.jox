    <JadeMethod name="validateMoveTo" id="d3ce775f-d8e4-485f-b4b0-00034dcc2567">
        <source>validateMoveTo(control: CMIF_MoveController input);
// ---------------------------------------------------------------------------
// Created:		May 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars

begin
	inheritMethod(control);
	
	if self.isGap() then // PAR 18682
		app.raiseCMException2(ERR_TI_ON_GAP,"s","s", null, null);
	endif;

end;</source>
        <Parameter name="control" type="CMIF_MoveController" usage="input"/>
    </JadeMethod>
