    <JadeMethod name="doCmbExtraTransModeClick" id="61db73b4-7ed6-450c-a69a-c0e363d00e3c">
        <source>doCmbExtraTransModeClick();
//----------------------------------------------------------------------
//
//  Created by cnwsh3
//
//	Date 04 January 2008
//
//	Moved from cmbExtraTransMod_click
//----------------------------------------------------------------------

vars
	tbl 		: CM_EntryTable;
	transMode 	: String;
begin
	tbl := self.tblExtra;
	transMode := self.cmbExtraTransMod.text;
		
	if self.mode = self.Mode_Add then 
		if transMode = TI_TRANSMODE_ROAD_STR then
			tbl.showRowByName(ETRow_EmailOptions, false);
			tbl.disableRowByName(ETRow_EmailOptions);
		else 
			tbl.hideRowByName(ETRow_EmailOptions, false);
		endif;
		//self.myAssistant.GTE_Assistant.showHideWagonField(tbl, transMode);
	endif;
	self.myAssistant.GTE_Assistant.showHideWagonField(tbl, transMode);	// 27/08/2009 cnwar2 #20539 - should occur for edit mode also
	self.myAssistant.setCarrierTransportMode(self.cmbCarrierPN,transMode);		//cnwas3 par 24344
//	self.viewTransportMode := cmbExtraTransMod.text;
//	self.setNavigatorHeading(self.viewTransportMode);

/*	if self.viewTransportMode = ViewRoad then
		self.lastTransportMode := TI_TRANSMODE_ROAD;
	elseif self.viewTransportMode = ViewRail then
		self.lastTransportMode := TI_TRANSMODE_RAIL;
	endif;
	*/
end;</source>
    </JadeMethod>
    <JadeMethod name="doDelete" id="f8a28093-f27d-4803-8618-dff045eb25f8">
        <updating/>
        <source>doDelete(): Boolean updating;
// ---------------------------------------------------------------------------
// Created:     18 April 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 03 Jan 2018	jlgrs1	TFS 36430 Penn Ship Manifest too many locks
// ---------------------------------------------------------------------------
vars
	result : Integer;
begin
	
	if self.allowMultiSelectDelete then
		return self.doDeleteBulk();
	endif;

	while true do
		app.myTrxDA.trxDeleteTI(self.myCurrentObject.CM_TrackedItem, true, app.myPassport);
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			break;
		else
			result := app.showErrorWarningDialog('Delete Pre-Note', app.myPassport, ErrWarnMode_Delete + ErrWarnMode_CanAckWarnSkipErr);
			if result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				// only reprocess the wles that had warnings.
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
		endif;
		break;
	endwhile;	
		
	/*app.myTrxDA.trxDeleteTI(self.myCurrentObject.CM_TrackedItem, app.myPassport);
	
	if (not app.myPassport.trxCompletedOK) then
		app.showErrorWarningDialog('Delete Pre-Note', app.myPassport, ErrWarnMode_Update);
		self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
	else
		self.clearErrorWarnings();
	endif;*/

epilog
	return app.myPassport.trxCompletedOK;	
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doDeleteBulk" id="528da0a0-4b3d-4e1e-93ad-e9e3ddfe76aa">
        <updating/>
        <source>doDeleteBulk() : Boolean updating;
//--------------------------------------------------
// Created:	23 July 2004 By: cnwgd1
//--------------------------------------------------
vars
	tiSet,
	tisWithWarnSet : CM_TISet;	
	result	: Integer;
begin
	app.mousePointer := MousePointer_HourGlass;
	
	create tiSet transient;
	self.tblData.allSelectedObjects.copy(tiSet);
	
	create tisWithWarnSet transient;

	while true do
		app.myTrxDA.trxDeleteTrackedItems(tiSet, tisWithWarnSet, true, app.myPassport);
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			break;
		else
			result := app.showErrorWarningDialog('Delete Pre-Note', app.myPassport, ErrWarnMode_Delete + ErrWarnMode_CanAckWarnSkipErr);
			if result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				// only reprocess the wles that had warnings.
				tiSet.clear;
				tisWithWarnSet.copy(tiSet);
				tisWithWarnSet.clear;	
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
		endif;
		break;
	endwhile;	


epilog
	return app.myPassport.trxCompletedOK;	
	delete tisWithWarnSet;
	delete tiSet;
	app.mousePointer := MousePointer_Default;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doFrmToolbarShowHideContextMnu" id="fbf8f69c-c0f3-4ad0-bf49-f27077531f7f">
