        <source>cmbYear_click(combobox: ComboBox input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 December 2018	jlgndl1	Initial creation	TFS 42614
29/08/2023	navkc1	CR 59556  Task 59557: Jade - CustDocs Auto Id
*/

vars

begin

	if self.typeToCreate = CM_AutoTaxNumberGen then
		if  self.myAutoIdGenerator &lt;&gt; null then
			txtNextSeqNum.text := self.myAutoIdGenerator.CM_AutoTaxNumberGen.getNextSequenceNumArray( cmbYear.text.String[3:2].Integer ).String;
		else
			txtNextSeqNum.text := "1";
		endif;
	elseif self.typeToCreate = CM_AutoIdCustomDocs then //29/08/2023	navkc1	CR 59556  Task 59557
		if  self.myAutoIdGenerator &lt;&gt; null then
			txtNextSeqNum.text := self.myAutoIdGenerator.CM_AutoIdCustomDocs.getNextSequenceNumArray( cmbYear.text.String[3:2].Integer ).String;
		else
			txtNextSeqNum.text := "1";
		endif;
	endif;

epilog

end;</source>
