    <JadeMethod name="addToCombo" id="060b7fe1-070c-4d1c-aa96-0f49eb2ae63f">
        <source>addToCombo(pListIndex:Integer; pComboboxObj:ComboBox input):Integer;
// --------------------------------------------------------------------------------
// Created:		11 November 2005 by cnwdad1
//
// Purpose:		Adds the receiver to the specified combobox control, at the specified
//				list index.
//
// Parameters:	pListIndex - The index at which to add the receiver to the listbox.
//				pComboboxObj - A reference to the listbox to add the receiver to.
//
// Returns:		True if the receiver was successfully added, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	childNodeObj	: CnEcTreeNode;
	listPointer		: Integer;
	
begin
	if pListIndex &lt; 1 or pListIndex &gt; pComboboxObj.listCount() then
		return 0;
	endif;
	
	pComboboxObj.addItemAt(self.itemText, pListIndex);
	pComboboxObj.itemLevel[pListIndex]		:=	self.itemLevel;
	pComboboxObj.itemForeColor[pListIndex]	:=	self.itemForeColor;
	pComboboxObj.itemBackColor[pListIndex]	:=	self.itemBackColor;
	pComboboxObj.itemData[pListIndex]		:=	self.itemData;
	pComboboxObj.itemPicture[pListIndex]		:=	self.itemPicture;
	pComboboxObj.itemObject[pListIndex]		:=	self.myItemObject;
	
	listPointer	:=	pListIndex;
		
	if self.allChildNodes.cnEcIsNotEmpty() then
		foreach childNodeObj in self.allChildNodes do
			listPointer	:=	listPointer + 1;
			listPointer	:=	childNodeObj.addToCombo(listPointer, pComboboxObj);
		endforeach;
	endif;
	
	return listPointer;
end;</source>
        <Parameter name="pListIndex" type="Integer"/>
        <Parameter name="pComboboxObj" type="ComboBox" usage="input"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="addToList" id="0ca75883-33fc-44b8-893a-41688708fd76">
        <source>addToList(pListIndex:Integer; pListboxObj:ListBox input):Integer;
// --------------------------------------------------------------------------------
// Created:		11 November 2005 by cnwdad1
//
// Purpose:		Adds the receiver to the specified listbox control, at the specified
//				list index.
//
// Parameters:	pListIndex - The index at which to add the receiver to the listbox.
//				pListboxObj - A reference to the listbox to add the receiver to.
//
// Returns:		True if the receiver was successfully added, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	childNodeObj	: CnEcTreeNode;
	listPointer		: Integer;
	
begin
//	if pListIndex &lt; 1 or pListIndex &gt; pListboxObj.listCount() then
//		return 0;
//	endif;
	
	pListboxObj.addItemAt(self.itemText, pListIndex);
	pListboxObj.itemLevel[pListIndex]		:=	self.itemLevel;
	pListboxObj.itemForeColor[pListIndex]	:=	self.itemForeColor;
	pListboxObj.itemBackColor[pListIndex]	:=	self.itemBackColor;
	pListboxObj.itemData[pListIndex]		:=	self.itemData;
	pListboxObj.itemPicture[pListIndex]		:=	self.itemPicture;
	pListboxObj.itemObject[pListIndex]		:=	self.myItemObject;
	
	listPointer	:=	pListIndex;
		
	if self.allChildNodes.cnEcIsNotEmpty() then
		foreach childNodeObj in self.allChildNodes do
			listPointer	:=	listPointer + 1;
			listPointer	:=	childNodeObj.addToList(listPointer, pListboxObj);
		endforeach;
	endif;
	
	return listPointer;
end;</source>
        <Parameter name="pListIndex" type="Integer"/>
        <Parameter name="pListboxObj" type="ListBox" usage="input"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="adjustItemLevel" id="e3774468-4dff-4636-ba3a-7109a7f9fc12">
        <updating/>
        <source>adjustItemLevel(pAdjustBy:Integer) updating;
// --------------------------------------------------------------------------------
// Created:		16 November 2005 by cnwdad1
//
// Purpose:		Adjusts the list item level of the receiver, and all of its child
//				nodes, by the specified value, which can be a positive or negative
//				value.
//
// Parameters:	pAdjustBy - The number of levels to adjust the receiver's level by.
//					This can be a positive or negative value.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	childNodeObj	: CnEcTreeNode;
	
begin
	self.itemLevel	:=	self.itemLevel + pAdjustBy;
	
	foreach childNodeObj in self.allChildNodes do
		childNodeObj.adjustItemLevel(pAdjustBy);
	endforeach;
end;</source>
        <Parameter name="pAdjustBy" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="delete" id="2f37940b-657b-4bf9-b62c-8450337ffd07">
        <updating/>
        <source>delete() updating, protected;
// --------------------------------------------------------------------------------
// Created:		11 November 2005 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.allChildNodes.purge();
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="deleteItemObject" id="839e5920-decd-433e-8ea2-3a700e5e5133">
        <updating/>
        <source>deleteItemObject(pIsDeleteOnChildren:Boolean) updating;
// --------------------------------------------------------------------------------
// Created:		20 November 2005 by cnwdad1
//
// Purpose:		Deletes the object referenced by the item object property, and optionally
//				deletes the references on all child nodes.
//
// Parameters:	pIsDeleteOnChildren - True if the item object references on all child
//					nodes should also be deleted.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	childNodeObj	: CnEcTreeNode;
	
begin
	delete self.myItemObject;
	
	if pIsDeleteOnChildren then
		foreach childNodeObj in self.allChildNodes do
			childNodeObj.deleteItemObject(pIsDeleteOnChildren);
		endforeach;
	endif;
end;</source>
        <Parameter name="pIsDeleteOnChildren" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getChildNodesCombo" id="25ba10bf-8811-4ad2-8cde-d562e5ef447f">
        <source>getChildNodesCombo(pComboboxObj:ComboBox):Boolean;
// --------------------------------------------------------------------------------
// Created:		11 November 2005 by cnwdad1
//
// Purpose:		Populates the receiver's array of ComboBox child nodes.
//
// Parameters:	pComboboxObj - The combobox control to get the child nodes from.
//
// Returns:		True if the child nodes were retrieved, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.allChildNodes.purge();
	
	return pComboboxObj.cnEcGetChildNodes(self.listIndex, self.allChildNodes);
end;</source>
        <Parameter name="pComboboxObj" type="ComboBox"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getChildNodesList" id="16d0bc2d-ba28-440c-bbaf-a3d5b2012841">
        <source>getChildNodesList(pListboxObj:ListBox):Boolean;
// --------------------------------------------------------------------------------
// Created:		11 November 2005 by cnwdad1
//
// Purpose:		Populates the receiver's array of ListBox child nodes.
//
// Parameters:	pListboxObj - The listbox control to get the child nodes from.
//
// Returns:		True if the child nodes were retrieved, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.allChildNodes.purge();
	
	return pListboxObj.cnEcGetChildNodes(self.listIndex, self.allChildNodes);
end;</source>
        <Parameter name="pListboxObj" type="ListBox"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getLastIndex" id="cf60a573-978f-476e-a890-240dafd41123">
        <source>getLastIndex():Integer;
// --------------------------------------------------------------------------------
// Created:		13 November 2005 by cnwdad1
//
// Purpose:		Returns the list index of the last entry in the last node.
//
// Parameters:	None
//
// Returns:		The list index of the last list entry.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	treeNodeObj	: CnEcTreeNode;
	
begin
	if self.hasChildNodes() then
		treeNodeObj	:=	self.allChildNodes.last();
		
		if treeNodeObj.hasChildNodes() then
			return treeNodeObj.getLastIndex();
		else
			return treeNodeObj.listIndex;
		endif;
	else
		return self.listIndex;
	endif;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="hasChildNodes" id="0bbabb7e-69c1-4015-8314-aa802c23eaf7">
        <source>hasChildNodes():Boolean;
// --------------------------------------------------------------------------------
// Created:		11 November 2005 by cnwdad1
//
// Purpose:		Returns a boolean flag to indicate whether the receiver has child nodes.
//
// Parameters:	None
//
// Returns:		True if the receiver has child nodes, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return not self.allChildNodes.isEmpty();
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="updateMe" id="ef4614d9-61b3-4b02-ab4c-6ba6f60bd5d4">
        <updating/>
        <source>updateMe(	pItemText:String;
			pListIndex:Integer;
			pItemLevel:Integer;
			pItemForeColor:Integer;
			pItemBackColor:Integer;
			pItemData:Integer;
			pItemPicture:Binary;
			pItemObject:Object) updating;
// --------------------------------------------------------------------------------
// Created:		11 November 2005 by cnwdad1
//
// Purpose:		Sets the receiver's attribute values and references.
//
// Parameters:	pItemText - The list item's text value.
//				pListIndex - The index of the list item.
//				pItemLevel - The hierarchy level of the list item.
//				pItemForeColor - The fore color of the list item.
//				pItemBackColor - The background color of the list item.
//				pItemData - The list item's data value.
//				pItemPicture - The list item's picture (BLOB).
//				pItemObject - A reference to the list item's object (or null).
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.itemText		:=	pItemText;
	self.listIndex		:=	pListIndex;
	self.itemLevel		:=	pItemLevel;
	self.itemForeColor	:=	pItemForeColor;
	self.itemBackColor	:=	pItemBackColor;
	self.itemData		:=	pItemData;
	self.itemPicture	:=	pItemPicture;
	self.myItemObject	:=	pItemObject;
end;</source>
        <Parameter name="pItemText" type="String"/>
        <Parameter name="pListIndex" type="Integer"/>
        <Parameter name="pItemLevel" type="Integer"/>
        <Parameter name="pItemForeColor" type="Integer"/>
        <Parameter name="pItemBackColor" type="Integer"/>
        <Parameter name="pItemData" type="Integer"/>
        <Parameter name="pItemPicture" type="Binary"/>
        <Parameter name="pItemObject" type="Object"/>
    </JadeMethod>
</Class>
