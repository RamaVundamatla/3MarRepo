    <JadeMethod name="setSearchValue" id="03d86f16-0a2a-483d-99e2-14686879b771">
        <updating/>
        <source>setSearchValue(_value: Any) updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
08 August 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars
	stringValue		: String;
	integerValue	: Integer;
	
begin
	if _value &lt;&gt; null then    // par 18123
		stringValue := _value.String;
		if stringValue.isInteger then
			integerValue := stringValue.Integer;
		else
			app.raiseCMException1(VB_INVALID_NUM, stringValue, null, null);
		endif;		
	endif;
	
	self.searchValue := integerValue;
	
end;</source>
        <Parameter name="_value" type="Any"/>
    </JadeMethod>
