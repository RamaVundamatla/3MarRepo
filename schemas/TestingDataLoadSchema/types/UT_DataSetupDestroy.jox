        <Parameter name="_methodStr" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="processSystemStops" id="719bd7c1-135b-4055-ab61-fc23bc3e2f2e">
        <source>processSystemStops(_stopXMLElement : JadeXMLElement; _methodStr : String io);

/*

Purpose:		Create the stops

Date			Who		Reason
01/03/2012		cnwmh5	Initial creation

*/

vars

	xmlElement				: JadeXMLElement;
	optsElement				: JadeXMLElement;
	stopsTableElement		: JadeXMLElement;
	
	obj						: Object;
	
	varsStr					: String;
	codeStr					: String;
	epilogStr				: String;
	
	selectedCargoArray		: StringArray;
	processAreasArray		: StringArray;
	stopsAreaArray			: StringArray;
	
	code					: String;	
	id	 					: Integer;
	heading					: String;
	selectedCargo			: String;
	str						: String;
	stopsArea				: String;
	processArea				: String;
	requiresInfo 			: Boolean;
	customsInfoEntry 		: String; 
	setupStopTemplate 		: Boolean; 
	allowClearanceExpiryDate : Boolean; 
	isMT					: Boolean;
	
begin

	varsStr := 'selectedTypes		: CM_CargoBOLTypeSet;' &amp; CrLf &amp;
		Tab &amp; 'processAreas		: IntegerArray;' &amp; CrLf &amp;
		Tab &amp; 'setStopsAreas		: IntegerArray;' &amp; CrLf &amp; 
		Tab &amp; 'opts			: CM_AssociationDict;' &amp; CrLf;

	codeStr := 'create selectedTypes transient;' &amp; CrLf &amp;
		Tab &amp; 'create processAreas transient;' &amp; CrLf &amp;
		Tab &amp; 'create setStopsAreas transient;' &amp; CrLf &amp; 
		Tab &amp; 'create opts transient;' &amp; CrLf &amp; CrLf;
		
	epilogStr := 'delete processAreas;' &amp; CrLf &amp; 
		Tab &amp; 'delete setStopsAreas;' &amp; CrLf &amp;
		Tab &amp; 'delete selectedTypes;' &amp; CrLf &amp;
		Tab &amp; 'delete opts;';
		
	create selectedCargoArray transient;
	create stopsAreaArray transient;
	create processAreasArray transient;
	
	foreach obj in _stopXMLElement.childNodes do
		xmlElement := obj.JadeXMLElement;
		
		id := self.returnElementText(xmlElement.getElementByTagName('id')).Integer;
		code := self.returnElementText(xmlElement.getElementByTagName('code')).String;
		heading := self.returnElementText(xmlElement.getElementByTagName('heading')).String;

		codeStr := codeStr &amp; Tab &amp; 'opts.purge();' &amp; CrLf &amp;
			Tab &amp; 'self.deleteStopsTable(' &amp; id.String &amp; ', opts);' &amp; CrLf &amp; CrLf &amp;
			Tab &amp; 'selectedTypes.clear();' &amp; CrLf;
				
		selectedCargo := self.returnElementText(xmlElement.getElementByTagName('selectedCargo')).String;
		selectedCargo.cnReplaceString('"', '');
		selectedCargoArray.clear();
		selectedCargo.getTokensForDelimiter(';', selectedCargoArray);
		foreach str in selectedCargoArray do
			codeStr := codeStr &amp; Tab &amp; 'if not selectedTypes.includes(app.myRoot.allCargoTypesById[' &amp; str &amp; ']) then' &amp; CrLf &amp;
				Tab &amp; Tab &amp; 'selectedTypes.add(app.myRoot.allCargoTypesById[' &amp; str &amp; ']);' &amp; CrLf &amp; 
				Tab &amp; 'endif;' &amp; CrLf;
		endforeach;
			
		stopsTableElement := xmlElement.getElementByTagName('StopsTable');
		if stopsTableElement &lt;&gt; null then
	
			codeStr := codeStr &amp; Tab &amp; 'self.opts.addAssoc("Terminal", ' &amp; 
				self.returnElementText(stopsTableElement.getElementByTagName('terminal')).String &amp; ');' &amp; CrLf;
			
			/*		
			selectedCargo := self.returnElementText(stopsTableElement.getElementByTagName('selectedCargo')).String;
			selectedCargo.cnReplaceString('"', '');
			selectedCargoArray.clear();
			selectedCargo.getTokensForDelimiter(';', selectedCargoArray);
			foreach str in selectedCargoArray do
				codeStr := codeStr &amp; Tab &amp; 'if not selectedTypes.includes(app.myRoot.allCargoTypesById[' &amp; str &amp; ']) then' &amp; CrLf &amp;
					Tab &amp; Tab &amp; 'selectedTypes.add(app.myRoot.allCargoTypesById[' &amp; str &amp; ']);' &amp; CrLf &amp; 
					Tab &amp; 'endif;' &amp; CrLf;
			endforeach;
			*/
			
			codeStr := codeStr &amp; CrLf &amp; Tab &amp; 'setStopsAreas.clear();' &amp; CrLf;
			stopsArea := self.returnElementText(stopsTableElement.getElementByTagName('stopsArea')).String;
			stopsArea.cnReplaceString('"', '');
			stopsAreaArray.clear();
			stopsArea.getTokensForDelimiter(';', stopsAreaArray);
			foreach str in stopsAreaArray do
				codeStr := codeStr &amp; Tab &amp; 'if not setStopsAreas.includes(' &amp; str &amp; ') then' &amp; CrLf &amp;
					Tab &amp; Tab &amp; 'setStopsAreas.add(' &amp; str &amp; ');' &amp; CrLf &amp; 
					Tab &amp; 'endif;' &amp; CrLf &amp; 
					Tab &amp; 'opts.addAssoc(ETRow_SetStopAreas, setStopsAreas);' &amp; CrLf;
			endforeach;
			
			codeStr := codeStr &amp; CrLf &amp; Tab &amp; 'processAreas.clear();' &amp; CrLf;
			processArea := self.returnElementText(stopsTableElement.getElementByTagName('processArea')).String;
			processArea.cnReplaceString('"', '');
			processAreasArray.clear();
			processArea.getTokensForDelimiter(';', processAreasArray);
			foreach str in processAreasArray do
				codeStr := codeStr &amp; Tab &amp; 'if not processAreas.includes(' &amp; str &amp; ') then' &amp; CrLf &amp;
					Tab &amp; Tab &amp; 'processAreas.add(' &amp; str &amp; ');' &amp; CrLf &amp; 
					Tab &amp; 'endif;' &amp; CrLf &amp; 
					Tab &amp; 'opts.addAssoc(ETRow_ProcessStopAreas, processAreas);' &amp; CrLf;
			endforeach;
			
			codeStr := codeStr &amp; CrLf;
			
			requiresInfo := self.returnElementText(stopsTableElement.getElementByTagName('ETRow_RequiresInfo')).Boolean;
			if requiresInfo &lt;&gt; null then
				codeStr := codeStr &amp; Tab &amp; 'opts.addAssoc(ETRow_RequiresInfo, ' &amp; requiresInfo.String &amp; ');' &amp; CrLf;
			endif;
			customsInfoEntry := self.returnElementText(stopsTableElement.getElementByTagName('ETRow_CustomsInfoEntry')).String;
			customsInfoEntry.cnReplaceString('"', '');
			if customsInfoEntry &lt;&gt; null then
				codeStr := codeStr &amp; Tab &amp; 'opts.addAssoc(ETRow_CustomsInfoEntry, ' &amp; customsInfoEntry &amp; ');' &amp; CrLf;
			endif;
			setupStopTemplate := self.returnElementText(stopsTableElement.getElementByTagName('setupStopTemplate')).Boolean;
			if setupStopTemplate &lt;&gt; null then
				codeStr := codeStr &amp; Tab &amp; 'opts.addAssoc("SetupStopTemplate", ' &amp; setupStopTemplate.String &amp; ');' &amp; CrLf;
			endif;
			allowClearanceExpiryDate := self.returnElementText(stopsTableElement.getElementByTagName('allowClearanceExpiryDate')).Boolean;
			if allowClearanceExpiryDate &lt;&gt; null then
				codeStr := codeStr &amp; Tab &amp; 'opts.addAssoc(ETRow_AllowClearanceExpiryDate, ' &amp; allowClearanceExpiryDate.String &amp; ');' &amp; CrLf;
			endif;
			isMT := self.returnElementText(stopsTableElement.getElementByTagName('ETRow_IsMT')).Boolean;
			if isMT then
				codeStr := codeStr &amp; Tab &amp; 'opts.addAssoc(ETRow_IsMT, ' &amp; isMT.String &amp; ');' &amp; CrLf;
			endif;
		
		endif;
		///optsElement := xmlElement.getElementByTagName("opts");
		///self.setupOptsAssoc(optsElement, codeStr);
		///codeStr.cnReplaceString('""', '');
		
		codeStr := codeStr &amp; Tab &amp; 'self.addStopsTable(' &amp; id.String &amp; ', ' &amp; code &amp; ', ' &amp; heading &amp; ', selectedTypes, opts);' &amp; CrLf &amp; CrLf;
	
	endforeach;
	
	_methodStr.cnReplaceString('&lt;^%vars^%&gt;', varsStr);
	_methodStr.cnReplaceString('&lt;^%code^%&gt;', codeStr);
	_methodStr.cnReplaceString('&lt;^%epilog^%&gt;', epilogStr);
	
epilog
	delete selectedCargoArray;
	delete stopsAreaArray;
	delete processAreasArray;
end;
</source>
        <Parameter name="_stopXMLElement" type="JadeXMLElement"/>
        <Parameter name="_methodStr" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="processSystemToDoTaskRes" id="8206f6b7-5876-4a18-a52c-afc6c2b870b0">
        <source>processSystemToDoTaskRes(_toDoTaskResXMLElement : JadeXMLElement; _methodStr : String io);

/*

Purpose:		Create the to do task resources

Date			Who		Reason
01/03/2012		cnwmh5	Initial creation

*/

vars

	xmlElement				: JadeXMLElement;
	optsElement				: JadeXMLElement;
	obj						: Object;
	
	varsStr					: String;
	codeStr					: String;
	epilogStr				: String;
	
	taskDescsArray			: StringArray;
	
	description				: String;	
	name 					: String;
	numDecimals 			: Integer;
	unitDescription 		: String;
	hasBeenUsed 			: Boolean;
	isAvailable 			: Boolean;
	taskDescs				: String;
	str						: String;
	
begin

	varsStr := 'toDoTasks 			: CM_ToDoTaskDescBySortKey;' &amp; CrLf;

	codeStr := codeStr &amp; 'create toDoTasks transient;' &amp; CrLf;
	
	epilogStr := 'delete toDoTasks;';
	
	create taskDescsArray transient;
	
	foreach obj in _toDoTaskResXMLElement.childNodes do
		xmlElement := obj.JadeXMLElement;
		name := xmlElement.tagName;
				
		description := self.returnElementText(xmlElement.getElementByTagName('description')).String;
		numDecimals := self.returnElementText(xmlElement.getElementByTagName('numDecimals')).Integer;
		unitDescription := self.returnElementText(xmlElement.getElementByTagName('unitDescription')).String;
		hasBeenUsed := self.returnElementText(xmlElement.getElementByTagName('hasBeenUsed')).Boolean;
		isAvailable :=self.returnElementText(xmlElement.getElementByTagName('isAvailable')).Boolean;
				
		codeStr := codeStr &amp; Tab &amp; 'toDoTasks.clear();' &amp; CrLf;
		
		taskDescs := self.returnElementText(xmlElement.getElementByTagName('taskDescs')).String;
		taskDescs.cnReplaceString('"', '');
		taskDescsArray.clear();
		taskDescs.getTokensForDelimiter(';', taskDescsArray);
		foreach str in taskDescsArray do
			codeStr := codeStr &amp; Tab &amp; 'toDoTasks.add(app.myRoot.allToDoTaskDescriptions[' &amp; str &amp; ']);' &amp; CrLf;
		endforeach;
		
		codeStr := codeStr &amp; Tab &amp; 'self.addToDoTaskResource("' &amp; name &amp; '", ' &amp; description &amp; ', "' &amp; 
			unitDescription.String &amp; '", ' &amp; numDecimals.String &amp; ', ' &amp; hasBeenUsed.String &amp; ', ' &amp; 
			isAvailable.String &amp; ', toDoTasks);' &amp; CrLf; 
			
	endforeach;
		
	_methodStr.cnReplaceString('&lt;^%vars^%&gt;', varsStr);
	_methodStr.cnReplaceString('&lt;^%code^%&gt;', codeStr);
	_methodStr.cnReplaceString('&lt;^%epilog^%&gt;', epilogStr);
	
epilog
	delete taskDescsArray;
end;
</source>
        <Parameter name="_toDoTaskResXMLElement" type="JadeXMLElement"/>
        <Parameter name="_methodStr" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="processSystemToDoTasks" id="9e116e66-6c54-4130-b748-4433d5b70e15">
        <source>processSystemToDoTasks(_toDoTaskAgentXMLElement : JadeXMLElement; _methodStr : String io);

/*

Purpose:		Create the to do task

Date			Who		Reason
01/03/2012		cnwmh5	Initial creation

*/

vars

	xmlElement				: JadeXMLElement;
	optsElement				: JadeXMLElement;
	obj						: Object;
	
	varsStr					: String;
	codeStr					: String;
	epilogStr				: String;
	
	description				: String;	
	code 					: String;
	trxTypeOnCompletion		: String;
	trxTypeOnCreation		: String;
	
begin

	varsStr := 'toDoTaskDesc		: CM_ToDoTaskDesc;' &amp; CrLf;

	codeStr := codeStr &amp; CrLf;
	
	foreach obj in _toDoTaskAgentXMLElement.childNodes do
		xmlElement := obj.JadeXMLElement;
		code := self.returnElementText(xmlElement.getElementByTagName('code')).String;
		description := self.returnElementText(xmlElement.getElementByTagName('description')).String;
			
		optsElement := xmlElement.getElementByTagName('opts');
		self.setupOptsAssoc(optsElement, codeStr);
		codeStr := codeStr &amp; Tab &amp; 'self.opts.addAssoc("Code", ' &amp; code &amp; ');' &amp; CrLf;
		
		trxTypeOnCreation := self.returnElementText(xmlElement.getElementByTagName('TrxTypeOnCreation')).String;
		if trxTypeOnCreation &lt;&gt; null then
			codeStr := codeStr &amp; Tab &amp; 'self.opts.addAssoc("TrxTypeOnCreation", app.myRoot.allTransactionTypesByDesc[' &amp; 
				trxTypeOnCreation &amp; ']);' &amp; CrLf;
		endif;
		
		trxTypeOnCompletion := self.returnElementText(xmlElement.getElementByTagName('TrxTypeOnCompletion')).String;
		if trxTypeOnCompletion &lt;&gt; null then
			codeStr := codeStr &amp; Tab &amp; 'self.opts.addAssoc("TrxTypeOnCompletion", app.myRoot.allTransactionTypesByDesc[' &amp; 
				trxTypeOnCompletion &amp; ']);' &amp; CrLf;
		endif;
		
		codeStr := codeStr &amp; Tab &amp; 'toDoTaskDesc := app.myRoot.allToDoTaskDescriptions[' &amp; code &amp; '];' &amp; CrLf &amp;
			Tab &amp; 'self.deleteToDoTaskDescription(toDoTaskDesc);' &amp; CrLf &amp; 
			Tab &amp; 'self.createToDoTaskDesc(' &amp; description &amp; ');' &amp; CrLf; 
	endforeach;
		
	_methodStr.cnReplaceString('&lt;^%vars^%&gt;', varsStr);
	_methodStr.cnReplaceString('&lt;^%code^%&gt;', codeStr);
	_methodStr.cnReplaceString('&lt;^%epilog^%&gt;', epilogStr);
	
epilog

end;
</source>
        <Parameter name="_toDoTaskAgentXMLElement" type="JadeXMLElement"/>
        <Parameter name="_methodStr" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="processSystemTrades" id="c4943d5a-4bcc-4aa6-80ce-a121f1d58f5f">
        <source>processSystemTrades(_tradeXMLElement : JadeXMLElement; _methodStr : String io);

/*

Purpose:		Create the trades

Date			Who		Reason
03/03/2012		cnwmh5	Initial creation

*/

vars

	xmlElement				: JadeXMLElement;
	element					: JadeXMLElement;
	obj						: Object;
	
	varsStr					: String;
	codeStr					: String;
	epilogStr				: String;
	
	description				: String;
	
begin

	varsStr := 'obj					: Object;' &amp; CrLf &amp; 
		Tab &amp; 'shippingLines		: CM_ShippingLineByCodeDict;' &amp; CrLf &amp;
		Tab &amp; 'portRotationArray	: ObjectArray;' &amp; CrLf &amp;
		Tab &amp; 'operatorArray		: ObjectArray;' &amp; CrLf;

	codeStr := CrLf &amp; Tab &amp; 'create portRotationArray transient;' &amp; CrLf &amp;
		Tab &amp; 'create shippingLines transient;' &amp; CrLf &amp;
		Tab &amp; 'create operatorArray transient;' &amp; CrLf &amp; CrLf;
	
	epilogStr := 'delete shippingLines;' &amp; CrLf &amp;
		Tab &amp; 'delete portRotationArray;' &amp; CrLf &amp; 
		Tab &amp; 'delete operatorArray;';
	
	foreach obj in _tradeXMLElement.childNodes do
		xmlElement := obj.JadeXMLElement;
		
		codeStr := codeStr &amp; Tab &amp; 'shippingLines.clear();' &amp; CrLf &amp;
			Tab &amp; 'operatorArray.clear();' &amp; CrLf &amp;
			Tab &amp; 'portRotationArray.clear();' &amp; CrLf;

		element := xmlElement.getElementByTagName('shippingLines');	
		self.returnArrayDetails(element, 'allShippingLines', 'root', codeStr);
		
		element := xmlElement.getElementByTagName('operatorArray');	
		self.returnArrayDetails(element, 'allOperators', 'root', codeStr);
		
		element := xmlElement.getElementByTagName('portRotationArray');	
		self.returnArrayDetails(element, 'allPorts', 'root', codeStr);
			
		codeStr := codeStr &amp; Tab &amp; 'if portRotationArray.size &gt; 0 then' &amp; CrLf &amp;
			Tab &amp; Tab &amp; 'self.opts.addAssoc("PortsOfRotation", portRotationArray);' &amp; CrLf &amp; 
			Tab &amp; 'endif;' &amp; CrLf;
		
		description := self.returnElementText(xmlElement.getElementByTagName('description')).String;
		
		codeStr := codeStr &amp; Tab &amp; 'self.addTrade("", ' &amp; description &amp; ', false, shippingLines, operatorArray);' &amp; CrLf &amp; CrLf;
		
	endforeach;
		
	_methodStr.cnReplaceString('&lt;^%vars^%&gt;', varsStr);
	_methodStr.cnReplaceString('&lt;^%code^%&gt;', codeStr);
	_methodStr.cnReplaceString('&lt;^%epilog^%&gt;', epilogStr);
	
epilog
	
end;
</source>
        <Parameter name="_tradeXMLElement" type="JadeXMLElement"/>
        <Parameter name="_methodStr" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="processSystemTrailerTypes" id="074e8c4e-9ad0-41b7-9642-87982b0c40ef">
        <source>processSystemTrailerTypes(_trailerTypeXMLElement : JadeXMLElement; _methodStr : String io);

/*

Purpose:		Create the trailer types

Date			Who		Reason
01/03/2012		cnwmh5	Initial creation

*/

vars

	xmlElement				: JadeXMLElement;
	optsElement				: JadeXMLElement;
	obj						: Object;
	cargoType				: CM_CargoType;
	
	cargoTypesArray			: StringArray;
	
	varsStr					: String;
	codeStr					: String;
	epilogStr				: String;
	
	description				: String;	
	cargoTypes				: String;
	str						: String;
	length					: Integer;
	noCargoPositions		: Integer;
	height					: Integer;
	weight					: Integer;
	
	
begin

	varsStr := CrLf &amp; Tab &amp; 'cargoType			: CM_CargoType;' &amp; CrLf;
	
	codeStr := CrLf &amp; Tab &amp; 'foreach cargoType in app.myRoot.allCargoTypesById do' &amp; CrLf &amp;
			Tab &amp; Tab &amp; 'if cargoType.abbreviation = "MAFI" then' &amp; CrLf &amp;
			Tab &amp; Tab &amp; Tab &amp; 'break;' &amp; CrLf &amp;
			Tab &amp; Tab &amp; 'endif;' &amp; CrLf &amp;
			Tab &amp; 'endforeach;' &amp; CrLf;
	
	create cargoTypesArray transient;
	
	foreach obj in _trailerTypeXMLElement.childNodes do
		xmlElement := obj.JadeXMLElement;
		description := self.returnElementText(xmlElement.getElementByTagName('description')).String;
		length := self.returnElementText(xmlElement.getElementByTagName('length')).Integer;
		noCargoPositions := self.returnElementText(xmlElement.getElementByTagName('noCargoPositions')).Integer;
		height := self.returnElementText(xmlElement.getElementByTagName('height')).Integer;
		weight := self.returnElementText(xmlElement.getElementByTagName('weight')).Integer;
		
		codeStr := codeStr &amp; Tab &amp; 'self.addTrailerType("' &amp; xmlElement.tagName &amp; '", ' &amp; description &amp; ', cargoType, ' &amp; 
			length.String &amp; ', ' &amp; noCargoPositions.String &amp; ', ' &amp; height.String &amp; ', ' &amp; weight.String &amp; ');' &amp; CrLf;
		
	endforeach;
		
	_methodStr.cnReplaceString('&lt;^%vars^%&gt;', varsStr);
	_methodStr.cnReplaceString('&lt;^%code^%&gt;', codeStr);
	_methodStr.cnReplaceString('&lt;^%epilog^%&gt;', epilogStr);
	
epilog
	delete cargoTypesArray;
end;
</source>
        <Parameter name="_trailerTypeXMLElement" type="JadeXMLElement"/>
        <Parameter name="_methodStr" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="processSystemTransactionTypes" id="6e4b84df-a646-4287-b463-5e56d09719f2">
        <source>processSystemTransactionTypes(_transactionTypeXMLElement : JadeXMLElement; _methodStr : String io);

/*

Purpose:		Create the transaction types

Date			Who		Reason
01/03/2012		cnwmh5	Initial creation

*/

vars

	xmlElement				: JadeXMLElement;
	optsElement				: JadeXMLElement;
	obj						: Object;
	cargoType				: CM_CargoType;
	
	cargoTypesArray			: StringArray;
	
	varsStr					: String;
	codeStr					: String;
	epilogStr				: String;
	
	description				: String;	
	group		 			: Integer;
	classToCreate	 		: String;
	canCompleteToDoTask		: Boolean;
	code					: String;
	
begin
	
	codeStr := CrLf;	
	
	foreach obj in _transactionTypeXMLElement.childNodes do
		xmlElement := obj.JadeXMLElement;
		code := self.returnElementText(xmlElement.getElementByTagName('code')).String;
		description := self.returnElementText(xmlElement.getElementByTagName('description')).String;
		group := self.returnElementText(xmlElement.getElementByTagName('group')).Integer;
		classToCreate := self.returnElementText(xmlElement.getElementByTagName('classToCreate')).String;
		canCompleteToDoTask := self.returnElementText(xmlElement.getElementByTagName('canCompleteToDoTask')).Boolean;
		
		codeStr := codeStr &amp; Tab &amp; 'self.addTransactionType(' &amp; description &amp; ', ' &amp; 
			classToCreate &amp; ', ' &amp; code &amp; ', ' &amp; group.String &amp; ', ' &amp; canCompleteToDoTask.String &amp; ');' &amp; CrLf;
		
	endforeach;
		
	_methodStr.cnReplaceString('&lt;^%vars^%&gt;', varsStr);
	_methodStr.cnReplaceString('&lt;^%code^%&gt;', codeStr);
	_methodStr.cnReplaceString('&lt;^%epilog^%&gt;', epilogStr);
	
epilog
	delete cargoTypesArray;
end;
</source>
        <Parameter name="_transactionTypeXMLElement" type="JadeXMLElement"/>
        <Parameter name="_methodStr" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="processSystemUserHookCodes" id="6c531298-30c3-4504-ad89-223580382447">
        <source>processSystemUserHookCodes(_userXMLElement : JadeXMLElement; _methodStr : String io);

/*

Purpose:		Create / Add required user hook codes	

Date			Who		Reason
23/02/2012		cnwmh5	Initial creation

*/

vars

	xmlElement				: JadeXMLElement;
	obj						: Object;
	
	varsStr					: String;
	codeStr					: String;
	epilogStr				: String;
	
	userHookType			: Integer;
	jadeCode				: String;
	
begin
	
	varsStr := CrLf &amp; Tab &amp; 'userHookCode		: Integer;' &amp; CrLf &amp; 
		Tab &amp; 'jadeCode			: String;';

	foreach obj in _userXMLElement.childNodes do
		xmlElement := obj.JadeXMLElement;
		userHookType := self.returnElementText(xmlElement.getElementByTagName('userHookType')).Integer;
		codeStr := codeStr &amp; Tab &amp; 'jadeCode := ' &amp; self.returnElementText(xmlElement.getElementByTagName('jadeCode')).String &amp; ';' &amp; CrLf;
		codeStr := codeStr &amp; Tab &amp; 'self.addUserHookCode("' &amp; xmlElement.tagName &amp; '", jadeCode, ' &amp; userHookType.String &amp; ');' &amp; CrLf;
	endforeach;
	
	_methodStr.cnReplaceString('&lt;^%vars^%&gt;', varsStr);
	_methodStr.cnReplaceString('&lt;^%code^%&gt;', codeStr);
	_methodStr.cnReplaceString('&lt;^%epilog^%&gt;', epilogStr);
	
epilog

end;
</source>
        <Parameter name="_userXMLElement" type="JadeXMLElement"/>
        <Parameter name="_methodStr" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="processSystemUsers" id="9eada519-8eb3-481b-a233-4b5eee7792c2">
        <source>processSystemUsers(_userXMLElement : JadeXMLElement; _methodStr : String io);

/*

Purpose:		Create / Add required users	

Date			Who		Reason
22/02/2012		cnwmh5	Initial creation

*/

vars

	xmlElement				: JadeXMLElement;
	obj						: Object;
	
	varsStr					: String;
	codeStr					: String;
	epilogStr				: String;
	
	description				: String;	
	
begin
			
	foreach obj in _userXMLElement.childNodes do
		xmlElement := obj.JadeXMLElement;
		description := self.returnElementText(xmlElement.getElementByTagName('description')).String;
		self.setupOptsAssoc(xmlElement.getElementByTagName('opts'), codeStr);
		codeStr := codeStr &amp; Tab &amp; 'self.addUser(' &amp; description &amp; ',"' &amp; xmlElement.tagName &amp; '");' &amp; CrLf;
	endforeach;
	
	_methodStr.cnReplaceString('&lt;^%vars^%&gt;', varsStr);
	_methodStr.cnReplaceString('&lt;^%code^%&gt;', codeStr);
	_methodStr.cnReplaceString('&lt;^%epilog^%&gt;', epilogStr);
	
epilog

end;
</source>
        <Parameter name="_userXMLElement" type="JadeXMLElement"/>
        <Parameter name="_methodStr" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="processSystemWagonClasses" id="7278346d-271a-4bc9-89ea-d6758f7deba4">
        <source>processSystemWagonClasses(_wagonClassXMLElement : JadeXMLElement; _methodStr : String io);

/*

Purpose:		Create the wagon class

Date			Who		Reason
01/03/2012		cnwmh5	Initial creation

*/

vars

	xmlElement				: JadeXMLElement;
	optsElement				: JadeXMLElement;
	obj						: Object;
	
	varsStr					: String;
	codeStr					: String;
	epilogStr				: String;
	
	maxPosWeight 			: Decimal[14,2];
	maxPosHeight 			: Decimal[14,2];
	deckHeight				: Decimal[14,2];
	tareWeight 				: Decimal[14,2];
	maxLoadWeight 			: Integer;
	carrier					: String;
	
begin

	varsStr := 'wagonClass				: CM_WagonClass;' &amp; CrLf;
	
	foreach obj in _wagonClassXMLElement.childNodes do
		xmlElement := obj.JadeXMLElement;
		
		maxPosWeight := self.returnElementText(xmlElement.getElementByTagName('maxPosWeight')).Decimal;
		maxPosHeight := self.returnElementText(xmlElement.getElementByTagName('maxPosHeight')).Decimal;
		deckHeight := self.returnElementText(xmlElement.getElementByTagName('deckHeight')).Decimal;
		tareWeight := self.returnElementText(xmlElement.getElementByTagName('tareWeight')).Decimal;
		maxLoadWeight := self.returnElementText(xmlElement.getElementByTagName('maxLoadWeight')).Integer;
			
		optsElement := xmlElement.getElementByTagName('opts');
		self.setupOptsAssoc(optsElement, codeStr);
		
		carrier := self.returnElementText(xmlElement.getElementByTagName('carrier')).String;	
		if carrier &lt;&gt; null then
			codeStr := codeStr &amp; Tab &amp; 'opts.addAssoc("Carrier", app.myRoot.allCarriers[' &amp; carrier &amp; ']);' &amp; CrLf;
		endif;
		
		codeStr := codeStr &amp; Tab &amp; 'wagonClass := app.myRoot.allWagonClasses.getAtKey("' &amp; xmlElement.tagName &amp; '");' &amp; CrLf &amp; CrLf &amp; 
			Tab &amp; 'self.deleteWagonClassAndWagons(wagonClass);' &amp; CrLf &amp;
			Tab &amp; 'self.addWagonClass("' &amp; xmlElement.tagName &amp; '", ' &amp; maxPosWeight.String &amp; ', ' &amp; 
			maxPosHeight.String &amp; ', ' &amp; deckHeight.String &amp; ', ' &amp; tareWeight.String &amp; ', ' &amp; 
			maxLoadWeight.String &amp;', false);' &amp; CrLf;
		
	endforeach;
		
	_methodStr.cnReplaceString('&lt;^%vars^%&gt;', varsStr);
	_methodStr.cnReplaceString('&lt;^%code^%&gt;', codeStr);
	_methodStr.cnReplaceString('&lt;^%epilog^%&gt;', epilogStr);
	
epilog
	
end;
</source>
        <Parameter name="_wagonClassXMLElement" type="JadeXMLElement"/>
        <Parameter name="_methodStr" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="processTemperatureConversions" id="371fed77-48a8-4ff5-943d-b8edd8d6e162">
        <source>processTemperatureConversions(_tempConvXMLElement : JadeXMLElement; _methodStr : String io);

/*

Purpose:		Create / Add required temperature conversions
Date			Who		Reason
25/01/2018		jlgmh5	Initial creation

*/

vars

	xmlElement				: JadeXMLElement;
	xmlElement2				: JadeXMLElement;
	xmlElement3				: JadeXMLElement;
	obj						: Object;
	
	varsStr					: String;
	codeStr					: String;
	epilogStr				: String;
	
begin

	varsStr := varsStr &amp; Tab &amp; 'tempConv				: CM_TemperatureConversion;' &amp; CrLf &amp; CrLf;
			
	foreach obj in _tempConvXMLElement.childNodes do
		xmlElement := obj.JadeXMLElement;
		
		self.setupOptsAssoc(xmlElement.getElementByTagName('opts'), codeStr);
		
		xmlElement2 := xmlElement.getElementByTagName("celsius");
		if xmlElement2 = null then
			continue;
		endif;
		
		xmlElement3 := xmlElement.getElementByTagName("fahrenheit");
		if xmlElement3 = null then
			continue;
		endif;
		
		codeStr := codeStr &amp; Tab &amp; 'tempConv := self.addTemperatureConversion(' &amp; self.returnElementText(xmlElement2).String &amp; '.Real,' &amp; 
			self.returnElementText(xmlElement3).String &amp; '.Real);' &amp; CrLf &amp; CrLf;

	endforeach;
	
	_methodStr.cnReplaceString('&lt;^%vars^%&gt;', varsStr);
	_methodStr.cnReplaceString('&lt;^%code^%&gt;', codeStr);
	_methodStr.cnReplaceString('&lt;^%epilog^%&gt;', epilogStr);
	
epilog

end;
</source>
        <Parameter name="_tempConvXMLElement" type="JadeXMLElement"/>
        <Parameter name="_methodStr" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="processTerminalAreas" id="c550e4f6-9dde-421d-91cb-397fba636af6">
        <source>processTerminalAreas(_terminalAreaXMLElement : JadeXMLElement; _methodStr : String io);

/*

Purpose:		Create / Add required gate(s)

Date			Who		Reason
23/02/2012		cnwmh5	Initial creation

*/

vars

	areaTypeElement			: JadeXMLElement;
	areaElement				: JadeXMLElement;
	optsElement				: JadeXMLElement;
	attribute				: JadeXMLAttribute;
	obj						: Object;
	
	varsStr					: String;
	codeStr					: String;
	epilogStr				: String;
	
	size					: Integer;
	
begin
	
	varsStr := varsStr &amp; CrLf &amp; Tab &amp; 'defaultInterchangeArea	: CM_InterchangeArea;' &amp; CrLf &amp;
		Tab &amp; 'interChangeAreaArray	: CM_InterchangeAreaArray;' &amp; CrLf;
		
	codeStr := codeStr &amp; CrLf &amp; Tab &amp; 'create interChangeAreaArray transient;' &amp; CrLf;
	
	epilogStr := epilogStr &amp; CrLf &amp; Tab &amp; 'delete interChangeAreaArray;' &amp; CrLf;
	
	foreach obj in _terminalAreaXMLElement.childNodes do
		areaTypeElement := obj.JadeXMLElement;
	
		foreach obj in areaTypeElement.childNodes do
			areaElement := obj.JadeXMLElement;
			app.writeLog("Creating Terminal Area " &amp; areaElement.tagName &amp; ".  Please wait...", LogINFO);
			write "Creating Terminal Area " &amp; areaElement.tagName &amp; ".  Please wait...";
			
			optsElement := areaElement.getElementByTagName('opts');
			if optsElement = null then
			
				codeStr := codeStr &amp; CrLf &amp; Tab &amp; 'self.opts.purge();' &amp; CrLf;
				attribute := areaElement.getAttributeByName("Terminal");
				codeStr := codeStr &amp; CrLf &amp; Tab &amp; 'self.opts.addAssoc("Terminal", "' &amp; attribute.value &amp; '");' &amp; CrLf;
			else
				self.setupOptsAssoc(optsElement, codeStr);
				attribute := areaElement.getAttributeByName("Terminal");
				codeStr := codeStr &amp; CrLf &amp; Tab &amp; 'self.opts.addAssoc("Terminal", "' &amp; attribute.value &amp; '");' &amp; CrLf;
				if optsElement.getElementByTagName("DefaultYIC") &lt;&gt; null then
					codeStr := codeStr &amp; CrLf &amp; Tab &amp; 'defaultInterchangeArea := self.getTerminal().allTerminalAreas[' &amp;  
							self.returnElementText(optsElement.getElementByTagName('DefaultYIC')).String &amp; '].CM_InterchangeArea;' &amp; CrLf &amp;
						Tab &amp; 'interChangeAreaArray.clear();' &amp; CrLf &amp;
						Tab &amp; 'interChangeAreaArray.add(defaultInterchangeArea);' &amp; CrLf &amp;
						Tab &amp; 'self.opts.addAssoc("DefaultYIC", defaultInterchangeArea);' &amp; CrLf;
				endif;
			endif;
			
			if areaTypeElement.tagName.toUpper() = "BlockStack".toUpper() then
				size := self.returnElementText(areaElement.getElementByTagName('size')).Integer;
				codeStr := codeStr &amp; Tab &amp; 'self.addBlockStack("' &amp; areaElement.tagName &amp; '", ' &amp; size.String &amp; ', interChangeAreaArray);' &amp; CrLf;
			elseif areaTypeElement.tagName.toUpper() = "GeneralCargo".toUpper() then
				codeStr := codeStr &amp; Tab &amp; 'create interChangeAreaArray transient;' &amp; CrLf &amp;
					Tab &amp; 'self.addGeneralCargoArea("' &amp; areaElement.tagName &amp; '", ' &amp; self.returnElementText(areaElement.getElementByTagName('comments')).String  &amp; ', ' &amp; 
					self.returnElementText(areaElement.getElementByTagName('rows')).String &amp; 
					', ' &amp; self.returnElementText(areaElement.getElementByTagName('columns')).String &amp; ', ' &amp;
					self.returnElementText(areaElement.getElementByTagName('units')).String &amp; ', interChangeAreaArray, defaultInterchangeArea);' &amp; CrLf; 
			elseif areaTypeElement.tagName.toUpper() = "YardInterchangeArea".toUpper() then
				codeStr := codeStr &amp; Tab &amp; 'self.addYardInterchangeArea("' &amp; areaElement.tagName &amp; '", null, ' &amp; 
					self.returnElementText(areaElement.getElementByTagName('laneCount')).String &amp; ', 0);' &amp; CrLf; 
			elseif areaTypeElement.tagName.toUpper() = "StraddleStack".toUpper() then
				codeStr := codeStr &amp; Tab &amp; 'self.opts.addAssoc("InterChangeAreaArray", defaultInterchangeArea);' &amp; CrLf;
				codeStr := codeStr &amp; Tab &amp; 'self.addStraddleStack("' &amp; areaElement.tagName &amp; '", ' &amp; self.returnElementText(areaElement.getElementByTagName('rows')).String &amp; 
					', ' &amp; self.returnElementText(areaElement.getElementByTagName('columns')).String &amp; ', ' &amp;
					self.returnElementText(areaElement.getElementByTagName('height')).String &amp; ');' &amp; CrLf; 
			elseif areaTypeElement.tagName.toUpper() = "RTGArea".toUpper() then
				codeStr := codeStr &amp; Tab &amp; 'self.deleteTerminalArea("' &amp; areaElement.tagName &amp; '");' &amp; CrLf;
				if areaElement.getElementByTagName('use40ftIds') &lt;&gt; null then
					codeStr := codeStr &amp; Tab &amp; 'self.opts.addAssoc("use40ftIds", ' &amp; self.returnElementText(areaElement.getElementByTagName('use40ftIds')).String &amp; ');' &amp; CrLf;
				endif;
				codeStr := codeStr &amp; Tab &amp; 'self.addRTGArea("' &amp; areaElement.tagName &amp; '", ' &amp; self.returnElementText(areaElement.getElementByTagName('rows')).String &amp; 
						', ' &amp; self.returnElementText(areaElement.getElementByTagName('bays')).String &amp; ', ' &amp;
						self.returnElementText(areaElement.getElementByTagName('positions')).String &amp; ');' &amp; CrLf; 
			elseif areaTypeElement.tagName.toUpper() = "Bulk".toUpper() then
				codeStr := codeStr &amp; Tab &amp; 'self.addBulkArea("' &amp; areaElement.tagName &amp; '");' &amp; CrLf;
			elseif areaTypeElement.tagName.toUpper() = "CraneTransferArea".toUpper() then
				codeStr := codeStr &amp; Tab &amp; 'self.addCraneTransferArea("' &amp; areaElement.tagName &amp; '");' &amp; CrLf;
			elseif areaTypeElement.tagName.toUpper() = "GriddedBlockStack".toUpper() then
				codeStr := codeStr &amp; Tab &amp; 'self.addForkLiftStack("' &amp; areaElement.tagName &amp; '", ' &amp; self.returnElementText(areaElement.getElementByTagName('rows')).String &amp; ', ' &amp;
					self.returnElementText(areaElement.getElementByTagName('cols')).String &amp; ', ' &amp; self.returnElementText(areaElement.getElementByTagName('positions')).String &amp; ');' &amp; CrLf;
			endif;
		endforeach;
		
	endforeach;
	
	_methodStr.cnReplaceString('&lt;^%vars^%&gt;', varsStr);
	_methodStr.cnReplaceString('&lt;^%code^%&gt;', codeStr);
	_methodStr.cnReplaceString('&lt;^%epilog^%&gt;', epilogStr);
	
epilog

end;
</source>
        <Parameter name="_terminalAreaXMLElement" type="JadeXMLElement"/>
        <Parameter name="_methodStr" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="processTerminalCreate" id="51a823c6-dfd0-4036-b1aa-9d0b100a08bb">
        <source>processTerminalCreate(_terminalXMLElement : JadeXMLElement; _methodStr : String io);

/*

Purpose:		Create / Add required terminals	

Date			Who		Reason
23/02/2012		cnwmh5	Initial creation

*/

vars

	xmlElement				: JadeXMLElement;
	icaXMLElement			: JadeXMLElement;
	obj						: Object;
	
	varsStr					: String;
	codeStr					: String;
	epilogStr				: String;
	
	description				: String;
	ica						: CM_InterchangeArea;
	
begin
	
	description := self.returnElementText(_terminalXMLElement.getElementByTagName('description')).String;
	xmlElement := _terminalXMLElement.getElementByTagName("opts");
	if xmlElement &lt;&gt; null then
		self.setupOptsAssoc(xmlElement, codeStr);
	endif;
	codeStr := codeStr &amp; CrLf &amp; Tab &amp; 'self.addTerminal(' &amp; description &amp; ', "' &amp; _terminalXMLElement.parentNode.JadeXMLElement.tagName &amp; '");' &amp; CrLf;
	
	xmlElement := _terminalXMLElement.getElementByTagName("InterchangeArea");
	if xmlElement &lt;&gt; null then
		codeStr := codeStr &amp; Tab &amp; 'self.opts.purge();' &amp; CrLf &amp;
			Tab &amp; 'self.opts.addAssoc("Terminal", "' &amp;  _terminalXMLElement.parentNode.JadeXMLElement.tagName &amp; '");' &amp; CrLf;
			
		foreach obj in xmlElement.childNodes do
			icaXMLElement := obj.JadeXMLElement;
			codeStr := codeStr &amp; Tab &amp; 'self.addYardInterchangeArea("' &amp; icaXMLElement.tagName &amp; '", null, 0, 0);' &amp; CrLf;
		endforeach;
	endif;
		
	_methodStr.cnReplaceString('&lt;^%vars^%&gt;', varsStr);
	_methodStr.cnReplaceString('&lt;^%code^%&gt;', codeStr);
	_methodStr.cnReplaceString('&lt;^%epilog^%&gt;', epilogStr);
	
epilog

end;
</source>
        <Parameter name="_terminalXMLElement" type="JadeXMLElement"/>
        <Parameter name="_methodStr" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="processTerminalDetails" id="0433a671-548a-4284-8f30-6d97d6ce13ad">
        <updating/>
        <source>processTerminalDetails(_terminalXMLElement : JadeXMLElement) updating;

/*

Purpose:		Create the Admin Details	

Date			Who		Reason
22/02/2012		cnwmh5	Initial creation

*/

vars

	xmlElement		: JadeXMLElement;
	terminalElement	: JadeXMLElement;
	
	obj				: Object;
	
	methodStr		: String;
	
begin

	foreach obj in _terminalXMLElement.childNodes do
		xmlElement := obj.JadeXMLElement;
		
		foreach obj in xmlElement.childNodes do
			terminalElement := obj.JadeXMLElement;
		
			methodStr := self.MethodString;
		
			if terminalElement.tagName.toUpper = "Create".toUpper() then
				methodStr.cnReplaceString("&lt;^%For^%&gt;", "CreateTerminal");
				self.processTerminalCreate(terminalElement, methodStr);
			elseif terminalElement.tagName.toUpper = "ObjSetConfig".toUpper() then
				methodStr.cnReplaceString("&lt;^%For^%&gt;", "ObjSetConfig");
				self.processTerminalObjNonConfig(terminalElement, methodStr);
			elseif terminalElement.tagName.toUpper = "SubTerminal".toUpper() then
				methodStr.cnReplaceString("&lt;^%For^%&gt;", "SubTerminal");
				self.processTerminalSubTerminals(terminalElement, methodStr);
			elseif terminalElement.tagName.toUpper = "SetConfig".toUpper() then
				methodStr.cnReplaceString("&lt;^%For^%&gt;", "SetConfig");
				self.processTerminalSetConfig(terminalElement, methodStr);
			elseif terminalElement.tagName.toUpper = "Gates".toUpper() then
				methodStr.cnReplaceString("&lt;^%For^%&gt;", "Gates");
				self.processTerminalGates(terminalElement, methodStr);
			elseif terminalElement.tagName.toUpper = "TerminalArea".toUpper() then
				methodStr.cnReplaceString("&lt;^%For^%&gt;", "TerminalArea");
				self.processTerminalTerminalAreas(terminalElement, methodStr);
			elseif terminalElement.tagName.toUpper = "MachineRules".toUpper() then
				methodStr.cnReplaceString("&lt;^%For^%&gt;", "MachineRules");
				self.processTerminalMachineRules(terminalElement, methodStr);
			elseif terminalElement.tagName.toUpper = "Machines".toUpper() then
				methodStr.cnReplaceString("&lt;^%For^%&gt;", "Machines");
				self.processTerminalMachines(terminalElement, methodStr);
			elseif terminalElement.tagName.toUpper = "DriverDetails".toUpper() then
				methodStr.cnReplaceString("&lt;^%For^%&gt;", "DriverDetails");
				self.processTerminalDrivers(terminalElement, methodStr);
			elseif terminalElement.tagName.toUpper() = "Users".toUpper() then	
				methodStr.cnReplaceString("&lt;^%For^%&gt;", "Users");
				self.processTerminalUsers(terminalElement);
			endif;

			if methodStr.pos("&lt;^%vars^%&gt;", 1) &gt; 0 or methodStr.pos("&lt;^%code^%&gt;", 1) &gt; 0 or 
					methodStr.pos("&lt;^%epilog^%&gt;", 1) &gt; 0 then
				continue;
			endif;
			
			write methodStr &amp; CrLf &amp; CrLf;
			
			// execute the transient method
			self.executeMethod(methodStr);
			
		endforeach;	
		
	endforeach;


end;
</source>
        <Parameter name="_terminalXMLElement" type="JadeXMLElement"/>
    </JadeMethod>
    <JadeMethod name="processTerminalDrivers" id="ae84c088-1d44-4565-b590-4aea8f3db8d3">
        <source>processTerminalDrivers(_driverXMLElement : JadeXMLElement; _methodStr : String io);

/*

Purpose:		Create / Add required terminal driver

Date			Who		Reason
27/02/2012		cnwmh5	Initial creation

*/

vars

	xmlElement				: JadeXMLElement;
	driverElement			: JadeXMLElement;
		
	obj						: Object;
	
	varsStr					: String;
	codeStr					: String;
	epilogStr				: String;
	
	text					: String;
	carrier					: String;
		
begin
	
	varsStr := CrLf &amp; Tab &amp; 'allCarriers			: CM_CarrierByCodeDict;' &amp; CrLf &amp;
		Tab &amp; 'allVehicleMachines 	: CM_VehicleSet; ' &amp; CrLf;
	
	codeStr := codeStr &amp; CrLf &amp; Tab &amp; 'create allCarriers transient;' &amp; CrLf &amp;
		Tab &amp; 'create allVehicleMachines transient;' &amp; CrLf &amp; 
		Tab &amp; 'self.opts.purge();' &amp; CrLf &amp;
		Tab &amp; 'self.opts.addAssoc("Terminal", "' &amp; _driverXMLElement.parentNode.JadeXMLElement.tagName &amp; '");' &amp; CrLf;
		
	epilogStr := 'delete allVehicleMachines;' &amp; CrLf &amp;
		Tab &amp; 'delete allCarriers;' &amp; CrLf;
	
	foreach obj in _driverXMLElement.childNodes do
		driverElement := obj.JadeXMLElement;
		
		carrier := self.returnElementText(driverElement.getElementByTagName('carrier')).String;
		codeStr := codeStr  &amp; Tab &amp; 'allCarriers.clear();' &amp; CrLf &amp;
			Tab &amp; 'allVehicleMachines.clear();' &amp; CrLf &amp;
			Tab &amp; 'allCarriers.add(app.myRoot.allCarriers[' &amp; carrier &amp; ']);' &amp; CrLf &amp;
			Tab &amp; 'self.createDriverDetails("' &amp; driverElement.tagName &amp; '", allCarriers, allVehicleMachines);' &amp; CrLf;		
	endforeach;
	
	_methodStr.cnReplaceString('&lt;^%vars^%&gt;', varsStr);
	_methodStr.cnReplaceString('&lt;^%code^%&gt;', codeStr);
	_methodStr.cnReplaceString('&lt;^%epilog^%&gt;', epilogStr);
	
epilog

end;
</source>
        <Parameter name="_driverXMLElement" type="JadeXMLElement"/>
        <Parameter name="_methodStr" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="processTerminalGates" id="ffa63938-b291-4c8b-9dc7-347249222338">
        <source>processTerminalGates(_gateXMLElement : JadeXMLElement; _methodStr : String io);

/*

Purpose:		Create / Add required gate(s)

Date			Who		Reason
23/02/2012		cnwmh5	Initial creation

*/

vars

	xmlElement				: JadeXMLElement;
	gateElement				: JadeXMLElement;
	gateAreaElement			: JadeXMLElement;
	icaElement				: JadeXMLElement;
		
	obj						: Object;
	
	varsStr					: String;
	codeStr					: String;
	epilogStr				: String;
	
	description				: String;
	ica						: String;
	
	name					: String;
	gateName				: String;
	comment					: String;
	areaType				: Integer;
	inGate					: Boolean;
	outGate					: Boolean;
	
begin
	
	varsStr := 'terminal			: CM_Terminal;' &amp; CrLf &amp; 
		Tab &amp; 'yicArea				: CM_YardInterchangeArea;' &amp; CrLf &amp; 
		Tab &amp; 'gateAreasArray		: StringArray;' &amp; CrLf;
	
	foreach obj in _gateXMLElement.childNodes do
		xmlElement := obj.JadeXMLElement;
		gateName := xmlElement.tagName;
		gateName.cnReplaceString('_', ' ');
		
		codeStr := codeStr &amp; CrLf &amp; Tab &amp; 'opts.purge();' &amp; CrLf &amp; 
			Tab &amp; 'opts.addAssoc("Terminal", "' &amp; xmlElement.parentNode.parentNode.JadeXMLElement.tagName &amp; '");' &amp; CrLf &amp;
			Tab &amp; 'terminal := self.getTerminal();' &amp; CrLf;
				
		icaElement := xmlElement.getElementByTagName('InterchangeArea');
		if icaElement = null then
			ica := _gateXMLElement.tagName &amp; "ICA";
		else
			ica := icaElement.text;
		endif;

		codeStr := codeStr &amp; Tab &amp; 'yicArea := terminal.allTerminalAreasByTypeId[32,"' &amp; ica &amp; '"].CM_YardInterchangeArea;' &amp; CrLf &amp; 
			Tab &amp; 'if yicArea = null then' &amp; CrLf &amp; 
			Tab &amp; Tab &amp; 'yicArea := self.addYardInterchangeArea("' &amp; ica &amp; '", null, 0, 0);' &amp; CrLf &amp;
			Tab &amp; 'endif;' &amp; CrLf &amp;
			Tab &amp; 'create gateAreasArray transient;' &amp; CrLf;
		
		gateAreaElement := xmlElement.getElementByTagName('GateArea');
		foreach obj in gateAreaElement.childNodes do
			gateElement := obj.JadeXMLElement;
			name := gateElement.tagName;
			comment	:= self.returnElementText(gateElement.getElementByTagName("comment")).String;
			if comment = null then
				comment := " ";
			endif;
			areaType := self.returnElementText(gateElement.getElementByTagName("areaType")).Integer;
			inGate := self.returnElementText(gateElement.getElementByTagName("in")).Boolean;
			outGate := self.returnElementText(gateElement.getElementByTagName("out")).Boolean;		
			
			codeStr := codeStr &amp; Tab &amp; 'gateAreasArray.add("' &amp; name &amp; ';' &amp; comment &amp; ';' &amp; areaType.String &amp; ';' &amp; 
				inGate.String &amp; ';' &amp; outGate.String &amp; ';0");' &amp; CrLf;
			
		endforeach;
		
		codeStr := codeStr &amp; Tab &amp; 'self.addGate("' &amp; gateName &amp; '", false, true, true, false, yicArea, gateAreasArray);' &amp; CrLf;
		
	endforeach;
	
	epilogStr := 'delete gateAreasArray;';
	
	_methodStr.cnReplaceString('&lt;^%vars^%&gt;', varsStr);
	_methodStr.cnReplaceString('&lt;^%code^%&gt;', codeStr);
	_methodStr.cnReplaceString('&lt;^%epilog^%&gt;', epilogStr);
	
epilog

end;
</source>
        <Parameter name="_gateXMLElement" type="JadeXMLElement"/>
        <Parameter name="_methodStr" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="processTerminalMachineRules" id="1c0f57f1-42a7-43a9-bd49-fe8ca2072248">
        <source>processTerminalMachineRules(_terminalXMLElement : JadeXMLElement; _methodStr : String io);

/*

Purpose:		Create / Add required terminal machine rules

Date			Who		Reason
24/02/2012		cnwmh5	Initial creation

*/

vars

	xmlElement				: JadeXMLElement;
	ruleElement				: JadeXMLElement;
	methodElement			: JadeXMLElement;
	methodsElement			: JadeXMLElement;
	queuingRuleElement		: JadeXMLElement;
	
	obj						: Object;
	
	varsStr					: String;
	codeStr					: String;
	epilogStr				: String;
	
	text					: String;
	beginTWritten			: Boolean;
	fromArea				: Integer;
	toArea					: Integer;
	queuingRule				: String;
	moveMethod				: String;
	isDefault				: Boolean;
	tagNumber				: String;
	
begin
	
	varsStr := CrLf &amp; Tab &amp; 'terminal			: CM_Terminal;' &amp; CrLf &amp; 
		Tab &amp; 'fromTA			: CM_TerminalAreaType;' &amp; CrLf &amp;
		Tab &amp; 'toTA				: CM_TerminalAreaType;' &amp; CrLf &amp; 
		Tab &amp; 'moveMethod1		: CM_RTMoveMethod;' &amp; CrLf &amp;
		Tab &amp; 'moveMethod2		: CM_RTMoveMethod;' &amp; CrLf &amp;
		Tab &amp; 'moveMethod3		: CM_RTMoveMethod;' &amp; CrLf &amp;
		Tab &amp; 'multiRule		: CM_RTQueueMultiRule;' &amp; CrLf &amp;
		Tab &amp; 'realMultiRule	: CM_RTQueueMultiRule;' &amp; CrLf &amp;
		Tab &amp; 'rule1			: CM_RTMoveMethodRule;' &amp; CrLf &amp;
		Tab &amp; 'rule2			: CM_RTMoveMethodRule;' &amp; CrLf &amp;
		Tab &amp; 'rule3			: CM_RTMoveMethodRule;' &amp; CrLf;
	
	codeStr := codeStr &amp; CrLf &amp; Tab &amp; 'terminal := app.myRoot.allTerminals["' &amp; _terminalXMLElement.parentNode.JadeXMLElement.tagName &amp; '"];' &amp; CrLf &amp; 
		Tab &amp; 'if terminal &lt;&gt; null then' &amp; CrLf;
		
	epilogStr := 'delete rule1;' &amp; CrLf &amp; 
		Tab &amp; 'delete rule2;' &amp; CrLf &amp;
		Tab &amp; 'delete rule3;' &amp; CrLf &amp;
		Tab &amp; 'delete multiRule;' &amp; CrLf;
	
	foreach obj in _terminalXMLElement.childNodes do
		ruleElement := obj.JadeXMLElement;
		
		codeStr := codeStr &amp; Tab &amp; Tab &amp; 'fromTA := app.myRoot.allTerminalAreaTypes[' &amp; self.returnElementText(ruleElement.getElementByTagName("fromArea")).String &amp; '];' &amp; CrLf &amp;
			Tab &amp; Tab &amp; 'toTA := app.myRoot.allTerminalAreaTypes[' &amp; self.returnElementText(ruleElement.getElementByTagName("toArea")).String &amp; '];' &amp; CrLf &amp; CrLf &amp;
			Tab &amp; Tab &amp; 'self.opts.purge();' &amp; CrLf &amp;
			Tab &amp; Tab &amp; 'self.opts.addAssoc("Terminal", terminal.code);' &amp; CrLf &amp;
			Tab &amp; Tab &amp; 'self.deleteMachineRule(fromTA, toTA);' &amp; CrLf &amp;
			Tab &amp; Tab &amp; 'create multiRule as CM_RTQueueMultiRuleTAType transient;' &amp; CrLf &amp;
			Tab &amp; Tab &amp; 'multiRule.CM_RTQueueMultiRuleTAType.setForProxyTAType(fromTA, toTA, terminal);' &amp; CrLf &amp; CrLf;
		
		methodsElement := ruleElement.getElementByTagName('Methods');
		foreach obj in methodsElement.childNodes do
			methodElement := obj.JadeXMLElement;
			
			tagNumber := methodElement.tagName[methodElement.tagName.length:end];
			
			moveMethod := self.returnElementText(methodElement.getElementByTagName("method")).String;
			moveMethod.cnReplaceString('"', '');
			isDefault := self.returnElementText(methodElement.getElementByTagName("isDefault")).Boolean;
			queuingRuleElement := methodElement.getElementByTagName("queuingRule");
			if queuingRuleElement = null then
				queuingRule := "null";
			else
				queuingRule := queuingRuleElement.text;
			endif;
		
			codeStr := codeStr &amp; Tab &amp; Tab &amp; 'moveMethod' &amp; tagNumber &amp; ' := app.myRoot.allRTMoveMethods[' &amp; moveMethod &amp; '];' &amp; CrLf &amp;
				Tab &amp; Tab &amp; 'create rule' &amp; tagNumber &amp; ' transient;' &amp; CrLf &amp;
				Tab &amp; Tab &amp; 'rule' &amp; tagNumber &amp; '.setProxy(multiRule, moveMethod' &amp; tagNumber &amp; ', ' &amp; isDefault.String &amp; ', "", null, null, ' &amp; queuingRule &amp; ');' &amp; CrLf &amp; CrLf;
		
		endforeach;
				
		codeStr := codeStr &amp; Tab &amp; Tab &amp; 'app.myTrxCA.trxCreateRTQueueMultiRule(multiRule, realMultiRule, app.myPassport);' &amp; CrLf &amp; CrLf;
			
	endforeach;
	
	codeStr := codeStr &amp; Tab &amp; 'endif;' &amp; CrLf;
	
	_methodStr.cnReplaceString('&lt;^%vars^%&gt;', varsStr);
	_methodStr.cnReplaceString('&lt;^%code^%&gt;', codeStr);
	_methodStr.cnReplaceString('&lt;^%epilog^%&gt;', epilogStr);
	
epilog

end;
</source>
        <Parameter name="_terminalXMLElement" type="JadeXMLElement"/>
        <Parameter name="_methodStr" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="processTerminalMachines" id="1905dcdf-7fe4-402f-9a58-953d9a8aab01">
        <source>processTerminalMachines(_terminalXMLElement : JadeXMLElement; _methodStr : String io);

/*

Purpose:		Create / Add required terminal machines

Date			Who		Reason
24/02/2012		cnwmh5	Initial creation

*/

vars

	xmlElement				: JadeXMLElement;
	machineTypeElement		: JadeXMLElement;
	machineElement			: JadeXMLElement;
		
	obj						: Object;
	
	varsStr					: String;
	codeStr					: String;
	epilogStr				: String;
	
	text					: String;
	craneTransferArea		: String;
		
begin
	
	varsStr := CrLf &amp; Tab &amp; 'cta						: CM_CraneTransferArea;' &amp; CrLf &amp; 
		Tab &amp; 'tas						: StringArray;' &amp; CrLf;
	
	codeStr := codeStr &amp; CrLf &amp; Tab &amp; 'create tas transient;' &amp; CrLf;
	epilogStr := 'delete tas;';
	
	foreach obj in _terminalXMLElement.childNodes do
		machineTypeElement := obj.JadeXMLElement;
		
		if machineTypeElement.tagName.toUpper() = "Crane".toUpper() then
			foreach obj in machineTypeElement.childNodes do 
				machineElement := obj.JadeXMLElement;
				craneTransferArea := self.returnElementText(machineElement.getElementByTagName('CraneTransferArea')).String;
				if craneTransferArea = null then
					craneTransferArea := machineElement.tagName &amp; "A";
				endif;
				codeStr := codeStr &amp; CrLf &amp; Tab &amp; 'cta := self.addCraneTransferArea(' &amp; craneTransferArea &amp; ');' &amp; CrLf &amp;  
					Tab &amp; 'tas.purge();' &amp; CrLf &amp;
					Tab &amp; 'tas.add(cta.id);';
					
				self.setupOptsAssoc(machineElement.getElementByTagName('opts'), codeStr);
				
				codeStr := codeStr &amp; Tab &amp; 'self.opts.addAssoc("CraneTransferArea", cta);' &amp; CrLf &amp; 
					Tab &amp; 'self.opts.addAssoc("Terminal", "' &amp; _terminalXMLElement.parentNode.JadeXMLElement.tagName &amp; '");' &amp; CrLf &amp;
					Tab &amp; 'self.addCrane("' &amp; machineElement.tagName &amp; '", null, tas, null);' &amp; CrLf;
			endforeach;
		endif;
			
	endforeach;
	
	_methodStr.cnReplaceString('&lt;^%vars^%&gt;', varsStr);
	_methodStr.cnReplaceString('&lt;^%code^%&gt;', codeStr);
	_methodStr.cnReplaceString('&lt;^%epilog^%&gt;', epilogStr);
	
epilog

end;
</source>
        <Parameter name="_terminalXMLElement" type="JadeXMLElement"/>
        <Parameter name="_methodStr" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="processTerminalObjNonConfig" id="48be711a-f64d-4239-a333-cc4a3decc7f5">
        <source>processTerminalObjNonConfig(_terminalXMLElement : JadeXMLElement; _methodStr : String io);

/*

Purpose:		Create / Add required not setConfigs

Date			Who		Reason
24/02/2012		cnwmh5	Initial creation

*/

vars

	xmlElement				: JadeXMLElement;
	
	varsStr					: String;
	codeStr					: String;
	epilogStr				: String;
	
	setAutoPlanMTReleaseStrategy				: String;
	gateDefaultEntry		: String;
	gateDefaultExit			: String;
	defCommodity			: String;
	defReeferComdty			: String;
	defHazCommodity			: String;
	defISOType				: String;
	defReeferISOType		: String;
	defOperator				: String;
	defCompany				: String;
	defVoyage				: String;
	
begin
	
	varsStr := Tab &amp; 'terminal 	: CM_Terminal;' &amp; CrLf;
	
	codeStr := codeStr &amp; 'self.opts.purge();' &amp; CrLf &amp;
		Tab &amp; 'self.opts.addAssoc("Terminal", "' &amp; _terminalXMLElement.parentNode.JadeXMLElement.tagName &amp; '");' &amp; CrLf &amp;
		Tab &amp; 'terminal := self.getTerminal();' &amp; CrLf &amp;
		Tab &amp; 'if terminal &lt;&gt; null then' &amp; CrLf &amp; 
		Tab &amp; Tab &amp; 'beginTransaction;' &amp; CrLf; 
	
	setAutoPlanMTReleaseStrategy := self.returnElementText(_terminalXMLElement.getElementByTagName('setAutoPlanMTReleaseStrategy')).String;
	setAutoPlanMTReleaseStrategy.cnReplaceString('"', '');
	if setAutoPlanMTReleaseStrategy &lt;&gt; null then
		codeStr := codeStr &amp; Tab &amp; Tab &amp; 'terminal.setAutoPlanMTReleaseStrategy(' &amp; setAutoPlanMTReleaseStrategy &amp; ');' &amp; CrLf;
	endif;			
			
	gateDefaultEntry := self.returnElementText(_terminalXMLElement.getElementByTagName('GateDefaultEntry')).String;
	gateDefaultEntry.cnReplaceString('"', '');
	if gateDefaultEntry &lt;&gt; null then
		codeStr := codeStr &amp; Tab &amp; Tab &amp; 'terminal.setConfig(GateDefaultEntry, terminal.allGates["' &amp; gateDefaultEntry &amp; '"]);' &amp; CrLf;
	endif;		
	
	gateDefaultExit := self.returnElementText(_terminalXMLElement.getElementByTagName('GateDefaultExit')).String;
	gateDefaultExit.cnReplaceString('"', '');
	if gateDefaultExit &lt;&gt; null then
		codeStr := codeStr &amp; Tab &amp; Tab &amp; 'terminal.setConfig(GateDefaultExit, terminal.allGates["' &amp; gateDefaultExit &amp; '"]);' &amp; CrLf;
	endif;	
	
	defCommodity := self.returnElementText(_terminalXMLElement.getElementByTagName('DefCommodity')).String;
	defCommodity.cnReplaceString('"', '');
	if defCommodity &lt;&gt; null then
		codeStr := codeStr &amp; Tab &amp; Tab &amp; 'terminal.setConfig(DefCommodity, app.myRoot.allCommodities["' &amp; defCommodity &amp; '"].code);' &amp; CrLf;
	endif;
		
	defReeferComdty := self.returnElementText(_terminalXMLElement.getElementByTagName('DefReeferComdty')).String;
	defReeferComdty.cnReplaceString('"', '');
	if defReeferComdty &lt;&gt; null then
		codeStr := codeStr &amp; Tab &amp; Tab &amp; 'terminal.setConfig(DefReeferComdty, app.myRoot.allCommodities["' &amp; defReeferComdty &amp; '"].code);' &amp; CrLf;
	endif;
	
	defHazCommodity := self.returnElementText(_terminalXMLElement.getElementByTagName('DefHazCommodity')).String;
	defHazCommodity.cnReplaceString('"', '');
	if defHazCommodity &lt;&gt; null then
		codeStr := codeStr &amp; Tab &amp; Tab &amp; 'terminal.setConfig(DefHazCommodity, app.myRoot.allCommodities["' &amp; defHazCommodity &amp; '"].code);' &amp; CrLf;
	endif;
	
	defISOType := self.returnElementText(_terminalXMLElement.getElementByTagName('DefISOType')).String;
	defISOType.cnReplaceString('"', '');
	if defISOType &lt;&gt; null then
		codeStr := codeStr &amp; Tab &amp; Tab &amp; 'terminal.setConfig(DefISOType, app.myRoot.allISOTypes["' &amp; defISOType &amp; '"].CM_ISOType);' &amp; CrLf;
	endif;

	defReeferISOType := self.returnElementText(_terminalXMLElement.getElementByTagName('DefReeferISOType')).String;
	defReeferISOType.cnReplaceString('"', '');
	if defReeferISOType &lt;&gt; null then
		codeStr := codeStr &amp; Tab &amp; Tab &amp; 'terminal.setConfig(DefReeferISOType, app.myRoot.allISOTypes["' &amp; defReeferISOType &amp; '"].CM_ISOType);' &amp; CrLf;
	endif;
	
	defOperator := self.returnElementText(_terminalXMLElement.getElementByTagName('DefOperator')).String;
	defOperator.cnReplaceString('"', '');
	if defOperator &lt;&gt; null then
		codeStr := codeStr &amp; Tab &amp; Tab &amp; 'terminal.setConfig(DefOperator, app.myRoot.allOperators["' &amp; defOperator &amp; '"].CM_Operator);' &amp; CrLf;
	endif;
	
	defCompany := self.returnElementText(_terminalXMLElement.getElementByTagName('DefCompany')).String;
	defCompany.cnReplaceString('"', '');
	if defCompany &lt;&gt; null then
		codeStr := codeStr &amp; Tab &amp; Tab &amp; 'terminal.setConfig(DefCompany, terminal.companies["' &amp; defCompany &amp; '"].CM_Bank);' &amp; CrLf;
	endif;
	
	defVoyage := self.returnElementText(_terminalXMLElement.getElementByTagName('DefVoyage')).String;
	defVoyage.cnReplaceString('"', '');
	if defVoyage &lt;&gt; null then
		codeStr := codeStr &amp; Tab &amp; Tab &amp; 'terminal.setConfig(DefVoyage, terminal.getNullVoyage().CM_Voyage);' &amp; CrLf;
	endif;
	
	codeStr := codeStr &amp; Tab &amp; Tab &amp; 'terminal.setConfig(DefAvailabilityGrade, "0");' &amp; CrLf;
	
	
	codeStr := codeStr &amp; Tab &amp; Tab &amp; 'commitTransaction;' &amp; CrLf &amp;
		Tab &amp; 'endif;' &amp; CrLf;
		
	_methodStr.cnReplaceString('&lt;^%vars^%&gt;', varsStr);
	_methodStr.cnReplaceString('&lt;^%code^%&gt;', codeStr);
	_methodStr.cnReplaceString('&lt;^%epilog^%&gt;', epilogStr);
	
epilog

end;
</source>
        <Parameter name="_terminalXMLElement" type="JadeXMLElement"/>
        <Parameter name="_methodStr" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="processTerminalSetConfig" id="1a88abe3-0bb1-4a08-a7b2-d37e272826a7">
        <source>processTerminalSetConfig(_terminalXMLElement : JadeXMLElement; _methodStr : String io);

/*

Purpose:		Add required terminal setConfigs

Date			Who		Reason
24/02/2012		cnwmh5	Initial creation

*/

vars

	xmlElement				: JadeXMLElement;
	obj						: Object;
	
	varsStr					: String;
	codeStr					: String;
	epilogStr				: String;
	
	text					: String;
	
begin
	
	varsStr := 'terminal			: CM_Terminal;';
		
	codeStr := codeStr &amp; 'self.opts.purge();' &amp; CrLf &amp;
		Tab &amp; 'self.opts.addAssoc("Terminal", "' &amp; _terminalXMLElement.parentNode.JadeXMLElement.tagName &amp; '");' &amp; CrLf &amp;
		Tab &amp; 'terminal := self.getTerminal();' &amp; CrLf &amp; 
		Tab &amp; 'if terminal &lt;&gt; null then' &amp; CrLf &amp; 
		Tab &amp; Tab &amp; 'beginTransaction;' &amp; CrLf;
	
	foreach obj in _terminalXMLElement.childNodes do
		xmlElement := obj.JadeXMLElement;
		text := xmlElement.text;
		if text = null then
			text := true.String;
		else
			//if not text.isDecimal() and not text.isInteger() and text.isReal() then
			if text.isAlpha() then
				text := '"' &amp; xmlElement.text &amp; '"';
			endif;
		endif;
		codeStr := codeStr &amp; Tab &amp; Tab &amp; 'terminal.setConfig(' &amp; xmlElement.tagName &amp; ', ' &amp; text &amp; ');' &amp; CrLf;
	endforeach;
	
	codeStr := codeStr &amp; Tab &amp; Tab &amp; "commitTransaction;" &amp; CrLf &amp;
		Tab &amp; "endif;" &amp; CrLf;
		
	_methodStr.cnReplaceString('&lt;^%vars^%&gt;', varsStr);
	_methodStr.cnReplaceString('&lt;^%code^%&gt;', codeStr);
	_methodStr.cnReplaceString('&lt;^%epilog^%&gt;', epilogStr);
	
epilog

end;
</source>
        <Parameter name="_terminalXMLElement" type="JadeXMLElement"/>
        <Parameter name="_methodStr" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="processTerminalSetUsers" id="3b931224-c6b0-486b-82c9-ec2ff26fe66c">
        <source>processTerminalSetUsers(_xmlElement : JadeXMLElement);

/*

Purpose:		Set SuperUser so can use terminal

Date			Who		Reason
02/03/2012		cnwmh5	Initial creation

*/

vars

	proxyUser			: CM_User;
	pxyUserTerm			: CM_UserTerminal;
	secRole				: CM_SecurityRole;
	user				: CM_User;
	terminal			: CM_Terminal;
	
begin
	
	user := app.myRoot.allUsers['SUPERUSER'];
	if user = null then
		return;
	endif;
	
	create proxyUser transient;

	proxyUser.setProxy(user.code, 
					   user.userName,
					   user.status,
					   user.myOrganisation,
					   app.myRoot,
					   user.persistentPassword,
					   //_user.radioTelemetryDevice, 
					   true, 
					   false,
					   user.allowAutomaticDisability,
					   user.lastLoginTS,
					   null,
					   user.mySystemSecurityRole, 
					   user.myEmailEntity, 
					   user.allEmailsICanSee,
					   user.allSystemAlertTypes,
					   user.allEventTypes,
					   user.myLocale,
					   false,
					   false);

					   
	terminal := app.myRoot.allTerminals[_xmlElement.tagName];
	if terminal = null then
		return;
	endif;
					   
	pxyUserTerm := user.getUserTerminal(terminal);
	if pxyUserTerm = null then
		create pxyUserTerm transient;
	endif;
	secRole := app.myRoot.allRoles["Terminal Root"];
	beginTransaction;
	pxyUserTerm.setForProxy(terminal, user, secRole, null, null, null);
	commitTransaction;
	app.myTrxUA.trxUpdateUser(proxyUser, app.encryptPassword("SUPERUSER", "c0nt@inerS", true).String, app.myPassport);	
	
epilog
	delete proxyUser;
end;
</source>
        <Parameter name="_xmlElement" type="JadeXMLElement"/>
    </JadeMethod>
    <JadeMethod name="processTerminalSubTerminals" id="8d871c81-4ac0-4190-b755-1cd8ae59ddc2">
        <source>processTerminalSubTerminals(_terminalXMLElement : JadeXMLElement; _methodStr : String io);

/*

Purpose:		Create / Add required terminal sub terminals

Date			Who		Reason
23/02/2012		cnwmh5	Initial creation

*/

vars

	xmlElement				: JadeXMLElement;
	obj						: Object;
	
	varsStr					: String;
	codeStr					: String;
	epilogStr				: String;
	
	text					: String;
	beginTWritten			: Boolean;
	
begin
	
	varsStr := 'terminal			: CM_Terminal;' &amp; CrLf &amp;
		Tab &amp; 'warehouseST		: CM_SubTerminal;' &amp; CrLf &amp;
		Tab &amp; 'depotST			: CM_SubTerminal;';
		
	codeStr := codeStr &amp; 'self.opts.purge();' &amp; CrLf &amp;
		Tab &amp; 'self.opts.addAssoc("Terminal", "' &amp; _terminalXMLElement.parentNode.JadeXMLElement.tagName &amp; '");' &amp; CrLf &amp;
		Tab &amp; 'terminal := self.getTerminal();' &amp; CrLf &amp;
		Tab &amp; 'if terminal &lt;&gt; null then' &amp; CrLf; 
		
	
	foreach obj in _terminalXMLElement.childNodes do
		xmlElement := obj.JadeXMLElement;
		
		if xmlElement.tagName = "Create" then
			self.processSubTerminalCreate(xmlElement, codeStr);
		elseif xmlElement.tagName = "depotST" or xmlElement.tagName = "warehouseST" then
			if not beginTWritten then
				codeStr := codeStr &amp; Tab &amp; Tab &amp; 'beginTransaction;' &amp; CrLf;
				beginTWritten := true;
			endif;
			codeStr := codeStr &amp; Tab &amp; Tab &amp; xmlElement.tagName &amp; ' := app.myRoot.allSubTerminals[' &amp; 
				self.returnElementText(xmlElement).String &amp; '];' &amp; CrLf;
		else
			text := self.returnElementText(xmlElement).String;
			text.cnReplaceString('"', '');
			codeStr := codeStr &amp; Tab &amp; Tab &amp; 'terminal.setConfig(' &amp; xmlElement.tagName &amp; ', ' &amp; 
				text &amp; ');' &amp; CrLf;
		endif;
		
	endforeach;
	
	codeStr := codeStr &amp; Tab &amp; Tab &amp; "commitTransaction;" &amp; CrLf &amp;
		Tab &amp; "endif;" &amp; CrLf;
		
	_methodStr.cnReplaceString('&lt;^%vars^%&gt;', varsStr);
	_methodStr.cnReplaceString('&lt;^%code^%&gt;', codeStr);
	_methodStr.cnReplaceString('&lt;^%epilog^%&gt;', epilogStr);
	
epilog

end;
</source>
        <Parameter name="_terminalXMLElement" type="JadeXMLElement"/>
        <Parameter name="_methodStr" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="processTerminalTerminalAreas" id="18ebe3ee-1160-40a2-84f9-036a2adc167a">
        <source>processTerminalTerminalAreas(_terminalAreaXMLElement : JadeXMLElement; _methodStr : String io);

/*

Purpose:		Create / Add required gate(s)

Date			Who		Reason
23/02/2012		cnwmh5	Initial creation

*/

vars

	xmlElement				: JadeXMLElement;
	areaTypeElement			: JadeXMLElement;
	areaElement				: JadeXMLElement;
	optsElement				: JadeXMLElement;
	obj						: Object;
	
	varsStr					: String;
	codeStr					: String;
	epilogStr				: String;
	
	addArea					: String;
	size					: Integer;
	
begin
	
	varsStr := varsStr &amp; CrLf &amp; Tab &amp; 'defaultInterchangeArea	: CM_InterchangeArea;' &amp; CrLf &amp;
		Tab &amp; 'interChangeAreaArray	: CM_InterchangeAreaArray;' &amp; CrLf;
	
	
	
	foreach obj in _terminalAreaXMLElement.childNodes do
		areaTypeElement := obj.JadeXMLElement;
	
		foreach obj in areaTypeElement.childNodes do
			areaElement := obj.JadeXMLElement;
			
			optsElement := areaElement.getElementByTagName('opts');
			if optsElement = null then
				codeStr := codeStr &amp; CrLf &amp; Tab &amp; 'self.opts.purge();' &amp; CrLf &amp;
					Tab &amp; 'self.opts.addAssoc("Terminal", "' &amp; _terminalAreaXMLElement.parentNode.JadeXMLElement.tagName &amp; '");' &amp; CrLf;
			else
				self.setupOptsAssoc(optsElement, codeStr);
				codeStr := codeStr &amp; CrLf &amp; Tab &amp; 'self.opts.addAssoc("Terminal", "' &amp; _terminalAreaXMLElement.parentNode.JadeXMLElement.tagName &amp; '");' &amp; CrLf;
			endif;
			
			if areaTypeElement.tagName.toUpper() = "BlockStack".toUpper() then
				size := self.returnElementText(areaElement.getElementByTagName('size')).Integer;
				codeStr := codeStr &amp; Tab &amp; 'self.addBlockStack("' &amp; areaElement.tagName &amp; '", ' &amp; size.String &amp; ', null);' &amp; CrLf;
			elseif areaTypeElement.tagName.toUpper() = "GeneralCargo".toUpper() then
				codeStr := codeStr &amp; Tab &amp; 'create interChangeAreaArray transient;' &amp; CrLf &amp;
					Tab &amp; 'self.addGeneralCargoArea("' &amp; areaElement.tagName &amp; '", " ", ' &amp; self.returnElementText(areaElement.getElementByTagName('rows')).String &amp; 
					', ' &amp; self.returnElementText(areaElement.getElementByTagName('columns')).String &amp; ', ' &amp;
					self.returnElementText(areaElement.getElementByTagName('units')).String &amp; ', interChangeAreaArray, defaultInterchangeArea);' &amp; CrLf; 
			elseif areaTypeElement.tagName.toUpper() = "YardInterchangeArea".toUpper() then
				codeStr := codeStr &amp; Tab &amp; 'self.addYardInterchangeArea("' &amp; areaElement.tagName &amp; '", null, ' &amp; 
					self.returnElementText(areaElement.getElementByTagName('laneCount')).String &amp; ', 0);' &amp; CrLf; 
			elseif areaTypeElement.tagName.toUpper() = "StraddleStack".toUpper() then
				codeStr := codeStr &amp; Tab &amp; 'self.addStraddleStack("' &amp; areaElement.tagName &amp; '", ' &amp; self.returnElementText(areaElement.getElementByTagName('rows')).String &amp; 
					', ' &amp; self.returnElementText(areaElement.getElementByTagName('columns')).String &amp; ', ' &amp;
					self.returnElementText(areaElement.getElementByTagName('height')).String &amp; ');' &amp; CrLf; 
			elseif areaTypeElement.tagName.toUpper() = "RTGArea".toUpper() then
				codeStr := codeStr &amp; Tab &amp; 'self.opts.addAssoc("use40ftIds", ' &amp; self.returnElementText(areaElement.getElementByTagName('use40ftIds')).String &amp; ');' &amp; CrLf &amp;
					Tab &amp; 'self.addRTGArea("' &amp; areaElement.tagName &amp; '", ' &amp; self.returnElementText(areaElement.getElementByTagName('rows')).String &amp; 
						', ' &amp; self.returnElementText(areaElement.getElementByTagName('stacks')).String &amp; ', ' &amp;
						self.returnElementText(areaElement.getElementByTagName('tiers')).String &amp; ', opts);' &amp; CrLf; 
			endif;
		endforeach;
		
	endforeach;
	
	_methodStr.cnReplaceString('&lt;^%vars^%&gt;', varsStr);
	_methodStr.cnReplaceString('&lt;^%code^%&gt;', codeStr);
	_methodStr.cnReplaceString('&lt;^%epilog^%&gt;', epilogStr);
	
epilog

end;
</source>
        <Parameter name="_terminalAreaXMLElement" type="JadeXMLElement"/>
        <Parameter name="_methodStr" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="processTerminalUsers" id="e79dd7a2-10f1-4b3c-b156-1d1cae8a0c8b">
        <source>processTerminalUsers(userXMLElement : JadeXMLElement);

/*

Purpose:		Set the user can use the terminal

Date			Who		Reason
06/03/2012		cnwmh5	Initial creation

*/

vars

	xmlElement				: JadeXMLElement;
	obj						: Object;
	user 					: CM_User;
	proxyUser				: CM_User;
	userTerm				: CM_UserTerminal;
	proxyUT					: CM_UserTerminal;
	secRole					: CM_SecurityRole;
	terminal				: CM_Terminal;
	
	varsStr					: String;
	codeStr					: String;
	epilogStr				: String;
	
	text					: String;
	role					: String;
		
begin
	
	// get the terminal
	terminal := app.myRoot.allTerminals[userXMLElement.parentNode.JadeXMLElement.tagName];
	if terminal = null then
		return;
	endif;
	
	foreach obj in userXMLElement.childNodes do
		xmlElement := obj.JadeXMLElement;
	
		role := self.returnElementText(xmlElement.getElementByTagName('role')).String;
		role.cnReplaceString('"', '');
		secRole := app.myRoot.allRoles[role];
		
		user := app.myRoot.allUsers[xmlElement.tagName];
		if user = null then
			continue;
		endif;
		
		beginLoad; 
		proxyUser := user.pxyCreateUpdateProxy();
		endLoad;
		
		create proxyUT transient;
		proxyUT.setForProxy(terminal, proxyUser, secRole, null, null, null);
		userTerm := user.allUserTerminals[terminal];
		if userTerm &lt;&gt; null then
			continue;
		endif;
		
		beginTransaction;
		create userTerm persistent;
		userTerm.setForCreate(proxyUT, user);
		commitTransaction;
		delete proxyUT;
		delete proxyUser;
		
	endforeach;
	
epilog
	delete proxyUT;
	delete proxyUser;
end;
</source>
        <Parameter name="userXMLElement" type="JadeXMLElement"/>
    </JadeMethod>
    <JadeMethod name="processTerminals" id="18b164f0-9d32-4df8-aba6-b19f8a97fb97">
        <source>processTerminals(_terminalXMLElements : JadeXMLElement; _methodStr : String io);

/*

Purpose:		Create / Add required terminals	

Date			Who		Reason
23/02/2012		cnwmh5	Initial creation

*/

vars

	xmlElement				: JadeXMLElement;
	obj						: Object;
	attribute				: JadeXMLAttribute;
	
	varsStr					: String;
	codeStr					: String;
	epilogStr				: String;
	
	description				: String;
	isCreate				: Boolean;
	
begin
	
	varsStr := varsStr &amp; CrLf &amp; Tab &amp; 'cargoType				: CM_CargoType;' &amp; CrLf &amp; 
		Tab &amp; 'terminal				: CM_Terminal;' &amp; CrLf &amp;
		Tab &amp; 'secRoleTerm			: CM_SecurityRoleTerminal;' &amp; CrLf &amp; CrLf &amp;
		Tab &amp; 'tokens				: StringArray;' &amp; CrLf &amp; 
		Tab &amp; 'bolTypesArray		: CM_CargoBOLTypeArray;' &amp; CrLf &amp; CrLf &amp;
		Tab &amp; 'users				: String;' &amp; CrLf &amp;
		Tab &amp; 'cargoTypes			: String;' &amp; CrLf &amp;
		Tab &amp; 'userName				: String;' &amp; CrLf &amp;
		Tab &amp; 'secRoleTermStr		: String;' &amp; CrLf &amp; 
		Tab &amp; 'pos					: Integer;' &amp; CrLf &amp;
		Tab &amp; 'str					: String;' &amp; CrLf &amp; CrLf;
		
	codeStr := codeStr &amp; CrLf &amp; Tab &amp; 'create tokens transient;' &amp; CrLf &amp; 
		Tab &amp; 'create bolTypesArray transient;' &amp; CrLf &amp; CrLf;
	
	epilogStr := epilogStr &amp; CrLf &amp; Tab &amp;'delete tokens;' &amp; CrLf &amp;
		Tab &amp; 'delete bolTypesArray;' &amp; CrLf &amp; CrLf;
	
	foreach obj in _terminalXMLElements.childNodes do
		xmlElement := obj.JadeXMLElement;
		
		attribute := xmlElement.getAttributeByName("Action");
		isCreate := (attribute &lt;&gt; null and attribute.value.toUpper() = "Create".toUpper());
		
		// create the terminal
		if isCreate then
			description := self.returnElementText(xmlElement.getElementByTagName('description')).String;
			codeStr := codeStr &amp; CrLf &amp; Tab &amp; 'self.opts.purge();' &amp; CrLf &amp;
				Tab &amp; 'self.opts.addAssoc("TerminalToDelete", "' &amp; xmlElement.tagName &amp; '");' &amp; CrLf &amp;
				Tab &amp; 'self.opts.addAssoc("FromUnitTestMethod", true);' &amp; CrLf &amp;
				Tab &amp; 'self.ndlDeleteTerminalNotComplete();' &amp; CrLf &amp;
				Tab &amp; 'terminal := self.addTerminal(' &amp; description &amp; ', "' &amp; xmlElement.tagName &amp; '");' &amp; CrLf &amp; CrLf;
		endif;		
		
		// set any cargo types that the temrinal requires
		codeStr := codeStr &amp; Tab &amp; 'cargoTypes := ' &amp; self.returnElementText(xmlElement.getElementByTagName('CargoTypes')).String &amp; ';' &amp; CrLf &amp;
			Tab &amp; 'tokens.clear();' &amp; CrLf &amp;
			Tab &amp; 'cargoTypes.getTokensForDelimiter(";", tokens);' &amp; CrLf &amp;
			Tab &amp; 'foreach str in tokens do' &amp; CrLf &amp;
			Tab &amp; '			foreach cargoType in app.myRoot.allCargoTypesById do' &amp; CrLf &amp;
			Tab &amp; '				if not tokens.includes(cargoType.abbreviation) then' &amp; CrLf &amp;
			Tab &amp; '					continue;' &amp; CrLf &amp;
			Tab &amp; '				endif;' &amp; CrLf &amp;
			Tab &amp; '				bolTypesArray.add(cargoType);' &amp; CrLf &amp;
			Tab &amp; '			endforeach;' &amp; CrLf &amp;
			Tab &amp; '         bolTypesArray.add(CM_BOLType.firstInstance);' &amp; CrLf &amp;
			Tab &amp; '			beginTransaction;' &amp; CrLf &amp;
			Tab &amp; '			terminal.allCargoBOLTypes.clear();' &amp; CrLf &amp;
			Tab &amp; '			bolTypesArray.copyNoDups(terminal.allCargoBOLTypes);' &amp; CrLf &amp;
			Tab &amp; '			commitTransaction;' &amp; CrLf &amp;
			Tab &amp; 'endforeach;' &amp; CrLf &amp; CrLf;
			
	endforeach;
	
	_methodStr.cnReplaceString('&lt;^%vars^%&gt;', varsStr);
	_methodStr.cnReplaceString('&lt;^%code^%&gt;', codeStr);
	_methodStr.cnReplaceString('&lt;^%epilog^%&gt;', epilogStr);
	
epilog

end;
</source>
        <Parameter name="_terminalXMLElements" type="JadeXMLElement"/>
        <Parameter name="_methodStr" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="processToDoResources" id="df299e27-051e-419d-82c1-cddd361523cf">
        <source>processToDoResources(_toDoTaskResXMLElement : JadeXMLElement; _methodStr : String io);

/*

Purpose:		Create the to do task resources

Date			Who		Reason
01/03/2012		cnwmh5	Initial creation

*/

vars

	xmlElement				: JadeXMLElement;
	optsElement				: JadeXMLElement;
	obj						: Object;
	
	varsStr					: String;
	codeStr					: String;
	epilogStr				: String;
	
	taskDescsArray			: StringArray;
	
	description				: String;	
	name 					: String;
	numDecimals 			: Integer;
	unitDescription 		: String;
	hasBeenUsed 			: Boolean;
	isAvailable 			: Boolean;
	taskDescs				: String;
	str						: String;
	
begin

	varsStr := 'toDoTasks 			: CM_ToDoTaskDescBySortKey;' &amp; CrLf;

	codeStr := codeStr &amp; 'create toDoTasks transient;' &amp; CrLf;
	
	epilogStr := 'delete toDoTasks;';
	
	create taskDescsArray transient;
	
	foreach obj in _toDoTaskResXMLElement.childNodes do
		xmlElement := obj.JadeXMLElement;
		name := xmlElement.tagName;
				
		description := self.returnElementText(xmlElement.getElementByTagName('description')).String;
		numDecimals := self.returnElementText(xmlElement.getElementByTagName('numDecimals')).Integer;
		unitDescription := self.returnElementText(xmlElement.getElementByTagName('unitDescription')).String;
		hasBeenUsed := self.returnElementText(xmlElement.getElementByTagName('hasBeenUsed')).Boolean;
		isAvailable :=self.returnElementText(xmlElement.getElementByTagName('isAvailable')).Boolean;
				
		codeStr := codeStr &amp; Tab &amp; 'toDoTasks.clear();' &amp; CrLf;
		
		taskDescs := self.returnElementText(xmlElement.getElementByTagName('taskDescs')).String;
		taskDescs.cnReplaceString('"', '');
		taskDescsArray.clear();
		taskDescs.getTokensForDelimiter(';', taskDescsArray);
		foreach str in taskDescsArray do
			codeStr := codeStr &amp; Tab &amp; 'toDoTasks.add(app.myRoot.allToDoTaskDescriptions[' &amp; str &amp; ']);' &amp; CrLf;
		endforeach;
		
		codeStr := codeStr &amp; Tab &amp; 'self.addToDoTaskResource("' &amp; name &amp; '", ' &amp; description &amp; ', "' &amp; 
			unitDescription.String &amp; '", ' &amp; numDecimals.String &amp; ', ' &amp; hasBeenUsed.String &amp; ', ' &amp; 
			isAvailable.String &amp; ', toDoTasks);' &amp; CrLf; 
			
	endforeach;
		
	_methodStr.cnReplaceString('&lt;^%vars^%&gt;', varsStr);
	_methodStr.cnReplaceString('&lt;^%code^%&gt;', codeStr);
	_methodStr.cnReplaceString('&lt;^%epilog^%&gt;', epilogStr);
	
epilog
	delete taskDescsArray;
end;
</source>
        <Parameter name="_toDoTaskResXMLElement" type="JadeXMLElement"/>
        <Parameter name="_methodStr" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="processToDoTasks" id="84dc94af-f1f3-45a9-b349-c2f54d7acb5e">
        <source>processToDoTasks(_toDoTaskAgentXMLElement : JadeXMLElement; _methodStr : String io);

/*

Purpose:		Create the to do task

Date			Who		Reason
01/03/2012		cnwmh5	Initial creation

*/

vars

	xmlElement				: JadeXMLElement;
	optsElement				: JadeXMLElement;
	obj						: Object;
	
	varsStr					: String;
	codeStr					: String;
	epilogStr				: String;
	
	description				: String;	
	code 					: String;
	trxTypeOnCompletion		: String;
	trxTypeOnCreation		: String;
	
begin

	varsStr := 'toDoTaskDesc		: CM_ToDoTaskDesc;' &amp; CrLf;

	codeStr := codeStr &amp; CrLf;
	
	foreach obj in _toDoTaskAgentXMLElement.childNodes do
		xmlElement := obj.JadeXMLElement;
		code := self.returnElementText(xmlElement.getElementByTagName('code')).String;
		description := self.returnElementText(xmlElement.getElementByTagName('description')).String;
			
		optsElement := xmlElement.getElementByTagName('opts');
		self.setupOptsAssoc(optsElement, codeStr);
		codeStr := codeStr &amp; Tab &amp; 'self.opts.addAssoc("Code", ' &amp; code &amp; ');' &amp; CrLf;
		
		trxTypeOnCreation := self.returnElementText(xmlElement.getElementByTagName('TrxTypeOnCreation')).String;
		if trxTypeOnCreation &lt;&gt; null then
			codeStr := codeStr &amp; Tab &amp; 'self.opts.addAssoc("TrxTypeOnCreation", app.myRoot.allTransactionTypesByDesc[' &amp; 
				trxTypeOnCreation &amp; ']);' &amp; CrLf;
		endif;
		
		trxTypeOnCompletion := self.returnElementText(xmlElement.getElementByTagName('TrxTypeOnCompletion')).String;
		if trxTypeOnCompletion &lt;&gt; null then
			codeStr := codeStr &amp; Tab &amp; 'self.opts.addAssoc("TrxTypeOnCompletion", app.myRoot.allTransactionTypesByDesc[' &amp; 
				trxTypeOnCompletion &amp; ']);' &amp; CrLf;
		endif;
		
		codeStr := codeStr &amp; Tab &amp; 'toDoTaskDesc := app.myRoot.allToDoTaskDescriptions[' &amp; code &amp; '];' &amp; CrLf &amp;
			Tab &amp; 'self.deleteToDoTaskDescription(toDoTaskDesc);' &amp; CrLf &amp; 
			Tab &amp; 'self.createToDoTaskDesc(' &amp; description &amp; ');' &amp; CrLf; 
	endforeach;
		
	_methodStr.cnReplaceString('&lt;^%vars^%&gt;', varsStr);
	_methodStr.cnReplaceString('&lt;^%code^%&gt;', codeStr);
	_methodStr.cnReplaceString('&lt;^%epilog^%&gt;', epilogStr);
	
epilog

end;
</source>
        <Parameter name="_toDoTaskAgentXMLElement" type="JadeXMLElement"/>
        <Parameter name="_methodStr" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="processTrades" id="cc879d62-9e42-43e9-8ac0-e4c4ae4f4432">
        <source>processTrades(_tradeXMLElement : JadeXMLElement; _methodStr : String io);

/*

Purpose:		Create the trades

Date			Who		Reason
03/03/2012		cnwmh5	Initial creation

*/

vars

	xmlElement				: JadeXMLElement;
	element					: JadeXMLElement;
	obj						: Object;
	
	varsStr					: String;
	codeStr					: String;
	epilogStr				: String;
	
	description				: String;
	
begin

	varsStr := 'obj					: Object;' &amp; CrLf &amp; 
		Tab &amp; 'shippingLines		: CM_ShippingLineByCodeDict;' &amp; CrLf &amp;
		Tab &amp; 'portRotationArray	: ObjectArray;' &amp; CrLf &amp;
		Tab &amp; 'operatorArray		: ObjectArray;' &amp; CrLf;

	codeStr := CrLf &amp; Tab &amp; 'create portRotationArray transient;' &amp; CrLf &amp;
		Tab &amp; 'create shippingLines transient;' &amp; CrLf &amp;
		Tab &amp; 'create operatorArray transient;' &amp; CrLf &amp; CrLf;
	
	epilogStr := 'delete shippingLines;' &amp; CrLf &amp;
		Tab &amp; 'delete portRotationArray;' &amp; CrLf &amp; 
		Tab &amp; 'delete operatorArray;';
	
	foreach obj in _tradeXMLElement.childNodes do
		xmlElement := obj.JadeXMLElement;
		
		codeStr := codeStr &amp; Tab &amp; 'shippingLines.clear();' &amp; CrLf &amp;
			Tab &amp; 'operatorArray.clear();' &amp; CrLf &amp;
			Tab &amp; 'portRotationArray.clear();' &amp; CrLf;

		element := xmlElement.getElementByTagName('shippingLines');	
		self.returnArrayDetails(element, 'allShippingLines', 'root', codeStr);
		
		element := xmlElement.getElementByTagName('operatorArray');	
		self.returnArrayDetails(element, 'allOperators', 'root', codeStr);
		
		element := xmlElement.getElementByTagName('portRotationArray');	
		self.returnArrayDetails(element, 'allPorts', 'root', codeStr);
			
		codeStr := codeStr &amp; Tab &amp; 'if portRotationArray.size &gt; 0 then' &amp; CrLf &amp;
			Tab &amp; Tab &amp; 'self.opts.addAssoc("PortsOfRotation", portRotationArray);' &amp; CrLf &amp; 
			Tab &amp; 'endif;' &amp; CrLf;
		
		description := self.returnElementText(xmlElement.getElementByTagName('description')).String;
		
		codeStr := codeStr &amp; Tab &amp; 'self.addTrade("", ' &amp; description &amp; ', false, shippingLines, operatorArray);' &amp; CrLf &amp; CrLf;
		
	endforeach;
		
	_methodStr.cnReplaceString('&lt;^%vars^%&gt;', varsStr);
	_methodStr.cnReplaceString('&lt;^%code^%&gt;', codeStr);
	_methodStr.cnReplaceString('&lt;^%epilog^%&gt;', epilogStr);
	
epilog
	
end;
</source>
        <Parameter name="_tradeXMLElement" type="JadeXMLElement"/>
        <Parameter name="_methodStr" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="processTrailerTypes" id="c60b827e-6fd9-4076-a3cf-100c707835bf">
        <source>processTrailerTypes(_trailerTypeXMLElement : JadeXMLElement; _methodStr : String io);

/*

Purpose:		Create the trailer types

Date			Who		Reason
01/03/2012		cnwmh5	Initial creation

*/

vars

	xmlElement				: JadeXMLElement;
	optsElement				: JadeXMLElement;
	obj						: Object;
	
	cargoTypesArray			: StringArray;
	
	varsStr					: String;
	codeStr					: String;
	epilogStr				: String;
	
	description				: String;	
	length					: Integer;
	noCargoPositions		: Integer;
	height					: Integer;
	weight					: Integer;
	tareWeight				: Integer;
	
begin

	varsStr := CrLf &amp; Tab &amp; 'cargoType			: CM_CargoType;' &amp; CrLf;
	
	create cargoTypesArray transient;
	
	foreach obj in _trailerTypeXMLElement.childNodes do
		xmlElement := obj.JadeXMLElement;
		
		// get the cargo type
		codeStr := CrLf &amp; Tab &amp; 'cargoType := app.myRoot.getCargoTypeFromAbbrev(' &amp; 
			self.returnElementText(xmlElement.getElementByTagName('cargoType')).String &amp; ');' &amp; CrLf;
		
		description := self.returnElementText(xmlElement.getElementByTagName('description')).String;
		length := self.returnElementText(xmlElement.getElementByTagName('length')).Integer;
		noCargoPositions := self.returnElementText(xmlElement.getElementByTagName('noCargoPositions')).Integer;
		height := self.returnElementText(xmlElement.getElementByTagName('height')).Integer;
		weight := self.returnElementText(xmlElement.getElementByTagName('weight')).Integer;
		tareWeight := self.returnElementText(xmlElement.getElementByTagName('tareWeight')).Integer;
		
		codeStr := codeStr &amp; Tab &amp; 'self.addTrailerType("' &amp; xmlElement.tagName &amp; '", ' &amp; description &amp; ', cargoType, ' &amp; 
			length.String &amp; ', ' &amp; noCargoPositions.String &amp; ', ' &amp; height.String &amp; ', ' &amp; weight.String &amp; 
			', ' &amp; tareWeight.String &amp; ');' &amp;CrLf;
		
	endforeach;
		
	_methodStr.cnReplaceString('&lt;^%vars^%&gt;', varsStr);
	_methodStr.cnReplaceString('&lt;^%code^%&gt;', codeStr);
	_methodStr.cnReplaceString('&lt;^%epilog^%&gt;', epilogStr);
	
epilog
	delete cargoTypesArray;
end;
</source>
        <Parameter name="_trailerTypeXMLElement" type="JadeXMLElement"/>
        <Parameter name="_methodStr" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="processTransactionTypes" id="9587e02f-84ee-45f9-82fc-0db3ce93c698">
        <source>processTransactionTypes(_transactionTypeXMLElement : JadeXMLElement; _methodStr : String io);

/*

Purpose:		Create the transaction types

Date			Who		Reason
01/03/2012		cnwmh5	Initial creation

*/

vars

	xmlElement				: JadeXMLElement;
	optsElement				: JadeXMLElement;
	obj						: Object;
	
	cargoTypesArray			: StringArray;
	
	varsStr					: String;
	codeStr					: String;
	epilogStr				: String;
	
	description				: String;	
	group		 			: Integer;
	classToCreate	 		: String;
	canCompleteToDoTask		: Boolean;
	code					: String;
	
begin
	
	codeStr := CrLf;	
	
	foreach obj in _transactionTypeXMLElement.childNodes do
		xmlElement := obj.JadeXMLElement;
		code := self.returnElementText(xmlElement.getElementByTagName('code')).String;
		description := self.returnElementText(xmlElement.getElementByTagName('description')).String;
		group := self.returnElementText(xmlElement.getElementByTagName('group')).Integer;
		classToCreate := self.returnElementText(xmlElement.getElementByTagName('classToCreate')).String;
		canCompleteToDoTask := self.returnElementText(xmlElement.getElementByTagName('canCompleteToDoTask')).Boolean;
		
		codeStr := codeStr &amp; Tab &amp; 'self.addTransactionType(' &amp; description &amp; ', ' &amp; 
			classToCreate &amp; ', ' &amp; code &amp; ', ' &amp; group.String &amp; ', ' &amp; canCompleteToDoTask.String &amp; ');' &amp; CrLf;
		
	endforeach;
		
	_methodStr.cnReplaceString('&lt;^%vars^%&gt;', varsStr);
	_methodStr.cnReplaceString('&lt;^%code^%&gt;', codeStr);
	_methodStr.cnReplaceString('&lt;^%epilog^%&gt;', epilogStr);
	
epilog
	delete cargoTypesArray;
end;
</source>
        <Parameter name="_transactionTypeXMLElement" type="JadeXMLElement"/>
        <Parameter name="_methodStr" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="processUpdateCargoTypes" id="1eb2c431-05b1-4df6-a003-871b0d783e24">
        <source>processUpdateCargoTypes(_cargoTypesXMLElement : JadeXMLElement; _methodStr : String io);

/*

Purpose:		Create / Add / Update Cargo Types

Date			Who		Reason
23/02/2012		cnwmh5	Initial creation

*/

vars

	xmlElement				: JadeXMLElement;
	xmlSubElement			: JadeXMLElement;
	
	obj						: Object;
	
	varsStr					: String;
	codeStr					: String;
	epilogStr				: String;
	
	hasSubCargo				: Boolean;
	
begin

	varsStr := "cargoType				: CM_CargoType;" &amp; CrLf;

	foreach obj in _cargoTypesXMLElement.childNodes do
		xmlElement := obj.JadeXMLElement;
		
		codeStr := codeStr &amp; CrLf &amp; Tab &amp; 'cargoType := app.myRoot.allCargoTypesById.getAtKey(' &amp; xmlElement.tagName &amp; ');' &amp; CrLf &amp; 
			Tab &amp; 'if cargoType &lt;&gt; null then' &amp; CrLf &amp; 
			Tab &amp; Tab &amp; 'beginTransaction;' &amp; CrLf;
		
		foreach obj in xmlElement.childNodes do
			xmlSubElement := obj.JadeXMLElement;
			codeStr := codeStr &amp; Tab &amp; Tab &amp; 'cargoType.setPropertyValue("' &amp; xmlSubElement.tagName &amp; '", true);' &amp; CrLf;
		endforeach;
		
		codeStr := codeStr &amp; Tab &amp; Tab &amp; 'commitTransaction;' &amp; CrLf &amp;
			Tab &amp; 'endif;' &amp; CrLf;
			
	endforeach;
	
	_methodStr.cnReplaceString('&lt;^%vars^%&gt;', varsStr);
	_methodStr.cnReplaceString('&lt;^%code^%&gt;', codeStr);
	_methodStr.cnReplaceString('&lt;^%epilog^%&gt;', epilogStr);
	
epilog

end;
</source>
        <Parameter name="_cargoTypesXMLElement" type="JadeXMLElement"/>
        <Parameter name="_methodStr" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="processUpdateLicense" id="be39f5ea-e20c-485c-9385-d65a98f7e5dd">
        <source>processUpdateLicense();

/*

Purpose:		Update the systems license

Date			Who		Reason
02/03/2012		cnwmh5	Initial creation

*/

vars

	//schema				: Schema;
	//klass				: Class;
	//tempClass			: Class;

	licName 			: String;
	license 			: String; 
	ediLicName 			: String;
	ediLicense 			: String;
		
begin

	licName := "JADE Master Terminal"; //Base + backup
	license := "8400000094000000A794DED9C094949494949494979494949B15B1946B734B6B6B6B6B8B";
	ediLicName := "JADE Master Terminal (EDI)";
	ediLicense := "0A0000006700000050672D2A333822232E6767677C6767678DBC42679898986467679B98989818999868E778";

	app.myTrxUA.trxUpdateLicense(CM_Root.firstInstance, licName, license, ProductCode_JMT, CM_Root.firstInstance.edition, app.myPassport);
	//if not app.myPassport.noErrors then
	//	return returnCode;
	//endif;
	//if _licenseKeyEDI &lt;&gt; null then
		app.myTrxUA.trxUpdateLicense(CM_Root.firstInstance, ediLicName, ediLicense, ProductCode_JMT_EDI, CM_Root.firstInstance.edition, app.myPassport);
		//if not app.myPassport.noErrors then
		//	return returnCode;
		//endif;
	//endif;
		
epilog

	//delete tempClass;

end;
</source>
    </JadeMethod>
