    <JadeMethod name="doMnuInvChangeToCreditClick" id="1d803a46-8ad6-4da0-8455-1cd8f9233373">
        <updating/>
        <source>doMnuInvChangeToCreditClick() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 January 2023	navkc1	Initial creation TFS CR 55305 Task 55537

*/

vars
	allSelectedInvoices : CM_InvoiceSet;
	theReturn			: Integer;
	realInv,
	pxyInv				: CM_Invoice;
begin
	
	if app.msgBox(app.getErrorString(ChgInvStatusToCredit), app.getErrorString(Attention), MsgBox_Yes_No + MsgBox_Question_Mark_Icon) = MsgBox_Return_No then
		return;
	endif;
	
	create allSelectedInvoices transient;
	
	foreach realInv in self.tblData.allSelectedObjects as CM_Invoice do
		pxyInv := app.createUpdateProxy(realInv).CM_Invoice;
		allSelectedInvoices.add(pxyInv);
	endforeach;
	
	while true do
		app.myTrxUA.trxUpdateInvoiceToCredit(allSelectedInvoices, app.myPassport);
		
		if app.myPassport.trxCompletedOK then
			self.clearErrorWarnings();
			app.msgBox( app.getErrorString(SAVE_COMPLETE),app.getErrorString(Information) , MsgBox_OK_Only + MsgBox_Information_Icon);
			break;
		else
			theReturn := app.showErrorWarningDialog(app.getErrorString(CM_Update_Invoice), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors 
			and theReturn = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);
			return;
		endif;
		break;
	endwhile;
	
epilog
	if allSelectedInvoices &lt;&gt; null then
		allSelectedInvoices.purge();
		delete allSelectedInvoices;
	endif;
end;</source>
    </JadeMethod>
