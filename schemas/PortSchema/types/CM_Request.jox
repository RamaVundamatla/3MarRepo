    <JadeMethod name="isIntegral" id="813af067-b5b8-4630-84d3-31cb18b4c312">
        <source>isIntegral() : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 September 2017	jlger1	Initial creation tfs 7006

*/

vars
	ti : CM_TrackedItem;
begin
	ti :=self.getTrackedItem;
	if ti &lt;&gt; null then
		if  (ti.isIntegral or
				   ti.isAttributeTrue(TI_Attrib_IsWaterCooled)) then
			return true;
		endif;
	else
		if  (self.getAttrPowerRequired or self.getAttrWaterCooled) then
			return true;
		endif;
	endif;
	
	return false;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
