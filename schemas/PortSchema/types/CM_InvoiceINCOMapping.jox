    <JadeMethod name="setForUpdate" id="4dad399c-e3c5-4b69-918a-d0db6e6079d2">
        <updating/>
        <source>setForUpdate(_proxy : CM_InvoiceINCOMapping)updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who			Reason
16 May 2023 navtnr20	TFS CR 57983 Task 57984: EUP - INCO Terms TRX Layer

*/

vars

begin
	self.myINCOTerm := _proxy.myINCOTerm;
	self.myDebtorType := _proxy.myDebtorType;
	self.allInvoiceLineTypes.clear();
	_proxy.allInvoiceLineTypes.copy(self.allInvoiceLineTypes);
	
	self.myINCOTerm.setInvLineTypeCollection();
epilog

end;</source>
        <Parameter name="_proxy" type="CM_InvoiceINCOMapping"/>
