    <JadeMethod name="setInfo_jadestar" id="1f6d6d9b-b9a6-4ef5-9a42-233f90aa068a">
        <updating/>
        <source>setInfo_jadestar() updating;
//	set profile name to be used for each Creator
//	to set profile name per copy of a Creator, modify startApp
begin
	copies:=1;
	port:=myBmkControl.bmkBasePort.Integer;
	
	port:=port+(appSequenceId div  4);
//	port:=port+(appSequenceId mod myBmkControl.appServers);  // distrubute evenly across appServers
	profType:=(appSequenceId mod 4);
//	profType:=(appSequenceId mod 2)+1;
	if     profType = 0 then profile:='Payin';
	elseif profType = 1 then profile:='BulkPayin';
	elseif profType = 2 then profile:='LeaveInquiry';
	elseif profType = 3 then profile:='ReportInit';
	endif;
	if profType = 1 and appSequenceId div 4 = 2 then
		profile:='Payin';  // need more of these
	endif;
//	profile:='LeaveInquiry';
end;</source>
    </JadeMethod>
    <JadeMethod name="setInfo_jadestar2" id="0360fd41-4e7f-470a-a572-711c7f972893">
        <updating/>
        <source>setInfo_jadestar2() updating;
//	set profile name to be used for each Creator
//	to set profile name per copy of a Creator, modify startApp
begin
	copies:=1;
	port:=myBmkControl.bmkBasePort.Integer;
	
	if computerName &lt;&gt; 'x' then
		port:=port+(appSequenceId div  4);  //  5 users per appserver - 30 user test
//		port:=port+(appSequenceId div 10);  // 10 users per appserver - 60 user test
//		port:=port+(appSequenceId mod myBmkControl.appServers);  // distrubute evenly across appServers
		profType:=(appSequenceId mod 4);
//		profType:=(appSequenceId mod 2)+1;
		if     profType = 0 then profile:='Payin';
		elseif profType = 1 then profile:='BulkPayin';
		elseif profType = 2 then profile:='LeaveInquiry';
		elseif profType = 3 then profile:='ReportInit';
		endif;
		if profType = 1 and appSequenceId div 4 = 2 then
			profile:='Payin';  // need more of these
		endif;
//		profile:='LeaveInquiry';
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="setInfo_jasper" id="99ed8315-685c-4f38-8f99-c022d1197090">
        <updating/>
        <source>setInfo_jasper() updating;

begin
	copies:=1;
	port := myBmkControl.bmkBasePort.Integer;
	
	// this is the configuration for the 6.3 UOC tests - 8 appservers, 2 client machines
	port:=port+(appSequenceId mod 8);
	if      appSequenceId &lt;= 9 then
		profile:='AddressChange';
	elseif appSequenceId &lt;= 19 then
		profile:='Inquiries';
	elseif appSequenceId &lt;= 24 then
		profile:='Enrol';
	else
		profile:='AgendaMonitor';
	endif;/**/
	
	// this is the configuration for the 6.1 version test
	/*port:=port+(appSequenceId div 3);
	if appSequenceId = 0 then
		profile:='StuAddrMaint';
	else
		profile:='NewRegMaint';
	endif;/**/
//	profile:='PrintTest';
end;</source>
    </JadeMethod>
    <JadeMethod name="setInfo_jasperInit" id="87270825-6212-4ddd-93da-a0b904733524">
        <updating/>
        <source>setInfo_jasperInit() updating;

begin
	copies:=0;
	port:=51724;  // standard for benchmark db's
	port := myBmkControl.bmkBasePort.Integer;
	
	if computerName='cnwchcs131' then	profile:='SetupMaint';	copies:=1;	port:=port+1;		
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="setInfo_jasperTest" id="9b0923c1-3ce3-4a96-a28a-9424ff4e6bb2">
        <updating/>
        <source>setInfo_jasperTest() updating;

begin
	copies:=1;
	port:=51700;  // standard for benchmark db's
	port := myBmkControl.bmkBasePort.Integer;
	
	// Do it like this if you want multiples copies of the same profile on each client machine.
	// Use one creator per client machine.
	
	if     computerName='cnwchcs46'	then	port:=port+0;
	elseif computerName='cnwmjw1b' then		port:=port+0;
	elseif computerName='cnwpaf1a' then		port:=port+(appSequenceId mod 4);
	elseif computerName='cnwchcs73'	then	port:=port+(appSequenceId div 2);
	elseif computerName='cnwchcs121' then	port:=port+0;
	elseif computerName='cnwchcs124' then	port:=port+1;
	elseif computerName='cnwchcs131' then	port:=port+(appSequenceId mod 6);
	endif;
//	if appSequenceId = 0 then
//		profile:='StuAddrMaint';
//	else
		profile:='NewRegMaint';
//	endif;
//	profile:='PrintTest';

end;</source>
    </JadeMethod>
    <JadeMethod name="setInfo_jcc" id="af884a48-0f16-49f7-9b36-2b823b09feb7">
        <updating/>
        <source>setInfo_jcc() updating;

begin
	port:=myBmkControl.bmkBasePort.Integer;  // standard for benchmark db's
	
	copies:=1;
	profType:=(appSequenceId mod 4)+0;
	//port:=port+(appSequenceId div 24);  // users per appServer
	port:=port+(appSequenceId div 4);  // users per appServer
//	port:=port+(appSequenceId div 1);  // users per appServer
	if     profType = 0 then profile:='Case';  // copies:=2;
	elseif profType = 1 then profile:='CaseProgressNotes';
	elseif profType = 2 then profile:='Person';
	elseif profType = 3 then profile:='PersonProgressNotes';
	endif;
//	profile:='Case';
end;</source>
    </JadeMethod>
    <JadeMethod name="setInfo_jcc2" id="ad3001c2-b80d-4d11-8fc7-fe0a26efa0e0">
        <updating/>
        <source>setInfo_jcc2() updating;

begin
	copies:=0;
	port:=myBmkControl.bmkBasePort.Integer;  // standard for benchmark db's
	
	// Do it like this if you want multiples copies of the same profile on each client machine.
	// Use one creator per client machine.
	if     computerName='cnwjhp1x'	then	profile:='Case';				copies:=0;	port:=port+0;
	
	// Do it like this if you want multiple profiles on each client machine.
	// Use multiple creators per client machine, one per profile.
	elseif computerName &lt;&gt; 'x'
	then
		copies:=1;
		profType:=(appSequenceId mod 4)+0;
		port:=port+(appSequenceId div 4);  // users per appServer
//		if computerName &lt;&gt; 'cnwchcs136' then port:=port+1; endif;
//		port:=port+(appSequenceId div 1);  // users per appServer
		if     profType = 0 then profile:='Case';  // copies:=2;
		elseif profType = 1 then profile:='CaseProgressNotes';
		elseif profType = 2 then profile:='Person';  // if computerName='cnwchcs76' then copies:=0; endif;
		elseif profType = 3 then profile:='PersonProgressNotes';
		endif;


	endif;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="setInfo_jmt" id="2738af26-9893-46dd-a3b7-54a840afd372">
        <updating/>
        <source>setInfo_jmt() updating;
//	set profile name to be used for each Creator
//	to set profile name per copy of a Creator, modify startApp
begin
	port:=myBmkControl.bmkBasePort.Integer;  // same for all benchmark db's
	
	copies:=1;
	if myBmkControl.owner = "cnwjhp1" then
		port:=port+(appSequenceId div  7);  //  7 users per appserver
		if      appSequenceId =  0 then profile:='RoadOpsInquiry';
		elseif appSequenceId =  1 then profile:='GateInOut';
		elseif appSequenceId =  2 then profile:='GateInOut';
		elseif appSequenceId =  3 then profile:='GateInOut';
		elseif appSequenceId =  4 then profile:='GateInOut';
		elseif appSequenceId =  5 then profile:='VoyageWorker';
		elseif appSequenceId =  6 then profile:='VoyageWorker';
		elseif appSequenceId =  7 then profile:='RoadOpsInquiry';
		elseif appSequenceId =  8 then profile:='VoyagePlanner';
		elseif appSequenceId =  9 then profile:='VoyageWorker';
		elseif appSequenceId = 10 then profile:='VoyageWorker';
		elseif appSequenceId = 11 then profile:='VoyageWorker';
		elseif appSequenceId = 12 then profile:='VoyageWorker';
		endif;
		
	else  // standard definition
		port:=port+(appSequenceId div  5);  //  5 users per appserver
		if     appSequenceId = 0 then profile:='RoadOpsInquiry';
		elseif appSequenceId = 1 then profile:='GateInOut';
		elseif appSequenceId = 2 then profile:='GateInOut';
		elseif appSequenceId = 3 then profile:='GateInOut';
		elseif appSequenceId = 4 then profile:='GateInOut';
		elseif appSequenceId = 5 then profile:='RoadOpsInquiry';
		elseif appSequenceId = 6 then profile:='VoyagePlanner';
		elseif appSequenceId = 7 then profile:='VoyageWorker';
		elseif appSequenceId = 8 then profile:='VoyageWorker';
		endif;
	endif;
	//profile:='VoyageWorker';
end;</source>
    </JadeMethod>
    <JadeMethod name="setInfo_jmt2" id="e665c60d-4ea9-4ace-8536-ac2e6db14034">
        <updating/>
        <source>setInfo_jmt2() updating;
//	set profile name to be used for each Creator
//	to set profile name per copy of a Creator, modify startApp
begin
	port:=myBmkControl.bmkBasePort.Integer;  // same for all benchmark db's
	
	copies:=1;
	port:=port+(appSequenceId div  5);  //  5 users per appserver
	if     appSequenceId = 0 then profile:='RoadOpsInquiry';
	elseif appSequenceId = 1 then profile:='GateInOut';
	elseif appSequenceId = 2 then profile:='GateInOut';
	elseif appSequenceId = 3 then profile:='GateInOut';
	elseif appSequenceId = 4 then profile:='GateInOut';
	elseif appSequenceId = 5 then profile:='RoadOpsInquiry';
	elseif appSequenceId = 6 then profile:='VoyagePlanner';
	elseif appSequenceId = 7 then profile:='VoyageWorker';
	elseif appSequenceId = 8 then profile:='VoyageWorker';
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="setInfo_mtl" id="e07c3fad-c3ca-4a87-95b7-4f0db8384199">
        <updating/>
        <source>setInfo_mtl() updating;
//	set profile name to be used for each Creator
//	to set profile name per copy of a Creator, modify startApp
begin
	port:=myBmkControl.bmkBasePort.Integer;  // same for all benchmark db's
	
	copies:=1;
	if myBmkControl.owner = "cnwjhp1" then
		//port:=port+(appSequenceId div 20);  //  n users per appserver
		//port:=port+(appSequenceId mod myBmkControl.appServers);  //  round robin around all appservers
		port:=port+(appSequenceId mod 12);  //  round robin around all appservers
		schemaName:='JtdDriverSchema';
		/* this is a new config for the proposed mtl stdrun
		if      appSequenceId =  0 then profile:='RailPlanner';
		elseif appSequenceId =  1 then profile:='ShiftManager';
		elseif appSequenceId =  2 then profile:='AdminMisc';
		elseif appSequenceId =  3 then profile:='YardShipPlanner';
		elseif appSequenceId =  4 then profile:='YardShipController';
		elseif appSequenceId =  5 then profile:='EDIOperations';
		elseif appSequenceId =  6 then profile:='CorporateExec';
		elseif appSequenceId =  7 then profile:='ShipOperations';
		elseif appSequenceId &gt;= 8 and appSequenceId &lt;= 11 then profile:='ReeferReadings';
		elseif appSequenceId = 12 then profile:='RailChecker'; schemaName:='JtdMobileDriverSchema';
		elseif appSequenceId &gt;= 13 and appSequenceId &lt;= 28 then profile:='RTG'; schemaName:='JtdMobileDriverSchema';
		elseif appSequenceId &gt;= 29 and appSequenceId &lt;= 55 then profile:='IMV'; schemaName:='JtdMobileDriverSchema';
		elseif appSequenceId &gt;= 56 and appSequenceId &lt;= 60 then profile:='ShipLander'; schemaName:='JtdMobileDriverSchema';
		elseif appSequenceId = 61 then profile:='ReachStacker'; schemaName:='JtdMobileDriverSchema';
		endif;/**/
		
		// this is the config used for the JMT 7.7.2 hotfix 11 test Dec 2009 and 7.8.1 tests March 2010, also 7.8.2 tests May 2010
		if      appSequenceId =  0 then profile:='RailPlanner';
		elseif appSequenceId =  1 then profile:='ShiftManager';
		elseif appSequenceId =  2 then profile:='AdminMisc';
		elseif appSequenceId =  3 then profile:='YardShipPlanner';
		//elseif appSequenceId =  3 then profile:='RTG'; schemaName:='JtdMobileDriverSchema';
		elseif appSequenceId =  4 then profile:='YardShipPlanner';
		elseif appSequenceId =  5 then profile:='YardShipController';
		//elseif appSequenceId =  5 then profile:='ShipOperations';
		elseif appSequenceId =  6 then profile:='YardShipPlanner';
		elseif appSequenceId =  7 then profile:='YardShipPlanner';
		elseif appSequenceId =  8 then profile:='YardShipController';
		elseif appSequenceId =  9 then profile:='AdminMisc';
		elseif appSequenceId = 10 then profile:='EDIOperations';
		elseif appSequenceId = 11 then profile:='CorporateExec';
		elseif appSequenceId = 12 then profile:='YardShipPlanner';
		elseif appSequenceId = 13 then profile:='YardShipPlanner';
		elseif appSequenceId = 14 then profile:='YardShipController';
		elseif appSequenceId = 15 then profile:='CorporateExec';
		elseif appSequenceId = 16 then profile:='ShipOperations';
		elseif appSequenceId &gt;= 17 and appSequenceId &lt;= 20 then profile:='ReeferReadings';
		elseif appSequenceId &gt;= 21 and appSequenceId &lt;= 36 then profile:='RTG'; schemaName:='JtdMobileDriverSchema';
		elseif appSequenceId &gt;= 37 and appSequenceId &lt;= 61 then profile:='IMV'; schemaName:='JtdMobileDriverSchema';
		elseif appSequenceId &gt;= 62 and appSequenceId &lt;= 66 then profile:='ShipLander'; schemaName:='JtdMobileDriverSchema';
		elseif appSequenceId = 16 then profile:='ReachStacker';
		endif;/**/
		
		/*port:=port+(appSequenceId div 11);  //  n users per appserver
		if      appSequenceId div 8 =  0 then profile:='RTG'; schemaName:='JtdMobileDriverSchema';
		elseif appSequenceId div 8 =  1 then profile:='IMV'; schemaName:='JtdMobileDriverSchema';
		elseif appSequenceId = 20 then profile:='ShipOperations'; schemaName:='JtdDriverSchema';
		elseif appSequenceId = 21 then profile:='ReeferReadings'; schemaName:='JtdDriverSchema';
		elseif appSequenceId div 8 =  2 then profile:='ShipLander'; schemaName:='JtdMobileDriverSchema';
		//if      appSequenceId =  0 then profile:='RoadOpsInquiry';
