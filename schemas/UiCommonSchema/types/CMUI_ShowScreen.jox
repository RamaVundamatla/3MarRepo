    <JadeMethod name="userNotify" id="19fc1be4-a346-45e1-9fd0-da5351635b9c">
        <controlMethod name="Form::userNotify"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>userNotify(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;
// ---------------------------------------------------------------------------
// Created:     27 November 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	theRequest	: NR_ShowScreenRequest;

begin

	if eventType = NR_NodeFileRequest.NR_NodeRequestLogEntryEvent then
		//tblLogEntries.addItem(userInfo.String);
		return;
	elseif eventType = NR_NodeFileRequest.NR_NodeRequestCompleteEvent then
		if NR_ShowScreenRequest.hasInstance(userInfo.Object) then
			theRequest := userInfo.NR_ShowScreenRequest;
			self.handleRequestCompletion(theRequest);
		endif;
		return;
	endif;

end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
</GUIClass>
