    <JadeMethod name="handleBtnTwo" id="3581109c-40b2-45d6-ae0d-d4fd54b66c9a">
        <updating/>
        <source>handleBtnTwo() updating, protected;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 February 2010	cnwndl1	Initial creation	CCMS MES 1005
*/
vars

	context : Integer;
	cargoId : String;

begin
	//user clicked checks - show cargo checks
	if self.myTrackedItem = null then
		return;
	endif;
	
	// do we have any checks to perform?
	if self.myTerminal.hasNoCargoCheckItemsFor(CARGO_CHECK_CONTEXT_TRUKUNLOAD) then	//31 May 2012	NDL Par 29038
		return;
	endif;
	
	//self.myHandHeldCheckerAgent.setChecksState(self.myHandHeldCheckerAgent.GateReceipt);
	self.myMobileGenericAgent.setChecksState(self.myMobileGenericAgent.TruckUnload);//28 May 2010	NDL	Par 23698		
	self.myMobileGenericAgent.setMyNextTiToAction(self.myTrackedItem);
	self.myMobileGenericAgent.setDisplayIdOnCheckForm(true);
	if self.txtLocation.text.trimBlanks &lt;&gt; null then
		app.myMobileCargoFindAgent.setStringField1( self.txtLocation.text.trimBlanks );
	endif;
	self.gotoForm(MOB_HHGateCheckCargo, false);
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="populateTrackedItem" id="ce59c1e7-c787-4271-900c-ac0d07b5c185">
        <source>populateTrackedItem();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 February 2010	cnwndl1	Initial creation	CCMS MES 1005

*/

vars

	desc1 : String;
	desc2 : String;

begin

	if app.myMobileCargoFindAgent.stringField1 &lt;&gt; null then	// returning from search, and had already populated this
			self.txtLocation.text := app.myMobileCargoFindAgent.stringField1;
	elseif self.myMobileGenericAgent.myYardLocation &lt;&gt; null then
		self.txtLocation.text := self.myMobileGenericAgent.myYardLocation.getFullId;
	else
		self.txtLocation.text := lblLocation.caption.toUpper;
	endif;
	
	if self.myTrackedItem = null then
		self.btnTwo.enabled := false;
		self.lblCargoDesc.caption := null;	//02 Aug 2013	NDL	Par 32156
		self.txtCargoId.text := lblCargoId.caption.toUpper;
		self.txtCargoId.setFocus();
		
	else
		self.btnTwo.enabled := true;
		self.txtCargoId.text := self.myTrackedItem.id;
		//self.lblType.caption := myTrackedItem.cargoBOLTypeDescr;
		self.myTrackedItem.getShortDescriptions( desc1, desc2 );	//02 Aug 2013	NDL	Par 32156
		self.lblType.caption := desc1;	//02 Aug 2013	NDL	Par 32156
		self.lblCargoDesc.caption := desc2;	//02 Aug 2013	NDL	Par 32156
		app.myMobileCargoFindAgent.clearHistory(true);
		
	endif;
	
	
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="selectCargoItem" id="3f4828d1-6207-485f-8261-14f1a676c565">
        <updating/>
        <source>selectCargoItem( _manual : Boolean ) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 February 2010	cnwndl1	Initial creation	CCMS MES 1005

*/

vars

	cargoId : String;
	term : CM_Terminal;
	firstTi : CM_TrackedItem;
	tiArray : CM_TIArray;
	iter : Iterator;
	ti : CM_TrackedItem;
	
	cargoIdLength : Integer;	//11 Oct 2010	NDL	Par 25836
	cargoIdReversed : String;	//11 Oct 2010	NDL	Par 25836
	
begin

	self.myTrackedItem := null;
	self.lblCargoDesc.caption := null;	//02 Aug 2013	NDL	Par 32156
	
	cargoId := txtCargoId.text.trimBlanks.toUpper;
	if cargoId = lblCargoId.caption.toUpper then
		cargoId := null;
	endif;
	
	term := self.myMobileDataAgent.myTerminal;
	create tiArray transient;
	
	if cargoId &lt;&gt; null then
	
		cargoIdLength := cargoId.length;	//11 Oct 2010	NDL	Par 25836
		cargoIdReversed := cargoId.reverse;	//11 Oct 2010	NDL	Par 25836
	
		firstTi := term.allOnsiteTIsByIdCargoType.getAtKeyGeq(cargoId,null);
		//if firstTi &lt;&gt; null and firstTi.id = cargoId then
		if firstTi &lt;&gt; null and firstTi.id[1:cargoIdLength] = cargoId then	//11 Oct 2010	NDL	Par 25836
			iter := term.allOnsiteTIsByIdCargoType.createIterator;
			iter.startAtObject(firstTi);
			while iter.next( ti ) do
			//	if ti.id &lt;&gt; cargoId then
				if ti.id[1:cargoIdLength] &lt;&gt; cargoId then	//11 Oct 2010	NDL	Par 25836
					break;
				endif;
				tiArray.addExclusive(ti);
			endwhile;
			delete iter;
		endif;
		
		//11 Oct 2010	NDL	Par 25836 - Try reverse 'cargoId' as any piece of the id	
		firstTi := term.allOnsiteTIsByIdCargoTypeRev.getAtKeyGeq(cargoIdReversed,null);
		if firstTi &lt;&gt; null and firstTi.idReversed[1:cargoIdLength] = cargoIdReversed then
			iter := term.allOnsiteTIsByIdCargoTypeRev.createIterator;
			iter.startAtObject(firstTi);
			while iter.next( ti ) do
				if ti.idReversed[1:cargoIdLength] &lt;&gt; cargoIdReversed then
					break;
				endif;
				tiArray.addExclusive(ti);
			endwhile;
			delete iter;
		endif;
			
		
		firstTi := term.allNotifiedTIsByIdCargoType.getAtKeyGeq(cargoId,null);
		//if firstTi &lt;&gt; null and firstTi.id = cargoId then
		if firstTi &lt;&gt; null and firstTi.id[1:cargoIdLength] = cargoId then	//11 Oct 2010	NDL	Par 25836
			iter := term.allNotifiedTIsByIdCargoType.createIterator;
			iter.startAtObject(firstTi);
			while iter.next( ti ) do
			//	if ti.id &lt;&gt; cargoId then
				if ti.id[1:cargoIdLength] &lt;&gt; cargoId then	//11 Oct 2010	NDL	Par 25836
					break;
				endif;
				tiArray.addExclusive(ti);
			endwhile;
			delete iter;
		endif;
		
		//11 Oct 2010	NDL	Par 25836 - Try reverse 'cargoId' as any piece of the id	
		firstTi := term.allNotifiedTIsByIdCargoTypeRev.getAtKeyGeq(cargoIdReversed,null);
		if firstTi &lt;&gt; null and firstTi.idReversed[1:cargoIdLength] = cargoIdReversed then
			iter := term.allNotifiedTIsByIdCargoTypeRev.createIterator;
			iter.startAtObject(firstTi);
			while iter.next( ti ) do
				if ti.idReversed[1:cargoIdLength] &lt;&gt; cargoIdReversed then
					break;
				endif;
				tiArray.addExclusive(ti);
			endwhile;
			delete iter;
		endif;
	
	endif;
		
	if not _manual and tiArray.isEmpty then
		return;
		
	elseif tiArray.size = 1 then
		self.myTrackedItem := tiArray.first;			
		populateTrackedItem();
		return;
		
	else
		// more than one found.
		/*		30 Apr 2013	NDL	Par 31506
		if not _manual then
			self.msgBox( app.getErrorString1(Multiple_cargo_items_search, cargoId), app.getErrorString(Warning), MsgBox_OK_Only,true );
		endif;
		*/
		app.myMobileCargoFindAgent.setID( cargoId );
		app.myMobileCargoFindAgent.setMyTrackedItemToProcess(null);
		app.myMobileCargoFindAgent.setStringField1( txtLocation.text );
		app.myMobileCargoFindAgent.setDoSearchImmediate( cargoId.trimBlanks &lt;&gt; null );
		app.myMobileCargoFindAgent.setSearchSite(TI_SITE_UNDEFINED);	//11 Oct 2010	NDL	Par 25836
	
		self.myMobileGenericAgent.setMyNextTiToAction(null);
		self.gotoForm( MOB_HHCargoFind, false );
	endif;
	

epilog

	delete tiArray;
	delete iter;

end;</source>
        <Parameter name="_manual" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setupControls" id="2cc8ac73-1a44-49bc-be81-3f4a4caf47ed">
        <updating/>
        <source>setupControls() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 February 2010	cnwndl1	Initial creation

*/

vars

	
begin
	
	self.doResizeControls(true);
						 
	populateTrackedItem();
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="f3ec67ea-b9f3-4f19-8b86-3ac07d75b0d5">
        <updating/>
        <source>setupForm() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 February 2010	cnwndl1	Initial creation	CCMS MES 1005

*/

vars

begin
	self.myHandHeldCheckerAgent := app.myHandHeldCheckerAgent;

	self.setupCmdButtons( 3, app.getErrorString(Complete), app.getErrorString(Checks), app.getErrorString(Back), null, null );
	if app.myMobileCargoFindAgent = null then
		create app.myMobileCargoFindAgent transient;
	endif;
	self.myTrackedItem := app.myMobileCargoFindAgent.myTrackedItemToProcess; // populated if returning from a search.
	if self.myTrackedItem = null then
		self.myTrackedItem := self.myMobileGenericAgent.myNextTiToAction;	// returning from another screen
	endif;
	
	inheritMethod();
	
	self.setupControls();
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="translateForm" id="ef304e14-328f-4573-82bc-b9f3b361389c">
        <updating/>
        <source>translateForm(locale : CM_Locale) updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	
begin
	// Determine the locale for translations.
	inheritMethod(locale);
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0014251, locale);
	lblCargoId.translateCaption(Xlat_0014252, locale);
	lblLocation.translateCaption(Xlat_0014253, locale);
end;</source>
        <Parameter name="locale" type="CM_Locale"/>
    </JadeMethod>
    <JadeMethod name="txtCargoId_gotFocus" id="9083220f-d520-42c7-890c-91a11f376828">
        <controlMethod name="TextBox::gotFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtCargoId_gotFocus(textbox: TextBox input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 February 2010	cnwndl1	Initial creation	CCMS MES 1005

*/

vars

begin
	if self.txtCargoId.text = self.lblCargoId.caption.toUpper then
		//self.txtCargoId.text := null;
		self.txtCargoId.selStart := 0;
		self.txtCargoId.selLength := self.lblCargoId.caption.length;
	endif;
epilog

end;</source>
        <Parameter name="textbox" type="TextBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="txtCargoId_lostFocus" id="602bcf27-c70b-4051-8ed4-3d6a33d4f3db">
        <controlMethod name="TextBox::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtCargoId_lostFocus(textbox: TextBox input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 February 2010	cnwndl1	Initial creation	CCMS MES 1005

*/

vars

begin

	app.convertScannedCargoId( self.myTerminal, textbox, false, null );	//06 Jul 2016	NDL	TFS 2275
	
	if self.txtCargoId.text.trimBlanks = null then
		self.txtCargoId.text := self.lblCargoId.caption.toUpper;
	else
		//self.selectCargoItem( false );
		//24 Jun2 2013	NDL	Par 31886
		if self.myTrackedItem &lt;&gt; null and self.myTrackedItem.id &lt;&gt; self.txtCargoId.text
		or ( self.myTrackedItem = null and self.txtCargoId.text &lt;&gt; self.lblCargoId.caption.toUpper )	//01 Aug 2013	NDL	Par 32140
		then
			self.selectCargoItem( false );
		endif;
	endif;
	
	self.txtCargoId.selStart := 0;
	self.txtCargoId.selLength := 0;
	
epilog

end;</source>
        <Parameter name="textbox" type="TextBox" usage="input"/>
    </JadeMethod>
