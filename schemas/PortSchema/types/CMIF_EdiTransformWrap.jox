<Class name="CMIF_EdiTransformWrap" id="d2252b81-1446-4f24-b140-161bab56c422">
    <superclass name="CMIF_DotNetWrap"/>
    <transient/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>Wrapper class for calling the .NET EDI transformations available to JMT.  Handles all the 
conversion of JADE strings to .NET calls, and deals with any .NET calling exceptions that 
may occur.

Usage is as follows:

1.	Create transient instance - loads the default plugins (&lt;JADE binary dir&gt;/ediplugins)
2.	Optionally call CMIF_EdiTransformWrap::loadPlugins(&lt;app server file path&gt;) to add any 
	.NET EDI transform plugins to the available list
3.	Optional call(s) to CMIF_EdiTransformWrap::addHeaderData(&lt;key&gt;, &lt;value&gt;) to pass any
	required information through to the .NET code
4.	Optionally call CMIF_EdiTransformWrap::clearHeaderData to clear any previously added headers
5.	Call CMIF_EdiTransformWrapper::transformMessage with an input EDI message.  Will return true and 
	will populate _result with the transformed message if it is understood by any of the loaded
	plugins.
	
Note that in the development environment, there is a local ini file option [JMTThinClient] DotNETUsePresentation
which can be set to true to actually create the .NET component on the thin client, and therefore any file path
used would need to be a thin client relative one.
</text>
    <DbClassMap file="cmtrans"/>
    <ImplicitInverseRef name="myEdiTransform" id="19c577a5-ec36-4fac-8527-ab23dc0de84c">
        <embedded/>
        <type name="JMTEdiTransform"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <JadeMethod name="create" id="e889a98b-114f-46b1-a247-f6734ceaeada">
        <updating/>
        <source>create() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 Aug 2014	cnwkpd1	PAR #34713 - .NET EDI transform integration

*/

vars
	hadException	: Boolean;
	fileName		: String;
	iniValue		: String;
	usePresentation	: Boolean;
	
begin
	on Exception do self.handleExceptions(exception, hadException);
	
	create self.myEdiTransform transient;
	if self.myEdiTransform &lt;&gt; null then
	
		self.myEdiTransform.usePresentationClient := self.usePresentationClient;
		
		self.loadDefaultPlugins();
	endif;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="delete" id="6269b9b3-a297-42a0-9bb1-90ae6b957aae">
        <updating/>
        <source>delete() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 Aug 2014	cnwkpd1	PAR #34713 - .NET EDI transform integration

*/

vars

begin
	delete self.myEdiTransform;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="loadDefaultPlugins" id="5a1048ef-f1e1-4764-ab52-03ff82cd72b7">
        <source>loadDefaultPlugins() protected;
/*

Purpose:			Load up the plugin dlls from the default directory

Parameters:			None

Return Value:		None

Date		Who		Reason
08 Aug 2014	cnwkpd1	PAR #34713 - .NET EDI transform integration

*/

vars
	defaultDir		: String;
	
begin
	if self.myEdiTransform &lt;&gt; null then
		if self.myEdiTransform.usePresentationClient then
			defaultDir := process.getJadeInstallDirectory();
		else
			defaultDir := node.getJadeInstallDirectory();
		endif;
		
		defaultDir := defaultDir &amp; "ediplugins/";
	
		self.loadPlugins(defaultDir);
	endif;
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="loadPlugins" id="6405715a-77c0-435e-af62-05474d656658">
        <source>loadPlugins(_path : String) : Boolean;
/*

Purpose:			Load any plugin dlls from the passed in App Server relative directory

Parameters:			Directory to load plugins from

Return Value:		True if plugins load occurred, false if the directory doesn't exist or

Date			Who		Reason
11 August 2014	cnwkpd1	PAR #34713 - .NET EDI transform integration
26 January 2024	navmd1	TFS #62266 Log debug output from dlls to help work out .NET errors

*/

vars
	hadException	: Boolean;
	folder			: FileFolder;
	logMessages		: StringUtf8;
	
begin
	if self.myEdiTransform = null then
		app.writeLog(method.qualifiedName &amp; " myEdiTransform is null", LogDEBUG);	//25 Nov 2019	NDL	TFS 47053
		return false;
	endif;

	create folder transient;
	folder.usePresentationFileSystem := self.myEdiTransform.usePresentationClient;
	folder.fileName := _path;
	
	if not folder.isAvailable() then
		app.writeLog(method.qualifiedName &amp; " folder " &amp; folder.fileName &amp; " is not available", LogDEBUG);	//25 Nov 2019	NDL	TFS 47053
		return false;
	endif;
		
	on Exception do self.handleExceptions(exception, hadException);
		
	self.myEdiTransform.loadPlugins(_path.StringUtf8, logMessages);
	
	app.writeLog(method.qualifiedName &amp; Tab &amp; logMessages.String, LogTRACE);
	
	return not hadException;
	
epilog
	delete folder;
	
end;</source>
        <Parameter name="_path" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="transformMessage" id="ba9d9c9e-9123-4536-98a9-c0e11119b304">
        <source>transformMessage(_from,
				 _to,
				 _topic,
				 _body : String;
				 _result : String output) : Boolean;
/*

Purpose:			Attempt to transform the message in _body, and return the resulting
					transformation in _result (if successful)

Parameters:			Optional _from, _to, _topic are passed through to .NET as is
					_body of the message to be transformed

Return Value:		True if the transformation was done
					_result contains the result of the transformation

Date			Who		Reason
11 Aug 2014		cnwkpd1	PAR #34713 - .NET EDI transform integration
15 Jan 2016		cnwkpd1	PAR #37404 - Add CardSchema instrumentation to the .NET call for diagnostic purposes
// 27 Sep 2018	jlgrs1	TFS 40627 STWR Make EDI MultiThreaded Stage 4
26 January 2024	navmd1	TFS 62266 Log debug output from dlls to help work out .NET errors
*/

vars
	hadException	: Boolean;
	resultUtf8		: StringUtf8;
	transformed		: Boolean;
	xml				: JadeXMLDocument;
	headersElement,
	itemElement		: JadeXMLElement;
	headerData		: CMIF_DotNetHeaderData;
	hasHeaders		: Boolean;
	headersString	: String;
	logMessages		: StringUtf8;
	
begin
//	self.cnStartTransaction(method.qualifiedName);		// PAR #37404
	
	// Check creation has been successful
	if self.myEdiTransform = null then
		app.writeLog(method.qualifiedName &amp; " myEdiTransform is null", LogDEBUG);	//25 Nov 2019	NDL	TFS 47053
		return false;
	endif;
		
	on Exception do self.handleExceptions(exception, hadException);
	
	// Transform any Header data into XML that will be understood by the .NET component
	create xml transient;
	headersElement := xml.addElement("Headers");
	
	foreach headerData in self.allHeaderData do
		itemElement := headersElement.addElement("Item");
		itemElement.addElement("Key").setText(headerData.key.asXML());
		itemElement.addElement("Value").setText(headerData.value.asXML());
		hasHeaders := true;
	endforeach;
	
	headersString := xml.writeToString();
	
	app.writeLog(method.qualifiedName &amp; " parameters=" &amp;
				   "|" &amp; _from &amp; "|" &amp;
				   "|" &amp; _to &amp; "|" &amp;
				   "|" &amp; _topic &amp; "|" &amp;
				   "|" &amp; headersString &amp; "|" &amp;
				   "|" &amp; _body &amp; "|", LogDEBUG);	//25 Nov 2019	NDL	TFS 47053
	
	transformed := self.myEdiTransform.transformMessage(_from.StringUtf8,
														_to.StringUtf8,
														_topic.StringUtf8,
														headersString.StringUtf8,
														_body.StringUtf8,
														resultUtf8,
														logMessages);
														
	app.writeLog(method.qualifiedName &amp; Tab &amp; logMessages.String, LogTRACE);

	if transformed and not hadException then
		_result := resultUtf8.String;
		
		app.writeLog(method.qualifiedName &amp; " result=" &amp;
					   "|" &amp; _result &amp; "|", LogDEBUG);	//25 Nov 2019	NDL	TFS 47053
		return true;
	endif;
	
	app.writeLog( method.qualifiedName &amp; " no result", LogDEBUG);	//25 Nov 2019	NDL	TFS 47053
	
	return false;

epilog
	delete xml;
	
//	self.cnEndTransaction();		// PAR #37404
end;</source>
        <Parameter name="_from" type="String"/>
        <Parameter name="_to" type="String"/>
        <Parameter name="_topic" type="String"/>
        <Parameter name="_body" type="String"/>
        <Parameter name="_result" type="String" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
