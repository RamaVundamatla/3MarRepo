    <JadeMethod name="getAuditText" id="5a9b62ed-d5d8-449b-9d23-afac55c47532">
        <source>getAuditText(): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21 May 2014	cnwrd1	Initial creation

*/

vars
	txt, str	:String;
begin
	str := "Action " &amp; self.getFunctionDescription;
	
	txt := txt &amp; self.formatAuditText(str, self.item &amp; '+' &amp; self.value &amp; '+' &amp; self.matchText &amp; '+' &amp; self.todoTask);
	
	return txt;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
