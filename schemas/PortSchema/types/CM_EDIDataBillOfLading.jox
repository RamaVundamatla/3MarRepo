    <JadeMethod name="loadDB" id="1dcaa82c-2018-41af-85d0-2fbdef39d1d7">
        <updating/>
        <source>loadDB(_mergeCargo: Boolean; _passport: CM_Passport input) updating;
//----------------------------------------------------------------------
//  Created by cnwsh3 01 October 2008
//
//----------------------------------------------------------------------
// 21 Feb 2013	cnwrs1	Par 31143 EDI TRX not handling dbLoadErrors after no verify errors take 3
// 07/03/2013	cnwcs5	CCMS POL 2097 / par 31259 - include _foundMatch in method signatures

vars
	terminal			: CM_Terminal;
	realBOL, pxyBOL		: CM_BOLIn;
	cmifBOL				: CMIF_BOLIn;
	voyage 				: CM_Voyage;
	operatorCode 		: String;
	operatorOid			: CM_Operator;
	foundMatch			: Boolean;
begin
	if self.status = CM_EDIFile.EDI_STATUS_DBLOADED then
		return;
	endif;
	
	terminal := self.getMyTerminal();
	//Check to see if the BOL does not already exist so we can reference it.
	realBOL := terminal.getBOLInByNumber(self.billOfLading, BOLType_GeneralBillOfLading);
	
	voyage := self.getVoyageFromCode(self.voyageCode);
	//Can't go on without a voyage.
	if voyage = null then
		app.raiseCMException1(ERR_INVALID_VOYAGE, self.voyageCode, 'Voyage Code', self);
		return;
	endif;
	
	create cmifBOL transient;
	self.setBOLValues(cmifBOL);
	cmifBOL.myTerminal := terminal;
	cmifBOL.mySubTerminal := terminal.getConfig(MySubTerminalForBOLIn).CM_SubTerminal; //PAR19535 cnwsh3
	
	cmifBOL.transportMode := self.transportMode;
	cmifBOL.isEDILoad := true;
	cmifBOL.myEDIDataBillOfLading := self;
	if self.operatorCode &lt;&gt; null or 
		self.myOperator &lt;&gt; null and self.myOperator.code &lt;&gt; self.operatorCode then
		operatorCode := app.myRoot.getXlationSystemCode(self.operatorCode, XLATION_TYPE_OPERATOR, foundMatch)[1:4];	// par 31259
		operatorOid := app.myRoot.allOperators[operatorCode];
		if operatorOid &lt;&gt; null then
			cmifBOL.myOperator := operatorOid;
		endif;
	else
		cmifBOL.myOperator := self.myOperator;
	endif;

	//cnwgb1 Removed CAMIR PEN 2353 28/5/2014
    /*
	if realBOL = null then
		//app.myTrxCA.trxCreateBOLInGeneralCargo(cmifBOL, app.myPassport);
		app.myTrxCA.trxCreateEDIBOLCustomsData(cmifBOL, self, false, _passport);
	else
		if realBOL.myCustomsBOLExt = null then
			app.myTrxCA.trxCreateEDIBOLCustomsExt(realBOL, self, false, _passport); //ccms1845
		else
			app.myTrxUA.trxUpdateEDIBOLCustomsData(realBOL, self, false, _passport); //ccms1845
		endif;
	endif;
    */
epilog
	if cmifBOL &lt;&gt; null then						// 27/08/2012 cnwmh5 - Changed after issue found in unit test dump
		cmifBOL.deleteSubItemProxies();
	endif;
	delete cmifBOL;
	delete pxyBOL;
	
end;</source>
        <Parameter name="_mergeCargo" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
