    <JadeMethod name="getAllSubLocations" id="be6cedb8-459b-4ce6-88b1-b73d63ad06a9">
        <source>getAllSubLocations() : String;
/*
Purpose:			
Date		Who		Reason
13 December 2016	cnwab1	Initial creation
*/

vars

begin
	return self.allSubLocations.getEntriesAsString();

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
