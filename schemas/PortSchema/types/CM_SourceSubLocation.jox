------------------------------------------------------------------------------*/
vars

begin

	inheritMethod(_proxy);

	self.isFSC := _proxy.isFSC;		//ccms jml 1105, par 21535 Nov 2009

end;</source>
        <Parameter name="_proxy" type="CM_SourceSubLocation"/>
    </JadeMethod>
