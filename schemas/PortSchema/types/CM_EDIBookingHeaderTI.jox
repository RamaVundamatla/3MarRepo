    </JadeMethod>
    <JadeMethod name="getId" id="1ead2ea0-45d5-4dad-9814-ce5070e53bfa">
        <source>getId(_misVersioned : Boolean) : String;
//
// cnwrs1 sept 2009 CCMS Messina 1008 par21718
//
vars
	pos : Integer;
	newID : String;
begin
	if _misVersioned and 
	   self.operatorCode = "MIS" then
		pos := self.id.pos('-', 1);
		if pos = 0 then
			newID := self.id;
		else
			newID := self.id[1:pos-1];
		endif;
	else
		newID := self.id;
	endif;
//	write class.name&amp;'::'&amp;method.name&amp;' '&amp;newID;
	return newID;
end;
</source>
        <Parameter name="_misVersioned" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
