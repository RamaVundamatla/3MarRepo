    <JadeMethod name="trxUpdateGTEDamageToDo" id="38acdce7-fc36-48b9-aedf-cb12cb2c0bb2">
        <updating/>
        <source>trxUpdateGTEDamageToDo(	_realGTE : CMGTE_Receival input;	
						_proxyGTE : CMGTE_Receival;	//just a dummy one with damage on it
						_damageInterface : IF_DamageDetails;
						_toDoTaskDescToAdd : CM_ToDoTaskDesc;
						_addToDoTask : Boolean;
						_passport : CM_Passport input
						) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 May 2014	cnwndl1	Initial creation	Par 34076

*/

vars

begin

	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(false);

	beginTransaction;

	if _proxyGTE &lt;&gt; null and _realGTE &lt;&gt; null then
		_realGTE.setDamageFromProxy( _proxyGTE  );
	endif;
	
	if not _passport.noErrors then
		return;
	endif;
	
	if _realGTE &lt;&gt; null then
		if _addToDoTask and _toDoTaskDescToAdd &lt;&gt; null then
			_realGTE.addToDoTask( _toDoTaskDescToAdd, _passport );
		endif;
	endif;

epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_realGTE" type="CMGTE_Receival" usage="input"/>
        <Parameter name="_proxyGTE" type="CMGTE_Receival"/>
        <Parameter name="_damageInterface" type="IF_DamageDetails"/>
        <Parameter name="_toDoTaskDescToAdd" type="CM_ToDoTaskDesc"/>
        <Parameter name="_addToDoTask" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxUpdateGTEReleaseAndRequest" id="d9bf2f07-f8f0-4923-b22c-f6e94698f7ad">
        <updating/>
        <source>trxUpdateGTEReleaseAndRequest(	_vvr : CM_VehicleVisitRecord input; 
								_pxyGTE : CMGTE_Release input;
								_wle : CM_YardWLE input;
								_passport : CM_Passport input) updating;
/*

Date		Who		Reason
24 November 2015	cnwer1	Initial creation PAR
15 May 2025	jlier1	MTN-34221 refactoring validation so is before trx 
*/

vars
	realRequest, 
	pxyRequest : CM_DeliveryRequest;
	realGTE : CMGTE_Release;
	wleArray 		: CM_WLEArray;
	ct : CM_CargoType; 
	pxyTIs : CM_ObjectByStringDict;
begin

// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);
	app.setContinueCMExceptions(true);
	
	create pxyTIs transient;
	app.myValCA.valGateEntity(_vvr,_pxyGTE,pxyTIs, _passport);
	
	if pxyTIs &lt;&gt; null then
		pxyTIs.purge;
		delete pxyTIs;
	endif;
	
	if app.myPassport.hasErrorsIgnored then
		return;
	endif;
	
	app.setContinueCMExceptions(false);
	beginTransaction;

	app.myUtilityUA.utlUpdateInOutFlexiGateEntity(_vvr, _pxyGTE, _passport);
	
	if _passport.hasErrors then	
		return;
	endif;
	
	realGTE:= _pxyGTE.pxyGetRealObject();
	realRequest:=realGTE.myYardRequest.CM_DeliveryRequest;
		
	ct:=realRequest.getCargoType();
	
	if ct &lt;&gt; null then
		if ct.isBreakBulkMulti and  realGTE.numItems &gt; 0 then	
			app.myUtilityUA.utlUpdateYardRequestQuantity(_wle,realGTE.numItems ,_passport);
		endif;		
		if ct.isBulkMulti and realGTE.weight &gt; 0  then
			app.myUtilityUA.utlUpdateYardRequestWeight(_wle,realGTE.weight,_passport);
		endif;	
	endif;
	
	if _passport.hasErrors then
		return;
	endif;
	
	create wleArray transient;
	realRequest.allWorkListEntries.copy (wleArray);
	pxyRequest:=realGTE.updatePxyRequest();
	if pxyRequest &lt;&gt; null then
		app.myUtilityUA.utlUpdateRequestDetails(pxyRequest, wleArray, realGTE.allSourceTAs, realGTE.allSourceTAGridObjs, realGTE.getBestPick, realGTE.isFIFO, app.myPassport);
	endif;
	
epilog
	delete pxyRequest;
	delete wleArray;
	if pxyTIs &lt;&gt; null then
		pxyTIs.purge;
		delete pxyTIs;
	endif;
	self.finaliseActivityWithPassport(_passport);
	
	
end;</source>
        <Parameter name="_vvr" type="CM_VehicleVisitRecord" usage="input"/>
        <Parameter name="_pxyGTE" type="CMGTE_Release" usage="input"/>
        <Parameter name="_wle" type="CM_YardWLE" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
