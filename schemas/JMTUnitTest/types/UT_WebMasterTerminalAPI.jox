ookingId":"","cargoSubTypeId":"","cargoTypeId":"CONT","commodityId":"GENL","consigneeId":"UTCC1","consignorId":"UTCC2","contentsStatusId":"FCL","customerPriority":"","customsReferences":null,"density":0.00,"description":"","destinationPortId":"NZAKA","diameter":0.00,"dimensions":{"height":0.00,"length":0.00,"width":0.00},"dischargePortId":"NZPOE","grade":"","grammage":0.00,"hazards":null,"id":"ONSH5685303","imexStatus":"IMP","isoTypeId":"2200","loadPortId":"NZPOE","locationId":"VOY56853","operatorId":"MSL","orderNumber":"","prenotified":false,"receivalDetails":null,"reeferProperties":null,"releaseDetails":null,"remarks":"TestRemarks3","rollingLength":0.00,"secondaryBarcodeId":"","shipmentNumber":"","state":5,"stops":null,"totalQuantity":1,"trailerTypeId":"","vesselId":"VES56853","volume":0.00,"voyageId":"VOY56853","weights":{"gross":15000.0000,"max":0.00,"net":13000.0000,"tare":2000.0000}}]}';
OperatorOutput		: String = '{"allErrors":null,"allInfo":null,"allWarnings":null,"result":0,"cargoitems":[{"alternativeId":"SHIPALT3","bookingId":"","cargoSubTypeId":"","cargoTypeId":"CONT","commodityId":"GENL","consigneeId":"UTCC1","consignorId":"UTCC2","contentsStatusId":"FCL","customerPriority":"","customsReferences":null,"density":0.00,"description":"","destinationPortId":"NZAKA","diameter":0.00,"dimensions":{"height":0.00,"length":0.00,"width":0.00},"dischargePortId":"NZPOE","grade":"","grammage":0.00,"hazards":null,"id":"ONSH5685303","imexStatus":"IMP","isoTypeId":"2200","loadPortId":"NZPOE","locationId":"VOY56853","operatorId":"MSL","orderNumber":"","prenotified":false,"receivalDetails":null,"reeferProperties":null,"releaseDetails":null,"remarks":"TestRemarks3","rollingLength":0.00,"secondaryBarcodeId":"","shipmentNumber":"","state":5,"stops":null,"totalQuantity":1,"trailerTypeId":"","vesselId":"VES56853","volume":0.00,"voyageId":"VOY56853","weights":{"gross":15000.0000,"max":0.00,"net":13000.0000,"tare":2000.0000}}]}';
AlternativeIdOutput : String = '{"allErrors":null,"allInfo":null,"allWarnings":null,"result":0,"cargoitems":[{"alternativeId":"COMMONALT","bookingId":"","cargoSubTypeId":"","cargoTypeId":"CONT","commodityId":"GENL","consigneeId":"UTCC1","consignorId":"UTCC2","contentsStatusId":"FCL","customerPriority":"","customsReferences":[{"alternateId":"Test2","id":"Test2","packages":{"remaining":5,"total":10},"position":2,"remarks":"TestRemarks2","retentionPeriod":"","status":"TestStatus","typeId":"Test2"}],"density":0.00,"description":"","destinationPortId":"NZAKA","diameter":0.00,"dimensions":{"height":0.00,"length":0.00,"width":0.00},"dischargePortId":"","grade":"","grammage":0.00,"hazards":[{"acidBase":"ACID","flashpointTemperature":2,"id":"2.2","limitedQuantity":true,"marinePollutant":1,"packingGroupId":"II","undgNumber":"3320"}],"id":"ONSI5685301","imexStatus":"EXP","isoTypeId":"2200","loadPortId":"NZPOE","locationId":"BS56853","operatorId":"UTOP","orderNumber":"","prenotified":false,"receivalDetails":null,"reeferProperties":null,"releaseDetails":null,"remarks":"OnsiteCargo1","rollingLength":0.00,"secondaryBarcodeId":"","shipmentNumber":"","state":1,"stops":null,"totalQuantity":1,"trailerTypeId":"","vesselId":"VES56853","volume":6.6660,"voyageId":"VOY56853","weights":{"gross":12250.0000,"max":0.00,"net":10250.0000,"tare":2000.0000}},{"alternativeId":"COMMONALT","bookingId":"HNBOOKUNIQ","cargoSubTypeId":"ROLLS","cargoTypeId":"PAPER","commodityId":"","consigneeId":"UTCC1","consignorId":"UTCC2","contentsStatusId":"","customerPriority":"","customsReferences":null,"density":0.00,"description":"","destinationPortId":"NZAKA","diameter":1000.00,"dimensions":{"height":200.0000,"length":5000.0000,"width":150.0000},"dischargePortId":"NZAKL","grade":"FIRST","grammage":360.00,"hazards":null,"id":"PRENOTE568531","imexStatus":"EXP","isoTypeId":"","loadPortId":"NZPOE","locationId":"","operatorId":"UTOP","orderNumber":"","prenotified":true,"receivalDetails":{"carrierId":"","dateTime":"","id":"","type":"Truck"},"reeferProperties":null,"releaseDetails":null,"remarks":"PrenoteRemarks","rollingLength":12345.00,"secondaryBarcodeId":"","shipmentNumber":"","state":3,"stops":null,"totalQuantity":1,"trailerTypeId":"","vesselId":"VES56853","volume":0.00,"voyageId":"VOY56853","weights":{"gross":2200.0000,"max":0.00,"net":2000.0000,"tare":200.0000}}]}';
OnsiteOutput		: String = '{"allErrors":null,"allInfo":null,"allWarnings":null,"result":0,"cargoitems":[{"alternativeId":"ONSHALT2","bookingId":"","cargoSubTypeId":"","cargoTypeId":"CONT","commodityId":"GENL","consigneeId":"UTCC1","consignorId":"UTCC2","contentsStatusId":"FCL","customerPriority":"","customsReferences":null,"density":0.00,"description":"","destinationPortId":"NZAKA","diameter":0.00,"dimensions":{"height":0.00,"length":0.00,"width":0.00},"dischargePortId":"","grade":"","grammage":0.00,"hazards":null,"id":"ONSI5685302","imexStatus":"EXP","isoTypeId":"2200","loadPortId":"NZPOE","locationId":"BS56853","operatorId":"UTOP","orderNumber":"","prenotified":false,"receivalDetails":null,"reeferProperties":null,"releaseDetails":null,"remarks":"OnsiteCargo2","rollingLength":0.00,"secondaryBarcodeId":"","shipmentNumber":"","state":1,"stops":null,"totalQuantity":1,"trailerTypeId":"","vesselId":"VES56853","volume":6.6660,"voyageId":"VOY56853","weights":{"gross":15000.0000,"max":0.00,"net":13000.0000,"tare":2000.0000}},{"alternativeId":"ONSHALT3","bookingId":"HNBOOKUNIQ","cargoSubTypeId":"","cargoTypeId":"CONT","commodityId":"GENL","consigneeId":"UTCC1","consignorId":"UTCC2","contentsStatusId":"FCL","customerPriority":"","customsReferences":null,"density":0.00,"description":"","destinationPortId":"NZAKA","diameter":0.00,"dimensions":{"height":0.00,"length":0.00,"width":0.00},"dischargePortId":"","grade":"","grammage":0.00,"hazards":null,"id":"ONSI5685303","imexStatus":"EXP","isoTypeId":"2200","loadPortId":"NZPOE","locationId":"BS56853","operatorId":"UTOP","orderNumber":"","prenotified":false,"receivalDetails":null,"reeferProperties":null,"releaseDetails":null,"remarks":"OnsiteCargo3","rollingLength":0.00,"secondaryBarcodeId":"","shipmentNumber":"","state":1,"stops":null,"totalQuantity":1,"trailerTypeId":"","vesselId":"VES56853","volume":6.6660,"voyageId":"VOY56853","weights":{"gross":16000.0000,"max":0.00,"net":14000.0000,"tare":2000.0000}}]}';
vars
	cargoType		: CM_CargoType;
	cargoSubType	: CM_Product;
	vessel			: CM_Vessel;
	voyage			: CM_Voyage;
	bs				: CM_TerminalArea;
	operatorCode	: String;
	operator		: CM_Operator;
	prenote			: CM_TrackedItem;
	onsite1, onsite2, onsite3, onsite4 : CM_TrackedItem;
	onship1, onship2, onship3 : CM_TrackedItem;
	passport		: CM_Passport;
	hazard 			: CM_TIHazard;
	incomingJsonString,
	loginJson,terminalCode			: String;
	expectFailure		: Boolean;
	root				: CM_Root;
	terminal 			: CM_Terminal;
	response			: String;
	qp_Config 			: String;
	sent_1,sent_2,sent_3,
	sent_4,sent_5,sent_6,
	exp_1,exp_2,exp_3,exp_4,
	exp_5,exp_6			: String;
	
begin
	root := app.myRoot;
	passport := app.myPassport;
	terminalCode := self.getProfileSetting(UT_Profile.P_TERMINAL).asString;
	self.assertNotNullMsg(terminalCode, "Terminal Code not set in Unit Test Profile");
	terminal := root.allTerminals[terminalCode];
	operatorCode := self.getProfileSetting(UT_Profile.P_OPERATOR).asString;
	operator := root.allOperators[operatorCode];
	self.assertNotNullMsg(operator, "Operator for '" &amp; operatorCode &amp; "' not found");
	
	cargoType := root.getCargoTypeFromAbbrevOrDescr("PAPER");
	self.assertNotNullMsg(cargoType, "Cargo Type PAPER not found");
	cargoSubType := cargoType.allProducts[null, "ROLLS"];
	self.assertNotNullMsg(cargoSubType, "Cargo Subtype ROLLS not found");
	
	// Set up - delete vessel, voyage, terminal area, prenotes, onsite cargo, onship cargo
	self.deleteVoyage(ThisVoyage);
	voyage := self.getVoyage(ThisVoyage);
	self.assertTrueMsg(voyage = null, "Voyage " &amp; ThisVoyage &amp; " not deleted");
	self.deleteVessel(ThisVessel);
	vessel := self.getVessel(ThisVessel);
	self.assertTrueMsg(vessel = null, "Vessel " &amp; ThisVessel &amp; " not deleted");
	self.deleteTerminalArea(ThisBlockStack);
	bs := self.getTerminalArea(ThisBlockStack);
	self.assertTrueMsg(bs = null, "Terminal Area " &amp; ThisBlockStack &amp; " not deleted");
	self.deleteCargo(Prenote1, "CONT");
	self.deleteCargo(OnSite1, "CONT");
	self.deleteCargo(OnSite2, "CONT");
	self.deleteCargo(OnSite3, "CONT");
	self.deleteCargo(OnShip1, "CONT");
	self.deleteCargo(OnShip2, "CONT");
	self.deleteCargo(OnShip3, "CONT");
	
	// Create Vessel / Voyage
	self.createVesselVoyage(ThisVoyage, ThisVessel, operator);
	voyage := self.getVoyage(ThisVoyage);
	self.assertNotNullMsg(voyage, "Voyage " &amp; ThisVoyage &amp; " not found");
	
	// Create Block Stack
	bs := self.addBlockStack(ThisBlockStack, 0, null);
	self.assertNotNullMsg(bs, "Block Stack '" &amp; ThisBlockStack &amp; "' not created");
	
	// Create on ship cargo
	onship1 := self.addContainerOnShip(OnShip1, operator, "2200", "GENL", null, voyage, "NZPOE", ThisVoyage);
	onship2 := self.addContainerOnShip(OnShip2, operator, "2200", "GENL", null, voyage, "NZPOE", ThisVoyage);
	onship3 := self.addContainerOnShip(OnShip3, operator, "2200", "GENL", null, voyage, "NZPOE", ThisVoyage);
	self.assertTrueMsg(voyage.allOnshipTIsByIdCargoType.size = 3, "Voyage has wrong number of on ship TIs");
	
	beginTransaction;
	onship1.setPropertyValue(CM_TrackedItem::consignee.name, "UTCC1");
	onship1.setPropertyValue(CM_TrackedItem::consignor.name, "UTCC2");
	onship1.setPropertyValue(CM_TrackedItem::remarks.name, "Test Remarks 1");
	onship1.setAlternativeId("SHIPALT1");
	onship1.setDestinationPort("NZAKA");
	onship1.setWeightCargo(11000.0000);
	onship1.setWeightTare(2000.0000);
	onship1.setTotalWeightWithoutTrans(13000.0000);
	
	onship2.setPropertyValue(CM_TrackedItem::consignee.name, "UTCC1");
	onship2.setPropertyValue(CM_TrackedItem::consignor.name, "UTCC2");
	onship2.setPropertyValue(CM_TrackedItem::remarks.name, "Test Remarks 2");
	onship2.setAlternativeId("SHIPALT2");
	onship2.setDestinationPort("NZAKA");
	onship2.setWeightCargo(12000.0000);
	onship2.setWeightTare(2000.0000);
	onship2.setTotalWeightWithoutTrans(14000.0000);
	onship2.changeOperator(root.allOperators["MSC"], app.myPassport);
	
	onship3.setPropertyValue(CM_TrackedItem::consignee.name, "UTCC1");
	onship3.setPropertyValue(CM_TrackedItem::consignor.name, "UTCC2");
	onship3.setPropertyValue(CM_TrackedItem::remarks.name, "Test Remarks 3");
	onship3.setAlternativeId("SHIPALT3");
	onship3.setDestinationPort("NZAKA");
	onship3.setWeightCargo(13000.0000);
	onship3.setWeightTare(2000.0000);
	onship3.setTotalWeightWithoutTrans(15000.0000);
	onship3.changeOperator(root.allOperators["MSL"], app.myPassport);
	commitTransaction;
	
	// Create on site cargo
	onsite1 := self.addContainerAtLocation(OnSite1, operator, "2200", "GENL", TI_IMEX_STATUS_EXPORT, bs);
	onsite2 := self.addContainerAtLocation(OnSite2, operator, "2200", "GENL", TI_IMEX_STATUS_EXPORT, bs);
	onsite3 := self.addContainerAtLocation(OnSite3, operator, "2200", "GENL", TI_IMEX_STATUS_EXPORT, bs);
	onsite4 := self.addContainerAtLocation(OnSite4, operator, "2200", "GENL", TI_IMEX_STATUS_EXPORT, bs);
	self.addTIHazard(onsite1, "2.2", true);
	self.assertEqualMsg(onsite1.allTIHazards.size, 1, "No hazard for " &amp; onsite1.id);
	self.addTICustomsReference(onsite1, "Test2", "Test2", "Test2", "Test Remarks2", "Test Status", 2, 10, 5);
	self.assertNotNullMsg(onsite1.allCustomsReferences, "No Customs Reference for " &amp; onsite1.id);
	self.assertEqualMsg(onsite1.allCustomsReferences.size, 1, "Too many Customs References for " &amp; onsite1.id);
	beginTransaction;
	onsite1.setMyVoyage(voyage, passport);
	onsite1.setPropertyValue(CM_TrackedItem::consignee.name, "UTCC1");
	onsite1.setPropertyValue(CM_TrackedItem::consignor.name, "UTCC2");
	onsite1.setPropertyValue(CM_TrackedItem::remarks.name, "Onsite Cargo 1");
	onsite1.setAlternativeId("COMMONALT");
	onsite1.setDestinationPort("NZAKA");
	onsite1.setWeightCargo(10250.0000);
	onsite1.setWeightTare(2000.0000);
	onsite1.setTotalWeightWithoutTrans(12250.0000);
	
	hazard := onsite1.allTIHazards.first.CM_TIHazard;
	hazard.setPropertyValue(CM_TIHazard::acidsBases.name, "ACID");
	hazard.setPropertyValue(CM_TIHazard::flashpointTemperature.name, 2.Real);
	hazard.setPropertyValue(CM_TIHazard::isMarinePollutant.name, 1);
	hazard.setPropertyValue(CM_TIHazard::packingGroup.name, "II");
	hazard.addUNCode("3320");
	
	onsite2.setMyVoyage(voyage, passport);
	onsite2.setPropertyValue(CM_TrackedItem::consignee.name, "UTCC1");
	onsite2.setPropertyValue(CM_TrackedItem::consignor.name, "UTCC2");
	onsite2.setPropertyValue(CM_TrackedItem::remarks.name, "Onsite Cargo 2");
	onsite2.setAlternativeId("ONSHALT2");
	onsite2.setDestinationPort("NZAKA");
	onsite2.setWeightCargo(13000.0000);
	onsite2.setWeightTare(2000.0000);
	onsite2.setTotalWeightWithoutTrans(15000.0000);
	
	onsite3.setMyVoyage(voyage, passport);
	onsite3.setPropertyValue(CM_TrackedItem::consignee.name, "UTCC1");
	onsite3.setPropertyValue(CM_TrackedItem::consignor.name, "UTCC2");
	onsite3.setPropertyValue(CM_TrackedItem::remarks.name, "Onsite Cargo 3");
	onsite3.setAlternativeId("ONSHALT3");
	onsite3.setDestinationPort("NZAKA");
	onsite3.setWeightCargo(14000.0000);
	onsite3.setWeightTare(2000.0000);
	onsite3.setTotalWeightWithoutTrans(16000.0000);
	onsite3.setBookingReference("HNBOOKUNIQ");
	
	onsite4.setMyVoyage(voyage, passport);
	onsite4.setPropertyValue(CM_TrackedItem::consignee.name, "UTCC1");
	onsite4.setPropertyValue(CM_TrackedItem::consignor.name, "UTCC2");
	onsite4.setPropertyValue(CM_TrackedItem::remarks.name, "Onsite Cargo 4");
	onsite4.setAlternativeId("ONSHALT4");
	onsite4.setDestinationPort("NZAKA");
	onsite4.setWeightCargo(15000.0000);
	onsite4.setWeightTare(2000.0000);
	onsite4.setTotalWeightWithoutTrans(17000.0000);
	commitTransaction;
	self.assertEqualMsg(voyage.allOnsiteTIsByIdCargoType.size, 4, "Voyage has wrong number of onsite cargo items");
	
	// Create Prenote
	self.opts.purge;
	self.opts.addAssociation("CargoType", cargoType.id);
	self.opts.addAssociation("cargoSubType", cargoSubType);
	prenote := self.addPrenoted(Prenote1);
	self.assertNotNullMsg(prenote, "Prenote " &amp; Prenote1 &amp; " not created");
	beginTransaction;
	prenote.setMyVoyage(voyage, passport);
	prenote.setPropertyValue(CM_TrackedItem::consignee.name, "UTCC1");
	prenote.setPropertyValue(CM_TrackedItem::consignor.name, "UTCC2");
	prenote.setPropertyValue(CM_TrackedItem::remarks.name, "Prenote Remarks");
	prenote.setAlternativeId("COMMONALT");
	prenote.setDestinationPort("NZAKA");
	prenote.setWeightCargo(2000.0000);
	prenote.setWeightTare(200.0000);
	prenote.setTotalWeightWithoutTrans(2200.0000);
	prenote.CM_BreakBulkGeneric.setGrammage(360.0000);
	prenote.CM_BreakBulkGeneric.setGrade("FIRST");
	prenote.CM_BreakBulkGeneric.setDiameter(1000.000);
	prenote.CM_BreakBulkGeneric.setRollingLength(12345.0000);
	prenote.setHeight(200.000);
	prenote.setWidth(150.000);
	prenote.setLength(5000.000);
	prenote.setBookingReference("HNBOOKUNIQ");
	commitTransaction;
	self.assertEqualMsg(voyage.allNotifiedTIsByIdCargoType.size, 1, "Voyage has wrong number of prenotes");
	
	loginJson := '{
   "userId": "' &amp; UT_WebFramework.USERCODE &amp; '",
   "password": "' &amp; UT_WebFramework.PASSWORD &amp; '",
    "applicationId" : "internalAPI",
    "scope" : {
        "complexId" : "Navis",
		"facilityId": "' &amp; terminalCode &amp; '",
        "operatorId" : "Navis",
        "yardId" : "MTN"
    }}';
	
	//Prenote Enquiry
	incomingJsonString := PrenoteJsonString;
	expectFailure := false;
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPostFindCargo.name, loginJson, incomingJsonString,response,expectFailure,qp_Config);
	sent_1 := response.replace(Cr,'').replace(Lf,'').replace(CrLf,'').replace(' ','');
	sent_1  := JadeRegex@replaceAll(sent_1 , "", DateTimeRegex, false);
	exp_1 := PrenoteOutput.replace(Cr,'').replace(Lf,'').replace(CrLf,'').replace(' ','');
	exp_1 := JadeRegex@replaceAll(exp_1, "", DateTimeRegex, false);
	self.assertEqualMsg(sent_1,exp_1,"We expect the PrenoteJson response to match the expected json string");
	
	//Onship Cargo Enquiry
	incomingJsonString := OnshipCargoJsonString;
	expectFailure := false;
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPostFindCargo.name, loginJson, incomingJsonString,response,expectFailure,qp_Config);
	sent_2 := response.replace(Cr,'').replace(Lf,'').replace(CrLf,'').replace(' ','');
	sent_2  := JadeRegex@replaceAll(sent_2 , "", DateTimeRegex, true);
	sent_2 :=JadeRegex@replaceAll(sent_2, '"stops":null', StopsRegex, true);
	exp_2 := OnshipOutput.replace(Cr,'').replace(Lf,'').replace(CrLf,'').replace(' ','');
	exp_2 := JadeRegex@replaceAll(exp_2, "", DateTimeRegex, true);
	self.assertEqualMsg(sent_2,exp_2,"We expect the OnShipCargoJson response to match the expected json string");
	
	//Booking Cargo Enquiry
	incomingJsonString := BookingJsonString;
	expectFailure := false;
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPostFindCargo.name, loginJson, incomingJsonString,response,expectFailure,qp_Config);
	sent_3 := response.replace(Cr,'').replace(Lf,'').replace(CrLf,'').replace(' ','');
	sent_3  := JadeRegex@replaceAll(sent_3 , "", DateTimeRegex, true);
	sent_3 := JadeRegex@replaceAll(sent_3, '"stops":null', StopsRegex, true);
	exp_3 := BookingOutput.replace(Cr,'').replace(Lf,'').replace(CrLf,'').replace(' ','');
	exp_3 := JadeRegex@replaceAll(exp_3, "", DateTimeRegex, true);
	self.assertEqualMsg(sent_3,exp_3,"We expect the BookingJson response to match the expected json string");
	
	//OperatorId Cargo Enquiry
	incomingJsonString := OperatorJsonString;
	expectFailure := false;
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPostFindCargo.name, loginJson, incomingJsonString,response,expectFailure,qp_Config);
	sent_4 := response.replace(Cr,'').replace(Lf,'').replace(CrLf,'').replace(' ','');
	sent_4  := JadeRegex@replaceAll(sent_4 , "", DateTimeRegex, true);
	sent_4 := JadeRegex@replaceAll(sent_4, '"stops":null', StopsRegex, true);
	exp_4 := OperatorOutput.replace(Cr,'').replace(Lf,'').replace(CrLf,'').replace(' ','');
	exp_4 := JadeRegex@replaceAll(exp_4, "", DateTimeRegex, true);
	self.assertEqualMsg(sent_4,exp_4,"We expect the OperatorJson response to match the expected json string");
	
	//AlternativeId Cargo Enquiry
	incomingJsonString := AlternativeIdJsonString;
	expectFailure := false;
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPostFindCargo.name, loginJson, incomingJsonString,response,expectFailure,qp_Config);
	sent_5 := response.replace(Cr,'').replace(Lf,'').replace(CrLf,'').replace(' ','');
	sent_5  := JadeRegex@replaceAll(sent_5 , "", DateTimeRegex, true);
	sent_5  := JadeRegex@replaceAll(sent_5 , "", RetentionPeriodRegex, true);
	sent_5 := JadeRegex@replaceAll(sent_5, '"stops":null', StopsRegex, true);
	exp_5 := AlternativeIdOutput.replace(Cr,'').replace(Lf,'').replace(CrLf,'').replace(' ','');
	exp_5 := JadeRegex@replaceAll(exp_5, "", DateTimeRegex, true);
	exp_5 := JadeRegex@replaceAll(exp_5, "", RetentionPeriodRegex, true);
	self.assertEqualMsg(sent_5,exp_5,"We expect the AlternativeIdJson response to match the expected json string");
	
	//MaxReturnItems and StartFrom parameters
	qp_Config := "?MasterTerminalAPI=true&amp;maxReturnItems=2&amp;startFrom=2";
	incomingJsonString := OnsiteJsonString;
	expectFailure := false;
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPostFindCargo.name, loginJson, incomingJsonString,response,expectFailure,qp_Config);
	sent_6 := response.replace(Cr,'').replace(Lf,'').replace(CrLf,'').replace(' ','');
	sent_6  := JadeRegex@replaceAll(sent_6 , "", DateTimeRegex, true);
	sent_6 := JadeRegex@replaceAll(sent_6, '"stops":null', StopsRegex, true);
	exp_6 := OnsiteOutput.replace(Cr,'').replace(Lf,'').replace(CrLf,'').replace(' ','');
	exp_6 := JadeRegex@replaceAll(exp_6, "", DateTimeRegex, true);
	self.assertEqualMsg(sent_6,exp_6,"We expect the OnsiteCargoJson response to match the expected json string");
	
	
epilog
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tPostInvoiceAndLinesCN" id="854b8d4d-965b-4100-9ec6-18b147765532">
        <source>tPostInvoiceAndLinesCN();
/*

Purpose:

	Unit test to test the correct functioning of the Put method putInvoiceAndLines on the MasterTerminalAPI with an credit note input

Parameters:		

	None

Return Value:

	None
	
Date			Who		Reason
13 June 2023	navcs2	ChangeRequest 56901: [58447]: TAS Invoicing Invoice Endpoint - JADE changes

*/
constants
	InvoiceId1			: String = "INV342523";
	InvoiceExternalRef2	: String = "INV342522";
	DebtorId		 	: String = "1AAA";
	CurrencyCode    	: String = "EUR";
	DocType				: String = "INV";
	DocDate				: String = "2022-10-14T00:00:00";
	DueDate				: String = "2022-10-14T00:00:00";
	NarrationInv		: String = "2206001496-2206001497-2206001498-2206001499-2206001500-2207000009-2207000011-2207000012  -2207000042-2207000044-2207000046-2207000047";
	ServicePeriod1		: String = "2022-10-14T00:00:00";
	ServicePeriod2		: String = "2022-10-14T00:00:00";
	LineExternalRef1	: String = "TP_202210_001";
	LineExternalRef2	: String = "TP_202210_002";
	LineExternalRef3	: String = "TP_202210_003";
	YourRef1			: String = "TestRef1";
	YourRef2			: String = "TestRef2";
	Amount1				: String = "625,00";
	Amount2				: String = "111,34";
	TaxCode				: String = "GST";
	NarrationLine1		: String = "Berthage 6";
	NarrationLine2		: String = "Berthage 6";
	ServiceExternalRef1	: String = "7001";
	ServiceExternalRef2	: String = "7001";
	Uom					: String = "FT";
	Rate1				: Decimal = 1.000000;
	Rate2				: Decimal = 1.000000;
	Qty1				: Decimal = 18.9;
	Qty2				: Decimal = 23.1;
	ServiceId			: String  = "7001";
	
	CorrectFormatJsonRequest1 : String = 
	'{
	  "businessUnitId": "",
	  "typeId": "",
	  "debtor": {
		"id": "'&amp;DebtorId&amp;'",
		"addressId": "1",
		"alternateAddressId": "20"
	  },
	  "currencyId": "'&amp;CurrencyCode&amp;'",
	  "creditNote": false,
	  "dueDate": "'&amp;DueDate&amp;'",
	  "externalId": "'&amp;InvoiceId1&amp;'",
	  "externalReference2": "'&amp;InvoiceExternalRef2&amp;'",
	  "narration": "'&amp;NarrationInv&amp;'",
	  "lines": [
		{
		  "typeId": "APIService",
		  "service": {
			"id": "'&amp;ServiceId&amp;'",
			"externalReference1": "'&amp;ServiceExternalRef1&amp;'"
		  },
		  "charge": {
			"rate": "'&amp;Rate1.String&amp;'",
			"amount": "'&amp;Amount1.String&amp;'",
			"quantity": "'&amp;Qty1.String&amp;'",
		  },
		  "date": "'&amp;DueDate&amp;'",
		  "narration": "'&amp;NarrationLine1&amp;'",
		  "taxId": "70",
		  "uomId": "'&amp;Uom&amp;'",
		  "externalReference1": "'&amp;LineExternalRef1&amp;'",
		  "externalReference2": "'&amp;LineExternalRef2&amp;'",
		  "externalReference3": "'&amp;LineExternalRef3&amp;'"
		},
		{
		  "typeId": "APIService",
		  "service": {
			"id": "'&amp;ServiceId&amp;'",
			"externalReference1": "'&amp;ServiceExternalRef2&amp;'"
		  },
		  "charge": {
			"rate": "'&amp;Rate2.String&amp;'",
			"amount": "'&amp;Amount1.String&amp;'",
			"quantity": "'&amp;Qty2.String&amp;'",
		  },
		  "date": "'&amp;DueDate&amp;'",
		  "narration": "'&amp;NarrationLine2&amp;'",
		  "taxId": "70",
		  "uomId": "'&amp;Uom&amp;'",
		  "externalReference1": "'&amp;LineExternalRef1&amp;'",
		  "externalReference2": "'&amp;LineExternalRef2&amp;'",
		  "externalReference3": "'&amp;LineExternalRef3&amp;'"
		}
	  ]
	}';
	
	CorrectFormatJsonRequest2 : String = 
	'{
	  "businessUnitId": "",
	  "typeId": "",
	  "debtor": {
		"id": "'&amp;DebtorId&amp;'",
		"addressId": "1",
		"alternateAddressId": "20"
	  },
	  "currencyId": "'&amp;CurrencyCode&amp;'",
	  "creditNote": false,
	  "dueDate": "'&amp;DueDate&amp;'",
	  "externalId": "'&amp;InvoiceExternalRef2&amp;'",
	  "externalReference2": "'&amp;InvoiceId1&amp;'",
	  "narration": "'&amp;NarrationInv&amp;'",
	  "lines": [
		{
		  "typeId": "APIService",
		  "service": {
			"id": "'&amp;ServiceId&amp;'",
			"externalReference1": "'&amp;ServiceExternalRef1&amp;'"
		  },
		  "charge": {
			"rate": "'&amp;Rate1.String&amp;'",
			"amount": "'&amp;Amount1.String&amp;'",
			"quantity": "'&amp;Qty1.String&amp;'",
		  },
		  "date": "'&amp;DueDate&amp;'",
		  "narration": "'&amp;NarrationLine1&amp;'",
		  "taxId": "70",
		  "uomId": "'&amp;Uom&amp;'",
		  "externalReference1": "'&amp;LineExternalRef1&amp;'",
		  "externalReference2": "'&amp;LineExternalRef2&amp;'",
		  "externalReference3": "'&amp;LineExternalRef3&amp;'"
		},
		{
		  "typeId": "APIService",
		  "service": {
			"id": "'&amp;ServiceId&amp;'",
			"externalReference1": "'&amp;ServiceExternalRef2&amp;'"
		  },
		  "charge": {
			"rate": "'&amp;Rate2.String&amp;'",
			"amount": "'&amp;Amount1.String&amp;'",
			"quantity": "'&amp;Qty2.String&amp;'",
		  },
		  "date": "'&amp;DueDate&amp;'",
		  "narration": "'&amp;NarrationLine2&amp;'",
		  "taxId": "70",
		  "uomId": "'&amp;Uom&amp;'",
		  "externalReference1": "'&amp;LineExternalRef1&amp;'",
		  "externalReference2": "'&amp;LineExternalRef2&amp;'",
		  "externalReference3": "'&amp;LineExternalRef3&amp;'"
		}
	  ]
	}';


vars
	incomingJsonString,
	terminalCode,
	params,
	loginJson				: String;
	root					: CM_Root;
	terminal				: CM_Terminal;
	expectError				: Boolean;
	invoiceOld,
	newInvoice,
	newInvoice2				: CM_Invoice;
	invoiceLineOld,
	invoiceLine1,
	invoiceLine2			: CM_InvoiceLine;
	found					: Boolean;
	invType					: CM_InvoiceDesc;
	invLineType				: CM_InvoiceLineDesc;
	service					: CM_Service;
	serviceSet				: CM_ServiceByNameDict;
	calcType				: CM_CalculationType;
begin

	
	/*
	** Setup and cleanup Section
	*/
	
	// Get the app root
	root := app.myRoot;
	
	//Get terminal
	terminalCode := self.getProfileSetting(UT_Profile.P_TERMINAL).asString;
	self.assertNotNullMsg(terminalCode, "Terminal Code not set in Unit Test Profile");
	terminal := root.allTerminals[terminalCode];
	
	incomingJsonString := CorrectFormatJsonRequest1;
	
	foreach invType in CM_InvoiceDesc.instances discreteLock do 
		if invType.description = "UT_CNTypeApi" then
			found := true;
			break;
		endif;
	endforeach;
	if not found then
		invType := self.createCreditNoteApiType("UT_CNTypeApi", InvoiceTypeStorage);
	endif;
	
	foreach invType in CM_InvoiceDesc.instances discreteLock do 
		if invType.description = "UT_InvoiceTypeApi" then
			found := true;
			break;
		endif;
	endforeach;
	if not found then
		invType := self.createCreditNoteApiType("UT_InvoiceTypeApi", InvoiceTypeStorage);
	endif;
	
	self.deleteInvoiceLineType("Unit Test Credit Note", FORCED_ERASE);
	self.deleteInvoiceService(ServiceExternalRef1,0);
	
	calcType := app.myRoot.allCalculationTypesByCode["CCT00"];	
	service := self.createInvoiceService(ServiceExternalRef1, "null", calcType, null);
	create serviceSet transient;
	serviceSet.add(service);
	
	invLineType := self.getInvoiceLineType("Unit Test Credit Note");
	
	if invLineType = null then
		invLineType := self.createInvoiceLineType("Unit Test Credit Note", calcType, invType, serviceSet, "Unit Test Credit Note");
	endif;
	
	// Delete the Invoice and Lines as they cannot be duplicate
	invoiceOld := terminal.getDefaultCompanyBank.allInvoicesByExternalCode[InvoiceId1];
	if invoiceOld &lt;&gt; null then
		foreach invoiceLineOld in invoiceOld.invoiceLines do
			self.deleteInvoiceLine(invoiceLineOld);
		endforeach;
		self.deleteInvoice(invoiceOld);
	endif;
	
	// Delete the Invoice and Lines as they cannot be duplicate
	invoiceOld := terminal.getDefaultCompanyBank.allInvoicesByExternalCode[InvoiceExternalRef2];
	if invoiceOld &lt;&gt; null then
		foreach invoiceLineOld in invoiceOld.invoiceLines do
			self.deleteInvoiceLine(invoiceLineOld);
		endforeach;
		self.deleteInvoice(invoiceOld);
	endif;
	
	// Unit Test to update Invoice and Invoice Lines via a Put Request
	
	// Set the login Json so we can authenticate
	loginJson := '{
   "userId": "' &amp; UT_WebFramework.USERCODE &amp; '",
   "password": "' &amp; UT_WebFramework.PASSWORD &amp; '",
    "applicationId" : "internalAPI",
    "scope" : {
        "complexId" : "Master Terminal",
		"facilityId": "' &amp; terminalCode &amp; '",
        "operatorId" : "Navis",
        "yardId" : "MTN"
    }}';
	
	params		:= "InvoiceAndLines/?MasterTerminalAPI";
	expectError	:= false;
	
	// Make the WebServiceCall
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPutInvoiceAndLines.name, loginJson, incomingJsonString, params, expectError);
	
	
	/*
	** Assert Section for the new invoice that will be used as the linked invoice on the credit note
	*/
	
	
	// Check that the correct invoice has been created
	newInvoice  := terminal.getDefaultCompanyBank.allInvoicesByExternalCode[InvoiceId1];
	
	self.assertTrueMsg(newInvoice &lt;&gt; null, "External Ref1 (" &amp; InvoiceId1 &amp; ") has not been created/is null");
	
	
	// Assert Invoice fields
	self.assertTrueMsg(newInvoice.debtor.code = DebtorId, "Field: " &amp; CM_Invoice::debtor.name &amp; " | Expected: '" &amp; DebtorId &amp; "' | Actual: '" &amp; newInvoice.debtor.code &amp; "'");
	self.assertTrueMsg(newInvoice.category = 0, "Field: " &amp; CM_Invoice::category.name &amp; " | Expected: '" &amp; DocType &amp; "' | Actual: '" &amp; newInvoice.category.String &amp; "'");
	self.assertTrueMsg(newInvoice.exportCurrencyCode = InvoiceId1, "Field: " &amp; CM_Invoice::exportCurrencyCode.name &amp; " | Expected: '" &amp; InvoiceId1 &amp; "' | Actual: '" &amp; newInvoice.exportCurrencyCode &amp; "'");
	
	
	/*
	** Assert Section for the first new invoice line
	*/
	
	
	// Get and check the first invoice line fields are correct
	invoiceLine1 := newInvoice.invoiceLines.first;
	self.assertTrueMsg(invoiceLine1.debtor.code = DebtorId, "Field: " &amp; CM_InvoiceLine::debtor.name &amp; " | Expected: '" &amp; DebtorId &amp; "' | Actual: '" &amp; invoiceLine1.debtor.code &amp; "'");
	self.assertTrueMsg(invoiceLine1.externalRef1 = LineExternalRef1, "Field: " &amp; CM_InvoiceLine::externalRef1.name &amp; " | Expected: '" &amp; LineExternalRef1 &amp; "' | Actual: '" &amp; invoiceLine1.externalRef1 &amp; "'");
	self.assertTrueMsg(invoiceLine1.externalRef2 = LineExternalRef2, "Field: " &amp; CM_InvoiceLine::externalRef2.name &amp; " | Expected: '" &amp; LineExternalRef2 &amp; "' | Actual: '" &amp; invoiceLine1.externalRef2 &amp; "'");
	self.assertTrueMsg(invoiceLine1.externalRef3 = LineExternalRef3, "Field: " &amp; CM_InvoiceLine::externalRef3.name &amp; " | Expected: '" &amp; LineExternalRef3 &amp; "' | Actual: '" &amp; invoiceLine1.externalRef3 &amp; "'");
	self.assertTrueMsg(invoiceLine1.remarks = NarrationLine1, "Field: " &amp; CM_InvoiceLine::remarks.name &amp; " | Expected: '" &amp; NarrationLine1 &amp; "' | Actual: '" &amp; invoiceLine1.remarks &amp; "'");
	self.assertTrueMsg(invoiceLine1.quantity = Qty1.Real, "Field: " &amp; CM_InvoiceLine::quantity.name &amp; " | Expected: '" &amp; Qty1.String &amp; "' | Actual: '" &amp; invoiceLine1.quantity.String &amp; "'");
	self.assertTrueMsg(invoiceLine1.uomCode = Uom, "Field: " &amp; CM_InvoiceLine::uomCode.name &amp; " | Expected: '" &amp; Uom &amp; "' | Actual: '" &amp; invoiceLine1.uomCode &amp; "'");
	
	
	
	/*
	** Assert Section for the second new invoice line
	*/
	
	
	// Get and ch/eck the second invoice line fields are correct
	invoiceLine2 := newInvoice.invoiceLines.last;
	self.assertTrueMsg(invoiceLine2.debtor.code = DebtorId, "Field: " &amp; CM_InvoiceLine::debtor.name &amp; " | Expected: '" &amp; DebtorId &amp; "' | Actual: '" &amp; invoiceLine2.debtor.code &amp; "'");
	self.assertTrueMsg(invoiceLine2.externalRef1 = LineExternalRef1, "Field: " &amp; CM_InvoiceLine::externalRef1.name &amp; " | Expected: '" &amp; LineExternalRef1 &amp; "' | Actual: '" &amp; invoiceLine2.externalRef1 &amp; "'");
	self.assertTrueMsg(invoiceLine2.externalRef2 = LineExternalRef2, "Field: " &amp; CM_InvoiceLine::externalRef2.name &amp; " | Expected: '" &amp; LineExternalRef2 &amp; "' | Actual: '" &amp; invoiceLine2.externalRef2 &amp; "'");
	self.assertTrueMsg(invoiceLine2.externalRef3 = LineExternalRef3, "Field: " &amp; CM_InvoiceLine::externalRef3.name &amp; " | Expected: '" &amp; LineExternalRef3 &amp; "' | Actual: '" &amp; invoiceLine2.externalRef3 &amp; "'");
	self.assertTrueMsg(invoiceLine2.remarks = NarrationLine2, "Field: " &amp; CM_InvoiceLine::remarks.name &amp; " | Expected: '" &amp; NarrationLine2 &amp; "' | Actual: '" &amp; invoiceLine2.remarks &amp; "'");
	self.assertTrueMsg(invoiceLine2.quantity = Qty2.Real, "Field: " &amp; CM_InvoiceLine::quantity.name &amp; " | Expected: '" &amp; Qty2.String &amp; "' | Actual: '" &amp; invoiceLine2.quantity.String &amp; "'");
	self.assertTrueMsg(invoiceLine2.uomCode = Uom, "Field: " &amp; CM_InvoiceLine::uomCode.name &amp; " | Expected: '" &amp; Uom &amp; "' | Actual: '" &amp; invoiceLine2.uomCode &amp; "'");
	
	
	/*
	** Now Test Making the credit note and checking it has the matching Invoice we created earlier
	*/
	
	
	incomingJsonString := CorrectFormatJsonRequest2;
	
	
	// Make the WebServiceCall
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPutInvoiceAndLines.name, loginJson, incomingJsonString, params, expectError);
	
	
	/*
	** Assert Section for the new Credit Note
	*/
	
	
	// Check that the correct invoice has been created
	newInvoice  := terminal.getDefaultCompanyBank.allInvoicesByExternalCode[InvoiceExternalRef2];
	
	self.assertTrueMsg(newInvoice &lt;&gt; null, "External Ref1 (" &amp; InvoiceExternalRef2 &amp; ") has not been created/is null");
	
	
	// Assert Invoice fields
	self.assertTrueMsg(newInvoice.debtor.code = DebtorId, "Field: " &amp; CM_Invoice::debtor.name &amp; " | Expected: '" &amp; DebtorId &amp; "' | Actual: '" &amp; newInvoice.debtor.code &amp; "'");
	self.assertTrueMsg(newInvoice.category = 0, "Field: " &amp; CM_Invoice::category.name &amp; " | Expected: '" &amp; DocType &amp; "' | Actual: '" &amp; newInvoice.category.String &amp; "'");
	self.assertTrueMsg(newInvoice.exportCurrencyCode = InvoiceExternalRef2, "Field: " &amp; CM_Invoice::exportCurrencyCode.name &amp; " | Expected: '" &amp; InvoiceExternalRef2 &amp; "' | Actual: '" &amp; newInvoice.exportCurrencyCode &amp; "'");

	
	/*
	** Assert Section for the first new invoice line on the credit note
	*/
	
	
	// Get and check the first invoice line fields are correct
	invoiceLine1 := newInvoice.invoiceLines.first;
	self.assertTrueMsg(invoiceLine1.debtor.code = DebtorId, "Field: " &amp; CM_InvoiceLine::debtor.name &amp; " | Expected: '" &amp; DebtorId &amp; "' | Actual: '" &amp; invoiceLine1.debtor.code &amp; "'");
	self.assertTrueMsg(invoiceLine1.externalRef1 = LineExternalRef1, "Field: " &amp; CM_InvoiceLine::externalRef1.name &amp; " | Expected: '" &amp; LineExternalRef1 &amp; "' | Actual: '" &amp; invoiceLine1.externalRef1 &amp; "'");
	self.assertTrueMsg(invoiceLine1.externalRef2 = LineExternalRef2, "Field: " &amp; CM_InvoiceLine::externalRef2.name &amp; " | Expected: '" &amp; LineExternalRef2 &amp; "' | Actual: '" &amp; invoiceLine1.externalRef2 &amp; "'");
	self.assertTrueMsg(invoiceLine1.externalRef3 = LineExternalRef3, "Field: " &amp; CM_InvoiceLine::externalRef3.name &amp; " | Expected: '" &amp; LineExternalRef3 &amp; "' | Actual: '" &amp; invoiceLine1.externalRef3 &amp; "'");
	self.assertTrueMsg(invoiceLine1.remarks = NarrationLine1, "Field: " &amp; CM_InvoiceLine::remarks.name &amp; " | Expected: '" &amp; NarrationLine1 &amp; "' | Actual: '" &amp; invoiceLine1.remarks &amp; "'");
	self.assertTrueMsg(invoiceLine1.quantity = Qty1.Real, "Field: " &amp; CM_InvoiceLine::quantity.name &amp; " | Expected: '" &amp; Qty1.String &amp; "' | Actual: '" &amp; invoiceLine1.quantity.String &amp; "'");
	self.assertTrueMsg(invoiceLine1.uomCode = Uom, "Field: " &amp; CM_InvoiceLine::uomCode.name &amp; " | Expected: '" &amp; Uom &amp; "' | Actual: '" &amp; invoiceLine1.uomCode &amp; "'");
	
	
	/*
	** Assert Section for the second new invoice line
	*/
	
	
	// Get and ch/eck the second invoice line fields are correct
	invoiceLine2 := newInvoice.invoiceLines.last;
	self.assertTrueMsg(invoiceLine2.debtor.code = DebtorId, "Field: " &amp; CM_InvoiceLine::debtor.name &amp; " | Expected: '" &amp; DebtorId &amp; "' | Actual: '" &amp; invoiceLine2.debtor.code &amp; "'");
	self.assertTrueMsg(invoiceLine2.externalRef1 = LineExternalRef1, "Field: " &amp; CM_InvoiceLine::externalRef1.name &amp; " | Expected: '" &amp; LineExternalRef1 &amp; "' | Actual: '" &amp; invoiceLine2.externalRef1 &amp; "'");
	self.assertTrueMsg(invoiceLine2.externalRef2 = LineExternalRef2, "Field: " &amp; CM_InvoiceLine::externalRef2.name &amp; " | Expected: '" &amp; LineExternalRef2 &amp; "' | Actual: '" &amp; invoiceLine2.externalRef2 &amp; "'");
	self.assertTrueMsg(invoiceLine2.externalRef3 = LineExternalRef3, "Field: " &amp; CM_InvoiceLine::externalRef3.name &amp; " | Expected: '" &amp; LineExternalRef3 &amp; "' | Actual: '" &amp; invoiceLine2.externalRef3 &amp; "'");
	self.assertTrueMsg(invoiceLine2.remarks = NarrationLine2, "Field: " &amp; CM_InvoiceLine::remarks.name &amp; " | Expected: '" &amp; NarrationLine2 &amp; "' | Actual: '" &amp; invoiceLine2.remarks &amp; "'");
	self.assertTrueMsg(invoiceLine2.quantity = Qty2.Real, "Field: " &amp; CM_InvoiceLine::quantity.name &amp; " | Expected: '" &amp; Qty2.String &amp; "' | Actual: '" &amp; invoiceLine2.quantity.String &amp; "'");
	self.assertTrueMsg(invoiceLine2.uomCode = Uom, "Field: " &amp; CM_InvoiceLine::uomCode.name &amp; " | Expected: '" &amp; Uom &amp; "' | Actual: '" &amp; invoiceLine2.uomCode &amp; "'");
	
	
epilog
	delete serviceSet;
end;</source>
    </JadeMethod>
    <JadeMethod name="tPostInvoiceAndLinesINV" id="a5f55b71-9ec5-4561-b57c-d722370d88eb">
        <source>tPostInvoiceAndLinesINV();
/*

Purpose:

	Unit test to test the correct functioning of the Put method putInvoiceAndLines on the MasterTerminalAPI with an invoice input

Parameters:		

	None

Return Value:

	None
	
Date			Who		Reason
13 June 2023	navcs2	ChangeRequest 56901: [58447]: TAS Invoicing Invoice Endpoint - JADE changes

*/
constants
	InvoiceId1			: String = "INV342523";
	InvoiceExternalRef2	: String = "INV342522";
	DebtorId		 	: String = "1AAA";
	CurrencyCode    	: String = "EUR";
	DocType				: String = "INV";
	DocDate				: String = "2022-10-14T00:00:00";
	DueDate				: String = "2022-10-14T00:00:00";
	NarrationInv		: String = "2206001496-2206001497-2206001498-2206001499-2206001500-2207000009-2207000011-2207000012  -2207000042-2207000044-2207000046-2207000047";
	ServicePeriod1		: String = "2022-10-14T00:00:00";
	ServicePeriod2		: String = "2022-10-14T00:00:00";
	LineExternalRef1	: String = "TP_202210_001";
	LineExternalRef2	: String = "TP_202210_002";
	LineExternalRef3	: String = "TP_202210_003";
	LineExternalRef4	: String = "TP_202210_004"; //20/01/2026	navkc1 JIRA MTN 36571
	YourRef1			: String = "TestRef1";
	YourRef2			: String = "TestRef2";
	Amount1				: String = "625,00";
	Amount2				: String = "111,34";
	TaxCode				: String = "GST";
	NarrationLine1		: String = "Berthage 6";
	NarrationLine2		: String = "Berthage 6";
	ServiceExternalRef1	: String = "7001";
	ServiceExternalRef2	: String = "7001";
	Uom					: String = "FT";
	Rate1				: Decimal = 1.000000;
	Rate2				: Decimal = 1.000000;
	Qty1				: Decimal = 18.9;
	Qty2				: Decimal = 23.1;
	ServiceId			: String  = "7001";
	
	CorrectFormatJsonRequest : String = 
	'{
	  "businessUnitId": "",
	  "typeId": "",
	  "debtor": {
		"id": "'&amp;DebtorId&amp;'",
		"addressId": "1",
		"alternateAddressId": "20"
	  },
	  "currencyId": "'&amp;CurrencyCode&amp;'",
	  "creditNote": false,
	  "dueDate": "'&amp;DueDate&amp;'",
	  "externalId": "'&amp;InvoiceId1&amp;'",
	  "externalReference2": "'&amp;InvoiceExternalRef2&amp;'",
	  "narration": "'&amp;NarrationInv&amp;'",
	  "lines": [
		{
		  "typeId": "APIService",
		  "service": {
			"id": "'&amp;ServiceId&amp;'",
			"externalReference1": "'&amp;ServiceExternalRef1&amp;'"
		  },
		  "charge": {
			"rate": "'&amp;Rate1.String&amp;'",
			"amount": "'&amp;Amount1.String&amp;'",
			"quantity": "'&amp;Qty1.String&amp;'",
		  },
		  "date": "'&amp;DueDate&amp;'",
		  "narration": "'&amp;NarrationLine1&amp;'",
		  "taxId": "70",
		  "uomId": "'&amp;Uom&amp;'",
		  "externalReference1": "'&amp;LineExternalRef1&amp;'",
		  "externalReference2": "'&amp;LineExternalRef2&amp;'",
		  "externalReference3": "'&amp;LineExternalRef3&amp;'",
		  "externalReference4": "'&amp;LineExternalRef4&amp;'"
		},
		{
		  "typeId": "APIService",
		  "service": {
			"id": "'&amp;ServiceId&amp;'",
			"externalReference1": "'&amp;ServiceExternalRef2&amp;'"
		  },
		  "charge": {
			"rate": "'&amp;Rate2.String&amp;'",
			"amount": "'&amp;Amount1.String&amp;'",
			"quantity": "'&amp;Qty2.String&amp;'",
		  },
		  "date": "'&amp;DueDate&amp;'",
		  "narration": "'&amp;NarrationLine2&amp;'",
		  "taxId": "70",
		  "uomId": "'&amp;Uom&amp;'",
		  "externalReference1": "'&amp;LineExternalRef1&amp;'",
		  "externalReference2": "'&amp;LineExternalRef2&amp;'",
		  "externalReference3": "'&amp;LineExternalRef3&amp;'",
		  "externalReference4": "'&amp;LineExternalRef4&amp;'"
		}
	  ]
	}';
	

vars
	incomingJsonString,
	terminalCode,
	params,
	loginJson				: String;
	root					: CM_Root;
	terminal				: CM_Terminal;
	expectError				: Boolean;
	invoiceOld,
	newInvoice				: CM_Invoice;
	invoiceLineOld,
	invoiceLine1,
	invoiceLine2			: CM_InvoiceLine;
	found					: Boolean;
	invType					: CM_InvoiceDesc;
	invLineType				: CM_InvoiceLineDesc;
	service					: CM_Service;
	serviceSet				: CM_ServiceByNameDict;
	calcType				: CM_CalculationType;
begin
	/*
	** Setup and cleanup Section
	*/
	
	// Get the app root
	root := app.myRoot;
	
	foreach invType in CM_InvoiceDesc.instances discreteLock do 
		if invType.description = "UT_InvTypeApi" then
			found := true;
			break;
		endif;
	endforeach;
	if not found then
		invType := self.createInvoiceApiType("UT_InvTypeApi", InvoiceTypeStorage);
	endif;
	
	self.deleteInvoiceLineType("Unit Test", FORCED_ERASE);
	self.deleteInvoiceService(ServiceExternalRef1,0);
	
	calcType := app.myRoot.allCalculationTypesByCode["CCT00"];	
	service := self.createInvoiceService(ServiceExternalRef1, "null", calcType, null);
	create serviceSet transient;
	serviceSet.add(service);
	invLineType := self.createInvoiceLineType("Unit Test", calcType, invType, serviceSet, "Unit Test");

	
	//Get terminal
	terminalCode := self.getProfileSetting(UT_Profile.P_TERMINAL).asString;
	self.assertNotNullMsg(terminalCode, "Terminal Code not set in Unit Test Profile");
	terminal := root.allTerminals[terminalCode];
	
	incomingJsonString := CorrectFormatJsonRequest;
	
	// Delete the Invoice and Lines as they cannot be duplicate
	invoiceOld := terminal.getDefaultCompanyBank.allInvoicesByExternalCode[InvoiceId1];
	if invoiceOld &lt;&gt; null then
		foreach invoiceLineOld in invoiceOld.invoiceLines do
			self.deleteInvoiceLine(invoiceLineOld);
		endforeach;
		self.deleteInvoice(invoiceOld);
	endif;
	
	// Unit Test to update Invoice and Invoice Lines via a Put Request
	
	// Set the login Json so we can authenticate
	loginJson := '{
   "userId": "' &amp; UT_WebFramework.USERCODE &amp; '",
   "password": "' &amp; UT_WebFramework.PASSWORD &amp; '",
    "applicationId" : "internalAPI",
    "scope" : {
        "complexId" : "Master Terminal",
		"facilityId": "' &amp; terminalCode &amp; '",
        "operatorId" : "Navis",
        "yardId" : "MTN"
    }}';
	
	params		:= "InvoiceAndLines/?MasterTerminalAPI";
	expectError	:= false;
	
	// Make the WebServiceCall
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPutInvoiceAndLines.name, loginJson, incomingJsonString, params, expectError);
	
	
	/*
	** Assert Section for the new invoice
	*/
	
	
	// Check that the correct invoice has been created
	newInvoice  := terminal.getDefaultCompanyBank.allInvoicesByExternalCode[InvoiceId1];
	
	self.assertTrueMsg(newInvoice &lt;&gt; null, "External Ref1 (" &amp; InvoiceId1 &amp; ") has not been created/is null");
	
	
	// Assert Invoice fields
	self.assertTrueMsg(newInvoice.debtor.code = DebtorId, "Field: " &amp; CM_Invoice::debtor.name &amp; " | Expected: '" &amp; DebtorId &amp; "' | Actual: '" &amp; newInvoice.debtor.code &amp; "'");
	self.assertTrueMsg(newInvoice.category = 0, "Field: " &amp; CM_Invoice::category.name &amp; " | Expected: '" &amp; DocType &amp; "' | Actual: '" &amp; newInvoice.category.String &amp; "'");
	//self.assertTrueMsg(newInvoice.externalFinancialId = InvoiceId1, "Field: " &amp; CM_Invoice::externalFinancialId.name &amp; " | Expected: '" &amp; InvoiceId1 &amp; "' | Actual: '" &amp; newInvoice.externalFinancialId &amp; "'");
	self.assertTrueMsg(newInvoice.getExternalFinancialId() = InvoiceId1, "Field: " &amp; CM_Invoice::externalFinancialId.name &amp; " | Expected: '" &amp; InvoiceId1 &amp; "' | Actual: '" &amp; newInvoice.getExternalFinancialId() &amp; "'"); //08/12/2025	navkc1 JIRA 36262
	
	
	/*
	** Assert Section for the first new invoice line
	*/
	
	
	// Get and check the first invoice line fields are correct
	invoiceLine1 := newInvoice.invoiceLines.first;
	self.assertTrueMsg(invoiceLine1.debtor.code = DebtorId, "Field: " &amp; CM_InvoiceLine::debtor.name &amp; " | Expected: '" &amp; DebtorId &amp; "' | Actual: '" &amp; invoiceLine1.debtor.code &amp; "'");
	self.assertTrueMsg(invoiceLine1.externalRef1 = LineExternalRef1, "Field: " &amp; CM_InvoiceLine::externalRef1.name &amp; " | Expected: '" &amp; LineExternalRef1 &amp; "' | Actual: '" &amp; invoiceLine1.externalRef1 &amp; "'");
	self.assertTrueMsg(invoiceLine1.externalRef2 = LineExternalRef2, "Field: " &amp; CM_InvoiceLine::externalRef2.name &amp; " | Expected: '" &amp; LineExternalRef2 &amp; "' | Actual: '" &amp; invoiceLine1.externalRef2 &amp; "'");
	self.assertTrueMsg(invoiceLine1.externalRef3 = LineExternalRef3, "Field: " &amp; CM_InvoiceLine::externalRef3.name &amp; " | Expected: '" &amp; LineExternalRef3 &amp; "' | Actual: '" &amp; invoiceLine1.externalRef3 &amp; "'");
	self.assertTrueMsg(invoiceLine1.externalRef4 = LineExternalRef4, "Field: " &amp; CM_InvoiceLine::externalRef4.name &amp; " | Expected: '" &amp; LineExternalRef4 &amp; "' | Actual: '" &amp; invoiceLine1.externalRef4 &amp; "'"); //20/01/2026	navkc1 JIRA MTN 36571
	self.assertTrueMsg(invoiceLine1.remarks = NarrationLine1, "Field: " &amp; CM_InvoiceLine::remarks.name &amp; " | Expected: '" &amp; NarrationLine1 &amp; "' | Actual: '" &amp; invoiceLine1.remarks &amp; "'");
	self.assertTrueMsg(invoiceLine1.quantity = Qty1.Real, "Field: " &amp; CM_InvoiceLine::quantity.name &amp; " | Expected: '" &amp; Qty1.String &amp; "' | Actual: '" &amp; invoiceLine1.quantity.String &amp; "'");
	self.assertTrueMsg(invoiceLine1.uomCode = Uom, "Field: " &amp; CM_InvoiceLine::uomCode.name &amp; " | Expected: '" &amp; Uom &amp; "' | Actual: '" &amp; invoiceLine1.uomCode &amp; "'");
	
	
	/*
	** Assert Section for the second new invoice line
	*/
	
	
	// Get and ch/eck the second invoice line fields are correct
	invoiceLine2 := newInvoice.invoiceLines.last;
	self.assertTrueMsg(invoiceLine2.debtor.code = DebtorId, "Field: " &amp; CM_InvoiceLine::debtor.name &amp; " | Expected: '" &amp; DebtorId &amp; "' | Actual: '" &amp; invoiceLine2.debtor.code &amp; "'");
	self.assertTrueMsg(invoiceLine2.externalRef1 = LineExternalRef1, "Field: " &amp; CM_InvoiceLine::externalRef1.name &amp; " | Expected: '" &amp; LineExternalRef1 &amp; "' | Actual: '" &amp; invoiceLine2.externalRef1 &amp; "'");
	self.assertTrueMsg(invoiceLine2.externalRef2 = LineExternalRef2, "Field: " &amp; CM_InvoiceLine::externalRef2.name &amp; " | Expected: '" &amp; LineExternalRef2 &amp; "' | Actual: '" &amp; invoiceLine2.externalRef2 &amp; "'");
	self.assertTrueMsg(invoiceLine2.externalRef3 = LineExternalRef3, "Field: " &amp; CM_InvoiceLine::externalRef3.name &amp; " | Expected: '" &amp; LineExternalRef3 &amp; "' | Actual: '" &amp; invoiceLine2.externalRef3 &amp; "'");
	self.assertTrueMsg(invoiceLine2.externalRef4 = LineExternalRef4, "Field: " &amp; CM_InvoiceLine::externalRef4.name &amp; " | Expected: '" &amp; LineExternalRef4 &amp; "' | Actual: '" &amp; invoiceLine2.externalRef4 &amp; "'"); //20/01/2026	navkc1 JIRA MTN 36571
	self.assertTrueMsg(invoiceLine2.remarks = NarrationLine2, "Field: " &amp; CM_InvoiceLine::remarks.name &amp; " | Expected: '" &amp; NarrationLine2 &amp; "' | Actual: '" &amp; invoiceLine2.remarks &amp; "'");
	self.assertTrueMsg(invoiceLine2.quantity = Qty2.Real, "Field: " &amp; CM_InvoiceLine::quantity.name &amp; " | Expected: '" &amp; Qty2.String &amp; "' | Actual: '" &amp; invoiceLine2.quantity.String &amp; "'");
	self.assertTrueMsg(invoiceLine2.uomCode = Uom, "Field: " &amp; CM_InvoiceLine::uomCode.name &amp; " | Expected: '" &amp; Uom &amp; "' | Actual: '" &amp; invoiceLine2.uomCode &amp; "'");
	
	
epilog
	delete serviceSet;
end;</source>
    </JadeMethod>
    <JadeMethod name="tPostInvoiceEuroPortsMap" id="a7466ef8-dd6f-4d5f-becb-bf0753786451">
        <source>tPostInvoiceEuroPortsMap();
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
24 April 2025	navcs2	MTN-34643

*/

constants
	InvoiceId1			: String = "INV342523";
	InvoiceExternalRef2	: String = "INV342522";
	DebtorId		 	: String = "1AAA";
	CurrencyCode    	: String = "EUR";
	DocType				: String = "INV";
	DocDate				: String = "2022-10-14T00:00:00";
	DueDate				: String = "2022-10-14T00:00:00";
	NarrationInv		: String = "2206001496-2206001497-2206001498-2206001499-2206001500-2207000009-2207000011-2207000012  -2207000042-2207000044-2207000046-2207000047";
	ServicePeriod1		: String = "2022-10-14T00:00:00";
	ServicePeriod2		: String = "2022-10-14T00:00:00";
	LineExternalRef1	: String = "TP_202210_001";
	LineExternalRef2	: String = "TP_202210_002";
	LineExternalRef3	: String = "TP_202210_003";
	YourRef1			: String = "TestRef1";
	YourRef2			: String = "TestRef2";
	Amount1				: String = "625,00";
	Amount2				: String = "111,34";
	TaxCode				: String = "GST";
	NarrationLine1		: String = "Berthage 6";
	NarrationLine2		: String = "Berthage 6";
	ServiceExternalRef1	: String = "7001";
	ServiceExternalRef2	: String = "7001";
	Uom					: String = "FT";
	Rate1				: Decimal = 1.000000;
	Rate2				: Decimal = 1.000000;
	Qty1				: Decimal = 18.9;
	Qty2				: Decimal = 23.1;
	ServiceId			: String  = "7001";
	
	CorrectFormatJsonRequest : String = 
	'{
	  "businessUnitId": "",
	  "typeId": "",
	  "debtor": {
		"id": "'&amp;DebtorId&amp;'",
		"addressId": "1",
		"alternateAddressId": "20"
	  },
	  "currencyId": "'&amp;CurrencyCode&amp;'",
	  "creditNote": false,
	  "dueDate": "'&amp;DueDate&amp;'",
	  "externalId": "'&amp;InvoiceId1&amp;'",
	  "externalReference2": "'&amp;InvoiceExternalRef2&amp;'",
	  "narration": "'&amp;NarrationInv&amp;'",
	  "lines": [
		{
		  "typeId": "APIService",
		  "service": {
			"id": "'&amp;ServiceId&amp;'",
			"externalReference1": "'&amp;ServiceExternalRef1&amp;'"
		  },
		  "charge": {
			"rate": "'&amp;Rate1.String&amp;'",
			"amount": "'&amp;Amount1.String&amp;'",
			"quantity": "'&amp;Qty1.String&amp;'",
		  },
		  "date": "'&amp;DueDate&amp;'",
		  "narration": "'&amp;NarrationLine1&amp;'",
		  "taxId": "70",
		  "uomId": "'&amp;Uom&amp;'",
		  "externalReference1": "'&amp;LineExternalRef1&amp;'",
		  "externalReference2": "'&amp;LineExternalRef2&amp;'",
		  "externalReference3": "'&amp;LineExternalRef3&amp;'"
		},
		{
		  "typeId": "APIService",
		  "service": {
			"id": "'&amp;ServiceId&amp;'",
			"externalReference1": "'&amp;ServiceExternalRef2&amp;'"
		  },
		  "charge": {
			"rate": "'&amp;Rate2.String&amp;'",
			"amount": "'&amp;Amount1.String&amp;'",
			"quantity": "'&amp;Qty2.String&amp;'",
		  },
		  "date": "'&amp;DueDate&amp;'",
		  "narration": "'&amp;NarrationLine2&amp;'",
		  "taxId": "70",
		  "uomId": "'&amp;Uom&amp;'",
		  "externalReference1": "'&amp;LineExternalRef1&amp;'",
		  "externalReference2": "'&amp;LineExternalRef2&amp;'",
		  "externalReference3": "'&amp;LineExternalRef3&amp;'"
		}
	  ]
	}';
	

vars
	incomingJsonString,
	terminalCode,
	params,
	loginJson				: String;
	root					: CM_Root;
	terminal				: CM_Terminal;
	expectError				: Boolean;
	invoiceOld,
	newInvoice				: CM_Invoice;
	invoiceLineOld,
	invoiceLine1,
	invoiceLine2			: CM_InvoiceLine;
	found					: Boolean;
	invType					: CM_InvoiceDesc;
	invLineType				: CM_InvoiceLineDesc;
	service					: CM_Service;
	serviceSet				: CM_ServiceByNameDict;
	calcType				: CM_CalculationType;
begin
	/*
	** Setup and cleanup Section
	*/
	
	// Get the app root
	root := app.myRoot;
	
	foreach invType in CM_InvoiceDesc.instances discreteLock do 
		if invType.description = "UT_InvTypeApi" then
			found := true;
			break;
		endif;
	endforeach;
	if not found then
		invType := self.createInvoiceApiType("UT_InvTypeApi", InvoiceTypeStorage);
	endif;
	
	self.deleteInvoiceLineType("Unit Test", FORCED_ERASE);
	self.deleteInvoiceService(ServiceExternalRef1,0);
	
	calcType := app.myRoot.allCalculationTypesByCode["CCT00"];	
	service := self.createInvoiceService(ServiceExternalRef1, "null", calcType, null);
	create serviceSet transient;
	serviceSet.add(service);
	invLineType := self.createInvoiceLineType("Unit Test", calcType, invType, serviceSet, "Unit Test");

	
	//Get terminal
	terminalCode := self.getProfileSetting(UT_Profile.P_TERMINAL).asString;
	self.assertNotNullMsg(terminalCode, "Terminal Code not set in Unit Test Profile");
	terminal := root.allTerminals[terminalCode];
	
	incomingJsonString := CorrectFormatJsonRequest;
	
	// Delete the Invoice and Lines as they cannot be duplicate
	invoiceOld := terminal.getDefaultCompanyBank.allInvoicesByExternalCode[InvoiceId1];
	if invoiceOld &lt;&gt; null then
		foreach invoiceLineOld in invoiceOld.invoiceLines do
			self.deleteInvoiceLine(invoiceLineOld);
		endforeach;
		self.deleteInvoice(invoiceOld);
	endif;
	
	// Unit Test to update Invoice and Invoice Lines via a Put Request
	
	// Set the login Json so we can authenticate
	loginJson := '{
   "userId": "' &amp; UT_WebFramework.USERCODE &amp; '",
   "password": "' &amp; UT_WebFramework.PASSWORD &amp; '",
    "applicationId" : "internalAPI",
    "scope" : {
        "complexId" : "Master Terminal",
		"facilityId": "' &amp; terminalCode &amp; '",
        "operatorId" : "Navis",
        "yardId" : "MTN"
    }}';
	
	params		:= "InvoiceAndLines/?MasterTerminalAPI";
	expectError	:= false;
	
	// Make the WebServiceCall
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPutInvoiceAndLines.name, loginJson, incomingJsonString, params, expectError);
	
	
	/*
	** Assert Section for the new invoice
	*/
	
	
	// Check that the correct invoice has been created
	newInvoice  := terminal.getDefaultCompanyBank.allInvoicesByExternalCode[InvoiceId1];
	
	self.assertTrueMsg(newInvoice &lt;&gt; null, "External Ref1 (" &amp; InvoiceId1 &amp; ") has not been created/is null");
	
	
	// Assert Invoice fields
	self.assertTrueMsg(newInvoice.debtor.code = DebtorId, "Field: " &amp; CM_Invoice::debtor.name &amp; " | Expected: '" &amp; DebtorId &amp; "' | Actual: '" &amp; newInvoice.debtor.code &amp; "'");
	self.assertTrueMsg(newInvoice.category = 0, "Field: " &amp; CM_Invoice::category.name &amp; " | Expected: '" &amp; DocType &amp; "' | Actual: '" &amp; newInvoice.category.String &amp; "'");
	//self.assertTrueMsg(newInvoice.externalFinancialId = InvoiceId1, "Field: " &amp; CM_Invoice::externalFinancialId.name &amp; " | Expected: '" &amp; InvoiceId1 &amp; "' | Actual: '" &amp; newInvoice.externalFinancialId &amp; "'");
	self.assertTrueMsg(newInvoice.getExternalFinancialId() = InvoiceId1, "Field: " &amp; CM_Invoice::externalFinancialId.name &amp; " | Expected: '" &amp; InvoiceId1 &amp; "' | Actual: '" &amp; newInvoice.getExternalFinancialId() &amp; "'"); //08/12/2025	navkc1 JIRA 36262
	
	
	/*
	** Assert Section for the first new invoice line
	*/
	
	
	// Get and check the first invoice line fields are correct
	invoiceLine1 := newInvoice.invoiceLines.first;
	self.assertTrueMsg(invoiceLine1.debtor.code = DebtorId, "Field: " &amp; CM_InvoiceLine::debtor.name &amp; " | Expected: '" &amp; DebtorId &amp; "' | Actual: '" &amp; invoiceLine1.debtor.code &amp; "'");
	self.assertTrueMsg(invoiceLine1.externalRef1 = LineExternalRef1, "Field: " &amp; CM_InvoiceLine::externalRef1.name &amp; " | Expected: '" &amp; LineExternalRef1 &amp; "' | Actual: '" &amp; invoiceLine1.externalRef1 &amp; "'");
	self.assertTrueMsg(invoiceLine1.externalRef2 = LineExternalRef2, "Field: " &amp; CM_InvoiceLine::externalRef2.name &amp; " | Expected: '" &amp; LineExternalRef2 &amp; "' | Actual: '" &amp; invoiceLine1.externalRef2 &amp; "'");
	self.assertTrueMsg(invoiceLine1.externalRef3 = LineExternalRef3, "Field: " &amp; CM_InvoiceLine::externalRef3.name &amp; " | Expected: '" &amp; LineExternalRef3 &amp; "' | Actual: '" &amp; invoiceLine1.externalRef3 &amp; "'");
	self.assertTrueMsg(invoiceLine1.remarks = NarrationLine1, "Field: " &amp; CM_InvoiceLine::remarks.name &amp; " | Expected: '" &amp; NarrationLine1 &amp; "' | Actual: '" &amp; invoiceLine1.remarks &amp; "'");
	self.assertTrueMsg(invoiceLine1.quantity = Qty1.Real, "Field: " &amp; CM_InvoiceLine::quantity.name &amp; " | Expected: '" &amp; Qty1.String &amp; "' | Actual: '" &amp; invoiceLine1.quantity.String &amp; "'");
	self.assertTrueMsg(invoiceLine1.uomCode = Uom, "Field: " &amp; CM_InvoiceLine::uomCode.name &amp; " | Expected: '" &amp; Uom &amp; "' | Actual: '" &amp; invoiceLine1.uomCode &amp; "'");
	
	
	/*
	** Assert Section for the second new invoice line
	*/
	
	
	// Get and ch/eck the second invoice line fields are correct
	invoiceLine2 := newInvoice.invoiceLines.last;
	self.assertTrueMsg(invoiceLine2.debtor.code = DebtorId, "Field: " &amp; CM_InvoiceLine::debtor.name &amp; " | Expected: '" &amp; DebtorId &amp; "' | Actual: '" &amp; invoiceLine2.debtor.code &amp; "'");
	self.assertTrueMsg(invoiceLine2.externalRef1 = LineExternalRef1, "Field: " &amp; CM_InvoiceLine::externalRef1.name &amp; " | Expected: '" &amp; LineExternalRef1 &amp; "' | Actual: '" &amp; invoiceLine2.externalRef1 &amp; "'");
	self.assertTrueMsg(invoiceLine2.externalRef2 = LineExternalRef2, "Field: " &amp; CM_InvoiceLine::externalRef2.name &amp; " | Expected: '" &amp; LineExternalRef2 &amp; "' | Actual: '" &amp; invoiceLine2.externalRef2 &amp; "'");
	self.assertTrueMsg(invoiceLine2.externalRef3 = LineExternalRef3, "Field: " &amp; CM_InvoiceLine::externalRef3.name &amp; " | Expected: '" &amp; LineExternalRef3 &amp; "' | Actual: '" &amp; invoiceLine2.externalRef3 &amp; "'");
	self.assertTrueMsg(invoiceLine2.remarks = NarrationLine2, "Field: " &amp; CM_InvoiceLine::remarks.name &amp; " | Expected: '" &amp; NarrationLine2 &amp; "' | Actual: '" &amp; invoiceLine2.remarks &amp; "'");
	self.assertTrueMsg(invoiceLine2.quantity = Qty2.Real, "Field: " &amp; CM_InvoiceLine::quantity.name &amp; " | Expected: '" &amp; Qty2.String &amp; "' | Actual: '" &amp; invoiceLine2.quantity.String &amp; "'");
	self.assertTrueMsg(invoiceLine2.uomCode = Uom, "Field: " &amp; CM_InvoiceLine::uomCode.name &amp; " | Expected: '" &amp; Uom &amp; "' | Actual: '" &amp; invoiceLine2.uomCode &amp; "'");
	
	self.assertTrueMsg(newInvoice.context = "TAS", "TAS: " &amp; CM_Invoice::context.name &amp; " | Expected: '" &amp; "TAS" &amp; "' | Actual: '" &amp; newInvoice.context &amp; "'");
epilog
	delete serviceSet;
end;</source>
    </JadeMethod>
    <JadeMethod name="tPostMoveCargo" id="37e994fe-9d5c-488b-a48a-9fde47d4c49b">
        <updating/>
        <source>tPostMoveCargo() updating;
/*

