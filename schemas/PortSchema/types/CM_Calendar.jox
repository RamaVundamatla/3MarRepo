    <JadeMethod name="addBusinessDaysTo" id="2cf61ba5-7f76-4baa-a39c-ebfa37dc4114">
        <source>addBusinessDaysTo(_dateTime : TimeStamp; _days : Integer) : TimeStamp;
// CCMS 1295 free storage days - used to derive free storage expiry date
vars
	count	: Integer;
	result	: TimeStamp;
	date	: Date;
	calendarDate : CM_CalendarDate;
begin

	result := _dateTime;
	if not _dateTime.isValid then
		return null;
	endif;
	if self.allCalendarDates.isEmpty or
	   _days &lt;= 0 then
		return result;
	endif;
	
	date := _dateTime.date;
	while true do
		date := date + 1; 
		calendarDate := self.getFirstCalendarDateForDay(date);
		if calendarDate = null then	// not a weekend/holiday
			count := count + 1;
		endif;
		if count = _days then
			break;
		endif;
	endwhile;
	
	result.setDate(date);
	return result;
end;
</source>
        <Parameter name="_dateTime" type="TimeStamp"/>
        <Parameter name="_days" type="Integer"/>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="doesCalendarIncludeDate" id="521df5fb-9169-4c73-b75a-1a3b8b107729">
        <source>doesCalendarIncludeDate( _date : Date) : Boolean;
/*
Purpose:			

Date		Who		Reason
18MAY2023	NAVAB1	BUG 57961 
*/

vars

	calendarDate : CM_CalendarDate;
	
begin

	if self.allCalendarDates.isEmpty 
	or not _date.isValid then
		return false;
	endif;
	
	calendarDate := self.allCalendarDates.getAtKeyGeq( _date, null );
	if calendarDate = null then
		return false;
	endif;
	
	return calendarDate.date = _date;
	
epilog


end;</source>
        <Parameter name="_date" type="Date"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
