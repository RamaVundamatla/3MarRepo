    <JadeMethod name="updateConnectionStatus" id="0e18b4cf-d3cf-442a-a7ad-c0b6fd896c23">
        <source>updateConnectionStatus() : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 October 2016	cnwrh7	Initial creation

*/

vars
	connectionStatus : String;
begin
	if self.myTCPConnection &lt;&gt; null then
		if self.myTCPConnection.state = Connection.Connecting then
			return 	"Connecting";
		elseif	self.myTCPConnection.state = Connection.Connected then
			return	"Connected";
		elseif self.myTCPConnection.state = Connection.Disconnected then
			return	"Disconnected";
		elseif self.myTCPConnection.state = Connection.Disconnecting then
			 return  "Disconnecting";
		endif;
	else
			return "Connection is NULL";
	endif;
	
	return "Invalid connection";
	
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
