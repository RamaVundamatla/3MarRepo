    <JadeMethod name="comboBoxISOType" id="ac60d63b-6c11-43ce-ba19-d23ea4319917">
        <source>comboBoxISOType(_cmb : ComboBox input);
/*

Purpose:			


Return Value:		


Date		Who		Reason
20 September 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars
	iter 		: Iterator;
	isoType 	: CM_ISOType;
begin
	if _cmb = null then
		return;
	endif;

	iter:=app.myRoot.allISOTypes.createIterator;
	while iter.next(isoType) do
		_cmb.itemObject[_cmb.addItem(self.displayEntryISOType(isoType))] := isoType;
	endwhile;
	
epilog
	delete iter;
end;</source>
        <Parameter name="_cmb" type="ComboBox" usage="input"/>
    </JadeMethod>
