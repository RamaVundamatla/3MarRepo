    <JadeMethod name="addToJobTotalsMove" id="b532107b-9edf-4022-8ba7-01ebfcf94cf9">
        <source>addToJobTotalsMove(_theTotals: CMIF_JobTITotals input; _moveType: Integer);
/* ---------------------------------------------------------------------------
// Created:		June  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
23 Aug 2011		cnwer1		CCMS 1033 giving a breakdown of break bulk totals by cargo type
21 May 2013 	cnwer1	 	Don't need to do anything here because totals added on request &amp; needed request wle
							to get proper breakbulk quantity

// ---------------------------------------------------------------------------*/

vars

begin
	return; // leave do no want it to inherit
end;</source>
        <Parameter name="_theTotals" type="CMIF_JobTITotals" usage="input"/>
        <Parameter name="_moveType" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="addToJobTotalsSnapShot" id="d1930b09-d356-4a56-a56b-ac472020e12e">
        <source>addToJobTotalsSnapShot(_theTotals: CMIF_JobTITotals input);
// ---------------------------------------------------------------------------
// Created:		June  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 14/07/2010	cnwdap1		PAR #25021 Review use of isImport/isExport for tranships
// ---------------------------------------------------------------------------

vars

begin
/* PAR 31756 822 REMOVE - NOT USED - AKB

	//if self.isImport or self.isExport or self.isStorage then														// PAR #25021
	if self.isImport or self.isExport or self.isStorage or self.isTranshipInbound or self.isTranshipOutbound then	// PAR #25021
		self.addJobTotalsPerCargoType( _theTotals.allBBLKTotals);
		//	PAR 31756			_theTotals.numBBLK := _theTotals.numBBLK + 1;
	elseif self.isRehandle then
		self.addJobTotalsPerCargoType( _theTotals.allBBLKTotalsRH);
		//	PAR 31756			_theTotals.numBBLKRH := _theTotals.numBBLKRH + 1;
	elseif self.isSOB then
		self.addJobTotalsPerCargoType( _theTotals.allBBLKTotalsSOB);
		//	PAR 31756			_theTotals.numBBLKSOB := _theTotals.numBBLKSOB + 1;
	endif; 
	
	_theTotals.numTwentyFoot := _theTotals.numTwentyFoot + 1;

	if self.isImport or self.isExport or self.isStorage then
		if self.isFull then
			_theTotals.numFull := _theTotals.numFull + 1;
			_theTotals.numFull20 := _theTotals.numFull20 + 1;
		else
			_theTotals.numEmpty := _theTotals.numEmpty + 1;
			_theTotals.numEmpty20 := _theTotals.numEmpty20 + 1;
		endif;
	elseif self.isRehandle then
		if self.isFull then
			_theTotals.numFullRH := _theTotals.numFullRH + 1;
			_theTotals.numFull20RH := _theTotals.numFull20RH + 1;
		else
			_theTotals.numEmptyRH := _theTotals.numEmptyRH + 1;
			_theTotals.numEmpty20RH := _theTotals.numEmpty20RH + 1;
		endif;
	elseif self.isSOB then
		if self.isFull then
			_theTotals.numFullSOB := _theTotals.numFullSOB + 1;
			_theTotals.numFull20SOB := _theTotals.numFull20SOB + 1;
		else
			_theTotals.numEmptySOB := _theTotals.numEmptySOB + 1;
			_theTotals.numEmpty20SOB := _theTotals.numEmpty20SOB + 1;
		endif;
	endif;

*/
end;</source>
        <Parameter name="_theTotals" type="CMIF_JobTITotals" usage="input"/>
    </JadeMethod>
    <JadeMethod name="create" id="6eb918a4-ea9c-4036-9ab7-c6f79d1d057d">
        <updating/>
        <source>create() updating;
// ---------------------------------------------------------------------------
// Created:     10 September 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	self.cargoType		:= TI_CargoType_BreakBulk;

	self.quantity 		:= NULL_QUANTITY;
