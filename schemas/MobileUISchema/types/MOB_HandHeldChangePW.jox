    <JadeMethod name="doCancel" id="8e1aa4f8-e61b-4e05-b190-ff5ba67b560c">
        <updating/>
        <source>doCancel() updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
26 May 2010	cnwer1	Initial creation

*/

vars

begin
	self.doBackButtonClick();
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doOK" id="894cb8ad-4a07-4cf8-9d87-fe0d3575083b">
        <updating/>
        <source>doOK() updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
26 May 2010	cnwer1	Initial creation
20 Oct 2011	cnwkpd1	PAR #28510 - Problems logging on in Windows Mobile 6.5 device

*/

vars
	oldPW,
	newPW,
	confirmPW	: String;
	tmpError	: CM_Error;
begin
	oldPW 	:= self.txtOldPW.getPasswordText();		// PAR #28510
	newPW 	:=  self.txtNewPW.getPasswordText();
	confirmPW	:= self.txtConfirmPW.getPasswordText();

	app.myTrxUA.trxUpdatePassword(true, app.getMyUserCode, oldPW, newPW, confirmPW, app.myPassport);
	if app.myPassport.trxCompletedOK then
	 	self.doBackButtonClick();
	else
		app.showErrorWarningDialog('Error(s)', app.myPassport, ErrWarnMode_Update);
		tmpError := app.myPassport.allErrors.first;
		if tmpError &lt;&gt; null and tmpError.errorCode = ERR_PASSWORD then
			txtOldPW.setFocus;
		else
			txtNewPW.setFocus;
		endif;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="245cde3b-2caf-4f45-aa62-957c3e1c5bdf">
        <updating/>
        <source>setupForm() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
26 May 2010	cnwer1	Initial creation

*/

vars

begin
	inheritMethod();
	
	self.lblUser.caption:=app.getMyUserCode;
	self.lblUser.fontBold:=true;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="translateForm" id="b4d17870-8ccc-43dd-8764-cb679bfe8b47">
        <updating/>
        <source>translateForm(locale : CM_Locale) updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	
begin
	// Determine the locale for translations.
	inheritMethod(locale);
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0017604, locale);
	btnCancel.translateCaption(Xlat_0014806, locale);
	btnOK.translateCaption(Xlat_0014807, locale);
	lblConfirmPW.translateCaption(Xlat_0014808, locale);
	lblCurrentPW.translateCaption(Xlat_0014809, locale);
	lblNewPW.translateCaption(Xlat_0014810, locale);
	lblUser.translateCaption(Xlat_0014811, locale);
end;</source>
        <Parameter name="locale" type="CM_Locale"/>
    </JadeMethod>
</GUIClass>
