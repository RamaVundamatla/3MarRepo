    <JadeMethod name="getVisibilityTallyman" id="cbca3297-aaed-4d23-9ca7-b41386a49cfc">
        <source>getVisibilityTallyman( dischargeVisible, loadVisible : Boolean output) : Boolean;
/*

Date		Who		Reason
24 July 2013	cnwer1	Initial creation CCMS 2265 

*/

vars
	deckItem 	: CM_DeckItem;
	coveringDeckItemLayout: CM_DeckItemLayout;
	requestLayout : CM_RORORequestLayout;
	requestSlotLC : CM_ROROSlotController;
	dischargeRequest : CM_RORORequest;
begin
	if not  self.isVisible then
		if  self.myDeckItem = null then
			return false;
		elseif  (not self.myDeckItem.isOOTL and not self.myDeckItem.isLocnGC) then //epr par 31153 13/2/13 once cargo moved outof GC area the deckLayout no longer visible
			return false;
		endif;
	endif;
				
	if self.myDeckLayer.type = ROROLayerType_Structure then					
		return true;
	endif;
				
	deckItem:=self.myDeckItem;

	if deckItem = null then
		return false;
	endif;
	//epr par 29742 11/6/12 re-written to hide show rotated cells correctly
	dischargeVisible:=true;
	loadVisible:=true;
	
	if self.myDeckLayer.type = ROROLayerType_CCLoad then // this is the CC Load layer discharge is not visible 
		dischargeVisible :=false;
		//epr par 32488 18/9/13 new checks for kocations unrotated on the load layer that could be covered 
		if self.type = DeckItemLayoutType_Locn and self.myDeckItem.isKindOf(CM_ROROLocnDefn) and self.myDeckItem.CM_ROROLocnDefn.hasBeenRotatedForLoad then
			if self.isCovered(DeckItemLayoutType_GCLoad,true) or self.isCovered(DeckItemLayoutType_CCLoad,true) then
				loadVisible :=false;
			endif;
		endif;
	elseif self.myDeckLayer.type = ROROLayerType_CCDischarge then// this is the CC Discharge layer discharge is not visible 
		loadVisible :=false;
	elseif self.myDeckLayer.type = ROROLayerType_GC then 
		//epr TFS 46166 29/11/19 and further changes 12/12/19
	//Another layer for General Cargo use deckItemLayout type to determine if visible for load or discharge
		loadVisible :=not (self.hasCCLayout(DeckItemLayoutType_GCLoad) or self.hasCCLayout(DeckItemLayoutType_GCDischarge)); // self.type =  DeckItemLayoutType_GCLoad;
		//if self.type = DeckItemLayoutType_GCDischarge then
		dischargeVisible := not (self.hasCCLayout(DeckItemLayoutType_GCDischarge) and self.isCovered(DeckItemLayoutType_GCDischarge,false));
		//endif;
	elseif self.myDeckLayer.type = ROROLayerType_OOTL then
		//if its on this layer  its actual cargo i.e. discharge only
		//epr par 32488 is visible in load if has CC
		if not self.hasNoCC(false) then
			loadVisible:=false;
		endif;
		//epr par 32929
		if deckItem.isOOTL() and deckItem.isOnLayerOOTL then // PAR 31116
			if deckItem.hasTIs40Loaded(REAL_MODE, true, false)   // PAR 31376
			or deckItem.hasTIs40Loaded(REAL_MODE, false, false) then  // PAR 31376
				dischargeVisible:=false;
			endif;
		endif;
		
	else
	// location with no CC determine if hidden by Rotated cells OOTL  etc
		coveringDeckItemLayout:= self.allCoveringPolygons[DeckItemLayoutType_Locn];
		if coveringDeckItemLayout &lt;&gt; null then
			// is covered by Load CC 
			if coveringDeckItemLayout.myDeckLayer.type = ROROLayerType_CCLoad  then
				loadVisible :=false;
				// is covered by Discharge CC 
			elseif coveringDeckItemLayout.myDeckLayer.type = ROROLayerType_CCDischarge then
				dischargeVisible :=false;
			elseif coveringDeckItemLayout.myDeckLayer.type = ROROLayerType_OOTL then 
				
				if  self.allCoveringPolygons[DeckItemLayoutType_CCDischarge] &lt;&gt; null then
					dischargeVisible :=false;
				endif;
				if self.allCoveringPolygons[DeckItemLayoutType_CCLoad] &lt;&gt; null then
					loadVisible :=false;
				endif;
			endif;
		endif;
		//covered by CC Load that is a OOTL 
		// epr par 30269 28/8/12
		coveringDeckItemLayout:= self.allCoveringPolygons[DeckItemLayoutType_CCLoad]; 
		if coveringDeckItemLayout &lt;&gt; null and coveringDeckItemLayout.isKindOf(CM_RORORequestLayout) then
			requestLayout:=coveringDeckItemLayout.CM_RORORequestLayout;
			if requestLayout.myRequest.myROROController.isKindOf(CM_ROROSlotController) then
				requestSlotLC:= requestLayout.myRequest.myROROController.CM_ROROSlotController;
				if requestSlotLC.mySlotDefn.myROROLocnDen.isOOTLLocn then
					loadVisible :=false;
				endif;
			endif;
		endif;
		// covered by GC load 
		if self.isCovered(DeckItemLayoutType_GCLoad,true) then
			loadVisible :=false;
		endif;
		//epr par 32658 14/10/13
		dischargeRequest:=self.myDeckItem.getFirstRequest(false);
		if dischargeRequest &lt;&gt; null then		
			if dischargeRequest.myLayout.isCovered(DeckItemLayoutType_CCDischarge,true) then
				dischargeVisible:=false;
			endif;
		else
			if self.isCovered(DeckItemLayoutType_CCDischarge,true) then
				dischargeVisible:=false;
			endif;
		endif;
		// covered by GC discharge 
		if self.isCovered(DeckItemLayoutType_GCDischarge,true) then
			dischargeVisible :=false;
			//epr TFS 46166 29/11/19
			if not self.isCoveredByDefnWithCC(DeckItemLayoutType_GCDischarge) then
				loadVisible:=false;
			endif;
		endif;
	endif;
	
	return true;
epilog

end;</source>
        <Parameter name="dischargeVisible" type="Boolean" usage="output"/>
        <Parameter name="loadVisible" type="Boolean" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getWidthInMetres" id="77681729-df7f-4d8a-9713-85e5e6346d01">
        <source>getWidthInMetres() : Decimal;
/*
Purpose:			
Date		Who		Reason
21 April 2011	cnwab1	Initial creation
*/

vars
	tmpPoint : Point;
	first, second, widthP : Integer;
	widthM : Decimal[12,2];
begin

	tmpPoint := self.getExtremePoint(self.Position_Top);
	first := tmpPoint.y;
	tmpPoint := self.getExtremePoint(self.Position_Bottom);
	second := tmpPoint.y;
	
	widthP := second - first; // width in pixels
	
	widthM := (widthP / ROROStructurePixelsPerMetre); // 10 pixels per metre
	
	
	
	return widthM;
epilog

end;</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="hasCCLayout" id="faa61159-3626-4ce0-8499-b092910b03b3">
        <source>hasCCLayout(_type : Integer) : Boolean;
/*
Purpose:			
Date		Who		Reason
07 September 2011	cnwab1	Initial creation
*/

vars
	lc : CM_VoyageROROController;
begin
	// // PAR 31073 - NOW LIKE THIS:
	if self.type = _type then 
		if self.myDeckItem &lt;&gt; null then
			lc := self.myDeckItem.getLC().CM_VoyageROROController;
			
			if lc &lt;&gt; null then
				if self.type = DeckItemLayoutType_GCDischarge then
					return (lc.myRORORequestDischarge &lt;&gt; null);
				elseif self.type = DeckItemLayoutType_GCLoad then
					return (lc.myRORORequestLoad &lt;&gt; null);
				endif;
			endif;
		endif;
	endif;
/* // PAR 31073
	if self.type = DeckItemLayoutType_GCDischarge 
	or self.type = DeckItemLayoutType_GCLoad then
		if self.myDeckItem &lt;&gt; null then
			lc := self.myDeckItem.getLC().CM_VoyageROROController;
			
			if lc &lt;&gt; null then
				if self.type = DeckItemLayoutType_GCDischarge then
					return (lc.myRORORequestDischarge &lt;&gt; null);
				elseif self.type = DeckItemLayoutType_GCLoad then
					return (lc.myRORORequestLoad &lt;&gt; null);
				endif;
			endif;
		endif;
	endif;

*/	
	return false;
epilog

end;</source>
        <Parameter name="_type" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
