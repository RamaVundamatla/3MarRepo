    <JadeMethod name="doPopulateMsgForAdd" id="5d1ddd56-58b0-47ca-a56d-f01c80b80e13">
        <source>doPopulateMsgForAdd();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03/08/2023	navkc1	CR 59552   Task 59555: UI CustDocs - Country Region Maint

*/

vars
	country				: CM_Country;
	countriesToDisplay	: CM_CountryByCodeDict;
	theForm				: SOP_TableMaintForm;
begin
	create countriesToDisplay transient;
	
	foreach country in app.myRoot.allCountries discreteLock do
		if country.myCountryRegion &lt;&gt; null then
			continue;
		endif;
		
		countriesToDisplay.add(country);
	endforeach;
	
	theForm := self.myForm;
	theForm.mulSelect1.setAvailable(countriesToDisplay, true);
	
	
epilog
	delete countriesToDisplay;
end;</source>
    </JadeMethod>
    <JadeMethod name="doSave" id="41d5c37d-e866-4aeb-bd3b-aec167a73985">
        <updating/>
        <source>doSave(): Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03/08/2023	navkc1	CR 59552   Task 59555: UI CustDocs - Country Region Maint

*/

vars
	proxyCountryRegion			: CM_CountryRegion;
	lCode,lDescription			: String;
	homeRegion, nafe			: Boolean;
	theCountries				: CM_CountryByCodeDict;
	theForm 					: SOP_TableMaintForm;
begin
	
	theForm := self.myForm; 
  	
	lCode 			:= theForm.tblInput1.getValueByName(ETRow_Code).String;
	lDescription 	:= theForm.tblInput1.getValueByName(ETRow_Description).String;
	homeRegion 		:= theForm.tblInput1.getValueByName(ETRow_HomeRegion).Boolean;
	nafe 			:= theForm.tblInput1.getValueByName(ETRow_NotAvailForEntry).Boolean;

	if theForm.myProxyObject = null then
		if theForm.mode = theForm.Mode_Add then
			create theForm.myProxyObject as CM_CountryRegion transient;
		else
			app.raiseUnexpectedProgramError(class.name, method.name, 'Proxy object is null for update');
			return false;
		endif;
	endif;

	proxyCountryRegion := theForm.myProxyObject.CM_CountryRegion;
	
	create theCountries transient;
	theForm.mulSelect1.getSelected(theCountries);
	
	proxyCountryRegion.setProxy(lCode, lDescription, homeRegion, nafe, theCountries);
	
	if theForm.mode = theForm.Mode_Add then
		app.myTrxCA.trxCreateCountryregion(proxyCountryRegion, theForm.myCurrentObject, app.myPassport);
	elseif theForm.mode = theForm.Mode_Update then
		app.myTrxUA.trxUpdateCountryRegion(proxyCountryRegion, app.myPassport);
		
	else
		app.raiseUnexpectedProgramError(class.name, method.name, '  Invalid mode (' &amp; theForm.mode.String &amp; ')');
		return false;
	endif;
	
	return app.myPassport.trxCompletedOK();

epilog
	delete theCountries;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
