    <JadeMethod name="setControlsForAddEdit" id="1a2097e5-5712-4327-ac60-42463f989fae">
        <updating/>
        <source>setControlsForAddEdit() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03/08/2023	navkc1	CR 59552   Task 59555: UI CustDocs - Country Region Maint

*/

vars
	theForm 			: SOP_TableMaintForm;
	theCountryRegion 	: CM_CountryRegion;
begin
	
	theForm := self.myForm;
	theForm.tblInput1.userInputEnabled := true;
	theForm.shtMultiSelect1.visible := true;
	theForm.mulSelect1.userInputEnabled := true;
	
	if theForm.mode = theForm.Mode_Add then
		theForm.tblInput1.clearValues;
		theForm.tblInput1.enableRowByName(ETRow_Code);
		theForm.tblInput1.enableRowByName(ETRow_Description);
		theForm.tblInput1.enableRowByName(ETRow_HomeRegion);
		theForm.tblInput1.enableRowByName(ETRow_NotAvailForEntry);
		theForm.mulSelect1.setSelected(null);
		theForm.tblInput1.setFocus;
		theForm.tblInput1.moveFirst();
		theForm.tblInput1.gotFocus(theForm.tblInput1);
		theForm.fldInput.initSheetBackColors();
		self.doPopulateMsgForAdd();
	else
		self.showThumbnail(theForm.myProxyObject.CM_CountryRegion);
		theForm.tblInput1.disableRowByName(ETRow_Code);
		theForm.tblInput1.enableRowByName(ETRow_Description);
		theForm.tblInput1.enableRowByName(ETRow_HomeRegion);
		theForm.tblInput1.enableRowByName(ETRow_NotAvailForEntry);
	endif;
	self.enableMulSelect1Contents();
	theForm.tblInput1.cnEcResizeContents();

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setCtrlsForView" id="93779d43-4678-47d6-87cf-75443d54a8bc">
        <updating/>
        <source>setCtrlsForView() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03/08/2023	navkc1	CR 59552   Task 59555: UI CustDocs - Country Region Maint

*/

vars
	theForm : SOP_TableMaintForm;
	
begin
	
	inheritMethod();  
  	theForm := self.myForm;
	theForm.tblInput1.userInputEnabled := false;
  	theForm.tblInput1.cnEcResizeContents();
  	theForm.shtMultiSelect1.visible := true;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupThumbnailDetails" id="fe356872-f7f5-4545-b650-bd4eb4d7b41a">
        <updating/>
        <source>setupThumbnailDetails() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03/08/2023	navkc1	CR 59552   Task 59555: UI CustDocs - Country Region Maint

*/

vars
	theForm : SOP_TableMaintForm;
	theCountry : CM_Country;
begin

	theForm := self.myForm;
	theForm.useProxyObject := true;
	theForm.setTblDataEntRows(ETDef_CountryRegionMaintList);

	theForm.shtTblInput1.caption := 'Details';
	theForm.initTblInput(theForm.tblInput1, ETDef_CountryRegionMaintTbl);
	theForm.shtTblInput1.visible := true;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="showThumbnail" id="9bdb0a6c-f7ae-40c7-aa41-54d6c7890152">
        <updating/>
        <source>showThumbnail(pCountryRegion: CM_CountryRegion) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03/08/2023	navkc1	CR 59552   Task 59555: UI CustDocs - Country Region Maint

*/

vars
	theForm 			: SOP_TableMaintForm;
	countriesToDisplay	: CM_CountryByCodeDict;
	country				: CM_Country;
begin
	theForm := self.myForm;
	
	theForm.tblInput1.clearValues;
	theForm.mulSelect1.multiClear();
	create countriesToDisplay transient;
	
	theForm.tblInput1.setValueByName(ETRow_Code, pCountryRegion.code);
	theForm.tblInput1.setValueByName(ETRow_Description,	pCountryRegion.description);
	theForm.tblInput1.setValueByName(ETRow_HomeRegion,	pCountryRegion.homeRegion);
	theForm.tblInput1.setValueByName(ETRow_NotAvailForEntry, pCountryRegion.notAvailForEntry);
	
	foreach country in app.myRoot.allCountries discreteLock do
		if country.myCountryRegion = null or pCountryRegion.allCountries.includes(country) then
			countriesToDisplay.add(country);
		endif;
	endforeach;
	
	theForm.mulSelect1.setAvailable(countriesToDisplay, true);
	theForm.mulSelect1.setSelected(pCountryRegion.allCountries);	
	
	self.disableMulSelect1Contents();

epilog
	delete countriesToDisplay;
end;</source>
        <Parameter name="pCountryRegion" type="CM_CountryRegion"/>
    </JadeMethod>
</Class>
