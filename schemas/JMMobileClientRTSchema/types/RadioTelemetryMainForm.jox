    <JadeMethod name="doAcceptedTask" id="f5fabcf9-205a-4806-8f17-34c68cbe4a13">
        <updating/>
        <source>doAcceptedTask() updating, protected;
/*

Date		Who		Reason
02 Feb 2006	cnwdvb1	 Created 
11 Mar 2008	cnwkpd1	PAR #16010 - CCMS Otago 1502 - Thin Client RT Enhancements


*/// -------------------------------------------
//
// -------------------------------------------
vars

begin

	if self.aQueueTaskType = TASK_DIRECTOR_DESC then
		self.showMessage('Enter the container number to check against the request.', false);
		self.btnPickup.caption		:=	self.Caption_SelectTI;
		self.txtContainerID.mbEnable(true);
		self.txtContainerID.setFocus();
	else
		self.btnPickup.caption		:=	self.Caption_Pickup;
		self.btnPickup.picture		:=	picPickup.picture;
		self.txtContainerID.mbEnable(false);
	endif;
	
	self.btnInfo.enabled			:=	false;
	self.btnAccept.caption 			:=	Caption_Accept;
//	self.btnAccept.picture			:=	picAccept.picture;
	self.btnChangePass.enabled 		:=	false;
	self.btnPreferences.enabled 	:=	false;
	self.btnChangeQueue.enabled		:=	false;			// PAR #16010
	//self.txtNewLocation.enabled		:=	false;
	self.txtNewLocation.enabled		:=	true;
	self.btnReject.enabled			:=	true;
	self.tblDataToDo.mbEnable(false);
	self.tblDataGrade.mbEnable(false);
	self.btnAccept.enabled			:=	false;
	self.btnTasksUpdate.enabled		:=	false;
	self.btnGradesUpdate.enabled	:=	false;
	self.btnPickup.enabled 			:=	true;
	self.aIsAbleToPutOnHold			:=	true;
			
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doAllocatedTIToDirectorTask" id="208c683f-0466-4192-996e-374b80de8a5d">
        <updating/>
        <source>doAllocatedTIToDirectorTask() updating, protected;
// -------------------------------------------
// Created 02 February 2006 by cnwdvb1
// -------------------------------------------
vars


	errorStr		: String;
	
begin

	self.aWarnings := false;
	
	while true do
		if not app.myRTGuiAgent.actionDirectorTask(self.txtContainerID.text, self, errorStr, self.aState, self.aWarnings) then
			if self.showMessage(errorStr, true) then
				continue;
			else
				self.txtContainerID.setFocus();
			endif;
		else
			self.updateFromState();
		endif;
		break;
	endwhile;
	
	

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doApplyScreenColors" id="c80ca6f5-66fb-4bf5-b4d1-5dfae3d97f0a">
        <updating/>
        <source>doApplyScreenColors() updating, protected;
// --------------------------------------------------------------------------------
// Created:		24 January 2006 by cnwdad1
//
// Purpose:		See superclass implementation.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 06 Mar 2008	cnwkpd1		PAR #16010 - CCMS Otago 1502 - Thin Client RT Enhancements
//							Add in new tables
// --------------------------------------------------------------------------------
vars
	backColorGen	: Integer;
	foreColorGen	: Integer;
	backColorTables	: Integer;
	foreColorTables	: Integer;
	numControls		: Integer;
	controlIndex	: Integer;
	controlObj		: Control;
	
begin
	inheritMethod();
	
	backColorGen	:=	app.colorBackGeneral;
	foreColorGen	:=	app.colorForeGeneral;
	backColorTables	:=	app.colorBackTables;
	foreColorTables	:=	app.colorForeTables;
	numControls		:=	self.controlCount();
	
	// In JADE 6.0, changing the background color of a Folder or Sheet control from
	// anything but the default Color_3DFace, will override the Folder::tabActiveColor
	// and Folder::tabInactiveColor settings, so instead we've painted a large
	// borderless GroupBox control on all of the Sheets of all Folders, and instead
	// we set the background color of the GroupBox.  This "bug" has been corrected in
	// JADE 6.1.
	
	foreach controlIndex in 1 to numControls do
		controlObj	:=	self.controls(controlIndex);
		
		if controlObj.isKindOf(Label)
//		or controlObj.isKindOf(Folder)
		or controlObj.isKindOf(Frame)
//		or controlObj.isKindOf(Sheet)
		or controlObj.isKindOf(Table)
		then
			controlObj.setBackForeColor(backColorGen, foreColorGen);
		endif;
	endforeach;
	
	tblDataToDo.mbSetFixedColors(backColorTables, foreColorTables);
	tblDataGrade.mbSetFixedColors(backColorTables, foreColorTables);
	
	self.tblContSrchRes.mbSetFixedColors(backColorTables, foreColorTables);		// PAR #16010
	self.tblQueueEntries.mbSetFixedColors(backColorTables, foreColorTables);
	
	self.tblResults.mbSetFixedColors( backColorTables, foreColorTables );
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doBtnAcceptClick" id="56f892ce-5f84-4081-bc7c-b1f0e60dccbe">
        <updating/>
        <source>doBtnAcceptClick(_btn : Button input) protected, updating;

/*

Date		Who		Reason
12 Jan 2006	cnwdvb1	Created 
12 Mar 2008	cnwkpd1	PAR #16010 - CCMS Otago 1502 - Thin Client RT Enhancements

*/

vars

begin
	if self.aState = RadioTelemetryGuiAgent.LoggedOnReset
	or self.aState = RadioTelemetryGuiAgent.Display_TI
	or self.aState = RadioTelemetryGuiAgent.Display_TI_Search_Results		// PAR #16010
	or self.aState = RadioTelemetryGuiAgent.Display_Show_Queue_Entries		// PAR #16010
	or self.aState = RadioTelemetryGuiAgent.LoggedOnReset
	or self.aState = RadioTelemetryGuiAgent.ActionedMove
	then
		if self.aShowNumberOfQueueEntries then								// PAR #16010
			self.doFindAllAvailableQEntries();
		else
			self.doRequestTask(false);
		endif;
	// Darrell. I'm going to provide a note to turn this off.
	//	btnAccept.picture	:=	null;
	elseif self.aState = RadioTelemetryGuiAgent.OfferedTask then
		self.doAcceptTask();
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doBtnPickupClick" id="f1314061-3167-4164-abbc-4448cf45405a">
        <updating/>
        <source>doBtnPickupClick() protected, updating;
// -------------------------------------------
// Created 12 January 2006 by cnwdvb1
// -------------------------------------------
vars

begin
	if self.aState = RadioTelemetryGuiAgent.AcceptedTask then
		if self.aQueueTaskType = TASK_DIRECTOR_DESC then
			self.doAllocatedTIToDirectorTask();
		else
			self.doPickupWithTask();
		endif;
		
	elseif self.aState = RadioTelemetryGuiAgent.ActionedPickupWithTask then
		self.doSetdownWithTask();
		//epr par 11737 21 June 2006
		if self.automaticGetNextTask() then
			self.doRequestTask(true);
		endif;
		
	elseif self.aState = RadioTelemetryGuiAgent.Display_TI or self.aState = RadioTelemetryGuiAgent.ActionedMove then
		//self.doPickup();
		self.doMove();
		
	elseif self.aState = RadioTelemetryGuiAgent.ActionedPickup then
		self.doSetdown();
		
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
