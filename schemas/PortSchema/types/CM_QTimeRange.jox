    <JadeMethod name="populateControlWithSearchValue" id="0e93c476-0917-4ed3-a241-6d43fd348b6a">
        <source>populateControlWithSearchValue(_controlArray: ObjectArray input);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14 May 2012	cnwndl1	Initial creation	Par 29532

*/

vars
	txtTo,
	txtFrom			: TextBox;
begin
	if _controlArray = null or _controlArray.size &lt; 2 then
		return;
	endif;
	
	txtFrom := _controlArray[1].TextBox;
	txtTo := _controlArray[2].TextBox;
	
	if txtFrom = null then
		return;
	endif;
	
	txtFrom.text := self.fromTime.String;

	if txtTo = null then
		return;
	endif;
	
	txtTo.text := self.toTime.String;		

end;</source>
        <Parameter name="_controlArray" type="ObjectArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setFromTime" id="5c6144b0-2c96-488e-97c5-804c6dcab99f">
        <updating/>
        <source>setFromTime(_time : Time) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 Nov 2019	jlger1	Initial creation TFS 47457

*/

vars

begin
	self.fromTime:=_time;
epilog

end;</source>
