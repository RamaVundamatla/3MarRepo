    <JadeMethod name="validateAbstractData" id="8646588c-149f-4857-ac9d-33a2eff8fa81">
        <updating/>
        <source>validateAbstractData(
	rootObject : Root;
	existingWorkbookDefinition : WorkbookDefinition;
	associatedObject : Object;
	associatedObjectName : String;
	associatedObjectType : String) : Boolean updating;


/*****************************************************
	Written by	:	cnwrh3		10 November 2004
	Description	:	Validates data in an abstract fashion, so this method can be used to support different interfaces.

	Change history
	--------------
	Date		By		Reason
******************************************************/

vars
	
	
begin
	if associatedObject = null or associatedObjectName = null or associatedObjectType = null then
		self.errorMessage := "Either the associated object, the associated object name or associated object type was not provided for this workbook definition.";
		self.errorFieldName := "associatedObject";
	elseif self.workbookName = null then
		self.errorMessage := "Please enter the workbook name";
		self.errorFieldName := "workbookName";
		return false;
	elseif (existingWorkbookDefinition = null or existingWorkbookDefinition.workbookName &lt;&gt; self.workbookName.trimBlanks())
	and rootObject.allWBDefnsByNameandAssocName.getAtKey(self.workbookName,associatedObjectName) &lt;&gt; null then
		self.errorMessage := "The workbook name that you have entered is not unique" &amp; CrLf	&amp; "for the associated " &amp; associatedObjectName;
		self.errorFieldName := "workbookName";
		return false;
	elseif self.workbookDescription = null then
		self.errorMessage := "Please enter a workbook description";
		self.errorFieldName := "workbookDescription";
		return false;
	elseif self.workbookDataWorksheet = null then
		self.errorMessage := "Please enter the workbook source data worksheet name";
		self.errorFieldName := "workbookDataWorksheet";
		return false;
	elseif self.workbookTopWorksheet = null then
		self.errorMessage := "Please enter the name of the worksheet to appear on top";
		self.errorFieldName := "workbookTopWorksheet";
		return false;
	elseif self.workbookDataWorksheet = self.workbookTopWorksheet then
		self.errorMessage := "The Source Data and Top worksheets must have unique names.";
		self.errorFieldName := "workbookDataWorksheet";
		return false;
	endif;
	
	self.errorFieldName := "";
	self.errorMessage := "";
	
	return true;
end;</source>
        <Parameter name="rootObject" type="Root"/>
        <Parameter name="existingWorkbookDefinition" type="WorkbookDefinition"/>
        <Parameter name="associatedObject" type="Object"/>
        <Parameter name="associatedObjectName" type="String"/>
        <Parameter name="associatedObjectType" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateStep1Data" id="9a21bd40-3866-4426-8a69-68a2776b4441">
        <updating/>
        <source>validateStep1Data() : Boolean updating;

vars
	errorTitle : String;
	controlToFocus : Window;
	
begin
	if not self.validateAbstractData(
		self.myExcelWorkbookDefnDA.myRoot, 
		self.myExcelWorkbookDefnDA.myWorkbookDefinition, 
		self.myExcelWorkbookDefnDA.myAssociatedObject,
		self.myExcelWorkbookDefnDA.associatedObjectName,
		self.myExcelWorkbookDefnDA.associatedObjectType) then
		
		if errorFieldName = "workbookName" then
			errorTitle := "Workbook Name";
			controlToFocus := self.myForm.ExcelDefnWizStep1Form.txtWorkbookName;
		elseif errorFieldName = "workbookDescription" then
			errorTitle := "Workbook Description";
			controlToFocus := self.myForm.ExcelDefnWizStep1Form.txtWorkbookDesc;
		elseif errorFieldName = "workbookDataWorksheet" then
			errorTitle := "Data Worksheet Name";
			controlToFocus := self.myForm.ExcelDefnWizStep1Form.txtDataWSName;
		elseif errorFieldName = "workbookTopWorksheet" then
			errorTitle := "Top Worksheet Name";
			controlToFocus := self.myForm.ExcelDefnWizStep1Form.txtTopWS;
		else
			errorTitle := "Error";
			controlToFocus := null;
		endif;
		
		app.msgBox(self.errorMessage, errorTitle, MsgBox_OK_Only);
		
		if controlToFocus &lt;&gt; null then
			controlToFocus.setFocus();
		endif;
		
		return false;
	endif;
	
	return true;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
