// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	inheritMethod(index);

end;</source>
        <Parameter name="index" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="removeItemObjWithIndex" id="fd956929-613f-4dac-8227-96e4ae037630">
        <updating/>
        <source>removeItemObjWithIndex(_obj : Object; _idx : Integer) updating;
// ---------------------------------------------------------------------------
// Created:     4 July 2006 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	rowIdx	: Integer;
	
begin

/*	if (not self.findObjectInRow(_obj, rowIdx)) then
		// object not in table
		return;
	endif;*/
	
	self.removeItem(_idx);
	
	if self.allTableObjects &lt;&gt; null and self.allTableObjects.includes(_obj) then
		self.allTableObjects.removeObject(_obj.CM_Object);
	endif;
	
	if self.allSelectedObjects.includes(_obj) then
		self.allSelectedObjects.remove(_obj);
	endif;

end;</source>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_idx" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="removeItemObject" id="92a70dcb-9461-4d3c-a1dc-e1bc8d560210">
        <updating/>
        <source>removeItemObject(_obj : Object) updating;
// ---------------------------------------------------------------------------
// Created:     4 July 2006 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	rowIdx	: Integer;
	
begin

	//jlier1 10/6/25 MTN-34771
	if self.isPaginated then
		
		if self.row &gt; 1 and self.row &lt; self.rows then
			if self.accessRow(self.row) &lt;&gt; null and self.accessRow(self.row).itemObject = _obj then
				self.fromRowColumnChanged:=true;
				self.deselectRow(self.row); //jlier1 35762 19/8/25
			endif;
		endif;
		
		self.removeKeyValForPagination(_obj);
		
		self.allSelectedObjects.tryRemove(_obj);
		if self.myInitialSelectObject = _obj then
			self.myInitialSelectObject:=null;
		endif;
		//23/06/2025	navkc1 JIRA MTN 34973
		if self.isPaginatedNotification() then
			self.doPaginatedNoteDelete(_obj.CM_Object);
		endif;
		
		self.refreshEntries(null);
		return;
	endif;

	if (not self.findObjectInRow(_obj, rowIdx)) then
		// object not in table
		return;
	endif;
	
	self.removeItem(rowIdx);
	
	if self.allTableObjects &lt;&gt; null and self.allTableObjects.includes(_obj) then
		self.allTableObjects.removeObject(_obj.CM_Object);
	endif;
	
	if self.allSelectedObjects.includes(_obj) then
		self.allSelectedObjects.remove(_obj);
	endif;

end;</source>
        <Parameter name="_obj" type="Object"/>
    </JadeMethod>
    <JadeMethod name="removeKeyValForPagination" id="e95bab86-d8f0-48f9-be04-e86bd966809c">
        <source>removeKeyValForPagination(_obj : Object);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 June 2025	jlier1	Initial creation JIRA MTN-34771

*/

vars
	coll : Collection;	
	keyStr1,
	keyStr2,
	keyStr3		: Any;
	keyType1,
	keyType2,
	keyType3	: Type;
	colId,
	idx			: Integer;
	sortEtRows	: EntTableRowArray;
	iter : Iterator;
begin
	coll:=self.getCollection;
	
	if coll = null then
		return;
	endif;
	
	if not coll.isKindOf(DynaDictionary) then
		coll.tryRemove(_obj);
		return;
	endif;
	
	create sortEtRows transient;
	
	foreach idx in 1 to self.allTblDataSortColumns.size() do
		sortEtRows.tryAdd(self.getEntRowColumnByRowName(self.allTblDataSortColumns[idx], colId));
	endforeach;
	if sortEtRows.isEmpty() then
		return;
	endif;
	
	iter:=coll.createIterator;
	iter.startAtObject(_obj);
	if sortEtRows.size() = 1 then
		coll.DynaDictionary.getIteratorKeys(keyStr1,iter);
	elseif sortEtRows.size() = 2 then
		coll.DynaDictionary.getIteratorKeys(keyStr1,keyStr2,iter);
	elseif sortEtRows.size() &gt;= 3 then
		coll.DynaDictionary.getIteratorKeys(keyStr1,keyStr2,keyStr3,iter);
	endif;

	keyType1 := self.convertInputTypeToPrimType(sortEtRows[1].inputType);
	if sortEtRows.size() = 1 then
		coll.DynaDictionary.tryRemoveKeyEntry(keyStr1.String.asAnyOfType(keyType1), _obj);
		return;
	endif;
	
	keyType2 := self.convertInputTypeToPrimType(sortEtRows[2].inputType);
	if sortEtRows.size() = 2 then
		coll.DynaDictionary.tryRemoveKeyEntry(keyStr1.String.asAnyOfType(keyType1), keyStr2.String.asAnyOfType(keyType2), _obj);
		return;
	endif;
	

	keyType3 := self.convertInputTypeToPrimType(sortEtRows[3].inputType);
	coll.DynaDictionary.tryRemoveKeyEntry(keyStr1.String.asAnyOfType(keyType1), keyStr2.String.asAnyOfType(keyType2), keyStr3.String.asAnyOfType(keyType3), _obj);
epilog
	delete iter;

end;</source>
        <Parameter name="_obj" type="Object"/>
    </JadeMethod>
    <JadeMethod name="resetColumns" id="cea53cdd-dc6c-49bb-ba17-99ba61862e3b">
        <updating/>
        <source>resetColumns(_clearTable : Boolean) updating;
//--------------------------------------------------------------
//Created: 20 June 2005 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	
	self.setColumns(_clearTable);
	
end;</source>
        <Parameter name="_clearTable" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="resetColumnsToMaxOf" id="e2286e55-458b-4f48-8601-3b5404dd7646">
        <updating/>
        <source>resetColumnsToMaxOf( _maxCols : Integer )updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 March 2021	navndl1	Initial creation	TFS 50796

*/

vars

	localArray : EntTableRowArray;
	entRow : EntTableRow;
	newColsSize : Integer;
	index : Integer;

begin

	create localArray transient;
	self.allTblDataEntRows.copy( localArray );
	
	newColsSize := localArray.size.min( _maxCols );
	
	self.allTblDataEntRows.clear;
	foreach index in 1 to newColsSize do
		self.allTblDataEntRows.add( localArray[index] );
	endforeach;
	
	self.resetColumns(true);

epilog

	delete localArray;

end;</source>
        <Parameter name="_maxCols" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="resetHeight" id="c1485ccd-a2ac-412d-b9d9-795993e7cfb6">
        <updating/>
        <source>resetHeight() updating;
// ---------------------------------------------------------------------------
// Created:     19 November 2002		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	theRow,
	theRowHeight		: Integer;
	fixedRowHeight		:Integer;
begin
	if self.rows = 0 then
		return;
	endif;
	
	if self.fixedRows &gt; 0 then
		theRow:=1 ;
		while theRow &lt;= self.fixedRows do
			theRowHeight:= theRowHeight +self.accessRow(theRow).height;
			theRow:=theRow + 1;
		endwhile;
		self.height:= theRowHeight;
		theRowHeight:=0;
	endif;
	
	if self.rows &gt; self.fixedRows then
		theRowHeight := self.accessRow(self.fixedRows + 1).height;
	endif;
	
	self.height :=self.height +  (theRowHeight * (self.rows - self.fixedRows));
	
end;</source>
    </JadeMethod>
    <JadeMethod name="resortForPagination" id="8a4c5328-8802-425b-8e91-233358148a28">
        <updating/>
        <source>resortForPagination(_coll : Collection) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 Mar 2025	navnk30	JIRA 34245: Develop a generic solution to show data in a CM_DataTable using "Pagination"
03 Apr 2025 navnk30 JIRA 34552: Pagination - Issue sorting Columns with Date/Time fields
09 Jun 2025 jlier1  JIRA 34771 : Inital load needs to be sorted - and when column sorting.  Also for multi select need the  display collection to be the dyna dict. Even if empty dict still attach as collection.
10 Jun 2025 jlier1 JIRA 35394 : Error 1322 - even though max key length is 512 if we have 3 keys it adds a terminating char so would be max of 169.66 so 170 is not enough
*/

constants
	MAX_KEY_LEN_LIMIT	: Integer = 169;
	MAX_SORT_COLS		: Integer = 3;
vars
	dynaDict		: DynaDictionary;
	rowName			: String;
	sortColNames	: StringArray;
	descend			: Boolean;
	entRow			: EntTableRow;
	objColl			: Collection;
	tmpCol,
	idx				: Integer;
	frm				: CM_BaseForm;
	entry			: Object;
begin
	sortColNames := self.allTblDataSortColumns;
	if sortColNames.isEmpty() then
		return;
	endif;
	
	create dynaDict transient;
	dynaDict.setMembership(Object);
	if _coll &lt;&gt; null then
		objColl:=_coll;
	else
		objColl := self.getCollection();
	endif;
	
	
	foreach idx in 1 to sortColNames.size() do
		rowName := sortColNames[idx];
		descend := self.allTblDataSortDescending[idx];
		entRow	:= self.getEntRowColumnByRowName(rowName, tmpCol);
		//dynaDict.addExternalKey(String, 83, descend, false);						//03.04.2025 navnk30 JIRA 34552
		dynaDict.addExternalKey(self.convertInputTypeToPrimType(entRow.inputType),	//03.04.2025 navnk30 JIRA 34552
					MAX_KEY_LEN_LIMIT,
					descend,
					false);
		if idx &gt;= MAX_SORT_COLS then
			break;
		endif;
	endforeach;
	dynaDict.endKeys(true);
	
	foreach entry in objColl as Object do
		self.addKeyValForPagination(dynaDict, entry);
	endforeach;
	frm := self.form.CM_BaseForm;
	self.displayRowsPaginated(dynaDict, frm);
epilog
	if _coll = null and objColl.isTransient then
		delete objColl;
	endif;	
end;</source>
        <access>protected</access>
        <Parameter name="_coll" type="Collection"/>
    </JadeMethod>
    <JadeMethod name="resortTableByColumn" id="f8520a18-83ad-47ff-802c-9e93f3ba7927">
        <updating/>
        <source>resortTableByColumn(_column : Integer)updating;
//--------------------------------------------------------------
//Created: 05 September 2002 By: cnwgd1
// 13 Mar 2025	navnk30	JIRA 34245: Develop a generic solution to show data in a CM_DataTable using "Pagination"
// 25/03/2025	navcs2	MTN-34327 CUX | Cargo Review Screen - Weight sorting alphabetically
//--------------------------------------------------------------
vars
	theSortCol,
	theSortType		: Integer;
	tmpStr			: String;
	entRow,
	entRowFirst		: EntTableRow;
	crit			: CM_SelectorCriteriaLine;		// 25/03/2025	navcs2	MTN-34327 
	pos				: Integer;						// 25/03/2025	navcs2	MTN-34327
begin
	//th2 PAR12069 - if the sort column is different from the previous sort column
	//it should initially sort ascending. If the same column as previous, it should be descending
	if self.sortColumn[1] &lt;&gt; _column then
		self.sortAscending := true;
	else
		self.sortAscending := not self.sortAscending;
	endif;
	/*
	if self.sortAscending  then
		self.sortAscending := false;
	else
		self.sortAscending := true;
	endif;
	*/
	//Don't clear the sort columns, make this one the first one to sort by
	//self.allTblDataSortColumns.clear();
	//self.allTblDataSortDescending.clear();

	if _column &gt; 0 and _column &lt;= self.columns  and _column &lt;= self.allTblDataEntRows.size then	
		// if column already part of sort order then remove it
		entRow := self.allTblDataEntRows[_column];
		self.zRemoveSortColumn(entRow.name);
		// remove first sort key
		entRowFirst := self.allTblDataEntRows[1];
		self.zRemoveSortColumn(entRowFirst.name);
		// insert new column in sort order
		self.allTblDataSortColumns.insert(1, entRow.name);
		self.allTblDataSortDescending.insert(1, not self.sortAscending);
	endif;	
	
	if self.allTableObjects &lt;&gt; null and (not self.allTableObjects.noKeys()) then
		self.setSortColumnsForMaxNumCols();	
		self.form.CM_BaseForm.setTableDataFromOrganiser(self);
	else
	
		theSortCol := self.sortColumn[1];
		if theSortCol &gt; 0 and self.fixedRows &gt; 0 then
			self.accessCell(self.fixedRows, theSortCol).fontBold := false;
		endif;

		// DVB 16/02/04 Changed code to look up visible selected column rather than invisible because
		// there is no corresponding entRow on form and it causes an exception.
		// Still sorts on invisible column though.
		
		theSortCol := _column;
	
		if theSortCol &lt; self.columns then
			if (not self.accessColumn(theSortCol + 1).visible) then
				tmpStr := self.accessCell(1, theSortCol + 1).text;
				if tmpStr &lt;&gt; null and tmpStr[1:1] = SortColHeadingPrefix then
					theSortCol := theSortCol + 1;
				endif;
			endif;
		endif;
		
		self.sortColumn[1]	:= theSortCol;    
		self.sortAsc[1]		:= self.sortAscending;
		self.sortCased[1]	:= false;
	
		if entRow &lt;&gt; null then
			theSortType := self.convertInputTypeToSortType(entRow.inputType);
			self.sortType[1] := theSortType;
		// 25/03/2025	navcs2	MTN-34327 Start
		else
			if self.form.isKindOf(CMUI_CargoReview) then
				foreach crit in self.form.CMUI_CargoReview.myCriteriaLineHolder.allCriteriaLines do
					if crit.propName.cnContains("_") then
						pos := 1;
						if app.myRoot.allMeasurementTypesByShortName[crit.propName.scanUntil("_", pos)] &lt;&gt; null then
							theSortType := Table.SortType_Numeric;
							break;
						endif;
					endif;
				endforeach;
				self.sortType[1] := theSortType;
			endif;
		endif;
		// 25/03/2025	navcs2	MTN-34327 End

		if self.isPaginated() then			//13.03.2025 navnk30 JIRA 34245
			self.resortForPagination(null);
		else
			self.resort;
		endif;
	endif;

end;</source>
        <Parameter name="_column" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="resortTableByColumnEntRow" id="9b98fd1a-16d3-4daf-b37c-12d00f3b4e2c">
        <updating/>
        <source>resortTableByColumnEntRow(_column : Integer; _entRow: EntTableRow)updating;
/*

Purpose:	

Parameters:			

Return Value:		

Date		Who			Reason
11 March 2025	navcs2	MTN-34327 CUX | Cargo Review Screen - Weight sorting alphabetically

*/
vars
	theSortCol,
	theSortType		: Integer;
	tmpStr			: String;
	entRowFirst		: EntTableRow;
	crit			: CM_SelectorCriteriaLine;
begin

	if self.sortColumn[1] &lt;&gt; _column then
		self.sortAscending := true;
	else
		self.sortAscending := not self.sortAscending;
	endif;
	
	if _column &gt; 0 and _column &lt;= self.columns  and _column &lt;= self.allTblDataEntRows.size then			
		// remove first sort key
		entRowFirst := self.allTblDataEntRows[1];
		self.zRemoveSortColumn(entRowFirst.name);
		// insert new column in sort order
		self.allTblDataSortColumns.insert(1, _entRow.name);
		self.allTblDataSortDescending.insert(1, not self.sortAscending);
	endif;	
	
	if self.allTableObjects &lt;&gt; null and (not self.allTableObjects.noKeys()) then
		self.setSortColumnsForMaxNumCols();	
		self.form.CM_BaseForm.setTableDataFromOrganiser(self);
	else
		theSortCol := self.sortColumn[1];
		if theSortCol &gt; 0 and self.fixedRows &gt; 0 then
			self.accessCell(self.fixedRows, theSortCol).fontBold := false;
		endif;
		theSortCol := _column;
		if theSortCol &lt; self.columns then
			if (not self.accessColumn(theSortCol + 1).visible) then
				tmpStr := self.accessCell(1, theSortCol + 1).text;
				if tmpStr &lt;&gt; null and tmpStr[1:1] = SortColHeadingPrefix then
					theSortCol := theSortCol + 1;
				endif;
			endif;
		endif;
		
		self.sortColumn[1]	:= theSortCol;    
		self.sortAsc[1]		:= self.sortAscending;
		self.sortCased[1]	:= false;
		
		if _entRow &lt;&gt; null then
			theSortType := self.convertInputTypeToSortType(_entRow.inputType);
			self.sortType[1] := theSortType;
		else
			if self.form.isKindOf(CMUI_CargoReview) then
				foreach crit in self.form.CMUI_CargoReview.myCriteriaLineHolder.allCriteriaLines do
					if crit.propName.cnContains("_") then
						if app.myRoot.allMeasurementTypesByShortName[crit.propName] &lt;&gt; null then
							theSortType := Table.SortType_Numeric;
						endif;
					endif;
				endforeach;
			endif;
		endif;
		
		self.resort;
	endif;
end;</source>
        <Parameter name="_column" type="Integer"/>
        <Parameter name="_entRow" type="EntTableRow"/>
    </JadeMethod>
    <JadeMethod name="rowColumnChg" id="7860dd8c-9165-443c-b771-f761bee4f911">
        <updating/>
        <source>rowColumnChg(table: Table input) updating;
// ---------------------------------------------------------------------------
// Created:     06 June 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 16/07/2008	cnwdad1		PAR #15765.
// 09/02/2011	cnwcs5		CCMS JML 1114/PAR 26847 - fixed bug where control event being called B4
//													  row was selected.
// ---------------------------------------------------------------------------
vars
	tmpCtrl		: Control;
	tmpEditMask	: JadeEditMask;
begin
	//self.fromRowColumnChanged := true;// PAR 33761 
	//jlier1 9/6/25 MTN-34771
	
	if table.row &gt; table.fixedRows then
		if self.selectionType = self.SelectionType_Row then 
			self.selectTheCurrentRow(table.row);
		endif;
	endif;
	// event methods get invoked after current row is selected
	inheritMethod(table);
	
	if table.row = 0 then
		return;
	endif;
	//epr par 34877 16/9/14 just use table.row to avoid invalid row errors
	tmpCtrl := table.accessCell(table.row, table.column).cellControl;

	if tmpCtrl &lt;&gt; null then
		if tmpCtrl.isKindOf(JadeEditMask) then
			tmpEditMask := tmpCtrl.JadeEditMask;
			// reset the mask otherwise the selectionStyle does not
			// always work correctly in all circumstances
			tmpEditMask.autoTab := false;
			tmpEditMask.selectionStyle	:=	JadeEditMask.SelectionStyle_Select;
			
		elseif tmpCtrl.isKindOf(TextBox) then
			tmpCtrl.TextBox.selectionStyle	:=	TextBox.SelectionStyle_SelectAllAlways;
			
		endif;
	endif;
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="searchAllRowsColumns" id="cead48a6-4932-46ff-b379-248b70b4ffc8">
        <updating/>
        <source>searchAllRowsColumns(_string: String; _startRow, _startColumn: Integer): ObjectSet updating; 
/*

Purpose:	Returns an array of the objects whose row in the table contains the search string provided		

Parameters:			

Return Value:		

Date		Who		Reason
13 May 2024	navcs2	ChangeRequest 59188: EUP | API Search - External Webservice Monitor

*/

vars
	returnArray		: ObjectSet;
	endRow,
	startRow,
	idx,
	idy,
	startColumn,
	endColumn		: Integer;
	theObject		: CM_Object;
	searchString	: String;
	regexPattern	: JadeRegexPattern;
begin
	create regexPattern transient;
	regexPattern.compile(_string);
	regexPattern.setIgnoreCase(true);
	
	create returnArray transient;
	endColumn		:= self.columns;
	endRow 			:= self.rows;
	startRow		:= _startRow;
	startColumn		:= _startColumn;
	
	if _startRow = 0 then
		startRow := 1;
	endif;
	
	if _startColumn = 0 then
		startColumn := 1;
	endif;
	
	foreach idx in startRow to endRow do
		foreach idy in startColumn to self.columns do 
			if regexPattern.isMatch(self.accessCell(idx, idy).text) then
				theObject := self.accessRow(idx).itemObject.CM_Object;
				returnArray.tryAdd(theObject);
			endif;
		endforeach;
	endforeach;
	
	return returnArray;
epilog

end;</source>
        <Parameter name="_string" type="String"/>
        <Parameter name="_startRow" type="Integer"/>
        <Parameter name="_startColumn" type="Integer"/>
        <ReturnType type="ObjectSet"/>
    </JadeMethod>
    <JadeMethod name="selectAll" id="76dc795e-afec-4eb7-a8a7-0f23e0904586">
        <updating/>
        <source>selectAll()updating;
//--------------------------------------------------
// Created:	11 September 2003 By: cnwgd1
//--------------------------------------------------
vars
	numRows,
	rowIdx		: Integer;
	jRow		: JadeTableRow;
begin
	numRows := self.rows;
	self.clearAllSelected();

	//jlier1 JIRA-35555 24/7/25
	if  self.isPaginated then
		self.getCollection.copy(self.allSelectedObjects);
	endif;
	
	foreach rowIdx in self.fixedRows to numRows do
		jRow := self.accessRow(rowIdx);
		if not jRow.visible then
			//only select visible rows PAR 11045
			continue;
		endif;
				
		//epr par 23089 15/3/10
		self.selectRow(rowIdx,false);
		
	endforeach;

end;</source>
    </JadeMethod>
    <JadeMethod name="selectAllCells" id="76c16c39-323f-4e71-8b1c-ff4ef29bdee5">
        <updating/>
        <source>selectAllCells()updating;
//--------------------------------------------------
// Created:	11 September 2003 By: cnwgd1
//--------------------------------------------------
vars
	numRows,
	numCols,
	rowIdx, 
	colIdx		: Integer;
	tmpCell		: JadeTableCell;
begin
	numRows := self.rows;
	numCols := self.columns;

	foreach rowIdx in self.fixedRows+1 to numRows do
		if not self.accessRow(rowIdx).visible then
			continue;
		endif;
		foreach colIdx in self.fixedColumns+1 to numCols do
			if not self.accessColumn(colIdx).visible then
				continue;
			endif;
			
			self.accessCell(rowIdx, colIdx).selected := true;
		endforeach;
	endforeach;

end;</source>
    </JadeMethod>
    <JadeMethod name="selectObject" id="db80a7e2-d670-4e86-bd75-2b416482d174">
        <updating/>
        <source>selectObject(_obj : Object; _makeTopRow : Boolean) : Boolean updating;
// ---------------------------------------------------------------------------
// Created:     15 September 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	rowIdx,
	colIdx	: Integer;
	
begin


	if (not self.findObjectInRow(_obj, rowIdx)) then
		// object is not in the table
		//if app.isDevelopmentSystem then
		
		//endif;
		return false;
	endif;

	//epr par 15/3/10 23089
	return self.selectRow(rowIdx,_makeTopRow);

end;</source>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_makeTopRow" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="selectRow" id="b3ac98cc-aa60-42e1-970a-daf1e876ccbc">
        <updating/>
        <source>selectRow(_idx : Integer; _makeTopRow : Boolean) : Boolean updating;
// ---------------------------------------------------------------------------
// Created:     15 September 2002 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
// 25/03/2010		cnwcs5	par 22602 - moved call to interface method
vars
	theObj	: Object;
	theRow	: JadeTableRow;		
	dtInterface : IF_CM_DataTable;
begin

	if _idx &lt;= self.fixedRows or _idx &gt; self.rows then
		return false;
	endif;

	theRow 			:= self.accessRow(_idx);
	theRow.selected := true;
	
	
	if _makeTopRow then
		self.topRow := _idx;
	endif;
	
	theObj 		:= theRow.itemObject;
	self.row 	:= _idx;
	
/*	dtInterface:= self.getIF_CM_DataTable;
	if dtInterface &lt;&gt; null then
		dtInterface.selectRow(self,_idx);
	endif;
*/	
	if theObj &lt;&gt; null then
		if (not self.allSelectedObjects.includes(theObj)) then
			self.allSelectedObjects.add(theObj);
		endif;
	endif;
	// par 22602 - start
	dtInterface:= self.getIF_CM_DataTable;
	if dtInterface &lt;&gt; null then
		dtInterface.selectRow(self,_idx);
	endif;
	// par 22602 - end
	return true;

end;</source>
        <Parameter name="_idx" type="Integer"/>
        <Parameter name="_makeTopRow" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="selectTheCurrentRow" id="38ab0663-4a0f-4992-95c3-6bc499e5d986">
        <updating/>
        <source>selectTheCurrentRow(_row : Integer) updating;

vars
	rowObj		: JadeTableRow;
	theObject	: Object;
	isSelected	: Boolean;

begin

	
// cnwdad1 14/12/2005.
//	if _row &lt;= 0 then
	if _row &lt;= self.fixedRows then
		return;
	endif;

	//jlier1 9/6/25 MTN-34771
	if not self.fromRowColumnChanged then
		return;
	endif;
	
	rowObj	:=	self.accessRow(_row);
	
	if self.controlKeyDown then
		isSelected	:=	(not rowObj.selected);
	else
		self.clearAllSelected();
		isSelected	:=	true;
	endif;
	

	theObject	:=	rowObj.itemObject;
	
	//epr par 23089 15/3/10 
	if rowObj.selected or  theObject = null then
		self.deselectRow(_row);
	else
		self.selectRow(_row,false);
	endif;
	
	
end;</source>
        <Parameter name="_row" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setBackColor" id="1fc72ff1-1b08-431d-93c8-9a00ab41180d">
        <updating/>
        <source>setBackColor(_rowIndex : Integer; _column : Integer; _color : Integer) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 August 2025	naviv1	Initial creation

*/

vars

begin	
	if _column &lt;&gt; null then
		self.accessCell(_rowIndex,_column).backColor := _color;
	endif;
epilog

end;</source>
        <Parameter name="_rowIndex" type="Integer"/>
        <Parameter name="_column" type="Integer"/>
        <Parameter name="_color" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setCellControl" id="d9b77e9c-5b5d-472f-b87e-69170c0c5768">
        <updating/>
        <source>setCellControl(_rowIndex : Integer; _column : Integer; _control : Any) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 August 2025	naviv1	Initial creation

*/

vars

begin
	if _column &lt;&gt; null then
		if _control.isKindOf(CMUI_TextBox) then
			self.accessCell(_rowIndex,_column).cellControl := _control.CMUI_TextBox;
		elseif _control.isKindOf(CMUI_ComboBox) then
			self.accessCell(_rowIndex,_column).cellControl := _control.CMUI_ComboBox;
		endif;
	endif;

epilog

end;</source>
        <Parameter name="_rowIndex" type="Integer"/>
        <Parameter name="_column" type="Integer"/>
        <Parameter name="_control" type="Any"/>
    </JadeMethod>
    <JadeMethod name="setCellValueByName" id="550dee1c-8b74-4d01-9bba-96dab0c93511">
        <updating/>
        <source>setCellValueByName(_heading : String; _theRow : Integer;_theValue : String) updating;
// ---------------------------------------------------------------------------
// Created:		December 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	theColumn : Integer;
begin
	theColumn := self.getColumnByRowName(_heading);
	
	if theColumn &gt; 0 then
		self.accessCell(_theRow,theColumn).text := _theValue;
	endif;
end;</source>
        <Parameter name="_heading" type="String"/>
        <Parameter name="_theRow" type="Integer"/>
        <Parameter name="_theValue" type="String"/>
    </JadeMethod>
    <JadeMethod name="setColWidthsFromUserWindow" id="fa66204f-385c-4105-8936-d34d9de9dc53">
        <updating/>
        <source>setColWidthsFromUserWindow(_userWindow : CM_UserWindow)updating, protected;
//--------------------------------------------------------------
//Created: 14 January 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	tmpStr,
	tmpTblName,	
	tmpColWidths,
	tmpColHeading	: String;
	startPos,
	idx,
	numCols,
	pos				: Integer;
	tmpArray		: StringArray;
	
begin

	if _userWindow = null then
		return;
	endif;
	
	pos := 1;	
	startPos := 1;

	tmpTblName := _userWindow.xmlInfo.cnEcGetNextTagValueOfName(XMLTag_Table &amp; self.name, startPos);
	if tmpTblName &lt;&gt; null then
		tmpColWidths := tmpTblName.cnEcGetNextTagValueOfName(XMLTag_ColWidth, pos);
		if tmpColWidths &lt;&gt; null then
			create tmpArray transient;
			tmpColWidths.getTokensForDelimiter(',', tmpArray);
			
			numCols := self.columns;
			foreach tmpStr in tmpArray do
				idx := idx + 1;
				if idx &gt; numCols then
					break;
				endif;
				self.accessColumn(idx).width := tmpStr.Integer;
			endforeach;
		endif;
	endif;	

epilog
	delete tmpArray;
end;</source>
        <access>protected</access>
        <Parameter name="_userWindow" type="CM_UserWindow"/>
    </JadeMethod>
    <JadeMethod name="setColWidthsFromXMLStr" id="105bebe2-078b-4d2b-93c3-b7c62a294da1">
        <updating/>
        <source>setColWidthsFromXMLStr(_xmlStr : String)updating, protected;
//--------------------------------------------------------------
//Created: 7 October 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	tmpStr,
	tmpColWidths	: String;
	idx,
	numCols,
	pos				: Integer;
	tmpArray		: StringArray;
	
begin

	if _xmlStr = null then
		return;
	endif;

	pos := 1;
	tmpColWidths := _xmlStr.cnEcGetNextTagValueOfName(XMLTag_ColWidth, pos);

	if tmpColWidths = null then
		return;
	endif;
	
	create tmpArray transient;
	tmpColWidths.getTokensForDelimiter(',', tmpArray);
	
	numCols := self.columns;
	foreach tmpStr in tmpArray do
		idx := idx + 1;
		if idx &gt; numCols then
			break;
		endif;
		self.accessColumn(idx).width := tmpStr.Integer;
	endforeach;

epilog
	delete tmpArray;
end;</source>
        <access>protected</access>
        <Parameter name="_xmlStr" type="String"/>
    </JadeMethod>
    <JadeMethod name="setColumnHeadingsFromDef" id="9ba4a6d8-ad58-4224-8a32-5f1b5787bb12">
        <updating/>
        <source>setColumnHeadingsFromDef(_defName: String; _isTextEditable: Boolean) updating;
// -------------------------------------------
// Created 18 May 2004 by cnwdvb1
// -------------------------------------------
vars

	
begin

	inheritMethod(_defName, _isTextEditable);
	//self.setMyEntTableDef(def);
//	return def;
	


end;</source>
        <Parameter name="_defName" type="String"/>
        <Parameter name="_isTextEditable" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setColumns" id="cee7f318-fdeb-4ad7-b54f-063735310fe5">
        <updating/>
        <source>setColumns(_clearTable : Boolean) updating, protected;
//--------------------------------------------------------------
//Created: January 2003 By: cnwgd1
// 13 Mar 2025	navnk30	JIRA 34245: Develop a generic solution to show data in a CM_DataTable using "Pagination"
//--------------------------------------------------------------
vars

begin
	
	if self.rows &lt; 1 or _clearTable then
		
		//self.rows := self.fixedRows;		//13.03.2025 navnk30 JIRA 34245
		if self.isPaginated() then			//13.03.2025 navnk30 JIRA 34245
			self.clearAllData();
		else
			self.rows := self.fixedRows;
		endif;
		
		if _clearTable then
			self.clearAllSelected();
		endif;
	endif;
	
	self.removeInvalidSortColumns();

	self.allTblDataColHeadings.clear();
	self.allTblDataColInputTypes.clear();
	self.allTblDataColPropertyNames.clear();
	
	self.addColumns();

	self.zTblDataSetup();
	
	self.setSortColumns();
	
end;</source>
        <access>protected</access>
        <Parameter name="_clearTable" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setColumnsFromDefault" id="93ce1881-80d7-4f1e-a599-8852930089e3">
        <updating/>
        <source>setColumnsFromDefault(_addRowArray : EntTableRowArray) updating, protected;
//--------------------------------------------------------------
//Created: 7 October 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	view : EntTableView;
begin

	if self.myEntTableDef = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Null Def');
		return;
	endif;

	self.allTblDataEntRows.clear();

	//No user defined view so use system default instead
	view := self.myEntTableDef.allEntTableViews[SystemDefault];

	if view = null then	
		//No system default view so use JMT default instead	
		view := self.myEntTableDef.allEntTableViews[Default];
	endif;

	if view = null then
		//No view so use all rows for def instead	
		self.myEntTableDef.allEntTableRows.copy(self.allTblDataEntRows);
	else
		//Use rows for view
		view.allEntTableRows.copy(self.allTblDataEntRows);
	endif;
	
	// add transient row that are not part of the def
	if _addRowArray &lt;&gt; null then
		_addRowArray.copy(self.allTblDataEntRows);
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="_addRowArray" type="EntTableRowArray"/>
    </JadeMethod>
    <JadeMethod name="setColumnsFromOrganiser" id="b295aec1-906b-4e0e-a38a-987807920b75">
        <updating/>
        <source>setColumnsFromOrganiser(_entTblRowArray : EntTableRowArray;_hiddenTblRows : EntTableRowArray)updating;
//--------------------------------------------------------------
//Created: 14 January 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	entTableRow : EntTableRow;
begin

	if (not _entTblRowArray.isEmpty) then
	
		self.allTblDataEntRows.clear;
		_entTblRowArray.copy(self.allTblDataEntRows);
		if _hiddenTblRows &lt;&gt; null then
			foreach entTableRow in _hiddenTblRows do
				if not self.allTblDataEntRows.includes(entTableRow) then
					self.allTblDataEntRows.add(entTableRow);
				endif;
			endforeach;
		endif;
		self.setColumns(false);
	endif;

end;</source>
        <Parameter name="_entTblRowArray" type="EntTableRowArray"/>
        <Parameter name="_hiddenTblRows" type="EntTableRowArray"/>
    </JadeMethod>
    <JadeMethod name="setColumnsFromStringArray" id="03feaed2-d959-4103-a8a0-f5c933022339">
        <updating/>
        <source>setColumnsFromStringArray(_columns : StringArray) updating;
/*
Purpose:	

Date		Who		Reason
01 November 2024	navab1	JIRA 14794
*/

vars
	entTableRow : EntTableRow;
	entTableRowArray : EntTableRowArray;
	rowName : String;
begin
		create entTableRowArray transient;
		
		foreach rowName in _columns do
			entTableRow:= self.myEntTableDef.getEntTableRow(rowName);

			if entTableRow &lt;&gt; null then
				entTableRowArray.add(entTableRow);
			endif;
		endforeach;
		
		self.setColumnsFromOrganiser(entTableRowArray,null);

epilog
	delete entTableRowArray;
end;</source>
        <Parameter name="_columns" type="StringArray"/>
    </JadeMethod>
    <JadeMethod name="setColumnsFromUserWindow" id="b9126502-5495-4d63-beae-49dd97efe253">
        <updating/>
        <source>setColumnsFromUserWindow() : Boolean updating, protected;
//--------------------------------------------------------------
//Created: 14 January 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	tmpTblXML		: String;	
	userWindow		: CM_UserWindow;
	startPos		: Integer;
begin

	userWindow := self.getMyUserWindow();

	if userWindow = null then
		return false;
	endif;
	
	startPos := 1;

	tmpTblXML := userWindow.xmlInfo.cnEcGetNextTagValueOfName(XMLTag_Table &amp; self.name, startPos);

	if tmpTblXML &lt;&gt; null then
		if self.setColumnsFromXMLStr(tmpTblXML) then
			return true;
		endif;
	endif;	
	
	return false;

end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setColumnsFromXMLStr" id="581db635-7245-43b7-a7bf-11c824644938">
        <updating/>
        <source>setColumnsFromXMLStr(_xmlStr : String) : Boolean updating;
//--------------------------------------------------------------
//Created: 7 October 2003 By: cnwgd1
//--------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	------------------------------------------------------
// 19/02/2013	cnwdap1		PAR #31155 CCMS SFW 1321 Imperial Measurements
// 20/03/2015   cnwma1      PAR #35887 Load List - weight not sorted by amount
// 11/05/2015	cmwdap1		PAR #35924 Correct proxy setting for columns of default measurement types
// 14/05/2015	cnwdap1		PAR #36235 Changes for 35924 broke sorting of non-default measurement types
//							EDI form is an exception here, because in edit mode only the default measurement type
// 							can be edited. All other forms need to allow the input type from the ent row to be
//							set, so that sorting on columns works correctly.
// 25 Aug 2025  navhl20 	Story MTN-35317: MTN | Pagination - Work Order Operations
// 18 Sep 2025 	navhl20 	Bug MTN-36084: MTN | Work Order Operations Pagination column issue with view
vars
	entRow				: EntTableRow;
	xmlDef,
	defName,
	tmpColHeading		: String;
	pos					: Integer;
	rowArray			: EntTableRowArray;
	newRow				: EntTableRowProxy;			// PAR #31155
	measurePos			: Integer;					// PAR #31155
	measureType			: String;					// PAR #31155
	rowName				: String;					// PAR #31155
	otherEntRow			: EntTableRow;				// PAR #31155
	newHeading			: String;					// PAR #31155
	alteredHeaderName	: String;
	inputType			: Integer;					// PAR #35887
	measure				: CM_MeasurementType;	// PAR #35924
	found 				: Boolean;	//09 May 2018	NDL	TFS 38460
	addEntRowIfNotFnd 	: Boolean;
	colHead				: String;
begin
	if _xmlStr = null then
		return false;
	endif;

	
	pos := 1;		
	xmlDef := _xmlStr.cnEcGetNextTagValueOfName(XMLTag_EntTblDef &amp; self.myEntTableDef.name, pos);
	if xmlDef = null then
		// no xml for def, defaults will be used
		return false;
	endif;
	
	// ### TFS BUG 64017 07MAY2024 NAVAB1;
	addEntRowIfNotFnd := true;
	if self.myForm &lt;&gt; null 
	and self.myForm.isKindOf(CM_BaseForm) then
		addEntRowIfNotFnd := self.myForm.CM_BaseForm.addEntRowIfNotFound();
	endif;
	
	//epr par 33900 3/4/14 delete proxy measurement table rows before clear
	self.deleteEntTableRowProxy();

	// 19/05/2010 cnwar2 #23932 - moved from above so that ETDef check is made first
	create rowArray transient;
	self.allTblDataEntRows.copy(rowArray);
	
	
	self.allTblDataEntRows.clear;

	pos := 1;
	while (pos &gt; 0) do
		tmpColHeading := xmlDef.cnEcGetNextTagValueOfName(XMLTag_Column, pos);
		if tmpColHeading &lt;&gt; null then
			found := false;//09 May 2018	NDL	TFS 38460
			foreach entRow in rowArray do
				if entRow.name = tmpColHeading then
					self.allTblDataEntRows.add(entRow);
					found := true;	//09 May 2018	NDL	TFS 38460
					break;
				endif;
			endforeach;
			
			if addEntRowIfNotFnd then // ### TFS BUG 64017 07MAY2024 NAVAB1;
				//09 May 2018	NDL	TFS 38460
				if not found then
					foreach entRow in self.myEntTableDef.allEntTableRows do
						if entRow.name = tmpColHeading then
							self.allTblDataEntRows.add(entRow);
							break;
						endif;
					endforeach;
				endif;
			endif;
			
			// PAR #31155 If we have a measurement row heading, add to array of headings								// PAR #31155
		//	if not self.allTblDataEntRows.isEmpty and self.allTblDataEntRows.last.name &lt;&gt; tmpColHeading then			// PAR #31155
			if self.allTblDataEntRows.isEmpty or self.allTblDataEntRows.last.name &lt;&gt; tmpColHeading then	//09 May 2018	TFS 38460 - in case first one is a measurement
				if tmpColHeading.isMeasurementType then																	// PAR #31155
					tmpColHeading.getRowNameMeasureType(rowName, measureType);											// PAR #31155
					newHeading := null;
					// 35440 use the cargo type attribute heading
					alteredHeaderName := self.getCargoTypeAttrHeading(rowName);
					if alteredHeaderName &lt;&gt; null then
						newHeading := alteredHeaderName;
					endif;
					if newHeading = null then
					foreach otherEntRow in rowArray where otherEntRow.name = rowName do									// PAR #31155
						newHeading := otherEntRow.getHeadingUnaltered;													// PAR #31155
						inputType := otherEntRow.inputType;																// PAR #35887
						break;																							// PAR #31155
					endforeach;	
					//31 Oct 2013	NDL	Par 32894 The row isn't declared in the entdef, but might be in the grp.
					if newHeading = null then	
						otherEntRow := self.myEntTableDef.myEntTableGroup.allEntTableRowsByName.getAtKey(rowName);
						if otherEntRow &lt;&gt; null then
							newHeading := otherEntRow.getHeadingUnaltered;
							inputType := otherEntRow.inputType;															// PAR #35887
						endif;
					endif;
					endif;
					if newHeading &lt;&gt; null then
						//01 Nov 2013	NDL	Par 32894
						if self.allTblDataEntRows.getEntRowNamed(tmpColHeading) &lt;&gt; null then
							continue;
						endif;
						create newRow transient;																			// PAR #31155
						measure := app.myRoot.allMeasurementTypesByShortName[measureType];								// PAR #35924
						//if measure = null or not measure.isDefault then												// PAR #35924	// PAR #36235
						// from 37288 development if this is the first form app.activeForm has not be set up yet, check for null
						if (measure = null or not measure.isDefault) and (app.activeForm &lt;&gt; null and app.activeForm.class = CMUI_EDIForm) then		// PAR #35924	// PAR #36235
							newRow.setBasicDetails(tmpColHeading, newHeading &amp; " " &amp; measureType, Table.InputType_None, true);	// Re-instated PAR #35924
						else																							// PAR #35924
							newRow.setBasicDetails(tmpColHeading, newHeading &amp; " " &amp; measureType, inputType, true);				// PAR #35887
						endif;																							// PAR #35924
						self.allTblDataEntRows.add(newRow);																	// PAR #31155
					endif;
				endif;																									// PAR #31155
			endif;																										// PAR #31155
		endif;
	endwhile;

	self.setColumns(true);
	self.setColWidthsFromXMLStr(xmlDef);
	self.setSortOrderFormXMLStr(xmlDef);	
	return self.columns &gt; 0;
	
epilog
	delete rowArray;
end;</source>
        <Parameter name="_xmlStr" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setForm" id="8aadb0c8-39a2-4ae0-9778-872711258a52">
        <updating/>
        <source>setForm(_form: Form) updating;
//26 August 2008	cnwdw1	
//
