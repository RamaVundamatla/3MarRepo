    <JadeMethod name="setComboValues" id="906d1fa9-e06e-4028-8931-ebd6e15d8965">
        <source>setComboValues(comboBox					: ComboBox input; 
			   queryCriteriaLineHolder	: CM_QueryCriteriaLineHolder; 
			   queryOperator			: CM_QueryOperator; 
			   passport					: CM_Passport);
/*

Purpose:			

Parameters:			

Return Value:		
/****Changes

Date			Name		TFS#		Description
===============================================================================================
15 May 2014		cnwndl1		Par 34142	Initial creation
27 Sep 2018		jlgka1		40200		Put an filter for Multi-terminal and Single Terminal.
===============================================================================================*/

vars
	terminal				: CM_Terminal;
	bank 					: CM_Bank;
	invType					: CM_InvoiceDesc;
	referenceLookup 		: CM_QReferenceLookup;
	multiTerminal			: Boolean;
	selectorCriteriaLine	: CM_SelectorCriteriaLine;
	userTerminal			: CM_UserTerminal;
	object					: Object;
	objectSet				: ObjectSet;
begin
	comboBox.clear();
	
	create objectSet transient;
	foreach selectorCriteriaLine in queryCriteriaLineHolder.allCriteriaLines do
		if selectorCriteriaLine.myQueryProperty.propertyName = 'myTerminal' or
		   selectorCriteriaLine.myQueryProperty.propertyName = 'getTerminal' then		   
				selectorCriteriaLine.myQueryOperator.getSearchValueAsObjectSet(objectSet);
				break;			
		endif;
	endforeach;
	if objectSet.isEmpty() then
		foreach userTerminal in app.myPassport.myUser.allUserTerminals do
			objectSet.add(userTerminal.getMyTerminal);
		endforeach;
	endif;
	
	multiTerminal := (objectSet.size &gt; 1);
	
	foreach object in objectSet do
		terminal := object.CM_Terminal;
		foreach bank in terminal.companies discreteLock where bank.isBusinessUnit do
			foreach invType in bank.invoiceTypes discreteLock where not invType.isNotAvailableForEntry do
				if multiTerminal then
					comboBox.itemObject[comboBox.addItem( self.translateToDisplayValue(invType).String ) ] := invType;
				else
					comboBox.itemObject[comboBox.addItem( self.translateToDisplayValue(invType).String ) ] := invType;
				endif;
			endforeach;
		endforeach;
	endforeach;

	if CM_QReferenceLookup.hasInstance(queryOperator) then
		referenceLookup := queryOperator.CM_QReferenceLookup;
		if global.isValidObject(referenceLookup.mySelectionValue) then
			comboBox.listObject := referenceLookup.mySelectionValue;
		endif;
	endif;
epilog
	delete objectSet;
end;</source>
        <Parameter name="comboBox" type="ComboBox" usage="input"/>
        <Parameter name="queryCriteriaLineHolder" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="queryOperator" type="CM_QueryOperator"/>
        <Parameter name="passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setListValues" id="0d85f4c3-1e77-44cd-9be0-57a018e5aeaf">
        <source>setListValues(table						: Table input; 
			  queryCriteriaLineHolder	: CM_QueryCriteriaLineHolder; 
			  operator					: CM_QReferenceIsOneOf; 
			  passport					: CM_Passport);
/*

Purpose:			

Parameters:			

Return Value:		

/****Changes

Date			Name		TFS#		Description
===============================================================================================
15 May 2014		cnwndl1		Par 34142	Initial creation
27 Sep 2018		jlgka1		40200		Put an filter for Multi-terminal and Single Terminal.

===============================================================================================*/

vars
	selectionValue 			: Integer;
	terminal 				: CM_Terminal;
	bank 					: CM_Bank;
	invType	 				: CM_InvoiceDesc;
	idx 					: Integer;	
	multiTerminal			: Boolean;
	selectorCriteriaLine	: CM_SelectorCriteriaLine;
	userTerminal			: CM_UserTerminal;
	object					: Object;
	objectSet				: ObjectSet;
begin

	table.clear;
	table.rows := 0;
	table.sortColumn[1] := 2; // TFS 7821
	
	create objectSet transient;
	foreach selectorCriteriaLine in queryCriteriaLineHolder.allCriteriaLines do
		if selectorCriteriaLine.myQueryProperty.propertyName = 'myTerminal' or
		   selectorCriteriaLine.myQueryProperty.propertyName = 'getTerminal' then		   
				selectorCriteriaLine.myQueryOperator.getSearchValueAsObjectSet(objectSet);
				break;			
		endif;
	endforeach;
	if objectSet.isEmpty() then
		foreach userTerminal in app.myPassport.myUser.allUserTerminals do
			objectSet.add(userTerminal.getMyTerminal);
		endforeach;
	endif;
	
	multiTerminal := (objectSet.size &gt; 1);
	
	foreach object in objectSet do
		terminal := object.CM_Terminal;		
		foreach bank in terminal.companies discreteLock where bank.isBusinessUnit do
			foreach invType in bank.invoiceTypes discreteLock where not invType.isNotAvailableForEntry do
				selectionValue := 0;
				if operator &lt;&gt; null and operator.allSelectionValues.includes(invType) then
					selectionValue := 1;
				endif;
				idx := table.addItem( selectionValue.String &amp; Tab &amp; self.translateToDisplayValue(invType).String );
				table.accessRow(idx).itemObject := invType;
				table.row := idx;
				table.change(table);
			endforeach;
		endforeach;
	endforeach;
epilog
		delete objectSet;
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="queryCriteriaLineHolder" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="operator" type="CM_QReferenceIsOneOf"/>
        <Parameter name="passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setValuesFromList" id="ca608e0a-b01f-4b8c-96e0-9b47100dc683">
        <source>setValuesFromList(_tbl: Table input; _op: CM_QueryOperator input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 May 2014	cnwndl1	Initial creation	Par 34142

*/

vars
	str				: String;
	numRows,
	idx				: Integer;
	invSet			: CM_ObjectSet;
	invType			: CM_InvoiceDesc;
begin

	create invSet transient;
	
	numRows := _tbl.rows;
	foreach idx in (_tbl.fixedRows + 1) to numRows do
		str := _tbl.accessCell(idx, 1).text;
		if str = TableCheckBox_Selected then
			invType := _tbl.accessRow(idx).itemObject.CM_InvoiceDesc;
			invSet.add(invType);
		endif;
	endforeach;
	
	_op.setSearchValue(invSet);
	
epilog
	delete invSet;
end;</source>
        <Parameter name="_tbl" type="Table" usage="input"/>
        <Parameter name="_op" type="CM_QueryOperator" usage="input"/>
    </JadeMethod>
    <JadeMethod name="translateToDisplayValue" id="025943f8-283c-472e-a288-f7c2a28c6432">
        <source>translateToDisplayValue(_value: Any): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 May 2014	cnwndl1	Initial creation	Par 34142

*/

vars

	invType : CM_InvoiceDesc;

begin
	if _value.isKindOf(CM_InvoiceDesc) then
		if _value &lt;&gt; null then
			invType := _value.CM_InvoiceDesc;
			return invType.description &amp; "  [" &amp; invType.company.code &amp; "/" &amp; invType.company.terminal.code &amp; "]";
		else
			return null;
		endif;
	else
		return _value.String;
	endif;
	

epilog

end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="translateToSearchValue" id="b60af349-72b1-47d8-8c00-016715240c82">
        <source>translateToSearchValue(_value: Any): Any;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 May 2014	cnwndl1	Initial creation	Par 34142

*/

vars

	invType : CM_InvoiceDesc;

begin
	if _value &lt;&gt; null then
		if _value.isKindOf(Collection) then	
			return _value;
		endif;
	
		if _value.isKindOf(CM_InvoiceDesc) then
			return _value.CM_InvoiceDesc;
		endif;
	endif;
	
	return null;
	
epilog

end;
</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="Any"/>
    </JadeMethod>
</Class>
