	theForm	:= self.myForm;
	theForm.tblInput1.userInputEnabled	:= false;
	theForm.tblInput1.cnEcResizeContents();
	
epilog
	
end;
</source>
    </JadeMethod>
    <JadeMethod name="setupThumbnailDetails" id="965d82c4-22cc-447b-8893-4adffbff02d9">
        <updating/>
        <source>setupThumbnailDetails() updating;

/*
Date			Who		Reason
19 August 2010	cnwrl1	Initial creation as part of PAR 23697 - CCMS 1097 - Stop Expiry - retain info after expiry.
*/
	
vars
	theForm	: SOP_TableMaintForm;
	
begin
  	theForm	:= self.myForm;
	theForm.useProxyObject	:= true;
	
	theForm.setTblDataEntRows( ETDef_StopOverriddenReason );
	//12/01/2011 cnwdz2 25840
	//theForm.zClearSortColumns();
	//theForm.zAddSortColumn( ETRow_Code, false );
	
	theForm.shtTblInput1.caption	:= 'Details';
	theForm.initTblInput( theForm.tblInput1, ETDef_StopOverriddenReason );
	theForm.shtTblInput1.visible	:= true;
	
	theForm.mulSelect1.formDisplayEntryMethodName	:= null;
	theForm.mulSelect2.formDisplayEntryMethodName	:= null;
	
epilog
	
end;
</source>
    </JadeMethod>
    <JadeMethod name="showThumbnail" id="136a1ecd-3bc1-496b-8eb6-7824d7e9bd52">
        <updating/>
        <source>showThumbnail( _stopOverriddenReason : CM_StopOverridenReason ) updating;

/*
Date			Who		Reason
19 August 2010	cnwrl1	Initial creation as part of PAR 23697 - CCMS 1097 - Stop Expiry - retain info after expiry.
*/
	
vars
	theForm	: SOP_TableMaintForm;
	
begin
	theForm	:= self.myForm;
	theForm.tblInput1.clearValues();
	
	theForm.tblInput1.setValueByName( ETRow_Code, _stopOverriddenReason.code );
	theForm.tblInput1.setValueByName( ETRow_Description, _stopOverriddenReason.description );
	
epilog
	
end;
</source>
        <Parameter name="_stopOverriddenReason" type="CM_StopOverridenReason"/>
    </JadeMethod>
</Class>
