    <JadeMethod name="resetNotes" id="fb9a7dc2-bc15-4785-b518-395f693c3ea9">
        <source>resetNotes() protected;

// Created by cnwdvb1 on 19 July 2006

vars

	terminal	: CM_Terminal;
	eventAdd,
	eventRemove	: Integer;
	machine		: CM_Machine;

begin

	self.endNotificationForSubscriber(self);
		
	terminal	:= app.getMyTerminalDO_NOT_USE();
	eventAdd	:= terminal.getTerminalEvent(Event_New_Queue_Entry);
	eventRemove	:= terminal.getTerminalEvent(Event_Delete_Queue_Entry);
	
	machine := self.myMediator.machine;
			
	if  terminal &lt;&gt; null then
		self.beginClassNotification(CM_RadioTelemetryQueue, false, eventAdd, Response_Continuous, 0);
		self.beginClassNotification(CM_RadioTelemetryQueue, false, eventRemove, Response_Continuous, 0);
		self.beginNotification(machine, EVENT_MACHQUEUE_ALTERED, Response_Continuous, 0);
		self.beginNotification(machine, EVENT_MACH_BROADCAST_MSG, Response_Continuous, 0);
		self.beginNotification(machine, Object_Update_Event, Response_Continuous, 0);
	endif;
		
	self.reviewQueueEntries();

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="reviewQueueEntries" id="c487f724-5e6d-4f1a-949c-9eb163c9fc77">
        <source>reviewQueueEntries() protected;
// -------------------------------------------
// Created 09 February 2006 by cnwdvb1
// -------------------------------------------
vars

	machine			: CM_Machine;
	queueEntry		: CM_RTQueueEntry;
	queue			: CM_RadioTelemetryQueue;
	sendNote		: Boolean;
	info			: DTO_StateInfo;
	testedQueues	: CM_ObjectSet;

begin

	create testedQueues transient;
	// This method tests a machine's queues to see what tasks
	// are available to be worked by this machine.
	
	// Clear out set of known tasks.
	self.allNotifiedQueueEntries.clear();
	machine := self.myMediator.machine;
	
	// Test primary queue.
	if self.testAQueue(machine.myPrimaryQueue, machine, testedQueues) then
		sendNote := true;
	endif;
	
	// Check secondary queues 
	//if not sendNote then	//cnwrd1 par 28960 23.1.2012 remove this as we should be showing secondary queue jobs all the time 
	foreach queue in machine.allQueues do			
		if self.testAQueue(queue, machine, testedQueues) then
			sendNote:=  true;
		endif;
	endforeach;
	//endif;

	// Transient gets deleted on client side.
	create info transient;
	
	// Set type of note.
	if sendNote then
		// Turn flag on.
		info.guiState := Event_New_Queue_Entry + 1000;
	else
		// Turn flag off.
		info.guiState := Event_Delete_Queue_Entry + 1000;
	endif;
	
	self.causeEvent(self.Event_Server_Note, true, info);
epilog
	delete testedQueues;
end;</source>
        <access>protected</access>
    </JadeMethod>
