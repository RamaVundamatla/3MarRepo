    <JadeMethod name="validateInvLineDescUsedTranMap" id="55039d83-f119-4432-b106-0dabbd9a3d9a">
        <source>validateInvLineDescUsedTranMap(_invLineDesc : CM_InvoiceLineDesc) : Boolean;
// ---------------------------------------------------------------------------
// Created:		12 October 2009 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars

	map : CM_DebtorMap;
begin
	foreach map in self.allDebtorMapsByDebtor discreteLock do
		if map.validateInvLineDescUsedTranMap(_invLineDesc) then
			return true;
		endif;
	endforeach;
	
	
	if self.myChildQuantityMap.validateInvLineDescUsedTranMap(_invLineDesc) then
		return true;
	endif;
	
	return false;
end;</source>
        <Parameter name="_invLineDesc" type="CM_InvoiceLineDesc"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
