    <JadeMethod name="loadDBToCMS" id="120d716b-6718-4dcd-931d-1f49dd4f848f">
        <updating/>
        <source>loadDBToCMS(_mergeCargo : Boolean; _passport : CM_Passport input) updating;

// 16/08/2012	cnwcs5	par 30210 - passport errors are not cleared during re-processing
//16 Jan 2014	cnwrs1	par 33309 - looks like the EDI Status DBLoading has run its course and needs to be removed
// 16 Aug 2016	cnwrs1	TFS 2534 Par 38135 - dead locking between edidata process and edidata deletion
// 23 Feb 2018	jlgrs1	TFS 36963 - add tranlog timings
// 05 Sep 2018	jlgrs1	TFS 40627 STWR Make EDI MultiThreaded
// 27 Sep 2018	jlgrs1	TFS 40627 STWR Make EDI MultiThreaded Stage 4
vars
//	terminal	: CM_Terminal;
//	ediConfig	: CM_EDIConfig;
//	auditConfig	: CM_AuditConfig;
	tmpStr : String;
begin
	app.mousePointer := MP_HOURGLASS;

	// Alway clear passport error/warnings before a loadDB - need for ediData that don't use a trx for loadDB
	_passport.clearErrorsWarnings;	// par 30210 August 2012

// 28 Aug 2018	jlgrs1	TFS 40627 STWR Make EDI MultiThreaded
/*	terminal := self.getMyTerminal();
	if terminal &lt;&gt; null then
		ediConfig := terminal.myEdiConfig;
		if ediConfig &lt;&gt; null then
			self.exclusiveLock(ediConfig);
		endif;
	endif;*/
	if not self.isLockedByMe(self) then
		if not self.tryLock(self, Exclusive_Lock, Session_Duration, LockTimeout_Immediate) then
			// we'll catch it next time around !!!
			app.writeLog ('Unable to lock ediData ' &amp; self.displayName, LogDEBUG);
			if app.myPassport.getMyBGPAgent = null then
				app.raiseCMException(Objects_locked, null, self);
			else
				return;
			endif;
		endif;
	endif;
	// 36185 get deadlocks between create and delete of EDI data -  the create updates CM_EDIConfig collections and then audits, updating CM_AuditConfig collection.
	//	The delete audits, updating CM_AuditConfig collection, then deletes, updating CM_EDIConfig collections.
	// Lock both in the same sequence in the add and delete code before beginTransaction.
	//  CM_EDIConfig is for the terminal, CM_AuditConfig is for the CM_EDIData class.
//	if app.myAA.getAuditConfigForClass(self.class, auditConfig) then
//		if auditConfig &lt;&gt; null then
//			self.exclusiveLock(auditConfig.allAuditObjects);
//		endif;
//	endif;

	tmpStr := method.qualifiedName;
	app.writeLog( tmpStr&amp;' '&amp;self.getVoyageCode&amp;' '&amp;self.fileName, LogINFO);	//25 Nov 2019	NDL	TFS 47053
	
	self.cnStartTransaction(tmpStr[1:60]);
	self.loadDB(_mergeCargo, _passport);

epilog
	if tmpStr &lt;&gt; null then
		self.cnEndTransaction();
	endif;
	app.mousePointer := MP_DEFAULT;
end;</source>
        <Parameter name="_mergeCargo" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="myEDIFile" id="460b2cd0-8b38-49da-94cc-058a507970e1">
