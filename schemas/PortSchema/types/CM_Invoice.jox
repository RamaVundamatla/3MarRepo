    <JadeMethod name="getTotalAmount" id="b7cc498d-80ae-4dca-89d5-6ddafab9b17b">
        <source>getTotalAmount() : Decimal;// SFW CCMS 1115 PAR23680   cnwsh3 - Invoice JRW Interface - Removed Progress bar
//
//07 Jun 2016	cnwrs1	TFS2107 round all values to this field
////2/07/2018 	JLGNS1	Ticket 39333: ADP - RE: cash receipt issue
//
vars
	//totInv:   Decimal[16,6];
	finIO	: CM_ExtFinanceIO;
	cp		: CM_CashPayment;
	invoiceLine:    CM_InvoiceLine;
	// TFS 42431 totInv:   Decimal[23,6];	//11 May 2018	NDL	TFS 38528
	// TFS 43253 totInv:   Decimal[23,2];	// TFS 42431 
	totInv:   Decimal[23,6]; // TFS 43253
begin
	
	if self.status &lt;&gt; INVOICE_VOID then
		//epr TFS 4291 4/5/17
		foreach invoiceLine in self.invoiceLines discreteLock
		//	where invoiceLine.status &lt;&gt; CM_InvoiceLine.STATUS_VOIDED do
			where ( invoiceLine.status &lt;&gt; CM_InvoiceLine.STATUS_VOIDED )
			or ( self.status = INVOICE_POSTED_CREDIT ) 	//04 Sep 2017	NDL	TFS 6759
			or ( self.status = INVOICE_POSTED_REVERSE ) 	//04 Sep 2017	NDL	TFS 6759
			or ( self.status = INVOICE_PENDING_REVERSE)     //31.10.2018 cnwma1 TFS #41703 
			do
			totInv:=totInv + invoiceLine.lineTotal;			
		endforeach;
		
		/*	Ticket 39333
		//totInv := self.getInvoiceStats(invLineStatDict, null, false, false);
		// 36444 add manual cash payments as they get exported line invoice lines
		//	but limit to Abu Dhabi Ports there are many other usages of this method
		finIO := self.myTerminal.getConfig(FinancialIOClass).CM_ExtFinanceIO;
		if finIO &lt;&gt; null and finIO.class = CM_ADPInterface then
			foreach cp in self.allCashPayments do
				if cp.isManual then
					totInv := totInv + cp.cashValue;
				endif;
			endforeach;
		endif;
		*/
	endif;
	return totInv;  // TFS 42283 .roundedTo(2);
epilog
end;

</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="getTotalAmountConverted" id="dd0f3477-4883-4a5b-a89e-635cb506dbd6">
        <source>getTotalAmountConverted( _rate : CM_CurrencyRate; _linesSubSet : CM_InvoiceLineBySeqNumDict input ) : Decimal;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 November 2018	jlgndl1	Initial creation	TFS 41684

*/

vars

	// TFS 42431 invTotal : Decimal [23,6];
	// TFS 43253 invTotal:   Decimal[23,2];	// TFS 42431 
	invTotal : Decimal [23,6]; // TFS 43253
	invoiceLine : CM_InvoiceLine;
	dict : CM_InvoiceLineBySeqNumDict;

begin

	//25 Mar 2019	NDL TFS 43687
	dict := self.invoiceLines;
	if _linesSubSet &lt;&gt; null then
		dict := _linesSubSet;
	endif;
	
	if _rate &lt;&gt; null then
		if self.status &lt;&gt; INVOICE_VOID then
			foreach invoiceLine in dict discreteLock
				where ( invoiceLine.status &lt;&gt; CM_InvoiceLine.STATUS_VOIDED )
				or ( self.status = INVOICE_POSTED_CREDIT ) 
				or ( self.status = INVOICE_POSTED_REVERSE ) 
				or ( self.status = INVOICE_PENDING_REVERSE)  
				do
				invTotal := invTotal + invoiceLine.getLineTotalConverted( _rate );
			endforeach;
		endif;
	else
		//29 Apr 2019	NDL	TFS 43687
		if self.status &lt;&gt; INVOICE_VOID then
			foreach invoiceLine in dict discreteLock
				where ( invoiceLine.status &lt;&gt; CM_InvoiceLine.STATUS_VOIDED )
				or ( self.status = INVOICE_POSTED_CREDIT ) 
				or ( self.status = INVOICE_POSTED_REVERSE ) 
				or ( self.status = INVOICE_PENDING_REVERSE)  
				do
				invTotal := invTotal + invoiceLine.lineTotal;
			endforeach;
		endif;
		//invTotal := self.getTotalAmount();
	endif;
	
	return invTotal;

epilog

end;</source>
        <Parameter name="_rate" type="CM_CurrencyRate"/>
        <Parameter name="_linesSubSet" type="CM_InvoiceLineBySeqNumDict" usage="input"/>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="getTotalAmountPlusPelindoTax" id="7c94bc1b-58e8-4ec4-9109-8063c1cad825">
        <source>getTotalAmountPlusPelindoTax() : Real;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 Dec 2018	jlger1	Initial creation 42116
07 Jan 2018 jlger1	More 42116 make sure always returns IDR and taxCode is A0 not AO
15 Mar 2019 cnwma1	ChangeRequest 43787: PEL1 - SAP Service Monitoring Report - Final Changes
*/

vars
	taxCode : String;
	taxAmount,
	totalAmount:   Decimal[23,2];	// TFS 42431 
	invLine : CM_InvoiceLine;
	isDomestic : Boolean;
	taxRate : Real;
begin
	taxCode :=self.getPelindoTaxCode();
	//jlier1 tfs 51963 15/10/21
	isDomestic :=self.bank.code.toUpper.cnContains("DOM");
	if isDomestic then
		totalAmount := self.getTotalAmount();		
	else
		totalAmount := self.getAmountForCurrencyCode("USD");
	endif;
	
	if taxCode = "A0" then
		foreach invLine in self.invoiceLines discreteLock where not invLine.voided do
			taxRate :=invLine.getTaxRateForLine();
			if taxRate = 0 then
				continue;
			endif;
			if isDomestic then
				taxAmount:=taxAmount + (invLine.lineTotal / taxRate);
			else			
				taxAmount:=taxAmount + (invLine.getAmountForCurrencyCode("USD") / taxRate);
			endif;
			
		endforeach;
		
		totalAmount:= (totalAmount + taxAmount);
	endif;
	
	//return totalAmount.truncatedTo(1); //15.03.2019 cnwma1 #43787
	return totalAmount.truncatedTo(0);   //15.03.2019 cnwma1 #43787
	
epilog

end;</source>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="getTotalQuantity" id="2451d419-b5bc-4cc1-9404-22f651cc00bd">
        <source>getTotalQuantity() : Real;
// 28218 CCMS 2120 Oct 2011 electronic invoicing, for reporting
vars
	line	: CM_InvoiceLine;
	total	: Real;
begin
	foreach line in self.invoiceLines where not line.voided do
		total := total + line.quantity;
	endforeach;
	
	return total;
end;
</source>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="getTotalTaxValueAsString" id="b23fcee1-21b1-4212-ac24-531bd13b40cc">
        <source>getTotalTaxValueAsString() : String ;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 Aug 2023 navlc30 ChangeRequest 59481: EUP | New Scope 54831 [15] - Total Tax Display on Invoice List Screen

*/

vars
	invoiceLine : CM_InvoiceLine;
