    <JadeMethod name="getLoadStartTime" id="8bc8c5e5-7ad6-4e31-9265-e9a969517f2f">
        <source>getLoadStartTime() : TimeStamp;
/*
Purpose:			Get the cargo loading start time
Return Value:		TimeStamp of cargo load start

Date		Who		Reason
17 Apr 2008	cnwkpd1	PAR #16521 - Short Term Movements report
22/09/2011	cnwcs5	CCMS RIO 2041 / PAR 28220
*/

vars
	movement		: HMS_VoyageMovement;
	interval		: CM_TimeStampInterval;
	loadStart		: TimeStamp;
	
begin 
	movement := self.getMovementFirstRealBerth;
	
	if movement = null then
		return null;
	endif;
	
	// Use the cargo operation start time from the first real movement
	interval := movement.allCargoOperationsIntervals.first;
	
	if interval &lt;&gt; null then
		loadStart := interval.startDT;
		
		if loadStart.isValid() then
			return loadStart;
		endif;
	endif;
	
	// If this hasn't been set, then default to Berth time
	return self.getRealBerthDT;
	
end;


</source>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="getLoadStartTimeByIndex" id="98acb8a6-1d9e-4c6c-a4f0-7621e6a2fc7b">
        <source>getLoadStartTimeByIndex(_index :Integer):TimeStamp protected;
/*
Date		Who		Reason
22 September 2011	cnwcs5	Initial creation - CCMS RIO 2041 / par 28220 Start/Stop Times
*/
vars
	movement	:HMS_Movement;
	ts			:TimeStamp;
begin
	movement := self.getMovementFirstRealBerth ;
	
	if movement = null then 
		return null;
	endif;
	
	ts := movement.getLoadStartTimeByIndex (_index);
	
	if ts = null and _index = 1 then
		ts := self.getRealBerthDT;
	endif;
	
	return ts;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_index" type="Integer"/>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="getLoadStartTimeLocalTZ" id="8ba79804-662e-4dfc-9143-ac3359dbce2a">
        <source>getLoadStartTimeLocalTZ() : TimeStamp;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 June 2016	cnwns1	Initial creation
// 07 June 2016	cnwns1	TFS 488 - Multi Timezone Support
*/

vars
	movement		: HMS_VoyageMovement;
	interval		: CM_TimeStampInterval;
	loadStart		: TimeStamp;
	
begin 
	movement := self.getMovementFirstRealBerth;
	
	if movement = null then
		return null;
	endif;
	
	// Use the cargo operation start time from the first real movement
	interval := movement.allCargoOperationsIntervals.first;
	
	if interval &lt;&gt; null then
		loadStart := interval.startDT;
		
		if loadStart.isValid() then
			return self.systemToLocalTime(loadStart);
		endif;
	endif;
	
	// If this hasn't been set, then default to Berth time
	return self.systemToLocalTime(self.getRealBerthDT);
	
end;


</source>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="getLoadStopTime" id="b08bfcd3-5b19-4824-8130-2c1dbf0bdc93">
        <source>getLoadStopTime() : TimeStamp;
/*
----------   ----------  --------------------------------------------------
Created:	07 August 2007 By cnwth2

Purpose:	User in report writer

----------   ----------  --------------------------------------------------
/*

Date		Who		Reason
17 Apr 208	cnwkpd1	PAR #16521 - Short Term Movements report
22/09/2011	cnwcs5	CCMS RIO 2041/par 28220
*/
vars
	movement		: HMS_VoyageMovement;
	loadStop		: TimeStamp;
	interval		: CM_TimeStampInterval;
begin
	movement := self.getMovementFirstRealBerth();
	
	if movement = null then
		return null;
	endif;
	
	// Use the cargo operation end time from the first real movement
	interval := movement.allCargoOperationsIntervals.last;
	
	if interval &lt;&gt; null then
		loadStop := interval.endDT;
		
		if loadStop.isValid() then
			return loadStop;
		endif;
	endif;
	
	// If this hasn't been set, then calculate
	loadStop := self.getRealBerthDT();
	
	if loadStop.isValid() then
		return loadStop.cnEcAddMinutes(self.getGrossLoadingTimeMinutes());
	endif;
	
	return null;
end;</source>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="getLoadStopTimeLocalTZ" id="98b8eb71-14bf-407a-b3ed-a681b531b6a0">
        <source>getLoadStopTimeLocalTZ() : TimeStamp;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 June 2016	cnwns1	Initial creation
// 07 June 2016	cnwns1	TFS 488 - Multi Timezone Support
*/

vars
	movement		: HMS_VoyageMovement;
	loadStop		: TimeStamp;
	interval		: CM_TimeStampInterval;
begin
	movement := self.getMovementFirstRealBerth();
	
	if movement = null then
		return null;
	endif;
	
	// Use the cargo operation end time from the first real movement
	interval := movement.allCargoOperationsIntervals.last;
	
	if interval &lt;&gt; null then
		loadStop := interval.endDT;
		
		if loadStop.isValid() then
			return loadStop;
		endif;
	endif;
	
	// If this hasn't been set, then calculate
	loadStop := self.getRealBerthDT();
	
	if loadStop.isValid() then
		return loadStop.cnEcAddMinutes(self.getGrossLoadingTimeMinutes());
	endif;
	
	return null;
end;</source>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="getLocationByID" id="d485cb2b-6cff-4080-84b7-5bddfb51f2cc">
        <source>getLocationByID(_locnID : String) : CM_LocationsController;
//--------------------------------------------------------------
//Created: 08 October 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	locnCntrl : CM_LocationsController;
begin
	if _locnID = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Null _locnID passed to method. Contact Developer.');
		return null;
	endif;
	
	foreach locnCntrl in self.allVoyageLocations do
		if locnCntrl.ident = _locnID then
			return locnCntrl;
		endif;
	endforeach;
	
	return null;
	
end;</source>
        <Parameter name="_locnID" type="String"/>
        <ReturnType type="CM_LocationsController"/>
    </JadeMethod>
    <JadeMethod name="getMatchingSlot" id="11506320-d6cf-43f3-a25a-1ccea00bc294">
