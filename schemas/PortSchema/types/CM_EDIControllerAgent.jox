    <JadeMethod name="actionForAutoTICustoms" id="86ef306a-7ca6-4999-a78f-bdcb4474789b">
        <updating/>
        <source>actionForAutoTICustoms(_ediTI: CM_EDITrackedItem) updating;
//----------------------------------------------------------------
//	Created:	02 December 2004	by Jason Chapman  (cnwjc2)
//
//	Processes customs for a specific TI - used when a TI comes through the gate (or hits the wharf?)
//
// cnwdad1 14/06/2010 - This method essentially does the same processing as
// CM_EDIDataCustomStop::loadDB.
//
//----------------------------------------------------------------
//
// if changing this method then CM_EDIDataCustomStop::loadDB may also need changing
//
// Rewritten 13/04/2010 cnwdad1 PAR 22153. This is no longer a single data file,
//		and it now also supports partial DB load status.
// Rewritten again cnwdad1 15/06/2010 PAR 22153. For BGP EDI processing.
// =--------------------------------------------------------------------------------
// 07/09/2010	cnwcs5	par25654 - fix null object reference error
// 07/08/2012	cnwcs5	par 30136 - EDI BGP Split
// 24/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
// 07 Nov 2017	jlgrs1	TFS 5705 - SNO - EDIDataBooking Prenote release Req
// 04 Mar 2019	jlgrs1	TFS 41913 STWR - Reconfiguration of the EDI Operation form to better handle EDI collection locks while loading 
//
vars
	ediDataCustoms		: CM_EDIData;
	ediTI				: CM_EDITrackedItem;
	proxyTI				: CM_TrackedItem;
	trackedItem			: CM_TrackedItem;
	ediCustomStopTi		: CM_EDICustomStopTI;
	passportObj			: CM_Passport;
	tiArray				: CM_TIArray;
	someIgnored			: Boolean;
	bolObj				: CM_BOL;
	anObject			: Object;
	isInvalid			: Boolean;
	status				: Integer;	// par 30136 Aug 2012
begin
	passportObj	:=	app.myPassport;
	
	on Exception do self.validationExceptionHandler(exception, passportObj);
	on Exception do app.handleDeletedObject(exception, anObject, isInvalid);
	
	anObject	:=	_ediTI;
	ediTI		:=  _ediTI;	// 06/09/2010 cnwcs5 par 25654
	
	create tiArray transient;
	
	//status can be updated in trx below so need to keep checking this
	if ediTI.status &lt;&gt; CM_EDIFile.EDI_STATUS_UNPROCESSED then
		return;
	endif;
	
	if isInvalid then
		return;
	endif;
	
	ediCustomStopTi	:=	ediTI.CM_EDICustomStopTI;
	
	app.writeLog("Processing [" &amp; ediCustomStopTi.String &amp; "] customs info for " &amp; ediCustomStopTi.id &amp; ".", LogINFO);
	
	ediDataCustoms	:=	ediTI.myEDIData;
	
	if ediDataCustoms = null then
		return;
	endif;
	
	//process cancellations
	tiArray.clear();
	anObject	:=	ediDataCustoms;
	ediDataCustoms.CM_EDIDataCustomStop.getValidTisForLoad(ediCustomStopTi, tiArray, someIgnored, bolObj, passportObj);
	
	if isInvalid then
		return;
	endif;
	
	foreach trackedItem in tiArray do
		anObject	:=	trackedItem;
		proxyTI		:=	app.createUpdateProxy(trackedItem).CM_TrackedItem;
		
		if isInvalid then
			isInvalid	:=	false;
			continue;
		endif;
		
		app.myTrxUA.trxUpdateEDICustomStop(proxyTI, ediDataCustoms.CM_EDIDataCustomStop, ediCustomStopTi, passportObj);
		
		if passportObj.hasErrors() then //par 21299 cnwrs1 oct 2009
			app.writeLog('Database Load failed for '&amp;proxyTI.id&amp;' one or more items.', LogINFO);
			app.remoteErrorWarningToAlert(	'Database load failure - Customs EDI item(s) failed for ' &amp; proxyTI.id &amp; '.',
											null,
											passportObj.allErrors,
											null,
											false,
											true);
			app.myPassport.clearErrorsWarnings();
		endif;
		
		delete proxyTI;
		
		if self.isLockedByMe(trackedItem) then
			self.unlock(trackedItem);
		endif;
	endforeach;		
	
	delete tiArray;
	
	status := ediDataCustoms.getStatusFromEDITrackedItems(false);					// par 30136 Aug 2012
	
	app.myTrxUA.trxSetEDIDataStatusAfterVerify (ediDataCustoms, status);	// par 30136 Aug 2012	
epilog
	if self.isLockedByMe(trackedItem) then
		self.unlock(trackedItem);
	endif;
	
	delete tiArray;
	delete proxyTI;
end;
</source>
        <Parameter name="_ediTI" type="CM_EDITrackedItem"/>
    </JadeMethod>
    <JadeMethod name="actionForAutoTIOperator" id="7f0ff99c-8f11-4111-8364-1dec451cd083">
        <updating/>
        <source>actionForAutoTIOperator(_ediTI: CM_EDITrackedItem) updating;
// --------------------------------------------------------------------------------
// Created:		14 June 2010 by cnwdad1
//
// Purpose:		Processes customs for a specific TI - used when a TI comes through
//				the gate (or hits the wharf?)
//
// cnwdad1 14/06/2010 - This method essentially does the same processing as
// CM_EDIDataOperatorStop::loadDB.
//
// NOTE: This method is a copy of actionForAutoTICustoms, for PAR 22153 (see attached
// Word doco on this PAR called "EDI Purge.doc").
//
// Parameters:	_ediTI - A reference to the EDI Tracked Item to process.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 14/06/2010	cnwdad1		Copied from actionForAutoTICustoms method for PAR #22153.
// 15/07/2010	cnwdap1		PAR #25021 review use of isImport/isExport for tranships
// 07/09/2010	cnwcs5		par25654 - fix null object reference error
// 07/08/2012	cnwcs5		par 30136 - EDI BGP Split
// 24/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
// 07 Nov 2017	jlgrs1	TFS 5705 - SNO - EDIDataBooking Prenote release Req
// 04 Mar 2019	jlgrs1	TFS 41913 STWR - Reconfiguration of the EDI Operation form to better handle EDI collection locks while loading 
// --------------------------------------------------------------------------------
vars
	terminalObj			: CM_Terminal;
	ediDataObj			: CM_EDIData;
	ediTI				: CM_EDITrackedItem;
	trackedItem			: CM_TrackedItem;
	ediOperatorStopTi	: CM_EDIOperatorStopTI;
	passportObj			: CM_Passport;
	voyageObj			: CM_Voyage;
	anObject			: CM_Object;
	isInvalid			: Boolean;
	status				: Integer;	// par 30136 Aug 2012
begin
	passportObj	:=	app.myPassport;
	on Exception do validationExceptionHandler(exception, passportObj);
	on Exception do app.handleDeletedObject(exception, anObject, isInvalid);
	
	anObject	:=	_ediTI;
	ediTI		:=  _ediTI;				// 07/09/2010 cnwcs5 par 25654
	terminalObj	:=	self.myTerminal;
	
	//status can be updated in trx below so need to keep checking this
	if ediTI.status &lt;&gt; CM_EDIFile.EDI_STATUS_UNPROCESSED then
		return;
	endif;
	
	if isInvalid then
		return;
	endif;
	
	ediOperatorStopTi	:=	ediTI.CM_EDIOperatorStopTI;
	anObject			:=	ediOperatorStopTi;
	
	if ediOperatorStopTi.status = CM_EDIFile.EDI_STATUS_DBLOADED then // Only unprocessed TIs
		return;
	endif;
	
	if isInvalid then
		return;
	else
		ediDataObj	:=	ediTI.myEDIData;
		
		if ediDataObj = null then
			return;
		endif;
	endif;
	
	// Look in on-site cargo.
	trackedItem	:=	terminalObj.allOnsiteTIsByIdCargoType[ediOperatorStopTi.id, TI_CargoType_Container];
	
	if trackedItem = null  then // Tracked Item is not onsite yet, check incoming voyages released by planners.
		foreach voyageObj in terminalObj.myEdiConfig.allVoyagesToProcess do
			if not voyageObj.hasDeparted() then //cnwgb1 PAR 20335 23.7.09
				trackedItem	:=	voyageObj.allOnshipTIsByIdCargoType[ediOperatorStopTi.id, TI_CargoType_Container];
				
				if trackedItem &lt;&gt; null then
					break;
				endif;
			endif;
		endforeach;
	endif;
	
	anObject	:=	trackedItem;
	
	if trackedItem = null  // Tracked item isn't on any available voyages either.
	or (not trackedItem.isImport  // Only Imports
	and not trackedItem.isTranshipItem)		// PAR 25021
	then
		return;
	endif;
	
	if isInvalid then
		return;
	endif;
	
	app.myTrxUA.trxUpdateEDIOperatorStops(trackedItem, ediOperatorStopTi, passportObj);
	
	if passportObj.hasErrors() then //par 21299 cnwrs1 oct 2009
		app.writeLog('Database Load failed for ' &amp; trackedItem.id &amp; ' one or more items.', LogINFO);
		
		app.remoteErrorWarningToAlert(	'Database load failure - Operator EDI item(s) failed for ' &amp; trackedItem.id &amp; '.',
										null,
										passportObj.allErrors,
										null,
										false,
										true);
		
		passportObj.clearErrorsWarnings();
	endif;
	
	if self.isLockedByMe(trackedItem) then
		self.unlock(trackedItem);
	endif;
	
	anObject	:=	ediDataObj;
	
	status := ediDataObj.getStatusFromEDITrackedItems(false);					// par 30136 Aug 2012
	
	app.myTrxUA.trxSetEDIDataStatusAfterVerify (ediDataObj, status);	// par 30136 Aug 2012	
epilog
	if self.isLockedByMe(trackedItem) then
		self.unlock(trackedItem);
	endif;
end;</source>
        <Parameter name="_ediTI" type="CM_EDITrackedItem"/>
    </JadeMethod>
    <JadeMethod name="actionForAutoTerminal" id="b025f001-c394-46de-bdbf-90dfebe1789b">
        <updating/>
        <source>actionForAutoTerminal(_processNewFiles, _processEventRequestStops, _deleteOldData :Boolean; _ediDataTypes :IntegerArray) updating;
/*
// cnwdvb1 28 January 2003 

Date		Who		Reason
24 Sep 2009	cnwkpd1	PAR #20624 - Tidy up Session duration locking
26/09/2009	cnwrl1	PAR 20320 - MES 1011 New Messina Messages - handle the queued EDI "files".
27/07/2010	cnwcs5	par 24406 - added comments to clarify exception handling
14/09/2010	cnwdad1	PAR #25627 - Process Event Request Stops for on-ship cargo.
13/12/2010	cnwcs5	ccms mes 1112/par 24464 - event request stops for pre-notes
22/06/2011	cnwcs5	par 27167 - change processing of stop requests
19/10/2011  cnwrs1  par 28461 - par 26223 was incorrect before loadEDiDb call and switch edidata and status to local variables
05/12/2011  cnwrs1  CCMS POL 2122 / PAR 28696 - add support for EDI Partial release Request processing
10/02/2012	cnwrs1	Par 29075 - reget the status after the load and verify have been completed.
01/08/2012	cnwcs5	par 30136 - use conditional collection for re-processing files.
// 08 Nov 2016	cnwrs1	TFS 2913 Par 38341 EDI files that are open are not being processed
// 29 May 2017	cnwrs1	TFS 4916 deletion of duplicate Event Request Stops
*/

vars
	terminal		: CM_Terminal;		// par 30136 Aug 2012
	errorText		: String;
	error			: Integer;
begin
	// We want exception handlers armed here so that try to process all files.
	// If exception is resumable we will Resume_Next in app.alertExceptionHandler otherwise we will abort the current action
	on Exception do app.alertExceptionHandler(exception, null, self.getErrorDesc(), error, errorText, true, true);	// creates alert (with call stack)
	on Exception do self.xHandler(exception);																	// email notification of error
	on LockException do app.alertLockExceptionHandler(exception);												// retry locks
	// Any exceptions trapped by trx exception handlers will be passed back to these local handlers because app.isBackGroundApp is true
	
	self.isBGPAuto 			:= true;
	self.isEmailNotified 	:= false;

	terminal := self.myTerminal;
	
	if terminal = null then
		// never going to happen
		app.raiseCMException1(Err_InvalidTerminal, null, null, null);
		return;
	endif;
	
	// process new files we have received
	if _processNewFiles then
		app.writeLog ('About to load new EDI files', LogDEBUG);
		self.processNewFiles (terminal);
	endif;
	
	// Reprocess any partially loaded files - mainly customs/operator stops, bookings, releases and Fonterra pack messages
	if _ediDataTypes &lt;&gt; null and not _ediDataTypes.isEmpty then	
		app.writeLog ('About to re-process selected EDI files', LogDEBUG);
		self.processExistingFiles (terminal, _ediDataTypes);
	endif;
	
	// process new files that have been queued from the web
	if _processNewFiles then
		app.writeLog ('About to load queued EDI files', LogDEBUG);
		self.processQueuedFiles(terminal);		
	endif;
	
	// process event request stops for on-ship cargo and prenotes
	if _processEventRequestStops then
		app.writeLog ('About to process event request stops', LogDEBUG);
		self.processEventRequestStops (terminal);
	endif;

	//clean up
	if _deleteOldData then
		app.writeLog ('About to purge old EDI data', LogDEBUG);
		self.processDeletedEDIData();
		self.processDeleteEDIDupEventReq();
	endif;
epilog

end;</source>
        <Parameter name="_processNewFiles" type="Boolean"/>
        <Parameter name="_processEventRequestStops" type="Boolean"/>
        <Parameter name="_deleteOldData" type="Boolean"/>
        <Parameter name="_ediDataTypes" type="IntegerArray"/>
    </JadeMethod>
    <JadeMethod name="canBeOutSequenceValid" id="1fd04c98-035d-4289-b75b-6d58d05563ec">
        <source>canBeOutSequenceValid(_status : Integer):Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 January 2016	cnwma1	Initial creation PAR #37389 JH - Out of Sequence file query - High

*/

vars
	status	:Integer;
begin
	status := _status;
	
	if  not self.isBGPAuto then
		if status = CM_EDIFile.EDI_STATUS_OUTOFSEQUENCE then
			return true;
		endif;
	endif;
	
	
epilog

end;</source>
        <Parameter name="_status" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="checkAgainstLoadedFiles" id="bed54472-04bb-4b00-93d0-a774a3904561">
        <source>checkAgainstLoadedFiles(_coll :CM_EDIFileByCreatedTSDict; _file : File; _ediFile : CM_EDIFile output) : Boolean protected;
// cnwdvb1 29 January 2003 

// 01 Aug 2012	cnwcs5	par 30136 - improve efficiency
// 24/04/2013	cnwcs5	par 30652 - remove resynch/resynchObject method calls
// 31/07/2013	cnwcs5	par 32131 - use local variable to force jade to optimise foreach using iterator
// 26/02/2015	cnwkpd1	PAR #35764 - Change to use iterator as JADE foreach optimisation is not working
// 17/03/2021	navdap1	TFS 50809 CPL TSW responses not processing - TSW files can have the same filename and creation date
//								  and we still need to process them
vars
	ediFile : CM_EDIFile;
	status	: Integer;
	ts		: TimeStamp;
	iter	: Iterator;
	
begin
	ts := _file.timeCreated;
	
	// PAR #35764
	iter := _coll.createIterator();
	_coll.startKeyGeq(ts, iter);

//	foreach ediFile in _coll discreteLock where  ediFile.fileCreatedTs = ts do
	while iter.next(ediFile) do
	
		if ediFile.fileCreatedTs &lt;&gt; ts then
			break;
		endif;
	
		if _file.fileName = ediFile.fileName and ediFile.computerName = app.computerName() then
			// looks like we have already loaded this one
			status := ediFile.fileStatus;
			
			if status = CM_EDIFile.EDI_STATUS_LOADED or
		   		status = CM_EDIFile.EDI_STATUS_VERIFIED or
		   		status = CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS then
				// pass back the file that was loaded
				_ediFile := ediFile;
				
				return true;
			else
				// TFS 50809 are we a TSW Customs Stop, in which case duplicate filenames and processing are allowed
				// If it turns out to be an exact duplicate, no harm because it will be applying a stop that's already
				// applied, or clearing a stop that's already cleared
				if ediFile.ediData.ediDataType = EDIDataType_CustomStop and ediFile.myEDIFileType.type = EDIFileType_JMTInternal then
					app.writeLog(method.qualifiedName &amp; Tab &amp; "edi file " &amp; ediFile.fileName &amp; " PROCESSED - is a TSW Custom Stop", LogINFO);
					return true;
				endif;
				// TFS 50809
				return false;
			endif;
		endif;
	endwhile;
	
	return true;
	
epilog
	delete iter;
	
end;</source>
        <access>protected</access>
        <Parameter name="_coll" type="CM_EDIFileByCreatedTSDict"/>
        <Parameter name="_file" type="File"/>
        <Parameter name="_ediFile" type="CM_EDIFile" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="checkForLockExceptionLimit" id="445f5079-f0f4-4518-bd4f-1d8ad7ba3652">
        <source>checkForLockExceptionLimit(_method :Method; _gotLockException :Boolean io; _lockCount :Integer io):Boolean protected;
/*
Date		Who		Reason
02 Aug 2012	cnwcs5	Initial creation - par 30136
*/
constants
	Max_Consecutive_LockExceptions = 3;
vars
	msg		:String;
begin
	if _gotLockException then
		// we are going to continue with the next file to be processed
		_lockCount := _lockCount + 1;
		
		if _lockCount &gt;= Max_Consecutive_LockExceptions then
			// this lock problem is not going to go away
			msg := 'INFO &gt;&gt; Alert Aborting EDI processing in ' &amp; _method.name &amp; ' method  - after ' &amp; Max_Consecutive_LockExceptions.String &amp; ' consecutive lock exceptions ';
			
			app.writeLog(msg, LogINFO);
			app.remoteErrorWarningToAlert (msg, null, app.myPassport.allErrors, null, true, true );
			return false;
		endif;
		
		_gotLockException := false;
	else
		_lockCount := 0;
	endif;
	
	return true;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_method" type="Method"/>
        <Parameter name="_gotLockException" type="Boolean" usage="io"/>
        <Parameter name="_lockCount" type="Integer" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="continueAfterLockException" id="f296eaa5-ae06-40d4-a4aa-ed7d648b7beb">
        <source>continueAfterLockException(_exception :LockException; _lockedOut :Boolean output):Integer protected;
/*
Date		Who		Reason
01 Aug 2012	cnwcs5	Initial creation - par 30136
*/
vars
	result	:Integer;
begin
	// we still want to do all the standard alert stuff if we get a lock exception
	result := app.alertLockExceptionHandler (_exception);
	
	if result = Ex_Continue then
		// all OK can carry on
		return Ex_Continue;
	endif;
	
	// we could not get the lock - result will be Ex_Resume_Next
	_lockedOut	:= true;
	
	abortTransaction;
	abortTransientTransaction;
	
	return Ex_Resume_Next;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_exception" type="LockException"/>
        <Parameter name="_lockedOut" type="Boolean" usage="output"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="createWebEDIFile" id="ea394f21-18c1-4592-957c-7f42d29c8f07">
        <updating/>
        <source>createWebEDIFile(_messageType	  : String;
				 _message		  : Binary;
				 _ediFileType	  : CM_EDIFileType output;
				 _synchronous 	  : Boolean; 
				 _incomingMessage : String ) : CM_EDIFile updating, protected;
	
/*
Purpose:	This method will attempt to create a unique EDIFile from the supplied parameters.
			If it is successful then the newly created CM_EDIFile (realEdiFile) will be returned.
			
/* Changes

Date		Name	TFS#		Description
============================================================================
10 Aug 2009	cnwrl1	Initial creation as part of PAR 20318 - MES 1011 Web EDI Link
19 Feb 2015	cnwrs1	Par EDI Refactor for fileload  
23 Jun 2015	cnwrs1	Par EDI Refactor for fileload  
13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
03 Sep 2019 jlgka1 	TFS 45332 	STWR - Better Forms and Interfaces for EDI Module
09 Jul 2024 navmd1	TFS 65114 Pass Binary message data directly, rather than doing String conversions on it at this level
============================================================================*/
	
vars
	realEdiFile 	: CM_EDIFile;
	realEdiData : CM_EDIData;
	passport		: CM_Passport;
	fileData : String;
begin
	//fileData := _message.String;
	//fileData := _message.ansiToString; // ### TFS 54082 04Aug2022 NAVPW1
	self.getDataTypeCreateEDIObjects(_message, self.ediClientRef, null, app.actualTimeServer, true, _messageType, _ediFileType, realEdiFile, realEdiData, _synchronous, _incomingMessage);// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	
//	self.processFileData(realEdiFile, realEdiData, _ediFileType, app.myPassport);
	return realEdiFile;
/*
	passport		:= app.myPassport;				// This is validated and set up on the Web.
	self.myTerminal	:= passport.myTerminal;			// This is validated and set up on the Web.
	
	// first do any required validation
	if not self.validateEDIWebMessage( _messageType, _message, _ediFileType ) then
		// the ediStatusCode and ediStatusDesc should aready be set.
		return null;
	endif;
	
	// ok is valid so create CM_EDIFile from data.
	app.myTrxCA.trxCreateEDIFile(	realEdiFile,
									_ediFileType,
									self.ediClientRef,					// file name
									app.actualTimeAppServer,			// file timeStamp
									null,								// edi data
									CM_EDIFile.EDI_STATUS_UNPROCESSED,
									self.myTerminal.myEdiConfig,
									passport,
									self.ediClientRef,
									_messageType,
									_message );
	
	if passport.hasErrors then 
		self.ediStatusCode	:= CM_EDIFile.EDI_WEB_STATUS_CREATION_ERROR.display;		// ie -1
		self.setEdiStatusDesc( app.getString( Failed_To_Create_EDIFile ) );
		return null;
	endif;
	
	return realEdiFile;
*/	
epilog
	
end;
</source>
        <access>protected</access>
