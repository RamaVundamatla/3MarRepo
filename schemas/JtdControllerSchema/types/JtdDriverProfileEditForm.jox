    <JadeMethod name="queryUnload" id="956bb98d-c583-46ff-beb8-c0360cd3912b">
        <controlMethod name="Form::queryUnload"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>queryUnload(cancel: Integer io; reason: Integer) updating;

vars
	n : Integer;
	
begin
	if not self.jtdUnsavedChanges then
		cancel := 0;
		return;
	endif;
	
	n := app.msgBox("You have made changes that have not been saved." &amp; CrLf &amp; CrLf &amp;
		"Do you want to save them?", "Warning - Unsaved Changes", MsgBox_Yes_No_Cancel +
		MsgBox_Exclamation_Mark_Icon);

	if n = MsgBox_Return_Cancel then
		cancel := 1;
		return;
	endif;
	
	if n = MsgBox_Return_Yes then
		self.jtdSaveAllProfiles;
	endif;
	
	cancel := 0;
end;</source>
        <Parameter name="cancel" type="Integer" usage="io"/>
        <Parameter name="reason" type="Integer"/>
    </JadeMethod>
