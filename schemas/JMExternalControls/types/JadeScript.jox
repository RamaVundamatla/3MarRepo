<Class name="JadeScript">
    <JadeMethod name="getWeight" id="cdf25d2a-ec35-4983-857d-77d5f1adf14f">
        <source>getWeight();

vars

	comm	: ClassKomunikacja;
	str		: String;
	r		: Real;

begin


	//vbNormal: 0 (default) Normal: vbMinimized: 1: Minimized (minimized to an icon) vbMaximized: 2: Maximized (enlarged to maximum size)

	create comm transient;
	
	str := "C:\PortGdanskTest\waga.ini";
	
	comm.myIniPath(str);
	str := "#0.00";
	comm.ustawFormatWskazania(str);
	
	comm.statusOkna(r);
	
	comm.pokazOkno();
	
	
epilog
	delete comm;
end;
</source>
    </JadeMethod>
</Class>
