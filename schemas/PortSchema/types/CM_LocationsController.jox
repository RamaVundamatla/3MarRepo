    </JadeMethod>
    <JadeMethod name="executePreMoveFromLocation" id="caa977d9-0d78-421e-b18d-94446088320e">
        <updating/>
        <source>executePreMoveFromLocation(_control : CMIF_MoveController) updating;
/*
------------------------------------------------------------------------
Created:			19 February 2003 by cnwdwq1
Purpose:			Dave Q's code
Parameters:		See Method signature above. Special comment:
Returns:			See Method signature above. Special comment:
Changed On		Changed By		Reason
------------	------------	-----------------------------------------
														
------------------------------------------------------------------------
*/
vars
	ti		: CM_TrackedItem;		// cnwjk3 ccms 1018 08/02/10
	rc		: CM_RoRoController;	// cnwjk3 ccms 1018 08/02/10
	used	: Decimal[6,2];			// cnwjk3 ccms 1018 08/02/10
begin
	if  not _control.myToPrimaryLocation.isKindOf(CM_RoRoController) then
		return;
	endif;
	
	if _control.moveMode = REAL_MODE then
		// Check if we are moving a TI into a RoRo location where it is currently queued or planned.   If we are, then we need to decrease the 
		// usedLength of the target location by the size of the TI (plus standarg gap if other TIs are there), as the Q or P placeholder will no longer exist.
		rc :=  _control.myToPrimaryLocation.CM_RoRoController;
		ti := _control.myTrackedItem;
		if rc.allQueuedFutureMoves.containsTI(ti) or
		   rc.allPlannedFutureMoves.containsTI(ti) then
			used := rc.usedLength;
			used := used - rc.getTILengthInMetres(ti);
			if rc.getNumQueuedPlannedActualTIs() &gt; 1 then
				used := used - rc.myRoRoLaneArea.standardGap;
			endif;
			rc.setUsedLength(used);
		endif;
	endif;

end;</source>
        <Parameter name="_control" type="CMIF_MoveController"/>
    </JadeMethod>
    <JadeMethod name="fixupStockOnHand" id="941ce097-0abd-4878-9a30-c3c983fdcccd">
        <updating/>
        <source>fixupStockOnHand(_passport : CM_Passport input; _comment :String; _parent : Object; _cmifMonitor : CMIF_Monitor input)updating;
//--------------------------------------------------------------
//Created: 29 October 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	sohLocn : CM_SOHLocation;
begin

	sharedLock(self);
	
	if (not self.isStockControlled) then
		app.writeLog('Fixup Stock on Hand :: Location ' &amp; 
					 self.getFullId() &amp; '/' &amp;
					 self.ident &amp; 
					 ' skipped - not stock controlled',
					 LogINFO);
		return;
	endif;

	foreach sohLocn in self.allProductLocations do
		sohLocn.fixupStockOnHand(_passport, _comment, _parent, _cmifMonitor);
		if (not _passport.noErrors) then
			return;
		endif;
	endforeach;

end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <Parameter name="_comment" type="String"/>
        <Parameter name="_parent" type="Object"/>
        <Parameter name="_cmifMonitor" type="CMIF_Monitor" usage="input"/>
    </JadeMethod>
