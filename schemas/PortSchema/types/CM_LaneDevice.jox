// Parameters:  None
// Returns:     Nothing
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	self.type		:= _proxy.type;

	// we expect all devices to already exist (could change!)
epilog

end;</source>
        <Parameter name="_proxy" type="CM_LaneDevice"/>
    </JadeMethod>
    <JadeMethod name="setMyLaneController" id="bfa762a8-f642-4e83-9d2a-bdb02373c242">
        <updating/>
        <source>setMyLaneController(_value :CM_LaneController)updating;
// ---------------------------------------------------------------------------
// Created:     22 June 2009 by concms1:1
// Purpose:     CCMS 1061 - Gate Config changes
// Parameters:  None
// Returns:     Nothing
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	self.raiseExceptionIfNotTransient (method);
	//_value.raiseExceptionIfNotTransient (method);
	
	self.myLaneController	:= _value;
epilog

end;</source>
        <Parameter name="_value" type="CM_LaneController"/>
    </JadeMethod>
    <JadeMethod name="validate" id="9d06d196-7c1a-464c-97c7-20b14c67ed59">
        <source>validate(_passport :CM_Passport input) protected;
// ---------------------------------------------------------------------------
// Created:     23 June 2009 by concms1
// Purpose:     CCMS 1061 - Gate Config
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	if self.type &lt;&gt; self.Type_BoomIn and
		self.type &lt;&gt; self.Type_BoomOut and 
		self.type &lt;&gt; self.Type_Kiosk and
		self.type &lt;&gt; self.Type_Printer and
		self.type &lt;&gt; self.Type_RFIDTagReaderAssign and
		self.type &lt;&gt; self.Type_WeighBridge and
		self.type &lt;&gt; self.Type_RFIDTagReaderRead and
		self.type &lt;&gt; self.Type_ScanReader 				// ### TFS 52773 06May2022 NAVPW1
	then
		app.raiseUnexpectedProgramError (self.class.name, method.name, 'Invalid lane device type');
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
