    <JadeMethod name="addResults" id="dcad3d5b-2a76-489d-bcbe-98ad927b464d">
        <updating/>
        <source>addResults(s:String) updating;

begin
	if txtResults.text.length &gt; 1000000 then
		txtResults.text := txtResults.text[txtResults.text.length-1000000:end];
	endif;
	if not s.cnContains(" generated on ") then
		txtResults.text := txtResults.text &amp; s &amp; CrLf;
	else
		txtResults.text := txtResults.text &amp; app.actualTimeAppServer.logFormat &amp; " " &amp; s &amp; CrLf;
	endif;
	txtResults.scrollVertPos := 99999;
	txtResults.refreshNow;
end;</source>
        <Parameter name="s" type="String"/>
    </JadeMethod>
