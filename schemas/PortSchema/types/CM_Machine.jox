    <JadeMethod name="setProxy" id="e988ad9a-6fbb-44eb-8690-024c79961437">
        <updating/>
        <source>setProxy(pId, pDescription : String;
         pMachineType :Integer;
         pTransferArea : CM_CraneTransferArea;
         pMaxLiftWeight : Integer;
         pTerm : CM_Terminal;
         pAvailable,_can40,_can30, _can45, _can53, pHasRadioTelemetry,pOnToolbar : Boolean;
         pCargoTypes,pTerminalAreas:ObjectArray;
         networkAddress : String;
         requiresAvailabilityCode, recordActivityHistory : Boolean;
         maxRejectedTasks : Integer;
		 pExternalRef :String) updating;

vars

begin

	self.raiseExceptionIfNotTransient(method);

	self.id := pId[1:4];
	self.setCode(self.id);
	self.description := pDescription[1:25];
	self.externalRef := pExternalRef;        //02.10.2018 cnwma1 TFS #41234
	self.machineType := pMachineType;
	self.maxLiftWeight := pMaxLiftWeight;
	self.available := pAvailable;
	self.canLift40Foot := _can40;
	self.canLift30Foot 			:= _can30; // PAR 16415 CCMS 1029
	self.canLift45Foot 			:= _can45; // PAR 16415 CCMS 1029
	self.canLift53Foot 			:= _can53; // PAR 16415 CCMS 1029
	self.hasRadioTelemetry := pHasRadioTelemetry; 
//	self.onToolbar := pOnToolbar;
	self.myTerminal := pTerm;
	self.allAllowedCargoTypes.clear;
	if pCargoTypes &lt;&gt; null then
		pCargoTypes.copy(self.allAllowedCargoTypes);
	endif;
	//epr 14/9/06 changed from allowedTerminalAreas to allowedTAMasters
	self.allowedTAMasters.clear;
	if pTerminalAreas &lt;&gt; null then
		pTerminalAreas.copy(self.allowedTAMasters);
	endif;
	
	self.myRoot := app.myRoot;
	
end;</source>
        <Parameter name="pId" type="String"/>
        <Parameter name="pDescription" type="String"/>
        <Parameter name="pMachineType" type="Integer"/>
        <Parameter name="pTransferArea" type="CM_CraneTransferArea"/>
        <Parameter name="pMaxLiftWeight" type="Integer"/>
        <Parameter name="pTerm" type="CM_Terminal"/>
        <Parameter name="pAvailable" type="Boolean"/>
        <Parameter name="_can40" type="Boolean"/>
        <Parameter name="_can30" type="Boolean"/>
        <Parameter name="_can45" type="Boolean"/>
        <Parameter name="_can53" type="Boolean"/>
        <Parameter name="pHasRadioTelemetry" type="Boolean"/>
        <Parameter name="pOnToolbar" type="Boolean"/>
        <Parameter name="pCargoTypes" type="ObjectArray"/>
        <Parameter name="pTerminalAreas" type="ObjectArray"/>
        <Parameter name="networkAddress" type="String"/>
        <Parameter name="requiresAvailabilityCode" type="Boolean"/>
        <Parameter name="recordActivityHistory" type="Boolean"/>
        <Parameter name="maxRejectedTasks" type="Integer"/>
        <Parameter name="pExternalRef" type="String"/>
    </JadeMethod>
    <JadeMethod name="setProxyFromCMIF_Machine" id="cf8ac817-9c94-4ad0-b665-bd2da7fe0baf">
        <updating/>
        <source>setProxyFromCMIF_Machine(_cmifMachine : CMIF_Machine; _passport : CM_Passport) updating;
// ---------------------------------------------------------------------------
// Created:		25 March 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------
/*
Date		Who		Reason
04 Sep 2009	cnwer1	CCMS 1076 - RMG machines added 
02 Oct  2018    cnwma1  ChangeRequest 41234: SAP Integration - Mapping fields
*/


vars

begin

	self.raiseExceptionIfNotTransient(method);

	self.id 					:= _cmifMachine.code;
	self.setCode(self.id);
	self.description 			:= _cmifMachine.description;
	self.externalRef 			:= _cmifMachine.externalRef;      //02.10.2018 cnwma1 TFS #41234
	self.colour 				:= _cmifMachine.colour;
	self.machineType 			:= _cmifMachine.machineType.type;
	self.maxLiftWeight 			:= _cmifMachine.maxLiftWeight;
	self.available 				:= _cmifMachine.available;
	self.canLift40Foot 			:= _cmifMachine.canLift40Foot;
	self.canLift30Foot 			:= _cmifMachine.canLift30Foot; // PAR 16415 CCMS 1029
	self.canLift45Foot 			:= _cmifMachine.canLift45Foot; // PAR 16415 CCMS 1029
	self.canLift53Foot 			:= _cmifMachine.canLift53Foot; // PAR 16415 CCMS 1029
	//self.canTwinLift 			:= _cmifMachine.canTwinLift;//ccms1595 27/11/07
	self.machineLiftType 		:= _cmifMachine.machineLiftType;//ccms1595 27/11/07
	self.canWeighCargo			:= _cmifMachine.canWeigh;
	self.canCertifyWeight		:= _cmifMachine.canCertifyWeight;	// TFS 2357 14/07/2016
	self.hasRadioTelemetry 		:= _cmifMachine.hasRadioTelemetry; 
//	self.onToolbar 				:= _cmifMachine.onToolbar;
	self.myTerminal 			:= _passport.myTerminal;
	self.maxHeightFull			:= _cmifMachine.maxStackHeightFull;			
	self.maxHeightMT			:= _cmifMachine.maxStackHeightMT;
	self.maxRejectedTasks		:= _cmifMachine.maxRejectedTasks;
	self.networkAddress			:= _cmifMachine.networkAddress;
	self.recordActivityHistory	:= _cmifMachine.recordActivityHistory;
	self.requireAvailabilityCode:= _cmifMachine.requiresAvailabilityCode;
	self.isNotAvailableForEntry := _cmifMachine.isNotAvailableForEntry;
	self.myRFIDTag				:= _cmifMachine.myRFIDTag;
	self.weightDifference		:= _cmifMachine.weightDifference;	//ccms jmt 1032, Par 18649. Dec 2008
	self.loadingPosition		:= _cmifMachine.loadingPosition; //ccms 1076 19/8/09
	self.interchangeType		:= _cmifMachine.interactionType;//ccms 1076 19/8/09
	self.setMyPhysicalStartBay(_cmifMachine.myPhysicalStartBay); //ccms 1076 4/9/09
	self.setMyPhysicalEndBay( _cmifMachine.myPhysicalEndBay); //ccms 1076 4/9/09
	self.tareWeight				:= _cmifMachine.tareWeight;	//12 Mar 2014	NDL Par 33268
	self.bucketVolume			:= _cmifMachine.bucketVolume; //epr 9/4/14 epr CCMS 1366
	//epr TFS 37584 27/4/18
	self.accessMaxHeightDiff    := _cmifMachine.accessMaxHeightDiff;
	self.accessMaxLocationReach := _cmifMachine.accessMaxLocationReach;
	self.accessMaxOverstowHeight := _cmifMachine.accessMaxOverstowHeight;
	
	
	self.myTerminal				:= app.getMyTerminalDO_NOT_USE();
	
	self.myOwner				:= _cmifMachine.myOwner;	//15 May 2018	NDL	TFS 38570
	
	self.allAllowedCargoTypes.clear;
	if _cmifMachine.cargoTypes &lt;&gt; null then
		_cmifMachine.cargoTypes.copy(self.allAllowedCargoTypes);
	endif;
	
		//epr 14/9/06 changed from allowedTerminalAreas to allowedTAMasters
	self.allowedTAMasters.clear;
	if _cmifMachine.terminalAreas &lt;&gt; null then
		_cmifMachine.terminalAreas.copy(self.allowedTAMasters);
	endif;
	
	// CCMS 1438
	self.allAllowableContentsStatuses.clear();
	_cmifMachine.allAllowableContentStatuses.copy(self.allAllowableContentsStatuses);
	
	self.setQueues(_cmifMachine.allSelectedQueues);
	
	self.myRoot := app.myRoot;
	
end;</source>
        <Parameter name="_cmifMachine" type="CMIF_Machine"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setQueues" id="e080fce4-1990-4d47-a2e8-deaaca7a4d63">
        <updating/>
        <source>setQueues(pQueues : CM_RTQueueArray) updating;
//Called from VB interface, sets the queues this machine is participating in
//in the order they are to participate. The array may be null.
//NOTE:::: the queues have NO ref back to us
//DQ 03/05/2000
vars
	rtQ	:	CM_RadioTelemetryQueue;
begin
	//------------------
	//clear out the current queues
	//------------------
	self.allQueues.clear;
	if pQueues.size = 0 then
		return;
	endif;
	self.checkCanJoinQueue();	// raises an exception is false

	if pQueues.size = 1 then
		//----------------
		//There is only 1 here, if its the "default" of our Standard Queue, then
		//no need to add to the queues coll.
		//----------------
		if pQueues[1] = self.myPrimaryQueue then	
			return;
		endif;
	endif;
	//------------------
	//Add em in..
	//------------------
	foreach rtQ in pQueues do
		//--------------
		//Test the machine can actually access the queue's areas
		//--------------
		rtQ.canMachineAccess(self);
		//--------------
		//OK, now add in the queues to the collection.
		//--------------
		self.addToQueue(rtQ, false, 0);
	endforeach;
end;</source>
        <Parameter name="pQueues" type="CM_RTQueueArray"/>
    </JadeMethod>
    <JadeMethod name="setTareWeight" id="9190c379-74d1-4544-b669-9142dfd68c41">
        <updating/>
