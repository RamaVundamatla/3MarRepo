    <JadeMethod name="btnTimings_click" id="c851c0bb-3fc3-4a12-85c6-305cbf15258f">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnTimings_click(btn: Button input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 June 2018	jlgndl1	Initial creation	TFS 39215

*/

vars

	form : HMS_MarineServiceTimingsForm;
	
begin

	if self.myCurrentMovement = null then
		app.msgBox('Cannot perform edit as there is no movement selected.', 'Error', MsgBox_Stop_Icon  + MsgBox_OK_Only);
		self.cmbMovements.setFocus();
		return;
	endif;

	if self.myCurrentMovement.myHMSVoyageData.voyageStatus = HMS_VoyageIsLocked then
		//Voyage is locked therefore they cannot change date/times berth etc
		app.msgBox('Cannot perform edit as the movement is locked.', 'Error', MsgBox_Stop_Icon  + MsgBox_OK_Only);
		return;
	endif;

	form := app.loadForm(HMS_MarineServiceTimingsForm, HMS_Assistant, false, false, true, self.myTerminal, null).HMS_MarineServiceTimingsForm;

	if form = null then
		return;
	endif;
	
	form.setParentForm( self );
	form.setMyMarineServicesTimings( self.myCurrentMovement, null );
	
	form.showModal;
	
epilog

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
