    <JadeMethod name="setupNewPreNoteForMerge" id="017eddd2-f8cc-4ae6-bd8a-5745d826bb0c">
        <updating/>
        <source>setupNewPreNoteForMerge() updating;
/*

Purpose:			

Parameters:			Special behaviour when creating a Pre-note, from excess unloaded in HH Truck Unloader
					when the extra is being merged back into a pre-note that no longer exists.
					Basically we create an empty pre-note, then merge teh excess back into it.

Return Value:		

Date		Who		Reason
03 September 2018	jlgndl1	Initial creation	TFS 39769

*/

vars

begin

	if not self.myCargoType.allowDuplicates then
		return;
	endif;
	
	self.locationId := null;
	self.totalQuantity := 0;
	self.totalWeight := 0;
	self.totalVolume := 0;
	self.myMoveCloneFromTI := null;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="splitBulkOrBreakBulkAndWLE" id="a9252b4b-e6a4-4a8e-a49b-bb90b0ce39eb">
        <updating/>
        <source>splitBulkOrBreakBulkAndWLE(_control : CMIF_MoveController input) : CM_TrackedItem updating;
//
// Purpose:			_control has a TI and WLE that are for more than the planned original prenote WLE
//					Go through the prenote WLEs to find other planned moves so we can fill those with
// 					what's in excess from the current move. Use as many prenote WLEs as it takes to fill
// 					the weight / quantity requirements of the real move, then finally complete the original
// 					real move for its original planned amount
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 15/10/2021	navdap1		TFS 51935 SAL Direct Loading Partial Prenoted Cargo from Truck to Vessel
// 15/11/2021	navdap1		TFS 52360 SAL Direct Prenote to Voyage Incorrect Job Values
// 09/12/2021	navdap1		TFS 52993 SAL Direct Loading - Marking Job as Direct Delivery
// 01/03/2022	navdap1		TFS 52686 MTN Direct Delivery - Jade error when tried moving more cargo than planned in hold job
// 12/12/2025   navsp1      MTN-36700  STWO - Damage Photos Not Visible for Multi-Quantity Cargo IDs After Full Discharge
vars
	passport : CM_Passport;
	ti, newTI : CM_TrackedItem;	
	newState : Integer;
	trans : CM_TITransaction;
	storageConfig : CM_StorageConfig;
	newControl : CMIF_MoveController;
	prenote : CM_TrackedItem;
	wle, ddWle, prenoteWle, newWle, newDDWle, tiWle, wleToClone, prenoteWleComplete : CM_WorkListEntry;
	excess, originalExcess, moved : Decimal [14,4];
	targetLocation : CM_LocationsController;
	foundHeight : Integer;
	excessWeight : Boolean;
	fm : CM_FutureMove;
	completedWLEs : CM_WLESet;
	wleSet : CM_WLESet;
	amountToUse, plannedTotal, onsiteTotal : Integer;	// TFS 52360
	newVoyageWLE : CM_VoyageWLE;						// TFS 52360
	newRoadWLE : CM_YardWLE;							// TFS 52360
	useSubSeqNum : Boolean;								// TFS 52360
	compareAmt : Integer;								// TFS 52360
	ddWLEs : CM_WLESet;									// TFS 52360
	wleToMove : CM_WorkListEntry;						// TFS 52360
	splitRoad : Boolean;						// TFS 52686
	splitRoadAmt : Decimal [14,4];				// TFS 52686

begin
	passport := _control.myPassport;
	
	ti := _control.myTrackedItem;
	wle := _control.myWorkListEntry;				// this is the yard WLE, with no target location
	ddWle := _control.myDDWorkListEntry;			// this is a voyage WLE, with a target location
	
	storageConfig := ti.myTerminal.myStorageConfig;
	if storageConfig &lt;&gt; null and storageConfig.includesTriggerType(CargoSplitMerge) then
		ti.createStorageTransaction(_control, passport);
		if not passport.noErrors() then
			return null;
		endif;
	endif;
	
	if _control.directExcessWeight &lt;&gt; null then
		excess := _control.directExcessWeight;
		excessWeight := true;
		onsiteTotal := ti.weight.Integer;			// TFS 52360
	else
		excess := _control.directExcessQuantity;
		onsiteTotal := ti.totalQuantity;			// TFS 52360
	endif;
	originalExcess := excess;
	prenote := ti.myVoyage.allNotifiedTIsByIdCargoType[ti.id, ti.cargoType];
	if prenote &lt;&gt; null then
		wleSet := prenote.allWorklistEntries;
	else
		wleSet := ti.allWorklistEntries;
		useSubSeqNum := true;						// TFS 52360
	endif;
	
	// now move the excess to any prenoted planned move(s)
	foreach prenoteWle in wleSet do
		if excess &lt;= 0 then
			break;
		endif;
		if prenoteWle.status = WLE_COMPLETED then
			continue;
		endif;
		if prenoteWle.locationTarget = ddWle.locationTarget 		// this is the location we've just filled
		and prenoteWleComplete = null then						// TFS 52293
			prenoteWleComplete := prenoteWle;
			continue;
		endif;
		
		// TFS 52686 if this WLE is a road WLE, all voyage WLEs have been used up and there is still some cargo to move
		// - split the road WLE but don't do anything else
		splitRoad := false;
		splitRoadAmt := null;
		if prenoteWle.isRoad then
			splitRoad := true;
			splitRoadAmt := excess;
		endif;
		// TFS 52686 end of this bit
		
		// we have a new location - move our new TI
		// create new ti from the ti on the controller
		newTI := ti.cloneMe(ti.id, ti.state, null, false, true, true, false, _control.myOriginatingLocation, ti.myVoyage, passport).CM_TrackedItem;
		if passport &lt;&gt; null and passport.useTIDictDeferUpdate then
			passport.addTrackedItemForDeferUpd(self);
		else
			newTI.updateCollections();
		endif;
		newTI.setMasterTI(ti);
		newState := newTI.calculateState(REAL_MODE);
		newTI.changeState(newState, passport);
		
		if newTI = null then
			app.raiseCMException1(Err_Unexpected_Program_Error,"split cargo not created",null,null);
			return null;
		endif;
		
		create newControl transient;
		newControl.setMyPassport(passport);
		if useSubSeqNum then									// TFS 52360
			if splitRoadAmt = null then				// TFS 52686
				compareAmt := prenoteWle.CM_VoyageWLE.subSeqNum;// TFS 52360
			else									// TFS 52686
				compareAmt := splitRoadAmt.Integer;	// TFS 52686
			endif;									// TFS 52686
		else													// TFS 52360
			if excessWeight then								// TFS 52360
				compareAmt := prenoteWle.weight.Integer;		// TFS 52360
			else												// TFS 52360
				compareAmt := prenoteWle.quantity;				// TFS 52360
			endif;												// TFS 52360
		endif;													// TFS 52360
		//if (excess &gt;= prenoteWle.weight and excessWeight) or (excess &gt;= prenoteWle.quantity and not excessWeight) then	// TFS 52360
		if excess &gt;= compareAmt then																						// TFS 52360
			// we've used up all of this prenoted planned move - set weight/quantity to zero so we know to delete it later
			if excessWeight then
				//newControl.setWeight(prenoteWle.weight);		// TFS 52360
				newControl.setWeight(compareAmt);				// TFS 52360
			else
				//newControl.setQuantity(prenoteWle.quantity);	// TFS 52360
				newControl.setQuantity(compareAmt);				// TFS 52360
			endif;
		else
			// this prenoted planned move still has something left - reduce it by the amount we're moving
			if excessWeight then
				newControl.setWeight(excess);
			else
				newControl.setQuantity(excess.Integer);
			endif;
		endif;
		newControl.setMyTrackedItem(newTI);
		newControl.setMoveMode(REAL_MODE);
		// create a new yard WLE (cloned from wle) for the new move controller
		newWle := wle.cloneSelf(wle.isTransient);
		newWle.setJob(wle.job);
		newWle.setMyTrackedItem(newTI);
		newWle.setLocations(wle.locationSource, wle.locationTarget);
		newWle.updateRequest(wle.myRequest);
		if excessWeight then
			newWle.setWeight(newControl.weight);
		else
			newWle.setQuantity(newControl.quantity);
		endif;
		// TFS 52686 don't do any moving if we're processing a yard WLE - just set its location to the truck,
		// and everything else we need will be done in the splitQVW below and in the move of the original TI later
		if splitRoad then
			newTI.myPrimaryActualLocation := ti.myPrimaryActualLocation;
			newTI.allLocations.add(newTI.myPrimaryActualLocation);
			newState := newTI.calculateState(REAL_MODE);
			newTI.changeState(newState, passport);
		else
			newControl.setMyWorkListEntry(newWle);
			// find a WLE on the existing TI that matches the target location of this prenote WLE
			newDDWle := null;
			plannedTotal := null;																				// TFS 52360
			//foreach tiWle in ti.allWorklistEntries where tiWle.locationTarget = prenoteWle.locationTarget do	// TFS 52360
			foreach tiWle in ti.allWorklistEntries do															// TFS 52360
				if tiWle.locationTarget = prenoteWle.locationTarget then										// TFS 52360
					wleToClone := tiWle;
				//break;																						// TFS 52360
				endif;																							// TFS 52360
				if tiWle.isKindOf(CM_VoyageWLE) and tiWle.CM_VoyageWLE.subSeqNum &lt;&gt; null then					// TFS 52360
					plannedTotal := plannedTotal + tiWle.CM_VoyageWLE.subSeqNum;								// TFS 52360
				endif;																							// TFS 52360
			endforeach;
			// didn't find one? create a new voyage WLE (cloned from ddWle) for the new controller
			if wleToClone = null then
				newDDWle := ddWle.cloneSelf(ddWle.isTransient);
			else
				newDDWle := wleToClone.cloneSelf(wleToClone.isTransient);
			endif;
			newDDWle.setMyTrackedItem(newTI);
			newDDWle.setJob(prenoteWle.job);
			if newDDWle.job.isVoyageHoldJob then
				newDDWle.job.CM_VoyageJob.allReleaseTrackeditems.addNoDuplicates(newTI, false);
			endif;
			newDDWle.setLocations(ddWle.locationSource, prenoteWle.locationTarget);
			newDDWle.updateRequest(prenoteWle.myRequest);
			if excessWeight then
				newDDWle.setWeight(newControl.weight);
			else
				newDDWle.setQuantity(newControl.quantity);
			endif;
			newControl.myDDWorkListEntry := newDDWle;
			newControl.myDDJob := newDDWle.job;
			
			newControl.myOriginalTI := ti;
			newControl.setMyOriginatingLocation(_control.myOriginatingLocation);
			ti.myTerminal.findLocationFromString(prenoteWle.locationTarget, true, targetLocation, foundHeight);
			newControl.setMyToPrimaryLocation(targetLocation);
		endif;
		
		// adjust the weights and create split transactions
		ti.splitSetQVW(newControl, newTI);
        
        //Split and merge attachments
        self.handleMergeAttachments(newTI);                                             //MTN-36700
        
        
		//if not excessWeight then							// TFS 52686
		if not excessWeight and newDDWle &lt;&gt; null then		// TFS 52686
			newDDWle.setWeight(newTI.weight);		// keep a weight on the new wle, even though we're tracked by quantity
			ddWle.setWeight(ti.weight);				// and fix the weight on the old wle
		endif;
		
		trans := ti.allTransactions.findLastStorageRelevantTrans();
		if trans = null then
			trans := ti.allPriorTransactions.findLastStorageRelevantTrans();
		endif;
		if trans &lt;&gt; null then
			newTI.allPriorTransactions.add(trans);
		endif;
		
		// now that we have a controller, and a new TI, and some matching WLEs, just move the new TI
		// TFS 52686 if we're dealing with a Yard WLE at this stage, don't do anything
		if not splitRoad then
			newControl.isSystemMove := true;
			newControl.directDoNotSplit := true;
			newControl.executeMove(passport);
			newControl.executePostMove(passport);
		endif;
		if passport.hasErrors then
			return null;
		endif;
		
		// TFS 52360 If the whole planned amount on all jobs is less than what's on site, split some WLEs
		//if plannedTotal &lt;&gt; null and plannedTotal &lt; onsiteTotal then						// TFS 52686
		if plannedTotal &lt;&gt; null and plannedTotal &lt; onsiteTotal and not splitRoad then		// TFS 52686
			// split the wle we've just cloned 
			newVoyageWLE := wleToClone.cloneSelf(ddWle.isTransient).CM_VoyageWLE;
			// attach it to the original TI but this WLE's job
			newVoyageWLE.setMyTrackedItem(ti);
			newVoyageWLE.setJob(prenoteWle.job);
			if newVoyageWLE.job.isVoyageHoldJob then
				newVoyageWLE.job.CM_VoyageJob.allReleaseTrackeditems.addNoDuplicates(ti, false);
			endif;
			newVoyageWLE.setLocations(ddWle.locationSource, prenoteWle.locationTarget);
			newVoyageWLE.updateRequest(prenoteWle.myRequest);
			// set amount to wleToClone.amount - excess			
			if excessWeight then
				//newVoyageWLE.setWeight(wleToClone.CM_VoyageWLE.subSeqNum - excess);				// TFS 52293
				newVoyageWLE.setWeight(onsiteTotal - plannedTotal);									// TFS 52293
			else
				//newVoyageWLE.setQuantity((wleToClone.CM_VoyageWLE.subSeqNum - excess).Integer);	// TFS 52293
				newVoyageWLE.setQuantity((onsiteTotal - plannedTotal).Integer);						// TFS 52293
			endif;
			newVoyageWLE.setSubSeqNum(onsiteTotal - plannedTotal);									// TFS 52293
			//newVoyageWLE.CM_VoyageWLE.setSubSeqNumNullAndAdjust((wleToClone.CM_VoyageWLE.subSeqNum - excess).Integer);
			// split the road wle
			newRoadWLE := wle.cloneSelf(wle.isTransient).CM_YardWLE;
			// attach it to the original TI and the road job
			newRoadWLE.setJob(wle.job);
			newRoadWLE.setMyTrackedItem(ti);
			newRoadWLE.setLocations(wle.locationSource, wle.locationTarget);
			newRoadWLE.updateRequest(wle.myRequest);
			// if the road WLE we've split this from is the one that is looking after the DD voyage WLEs, transfer them to this new WLE
			if not wle.allDirectDeliveryChildWLEs.isEmpty then
				create ddWLEs transient;
				wle.allDirectDeliveryChildWLEs.copy(ddWLEs);
				foreach wleToMove in ddWLEs do
					wleToMove.setMyDirectDeliveryParentWLE(newRoadWLE);
				endforeach;
				delete ddWLEs;
			endif;
			// set amount to the original road WLE amount - the original control move amount
			if excessWeight then
				newRoadWLE.setWeight(newRoadWLE.weight - _control.weight);
			else
				newRoadWLE.setQuantity(newRoadWLE.quantity - _control.quantity);
			endif;
		endif;
		// TFS 52360 end of this bit
		
		if excessWeight then
			excess := excess - newControl.weight;
			moved := moved + newTI.weight;
		else
			excess := excess - newControl.quantity;
			moved := moved + newTI.totalQuantity;
		endif;
		
		if not splitRoad then	// TFS 52686
			// TFS 52360 send notifications
			newWle.causeEvent(newTI.myTerminal.getTerminalEvent(WLE_Create_Event), false, newWle);
			newDDWle.causeEvent(newTI.myTerminal.getTerminalEvent(WLE_Create_Event), false, newDDWle);
			if newVoyageWLE &lt;&gt; null then
				newVoyageWLE.causeEvent(newTI.myTerminal.getTerminalEvent(WLE_Create_Event), false, newVoyageWLE);
				newRoadWLE.causeEvent(newTI.myTerminal.getTerminalEvent(WLE_Create_Event), false, newRoadWLE);
			endif;
			// TFS 52360 end of this bit
		endif;					// TFS 52686
		delete newControl;
		newTI := null;
	endforeach;
	
	// reduce the quantity / weight on _control's TI, WLE and DD WLE (control wle is the road wle, DD wle is the voyage wle)
	// TFS 52360 use original planned amount if present - this is present because the entire prenote has been brought onsite,
	// and we've lost the original planning weight/quantity because the voyaeg WLEs have inherited the road WLE weight/quantity
	// subSeqNum on the voyage wle is a hacky way of retaining this original planned amount
	if prenote = null then											// TFS 52360
		amountToUse := ddWle.CM_VoyageWLE.subSeqNum;				// TFS 52360
	endif;															// TFS 52360
	if excessWeight then
		if amountToUse &lt;&gt; null then									// TFS 52360
			wle.setWeight(amountToUse);								// TFS 52360
			ddWle.setWeight(amountToUse);							// TFS 52360
		else														// TFS 52360
			wle.setWeight(wle.weight - originalExcess);
			//ddWle.setWeight(ddWle.weight - originalExcess);				// TFS 52293
			ddWle.setWeight(wle.weight);									// TFS 52293
		endif;														// TFS 52360
		_control.setWeight(_control.weight - originalExcess);
	else
		if amountToUse &lt;&gt; null then									// TFS 52360
			wle.setQuantity(amountToUse);							// TFS 52360
			ddWle.setQuantity(amountToUse);							// TFS 52360
		else														// TFS 52360
			wle.setQuantity(wle.quantity - originalExcess.Integer);
			ddWle.setQuantity(wle.quantity);
		endif;														// TFS 52360
		_control.setQuantity(_control.quantity - originalExcess.Integer);
	endif;
	_control.directExcessQuantity := null;
	_control.directExcessWeight := null;
	
	// complete the move of the original TI for the reduced amount
	ti.setMyLocations(_control);
	// if set locations above has resulted in the ti (which originally was on the truck) being moved to a voyage, update its location
	// if the ti is still on the truck, because not enough was moved to move the entire truck load, just leave it where it is
	if ti.myPrimaryActualLocation &lt;&gt; null and ti.myPrimaryActualLocation.isVoyageController then
		ti.refreshMyFutureLocations(_control.moveMode, null);
		ti.setLocationString(_control);
		if ddWle.job.isVoyageHoldJob then
			ddWle.job.CM_VoyageJob.allReleaseTrackeditems.addNoDuplicates(ti, false);
		endif;
		// tidy up the TI's WLEs if we've been moved to the voyage
		// We still have WLE(s) that were created when this ti was gated in on the truck as part of setting up the yard WLE with DD children
		// - need to delete any WLEs not pointing to the completed prenote WLE
		create completedWLEs transient;
		foreach wle in ti.allWorklistEntries where wle.isKindOf(CM_VoyageWLE) do
			if wle.locationTarget &lt;&gt; prenoteWleComplete.locationTarget then
				completedWLEs.add(wle);
			endif;
		endforeach;
	endif;
	if prenoteWleComplete &lt;&gt; null then
		// this is a completed prenote WLE  - tidy it up (delete) this wle and its future move
		fm := prenoteWleComplete.myFutureMove;
		if fm &lt;&gt; null then
			delete fm;
		endif;
		if prenote &lt;&gt; null then
			prenoteWleComplete.setStatus(WLE_COMPLETED);
			prenoteWleComplete.erase(NORMAL_ERASE);
		endif;
	endif;
	if completedWLEs &lt;&gt; null then
		completedWLEs.purge;
	endif;
	
	// if moving to a voyage has to update the voyage to where it is
	if ti.myPrimaryActualLocation &lt;&gt; null and ti.myPrimaryActualLocation.isKindOf(CM_VoyageController) then
		if ti.myVoyage &lt;&gt; ti.myPrimaryActualLocation.CM_VoyageController.myVoyage then
			ti.setMyVoyage(ti.myPrimaryActualLocation.CM_VoyageController.myVoyage, passport);
		endif;
	endif;

	return newTI;
	
epilog
	delete newControl;
	delete completedWLEs;
end;</source>
        <Parameter name="_control" type="CMIF_MoveController" usage="input"/>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="splitChargesByFactor" id="7d616ca7-4584-4715-9b27-47fd2a917597">
        <updating/>
        <source>splitChargesByFactor(_oldWeight, 
						  _oldVolume 	: Decimal; 
						  _newWeight, 
						  _newVolume 	: Decimal; 
						  _oldQty, _newQty : Integer;
						  _newTI 		: CM_TrackedItem) updating;
/* JIRA 35213 renamed from splitMergeChargesByFactor

Purpose:			
		TFS 1990 modify existing invoice lines, proforma charges and payments that are weight or volume-based
		and create new manual invoice lines, payments and proforma details for the new cargo from the split values.
Parameters:			

Return Value:	
Date		Name	TFS#		Description
============================================================================
02/02/2018	jlgns1	Bug 36580: 	ADP - Tax for Cash Module Part 3
08/08/2018 	JLGNS1	Bug 39772: 	PKT - Decimal Precision Error
28/03/2019	jlgka1	TFS 42980	PKT - Modify to trapped Division by Zero.
21/10/2019  cnwma1  Bug 47081: JMT - Decimal amount on Cash needs to be reviewed
30/01/2020  cnwma1  Bug 48416: ADP - Invoice lines not going to expected cash invoice
02/05/2024  navma1	Bug 63718: QTS - Error 88618 while gate out
JIRA 34760 02MAY2025 NAVAB1 if cash is paid whilst onship and then part is discharged, the split gives the proportional cash payment to the 'new' TI and the new TIs rec ship makes the invoice line, but they are not linked. This will happen at road exit
============================================================================*/
// ### JIRA 34909 16MAY2025 NAVAB1 changed all the REALS to decimals

vars
	ts						: TimeStamp;
	hasPayment				: Boolean;
	quantity,
	newQuantity, 
	invAdjustmentAmount, 
	payAdjustmentAmount, 
	taxAdjustmentAmount		: Decimal[23, 6];  // ### JIRA 34982 28MAY2025 NAVAB1
	value,
	newValue, 
	newtaxvalue, 
	taxvalue,
	//factor, 
	taxfactor				: Decimal[23, 6];
	factor					: Decimal[23, 12];	//02.05.2024 navma1 #63718
	invLine,
	newLine, matchLine,
	otherLine				: CM_InvoiceLine;
	receipt					: CM_CashReceipt;
	newPayment, 
	newTaxPayment, 
	mergePayment,
	payment, 
	taxpayment				: CM_CashPayment;
	newProfDetail,
	proformaDetail			: CM_ProformaDetails;
	ild				: CM_InvoiceLineDesc;
	oa						: ObjectArray;
	obj						: Object;
	includeTaxPayment 		: Boolean;
	now						: TimeStamp;
	theController : CMIF_InvoiceLineManual;
	terminal : CM_Terminal;
	prevContext : Integer;

begin
	now := app.actualTimeServer;
	
	// ### JIRA 34909 16MAY2025 NAVAB1
	prevContext := app.myPassport.context;	
	app.myPassport.setContext(Context_Pass_InvSplitMerge); 
	
	// TFS 2379 it appears that this has been called with self and _newTI the same?
	if _newTI = self then
		return;
	endif;

	ts := app.serverTimestampAtTrxStart;
	// TFS 2379 these were reading and adding to self.invoiceLines and .allCashPayments and possibly creating too many instances
	//  changed to populate arrays and process these.  Also only do this processing for invoice lines with current payments
	//	as that's all its really needed for.
	
	terminal := self.myTerminal;
	
	// #### GET ALL THE INVOICE LINES THAT HAVE CASH PAYMENTS
	create oa transient;

	foreach invLine in self.invoiceLines do
		hasPayment := false;
		foreach payment in invLine.allCashPayments do
			if not payment.voided then
				if payment.myCarrier = null and
				   payment.myDriver = null then
					hasPayment := true;
					break;
				endif;
			endif;
		endforeach;
		if hasPayment then
			oa.add(invLine);
		elseif invLine.debtor.isCashOnlyDebtor(terminal) then
  // ### JIRA 34760 02MAY2025 NAVAB1
			if invLine.allCashPayments.isEmpty 
			and not self.allCashPayments.isEmpty then
				// have I got the cash payment that matches the invoice line?
				foreach payment in self.allCashPayments do
					if payment.getPaymentnvoiceLineType() = invLine.invoiceLineDesc then
						hasPayment := true;
						oa.add(invLine);
						break;
					endif;
				endforeach;
			// ### JIRA 35008 04JUN2025 NAVAB1
			elseif invLine.allCashPayments.isEmpty then
				hasPayment := true;
				oa.add(invLine);
			endif;
		endif;
	endforeach;

	foreach obj in oa do
		invLine := obj.CM_InvoiceLine;
		
		// #### don't split void or posted invoice lines
		if invLine.voided 
		or  (invLine.invoice &lt;&gt; null and invLine.invoice.isPosted) then		
			continue;
		endif;
		
		// #### Only split invoices line where the calc type is volume or weight
		if not (invLine.invoiceLineDesc.isWeightBased()
		or  invLine.invoiceLineDesc.isVolumeBased() 
		// ### JIRA 34760 30APR2025 NAVAB1
		or invLine.invoiceLineDesc.isQuantityBased()) then
			continue;
		endif;
		
		// #### Work out the adjustment factor
		factor := 0;
		if invLine.invoiceLineDesc.isWeightBased() then
			if _oldWeight &lt;&gt; _newWeight then
				factor := _newWeight / _oldWeight;
			endif;
		elseif invLine.invoiceLineDesc.isVolumeBased() then
			if _oldVolume &lt;&gt; _newVolume then
				factor := _newVolume / _oldVolume;
			endif;
		// ### JIRA 34760 30APR2025 NAVAB1
		elseif invLine.invoiceLineDesc.isQuantityBased() then
			if _oldQty &lt;&gt; _newQty then
				factor := _newQty / _oldQty;
			endif;
		endif;
		
		// #### Adjust the invoice lines and their payments
		if factor &lt;&gt; 0 then
			invLine.adjustForSplitByFactor(factor, invAdjustmentAmount, payAdjustmentAmount, taxAdjustmentAmount, includeTaxPayment); // REDUCE BY FACTOR
			
			
			//otherLine := _newTI.getInvoiceLineByTypeForCash(invLine.invoiceLineDesc);
			// ### JIRA 35213 27JUN2025 NAVAB1
			foreach matchLine in _newTI.invoiceLines do
				
				if matchLine.invoiceLineDesc = invLine.invoiceLineDesc 
				and matchLine.totalRate = invLine.totalRate
				and matchLine.taxRate = invLine.taxRate
				and matchLine.myTransactionTI = invLine.myTransactionTI then
					otherLine := matchLine;
					break;
				endif;
			
			endforeach;

			
			
			if otherLine = null then
			
				// ### JIRA 33007 03DEC2024 NAVAB1 change to pass in the controller in createManualInvoiceLine()
				create theController transient;
				theController.myInvoice := invLine.invoice;
				theController.chargeTime := ts;
				theController.quantity := invAdjustmentAmount;
				
				newLine := invLine.invoiceLineDesc.createManualInvoiceLine(theController, _newTI, false);
				
				if invLine.getOverridden then
					newLine.resetMinimumCharge(newLine.quantity * invLine.totalRate,invLine.totalRate);
				endif;
				newLine.setMyTransaction(invLine.myTransactionTI);
				delete theController;  // ### JIRA 35008 05JUN2025 NAVAB1
			
				 // ### JIRA 34760 02MAY2025 NAVAB1 if cash is paid whilst onship and then part is discharged, the split give the proportional cash payment to the 'new' TI and the new TIs rec ship makes the invoice line, but they arenot linked.
				//payment := invLine.allCashPayments.first;
				payment := invLine.getFirstNonCancelledPayment();  // ### JIRA 35593 29JUL2025 NAVAB1
				if payment &lt;&gt; null then
					receipt := payment.myCashReceipt;
					payAdjustmentAmount := newLine.lineTotal;  // ### JIRA 34982 28MAY2025 NAVAB1
					//newPayment := receipt.createCashPayment(payAdjustmentAmount, taxAdjustmentAmount, includeTaxPayment, receipt.myDebtorTerminal, _newTI, newLine, null, newLine.invoice);     // 30.01.2020 cnwma1 #48416
					newPayment := receipt.createCashPayment(payAdjustmentAmount, taxAdjustmentAmount, includeTaxPayment, receipt.myDebtorTerminal, _newTI, newLine, null, receipt.myCashInvoice); // 30.01.2020 cnwma1 #48416
					newPayment.setMyUserFrom(payment );	//26 Feb 2018	NDL	TFS 37220
					newPayment.setMyTerminal(); // TFS 36429
					newPayment.doAuditSplitMerge(factor,0,payAdjustmentAmount,method.qualifiedName, CM_AuditCashAdjustment.REASON_SPLIT_NEW);	//Bug 36580
					
					// set the receipt date time on the invoice other wise it will be ignored in the cash receipt display.
					// The cash receipt display at CM_CashReceipt::getBOLStoredDetails line 50ish.
					newLine.setChargeTime(receipt.dateTime); 
					newPayment.setDateTime(receipt.dateTime);

					if not receipt.allTrackedItems.includes(_newTI) then
						receipt.allTrackedItems.add(_newTI);
					endif;
					if not receipt.allInvoiceLines.includes(newLine) then
						receipt.allInvoiceLines.add(newLine);
					endif;
				endif;
			else
				otherLine.adjustForSplitByAmount(invAdjustmentAmount, payAdjustmentAmount); // INCREASE BY FACTOR
			endif;
		endif;
	endforeach;

	// do proforma payments now
	
	// ### ONLY AT TIME OF GATE RELEASE
	oa.clear();
	self.allCashPayments.copy(oa);
	/// only for current payments
	foreach obj in oa do
		payment := obj.CM_CashPayment;
		if payment.voided or
		   payment.myProformaDetail = null or
		   payment.myCarrier &lt;&gt; null or
		   payment.myDriver &lt;&gt; null or
		   payment.myCashPaymentForInvoice &lt;&gt; null then // TFS 7357 tax payment ignore
			continue;
		endif;
		
		 // ### JIRA 35593 30JUL2025 NAVAB1
		if payment.isCancelled then
			continue;
		endif;
		
		proformaDetail := payment.myProformaDetail;
		ild := proformaDetail.myInvoiceLineType;
		factor := 0;
		if ild.isWeightBased() then
			if _oldWeight &lt;&gt; _newWeight then
				factor := _newWeight / _oldWeight;
			endif;
		elseif ild.isVolumeBased() then
			if _oldVolume &lt;&gt; _newVolume then
				factor := _newVolume / _oldVolume;
			endif;
		// ### JIRA 34760 30APR2025 NAVAB1
		elseif ild.isQuantityBased() then
			if _oldQty &lt;&gt; _newQty then
				factor := _newQty / _oldQty;
			endif;
		endif;
		
		if factor &lt;&gt; 0 then
		
			// #### Work out the amount to REDUCE the proforma detail on THIS cargo's payments and then update date it
			value := payment.cashValue;			
			newValue := (value * factor).roundedTo(6);
			//jlgka TFS 42980 --&gt;
			if value = 0 then
				taxfactor := 0;
			else 
				taxfactor := (value - newValue) / value;
			endif;
			//jlgka TFS 42980 &lt;--
			newQuantity := (proformaDetail.quantity * factor).roundedTo(6);
			quantity    := proformaDetail.quantity - newQuantity;
			value       := value - newValue;
			payment.doAuditSplitMerge(1 - factor,payment.cashValue,value,method.qualifiedName,CM_AuditCashAdjustment.REASON_SPLIT_ORIGINAL);			//Bug 36580
			payment.setCashValue(value);
			proformaDetail.setValue(value);
			proformaDetail.setQuantity(quantity);
			proformaDetail.setRemarks();
			
			
			mergePayment := null;
			includeTaxPayment := payment.myCashPaymentForTax &lt;&gt; null;
			
			if includeTaxPayment then
			
				// TFS 8275 INCREASE TAX PAYMENT
				taxpayment := payment.myCashPaymentForTax;
				if taxpayment &lt;&gt; null then
					taxvalue    := taxpayment.cashValue;
					newtaxvalue := (taxvalue * taxfactor).roundedTo(6);
					taxpayment.setCashValue(newtaxvalue);
			
				endif;
			
			endif;
			
			mergePayment := _newTI.getCashPaymentByProformaLine(payment);
			if mergePayment &lt;&gt; null // MERGE increase existing payment
			and mergePayment &lt;&gt; payment then  // ### JIRA 35593 30JUL2025 NAVAB1
				newValue := newValue + mergePayment.cashValue;
				if mergePayment.cashValue = 0 then		// 14/2/18 TFS37099
					taxfactor := 0;
				else
					taxfactor := newValue / mergePayment.cashValue;
				endif;
				mergePayment.setCashValue(newValue);
				
				if mergePayment.myProformaDetail &lt;&gt; null then
					 // ### JIRA 35068 12JUN2025 NAVAB1if payild &lt;&gt; null then this is never populated!!!
						mergePayment.myProformaDetail.setValue(newValue);
						mergePayment.myProformaDetail.setQuantity(mergePayment.myProformaDetail.quantity + newQuantity);
						mergePayment.myProformaDetail.setRemarks();
					//endif;
				endif;
				
				// TFS 8275 INCREASE TAX PAYMENT
				taxpayment := mergePayment.myCashPaymentForTax;
				if taxpayment &lt;&gt; null then
					taxvalue    := taxpayment.cashValue;
					newtaxvalue := (taxvalue * taxfactor).roundedTo(6);
					taxpayment.setCashValue(newtaxvalue);
				endif;
			
			else // SPLIT create new payment
				// #### Work out the amount to INCREASE the proforma detail on OTHER cargo's payments and then update date it
				receipt       := payment.myCashReceipt;
				newProfDetail := receipt.createProformaDetail(newValue, newQuantity, proformaDetail.rate, proformaDetail.remarks, proformaDetail.myInvoiceLineType, _newTI, proformaDetail.transactionType, proformaDetail.overridden);
				receipt.allProformaDetails.addNoDuplicates(newProfDetail, false);  // ### JIRA 36550 07NOV2025 NAVAB1 proformDeail.myCashReceipt is not inversed!!
				
				//newPayment := receipt.createCashPayment(newValue,0, false, receipt.myDebtorTerminal, _newTI, null, newProfDetail, null);                   // 30.01.2020 cnwma1 #48416
				newPayment   := receipt.createCashPayment(newValue,0, false, receipt.myDebtorTerminal, _newTI, null, newProfDetail, receipt.myCashInvoice);  // 30.01.2020 cnwma1 #48416
				newPayment.setMyUserFrom( payment );	//26 Feb 2018	NDL	TFS 37220
				newPayment.doAuditSplitMerge(factor,0,newValue,method.qualifiedName,CM_AuditCashAdjustment.REASON_SPLIT_NEW);								 //Bug 36580
				if not receipt.allTrackedItems.includes(_newTI) then
					receipt.allTrackedItems.add(_newTI);
				endif;
				
				// TFS 8275 TAX PAYMENT
				taxpayment := payment.myCashPaymentForTax;
				if taxpayment &lt;&gt; null then
					value    := taxvalue;						 // taxvalue = the tax value before it was changed above.
					newValue := (value * factor).roundedTo(6);
					value    := value - newValue;
					taxpayment.setCashValue(value);
					
					
					//	TFS 36429 newTaxPayment := receipt.createCashPayment(newValue,0, false, receipt.myDebtorTerminal, _newTI, null, null, null);
					
					// TFS 36429 do not create the tax via the receipt, tax payments are not attached to the receipt.
					create newTaxPayment persistent;
					newTaxPayment.setProxy(newValue,				    //_cashValue : Decimal;
											0,							//_taxAmount : Decimal;
											now,						//_dateTime : TimeStamp;
											null,						//_proformaDesc : String;
											false,						//_manual : Boolean;
											0,							//_status : Integer;
											false,						//_voided : Boolean;	
											receipt.myDebtorTerminal,	//_myDebtorTerminal : CM_DebtorTerminal;
											_newTI,						//_myTrackedItem : CM_TrackedItem;
											null,						//_myInvoice : CM_Invoice;	
											null,						//_vvr : CM_VehicleVisitRecord;
											payment.myUser				// _myUser : CM_User;
											);
					newPayment.setMyCashPaymentForTax(newTaxPayment);
					newPayment.setMyTerminal(); // TFS 36429
				
				endif;
			endif;
			
				
		endif;
	endforeach;
epilog
	delete oa;
	delete theController;

	// ### JIRA 34909 16MAY2025 NAVAB1
	app.myPassport.setContext(prevContext); 

end;</source>
        <Parameter name="_oldWeight" type="Decimal"/>
        <Parameter name="_oldVolume" type="Decimal"/>
        <Parameter name="_newWeight" type="Decimal"/>
        <Parameter name="_newVolume" type="Decimal"/>
        <Parameter name="_oldQty" type="Integer"/>
        <Parameter name="_newQty" type="Integer"/>
        <Parameter name="_newTI" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="updateEDIAttributesForMerge" id="4c9140f3-9bfe-4ee4-9963-49b25c9048b1">
        <updating/>
        <source>updateEDIAttributesForMerge(_ti: CM_Cargo; updateCtrl: CMIF_TIUpdateController io) updating;
//----------------------------------------------------------------
//	Created:	14 February 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin

	//set volume first - totals set in superclass method
	//self.volume := _ti.volume;
	inheritMethod(_ti, updateCtrl);

end;</source>
        <Parameter name="_ti" type="CM_Cargo"/>
        <Parameter name="updateCtrl" type="CMIF_TIUpdateController" usage="io"/>
    </JadeMethod>
    <JadeMethod name="validateForBayPlan1" id="c5159c48-f86f-4d0d-8e1d-f0bf149cc9c4">
        <updating/>
        <source>validateForBayPlan1(pControl: CMIF_TIUpdateController; _passport : CM_Passport input) updating, protected;
// ---------------------------------------------------------------------------
// Created:     02 October 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 14 Jul 2011	NDL		Par 27485 - Should be checking volume NOT totalVolume.
// ---------------------------------------------------------------------------
vars

begin
	inheritMethod(pControl, _passport);

	//self.validateCubicMetres(pControl, self.cubicMetres);

//	self.validateCubicMetres(pControl, self.volume);
	self.validateCubicMetres(pControl);	//14 Jul 2011	NDL	Par 27485

end;</source>
