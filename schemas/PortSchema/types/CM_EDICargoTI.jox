    <JadeMethod name="verifyTransportMode" id="b47be5ed-16ef-4e8b-8105-c7acacb32de6">
        <updating/>
        <source>verifyTransportMode() protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 October 2012	cnwndl1	Initial creation	Par 30645

*/

vars

	transportMode : Integer;

begin

	transportMode := self.receiptTransportMode;
	
	if transportMode = TI_TRANSMODE_NULL
	or transportMode = TI_TRANSMODE_ROAD
	or transportMode = TI_TRANSMODE_RAIL
	or transportMode = TI_TRANSMODE_SHIP
	or transportMode = TI_TRANSMODE_INTERNAL
	or transportMode = TI_TRANSMODE_PACKING
	then
		return;
	endif;
	
	app.raiseCMWarning2(InvalidAttrForTransportMode, self.receiptTransportMode.String, null, ETRow_TransportMode, self, self);

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
