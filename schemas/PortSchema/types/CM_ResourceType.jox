    <JadeMethod name="isGroupMandatory" id="f4de6c22-d044-4110-8368-0c1c06f0acf6">
        <source>isGroupMandatory(_toDoTaskDesc : CM_ToDoTaskDesc): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 August	2024	navcs2	Bug 64746: EUP | VAS - Without adding resources for the mandatory resource group, able to complete the job in Thin Client

*/

vars
	resourceGroup 		: CM_ResourceTypeGroup;
	taskCriteria		: CM_TaskCriteria;
	allResources		: CM_ObjectSetActual;
	resourceType 		: CM_Object;
	mandatoryGroupsArr	: ObjectArray;
begin
	taskCriteria := _toDoTaskDesc.allTaskCriteria.getAtKeyGeq(app.myPassport.myTerminal, _toDoTaskDesc.code);
	
	if taskCriteria = null then
		return false;
	endif;
	
	allResources := _toDoTaskDesc.allResourceTypes;
	
	create mandatoryGroupsArr transient;
	
	taskCriteria.allMandatoryResourceGroups.copy(mandatoryGroupsArr);
	
	if mandatoryGroupsArr.includes(self.myResourceTypeGroup) then
		return true;
	endif;
	
	return false;
epilog

end;</source>
        <Parameter name="_toDoTaskDesc" type="CM_ToDoTaskDesc"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isMapped" id="49605eca-97af-4512-b3ec-ccf4d409c83f">
        <source>isMapped( _transactionType : CM_TransactionType ):Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
11 January 2010	cnwndl1	Initial creation	CCMS MES 1006

*/

vars

	obj : CM_Object;
	
begin

	foreach obj in self.allUsageContexts do
		if obj.isKindOf(CM_TransResourceServiceBroker) then
			if _transactionType = null or _transactionType = obj.CM_TransResourceServiceBroker.getMyTransactionType then
				return true;
			endif;
		endif;
	endforeach;
	
	return false;

epilog

end;</source>
        <Parameter name="_transactionType" type="CM_TransactionType"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="a9b3559c-c3ac-41f8-a7d4-a530c33da85a">
        <source>pxyCreateUpdateProxy(): SelfType;

/*

Purpose:			

Parameters:			

Return Value:		


Date				Who		Reason
18 December 2009	cnwndl1	Initial creation
20/04/2011			cnwmh5	PAR #27401 - Add code to handle prossible exceptions occurring when
							trying to create the proxy
*/

vars

	toDoResourceType	: SelfType;
	completedOK		: Boolean;
	
begin
	toDoResourceType := inheritMethod();
	
	self.allUsageContexts.copy(toDoResourceType.allUsageContexts);
	
	//cnwmc5 - 23 Sep 2015 - PAR 36920
	if self.myHookCode &lt;&gt; null then
		toDoResourceType.myHookCode := self.myHookCode.pxyCreateUpdateProxyWithCode();
	endif;
	
	toDoResourceType.myResourceTypeGroup		:= self.myResourceTypeGroup;		// ### TFS 58761 (60739) 16Nov2023 NAVPW1
	toDoResourceType.myAutoApplyResourceType	:= self.myAutoApplyResourceType;	// ### TFS 58761 (60739) 16Nov2023 NAVPW1
	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return toDoResourceType;

epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete toDoResourceType;
	endif;

end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="b8dc99b2-37b1-4fee-a67b-c273af9027df">
        <updating/>
        <source>setForCreate( proxy : CM_ResourceType ) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 December 2009	cnwndl1	Initial creation	CCMS MES 1006

*/

vars

begin

	self.raiseExceptionIfTransient(method);
	
	self.setForUpdate(proxy);
	
	self.myRoot := app.myRoot;
	
epilog

end;</source>
        <Parameter name="proxy" type="CM_ResourceType"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="3e9ea746-f8ee-4256-a434-cad74784b245">
        <updating/>
        <source>setForUpdate( proxy : CM_ResourceType ) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 December 2009	cnwndl1	Initial creation	CCMS MES 1006
02 November	2022	navds20 ChangeRequest 56635:[54261] EUP - Todo Task Resources Maintenance
23 December 2022    navds21 ChangeRequest 54349[54262]: EUP - Enable Is Mandatory for ToDo Task Resources
*/

vars
	pxyHookLink	: CM_HookLink;			//cnwmc5 - 23 Sep 2015 - PAR 36920
begin

	self.code := proxy.code;
	self.description				:= proxy.description;
	self.decimalPlaces				:= proxy.decimalPlaces;
	self.unitDescription			:= proxy.unitDescription;
	self.hasBeenUsed				:= proxy.hasBeenUsed;
	self.isAvailable				:= proxy.isAvailable;
	self.isFromToDateTimeRequired	:= proxy.isFromToDateTimeRequired;			//cnwmc5 - 22 Sep 2015 - PAR 36920
	self.additionalInfo				:= proxy.additionalInfo;					//13 Apr 2017	NDL	TFS 3414
	self.type						:= proxy.type;								//02/11/2022 navds20 TFS #56635[54261]
	self.mandatory					:= proxy.mandatory;   						//23/12/2022 navds21 TFS #54349[54262]
	self.myResourceTypeGroup		:= proxy.myResourceTypeGroup;				// ### TFS 58761 (60739) 16Nov2023 NAVPW1
	self.myAutoApplyResourceType	:= proxy.myAutoApplyResourceType;			// ### TFS 58761 (60739) 16Nov2023 NAVPW1
	self.allUsageContexts.clear();
	proxy.allUsageContexts.copy(self.allUsageContexts);
	
	//cnwmc5 - 23 Sep 2015 - PAR 36920
	if proxy.myHookCode &lt;&gt; null then
		pxyHookLink := proxy.myHookLink;
		if pxyHookLink &lt;&gt; null then
			// need to set to the new persistent object
			pxyHookLink.setLinkObject(self);
		endif;
		if self.myHookCode = null then
			create self.myHookCode persistent;
			self.myHookCode.setForCreate(proxy.myHookCode);
		else
			self.myHookCode.setForUpdate(proxy.myHookCode);
		endif;
	else
		delete self.myHookCode;
	endif;
	
epilog

end;</source>
        <Parameter name="proxy" type="CM_ResourceType"/>
    </JadeMethod>
    <JadeMethod name="setHasBeenUsed" id="cbd39e6d-4579-48c3-8ca2-46dcaa6c6f16">
        <updating/>
        <source>setHasBeenUsed( _value : Boolean ) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
