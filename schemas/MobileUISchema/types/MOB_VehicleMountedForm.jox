    <JadeMethod name="setupDrawingController" id="2d22ddf5-60f1-4c37-8b98-eec7604f6efb">
        <updating/>
        <source>setupDrawingController() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
05 May 2010	cnwjk3	Initial creation
20 Sep 2010 cnwjo3	par 25640.  Int to Real
*/

vars
	tmpUserWindow	: CM_UserWindow;
	tmpZoomFactor	: Real;
	highlightHeight : Integer;
begin

	//PAR 24899 - Implement saved window settings for Mobile Devices (CNWRS2 24 Aug 2010)
	tmpUserWindow := app.getUserWindow(self.name, true);
	tmpZoomFactor := tmpUserWindow.xmlInfo.cnEcGetTagValueOfName(XMLTag_ZoomFactor).Real;
	if tmpZoomFactor &gt; 0 then
		// this prevents system auto setting zoom level
		self.isZoomChanged := true;
	endif;

	self.setupControlFromParent(self.frmViewport,self.frmGraphic,0,0);
	self.setupControlFromParent(self.frmDrawing,self.frmViewport,0,0);
	self.setupControlFromParent(self.frmTI,self.frmViewport,0,0);	
	self.setupLabelFrames();
	
	self.frmGraphic.autoRedraw:=true;
	self.frmGraphic.drawPictureIn(self.picGrayV.picture,0,0,self.frmGraphic.clientWidth,self.frmGraphic.clientHeight);
	self.frmDrawing.visible := false;
	self.frmTI.visible := false;


	self.frmDrawing.zOrder(0);
	self.frmTI.zOrder(1);
	//24/09/2010 cnwdz2 25642
	if  self.frmTopHLabels &lt;&gt; null then
		self.frmTopHLabels.zOrder(2);
	endif;
	
	if  self.frmBottomHLabels &lt;&gt; null then
		self.frmBottomHLabels.zOrder(2);
	endif;
	
	if  self.frmLeftVLabels &lt;&gt; null then
		self.frmLeftVLabels.zOrder(2);
	endif;
	
	if  self.frmRightVLabels &lt;&gt; null then
		self.frmRightVLabels.zOrder(2);
	endif;
	
	if  self.frmTopLeftLabel &lt;&gt; null then
		self.frmTopLeftLabel.zOrder(3);
	endif;
	
	if  self.frmTopRightLabel &lt;&gt; null then
		self.frmTopRightLabel.zOrder(3);
	endif;
	
	if  self.frmBotmLeftLabel &lt;&gt; null then
		self.frmBotmLeftLabel.zOrder(3);
	endif;
	
	if  self.frmBotmRightLabl &lt;&gt; null then
		self.frmBotmRightLabl.zOrder(3);
	endif;
	
	self.frmMoveTbl.zOrder(0);
	self.frmDirector.zOrder(1);
	self.frmViewport.zOrder(4);
	
	create self.myDrawingController transient;
	self.myDrawingController.setTerminal(app.myVMAgent.myTerminal);
	
	self.myDrawingController.myRTVehicleConfig := app.myVMAgent.getMyRTVehicleConfig; //10 Feb 2012	NDL	Par 29108
	//20/04/2011 cnwdz2 par27313
	self.myDrawingController.setDrawAreaForForkLift(self.myMachine.machineType = MACHINETYPE_FORK_LIFT);
	
	//07/03/2011 cnwdz2 25644 start
	highlightHeight := app.myVMAgent.getMyRTVehicleConfig.highlightHight;
	self.myDrawingController.setHighlighHeight(highlightHeight);
	////07/03/2011 cnwdz2 25644 end
	
	// PAR 25509 - pass saved zoom factor to init method (CNWRS2 24 Aug 2010)
	//21/06/2011 cnwdz2 27732
	self.myDrawingController.setLabelsFrames(self.frmTopHLabels, self.frmBottomHLabels, self.frmLeftVLabels, self.frmRightVLabels, self.frmTopLeftLabel, self.frmTopRightLabel, self.frmBotmLeftLabel, self.frmBotmRightLabl);
	self.myDrawingController.init(1, self.frmDrawing, self.frmTI, self.frmViewport, tmpZoomFactor);
	self.myDrawingController.setHScrollFactor(GFX_HSCROLL_FACTOR);
	self.myDrawingController.setVScrollFactor(GFX_VSCROLL_FACTOR);
	self.myDrawingController.setIsFancyGFX(true);
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupForm" id="07bcef2b-b078-4661-a2ea-2efcd6ff50be">
        <updating/>
        <source>setupForm() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
13 April 2010	cnwer1	Initial creation
 17/08/2016 		cnwrh7	TFS	2501
*/

vars
	jadeCell : JadeTableCell;
begin
	self.isOnNarrowScreen := self.clientWidth &lt;= 320;
	//self.isOnNarrowScreen:= global.cnwer1 and  app.myVMAgent.getMyRTVehicleConfig.allAvailableGraphicViews.isEmpty ;
	self.frmBody.alignContainer:=Frame.AlignContainer_None;
	self.frmBody.parentAspect:=Frame.ParentAspect_StretchBoth;
	//epr TFS 1757 QNS want to tab to menu
	//self.btnMenu.tabStop:=false; //epr par 36977 18/11/15
	self.btnTaskMode.visible:=app.myVMAgent.allowChangeGetTaskMode;
	self.btnGraphic.visible:=not app.myVMAgent.getMyRTVehicleConfig.allAvailableGraphicViews.isEmpty;
	self.btnGraphicView.visible := false; //called here because resize controls is called from the inheritmethod 
	inheritMethod();
	if app.isOnDevice() then
		self.windowState := self.WindowState_Maximized;		
	endif;
	self.setVehicleMountedScreenSize();
	
	self.frmTaskTable.visible:=false;
	self.frmMove.visible:=false;
	self.frmGetTask.visible:=false;
	self.frmDirector.visible:=false;
	self.frmMoveTbl.left:=0;
	self.frmMoveEntry.top:=0;
	self.frmMoveEntry.left:=0;
	self.lblInfo.alignment:=Label.Alignment_Left_Top;
	//epr par 25955 7/10/10 
	self.lblCaption.fontSize:=10;
	self.lblCaption.fontBold:=true;
	if not app.isOnDevice then
		self.lblCaption.visible:=false;
		self.frmTop.height:=self.frmTop.clientHeight - self.lblCaption.clientHeight;
	endif;
	//app.myVMAgent.isWarehouseVMT:=false;
	//epr par 33495 13/2/14
	if not app.myVMAgent.allowChangeGetTaskMode then
		app.myVMAgent.setShowingTaskList(app.myVMAgent.getMyRTVehicleConfig.taskViewMode = CM_RTVehicleConfig.TASKVIEW_LIST);
	endif;
	
	self.setupControlFromParent(self.frmTaskTable,self.frmBody,0,0);
	self.setupControlFromParent(self.frmMove,self.frmBody,0,0);
	self.setupControlFromParent(self.frmGetTask,self.frmBody,0,0);
	self.setupControlFromParent(self.frmMoveTbl,self.frmGraphic,0,0);
	self.setupControlFromParent(self.frmDirector,self.frmGraphic,0,0);
	self.setupControlFromParent(self.tblMoveInfo,self.frmMoveTbl,0,0);
	//self.setupControlFromParent(self.tblMoveEntry,self.frmMoveEntry,(self.lblMode.top + self.lblMode.clientHeight).Integer,0);
	
	self.setTableMargins(self.tblMoveInfo);
	self.setupTasksTable();
	self.setupDirectorTable();
	self.setupWeightInterface(); 
	
	self.setupTCPWeightInterface();			//+TFS2207	for Iscale
	
	self.setupTableMoveEntry();
	self.setupGetTasks();
	self.setupTableMoveInfo();
	
	self.setupDrawingController();
	self.frmButtons.autoRedraw := true;
	self.picSpacerH.visible := false;
	self.picSpacerV.visible := false;
	
	self.txtSearch.text:=null;
	self.txtSearch.lostFocus(self.txtSearch);
	self.updateCaption();

	self.btnReject.enabled:=true;
	
	self.setFramesVisible();
	if app.myVMAgent.showingTaskList then
		self.clearTableData(self.tblTasks);
		app.myVMAgent.myMachQEntryTableSynchAgent.purgeEntries;
		app.myVMAgent.initTable(self.tblTasks);
		self.btnTaskMode.caption:=app.getErrorString(Get_mode);
		if self.myMachine.isTandemLift then
			self.btnTandem.visible := true;
			self.btnTandem.caption := app.getErrorString(Tandem);
		endif;
        // CCMS SFW 1210
		if self.myMachine.isTwinLift then
			self.btnTandem.visible := true;
			self.btnTandem.caption := app.getErrorString(CM_Twin);
			self.btnTandem.value := self.getSessionAgent.isTandem;		// 29/05/2012 cnwar2 #28219
		endif;
	else
		self.btnTaskMode.caption:=app.getErrorString(List_mode);
		self.loadTable(self.tblGetNext);
	endif;
		
	if not app.isOnDevice then
		self.resize;
	endif;
	
	self.setupFrmMove();
	
	self.showVoyageDischargeButton();
	
	self.btnMenu.caption:=app.getErrorString(Menu);
	self.btnGraphicView.caption := app.getErrorString(SwitchView);
	self.btnVoyDischarge.caption:= app.getErrorString(Discharge);
	self.btnSearchTwin.caption:=app.getErrorString(CM_Twin);
	//epr par 26511 7/12/10
	if  not self.isShowOverstowCargo and not self.isEnquiryMode then
		self.btnAccept.caption:=app.myVMAgent.getMoveTaskStr;
	endif;
	
	self.btnAccept.visible:=true;
	self.btnReject.visible:=true;
	self.setupF1Help(30);
	
	//20 Jan 2016	NDL	Par 37002
	if app.isOnDevice then
		self.tblTasks.refresh;
	endif;
	
epilog
	app.myVMAgent.startNotes();	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupFrmDirector" id="8a16c590-1b39-475f-9108-ecfe341d6c02">
        <source>setupFrmDirector(	_rtEntry: DTO_RTQueueEntry input; _twinEntry: DTO_RTQueueEntry input; _forceAuto : Boolean ) protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
26 April 2010	cnwer1	Initial creation
10 Nov   2014   cnwma1  1090 in MOB_VehicleMountedForm::setupFrmDirector
12 July  2018	jlgmd1	TFS #39292 - POL - Discharge job leaving details on Screen
*/

vars
	request: CM_Request;
	rtQTask: CM_RTQueueTask;
	sourceTA : CM_TerminalArea;
	ti 	: CM_TrackedItem;
	totalTODO	: Integer;
	allDirectorCargo	: CM_TIArray;
	searchString : String;
begin
	
	self.setupFrmTop(true);
	
	self.tblDirector.rows:=1;
	self.tblDirector.tag:=null; //epr 11/7/11 par 25048
	
	//epr TFS 995 24/5/17 refactored for generic vmt
	create allDirectorCargo transient;
	if not self.autoSearchDirector then	//13 Nov 2017	NDL	TFS 7427
		searchString := self.txtSearch.text.toUpper.trimBlanks;
		//if searchString = null and not _forceAuto then
		if (searchString = null or searchString = app.getErrorString(Search).toUpper) and not _forceAuto then	// TFS 39292
			return;
		endif;
		rtQTask :=self.myMachine.getDirectorTaskCargo( searchString, null, allDirectorCargo );
		//self.txtSearch.text := null;
		self.txtSearch.text := app.getErrorString(Search);	// TFS 39292
	else
		rtQTask :=self.myMachine.getDirectorTaskCargo(null,null,allDirectorCargo); //epr TFS 6863 14/9/17 so breakbulk works correctly
	endif;
	foreach ti in allDirectorCargo discreteLock do
		app.myVMAgent.loadRTTableFromDTORTEntry(self.tblDirector,ti);
	endforeach;
	
	if rtQTask &lt;&gt; null then
		sourceTA:=rtQTask.getDirectorTaskSourceTA();
		
		if sourceTA &lt;&gt; null then
			self.frmDirector.caption:=sourceTA.id;
		endif;
		request:=rtQTask.getTaskRequest ;
		if request  &lt;&gt; null then
			totalTODO:=request.myJob.getCountIncompleteWLE;
			self.frmDirector.caption:=self.frmDirector.caption &amp;  " -  " &amp; request.getId &amp; " - " &amp; totalTODO.asStringJMT &amp; " outstanding." ;
		endif;
	endif;

epilog

	delete allDirectorCargo;
end;</source>
        <access>protected</access>
        <Parameter name="_rtEntry" type="DTO_RTQueueEntry" usage="input"/>
        <Parameter name="_twinEntry" type="DTO_RTQueueEntry" usage="input"/>
        <Parameter name="_forceAuto" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setupFrmMove" id="a447d5d1-a45d-43b9-807e-74c327d6c15a">
        <updating/>
        <source>setupFrmMove() protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14 Apr 2010	cnwer1	Initial creation
07 Dec 2010 cnwer1 	par 25611
*/

vars
	dtoEntryArray 	: DTO_RTQueueEntryArray;
	firstEntry,
	twinEntry 		: Object;
	table			: Table;
	lc				: CM_LocationsController;
	strLocation		: String;
	ti 				: CM_TrackedItem;
	moveState		: Integer;
	useDetailsView	: Boolean;
begin
	
	if app.myVMAgent.isIMV then
		return;
	endif;
	create dtoEntryArray transient;
	
	if app.myVMAgent.showingTaskList then
		table :=self.tblTasks;
	endif;
	moveState := app.myVMAgent.getNextMoveState();
	app.myVMAgent.findWorkingDTORTEntries(dtoEntryArray,table);

	if dtoEntryArray.isEmpty then
		
		//check cargo on machine i.e. instant move stuff and manual overstow containers
		firstEntry:=self.myMachine.myMachineController.allTrackedItems.first;
		if firstEntry &lt;&gt; null then			
			if app.myVMAgent.getMyRTVehicleConfig.overstowMoveMode = CM_RTVehicleConfig.OSTOW_MANUAL then
				self.isShowOverstowCargo:=true;			
			else
				self.setIsEnquiryMode(true);
			endif;
			
			self.setupFrmMoveForTI(firstEntry.CM_TrackedItem);					
		endif;
		return;

	else	
		if dtoEntryArray.size &gt; 0 then
			firstEntry:=dtoEntryArray[1];
		endif;
		if dtoEntryArray.size &gt; 1 then
			twinEntry:=dtoEntryArray[2];
		endif;
	endif;
	
	//epr par 34682 5/8/14
	if app.myVMAgent.getMyRTVehicleConfig.canRemoveTargetSource then
		self.setupFrmMoveNoSplitTarget(firstEntry.DTO_RTQueueEntry,twinEntry.DTO_RTQueueEntry);	
		return;
	endif;
	
	self.setupFrmMoveFields(firstEntry,twinEntry);
	
	
	if self.isOnNarrowScreen or  (app.myVMAgent.getMyRTVehicleConfig.canRemoveSplitScreen) then
		self.setupFrmMoveNarrow(firstEntry.DTO_RTQueueEntry,twinEntry.DTO_RTQueueEntry);
			//epr par 34591 21/7/14
		self.doTableHighlightTarget(self.tblMoveEntry);
	else
	
		self.tblMoveInfo.clear;
		app.myVMAgent.setupTableHeadings(self.tblMoveInfo);
		app.myVMAgent.loadRTTaskTable(self.tblMoveInfo,null);
		self.doTableHighlightTarget(self.tblMoveInfo); //epr par 33401 18/2/14
		if self.tblMoveInfo.columns &gt; 1 then
			self.tblMoveInfo.accessColumn(2).fontBold:=true;
		endif;
		if twinEntry &lt;&gt; null then
			self.tblMoveInfo.accessColumn(3).fontBold:=true;
		endif;
		
		//+ cnwmd1 Par 25509
		
			if moveState = VehicleMountedGenericAgent.PICKUP_TASK then
				useDetailsView := app.myVMAgent.useDetailsViewForPickup;
			elseif moveState = VehicleMountedGenericAgent.SETDOWN_TASK then
				useDetailsView := app.myVMAgent.useDetailsViewForSetdown;
			else
				useDetailsView := true; //default
			endif;
		
			if (not useDetailsView) and self.canGFXDisplay(lc, strLocation, ti, false) then
				self.doShowGFX(lc, ti, strLocation);
			else
				self.hideGFXFrames();
				self.resizeForNoGraphics();
				
				if moveState = VehicleMountedGenericAgent.ACCEPT_TASK then
					if app.myVMAgent.showingTaskList then
						self.frmTaskTable.visible:=true;
					else
						self.frmGetTask.visible:=true;
					endif;
				else
					//epr 25/6/10 par 24560
					self.frmMoveTbl.visible:=true;				
				endif;
			endif;
	endif;

	self.setFrmMoveEntryScollRange();
	
	
epilog
	
	delete dtoEntryArray;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupFrmMoveFields" id="35329124-9e28-44c8-8fc4-93c77cca2498">
        <updating/>
        <source>setupFrmMoveFields(_firstEntry,_twinEntry : Object input) protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 April 2010	cnwer1	Initial creation
06 Nov 2012 	cnwer1	CCMS HAT 2200 PAR 30678 - narrow screen stuff
18 Nov2016 	cnwrh7	TFS	2501
*/

vars
	firstDTOEntry,
	twinDTOEntry	: DTO_RTQueueEntry;
	firstTI,
	twinTI			: CM_TrackedItem;
	showSetdown : Boolean;
	moveState 	: Integer;
begin
	
	self.setAutoSearchDirector();	//13 Nov 2017	NDL	TFS 7427
	
	//self.myMoveTableDetails.clearData(3);
	moveState:=app.myVMAgent.getNextMoveState;
	
	
	showSetdown:= moveState = VehicleMountedGenericAgent.SETDOWN_TASK or 
					moveState = VehicleMountedGenericAgent.COMPLETE_TASK;
					
	self.btnTandem.visible:=false;
	
	self.frmGraphic.visible:=not (self.isOnNarrowScreen or app.myVMAgent.getMyRTVehicleConfig.canRemoveSplitScreen);
	self.frmDirector.visible:=false;
	self.frmMoveTbl.visible:=not ( self.isGFXViewVisible or (self.isOnNarrowScreen or app.myVMAgent.getMyRTVehicleConfig.canRemoveSplitScreen) );

	self.btnTargetSearch.visible:=false;
	self.btnRejectTask.visible:=false;
	self.btnRejectTwin.visible:=false;
	self.btnSwap.visible:=false;
	self.btnIC.visible:=false;
	self.grpAccessDir.visible:=false;
	self.grpICFrom.visible:=false;
	self.grpNextPrev.visible:=false;
	self.lblMode.visible:=false;
	if _firstEntry = null  then
		self.tblMoveEntry.visible:=false;
	else
		self.tblMoveEntry.visible:=true;
	endif;
	
	if self.myTCPWeightInterfaceController &lt;&gt; null and  app.myVMAgent.getNextMoveState = VehicleMountedGenericAgent.SETDOWN_TASK then			//+TFS2207 
		self.btnGetWeight.visible := true;
		self.btnSaveWeight.visible := true;
	else
		self.btnGetWeight.visible := false;
		self.btnSaveWeight.visible := false;
	endif;
	
	self.myMoveTableDetails.setEntRowVisible(ETRow_IcAreaType,false);
	self.myMoveTableDetails.setEntRowVisible(ETRow_IcArea,false);
	self.myMoveTableDetails.setRowVisibleAfterEntRow(ETRow_IcArea, showSetdown and  (self.myVMAgent.getMyRTVehicleConfig.allowChangeSetdown or _twinEntry &lt;&gt; null));

	if _firstEntry.isKindOf(DTO_RTQueueEntry) then
		firstDTOEntry:=_firstEntry.DTO_RTQueueEntry;
		twinDTOEntry:=_twinEntry.DTO_RTQueueEntry;
		self.setupFrmMoveFieldsForDTOs(firstDTOEntry,twinDTOEntry);
		
		if twinDTOEntry = null and self.myVMAgent.getMyRTVehicleConfig.canRemoveSplitScreen then
			self.myMoveTableDetails.clearData(5);
		endif;
		
	elseif _firstEntry.isKindOf(CM_TrackedItem) then
		firstTI:=_firstEntry.CM_TrackedItem;
		twinTI:=_twinEntry.CM_TrackedItem;
		self.setupFrmMoveFieldsForTIs(firstTI,twinTI);
	endif;

	self.lastMoveState:=moveState;
epilog
	
end;</source>
        <access>protected</access>
        <Parameter name="_firstEntry" type="Object" usage="input"/>
        <Parameter name="_twinEntry" type="Object" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setupFrmMoveFieldsForDTOs" id="8559df9b-1a90-431b-9f6b-9f5b6d4cc2c4">
        <source>setupFrmMoveFieldsForDTOs(_firstEntry, twinEntry : DTO_RTQueueEntry input) protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28 April 2010	cnwer1	Initial creation
17/08/2016 		cnwrh7	TFS	2501


*/

vars
	showQuantity,
	showTarget,
	showSource,
	showAccess,
	showTandem,
	showTwin	: Boolean;
	moveState,
 	rejectRow,
	quantityRow : Integer;
	rejectCell			: JadeTableCell; 
	modeDisplay,
	rejectEntRow		: String;
	firstCargoId,
	secondCargoId,
	amountLeftToMove: String;
	ti : CM_TrackedItem;
	ct : CM_CargoType;
begin

	moveState:=app.myVMAgent.getNextMoveState;
	showTarget:= moveState = VehicleMountedGenericAgent.SETDOWN_TASK or 
					//moveState = VehicleMountedGenericAgent.COMPLETE_TASK or
					( moveState = VehicleMountedGenericAgent.COMPLETE_TASK and _firstEntry.getTI &lt;&gt; null ) or	// 21 Jan 2011	NDL	Par 26568
					moveState = VehicleMountedGenericAgent.ACCEPT_TASK;
					
	showSource:= moveState =  VehicleMountedGenericAgent.PICKUP_TASK or 
					moveState = VehicleMountedGenericAgent.COMPLETE_TASK or					
					moveState = VehicleMountedGenericAgent.ACCEPT_TASK;
					
	//22/06/2011 cnwdz2 27732				
	showAccess := moveState =  VehicleMountedGenericAgent.PICKUP_TASK or 
					moveState = VehicleMountedGenericAgent.SETDOWN_TASK or					
					moveState = VehicleMountedGenericAgent.ACCEPT_TASK;

	showTwin:=	self.myMachine.isTwinLift 	and twinEntry &lt;&gt;  null;		
	showTandem:=self.myMachine.isTandemLift and twinEntry &lt;&gt;  null;
	modeDisplay:=null;

	
	self.btnReject.enabled:=true;
	if moveState =  VehicleMountedGenericAgent.PICKUP_TASK  then
		modeDisplay:=app.getErrorString(Pickup_mode);
	elseif moveState = VehicleMountedGenericAgent.SETDOWN_TASK  then
		modeDisplay:=app.getErrorString(Setdown_mode); 
		self.btnReject.enabled:=false;
	endif;

	self.lblMode.visible:=true;
	self.lblMode.caption:=modeDisplay;
	
	if _firstEntry.isForDirectorTask or (twinEntry &lt;&gt; null and twinEntry.isForDirectorTask) then
		self.frmDirector.visible:=true;
		if _firstEntry.isForDirectorTask then
			self.setupFrmDirector(_firstEntry, twinEntry, false);
		else
			self.setupFrmDirector(twinEntry, _firstEntry, false);
		endif;
	endif;
	
	//self.myMoveTableDetails.setEntRowVisible(ETRow_TotalWeight,self.myWeightInterfaceController &lt;&gt; null and showTarget );					//-TFS2501
	self.myMoveTableDetails.setEntRowVisible(ETRow_TotalWeight,(self.myWeightInterfaceController &lt;&gt; null or  self.myTCPWeightInterfaceController &lt;&gt; null) and showTarget );		//+TFS2501
	self.myMoveTableDetails.addDataForEntRowName(ETRow_TotalWeight,null); //epr 1/7/10 initialise the weight value to null
	
	// TFS 2357 only show the 'is certified' checkbox if the machine and both weigh and certify, AND is in setdown mode
	self.myMoveTableDetails.setEntRowVisible(ETRow_IsWeightCertified,false);
	if showTarget and
	   self.myMachine.canWeighCargo and
	   self.myMachine.canCertifyWeight then
		self.myMoveTableDetails.setEntRowVisible(ETRow_IsWeightCertified,true);
	endif;
	
	//22/06/2011 cnwdz2 27732
	firstCargoId  :=  _firstEntry.containerID; // cnwrd1 changed to get cargo ID of dto entry 32423
	self.loadFrmMoveFields(_firstEntry,ETRow_CargoID,ETRow_SourceID,ETRow_Access,ETRow_TargetID,showSource,showAccess,showTarget, self.DataColumn);		
	
	showQuantity:= moveState = VehicleMountedGenericAgent.PICKUP_TASK  and _firstEntry.myRealQueueEntry.CM_RTQueueEntry.myBreakBulkMaster &lt;&gt; null;
	self.myMoveTableDetails.setEntRowVisible(ETRow_TotalQuantity,showQuantity );
	if showQuantity then
		quantityRow:=self.myMoveTableDetails.findRowWithEntRowName(ETRow_TotalQuantity);
		self.myMoveTableDetails.myTable.accessCell(quantityRow,2).text:=app.getErrorString(CM_Quantity);
		if moveState =  VehicleMountedGenericAgent.PICKUP_TASK then
			self.myMoveTableDetails.changeEntRowColInputType(ETRow_TotalQuantity,DataColumn,Table.InputType_TextBox);
			amountLeftToMove:=_firstEntry.myRealQueueEntry.CM_RTQueueEntry.getAmountLeftToMoveDisplay;
			self.myMoveTableDetails.addDataForEntRowName(ETRow_TotalQuantity,amountLeftToMove);
			if _firstEntry.myRealQueueEntry.CM_RTQueueEntry.isBulkMove then
			
				self.myMoveTableDetails.myTable.accessCell(quantityRow,DataColumn).cellControl:=self.tblWeight;
				ti:= _firstEntry.getTI;
				ct:= _firstEntry.myRealQueueEntry.CM_RTQueueEntry.getCargoType;
				if ct &lt;&gt; null then
					if ct.isTrackByWeight then
						self.myMoveTableDetails.myTable.accessCell(quantityRow,2).text:=app.getErrorString(CM_Weight);
						self.tblWeight.setup(Type_Weight,self.myMoveTableDetails.myTable.accessCell(quantityRow,DataColumn).backColor);
					else
						self.myMoveTableDetails.myTable.accessCell(quantityRow,2).text:=app.getErrorString(CM_Volume);
						self.tblWeight.setup(Type_Volume,self.myMoveTableDetails.myTable.accessCell(quantityRow,DataColumn).backColor);
					endif;
					self.tblWeight.setValues(amountLeftToMove);
				endif;
			else
				self.myMoveTableDetails.myTable.accessCell(quantityRow,DataColumn).cellControl:=null;
			endif;
		else
			self.myMoveTableDetails.changeEntRowColInputType(ETRow_TotalQuantity,DataColumn,Table.InputType_None);
		endif;
	endif;
	
	self.myMoveTableDetails.setEntRowVisible(ETRow_TwinID,showTwin );
	self.myMoveTableDetails.setEntRowVisible(ETRow_TwinSourceID,showTwin and showSource );
	self.myMoveTableDetails.setEntRowVisible(ETRow_TwinTargetID,showTwin and showTarget );
	
	self.myMoveTableDetails.setEntRowVisible(ETRow_TandemID, showTandem);
	self.myMoveTableDetails.setEntRowVisible(ETRow_TandemSourceID,showTandem and showSource);
	self.myMoveTableDetails.setEntRowVisible(ETRow_TandemTargetID,showTandem and showTarget );

	rejectRow:=self.myMoveTableDetails.findRowWithEntRowName(ETRow_TargetID)+ 2;
	self.tblMoveEntry.accessRow(rejectRow).visible:=twinEntry &lt;&gt; null and showSource;
	
	//epr par 25923 6/10
	if not self.myVMAgent.getMyRTVehicleConfig.canRemoveSplitScreen then
		self.myMoveTableDetails.setRowVisibleAfterEntRow(ETRow_TwinTargetID, showTwin or showTandem);
	endif;
	if showTwin then
		
		secondCargoId := twinEntry.containerID;	// cnwrd1 changed to get cargo ID of dto entry 32423
		self.loadFrmMove2ndFields(twinEntry,ETRow_TwinID, ETRow_TwinSourceID, ETRow_Access, ETRow_TwinTargetID,showSource,showAccess, showTarget);
		if not _firstEntry.isForDirectorTask then	//epr par 34586 29/7/14	
			//27/06/2011 cnwdz2 27732 start
			if self.myMachine.machineType = MACHINETYPE_STRADDLE then
				if not secondCargoId.endsWith(" (" &amp; app.getErrorString(TwinLift_Front) &amp; ")") and 
				   not secondCargoId.endsWith(" (" &amp; app.getErrorString(TwinLift_Back) &amp; ")") then
					firstCargoId := null;
					secondCargoId := null;
				endif;
			elseif self.myMachine.machineType = MACHINETYPE_FORK_LIFT or 
				   self.myMachine.machineType = MACHINETYPE_SIDE_LOADER then	
				if not secondCargoId.endsWith(" (" &amp; app.getErrorString(TwinLift_Left) &amp; ")") and 
				   not secondCargoId.endsWith(" (" &amp; app.getErrorString(TwinLift_Right) &amp; ")") then
					firstCargoId := null;
					secondCargoId := null;
				endif;
			endif;
			
			self.setupTwinLiftLabels(_firstEntry, twinEntry, firstCargoId, secondCargoId);
		endif;
		//27/06/2011 cnwdz2 27732 end
	elseif showTandem then
		self.loadFrmMove2ndFields(twinEntry,ETRow_TandemID,ETRow_TandemSourceID,ETRow_Access,ETRow_TandemTargetID,showSource,showAccess,showTarget);		
		
		if not _firstEntry.isForDirectorTask then //epr par 34586 29/7/14	
			secondCargoId := twinEntry.containerID; // cnwrd1 changed to get cargo ID of dto entry 32423
			//27/06/2011 cnwdz2 27732 start	
			if not secondCargoId.endsWith(" (" &amp; app.getErrorString(TandemLift_Top) &amp; ")") and 
			   not secondCargoId.endsWith(" (" &amp; app.getErrorString(TandemLift_Bottom) &amp; ")") then
			   firstCargoId := null;
			   secondCargoId := null;
			endif;
			self.setupTandemLiftLabels(_firstEntry, twinEntry, firstCargoId, secondCargoId);
		endif;
		//27/06/2011 cnwdz2 27732 end	
	endif;
	
	if showTarget and self.myVMAgent.getMyRTVehicleConfig.allowChangeSetdown then
		
		if showTwin then
			rejectEntRow:=ETRow_TwinTargetID;
		elseif showTandem then
			rejectEntRow:=ETRow_TandemTargetID;
		else
			rejectEntRow:=ETRow_TargetID;
		endif;
		if  app.myVMAgent.getMyRTVehicleConfig.canRemoveSplitScreen then
			rejectCell:=self.tblMoveEntry.accessCell(self.myMoveTableDetails.findRowWithEntRowName(ETRow_TargetID),DataColumn);
		else
			rejectCell:=self.tblMoveEntry.accessCell(self.myMoveTableDetails.findRowWithEntRowName(rejectEntRow),DataColumn);
		endif;
		
		if  moveState = VehicleMountedGenericAgent.ACCEPT_TASK then
			//self.grpNextPrev.visible:=true;
		else
			if self.btnSwap.visible then
				self.btnIC.top:=self.btnSwap.top + self.btnSwap.clientHeight  + 5;
			else
				self.btnIC.top:=self.tblMoveEntry.top + rejectCell.positionTop + self.tblMoveEntry.accessRow(rejectCell.row).height ;
			endif;
			self.btnIC.left:=rejectCell.positionLeft;
			self.btnIC.caption:=app.getErrorString(Pick_interchange);
			self.btnIC.visible:=true;
		endif;
		
	endif;
	

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_firstEntry" type="DTO_RTQueueEntry" usage="input"/>
        <Parameter name="twinEntry" type="DTO_RTQueueEntry" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setupFrmMoveFieldsForTIs" id="039e2934-9563-44c1-8575-6bf0ae2da007">
        <source>setupFrmMoveFieldsForTIs(_firstTI, twinTI : CM_TrackedItem input) protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28 April 2010	cnwer1	Initial creation
31 Oct	 2016   cnwma1	TFS #2832:PAR38310 STWR - Extra unexpected weight fields in VMT app
// 16 Aug 2016 cnwrh7            TFS2501

*/

vars

begin
	
	self.frmMoveTbl.visible:=true;
	
	// cargo id 
	self.myMoveTableDetails.setEntRowVisible(ETRow_CargoID,true);
	self.myMoveTableDetails.changeEntRowColInputType(ETRow_CargoID,3,Table.InputType_None);
	self.myMoveTableDetails.addDataForEntRowName(ETRow_CargoID,_firstTI.id);
	
	//source id 
	self.myMoveTableDetails.setEntRowVisible(ETRow_SourceID,true);
	self.myMoveTableDetails.changeEntRowColInputType(ETRow_SourceID,3,Table.InputType_None);
	self.myMoveTableDetails.addDataForEntRowName(ETRow_SourceID,_firstTI.getPrimaryLocationId(REAL_MODE));
	
	// target id
	self.myMoveTableDetails.setEntRowVisible(ETRow_TargetID,true);
	self.myMoveTableDetails.changeEntRowColInputType(ETRow_TargetID,3,Table.InputType_TextBox);
	self.myMoveTableDetails.addDataForEntRowName(ETRow_TargetID,null);
	
	//set twin fields visibility
	self.myMoveTableDetails.setEntRowVisible(ETRow_TwinID,twinTI &lt;&gt; null);
	self.myMoveTableDetails.setEntRowVisible(ETRow_TwinSourceID,twinTI &lt;&gt; null);
	self.myMoveTableDetails.setEntRowVisible(ETRow_TwinTargetID,twinTI &lt;&gt; null);
	
	self.myMoveTableDetails.setEntRowVisible(ETRow_TandemID, false);
	self.myMoveTableDetails.setEntRowVisible(ETRow_TandemSourceID,false);
	self.myMoveTableDetails.setEntRowVisible(ETRow_TandemTargetID,false);
	self.myMoveTableDetails.setEntRowVisible(ETRow_TotalQuantity,_firstTI.canSplitTotalQuantity ); //epr par 31774 27/6/13
	self.myMoveTableDetails.addDataForEntRowName(ETRow_TotalQuantity,null);
	
	//31/10/2016   cnwma1 TFS #2832
	self.myMoveTableDetails.setEntRowVisible(ETRow_TotalWeight,(self.myWeightInterfaceController &lt;&gt; null or  self.myTCPWeightInterfaceController &lt;&gt; null));		//+TFS2501
	self.myMoveTableDetails.addDataForEntRowName(ETRow_TotalWeight,null); 
	self.myMoveTableDetails.setEntRowVisible(ETRow_IsWeightCertified,false);
	if  self.myMachine.canWeighCargo and
		self.myMachine.canCertifyWeight then
		self.myMoveTableDetails.setEntRowVisible(ETRow_IsWeightCertified,true);
	endif;
	//31/10/2016   cnwma1 TFS #2832
	
	
	if twinTI &lt;&gt; null then
		self.myMoveTableDetails.changeEntRowColInputType(ETRow_TwinID,3,Table.InputType_None);
		self.myMoveTableDetails.addDataForEntRowName(ETRow_TwinID,twinTI.id);
		
		self.myMoveTableDetails.changeEntRowColInputType(ETRow_TwinSourceID,3,Table.InputType_None);
		self.myMoveTableDetails.addDataForEntRowName(ETRow_TwinSourceID,twinTI.getPrimaryLocationId(REAL_MODE));
		
		self.myMoveTableDetails.changeEntRowColInputType(ETRow_TwinTargetID,3,Table.InputType_TextBox);
		self.myMoveTableDetails.addDataForEntRowName(ETRow_TwinTargetID,null);
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_firstTI" type="CM_TrackedItem" usage="input"/>
        <Parameter name="twinTI" type="CM_TrackedItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setupFrmMoveForTI" id="fee2dbea-4d5c-4b45-a45d-f5ae5b676362">
        <updating/>
        <source>setupFrmMoveForTI(_ti : CM_TrackedItem input) protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 June 2010	cnwer1	Initial creation

*/

vars
	allTIs 			: CM_TIArray;
begin
	if _ti = null then
		return;
	endif;
	
	create allTIs transient;
	allTIs.add(_ti);
		
	self.loadEnquiryCargo(self.tblMoveInfo,allTIs);
	if app.myVMAgent.doesSeperatePickupSetdown then
		if _ti.myPrimaryActualLocation = self.myMachine.myMachineController then
			self.btnAccept.caption:=app.getErrorString(Setdown);
		else
			self.btnAccept.caption:=app.getErrorString(Pickup);
		endif;
	else
		self.btnAccept.caption:=app.getErrorString(Move);
	endif;
	self.setFramesVisible();
	self.setupFrmMoveFields(_ti,null);
epilog
	delete allTIs;
end;</source>
        <access>protected</access>
        <Parameter name="_ti" type="CM_TrackedItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setupFrmMoveNarrow" id="4d0491d7-ca79-420f-a0a0-85764e978967">
        <source>setupFrmMoveNarrow(firstEntry,twinEntry : DTO_RTQueueEntry) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 October 2012	cnwer1	Initial creation CCMS HAT 2200 30678

*/

vars
	entTableRow 	: EntTableRow;
	rowStr			: String;
	row	: Integer;
	colWidth : Real;
	
	theRow : JadeTableRow;
begin
	
	self.resizeForNoGraphics();
	self.frmMoveTbl.visible:=false;
	
	if  firstEntry.isForDirectorTask then
		self.frmGraphic.visible:=true;
		self.frmDirector.visible:=true;
		self.frmMoveEntry.visible:=false;
	
		self.frmGraphic.width:=self.frmMove.clientWidth;
		self.frmDirector.width:=self.frmMove.clientWidth;
		return; //epr par 34586 29/7/14
	else
		self.frmMoveEntry.width:=self.frmMove.clientWidth;
	endif;
	
	
	if self.myVMAgent.getMyRTVehicleConfig.canRemoveSplitScreen and not self.myVMAgent.getMyRTVehicleConfig.canRemoveTargetSource then
		foreach entTableRow in self.myMoveTableDetails.myEntTableDef.allEntTableRows do			
			if entTableRow.name[1:4] = "twin" then
				self.myMoveTableDetails.setEntRowVisible(entTableRow.name,false);
			endif;
		endforeach;
	endif;
		
	foreach entTableRow in app.myVMAgent.getMyRTVehicleConfig.myVisibleTaskFields.allEntTableRows do
		if not self.myVMAgent.getMyRTVehicleConfig.canRemoveTargetSource then
			if entTableRow.name = ETRow_ContainerID or
				entTableRow.name = ETRow_SourceLocation or
				entTableRow.name = ETRow_TargetLocation then
				continue;
			endif;
		endif;
		rowStr:=firstEntry.getDisplayStringForAttribute(entTableRow.name,false);
		self.myMoveTableDetails.setDataColumn(DataColumn);
		if not self.myMoveTableDetails.addDataForEntRow(entTableRow,rowStr) then		
			self.myMoveTableDetails.addNewEntRowWithData(entTableRow,rowStr);	
		endif;
		//epr par 34591 21/7/14
		self.tblMoveEntry.accessedCell.foreColor:=app.myVMAgent.getMyScreenMode.screenForeColour;
		if twinEntry &lt;&gt; null then
			rowStr:=twinEntry.getDisplayStringForAttribute(entTableRow.name,false);
			self.myMoveTableDetails.setDataColumn(DataColumn+2);
			self.myMoveTableDetails.addDataForEntRow(entTableRow,rowStr); 
				//epr par 34591 21/7/14
			self.tblMoveEntry.accessedCell.foreColor:=app.myVMAgent.getMyScreenMode.screenForeColour;
		endif;
	endforeach;
	self.myMoveTableDetails.setDataColumn(DataColumn);
	self.myMoveTableDetails.myTable.fitColumnWidth(2,0);
	
	
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="firstEntry" type="DTO_RTQueueEntry"/>
        <Parameter name="twinEntry" type="DTO_RTQueueEntry"/>
    </JadeMethod>
    <JadeMethod name="setupFrmMoveNoSplitTarget" id="f09919bb-1273-4087-a205-89213b48e609">
        <updating/>
        <source>setupFrmMoveNoSplitTarget(_firstEntry,_twinEntry : DTO_RTQueueEntry input) protected, updating;
/*

Date		Who		Reason
01 August 2014	cnwer1	Initial creation PAR 34682 CCMS 2404

*/

vars
	swapRow,
	targetRow,
	moveState 	: Integer;
	modeDisplay : String;
	entTableRow : EntTableRow;
begin
	if not app.myVMAgent.getMyRTVehicleConfig.canRemoveTargetSource then		
		return;
	endif;
	
	self.setAutoSearchDirector();	//13 Nov 2017	NDL	TFS 7427
	
	moveState:=app.myVMAgent.getNextMoveState;
	
	self.btnTandem.visible:=false;
	self.frmGraphic.visible:=false;
	self.btnRejectTask.visible:=false;
	self.btnRejectTwin.visible:=false;
	self.btnSwap.visible:=false;
	self.btnIC.visible:=false;
	self.grpAccessDir.visible:=false;
	self.grpICFrom.visible:=false;
	self.grpNextPrev.visible:=false;
	self.lblMode.visible:=false;
	if _firstEntry = null  then
		self.tblMoveEntry.visible:=false;
	else
		self.tblMoveEntry.visible:=true;
	endif;
	
	self.btnReject.enabled:=true;
	if moveState =  VehicleMountedGenericAgent.PICKUP_TASK  then
		modeDisplay:=app.getErrorString(Pickup_mode);
	elseif moveState = VehicleMountedGenericAgent.SETDOWN_TASK  then
		
		modeDisplay:=app.getErrorString(Setdown_mode); 
		self.btnReject.enabled:=false;
	endif;
	self.lblMode.visible:=true;
	self.lblMode.caption:=modeDisplay;
	
	if _firstEntry.isForDirectorTask or (_twinEntry &lt;&gt; null and _twinEntry.isForDirectorTask) then
		//clear cargo ids for directors
		self.myMoveTableDetails.setDataColumn(3);
		self.myMoveTableDetails.addDataForEntRowName(ETRow_CargoID,'');
		self.myMoveTableDetails.setDataColumn(5);
		self.myMoveTableDetails.addDataForEntRowName(ETRow_CargoID,'');
		self.myMoveTableDetails.setDataColumn(3);
		self.frmDirector.visible:=true;
		if _firstEntry.isForDirectorTask then
			self.setupFrmDirector(_firstEntry, _twinEntry, false);
		else
			self.setupFrmDirector(_twinEntry, _firstEntry, false);
		endif;
	endif;
	

	self.myMoveTableDetails.addDataForEntRowName(ETRow_TargetID,_firstEntry.getLocationTargetString());
	entTableRow:=app.myVMAgent.getMyRTVehicleConfig.myVisibleTaskFields.getEntTableRow(ETRow_ModifiedSource);
	if entTableRow &lt;&gt; null then
		targetRow:=self.myMoveTableDetails.findRowWithEntRow(entTableRow);
		if targetRow &gt; 0 then
			self.myMoveTableDetails.myTable.accessRow(targetRow).visible:=moveState   =  VehicleMountedGenericAgent.PICKUP_TASK ;
		endif;
	endif;
	
	if _twinEntry &lt;&gt; null then
		
		self.myMoveTableDetails.setDataColumn(5);
		self.myMoveTableDetails.addDataForEntRowName(ETRow_TargetID,_twinEntry.getLocationTargetString());
		self.myMoveTableDetails.setRowVisibleAfterEntRow(ETRow_TargetID, true);
		if moveState   =  VehicleMountedGenericAgent.PICKUP_TASK then
			self.btnRejectTask.visible:=true;
			self.btnRejectTwin.visible:=true;
			targetRow:=self.myMoveTableDetails.findRowWithEntRowName(ETRow_TargetID);
			self.btnRejectTask.top:=self.tblMoveEntry.top + self.tblMoveEntry.accessRow(3).height + 5;
			self.btnRejectTask.left:=self.tblMoveEntry.accessColumn(2).width;
			self.btnRejectTwin.top := self.btnRejectTask.top;
			self.btnRejectTwin.left:=self.btnRejectTask.left + self.tblMoveEntry.accessColumn(3).width;
		elseif moveState   =  VehicleMountedGenericAgent.SETDOWN_TASK then
			//epr par 34705 8/8/14
			self.btnSwap.visible:=true;
			swapRow:=3;		
			if  not self.tblMoveEntry.accessRow(swapRow).visible then
				swapRow:=2;
			endif;
			self.btnSwap.top:= self.tblMoveEntry.top + self.tblMoveEntry.accessRow(swapRow).height + 5;
			self.btnSwap.left:=self.tblMoveEntry.accessColumn(2).width;
		endif;
		
	else
		self.myMoveTableDetails.setRowVisibleAfterEntRow(ETRow_TargetID, false);
		self.myMoveTableDetails.clearData(5);
	endif;
	
	

	self.myMoveTableDetails.myTable.fitTableHeight();

	self.setupFrmMoveNarrow(_firstEntry,_twinEntry);
	self.doTableHighlightTarget(self.tblMoveEntry);
	self.lastMoveState:=moveState;
epilog
	self.myMoveTableDetails.setDataColumn(DataColumn);
end;</source>
        <access>protected</access>
        <Parameter name="_firstEntry" type="DTO_RTQueueEntry" usage="input"/>
        <Parameter name="_twinEntry" type="DTO_RTQueueEntry" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setupFrmTop" id="a8462c23-be45-465e-9b88-8d285efdb054">
        <source>setupFrmTop(_show : Boolean);
/*

Date		Who		Reason
17 February 2014	cnwer1	Initial creation PAR

*/

vars
	widthDiff	: Real;
begin
	

	if _show then
		if 	self.txtSearch.visible then
			return;
		endif;
		self.frmTop.height:= self.lblCaption.top + self.lblCaption.clientHeight + self.btnSearch.clientHeight + 10;
		if not app.isOnDevice then
			self.frmTop.height:=self.frmTop.clientHeight - self.lblCaption.clientHeight;
		endif;
		self.txtSearch.visible:=true;
	else
		if 	not self.txtSearch.visible then
			return;
		endif;
		self.frmTop.height:= self.btnSearch.top-2;
		self.txtSearch.visible:=false;
	endif;
	
	if self.width = self.scaleWidth then
		widthDiff :=8;
	endif;

	
	self.frmBody.move(0,self.frmTop.top + self.frmTop.clientHeight,  self.clientWidth - widthDiff, self.clientHeight - self.frmTop.clientHeight - self.frmBottom.clientHeight );
epilog

end;</source>
        <Parameter name="_show" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setupGetTasks" id="bf33e640-5abf-41a5-88f0-39e4c8e7e4d3">
        <source>setupGetTasks() protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 April 2010	cnwer1	Initial creation

*/

vars
	rtScreenMode	: CM_RTScreenConfig;
begin

	self.tblGetNext.fontSize:=app.myVMAgent.getMyRTVehicleConfig.tableFontSize;
	rtScreenMode:=app.myVMAgent.getMyScreenMode();
	self.tblGetNext.foreColor:=rtScreenMode.screenForeColour;
	self.tblGetNext.backColor:=rtScreenMode.screenBackColour;
	app.myVMAgent.setupTableHeadings(self.tblGetNext);
	

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupICFields" id="d4512003-17cf-4bef-ab45-d839ec7be39b">
        <source>setupICFields() protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 May 2010	cnwer1	Initial creation

*/

vars
	foundHeight : Integer;
	ti 	: CM_TrackedItem;
	dtoRTQueueEntry : DTO_RTQueueEntry;
	sourceLocID,
	targetLocID: String;
	sourceLocation,
	targetLocation,
	sourceICLoc,
	targetICLoc	: CM_LocationsController;
begin
	
	self.btnICSource.enabled:=true;
	self.btnICTarget.enabled:=true;
	dtoRTQueueEntry:=self.getWorkingDTOEntry;
	ti:=dtoRTQueueEntry.myRealQueueEntry.CM_RTQueueEntry.getTrackedItem;

	// container will be on the vehicle get the tis prior location
	sourceLocID:=ti.priorLocation;
	app.myVMAgent.myTerminal.findLocationFromString(sourceLocID,true,sourceLocation,foundHeight);	
	
	targetLocID:=dtoRTQueueEntry.queuedLocationID;
	app.myVMAgent.myTerminal.findLocationFromString(targetLocID,true,targetLocation,foundHeight);	
		
	if  sourceLocation &lt;&gt;  null then
		sourceICLoc:= sourceLocation.getDefaultInterchangeLocation;
	
		if sourceICLoc &lt;&gt; null then
			self.btnICSource.value:=true;
			self.btnICSource.click(self.btnICSource);
		endif;
		
	endif;
	
	self.btnICSource.enabled:=sourceICLoc &lt;&gt; null;
	if targetLocation &lt;&gt;  null then
		targetICLoc:= targetLocation.getDefaultInterchangeLocation;
	endif;
	
	if sourceICLoc = null then
		if targetICLoc &lt;&gt; null then
			self.btnICTarget.value:=true;
			self.btnICTarget.click(self.btnICTarget);
		endif;
	endif;
	
	self.btnICTarget.enabled:=targetICLoc &lt;&gt; null;

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupLabelFrames" id="19e9a8f0-db84-4317-af18-59b226435305">
        <updating/>
        <source>setupLabelFrames() protected, updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 September 2010	#cnwdz2	 25642

*/

vars

begin
	//09/11/2010 cnwdz2 26196
	self.configLabelFrames();
	
	//get config for frame visibility (view coloumn headers and/or row headers) and alignment i.e. align bottom  
	if  self.frmTopHLabels &lt;&gt; null then
		self.frmTopHLabels.left := 0; //topleft frame leftoffset + width
		self.frmTopHLabels.top := 0;
		self.frmTopHLabels.transparent := false;
		self.frmTopHLabels.width := self.frmViewport.clientWidth;
		self.frmTopHLabels.height := self.ColumeHeader_Height;
		self.frmTopHLabels.caption := null;
		self.frmTopHLabels.parentAspect:=Control.ParentAspect_StretchRight;
		self.frmTopHLabels.borderStyle:=Control.BorderStyle_None;
		self.frmTopHLabels.autoRedraw := true;	
	endif;
	
	if  self.frmBottomHLabels &lt;&gt; null then
		self.frmBottomHLabels.left := 0; //topleft frame leftoffset + width
		self.frmBottomHLabels.top := self.frmViewport.clientHeight() - self.ColumeHeader_Height;
		self.frmBottomHLabels.transparent := false;
		self.frmBottomHLabels.width := self.frmViewport.clientWidth;
		self.frmBottomHLabels.height := self.ColumeHeader_Height;
		self.frmBottomHLabels.caption := null;
		self.frmBottomHLabels.parentAspect:=Control.ParentAspect_StretchRight;
		self.frmBottomHLabels.borderStyle:=Control.BorderStyle_None;
		self.frmBottomHLabels.autoRedraw := true;
	endif;

	if  self.frmLeftVLabels &lt;&gt; null then  
		self.frmLeftVLabels.left := 0; //topleft frame leftoffset + width
		self.frmLeftVLabels.top := 0;//self.ColumeHeader_Height;
		self.frmLeftVLabels.transparent := false;
		self.frmLeftVLabels.width := self.RowHeader_Width;
		self.frmLeftVLabels.height := self.frmViewport.clientHeight;
		self.frmLeftVLabels.caption := null;
		self.frmLeftVLabels.parentAspect:=Control.ParentAspect_StretchBottom;
		self.frmLeftVLabels.borderStyle:=Control.BorderStyle_None;
		self.frmLeftVLabels.autoRedraw := true;
	endif;
	
	if  self.frmRightVLabels &lt;&gt; null then
		self.frmRightVLabels.left := self.frmViewport.clientWidth() - self.RowHeader_Width; //topleft frame leftoffset + width
		self.frmRightVLabels.top := 0;//self.ColumeHeader_Height;
		self.frmRightVLabels.transparent := false;
		self.frmRightVLabels.width := self.RowHeader_Width;
		self.frmRightVLabels.height := self.frmViewport.clientHeight;
		self.frmRightVLabels.caption := null;
		self.frmRightVLabels.parentAspect:=Control.ParentAspect_StretchBottom;
		self.frmRightVLabels.borderStyle:=Control.BorderStyle_None;
		self.frmRightVLabels.autoRedraw := true;
	endif;
	
	if  self.frmTopLeftLabel &lt;&gt; null then
		self.frmTopLeftLabel.left := 0; //topleft frame leftoffset + width
		self.frmTopLeftLabel.top := 0;
		self.frmTopLeftLabel.transparent := false;
		self.frmTopLeftLabel.width := self.RowHeader_Width;
		self.frmTopLeftLabel.height := self.ColumeHeader_Height;
		self.frmTopLeftLabel.caption := null;
		self.frmTopLeftLabel.borderStyle:=Control.BorderStyle_None;
		self.frmTopLeftLabel.autoRedraw := true;
	endif;
	
	if  self.frmTopRightLabel &lt;&gt; null then
		self.frmTopRightLabel.left := self.frmViewport.clientWidth() - self.RowHeader_Width;
		self.frmTopRightLabel.top := 0;
		self.frmTopRightLabel.transparent := false;
		self.frmTopRightLabel.width := self.RowHeader_Width;
		self.frmTopRightLabel.height := self.ColumeHeader_Height;
		self.frmTopRightLabel.caption := null;
		self.frmTopRightLabel.borderStyle:=Control.BorderStyle_None;
		self.frmTopRightLabel.autoRedraw := true;
	endif;
	
	if  self.frmBotmLeftLabel &lt;&gt; null then
		self.frmBotmLeftLabel.left := 0; //topleft frame leftoffset + width
		self.frmBotmLeftLabel.top := self.frmViewport.clientHeight() - self.ColumeHeader_Height;
		self.frmBotmLeftLabel.transparent := false;
		self.frmBotmLeftLabel.width := self.RowHeader_Width;
		self.frmBotmLeftLabel.height := self.ColumeHeader_Height;
		self.frmBotmLeftLabel.caption := null;
		self.frmBotmLeftLabel.borderStyle:=Control.BorderStyle_None;
		self.frmBotmLeftLabel.autoRedraw := true;
	endif;
	
	if  self.frmBotmRightLabl &lt;&gt; null then
		self.frmBotmRightLabl.left := self.frmViewport.clientWidth() - self.RowHeader_Width;
		self.frmBotmRightLabl.top := self.frmViewport.clientHeight() - self.ColumeHeader_Height;
		self.frmBotmRightLabl.transparent := false;
		self.frmBotmRightLabl.width := self.RowHeader_Width;
		self.frmBotmRightLabl.height := self.ColumeHeader_Height;
		self.frmBotmRightLabl.caption := null;
		self.frmBotmRightLabl.borderStyle:=Control.BorderStyle_None;
		self.frmBotmRightLabl.autoRedraw := true;
	endif;
epilog

end;</source>
