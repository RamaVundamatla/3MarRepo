<Class name="CMIF_LogController" id="1c34c883-64e6-4be3-8650-c26ead69865d">
    <superclass name="CMIF_Object"/>
    <transient/>
    <sharedTransientAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="containr"/>
    <JadeMethod name="doTransferLogs" id="3bb17d61-61e0-4f41-9e89-30b7c4c85950">
        <updating/>
        <source>doTransferLogs(_terminal : CM_Terminal input; _locationTo : CM_LogController input; _tisToProcess : CM_TISet input; _errSet : CM_TISet input) updating;
/*

Purpose:			Transfers a list of logs to a specified terminal area (Forces the move as it is usually called by web api's)

Parameters:			_terminal		CM_Terminal			The terminal we are going to use
					_locationTo		CM_LogController	The location we are sending the logs to
					_tisToProcess	CM_TISet			The Ti set of items we need to move
					_errSet			CM_TISet			The Ti set of items that cannot be moved

Return Value:		

Date		Who		Reason
13 January 2022	navpw1	Initial creation TFS: 52572

*/

vars
	moveController		: CMIF_MoveController;
	
begin
	create moveController transient;
	moveController.setMoveMode(REAL_MODE);
	moveController.isForcedMove := true;
	moveController.isLogMovement := true;
	moveController.isSystemMove := true;
	moveController.setMyToPrimaryLocation(_locationTo);
	moveController.setMyPassport(app.myPassport);
	
	if _tisToProcess.size &gt; 0 then
		app.myTrxUA.trxMoveTrackedItemsWithSplit(_tisToProcess, _errSet, moveController, app.myPassport);
	endif;
	
epilog
	endLoad;
	delete moveController;

end;</source>
        <Parameter name="_terminal" type="CM_Terminal" usage="input"/>
        <Parameter name="_locationTo" type="CM_LogController" usage="input"/>
        <Parameter name="_tisToProcess" type="CM_TISet" usage="input"/>
        <Parameter name="_errSet" type="CM_TISet" usage="input"/>
    </JadeMethod>
</Class>
