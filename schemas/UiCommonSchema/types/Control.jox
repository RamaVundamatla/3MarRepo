begin
	//if _locale = null then
	//	return;
	//endif;
	// An appropriate translation is provided or nothing happens
	// and the default bubbleHelp text from Painter is displayed.
	//translation	:= _locale.getTranslatedText(XLAT_FormCaptions, _id);
	translation := app.zGetTranslatedText(XLAT_FormCaptions, _id);
	if translation &lt;&gt; null then
		//self.caption := translation.text;
		self.setCaptionForTranslation(translation.text);
	endif;
epilog

end;</source>
        <Parameter name="_id" type="Integer"/>
        <Parameter name="_locale" type="CM_Locale"/>
    </JadeMethod>
