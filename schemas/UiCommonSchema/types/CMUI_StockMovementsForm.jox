    <JadeMethod name="btnValidate_click" id="20d95ac3-688f-4828-b4de-7d0b0c4b3423">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnValidate_click(btn: Button input) updating;
//--------------------------------------------------------------
//Created: 13 September 2002 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	if self.getOperatorAccessController &lt;&gt; null then
		app.msgBox("Validate Stock is not available as you have operator restrictions",
				   "Validate Stock Unavailable", MsgBox_OK_Only);
		return;
	endif;

	self.switchMode(Mode_ValidateStockTotals);
	if self.filtLocationType = LocationType_LC then
		self.validateByLocation(false, ValidType_Location);	
	elseif self.filtLocationType = LocationType_TA then
		self.validateByLocation(false, ValidType_TerminalArea);	
	elseif self.filtLocationType = LocationType_Terminal then
		self.validateByLocation(false, ValidType_Terminal);	
	elseif self.filtLocationType = LocationType_Voyage then
		self.validateByLocation(false, ValidType_Voyage);			
	else
		app.raiseUnexpectedProgramError(class.name, method.name, 'Unknown type (' &amp; self.filtLocationType &amp; ')');
	endif;

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
