    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="misc"/>
    <Constant name="Tag_GO" id="7b1c0efd-0592-43e5-9dfd-7cfb86103e30">
        <source>666</source>
        <type name="Integer"/>
    </Constant>
