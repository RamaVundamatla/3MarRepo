    <JadeMethod name="getTerminalCode" id="5e166386-1fac-4994-871e-d56124e09388">
        <source>getTerminalCode() : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 June 2024	navra1	Initial creation for //navra1 - TFS 60149/Task 64397 - 12th June 2024

*/

vars
	vvr : CM_VehicleVisitRecord;
	invalidObj : Boolean;
begin
	on Exception do app.handleDeletedObject(exception,self.myParentObject,invalidObj);

	vvr:=self.myParentObject.CM_VehicleVisitRecord;
	
	if invalidObj then
		return null;
	endif;
	
	return vvr.myTerminal.code;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
