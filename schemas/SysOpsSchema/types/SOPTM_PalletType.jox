    <JadeMethod name="includeObject" id="7590ceaf-8950-42c6-8ee9-34340eaecf02">
        <updating/>
        <source>includeObject(_obj: Object; _passport: CM_Passport): Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 March 2017	cnwndl1	Initial creation	TFS 3414

*/

vars

begin

	if self.includeNotAvailableEntries then
		return true;
	else
		return not _obj.CM_PalletType.isNotAvailableForEntry;
	endif;

epilog

end;</source>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
