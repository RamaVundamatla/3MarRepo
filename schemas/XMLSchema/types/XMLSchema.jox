    <JadeMethod name="finalizeTCPIPClient" id="e3855c17-9db5-4419-aeeb-cfb720bd5a6e">
        <updating/>
        <source>finalizeTCPIPClient() updating;

// cnwdvb1 28 April 2003 
/*

Date		Who		Reason
15 Jul 2008	cnwkpd1	PAR #17543 - Prevent 1090 exceptions during shutdown
22 Oct 2008	cnwkpd1	PAR #17953 - Add finalize call to check for transient leaks

*/

vars

begin
	if self.myBGPController &lt;&gt; null then		// PAR #17543
		self.myBGPController.finish();
	endif;
	delete self.myTcpIpClientAgent;

	self.finalize();							// PAR #17953

end;</source>
    </JadeMethod>
    <JadeMethod name="finalizeTCPIPWorker" id="87281634-fd31-4141-8206-af76c5b0033d">
        <updating/>
        <source>finalizeTCPIPWorker() updating;

vars

begin

	app.exitLogFile();
	if global.isValidObject(self.myXMLWorker) then
		self.myXMLWorker.finish();
		delete self.myXMLWorker;
	endif;
	app.finalize();

end;</source>
    </JadeMethod>
    <JadeMethod name="findWorkerClass" id="4c5709fc-0357-4ce1-89b2-d809b410dbe1">
        <source>findWorkerClass(_str : String) : Class;

// cnwdvb1 28 April 2003 

vars

	con 	: Constant;
	class	: Class;
	str		: String;
begin

	con := CMIF_BGPManagerChildren.findConstant(_str);
	if con &lt;&gt; null then
		str := con.text.cnEcGetTagValueOfName('workerclass');
		class	:= currentSchema.getClass(str);
	endif;
	if class = null then
		app.raiseCMException(InvalidTcpipClass, null, null);
	endif;
	return class;
end;</source>
        <Parameter name="_str" type="String"/>
        <ReturnType type="Class"/>
    </JadeMethod>
    <JadeMethod name="finializeTCPIPApp" id="a714ddef-675a-4547-98e7-2ef60be16dc6">
        <updating/>
        <source>finializeTCPIPApp() updating;
// -----------------------------------------------------------------------------
// Created:		05 August 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
// 15 Jul 2008	cnwkpd1	PAR #17543 - Prevent 1090 exceptions during shutdown
// -----------------------------------------------------------------------------
begin
	app.exitLogFile();
	if self.myXMLAgent &lt;&gt; null and global.isValidObject(self.myXMLAgent) then
		self.myXMLAgent.finish();
		delete self.myXMLAgent;
	endif;
	if self.myBGPController &lt;&gt; null then			// PAR #17543
		self.myBGPController.finish();
	endif;
	app.finalize();
		
		
end;</source>
    </JadeMethod>
    <JadeMethod name="initTCPIPClient" id="8c3485a6-2317-45d5-82b9-c99571e1c76b">
        <updating/>
        <source>initTCPIPClient(_controller : BGP_TCPClient input) updating;

// cnwdvb1 28 April 2003 
/*

Date		Who		Reason
23 Sep 2008	cnwkpd1	PAR #18009 - Allow ini file control of transient check

*/

vars

	class : Class;
	
begin

	if _controller = null then
		terminate;
	endif;
	
	class := app.findWorkerClass(_controller.workerClass);
	app.initialize();
	_controller.initApp();
	self.myBGPController := _controller;

	create self.myTcpIpClientAgent as class transient;
	self.myTcpIpClientAgent.init(_controller);
//	app.myCnCntrl.setCheckTransientsOnShutDown(false);	- removed PAR #18009

end;</source>
        <Parameter name="_controller" type="BGP_TCPClient" usage="input"/>
    </JadeMethod>
    <JadeMethod name="initTCPIPListen" id="138ae1a6-0892-457b-81b3-f58ec7dfd5b9">
        <updating/>
        <source>initTCPIPListen(_controller : BGP_XMLListenController input) updating;
// -----------------------------------------------------------------------------
// Created:		01 August 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
// 23 Sep 2008	cnwkpd1		PAR #18009 - Allow ini file control of transient check
// -----------------------------------------------------------------------------
begin

	if _controller = null then
		terminate;
	endif;
	
	app.initialize();
	_controller.initApp();
	self.myBGPController := _controller;

	// Put here because level is protected.
	//self.logLevel := self.myBGPController.BGP_XMLListenController.loggingLevel; //22 Nov 2019	NDL	TFS 47053 Part of 'initialize'
	create self.myXMLAgent as CM_TCPIPAgentListen transient;
	self.myXMLAgent.init();
//	app.myCnCntrl.setCheckTransientsOnShutDown(false);	- removed PAR #18009
	
end;</source>
        <Parameter name="_controller" type="BGP_XMLListenController" usage="input"/>
    </JadeMethod>
    <JadeMethod name="initTCPIPWorker" id="f1c46c15-c61c-4015-b2bf-ecf2c6b6a769">
        <updating/>
        <source>initTCPIPWorker(_xmlAgent : CM_TCPIPShared) updating;
// -----------------------------------------------------------------------------
// Created:		01 August 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
// 23 Sep 2008	cnwkpd1		PAR #18009 - Allow ini file control of transient check
// -----------------------------------------------------------------------------

begin

	app.initialize();
	// Put here because level is protected.
	self.changeLogLevel(_xmlAgent.loggingLevel);
	self.myXMLAgent := _xmlAgent; 
	self.myXMLAgent.init();
	create self.myXMLWorker as _xmlAgent.myWorkerClass transient;
	self.myXMLWorker.init();
	beginTransaction;
	process.changeUserCode('TCPIP Worker');
	commitTransaction;
	app.isBackGroundApp := true;
//	app.myCnCntrl.setCheckTransientsOnShutDown(false);	- removed PAR #18009
//	app.myCnCntrl.setCheckTransientsOnShutDown(true);
end;</source>
        <Parameter name="_xmlAgent" type="CM_TCPIPShared"/>
    </JadeMethod>
</Class>
