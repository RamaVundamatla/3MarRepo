    <JadeMethod name="displayEntryErrorWarning" id="9dd1be3b-d4ee-4022-97e7-aac1d4476868">
        <source>displayEntryErrorWarning(_errorObj : XLAT_Translation) : String;
/*
----------   ----------  --------------------------------------------------
Created:	12 July 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	return _errorObj.myTranslatableText.number.String &amp; ' : ' &amp;  _errorObj.text;

end;


