    <JadeMethod name="getDisplayStringForAttribute" id="6ed246fb-4a10-4a8e-b9cb-082b9c7356d7">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 Jun 2024 navnk30 Bug 64601: FR | 54883 - Start and End Times for Operations in Mobile App

*/

vars

begin
	if _attrName = ETRow_TransactionDT then
		if self.type = TRANS_TYPE_WOJOBSTART then
			return self.systemToLocalTime(self.getJobStart()).shortCurrentLocaleFormat();
		elseif self.type = TRANS_TYPE_WOJOBCOMPLETE then
			return self.systemToLocalTime(self.getJobEnd()).shortCurrentLocaleFormat();
		endif;
	endif;
	
	return inheritMethod(_attrName, _short);
		

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
