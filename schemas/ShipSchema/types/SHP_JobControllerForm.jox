    <JadeMethod name="doResize" id="f1576680-5cbc-4dcc-a1f5-f22bf496db6b">
        <updating/>
        <source>doResize() updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
18 December 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars
	vTop,
	vHeight : Real;
begin
	self.btnHideGraph.enabled:=self.windowState = Form.WindowState_Normal;
	if self.myJobController = null then
		 inheritMethod();
		 return;
	endif;
	
	
	if self.windowState = Form.WindowState_Maximized and not self.frmScrollingMain.visible then
		self.doShowHideMainGraph;
		return;
	endif;

	if self.frmScrollingMain.visible then
		vTop:=frmToolbar.height  + self.frmSailingTime.clientHeight;//+ self.frmCranes.clientHeight
		vHeight:=self.clientWindowHeight - frmToolbar.height -  self.frmSailingTime.clientHeight;
		self.myJobController.setTop(vTop);
		self.myJobController.setHeight(vHeight);
		self.myJobController.setWidth(self.clientWidth);
		self.frmScrollablMain.top:=vTop;
		self.frmScrollablMain.height:=vHeight;
	
		self.doResizeCraneTable;
		self.myJobController.resizeScrollableMain;
	endif;
	
inheritMethod();
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doResizeCraneTable" id="3dfddaae-0c81-41dc-8f6a-7df83dd5c5ab">
        <source>doResizeCraneTable();
/*

Purpose:			


Return Value:		


Date		Who		Reason
07 August 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars
	newWidth, newLeft : Real;
begin
	if self.frmScrollingMain.visible then
		newWidth:=self.clientWidth- self.myJobController.getVoyageOverviewLabelFrame.width;
		newLeft:=self.myJobController.getVoyageOverviewLabelFrame.width;
	else
		newWidth:=self.clientWidth;
		newLeft:=0;
	endif;
	if self.frmScrollablMain.hasVScroll then
		newWidth:=newWidth - CMUI_ScrollableFrame.ScrollBarWidth;
	endif;
	self.frmCranesNew.width:=newWidth;
	self.frmCranesNew.left:=newLeft;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doSelectVoyage" id="3f50b6de-075d-4ae6-86cb-503a8cb10ed6">
        <updating/>
        <source>doSelectVoyage(_voyage : CM_Voyage) updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
19 December 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars
	allJobsStartEndTime : ObjectArray;
	vTop,
	vHeight,
	vWidth: Real;
begin
	//self.doCheckNotLocked(_voyage);
	//self.scrolledOffset:=0;
	self.btnHideCompleted.value:=false;
	self.myVoyage := _voyage;
	self.mousePointer := Window.MousePointer_HourGlass;
	
	
	self.frmSailingTime.ignoreSkin:=true;
	self.frmSailingTime.left:=0;
	self.frmSailingTime.top:=0;
	self.frmSailingTime.height :=30;
	self.frmSailingTime.parentAspect:=Control.ParentAspect_StretchBoth;
	self.frmSailingTime.visible:=true;
	self.frmSailingTime.alignContainer:=Frame.AlignContainer_Top;
	
	
	vTop:=frmToolbar.height  + self.frmSailingTime.clientHeight;//+ self.frmCranes.clientHeight
	vHeight:=self.clientWindowHeight - frmToolbar.height  -  self.frmSailingTime.clientHeight;
	vWidth:=self.clientWidth;
	if self.myJobController &lt;&gt; null then
		delete self.myJobController;
	endif;

	//beginTransientTransaction;
	create self.myJobController transient;
	self.myJobController.setDetails(self,
									_voyage,
									self.frmScrollablMain,
									self.frmScrollingMain,
									self.frmJobBubble,
									vTop,
									vHeight,
									vWidth,
									self.timeScale,
									self.voyageZoom,
									false);
	self.myJobController.drawVoyage();								
	//self.frmCranesNew.top:=1;
	//self.frmCranesNew.left:=self.frmScrollablMain.myVLabels.width;
	//self.frmCranesNew.width:=vWidth - self.frmCranesNew.left - app.getVerticalScrollbarWidth;
	//self.setupCraneStatsTable(self.frmScrollablMain.myVLabels.width,vWidth - self.frmCranesNew.left - app.getVerticalScrollbarWidth);
					
	
	self.setFormCaption();
	self.setSailingTimes;
	self.mousePointer := Window.MousePointer_Default;
epilog
	
end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="doShowHideMainGraph" id="fadc145a-d667-459d-9766-e45b3fec5285">
        <updating/>
        <source>doShowHideMainGraph() updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
08 August 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars

	vesselFrame :CMUI_Frame;
	timeFrame : CMUI_Frame;
	theHeight : Real;
begin
	self.frmScrollingMain.visible:=not self.frmScrollingMain.visible;
	vesselFrame:=self.myJobController.getVoyageOverviewLabelFrame;
	//vesselFrame.visible:=not vesselFrame.visible;
	vesselFrame.distanceFromBottom:=0;
	vesselFrame.top:=0;
	self.mnShowMain.checked:=not self.mnShowMain.checked;
	self.btnHideGraph.value:=not self.mnShowMain.checked;
	self.doResizeCraneTable;
	self.tblCranes.repositionAfterResize;
	timeFrame:=self.myJobController.getTimeLineLabelFrame;
	//self.frmScrollablMain.myTopLeftFillerFrame.visible:=not self.frmScrollablMain.myTopLeftFillerFrame.visible;
	if self.frmScrollingMain.visible then
		theHeight:=self.frmToolbar.height + self.frmSailingTime.height + self.myJobController.height;
	else
		theHeight:= self.frmToolbar.height + self.frmSailingTime.height +  self.frmCranesNew.height + timeFrame.height;
		if self.frmScrollablMain.hasHScroll then
			theHeight := theHeight + CMUI_ScrollableFrame.ScrollBarWidth;
		endif;
	endif;
	self.clientHeight:=theHeight.Integer;
	
	if self.frmScrollingMain.visible then
		self.doResize;
	else
		//self.frmScrollablMain.setLeftLabelMargin(0);
		self.frmScrollablMain.sendMsg("positionHScrollBar");//repositionScrollBars();
		self.frmScrollablMain.sendMsg("positionVScrollBar");
		//self.frmScrollablMain.repositionScrollBars();
	endif;
	
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doShowJobEdit" id="5497da6f-3356-475a-9b52-30fe114363bf">
        <source>doShowJobEdit(_menuItem : MenuItem input; _isStart,_isEnd : Boolean);
/*

Purpose:			


Return Value:		


Date		Who		Reason
23 Jan 2007	cnwer1	Initial creation - PAR#xxxx
25 Oct 2012	PJS		PAR # 30631 - Voyage Rationlisation

*/
vars

	realVoyageJob : CM_VoyageJob;
begin
	if _menuItem.userObject = null then
		return;
	endif;
	
	if _menuItem.userObject.isTransient then
		realVoyageJob:=app.myProxyManager.getRealObject(_menuItem.userObject.CM_Object).CM_VoyageJob;
	else
		realVoyageJob:=_menuItem.userObject.CM_VoyageJob;
	endif;

	if realVoyageJob = null then
		return;
	endif;	
	
	if _isStart or _isEnd then
		self.myAssistant.SHP_Assistant.showVoyageJobFormDefaultTS(self.myVoyage, realVoyageJob, _isStart,_isEnd);
	else
		self.myAssistant.SHP_Assistant.showVoyageJobForm(self.myVoyage, realVoyageJob);
	endif;
		

epilog

end;</source>
        <Parameter name="_menuItem" type="MenuItem" usage="input"/>
        <Parameter name="_isStart" type="Boolean"/>
        <Parameter name="_isEnd" type="Boolean"/>
    </JadeMethod>
