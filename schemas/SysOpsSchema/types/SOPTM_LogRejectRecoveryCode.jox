	theForm.tblInput1.cnEcResizeContents();
end;</source>
    </JadeMethod>
    <JadeMethod name="setupThumbnailDetails" id="0c945bbc-d6f9-4b43-870d-d4cbe996ac0b">
        <source>setupThumbnailDetails();
// ---------------------------------------------------------------------------
// Created:     26 March 2002 by cnwdf1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	theForm : SOP_TableMaintForm;

begin
  
  	theForm := self.myForm;
	theForm.useProxyObject := true;
	theForm.setTblDataEntRows(ETDef_LogRejectRCCodeTbl);
//	theForm.zAddColumn('Log Reject Recovery Code', 'code', Table.InputType_None, 60);
//	theForm.zAddColumn('Description', 'description', Table.InputType_None, 40);
//12/01/2011 cnwdz2 25840
	//theForm.zClearSortColumns();
	//theForm.zAddSortColumn(ETRow_Code, false);

	theForm.shtTblInput1.caption := 'Details';
	theForm.initTblInput(theForm.tblInput1, ETDef_LogRejectRCCodeMaint);
	theForm.shtTblInput1.visible := true;
	
	theForm.tblData.userInputEnabled := false;

	theForm.mulSelect1.formDisplayEntryMethodName := null;
	theForm.mulSelect2.formDisplayEntryMethodName := null;
end;</source>
    </JadeMethod>
    <JadeMethod name="showThumbnail" id="abacdcb3-52ed-4b9b-ae09-96c5f018f60b">
        <updating/>
        <source>showThumbnail(pObj: CM_LogRejectRecoveryCode) updating;
// ---------------------------------------------------------------------------
// Created:     25 March 2002 by cnwdf1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

	theForm : SOP_TableMaintForm;

begin
  
    theForm := self.myForm;
	theForm.tblInput1.clearValues;
	theForm.tblInput1.setValueByName(ETRow_Code, pObj.code);
	theForm.tblInput1.setValueByName(ETRow_Description,	pObj.description);
	theForm.tblInput1.setValueByName(ETRow_NotAvailableForEntry, pObj.notAvailableForEntry);

end;</source>
        <Parameter name="pObj" type="CM_LogRejectRecoveryCode"/>
    </JadeMethod>
</Class>
