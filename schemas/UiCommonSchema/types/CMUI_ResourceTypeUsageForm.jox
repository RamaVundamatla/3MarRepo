    <JadeMethod name="checkForUnsavedTransientChgs" id="175a2f07-fa2e-4fcf-97e7-1dc09d033210">
        <source>checkForUnsavedTransientChgs(unsavedChange : Boolean output);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 March 2010	cnwndl1	Initial creation	Par 22725

*/

vars

	resourceType : CM_ResourceType;
	
begin
	
	if not self.grpResource.enabled then
		// no entry possible, can't be any unsaved changes.
		unsavedChange := false;
		return;
	endif;
	
	resourceType := self.cmbResourceType.listObject.CM_ResourceType;
	
	if self.myCurrentProxyUsage &lt;&gt; null then
		// in update mode
		if self.myCurrentProxyUsage.myResourceType &lt;&gt; resourceType
		//or self.myCurrentProxyUsage.quantity &lt;&gt; self.txtUnits.text.Decimal
		or self.myCurrentProxyUsage.quantity &lt;&gt; self.txtUnits.text.asDecimalJMT()// 01 APR 2010	NDL	Par 23556
		or	self.myCurrentProxyUsage.remarks &lt;&gt; self.txtRemarks.text
		or	self.myCurrentProxyUsage.noCharge &lt;&gt; self.chkNoCharge.value
		or	( self.myCurrentProxyUsage.status = CM_InvoiceLine.STATUS_VOIDED and self.chkVoid.value = false )
		or	( self.myCurrentProxyUsage.status = CM_InvoiceLine.STATUS_NORMAL and self.chkVoid.value = true )
		or self.myCurrentProxyUsage.fromDateTime.date &lt;&gt; self.txtFromDate.getDate()		//cnwmc5 - 22 Sep 2015 - PAR 36920
		or self.myCurrentProxyUsage.fromDateTime.time &lt;&gt; self.txtFromTime.getTime()		//cnwmc5 - 22 Sep 2015 - PAR 36920
		or self.myCurrentProxyUsage.toDateTime.date &lt;&gt; self.txtToDate.getDate()			//cnwmc5 - 22 Sep 2015 - PAR 36920
		or self.myCurrentProxyUsage.toDateTime.time &lt;&gt; self.txtToTime.getTime()			//cnwmc5 - 22 Sep 2015 - PAR 36920
		or self.myCurrentProxyUsage.myPalletType &lt;&gt; self.cmbPalletType.listObject.CM_PalletType	//13 Apr 2017	NDL	TFS 3414
		or self.myCurrentProxyUsage.isHeatTreated &lt;&gt; self.chkHeatTreated.value	//13 Apr 2017	NDL	TFS 3414
		or self.myCurrentProxyUsage.isStoreOnPallet &lt;&gt; self.chkStoreOnP.value	//13 Apr 2017	NDL	TFS 3414
		then
			unsavedChange := true;
		endif;
	
	else
		// in add mode
		if resourceType &lt;&gt; null
		//or self.txtUnits.text.Decimal &lt;&gt; 0
		or self.txtUnits.text.asDecimalJMT &lt;&gt; 0	//22 Oct 2015	NDL	Par 36655
		or	self.txtRemarks.text.trimBlanks &lt;&gt; null
		or	self.chkNoCharge.value
		or not self.txtFromDate.isEmpty			//cnwmc5 - 22 Sep 2015 - PAR 36920
		or not self.txtFromTime.isEmpty			//cnwmc5 - 22 Sep 2015 - PAR 36920
		or not self.txtToDate.isEmpty 			//cnwmc5 - 22 Sep 2015 - PAR 36920
		or not self.txtToTime.isEmpty			//cnwmc5 - 22 Sep 2015 - PAR 36920
		or self.cmbPalletType.listIndex &gt; 1	//13 Apr 2017	NDL	TFS 3414
		or self.chkHeatTreated.value	//13 Apr 2017	NDL	TFS 3414
		or self.chkStoreOnP.value	//13 Apr 2017	NDL	TFS 3414
		then
			unsavedChange := true;
		endif;
	
	endif;

epilog

end;</source>
        <Parameter name="unsavedChange" type="Boolean" usage="output"/>
    </JadeMethod>
    <JadeMethod name="chkStoreOnP_click" id="163da430-2c3d-437c-b469-99ccd7d0720a">
        <controlMethod name="CMUI_CheckBox::click"/>
