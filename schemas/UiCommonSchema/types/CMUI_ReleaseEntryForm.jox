    <JadeMethod name="loadCmbProduct" id="e7a86fa1-aeff-48f2-a86b-40cfe05a5826">
        <source>loadCmbProduct() protected;
/*
----------   ----------  --------------------------------------------------
Created:	26 March 2007 By cnwth2

