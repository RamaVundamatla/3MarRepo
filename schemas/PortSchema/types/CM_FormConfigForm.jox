    <JadeMethod name="getDisplayStringForAttribute" id="6b39118e-234f-473f-a544-43b51a11b522">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*	Purpose:				
	Parameters:			
	Return Value:		

Date				Who			Reason
02 September 2008	concms1:1	User definable forms

*/

vars

begin
	if _attrName = ETRow_FormConfigName then
		return self.getFormNameDisplay;
	elseif _attrName = ETRow_FormConfigTerminal then
		return self.getTerminalNameDisplay;
	endif;

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getFormNameDisplay" id="445289c2-54ff-438c-b0e4-66b1cf07e4ba">
        <source>getFormNameDisplay():String;
/*	Purpose:				
	Parameters:			
	Return Value:		

Date				Who			Reason
02 September 2008	concms1:1	User definable forms

*/
vars

begin
	if self.formName = null then
		return Any_String;
	elseif formName = 'GTE_InOutExpressForm' then
		return 'Flexi-Gate in/Out';
	endif;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getSchemaName" id="5409351d-3de2-4435-8d8f-720a97bb313a">
        <source>getSchemaName():String;
// ---------------------------------------------------------------------------
// Created:     02 September 2008 by concms1:1
//
// Purpose:     User definable forms - CCMS 1011
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	prefix :String;
begin
	if self.formName.length &gt; 3 then
		prefix := self.formName [1:4];
		
		if prefix = 'GTE_' then
			return 'GateSchema';
		endif;
	endif;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTerminalNameDisplay" id="702830ff-4c4f-4bff-a0af-01532b04cb95">
        <source>getTerminalNameDisplay():String;
// ---------------------------------------------------------------------------
// Created:     02 September 2008 by concms1:1
//
// Purpose:     User definable forms - CCMS 1011
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

begin
	if self.myTerminal = null then
		return Any_String;
	endif;
	
	return self.myTerminal.name;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="3252f0f8-b710-48d8-9350-893754220518">
        <source>pxyCreateUpdateProxy(): SelfType;
// ---------------------------------------------------------------------------
// Created:     03 September 2008 by concms1
// Purpose:     User definable forms - CCMS 1011
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy
// ---------------------------------------------------------------------------
vars
	proxy			:CM_FormConfigForm;
	item, pxyItem	:CM_FormConfigItem;
	completedOK		: Boolean;
begin
	proxy := inheritMethod();
	
	proxy.formName		:= self.formName;
	proxy.myTerminal	:= self.myTerminal;
	
	foreach item in self.allConfigItems do
		pxyItem := item.pxyCreateUpdateProxy;
		
		pxyItem.setMyConfigForm (proxy);
	endforeach;
	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return proxy;
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete proxy;
	endif;

end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="d8f4f18e-c30d-4b86-9ee1-1e124be16f63">
        <updating/>
        <source>setForCreate(_pxyConfig :CM_FormConfigForm)updating;
// ---------------------------------------------------------------------------
// Created:     02 September 2008 by concms1:1
//
// Purpose:     User definable forms - CCMS 1011
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
begin

epilog
	self.formName	:= _pxyConfig.formName;
	self.myTerminal	:= _pxyConfig.myTerminal;
end;</source>
        <Parameter name="_pxyConfig" type="CM_FormConfigForm"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="6a88cd58-2716-4ac5-ba7e-213e2054c7d7">
        <updating/>
        <source>setForUpdate(_proxy :CM_FormConfigForm)updating;
// ---------------------------------------------------------------------------
// Created:     03 September 2008 by concms1
// Purpose:     User definable forms - CCMS 1011
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	item, pxyItem	:CM_FormConfigItem;
begin
	self.width	:= _proxy.width;
	self.height	:= _proxy.height;
	
	self.allConfigItems.purge;	// won't need these anymore
	
	foreach pxyItem in _proxy.allConfigItems do
		item := pxyItem.cloneSelf (false);
		
		item.setMyConfigForm (self);
	endforeach;
epilog

end;</source>
        <Parameter name="_proxy" type="CM_FormConfigForm"/>
    </JadeMethod>
