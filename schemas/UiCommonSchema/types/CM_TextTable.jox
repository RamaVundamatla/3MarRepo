    <JadeMethod name="create" id="de86e583-79c5-439f-908e-235da761fd5a">
        <updating/>
        <executionLocation>client</executionLocation>
        <source>create() updating, clientExecution;
/*
	Created on 05 February 2008
	
	by Debby Hutchison
	
	Purpose:
*/

vars

begin
	self.fixedRows 		:= 0;
	self.fixedColumns	:= 0;

	self.rows := 0;

end;</source>
    </JadeMethod>
    <JadeMethod name="getXmlStrForDisplay" id="e920c9bd-7ec9-4f58-bec1-9031e65e0c71">
        <source>getXmlStrForDisplay() : String ;
/*
	Created on 05 February 2008
	
	by Debby Hutchison
	
	Purpose:
*/

vars
	str,
	xmlStr,
	tmpStr,
	sortStr,
	widthStr 	: String;
	entRow		: EntTableRow;		
	numCols,
	idx			: Integer;
begin
	if self.allDisplayEntTableRows.isEmpty then
		return null;
	endif;
	
	foreach entRow in self.allDisplayEntTableRows do
		tmpStr := tmpStr &amp; global.formatAsXML(XMLTag_Column, entRow.name);
	endforeach;
	
	xmlStr := xmlStr &amp; 
			global.formatAsXMLPrefix(XMLTag_Table &amp; self.name) &amp;
			global.formatAsXMLPrefix(XMLTag_EntTblDef &amp; self.myEntTableDef.name) &amp;			
			tmpStr &amp;
			global.formatAsXMLSuffix(XMLTag_EntTblDef &amp; self.myEntTableDef.name) &amp;									
			global.formatAsXMLSuffix(XMLTag_Table &amp; self.name);

	return xmlStr;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="keyDown" id="5dc9a165-a71f-48a6-9c52-aa335a97ae8c">
        <controlMethod name="CM_BaseTable::keyDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>keyDown(table: CM_TextTable input; keyCode: Integer io; shift: Integer) updating, clientExecution;
/*
	Created on 05 February 2008
	
	by Debby Hutchison
	
	Purpose:
*/

vars
	theRow		: JadeTableRow;
	theObject	: Object;
	
begin

	inheritMethod(table, keyCode, shift);

	if table.multiSelect &lt;&gt; MultiSelect_None then
		if shift.bitAnd(2) &lt;&gt; 0 then
			self.controlKeyDown := true;
		endif;
	endif;
	
end;
</source>
        <Parameter name="table" type="CM_TextTable" usage="input"/>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="keyUp" id="98a69a2d-1e1c-4b6f-a9ca-d4e2f8f9be20">
