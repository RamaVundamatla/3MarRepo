<Class name="CM_BOLInScalerTransaction" id="da7fcea4-901c-41a6-8638-a9ccaa7f7a12">
    <superclass name="CM_BOLTransaction"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="transactbol"/>
    <PrimAttribute name="scalerCode" id="d7153a00-035c-493f-baca-a93a3ef1622b">
        <length>11</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="scalingFinishTime" id="e9bf32be-9be5-4eea-a04a-6ec12d0a200a">
        <embedded/>
        <type name="TimeStamp"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="scalingStartTime" id="734be32f-7ef4-47fb-9a53-840579dc9cbc">
        <embedded/>
        <type name="TimeStamp"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="getScalingFinishTimeLocalTZ" id="c6e0fd84-6c4f-4ca6-84a1-65608681ba95">
        <source>getScalingFinishTimeLocalTZ(): TimeStamp;
/*

Purpose:			Return the local timezone version of the receiver's dateTime (for JRW)

Parameters:			None

Return Value:		

Date		Who		Reason
07 Jun 2016	cnwmp6	TFS 488 - Multi Timezone Support

*/
vars

begin
	return self.systemToLocalTime(self.scalingFinishTime);
epilog

end;</source>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="getScalingStartTimeLocalTZ" id="e4c2364f-bcc8-4f63-8229-f67c274c798f">
        <source>getScalingStartTimeLocalTZ(): TimeStamp;
/*

Purpose:			Return the local timezone version of the receiver's dateTime (for JRW)

Parameters:			None

Return Value:		

Date		Who		Reason
07 Jun 2016	cnwmp6	TFS 488 - Multi Timezone Support

*/
vars

begin
	return self.systemToLocalTime(self.scalingStartTime);
epilog

end;</source>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="setScalerDetails" id="b0f0ce07-5b6f-4ffa-a91d-81ea66631ed6">
        <updating/>
        <source>setScalerDetails(_bol: CM_BOLIn; _logScaleExtra : CM_LogScalingExtra) updating;

// cnwdvb1 12 June 2003 

vars

begin

	self.scalerCode			:= _logScaleExtra.scalerCode;
	self.scalingStartTime	:= _logScaleExtra.scalingStartTime;
	self.scalingFinishTime	:= _logScaleExtra.scalingFinishTime;
	self.setForCreate(_bol, TRANS_TYPE_BOLIN_SCALER);
end;</source>
        <Parameter name="_bol" type="CM_BOLIn"/>
        <Parameter name="_logScaleExtra" type="CM_LogScalingExtra"/>
    </JadeMethod>
</Class>
