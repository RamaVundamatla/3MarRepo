    <JadeMethod name="doResize" id="1fc91a8c-4bc3-406a-a834-f732409cec92">
        <updating/>
        <source>doResize() updating;
// ---------------------------------------------------------------------------
// Created:		August 2004 By Andrew Bishop cnwab1
// 
// Purpose:		
// 08 May 2025 navrv30	MTN 34672: MTN | Multigroup Selection Filter Phase 3
// ---------------------------------------------------------------------------

vars

begin
	inheritMethod();
	self.lstPropFour.move(0,0,self.lstPropFour.parent.width,self.lstPropFour.parent.height + 20);
	self.myCarriersMultiSelectBox.move(0,0,self.myCarriersMultiSelectBox.parent.width,self.myCarriersMultiSelectBox.parent.height + 20); //+ cnwmd1, CCMS 1067, Par 19913	
	self.myCarriersMultiSelectBox.cnEcResizeContents(); //+ cnwmd1, CCMS 1067, Par 19913
end;</source>
