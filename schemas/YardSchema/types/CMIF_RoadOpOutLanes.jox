    <JadeMethod name="updateDataTableObject" id="a2aaf712-2bf2-4a1e-b6a9-5ab5729ed7f9">
        <source>updateDataTableObject(_obj: CM_Object input);

/*
Date			Who		Reason
25 Sep 2014		cnwar2	Initial creation
08 Jan 2026 	navma1  MTN-36897 PEN - Transient File Growth in PEN Production Environment 
*/
vars
	job 		: CM_Job;
	vehicle 	: CM_Vehicle;				//27 Aug 2019	NDL	TFS 42876
	vehLocation : CM_LocationsController;	//27 Aug 2019	NDL	TFS 42876
	
begin
	// 25/09/2014 cnwar2 #34333
	if self.myRoadOpController.hideCompletedJobs then
		job := _obj.CM_WorkListEntry.job;
		if job &lt;&gt; null and job.isJobComplete then
			return;
		endif;
	endif;
	
	//27 Aug 2019	NDL	TFS 42876
	//Can get to here via a notification, when we have multiple wles for the same break bulk
	//i.e. Rail to multiple trucks with a wle that is on a truck that is not yet in the yard.
	if _obj &lt;&gt; null then
		if _obj.isKindOf(CM_WorkListEntry) then				//08.01.2026 navma1 #MTN-36897
			job := _obj.CM_WorkListEntry.job;

			if job &lt;&gt; null then
				vehicle := job.CM_RoadJob.myVehicle;
			endif;
		elseif _obj.isKindOf(CM_Vehicle) then
			vehicle := _obj.CM_Vehicle;
		endif;
	endif;
	
	if vehicle &lt;&gt; null then
		vehLocation := vehicle.myPrimaryActualLocation;
		if vehLocation = null or not vehLocation.isLaneController then
			return;
		endif;
	endif;
	
	inheritMethod(_obj);

end;</source>
        <Parameter name="_obj" type="CM_Object" usage="input"/>
    </JadeMethod>
</Class>
