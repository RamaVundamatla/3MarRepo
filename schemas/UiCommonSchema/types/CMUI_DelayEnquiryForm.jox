    <JadeMethod name="doNotableAdd" id="1a763425-c753-49b6-9243-d36d6cfaf660">
        <source>doNotableAdd(_delay :CM_Delay);
// ---------------------------------------------------------------------------
// Created:     04 April 2011 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	// need to allow for notes already being registered for object
	self.allNotableObjects.addNoDuplicates(_delay, false);
	// using class notifications for adds/updates
	beginNotification(_delay, Object_Delete_Event, Response_Continuous, null);
epilog

end;
</source>
        <Parameter name="_delay" type="CM_Delay"/>
    </JadeMethod>
    <JadeMethod name="doNotableClear" id="bc8560f6-091f-4f55-ad2e-78bc704e1d50">
        <source>doNotableClear();
// ---------------------------------------------------------------------------
// Created:     04 April 2011 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	// we don't want to call inheritMethod
	self.endNotificationForSubscriber (self);
	// don't forget the class notes
	self.beginClassNotification(CM_Delay, false, Object_Create_Event, Response_Continuous, 0);
	self.beginClassNotification(CM_Delay, false, Object_Update_Event, Response_Continuous, 0);
	self.allNotableObjects.clear;
epilog
	
end;
</source>
    </JadeMethod>
    <JadeMethod name="doNotableRemove" id="0c6af7da-0b85-455c-8486-9b1a8f682d3b">
        <source>doNotableRemove(_delay :CM_Delay);
// ---------------------------------------------------------------------------
// Created:     04 April 2011 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	
begin
	// no need for inheritMethod
	
	if  self.allNotableObjects.includes(_delay) then
		self.allNotableObjects.remove(_delay);				// no exception even if invalid object
		self.endNotification(_delay, Object_Delete_Event);	// no exception even if invalid object
	endif;
epilog

end;</source>
        <Parameter name="_delay" type="CM_Delay"/>
    </JadeMethod>
