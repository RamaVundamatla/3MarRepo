    <JadeMethod name="isStorageDetailMatch" id="5c0203df-0514-4935-aa0b-bdc7a5614aa6">
        <source>isStorageDetailMatch(_criteria : CM_YACriteria; _ti: CM_TrackedItem; _tiTrx : CM_TITransaction): Boolean;
// CCMS 1295 free storage days
vars

begin
	//epr TFS 37176 21/2/18
	// specific value
//	return _criteria.myYAData.CM_YADataBoolean.doesValueMatch(_ti.isOverDimensions);
	
	if _tiTrx &lt;&gt; null and _tiTrx.myTrackedItem &lt;&gt; null then	//13 Nov 2019	NDL	TFS 47344
		return _criteria.myYAData.CM_YADataBoolean.doesValueMatch(_tiTrx.myTrackedItem.isOverDimensions);	// over dimensions not kept on the generic transaction
	else
		return _criteria.myYAData.CM_YADataBoolean.doesValueMatch(_ti.isOverDimensions);
	endif;
end;
</source>
        <Parameter name="_criteria" type="CM_YACriteria"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_tiTrx" type="CM_TITransaction"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isVoyageAllocationCT" id="cf747f9a-a8f7-45bc-858f-587a855996b0">
