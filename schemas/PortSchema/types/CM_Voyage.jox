    <JadeMethod name="getLoadEndTimeByIndex" id="b13fbab7-7f3f-4167-ab89-4ce2850f7bfc">
        <source>getLoadEndTimeByIndex(_index :Integer):TimeStamp protected;
/*
Date		Who		Reason
22 September 2011	cnwcs5	Initial creation - CCMS RIO 2041 / par 28220 Start/Stop Times
*/
vars
	movement	:HMS_Movement;
	ts			:TimeStamp;
begin
	movement := self.getMovementFirstRealBerth ;
	
	if movement = null then 
		return null;
	endif;
	
	ts := movement.getLoadEndTimeByIndex (_index);
	
	if ts = null and _index = 1 then
		ts := self.getRealBerthDT.cnEcAddMinutes (self.getGrossLoadingTimeMinutes);
	endif;
	
	return ts;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_index" type="Integer"/>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="getLoadMoveCount" id="c4520e5c-0c66-4ae0-aa53-1f953e9be424">
        <source>getLoadMoveCount() : Integer;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 May 2012	cnwdw1	Initial creation
*/
vars
	count : Integer;
	aJS : CM_JobSheet;
begin
	foreach aJS in self.allJobSheets discreteLock do
		count := count + aJS.CM_VoyageJobSheet.allShipReleases.size;
	endforeach;
	return count;
end;
</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
