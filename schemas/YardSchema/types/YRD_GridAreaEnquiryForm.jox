    <JadeMethod name="doMnuRemoveLabRestrictClick" id="51c3445a-e498-48ce-b285-2d2d1ba8ac5b">
        <updating/>
        <source>doMnuRemoveLabRestrictClick(menuItem: MenuItem input) updating;
// ---------------------------------------------------------------------------
// Created:     07 June 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars

	rowNum		: Integer;
	theTA		: CM_TerminalArea;
	restrictionLabour	: CM_LabourRestriction;
begin

	if menuItem.helpKeyword &lt;&gt; "MAIN" then
		if menuItem.helpKeyword = "VIEW" then 			
			self.doRestrictionOpenLabour(menuItem.userObject.CM_TerminalArea);
		elseif menuItem.helpKeyword = "ALL" then 
			self.deleteAllLabourRestriction(menuItem.userObject.CM_TerminalArea);
		else 		
			self.deleteLabourRestriction(menuItem.userObject.CM_LabourRestriction);
		endif;	
	endif;
end;</source>
