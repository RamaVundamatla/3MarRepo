    <JadeMethod name="doControlEvent" id="dc4838a9-e1ba-4213-be70-ac1a3b7944e2">
        <updating/>
        <source>doControlEvent(_control: Control) updating;

// Created by cnwdvb1 on 31 July 2007
/* This method is called from the multiSelectGroupBoxs when events happen */

vars

begin
	
	// If we are dealing with buttons from from areas.
	if _control = self.grpAreasCovered1.myAddAllBtn or
	_control = self.grpAreasCovered1.myAddSelectedBtn or
	_control = self.grpAreasCovered1.myRemoveAllBtn or 
	_control = self.grpAreasCovered1.myRemoveSelectedBtn then
		self.showMultiSelectForm(self.grpAreasCovered1, null, true, false);
		return;
	endif;
	
	// If we are dealing with buttons from to areas.
	if _control = self.grpAreasCovered2.myAddAllBtn or
	_control = self.grpAreasCovered2.myAddSelectedBtn or
	_control = self.grpAreasCovered2.myRemoveAllBtn or 
	_control = self.grpAreasCovered2.myRemoveSelectedBtn then
		self.showMultiSelectForm(self.grpAreasCovered2, null, false, false);
		return;
	endif;


end;</source>
        <Parameter name="_control" type="Control"/>
    </JadeMethod>
    <JadeMethod name="doDelete" id="810ff774-658e-43f8-942c-d32903065d4e">
        <updating/>
        <source>doDelete(): Boolean updating;
// ---------------------------------------------------------------------------
// Created:		October 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

	result			: Boolean;
	theResult : Integer;
	
begin
	if not app.myCurrentUserCan(self.myTerminal,PmAdmQueue_createMaint) then
		return false;
	endif;	

	self.tblMain.clearValues();
	
	//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxDA.trxDeleteQueue(self.myCurrentObject.CM_RadioTelemetryQueue,app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			break;
		else
			theResult := app.showErrorWarningDialog('RT Queue Maint Save Crane', app.myPassport, ErrWarnMode_Add);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		return false;
		
	endwhile;
	
	return app.myPassport.trxCompletedOK;
	
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doDisplayGroupLocations" id="534e3ecf-d561-44bf-8322-632dff2a9782">
        <updating/>
        <source>doDisplayGroupLocations(_theQueue : CM_SubQueue) updating;
// ---------------------------------------------------------------------------
// Created:		October  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	availAreas								: CM_TAByIdDict;
	ta : CM_TerminalArea;
	qType   : Integer;
begin

	self.shtFromAreas.caption := "From Terminal Areas";
	self.shtToAreas.caption := "To Terminal Areas";
	qType:=self.cmbType.getCurrentItemData();
	create availAreas transient;
	foreach ta in self.myTerminal.allTerminalAreas do
		
		
		if 	qType = QTYPE_RTG and
			ta.type &lt;&gt; TA_TYPE_RTG then
			continue;
		endif;
		if 	qType = QTYPE_RMG and
			ta.type &lt;&gt; TA_TYPE_RMG then
			continue;
		endif;
		
		if ( qType &lt;&gt; QTYPE_RTG and
			 qType &lt;&gt; QTYPE_RMG) and 
			 (ta.type = TA_TYPE_RTG or
				ta.type = TA_TYPE_RMG) then
			continue;
		endif;
		
		availAreas.add(ta);
	
	endforeach;
	
	self.grpAreasCovered1.setAvailable(availAreas, true);

	
	if _theQueue &lt;&gt; null then
		self.grpAreasCovered1.setSelected(_theQueue.allMoveFromTAMasters);
		self.showMultiSelectForm(self.grpAreasCovered1, _theQueue, true, true);
	endif;
	
	// ###########################
	// AREA TWO
	self.grpAreasCovered2.setAvailable(availAreas, true);
	
	if _theQueue &lt;&gt; null then
		self.grpAreasCovered2.setSelected(_theQueue.allMoveToTAMasters);
		self.showMultiSelectForm(self.grpAreasCovered2, _theQueue, false, true);
	endif;

epilog
	delete availAreas;
end;</source>
        <Parameter name="_theQueue" type="CM_SubQueue"/>
    </JadeMethod>
    <JadeMethod name="doDisplayMachineTypeGrps" id="d5abcf95-72f8-478c-b6b2-94701c5a72ad">
        <source>doDisplayMachineTypeGrps(_theQueue : CM_SubQueue) protected;

// Created by cnwdvb1 on 15 September 2006

vars

begin

	self.grpMachineTypeGr.setSelected(_theQueue.allAllowedMachineTypeGroups.getDisplayMachineTypeGroups(app.myRoot, self.allSelectedMachineTypeGrps));

end;</source>
        <access>protected</access>
        <Parameter name="_theQueue" type="CM_SubQueue"/>
    </JadeMethod>
    <JadeMethod name="doDisplayRTGBays" id="cd0cec0c-08c5-4128-b039-47aa49e1e75b">
        <updating/>
        <source>doDisplayRTGBays(_allRTGColumns : CM_RTGColumnByAreaIdColDict) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28 August 2008	cnwer1	Initial creation

*/

vars

	theQueue : CM_RTGSubQueue;
begin
	
	if _allRTGColumns = null then
		return;
	endif;
	

	self.grpBaysCovered.setAvailable(_allRTGColumns, true);
	
	if self.myCurrentObject &lt;&gt; null then
		if self.myCurrentObject.isKindOf(CM_RTGSubQueue) then	
			theQueue := self.myCurrentObject.CM_RTGSubQueue;
		endif;
	endif;
	
	if theQueue &lt;&gt; null then
		self.grpBaysCovered.setSelected(theQueue.allRTGColumns);
	endif;

epilog

end;</source>
        <Parameter name="_allRTGColumns" type="CM_RTGColumnByAreaIdColDict"/>
    </JadeMethod>
    <JadeMethod name="doSave" id="89715d82-d773-41cb-9014-41aef799d7f8">
        <updating/>
        <source>doSave() : Boolean updating;
// ---------------------------------------------------------------------------
// Created:		October 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 01/10/2025	jlizm1		MTN 35861 RTQueue configuration - cargo attribute criteria
// ---------------------------------------------------------------------------

vars
	proxyQueue,
	realQueue : CM_RadioTelemetryQueue;
	numItems,result		: Integer;
	breakOut		: Boolean;	
	qType : Integer;
	allTransientCriteriaObj : CMIF_Array;
begin
	if self.mode = Mode_Update then
		if self.myProxyObject = null then
			self.zDoCancel();
			app.raiseUnexpectedProgramError(class.name, method.name, 'ProxyObject is null for update');
			return false;
		endif;		
	endif;
	
	qType:=self.cmbType.getCurrentItemData;
	if qType = QTYPE_SUBQUEUE or qType = QTYPE_VOYAGEYARD  then
		self.doSaveSubQueueProxy();
	elseif qType = QTYPE_VOYAGE then
		self.doSaveVoyageQueueProxy();
	elseif qType = QTYPE_CRANE then
		self.doSaveCraneQueueProxy();
	elseif qType = QTYPE_RTGSUBQUEUE then
		self.doSaveRTGSubQueueProxy();
	elseif qType = QTYPE_RTG or
		qType = QTYPE_RMG then
		 self.doSaveRTGQueueProxy();
	elseif qType = QTYPE_WORKPOINT then
		 self.doSaveWorkPointQueueProxy();		
	endif;

	create allTransientCriteriaObj transient;
	self.getCriteriaAllCMIF( allTransientCriteriaObj );
	
	proxyQueue:=self.myProxyObject.CM_RadioTelemetryQueue;
	while true do
		if self.mode = self.Mode_Add then		
			app.myTrxCA.trxCreateRTQueue(proxyQueue, realQueue, allTransientCriteriaObj, app.myPassport);
		else
			app.myTrxUA.trxUpdateRTQueue(proxyQueue, allTransientCriteriaObj,  app.myPassport);	
		endif;
		if app.myPassport.trxCompletedOK then
			if realQueue &lt;&gt; null then				
				self.addObjectToTable(realQueue, numItems, breakOut);
				self.myCurrentObject := realQueue;
			endif;
		else
		
			result :=	app.showErrorWarningDialog(app.getErrorString(RadioTelemetryQueueMaintenance), app.myPassport, ErrWarnMode_Add);
			if app.myPassport.noErrors and result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;	
			return false;
		endif;
		break;
	endwhile;

	
	
	return true;

epilog
	self.myDataClass := CM_SubQueue;
	if allTransientCriteriaObj &lt;&gt; null then
		allTransientCriteriaObj.purge;
		delete allTransientCriteriaObj;
	endif;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
