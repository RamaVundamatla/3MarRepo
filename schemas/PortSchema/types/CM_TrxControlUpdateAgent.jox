    <JadeMethod name="trxSendMachineMessage" id="46df869c-6a83-45ce-8903-3799d8c3b8d5">
        <updating/>
        <source>trxSendMachineMessage(_machines : CM_MachineByIdDict input; 
						_message : String;
						_passport : CM_Passport input) updating;
/*

Date		Who		Reason
15 June 2017	cnwer1	Initial creation TFS 4620

*/

vars
	machine	: CM_Machine; 
begin
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);
	
	app.setContinueCMExceptions(false);

	if _message = null then
		return;
	endif;
	
	if _machines = null or _machines.isEmpty then
		return;
	endif;
	
	beginTransaction;
	
	foreach machine in _machines discreteLock do	
		machine.sendBroadcastMessage(_message, false);
		
		if machine.loggedOn then
			machine.addInfoToHistory(CM_MachineInfoHistory.InfoType_ControlMessage,null,null,_message);
		endif;
	endforeach;	
	
epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_machines" type="CM_MachineByIdDict" usage="input"/>
        <Parameter name="_message" type="String"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
