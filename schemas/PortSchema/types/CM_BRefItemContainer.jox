    <JadeMethod name="getVentilationUnitDesc" id="a42ec66c-740a-4583-a0f3-b5a15b7688c1">
        <source>getVentilationUnitDesc(): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
23 November 2009	cnwndl1	Initial creation

*/

vars

begin

	if self.getVentilationUnits = Metres3perHour then
		return Metres3perHourDesc.asStringJMT;
	elseif self.getVentilationUnits = Feet3perHour then
		return Feet3perHourDesc.asStringJMT;
	endif;
	
	return null;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
