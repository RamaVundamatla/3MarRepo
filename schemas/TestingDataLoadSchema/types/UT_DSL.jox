    <JadeMethod name="updateCargoType" id="17d50621-02a9-4c42-9af0-c774e2f28d01">
        <source>updateCargoType(_cargoType : CM_CargoType);

/*

Purpose:		Update Cargo Type

Date			Who		Reason
21/05/2015		cnwmh5	Initial creation
07/03/2019		jlgdap1	TFS 41570 PNL No PIN for Cargo Type
//18 May 2022   navnk20 	ChangeRequest 53504: EUP - Cargo Uniqueness - PortSchema
//10/08/2022    navds20		ChangeRequest 54219: EUP - Cargo Group to be mandatory
//11/07/2023 navmv20 CR 58244 Task 58245: UI - Multiple Operators
*/

vars

	pxyCargoType			: CM_CargoType;
	pxyDraw					: CM_DrawingAttribute;
	
	selectedDamagePos		: CM_ObjectSet;
	allDamageCodes 			: CM_ObjectSet;
	ignoreWarnings 			: Boolean;
	allowAutoWeightCalc 	: Boolean;
	useTareCargoWeight 		: Boolean;
	allowDuplicates 		: Boolean;
	autoTareCargoWeightCalc : Boolean;			//navra1 - TFS 63624 - 15th Apr 2024
	
begin

	self.assertNotNull(_cargoType);
	
	create pxyDraw transient;
	
	create selectedDamagePos transient;
	_cargoType.allDamagePositions.copy(selectedDamagePos);
	
	if self.opts.includesKey("DamagePosition") then
		self.opts.obj("DamagePosition").CM_ObjectSet.copy(selectedDamagePos);	
	endif;
		
	
	if self.opts.includesKey("RemoveDamagePos")then
		selectedDamagePos.remove(self.opts.obj("RemoveDamagePos"));
	endif;
		
	create allDamageCodes transient;				// 07/04/2016	cnwmk3
	if self.opts.includesKey("DamageCodes") then
		self.opts.obj("DamageCodes").CM_ObjectSet.copy(allDamageCodes);	
	else
	_cargoType.allDamageDefinitionCodes.copy(allDamageCodes);
	endif;
	
	if self.opts.includesKey("RemoveDamageCode")then
		allDamageCodes.remove(self.opts.obj("RemoveDamageCode"));
	endif;
	
		if self.opts.includesKey("AllowAutoWeightCalc") then
		allowAutoWeightCalc := self.opts.bool("AllowAutoWeightCalc");
	else
		allowAutoWeightCalc := _cargoType.allowAutoWeightCalc;
	endif;
	
	if self.opts.includesKey("UseTareCargoWeight") then
		useTareCargoWeight := self.opts.bool("UseTareCargoWeight");
	else
		useTareCargoWeight := _cargoType.useTareCargoWeight;
	endif;
	
	//navra1 - TFS 63624 - 15th Apr 2024 - start
	if self.opts.includesKey("AutoTareCargoWeightCalc") then
		autoTareCargoWeightCalc := self.opts.bool("AutoTareCargoWeightCalc");
	else
		autoTareCargoWeightCalc := _cargoType.autoTareCargoWeightCalc;
	endif;
	//navra1 - TFS 63624 - 15th Apr 2024 - end
	
	if self.opts.includesKey("AllowDuplicates") then
		allowDuplicates := self.opts.bool("AllowDuplicates");
	else
		allowDuplicates := _cargoType.allowDuplicates;
	endif;

		
	beginLoad;
		pxyCargoType := _cargoType.pxyCreateUpdateProxy();
	endLoad;
	
	pxyCargoType.setProxy(_cargoType.id,
		_cargoType.abbreviation, 
		_cargoType.description,
		_cargoType.productType,
		_cargoType.isWeighable,
		_cargoType.isCheckMaxLift,
		_cargoType.includeInStorageProcess,
		_cargoType.showDamageCodes,
		_cargoType.isDynamicallyCreated,
		_cargoType.isShownInGateInOut,
		allowDuplicates,
		_cargoType.colour, 
		_cargoType.myDefaultHandlingType,
		_cargoType.myDefHandlingSubType,	//31 Mar 2017	NDL	TFS 3414
		_cargoType.createBOL,
		_cargoType.isSubCargoTypeRequired,
		_cargoType.isCommodityRequired,
		_cargoType.isNotAvailableForEntry,
		_cargoType.defaultCommodityCode,
		_cargoType.allCommodities,
		allDamageCodes,
		selectedDamagePos,
		_cargoType.allSealTypes,
		useTareCargoWeight,
		_cargoType.canWeightBeCertified,
		_cargoType.myTIBehaviourType,
		_cargoType.trackByMeasureType,
		_cargoType.myWeightMeasurementType,
		_cargoType.myVolumeMeasurementType,
		_cargoType.chgToStorageOnUnpack,
		_cargoType.allowAutoVolumeCalc,	//10 Jun 2016	NDL	TFS 2141
		allowAutoWeightCalc, //18 Jan 2018	NDL	TFS 36697
		_cargoType.canGeneratePIN,					// TFS 41570
		_cargoType.requiresWeighing,	//_requiresWeighing : Boolean	//05 Jul 2019	NDL	TFS 44965
		_cargoType.saveLocationActivity,
		_cargoType.useCargoGroupForUniqueness, //_cargoUniqueness : Boolean // 18 May 2022 navnk20 TFS 53508
		_cargoType.useCargoSubtypeForUniqueness,
		_cargoType.isCargoGroupRequired, //10/08/2022 navds20 TFS 54219
		_cargoType.allowMultiOperators, //11/07/2023 navmv20 CR 58244 Task 58245
		autoTareCargoWeightCalc,		//navra1 - TFS 63624 - 15th Apr 2024
		_cargoType.externalReference
		);	
	
	app.myTrxUA.trxUpdateCargoType(pxyCargoType, pxyDraw, null, app.myPassport);
	
	if self.opts.includesKey("IgnoreWarnings") then
		ignoreWarnings :=	self.opts.bool("IgnoreWarnings");		
	endif;
	
	if not ignoreWarnings then
		self.assertNoTrxErrorsOrWarnings();
	endif;

epilog

	delete pxyDraw;
	delete pxyCargoType;
	delete allDamageCodes;
	delete selectedDamagePos;

end;</source>
        <Parameter name="_cargoType" type="CM_CargoType"/>
    </JadeMethod>
