    <JadeMethod name="addHarbourRouteTemplate" id="c9daefad-afca-48cd-b8e4-23266b17a37b">
        <source>addHarbourRouteTemplate(_routeTemplateCode, _routeTemplateDesc : String; _allRegions : HMS_HarbourRegionArray) : HMS_RouteTemplate;

/*

Purpose:			

Parameters:			

Return Value:		


Date			Who		Reason
12 January 2012	cnwmh5	Initial creation

*/

vars

	pxyRouteTemplate			: HMS_RouteTemplate;
	routeTemplate				: HMS_RouteTemplate;


begin

	self.deleteHarbourRouteTemplate(_routeTemplateCode);

	create pxyRouteTemplate transient;
	pxyRouteTemplate.setProxy(_routeTemplateCode,
							  _routeTemplateDesc,
							  _allRegions,
							  app.myRoot);
							  
	app.myTrxCA.trxCreateRouteTemplate(pxyRouteTemplate, routeTemplate, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	return routeTemplate;							  

epilog

	delete pxyRouteTemplate;

end;</source>
        <Parameter name="_routeTemplateCode" type="String"/>
        <Parameter name="_routeTemplateDesc" type="String"/>
