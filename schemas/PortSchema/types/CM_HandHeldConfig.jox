epilog

end;</source>
        <Parameter name="_proxy" type="CM_HandHeldConfig"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="e0dcad83-2b87-4f44-8fe8-54e3f235add7">
        <updating/>
        <source>setForUpdate( _proxy : CM_HandHeldConfig ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 October 2016	cnwndl1	Initial creation	TFS 2850 / 2370

*/

vars

	proxyRow : EntTableRow;
	entRow : EntTableRow;
	rowHeader : EntTableRowHeader;

begin

	self.myTerminal := _proxy.myTerminal;
	self.myRoot := app.myRoot;
	
	if not self.allVisibleResultsCols.isEmpty then
		foreach entRow in self.allVisibleResultsCols do
			rowHeader := entRow.myEntTableRowHeader;
			if rowHeader &lt;&gt; null then
				delete rowHeader;
			endif;
		endforeach;
		self.allVisibleResultsCols.purge();
	endif;
	
	foreach proxyRow in _proxy.allVisibleResultsCols do
		create entRow;
		create rowHeader;
		rowHeader.setPropertyValue( "name", proxyRow.name );
		entRow.setPropertyValue( "myEntTableRowHeader", rowHeader );
		entRow.setHeading( proxyRow.getRawHeadingValue );
		entRow.setInputType( proxyRow.inputType );
		entRow.setVisible( proxyRow.visible );
		self.allVisibleResultsCols.add( entRow );
	endforeach;
	
	if not self.allVisibleSearchRows.isEmpty then
		foreach entRow in self.allVisibleSearchRows do
			rowHeader := entRow.myEntTableRowHeader;
			if rowHeader &lt;&gt; null then
				delete rowHeader;
			endif;
		endforeach;
		self.allVisibleSearchRows.purge();
	endif;
	
	foreach proxyRow in _proxy.allVisibleSearchRows do
		create entRow;
		create rowHeader;
		rowHeader.setPropertyValue( "name", proxyRow.name );
		entRow.setPropertyValue( "myEntTableRowHeader", rowHeader );
		entRow.setHeading( proxyRow.getRawHeadingValue );
		entRow.setInputType( proxyRow.inputType );
		entRow.setVisible( proxyRow.visible );
		self.allVisibleSearchRows.add( entRow );
	endforeach;
	
	//07 Dec 2016	NDL	TFS 3008 / 2370
	if not self.allVisibleViewRows.isEmpty then
		foreach entRow in self.allVisibleViewRows do
			rowHeader := entRow.myEntTableRowHeader;
			if rowHeader &lt;&gt; null then
				delete rowHeader;
			endif;
		endforeach;
		self.allVisibleViewRows.purge();
	endif;
	
	foreach proxyRow in _proxy.allVisibleViewRows do
		create entRow;
		create rowHeader;
		rowHeader.setPropertyValue( "name", proxyRow.name );
		entRow.setPropertyValue( "myEntTableRowHeader", rowHeader );
		entRow.setHeading( proxyRow.getRawHeadingValue );
		entRow.setInputType( proxyRow.inputType );
		entRow.setVisible( proxyRow.visible );
		self.allVisibleViewRows.add( entRow );
	endforeach;

epilog

end;</source>
        <Parameter name="_proxy" type="CM_HandHeldConfig"/>
    </JadeMethod>
    <JadeMethod name="setHandHeldTermConfigs" id="149218f2-782b-4919-9db3-bdb1338d55db">
        <source>setHandHeldTermConfigs( _cmif : CMIF_ConfigTerminal input; _doAuditing : Boolean );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 October 2016	cnwndl1	Initial creation	TFS 2850 / 2370
//28 Nov 2016	cnwrs1	TFS 2866 use new HH config matchFindCargoConsignee
*/

vars

	term : CM_Terminal;
	termAudit : CM_UpdateTransactionAuditAgent;

begin

	term := self.myTerminal;
	
	if _doAuditing then
		create termAudit transient;
		termAudit.audUpdateGeneric(term, true);
	endif;
	
	term.setConfig(AllowLoadMoreCargo, _cmif.allowLoadMoreCargo);
	term.setConfig(AllowPackMoreCargo, _cmif.allowPackMoreCargo);
	term.setConfig(AllowUnloadMoreCargo, _cmif.allowUnloadMoreCargo);
	term.setConfig(AllowUnpackMoreCargo, _cmif.allowUnpackMoreCargo);
	term.setConfig(HhDelayTypeGroup, _cmif.hhDelayTypeGroup);
	term.setConfig(HhLanderGroundingOpt, _cmif.hhLanderGroundingOpt);
	term.setConfig(HhHideTitleBarButtons, _cmif.hhHideTitleBarButtons); // TFS 3809
	term.setConfig(HhErrorBeeps, _cmif.hhErrorBeeps); // 17 May 2017	NDL	TFS 4460
	term.setConfig(HhIncludeHazDet, _cmif.hhIncludeHazDet); // 30 May 2017	NDL	TFS 4587
	term.setConfig(HhMoveConfirmation, _cmif.hhMoveConfirmation);
	term.setConfig(HhTruckLoadConfComplete, _cmif.hhTruckLoadConfComplete); // 17/05/2017 cnwma1 TFS #3933
	term.setConfig(HhMoveHideNonSplit, _cmif.hhMoveHideNonSplit);	//02 Mar 2017	NDL	TFS 3298
	term.setConfig(HhSpreadButtons, _cmif.hhSpreadButtons);	//16 Feb 2017	NDL	TFS 3387 / 3006
	term.setConfig(HhTaskUseFullDesc, _cmif.hhTaskUseFullDesc);
	term.setConfig(HhTruckLoadBolId, _cmif.hhTruckLoadBolId);	//17 Jul 2017	NDL	TFS 5408
	term.setConfig(HhTruckLoadScan, _cmif.hhTruckLoadScan);
	term.setConfig(UseAltSelectRulesTL, _cmif.useAltSelectRulesTL); //11 May 2017	NDL	TFS 4016
	term.setConfig(RailHHAlwaysCargoFullID, _cmif.railHHAlwaysCargoFullID);
	term.setConfig(RailHHCargoMustPrenote, _cmif.railHHCargoMustPrenote);
	term.setConfig(RailHHAlwaysWagonFullID, _cmif.railHHAlwaysWagonFullID);
	term.setConfig(RailHHWagonUseReversedID, _cmif.railHHWagonUseReversedID);
	term.setConfig(RailHHWarnPrenoteHazDiffer, _cmif.railHHWarnPrenoteHazDiffer);
	term.setConfig(RailHHToDoTask, _cmif.railHHToDoTask);
	term.setConfig(DischargeHHLanderOption, _cmif.dischargeHHLanderOption);
	term.setConfig(IgnoreHHFindCargoConsignee, _cmif.ignoreHHFindCargoConsignee);
	term.setConfig(HhUnPackQtyPreFill, _cmif.hhUnPackQtyPreFill);	//10 Feb 2017	NDL	TFS 3002
	term.setConfig(HhShowUnplanOptions, _cmif.hhShowUnplanOptions);
	term.setConfig(AllowMobileRoadExit, _cmif.allowMobileRoadExit); //08/09/2017 TFS#6864 cnwma1
	term.setConfig(UseRelReqAnyVoyLoad, _cmif.useRelReqAnyVoyLoad);	//16 Jul 2018	NDL	TFS 38679
	term.setConfig(HhTUnloadEdit, _cmif.hhTUnloadEdit);	//21 Aug 2018	NDL	TFS 39769
	term.setConfig(HhTruckLoadByLocn, _cmif.hhTruckLoadByLocn);	//05 Sep 2018	NDL	TFS 39950
	term.setConfig(HhAllowLoadUnloaded, _cmif.hhAllowLoadUnloaded);	//25 Oct 2018	NDL	TFS 41240
	
	if app.myPassport.noErrors and _doAuditing then
		termAudit.audUpdateGeneric(term, false);
	endif;
	
epilog

	delete termAudit;

end;</source>
        <Parameter name="_cmif" type="CMIF_ConfigTerminal" usage="input"/>
        <Parameter name="_doAuditing" type="Boolean"/>
    </JadeMethod>
