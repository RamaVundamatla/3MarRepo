    <JadeMethod name="createProperties" id="7b20217d-d68a-44d2-a438-4974f5e97297">
        <source>createProperties();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 November 2019	jlgndl1	Initial creation
03 Jun 2020 cnwma1  ChangeRequest 49400: ASPA - Invoice Enhancements for Barges
*/

vars
	qProp		: CM_QueryProperty;
begin
	inheritMethod();		// 'Terminal', myTerminal
	
	create qProp as CM_QDateProperty persistent;
	qProp.set('Transaction Date', CM_BOLTransaction::dateTime.name, self.className);
	qProp.setPerformanceRating( CM_QueryProperty.CollKey );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(qProp);
	
	create qProp as CM_QRefTransactionTypeMethod persistent;
	qProp.set('Transaction Type', CM_TITransaction::getTransactionType.name, self.className);
	qProp.setPerformanceRating( CM_QueryProperty.CollKey );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	qProp.CM_QRefTransactionTypeMethod.setType( TRANS_TYPE_GROUP_BOL );
	self.allQueryProperties.add(qProp);
	
	create qProp as CM_QRefDebtorMethod persistent;
	qProp.set('Debtor', CM_BOLTransaction::getDebtorForSelector.name, self.className);
	qProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(qProp);
	
	create qProp as CM_QStringMethod persistent;
	qProp.set('Invoice Number', CM_BOLTransaction::getInvoiceNumber.name, self.className);
	qProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(qProp);

	create qProp as CM_QBooleanProperty persistent;
	qProp.set('Is No Charge', CM_BOLTransaction::noCharge.name, self.className);
	qProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(qProp);
	
	create qProp as CM_QStrUserMethod persistent;
	qProp.set('User Code', CM_BOLTransaction::getUserId.name, self.className);
	qProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(qProp);
	
	create qProp as CM_QRefVoyageMethod persistent;
	qProp.set('Voyage', CM_BOLTransaction::getMyVoyage.name, self.className);
	qProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(qProp);
	
	create qProp as CM_QBooleanMethod persistent;
	qProp.set('Charged', CM_BOLTransaction::isCharged.name, self.className);
	qProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(qProp);
	
	create qProp as CM_QStringMethod persistent;												//03/06/2020 cnwma1 Tfs #49400
	qProp.set('Voyage Group Code', CM_BOLTransaction::getVoyageGroupCode.name, self.className);
	qProp.setPerformanceRating( CM_QueryProperty.Simple );
	self.allQueryProperties.add(qProp);

end;</source>
    </JadeMethod>
    <JadeMethod name="getSelectorVisibleColumns" id="8f8f9075-9ced-4c8f-afca-6c04d3951b13">
        <source>getSelectorVisibleColumns(_sa: StringArray input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 November 2019	jlgndl1	Initial creation	TFS 47100

*/

vars
	qProp	: CM_QueryProperty;
begin
	_sa.clear();

	qProp := self.allQueryProperties[CM_BOLTransaction::dateTime.name];
	if qProp &lt;&gt; null then
		_sa.add(qProp.propertyName);
	endif;
	qProp := self.allQueryProperties[CM_BOLTransaction::getDebtorForSelector.name];
	if qProp &lt;&gt; null then
		_sa.add(qProp.propertyName);
	endif;
	qProp := self.allQueryProperties[CM_BOLTransaction::getInvoiceNumber.name];
	if qProp &lt;&gt; null then
		_sa.add(qProp.propertyName);
	endif;
	qProp := self.allQueryProperties[CM_BOLTransaction::userId.name];
	if qProp &lt;&gt; null then
		_sa.add(qProp.propertyName);
	endif;
	qProp := self.allQueryProperties[CM_BOLTransaction::noCharge.name];
	if qProp &lt;&gt; null then
		_sa.add(qProp.propertyName);
	endif;
	qProp := self.allQueryProperties[CM_BOLTransaction::getMyVoyage.name];
	if qProp &lt;&gt; null then
		_sa.add(qProp.propertyName);
	endif;

end;
</source>
        <Parameter name="_sa" type="StringArray" usage="input"/>
    </JadeMethod>
</Class>
