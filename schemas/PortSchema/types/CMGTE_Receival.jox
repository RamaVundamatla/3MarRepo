    <JadeMethod name="getWeightTotalDisplay" id="7c61a43c-66bb-47f9-b9fc-3dfd7181f27e">
        <source>getWeightTotalDisplay() : String;
/*

Date		Who		Reason
25 September 2014	cnwer1	Initial creation PAR 34935

*/

vars
	ct : CM_CargoType;

	measure			: CM_MeasurementType;	
begin
	ct := self.getMyCargoType;
	if ct = null or not ct.isBulkByWeight then
		if ct &lt;&gt; null then
			measure:=ct.myWeightMeasurementType;
		endif;
		if measure = null then
			measure:=app.getDefaultMeasurementForType(Type_Weight);
		endif;
	
		return app.convertMeasurementForDisplay(measure.shortName, self.weightTotal) &amp; Space &amp; measure.shortName;
	endif;
	
    return ct.getBulkTrackByDisplayForWeight(self.weightTotal,self.getDensity,true);
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
