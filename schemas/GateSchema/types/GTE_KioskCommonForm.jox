    <JadeMethod name="doKeyboardInput" id="4a4a7108-1390-4184-93b9-b86bd246962e">
        <updating/>
        <source>doKeyboardInput(_input:String):Boolean updating, protected;
// --------------------------------------------------------------------------------
// Created:		29 June 2006 by cnwdad1
//
// Purpose:		Reimplement this abstraction method on subclassed forms, with the
//				appropriate behaviour.
//
// Parameters:	_input - The keyboard input value.
//
// Returns:		True if the keystroke was actioned, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if _input = self.KEY_BACKSP then
		self.doBackspace();
	elseif _input = self.KEY_CLEAR then
		self.doClear();
	elseif _input = self.KEY_ENTER then
		self.doEnter();
	else
		return false;
	endif;
	
	return true;
end;</source>
        <access>protected</access>
        <Parameter name="_input" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
