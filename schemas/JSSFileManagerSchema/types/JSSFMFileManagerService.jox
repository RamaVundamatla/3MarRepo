    <JadeMethod name="addBaseDriveName" id="f75b8baa-b607-4587-b930-789f28ad203d">
        <source>addBaseDriveName(pDriveName:String; pNodeOptions:Integer);
// --------------------------------------------------------------------------------
// Created:		11 July 2002 by cnwdad1
//
// Purpose:		Specifies a disk drive name to restrict access to that drive on the
//				requested Server node.
//
// Parameters:	pDriveName - If a drive name is specified, then access will only be
//					allowed to that disk drive.  If no drive names are specified,
//					then access will be unrestricted.
//				pNodeOptions - Specifies the server source node, i.e. AppServer
//					or DB Server.  This must be a source node constant, not a
//					target node constant. Refer to the class constants on this
//					interface class.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	driveName	: String;
	
begin
	driveName	:=	pDriveName.trimBlanks().toUpper();
	
	if driveName = null then
		return;
	elseif driveName.length &gt; 1 then
		driveName	:=	driveName[1];
	endif;
	
	if self.myFileAgent.isValidDrive(driveName, pNodeOptions) then
	
		if pNodeOptions = JSSFMFileManagerService.NODE_SOURCE_DBSERVER then
			self.allDriveNamesDbServer.add(driveName);
			
		elseif pNodeOptions = JSSFMFileManagerService.NODE_SOURCE_APPSERVER then
			self.allDriveNamesAppServer.add(driveName);
			
		endif;
		
	else
		self.myServiceManager.raiseJSSException2(JSS_EX_00011, "Invalid Drive", driveName);
	endif;
end;</source>
        <Parameter name="pDriveName" type="String"/>
        <Parameter name="pNodeOptions" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="addBasePathName" id="243196c8-3cb0-475f-b197-276fc26a2f02">
        <source>addBasePathName(pPathName:String; pNodeOptions:Integer);
// --------------------------------------------------------------------------------
// Created:		11 July 2002 by cnwdad1
//
// Purpose:		Specifies a disk directory name to restrict access to that directory
//				on the requested Server node.
//
// Parameters:	pPathName - If a base directory name is specified, then access will
//					only be allowed to that directory, and its sub-nodes on the
//					Application Server node.
//				pNodeOptions - Specifies the server source node, i.e. AppServer
//					or DB Server.  This must be a source node constant, not a
//					target node constant. Refer to the class constants on this
//					interface class.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	pathName	: String;
	
begin
	pathName	:=	pPathName.trimBlanks().toUpper();
	
	if pathName = null then
		return;
	else
		if pathName[pathName.length] &lt;&gt; JSS_SEPARATOR_WIN then
			pathName	:=	pathName &amp; JSS_SEPARATOR_WIN;
		endif;
	endif;
	
	if self.myFileAgent.isValidDirectory(pathName, pNodeOptions) then
	
		if pNodeOptions = JSSFMFileManagerService.NODE_SOURCE_DBSERVER then
			self.allPathNamesDbServer.add(pathName);
			
		elseif pNodeOptions = JSSFMFileManagerService.NODE_SOURCE_APPSERVER then
			self.allPathNamesAppServer.add(pathName);
			
		endif;
	else
		self.myServiceManager.raiseJSSException2(JSS_EX_00011, "Invalid Directory", pathName);
	endif;
end;</source>
        <Parameter name="pPathName" type="String"/>
        <Parameter name="pNodeOptions" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="clearBaseDriveNames" id="40a27264-9dfc-4ca3-a78e-9cdb4e0ab614">
        <source>clearBaseDriveNames(pNodeOptions:Integer);
// --------------------------------------------------------------------------------
// Created:		12 July 2002 by cnwdad1
//
// Purpose:		Clears all specified disk drive names that restrict access to those
//				drives on the requested Server node.  When no names are specified,
//				then access is unrestricted.
//
// Parameters:	pNodeOptions - Specifies the server source node, i.e. AppServer
//					or DB Server.  This must be a source node constant, not a
//					target node constant. Refer to the class constants on this
//					interface class.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if pNodeOptions = JSSFMFileManagerService.NODE_SOURCE_DBSERVER then
		self.allDriveNamesDbServer.purge();
	elseif pNodeOptions = JSSFMFileManagerService.NODE_SOURCE_APPSERVER then
		self.allDriveNamesAppServer.purge();
	endif;
end;</source>
        <Parameter name="pNodeOptions" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="clearBasePathNames" id="a3144983-cafb-4936-824f-2555f622c349">
        <source>clearBasePathNames(pNodeOptions:Integer);
// --------------------------------------------------------------------------------
// Created:		12 July 2002 by cnwdad1
//
// Purpose:		Clears all specified disk directory names that restrict access to
//				those directories on the requested Server node.  When no names
//				are specified, then access is unrestricted.
//
// Parameters:	pNodeOptions - Specifies the server source node, i.e. AppServer
//					or DB Server.  This must be a source node constant, not a
//					target node constant. Refer to the class constants on this
//					interface class.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if pNodeOptions = JSSFMFileManagerService.NODE_SOURCE_DBSERVER then
		self.allPathNamesDbServer.purge();
	elseif pNodeOptions = JSSFMFileManagerService.NODE_SOURCE_APPSERVER then
		self.allPathNamesAppServer.purge();
	endif;
end;</source>
        <Parameter name="pNodeOptions" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="copyDirectory" id="409d875c-c6ca-49e0-b331-2d91e80867fd">
        <source>copyDirectory(pSourcePath:String; pTargetPath:String; pNodeOptions:Integer):Boolean;
// --------------------------------------------------------------------------------
// Created:		10 July 2002 by cnwdad1
//
// Purpose:		Copies the requested directory into the specified path.  Note that
//				all of the directory's child nodes will also be copied.
//
//				*********************************************************************
//				* You must call the setUnixFlags method before calling this method. *
//				*********************************************************************
//
// Parameters:	pSourcePath - The pathname of the source directory to be copied.
//				pTargetPath - The pathname of the directory's destination.
//				pNodeOptions - A combination of the source and target nodes, i.e.
//					Client, AppServer or DB Server.  Refer to the class constants
//					on this interface class.  Note that the source and target
//					can be the same node.  For example:
//
//					a) NODE_SOURCE_CLIENT + NODE_TARGET_DBSERVER = the file source
//						node is the workstation client, and the file target node
//						is the Database Server machine.
//
//					b) NODE_SOURCE_CLIENT + NODE_TARGET_CLIENT = the file source
//						node is the workstation client, and the file target node
//						is the workstation client (i.e. the source and target are
//						the same node).
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return self.myFileAgent.copyDirectory(pSourcePath, pTargetPath, pNodeOptions);
end;</source>
        <Parameter name="pSourcePath" type="String"/>
        <Parameter name="pTargetPath" type="String"/>
        <Parameter name="pNodeOptions" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="copyDirectoryBackground" id="bc789b16-171a-483a-8fb0-287d72b9e28b">
        <source>copyDirectoryBackground(pSourcePath:String; pTargetPath:String; pNodeOptions:Integer);
// --------------------------------------------------------------------------------
// Created:		10 July 2002 by cnwdad1
//
// Purpose:		Copies the requested directory into the specified path.  Note that
//				all of the directory's child nodes will also be copied.
//
//				*********************************************************************
//				* You must call the setUnixFlags method before calling this method. *
//				*********************************************************************
//
// Parameters:	pSourcePath - The pathname of the source directory to be copied.
//				pTargetPath - The pathname of the directory's destination.
//				pNodeOptions - This parameter is not used, but is reserved for
//					future use.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theTA			: JSSFMTransactionAgent;
	theCopy			: JSSFMBackgroundCopy;
	thePasteFile	: JSSFMPasteFile;
	theRoot			: JSSFMRoot;
	
begin
	theRoot	:=	JSSFMRoot.firstInstance();
	theTA	:=	self.getTA();
	
	theTA.trxCreateBackgroundCopy(	app.computerName,
									app.dbServerComputerName(),
									app.dbServerComputerName(),
									theRoot,
									theCopy);
	
	theTA.trxCreatePasteFile(	pSourcePath,
								pTargetPath,
								(self.NODE_SOURCE_DBSERVER + self.NODE_TARGET_DBSERVER),
								true,
								false,
								self.myFileAgent.isSourceUnix,
								self.myFileAgent.isTargetUnix,
								theCopy,
								thePasteFile);
	
	self.myFileAgent.startBackgroundCopy(theCopy);
end;</source>
        <Parameter name="pSourcePath" type="String"/>
        <Parameter name="pTargetPath" type="String"/>
        <Parameter name="pNodeOptions" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="copyFile" id="9e76efc5-53bc-4f25-96f9-6439aa11628b">
        <source>copyFile(pSourcePath:String; pTargetPath:String; pNodeOptions:Integer):Boolean;
// --------------------------------------------------------------------------------
// Created:		10 July 2002 by cnwdad1
//
// Purpose:		Copies the requested file into the specified path.
//
//				*********************************************************************
//				* You must call the setUnixFlags method before calling this method. *
//				*********************************************************************
//
// Parameters:	pSourcePath - The pathname of the source file to be copied.
//				pTargetPath - The pathname of the file's destination.
//				pNodeOptions - A combination of the source and target nodes, i.e.
//					Client, AppServer or DB Server.  Refer to the class constants
//					on this interface class.  Note that the source and target
//					can be the same node.  For example:
//
//					a) NODE_SOURCE_CLIENT + NODE_TARGET_DBSERVER = the file source
//						node is the workstation client, and the file target node
//						is the Database Server machine.
//
//					b) NODE_SOURCE_CLIENT + NODE_TARGET_CLIENT = the file source
//						node is the workstation client, and the file target node
//						is the workstation client (i.e. the source and target are
//						the same node).
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return self.myFileAgent.copyFile(pSourcePath, pTargetPath, pNodeOptions);
end;</source>
        <Parameter name="pSourcePath" type="String"/>
        <Parameter name="pTargetPath" type="String"/>
        <Parameter name="pNodeOptions" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="copyFileBackground" id="d1ea06ec-824c-4056-b203-98a7dd689808">
        <source>copyFileBackground(pSourcePath:String; pTargetPath:String; pNodeOptions:Integer);
// --------------------------------------------------------------------------------
// Created:		10 July 2002 by cnwdad1
//
// Purpose:		Copies the requested file into the specified path.
//
//				*********************************************************************
//				* You must call the setUnixFlags method before calling this method. *
//				*********************************************************************
//
// Parameters:	pSourcePath - The pathname of the source file to be copied.
//				pTargetPath - The pathname of the file's destination.
//				pNodeOptions - This parameter is not used, but is reserved for
//					future use.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theTA			: JSSFMTransactionAgent;
	theCopy			: JSSFMBackgroundCopy;
	thePasteFile	: JSSFMPasteFile;
	theRoot			: JSSFMRoot;
	
begin
	theRoot	:=	JSSFMRoot.firstInstance();
	theTA	:=	self.getTA();
	
	theTA.trxCreateBackgroundCopy(	app.computerName,
									app.dbServerComputerName(),
									app.dbServerComputerName(),
									theRoot,
									theCopy);
	
	theTA.trxCreatePasteFile(	pSourcePath,
								pTargetPath,
								(self.NODE_SOURCE_DBSERVER + self.NODE_TARGET_DBSERVER),
								false,
								false,
								self.myFileAgent.isSourceUnix,
								self.myFileAgent.isTargetUnix,
								theCopy,
								thePasteFile);
	
	self.myFileAgent.startBackgroundCopy(theCopy);
end;</source>
        <Parameter name="pSourcePath" type="String"/>
        <Parameter name="pTargetPath" type="String"/>
        <Parameter name="pNodeOptions" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="create" id="247313f0-f59f-4b04-a57b-c6438246186a">
        <updating/>
        <source>create() updating;
// --------------------------------------------------------------------------------
// Created:		04 July 2002 by cnwdad2
//
// Purpose:		Constructor to instantiate the File Manager schema's service object
//				class.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theRoot		: JSSFMRoot;
	
begin
	create self.myFileAgent;
	self.isAllowAppServer	:=	true;
	self.fileChunkSize		:=	JSSFMFileAgent.COPY_CHUNK_SIZE;
	self.myFileAgent.setServiceObject(self);
	self.myFileAgent.setServiceManager(self.getManager);
	
	// We need to ensure that the singleton Root object exists because the background
	// copy feature uses it.
	 
	theRoot	:=	JSSFMRoot.firstInstance();
	
	if theRoot = null then
		beginTransaction;
		create theRoot;
		commitTransaction;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="createDirectory" id="e188d667-44ba-4016-a7cc-39df1c54f6c9">
        <source>createDirectory(pDirectoryName:String; pNodeOptions:Integer):Boolean;
// --------------------------------------------------------------------------------
// Created:		10 July 2002 by cnwdad1
//
// Purpose:		Creates a new directory of the specified name.
//
// Parameters:	pDirectoryName - The pathname of the new directory.
//				pNodeOptions - Specifies destination node, i.e. Client, AppServer
//					or DB Server.  This must be a target node constant, not a
//					source node constant. Refer to the class constants on this
//					interface class.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return self.myFileAgent.createDirectory(pDirectoryName, pNodeOptions);
end;</source>
        <Parameter name="pDirectoryName" type="String"/>
        <Parameter name="pNodeOptions" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="delete" id="30db420b-51a1-4a6f-88b6-637cac919799">
        <updating/>
        <source>delete() updating;
// --------------------------------------------------------------------------------
// Created:		04 July 2002 by cnwdad2
//
// Purpose:		Destructor to delete the File Manager schema's service object.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	delete self.myFileAgent;
	delete self.myFormInterface;
	
	if self.getManager().myFileBrowserForm &lt;&gt; null then
		self.getManager().myFileBrowserForm.setFormInterface(null);
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="deleteDirectory" id="a88fa16c-7aad-4aec-a82f-e1e426d6a5b1">
        <source>deleteDirectory(pDirectoryName:String; pNodeOptions:Integer):Boolean;
// --------------------------------------------------------------------------------
// Created:		10 July 2002 by cnwdad1
//
// Purpose:		Deletes the specified directory, including all of its contents.
//
// Parameters:	pDirectoryName - The pathname of the directory to delete.
//				pNodeOptions - Specifies source node, i.e. Client, AppServer
//					or DB Server.  This must be a source node constant, not a
//					target node constant. Refer to the class constants on this
//					interface class.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return self.myFileAgent.deleteDirectory(pDirectoryName, pNodeOptions);
end;</source>
        <Parameter name="pDirectoryName" type="String"/>
        <Parameter name="pNodeOptions" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="deleteFile" id="df32b648-e3f7-4d57-8b71-eeb9959b9fed">
        <source>deleteFile(pFileName:String; pNodeOptions:Integer):Boolean;
// --------------------------------------------------------------------------------
// Created:		10 July 2002 by cnwdad1
//
