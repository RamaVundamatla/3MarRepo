    <JadeMethod name="translateForm" id="cc6bfc19-efea-4798-b7dd-b5a1f46cc158">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 11 April 2022 11:49:40.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0024629, locale);
	btnClose.translateCaption(Xlat_0024630, locale);
	btnCopyAll.translateCaption(Xlat_0024631, locale);
	btnSave.translateCaption(Xlat_0024632, locale);
	lblName.translateCaption(Xlat_0024633, locale);
	lblVoyage.translateCaption(Xlat_0024634, locale);
	lblVoyageOperators.translateCaption(Xlat_0024635, locale);
	mnuContextTable.translateCaption(Xlat_0024636, locale);
	mnuInspectObject.translateCaption(Xlat_0024637, locale);
end;</source>
    </JadeMethod>
    <JadeMethod name="validateCustomsManifest" id="4e1ee1b7-aa26-418e-a9be-6c611d914608">
        <source>validateCustomsManifest(_customsManifest : String) : Boolean;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 11 April 2022
TFS#		: 53181
Function	:

*** Changes ***
Date			Name		TFS#		Description
28/06/2022      navds20 TFS 53760 MTN - DuplicateItem not Translatable
****************************************************/

vars	
	selectedVoyage 	: CM_Voyage;
	terminal 		: CM_Terminal;
	terminalColl 	: CM_TerminalByCodeDict;
	voyage 			: CM_Voyage;		
begin
	if (_customsManifest = "") then
		return true;
	endif;
	
	selectedVoyage := self.cmbVoyage.listObject.CM_Voyage;	
	
	create terminalColl transient;
	app.getMyUser.getTerminals(terminalColl);	
	
	foreach terminal in terminalColl do		
		
		foreach voyage in terminal.allVoyagesByCode where voyage.code &lt;&gt; selectedVoyage.code and voyage.customsManifest = _customsManifest do
			//app.raiseCMException2(DuplicateItem, app.getErrorString(Customs_manifest_code) &amp; " " &amp; _customsManifest, app.getErrorString(Terminal) &amp; " "  &amp; terminal.code &amp; " " &amp; app.getErrorString(Voyage) &amp; " "  &amp; voyage.code, ETRow_Manifest, null); //28/06/2022 navds20 TFS 53760
			//Customs Manifest Code %1 already exists for Terminal %2 Voyage %3 : Custo_manif_code_alrea_exist_t
			app.raiseCMException3(Custo_manif_code_alrea_exist_t,  _customsManifest,  terminal.code , voyage.code, ETRow_Manifest, null);  //28/06/2022 navds20 TFS 53760
			return false;
			break;
		endforeach;
	endforeach;
	return true;
epilog
	delete terminalColl;
end;</source>
        <Parameter name="_customsManifest" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</GUIClass>
