vars

begin
	//be helpful and intuitive
	if self.fldInput.topSheet = self.shtParameters then
		if self.mode &lt;&gt; self.Mode_View then
			self.tblParamEnt.setFocus();
			self.tblParamEnt.moveFirst();
		endif;
	endif;

end;</source>
