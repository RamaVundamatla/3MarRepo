	ADDITIONAL_TEXT	= "//IF NO 20GP AVAILABLE PLEASE RELEASE DAIRY UNITS";
	ISOTYPE 		= '22G1';
	QUANTITY		= 10;
vars
	text	:String;
	ediFile	:CM_EDIFile;
	ediData	:CM_EDIData;
	ediTI	:CM_EDIRequestHeaderTI;
	ediItemTI : CM_EDIRequestDetailTI;
	ediRelReq : CM_EDIReleaseRequestTI;
	release	:CM_BulkRelease;
	item	:CM_ReserveSelection;
	isoType	:CM_ISOType;
	tempStr : String;
	ediItem : CM_EDITrackedItem;
begin
	// ---------------------------------------
	// delete the release if it already exists
	// ---------------------------------------
	self.deleteReleaseRequest (_releaseNo);
	
	// ---------------------------------------
	// get edi file to load
	// ---------------------------------------
	text := self.zCoparn_mtrel_addthendelete ("12", '9', _sender, _voyageCode, _vesselName, _consignorCode, _consigneeCode, _releaseNo, ADDITIONAL_TEXT, "TEXTSIN", "TEXTHAN", ISOTYPE, QUANTITY.String, _mt);

	// ---------------------------------------
	// load edi file to create EDI tracked items
	// ---------------------------------------
	ediFile := self.ediLoadFileName(text, EDIFileType_Unknown, "COPARN", "COPARN-1"&amp;method.name);
	
	self.assertNotNull(ediFile);
	
	// ---------------------------------------
	// find the release request ediData
	// ---------------------------------------
	if ediFile.ediData.isKindOf(CM_EDIDataGateDoc) or
	   ediFile.ediData.isKindOf(CM_EDIDataReleaseRequest) then
		ediData := ediFile.ediData;
	else
		ediData := ediFile.allEDIData.first;
	endif;
	
	self.assertNotNullMsg (ediData, 'No edi data for release requests');
	
	// ---------------------------------------
	// find the edi tracked item
	// ---------------------------------------
//	ediTI := ediData.allEDITrackedItems.first.CM_EDIRequestHeaderTI;
	if ediData.isKindOf(CM_EDIDataGateDoc) then
		foreach ediItem in ediData.allEDITrackedItems do
			if  ediItem.isKindOf(CM_EDIRequestHeaderTI) then
				ediTI := ediItem.CM_EDIRequestHeaderTI;
				break;
			endif;
		endforeach;
		self.assertNotNullMsg(ediTI, 'EDI tracked items not created');
		ediItemTI := self.getMatchingEDIItemTI(ediTI);
		// ---------------------------------------
		// check values on EDI TI
		// ---------------------------------------
		self.doCheckEDITiRequestMulti(ediTI, ediItemTI, "A", _releaseNo, _voyageCode, _vesselName, _operator.code, _consignorCode, _consigneeCode, ISOTYPE, ADDITIONAL_TEXT, "TEXTSIN", "TEXTHAN", QUANTITY, _ediPartyRules, null, null, false, true, false, false, false, true);
	endif;
	if ediData.isKindOf(CM_EDIDataReleaseRequest) then
		foreach ediItem in ediData.allEDITrackedItems do
			if  ediItem.isKindOf(CM_EDIReleaseRequestTI) then
				ediRelReq := ediItem.CM_EDIReleaseRequestTI;
				break;
			endif;
		endforeach;
		self.assertNotNullMsg(ediRelReq, 'EDI tracked items not created');
		// ---------------------------------------
		// check values on EDI TI
		// ---------------------------------------
		self.doCheckEDITIReleaseRequest(ediRelReq, "A", _releaseNo, _voyageCode, _vesselName,  _operator.code,_consignorCode, _consigneeCode, ISOTYPE, ADDITIONAL_TEXT, "TEXTSIN", "TEXTHAN", QUANTITY, _ediPartyRules, null, null, false, true, false, false, false, true);
	endif;
	if ediTI &lt;&gt; null then 
		// destination - LOC+8+AUMEL:139:6'
		self.assertEqualMsg (ediTI.destinationPort, "AUMEL", "Destination shoudl be AUMEL");
		// load port - LOC+9+NZPOE:139:6'
		self.assertEqualMsg (ediTI.loadPort, "NZPOE", "Load port should be NZPOE");
		// discharge port - LOC+11+NZAKL:139:6'
		self.assertEqualMsg (ediTI.dischargePort, "NZAKL", "Destination shoudl be AUSYS");
	endif;
	if ediRelReq &lt;&gt; null then 
		// destination - LOC+8+AUMEL:139:6'
		self.assertEqualMsg (ediRelReq.destinationPort, "AUMEL", "Destination shoudl be AUMEL");
		// load port - LOC+9+NZPOE:139:6'
		self.assertEqualMsg (ediRelReq.loadPort, "NZPOE", "Load port should be NZPOE");
		// discharge port - LOC+11+NZAKL:139:6'
		self.assertEqualMsg (ediRelReq.dischargePort, "NZAKL", "Destination shoudl be AUSYS");
	endif;
	// ---------------------------------------
	// do verify (all edi data)  
	// ---------------------------------------
	self.ediVerify(ediFile);
	tempStr	:= 'Verify failed' &amp; CrLf &amp; app.myPassport.getErrorsAsString;
	self.assertEqualMsg(ediData.status, CM_EDIFile.EDI_STATUS_VERIFIED, tempStr);
	
	// ---------------------------------------
	// load to DB
	// ---------------------------------------
	self.ediDBLoad(ediFile);
	tempStr	:= 'DBLoad failed' &amp; CrLf &amp; app.myPassport.getErrorsAsString;
	self.assertEqualMsg(ediData.status, CM_EDIFile.EDI_STATUS_DBLOADED, tempStr);
	
	// ---------------------------------------
	// find the release
	// ---------------------------------------
	release := self.getReleaseRequest (_releaseNo);
	
	self.assertNotNull (release);
	
	// ---------------------------------------
	// do standard checks
	// ---------------------------------------
	self.doCheckPartyRules_AddRelease (release, _ediPartyRules, false, true, false);
	
	self.assertTrueMsg (release.releaseByType, 'Release by type is not set');
	self.assertEqualMsg (release.code, _releaseNo, 'Release number is incorrect');
	self.assertEqualMsg (release.myVoyage.code, _voyageCode, 'Voyage code is incorrect');
	self.assertEqualMsg (release.myOperator, _operator, 'Operator is incorrect');
	self.assertEqualMsg (release.consignorCode, _consignorCode, 'Consignor is incorrect');
	self.assertFalseMsg (release.needsReview, 'Needs review should not be set');

	// we expect the release cargo remarks to include the addition text
	item := release.allReserveDetails.first.CM_ReserveSelection;
	
	self.assertNotNull (item);
	self.assertTrueMsg (item.remarks.pos (ADDITIONAL_TEXT, 1) &gt; 0, 'Additionl text from FTX+AAI not stored in cargo remarks');
	self.assertTrueMsg (item.remarks.pos ("TEXTSIN", 1) &gt; 0, 'Additionl text from FTX+SIN not stored in cargo remarks');
	self.assertTrueMsg (item.remarks.pos ("TEXTHAN", 1) &gt; 0, 'Additionl text from FTX+HAN not stored in cargo remarks');

	self.assertNotNullMsg (item.myISOType, 'ISO Type not set');
	self.assertEqualMsg (item.myISOType.code, ISOTYPE, 'ISO type is incorrect');
	
	// Availability grade - defaults for this file
	
	// total requested
	self.assertEqualMsg (item.totalRequested, QUANTITY, 'Total requested not set');
	
	// check ediFile collection has been updated
	self.assertTrueMsg (release.allEDIFiles.includes (ediFile), 'Update the edi files collection !!!');
	self.assertTrueMsg (release.allEDIFiles.size = 1, _releaseNo &amp; ' EDI the edi files collection should have 1 entry!!!');
	
	// now do load the file to do the delete
	// ---------------------------------------
	// get edi file to load
	// ---------------------------------------
	text := self.zCoparn_mtrel_addthendelete ("12", '1', _sender, _voyageCode, _vesselName, _consignorCode, _consigneeCode, _releaseNo, ADDITIONAL_TEXT, "TEXTSIN", "TEXTHAN", ISOTYPE, QUANTITY.String, _mt);

	// ---------------------------------------
	// load edi file to create EDI tracked items
	// ---------------------------------------
	ediFile := self.ediLoadFileName(text, EDIFileType_Unknown, "COPARN", "COPARN-2"&amp;method.name);
	
	self.assertNotNull(ediFile);
	
	// ---------------------------------------
	// find the release request ediData
	// ---------------------------------------
	if ediFile.ediData.isKindOf(CM_EDIDataGateDoc) or
	   ediFile.ediData.isKindOf(CM_EDIDataReleaseRequest) then
		ediData := ediFile.ediData;
	else
		ediData := ediFile.allEDIData.first;
	endif;
	
	self.assertNotNullMsg (ediData, 'No edi data for delete release requests');	

	// ---------------------------------------
	// do verify (all edi data)  
	// ---------------------------------------
	self.ediVerify(ediFile);
	tempStr	:= 'Veriy of delete failed' &amp; CrLf &amp; app.myPassport.getErrorsAsString;
	self.assertEqualMsg(ediData.status, CM_EDIFile.EDI_STATUS_VERIFIED, tempStr);
	
	// ---------------------------------------
	// load to DB
	// ---------------------------------------
	self.ediDBLoad(ediFile);
	tempStr	:= 'DBLoad for delete failed' &amp; CrLf &amp; app.myPassport.getErrorsAsString;
	self.assertEqualMsg(ediData.status, CM_EDIFile.EDI_STATUS_DBLOADED, tempStr);
	
	// ---------------------------------------
	// find the release
	// ---------------------------------------
	release := self.getReleaseRequest (_releaseNo);
	
	self.assertNullMsg (release, 'Release request has not been deleted');

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_sender" type="String"/>
        <Parameter name="_voyageCode" type="String"/>
        <Parameter name="_vesselName" type="String"/>
        <Parameter name="_consignorCode" type="String"/>
        <Parameter name="_consigneeCode" type="String"/>
        <Parameter name="_releaseNo" type="String"/>
        <Parameter name="_mt" type="Character"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_ediPartyRules" type="CM_EDIPartyCoparnRules"/>
    </JadeMethod>
    <JadeMethod name="doCoparn_mtrel_addthendelfail" id="95efada0-8e8c-4d15-80ff-c10eb5523a54">
        <source>doCoparn_mtrel_addthendelfail(_sender, _voyageCode, _vesselName, _consignorCode, _consigneeCode, _releaseNo:String; _mt :Character; _operator :CM_Operator;  _ediPartyRules :CM_EDIPartyCoparnRules io)protected;
/*
Date		        Who		Reason
13 December 2011	cnwrs1	Initial creation - CCMS POL 2122 / par 28696 - Empty Releases via COPARN
16/05/2012			cnwcs5	par 29575
9 January 2013      cnwgb1  CCMS POL 2216/ par 30902 Heavy Rated Releases      
// 31 Oct 2017	jlgrs1	TFS 5705 - SNO - EDIDataBooking Prenote release Req
// 10 Apr 2018	jlgrs1	TFS 38021 - JMT - Fix issues shown by TFS 37610, delete errors not handled correctly
// 09 Aug 2018	jlgmd1	TFS 39693 - Bulk Release deleting inconsistency between Bulk Release Form and EDI
*/
constants
	ADDITIONAL_TEXT	= "//IF NO 20GP AVAILABLE PLEASE RELEASE DAIRY UNITS";
	ISOTYPE 		= '22G1';
	QUANTITY		= 10;
	ContainerName1 = "CONT001";
	ContainerName2 = "CONT002";
vars
	text	:String;
	ediFile	:CM_EDIFile;
	ediData	:CM_EDIData;
	ediTI	:CM_EDIRequestHeaderTI;
	ediItemTI : CM_EDIRequestDetailTI;
	ediRelReq : CM_EDIReleaseRequestTI;
	release	:CM_BulkRelease;
	item	:CM_ReserveSelection;
	isoType	:CM_ISOType;
	tempStr : String;
	booking : CM_BookingRef;
	ediAgent: CM_EDIControllerAgent;
	container : CM_Container;
	containerId	:String;
	ediItem : CM_EDITrackedItem;
begin
	// ---------------------------------------
	// delete the container if it already exists
	// ---------------------------------------
	if self.getTerminal.getConfig (EdiReleaseAllowPartial).Boolean then
		containerId := ContainerName1;
	else
		containerId := ContainerName2;
	endif;
	
	self.deleteContainer (containerId);
	// ---------------------------------------
	// delete the release if it already exists
	// ---------------------------------------
	self.deleteReleaseRequest (_releaseNo);
	
	// ---------------------------------------
	// get edi file to load
	// ---------------------------------------
	text := self.zCoparn_mtrel_addthendelete ("12", '9', _sender, _voyageCode, _vesselName, _consignorCode, _consigneeCode, _releaseNo, ADDITIONAL_TEXT, "TEXTSIN", "TEXTHAN", ISOTYPE, QUANTITY.String, _mt);

	// ---------------------------------------
	// load edi file to create EDI tracked items
	// ---------------------------------------
	ediFile := self.ediLoadFileName(text, EDIFileType_Unknown, "COPARN", "COPARN1"&amp;method.name);
	
	self.assertNotNull(ediFile);
	
	// ---------------------------------------
	// find the release request ediData
	// ---------------------------------------
	if ediFile.ediData.isKindOf(CM_EDIDataGateDoc) or
	   ediFile.ediData.isKindOf(CM_EDIDataReleaseRequest) then
		ediData := ediFile.ediData;
	else
		ediData := ediFile.allEDIData.first;
	endif;
	
	self.assertNotNullMsg (ediData, 'No edi data for release requests');
	
	// ---------------------------------------
	// find the edi tracked item
	// ---------------------------------------
//	ediTI := ediData.allEDITrackedItems.first.CM_EDIRequestHeaderTI;
	if ediData.isKindOf(CM_EDIDataGateDoc) then
		foreach ediItem in ediData.allEDITrackedItems do
			if  ediItem.isKindOf(CM_EDIRequestHeaderTI) then
				ediTI := ediItem.CM_EDIRequestHeaderTI;
				break;
			endif;
		endforeach;
		self.assertNotNullMsg(ediTI, 'EDI tracked items not created');
		ediItemTI := self.getMatchingEDIItemTI(ediTI);
		// ---------------------------------------
		// check values on EDI TI
		// ---------------------------------------
		self.doCheckEDITiRequestMulti(ediTI, ediItemTI, "A", _releaseNo, _voyageCode, _vesselName, _operator.code, _consignorCode, _consigneeCode, ISOTYPE, ADDITIONAL_TEXT, "TEXTSIN", "TEXTHAN", QUANTITY, _ediPartyRules, null, null, false, true, false, false, false, true);
	endif;
	if ediData.isKindOf(CM_EDIDataReleaseRequest) then
		foreach ediItem in ediData.allEDITrackedItems do
			if  ediItem.isKindOf(CM_EDIReleaseRequestTI) then
				ediRelReq := ediItem.CM_EDIReleaseRequestTI;
				break;
			endif;
		endforeach;
		self.assertNotNullMsg(ediRelReq, 'EDI tracked items not created');
		// ---------------------------------------
		// check values on EDI TI
		// ---------------------------------------
		self.doCheckEDITIReleaseRequest(ediRelReq, "A", _releaseNo, _voyageCode, _vesselName,  _operator.code,_consignorCode, _consigneeCode, ISOTYPE, ADDITIONAL_TEXT, "TEXTSIN", "TEXTHAN", QUANTITY, _ediPartyRules, null, null, false, true, false, false, false, true);
	endif;
	if ediTI &lt;&gt; null then
		// destination - LOC+8+AUMEL:139:6'
		self.assertEqualMsg (ediTI.destinationPort, "AUMEL", "Destination shoudl be AUMEL");
		// load port - LOC+9+NZPOE:139:6'
		self.assertEqualMsg (ediTI.loadPort, "NZPOE", "Load port should be NZPOE");
		// discharge port - LOC+11+NZAKL:139:6'
		self.assertEqualMsg (ediTI.dischargePort, "NZAKL", "Destination shoudl be NZAKL");
	endif;
	if ediRelReq &lt;&gt; null then
		// destination - LOC+8+AUMEL:139:6'
		self.assertEqualMsg (ediRelReq.destinationPort, "AUMEL", "Destination shoudl be AUMEL");
		// load port - LOC+9+NZPOE:139:6'
		self.assertEqualMsg (ediRelReq.loadPort, "NZPOE", "Load port should be NZPOE");
		// discharge port - LOC+11+NZAKL:139:6'
		self.assertEqualMsg (ediRelReq.dischargePort, "NZAKL", "Destination shoudl be NZAKL");
	endif;
	// ---------------------------------------
	// do verify (all edi data)  
	// ---------------------------------------
	self.ediVerify(ediFile);
	tempStr	:= 'Verify failed' &amp; CrLf &amp; app.myPassport.getErrorsAsString;
	self.assertEqualMsg(ediData.status, CM_EDIFile.EDI_STATUS_VERIFIED, tempStr);
	
	// ---------------------------------------
	// load to DB
	// ---------------------------------------
	self.ediDBLoad(ediFile);
	tempStr	:= 'DBLoad failed' &amp; CrLf &amp; app.myPassport.getErrorsAsString;
	self.assertEqualMsg(ediData.status, CM_EDIFile.EDI_STATUS_DBLOADED, tempStr);
	
	// ---------------------------------------
	// find the release
	// ---------------------------------------
	release := self.getReleaseRequest (_releaseNo);
	
	self.assertNotNull (release);
	
	// ---------------------------------------
	// do standard checks
	// ---------------------------------------
	self.doCheckPartyRules_AddRelease (release, _ediPartyRules, false, true, false);
	
	self.assertTrueMsg (release.releaseByType, 'Release by type is not set');
	self.assertEqualMsg (release.code, _releaseNo, 'Release number is incorrect');
	self.assertEqualMsg (release.myVoyage.code, _voyageCode, 'Voyage code is incorrect');
	self.assertEqualMsg (release.myOperator, _operator, 'Operator is incorrect');
	self.assertEqualMsg (release.consignorCode, _consignorCode, 'Consignor is incorrect');
	self.assertFalseMsg (release.needsReview, 'Needs review should not be set');

	// we expect the release cargo remarks to include the addition text
	item := release.allReserveDetails.first.CM_ReserveSelection;
	
	self.assertNotNull (item);
	self.assertTrueMsg (item.remarks.pos (ADDITIONAL_TEXT, 1) &gt; 0, 'Additionl text from FTX+AAI not stored in cargo remarks');
	self.assertTrueMsg (item.remarks.pos ("TEXTSIN", 1) &gt; 0, 'Additionl text from FTX+SIN not stored in cargo remarks');
	self.assertTrueMsg (item.remarks.pos ("TEXTHAN", 1) &gt; 0, 'Additionl text from FTX+HAN not stored in cargo remarks');

	self.assertNotNullMsg (item.myISOType, 'ISO Type not set');
	self.assertEqualMsg (item.myISOType.code, ISOTYPE, 'ISO type is incorrect');
	
	// Availability grade - defaults for this file
	
	// total requested
	self.assertEqualMsg (item.totalRequested, QUANTITY, 'Total requested not set');
	
	// check ediFile collection has been updated
	self.assertTrueMsg (release.allEDIFiles.includes (ediFile), 'Update the edi files collection !!!');
	self.assertTrueMsg (release.allEDIFiles.size = 1, _releaseNo &amp; ' EDI the edi files collection should have 1 entry!!!');

	// now add a booking and check the delete fails
	text := self.zCoparn_mtrel_addthendelete ("11", '9', _sender, _voyageCode, _vesselName, _consignorCode, _consigneeCode, _releaseNo, ADDITIONAL_TEXT, "TEXTSIN", "TEXTHAN", ISOTYPE, QUANTITY.String, _mt);
	// ---------------------------------------
	// load edi file to create EDI tracked items
	// ---------------------------------------
	ediFile := self.ediLoadFileName(text, EDIFileType_Unknown, "COPARN", "COPARN2"&amp;method.name);
	
	self.assertNotNull(ediFile);
	
	// ---------------------------------------
	// find the release request ediData
	// ---------------------------------------
	if ediFile.ediData.isKindOf(CM_EDIDataGateDoc) or
	   ediFile.ediData.isKindOf(CM_EDIDataBooking) then
		ediData := ediFile.ediData;
	else
		ediData := ediFile.allEDIData.first;
	endif;
	
	self.assertNotNullMsg (ediData, 'No edi data for booking');
	
	// ---------------------------------------
	// do verify (all edi data)  
	// ---------------------------------------
	self.ediVerify(ediFile);
	tempStr	:= 'Verify failed' &amp; CrLf &amp; app.myPassport.getErrorsAsString;
	self.assertEqualMsg(ediData.status, CM_EDIFile.EDI_STATUS_VERIFIED, tempStr);
	
	// ---------------------------------------
	// load to DB
	// ---------------------------------------
	self.ediDBLoad(ediFile);
	tempStr	:= 'DBLoad failed' &amp; CrLf &amp; app.myPassport.getErrorsAsString;
	self.assertEqualMsg(ediData.status, CM_EDIFile.EDI_STATUS_DBLOADED, tempStr);
	
	// ---------------------------------------
	// find the release
	// ---------------------------------------
	booking := self.getBooking (_releaseNo);
	
	self.assertNotNull (booking);

	// now do load the file to do the delete
	// ---------------------------------------
	// get edi file to load
	// ---------------------------------------
	text := self.zCoparn_mtrel_addthendelete ("12", '1', _sender, _voyageCode, _vesselName, _consignorCode, _consigneeCode, _releaseNo, ADDITIONAL_TEXT, "TEXTSIN", "TEXTHAN", ISOTYPE, QUANTITY.String, _mt);

	// ---------------------------------------
	// load edi file to create EDI tracked items
	// ---------------------------------------
	ediFile := self.ediLoadFileName(text, EDIFileType_Unknown, "COPARN", "COPARN3"&amp;method.name);
	
	self.assertNotNull(ediFile);
	
	// ---------------------------------------
	// find the release request ediData
	// ---------------------------------------
	if ediFile.ediData.isKindOf(CM_EDIDataGateDoc) or
	   ediFile.ediData.isKindOf(CM_EDIDataReleaseRequest) then
		ediData := ediFile.ediData;
	else
		ediData := ediFile.allEDIData.first;
	endif;
	
	self.assertNotNullMsg (ediData, 'No edi data for delete release requests');	

	// ---------------------------------------
	// do verify (all edi data)  
	// ---------------------------------------
	self.ediVerify(ediFile);
	tempStr	:= 'Verify of delete failed' &amp; CrLf &amp; app.myPassport.getErrorsAsString;
	self.assertEqualMsg(ediData.status, CM_EDIFile.EDI_STATUS_VERIFIED, tempStr);
	
	// ---------------------------------------
	// load to DB
	// ---------------------------------------
	create ediAgent transient;
	
	ediAgent.setTerminal(self.getTerminal());
		
	// now add a container to the release request 
	release := self.getReleaseRequest (_releaseNo);
	// Add the container to the voyage
	container := self.addContainerForExport(containerId,
										release.myOperator,
										"2200",					// ISOType is not needed
										"MT",					// commodity is not needed
										TI_IMEX_STATUS_STORAGE,	// import not export
										null,					// booking id
										_voyageCode,
										null,					// dischargePort
										null).CM_Container;			// transhipToPort
	beginTransaction;
	release.allTrackedItemsReleased.add(container);
	// Set the release to Active, so it can't be deleted
	release.setStatus(BR_ACTIVE, false, true);
	commitTransaction;

	ediData := ediFile.ediData;
	
	ediAgent.verifyEdiData(ediData);
	ediAgent.loadEdiDb(null, ediData, false);
//	self.ediDBLoad(ediFile);
	tempStr	:= 'DBLoad for delete failed' &amp; CrLf &amp; app.myPassport.getErrorsAsString;
	if ediFile.ediData.isKindOf(CM_EDIDataGateDoc) then
		self.assertEqualMsg(ediData.status, CM_EDIFile.EDI_STATUS_VERIFY_ERRORS_X, tempStr);
//		beginTransaction;
//		release.allTrackedItemsReleased.remove(container);
//		commitTransaction;
	endif;
	if ediFile.ediData.isKindOf(CM_EDIDataReleaseRequest) then	//wrong
		self.assertEqualMsg(ediData.status, CM_EDIFile.EDI_STATUS_VERIFY_ERRORS_X, tempStr);
	endif;

	// change rule to email on delete
	beginTransaction;
	_ediPartyRules.setPropertyValue(CM_EDIPartyCoparnRules::sendEmailForDeletes.name, true);
	commitTransaction;
	self.ediDBLoad(ediFile);
	tempStr	:= 'DBLoad for delete failed' &amp; CrLf &amp; app.myPassport.getErrorsAsString;
	if ediData.isKindOf(CM_EDIDataGateDoc) then
		self.assertEqualMsg(ediData.status, CM_EDIFile.EDI_STATUS_VERIFY_ERRORS_X, tempStr);	//wrong
	endif;
	if ediData.isKindOf(CM_EDIDataReleaseRequest) then
		self.assertEqualMsg(ediData.status, CM_EDIFile.EDI_STATUS_VERIFY_ERRORS_X, tempStr);
	endif;
	// ---------------------------------------
	// find the release
	// ---------------------------------------
	release := self.getReleaseRequest (_releaseNo);
	
	self.assertNotNullMsg (release, 'Release request has not been deleted');

	// turn off rule change
	beginTransaction;
	_ediPartyRules.setPropertyValue(CM_EDIPartyCoparnRules::sendEmailForDeletes.name, false);
	// Set the release back to pending, so it can be deleted later
	release.setStatus(BR_PENDING, false, true);
	commitTransaction;

epilog
	delete 	ediAgent;
end;
</source>
        <access>protected</access>
        <Parameter name="_sender" type="String"/>
        <Parameter name="_voyageCode" type="String"/>
        <Parameter name="_vesselName" type="String"/>
        <Parameter name="_consignorCode" type="String"/>
        <Parameter name="_consigneeCode" type="String"/>
        <Parameter name="_releaseNo" type="String"/>
        <Parameter name="_mt" type="Character"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_ediPartyRules" type="CM_EDIPartyCoparnRules" usage="io"/>
    </JadeMethod>
    <JadeMethod name="doCoparn_mtrel_chilled2probes" id="b9d59a7e-bb0e-4e90-b9b3-280a45b86f2d">
        <source>doCoparn_mtrel_chilled2probes(_sender, _voyageCode, _vesselName, _consignorCode, _releaseNo :String; _mt :Character; _operator :CM_Operator; _ediPartyRules :CM_EDIPartyCoparnRules)protected;
/*
Date		        Who		Reason
01 December 2011	cnwcs5	Initial creation - CCMS POL 2122 / par 28696 - Empty Releases via COPARN
23/08/2012	        cnwcs5	par 30096
9 January 2013      cnwgb1  CCMS POL 2216/ par 30902 Heavy Rated Releases      
// 31 Oct 2017	jlgrs1	TFS 5705 - SNO - EDIDataBooking Prenote release Req
1 March 2018		jlgdap1	TFS 37308 SNO COPARN Reefer Info applied to remarks
*/
constants
	ADDITIONAL_TEXT	= "CHILLED/PROBESX2";
	ISOTYPE 		= '22R1';
	QUANTITY		= 2;
vars
	text	:String;
	ediFile	:CM_EDIFile;
	ediData	:CM_EDIData;
	ediTI	:CM_EDIRequestHeaderTI;
	ediItemTI : CM_EDIRequestDetailTI;
	ediRelReq : CM_EDIReleaseRequestTI;
	release	:CM_BulkRelease;
	item	:CM_ReserveSelection;
	isoType	:CM_ISOType;
	tempStr : String;
	ediItem : CM_EDITrackedItem;
	ediTIDetail : CM_EDIRequestDetailTI;			// TFS 37308
begin
	// ---------------------------------------
	// delete the release if it already exists
	// ---------------------------------------
	self.deleteReleaseRequest (_releaseNo);
	
	// ---------------------------------------
	// get edi file to load
	// ---------------------------------------
	text := self.zCoparn_mtrel_chilled2probes (_sender, _voyageCode, _vesselName, _consignorCode, _releaseNo, ADDITIONAL_TEXT, ISOTYPE, QUANTITY.String, _mt);

	// ---------------------------------------
	// load edi file to create EDI tracked items
	// ---------------------------------------
	ediFile := self.ediLoadFileName(text, EDIFileType_Unknown, "COPARN", "COPARN"&amp;method.name);
	
	self.assertNotNull(ediFile);
	
	// ---------------------------------------
	// find the release request ediData
	// ---------------------------------------
	if ediFile.ediData.isKindOf(CM_EDIDataGateDoc) or
	   ediFile.ediData.isKindOf(CM_EDIDataReleaseRequest) then
		ediData := ediFile.ediData;
	else
		ediData := ediFile.allEDIData.first;
	endif;
	
	self.assertNotNullMsg (ediData, 'No edi data for release requests - ' &amp; app.myPassport.getAllErrorsAndWarnsFullAsStr);
	
	// ---------------------------------------
	// find the edi tracked item
	// ---------------------------------------
//	ediTI := ediData.allEDITrackedItems.first.CM_EDIRequestHeaderTI;
	if ediData.isKindOf(CM_EDIDataGateDoc) then
		foreach ediItem in ediData.allEDITrackedItems do
			if  ediItem.isKindOf(CM_EDIRequestHeaderTI) then
				ediTI := ediItem.CM_EDIRequestHeaderTI;
				//break;													// TFS 37308
			endif;
			if ediItem.isKindOf(CM_EDIRequestDetailTI) then					// TFS 37308
				ediTIDetail := ediItem.CM_EDIRequestDetailTI;				// TFS 37308
			endif;															// TFS 37308
		endforeach;
		self.assertNotNullMsg(ediTI, 'EDI tracked items not created');
		ediItemTI := self.getMatchingEDIItemTI(ediTI);
		// ---------------------------------------
		// check values on EDI TI
		// ---------------------------------------
		self.doCheckEDITiRequestMulti(ediTI, ediItemTI, "A", _releaseNo, _voyageCode, _vesselName,  _operator.code,_consignorCode, null, ISOTYPE, ADDITIONAL_TEXT,  null, null, QUANTITY, _ediPartyRules, null, null, false, true, false, false, false, true);
	endif;
	if ediData.isKindOf(CM_EDIDataReleaseRequest) then
		foreach ediItem in ediData.allEDITrackedItems do
			if  ediItem.isKindOf(CM_EDIReleaseRequestTI) then
				ediRelReq := ediItem.CM_EDIReleaseRequestTI;
				break;
			endif;
		endforeach;
		self.assertNotNullMsg(ediRelReq, 'EDI tracked items not created');
		// ---------------------------------------
		// check values on EDI TI
		// ---------------------------------------
		self.doCheckEDITIReleaseRequest(ediRelReq, "A", _releaseNo, _voyageCode, _vesselName,  _operator.code,_consignorCode, null, ISOTYPE, ADDITIONAL_TEXT,  null, null, QUANTITY, _ediPartyRules, null, null, false, true, false, false, false, true);
	endif;
	if ediTI &lt;&gt; null then
		self.assertNotNull (ediTI.remarks);
		self.assertTrueMsg (ediTI.remarks.pos ('VENTILATION 80 CBM/H', 1) &gt; 0, 'VENTILATION  not stored in cargo remarks');
		self.assertTrueMsg (ediTI.remarks.pos ('HUMIDITY 60.06%', 1) &gt; 0, 'HUMIDITY  not stored in cargo remarks');
		self.assertTrueMsg (ediTI.remarks.pos ('OXYGEN 30.03%', 1) &gt; 0, 'OXYGEN  not stored in cargo remarks');
		self.assertTrueMsg (ediTI.remarks.pos ('CO2 45.54%', 1) &gt; 0, 'CO2  not stored in cargo remarks');
		self.assertTrueMsg (ediTI.remarks.pos ('TEMP -002CEL', 1) &gt; 0, 'TEMPERATURE  not stored in cargo remarks');
	endif;
	if ediRelReq &lt;&gt; null then
		self.assertNotNull (ediRelReq.remarks);
		self.assertTrueMsg (ediRelReq.remarks.pos ('VENTILATION 80 CBM/H', 1) &gt; 0, 'VENTILATION  not stored in cargo remarks');
		self.assertTrueMsg (ediRelReq.remarks.pos ('HUMIDITY 60.06%', 1) &gt; 0, 'HUMIDITY  not stored in cargo remarks');
		self.assertTrueMsg (ediRelReq.remarks.pos ('OXYGEN 30.03%', 1) &gt; 0, 'OXYGEN  not stored in cargo remarks');
		self.assertTrueMsg (ediRelReq.remarks.pos ('CO2 45.54%', 1) &gt; 0, 'CO2  not stored in cargo remarks');
		self.assertTrueMsg (ediRelReq.remarks.pos ('TEMP -002CEL', 1) &gt; 0, 'TEMPERATURE  not stored in cargo remarks');
	endif;
	if ediTIDetail &lt;&gt; null then																										// TFS 37308
		self.assertNotNull (ediTIDetail.remarks);																						// TFS 37308
		self.assertTrueMsg (ediTIDetail.remarks.pos ('VENTILATION 80 CBM/H', 1) &gt; 0, 'VENTILATION  not stored in cargo remarks');		// TFS 37308
		self.assertTrueMsg (ediTIDetail.remarks.pos ('HUMIDITY 60.06%', 1) &gt; 0, 'HUMIDITY  not stored in cargo remarks');				// TFS 37308
		self.assertTrueMsg (ediTIDetail.remarks.pos ('OXYGEN 30.03%', 1) &gt; 0, 'OXYGEN  not stored in cargo remarks');					// TFS 37308
		self.assertTrueMsg (ediTIDetail.remarks.pos ('CO2 45.54%', 1) &gt; 0, 'CO2  not stored in cargo remarks');							// TFS 37308
		self.assertTrueMsg (ediTIDetail.remarks.pos ('TEMP -002CEL', 1) &gt; 0, 'TEMPERATURE  not stored in cargo remarks');				// TFS 37308
	endif;																															// TFS 37308
	// ---------------------------------------
	// do verify (all edi data)  
	// ---------------------------------------
	self.ediVerify(ediFile);
	tempStr	:= 'Verify failed' &amp; CrLf &amp; app.myPassport.getErrorsAsString;		// par 30096 Aug 2012
	self.assertEqualMsg(ediData.status, CM_EDIFile.EDI_STATUS_VERIFIED, tempStr);
	
	// ---------------------------------------
	// load to DB
	// ---------------------------------------
	self.ediDBLoad(ediFile);
	tempStr	:= 'DBLoad failed' &amp; CrLf &amp; app.myPassport.getErrorsAsString;
	self.assertEqualMsg(ediData.status, CM_EDIFile.EDI_STATUS_DBLOADED, tempStr);
	
	// ---------------------------------------
	// find the release
	// ---------------------------------------
	release := self.getReleaseRequest (_releaseNo);
	
	self.assertNotNull (release);
	
	// ---------------------------------------
	// do standard checks
	// ---------------------------------------
	self.doCheckPartyRules_AddRelease (release, _ediPartyRules, false, true, false);
	
	self.assertTrueMsg (release.releaseByType, 'Release by type is not set');
	self.assertEqualMsg (release.code, _releaseNo, 'Release number is incorrect');
	self.assertEqualMsg (release.myVoyage.code, _voyageCode, 'Voyage code is incorrect');
	// self.assertEqualMsg (release.myOperator, ???, 'Operator is incorrect');// operator ???
	self.assertEqualMsg (release.consignorCode, _consignorCode, 'Consignor is incorrect');

	// we expect the release cargo remarks to include the addition text
	item := release.allReserveDetails.first.CM_ReserveSelection;
	
	self.assertNotNull (item);
	self.assertTrueMsg (item.remarks.pos (ADDITIONAL_TEXT, 1) &gt; 0, 'Additionl text from FTX not stored in cargo remarks');
	self.assertTrueMsg (item.remarks.pos ('VENTILATION 80 CBM/H', 1) &gt; 0, 'VENTILATION  not stored in cargo remarks');
	self.assertTrueMsg (item.remarks.pos ('HUMIDITY 60.06%', 1) &gt; 0, 'HUMIDITY  not stored in cargo remarks');
	self.assertTrueMsg (item.remarks.pos ('OXYGEN 30.03%', 1) &gt; 0, 'OXYGEN  not stored in cargo remarks');
	self.assertTrueMsg (item.remarks.pos ('CO2 45.54%', 1) &gt; 0, 'CO2  not stored in cargo remarks');
	self.assertTrueMsg (item.remarks.pos ('TEMP -002CEL', 1) &gt; 0, 'TEMP not stored in cargo remarks');

	
	self.assertNotNullMsg (item.myISOType, 'ISO Type not set');
	
	self.assertEqualMsg (item.myISOType.code, ISOTYPE, 'ISO type is incorrect');
	
	// Availability grade - defaults for this file
	
	// total requested
	self.assertEqualMsg (item.totalRequested, QUANTITY, 'Total requested not set');
	
	// check ediFile collection has been updated
	self.assertTrueMsg (release.allEDIFiles.includes (ediFile), 'Update the edi files collection !!!');
	self.assertTrueMsg (release.allEDIFiles.size = 1, _releaseNo &amp; ' EDI the edi files collection should have 1 entry!!!');	
epilog

end;</source>
