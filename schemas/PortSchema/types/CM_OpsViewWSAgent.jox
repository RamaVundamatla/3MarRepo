    <JadeMethod name="setupTerminalAreaForActivity" id="9481844a-e751-427f-97d0-1da30f52efdb">
        <source>setupTerminalAreaForActivity(_cmifArray : CMIF_OpsViewTablesArray io; _ewsOpsView : CM_EWSActivityOpsview): CMIF_OpsViewTablesArray;
/*
Purpose:			

Date		Who		Reason
08FEB2022	NAVAB1	TFS 51854
*/

vars
	spatial	 	: CMIF_SpatialBins;
	stack : CMIF_XpsStackStatus;
	data            : Any;
	termArea : CM_TerminalArea;
	terminal : CM_Terminal;
	gridArea : CM_GridArea;
	gridCol : CM_GridColumn;
	gridLC : CM_GridController;
begin
	if _ewsOpsView.dataAction = BGP_OpsViewWSRequest.OPS_ACTION_DELETE then
		data := _ewsOpsView.objectOid;
	else
		data := _ewsOpsView.myOpsviewObject;
		if data.isKindOf(CM_TerminalArea) then
			termArea := data.CM_TerminalArea;
		endif;
	endif;
	
	if termArea &lt;&gt; null then
		// ### TERMINAL
		/*create spatial transient;
		spatial.initializeForActivity(termArea.myTerminal,_ewsOpsView);*/ //Commented for TFS#53369 NAVSP1 22APR2022
			
		_cmifArray.add(spatial);
	
		// ### TERMINAL AREA
		create spatial transient;
		spatial.initializeForActivity(termArea,_ewsOpsView);
			
		_cmifArray.add(spatial);
	
		if termArea.isGridArea() then
			gridArea := termArea.CM_GridArea;
			foreach gridCol in gridArea.allGridColumns discreteLock do
				// ### Grid Column
				create spatial transient;
				spatial.initializeForActivity(gridCol,_ewsOpsView);
					
				_cmifArray.add(spatial);
			
				foreach gridLC in gridCol.allControllersByRow discreteLock do
					// ### Grid Location
					create spatial transient;
					spatial.initializeForActivity(gridLC,_ewsOpsView);
						
					_cmifArray.add(spatial);
					
					create stack transient;
					stack.initializeForActivity(gridLC,_ewsOpsView);
						
					_cmifArray.add(stack);
				
				endforeach;
			
			endforeach;
		endif;
	else
		// ### TERMINAL AREA
		create spatial transient;
		spatial.initializeForActivity(data,_ewsOpsView);
			
		_cmifArray.add(spatial);

	endif;

	return _cmifArray;
	
epilog

end;</source>
        <Parameter name="_cmifArray" type="CMIF_OpsViewTablesArray" usage="io"/>
        <Parameter name="_ewsOpsView" type="CM_EWSActivityOpsview"/>
        <ReturnType type="CMIF_OpsViewTablesArray"/>
    </JadeMethod>
    <JadeMethod name="setupTerminalForActivity" id="c9463992-9477-4827-b7e7-9a358ab3c7ba">
        <source>setupTerminalForActivity(_cmifArray : CMIF_OpsViewTablesArray io; _ewsOpsView : CM_EWSActivityOpsview): CMIF_OpsViewTablesArray;
/*
Purpose:			

Date		Who		Reason
26AUG2021	NAVAB1	TFS 51853
*/

vars
	argoFacilityCmif    	: CMIF_ArgoFacility;
	data                    : Any;
	spatialBins				: CMIF_SpatialBins; //TFS#53369 NAVSP1 22APR2022
	terminal				: CM_Terminal;		//TFS#53369 NAVSP1 22APR2022
	yardN4 : CMIF_ArgoYard;
begin
	
	data := _ewsOpsView.myOpsviewObject;
	
	create argoFacilityCmif transient;
	argoFacilityCmif.initializeForActivity(data,_ewsOpsView);	

	_cmifArray.add(argoFacilityCmif);
	
	//TFS#53369 NAVSP1 22APR2022
	if data.isKindOf(CM_Terminal) then
		terminal := data.CM_Terminal;
		create spatialBins transient;	
		terminal.initializeForActivity(_ewsOpsView,spatialBins);
		_cmifArray.add(spatialBins);
		
		create yardN4 transient;
		yardN4.initializeForActivity(terminal,_ewsOpsView);	
		_cmifArray.add(yardN4);
		
		
	endif;
	
	return _cmifArray;
	
epilog

end;</source>
        <Parameter name="_cmifArray" type="CMIF_OpsViewTablesArray" usage="io"/>
        <Parameter name="_ewsOpsView" type="CM_EWSActivityOpsview"/>
        <ReturnType type="CMIF_OpsViewTablesArray"/>
    </JadeMethod>
    <JadeMethod name="setupTrackedItemForActivity" id="5e966189-571f-4b77-90c0-68ea110d8132">
        <source>setupTrackedItemForActivity(_cmifArray : CMIF_OpsViewTablesArray io; _ewsOpsView : CM_EWSActivityOpsview): CMIF_OpsViewTablesArray;
/*
Purpose:			

Date		Who		Reason
21FEB2022	NAVAB1	TFS 52925
*/

vars
	unit : CMIF_InvUnit;
	unitFcy : CMIF_InvUnitFcyVisit;
	equip : CMIF_RefEquipment;
	
	ti : CM_TrackedItem;
	roadTruckCmif : CMIF_RoadTruckTransactions;
	data            : Any;
	opsviewyrdvisit : CMIF_InvUnitYrdVisit;
	invgoods : CMIF_InvGoods;
begin
	if _ewsOpsView.dataAction = BGP_OpsViewWSRequest.OPS_ACTION_DELETE then
		data := _ewsOpsView.objectOid;
	else
		data := _ewsOpsView.myOpsviewObject;
		ti := data.CM_TrackedItem;


	endif;

	//9th March 2022 - navab1 TFS #53037
	create unit transient;
	unit.initializeForActivity(ti,_ewsOpsView);
	_cmifArray.add(unit);

	create unitFcy transient;
	unitFcy.initializeForActivity(ti,_ewsOpsView);
	_cmifArray.add(unitFcy);

	if ti &lt;&gt; null then
		if ti.isContainer() then // ### TFS 53105 09JUN2022 NAVAB1
			create equip transient;
			equip.initializeForActivity(ti,_ewsOpsView);
			_cmifArray.add(equip);
		endif;
		
		if ti.isOpsViewData()   // ### TFS 53105 02JUN2022 NAVAB1
		and not ti.isContainer() then // ### TFS 53105 02JUN2022 NAVAB1
			create invgoods transient; // ### TFS 53105 02JUN2022 NAVAB1
			invgoods.initializeForActivity(ti,_ewsOpsView); // ### TFS 53105 02JUN2022 NAVAB1
			_cmifArray.add(invgoods); // ### TFS 53105 02JUN2022 NAVAB1
		
		endif;
	endif;
	
	return _cmifArray;

epilog

end;</source>
        <Parameter name="_cmifArray" type="CMIF_OpsViewTablesArray" usage="io"/>
        <Parameter name="_ewsOpsView" type="CM_EWSActivityOpsview"/>
        <ReturnType type="CMIF_OpsViewTablesArray"/>
