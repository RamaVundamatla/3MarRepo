    <JadeMethod name="doMnuEnquiry" id="960c6ea1-3d91-415a-8a1b-4edc866e5f5e">
        <source>doMnuEnquiry( menuItem : MenuItem );

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
31 October 2011	cnwndl1	Initial creation	Par 28466

*/

vars

	myAssistant : CMUI_Assistant;
	objArray : ObjectArray;

begin

	create objArray transient;
	if menuItem.userObject &lt;&gt; null then
		if menuItem.userObject.isKindOf( CM_TrackedItem ) then
			objArray.add( menuItem.userObject.CM_TrackedItem );
		elseif menuItem.userObject.isKindOf( ObjectArray ) then
			menuItem.userObject.ObjectArray.copy( objArray );
		endif;
	endif;
	
	if objArray.isEmpty then
		return;
	endif;
	
	myAssistant := self.myAssistant;	
	if myAssistant = null then
		return;
	endif;
	
	myAssistant.showCargoEnquiryForTIs( objArray[1].CM_TrackedItem, objArray, self.myMasterMenuAction, false);
		 
epilog

	delete objArray;

end;</source>
