        <updating/>
        <source>doTblDataClick(table: Table input) updating;
//----------------------------------------------------------------------
// Created by 	cnwsh3 - 03 September 2010
//
// Implemented version: JMT 7.8.3
// Date  		User  		Change
//----------------------------------------------------------------------
vars

begin
	//Not status bar info required so implemented with nothing in it.
	
		// TFS 2198 CNWAB1
