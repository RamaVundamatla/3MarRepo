    <JadeMethod name="timerEvent" id="fa93432c-7f35-48ad-b4b7-7fd68a243b3d">
        <updating/>
        <source>timerEvent(eventTag: Integer) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
13 January 2021		jlgmd1	Initial creation TFS 50644

*/

vars
	session 		: WebSession;
	invalid			: Boolean;
begin
	if eventTag = self.Remove_Session_After_Reply then
		// 'purge' any temporary sessions that have been automatically created, and would otherwise only be removed when they get timed out.
		//    (or the JMTWebServices causes the server to grind to a halt as the JADE session collections become too big - yay DOS attacks!)
		// NB: This has to be done after the reply has been sent to the requestor, otherwise the reply gets nuked
		
		app.writeLog("Clearing temporary sessions... [Size: " &amp; self.temporaryWebSessions.size.String &amp;"]", LogDEBUG);
		
		on Exception do app.handleDeletedObject(exception, session, invalid);	// The session might have timedout and is in the process of being cleaned up automatically (unlikely, but you never know)
		foreach session in self.temporaryWebSessions do
			invalid := false;
			session.edition;
			if not invalid then
				app.writeLog("    Removing session " &amp; session.getPropertyValue("_encryptedSessionId").String, LogTRACE);
				session.removeSession();
			endif;
		endforeach;
		on Exception do null;
		
		// These should all be invalid refs now
		app.temporaryWebSessions.clear();
		
	endif;
epilog

end;</source>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
</Class>
