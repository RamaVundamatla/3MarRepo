// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	self.cmbLoadAsType.enabled := (optionbutton.value);
	self.lblLoadAsType.enabled := (optionbutton.value);
epilog

end;</source>
        <Parameter name="optionbutton" type="OptionButton" usage="input"/>
    </JadeMethod>
    <JadeMethod name="progressStart" id="f3305c6a-2af1-4551-9f76-08e8ccca8626">
        <updating/>
        <source>progressStart(totalParts: Integer; btnDefaultCaption: String; btnOpt1Caption: String; btnOpt2Caption: String; _msg1: String) updating;
// ---------------------------------------------------------------------------
// Created:     03 May 2010 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin 
	inheritMethod(totalParts, btnDefaultCaption, btnOpt1Caption, btnOpt2Caption, _msg1);
	
	if totalParts &lt; 100 then
		progressUpdateAfter := (totalParts / 2).roundedUp;
	elseif totalParts &lt; 500 then
		progressUpdateAfter := (totalParts / 10).roundedUp;
	else
		// leave at default setting
	endif;
epilog

end;</source>
        <Parameter name="totalParts" type="Integer"/>
        <Parameter name="btnDefaultCaption" type="String"/>
        <Parameter name="btnOpt1Caption" type="String"/>
        <Parameter name="btnOpt2Caption" type="String"/>
        <Parameter name="_msg1" type="String"/>
    </JadeMethod>
    <JadeMethod name="searcherShowHideControls" id="b4e7744a-e709-43a4-b591-2b34de907ee1">
        <source>searcherShowHideControls(_hide: Boolean) protected;
// ---------------------------------------------------------------------------
// Created:     27 April 2010 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	inheritMethod(_hide);
	
	self.btnPrint.enabled		:= _hide;
	self.btnExportCSVQE.enabled	:= _hide;
	self.btnEditItem.enabled	:= _hide;
	self.btnDelete.enabled		:= _hide;
	self.btnSelectAll.enabled	:= _hide;
	self.btnShowLoadNew.enabled		:= _hide;
	self.btnExtractNew.enabled	:= _hide;
	
	self.tblData.enabled		:= _hide;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_hide" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setCorrectComboStyle" id="612e2fe4-c027-4734-b4d0-8a61952a654d">
