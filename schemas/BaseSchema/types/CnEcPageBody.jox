    <JadeMethod name="getHtml" id="c71a7d05-4cae-4c5d-9916-b2f452d13379">
        <source>getHtml(): String;
// --------------------------------------------------------------------------------
// Created:		02 December 2001 by cnwdad1
//
// Purpose:		Refer to the CnEcHtmlTagObject implementation.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return '&lt;BODY&gt;' &amp; CrLf &amp; self.buildTagBody() &amp; '&lt;/BODY&gt;' &amp; CrLf;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setPage" id="6be9143b-bc23-4bd3-a7e0-63d9cd5704f3">
        <updating/>
        <source>setPage(pPageObj:CnEcHtmlPage) updating;
// --------------------------------------------------------------------------------
// Created:		02 December 2001 by cnwdad1
//
// Purpose:		Set a reference to the receiver's owning HTML page tag object.
//
// Parameters:	pPageObj - The HTML pag tag object.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.myPage &lt;&gt; pPageObj then
		self.myPage	:=	pPageObj;
	endif;
end;</source>
        <Parameter name="pPageObj" type="CnEcHtmlPage"/>
    </JadeMethod>
</Class>
