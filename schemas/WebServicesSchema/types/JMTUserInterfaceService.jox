    <JadeWebServicesMethod name="machineDoUpdateQueue" id="ca40b125-a5b2-4aac-a1c7-d44bb11fed27">
        <source>machineDoUpdateQueue(_queueId : String)  : WS_Response webService;
/*

Date		Who		Reason
07 June 2017	cnwer1	Initial creation TFS 4624

*/

vars
	response : WS_Response;
	completedOK : Boolean;
	newQueue	 	: CM_RadioTelemetryQueue;
	pxyMachine,
	machine 		: CM_Machine;
	loadStateSet : Boolean;
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null ;
	endif;
	
	// Initialise the passport for the new transaction
	// In particular this sets passport myUser and myTerminal
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
		
	self.validateCurrentMachine(true);
	if app.myPassport.hasErrors then
		completedOK := true;
		return response;
	endif;
	
	if currentSession.myCurrentTerminal.radioTelemetry = null then
		completedOK := true;
		return response;
	endif;
	
	newQueue := currentSession.myCurrentTerminal.findQueue(_queueId);
	
	if newQueue = null then
		app.raiseCMException1(Err_InvalidQueue,_queueId,null,null);
		completedOK := true;
		return response;
	endif;
	
	machine:=currentSession.myCurrentMachine;
	//nothing to do if already in queue
	if newQueue = machine.myPrimaryQueue then
		completedOK := true;
		return response;
	endif;
	
	if machine.currentQueueTask &lt;&gt; null then
		app.raiseCMException(Change_queue_working_task,null,null);
		completedOK := true;
		return response;
	endif;
	
	self.setIgnoreWarnings(true);
	app.cmsBeginLoad(loadStateSet);
	pxyMachine := machine.pxyCreateUpdateProxy;
	app.cmsEndLoad(loadStateSet);
	app.myTrxUA.trxUpdateMachineQueue(pxyMachine, newQueue,app.myPassport);
	
	// Got to here, everything is ok
	completedOK := true;
	return response;
	

epilog
	// Tidy up any local transients
	// ...
	app.cmsEndLoad(loadStateSet);
	delete pxyMachine;
	
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;

end;</source>
        <Parameter name="_queueId" type="String"/>
        <ReturnType type="WS_Response"/>
    </JadeWebServicesMethod>
