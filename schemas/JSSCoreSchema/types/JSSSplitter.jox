    <JadeMethod name="repositionAfterResize" id="2485f800-8ea7-4b72-ac55-9091eef3388f">
        <updating/>
        <source>repositionAfterResize() updating;

vars
   	newLeft, newTop, newWidth, newHeight	: Real;

begin
	//inheritMethod();

	newLeft := self.left;
	newTop := self.top;
	newWidth := self.width;
	newHeight := self.height;

	if self.isLockRight then
		newLeft := (parent.width - newWidth - self.distanceFromRight).max(0);
	endif;
	
	if self.isLockBottom then
		newTop := (parent.height - newHeight - self.distanceFromBottom).max(0);
	endif;
	
	if self.isStretchWidth then
		newWidth := (parent.width - newLeft - self.distanceFromRight).max(0);
	endif;
	
	if self.isStretchHeight then
		newHeight := (parent.height - newTop - self.distanceFromBottom).max(0);
	endif;

	if newLeft &lt;&gt; self.left or newTop &lt;&gt; self.top or newWidth &lt;&gt; self.width or newHeight &lt;&gt; self.height then
		self.move(newLeft, newTop, newWidth, newHeight);
		self.resizeContents;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="resizeChildren" id="f3dc5e71-278b-4bd4-bd55-984ce0c9b391">
        <source>resizeChildren(pParent : Window) protected;
// ---------------------------------------------------------------------------
// Created:     16 November 2000 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	controlIndex	: Integer;
	theControl		: Control;
	
begin

	foreach controlIndex in 1 to form.controlCount do
		theControl := form.controls(controlIndex);
		
		if theControl.parent = pParent then
//			theControl.cnEcResizeContents();
			theControl.sendMsg("jssfmResizeContents");
		endif;
	endforeach;

end;</source>
        <access>protected</access>
        <Parameter name="pParent" type="Window"/>
    </JadeMethod>
    <JadeMethod name="resizeChildrenAndSplitter" id="59dc5195-020a-4ce7-8820-dd3cc429f300">
        <source>resizeChildrenAndSplitter() protected;
//Purpose:		Positions and sizes the left and right controls, and the vertical splitter
//				on the control
//
//14 Nov 00	cnwrs2	Add code to set seperation to 0 if splitter is not visible.
vars
	theLeftControl		: Control;
	theRightControl		: Control;
	theTopControl		: Control;
	theBottomControl	: Control;
	ratio				: Decimal[4,2];
	separation			: Integer;
	
	startTime				: Integer;
	endTime					: Integer;
	bcommittedTransactions	: Integer;
	babortedTransactions	: Integer;
	bgetObjects				: Integer;
	bqueuedLocks			: Integer;
	bcreateObjects			: Integer;
	bdeleteObjects			: Integer;
	bupdateObjects			: Integer;
	blockObjects			: Integer;
	bunlockObjects			: Integer;
	bbeginNotifications		: Integer;
	bendNotifications		: Integer;
	bdeliveredNotifications	: Integer;
	bserverMethodExecutions	: Integer;
	fcommittedTransactions	: Integer;
	fabortedTransactions	: Integer;
	fgetObjects				: Integer;
	fqueuedLocks			: Integer;
	fcreateObjects			: Integer;
	fdeleteObjects			: Integer;
	fupdateObjects			: Integer;
	flockObjects			: Integer;
	funlockObjects			: Integer;
	fbeginNotifications		: Integer;
	fendNotifications		: Integer;
	fdeliveredNotifications	: Integer;
	fserverMethodExecutions	: Integer;
	
begin
//	system.getStatistics(bcommittedTransactions,
//						babortedTransactions,
//						bgetObjects,
//						bqueuedLocks,
//						bcreateObjects,
//						bdeleteObjects,
//						bupdateObjects,
//						blockObjects,
//						bunlockObjects,
//						bbeginNotifications,
//						bendNotifications,
//						bdeliveredNotifications,
//						bserverMethodExecutions);
//	startTime	:=	app.clock();

	ratio		:=	self.leftToRightRatio / 100;

	if self.isSplitHorizontal then
	 	// Handle horizontal split
		
		theTopControl		:=	self.myLeftControl;
		theBottomControl	:=	self.myRightControl;
		
		if self.myHorizontalSplitter = null or (not self.myHorizontalSplitter.visible) then
			separation	:=	0;
		else
			separation	:=	self.myHorizontalSplitter.height.Integer;
		endif;

		if theTopControl &lt;&gt; null then
			theTopControl.move(0, 0, self.clientWidth(), (self.clientHeight() * ratio) - (separation div 2));
			
			if theTopControl.class.name = self.class.name then
				theTopControl.sendMsg("jssfmResizeContents");
//				theTopControl.JSSFMSplitContainer.jssfmResizeContents();
			endif;
			
			if theTopControl.isKindOf(Frame) then
				self.resizeChildren(theTopControl);
			endif;
		endif;

		if (theBottomControl &lt;&gt; null) and (theTopControl &lt;&gt; null) then
			theBottomControl.move(theTopControl.left, theTopControl.height + separation, theTopControl.width, self.clientHeight() - theTopControl.height - separation);
			
			if theTopControl.class.name = self.class.name then
				theBottomControl.sendMsg("jssfmResizeContents");
//				theBottomControl.JSSFMSplitContainer.jssfmResizeContents();
			endif;
			
			if theBottomControl.isKindOf(Frame) then
				self.resizeChildren(theBottomControl);
			endif;
		endif;

		if (self.myHorizontalSplitter &lt;&gt; null) and (theTopControl &lt;&gt; null) then
			self.myHorizontalSplitter.move(theTopControl.left, theTopControl.top + theTopControl.height, theTopControl.width, self.myHorizontalSplitter.height);
			self.myHorizontalSplitter.zOrder(1);
		endif;

	else
		// Handle vertical split
		
		theLeftControl	:=	self.myLeftControl;
		theRightControl	:=	self.myRightControl;
		
		if self.myVerticalSplitter = null or (not self.myVerticalSplitter.visible) then
			separation	:=	0;
		else
			separation	:=	self.myVerticalSplitter.width.Integer - 5;
		endif;

		if theLeftControl &lt;&gt; null then
			theLeftControl.move(0, 0, (self.clientWidth() * ratio) - (separation div 2), self.clientHeight());
			
			if theLeftControl.class.name = self.class.name then
				theLeftControl.sendMsg("jssfmResizeContents");
//				theLeftControl.JSSFMSplitContainer.jssfmResizeContents();
			endif;
			
			if theLeftControl.isKindOf(Frame) then
				self.resizeChildren(theLeftControl);
			endif;
		endif;

		if (theRightControl &lt;&gt; null) and (theLeftControl &lt;&gt; null) then
			theRightControl.move(theLeftControl.width + separation, theLeftControl.top, self.clientWidth() - theLeftControl.width - separation, theLeftControl.height);
			
			if theLeftControl.class.name = self.class.name then
				theRightControl.sendMsg("jssfmResizeContents");
//				theRightControl.JSSFMSplitContainer.jssfmResizeContents();
			endif;
			
			if theRightControl.isKindOf(Frame) then
				self.resizeChildren(theRightControl);
			endif;
		endif;

		if (self.myVerticalSplitter &lt;&gt; null) and (theLeftControl &lt;&gt; null) then
			self.myVerticalSplitter.move(theLeftControl.left + theLeftControl.width, theLeftControl.top, self.myVerticalSplitter.width, theLeftControl.height.min(theRightControl.height));
			self.myVerticalSplitter.zOrder(1);
		endif;

	endif;
//epilog
//	endTime	:=	app.clock();
//	
//	system.getStatistics(fcommittedTransactions,
//						fabortedTransactions,
//						fgetObjects,
//						fqueuedLocks,
//						fcreateObjects,
//						fdeleteObjects,
//						fupdateObjects,
//						flockObjects,
//						funlockObjects,
//						fbeginNotifications,
//						fendNotifications,
//						fdeliveredNotifications,
//						fserverMethodExecutions);
//	
//	write self.name &amp; " resize done in " &amp; ((endTime - startTime) / 1000).String &amp; " seconds.";
//	write "Number of committed transactions.........................: " &amp; (fcommittedTransactions - bcommittedTransactions).String;
//	write "Number of aborted transactions...........................: " &amp; (fabortedTransactions - babortedTransactions).String;
//	write "Number of getObject operations performed.................: " &amp; (fgetObjects - bgetObjects).String;
//	write "Number of queuedLock operations performed................: " &amp; (fqueuedLocks - bqueuedLocks).String;
//	write "Number of createObject operations performed..............: " &amp; (fcreateObjects - bcreateObjects).String;
//	write "Number of deleteObject operations performed..............: " &amp; (fdeleteObjects - bdeleteObjects).String;
//	write "Number of updateObject operations performed..............: " &amp; (fupdateObjects - bupdateObjects).String;
//	write "Number of lockObject operations performed................: " &amp; (flockObjects - blockObjects).String;
//	write "Number of unlockObject operations performed..............: " &amp; (funlockObjects - bunlockObjects).String;
//	write "Number of beginNotification operations performed.........: " &amp; (fbeginNotifications - bbeginNotifications).String;
//	write "Number of endNotification operations performed...........: " &amp; (fendNotifications - bendNotifications).String;
//	write "Number of notifications that were sent...................: " &amp; (fdeliveredNotifications - bdeliveredNotifications).String;
//	write "Number of methods executed in the server node operations.: " &amp; (fserverMethodExecutions - bserverMethodExecutions).String;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="resizeContents" id="b459d86c-2165-43a5-8ab6-d3ecbdbc98bf">
        <updating/>
        <source>resizeContents() updating;

vars

begin
	self.resizeChildrenAndSplitter();
end;</source>
    </JadeMethod>
    <JadeMethod name="setDistanceFromBottom" id="82e0fc1a-ef8e-45fa-920e-3fdd0271fa0d">
        <updating/>
        <source>setDistanceFromBottom(value: Real) updating;

begin


epilog	
	if self.distanceFromBottom &lt;&gt; value then 
		self.distanceFromBottom := value;
	endif;
end;</source>
        <Parameter name="value" type="Real"/>
    </JadeMethod>
    <JadeMethod name="setDistanceFromRight" id="b642b8f2-b953-4b9d-9390-9e35c0ed2e3c">
        <updating/>
        <source>setDistanceFromRight(value: Real) updating;

begin

epilog	
	if self.distanceFromRight &lt;&gt; value then 
		self.distanceFromRight := value;
	endif;
end;</source>
        <Parameter name="value" type="Real"/>
    </JadeMethod>
    <JadeMethod name="setLeftToRightRatio" id="3ece1d8b-178c-406a-b5d4-a2432ad6b9d1">
        <updating/>
        <source>setLeftToRightRatio(value : Integer) updating;
//Purpose:		Update the ratio (in percent) that the left control uses of the parent
//				control width

begin
	if value &lt;&gt; self.leftToRightRatio then
		self.leftToRightRatio := value;
		self.resizeChildrenAndSplitter();
	endif;
end;</source>
        <Parameter name="value" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setupChildControls" id="1e737b56-8de0-4241-84d5-f89abf49e82c">
        <updating/>
        <source>setupChildControls() updating;
// Purpose:	Setup the left and right child controls the children of the receiver, and
//			setup the starting ratio to reflect the painted ratios of the visible child 
//			controls.
//
// Note:	The container control only supports two child controls.
vars
	theControl		: Control;
	controlIndex	: Integer;
	totalSize		: Real;
	errorMessage	: String;

begin
	// First delete any existing splitter bars
	if self.myVerticalSplitter &lt;&gt; null then
		delete self.myVerticalSplitter;
	endif;

	if self.myHorizontalSplitter &lt;&gt; null then
		delete self.myHorizontalSplitter;
	endif;

	// Forget existing controls
	self.myLeftControl	:=	null;
	self.myRightControl	:=	null;

	// Look through the controls of the form for children of self
	foreach controlIndex in 1 to self.form.controlCount do
		theControl := self.form.controls(controlIndex);
		
		if theControl.isKindOf(ScrollBar) or
		   theControl.isKindOf(JSSVerticalSplitter) or
		   theControl.isKindOf(JSSHorizontalSplitter) then
		   	continue;
		endif;

		if (not theControl.isKindOf(ScrollBar)) then		// ignore JASTablePlus scroll bars
			if theControl.parent = self then
				if self.myLeftControl = null then
		    		self.myLeftControl := theControl;
		    	else
		    		if self.myRightControl = null then
			    		if (not self.isSplitHorizontal)
			    		and (theControl.left &gt; self.myLeftControl.left)
			    		or self.isSplitHorizontal
			    		and (theControl.top &gt; myLeftControl.top)
			    		then
			    			self.myRightControl	:=	theControl;
			    		else
			    			self.myRightControl	:=	self.myLeftControl;
			    			self.myLeftControl	:=	theControl;
			    		endif;
					else
						errorMessage	:=	class.name &amp; '::' &amp; method.name &amp;
											"  Error&gt;&gt; you can only have 2 child controls.";
						app.msgBox(errorMessage, "Error", MsgBox_OK_Only);
					endif;
				endif;
			endif;
	 	endif;
	endforeach;

	if self.myRightControl = null then
		//JASFormException.raise_(6, "JASSplitContainer must have 2 child controls");
		// write class.name &amp; '::' &amp; method.name &amp; '  Error&gt;&gt; you must have 2 child controls';
		// return added to avoid null object ref if cloning at run time (RJS 7Feb01)
		return;
	endif;

	if self.myLeftControl.visible and self.myRightControl.visible then
		// Setup the ratios of the children based on their current widths/heights if not
		//  defined in Painter
	 	if self.leftToRightRatio = 0 then
	 		if self.isSplitHorizontal then
	 			totalSize				:=	self.myLeftControl.height + self.myRightControl.height;
				self.leftToRightRatio	:=	(self.myLeftControl.height / totalSize * 100).Integer;
 			else
				totalSize				:=	self.myLeftControl.width + self.myRightControl.width;
				self.leftToRightRatio	:=	(self.myLeftControl.width / totalSize * 100).Integer;
			endif;
 		endif;
 	else
 		if self.myLeftControl.visible then
 			self.leftToRightRatio	:=	100;
 		else
			self.leftToRightRatio	:=	0;
		endif;
	endif;
	
	// Following was moved from windowCreated to allow for control to be cloned at runtime (RJS 7Feb01).
	if (self.myLeftControl &lt;&gt; null)
	and self.myLeftControl.visible
	and (self.myRightControl &lt;&gt; null)
	and self.myRightControl.visible
	then
		self.initializeSplitter();
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="showLeftControl" id="69cc3c65-38d1-4036-acd7-17a539f5dbb9">
        <updating/>
        <source>showLeftControl(value : Integer) updating;
// ---------------------------------------------------------------------------
// Created:     14 November 2000 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	
	if self.isSplitHorizontal then
		self.myHorizontalSplitter.visible := true;
	else
		self.myVerticalSplitter.visible := true;
	endif;

	self.myLeftControl.visible := true;

	self.setLeftToRightRatio(value);

end;</source>
        <Parameter name="value" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="showRightControl" id="467aa844-48f5-4ebb-854d-85b1fe92fff3">
        <updating/>
        <source>showRightControl(value : Integer) updating;
// ---------------------------------------------------------------------------
// Created:     19 December 2000 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if self.isSplitHorizontal then
		self.myHorizontalSplitter.visible := true;
	else
		self.myVerticalSplitter.visible := true;
	endif;

	self.myRightControl.visible := true;

	self.setLeftToRightRatio(100 - value);

end;</source>
        <Parameter name="value" type="Integer"/>
    </JadeMethod>
    <ExternalMethod name="splitterMove" id="7516ebec-e265-4dec-9e1a-1dc39ceaeec9">
        <updating/>
        <entrypoint>CallControlEvent</entrypoint>
        <library name="jadpmap"/>
        <source>splitterMove(pSplitContainer: JSSSplitter input) is "CallControlEvent" in "jadpmap" updating, number = 1018;</source>
        <Parameter name="pSplitContainer" type="JSSSplitter" usage="input"/>
    </ExternalMethod>
    <JadeMethod name="windowCreated" id="0653566f-450c-4216-86f7-79a98f4c511a">
        <updating/>
        <source>windowCreated(cntrl: Control input; persistCntrl: Control) updating;

vars

begin
	inheritMethod(cntrl, persistCntrl);

	if self.isInPainter() then
		self.borderStyle := BorderStyle_Single;
	else	
		self.borderStyle := BorderStyle_None;
		self.setupChildControls;
// Moved to setupChildControls to allow for control to be cloned at runtime (RJS 7Feb01).
//		if (myLeftControl &lt;&gt; null) and myLeftControl.visible and (myRightControl &lt;&gt; null) and myRightControl.visible then
//			self.initializeSplitter;
//		endif;
		self.resizeChildrenAndSplitter;
	endif;

	self.transparent := false;
	self.backColor := Gray;

	if self.isLockRight or self.isStretchWidth then
 		self.distanceFromRight := persistCntrl.parent.width - persistCntrl.width - persistCntrl.left;
 	endif;

	if self.isLockBottom or self.isStretchHeight then
		self.distanceFromBottom := persistCntrl.parent.height - persistCntrl.height - persistCntrl.top;
	endif;
end;</source>
        <Parameter name="cntrl" type="Control" usage="input"/>
        <Parameter name="persistCntrl" type="Control"/>
    </JadeMethod>
