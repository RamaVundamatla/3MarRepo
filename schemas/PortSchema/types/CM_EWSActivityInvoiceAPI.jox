    <JadeMethod name="initialiseFromInvoiceAndDef" id="78704fe6-8274-4878-b9d9-692c378c12e9">
        <updating/>
        <source>initialiseFromInvoiceAndDef(_invoice : CM_Invoice; _def : CM_ExternalWebServiceDef; _statusStr : String) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 November 2023	navra1	Initial creation for TFS 54090 - EUP | EUP | Interface - MTN Invoicing Oracle &lt;&lt;54090&gt;&gt;(CR - 61356/Task - 61377)
16/9/24 	jlier1	TFS 65962 : CR 65949 NSW | Dynamic Integration Development
05 Jan 2026 navsp1  MTN-36449 MTN - EWS monitor form - Status is blank when Response is null
*/

vars

begin
	self.description:="InvoiceAPI send EWSActivityInvoiceAPI";
	
	if _invoice &lt;&gt; null then
		self.attemptNumber := _invoice.allEWSInvoiceAPIActivities.size() + 1;
		self.myInvoice := _invoice;
		self.myTerminal := _invoice.myTerminal;
		self.description := self.description &amp; Space &amp; self.myInvoice.sequenceNum.String;	
	endif;
	
	if _def &lt;&gt; null then
		self.interfaceName := ExternalWebServiceInvoiceAPI;
	endif;
	
	self.fullMsgStatusStr := _statusStr;
    self.status           := _statusStr;              //MTN-36449
	self.myRoot:=app.myRoot;
	self.myExtWebserviceDef := _def;
	self.createdUser := app.getMyUserCode();
	self.created := app.actualTimeServer();
epilog

end;</source>
        <Parameter name="_invoice" type="CM_Invoice"/>
        <Parameter name="_def" type="CM_ExternalWebServiceDef"/>
        <Parameter name="_statusStr" type="String"/>
    </JadeMethod>
    <JadeMethod name="isInvoice" id="5a185d4f-62fa-446b-903d-4cedd803b6c5">
        <source>isInvoice(): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
09 July 2024	navcs2	Defect 65102: EUP - EWS monitor - Unable to view any Invoice API messages

*/

vars

begin
	return true;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="08548e3d-fc32-44bd-9721-f6b98f2318b3">
        <source>pxyCreateUpdateProxy(): SelfType;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 December 2023	navra1	Initial creation for TFS 54090 CR 61414 - Task 61416 &amp; 61415  - 5th Dec 2023

*/

vars
	pxyObj : SelfType;
	child : CM_EWSActivityInvoiceAPIParts;
begin
	pxyObj := inheritMethod();
	
	pxyObj.myInvoice := self.myInvoice;
	
	self.allEWSMessageParts.copy(pxyObj.allEWSMessageParts);
	
	return pxyObj;
	
epilog

end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="cda088ca-df9c-4edc-a998-c5fda316b628">
        <updating/>
        <source>setForCreate(_proxy: SelfType) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 November 2023	navra1	Initial creation for TFS 54090 - EUP | EUP | Interface - MTN Invoicing Oracle &lt;&lt;54090&gt;&gt;(CR 61356/Task 61377)

*/

vars

begin
	inheritMethod(_proxy);
	
	self.attemptNumber := _proxy.attemptNumber;
	self.myInvoice := _proxy.myInvoice;
	self.request := _proxy.request;
	self.response := _proxy.response;
	self.responseCode := _proxy.responseCode;	
	self.fullMsgStatusStr := _proxy.fullMsgStatusStr;	
	self.myInvoice :=_proxy.myInvoice;
epilog

end;</source>
        <Parameter name="_proxy" type="SelfType"/>
    </JadeMethod>
