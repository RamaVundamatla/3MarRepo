    <JadeMethod name="doResize" id="56a44e5d-a53b-467a-8642-fa86ae25d76a">
        <updating/>
        <source>doResize() updating;
// ---------------------------------------------------------------------------
// Created:     15 July 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
begin
	inheritMethod();

	self.btnSave.top := self.clientHeight - VerticalSpacing - self.btnSave.height;
	self.btnCancel.top := self.btnSave.top;
	self.btnCancel.left := self.tblMain.left + self.tblMain.width - self.btnCancel.width;
	self.btnSave.left := self.btnCancel.left - self.btnCancel.width - HorizontalSpacing;	

	self.tblMain.move(self.tblMain.left, self.tblMain.top, self.width - WinRightMargin-WinLeftMargin, self.btnSave.top - WinBottomMargin-self.tblMain.top);
	self.tblMain.cnEcResizeContents();

end;</source>
    </JadeMethod>
    <JadeMethod name="doSave" id="6f4b5ba6-6886-4519-a2b2-495c527f3516">
        <updating/>
        <source>doSave() updating;
//--------------------------------------------------------------
//Created: 16 January 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	damaged			: Boolean;
	remarks,
	reeferRemarks	: String;
	ct : CM_CargoType;
	totalQuantity  : Integer;
	weightRequested  : Decimal[14,4];
	yardRequest 	: CM_YardRequest;
	wle 			: CM_YardWLE;
	theResult : Integer;	//13 Jan 2020 NDL	TFS 46815
begin

	if self.myCurrentObject = null then
		return;
	endif;
	app.mousePointer := MousePointer_HourGlass;
	
	remarks := self.tblMain.accessCell(1,2).text;
	
	if self.myCurrentObject.isKindOf(CM_YardRequest) then
			yardRequest:= self.myCurrentObject.CM_YardRequest;	
	elseif self.myCurrentObject.isKindOf(CM_YardWLE) then
		wle:=self.myCurrentObject.CM_YardWLE;
		yardRequest:=self.myCurrentObject.CM_YardWLE.myRequest.CM_YardRequest;
	endif;
	
	if yardRequest &lt;&gt; null then
		if self.tblMain.rows = 2 then	
			//epr 34406 18/6/14 bulk changes
			ct:= yardRequest.getCargoType;
			if ct &lt;&gt; null then
				if ct.isBreakBulkMulti then
					totalQuantity:=self.tblMain.accessCell(2,2).text.Integer;
				elseif ct.isBulkByWeight then
					weightRequested:= self.tblMain.accessCell(2,2).cellControl.CMUI_MeasurementTable.getConvertedValue();
				elseif ct.isBulkByVolume then
					weightRequested:= self.tblMain.accessCell(2,2).cellControl.CMUI_MeasurementTable.getConvertedValue() * yardRequest.getDensityFromCargoType ;
				endif;
			endif;
		endif;
	endif;
	
	//13 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do

		if self.myCurrentObject.isKindOf(CM_TrackedItem) then
			if self.tblMain.accessCell(2,2).text = '1' then
				damaged := true;
			endif;
			if self.myCurrentObject.isKindOf(CM_Container) then
				reeferRemarks := self.tblMain.accessCell(3,2).text;
			endif;
			app.myTrxUA.trxUpdateTIRemarksDamage(self.myCurrentObject.CM_TrackedItem, remarks, reeferRemarks, damaged, app.myPassport);
		elseif self.myCurrentObject.isKindOf(CM_VoyageJob) then
			app.myTrxUA.trxUpdateVoyageJobRemarks(self.myCurrentObject.CM_VoyageJob, remarks, app.myPassport);
		elseif self.myCurrentObject.isKindOf(CM_Wagon) then
			app.myTrxUA.trxUpdateWagonRemarks(self.myCurrentObject.CM_Wagon, remarks, app.myPassport);
		elseif self.myCurrentObject.isKindOf(CM_Train) then
			app.myTrxUA.trxUpdateTrainRemarks(self.myCurrentObject.CM_Train, remarks, app.myPassport);	
		elseif self.myCurrentObject.isKindOf(CM_Voyage) then
			remarks := self.txtRemarks.text;
			app.myTrxUA.trxUpdateVoyageRemarks(self.myCurrentObject.CM_Voyage, remarks, app.myPassport);	
		elseif self.myCurrentObject.isKindOf(CM_DeckItemLayout) then
			remarks := self.txtRemarks.text.trimBlankCharacters();
			app.myTrxUA.trxUpdateROROGraphicRemarks(self.myCurrentObject.CM_DeckItemLayout, remarks, app.myPassport);
		elseif self.myCurrentObject.isKindOf(CM_DeckVoyage) then
			app.myTrxUA.trxUpdateRORODeckRemarks(self.myCurrentObject.CM_DeckVoyage, remarks, app.myPassport);
		elseif self.myCurrentObject.isKindOf(CM_BayVoyage) then
			remarks := self.txtRemarks.text;
			app.myTrxUA.trxUpdateBayRemarks(self.myCurrentObject.CM_BayVoyage, remarks, app.myPassport);
		elseif self.myCurrentObject.isKindOf(CM_DeckItem) then
			remarks := self.txtRemarks.text;
			app.myTrxUA.trxUpdateDeckItemRemarks(self.myCurrentObject.CM_DeckItem, remarks, app.myPassport);
		elseif yardRequest &lt;&gt; null then	
			app.myTrxUA.trxUpdateYardRequestRemarks(yardRequest, remarks,wle,totalQuantity,weightRequested, app.myPassport);
		endif;
	
		if app.myPassport.trxCompletedOK then
			break;
		else
			theResult := app.showErrorWarningDialog('Remarks', app.myPassport, ErrWarnMode_AddUpdate);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		break;
	
	endwhile;
	
	
	
epilog
	app.mousePointer := MousePointer_Default;
end;</source>
    </JadeMethod>
    <JadeMethod name="initTable" id="b1c06ec0-d7fb-4e42-95eb-ecebcdb20171">
        <source>initTable();
// ---------------------------------------------------------------------------
// Created:		February  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	idx : Integer;
	ti : CM_TrackedItem;
	ct : CM_CargoType;
	controlId : Integer;
	measureControl	: CMUI_MeasurementTable;
	yardRequest : CM_YardRequest;
	wle : CM_WorkListEntry;
begin

	self.tblMain.rows := 0;	
	self.tblMain.columns := 2;
	self.tblMain.fixedColumns := 1;
	self.tblMain.fixedRows := 0;

	self.tblMain.accessColumn(1).width := 100;
	self.tblMain.accessedColumn.backColor := self.colorHeadingColumn;
	
	idx := self.tblMain.addItem(app.getErrorString(Remarks_GC));
	self.tblMain.accessRow(idx).alignment := Table.Alignment_Left_Top;
	self.tblMain.accessedRow.height := 50; // PAR 19710
	self.tblMain.accessCell(idx,2).inputType := Table.InputType_TextBox;
	self.tblMain.accessedCell.wordWrap := true; // PAR 19710
	self.tblMain.row := idx;
	self.tblMain.column := 2;
	self.tblMain.accessCell(idx,2).selected := true;
	self.tblMain.setFocus();		

	
	//epr par 32509 8/10/13
	if self.myCurrentObject.isKindOf(CM_WorkListEntry)  
		and not self.myCurrentObject.CM_WorkListEntry.isReceipt 
		and not self.myCurrentObject.CM_WorkListEntry.status = WLE_COMPLETED then //epr par 34880 18/9/14
		yardRequest:=self.myCurrentObject.CM_YardWLE.myRequest.CM_YardRequest;
		ct :=yardRequest.getCargoType;
		
		if ct &lt;&gt; null then
			controlId := 13000;
			if  ct.isBreakBulkMulti then
				idx := self.tblMain.addItem(app.getErrorString(CM_Quantity));
				self.tblMain.accessRow(idx).alignment := Table.Alignment_Left_Top;
				self.tblMain.accessCell(idx,2).inputType := Table.InputType_TextNumeric;
			elseif ct.isBulkByWeight then
				idx := self.tblMain.addItem(app.getErrorString(CM_Weight));
				measureControl := self.tblMeasurement.loadControl(controlId).CMUI_MeasurementTable;
				measureControl.visible := true;
				measureControl.name := app.getErrorString(CM_Weight);
				measureControl.setMeasurementType(Type_Weight);
				measureControl.setHeading(self.tblMain.name);	//31 Mar 2014	NDL	Par 33356
				self.allMeasurementControls.add(measureControl);
				measureControl.setRowName(app.getErrorString(CM_Weight));
				measureControl.setValues( " " &amp; ct.myWeightMeasurementType.shortName);
				self.tblMain.setControl(idx, measureControl);
			elseif ct.isBulkByVolume then
				idx := self.tblMain.addItem(app.getErrorString(CM_Volume));
				measureControl := self.tblMeasurement.loadControl(controlId).CMUI_MeasurementTable;
				measureControl.visible := true;
				measureControl.name := app.getErrorString(CM_Volume);
				measureControl.setMeasurementType(Type_Volume);
				measureControl.setHeading(self.tblMain.name);	//31 Mar 2014	NDL	Par 33356
				self.allMeasurementControls.add(measureControl);
				measureControl.setRowName(app.getErrorString(CM_Volume));
				measureControl.setValues(" " &amp; ct.myVolumeMeasurementType.shortName  );
				self.tblMain.setControl(idx, measureControl);
			endif;
		
		endif;
	endif;
	
	if self.myCurrentObject.isKindOf(CM_TrackedItem) then
		idx := self.tblMain.addItem(app.getErrorString(Damaged));
		self.tblMain.accessCell(idx,2).inputType := Table.InputType_CheckBox;
		
		if self.myCurrentObject.isKindOf(CM_Container) then
			idx := self.tblMain.addItem(app.getErrorString(Reefer_remarks));
			self.tblMain.accessRow(idx).alignment := Table.Alignment_Left_Top;
			self.tblMain.accessCell(idx,2).inputType := Table.InputType_TextBox;
		endif;
	endif;
	

end;</source>
    </JadeMethod>
