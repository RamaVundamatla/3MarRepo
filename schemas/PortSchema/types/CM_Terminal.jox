    <JadeMethod name="availableLocationsForType" id="f260ec09-d3c5-4e06-9711-f9fee092588e">
        <source>availableLocationsForType(_cmifSearchTypes : CMIF_SearchTypes; _locationsArray : Collection input; _terminalAreaType : Integer);

vars
	iter	: Iterator;
	ta		: CM_TerminalArea;
	ls		: Boolean;
begin

	_locationsArray.clear;

	app.cmsBeginLoad(ls);
	// Setup location combo box.
	iter := self.allTerminalAreas.createIterator;
	while iter.next(ta) do
		if ta.type &lt;&gt; _terminalAreaType then
			continue;
		endif;
		ta.availableLocationsForType(_cmifSearchTypes, _locationsArray);
	endwhile;

epilog
	app.cmsEndLoad(ls);
	delete iter;
end;</source>
        <Parameter name="_cmifSearchTypes" type="CMIF_SearchTypes"/>
        <Parameter name="_locationsArray" type="Collection" usage="input"/>
        <Parameter name="_terminalAreaType" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="availableLocationsForTypeSub" id="d1727b76-65d1-41bc-b615-b6e9dabdcbd0">
        <source>availableLocationsForTypeSub(_cmifSearchTypes : CMIF_SearchTypes; _locations : Collection input; _terminalAreaType : Integer);

vars
	iter		: Iterator;
	ta			: CM_TerminalArea;

begin

	// Setup location combo box.
	iter := self.allTerminalAreas.createIterator;
	while iter.next(ta) do
		if ta.type &lt;&gt; _terminalAreaType then
			continue;
		endif;
		ta.availableLocationsForTypeSub(_cmifSearchTypes, _locations);
	endwhile;

epilog
	delete iter;

end;</source>
        <Parameter name="_cmifSearchTypes" type="CMIF_SearchTypes"/>
        <Parameter name="_locations" type="Collection" usage="input"/>
        <Parameter name="_terminalAreaType" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="bolInNextSeqNumber" id="52b6831d-7f09-4fb2-bff1-6fb468275b94">
        <methodInvocation>mapping</methodInvocation>
        <source>bolInNextSeqNumber(set: Boolean; _value: String io) mapping;
/*
----------   ----------  --------------------------------------------------
Created:	08 June 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
constants
	KeyDesc = 'BOL In Sequence Number';
vars
	theKeySeries 	: CM_KeySeries;
	seriesKey		: CM_SeriesKey;
	prefix,
	suffix 			: String;
	root 			: Integer;	
	keyLocked		: Boolean;
	
begin

	if set then
		app.raiseSetVirtualError(class.name, method.name);	
		return;
	endif;
	
	//17 May 2012	NDL	Par 28193 - Being a mapping method this is
	// called from CardSchema when a system dump is being performed... 
	// If we are not in trans state, the crash caused by the 1048,
	// means we don't get the rest of the details for terminal in the dump
	if not self.isTransient then
		if not process.isInTransactionState then
			return;
		endif;
	endif;
	
	//th2 and dvb1 deciding to not prefix at this stage
	//prefix := self.code;
	
	theKeySeries := self.allKeySeriesByCode[SN_BOLInSeqNumber];
	
	if theKeySeries = null then
		create theKeySeries persistent;
		theKeySeries.set(SN_BOLInSeqNumber, KeyDesc, self);
		create seriesKey persistent;
		//everitt - seed 1000
		seriesKey.set(prefix, 1000);
		theKeySeries.nextKey := seriesKey;
	else
		seriesKey := theKeySeries.nextKey;
		if seriesKey.prefix &lt;&gt; prefix then
			seriesKey.set(prefix, 1);
		endif;
	endif;

	lock(theKeySeries, Reserve_Lock, Transaction_Duration, 5000);
	keyLocked := true;	//17 May 2012	NDL	Par 28193
	
	theKeySeries.reserve(app.computerName, process.signOnUserCode, prefix, root, suffix);
	theKeySeries.issue(app.computerName, process.signOnUserCode);

	_value := prefix &amp; root.String;	// &amp; suffix; not used at present.

epilog
	if keyLocked then	//17 May 2012	NDL	Par 28193
		unlock(theKeySeries);
	endif;
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="bolOutNextSeqNumber" id="68d60d01-b3dc-4559-af23-53318138d1ee">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <source>bolOutNextSeqNumber(set: Boolean; _value: String io) mapping, updating;
//--------------------------------------------------------------
//Created: 30 August 2002 By: cnwgd1
//--------------------------------------------------------------
constants
	KeyDesc = 'BOL Sequence Number';
vars
	theKeySeries 	: CM_KeySeries;
	seriesKey		: CM_SeriesKey;
	prefix,
	suffix 			: String;
	root 			: Integer;
	keyLocked		: Boolean;
begin

	if set then
		app.raiseSetVirtualError(class.name, method.name);	
		return;
	endif;
	
	//17 May 2012	NDL	Par 28193 - Being a mapping method this is
	// called from CardSchema when a system dump is being performed... 
	// If we are not in trans state, the crash caused by the 1048,
	// means we don't get the rest of the details for terminal in the dump
	if not self.isTransient then
		if not process.isInTransactionState then
			return;
		endif;
	endif;
	
	//prefix := self.getConfig(LogSeqNumberPrefix).String;
	prefix := self.code;
	
	theKeySeries := self.allKeySeriesByCode[SN_BOLOutSeqNumber];
	
	if theKeySeries = null then
		create theKeySeries persistent;
		theKeySeries.set(SN_BOLOutSeqNumber, KeyDesc, self);
		create seriesKey persistent;
		seriesKey.set(prefix, 1);
		theKeySeries.nextKey := seriesKey;
	else
		seriesKey := theKeySeries.nextKey;
		if seriesKey.prefix &lt;&gt; prefix then
			seriesKey.set(prefix, 1);
		endif;
	endif;

	lock(theKeySeries, Reserve_Lock, Transaction_Duration, 5000);
	keyLocked := true;	//17 May 2012	NDL	Par 28193

	theKeySeries.reserve(app.computerName, process.signOnUserCode, prefix, root, suffix);
	theKeySeries.issue(app.computerName, process.signOnUserCode);

	_value := prefix &amp; root.String;	// &amp; suffix; not used at present.

epilog
	if keyLocked then	//17 May 2012	NDL	Par 28193
		unlock(theKeySeries);
	endif;
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="boxAlreadyThereExceptionHdlr" id="677020c8-4cd0-4b7d-9ce3-4ceb53769402">
        <updating/>
        <source>boxAlreadyThereExceptionHdlr(exObj	:	Exception) :	Integer updating;
//This exception handler ONLY looks afyter the error reported by the move code
//thats says the box is already in the position allocated to it.
begin
	if exObj.errorCode = ERR_ALREADY_HERE then
		//--------------------
		//This is a harmless error in terms of tasks being cleanedup.
		//Simply ignore it at this stage
		//--------------------
		return Ex_Resume_Next	;	//Cannot Ex_Continue;!
	else
		//--------------------
		//Pass this back for someone else to handle
		//--------------------
		return Ex_Pass_Back	;
	endif;
end;</source>
        <Parameter name="exObj" type="Exception"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="buildLocationStatistics" id="63b456ea-f0eb-4abc-8e46-97e1a66e94aa">
        <source>buildLocationStatistics();
// --------------------------------------------------------------------------------
// Created:		05 November 2008 by cnwdad1:2
//
// Purpose:		Refer to superclass implementation.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	c20Free				: Integer;
	c20PlannedIn		: Integer;
	c20PlannedOut		: Integer;
	c20Projected		: Integer;
	c20QueuedIn			: Integer;
	c20QueuedOut		: Integer;
	c20Total			: Integer;
	c20Used				: Integer;
	c30Free				: Integer;
	c30PlannedIn		: Integer;
	c30PlannedOut		: Integer;
	c30Projected		: Integer;
	c30QueuedIn			: Integer;
	c30QueuedOut		: Integer;
	c30Total			: Integer;
	c30Used				: Integer;
	c40Free				: Integer;
	c40PlannedIn		: Integer;
	c40PlannedOut		: Integer;
	c40Projected		: Integer;
	c40QueuedIn			: Integer;
	c40QueuedOut		: Integer;
	c40Total			: Integer;
	c40Used				: Integer;
	c45Free				: Integer;
	c45PlannedIn		: Integer;
	c45PlannedOut		: Integer;
	c45Projected		: Integer;
	c45QueuedIn			: Integer;
	c45QueuedOut		: Integer;
	c45Total			: Integer;
	c45Used				: Integer;
	c53Free				: Integer;
	c53PlannedIn		: Integer;
	c53PlannedOut		: Integer;
	c53Projected		: Integer;
	c53QueuedIn			: Integer;
	c53QueuedOut		: Integer;
	c53Total			: Integer;
	c53Used				: Integer;
	statisticsObj		: CM_LocationStatistics;
	proxyStatsObj		: CM_LocationStatistics;
	gridStatsObj		: CM_LocationStatistics;
	allAreasObj			: CM_TAByIdDict;
	areaObj				: CM_TerminalArea;
	
begin
	if self.myLocationStatistics = null then
		create proxyStatsObj transient;
		proxyStatsObj.setParent(self);
		create statisticsObj  persistent;
		statisticsObj.setupForCreate(proxyStatsObj);
	else
		statisticsObj	:=	self.myLocationStatistics;
	endif;
	
	create allAreasObj transient;
	self.allTerminalAreas.copy(allAreasObj);

	exclusiveLock(self.myLocationStatistics);
	self.myLocationStatistics.clearSystemCounts();
	
	foreach areaObj in allAreasObj do
		gridStatsObj	:=	areaObj.myLocationStatistics;
		if gridStatsObj &lt;&gt; null then
			c20Free			:=	c20Free + gridStatsObj.c20Free;
			c20PlannedIn	:=	c20PlannedIn + gridStatsObj.c20PlannedIn;
			c20PlannedOut	:=	c20PlannedOut + gridStatsObj.c20PlannedOut;
			c20Projected	:=	c20Projected + gridStatsObj.c20Projected;
			c20QueuedIn		:=	c20QueuedIn + gridStatsObj.c20QueuedIn;
			c20QueuedOut	:=	c20QueuedOut + gridStatsObj.c20QueuedOut;
			c20Total		:=	c20Total + gridStatsObj.c20Total;
			c20Used			:=	c20Used + gridStatsObj.c20Used;
			c30Free			:=	c30Free + gridStatsObj.c30Free;
			c30PlannedIn	:=	c30PlannedIn + gridStatsObj.c30PlannedIn;
			c30PlannedOut	:=	c30PlannedOut + gridStatsObj.c30PlannedOut;
			c30Projected	:=	c30Projected + gridStatsObj.c30Projected;
			c30QueuedIn		:=	c30QueuedIn + gridStatsObj.c30QueuedIn;
			c30QueuedOut	:=	c30QueuedOut + gridStatsObj.c30QueuedOut;
			c30Total		:=	c30Total + gridStatsObj.c30Total;
			c30Used			:=	c30Used + gridStatsObj.c30Used;
			c40Free			:=	c40Free + gridStatsObj.c40Free;
			c40PlannedIn	:=	c40PlannedIn + gridStatsObj.c40PlannedIn;
			c40PlannedOut	:=	c40PlannedOut + gridStatsObj.c40PlannedOut;
			c40Projected	:=	c40Projected + gridStatsObj.c40Projected;
			c40QueuedIn		:=	c40QueuedIn + gridStatsObj.c40QueuedIn;
			c40QueuedOut	:=	c40QueuedOut + gridStatsObj.c40QueuedOut;
			c40Total		:=	c40Total + gridStatsObj.c40Total;
			c40Used			:=	c40Used + gridStatsObj.c40Used;
			c45Free			:=	c45Free + gridStatsObj.c45Free;
			c45PlannedIn	:=	c45PlannedIn + gridStatsObj.c45PlannedIn;
			c45PlannedOut	:=	c45PlannedOut + gridStatsObj.c45PlannedOut;
			c45Projected	:=	c45Projected + gridStatsObj.c45Projected;
			c45QueuedIn		:=	c45QueuedIn + gridStatsObj.c45QueuedIn;
			c45QueuedOut	:=	c45QueuedOut + gridStatsObj.c45QueuedOut;
			c45Total		:=	c45Total + gridStatsObj.c45Total;
			c45Used			:=	c45Used + gridStatsObj.c45Used;
			c53Free			:=	c53Free + gridStatsObj.c53Free;
			c53PlannedIn	:=	c53PlannedIn + gridStatsObj.c53PlannedIn;
			c53PlannedOut	:=	c53PlannedOut + gridStatsObj.c53PlannedOut;
			c53Projected	:=	c53Projected + gridStatsObj.c53Projected;
			c53QueuedIn		:=	c53QueuedIn + gridStatsObj.c53QueuedIn;
			c53QueuedOut	:=	c53QueuedOut + gridStatsObj.c53QueuedOut;
			c53Total		:=	c53Total + gridStatsObj.c53Total;
			c53Used			:=	c53Used + gridStatsObj.c53Used;
		endif;
	endforeach;

	statisticsObj.c20Free		:=	c20Free;
	statisticsObj.c20PlannedIn	:=	c20PlannedIn;
	statisticsObj.c20PlannedOut	:=	c20PlannedOut;
	statisticsObj.c20Projected	:=	c20Projected;
	statisticsObj.c20QueuedIn	:=	c20QueuedIn;
	statisticsObj.c20QueuedOut	:=	c20QueuedOut;
	statisticsObj.c20Total		:=	c20Total;
	statisticsObj.c20Used		:=	c20Used;
	statisticsObj.c30Free		:=	c30Free;
	statisticsObj.c30PlannedIn	:=	c30PlannedIn;
	statisticsObj.c30PlannedOut	:=	c30PlannedOut;
	statisticsObj.c30Projected	:=	c30Projected;
	statisticsObj.c30QueuedIn	:=	c30QueuedIn;
	statisticsObj.c30QueuedOut	:=	c30QueuedOut;
	statisticsObj.c30Total		:=	c30Total;
	statisticsObj.c30Used		:=	c30Used;
	statisticsObj.c40Free		:=	c40Free;
	statisticsObj.c40PlannedIn	:=	c40PlannedIn;
	statisticsObj.c40PlannedOut	:=	c40PlannedOut;
	statisticsObj.c40Projected	:=	c40Projected;
	statisticsObj.c40QueuedIn	:=	c40QueuedIn;
	statisticsObj.c40QueuedOut	:=	c40QueuedOut;
	statisticsObj.c40Total		:=	c40Total;
	statisticsObj.c40Used		:=	c40Used;
	statisticsObj.c45Free		:=	c45Free;
	statisticsObj.c45PlannedIn	:=	c45PlannedIn;
	statisticsObj.c45PlannedOut	:=	c45PlannedOut;
	statisticsObj.c45Projected	:=	c45Projected;
	statisticsObj.c45QueuedIn	:=	c45QueuedIn;
	statisticsObj.c45QueuedOut	:=	c45QueuedOut;
	statisticsObj.c45Total		:=	c45Total;
	statisticsObj.c45Used		:=	c45Used;
	statisticsObj.c53Free		:=	c53Free;
	statisticsObj.c53PlannedIn	:=	c53PlannedIn;
	statisticsObj.c53PlannedOut	:=	c53PlannedOut;
	statisticsObj.c53Projected	:=	c53Projected;
	statisticsObj.c53QueuedIn	:=	c53QueuedIn;
	statisticsObj.c53QueuedOut	:=	c53QueuedOut;
	statisticsObj.c53Total		:=	c53Total;
	statisticsObj.c53Used		:=	c53Used;

	self.myLocationStatistics.setUpdateTimestamp();
epilog
	delete proxyStatsObj;
	delete allAreasObj;
end;</source>
    </JadeMethod>
    <JadeMethod name="canDo" id="a7dab898-a1e6-43f2-a7e4-960b72db400b">
        <source>canDo(_doWhat : Integer) : Boolean;
// ---------------------------------------------------------------------------
// Created:     02 April 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	obj		: Object;
	tmpNum	: Integer;

begin

	if _doWhat &lt;= Mod_BaseView then
		return false;
	endif;

// all clients on v7 rs oct 2005
//	if app.isConverting then
		// no license check if converting
//		return true;
//	endif;
	
	tmpNum := _doWhat - Mod_BaseView;
		
	// need to call into license key schema
	obj := app.myCheckerObject;
	if obj = null then
		return false;
	endif;

	if self.licenseName = null then
		return false;
	endif;

	return obj.sendMsgWithParams('isLicensed', self.licenseName, ProductCode_JMT, tmpNum).Boolean;

end;</source>
        <Parameter name="_doWhat" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
