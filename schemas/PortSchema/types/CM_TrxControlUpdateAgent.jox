        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxUpdateCargoFreeStorageDays" id="0dd87ef3-c6ae-4a57-bb4b-11276ac6eaa0">
        <updating/>
        <source>trxUpdateCargoFreeStorageDays(	_terminal 		: CM_Terminal; 
								_storageDetails : CM_StorageDetail; //08/06/2023	navkc1	CR 58007 Task 58008
								_passport 	    : CM_Passport input) updating;

/*

Purpose:		Apply current free storage criteria to all on-site cargo to determine the new free storage days value
				Commits every 2 seconds with progress update and cancel.

Parameters:			

Return Value:		


Date		Who		Reason
05 Oct 2012	cnwjre1	Initial creation CCMS 1295
08 Jun 2023	navkc1	CR 58007 Task 58008: JADE - Storage Config - Audits
28 May 2024 navma1	Bug 64224: MTN - DeadLocks Caused by Future Actors
04 Jun 2024	navnk30 ChangeRequest 64384: MTN - Improving Applying Storage to cargo onsite
15 Jul 2024 navnk30	Defect 65066: MTN - Apply to cargo button not applying free storage to cargo as expected
*/
constants
	MaxTransactionTime = 2000;
vars
	lastCommit,
	now			: Decimal[20];
	numUpdated	: Integer;
	cmifMonitor	: CMIF_Monitor;
	ti			: CM_TrackedItem;

begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	//04.06.2024 navnk30 CR 64384 TASK 64396 START
	_passport.useTIDictDeferUpdate := true;
	_passport.useTITransactionDeferUpdate := true;
	_passport.useOfflineFutureActorDeferUpd := true;
	//04.06.2024 navnk30 CR 64384 TASK 64396 END

	cmifMonitor := _passport.myCMIFMonitor;
	lastCommit := app.relativeMachineTime();
	
	beginTransaction;
	foreach ti in _terminal.allOnsiteTIsByCargoTypeId do
		
		//08/06/2023	navkc1	CR 58007 Task 58008 - We have a storage detail, only apply to cargo that matches this
		if _storageDetails &lt;&gt; null then
			if ti.getMatchingFreeStorageDetail(null) &lt;&gt; _storageDetails then
				continue;
			endif;
		endif;
		
		
		ti.evaluateFreeStorageDays(null,true);  // TFS 2937 added null	//28.05.2024 navma1 #64224
		
		numUpdated := numUpdated + 1;
		now := app.relativeMachineTime();
		if now - lastCommit &gt; MaxTransactionTime then
			if (not _passport.noErrors) then
		    	return;
		    endif;
		    
		    _passport.doDeferredUpdates();
			app.cmsCommitTransaction(_passport);
			// Check for cancel outside transaction state
			
			if cmifMonitor &lt;&gt; null then
				cmifMonitor.partsDone := numUpdated;
				cmifMonitor.updateProgress('Cargo Free Days successfully updated:', cmifMonitor.partsInJob, cmifMonitor.partsDone);
				if (cmifMonitor.monitorReturnValue = CMIF_Monitor.MonitorReturnValue_Cancel)  then
					break;
				endif;
			endif;
			lastCommit := app.relativeMachineTime();
			//04.06.2024 navnk30 CR 64384 TASK 64396 START
			_passport.useTIDictDeferUpdate := true;
			_passport.useTITransactionDeferUpdate := true;
			_passport.useOfflineFutureActorDeferUpd := true;
			//04.06.2024 navnk30 CR 64384 TASK 64396 END
			beginTransaction;
		endif;
	endforeach;
	_passport.doDeferredUpdates();		//15.07.2024 navnk30 #65066
	if cmifMonitor &lt;&gt; null then
		cmifMonitor.partsDone := numUpdated;
		cmifMonitor.updateProgress('Cargo Free Days successfully updated:', cmifMonitor.partsInJob, cmifMonitor.partsDone);
	endif;
epilog
	self.finaliseActivityWithPassport(_passport);

end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_storageDetails" type="CM_StorageDetail"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxUpdateCargoGroupOperators" id="cdbc3769-4a4c-4792-bf65-b0cf1b0f4476">
        <updating/>
        <source>trxUpdateCargoGroupOperators(_cargoGroup : CM_CargoGroup; _passport : CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

