    <JadeMethod name="setProxy" id="90bb0995-843d-4c3e-9bb0-1192c21da4ea">
        <updating/>
        <source>setProxy(pCode, pDescription : String;_notAvailableForEntry:Boolean) updating;
// ---------------------------------------------------------------------------
// Created:     25 March 2002 by cnwdf1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
