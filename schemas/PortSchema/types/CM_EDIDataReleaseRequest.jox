        <source>canGetStatusFromEDITrackedItem(): Boolean;
/*
Date		Who		Reason
25 Jul 2013	cnwcs5	CCMS POL 2221 / par 32094(2)
*/
vars

begin
	return true;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="copyErrors" id="04f977a5-495f-4b2a-a36d-e87aaf9db656">
        <updating/>
        <source>copyErrors() updating;
/*
Date		Who		Reason
08/08/2013	cnwcs5	CCMS POL 2221 / par 32094(2)
*/
// 24 Jan 2014	cnwrs1	Par 32463 - reduce the journal activity from EDI
vars
	ediError		:CM_EDIError;
	trxError		:CM_Error;
	obj				:Object;
	ediTI			:CM_EDITrackedItem;
	gotException, keepErrors	:Boolean;
	status			:Integer;
	allErrorsMatched : Boolean;
	errorMatched : Boolean;
begin
	// first lets if the error list has changed if not we do nothing.
	if self.allErrorWarnings.size &lt;&gt; app.myPassport.allErrorWarnings.size then
		// if we dont have the same number of messages
		// dont try and match them up
		allErrorsMatched := false;
	else
		allErrorsMatched := true;
		// for each passport error see if we already have an existing matching pesistant error
		foreach trxError in app.myPassport.allErrorWarnings do
			errorMatched := false;
			foreach ediError in  self.allErrorWarnings do
				if trxError.errorCode = ediError.errorCode and
				   trxError.text = trxError.text and
				   trxError.warningOnly = trxError.warningOnly then
					errorMatched := true;
					break;
				endif;
			endforeach;
			if errorMatched = false then
				allErrorsMatched := false;
				break;
			endif;
		endforeach;
	endif;
	if allErrorsMatched then
		return;
	endif;
	//self.allErrorWarnings.purge();	// not know why this was missing have we been just adding and adding errors??
	
	// Note:  Ideally I would like to mark the errors themselves as needing to be kept
	// but this would require a reorg and we are patching this CCMS
	// if we have any EDI TIs with a status that means they will be skiped in 
	// subsequent runs then keep any errors associated with them
	on Exception do app.handleDeletedObject (exception, obj, gotException);
	
	foreach ediError in self.allErrorWarnings do
		obj := ediError.myUserObject;
		
		if obj &lt;&gt; null and obj.isKindOf (CM_EDITrackedItem) then	
			ediTI := obj.CM_EDITrackedItem;
			
			keepErrors := ediTI.getKeepPersistentErrors ;
						
			if gotException then
				// for next iteration
				gotException := false;
			elseif keepErrors then
				// keep this error				
				continue;
			endif;
		endif;
		// not an error we need to keep
		self.allErrorWarnings.remove(ediError);
		delete ediError;
	endforeach;
		
	// for each passport error create a persistent copy - even if we dont want to store all errors persistenly we do
	// need to keep those errors for EDI TIs that have been marked as skipped in this run
	foreach trxError in app.myPassport.allErrorWarnings do
		keepErrors := false;  
	
		// do we need to persist these errors for an EDI TI that will be skipped next run.
		obj := trxError.myUserObject;
	
		if obj &lt;&gt; null and obj.isKindOf (CM_EDITrackedItem) then
			ediTI 	:= obj.CM_EDITrackedItem;
			status	:= ediTI.status;
			
			if gotException then
				// really hope this does not happen
				gotException := false;
				
			else					
				if status = CM_EDITrackedItem.EDI_STATUS_SKIP_PROCESSING or
					status = CM_EDITrackedItem.EDI_STATUS_SKIP_PROCESSING_X then
					// these will never be reprocessed so if there are errors for them
					// in this run make sure we don't delete them in a subseuqnet run
					if not ediTI.getKeepPersistentErrors then
						ediTI.setKeepPersistentErrors (true); 
					endif;
					// need to persist errors as this EDi TI will not be procesed again and we dont want to loase the errors
					keepErrors := true;
				endif;
			endif;
		endif;
		
		if not keepErrors then
			// if we don't allow partial loading then all errors are persisted
			keepErrors := self.storePersistentErrors;  
			
		endif;
		
		if keepErrors then
			create ediError;
			
			ediError.set(trxError.errorCode, trxError.text, trxError.warningOnly, trxError.fieldName, trxError.myUserObject);
			
			self.allErrorWarnings.add(ediError);
		endif;
	endforeach;
epilog
	
end;</source>
    </JadeMethod>
    <JadeMethod name="createReleaseCMIFObjects" id="05df5c15-58d7-4d1a-b1ee-f7917573dead">
        <updating/>
        <source>createReleaseCMIFObjects(_coll :CMIF_TIObjectArray input; _passport :CM_Passport input):Boolean updating, protected;
/*
Date		Who		Reason
25 Jul 2013	cnwcs5	CCMS POL 2221 / par 32094
08/08/2013	cnwcs5	CCMS POL 2221 / par 32094(2)
28/08/2013	cnwcs5	CCMS POL 2221 / par 32094(3) - things found during qual
//23 Mar 2015	cnwrs1	Par 35827 - for error 88612 set the status to skip processing
// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
14 Sep 2016		cnwer1	TFS 2606 - refactored to verify 1 edi ti
20 Oct 2020	jlgmd1	TFS 50204	Refactor progress updates to superclass method
*/
vars
	dynaDict					:DynaDictionary;
	iter						:Iterator;
	ediTI						:CM_EDIReleaseRequestTI;
	action_old, relReqNo_old, 
	progressStr					:String;
	relReqType_old, newRelease	:Boolean;
	progressTS 					:TimeStamp;
	partsInJob, partsDone		:Integer;
	coparnRules					:CM_EDIPartyCoparnRules;
	errorSet 					:CM_ErrorSet;
	releaseByTypeOnly			: Boolean;
	hadSkipProcessing : Boolean;
begin	 
	create errorSet transient;
	create dynaDict transient;
	
	// get anything that is has not been dbloaded or skipped.
	self.setupDynaDictionary(dynaDict);
	
	iter	:= dynaDict.createIterator(); 
	
	if dynaDict.isEmpty() then
		return true;
	endif;
	
	ediTI			:= dynaDict.first().CM_EDIReleaseRequestTI;
	action_old		:= ediTI.messageMode;
	relReqType_old	:= ediTI.releaseByType;
	action_old		:= ediTI.messageMode;		

	
	// just get our coparn rules once - all send codes will be the same
	if self.isCoparnFile  then							// par 29402 may 2012
		coparnRules := self.getEDIPartyCoparnRules (ediTI.senderCode);
		
		if coparnRules &lt;&gt; null then
			releaseByTypeOnly := coparnRules.getRelByTypeOnly; //cnwrd1 par 34035
		endif;
	endif;

	partsInJob		:= dynaDict.size;
	partsDone		:= null;
	progressStr		:= app.getString(Verifying_Loaded_Details, partsInJob.display);
	progressTS		:= app.actualTimeServer();// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	
	self.updateProgress(progressTS, progressStr, partsInJob, partsDone, true, _passport);
	
	// create an interface object and populate it from each of the EDI items,
	// add each to the array of interface objects for validation later.
	while iter.next(ediTI) do 
		// go through all EDI tracked items
		partsDone			:= partsDone + 1;
		self.updateProgress(progressTS, progressStr, partsInJob, partsDone, false, _passport);
		
		// If we are processing the same release request number then the release request by type must be the same.
		newRelease	:= ediTI.releaseRequestNumber &lt;&gt; relReqNo_old;
		
		//cnwmc5 - 25 Feb 2014 - PAR 33496 - there doesn't seem to be any logical reason to not have delete's and add's for different releases in the same file..
		if not newRelease and action_old &lt;&gt; null then
			if (ediTI.messageMode = CM_EDITrackedItem.EDI_ACTION_DELETE
			and action_old &lt;&gt; CM_EDITrackedItem.EDI_ACTION_DELETE)
			or (action_old = CM_EDITrackedItem.EDI_ACTION_DELETE
			and ediTI.messageMode &lt;&gt; CM_EDITrackedItem.EDI_ACTION_DELETE)then
				app.raiseCMException(Cannot_Mix_EDI_Actions, ETRow_MessageMode, ediTI);
			endif;			
		endif;		
		
		if not releaseByTypeOnly then //cnwrd1 33790
			if not newRelease and ediTI.releaseByType &lt;&gt; relReqType_old then
				app.raiseCMException1(Attempting_Release_ByTypeAndId, ediTI.releaseRequestNumber, ETRow_ReleaseByType, ediTI);
				// stop the verify processing any further
				return false;
			endif;
		endif;
		
		//epr TFS 2606 refactored into method on ediTI we need to just verfiy and load one ediTI
		if not ediTI.verifyAndUpdateStatus(_coll,newRelease,errorSet,_passport) then
			continue;
		endif;
		
		if ediTI.status = CM_EDITrackedItem.EDI_STATUS_SKIP_PROCESSING_X then
			 hadSkipProcessing := true;
		endif;

		action_old		:= ediTI.messageMode;
		relReqNo_old	:= ediTI.releaseRequestNumber;
		relReqType_old	:= ediTI.releaseByType;
	endwhile;
	
	self.updateProgress(progressTS, progressStr, partsInJob, partsDone, true, _passport);
	
	if hadSkipProcessing then
		return false;
	endif;
	
	return true;
epilog
	// move all the errors back to the passport
	_passport.addErrorsFromSet (errorSet);	// par 29480

	delete iter;
	delete dynaDict;
	delete errorSet;
end;</source>
        <access>protected</access>
        <Parameter name="_coll" type="CMIF_TIObjectArray" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doCompletedStatusReset" id="2d3a6efc-62a5-49ef-947e-7b2d0cad833b">
        <source>doCompletedStatusReset(_proxy :CM_BulkRelease input) protected;
/*
Date		Who		Reason
21 Feb 2013	cnwcs5	Initial Creation - CCMS PNL 2243 / par 31185 
*/
vars
	release				:CM_BulkRelease;
	reserve, pxyReserve	:CM_ReserveDetail;
	isNew				:Boolean;
	ti					:CM_TrackedItem;
begin
	// par 31185 - if they have added new items to a completed release we may need to reset the status to Active
	release := _proxy.pxyGetRealObject;

	if release = null or release.status &lt;&gt; BR_COMPLETE then
		return;
	endif;
	
	if _proxy.status = BR_ACTIVE then
		// already reset
		return;
	endif;
	
	if _proxy.getTotalRequested &gt; release.getTotalRequested then
		// total has increased we want to reset the status
		_proxy.setStatus (BR_ACTIVE, false, false);
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_proxy" type="CM_BulkRelease" usage="input"/>
    </JadeMethod>
    <JadeMethod name="findBulkReleaseToUpdate" id="917d800d-7fa9-4906-8f68-70571149654c">
        <source>findBulkReleaseToUpdate(_ediTI : CM_EDIReleaseRequestTI; _cmifColl, _addColl, _updateColl, _deleteColl : ObjectSet input) : CM_BulkRelease protected;
// --------------------------------------------------------------------------------
// Created:		04 October 2010
//
// Purpose:		Returns a reference to the proxy Bulk Release to update by matching
//				the details of the EDI Tracked Item to the proxy Bulk Releases that
//				have already been created.
//
// Parameters:	_ediTI - A reference to the EDI Tracked Item object being processed.
//				_cmifColl - A reference to a collection of existing proxy Bulk Releases.
//				_addColl - A reference to a collection of proxy Bulk Releases to add.
//				_updateColl - A reference to a collection of proxy Bulk Releases to update.
//				_deleteColl - A reference to a collection of proxy Bulk Releases to delete.
//
// Returns:		A reference to a proxy Bulk Release, or null.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//				cnwdad1		Initial creation.
// 08/04/2011	cnwmh5		PAR #27347 - Add cmsEndLoad or endLoad to epilog so that if error occurs it will not leave it in beginLoad state
// 14/12/2011	cnwrs1		CCMS POL 2122 PAR 28696 - change to support 
// 15/03/2012	cnwcs5		par 29247 - take out bookong check
// 25/02/2013 	cnwcs5		CCMS PNL 2243 / Par 31185 - re-work
// 26 Jul 2013	cnwcs5		CCMS POL 2221 / par 32094
// 05/09/2013	cnwcs5		par 32321 - dont create proxy for deletes
// 26 Feb 2014	cnwmc5		PAR 33496 - added 'cmifDelete' because this was causing issues with the other cmif (local variable getting reused incorrectly)
//09 Sep 2014	cnwrs1		CCMS 2351 att Sequence to Release request 
// 03 Nov 2017	jlgrs1		TFS 5705 - SNO - EDIDataBooking Prenote release Req
// 08 Aug 2018	jlgmd1		TFS 39693 - JMT - Bulk Release deleting inconsistency between Bulk Release Form and EDI
// --------------------------------------------------------------------------------
vars
	realRelease		: CM_BulkRelease;
	proxy			: CM_BulkRelease;
	cmif,
	cmifDelete		: CMIF_EDIReleaseRequest;					//cnwmc5 - 26 Feb 2014 - PAR 33496
	object 			: Object;
	releaseNumber	: String;
	mode			: String;
	releaseItem : CM_ReserveDetail;
	found : Boolean;
	ediTrackedItem : CM_EDITrackedItem;
begin
	releaseNumber 	:= _ediTI.releaseRequestNumber;
	mode 			:= _ediTI.messageMode;

	
	// If this BR is going to be deleted, then don't bother doing anything.
	foreach object in _deleteColl do
		cmifDelete	:= object.CMIF_EDIReleaseRequest;			//cnwmc5 - 26 Feb 2014 - PAR 33496
		
		if cmifDelete.myBulkRelease.code = releaseNumber then	//cnwmc5 - 26 Feb 2014 - PAR 33496
			if cmifDelete.myReserveDetailDel = null then
				cmifDelete.allEDITIs.add(_ediTI);					//cnwmc5 - 26 Feb 2014 - PAR 33496
				return null;
			endif;
		endif;
		
		cmifDelete := null;										//cnwmc5 - 26 Feb 2014 - PAR 33496
	endforeach;

	// look for a CMIF for this release number - if we start to get big release files will need to revisit this
	foreach object in _cmifColl do
		if object.CMIF_EDIReleaseRequest.myBulkRelease.code = releaseNumber and
		   object.CMIF_EDIReleaseRequest.myReserveDetailDel = null then
			cmif := object.CMIF_EDIReleaseRequest;	
			
			if mode &lt;&gt; CM_EDITrackedItem.EDI_ACTION_DELETE then
				proxy	:= object.CMIF_EDIReleaseRequest.myBulkRelease;
			endif;
			
			break;
		endif;
	endforeach;
	
	realRelease	:=	self.getMyTerminal().getBulkReleaseFromCode(releaseNumber);

	// par 32321 - dont create proxy for a delete
	if mode &lt;&gt; CM_EDITrackedItem.EDI_ACTION_DELETE and (proxy = null or proxy.code &lt;&gt; _ediTI.releaseRequestNumber) then		
		if realRelease = null then
			create proxy transient;
		else
			beginLoad;
			proxy	:=	realRelease.pxyCreateUpdateProxy();
			endLoad;
		endif;
	endif;
		
	if cmif = null then
		create cmif transient;
		
		// par 32321 - set reference to real release for delete
		if mode = CM_EDITrackedItem.EDI_ACTION_DELETE then
			cmif.myBulkRelease	:= realRelease;
			if _ediTI.sequence &lt;&gt; null then
				found := false;
				foreach releaseItem in cmif.myBulkRelease.allReserveDetails do
					if releaseItem.sequence = _ediTI.sequence then
						cmif.myReserveDetailDel := releaseItem;
						found := true;
						break;
					endif;
				endforeach;
				if not found then
					ediTrackedItem := _ediTI;
					app.myTrxUA.trxUpdateEDITIStatus(ediTrackedItem, CM_EDITrackedItem.EDI_STATUS_SKIP_PROCESSING, app.myPassport);
					delete cmif;
					return null;
				endif;
			endif;
		else
			cmif.myBulkRelease 	:= proxy;
		endif;
		_cmifColl.add(cmif);
	endif;
	
	// we can have more then one EDI TI making up a single release
	cmif.allEDITIs.add (_ediTI);
	
	
	if mode = CM_EDITrackedItem.EDI_ACTION_ADD or mode = CM_EDITrackedItem.EDI_ACTION_UPDATE   then  
		if realRelease = null then
			_addColl.addNoDuplicates(cmif, false);
		else
			_updateColl.addNoDuplicates(cmif, false);
		endif;
		
	elseif mode = CM_EDITrackedItem.EDI_ACTION_DELETE then
		if realRelease &lt;&gt; null then
			_deleteColl.addNoDuplicates (cmif, false);

			// a bit of validation !!!
			realRelease.validateForDelete(app.myPassport);		// TFS 39693
		endif;
	else
		app.raiseCMException1(EDIModeIgnored, _ediTI.messageMode, ETRow_MessageMode, _ediTI);
	endif;
	
	return proxy;
epilog
	endLoad;				// 08/04/2011 cnwmh5 #27347
end;
</source>
        <access>protected</access>
        <Parameter name="_ediTI" type="CM_EDIReleaseRequestTI"/>
        <Parameter name="_cmifColl" type="ObjectSet" usage="input"/>
        <Parameter name="_addColl" type="ObjectSet" usage="input"/>
        <Parameter name="_updateColl" type="ObjectSet" usage="input"/>
        <Parameter name="_deleteColl" type="ObjectSet" usage="input"/>
        <ReturnType type="CM_BulkRelease"/>
    </JadeMethod>
    <JadeMethod name="getDefaultVoyage" id="7e07b568-af6d-4f40-b670-7c0d953d7310">
        <source>getDefaultVoyage(_senderCode : String)  : CM_Voyage;
/*

Date		Who		Reason
06 September 2016	cnwer1	Initial creation TFS 2606

*/

vars
	coparnRules					:CM_EDIPartyCoparnRules;
begin
	if self.isCoparnFile() then
		coparnRules := self.CM_EDIDataReleaseRequest.getEDIPartyCoparnRules (_senderCode);
		
		if coparnRules &lt;&gt; null then
			return  coparnRules.getDefaultVoyage;	// par 32094(3)
		endif;	
	endif;
	return null;
epilog

end;</source>
