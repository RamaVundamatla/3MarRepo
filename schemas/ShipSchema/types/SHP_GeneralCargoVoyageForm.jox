    <JadeMethod name="getBottomTable" id="0c5516f1-878c-4c8e-a809-1336647a3a0c">
        <source>getBottomTable() : CM_DataTable;
//--------------------------------------------------
// Created:	02 February 2006 By: cnwgd1
//--------------------------------------------------
vars
	topSheet : Sheet;
begin
	topSheet := self.fldMain.topSheet;
	if topSheet = self.shtOnSite then
		return self.tblOnSiteInfo;
	elseif topSheet = self.shtPlanned then
		return self.tblPlannedInfo;
	elseif topSheet = self.shtNonplanned then
		return self.tblNonPlannedInf;
	elseif topSheet = self.shtNNCargo then
		return self.tblNNCargoInfo;
	else
		return self.tblOnShipInfo;								
	endif;
end;</source>
        <ReturnType type="CM_DataTable"/>
    </JadeMethod>
    <JadeMethod name="getCurrentlySelectedTIs" id="76b3b6a3-a043-4ae4-8778-b366593c25a7">
        <source>getCurrentlySelectedTIs(_tiSet : CM_TISet input) protected;
/*
----------   ----------  --------------------------------------------------
Created:	24 May 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	objArray		: ObjectArray;
	obj				: Object;
begin
	_tiSet.clear();
	
	if self.myCurrentContextTbl = self.tblNNCargo then
		objArray := self.tblNNCargo.allSelectedObjects;
	elseif self.myCurrentContextTbl = self.tblNNCargoInfo then
		objArray := self.tblNNCargoInfo.allSelectedObjects;
	elseif self.myCurrentContextTbl = self.tblNonPlanned then
		objArray := self.tblNonPlanned.allSelectedObjects;
	elseif self.myCurrentContextTbl = self.tblNonPlannedInf then
		objArray := self.tblNonPlannedInf.allSelectedObjects;
	elseif self.myCurrentContextTbl = self.tblOnShip then
		objArray := self.tblOnShip.allSelectedObjects;
	elseif self.myCurrentContextTbl = self.tblOnShipInfo then
		objArray := self.tblOnShipInfo.allSelectedObjects;
	elseif self.myCurrentContextTbl = self.tblOnSite then
		objArray := self.tblOnSite.allSelectedObjects;
	elseif self.myCurrentContextTbl = self.tblOnSiteInfo then
		objArray := self.tblOnSiteInfo.allSelectedObjects;
	elseif self.myCurrentContextTbl = self.tblPlanned then
		objArray := self.tblPlanned.allSelectedObjects;
	elseif self.myCurrentContextTbl = self.tblPlannedInfo then
		objArray := self.tblPlannedInfo.allSelectedObjects;
	else
		return;
	endif;
	
	foreach obj in objArray do
		if CM_TrackedItem.hasInstance(obj) then
			_tiSet.add(obj.CM_TrackedItem);
		endif;
	endforeach;
	
end;</source>
        <access>protected</access>
        <Parameter name="_tiSet" type="CM_TISet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getTopTable" id="f16d14e6-d1bd-44c4-8eba-424778ccdab7">
        <source>getTopTable() : CM_DataTable;
//--------------------------------------------------
// Created:	02 February 2006 By: cnwgd1
//--------------------------------------------------
vars
	topSheet : Sheet;
begin
	topSheet := self.fldMain.topSheet;
	if topSheet = self.shtOnSite then
		return self.tblOnSite;
	elseif topSheet = self.shtPlanned then
		return self.tblPlanned;
	elseif topSheet = self.shtNonplanned then
		return self.tblNonPlanned;
	elseif topSheet = self.shtNNCargo then
		return self.tblNNCargo;
	else
		return self.tblOnShip;								
	endif;
end;</source>
        <ReturnType type="CM_DataTable"/>
    </JadeMethod>
    <JadeMethod name="getXMLSettingsForSave" id="91dfad93-0691-4eb1-99a2-5ecb6f2fb602">
        <updating/>
        <source>getXMLSettingsForSave(): String updating;
//--------------------------------------------------
// Created:	03 February 2006 By: cnwgd1
//--------------------------------------------------
vars
	xmlStr	: String;
begin
	xmlStr := inheritMethod();
	
/*	xmlStr := xmlStr &amp; self.xmlStrDataTables &amp;
			global.formatAsXML(self.optBOL.name, self.optBOL.value.String) &amp;
			global.formatAsXML(self.chkNNCargo.name, self.chkNNCargo.value.String) &amp;
			global.formatAsXML(self.chkNonPlanned.name, self.chkNonPlanned.value.String) &amp;
			global.formatAsXML(self.chkOnShip.name, self.chkOnShip.value.String) &amp;
			global.formatAsXML(self.chkOnSite.name, self.chkOnSite.value.String) &amp;
			global.formatAsXML(self.chkPlanned.name, self.chkPlanned.value.String); */

	
	xmlStr := xmlStr &amp;	global.formatAsXMLPrefix(self.XMLTag_MultiDefTables) &amp;
						global.formatAsXMLPrefix(ETDef_GCVoyageData) &amp; self.xmlStrTI &amp; global.formatAsXMLSuffix(ETDef_GCVoyageData) &amp;
						global.formatAsXMLPrefix(ETDef_GCVoyageBOLData) &amp; self.xmlStrBOL &amp; global.formatAsXMLSuffix(ETDef_GCVoyageBOLData) &amp;
						global.formatAsXMLSuffix(self.XMLTag_MultiDefTables) &amp;
			global.formatAsXML(self.optBOL.name, self.optBOL.value.String) &amp;
			global.formatAsXML(self.chkNNCargo.name, self.chkNNCargo.value.String) &amp;
			global.formatAsXML(self.chkNonPlanned.name, self.chkNonPlanned.value.String) &amp;
			global.formatAsXML(self.chkOnShip.name, self.chkOnShip.value.String) &amp;
			global.formatAsXML(self.chkOnSite.name, self.chkOnSite.value.String) &amp;
			global.formatAsXML(self.chkPlanned.name, self.chkPlanned.value.String); 

	return xmlStr;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="handleExceptionObject" id="c8f0398c-4df9-4b41-984d-f05ca85cec1b">
        <source>handleExceptionObject(exObj : Exception; _obj : CM_Object io) : Integer protected;
//--------------------------------------------------
// Created:	07 February 2006 By: cnwgd1
//--------------------------------------------------
constants
	ObjectNotFound	: Integer = 4;
	ObjectDeleted	: Integer = 1072;
begin

	if exObj.errorCode = ObjectNotFound 
	or exObj.errorCode = ObjectDeleted then
		_obj := null;
		return Ex_Resume_Next;
	endif;

	return Ex_Pass_Back;

end;</source>
        <access>protected</access>
        <Parameter name="exObj" type="Exception"/>
        <Parameter name="_obj" type="CM_Object" usage="io"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="handleNotificationEvent" id="1fd1f813-a686-4e1c-be2c-519d34edfb1e">
        <updating/>
        <source>handleNotificationEvent(eventType: Integer; theObject: Object; eventTag: Integer) updating;
//--------------------------------------------------
// Created:	07 February 2006 By: cnwgd1
//--------------------------------------------------
vars

begin

	if eventType = Object_Update_Event then
		if CM_Object.hasInstance(theObject) then
			self.updateObject(theObject.CM_Object);
		endif;
	endif;
	
	if eventType = Object_Delete_Event then
		if CM_Object.hasInstance(theObject) then
			self.removeObject(theObject.CM_Object);
		endif;
	endif;
end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="handleNotificationUserEvent" id="ff9d58d3-9df4-49ed-9cf3-d580347522a4">
        <updating/>
        <source>handleNotificationUserEvent(_event : Integer; _theObject, _userObject : CM_Object) updating;
//--------------------------------------------------
// Created:	07 February 2006 By: cnwgd1
//--------------------------------------------------
vars
	theVoyage : CM_Voyage;
	tmpBOL : CM_BOLIn;
	event : Integer;
begin
	
	if self.myCurrentGCVoyage = null then
		return;
	endif;
	
	if CM_BOLIn.hasInstance(_userObject) then
		tmpBOL := _userObject.CM_BOLIn;
		event := self.myTerminal.getEventFromTerminalEvent(_event);
		if event = BOL_Update_Event then
			self.updateObject(tmpBOL);
			return;
		endif;		
	else
		return;
	endif;

	if _event &lt;&gt; VoyageBOLIn_Create_Event then
		self.doRefresh();
		return;
	endif;	
	
	if CM_Voyage.hasInstance(_theObject) then
		theVoyage := _theObject.CM_Voyage;	
	else
		return;	
	endif;
	
	if theVoyage &lt;&gt; self.myCurrentGCVoyage.myVoyage then
		return;
	endif;
	
	self.displayBOL(tmpBOL);

end;</source>
        <Parameter name="_event" type="Integer"/>
        <Parameter name="_theObject" type="CM_Object"/>
        <Parameter name="_userObject" type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="includeObject" id="45023241-06f4-48c6-a331-8b67d4c17c95">
        <source>includeObject(_obj : CM_Object) : Boolean;
//--------------------------------------------------
// Created:	02 February 2006 By: cnwgd1
//--------------------------------------------------
vars
	tmpTI : CM_TrackedItem;
	tmpBOL : CM_BOL;
	loadPort : String;
	cargoType : CM_CargoType;
	typeId : Integer;
	oper : CM_Operator;
	tmpFilter : CMQF_VoyageGeneralCargoSummary;
begin

	if CM_TrackedItem.hasInstance(_obj) then
		tmpTI := _obj.CM_TrackedItem;
		oper := tmpTI.myOperator;
		loadPort := tmpTI.loadPort;
		cargoType := tmpTI.myCargoType;		
			
	elseif CM_BOL.hasInstance(_obj) then
		tmpBOL := _obj.CM_BOL;
		oper := tmpBOL.myOperator;
		loadPort := tmpBOL.loadPortCode;
		typeId := tmpBOL.bolType;
	else
		return false;
	endif;

	tmpFilter := self.myGCVoyageQueryFilter;
	
	if tmpFilter = null then
		return true;
	endif;
		
	if (not tmpFilter.allBOLTypes.isEmpty) then
		if (not tmpFilter.allBOLTypes.includesKey(typeId)) then
			return false;
		endif;
	endif;
	
	if (not tmpFilter.allOperators.isEmpty) then
		if oper &lt;&gt; null and (not tmpFilter.allOperators.includes(oper)) then
			return false;
		endif;
	endif;
		
	if (not tmpFilter.allCargoTypes.isEmpty) then	
		if cargoType &lt;&gt; null and (not tmpFilter.allCargoTypes.includes(cargoType)) then
			return false;
		endif;
	endif;
		
	if (not tmpFilter.allPortsLoad.isEmpty) then
		if loadPort &lt;&gt; null and (not tmpFilter.allPortsLoad.includesKey(loadPort)) then
			return false;
		endif;
	endif;
	
	return true;
end;</source>
        <Parameter name="_obj" type="CM_Object"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="initFromUserWindow" id="136b64d9-10d9-448f-86ac-a69df6df75f2">
        <updating/>
        <source>initFromUserWindow(_userWindow: CM_UserWindow) updating;
//--------------------------------------------------
// Created:	08 February 2006 By: cnwgd1
//--------------------------------------------------
vars
	tmpXMLStr : String;
begin
	inheritMethod(_userWindow);
	
	if _userWindow = null then
		return;
	endif;

	tmpXMLStr := _userWindow.xmlInfo.cnEcGetTagValueOfName(self.XMLTag_MultiDefTables);
	//self.xmlStrDataTables := global.formatAsXMLPrefix(self.XMLTag_MultiDefTables) &amp; tmpXMLStr &amp; global.formatAsXMLSuffix(self.XMLTag_MultiDefTables);			
	
	self.xmlStrBOL	:= _userWindow.xmlInfo.cnEcGetTagValueOfName(ETDef_GCVoyageBOLData);
	self.xmlStrTI	:= _userWindow.xmlInfo.cnEcGetTagValueOfName(ETDef_GCVoyageData);
	
	tmpXMLStr := _userWindow.xmlInfo.cnEcGetTagValueOfName(self.optBOL.name);
	self.optBOL.value := tmpXMLStr.Boolean;
	self.optCargo.value := (not self.optBOL.value);

	tmpXMLStr := _userWindow.xmlInfo.cnEcGetTagValueOfName(self.chkNNCargo.name);
	if tmpXMLStr &lt;&gt; null then
		self.chkNNCargo.value := tmpXMLStr.Boolean;	
	endif;

	tmpXMLStr := _userWindow.xmlInfo.cnEcGetTagValueOfName(self.chkNonPlanned.name);
	if tmpXMLStr &lt;&gt; null then	
		self.chkNonPlanned.value := tmpXMLStr.Boolean;	
	endif;

	tmpXMLStr := _userWindow.xmlInfo.cnEcGetTagValueOfName(self.chkOnShip.name);
	if tmpXMLStr &lt;&gt; null then	
		self.chkOnShip.value := tmpXMLStr.Boolean;	
	endif;

	tmpXMLStr := _userWindow.xmlInfo.cnEcGetTagValueOfName(self.chkOnSite.name);
	if tmpXMLStr &lt;&gt; null then	
		self.chkOnSite.value := tmpXMLStr.Boolean;	
	endif;

	tmpXMLStr := _userWindow.xmlInfo.cnEcGetTagValueOfName(self.chkPlanned.name);
	if tmpXMLStr &lt;&gt; null then	
		self.chkPlanned.value := tmpXMLStr.Boolean;					
	endif;

end;</source>
        <Parameter name="_userWindow" type="CM_UserWindow"/>
    </JadeMethod>
    <JadeMethod name="initTblData" id="42277d6b-8eb3-49d5-b618-0b9c4889cf04">
        <source>initTblData(_table : CM_DataTable input);
//--------------------------------------------------
// Created:	01 February 2006 By: cnwgd1
//--------------------------------------------------
vars
begin
	
	_table.userInputEnabled := false;
	_table.selectMode := Table.SelectMode_CurrentRow;
	_table.selectionType := CM_DataTable.SelectionType_Row;
	_table.multiSelect := _table.MultiSelect_Simple;

	_table.autoSize := Table.AutoSize_Column;
	
end;</source>
        <Parameter name="_table" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="keyDown" id="86e53dc4-ffcc-4dfb-a512-090276b30090">
        <controlMethod name="Form::keyDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>keyDown(keyCode: Integer io; shift: Integer) updating;
//--------------------------------------------------
// Created:	02 February 2006 By: cnwgd1
//--------------------------------------------------
vars

begin
	if keyCode = CMUI_Key_F3 then
		self.showHideSearcher();
	elseif keyCode = J_key_Enter then
		if self.frmSearch.visible then
			self.doSearch();
		endif;		
	else
		inheritMethod(keyCode, shift);
	endif;
end;</source>
