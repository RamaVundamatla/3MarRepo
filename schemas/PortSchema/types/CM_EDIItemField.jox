    <JadeMethod name="setXMLElement" id="67cfb529-6ec6-4b95-9cb5-6fcc40b1c3a3">
        <source>setXMLElement(_xmlElement: JadeXMLElement input);
//----------------------------------------------------------------
//	Created:	08 October 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	tmpXMLElem	: JadeXMLElement;
	addXMLElem	: JadeXMLElement;
	obj			: Object;
begin
	
	tmpXMLElem := _xmlElement.addElement("name");
	tmpXMLElem.setText(self.name);
	tmpXMLElem := _xmlElement.addElement("required");
	tmpXMLElem.setText(self.required.String);
	tmpXMLElem := _xmlElement.addElement("stringFormatMethodName");
	tmpXMLElem.setText(self.stringFormatMethodName);
	tmpXMLElem := _xmlElement.addElement("systemName");
	tmpXMLElem.setText(self.systemName);
	tmpXMLElem := _xmlElement.addElement("systemTypeName");
	tmpXMLElem.setText(self.systemTypeName);
	tmpXMLElem := _xmlElement.addElement("className");
	tmpXMLElem.setText(self.className);

	if not self.allFieldAdditionals.isEmpty then
		tmpXMLElem := _xmlElement.addElement("AdditionalFields");
		foreach obj in self.allFieldAdditionals do
			addXMLElem := tmpXMLElem.addElement('AdditionalField');
			obj.CM_EDIItemField.setXMLElement(addXMLElem);
		endforeach;
	endif;

end;</source>
        <Parameter name="_xmlElement" type="JadeXMLElement" usage="input"/>
    </JadeMethod>
</Class>
