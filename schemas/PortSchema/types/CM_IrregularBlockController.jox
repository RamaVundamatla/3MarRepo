    <JadeMethod name="getMaxWeightDisplayAsStr" id="937602ff-5509-40b3-99f6-e83f9a2f3220">
        <source>getMaxWeightDisplayAsStr():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 July 2020	jlgndl1	Initial creation	TFS 49775

*/

vars

	measureType : CM_MeasurementType;
	maxWeight : String;
	subLoc : CM_RackShelfController;
	unit : String;
	
begin

	measureType := app.getDefaultMeasurementForType(Type_Weight);

	if self.allSubLocations.isEmpty then
		if self.maximumWeight = 0 then
			maxWeight := "0";
		elseif measureType &lt;&gt; null then
			maxWeight := measureType.convertMeasurementForDisplay( self.maximumWeight ).asStringJMT;
		else
			maxWeight := self.maximumWeight.asStringJMT;
		endif;
	
	else
		foreach subLoc in self.allSubLocations do
			if maxWeight &lt;&gt; null then
				maxWeight := maxWeight &amp; ", ";
			endif;
			if subLoc.maximumWeight = 0 then
				maxWeight := maxWeight &amp; "0";
			elseif measureType &lt;&gt; null then
				maxWeight := maxWeight &amp; measureType.convertMeasurementForDisplay( subLoc.maximumWeight ).asStringJMT;
			else
				maxWeight := maxWeight &amp; subLoc.maximumWeight.asStringJMT;
			endif;
		endforeach;
	
	endif;

	measureType := app.getDefaultMeasurementForType(Type_Weight);
	if measureType = null then
		unit := " Kg";
	else
		unit := " " &amp; measureType.shortName;
	endif;
	
	return maxWeight &amp; unit;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getMaxWeightDisplayForTADef" id="330932dd-f37b-4386-bcba-ea49dd87f48d">
        <source>getMaxWeightDisplayForTADef():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 July 2020	jlgndl1	Initial creation	TFS 49775

*/

vars

	measureType : CM_MeasurementType;
	maxWeight : Real;
	subLoc : CM_RackShelfController;
	
begin

	if self.allSubLocations.isEmpty then
		maxWeight := self.maximumWeight;
	
	else
		foreach subLoc in self.allSubLocations do
			maxWeight := maxWeight + subLoc.maximumWeight;
		endforeach;
	
	endif;

	if maxWeight = 0 then
		measureType := app.getDefaultMeasurementForType(Type_Weight);
		if measureType = null then
			return "0 Kg";
		else
			return "0 " &amp; measureType.shortName;
		endif;
	else
		return app.getWeightForDefaultDisplay( maxWeight );
	endif;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
