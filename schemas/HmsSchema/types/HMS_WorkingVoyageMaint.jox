    <JadeMethod name="doResizeTopSheet" id="f6c235ae-00c3-4761-b685-d2c10f380b07">
        <updating/>
        <source>doResizeTopSheet() updating;
//--------------------------------------------------
// Created:	August 2003	By: cnwgd1
//--------------------------------------------------
vars
	topSheet : Sheet;
begin

	topSheet := self.fldVoyageMaint.topSheet;
	
	if topSheet = self.shtShip then							
		self.doResizeShtShip();
	elseif topSheet = self.shtMovements then
		self.doResizeShtMovements();
	elseif topSheet = self.shtCargo then
		self.doResizeShtCargo();
	elseif topSheet = self.shtStevedores then
		self.doResizeShtStevedore();
	elseif topSheet = self.shtDelays then		
		self.doResizeShtDelay();
	endif;	
			
end;</source>
    </JadeMethod>
    <JadeMethod name="doTimeArrivalChange" id="c244df6f-8175-4246-bec2-78232a7535e3">
        <updating/>
        <source>doTimeArrivalChange(dTCalender: DTPicker input) updating;

vars
	arrivedLocal,
	departedLocal:	TimeStamp;

begin
	if self.myCurrentWorkingVoyage = null then
		return;
	endif;
	
// cnwdad1 17/06/2009 - PAR #19942.
//	self.myCurrentWorkingVoyage.arrivedDT := (txtDateArrival.text &amp; ", " &amp; txtTimeArrival.getTime().roundToNearestMinute.String).TimeStamp;
//	self.myCurrentWorkingVoyage.departedDT := (txtDateDepart.text &amp; ", " &amp; txtTimeDepart.getTime().roundToNearestMinute.String).TimeStamp;
	arrivedLocal.setDate(txtDateArrival.text.asDateJMT());
	arrivedLocal.setTime(txtTimeArrival.getTime().roundToNearestMinute());
	self.myCurrentWorkingVoyage.arrivedDT := self.localToSystemTime(arrivedLocal);	// 31/5/16 cnwmp6 TFS 488 - Multi timezone support
	departedLocal.setDate(txtDateDepart.text.asDateJMT());
	departedLocal.setTime(txtTimeDepart.getTime().roundToNearestMinute());
	self.myCurrentWorkingVoyage.departedDT := self.localToSystemTime(departedLocal);
	
	if self.myCurrentWorkingVoyage.arrivedDT &gt;= self.myCurrentWorkingVoyage.departedDT then
		// Set departure date to arrival date + 1 day
//		self.myCurrentWorkingVoyage.departedDT := ((self.myCurrentWorkingVoyage.arrivedDT.Date+1).Date.String &amp; "," &amp; self.myCurrentWorkingVoyage.arrivedDT.Time.String).TimeStamp;
		self.myCurrentWorkingVoyage.departedDT.setDate(self.myCurrentWorkingVoyage.arrivedDT.date+1);
		self.myCurrentWorkingVoyage.departedDT.setTime(self.myCurrentWorkingVoyage.arrivedDT.Time);
		
		txtDateDepart.setDate(self.systemToLocalTime(self.myCurrentWorkingVoyage.departedDT).date);	// 31/5/16 cnwmp6 TFS 488 - Multi timezone support
		txtTimeDepart.setTime(self.systemToLocalTime(self.myCurrentWorkingVoyage.departedDT).Time);
	endif; 	

  	// A change has occurred: Enable the 'Apply' button
	self.enableDisableApplyBtn(true);
end;</source>
        <Parameter name="dTCalender" type="DTPicker" usage="input"/>
    </JadeMethod>
