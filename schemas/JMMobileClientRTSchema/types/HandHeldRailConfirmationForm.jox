    <JadeMethod name="createDamageInstance" id="b0a8701f-b386-4869-a1a2-30f97e48d7c9">
        <source>createDamageInstance(_damageCmb, _severityCmb : ComboBox; 
					 _damageInstanceDict : MobileHandHeldThin::CM_DamageInstanceByDmgePos input) protected;
					 //_damageInstanceDict : MobileHandHeldThin::CM_DamageInstanceByLocDict input) protected;
/*
----------   ----------  --------------------------------------------------
Created:	20 September 2006 By cnwth2

Purpose:	

Changed On   	Changed By  Reason
26/08/2009 		cnwsh3 		CCMS SFW1066 PAR20321 - Recording Damage Details - changed method signature to use new damage position object dicts.
01/07/2022  navak20 ChangeRequest 53862: EUP - WMS - Damage Recording Extra Details
----------   ----------  --------------------------------------------------
*/
vars
	damageDefCode			: MobileHandHeldThin::CM_DamageDefinitionCode;
	damageInstance				: MobileHandHeldThin::CM_DamageInstance;
	damagePosition			: MobileHandHeldThin::CM_DamagePosition;
	remarks					: String;
	quantity				: Integer;
	isNewDamage,
	isRepaired				: Boolean;
begin
	damageDefCode := _damageCmb.listObject.MobileHandHeldThin::CM_DamageDefinitionCode;
	
	//damagePosition := app.
	if damageDefCode = null then
		return;
	endif;
	
	create damageInstance transient;

	damageInstance.setProxy(null, 
							null,
							damageDefCode,
							damagePosition,//_damageCmb.tag.Integer,
							remarks,
							isNewDamage,
							quantity,
							//_severityCmb.text.Integer,		//July 1, 2022 navak20 TFS 53862
							//isRepaired,						//July 1, 2022 navak20 TFS 53862
							//null	//_locationStr 	: String	01 Mar 2016	NDL	TFS 1593	//July 1, 2022 navak20 TFS 53862
							null, 	// 11.07.2022 navak20 TFS 53862		
							null,	//_locationStr 	: String	01 Mar 2016	NDL	TFS 1593
							null, null, null, null, null, null, null, null, null	//July 1, 2022 navak20 TFS 53862
							);
	_damageInstanceDict.add(damageInstance);
end;



</source>
        <access>protected</access>
        <Parameter name="_damageCmb" type="ComboBox"/>
        <Parameter name="_severityCmb" type="ComboBox"/>
        <Parameter name="_damageInstanceDict" type="MobileHandHeldThin::CM_DamageInstanceByDmgePos" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doAcceptWagonInwards" id="c6bd4bb6-3ebf-4df4-b58d-ecdb66f13c5e">
        <updating/>
        <source>doAcceptWagonInwards() protected, updating;
/*
----------   ----------  --------------------------------------------------
Created:	31 October 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	errorMsgs		: MobileHandHeldThin::DTO_HandHeldGateErrorDict;
	error			: DTO_HandHeldGateError;

begin
	create errorMsgs transient;
	self.doClearErrors();
	self.myDTOWagonIn.wagonID 		:= self.txtWagonIn.text.trimBlanks.toUpper;
	self.myDTOWagonIn.myTrain		:= self.cmbTrain.listObject.MobileHandHeldThin::CM_Train;
	self.myDTOWagonIn.myRailLine 	:= self.cmbRailLine.listObject.MobileHandHeldThin::CM_RailLine;
	self.myDTOWagonIn.position 		:= self.txtWagonPos.text.Integer;
	
	app.myHandHeldRailGuiAgent.doAcceptWagonInwards(self.myDTOWagonIn, errorMsgs);
	
	if (not errorMsgs.isEmpty) then
		app.msgBox('Errors occured when accepting this wagon inwards. They will now be displayed','Errors occurred', MsgBox_Exclamation_Mark_Icon);
		self.doApplyErrors(errorMsgs);
	else
		app.msgBox('Wagon ' &amp; self.txtWagonIn.text &amp; ' OK','Wagon OK', MsgBox_Exclamation_Mark_Icon);
		self.txtWagonIn.text := null;
		self.clearInwardInfo();
		self.txtWagonIn.setFocus();
	endif;
	
epilog
	if errorMsgs &lt;&gt; null then
		errorMsgs.purge();
	endif;
	
	delete errorMsgs;
end;







</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doAcceptWagonOutwards" id="aa65d8d2-a53c-4111-9ad7-93625b6ddf69">
        <updating/>
        <source>doAcceptWagonOutwards() protected, updating;
/*
----------   ----------  --------------------------------------------------
Created:	31 October 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	errorMsgs		: MobileHandHeldThin::DTO_HandHeldGateErrorDict;
	numWLEs			: Integer;
	error			: DTO_HandHeldGateError;
	dtoWagonPos		: MobileHandHeldThin::DTO_WagonPosition;	

begin
	create errorMsgs transient;
	self.doClearErrors();
	
	
	foreach dtoWagonPos in self.myDTOWagonOut.allDTOWagonPositions do
		if (not dtoWagonPos.myDTOContainer.confirmed) then
			create error transient;
			error.errorNo := error.Error_FowardContainerConfirm;
			error.errorDescr := 'Confirmation of container ' &amp; dtoWagonPos.idx.String &amp; ' is required before confirming this wagon outward';
			errorMsgs.add(error);
		endif;
	endforeach;

	if (not errorMsgs.isEmpty) then
		self.doApplyErrors(errorMsgs);
		return;
	endif;
	
	app.myHandHeldRailGuiAgent.doAcceptWagonOutwards(self.myDTOWagonOut, errorMsgs);
	if (not errorMsgs.isEmpty) then
		app.msgBox('Errors occured when proceeding this wagon. They will now be displayed','Errors occurred', MsgBox_Exclamation_Mark_Icon);
		self.doApplyErrors(errorMsgs);
	else
		app.msgBox('Wagon acceptance outwards successful.','Wagon update successful', MsgBox_Exclamation_Mark_Icon);
		self.txtWagonOut.text := null;
		self.clearOutwardInfo();
		self.txtWagonOut.setFocus();
	endif;
	
epilog
	if errorMsgs &lt;&gt; null then
		errorMsgs.purge();
	endif;
	
	delete errorMsgs;
end;





</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doApplyErrors" id="10936d19-c837-4fe1-8794-1f453ab1f65f">
        <source>doApplyErrors(_errorMsgs : MobileHandHeldThin::DTO_HandHeldGateErrorDict) protected;
/*
----------   ----------  --------------------------------------------------
Created:	14 September 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	
	errorMsg		: MobileHandHeldThin::DTO_HandHeldGateError;
	str				: String;
begin
	str[5000] := '*';
	str := null;
	
	foreach errorMsg in _errorMsgs do
		str := str &amp; errorMsg.errorDescr &amp; '.' &amp; CrLf &amp; CrLf;
		//th2 doesn't seem to be a way including global constants from port schema into
		//the MobileHandHeldThin package
		//foward container fields
		if errorMsg.errorNo = 82135 or //Err_GateFoward_Id
		   errorMsg.errorNo = 82136 then //Err_GateAft_Id
			self.txtId.text := null;
			
		elseif errorMsg.errorNo = 82137 or//Err_Gate_FowardCustSeal
		   errorMsg.errorNo = 82141 then //Err_Gate_AftCustSeal
			self.txtSealCust.text := null;
			
		elseif errorMsg.errorNo = 82138 or //Err_Gate_FowardOpSeal
		   errorMsg.errorNo = 82140 then //Err_Gate_AftOpSeal
			self.txtSealOp.text := null;
		elseif errorMsg.errorNo = 82139 or //Err_Gate_FowardShipSeal
		   errorMsg.errorNo = 82142 then //Err_Gate_AftShipSeal
			self.txtSealShip.text := null;
		endif;
		
	endforeach;
	
	self.txtWrongData.text := str;
	self.fldMain.topSheet 		:= self.shtError;
end;


</source>
        <access>protected</access>
        <Parameter name="_errorMsgs" type="MobileHandHeldThin::DTO_HandHeldGateErrorDict"/>
    </JadeMethod>
