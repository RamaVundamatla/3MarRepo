    <JadeMethod name="initFromUserWindow" id="206fab36-c8f9-4814-acc3-201a66c6d337">
        <updating/>
        <source>initFromUserWindow(_userWindow: CM_UserWindow) updating;
// ---------------------------------------------------------------------------
// Created:     11 November 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	splRatio		: String;
	taTypeStr		: String;

begin
	inheritMethod(_userWindow);

	if _userWindow = null then
		return;
	endif;
	
	self.width := _userWindow.width;
	self.height := _userWindow.height;
	
	splRatio := _userWindow.xmlInfo.cnEcGetTagValueOfName(self.XMLTag_Splitter);
	if splRatio &lt;&gt; null then
		self.sptMain.setLeftToRightRatio(splRatio.Integer);
	endif;
	
	taTypeStr := _userWindow.xmlInfo.cnEcGetTagValueOfName('TAType');
	if taTypeStr &lt;&gt; null then
		self.aTerminalAreaType := taTypeStr.Integer;
	endif;
	
end;</source>
        <Parameter name="_userWindow" type="CM_UserWindow"/>
    </JadeMethod>
    <JadeMethod name="initTblAll" id="e5d98cf0-bf57-46a9-8e25-b8d6a51d9738">
        <source>initTblAll();
// ---------------------------------------------------------------------------
// Created:     16 October 2002		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	table		: CM_DataTable;
begin
	table := self.tblAll;
	
	table.setColumnHeadingsFromDef(self.getTblAllDef.name, false);
	table.setTblDataEntRowsFromDef(self.getTblAllDef);
	table.selectionType := CM_EntryTable.SelectionType_Row;
	table.userInputEnabled := false;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="initTblItem" id="dab7c123-c8a6-47ca-9ebe-2b5df1eace24">
        <source>initTblItem();
// ---------------------------------------------------------------------------
// Created:     16 October 2002		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
// 15/03/2010	cnwcs5		par 22804 = general GUI issues with this form
// 12/12/2012	cnwcs5		par 30852 - trailer type combo should be hidden if no cargo type selected
vars
	entTableDef		: EntTableDef;
	theTable		: CM_EntryTable;
	
begin
	theTable 				:= self.tblItem;
	theTable.warningMethod 	:= CM_BaseForm::entTableWarning.name;							// par 22804 - use qualified method name
	entTableDef 			:= app.myController.getEntTableDef(self.getTblItemDef.name);
	
	theTable.setEntTableDef(entTableDef, null, CM_BaseForm::entTableDefSetupWarning.name);	// par 22804 - use qualified method name

	theTable.hideRowByName (ETRow_MyTrailerType, false);	// par 30852 Dec 2012
	if not app.isCargoGroupEnabled then //jlier1 TFS 53515 25/5/22
		theTable.hideRowByName(ETRow_CargoGroupId, false);
	endif;
	
	if self.aUseMasterContainer then
		self.hideRowsForMakeAttachment();
	endif;
	
	if self.isFromShipPreNote then 
		self.hideRowsForShipPreNote();
	endif;
	
	theTable.repositionAfterResize();
	//theTable.optimiseHeadingColumn();
	theTable.changeMode := CM_EntryTable.ChangeMode_FirstOnly;
	theTable.enabled 	:= true;
end;</source>
    </JadeMethod>
    <JadeMethod name="keyDown" id="e0a01bf3-64ff-4d31-b531-d1182451511d">
        <controlMethod name="Form::keyDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>keyDown(keyCode: Integer io; shift: Integer) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 10/05/2013	cnwdap1		Initial creation PAR #31155 CCMS SFW 1321 Imperial Measurements
//
vars

begin
	if self.doCheckKeyDownSpecial(keyCode, CMUI_AttachBreakBulk::doTblItemCellInputReady.name) then
		keyCode := 0;
		return;
	endif;
	
	inheritMethod(keyCode, shift);
epilog

end;</source>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="loadBookingItems" id="e5d7daf4-95f6-4694-89f2-bcda894bf991">
        <source>loadBookingItems(_br : CM_BookingRef; _brItem : CM_BookingRefItem);
//06 October 2010	cnwml2
//+cnwml2 PAR25895

vars

begin
	if _br = self.cmbBookingItem.myBookingRef then  // store the booking ref so don't reload if it has not changed
		return;
	endif;
	self.cmbBookingItem.clear;
	self.cmbBookingItem.setMyBookingRef(_br);
	self.cmbBookingItem.setObject(_brItem);

epilog

end;</source>
        <Parameter name="_br" type="CM_BookingRef"/>
        <Parameter name="_brItem" type="CM_BookingRefItem"/>
    </JadeMethod>
    <JadeMethod name="loadCargoTypes" id="fd79f683-91b0-41f0-b7dc-089f9849b74a">
        <source>loadCargoTypes() protected;
// ---------------------------------------------------------------------------
// Created:     30 June 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
// Changed On	By			Reason
// ----------	----------	--------------------------------------------------
// 05/05/2020	jlgdap1		TFS 49252 CPL Cargo Types not showing in System Admin
vars
	cmb					: ComboBox;
	canDoGeneralCargo,
//	canDoDeveloper,
	canDoCusCar			: Boolean;
	cargoBOLType		: CM_CargoBOLType;
	userDefaultCargoType : CM_CargoType;
	user				: CM_User;
	userTerminal		: CM_UserTerminal;
begin
	cmb := self.cmbCargoType;
	cmb.clear();
	user := app.getMyUser();
	canDoGeneralCargo 	:= user.canDo(self.myTerminal, Mod_GeneralCargo);
//	canDoDeveloper		:= user.canDo(self.myTerminal, PmDeveloper);

	cargoBOLType := app.myRoot.allCargoTypesById[TI_CargoType_LCL];
	cmb.itemObject[self.cmbCargoType.addItem(cargoBOLType.description)] := cargoBOLType;

	cargoBOLType := app.myRoot.allCargoTypesById[TI_CargoType_BreakBulk];
	cmb.itemObject[self.cmbCargoType.addItem(cargoBOLType.description)] := cargoBOLType;
	
	//th2 CCMS1032 - motor car is a system cargo type and therefore should be available to everyone
	//canDoCusCar	:=	app.myRoot.canDoEDIFileType(EDIFileType_CusCar);	
	//if canDoCusCar then 
	// if is create new cargo screen and is licenced for CusCar then add car cargo type
	cargoBOLType := app.myRoot.allCargoTypesById[TI_CargoType_Car];
	// after 33606 car is no longer a system cargo type, 35028 make it optional
	if cargoBOLType &lt;&gt; null then
		cmb.itemObject[self.cmbCargoType.addItem(cargoBOLType.description)] := cargoBOLType;
	endif;
	
	//CCMS SFW1039 add more cargo types for entry.  No reason why we should not be able to
	//include all cargo types in load. 16/2/2009
	cargoBOLType := app.myRoot.allCargoTypesById[TI_CargoType_Container];
	cmb.itemObject[self.cmbCargoType.addItem(cargoBOLType.description)] := cargoBOLType;
	
	cargoBOLType := app.myRoot.allCargoTypesById[TI_CargoType_Generator];
	cmb.itemObject[self.cmbCargoType.addItem(cargoBOLType.description)] := cargoBOLType;
	
	cargoBOLType := app.myRoot.allCargoTypesById[TI_CargoType_COU];
	cmb.itemObject[self.cmbCargoType.addItem(cargoBOLType.description)] := cargoBOLType;
	
	cargoBOLType := app.myRoot.allCargoTypesById[TI_CargoType_Tower];
	cmb.itemObject[self.cmbCargoType.addItem(cargoBOLType.description)] := cargoBOLType;
	
	cargoBOLType := app.myRoot.allCargoTypesById[TI_CargoType_Timber];
	cmb.itemObject[self.cmbCargoType.addItem(cargoBOLType.description)] := cargoBOLType;
	
	if canDoGeneralCargo then
		foreach cargoBOLType in self.myTerminal.allCargoBOLTypes where cargoBOLType.id &gt; TI_CargoBOLType_Max do	
		//	if (not canDoDeveloper) and
			if (not app.myRoot.isClientCentrePort) and				// TFS 49252
			cargoBOLType.id &gt; TI_CargoBOLType_JMTMax then
				break;
			endif;
			if CM_CargoType.hasInstance(cargoBOLType)					// 26/05/2010 cnwar2 #24132
			and cargoBOLType.CM_CargoType.isNotAvailableForEntry then	// 26/05/2010 cnwar2 #24132
				continue;
			endif;
			cmb.itemObject[self.cmbCargoType.addItem(cargoBOLType.description)] := cargoBOLType;
		endforeach;
	endif;
	//th2 changed 13th/06/06 - use the default cargotype set on the form, otherwise use the terminal default
	if self.aMyCargoType &lt;&gt; null  and self.aMyCargoType.id &gt; TI_CargoBOLType_Max then
		cargoBOLType := self.aMyCargoType;	
		self.cmbCargoType.listObject := cargoBOLType.CM_CargoType;
		self.tblItem.setValueByName(ETRow_CargoType, cargoBOLType.description);
	else
		userTerminal := user.getUserTerminal(self.myTerminal);
		if userTerminal &lt;&gt; null then
			userDefaultCargoType := userTerminal.myDefaultCargoType;
			if userDefaultCargoType &lt;&gt; null and 
			   (self.cmbCargoType.findObject(userDefaultCargoType) &gt; 0) then
				self.cmbCargoType.listObject := userDefaultCargoType;
			endif;
		endif;
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="loadCodesForProduct" id="f93fa121-38ef-43ba-9134-a57f451dc456">
        <source>loadCodesForProduct(_product : CM_Product) protected;
// ---------------------------------------------------------------------------
// Created:     24 October 2002		cnwth2	
//
// Purpose:    	
//				
//			 
// ----------   ----------  --------------------------------------------------
vars

begin
	
	if _product = null then
		self.setProdAttrCodeValue(ETRow_MyWidthString, null, self.cmbWidthCodes, true, null);
		self.setProdAttrCodeValue(ETRow_MyHeight, null, self.cmbHeightCodes, true, null);
		self.setProdAttrCodeValue(ETRow_MyLength, null, self.cmbLengthCodes, true, null);
		self.setProdAttrCodeValue(ETRow_MyType, null, self.cmbTypeCodes, true, null);
		return;
	endif;
	
	self.setProdAttrCodeValue(ETRow_MyWidthString, _product.myWidthString, self.cmbWidthCodes, true, null);
	self.setProdAttrCodeValue(ETRow_MyHeight, _product.myHeightString, self.cmbHeightCodes, true, null);
	self.setProdAttrCodeValue(ETRow_MyLength, _product.myLengthString, self.cmbLengthCodes, true, null);
	self.setProdAttrCodeValue(ETRow_MyType, _product.myType, self.cmbTypeCodes, true, null);

end;</source>
        <access>protected</access>
        <Parameter name="_product" type="CM_Product"/>
    </JadeMethod>
    <JadeMethod name="loadCombos" id="c3a351a9-a3f7-4dc7-9679-152e618967ce">
        <updating/>
        <source>loadCombos() updating;
// ---------------------------------------------------------------------------
// Created:     16 October 2002		cnwth2	
//
// Purpose:     Loads the cargoTypes and warhouse areas
//			 
// ----------   ----------  --------------------------------------------------
/*
Date		Who		Reason
10 Jun 2008	cnwkpd1	PAR #16753 - CCMS SFW 1003 - General Cargo Graphical Screens
17 Jun 2008	cnwrd1	PAR #17047 - Extinct Terminal area type still in user pref xml.
11 May 2009	cnwdad1	CCMS 1735 - Added Sub-Terminal field.
13 Aug 2013	cnwdap1	PAR #32123 Added Colour Picker
08 Sep 2022	jlika1	TFS 54699 - CUX - MAFI Handling Enhancements - MAFI Heap Terminal Area
*/
vars
	cargoBOLType			: CM_CargoBOLType;
	taType					: CM_TerminalAreaType;
	ta						: CM_TerminalArea;
	taTypeDict				: CM_TATypeByTypeDict;
	cmb						: ComboBox;
	allowWarehouse			: Boolean;
	tmpImexStatus			: Integer;
	opByName				: Boolean;			// TFS 53362
begin
	cmb := self.cmbTAType;
	cmb.clear();
	taTypeDict := app.myRoot.allTerminalAreaTypes;
	allowWarehouse := app.getMyUser().canDo(self.myTerminal, Mod_GeneralCargo);
	if allowWarehouse then
		taType := taTypeDict[TA_TYPE_IRREGULAR_BLOCK_AREA];		// was TA_TYPE_GENERAL_CARGO_AREA
		if taType &lt;&gt; null then
			cmb.itemObject[cmb.addItem(taType.description)] := taType;
		endif;
	endif;
	cmb.itemObject[cmb.addItem(taTypeDict[TA_TYPE_COU_CRIB_PACK_UNPACK].description)] 	:= taTypeDict[TA_TYPE_COU_CRIB_PACK_UNPACK];
	cmb.itemObject[cmb.addItem(taTypeDict[TA_TYPE_CONT_PACK_REPACK].description)] := taTypeDict[TA_TYPE_CONT_PACK_REPACK];
	cmb.itemObject[cmb.addItem(taTypeDict[TA_TYPE_BLOCK_STACK].description)] := taTypeDict[TA_TYPE_BLOCK_STACK];
	cmb.itemObject[cmb.addItem(taTypeDict[TA_TYPE_RTG].description)] := taTypeDict[TA_TYPE_RTG];
	cmb.itemObject[cmb.addItem(taTypeDict[TA_TYPE_SUBBLOCK_STACK].description)] := taTypeDict[TA_TYPE_SUBBLOCK_STACK];
	cmb.itemObject[cmb.addItem(taTypeDict[TA_TYPE_STRADDLE_STACK].description)] := taTypeDict[TA_TYPE_STRADDLE_STACK];
	
	cmb.itemObject[cmb.addItem(taTypeDict[TA_TYPE_RECTRANS].description)] := taTypeDict[TA_TYPE_RECTRANS];
	cmb.itemObject[cmb.addItem(taTypeDict[TA_TYPE_RELTRANS].description)] := taTypeDict[TA_TYPE_RELTRANS];
	
	cmb.itemObject[cmb.addItem(taTypeDict[TA_TYPE_DEPOT_LCL].description)] := taTypeDict[TA_TYPE_DEPOT_LCL];
	cmb.itemObject[cmb.addItem(taTypeDict[TA_TYPE_FORK_LIFT_STACK].description)] := taTypeDict[TA_TYPE_FORK_LIFT_STACK];
	cmb.itemObject[cmb.addItem(taTypeDict[TA_TYPE_GENERATOR_STORE_AREA].description)] := taTypeDict[TA_TYPE_GENERATOR_STORE_AREA];
	cmb.itemObject[cmb.addItem(taTypeDict[TA_TYPE_MAFI].description)] := taTypeDict[TA_TYPE_MAFI];
	taType := taTypeDict[self.aTerminalAreaType];

		
	if taType &lt;&gt; null then 						// cnwrd1 par #17047 , 17.06.2008 - terminal area type removed (by data migration?) but user default may still be set.
		if cmb.findObject(taType) &lt;&gt; -1 then 
			cmb.listObject := taType;	
		endif;
	
		self.tblItem.setValueByName(ETRow_TaType, taType.description);
	
		self.myAssistant.comboBoxTerminalArea(self.cmbTerminalArea, taType.type, null);
	
	
		if self.aMyTerminalArea &lt;&gt; null and taType.allTerminalAreasByTerminal.includes(self.aMyTerminalArea) then
			self.cmbTerminalArea.text := self.aMyTerminalArea.id;
			self.tblItem.setValueByName(ETRow_TerminalArea, self.aMyTerminalArea.id);
		endif;
		
	endif; 									// cnwrd1 par #17047 , 17.06.2008
	
	self.loadCargoTypes();
		
	if self.aMyVoyage = null then 
		self.myAssistant.comboBoxVoyageCurrent(	self.cmbVoyage,
												self.myTerminal.getNullVoyage(),
												true,
												false,
												true,
												true,
												true,
												true,
												true,
												false,
												false);
	else
	// if self.aMyVoyage then is from GTE_ShipPreNote screen, so limit what is in combo to not include departed. 
		self.myAssistant.comboBoxVoyageCurrent(	self.cmbVoyage,
												self.aMyVoyage,
												true,
												false,
												false,
												true,
												true,
												true,
												true,
												false,
												false);
	endif;
	
	if self.isFromShipPreNote and self.aMyVoyage &lt;&gt; null then 
//		is from create cargo screen and has passed in a voyage. then should not be able to change it then
		self.tblItem.disableRowByName(ETRow_Voyage);
	endif;

	self.tblItem.setValueByControlName(self.cmbVoyage.name, self.cmbVoyage.text);
	self.cmbDestPort.myTerminal := self.myTerminal;// so text for port is displayed in correct order from config
	self.cmbDestPort.myAssistant := self.myAssistant;
	self.cmbDestPort.showAllDestinations := true;

	self.cmbDisPort.myAssistant := self.myAssistant;
	
	self.cmbConsignee.setObject(null);
	self.cmbConsignor.setObject(null);
	self.cmbCommodity.setObject(null);
	
	//epr par 17165 if imexStatus has been set from parent form then default this forms one to that
	if self.imexStatus &gt; 0 then
		tmpImexStatus:=self.imexStatus;
	else
		///16314 this par meant if the combo was visible for some reason it defaulted to import
		if self.tblItem.isRowVisible(ETRow_ImexStatus) then
			tmpImexStatus:=TI_IMEX_STATUS_IMPORT;
		else
		// the old behaviour just default it to export 
			tmpImexStatus:=TI_IMEX_STATUS_EXPORT;
		endif;
	endif;
	
	self.myAssistant.comboBoxIMEXStatus(self.cmbImExStatus, tmpImexStatus);
	
	if app.isSubTerminalsOn(self.myTerminal) then
		self.myAssistant.comboBoxSubTerminal(cmbSubTerminal, null, self.myTerminal);
		cmbSubTerminal.automaticCellControl	:=	true;
	endif;
	
	opByName := app.myRoot.getConfig(ComboByNameOperator).Boolean;								// TFS 53362
	self.cmbOperator.setObject(self.aMyOperator);
	if self.aMyOperator &lt;&gt; null then
		if opByName then																		// TFS 53362
			self.tblItem.setValueByName(ETRow_Operator,self.aMyOperator.description);			// TFS 53362
		else																					// TFS 53362
			self.tblItem.setValueByName(ETRow_Operator,self.aMyOperator.code);
		endif;																					// TFS 53362
	endif;
	if app.myCurrentOperator &lt;&gt; null then
		if opByName then																		// TFS 53362
			self.tblItem.setValueByName(ETRow_Operator, app.myCurrentOperator.description);		// TFS 53362
		else																					// TFS 53362
			self.tblItem.setValueByName(ETRow_Operator, app.myCurrentOperator.code);
		endif;																					// TFS 53362
	endif;
	self.myAssistant.comboBoxHasRadio(self.cmbHasRadio, null);
	self.myAssistant.comboBoxCustomsAgent(self.cmbCustomsAgent, null);
	
	self.myAssistant.listTableColour(self.lstColour);						// PAR #32123
end;</source>
    </JadeMethod>
    <JadeMethod name="loadDataForFirstTime" id="40bedb38-24cd-40a0-a374-d53ff9669ce5">
        <updating/>
        <source>loadDataForFirstTime() updating, protected;
// ---------------------------------------------------------------------------
// Created:      30 May 2003 by cnwsgp1
// ---------------------------------------------------------------------------
vars
	termArea			: CM_TerminalAreaMaster;
	taType				: CM_TerminalAreaType;
begin
	self.initTblAll();
	self.initTblItem();
	
	if self.aMyTerminalArea = null then
		if not self.isFromShipPreNote then 	// if going on a ship so dont worry about term area. 
			//default to the first terminal area of the right terminal
			taType := app.myRoot.allTerminalAreaTypes[self.aTerminalAreaType];
			if taType &lt;&gt; null then
				foreach termArea in taType.allTerminalAreasByTerminal do
					if termArea.myTerminal = self.myTerminal then
						self.aMyTerminalArea := termArea.CM_TerminalArea;
						break;
					endif;
				endforeach;
			endif;
		endif;
	endif;
	self.loadCombos();
	self.doCmbCargoTypeClick();
	if self.aMyBookRefItem &lt;&gt; null then
		self.cmbProduct.listIndex := self.cmbProduct.findObject(self.aMyBookRefItem.myProduct);
		self.cmbProduct.click(self.cmbProduct);
		self.tblItem.setValueByName(ETRow_MyQuantity, self.aMyBookRefItem.productQuantity.String);
		self.tblItem.setValueByName(ETRow_MyLengthString, self.aMyBookRefItem.lengthString);
		self.tblItem.setValueByName(ETRow_MyWidthString, self.aMyBookRefItem.widthString);
		self.tblItem.setValueByName(ETRow_MyHeightString, self.aMyBookRefItem.heightString);
	
		self.tblItem.setValueByName(ETRow_MyLength, self.aMyBookRefItem.length.asStringMeasurementJMT());
		self.tblItem.setValueByName(ETRow_MyWidth, self.aMyBookRefItem.width.asStringMeasurementJMT());
		self.tblItem.setValueByName(ETRow_MyHeight, self.aMyBookRefItem.height.asStringMeasurementJMT());
	
		self.tblItem.setValueByName(ETRow_MyVolume, self.aMyBookRefItem.volume.String);
		self.tblItem.setValueByName(ETRow_MyDensity, self.aMyBookRefItem.density.String);
		self.tblItem.setValueByName(ETRow_MyWeight, self.aMyBookRefItem.weight.asStringWeightJMT());
		
		self.tblItem.setValueByName(ETRow_MyType, self.aMyBookRefItem.typeString);
	
		self.tblItem.setValueByName(ETRow_Description, self.aMyBookRefItem.description);
		self.tblItem.setValueByName(ETRow_Remarks, self.aMyBookRefItem.remarks);
		self.lstHazardList.setSelectedFromObject(self.aMyBookRefItem);
		self.lstHazardList.lostFocus(self.lstHazardList);
	endif;
	
	self.tblItem.setFocus();
	self.tblItem.moveFirst();
	//self.tblItem.goToRowByName(ETRow_Id);
	self.displayAttachments();
	self.btnAdd.default := true;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="loadProducts" id="43bd8a8f-d89d-4000-9833-74a0b1acce53">
        <source>loadProducts(_cargoType : CM_CargoType);
// ---------------------------------------------------------------------------
// Created:     16 October 2002		cnwth2	
//			 
// ----------   ----------  --------------------------------------------------
// 06 Dec 2012			cnwcs5	par 30852 - add isNotAvailableForEntry for trailer type 
vars
	proDict					: CM_ProductByOpCodeProCodeDict;
	pro						: CM_Product;
	iter					: Iterator;
	trailerType : CM_TILCType;
	
begin
	if _cargoType = null then
		return;
	endif;
	
	self.cmbProduct.clear();
	self.tblItem.setValueByName(ETRow_Product, null);
	
	create proDict transient;
	
	iter := _cargoType.allProducts.createIterator;
	
	_cargoType.allProducts.startKeyGeq(null, null, iter);
	
	while iter.next(pro) do
		//epr TFS 1846 19/4/16
		if pro.isNotActive then
			continue;
		endif;
		proDict.add(pro);
	endwhile;
	
	//29 Aug 2013	NDL	Par 32055
	if _cargoType.allProducts.isEmpty and _cargoType.mySystemProductType &lt;&gt; null then
		proDict.add( _cargoType.mySystemProductType);
	endif;
	
	if not proDict.isEmpty then
		self.cmbProduct.listCollection(proDict, false, 0);
		
		pro := proDict.first;
		
		self.cmbProduct.listObject := pro;
		self.tblItem.setValueByName(ETRow_Product, pro.code &amp; '  ' &amp; pro.description);
	endif;
	
	//17 Oct 2012	NDL	Par 30095	
	if not _cargoType.isTrailer then
		self.cmbTrailerType.clear();
		
		self.tblItem.setValueByName(ETRow_MyTrailerType, null);
		return;
	else 
		if self.cmbTrailerType.listIndex &gt; 0 then
			trailerType := self.cmbTrailerType.listObject.CM_TILCType;
		endif;
		
		self.cmbTrailerType.clear();
		self.cmbTrailerType.myCargoType	:= _cargoType;
		
		//self.cmbTrailerType.listCollection(_cargoType.allTILCTypes, true, 1);
		
		if trailerType &lt;&gt; null then
			self.tblItem.setValueByName(ETRow_MyTrailerType, trailerType);
		endif;
	endif;
	
epilog
	delete iter;
	delete proDict;

end;</source>
        <Parameter name="_cargoType" type="CM_CargoType"/>
    </JadeMethod>
    <JadeMethod name="loadTATypes" id="8916bca6-98b1-4bbd-9251-f1fd79ddd2d0">
        <source>loadTATypes() protected;
// ---------------------------------------------------------------------------
// Created:     30 June 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
/*

Date		Who		Reason
10 Jun 2008	cnwkpd1	PAR #16753 - CCMS SFW 1003 - General Cargo Graphical Screens
08 Sep 2022	jlika1	TFS 54699 - CUX - MAFI Handling Enhancements - MAFI Heap Terminal Area
*/

vars
	cmb						: ComboBox;
	taType					: CM_TerminalAreaType;
	taTypeDict				: CM_TATypeByTypeDict;
	allowWarehouse			: Boolean;	
begin
	cmb := self.cmbTAType;
	cmb.clear();
	taTypeDict := app.myRoot.allTerminalAreaTypes;
	allowWarehouse := app.getMyUser().canDo(self.myTerminal, Mod_GeneralCargo);
	if allowWarehouse then
		taType := taTypeDict[TA_TYPE_IRREGULAR_BLOCK_AREA];			// was TA_TYPE_GENERAL_CARGO_AREA
		if taType &lt;&gt; null then
			cmb.itemObject[cmb.addItem(taType.description)] := taType;
		endif;
	endif;
	cmb.itemObject[cmb.addItem(taTypeDict[TA_TYPE_COU_CRIB_PACK_UNPACK].description)] 	:= taTypeDict[TA_TYPE_COU_CRIB_PACK_UNPACK];
	cmb.itemObject[cmb.addItem(taTypeDict[TA_TYPE_CONT_PACK_REPACK].description)] 		:= taTypeDict[TA_TYPE_CONT_PACK_REPACK];
	cmb.itemObject[cmb.addItem(taTypeDict[TA_TYPE_BLOCK_STACK].description)] 			:= taTypeDict[TA_TYPE_BLOCK_STACK];
	cmb.itemObject[cmb.addItem(taTypeDict[TA_TYPE_SUBBLOCK_STACK].description)] 		:= taTypeDict[TA_TYPE_SUBBLOCK_STACK];
	
	cmb.itemObject[cmb.addItem(taTypeDict[TA_TYPE_RECTRANS].description)] 				:= taTypeDict[TA_TYPE_RECTRANS];
	cmb.itemObject[cmb.addItem(taTypeDict[TA_TYPE_RELTRANS].description)] 				:= taTypeDict[TA_TYPE_RELTRANS];
	
	cmb.itemObject[cmb.addItem(taTypeDict[TA_TYPE_DEPOT_LCL].description)] 				:= taTypeDict[TA_TYPE_DEPOT_LCL];
	cmb.itemObject[cmb.addItem(taTypeDict[TA_TYPE_FORK_LIFT_STACK].description)] 		:= taTypeDict[TA_TYPE_FORK_LIFT_STACK];
	cmb.itemObject[cmb.addItem(taTypeDict[TA_TYPE_GENERATOR_STORE_AREA].description)] 	:= taTypeDict[TA_TYPE_GENERATOR_STORE_AREA];
	cmb.itemObject[cmb.addItem(taTypeDict[TA_TYPE_MAFI].description)] 					:= taTypeDict[TA_TYPE_MAFI];
	taType := taTypeDict[self.aTerminalAreaType];
	cmb.listObject := taType;	
	self.tblItem.setValueByName(ETRow_TaType, taType.description);
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="loadTerminalAreas" id="086cc371-19ff-4714-ac2e-29a9ce5e4cfa">
        <source>loadTerminalAreas(_terminalArea : CM_TerminalArea) protected;
// ---------------------------------------------------------------------------
// Created:     30 June 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars
	taType					: CM_TerminalAreaType;
begin
	taType := self.cmbTAType.listObject.CM_TerminalAreaType;
	if taType &lt;&gt; null and not self.isFromShipPreNote then //dont worry about loading combos as they wont be used
		self.myAssistant.comboBoxTerminalArea(self.cmbTerminalArea, taType.type, _terminalArea);
		self.tblItem.setValueByName(ETRow_TerminalArea, _terminalArea.id);
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_terminalArea" type="CM_TerminalArea"/>
    </JadeMethod>
    <JadeMethod name="lstColour_displayRow" id="a7629245-9846-4c89-979d-493aefba0c72">
        <controlMethod name="Table::displayRow"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>lstColour_displayRow(table: Table input; theSheet: Integer; obj: Object; theRow: Integer; bcontinue: Boolean io):String updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 13/08/2013	cnwdap1		Initial creation PAR #32123
//
vars
	selected : Boolean;
	
begin
	selected := table.CMUI_ListTableColour.allSelectedObjects.includes(obj);
	return self.myAssistant.displayEntryColour(obj.CM_VehicleColour, selected);
epilog

end;</source>
