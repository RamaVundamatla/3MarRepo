					);
	

end;</source>
    </JadeMethod>
    <JadeMethod name="createDelProductForLogModuTest" id="7fe33f03-d255-4742-88d4-8633cb08872e">
        <source>createDelProductForLogModuTest(_create: Boolean);
//09 September 2010	by cnwvu1

vars
	logSpecs	:	CM_CodeGroupLogSpecs;
	operator	: CM_Operator;

	tmpLength	: CM_LogLength;
	tmpTreat	: CM_LogTreatment;
	tmpType		: CM_LogType;
	tmpSpecies		: CM_LogSpecies;
	tmpGrade	: CM_LogGrade;
	tmpCode		: CM_Code;
	
begin

	logSpecs := self.getLogSpecs(LogSpecsName);
	operator := self.getOperator(OperatorCode);
	
	if operator = null or logSpecs = null then
		return;
	endif;
	
	foreach tmpCode in logSpecs.allCodes do
		tmpSpecies := tmpCode.CM_LogSpecies;
		foreach tmpCode in tmpSpecies.allLogGrades do
			tmpGrade := tmpCode.CM_LogGrade;
			foreach tmpType in tmpGrade.allLogTypes	do
				foreach tmpTreat in tmpGrade.allLogTreatments do
					foreach tmpLength in tmpGrade.allLogLengths do
	
						if _create then
							self.addProductLog(operator, tmpSpecies, tmpGrade, tmpType, tmpTreat, tmpLength);
						else
							self.deleteProductLog(operator, tmpSpecies, tmpGrade, tmpType, tmpTreat, tmpLength);
						endif;
						
						self.assertNoTrxErrorsOrWarnings();

					endforeach;
				endforeach;
			endforeach;
		endforeach;
	endforeach;

end;</source>
        <Parameter name="_create" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="createGradesForLogModuleTest" id="aff22a8b-a198-47dc-bf77-e164f0a3e2c3">
        <source>createGradesForLogModuleTest();
//08 September 2010	cnwvu1

vars
	logSpecs		: CM_CodeGroupLogSpecs;
	code			: CM_Code;
	logSpeciesOak	: CM_LogSpecies;
	logGrade		: CM_LogGrade;
	lengths,
	treatments,
	types			: CM_ObjectSet;
	logLen			: CM_LogLength;
	
begin

	logSpecs := self.getLogSpecs(LogSpecsName);

	// -------------------------------------------------------
	// 			create grades GL and GH for Oak
	// -------------------------------------------------------

	logSpeciesOak := self.getLogSpecies(LogSpecsName, LogSpecsSpeciesOak);
	
	// when Oak found, create log grades and all other log specs attributes. If not found - we will have UE 1090
	create lengths		transient;
	create types		transient;
	create treatments	transient;

	// -------------------------------------------------------
	// 					create grade GL
	// -------------------------------------------------------
	
	lengths.add(	getLogLength(		LogSpecsName, LogSpecsLength2) );
	lengths.add(	getLogLength(		LogSpecsName, LogSpecsLength6) );
	lengths.add(	getLogLength(		LogSpecsName, LogSpecsLength8) );
	types.add(		getLogType(			LogSpecsName, LogSpecsTypeBon) );
	treatments.add(	getLogTreatment(	LogSpecsName, LogSpecsTreatmentUTN) );

	logGrade	:= self.addLogGrade(LogSpecsGradeL, LogSpecsGradeLDesc, false, logSpeciesOak,
									lengths, treatments, types, 0,
									0,0,0,0);
	self.assertNoTrxErrorsOrWarnings();

	// -------------------------------------------------------
	// 					create grade GH
	// -------------------------------------------------------
	lengths.clear;
	types.clear;
	treatments.clear;
	
	lengths.add(	getLogLength(		LogSpecsName, LogSpecsLength2) );
	lengths.add(	getLogLength(		LogSpecsName, LogSpecsLength6) );
	lengths.add(	getLogLength(		LogSpecsName, LogSpecsLength8) );
	types.add(		getLogType(			LogSpecsName, LogSpecsTypeBoff) );
	treatments.add(	getLogTreatment(	LogSpecsName, LogSpecsTreatmentUTT) );

	logGrade	:= self.addLogGrade(LogSpecsGradeH, LogSpecsGradeHDesc, false, logSpeciesOak,
									lengths, treatments, types, 0,
									0,0,0,0);
	self.assertNoTrxErrorsOrWarnings();

epilog
	delete lengths;
	delete treatments;
	delete types;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="createLocationForLogModuleTest" id="ee7bd93c-489b-49f7-b88b-5732a8286f27">
        <source>createLocationForLogModuleTest(_locationId: String);
// 28 January 2011	cnwvu1
vars
	cmif_LogRow	: CMIF_LogRowRestriction;
	operator	: CM_Operator;
	obj			: CM_Object;

begin

	// creating log row for OAK, Grade High
	
	create cmif_LogRow transient;

	operator:= self.getOperator(OperatorCode);
	
	cmif_LogRow.allOperators.add(operator);

	obj := operator.getLogSpecies(LogSpecsSpeciesOak);
	cmif_LogRow.allSpecies.add(obj);

	obj := operator.getLogGrade(LogSpecsSpeciesOak, LogSpecsGradeH);
	cmif_LogRow.allGrades.add(obj);

	obj := operator.getLogType(LogSpecsTypeBoff);
	cmif_LogRow.allTypes.add(obj);

	obj := operator.getLogTreatment(LogSpecsTreatmentUTT);
	cmif_LogRow.allTreatments.add(obj);

	obj := operator.getLogLength(LogSpecsLength8);
	cmif_LogRow.allLengths.add(obj);
	
	cmif_LogRow.myRowArea := self.getLogArea(LogAreaCode);
	cmif_LogRow.id := _locationId;

	//cmif_LogRow.isMixedRow := false;
	cmif_LogRow.transport := 3;  // there is no constant
	
	cmif_LogRow.status := LC_Status_Open;
	
	cmif_LogRow.width := 12;  //see LOG_LogRowMaintForm :: setRowWidth();

	cmif_LogRow.user := app.getMyUserCode;
	
	self.addLogRow(cmif_LogRow);

	
epilog
	delete cmif_LogRow;

end;</source>
        <Parameter name="_locationId" type="String"/>
    </JadeMethod>
