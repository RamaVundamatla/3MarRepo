    <JadeMethod name="getConsolidatingNarration" id="5e4c06a8-6c30-45a3-94d8-63ecf9be6f3e">
        <source>getConsolidatingNarration() : String;
/*
Purpose:			
Date		Who		Reason
21 April 2017	cnwab1	Initial creation
*/

vars
	debtor : CM_Debtor;
    dild : CM_DebtorInvoiceLineDesc;
begin
	if self.invoice = null then
		//return self.invoiceLineDesc.narration;
		return self.getNarrationFromInvoiceLocale(); // ### TFS 54564 (54379) 09Sept2022 NAVPW1
	endif;
	
	debtor := self.invoice.debtor;
	
	if debtor = null then
		//return self.invoiceLineDesc.narration;
		return self.getNarrationFromInvoiceLocale(); // ### TFS 54564 (54379) 09Sept2022 NAVPW1
	endif;
	
	dild :=  self.invoiceLineDesc.getDILDForDebtor(debtor);
	
	if dild &lt;&gt; null then
		return dild.narration;
	endif;
	
	//return self.invoiceLineDesc.narration; 
	return self.getNarrationFromInvoiceLocale(); // ### TFS 54564 (54379) 09Sept2022 NAVPW1

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getConsolidatingRemarks" id="43191b84-9697-4fa0-b2c3-e9be1971c2cc">
        <source>getConsolidatingRemarks() : String;
/*
Purpose:			
Date		Who		Reason
21 April 2017	cnwab1	Initial creation
*/

vars
	debtor : CM_Debtor;
    dild : CM_DebtorInvoiceLineDesc;
begin
	if self.invoice = null then
		return self.invoiceLineDesc.remarks;
	endif;
	
	debtor := self.invoice.debtor;
	
	if debtor = null then
		return self.invoiceLineDesc.remarks;
	endif;
	
	dild :=  self.invoiceLineDesc.getDILDForDebtor(debtor);
	
	if dild &lt;&gt; null then
		return dild.remarks;
	endif;
	
	return self.invoiceLineDesc.remarks;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
