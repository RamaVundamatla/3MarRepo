        <source>doControlEvent(_control: Control) updating;
// called from msPackages on add/remove
vars

begin
	self.changed := true;
end;
</source>
        <Parameter name="_control" type="Control"/>
    </JadeMethod>
    <JadeMethod name="doSave" id="06c1a2c1-c4c7-483d-94e8-9b11ec646cd1">
        <updating/>
        <source>doSave() updating, protected;

vars
	default	: Integer;
	selectedPackages	: ObjectArray;
	obj		: Object;
	package	: CM_PackageInvoice;
begin
	if not self.changed then
		self.unloadForm;
	endif;
	
	create selectedPackages transient;
	if self.myDebtorInvoiceType = null then
		create self.myDebtorInvoiceType transient;
		self.myDebtorInvoiceType.setup(self.myDebtor, self.myInvoiceType, 0);
	endif;
	
	if chkDefault.value then
		default := DfltDbtrRef_XlatedVoyageCode;
	endif;
	self.myDebtorInvoiceType.setDefaultDebtorRefTo(default);
	
	self.msPackages.getSelected(selectedPackages);
	self.myDebtorInvoiceType.allPackageInvoices.clear();
	foreach obj in selectedPackages do
		package := obj.CM_PackageInvoice;
		self.myDebtorInvoiceType.allPackageInvoices.add(package);
	endforeach;
	// if self.myDebtorInvoiceType exists and is not default and has no selected packages, delete it
	if self.myDebtorInvoiceType.defaultDebtorRefTo = 0 and
	   self.myDebtorInvoiceType.allPackageInvoices.size = 0 then
		delete self.myDebtorInvoiceType;
	endif;
	
	self.myDebtor.causeEvent(Event_InvoiceUpdate, true, self.myInvoiceType);
	
	self.unloadForm();
epilog
	delete selectedPackages;
end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doSysNotify" id="0cfe1477-47ba-4ec0-a9fc-a44c074f8a32">
        <updating/>
        <source>doSysNotify(eventType: Integer; theObject: Object; eventTag: Integer) protected, updating;
// update the available and selected lists from invoice package changes
vars
	package	: CM_PackageInvoice;
	oa		: ObjectArray;
begin

	if not theObject.isKindOf(CM_PackageInvoice) then
		return;
	endif;
	package := theObject.CM_PackageInvoice;
	
	if eventType = Object_Delete_Event then
		create oa transient;
		self.msPackages.getSelected(oa);
		self.allInvoicePackages.remove(package);
		self.msPackages.setAvailable(self.allInvoicePackages, true);
		self.msPackages.setSelected(oa);
		
	elseif eventType = Object_Create_Event then
		create oa transient;
		self.msPackages.getSelected(oa);
		self.allInvoicePackages.add(package);
		self.msPackages.setAvailable(self.allInvoicePackages, true);
		self.msPackages.setSelected(oa);

	elseif eventType = Object_Update_Event then
		self.msPackages.refreshOwnListboxes();
	endif;

epilog
	delete oa;
end;</source>
        <access>protected</access>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="editPackage" id="67650925-e48a-4f1e-8e63-275de3962d83">
        <updating/>
        <source>editPackage() updating, protected;

vars
	form	: CMUI_PackageConfigForm;
	package	: CM_Package;
begin

	package := self.msPackages.mySelectedListBox.listObject.CM_Package;
	if package = null then
		package := self.msPackages.myAvailableListBox.listObject.CM_Package;
	endif;
	if package = null then
		return;
	endif;

	form := app.loadForm(CMUI_PackageConfigForm, CMUI_Assistant, false, false, false, null, null).CMUI_PackageConfigForm;
	if form = null then
		return;
	endif;

	form.setAttributes(true, PackageInvoicePost, package);
	form.centreWindow;
	
	form.showModal;
end;

</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="initMsPackages" id="03b9ae33-6703-4ebd-870b-40d5e9cee8df">
        <updating/>
        <source>initMsPackages() updating, protected;

vars
	theGroupBox : CMUI_MultiSelectGroupBox;
begin
	theGroupBox := self.msPackages;
	theGroupBox.caption := null;
	theGroupBox.distanceFromBottom 	:= 5;
	theGroupBox.distanceFromRight 		:= 5;
	theGroupBox.lockBottom 				:= false;
	theGroupBox.lockRight				:= false;
	theGroupBox.stretchHeight 			:= false;
	theGroupBox.stretchWidth 			:= true;
	theGroupBox.multiSelect 	:= ListBox.MultiSelect_Extended;
	theGroupBox.formDisplayEntryMethodName := "displayPackage";
	theGroupBox.availableHeading := app.getErrorString(Available);
	theGroupBox.selectedHeading := app.getErrorString(Selected);
	theGroupBox.myBaseForm	:= self;
	theGroupBox.mySelectedListBox.sorted := false;
	theGroupBox.cnEcResizeContents();
	theGroupBox.readOnly := false;
	theGroupBox.isMultipleSelectAllowed := false;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="populateForm" id="fde11c0f-7079-45ce-a47a-4c978ac2821f">
        <updating/>
        <source>populateForm() updating, protected;

vars

begin
	if self.myInvoiceType = null then
		return;
	endif;
	
	self.myDebtorInvoiceType := self.myDebtor.allDebtorInvTypes[self.myInvoiceType];
	
	txtBU.text := self.myInvoiceType.company.mailingName;
	txtInvType.text := self.myInvoiceType.description;
	
	if self.myDebtorInvoiceType &lt;&gt; null then
		self.chkDefault.value := (self.myDebtorInvoiceType.defaultDebtorRefTo = DfltDbtrRef_XlatedVoyageCode);
	endif;
	self.chkDefault.enabled := (self.myInvoiceType.invoiceKey = CM_InvoiceDesc.Key_Voyage);
end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="populatePackages" id="339a536e-e52f-4595-a2c6-2c7795b929c9">
        <updating/>
        <source>populatePackages() updating, protected;

vars
	package		: CM_Package;
	
begin
	self.allInvoicePackages.clear();
	foreach package in app.myRoot.allPackages discreteLock do
		if package.type = PackageInvoicePost then
			self.allInvoicePackages.add(package);
		endif;
	endforeach;

	self.msPackages.setAvailable(self.allInvoicePackages, true);
	if self.myDebtorInvoiceType = null then
		self.msPackages.setSelected(null);
	else
		self.msPackages.setSelected(self.myDebtorInvoiceType.allPackageInvoices);
	endif;
end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupForm" id="aa890cbc-50f8-471a-bafb-eb2cc5fb0242">
        <updating/>
        <source>setupForm() updating;

vars

begin
	self.caption := self.caption &amp; " - " &amp; app.getErrorString(INV_Debtor) &amp; " " &amp; self.myDebtor.name;
	inheritMethod();

	self.populateForm();
	
	self.initMsPackages();
	
	self.populatePackages();

	self.beginClassNotification(CM_Package, false, Object_Delete_Event, Response_Continuous, 0);
	self.beginClassNotification(CM_Package, false, Object_Create_Event, Response_Continuous, 0);
	self.beginClassNotification(CM_Package, false, Object_Update_Event, Response_Continuous, 0);
end;
</source>
    </JadeMethod>
    <JadeMethod name="sysNotify" id="a28a9a58-34d7-4665-aa1f-d6cf1c5e1b56">
        <controlMethod name="Form::sysNotify"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>sysNotify(eventType: Integer; theObject: Object; eventTag: Integer) updating;

vars

begin
	self.doSysNotify(eventType, theObject, eventTag);
end;
</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="1ba4bed4-0323-4aa6-8c6e-ecc27077c8be">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0017094, locale);
	btnAddPackage.translateCaption(Xlat_0017095, locale);
	btnCancel.translateCaption(Xlat_0017096, locale);
//	btnDeletePackage.translateCaption(Xlat_0017582, locale);
	btnEditPackage.translateCaption(Xlat_0017097, locale);
	btnOK.translateCaption(Xlat_0017098, locale);
	grpPackage.translateCaption(Xlat_0017099, locale);
	lblBU.translateCaption(Xlat_0017100, locale);
	lblDefault.translateCaption(Xlat_0017101, locale);
	lblInvType.translateCaption(Xlat_0017102, locale);
	lblPackage.translateCaption(Xlat_0017103, locale);
	msPackages.translateCaption(Xlat_0017104, locale);
end;</source>
    </JadeMethod>
</GUIClass>
