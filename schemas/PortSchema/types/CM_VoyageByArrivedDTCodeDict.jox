<CollClass name="CM_VoyageByArrivedDTCodeDict" id="e9817d9b-7a9f-4c33-a755-0ce9745b7d06">
    <memberType name="CM_Voyage"/>
    <superclass name="CM_MemberKeyDictionary"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="voyages"/>
    <MemberKey>
        <property name="CM_Voyage::arrivedDT"/>
    </MemberKey>
    <MemberKey>
        <property name="CM_Voyage::code"/>
    </MemberKey>
    <JadeMethod name="removeObject" id="da7296c9-42f3-426d-9263-d4b5c8575711">
        <lockReceiver/>
        <updating/>
        <source>removeObject(_obj: MemberType): Boolean updating, lockReceiver;
//--------------------------------------------------
// Created:	30 July 2004 By: cnwgd1
//--------------------------------------------------
vars
	iter	: Iterator;
	tmpObj	: MemberType;
	keyDT   : TimeStamp;
	keyCode	: String;
begin
	iter := self.createIterator();
	
	while iter.next(tmpObj) do
		if tmpObj = _obj then
			self.getIteratorKeys(keyDT, keyCode, iter);
			self.removeKey(keyDT, keyCode);
			return true;
		endif;
	endwhile;

	return false;

epilog
	delete iter;
end;</source>
        <Parameter name="_obj" type="MemberType"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</CollClass>
