    </PrimAttribute>
    <JadeMethod name="bgpRequestCallback" id="6019220b-300e-4aa2-9a35-77d1744c0cc7">
        <updating/>
        <source>bgpRequestCallback(_bgpRequest: BGP_EmailReadRequest) updating;
// -------------------------------------------
// Created 03 March 2004 by cnwdvb1
// -------------------------------------------
// 17 Jun 2013		cnwrs1	ccms 1336 Par 31389 separate BGP EmailRequest to seperate read and send
vars

	alertMe : Boolean;

begin

//	if not _bgpRequest.isToSend and 
	if _bgpRequest.errorCode = 0 and 
	   self.lastPollTime &lt;&gt; null and 
	   _bgpRequest &lt;&gt; self.myCurrentRequest then
		beginTransaction;
		app.writeLog('Reseting lastPollTime to null because of successful poll', LogINFO);
		self.exclusiveLock(self);
		self.lastPollTime := null;
		if self.lastPollAlert &lt;&gt; null then
			app.writeLog('Reseting lastPollAlert to null', LogINFO);
			self.lastPollAlert := null;
			alertMe := true;
		endif;
		commitTransaction;
		if alertMe then
			app.remoteErrorWarningToAlert('Email polling has resumed', null,  null, null, true, false);
		endif;
	endif;

end;</source>
        <Parameter name="_bgpRequest" type="BGP_EmailReadRequest"/>
    </JadeMethod>
    <JadeMethod name="checkPollTimeOnError" id="eeedd039-9a8d-4889-8903-e3e7e1fc2230">
        <updating/>
        <source>checkPollTimeOnError(_lastPollTime : TimeStamp; _request : BGP_Request) : Boolean updating;
// -------------------------------------------
// Created 04 March 2004 by cnwdvb1
// -------------------------------------------
// This method determines what should be done about an email
// poll error.
vars

	rtnValue : Boolean;

begin

	if self.numAlertMinutes = null or self.numFailMinutes = null then
		return false;
	endif;
	
	if self.lastPollTime = null then
		app.writeLog('Setting last poll time to ' &amp; _lastPollTime.String, LogINFO);
		self.lastPollTime := _lastPollTime;
	else
		if self.lastPollAlert &lt;&gt; null then
			if self.lastPollAlert.cnEcAddMinutes(self.numFailMinutes) &lt;= _lastPollTime then
				self.lastPollAlert := _lastPollTime;
				app.writeLog('Time to alert again', LogINFO);
				rtnValue := true;
			endif;
		else
			if self.lastPollTime.cnEcAddMinutes(self.numAlertMinutes) &lt;= _lastPollTime then
				self.lastPollTime := _lastPollTime;
				self.lastPollAlert := _lastPollTime;
				app.writeLog('First alert', LogINFO);
				rtnValue := true;
			endif;
		endif;
	endif;
	self.myCurrentRequest := _request;
	return rtnValue;


end;</source>
        <Parameter name="_lastPollTime" type="TimeStamp"/>
        <Parameter name="_request" type="BGP_Request"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getEntryTableViewName" id="6289e3f4-c889-4ddd-aa38-0ca38ec252d5">
