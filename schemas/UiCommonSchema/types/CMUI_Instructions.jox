    <JadeMethod name="initTblInstructions" id="9c02ea7a-6bba-46bf-a1bd-46e76b314265">
        <updating/>
        <source>initTblInstructions() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 Oct 2023	navnk30	ChangeRequest 59946: EUP - Additional Operational Instructions on the Order - Enhancement 2

*/

vars
	entTableDef	: EntTableDef;
	tbl			: CM_DataTable;
begin
	entTableDef := app.myController.getEntTableDef(ETDef_Instructions);
	tbl := self.tblInstructions;
	tbl.selectionType := CM_DataTable.SelectionType_Row;
	tbl.setTblDataEntRowsFromDef(entTableDef);
	
	tbl.accessRow(1).backColor := self.colorHeadingColumn;
	tbl.selectMode := Table.SelectMode_CurrentRow;
	tbl.selectionType := CM_DataTable.SelectionType_Row;
	tbl.colourRows(self.colorRow1, self.colorRow2);
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="load" id="12f0c476-585b-4ebd-826c-1c1d01faf772">
        <controlMethod name="Form::load"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>load() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 Oct 2023	navnk30	ChangeRequest 59946: EUP - Additional Operational Instructions on the Order - Enhancement 2

*/

vars

begin
	if self.myObject = null then
		app.msgBox("Please select a Work order or Task", "Error", MsgBox_OK_Only);
		self.unload();
		return;
	endif;
	inheritMethod();
	self.beginClassNotification(CMUI_InstructionEntry, true, CMUI_InstructionEntry.InstructionEntryDeleted, Response_Continuous, 0);
	self.beginClassNotification(CMUI_InstructionEntry, true, CMUI_InstructionEntry.InstructionEntryUpdated, Response_Continuous, 0);
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="populateTblInstructions" id="294ead16-22dc-4816-84ac-5812ec3f2a3c">
        <source>populateTblInstructions();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 Oct 2023	navnk30	ChangeRequest 59946: EUP - Additional Operational Instructions on the Order - Enhancement 2

*/

vars
	instruction	: CM_InstructionsIssued;
	tbl			: CM_DataTable;
	entRowArray	: EntTableRowArray;
	allIns		: CM_InstructionsIssuedSet;	
begin
	create allIns transient;
	tbl := self.tblInstructions;
	self.myObject.CM_WorkOrder.getInstructionsForContext(allIns, null, null);
	
	entRowArray := tbl.myEntTableDef.allEntTableRows;
	foreach instruction in allIns do
		tbl.addItemObject(instruction, instruction.getAttributeStringForDefArray(entRowArray));
	endforeach;
epilog
	delete allIns;
end;</source>
    </JadeMethod>
    <JadeMethod name="removeInstructionEntry" id="9bbd6595-dcca-444c-9424-2a7e0f88a53b">
        <updating/>
        <source>removeInstructionEntry() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 Oct 2023	navnk30	ChangeRequest 59946: EUP - Additional Operational Instructions on the Order - Enhancement 2

*/

vars

begin
	if self.accessedRowId &lt; 1 then
		return;
	endif;
	self.tblInstructions.removeItem(self.accessedRowId);
	self.accessedRowId := 0;
	self.resetViewBtn();
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="resetViewBtn" id="65764b1e-2031-49a7-9146-bc487c0f24a7">
        <updating/>
        <source>resetViewBtn() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 Oct 2023	navnk30	ChangeRequest 59946: EUP - Additional Operational Instructions on the Order - Enhancement 2

*/

vars

begin
	self.btnView.enabled := self.accessedRowId &gt; 0;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="dc27e989-c8dd-4b59-953f-9df01ae078ad">
        <updating/>
        <source>setupForm() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 Oct 2023	navnk30	ChangeRequest 59946: EUP - Additional Operational Instructions on the Order - Enhancement 2

*/

vars
	obj	: CM_Object;
begin
	self.initTblInstructions();
	
	obj := self.myObject;
	if not obj.isKindOf(CM_WorkOrderDtl) and not obj.isKindOf(CM_WorkOrder) then
		return;
	endif;
	if obj.isKindOf(CM_WorkOrderDtl) then
		self.myObject := obj.CM_WorkOrderDtl.myParent;
	endif;
	
	self.caption := self.caption &amp; " " &amp; self.myObject.CM_WorkOrder.id;
	self.populateTblInstructions();
	inheritMethod();
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="tblInstructions_click" id="087b2dbf-bedd-405e-9d2c-c777b5839348">
        <controlMethod name="Table::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblInstructions_click(table: Table input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 Oct 2023	navnk30	ChangeRequest 59946: EUP - Additional Operational Instructions on the Order - Enhancement 2

*/

vars

begin
	if not self.tblInstructions.accessedRow.selected then
		return;
	endif;
	
	self.accessedRowId := self.tblInstructions.accessedRow.row;
	self.resetViewBtn();
epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="tblInstructions_dblClick" id="c0cfadf3-5e08-4f1c-8b8a-5c7a68c4e87e">
        <controlMethod name="CM_DataTable::dblClick"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblInstructions_dblClick(table: Table input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 Oct 2023	navnk30	ChangeRequest 59946: EUP - Additional Operational Instructions on the Order - Enhancement 2

*/

vars

begin
	if self.accessedRowId &gt; 1 then
		self.viewInstructionEntry();
	endif;
epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="8ae05fd5-e4d5-4310-b9b3-7c0e5d319d8c">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 26 October 2023 09:25:09.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0026545, locale);
	btnClose.translateCaption(Xlat_0026546, locale);
	btnView.translateCaption(Xlat_0026547, locale);
end;</source>
    </JadeMethod>
    <JadeMethod name="unload" id="d7ffc433-10f1-4a3b-b5d7-cf92aae1fa2b">
        <controlMethod name="Form::unload"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>unload() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 Oct 2023	navnk30	ChangeRequest 59946: EUP - Additional Operational Instructions on the Order - Enhancement 2

*/

vars

begin
	self.endClassNotification(CMUI_InstructionEntry, true, CMUI_InstructionEntry.InstructionEntryUpdated);
	self.endClassNotification(CMUI_InstructionEntry, true, CMUI_InstructionEntry.InstructionEntryDeleted);
	inheritMethod();
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="updateInstructionEntry" id="f4026746-7402-4911-9c1c-51a9fcbe52df">
        <updating/>
        <source>updateInstructionEntry() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 Oct 2023	navnk30	ChangeRequest 59946: EUP - Additional Operational Instructions on the Order - Enhancement 2

*/

vars
	updatedIns	: CM_InstructionsIssued;
	entRow		: EntTableRow;
	colId 		: Integer;
	tbl			: CM_DataTable;
begin
	if self.accessedRowId &lt; 1 then
		return;
	endif;
	
	colId := 1;
	tbl := self.tblInstructions;
	updatedIns := tbl.accessRow(self.accessedRowId).itemObject.CM_InstructionsIssued;
	foreach entRow in tbl.myEntTableDef.allEntTableRows do
		self.tblInstructions.accessCell(self.accessedRowId, colId).text := updatedIns.getDisplayStringForAttribute(entRow.getName, true);
		colId := colId + 1;
	endforeach;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="userNotify" id="21eec7de-7497-4938-99ea-95cc7be4bc19">
        <controlMethod name="Form::userNotify"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>userNotify(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: CM_Object) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 Oct 2023	navnk30	ChangeRequest 59946: EUP - Additional Operational Instructions on the Order - Enhancement 2

*/

vars

begin
	if eventType = CMUI_InstructionEntry.InstructionEntryDeleted then
		self.removeInstructionEntry();
	elseif eventType = CMUI_InstructionEntry.InstructionEntryUpdated then
		self.updateInstructionEntry();
	endif;
epilog

end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="viewInstructionEntry" id="c396768f-cb3b-450b-934a-1411f89f7722">
        <source>viewInstructionEntry();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 Oct 2023	navnk30	ChangeRequest 59946: EUP - Additional Operational Instructions on the Order - Enhancement 2

*/

vars

begin
	self.myAssistant.showInstructionEntryForm(self.tblInstructions.allSelectedObjects.first.CM_InstructionsIssued.myParent, self);
epilog

end;</source>
    </JadeMethod>
</GUIClass>
