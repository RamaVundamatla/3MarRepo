        <source>tblGateAreas_contextMenu(table: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating;
// ---------------------------------------------------------------------------
// Created:     08 June 2009 by concms1
// Purpose:     Par 
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	x1, y1 :Real;
begin
	self.setupPopupMenuA;
	
	x1 := x;
	y1 := y;
	
	table.windowToScreen(x1, y1);
	self.screenToWindow(x1, y1);   // convert x, y relative to form
	
