    <JadeMethod name="getWOOperationStarted" id="cd2562ce-a02e-42d6-876e-df6fe06c48b2">
        <source>getWOOperationStarted():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 Nov 2024	navhl20 CR MTN-33232: EUP - Start End Times for Road and Rail jobs
*/

vars
	wo		: CM_WorkOrder;
	woDtl	: CM_WorkOrderDtl;
	woTxn	: CM_WOTransaction;
begin
	woDtl := self.getMyWorkOrderDtl();
	if woDtl = null then
		return null;
	endif;
	
	wo := woDtl.myParent;
	if wo = null then
		return null;
	endif;
	
	foreach woTxn in wo.allTransactions discreteLock do
		if woTxn.type = TRANS_TYPE_WOJOBSTART and woTxn.CM_WOJobDetail.myWorkOrderDetail = woDtl then
			return woTxn.getJobStart().asStringJMT();
		endif;
	endforeach;
	
	return null;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
