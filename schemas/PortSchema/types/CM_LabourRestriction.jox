    <JadeMethod name="validateLocationControllers" id="0c934e2b-2d01-4dd9-9d9b-dbfa2179b61d">
        <source>validateLocationControllers(pTA : CM_TerminalArea; pLocationControllers : CM_LCArray) protected;
// ---------------------------------------------------------------------------
// Created:     13 December 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	lController	: CM_LocationsController;

begin
	if pLocationControllers.size = 0 then
		app.raiseCMException2(ERR_INVALID_VALUE,"Labour Restriction","No Locations where selected. Please select some Locations and try again", null, null);
	
	endif;

	//cnwjo3 ccms 1018
	if not self.myTerminalArea.isKindOf(CM_RoRoLaneArea) then
		if not self.myTerminalArea.testAreWeTogether(self.allLocationControllers) then
			app.raiseCMException1(ERR_CONTROLLERS_NOT_CONTIGUOUS, " Labour Restriction " &amp; self.id, null, null);
		endif;
	endif;
	

end;</source>
        <access>protected</access>
        <Parameter name="pTA" type="CM_TerminalArea"/>
        <Parameter name="pLocationControllers" type="CM_LCArray"/>
    </JadeMethod>
</Class>
