    <JadeMethod name="showHideSearch" id="ca5a20f1-dc29-4f36-aab7-800808092a97">
        <source>showHideSearch()protected;
/*

Purpose:			


Return Value:		


Date				Who		Reason
06 December 2006	cnwer1	Initial creation - PAR#xxxx
01/07/2010 			CNWCS5	refresh display in case user has clicked cancel
*/
vars
	frame	:CMUI_Frame;
begin
	frame := self.frmSelect;
	
	frame.visible := not frame.visible;
	
	// if the user has clicked cancel at any point then
	// the gate/interchange areas displayed will match those
	// in our collections
	if frame.visible then
		self.setupSearchFrame;
	endif;
	
	frame.centreWindow();

	frame.zOrder(1);	// concms1 - 18/11/2008 
epilog

end;</source>
