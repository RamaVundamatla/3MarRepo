    <JadeMethod name="showHideReceiptCombo" id="2557e849-bcbc-4188-b339-0c7a65662b96">
        <updating/>
        <source>showHideReceiptCombo() updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 02/03/2016	cnwdap1		Initial creation PAR #37608 Added receipt number text box for sites with &gt; 32,000 cash receipts
//03 Jul 2019	NDL 	TFS 45296
//
vars
	bank : CM_Bank;
	useTextBox : Boolean;
	totalItems: Integer;

begin
	self.txtReceiptNo.visible := true;
	if self.myTerminal = null then
		if CM_CashReceipt.instances.size &gt; self.ComboBox_MaxEntries then
			useTextBox := true;
		endif;
	else
		if self.cmbBanks.listIndex &gt; 0 and self.cmbBanks.listObject &lt;&gt; null then
			bank := self.cmbBanks.listObject.CM_Bank;
			if bank.allCashReceipts.size &gt; self.ComboBox_MaxEntries then
				useTextBox := true;
			endif;
		else
			foreach bank in self.myTerminal.companies where bank.isBusinessUnit do
				totalItems := totalItems + bank.allCashReceipts.size;
			endforeach;
			if totalItems &gt; self.ComboBox_MaxEntries then
				useTextBox := true;
			endif;
		endif;
	endif;
	
	if useTextBox then
		self.cmbReceiptNo.enabled := false;
		self.cmbReceiptNo.clear();
		self.cmbReceiptNo.addItem( app.getErrorString( Too_many_list ) );
		self.cmbReceiptNo.listIndex := 1;
	//	self.txtReceiptNo.visible := true;
	//	self.txtReceiptNo.move(self.cmbReceiptNo.left, self.cmbReceiptNo.top, self.cmbReceiptNo.width, self.cmbReceiptNo.height);
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="showSearchFrame" id="cd53d5e3-69c6-4f71-a069-7759a0398b87">
        <source>showSearchFrame();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 August 2012	cnwndl1	Initial creation

*/

vars

	theFrame : CMUI_MoveableFrame;

begin

	if self.frmSearch.visible then
		self.hideSearchFrame();
	else
		theFrame := self.frmSearch;
		theFrame.zOrder(1);
		theFrame.centreWindow();
		theFrame.visible := true;
		self.frmMain.enabled := false;
	endif;

epilog

end;</source>
    </JadeMethod>
