    <JadeMethod name="doPerformSearch" id="b9cc3206-7007-42a9-9586-f38a927ad9b7">
        <updating/>
        <source>doPerformSearch() protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
01 June 2010	cnwer1	Initial creation	Par 30901
16 Sept 2014    cnwma1 PAR #34408 Credit Customer current charges
*/

vars
	
	objArray : ObjectArray;
	ti : CM_TrackedItem;
	effectiveDate : Date;
	bank : CM_Bank;
	agent : CM_CashInvoiceProformaAgent;
	row : Integer;
	consignee : CM_ConsigneeConsignor;
	debtor : CM_Debtor;
	dutyDoc : CM_DutyDoc;
	allDutyDocs : CM_DutyDocById;
	obj : Object;
	ddHasData : Boolean;
	extraRowIndex : Integer;
	zeroBalanceLine : Boolean;
	ddRow : Integer;
	
begin

	//06 Nov 2013	NDL	Par 32940
	if self.myInitDutyDoc &lt;&gt; null then
		debtor := self.myInitDutyDoc.getMyDebtor;
	else
		consignee := self.cmbConsignee.listObject.CM_ConsigneeConsignor;
		if consignee &lt;&gt; null then
			debtor := consignee.debtor;
		endif;
	endif;
	
	self.allTIs.clear();
	self.setMyDebtor( debtor );
	self.initChargesTable();
	self.initPaymentsTable();

	create objArray transient;
	create allDutyDocs transient;
	
	self.getDutyDocs( allDutyDocs );
	
	foreach dutyDoc in allDutyDocs do
	
		objArray.clear();
		self.getTIsFromDutyDoc(dutyDoc, objArray, effectiveDate );
		if objArray.isEmpty then
			// no cargo found to process for this one.
			continue;
		endif;
		
		objArray.copy( self.allTIs );
		
		ddHasData := false;
		ddRow := self.addChargesLine( dutyDoc, null ) ;
		
		foreach obj in objArray do
		
			ti := obj.CM_TrackedItem;
			if bank = null then
				bank := ti.companyOid;
				if bank = null then
					bank := self.myTerminal.getDefaultCompanyBank();
				endif;
			endif;
			
			create agent transient;
			
			agent.init( bank, ti, effectiveDate,  true );
			agent.createProformaInvLines( null, false, true );
			//agent.getCurrentInvLines();					//16/09/2014 cnwma1 PAR #34408
			  agent.getCurrentInvLinesDutyDoc();			//16/09/2014 cnwma1 PAR #34408
			
			if agent.myDebtor &lt;&gt; null and self.myDebtor = null then
				self.setMyDebtor(agent.myDebtor );
			endif;
			
			row := self.addChargesLine( agent, null ) ;
			
			zeroBalanceLine := ( self.tblCharges.getCellText( self.tblCharges.row, ColumnBalance ).asDecimalFromCurrencyString = 0.0 );
			if zeroBalanceLine then
				self.tblCharges.deleteRow( row );
				continue;
			endif;
			
			ddHasData := true;
			
		endforeach;
		
		extraRowIndex := self.addChargesLine( self.myDebtor, dutyDoc );
		if not ddHasData then
			ddHasData := ( extraRowIndex &gt; 0 );
		endif;
		
		if not ddHasData then
			// no data rows that should be displayed for this duty doc.
			self.tblCharges.deleteRow( ddRow );
		else
			self.expandCollapseDutyDoc( ddRow, false );
		endif;
		
	endforeach;
	
	self.enableButtonsSetBalances();
	
epilog

	delete objArray;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doSave" id="a01beefa-a4b0-4459-a515-9c745d1941dd">
        <updating/>
        <source>doSave():Boolean updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 July 2012	cnwndl1	Initial creation	Par 29968

*/

vars

	drTerm : CM_DebtorTerminal;
	now : TimeStamp;
	user : CM_User;
	
	allPxyCashRecs : ObjectArray;
	allRealCashRecs : ObjectArray;
	allPxyCashPays : ObjectArray;
	allRealCashPays	: ObjectArray;
	obj : Object;
	cashReceipt	: CM_CashReceipt;
	proformaAgent : CM_CashInvoiceProformaAgent;
	theReturn : Integer;
	row : Integer;
	allExtraChargeInvLines : ObjectArray;
	totalToAllocate	: Decimal[16, 4];
	numRows : Integer;
	descriptions : String;
	amounts : String;
	dutyDoc : CM_DutyDoc;
	allSelectedDutyDocs : CM_DutyDocByTicket;
	
	pxyCashRec	: CM_CashReceipt;	//30 Jan 2014	NDL	Par 33181
	invoiceLine : CM_InvoiceLine;	//30 Jan 2014	NDL	Par 33181
	newSeq : Integer;	//30 Jan 2014	NDL	Par 33181
	
begin

	//create the the proxy cash receipt(s) / ( I.e The details of the cash and cheques received. )
	now := app.actualTimeServer;
	user := app.getMyUser;
	drTerm := self.myTerminal.allDebtorTerminals.getAtKey( self.myDebtor );
	create allPxyCashRecs transient;
	self.createProxyCashReceipts(	allPxyCashRecs,	//_allPxyCashRecs : ObjectArray input;
									drTerm,	//_drTerm : CM_DebtorTerminal;
									now,	//_now : TimeStamp;
									user	//_user : CM_User
									);
							
	//create the the proxy cash payment(s) against the tracked item invoices / ( I.e. The details of where the cash received is being applied )
	create allPxyCashPays transient;
	create allSelectedDutyDocs transient;
	row := 1;
	newSeq := 1;
	totalToAllocate := self.totalPayments;
	while row &lt; self.tblCharges.rows do
		row := row + 1;
		if self.isChargeLineSelectedForPaying( row ) then
			obj := self.tblCharges.accessRow(row).itemObject;
			if obj = null then
				continue;
			endif;
			if obj.isKindOf(CM_DutyDoc) then
				dutyDoc := obj.CM_DutyDoc;
				allSelectedDutyDocs.add(dutyDoc);
			elseif obj.isKindOf(CM_CashInvoiceProformaAgent) then
				proformaAgent := obj.CM_CashInvoiceProformaAgent;
				proformaAgent.createProxiesForPayments(totalToAllocate, now,drTerm,allPxyCashPays);
				
				//30 Jan 2014	NDL	Par 33181
				if not allPxyCashRecs.isEmpty then
					pxyCashRec	:= allPxyCashRecs.first.CM_CashReceipt;
					proformaAgent.allCurrentInvLines.copy(pxyCashRec.allInvoiceLines);
					foreach invoiceLine in proformaAgent.allProformaInvLines do
						invoiceLine.invoice := null;		// to prevent the sequence number change being applied to an invalid .invoice property
						invoiceLine.sequenceNum := newSeq;	// to get unique ids for the CM_CashReceipt allProformaInvoiceLines dictionary
						newSeq := newSeq + 1;
						pxyCashRec.allProformaInvoiceLines.add(invoiceLine);
					endforeach;
					pxyCashRec.allTrackedItems.add(proformaAgent.myTrackedItem);
				endif;
				
			endif;
		endif;
	endwhile;
	
	//find the invoices lines relative only to a debtor (i.e. those not related to a specific tracked item)
	//in the trx we will create a new invoive for these and move them to it, and create a cash payment item for it.
	create allExtraChargeInvLines transient;
	foreach dutyDoc in allSelectedDutyDocs do
		self.getExtraCharges(dutyDoc,numRows,descriptions,amounts,allExtraChargeInvLines);
	endforeach;
	
	//persist all of our transients.
	create allRealCashRecs transient;
	create allRealCashPays transient;
	while true do
		app.myTrxCA.trxCreateCashReceipts(allPxyCashRecs, allRealCashRecs, allPxyCashPays, allRealCashPays, allExtraChargeInvLines, app.myPassport);
		if app.myPassport.trxCompletedOK then
			
			break;
		else
			theReturn := app.showErrorWarningDialog(app.getErrorString(Cash_receipts), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and theReturn = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		
			return false;
		endif;
		break;
	endwhile;
	
	//print a copy of the cash receipts if required
	if self.chkPrintRec.value then
	//	foreach obj in allRealCashRecs do
	//		cashReceipt	:= obj.CM_CashReceipt;
	//		cashReceipt.printReceipt(1, true, null, null);
	//	endforeach;
		//05 Feb 2014	NDL	_ Par 33181 Only need to print the first one
		if not allRealCashRecs.isEmpty then
			cashReceipt	:= allRealCashRecs.first.CM_CashReceipt;
			cashReceipt.printReceipt(1, true, null, null, null,false);
		endif;
	endif;
	
	//clear the payemnts table and refresh the charges table
	self.doPerformSearch();
	
	return true;	

epilog

	if allPxyCashRecs &lt;&gt; null and not allPxyCashRecs.isEmpty then
		allPxyCashRecs.purge();
	endif;
	delete allPxyCashRecs;
	
	if allPxyCashPays &lt;&gt; null and not allPxyCashPays.isEmpty then
		allPxyCashPays.purge();
	endif;
	delete allPxyCashPays;
	
	delete allRealCashRecs;
	delete allRealCashPays;
	
	delete allSelectedDutyDocs;
	delete allExtraChargeInvLines;

end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doTblChargesClick" id="103c4c45-12df-41af-9013-cc0630c06793">
        <updating/>
        <source>doTblChargesClick() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 March 2013	cnwndl1	Initial creation	Par 30901

*/

vars

	text : String;
	firstObj : Object;
	rowIndex : Integer;
	startRow : Integer;
	endRow : Integer;
	obj : Object;
	selectionString : String;
	ddBalance : Decimal [16,4];
	
begin

	text:= self.tblCharges.getCellText(self.tblCharges.row,self.tblCharges.column);
	
	if self.tblCharges.column = ColumnInclude then
		
		firstObj := self.tblCharges.accessRow(self.tblCharges.row).itemObject; 
		if self.tblCharges.row &gt; self.tblCharges.fixedRows then
			selectionString := self.tblCharges.accessCell(self.tblCharges.row,self.tblCharges.column).text;
			
			if firstObj.isKindOf(CM_CashInvoiceProformaAgent) or firstObj.isKindOf(CM_Debtor) then  // represents a cargo line or an extras line
				// not allowed to select/unselect single lines only whole duty docs
				if selectionString = self.unSelectedString then
					self.tblCharges.accessCell(self.tblCharges.row,self.tblCharges.column).text := self.unSelectedString;
				else
					self.tblCharges.accessCell(self.tblCharges.row,self.tblCharges.column).text := self.selectedString;
				endif;
				
			elseif firstObj.isKindOf(CM_DutyDoc) then
				startRow := self.tblCharges.row + 1;
				endRow := self.tblCharges.rows;
				
				if self.tblCharges.row &gt; self.tblCharges.fixedRows and startRow &lt;= endRow then
					foreach rowIndex in startRow to endRow do
						obj := self.tblCharges.accessRow(rowIndex).itemObject;
						if obj.isKindOf( CM_CashInvoiceProformaAgent ) then
							self.tblCharges.accessCell(rowIndex,self.tblCharges.column).text := selectionString; 
							ddBalance := ddBalance + self.tblCharges.getCellText( rowIndex, ColumnBalance ).asDecimalFromCurrencyString;
						elseif obj.isKindOf( CM_Debtor ) then
							self.tblCharges.accessCell(rowIndex,self.tblCharges.column).text := selectionString; 
							ddBalance := ddBalance + self.tblCharges.getCellText( rowIndex, ColumnBalance ).asDecimalFromCurrencyString;
						else
							break;
						endif;
					endforeach;
					
					if selectionString = self.unSelectedString then
						self.tblCharges.row := startRow - 1; 
						self.expandCollapseDutyDoc(self.tblCharges.row, false);
						self.tblCharges.accessCell(self.tblCharges.row,ColumnExpandDutyDoc).text := null;
						self.tblCharges.setCellText( self.tblCharges.row, ColumnBalance, null );
					else
						self.tblCharges.accessCell(self.tblCharges.row,ColumnExpandDutyDoc).text := Expand;
						self.tblCharges.setCellText( self.tblCharges.row, ColumnBalance, ddBalance.asCurrencyJMT);
					endif;
				
				endif;
				
			endif;
			self.enableButtonsSetBalances();
		endif;
	endif;
	
	if self.tblCharges.column = ColumnExpandCargo then
		if text = self.Expand then
			self.expandCollapseRow(true);
		elseif text = self.Collapse then
			self.expandCollapseRow(false);
		endif;
	
	elseif self.tblCharges.column = ColumnExpandDutyDoc then
		if text = self.Expand then
			self.expandCollapseDutyDoc(self.tblCharges.row, true);
		elseif text = self.Collapse then
			self.expandCollapseDutyDoc(self.tblCharges.row, false);
		endif;
		
	endif;

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doTblChargesDblClick" id="edba8fd8-35ba-428f-bb80-5f20465e6a04">
        <updating/>
        <source>doTblChargesDblClick() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 March 2013	cnwndl1	Initial creation	Par 30901

*/

vars

begin

	if self.tblCharges.column = ColumnCargoId and app.isAllowedToInspect then
		self.tblCharges.accessRow(self.tblCharges.row).itemObject.inspectModal;
	elseif self.myDebtor &lt;&gt; null then
		self.myAssistant.INV_Assistant.showInvoiceLineList(self.myDebtor, true, self.myMasterMenuAction);
	endif;
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doTblPaymentsClick" id="9d6a2504-3080-4029-996a-7339b50d88f9">
        <updating/>
        <source>doTblPaymentsClick() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 March 2013	cnwndl1	Initial creation	Par 30901

*/

vars

	rowIndex : Integer;
	index : Integer;

begin

	rowIndex := self.tblPayments.row;
	if rowIndex &gt; 1 and rowIndex &lt;= self.tblPayments.rows then
		foreach index in 1 to self.tblPayments.rows do
			if rowIndex = index then
				self.tblPayments.accessRow(index).selected := true;
			else
				self.tblPayments.accessRow(index).selected := false;
			endif;
		endforeach;
	else
		foreach index in 1 to self.tblPayments.rows do
			self.tblPayments.accessRow(index).selected := false;
		endforeach;
	endif;
	
	self.enableButtonsSetBalances();

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doUpdatePaymentLine" id="b03ab310-fa53-4572-b976-0e24d1c4f419">
        <source>doUpdatePaymentLine() protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 March 2013	cnwndl1	Initial creation	Par 30901

*/

vars

	row : Integer;

begin

	row := self.tblPayments.row;
	if row &gt; self.tblPayments.fixedRows and row &lt;= self.tblPayments.rows then
		self.tblPayments.accessRow(self.tblPayments.row).selected := true;
	endif;
	self.displayPaymentLine( true );

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doValidate" id="6a8f9e41-276a-4aed-ad8c-7a820173bdc4">
        <source>doValidate():Boolean protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 July 2012	cnwndl1	Initial creation	Par 29968

*/

vars

	drTerm : CM_DebtorTerminal;
	msg : String;

begin

	if self.cashRequiredToClearCharges &gt; self.totalPayments then
		app.raiseCMException( Cash_less_than_owing, null, null );
		return false;
	endif;
	
	drTerm := self.myTerminal.allDebtorTerminals.getAtKey( self.myDebtor );
	if drTerm = null then
		app.raiseCMException( Debtor_not_found, null, null );
		return false;
	endif;
	
	if self.cashRequiredToClearCharges &lt; self.totalPayments then
		msg := app.getErrorString(Cash_payme_great_than_amoun_ow) &amp; CrLf &amp; app.getErrorString(DoYouWantToContinue);
		if app.msgBox( msg, app.getErrorString(Continue), MsgBox_Yes_No ) &lt;&gt; MsgBox_Return_Yes then
			return false;
		endif;
	endif;
	
	return true;

epilog

end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="enableButtonsSetBalances" id="8f509357-e541-4e28-a9a7-946a4a073a4d">
        <updating/>
        <source>enableButtonsSetBalances() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 January 2013	cnwndl1	Initial creation

*/

vars

	rowIndex : Integer;
	numRows : Integer;
	descriptions : String;
	amounts : String;
	obj : Object;

begin

	self.totalPayments := 0;
	self.cashRequiredToClearCharges := 0;

	self.btnAddPay.enabled := self.myDebtor &lt;&gt; null;
	self.btnUpdPay.enabled := false;
	self.btnDelPay.enabled := false;
	
	if self.tblPayments.rows &gt; 1 then
		if self.tblPayments.row &gt; 1 and self.tblPayments.row &lt;= self.tblPayments.rows then
			if self.tblPayments.accessRow( self.tblPayments.row ).selected then
				self.btnUpdPay.enabled := true;
				self.btnDelPay.enabled := true;
			endif;
		endif;
	endif;
	
	//Add up the selected charges.
	foreach rowIndex in 1 to self.tblCharges.rows do
		obj := self.tblCharges.accessRow(rowIndex).itemObject;
		if obj &lt;&gt; null and obj.isKindOf( CM_DutyDoc ) then
			continue;
		endif;
		if rowIndex = 1 then
			continue;
		endif;
		if not self.isChargeLineSelectedForPaying( rowIndex ) then
			continue;
		endif;
		self.cashRequiredToClearCharges := self.cashRequiredToClearCharges + self.tblCharges.getCellText( rowIndex, ColumnBalance ).asDecimalFromCurrencyString;
	endforeach;
	
	//Add up the payments
	foreach rowIndex in 1 to self.tblPayments.rows do
		if rowIndex = 1 then
			continue;
		endif;
		self.totalPayments := self.totalPayments + tblPayments.getCellText( rowIndex, ColumnPayAmount ).asDecimalFromCurrencyString;
	endforeach;
	
	self.lblCargoTotal2.caption := self.cashRequiredToClearCharges.asCurrencyJMT();
	self.lblCashPaysTot2.caption := self.totalPayments.asCurrencyJMT;
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="expandCollapseDutyDoc" id="f83c6c63-e28e-4564-a745-429397f1c837">
        <source>expandCollapseDutyDoc( _row : Integer; _expand : Boolean) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 November 2013	cnwndl1	Initial creation	Par 32668

*/

vars

	startRow : Integer;
	endRow : Integer;
	rowIndex : Integer;
	obj : Object;
	ddBalance : Decimal [16,4];

begin

	startRow := _row + 1;
	endRow := self.tblCharges.rows;
	if _row &gt; self.tblCharges.fixedRows and startRow &lt;= endRow then
		foreach rowIndex in startRow to endRow do
			obj := self.tblCharges.accessRow(rowIndex).itemObject;
			if obj.isKindOf( CM_CashInvoiceProformaAgent ) then
				self.tblCharges.accessRow(rowIndex).visible := _expand; 
				ddBalance := ddBalance + self.tblCharges.getCellText( rowIndex, ColumnBalance ).asDecimalFromCurrencyString;
			elseif obj.isKindOf( CM_Debtor ) then
				self.tblCharges.accessRow(rowIndex).visible := _expand; 
				ddBalance := ddBalance + self.tblCharges.getCellText( rowIndex, ColumnBalance ).asDecimalFromCurrencyString;
			else
				break;
			endif;
		endforeach;
		
		self.tblCharges.setCellText( _row, ColumnBalance, null);
		if not _expand then
			self.tblCharges.accessCell(_row,ColumnExpandDutyDoc).text := self.Expand;
			self.tblCharges.setCellText( _row, ColumnBalance, ddBalance.asCurrencyJMT);
		else
			self.tblCharges.accessCell(_row,ColumnExpandDutyDoc).text := self.Collapse;	
		endif;
	
	endif;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_row" type="Integer"/>
        <Parameter name="_expand" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="expandCollapseRow" id="8f6439b7-d59c-4f7d-9fb8-49db6c548700">
        <source>expandCollapseRow( _expand : Boolean) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 February 2013	cnwndl1	Initial creation
27/11/2019	jlgsl4	TFS 47529 - JMT - Decimal Values on CM_CashReceipt, CM_CashPayment, CM_CashInvoiceProformaAgent
*/

vars
	obj : Object;
	proformaAgent : CM_CashInvoiceProformaAgent;
	debtor : CM_Debtor;
	tiDetails : String;
	invoicedCharges : String;
	invoicedAmount : String;
	estimatedCharges : String;
	estimatedAmount : String;
	extraTrxs : String;
	totalCharges : String;
	numRows : Integer;
	row : Integer;
	rowHeight : Integer;
	extraCharges : Decimal[23,6];// [16,4]; // TFS 47529
	extraChargesStr : String;
	invAndEstAmount : Decimal[23,6];// [16,4]; // TFS 47529
	paidAmount : Decimal[23,6];// [16,4]; // TFS 47529
	outstandingAmount : Decimal[23,6];// [16,4]; // TFS 47529
	allExtraChargeInvLines : ObjectArray;
	dutyDoc : CM_DutyDoc;
begin
	row := self.tblCharges.row;
	
	if row &gt; self.tblCharges.fixedRows and row &lt;= self.tblCharges.rows then
		obj := self.tblCharges.accessRow( row ).itemObject;
	endif;
	
	if obj = null then
		return;
	endif;
	
	row := self.tblCharges.row;
	
	if obj.isKindOf(CM_CashInvoiceProformaAgent) then
		proformaAgent := obj.CM_CashInvoiceProformaAgent;
		invAndEstAmount := (proformaAgent.invoicedCashCharges + proformaAgent.estimatedCashCharges);
		paidAmount := proformaAgent.getPaidAmount();
		outstandingAmount := invAndEstAmount - paidAmount;
		if outstandingAmount = 0 then
			self.tblCharges.accessCell(row,ColumnInclude).text := self.unSelectedString; // Not included, as there is nothing owing.
		endif;
	elseif obj.isKindOf(CM_Debtor) then
		debtor := obj.CM_Debtor;
		dutyDoc := self.tblCharges.accessCell(row,ColumnExpandDutyDoc).itemObject.CM_DutyDoc;
		create allExtraChargeInvLines transient;
		extraCharges := self.getExtraCharges( dutyDoc, numRows, invoicedCharges, invoicedAmount, allExtraChargeInvLines );
		extraChargesStr := extraCharges.asCurrencyJMT;
	else
		return;
	endif;
	
	rowHeight := self.tblCharges.accessRow(1).height;
	if _expand then
		//expand 
		if proformaAgent &lt;&gt; null then
			proformaAgent.getExpandedDetails(numRows,invoicedCharges,invoicedAmount,estimatedCharges,estimatedAmount,extraTrxs);
			if estimatedAmount = null then
				estimatedAmount := "0.0".Decimal.asCurrencyJMT;
			endif;
		else
			invoicedAmount := invoicedAmount;
			estimatedCharges := null;
			estimatedAmount := null;
		endif;
		
		self.expandCollapseRowCells(self.tblCharges.row,false);
		
		self.tblCharges.accessCell(row,ColumnExpandCargo).text := self.Collapse;
		self.tblCharges.accessCell(row,ColumnInvoiceDescription).text := invoicedCharges;
		self.tblCharges.accessCell(row,ColumnInvoiceValue).text := invoicedAmount;
		self.tblCharges.accessCell(row,ColumnEstDescription).text := estimatedCharges;
		self.tblCharges.accessCell(row,ColumnEstValue).text := estimatedAmount;
		
		
		if proformaAgent &lt;&gt; null then
			self.tblCharges.accessCell(row,ColumnCargoId).text := proformaAgent.myTrackedItem.id;
			self.tblCharges.accessCell(row,ColumnTotCharges).text := invAndEstAmount.asCurrencyJMT;
			self.tblCharges.accessCell(row,ColumnPaid).text := paidAmount.asCurrencyJMT;
			self.tblCharges.accessCell(row,ColumnBalance).text := outstandingAmount.asCurrencyJMT;
		else
			self.tblCharges.accessCell(row,ColumnCargoId).text := app.getErrorString(Extra_charges);
			self.tblCharges.accessCell(row,ColumnTotCharges).text := extraChargesStr;
			self.tblCharges.accessCell(row,ColumnPaid).text := null;
			self.tblCharges.accessCell(row,ColumnBalance).text := extraChargesStr;
		endif;
		
		self.tblCharges.accessRow( row ).height :=  numRows * rowHeight;
	else
		self.expandCollapseRowCells(row,true);
		
		self.tblCharges.accessCell(row,ColumnExpandCargo).text := self.Expand;
		self.tblCharges.accessCell(row,ColumnInvoiceValue).text := null;
		self.tblCharges.accessCell(row,ColumnEstValue).text := null;
		
		if proformaAgent &lt;&gt; null then
			self.tblCharges.accessCell(row,ColumnCargoId).text := proformaAgent.myTrackedItem.id;
			self.tblCharges.accessCell(row,ColumnInvoiceDescription).text := proformaAgent.invoicedCashCharges.asCurrencyJMT;
			self.tblCharges.accessCell(row,ColumnEstDescription).text := proformaAgent.estimatedCashCharges.asCurrencyJMT;
			self.tblCharges.accessCell(row,ColumnTotCharges).text := invAndEstAmount.asCurrencyJMT;
			self.tblCharges.accessCell(row,ColumnPaid).text := paidAmount.asCurrencyJMT;
			self.tblCharges.accessCell(row,ColumnBalance).text := outstandingAmount.asCurrencyJMT;
		else
			self.tblCharges.accessCell(row,ColumnCargoId).text := app.getErrorString(Extra_charges);
			self.tblCharges.accessCell(row,ColumnInvoiceDescription).text := extraChargesStr;
			self.tblCharges.accessCell(row,ColumnEstDescription).text := null;
			self.tblCharges.accessCell(row,ColumnTotCharges).text := extraChargesStr;
			self.tblCharges.accessCell(row,ColumnPaid).text := null;
			self.tblCharges.accessCell(row,ColumnBalance).text := extraChargesStr;
		endif;
		self.tblCharges.accessRow( row ).height := rowHeight;
		
	endif;
	
	self.tblCharges.accessCell(row,ColumnExpandCargo).fontBold:=true;
	
epilog

	delete allExtraChargeInvLines;

end;</source>
        <access>protected</access>
        <Parameter name="_expand" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="expandCollapseRowCells" id="ff3181cf-f647-431e-b42a-007c4c04ad63">
        <source>expandCollapseRowCells(_row : Integer; _collapse : Boolean) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 February 2013	cnwndl1	Initial creation

*/

vars

begin
	
	if  _collapse then
		self.tblCharges.accessCell(_row,ColumnInvoiceDescription).alignment:=Table.Alignment_Right_Top;
		self.tblCharges.accessCell(_row,ColumnInvoiceDescription).gridRight :=true;
		self.tblCharges.accessCell(_row,ColumnInvoiceDescription).mergeCells:=Table.MergeCells_Merge;
		self.tblCharges.accessCell(_row,ColumnEstDescription).mergeCells:=Table.MergeCells_NotAvailable;
		self.tblCharges.accessCell(_row,ColumnEstDescription).alignment:=Table.Alignment_Right_Top;
		self.tblCharges.accessCell(_row,ColumnEstDescription).gridRight :=true;
		self.tblCharges.accessCell(_row,ColumnEstDescription).mergeCells:=Table.MergeCells_Merge;
		
	else
		self.tblCharges.accessCell(_row,ColumnInvoiceDescription).alignment:=Table.Alignment_Left_Top;
		self.tblCharges.accessCell(_row,ColumnInvoiceDescription).mergeCells:=Table.MergeCells_NotAvailable;
		self.tblCharges.accessCell(_row,ColumnInvoiceDescription).gridRight :=false;
		self.tblCharges.accessCell(_row,ColumnInvoiceValue).alignment:=Table.Alignment_Right_Top;
		self.tblCharges.accessCell(_row,ColumnEstDescription).mergeCells:=Table.MergeCells_NotAvailable;
		self.tblCharges.accessCell(_row,ColumnEstDescription).alignment:=Table.Alignment_Left_Top;
		self.tblCharges.accessCell(_row,ColumnEstDescription).gridRight :=false;
		self.tblCharges.accessCell(_row,ColumnEstValue).alignment:=Table.Alignment_Right_Top;
		self.tblCharges.accessCell(_row,ColumnEstDescription).mergeCells:=Table.MergeCells_NotAvailable;
		
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_row" type="Integer"/>
        <Parameter name="_collapse" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="firstDutyDocSelected" id="f4ba3526-86d6-471e-85c7-2856a501e8e1">
        <source>firstDutyDocSelected():CM_DutyDoc;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 December 2013	cnwndl1	Initial creation	Par 33182

*/
vars

	rowObject : Object;
	row : Integer;

begin

	foreach row in 1 to self.tblCharges.rows do
		if self.isChargeLineSelectedForPaying( row ) then
			rowObject := self.tblCharges.accessRow(row).itemObject;
			if rowObject = null then
				continue;
			endif;
			if rowObject.isKindOf(CM_DutyDoc) then
				return rowObject.CM_DutyDoc;
			endif;
		endif;
	endforeach;

	return null;

epilog
	
end;
</source>
        <ReturnType type="CM_DutyDoc"/>
    </JadeMethod>
    <JadeMethod name="getDutyDocs" id="0a3e0f8a-810f-4753-8c29-3699fe54059a">
        <source>getDutyDocs( allDutyDocs : CM_DutyDocById input );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 January 2013	cnwndl1	Initial creation	Par 30901

*/

vars

	row : Integer;
	dutyDocRoot : CM_DutyDocRoot;
	dutyDocTerminalRoot : CM_DutyDocTerminalRoot;
	dutyDoc : CM_DutyDoc;
	newestDutyDoc : CM_DutyDoc;
	dutyDocItem : CM_DutyDocItem;
	iterDutyDoc : Iterator;
	consignee : CM_ConsigneeConsignor;	//07 Nov 2013	NDL	Par 32940
	startDate : Date;
	
begin

	if self.myInitDutyDoc &lt;&gt; null then
		allDutyDocs.add( self.myInitDutyDoc );
		return;
	endif;
	
	dutyDocRoot := app.myDutyDocRoot();
	if dutyDocRoot = null then
		return;
	endif;
	dutyDocTerminalRoot := dutyDocRoot.allDutyDocTerminalRoots[self.myTerminal];
	if dutyDocTerminalRoot = null then
		return;
	endif;
	
	consignee := self.cmbConsignee.listObject.CM_ConsigneeConsignor;	//07 Nov 2013	NDL	Par 32940

	if self.optItem.value then
	
		if self.txtItemId.text.trimBlanks &lt;&gt; null then
		
			if self.myTerminal.getConfig(ProFormaInclDDTicket).Boolean then
				dutyDoc := dutyDocTerminalRoot.allDutyDocsByTicket.getAtKey( self.txtItemId.text.toUpper );
				if dutyDoc &lt;&gt; null then // there is at least one that matches, find the most recent.
					iterDutyDoc := dutyDocTerminalRoot.allDutyDocsByTicket.createIterator;
					iterDutyDoc.startAtObject( dutyDoc );
					while iterDutyDoc.next( dutyDoc ) do
						if dutyDoc.ticket.toUpper &lt;&gt; self.txtItemId.text.toUpper then
							break;
						endif;
						if dutyDoc.status &lt;&gt; DutyDoc_Approved then
							continue;
						endif;
						if newestDutyDoc = null or dutyDoc.createdDate &gt; newestDutyDoc.createdDate then
							newestDutyDoc := dutyDoc;
						endif;
					endwhile;
					delete iterDutyDoc;
					
					//we have the latest
					if newestDutyDoc &lt;&gt; null then
						allDutyDocs.add( newestDutyDoc );
						return;
					endif;
				endif;
			endif;
			
			if self.myTerminal.getConfig(ProFormaInclDDBill).Boolean then	// this number is unique
				dutyDoc := dutyDocTerminalRoot.allDutyDocsById.getAtKey( self.txtItemId.text.toUpper );
				if dutyDoc &lt;&gt; null and dutyDoc.status = DutyDoc_Approved then
					allDutyDocs.add( dutyDoc );
					return;
				endif;
			endif;
			
		endif;
		
	elseif self.optConsignee.value then
	
		if consignee = null then	//07 Nov 2013	NDL	Par 32940
			app.msgBox( app.getErrorString(Must_select_consign_first), app.getErrorString(Error), MsgBox_OK_Only);
			self.cmbConsignee.setFocus();
			return;
		
		else
		
			iterDutyDoc := dutyDocTerminalRoot.allDutyDosByStatus.createIterator;
			if self.txtDateFrom.text = null then
				startDate := null;
			else
				startDate := self.txtDateFrom.getDate;
			endif;
	
			dutyDoc := dutyDocTerminalRoot.allDutyDosByStatus.getAtKeyGeq( DutyDoc_Approved, startDate );
			if dutyDoc &lt;&gt; null then
				iterDutyDoc.startAtObject( dutyDoc );
				while iterDutyDoc.next( dutyDoc ) do
					if dutyDoc.status &lt;&gt; DutyDoc_Approved then
						break;
					endif;
					if dutyDoc.getMyConsignee &lt;&gt; consignee then
						continue;
					endif;
					allDutyDocs.add( dutyDoc );
				endwhile;
			endif;
			delete iterDutyDoc;
	
		endif;
	
	endif;

epilog

	delete iterDutyDoc;

end;</source>
        <Parameter name="allDutyDocs" type="CM_DutyDocById" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getExtraCharges" id="fd5c9677-4b15-43d7-a142-ee806dc78900">
        <source>getExtraCharges( _dutyDoc : CM_DutyDoc; _numRows : Integer output; _descriptions : String output; _amounts : String output; _allExtraChargeInvLines : ObjectArray input):Decimal protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 February 2013	cnwndl1	Initial creation

*/

vars

	extraCharges : Decimal [16,4];
	invoice : CM_Invoice;
	
	totalCharges : Decimal [16,4];
	cashAmount	: Decimal [16,4];
	outstandingAmount : Decimal [16,4];
	
	allExtraChargeInvs : CM_InvoiceSet;
	invLine : CM_InvoiceLine;
	
	lastNumRows : Integer;

begin

	_numRows := 0;
	_descriptions := null;
	_amounts := "0.0".Decimal.asCurrencyJMT;

	if self.myDebtor = null then
		return 0.0;
	endif;
	
	if _dutyDoc = null then
		return 0.0;
	endif;
	
	create allExtraChargeInvs transient;
	self.myDebtor.getDutyDocExtraCharges( self.myTerminal, allExtraChargeInvs );
	if allExtraChargeInvs.isEmpty then
		return 0.0;
	endif;
	
	foreach invoice in allExtraChargeInvs do
		if invoice.isExtraChargeForDutyDocSystem( totalCharges, cashAmount, outstandingAmount) then
			lastNumRows := _numRows;	//03 Feb 2014	NDL	Par 33181
			foreach invLine in invoice.invoiceLines where not invLine.voided do
				if invLine.remarks.pos(_dutyDoc.id,1) &lt;&gt; 1 then
					continue;
				endif;
				
				_numRows := _numRows + 1;
				if _numRows = 1 then
					_descriptions := invLine.invoiceLineDesc.narration;
					_amounts := invLine.lineTotal.asCurrencyJMT;
				else
					_descriptions := _descriptions &amp; CrLf &amp; invLine.invoiceLineDesc.narration;
					_amounts := _amounts &amp; CrLf &amp; invLine.lineTotal.asCurrencyJMT;
				endif;
				_allExtraChargeInvLines.addExclusive( invLine );
				extraCharges := extraCharges + invLine.lineTotal;
			endforeach;
			if _numRows &gt; lastNumRows then	//03 Feb 2014	NDL	Par 33181 - There were no inv lines so we don't care
				if cashAmount &lt;&gt; 0 then
					_numRows := _numRows + 1;
					_descriptions := _descriptions &amp; CrLf &amp; "Cash Paid";
					_amounts := _amounts &amp; CrLf &amp; cashAmount.asCurrencyJMT;
				endif;
			endif;
			
		endif;
	endforeach;

	return extraCharges;

epilog

	delete allExtraChargeInvs;

end;</source>
        <access>protected</access>
        <Parameter name="_dutyDoc" type="CM_DutyDoc"/>
        <Parameter name="_numRows" type="Integer" usage="output"/>
        <Parameter name="_descriptions" type="String" usage="output"/>
        <Parameter name="_amounts" type="String" usage="output"/>
        <Parameter name="_allExtraChargeInvLines" type="ObjectArray" usage="input"/>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="getTIsFromDutyDoc" id="76816032-6b48-4e91-b19c-84bfbb79ac35">
        <source>getTIsFromDutyDoc(dutyDoc : CM_DutyDoc input; objArray : ObjectArray input; _effectiveDate : Date output) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 March 2013	cnwer1	Initial creation HAT 2189

*/

vars
	iterDutyDocItem : Iterator;
	ti : CM_TrackedItem;
	dutyDocItem : CM_DutyDocItem;
begin
	_effectiveDate := dutyDoc.effectiveDate;
	iterDutyDocItem := dutyDoc.allDutyDocItems.createIterator;
	while iterDutyDocItem.next( dutyDocItem ) do
		ti := dutyDocItem.getMyTrackedItem;
		if ti = null then
			continue;
		endif;
		if objArray.includes( ti ) then
			continue;
		endif;
		if not ti.allCashPayments.isEmpty then
			//Must have been paid, no point in checking this one.
			break;
		endif;
		if ( not ti.isOnSite and not ti.isOnShip ) then
			continue;
		endif;
		
		objArray.add( ti );
	endwhile;
epilog
	delete iterDutyDocItem;
end;</source>
        <access>protected</access>
        <Parameter name="dutyDoc" type="CM_DutyDoc" usage="input"/>
        <Parameter name="objArray" type="ObjectArray" usage="input"/>
        <Parameter name="_effectiveDate" type="Date" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getXMLSettingsForSave" id="7786ab33-09f1-4d58-9a3f-64a059aed99b">
        <updating/>
        <source>getXMLSettingsForSave(): String updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
23 July 2012	cnwndl1	Initial creation

*/

vars

	str : String;

begin

	str	:=	inheritMethod();
	str := str &amp; global.formatAsXML( self.chkPrintRec.name, self.chkPrintRec.value.String);

	
	return str;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="initChargesTable" id="6bfadc4d-11d8-489f-9c36-0c54912fc2b6">
        <source>initChargesTable() protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 February 2013	cnwndl1	Initial creation

*/

vars
	headings : String;
begin

	self.deleteProformaAgents();
	
	self.tblCharges.selectMode:=Table.SelectMode_None;
	self.tblCharges.visible:=true;
	self.tblCharges.rows:=1;
	self.tblCharges.fixedRows:=1;
	self.tblCharges.columns:=ColumnBalance;
	self.tblCharges.fixedColumns:=0;
	self.tblCharges.accessRow(1).fontBold:=true;
	self.tblCharges.accessColumn(ColumnInclude).alignment:=Table.Alignment_Center_Top;
	self.tblCharges.accessColumn(ColumnInclude).width:=60;
	self.tblCharges.accessColumn(ColumnInclude).fontBold:=true;
	self.tblCharges.accessColumn(ColumnExpandDutyDoc).alignment:=Table.Alignment_Center_Top;
	self.tblCharges.accessColumn(ColumnExpandDutyDoc).width:=20;
	self.tblCharges.accessColumn(ColumnExpandDutyDoc).fontBold:=true;
	self.tblCharges.accessColumn(ColumnDutyDocId).alignment:=Table.Alignment_Left_Top;
	self.tblCharges.accessColumn(ColumnDutyDocId).width:=110;
	self.tblCharges.accessColumn(ColumnDutyDocId).fontBold:=true;
	self.tblCharges.accessColumn(ColumnExpandCargo).alignment:=Table.Alignment_Center_Top;
	self.tblCharges.accessColumn(ColumnExpandCargo).width:=20;
	self.tblCharges.accessColumn(ColumnExpandCargo).fontBold:=true;
	self.tblCharges.accessColumn(ColumnCargoId).alignment:=Table.Alignment_Left_Top;
	self.tblCharges.accessColumn(ColumnInvoiceValue).alignment:=Table.Alignment_Right_Top;
	self.tblCharges.accessColumn(ColumnEstValue).alignment:=Table.Alignment_Right_Top;
	self.tblCharges.accessColumn(ColumnTotCharges).alignment:=Table.Alignment_Right_Top;
	self.tblCharges.accessColumn(ColumnPaid).alignment:=Table.Alignment_Right_Top;
	self.tblCharges.accessColumn(ColumnBalance).alignment:=Table.Alignment_Right_Top;
	self.tblCharges.accessCell(1,ColumnInvoiceDescription).mergeCells:=Table.MergeCells_Merge;
	self.tblCharges.accessCell(1,ColumnEstDescription).mergeCells:=Table.MergeCells_NotAvailable;
	self.tblCharges.accessCell(1,ColumnEstDescription).mergeCells:=Table.MergeCells_Merge;
	
	headings := 	app.getErrorString(Include) &amp; Tab			//Include - column 1
					&amp; "" &amp; Tab									//Expand for Duty Doc	- column 2		
					&amp; app.getErrorString(Duty_document) &amp; Tab	//Duty Doc Id	- column 3						
					&amp; "" &amp; Tab									//Expand for Cargo	- column 4						
					&amp; app.getErrorString(Cargo)	&amp; Tab			//Cargo id	- column 5
					&amp; app.getErrorString(Invoiced) &amp; Tab 		//Invoice description	- column 6
					&amp; "" &amp; Tab									//Invoice value	- column 7
					&amp; app.getErrorString(Estimated) &amp; Tab		//Estimate description	- column 8
					&amp; "" &amp; Tab									//Estimate value	- column 9
					&amp; app.getErrorString(Total_charges) &amp; Tab	//Total charges value	- column 10
					&amp; app.getErrorString(Paid) &amp; Tab			//Total paid value	- column 11
					&amp; app.getErrorString(Balance);				//Balance value - column 12
					
	self.tblCharges.setCellText(1,1,headings);
	
	//Hide these two for now
	self.tblCharges.accessColumn(ColumnTotCharges).visible := false;
	self.tblCharges.accessColumn(ColumnPaid).visible := false;
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="initFromUserWindow" id="e897c1f0-7d34-4ff5-b413-f90e16c09232">
