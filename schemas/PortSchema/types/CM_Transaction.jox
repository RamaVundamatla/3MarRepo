    <JadeMethod name="createAndSetSnapShot" id="0d1817f6-56d5-4259-8c75-8774736aab09">
        <updating/>
        <source>createAndSetSnapShot(_snapShotOf : CM_Object) updating, protected;
// ---------------------------------------------------------------------------
// Created:     19 July 2004	cnwth2
//
// Purpose:     Call from an updating 
//				method where you have the snapShotOf object
//				Example, see CM_TITransaction.setTrackedItem
//			 	
// ----------   ----------  --------------------------------------------------
vars
	snapShot			: CM_SnapShot;
begin
	if (_snapShotOf = null) or (not self.doesRequireSnapShot) then
		return;
	endif;
	
	create self.mySnapShot as self.getSnapShotClassToCreate() persistent;
	
	self.mySnapShot.setCreatedRefs(self, _snapShotOf);
	self.mySnapShot.takeSnapShot();

end;</source>
        <access>protected</access>
        <Parameter name="_snapShotOf" type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="createChargeDeferred" id="a1a7b069-b33f-4938-88bd-0fc2b834db3e">
        <updating/>
        <source>createChargeDeferred(_passport: CM_Passport):Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 Jul 2021	navndl1	Initial creation	TFS 51443
28 May 2024 navma1	Bug 64224: MTN - DeadLocks Caused by Future Actors
*/

vars

	term 		: CM_Terminal;
	useDeferred : Boolean;
	request 	: BGP_DeferredChargingRequest;

begin
	
	term := self.getMyTerminal;
	if term = null then
		//app.raiseUnexpectedProgramError(class.name, method.name, CM_TITransaction::myTerminal.name &amp; " is null.");  // ### JIRA 33567 03DEC2024 NAVAB1 events might not have a terminal
		return false;
	endif;
	
	if term &lt;&gt; null then
		if app.deferredChargesBgpRunning then  // do we have an appropiate BGP App running
			useDeferred := term.getConfig(DeferredCharging).Boolean; //does this terminal want to use deferred charging 
		endif;
	endif;
	
	if useDeferred  then
		
		if not self.isChargeable then			//28.05.2024 navma1 #64224
			return true;
		endif;
		
		//just create a request and let the BGP handle creating the charges as a separate piece of work.
		create request persistent;
		request.setTransaction( self );
		return true;
	else
		//create the charges inline.  Keeps them in the same database transaction, BUT slows
		// the overall transaction increasing lock times and the potential for perfomance issues and deadlocks.
		return self.doCreateCharge( _passport );
	
	endif;

epilog

end;</source>
        <Parameter name="_passport" type="CM_Passport"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="createExtension" id="0760d114-1980-4202-a3d1-3a5d9a18cdb7">
        <updating/>
        <source>createExtension(_extClass : Class) updating, protected;
// ---------------------------------------------------------------------------
// Created:     30 August 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if self.isTransient then
		// do not create for transients
		return;
	endif;
	
	create self.myExtension as _extClass persistent;
	self.myExtension.initialize();

end;</source>
        <access>protected</access>
        <Parameter name="_extClass" type="Class"/>
    </JadeMethod>
