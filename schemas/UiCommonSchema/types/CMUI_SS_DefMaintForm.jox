    <JadeMethod name="checkChanged" id="71d83956-e57f-470b-8860-978a99ea1be9">
        <source>checkChanged() : Boolean;
// 26608 Dec 2010 snap shot definition form issues, warn about unsaved changes
vars

begin
	if self.hasChanged and
	   btnSave.enabled = true then
		if app.msgBox(app.getErrorString(EditChangedAndClosing), app.getErrorString(MSGBOX_UnsavedChangesTitle), MsgBox_Yes_No + MsgBox_Question_Mark_Icon) &lt;&gt; MsgBox_Return_Yes then
			return true;
		endif;	
	endif;
	
	return false;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
