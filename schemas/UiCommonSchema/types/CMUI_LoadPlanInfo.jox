    <JadeMethod name="displayShipControllerInfo" id="e5868e78-6c6f-4be4-96db-9dd714b903e5">
        <source>displayShipControllerInfo();
// --------------------------------------------------------------------------------
// Created:		23 November 2010 by cnwjo3
//
// Purpose:		
//// 17 May 2016	cnwns1	TFS 488 - Multi Timezone Support
vars
	seconds : Integer;
	endDateTime : TimeStamp;	
	jobColourCoded : Integer;
	jobNotPlanned : Integer;
	jobPlanned : Integer;
	errorWarning : String;
	errorsAndWarnings : String200Array;
	ew : String;
	rowIndex : Integer;

begin
	self.tblInfo.clear();
	self.tblInfo.rows := 0;
	self.tblInfo.columns := 2;
	self.tblInfo.fixedColumns := 0;	
	
	self.tblErrors.clear();

	self.tblInfo.addItem("");
	
	self.tblInfo.addItem(app.getErrorString(Voyage) &amp; ":" &amp; Tab &amp; self.myCurrentVoyage.code);
	self.tblInfo.addItem("");
	endDateTime := app.actualTimeServer();// 17 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	seconds := (self.startDateTime.cnEcDiff(endDateTime)/1000).Integer;
	self.tblInfo.addItem(app.getErrorString(LoadPlanInfo_PlanningDuration) &amp; ":" &amp; Tab &amp; seconds.getHMS());
	self.tblInfo.addItem("");
	
	self.tblInfo.addItem(app.getErrorString(LoadPlanInfo_TotalOnsiteContai) &amp; ":" &amp; Tab &amp; self.myCurrentVoyage.getNumAllOnsiteTIsByIMEX(TI_IMEX_STATUS_EXPORT).String);
	self.tblInfo.addItem(app.getErrorString(LoadPlanInfo_TotalPrenotedCont) &amp; ":" &amp; Tab &amp; self.myCurrentVoyage.allNotifiedTIsByCargoTypeId.size.String);
	self.tblInfo.addItem(app.getErrorString(LoadPlanInfo_TotalOnsitePlanne) &amp; ":" &amp; Tab &amp; self.myCurrentVoyage.getNumOnsiteNonPlannedTIs().String);
	self.tblInfo.addItem(app.getErrorString(LoadPlanInfo_TotalSlotsColorCo) &amp; ":" &amp; Tab &amp; self.myCurrentVoyage.myCellularVoyageStructure.getTotalColourCode(true,true, true).String);
	self.tblInfo.addItem("");

	self.tblInfo.addItem(app.getErrorString(LoadPlanInfo_Crane) &amp; ":" &amp; Tab &amp; self.allJobs.first().CM_VoyageJob.craneId);
	if self.allJobs.size &gt; 50 then
		self.tblInfo.addItem(app.getErrorString(LoadPlanInfo_JobOrJobs) &amp; ":" &amp; Tab &amp; self.allJobs.size.String &amp; " " &amp; app.getErrorString(Jobs));
	else
		self.tblInfo.addItem(app.getErrorString(LoadPlanInfo_JobOrJobs) &amp; ":" &amp; Tab &amp; self.allJobs.getName());
	endif;
	self.tblInfo.addItem("");
	
	jobColourCoded := self.allJobs.getTotalRequests(false);
	jobNotPlanned := self.allJobs.getTotalRequests(true);
	jobPlanned := jobColourCoded - jobNotPlanned;
	
	self.tblInfo.addItem(app.getErrorString(LoadPlanInfo_Planned) &amp; ":" &amp; Tab &amp; jobPlanned.String);
	self.tblInfo.addItem(app.getErrorString(LoadPlanInfo_NotPlanned) &amp; ":" &amp; Tab &amp; jobNotPlanned.String);
	self.tblInfo.addItem(app.getErrorString(LoadPlanInfo_ColourCoding) &amp; ":" &amp; Tab &amp; jobColourCoded.String);
	self.tblInfo.addItem("");
	
	if self.shipController.errorsWarnings &lt;&gt; null then
		self.tblErrors.addItem(app.getErrorString(LoadPlanInfo_ErrorsFound));
		self.tblErrors.addItem("");
		//self.tblErrors.addItem(self.shipController.errorsWarnings);
		create errorsAndWarnings transient;
		
		self.shipController.errorsWarnings.asString200ArrayByDelimiter(errorsAndWarnings,CrLf);
		
		foreach ew in errorsAndWarnings do
			rowIndex := self.tblErrors.addItem(ew);
			if ew.pos(app.getErrorString(Warning) &amp; " - ",1) &gt; 0 then
				self.tblErrors.itemBackColor[rowIndex] := LightYellow;
			elseif ew.pos(app.getErrorString(Error) &amp; " - ",1) &gt; 0 then
				self.tblErrors.itemBackColor[rowIndex] := Red;
				self.tblErrors.itemForeColor[rowIndex] := White;
			endif;
		endforeach;
	else
		self.tblErrors.addItem(app.getErrorString(LoadPlanInfo_NoErrorsFound));
	endif;
epilog
	delete errorsAndWarnings;
end;</source>
    </JadeMethod>
