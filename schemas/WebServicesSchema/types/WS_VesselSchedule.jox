    <JadeMethod name="delete" id="c2843270-895d-48b3-8f9a-6c29678f2997">
        <updating/>
        <source>delete() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 Jan 2026 navma1 MTN-36897 PEN - Transient File Growth in PEN Production Environment 

*/

vars

begin
	self.nextValidStatuses.purge(); //08.01.2026 navma1 #MTN-36897
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setProxyFromObject" id="9c454e15-9aab-4c1a-85ee-ab618ab2e73d">
        <updating/>
        <source>setProxyFromObject(_object: CM_Voyage) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
29 Sept 2017	jlghl1	Initial creation
06 Aug 2018		jlgam15	TFS 39931 - added 'hasCargo' field for the voyage request.
16 Aug 2018  	cnwma1	ChangeRequest 39698: PEL1 - SAP Enable SAP interfaces
11 Sep 2018		jlgdap1	TFS 40030 PEL1 Multiple Estimates and Invoices
19 Sep 2018		NDL		TFS 40807
18 Nov 2020     cnwma1  Bug 50370: LNX- Webportal and Options drop down menu issue
07 Oct 2021		jlier1  TFS 51963 
10 Jan 2022		navma1  ChangeRequest 52510: SAL - Web Portal - Berth display in Cargo Request
15 Feb 2023 	navma1  ChangeRequest 56561: FR 53944 | EUP - Simplified Voyage Work Order
*/

vars
	previousPort,
	nextPort 		: CM_Port;
	voyStatus 		: CM_VoyageStatus;
	nextStatuses 	: CM_VoyageStatusByPriority;
	voyWorkOrder 	: CM_WorkOrderVoyageDtl;
	workOrder		: CM_WorkOrder;
	financeStatus   : String;
	invoice 		: CM_Invoice;						// TFS 40030
	failedDAC 		: CM_DataAccessController;
	berth			: HMS_Berth;
	voyageProcess   : CM_VoyageProcess;
	hmsVoyageData   : HMS_VoyageData;
	root			: CM_Root;
	processTerminal : CM_ProcessTerminal;
	user			: CM_User;
begin
	inheritMethod(_object);
	
	root 			:= app.myRoot;									//10.01.2022 navma1 #52510
	user			:= app.getMyUser();								//15.02.2023 navma1 #56561
	self.vesselName := _object.vesselName;
	self.voyageCode := _object.code;
	voyStatus		:= root.allVoyageStatuses[_object.status];
	voyageProcess   := _object.myVoyageProcess;						//18.11.2020 cnwma1 #50370
	hmsVoyageData   := _object.myHMSVoyageData;
	
	//16.8.2018 cnwma1 TFS #39698
	// if Current Status is Cargo Requested ,But The Wo order staus is Finance Pending 
	// The user is not allowed to to update the Intial cargo Request ,
	// Also we need to change the voyage status by concat The Current Voyage Status with the Wo Status "Cargo Request Finance Pending"
	if voyStatus &lt;&gt; null then
		voyWorkOrder := _object.getWorkOrderForStatus();
		if voyWorkOrder &lt;&gt; null then
			workOrder := voyWorkOrder.getMyParent;
			if workOrder &lt;&gt; null then
				if workOrder.taskStatus = WO_STATUS_PENDING_FIN then
					financeStatus := app.getErrorString(WO_STATUS_PENDING_FIN_DESC);			//15.02.2023 navma1 #56561
				elseif workOrder.taskStatus = WO_STATUS_REJECTED_FIN then
					financeStatus := app.getErrorString(WO_STATUS_REJECTED_FIN_DESC);			//15.02.2023 navma1 #56561
				endif;
			endif;
		endif;
		self.status :=  voyStatus.description;
		if financeStatus &lt;&gt; null then
			self.status :=  voyStatus.description &amp; " - " &amp; financeStatus;
		endif;
	endif;
	
	self.statusCode    		:= _object.status; 								//21/3/18  epr tfs 37662 pelindo status details 
	self.departDT      		:= _object.departedDT.asStringForWebInterface;
	self.arriveDT      		:= _object.arrivedDT.asStringForWebInterface;
	self.operatorCode  		:= _object.operatorCode;
	self.hasCargo 	   		:= _object.myGeneralCargoVoyage &lt;&gt; null;
	self.hasTowedVoyages	:= _object.allTowedVoyages.isNotEmpty();		//10.01.2022 navma1 #52510
	processTerminal		    := _object.getProcessTerminal();				//10.01.2022 navma1 #52510
	if processTerminal &lt;&gt; null then											//10.01.2022 navma1 #52510
		self.allowUpdateWOBerth := processTerminal.allowUpdateOfIMSRBerth;  //10.01.2022 navma1 #52510
	endif;
	
	//jlier1 TFS 51963 4/10/21
	if _object.myTrade &lt;&gt; null then
		self.trade:=_object.myTrade.description;
	endif;
	
	if hmsVoyageData &lt;&gt; null then
		berth := hmsVoyageData.getMyBerth();		// 30/8/19 MAP TFS46374
		if berth &lt;&gt; null then
			self.berth := berth.code;
		endif;
		previousPort := root.allPorts[hmsVoyageData.portArrivingFromCode];
		nextPort	 := root.allPorts[hmsVoyageData.portDepartingToCode];
		
		self.cargo					:= _object.getCargoDescription(); 					// TFS 40747 	
		self.grossRegisteredTonnage := hmsVoyageData.dim_GrossRegTonnes.String &amp; ' T';	// 19 Sep 2018	NDL	TFS 40807
		self.loa 					:= hmsVoyageData.dim_LengthOverall.String  &amp; ' m';	// 19 Sep 2018	NDL	TFS 40807
		if hmsVoyageData.myVesselType &lt;&gt; null then
			self.vesselType := hmsVoyageData.myVesselType.description;					//19 Sep 2018	NDL	TFS 40807
		endif;
	endif;	
	
	if previousPort = null then
		previousPort	:=_object.getPreviousPortInRotation;
	endif;
	if previousPort &lt;&gt; null then
		self.arrivingFrom := previousPort.description;
	endif;	
		
	if nextPort = null then
		nextPort 		:= _object.getNextPortInRotation;
	endif;
	if nextPort &lt;&gt; null then
		self.goingTo := nextPort.description;
	endif;
	
	
	create nextStatuses transient;
	
	//epr TFS 42396 13/12/18 move the departure date/time check in method
	// some departures can be updated after the departure dt if it is at a private berth
	_object.getNextValidStatuses(nextStatuses);

	
	//if at a SAP finance status they are not allowed to update
	if financeStatus = null then	
		foreach voyStatus in nextStatuses do
			//epr TFS 41523 2/11/18
			self.nextValidStatuses.add(voyStatus.id.String);
		endforeach;
	endif;
	
	if voyageProcess &lt;&gt; null and not voyageProcess.isDefaultProcessJMT then
		//epr TFS 42346 4/12/18
		foreach workOrder in _object.allWorkOrders discreteLock do
			if workOrder.taskStatus = WO_STATUS_CANCELLED then
				continue;
			endif;
			
			if workOrder.taskStatus = WO_STATUS_NOTAPPROVED then
				continue;
			endif;
		
			if workOrder.canAccessCashReceipts(user,app.myPassport) then
				self.canEstimate := true;
				break;
			endif;
			
		endforeach;
		// TFS 41539 show all prepend, pending and posted
		//epr TFS 41539 -don't need to check for work order 5/11/2018 
		foreach invoice in _object.allInvoices where invoice.status.isOneOf(invoice.INVOICE_PREPEND, invoice.INVOICE_PENDING, invoice.INVOICE_POSTED) do
			if invoice.invoiceLines.isEmpty() then
				continue;
			endif;
			
			if not invoice.debtor.canUserAccessSelf(user, failedDAC, app.myPassport) then
				continue;
			endif;
			
			self.canPreInvoice := invoice.status.isOneOf(invoice.INVOICE_PREPEND, invoice.INVOICE_PENDING, invoice.INVOICE_POSTED) ;
			self.canTaxInvoice := invoice.status.isOneOf(invoice.INVOICE_PENDING, invoice.INVOICE_POSTED) ;
			
			if self.canPreInvoice and self.canTaxInvoice then
				break;
			endif;
			
		endforeach;	
		
		if not voyageProcess.allAdditionalReports.isEmpty then
			foreach invoice in _object.allInvoices where invoice.status.isOneOf( invoice.INVOICE_PENDING, invoice.INVOICE_POSTED ) do
				//jlier1 TFS 51963 8/10/21
				self.canRunAdditionalReports := true;
				break;
			endforeach;
		endif;
	endif;
		
epilog
	delete nextStatuses;
end;</source>
        <Parameter name="_object" type="CM_Voyage"/>
    </JadeMethod>
</Class>
