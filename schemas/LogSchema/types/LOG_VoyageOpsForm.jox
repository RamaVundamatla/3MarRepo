    <JadeMethod name="listsUpdateItem" id="5465e65f-e027-440b-8a24-81f5fea55aae">
        <updating/>
        <source>listsUpdateItem(_obj : Object)updating;
//--------------------------------------------------------------
//Created: 07 November 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	expand		: Boolean;
	str			: String;
	idx, level	: Integer;
	voyGlobal	: CM_VoyageGlobal;
	voy			: CM_Voyage;
	terminal	: CM_Terminal;
begin

	if _obj = null then
		return;
	endif;

	if _obj.isKindOf(CM_VoyageGlobal) then
		voyGlobal := _obj.CM_VoyageGlobal;
		if (not self.includeGlobalVoyage(voyGlobal, app.myPassport)) then
			self.removeDeletedObject(_obj);		
			return;
		else
			idx := lstPorts.findObject(_obj);
			if idx &lt; 1 then		
				self.listsAddItem(voyGlobal);
				return;
			endif;
		endif;
		str := voyGlobal.code &amp; '  ' &amp; voyGlobal.vesselName;

	elseif _obj.isKindOf(CM_VoyageOperator) then
		str := _obj.CM_VoyageOperator.operatorCode;

//	elseif _obj.isKindOf(CM_LogVoyage) then
	elseif _obj.isKindOf(CM_Voyage) and  
		_obj.CM_Voyage.myLogVoyageStructure &lt;&gt; null  then
		
		if (not self.includeVoyage(_obj.CM_Voyage, app.getMyUser())) then
			self.removeDeletedObject(_obj);
		endif;
		if self.mySSSLogVoyage = _obj then
			self.sssShowDocketsToBeLoaded();
			self.sssShowEDIData();
		endif;
		return;
	else

		return;
	endif;

	idx := lstPorts.findObject(_obj);
	if idx &gt; 1 then 
		level := lstPorts.itemLevel[idx];
		expand := lstPorts.itemExpanded[idx];
		lstPorts.removeItem(idx);
		lstPorts.addItemAt(str, idx);	
		lstPorts.itemObject[idx] := _obj;
		lstPorts.itemLevel[idx] := level;
		lstPorts.itemPicture[idx] := app.myRoot.getConfig(PicVesselLogs).Binary;
		if _obj.isKindOf(CM_VoyageGlobal) then
			lstPorts.clearBelowLevel(idx);						
			self.listPortsSetBelowVoyGlobal(_obj.CM_VoyageGlobal, idx);
		endif;
		lstPorts.itemExpanded[idx] := expand;				
	endif;
	
	idx := null;
	
	idx := lstSuppliers.findObject(_obj); 
	if idx &gt; 1 then
		level := lstSuppliers.itemLevel[idx];
		expand := lstSuppliers.itemExpanded[idx];		
		lstSuppliers.removeItem(idx);	
		lstSuppliers.addItemAt(str, idx);
		lstSuppliers.itemObject[idx] := _obj;
		lstSuppliers.itemLevel[idx] := level;
		lstSuppliers.itemPicture[idx] := app.myRoot.getConfig(PicVesselLogs).Binary;
		if _obj.isKindOf(CM_VoyageGlobal) then
			lstSuppliers.clearBelowLevel(idx);					
			self.listSupplierSetBelowVoyGlobal(_obj.CM_VoyageGlobal, idx);
		endif;
		lstSuppliers.itemExpanded[idx] := expand;						
	endif;
	
	if _obj.isKindOf(CM_VoyageOperator) then
		self.listsSetBelowVoyOper(_obj.CM_VoyageOperator);			
	endif;
	
end;</source>
        <Parameter name="_obj" type="Object"/>
    </JadeMethod>
    <JadeMethod name="loadAllOrdersByVoyGlobOperator" id="b4dabbfd-725d-4c07-b9e9-1fed8679c218">
        <source>loadAllOrdersByVoyGlobOperator(_operator : CM_Operator; _voyGlobal : CM_VoyageGlobal) protected;
// ---------------------------------------------------------------------------
// Created:      15 May 2003 by cnwsgp1
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
11 Jan 2011	cnwkpd1	PAR #26678 - Tidy up transient leaks

*/

vars
	iter : Iterator;
	order : CM_StockOrderHeader;
	summary	: CM_StockOrderSummary;
	objectArray : CM_ObjectArray;
	voyage	: CM_Voyage;
	voyOperator : CM_VoyageOperator;
	iterGlobal : Iterator;
	
begin
	create objectArray transient;
	
	iterGlobal := _voyGlobal.allVoyOpsByOpTerm.createIterator;
	_voyGlobal.allVoyOpsByOpTerm.startKeyGeq(_operator.code, null, iterGlobal);
	
	while iterGlobal.next(voyOperator) do
		if voyOperator.myOperator &lt;&gt; _operator then
			break;
		endif;
		
		voyage := voyOperator.myVoyage;
				
		if optSummary.value then
			delete iter;		// PAR #26678
			iter := voyage.allStockOrderSummaries.createIterator;
			voyage.allStockOrderSummaries.startKeyGeq(_operator, null, iter);
			while iter.next(summary) do
				if summary.myOperator &lt;&gt; _operator then
					break;
				endif;
				objectArray.add(summary);
			endwhile;		

		elseif optDetails.value then
			delete iter;		// PAR #26678
			iter := voyage.allOrdersByOperatorOrderNo.createIterator;
			voyage.allOrdersByOperatorOrderNo.startKeyGeq(_operator, null, iter);
			while iter.next(order) do
				if order.myOperator &lt;&gt; _operator then
					break;
				endif;
				order.allStockOrderLines.copy(objectArray);
			endwhile;	

		elseif optBoth.value then
			delete iter;		// PAR #26678
			iter := voyage.allStockOrderSummaries.createIterator;
			voyage.allStockOrderSummaries.startKeyGeq(_operator, null, iter);
			while iter.next(summary) do
				if summary.myOperator &lt;&gt; _operator then
					break;
				endif;
				objectArray.add(summary);
				summary.allStockOrderLines.copy(objectArray);
			endwhile;	
		endif;
	endwhile;
	
	self.showStockOrderData(objectArray);
	
epilog
	delete objectArray;
	delete iter;
	delete iterGlobal;
end;</source>
        <access>protected</access>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_voyGlobal" type="CM_VoyageGlobal"/>
    </JadeMethod>
    <JadeMethod name="loadAllOrdersByVoyageGlobal" id="a2987bbd-b71e-4a2f-8b33-07330980999c">
        <source>loadAllOrdersByVoyageGlobal(_voyageGlobal : CM_VoyageGlobal);
//--------------------------------------------------------------
//Created: 09 July 2002 By: cnwgd1
//--------------------------------------------------------------

vars
	voy	: CM_Voyage;
	order : CM_StockOrderHeader;
	summary	: CM_StockOrderSummary;
	objectArray : CM_ObjectArray;
	voysExcluded	: Boolean;
	theUser	: CM_User;
begin

	create objectArray transient;
	theUser := app.getMyUser();
	if optBoth.value then
		foreach voy in _voyageGlobal.allVoyages do
			if (not self.includeVoyage(voy, theUser)) then
				voysExcluded := true;
				continue;
			endif;

			foreach summary in voy.allStockOrderSummaries do
				objectArray.add(summary);
				summary.allStockOrderLines.copy(objectArray);
			endforeach;
		endforeach;	

	elseif optDetails.value then
		foreach voy in _voyageGlobal.allVoyages do
	
			if (not self.includeVoyage(voy, theUser)) then
				voysExcluded := true;
				continue;
			endif;

			foreach order in voy.allOrdersByOperatorOrderNo do
				order.allStockOrderLines.copy(objectArray);
			endforeach;		
		endforeach;

	elseif optSummary.value then
		foreach voy in _voyageGlobal.allVoyages do
			if (not self.includeVoyage(voy, theUser)) then
				voysExcluded := true;
				continue;
			endif;
			voy.allStockOrderSummaries.copy(objectArray);
		endforeach;
	endif;
	self.showStockOrderData(objectArray);
	
epilog
	delete objectArray;
end;</source>
        <Parameter name="_voyageGlobal" type="CM_VoyageGlobal"/>
    </JadeMethod>
    <JadeMethod name="loadAllOrdersByVoyageOperator" id="d19e6cfc-ba39-4be6-a22b-c9be8dcac1df">
        <source>loadAllOrdersByVoyageOperator(_voyOperator : CM_VoyageOperator);
//--------------------------------------------------------------
//Created: 09 July 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	iter: Iterator;
	order : CM_StockOrderHeader;
	summary	: CM_StockOrderSummary;
	objectArray : CM_ObjectArray;
	voyage	: CM_Voyage;
	operator : CM_Operator;
	prod	: CM_Product;
begin

	create objectArray transient;
	voyage := _voyOperator.myVoyage;
	operator := _voyOperator.myOperator;
			
	if optSummary.value then
		iter := voyage.allStockOrderSummaries.createIterator;
		voyage.allStockOrderSummaries.startKeyGtr(operator, null, iter);
		while iter.next(summary) do
			if summary.myOperator &lt;&gt; operator then
				break;
			endif;
			objectArray.add(summary);
		endwhile;		
	elseif optDetails.value then
		iter := voyage.allOrdersByOperatorOrderNo.createIterator;
		voyage.allOrdersByOperatorOrderNo.startKeyGtr(operator, null, iter);
		while iter.next(order) do
			if order.myOperator &lt;&gt; operator then
				break;
			endif;
			order.allStockOrderLines.copy(objectArray);
		endwhile;	
	elseif optBoth.value then
		iter := voyage.allStockOrderSummaries.createIterator;
		voyage.allStockOrderSummaries.startKeyGeq(operator, null, iter);
		while iter.next(summary) do
			if summary.myOperator &lt;&gt; operator then
				break;
			endif;
			objectArray.add(summary);
			summary.allStockOrderLines.copy(objectArray);
		endwhile;	
	endif;
	self.showStockOrderData(objectArray);
epilog
	delete objectArray;
	delete iter;
end;</source>
        <Parameter name="_voyOperator" type="CM_VoyageOperator"/>
    </JadeMethod>
    <JadeMethod name="loadAllOrdersByVoyageTerminal" id="99a18c94-af66-4301-a707-ad5f6461caeb">
        <source>loadAllOrdersByVoyageTerminal(_voy : CM_Voyage; _operator : CM_Operator);
//--------------------------------------------------------------
//Created: 09 July 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	order 		: CM_StockOrderHeader;
	line		: CM_StockOrderLine;
	summary		: CM_StockOrderSummary;
	objectArray : CM_ObjectArray;
begin

	create objectArray transient;
	
	if optBoth.value or optSummary.value then
		foreach summary in _voy.allStockOrderSummaries do
			if _operator &lt;&gt; null and summary.myOperator &lt;&gt; _operator then
				continue;
			endif;
			objectArray.add(summary);
			if optBoth.value then
				summary.allStockOrderLines.copy(objectArray);
			endif;
		endforeach;	
	elseif optDetails.value then
		foreach order in _voy.allOrdersByOperatorOrderNo do
			if _operator &lt;&gt; null and order.myOperator &lt;&gt; _operator then
				continue;
			endif;
			order.allStockOrderLines.copy(objectArray);
		endforeach;
	endif;
	
	self.showStockOrderData(objectArray);

epilog
	delete objectArray;
	
end;</source>
        <Parameter name="_voy" type="CM_Voyage"/>
        <Parameter name="_operator" type="CM_Operator"/>
    </JadeMethod>
