    <JadeMethod name="cmbDebtorAddressProp_lostFocus" id="6854afba-5456-44e1-82ed-8ace4e2bd9de">
        <controlMethod name="CMUI_ComboBox::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbDebtorAddressProp_lostFocus(combobox: ComboBox input) updating;
/*

Purpose:			Sets the ent table to the value of the combo box

Parameters:			combobox	ComboBox	The combobox that lost focus

Return Value:		NONE

Date		Who		Reason
29 May 2023  navmv20 Bug 58090: FR | EUP 54086 - Invoicing - Maintenance Enhancements - 050.d
20/07/2023	navkc1	Bug 58995: EUP - Inv Maint Credit Notes
14/08/2023	navkc1	Bug 59803: FR | EUP 53978 - Invoicing - Configuration Enhancements - Invoice Update - missing items
*/

begin
	//20/07/2023	navkc1	Bug 58995
	if self.isCreditNote then
		//14/08/2023	navkc1	Bug 59803
		self.tblInvProperties.setValueByControlName(combobox.name,combobox.text);
	else
		//14/08/2023	navkc1	Bug 59803
		self.tblInvProperties.setValueByControlName(combobox.name,combobox.text);
		if combobox.listObject &lt;&gt; null and self.tblInvProperties.getValueByName(ETRow_DebtorAddress) = null then
			self.tblInvProperties.setValueByName(ETRow_DebtorAddress,combobox.listObject.CM_Address.description);
		endif;
	endif;
end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="cmbDebtorAltAddrProp_lostFocus" id="7ea7ff9a-61d8-4ab9-9323-71cff4dc8312">
        <controlMethod name="CMUI_ComboBox::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbDebtorAltAddrProp_lostFocus(combobox: ComboBox input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09-June-2023 navtnr20 Bug 58472: EUP | Invoicing - Configuration Enhancements - Debtor Address update on Invoice
14/08/2023	navkc1	Bug 59803: FR | EUP 53978 - Invoicing - Configuration Enhancements - Invoice Update - missing items
*/

vars

begin
	//14/08/2023	navkc1	Bug 59803
	self.tblInvProperties.setValueByControlName(combobox.name,combobox.text);
	if combobox.listObject &lt;&gt; null and self.tblInvProperties.getValueByName(ETRow_AlternativeAddress) = null then
		//14/08/2023	navkc1	Bug 59803
		self.tblInvProperties.setValueByName(ETRow_AlternativeAddress,combobox.listObject.CM_Address.description);
	endif;
epilog

end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
