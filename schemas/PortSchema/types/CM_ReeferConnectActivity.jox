    <JadeMethod name="validateForUpdate" id="55172e2a-ee48-4f7f-8979-ac4757dd7704">
        <source>validateForUpdate();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		 Reason
08 Nov 2023	navhn30	 ChangeRequest 59144: PEN - Reefer Jobs and connection status

*/

vars

begin
	inheritMethod();
	
	if self.myTrackedItem.isConnected then
		app.raiseCMWarning1(ERR_ALREADY_CONNECTED, self.myTrackedItem.id, null,null, null);
	endif;

epilog

end;</source>
