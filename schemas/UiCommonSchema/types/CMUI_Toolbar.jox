    <JadeMethod name="doMenuUserToolbarClick" id="50d31763-7170-4505-9427-bbc9bf0005b4">
        <source>doMenuUserToolbarClick(_isControlKeyDown : Boolean; _menuUserToolbar : CM_MenuUserToolbar);
