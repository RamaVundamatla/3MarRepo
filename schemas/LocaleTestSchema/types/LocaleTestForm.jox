    <JadeMethod name="btnCancel_click" id="0ac32b92-46b5-4cdd-9a36-19ba0e9ee4c1">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnCancel_click(btn: Button input) updating;
// --------------------------------------------------------------------------------
