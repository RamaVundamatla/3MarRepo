<Class name="CM_Product">
    <JadeMethod name="exportPDXMLMyReferences" id="adaae9f2-8f8c-4644-9b55-feb47dce1a11">
        <source>exportPDXMLMyReferences(_file: File; _objArray: ObjectArray io; _property: Property; _object: Object);

vars

begin
	if _property.getName() = CM_Product::myDensityDec.name then			// ### TFS 52193 22Nov2021 NAVPW1
		_file.writeLine("&lt;"&amp;_property.getName&amp;"&gt;");
		self.myDensityDec.exportPDXML(_file, _objArray, true, true);	// ### TFS 52193 22Nov2021 NAVPW1
		_file.writeLine("&lt;/"&amp;_property.getName&amp;"&gt;");

	elseif _property.getName() = CM_Product::myHeight.name then
		_file.writeLine("&lt;"&amp;_property.getName&amp;"&gt;");
		self.myHeight.exportPDXML(_file, _objArray, true, true);
		_file.writeLine("&lt;/"&amp;_property.getName&amp;"&gt;");

	elseif _property.getName() = CM_Product::myHeightString.name then
		_file.writeLine("&lt;"&amp;_property.getName&amp;"&gt;");
		self.myHeightString.exportPDXML(_file, _objArray, true, true);
		_file.writeLine("&lt;/"&amp;_property.getName&amp;"&gt;");

	elseif _property.getName() = CM_Product::myLength.name then
		_file.writeLine("&lt;"&amp;_property.getName&amp;"&gt;");
		self.myLength.exportPDXML(_file, _objArray, true, true);
		_file.writeLine("&lt;/"&amp;_property.getName&amp;"&gt;");

	elseif _property.getName() = CM_Product::myLengthString.name then
		_file.writeLine("&lt;"&amp;_property.getName&amp;"&gt;");
		self.myLengthString.exportPDXML(_file, _objArray, true, true);
		_file.writeLine("&lt;/"&amp;_property.getName&amp;"&gt;");

	elseif _property.getName() = CM_Product::myQuantity.name then
		_file.writeLine("&lt;"&amp;_property.getName&amp;"&gt;");
		self.myQuantity.exportPDXML(_file, _objArray, true, true);
		_file.writeLine("&lt;/"&amp;_property.getName&amp;"&gt;");

	elseif _property.getName() = CM_Product::myType.name then
		_file.writeLine("&lt;"&amp;_property.getName&amp;"&gt;");
		self.myType.exportPDXML(_file, _objArray, true, true);
		_file.writeLine("&lt;/"&amp;_property.getName&amp;"&gt;");

	elseif _property.getName() = CM_Product::myVolume.name then
		_file.writeLine("&lt;"&amp;_property.getName&amp;"&gt;");
		self.myVolume.exportPDXML(_file, _objArray, true, true);
		_file.writeLine("&lt;/"&amp;_property.getName&amp;"&gt;");

	elseif _property.getName() = CM_Product::myWeight.name then
		_file.writeLine("&lt;"&amp;_property.getName&amp;"&gt;");
		self.myWeight.exportPDXML(_file, _objArray, true, true);
		_file.writeLine("&lt;/"&amp;_property.getName&amp;"&gt;");

	elseif _property.getName() = CM_Product::myWidth.name then
		_file.writeLine("&lt;"&amp;_property.getName&amp;"&gt;");
		self.myWidth.exportPDXML(_file, _objArray, true, true);
		_file.writeLine("&lt;/"&amp;_property.getName&amp;"&gt;");

	elseif _property.getName() = CM_Product::myWidthString.name then
		_file.writeLine("&lt;"&amp;_property.getName&amp;"&gt;");
		self.myWidthString.exportPDXML(_file, _objArray, true, true);
		_file.writeLine("&lt;/"&amp;_property.getName&amp;"&gt;");

	else
		inheritMethod(_file, _objArray, _property, _object);
	endif;
end;</source>
        <Parameter name="_file" type="File"/>
        <Parameter name="_objArray" type="ObjectArray" usage="io"/>
        <Parameter name="_property" type="Property"/>
        <Parameter name="_object" type="Object"/>
    </JadeMethod>
    <JadeMethod name="importPLXMLReference" id="e0304e8b-f49c-4e67-8db9-99fe8a842b46">
        <updating/>
        <source>importPLXMLReference(_name, _theCode, _referencesBlock: String): Object updating;

vars
	objectBlock: String;
	newObj: Object;
begin
	if _name = CM_Product::myCargoType.name then
		return app.myRoot.allCargoTypesById[_theCode.Integer];

	elseif _name = CM_Product::myOperator.name then
		return app.myRoot.allOperators[_theCode];

	elseif _name = CM_Product::myHandlingType.name then
		return app.myRoot.allHandlingTypes[_theCode.Integer];

	elseif _name = CM_Product::myDensityDec.name then									// ### TFS 52193 22Nov2021 NAVPW1
		objectBlock := _referencesBlock.cnEcGetTagValueOfName(_name);
		if objectBlock.cnEcGetTagValueOfName(CM_ProdAttrInteger.name) &lt;&gt; null then
			create newObj as CM_ProdAttrInteger transient;
			newObj.importPLXML(CM_ProdAttrInteger.name, objectBlock);
			self.setPropertyValue(CM_Product::myDensityDec.name, newObj); 				// ### TFS 52193 22Nov2021 NAVPW1
			return newObj;
		endif;

	elseif _name = CM_Product::myHeight.name then
		objectBlock := _referencesBlock.cnEcGetTagValueOfName(_name);
		if objectBlock.cnEcGetTagValueOfName(CM_ProdAttrInteger.name) &lt;&gt; null then
			create newObj as CM_ProdAttrInteger transient;
			newObj.importPLXML(CM_ProdAttrInteger.name, objectBlock);
			self.setPropertyValue(CM_Product::myHeight.name, newObj); 
			return newObj;
		endif;

	elseif _name = CM_Product::myHeightString.name then
		objectBlock := _referencesBlock.cnEcGetTagValueOfName(_name);
		if objectBlock.cnEcGetTagValueOfName(CM_ProdAttrString.name) &lt;&gt; null then
			create newObj as CM_ProdAttrString transient;
			newObj.importPLXML(CM_ProdAttrString.name, objectBlock);
			self.setPropertyValue(CM_Product::myHeightString.name, newObj); 
			return newObj;
		endif;

	elseif _name = CM_Product::myLength.name then
		objectBlock := _referencesBlock.cnEcGetTagValueOfName(_name);
		if objectBlock.cnEcGetTagValueOfName(CM_ProdAttrInteger.name) &lt;&gt; null then
			create newObj as CM_ProdAttrInteger transient;
			newObj.importPLXML(CM_ProdAttrInteger.name, objectBlock);
			self.setPropertyValue(CM_Product::myLength.name, newObj); 
			return newObj;
		endif;

	elseif _name = CM_Product::myLengthString.name then
		objectBlock := _referencesBlock.cnEcGetTagValueOfName(_name);
		if objectBlock.cnEcGetTagValueOfName(CM_ProdAttrString.name) &lt;&gt; null then
			create newObj as CM_ProdAttrString transient;
			newObj.importPLXML(CM_ProdAttrString.name, objectBlock);
			self.setPropertyValue(CM_Product::myLengthString.name, newObj); 
			return newObj;
		endif;

	elseif _name = CM_Product::myQuantity.name then
		objectBlock := _referencesBlock.cnEcGetTagValueOfName(_name);
		if objectBlock.cnEcGetTagValueOfName(CM_ProdAttrInteger.name) &lt;&gt; null then
			create newObj as CM_ProdAttrInteger transient;
			newObj.importPLXML(CM_ProdAttrInteger.name, objectBlock);
			self.setPropertyValue(CM_Product::myQuantity.name, newObj); 
			return newObj;
		endif;

	elseif _name = CM_Product::myType.name then
		objectBlock := _referencesBlock.cnEcGetTagValueOfName(_name);
		if objectBlock.cnEcGetTagValueOfName(CM_ProdAttrString.name) &lt;&gt; null then
			create newObj as CM_ProdAttrString transient;
			newObj.importPLXML(CM_ProdAttrString.name, objectBlock);
			self.setPropertyValue(CM_Product::myType.name, newObj); 
			return newObj;
		endif;

	elseif _name = CM_Product::myVolume.name then
		objectBlock := _referencesBlock.cnEcGetTagValueOfName(_name);
		if objectBlock.cnEcGetTagValueOfName(CM_ProdAttrInteger.name) &lt;&gt; null then
			create newObj as CM_ProdAttrInteger transient;
			newObj.importPLXML(CM_ProdAttrInteger.name, objectBlock);
			self.setPropertyValue(CM_Product::myVolume.name, newObj); 
			return newObj;
		endif;

	elseif _name = CM_Product::myWeight.name then
		objectBlock := _referencesBlock.cnEcGetTagValueOfName(_name);
		if objectBlock.cnEcGetTagValueOfName(CM_ProdAttrInteger.name) &lt;&gt; null then
			create newObj as CM_ProdAttrInteger transient;
			newObj.importPLXML(CM_ProdAttrInteger.name, objectBlock);
			self.setPropertyValue(CM_Product::myWeight.name, newObj); 
			return newObj;
		endif;

	elseif _name = CM_Product::myWidth.name then
		objectBlock := _referencesBlock.cnEcGetTagValueOfName(_name);
		if objectBlock.cnEcGetTagValueOfName(CM_ProdAttrInteger.name) &lt;&gt; null then
			create newObj as CM_ProdAttrInteger transient;
			newObj.importPLXML(CM_ProdAttrInteger.name, objectBlock);
			self.setPropertyValue(CM_Product::myWidth.name, newObj); 
			return newObj;
		endif;

	elseif _name = CM_Product::myWidthString.name then
		objectBlock := _referencesBlock.cnEcGetTagValueOfName(_name);
		if objectBlock.cnEcGetTagValueOfName(CM_ProdAttrString.name) &lt;&gt; null then
			create newObj as CM_ProdAttrString transient;
			newObj.importPLXML(CM_ProdAttrString.name, objectBlock);
			self.setPropertyValue(CM_Product::myWidthString.name, newObj); 
			return newObj;
		endif;

	else
		return null;
	endif;
end;</source>
        <Parameter name="_name" type="String"/>
        <Parameter name="_theCode" type="String"/>
        <Parameter name="_referencesBlock" type="String"/>
        <ReturnType type="Object"/>
    </JadeMethod>
</Class>
