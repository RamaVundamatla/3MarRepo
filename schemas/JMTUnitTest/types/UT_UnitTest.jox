    <JadeMethod name="updateTesterAttributes" id="24f1d095-17ac-4db7-bb58-58ed00322837">
        <updating/>
        <source>updateTesterAttributes(_checkLeaks, _logMessages, _logResult, _findBlame : Boolean; _methods : Boolean; _scheduleName : String; _byTeam : Boolean) updating;		//, _oNightClassName, _oNightMethodName : String) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
08 October 2012	cnwmc5	Initial creation
30 April 2025	navpw1	JIRA: MTN-34212 - Added byTeam attribute and paremeter so we can get the results by team or by user

*/

vars

begin
	self.checkForLeaks := _checkLeaks;
	self.logMessages := _logMessages;
	self.logResult := _logResult;
	self.findBlame := _findBlame;
	self.methods := _methods;
	self.scheduleName := _scheduleName;
	self.byTeam := _byTeam;
	//self.oNightClassName := _oNightClassName;
	//self.oNightMethodName := _oNightMethodName;
epilog

end;</source>
        <Parameter name="_checkLeaks" type="Boolean"/>
        <Parameter name="_logMessages" type="Boolean"/>
        <Parameter name="_logResult" type="Boolean"/>
        <Parameter name="_findBlame" type="Boolean"/>
        <Parameter name="_methods" type="Boolean"/>
        <Parameter name="_scheduleName" type="String"/>
        <Parameter name="_byTeam" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="userNotification" id="25fc1f7d-f98c-439f-943e-c9cb73c45167">
        <updating/>
        <source>userNotification(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;
//30 July 2008	cnwdw1	
//
vars

begin
	self.receivedNotes.add(self.UT_DSL.getTerminal.getEventFromTerminalEvent(eventType));
end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
    <JadeMethod name="writeTransientsNow" id="028d185b-fea9-4b10-957b-aabde15ae295">
        <source>writeTransientsNow( type : Class );

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
30 December 2010	cnwndl1	Initial creation

	Insert this sucker where you like, telling it what class of leak you are
	looking for, it will write out whether any of those transients have been created yet.
	
	Turn on transient checking in unit testing.
	
	When you look at the log of transients remaining, you will be able to identify (using the oid) and
	the output of this method where the transient was created.  Then all you have to do is work
	out where it should be deleted....

*/

vars

	leaks : String;

begin
	process.isNDLref;  
	if self.leakChecker &lt;&gt; null then
		if type = null then
			leaks := leakChecker.getLeaks(false);
		else
			leaks := leakChecker.getLeaksOf(type);
		endif;
		write method.qualifiedName &amp; "- Leaks text = '" &amp;  leaks &amp; "'";
	else
		write method.qualifiedName &amp; "- LeakChecker off";
	endif;

epilog

end;</source>
        <Parameter name="type" type="Class"/>
    </JadeMethod>
</Class>
