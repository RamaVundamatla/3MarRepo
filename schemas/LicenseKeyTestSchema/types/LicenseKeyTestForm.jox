// --------------------------------------------------------------------------------
vars
	theMaintForm	: LicenseListForm;
	
begin
	create theMaintForm;
	theMaintForm.showModal();
end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
