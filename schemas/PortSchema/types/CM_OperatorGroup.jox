    <JadeMethod name="addOperator" id="3550b94c-3e2c-4e93-8997-4d8682dea7d9">
        <updating/>
        <source>addOperator(_operator : CM_Operator) updating;
//--------------------------------------------------------------
//Created: 13 June 2003 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	if _operator = null then
		return;
	endif;
	
	if self.allOperators.includes(_operator) then
		return;
	endif;
	
	self.allOperators.add(_operator);
	
	self.updateObjectEdition(_operator); //cnwrd1 par 34536
end;</source>
        <Parameter name="_operator" type="CM_Operator"/>
    </JadeMethod>
    <JadeMethod name="canUserAccessSelf" id="77fdfe42-00b5-4221-a209-1ca84dbc1550">
        <source>canUserAccessSelf(_user : CM_User; _failedDAC  :CM_DataAccessController output; _passport: CM_Passport): Boolean;
//--------------------------------------------------
// Created:	26 January 2004 By: cnwgd1
//--------------------------------------------------
vars
	dac 	: CM_DataAccessController;
	oper	: CM_Operator;
begin
	if app.isSpecial() then
		return true;
	endif;

	dac := _passport.allDataAccessControllers[CM_Operator.name];

	if dac = null then
		// no Operator Data Access Group so view all
		return true;
	endif;
	
	if self.allOperators.isEmpty then
		return true;
	endif;
	
	// does user have access to any of the operators
	foreach oper in self.allOperators do
		if dac.canAccess(oper) then
			return true;
		endif;
	endforeach;
	
	_failedDAC := dac;
	return false;

end;</source>
        <Parameter name="_user" type="CM_User"/>
        <Parameter name="_failedDAC" type="CM_DataAccessController" usage="output"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="checkEntriesDict" id="6bd05de6-ee48-4f4f-aa00-33caf3ca8a92">
        <source>checkEntriesDict();

vars
	operator:CM_Operator;
	object:Object;
begin
	if entries.size &lt;&gt; allOperators.size then
		app.writeStatement( "Operator size mismatch by " &amp; (entries.size - allOperators.size).String);
	endif;
	foreach object in entries do
		operator := object.CM_Operator;
		if not allOperators.includes(operator) then
			app.writeStatement( "Operator " &amp;  operator.code &amp; " is not in old entries for " &amp; code &amp; ".");
		endif; 
	endforeach;
	foreach operator in allOperators do
		if not entries.includes(operator) then
			app.writeStatement( "Operator " &amp;  operator.code &amp; " is not in new entries for " &amp; code &amp; ".");
		endif; 
	endforeach;
end;</source>
    </JadeMethod>
    <JadeMethod name="cnEcGetDuplicate" id="864b4d33-ac6b-449a-8a85-49ab1cfde23a">
        <source>cnEcGetDuplicate(pFormat: CnEcXmlFormat; pInput: CnEcXmlStructureInstance): Object;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 September 2014	cnwndl1	Initial creation	Par 34893

*/

vars

	code : String;
	group : CM_OperatorGroup;

begin

	code := self.cnEcXMLGetTheAttributeValue( pFormat, pInput, self.class.name, "code" ).String; 
	
	if code &lt;&gt; null then
		group := app.myRoot.allOperatorGroups.getAtKey( code );
	endif;

epilog

	return group;

end;</source>
        <Parameter name="pFormat" type="CnEcXmlFormat"/>
        <Parameter name="pInput" type="CnEcXmlStructureInstance"/>
        <ReturnType type="Object"/>
    </JadeMethod>
    <JadeMethod name="getAllOperatorCodes" id="dcc0187a-6e1c-465c-a29f-d02971bd215c">
        <source>getAllOperatorCodes() : String;
//--------------------------------------------------------------
//Created: 12 June 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	oper : CM_Operator;
	operCodes : String;
begin

	foreach oper in self.allOperators do
		operCodes := oper.code &amp; ', ' &amp; operCodes;
	endforeach;
	return operCodes;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getAllOperatorsAsString" id="30ad5ce9-afc7-4a82-840f-a637fc0d8679">
        <source>getAllOperatorsAsString(): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21 July 2014	cnwrd1	Initial creation

*/

vars
	result,
 	separator 	: String;
	oper 		: CM_Operator;
begin

	separator := ' ';

	foreach oper in self.allOperators do
	
		result := result &amp; separator &amp; oper.code;
		separator := ', ';
	endforeach;
	
	return result;
	
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getAuditText" id="8dc28255-d2e3-40ec-8c8d-3b7ff547fd3d">
        <source>getAuditText(): String;
// ---------------------------------------------------------------------------
// Created:     15 March 2007 by cnwaer1
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	txt		: String;
	tmpStr	: String;
	opGroup  : CM_CodeGroup;
	ops : CM_Operator;
begin
	txt[10000] := '*';
	txt := null;
	txt := inheritMethod();
	
	foreach opGroup in self.allCodeGroups do
		if tmpStr = null then
			tmpStr := opGroup.name;
		else
			tmpStr := tmpStr &amp; ', ' &amp; opGroup.name;
		endif;
	endforeach;
	txt := txt &amp; 'Selected Code Groups' &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;
	
	tmpStr := null;
	foreach ops in self.allOperators do
		if tmpStr = null then
			tmpStr := ops.code;
		else
			tmpStr := tmpStr &amp; ', ' &amp; ops.code;
		endif;
	endforeach;
	txt := txt &amp; 'Selected Operators' &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;
	
	return txt;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="d4fe4a3b-2252-48d1-9555-88c01cd9a391">
        <source>pxyCreateUpdateProxy(): SelfType;
//--------------------------------------------------------------
//Created: 11 June 2003 By: cnwgd1
//--------------------------------------------------------------
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy
vars
	proxy : CM_OperatorGroup;
	completedOK		: Boolean;
begin
	proxy := inheritMethod();
	self.allOperators.copy(proxy.allOperators);
	proxy.myRoot := self.myRoot;
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return proxy;
	
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete proxy;
	endif;	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="a96d9a54-867c-4da0-84cc-0ac26f7056bd">
        <updating/>
        <source>setForCreate(pProxyOperatorGroup:CM_OperatorGroup) updating;
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	setForUpdate(pProxyOperatorGroup);
	self.myRoot := app.myRoot;

end;</source>
        <Parameter name="pProxyOperatorGroup" type="CM_OperatorGroup"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="246c6bbd-5bb7-417e-8aa2-41da42fd242b">
        <updating/>
        <source>setForUpdate(pProxyOperatorGroup : CM_OperatorGroup) updating;
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	oper 	: CM_Operator;
begin
	self.code := pProxyOperatorGroup.code.trimBlanks;
	self.description := pProxyOperatorGroup.description.trimBlanks;
	self.isAvailableForEntry := pProxyOperatorGroup.isAvailableForEntry;
	
	// cnwrd1 update for sql native par 34536
	foreach oper in self.allOperators do
		self.updateObjectEdition(oper);
	endforeach;
	
	self.allOperators.clear();
	self.allCodeGroups.clear();
	pProxyOperatorGroup.allCodeGroups.copy(self.allCodeGroups);
	pProxyOperatorGroup.allOperators.copy(self.allOperators);

	// cnwrd1 update for sql native par 34536
	foreach oper in self.allOperators do
		self.updateObjectEdition(oper);
	endforeach;
	
end;</source>
        <Parameter name="pProxyOperatorGroup" type="CM_OperatorGroup"/>
    </JadeMethod>
    <JadeMethod name="setMyRoot" id="2845c3be-367e-410a-bd88-52f7e064c61e">
        <updating/>
