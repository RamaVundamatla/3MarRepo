    <JadeMethod name="addUser" id="60d76d1f-034c-4025-8ba4-3dab57036629">
        <updating/>
        <source>addUser(userIndex : Integer; userName : String) : AAUser updating;

vars
	user	: AAUser;
begin
	create user transient;
	user.update(userIndex, userName);
	users.add(user);
	
	return user;
end;
</source>
        <Parameter name="userIndex" type="Integer"/>
        <Parameter name="userName" type="String"/>
        <ReturnType type="AAUser"/>
    </JadeMethod>
    <JadeMethod name="changeUser" id="ad6a38bc-2b0a-4056-9fba-190624819873">
        <updating/>
        <source>changeUser(userIndex : Integer; userName : String) updating;
vars
	user	: AAUser;
begin
	user := users[userIndex];
	if user = null then
		user := addUser(userIndex, userName);
	else
		user.update(userIndex, userName);
	endif;
end;
</source>
        <Parameter name="userIndex" type="Integer"/>
        <Parameter name="userName" type="String"/>
    </JadeMethod>
