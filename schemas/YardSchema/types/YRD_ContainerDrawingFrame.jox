        <executionLocation>client</executionLocation>
        <source>doDFDragDrop(frame: Frame input; win: Window input; x: Real; y: Real) updating, clientExecution;
// ---------------------------------------------------------------------------
// Created:		10 August 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
begin
	if self.myDockBar.isForRoRoLanes then																		// cnwjk3 ccms 1018 4/12/09
		self.myDockBar.myRoRoLaneDrawingController.doDFDragDrop(frame.YRD_ContainerDrawingFrame, win, x, y, null);	// cnwjk3 ccms 1018 4/12/09
	else
		self.myDockBar.myDrawingController.doDFDragDrop(frame.YRD_ContainerDrawingFrame,win, x,y);
	endif;

end;</source>
        <Parameter name="frame" type="Frame" usage="input"/>
        <Parameter name="win" type="Window" usage="input"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
