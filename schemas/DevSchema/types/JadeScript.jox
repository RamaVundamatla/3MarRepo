    <JadeMethod name="shScan" id="ef3d7844-97ec-4106-aa46-0ca3fcac3262">
        <source>shScan();
//----------------------------------------------------------------------
// Created by 	cnwsh3 - 08 January 2016
//
// Implemented version: JMT 8.2.1
// Date  		User  		Change
//----------------------------------------------------------------------
vars
 test : String;
 final : String;
 idx : Integer;
