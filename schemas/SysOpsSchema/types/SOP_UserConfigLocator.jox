    <JadeMethod name="delete" id="e5a7dff1-3f49-480b-af85-170350a181f6">
        <updating/>
        <executionLocation>client</executionLocation>
        <source>delete() updating, clientExecution;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 August 2014	cnwndl1	Initial creation

*/

vars

	obj : Object;
	objSet : ObjectSet;

begin

	if self.allColumnFilters &lt;&gt; null then
		delete self.allColumnFilters;
	endif;
	
	if self.myConfigDisplayAgent &lt;&gt; null then
		delete self.myConfigDisplayAgent;
	endif;
	
	foreach obj in self.selectedObjectSets do
		if not obj.isKindOf( ObjectSet ) then
			continue;
		endif;
		objSet := obj.ObjectSet;
		delete objSet;
	endforeach;

epilog

end;</source>
    </JadeMethod>
