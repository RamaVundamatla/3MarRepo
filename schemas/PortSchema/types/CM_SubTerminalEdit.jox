<Class name="CM_SubTerminalEdit" id="3891b8c3-8533-40e0-8d1f-0bc916a6f735">
    <superclass name="CM_TITransaction"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <access>protected</access>
    <DbClassMap file="transact"/>
    <ImplicitInverseRef name="mySubTerminalFrom" id="0da02f98-3a93-4392-a495-71c8dd2b519c">
        <embedded/>
        <type name="CM_SubTerminal"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="mySubTerminalTo" id="ed01343d-3e1c-4afc-9b15-c32971705300">
        <embedded/>
        <type name="CM_SubTerminal"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <JadeMethod name="getDisplayStringForAttribute" id="a30f4283-dac9-4e90-ac4e-9ed67c0c2d92">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 June 2010	cnwndl1	Initial creation	Par 23498

*/

vars
	lDetail : String;
begin

	if _attrName = ETRow_Details  then
		if self.deleted then
			return self.getDeletedDetails();		// 15/10/18 MAP TFS41191
			
		else
			if self.mySubTerminalFrom &lt;&gt; null and self.mySubTerminalTo &lt;&gt; null then 
				return app.getErrorString(TransType_119) &amp; " from " &amp; self.mySubTerminalFrom.code &amp; " to " &amp; self.mySubTerminalTo.code;	
			endif;
			
		endif;
							
	else
		return inheritMethod(_attrName, _short);
	
	endif;

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getEnquiryRow" id="8e91f3e5-2344-4d1a-9cc7-2dfdd44ebf88">
        <source>getEnquiryRow(): String;

/*

Purpose:			CCMS 1735

Parameters:			

Return Value:		


Date		Who		Reason
14 April 2009	#cnwdz2	 

*/

vars

begin
	if self.mySubTerminalFrom &lt;&gt; null and self.mySubTerminalTo &lt;&gt; null then 
		return inheritMethod() &amp; app.getErrorString(TransType_119) &amp; " from " &amp; self.mySubTerminalFrom.code &amp; " to " &amp; self.mySubTerminalTo.code;	
	endif;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setFromCMIF_TITransactionCntrl" id="8b13fb4c-24c5-4935-88f0-3435ec4b3d24">
        <updating/>
        <source>setFromCMIF_TITransactionCntrl(_tiTransCntrl: CMIF_TITransactionController; _passport: CM_Passport input) updating;
/* ---------------------------------------------------------------------------
Created:     27 April 2009 by cnwrs2

Purpose:     
        
Change Date	Who		Reason

------------------------------------------------------------------------------*/
vars

begin
	inheritMethod(_tiTransCntrl, _passport);
	self.mySubTerminalFrom := _tiTransCntrl.mySubTerminalFrom;
	self.mySubTerminalTo := _tiTransCntrl.mySubTerminalTo;
epilog

end;</source>
        <Parameter name="_tiTransCntrl" type="CMIF_TITransactionController"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setFromCMIF_TIUpdateController" id="187b36b0-9863-4b3c-9c3b-bb352bc51d06">
        <updating/>
        <source>setFromCMIF_TIUpdateController(_tiUpdateCntrlr: CMIF_TIUpdateController; _passport: CM_Passport) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
15 April 2009	#cnwdz2	 

*/

vars

begin
	inheritMethod(_tiUpdateCntrlr, _passport);
	self.mySubTerminalFrom := _tiUpdateCntrlr.mySubTerminalFrom;
	self.mySubTerminalTo := _tiUpdateCntrlr.mySubTerminalTo;
epilog

end;</source>
        <Parameter name="_tiUpdateCntrlr" type="CMIF_TIUpdateController"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
</Class>
