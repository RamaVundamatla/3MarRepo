	lbl_CargoType.translateCaption(Xlat_0013206, locale);
	lbl_Location.translateCaption(Xlat_0013207, locale);
	lbl_RequestNo.translateCaption(Xlat_0013208, locale);
	lbl_TareWeight.translateCaption(Xlat_0013209, locale);
	lbl_Title.translateCaption(Xlat_0013210, locale);
end;</source>
