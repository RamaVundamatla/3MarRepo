    <JadeMethod name="getDisplayStringForAttribute" id="d7b42320-50d7-4d80-83c4-796e2a4b9cfd">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
//--------------------------------------------------------------
