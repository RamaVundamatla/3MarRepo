    <JadeMethod name="getAllProductsForProductGroup" id="1eb4159c-c52b-4c31-b53b-15671a6f0559">
        <source>getAllProductsForProductGroup( _cargoType : CM_CargoType; _prodGroup : CM_ProductGroup; _prodSet : CM_ProductSet input);
/* ---------------------------------------------------------------------------
Created:	06 April 2009	by cnwvu1

Purpose:	To build all products that belong to _prodGroup and all other products
			that are available still
   
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars
	theProduct	: CM_Product;
	
begin
	
	_prodSet.clear;
	
	if _cargoType = null then
		return;
	endif;
	
	foreach theProduct in _cargoType.allProducts do
		if theProduct.myProductGroup = null		// available products
		or theProduct.myProductGroup = _prodGroup	// for the current cargo type
		then
			_prodSet.add(theProduct);
		endif;
	endforeach;
	
end;</source>
        <Parameter name="_cargoType" type="CM_CargoType"/>
        <Parameter name="_prodGroup" type="CM_ProductGroup"/>
        <Parameter name="_prodSet" type="CM_ProductSet" usage="input"/>
    </JadeMethod>
