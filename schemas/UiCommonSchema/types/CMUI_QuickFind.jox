    <JadeMethod name="doFind" id="94707a83-1844-4bca-a78b-d1e6cc5e7d1f">
        <source>doFind();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 January 2014	cnwndl1	Initial creation	Par 33350

*/

vars

	text : String;
	pos : Integer;
	restrictSearchTo : String;
	helpRequested : Boolean;
	helpStr : String;

begin

	if self.myTerminal = null then
		app.msgBox("Must select a terminal", "Error", MsgBox_OK_Only );
		return;
	endif;
	
	text := self.txtFind.text.trimBlanks;
	if text = null then
		app.msgBox("No 'Find' text entered", "Error", MsgBox_OK_Only );
		return;
	endif;
	
	helpRequested := text.trimBlanks.pos("?",1) &gt;= 1;
	if not helpRequested then
		pos := text.pos(" ",1);
		if pos &gt; 1 and pos &lt; text.length then
			restrictSearchTo := text[1:pos-1].toUpper.trimBlanks;
			text := text[pos+1:end].trimBlanks;
			if text = null then
				app.msgBox("No 'Find' text entered", "Error", MsgBox_OK_Only );
				return;
			endif;
		endif;
		
	elseif helpRequested then
		if text.trimBlanks.toUpper.pos("F",1) &gt; 0 then
			restrictSearchTo := "F";
			text := "?";
		endif;
	endif;
	
	//Simple Form open feature
	if restrictSearchTo = "F" or  restrictSearchTo = "X" then
		if self.openForm( restrictSearchTo, text.toUpper ) then
			return;
		endif;

	endif;
	
	//Simple Print feature
	if restrictSearchTo = "P" then
		if self.openPrintForm( text.toUpper ) then
			return;
		endif;
	endif;
	
	// Is the text entered meaningful
	if helpRequested or
	( restrictSearchTo &lt;&gt; null
	and restrictSearchTo &lt;&gt; "T"
	and restrictSearchTo &lt;&gt; "L"
	and restrictSearchTo &lt;&gt; "A"
	and restrictSearchTo &lt;&gt; "B"
	and restrictSearchTo &lt;&gt; "R"
	and restrictSearchTo &lt;&gt; "G"
	and restrictSearchTo &lt;&gt; "C"
	and restrictSearchTo &lt;&gt; "N"
	and restrictSearchTo &lt;&gt; "I"
	)
	then
		helpStr := helpStr &amp; "? 			This help" &amp; CrLf;
		helpStr := helpStr &amp; CrLf;
		helpStr := helpStr &amp; "FORM quick open" &amp; CrLf;
		helpStr := helpStr &amp; " F &lt;short form name&gt;	open a new copy of a form by its short name" &amp; CrLf;
		helpStr := helpStr &amp; " F ? 			full list of short form names" &amp; CrLf;
		helpStr := helpStr &amp; CrLf;
		helpStr := helpStr &amp; "PRINT report" &amp; CrLf;
		helpStr := helpStr &amp; " P &lt;report name&gt;		open a new copy of the Report Runner form" &amp; CrLf;
		helpStr := helpStr &amp; " 			and search for a report" &amp; CrLf;
		helpStr := helpStr &amp; CrLf;
		helpStr := helpStr &amp; "General OBJECT quick find" &amp; CrLf;
		helpStr := helpStr &amp; " &lt;text&gt;			first match of any of the specific finds listed" &amp; CrLf;
		helpStr := helpStr &amp; " 			below" &amp; CrLf;
		helpStr := helpStr &amp; CrLf;
		helpStr := helpStr &amp; "Specific OBJECT quick find" &amp; CrLf;
		helpStr := helpStr &amp; " T &lt;truck registration&gt;	first exact matching truck (latest visit of)" &amp; CrLf;
		helpStr := helpStr &amp; " L &lt;full yard location id&gt;	first exact matching yard location" &amp; CrLf;
		helpStr := helpStr &amp; " A &lt;terminal area code&gt;	first exact matching terminal area" &amp; CrLf;
		helpStr := helpStr &amp; " B &lt;booking number&gt;	first exact matching active booking" &amp; CrLf;
		helpStr := helpStr &amp; " R &lt;release id&gt;		first exact matching active release" &amp; CrLf;
		if app.isCargoGroupEnabled then
			helpStr := helpStr &amp; " G &lt;cargo group id&gt;		all partial matching cargo group items" &amp; CrLf;
		endif;
		helpStr := helpStr &amp; " C &lt;cargo id&gt;		all partial matching on-site cargo" &amp; CrLf;
		helpStr := helpStr &amp; " N &lt;pre-note id&gt;		all partial matching pre-notified cargo" &amp; CrLf;
		helpStr := helpStr &amp; " I &lt;invoice seq. number&gt;	exact invoice in current business unit" &amp; CrLf;
		
		// 10 Sept 2024	navab1	CR 66065 : MTN - Generate quick list of selected column data
		helpStr := helpStr &amp; CrLf;
		helpStr := helpStr &amp; "__________________________________________________________" &amp; CrLf &amp; CrLf;
		helpStr := helpStr &amp; "Table Short Cuts:" &amp; CrLf &amp; CrLf;
		helpStr := helpStr &amp; "Ctrl+C - Copy selected cell's text to clipboard" &amp; CrLf;
		helpStr := helpStr &amp; "Ctrl+G - Copy selected rows Ids to dialog" &amp; CrLf;
		helpStr := helpStr &amp; "Ctrl+Shft+G - Click column then" &amp; CrLf &amp; Tab &amp; "Ctrl+Shft+G to copy selected column text to dialog (also copied to clipboard)" &amp; CrLf;
		helpStr := helpStr &amp; "Ctrl+Shft+G - Alt+Click columns then" &amp; CrLf &amp; Tab &amp; "Ctrl+Shft+G to copy selected columns text, Tab delimited, to dialog (also copied to clipboard)" &amp; CrLf;
		
		if not helpRequested then
			self.setStatusCaption( restrictSearchTo &amp; ": Not known...", 0 );
		endif;
		app.msgBox(helpStr, "Valid quick action formats:", MsgBox_OK_Only );
		return;
	endif;
	
	// do the finds in the least likely order that we might find things (in case they are trying all options)
	if self.findTruck( restrictSearchTo, text.toUpper ) then
		return;
	endif;
	
	if self.findYardLocation( restrictSearchTo, text.toUpper ) then
		return;
	endif;
	
	if self.findBooking( restrictSearchTo, text.toUpper ) then
		return;
	endif;
	
	if self.findReleaseRequest( restrictSearchTo, text.toUpper ) then
		return;
	endif;
	
	if self.findCargo( restrictSearchTo, text.toUpper ) then
		return;
	endif;
	
	if self.findInvoice( restrictSearchTo, text.toUpper ) then
		return;
	endif;
	
	
	self.setStatusCaption( "Nothing found...", 0 );

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="findBooking" id="34b1d25b-1bd5-44c0-80a9-965b9e4824ac">
        <source>findBooking( _restrictSearchTo, _text : String ) : Boolean protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 January 2014	cnwndl1	Initial creation	Par 33350

*/

vars

	firstBooking : CM_BookingRef;
	iter : Iterator;
	booking : CM_BookingRef;
	bookings : CM_BookingRefsByStatusRefDups;

begin

	if _restrictSearchTo = null or _restrictSearchTo = "B" then
		self.setStatusCaption( "Checking for booking...", 0 );
		firstBooking := self.myTerminal.allBookingRefsByStatusRef.getAtKeyGeq( BOOKING_REF_ACTIVE, _text );
		if firstBooking &lt;&gt; null then
			create bookings transient;
			iter := self.myTerminal.allBookingRefsByStatusRef.createIterator;
			iter.startAtObject( firstBooking );
			while iter.next( booking ) do
				if booking.bookingReference[1:_text.length] &lt;&gt; _text then
					break;
				endif;
				bookings.addNoDuplicates( booking, false );
			endwhile;
			if not bookings.isEmpty then
				self.setStatusCaption( "Found a booking...", 0 );
				self.myAssistant.showBookingForm( bookings.first, null, self.myTerminal );
				return true;
			endif;
		endif;
	endif;
	
	return false;

epilog

	delete bookings;
	delete iter;

end;</source>
        <access>protected</access>
        <Parameter name="_restrictSearchTo" type="String"/>
        <Parameter name="_text" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="findCargo" id="2acd20a6-7f72-4fad-927e-443ef9ec746b">
        <source>findCargo( _restrictSearchTo, _text : String ) : Boolean protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 January 2014	cnwndl1	Initial creation	Par 33350
// 06 Sep 2016	cnwrs1	TFS 2586 dont always include archived voyages and lookup reveresed even if we found data in non reverese lookup
*/

vars

	objArray : ObjectArray;
	tiSet : CM_TISet;
	iter : Iterator;
	ti : CM_TrackedItem;
	checkIdValue : String;
	reversedId : String;
	reversedCheckIdvalue : String;
	reversedText : String;
	length : Integer;
	startCargoGroup : CM_TrackedItem;
	cargoGroup : CM_TrackedItem;

begin

	create tiSet transient;
	create objArray transient;
	
	if app.isCargoGroupEnabled then
		if _restrictSearchTo = null or _restrictSearchTo = "G" then
			self.setStatusCaption( "Checking for cargo group...", 0 );
			length := _text.length;
			iter := self.myTerminal.allCargoGroupsByIdCargoType.createIterator;
			startCargoGroup := self.myTerminal.allCargoGroupsByIdCargoType.getAtKeyGeq( _text, null );
			if startCargoGroup &lt;&gt; null then
				iter.startAtObject(startCargoGroup);
				while iter.next( cargoGroup ) do
					checkIdValue := cargoGroup.id[1:length].toUpper;
					if checkIdValue = _text then
						tiSet.addNoDuplicates(cargoGroup,false);
						continue;
					endif;
					break;
				endwhile;
			endif;
			delete iter;
			
			if not tiSet.isEmpty then
				if tiSet.size = 1 then
					self.setStatusCaption( "Found a cargo group...", 0 );
					self.myAssistant.showCargoEnquiry( tiSet.first );
					return true;
				else
					self.setStatusCaption( "Found " &amp; tiSet.size.String &amp; " cargo group items...", 0 );
					
					tiSet.copy( objArray );
					self.myAssistant.showCargoEnquiryForTIs( tiSet.first, objArray, null, false);
					return true;
				endif;
				
			endif;
		endif;
	endif;

	if _restrictSearchTo = null or _restrictSearchTo = "C" then
		self.setStatusCaption( "Checking for cargo...", 0 );
		self.myTerminal.lookupAllOnsiteTrackedItems( null, _text, tiSet, false, null );
		
		if not tiSet.isEmpty then
			if tiSet.size = 1 then
				self.setStatusCaption( "Found a cargo item...", 0 );
				self.myAssistant.showCargoEnquiry( tiSet.first );
				return true;
			else
				self.setStatusCaption( "Found " &amp; tiSet.size.String &amp; " cargo items...", 0 );
				
				tiSet.copy( objArray );
				self.myAssistant.showCargoEnquiryForTIs( tiSet.first, objArray, null, false);
				return true;
			endif;
			
		endif;
	endif;
	
	tiSet.clear();
	objArray.clear();
	
	if _restrictSearchTo = null or _restrictSearchTo = "N" then
		self.setStatusCaption( "Checking for pre-notes...", 0 );
	
		iter := self.myTerminal.allNotifiedTIsByCargoTypeId.createIterator;
		length := _text.length;
		reversedText := _text.reverse;
		while iter.next( ti ) do
			checkIdValue := ti.id[1:length].toUpper;
			if checkIdValue = _text then
				tiSet.addNoDuplicates(ti,false);
				continue;
			endif;
			reversedId := ti.id.reverse();
			reversedCheckIdvalue := reversedId[1:length];
			if reversedCheckIdvalue = reversedText then
				tiSet.addNoDuplicates(ti,false);
			endif;
		endwhile;
		
		if not tiSet.isEmpty then
			if tiSet.size = 1 then
				self.setStatusCaption( "Found a pre-noted cargo item...", 0 );
				self.myAssistant.showCargoEnquiry( tiSet.first );
				return true;
			else
				self.setStatusCaption( "Found " &amp; tiSet.size.String &amp; " pre-noted cargo items...", 0 );
				tiSet.copy( objArray );
				self.myAssistant.showCargoEnquiryForTIs( tiSet.first, objArray, null, false);
				return true;
			endif;
			
		endif;
	endif;
	
	return false;

epilog

	delete objArray;
	delete tiSet;
	delete iter;

end;</source>
        <access>protected</access>
        <Parameter name="_restrictSearchTo" type="String"/>
        <Parameter name="_text" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="findInvoice" id="e7d6dc5e-d294-43a9-acb1-fc4fa1f9a1f5">
        <source>findInvoice( _restrictSearchTo, _text : String ) : Boolean protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 April 2014	cnwndl1	Initial creation

*/

vars

	bank : CM_Bank;
	invoice : CM_Invoice;
	invoiceLine : CM_InvoiceLine;
	
begin

	if _restrictSearchTo = null or _restrictSearchTo = "I" then
	
		if not _text.isInteger then
			return false;
		endif;
		
		self.setStatusCaption( "Checking for invoices...", 0 );
		
		bank := self.myTerminal.getDefaultCompanyBank();
		if bank = null then
			return false;
		endif;
		invoice := bank.allInvoices.getAtKey( self.myTerminal, bank, _text.Integer );
		
		if invoice &lt;&gt; null then
			self.myAssistant.showInvoiceForm( invoice, null);
			self.setStatusCaption( "Found an invoice...", 0 );
			return true;
		endif;
		
		self.setStatusCaption( "Checking for invoice lines...", 0 );
		
		invoiceLine := bank.invoiceLines.getAtKey( self.myTerminal, bank, _text.Integer );
		
		if invoiceLine &lt;&gt; null then
			self.myAssistant.showInvoiceLineForm( invoiceLine, null);
			self.setStatusCaption( "Found an invoice line...", 0 );
			return true;
		endif;
		
	endif;
	
	return false;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_restrictSearchTo" type="String"/>
        <Parameter name="_text" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="findReleaseRequest" id="7bf85f06-57f4-4178-b868-601bfdb6409d">
        <source>findReleaseRequest( _restrictSearchTo, _text : String ) : Boolean protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 January 2014	cnwndl1	Initial creation	Par 33350
14 June 2023 	navhl20 Bug 58634: MTN - Release by Type option should be disabled if there is no VAS subscription 
*/

vars

	firstBR : CM_BulkRelease;
	iter : Iterator;
	br : CM_BulkRelease;
	releases : CM_BulkReleaseByCodeDict;

begin

	if _restrictSearchTo = null or _restrictSearchTo = "R" then
		self.setStatusCaption( "Checking for release request...", 0 );
		firstBR := self.myTerminal.allBulkReleasesByCodeDate.getAtKeyLeq( _text, null );
		if firstBR &lt;&gt; null then
			create releases transient;
			iter := self.myTerminal.allBulkReleasesByCodeDate.createIterator;
			iter.startAtObject( firstBR );
			while iter.next( br ) do
				if br.status &lt;&gt; BR_ACTIVE then
					continue;
				endif;
				if br.code[1:_text.length] &lt;&gt; _text then
					break;
				endif;
				releases.addNoDuplicates( br, false );
				break;
			endwhile;
			if not releases.isEmpty then
				br := releases.first;
				self.setStatusCaption( "Found a release request...", 0 );
				myAssistant.releaseRequestUpdate(br, null,null);					//14.6.2023 navhl20 #58634
				return true;
			endif;
		endif;
	endif;
	
	return false;

epilog

	delete releases;
	delete iter;

end;</source>
        <access>protected</access>
        <Parameter name="_restrictSearchTo" type="String"/>
        <Parameter name="_text" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="findTruck" id="59a41663-9fd2-46c0-9dc6-7722d60afa4c">
        <source>findTruck( _restrictSearchTo, _text : String ) : Boolean protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 January 2014	cnwndl1	Initial creation	Par 33350

*/

vars

	vehicle : CM_Vehicle;
	vehicleVisit : CM_VehicleVisitRecord;
	ta : CM_TerminalArea;
	schema : Schema;
	class : Class;
	yrdAssist : CMUI_Assistant;
	menuAction : CMUI_MenuAction;
	tableViewForm : CM_TableViewForm;
	baseForm : CM_BaseForm;
	
begin

	if _restrictSearchTo = null or _restrictSearchTo = "T" then
		self.setStatusCaption( "Checking for truck...", 0);
		vehicle := self.myTerminal.vehicles.getAtKeyGeq(_text,null);
		if vehicle &lt;&gt; null and vehicle.regNumber = _text and not vehicle.visitRecords.isEmpty then
			vehicleVisit := vehicle.visitRecords.last;
			if vehicle.isOnsite then
				if vehicle.myPrimaryActualLocation &lt;&gt; null then
					ta :=  vehicle.myPrimaryActualLocation.myTerminalArea;
				endif;
			endif;
			if ta &lt;&gt; null then
				
				if vehicle.myPrimaryActualLocation.isKindOf(CM_GateAreaLaneController)
				and vehicle.myPrimaryActualLocation.CM_GateAreaLaneController.isAGateLane
				and vehicleVisit &lt;&gt; null
				then
					//the truck has arrived at the admin gate
					menuAction := app.myController.createMenuAction(PmGteInOutFastView, null, null, self.myTerminal);
					if menuAction &lt;&gt; null then
						self.setStatusCaption( "Found a truck at the gate...", 0 );
						baseForm := menuAction.goToObject(null, null, false, null).CM_BaseForm;
						if baseForm &lt;&gt; null then
							baseForm.show();
							baseForm.setFromQuickFind(vehicleVisit,null);
							return true;
						endif;
					endif;
				else
					// the truck is on site in the yard show road operations form
					self.setStatusCaption( "Found a truck onsite...", 0 );
					schema := rootSchema.getSchema("YardSchema");
					class := schema.getClass("YRD_Assistant");
					create yrdAssist as class;
					yrdAssist.setMyTerminal(self.myTerminal);
					yrdAssist.sendMsgWithParams("showRoadOperations",ta,null);
					return true;
				endif;
			elseif vehicleVisit &lt;&gt; null then
				//the truck is no longer on-site but has been here, show teh last vehicle visit record
				menuAction := app.myController.createMenuAction(PmGteVisitRecordView, null, null, self.myTerminal);
				if menuAction &lt;&gt; null then
					self.setStatusCaption( "Found a truck that has visited...", 0 );
					tableViewForm := menuAction.goToObject(null, null, false, null).CM_TableViewForm;
					if tableViewForm &lt;&gt; null then
						tableViewForm.show();
						tableViewForm.setFromQuickFind(vehicleVisit,null);
						return true;
					endif;
				endif;
			endif;
		endif;
	endif;

	return false;
		
epilog

	delete yrdAssist;
	
end;</source>
        <access>protected</access>
        <Parameter name="_restrictSearchTo" type="String"/>
        <Parameter name="_text" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="findYardLocation" id="7a1358fa-ad49-4566-981f-5c336af15282">
        <source>findYardLocation( _restrictSearchTo, _text : String ) : Boolean protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 January 2014	cnwndl1	Initial creation	Par 33350

*/

vars

	lc : CM_LocationsController;
	height	: Integer;
	
	strs : StringArray;
	allTAs  : CM_TerminalAreaSet;
	remainingStrs : StringArray;
	ta : CM_TerminalArea;

begin

	if _restrictSearchTo = null or _restrictSearchTo = "L" then
		self.setStatusCaption( "Checking for yard location...", 0 );
		self.myTerminal.findLocationFromString( _text, true, lc, height );
		if lc &lt;&gt; null and lc.isKindOf(CM_YardController) then
			self.setStatusCaption( "Found a yard location...", 0 );
			self.myAssistant.showLocationEnquiryForm(lc, null, false, false);
			return true;
		endif;
	endif;
	
	if _restrictSearchTo = null or _restrictSearchTo = "A" then
		self.setStatusCaption( "Checking for terminal area...", 0 );
		create strs transient;
		strs.add( _text );
		create remainingStrs transient;
		create allTAs transient;
		self.myTerminal.findTAFromString(strs,remainingStrs,true,allTAs);
		if not allTAs.isEmpty then
			self.setStatusCaption( "Found a terminal area...", 0 );
			if allTAs.first.isKindOf( CM_IrregularBlockArea ) then
				self.myAssistant.showLocationEnquiryForm(allTAs.first, null, false, false);
				return true;
			else
				self.myAssistant.showTerminalAreaForm( allTAs.first, null );
			endif;
			return true;
		endif;
	endif;

	return false;
		
epilog

	delete strs;
	delete allTAs;
	delete remainingStrs;
	
end;</source>
        <access>protected</access>
        <Parameter name="_restrictSearchTo" type="String"/>
        <Parameter name="_text" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getQuickAccess" id="c5a7f744-ca10-431e-bb79-ae5c633dc29e">
        <source>getQuickAccess( _byKeyText : String; _byPermission : Integer ) : CM_QuickAccess protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 July 2014	cnwndl1	Initial creation

*/

vars

	user : CM_User;
	quickAccess : CM_QuickAccess;

begin

	user := app.getMyUser;
	
	if user &lt;&gt; null and not user.allUserQuickAccess.isEmpty then
		//if the user has their own Quick Accesses, try these first
		if _byKeyText &lt;&gt; null then
			quickAccess := user.allUserQuickAccess.getAtKey( _byKeyText );
		elseif _byPermission &gt; 0 then
			quickAccess := user.getQuickAccessByPermission( _byPermission );
		endif;
	endif;
	
	if quickAccess = null then
		// No quick access found yet, try the default ones
		if _byKeyText &lt;&gt; null then
			quickAccess := app.myRoot.allSystemQuickAccess.getAtKey( _byKeyText );
		elseif _byPermission &gt; 0 then
			quickAccess := app.myRoot.getQuickAccessByPermission(_byPermission);
		endif;
	endif;
	
	return quickAccess;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_byKeyText" type="String"/>
        <Parameter name="_byPermission" type="Integer"/>
        <ReturnType type="CM_QuickAccess"/>
    </JadeMethod>
    <JadeMethod name="keyDown" id="e62707c5-d59e-40ca-86db-20bd2a09cd6d">
        <controlMethod name="Form::keyDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>keyDown(keyCode: Integer io; shift: Integer) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 January 2014	cnwndl1	Initial creation

*/

vars

begin

	if keyCode = CMUI_Key_F12 then
		if (app.isSpecial() or app.isDevelopmentSystem()) and shift.cnEcIsCtrlKey() then
			if shift.cnEcIsShiftKey() then
				self.cnEcShowContents();
			else
				self.cnEcShowGuiInfo();
			endif;
		elseif (app.isSpecial() or app.isDevelopmentSystem()) and shift.cnEcIsAltKey() then
			self.cnEcListInUseBy();
		endif;
	endif;

epilog

end;</source>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
