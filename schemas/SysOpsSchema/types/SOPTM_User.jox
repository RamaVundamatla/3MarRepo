	sht.caption := 'Terminal Access';
	sht.visible := true;
	
	tbl.rows := 1;
	tbl.columns := 6;
	tbl.accessColumn(1).inputType := Table.InputType_CheckBox;
	
	tbl.accessCell(1,1).text := 'Allow' &amp; Tab &amp; 
								'Terminal' &amp; Tab &amp; 
								'Security Role' &amp; Tab &amp; 
								'Default Cargo Type' &amp; Tab &amp; 
								'Default BOL Type' &amp; Tab &amp;
								'Default Cargo/BOL Type';
	tbl.sortColumn[1] := 2; // NAVAB1 19DEC2021 sort by terminal name
	
	self.myForm.cmbSecurityRole.automaticCellControl := true;
	self.myForm.cmbSystemRole.automaticCellControl := true;
	self.myForm.cmbSystemRole.sorted := true;
	self.myForm.cmbCargoBOLType.automaticCellControl := true;
	
end;</source>
    </JadeMethod>
