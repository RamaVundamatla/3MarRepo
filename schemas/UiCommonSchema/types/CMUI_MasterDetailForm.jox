    <JadeMethod name="zHandleNotifyCreate" id="939a8423-f471-4feb-a3a3-1daefa2c2759">
        <updating/>
        <source>zHandleNotifyCreate(eventType: Integer; theObject: Object; eventTag: Integer) updating, protected;
// ---------------------------------------------------------------------------
// Created:     08 April 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	theRow	: Integer;
	tmpBool	: Boolean;
	breakOut	: Boolean;

begin
	if (not CM_Object.hasInstance(theObject)) then
		return;
	endif;
	
	if (not self.includeObject(theObject, app.myPassport)) then
		return;
	endif;

	if (not self.tblDataMaster.findObjectInRow(theObject, theRow)) then
		self.addObjectToMasterTable(self.tblDataMaster, theObject.CM_Object, null, null, breakOut);
	endif;
	
end;</source>
        <access>protected</access>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="zHandleNotifyDelete" id="0b5d3821-3682-463b-b322-e3c0620834c3">
        <updating/>
        <source>zHandleNotifyDelete(eventType: Integer; theObject: Object; eventTag: Integer) updating, protected;
// ---------------------------------------------------------------------------
// Created:     08 April 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	newRow,
	theRow	: Integer;
	tmpBool	: Boolean;
	iter	: Iterator;
	obj		: Object;
	numCols	: Integer;
	key1, key2, key3, key4	: Any;
	idx		: Integer;

begin
	self.tblDataMaster.findObjectInRow(theObject, theRow);
	
	if theRow &lt;= self.tblDataMaster.fixedRows then
		return;
	endif;
	
	if self.mode = Mode_New then
		self.tblDataMaster.removeItem(theRow);

	elseif self.mode = Mode_Edit then
		if theObject = self.myCurrentMasterObject then
			app.msgBox(app.getErrorString1(ObjectDeletedByOtherUser, self.caption), 'Warning', MsgBox_OK_Only);
			self.zDoCancel();
		endif;
	endif;
	
	self.tblDataMaster.removeItem(theRow);

end;</source>
        <access>protected</access>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="zHandleNotifyUpdate" id="9bd221bc-fc0e-41f8-a5bb-bbc3274a151e">
        <updating/>
        <source>zHandleNotifyUpdate(eventType: Integer; theObject: Object; eventTag: Integer) updating, protected;
// ---------------------------------------------------------------------------
// Created:     08 April 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	rtnCode,
	theRow			: Integer;
	tmpInclude,
	tmpBool,
	breakOut		: Boolean;

begin
	if (not CM_Object.hasInstance(theObject)) then
		return;
	endif;
	
	if theObject = self.myCurrentMasterObject then
		if self.mode = Mode_View or
		   self.isUpdateComplete then
			self.zShowThumbnailData(theObject.CM_Object);
		elseif self.mode = Mode_Edit then
			// user is editting the object that has just been changed.
			rtnCode := app.msgBox(app.getErrorString1(ObjectUpdatedByAnotherUserEdit, self.caption), 'Warning', MsgBox_OK_Cancel + MsgBox_Exclamation_Mark_Icon);
			if rtnCode = MsgBox_Return_OK then
				self.zDoCancel();
				self.zDoEdit();
			else
				self.zDoCancel();
			endif;
		endif;
	endif;

	tmpInclude := self.includeObject(theObject, app.myPassport);
	// See if the object updated is currently loaded into tblData
	self.tblDataMaster.findObjectInRow(theObject, theRow);

	if tmpInclude and theRow &lt;= 0 then
		// should be included but not found so add
		self.addObjectToMasterTable(self.tblDataMaster, theObject.CM_Object, null, null, breakOut);
		return;
	elseif (not tmpInclude) and theRow &gt; 0 then
		// The object should no longer be in the table based upon
		// the selection criteria
		if self.mode = Mode_Edit and 
		   (theObject = self.myCurrentMasterObject) then
			// user is editting the object that has just been changed.
			rtnCode := app.msgBox(app.getErrorString1(ObjectUpdByAnotherUserNoAccess, self.caption), app.getErrorString(Warning), MsgBox_OK_Only + MsgBox_Stop_Icon);
			self.zDoCancel();
			// belts and braces to ensure the row has not changed in the doCancel
			self.tblDataMaster.findObjectInRow(theObject, theRow);
		endif;
		
		if theRow &gt; 0 then
			self.tblDataMaster.removeItem(theRow);
		endif;
		return;
	endif;

	if theRow &gt; 0 then
		if self.mode = Mode_View or
		   self.isUpdateComplete then
		   	if tmpInclude then
				self.tblDataMaster.accessCell(theRow, 1).text := self.getDataRowForDef(theObject.CM_Object, self.tblDataMaster.myEntTableDef);
		
				if theObject = self.myCurrentMasterObject then
					self.zShowThumbnailData(theObject.CM_Object);
				endif;
			endif;

		elseif self.mode = Mode_Edit then
			if theObject = self.myCurrentMasterObject then
				// user is editting the object that has just been changed.
				rtnCode := app.msgBox(app.getErrorString1(ObjectUpdatedByAnotherUserEdit, self.caption), app.getErrorString(Warning), MsgBox_OK_Cancel + MsgBox_Stop_Icon);
				if rtnCode = MsgBox_Return_OK then
					self.zDoCancel();
					self.zDoEdit();
				else
					self.zDoCancel();
				endif;

			else
			   	if tmpInclude then
					// just redisplay the row changed
					self.tblDataMaster.accessCell(theRow, 1).text := self.tblDataDisplayRow(self.tblDataMaster, theObject.CM_Object);
				endif;
			endif;
		endif;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="zInitControls" id="cc4dde6e-e965-432d-95f6-9b782c90e012">
        <updating/>
        <source>zInitControls() updating, protected;
// ---------------------------------------------------------------------------
// Created:     30 March 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	tmpHeight,
	selfHeight,
	selfWidth			: Real;
	frm					: CMUI_MoveableFrame;
	controller			: CMUI_Controller;	
begin
	self.splMain.left := 0;
	self.splTop.left := 0;
	
	controller := app.myController;
	self.initEntryTbl(self.tblSearch, controller.getEntTableDef(self.getTblSearchDef));
	self.initDataTbl(self.tblDataMaster, controller.getEntTableDef(self.getTblDataMasterDef));
	self.initDataTbl(self.tblDataDetail, controller.getEntTableDef(self.getTblDataDetailDef));
	self.initEntryTbl(self.tblMasterEnt, controller.getEntTableDef(self.getTblEntMasterDef));
	self.initEntryTbl(self.tblDetailEnt, controller.getEntTableDef(self.getTblEntDetailDef));
	
	selfWidth := self.width;
	selfHeight := self.height;
	//resize searcher frame - put front and centre...
	frm := self.frmSearch;
	frm.parent := self;
	frm.zOrder(1);
	frm.left := (selfWidth / 2) - 150;
	frm.top := 200;	
	frm.height := self.tblSearch.height + self.frmToolbarSearch.height + 30;
	//resize detail entry frame - put over the top half of the screen
	frm := self.frmDetailEnt;
	frm.parent := self;
	frm.zOrder(1);
	frm.left := (selfWidth / 2) - 150;
	frm.top := 50;
	frm.visible := false;
	frm.height := self.tblDetailEnt.height + self.frmToolbarDetail.height + 30;
	
	if self.showTblDetailCount then
		self.staMain.visible := true;
	else
		self.staMain.visible := false;
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="zSetControlsForAddEdit" id="7d432cec-e3a4-4a24-a48d-ca99cbf5ca0b">
        <updating/>
        <source>zSetControlsForAddEdit() updating, protected;
// ---------------------------------------------------------------------------
// Created:     05 April 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin

	self.btnCancelBase.enabled := true;
	self.btnSaveBase.enabled := true;
	self.btnShowSearcher.enabled := false;
	
	if self.allowDetailAdd then
//		self.btnAddDetail.enabled := true;
		self.btnAddShow.enabled := true;
	endif;

//	if self.allowDetailUpdate then
//		self.btnUpdateDetail.enabled := true;
//		self.btnUpdateShow.enabled := true;
//	endif;

	if self.allowDetailRemove then
		self.btnRemoveDtl.enabled := true;
		self.btnRemoveDtl2.enabled := true;
	endif;
	self.btnNew.enabled := false;
	self.btnEdit.enabled := false;
	self.btnDelete.enabled := false;
	
	self.tblDetailEnt.userInputEnabled := true;
	self.tblMasterEnt.userInputEnabled := true;

	self.tblMasterEnt.moveFirst();
	self.tblMasterEnt.setFocus();

	self.zShowHideSearcher(false);
	self.btnSaveBase.default := true;
	self.setControlsForAddEdit();
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="zSetControlsForView" id="4e5e19bb-e13c-448b-a162-6723601dd8c4">
        <updating/>
        <source>zSetControlsForView() updating, protected;
// ---------------------------------------------------------------------------
// Created:     05 April 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin
	self.mode := self.Mode_View;
	self.btnCancelBase.enabled := false;
	self.btnSaveBase.enabled := false;
	
	self.btnShowSearcher.enabled := true;
	
	self.btnNew.enabled := true;
	self.btnEdit.enabled := true;
	self.btnDelete.enabled := true;
	//can't go straight into add/editing/removing details from view mode as yet
//	self.btnAddDetail.enabled := true;
	self.btnAddShow.enabled := true;
//	self.btnUpdateDetail.enabled := false;
//	self.btnUpdateShow.enabled := false;
	self.btnRemoveDtl.enabled := true;
//	self.btnRemoveDtl2.enabled := false;
	
	self.frmDetailEnt.visible := false;
	self.tblDetailEnt.userInputEnabled := false;
	self.tblMasterEnt.userInputEnabled := false;
	
	self.setControlsForView();

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="zShowHideDetailEnt" id="32c8bab9-10ee-4636-88f2-8bc394c56ba1">
        <updating/>
        <source>zShowHideDetailEnt(_show : Boolean) protected, updating;
// ---------------------------------------------------------------------------
// Created:     05 April 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin

	if _show then
		self.btnAddShow.enabled := false;
//		self.btnUpdateShow.enabled := false;
		
	
		self.btnAddDetail.enabled := true;
		
		self.btnUpdateDetail.enabled := true;
		self.btnRemoveDtl2.enabled := true;
		
		self.frmDetailEnt.zOrder(1);
		self.frmDetailEnt.visible := true;
		
		self.tblDetailEnt.setFocus();
	else
		self.btnAddShow.enabled := true;
		self.btnUpdateShow.enabled := true;
		self.btnSaveBase.default := false;//meant to be false - handled in keyDown as resetting of default button has a fault
		self.frmDetailEnt.visible := false;
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="_show" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="zShowHideSearcher" id="05328e64-7f00-4a02-bc54-4d9571920f84">
        <updating/>
        <source>zShowHideSearcher(_show : Boolean) updating, protected;
// ---------------------------------------------------------------------------
// Created:     30 March 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin
	if _show then
		if self.mode &lt;&gt; self.Mode_View then
			return;
		endif;
		
		self.frmSearch.visible := true;
		self.tblSearch.moveFirst();
		self.tblSearch.setFocus();
		self.btnSearch.default := true;
		self.btnShowSearcher.caption := 'Hide Searcher';
	else
		self.frmSearch.visible := false;
		self.btnShowSearcher.caption := 'Show Searcher';
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_show" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="zShowThumbnailData" id="0b6a406d-9013-48d4-8020-145868fac26a">
        <updating/>
        <source>zShowThumbnailData(_obj : CM_Object) updating, protected;
// ---------------------------------------------------------------------------
// Created:     06 April 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
// 29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
vars

begin
	self.tblDataDetail.rows := self.tblDataDetail.fixedRows;
	self.myCurrentDetailObject := null;
	
	self.showThumbnailData(_obj);
	
	if self.showTblDetailCount then
		self.staMain.caption := (self.tblDataDetail.rows - self.tblDataDetail.fixedRows).String &amp; ' ' &amp;
									self.getDataEntityDescription(false) &amp; ' listed';
	endif;
	
end;</source>
        <access>protected</access>
        <Parameter name="_obj" type="CM_Object"/>
    </JadeMethod>
</GUIClass>
