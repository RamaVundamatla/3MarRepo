    <JadeMethod name="testTugVariableHook" id="7221ebee-4d91-43f9-9f57-5802bfe382a0">
        <source>testTugVariableHook() : Real;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 February 2025	jlier1	Initial creation

*/

vars

	newRate : Real;
	hmsTran : HMS_VTMISTransaction;
	hmsData : HMS_VoyageData;
	hmsTidal : HMS_TidalClass;
	
	rateEntry : CM_RateEntry;
	
	grt : Integer;
	grtService : CM_Service;
	bu : CM_Bank;
	voyage : CM_Voyage;
	
	re : CM_RateEntry;
	operator : CM_Operator;
	debtor : CM_Debtor;
	adjustedRate : Decimal[14,2];
	
	hmsResource : HMS_ResourceUsed;
	startDT,
	endDT	: TimeStamp;
	difference : Real;
	
	theInteger : Integer;
	theDecimal : Decimal[3,2];
	timeBlock : Decimal[10,1];
	isIntegerNull : Boolean;
	_cmif : CMIF_CalcTypeRateHook;
begin
	if not _cmif.myTransaction.isKindOf(HMS_VTMISTransaction) then
		return newRate;
	endif;
	
	newRate := _cmif.origRate;
	hmsTran := _cmif.myTransaction.HMS_VTMISTransaction;
	hmsData := hmsTran.myHMSVoyageData;
	
	if hmsData = null then
		app.invLog("No HMS Data - shouldn't be here.",LogDEBUG.String);
		return newRate;
	endif;
	
	hmsResource  := hmsTran.myResourceUsed;
	if hmsResource = null then
		app.invLog("No HMS resource found",LogDEBUG.String);
	endif;
	
	startDT := hmsResource.fromDateTime;
	endDT := hmsResource.toDateTime;
	app.invLog("Resource Start Date Time is " &amp; startDT.String,LogDEBUG.String);
	app.invLog("Resource End Date Time is " &amp; endDT.String,LogDEBUG.String);
	
	difference := endDT.differenceInHoursReal(startDT);
	app.invLog("Difference between start and end date times is " &amp; difference.String,LogDEBUG.String);
	
	theInteger := difference.Integer;
	theDecimal := difference - theInteger;
	app.invLog("The Integer value of difference is " &amp; theInteger.String,LogDEBUG.String);
	app.invLog("The Decimal value of the part thereof is " &amp; theDecimal.String,LogDEBUG.String);
	
	if theInteger = 0 then
		isIntegerNull := true;
	else 
		timeBlock := theInteger.Decimal;
	endif;
	app.invLog("The timeBlock calculation from the Integer value is " &amp; timeBlock.String &amp; ". The decimal portion still to be added",LogDEBUG.String);
	
	if theDecimal &gt; 0 then
		if theDecimal &lt; 1 and isIntegerNull then
			theDecimal := 1.0;
		elseif theDecimal &gt; 0 and theDecimal &lt; 0.5 then
			theDecimal := 0.5;
		elseif theDecimal &gt; 0.5 and theDecimal &lt; 1 then
			theDecimal := 1;
		endif;
	endif;
	app.invLog("The rounded (to the nearest half hour) decimal value  has been calculated as " &amp; theDecimal.String,LogDEBUG.String);
	
	if isIntegerNull then
		timeBlock := theDecimal;
	else
		timeBlock := timeBlock + theDecimal;
	endif;
	app.invLog("The final timeBlock calculation is " &amp; timeBlock.String,LogDEBUG.String);
		
	voyage := hmsTran.myVoyage;
	if voyage = null then
		app.invLog("Couldn't find a voyage",LogDEBUG.String);
		return newRate;
	endif;
	
	bu := voyage.myDischargeCompany;
	if bu = null then
		app.invLog("No BU found on voyage",LogDEBUG.String);
		return newRate;
	endif;
	
	grt := hmsData.dim_GrossRegTonnes;
	app.invLog(grt.String &amp; " is the GRT of the voyage",LogDEBUG.String);
	if grt = null then
		app.invLog("No GRT for voyage",LogDEBUG.String);
		return newRate;
	endif;
	
	if grt &lt;= 3500 then
		grtService := bu.services["0-3500 Tug"];
	elseif grt &gt;3500 and grt &lt;= 8000 then
		grtService := bu.services["3501-8000 Tug"];
	elseif grt &gt; 8000 and grt &lt;= 14000 then
		grtService := bu.services["8001-14000 Tug"];
	elseif grt &gt;14000 and grt &lt;= 18000 then
		grtService := bu.services["14001-18000 Tug"];
	elseif grt &gt;18000 and grt &lt;= 26000 then
		grtService := bu.services["18001-26000 Tug"];
	elseif grt &gt; 26000 and grt &lt;= 40000 then
		grtService := bu.services["26001-40000 Tug"];
	elseif grt &gt; 40000 and grt &lt;= 75000 then
		grtService := bu.services["40001-75000 Tug"];
	elseif grt &gt; 75000 then
		grtService := bu.services["75001+ Tug"];
	endif;
	
	if grtService = null then
		app.invLog("GRT Service not found for voyage with " &amp; grt.String &amp; " tonnes",LogDEBUG.String);
		return newRate;
	endif;
	
	operator := voyage.myOperator;
	if operator = null then
		app.invLog("No voyage operator found",LogDEBUG.String);
		return newRate;
	endif;
	
	debtor := operator.debtor;
	if debtor = null then
		app.invLog("No debtor located",LogDEBUG.String);
		return newRate;
	endif;
	
	re := debtor.getServiceTimeRate(grtService, hmsTran.transactionDT);
	if re = null then
		app.invLog("No debtor located",LogDEBUG.String);
		return newRate;
	endif;
	
	adjustedRate := re.getRawCostPerUnit();
	app.invLog("Adjusted Rate before GRT and Time Block is " &amp; adjustedRate.String,LogDEBUG.String );
	
	adjustedRate := (timeBlock * grt) * adjustedRate;
	app.invLog("Adjusted Rate Returned (GRT*timeBlock*Rate Table Entry is " &amp; adjustedRate.String&amp; ")",LogDEBUG.String );
	
	return adjustedRate;
	//return newRate;

epilog

end;</source>
        <ReturnType type="Real"/>
    </JadeMethod>
