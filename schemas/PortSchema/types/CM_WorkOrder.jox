    <JadeMethod name="getNextJobActionTxn" id="0d0b165b-0a74-4dc0-b055-abdbc4393900">
        <source>getNextJobActionTxn(_ts : TimeStamp; _type : Integer) : CM_WOTransaction;
/*

Purpose:			This method returns the next Job Action WO Transaction Type

Parameters:			

Return Value:		

Date		Who		Reason
20/03/2024	navkc1 CR 62694 Task 62901: UI - WO Ops Start Stop Details

*/

vars
	
	woTxn 	: CM_WOTransaction;
	ts		: TimeStamp;
	isEnd	: Boolean;
	
begin
	
	isEnd := _type = TRANS_TYPE_WOJOBSTOP or _type = TRANS_TYPE_WOJOBCOMPLETE;
	
	foreach woTxn in self.allTransactions discreteLock where woTxn.type = _type do
		if isEnd then
			ts := woTxn.getJobEnd();
		else
			ts := woTxn.getJobStart();
		endif;
		
		if not ts.isValid() or ts &lt; _ts then
			continue;
		endif;
		
		return woTxn;
	endforeach;
	
	return null;
	
epilog

end;</source>
        <Parameter name="_ts" type="TimeStamp"/>
        <Parameter name="_type" type="Integer"/>
        <ReturnType type="CM_WOTransaction"/>
    </JadeMethod>
    <JadeMethod name="getNextTask" id="43addd69-6b0d-403c-9f6e-fa563cce353c">
        <source>getNextTask( _aTask : CM_WorkOrderDtl) : CM_WorkOrderDtl;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 July 2009	cnwrd1	Initial creation

*/

vars
	nextTask : CM_WorkOrderDtl;
	position : Integer;
begin

	position := self.allWoDtls.indexOf( _aTask) ;
	
	if position = self.allWoDtls.size then 
		return null;
	endif;
	
	nextTask := self.allWoDtls[position+1];

	return nextTask;
epilog

end;</source>
        <Parameter name="_aTask" type="CM_WorkOrderDtl"/>
        <ReturnType type="CM_WorkOrderDtl"/>
    </JadeMethod>
