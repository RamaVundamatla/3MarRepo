    <JadeMethod name="xHandler" id="e50019a3-2781-4b1e-9c3a-c26df7d75ed3">
        <source>xHandler(_ex : Exception; _hadException : Boolean output) : Integer;

// Created by cnwdvb1 on 04 July 2007

vars

begin

	if _ex.errorCode = 4 then
		_hadException := true;
		return Ex_Resume_Next;
	endif;
	return Ex_Pass_Back;

end;</source>
        <Parameter name="_ex" type="Exception"/>
        <Parameter name="_hadException" type="Boolean" usage="output"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
</Class>
