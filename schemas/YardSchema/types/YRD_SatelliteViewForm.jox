    <JadeMethod name="getFirstAvailTAV" id="8582991c-dc89-4874-b7c2-1a3400964ab4">
        <source>getFirstAvailTAV() : CM_TerminalAreaView;

/*

Purpose:		Get the 1st available terminal area view		

Date			Who		Reason
14/09/2012		cnwmh5	Initial creation

*/

vars

	tav					: CM_TerminalAreaView;

begin

	
	if self.xmlTAViewObject &lt;&gt; null then
		tav := self.xmlTAViewObject.asOid.CM_TerminalAreaView;
	endif;
	
	// find a valid tav
	if not app.isValidObject(tav) then
		foreach tav in self.getTerminal().allTerminalAreaViews discreteLock do
			if app.isValidObject(tav) then
				break;
			endif;
		endforeach;	
	endif;

	return tav;

epilog

end;</source>
        <ReturnType type="CM_TerminalAreaView"/>
    </JadeMethod>
    <JadeMethod name="getNonVisibleBlocks" id="d6af9b10-052c-449a-bbb1-e2e75c4926b0">
        <source>getNonVisibleBlocks(_blocks : ObjectArray input;
					_allYABlocks : CM_YABlockArray input;
					_ya : CM_YardAllocation);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
23 February 2009	cnwjk3	SFW1030
24 September 2009	cnwjo3	par 20066
*/

vars
	obj 		: Object;
	lcArray 	: CM_LCArray;
	rowObjects 	: ObjectArray;
	taView		: CM_TerminalAreaView;
	proxyYABlock : CM_YABlock;
	invalidObj	: Boolean;
	proxyDeckingOptions, newDeckingOptions: CM_YADeckingOptionsBlock;

begin

	on Exception do app.handleDeletedObject(exception, obj, invalidObj); 	 //cnwrd1 26883 6.2.2011

	create rowObjects transient;
	//self.tblYAM.getAllRowObjects(rowObjects);
	self.tblYAM.getAllRowObjectsForYAM(rowObjects,false);  //par 20066
	foreach obj in rowObjects do
		invalidObj := false;//cnwrd1 26883 6.2.2011
		obj.edition(); //cnwrd1 26883 6.2.2011
		
		if not invalidObj and obj.isKindOf(CM_YABlock) and obj.CM_YABlock.getYardAllocation() = _ya then//cnwrd1 26883 6.2.2011
			taView := self.getTerminalAreaView();
			if taView &lt;&gt; null then
				if not taView.includesTA(obj.CM_YABlock.myTerminalArea) then
					// this TA isn't visible in the satellite view, so add its LC array to blocks
					create lcArray transient; // These get deallocated elsewhere
					obj.CM_YABlock.allYardControllers.copy(lcArray);
					_blocks.add(lcArray);
					
					create proxyYABlock as obj.class transient;
					create newDeckingOptions transient;
					newDeckingOptions.setProxyFrom(obj.CM_YABlock.myDeckingOptions);
					newDeckingOptions.setMyBlock(proxyYABlock);
					proxyYABlock.setMinMaxHeight(obj.CM_YABlock.getMinHeight,obj.CM_YABlock.getMaxHeight);
					proxyYABlock.setStatus(obj.CM_YABlock.status);
					_allYABlocks.add(proxyYABlock);
				endif;
			endif;
		endif;
	endforeach;
epilog
	delete rowObjects;
end;</source>
        <Parameter name="_blocks" type="ObjectArray" usage="input"/>
        <Parameter name="_allYABlocks" type="CM_YABlockArray" usage="input"/>
        <Parameter name="_ya" type="CM_YardAllocation"/>
    </JadeMethod>
    <JadeMethod name="getSelectedYA" id="3c057aa1-22ae-47f2-8dd7-b84573850c27">
        <source>getSelectedYA() : CM_YardAllocation;
//12 August 2008	cnwdw1	
// Get the selected YA from the YAM table
vars
	yaEntity	: CM_YAEntity;
	invalid		: Boolean;
	yardAlloc	: CM_YardAllocation;
	
begin
	on Exception do app.handleDeletedObject (exception, yaEntity, invalid);		// 12/03/2013 cnwar2 #29273

	yaEntity := self.tblYAM.getSelectedObject();
	if yaEntity &lt;&gt; null then
		if yaEntity.isKindOf(CM_YardAllocation) then
			yardAlloc := yaEntity.CM_YardAllocation;
		elseif yaEntity.isKindOf(CM_YABlock) then
			yardAlloc := yaEntity.CM_YABlock.myYardAllocationIn;
		endif;
	endif;
	
	return yardAlloc;
end;</source>
        <ReturnType type="CM_YardAllocation"/>
    </JadeMethod>
