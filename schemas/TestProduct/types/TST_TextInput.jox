        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>button1_click(btn: Button input) updating;
/*

Date		Who		Reason
24 August 2015	cnwer1	Initial creation PAR

*/

vars

begin
	self.lstEvents.clear;
	self.txtInput.text:=null;
	self.txtInput.setFocus();
epilog

end;</source>
