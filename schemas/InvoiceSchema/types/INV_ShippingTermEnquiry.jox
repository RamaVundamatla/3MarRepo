    <JadeMethod name="setBusinessUnit" id="3160e09b-f6ee-4f21-8cf3-6025b756cf57">
        <updating/>
        <source>setBusinessUnit() updating;
/*
Purpose:			

Date		Who		Reason

*/

vars
	shipTerm : CM_InvoiceContractShipTerm;
begin
	self.endNotificationForSubscriber(self.myCurrentBank);
	self.myCurrentBank := self.cmbBusinessUnit.listObject.CM_Bank;
	self.beginNotification(self.myCurrentBank, self.myTerminal.getTerminalEvent(Event_InvShipTermCreate), Response_Continuous, null);
	self.beginNotification(self.myCurrentBank, self.myTerminal.getTerminalEvent(Event_InvShipTermUpdate), Response_Continuous, null);
	self.beginNotification(self.myCurrentBank, self.myTerminal.getTerminalEvent(Event_InvShipTermDelete), Response_Continuous, null);
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="82ed7263-75b9-488e-8f36-70ab0737ad7b">
        <updating/>
        <source>setupForm()updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 Jan 2023 navtnr20	TFS CR 55622 Task 55692: UI - Shipping Terms Maint

*/

vars

begin
	inheritMethod();
	self.doPermissions();	
	// ### TFS BUG 59633 31AUG2023 NAVAB1 self.handleMenusForModalDisplay();
	if self.myCurrentBank = null then
		self.myCurrentBank := self.myTerminal.getDefaultCompanyBank();
	endif;
	self.doCmbBUBuild(self.cmbBusinessUnit);
	self.initTblShipTerm(ETDef_ShipTermList);
	self.tblDisplayRow();
	self.setBusinessUnit();
	self.setNavigatorHeading(self.caption);
	
	self.setCaption("Invoice Shipping Terms Enquiry " &amp; self.myCurrentBank.code );

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="tblDisplayRow" id="7a53b9cc-0721-4f3b-ae6c-824e02860ddb">
        <updating/>
        <source>tblDisplayRow()updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 Jan 2023 navtnr20	TFS CR 55622 Task 55692: UI - Shipping Terms Maint

*/

vars
	tbl					: CM_DataTable;
	shipTerm			: CM_InvoiceContractShipTerm;
	idx					: Integer;
	str 				: String;

begin

	tbl := self.tblShipTerm;
	tbl.rows := tbl.fixedRows;
	
	foreach shipTerm in self.myCurrentBank.allShippingTermsByCode
		where shipTerm.myBusinessUnit = self.myCurrentBank do
		str := shipTerm.getAttributeStringForDefArray(tbl.allTblDataEntRows);
		idx := tbl.addItem(str);
		tbl.accessRow(idx).itemObject := shipTerm;
	endforeach;
epilog

end;</source>
    </JadeMethod>
