// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if self.attributeAreas.includes(_attrArea) then
		self.attributeAreas.remove(_attrArea);
	endif;
	if self.attributeAreasByTermAreaId.includes(_attrArea) then
		self.attributeAreasByTermAreaId.remove(_attrArea);
	endif;
	
end;</source>
        <Parameter name="_attrArea" type="CM_AttributeArea"/>
