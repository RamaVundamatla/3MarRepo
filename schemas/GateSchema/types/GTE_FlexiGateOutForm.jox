    <JadeMethod name="populateData" id="6ed1b0db-18f2-458d-8297-95a69cde6def">
        <updating/>
        <source>populateData()updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06 August 2009	cnwml2	Initial creation
// 19 May 2016	cnwns1	TFS 488 - Multi Timezone Support
*/

vars
	tsIn,
	tsOut,
	tsNow: TimeStamp;
begin
	if self.myVisitRecord.myRoadJob &lt;&gt; null then
		self.lblStatus.caption := self.myVisitRecord.myRoadJob.statusString;
	endif;
	self.txtVisitNo.text := self.myVisitRecord.visitNumber;
	if self.myVisitRecord.myDriverDetails &lt;&gt; null then
		self.txtDriver.text := self.myVisitRecord.myDriverDetails.code.asStringJMT;
		self.lblDriverName.caption := self.myVisitRecord.myDriverDetails.name;
	endif;
	self.txtCarrier.text := self.myVisitRecord.carrierCode;
	self.txtRego.text := self.myVisitRecord.regNumber.asStringJMT;
	tsIn := self.systemToLocalTime(myVisitRecord.timeIn);			// 19 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	self.dateIn.text := tsIn.date().asStringJMT;					// 19 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	self.timeIn.text := tsIn.time().asStringJMT;					// 19 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	
	if self.myVisitRecord.timeOut &lt;&gt; null then
		tsOut := self.systemToLocalTime(self.myVisitRecord.timeOut);// 19 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		self.dateOut.text := tsOut.date().asStringJMT;				// 19 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		self.timeOut.text := tsOut.time().asStringJMT;				// 19 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	else
		tsNow := self.systemToLocalTime(app.actualTimeServer);		// 19 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		self.dateOut.text := tsNow.date().asStringJMT;				// 19 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		self.timeOut.text := tsNow.time().asStringJMT;				// 19 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	endif;
	
	self.loadReceivalsTable();
	self.loadReleasesTable();
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="saveGateEntity" id="94dd57e7-926b-4d96-aea0-40c5bd04fc9f">
        <updating/>
        <source>saveGateEntity(_isUpdate : Boolean; _pxyGTE : CMGTE_Entity input; _validationOnly : Boolean; warningsToIgnore : IntegerArray) : Boolean updating;
// ---------------------------------------------------------------------------
// Created:     August 2008 ANDREW BISHOP
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	result : Integer;
	vvRec : CM_VehicleVisitRecord;
	gte: CMGTE_Entity;
	tranNum : String;
begin
	vvRec := self.myVisitRecord;
	while true do
		// When adding gte from the Gate Complete, always auto complete
		_pxyGTE.setAutoComplete(true);
		if _isUpdate then
			//app.myTrxUA.trxUpdateInOutFlexiGateEntity(vvRec, _pxyGTE, app.myPassport);
		else
			//app.myTrxCA.trxCreateAndActionGateEntity(vvRec, _pxyGTE, null, gte, app.myPassport);													// cnwjk3 ccms 1071 25/02/10
			if self.myCurrentCMGTE_ReceivalByType = null then																						// cnwjk3 ccms 1071 25/02/10
				app.myTrxCA.trxCreateAndActionGateEntity(vvRec, _pxyGTE, null, gte, app.myPassport);												// cnwjk3 ccms 1071 25/02/10
			else																																	// cnwjk3 ccms 1071 25/02/10
				app.myTrxCA.trxCreateAndActionGateEntity(vvRec, _pxyGTE, self.myCurrentCMGTE_ReceivalByType.myReceivalInfo, gte, app.myPassport);	// cnwjk3 ccms 1071 25/02/10
			endif;	
		endif;
		if app.myPassport.trxCompletedOK then
			self.doRefresh();
			return true;
		endif;
		
		result := app.showErrorWarningDialog(app.getErrorString(GateInOut), app.myPassport, ErrWarnMode_Add + ErrWarnMode_CanAckWarnings);
		if app.myPassport.noErrors and result = IDOK then
			// there must have just been warnings that the user has acknowledged so ..
			app.myPassport.warningsAcknowledged	:= true;
			continue;
		endif;
		return false;
	endwhile;

	return true;
epilog
	app.myPassport.clearErrorsToIgnore();
end;</source>
        <Parameter name="_isUpdate" type="Boolean"/>
        <Parameter name="_pxyGTE" type="CMGTE_Entity" usage="input"/>
        <Parameter name="_validationOnly" type="Boolean"/>
        <Parameter name="warningsToIgnore" type="IntegerArray"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
