	//epr TFS 3418 13/3/17 removed not needed for exposure
	//create xdbFeature transient;
	//xdbFeature.setupAndBuildSet(CM_Train::myEDIConfig.name, "CM_Train", "myEDIConfig", "CM_Train", _features); 
	
	//epr TFS 3418 13/3/17 removed as job sheet just holds collections of wles and jobs
	//create xdbFeature transient;
	//xdbFeature.setupAndBuildSet(CM_Train::myJobSheet.name, "CM_Train", "myJobSheet", "CM_Train", _features); 
	
	create xdbFeature transient;
	xdbFeature.setupAndBuildSet(CM_Train::myOriginPort.name, "CM_Train", "myOriginPort", "CM_Train", _features); 
	
