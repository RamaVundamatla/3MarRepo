    <JadeMethod name="create" id="57f9ccaf-9c0f-46ba-afed-87561a89611b">
        <updating/>
        <executionLocation>client</executionLocation>
        <source>create() updating, clientExecution;
/*
Purpose:			
Date		Who		Reason
12 January 2015	cnwab1	Initial creation
*/

vars

begin
	self.permissionView	:= PmShipOperationsView;
	self.permissionMaint := PmShipOperationsView;
	self.helpFileName := HelpFile_Voyage;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="displayList" id="2116493e-1e8b-4df5-96cc-8bdb5a12647f">
        <source>displayList();
/*
Purpose:			
Date		Who		Reason
12 January 2015	cnwab1	Initial creation
*/

vars
	item : CMIF_VoyageCheckListItem;
	obj : Object;
begin



	self.tblData.rows := 0;
	foreach obj in self.myVoyageCheckList.allItems discreteLock do
		item := obj.CMIF_VoyageCheckListItem;
		self.tblData.addItemObject(obj,item.name &amp; Tab &amp; item.amount);
	endforeach;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doRefresh" id="31be1428-c065-437c-890c-ad57aa926c98">
        <updating/>
        <source>doRefresh() updating, protected;
/*
Purpose:			
Date		Who		Reason
12 January 2015	cnwab1	Initial creation
*/

vars

begin
	inheritMethod();
	self.buildList();
	
	self.displayList();

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupForm" id="4cf3abcf-220d-4236-878f-8af5314b8323">
        <updating/>
        <source>setupForm() updating;
/*
Purpose:			
Date		Who		Reason
12 January 2015	cnwab1	Initial creation
*/

vars

begin
	inheritMethod();

	self.tblData.move(1,10,self.clientWidth - 1, self.btnPrint.top - 20);
	self.tblData.parentAspect := Frame.ParentAspect_StretchBoth;
	create myVoyageCheckList transient;
	
	self.setCaption(self.caption &amp; " - " &amp; self.myVoyage.code);
	self.doRefresh();
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="6f0116c6-bb49-453f-a27a-2cbec5a8b730">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 January 2015.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0020202, locale);
	btnCancel.translateCaption(Xlat_0020203, locale);
	btnPrint.translateCaption(Xlat_0020204, locale);
	btnRefresh.translateBubbleHelp(Xlat_0020205, locale);
	btnRefresh.translateCaption(Xlat_0020206, locale);
end;</source>
    </JadeMethod>
    <JadeMethod name="unload" id="6c198e67-e0c9-4853-9d53-96ac949505c9">
        <controlMethod name="Form::unload"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>unload() updating;
/*
Purpose:			
Date		Who		Reason
12 January 2015	cnwab1	Initial creation
*/

vars

begin
	inheritMethod();
	
	self.myVoyageCheckList.allItems.purge();
	delete self.myVoyageCheckList;
epilog

end;</source>
    </JadeMethod>
