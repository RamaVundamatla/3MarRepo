    <JadeMethod name="utlCreateUnscaledLogs" id="ba03856e-c21f-4ce3-a7d3-a3931cd9292e">
        <updating/>
        <source>utlCreateUnscaledLogs(_bol : CM_BOL input; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     14 February 2001 by cnwdwq1
//
// Purpose:			Creates persistent trackeditems for each transient in 
//							the _logBOL struct
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	ti : CM_TrackedItem;
	newTI : CM_TrackedItem;
begin
	// Always initialize the activity first
	self.initialiseActivity;
	app.setContinueCMExceptions(true);
	
	app.myValCA.valUnscaledLogs(_bol);

	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);

	_bol.myExtension.CM_BOLExtLogIn.addUnscaledLogs(_passport);
	
end;</source>
        <Parameter name="_bol" type="CM_BOL" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
