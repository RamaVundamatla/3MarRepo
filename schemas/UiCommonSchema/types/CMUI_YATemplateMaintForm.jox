    <JadeMethod name="createProxyCriteria" id="cb97bb82-fa42-4a10-92e2-035383d2596a">
        <updating/>
        <source>createProxyCriteria() updating;

/*

Purpose:		This method is invoked for a new template.  It creates proxy criteria objects
				which are used to display the default criteria type ex CM_YAConfig.

Parameters:			

Return Value:	self.myProxyCriterias populated with transients


Date			Who		Reason
14 August 2008	consw1	Initial creation

*/

vars
	cmifCriteria 	: CMIF_YACriteriaPriority;
	criteriaValue	: String;
	criteriaType 	: CM_YACriteriaType;
	itemCode 		: String;
	proxyCriteria	: CM_YACriteria;
	yaConfig		: CM_YAConfig;

begin
	yaConfig := self.myTerminal.myYAConfig;

	if yaConfig = null then
		return;
	endif;
	
	foreach criteriaType in yaConfig.allDefaultCriteriaTypes do
		itemCode := criteriaType.description.cnEcUpto(CM_YACriteriaPriority::code.length -1);
		criteriaValue := null;
		if criteriaType.isBooleanType() then
			criteriaValue := CM_YADataBoolean.VALUE_FALSE.String;
		endif;
		create proxyCriteria transient;
		proxyCriteria.setProxy(criteriaType, criteriaValue, itemCode);
		cmifCriteria := proxyCriteria.getTransient();
		self.myProxyCriterias.add(cmifCriteria);
	endforeach;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="createProxyYATemplate" id="276480fe-4e39-4533-ac17-f96c3864089a">
        <updating/>
        <source>createProxyYATemplate() updating;
//18 July 2008	cnwdw1	
// Create a proxy for the YA Template being editted, and mark all the criteria for delete
// We will recreate all the criteria on save
vars
	proxyYATemplate: CM_YATemplate;
	criteria: CM_YACriteria;
	cmifCriteria : CMIF_YACriteriaPriority;
begin
	self.myProxyYATemplate := app.createUpdateProxy(self.myYATemplate).CM_YATemplate;
	foreach criteria in self.myYATemplate.myYardAllocation.allCriteria do
		cmifCriteria := criteria.getTransient();
		cmifCriteria.setFlag(false, false, true);	
		self.myProxyCriterias.add(cmifCriteria);
	endforeach;
end;</source>
    </JadeMethod>
    <JadeMethod name="doCancel" id="6c4955e1-b240-4d8d-b039-292162f699e9">
        <updating/>
        <source>doCancel() updating;
//31 July 2008	cnwdw1	
//
vars

begin
	unloadForm;
end;</source>
    </JadeMethod>
    <JadeMethod name="doOK" id="14d8df4e-50d8-40b9-a5a9-b55e9e4c8390">
        <updating/>
        <source>doOK() updating;
//29 July 2008	cnwdw1	
//
vars
	proxyYA					: CM_YardAllocation;
	yardAllocation			: CM_YardAllocation;
	proxyYATemplate			: CM_YATemplate;
	yaTemplate				: CM_YATemplate;
	fillOptionIn			: Integer;
	fillOptionOut			: Integer;
	yaCode					: String;
	yaDescription			: String;
	yaRemarks				: String;
	expiryType				: Integer;
	expiryDate				: Date;
	allowOthers				: Integer;
	noLocation				: Integer;
	priorityAdj				: Integer;
	isTestOverstowWeight	: Boolean;
	isDisabled				: Boolean;
	proxyCriterias			: CMIF_Array;
	proxyCriteriasCombined	: CMIF_Array;
	yaColor					: Integer;
	overstowRule			: CM_YAOverstowRule;
	status					: Integer;
	theResult : Integer;	//14 Jan 2020 NDL	TFS 46815
	
begin
	if self.isEditMode then
		proxyYA := self.myProxyYATemplate.myYardAllocation;
		proxyYATemplate := self.myProxyYATemplate;
	else
		create proxyYA transient;
		create proxyYATemplate transient;
	endif;
	
	create proxyCriterias transient;
	self.getCriteria(proxyCriterias);
	
	fillOptionIn			:=	YAFillOption_Alternating;
	fillOptionOut			:=	YAFillOption_Alternating;
	yaCode					:=	self.txtCode.cnEcString();
	status					:=	self.cmbStatus.getCurrentItemData();
	yaDescription			:=	self.txtDescription.cnEcString();
	yaRemarks				:=	self.txtYARemarks.cnEcString();
	expiryType				:=	self.getExpiryType();
	expiryDate				:=	self.dateExpiryDate.getDate();
	//yaColor					:=	self.clrColour.getColor();
	allowOthers				:=	self.cmbAllowOthers.getCurrentItemData();
	noLocation				:=	YANoLocation_Continue;
	overstowRule			:=  self.cmbOverstowRule.listObject.CM_YAOverstowRule;
	priorityAdj				:=	0;
	isTestOverstowWeight	:=	false;
	isDisabled				:=	false;

	proxyYA.setProxy(yaCode,
						yaDescription,
						yaRemarks,
						fillOptionIn,
						fillOptionOut,
						expiryType,
						expiryDate,
						yaColor,
						null,  //cnwjo3 par 24145
						allowOthers,
						noLocation,
						overstowRule,
						priorityAdj,
						isTestOverstowWeight,
						isDisabled,
						null,
						null,
						false,
						null);
	proxyYATemplate.setProxy(yaCode, proxyYA, self.myTerminal, status);
	
	//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		if self.isEditMode() then
			create proxyCriteriasCombined transient;
			proxyCriterias.copy(proxyCriteriasCombined); // new criteria to add
			self.myProxyCriterias.copy(proxyCriteriasCombined); // old criteria to delete
			app.myTrxUA.trxUpdateYATemplate(self.myProxyYATemplate, proxyCriteriasCombined, yaTemplate, app.myPassport);
		else
			app.myTrxCA.trxCreateYATemplate(proxyYATemplate, proxyCriterias, yaTemplate, app.myPassport);
		endif;
	
		if app.myPassport.trxCompletedOK then
			unloadForm;
			break;
		else
			theResult := app.showErrorWarningDialog("Yard Allocation Template", app.myPassport, ErrWarnMode_Update);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		break;
		
	endwhile;

epilog
//	delete proxyYA;
	if not self.isEditMode then
		delete proxyYA;
		delete proxyYATemplate;
	endif;
	if proxyCriterias &lt;&gt; null then
		proxyCriterias.purge();
	endif;
	delete proxyCriterias;
	delete proxyCriteriasCombined;
end;</source>
    </JadeMethod>
    <JadeMethod name="doUnload" id="0723376c-02ab-42b2-b87e-a5d6229302c4">
        <updating/>
        <source>doUnload() updating;
//31 July 2008	cnwdw1	
//
begin
	if self.myParentForm &lt;&gt; null then
		self.myParentForm.doEnable(true);
	endif;
	if self.myProxyCriterias &lt;&gt; null then
		self.myProxyCriterias.purge();
	endif;
	if self.myProxyYATemplate &lt;&gt; null then
		delete self.myProxyYATemplate;
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="getCriteria" id="f926149c-d052-49c4-8431-2a96fe441a4c">
        <source>getCriteria(_criterias: CMIF_Array input);
//30 July 2008	cnwdw1	
// Get a collection of criteria that have been entered on the form
vars
	proxyCriteria: CM_YACriteria;
	criteriaType : CM_YACriteriaType;
	cmifCriteria : CMIF_YACriteriaPriority;
	itemCode : String;
	value: Any;
	criteriaFrame : CMUI_YACriteriaCntl;
	index: Integer;
begin
	foreach index in 1 to MAX_CRITERIA do
		criteriaFrame := self.frmCriteria.getControl(index).CMUI_YACriteriaCntl;
		criteriaType := criteriaFrame.getCriteriaType();
		if criteriaType &lt;&gt; null and criteriaFrame.hasValue() then
			create proxyCriteria transient;
			itemCode := criteriaType.description.cnEcUpto(CM_YACriteriaPriority::code.length -1);
			value := criteriaFrame.getValue();
			proxyCriteria.setProxy(criteriaType, value, itemCode);
			cmifCriteria := proxyCriteria.getTransient();
			cmifCriteria.setFlag(true, false, false);	
			_criterias.add(cmifCriteria);
		endif;
	endforeach;
end;</source>
        <Parameter name="_criterias" type="CMIF_Array" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getExpiryType" id="b43c35f7-ac3b-4678-939f-635722ba6914">
        <source>getExpiryType() : Integer;

/*

Purpose:		Get the value of the relevant YA Expiry Type global constant.		

Parameters:			

Return Value:		


Date			Who		Reason
07 August 2008	consw1	Initial creation

*/

vars

begin
	if self.optExpiryNever.value then
		return YAExpiryType_Never;
	elseif self.optExpiryVoyage.value then
		return YAExpiryType_VoyageDepart;
	
	elseif self.optExpiryClear.value then	//29 Jun 2011	NDL	Par 27786
		return YAExpiryType_VoyageClear;
		
	elseif self.optExpiryEmpty.value then
		return YAExpiryType_WhenEmpty;
	elseif self.optExpiryDate.value then
		return YAExpiryType_SpecifiedDate;
	endif;
	
	return 0;

epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="initializeControls" id="688decc7-d09a-44d9-b8d0-b3a1f81fec8e">
        <source>initializeControls();

/*

Purpose:			

Parameters:			

Return Value:		


Date			Who		Reason
08 August 2008	consw1	Initial creation

*/

vars
	terminal : CM_Terminal;
	
begin
	if self.isEditMode then
		terminal := self.myYATemplate.myTerminal;
	else
		terminal := self.myTerminal;
	endif;

	self.shtOptions.visible := false;	// PAR 19210
	
	cmbStatus.itemData[cmbStatus.addItem(YATemplateStatus_ActiveStr)]			:=	YATemplateStatus_Active;
	cmbStatus.itemData[cmbStatus.addItem(YATemplateStatus_DisabledStr)]			:=	YATemplateStatus_Disabled;
	
	cmbAllowOthers.itemData[cmbAllowOthers.addItem(YAOverlap_AlwaysStr)]		:=	YAOverlap_Always;
	cmbAllowOthers.itemData[cmbAllowOthers.addItem(YAOverlap_NeverStr)]			:=	YAOverlap_Never;
	cmbAllowOthers.itemData[cmbAllowOthers.addItem(YAOverlap_SometimesStr)]		:=	YAOverlap_Sometimes;
	cmbAllowOthers.itemData[cmbAllowOthers.addItem(YAOverlap_LastResortStr)]	:=	YAOverlap_LastResort;
	
	cmbOverstowRule.displayCollection(terminal.allYAOverstowRules, true, 0, null, "None");

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="isDefaultCriteriaType" id="e601c5eb-d8f1-47b2-b416-fb29a183cfbd">
        <source>isDefaultCriteriaType( _criteria: CM_YACriteria ) : Boolean;

/*

Purpose:			

Parameters:			

Return Value:	Returns true when type for criteria is select in default criteria types


Date			Who		Reason
14 August 2008	consw1	Initial creation

*/

vars
	yaConfig : CM_YAConfig;

begin
	if _criteria = null then
		return false;
	endif;
	
	yaConfig := self.myTerminal.myYAConfig;

	if yaConfig = null then
		return false;
	endif;
	
	return yaConfig.allDefaultCriteriaTypes.includes( _criteria.myYACriteriaType );

epilog

end;</source>
        <Parameter name="_criteria" type="CM_YACriteria"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isEditMode" id="ae84d3a8-78bc-49a4-8bf5-623a6cd223ed">
        <source>isEditMode() : Boolean protected;
//28 July 2008	cnwdw1	
//
vars

begin
	return self.myYATemplate &lt;&gt; null;
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="populateCriteriaFrames" id="aa5da68d-dde4-4887-816a-a3a279196bea">
        <source>populateCriteriaFrames();
//18 July 2008	cnwdw1	
//
vars
	i: Integer;
	top, left, height, width: Integer;
	criteriaFrame : CMUI_YACriteriaCntl;
	criteria: CM_YACriteria;
	cmifCriteria: CMIF_YACriteriaPriority;
	criterias: Iterator;
	cntlTabIndex: Integer;
	
begin

	top :=  1; 
	left := 1; 
	height := ((self.shtCriteria.height - 10) / 10).Integer;
	width := (self.shtCriteria.width / 2).Integer;

	cntlTabIndex := self.frmCriteria.tabIndex;

//	if self.isEditMode() then
		criterias := self.myProxyCriterias.createIterator;
//	endif;
	
	// Load up the criteria controls max of 20 criteria
	foreach i in 1 to MAX_CRITERIA do 
		if (i = (MAX_CRITERIA / 2) + 1) then
			left := width;	// second column
			top := 1;
		endif;
		criteriaFrame := self.frmCriteria.loadControl(i).CMUI_YACriteriaCntl;
		criteriaFrame.setWidth(width);
//		criteriaFrame.setTabIndex(cntlTabIndex);
		
		criteria := null;
//		if self.isEditMode() then
			if criterias.next(cmifCriteria) then
//				criteria := cmifCriteria.myCriteriaPriority.CM_YACriteria;
				criteria := cmifCriteria.myProxy.CM_YACriteria;
			endif;
//		endif;
		criteriaFrame.setCriteria(criteria);
		criteriaFrame.setMasterControl(self.frmCriteria);	//cnwmc5 - PAR 31255

		if self.isDefaultCriteriaType(criteria) then
			criteriaFrame.setLabelVisible(true);
		endif;
				
		criteriaFrame.setTabIndex(cntlTabIndex);
		criteriaFrame.move(left, top, width, height);
		criteriaFrame.visible := true;
		criteriaFrame.tag := "true";	// to active three-state booleans 23 Mar 2015	NDL	Par 35886
		top := top + height;
	endforeach;

	self.frmCriteria.visible := false;
epilog
	delete criterias;
end;
</source>
    </JadeMethod>
    <JadeMethod name="populateExpiryType" id="74466365-f94b-444e-8d1a-a08ad7f7022a">
        <source>populateExpiryType( _expiryType : Integer );

/*

Purpose:		Set the expiry option controls for the given YA Expiry Type value.

Parameters:			

Return Value:		


Date			Who		Reason
07 August 2008	consw1	Initial creation

*/

vars

begin
	self.optExpiryNever.cnEcSet(_expiryType = YAExpiryType_Never);
	self.optExpiryVoyage.cnEcSet(_expiryType = YAExpiryType_VoyageDepart);
	self.optExpiryEmpty.cnEcSet(_expiryType = YAExpiryType_WhenEmpty);
	self.optExpiryDate.cnEcSet(_expiryType = YAExpiryType_SpecifiedDate);
	self.optExpiryClear.cnEcSet(_expiryType = YAExpiryType_VoyageClear);	//29 Jun 2011	NDL	Par 27786

epilog

end;</source>
        <Parameter name="_expiryType" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="populateForm" id="53b98715-7e24-4ce2-b674-e8ef534db639">
        <updating/>
        <source>populateForm() updating;
//31 July 2008	cnwdw1	
//
vars
	templateYA : CM_YardAllocation;
	
begin
	if self.isEditMode then
		templateYA := self.myProxyYATemplate.myYardAllocation;
		self.txtCode.text := self.myProxyYATemplate.code.String;
		self.cmbStatus.setIndexForItemData( self.myProxyYATemplate.status );
		//self.clrColour.setColor(templateYA.color);
		self.txtDescription.text := templateYA.description;
		self.txtYARemarks.text := templateYA.remarks;
		self.populateExpiryType( templateYA.expiryType );
		self.dateExpiryDate.setDate( templateYA.expiryDate );
		self.cmbAllowOthers.setIndexForItemData( templateYA.allowOthersOption );
		self.cmbOverstowRule.setIndexFromObject( templateYA.myYAOverstowRule );
	else
		self.cmbStatus.setIndexForItemData(YATemplateStatus_Active);
		self.optExpiryNever.value := true;
		self.cmbAllowOthers.setIndexForItemData(YAOverlap_Always);
	endif;
	
	self.populateCriteriaFrames();

end;</source>
    </JadeMethod>
    <JadeMethod name="setParentForm" id="70649523-3c3e-4613-af6e-82508fd3f640">
        <updating/>
        <source>setParentForm(_parent: CM_BaseForm) updating;
//31 July 2008	cnwdw1	
//
begin
	self.myParentForm := _parent;
end;</source>
        <Parameter name="_parent" type="CM_BaseForm"/>
    </JadeMethod>
    <JadeMethod name="setYATemplate" id="b86b0947-8f48-453c-be91-25fe6e7a0c8d">
        <updating/>
        <source>setYATemplate(_yaTemplate: CM_YATemplate) updating;
//31 July 2008	cnwdw1	
// Set the ya template that will be editted
vars

begin
	self.myYATemplate := _yaTemplate;
end;</source>
        <Parameter name="_yaTemplate" type="CM_YATemplate"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="4f5ae493-e112-409c-bef6-f5e06d32b3dd">
        <updating/>
        <source>setupForm() updating;
//28 July 2008	cnwdw1	
//
vars

begin
	inheritMethod();
	self.centreOverParent(100);
	
	if self.isEditMode() then
		self.setCaption(app.getErrorString(Edit_Yard_Allocation_Template));
		self.createProxyYATemplate();
	else
		self.setCaption(app.getErrorString(New_Yard_Allocation_Template));
		self.createProxyCriteria();
	endif;

	self.initializeControls();

	self.populateForm();

epilog
	app.mousePointer := MousePointer_Default;
end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="676fc608-dcd4-454d-a78c-1b375d9d83bf">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0017527, locale);
	btnCancel.translateCaption(Xlat_0010326, locale);
	btnOK.translateCaption(Xlat_0010327, locale);
	grpExpiryType.translateCaption(Xlat_0010328, locale);
	lblAllowOthers.translateCaption(Xlat_0010329, locale);
	lblCode.translateCaption(Xlat_0010330, locale);
	lblDescription.translateCaption(Xlat_0010331, locale);
	lblOverstowRule.translateCaption(Xlat_0010332, locale);
	lblStatus.translateCaption(Xlat_0010333, locale);
	lblYARemarks.translateCaption(Xlat_0010334, locale);
	optExpiryClear.translateCaption(Xlat_0016926, locale);
	optExpiryDate.translateCaption(Xlat_0010335, locale);
	optExpiryEmpty.translateCaption(Xlat_0010336, locale);
	optExpiryNever.translateCaption(Xlat_0010337, locale);
	optExpiryVoyage.translateCaption(Xlat_0010338, locale);
	shtCriteria.translateCaption(Xlat_0010339, locale);
	shtOptions.translateCaption(Xlat_0010340, locale);
end;</source>
    </JadeMethod>
