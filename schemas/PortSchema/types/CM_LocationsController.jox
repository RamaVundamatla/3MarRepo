    <JadeMethod name="testIsControllerFullTAMax" id="cb2bdce7-7ec7-419f-848c-745ef628eafb">
        <source>testIsControllerFullTAMax(obj: CMIF_AutoMovePlan input) : Boolean;
/*

Date		Who		Reason
02 April 2014	cnwer1	Initial creation PAR

*/

vars
	ti : CM_TrackedItem;
	errorMsg : String;
	errorNum : Integer;
	availableQuantity : Integer;
	availableWeight : Decimal [18,4];//navsp1 13MAY2022 TFS#53529
	availableVolume : Decimal [18,4];//navsp1 13MAY2022 TFS#53529
begin
	ti:=obj.myTrackedItem;
	
	if ti = null then
		return false;
	endif;
	
	if self.checkControllerFullTAMax(ti,obj.quantity,obj.weight, errorMsg,errorNum,availableQuantity,availableWeight,availableVolume) then
		obj.addVerboseLogEntry(errorMsg, IsError, errorNum);
		obj.updateController(null);	
		return true;
	endif;

	return false;
epilog

end;</source>
        <Parameter name="obj" type="CMIF_AutoMovePlan" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="testIsControllerFullTAMaxYA" id="96c30560-0c3b-4a30-8f05-362231a21661">
        <source>testIsControllerFullTAMaxYA(_yaAgent: CM_YAAutoplanAgent input; _hasSomeCap : Boolean output): Boolean;
/*

Date		Who		Reason
01 April 2014	cnwer1	Initial creation PAR

*/

vars
	ti : CM_TrackedItem;
	errorMsg : String;
	errorNum : Integer;
	availableQuantity : Integer;
	availableWeight : Decimal [18,4];//navsp1 13MAY2022 TFS#53529
	availableVolume : Decimal [18,4];//navsp1 13MAY2022 TFS#53529
begin
	ti:=_yaAgent.myCMIFYAAutoPlan.getMyTrackedItem();
	
	if ti = null then
		_hasSomeCap := false;
		return false;
	endif;
	
	if self.checkControllerFullTAMax(ti,null,null,errorMsg,errorNum,availableQuantity,availableWeight,availableVolume) then
		_yaAgent.addLogEntry(AP_Log_YA_Default,errorMsg,true);
		return true;
	endif;
	
	return false;
epilog
	//16 Jun 2016	NDL	TFS 2172
	if ti &lt;&gt; null then
		_hasSomeCap := ( availableQuantity + availableWeight + availableVolume ) &gt; 0;	
	endif;
	
end;</source>
        <Parameter name="_yaAgent" type="CM_YAAutoplanAgent" usage="input"/>
        <Parameter name="_hasSomeCap" type="Boolean" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
