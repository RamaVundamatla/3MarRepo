    <JadeMethod name="setDisplayMonth" id="0f1f4565-98ca-408e-bf4b-88c6156f28d4">
        <updating/>
        <source>setDisplayMonth(pMonth:Integer; pYear:Integer) updating;
// --------------------------------------------------------------------------------
// Created:		02 November 2000 by cnwdad1
//
// Purpose:		Updates the currently displayed month and year.
//
// Parameters:	pMonth - The new month to display.
//				pYear - The new year to display.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.currentMonth &lt;&gt; pMonth or self.currentYear &lt;&gt; pYear then
		self.setSelectedDate(null, false);

		self.currentMonth	:= pMonth;
		self.currentYear	:= pYear;

		self.redrawSelf();
		self.monthChange(self);
	endif;
end;</source>
        <Parameter name="pMonth" type="Integer"/>
        <Parameter name="pYear" type="Integer"/>
    </JadeMethod>
