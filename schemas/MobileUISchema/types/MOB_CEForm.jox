    <JadeMethod name="processForCloseForm" id="84b4062f-4364-41fe-bff2-817dc1791b7f">
        <updating/>
        <source>processForCloseForm(): Boolean updating;
/*
	Created on 20 May 2008
	
	by Debby Hutchison
	
	Purpose:
*/

vars

begin
	if not self.forceClose and self.hasUnsavedChanges() then 
		if app.msgBox(app.getErrorString(Unsaved_data), "",MsgBox_Yes_No) = MsgBox_Return_No then
			return false;
		endif;
	endif;
	
	return true;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="84d14057-0f2a-48e6-870d-1670e26bed0b">
        <updating/>
        <source>setupForm() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 July 2008	cnwer1	Initial creation

*/

vars

begin
	inheritMethod();
	//epr par 16981 
	if self.caption = null then
		self.caption:=app.name;
	endif;
	self.controlBox:=false;
	self.borderStyle := self.BorderStyle_None;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="translateForm" id="b15503e0-e9ba-40bf-88b5-35bf8a01894c">
        <updating/>
        <source>translateForm(locale : CM_Locale) updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	
begin
	// Determine the locale for translations.
	inheritMethod(locale);
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0018466, locale);
end;</source>
        <Parameter name="locale" type="CM_Locale"/>
    </JadeMethod>
