    <JadeMethod name="verifyEDIDataTIs" id="5d07eb8c-2833-4b1f-b98b-2c436060f5cc">
        <updating/>
        <source>verifyEDIDataTIs(_passport: CM_Passport input): Integer updating;
// ---------------------------------------------------------------------------
// Created:	15 October 2009 By Graeme Black cnwgb1
// Status: 	
// Purpose:	Messina 1008 PAR 20320 
// ---------------------------------------------------------------------------
// 18/06/2012	cnwcs5	par 29747 - refactor into trx
vars
	
begin
	// Arm our base exception handlers
	on Exception do validationExceptionHandler(exception, _passport);
	
	app.setContinueCMExceptions(true);
		
	app.myTrxUA.trxProcessEDIBOLConsist(self, true, _passport);
	
	return _passport.allErrors.size;
epilog
	
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
</Class>
