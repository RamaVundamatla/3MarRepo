    <JadeMethod name="setControlsForAddEdit" id="d0143263-adde-4283-83f5-22567ca5ddd6">
        <updating/>
        <source>setControlsForAddEdit() updating;
// ---------------------------------------------------------------------------
// Created:		January 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	now : Time;
begin
	inheritMethod();

	self.tblEntDetail.clearValues();
	self.populateEntDetailTable();
	self.tblEntDetail.setFocus;
	
	if self.mode = self.Mode_Add then
		self.range.clear;
		self.rangeStart.clear();
		self.rangeEnd.clear();
		self.days.clear();
		self.tblEntDetail.setValueByName(ETRow_IsNotAvailableForEntryCk,false);
		self.tblEntDetail.showHideRowsByViewName("InvCalcViewBlank",CM_EntryTable.ShowHideRows, false);
		self.tblEntDetail.setValueByName(ETRow_TimeFrom, "00:00"); 
		self.tblEntDetail.setValueByName(ETRow_TimeTo, "00:00"); 
	endif;

	self.tblEntDetail.goToRowByName(ETRow_Code);
	
	/*//25/06/2024	navkc1 CR 64823 Task 64824
	self.txtFilterBox.enabled		:=	false; 	// ### TFS 51912 22Sep2021 NAVPW1
	self.btnClearFilter.enabled		:=	false; 	// ### TFS 51912 22Sep2021 NAVPW1
	*/
	
	//05/06/2024	navkc1 CR 63736 Task 63770
	if self.frmTableFilter &lt;&gt; null then
		self.frmTableFilter.btnClearFilter.enabled := false;
		self.frmTableFilter.txtFilterBox.enabled := false;
	endif;
end;</source>
    </JadeMethod>
