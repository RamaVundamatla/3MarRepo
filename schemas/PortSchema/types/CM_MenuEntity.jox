    <JadeMethod name="getMyTopLevelParent" id="4063a424-82be-40d6-8293-ea31b03b90d6">
        <source>getMyTopLevelParent() : CM_MenuEntity;

vars
	obj	: Object;
	
begin

	if self.myParent.isKindOf(CM_MenuRoot) then
		return self;
	else
		return self.myParent.getMyTopLevelParent();
	endif;
	
end;</source>
