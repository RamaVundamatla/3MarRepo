<Class name="CM_EWSActivityFinanceOne" id="37ecb9d4-48e1-4913-9d42-beff46052814">
    <superclass name="CM_ExternalWebServiceActivity"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="backgroundprocess"/>
    <Constant name="Status_FailureException" id="17085634-7977-4c90-bcfc-64fd75e8591e">
        <source>"Failure Exception"</source>
        <type name="String"/>
    </Constant>
    <Constant name="Status_FailureResponse" id="c5e5693e-ad4c-4d0f-9bd5-ec680059b89a">
        <source>"Failure Response"</source>
        <type name="String"/>
    </Constant>
    <Constant name="Status_Success" id="f28bb725-e7eb-468c-a4ad-7a5f7cda1f19">
        <source>"Success"</source>
        <type name="String"/>
    </Constant>
    <ExplicitInverseRef name="myInvoice" id="823775e9-0464-4a10-bb0b-408d056de0e8">
        <kind>child</kind>
        <transientToPersistentAllowed/>
        <updateMode>manual</updateMode>
        <embedded/>
        <type name="CM_Invoice"/>
        <access>readonly</access>
        <Inverse name="CM_Invoice::allEWSFinanceOneActivities"/>
    </ExplicitInverseRef>
    <JadeMethod name="initialiseFromInvoiceAndDef" id="9ab940d4-b540-4b57-8c4b-6ddc87d0510f">
        <updating/>
        <source>initialiseFromInvoiceAndDef(_invoice : CM_Invoice;
							_def : CM_FinanceOneSeviceDef) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 March 2023	jlier1	Initial creation 56856

*/

vars

begin
	self.description:="Finance One gRPC sendInvoice";
	if _invoice &lt;&gt; null then
		self.myInvoice:=_invoice;
		self.myTerminal:=_invoice.myTerminal;
		self.description:=self.description &amp; Space &amp; self.myInvoice.sequenceNum.String;
		if self.myInvoice.myPostedCreditInvoice &lt;&gt; null then
			self.description:=self.description &amp; Space &amp; "Posted Credit Invoice " &amp; self.myInvoice.myPostedCreditInvoice.sequenceNum.String;
		endif;
	endif;
	if _def &lt;&gt; null then
		self.interfaceName := _def.name;
	endif;
	
	self.myRoot:=app.myRoot;
	self.createdUser := app.getMyUserCode();
	self.created := app.actualTimeServer();
epilog

end;</source>
        <Parameter name="_invoice" type="CM_Invoice"/>
        <Parameter name="_def" type="CM_FinanceOneSeviceDef"/>
    </JadeMethod>
    <JadeMethod name="isFinanceOne" id="124eabf6-9947-4ced-828d-af18707b8f6a">
        <source>isFinanceOne(): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
27 September 2024	navcs2	ChangeRequest 66181: MTN | External Webservice Monitor - Feedback

*/

vars

begin
	return true;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="a1e5e42f-0ca9-4336-acd5-ea2d6fbf679a">
        <updating/>
        <source>setForCreate(_proxy: SelfType) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 March 2023	jlier1	Initial creation 56856

*/

vars

begin
	inheritMethod(_proxy);
	
	self.myInvoice := _proxy.myInvoice;
	self.setForUpdate(_proxy);
	self.interfaceName:=ExternalWebServiceFinanceOne;
epilog

end;</source>
        <Parameter name="_proxy" type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setStatus" id="b16ff3db-5eee-46dd-b535-839176f485c7">
        <updating/>
        <source>setStatus(_hadError, _hadException, _hadSuccess : Boolean) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date					Who		Reason
23 September 2024		navmd1	Initial creation TFS 66210 Moved from trxCreateFinanceOneActivity so it can be used in update too

*/

vars

begin
	if _hadError then
		self.setProxyStatus(CM_EWSActivityFinanceOne.Status_FailureResponse);
	elseif _hadException then
		self.setProxyStatus(CM_EWSActivityFinanceOne.Status_FailureException);
	elseif _hadSuccess then
		self.setProxyStatus(CM_EWSActivityFinanceOne.Status_Success);
	endif;
epilog

end;</source>
        <Parameter name="_hadError" type="Boolean"/>
        <Parameter name="_hadException" type="Boolean"/>
        <Parameter name="_hadSuccess" type="Boolean"/>
    </JadeMethod>
</Class>
