    <JadeMethod name="getRowMoveHelperForDate" id="fc55653c-855b-4bd2-89d4-b30c20b0ac7a">
        <source>getRowMoveHelperForDate(_date : Date) : CMIF_StockMoveHelper;
//--------------------------------------------------------------
//Created: 08 October 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	rowMoveHelper : CMIF_StockMoveHelper;
begin
	foreach rowMoveHelper in self.allStockMoveHelpers do
		if rowMoveHelper.date = _date then
			return rowMoveHelper;
		endif;
	endforeach;
	return null;
end;</source>
        <Parameter name="_date" type="Date"/>
        <ReturnType type="CMIF_StockMoveHelper"/>
