    <JadeMethod name="addObjectsToTable" id="e83bc260-9fdb-4da4-a59c-eb8a003e537f">
        <updating/>
        <source>addObjectsToTable(_numItems: Integer io) updating;
// ---------------------------------------------------------------------------
// Created:     22 October 2003 by cnwrs2
//23/08/2016 cnwma1 TFS #2557:SPT - Missing Planned Location on Sequence Sheets- Issue not fixed from previous TFS
// Purpose:     
// ---------------------------------------------------------------------------
vars
	job : CM_Job;
	jobSet : CM_JobSet;
	passport : CM_Passport;
	breakOut	: Boolean;
begin

	if self.filterVoyage = null then
		return;
	endif;
	
	app.setMyCurrentVoyage(self.filterVoyage);
	
	self.tblJobEdit.clearValues();
	self.tblJobEdit.clearAllSelected;
	
	jobSet := self.filterVoyage.allVoyageJobs;
	
	self.doCombosBuildForFilterVoyage();
	
	passport := app.myPassport;
	beginNotification(self.filterVoyage, self.myTerminal.getTerminalEvent(VoyageJob_Create_Event), Response_Continuous, 0);

	//foreach job in jobSet                                               //23/08/2016 cnwma1 TFS# 2557
	foreach job in jobSet  where  not job.isKindOf(CM_VoyageROROJob) do   //23/08/2016 cnwma1 TFS# 2557
		if self.includeObject(job, passport) then
			self.addObjectToTable(job, _numItems, breakOut);
			if breakOut then
				break;
			endif;
		endif;
	endforeach;
end;</source>
        <Parameter name="_numItems" type="Integer" usage="io"/>
    </JadeMethod>
