<Class name="CM_YATypeIsOnTrailer" id="e740514d-d998-44b3-8269-2267ed10e754">
    <superclass name="CM_YACriteriaType"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="yardAllocations"/>
    <JadeMethod name="getCriteriaObjectForTi" id="ff1d23e7-9130-44a8-86a5-84ee1d6945f0">
        <source>getCriteriaObjectForTi(_ti: CM_TrackedItem; _criteriaObject: CM_Object output; _process: Boolean output);
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 25 January 2024
TFS#		: 62141
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/
begin
	if _ti.isOnTrailer then
		_process := true;
	endif;
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_criteriaObject" type="CM_Object" usage="output"/>
        <Parameter name="_process" type="Boolean" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getCriteriaValueForTi" id="97992d15-ea9f-4fa2-a1f4-1226621b71f3">
        <source>getCriteriaValueForTi(_ti: CM_TrackedItem; _criteriaValue: Any output);
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 25 January 2024
TFS#		: 62141
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

begin
	if _ti.isOnTrailer then
		_criteriaValue := CM_YADataBoolean.VALUE_TRUE;
	else
		_criteriaValue := CM_YADataBoolean.VALUE_FALSE;
	endif;
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_criteriaValue" type="Any" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getTypeName" id="7ded53c2-06b7-42da-bf08-6283d7003417">
        <source>getTypeName(): String;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 25 January 2024
TFS#		: 62141
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/
begin
	return "Is On Trailer";
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
