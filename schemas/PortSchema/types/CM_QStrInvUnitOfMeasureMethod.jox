    <JadeMethod name="getKeyLengthForXTABDictionary" id="35fc9826-cbf7-4696-b6db-6e19ca2b6506">
        <source>getKeyLengthForXTABDictionary(): Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08/02/2023	navvt20 TFS 56132 Task 56137: Jade - Invoice Line Selector - UOM
*/

vars
	length	:Integer;
begin
	// just incase the global constant values change !!!
	length := app.getErrorString(Normal).length;
	length := length.max (app.getErrorString(Void).length);
	
	return length;

epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
