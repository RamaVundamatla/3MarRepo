    <JadeMethod name="addQueueToTable" id="df9de17e-be1a-4ee0-912d-2c5e1b1cc416">
        <source>addQueueToTable(pQueue : CM_RadioTelemetryQueue; pIsAccessable : Boolean);
// ---------------------------------------------------------------------------
// Created:     18 October 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	isCurrent,
	canAccess	: Boolean;
	idx,
	theRow		: Integer;
	
begin

	if pQueue = null then
		return;
	endif;

	idx := tblSecondQueues.rows;
	theRow := tblSecondQueues.addItem(idx.String &amp; Tab &amp; 
									  pQueue.id &amp; Tab &amp;
									  pIsAccessable.cnEcGetTableCheckBoxValue);

	if pQueue = self.myMachine.myPrimaryQueue then
		tblSecondQueues.accessCell(theRow, 4).text := 'X';
	endif;

end;</source>
        <Parameter name="pQueue" type="CM_RadioTelemetryQueue"/>
        <Parameter name="pIsAccessable" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doLoad" id="d5e2e826-e2f5-45c0-b6df-e9e548525b82">
        <updating/>
        <source>doLoad() updating;
// ---------------------------------------------------------------------------
// Created:     18 October 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	hist	: CM_MachineHistory;
	idx		: Integer;
//	masterQ	: CM_MasterQueue;
//	rt		: CM_RadioTelemetry;
//	subQ	: CM_RadioTelemetryQueue;

begin

	if self.myMachine = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Machine is not set');
		return;
	endif;

	self.setHeading();

	shtMoveHistory.caption := 'Move History [' &amp; self.myMachine.history.size.String &amp; ']';
	tblMoveHistory.columns := 3;
	tblMoveHistory.displayCollection(self.myMachine.history, true, Table.DisplayCollection_Reversed, null);

	shtRejectedTasks.caption := 'Rejected Tasks [' &amp; self.myMachine.rejectedRTQueueTasks.size.String &amp; ']';
	tblRejectedTasks.columns := 6;
	tblRejectedTasks.displayCollection(self.myMachine.rejectedRTQueueTasks, true, Table.DisplayCollection_Reversed, null);


	tblSecondQueues.accessCell(1,1).text := Tab &amp; 'Queue' &amp; Tab &amp; 'Access' &amp; Tab &amp; 'Current';
	tblSecondQueues.accessColumn(3).inputType := Table.InputType_CheckBox;

	// sgp 3 June 2003 : moved to loadDataForFirstTime
/*	foreach subQ in self.myMachine.allQueues do
		self.addQueueToTable(subQ, true);
	endforeach;
	
	rt := self.myTerminal.radioTelemetry;
	if rt &lt;&gt; null then
		masterQ := rt.masterQueue;
		loadQueue(masterQ);
	endif;
*/

end;</source>
    </JadeMethod>
    <JadeMethod name="load" id="d2d52905-274c-40b7-9fa7-fdbf1dabf1d3">
        <controlMethod name="Form::load"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>load() updating;
// ---------------------------------------------------------------------------
// Created:     18 October 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	self.doLoad();

end;</source>
    </JadeMethod>
    <JadeMethod name="loadDataForFirstTime" id="ad06aed7-525f-42d2-8a59-700d90c62fc7">
        <updating/>
        <source>loadDataForFirstTime() updating, protected;
// ---------------------------------------------------------------------------
// Created:      03 June 2003 by cnwsgp1
// ---------------------------------------------------------------------------
vars
	masterQ	: CM_MasterQueue;
	rt		: CM_RadioTelemetry;
	subQ	: CM_RadioTelemetryQueue;

begin
	foreach subQ in self.myMachine.allQueues do
		self.addQueueToTable(subQ, true);
	endforeach;
	
	rt := self.myTerminal.radioTelemetry;
	if rt &lt;&gt; null then
		masterQ := rt.masterQueue;
		loadQueue(masterQ);
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="loadQueue" id="ed541217-91a3-4868-86b7-e96d33b9ff78">
        <source>loadQueue(pQueue : CM_RadioTelemetryQueue);
// ---------------------------------------------------------------------------
// Created:     18 October 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	subQ		: CM_RadioTelemetryQueue;
	
begin

	if pQueue = null then
		return;
	endif;
	
	if self.myMachine.allQueues.includes(pQueue) then
		// Will have already been loaded earlier
		return;
	endif;

	if pQueue.allSubQueuesById.size = 0 then
		self.addQueueToTable(pQueue, false);
	else
		foreach subQ in pQueue.allSubQueuesById do
			self.loadQueue(subQ);
		endforeach;
	endif;

end;</source>
        <Parameter name="pQueue" type="CM_RadioTelemetryQueue"/>
    </JadeMethod>
    <JadeMethod name="setHeading" id="ca643b5b-0554-4395-a72d-4db3d26a1ee2">
        <updating/>
        <source>setHeading() updating;
// ---------------------------------------------------------------------------
// Created:     19 October 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	str	: String;
	
begin

	str := 'Machine ' &amp; self.myMachine.id;
	self.caption := str;
	
	str := str &amp; ' - ' &amp; self.myMachine.machineTypeString &amp; '.';
	
	if self.myMachine.workingInQueue &lt;&gt; null then
		str := str &amp; ' Working in queue ' &amp; self.myMachine.workingInQueue.id;
	endif;
	
	lblMachineName.caption := str;

end;</source>
    </JadeMethod>
    <JadeMethod name="tblMoveHistory_displayRow" id="70c4c397-4191-4313-9e69-db96f9b3615b">
        <controlMethod name="Table::displayRow"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblMoveHistory_displayRow(table: Table input; theSheet: Integer; obj: Object; theRow: Integer; bcontinue: Boolean io):String updating;
// ---------------------------------------------------------------------------
// Created:     18 October 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	hist	: CM_MachineHistory;
begin

	hist := obj.CM_MachineHistory;

	return hist.dateTime.String &amp; Tab &amp;
		   hist.userId &amp; Tab &amp;
		   hist.typeString;

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="theSheet" type="Integer"/>
        <Parameter name="obj" type="Object"/>
        <Parameter name="theRow" type="Integer"/>
        <Parameter name="bcontinue" type="Boolean" usage="io"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="tblRejectedTasks_displayRow" id="7a0a9172-0d73-44d5-94b4-b8160157f775">
        <controlMethod name="Table::displayRow"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblRejectedTasks_displayRow(table: Table input; theSheet: Integer; obj: Object; theRow: Integer; bcontinue: Boolean io):String updating;
// ---------------------------------------------------------------------------
// Created:     18 October 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	task	: CM_RTQueueTask;

begin

	task := obj.CM_RTQueueTask;
	
	return task.queueId &amp; Tab &amp;
		   task.tiId &amp; Tab &amp;
		   task.taskTypeId &amp; Tab &amp;
		   task.sourceLocationId &amp; Tab &amp;
		   task.targetLocationId &amp; Tab &amp;
		   task.statusString;
		   
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="theSheet" type="Integer"/>
        <Parameter name="obj" type="Object"/>
        <Parameter name="theRow" type="Integer"/>
        <Parameter name="bcontinue" type="Boolean" usage="io"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="651ba357-b868-4aac-94ad-b2f5637e369d">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
//	self.translateCaption(Xlat_0017729, locale);
	lblMachineName.translateCaption(Xlat_0004546, locale);
	shtMoveHistory.translateCaption(Xlat_0004547, locale);
	shtRejectedTasks.translateCaption(Xlat_0004545, locale);
	shtSecondQueues.translateCaption(Xlat_0004548, locale);
end;</source>
    </JadeMethod>
</GUIClass>
