    <JadeMethod name="delete" id="188c95c1-c236-473c-bd1a-9ae84dbcdaa1">
        <updating/>
        <source>delete() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
07 Jan 2009	cnwdz2	Initial creation

*/

vars

begin
	delete self.allDischargePorts;
	delete self.cargoType;
	delete self.commodity;
	delete self.consignor;
	delete self.consignee;
	delete self.destinationPort;
	delete self.dischargePort;
	delete self.imexStatusString;
	delete self.isoType;
	delete self.operatorCode;
	delete self.shippingLineCode;
	delete self.transportMode;
	delete self.voyageCode;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setAllTIHazards" id="38f60660-35e2-44c3-8044-226e1570e37a">
        <updating/>
        <source>setAllTIHazards(obj: CM_BookingRefItem) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
15 September 2010	#cnwdz2	 25439

*/
constants
	Delimiter	: String = "; ";
vars
	 tiHazard : CM_Hazard;
begin
	foreach tiHazard in obj.allTIHazards do
		if self.allTIHazards = null then
			self.allTIHazards := tiHazard.getTableDisplay(false, true);
		else
			self.allTIHazards := self.allTIHazards &amp; Delimiter &amp; tiHazard.getTableDisplay(false, true);
		endif;
	endforeach;
epilog

end;</source>
        <Parameter name="obj" type="CM_BookingRefItem"/>
    </JadeMethod>
    <JadeMethod name="setDefaultsFromObject" id="104f61bf-3c78-4b24-86f2-4c1f047dc32b">
        <updating/>
        <source>setDefaultsFromObject(bookingRefNumber : String; pObj : CM_BookingRefItem) updating;
/*
	Created on 23 January 2008
	
	by Debby Hutchison
	
	Purpose:
*/

vars
	defCommodity	: CM_Commodity;
	defConsignee,
	defConsignor	: CM_ConsigneeConsignor;

	defDestination,
	defDischarge	: CM_Port;
	defISOType		: CM_ISOType;
	defOperator		: CM_Operator;
	defCargoType	: CM_CargoType;
	defVoyage		: CM_Voyage;

	defTransportMode,
	tmpInt			: Integer;
	tmpReal	  	    : Real;
	defStatus	: CM_IMEXStatus;	
	pConsignor  : CM_ConsigneeConsignor;	
	isControlledAtmosphere : Boolean;
begin	
	//self.noneEditableFields := "bookingReference,cargoType,isoType,imexStatusString,voyageCode,operatorCode,dischargePort,commodity,consignor";
	if pObj &lt;&gt; null then		
		defCommodity 	:= app.getCargoFieldObject(pObj, ETRow_Commodity).CM_Commodity;
		defConsignor	:= app.getCargoFieldObject(pObj, ETRow_ConsignorCode).CM_ConsigneeConsignor;
		defConsignee	:= app.getCargoFieldObject(pObj, ETRow_ConsigneeCode).CM_ConsigneeConsignor;
		defDestination	:= app.getCargoFieldObject(pObj, ETRow_DestinationPort).CM_Port;
		defDischarge	:= app.getCargoFieldObject(pObj, ETRow_DischargePort).CM_Port;
		defISOType		:= app.getCargoFieldObject(pObj, ETRow_IsoType).CM_ISOType;		
		defStatus		:= app.getCargoFieldObject(pObj, ETRow_StatusString).CM_IMEXStatus;				
		defVoyage		:= app.getCargoFieldObject(pObj, ETRow_VoyageCode).CM_Voyage;
		defOperator		:= app.getCargoFieldObject(pObj, ETRow_OperatorCode).CM_Operator;
		defCargoType	:= app.getCargoFieldObject(pObj, ETRow_CargoType).CM_CargoType;
		defTransportMode := TI_TRANSMODE_ROAD;				
		
		if pObj.isKindOf(CM_BRefItemContainer) then
			isControlledAtmosphere := pObj.CM_BRefItemContainer.isControlledAtmosphere;
			if isControlledAtmosphere then
				//cnwmc5 - PAR 32206 - 5 Sep 2013
				self.isControlledAtmosphere := isControlledAtmosphere.String;//app.getYesNo(isControlledAtmosphere);
				self.curtainsIn := pObj.CM_BRefItemContainer.getCurtainsIn.String;//app.getYesNo(pObj.CM_BRefItemContainer.getCurtainsIn);
				//29/05/2009 cnwdz2 refactored the following
				self.carbonDioxide := pObj.CM_BRefItemContainer.getCarbonDioxide.asNullCarbonDioxide();
				self.oxygen := pObj.CM_BRefItemContainer.getOxygen.asNullOxygen();
			endif;
			
			self.humidity := pObj.CM_BRefItemContainer.getHumidity.asNullHumidity();				
			self.ventilation := pObj.CM_BRefItemContainer.getVentilation.asNullDecimal(); //par19252 cnwrs1 may 2009
			self.carriageTempC := pObj.CM_BRefItemContainer.getTemperatureAsString();//13/03/2009 cnwdz2 par 19051
		endif;
		
		//14/06/2010 cnwdz2 par23027
		self.remarks := pObj.remarks;
		//17/09/2010 cnwdz2 par25439
		self.setAllTIHazards(pObj);
	
		self.bookingReference := bookingRefNumber;
		self.myBookingRefItem := pObj.getShortDisplay();
		//self.creationDateTime := pObj.creationTS.asStringJMT();
		self.creationDateTime := pObj.creationTS.asStringForWebInterface();	//26 Oct 2012	NDL	Par 30622
		//self.weightTotal := pObj.weight.truncatedTo(0).asStringJMT();
		self.weightTotal := pObj.weight.truncatedTo(0).asStringWeightForWebInterface();	//26 Oct 2012	NDL	Par 30622
		//self.volume := pObj.volume.asStringJMT(); //26/08/2010 cnwdz2 25440
		self.volume := pObj.volume.asStringForWebInterface(); //26 Oct 2012	NDL	Par 30622
		
		
		if defCommodity &lt;&gt; null then
			create self.commodity transient;
			self.commodity.setProxyFromObject(defCommodity);
		endif;
		
		
		if defConsignor &lt;&gt; null then
			create self.consignor transient;
			self.consignor.setProxyFromObject(defConsignor);		
		endif;
	
		if defConsignee &lt;&gt; null then
			create self.consignee transient;
			self.consignee.setProxyFromObject(defConsignee);		
		endif;
		
		if defDestination &lt;&gt; null then
			create self.destinationPort transient;
			self.destinationPort.setProxyFromObject(defDestination);			
		endif;	
	
		if defDischarge&lt;&gt; null then
			create self.dischargePort transient;
			self.dischargePort.setProxyFromObject(defDischarge);		
		endif;
	
		if defISOType &lt;&gt; null then
			create self.isoType transient;
			self.isoType.setProxyFromObject(defISOType);
		endif;
	
		
		if defStatus &lt;&gt; null then
			create self.imexStatusString transient;
			self.imexStatusString.setProxyFromObject(defStatus);
		endif;
			
		if  defVoyage &lt;&gt; null then
			create self.voyageCode transient;
			self.voyageCode.setProxyFromObject(defVoyage);
			
			if defVoyage.myShippingLine &lt;&gt; null then
				create self.shippingLineCode transient;
				self.shippingLineCode.setProxyFromObject(defVoyage.myShippingLine);
			endif;
		endif;
			
		if defOperator &lt;&gt; null then
			create self.operatorCode transient;
			self.operatorCode.setProxyFromObject(defOperator);		
		endif;	
		
		create self.transportMode transient;
		self.transportMode.id			:= app.transportModeENumToString(defTransportMode);	
		self.transportMode.description	:= self.transportMode.id;
		
		if defCargoType &lt;&gt; null then
			create self.cargoType transient;
			self.cargoType.setProxyFromObject(defCargoType);
		endif;
	endif;
end;</source>
        <Parameter name="bookingRefNumber" type="String"/>
        <Parameter name="pObj" type="CM_BookingRefItem"/>
    </JadeMethod>
</Class>
