        <updating/>
        <source>cmbConsignee_displayEntry(combobox: ComboBox input; obj: Any; lstIndex: Integer):String updating;
// ---------------------------------------------------------------------------
// Created:     20 December 2000 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	/* WAS PAR 1318. AKB August 2001. The obj in our combo is now a string not the actual consignor object
	return self.myAssistant.displayEntryConsignor(obj.CM_ConsigneeConsignor);
	NOW */
	//return obj.String;	
	return self.myAssistant.displayEntryConsignor(obj.CM_ConsigneeConsignor);	
	
end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
        <Parameter name="obj" type="Any"/>
        <Parameter name="lstIndex" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
