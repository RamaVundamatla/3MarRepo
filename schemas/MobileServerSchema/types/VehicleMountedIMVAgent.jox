    <JadeMethod name="doAcceptTask" id="43924f1c-d2e0-4767-b229-385125f7ea06">
        <updating/>
        <source>doAcceptTask(rtQueueEntry: CM_RTQueueEntry input;
				_twinQueueEntry : CM_RTQueueEntry input;
				_sideAccessDirection : Integer input;
				_tandemLift	: Boolean;
				_errorMsgs: DTO_HandHeldGateErrorDict input) updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
26 October 2006	cnwer1	Initial creation - PAR#xxxx
20 January 2020	jlgka1 TFS 47394 - Tandem Movement Enhancement. Revert code back before the Tandem Movement changes.
*/
vars	
	error : CM_Error;
	invalidObject : Boolean;
begin
	
	// cnwjk3 par 18518 20/11/08 
	on Exception do app.handleDeletedObject(exception, rtQueueEntry, invalidObject);

	self.initialiseForNewRequest(_errorMsgs);  //cnwjo3 par 24636
	
	app.myTrxUA.trxMachineAcceptTask(self.myMachine,rtQueueEntry.allTasks.first,null,null,app.myPassport);	// 29/11/19 JLGNS1 TFS47394
	//inheritMethod(rtQueueEntry,_errorMsgs);
	//app.myTrxRT.trxChangeTaskStatus(rtQueueEntry.allTasks.first,self.myMachine,TASK_ACCEPTED,app.myPassport);

	// cnwjk3 par 18518 20/11/08 
	if invalidObject then
		return;
	endif;

	//app.myTrxRT.trxChangeTaskStatus(rtQueueEntry.allTasks.first,self.myMachine,TASK_ACCEPTED,app.myPassport);
	//app.myTrxRT.trxAcceptTask(self.myMediator,app.myPassport);
	//if self.createErrorsFromPassport(_errorMsgs) then
	//	return;
	//endif;

	
	epilog

end;</source>
        <Parameter name="rtQueueEntry" type="CM_RTQueueEntry" usage="input"/>
        <Parameter name="_twinQueueEntry" type="CM_RTQueueEntry" usage="input"/>
        <Parameter name="_sideAccessDirection" type="Integer" usage="input"/>
        <Parameter name="_tandemLift" type="Boolean"/>
        <Parameter name="_errorMsgs" type="DTO_HandHeldGateErrorDict" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doAttachChassis" id="c5c10255-75f2-420f-af90-aa067e7da2bb">
        <source>doAttachChassis(	_chassisStr : String; 
					_errorMsgs: DTO_HandHeldGateErrorDict input);
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 October 2009	cnwer1	Initial creation

*/

vars
	error : CM_Error;
	chassis : CM_TILC;
	moveController : CMIF_MoveController;
begin
	self.initialiseForNewRequest(_errorMsgs);  //cnwjo3 par 24636

	chassis:=self.myTerminal.lookupTrailerOnsite(_chassisStr,null).CM_TILC;
	
	if chassis = null then
		self.addError(Could_find_chassis_with,app.getErrorString1(Could_find_chassis_with,_chassisStr ),_errorMsgs);
		return;
	endif;
	
	create moveController transient;
	moveController.setMyTrackedItem(chassis);
	moveController.setMyToPrimaryLocation(self.myMachine.myMachineController);
	moveController.setMoveMode(REAL_MODE);
	moveController.isForcedMove := true;
	
	app.myTrxUA.trxMoveTrackedItem(moveController, app.myPassport);
	
	self.createErrorsFromPassport(_errorMsgs);
epilog
	delete moveController;
end;</source>
        <Parameter name="_chassisStr" type="String"/>
        <Parameter name="_errorMsgs" type="DTO_HandHeldGateErrorDict" usage="input"/>
    </JadeMethod>
