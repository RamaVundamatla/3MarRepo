    <JadeMethod name="clickBtnMove" id="9596f51e-f8c6-4c61-8bc7-070cc360c97a">
        <updating/>
        <source>clickBtnMove()updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 October 2020	jlgndl1	Initial creation	TFS 49189
04 Nov 2020 	cnwma1  ChangeRequest 50112: ASPA - GCI Stevedores
*/

vars
	
	tiArray : CM_TIArray;
	targetLocation : CM_LocationsController;
	moveController : CMIF_MoveController;
	allMoveControllers : ObjectArray;
	ti : CM_TrackedItem;
	localTimeStamp : TimeStamp;
	effectiveTimeStamp : TimeStamp;
	ret : Integer;
	msg : String;
	stevedore: CM_Stevedore;

begin

	self.endNotes();

	if self.optOps.value then
	
		if not self.txtDate.getDate.isValid then
			msg := app.getErrorString( Date_time_value_not_valid );
			app.msgBox( msg, app.getErrorString(Error), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon );
			return;
		endif;
		
		localTimeStamp.setDate( self.txtDate.getDate );
		localTimeStamp.setTime( self.txtTime.getTime );
		effectiveTimeStamp := self.myTerminal.localToSystemTime( localTimeStamp );
		
		if effectiveTimeStamp &gt; app.actualTimeAppServer then
			//can be in the past but not the future
			msg := app.getErrorString( Date_time_not_future );
			app.msgBox( msg, app.getErrorString(Error), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon );
			return;
		endif;
	
		if self.optGateOut.value then
			
			while true do
				app.myTrxUA.trxUpdateVVRRoadExit( self.myVehicleVisitRecord, effectiveTimeStamp, app.myPassport );
				
				if app.myPassport.trxCompletedOK then
					self.clearErrorWarnings();
					self.optOps.enabled := false;
					self.optView.value := true;
					break;	
				else
					ret := app.showErrorWarningDialog(app.getErrorString(GateOut), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
					if app.myPassport.noErrors and
					   ret = IDOK then
						app.myPassport.warningsAcknowledged	:= true;
						continue;
					endif;
					break;
				endif;
				
				break;
			
			endwhile;
			
		elseif self.optLoad.value or self.optDischarge.value then
		
			create tiArray transient;
			self.getSelected( tiArray );
			
			targetLocation := self.cmbSubLocation.listObject.CM_LocationsController;
			
			if tiArray.isEmpty or targetLocation = null then
				return;
			endif;
			
			create allMoveControllers transient;
			
			foreach ti in tiArray do		
				create moveController transient;
				moveController.setMyTrackedItem( ti );	
				moveController.setMyToPrimaryLocation(targetLocation);
				moveController.setMyOriginatingLocation( ti.myPrimaryActualLocation );
				moveController.setMoveMode( REAL_MODE );
				moveController.setEffectiveTimeStampOverride( effectiveTimeStamp );	
				moveController.myAssociatedVVR := self.myVehicleVisitRecord;
				if ti.canSplitTotalQuantity then
					moveController.setWeight( ti.totalWeight ); 
					moveController.setQuantity( ti.totalQuantity );
					if not self.getQuantityForMove( moveController ) then
						delete moveController;
						continue;
					endif; 
				endif;	
				allMoveControllers.add( moveController );
			endforeach;
			
			while true do
				app.myTrxUA.trxMoveMultiTrackedItems( allMoveControllers, app.myPassport );
				
				if app.myPassport.trxCompletedOK then
					self.clearErrorWarnings();
					break;	
				else
					ret := app.showErrorWarningDialog(app.getErrorString(Move), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
					if app.myPassport.noErrors and
					   ret = IDOK then
						app.myPassport.warningsAcknowledged	:= true;
						continue;
					endif;
					break;
				endif;
				
				break;
			
			endwhile;
				
			
		endif;
	
	elseif self.optUpdate.value then   //04.11.2020 cnwma1 TFS #50112
		if self.cmbStevedore.listObject &lt;&gt; null then
			stevedore := self.cmbStevedore.listObject.CM_Stevedore;
		endif;
		self.updateStevedore(stevedore);
	else
		//view mode, move button should not be visible
	endif;
	
epilog

	self.beginNotes();
	
	if allMoveControllers &lt;&gt; null and not allMoveControllers.isEmpty then
		allMoveControllers.purge();
	endif;
	delete allMoveControllers;
	delete tiArray;
	self.clickOptionButton();

end;</source>
    </JadeMethod>
    <JadeMethod name="clickCargoEnquiry" id="649a87c6-d675-4e6e-809e-fd3ca36a79c4">
        <source>clickCargoEnquiry();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 November 2020	jlgndl1	Initial creation	TFS 50274

*/

vars

	tiArray : CM_TIArray;

begin
	
	create tiArray transient;
	self.getSelected( tiArray );
	
	if tiArray.isEmpty then
		return;
	endif;
	
	self.myAssistant.showCargoEnquiryForTIs( tiArray.first, tiArray,self.myMasterMenuAction, false );

epilog

	delete tiArray;

end;</source>
    </JadeMethod>
