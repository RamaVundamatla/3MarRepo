    <JadeMethod name="setProxyFromObject" id="57732f74-5ede-43ec-9dc6-feff4513607f">
        <updating/>
        <source>setProxyFromObject(_toDoTask : CM_ToDoTask) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 November 2023	navpw1	Initial creation TFS: 58761 (60739)

*/

vars
	toDoTaskDesc	: CM_ToDoTaskDesc;
	status			: Integer;
	
begin
	inheritMethod(_toDoTask);
	
	toDoTaskDesc		:= _toDoTask.toDoTaskDesc;
	status				:= _toDoTask.status;
	self.code			:= _toDoTask.toDoTaskDescCode;
	self.description	:= toDoTaskDesc.description;
	
	self.remarks := _toDoTask.remarks;
	if status = STATUS_COMPLETE then	 //10.7.2018 cnwma1 TFS #39560
		self.completedDate := _toDoTask.dtLastUpdate.asStringForWebInterface;
	endif;
	
	self.requiredExtraInfo	:= toDoTaskDesc.requiredExtraInfo;
	self.hasResources		:= toDoTaskDesc.allResourceTypes.isNotEmpty();
	self.isComplete			:= status = STATUS_COMPLETE;
	
end;</source>
        <Parameter name="_toDoTask" type="CM_ToDoTask"/>
    </JadeMethod>
    <JadeMethod name="setResourceGroups" id="23e2cfe9-8026-4bf3-ad69-ee4d14b0a610">
        <source>setResourceGroups(_availableResourceGroups, _mandatoryResourceGroups : CM_ResourceTypeGroupByCode; _objectsToBeDeleted : ObjectArray input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 November 2023	navpw1	Initial creation TFS: 58761 (60739)

*/

vars
	availableResourceGroups,
	mandatoryResourceGroups	: CM_ResourceTypeGroupByCode;
	resourceGroup			: CM_ResourceTypeGroup;
	wsResourceGroup			: WS_RestIntResourceTypeGroup;
	
begin
	availableResourceGroups := _availableResourceGroups;
	foreach resourceGroup in availableResourceGroups do
		create wsResourceGroup transient;
		wsResourceGroup.setProxyFromObject(resourceGroup);
		self.allResourceGroups.add(wsResourceGroup);
		_objectsToBeDeleted.add(wsResourceGroup);
		
	endforeach;
	
	mandatoryResourceGroups := _mandatoryResourceGroups;
	foreach resourceGroup in mandatoryResourceGroups do
		foreach wsResourceGroup in self.allResourceGroups do
			if wsResourceGroup.code = resourceGroup.code then
				break;
			endif;
		endforeach;
		
		if wsResourceGroup.code = resourceGroup.code then
			wsResourceGroup.isMandatory := true;
		else
			create wsResourceGroup transient;
			wsResourceGroup.setProxyFromObject(resourceGroup);
			wsResourceGroup.isMandatory := true;
			self.allResourceGroups.add(wsResourceGroup);
			_objectsToBeDeleted.add(wsResourceGroup);
		endif;
		
	endforeach;
	
end;</source>
        <Parameter name="_availableResourceGroups" type="CM_ResourceTypeGroupByCode"/>
        <Parameter name="_mandatoryResourceGroups" type="CM_ResourceTypeGroupByCode"/>
        <Parameter name="_objectsToBeDeleted" type="ObjectArray" usage="input"/>
    </JadeMethod>
</Class>
