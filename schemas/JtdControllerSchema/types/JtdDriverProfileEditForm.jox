    <JadeMethod name="mnuViewDefaultFont_click" id="34ee9f7f-33f2-4734-95d8-8f87f3d8b8a5">
        <controlMethod name="MenuItem::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mnuViewDefaultFont_click(menuItem: MenuItem input) updating;

begin
	tblMthProfiles.fontName := "Arial";
	tblMthProfiles.fontSize := 8.25;
	tblMthProfiles.fontBold := false;
	tblMthProfiles.fontItalic := false;
	tblMthProfiles.fontStrikethru := false;
	tblMthProfiles.fontUnderline := false;

	tblProlog.fontName := "Arial";
	tblProlog.fontSize := 8.25;
	tblProlog.fontBold := false;
	tblProlog.fontItalic := false;
	tblProlog.fontStrikethru := false;
	tblProlog.fontUnderline := false;

	tblEpilog.fontName := "Arial";
	tblEpilog.fontSize := 8.25;
	tblEpilog.fontBold := false;
	tblEpilog.fontItalic := false;
	tblEpilog.fontStrikethru := false;
	tblEpilog.fontUnderline := false;

	lstDrvProfiles.fontName := "Arial";
	lstDrvProfiles.fontSize := 8.25;
	lstDrvProfiles.fontBold := false;
	lstDrvProfiles.fontItalic := false;
	lstDrvProfiles.fontStrikethru := false;
	lstDrvProfiles.fontUnderline := false;

	lstMethods.fontName := "Arial";
	lstMethods.fontSize := 8.25;
	lstMethods.fontBold := false;
	lstMethods.fontItalic := false;
	lstMethods.fontStrikethru := false;
	lstMethods.fontUnderline := false;
end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="mnuViewSetFont_click" id="4d759399-34bf-4ed4-8344-774bfd9c6080">
        <controlMethod name="MenuItem::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mnuViewSetFont_click(menuItem: MenuItem input) updating;

vars
	f : CMDFont;
	
begin
	create f transient;

	f.showEffects := false;
	f.fontName := tblMthProfiles.fontName;
	f.fontSize := tblMthProfiles.fontSize;
	f.fontBold := tblMthProfiles.fontBold;
	f.fontItalic := tblMthProfiles.fontItalic;
	
	if f.open = 0 then
		tblMthProfiles.fontName := f.fontName;
		tblMthProfiles.fontSize := f.fontSize;
		tblMthProfiles.fontBold := f.fontBold;
		tblMthProfiles.fontItalic := f.fontItalic;
		tblMthProfiles.fontStrikethru := false;
		tblMthProfiles.fontUnderline := false;

		tblProlog.fontName := f.fontName;
		tblProlog.fontSize := f.fontSize;
		tblProlog.fontBold := f.fontBold;
		tblProlog.fontItalic := f.fontItalic;
		tblProlog.fontStrikethru := false;
		tblProlog.fontUnderline := false;

		tblEpilog.fontName := f.fontName;
		tblEpilog.fontSize := f.fontSize;
		tblEpilog.fontBold := f.fontBold;
		tblEpilog.fontItalic := f.fontItalic;
		tblEpilog.fontStrikethru := false;
		tblEpilog.fontUnderline := false;

		lstDrvProfiles.fontName := f.fontName;
		lstDrvProfiles.fontSize := f.fontSize;
		lstDrvProfiles.fontBold := f.fontBold;
		lstDrvProfiles.fontItalic := f.fontItalic;
		lstDrvProfiles.fontStrikethru := false;
		lstDrvProfiles.fontUnderline := false;

		lstMethods.fontName := f.fontName;
		lstMethods.fontSize := f.fontSize;
		lstMethods.fontBold := f.fontBold;
		lstMethods.fontItalic := f.fontItalic;
		lstMethods.fontStrikethru := false;
		lstMethods.fontUnderline := false;
	endif;

epilog
	delete f;
end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
