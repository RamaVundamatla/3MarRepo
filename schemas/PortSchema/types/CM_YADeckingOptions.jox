    <JadeMethod name="getRulesStr" id="cae189a5-a8a2-4333-9356-0428bd5f8557">
        <source>getRulesStr(pIsSortIn:Boolean): String;
//----------------------------------------------------------------
//	Created:	08 June 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	str		: String;
	offset	: Integer;
	rule	: CM_YADeckingRule;
	
begin
	if pIsSortIn then
		foreach rule in self.allDeckingRulesIn do
			offset	:=	app.getDeckingMenuIndexFromOption(rule.deckingRuleType);
			
			if str = null then
				str	:=	app.getDeckingInCaption(DeckingMenuOffset_In + offset);
			else
				str	:=	str &amp; ", " &amp; app.getDeckingInCaption(DeckingMenuOffset_In + offset);
			endif;
		endforeach;
	else
		foreach rule in self.allDeckingRulesOut do
			offset	:=	app.getDeckingMenuIndexFromOption(rule.deckingRuleType);
			
			if str = null then
				str	:=	app.getDeckingOutCaption(DeckingMenuOffset_Out + offset);
			else
				str	:=	str &amp; ", " &amp; app.getDeckingOutCaption(DeckingMenuOffset_Out + offset);
			endif;
		endforeach;
	endif;
	
	return str;
end;</source>
        <Parameter name="pIsSortIn" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
