    <JadeMethod name="resizeControls" id="38ffadfb-40d8-42d7-831a-b40854b2073d">
        <source>resizeControls();
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 June 2010	cnwer1	Initial creation
 17/08/2016 		cnwrh7	TFS	2501

*/
constants
	Margin = 5;
vars
	theHeight,
	theWidth,
	newTop 	: Integer;
	acceptCaption : String;
begin
	acceptCaption:=app.getErrorString(Accept);
	theHeight:=self.btnAccept.getTextHeight(acceptCaption);
	theHeight:= theHeight + (Margin *2);
	//ACCEPT &amp; REJECT BUTTONS should be same width;
	theWidth:=self.btnAccept.getTextExtent(acceptCaption).max(theWidth);
	theWidth:=self.btnAccept.getTextExtent(app.getErrorString(GetNext)).max(theWidth);
	theWidth:=self.btnAccept.getTextExtent(app.getErrorString(Pickup)).max(theWidth);
	theWidth:=self.btnAccept.getTextExtent(app.getErrorString(Setdown)).max(theWidth);
	theWidth:=self.btnAccept.getTextExtent(app.getErrorString(Complete)).max(theWidth);
	//return;
	// bottom frame buttons
	// don't have to set top position these are center aligned
	self.btnAccept.height:=theHeight;
	self.btnReject.height:=theHeight;
	self.btnMenu.height:=theHeight;
	self.btnGraphic.height:=theHeight;
	self.btnTaskMode.height:=theHeight;
	self.btnVoyDischarge.height:=theHeight;
	self.btnGraphicView.height:=theHeight;
	self.btnGetWeight.height := theHeight;				//+TFS2501
	self.btnSaveWeight.height := theHeight;			//+TFS2501

	
	self.frmBottom.height:=theHeight + (Margin *2);
	
	//buttons on the move frame that might appear;
	self.btnRejectTask.height:=theHeight;
	self.btnRejectTwin.height:=theHeight;
	self.btnSwap.height:=theHeight;
	self.btnICSource.height:=theHeight;
	self.btnICTarget.height:=theHeight;
	self.btnNextTask.height:=theHeight;
	self.btnPrevTask.height:=theHeight;
	self.btnIC.height:=theHeight;
	
	
	
	//epr CCMS HAT 2200 26/10/12
	//buttons on the top frame
	// set top because these are bottom aligned
	self.btnTandem.height:=theHeight;
	newTop:=self.frmTop.clientHeight - theHeight - Margin;
	self.btnTandem.top:=newTop;
	self.btnSearchTwin.height:=theHeight;
	self.btnSearchTwin.top:=newTop;
	self.btnSearch.height:=theHeight;
	self.btnSearch.top:=newTop;
	self.btnSearchReset.height:=theHeight;
	self.btnSearchReset.top:=newTop;
	self.txtSearch.height:=theHeight;
	self.txtSearch.top:=newTop;
	
	self.frmTop.height:=lblCaption.top + lblCaption.clientHeight + theHeight + (Margin *2);
	//epr par 33141 11/12/13
	self.lblInfo.height:=self.frmTop.height;
	self.lblInfo.top:=0;
	
	theWidth:=theWidth + (Margin *2);
	if theWidth &lt;&gt; self.btnAccept.clientWidth then
		self.btnAccept.width:=theWidth;
		self.btnReject.width:=theWidth;
		self.btnGetWeight.width := theWidth +20;			//+TFS2501
		self.btnSaveWeight.width := theWidth +20;			//+TFS2501
		self.btnReject.left:=self.btnAccept.left+theWidth + Margin;
		self.btnGetWeight.left :=self.btnSaveWeight.left + theWidth + Margin;			//+TFS2501
		self.btnSaveWeight.left :=self.btnReject.left + theWidth + Margin;						//+TFS2501
		self.btnRejectTask.width:=theWidth;
		self.btnRejectTwin.width:=theWidth;
	endif;
	//GRAPHIC, TASK MODE, &amp; MENU btns should be same width
	theWidth:=0;
	if self.btnTaskMode.visible then
		theWidth:=self.btnTaskMode.getTextExtent(app.getErrorString(List_mode)).max(theWidth);
		theWidth:=self.btnTaskMode.getTextExtent(app.getErrorString(Get_mode)).max(theWidth);
	endif;
	if self.btnGraphic.visible then
		theWidth:=self.btnTaskMode.getTextExtent(app.getErrorString(Graphic)).max(theWidth);
		theWidth:=self.btnTaskMode.getTextExtent(app.getErrorString(SwitchView)).max(theWidth);
		theWidth:=self.btnTaskMode.getTextExtent(app.getErrorString(Details)).max(theWidth);
	endif;
	
	theWidth:=self.btnTaskMode.getTextExtent(self.btnMenu.caption).max(theWidth);
	theWidth:= self.btnTaskMode.getTextExtent(app.getErrorString(Discharge)).max(theWidth);
	theWidth:=theWidth + (Margin *2);
	
	if theWidth &lt;&gt; self.btnTaskMode.clientWidth then
		self.btnMenu.width:=theWidth;
		self.btnGraphic.width:=theWidth;
		self.btnTaskMode.width:=theWidth;
		self.btnVoyDischarge.width:= theWidth;
		self.btnGraphicView.width:= theWidth;
		
		self.btnMenu.left:=self.clientWidth - theWidth - Margin;
		self.btnGraphic.left:=self.btnMenu.left- theWidth - Margin;
		self.btnGraphicView.left:=self.btnGraphic.left- theWidth - Margin;
		
		self.repositionButtons();
	endif;
	
	
	//self.btnTandem.fontSize:=10;
	//self.btnSearchTwin.fontSize:=10;
	theWidth:=0;
	theWidth:=self.btnTandem.getTextExtent(app.getErrorString(CM_Twin)).max(theWidth);
	theWidth:=self.btnTandem.getTextExtent(app.getErrorString(Tandem)).max(theWidth);
	theWidth:=theWidth + (Margin *2) + 20;		//+cnwml2 PAR26293
	self.btnTandem.width:=theWidth;
	self.btnSearchTwin.width:=theWidth;
	
	
	theWidth:=0;
	theWidth:=self.btnIC.getTextExtent(app.getErrorString(Pick_interchange));
	theWidth:=theWidth + (Margin *2);
	if theWidth &lt;&gt; self.btnIC.clientWidth then
		self.btnIC.width:=theWidth;
	endif;
	
	theWidth:=0;
	theWidth:=self.btnICSource.getTextExtent(self.btnICSource.caption).max(theWidth);
	theWidth:=self.btnICTarget.getTextExtent(self.btnICTarget.caption).max(theWidth);
	theWidth:=theWidth + (Margin *2);
	if theWidth &lt;&gt; self.btnIC.clientWidth then
		self.btnICSource.width:=theWidth;
		self.btnICTarget.width:=theWidth;
		self.btnICTarget.left:=self.btnICSource.left + self.btnICSource.clientWidth + Margin;
		self.grpICFrom.height:=self.btnICSource.clientHeight;
		self.grpICFrom.width:=theWidth * 2 + Margin;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="resizeForGfxButtonsLandscape" id="f581435d-0de5-4bb2-94cc-6d5b4818cbbf">
        <source>resizeForGfxButtonsLandscape() protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 June 2010	cnwjk3	Initial creation

*/

vars
	frmMoveEntryWidth, 

	frmGraphicWidth, 
	parentClientWidth,
	frmGraphicHeight, 
	parentClientHeight : Integer;
begin

	parentClientWidth := self.frmMove.clientWidth();
	parentClientHeight := self.frmMove.clientHeight() - GFX_ButtonHeight;
	frmMoveEntryWidth := (PercentMoveEntry/100 * parentClientWidth).Integer;
	frmGraphicWidth := (PercentGraphic/100 * parentClientWidth).Integer;
	
	
	// Move and rezsize the graphic frame accordingly
	self.frmGraphic.left := 0;
	self.frmGraphic.width := frmGraphicWidth;
	self.frmGraphic.top := GFX_ButtonHeight;
	self.frmGraphic.height := parentClientHeight;

	// Move and rezsize the move entry frame accordingly
	self.resizeFrmMoveEntry(frmGraphicWidth,frmMoveEntryWidth);
	// Now the button frame
	self.resizeButtonsFrameLandscape();	
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="resizeForGfxButtonsPortrait" id="315d33db-2bd4-422b-8dca-c479d5362a4f">
        <source>resizeForGfxButtonsPortrait() protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 June 2010	cnwjk3	Initial creation

*/

vars
	frmMoveEntryWidth, 
	frmGraphicWidth, 
	parentClientWidth : Integer;
begin
	
	parentClientWidth := self.frmMove.clientWidth() - GFX_ButtonWidth;
	frmMoveEntryWidth := (PercentMoveEntry/100 * parentClientWidth).Integer;
	frmGraphicWidth := (PercentGraphic/100 * parentClientWidth).Integer;
	
	
	// Move and rezsize the graphic frame accordingly
	self.frmGraphic.left := GFX_ButtonWidth;
	self.frmGraphic.width := frmGraphicWidth;
	self.frmGraphic.top := 0;
	self.frmGraphic.height := self.frmMove.height;

	// Move and rezsize the move entry frame accordingly
	self.resizeFrmMoveEntry(frmGraphicWidth,frmMoveEntryWidth+ GFX_ButtonWidth);

	// Now the button frame
	self.resizeButtonsFramePortrait();
			
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="resizeForNoGraphics" id="218a943c-f55b-4f70-9480-d9e24077daa8">
        <source>resizeForNoGraphics() protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 June 2010	cnwjk3	Initial creation

*/


vars
	frmMoveEntryWidth, 
	frmGraphicWidth, 
	parentClientWidth : Integer;
begin
	// We are resizing the graphics frame here purely so that frmMoveTbl resizes along with it	
	parentClientWidth := self.frmMove.clientWidth();
	if self.isOnNarrowScreen or (app.myVMAgent.getMyRTVehicleConfig.canRemoveSplitScreen) then
		frmMoveEntryWidth:=parentClientWidth;
		frmGraphicWidth:=0;
		self.frmViewport.visible:=false;
	else
		frmMoveEntryWidth := (PercentMoveEntry/100 * parentClientWidth).Integer;
		frmGraphicWidth := (PercentGraphic/100 * parentClientWidth).Integer;
		
		// Move and rezsize the graphic frame accordingly
		self.frmGraphic.left := 0;
		self.frmGraphic.width := frmGraphicWidth;
		self.frmGraphic.top := 0;
		self.frmGraphic.height := self.frmMove.clientHeight;
	endif;
	// Move and rezsize the move entry frame accordingly
	self.resizeFrmMoveEntry(frmGraphicWidth,frmMoveEntryWidth);
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="resizeFrmMoveEntry" id="e14620fd-75da-4115-b27a-6c874a4a4dd1">
        <source>resizeFrmMoveEntry(_left,_width : Integer) protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 June 2010	cnwer1	Initial creation

*/

vars

begin
	self.frmMoveEntry.left := _left;
	self.frmMoveEntry.width := _width;
	self.frmMoveEntry.top := 0;
	self.frmMoveEntry.height := self.frmMove.clientHeight;
	self.tblMoveEntry.width:=_width;
