    <JadeMethod name="doSave" id="46140a0a-65f0-4c67-b9a1-fe50ed8554b4">
        <updating/>
        <source>doSave(): Boolean updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 July 2011	cnwndl1	Initial creation	Par 27890

*/

vars

	theForm : SOP_TableMaintForm;
	lColour : Integer;
	lLower : Integer;
	lUpper : Integer;
	pxyDwellDayRange : CM_DwellDayRange;
	rtnValue : Boolean;

begin
	
	theForm := self.myForm;
	 
	lColour := theForm.tblInput1.getValueByName(ETRow_Colour).Integer;
	lLower := theForm.tblInput1.getValueByName(ETRow_Lower).Integer;
	lUpper := theForm.tblInput1.getValueByName(ETRow_Upper).Integer;
	
	if theForm.myProxyObject = null then
		if theForm.mode = theForm.Mode_Add then
			create theForm.myProxyObject as CM_DwellDayRange transient;
		else
			app.raiseUnexpectedProgramError(class.name, method.name, app.getErrorString(Proxy_Object_Null_For_Update));
			return false;
		endif;
	endif;
	
	pxyDwellDayRange := theForm.myProxyObject.CM_DwellDayRange;
	pxyDwellDayRange.setProxy(lColour, lLower, lUpper );
	
	if theForm.mode = theForm.Mode_Add then
		app.myTrxCA.trxCreateDwellDayRange(pxyDwellDayRange, theForm.myCurrentObject, app.myPassport);
		rtnValue := app.myPassport.trxCompletedOK;
	elseif theForm.mode = theForm.Mode_Update then
		app.myTrxUA.trxUpdateDwellDayRange(pxyDwellDayRange, app.myPassport);
		rtnValue := app.myPassport.trxCompletedOK;
	else
		app.raiseUnexpectedProgramError(class.name, method.name, '  Invalid mode (' &amp; theForm.mode.String &amp; ')');
		return false;
	endif;
	return rtnValue;
	

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
