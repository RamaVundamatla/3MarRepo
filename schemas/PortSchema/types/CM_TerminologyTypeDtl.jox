    <JadeMethod name="setForUpdate" id="d2222d0c-6241-4414-98cc-617a3f5346d9">
        <updating/>
        <source>setForUpdate(_pxyTermTypeDtl : CM_TerminologyTypeDtl; _termType : CM_TerminologyType) updating;
// ---------------------------------------------------------------------------
// Created:     06 August 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin
	self.groupName 		:= _pxyTermTypeDtl.groupName;
	self.rowName 		:= _pxyTermTypeDtl.rowName;
	self.myTerminologyType := _termType;
	self.systemEntRowHeading := _pxyTermTypeDtl.systemEntRowHeading;
	self.systemEntRowShortHeading := _pxyTermTypeDtl.systemEntRowShortHeading;
	
end;</source>
        <Parameter name="_pxyTermTypeDtl" type="CM_TerminologyTypeDtl"/>
        <Parameter name="_termType" type="CM_TerminologyType"/>
    </JadeMethod>
    <JadeMethod name="setMyTerminologyType" id="774954c3-b9b0-4c63-ac47-323b426f40f8">
        <updating/>
        <source>setMyTerminologyType(_termType : CM_TerminologyType) updating;
// ---------------------------------------------------------------------------
// Created:     06 August 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin
	self.myTerminologyType := _termType;

end;</source>
        <Parameter name="_termType" type="CM_TerminologyType"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="b874e109-4e0b-4b2e-a69c-f283962e55cb">
        <updating/>
        <source>setProxy(_groupName, _rowName : String; _termType : CM_TerminologyType) updating;
// ---------------------------------------------------------------------------
// Created:     06 August 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	entTableGroup		: EntTableGroup;
	entTableRow			: EntTableRow;
begin
	self.groupName := _groupName;
	self.rowName := _rowName;
	self.myTerminologyType := _termType;
	
	//set the default heading from the corresponding entRow's headings if we can find it
	entTableGroup := app.myRoot.myEntTableDataRoot.allEntTableGroups[self.groupName];
	if entTableGroup &lt;&gt; null then
		entTableRow := entTableGroup.allEntTableRowsByName[self.rowName];
		if entTableRow &lt;&gt; null then
			//never pass anything through to getHeading here, we want the unaltered value
			self.systemEntRowHeading := entTableRow.getHeadingUnaltered();
			self.systemEntRowShortHeading := entTableRow.getShortHeadingUnaltered();
			return;
		endif;
	endif;
	
	//if we can't find the row in the system, make the system heading say so, but keep going
	if self.systemEntRowHeading = null then
		self.systemEntRowHeading := 'FAILED TO RESOLVE'; 
	endif;
	
end;</source>
        <Parameter name="_groupName" type="String"/>
        <Parameter name="_rowName" type="String"/>
        <Parameter name="_termType" type="CM_TerminologyType"/>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="ccf0bb75-cd99-47e6-97c8-ac8bb6c91f0a">
        <source>validateForUpdate();
// ---------------------------------------------------------------------------
// Created:     06 August 2004	cnwth2
//
// Purpose:     
//27/06/2022 		NAVDS20 			TFS 53760  DuplicateItem not Translatable		 
// ----------   ----------  --------------------------------------------------
vars
	existingTypeDtl,
	realTermTypeDtl				: CM_TerminologyTypeDtl;
	realTermType			: CM_TerminologyType;
	
begin
	if self.rowName = null then
//		app.raiseCMException1(REQUIRED_FIELD,'rowName', 'rowName', null);
		app.raiseCMException(Input_required_field_rowName, 'rowName', null); // cnwdb2	PAR 35364
	endif;

	if self.groupName = null then
	//	app.raiseCMException1(REQUIRED_FIELD,'groupName', 'groupName', null);
		app.raiseCMException(Input_required_field_groupName, 'groupName', null); // cnwdb2	PAR 35364
	endif;
	
	realTermTypeDtl := self.pxyGetRealObject();
	if realTermTypeDtl &lt;&gt; null then //we're updating
		existingTypeDtl := realTermTypeDtl.myTerminologyType.allTerminologyTypeDtls[self.groupName, self.rowName];
		if ((existingTypeDtl &lt;&gt; null) and (existingTypeDtl &lt;&gt; realTermTypeDtl)) then 
			//app.raiseCMException2(DuplicateItem, 'Terminology Type Dtl: ' &amp; self.groupName &amp; '/' &amp; self.rowName, 'Terminology Type', null, null);  //27/06/2022 NAVDS20 TFS 53760
			// Terminology Type Dtl: %1 / %2 already exists for Terminology Type : Termi_type_alrea_exist_termi_t
			app.raiseCMException2(Termi_type_alrea_exist_termi_t, self.groupName , self.rowName , null, null); //27/06/2022 NAVDS20 TFS 53760
		endif;
	else //we're creating 
		realTermType := self.myTerminologyType.pxyGetRealObject();
		if realTermType &lt;&gt; null and realTermType.allTerminologyTypeDtls[self.groupName, self.rowName] &lt;&gt; null then
			//app.raiseCMException2(DuplicateItem, 'Terminology Type Dtl: ' &amp; self.groupName &amp; '/' &amp; self.rowName, 'Terminology Type', null, null); //27/06/2022 NAVDS20 TFS 53760
			// Terminology Type Dtl: %1 / %2 already exists for Terminology Type : Termi_type_alrea_exist_termi_t
			app.raiseCMException2(Termi_type_alrea_exist_termi_t,  self.groupName , self.rowName, null, null);  //27/06/2022 NAVDS20 TFS 53760
		endif; 
	endif;
	
end;</source>
    </JadeMethod>
</Class>
