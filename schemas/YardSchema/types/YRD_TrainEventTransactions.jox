    <JadeMethod name="doBaseFormCancel" id="fbbed74d-3506-402d-afc5-92be71575ed1">
        <updating/>
        <source>doBaseFormCancel() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06 November 2009	cnwndl1	Initial creation	Par 21519

*/

vars

begin

	if	self.tblEvents.selectedCount = 0 then
		if not btnSaveBase.enabled then
			self.unloadForm();
			return;
		endif;
	endif;

	inheritMethod();
	
	self.clearEditControls();

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doBaseFormSave" id="dbe2bdce-cda9-4f18-ba1b-c7af00d49bdf">
        <updating/>
        <source>doBaseFormSave() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06 November 2009	cnwndl1	Initial creation	Par 21519

*/

vars

	allPreWarnings : HugeStringArray;
	warning : String;
	eventType : CM_EventType;
	date : Date;
	time : Time;
	timeStamp : TimeStamp;
	isCreate : Boolean;
	charge : Boolean;
	noCharge : Boolean;
	realTransaction : CM_EventTransaction;
	result : Integer;
	theResult : Integer;	//15 Jan 2020 NDL	TFS 46815
	
begin

	if cmbEventType.listIndex &gt; 0 then
		eventType := self.cmbEventType.itemObject[self.cmbEventType.listIndex].CM_EventType;
	endif;
	
	create allPreWarnings transient;
	if eventType = null then
		warning := app.getErrorString(Must_select_event_type);
		allPreWarnings.add(warning);
	endif;
	if self.myTrain = null then
		warning := app.getErrorString(Error) &amp; " - " &amp; app.getErrorString(No_train_assoc_form);
		allPreWarnings.add(warning);
	endif;
	if not allPreWarnings.isEmpty then
		app.showErrorWarningDialogArray(app.getErrorString(Train_event_update), allPreWarnings, null, ErrWarnMode_CanAckWarnings);
		return;
	endif;
	
	date := self.txtDate.getDate;
	time := self.txtTime.getTime;
	timeStamp.setDate(date);
	timeStamp.setTime(time);
	charge := cmbCharge.itemData[cmbCharge.listIndex].Boolean;
	noCharge := not charge;

	if self.myProxyObject = null then
		isCreate := true;
		create self.myProxyObject as eventType.myClassToCreate transient;
		charge := cmbCharge.itemData[cmbCharge.listIndex].Boolean;
	endif;
	self.myProxyObject.CM_EventTransaction.setDetails(	eventType,	//_eventType 	: CM_EventType;
														timeStamp,	//_dateTime 	: TimeStamp;
														myTrain.getTerminal,	//_terminal 	: CM_Terminal;
														app.myPassport.myUser.code,	//_userCode	: String;
														noCharge	// _noCharge : Boolean
														,0);
	
	
	//15 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		if isCreate then
			app.myTrxCA.trxCreateTrainEvent(myProxyObject.CM_EventTransaction, realTransaction, self.myTrain, app.myPassport);
		else
			app.myTrxUA.trxUpdateTrainEvent(myProxyObject.CM_EventTransaction, app.myPassport);
		endif;
	
		if app.myPassport.trxCompletedOK then
			break;
		else
			theResult := app.showErrorWarningDialog(app.getErrorString(Train_event_update), app.myPassport, ErrWarnMode_Add + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		delete self.myProxyObject;
		return;
		
	endwhile;
	
	self.clearEditControls();
	self.loadTblEvents();

epilog

	delete allPreWarnings;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doMnuContextBuildTblTrans" id="cf4121af-4ab5-4b4f-990e-0a20106e5002">
        <source>doMnuContextBuildTblTrans(table: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean;


/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06 November 2009	cnwndl1	Initial creation	Par 21519

*/

vars
	anObject 	: Object;
	hasObject : Boolean;
begin
	anObject :=  table.accessRow(table.row).itemObject;
	if app.isValidObject(anObject) then
		self.mnuInspectObject.visible := self.mnuInspectObject.userObject &lt;&gt; null and app.isAllowedToInspect();
	endif;

	self.mnuColumnOrganiser.visible := true; 
	
	return true;
	
epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
