    <JadeMethod name="getGapWidthPixels" id="b707b5b0-ae72-4763-9cd5-1e9e45da990f">
        <source>getGapWidthPixels(_gridWidth: Real): Real;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 October 2010	#cnwdz2	 

*/

vars

begin
	
	return _gridWidth/7 * self.width;

epilog

end;</source>
