        <controlMethod name="Table::resizeColumn"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblNNCargoInfo_resizeColumn(table: CM_DataTable input; column: Integer input; previousWidth: Integer input) updating;
