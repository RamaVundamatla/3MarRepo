<Class name="JadeScript">
    <JadeMethod name="mmFooTest" id="edaf81f3-8130-433c-900d-f8c7dba39b36">
        <source>mmFooTest();

vars
mmProxy   : MoinMoinProxy;
success   : Boolean;
pageContent : String;
attachmentContent : String;
errormsg : String;
form : PasswordForm;
pw : String;
user : String;

begin 
    success := true;
    create mmProxy transient;
     

    write "Test #4: Log in for real.";
    errormsg := "";
    create form transient; 
    form.ok := false;
    form.txtUserName.text := 'cnwwikijmt';
    form.showModal();
    if false = form.ok
    then
        success := false;
        write "User cancelled password dialog. STOP.";
        return;
    else
        pw := 'XpAR6YmT';//form.txtPassword.text;
        user := form.txtUserName.text;
    endif; 
    if( false = mmProxy.getAuthToken( 'wiki.cnw.co.nz', user, pw, errormsg ) )
    then
        write "Unable to get Authentication token.";
        success := false;
    endif;
    if( "" &lt;&gt; errormsg ) 
    then
        write "getAuthToken : Warning from server : " &amp; errormsg;
    endif;    

    
    if success then 
        write "- - - MoinMoinProxy test successful !!!";
    else
        write "- - - MoinMoinProxy test FAILED - - -";
    endif;

epilog
    delete mmProxy;
    delete form;
end;
</source>
    </JadeMethod>
    <JadeMethod name="mmProxyTest" id="1716ea50-b2d7-4529-94d3-3d4f84c60961">
        <source>mmProxyTest();

vars
mmProxy   : MoinMoinProxy;
success   : Boolean;
pageContent : String;
attachmentContent : String;
errormsg : String;
form : PasswordForm;
pw : String;
user : String;

begin 
    success := true;
    create mmProxy transient;
     
    write "Test #1: Try logging in with a bogus password.";
    errormsg := "";
    
    if( false = mmProxy.getAuthToken( 'testwiki.cnw.co.nz', 'cnwwikijmt', 'bogus', errormsg ) )
    then
        write "Unable to get Authentication token (as expected).";
    else
        success := false; // We expect this to fail
    endif;
    if( "" &lt;&gt; errormsg ) 
    then
        write "getAuthToken : Warning from server : " &amp; errormsg; 
    endif;

    write "Test #2: Try to put a page with no authentication token.";
    errormsg := "";
    if( false = mmProxy.putPage( 'AbcPage', '= header 1 =', errormsg ) )
    then
        write "Unable to put the page (as expected).";       
    else
        success := false; // We expect this to fail
    endif;
    if( "" &lt;&gt; errormsg ) 
    then
        write "putPage : Warning from server : " &amp; errormsg;
    endif;

    write "Test #3: Try to get a page with no authentication token.";
    errormsg := "";
    if( false = mmProxy.getPage( 'AbcPage', pageContent, errormsg ) )
    then
        write "Unable to get the page (as expected).";       
    else
        success := false; // We expect this to fail
    endif;
    if( "" &lt;&gt; errormsg ) 
    then
        write "getPage : Warning from server : " &amp; errormsg;
    endif;    

    write "Test #4: Log in for real.";
    errormsg := "";
    create form transient; 
    form.ok := false;
    form.txtUserName.text := 'cnwwikijmt';
    form.showModal();
    if false = form.ok
    then
        success := false;
        write "User cancelled password dialog. STOP.";
        return;
    else
        pw := 'XpAR6YmT';//form.txtPassword.text;
        user := form.txtUserName.text;
    endif; 
    if( false = mmProxy.getAuthToken( 'testwiki.cnw.co.nz', user, pw, errormsg ) )
    then
        write "Unable to get Authentication token.";
        success := false;
    endif;
    if( "" &lt;&gt; errormsg ) 
    then
        write "getAuthToken : Warning from server : " &amp; errormsg;
    endif;    

    write "Test #5: Put a page, should work this time.";
    errormsg := "";
    if( false = mmProxy.putPage( 'AbcPage', '= header 1 =', errormsg ) )
    then
        write "Unable to put the page.";       
        success := false; 
    endif;
    if( "" &lt;&gt; errormsg ) 
    then
        write "putPage : Warning from server : " &amp; errormsg;
    endif;
    
    write "Test #6: Get a page, should work this time.";
    errormsg := "";
    if( false = mmProxy.getPage( 'AbcPage', pageContent, errormsg ) )
    then
        write "Unable to get the page.";       
        success := false;
    endif;
    if( "" &lt;&gt; errormsg ) 
    then
        write "getPage : Warning from server : " &amp; errormsg;
    endif;    
    
    write "Test #7: Put back the same page, should get a warning.";
    errormsg := "";
    if( false = mmProxy.putPage( 'AbcPage', pageContent, errormsg ) )
    then
        write "Unable to put the page.";       
        success := false;
    endif;
    if( "" &lt;&gt; errormsg ) 
    then
        write "putPage : Warning from server : " &amp; errormsg;
    endif;

    write "Test #8: Upload an attachment. Oops wrong name";
    errormsg := "";
    if( false = mmProxy.putAttachment( 'AbcPage', 'C:\Documents and Settings\cnwdl1\Desktop\tst.txt', errormsg))
    then
        write "Unable to upload attachment (as expected).";  
    else
        success := false; // We expect this to fail
    endif;
    if( "" &lt;&gt; errormsg ) 
    then
        write "putAttachment : Warning from server : " &amp; errormsg;
    endif;

    write "Test #9: Upload an attachment.";
    errormsg := "";
    if( false = mmProxy.putAttachment( 'AbcPage', 'C:\Documents and Settings\cnwdl1\Desktop\test.txt', errormsg))
    then
        write "Unable to upload attachment.";       
        success := false;
    endif;
    if( "" &lt;&gt; errormsg ) 
    then
        write "putAttachment : Warning from server : " &amp; errormsg;
    endif;

    write "Test #10: Add a line to the page and put it back.";
    pageContent := pageContent &amp; CrLf &amp; "&lt;&lt;BR&gt;&gt;" &amp; CrLf &amp; "{{attachment:test.txt}}";
    errormsg := "";
    if( false = mmProxy.putPage( 'AbcPage', pageContent, errormsg ) )
    then
        write "Unable to put the page.";       
        success := false;
    endif;
    if( "" &lt;&gt; errormsg ) 
    then
        write "putPage : Warning from server : " &amp; errormsg;
    endif;
    
    write "Test #11: Read the attachment.";
    errormsg := "";
    attachmentContent := "";
    if( false = mmProxy.getAttachment( 'AbcPage', 'test.txt', attachmentContent, errormsg ) )
    then
        write "Unable to get Attachment.";       
        success := false;
    else
        write "Attachment content : " &amp; attachmentContent;
    endif;
    if( "" &lt;&gt; errormsg ) 
    then
        write "getAttachment : Warning from server : " &amp; errormsg;
    endif;
    
    write "Test #12: Read the attachment, oops wrong name.";
    errormsg := "";
    attachmentContent := "";
    if( false = mmProxy.getAttachment( 'AbcPage', 'tst.txt', attachmentContent, errormsg ) )
    then
        write "Unable to get Attachment (as expected).";       
    else
        success := false; // We expect this to fail
    endif;
    if( "" &lt;&gt; errormsg ) 
    then
        write "getAttachment : Warning from server : " &amp; errormsg;
    endif;    
  
    write "Test #12: Be nice to MoinMoin - delete the token.";
    errormsg := "";
    if( false = mmProxy.deleteAuthToken( errormsg) )
    then
        write "Unable to delete Authentication token.";
        success := false;       
    endif;
    if( "" &lt;&gt; errormsg ) 
    then
        write "deleteAuthToken : Warning from server : " &amp; errormsg;
    endif;
    
    if success then 
        write "- - - MoinMoinProxy test successful !!!";
    else
        write "- - - MoinMoinProxy test FAILED - - -";
    endif;

epilog
    delete mmProxy;
    delete form;
end;
</source>
    </JadeMethod>
</Class>
