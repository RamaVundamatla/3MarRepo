    <JadeMethod name="handleDateCellLostFocus" id="e3ada337-6ff1-4735-9886-81a4d880dc5c">
        <updating/>
        <source>handleDateCellLostFocus(_row, _col : Integer) updating;
// ---------------------------------------------------------------------------
// Created:     12 April 2005 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpCell	: JadeTableCell;
	tmpDate	: Date;
begin
	if _row &lt;= 0 or _row &gt; self.rows or
	   _col &lt;= 0 or _col &gt; self.columns then
	   	return;
	endif;
	tmpCell := self.accessCell(_row, _col);
	if tmpCell.inputType &lt;&gt; self.InputType_EditMask then
		return;
	endif;
	if tmpCell.editMask &lt;&gt; app.getDateEditMaskForShortFormat() then
		return;
	endif;
	tmpDate := tmpCell.text.asDateJMT();
	if tmpDate.isValid then
		tmpCell.text := tmpDate.shortFormatJMT();
	endif;

end;</source>
        <Parameter name="_row" type="Integer"/>
        <Parameter name="_col" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="initCellForDate" id="c1d1e86c-e65e-43c1-a7b7-9c32a9746be6">
