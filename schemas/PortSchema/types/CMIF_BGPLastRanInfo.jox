    <JadeMethod name="getDetails" id="16a9f9ad-e4d7-4e1f-8b75-4ff51a86fa30">
        <source>getDetails() : String;
// -------------------------------------------
// Created 16 February 2006 by cnwdvb1
// -------------------------------------------
/* Get those details */
vars


begin

	return 
	
	'Task ' &amp; self.niceName &amp;
	' has not run successfully since ' &amp; self.lastRanTs.shortCurrentLocaleFormat();

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="initializeInfo" id="903dd506-59b0-44bd-aa3f-3b6f947faf79">
        <updating/>
        <source>initializeInfo(_className, _niceName : String; _numberOfMinutes, _alertFrequency : Integer; _webSiteConfigName : String;  _agent : CM_AutoWarningAgent input) updating;
// -------------------------------------------
// Created 15 February 2006 by cnwdvb1
// -------------------------------------------
vars

begin


	// Set up the info with all relevant information.
	self.requestClassName	:= _className;
	self.numberOfMinutes	:= _numberOfMinutes;
	self.alertFrequency		:= _alertFrequency;
	self.lastRanTs			:= app.actualTimeServer();
	self.niceName			:= _niceName[1:30];
	self.webSiteConfigName	:= _webSiteConfigName;
	
	self.myAutoWarningAgent	:= _agent;


end;</source>
        <Parameter name="_className" type="String"/>
        <Parameter name="_niceName" type="String"/>
        <Parameter name="_numberOfMinutes" type="Integer"/>
        <Parameter name="_alertFrequency" type="Integer"/>
        <Parameter name="_webSiteConfigName" type="String"/>
        <Parameter name="_agent" type="CM_AutoWarningAgent" usage="input"/>
    </JadeMethod>
    <JadeMethod name="isOutOfScope" id="5b7fd980-8e9f-47e4-ab53-be8c43e4b1e5">
        <updating/>
        <source>isOutOfScope(_now	: TimeStamp) : Boolean updating;
// -------------------------------------------
// Created 16 February 2006 by cnwdvb1
// -------------------------------------------
vars


begin

	// If last run plus minutes allowed is less than now, then we've got a problem.
	
	// Specific web docs website functionality
	if self.webSiteConfigName &lt;&gt; null and self.requestClassName = CM_WebSiteConfig.name then
		return self.isOutOfScopeWeb(_now);
	endif;
	
	return self.lastRanTs.cnEcAddMinutes(self.numberOfMinutes) &lt; _now;

end;</source>
        <Parameter name="_now" type="TimeStamp"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isOutOfScopeWeb" id="8907a9c8-da68-47c3-bce4-57267ffd8d1c">
        <updating/>
        <source>isOutOfScopeWeb(_now : TimeStamp) : Boolean protected, updating;

// Created by cnwdvb1 on 11 July 2007

vars

	str	,
	webSite,
	page		: String;
	result  	: Boolean;
	webConfig	: CM_WebSiteConfig;
	
	
begin

	// Do we need to check.
	if self.lastRanTs.cnEcAddMinutes(self.numberOfMinutes) &gt; _now then
		return false;
	endif;
	
	webConfig := app.myRoot.allWebSiteConfigs[self.webSiteConfigName];
	
	if webConfig = null then
		app.remoteErrorWarningToAlert('Web Config (' &amp; self.webSiteConfigName &amp; ') not located', null, null, null, true, true);
		return false;
	endif;
	
	// Get details of page from website config.
	webSite := 'http://' &amp; webConfig.machineName &amp; '/' &amp; webConfig.virtualDirectory &amp; '/';
	
	app.writeLog(webSite, LogINFO);
	
	page	:= 'jadehttp.dll?'  &amp; webConfig.webApplicationName &amp; '&amp;_jadeReferenceClass=JMTIsRunning';
	
	app.writeLog(page, LogINFO);
	
	//str := self.runWebClient('http://cnwdvb1a/dmast/', 'jadehttp.dll?WebExampleApp&amp;_jadeReferenceClass=JMTIsRunning');
	// Call web page.
	str := self.runWebClient(webSite, page);
	
	result := str.pos('&lt;-- Success --&gt;', 1) &lt;&gt; 0;
	
	if result then
		self.lastRanTs := _now;
		app.writeLog('Success ' &amp; _now.String, LogINFO);
	else
		app.writeLog('Failed', LogINFO);
		app.writeLog(str, LogINFO);
	endif;
	
	return not result;

end;</source>
        <access>protected</access>
        <Parameter name="_now" type="TimeStamp"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="runWebClient" id="ed49de2c-c184-4272-8226-9bf9ecdc89fa">
        <source>runWebClient(_webSite, _page : String) : String protected;

// Created by cnwdvb1 on 11 July 2007

constants

	INTERNET_CONSTANT = #80000100;
	INTERNET_REQUEST_CONSTANT = #4080000;
	Buffer_Size : Integer = 4096;
 
vars
 
	bRet, bln : Boolean;
	buffer : String [ Buffer_Size ];
	result : String;
	bytesRead : Integer;
	str : String;
	internetHandle  : Integer;
	requestHandle : Integer;
	httpHandle  : Integer;
	openURLHandle   : Integer;
  
begin
 
 
 
	internetHandle := call internetOpen("JMT", 0, "", "", 0);
 	httpHandle := call internetConnect(internetHandle, _webSite, 80, '', '', 3, 0, 0);
	openURLHandle := call internetOpenUrl( internetHandle, _webSite &amp; _page, "", 0, 0, 0);
 
	buffer := null;
	//while true do
	bRet := call internetReadFile(openURLHandle, buffer, Buffer_Size, bytesRead);
	result := result &amp; buffer[1:bytesRead];
		//if bytesRead &lt;&gt; Buffer_Size then
		//	break;
		//endif;
	//endwhile;
	

	return result;
end;</source>
        <access>protected</access>
        <Parameter name="_webSite" type="String"/>
        <Parameter name="_page" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="updateLastRanTs" id="5a598046-a873-4c8a-8c8a-c3a7717eef56">
        <updating/>
        <source>updateLastRanTs() updating;
// -------------------------------------------
// Created 15 February 2006 by cnwdvb1
// -------------------------------------------
vars

begin

	// Update the last ran and turn is alerted off.
	self.lastRanTs	:= app.actualTimeServer();
	self.isAlerted	:= false;
end;</source>
    </JadeMethod>
</Class>
