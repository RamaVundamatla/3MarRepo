    <JadeMethod name="doNext" id="79440857-9fbf-40dc-9744-bd17613bfded">
        <updating/>
        <source>doNext( errMsg : String output):Boolean updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 February 2010	cnwndl1	Initial creation	CCMS MES 1005

*/

vars

	voyage : CM_Voyage;
	
begin

	self.myMobileGenericAgent.setMyVoyage(null);
	self.myMobileGenericAgent.setChecksState(0);
	
	voyage := self.cmbVoyage.listObject.CM_Voyage;
	if voyage = null then
		errMsg := self.lblVoyage.caption;
		return false;
	endif;
	
	if not self.optDischarge.value and not self.optLoad.value and not self.optShift.value then
		errMsg := app.getErrorString3( Choose_One_Of, self. optDischarge.caption, self.optLoad.caption, self.optShift.caption );
		return false;
	endif;
	
	self.myMobileGenericAgent.setMyVoyage(voyage);
	
	if self.optDischarge.value then
		self.myMobileGenericAgent.setChecksState(self.myMobileGenericAgent.ShipDischargeCargo);
		if self.grpDischTo.visible then
			if self.optMach.value then
				self.myMobileGenericAgent.setDischargeToHHOption(DiscHHLander_ToMach );
			else
				self.myMobileGenericAgent.setDischargeToHHOption(DiscHHLander_ToGround);
			endif;
		elseif not self.grpDischTo.visible then	//16 July 2012	NDL	Par 29961
			if not self.toGroundAllowed then
				self.myMobileGenericAgent.setDischargeToHHOption(DiscHHLander_ToMach );
			endif;
		endif;
		app.myMobileCargoFindAgent.setReUseSearchCriteria( false );	//08 Feb 2017	NDL	TFS 3191/2876
		app.myMobileCargoFindAgent.setSavedSearchCrit(null);	//08 Feb 2017	NDL	TFS 3191/2876
	elseif self.optLoad.value then
		self.myMobileGenericAgent.setChecksState(self.myMobileGenericAgent.ShipLoadCargo);
		app.myMobileCargoFindAgent.setReUseSearchCriteria( self.chkSearchParam.value );	//08 Feb 2017	NDL	TFS 3191/2876
	elseif self.optShift.value then
		self.myMobileGenericAgent.setChecksState(self.myMobileGenericAgent.ShiftOnBoard);
		app.myMobileCargoFindAgent.setReUseSearchCriteria( false );	//08 Feb 2017	NDL	TFS 3191/2876
		app.myMobileCargoFindAgent.setSavedSearchCrit(null);	//08 Feb 2017	NDL	TFS 3191/2876
	else
		errMsg := "Invalid state - see developer";
		return false;
	endif;
	
	self.gotoForm( MOB_HHLanderCargoMove, false );
	
	return true;
	
	
epilog

end;</source>
        <Parameter name="errMsg" type="String" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doResizeControls" id="5286c566-118d-4204-b97a-f56ab967bb7b">
        <updating/>
        <source>doResizeControls(_initialSetup: Boolean) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 February 2015	cnwndl1	Initial creation	Par 35604

*/

vars

	top : Real;
	width : Real;
	now : TimeStamp;
	stdHeight : Real;

begin

	self.setResizeableMarginAndFontSize();
	top := self.resizedMargin;
	width := self.clientWidth - self.resizedMargin - self.resizedMargin;
	stdHeight := self.getStdControlHeight;
	
	if _initialSetup then
		self.cmbVoyage.visible := true;
	endif;
	self.cmbVoyage.move( self.resizedMargin,
						 top,
						 width,
						stdHeight );
	
	top := top + self.cmbVoyage.height + self.resizedMargin;
	if _initialSetup then
		self.cmbQueue.visible := false; 
	endif;
	width := (( width / 3 ) * 2 );
	if _initialSetup then
		self.optDischarge.visible := true;
	endif;
	self.optDischarge.move(	self.resizedMargin,
							top,
							width,
							stdHeight );
	
	
	top := top + self.optDischarge.height + self.resizedMargin;
	if _initialSetup then
		self.optLoad.visible := true;
	endif;
	self.optLoad.move(	self.resizedMargin,
						top,
						width,
						stdHeight );
							 
	top := top + self.optLoad.height + self.resizedMargin;
	if _initialSetup then
		self.optShift.visible := true;
	endif;
	self.optShift.move(	self.resizedMargin,
						top,
						width,
						stdHeight );
						
	top := top + self.optShift.height + self.resizedMargin;
	
	if self.myMobileGenericAgent.myTerminal.getConfig(DischargeHHLanderOption).Integer = DiscHHLander_Both then
		
		
		self.grpDischTo.move(	self.resizedMargin,
								top,  
								self.clientWidth - (self.resizedMargin * 2),
								stdHeight*3.5);
		
		if _initialSetup then
			self.optMach.parent:=self.grpDischTo;
		endif;
		
		self.optMach.move(	self.resizedMargin,
							stdHeight,
							width,
							stdHeight );
		top := self.optMach.height + self.optMach.top + self.resizedMargin;
		
		if _initialSetup then
			self.optGround.parent:=self.grpDischTo;
		endif;
		self.optGround.move(	self.resizedMargin,
								top,
								width,
								stdHeight );
	
		if _initialSetup then
			if self.myMobileGenericAgent.dischargeToHHOption = DiscHHLander_ToGround then
				self.optGround.value:=true;
			else
				self.optMach.value:=true;
			endif;
			
			//10 Jul 2012	NDL	Par 29961
			if not self.toGroundAllowed then
				self.optGround.value := false;
				self.optGround.enabled := false;
				self.optGround.visible := false;
				self.optMach.value := true;
				self.grpDischTo.visible := false;
			endif;
		endif;
		
		//08 Feb 2017	NDL	TFS 3191/2876
		top := self.grpDischTo.top + self.grpDischTo.height + self.resizedMargin;
	
	endif;
	
	if _initialSetup then
		self.chkSearchParam.visible := false;
	endif;
	top := top + stdHeight;
	width := self.clientWidth - self.resizedMargin - self.resizedMargin;
	self.chkSearchParam.move(	self.resizedMargin + stdHeight,
								top,
								width,
								stdHeight );
	
	inheritMethod(_initialSetup);

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_initialSetup" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="handleBtnOne" id="61bf6210-64fc-4f0d-bee2-6aca7859888b">
        <updating/>
        <source>handleBtnOne() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 February 2010	cnwndl1	Initial creation	CCMS MES 1005

*/

vars
	errMsg : String;
begin
	//user clicked next
	if not doNext( errMsg ) then
		self.msgBox(errMsg , app.getErrorString(Error), MsgBox_OK_Only, true);
	endif;

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
