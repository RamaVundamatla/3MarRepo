    <JadeMethod name="displaySelectorResults" id="8acca783-8a7e-4bdd-8b60-30891c79cc89">
        <updating/>
        <source>displaySelectorResults(_resultCollection: Collection; _mode: Integer) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 December 2012	cnwer1	Initial creation HAT 2189
19 November 2019	jlgmp6	Copied to new cash collection screen TFS47595

*/

vars
	allTIs : ObjectArray;
begin
	if _mode &gt; TI_CargoType_Max then
		app.msgBox('The Cash Collection screen cannot display item for the selected mode (' &amp; _mode.String &amp; ')', 'Invalid selector mode', MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	
	create allTIs transient;
	_resultCollection.copy(allTIs);
	
	self.loadCargo(allTIs);
//	self.doCalculate();
epilog
	delete allTIs;
end;</source>
