    <JadeMethod name="createMeasurementType" id="96b702fc-2ad7-417d-8bde-6762498c03a5">
        <source>createMeasurementType(_conversionRate    : Decimal;
					_format 		     : Decimal;
					_isAvailableForEntry : Boolean;
					_isDefault 			 : Boolean;
					_isDisplay 			 : Boolean;
					_isSystemType		 : Boolean;
					_shortName 			 : String;
					_measurementType 	 : String;
					_name : String	) 	 : CM_MeasurementType;
/*
Purpose:			
Date		Who		Reason
28 May 2013	NAVAB1	Initial creation
14 Nov 2022	navma1	ChangeRequest 55381: MTN - Store format's decimal precision on Measurement Type
*/

vars
	pxyMeasure, 
	realMeasure 		: CM_MeasurementType;
	formatPrecision		: Integer;
begin
		create pxyMeasure transient;
		formatPrecision := pxyMeasure.calculateFormatPrecision(_format);			//14.11.2022 navma1 #55381
		
		pxyMeasure.setProxy(_conversionRate ,_format,_isAvailableForEntry,_isDefault,_isDisplay,_isSystemType,_shortName,_measurementType,_name,formatPrecision);
		app.myTrxCA.trxCreateMeasurementType(pxyMeasure, realMeasure, app.myPassport);
		
		return realMeasure;

epilog
	delete pxyMeasure;
end;</source>
        <Parameter name="_conversionRate" type="Decimal"/>
        <Parameter name="_format" type="Decimal"/>
        <Parameter name="_isAvailableForEntry" type="Boolean"/>
        <Parameter name="_isDefault" type="Boolean"/>
        <Parameter name="_isDisplay" type="Boolean"/>
        <Parameter name="_isSystemType" type="Boolean"/>
        <Parameter name="_shortName" type="String"/>
        <Parameter name="_measurementType" type="String"/>
        <Parameter name="_name" type="String"/>
        <ReturnType type="CM_MeasurementType"/>
    </JadeMethod>
    <JadeMethod name="createOnsiteCargoForLoadJob" id="173d1a09-b686-4e19-a323-33824d96e551">
        <updating/>
        <source>createOnsiteCargoForLoadJob(_voyageCode : String; _job : CM_VoyageJob; _blockstack : String) updating;
/*
Purpose:			 // PAR 35502
Date				Who			Reason
JANUARY 2015		NAVAB1		Initial creation
*/
vars
	bs: CM_BlockStack;

	cargo : CM_TrackedItem;
	aPort : CM_Port;
	voy : CM_Voyage;
	ct : CM_CargoType;
	startLC : CM_LocationsController;
	req : CM_Request;
	slot : CM_SlotRequest;
	iso, id : String;
	isoType : CM_ISOType;
	comm : String;
	commGrp : CM_CommodityGroup;
	commodity : CM_Commodity;
	reqTemp : Boolean;
begin

	voy := self.getVoyage(_voyageCode);

	

	deleteTerminalArea(_blockstack);
	bs := self.addBlockStack(_blockstack, 99999,null);
	startLC := bs.getMyLocationsController();
	
	foreach req in _job.allRequests discreteLock do
		slot := req.CM_SlotRequest;
		ct := slot.getAttrCargoType();
		aPort := slot.getAttrDischargePort();
		iso := "2200"; // default
		comm := "GENL"; // default
		self.opts.removeAssoc("Temperature");
		reqTemp := false;
		
		isoType := slot.getAttrISOType();
		if isoType &lt;&gt; null then
			iso := isoType.code;
		endif;
		commGrp := slot.getAttrCommodityGroup();
		if commGrp &lt;&gt; null then
			commodity := commGrp.allCommodities.first;
			if commodity &lt;&gt; null then
				comm := commodity.code;
				reqTemp := commodity.requiresPower or commodity.hasTemp;
				if reqTemp then
					self.opts.addAssoc("Temperature", -10); // this relies on using a UT commodity thaat has a temp range of -276 to 100
				endif;
			endif;
		endif;
		id := bs.getNextQuickCargoID(ct.id);
		
		cargo := self.addContainerAtLocnDisch(id, iso, comm, TI_IMEX_STATUS_EXPORT, startLC, aPort, voy);
	endforeach;
	

epilog

end;</source>
        <Parameter name="_voyageCode" type="String"/>
        <Parameter name="_job" type="CM_VoyageJob"/>
        <Parameter name="_blockstack" type="String"/>
    </JadeMethod>
    <JadeMethod name="createPackage" id="5c05dd01-ae31-4092-b776-fcdfe289ecf4">
        <source>createPackage(_packageType : Integer; _packageName : String; _description : String; _toAddress : String; _ccAddress : String; _bccAddress : String; 
				_subject : String; _message : String; _user : CM_User; _reports : ObjectArray input) : CM_Package;
// to be completed for sailing and reports - just invoice packages so far
vars
	proxyPackage,
	package 	: CM_Package;
	emailTemplate	: CM_EmailTemplate;
begin

	if _packageType = PackageSailing then
		create proxyPackage as CM_PackageSailing transient;
	elseif _packageType = PackageReports then
		create proxyPackage as CM_PackageRpts transient;
	elseif _packageType = PackageInvoicePost then
		create proxyPackage as CM_PackageInvoice transient;
	endif;

	create emailTemplate transient;
	
	emailTemplate.setProxy(null, null, null,
							null,
						    _toAddress, 
						    _ccAddress, 
						    _bccAddress, 
						    _subject, 
						    _message, 
						    false);

	
	if _packageType = PackageSailing then
		//self.setProxyForSailing();
	elseif _packageType = PackageReports then
		//self.setProxyForReports();
	elseif _packageType = PackageInvoicePost then
		proxyPackage.setForProxy(_packageName,
								_description,
								emailTemplate,
								_reports,
								_user,
								_packageType,
								null,		//navra1 - CR 61910/Task 62303 - 15th Feb 2024
								null,		//navra1 - CR 61910/Task 62303 - 15th Feb 2024
								null);		//navra1 - CR 61910/Task 62303 - 15th Feb 2024

	endif;
	
	app.myTrxCA.trxCreatePackage(self.getTerminal, proxyPackage, package, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();

	return package;
epilog
	delete proxyPackage;
end;</source>
        <Parameter name="_packageType" type="Integer"/>
        <Parameter name="_packageName" type="String"/>
        <Parameter name="_description" type="String"/>
        <Parameter name="_toAddress" type="String"/>
        <Parameter name="_ccAddress" type="String"/>
        <Parameter name="_bccAddress" type="String"/>
        <Parameter name="_subject" type="String"/>
        <Parameter name="_message" type="String"/>
        <Parameter name="_user" type="CM_User"/>
        <Parameter name="_reports" type="ObjectArray" usage="input"/>
        <ReturnType type="CM_Package"/>
    </JadeMethod>
    <JadeMethod name="createPaymentMethod" id="b5e0626b-502d-410d-97a9-feb8e47939a5">
        <source>createPaymentMethod( _code : String ):CM_PaymentMethod;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21 August 2012	cnwndl1	Initial creation	Par 29968

*/

vars

	proxy : CM_PaymentMethod;
	realPayMeth : CM_PaymentMethod;

begin

	
	create proxy transient;
	proxy.setProxy(_code, _code, false, false);

	app.myTrxCA.trxCreatePaymentMethod(proxy, realPayMeth, app.myPassport);
	
	return realPayMeth;

epilog

	delete proxy;

end;</source>
        <Parameter name="_code" type="String"/>
        <ReturnType type="CM_PaymentMethod"/>
    </JadeMethod>
    <JadeMethod name="createQuickCargo" id="fb663d2b-70cc-4077-ae4c-b56f47488df1">
        <source>createQuickCargo(_calledFrom : String; _obj : Any; _defn : Any io; _numberToCreate : Integer; _opts : CM_AssociationDict);

/*

Purpose:		Create Quick Cargo - call the correct quick cargo method	

Date			Who		Reason
27/08/2015		cnwmh5	Initial creation

*/

vars

	voyageStructure				: CM_ROROVoyageStructure;
	voyage						: CM_Voyage;
	ti							: CM_TrackedItem;
	defnGC						: CM_ROROGCDefn;
	defn						: CM_ROROLocnDefn;
	lc							: CM_LocationsController;
	
	tempLCSet					: CM_LCSet;

begin

	if _obj.isKindOf(CM_Voyage) then
		voyage := _obj.CM_Voyage;
	elseif _obj.isKindOf(CM_ROROVoyageStructure) then
		voyageStructure := _obj.CM_ROROVoyageStructure;
		voyage := voyageStructure.myVoyage;
	endif;
	
	if voyage = null and voyageStructure = null then
		self.assertTrue(true);
	endif;
	
	create tempLCSet transient;
		
	// create the cargo
	if _calledFrom = "createQuickCargoGC" then
		voyageStructure.createQuickCargoGC(_defn.CM_ROROGCDefnVoyage, _opts.obj("CargoType").CM_CargoType, 
			_opts.dec("XMetres").Decimal, _opts.dec("YMetres").Decimal, 
			_opts.obj("Deck").CM_DeckVoyage, _numberToCreate);
	elseif _calledFrom = "createQuickCargoLOLO" then
		voyage.createQuickCargo(_defn.CM_LCSet, _opts.bool("is40"));
	elseif _calledFrom = "createQuickCargoOOTL" then
		voyageStructure.createQuickCargoOOTL(null, _opts.bool("is40"), _opts.dec("XMetres").Decimal, 
			_opts.dec("YMetres").Decimal, _opts.obj("Deck").CM_DeckVoyage, _numberToCreate);
	elseif _calledFrom = "createQuickCargoRORO" then
		voyageStructure.createQuickCargo(_defn.CM_ROROLocnDefn, _opts.bool("is40"), _opts.bool("Fill"), 
			_opts.str("DischargePort"), _opts.str("Commodity"));
	elseif _calledFrom = "createQuickCargoLane" then
	
	endif;
	
	// 16/09/2015 cnwmh5
	beginTransaction;
	foreach ti in voyage.allOnshipTIsByIdCargoType discreteLock do
		ti.setRemarks(self.createdByUnitTest(ti.remarks), true);
	endforeach;
	commitTransaction;
	
epilog

	delete tempLCSet;

end;</source>
        <Parameter name="_calledFrom" type="String"/>
        <Parameter name="_obj" type="Any"/>
        <Parameter name="_defn" type="Any" usage="io"/>
        <Parameter name="_numberToCreate" type="Integer"/>
        <Parameter name="_opts" type="CM_AssociationDict"/>
    </JadeMethod>
    <JadeMethod name="createQuickCargoGC" id="c2375149-b4ac-4c8e-a8d2-7b89db358ece">
