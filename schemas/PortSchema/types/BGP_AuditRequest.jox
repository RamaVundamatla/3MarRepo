    <JadeMethod name="action" id="39b156bd-c71b-4c22-991a-240573610ae7">
        <updating/>
        <source>action() : Boolean updating;

begin

	beginTransaction;
	if mode = BGP_AuditRequest.Create then
		app.myAA.createCreateAuditFromRequest(self);
	elseif mode = BGP_AuditRequest.UpdateTrx then
		app.myAA.createUpdateAuditFromRequest(self);
	elseif mode = BGP_AuditRequest.Delete then
		app.myAA.createDeleteAuditFromRequest(self);
	elseif mode = BGP_AuditRequest.Update then
		app.myAA.createUpdateFromRequest(self);
	else
		// Return.
		// Leaving this open for testing.
	endif;

	if app.myPassport.noErrors then
		commitTransaction;
		return true;
	else
		abortTransaction;
		return false;
	endif;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="initAuditRequest" id="ff9c81ec-27fe-40ac-8adb-10c77337e27d">
        <updating/>
        <source>initAuditRequest(_subject : CM_Object; _beforeText, _afterText, _userCode : String; _mode : Integer; _extraInfo : String) updating;


begin

	self.afterText := _afterText;
	self.beforeText := _beforeText;
//	self.userCode := _userCode;
	self.mode := _mode;
	self.extraInfo := _extraInfo;
	initRequestEvent(true, false, null);
		
end;</source>
        <Parameter name="_subject" type="CM_Object"/>
        <Parameter name="_beforeText" type="String"/>
        <Parameter name="_afterText" type="String"/>
        <Parameter name="_userCode" type="String"/>
        <Parameter name="_mode" type="Integer"/>
        <Parameter name="_extraInfo" type="String"/>
    </JadeMethod>
