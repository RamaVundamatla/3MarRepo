    <JadeMethod name="getMyVessel" id="859f4429-3e61-4588-8ba6-72d592cd0e67">
        <source>getMyVessel() : CM_Vessel;
//--------------------------------------------------------------
//Created: 30 July 2003 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	if self.myPersistentMovement &lt;&gt; null then
		return self.myPersistentMovement.getMyVessel();
	elseif self.myWorkingVoyage &lt;&gt; null then
		return self.myWorkingVoyage.getMyVessel();		
	elseif self.myClonedMovement &lt;&gt; null then
		return self.myClonedMovement.myPersistentMovement.getMyVessel();
	elseif self.myClonedVoyage &lt;&gt; null then
		return self.myClonedVoyage.getMyVessel();				
	endif;

end;</source>
        <ReturnType type="CM_Vessel"/>
    </JadeMethod>
    <JadeMethod name="getPilotLaunchToolTipStr" id="ca1fc370-2e0e-47e5-b082-9adeb14fc511">
        <source>getPilotLaunchToolTipStr() : String;
// ---------------------------------------------------------------------------
// Created:     07 September 2005	cnwhjg1
//
// Purpose:      boolean passed through only used to check whether shift movements
//				are from or going to. 					 
// ----------   ----------  --------------------------------------------------
vars

	strBubble,
	str					: String;
//	workingMove,
//	nextWorkingMove		: CMIF_HMS_WorkingMovement;
	tmpMove			: CMIF_HMS_WorkingMovement;	
begin

		if self.pilotExempt then 
			return app.getErrorString(NotRequired);
		endif;
	
		if self.myPilotLaunch &lt;&gt; null then
			if self.moveType = HMSMovementTypeShift then 				
				
				tmpMove  := self.getMovementPrevious;		
				if tmpMove &lt;&gt; null and tmpMove.myBerth &lt;&gt; null then
 			//need to check whether prev or next movement is from logical berth or not. 
					if tmpMove.isLogicalBerth() or self.isLogicalBerth() then
					// Ship is being SHIFTed to or from sea - pilot launch is required
						return self.myPilotLaunch.description &amp; CrLf;
					else
						// Ship is being SHIFTed within the harbour - pilot launch is NOT required
						// DONT display shift movements without pilot launch?
						return app.getErrorString(NotRequired);
					endif;
 				else 
 					// Destination berth for ship not set - set pilot launch to 'Not Required'
					return app.getErrorString(NotRequired);
 				endif;
 			else
	 			// Move is not a shift and is not pilot exempt - ie. launch is required
 				return self.myPilotLaunch.description;
 				 				
 			endif;
 		else 
	 		return app.getErrorString(NoneSelected); 
 		endif;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getPilotsString" id="78076e18-3076-46a2-a2e6-a1f58b5c2cd2">
        <source>getPilotsString():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31/10/2018	jlgndl1	Initial creation	TFS 41662
27/02/2019	jlgdap1	TFS 43667 PNL Two Pilots on Departure Resources Used
29 Apr 2019	jlgsl4	TFS 44438 - PEL1 - Multiple Pilot Launches for one movement
*/

vars
	//pilot : HMS_Pilot; // TFS 44438
	str : String;
	movementPilotDetails : HMS_MovementPilotDetails; // TFS 44438
begin
	
	//if self.allPilots.isEmpty then					// TFS 43667
	if not self.allMovementPilotDetails.isEmpty then //allPilots.isEmpty then // TFS 43667 // TFS 44438
		foreach movementPilotDetails in self.allMovementPilotDetails where movementPilotDetails.myPilot &lt;&gt; null do //pilot in self.allPilots do // TFS 44438
			if str &lt;&gt; null then
				str := str &amp; "," &amp; movementPilotDetails.myPilot.description; //pilot.description; // TFS 44438
			else
				str := movementPilotDetails.myPilot.description; //pilot.description; // TFS 44438
			endif;
		endforeach;
	endif;
	
	return str;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getRegionWithChkPtsAlongPath" id="2f85b636-fa4e-4a56-953c-aa21216d2d4f">
        <source>getRegionWithChkPtsAlongPath(_regionFrom : HMS_HarbourRegion; _pathToCheck : HMS_MovementPath; _totalOffsetTime : Integer io; _directionForward, _baseTimeAtRegA : Boolean ) : HMS_HarbourRegion;
/*

Purpose:		Just refactored from getFirstRegionWithChkPts	

Parameters:			

Return Value:		


Date		Who		Reason
17 June 2008	cnwer1	Initial creation 16635

*/

vars
	pathSegment : HMS_PathSegment;
	regToCheck : HMS_HarbourRegion;
	offSetTime : Integer;
begin
	// Check checkpoints at reg A at basetime
	if _regionFrom.hasCheckpointsWithTidalModel() then
		// Checkpoints to check
		return _regionFrom;
	endif;

// ----------------------------------------------------
// 			restored as it was in 761. Par 18907
// ----------------------------------------------------
	if _directionForward and _baseTimeAtRegA then
	
		foreach pathSegment in _pathToCheck.allPathSegments do
			regToCheck			:=	pathSegment.myRegionTo;
			offSetTime			:=	pathSegment.steamingTimeAB;
			_totalOffsetTime	:=	_totalOffsetTime + offSetTime;
		
			if regToCheck.hasCheckpointsWithTidalModel() then
				return regToCheck;
			endif;
		endforeach;
		
	elseif _directionForward and not _baseTimeAtRegA then
	
		foreach pathSegment in _pathToCheck.allPathSegments reversed do
			regToCheck			:=	pathSegment.myRegionFrom;
			offSetTime			:=	pathSegment.steamingTimeAB;
			_totalOffsetTime	:=	_totalOffsetTime - offSetTime;
		
			if regToCheck.hasCheckpointsWithTidalModel() then
				return regToCheck;
			endif;
		endforeach;
		
	elseif not _directionForward and _baseTimeAtRegA then
	
		foreach pathSegment in _pathToCheck.allPathSegments do
			regToCheck			:=	pathSegment.myRegionTo;
			offSetTime			:=	pathSegment.steamingTimeBA;
			_totalOffsetTime	:=	_totalOffsetTime - offSetTime;
		
			if regToCheck.hasCheckpointsWithTidalModel() then
				return regToCheck;
			endif;
		endforeach;
		
	elseif not _directionForward and not _baseTimeAtRegA then
	
		foreach pathSegment in _pathToCheck.allPathSegments reversed do
			regToCheck			:=	pathSegment.myRegionFrom;
			offSetTime			:=	pathSegment.steamingTimeBA;
			_totalOffsetTime	:=	_totalOffsetTime + offSetTime;
		
			if regToCheck.hasCheckpointsWithTidalModel() then
				return regToCheck;
			endif;
		endforeach;
		
	endif;


// --------------------------------------------------------
// 	last changes, were made in 762. Commented by Par 18907	
// --------------------------------------------------------
/*	if _directionForward then
		foreach pathSegment in _pathToCheck.allPathSegments do
			regToCheck			:=	pathSegment.myRegionTo;
			offSetTime			:=	pathSegment.steamingTimeAB;
			_totalOffsetTime	:=	_totalOffsetTime + offSetTime;
			//basetime			:=	basetime+offSetTime;
		
			if regToCheck.hasCheckpointsWithTidalModel() then
				return regToCheck;
			endif;
		endforeach;
	else
		foreach pathSegment in _pathToCheck.allPathSegments reversed do
			regToCheck			:=	pathSegment.myRegionTo;
			offSetTime			:=	pathSegment.steamingTimeAB;
			_totalOffsetTime	:=	_totalOffsetTime + offSetTime;
			//basetime			:=	basetime+offSetTime;
		
			if regToCheck.hasCheckpointsWithTidalModel() then
				return regToCheck;
			endif;
		endforeach;
	endif;
*/
	
	
	return null;
	
epilog

end;</source>
        <Parameter name="_regionFrom" type="HMS_HarbourRegion"/>
        <Parameter name="_pathToCheck" type="HMS_MovementPath"/>
        <Parameter name="_totalOffsetTime" type="Integer" usage="io"/>
        <Parameter name="_directionForward" type="Boolean"/>
        <Parameter name="_baseTimeAtRegA" type="Boolean"/>
        <ReturnType type="HMS_HarbourRegion"/>
    </JadeMethod>
    <JadeMethod name="getRemarks" id="56d0f3a4-8006-4980-9779-be8281fd2438">
        <source>getRemarks() : String;
//--------------------------------------------------
// Created:	02 August 2004 By: cnwgd1
//--------------------------------------------------
vars

begin
	if self.myPersistentMovement &lt;&gt; null then
		return self.myPersistentMovement.getRemarks();
	endif;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getResourceUsedString" id="5c43e9e7-ce5b-40de-8d37-8dad01fa38c6">
        <source>getResourceUsedString() : String;
//--------------------------------------------------
// Created:	16 September 2004 By: cnwgd1
//--------------------------------------------------
/* Changes

Date		Name	TFS#		Description
============================================================================
15/10/2019  jlgka1 	TFS 46888 	JMT - Graphical View - 1090 exception
============================================================================*/
vars
	res : CMIF_HMS_ResourceUsed;
	str : String;
	rd	: HMS_ResourceType;
begin

	if self.allWorkingResUsedByDescription.isEmpty then
		return CrLf;
	endif;
	
	foreach res in self.allWorkingResUsedByDescription do
		rd := res.myResourceType;
		//jlgka1 TFS 46888 --&gt;
		if rd = null then
			continue;
		endif;
		//jlgka1 TFS 46888 &lt;--
		if res.myResource &lt;&gt; null then
			str := str &amp; CrLf &amp; Tab &amp; rd.description &amp; ' ' &amp; res.myResource.description;
		else
			str := str &amp; CrLf &amp; Tab &amp;  rd.description;
		endif;
	endforeach;	
	
	return str &amp; CrLf;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getShipEnterLeaveStatus" id="33e4a4c9-8c09-4eeb-b7ad-93c5a25a5c77">
        <source>getShipEnterLeaveStatus(regionFrom:HMS_HarbourRegion io; regionTo:HMS_HarbourRegion io; movePrev: CMIF_HMS_WorkingMovement):String;

vars
 	fromBerth:		HMS_Berth;
 	toBerth:		HMS_Berth;
 	//movePrev:		CMIF_HMS_VoyageMovement;
 	movementType: 	String;

begin
	// This method determines whether a ship is entering or leaving the 
	// harbour on this movement and which regions it is travelling to/from

	//movePrev:=self.getMovementPrevious;
	if movePrev&lt;&gt;null then
		// either a shift or a departure movement
		fromBerth:=movePrev.myBerth;
		toBerth:=self.myBerth;
	else
		// arrival movement
		fromBerth:=null;
		toBerth:=self.myBerth;
	endif;

	// Determine whether a ship is entering the harbour
	// ie. moving from a logical wharf to a nonlogical wharf
	if fromBerth&lt;&gt;null and toBerth&lt;&gt;null then
		if fromBerth.isLogicalBerth() and  (not toBerth.isLogicalBerth()) then
			// Ship is entering the harbour
			movementType:=HMSMovementTypeEntering;
		elseif (not fromBerth.isLogicalBerth()) and toBerth.isLogicalBerth() then
			// Ship is leaving the harbour
			movementType:=HMSMovementTypeLeaving;
		endif;
		regionFrom:=fromBerth.myHarbourRegion;
		regionTo:=toBerth.myHarbourRegion;
	elseif fromBerth&lt;&gt;null and toBerth=null then
		if (not fromBerth.isLogicalBerth()) then
			// Ship is leaving the harbour
			movementType:=HMSMovementTypeLeaving;
		endif;
		regionFrom:=fromBerth.myHarbourRegion;
		if myHarbour.defaultDepartBerth &lt;&gt; null then
			regionTo:=myHarbour.defaultDepartBerth.myHarbourRegion;
		endif;
	elseif fromBerth=null and toBerth&lt;&gt;null then
		if (not toBerth.isLogicalBerth()) then
			// Ship is entering the harbour
			movementType:=HMSMovementTypeEntering;
		endif;
		if myHarbour.defaultDepartBerth &lt;&gt; null then
			regionFrom:=myHarbour.defaultDepartBerth.myHarbourRegion;
		endif;
		regionTo:=toBerth.myHarbourRegion;
	endif;

	return movementType;		

end;</source>
        <Parameter name="regionFrom" type="HMS_HarbourRegion" usage="io"/>
        <Parameter name="regionTo" type="HMS_HarbourRegion" usage="io"/>
        <Parameter name="movePrev" type="CMIF_HMS_WorkingMovement"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getSternMark" id="847bc38e-d8ce-496b-a278-1a2f434e7f67">
        <updating/>
        <source>getSternMark(_berth : HMS_Berth; _bowMark : Decimal; _sternMark : Decimal io) updating;
//-----------------------------------------
// Created: May 2004 By: cnwgd1
//-----------------------------------------
vars
    waterOnLeftmyWharf:	Boolean;
    loa:				Decimal[6,2];
begin
 	// This method calculates the stern position for a ship, when supplied with the 
 	// bow mark, berth, and orientation, and ship L.O.A.

 	waterOnLeftmyWharf := _berth.myWharf.waterOnLeft;
 	if self.myClonedVoyage &lt;&gt; null then
 		loa:=self.myClonedVoyage.myHMSVoyageData.dim_LengthOverall;
 	else	
 		loa:=self.myWorkingVoyage.myHMSVoyageData.dim_LengthOverall;
    endif;

 	if waterOnLeftmyWharf=true and self.sideTo=OrientPortSideTo then
    	// CASE A: Water on left of wharf, ship is PortSideTo, bowMark=min, sternMark=max
    	_sternMark := _bowMark+loa;
    elseif waterOnLeftmyWharf=true and self.sideTo=OrientStarboardSideTo then
    	// CASE B: Water on left of wharf, ship is StarboardSideTo, bowMark=max, sternMark=min
    	_sternMark := _bowMark-loa;
    elseif waterOnLeftmyWharf=false and self.sideTo=OrientPortSideTo then
    	// CASE C: Water on right of wharf, ship is PortSideTo, bowMark=max, sternMark=min
    	_sternMark := _bowMark-loa;
    elseif waterOnLeftmyWharf=false and self.sideTo=OrientStarboardSideTo then
    	 // CASE D: Water on right of wharf, ship is StarboardSideTo, bowMark=min, sternMark=max
    	_sternMark := _bowMark+loa;
    endif;

end;</source>
        <Parameter name="_berth" type="HMS_Berth"/>
        <Parameter name="_bowMark" type="Decimal"/>
        <Parameter name="_sternMark" type="Decimal" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getVesselRemarks" id="0b97bf2a-f158-45d6-b469-da906f084da4">
        <updating/>
        <source>getVesselRemarks() : String updating;
//********************************************************************
//
// Created by: cnwsh3
//
// Date: 29 October 2004
//
//	Get the remarks of the vessel definition
//
//********************************************************************
vars
	str : String;
	vessel : CM_Vessel;
begin
	//Get the vessel definition we have used.
	vessel := self.getMyVessel;
	
	//Now get the remarks of the vessel.
	if vessel &lt;&gt; null then
		str := vessel.remarks;
	endif;
	
	return str;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getVoyage" id="c5d48fe5-70b6-4915-8121-5403be08e6ac">
        <source>getVoyage():CM_Voyage;
// --------------------------------------------------------------------------------
// Created:		22 February 2007 by cnwdad1
//
// Purpose:		Returns a reference to the receiver's Voyage object.
//
// Parameters:	None
//
// Returns:		A reference to a Voyage object, otherwise null.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.myHMSVoyageData = null then
		return null;
	endif;
	
	return self.myHMSVoyageData.myVoyage;
end;</source>
        <ReturnType type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="getVoyageGlobal" id="af2c1509-7b28-4745-ae70-83275232a667">
        <source>getVoyageGlobal():CM_VoyageGlobal;
// --------------------------------------------------------------------------------
// Created:		06 March 2007 by cnwdad1
//
// Purpose:		Returns a reference to the receiver's Global Voyage.
//
// Parameters:	None
//
// Returns:		A rteference to a Global Voyage, otherwise null.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	voyageObj	: CM_Voyage;
	
begin
	voyageObj	:=	self.getVoyage();
	
	if voyageObj = null then
		return null;
	endif;
	
	return voyageObj.getGlobalVoyage();
end;</source>
        <ReturnType type="CM_VoyageGlobal"/>
    </JadeMethod>
    <JadeMethod name="getWorkingVoyageForCancelled" id="7fd512ab-8528-4e9f-b1e2-78ffe9bbe19e">
        <source>getWorkingVoyageForCancelled():CMIF_HMS_WorkingVoyage;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 November 2018	jlgndl1	Initial creation	TFS 42043

*/

vars

begin

	if self.isCancelled then
		return self.myReplacementMovement.getWorkingVoyageForCancelled();
	endif;
	
	return self.myWorkingVoyage;

epilog

end;</source>
        <ReturnType type="CMIF_HMS_WorkingVoyage"/>
    </JadeMethod>
    <JadeMethod name="hasRemarks" id="9a1a261d-b89f-4a0f-b8f5-b6fd033fea2c">
        <updating/>
        <source>hasRemarks( _checkShortComment, _checkRemarksGeneral, _checkRemarksPilotOnly,
			_checkVoyageRemarks: Boolean ): Boolean updating;
//********************************************************************
//
// Created by: cnwsh3
//
// Date: 02 December 2004
//
//	Several remarks attributes need to be checked.  
//	A check against any attribute that is used for comments
// 
//	Can flag which remarks attributes to check. As soon as one is found
//  to contain anything, a true result is returned otherwise it will be false.
//
//********************************************************************
vars
	hmsData : HMS_VoyageData;
	str : String;
	voyMove	: HMS_VoyageMovement;
begin
	
	//Check both self and the persistent movement as there may have been changes that
	//have not been updated yet.
	if self.myPersistentMovement &lt;&gt; null then
		if self.myPersistentMovement.remarks &lt;&gt; null then
			return true;
		endif;
		//HMS Voyage data (hmsData) will be checked below
	elseif self.remarks &lt;&gt; null then
		return true;
	elseif self.myWorkingVoyage &lt;&gt; null then
		if self.myWorkingVoyage.remarks &lt;&gt; null
		or self.myWorkingVoyage.shortComment &lt;&gt; null then
			return true;
		endif;	
	else
		//No persistent movement and no remarks
		return false;
	endif;
	
	
		
	hmsData := self.myHMSVoyageData;
	//If we are a scenario movement we won't yet have an HMS_VoyageData object.
	if hmsData &lt;&gt; null then
		if _checkShortComment then
			if hmsData.shortComment &lt;&gt; null then
				return true;
			endif;
		endif;
		
		//Check any movements for remarks.
		foreach voyMove in hmsData.allVoyageMovements do
			if voyMove.remarks &lt;&gt; null then
				return true;
			endif;
		endforeach;
		
		if _checkRemarksGeneral then
			if hmsData.remarksGeneral &lt;&gt; null then
				return true;
			endif;
		endif;
		
		if _checkRemarksPilotOnly then
			if hmsData.remarksPilotOnly &lt;&gt; null then
				return true;
			endif;		
		endif;
		
		if _checkVoyageRemarks then
			//Check we have a voyage in the first place.
			if hmsData.myVoyage &lt;&gt; null then
				if hmsData.myVoyage.remarks &lt;&gt; null then
					return true;
				endif;
			endif;
		endif;
	endif;
			
	return false;
end;</source>
        <Parameter name="_checkShortComment" type="Boolean"/>
        <Parameter name="_checkRemarksGeneral" type="Boolean"/>
        <Parameter name="_checkRemarksPilotOnly" type="Boolean"/>
        <Parameter name="_checkVoyageRemarks" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="init_Berth" id="352d51f8-1c12-4c15-ab04-a90d23a3aefc">
