<Class name="CMQF_VoyageExchangeSummaryAll" id="22f0783d-494d-4d57-882d-e1906fba5129">
    <superclass name="CMQF_VoyageExchangeSummary"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="query"/>
    <JadeMethod name="addNDLTestData" id="e933bc08-2d02-4382-b0e0-649d214d6c22">
        <source>addNDLTestData( _collection: Collection input );

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
15 April 2010	cnwndl1	Initial creation

*/

vars

	voySummaryDict : CMIF_VoyageSummaryByValueDict;
	summaryObj : CMIF_VoyageSummary;
	
begin

	// only callable in development for testing
	
	executeWhen JMTDevelopmentEnvironment;

	voySummaryDict := _collection.CMIF_VoyageSummaryByValueDict;

	create summaryObj transient;
	summaryObj.keyValue1 := "NDL test data";
	summaryObj.keyValue2 := null;
	voySummaryDict.add(summaryObj);
		
	summaryObj.addNdlTestData( voySummaryDict, true );
	
	endExecuteWhen;
	
epilog

end;</source>
        <Parameter name="_collection" type="Collection" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doTotalsForTI" id="6cb6e5a0-3acf-4637-afa6-6a7533862e64">
        <source>doTotalsForTI(_key: String; _voyageSum: CMIF_VoyageSummaryByValueDict input; _ti: CM_TrackedItem) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
13 April 2010	cnwndl1	Initial creation	Par 23048 - New version to include 30's, 45's and 53's 

*/

vars

	summaryObj : CMIF_VoyageSummary;
	only20sAnd40s : Boolean;
	
begin

	only20sAnd40s := false;
	summaryObj := _voyageSum[_key, null];
					
	if summaryObj = null then
		create summaryObj transient;
		summaryObj.keyValue1 := _key;
		summaryObj.keyValue2 := null;
		_voyageSum.add(summaryObj);
	endif;

	summaryObj.totalSelfForExchangeSummaryAll(_ti, null, only20sAnd40s, false);
	summaryObj.totalDescriptorsForAll(_ti, null, only20sAnd40s);
	
	//totals objects
	_voyageSum[self.TOTALS_ID, null].totalSelfForExchangeSummaryAll(_ti, null, only20sAnd40s, true);

end;</source>
        <access>protected</access>
        <Parameter name="_key" type="String"/>
        <Parameter name="_voyageSum" type="CMIF_VoyageSummaryByValueDict" usage="input"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="doTotalsForTxn" id="1734a623-5736-49a3-852f-277fdd35920b">
        <source>doTotalsForTxn(_key: String; _voyageSum: CMIF_VoyageSummaryByValueDict input; _txn: CM_TITransaction) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14 April 2010	cnwndl1	Initial creation

*/

vars

	summaryObj			: CMIF_VoyageSummary;
	only20sAnd40s : Boolean; 
	
begin

	only20sAnd40s := false;
	summaryObj := _voyageSum[_key, null];
		
	if summaryObj = null then
		create summaryObj transient;
		summaryObj.keyValue1 := _key;
		summaryObj.keyValue2 := null;
		summaryObj.heading := _key;
		_voyageSum.add(summaryObj);
	endif;

	summaryObj.totalSelfForExchangeSummaryAll(null, _txn, only20sAnd40s, false);
	summaryObj.totalDescriptorsForAll(null, _txn, only20sAnd40s);

	//totals objects
	_voyageSum[self.TOTALS_ID, null].totalSelfForExchangeSummaryAll(null, _txn, only20sAnd40s, true);

end;</source>
        <access>protected</access>
        <Parameter name="_key" type="String"/>
        <Parameter name="_voyageSum" type="CMIF_VoyageSummaryByValueDict" usage="input"/>
        <Parameter name="_txn" type="CM_TITransaction"/>
    </JadeMethod>
    <JadeMethod name="filterObjects" id="290a61d7-ab91-4218-9a08-6bf752b93799">
        <updating/>
        <source>filterObjects(_collection: Collection input; _passport: CM_Passport) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
15 April 2010	cnwndl1	Initial creation

*/

vars

	testing : Boolean;
	
begin

	inheritMethod(_collection, _passport);

	return;
	// builds a full test record for testing if teh return is commented out.
	self.addNDLTestData(_collection);

epilog

end;</source>
        <Parameter name="_collection" type="Collection" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
</Class>
