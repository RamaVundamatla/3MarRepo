vars

begin
	return "Not Included In Contract";
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getPicture" id="da9a8477-cd85-417e-b132-fbae7cb0e8e5">
        <source>getPicture(form: INV_TransactionMap): Picture;
// ---------------------------------------------------------------------------
// Created:		February 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	if self.hidePictures then
		return null;
	endif;
	return form.picConOUT;
end;</source>
        <Parameter name="form" type="INV_TransactionMap"/>
        <ReturnType type="Picture"/>
    </JadeMethod>
    <JadeMethod name="getRealMapObject" id="30242472-170b-44d9-a972-4599e9bacc2b">
        <source>getRealMapObject(): Object;
// ---------------------------------------------------------------------------
// Created:		February 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	if self.myDebtorMap &lt;&gt; null then
		return self.myDebtorMap;
	else
		return self.myServiceBroker;
	endif;

end;</source>
        <ReturnType type="Object"/>
    </JadeMethod>
    <JadeMethod name="initialise" id="70ae79f1-3846-4058-ae96-20a20a7c5a76">
        <updating/>
        <source>initialise(_groupCount : Integer io) updating;
// ---------------------------------------------------------------------------
// Created:		February 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	ild: CM_InvoiceLineDesc;
	tmcS : CMIF_TMCInvLineDesc;
	lineMapDict		: CM_TMInvLineMapByCargoAttrDict;
	lineMapping		: CM_TranMapInvoiceLineMapping;
	currKey : Integer;
begin
	self.myTMCController := self.myGroup.myTMCController;	// April 2010, cnwjre1, par 23659, invoice transaction map extract enhancements for Tranship IMEX status
	self.hidePictures := self.myTMCController.hidePictures;
	lineMapDict := self.myQuantityRangeMap.allTMInvoiceLineMappings;
	foreach lineMapping in lineMapDict do
		ild := lineMapping.myTMInvoiceLineDesc;
		currKey := lineMapping.mapValue;
		if currKey = CM_ResourceServiceBroker.INVOICELINE_KEY_OUT_CONTRACT then
			create tmcS;
			tmcS.itemName := ild.narration;
			tmcS.extractName := ild.narration;	// 23659
			tmcS.myParentServiceBroker := null;
			tmcS.myParentDebtorMap := null;
			tmcS.myQuantityRangeMap := self.myQuantityRangeMap;
			tmcS.myGroup := self;
			tmcS.myInvoiceLineDesc := ild;
			tmcS.hidePictures := self.myTMCController.hidePictures;
			_groupCount := _groupCount + 1;
		endif;
	endforeach;
	_groupCount := _groupCount + 1;
epilog

end;</source>
        <Parameter name="_groupCount" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="loadListaAt" id="726e7a1a-dd7d-4212-94f1-6332b1174c4f">
        <source>loadListaAt(listbox: ListBox; level: Integer; at: Integer);

vars
	tmc : CMIF_TranMapController;
	parent	: CMIF_TMCGroup;
	child	: CMIF_TranMapController;
	inResource	: CMIF_TMCResourceContractIN;
	i :Integer;
	pic : Picture;
	str : String;
	int : Integer;
begin
	int := 1;
	str := itemName.scanUntil(Tab, int);
	str := str.trimRight;

	// from 30955, fix refresh for voyage resource changes
	parent := self.myGroup;
	foreach child in parent.allGroupMembers do
	// should be one CMIF_TMCResourceContractIN and one CMIF_TMCResourceContractOUT
		if child.isKindOf(CMIF_TMCResourceContractIN) then
			inResource := child.CMIF_TMCResourceContractIN;
			break;
		endif;
	endforeach;
	// this should be there, but playing safe ..
	if inResource = null then
		i := at + 1;		// original code
	else
		i := at + inResource.allGroupMembers.size;	// the number of entries added above this one
	endif;
	
	listbox.addItemAt(str, i);
	listbox.itemLevel[listbox.newIndex] := level;
	listbox.itemObject[listbox.newIndex] := self;
	listbox.itemData[listbox.newIndex] := self.getType();
	pic := getPicture(listbox.form.INV_TransactionMap);
	if pic &lt;&gt; null then
		listbox.itemPicture[listbox.newIndex] := pic.picture;
	endif;


	i := i;
	foreach tmc in self.allGroupMembers do
		i := i + 1;
		tmc.loadListaAt(listbox, level + 1, i);
	endforeach;

end;</source>
        <Parameter name="listbox" type="ListBox"/>
        <Parameter name="level" type="Integer"/>
        <Parameter name="at" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setControllerCurrent" id="5148a62e-03c9-4a05-944e-ae3d52e076d8">
        <source>setControllerCurrent() ;
// April 2010, cnwjre1, par 23659, invoice transaction map extract enhancements for Tranship IMEX status
vars

begin
	inheritMethod();

	myTMCController.isContractOut := true;

end;</source>
    </JadeMethod>
    <JadeMethod name="setMyCurrent" id="1cb96b7e-aea7-4dc1-b499-ff0954b4165b">
        <updating/>
        <source>setMyCurrent(form: INV_TransactionMap io) updating;
// ---------------------------------------------------------------------------
// Created:		February 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	inheritMethod(form);

	form.myTMCContractOUT := self;

end;</source>
        <Parameter name="form" type="INV_TransactionMap" usage="io"/>
    </JadeMethod>
</Class>
