    <JadeMethod name="setFilterDefaults" id="d050d4d4-be1c-4a1a-a007-1e743af20838">
        <updating/>
        <source>setFilterDefaults() updating;
// ---------------------------------------------------------------------------
// Created:     06 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 24/11/2011	cnwcs5		CCMS POL 2122 / par 28696 - needs review added
// 23/04/2012	cnwcs5		CCMS POL 2172 / par 29480 - stop EDI updates added
// 07/01/2015	cnwdap1		PAR #35397 CCMS SFW 1394 Voyage Rationalisation
// ---------------------------------------------------------------------------
vars
	table	:CM_EntryTable;
begin
	table := self.tblSearch;
	
	self.filterReleaseNo				:= null;
	self.myFilterBulkRelease			:= null;
	
	self.cmbMTGrade.setObjectAndOperator(null,null,null);
	
	self.filterAvGrade					:= -1;		// cnwmc5 - 27 May 2016 - TFS 2044
	self.filterCarrierCode				:= null;
	self.myFilterCarrier				:= null;
	self.cmbFiltCarrier.listObject 		:= null;
	
	self.filtBusinessUnitCode			:= null;
	self.filterConsignorCode			:= null;
	self.myFilterConsignor				:= null;
	self.cmbFiltConsignee.listObject	:= null;
	self.cmbFiltBooking.listIndex 		:= -1;	//PAR 20296 Sep 2009
	
	self.filterFreightForwarder			:= null;
	self.myFilterFreightForwarder		:= null;
	self.cmbFiltFrghtFwdr.listObject	:= null;
	
	self.filterOperatorCode				:= null;
	self.myFilterOperator				:= null;
	self.cmbFiltOperator.listObject 	:= null;
	
	self.filterDateFrom := null;
	table.setValueByName(ETRow_FilterDateRequestFrom, null);
	self.filterFreeText := null;
	
	self.filterDateTo := null;
	table.setValueByName(ETRow_FilterDateRequestTo, null);

	self.filterDateRequireFrom := null;
	
	table.setValueByName(ETRow_FilterDateRequiredFrom, null);
	table.setValueByName(ETRow_FilterTimeRequireFrom, null);

	self.filterPIN	:= null;
	
	self.cmbFiltNeedsRev.listIndex	:= 1;				// all
	self.filterNeedsReview			:= self.FILTER_ALL;	// all
	self.cmbFiltStopEDIUp.listIndex	:= 1;				// all par 29480 April 2012
	self.filterBlockEDIUpdates		:= self.FILTER_ALL;	// all par 29480 April 2012
	
	table.setValueByName (ETRow_FilterNeedsReview, self.cmbFiltNeedsRev.text);
	table.setValueByName (ETRow_FilterBlockEDIUpdates, self.cmbFiltStopEDIUp.text);	 // par 29480 April 2012
	
	self.myFilterVoyage				:= null;			// PAR #35397
	self.cmbFiltVoyage.listObject	:= null;			// PAR #35397
end;</source>
    </JadeMethod>
    <JadeMethod name="setFilterValues" id="637f6dde-2c8a-4e3c-85b0-4cd7f63ae1c7">
        <updating/>
        <source>setFilterValues() updating;
// ---------------------------------------------------------------------------
// Created:     06 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 24/11/2011	cnwcs5		CCMS POL 2122 / par 28696 - needs review added
// 23/04/2012	cnwcs5		CCMS POL 2172 / par 29480 - stop EDI updates added
// 07/01/2015	cnwdap1		PAR #35397 CCMS SFW 1394 Voyage Rationalisation
// ---------------------------------------------------------------------------
vars
	table	:CM_EntryTable;
	value	:Integer;
begin
	table := self.tblSearch;
	
	self.myFilterBulkRelease		:= self.cmbBulkRelease.listObject.CM_BulkRelease;
	self.myFilterCarrier			:= self.cmbFiltCarrier.listObject.CM_Carrier;
	self.myFilterConsignor  		:= self.cmbFiltConsignee.listObject.CM_ConsigneeConsignor; 
	self.myFilterFreightForwarder	:= self.cmbFiltFrghtFwdr.listObject.CM_ConsigneeConsignor;	
	self.myFilterOperator			:= self.cmbFiltOperator.listObject.CM_Operator;
	self.myFilterVoyage				:= self.cmbFiltVoyage.getCurrentItemObject.CM_Voyage;			// PAR #35397
	
	if self.cmbFiltBizUnit.listObject &lt;&gt; null then
		self.filtBusinessUnitCode	:= self.cmbFiltBizUnit.listObject.CM_Bank.code;
	else
		self.filtBusinessUnitCode	:= null;
	endif;
	
	self.filterBooking := self.cmbFiltBooking.listIndex;	//PAR 20296 Sep 2009 
	
	if self.filterBooking = -1 then
		self.filterBooking := 0;
	endif;
		
	if self.cmbMTGrade.listObject &lt;&gt; null then
		self.filterAvGrade := self.cmbMTGrade.listObject.CM_MTGrade.code;
	else
		self.filterAvGrade := -1;		// cnwmc5 - 27 May 2016 - TFS 2044
	endif;
	
	if self.myFilterCarrier &lt;&gt; null then
		self.filterCarrierCode := self.myFilterCarrier.code.trimRight;
	else
		self.filterCarrierCode := null;
	endif;

	if self.myFilterConsignor &lt;&gt; null then
		self.filterConsignorCode := self.myFilterConsignor.code.trimRight;
	else
		self.filterConsignorCode := null;
	endif;
	
	if self.myFilterFreightForwarder &lt;&gt; null then
		self.filterFreightForwarder := self.myFilterFreightForwarder.code.trimRight;
	else
		self.filterFreightForwarder := null;
	endif;
	
	if (not self.relNoSearchByText) then //jlgzm1 tfs41961
		if global.isValidObject(self.myFilterBulkRelease) then
			self.filterReleaseNo := self.myFilterBulkRelease.code;
		else
			self.filterReleaseNo := null;
		endif;
	else
		self.filterReleaseNo := table.getValueByName(ETRow_FiltReleaseNo).String.toUpper.trimBlanks();
	endif;	
		
	if global.isValidObject(self.myFilterOperator) then
		self.filterOperatorCode := self.myFilterOperator.code.trimRight;
	else
		self.filterOperatorCode := null;
	endif;

	self.filterDateFrom 		:= table.getValueByName(ETRow_FilterDateRequestFrom).Date;
	self.filterDateTo 			:= table.getValueByName(ETRow_FilterDateRequestTo).Date;
	self.filterDateRequireFrom 	:= table.getValueByName(ETRow_FilterDateRequiredFrom).Date;
	self.filterFreeText 		:= table.getValueByName(ETRow_FilterFreeText).String;	
	self.filterPIN 				:= table.getValueByName(ETRow_FilterPIN).String.trimBlanks;	
	
	// Needs review - par 28696
	value	:= self.cmbFiltNeedsRev.listIndex;
	
	if value &gt; 0 then
		self.filterNeedsReview	:= value;
	else
		self.filterNeedsReview := self.FILTER_ALL;
	endif;
	
	// Stop EDI Updates - par 29480 April 2012
	value	:= self.cmbFiltStopEDIUp.listIndex;
	
	if value &gt; 0 then
		self.filterBlockEDIUpdates	:= value;
	else
		self.filterBlockEDIUpdates := self.FILTER_ALL;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="setFromMTContAvailEnq" id="c1bf2db8-ad76-4156-8224-86efd7e5dc7f">
        <updating/>
        <source>setFromMTContAvailEnq( brSet : CM_BulkReleaseSet ) updating;

/*

Purpose:			

Parameters:			Note this method is called via sendMsg from YardSchema
					in YRD_MTContAvailEnq::doMnuRelaseReqsEnq

Return Value:		


Date		Who		Reason
21/06/2011	cnwndl1	Initial creation	Par 27731
11/08/2011	cnwdap1	PAR #27972 Bulk release type no longer translatable, replaced by string condstants
*/

vars

	br : CM_BulkRelease;
	theRow		: Integer;
	breakOut	: Boolean;

begin

	self.cmbView.listIndex := 5; // Active &amp; Pending
	//self.cmbType.listIndex := self.cmbType.findStringExact(1,app.getErrorString(BR_TYPE_DESCR_ALL));	// PAR #27972
	self.cmbType.listIndex := self.cmbType.findStringExact(1,BR_TYPE_ALL_STR);							// PAR #27972
	
	self.doWindowEvents(1);
		
	foreach br in brSet do
		if (not self.tblData.findObjectInRow(br, theRow)) then
			self.addObjectToTable(br, theRow, breakOut);
		endif;
	endforeach;
	
	self.zTblDataColorRows();
	self.zHideSearcher();
	
	self.numItemsShown:=self.tblData.rows - self.tblData.fixedRows;
	self.showNumRowsShown();
epilog

end;</source>
        <Parameter name="brSet" type="CM_BulkReleaseSet"/>
    </JadeMethod>
