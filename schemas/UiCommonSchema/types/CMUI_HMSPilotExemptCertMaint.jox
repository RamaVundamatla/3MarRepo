    <JadeMethod name="translateForm" id="1271cf2b-5f70-494c-b36c-f2c98eb2ba5d">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0018771, locale);
	lblCertified.translateCaption(Xlat_0018772, locale);
	lblExpiry.translateCaption(Xlat_0018773, locale);
	lblLoaGrt.translateCaption(Xlat_0018774, locale);
	lblName.translateCaption(Xlat_0018775, locale);
	lblReValidate.translateCaption(Xlat_0018776, locale);
	lblValidated.translateCaption(Xlat_0018777, locale);
	lblVessel.translateCaption(Xlat_0018778, locale);
end;</source>
    </JadeMethod>
    <JadeMethod name="txtCertified_lostFocus" id="39387f5b-212b-4f7c-8352-bea966f6f769">
        <controlMethod name="CMUI_DateMask::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtCertified_lostFocus(editMask: JadeEditMask input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 April 2012	cnwndl1	Initial creation	Par 29496

*/

vars

	certDate : Date;
	revalDate : Date;

begin

	certDate := txtCertified.getDate();
	if certDate.isValid then
		revalDate := txtReValidate.getDate();
		if not revalDate.isValid then
			revalDate := certDate.cnEcAddYears(1);
			txtReValidate.setDate(revalDate);
		endif;
	endif;
epilog

end;</source>
        <Parameter name="editMask" type="JadeEditMask" usage="input"/>
    </JadeMethod>
</GUIClass>
