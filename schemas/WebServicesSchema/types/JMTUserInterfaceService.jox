    <JadeWebServicesMethod name="aaTemplate" id="8ec73ef5-f818-49fc-be09-6c72cd1b39c8">
        <source>aaTemplate(contact : WS_ContactRequest) : WS_ContactResponse webService;
/*

Purpose:			

Parameters:			

Return Value:		Response object (with errors)


Date		 Who	Reason
*/

vars
	response		: WS_ContactResponse;
	completedOK		: Boolean;
	user			: CM_User;
	
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
	
	user := app.getMyUser();
	if user = app.myPublicUser then 
		return null;
	endif;

	
	// ### QUERY and UPDATING etc here
	
	completedOK := true;
	return response;
epilog
	// Tidy up any local transients
	
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;

end;
</source>
        <Parameter name="contact" type="WS_ContactRequest"/>
        <ReturnType type="WS_ContactResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="addNewContact" id="e6c79413-8c7d-48da-85ca-e6e1d94ee964">
        <usesRPC>default</usesRPC>
        <source>addNewContact(contact : WS_ContactRequest) : WS_ContactResponse webService;

/*

Purpose:			Create a new Email Address contact for the current user.

Parameters:			Title and Email Address for new contact

Return Value:		Response object (with errors)


Date		 Who	Reason
13 Jan 2009	cnwdz2	PAR #17554 - Development of new RIA Web Service application
27 Jan 2009	cnwkpd1	PAR #17554 - Rework to user standard response class
17 Sep 2014 cnwmc5	PAR 34888 - a decision was made to remove the "allPrivateEmails" collection on CM_User.. 
								it was causing confusion (as it was only used by the RIA - and appeared to be giving no benefit) 
								as well as casuing errors on the RIA in cases where an email address exisited, but a user couldn't see it.
								From now on the RIA will only be using "allEmailsICanSee" on CM_User only.
*/

vars
	response		: WS_ContactResponse;
	completedOK		: Boolean;
	//lTitle,
	lEmailAddress	: String;
	iter			: Iterator;
	newEmail,		
	pxyEmailAddress	: CM_EmailAddress2;
	user			: CM_User;
	
	existingEmail	: CM_EmailAddress2;

begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
	
	user := app.getMyUser();
	if user = app.myPublicUser then 
		return null;
	endif;
	lEmailAddress := contact.emailAddress.trimBlanks.toLower;
	
	// Need to validate emails address to check it's not blanks for Web Service, because
	// transaction layer doesn't care
	if lEmailAddress = null then
	/*	app.raiseCMException1(REQUIRED_FIELD,
							  "Email Address",
							  null, 
							  null); */
		app.raiseCMException(Input_required_field_emlAddres,
					  null, 
					  null);

		completedOK := true;
		return response;
	endif;	
		
	// Check to see if this email address already exists in the system
	existingEmail := app.myRoot.allEmailAddressesByAddress[lEmailAddress];
	
	// If it does, and I already have access to it, then error
	if existingEmail &lt;&gt; null then
		if user.allEmailsICanSee.includes(existingEmail) then
			app.raiseCMException(Email_with_this_addre_alrea_ex,
								  null, 
								  null);
		endif;
		
		// If we update the existing email address, that will add it to the current user's list
		beginLoad;
		pxyEmailAddress := existingEmail.pxyCreateUpdateProxy();
		endLoad;
		app.myTrxUA.trxUpdateEmailAddress2(pxyEmailAddress, app.myPassport);		
	else
		// Attempt to create the new email address
		create pxyEmailAddress transient;

		pxyEmailAddress.setProxyForEmailAddress(contact.title.trimBlanks.truncatedAt(30), lEmailAddress, 0);
		app.myTrxCA.trxCreateEmailAddress2(pxyEmailAddress, newEmail, app.myPassport);	
	endif;
	
	// If we successfully updated or created an email address, then return it's details
	if newEmail &lt;&gt; null then
		create response.myEmailAddress;
		response.myEmailAddress.setProxyFromObject(newEmail);
	endif;
	
	completedOK := true;
	return response;
epilog
	// Tidy up any local transients
	delete pxyEmailAddress;
	
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;

end;
</source>
        <text>Create a new Email Address contact for the current user.</text>
        <wsdlName>addNewContact</wsdlName>
        <Parameter name="contact" type="WS_ContactRequest"/>
        <ReturnType type="WS_ContactResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="canCreateVoyageRequest" id="72cbfbf9-b078-44f9-b294-88368625ab51">
        <source>canCreateVoyageRequest()  : WS_Response webService;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
09 April 2018		jlger1	Initial creation
18 August 2022		jlizm1	TFS 54298 EUP - Simplified Voyage Work Order Process

*/

vars
	response : WS_Response;
	completedOK :Boolean;
	voyageStatus : CM_VoyageStatus;
	voyProcessDesc : String;
	terminal : CM_Terminal;
	voyageProcess : CM_VoyageProcess;	//27 Sep 2018	NDL	TFS 41109
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	// In particular this sets passport myUser and myTerminal
	self.initialisePassport();

	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
	
	terminal:=app.myPassport.myTerminal;
	
	//27 Sep 2018	NDL	TFS 41109
	voyageProcess := terminal.getDefaultVoyageProcess();
	if voyageProcess &lt;&gt; null then
		if voyageProcess.isMTNWOProcess then
			voyageStatus := app.myRoot.allVoyageStatuses[Voyage_Status_VoyRequested];
		elseif voyageProcess.isEUPDefaultProcess then									// TFS 54928
			voyageStatus := app.myRoot.allVoyageStatuses[Voyage_Status_EUP_VoyReq];		// TFS 54928
		endif;
	endif;
	if voyageStatus = null then
		//raise exception
		app.raiseCMException1(Voyage_process_create_voyage,"Voyage Requested",null,null);
		completedOK := true;
		return response;
	endif;
	
	if not voyageStatus.userCanSet(terminal) then
		app.raiseCMException2(Cannot_Set_Voyage_Status,terminal.code,voyageStatus.description,null,null);
		completedOK := true;
		return response;
	endif;
	
	completedOK := true;
	return response;
epilog
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
end;</source>
        <ReturnType type="WS_Response"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="canPackAllForRelease" id="5171020f-9816-42d1-b5c3-c544a0f67f60">
        <source>canPackAllForRelease(request : WS_FindBulkRelChildrenRequest) : WS_Response webService;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 Mar 2022	jlier1	Initial creation  TFS 52519
05 Mar 2025	navdap1	MTN-34024 PRP | Deadlock 1081, Yard Allocation &amp; Release Request Performance
*/

vars
	response		: WS_Response;
	completedOK		: Boolean;
	bulkRelease		: CM_BulkRelease;
	trackedItemList	: CM_TIByIdCargoTypeDict;
	reserveDetail	: CM_ReserveDetail;
	yardLocation	: CM_TerminalArea;
	hasChecks : Boolean;
	cmifAutoPlan	: CMIF_YAAutoPlanNormal;
	check 			: CM_CargoCheckItem;
	cargoCheck	  : CM_CargoCheck;
	ti : CM_TrackedItem;
	failedDAC 		: CM_DataAccessController;
	count			: Integer;		// MTN-34024
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	cnStartTransaction(method.qualifiedName[1:50]);

	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	// In particular this sets passport myUser and myTerminal
	self.initialisePassport();
	
	self.setIgnoreWarnings(true);
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
	
	if not  app.getMyUser.canDo(app.myPassport.myTerminal, PmHHAllowLoadAll) then
		app.raiseCMException(Cannot_pack_cargo_release,null,null);
		completedOK := true;
		return response;
	endif;
	
	if request.bulkReleaseOid = null and request.reserveDetailOid = null then
		completedOK := true;
		return response;
	endif;
	
	bulkRelease := app.myPassport.getObjectOfTypeFromOid(request.bulkReleaseOid, CM_BulkRelease).CM_BulkRelease;
	if bulkRelease = null then
		app.raiseCMException(Cannot_pack_cargo_release,null,null);
		completedOK := true;
		return response;
	endif;
	
	reserveDetail := app.myPassport.getObjectOfTypeFromOid(request.reserveDetailOid, CM_ReserveDetail).CM_ReserveDetail;
	yardLocation := app.myPassport.getObjectOfTypeFromOid(request.yardLocationOid, CM_TerminalArea).CM_TerminalArea;
	create trackedItemList  transient;
	bulkRelease.getProspectiveCargo(reserveDetail, yardLocation, null,null, trackedItemList, false, null, null, count);		// MTN-34024
	cargoCheck := app.myPassport.myTerminal.allCargoChecks[CARGO_CHECK_CONTEXT_PACK];
	hasChecks:=cargoCheck &lt;&gt; null and cargoCheck.allCargoCheckItems.first &lt;&gt; null;
	
	if trackedItemList.first = null then
		app.raiseCMException(Cannot_pack_cargo_release,null,null);
		completedOK := true;
		return response;
	endif;
	
	
	foreach ti in trackedItemList discreteLock where not  ti.isContainer() do
		if ti.hasBeenMerged then
			continue;
		endif;
			
		if not ti.canUserAccessSelf(app.getMyUser(), failedDAC, app.myPassport) then
			continue;
		endif;
			
			
		if ti.canSplitTotalQuantity then
			app.raiseCMException(Cannot_pack_cargo_release,null,null);
			completedOK := true;
			return response;
		endif;
		
		
		if hasChecks then
			delete cmifAutoPlan;
			create cmifAutoPlan transient;
			cmifAutoPlan.attachTI(ti);		
			foreach check in cargoCheck.allCargoCheckItems discreteLock do
				if  check.doesTIMatchMe(cmifAutoPlan) then	
					app.raiseCMException(Cannot_pack_cargo_release,null,null);
					completedOK := true;
					return response;
				endif;
			endforeach;
		endif;
	endforeach;
	
	// Got to here, everything is ok
	completedOK := true;
	return response;

	
epilog
	delete trackedItemList;
	delete cmifAutoPlan;
	
	if not completedOK then
		cnSetTransactionError(true);		
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction();


end;</source>
        <Parameter name="request" type="WS_FindBulkRelChildrenRequest"/>
        <ReturnType type="WS_Response"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="canSubmitVoyageRequest" id="113d270a-fa96-4e16-b6f1-471286fa2737">
        <source>canSubmitVoyageRequest() : WS_Response webService;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 Nov 2021	jlier1	Initial creation 52302
18 Aug 2022	jlizm1	TFS 54298 EUP - Simplified Voyage Work Order Process

*/

vars
	response : WS_Response;
	completedOK :Boolean;
	voyageStatus : CM_VoyageStatus;
	voyProcessDesc : String;
	terminal : CM_Terminal;
	voyageProcess : CM_VoyageProcess;	//27 Sep 2018	NDL	TFS 41109
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	// In particular this sets passport myUser and myTerminal
	self.initialisePassport();

	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
	
	terminal:=app.myPassport.myTerminal;
	
	//27 Sep 2018	NDL	TFS 41109
	voyageProcess := terminal.getDefaultVoyageProcess();
	
	if voyageProcess &lt;&gt; null then
		if voyageProcess.isEUPDefaultProcess then										// TFS 54298
			voyageStatus := app.myRoot.allVoyageStatuses[Voyage_Status_EUP_VoyReqSubm]; // TFS 54298
		else
			voyageStatus := app.myRoot.allVoyageStatuses[Voyage_Status_VoyReqSubmitted];
		endif;
	endif;
	
	if voyageStatus = null then
		//raise exception
		app.raiseCMException1(Voyage_process_create_voyage,"Voyage Submitted",null,null);
		completedOK := true;
		return response;
	endif;
	
	if not voyageStatus.userCanSet(terminal) then
		app.raiseCMException2(Cannot_Set_Voyage_Status,terminal.code,voyageStatus.description,null,null);
		completedOK := true;
		return response;
	endif;
	
	completedOK := true;
	return response;
epilog
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
end;
</source>
        <ReturnType type="WS_Response"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="cancelVehicleVisit" id="d585fcab-047a-46fc-9c7b-afe12e6c1941">
        <source>cancelVehicleVisit(request : WS_CancelVehicleVisitRequest) : WS_Response webService;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 January 2015	cnwmc5	Initial creation

*/

vars
	response		: WS_Response;
	completedOK		: Boolean;
	
	vvr				: CM_VehicleVisitRecord;
	terminal		: CM_Terminal;
	visitNumber		: String;
	
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	// In particular this sets passport myUser and myTerminal
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
	
	// Check security access to this message, if required
		//epr TFS 5535 17/8/17
	app.checkCurrentUserHasAccess(PmWebCancelVVR);	
	if app.myPassport.hasErrors then
		completedOK := true;
		return response;
	endif;
	
	terminal := app.myPassport.myTerminal;
	visitNumber := request.visitNumber;
	vvr := terminal.getVehicleVisitRecordByTran(visitNumber);
	
	if vvr = null then
		app.raiseCMException(Invalid_vehicle_visit_record, null, null);
		completedOK := true;
		return response;
	endif;
	
	if vvr.status = CM_VehicleVisitRecord.Status_Cancelled then 
		app.raiseCMException1(Vehicle_visit_cancelled, visitNumber, null, null);
		completedOK := true;
		return response;
	endif;
	
	if vvr.status = CM_VehicleVisitRecord.Status_Complete then	
		app.raiseCMException1(Vehicle_visit_complete, visitNumber, null, null);
		completedOK := true;
		return response;
	endif;
	
	self.setIgnoreWarnings(true);
	if vvr.myRoadJob &lt;&gt; null and not vvr.isUpdatable then
		app.myTrxUA.trxUpdateVVRCancelWithJob(vvr, request.cancellationReason, app.myPassport);
	else
		app.myTrxUA.trxUpdateVVRCancel(vvr, request.cancellationReason, app.myPassport);
	endif;
	
	// Got to here, everything is ok
	completedOK := true;
	return response;

epilog
	
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
	
end;</source>
        <Parameter name="request" type="WS_CancelVehicleVisitRequest"/>
        <ReturnType type="WS_Response"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="cancelVoyageRequest" id="97fe3574-dd79-4bf6-a748-c056c01a7b77">
        <source>cancelVoyageRequest(request : WS_UpdateRequest) : WS_Response webService;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 Sep 2021	jlier1	Initial creation 51963
19 Oct 2021 jlier1 TFS 52203
18 Aug 2022	jlizm1	TFS 54298 EUP - Simplified Voyage Work Order Process
26 Mar 2024	navpw1	TFS: 62849 (62927) - Reverted Code

*/

vars
	response : WS_Response;
	completedOK : Boolean;
	voyageStatus : CM_VoyageStatus;
	voyage : CM_Voyage;
	pxyDtl,
	woDtl : CM_WodVoyageRequest;
	pxyWorkOrder : CM_WorkOrder;
begin
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	// In particular this sets passport myUser and myTerminal
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
	
	// Check security access to this message, if required
	app.checkCurrentUserHasAccess(PmAdmVoyageDefEdit);		// Replace with appropriate permission
	
	if app.myPassport.hasErrors then
		completedOK := true;
		return response;
	endif;
	
	if app.myPassport.myTerminal = null then
		completedOK:=true;
		return response;
	endif;

	voyage:=app.myPassport.getObjectOfTypeFromOid(request.cmObjectId,CM_Voyage).CM_Voyage;
	if app.myPassport.hasErrors then
		completedOK := true;
		return response;
	endif;
	if voyage = null then
		app.raiseCMException(Input_required_field_voyage,null,null);
		completedOK:=true;
		return response;
	endif;	
	
	if voyage.status &lt;&gt; Voyage_Status_VoyRequested and 
		voyage.status &lt;&gt; Voyage_Status_VoyReqRejected  and
		voyage.status &lt;&gt; Voyage_Status_VoyReqSubmitted and
		voyage.status &lt;&gt; Voyage_Status_EUP_VoyReq and 
		voyage.status &lt;&gt; Voyage_Status_EUP_VoyReqRej  and
		voyage.status &lt;&gt; Voyage_Status_EUP_VoyReqSubm then
		
		app.raiseCMException2(Voyage_incorr_status_this_acti,voyage.code,voyage.statusDescription,null ,null);
		completedOK:=true;
		return response;
	endif;
	
	voyageStatus:=app.myRoot.allVoyageStatuses[Voyage_Status_VoyCancelled];
	if not voyageStatus.userCanSet(app.myPassport.myTerminal) then
		app.raiseCMException2(Cannot_Set_Voyage_Status, app.myPassport.myTerminal.code, voyageStatus.description, "status", null);
		completedOK:=true;
		return response;
	endif;
	
	woDtl := voyage.getWorkOrderForVoyageRequest();	
	if woDtl = null then
		app.raiseCMException(Input_required_field_voyage,null,null);
		completedOK := true;
		return response;
	endif;
	beginLoad;
		pxyWorkOrder:=woDtl.getMyParent.pxyCreateUpdateProxy.CM_WorkOrder;
	endLoad;
	
	pxyWorkOrder.setTaskStatus(WO_STATUS_CANCELLED);
	
	app.myPassport.setWarningsIgnored( true);
	app.myPassport.setWarningsAcknowledged( true);
	app.myTrxUA.trxUpdateWorkOrder(pxyWorkOrder,false,app.myPassport);
	
	// Got to here, everything is ok
	completedOK := true;
	return response;
	
epilog
	endLoad;
	delete pxyWorkOrder;
	
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				
	endif;

	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;

end;</source>
        <Parameter name="request" type="WS_UpdateRequest"/>
        <ReturnType type="WS_Response"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="changeRecord" id="c48b3299-e68d-4a75-8e32-7f190ba469c2">
        <usesRPC>default</usesRPC>
        <source>changeRecord(update: WS_UpdateRequestObject) : WS_Response webService;

/*

Purpose:			This method is designed for the JMT RIA.

Parameters:			

Return Value:		


Date		Who		Reason
28 Aug 2008	cnwcrs2	Initial creation
06 Oct 2008	cnwkao1 reworked
17 Mar 2014	cnwmc5	CCMS SFW 1368 - removing the JMTUpdateService
26/112020   cnwma1  Bug 50394: NXL-Cannot create prenote from RIA or SOAP
*/

vars
	updateReq       : WS_UpdateRequest;
	response		: WS_Response;
	completedOK		: Boolean;
	
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);

	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	//create updateService transient;
	//26.11.2020 cnwma1 #50394
	updateReq 						:= update.myUpdateRequest;
	if update.formName &lt;&gt; null then
		updateReq.warningsAcknowledged	:= true;
	endif;
	//26.11.2020 cnwma1 #50394
	
	if update.formName = WS_FormDefinition.Cargo_Notification then
		if update.operationType = WS_UpdateRequestObject.OperationType_Create then				
			response := self.createCargoNotifications(updateReq.WS_CargoNoteUpdateRequest);
		elseif update.operationType = WS_UpdateRequestObject.OperationType_Update then				
			response := self.updateCargoNotification(updateReq.WS_CargoNoteUpdateRequest);
		elseif update.operationType = WS_UpdateRequestObject.OperationType_Delete then
			response := self.deleteCargoNotification(updateReq.WS_CargoNoteUpdateRequest);		
		endif;		
	elseif update.formName = WS_FormDefinition.PreNotes then
		if update.operationType = WS_UpdateRequestObject.OperationType_Create then				
			response := self.createPreNote(updateReq.WS_PreNoteUpdateRequest);
		elseif update.operationType = WS_UpdateRequestObject.OperationType_Update then	
			response := self.updatePreNote(updateReq.WS_PreNoteUpdateRequest);
		elseif update.operationType = WS_UpdateRequestObject.OperationType_Delete then
			response := self.deletePreNote(updateReq.WS_PreNoteUpdateRequest);
		endif;
	elseif update.formName = WS_FormDefinition.Add_Attachments then
		if update.operationType = WS_UpdateRequestObject.OperationType_Create then
			response := self.createPreNoteAttachment(updateReq.WS_AttachmentUpdateRequest);
		elseif update.operationType = WS_UpdateRequestObject.OperationType_Update then	
			response := self.updatePreNoteAttachment(updateReq.WS_AttachmentUpdateRequest);
		endif;
	elseif update.formName = WS_FormDefinition.Cargo_Update_Request then
		if update.operationType = WS_UpdateRequestObject.OperationType_Create then				
			response := self.createCargoStops(updateReq.WS_CargoStopUpdateRequest);
		elseif update.operationType = WS_UpdateRequestObject.OperationType_Update then				
			response := self.updateCargoStop(updateReq.WS_CargoStopUpdateRequest);
		elseif update.operationType = WS_UpdateRequestObject.OperationType_Delete then
			response := self.deleteCargoStop(updateReq.WS_CargoStopUpdateRequest);		
		endif;
	elseif update.formName = WS_FormDefinition.Cargo_Rel_Import then
		if update.operationType = WS_UpdateRequestObject.OperationType_Update then				
			response := self.updateReleaseImport(updateReq.WS_ReleaseImportUpdateRequest);
		endif;
	elseif update.formName = WS_FormDefinition.VehicleBooking then	//08 May 2013	NDL Par 31393
		if update.operationType = WS_UpdateRequestObject.OperationType_Update then	
			response := self.updateVehicleBooking(updateReq.WS_VehicleBookingUpdateRequest);
		endif;
	//cnwmc5 - 10 Nov 2014 - CCMS 2429
	elseif update.formName = WS_FormDefinition.Release_Request then
		if update.operationType = WS_UpdateRequestObject.OperationType_Create then				
			response := self.createBulkRelease(updateReq.WS_BulkReleaseUpdateRequest);
		elseif update.operationType = WS_UpdateRequestObject.OperationType_Update then				
			response := self.updateBulkRelease(updateReq.WS_BulkReleaseUpdateRequest);
		elseif update.operationType = WS_UpdateRequestObject.OperationType_Delete then
			response := self.deleteBulkRelease(updateReq.WS_BulkReleaseUpdateRequest);		
		endif;
	endif;
	
	// Got to here, everything is ok
	completedOK := true;
	return response;
	

epilog
	// Tidy up any local transients
	//delete updateService;
	
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;

end;</source>
        <text>This method is designed for the JMT RIA only.</text>
        <wsdlName>changeRecord</wsdlName>
        <Parameter name="update" type="WS_UpdateRequestObject"/>
        <ReturnType type="WS_Response"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="checkPermissions" id="c2ab070c-632f-4f43-b90d-655230889707">
        <source>checkPermissions(checkPermRequest : WS_CheckPermissionRequest) : WS_CheckPermissionResponse webService;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 September 2011	cnwer1	Initial creation CCMS MES 1033
14 Dec 2011 moved from JMTSecureService and modified.

*/

vars

	ws_permission	: WS_Permission;
	response		: WS_CheckPermissionResponse;
	ws_permResponse	: WS_Permission;
	completedOK		: Boolean;
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	// In particular this sets passport myUser and myTerminal
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
	
	foreach ws_permission in checkPermRequest.allPermissions do
		if ws_permission.permission &gt; 0 then
			app.myPassport.clearErrorsWarnings; //epr 4/12/17 found web portal testing need to clear incase last one had an error
			ws_permission.canDo := app.checkCurrentUserHasAccess(ws_permission.permission);
			
			if app.myPassport.hasErrors then
				ws_permission.canDo := false;
			endif;
		else
			ws_permission.canDo := false;
		endif;
	//	app.myPassport.clearErrorsWarnings();
	endforeach;
		
	checkPermRequest.allPermissions.copy( response.allPermissions );
	
	// Perform validation, start populate response
	// ....
	
	
	// Got to here, everything is ok
	completedOK := true;
	return response;
	

epilog
	// Tidy up any local transients
	// ...
	
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;

end;</source>
        <Parameter name="checkPermRequest" type="WS_CheckPermissionRequest"/>
        <ReturnType type="WS_CheckPermissionResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="createAndMoveCargoForVoyage" id="4ac65c05-23b2-4dbc-9aee-685f5f9ebb37">
        <source>createAndMoveCargoForVoyage(request : WS_CargoItemUpdateRequest): WS_Response webService;
/*

Purpose: Creates a new cargo and moves the cargo onto the ship.	

Parameters:			

Return Value:		

Date			Who			Reason
10 April 2017	cnwam15		TFS 2731 Create and move cargo onto the ship
30 May 2017		cnwdap1		TFS 4449 STWR Mark and Mark Number field length adjustment
10 Nov 2017		cnwer1		TFS 7521 leaking transients
28 Jul 2021		navdap1		TFS 51604 MTN Cargo Lander - Add Cargo - Adding Bag of Sand getting Sub-Terminal error
13 Aug 202      navma1  	Bug 51757: MTN - Cargo Lander - Add Cargo - Vehicle - No saving all fields
26 May 2022		jlika1		TFS 53316 - EUP - GEN - Additional Dimensions For Cargo - PortSchema
28.06.2022		navsrk20	Task 53923: Implement shipping line in WS_CargoItemUpdateRequest
06 Jul 2022		jlizm1		TFS 53819 Cargo Lander add cargo - default imex status to import
18 Aug 2022		navma1		Bug 54368: MTN - Issues with Add Cargo form on mobile applications
07 Sep 2022     navma1		Bug 51775: MTN - Add Cargo from Cargo Lander and then try to edit through maintenance gives an error
25 Oct 2022 	navlw1		Bug 55211: MTN - Trailer Type doesn't able to Create or Update correctly from Mobile apps 
03 May 2023		navpw1		Defect: 57845: MTN - Mobile apps Create Cargo from Cargo Lander show error during reefer cargo creating 
25 May 2023		jlika1		TFS 56398 - EUP - OUT - Overlanded Cargo Handling - Web
24 Jun 2024 	navsck1 	ChangeRequest 63668: FR | 53891 - Delivery Dispatch - turn off other apps
*/

vars
	response				: WS_Response;
	completedOK				: Boolean;
	term					: CM_Terminal;
	cargoType				: CM_CargoType;
	product 				: CM_Product;
	destPortCode 			: String;
	location				: CM_LocationsController;
	voyage 					: CM_Voyage;
	operator 				: CM_Operator;
	ti 						: CM_TrackedItem;
	toDoTaskDesc 			: CM_ToDoTaskDesc;
	pxyTI 					: CM_TrackedItem;
	updController			: CMIF_TIUpdateController;
	tiSet					: CM_TISet;
	moveController 			: CMIF_MoveController;
	currentVoyages 			: CM_VoyageSet;
	voy 					: CM_Voyage;
	class					: Class;
	permissionsToCheck 		: IntegerArray;
	shippingLine			: CM_ShippingLine;		//28.06.2022 navsrk20 TFS 53923
	foundHeight			    : Integer;
	trailerType				: CM_TILCType;
	txnControlller			: CMIF_BBDiscrepancyController;
	newTITxn				: CM_TITransaction;
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	// In particular this sets passport myUser and myTerminal
	self.initialisePassport();
		
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	// Create the response
	create response transient;
	
	
	term := app.myPassport.myTerminal;
	if term = null then
		app.raiseCMException(Input_required_field_terminal,null,null);
		completedOK := true;
		return response;
	endif;
	//epr TFS 5535 4/8/17 if doing rail requests then check that
	create permissionsToCheck transient;
	//63668 =&gt; add the deliver dispatch app permission, this allows					//24.06.2024 navsck1 #63668
	//for the action to continue if the user has access to the underlaying
	//app via delivery dispatch even if the specific permission is not
	//given.
	permissionsToCheck.add(PmMobDeliveryDispatchApp);								//24.06.2024 navsck1 #63668
	permissionsToCheck.add(PmHandHeldLander);
	permissionsToCheck.add(PmHandHeldShipLander);
	
	
	app.myPassport.validateUserHasOnePermission(permissionsToCheck);
	if app.myPassport.hasErrors then
		completedOK :=true;
		return response;
	endif;
		
	
	
	cargoType :=app.myRoot.allCargoTypesById[request.cargoType.Integer];
	//06 Sep 2021	NDL	TFS 51773
	if cargoType = null then
		app.raiseCMException(ERR_INVALID_TI_TYPE, null, null);
		completedOK := true;
		return response;
	endif;

	product := cargoType.getProductFromCode(request.product);
	
	create currentVoyages transient;
	term.getAllCurrentVoyages(currentVoyages,true,true,false);
	
	foreach voy in currentVoyages do
		if voy.code = request.voyageCode then
			operator := voy.allOperators[request.operatorCode];
			voyage := voy;
			break;
		endif;
	endforeach;

	//location := voyage.myNotNotifiedStack;      										//07.09.2022 navma1 #51775
	term.findLocationFromString(request.voyageCode, false, location, foundHeight);      //07.09.2022 navma1 #51775
	
	create toDoTaskDesc as CM_ToDoTaskDesc transient;
	toDoTaskDesc := term.getConfig(DefNoInfoToDo).CM_ToDoTaskDesc;
	destPortCode := term.getConfig(PortDestCode).String;
		
	app.myPassport.clearErrorsWarnings();
	app.myPassport.setWarningsIgnored(true);
	
	create tiSet transient;
	
	if cargoType.id = TI_CargoType_Container then
		
		create pxyTI as CM_Container transient;
		
		pxyTI.setPxyFromDefaultTI(term,TI_CargoType_Container,request.id, request.commodityCode,operator);
		pxyTI.CM_Container.zSetPxyISOType(request.isoType);
		pxyTI.CM_Container.setMyVoyage(voyage, app.myPassport);
	else
		class := cargoType.myClassToCreate;
		
		create pxyTI as class transient;
		
		pxyTI.setCargoType(request.cargoType.Integer);
		pxyTI.zSetPxyId(request.id);
		pxyTI.zSetVoyageCodePAR25371(request.voyageCode);
		pxyTI.zSetPxyOperator(operator);
		pxyTI.setCommodity(request.commodityCode);
		pxyTI.zSetPxyTerminal(term);
		pxyTI.setMyProduct(product);
	endif;
	
	pxyTI.setReceiptTransportMode(TI_TRANSMODE_SHIP);	
	
	if request.imexStatus = null then	// TFS 53819
		// Default to IMPORT if imex status not specified
		pxyTI.setImExStatus(TI_IMEX_STATUS_IMPORT);
	else
		pxyTI.setImExStatus(request.imexStatus);
	endif;
	
	pxyTI.setDischargePort(destPortCode);
	//18.08.2022 navma1 #54368
	pxyTI.zSetPxyTotalQVW(request.quantity,request.numItems,request.volumeTotal.Decimal,request.weightTotal.Decimal); 
 
	//jlier1 TFS 56680 23/2/23
	if request.weightTare &lt;&gt; null then
		pxyTI.setWeightTare(request.weightTare.asDecimalJMT);
	endif;
 
	pxyTI.zSetPxyConsignee(request.consignee);
	pxyTI.zSetPxyLength(request.length.Decimal);
	pxyTI.zSetPxyHeight(request.height.Decimal);
	pxyTI.zSetPxyWidth(request.width.Decimal);
	pxyTI.setDestinationPort(request.destinationPort);	
	pxyTI.zSetPxyMark(request.mark[1:150]);					// TFS 4449 
	pxyTI.setVentilation(request.ventilation);
	// ### TFS 57845 03May2023 NAVPW1
	pxyTI.setTemperature(request.carriageTemp);
	// ### TFS 57845 03May2023 NAVPW1
	
	shippingLine := app.myRoot.allShippingLines[request.shippingLine];		//28.06.2022 navsrk20 TFS 53923
	pxyTI.setMyShippingLine(shippingLine);									//28.06.2022 navsrk20 TFS 53923			
	
	if toDoTaskDesc &lt;&gt; null then
		pxyTI.addToDoTask(toDoTaskDesc.description, app.myPassport);
	endif;
	
	//13.08.2021 navma1 51757
	if pxyTI.isKindOf(CM_Car) then 
		if request.carType &lt;&gt; null then
			pxyTI.CM_Car.setVehicleType(request.carType);
		endif;
		
		if request.model &lt;&gt; null then
			pxyTI.CM_Car.setModel(request.model);
		endif;
		
		if request.make &lt;&gt; null then
			pxyTI.CM_Car.setMake(request.make);								
		endif;
		
		if request.year &lt;&gt; null then			
			pxyTI.CM_Car.setYear(request.year);					
		endif;
	endif;
	
	// 25/10/2022 navlw1 tfs 55211
	if pxyTI.isKindOf(CM_TILC) then 
		if request.trailerType &lt;&gt; null then
			trailerType := cargoType.allTILCTypes[request.trailerType];
			if trailerType &lt;&gt; null then
				pxyTI.CM_TILC.setMyType(trailerType);
			endif;
		endif;
	endif;
	
	if pxyTI.isKindOf(CM_BreakBulkGeneric) then
		if  request.diameter &lt;&gt; null then
			pxyTI.CM_BreakBulkGeneric.setDiameter(request.diameter.asDecimalJMT);
		endif;
		
		if  request.grade &lt;&gt; null then
			pxyTI.CM_BreakBulkGeneric.setGrade(request.grade);
		endif;
		
		if  request.grammage &lt;&gt; null then
			pxyTI.CM_BreakBulkGeneric.setGrammage(request.grammage.asDecimalJMT);
		endif;
		
		if  request.rollingLength &lt;&gt; null then
			pxyTI.CM_BreakBulkGeneric.setRollingLength(request.rollingLength.asDecimalJMT);
		endif;
	endif;
	
	//jlika1 TFS 56398 --&gt;
	pxyTI.zSetPxyAlternativeId(request.alternativeId);
	pxyTI.zSetPxyCargoGroupId(request.cargoGroupId);
	pxyTI.zSetPxyMarkNumber(request.markNumber);
	pxyTI.zSetPxyRemarks(request.remarks);
	//jlika1 TFS 56398 &lt;--
	
	// TFS 51604 set subterminal on non-container cargo (set in pxyTI.setPxyFromDefaultTI for containers)	// TFS 51604
	if not cargoType.id = TI_CargoType_Container then														// TFS 51604
		if app.isSubTerminalsOn(term) then																	// TFS 51604
			pxyTI.setSubTerminalDefaultFromTerm(term);														// TFS 51604
		endif;																								// TFS 51604
	endif;																									// TFS 51604
	
	updController := app.createTIUpdateControl(TI_UPDMODE_NORMAL, app.getMyUserCode, null);
		
	tiSet.add(pxyTI);
	updController.setMyTransientTIs(tiSet);
	
	app.myPassport.clearErrorsWarnings;
	app.myPassport.setWarningsIgnored(true);
	
	app.myTrxCA.trxCreateTrackedItems(updController, app.myPassport);
	
	if app.myPassport.trxCompletedOK then
		app.myPassport.clearErrorsWarnings();
		ti := updController.allPersistentTIs.first;
	else
		app.myPassport.removeDuplicateWarnings();
		
		if app.myPassport.noErrors then
			app.myPassport.warningsAcknowledged	:= true;			
		else
			completedOK := true;
			return response;
		endif;
	endif;
	
	if request.isOverlanded then
		create txnControlller transient;
		txnControlller.type := TRANS_TYPE_OVERLANDED;
		txnControlller.myTrackedItem := ti;
		app.myTrxCA.trxCreateTITransaction(txnControlller, newTITxn, app.myPassport);
		delete txnControlller;
	endif;
	
	create moveController transient;
	moveController.setMyTrackedItem(ti);
	moveController.setMyToPrimaryLocation( location );
	moveController.isSystemMove := true;
	
	app.myPassport.clearErrorsWarnings;
	app.myPassport.setWarningsIgnored(true);
	app.myTrxUA.trxMoveTrackedItem(moveController, app.myPassport);
	
	if app.myPassport.trxCompletedOK then
		app.myPassport.clearErrorsWarnings();		
	else
		app.myPassport.removeDuplicateWarnings();
		
		if app.myPassport.noErrors then
			app.myPassport.warningsAcknowledged	:= true;			
		endif;
	endif;
	
	completedOK := true;	
	return response;
	
epilog
	delete updController; //epr TFS 7521 10/11/17
	delete tiSet;
	delete moveController;
	delete permissionsToCheck;
	delete currentVoyages;
	
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
end;</source>
        <Parameter name="request" type="WS_CargoItemUpdateRequest"/>
        <ReturnType type="WS_Response"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="createBooking" id="afb413e3-e6be-4dfa-8ac8-7bf169ffee36">
        <source>createBooking(bookingRequest : WS_BookingUpdateRequest) : WS_Response webService;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16/10/2014	cnwmc5	Initial creation
11/06/2015	cnwdap1	PAR #36421 Change in signature for CM_TIHazard::setProxy
09/11/2016	cnwdap1	TFS 2842 Hazardous Details Enhancements
05 Jun 2018	jlgrs1	TFS 39018 SNO Cargo Operator in COPRAR
30/09/2019	jlgzm1	TFS 46575 GUI, Web, EDI createing Booking ref items differently
15/01/2020	jlgdap1	TFS 47457 Web Portal Bookings
26/11/2021  navmj1  TFS 51856 Booking marks not being saved
14/01/2026	navtr3	MTN-36695 SNO - Release Empties - Thin client Webservices changes
*/

vars
	response		: WS_Response;
	completedOK		: Boolean;
	bookingRef,
	newBookingRef	: CM_BookingRef;
	wsBooking		: WS_Booking;
	destination,
	discharge		: String;
	consignee,
	consignor,
	freightFwder	: CM_ConsigneeConsignor;
	operator		: CM_Operator;
	voyage,
	transhipVoyage	: CM_Voyage;
	customsAgent,
	carrier			: String;
	newBulkRelease	: CM_BulkRelease;
	wsBookingItem	: WS_BookingItem;
	//bookingRefItem	: CM_BookingRefItem;
	bookingRefItem	: CM_BRefItemContainer; // TFS 46575
	cargoType		: CM_CargoType;
	dischargePorts	: StringArray;
	bookingHazards	: ObjectArray;
	temp			: Real;
	commodity,
	isoType,
	isoGroup		: String;
	hazards			: CM_HazardByCodeDict;
	tiHazard		: CM_TIHazard;
	wsTIHazard		: WS_TIHazard;
	failedDAC		: CM_DataAccessController;
	statusCode		: Integer;
	allBookHazards	: CM_HazardByCodeDict;
	permissionsToCheck   : IntegerArray;			// TFS 47457
	product 		: CM_Product;					// TFS 47457
	specialStow 	: CM_SpecialStow;				// TFS 47457
	allSpecialLifts	: CM_SpecialLiftByCodeDict;		// TFS 47457
	wsSpecialLift 	: WS_SpecialLift;				// TFS 47457
	specialLift		: CM_SpecialLift;				// TFS 47457
	hazardstoDelete	: ObjectArray;					// TFS 47457
	stevedore       : CM_Stevedore;
	// Release Empties variables					MTN-36695
	wsBulkRelease	: WS_BulkRelease;
	_pxyBulkRelease	: CM_BulkRelease;
	noFullsIn,
	noEmptiesOut	: Boolean;
	consigneeCode,
	consignorCode,
	carrierReleaseReqCode,
	freightForwarderCode,
	releaseId,	
	deliveryReasonDesc	: String;
	destinationPort,
	dischargePort,
	loadPort		: CM_Port;
	transType		: Integer;
	subTerminal		: CM_SubTerminal;
	deliveryReason	: CM_DeliveryReleaseReason;
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	// In particular this sets passport myUser and myTerminal
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
	
	// Check security access to this message, if required
	create permissionsToCheck transient;								// TFS 47457
	permissionsToCheck.add(PmGteBookingRefMaint);						// TFS 47457
	permissionsToCheck.add(PmWebBookingMaint);							// TFS 47457
	//app.checkCurrentUserHasAccess(PmGteBookingRefMaint);				// TFS 47457
	app.myPassport.validateUserHasOnePermission(permissionsToCheck);	// TFS 47457
	if app.myPassport.hasErrors then
		completedOK := true;
		return response;
	endif;
	
	wsBooking := bookingRequest.myBooking;
	
	create dischargePorts transient;
	create bookingHazards transient;
	create allBookHazards transient;
	create allSpecialLifts transient;									// TFS 47457
	create hazardstoDelete transient;									// TFS 47457
	
	destinationPort := null;
	if wsBooking.destination &lt;&gt; null then
		destination := wsBooking.destination.code;
		destinationPort := app.myRoot.allPorts[destination];
	endif;
	
	dischargePort := null;
	if wsBooking.dischargePort &lt;&gt; null then
		discharge := wsBooking.dischargePort.code;
		dischargePort := app.myRoot.allPorts[discharge];		
	endif;
	
	if wsBooking.consignee &lt;&gt; null then
		consignee := app.myRoot.allConsigneeConsignors[wsBooking.consignee.code];
		consigneeCode := consignee.code;
	endif;
	
	if wsBooking.consignor &lt;&gt; null then
		consignor := app.myRoot.allConsigneeConsignors[wsBooking.consignor.code];
		consignorCode := consignor.code;
	endif;
	
	if wsBooking.operator &lt;&gt; null then
		operator := app.myRoot.allOperators[wsBooking.operator.code];
	endif;
	
	if wsBooking.customsAgent &lt;&gt; null then
		customsAgent := wsBooking.customsAgent.code;
	endif;
	
	if wsBooking.freightForwarder &lt;&gt; null then
		freightFwder := app.myRoot.allConsigneeConsignors[wsBooking.freightForwarder.code];
		freightForwarderCode := freightFwder.code;
	endif;
	
	if wsBooking.carrier &lt;&gt; null then
		carrier := wsBooking.carrier.code;
	endif;
	
	if wsBooking.stevedoreCode &lt;&gt; null then                                  //02.10.2020 cnwma1 TFS #50112
		stevedore := app.myRoot.allStevedores[wsBooking.stevedoreCode];
	endif;
	
	if wsBooking.status &lt;&gt; null then
		statusCode := wsBooking.status.id;
	endif;
	
	// Check for WS_BulkRelease for Release Empties
	wsBulkRelease := wsBooking.bulkRelease;
	noEmptiesOut := false;
	if wsBulkRelease &lt;&gt; null then
		noEmptiesOut := true;
		noFullsIn := wsBulkRelease.noFullsIn;
	endif;	
	
	voyage := app.myPassport.myTerminal.lookupVoyage(wsBooking.voyageCode, null, false);
	transhipVoyage := app.myPassport.myTerminal.lookupVoyage(wsBooking.transhipOriginalVoyage, null, false);
	
	app.writeLog(method.qualifiedName &amp; Tab &amp; 'wsBooking.remarks is ' &amp; wsBooking.remarks, LogDEBUG);
	create bookingRef transient;
	bookingRef.setProxy(wsBooking.bookingReference,
						null,
						null,
						null,
						null,
						null,
						destination,
						discharge,
						null,		//review - myTranshipPort
						dischargePorts,
						bookingHazards,		//review - hazards
						NULL_HUMIDITY,
						false,
						null,
						consignor,
						consignee,
						operator,
						voyage,
						0,
						wsBooking.bookingRemarks,
						wsBooking.remarks,
						NULL_TEMPERATURE,
						NULL_VENTILATION,
						0,
						0,
						0,
						null,
						null,
						null,
						null,
						0,
						NULL_VOLUME,
						0,
						0,
						0,
						app.myPassport.myTerminal,
						null,
						true,
						wsBooking.isStockBooking,
						null,		//review - ediBookingRefTI
						null,		//review - rawEDIData
						wsBooking.shippingReference,
						carrier,
						null,
						null,
						null,		//review - custPriority
						null,		//review - specialStow
						null,		//review - holdPartials
						//null,		//review - noFullIsAllowedIn
						noFullsIn,	//noFullsAllowedIn
						//null,		//review - noEmptiesOut
						noEmptiesOut,		// Release Empties - set to true if WS_BulkRelease is present
						null,		//review - isMilitary
						null,		//review - vNumber
						null,		//review - overrideCutoff
						null,		//review - overDimension
						null,		//review - fumigationNeeded
						null,		//review - isStopped
						statusCode,
						null,
						null,		//review - specialLift
						null,		//review - allLinkedStockBookingItems
						wsBooking.receiveAsTranship,
						transhipVoyage,
						app.bookingPackAsStringToEnumb(wsBooking.packAs.toUpper),
						customsAgent,
						null,
						null,
						null,
						freightFwder,
						null, 	//carrier
						stevedore);              //02.10.2020 cnwma1 TFS #50112
	
	foreach wsBookingItem in wsBooking.allBookingItems do
		app.writeLog(method.qualifiedName &amp; Tab &amp; 'wsBookingItem weight for cargo ' &amp; wsBookingItem.cargoType.description &amp; ' is ' &amp; wsBookingItem.weight.String, LogDEBUG);
		if wsBookingItem.cargoType &lt;&gt; null then
			cargoType := app.myRoot.allCargoTypesById[wsBookingItem.cargoType.id];
			if cargoType = null then
				app.raiseCMException(ERR_INVALID_TI_TYPE, null, null);
				completedOK := true;
				return response;
			endif;
		endif;
		
		temp := wsBookingItem.temperature;
		if temp = 0 then
			temp := NULL_TEMPERATURE;
		endif;
		
		commodity := null;									// TFS 47457
		if wsBookingItem.commodity &lt;&gt; null then
			commodity := wsBookingItem.commodity.code;
		endif;
		
		isoType := null;									// TFS 47457
		if wsBookingItem.isoType &lt;&gt; null then
			isoType := wsBookingItem.isoType.code;
		endif;
		
		isoGroup := null;									// TFS 47457
		if wsBookingItem.isoGroup &lt;&gt; null then
			isoGroup := wsBookingItem.isoGroup.code;
		endif;
		
		// tidying up transient leaks - used to create hazards inside the check below, which meant
		// hazards wasn't initialized or cleared if a second or subsequent booking item didn't have hazards
		// Now to clear up the transient hazards created, copy them to a holding array and purge at the end
		if hazards &lt;&gt; null then								// TFS 47457
			hazards.copy(hazardstoDelete);					// TFS 47457
		endif;												// TFS 47457
		create hazards transient;							// TFS 47457
		if wsBookingItem.allTIHazards &lt;&gt; null and not wsBookingItem.allTIHazards.isEmpty then
			//create hazards transient;						// TFS 47457
			foreach wsTIHazard in wsBookingItem.allTIHazards do
				create tiHazard transient;
				//tiHazard.setProxy(	wsTIHazard.code,								// TFS 2842
				//					wsTIHazard.description,								// TFS 2842
				//					wsTIHazard.undgCodes,								// TFS 2842
				//					null,												// TFS 2842
				//					wsTIHazard.limitedQuantity.asBooleanJMT,			// TFS 2842
				//					null);												// TFS 2842
				tiHazard.setProxy(	wsTIHazard.code,									// TFS 2842
									wsTIHazard.description,								// TFS 2842
									wsTIHazard.undgCodes,								// TFS 2842
									null,												// TFS 2842
									wsTIHazard.limitedQuantity.asBooleanJMT,			// TFS 2842
									wsTIHazard.packingGroup,							// TFS 2842		// TFS 47457
									wsTIHazard.flashpointTemperature,					// TFS 2842		// TFS 47457
									wsTIHazard.marinePollutant,							// TFS 2842		// TFS 47457
									wsTIHazard.acidsBases	);							// TFS 2842		// TFS 47457
				hazards.add(tiHazard);
				allBookHazards.addNoDuplicates(tiHazard, false);
			endforeach;
		endif;
		
		// TFS 47457 product, special stow and special lifts
		product := null;
		if wsBookingItem.product &lt;&gt; null then
			if operator &lt;&gt; null then
				product := cargoType.allProducts[operator.code, wsBookingItem.product.code];
			endif;
			if product = null then
				product := cargoType.allProducts[null, wsBookingItem.product.code];
			endif;
		endif;
		specialStow := null;
		if wsBookingItem.specialStow &lt;&gt; null then
			specialStow := app.myRoot.allSpecialStows[wsBookingItem.specialStow];
		endif;
		allSpecialLifts.clear;
		foreach wsSpecialLift in wsBookingItem.allSpecialLifts do
			specialLift := app.myRoot.allSpecialLifts[wsSpecialLift.code];
			if specialLift &lt;&gt; null then
				allSpecialLifts.addNoDuplicates(specialLift, false);
			endif;
		endforeach;
		// TFS 47457
		
		//create bookingRefItem as bookingRef.getBookingRefItemClass(cargoType) transient;
		create bookingRefItem transient; // TFS 46575
		// TFS 47457 different setproxy methods for container and non-container
		if cargoType.isContainer then
			bookingRefItem.setProxy(cargoType.id,
									commodity,
									null,		//review - description
									wsBookingItem.remarks,
									hazards,
									isoType,
									wsBookingItem.quantity,
									wsBookingItem.weight,
									//null,		//review - maxToRelease
									//null,		//review - grade
									wsBookingItem.maxToRelease,		// Release Empties
									wsBookingItem.grade,			// Release Empties									
									wsBookingItem.humidity,
									temp,
									wsBookingItem.vent,
									wsBookingItem.ventUnits,
									wsBookingItem.carbonDioxide,
									wsBookingItem.oxygen,
									wsBookingItem.curtainsIn,
									//null,		//review - isClean
									//null,		//review - heavyRated
									wsBookingItem.clean,			// Release Empties
									wsBookingItem.heavyRated,		// Release Empties									
									specialStow,									// TFS 47457
									isoGroup,
									//null,		//review - inspected
									wsBookingItem.inspected,		// Release Empties
									allSpecialLifts,								// TFS 47457
									wsBookingItem.purchaseOrder,					// TFS 47457
									wsBookingItem.serviceOrder,						// TFS 47457
									wsBookingItem.matchMode);						//navra1 - CR 63764/Task 64227 - 23rd May 2024
									
		// TFS 47457 start
		else
			bookingRefItem.setProxyForCargo(cargoType.id,
											commodity,
											null,
											hazards,
											wsBookingItem.quantity,
											wsBookingItem.remarks,
											wsBookingItem.height,
											wsBookingItem.length,
											wsBookingItem.width,
											null,						// _heightString
											null,						// _lengthString
											null,						// _widthString
											null,						// _type
											wsBookingItem.density.Integer,
											wsBookingItem.volume,
											wsBookingItem.productQuantity,
											wsBookingItem.marks,		// _shippingMarks - TFS 51856
											wsBookingItem.weight,
											product,
											null,						// _ediBookingRefTI
											null,						// _rawEDIData
											wsBookingItem.generatorType,
											specialStow,
											wsBookingItem.cargoID,
											wsBookingItem.colour,
											wsBookingItem.markNumber,
											allSpecialLifts,
											wsBookingItem.productWeight,
											wsBookingItem.productVolume,
											wsBookingItem.trailerTypeCode,
											wsBookingItem.purchaseOrder,
											wsBookingItem.serviceOrder,
											wsBookingItem.matchMode);								//navra1 - CR 63764/Task 64227 - 23rd May 2024
		endif;
		// TFS 47457 end
		
		bookingRef.allBookingRefItems.add(bookingRefItem);
		
		if bookingRef.isReleaseEmptiesAllowed and noEmptiesOut then //Only Applicable to ISO Containers
			bookingRefItem.setProxyReserveDetail(wsBookingItem.quantity, wsBookingItem.maxToRelease, wsBookingItem.grade,wsBookingItem.heavyRated);
		endif;
	endforeach;
	
	if not bookingRef.canUserAccessSelf(app.getMyUser(), failedDAC, app.myPassport) then
		app.raiseCMException(ERR_dontHaveAccessToThisItem, null, null);
		completedOK := true;
		return response;
	endif;
	
	if not allBookHazards.isEmpty then
		bookingRef.setPxyHazards(allBookHazards);
	endif;		
	
	// Release Empties - Process WS_BulkRelease if present and booking allows release empties MTN-36695
	if wsBulkRelease &lt;&gt; null and bookingRef &lt;&gt; null and bookingRef.isReleaseEmptiesAllowed then
		_pxyBulkRelease := bookingRef.allReleaseRequests.first;
		if _pxyBulkRelease &lt;&gt; null then
			// Get values from WS_BulkRelease
			if wsBulkRelease.carrier &lt;&gt; null then
				carrierReleaseReqCode := app.myRoot.allCarriers[wsBulkRelease.carrier.code].code;
			endif;
			
			releaseId := wsBooking.bookingReference;
			
			if wsBulkRelease.transType = BR_TYPE_ROAD then
				transType := BR_TYPE_ROAD;
			elseif  wsBulkRelease.transType = BR_TYPE_RAIL then
				transType := BR_TYPE_RAIL;
			elseif  wsBulkRelease.transType = BR_TYPE_SHIP then
				transType := BR_TYPE_SHIP;
			endif;
			
			loadPort := null;
			if wsBulkRelease.myLoadPort &lt;&gt; null then
				loadPort := app.myRoot.allPorts[wsBulkRelease.myLoadPort.code];
			endif;
			
			if bookingRef.myTerminal.isSubTerminalsOn then
				if transType = BR_TYPE_PACKING then
					subTerminal := bookingRef.myTerminal.getConfig(MySubTerminalForSourceBulkPack).CM_SubTerminal;
				elseif transType = BR_TYPE_ROAD then
					subTerminal := bookingRef.myTerminal.getConfig(MySubTerminalForSourceBulkRoad).CM_SubTerminal;
				elseif transType = BR_TYPE_RAIL then
					subTerminal := bookingRef.myTerminal.getConfig(MySubTerminalForSourceBulkRail).CM_SubTerminal;
				endif;
			endif;
			
			foreach deliveryReason in app.myRoot.allDeliveryReasonselReasons do
				if deliveryReason.id = wsBulkRelease.deliveryReasonCode then
					deliveryReasonDesc := deliveryReason.description;
				endif;
			endforeach;			
			
			_pxyBulkRelease.setProxy(releaseId, //code same as this booking reference number
									transType,							//Release Empties
									true,
									BR_ACTIVE,
									null, ///availability grades null set on reserve selections
									null,//booking confirmation 
									carrierReleaseReqCode, //carrierId				//Release Empties
									null, //cargo remarks
									consigneeCode,		//consigneeCode
									null,
									consignorCode,		//consignor Code
									null,
									null,//_consignorVoyageCode 
									null, //date requested
									null,//_dateEstimatedRequired
									wsBulkRelease.deliveryReasonCode,//_deliveryReasonCode			//Release Empties
									deliveryReasonDesc,//_deliveryReasonDescr						//Release Empties
									wsBulkRelease.deliveryReleaseNumber,//_deliveryReleaseNumber	//Release Empties	
									null,//_doorsDirection
									null,//_freightPayerCode
									bookingRef,//CM_BookingRef
									loadPort,//_loadPort				//Release Empties
									destinationPort,//_destinationPort	
									dischargePort,//_dischargePort
									freightForwarderCode,//_freightForwarder
									null,//_transferToTerminal
									bookingRef.myTerminal,
									operator,//_operator
									null,//_operatorGroup
									voyage,//_voyage
									null,		//_businessUnit	
									null,		//_fullRelease	
									null,  //pack locations
									null,
									null,
									subTerminal,
									bookingRef.myTerminal.getConfig(MySubTerminalForTargetBulk).CM_SubTerminal, // subterm target
									null,
									false,
									customsAgent,
									false,
									false,
									_pxyBulkRelease.needsReview,
									_pxyBulkRelease.blockEDIUpdates,
									null,
									null,
									null,
									null
									);
		_pxyBulkRelease.requests.purge();
		endif;
	endif;
	
	self.setIgnoreWarnings(true);			//cnwmc5 - 5 Feb 2015 - PAR 35639
	
	app.myTrxCA.trxCreateBookingBulkRel(bookingRef, newBookingRef, newBulkRelease, app.myPassport);
	if newBookingRef &lt;&gt; null then
		app.writeLog(method.qualifiedName &amp; Tab &amp; 'newBookingRef.remarks is ' &amp; newBookingRef.remarks, LogDEBUG);
	endif;
	
	// Got to here, everything is ok
	completedOK := true;
	return response;
	
epilog
	// Tidy up any local transients
	delete bookingRef;
	delete dischargePorts;
	if hazards &lt;&gt; null and not hazards.isEmpty then
		hazards.purge();
	endif;
	if hazardstoDelete &lt;&gt; null then			// TFS 47457
		hazardstoDelete.purge;				// TFS 47457
	endif;									// TFS 47457
	delete hazardstoDelete;					// TFS 47457
	delete hazards;
	delete bookingHazards;
	delete allBookHazards;
	if allBookHazards &lt;&gt; null and not allBookHazards.isEmpty then
		allBookHazards.purge();
	endif;
	delete permissionsToCheck;				// TFS 47457
	delete allSpecialLifts;					// TFS 47457
	
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
end;</source>
        <Parameter name="bookingRequest" type="WS_BookingUpdateRequest"/>
        <ReturnType type="WS_Response"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="createBulkRelease" id="93d13c94-565d-4e97-a24a-121353f74690">
        <source>createBulkRelease(bulkReleaseRequest : WS_BulkReleaseUpdateRequest) : WS_BulkReleaseUpdateResponse webService;
/*

Purpose:			

Parameters:			

Return Value:		

/* Changes

Date		Name	TFS#	Description
============================================================================
16/10/2014	cnwmc5			Initial creation
24/01/2019	jlgka1			41708	As a result of the changes in the CM_BulkRelease.setProxy
							we also need to add myBOLIn here.
22/02/2019	jlgdap1			43487	PEL1 Error 11051 Application has aborted your request
16/09/2019  cnwma1			Bug 46485: JMT - Web Portal - Warnings do not show for updating release requests
19/07/2022	navtnr20		ChangeRequest 53974: EUP - OUT - Additional Fields on Release Line Level	
28 June 2023 navmv20 CR 58410 Task 58411: UI - Cargo Review - Release Request	
6/12/2023	navcs2	ChangeRequest 57537: EUP | Release Request By Type - with Weight															
============================================================================*/

vars
	response			: WS_BulkReleaseUpdateResponse;
	completedOK			: Boolean;
	pxyBulkRelease,
	newBulkRelease		: CM_BulkRelease;
	wsBulkRelease		: WS_BulkRelease;
	terminal,
	destTerminal		: CM_Terminal;			//cnwmc5 - 2 March 2015 - PAR 35777
	root				: CM_Root;
	dischargePort		: CM_Port;
	operator			: CM_Operator;
	voyage				: CM_Voyage;
	type				: Integer;
	pxyReserveTI		: CM_ReserveTI;
	pxyReserveSelection	: CM_ReserveSelection;
	wsReserveDetail 	: WS_ReserveDetail;
	wsReserveTI			: WS_ReserveTI;
	wsReserveSelection	: WS_ReserveSelection;
	ti					: CM_TrackedItem;
	cargoTypeID			: Integer;
	allTis 				: CM_TISet;
	wsTI				: WS_TrackedItem;
	cargoType			: CM_CargoType;
	isoType				: CM_ISOType;
	isoTypeGroup		: CM_ISOTypeGroup;
	product				: CM_Product;
	failedDAC			: CM_DataAccessController;
	statusCode			: Integer;
	carrier				: CM_Carrier;
	carrierCode			: String;
	consignee			: CM_ConsigneeConsignor;
	consigneeCode		: String;
	consignor			: CM_ConsigneeConsignor;
	consignorCode		: String;
	freightForwarder	: CM_ConsigneeConsignor;
	freightForwarderCode : String;
	infoMessage			: WS_InfoMessage;
	subTerminal			: CM_SubTerminal;
	requestDate			: TimeStamp;
	
	booking				: CM_BookingRef;		//cnwmc5 - 1 June 2016 - TFS 2039
	bolIn				: CM_BOLIn; 			// jlgka1 TFS 41708
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	// In particular this sets passport myUser and myTerminal
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
	
	// Check security access to this message, if required
	app.checkCurrentUserHasAccess(PmGteEmptyReleaseMaintAll);
	if app.myPassport.hasErrors then
		completedOK := true;
		return response;
	endif;
	
	// Perform validation, start populate response
	wsBulkRelease := bulkReleaseRequest.myBulkRelease;
	
	root := app.myRoot;
	terminal := app.myPassport.myTerminal;
	
	if wsBulkRelease.dischargePort &lt;&gt; null then
		dischargePort := root.allPorts[wsBulkRelease.dischargePort.code];
	endif;
	
	if wsBulkRelease.operator &lt;&gt; null then
		operator := root.allOperators[wsBulkRelease.operator.code];
	endif;
	
	if wsBulkRelease.carrier &lt;&gt; null then
		carrier := root.allCarriers[wsBulkRelease.carrier.code];
		if carrier &lt;&gt; null then
			carrierCode := carrier.code;
		endif;
	endif;
	
	if wsBulkRelease.consignee &lt;&gt; null then
		consignee := root.allConsigneeConsignors[wsBulkRelease.consignee.code];
		if consignee &lt;&gt; null then
			consigneeCode := consignee.code;
		endif;
	endif;
	
	if wsBulkRelease.consignor &lt;&gt; null then
		consignor := root.allConsigneeConsignors[wsBulkRelease.consignor.code];
		if consignor &lt;&gt; null then
			consignorCode := consignor.code;
		endif;
	endif;
	
	if wsBulkRelease.freightForwarder &lt;&gt; null then
		freightForwarder := root.allConsigneeConsignors[wsBulkRelease.freightForwarder.code];
		if freightForwarder &lt;&gt; null then
			freightForwarderCode := freightForwarder.code;
		endif;
	endif;
	
	if wsBulkRelease.type &lt;&gt; null then
		type := wsBulkRelease.type.id;
	endif;
	
	voyage := terminal.lookupVoyage(wsBulkRelease.voyageCode, null, false);
	
	if wsBulkRelease.status &lt;&gt; null then
		statusCode := wsBulkRelease.status.id;
		if statusCode &lt;&gt; BR_ACTIVE and statusCode &lt;&gt; BR_PENDING then			//cnwmc5 - 13 November 2014 - CCMS 2429
			app.raiseCMException1(ERR_INVALID_StatusBulkRelease, wsBulkRelease.status.description, null, null);
			completedOK := true;
			return response;
		endif;
	endif;
	
	if wsBulkRelease.mySubTerminal &lt;&gt; null then
		subTerminal := app.myRoot.allSubTerminals[wsBulkRelease.mySubTerminal.code];
	endif;
	
	//cnwmc5 - 2 March 2015 - PAR 35777
	if wsBulkRelease.destinationTerminal &lt;&gt; null then
		destTerminal := app.myRoot.allTerminals[wsBulkRelease.destinationTerminal.code];
	endif;
	
	//cnwmc5 - 1 June 2016 - TFS 2039
	if wsBulkRelease.booking &lt;&gt; null then
		
		//epr TFS 5535 9/8/17
		booking:=app.myPassport.getObjectOfTypeFromOid(wsBulkRelease.booking.cmObjectId,CM_BookingRef).CM_BookingRef;
		if app.myPassport.hasErrors then
			completedOK:=true;
			return response;
		endif;
	endif;
	//jlgka1 TFS 41708 --&gt; set for null for now I don't know yet if we are going to add this to the web apps
	if not wsBulkRelease.releaseByType then
		bolIn := null;
	endif;
	//jlgka1 TFS 41708 &lt;--
	requestDate.setDate(wsBulkRelease.requestDate.asDateFromWebInterface);		//cnwmc5 - 26 Nov 2014 - CCMS 2429
	requestDate.setTime(wsBulkRelease.requestTime.asTimeFromWebInterface);		//cnwmc5 - 26 Nov 2014 - CCMS 2429
	
	create pxyBulkRelease transient;
	pxyBulkRelease.setProxy(wsBulkRelease.releaseNo,
							type,
							wsBulkRelease.releaseByType,
							statusCode,
							null,		//review - availGrades			wsBulkRelease.allMTGrades
							wsBulkRelease.bookingConfirmation,	//review?
							carrierCode,
							wsBulkRelease.remarks,			//cnwmc5 - 12 Nov 2014 - CCMS 2429
							consigneeCode,
							null,		//review - consigneeDesc
							consignorCode,
							null,		//review - consignorDesc
							wsBulkRelease.consignorVoyageCode,
							requestDate,					//cnwmc5 - 26 Nov 2014 - CCMS 2429
							wsBulkRelease.estimatedRequiredDate.asTimeStampFromWebInterface,
							null,
							null,		//review - deliveryReleaseDescr
							wsBulkRelease.deliveryReleaseNumber,
							null,		//review - doorsDriection
							wsBulkRelease.freightPayerCode,
							booking,		//review - bookingRef			//cnwmc5 - 1 June 2016 - TFS 2039
							null,		//review - loadPort
							null,		//review - destinationPort
							dischargePort,
							freightForwarderCode,
							destTerminal,		//review - transferToTerminal			//cnwmc5 - 2 March 2015 - PAR 35777
							terminal,
							operator,
							null,		//review - operatorGroup
							voyage,
							null,		//review - businessUnit		wsBulkRelease.businessUnit
// TFS 2686							null,		//review - removeStops
							wsBulkRelease.fullRelease,		//review - fullRelease
							null,		//review - allPackLocations		wsBulkRelease.packLocation
							null,		//review - poolPartner
							null,		//review - dispatchLocn
							subTerminal,
							null,		//review - subTerminalTarget
							null,		//review - assignedTrain
							true,		//review - allowCargoOnMultiRel	// 23/02/2015 cnwar2 #35735 - default to true
							null,		//review - customsAgent
							null,		//review - cusotmsAssistance
							true,		//review - canBeHiLowCube		// 23/02/2015 cnwar2 #35735 - default to true
							null,		//review - needsReview
							null,		//review - stopEDIUpdates
							null,		//review - allEDIFiles
							null,		// expiryTimeStamp 13 Feb 2017	NDL	TFS 3368
							bolIn,		//jlgka1 TFS 41708
							null	// ### TFS 53953 27June2022 NAVPW1
							);
	
	//cnwmc5 - 13 March 2015 - PAR 35864
	//weightType := app.getDefaultMeasurementForType(Type_Weight);		// TFS 43487
	//volumeType := app.getDefaultMeasurementForType(Type_Volume);		// TFS 43487
	
	foreach wsReserveDetail in wsBulkRelease.allReserveDetails do
		// cnwma1 - 04.05.2018 ChangeRequest 37957
		wsTI := null;
		ti := null;
		cargoType:= null;
		product :=null;
		cargoTypeID := null;
		//volume := null;						// TFS 43487
		//weight := null;						// TFS 43487
		isoType := null;
		isoTypeGroup := null;
		
		if wsReserveDetail.isKindOf(WS_ReserveTI) then
			wsReserveTI := wsReserveDetail.WS_ReserveTI;
			wsTI := wsReserveTI.myTrackedItem;
			
			create pxyReserveTI transient;
			pxyBulkRelease.allReserveDetails.add(pxyReserveTI);			//cnwmc5 - 26 Nov 2014 - CCMS 2429
			
			//Attempt to get the cargo item by look at the 'myTrackedItem' and see if they have provided an OID..
			//If not, go looking up cargo items, break-bulk may have more than 1 for that ID..
			if wsTI &lt;&gt; null and wsTI.cmObjectId &lt;&gt; null then
				//epr TFS 5535 4/8/17
				ti:=app.myPassport.getObjectOfTypeFromOid(wsTI.cmObjectId,CM_TrackedItem).CM_TrackedItem;			
				if ti &lt;&gt; null  then
					  pxyReserveTI.allTrackedItems.add(ti);
				else
					//Couldn't find the tracked item..
					app.raiseCMException1(Cargo_item_not_found, wsTI.idTextBox, null, null);
					completedOK := true;
					return response;
				endif;	
			else
				if wsReserveTI.cargoType &lt;&gt; null then
					cargoTypeID := wsReserveTI.cargoType.id;
				endif;
				
				if wsReserveTI.cargoID &lt;&gt; null and cargoTypeID &lt;&gt; null then
					delete allTis;
					create allTis transient;
					//cnwmc5 - 24 Nov 2014 - CCMS 2429
					//terminal.lookupAllOnShipTrackedItems(wsReserveTI.cargoID, cargoTypeID, true, false, allTis, null);
					//terminal.lookupAllOnsiteTrackedItems(cargoTypeID, wsReserveTI.cargoID, allTis, null);
					//terminal.lookupAllNotifiedOnsiteTIs(cargoTypeID, wsReserveTI.cargoID, allTis, null);
					terminal.lookupTIsForIDCargoTypeVoyage(wsReserveTI.cargoID, cargoTypeID, voyage, allTis);
					
					//Create an error here, contain all onsite TIs and return them for user to choose one then make another request..
					if allTis.size &gt; 1 then
						//Found more than 1 tracked item and them to the responses collection to return for choosing..
						foreach ti in allTis do
							create wsTI transient;
							wsTI.setProxyFromObject(ti);
							response.allTrackedItems.add(wsTI);
						endforeach;
						app.raiseCMException1(Multiple_cargo_items_search, wsReserveTI.cargoID, null, null);
						completedOK := true;
						return response;
					endif;
					
					
					
					if allTis.size = 1 then
						ti := allTis.first;												//cnwmc5 - 18 Dec 2014 - PAR 35320
						pxyReserveTI.addTI(ti);
						
						pxyReserveTI.setTotalRequested(wsReserveTI.totalQuantity);	//cnwmc5 - 18 Dec 2014 - PAR 35320
						
						//cnwmc5 - 13 March 2015 - PAR 35864 - begin
						cargoType := ti.myCargoType;
						product := ti.myProduct;
						
						if cargoType &lt;&gt; null
						and cargoType.isBulkByVolume then
							if product = null then
								product := cargoType.mySystemProductType;
							endif;
							
							//volume := app.convertMeasurementForStorage(volumeType.shortName, wsReserveTI.totalVolume.Decimal);	// TFS 43487
							//pxyReserveTI.setWeightRequested(volume * product.myDensity.value);									// TFS 43487
							pxyReserveTI.setWeightRequested(wsReserveTI.totalVolume.Decimal * product.myDensityDec.value);			// TFS 43487 // ### TFS 52193 22Nov2021 NAVPW1
						else
							//weight := app.convertMeasurementForStorage(weightType.shortName, wsReserveTI.totalWeight.Decimal);	// TFS 43487
							//pxyReserveTI.setWeightRequested(weight);																// TFS 43487
							pxyReserveTI.setWeightRequested(wsReserveTI.totalWeight.Decimal);										// TFS 43487
						endif;
						//cnwmc5 - 13 March 2015 - PAR 35864 - end
					else
						//Couldn't find the tracked item..
						app.raiseCMException1(Cargo_item_not_found, wsReserveTI.cargoID, null, null);
						completedOK := true;
						return response;
					endif;
				endif;
			endif;
			
		elseif wsReserveDetail.isKindOf(WS_ReserveSelection) then
			wsReserveSelection := wsReserveDetail.WS_ReserveSelection;
			
			if wsReserveSelection.cargoType &lt;&gt; null then
				cargoType := root.allCargoTypesById[wsReserveSelection.cargoType.id];
				if cargoType = null then
				app.raiseCMException(ERR_INVALID_TI_TYPE, null, null);
					completedOK := true;
					return response;
				endif;
			endif;
			
			if wsReserveSelection.isoType &lt;&gt; null then
				isoType := root.allISOTypes[wsReserveSelection.isoType.code];
			endif;
			
			if wsReserveSelection.isoGroup &lt;&gt; null then
				isoTypeGroup := root.allISOTypeGroups[wsReserveSelection.isoGroup.code];
			endif;
			
			if wsReserveSelection.product &lt;&gt; null and cargoType &lt;&gt; null and cargoType.hasProductTypes then
				product := cargoType.getProductFromCode(wsReserveSelection.product.code);
			endif;
			
			//cnwmc5 - 13 March 2015 - PAR 35864 - begin
			if cargoType &lt;&gt; null
			and cargoType.isBulkByVolume then
				if product = null then
					product := cargoType.mySystemProductType;
				endif;
				
			//	volume := app.convertMeasurementForStorage(volumeType.shortName, wsReserveSelection.totalVolume.Decimal);	// TFS 43487
			//else																											// TFS 43487
			//	weight := app.convertMeasurementForStorage(weightType.shortName, wsReserveSelection.totalWeight.Decimal);	// TFS 43487
			endif;
			
			create pxyReserveSelection transient;
			pxyReserveSelection.setProxy(	null,		//review - packType
											cargoType,
											null,		//review - bookRefItemObj
											isoType,
											isoTypeGroup,
											product,
											null,		//review - productStr
											wsReserveSelection.remarks,
											wsReserveSelection.totalRequested,
											null,		//review - allAvailGrades
											wsReserveSelection.clean,
											null,		//review - doISOGroupCheck
											wsReserveSelection.heavyDuty,
											null,		//review - maskIds
											null,		//review - maxToRelease
											null,		//review - color
											null,		//review - descriptionSelection
											null,		//review - heightSelection
											null,		//review - lengthSelection
											null,		//review - markNumber
											null,		//review - quantitySelection
											null,		//review - remarksSelection
											//volume,	//review - volumeSelection		//cnwmc5 - 13 March 2015 - PAR 35864
											//weight,	//review - weightSelection		//cnwmc5 - 13 March 2015 - PAR 35864
											wsReserveSelection.totalVolume.Decimal,					// TFS 43487
											wsReserveSelection.totalWeight.Decimal,					// TFS 43487
											null,		//review - widthSelection
											null,		//review - markSelection
											null,		//review - densitySelection
											null,		//review - typeSelection
											null,		//review - terminalArea
											null,		//review - myReceivalBOL
											null,		//review - bestPick
											null,		//review - sequence
											null,null,null,null,null,false,false,null,null,null,null,null,null,null,null,
											null,	// ### TFS 53953 11July2022 NAVPW1
											null,null,  //12-07-2022 navtnr20 53974
											null,		//28/06/2023 navmv20 CR 58410 Task 58411
											false,     // 6/12/2023 navcs2 ChangeRequest 57537
											terminal.getConfig(LocnByOldestTransArrival).Boolean,		//19/02/2023	navkc1 CR 60078 Task 62450
											null,  //24/04/2025	navrv30	MTN 34319
											null);
			pxyReserveSelection.setWeightRequested(wsReserveSelection.totalWeight.Decimal);			// TFS 43487
			
			pxyBulkRelease.allReserveDetails.add(pxyReserveSelection);
			pxyReserveSelection.setLineNumber(pxyBulkRelease.getNextLineNumber(pxyReserveSelection)); //05.09.2022 navma1 #54714
		endif;
	endforeach;
	
	if not pxyBulkRelease.canUserAccessSelf(app.getMyUser(), failedDAC, app.myPassport) then
		app.raiseCMException(ERR_dontHaveAccessToThisItem, null, null);
		completedOK := true;
		return response;
	endif;
	
	//Do the create trx...
	app.myPassport.setWarningsIgnored(bulkReleaseRequest.warningsAcknowledged); 			//12/09/2019 cnwma1 #46485
	app.myTrxCA.trxCreateBulkRelease(pxyBulkRelease, newBulkRelease, null, app.myPassport);
	
	//Attach PIN number to response..
	if app.myPassport.allErrors.isEmpty() and newBulkRelease &lt;&gt; null then
		create infoMessage transient;	
		if newBulkRelease.getPinNumber() &lt;&gt; null then
			infoMessage.text :=	app.getErrorString2(Release_request_added_pin,newBulkRelease.code, newBulkRelease.getPinNumber() );
		else
			infoMessage.text :=app.getErrorString1(Release_request_added,newBulkRelease.code);
		endif;	
		response.allInfo.add(infoMessage);
	endif;
	
	// Got to here, everything is ok
	completedOK := true;
	return response;
	
epilog
	// Tidy up any local transients
	delete pxyBulkRelease;
	delete allTis;
	
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
	
end;</source>
        <Parameter name="bulkReleaseRequest" type="WS_BulkReleaseUpdateRequest"/>
        <ReturnType type="WS_BulkReleaseUpdateResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="createCargoDamage" id="1292c1f4-7a88-426a-b659-a7624b724916">
        <source>createCargoDamage(cargoDamageRequest : WS_CargoDamageUpdateRequest) : WS_Response webService;

/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 July 2015	cnwmc5	Initial creation
11 July 2022	navak20	TFS 53862 EUP - WMS - Damage Recording Extra Details
*/

vars

	response 		: WS_Response;
	completedOK 	: Boolean;	
	wsDamage	 	: WS_Damage;
	cargoId			: String;
	wsCargoType		: WS_CargoType;
	terminal 		: CM_Terminal;
	ti,
	pxyTI			: CM_TrackedItem;
	
	//damSev 			: Integer;			// 11.07.2022 navak20 TFS 53862
	damSev 			: CM_DamageSeverity;	// 11.07.2022 navak20 TFS 53862
	damPos 			: CM_DamagePosition;
	damType 		: CM_DamageDefinitionCode;
	isLoadStateSet	: Boolean;
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	cnStartTransaction(method.qualifiedName[1:50]);

	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;

	// Initialise the passport for the new transaction
	// In particular this sets passport myUser and myTerminal
	self.initialisePassport();
	
	self.setIgnoreWarnings(cargoDamageRequest.warningsAcknowledged);
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
	terminal := app.myPassport.myTerminal;
	
	// Check security access to this message, if required
	app.checkCurrentUserHasAccess(PmHHDamageReport);		// Replace with appropriate permission
	if app.myPassport.hasErrors then
		completedOK := true;
		return response;
	endif;	
	
	wsDamage := cargoDamageRequest.damage;
	cargoId := cargoDamageRequest.cargoId;
	wsCargoType := cargoDamageRequest.cargoType;
	
	if cargoId = null or wsCargoType = null or wsDamage = null then
		//app.raiseCMException1( ,alertMsg, null, null);
		completedOK := true;
		return response;
	endif;

	//epr TFS 5535 4/8/17 
	ti := app.myPassport.getObjectOfTypeFromOid(cargoDamageRequest.cmObjectId,CM_TrackedItem).CM_TrackedItem;
	if app.myPassport.hasErrors then
		completedOK:=true;
		return response;
	endif;
	
	
	damPos := app.myRoot.allDamagePositionsByCode[wsDamage.myDamagePosition.code].CM_DamagePosition;
	damType := app.myRoot.allDamageDefinitionCodes[wsDamage.myDamageCode.code].CM_DamageDefinitionCode;
	//damSev := wsDamage.severity;		// 11.07.2022 navak20 TFS 53862
	damSev := terminal.allDamageSeverities[wsDamage.severity.String];	 // 11.07.2022 navak20 TFS 53862
	
	//if ti = null or damPos = null or damType = null or damSev = 0 then		// 11.07.2022 navak20 TFS 53862
	if ti = null or damPos = null or damType = null or damSev = null then		// 11.07.2022 navak20 TFS 53862
		//app.raiseCMException( , null, null);
		completedOK := true;
		return response;
	endif;
	
	app.cmsBeginLoad(isLoadStateSet);
	pxyTI		:=	ti.pxyCreateUpdateProxy();
	app.cmsEndLoad(isLoadStateSet);
	
	pxyTI.setDamaged(true);
	//pxyTI.createPxyDamageInstance(damType, damPos, null, true, wsDamage.quantity, damSev, false, null);		// 11.07.2022 navak20 TFS 53862
	pxyTI.createPxyDamageInstance(damType, 
								  damPos,
								  null, 
								  true, 
								  wsDamage.quantity, 
								  damSev, 
								  null,
								  null, 
								  null, 
								  null, 
								  null, 
								  null, 
								  app.actualTimeServer,    // 07.09.2022 navma1 #53862 ***** Pending*****
								  null, 
								  null, 
								  null	// July 1, 2022 navak20 TFS 53862
									);
	app.myTrxUA.trxUpdateTIDamage(pxyTI, app.myPassport);
	
	// Got to here, everything is ok
	completedOK := true;
	return response;
	
epilog
	app.cmsEndLoad(isLoadStateSet);
	delete pxyTI;
	
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
	
end;</source>
        <Parameter name="cargoDamageRequest" type="WS_CargoDamageUpdateRequest"/>
        <ReturnType type="WS_Response"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="createCargoNotifications" id="87475c49-0fe0-4f53-890f-10dc4aba0ad4">
        <usesRPC>default</usesRPC>
        <source>createCargoNotifications(cargoCreateRequest : WS_CargoNoteUpdateRequest) : WS_CargoNoteUpdateResponse webService;

/*

Purpose:			Create Cargo Notification(s) within JMT. These will behave like JMT created notifications and can be maintained from the 
					Cargo Notification Request screen.

Parameters:			None

Return Value:		


Date		Who		Reason
21 Jul 2008	cnwkpd1	PAR #17554 - Development of new RIA Web Service application
10 Sep 2008	cnwkao1	modified
29 Jan 2009	cnwkpd1	Completed data security check
08/04/2011	cnwmh5	PAR #27347 - Add cmsEndLoad or endLoad to epilog so that if error occurs it will not leave it in beginLoad state
*/

vars
	response		: WS_CargoNoteUpdateResponse;
	completedOK		: Boolean;
	requestType		: WS_RequestType;
	
	tmpUser 		: CM_User;
	cmifEventReq 	: CMIF_EventRequestController;
	pxyEmail,
	realEmail 		: CM_EventRequestEmail;
	pxyRequestNotify : CM_EventRequestNotification;
		
	cargoType 		: CM_CargoType;
	organisation 	: CM_Organisation;
	
	addresses 		: CM_StringArray;
	stringAddresses	: StringArray;
	requestTypeObj	: CM_Object;
	
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);

	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);

	// Create the response
	create response transient;
	
	// Check security access to this message
	app.checkCurrentUserHasAccess(PmEventReqNotifyMaint);
	if app.myPassport.hasErrors then
		completedOK := true;
		return response;
	endif;
	
	// Perform validation of input - code cloned from CMUI_EventRequestModal::doSaveNotify, setProxyEventRequest
	create pxyRequestNotify transient;
	
	tmpUser := app.getMyUser;
	cargoType := app.myRoot.allCargoTypesById[cargoCreateRequest.myCargoType];
	organisation := app.myRoot.allOrganisations[cargoCreateRequest.myOrganisation];
	
	// Validate User access to organisation here
	if organisation &lt;&gt; null and not tmpUser.canUserAccessObj(organisation, CM_Organisation) then
		app.raiseCMException3(ERR_USER_NO_ACCESS,
							  tmpUser.code, 
							  "Organisation",
							  organisation.name,
							  null, 
							  null);
		
	endif;
	
	
	// Get email addresses - needs to be refactored later
	create stringAddresses transient;
	cargoCreateRequest.emailAddresses.getTrimedTokensForDelimiter(";", stringAddresses); //18/03/2009 cnwdz2 par19178
	create addresses transient;
	stringAddresses.copy(addresses);
	
	pxyRequestNotify.setProxyRequestNotify(addresses,						// _addresses		: CM_StringArray; 
										   cargoCreateRequest.remarks,		// _remarks, 
										   null,							// _cargoId		: String;
										   tmpUser,							// _user			: CM_User;
										   cargoType,						// _cargoType		: CM_CargoType;
										   pxyRequestNotify.myTrackedItem,	// _trackedItem	: CM_TrackedItem;
										   organisation,					// _organisation	: CM_Organisation;
										   app.getMyTerminalDO_NOT_USE(),						// _root			: CM_Root;
										   pxyRequestNotify.status,			// _status			: Integer;
										   pxyRequestNotify.eventType,		// _eventType,
										   pxyRequestNotify.eventName,		// _eventName		: String;
										   null,							// _eventKey,
										   null,							// _eventTypeNew	: Integer; 
										   cargoCreateRequest.reference,	// _ref : String; 
										   false,							// _noCleanup : Boolean) updating;
										   false );							// isEDI
	
	if not cargoCreateRequest.allNotifyTimes.isEmpty then
		beginLoad;
		realEmail := tmpUser.allEventRequestEmail[pxyRequestNotify.type];
		if realEmail &lt;&gt; null then
			pxyEmail := realEmail.pxyCreateUpdateProxy();
		else
			create pxyEmail transient;
		endif;
		pxyEmail.setProxy(app.myRoot, tmpUser, pxyRequestNotify.type, cargoCreateRequest.allNotifyTimes);
		endLoad;
	endif;
	

	// Create update request
	create cmifEventReq transient;
	cmifEventReq.myPxyEventRequestEmail := pxyEmail;		
	cmifEventReq.myPxyEventRequestNotify := pxyRequestNotify;
	cmifEventReq.cargoIds := cargoCreateRequest.cargoId;
	
	foreach requestType in cargoCreateRequest.allRequestTypes do
		requestTypeObj := app.getObjectForRequestTypeString(requestType.description);
		if requestTypeObj &lt;&gt; null then
			cmifEventReq.allEventNames.add(requestType.description);
			cmifEventReq.allSelectedObjects.add(requestTypeObj);
		else
			// Invalid request type
			app.raiseCMException3(ERR_USER_NO_ACCESS,
								  tmpUser.code,
								  'Request type',
								  requestType.description,
								  null, 
								  null);
			
			completedOK := true;
			return response;
		endif;
	endforeach;


	// Perform update	
	app.myTrxUA.trxUpdateEventRequest(cmifEventReq, app.myPassport);					

	// If result is OK, then set up response return values
	if app.myPassport.trxCompletedOK then
		response.numberActioned := cmifEventReq.numActioned;
		response.numberMatchFailed := cmifEventReq.numMatchFailed;
		response.numberPending := cmifEventReq.numPending;
	endif;
	
	
	// Got to here, everything is ok
	completedOK := true;
	return response;
	

epilog
	endLoad;				// 08/04/2011 cnwmh5 #27347
	// Tidy up local transients
	delete pxyRequestNotify;
	delete pxyEmail;
	delete addresses;
	delete stringAddresses;
	delete cmifEventReq;
	
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
	
end;</source>
        <text>Create Cargo Notification(s) within JMT. These will behave like JMT created notifications and can be maintained from the Cargo Notification Request screen.</text>
        <Parameter name="cargoCreateRequest" type="WS_CargoNoteUpdateRequest"/>
        <ReturnType type="WS_CargoNoteUpdateResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="createCargoRelease" id="aed8217c-65af-436b-b08e-5b5d1c56109a">
        <source>createCargoRelease( request : WS_BulkReleaseUpdateRequest) : WS_BulkReleaseUpdateResponse webService;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 May 2018	jlger1	Initial creation 38519

*/

vars
	response			: WS_BulkReleaseUpdateResponse;
	completedOK			: Boolean;
	pxyBulkRelease,
	newBulkRelease		: CM_BulkRelease;
	wsBulkRelease		: WS_BulkRelease;
	terminal		: CM_Terminal;			//cnwmc5 - 2 March 2015 - PAR 35777
	operator 			: CM_Operator;
	type				: Integer;
	pxyReserveTI		: CM_ReserveTI;
	wsReserveDetail 	: WS_ReserveDetail;
	wsReserveTI			: WS_ReserveTI;
	ti					: CM_TrackedItem;
	cargoTypeID			: Integer;
	allTis 				: CM_TISet;
	wsTI				: WS_TrackedItem;
	operatorDAC,
	failedDAC			: CM_DataAccessController;
	infoMessage			: WS_InfoMessage;
	expiryDate,
	requestDate			: TimeStamp;
	
begin
// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	// In particular this sets passport myUser and myTerminal
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
	
	// Check security access to this message, if required
	app.checkCurrentUserHasAccess(PmWebCargoReleaseAdd);
	if app.myPassport.hasErrors then
		completedOK := true;
		return response;
	endif;
	
	terminal := app.myPassport.myTerminal;
	
	if terminal = null then
		completedOK := true;
		return response;
	endif;
	
	operatorDAC:= app.myPassport.myUser.allDataAccessControllers[CM_Operator.name];
	if operatorDAC &lt;&gt; null and  not operatorDAC.mustNotBeIncluded then
		operator:= operatorDAC.allObjects.first.CM_Operator;
	endif;

	requestDate:=app.actualTimeAppServer;
	expiryDate:=requestDate.addDays(2);
	wsBulkRelease:= request.myBulkRelease;
	
	create pxyBulkRelease transient;
	pxyBulkRelease.setProxyBasic(null,
							BR_TYPE_ROAD,
							false,
							BR_ACTIVE,
							terminal,
							operator,
							null,
							requestDate,					//cnwmc5 - 26 Nov 2014 - CCMS 2429
							expiryDate		// expiryTimeStamp 13 Feb 2017	NDL	TFS 3368
							);
	
	
	foreach wsReserveDetail in wsBulkRelease.allReserveDetails do
		// cnwma1 - 04.05.2018 ChangeRequest 37957
		wsTI := null;
		ti := null;
		
		if wsReserveDetail.isKindOf(WS_ReserveTI) then
			wsReserveTI := wsReserveDetail.WS_ReserveTI;
			wsTI := wsReserveTI.myTrackedItem;
			
			create pxyReserveTI transient;
			pxyBulkRelease.allReserveDetails.add(pxyReserveTI);			//cnwmc5 - 26 Nov 2014 - CCMS 2429
			
			//Attempt to get the cargo item by look at the 'myTrackedItem' and see if they have provided an OID..
			//If not, go looking up cargo items, break-bulk may have more than 1 for that ID..
			if wsTI &lt;&gt; null and wsTI.cmObjectId &lt;&gt; null then
				//epr TFS 5535 4/8/17
				ti:=app.myPassport.getObjectOfTypeFromOid(wsTI.cmObjectId,CM_TrackedItem).CM_TrackedItem;			
				if ti &lt;&gt; null  then
					  pxyReserveTI.allTrackedItems.add(ti);
					  if operator = null  and ti.myOperator &lt;&gt; null then  
							pxyBulkRelease.setDetailsFromTI(ti);
						endif;
				else
					//Couldn't find the tracked item..
					app.raiseCMException1(Cargo_item_not_found, wsTI.idTextBox, null, null);
					completedOK := true;
					return response;
				endif;	
			else
				if wsReserveTI.cargoType &lt;&gt; null then
					cargoTypeID := wsReserveTI.cargoType.id;
				endif;
				
				if wsReserveTI.cargoID &lt;&gt; null and cargoTypeID &lt;&gt; null then
					delete allTis;
					create allTis transient;
					terminal.lookupTIsForIDCargoTypeVoyage(wsReserveTI.cargoID,TI_CargoType_Container, null, allTis);
					
					//Create an error here, contain all onsite TIs and return them for user to choose one then make another request..
					if allTis.size &gt; 1 then
						//Found more than 1 tracked item and them to the responses collection to return for choosing..
						foreach ti in allTis do
							create wsTI transient;
							wsTI.setProxyFromObject(ti);
							response.allTrackedItems.add(wsTI);
						endforeach;
						app.raiseCMException1(Multiple_cargo_items_search, wsReserveTI.cargoID, null, null);
						completedOK := true;
						return response;
					endif;
					
									
					if allTis.size = 0 then

						//Couldn't find the tracked item..
						app.raiseCMException1(Cargo_item_not_found, wsReserveTI.cargoID, null, null);
						completedOK := true;
						return response;
					endif;
				endif;
			endif;
		endif;	
			
		
	endforeach;
	
	if not pxyBulkRelease.canUserAccessSelf(app.getMyUser(), failedDAC, app.myPassport) then
		app.raiseCMException(ERR_dontHaveAccessToThisItem, null, null);
		completedOK := true;
		return response;
	endif;
	
	app.myPassport.setWarningsIgnored(true);
	app.myPassport.setWarningsAcknowledged(true);
	
	//Do the create trx...
	app.myTrxCA.trxCreateBulkRelease(pxyBulkRelease, newBulkRelease, null, app.myPassport);
	
	//Attach PIN number to response..
	if app.myPassport.allErrors.isEmpty() and newBulkRelease &lt;&gt; null then
		create infoMessage transient;	
		if newBulkRelease.getPinNumber() &lt;&gt; null then
			infoMessage.text :=	app.getErrorString2(Release_request_added_pin,newBulkRelease.code, newBulkRelease.getPinNumber() );
		else
			infoMessage.text :=app.getErrorString1(Release_request_added,newBulkRelease.code);
		endif;	
		response.allInfo.add(infoMessage);
	endif;
	
	// Got to here, everything is ok
	completedOK := true;
	return response;
	
epilog
	// Tidy up any local transients
	delete pxyBulkRelease;
	delete allTis;
	
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;

end;</source>
        <Parameter name="request" type="WS_BulkReleaseUpdateRequest"/>
        <ReturnType type="WS_BulkReleaseUpdateResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="createCargoReleaseFromFile" id="b44943ee-c158-4b19-8a1a-5ab42d3cd55f">
        <source>createCargoReleaseFromFile(_request : WS_LoadVoyageEDIPrenoteRequest)  : WS_BulkReleaseUpdateResponse webService;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16/07/2018	jlger1	Initial creation 39642
14/02/2019	jlgdap1	TFS 43062 Allow for voyage oid as well as external voyage code
20/02/2019	jlgdap1	TFS 43431 PEL1 Container Services - Release Request Expiry Date
*/

vars

	response			: WS_BulkReleaseUpdateResponse;
	completedOK			: Boolean;
	realBulkRelease,
	pxyBulkRelease,
	newBulkRelease		: CM_BulkRelease;

	terminal		: CM_Terminal;			//cnwmc5 - 2 March 2015 - PAR 35777
	operator 			: CM_Operator;
	pxyReserveTI		: CM_ReserveTI;
	ti					: CM_TrackedItem;
	operatorDAC			: CM_DataAccessController;
	infoMessage			: WS_InfoMessage;
	expiryDate,
	requestDate			: TimeStamp;
	releaseNo			: String; 
	voyage 				: CM_Voyage;
	containerID,
	bolID,
	line,
	fileName,
	fileData : String;
	theLines : HugeStringArray;
	messageData : StringArray;
	allRealBulkReleases,
	allPxyBulkReleases : CM_BulkReleaseByCodeDict;
	ts						: TimeStamp;
	generatedId 		: String;
	ffCode : String;	//06 Mar 2019	NDL	TFS 43673
	pxyTi : CM_TrackedItem;	//11 Mar 2019	NDL	TFS 43673
	allPxyTis : CM_TISet;		//11 Mar 2019	NDL	TFS 43472 
	hasSkippedFirstLine : Boolean;	//03 May 2019	NDL	TFS 44570
begin
// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	// In particular this sets passport myUser and myTerminal
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
	
	// Check security access to this message, if required
	app.checkCurrentUserHasAccess(PmWebCargoReleaseAdd);
	if app.myPassport.hasErrors then
		completedOK := true;
		return response;
	endif;
	
	terminal := app.myPassport.myTerminal;
	
	if terminal = null then
		completedOK := true;
		return response;
	endif;
	
	operatorDAC:= app.myPassport.myUser.allDataAccessControllers[CM_Operator.name];
	if operatorDAC &lt;&gt; null and  not operatorDAC.mustNotBeIncluded then
		operator:= operatorDAC.allObjects.first.CM_Operator;
	endif;
	
	voyage:= app.myPassport.myTerminal.allVoyagesByExternalCode[_request.externalVoyageCode.toUpper];
	if voyage = null then
		voyage := app.myPassport.getObjectOfTypeFromOid(_request.externalVoyageCode, CM_Voyage).CM_Voyage;	// TFS 43062
	endif;																									// TFS 43062
	/* epr TFS 43879 18/3/19
	if voyage = null then																					// TFS 43062
		//epr TFS 39416 10/7/18
		app.raiseCMException1(Voyag_not_found_with_exter_voy, _request.externalVoyageCode, null, null);
		completedOK := true;
		return response;
	endif;*/
	
	
	if _request.myDocument = null or _request.myDocument.documentBytes = null then
		app.raiseCMException(File_been_selecte_load,null,null);
		completedOK := true;
		return response;
	endif;
	ts.setDate('12/12/9999'.Date); 
	fileData :=  _request.myDocument.documentBytes.String; //.compressToBinary(Binary.Compression_ZLib);
	fileData := fileData.replaceString(CrLf, Cr);
	fileData := fileData.replaceString(Lf, Cr);
	
	fileName := _request.myDocument.fileName;
	create theLines transient;
	fileData.getHugeTokensForDelimiter(Cr, theLines);
	
	create messageData transient;
	create allPxyBulkReleases transient;
	create allPxyTis transient;	//11 Mar 2019	NLD	TFS 43472 

	requestDate:=app.actualTimeAppServer;
	expiryDate:=requestDate.addDays(2);
	foreach line in theLines do
		//03 May 2019	NDL	TFS 44570 - Always skip the first line.
		if not hasSkippedFirstLine then
			app.writeLog(method.qualifiedName &amp; " Skipping - " &amp; line, LogDEBUG);	//26 Nov 2019	NDL	TFS 47053
			hasSkippedFirstLine := true;
			continue;
		endif;
		
		app.writeLog(method.qualifiedName &amp; " " &amp; line, LogDEBUG);	//26 Nov 2019	NDL	TFS 47053
		pxyBulkRelease:=null;
		messageData.clear;
		line.csvToStringArray(messageData, ",");	
		if messageData.size &gt;= 3 then
			containerID:=messageData[1];
			if containerID = null then
				continue;
			endif;
			bolID		:=messageData[2];
			//releaseNo:=messageData[3];							// TFS 43431
			releaseNo:=messageData[3].trimBlanks.toUpper;			// TFS 43431
			if messageData.size &gt; 3 then
				expiryDate:=messageData[4].asTimeStampFromWebInterface;
			endif;
			if releaseNo &lt;&gt; null then
				pxyBulkRelease :=allPxyBulkReleases.getAtKeyGeq(releaseNo, ts);
				if pxyBulkRelease &lt;&gt; null and pxyBulkRelease.code &lt;&gt; releaseNo then
					pxyBulkRelease:=null;
				endif;
			endif;
			ti:=terminal.allOnsiteTIsByCargoTypeId[TI_CargoType_Container,containerID];
			if ti = null then
				//Couldn't find the tracked item..
				app.raiseCMException1(Cargo_item_not_found, containerID, null, null);
				completedOK := true;
				return response;
			endif;
			
			if pxyBulkRelease = null then
				realBulkRelease:=terminal.getBulkReleaseFromCode(releaseNo);
				if realBulkRelease &lt;&gt; null then
					if realBulkRelease.allTrackedItemsAssigned.includes(ti) then
						continue;
					endif;
					beginLoad;
						pxyBulkRelease:=realBulkRelease.pxyCreateUpdateProxy;
					endLoad;
				else
					create pxyBulkRelease transient;
					pxyBulkRelease.setProxyBasic(releaseNo,BR_TYPE_ROAD,false,BR_ACTIVE,terminal,operator,voyage,requestDate,expiryDate);
					if releaseNo = null then
						generatedId:=pxyBulkRelease.code;
					endif;
				endif;
				allPxyBulkReleases.add(pxyBulkRelease);
			endif;
				
			create pxyReserveTI transient;
			pxyBulkRelease.allReserveDetails.add(pxyReserveTI);	
			pxyReserveTI.allTrackedItems.add(ti);
			if operator = null  and ti.myOperator &lt;&gt; null then  
				pxyBulkRelease.setDetailsFromTI(ti);
			endif;
			
			//06 Mar 2019	NDL	TFS 43673
			if messageData.size &gt; 4 then
				ffCode := messageData[5].trimBlanks;
			endif;
//			if ffCode &lt;&gt; null then
			if ffCode &lt;&gt; null or bolID &lt;&gt; null then	//27 Mar 2019	NDL	TFS 43936
//				pxyBulkRelease.setPxyFreightForwarderCode( ffCode );  //14 Mar 2019	NDL	TFS 43846 to reverse original request in 43673
				
				//11 Mar 2019	NDL	TFS 43673
				beginLoad;
				pxyTi := ti.pxyCreateUpdateProxy();
				endLoad;
				if pxyTi &lt;&gt; null then
					allPxyTis.add( pxyTi );
					if ffCode &lt;&gt; null then
						pxyTi.zSetPxyFreightFowarderCode( ffCode );
					endif;
					//27 Mar 2019	NDL	TFS 43936
					if bolID &lt;&gt; null then		
						pxyTi.setBOL( bolID );
					endif;
				endif;
				
			endif;
			
		endif;

	endforeach;
	
	
	create allRealBulkReleases transient;
	
	//11 Mar 2019	NDL	TFS 43673 - Move below Bulkrelease updates plus new Cargo update to a single trx.
	while true do
		allRealBulkReleases.clear();
		app.myTrxUA.trxCreateCargoReleaseFromFile( allRealBulkReleases, allPxyBulkReleases, allPxyTis, app.myPassport );
	
		if app.myPassport.trxCompletedOK then
			break;
		elseif app.myPassport.noErrors then
			app.myPassport.warningsAcknowledged	:= true;
			continue;
		endif;
		break;
			
	endwhile;
	
/*	foreach pxyBulkRelease in allPxyBulkReleases discreteLock do
		//Do the create trx...
		app.myPassport.setWarningsIgnored(true);
		app.myPassport.setWarningsAcknowledged(true);
		if pxyBulkRelease.pxyGetRealObject = null then		
			app.myTrxCA.trxCreateBulkRelease(pxyBulkRelease, newBulkRelease, null, app.myPassport);
			if newBulkRelease &lt;&gt; null then
				allRealBulkReleases.add(newBulkRelease);
			endif;
		else			
			app.myTrxUA.trxUpdateBulkRelease(pxyBulkRelease,null,app.myPassport);
			if not app.myPassport.trxCompletedOK then
				break;
			endif;
			allRealBulkReleases.add(pxyBulkRelease.pxyGetRealObject);
		endif;
	endforeach; */
	
	//Attach PIN number to response..
	foreach realBulkRelease in allRealBulkReleases do
		
		create infoMessage transient;	
		if realBulkRelease.getPinNumber() &lt;&gt; null then
			infoMessage.text :=	app.getErrorString2(Release_request_added_pin,realBulkRelease.code, realBulkRelease.getPinNumber() );
		else
			infoMessage.text :=app.getErrorString1(Release_request_added,realBulkRelease.code);
		endif;	
		response.allInfo.add(infoMessage);
		
	endforeach;
	
	// Got to here, everything is ok
	completedOK := true;
	return response;
	
epilog
	// Tidy up any local transients
	if allPxyBulkReleases &lt;&gt; null then
		allPxyBulkReleases.purge;
		delete allPxyBulkReleases;
	endif;
	//11 Mar 2019	NDL	TFS 43673
	if allPxyTis &lt;&gt; null then
		if not allPxyTis.isEmpty then
			allPxyTis.purge();
		endif;
		delete allPxyTis;
	endif;
	
	delete allRealBulkReleases;
	delete messageData;
	delete theLines;
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
end;</source>
        <Parameter name="_request" type="WS_LoadVoyageEDIPrenoteRequest"/>
        <ReturnType type="WS_BulkReleaseUpdateResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="createCargoStops" id="540c447b-d7a1-4246-8380-2c89c526489a">
        <usesRPC>default</usesRPC>
        <source>createCargoStops(cargoCreateRequest : WS_CargoStopUpdateRequest) : WS_CargoStopUpdateResponse webService;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 Sep 2008	cnwkao1	Initial creation - similar to KPD's create cargo notes method
08/04/2011	cnwmh5	PAR #27347 - Add cmsEndLoad or endLoad to epilog so that if error occurs it will not leave it in beginLoad state
28 Jun 2017	cnwkpd1	TFS 5180 - 1090 exception in epilog leads to hanging CardSchema transaction
06 Jun 2018 cnwma1	Bug 38847: Weird Error - "Voyage of item underneath is different"
16 Sep 2019 cnwma1	Bug 46485: JMT - Web Portal - Warnings do not show for updating release requests
*/

vars
	response		: WS_CargoStopUpdateResponse;
	completedOK		: Boolean;
	tmpUser 		: CM_User;
	cmifEventReq 	: CMIF_EventRequestController;
	organisation 	: CM_Organisation;

begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);

	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
	
	// Check security access to this message
	app.checkCurrentUserHasAccess(PmEventReqStopsMaint);
	if app.myPassport.hasErrors then
		completedOK := true;
		return response;
	endif;	
	
	// Perform validation of input - code cloned from CMUI_EventRequestModal::doSaveNotify, setProxyEventRequest
	tmpUser 		:= app.getMyUser;
	organisation 	:= app.myRoot.allOrganisations[cargoCreateRequest.myOrganisation];
	
	// Validate User access to organisation here - TBC
	if not tmpUser.canUserAccessObj(organisation, CM_Organisation) then
		app.raiseCMException1(User_does_have_access_organi, organisation.name, null, null);
		completedOK := true;
		return response;
	endif;
	
	create cmifEventReq transient;
	cargoCreateRequest.createAllPxyCargoUpdates(cmifEventReq);

	//self.setIgnoreWarnings(true); //6.6.2018 cnwma1 Bug #38847                //12/09/2019 cnwma1 #46485
	app.myPassport.setWarningsIgnored(cargoCreateRequest.warningsAcknowledged); //12/09/2019 cnwma1 #46485
	// Perform update	
	app.myTrxUA.trxUpdateEventRequest(cmifEventReq, app.myPassport);					

	// If result is OK, then set up response return values
	if app.myPassport.trxCompletedOK then
		response.numberActioned		:= cmifEventReq.numActioned;
		response.numberMatchFailed	:= cmifEventReq.numMatchFailed;
		response.numberPending		:= cmifEventReq.numPending;
	endif;
	
	
	// Got to here, everything is ok
	completedOK := true;
	return response;
	

epilog
	endLoad;				// 08/04/2011 cnwmh5 #27347


	// TFS 5180 - Protect against null cmifEventReq if validation causes early exit
	if cmifEventReq &lt;&gt; null then
		cmifEventReq.allPxyCargoUpdateRequests.purge;
		delete cmifEventReq;
	endif;
	
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
	
end;</source>
        <Parameter name="cargoCreateRequest" type="WS_CargoStopUpdateRequest"/>
        <ReturnType type="WS_CargoStopUpdateResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="createChildCargo" id="afdbe8e7-0ae0-47eb-9a35-d8cce411e0f1">
        <source>
createChildCargo(request : WS_CargoItemUpdateRequest) : WS_TrackedItemUpdateResponse webService;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who			Reason
11 Oct 2016		cnwma1		Initial creation
28.06.2022		navsrk20	Task 53923	: Implement shipping line in WS_CargoItemUpdateRequest
25 Oct 2022		navlw1		Bug 55211	: MTN - Trailer Type doesn't able to Create or Update correctly from Mobile apps 
26 May 2023		jlika1		TFS 56398 - EUP - OUT - Overlanded Cargo Handling - Web
24 Jun 2024 	navsck1 ChangeRequest 63668: FR | 53891 - Delivery Dispatch - turn off other apps

*/

vars
	response				: WS_TrackedItemUpdateResponse;
	completedOK				: Boolean;
	term					: CM_Terminal;
	cargoType				: CM_CargoType;
	product 				: CM_Product;
	container				: CM_TrackedItem;
	id 						: String;
	operator 				: CM_Operator;
	commodity 				: CM_Commodity;
	imex 					: CM_IMEXStatus;
	voyage 					: CM_Voyage;
	weightTotal 			: Decimal [14,4];
	destination 			: CM_Port;
	discharge 				: CM_Port;
	isoType 				: CM_ISOType;
	quantity 				: Integer;
	consignee 				: CM_ConsigneeConsignor;
	controller 				: CMIF_MobileGenericAgent;
	shippingLine 			: CM_ShippingLine;		//28.06.2022 navsrk20 TFS 53923
	trailerType				: CM_TILCType;
	permissionsToCheck 		: IntegerArray;	
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	// In particular this sets passport myUser and myTerminal
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
	
	term := app.myPassport.myTerminal;
	if term = null then
		app.raiseCMException(Input_required_field_terminal,null,null);
		completedOK := true;
		return response;
	endif;
	//epr TFS 5535 4/8/17 
	//app.checkCurrentUserHasAccess(PmHHUnpackContainer);
	create permissionsToCheck transient;
	//63668 =&gt; add the deliver dispatch app permission, this allows					//24.06.2024 navsck1 #63668
	//for the action to continue if the user has access to the underlaying
	//app via delivery dispatch even if the specific permission is not
	//given.
	permissionsToCheck.add(PmMobDeliveryDispatchApp);								//24.06.2024 navsck1 #63668
	permissionsToCheck.add(PmHHUnpackContainer);
	
	app.myPassport.validateUserHasOnePermission(permissionsToCheck);
	if app.myPassport.hasErrors then
		completedOK := true;
		return response;
	endif;	
	
	if app.myPassport.hasErrors then
		completedOK := true;
		return response;
	endif;
	
	//Get Parent
	if request.cmObjectId &lt;&gt; null then
		//epr TFS 5535 4/8/17 
		container:=app.myPassport.getObjectOfTypeFromOid(request.cmObjectId,CM_TrackedItem).CM_TrackedItem;
		if app.myPassport.hasErrors then
			completedOK:=true;
			return response;
		endif;
	endif;
	
	if container = null then
		app.raiseCMException(Input_required_field_cargoId,null,null);
		completedOK := true;
		return response;
	endif;
	
	create controller transient;
	
	controller.setMyTerminal(term);
	controller.setUnPackContainerDetails(container,controller.myUnpackDefaultLocation);
	
	if request.cargoType &lt;&gt; null then
		cargoType :=app.myRoot.allCargoTypesById[request.cargoType.Integer];
	endif;
	
	if request.product &lt;&gt; null then
		product := cargoType.getProductFromCode(request.product);
	endif;
	
	if cargoType = null then
		app.raiseCMException(Input_required_field_cargoType,null,null);
		completedOK := true;
		return response;
	endif;
	
	if request.consignee &lt;&gt; null then
		consignee := app.myRoot.allConsigneeConsignors[request.consignee];
	endif;
	
	id := request.id;

	operator := app.myRoot.allOperators[request.operatorCode];

	commodity := app.myRoot.allCommodities[request.commodityCode];
	
	imex := app.myRoot.allImexStatuses[request.imexStatus];

	voyage := term.allVoyagesByCode[request.voyageCode,null];
	
	shippingLine := app.myRoot.allShippingLines[request.shippingLine];		//28.06.2022 navsrk20 TFS 53923
		
	if container &lt;&gt; null and request.isoType &lt;&gt; null then
		isoType := app.myRoot.allISOTypes[request.isoType];
	endif;
	
	if request.weightTotal &lt;&gt;null then
		weightTotal :=request.weightTotal.asDecimalJMT;
	endif;
	
	destination := app.myRoot.allPorts[request.destinationPort];	
	discharge := app.myRoot.allPorts[request.dischargePort];	

	quantity := request.quantity;

	// 25/10/2022 navlw1 tfs 55211
	if request.trailerType &lt;&gt; null then
		trailerType := cargoType.allTILCTypes[request.trailerType];
	endif;
	
	controller.createNewTrackedItem(container,
									cargoType,
									id,
									isoType,
									operator,
									commodity,
									imex,
									voyage,
									weightTotal,
									destination,
									discharge,
									request.quantity,
									product,
									request.carriageTemp.String,
									null,
									null,
									request.colour,
									request.mark,
									request.make,
									request.model,
									request.year.asStringJMT,
									request.carType,
									trailerType,
									request.length.asDecimalJMT,
									request.width.asDecimalJMT,
									request.height.asDecimalJMT,
									consignee, 
									shippingLine,//TFS 53923
									request.weightTare.asDecimalJMT,
									request.alternativeId,
									request.cargoGroupId,
									request.markNumber,
									request.remarks,
									request.isOverlanded);			//jlier1 TFS 23/2/23	

	if app.myPassport.hasErrors then
		completedOK := true;
		return response;
	endif;

	completedOK := true;
	return response;

	
epilog
	delete controller; //epr TFS 20/4/17
	delete permissionsToCheck;
	
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
	
end;</source>
        <Parameter name="request" type="WS_CargoItemUpdateRequest"/>
        <ReturnType type="WS_TrackedItemUpdateResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="createDelay" id="dd48230b-f10c-464f-86d2-52fd4a4db362">
        <source>createDelay(request : WS_DelayUpdateRequest) : WS_DelayResponse webService;
/*
Purpose:			
Date				Who			Reason
JUNE 2015		CNWAB1		Initial creation
*/


vars
	response		: WS_DelayResponse;
	completedOK		: Boolean;
	
	pxyDelay,
	newDelay	: CM_Delay;
	
	wsDelay,
	wsDelayNew	: WS_Delay;
	
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	// In particular this sets passport myUser and myTerminal
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
	
	// Check security access to this message, if required
	app.checkCurrentUserHasAccess(PmHandHeldShipDelays);		// Replace with appropriate permission
	
	if app.myPassport.hasErrors then
		completedOK := true;
		return response;
	endif;
	
	wsDelay := request.myDelay;
	//wsDelay.setUTCToTimeStamp();		//cnwmc5 - 11 Jan 2016 - PAR 37326
	
	create pxyDelay transient;
	wsDelay.setProxyDelay(pxyDelay);
	
	app.myPassport.setWarningsIgnored(request.warningsAcknowledged);
	app.myTrxCA.trxCreateDelay(pxyDelay, newDelay,app.myPassport);
	
	if newDelay &lt;&gt; null and app.myPassport.noErrors() then
		create wsDelayNew transient;
		wsDelayNew.setProxyFromObject(newDelay);
		response.setDelay(wsDelayNew);
	endif;
	
	// Got to here, everything is ok
	completedOK := true;
	return response;
	
epilog
	
	delete pxyDelay;
	
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
	
end;</source>
        <Parameter name="request" type="WS_DelayUpdateRequest"/>
        <ReturnType type="WS_DelayResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="createLogDocket" id="9e9df90c-d184-4c64-9c74-956d371864c2">
        <source>createLogDocket(request : WS_LogDocketDataRequest) : WS_LogDocketResponse webService;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 October 2014	cnwmc5	Initial creation
15 Nov      2017    cnwma1  TFS #7354: C3 - Urgent - createLogDocket and updateLogDocket webservice returning the wrong JadeOID
*/

vars
	response			: WS_LogDocketResponse;
	completedOK			: Boolean;
	
	wsLogDocket			: WS_LogDocket;
	logDocketData,
	logDocketDataNew 	: CM_LogDocketData;
	bol					: CM_BOLIn;
	wsBOL				: WS_BOL;
	
	intFaceArray		: CMIF_TIObjectArray;
	intFaceCommon		: CMIF_InOutCommon;
	intFaceBOLIn		: CMIF_BOLIn;
	terminal			: CM_Terminal;
	
	gateDefault			: CM_Gate;
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	// In particular this sets passport myUser and myTerminal
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
	
	// Check security access to this message
	app.checkCurrentUserHasAccess(PmGteInOutEntry);
	if app.myPassport.hasErrors then
		completedOK := true;
		return response;
	endif;
	
	//Method processing here...
	wsLogDocket := request.myLogDocket;
	terminal := app.getMyTerminalDO_NOT_USE();
	
	create logDocketData transient;
	wsLogDocket.setLogDocketProxy(logDocketData);
	
	create intFaceArray transient;
	create intFaceCommon transient;
	
	intFaceCommon.myTerminal := terminal;
	intFaceCommon.regNumber := logDocketData.regNo;
	intFaceCommon.carrierCode := logDocketData.carrierCode;
	intFaceCommon.driverId := logDocketData.driverId;
	intFaceCommon.isReceiptRequired := logDocketData.receiptRequired;
	intFaceCommon.vehicleTareKilos := logDocketData.weightTare;
	
	gateDefault := terminal.getDefaultGate_IN();
	intFaceCommon.myGateEntry := gateDefault;
	if gateDefault &lt;&gt; null and gateDefault.myDefaultInterchangeArea &lt;&gt; null then
		intFaceCommon.roadTransAreaId := gateDefault.myDefaultInterchangeArea.id;
	endif;
	
	create intFaceBOLIn transient;
	intFaceBOLIn.setMyInOutCommon(intFaceCommon);
	logDocketData.setIntFaceBOLIn(intFaceBOLIn, null);
	intFaceArray.add(intFaceBOLIn);
	
	//app.myPassport.setWarningsIgnored(true);									//cnwmc5 - 22 Jan 2015 - PAR 35518
	//app.myTrxCA.trxCreateInOutVehicle(intFaceCommon, app.myPassport);			//cnwmc5 - 22 Jan 2015 - PAR 35518
	app.myPassport.setWarningsIgnored(true);
	app.myTrxCA.trxCreateLogDocketAndData(logDocketData, logDocketDataNew, intFaceCommon, intFaceArray, app.myPassport);
	
	//Find the newly added Log Docket (BOL)
	if app.myPassport.noErrors() then	
		//bol := terminal.getBOLInByNumber(logDocketData.docketNumber, BOLType_Log); //15/11/2017 cnwma1 TFS #7354
		
		if  logDocketDataNew &lt;&gt; null  then            //15/11/2017 cnwma1 TFS #7354
			bol := logDocketDataNew.myBol.CM_BOLIn;
			if  bol &lt;&gt; null then
				create wsBOL transient;
				wsBOL.setProxyFromObject(bol);
				response.allBOLs.add(wsBOL);
			endif;
		endif;
	endif;
	
	// Got to here, everything is ok
	completedOK := true;
	return response;
	
epilog
	// Tidy up any local transients
	delete logDocketData;
	delete intFaceBOLIn;
	delete intFaceArray;
	delete intFaceCommon;
	
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
	
end;</source>
        <text>Used for the Logs Module only.</text>
        <Parameter name="request" type="WS_LogDocketDataRequest"/>
        <ReturnType type="WS_LogDocketResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="createLogDocketData" id="9194c511-5f9c-4373-95dc-39783222a123">
        <source>createLogDocketData(request : WS_LogDocketDataRequest) : WS_LogDocketDataResponse webService;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 March 2014	cnwmc5	Initial creation

*/

vars
	response		: WS_LogDocketDataResponse;
	completedOK		: Boolean;
	
	wsLogDocket,
 	wsLogDcoketNew	: WS_LogDocket;
	logDocket,
	logDocketNew 	: CM_LogDocketData;
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	// In particular this sets passport myUser and myTerminal
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
	
	// Check security access to this message
	app.checkCurrentUserHasAccess(PmXmlBolEntryRq);
	if app.myPassport.hasErrors then
		completedOK := true;
		return response;
	endif;
	
	//Method processing here...
	wsLogDocket := request.myLogDocket;
	
	create logDocket transient;
	wsLogDocket.setLogDocketProxy(logDocket);
	
	app.myTrxCA.trxCreateLogDocketData(logDocket, logDocketNew, app.myPassport);
	
	if logDocketNew &lt;&gt; null and app.myPassport.noErrors() then
		create wsLogDcoketNew transient;
		wsLogDcoketNew.setProxyFromObject(logDocketNew);
		response.setMyLogDocketData(wsLogDcoketNew);
	endif;
	
	// Got to here, everything is ok
	completedOK := true;
	return response;

epilog
	// Tidy up any local transients
	delete logDocket;
	
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
	
end;</source>
        <text>Used for the Logs Module only.</text>
        <Parameter name="request" type="WS_LogDocketDataRequest"/>
        <ReturnType type="WS_LogDocketDataResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="createLogRow" id="50980d1a-98c9-4dbf-8bc3-57c0aa146cbb">
        <source>createLogRow(request : WS_LogRowUpdateRequest) : WS_LogRowResponse webService;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 October 2014	cnwmc5	Initial creation

*/

vars
	response		: WS_LogRowResponse;
	completedOK		: Boolean;
	cmifLogRow		: CMIF_LogRowRestriction;
	logRow,
	newLogRow		: CM_LogController;
	wsLogRow,
	wsNewLogRow		: WS_LogController;
	
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	// In particular this sets passport myUser and myTerminal
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
	
	// Check security access to this message, if required
	app.checkCurrentUserHasAccess(PmLogRowMaint);		// Replace with appropriate permission
	if app.myPassport.hasErrors then
		completedOK := true;
		return response;
	endif;
	
	wsLogRow := request.myLogController;
	
	create cmifLogRow transient;
	wsLogRow.setCMIFLogRow(cmifLogRow);
	
	app.myTrxCA.trxCreateLogRow(cmifLogRow, newLogRow, app.myPassport);
	
	if newLogRow &lt;&gt; null and app.myPassport.noErrors() then
		create wsNewLogRow transient;
		wsNewLogRow.setProxyFromObject(newLogRow);
		response.setLogController(wsNewLogRow);
	endif;
	
	// Got to here, everything is ok
	completedOK := true;
	return response;

epilog
	
	delete cmifLogRow;
	
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
	
end;</source>
        <text>Used for the Logs Module only.</text>
        <Parameter name="request" type="WS_LogRowUpdateRequest"/>
        <ReturnType type="WS_LogRowResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="createLogSpec" id="dcbc66a8-9d07-42e9-b38f-a0968fca681a">
        <source>createLogSpec(request : WS_LogSpecsUpdateRequest) : WS_LogSpecsResponse webService;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 October 2014	cnwmc5	Initial creation

*/

vars
	response		: WS_LogSpecsResponse;
	completedOK		: Boolean;
	
	pxyCodeGroup	: CM_CodeGroupLogSpecs;
	newCodeGroup	: CM_CodeGroup;
	
	wsCodeGroup,
	wsCodeGroupNew	: WS_CodeGroupLogSpecs;
	
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	// In particular this sets passport myUser and myTerminal
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
	
	// Check security access to this message, if required
	app.checkCurrentUserHasAccess(PmAdmCodeGroupMaint);		// Replace with appropriate permission
	if app.myPassport.hasErrors then
		completedOK := true;
		return response;
	endif;
	
	wsCodeGroup := request.myCodeGroupLogSpecs;
	
	create pxyCodeGroup transient;
	wsCodeGroup.setProxyCodeGroupLogSpecs(pxyCodeGroup);
	
	app.myTrxCA.trxCreateCodeGroupLogSpecsTree(pxyCodeGroup, newCodeGroup, app.myPassport);
	
	if newCodeGroup &lt;&gt; null and newCodeGroup.isKindOf(CM_CodeGroupLogSpecs) and app.myPassport.noErrors() then
		create wsCodeGroupNew transient;
		wsCodeGroupNew.setProxyFromObject(newCodeGroup.CM_CodeGroupLogSpecs);
		response.setCodeGroupLogSpecs(wsCodeGroupNew);
	endif;
	
	// Got to here, everything is ok
	completedOK := true;
	return response;
	
epilog
	
	delete pxyCodeGroup;
	
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
	
end;</source>
        <text>Used for the Logs Module only.</text>
        <Parameter name="request" type="WS_LogSpecsUpdateRequest"/>
