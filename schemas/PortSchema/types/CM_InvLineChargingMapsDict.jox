<CollClass name="CM_InvLineChargingMapsDict" id="c89dc081-654a-4f58-84d6-c74665d35322">
    <loadFactor>66</loadFactor>
    <memberType name="CM_InvoiceLineChargeMapping"/>
    <superclass name="CM_MemberKeyDictionary"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="invoice"/>
    <MemberKey>
        <property name="CM_InvoiceLineChargeMapping::myInvoiceLineDesc"/>
    </MemberKey>
    <MemberKey>
        <property name="CM_InvoiceLineChargeMapping::myParentMappingObject"/>
    </MemberKey>
    <MemberKey>
        <property name="CM_InvoiceLineChargeMapping::myCombinationMappingObject"/>
    </MemberKey>
    <JadeMethod name="getDescription" id="2e5e436e-b935-40de-ac92-cb6455c43224">
        <source>getDescription() : String;
// ---------------------------------------------------------------------------
// Created:		20 February 2008 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	aMap : CM_InvoiceLineChargeMapping;
	tmpStr : String;
begin
	if self.isEmpty() then
		return null;
	endif;
	
	foreach aMap in self discreteLock do
		tmpStr := tmpStr &amp; aMap.getDescription(3) &amp; Cr;
	endforeach;
	return tmpStr;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
</CollClass>
