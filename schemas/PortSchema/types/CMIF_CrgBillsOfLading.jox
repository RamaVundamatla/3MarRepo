    <text>


MTN = BOL and Booking
N4 aux_crg_bills_of_lading

Attribute gkey  (Integer64)
Attribute client_id   (String 25)
Attribute nbr (String 35)
Attribute category (String 255)
Attribute complex_gkey  (Integer64)
Attribute line_gkey  (Integer64)
Attribute cargoSuperType (to be confirmed)  (Integer64)
Attribute consignee_name (String 80)
Attribute shipper_name (String 80)
Attribute consignee_gkey  (Integer64)
Attribute shipper_gkey  (Integer64)
Attribute agent_gkey  (Integer64)
Attribute cv_gkey  (Integer64)
Attribute origin (String 30)
Attribute destination (String 30)
Attribute notes (String 80)
Attribute manifested_qty (Real)
Attribute created (Integer64)
Attribute creator (String 30)
Attribute changed (Integer64)
Attribute changer    (String 30)
Attribute gid (Integer64)
Attribute pin  (String 30)
Attribute is_direct (Boolean)
Attribute bl_type  (String 30)
</text>
