    <JadeMethod name="verifyEDIData" id="4aef380c-fbab-42a4-9397-beeb0e15078f">
        <updating/>
        <source>verifyEDIData(): Integer updating;
//----------------------------------------------------------------------
// Created by 	cnwsh3
// Date 		15 September 2009
//
// Implemented version: JMT 7.7.3
// Date  		User  		Change

//----------------------------------------------------------------------
vars
	voyage : CM_Voyage;
begin
	on Exception do validationExceptionHandler(exception, app.myPassport);
	app.setContinueCMExceptions(true);

	voyage := self.getVoyageFromCode(self.voyageCode);
	if voyage = null then
		app.raiseCMException1(VoyageCodeNoMatch, self.voyageCode, 'voyageCode', self);
	else
		//epr par 37090 23/10/15 CCMS 2538 EDI Admin Improvements
		if voyage.hasDeparted and  self.getMyTerminal.getConfig(EdiAddVoyageDepartError).Boolean then
			app.raiseCMException1(Voyage_departed,voyageCode,"Voyage Code", self);
		endif;
	endif;
epilog
	return app.myPassport.allErrorWarnings.size; 
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
