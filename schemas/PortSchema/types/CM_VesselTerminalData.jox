vars

begin
	self.nextNumber	:= _number;
end;</source>
        <Parameter name="_number" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setPreferredBerth" id="b47e76d7-5a5e-465f-91c7-cf35b54396f3">
        <updating/>
        <source>setPreferredBerth(pBerth :HMS_Berth) updating;

vars

begin
	myPreferredBerth := pBerth;
end;
</source>
        <Parameter name="pBerth" type="HMS_Berth"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="87342d3f-2891-4edf-a4da-b69a08e2e6b7">
        <updating/>
        <source>setProxy(	_isUseTerminal:Boolean;
			_nonChargeTime:Decimal;
			_stopChargingAt:String;
			_grossLoadingTime:Decimal;
			_grossDischargeTime:Decimal;
			_downTime:Decimal;
			_loadRate:Decimal;
			_dischargeRate:Decimal;
			_draftArrival:Decimal;
			_draftDeparture:Decimal;
			_preferredBerthObj:HMS_Berth;
			_terminalObj:CM_Terminal;
			_vesselObj:CM_Vessel) updating;
// --------------------------------------------------------------------------------
// Created:		25 August 2006 by cnwdad1
//
// Purpose:		Sets the proxy receiver's attribute values and references.
//
// Parameters:	_isUseTerminal - True if Terminal default values are to be used.
//				_nonChargeTime - The number of hours after arrival at the harbour
//					before charging begins.
//				_stopChargingAt - A constant value (CM_Terminal) to indicate when
//					charging stops.
//				_grossLoadingTime - The expected number of hours the ship will be 
//					loading at the port (until ready for sailing time).
//				_grossDischargeTime - The expected number of hours the ship will be 
//					 discharging  at the port (until ready for sailing time).
//				_downTime - The number of hours at the wharf where the vessel is
//					neither loading nor discharging cargo.
//				_loadRate - The standard load rate in tonnes per hour.
//				_dischargeRate - The standard discharge rate in tonnes per hour.
//				_draftArrival - The default draft of the vessel upon arrival.
//				_draftDeparture - The default draft of the vessel upon departure.
//				_terminalObj - A reference to the Terminal the ship is visiting.
//				_vesselObj - A reference to the receiver's Vessel.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	// This method should be used only to update transient
	self.raiseExceptionIfNotTransient(method);
	
	self.isUseTerminalDefaults	:=	_isUseTerminal;
	self.nonChargeTime			:=	_nonChargeTime;
	self.stopChargingAt			:=	_stopChargingAt;
	self.grossLoadingTime		:=	_grossLoadingTime;
	self.grossDischargeTime		:=  _grossDischargeTime;
	self.vesselDownTime			:=	_downTime;
	self.vesselLoadRate			:=	_loadRate;
	self.vesselDischargeRate	:=	_dischargeRate;
	self.defaultDraftArrival	:=	_draftArrival;
	self.defaultDraftDeparture	:=	_draftDeparture;
	self.myPreferredBerth		:=  _preferredBerthObj;
	
	self.myTerminal				:=	_terminalObj;
	self.myVessel				:=	_vesselObj;
end;</source>
        <Parameter name="_isUseTerminal" type="Boolean"/>
        <Parameter name="_nonChargeTime" type="Decimal"/>
        <Parameter name="_stopChargingAt" type="String"/>
        <Parameter name="_grossLoadingTime" type="Decimal"/>
        <Parameter name="_grossDischargeTime" type="Decimal"/>
        <Parameter name="_downTime" type="Decimal"/>
        <Parameter name="_loadRate" type="Decimal"/>
        <Parameter name="_dischargeRate" type="Decimal"/>
        <Parameter name="_draftArrival" type="Decimal"/>
        <Parameter name="_draftDeparture" type="Decimal"/>
        <Parameter name="_preferredBerthObj" type="HMS_Berth"/>
        <Parameter name="_terminalObj" type="CM_Terminal"/>
        <Parameter name="_vesselObj" type="CM_Vessel"/>
    </JadeMethod>
    <JadeMethod name="setTerminal" id="f74ef8df-4991-4011-9025-2c4c9b7cd239">
        <updating/>
        <source>setTerminal(pTerminal :CM_Terminal) updating;

vars

begin
	myTerminal	:= pTerminal;
end;
</source>
        <Parameter name="pTerminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="setVessel" id="cd518c63-4a2b-4512-a4cc-b409109ccf02">
        <updating/>
        <source>setVessel(_vesselObj:CM_Vessel) updating;
// --------------------------------------------------------------------------------
// Created:		25 August 2006 by cnwdad1
//
// Purpose:		Sets the reference to the receiver's Vessel object.
//
// Parameters:	_vesselObj - A reference to a Vessel object.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.myVessel	:=	_vesselObj;
end;</source>
        <Parameter name="_vesselObj" type="CM_Vessel"/>
    </JadeMethod>
    <JadeMethod name="setVesselAndTerminal" id="45a8091e-2fcc-4606-9042-057e05d531d6">
        <updating/>
        <source>setVesselAndTerminal(_vessel : CM_Vessel; _terminal : CM_Terminal) updating;
// ---------------------------------------------------------------------------
// Created:     07 June 2007 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin

	self.myTerminal := _terminal;
	self.myVessel	:= _vessel;
	if self.nextNumber = 0 then
		self.nextNumber	:= 1;
	endif;

end;</source>
        <Parameter name="_vessel" type="CM_Vessel"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="stopChargingAt" id="0a184e6e-7200-4d4e-8e16-2bc78bfefec6">
        <methodInvocation>mapping</methodInvocation>
        <source>stopChargingAt(set : Boolean; _value : String io) mapping;
// --------------------------------------------------------------------------------
// Created:		07 June 2007 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if (not set) and self.isUseTerminalDefaults then
		_value	:=	self.myTerminal.getConfig(StopCharging).String;
	endif;
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="String" usage="io"/>
    </JadeMethod>
