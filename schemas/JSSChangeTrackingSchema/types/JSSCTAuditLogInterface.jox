    <JadeMethod name="clearClasses" id="f61c020d-614a-43c7-a02a-916f0a0cfadc">
        <source>clearClasses(pServerExecution: Boolean);

begin
	if pServerExecution then
		self.doClearClassesSE();
	else
		self.doClearClasses();
	endif;
end;</source>
        <Parameter name="pServerExecution" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="closeJournal" id="455adc19-b903-46f7-a61a-657a4e4d1e22">
        <source>closeJournal(pServerExecution: Boolean);
/*
*/
begin
	if pServerExecution then
		self.doCloseAuditLogSE();
	else
		self.doCloseAuditLog();
	endif;
end;</source>
        <Parameter name="pServerExecution" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="create" id="7d3a53c4-66cf-4864-8cc3-63d8d2585b95">
        <updating/>
        <source>create() updating;
/*
*/
vars
	jdba : JadeDatabaseAdmin;
begin
	if self.isTransient() then
		if app.getProfileStringAppServer(app.getIniFileNameAppServer(), "JSSChangeTracker", "ReadLogServerExecution", 'true').toLower = "true" then
			if self.doBeginSessionSE() &gt; 0 then
//				delete self;
			endif;
		else
			if self.doBeginSession() &gt; 0 then
//				delete self;
			endif;
		endif;
		create jdba;
		self.journalPathName := jdba.getCurrentJournalDirectory;
		delete jdba;
		self.latestJournalOffset := 0;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="delete" id="327fb05f-bb1f-4284-b516-0edc9fdbb164">
        <updating/>
        <source>delete() updating;
/*
*/
begin
	if self.isTransient() then
		if app.getProfileStringAppServer(app.getIniFileNameAppServer(), "JSSChangeTracker", "ReadLogServerExecution", 'true').toLower = "true" then
			self.doEndSessionSE();
		else
			self.doEndSession();
		endif;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="doBeginSession" id="b84d6762-64d5-4852-9ae9-fc9ac245e3d8">
        <updating/>
        <source>doBeginSession(): Integer updating, protected;
/*
*/
begin
	create self.myJadeAuditAccess transient;
	self.myJadeAuditAccess.setFilterExcludes(false);
	self.myJadeAuditAccess.setAccessMode(JadeAuditAccess.Jaa_AccessMode_Standard);
	return 0;

	//return (call beginSession(self.journalHandle));
end;</source>
        <access>protected</access>
        <ReturnType type="Integer"/>
    </JadeMethod>
