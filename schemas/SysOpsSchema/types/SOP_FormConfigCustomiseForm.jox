    <JadeMethod name="doSave" id="8cf8f846-731f-4f28-bd13-8036f406de38">
        <source>doSave():Boolean;
// ---------------------------------------------------------------------------
// Created:     03 September 2008 by concms1
// Purpose:     User definable forms - CCMS 1011
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	rtnValue	: Boolean;
	result		: Integer;
	proxy		: CM_FormConfigForm;
	theResult : Integer;	//14 Jan 2020 NDL	TFS 46815
	
begin
	// before we save the form we need to set the width and height properties
	proxy := self.myAgent.myPxyFormConfiguration;
	
	proxy.setWidth	(frame1.width);
	proxy.setHeight (frame1.height);
	
	while true do
	
		app.myTrxUA.trxUpdateFormCustomisation(proxy, app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			return true;

		else
			theResult := app.showErrorWarningDialog('Form Configuration', app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		return false;
		
	endwhile;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="drawDraggingRectangle" id="cbc3e921-c136-4d01-8f78-760aa4e5d061">
        <updating/>
        <source>drawDraggingRectangle(_control :Control input; _win :Window; _x, _y :Real)updating, protected;
// ---------------------------------------------------------------------------
// Created:     04 September 2008 by concms1
// Purpose:     User definable forms - CCMS 1011
// Parameters:  _control	- the control receiving the event
//				_ win		- the control being dragged
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	x, y, w, h	:Real;
	l, t, r, b	:Integer;	// left, top, right, bottom
begin
	// undo last draw of rectangle
	self.hideDraggingRectangle ();
	
	w := _win.width;
	h := _win.height;
	x := _x;
	y := _y;
	
	_control.windowToScreen (x, y);
	self.screenToWindow(x, y);
	
	x := x - self.dragOffsetX;
	y := y - self.dragOffsetY;
	
	l := x.Integer;
	t := y.Integer;
	r := (x + w).Integer;
	b := (y + h).Integer;
	
	if x &lt; 0 then l := 0; endif;
	if y &lt; 0 then t := 0; endif;
	
	self.drawDeskTopRectangle (DragRectangle_DrawPattern, l , t , r, b, DragRectangle_DrawColour, DragRectangle_DrawWidth);
	
	self.lastDragLeft			:= l;
	self.lastDragTop			:= t;
	self.lastDragRight			:= r;
	self.lastDragBottom 		:= b;
	
	self.isDragRectangleVisible	:= true;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_control" type="Control" usage="input"/>
        <Parameter name="_win" type="Window"/>
        <Parameter name="_x" type="Real"/>
        <Parameter name="_y" type="Real"/>
    </JadeMethod>
