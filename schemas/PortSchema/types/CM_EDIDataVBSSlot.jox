    <JadeMethod name="getDataTypeFromDefName" id="86f8fafd-7410-4f83-9dcf-445864e84989">
        <source>getDataTypeFromDefName(_name: String): Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
27 June 2023		jlizm1	Initial creation TFS 53901 EUP VBS EDI

*/

vars

begin
	if _name = ETDef_EDITIVBSSlot then
		return EDIDataType_VBSSlotHeader;
	elseif _name = ETDef_EDITIVBSSlotItem then
		return EDIDataType_VBSSlotItem;
	endif;
	
epilog

end;</source>
        <Parameter name="_name" type="String"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStrForDefName" id="4be81cb4-83c6-4ffe-88c1-5523d8675974">
