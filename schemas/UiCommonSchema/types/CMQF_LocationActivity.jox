<Class name="CMQF_LocationActivity">
    <JadeMethod name="setFromAgent" id="15464c86-0009-4e85-a1dc-f5214460a5aa">
        <updating/>
        <source>setFromAgent(_agent: CMUI_ReportAgent input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 June 2021	navndl1	Initial creation	TFS 51245

*/

vars

begin
	inheritMethod(_agent);
	
	if _agent.isRowIncluded(ETRow_FilterFromDate) then
		if _agent.state = _agent.STATE_TEMPLATE_SAVE or	
		   _agent.state = _agent.STATE_TEMPLATE_EDIT then
			self.setTemplateDateFields(_agent.getValueForTemplateDates(ETRow_FilterFromDate), 
								self.startDateTplType, self.startDateTplFactor, ETRow_FilterFromDate);
		else
			self.startDate := _agent.getValueByNameIfVisible(ETRow_FilterFromDate).Date;
		endif;
		
	elseif _agent.isRowIncluded(ETRow_StartOfYearDate) then
		self.startOfYearDate := _agent.getValueByNameIfVisible(ETRow_StartOfYearDate).Date;
	endif;
	
	if _agent.isRowIncluded(ETRow_Month) then
		self.reportingMonth := _agent.getSelectedMonth();
	endif;
	
	if _agent.isRowIncluded(ETRow_FilterToDate) then
		
		if _agent.state = _agent.STATE_TEMPLATE_SAVE or	
		   _agent.state = _agent.STATE_TEMPLATE_EDIT then
			self.setTemplateDateFields(_agent.getValueForTemplateDates(ETRow_FilterToDate), 
								self.endDateTplType, self.endDateTplFactor, ETRow_FilterToDate);
		else
			self.endDate := _agent.getValueByNameIfVisible(ETRow_FilterToDate).Date;
		endif;
	endif;
	
	if _agent.isRowIncluded(ETRow_FilterTA) then
		self.setMyTerminalArea( _agent.getSelectedTerminalArea );
	endif;
	
	if _agent.isRowIncluded(ETRow_FilterLocation) then
		self.myLocationsController := _agent.getSelectedLocation();
	endif;
	
	if _agent.isRowIncluded(ETRow_FilterOperator) then
		self.myOperator := _agent.getSelectedOperator();
	endif;
	
	if _agent.isRowIncluded(ETRow_FilterCargoType) then
		self.myCargoType := _agent.getSelectedCargoType();
	endif;
	
	

epilog

end;</source>
        <Parameter name="_agent" type="CMUI_ReportAgent" usage="input"/>
    </JadeMethod>
</Class>
