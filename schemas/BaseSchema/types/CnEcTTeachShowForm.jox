    <JadeMethod name="positionWizard" id="a5a94810-8fe2-43f1-affe-7c746874389f">
        <updating/>
        <source>positionWizard(pTheControl : Control io) updating;

constants
	VERTICAL_OFFSET		: Real = 115;
	HORIZONTAL_OFFSET	: Real = 20;
	
vars
	xpos		: Real;
	ypos		: Real;
	formLeft	: Real;
	formTop		: Real;
	formWidth	: Real;
	picStopTop	: Real;
	picTop		: Real;
	
begin
	// color the selected control in the highlight colour
	if pTheControl &lt;&gt; null then
		// uncolour the previous item
		if aMyPreviousControl &lt;&gt; null then
			aMyPreviousControl.backColor := aPreviousBackColor;
		endif;	
		
		aMyPreviousControl 	:= pTheControl;
		aPreviousBackColor	:= pTheControl.backColor;		
		pTheControl.backColor := aTeachDrawColor;
	endif;

	self.makePictureVisible(picLeft, false);
	self.makePictureVisible(picRight, false);

	// the user wants this form to move to the target control, showing an arrow beside that control (as well as the drawn rectangle from above)
	if chkPin.value = false then
		// get the correct position for this window, relative to the referenced control or form
		if pTheControl &lt;&gt; null then
			pTheControl.windowToScreen(xpos, ypos);
			formTop 	:= ypos - (picSide1.top + ((self.height - self.clientHeight)/2));
			formLeft 	:= xpos - self.width - 10;
			formWidth 	:= pTheControl.width;
		elseif aMyForm &lt;&gt; null then
			aMyForm.windowToScreen(xpos, ypos);
			formTop 	:= ypos + self.aMyForm.height / 2 - (self.height / 2);
			formLeft 	:= xpos + self.aMyForm.width / 2  - (self.width / 2);
			formWidth 	:= self.aMyForm.width;
		else
			formTop 	:= self.top;
			formLeft 	:= self.left;
			formWidth 	:= self.width;
		endif;

		if formLeft &gt;= 0 then
			if pTheControl &lt;&gt; null then
				self.makePictureVisible(picRight, true);
			endif;
			
			left := formLeft;
		else
			if pTheControl &lt;&gt; null then
				self.makePictureVisible(picLeft, true);
			endif;
			
			formLeft := xpos + formWidth + 10;
		endif;

		if self.aMyForm &lt;&gt; null and (formTop + self.height &gt; self.aMyForm.top + self.aMyForm.height) then
			formTop := formTop - VERTICAL_OFFSET + 5;
			picTop := VERTICAL_OFFSET;
			picStopTop := 5;
		else
			picTop := 5;
			picStopTop := (VERTICAL_OFFSET + 5) / 2;
		endif;

		self.movePicture(picRight, picTop, picRight.left);
		self.movePicture(picLeft, picTop, picLeft.left);

		self.move(formLeft, formTop, self.width, self.height);
	endif;

	windowState := Form.WindowState_Normal;
	refreshNow();
end;</source>
        <Parameter name="pTheControl" type="Control" usage="io"/>
    </JadeMethod>
    <JadeMethod name="resize" id="bbffe21e-6ffe-404d-85ea-811a06825066">
        <controlMethod name="Form::resize"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>resize() updating;

begin
	self.doResize();
end;</source>
    </JadeMethod>
    <JadeMethod name="setDoItCaption" id="6e17e319-0d9e-4877-b8de-470cbfd81f5f">
        <source>setDoItCaption(setToNext : Boolean);
//	Sets DoIt caption...
//	... if true, to Next unless it's the last part of the last step...
//	... if false, to DoIt unless it's the last part of the last step...
begin
	if setToNext then
		if aSequence &gt;= aMyLesson.allActivities.size() and aMyLesson.nextLessonName.length = 0 then	// is last step
			btnDoIt1.caption := self.FINISH;
			txtTextAction.text := "Click '" &amp; btnDoIt1.caption &amp; "' to finish the lesson.";
		else
			btnDoIt1.caption := self.NEXT;
			txtTextAction.text := "Click '" &amp; btnDoIt1.caption &amp; "' for the next step.";
		endif;
	else
		if aSequence &gt;= aMyLesson.allActivities.size() 	// last activity for the lesson
		and aMyActivity.action.length = 0			// no action 
		and aMyActivity.afterText.length = 0 		// no after activity
		and aMyLesson.nextLessonName.length = 0 	// no follow on lesson
		then	// this is the last step!
			btnDoIt1.caption := self.FINISH;
			txtTextAction.text := "Click '" &amp; btnDoIt1.caption &amp; "' to finish the lesson.";
		else
			btnDoIt1.caption := self.DO_IT;
			txtTextAction.text := "Click '" &amp; btnDoIt1.caption &amp; "' to do this.";
		endif;
	endif;

	btnDoIt1.setFocus();
end;</source>
        <Parameter name="setToNext" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setupHelp" id="7045b416-f589-4402-871e-e0da04867e0c">
        <updating/>
        <source>setupHelp() updating;

begin
	if app.helpFile.length = 0 then
		return;
	endif;

	if self.aMyForm = null then
		helpKeyword := "";
		return;
	endif;

	helpKeyword := self.aMyForm.helpKeyword;
end;</source>
    </JadeMethod>
    <JadeMethod name="startup" id="ac2ed770-0f25-4f55-a2eb-e1b29f37ca37">
        <updating/>
        <source>startup(pTheForm : Form; automate : Boolean) updating;

begin
	self.aMyForm := pTheForm;
	self.aIsNoUserInput := automate;
end;</source>
        <Parameter name="pTheForm" type="Form"/>
        <Parameter name="automate" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="timerEvent" id="018130c2-5cd4-431f-aaa7-5e4c5342ecc0">
        <updating/>
        <source>timerEvent(eventTag: Integer) updating;

begin
	btnDoIt1.setFocus();
end;</source>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="toggleMode" id="823479d1-3749-464b-ba8d-116e72f13281">
        <updating/>
        <source>toggleMode(newMode : Integer) updating;

begin
	if newMode = self.MODE_TEXT then
		// displaying lesson steps
		lstLessons.visible 	:= false;
		txtText.visible		:= true;
		txtTextAction.visible := true;
	elseif newMode = self.MODE_LIST then
		// displaying available lessons
		txtText.visible		:= false;
		txtTextAction.visible := false;
		lstLessons.visible 	:= true;
	endif;
end;</source>
        <Parameter name="newMode" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="writeScriptFileServer" id="e3876742-034b-4ff5-b67a-cb6279e2a1ea">
        <executionLocation>server</executionLocation>
        <source>writeScriptFileServer(text : String) serverExecution;

vars
	date		: Date;
	today		: TimeStamp;
	file		: File;
	count		: Integer;	

begin
	if aMyLesson = null or aMyLesson.logDirectory.length = 0 then
		return;
	endif;

	count := 0;

	create file;
	file.fileName	:= aMyLesson.logDirectory &amp; "script" &amp; date.format( "yyMMdd" ).String &amp; ".txt";
	file.kind := File.Kind_Unknown_Text; // 2/3/16  cnwns1 PAR 36286 unicode version
	file.mode		:= File.Mode_Append;

	file.usePresentationFileSystem := false;	// make sure running on server

	if not file.isAvailable() then
		file.mode			:= File.Mode_IO;
		file.allowCreate 	:= true;
		file.open;
		file.writeLine( "New log Created " &amp; today.String );
		file.close();
		file.mode			:= File.Mode_Append;
	endif;

	while count &lt; 5 do	
		if file.isOpen() then	
			process.sleep(500);
			count := count + 1;
		else		
			if not file.isAvailable() then
				write "Unable to log message. File " &amp; file.fileName &amp; " is not available.";
				break;
			else
				file.open();
				file.writeLine(text &amp; " - at " &amp; today.Time.String);
				file.close();
				delete file;
				break;
			endif;
		endif;		
 	endwhile;
end;</source>
        <Parameter name="text" type="String"/>
    </JadeMethod>
</GUIClass>
