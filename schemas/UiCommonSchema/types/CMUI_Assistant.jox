    <JadeMethod name="validateVehicleAganistVBSSlot" id="2280f63a-cce9-4038-94b2-0686d7b542cc">
        <updating/>
        <source>validateVehicleAganistVBSSlot(_vbsTimeSlot : CM_VehicleBookingTimeSlot; 
								_vbt : CM_VehicleBookingTerminal; 
								_allVehicleBookingSlots : CM_VehicleBookingTimeSlotById;
								_retroDateTime : TimeStamp) : Boolean updating;
/*

Purpose:			Validates whether the vbs slot is valid and can be added to the vehicle visit record

Parameters:			_vbsTimeSlot			CM_VehicleBookingTimeSlot		The vehicle booking timeslot to check
					_vbt					CM_VehicleBookingTerminal		The vehicle booking terminal to sue to check the grace period etc.
					_allVehicleBookingSlots	CM_VehicleBookingTimeSlotById	All the vehicle booking time slots to check

Return Value:		Boolean representing whether the vehicle visit time in is beyond the booking time end and grace period

Date		Who		Reason
26 May 2023	navpw1	Initial creation TFS: 57756 (57896)
14 June 2023 navpw1	TFS: 58590 - Fixed the else statement for outside timeslot action
08 Feb 2024 navhl20 ChangeRequest 62084:[62379] EUP | Retrospective Operations - [54177.010] - Road Entry
05 Feb 2025	navhl20 Bug MTN-19856: MTN - VBS Slot validation is not using the retrospective date/time entered in the gate.
*/

vars
	terminal				: CM_Terminal;
	vbsTimeSlotType			: CM_VehicleBookingTimeSlotType;
	allVehicleBookingSlots	: CM_VehicleBookingTimeSlotById;
	outsideTimeSlotAction,
	terminalGracePeriod,
	msgResult				: Integer;
	msg						: String;
	vbsProcess				: CM_VBSProcess;
	isOutsideGracePeriod	: Boolean;
	slotIdsOutsideTime		: StringArray;
	
begin
	create slotIdsOutsideTime transient;
	//Checks the vbsTimeSlot is outside the slot grace period or the terminal grace period then
	terminal				:= _vbt.myTerminal;
	terminalGracePeriod		:= terminal.getConfig(VsOntimeGracePeriod).Integer;
	
	create allVehicleBookingSlots transient;
	allVehicleBookingSlots.addNoDuplicates(_vbsTimeSlot, false);
	_allVehicleBookingSlots.copyNoDuplicates(allVehicleBookingSlots, false);
	
	vbsProcess := terminal.getMyVBSProcess;
	
	if allVehicleBookingSlots = null or allVehicleBookingSlots.isEmpty then
		return true;
	endif;
	
	//isOutsideGracePeriod := vbsProcess.checkTimeSlotOutsideGrcePeriod(allVehicleBookingSlots, terminal, outsideTimeSlotAction, slotIdsOutsideTime);		//09.02.2023 navhl20 #62084[62379]
	//isOutsideGracePeriod := vbsProcess.checkTimeSlotOutsideGrcePeriod(allVehicleBookingSlots, terminal, outsideTimeSlotAction, slotIdsOutsideTime,null);	//09.02.2023 navhl20 #62084[62379]	//05.02.2025 navhl20 #19856
	isOutsideGracePeriod := vbsProcess.checkTimeSlotOutsideGrcePeriod(allVehicleBookingSlots, terminal, outsideTimeSlotAction, slotIdsOutsideTime, null, _retroDateTime);	//05.02.2025 navhl20 #19856
	
	if isOutsideGracePeriod then
		if outsideTimeSlotAction = CM_VehicleBookingTimeSlotType.VBS_ENTRY_WARN then 
			msg := app.getErrorString1(WARN_Vbs_slot_outside_grace, slotIdsOutsideTime.asCSV(false));
			msgResult := app.msgBox(msg, app.getErrorString(Warning), MsgBox_OK_Cancel);
			
			if msgResult = MsgBox_Return_OK then
				return true;
			else
				return false;
			endif;
			
		// ### TFS 58590 14Jun2023 NAVPW1
		elseif outsideTimeSlotAction = CM_VehicleBookingTimeSlotType.VBS_ENTRY_ERROR then
			msg := app.getErrorString1(Veh_booking_slot_outside_grace, slotIdsOutsideTime.asCSV(false));
			app.msgBox(msg, app.getErrorString(Error), MsgBox_OK_Only);
			return false;
			
		else
			return true;
		endif;
		// ### TFS 58590 14Jun2023 NAVPW1
	endif;
	
	return true;
	
epilog
	delete allVehicleBookingSlots;
	delete slotIdsOutsideTime;
	
end;</source>
        <Parameter name="_vbsTimeSlot" type="CM_VehicleBookingTimeSlot"/>
        <Parameter name="_vbt" type="CM_VehicleBookingTerminal"/>
        <Parameter name="_allVehicleBookingSlots" type="CM_VehicleBookingTimeSlotById"/>
        <Parameter name="_retroDateTime" type="TimeStamp"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="writeClient" id="a4d0556f-e72d-4bff-a734-d52559cf1096">
        <executionLocation>client</executionLocation>
        <source>writeClient(str : String) clientExecution;
// ---------------------------------------------------------------------------
// Created:     23 January 2002 by cnwrs2
//
