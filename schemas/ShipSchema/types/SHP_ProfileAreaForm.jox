    <JadeMethod name="doPrintOutTables" id="fe05b777-3242-4cc2-b57b-c6d82f3260d1">
        <source>doPrintOutTables(_table1, _table2, _table3, _table4, _table5: CM_DataTable input; 
						_headerStr : String; _preview : Boolean; 
		_whiteBG, _useOrigTableColumnWidths : Boolean; _portrait : Boolean) ;
// ---------------------------------------------------------------------------
// Created:		June 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// 16/08/2011	cnwcs5	CCMS MES 1033 RORO KPI
vars
	gtpdataTable 	: CM_GenericTablePrint;
	now 			: TimeStamp;
	tmpJadeReport 	: JadeReport;

begin
	now := self.systemToLocalTime(app.actualTimeServer());		// 20/5/16 cnwmp6 TFS 488 - Multi timezone support

	app.mousePointer := MP_HOURGLASS;
	app.printer.suppressDialog := true;

	create gtpdataTable transient;
	gtpdataTable.whiteBackground := _whiteBG;
	
	if _portrait then
		app.printer.setMargins(Print_Portrait,0,0,10,10);
	else
		app.printer.setMargins(Print_Landscape,0,0,10,10);
	endif;
	
	gtpdataTable.frHeader.width := app.printer.pageWidth;

	gtpdataTable.setHeaders(_headerStr, null );
	
	create tmpJadeReport transient;
	tmpJadeReport.description := _headerStr[1:60];
	
	if _preview then  // if print preview required then set report
		app.printer.setReport(tmpJadeReport);
	endif;
	
	app.printer.setHeader(gtpdataTable.frHeader);

	gtpdataTable.frFooter.width 			:= app.printer.pageWidth;
	gtpdataTable.lblTheUser.caption 		:= app.getMyUserCode;
	gtpdataTable.lblTheDatePrinted.caption 	:= now.asStringJMT;
	gtpdataTable.useOrigTableColumnWidths 	:= _useOrigTableColumnWidths;

	app.printer.setFooter(gtpdataTable.frFooter);

	if _table1 = null then
		self.printControlData(gtpdataTable, null);
	else
		self.frmPrint.left := 1;
		self.frmPrint.clearGraphics();
		self.frmPrint.drawTextAt(app.getErrorString (Move_details), 1, 1, Black);
		app.printer.print(self.frmPrint);
		gtpdataTable.printTable(_table1, (not _portrait), null);

		app.printer.setPrintPosition(app.printer.getPrintPosition() + 10);
		self.frmPrint.clearGraphics();
		self.frmPrint.drawTextAt(app.getErrorString (Timing_details), 1, 1, Black);
		app.printer.print(self.frmPrint);
		gtpdataTable.printTable(_table2, (not _portrait), null);

		app.printer.setPrintPosition(app.printer.getPrintPosition() + 10);
		self.frmPrint.clearGraphics();
		self.frmPrint.drawTextAt(app.getErrorString (Deck_details), 1, 1, Black);
		app.printer.print(self.frmPrint);
		gtpdataTable.printTable(_table3, (not _portrait), null);
		
		if _table4 &lt;&gt; null then
			app.printer.setPrintPosition(app.printer.getPrintPosition() + 10);
			self.frmPrint.clearGraphics();
			self.frmPrint.drawTextAt(app.getErrorString (Roro_move_details), 1, 1, Black);
			app.printer.print(self.frmPrint);
			gtpdataTable.printTable(_table4, (not _portrait), null);
		endif;
		
		if _table5 &lt;&gt; null then
			app.printer.setPrintPosition(app.printer.getPrintPosition() + 10);
			self.frmPrint.clearGraphics();
			self.frmPrint.drawTextAt(app.getErrorString (Delay_details), 1, 1, Black);
			app.printer.print(self.frmPrint);
			gtpdataTable.printTable(_table5, (not _portrait), null);
		endif;
	endif;
epilog
	app.printer.close;
	if _preview then // if print preview call method 
		app.printPreview(tmpJadeReport, true);
	endif;
	delete gtpdataTable;
	app.mousePointer := MP_DEFAULT;
end;</source>
        <Parameter name="_table1" type="CM_DataTable" usage="input"/>
        <Parameter name="_table2" type="CM_DataTable" usage="input"/>
        <Parameter name="_table3" type="CM_DataTable" usage="input"/>
        <Parameter name="_table4" type="CM_DataTable" usage="input"/>
        <Parameter name="_table5" type="CM_DataTable" usage="input"/>
        <Parameter name="_headerStr" type="String"/>
        <Parameter name="_preview" type="Boolean"/>
        <Parameter name="_whiteBG" type="Boolean"/>
        <Parameter name="_useOrigTableColumnWidths" type="Boolean"/>
        <Parameter name="_portrait" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doPrintStats" id="9d3024d3-b729-490f-949a-8de3662b822e">
        <source>doPrintStats();
/*
----------   ----------  --------------------------------------------------
Created:	29 May 2007 By cnwmo1

Purpose:	

Changed On	Changed By	Reason
----------	----------	--------------------------------------------------
17 Mar 2010	consw1		PAR #22886 - Leaking report transients
11/03/2015	cnwmh5		Transient Leaks
*/
vars
	jadeReport,
	tmpJadeReport	: JadeReport;
	jrwManager	: JadeReportWriterManager;
	jrwReport	: JadeReportWriterReport;
	jrwTrans 	: CM_JRWVoyages;
	ls				: Boolean;
	reportArray		: StringArray;
	repName 	: String;
	
	// page options
	documentType: Integer;
	idx,
	pageNum : Integer;
	isSecondTime		: Boolean;
	tmpPrintData,
	pxyPrintData		: JadePrintData;
	termDict			: CM_TerminalByCodeDict;
begin
	/************************************* 12/6/2006 ****************************************************/
	create reportArray transient;
	create jadeReport transient;
	create termDict transient;
	termDict.add(self.myTerminal);

		
		
	documentType := app.printer.getDefaultDocumentType();
	app.printer.abort();

	jadeReport.description := "Voyage Side Profile";
	app.printer.setReport(jadeReport);
	
	reportArray.add("CM_VoyageSideProfile");
	reportArray.add("CM_VoyageSideProfileTimings");
	
	
	jrwManager := app.createReportWriterManager();
	jrwTrans := app.myQAFilter.createJRWTransient(CM_JRWVoyages).CM_JRWVoyages;
	
	jrwTrans.setAllTerminals(termDict);	
	jrwTrans.allVoyages.add(self.myCurrentVoyage);

//	foreach repName in self.myQryReport.jrwReportName do
	foreach repName in reportArray do
		app.printer.abort();

		idx := idx + 1;
		
		jrwReport := jrwManager.getReport(repName);
		if jrwReport = null then
			app.raiseUnexpectedProgramError(class.name, method.name, "report with name 'CM_VoyageSideProfile' does not exist");
			return;
		endif;
		
		jrwReport.setOutputDestination(JadeReportWriterReport.PRINTER);
		
		// params = documentType; orientation; copies; topOfPage; bottomOfPage; leftMargin; rightMargin; borderWidth; collate; duplex
		jrwReport.setPageOptions(documentType, Print_Landscape, 1, 0, 0, 0, 20, 0, false, 0);
		jrwReport.setPreviewOptions(false, true, false, false, null);
		//these are for multi reports - doesn't barf if report does not have these params.

		app.printer.printPreview := false;
		app.printer.setReport(jadeReport);	//need to do this for each report
		
		jrwReport.run;
		
		if not isSecondTime then
			tmpJadeReport := jadeReport.cloneSelf(true);
			tmpJadeReport.description := jadeReport.description;
			isSecondTime := true;
		endif;
		
		foreach pxyPrintData in jadeReport.printArray do
			tmpPrintData := pxyPrintData.cloneSelf(true);
			tmpJadeReport.printArray.add(tmpPrintData);
		endforeach;
		pageNum := tmpJadeReport.printArray.size();
		jadeReport.printArray.purge;	//pages have been cloned on to tmpJadeReport

		abortTransaction;				// to clear any locks held by the report writer

		delete jrwReport;
	endforeach;

	app.writeLog('running report - complete', LogINFO);


	app.printPreview(tmpJadeReport, true);
	
epilog
	delete jrwReport;
	delete jrwTrans;
	delete jrwManager;
	delete reportArray;
	app.cmsEndLoad(ls);
end;
</source>
    </JadeMethod>
    <JadeMethod name="doQueryVessel" id="19211c82-9d95-44a1-841f-083e49da5dec">
        <updating/>
        <source>doQueryVessel() updating;
// ---------------------------------------------------------------------------
// Created:		23 August 2007 By Andrew Bishop cnwab1
//
// Purpose:		called from SHP_VoyageListForm::doBaseFormSave
//
// ---------------------------------------------------------------------------
vars
	aVoy : CM_Voyage;
	tmpStr : String;
begin
	self.kpiDetail := self.KPIDetail_ALL;
	
	self.showMoveStatsByJS();
	self.showBayStats();
	self.showTimings();
	self.showRORODecksStats();
	self.showROROMovesStats();
	
	if self.myVesselVoyageController &lt;&gt; null then

		foreach aVoy in self.myVesselVoyageController.allVoyages do
			if tmpStr = null then
				tmpStr := ". Vessel Comparision For "  &amp; self.myCurrentVoyage.code &amp; ", " &amp; aVoy.code;
			else
				tmpStr := tmpStr &amp; ", " &amp; aVoy.code;
			endif;
		endforeach;
		
	endif;
	
	self.caption := "Side Profile For " &amp; self.myCurrentVoyage.code &amp; tmpStr;
end;</source>
    </JadeMethod>
    <JadeMethod name="doResize" id="9eb15097-0a45-4475-8465-2770c858c898">
        <updating/>
        <source>doResize() updating;
// ---------------------------------------------------------------------------
// Created:		February 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	frmTop,toolbarTopOffset : Integer;
	
begin
	inheritMethod();
	self.sdf01.backColor := COLOUR_WATER;
	
	frmTop := (self.sdf01.top + self.frmGridArea.clientHeight).Integer;

	// #################################
	// SCROLLABLE AREA

	if self.frmToolbar.visible  then
		toolbarTopOffset := (self.frmToolbar.top + self.frmToolbar.clientHeight + 1).Integer;
	else
		toolbarTopOffset := self.frmToolbar.top.Integer;
	endif;
	self.fldMain.top := toolbarTopOffset - 1; // PAR 20197
	self.splMain.top := 1;
	self.splMain.left := 1;
	self.splMain.height := self.clientHeight - toolbarTopOffset;
	self.splMain.width := self.clientWidth - 6;
	self.splMain.backColor := Gray;
	self.sptGridArea01.left := 0; 
	self.sptGridArea01.height := self.splMain.clientHeight; 
	self.sptGridArea01.top := 0; 
	self.sptGridArea01.backColor := Gray;

	self.frmCargoPic.visible := false;
	self.sptGridArea01.left := self.frmColLegendTIs.clientWidth + 5;
	self.sptGridArea01.width := self.clientWidth - self.frmColLegendTIs.clientWidth -  17;
	
	self.sptGridArea01.cnEcResizeContents();

	self.sdf01.myDrawingFrame.width := self.getMaxWidth();
	self.sdf01.repositionScrollBars();
	// #################################
	// GridArea INFORMATION
	self.tblGridAreaInfo.width := self.sptBottom.clientWidth - 2; //
	self.tblGridAreaInfo.height:=self.sptBottom.clientHeight;
	
	self.sptBottom.backColor := Gray;
	self.sptBottom.cnEcResizeContents();
	if self.frmCargoPic.visible then
		self.picCargo.width := self.frmCargoPic.clientWidth;
		self.picCargo.top := 0;
		self.picCargo.left := 0;
		self.picCargo.height := self.frmCargoPic.clientHeight; 
	endif;
	
	self.frmColLegendTIs.top := 0; 
	self.frmColLegendTIs.left := 0;
	self.frmColLegendTIs.height := self.sptGridArea01.clientHeight;
	self.frmColLegendTIs.doResize();

	self.frmGridArea.width := 2000;
	self.sdf01.myDrawingFrame.width := 2000; // self.mySDF.allColumnEndPositions.last;
	self.sdf01.myDrawingFrame.height := 2000; // self.mySDF.allColumnEndPositions.last;
	self.frmGridArea.height := 500;
	self.sdf01.ignoreSkin := true;
	self.sdf01.myDrawingFrame.ignoreSkin := true;
	self.sdf01.myDrawingFrame.backColor := COLOUR_WATER;
	self.sdf01.backColor := COLOUR_WATER;
	
	self.splTimings.cnEcResizeContents();
	// 30278 set the table heights to keep the horizontal scroll
	self.setTableHeights();
	self.doResizeDrawingLegend();
end;</source>
    </JadeMethod>
    <JadeMethod name="doResizeDrawingLegend" id="82ad9d59-432d-4ae4-87d4-088424a9d0a5">
        <source>doResizeDrawingLegend() protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 November 2012	cnwer1	Initial creation SFW 1295

*/

vars
	shipProfileArea : SHP_ProfileArea;
	minleft : Integer;
begin
	shipProfileArea:=self.allGridAreas.first.SHP_ProfileArea;
	if shipProfileArea = null then
		return;
	endif;
	
	if not self.myCurrentSDF.drawInReverse then
		minleft := shipProfileArea.lastXForward;
	else
		minleft := shipProfileArea.lastXAft;
	endif;
	minleft:=minleft + 20;
	self.frmDrawLegend.left:= (self.myCurrentSDF.left + self.myCurrentSDF.clientWidth - self.frmDrawLegend.clientWidth -10).max(minleft);
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doTableDblClick" id="71164daa-ee5b-4e1b-a2a6-cc40283688ee">
        <updating/>
        <source>doTableDblClick(table: Table input) updating;
// ---------------------------------------------------------------------------
// Created:		February 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	if table = null then
		return;
	endif;
	if table.row &lt;= table.fixedRows then
		return;
	endif;
	
	if table.accessRow(table.row).itemObject &lt;&gt; null then
		self.myAssistant.showTableMaintForm(table.accessRow(table.row).itemObject.CM_Object, self.myMasterMenuAction, false, false);
	endif;


end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doTblTimingsMouseMove" id="4695e477-385d-4c86-b9bc-6bdec032c0f5">
        <source>doTblTimingsMouseMove(x, y : Real);
// ---------------------------------------------------------------------------
// Created:		13 September 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	row, col : Integer;
	tmpStr : String;
	table : Table;
	voy : CM_Voyage;
begin
	table := self.tblTimings;
	//row := (y / 15).roundedUp;
	table.bubbleHelp := "";	
	
	if table.getCellFromPosition(x, y, row, col) then
		voy := table.accessCell(row,col).itemObject.CM_Voyage;
	
		if voy &lt;&gt; null and row &lt;= 8 and col &gt; 2 and row &gt; 1 then
			if col &lt; 6 then 
				col := 6;
			endif;
			if row = 2 then
				tmpStr := voy.pilotOnBoardDT.shortCurrentLocaleFormat() &amp; " to " &amp; voy.labourOnShore.shortCurrentLocaleFormat() &amp; " = " &amp; self.tblTimings.accessCell(row,col).text &amp; " Hours";
			elseif row = 4 then
				tmpStr := voy.shipAnchorDownDT.shortCurrentLocaleFormat() &amp; " to " &amp; voy.shipPilotReturnDT.shortCurrentLocaleFormat() &amp; " = " &amp; self.tblTimings.accessCell(row,col).text &amp; " Hours";
			elseif row = 5 then
				tmpStr := voy.arrivedDT.shortCurrentLocaleFormat() &amp; " to " &amp; voy.labourOnShore.shortCurrentLocaleFormat() &amp; " = " &amp; self.tblTimings.accessCell(row,col).text &amp; " Hours";
			elseif row = 7 then
				tmpStr := voy.labourOnBoard.shortCurrentLocaleFormat() &amp; " to " &amp; voy.labourOnShore.shortCurrentLocaleFormat() &amp; " = " &amp; self.tblTimings.accessCell(row,col).text &amp; " Hours";
			endif;
			table.bubbleHelp := voy.code &amp; " - " &amp; self.tblTimings.accessCell(row,3).text &amp; " " &amp; self.tblTimings.accessCell(row,4).text &amp; Cr &amp; tmpStr;
			
		endif;
	endif;
end;</source>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="doTurnOffContextMenus" id="8ae7055d-4341-4e59-a720-c8b31c5ab221">
        <source>doTurnOffContextMenus();
// ---------------------------------------------------------------------------
// Created:		July 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	inheritMethod();
	self.mnuZoomSub.visible := false;
	self.mnuGridSeperator02.visible := false;
