    <JadeMethod name="doPicSeqUndoClick" id="b4b266e3-3cd4-4842-9260-25b2a72f2432">
        <updating/>
        <source>doPicSeqUndoClick() updating;
// ---------------------------------------------------------------------------
// Created:		April 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars
	aRequest : CM_Request;
	aSlotRequest : CM_SlotRequest;
	tmpJob		: CM_VoyageJob;
	tmpController	: SHP_BayDrawingController;
begin

	tmpJob := self.myCurrentJob;

	if tmpJob = null then
		return;
	endif;
	
	// must do this BEFORE the redraw as this clears
	// the custSeqObjs, otherwise the redraw uses the 
	// transient cusSeqObjs
	self.setCurrentJob(null);
	
	tmpController := self.myBayDrawingController;
	
	foreach aRequest in tmpJob.allRequests do
		aSlotRequest := aRequest.CM_SlotRequest;
		tmpController.drawObject(null, aSlotRequest.mySlotController);
	endforeach;
	
	self.currentSeqNumber := 0;
	self.hasChanged := false;

end;</source>
    </JadeMethod>
