    </JadeMethod>
    <JadeMethod name="setForUpdate" id="bca9ace2-ca10-4e74-8c2f-196c45369fa1">
        <updating/>
        <source>setForUpdate(_proxy : CM_Code) updating;
// ---------------------------------------------------------------------------
// Created:     07 February 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	_proxy.raiseExceptionIfNotTransient(method);

	self.code 			:= _proxy.code.toUpper; //PAR 10280
	self.description 	:= _proxy.description;
	self.notAvailableForEntry := _proxy.notAvailableForEntry;
end;</source>
        <Parameter name="_proxy" type="CM_Code"/>
    </JadeMethod>
    <JadeMethod name="setNotAvailableForEntry" id="e60d25b6-a9bd-4289-a97c-6a78d7cab6c7">
