    <JadeMethod name="lstCompleted_mouseDown" id="acbf564d-0e07-475d-9a2c-5569c56b5c2c">
        <controlMethod name="ListBox::mouseDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>lstCompleted_mouseDown(listbox: ListBox input; button: Integer; shift: Integer; x: Real; y: Real) updating;
// -----------------------------------------------------------------------------
// Created:		15 December 2001 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------
vars
	actualXPos	: Real;
	actualYPos	: Real;
	
begin
	if button = Window.MouseButton_Right then
		actualXPos	:=	x;
		actualYPos	:=	y;
		
		self.enableMenus(listbox);
		self.cnEcGetRelativePosition(listbox, actualXPos, actualYPos);
		self.aMyMenuListbox	:=	listbox;
		popupMenu(mnuQueue, actualXPos.Integer, actualYPos.Integer);
	endif;
end;</source>
        <Parameter name="listbox" type="ListBox" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
