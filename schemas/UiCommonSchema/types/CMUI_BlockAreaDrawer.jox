    <JadeMethod name="initYardAllocations" id="c627b8ef-1d7a-41ff-bfe1-bd51078eefe6">
        <source>initYardAllocations() protected;
//17 June 2008	cnwdw1	
// Initialise the yard allocations used by the terminal area
vars
	yalloc: CM_YardAllocation;
begin
	foreach yalloc in self.myTerminalArea.CM_IrregularBlockArea.allYardAllocations discreteLock where not (yalloc.isDisabled or not yalloc.includeInYardDisplays()) do
		self.myDrawingAttrController.allYardAllocations.addNoDuplicates(yalloc,false);
	endforeach;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="initialiseCells" id="3a7af9cd-d198-4852-a399-694dc4b8db81">
        <source>initialiseCells() protected;
// Initialise the grid cells, to reference the existing locations
vars
	location: CM_LocationsController;
	x, y: Integer;
	gridCell : CMUI_BlockGridCell;
begin
	
	self.myCells.purge();
	self.myCells.initialise(self.rows() * self.columns());
	foreach x in 1 to self.columns() do
		foreach y in 1 to self.rows() do
			create gridCell transient;
			gridCell.setColumn(x);
			gridCell.setRow(y);
			self.myCells[self.getCellIndex(x, y)] := gridCell;
		endforeach;
	endforeach;
	
	foreach location in myTerminalArea.allLocationsControllers do
		self.addLocationToCells(location.CM_IrregularBlockController);
	endforeach;
end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="initializeYardAllocations" id="29d645dd-68ce-4bff-9b5d-9b0fc7291f06">
