    <JadeMethod name="setTabOrder" id="d2dbccb9-84d3-41e9-908b-f621aaaf8297">
        <source>setTabOrder(_tabOrder: Integer) : Integer;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27/03/2013	cnwdap1	Initial creation PAR #31155 CCMS SFW 1321 Imperial Measurements
*/
vars
	tabOrder	: Integer;

begin
	tabOrder							:= inheritMethod(_tabOrder);
	tabOrder							:= tabOrder + 1;
	self.myMeasurementTable.tabIndex	:= tabOrder;
	
	return tabOrder;
epilog

end;</source>
        <Parameter name="_tabOrder" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
