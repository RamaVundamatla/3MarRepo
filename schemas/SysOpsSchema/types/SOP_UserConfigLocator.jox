    <JadeMethod name="doChangeSheetOnFldBaseCode" id="b5d382da-ac3b-4aa7-a104-5272ec6e4f35">
        <source>doChangeSheetOnFldBaseCode( _newSheet: Sheet ) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 September 2014	cnwndl1	Initial creation

*/

vars

	allSelectedObjects : ObjectArray;

begin

	if _newSheet = self.shtExtract then
	
		self.shtClasses.visible := true;
		self.shtObjects.visible := true;
		self.lblFormat.parent := _newSheet;
		self.cmbFormat.parent := _newSheet;
		self.lblNoid.parent := _newSheet;
		self.txtNoid.parent := _newSheet;
		self.lblMain.parent := _newSheet;
		self.lblMain.caption := "Main Output file";
		self.txtMain.parent := _newSheet;
		self.lblLog.parent := _newSheet;
		self.lblLog.caption := "Log file";
		self.txtLog.parent := _newSheet;
		create allSelectedObjects transient;
		self.getAllSelectedObjects( allSelectedObjects );
		if allSelectedObjects.isEmpty then
			self.lblMessage.caption := "EXTRACT";
		else
			self.lblMessage.caption := "EXTRACT " &amp; allSelectedObjects.size.String &amp; " selected objects";
		endif;
		self.lblMessage.parent := _newSheet;
	
	elseif _newSheet = self.shtImport then
	
		self.shtClasses.visible := false;
		self.shtObjects.visible := false;
		self.lblFormat.parent := _newSheet;
		self.cmbFormat.parent := _newSheet;
		self.lblNoid.parent := _newSheet;
		self.txtNoid.parent := _newSheet;
		self.lblMain.parent := _newSheet;
		self.lblMain.caption := "Main Input file";
		self.txtMain.parent := _newSheet;
		self.lblLog.parent := _newSheet;
		self.lblLog.caption := "Error file";
		self.txtLog.parent := _newSheet;
		self.lblMessage.caption := "IMPORT";
		self.lblMessage.parent := _newSheet;
	
	endif;

epilog

	delete allSelectedObjects;

end;</source>
        <access>protected</access>
        <Parameter name="_newSheet" type="Sheet"/>
    </JadeMethod>
    <JadeMethod name="doChgSelections" id="33c6ee35-9187-48ec-b42d-8868a42724e4">
        <source>doChgSelections( _tbl : CM_DataTable input ) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 September 2014	cnwndl1	Initial creation

*/

vars

	rowIndex : Integer;
	statusCol : Integer;
	startIndex : Integer;
	strValue : String;
	
	includeChanged : Boolean;
	includeMatches : Boolean;
	includeMissingDB : Boolean;
	includeMissingFile : Boolean;

begin

	statusCol := _tbl.getColumnByRowName(ETRow_Status);
	startIndex := _tbl.fixedRows + 1;
	
	if _tbl = self.tblRoles then
		includeChanged := self.chkChangeRole.value;
		includeMatches := self.chkMatchRole.value;
		includeMissingDB := self.chkFileOnlyRole.value;
		includeMissingFile := self.chkDBonlyRole.value;
	elseif _tbl = self.tblUsers then
		includeChanged := self.chkChangedUser.value;
		includeMatches := self.chkMatchUser.value;
		includeMissingDB := self.chkFileOnlyUser.value;
		includeMissingFile := self.chkDBonlyUser.value;
	endif;

	foreach rowIndex in startIndex to _tbl.rows do
		strValue := _tbl.getCellText( rowIndex, statusCol ).trimBlanks;
		if strValue = null then
			_tbl.accessRow(rowIndex).visible := true;
		elseif strValue = self.Changed and includeChanged then
			_tbl.accessRow(rowIndex).visible := true;
		elseif strValue = self.Matches and includeMatches then
			_tbl.accessRow(rowIndex).visible := true;
		elseif strValue = self.MissingDB and includeMissingDB then
			_tbl.accessRow(rowIndex).visible := true;
		elseif strValue = self.MissingFile and includeMissingFile then
			_tbl.accessRow(rowIndex).visible := true;
		else
			_tbl.accessRow(rowIndex).visible := false;
		endif;
	endforeach;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_tbl" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doColourConfigTable" id="24d3f264-42d1-4422-bb87-79c96806e143">
        <source>doColourConfigTable( 	colCurrentValue : Integer;
			colCompareValue : Integer;
			singleRow : Integer
			) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 August 2014	cnwndl1	Initial creation

*/

vars

	rowIndex : Integer;
	colUpdateValue : Integer;
	colDiffers : Integer;

begin

	colUpdateValue := self.tblCompare.getColumnByRowName(ETRow_UpdateValue);
	colDiffers := self.tblCompare.getColumnByRowName(ETRow_Differs);
	
	if singleRow &gt; 0 then
	
		rowIndex := singleRow;
		if rowIndex &gt; self.tblCompare.fixedRows and rowIndex &lt;= self.tblCompare.rows then
			if self.doTblCompareColumnValuesMatch( 	rowIndex, colCurrentValue, colCompareValue ) then
				self.tblCompare.accessRow(rowIndex).backColor := White;
				if colUpdateValue &gt; 0 then
					self.tblCompare.accessCell(rowIndex,colUpdateValue).enabled := false;
				endif;
				if colDiffers &gt; 0 then
					self.tblCompare.setCellText(rowIndex,colDiffers,null);
				endif;
			else
				self.tblCompare.accessRow(rowIndex).backColor := Yellow;
				if colUpdateValue &gt; 0 then
					self.tblCompare.accessCell(rowIndex,colUpdateValue).enabled := true;
				endif;
				if colDiffers &gt; 0 then
					self.tblCompare.setCellText(rowIndex,colDiffers,true.getYes);
				endif;
			endif;
		endif;
	
	else

		foreach rowIndex in 2 to self.tblCompare.rows do
			if self.doTblCompareColumnValuesMatch( 	rowIndex, colCurrentValue, colCompareValue ) then
				self.tblCompare.accessRow(rowIndex).backColor := White;
				if colUpdateValue &gt; 0 then
					self.tblCompare.accessCell(rowIndex,colUpdateValue).enabled := false;
				endif;
				if colDiffers &gt; 0 then
					self.tblCompare.setCellText(rowIndex,colDiffers,null);
				endif;
			else
				self.tblCompare.accessRow(rowIndex).backColor := Yellow;
				if colUpdateValue &gt; 0 then
					self.tblCompare.accessCell(rowIndex,colUpdateValue).enabled := true;
				endif;
				if colDiffers &gt; 0 then
					self.tblCompare.setCellText(rowIndex,colDiffers,true.getYes);
				endif;
			endif;
		endforeach;
	
	endif;
	
	self.doTbComparelDiffCount( false );

epilog

end;</source>
        <access>protected</access>
        <Parameter name="colCurrentValue" type="Integer"/>
        <Parameter name="colCompareValue" type="Integer"/>
        <Parameter name="singleRow" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doCompareConfigOptionsClick" id="d8f9a39e-2a99-4521-955e-f16ed755f3ba">
        <updating/>
        <source>doCompareConfigOptionsClick( optionbutton: OptionButton ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 August 2014	cnwndl1	Initial creation

*/

vars

begin

	self.optCompare.value := optionbutton = self.optCompare;
	self.optExport.value := optionbutton = self.optExport;
	self.optFile.value := optionbutton = self.optFile;
	
	self.doTbComparelDiffCount(true);
	
	self.cmbCompTerm.enabled := false;
	self.cmbExpTerm.enabled := false;
	self.btnCompTerm.enabled := false;
	self.btnCompare.enabled := false;
	self.btnExtract.enabled := false;
	
	if self.optCompare.value then
		self.cmbCompTerm.enabled := true;
		self.btnCompTerm.enabled := true;
	elseif self.optExport.value then
		self.cmbExpTerm.enabled := true;
		self.btnExtract.enabled := true;
	elseif self.optFile.value then
		self.btnCompare.enabled := true;
	endif;
	
	if frmCompHeading.visible then
		//Changing options, and already showing a comparision of some sort, clear it.
		self.doRefresh();
		self.doCompareConfigOptionsClick( optionbutton );
	endif;

epilog

end;</source>
        <Parameter name="optionbutton" type="OptionButton"/>
    </JadeMethod>
    <JadeMethod name="doCompareWithTerm" id="00dd868d-a1ef-458e-bd36-086f5ec06ada">
        <updating/>
        <source>doCompareWithTerm() protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 August 2014	cnwndl1	Initial creation

*/

vars

	term : CM_Terminal;
	xmlDoc	: JadeXMLDocument;
	agent : CM_ConfigDisplayAgent;

begin

	self.clearTableFilter();

	term := self.cmbCompTerm.listObject.CM_Terminal;
	if term = null then
		app.msgBox("Must select a Terminal to compare","Error", MsgBox_OK_Only);
		self.cmbExpTerm.setFocus();
		return;
	endif;
	
	app.mousePointer := MP_HOURGLASS;
	self.doWindowEvents(1);
	
	create agent transient;
	agent.setMyTerminal( term );
	
	self.setCompHeading( agent.sysEnviron );
		
	agent.populateXmlDoc();
	xmlDoc := agent.xmlDoc;
							
	self.doLoadXMLComparisonValues( xmlDoc, false );
	
epilog

	delete agent;
	app.mousePointer := MP_DEFAULT;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doExportCodeData" id="3ff0186a-cce9-4814-b799-384abf6cf7c5">
        <source>doExportCodeData() protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 September 2014	cnwndl1	Initial creation
// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
*/

vars

	allSelectedObjects : ObjectArray;
	formatName : String;
	errorFileName : String;
	inputFileName : String;
	noidFileName : String;
	logFileName : String;
	outputFileName : String;
	
	oidTableRootObj : CnEcOidTable;
	hubbleObj : CnEcHubble;

begin

	create allSelectedObjects transient;
	self.getAllSelectedObjects( allSelectedObjects );
	
	if allSelectedObjects.isEmpty then
		app.msgBox( "No objects selected to export", "Warning", MsgBox_OK_Only );
		return;
	endif;
	
	formatName := self.cmbFormat.text;
	if formatName = null then
		app.msgBox( "No export format selected", "Warning", MsgBox_OK_Only );
		return;
	endif;
	
	inputFileName := null;
	errorFileName := self.txtLog.text;
	noidFileName := self.txtNoid.text;
	outputFileName := self.txtMain.text;
	logFileName := self.txtLog.text;
	
	if logFileName = null then
		app.msgBox( "Log file name required", "Warning", MsgBox_OK_Only );
		return;
	endif;
	if noidFileName = null then
		app.msgBox( "Noid file name required", "Warning", MsgBox_OK_Only );
		return;
	endif;
	if outputFileName = null then
		app.msgBox( "Main Output file name required", "Warning", MsgBox_OK_Only );
		return;
	endif;
	
	lblMessage.caption := allSelectedObjects.size().String &amp; " objects being exported.";
	self.btnExtractCode.enabled := false;
	self.doWindowEvents(1);
	
	create oidTableRootObj transient;
	create hubbleObj transient;
	
	hubbleObj.initializeMe(	errorFileName,
							inputFileName,
							noidFileName,
							logFileName,
							outputFileName,
							formatName,
							oidTableRootObj,
							allSelectedObjects
							);
	
	lblMessage.caption := "Exporting...." &amp; " - " &amp; app.actualTimeServer().Time.String;// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
	self.doWindowEvents(1);
	
    if allSelectedObjects.size() &lt; 1000 then
    	hubbleObj.export(0,false);
 	else
 		hubbleObj.export((allSelectedObjects.size() div 10),false);
 	endif;   	   	
    
    lblMessage.caption :=  "Deleting transients...." &amp; " - " &amp; app.actualTimeServer().Time.String;// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
	self.doWindowEvents(1);
	
epilog

	delete allSelectedObjects;
	delete oidTableRootObj;
	delete hubbleObj;
	
	lblMessage.caption :=  "Exporting complete" &amp; " - " &amp; app.actualTimeServer().Time.String;// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
	self.btnExtractCode.enabled := true;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doExportConfigForTerm" id="41faa5cb-de43-4c2d-a64c-fc53d4416754">
        <source>doExportConfigForTerm();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 August 2014	cnwndl1	Initial creation

*/

vars

	info : String;
	fileXML : CMDFileSave;
	theXMLFile : File;
	term : CM_Terminal;
	
	agent : CM_ConfigDisplayAgent;
	xmlDoc	: JadeXMLDocument;

begin

	term := self.cmbExpTerm.listObject.CM_Terminal;
	if term = null then
		app.msgBox("Must select a Terminal to export","Error", MsgBox_OK_Only);
		self.cmbExpTerm.setFocus();
		return;
	endif;
	
	create agent transient;
	agent.setMyTerminal( term );
		
	create fileXML;
	
	fileXML.filter := "XML Files (*.XML)|*.XML";
	fileXML.allowMultiSelect := false;
	fileXML.readOnly := false;
	fileXML.fileName := agent.termEnviron &amp; '.XML';
	
	
	if fileXML.open() = 0 then
		create theXMLFile;
		theXMLFile.fileName := fileXML.fileName;
		theXMLFile.mode :=	File.Mode_Output;
		
		if not theXMLFile.tryOpen then
			info := "Unable to open nominated file";
			app.msgBox( info, "Warning", MsgBox_OK_Only );
			return;
		endif;
		
	else	
		info := "Unable to open file or cancelled";
		app.msgBox( info, "Warning", MsgBox_OK_Only );
		return;
		
	endif;
	
	app.mousePointer := MP_HOURGLASS;
	self.doWindowEvents(1);
		
	agent.populateXmlDoc();
	xmlDoc := agent.xmlDoc;
							
	if xmlDoc &lt;&gt; null then
		xmlDoc.writeToFile( theXMLFile.fileName );
		info := "XML file created '" &amp; theXMLFile.fileName &amp; "'";
		app.msgBox( info, "Warning", MsgBox_OK_Only );
	else
		info := "NO XML file created";
		app.msgBox( info, "Warning", MsgBox_OK_Only );
	endif;
	
epilog

	if fileXML &lt;&gt; null then
		delete fileXML;
	endif;
	if theXMLFile &lt;&gt; null then
		delete theXMLFile;
	endif;

	delete agent;
	app.mousePointer := MP_DEFAULT;

end;</source>
    </JadeMethod>
    <JadeMethod name="doExportUsersOrRoles" id="20599b42-9485-41c8-9cfb-d3aa30c8ecbf">
        <updating/>
        <source>doExportUsersOrRoles( _type : String ) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 September 2014	cnwndl1	Initial creation

*/

vars

	fileSave : CMDFileSave;
	file : File;
	info : String;
	
	xmlDocument : JadeXMLDocument;
	xmlElement : JadeXMLElement;
	
	role : CM_SecurityRole;
	roleSet : CM_SecurityRoleSet;
	user : CM_User;
	userSet : CM_UserSet;
	
	outputFileName : String;
	
	msg : String;
	success : Boolean;

	
begin

	if _type = self.RoleImport then
		msg := "Setting up export of role data..." &amp; CrLf;
		self.setLblRoleHeading(msg);
	elseif _type = self.UserImport then
		msg := "Setting up export of user data..." &amp; CrLf;
		self.setLblUserHeading(msg);
	endif;
		
	create fileSave;
	
	if _type = self.RoleImport then
		fileSave.dialogTitle := 'Export Roles File';
	elseif _type = self.UserImport then
		fileSave.dialogTitle := 'Export Users File';
	endif;
	
	fileSave.filter := "XML Files (*.xml)|*.xml";
	fileSave.allowMultiSelect := false;
	fileSave.defaultExt := "*.xml";
	
	if fileSave.open() = 0 then
		outputFileName := fileSave.fileName;
		create file;
		file.fileName := outputFileName;
		file.mode :=	File.Mode_Output;
		
		if not file.tryOpen then
			info := "Unable to open nominated file";
			app.msgBox( info, "Warning", MsgBox_OK_Only );
			return;
		endif;
		
		if file &lt;&gt; null then
			delete file;
		endif;
	
		if fileSave &lt;&gt; null then
			delete fileSave;
		endif;
		
		app.mousePointer := MP_HOURGLASS;
		self.doWindowEvents(1);
		
	else
		info := "Unable to open file or cancelled";
		app.msgBox( info, "Warning", MsgBox_OK_Only );
		return;
		
	endif;
	
	create xmlDocument transient;
	
	if _type = self.RoleImport then
		create roleSet transient;
		CM_SecurityRole.instances.copy( roleSet );
		CM_SecurityRoleSystem.instances.copy( roleSet );
		CM_SecurityRoleSystemRoot.instances.copy( roleSet );
		CM_SecurityRoleTerminal.instances.copy( roleSet );
		CM_SecurityRoleTerminalRoot.instances.copy( roleSet );
		msg := roleSet.size().String &amp; " roles being extracted to '" &amp; outputFileName &amp; "'." &amp; CrLf;
		self.setLblRoleHeading(msg);
		xmlElement := xmlDocument.addElement("Roles");
		foreach role in roleSet do
			role.getXMLForComparision(xmlElement);
		endforeach;
		
	elseif _type = self.UserImport then
		create userSet transient;
		CM_User.instances.copy( userSet );
		CM_UserInternal.instances.copy( userSet );
		CM_UserExternal.instances.copy( userSet );
		msg := userSet.size().String &amp; " users being extracted to '" &amp; outputFileName &amp; "'." &amp; CrLf;
		self.setLblUserHeading(msg);
		xmlElement := xmlDocument.addElement("Users");
		foreach user in userSet do
			user.getXMLForComparision(xmlElement);
		endforeach;
		
	endif;
	
	xmlDocument.writeToFile( outputFileName );
	
	success := true;
	
epilog

	if success then
		msg := "Completed to " &amp; outputFileName;
		if _type = self.RoleImport then
			self.setLblRoleHeading(msg);
		elseif _type = self.UserImport then
			self.setLblUserHeading(msg);
		endif;
	else
		msg := "Failed. " &amp; info;
		if _type = self.RoleImport then
			self.setLblRoleHeading(msg);
		elseif _type = self.UserImport then
			self.setLblUserHeading(msg);
		endif;
	endif;

	delete xmlDocument;
	delete roleSet;
	delete userSet;

	app.mousePointer := MP_DEFAULT;
	
	if file &lt;&gt; null then
		delete file;
	endif;

	if fileSave &lt;&gt; null then
		delete fileSave;
	endif;
	
end;
	</source>
        <access>protected</access>
        <Parameter name="_type" type="String"/>
    </JadeMethod>
    <JadeMethod name="doImportCodeData" id="e25a0d9d-85a5-456b-b0c5-076df3eec060">
        <source>doImportCodeData() protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 September 2014	cnwndl1	Initial creation
// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
*/

vars

	inputFileName	: String;
	noidFileName	: String;
	errorFileName	: String;
	logFileName		: String;
	outputFileName	: String;
	hubbleId		: String;
	formatName		: String;
	fileKind 		: Integer;
	oidTableObj		: CnEcOidTable;
	hubbleObj 		: CnEcHubble;
	displayMessage	: String;
	commitEveryXtrx : Integer;
	baseCaption : String;


begin

	inputFileName := self.txtMain.text;
	errorFileName := self.txtLog.text;
	noidFileName := self.txtNoid.text;
	outputFileName := null;
	logFileName := self.txtLog.text;
	
	if errorFileName = null then
		app.msgBox( "Error file name required", "Warning", MsgBox_OK_Only );
		return;
	endif;
	if noidFileName = null then
		app.msgBox( "Noid file name required", "Warning", MsgBox_OK_Only );
		return;
	endif;
	if inputFileName = null then
		app.msgBox( "Input file name required", "Warning", MsgBox_OK_Only );
		return;
	endif;

	hubbleId := "Import";
	
	oidTableObj := app.myBaseRoot.allXmlOidTables.getAtKey( hubbleId );
	if oidTableObj &lt;&gt; null then
		beginTransaction;
		delete oidTableObj;
		oidTableObj := null;
		commitTransaction;
	endif;
	
	formatName := self.cmbFormat.text;
	if formatName = null then
		app.msgBox( "No extract format selected", "Warning", MsgBox_OK_Only );
		return;
	endif;
	
	commitEveryXtrx := 1;
	//fileKind := 2;  // Kind_ANSI	
	fileKind := File.Kind_Unknown_Text;        // 23/2/16 cnwmp6 PAR 36286 unicode version
	
	create hubbleObj transient;

	hubbleObj.initializeMe(	errorFileName,
							inputFileName,
							noidFileName,
							logFileName,
							outputFileName,
							formatName,
							oidTableObj,
							null);	
	
	hubbleObj.setMyOidTable(hubbleId);
	hubbleObj.setObjectsPerTrx(commitEveryXtrx);
	hubbleObj.setMergeDuplicateCheck(true);

    baseCaption :=  "Started at " &amp; app.actualTimeServer().Time.String &amp; ".  ";// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
    lblMessage.caption := baseCaption &amp; CrLf &amp; "currently 'Loading NOID's ";
	self.doWindowEvents(1);
    
    hubbleObj.loader(CNEC_DATA_LOAD_NOID, fileKind);
	
    lblMessage.caption := baseCaption &amp; CrLf &amp; "Processing of 'Noid's completed at " &amp; app.actualTimeServer().Time.String &amp; CrLf &amp; "Currently 'Loading Primary attribute's.";// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
	self.doWindowEvents(1);
	
   	hubbleObj.loader(CNEC_DATA_LOAD_ATTRIBUTE, fileKind);
   	
   	lblMessage.caption := baseCaption &amp; CrLf &amp; "Processing of 'Primary attribute's completed at " &amp; app.actualTimeServer().Time.String &amp; CrLf &amp; "Currently 'Loading Singleton's.";// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
    self.doWindowEvents(1);
	
  	hubbleObj.loader(CNEC_DATA_LOAD_SINGLETON, fileKind);
	
  	lblMessage.caption := baseCaption &amp; CrLf &amp; "Processing of 'Singleton's completed at " &amp; app.actualTimeServer().Time.String &amp; CrLf &amp; "Currently 'Loading Collection's.";// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
    self.doWindowEvents(1);
	
	hubbleObj.loader(CNEC_DATA_LOAD_COLLECTION, fileKind);
	
	lblMessage.caption := baseCaption &amp; CrLf &amp; "Processing of 'Collection's completed at " &amp; app.actualTimeServer().Time.String &amp; CrLf &amp; "Currently 'running Epilogue's.";// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
    self.doWindowEvents(1);
	
	hubbleObj.epilogue();
	
	lblMessage.caption := baseCaption &amp; CrLf &amp; "Processing of 'Epilogue's completed at " &amp; app.actualTimeServer().Time.String &amp; CrLf &amp; "Currently 'deleting transient's.";// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
	self.doWindowEvents(1);
	
	hubbleObj.deleteMyOidTable(hubbleId);
	
epilog

	delete hubbleObj;
	lblMessage.caption := baseCaption &amp; CrLf &amp; "Complete at " &amp; app.actualTimeServer().Time.String;// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doImportUserOrRoleFile" id="6a8ff770-c388-4cb5-bb37-6130861db210">
        <updating/>
        <source>doImportUserOrRoleFile( _type : String ) protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 September 2014	cnwndl1	Initial creation

*/

vars

	fileOpen : CMDFileOpen;
	file : File;
	environ : String;
	info : String;
	xmlDoc : JadeXMLDocument;
	inputStr : String;
	str : String;
	success : Boolean;

begin
		
	create fileOpen;
	
	if _type = self.RoleImport then
		fileOpen.dialogTitle := 'Import Role File';
	elseif _type = self.UserImport then
		fileOpen.dialogTitle := 'Import User File';
	endif;
	
	fileOpen.filter := "XML Files (*.xml)|*.xml";
	fileOpen.allowMultiSelect := false;
	fileOpen.readOnly := true;
	
	if fileOpen.open() = 0 then
		create file;
		file.kind := File.Kind_Unknown_Text; // 1/3/16  cnwns1 PAR 36286 unicode version
		file.fileName := fileOpen.fileName;
		file.mode :=	File.Mode_Input;
		
		if not file.tryOpen then
			info := "Unable to open nominated file";
			app.msgBox( info, "Warning", MsgBox_OK_Only );
			return;
		endif;
		
		app.mousePointer := MP_HOURGLASS;
		self.doWindowEvents(1);
		
		file.close();
		
		create xmlDoc transient;
		xmlDoc.parseFile( fileOpen.fileName );	
	
		
	else
		info := "Unable to open file or cancelled";
		app.msgBox( info, "Warning", MsgBox_OK_Only );
		return;
		
	endif;
	
	if _type = self.RoleImport then
		self.doLoadXMLRoleValues( xmlDoc );
		str := "File = " &amp; file.fileName;
		self.setLblRoleHeading(str);
		
	elseif _type = self.UserImport then
		self.doLoadXMLUserValues( xmlDoc );
		str := "File = " &amp; file.fileName;
		self.setLblUserHeading(str);
		
	endif;
	
	success := true;

epilog

	if not success then
		str := "Failed. " &amp; info;
		if _type = self.RoleImport then
			self.setLblRoleHeading(str);
		elseif _type = self.UserImport then
			self.setLblUserHeading(str);
		endif;
	endif;

	app.mousePointer := MP_DEFAULT;
	
	if file &lt;&gt; null then
		delete file;
	endif;
	
	if xmlDoc &lt;&gt; null then
		delete xmlDoc;
	endif;

	if fileOpen &lt;&gt; null then
		delete fileOpen;
	endif;
	
end;</source>
        <access>protected</access>
        <Parameter name="_type" type="String"/>
    </JadeMethod>
    <JadeMethod name="doJumpTo" id="8c1e898f-79d4-43df-9d29-1760fa005e1b">
        <source>doJumpTo();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
12 July 2012	cnwndl1	Initial creation

*/

vars

	rowIndex : Integer;
	tblMaintFormName : String;
	tblAttributeName : String;
	term : CM_Terminal;
	sheetName : String;
	form : Form;
	formClass : Class;
	assistClass : Class;
	termConfigForm : SOP_TableMaintForm;
	sopTableMaintItem : SOP_TableMaintItem;
	configForm : CM_BaseForm;	
	cmif : CMIF_ConfigOptionsDisplay;
	table : CM_DataTable;

begin

	cmif := self.getSelectedCMIF( table );
	if cmif = null then
		app.msgBox(app.getErrorString(Select_option),app.getErrorString(Error), MsgBox_OK_Only + MsgBox_Stop_Icon);
		return;
	endif;
	
	tblAttributeName := cmif.optionName;
	tblMaintFormName := cmif.maintFormName;
	sheetName := cmif.sheetName;

	if tblMaintFormName &lt;&gt; CM_ConfigDisplayAgent.System_Config and tblMaintFormName &lt;&gt; CM_ConfigDisplayAgent.ROROVessel_Config then
		if self.cmbTerminal.listObject = null then                        
			app.msgBox(app.getErrorString(Select_Terminal),app.getErrorString(Error), MsgBox_OK_Only + MsgBox_Stop_Icon);
			self.cmbTerminal.setFocus();
			return;
		else
			term := self.cmbTerminal.listObject.CM_Terminal;
		endif;
	endif;
	

	if tblMaintFormName = CM_ConfigDisplayAgent.Terminal_Config then
		//Terminal_Config : SOP_TableMaintForm;
		termConfigForm := self.findExistingForm(tblMaintFormName, formClass, assistClass, term).SOP_TableMaintForm;
		
		if termConfigForm &lt;&gt; null then
			sopTableMaintItem := termConfigForm.myCurrentTableItem;
			termConfigForm.zOrder(1);
		else
			termConfigForm := self.myAssistant.showTableMaintForm(term, self.myMasterMenuAction, true, false).SOP_TableMaintForm;
			termConfigForm.show;
			sopTableMaintItem := termConfigForm.myCurrentTableItem;
		endif;
		
		if termConfigForm &lt;&gt; null and sopTableMaintItem &lt;&gt; null then
			sopTableMaintItem.SOPTM_Terminal.skipToAttribute( tblAttributeName, sheetName );
		endif;
		
		
	else	
		// Gate_Config : SOP_GateConfigForm;
		// Rail_Config : YRD_RailConfiguration;
		// Vehicle_Config : CMUI_RTVehicleConfig
		// System_Config : SOP_ConfigForm;
		// Voyage_Config : SHP_VoyageConfiguration;
		// ROROVessel_Config : CMUI_VesselROROConfig;
		// Invoice_Config : INV_InvoiceSystemDefaults;
		// Cash_Config : INV_CashModuleConfigForm;
		// AutoId_Config : CMUI_AutoIdConfiguration;
		// YardAlloc_Config : CMUI_YAConfigForm;
		// HandHeld_Config : CMUI_HandHeldConfigForm;
		configForm := self.findExistingForm(tblMaintFormName, formClass, assistClass, term);
		
		if configForm &lt;&gt; null then
			configForm.zOrder(1);
		elseif formClass &lt;&gt; null then
			configForm := app.loadForm(formClass, assistClass, false, false, false, term, null).CM_BaseForm;
			configForm.show;
		endif;
		
		if configForm &lt;&gt; null then
			configForm.skipToAttribute( tblAttributeName, sheetName );
		endif;
		
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doLoadFileAndCompare" id="013da5e3-9bd8-432b-bb56-6bcf44955010">
        <updating/>
        <source>doLoadFileAndCompare() protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 August 2014	cnwndl1	Initial creation

*/

vars

	fileXML : CMDFileOpen;
	theXMLFile : File;
	environ : String;
	info : String;
	fileXmlDoc : JadeXMLDocument;

begin
		
	create fileXML;
	
	fileXML.filter := "XML Files (*.XML)|*.XML";
	fileXML.allowMultiSelect := false;
	fileXML.readOnly := true;
	
	if fileXML.open() = 0 then
		create theXMLFile;
		theXMLFile.kind := File.Kind_Unknown_Text; // 1/3/16  cnwns1 PAR 36286 unicode version	
		theXMLFile.fileName := fileXML.fileName;
		theXMLFile.mode :=	File.Mode_Input;
		
		if not theXMLFile.tryOpen then
			info := "Unable to open nominated file";
			app.msgBox( info, "Warning", MsgBox_OK_Only );
			return;
		endif;
		
	else
		info := "Unable to open file or cancelled";
		app.msgBox( info, "Warning", MsgBox_OK_Only );
		return;
		
	endif;
	
	app.mousePointer := MP_HOURGLASS;
	self.doWindowEvents(1);
	
	self.clearTableFilter();
	
	create fileXmlDoc transient;
	fileXmlDoc.parseFile( theXMLFile.fileName );
	
	self.doLoadXMLComparisonValues( fileXmlDoc, true );

epilog

	app.mousePointer := MP_DEFAULT;
	
	if fileXML &lt;&gt; null then
		delete fileXML;
	endif;
	
	if fileXmlDoc &lt;&gt; null then
		delete fileXmlDoc;
	endif;

	if theXMLFile &lt;&gt; null then
		delete theXMLFile;
	endif;
	

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doLoadXMLComparisonValues" id="cbb1f4ea-cb52-48c9-b7a2-fbfc922a6d7f">
        <updating/>
        <source>doLoadXMLComparisonValues(	_xmlDoc : JadeXMLDocument input; _isFile : Boolean )protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 August 2014	cnwndl1	Initial creation 'Par Avion'

*/

vars

	value : String;
	
	fileDocElement : JadeXMLElement;
	fileRootElement	: JadeXMLElement;
	fileTermElement	: JadeXMLElement;
	fileXmlElement	: JadeXMLElement;
	fileChildNode : JadeXMLNode;
	
	childNode : JadeXMLNode;
	constantName : String;
	
	fileTerminalCode : String;
	fileSysVersion : String;
	
	colCurrentValue : Integer;
	colCompareValue : Integer;
	colCompareHeading : String;
	maxRows : Integer;
	rowIndex : Integer;
	rowIndices : IntegerArray;
	dummyConstant : String;
	
begin

	if _xmlDoc = null then
		return;
	endif;

	app.mousePointer := MP_HOURGLASS;

	colCurrentValue := self.tblCompare.getColumnByRowName(ETRow_CurrentValue);
	colCompareValue := self.tblCompare.getColumnByRowName(ETRow_CompareValue);
	maxRows := self.tblCompare.rows;
	
	colCompareHeading := "Comparison Value";

	
	fileDocElement := _xmlDoc.rootElement;
	if fileDocElement &lt;&gt; null then
		fileRootElement	:= fileDocElement.getElementByTagName("System");
		fileTermElement	:= fileDocElement.getElementByTagName("Terminal");
	endif;
	
	create rowIndices transient;
		
	if fileRootElement &lt;&gt; null then
		
		if fileRootElement.childNodes.first.isKindOf(JadeXMLCDATA) then
			fileSysVersion := fileRootElement.childNodes.first.JadeXMLCDATA.data;
		endif;
					
		foreach childNode in fileRootElement.childNodes do
			if childNode.isKindOf( JadeXMLElement ) then
				fileXmlElement := childNode.JadeXMLElement;
				constantName := fileXmlElement.tagName;
			//	value := fileXmlElement.text;
				value := fileXmlElement.text.asTextFromXML;	//15 Nov 2017	NDL	TFS 7472
				
				rowIndices.clear();
				self.findRowInCompareTable( constantName, false, rowIndices );
				if not rowIndices.isEmpty then
					foreach rowIndex in rowIndices do
						if rowIndex &gt; 1 and rowIndex &lt;= maxRows then
							self.tblCompare.setCellText( rowIndex, colCompareValue, value );
						endif;
					endforeach;
				endif;
				
			endif;
		endforeach;
		
	endif;
		
	if fileTermElement &lt;&gt; null then
	
		if fileTermElement.childNodes.first.isKindOf(JadeXMLCDATA) then
			fileTerminalCode := fileTermElement.childNodes.first.JadeXMLCDATA.data;
		endif;
					
		foreach childNode in fileTermElement.childNodes do
			if childNode.isKindOf( JadeXMLElement ) then
				fileXmlElement := childNode.JadeXMLElement;
				constantName := fileXmlElement.tagName;
				//value := fileXmlElement.text;
				//15 Nov 2017	NDL	TFS 7472
				value := fileXmlElement.text.asTextFromXML;	
				if ( constantName = "InvoiceCurrencySymbol" or constantName = "invoiceCurrencySymbol" ) and value.isInteger then
					dummyConstant := InvoiceCurrencySymbol; // to provide a reference only.
					value := value.Integer.Character.String;
				endif;
				
				rowIndices.clear();
				self.findRowInCompareTable( constantName, true, rowIndices );
				if not rowIndices.isEmpty then
					foreach rowIndex in rowIndices do
						if rowIndex &gt; 1 and rowIndex &lt;= maxRows then
							self.tblCompare.setCellText( rowIndex, colCompareValue, value );
						endif;
					endforeach;
				endif;
				
			endif;
		endforeach;
		
	endif;
	
	colCompareHeading := colCompareHeading &amp; " for (" &amp; fileTerminalCode &amp; ")";
	self.tblCompare.setCellText( 1, colCompareValue, colCompareHeading );
	
	if _isFile then
		self.setCompHeading( fileTerminalCode &amp; " FILE" );
	else
		self.setCompHeading( fileTerminalCode );
	endif;
	
	self.doColourConfigTable( colCurrentValue, colCompareValue, 0 );
		

epilog

	delete rowIndices;

end;</source>
        <access>protected</access>
        <Parameter name="_xmlDoc" type="JadeXMLDocument" usage="input"/>
        <Parameter name="_isFile" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doLoadXMLRoleValues" id="1a5d8e35-b278-4099-a70d-b64625f73781">
        <updating/>
        <source>doLoadXMLRoleValues( xmlDoc : JadeXMLDocument input ) protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 September 2014	cnwndl1	Initial creation	Par 35619

*/

vars

	statusCol : Integer;
	diffsCol : Integer;
	startIndex : Integer;
	
	xmlElementArray : JadeXMLElementArray;
	xmlRoleElement : JadeXMLElement;
	xmlSubElement : JadeXMLElement;
	myCollElementArray : JadeXMLElementArray;
	
	name : String;
	myParentName : String;
	diffString : String;
	existingRole : CM_SecurityRole;
	existingString : String;
	rowIndex : Integer;
	permissionsArray : IntegerArray;
	permissionInt : Integer;
	index : Integer;
	maxSize : Integer;
	permStr : String;
	
begin

	statusCol := self.tblRoles.getColumnByRowName(ETRow_Status);
	diffsCol := self.tblRoles.getColumnByRowName(ETRow_Differences);
	startIndex := self.tblRoles.fixedRows + 1;

	create permissionsArray transient;
	create xmlElementArray transient;
	create myCollElementArray transient;
	
	xmlDoc.getElementsByTagName( "CM_SecurityRole", xmlElementArray );
	foreach xmlRoleElement in xmlElementArray do
	
		name := null;
		myParentName := null;
		
		xmlSubElement := xmlRoleElement.getElementByTagName("name");
		if xmlSubElement &lt;&gt; null then
			name := xmlSubElement.text;
		endif;
		
		xmlSubElement := xmlRoleElement.getElementByTagName("myParentRole");
		if xmlSubElement &lt;&gt; null then
			myParentName := xmlSubElement.text;
		endif;

		diffString := null;
	
		existingRole := app.myRoot.allRoles.getAtKey( name );
		if existingRole = null then
			diffString := diffString &amp; "Name: '" &amp; name &amp; "'. ";
			diffString := diffString &amp; "Parent: '" &amp; myParentName &amp; "''. ";
			
		else
			existingString := null;
			if existingRole.myParentRole &lt;&gt; null then
				existingString := existingRole.myParentRole.name;
			endif;
			if myParentName &lt;&gt; existingString then
				diffString := diffString &amp; "Parent: '" &amp; myParentName &amp; "' vs '" &amp; existingString &amp; "'. ";
			endif;
		
		endif;
		
		permissionsArray.clear();
		
		myCollElementArray.clear;
		xmlRoleElement.findAllElementsByTagName( "permission", myCollElementArray );
		foreach xmlSubElement in myCollElementArray do
			permissionInt := xmlSubElement.text.Integer;
			permissionsArray.add( permissionInt );
		endforeach;
		
		
		
		if existingRole = null then
			diffString := diffString &amp; " " &amp; permissionsArray.size.String &amp; " granted permissions. ";		
		else
			maxSize := existingRole.permissions.size;
			foreach index in permissionsArray do
				if index &gt; maxSize then
					break;
				endif;
				if not existingRole.permissions[index] then
					permStr := self.getPermissionNameFromInteger(index);
					diffString := diffString &amp; permStr &amp; " permission: 'false' vs 'true'. ";
				endif;
			endforeach;
			foreach index in 1 to maxSize do
				if existingRole.permissions[index] then
					if not permissionsArray.includes( index ) then
						permStr := self.getPermissionNameFromInteger(index);
						diffString := diffString &amp; permStr &amp; " permission: 'true' vs 'false'. ";
					endif;
				endif;
			endforeach;
			
		endif;
		
		if existingRole &lt;&gt; null then
			rowIndex := startIndex;
			self.tblRoles.findObjectInRow( existingRole, rowIndex );
			if rowIndex &gt;= startIndex and rowIndex &lt;= self.tblRoles.rows then
				if diffString = null then
					self.tblRoles.setCellText( rowIndex, statusCol, self.Matches );
				else
					self.tblRoles.setCellText( rowIndex, statusCol, self.Changed );
					self.tblRoles.setCellText( rowIndex, diffsCol, diffString );
				endif;
			endif;
		else
			rowIndex := self.tblRoles.addItem( name );
			self.tblRoles.setCellText( rowIndex, statusCol, self.MissingDB );
			self.tblRoles.setCellText( rowIndex, diffsCol, diffString );
		endif;
		
	endforeach;
	
	foreach rowIndex in startIndex to self.tblRoles.rows do
		if self.tblRoles.getCellText( rowIndex, statusCol ).trimBlanks = null then
			self.tblRoles.setCellText( rowIndex, statusCol, self.MissingFile );
		endif;
	endforeach;
	
	self.doChgSelections( self.tblRoles );

epilog

	delete xmlElementArray;
	delete myCollElementArray;
	delete permissionsArray;

end;</source>
        <access>protected</access>
        <Parameter name="xmlDoc" type="JadeXMLDocument" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doLoadXMLUserValues" id="c75da29d-c6d0-4240-b111-42efa706763a">
        <updating/>
        <source>doLoadXMLUserValues( xmlDoc : JadeXMLDocument input ) protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 September 2014	cnwndl1	Initial creation	Par 35619
04 Feb 2025	navah1	Story 14660: MTN - New option to disable users from changing their own passwords
*/

vars

	xmlElementArray : JadeXMLElementArray;
	xmlUserElement : JadeXMLElement;
	myCollElementArray : JadeXMLElementArray;
	xmlSubElement : JadeXMLElement;
	xmlSubSubElement : JadeXMLElement;
	
	code : String;
	status : Integer;
	allowAutomaticDisability : Boolean;
	persistentPassword : Boolean;
	preventPasswordChange : Boolean; 	//04.02.2025 navah1 #14660
	isNotAvailableForEntry : Boolean;
	myOrgName : String;
	mySysSecRoleName : String;
	myLocaleDesc : String;
	userName : String;
	termCode : String;
	termSecRoleName : String;
	
	existingUser : CM_User;
	diffString : String;
	existingString : String;
	
	termCodeArray : StringArray;
	termSecRoleNameArray : StringArray;
	index : Integer;
	userTerminal : CM_UserTerminal;
	found : Boolean;
	
	rowIndex : Integer;
	statusCol : Integer;
	diffsCol : Integer;
	startIndex : Integer;

begin

	statusCol := self.tblUsers.getColumnByRowName(ETRow_Status);
	diffsCol := self.tblUsers.getColumnByRowName(ETRow_Differences);
	startIndex := self.tblUsers.fixedRows + 1;

	create xmlElementArray transient;
	create myCollElementArray transient;
	create termCodeArray transient;
	create termSecRoleNameArray transient;
	
	xmlDoc.getElementsByTagName( "CM_User", xmlElementArray );
	foreach xmlUserElement in xmlElementArray do
	
		code := null;
		status := null;
		allowAutomaticDisability := false;
		persistentPassword := false;
		isNotAvailableForEntry := false;
		userName := null;
		myOrgName := null;
		mySysSecRoleName := null;
		myLocaleDesc := null;
		
		xmlSubElement := xmlUserElement.getElementByTagName("code");
		if xmlSubElement &lt;&gt; null then
			code := xmlSubElement.text;
		endif;
		xmlSubElement := xmlUserElement.getElementByTagName("status");
		if xmlSubElement &lt;&gt; null then
			status := xmlSubElement.text.Integer;
		endif;
		xmlSubElement := xmlUserElement.getElementByTagName("allowAutomaticDisability");
		if xmlSubElement &lt;&gt; null then
			allowAutomaticDisability := xmlSubElement.text.Boolean;
		endif;
		xmlSubElement := xmlUserElement.getElementByTagName("persistentPassword");
		if xmlSubElement &lt;&gt; null then
			persistentPassword := xmlSubElement.text.Boolean;
		endif;
		xmlSubElement := xmlUserElement.getElementByTagName("preventPasswordChange"); 	//04.02.2025 navah1 #14660
		if xmlSubElement &lt;&gt; null then													//04.02.2025 navah1 #14660
			preventPasswordChange := xmlSubElement.text.Boolean;
		endif;
		xmlSubElement := xmlUserElement.getElementByTagName("isNotAvailableForEntry");
		if xmlSubElement &lt;&gt; null then
			isNotAvailableForEntry := xmlSubElement.text.Boolean;
		endif;
		xmlSubElement := xmlUserElement.getElementByTagName("userName");
		if xmlSubElement &lt;&gt; null then
			userName := xmlSubElement.text;
		endif;
		xmlSubElement := xmlUserElement.getElementByTagName("myOrgName");
		if xmlSubElement &lt;&gt; null then
			myOrgName := xmlSubElement.text;
		endif;
		xmlSubElement := xmlUserElement.getElementByTagName("mySysSecRoleName");
		if xmlSubElement &lt;&gt; null then
			mySysSecRoleName := xmlSubElement.text;
		endif;
		xmlSubElement := xmlUserElement.getElementByTagName("myLocaleDesc");
		if xmlSubElement &lt;&gt; null then
			myLocaleDesc := xmlSubElement.text;
		endif;
		
		diffString := null;
	
		existingUser := app.myRoot.allUsers.getAtKey( code );
		
		if existingUser = null then
			diffString := diffString &amp; "Code: '" &amp; code &amp; "'. ";
			diffString := diffString &amp; "Name: '" &amp; userName &amp; "'. ";
			diffString := diffString &amp; "Status: '" &amp; app.userStatusEnumToString(status) &amp; "''. ";
			diffString := diffString &amp; "Auto-disable if inactive: '" &amp; allowAutomaticDisability.String &amp; "''. ";
			diffString := diffString &amp; "Password never expires: '" &amp; persistentPassword.String &amp; "''. ";
			diffString := diffString &amp; "Organisation: '" &amp; myOrgName &amp; "''. ";
			diffString := diffString &amp; "System Security Role: '" &amp; mySysSecRoleName &amp; "''. ";
			diffString := diffString &amp; "Not Available For Entry: '" &amp; isNotAvailableForEntry.String &amp; "''. ";
			diffString := diffString &amp; "Locale: '" &amp; myLocaleDesc &amp; "''. ";
			diffString := diffString &amp; "Prevent changing own password: '" &amp; preventPasswordChange.String &amp; "''. ";  //04.02.2025 navah1 #14660
		else
			if userName &lt;&gt; existingUser.userName then
				diffString := diffString &amp; "Name: '" &amp; userName &amp; "' vs '" &amp; existingUser.userName &amp; "'. ";
			endif;
			if status &lt;&gt; existingUser.status then
				diffString := diffString &amp; "Status: '" &amp; app.userStatusEnumToString(status) &amp; "' vs '" &amp; app.userStatusEnumToString(existingUser.status) &amp; "'. ";
			endif;
			if allowAutomaticDisability &lt;&gt; existingUser.allowAutomaticDisability then
				diffString := diffString &amp; "Auto-disable if inactive: '" &amp; allowAutomaticDisability.String &amp; "' vs '" &amp; existingUser.allowAutomaticDisability.String &amp; "'. ";
			endif;
			if persistentPassword &lt;&gt; existingUser.persistentPassword then
				diffString := diffString &amp; "Password never expires: '" &amp; persistentPassword.String &amp; "' vs '" &amp; existingUser.persistentPassword.String &amp; "'. ";
			endif;
			if preventPasswordChange &lt;&gt; existingUser.preventPasswordChange then 	//04.02.2025 navah1 #14660
				diffString := diffString &amp; "Prevent changing own password: '" &amp; preventPasswordChange.String &amp; "' vs '" &amp; existingUser.preventPasswordChange.String &amp; "'. ";
			endif;
			existingString := null;
			if existingUser.myOrganisation &lt;&gt; null then
				existingString := existingUser.myOrganisation.name;
			endif;
			if myOrgName &lt;&gt; existingString then
				diffString := diffString &amp; "Organisation: '" &amp; myOrgName &amp; "' vs '" &amp; existingString &amp; "'. ";
			endif;
			existingString := null;
			if existingUser.mySystemSecurityRole &lt;&gt; null then
				existingString := existingUser.mySystemSecurityRole.name;
			endif;
			if mySysSecRoleName &lt;&gt; existingString then
				diffString := diffString &amp; "System Security Role: '" &amp; mySysSecRoleName &amp; "' vs '" &amp; existingString &amp; "'. ";
			endif;
			if isNotAvailableForEntry &lt;&gt; existingUser.isNotAvailableForEntry then
				diffString := diffString &amp; "Not Available For Entry: '" &amp; isNotAvailableForEntry.String &amp; "' vs '" &amp; existingUser.isNotAvailableForEntry.String &amp; "'. ";
			endif;
			existingString := null;
			if existingUser.myLocale &lt;&gt; null then
				existingString := existingUser.myLocale.localeDescription;
			endif;
			if myLocaleDesc &lt;&gt; existingString then
				diffString := diffString &amp; "Locale: '" &amp; myLocaleDesc &amp; "' vs '" &amp; existingString &amp; "'. ";
			endif; 
		endif;
		
		termCodeArray.clear;
		termSecRoleNameArray.clear;
		myCollElementArray.clear;
		xmlUserElement.findAllElementsByTagName( "CM_UserTerminal", myCollElementArray );
		if not myCollElementArray.isEmpty then
			foreach xmlSubElement in myCollElementArray do
			
				termCode := null;
				termSecRoleName := null;
				
				xmlSubSubElement := xmlSubElement.getElementByTagName("termCode");
				if xmlSubSubElement &lt;&gt; null then
					termCode := xmlSubSubElement.text;
				endif;
				xmlSubSubElement := xmlSubElement.getElementByTagName("termSecRoleName");
				if xmlSubSubElement &lt;&gt; null then
					termSecRoleName := xmlSubSubElement.text;
				endif;
		
				termCodeArray.add( termCode );
				termSecRoleNameArray.add( termSecRoleName );
				
			endforeach;
		endif;
		
		if existingUser = null then
			if not termCodeArray.isEmpty then
				foreach index in 1 to termCodeArray.size do
					found := false;
					termCode := termCodeArray[index];
					termSecRoleName := termSecRoleNameArray[index];
					if termSecRoleName = null then
						diffString := diffString &amp; termCode &amp; " Terminal Access. ";
					else
						diffString := diffString &amp; termCode &amp; " Terminal Access Security: '" &amp; termSecRoleName &amp; "'. ";
					endif;
				endforeach;
			endif;
		else
			if not termCodeArray.isEmpty then
				foreach index in 1 to termCodeArray.size do
					found := false;
					termCode := termCodeArray[index];
					termSecRoleName := termSecRoleNameArray[index];
					foreach userTerminal in existingUser.allUserTerminals do
						if userTerminal.myTerminal = null or userTerminal.myTerminal.code &lt;&gt; termCode then
							continue;
						endif;
						found := true;
						break;
					endforeach;
					if not found then
						diffString := diffString &amp; termCode &amp; " Terminal Access: 'No' vs 'Yes'. ";
					else
						if userTerminal.mySecurityRole = null then
							if termSecRoleName &lt;&gt; null then
								diffString := diffString &amp; termCode &amp; " Terminal Access Security: 'None' vs '" &amp; termSecRoleName &amp; "'. ";
							endif;
						elseif userTerminal.mySecurityRole.name &lt;&gt; termSecRoleName then
							diffString := diffString &amp; termCode &amp; " Terminal Access Security: '" &amp; userTerminal.mySecurityRole.name &amp; "' vs '" &amp; termSecRoleName &amp; "'. ";
						endif;
					endif;
				endforeach;
			endif;
			foreach userTerminal in existingUser.allUserTerminals do
				termCode := userTerminal.myTerminal.code;
				index := termCodeArray.indexOf(userTerminal.myTerminal.code);
				if index &lt; 1 then
					diffString := diffString &amp; termCode &amp; " Terminal Access: 'Yes' vs 'No'. ";
					continue;
				endif;
				termSecRoleName := null;
				if userTerminal.mySecurityRole &lt;&gt; null then
					termSecRoleName := userTerminal.mySecurityRole.name;
				endif;
				if termSecRoleNameArray[index] &lt;&gt; termSecRoleName then
					diffString := diffString &amp; termCode &amp; " Terminal Access Security: '" &amp; termSecRoleName &amp; "' vs '" &amp; termSecRoleNameArray[index] &amp; "'. ";
				endif;
			endforeach;
		endif;
		
		if existingUser &lt;&gt; null then
			rowIndex := startIndex;
			self.tblUsers.findObjectInRow( existingUser, rowIndex );
			if rowIndex &gt;= startIndex and rowIndex &lt;= self.tblUsers.rows then
				if diffString = null then
					self.tblUsers.setCellText( rowIndex, statusCol, self.Matches );
				else
					self.tblUsers.setCellText( rowIndex, statusCol, self.Changed );
					self.tblUsers.setCellText( rowIndex, diffsCol, diffString );
				endif;
			endif;
		else
			rowIndex := self.tblUsers.addItem( code &amp; "/" &amp; userName );
			self.tblUsers.setCellText( rowIndex, statusCol, self.MissingDB );
			self.tblUsers.setCellText( rowIndex, diffsCol, diffString );
		endif;
		
	endforeach;
	
	foreach rowIndex in startIndex to self.tblUsers.rows do
		if self.tblUsers.getCellText( rowIndex, statusCol ).trimBlanks = null then
			self.tblUsers.setCellText( rowIndex, statusCol, self.MissingFile );
		endif;
	endforeach;
	
	self.doChgSelections( self.tblUsers );

epilog

	delete xmlElementArray;
	delete myCollElementArray;
	delete termCodeArray;
	delete termSecRoleNameArray;

end;</source>
        <access>protected</access>
        <Parameter name="xmlDoc" type="JadeXMLDocument" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doRefresh" id="8966afb7-5cae-4b2c-8ac5-a4a69a4aa8a7">
        <updating/>
        <source>doRefresh() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 August 2014	cnwndl1	Initial creation
25 August 2022  navds20 ChangeRequest 54617: MTN - Configure Options Locator

*/

	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars

	locale : CM_Locale;
	
begin

	if self.myTerminal &lt;&gt; self.cmbTerminal.listObject then
		self.setMyTerminal( self.cmbTerminal.listObject.CM_Terminal);
		
		locale := app.myCurrentLocale;
		if locale = null then
			locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
			// if no locale the bail out at this point
			if locale = null then
				return;
			endif;
		endif;
		
		self.translateCaption(Xlat_0018599, locale);
		self.setCaption( self.caption ); // to add the term code...
	endif;
	
	inheritMethod();
	
	//start 22/09/2022 navds20 TFS 54617
	if not self.isFind then
		self.txtFilterBox.text := ""; 
		self.txtSearchMsg.text := "";
	else
		self.isFind :=false;
	endif;
	//end 22/09/2022 navds20 TFS 54617
	
	self.clearTableFilter();
	self.frmSearchMsg.visible :=false; 		    //26/08/2022 navds20 TFS 54617
	self.populateTable();
	self.populateUserTable();
	self.populateRoleTable();

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doResize" id="aeb4ff50-cb63-4efe-bc28-589b8bfa921f">
        <updating/>
        <source>doResize() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
12 July 2012	cnwndl1	Initial creation
28/09/2022 	navds20 ChangeRequest 54617: MTN - Configure Options Locator

*/

vars

begin

	inheritMethod();
	
	self.grpConfig.top := self.frmToolbar.height + 2;
	self.grpConfig.left := 1;
	self.grpConfig.width := self.clientWidth - 2;
 // ### TFS 50421 17SEP2021 NAVAB1	self.grpConfig.height := self.clientHeight - 57;
	self.grpConfig.height := self.clientHeight - self.frmToolbar.clientHeight - self.btnClose1.clientHeight - 10; // ### TFS 50421 17SEP2021 NAVAB1
	
	
	self.btnClose1.top := self.grpConfig.top + self.grpConfig.height + 2;
	self.btnClose1.left := self.clientWidth - ( self.btnClose1.width + 2 );
	
	
	self.btnJumpTo.left := 2;
	self.btnJumpTo.top := self.btnClose1.top;
	
	//self.cmbTerminal.top := self.btnClose1.top + 2;		//25/08/2022 navds20 TFS 54617
	//self.cmbTerminal.left := self.btnJumpTo.left + ( self.btnJumpTo.width + 2 );		//25/08/2022 navds20 TFS 54617
	
	self.btnRefresh2.top := self.btnJumpTo.top;
	//self.btnRefresh2.left := self.cmbTerminal.left + ( self.cmbTerminal.width + 2 );	//25/08/2022 navds20 TFS 54617
	
	self.tblCompare.top := 40; // TFS 52235 2NOV2021 NAVLW1
	self.tblCompare.height := self.shtCompare.height - 30;
	
	
	self.frmExpTerm.borderStyle := 0;
	self.frmCompTerm.borderStyle := 0;
	self.frmCompFile.borderStyle := 0;
	
	self.resizeColumns( false );
	
	self.lblSelectTerm.top := (( self.tblConfigOptions.top + self.tblConfigOptions.height ) - self.lblSelectTerm.height );
	//self.lblSelectTerm.left := self.cmbTerminal.left - (( self.lblSelectTerm.width - self.cmbTerminal.width ) /2 );	//25/08/2022 navds20 TFS 54617
	
	self.lblDifferences.left := self.btnClose1.left - self.lblDifferences.width - 20;
	self.lblDifferences.top := self.btnClose1.top;
	
	self.tblUsers.top := 40; // TFS 52235 2NOV2021 NAVLW1
	self.tblUsers.height := self.shtUsers.height - 30;
	
	self.tblRoles.top := 40; // TFS 52235 2NOV2021 NAVLW1
	self.tblRoles.height := self.shtRoles.height - 30;
	
	self.fldMain.cnEcResizeContents(); // ### TFS 50421 17SEP2021 NAVAB1
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doSaveSelection" id="dcefd068-2580-4734-9ce5-8868b432051e">
        <updating/>
        <source>doSaveSelection() protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 September 2014	cnwndl1	Initial creation

*/

vars

	objSet : ObjectSet;
	index : Integer;
	obj : Object;

begin

	if self.myCurrentClass &lt;&gt; null then
		self.getSelectedObjects( self.myCurrentClass, objSet );
		if objSet = null then
			create objSet transient;
		endif;
		objSet.clear();
		if self.chkSelectAll.value then
			if self.myCurrentClass = CM_Organisation then
				CM_ExternalOrganisation.instances.copy(objSet);
				CM_InternalOrganisation.instances.copy(objSet);
			elseif self.myCurrentClass = CM_RadioTelemetryDevice then
				CM_RTDeviceHandHeld.instances.copy(objSet);
				CM_RTDeviceVehicleMount.instances.copy(objSet);
			else
				self.myCurrentClass.instances.copy(objSet);
			endif;
		else
			foreach index in 2 to self.tblObjects.rows do
				if self.tblObjects.getCellText( index, 1 ).Integer = 1 then
					obj := self.tblObjects.accessRow( index ).itemObject;
					objSet.add( obj );
				endif;
			endforeach;
		endif;
		
		if not self.selectedObjectSets.includes( objSet ) then
			self.selectedObjectSets.add( objSet );
		endif;
		
	endif;
	
	self.populateClassesTable();

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doSearch" id="c252f263-0714-41cb-8355-db14af45c87c">
        <updating/>
        <source>doSearch()updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
12 July 2012	cnwndl1	Initial creation

21 Jul 2022 navvt20 Bug 52421: MTN - System Configuration first row not selected when loading form
8 Aug 2023 	navhl20 Bug 59197: MTN - Terminal Config Option Search does not Show Current Values
*/

vars

	searchText : String;
	row : Integer;
	targetText : String;
	matches : Boolean;
	includeConstant : Boolean;
	cmif : CMIF_ConfigOptionsDisplay;
	jRow : JadeTableRow; // 21 July 2022 navvt20 52421
	numRows,rowIdx		: Integer;//21 July 2022 navvt20 52421

begin

	// ### TFS 55322 08NOV2022 NAVAB1 searchText := self.txtSearchMsg.text.toUpper.trimBlanks;
	searchText := self.txtFilterBox.text.toUpper.trimBlanks; // ### TFS 55322 08NOV2022 NAVAB1
	self.doRefresh();											//8.8.2023 navhl20 #59197
    self.txtFilterBox.text := searchText;						//8.8.2023 navhl20 #59197

	if searchText = null then
		foreach row in 1 to self.tblConfigOptions.rows do
			self.tblConfigOptions.accessRow( row ).visible := true;
		endforeach;
		
	else
		includeConstant := self.allowShowConstant;
		foreach row in 1 to self.tblConfigOptions.rows do
			if row = 1 then
				continue;
			endif;
			cmif := self.tblConfigOptions.accessRow(row).itemObject.CMIF_ConfigOptionsDisplay;
			targetText := cmif.getTextToSearch( includeConstant );
			matches := targetText.pos(searchText,1) &gt; 0;
			self.tblConfigOptions.accessRow( row ).visible := matches;
		endforeach;
		// Start 21 July 2022 navvt20 52421
		numRows := self.tblConfigOptions.rows;
		self.tblConfigOptions.clearAllSelected();

		foreach rowIdx in self.tblConfigOptions.fixedRows to numRows do
			jRow := self.tblConfigOptions.accessRow(rowIdx);
			if not jRow.visible then
				continue;
			endif;
				
			self.tblConfigOptions.selectRow(rowIdx,false);
		
			if(rowIdx&gt;1) then
				return;
			endif;
		
		endforeach;
		
		// End 21 July 2022 navvt20 52421
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doTbComparelDiffCount" id="f058e0a5-23ff-4f4f-815d-e7ae809034f0">
        <source>doTbComparelDiffCount( _clearOnly : Boolean );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 August 2014	cnwndl1	Initial creation

*/

vars

	colDiffers : Integer;
	rowIndex : Integer;
	count : Integer;

begin

	self.lblDifferences.visible := false;
	
	if _clearOnly
	or not self.allowConfigCompare
	or ( self.optCompare.value = false and self.optFile.value = false )
	then
		return;
	endif;
	
	colDiffers := self.tblCompare.getColumnByRowName(ETRow_Differs);
	
	foreach rowIndex in 2 to self.tblCompare.rows do
		if self.tblCompare.getCellText(rowIndex,colDiffers) = true.getYes then
			count := count + 1;
		endif;
	endforeach;
	
	self.lblDifferences.visible := true;

	if count = 0 then
		self.lblDifferences.caption := "No differences detected";
		self.lblDifferences.transparent := true;
	else
		self.lblDifferences.caption := count.String &amp; " difference(s) detected";
		self.lblDifferences.transparent := false;
		self.lblDifferences.backColor := Yellow;
	endif;

epilog

end;</source>
        <Parameter name="_clearOnly" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doTblCompareColumnValuesMatch" id="a9b1259a-d39f-4609-b109-718239be9ae5">
        <source>doTblCompareColumnValuesMatch( 	rowIndex : Integer;
						colCurrentValue : Integer;
						colCompareValue : Integer
						):Boolean protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 August 2014	cnwndl1	Initial creation

*/

vars

	cellText1 : String;
	cellText2 : String;

begin

	cellText1 := self.tblCompare.getCellText( rowIndex, colCurrentValue );
	cellText2 := self.tblCompare.getCellText( rowIndex, colCompareValue );
	
	return self.myConfigDisplayAgent.valuesMatch( cellText1,  cellText2 );

epilog

end;</source>
        <access>protected</access>
        <Parameter name="rowIndex" type="Integer"/>
        <Parameter name="colCurrentValue" type="Integer"/>
        <Parameter name="colCompareValue" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="findExistingForm" id="31766b17-85d2-49cd-9fb8-3225d0d5a552">
        <source>findExistingForm( _formName : String; _formClass : Class output; _assistClass : Class output; _term : CM_Terminal ):CM_BaseForm protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 July 2012	cnwndl1	Initial creation
19 Sep 2019	jlgdi1	Added Storage Cofiguration form
*/

vars

	form : Form;
	formIndex : Integer;
	sopTableMaintItem : SOP_TableMaintItem;
	schema : Schema;
	formClass : Class;

begin

	_assistClass := CMUI_Assistant;

	if _formName = CM_ConfigDisplayAgent.System_Config then
		_formClass := SOP_ConfigForm;
		return app.getForm("SOP_ConfigForm").CM_BaseForm;
		
	elseif _formName = CM_ConfigDisplayAgent.ROROVessel_Config then
		_formClass := CMUI_VesselROROConfig;
		return app.getForm("CMUI_VesselROROConfig").CM_BaseForm;
		
	else
	
		if _formName = CM_ConfigDisplayAgent.Gate_Config then
			_formClass := SOP_GateConfigForm;
		elseif _formName = CM_ConfigDisplayAgent.HandHeld_Config then
			_formClass :=CMUI_HandHeldConfigForm;
		elseif _formName = CM_ConfigDisplayAgent.Rail_Config then
			schema := currentSchema.getSchema("YardSchema");
			_formClass := schema.getClass("YRD_RailConfiguration");
			_assistClass := schema.getClass("YRD_Assistant");
		elseif _formName = CM_ConfigDisplayAgent.Vehicle_Config then
			_formClass := CMUI_RTVehicleConfig;
		elseif _formName = CM_ConfigDisplayAgent.Terminal_Config then
			_formClass := SOP_TableMaintForm;
		elseif _formName = CM_ConfigDisplayAgent.Voyage_Config then
			schema := currentSchema.getSchema("ShipSchema");
			_formClass := schema.getClass("SHP_VoyageConfiguration");
			_assistClass := schema.getClass("SHP_Assistant");
		elseif _formName = CM_ConfigDisplayAgent.Invoice_Config then
			schema := currentSchema.getSchema("InvoiceSchema");
			_formClass := schema.getClass("INV_InvoiceSystemDefaults");
			_assistClass := schema.getClass("INV_Assistant");
		elseif _formName = CM_ConfigDisplayAgent.Cash_Config then
			schema := currentSchema.getSchema("InvoiceSchema");
			_formClass := schema.getClass("INV_CashModuleConfigForm");
			_assistClass := schema.getClass("INV_Assistant");
		elseif _formName = CM_ConfigDisplayAgent.AutoId_Config then
			schema := currentSchema.getSchema("UiCommonSchema");
			_formClass := schema.getClass("CMUI_AutoIdConfiguration");
		elseif _formName = CM_ConfigDisplayAgent.YardAlloc_Config then
			schema := currentSchema.getSchema("UiCommonSchema");
			_formClass := schema.getClass("CMUI_YAConfigForm");
		elseif _formName = CM_ConfigDisplayAgent.Storage_Config then
			schema := currentSchema.getSchema("InvoiceSchema");
			_formClass := schema.getClass("INV_StorageConfig");
		else
			app.msgBox("Direct navigation to this form type not implemented yet." &amp; CrLf &amp; method.qualifiedName ,app.getErrorString(Warning), MsgBox_OK_Only);
			_formClass := null;
			return null;
		endif;
		

		foreach formIndex in 1 to app.formsCount() do
			form := app.forms(formIndex);
			if form.class &lt;&gt; _formClass then
				continue;
			endif;
			if _formName = CM_ConfigDisplayAgent.Terminal_Config then
				sopTableMaintItem := form.SOP_TableMaintForm.myCurrentTableItem;
				if sopTableMaintItem = null then
					continue;
				endif;
				if not sopTableMaintItem.isKindOf(SOPTM_Terminal) then
					continue;
				endif;
				if _term &lt;&gt; form.SOP_TableMaintForm.myCurrentObject then
					continue;
				endif;
			else
				if _term &lt;&gt; form.CM_BaseForm.myTerminal then
					continue;
				endif;
			endif;
			// OK we have found the form already open for our terminal
			return form.CM_BaseForm;
			
		endforeach;
			
		return null;
		
	endif;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_formName" type="String"/>
        <Parameter name="_formClass" type="Class" usage="output"/>
        <Parameter name="_assistClass" type="Class" usage="output"/>
        <Parameter name="_term" type="CM_Terminal"/>
        <ReturnType type="CM_BaseForm"/>
    </JadeMethod>
    <JadeMethod name="findRowInCompareTable" id="c2495dd6-7534-4068-bb97-02e0b89226b0">
        <source>findRowInCompareTable( _passedText : String; _perTerm : Boolean; rowIndices : IntegerArray io ) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 August 2014	cnwndl1	Initial creation

*/

vars

	rowIndex : Integer;
	cmif : CMIF_ConfigOptionsDisplay;
	cellText : String;
	formColumn : Integer;
	dummyConstant : String;

begin

	foreach rowIndex in 2 to self.tblCompare.rows do
		cmif := self.tblCompare.accessRow(rowIndex).itemObject.CMIF_ConfigOptionsDisplay;
		if cmif &lt;&gt; null and cmif.constantName = _passedText then
			if cmif.appliesToTerm = _perTerm then
				rowIndices.add( rowIndex );
			endif;
		endif;
	endforeach;
	
	if rowIndices.isEmpty then
		foreach rowIndex in 2 to self.tblCompare.rows do
			cmif := self.tblCompare.accessRow(rowIndex).itemObject.CMIF_ConfigOptionsDisplay;
			dummyConstant := self.myConfigDisplayAgent.convertValueForXMLTagUse(cmif.optionName);
			if dummyConstant = _passedText then
				if cmif.appliesToTerm = _perTerm then
					rowIndices.add( rowIndex );
				endif;
			endif;
		endforeach;
	endif;
	

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_passedText" type="String"/>
        <Parameter name="_perTerm" type="Boolean"/>
        <Parameter name="rowIndices" type="IntegerArray" usage="io"/>
    </JadeMethod>
    <JadeMethod name="fldBaseCode_querySheetChg" id="edee7c0b-934d-4386-88d1-e26cef65d164">
        <controlMethod name="CMUI_Folder::querySheetChg"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>fldBaseCode_querySheetChg(folder: Folder; newSheet: Sheet):Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 September 2014	cnwndl1	Initial creation

*/

vars

begin

	self.doChangeSheetOnFldBaseCode( newSheet );
	return true;

epilog

end;</source>
        <Parameter name="folder" type="Folder"/>
        <Parameter name="newSheet" type="Sheet"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="fldMain_querySheetChg" id="107c97a8-8e34-4e5c-9b76-e894759f8a15">
        <controlMethod name="CMUI_Folder::querySheetChg"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>fldMain_querySheetChg(folder: Folder; newSheet: Sheet):Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 August 2014	cnwndl1	Initial creation

*/

vars

begin

	if newSheet = self.shtCompare and not allowConfigCompare then
		return false;
	elseif newSheet = self.shtUsers  and not allowUserCompare then
		return false;
	elseif newSheet = self.shtRoles  and not allowRoleCompare then
		return false;
	elseif newSheet = self.shtBaseCode  and not allowDataMigration then
		return false;
	endif;

	self.shtChange( newSheet );
	return true;

epilog

end;</source>
        <Parameter name="folder" type="Folder"/>
        <Parameter name="newSheet" type="Sheet"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getAllSelectedObjects" id="c9d63910-066d-47fc-bd96-6d9f08fae64f">
        <source>getAllSelectedObjects( _allSelectedObjects : ObjectArray input ) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 September 2014	cnwndl1	Initial creation

*/

vars

	obj : Object;
	objSet : ObjectSet;
	subObj : Object;
	consign : CM_ConsigneeConsignor;
	add : CM_Address;
	rt : CM_RadioTelemetry;

begin

	foreach obj in self.selectedObjectSets do
		if not obj.isKindOf( ObjectSet ) then
			continue;
		endif;
		objSet := obj.ObjectSet;
		if not objSet.isEmpty then
			subObj := objSet.first;
			if subObj.isKindOf( CM_ConsigneeConsignor ) then
				foreach subObj in objSet do
					add := subObj.CM_ConsigneeConsignor.myAddress;
					if add &lt;&gt; null then
						_allSelectedObjects.addExclusive( add );
					endif;
					_allSelectedObjects.addExclusive( subObj );
				endforeach;
			elseif subObj.isKindOf( CM_RadioTelemetryDevice ) then
				foreach subObj in objSet do
					rt := subObj.CM_RadioTelemetryDevice.myRadioTelemetry;
					if rt &lt;&gt; null then
						_allSelectedObjects.addExclusive( rt );
					endif;
					_allSelectedObjects.addExclusive( subObj );
				endforeach;
			else
				objSet.copy( _allSelectedObjects );
			endif;
		endif;
	endforeach;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_allSelectedObjects" type="ObjectArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getNiceDisplay" id="82992f6b-85ec-474a-a0c4-8afeb279a34b">
        <source>getNiceDisplay( _class : Class; _obj : Object ) : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 September 2014	cnwndl1	Initial creation

*/

vars

begin

	if _class = CM_Carrier then
		if _obj = null then
			return "System Admin / Carrier";
		else
			return _obj.CM_Carrier.code &amp; " / " &amp; _obj.CM_Carrier.description;
		endif;
	elseif _class = CM_Commodity then
		if _obj = null then
			return "System Admin / Commodity";
		else
			return _obj.CM_Commodity.code &amp; " / " &amp; _obj.CM_Commodity.description;
		endif;
	elseif _class = CM_ConsigneeConsignor then
		if _obj = null then
			return "System Admin / Consignee, Consignor, Fright Forwarder";
		else
			return _obj.CM_ConsigneeConsignor.code &amp; " / " &amp; _obj.CM_ConsigneeConsignor.description;
		endif;
	elseif _class = CM_CustomsAgent then
		if _obj = null then
			return "System Admin / Customs Agent";
		else
			return _obj.CM_CustomsAgent.code &amp; " / " &amp; _obj.CM_CustomsAgent.name;
		endif;
	elseif _class = CM_DamageDefinitionCode then
		if _obj = null then
			return "System Admin / Damage Code";
		else
			return _obj.CM_DamageDefinitionCode.code &amp; " / " &amp; _obj.CM_DamageDefinitionCode.description;
		endif;
	elseif _class = CM_DamagePosition then
		if _obj = null then
			return "System Admin / Damage Position";
		else
			return _obj.CM_DamagePosition.code &amp; " / " &amp; _obj.CM_DamagePosition.description;
		endif;
	elseif _class = CM_EmailAddress2 then
		if _obj = null then
			return "System Admin / Email Address";
		else
			return _obj.CM_EmailAddress2.name &amp; " / " &amp; _obj.CM_EmailAddress2.emailAddress;
		endif;
	elseif _class = CM_HazardClass then
		if _obj = null then
			return "System Admin / Hazarad Classs";
		else
			return _obj.CM_HazardClass.code &amp; " / " &amp; _obj.CM_HazardClass.description;
		endif;
	elseif _class = CM_ISOType then
		if _obj = null then
			return "System Admin / ISO Type";
		else
			return _obj.CM_ISOType.code &amp; " / " &amp; _obj.CM_ISOType.description;
		endif;
	elseif _class = CM_ISOTypeGroup then
		if _obj = null then
			return "System Admin / ISO Type Group";
		else
			return _obj.CM_ISOTypeGroup.code &amp; " / " &amp; _obj.CM_ISOTypeGroup.description;
		endif;
	elseif _class = CM_Operator then
		if _obj = null then
			return "System Admin / Operator";
		else
			return _obj.CM_Operator.code &amp; " / " &amp; _obj.CM_Operator.description;
		endif;
	elseif _class = CM_OperatorGroup then
		if _obj = null then
			return "System Admin / Operator Group";
		else
			return _obj.CM_OperatorGroup.code &amp; " / " &amp; _obj.CM_OperatorGroup.description;
		endif;
	elseif ( _class = CM_Organisation or _class = CM_ExternalOrganisation or _class = CM_InternalOrganisation ) then
		if _obj = null then
			return "System Admin / Organisation";
		else
			return _obj.CM_Organisation.name;
		endif;
	elseif _class = CM_Port then
		if _obj = null then
			return "System Admin / Port";
		else
			return _obj.CM_Port.code &amp; " / " &amp; _obj.CM_Port.description;
		endif;
	elseif _class = CM_PrinterDef then
		if _obj = null then
			return "System Admin / Printer";
		else
			return _obj.CM_PrinterDef.description &amp; " / " &amp; _obj.CM_PrinterDef.logicalPrinterName;
		endif;
	elseif _class = CM_ResourceType then
		if _obj = null then
			return "System Admin / To Do Task Resource";
		else
			return _obj.CM_ResourceType.code &amp; " / " &amp; _obj.CM_ResourceType.description;
		endif;
	elseif _class = CM_ShippingAgent then
		if _obj = null then
			return "System Admin / Shipping Agent";
		else
			return _obj.CM_ShippingAgent.code &amp; " / " &amp; _obj.CM_ShippingAgent.description;
		endif;
	elseif _class = CM_ShippingLine then
		if _obj = null then
			return "System Admin / Shipping Line";
		else
			return _obj.CM_ShippingLine.code &amp; " / " &amp; _obj.CM_ShippingLine.description;
		endif;
	elseif _class = CM_StopsTable then
		if _obj = null then
			return "System Admin / Stop";
		else
			return _obj.CM_StopsTable.code &amp; " / " &amp; _obj.CM_StopsTable.heading;
		endif;
	elseif _class = CM_TemperatureConversion then
		if _obj = null then
			return "System Admin / Temperature Conversion";
		else
			return _obj.CM_TemperatureConversion.celsius.String &amp; " / " &amp; _obj.CM_TemperatureConversion.fahrenheit.String;
		endif;
	elseif _class = CM_TempRange then
		if _obj = null then
			return "System Admin / Temperature Range";
		else
			return _obj.CM_TempRange.value.String;
		endif;
	elseif _class = CM_ToDoTaskDesc then
		if _obj = null then
			return "System Admin / To Do Task Description";
		else
			return _obj.CM_ToDoTaskDesc.description;
		endif;
	elseif _class = CM_Trade then
		if _obj = null then
			return "System Admin / Trade";
		else
			return _obj.CM_Trade.code &amp; " / " &amp; _obj.CM_Trade.description;
		endif;
	elseif _class = CM_UNDangerousGoods then
		if _obj = null then
			return "System Admin / Dangerous Goods Code";
		else
			return _obj.CM_UNDangerousGoods.code &amp; " / " &amp; _obj.CM_UNDangerousGoods.nameDesc;
		endif;
	elseif _class = CM_VehicleColour then
		if _obj = null then
			return "System Admin / Vehicle Colour";
		else
			return _obj.CM_VehicleColour.colour;
		endif;
	elseif _class = CM_VehicleMake then
		if _obj = null then
			return "System Admin / Vehicle Make";
		else
			return _obj.CM_VehicleMake.make;
		endif;
	elseif _class = CM_VehicleModel then
		if _obj = null then
			return "System Admin / Vehicle Model";
		else
			return _obj.CM_VehicleModel.model;
		endif;
	elseif _class = CM_VehicleType then
		if _obj = null then
			return "System Admin / Vehicle Type";
		else
			return _obj.CM_VehicleType.type;
		endif;
	elseif _class = CM_WagonClass then
		if _obj = null then
			return "System Admin / Wagon Class";
		else
			return _obj.CM_WagonClass.code;
		endif;
	elseif _class = CM_Stevedore then
		if _obj = null then
			return "System Admin / Stevedore";
		else
			return _obj.CM_Stevedore.code;
		endif;
	elseif _class = CM_WeightRange then
		if _obj = null then
			return "System Admin / Weight Range";
		else
			return _obj.CM_WeightRange.value.String &amp; " " &amp; _obj.CM_WeightRange.myMeasurementType.shortName;
		endif;
	elseif _class = CM_Machine then
		if _obj = null then
			return "Terminal Admin / Machine";
		else
			return "[" &amp; _obj.CM_Machine.myTerminal.code &amp; "] " &amp; _obj.CM_Machine.id &amp; " / " &amp; _obj.CM_Machine.description;
		endif;
	elseif _class = CM_RadioTelemetryDevice then
		if _obj = null then
			return "Terminal Admin / RT Device";
		else
			return "[" &amp; _obj.CM_RadioTelemetryDevice.getMyTerminal.code &amp; "] " &amp; _obj.CM_RadioTelemetryDevice.id;
		endif;
	elseif _class = CM_DriverDetails then
		if _obj = null then
			return "Terminal Admin / Driver Detail";
		else
			return "[" &amp; _obj.CM_DriverDetails.myTerminal.code &amp; "] " &amp; _obj.CM_DriverDetails.code &amp; " / " &amp; _obj.CM_DriverDetails.name;
		endif;
	elseif _class = CM_CargoType then
		if _obj = null then
			return "System / Cargo Type";
		else
			return _obj.CM_CargoType.abbreviation &amp; " / " &amp; _obj.CM_CargoType.description;
		endif;
	elseif _class = CM_TransactionType then
		if _obj = null then
			return "System Admin / Transaction Type";
		else
			return _obj.CM_TransactionType.trxType.String &amp; " / " &amp; _obj.CM_TransactionType.description;
		endif;
	endif;

epilog

end;</source>
        <Parameter name="_class" type="Class"/>
        <Parameter name="_obj" type="Object"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getPermissionNameFromInteger" id="0cd69a6f-bad6-425e-96cb-189134a7fa1d">
        <source>getPermissionNameFromInteger( _int : Integer ):String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 September 2014	cnwndl1	Initial creation

*/

vars

	perm : XLAT_Translation;

begin

	if _int = 0 then
		return null;
	endif;
	
	perm := app.zGetTranslatedText(XLAT_Permissions, _int);
	if perm &lt;&gt; null then
		return "'" &amp; perm.text &amp; "'";	
	endif;
	
	return "[" &amp; _int.String &amp; "] unknown";

epilog

end;</source>
        <Parameter name="_int" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getSelectedCMIF" id="674c7e79-264c-4dcd-b8c8-e8260cf07bf3">
        <source>getSelectedCMIF( _table : CM_DataTable output ):CMIF_ConfigOptionsDisplay;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 August 2014	cnwndl1	Initial creation

*/

vars

	rowIndex : Integer;
	cmif : CMIF_ConfigOptionsDisplay;

begin

	if self.fldMain.topSheet = self.shtMain then
		rowIndex := self.tblConfigOptions.row;
		
		if rowIndex &lt;= self.tblConfigOptions.fixedRows
		or rowIndex &gt; self.tblConfigOptions.rows
		or self.tblConfigOptions.accessRow(rowIndex).visible = false
		or self.tblConfigOptions.selected = false
		then
			return null;
		endif;
		
		_table := self.tblConfigOptions;
		cmif := self.tblConfigOptions.accessRow( self.tblConfigOptions.row ).itemObject.CMIF_ConfigOptionsDisplay;
		
	elseif self.fldMain.topSheet = self.shtCompare then
	
		rowIndex := self.tblCompare.row;
	
		if rowIndex &lt;= self.tblCompare.fixedRows
		or rowIndex &gt; self.tblCompare.rows
		or self.tblCompare.accessRow(rowIndex).visible = false
		or self.tblCompare.selected = false
		then
			return null;
		endif;
	
		_table := self.tblCompare;
		cmif := self.tblCompare.accessRow( self.tblCompare.row ).itemObject.CMIF_ConfigOptionsDisplay;
		
	endif;
	
	return cmif;

epilog

end;</source>
        <Parameter name="_table" type="CM_DataTable" usage="output"/>
        <ReturnType type="CMIF_ConfigOptionsDisplay"/>
    </JadeMethod>
    <JadeMethod name="getSelectedObjects" id="4644152c-2a0c-4983-8d97-793c499147b6">
        <source>getSelectedObjects( _class : Class; _objSet : ObjectSet output ) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 September 2014	cnwndl1	Initial creation

*/

vars

	obj : Object;
	objSet : ObjectSet;
	firstObject : Object;

begin

	foreach obj in self.selectedObjectSets do
		objSet := obj.ObjectSet;
		if objSet.isEmpty then
			continue;
		endif;
		firstObject := objSet.first;
		if firstObject.class = _class then
			_objSet := objSet;
			return;
		elseif _class = CM_Organisation then
			if firstObject.isKindOf(_class) then
				_objSet := objSet;
				return;
			endif;
		elseif _class = CM_RadioTelemetryDevice then
			if firstObject.isKindOf(_class) then
				_objSet := objSet;
				return;
			endif;
		endif;
	endforeach;
	
	_objSet := null;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_class" type="Class"/>
        <Parameter name="_objSet" type="ObjectSet" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getTableColumFilters" id="5fca057e-ab8f-48c2-808f-b453a9b17c56">
        <updating/>
        <source>getTableColumFilters(_table: Table; _allFilterColumns: CM_ColumnFilterDict io) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 August 2014	cnwndl1	Initial creation

*/

vars

begin

	if self.allColumnFilters = null then
		create self.allColumnFilters transient;  // this is a non exclusive collection.
	endif;
	
	if self.allColumnFilters.isEmpty then
		return;
	endif;
	
	self.allColumnFilters.cloneFiltersForTable( _table, _allFilterColumns );

epilog

end;</source>
        <Parameter name="_table" type="Table"/>
        <Parameter name="_allFilterColumns" type="CM_ColumnFilterDict" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getXMLSettingsForSave" id="bf634514-0c12-4537-9c03-c6d2162be706">
        <updating/>
        <source>getXMLSettingsForSave(): String updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 August 2014	cnwndl1	Initial creation

*/

vars

	xmlStr : String;

begin

	xmlStr := inheritMethod();
	
	xmlStr := xmlStr &amp; global.formatAsXML( self.tblConfigOptions.name, self.xmlStrTblConfig );
	 
	return xmlStr;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="initBaseCodeFeature" id="ac4ffb4c-e0af-4ca4-8253-6c9780e0dbe9">
        <updating/>
        <source>initBaseCodeFeature() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 September 2014	cnwndl1	Initial creation

*/

vars

	msg : String;

begin

	app.cnEcInitializeBaseSchema();
	
	// See pars 34893, 35619, 36350
	if app.myBaseRoot = null then
		msg := "Failed to set 'CnEcBaseRoot'.  Requires XMLUtility to be run by JMT Implementation staff. See Par 35619" &amp; CrLf;
		app.msgBox( msg, "Error", MsgBox_OK_Only );
		return;
	endif;
	
	app.cnEcSetXmlSchema("PortSchema");
	
	self.populateFormats();
	self.populateClassesTable();
	self.fldBaseCode.topSheet := self.shtExtract;
	
	self.shtBaseCode.visible := true;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="initFromUserWindow" id="ce3403a7-a756-455c-af94-4ead365bc7da">
        <updating/>
        <source>initFromUserWindow(_userWindow: CM_UserWindow) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 August 2014	cnwndl1	Initial creation

*/

vars

	theXML : String;

begin

	inheritMethod(_userWindow);
	
	theXML:= _userWindow.xmlInfo;
	self.xmlStrTblConfig := theXML.cnEcGetTagValueOfName(self.tblConfigOptions.XMLTag_Table &amp; self.tblConfigOptions.name);

epilog

end;</source>
        <Parameter name="_userWindow" type="CM_UserWindow"/>
    </JadeMethod>
    <JadeMethod name="initTable" id="4724a636-69d0-4eb4-8c52-1f48e68577c0">
        <updating/>
        <source>initTable() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 August 2014	cnwndl1	Initial creation

*/

vars

	entDef : EntTableDef;
	colCompareValue : Integer;

begin

	self.tblConfigOptions.clear();
	self.tblConfigOptions.fixedRows := 1;
	self.tblConfigOptions.rows := 1;
	
	entDef := app.myController.getEntTableDef(ETDef_Locator);
	self.tblConfigOptions.setMyEntTableDef(entDef);	
	self.tblConfigOptions.setTblDataEntRowsFromDef(entDef);
	
	if self.xmlStrTblConfig = null then
		self.tblConfigOptions.allTblDataSortColumns.clear();
		self.tblConfigOptions.allTblDataSortDescending.clear();
		self.tblConfigOptions.zAddSortColumn(ETRow_MaintFormName, false);
		self.tblConfigOptions.zAddSortColumn(ETRow_SheetName, false);
		self.tblConfigOptions.zAddSortColumn(ETRow_OptionName, false);
		self.tblConfigOptions.setSortColumnsForMaxNumCols();
	else
		self.tblConfigOptions.setColumnsFromXMLStr( self.xmlStrTblConfig );
	endif;
	
	if not self.allowShowConstant then
		self.tblConfigOptions.hideColumnByColPropertyName(ETRow_ConstantName);
	endif;
	if not self.allowConfigCompare then
		self.tblConfigOptions.hideColumnByColPropertyName(ETRow_CurrentValue);
	endif;
	
	self.tblConfigOptions.selectMode := Table.SelectMode_WholeRows;
	
	
	
	
	if self.allowConfigCompare then
		// System And Terminal Config comparision
		self.tblCompare.clear();
		self.tblCompare.fixedRows := 1;
		self.tblCompare.rows := 1;
		
		entDef := app.myController.getEntTableDef(ETDef_Compare);
		self.tblCompare.setMyEntTableDef(entDef);	
		self.tblCompare.setTblDataEntRowsFromDef(entDef);
		
		self.tblCompare.selectMode := Table.SelectMode_WholeRows;
		
		colCompareValue := self.tblCompare.getColumnByRowName(ETRow_CompareValue);
		if colCompareValue &gt; 0 then
			self.compareValueRowName := self.tblCompare.getCellText( 1, colCompareValue );
		endif;
		
	endif;
	
	if self.allowUserCompare then
		// System Users
		self.tblUsers.clear();
		self.tblUsers.fixedRows := 1;
		self.tblUsers.rows := 1;
		
		entDef := app.myController.getEntTableDef(ETDef_UserCompare);
		self.tblUsers.setMyEntTableDef(entDef);	
		self.tblUsers.setTblDataEntRowsFromDef(entDef);
		
		self.tblUsers.selectMode := Table.SelectMode_WholeRows;
		
		self.tblUsers.accessColumn(1).width := 150;
		self.tblUsers.accessColumn(2).width := 100;
		
		self.populateUserTable();
	endif;
	
	if self.allowRoleCompare then
		//System Roles
		self.tblRoles.clear();
		self.tblRoles.fixedRows := 1;
		self.tblRoles.rows := 1;
		
		entDef := app.myController.getEntTableDef(ETDef_RoleCompare);
		self.tblRoles.setMyEntTableDef(entDef);	
		self.tblRoles.setTblDataEntRowsFromDef(entDef);
		
		self.tblRoles.selectMode := Table.SelectMode_WholeRows;
		
		self.tblRoles.accessColumn(1).width := 150;
		self.tblRoles.accessColumn(2).width := 200;
		self.tblRoles.accessColumn(3).width := 100;
		
		self.populateRoleTable();	
	endif;

epilog

end;</source>
    </JadeMethod>
