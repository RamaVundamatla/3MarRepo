    <JadeMethod name="rtCleanupInitialise" id="75ec69c4-4426-45e1-b133-2e0b4583b882">
        <updating/>
        <source>rtCleanupInitialise() updating;
//Background process, runs off the server.
//In the JadeServer section, or the Server's Jade.ini, add
//
//ServerApplication1 = PortSchema,RadioTelemetryCleanup
//
//This will automatically start this application on the server as a standalone
//process whenever the server starts up, and kill it when the server goes away.
//
constants
	TimerVal = 60000;
vars

begin
	// this was part of initializeAgents but has nothing to do with agents conflicts with create of root
	self.myRoot := CM_Root.firstInstance; // a crude method of knowing if getSingleton has created the first CM_Root
	if self.myRoot = null then
		self.myRoot := global.myCM_Root;
	endif;

	self.initializeAgents;
	self.beginTimer(TimerVal, Timer_Continuous,0);
	beginTransaction;
	process.changeUserCode("Cleanup App every " &amp; TimerVal.String &amp;"ms.");
	process.userInfo := "Background Cleanup App.";
	commitTransaction;
end;</source>
    </JadeMethod>
    <JadeMethod name="runEventScheduleInvoice" id="c85c0c51-6ed4-4dde-86bb-3df3e7d5eefb">
        <source>runEventScheduleInvoice(_schedule : CM_AutoSchedule; _invoice : CM_Invoice; _requests : Collection input) : Boolean;
// CPL CCMS 2120 Nov 2011 MSC electronic invoicing, run 
vars
	eventDataDict	 : CM_EventDataByTypeDict;
	eventDataInvoice : CM_EventDataInvoice;
	
begin
	if _schedule = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Schedule' ,null, null);
		app.raiseCMException(Input_required_field_schedule ,null, null); // cnwdb2	PAR 35364
		return false;
	endif;
	
	if _invoice = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Invoice' ,null, null);
		app.raiseCMException(Input_required_field_invoice ,null, null); // cnwdb2	PAR 35364
		return false;
	endif;
	
	if not _schedule.selectionState = State_Event then
		app.raiseCMException1(InvalidScheduleType, 'Event', null, null);
		return false;
	endif;
	
	create eventDataDict transient;
	create eventDataInvoice transient;
	
	eventDataInvoice.setProxyEventDataInvoice(_invoice);
	eventDataDict.add(eventDataInvoice);
	_schedule.runTasks(eventDataDict, _requests);
	
	return true;
epilog
	if eventDataDict &lt;&gt; null then
		eventDataDict.purge();
		delete eventDataDict;
	endif;
end;</source>
        <Parameter name="_schedule" type="CM_AutoSchedule"/>
        <Parameter name="_invoice" type="CM_Invoice"/>
        <Parameter name="_requests" type="Collection" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="runEventScheduleVVR" id="1c1f172b-b930-4975-9e5e-40157918891e">
        <source>runEventScheduleVVR(_schedule: CM_AutoSchedule; _vvr: CM_VehicleVisitRecord): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
13 March 2018	jlgmp6	Initial creation	TFS37340
22 Aug 2018		jlgsl4	TFS 39990 - PEN -  Road exit OK if VVR task disabled
*/

vars
	eventDataDict: CM_EventDataByTypeDict;
	eventDataVVR : CM_EventDataVVR;
	iter: Iterator;
	task: CM_AutoTask;
	tmpClass: Class;
	bgpRequest: BGP_Request;
	theAlert : CM_SystemAlert; // TFS 39990
	alertMsg : String; // TFS 39990
	errorsStr : String;

begin
	if _schedule = null then
		app.writeLog(method.qualifiedName() &amp; " _schedule = null", LogINFO);	//27 Feb 2020	TFS 48696
		app.raiseCMException(Input_required_field_schedule, null, null);
		return false;
	endif;
	
	if not _schedule.selectionState = State_Event then
		app.writeLog(method.qualifiedName() &amp; " not _schedule.selectionState = State_Event", LogINFO);	//27 Feb 2020	TFS 48696
		app.raiseCMException1(InvalidScheduleType, 'Event', null, null);
		return false;
	endif;
	
	if not _schedule.isActive =  CM_AutoSchedule.Schedule_Is_Active then
		app.writeLog(method.qualifiedName() &amp; " not _schedule.isActive =  CM_AutoSchedule.Schedule_Is_Active", LogINFO);	//27 Feb 2020	TFS 48696
		// SHOULD ALREADY BE IN TRANSACTION STATE FROM TRX. // TFS 39990
		if not process.isInTransactionState then // TFS 39990
				beginTransaction; // TFS 39990
		endif; // TFS 39990
		alertMsg := '(runEventScheduleVVR) - Gate Out has occurred, but there is no active VVR Package task'; // TFS 39990
		app.writeLog(alertMsg, LogERROR); // TFS 39990
		create theAlert transient; // TFS 39990
		theAlert.details := alertMsg; // TFS 39990
		theAlert.setSeverity(SEVERE_WARNING); // TFS 39990
		theAlert.add; // TFS 39990
		//app.raiseCMException1(InvalidScheduleType, 'Active', null, null); // TFS 39990
		return false;
	endif;
	
	create eventDataDict transient;
	create eventDataVVR transient;
	
	eventDataVVR.setProxyEventDataVVR(_vvr);
	eventDataDict.add(eventDataVVR);
//	_schedule.runTasks(eventDataDict, null);
	
	iter := _schedule.allAutoTasks.createIterator();
	
	while iter.next(task) do
		//if not _schedule.tryLock(task, Exclusive_Lock, Session_Duration, LockTimeout_Immediate) then
		if not _schedule.tryLock(task, Exclusive_Lock, Session_Duration, 2000) then	// ### TFS 56210 06Apr2023 NAVPW1 - Added a 2 second timeout to see if this resolves PRP's locking issue as the task trx should not take longer than 2 seconds
			app.writeLog(method.qualifiedName() &amp; " _schedule.tryLock for task failed", LogINFO);	//27 Feb 2020	TFS 48696
			// Will move on because someone is editing task.
			continue;
		endif;
		tmpClass := _schedule.getClass(task.requestClassName);
		if tmpClass = null then
			app.writeLog(method.qualifiedName() &amp; " tmpClass = null", LogINFO);	//27 Feb 2020	TFS 48696
			// Class has not been correctly setup.
			app.raiseCMException(Invalid_class_objects, null, null);
			continue;
		endif;
		app.writeLog(method.qualifiedName() &amp; " call app.myUtilityCA.utlCreateBGPRequest", LogINFO);	//27 Feb 2020	TFS 48696
		app.myUtilityCA.utlCreateBGPRequest(tmpClass, bgpRequest, task, eventDataDict);
		
		//27 Feb 2020	TFS 48696
		errorsStr := app.myPassport.getAllErrorsAndWarningsAsStr();
		if errorsStr &lt;&gt; null then
			app.writeLog(method.qualifiedName() &amp; " utlCreateBGPRequest errors " &amp; errorsStr, LogINFO);	//27 Feb 2020	TFS 48696
		endif;
		
		self.unlock(task);
	endwhile;

	return true;
epilog
	delete iter;
	if eventDataDict &lt;&gt; null then
		eventDataDict.purge();
		delete eventDataDict;
	endif;
end;</source>
        <Parameter name="_schedule" type="CM_AutoSchedule"/>
        <Parameter name="_vvr" type="CM_VehicleVisitRecord"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="runEventScheduleVoyage" id="fab2eca4-120c-411d-9782-cd10de8cfdd2">
        <source>runEventScheduleVoyage(_schedule : CM_AutoSchedule; _voyage : CM_Voyage; _portCode : String) : Boolean;
// -------------------------------------------
// Created 28 June 2004 by cnwdvb1
// -------------------------------------------
vars
	eventDataDict	: CM_EventDataByTypeDict;
	eventDataVoyage : CM_EventDataVoyage;
	
begin
	if _schedule = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Schedule' ,null, null);
		app.raiseCMException(Input_required_field_schedule ,null, null);  // cnwdb2	PAR 35364
		return false;
	endif;
	
	if _voyage = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Voyage' ,null, null);
		app.raiseCMException(Input_required_field_voyage ,null, null); // cnwdb2	PAR 35364
		return false;
	endif;
	
	if not _schedule.selectionState = State_Event then
		app.raiseCMException1(InvalidScheduleType, 'Event', null, null);
		return false;
	endif;
	
	if not _schedule.isActive =  CM_AutoSchedule.Schedule_Is_Active then
		app.raiseCMException1(InvalidScheduleType, 'Active', null, null);
		return false;
	endif;
	
	create eventDataDict transient;
	create eventDataVoyage transient;
	
	if _portCode = null then
		if _schedule.scheduleNeedsExtraData() then
//			app.raiseCMException1(REQUIRED_FIELD, 'Next Port Of Call' ,null, null);
			app.raiseCMException(Input_required_field_nextPrtOf ,null, null); // cnwdb2	PAR 35364
			return false;
		endif;
	endif;
	
	eventDataVoyage.setProxyEventDataVoyage(_voyage, _portCode);
	eventDataDict.add(eventDataVoyage);
	_schedule.runTasks(eventDataDict, null);
	
	return true;
epilog
	if eventDataDict &lt;&gt; null then
		eventDataDict.purge();
		delete eventDataDict;
	endif;
end;</source>
        <Parameter name="_schedule" type="CM_AutoSchedule"/>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_portCode" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="runRoadReceiptForeground" id="430760ce-8855-4306-a29f-a90a5e2678a6">
        <source>runRoadReceiptForeground(_roadJob : CM_RoadJob);
// -------------------------------------------
// Created 08 December 2004 by cnwdvb1
// -------------------------------------------
//			 
// Changed On	Changed By	Reason
// ----------	----------	--------------------------------------------------
// 17 Mar 2010	consw1		PAR #22886 - Leaking report transients

vars

	theQryReport	: CM_QryReport;
	filter			: CMQF_AnyDataObject;
	jrwManager		: JadeReportWriterManager;
	jrwReport		: JadeReportWriterReport;
	jrwFileName		: String;
	jadeReport		: JadeReport;
begin


	theQryReport := app.myRoot.myReportMenuRoot.getReportByConstantValue(CM_RepAutoGateReceipt);

	if  theQryReport = null then
		app.raiseCMException1(BackgroundErrorGeneral, 'INFO &gt;&gt; Error processing specific report. Could not locate report definition',
		 null, null);
		return;
	endif;
	
	if  _roadJob = null then
		app.raiseCMException1(BackgroundErrorGeneral, 'INFO &gt;&gt; Error processing specific report. Could not locate Road Job',
		 null, null);
		return;
	endif;
	filter := theQryReport.createFilter().CMQF_AnyDataObject;
	filter.initialize();
	filter.dataClass	:= CM_RoadJob.name;
	filter.setMyDataObject( _roadJob );
	filter.allTerminals.add(app.getMyTerminalDO_NOT_USE);

	theQryReport.doFilter(filter, app.myPassport);
	
	jrwManager := app.createReportWriterManager();
	
	jrwFileName := theQryReport.jrwReportName.first;
	jrwReport := jrwManager.getReport(jrwFileName);
	
	app.printer.printPreview := false;
	create jadeReport transient;
	jadeReport.description := jrwReport.name;
	app.printer.setReport(jadeReport);
	jrwReport.run();
	app.printPreview(jadeReport, true);

	// Par 10048
//	abortTransaction;		// to clear any locks held by the report writer
	
epilog
	delete jrwManager;
	delete jrwReport;
	// Jade report erazed by print preview.
	
end;</source>
        <Parameter name="_roadJob" type="CM_RoadJob"/>
    </JadeMethod>
    <JadeMethod name="rvTideLibraryExceptionHandler" id="e2080f29-9369-4f9c-8efd-cb61d21bb924">
        <source>rvTideLibraryExceptionHandler(exObj 			: Exception ) : Integer;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 February 2009	cnwer1	Initial creation Par 18343

