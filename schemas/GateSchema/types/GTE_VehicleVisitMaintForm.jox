    <JadeMethod name="unload" id="7479e5a4-b38f-4427-ac42-d1aeb4c4f3db">
        <controlMethod name="Form::unload"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>unload() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 October 2020	jlgndl1	Initial creation	TFS 49189

*/

vars

	entTableRowProxy : EntTableRow;

begin

	self.endNotes();
	
	inheritMethod();
	
	foreach entTableRowProxy in self.allTblDataTransientRows do
		if self.tblCargo.allTblDataEntRows.includes(entTableRowProxy) then
			self.tblCargo.allTblDataEntRows.remove(entTableRowProxy);
		endif;
	endforeach;
	self.allTblDataTransientRows.purge;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="updateStevedore" id="91c77623-3711-4a0b-b9b7-9c89b1242f11">
        <source>updateStevedore(_stevedore : CM_Stevedore);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 Nov 2020 cnwma1 ChangeRequest 50112: ASPA - GCI Stevedores
*/

vars
	ret : Integer;
begin
	while true do
		app.myTrxUA.trxUpdateVvrStevedore( self.myVehicleVisitRecord, _stevedore, app.myPassport );
		
		if app.myPassport.trxCompletedOK then
			self.clearErrorWarnings();
			self.optView.value := true;
			break;	
		else
			ret := app.showErrorWarningDialog(app.getErrorString(Stevedore), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   ret = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			break;
		endif;
		
		break;
	
	endwhile;
epilog

end;</source>
        <Parameter name="_stevedore" type="CM_Stevedore"/>
    </JadeMethod>
    <JadeMethod name="zAddTransientEntTblRow" id="a06fb30b-20d4-43a4-81ae-e37fcb83b22a">
        <updating/>
        <source>zAddTransientEntTblRow(pHeading, pProperty : String; pInputType : Integer) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 November 2020	jlgndl1	Initial creation	TFS 49189

*/

vars
	newRow : EntTableRowProxy;
begin
	create newRow transient;
	newRow.setBasicDetails(pProperty, pHeading, pInputType, true);
	self.allTblDataTransientRows.add(newRow);	
	
end;</source>
        <Parameter name="pHeading" type="String"/>
        <Parameter name="pProperty" type="String"/>
        <Parameter name="pInputType" type="Integer"/>
    </JadeMethod>
</GUIClass>
