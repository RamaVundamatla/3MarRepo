    <JadeMethod name="processFile" id="d673492d-4dc0-4349-a642-73ed629ec74d">
        <updating/>
        <source>processFile(_ediFile: CM_EDIFile input) protected, updating;
// 07 Mar 2013	cnwcs5	CCMS POL 2097 / par 31259 - include foundMatch in method signatures
//12 Jan 2015	cnwrs1	Par 35504 - Refactor EDI file load for .NET
//08 Oct 2015	cnwrs1	Par 36863 - make EDI consistant times when refreshing progress bar
// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
// 08 May 2018	jlgrs1	TFS 36425 SingleLine Booking partial processing not working
// 18 Jan 2019	jlgrs1	TFS 41659 42276 STWR Make EDI MultiThreaded Stage 8
// 11 Apr 2019	jlgrs1	TFS 41913 STWR - Reconfiguration of the EDI Operation form to better handle EDI collection locks while loading 
//
constants
	ProgressBarRefresh	: Integer = 2000;	
	Ignore					: Integer = 0;
	NextVoyage				: Integer = 1;
	Pools					: Integer = 2;
	Projections				: Integer = 3;
vars
	container				: CM_EDIStowAdviceTI;
	ediDataStowAdvice		: CM_EDIDataStowAdvice;
	lineStr					: String;
	message					: String;
	int						: Integer;
	generatedContainerNo	: Integer;
	poolNumber				: Integer;
	poolId					: Integer;
	tmpPoolId				: Integer;
	containerId				: String;
	mode					: Integer;
	imCode					: String;
	isoType					: String;
	dischargePort			: String;
	stowage					: String;
	stowageId				: String;
	temperature				: Real;
	mtCmdty					: String;
	defCmdty				: String;
	refCmdty				: String;
	hazCmdty				: String;
	fullOrMT				: String;
	cooledType				: Integer;
	weight					: Integer;
	portDestCode			: String;
	operator				: CM_Operator;
	msgCount				: Integer;
	numMsgs					: Integer;
	passport				: CM_Passport;
	terminal				: CM_Terminal;
	msgHelper				: CMIF_EDIVSLStowHelper;
//	binaryLine				: Binary;
	foundMatch				: Boolean;
	theLines : HugeStringArray;
	progressInt	: TimeStampInterval;
	progressTS : TimeStamp;
begin
	progressTS := app.actualTimeServer();// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	passport := app.myPassport;	
	terminal := passport.myTerminal;
	app.getTerminalDefCmdty(mtCmdty, defCmdty, refCmdty, hazCmdty);
	portDestCode := terminal.getConfig(PortDestCode).String;	
	// FD 29/10/02: for baplie and master plan, we should show the gross TIs and the total of the TIs
	// For the user's port . This is purely for a check or review purpose.
	ediDataStowAdvice := _ediFile.ediData.CM_EDIDataStowAdvice;
	ediDataStowAdvice.loadRecordsForPort := 0;
	//operator := app.myRoot.allOperators[opCode];
	mode := NextVoyage;	//as first line contains voyage details

	create msgHelper transient;
	msgHelper.setEDIFile(_ediFile);

	create theLines transient;
	self.rawDataToHSA(_ediFile, theLines);
	numMsgs	:= theLines.size;
	foreach lineStr in theLines do
		msgCount	:=	msgCount + 1;
		
		progressInt := app.actualTimeServer() - progressTS;// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		if passport.myCMIFMonitor &lt;&gt; null  and (progressInt.getMilliseconds &gt;= ProgressBarRefresh) then
			passport.myCMIFMonitor.updateProgressWithCaption("Processing File Data", numMsgs, msgCount, "Loading EDI file Step 3 of 3.");
			progressTS := app.actualTimeServer();// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		endif;
		
		msgHelper.setNextMessage(lineStr);	//set the current message
		
		//get current
		message := msgHelper.currentMessage;	
		int := int + 1;

		if message[1:8] = "*VSLSTOW" then
			// the messages collection never has this line in it... hmmm
			mode := NextVoyage;
			continue;
		endif;
		if message[1:7] = "* POOLS" then
			mode := Pools;
			continue;
		endif;
		if message[1:13] = "* PROJECTIONS" then
			mode := Projections;
			generatedContainerNo := 0;
			continue;
		endif;
		if message[1:6] = "* TANK" then
			mode := Ignore;
			continue;
		endif;
		
		if mode = Ignore then
			continue;
		elseif mode = NextVoyage then
			if ediDataStowAdvice.voyageCode = null and
			   int = 1 then
				msgHelper.setFirstField;
				msgHelper.setNextField;
				
				ediDataStowAdvice.vesselName := msgHelper.currentField;
				msgHelper.setNextField;
				
				//poolId := self.getCurrentField.Integer;
				ediDataStowAdvice.voyageCode := msgHelper.currentField;
			endif;
			mode := Ignore;
			continue;		
		elseif mode = Pools then
			msgHelper.setFirstField;
			poolId := msgHelper.currentField.Integer;
			msgHelper.setNextField;
			poolNumber := msgHelper.currentField.Integer;
			msgHelper.setNextField;				//iso
			isoType := msgHelper.currentField[1:4];
			msgHelper.setNextField;
			msgHelper.setNextField;				//weight
			weight := msgHelper.currentField.Integer;
			msgHelper.setNextField;				//owner
			msgHelper.setNextField;				//live reefer
			if msgHelper.currentField[1:1] = "N" then
				//anything else represents a live reefer
				temperature := NULL_TEMPERATURE;
			else
				temperature := 0.0;
			endif;
			msgHelper.setNextField;				//loadport
			msgHelper.setNextField;				//discharge
			dischargePort := msgHelper.currentField[1:5];
			msgHelper.setNextField;				//dest
			msgHelper.setNextField;				//full status
			fullOrMT := msgHelper.currentField[1:1];

			msgHelper.setNextField;				//hazard
			imCode := msgHelper.currentField[1:1];
			msgHelper.setNextField;				//reefer temp - not interested because these are colour codes only - only need to know that temp is required

			msgHelper.setNextField;				//over height

			msgHelper.setNextField;				//over width right	

			msgHelper.setNextField;				//over width left

			msgHelper.setNextField;				//booking

			msgHelper.setNextField;				//stow block

			msgHelper.setNextField;				//category

			msgHelper.setNextField;				//DG1

			msgHelper.setNextField;				//DG2

			msgHelper.setNextField;				//DG3

			msgHelper.setNextField;				//DG4

			msgHelper.setNextField;				//DG5

			msgHelper.setNextField;				//DG6

			msgHelper.setNextField;				//DG7

			msgHelper.setNextField;				//DG8

			msgHelper.setNextField;				//DG9

			msgHelper.setNextField;				//upper temp

			msgHelper.setNextField;				//lower temp

			msgHelper.setNextField;				//cooled type  air/water

			if temperature = NULL_TEMPERATURE 
			or msgHelper.currentField.trimBlanks = "" then
				cooledType := ContainerCooledNull;
			elseif msgHelper.currentField[1:3] = "ACR" then	//air cooled reefer
				cooledType := ContainerAirCooled;
			elseif msgHelper.currentField[1:3] = "WCR" then	//water cooled reefer ???
				cooledType := ContainerWaterCooled;
			endif;
			
			generatedContainerNo := 0;
			foreach int in 1 to poolNumber do
				generatedContainerNo := generatedContainerNo + 1;
				
				create container as CM_EDIStowAdviceTI persistent;
				container.setForCreateNew(ediDataStowAdvice);
				container.temperature := NULL_TEMPERATURE;
				
				container.setIdDefault(poolId.String.padLeadingZeros(4)&amp;generatedContainerNo.String.padLeadingZeros(7));
				msgHelper.setNextField;
				//now use xlation CCMS 1157
				if operator &lt;&gt; null then
					container.isoType := operator.getXlationSystemCode(isoType, XLATION_TYPE_ISOTYPE_BYOP, foundMatch);
				else
					container.isoType := isoType.trimBlanks;
				endif;
				container.dischargePort := dischargePort;
				//container.dischargePort := dischargePort; now done as above
				
				// FD 29/10/02: for baplie and master plan, we should show the gross TIs and the total of the TIs
				// For the user's port . This is purely for a check or review purpose.
				if container.dischargePort =  portDestCode then
					ediDataStowAdvice.loadRecordsForPort := ediDataStowAdvice.loadRecordsForPort + 1;
				endif;

				container.fullOrMT := fullOrMT;			
				if fullOrMT = "F" then
					if temperature &lt;&gt; NULL_TEMPERATURE then
						container.temperature := temperature;
					endif;
				else
					container.commodity := mtCmdty;
				endif;				
				container.weight := weight;
				container.setMode(CM_EDIStowAdviceTI.MODE_LOA);
				container.loadPort := portDestCode;
				container.cooledType := cooledType;
			endforeach;
			continue;
		elseif mode = Projections then
			msgHelper.setFirstField;
			poolId := msgHelper.currentField.Integer;
			if tmpPoolId &lt;&gt; poolId then
				tmpPoolId := poolId;
				generatedContainerNo := 0;
			endif;
			generatedContainerNo := generatedContainerNo + 1;
			msgHelper.setNextField;
			stowage := msgHelper.currentField;
			stowageId := "0"&amp;stowage[1:2]&amp;stowage[4:4];
			containerId := poolId.String.padLeadingZeros(4)&amp;generatedContainerNo.String.padLeadingZeros(7);
			container := ediDataStowAdvice.allEDITrackedItems[containerId].CM_EDIStowAdviceTI;
			container.stowageId := stowageId;
			continue;
		endif;
	endforeach;
epilog
	delete theLines;
	delete msgHelper;
end;</source>
        <access>protected</access>
        <Parameter name="_ediFile" type="CM_EDIFile" usage="input"/>
    </JadeMethod>
    <JadeMethod name="rawDataToHSA" id="547d4426-2cb9-4e29-814d-64f3b221024e">
        <source>rawDataToHSA(_ediFile : CM_EDIFile; _theLines: HugeStringArray input);
//
//15 Jan 2015	cnwrs1	Par 35504 - Refactor EDI file load for .NET
// 28 Jul 2015	cnwrs1	Par 36683 since new data is in rawData suport old data (8.3.2) from compressedFilelines
//
vars
	ediFile : CM_EDIFile;
	fileLine : String;
	theLines: HugeStringArray;
begin
	_theLines.clear;
	create theLines transient;
	fileLine := self.rawDataToString(_ediFile);
	if fileLine = null then
		self.compressedDataToHSD(_ediFile, _theLines);
	else
		fileLine.getHugeTokensForDelimiter(Cr, theLines);
		foreach fileLine in theLines do
			if fileLine.isBlank then
				continue;
			endif;
			if fileLine[1:8] = "*VSLSTOW" then
				// start next line
				continue;
			elseif fileLine.toUpper.pos("END OF FILE", 1) &lt;&gt; null then
				// we have finished
				break;
			else
				_theLines.addTruncated(fileLine);
			endif;
		endforeach;
		ediFile := _ediFile;
		if process.isInTransactionState then
			ediFile.setNumContainers(_theLines.size);
		endif;
	endif;
epilog
	delete theLines;
end;
</source>
        <Parameter name="_ediFile" type="CM_EDIFile"/>
        <Parameter name="_theLines" type="HugeStringArray" usage="input"/>
    </JadeMethod>
</Class>
