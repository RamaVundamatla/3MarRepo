    <JadeMethod name="trxCreateBOLOutPacked" id="39f3cea5-d582-4d41-8fc3-fe19aa38d56a">
        <updating/>
        <source>trxCreateBOLOutPacked(_ifaceBOLOut: CMIF_BOLOut input; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     28 June 2002 by cnwsb1
//
// Creates a BOL Out, and packs Children into Parent (eg. Timber
// Packs into Container).
//
// ---------------------------------------------------------------------------
vars
	newBOLEdition				: Integer;
	dummyTI,
	pxyParentTI					: CM_TrackedItem;
	theMoveController 			: CMIF_MoveController;
	lc							: CM_LocationsController;
	charged						: Boolean;
	unPackTIs,
	thePackTIs					: CM_TIArray;
	
begin

	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);
	
	// Start the transaction
	beginTransaction;

	// Perform the operation
	app.myUtilityCA.utlCreateBOLOut(_ifaceBOLOut, _passport);
	
	if not _passport.noErrors then
		return;
	endif;
	
/*
need to call the following from here instead of the subsequent methods
so we do exactly what is done from YRD_PackUnpack screen
		app.myUtilityUA.utlUpdatePackUnpack(_theMoveController,_noCharge, _thePackTIs, 
								_theUnpackTIs, _theProxyParentTI, 
								TI_UPDMODE_NORMAL, _passport);

	
///// changed to call same transaction used by yard pack/unpack for consistancey /////

	//setup the move controller
	//As not unpacking the move controllers toLocation will be null (not set). This is correct, as the move done
	//to the child items being packed sets their location to null, as thence it is retrieved from the parent.

*/	
	create theMoveController transient;
	create unPackTIs transient;
	theMoveController.setMyOriginatingLocation(_ifaceBOLOut.myMasterTI.getPrimaryLocation(REAL_MODE));
	theMoveController.setMoveMode(REAL_MODE);
	theMoveController.isSystemMove := true;
	theMoveController.isForcedMove := true;
	charged := _ifaceBOLOut.noCharge;

	if _ifaceBOLOut.doUpdateParentContainer and _ifaceBOLOut.myMasterTI &lt;&gt; null then
		pxyParentTI := app.createUpdateProxy(_ifaceBOLOut.myMasterTI).CM_TrackedItem;
		pxyParentTI.setPxyFromCMIF_BOLOut(_ifaceBOLOut, _passport);

		create thePackTIs transient;
		
		_ifaceBOLOut.allTrackedItems.copy(thePackTIs);
		
		app.myUtilityUA.utlUpdatePackUnpack(theMoveController, charged, thePackTIs, 
								unPackTIs, false, pxyParentTI,  
								TI_UPDMODE_NORMAL, _passport);
	endif;

/*
old code here

	if _ifaceBOLOut.doUpdateParentContainer and _ifaceBOLOut.myMasterTI &lt;&gt; null then
		pxyParentTI := app.createUpdateProxy(_ifaceBOLOut.myMasterTI).CM_TrackedItem;
		pxyParentTI.setPxyFromCMIF_BOLOut(_ifaceBOLOut, _passport);
		app.myUtilityUA.utlUpdateTrackedItem(pxyParentTI, TI_UPDMODE_NORMAL, null, _passport);
		
		_ifaceBOLOut.editionMasterTI := _ifaceBOLOut.myMasterTI.edition;
		if not _passport.noErrors then
			return;
		endif;
	endif;
	
	app.myUtilityUA.utlUpdateContainerPack(_ifaceBOLOut, _passport);
*/
	
epilog
	delete thePackTIs;
	delete theMoveController;
	delete pxyParentTI;
	delete unPackTIs;
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_ifaceBOLOut" type="CMIF_BOLOut" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
