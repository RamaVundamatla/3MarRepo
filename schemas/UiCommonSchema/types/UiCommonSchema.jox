    <JadeMethod name="showTestForm" id="f92ae9e0-8711-4406-b494-849d9b3d9436">
        <source>showTestForm(_schemaName, _formName : String);
/* ---------------------------------------------------------------------------
Created:     03 July 2008 by cnwrs2

Purpose:    Can be called to show a form that is being developed, that don't want to add
			to navigator at this time
        
Change Date	Who		Reason

------------------------------------------------------------------------------*/
vars
	subSystem			: CMUI_SubSystem;
	assistantClass,
	formClass			: Class;

begin

	subSystem := app.myController.allSubSystems[_schemaName];	
	if subSystem = null then
