    <JadeMethod name="setEntTableDef" id="acfaef1a-d188-4f42-9e28-faf7ff47ee77">
        <source>setEntTableDef();
/*
Purpose:			

Date		Who		Reason
11 January 2024	navab1	CR 58085 TASK 61346
*/

vars
	entTableDef		: EntTableDef;
begin
	
	entTableDef := app.myController.getEntTableDef(ETDef_InvListDataTable);
	if entTableDef &lt;&gt; null then
		tblInvoices.selectionType := CM_EntryTable.SelectionType_Row;
		tblInvoices.rows := tblInvoices.fixedRows;
		tblInvoices.setTblDataEntRowsFromDef(entTableDef);
		tblInvoices.userInputEnabled := false;
	endif;
epilog

end;</source>
