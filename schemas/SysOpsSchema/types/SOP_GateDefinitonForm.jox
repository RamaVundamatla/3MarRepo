    <JadeMethod name="tblGateLanes_cellInputReady" id="bb1c5c0e-4131-4da5-9692-fdfc9d132294">
        <controlMethod name="Table::cellInputReady"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblGateLanes_cellInputReady(table: Table input; inputControl: Control input; cleft: Real io; ctop: Real io; cwidth: Real io; cheight: Real io) updating;
// ---------------------------------------------------------------------------
// Created:     25 June 2009 by concms1
// Purpose:     CCMS 1061 - Gate Config Changes  
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
////21/03/17 cnwns1 TFS3153:PKT - Bulk Process - WeighBridge Integration
// ---------------------------------------------------------------------------
vars
	lane	:CM_LaneController;
	printer	:CM_PrinterDef;
	reader	:CM_RFIDTagReader;
	kiosk	:CM_Kiosk;
	boom	:CM_Boom;
	weighBridge : CM_WeighBridgeObj;
	scanReader	: CM_ScanReaderObj;
	
begin
	lane :=  table.accessRow (table.row).itemObject.CM_LaneController;
	
	inputControl.width := table.accessColumn (table.column).width;
	
	if inputControl = cmbPrinter then
		printer := lane.getPrinter;
		if printer &lt;&gt; null then
			cmbPrinter.listIndex := cmbPrinter.findObject (printer);
		else
			cmbPrinter.listIndex := -1;
		endif;
	
	elseif inputControl = cmbWeighBridge then
		weighBridge := lane.getWeighBridge;
		if weighBridge &lt;&gt; null then
			if weighBridge.isSerialPort then									//TFS 3153
				table.accessedCell.cellControl	:= lblPlaceHolder;				//TFS 3153
				lblPlaceHolder.caption 			:= table.accessedCell.text;		//TFS 3153
				lblPlaceHolder.backColor 		:= table.backColor ;			//TFS 3153
				lblPlaceHolder.width 			:= cwidth;						//TFS 3153
				lblPlaceHolder.alignment 		:= Label.Alignment_Center_Middle;//TFS 3153
			else
				cmbWeighBridge.listIndex := cmbWeighBridge.findObject (weighBridge);
			endif;
		else
			cmbWeighBridge.listIndex := -1;
		endif;
		
	// ### TFS 52773 04MAY2022 NAVPW1
	elseif inputControl = cmbScanReader then
		scanReader := lane.getScanReader();
		if scanReader &lt;&gt; null then
			cmbScanReader.listIndex := cmbScanReader.findObject(scanReader);
		else
			cmbScanReader.listIndex := -1;
		endif;
	// ### TFS 52773 04MAY2022 NAVPW1
	
	elseif inputControl = cmbRFIDReader then
		reader := lane.getRFIDTagReader(true);
		if reader &lt;&gt; null then
			cmbRFIDReader.listIndex := cmbRFIDReader.findObject (reader);
		else
			cmbRFIDReader.listIndex := -1;
		endif;
		
	elseif inputControl = cmbRFIDReaderA then
		reader := lane.getRFIDTagReader(false);
		if reader &lt;&gt; null then
			cmbRFIDReaderA.listIndex := cmbRFIDReaderA.findObject (reader);
		else
			cmbRFIDReaderA.listIndex := -1;
		endif;
		
	elseif inputControl = cmbKiosk then
		kiosk := lane.getKiosk;
		if kiosk &lt;&gt; null then
			cmbKiosk.listIndex := cmbKiosk.findObject(kiosk);
		else
			cmbKiosk.listIndex := -1;
		endif;
		
	elseif inputControl = cmbBoom then 
		boom := lane.getBoom(true);
		if boom &lt;&gt; null then
			cmbBoom.listIndex := cmbBoom.findObject(boom);
		else
			cmbBoom.listIndex := -1;
		endif;
	
	elseif inputControl = cmbBoomOut then
		boom := lane.getBoom(false);
		if boom &lt;&gt; null then
			cmbBoomOut.listIndex := cmbBoomOut.findObject(boom);
		else
			cmbBoomOut.listIndex := -1;
		endif;
	endif;
epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="inputControl" type="Control" usage="input"/>
        <Parameter name="cleft" type="Real" usage="io"/>
        <Parameter name="ctop" type="Real" usage="io"/>
        <Parameter name="cwidth" type="Real" usage="io"/>
        <Parameter name="cheight" type="Real" usage="io"/>
    </JadeMethod>
