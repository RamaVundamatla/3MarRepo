        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnRun_click(btn: Button input) updating;
// ---------------------------------------------------------------------------
// Created:     24 May 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

