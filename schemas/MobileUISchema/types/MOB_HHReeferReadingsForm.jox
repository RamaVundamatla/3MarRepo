    <JadeMethod name="buildContextMenu" id="bb5813af-a517-4366-b1ca-450e9ac6389a">
        <updating/>
        <source>buildContextMenu(conwin: Window input; mouse: Boolean; x: Integer; y: Integer): Boolean updating, protected;
/*
Date		Who		Reason
27 January 2009	cnwcp2	Initial creation
*/

vars

begin
	if not isMenuBuilt then
		self.setupMenu();
		isMenuBuilt := true;
	endif;
	// If more menus are added then this will need to be changed to using an attribute on the form
	// like in the 2 enquiry forms (so it is true if any of the menus are visible)
	if mAlert.visible then
		return self.showContextMenu(self.mPopup, null, conwin, mouse, x, y);
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
