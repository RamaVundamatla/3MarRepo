    <JadeMethod name="create" id="0bba91e9-063e-4b03-a6e1-999bc079d11b">
        <updating/>
        <source>create() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 Jan 2019	jlgsl4	TFS 39618 - LNX - Invoice Approved Status

*/

vars

begin
	self.name				:=	SOP_TableMaintForm.Table_InvoiceStatus;
	self.permissionView		:=	PmAdmVoyageStatusView; // need Invoice permissions
	self.permissionMaint	:=	PmAdmVoyageStatusMaint; // need Invoice permissions
	self.myDataClass		:=	CM_InvoiceStatus;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doSave" id="e4df4a45-d05b-4914-a88d-bd0f3f5c6401">
        <updating/>
        <source>doSave(): Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 Jan 2019	jlgsl4	TFS 39618 - LNX - Invoice Approved Status
29 Nov 2022 navvt20  CR 55298 TASK 55548: UI - Add Colour to Invoice Status maintenance.
*/

vars
	pxyStatus : CM_InvoiceStatus;
	form : SOP_TableMaintForm;
	description : String;
	emailTemplate : CM_EmailTemplate;

begin
	form := self.myForm;
	description := form.tblInput1.getValueByName(ETRow_Description).String;

	// Add is not valid for these items, so we only need to worry about Edit
	if form.myProxyObject = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Proxy object is null for update');
		return false;
	endif;
	
	pxyStatus := form.myProxyObject.CM_InvoiceStatus;
	//pxyStatus.setProxy(pxyStatus.id, pxyStatus.priority, description, pxyStatus.myInvoiceProcess, emailTemplate); // 29 Nov 2022 navvt20 TFS 55548
	pxyStatus.setProxy(pxyStatus.id, pxyStatus.priority, description, pxyStatus.myInvoiceProcess,pxyStatus.colour, emailTemplate); // 29 Nov 2022 navvt20 TFS 55548
	app.myTrxUA.trxUpdateInvoiceStatusNew(pxyStatus, app.myPassport);
	
	return app.myPassport.trxCompletedOK;

end;</source>
        <text>TFS39618</text>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doShowEmailForm" id="da003d5e-85d4-4485-99aa-e3aee73c6ffa">
        <source>doShowEmailForm();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 Jan 2019	jlgsl4	TFS39618

*/

vars
	form : SOP_TableMaintForm;
	status, pxyStatus : CM_InvoiceStatus;
	emailDefault, pxyEmailDefaults : CM_InvStatusDefaultEmail;
	emailAdding : Boolean;
	pxyEmailTemplate, oldTemplate : CM_EmailTemplate;
	modalResult : Integer;
	loadState : Boolean;					// TFS 37540
	invoiceProcess : CM_InvoiceProcess;
begin
	form := self.myForm;
	status := form.myCurrentObject.CM_InvoiceStatus;
	pxyStatus := form.myProxyObject.CM_InvoiceStatus;
	invoiceProcess := status.myInvoiceProcess;
	if status.myEmailTemplate = null then
		emailAdding := true;
		pxyEmailTemplate := pxyStatus.createPxyEmailTemplate();
		emailDefault := app.myRoot.allInvStatusDefaultEmails[invoiceProcess.pinEmailOffset + status.id];
	else
//		app.cmsBeginLoad(loadState);											// TFS 37540
//		pxyEmailTemplate := pxyStatus.myEmailTemplate.pxyCreateUpdateProxy();	// TFS 37540
//		app.cmsEndLoad(loadState);												// TFS 37540
		pxyEmailTemplate := pxyStatus.myEmailTemplate;
		emailDefault := app.myRoot.allInvStatusDefaultEmails[status.myEmailTemplate.type];
	endif;
	
	pxyEmailDefaults := emailDefault.cloneSelf(true).CM_InvStatusDefaultEmail;
	
	if not emailAdding then	// there is some email info saved on invoice status before
		pxyEmailDefaults.setFromEmailTemplate(pxyEmailTemplate);	//prepare self.myEmailDefaults from persistent stored email template
		pxyEmailDefaults.setAddresses(pxyEmailTemplate.bccAddresses, pxyEmailTemplate.ccAddresses, pxyEmailTemplate.toAddresses);
	endif;
	
	modalResult := form.myAssistant.showInvoiceStatusEmailOptions(pxyEmailDefaults, false);
	
	if modalResult = IDOK then
		pxyEmailTemplate.setFromObjectEmail(pxyEmailDefaults);	//saving email info on the voyage status
		oldTemplate := pxyStatus.myEmailTemplate;
		if oldTemplate &lt;&gt; pxyEmailTemplate then
			delete oldTemplate;
		endif;
		pxyEmailTemplate.setMyParent(pxyStatus);
		if pxyEmailTemplate.canBeDeletedForVoyageStatus then
			pxyEmailTemplate.setMyParent(null);
			delete pxyEmailTemplate;
		endif;
	endif;
	
epilog
	if modalResult &lt;&gt; IDOK then
		delete pxyEmailTemplate;
	endif;
	delete pxyEmailDefaults;
	if loadState then						// TFS 37540
		app.cmsEndLoad(loadState);			// TFS 37540
	endif;
end;</source>
    </JadeMethod>
