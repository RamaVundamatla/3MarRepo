<Class name="CM_SlotController">
    <JadeMethod name="getSpannedToLCsUnitTest" id="41069ca8-c1cc-4772-bd63-f11a063a9414">
        <source>getSpannedToLCsUnitTest(_control: CMIF_MoveController input): Boolean;

/*

Purpose:		

Date			Who		Reason
07/11/2014		cnwmh5	Initial creation

*/

vars
	units : Real;
	tArray : CM_LCArray;
	lc : CM_SlotController;
	count : Integer;
begin
	// if we have already set multiple locations for this TI then get out, break bulk can take up more than one slot
	if _control.allToLocations.size &gt; 1 then
		if _control.myTrackedItem &lt;&gt; null then
			if _control.myTrackedItem.isKindOf(CM_Cargo) then
				return true;
			endif;
		endif;
	endif;

	_control.setMyToSecondaryLocations(null);

	
	//Determine the # of spaces this TI will take up
	units := _control.myTrackedItem.getLengthInUnits();
	if _control.myTrackedItem.is53() then
		units := units + 2;
	endif;
	if units &lt;= 2 then
		//---------------
		//This controller will carry it off (2 * 10' units = my size. i.e. 1 * 20' unit)
		//---------------
		return true;
	endif;
	//---------------
	//Convert to 20' scale
	//---------------
	units := units div 2;
	//---------------
	//Because each of me is a 20' unit, I need 1 for each 2 units returned from the call
	//as they are 10' units as well
	//---------------
	if self.myBayVoyage.myHold &lt;&gt; self.myAftSlot.mySlotDefnVoyage.mySlotController.myBayVoyage.myHold then
		//There is NO next LC (slot)!

		return false;
	endif;
/* PAR 17841 moved up for 40s only
	if not self.isFortyFront then
		return false;
	endif;

*/
	create tArray transient;
	lc := self.myAftSlot;
	count := 1;
	while true do
		if lc = null then
			break;
		endif;
		if lc.myBayVoyage.myHold &lt;&gt; self.myBayVoyage.myHold then
			break;
		endif;
		count := count + 1;
		tArray.add(lc);
		if count = units then
			break;
		endif;	
		lc := lc.myAftSlot;
	endwhile;	
	//--------------------
	//Return whether there are enough positions
	//--------------------
	if (tArray.size + 1) &lt;&gt; units then
		//Subtract 1 for the current lc where we started from (its NOT in the array returned)
		return false;
	endif;
	//Set the array
	_control.setMyToSecondaryLocations(tArray);
	return true;
epilog
	delete tArray;
end;</source>
        <Parameter name="_control" type="CMIF_MoveController" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
