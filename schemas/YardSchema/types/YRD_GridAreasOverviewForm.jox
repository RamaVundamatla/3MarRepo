    <JadeMethod name="doMnuLcnPadMainClick" id="64fad954-c26d-4b54-b96d-3e99802b5fea">
        <updating/>
        <source>doMnuLcnPadMainClick(menuItem: MenuItem input) updating;
// ---------------------------------------------------------------------------
// Created:		September 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars
	theController : CM_GridController;
	theIndex : Integer;
	theMode, theValue : Integer;
begin
	if CMIF_MenuParams.hasInstance(menuItem.userObject) then
		self.doMnuLcnCLICK(menuItem);
	else
		
		theController := menuItem.userObject.CM_GridController;
		if theController = null then
			return;
		endif;
		
		theIndex := menuItem.helpContextId;
		
		if theIndex = MENU_INDEX_AVAIL then
			theMode := CMIF_GridTARegion.UpdateMode_LocationAvailable;
			theValue := PAD_AVAILABLE;
		elseif theIndex = MENU_INDEX_UNAVAIL then
			theMode := CMIF_GridTARegion.UpdateMode_LocationUnavailable;
			theValue := PAD_UNAVAILABLE;
		elseif theIndex = MENU_INDEX_POWER_BAD then
			theMode := CMIF_GridTARegion.UpdateMode_PowerDamaged;
			theValue := null;
		elseif theIndex = MENU_INDEX_POWER_GOOD then
			theMode := CMIF_GridTARegion.UpdateMode_PowerGood;
			theValue := null;
		elseif theIndex &gt; MENU_INDEX_NOTHING_BASE then
			theMode := CMIF_GridTARegion.UpdateMode_HeightRestriction;
			theValue := theIndex - MENU_INDEX_NOTHING_BASE + 2;
		endif;
		
		self.doMnuLcnPadHeights(theController,theMode, theValue);
	endif;
end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
