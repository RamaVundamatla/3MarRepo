    <JadeMethod name="utlUpdateBGPControllerProcess" id="b1d01bb0-797d-460b-bb8c-c48406839c9a">
        <source>utlUpdateBGPControllerProcess(_bgpController : BGP_Controller input; _process: Process; _startTime : TimeStamp; _isNotify : Boolean);

// cnwdvb1 12 November 2002 

vars
	
begin

	self.initialiseActivity();
	
	app.setContinueCMExceptions(false);

	self.exclusiveLock(_bgpController);

	_bgpController.setProcess(_process, _startTime, _isNotify);
	_bgpController.setIsAlerted(false);

end;</source>
        <Parameter name="_bgpController" type="BGP_Controller" usage="input"/>
        <Parameter name="_process" type="Process"/>
        <Parameter name="_startTime" type="TimeStamp"/>
        <Parameter name="_isNotify" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateBGPControllerSDSProcs" id="b3a6225b-bd40-4639-a469-c0500f2668af">
        <updating/>
        <source>utlUpdateBGPControllerSDSProcs(_bgpController : BGP_Controller input; _process : Process) updating;

vars

begin
	self.initialiseActivity();
	
	app.setContinueCMExceptions(false);
	self.exclusiveLock(_bgpController);
	if _process = null then
		_bgpController.setTerminateSDSProcess(false);
	endif;
	_bgpController.setSDSSecondaryProcess(_process);
	_bgpController.setLastSDSUpdateDT();
end;
</source>
