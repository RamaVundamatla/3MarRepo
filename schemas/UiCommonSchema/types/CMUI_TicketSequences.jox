    <JadeMethod name="addItem" id="b8a4bb42-b5d7-45a5-80fa-4350680a79c4">
        <updating/>
        <source>addItem() updating;
//--------------------------------------------------------------
//Created: March 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	ticketSeq 	: CM_TicketSequence;
	numFrom,
	numTo,	
	qty		: Integer;
	strFrom,
	strTo : String;	
	rtValue : Boolean;
		
begin
	strFrom := tblItem.getValueByName(ETRow_FromId).String;
	
	if strFrom = null then
		return;
	endif;
	
	strTo := tblItem.getValueByName(ETRow_ToId).String;
	
	if strTo = null then
		self.setFieldToID();
		return;
	endif;
	
	numFrom := strFrom.getTrailingInteger();
	numTo := strTo.getTrailingInteger();
	
	on CM_Exception do app.validationExHandler(exception, app.myPassport);
	app.setContinueCMExceptions(true);
	app.myPassport.clearErrorsWarnings();
	
	self.validateSequence(numFrom, numTo);

	if app.myPassport.hasErrors then
		app.showErrorWarningDialog('Ticket Sequences', app.myPassport, ErrWarnMode_Add);
		return;
	endif;
	on CM_Exception do null;	// disarm the validation ex handler
	
	qty := (numTo.Integer - numFrom.Integer) + 1;
	
	create ticketSeq transient;

	if self.myCurrentView.name = 'LogTicketSeq' then
		ticketSeq.setProxy(strFrom, strTo, qty, 
							tblItem.getValueByName(ETRow_Scale).Boolean);							 
	endif;

	app.setContinueCMExceptions(true);

	// check all fields have been entered
	ticketSeq.checkFieldNotNull();
	self.checkForDuplicateId(ticketSeq);

	if app.myPassport.hasErrors then
		app.showErrorWarningDialog('Ticket Sequences', app.myPassport, ErrWarnMode_Add);
		delete ticketSeq;
		return;
	endif;

	self.myTicketSequenceRules.allTicketSequences.add(ticketSeq);

	if (not self.showRemaining()) then
		app.showErrorWarningDialog('Ticket Sequences', app.myPassport, ErrWarnMode_Add);
		self.myTicketSequenceRules.allTicketSequences.remove(ticketSeq);
		delete ticketSeq;
		return;
	endif;	
	on CM_Exception do null;	// disarm the validation ex handler

	self.tblAll_ShowTicketSeq(ticketSeq, 0);
	self.setFieldScale();
	self.setFieldFromID();
	self.setFieldToID();
	tblItem.setFocus();
epilog
	self.tblItem.setFocus;
	self.tblItem.goToRowByName(ETRow_FromId);
		
end;</source>
    </JadeMethod>
    <JadeMethod name="calculateRemaining" id="7f560372-0634-4c7b-8a62-723729b2fd88">
        <source>calculateRemaining() : Integer protected;
// -----------------------------------------------------------------------------
// Created:		08 April 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
begin
	return self.myTicketSequenceRules.calculateRemaining();
end;</source>
        <access>protected</access>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="calculateRequired" id="b0320a14-37ae-4a20-85c7-c43748658e02">
