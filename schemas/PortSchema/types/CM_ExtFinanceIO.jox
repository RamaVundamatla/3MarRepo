    <JadeMethod name="exportCredit" id="15f73c72-7c75-4227-beb8-f2a9074e9a70">
        <source>exportCredit(_credit : CM_CashCredit input);
/*
Purpose:		Default credit export, based heavily on CM_OracleFinancials::exportCredit	

Parameters:			

Return Value:		

Date		Who		Reason
26 Jun 2019	jlgsl4	TFS 44265 - JMT - Cash Export JMT Default
*/

vars
	file 	: File;
	path 	: String;
	fileFolder : FileFolder;
	debtor	: CM_Debtor;
	terminal : CM_Terminal;
	message : String;
begin
	debtor := _credit.getDebtor(); // don't export default debtor
	if debtor = null or debtor.isRDT() then
		return;
	endif;
	
	terminal := _credit.myDebtorTerminal.myTerminal;
	path := self.exportPath.normaliseDirectory().substituteDirectory();
	path := path &amp; terminal.code &amp; "\";

	create fileFolder;
	fileFolder.fileName := path;
	// all files and directories are on the app server
	// except from unit test and special for testing
	/*if not app.isJMTUnitTest and  not app.isSpecial() then	
		fileFolder.usePresentationFileSystem := false;
	endif;*/
	if not fileFolder.isAvailable then
		if not process.isInTransactionState then
			message := app.getErrorString2(Expor_path_does_not_exist_rec, path, _credit.myDerivedFromCashReceipt.getExternalInvoiceNumber());
			app.msgBox(message, app.getErrorString(Export_error), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
			return;
		else
			app.raiseCMException3(Error_statu_chang_invoi_not_re, _credit.myDerivedFromCashReceipt.getExternalInvoiceNumber(), path, _credit.myDerivedFromCashReceipt.getExternalInvoiceNumber(), null, null);		
			return;
		endif;
	endif;

	create file;
	file.fileName := path &amp; "CRD" &amp; _credit.getExportSequence().padLeadingWith('0', 6) &amp; ".csv";
	file.mode := File.Mode_Output;
	file.allowReplace := true;
	/*if not app.isJMTUnitTest then	
		file.usePresentationFileSystem := false;
	endif;*/
	self.exportCreditToFileCSV(_credit, file);
epilog
	delete fileFolder;
	if file &lt;&gt; null then
		if file.isOpen() then
			file.close();
		endif;
		delete file;
	endif;
end;</source>
        <Parameter name="_credit" type="CM_CashCredit" usage="input"/>
    </JadeMethod>
    <JadeMethod name="exportCreditToFile" id="1530d044-a34e-400f-af52-7f87f48ae940">
        <source>exportCreditToFile(_credit : CM_CashCredit input; _fileNameBase : String);
//26 Jun 2019	jlgsl4	TFS 44265 - JMT - Cash Export JMT Default

vars
	file : File;
	debtor	: CM_Debtor;
begin
	// don't export if default debtor to match invoice processing
	debtor := _credit.getDebtor();
	if debtor = null or debtor.isRDT() then
		return;
	endif;

	create file;
	file.allowReplace := true;
	file.fileName := _fileNameBase; 
	file.mode := File.Mode_Output;
	file.usePresentationFileSystem := true;	
	self.exportCreditToFileCSV(_credit, file);
epilog
	if file &lt;&gt; null then
		if file.isOpen() then
			file.close();
		endif;
		delete file;
	endif;
end;</source>
        <Parameter name="_credit" type="CM_CashCredit" usage="input"/>
        <Parameter name="_fileNameBase" type="String"/>
    </JadeMethod>
    <JadeMethod name="exportCreditToFileCSV" id="7262f5ae-1c43-45a4-b02f-aa2c5fea86ee">
        <source>exportCreditToFileCSV(_credit: CM_CashCredit input; _file: File input) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 Jun 2019	jlgsl4	TFS 44265 - JMT - Cash Export JMT Default
*/

vars
	fileException : FileException;
	terminal 	: CM_Terminal;
begin
	on FileException do self.fileExceptionHandler(fileException);

	if _credit.getDebtor() = null then
		return;
	endif;

	self.writeHeaderCreditToFile(_file, _credit);
	self.writeCreditLinesToFile(_file, _credit, 0.0);

	if process.isInTransactionState then // true for export called from invoice post
		_credit.exportedCount := _credit.exportedCount + 1;
	else
		app.myTrxUA.trxIncrementCreditExportCount(_credit, app.myPassport);
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_credit" type="CM_CashCredit" usage="input"/>
        <Parameter name="_file" type="File" usage="input"/>
    </JadeMethod>
    <JadeMethod name="exportReceipt" id="0c33b6c9-50a0-4f90-a356-05fea4964dfb">
        <source>exportReceipt(_receipt: CM_CashReceipt input);
/*

Purpose:		Default receipt export, based heavily on CM_OracleFinancials::exportReceipt	

Parameters:			

Return Value:		

Date		Who		Reason
24 Jun 2019	jlgsl4	TFS 44265 - JMT - Cash Export JMT Default
*/

vars
	file 	: File;
	path 	: String;
	fileFolder : FileFolder;
	debtor	: CM_Debtor;
	terminal : CM_Terminal;
	message : String;
begin
	debtor := _receipt.getDebtor(); // don't export default debtor
	if debtor = null or debtor.isRDT() then
		return;
	endif;
	
	terminal := _receipt.myDebtorTerminal.myTerminal;
	path := self.exportPath.normaliseDirectory().substituteDirectory();
	path := path &amp; terminal.code &amp; "\";

	create fileFolder;
	fileFolder.fileName := path;
	// all files and directories are on the app server
	// except from unit test and special for testing
	/*if not app.isJMTUnitTest and  not app.isSpecial() then	
		fileFolder.usePresentationFileSystem := false;
	endif;*/
	if not fileFolder.isAvailable then
		if not process.isInTransactionState then
			message := app.getErrorString2(Expor_path_does_not_exist_rec, path, _receipt.getExternalInvoiceNumber());
			app.msgBox(message, app.getErrorString(Export_error), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
			return;
		else
			app.raiseCMException3(Error_statu_chang_invoi_not_re, _receipt.getExternalInvoiceNumber(), path, _receipt.getExternalInvoiceNumber(), null, null);		
			return;
		endif;
	endif;

	create file;
	file.fileName := path &amp; "REC" &amp; _receipt.getExportSequence().padLeadingWith('0', 6) &amp; ".csv";
	file.mode := File.Mode_Output;
	file.allowReplace := true;
	/*if not app.isJMTUnitTest then	
		file.usePresentationFileSystem := false;
	endif;*/
	self.exportReceiptToFileCSV(_receipt, file);
epilog
	delete fileFolder;
	if file &lt;&gt; null then
		if file.isOpen() then
			file.close();
		endif;
		delete file;
	endif;
end;</source>
        <Parameter name="_receipt" type="CM_CashReceipt" usage="input"/>
    </JadeMethod>
    <JadeMethod name="exportReceiptToFile" id="b0c4ab1c-80c1-47f5-acc8-39e4d361dd28">
        <source>exportReceiptToFile(_receipt: CM_CashReceipt input; _fileNameBase: String);
//24 Jun 2019	jlgsl4	TFS 44265 - JMT - Cash Export JMT Default

vars
	file : File;
	debtor	: CM_Debtor;
begin
	// don't export if default debtor to match invoice processing
	debtor := _receipt.getDebtor();
	if debtor = null or debtor.isRDT() then
		return;
	endif;

	create file;
	file.allowReplace := true;
	file.fileName := _fileNameBase; 
	file.mode := File.Mode_Output;
	file.usePresentationFileSystem := true;
	self.exportReceiptToFileCSV(_receipt, file);
epilog
	if file &lt;&gt; null then
		if file.isOpen() then
			file.close();
		endif;
		delete file;
	endif;
end;
</source>
        <Parameter name="_receipt" type="CM_CashReceipt" usage="input"/>
        <Parameter name="_fileNameBase" type="String"/>
    </JadeMethod>
    <JadeMethod name="exportReceiptToFileCSV" id="136e6824-788f-48c5-b6b3-aba309401376">
        <source>exportReceiptToFileCSV(_receipt: CM_CashReceipt input; _file : File input) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 Jun 2019	jlgsl4	TFS 44265 - JMT - Cash Export JMT Default
*/

vars
	fileException : FileException;
begin
	on FileException do self.fileExceptionHandler(fileException);

	if _receipt.getDebtor() = null or _receipt.getCashInvoice() = null then
		return;
	endif;
	
	self.writeHeaderRecToFile(_file, _receipt);
	self.writeCashPaymentsToFile(_file, _receipt);

	if process.isInTransactionState then // true for export called from invoice post
		_receipt.exportedCount := _receipt.exportedCount + 1;
	else
		app.myTrxUA.trxIncrementReceiptExportCount(_receipt, app.myPassport);
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_receipt" type="CM_CashReceipt" usage="input"/>
        <Parameter name="_file" type="File" usage="input"/>
    </JadeMethod>
