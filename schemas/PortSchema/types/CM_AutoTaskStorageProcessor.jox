        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getValueForRow" id="5de33769-4baa-4ac2-b97a-59b106dc4757">
        <source>getValueForRow(_rowName: String; _obj: Object output): Any;
// 24016 add selector query and financial period to BGP storage process
vars

begin
	if _rowName = ETRow_Period then
		if self.myFinancialPeriod = null then
			return "";
		else
			return self.myFinancialPeriod.description;
		endif;
	elseif _rowName = ETRow_BgpAutoSelectorQuery then
		if self.mySelectorQuery = null then
			return "";
		else
			return self.mySelectorQuery.description;
		endif;
	else
		return inheritMethod(_rowName, _obj);
	endif;
end;
</source>
        <Parameter name="_rowName" type="String"/>
        <Parameter name="_obj" type="Object" usage="output"/>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="492f1696-5b65-4903-bd40-ece3a2326e3b">
        <source>pxyCreateUpdateProxy(): SelfType;
// 24016 add selector query and financial period to BGP storage process
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy
vars
	task : CM_AutoTaskStorageProcessor;
	completedOK		: Boolean;
	
begin
	
	task := inheritMethod();
	task.myFinancialPeriod := self.myFinancialPeriod;
	task.mySelectorQuery := self.mySelectorQuery;
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return task;

epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete task;
	endif;	
end;
</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="968599ef-e69d-4e6c-bf6e-9fb239466d26">
        <updating/>
        <source>setForCreate(_pxyAutoTask: CM_AutoTaskStorageProcessor) updating;
// -------------------------------------------
// Created 08 September 2003 by cnwdvb1
// -------------------------------------------
vars

begin
	inheritMethod(_pxyAutoTask);
	self.requestClassName	:= BGP_StorageProcessorRequest.name;
	// added properties for 24016 add item selector and financial period
	self.myFinancialPeriod  := _pxyAutoTask.myFinancialPeriod;
	self.mySelectorQuery	:= _pxyAutoTask.mySelectorQuery;
end;</source>
        <Parameter name="_pxyAutoTask" type="CM_AutoTaskStorageProcessor"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="ff5d60c8-9111-4fd1-a9ae-b78f70667b7e">
        <updating/>
        <source>setForUpdate(_pxyAutoTask: CM_AutoTaskStorageProcessor) updating;
// added properties for 24016 add item selector and financial period
vars

begin
	inheritMethod(_pxyAutoTask);
	self.myFinancialPeriod  := _pxyAutoTask.myFinancialPeriod;
	self.mySelectorQuery	:= _pxyAutoTask.mySelectorQuery;
end;</source>
        <Parameter name="_pxyAutoTask" type="CM_AutoTaskStorageProcessor"/>
    </JadeMethod>
    <JadeMethod name="setValueForRow" id="d6967de8-cd29-4f05-925f-7d17912855b9">
        <updating/>
        <source>setValueForRow(_rowName: String; _value: Any) updating;
// 24016 add selector query and financial period to BGP storage process
vars

begin
	if _rowName = ETRow_Period then
		self.myFinancialPeriod := _value.CM_FinancialPeriodEnd;
	elseif _rowName = ETRow_BgpAutoSelectorQuery then
		self.mySelectorQuery := _value.CM_MenuUserQuery;
	else
		inheritMethod(_rowName, _value);
	endif;
end;
</source>
        <Parameter name="_rowName" type="String"/>
        <Parameter name="_value" type="Any"/>
    </JadeMethod>
    <JadeMethod name="validate" id="9da2e030-0b32-419e-b060-9912b86668ca">
        <source>validate();
/* ---------------------------------------------------------------------------
Created:	15 July 2010	by cnwvu1

Purpose:	#24990
   
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars

begin
	inheritMethod();

	if self.myTerminal = null then																		//cnwas3 par 24528 begin
	//	app.raiseCMException1(REQUIRED_FIELD,app.getErrorString(Terminal), ETRow_BgpAutoSelectorQuery, null);
		app.raiseCMException1(Input_required_field_Required,app.getErrorString(Terminal), ETRow_BgpAutoSelectorQuery, null); // cnwdb2	PAR 35364
	endif;


end;</source>
    </JadeMethod>
</Class>
