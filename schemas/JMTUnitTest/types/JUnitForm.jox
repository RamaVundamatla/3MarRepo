    <JadeMethod name="addClassToTree" id="fa5b9d54-3f0d-453d-b3ef-c6c5ce9b217a">
        <updating/>
        <source>addClassToTree(klass: Class; level: Integer) : Integer updating;
//03 August 2008	cnwdw1	
//
vars
	subklass: Class;
	meth: Method;
	index: Integer;
	parent: Integer;
	allSubclasses: ClassColl;
	allMethods: MethodSet;
	methodsByName: DynaDictionary;
	obj: Object;
	doFilter : Boolean;
	filterText : String;
	methCount : Integer;
begin
	if not self.noFilter then
		filterText := self.txtFilter.text.trimWhiteSpace().toLower();
		doFilter := filterText.length &gt; 0;
	endif;

	index := lbxTests.addItem(klass.name);
	parent := index;
	lbxTests.itemObject[index] := klass;
	lbxTests.itemLevel[index] := level;
	
	create allSubclasses transient;
	klass.getSubclasses(allSubclasses);
	klass.allSubclassesInSubschemas(allSubclasses);
	foreach subklass in allSubclasses do
		if subklass.getSuperclass = klass then
			methCount += self.addClassToTree(subklass, level + 1);
		endif;
	endforeach;
	
	create allMethods transient;
	//klass.allMethods(allMethods);
	self.getAllMethods(klass, allMethods);
	create methodsByName transient;
	methodsByName.setMembership(Method);
	methodsByName.addMemberKey("name", false, true);
	methodsByName.endKeys(false);
	allMethods.copy(methodsByName);
	
	foreach obj in methodsByName do
		meth := obj.Method;
		if doFilter and meth.name.toLower().pos(filterText, 2) = 0 then
			continue;
		endif;
		methCount += 1;
		
		if self.isUnitTest(meth) then
			index := lbxTests.addItem(meth.name[2:end]);
			lbxTests.itemObject[index] := meth;
			lbxTests.itemLevel[index] := level+1;
			lbxTests.itemData[index] := parent;
			lbxTests.itemPicture[index] := picNotRun.picture;
			self.testCount := self.testCount + 1;
		endif;
		if self.isIgnoreTest(meth) then
			index := lbxTests.addItem(meth.name[2:end]);
			lbxTests.itemObject[index] := meth;
			lbxTests.itemLevel[index] := level+1;
			lbxTests.itemData[index] := parent;
			lbxTests.itemPicture[index] := picIgnored.picture;
			self.testCount := self.testCount + 1;
		endif;
		if self.isUtilityTest(meth) then
			index := lbxTests.addItem(meth.name[2:end]);
			lbxTests.itemBackColor[index] := LightYellow;
			lbxTests.itemObject[index] := meth;
			lbxTests.itemLevel[index] := level+1;
			lbxTests.itemData[index] := parent;
			lbxTests.itemPicture[index] := picNotRun.picture;
		endif;
	endforeach;
	
	if doFilter and methCount = 0 and level &gt; 2 then
		// Remove the parent class
		lbxTests.removeItem(parent);
	endif;
	
	return methCount;
epilog
	delete methodsByName;
	delete allMethods;
	delete allSubclasses;
end;</source>
        <Parameter name="klass" type="Class"/>
        <Parameter name="level" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="appendToResults" id="e3df4767-bea0-4c4b-b1c3-3d20fe03b8de">
        <source>appendToResults(_result: UT_TestResult);
//24 April 2009	cnwdw1	
//
vars
	index	: Integer;
	string	: CnEcString;
begin
	self.tblResults.rows := self.tblResults.rows + 1;
	index := self.tblResults.rows;
	if _result.hasPassed() then
		self.tblResults.accessCell(index, 1).picture := picSuccess.picture;
		// 26/02/2013 cnwmh5
		if self.chkFailsOnly.value = true then
			self.tblResults.accessRow(index).visible := false;
		endif;
	else
		self.tblResults.accessCell(index, 1).picture := picFailed.picture;
	endif;
	self.tblResults.accessCell(index, 2).text := _result.getClassName();
	self.tblResults.accessCell(index, 3).text := _result.getMethodName();
	self.tblResults.accessCell(index, 4).text := _result.getTerminal();
	self.tblResults.accessCell(index, 5).text := _result.getProfile();
	self.tblResults.accessCell(index, 6).text := _result.getTimeString();
	self.tblResults.accessCell(index, 7).text := _result.getOwnerName();

	self.tblResults.accessCell(index, 8).text := _result.fullDetails();
	
	// UT_TestResult is transient and deleted before the results are disabled, so we need to save off the full string
	// (Cleaned up in doClearResults)
	create string transient;
	string.updateMe(_result.fullDetails());
	self.tblResults.accessRow(index).itemObject := string;
	
end;</source>
        <Parameter name="_result" type="UT_TestResult"/>
    </JadeMethod>
    <JadeMethod name="btnAddBmrk_click" id="e1beb794-90ef-4de4-beaa-36805351ab25">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnAddBmrk_click(btn: Button input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 April 2023	navra1	Initial creation

*/

vars
	folderSelected : UM_BookmarkFolder;
	methodName : UM_MethodName;
begin
	
	if lbxTests.itemObject[lbxTests.listIndex].isKindOf(Class) then
		app.msgBox(	"Only a method can be bookmarked for now", "Choose a method", MsgBox_OK_Only + MsgBox_Stop_Icon);		
		return;
	endif;
	
	if lbxTests.itemObject[lbxTests.listIndex].isKindOf(Method) then
		if lstBookMarks.listIndex &lt;&gt; -1 then
			if self.lstBookMarks.itemObject[lstBookMarks.listIndex].isKindOf(UM_BookmarkFolder) then
				folderSelected := self.lstBookMarks.itemObject[lstBookMarks.listIndex].UM_BookmarkFolder;
			
				beginTransaction;
					create methodName persistent;
					methodName.methodNameString:=lbxTests.itemObject[lbxTests.listIndex].getNiceName();
					methodName.bkMarkfolder:=folderSelected;
					folderSelected.methodNames.add(methodName);					
				commitTransaction;
			
			endif;
		else
			app.msgBox(	"Choose a bookmark folder", "Choose a folder", MsgBox_OK_Only + MsgBox_Stop_Icon);		
		endif;
			
		
			
	endif;
	
	reloadBookmarks();
epilog
	
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnAddFolder_click" id="08967de6-db56-407b-aafe-14495e9f6613">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnAddFolder_click(btn: Button input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 April 2023	navra1	Initial creation

*/

vars
	newLabelName : String;
	item : Object;
	index : Integer;
	parent: Integer;
	level : Integer;
	listBoxCount : Integer;
	count : Integer;
	newBookmarkFolder : UM_BookmarkFolder;
	 
begin

	
	if self.txtFolderName.text = null or self.txtFolderName.text = '' then
		return;
	endif;
	
	newLabelName := self.txtFolderName.text;
	count := 1;
	self.lstBookMarks.hasPlusMinus:=true;
	listBoxCount := self.lstBookMarks.listCount;	
	
	foreach item in lstBookMarks.itemObject do	
		if item &lt;&gt; null and item.isKindOf(UM_BookmarkFolder) then
			if item.UM_BookmarkFolder.bookmarkName = newLabelName then
				app.msgBox(	"Bookmark category with name '" &amp; newLabelName &amp; "' already exists!", "Choose different name", MsgBox_OK_Only + MsgBox_Stop_Icon);		
				return;
			endif;
		endif;
	endforeach;
	
	beginTransaction;
		create newBookmarkFolder persistent;	
		newBookmarkFolder.bookmarkName :=self.txtFolderName.text;		
		index := self.lstBookMarks.addItem(self.txtFolderName.text);
		lstBookMarks.itemLevel[index] := 1;
		parent := index;
		//create newBookmarkFolder.methodNames persistent;
		//newBookmarkFolder.methodNames.add("first method");
		lstBookMarks.itemObject[index] := newBookmarkFolder;
		lstBookMarks.itemData[index] := 1;
	commitTransaction;
	
	self.txtFolderName.text := '';	
		
		
epilog

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
