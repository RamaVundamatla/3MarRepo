    <JadeMethod name="getDisplayStringForAttribute" id="cf72e19e-dc1b-4f0a-9b36-a4f8d69ed4b3">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;

vars
	lDetail : String;
	ta		: CM_TerminalArea;
begin

	if _attrName = ETRow_PackComplete then
		ta := self.getLocationTA();
		if ta &lt;&gt; null then
			lDetail := ta.id;
		endif;
		return lDetail;

	else
		return inheritMethod(_attrName, _short);
	endif;

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getLocationTA" id="2d2abefb-c21e-4a97-8bad-baeb84edef51">
        <source>getLocationTA() : CM_TerminalArea;
//
// cnwrs1 May 2007 Find SourceTerminal area for cams
//
vars
	tmpFoundLC : CM_LocationsController;
	tmpFoundHeight : Integer;
begin
	self.myTerminal.findLocationFromString(self.location, true, tmpFoundLC, tmpFoundHeight);
	if tmpFoundLC &lt;&gt; null then
		return tmpFoundLC.myTerminalArea;
	else
		return null;
	endif;
end;

</source>
        <ReturnType type="CM_TerminalArea"/>
    </JadeMethod>
