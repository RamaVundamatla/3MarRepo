    <JadeMethod name="setForCreate" id="c569ea8f-c922-4b8b-9ba6-dc7a5c6c2a8f">
        <updating/>
        <source>setForCreate(_proxySelf : SelfType;_passport : CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 April 2011	cnwer1	Initial creation CCMS 1031

*/

vars

begin
	_proxySelf.raiseExceptionIfNotTransient(method);
	
	self.setForUpdate(_proxySelf,_passport);
epilog

end;</source>
