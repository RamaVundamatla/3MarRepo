    <JadeMethod name="setForFullResyncOf" id="3a65fd32-806c-4080-9a89-bea43a3243fb">
        <updating/>
        <source>setForFullResyncOf( _ti : CM_TrackedItem ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22/04/2013	cnwndl1	Initial creation	Par 31424
04/06/2019	jlgdap1	TFS 44554 AAT Stevedore Data Access
04/04/2023	navmk20	Task 57433: Country of Origin - Transactions Resync
20/06/2023	navkc1	CR 55653 Task 58724: EUP - Re evaluate Contract Id
*/

vars

begin

	self.myTrackedItem := _ti;
	_ti.allTransactions.copy(self.allTransactions);
	
	self.updateBusinessUnit := true;
	self.updateCommodity := true;
	self.updateConsignee := true;
	self.updateConsignor := true;
	self.updateContents := true;
	self.updateCustomsAgent := true;
	self.updateDestinationPort := true;
	self.updateDischargePort := true;
	self.updateFreightForwarder := true;
	self.updateImexStatus := true;
	self.updateOperator := true;
	self.updateQuantity := true;
	self.updateVolume := true;
	self.updateWeight := true;
	self.updateStevedore := true;			// TFS 44554
	self.updateTrailerType := _ti.getCurrentTrailerType &lt;&gt; null;	//29 Oct 2020	NDL TFS 50113
	self.updateCountryOfOrigin := _ti.myCountryOfOrigin &lt;&gt; null; 	//4.4.2023 navmk20 TFS 57433
	self.updateShippingLine := true; // ### TFS BUG 56663 23FEB2023 NAVAB1
	self.updateContractId := true; //20/06/2023	navkc1	CR 55653 Task 58724
	self.updateHsCode := true; //04/10/2024	navkc1	JIRA 32999
epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
</Class>
