    <JadeMethod name="showSearchFrame" id="e379104e-ad60-4d20-9b93-b3573f5bbece">
        <source>showSearchFrame();
/*
Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 Dec 2019	NDL		TFS 47284

*/
vars

	theFrame : CMUI_MoveableFrame;

begin

	if self.frmSearch.visible then
		self.hideSearchFrame();
	else
		theFrame := self.frmSearch;
		theFrame.zOrder(1);
		theFrame.centreWindow();
		theFrame.visible := true;
		self.frmMain.enabled := false;
	endif;

epilog

end;</source>
