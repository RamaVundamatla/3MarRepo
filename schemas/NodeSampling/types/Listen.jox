    <JadeMethod name="lbx_System_click" id="fd6e448c-64c4-461e-a91d-b582fb4ed0f0">
        <controlMethod name="ListBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>lbx_System_click(listbox: ListBox input) updating;
constants

vars
	result : Integer;
begin
	v_environment := lbx_System.itemObject [lbx_System.listIndex].Environments;
	if v_environment.state &lt;&gt; Environments.State_Loaded then
		result := app.msgBox('System is not completely loaded. ' &amp; CrLf &amp; 
		                     "'Click OK' to delete." &amp; CrLf &amp;
		                     '     Then reload.', 'Invalid System', MsgBox_OK_Cancel);
		if result = MsgBox_Return_OK then
			v_tcpHandler.delClassAndMethodDescriptions(v_environment);
		endif;
		return;
	endif;
	caption := 'Using ' &amp; "'" &amp; v_environment.name &amp; "' System";
	v_tcpHandler.v_environment := v_environment;
epilog

end;</source>
        <Parameter name="listbox" type="ListBox" usage="input"/>
    </JadeMethod>
