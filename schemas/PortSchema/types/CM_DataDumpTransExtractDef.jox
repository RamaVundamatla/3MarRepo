<Class name="CM_DataDumpTransExtractDef" id="b6288903-0cea-49ca-90cb-5f3846515bb7">
    <superclass name="CM_DataDumpTransient"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>1:1 with CM_DataDumpExtractDef.</text>
    <DbClassMap file="cmtrans"/>
    <ExplicitInverseRef name="allTransExtractClasses" id="8de793c8-ffb8-4a6c-8616-f9431c3528a4">
        <kind>parent</kind>
        <updateMode>manual</updateMode>
        <type name="CM_DataDumpTransExtrClassArray"/>
        <access>readonly</access>
        <Inverse name="CM_DataDumpTransExtractClass::myTransExtractDef"/>
    </ExplicitInverseRef>
    <ImplicitInverseRef name="myDataDumpExtractDef" id="2a46ded2-1301-46b8-947e-6ece4f7b9b13">
        <embedded/>
        <type name="CM_DataDumpExtractDef"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <JadeMethod name="createExtractClass" id="d0d23959-c145-42f8-9da7-2fd00db00b08">
        <updating/>
        <source>createExtractClass(_extractClass: CM_DataDumpExtractClass;
		_initialiseAllClassesOnCreate: Boolean) : CM_DataDumpTransExtractClass updating;
// ---------------------------------------------------------------------------
// Created:     03 June 2003 by cnwsb1
// ---------------------------------------------------------------------------
vars
	newClass : CM_DataDumpTransExtractClass;

begin
	create newClass transient;
	newClass.setForCreate(_extractClass, _initialiseAllClassesOnCreate);
	self.allTransExtractClasses.add(newClass);
	
	return newClass;	
end;</source>
        <Parameter name="_extractClass" type="CM_DataDumpExtractClass"/>
        <Parameter name="_initialiseAllClassesOnCreate" type="Boolean"/>
        <ReturnType type="CM_DataDumpTransExtractClass"/>
    </JadeMethod>
    <JadeMethod name="getTransClass" id="f8d97b13-adeb-4f3d-8b16-6e5f11928d40">
        <source>getTransClass(_class: Class) : CM_DataDumpTransSpecClass;
// ---------------------------------------------------------------------------
// Created:     08 July 2003 by cnwsb1
//
// Purpose:		Returns the transClass for the given persistent class;
//
// Performance:	_initialiseTransClass should be true for JadeScripts, and false
//				for the main data extract, where there is no need to take the
//				performance hit of a class initialisation (approx 20-60 secs)
//				for classes that will not have any data extracted.
// ---------------------------------------------------------------------------
vars
	extrClass : CM_DataDumpTransExtractClass;
	transClass : CM_DataDumpTransSpecClass;

begin
	foreach extrClass in self.allTransExtractClasses do
		foreach transClass in extrClass.allTransSpecClasses where
				transClass.myClass = _class do
			return transClass;
		endforeach;
	endforeach;
	
	return null;
end;</source>
        <Parameter name="_class" type="Class"/>
        <ReturnType type="CM_DataDumpTransSpecClass"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="daea8e80-8a16-490f-88fc-b7e090de6ca2">
        <updating/>
        <source>setForCreate(_extractDef: CM_DataDumpExtractDef; _initialiseAllClassesOnCreate: Boolean) updating;
// ---------------------------------------------------------------------------
// Created:     03 June 2003 by cnwsb1
// ---------------------------------------------------------------------------
vars
	extractClass : CM_DataDumpExtractClass;
	ls : Boolean;

begin
	self.myDataDumpExtractDef := _extractDef;
	
	app.cmsBeginLoad(ls);

	foreach extractClass in _extractDef.allDataDumpExtractClasses do
		self.createExtractClass(extractClass, _initialiseAllClassesOnCreate);
	endforeach;

epilog
	app.cmsEndLoad(ls);
end;</source>
        <Parameter name="_extractDef" type="CM_DataDumpExtractDef"/>
        <Parameter name="_initialiseAllClassesOnCreate" type="Boolean"/>
    </JadeMethod>
</Class>
