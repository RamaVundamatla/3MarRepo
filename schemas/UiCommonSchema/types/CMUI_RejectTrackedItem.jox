    <JadeMethod name="doSave" id="6012b580-e371-4bdc-9abe-8ed848a6bca5">
        <updating/>
        <source>doSave(): Boolean updating;
// ---------------------------------------------------------------------------
// Created:     30 September 2002 by cnwth2
//
// Purpose:     
//
// ----------   ----------  --------------------------------------------------
vars

	rtnValue	: Boolean;
	reason		: String;
	recovery	: String;
	comment		: String;
	theReason	: CM_LogRejectCode;
	theRecovery	: CM_LogRejectRecoveryCode;
	theResult : Integer;	//13 Jan 2020 NDL	TFS 46815
	
begin
	//changed by cnwyl1 as conversation with Tim
	//it was...
	//if self.myTrackedItem = null then
		//app.msgBox('You have not entered sufficient information to save this sheet.', app.getErrorString(Warning), MsgBox_OK_Only + MsgBox_Information_Icon);
	if self.myTrackedItem = null and self.optSingleItem.value = true then
		app.msgBox('You must select a cargo item.', app.getErrorString(Warning), MsgBox_OK_Only + MsgBox_Information_Icon);
		return false;
	endif;
	if self.optSingleItem.value then
		self.allTrackedItems.clear;
		self.allTrackedItems.add(self.myTrackedItem);
	endif;
	
	reason := self.tblActionData.getValueByName(ETRow_ReasonCode).String;
	recovery := self.tblActionData.getValueByName(ETRow_RecoveryCode).String;
	comment := self.tblActionData.getValueByName(ETRow_Comment).String;
	
	//13 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxUA.trxRejectTrackedItems(self.allTrackedItems, reason, recovery, comment, 'CMUI_RejectTrackedItem', app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			self.refreshTable;
			rtnValue := true;
			break;
		else
			theResult := app.showErrorWarningDialog('Reject Tracked Item', app.myPassport, ErrWarnMode_Update);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		break;
		
	endwhile;

epilog
	return rtnValue;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
