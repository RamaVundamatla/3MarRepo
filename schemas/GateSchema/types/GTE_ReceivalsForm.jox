//	Created:	05 April 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
begin
	self.myAssistant.hazardlistTableLostFocus(self.tblExtra, self.saveRowHeight, table.CMUI_HazardsListTable);
end;</source>
