    <JadeMethod name="getTranslationForCategory" id="13987df4-cfe2-4c5e-8fa6-1224aaa5e020">
        <source>getTranslationForCategory(_xlatCategory : String) : String;
/* ---------------------------------------------------------------------------
Created:     21 August 2008 by cnwrs2

Purpose:     PAR 17779 
        
Change Date	Who		Reason

------------------------------------------------------------------------------*/
vars
	tmpLocale	: CM_Locale;
	tmpNum		: Integer;
	tmpTrans	: XLAT_Translation;
begin
	tmpLocale := app.myCurrentLocale;
	if tmpLocale &lt;&gt; null then
		tmpNum := self.getMenuTranslationNumber();
		if tmpNum &gt; 0 then
			tmpTrans := tmpLocale.getTranslatedText(_xlatCategory, tmpNum);
			if tmpTrans &lt;&gt; null and tmpTrans.text &lt;&gt; null then
				return tmpTrans.text;
			endif;
		endif;
	endif;
	
	return self.heading;
end;</source>
        <Parameter name="_xlatCategory" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
