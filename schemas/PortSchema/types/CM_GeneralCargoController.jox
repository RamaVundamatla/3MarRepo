    <JadeMethod name="convertToPopulateLocnDefnName" id="b96172eb-e331-416b-b2c1-bea4665de4dc">
        <updating/>
        <source>convertToPopulateLocnDefnName() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 July 2013	cnwndl1	Initial creation	Par 31965

*/

vars

	newName : String;

begin

	if self.name.trimBlanks &lt;&gt; null then
		return;
	endif;
	
	if self.ident.trimBlanks &lt;&gt; null then	// because in 8.2.1 'name' didn't exist, and some user may be using ident instead...
		newName := self.ident.trimBlanks;
		
	else
		if self.place = PlaceHold then
			newName := PlaceHoldStr;
		elseif self.place = PlaceDeck then
			newName := PlaceDeckStr;
		elseif self.place = PlaceUpper then
			newName := PlaceUpperStr;
		elseif self.place = PlaceTween then
			newName := PlaceTweenStr;
		elseif self.place = PlaceLower then
			newName := PlaceLowerStr;
		endif;
	
	endif;
	
	self.ident := null;
	self.setName(newName);
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="executeDisplayNotesForMove" id="45f22c84-0184-481e-9ff3-ebf64bf8de32">
        <source>executeDisplayNotesForMove(_controller: CMIF_MoveController);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 April 2017	cnwndl1	Initial creation	TFS 4058

*/

vars
	theVoyage : CM_Voyage;	
	theTerminal : CM_Terminal;
	theTI : CM_TrackedItem;
begin

	theTerminal := self.myTerminal;
	//epr par 15648 14/1/2008
	theTI := _controller.myTrackedItem;
	if theTI &lt;&gt; null then
		if  self = _controller.myOriginatingLocation then
			app.myEventManager.createSingleObjInfoNoteEvt(self.myVoyage, theTerminal.getTerminalEvent(EVENT_TI_MOVE_FROM_LOCATION),theTI);
		elseif self = _controller.myToPrimaryLocation then
			app.myEventManager.createSingleObjInfoNoteEvt(self.myVoyage, theTerminal.getTerminalEvent(EVENT_TI_MOVE_TO_LOCATION),theTI);
		endif;
		app.myEventManager.createSingleObjInfoNoteEvt(self.myVoyage, theTerminal.getTerminalEvent(EVENT_TI_MOVE),self);
	endif;

	app.myEventManager.createSingleObjInfoNoteEvt(self.myVoyage,  theTerminal.getTerminalEvent(EVENT_UPDATE_VOYAGE_AREA), self);
	
end;</source>
        <Parameter name="_controller" type="CMIF_MoveController"/>
    </JadeMethod>
    <JadeMethod name="getExtraInfo" id="1b4e743f-3c4c-46d6-9c3b-59e0528f9f12">
        <source>getExtraInfo(_dataContainer: CM_DataContainer);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 27/08/2015	cnwdap1		Initial creation PAR #36766 CCMS SFW 1334 Bulk Graphical Representation
// 27/07/2016	cnwmp6		Embellish macro information grid
//
vars
	block : CM_DataContainerBlock;
	passport : CM_Passport;
	allBlocksArray : CM_DataContainerBlockArray;
	quantityTotal : Integer;
	qdQuantityTotal : Integer;
	pdQuantityTotal : Integer;
	lineQuantity: Integer;
	idx, idxSt, idxEnd,
	idxQ, idxP: Integer;
	cargoSort, lastCargoSort : String;
	sohCargoS,
	sohCargoP,
	sohCargoQ: StringArray;
	sohVolumeS,
	sohVolumeP,
	sohVolumeQ: DecimalArray;
	sohWeightS,
	sohWeightP,
	sohWeightQ: DecimalArray;
	sohItemS,
	sohItemP,
	sohItemQ: IntegerArray;
	sohQuantityS,
	sohQuantityP,
	sohQuantityQ: IntegerArray;
	totVolume,
	totVolQueue,
	totVolPlan,
	lineVolume: Decimal[16,4];
	totWeight,
	totWgtQueue,
	totWgtPlan,
	lineWeight: Decimal[14,4];
	failedDAC :CM_DataAccessController;
	sortTIs,
	sortTIsQueue,
	sortTIsPlan: CM_TIByCargoTypeDict;
	allTIs,
	allTIsQueue,
	allTIsPlan: CM_TIArray;
	ti : CM_TrackedItem;

begin
	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getErrorString(CM_Location), DC_Label, 1, null);
	block.addNewItem(self.getFullId(), DC_Data, 3, null);

	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getErrorString(Maximum_Weight), DC_Label, 3, null);
	block.addNewItem(self.maxWeight.String, DC_Data, 3, null);
	
	//07 Feb 2017	NDL	TFS 3216
	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getErrorString(Maximum_Height), DC_Label, 3, null);
	block.addNewItem(self.maxHeight.String, DC_Data, 3, null);

	create allBlocksArray transient;
	
	passport := app.myPassport;
	
	if (not self.canUserAccessSelf(null, failedDAC, passport)) then
		block := _dataContainer.addNewBlock;
		block.addNewItem(app.getErrorString(CM_You_Do_Not_Have_Access), DC_Header, 1, null);
		return;
	endif;
		
	create sortTIs transient;
	create sortTIsPlan transient;
	create sortTIsQueue transient;
	create allTIs transient;
	create allTIsPlan transient;
	create allTIsQueue transient;
	create sohVolumeS transient; 
	sohVolumeS[10] := 0;
	create sohWeightS transient; 
	sohWeightS[10] := 0;
	create sohCargoS transient; 
	sohCargoS[10] := "";
	create sohItemS transient; 
	sohItemS[10] := 0;
	create sohQuantityS transient; 
	sohQuantityS[10] := 0;
	create sohVolumeP transient; 
	sohVolumeP[10] := 0;
	create sohWeightP transient; 
	sohWeightP[10] := 0;
	create sohCargoP transient; 
	sohCargoP[10] := "";
	create sohItemP transient; 
	sohItemP[10] := 0;
	create sohQuantityP transient; 
	sohQuantityP[10] := 0;
	create sohVolumeQ transient; 
	sohVolumeQ[10] := 0;
	create sohWeightQ transient; 
	sohWeightQ[10] := 0;
	create sohCargoQ transient; 
	sohCargoQ[10] := "";
	create sohItemQ transient; 
	sohItemQ[10] := 0;
	create sohQuantityQ transient; 
	sohQuantityQ[10] := 0;

	self.getTIs(allTIs, REAL_MODE, true);
	self.getTIs(allTIsPlan, PLANNING_MODE, true);
	self.getTIs(allTIsQueue, QUEUE_MODE, true);
	allTIs.copy(sortTIs);
	allTIsPlan.copy(sortTIsPlan);
	allTIsQueue.copy(sortTIsQueue);

	self.getTotalsByMode(REAL_MODE, totVolume, totWeight, quantityTotal);
	self.getTotalsByMode(QUEUE_MODE, totVolQueue, totWgtQueue, qdQuantityTotal);
	self.getTotalsByMode(PLANNING_MODE, totVolPlan, totWgtPlan, pdQuantityTotal);
	qdQuantityTotal := self.getNumTIs(QUEUE_MODE);
	pdQuantityTotal := self.getNumTIs(PLANNING_MODE);
	idx := 1;
	cargoSort := "";
	
	foreach ti in sortTIs discreteLock do
		//epr par 35905 26/3/15
		cargoSort := ti.getProductOrISODescr();
		if lastCargoSort &lt;&gt; "" and cargoSort &lt;&gt; lastCargoSort then
			idx := idx + 1;
		endif;
		//epr par 35905 26/3/15
		if sohCargoS.size &lt; idx then
			sohCargoS.add(null);
			sohVolumeS.add(null);
			sohWeightS.add(null);
			sohQuantityS.add(null);
			sohItemS.add(null);
		endif;
		
		if sohCargoS[idx] = "" then
			sohCargoS[idx] := cargoSort;
		endif;
		lastCargoSort := cargoSort;
		sohVolumeS[idx] := sohVolumeS[idx] + ti.totalVolume;
		sohWeightS[idx] := sohWeightS[idx] + ti.totalWeight;
		sohQuantityS[idx] := sohQuantityS[idx] + ti.totalQuantity;
		sohItemS[idx] := sohItemS[idx] + 1;
	endforeach;	
	
	idx := 1;
	cargoSort := "";
	lastCargoSort := "";
	foreach ti in sortTIsPlan discreteLock do
		//epr par 35905 26/3/15
		cargoSort := ti.getProductOrISODescr();
		if lastCargoSort &lt;&gt; "" and cargoSort &lt;&gt; lastCargoSort then
			idx := idx + 1;
		endif;
		//epr par 35905 26/3/15
		if sohCargoP.size &lt; idx then
			sohCargoP.add(null);
			sohVolumeP.add(null);
			sohWeightP.add(null);
			sohQuantityP.add(null);
			sohItemP.add(null);
		endif;
		
		if sohCargoP[idx] = "" then
			sohCargoP[idx] := cargoSort;
		endif;
		lastCargoSort := cargoSort;
		sohVolumeP[idx] := sohVolumeP[idx] + ti.totalVolume;
		sohWeightP[idx] := sohWeightP[idx] + ti.totalWeight;
		sohQuantityP[idx] := sohQuantityP[idx] + ti.totalQuantity;
		sohItemP[idx] := sohItemP[idx] + 1;
	endforeach;	
	
	idx := 1;
	cargoSort := "";
	lastCargoSort := "";
	foreach ti in sortTIsQueue discreteLock do
		//epr par 35905 26/3/15
		cargoSort := ti.getProductOrISODescr();
		if lastCargoSort &lt;&gt; "" and cargoSort &lt;&gt; lastCargoSort then
			idx := idx + 1;
		endif;
		//epr par 35905 26/3/15
		if sohCargoQ.size &lt; idx then
			sohCargoQ.add(null);
			sohVolumeQ.add(null);
			sohWeightQ.add(null);
			sohQuantityQ.add(null);
			sohItemQ.add(null);
		endif;
		
		if sohCargoQ[idx] = "" then
			sohCargoQ[idx] := cargoSort;
		endif;
		lastCargoSort := cargoSort;
		sohVolumeQ[idx] := sohVolumeQ[idx] + ti.totalVolume;
		sohWeightQ[idx] := sohWeightQ[idx] + ti.totalWeight;
		sohQuantityQ[idx] := sohQuantityQ[idx] + ti.totalQuantity;
		sohItemQ[idx] := sohItemQ[idx] + 1;
	endforeach;	

	// render the actual items
	if sohCargoS.size &gt; 0 then
		idxEnd := sohCargoS.size;
		idxSt := 1;
		idxQ := 1;
		idxP := 1;
		foreach idx  in idxSt to idxEnd discreteLock do
			if sohCargoS[idx] = "" then
				break;
			endif;
			create block transient;
			allBlocksArray.add(block);
			lineQuantity := 0;
			lineVolume := 0;
			lineWeight := 0;
			block.addNewItem(sohCargoS[idx], DC_Data, 1, null);
			if sohQuantityS[idx] = 0 then
				block.addNewItem("", DC_Data, 1, null);
			else
				block.addNewItem(sohQuantityS[idx].String, DC_Data, 1, null); // ACTUAL
				lineQuantity := sohQuantityS[idx];
			endif;
			if sohVolumeS[idx] = 0 then
				block.addNewItem("", DC_Data, 1, null);
			else
				block.addNewItem(app.getVolumeForDefaultDisplay(sohVolumeS[idx]), DC_Data, 1, null);
				lineVolume := sohVolumeS[idx];
			endif;
			if sohWeightS[idx] = 0 then
				block.addNewItem("", DC_Data, 1, null);
			else
				block.addNewItem(app.getWeightForDefaultDisplay(sohWeightS[idx]), DC_Data, 1, null);
				lineWeight := sohWeightS[idx];
			endif;
			// render any queued for this actual item
			if sohCargoS[idx] = sohCargoQ[idxQ] then
				if sohQuantityQ[idxQ] = 0 then
					block.addNewItem("", DC_Data, 1, null);
				else
					block.addNewItem(sohQuantityQ[idxQ].String, DC_Data, 1, null);
					lineQuantity := lineQuantity + sohQuantityQ[idxQ];
				endif;
				if sohVolumeQ[idxQ] = 0 then
					block.addNewItem("", DC_Data, 1, null);
				else
					block.addNewItem(app.getVolumeForDefaultDisplay(sohVolumeQ[idxQ]), DC_Data, 1, null);
					lineVolume := lineVolume + sohVolumeQ[idxQ];
				endif;
				if sohWeightQ[idxQ] = 0 then
					block.addNewItem("", DC_Data, 1, null);
				else
					block.addNewItem(app.getWeightForDefaultDisplay(sohWeightQ[idxQ]), DC_Data, 1, null);
					lineWeight := lineWeight + sohWeightQ[idxQ];
				endif;
				idxQ := idxQ + 1;
			else
				block.addNewItem("", DC_Data, 1, null);
				block.addNewItem("", DC_Data, 1, null);
				block.addNewItem("", DC_Data, 1, null);
			endif;
			// render any planned for this actual item
			if sohCargoS[idx] = sohCargoP[idxP] then
				if sohQuantityP[idxP] = 0 then
					block.addNewItem("", DC_Data, 1, null);
				else
					block.addNewItem(sohQuantityP[idxP].String, DC_Data, 1, null);
					lineQuantity := lineQuantity + sohQuantityP[idxP];
				endif;
				if sohVolumeP[idxP] = 0 then
					block.addNewItem("", DC_Data, 1, null);
				else
					block.addNewItem(app.getVolumeForDefaultDisplay(sohVolumeP[idxP]), DC_Data, 1, null);
					lineVolume := lineVolume + sohVolumeP[idxP];
				endif;
				if sohWeightP[idxP] = 0 then
					block.addNewItem("", DC_Data, 1, null);
				else
					block.addNewItem(app.getWeightForDefaultDisplay(sohWeightP[idxP]), DC_Data, 1, null);
					lineWeight := lineWeight + sohWeightP[idxP];
				endif;
				idxP := idxP + 1;
			else
				block.addNewItem("", DC_Data, 1, null);
				block.addNewItem("", DC_Data, 1, null);
				block.addNewItem("", DC_Data, 1, null);
			endif;
			// totals
			if lineQuantity  = 0 then
				block.addNewItem("", DC_Data, 1, null);
			else
				block.addNewItem(lineQuantity.cnEcNumberFormat(), DC_Data, 1, null);
			endif;
			if lineVolume = 0 then
				block.addNewItem("", DC_Data, 1, null);
			else
				block.addNewItem(app.getVolumeForDefaultDisplay(lineVolume), DC_Data, 1, null);
			endif;
			if lineWeight = 0 then
				block.addNewItem("", DC_Data, 1, null);
			else
				block.addNewItem(app.getWeightForDefaultDisplay(lineWeight), DC_Data, 1, null);
			endif;
		endforeach;
		
		// render the remaining queued
		foreach idx in idxQ to sohCargoQ.size discreteLock do
			if sohCargoQ[idx] = "" then
				break;
			endif;
			create block transient;
			allBlocksArray.add(block);
			lineQuantity := 0;
			lineVolume := 0;
			lineWeight := 0;
			block.addNewItem(sohCargoQ[idx], DC_Data, 1, null);
			block.addNewItem("", DC_Data, 1, null);
			block.addNewItem("", DC_Data, 1, null);
			block.addNewItem("", DC_Data, 1, null);
			if sohQuantityQ[idx] = 0 then
				block.addNewItem("", DC_Data, 1, null);
			else
				block.addNewItem(sohQuantityQ[idx].String, DC_Data, 1, null);
				lineQuantity := sohQuantityQ[idx];
			endif;
			if sohVolumeQ[idx] = 0 then
				block.addNewItem("", DC_Data, 1, null);
			else
				block.addNewItem(app.getVolumeForDefaultDisplay(sohVolumeQ[idx]), DC_Data, 1, null);
				lineVolume := sohVolumeQ[idx];
			endif;
			if sohWeightQ[idx] = 0 then
				block.addNewItem("", DC_Data, 1, null);
			else
				block.addNewItem(app.getWeightForDefaultDisplay(sohWeightQ[idx]), DC_Data, 1, null);
				lineWeight := sohWeightQ[idx];
			endif;
			// render any planned for this queued item
			if sohCargoQ[idx] = sohCargoP[idxP] then
				if sohQuantityP[idxP] = 0 then
					block.addNewItem("", DC_Data, 1, null);
				else
					block.addNewItem(sohQuantityP[idxP].String, DC_Data, 1, null);
					lineQuantity := lineQuantity + sohQuantityP[idxP];
				endif;
				if sohVolumeP[idxP] = 0 then
					block.addNewItem("", DC_Data, 1, null);
				else
					block.addNewItem(app.getVolumeForDefaultDisplay(sohVolumeP[idxP]), DC_Data, 1, null);
					lineVolume := lineVolume + sohVolumeP[idxP];
				endif;
				if sohWeightP[idxP] = 0 then
					block.addNewItem("", DC_Data, 1, null);
				else
					block.addNewItem(app.getWeightForDefaultDisplay(sohWeightP[idxP]), DC_Data, 1, null);
					lineWeight := lineWeight + sohWeightP[idxP];
				endif;
				idxP := idxP + 1;
			else
				block.addNewItem("", DC_Data, 1, null);
				block.addNewItem("", DC_Data, 1, null);
				block.addNewItem("", DC_Data, 1, null);
			endif;
			// totals
			if lineQuantity  = 0 then
				block.addNewItem("", DC_Data, 1, null);
			else
				block.addNewItem(lineQuantity.cnEcNumberFormat(), DC_Data, 1, null);
			endif;
			if lineVolume = 0 then
				block.addNewItem("", DC_Data, 1, null);
			else
				block.addNewItem(app.getVolumeForDefaultDisplay(lineVolume), DC_Data, 1, null);
			endif;
			if lineWeight = 0 then
				block.addNewItem("", DC_Data, 1, null);
			else
				block.addNewItem(app.getWeightForDefaultDisplay(lineWeight), DC_Data, 1, null);
			endif;
		endforeach;

		// render the remaining planned
		foreach idx in idxP to sohCargoP.size discreteLock do
			if sohCargoP[idx] = "" then
				break;
			endif;
			create block transient;
			allBlocksArray.add(block);
			lineQuantity := 0;
			lineVolume := 0;
			lineWeight := 0;
			block.addNewItem(sohCargoP[idx], DC_Data, 1, null);
			block.addNewItem("", DC_Data, 1, null);
			block.addNewItem("", DC_Data, 1, null);
			block.addNewItem("", DC_Data, 1, null);
			block.addNewItem("", DC_Data, 1, null);
			block.addNewItem("", DC_Data, 1, null);
			block.addNewItem("", DC_Data, 1, null);
			if sohQuantityP[idx] = 0 then
				block.addNewItem("", DC_Data, 1, null);
			else
				block.addNewItem(sohQuantityP[idx].String, DC_Data, 1, null);
				lineQuantity := sohQuantityP[idx];
			endif;
			if sohVolumeP[idx] = 0 then
				block.addNewItem("", DC_Data, 1, null);
			else
				block.addNewItem(app.getVolumeForDefaultDisplay(sohVolumeP[idx]), DC_Data, 1, null);
				lineVolume := sohVolumeP[idx];
			endif;
			if sohWeightP[idx] = 0 then
				block.addNewItem("", DC_Data, 1, null);
			else
				block.addNewItem(app.getWeightForDefaultDisplay(sohWeightP[idx]), DC_Data, 1, null);
				lineWeight := sohWeightP[idx];
			endif;
			// totals
			if lineQuantity  = 0 then
				block.addNewItem("", DC_Data, 1, null);
			else
				block.addNewItem(lineQuantity.cnEcNumberFormat(), DC_Data, 1, null);
			endif;
			if lineVolume = 0 then
				block.addNewItem("", DC_Data, 1, null);
			else
				block.addNewItem(app.getVolumeForDefaultDisplay(lineVolume), DC_Data, 1, null);
			endif;
			if lineWeight = 0 then
				block.addNewItem("", DC_Data, 1, null);
			else
				block.addNewItem(app.getWeightForDefaultDisplay(lineWeight), DC_Data, 1, null);
			endif;
		endforeach;
	endif;
		
	block := _dataContainer.addNewBlock;
	block.addNewItem("", DC_LabelHeader, 1, null);
	block.addNewItem(app.getErrorString(Actual), DC_LabelHeader, 3, null);
	block.addNewItem(app.getErrorString(Queued), DC_LabelHeader, 3, null);
	block.addNewItem(app.getErrorString(Planned), DC_LabelHeader, 3, null);
	block.addNewItem(app.getErrorString(Total), DC_LabelHeader, 3, null);
	block := _dataContainer.addNewBlock;
	block.addNewItem(null, DC_LabelHeader, 1, null);
	block.addNewItem(app.getErrorString(CM_Quantity), DC_LabelHeader, 1, null);
	block.addNewItem(app.getErrorString(CM_Volume), DC_LabelHeader, 1, null);
	block.addNewItem(app.getErrorString(CM_Weight), DC_LabelHeader, 1, null);
	block.addNewItem(app.getErrorString(CM_Quantity), DC_LabelHeader, 1, null);
	block.addNewItem(app.getErrorString(CM_Volume), DC_LabelHeader, 1, null);
	block.addNewItem(app.getErrorString(CM_Weight), DC_LabelHeader, 1, null);
	block.addNewItem(app.getErrorString(CM_Quantity), DC_LabelHeader, 1, null);
	block.addNewItem(app.getErrorString(CM_Volume), DC_LabelHeader, 1, null);
	block.addNewItem(app.getErrorString(CM_Weight), DC_LabelHeader, 1, null);
	block.addNewItem(app.getErrorString(CM_Quantity), DC_LabelHeader, 1, null);
	block.addNewItem(app.getErrorString(CM_Volume), DC_LabelHeader, 1, null);
	block.addNewItem(app.getErrorString(CM_Weight), DC_LabelHeader, 1, null);
	
	block := _dataContainer.addNewBlock();
	block.addNewItem(app.getErrorString(Total).toUpper &amp; "   ", DC_Data, 1, null);
	if quantityTotal = 0 then
		block.addNewItem("", DC_Data, 1, null);
	else
		block.addNewItem(quantityTotal.cnEcNumberFormat(), DC_Data, 1, null);
	endif;
	if totVolume = 0 then
		block.addNewItem("", DC_Data, 1, null);
	else
		block.addNewItem(app.getVolumeForDefaultDisplay(totVolume), DC_Data, 1, null);
	endif;
	if totalWeight = 0 then
		block.addNewItem("", DC_Data, 1, null);
	else
		block.addNewItem(app.getWeightForDefaultDisplay(totalWeight), DC_Data, 1, null);
	endif;
	if qdQuantityTotal = 0 then
		block.addNewItem("", DC_Data, 1, null);
	else
		block.addNewItem(qdQuantityTotal.cnEcNumberFormat(), DC_Data, 1, null);
	endif;
	if totVolQueue = 0 then
		block.addNewItem("", DC_Data, 1, null);
	else
		block.addNewItem(app.getVolumeForDefaultDisplay(totVolQueue), DC_Data, 1, null);
	endif;
	if totWgtQueue = 0 then
		block.addNewItem("", DC_Data, 1, null);
	else
		block.addNewItem(app.getWeightForDefaultDisplay(totWgtQueue), DC_Data, 1, null);
	endif;
	if pdQuantityTotal = 0 then
		block.addNewItem("", DC_Data, 1, null);
	else
		block.addNewItem(pdQuantityTotal.cnEcNumberFormat(), DC_Data, 1, null);
	endif;
	if totVolPlan = 0 then
		block.addNewItem("", DC_Data, 1, null);
	else
		block.addNewItem(app.getVolumeForDefaultDisplay(totVolPlan), DC_Data, 1, null);
	endif;
	if totWgtPlan = 0 then
		block.addNewItem("", DC_Data, 1, null);
	else
		block.addNewItem(app.getWeightForDefaultDisplay(totWgtPlan), DC_Data, 1, null);
	endif;
	if quantityTotal + qdQuantityTotal + pdQuantityTotal = 0 then
		block.addNewItem("", DC_Data, 1, null);
	else
		block.addNewItem((quantityTotal + qdQuantityTotal + pdQuantityTotal).cnEcNumberFormat(), DC_Data, 1, null);
	endif;
	if totalVolume + totVolQueue + totVolPlan = 0 then
		block.addNewItem("", DC_Data, 1, null);
	else
		block.addNewItem(app.getVolumeForDefaultDisplay(totalVolume + totVolQueue + totVolPlan), DC_Data, 1, null);
	endif;
	if totalWeight + totWgtQueue + totWgtPlan = 0 then
		block.addNewItem("", DC_Data, 1, null);
	else
		block.addNewItem(app.getWeightForDefaultDisplay(totalWeight + totWgtQueue + totWgtPlan), DC_Data, 1, null);
	endif;
	
	if app.isSpecial() then
		block := _dataContainer.addNewBlock();
		block.addNewItem("GC Controller", DC_MoreInfo, 2, self);
		block.addNewItem(self.String, DC_Data, 2, self);
		block.addNewItem("Voyage", DC_MoreInfo, 2, self.myGCVoyage.myVoyage);
		block.addNewItem(self.myGCVoyage.myVoyage.String, DC_Data, 2, self.myGCVoyage.myVoyage);
	endif;
	
	// Add the spec details after the summary details.
	_dataContainer.addMultipleBlocks(allBlocksArray);

epilog
	delete allBlocksArray;
	delete sortTIs;
	delete sortTIsPlan;
	delete sortTIsQueue;
	delete sohVolumeS;
	delete sohWeightS;
	delete sohCargoS;
	delete sohItemS;
	delete sohQuantityS;
	delete sohVolumeP;
	delete sohWeightP;
	delete sohCargoP;
	delete sohItemP;
	delete sohQuantityP;
	delete sohVolumeQ;
	delete sohWeightQ;
	delete sohCargoQ;
	delete sohItemQ;
	delete sohQuantityQ;
	delete allTIs;
	delete allTIsPlan;
	delete allTIsQueue;
end;</source>
        <Parameter name="_dataContainer" type="CM_DataContainer"/>
    </JadeMethod>
    <JadeMethod name="getFullId" id="8cbe98a6-e5e3-4c53-b824-b2b35775ca95">
        <source>getFullId(): String;
//--------------------------------------------------
// Created:	08 February 2006 By: cnwgd1
// 08 JAN 2015 cnwma1 PAR #35491 Non plan non work string to long error
//--------------------------------------------------
vars
	voyCode : String;
	returnStr : String;
begin
	if self.myVoyage &lt;&gt; null then
		voyCode := self.myVoyage.code;
	endif;
	
//	return voyCode &amp; '/' &amp; self.hatch.String &amp; '/' &amp; app.vesselPlaceEnumToStr(self.place);

	//11 Jul 2013	NDL	Par 31965
	returnStr := voyCode &amp; ' ' &amp; self.hatch.padLeadingWith('0',2) &amp; self.place.padLeadingWith('0',2);
	if self.name.trimBlanks &lt;&gt; null then
		returnStr := returnStr &amp; ' ' &amp; self.name;
	endif;
	return returnStr;
	
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
