//--------------------------------------------------
// Created:	20 October 2003 By: cnwgd1
//--------------------------------------------------
vars
	prof 		:  JadeProfiler;
	startTM		:  	Decimal[19,0];
begin
	if process.isMohamed then
		app.myRoot.startJadeProfiler(prof,method.getNiceName() ,20,true,'MA',startTM);
	endif;
	self.doDischarge(false, false, null, null); //cnwrd1 par 28343 14.10.2011
	app.myRoot.stopJadeProfiler(prof,startTM);
end;</source>
