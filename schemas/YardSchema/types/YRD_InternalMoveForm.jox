        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doDeleteSeletedTIs" id="eae226c0-476a-467b-aa10-128a4841a36d">
        <updating/>
        <source>doDeleteSeletedTIs() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 September 2009	cnwrd1	Initial creation

*/

vars
	aTI 		: CM_TrackedItem;
	lstCnt		: Integer;
	cnt			: Integer;
begin

	lstCnt := self.lstSelectedTIs.listCount();
	while cnt &lt; lstCnt do
		cnt := cnt+1;			
		if self.lstSelectedTIs.itemSelected[cnt] = true then
			aTI :=  self.lstSelectedTIs.itemObject[cnt].CM_TrackedItem;				
			self.lstSelectedTIs.removeItem(cnt);
			self.allSelectedTIs.remove(aTI);
			lstCnt := lstCnt-1;
			cnt := cnt -1;
		endif;	
	endwhile;
	
epilog

end;</source>
    </JadeMethod>
