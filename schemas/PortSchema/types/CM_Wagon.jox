    <JadeMethod name="getNumTEU" id="59822aa5-bd38-4d23-a55c-32f054344f56">
        <source>getNumTEU(isReceived : Boolean) : Real;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
13 July 2009	cnwmd1	Initial creation

*/

vars
	ti : CM_TrackedItem;
	tis : CM_TIArray;
	teus : Real;
begin
	create tis transient;
	self.getAllTrackedItems(isReceived, tis, true);
	if tis.isEmpty() then
		self.getAllTrackedItems(isReceived, tis, false);
	endif;
	
	foreach ti in tis do
		teus := teus + ti.getNumTEU();
	endforeach;
	
	return teus;
epilog
	delete tis;
end;</source>
        <Parameter name="isReceived" type="Boolean"/>
        <ReturnType type="Real"/>
    </JadeMethod>
