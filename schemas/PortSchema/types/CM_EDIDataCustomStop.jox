    <JadeMethod name="shouldAuditProperty" id="87fc18c1-bcde-44f3-9b25-6a16de4614ce">
        <source>shouldAuditProperty(_rootClass: Class; _property: Property): Boolean protected;
//
// 11 Aug 2016	cnwrs1	Par 38117 make deleted EDI for finable
//
vars
	propName : String;
begin
	if _property = null then
		return false;
	endif;
	propName := _property.name;
	if propName = CM_EDIDataCustomStop::allUnprocCustByIDMsgNum.name or
	   propName = CM_EDIDataCustomStop::allUnprocCustByRespID.name or
	   propName = CM_EDIDataCustomStop::updatedTime.name then
		return false;
	endif;
	return inheritMethod(_rootClass, _property);
end;
</source>
        <access>protected</access>
        <Parameter name="_rootClass" type="Class"/>
        <Parameter name="_property" type="Property"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
