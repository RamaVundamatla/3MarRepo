<Class name="CM_AutoTaskClearRemote" id="f778fb5a-cfe8-4e9b-b80d-50eec13dd146">
    <superclass name="CM_AutoTask"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>&lt;display&gt;Clear Remote Data&lt;/display&gt;</text>
    <DbClassMap file="backgroundprocess"/>
    <PrimAttribute name="autoRemoteTypes" id="d415b02b-dbc9-4c84-bba5-2b79a3a16e61">
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="numberOfDaysOld" id="2cf736bd-dedd-408d-a2a9-e1339605219b">
        <embedded/>
        <type name="Integer"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="getEntryTableViewName" id="bea2f48f-a620-45a1-8b3d-228cf30a4bd0">
        <source>getEntryTableViewName(): String;

vars

begin
	return 'bgpAutoViewClearRemotes';
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getValueForRow" id="70f529aa-8899-405d-817f-0712f71fc488">
        <source>getValueForRow(_rowName: String; _obj : Object output): Any;

vars

begin	

	if _rowName = ETRow_BgpAutoRemoteTypes then
		return self.autoRemoteTypes;
	elseif _rowName = ETRow_BgpAutoNumberOfDaysOld then
		return self.numberOfDaysOld;
	endif;
	return inheritMethod(_rowName, _obj);
end;</source>
        <Parameter name="_rowName" type="String"/>
        <Parameter name="_obj" type="Object" usage="output"/>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="5008a25c-1922-4e45-9857-1042123761cc">
        <updating/>
        <source>setForCreate(_pxyAutoTask: CM_AutoTaskClearRemote) updating;

vars

begin
	inheritMethod(_pxyAutoTask);
	self.requestClassName 	:= BGP_ClearRemotesRequest.name;
	self.autoRemoteTypes 	:= _pxyAutoTask.autoRemoteTypes;
	self.numberOfDaysOld	:= _pxyAutoTask.numberOfDaysOld;
end;</source>
        <Parameter name="_pxyAutoTask" type="CM_AutoTaskClearRemote"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="ba2b9ffc-440f-4d3a-a93f-be79a1a8122e">
        <updating/>
        <source>setForUpdate(_pxyAutoTask: CM_AutoTaskClearRemote) updating;

vars

begin
	inheritMethod(_pxyAutoTask);
	self.autoRemoteTypes 	:= _pxyAutoTask.autoRemoteTypes;
	self.numberOfDaysOld	:= _pxyAutoTask.numberOfDaysOld;
end;</source>
        <Parameter name="_pxyAutoTask" type="CM_AutoTaskClearRemote"/>
    </JadeMethod>
    <JadeMethod name="setValueForRow" id="8142585d-a0d7-49fb-a220-bbe0a195f96e">
        <updating/>
        <source>setValueForRow(_rowName: String; _value: Any) updating;

vars

begin
	if _rowName = ETRow_BgpAutoRemoteTypes then
		self.autoRemoteTypes := _value.String;
	elseif _rowName = ETRow_BgpAutoNumberOfDaysOld then
		self.numberOfDaysOld := _value.Integer;
	else
		inheritMethod(_rowName, _value);
	endif;
end;</source>
        <Parameter name="_rowName" type="String"/>
        <Parameter name="_value" type="Any"/>
    </JadeMethod>
    <JadeMethod name="validate" id="49cd2707-5f4a-44cb-9ccd-5dd436a37a60">
        <source>validate();

vars

begin

	inheritMethod();
	if self.autoRemoteTypes = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Auto Remote Types', null, null);
		app.raiseCMException(Input_required_field_autoRmtTy, null, null); // cnwdb2	PAR 35364

		
	endif;
	
	if self.numberOfDaysOld = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Number of Days Old', null, null);
		app.raiseCMException(Input_required_field_numDysOld, null, null);
		
	endif;
	
end;

</source>
    </JadeMethod>
</Class>
