    <JadeMethod name="setRetroFiledsInvisible" id="821356f3-5199-46b8-bc2c-2f0f2578b0e5">
        <source>setRetroFiledsInvisible();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 Apr 2025	navhl20 CR MTN-34493: MTN - Removing unnecessary codes from Work Order complete job screen methods.

*/

vars

begin
	self.lblRetrospectiveDate.visible := false;
	self.txtRetroDate.visible := false;
	self.txtRetroTime.visible := false;
	self.lblEffectiveDate.left := self.lblRetrospectiveDate.left;
	self.txtDate.left := self.txtRetroDate.left;
	self.txtTime.left := self.txtRetroTime.left;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setRowNumberAsFirst" id="25fc3d42-59b4-4436-bfb2-a23feb6df297">
        <updating/>
        <source>setRowNumberAsFirst(_theTable :CM_DataTable input) updating ;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 Jul 2024 navbs1 ChangeRequest 64884: EUP - Retrospective Jobs Grouped by Cargo Group

*/

vars
	theDef  : EntTableDef;
	theRow  : EntTableRow;
	col		: JadeTableColumn;
begin
if self.isCargoGrouping then

		theDef := app.myController.getEntTableDef(ETDef_LlHeadings);
		theRow := theDef.getEntTableRow(ETRow_RowNumber);
		
		// If we've already included it somewhere, remove it
		_theTable.removeColumnByEntRowName(ETRow_RowNumber);
		
		// Now add '#' as the first column
		_theTable.allTblDataEntRows.insert(1, theRow);
		_theTable.allTblDataColHeadings.insert(1, theRow.getHeading(_theTable.getMyTerminologyCargoBOLType, _theTable.getMyTerminologyTerminal, app.myCurrentLocale));
		_theTable.allTblDataColInputTypes.insert(1, Table.InputType_None);
		_theTable.allTblDataColPropertyNames.insert(1, theRow.name);
		
		_theTable.insertColumn(1);
		col := _theTable.accessColumn(1);
		col.inputType := Table.InputType_None;
		col.width := 0;	// Auto-resize
		_theTable.accessCell(_theTable.fixedRows, 1).text := _theTable.allTblDataColHeadings[1];
		endif;
		
epilog

end;</source>
        <Parameter name="_theTable" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setShtTodoForVASJobs" id="a0e8ce88-a18f-4d1f-bd76-84de287d1559">
        <source>setShtTodoForVASJobs();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 Nov 2024	navbs1	Initial creation Bug MTN-33403: EUP - New To Do Complete form is not available for non-cargo To Do Task jobs
04 Apr 2025	navhl20 CR MTN-34493: MTN - Removing unnecessary codes from Work Order complete job screen methods.
*/

vars
	toDoTask 	: CM_ToDoTask;
	str,lblStr  : String;
	wod 		: CM_WorkOrderToDoDtl;
begin
	if not self.isVASTodoWOJob then 
		return;
	endif;

	toDoTask := self.myWLE.CM_WOToDoWLE.myToDoTask;
	wod := toDoTask.myWODetailToDo;
		
	if toDoTask.isKindOf(CM_TrainToDoTask) then
		lblStr := app.getErrorString(Trains);
		str :=  wod.CM_WodToDoTrain.allTrainsActioned.listString(Comma,CM_Train::code.name);
	elseif toDoTask.isKindOf(CM_VBSToDoTask) then
		lblStr := app.getErrorString(Vehicle_bookings);
		str := wod.CM_WodToDoVBS.allVBSSlotsActioned.listString(Comma,CM_VehicleBookingTimeSlot::id.name);
	elseif toDoTask.isKindOf(CM_NonOpsToDoTask) then
		lblStr := app.getErrorString(Debtors);
		str := wod.CM_WodToDoNonOperational.allDebtorsActioned.listString(Comma,CM_Debtor::name.name);
	elseif toDoTask.isKindOf(CM_WagonToDoTask) then
		lblStr := app.getErrorString(Wagons);
		str := wod.CM_WodToDoWagon.allWagonsActioned.listString(Comma,CM_Wagon::id.name);
	elseif toDoTask.isKindOf(CM_VoyageToDoTask) then
		lblStr := app.getErrorString(Voyages);
		str := wod.CM_WodToDoVoyage.allVoyagesActioned.listString(Comma,CM_Voyage::code.name);
	elseif toDoTask.isKindOf(CM_VehicleVisitRecordToDoTask) then
		lblStr := app.getErrorString(Vehicle_visits);
		str := wod.CM_WodToDoVehicleVisit.allVehiclesActioned.listString(Comma,CM_VehicleVisitRecord::visitNumber.name);
	endif;
	
	self.lblEntity.visible := true;
	self.lblEntity.caption := lblStr;
	self.txtEntity.visible := true;
	self.txtEntity.text := str;
	
	self.tblToDo.visible := false;
	
	self.grpResource.top := self.tblToDo.top;
	self.tblResources.top := self.grpResource.top + self.grpResource.height+ 8;
	self.tblResources.height += self.tblToDo.height;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setTableDataFromOrganiser" id="83fe3865-a989-4e1d-a0e7-3273695d0e1c">
        <updating/>
        <source>setTableDataFromOrganiser(_theTable: CM_DataTable input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 Feb 2024 navhl20 ChangeRequest 62093: EUP | Retrospective Operations - [54177.030] - Road Receive
13 Feb 2024 navhl20 ChangeRequest 62418: EUP | Retrospective Operations - [54177.040] - Road Release
11 Mar 2024 navhl20 ChangeRequest 60097: EUP | Ship Operations in DD - [54176.060] - [Receive] Retrospective Operations
14 Mar 2024 navhl20 ChangeRequest 62861: EUP | Retrospective Operations - [54177.090] - UnPack
22 Jul 2024 navbs1 ChangeRequest 64884: EUP - Retrospective Jobs Grouped by Cargo Group
*/

vars
	
begin
	self.doRefresh();
	
	self.setRowNumberAsFirst(_theTable);		//22.07.2024 navbs1 #64884
	self.saveXMLStrForTblColumns(_theTable);
	
	if _theTable = self.tblAvailCargo then
		self.loadTblAvail();
	elseif _theTable = self.tblCompletedCargo then
		self.loadTblCompleted();
	elseif _theTable = self.tblParent then					//14.03.2024 navhl20 #62861
		self.loadTblParent();
	elseif _theTable = self.tblChild then					//14.03.2024 navhl20 #62861
		self.loadTblChild(self.tblParent.allSelectedObjects.first.CM_TrackedItem);
	elseif _theTable = self.tblUnpacked then				//14.03.2024 navhl20 #62861
		self.loadTblUnpacked();
	elseif _theTable = self.tblToDo then // ### TFS CR 62818 TASK 62821 15MAR2024 NAVAB1
		self.loadTbToDoTIs();
	endif;
epilog
	
end;</source>
        <Parameter name="_theTable" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setTblDataCount" id="ad25a38b-7f6d-4c07-8a81-6b1f6ea230d6">
        <source>setTblDataCount();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 Feb 2024 navhl20 ChangeRequest 62093: EUP | Retrospective Operations - [54177.030] - Road Receive
14 Feb 2024 navhl20 ChangeRequest 62418: EUP | Retrospective Operations - [54177.040] - Road Release
11 Mar 2024 navhl20 ChangeRequest 60097: EUP | Ship Operations in DD - [54176.060] - [Receive] Retrospective Operations
12 Mar 2024 navhl20 ChangeRequest 62734: EUP | Ship Operations in DD - [54176.060] - [Release] Retrospective Operations
14 Mar 2024 navhl20 ChangeRequest 62861: EUP | Retrospective Operations - [54177.090] - UnPack
18 Mar 2024 navhl20 ChangeRequest 62863: EUP | Retrospective Operations - [54177.100] - Pack
16 Apr 2024 navhl20 Bug 63708: EUP - 1086 Exception when selecting the Complete Job option for the Pack Jobs
22 Jul 2024 navbs1  ChangeRequest 64884: EUP - Retrospective Jobs Grouped by Cargo Group
12 Aug 2024	navnk30	Bug 65566: Table name is displayed wrongly on the Complete Job form for Ship Jobs
03 Oct 2024	navbs1	Bug MTN-19303: FR | 54177 - Retrospective Operations - part II
20 Feb 2025	jlizm1	MTN 34067 Not displaying Weight or volume for reserve detail in WO complete job
08 Aug 2025	jlizm1	MTN 35316 Pagination - Work Order Complete
13 Nov 2025	jlizm1	MTN 35927 Filter Issues on paginated forms
*/

vars
	resDetl,
	parentRes		: CM_ReserveSelection;
	resDtl			: CM_ReserveDetail;
	count,
	totalReq		: Integer;
	job				: CM_Job;
	woJob			: CM_Job;
	availTIs		: CM_TIArray;
	completeTIs		: CM_TISet;
	totalCompleted	: String;
	totalRequested 	: String;
	cargoType 		: CM_CargoType;
	trackByStr 		: String;
	woDtl			: CM_WorkOrderDtl;	
	relReq			: CM_BulkRelease;
begin
	job := self.myJob;
	
	self.lblSelectedCount.caption := self.lblSelectedCaption &amp; Space &amp; '0';	//MTN 35927
	
	if job.isKindOf(CM_WOPackJob) then 
		woDtl := job.myWODtl;
		if woDtl &lt;&gt; null then
			relReq := woDtl.CM_WodPack.myReleaseRequest;
		endif;
		if relReq &lt;&gt; null and relReq.releaseByType then						//16.04.2024 navhl20 #63708
			parentRes := relReq.allReserveDetails.first.CM_ReserveSelection;
		endif;
	endif;
	
	self.getResDtlFromJob(resDtl);
	if resDtl &lt;&gt; null and resDtl.isReserveSelection then
		resDetl := resDtl.CM_ReserveSelection;
	endif;
	
	if self.shtUnpack.visible then											//14.03.2024 navhl20 #62861
		self.setCaptionsForShtUnpack(parentRes,resDetl);					//04.04.2025 navhl20 #34493
		
	elseif not job.isRelease() then
		//Available Table Caption
		self.grpAvail.caption 		:= self.grpAvailCaption &amp; Space &amp; "[" &amp; (self.tblAvailCargo.getRowCount()).String &amp; "]" ;
		//Completed Table Caption
		self.grpCompleted.caption 	:= self.grpCompletedCaption &amp; Space &amp; "[" &amp; (self.tblCompletedCargo.getRowCount()).String &amp; "]" ;
		if self.isCargoGrouping then		//22.07.2024 navbs1 #64884
			//Available Table Caption
			self.grpAvail.caption := self.grpAvailCaption &amp; Space &amp; "[" &amp; self.getAvailableTis.size.String &amp; "]" ;
			//Completed Table Caption
			self.grpCompleted.caption 	:= self.grpCompletedCaption &amp; Space &amp; "[" &amp; self.getCompletedTis.size.String &amp; "]" ;
		endif;
	else
		availTIs 	:= self.getAvailableTis();
		completeTIs	:= self.getCompletedTis();
		count 		:= self.getTotalQuantity(availTIs);
		trackByStr 	:= app.getErrorString(CM_Quantity).trimBlanks;
		
		// if voyage release cargo by type
		if job.isVoyageWorkpointJob and woJob &lt;&gt; null and woJob.isKindOf(CM_WOReleaseCargoJob) and resDetl &lt;&gt; null then
			cargoType := resDetl.myCargoType;
			
			if cargoType &lt;&gt; null and cargoType.isTrackByVolume then
				trackByStr := app.getErrorString(CM_Volume).trimBlanks;
			elseif cargoType &lt;&gt; null and cargoType.isTrackByWeight then
				trackByStr := app.getErrorString(CM_Weight).trimBlanks;
			endif;
			
			totalCompleted := resDetl.getTotalReleasedDisplay;
			totalRequested := resDetl.getTotalRequestedDisplay;
		else
			totalCompleted := self.getTotalQuantity(completeTIs).String;
			totalRequested := job.getTotalQuantity().String;
		endif;
			
		//Available Table Caption
		self.grpAvail.caption 	:= self.grpAvailCaption &amp; Space &amp; "[" &amp; app.getErrorString(Items) &amp; " - " &amp; (availTIs.size).String &amp; "]" ;
		self.grpAvail.caption 	:= self.grpAvail.caption &amp; Space &amp; "[" &amp; app.getErrorString(CM_Quantity) &amp; " - " &amp; count.String &amp; "]";

		//Completed Table Caption
		self.grpCompleted.caption 	:= self.grpCompletedCaption &amp; Space &amp; "[" &amp; app.getErrorString(Items) &amp; " - " &amp; (completeTIs.size()).String &amp; "]" ;
		self.grpCompleted.caption 	:= self.grpCompleted.caption &amp; Space &amp; "[" &amp; trackByStr &amp; " - " &amp; totalCompleted &amp; Forward_Slash &amp; totalRequested &amp; "]" ;
	endif;
epilog
	delete availTIs;
	delete completeTIs;
end;</source>
    </JadeMethod>
    <JadeMethod name="setVisibilityAndCaptions" id="393ce11a-e76d-4b94-9441-2a6ca14f1315">
        <updating/>
        <source>setVisibilityAndCaptions(_relReq : CM_BulkRelease; _resDtl : CM_ReserveDetail)updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 Apr 2025	navhl20 CR MTN-34493: MTN - Removing unnecessary codes from Work Order complete job screen methods.

*/

vars
	job 	: CM_Job;
	woJob	: CM_Job;
begin
	job := self.myJob;
	
	if job.isVoyageWorkpointJob then
		woJob := job.CM_VoyageWorkPointJob.getMyWOJob();
	endif;
	
	if (woJob &lt;&gt; null and not woJob.isRelease) or (woJob = null and not job.isRelease) then
		if job.isVoyageWorkpointJob then
			self.grpAvail.caption 		:= TI_SITE_ONSHIP_str;
			self.grpAvailCaption		:= TI_SITE_ONSHIP_str;
			self.btnDoOperation.caption		:= app.getErrorString(Discharge);
			self.btnDoOperation.width		:= self.btnDoOperation.width + 10;
		endif;
		
		self.lblTerminalArea.visible	:= true;
		self.cmbTerminalArea.visible	:= true;
		self.lblSubArea.visible			:= true;
		self.cmbSubArea.visible			:= true;
		
		if job.isRail then						//17.06.2024 navhl20 #64602
			self.grpAvail.caption 		:= "On Wagon";
			self.grpAvailCaption		:= "On Wagon";
		endif;
		
	else
		self.grpAvail.caption 		:= TI_SITE_ONSITE_str;
		self.grpCompleted.caption	:= "On Vehicle";
		
		if job.isRail then						//17.06.2024 navhl20 #64602
			self.grpCompleted.caption 	:= "On Wagon";
		endif;
		
		self.grpCompletedCaption	:= self.grpCompleted.caption;
		self.btnDoOperation.caption	:= app.getErrorString(Load);
		self.grpAvailCaption		:= self.grpAvail.caption;
		
		if _relReq &lt;&gt; null then
			self.lblReleaseReq.visible	:= true;
			self.txtRelReq.visible		:= true;
			if _resDtl &lt;&gt; null and self.txtResDtl.text &lt;&gt; null then
				self.lblResDtl.visible		:= true;
				self.txtResDtl.visible		:= true;
			endif;
		endif;
		
		if job.isVoyageWorkpointJob then
			self.grpCompleted.caption 		:= TI_SITE_ONSHIP_str;
			self.grpCompletedCaption		:= TI_SITE_ONSHIP_str;
			self.grpLocation.visible		:= true;
			self.grpLocation.height			:= self.grpLocation.height - 20;
			self.grpCompleted.top			:= self.grpLocation.height + self.grpLocation.top + 5;
			self.grpCompleted.height		:= self.grpCompleted.height + 40;
			self.lblVoyLocation.visible		:= true;
			self.cmbVoyLocation.visible		:= true;
			self.btnDoOperation.top 		:= 20;
			self.buildCmbVoyLocation();
			
		else
			self.grpLocation.visible				:= false;
			self.btnDoOperation.parent				:= self.grpAvail;
			self.grpAvail.height					:= self.grpAvail.height + self.grpLocation.height + 5;
			self.btnDoOperation.top					:= 15;
			self.btnDoOperation.parentRightOffset	:= 125;
			self.btnDoOperation.parentAspect		:= 4;
		endif;
	endif;
epilog

end;</source>
        <Parameter name="_relReq" type="CM_BulkRelease"/>
        <Parameter name="_resDtl" type="CM_ReserveDetail"/>
    </JadeMethod>
    <JadeMethod name="setupBulkMode" id="bdb2e354-8d80-4b72-918c-aa1073908f78">
        <updating/>
        <source>setupBulkMode()updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 Apr 2025	navhl20 CR MTN-34493: MTN - Removing unnecessary codes from Work Order complete job screen methods.

*/

vars

begin
	self.chkHideCompleted.value 	:= true;
	self.chkHideCompleted.enabled 	:= false;
	self.chkHideCompleted_click(self.chkHideCompleted);
	self.chkCargoGroup.value 		:= true;
	self.lblSelectCount.visible 	:= true;
	self.txtSelectCount.visible 	:= true;
	self.chkSelectAll.visible 		:= true;
	if app.isSpecial() then
		self.grpShipDischarge.visible 		:= true;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="f019d152-d3a9-42fb-b584-b2e4adf676ef">
        <updating/>
        <source>setupForm() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 Feb 2024 navhl20 ChangeRequest 62093: EUP | Retrospective Operations - [54177.030] - Road Receive
13 Feb 2024 navhl20 ChangeRequest 62418: EUP | Retrospective Operations - [54177.040] - Road Release
02 Apr 2024 navhl20 ChangeRequest 63302: EUP - Bulk Moves in Retrospective Screen
22 Jul 2024 navbs1 ChangeRequest 64884: EUP - Retrospective Jobs Grouped by Cargo Group
20 Aug 2024 navhl20	ChangeRequest 65650: FR | 54177 - Retrospective Operations - Packing
27 Sep 2024	navnk30	Bug 66108: MTN | WO Job Complete Permissions
13 Nov 2025	jlizm1	MTN 35927 Filter Issues on paginated forms
*/

vars

begin
	inheritMethod();
	
	self.doPermissionCheck();		//27.09.2024 navnk30 #66108
	
	//Below method has form setup and cargo group setup
	self.setupFormDetails();														//04.04.2025 navhl20 #34493
	
	if self.isBulkMode then															//02.04.2024 navhl20 #63302
		self.setupBulkMode();														//04.04.2025 navhl20 #34493
	endif;
	
	self.txtOpTime.text				:= "2";
	self.populateDetails();
	
	self.chkHideCompleted_click(self.chkHideCompleted);								//13.02.2024 navhl20 #62418
	
	self.frmTableFilter.setupControl(self.tblAvailCargo, null); //05/06/2024	navkc1 CR 63736 Task 63770
	self.tblFilterParent.setupControl(self.tblParent, null);						//20.08.2024 navhl20 #65650
	self.tblFilterChild.setupControl(self.tblChild, null);							//20.08.2024 navhl20 #65650
	
	
	if app.myRoot.isPaginated then
		// MTN 35927
		// If paginated override table filtering to use version compatable with paginated tables
		self.frmTableFilter.setSkipControlFilter(true);
		self.frmTableFilter.setCallbackMethod(YRD_WorkOrderCompleteJob::filterTblAvailCargo.name);
		
		self.tblFilterParent.setSkipControlFilter(true);
		self.tblFilterParent.setCallbackMethod(YRD_WorkOrderCompleteJob::filterTblParent.name);
		
		self.tblFilterChild.setSkipControlFilter(true);
		self.tblFilterChild.setCallbackMethod(YRD_WorkOrderCompleteJob::filterTblChild.name);
	endif;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupFormDetails" id="46bbd7f5-7a98-4cea-9043-69597d607cc1">
        <updating/>
        <source>setupFormDetails()updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 Apr 2025	navhl20 CR MTN-34493: MTN - Removing unnecessary codes from Work Order complete job screen methods.

*/

vars

begin
	self.btnOk.width 				:= 130;
	self.btnOk.visible				:= false;
	self.btnOk.enabled				:= false;
	self.btnOk.left  				:= self.btnOk.left - 80;
	self.btnCancel.caption 			:= app.getErrorString(Close);
	self.grpAvailCaption			:= self.grpAvail.caption;
	self.grpCompletedCaption		:= self.grpCompleted.caption;
	self.lblSelectedCaption  		:= self.lblSelectedCount.caption;
	self.lblSelectedCount.visible 	:= true;
	self.lblSelectedCount.caption 	:= self.lblSelectedCaption &amp; Space &amp; '0';	
	self.allCargoGroupDetails.setMembership(CM_CargoGroupDetail);
	self.allCargoGroupDetails.addExternalKey(String, 30, false, false); //table name as key 
	self.allCargoGroupDetails.addExternalKey(CM_CargoGroup, null, false, false);
	self.allCargoGroupDetails.endKeys(false);
	self.chkCargoGrouping.visible 	:= false;
	self.btnExpandAll.visible		:=false;
	self.btnCollapseAll.visible		:=false;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupStartStop" id="90cdc124-76f8-40e9-8dbe-29d6a8227e3e">
        <source>setupStartStop();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 Apr 2025	navhl20 CR MTN-34493: MTN - Removing unnecessary codes from Work Order complete job screen methods.

*/

vars
	job 					: CM_Job;
	hasCompletedActivity	: Boolean;
begin
	job := self.myJob;
	self.btnStartStop.visible := true;
	
	if not self.btnPack.visible then
		self.btnStartStop.left := self.btnPack.left;
	endif;
	
	if job &lt;&gt; null then 
		if job.isRoadJob() then
			hasCompletedActivity := job.hasJobActivityType(VisitRecord_JobStart) or job.hasJobActivityType(VisitRecord_JobComplete);
		else
			hasCompletedActivity := job.hasJobActivityType(TRANS_TYPE_WOJOBSTART) or job.hasJobActivityType(TRANS_TYPE_WOJOBCOMPLETE);
		endif;
		
		if hasCompletedActivity then
			self.btnStartStop.enabled := false;
		endif;
	endif;
	
	if job.isKindOf(CM_WOToDoTaskJob) then
		self.btnStartStop.enabled := false;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="showCargoCheckForm" id="b29de8aa-14ee-4e26-8915-1c216e7c56be">
        <source>showCargoCheckForm(_ti : CM_TrackedItem; _context : Integer; _effectiveDT : TimeStamp);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 Feb 2024 navhl20 ChangeRequest 62525: EUP | Retrospective Operations - [54177.060] - Cargo &amp; Truck Checks
04 Apr 2025	navhl20 CR MTN-34493: MTN - Removing unnecessary codes from Work Order complete job screen methods.
*/

vars
	vvr 	: CM_VehicleVisitRecord;
	form 	: CMUI_CargoChecksForm;
begin
	if self.myJob.isRoadJob then
		vvr := self.myJob.CM_RoadJob.myVehicleVisit;
	endif;

	create form transient;
	
	if form = null then
		return;
	endif;
	
	form.setMyTerminal(self.myTerminal);
	form.setBaseDetails(_ti, null, _context);
	form.setMyVehicleVisit(vvr);
	form.setParentForm(self);
	form.setEffectiveDT(_effectiveDT);
	
	form.showModal;
epilog
	delete form;
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_context" type="Integer"/>
        <Parameter name="_effectiveDT" type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="showColumnOrganiser" id="b23005a0-cb2e-468c-ab0d-ba11b45677a3">
        <source>showColumnOrganiser();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 Feb 2024 navhl20 ChangeRequest 62093: EUP | Retrospective Operations - [54177.030] - Road Receive
13 Feb 2024 navhl20 ChangeRequest 62418: EUP | Retrospective Operations - [54177.040] - Road Release
11 Mar 2024 navhl20 ChangeRequest 60097: EUP | Ship Operations in DD - [54176.060] - [Receive] Retrospective Operations
14 Mar 2024 navhl20 ChangeRequest 62861: EUP | Retrospective Operations - [54177.090] - UnPack
*/

vars

begin
	if self.mnuColOrganiser.userObject = self.tblAvailCargo then
		self.tblAvailCargo.showColumnOrganiserFrm(self.myTerminal,null);
	elseif self.mnuColOrganiser.userObject = self.tblCompletedCargo then
		self.tblCompletedCargo.showColumnOrganiserFrm(self.myTerminal, null);
	elseif self.mnuColOrganiser.userObject = self.tblParent then					//14.03.2024 navhl20 #62861
		self.tblParent.showColumnOrganiserFrm(self.myTerminal, null);
	elseif self.mnuColOrganiser.userObject = self.tblChild then						//14.03.2024 navhl20 #62861
		self.tblChild.showColumnOrganiserFrm(self.myTerminal, null);
	elseif self.mnuColOrganiser.userObject = self.tblUnpacked then					//14.03.2024 navhl20 #62861
		self.tblUnpacked.showColumnOrganiserFrm(self.myTerminal, null);
	elseif self.mnuColOrganiser.userObject = self.tblToDo then // ### TFS CR 62818 TASK 62821 15MAR2024 NAVAB1
		self.tblToDo.showColumnOrganiserFrm(self.myTerminal, null);
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="showMoveAmountForm" id="6d9247b3-2864-441a-acd9-0cf6e8eb6808">
        <source>showMoveAmountForm(ti : CM_TrackedItem input; quantity : Integer io; _weight : Decimal io);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 Oct 2024	navbs1	Initial creation Bug MTN-19303: FR | 54177 - Retrospective Operations - part II
09 Dec 2024	navhl20 Bug MTN-33643: EUP - Partial move by weight is not working in Work Order Operation screen - Receive
*/

vars
	moveController : CMIF_MoveController;
begin
    create moveController transient;
	if app.myMoveController = null or not app.isValidObject(app.myMoveController) then
		app.myMoveController := moveController;
	endif;
	moveController.setMyTrackedItem(ti);
	moveController.setMoveMode(REAL_MODE);
	self.myAssistant.showMoveAmountForm(moveController);
	quantity := moveController.quantity;
	_weight	 := moveController.weight;							//09.12.2024 navhl20 #33643
epilog 
	if app.myMoveController &lt;&gt; moveController then				//09.10.2024 navbs1 #19303
		delete moveController;
	endif;
end;
</source>
        <Parameter name="ti" type="CM_TrackedItem" usage="input"/>
        <Parameter name="quantity" type="Integer" usage="io"/>
        <Parameter name="_weight" type="Decimal" usage="io"/>
    </JadeMethod>
    <JadeMethod name="showTruckCheckForm" id="f51aa5e1-1f09-48fb-abe6-1aacce8bfe0e">
        <source>showTruckCheckForm(): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 Feb 2024 navhl20 ChangeRequest 62525: EUP | Retrospective Operations - [54177.060] - Cargo &amp; Truck Checks
04 Apr 2025	navhl20 CR MTN-34493: MTN - Removing unnecessary codes from Work Order complete job screen methods.
*/

vars
	vvr : CM_VehicleVisitRecord;
begin
	if not self.myJob.isRoadJob then
		return false;
	endif;
	vvr := self.myJob.CM_RoadJob.myVehicleVisit;
	self.myAssistant.showSealObjectsForm(vvr);
epilog
	
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="tblAvailCargo_click" id="509f3f4c-2e13-439b-9e5b-16e37c985958">
        <controlMethod name="Table::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblAvailCargo_click(table: Table input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 Feb 2024 navhl20 ChangeRequest 62093: EUP | Retrospective Operations - [54177.030] - Road Receive
02 Apr 2024 navhl20 ChangeRequest 63302: EUP - Bulk Moves in Retrospective Screen
22 Jul 2024 navbs1 ChangeRequest 64884: EUP - Retrospective Jobs Grouped by Cargo Group
*/

vars
	count 		: Integer;
	rowIdx		: Integer;
	row			:JadeTableRow;
begin
	self.populateLocation();
	//Start 22.07.2024 navbs1 #64884
	count := self.tblAvailCargo.allSelectedObjects.size;
	rowIdx := self.tblAvailCargo.fixedRows +1;
	if self.isCargoGrouping and self.findObjectInTableRows(self.tblAvailCargo,null,rowIdx) then
		row := self.tblAvailCargo.accessRow(rowIdx);
		if row.selected = true then
			count := count+1;
		endif;
	endif;
	self.lblSelectedCount.caption := self.lblSelectedCaption &amp; Space &amp;count.String;
	self.collapseOrExpandCargoGroups(table, table.row ,table.column);
	//End 22.07.2024 navbs1 #64884
epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
