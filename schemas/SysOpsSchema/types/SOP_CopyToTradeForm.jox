    <JadeMethod name="doSave" id="2db6b2bf-d98a-4228-90f2-12ab87612a78">
        <updating/>
        <source>doSave() : Boolean updating, protected;

/*

Purpose:		
Parameters:		
Return Value:	

Date				Who		Reason
23 June 2009		cnwrl1	Initial creation as part of PAR 19998 - Copy To Trade

*/
	
vars
	tempStr				: String;
	realTrade			: CM_Trade;
	proxyTrade			: CM_Trade;
	parentForm			: SOP_ShipPortGroupForm;
	tmpSelectedPorts	: ObjectArray;
	tmpSelectedDebtors	: ObjectArray;
	theResult : Integer;	//14 Jan 2020 NDL	TFS 46815
	
begin
	if cmbTrade.myObject = null then
		tempStr	:= app.getErrorString1( Please_Select_A, app.getErrorString( Trade ) );
		app.msgBox(	tempStr, app.getErrorString( Error ), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon );
		return false;
	endif;
	
	app.mousePointer := Busy;
	
	create tmpSelectedPorts transient;
	create tmpSelectedDebtors transient;
	
	parentForm	:= self.myParentForm.SOP_ShipPortGroupForm;
	parentForm.mulPorts.getSelected( tmpSelectedPorts );
	parentForm.mulDebtors.getSelected( tmpSelectedDebtors );
	
	realTrade		:= cmbTrade.myObject.CM_Trade;
	proxyTrade		:= app.createUpdateProxy( realTrade ).CM_Trade;
	
	//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxUA.trxUpdateTradeCopyToTrade( proxyTrade, app.myPassport, tmpSelectedPorts, tmpSelectedDebtors );
	
		if app.myPassport.trxCompletedOK then
			tempStr	:= app.getErrorString3(	Trade_been_success_updated,
										proxyTrade.description.display,
										( realTrade.allPortRotations.size - proxyTrade.allPortRotations.size ).display,
										( realTrade.operators.size - proxyTrade.operators.size ).display );
			app.msgBox(	tempStr, app.getErrorString( Information ), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon );
			return true;
		else
			theResult := app.showErrorWarningDialog(	self.caption, app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings );
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		return false;
		
	endwhile;
	
epilog

	delete tmpSelectedPorts;
	delete tmpSelectedDebtors;
	delete proxyTrade;
	
	app.mousePointer := Idle;
	
end;
</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="91014adb-8628-4186-a56d-e535028795c1">
        <updating/>
        <source>setupForm() updating;

/*

Purpose:		
Parameters:		
Return Value:	

Date				Who		Reason
23 June 2009		cnwrl1	Initial creation as part of PAR 19998 - Copy To Trade

*/
	
vars
	
begin
	self.showToolbar	:= true;
	self.toolbarStyle	:= self.ToolbarStyle_ShowNoHide;
	self.cmbTrade.zOrder( 1 );				// make sure the combo is in front of labels (keydown was not working).
	
	inheritMethod();
	
	self.centreOverParent( 100 );			// keeps the modal form on the same monitor as the display form.
	
epilog
	
end;
</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="e4a27d85-b6e8-4cf8-ae2f-c6826935719d">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0011270, locale);
	lblHeading.translateCaption(Xlat_0014500, locale);
	lblTrade.translateCaption(Xlat_0011272, locale);
end;</source>
    </JadeMethod>
</GUIClass>
