    <JadeMethod name="updateEDICSV" id="2aae0b20-7dbe-42ff-8421-106da24b1842">
        <source>updateEDICSV();

vars

	fileFormat				: CM_FileFormatEDICSV;
	fileFormat1				: CM_FileFormatEDIXML;
	
	descArray				: StringArray;
	opArray					: StringArray;
	tokens					: StringArray;
	tokens2					: StringArray;

	line					: String;
	pos						: Integer;
	indexOf					: Integer;
	
begin

	app.initialize();

	line := "TollNZAdvNot;NZR~FonterraPack;FON~AllianceManifest;NZR~CPShipsLoadList;CSA~HapagLloydLoadlist;HLL~TranzRailBooking;NZR~TranzRailEmptyManifest;NZR~TranzRailLoadedManifest;NZR~ANLLoadList;ANL~CMALoadList;CMA~COSLoadList;COS~MOLLoadList;MOL~MSCLoadListOtago;MSC~NYKLoadList;NYK~TOLLoadList;TOL~MSKLoadList2;MSK";

	create tokens transient;
	create tokens2 transient;
	line.getTokensForDelimiter('~', tokens);
	
	create descArray transient;
	create opArray transient;
	foreach line in tokens do
	
		//pos := 1;
		//line.pos(';', pos);
		//descArray.add(line[1:pos-1]);
		//opArray.add(line[pos+1:end]);
		write line;
		tokens2.clear();
		line.getTokensForDelimiter(';', tokens2);
		descArray.add(tokens2[1]);
		opArray.add(tokens2[2]);
	
	endforeach;
	
	//return;
	
	beginTransaction;
	foreach fileFormat in CM_FileFormatEDICSV.instances discreteLock do
		
		write 'desc: ' &amp; fileFormat.description;
		indexOf := descArray.indexOf(fileFormat.description);
		write 'desc: ' &amp; fileFormat.description &amp; Tab &amp; 'indexof: ' &amp; indexOf.String;
		if indexOf = 0 then
			write fileFormat.String &amp; Tab &amp; fileFormat.description;
			continue;
		endif;
		
		fileFormat.setOperator(opArray[indexOf]);
	
	endforeach;
	commitTransaction;
	
	
	beginTransaction;
	foreach fileFormat1 in CM_FileFormatEDIXML.instances discreteLock do
		
		write 'desc: ' &amp; fileFormat1.description;
		indexOf := descArray.indexOf(fileFormat1.description);
		write 'desc: ' &amp; fileFormat1.description &amp; Tab &amp; 'indexof: ' &amp; indexOf.String;
		if indexOf = 0 then
			write fileFormat1.String &amp; Tab &amp; fileFormat1.description;
			continue;
		endif;
		
		fileFormat1.setOperator(opArray[indexOf]);
	
	endforeach;
	commitTransaction;
	
epilog

	delete tokens;
	delete descArray;
	delete opArray;
	delete tokens2;

end;
</source>
    </JadeMethod>
    <JadeMethod name="updatePortColours" id="6e9f374b-ba81-4967-9118-81232678ed44">
        <source>updatePortColours();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 May 2019	jlgmh5	Initial creation

*/

vars

	port					: CM_Port;
	
	colour					: Integer;
	randColour				: Integer;

begin

	colour := 0;

	beginTransaction;
	foreach port in CM_Port.instances discreteLock do
	
		port.setPropertyValue('colour', colour);
		randColour := app.randomRange(7000, 14000);
		colour := colour + randColour;
	
	endforeach;
	commitTransaction;

epilog

end;</source>
    </JadeMethod>
</Class>
