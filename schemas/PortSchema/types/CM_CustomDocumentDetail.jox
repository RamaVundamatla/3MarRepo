    <JadeMethod name="validateForIncludeChange" id="61da95ac-2cf0-47f6-8958-a418c42c5301">
        <source>validateForIncludeChange();
/*
Purpose - 	
Who - NAVAB1
Date - 28SEP2023
ADO - CR 60424 TASK 60549 
*/
vars
	ti : CM_TrackedItem;
	ct : CM_CargoType;
	realMe : SelfType;
	cdd1, cdd2 : CM_CustomDocumentDetail;
	dt1, dt2, dt0 : CM_CustomDocumentType;
	cd1, cd2, cd0 : CM_CustomDocument;
begin
	
	if self.myTrackedItem = null then
		app.raiseCMException(Custom_docume_must_have_cargo,null,null);
	endif;

	ti := self.myTrackedItem;
	
	if self.pxyIsProxy() then // UPDATING
		realMe := self.pxyGetRealObject();
		// this was not included but now is, it is trying to include this TI, so check if the TI already on a CDD for doc of same type.
		if self.included and not realMe.included then 
			cd1 := ti.allCustomDocuments.getLastActive(); // ### TFS CR 60425 TASK 60828 13NOV2023 NAVAB1 // get the last cust doc the TI was included on
			cd2 := realMe.getCustomDocumentHeader();
			
			if cd1 &lt;&gt; null then // ### TFS CR 64285 TASK 64286 24JUNE024 NAVAB1
				dt1 := cd1.myCustomDocumentType;
				dt2 := cd2.myCustomDocumentType;
				
				if dt1 = dt2 then
					// %1 is already included on a %2 document type (%3), cannot alos be added to this document
					app.raiseCMException3(Alrea_inclu_docum_type_canno_a,ti.id, dt1.code, cd1.code, null, self);
				else // if they are not the same then check that the previous document is compatible with this custom documents' doc type, i.e the TI is already included on an IMAH and this document is an IMAH-BTW
					cd0 := ti.allCustomDocuments.getAtKeyLss(cd1.sequence,null); // get the document before this probably a 126 if there is one
					if cd0 &lt;&gt; null
					and cd0 &lt;&gt; cd1 then
						dt0 := cd0.myCustomDocumentType;
						if dt0.allNextDocumentTypes.includes(dt2) then
							// %1 already has a document %2 that is after %3, cannot also be included on this document
							app.raiseCMException3(Alrea_docum_that_after_canno_a,ti.id, cd1.code &amp; "(" &amp; dt1.code &amp; ")", cd0.code &amp; "(" &amp; dt0.code &amp; ")", null, self);
						endif;
					endif;
				endif;
			endif;
		endif;
	
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="b170942d-6535-4050-9f6c-042e3fe837d0">
        <source>validateForUpdate();
// ##### CR 56094  TASK 59616 NAVAB1 08AUG2023
vars
	ti : CM_TrackedItem;
	ct : CM_CargoType;
begin
	if self.myTrackedItem = null then
		app.raiseCMException(Custom_docume_must_have_cargo,null,null);
	endif;
	
	self.validateForIncludeChange();// ### TFS CR 60424 TASK 60549 27SEP2023 NAVAB1

	ti := self.myTrackedItem;
	if ti.isCargoGroupItem then
		ti := self.myTrackedItem.CM_CargoGroup.allAssignedTrackedItems.first;
	endif;
	if ti &lt;&gt; null then
		ct := ti.myCargoType;
	endif;
	
	if self.clearedQuantity = 0 and self.clearedWeight = 0 and self.clearedVolume = 0 then
		app.raiseCMException(Custo_docum_clear_amoun_must_e, null, self);
	endif;
	
	
	if ct &lt;&gt; null then // if the cargo group is empty we cannot validate this.
		if ct.isBulk then
			if ct.isBulkByVolume() then
				if self.clearedVolume &lt;= 0
				or self.clearedVolume &gt; self.myTrackedItem.totalVolume then
					app.raiseCMException3(Clear_volum_great_than_total_v,self.clearedVolume.String ,self.myTrackedItem.id,self.myTrackedItem.totalVolume.String ,null,null);
				endif;
			else
				if self.clearedWeight	 &lt;= 0 
				or self.clearedWeight &gt; self.myTrackedItem.totalWeight then
					app.raiseCMException3(Clear_weigh_great_than_total_w, self.clearedWeight.String,self.myTrackedItem.id, self.myTrackedItem.totalWeight.String ,null,null);
				endif;
				
			endif;
		else
			if self.clearedQuantity &lt;= 0
			or self.clearedQuantity &gt; self.myTrackedItem.totalQuantity then
				app.raiseCMException3(Clear_quant_great_than_total_q, self.clearedQuantity.String,self.myTrackedItem.id,self.myTrackedItem.totalQuantity.String ,null,null);
			endif;
			
		endif;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="validateIncluded" id="b3c33e97-f16e-48cd-b26e-fb518cc8c865">
        <source>validateIncluded() : Boolean;
/*
Purpose:			

Date		Who		Reason
18 August 2023	navab1	CR 59615 TASK 59620
*/

vars
	prevCustDocDetail : CM_CustomDocumentDetail;
	ti : CM_TrackedItem;
	ct : CM_CargoType;
begin
	return true;
	
	
	
	
	
	
	prevCustDocDetail := self.getPrevCustDocDetail();
	
	if prevCustDocDetail &lt;&gt; null then
		return prevCustDocDetail.included;
	endif;
	
	return true;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
