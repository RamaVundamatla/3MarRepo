    <JadeMethod name="isPropEnabled" id="a7472a11-9a53-4259-ae7a-647b401d11ce">
        <source>isPropEnabled(_view : Object; _type : Object; _name : String) : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 July 2023	navkc1	Initial creation

*/

vars
	allFields				: MemberKeyDictionary;
	field					: Object;
	fieldName				: String;
	
begin
	
	allFields := _type.getPropertyValue("allReportingFields").MemberKeyDictionary;
	
	foreach field in allFields discreteLock do : loopField
		
		if field.class().name = JRDReportingFeatureDefn then
			fieldName := field.getPropertyValue("featureName").String;
		else
			fieldName := field.getPropertyValue("pathName").String;
		endif;
		
		if fieldName = _name then
			return true;
		endif;
	endforeach;
	
	return false;
	
epilog

end;</source>
        <Parameter name="_view" type="Object"/>
        <Parameter name="_type" type="Object"/>
        <Parameter name="_name" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
