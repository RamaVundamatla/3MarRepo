	inheritMethod();
	initForm();

end;</source>
    </JadeMethod>
    <JadeMethod name="loadFile" id="011349dd-7fb1-4835-843d-ac0351085a39">
        <source>loadFile() : String protected;

vars

	fOpen : CMDFileOpen;

begin

	create fOpen transient;
	fOpen.initDir := 'c:\AS400Files';
	if fOpen.open = 0 then  
		return fOpen.fileName;
	endif;

epilog

	delete fOpen;

end;</source>
        <access>protected</access>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="loadTable" id="f0c051ba-86e1-4d87-ae58-6106fea667e4">
        <source>loadTable() protected;

/*

Date		Who		Reason
11 Jan 2011	cnwkpd1	PAR #26678 - Tidy up transient leaks

*/

vars

	fileLoad	: CM_AS400FileLoad;
	iter		: Iterator;
	display		: String;
	count		: Integer;

begin

	count := 1;
	iter := self.myFileLoadAgent.myAS400Root.allFileLoads.createIterator;
	self.tblLoadedFiles.rows := 1;
	while iter.next(fileLoad) do
		count := count + 1;
		display := fileLoad.getLoadStateString(fileLoad.loadState) &amp; Tab &amp; fileLoad.id &amp; Tab &amp; fileLoad.terminalName &amp; Tab &amp; fileLoad.docketFileName &amp; Tab &amp; fileLoad.logFileName &amp;
		Tab &amp; fileLoad.allDockets.size.String &amp; Tab &amp; fileLoad.allLogs.size.String;
		self.tblLoadedFiles.addItem(display);
		self.tblLoadedFiles.row := count;
		self.tblLoadedFiles.itemObject := fileLoad;
	endwhile;	

epilog
	delete iter;		// PAR #26678
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setSelected" id="514be269-0ae1-4596-9bcf-bb2c48f64117">
        <updating/>
        <source>setSelected(_row : Integer) protected, updating;

vars

begin

	self.tblLoadedFiles.accessRow(_row).selected := true;
	self.tblLoadedFiles.column := 1;
	self.mySelectedFileLoad := self.tblLoadedFiles.itemObject.CM_AS400FileLoad;


end;</source>
        <access>protected</access>
        <Parameter name="_row" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="tblLoadedFiles_click" id="bed133e2-8dcd-47cf-83e3-e110241cad5a">
