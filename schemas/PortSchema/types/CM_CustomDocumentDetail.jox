    <JadeMethod name="setForCreate" id="bf10907f-cfb7-44b1-bd29-33c0c42f0f99">
        <updating/>
        <source>setForCreate(_pxy : SelfType) updating;
// ##### CR 56094  TASK 59616 NAVAB1 08AUG2023
vars
	subti : CM_TrackedItem;
	subDetail : CM_CustomDocumentDetail;
	
	hasPxySubDetails : Boolean;
begin
	
	self.myTrackedItem := _pxy.myTrackedItem;
	self.myParentCustomDocument := _pxy.myParentCustomDocument;
	self.myParentCustomDocumentDetail := _pxy.myParentCustomDocumentDetail;// ### TFS CR 59615 TASK 59620 15AUG2023 NAVAB1
	
	self.originalQuantity := self.myTrackedItem.totalQuantity;
	self.originalVolume := self.myTrackedItem.totalVolume;
	self.originalWeight := self.myTrackedItem.totalWeight;

	self.setForData(_pxy);
	
	hasPxySubDetails:= _pxy.allSubDetails.isNotEmpty();  // ### TFS CR 60052 TASK 60054 25AUG2023 NAVAB1
	
	// ### TFS CR 59615 TASK 59620 15AUG2023 NAVAB1
	if self.included 
	and self.myTrackedItem &lt;&gt; null
	and self. myParentCustomDocument &lt;&gt; null then
		self.myParentCustomDocument.addTI(self.myTrackedItem);
		
		// If proxies are via Cargo Review then there will be sub details.
		if _pxy.allSubDetails.isNotEmpty() then
			foreach  subDetail in _pxy.allSubDetails where subDetail.included do
				subti := subDetail.myTrackedItem;
				self.myParentCustomDocument.addTI(subti);
			endforeach;
		else
			// Put all TIs on the custom document so that all TIs can get to the cust doc by sequence
			if self.myTrackedItem.isCargoGroupItem then
				foreach subti in self.myTrackedItem.CM_CargoGroup.allAssignedTrackedItems discreteLock do
					self.myParentCustomDocument.addTI(subti);
					if not hasPxySubDetails then // ### TFS CR 60052 TASK 60054 25AUG2023 NAVAB1
						self.createSubDetailForTI(subti); // ### TFS CR 60052 TASK 60054 25AUG2023 NAVAB1
					endif;
				endforeach;
			endif;
		endif;
		
	endif;
epilog

end;</source>
        <Parameter name="_pxy" type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForData" id="364c412d-5ead-48b9-a201-732b6af76046">
