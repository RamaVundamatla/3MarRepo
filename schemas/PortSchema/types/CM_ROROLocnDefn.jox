    <JadeMethod name="addRotateLabel" id="44c3d986-50b1-4335-acc6-e4d0141c3cf9">
        <updating/>
        <source>addRotateLabel(_rotateLabel : String) updating;
/*
Purpose:			
Date		Who		Reason
13 July 2011	cnwab1	Initial creation
*/

vars
	labelLen, startPos : Integer;
	slotDefn : CM_ROROSlotDefn;
begin
	if _rotateLabel = null then
		return;
	endif;
	/*
	labelLen := _rotateLabel.length;
	startPos := (self.code.length - labelLen) + 1;
	
	// check that it is not already there
	if startPos &lt;= self.code.length then
		if self.code[startPos:end] &lt;&gt; _rotateLabel then
			self.code := self.code &amp; _rotateLabel;
		endif;
	else
	*/
		self.setCode( self.code &amp; _rotateLabel, false );
		
	foreach slotDefn in self.allROROSlotDefnByOrdinal discreteLock do
		
		slotDefn.setCode(slotDefn.code &amp; _rotateLabel);
	endforeach;
	//endif;
epilog

end;</source>
        <Parameter name="_rotateLabel" type="String"/>
    </JadeMethod>
    <JadeMethod name="clearAllPlannedRotatedLocnDefn" id="6d500957-f48c-4ff3-9b79-c1b5900f6906">
        <updating/>
        <source>clearAllPlannedRotatedLocnDefn() updating;
/*
Purpose:			
Date		Who		Reason
13 February 2013	cnwab1	Initial creation
*/

vars
	locn : CM_ROROLocnDefn;
begin
	foreach locn in self.allPlannedRotatedLocnDefns discreteLock do
		locn.setMyPlannedRotatedMaster(null);
	endforeach;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="cloneMySelf" id="995906c1-a511-45e0-93ce-88d9fe9ac677">
        <source>cloneMySelf(_newLayer : CM_DeckLayerLayout; _copy : Boolean; _nextOrd : Boolean) : CM_ROROLocnDefn;
/*
Purpose:			
Date		Who		Reason
29 April 2011	cnwab1	Initial creation
*/

vars
	deckItem : CM_DeckItem;
	newMe : SelfType;
	aSlot, newSlot : CM_ROROSlotDefn;
	aHaz, newHaz : CM_Hazard;
	ord : Integer;
	deck : CM_Deck;
	ignore : String;
	genCode : String;
begin

	deck:= _newLayer.myDeckLayout.myDeck;
	
	if deck.isKindOf(CM_DeckVessel) then
		newMe := self.cloneSelf(_copy);
		newMe.CM_ROROLocnDefnVessel.setMyROROStructure(deck.CM_DeckVessel.myROROStructure);
	elseif deck.isKindOf(CM_DeckVoyage) then
		//copy vessel decks to voyage decks
		newMe:= self.cloneSelfAs(CM_ROROLocnDefnVoyage,_copy).CM_ROROLocnDefnVoyage;
		newMe.CM_ROROLocnDefnVoyage.setMyVoyageStructure(deck.CM_DeckVoyage.myVoyageStructure);

	endif;
	
	
	// PAR 27528 
	if  _nextOrd then
	/* PAR 27749
		ord := _newLayer.myDeckLayout.myDeck.allROROLocnDefnByOrdinal.size;
		while true do : ordLoop
			ord := ord + 1;
			if _newLayer.myDeckLayout.myDeck.allROROLocnDefnByCode[ord.String] = null then
				newMe.ordinal := ord;
				newMe.code := ord.String;
				break ordLoop;
			endif;
		endwhile;
		*/
		// PAR 27749 Get Unique Ordinal and Code
		_newLayer.myDeckLayout.myDeck.getUniqueOrdCodeLocnDefn("", 0, genCode, newMe.ordinal); // PAR 28890
		newMe.setCode( genCode, false );

		
	endif;
	
	newMe.myDeckLayerLayout := _newLayer;
	newMe.myDeck := deck;
	newMe.myLayout := self.myLayout.cloneMySelf(newMe, _newLayer, _copy);
	
	if self.myAdjacentSlotAft &lt;&gt; null 
	and not _nextOrd then // PAR 27528 _nextOrd means that we are copying an individual location and as such we do not set the aft slot, the user can do that manually
		newMe.myAdjacentSlotAft := newMe.myDeckLayerLayout.allROROLocnDefnByOrdinal[self.myAdjacentSlotAft.ordinal];
	endif;
	
	foreach aSlot in self.allROROSlotDefnByOrdinal discreteLock do
		newSlot := aSlot.cloneMySelf(newMe, _copy);
	endforeach;
	
	foreach aHaz in self.allHazardsAllowed discreteLock do
		newHaz := aHaz.CM_ROROHazard.cloneMySelf(newMe, _copy);
	endforeach;
	
	return newMe;
epilog

end;</source>
        <Parameter name="_newLayer" type="CM_DeckLayerLayout"/>
        <Parameter name="_copy" type="Boolean"/>
        <Parameter name="_nextOrd" type="Boolean"/>
        <ReturnType type="CM_ROROLocnDefn"/>
    </JadeMethod>
    <JadeMethod name="copyAllRotatedCloneDetails" id="a411e8d4-3560-4798-bf5e-f9bba49f2a6f">
        <updating/>
        <source>copyAllRotatedCloneDetails() updating;
/*
Purpose:			
Date		Who		Reason
24 February 2012	cnwab1	Initial creation
*/

vars
	slotDefn : CM_ROROSlotDefn;
begin
	
	foreach slotDefn in self.allROROSlotDefnByOrdinal discreteLock do
		slotDefn.copyAllRotatedCloneDetails();
	endforeach;

epilog

end;</source>
    </JadeMethod>
