<Class name="CM_STWRInterface" id="2da18da5-6f9d-48f2-9e60-8cc11574441a">
    <superclass name="CM_ExtFinanceIO"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="invoice"/>
    <JadeMethod name="createInvoiceXML" id="6f70f9d0-def0-40ce-b64f-88bafa75392e">
        <source>createInvoiceXML(file : File input; _invoice : CM_Invoice);
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
12 September 2017	jlgndl1	Initial creation	TFS 6938
23 September 2019	jlgzm1	TFS 46054 STWO - Adding Extra Details to Manual Invoice Lines

*/

vars

	invLine : CM_InvoiceLine;
	charge: CM_Charge;
	chargeStr : String;
	voyage : CM_Voyage; // TFS 46054

begin

	file.writeLine('&lt;?xml version="1.0"?&gt;');
	file.writeLine("&lt;Invoice&gt;");
	
	voyage := self.getVoyage(_invoice);	// TFS 46054

		//Yes we are actually writing out each individual charge as an &lt;InvoiceLine&gt; tag set.
	foreach invLine in _invoice.invoiceLines do	
		foreach charge in invLine.charges do
			chargeStr := self.getChargeXML( charge, voyage );	// TFS 46054
			if chargeStr &lt;&gt; null then
				file.writeLine("&lt;InvoiceLine&gt;");
				file.writeLine(chargeStr);
				file.writeLine("&lt;/InvoiceLine&gt;");
			endif;
		endforeach;	
	endforeach;

	file.writeLine("&lt;/Invoice&gt;");

epilog

end;</source>
        <Parameter name="file" type="File" usage="input"/>
        <Parameter name="_invoice" type="CM_Invoice"/>
    </JadeMethod>
    <JadeMethod name="export" id="f723e3e6-b96d-4df4-afe4-76d2f4c61280">
        <updating/>
        <source>export(invoice: CM_Invoice input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
12 September 2017	jlgndl1	Initial creation	TFS 6938
22 July 2019		cnwma1	ChangeRequest 45577: ASPA - JMT Interface to AR Oracle
08 November 2019	jlgzm1	TFS 46948 STWO Change Export File name to Invoice Number
*/

constants
	//FixedPrefix : String = "Invoicing_v10_";	// TFS 46948
vars

	file : File;
	path : String; 
	exportDir : String; 
	fFolder	: FileFolder;
	runDate : Date;
	baseFileName : String;
	fileName : String;
	//counter : Integer;		// TFS 46948
	//checkFileExists : File;	// TFS 46948

begin

	path := self.exportPath.normaliseDirectory().substituteDirectory();
	//runDate := app.actualTimeAppServer.Date;							// TFS 46948
	//baseFileName := FixedPrefix &amp; runDate.format("yyyMMdd") &amp; "_";	// TFS 46948
	baseFileName := invoice.sequenceNum.asStringJMT();					// TFS 46948
	
	exportDir := path;
	
	create fFolder transient;
	fFolder.fileName := exportDir;

	if not fFolder.isAvailable() then
		fFolder.make();
	endif;
	
	fileName := exportDir &amp; "/" &amp; baseFileName &amp; ".xml";	// TFS 46948
	
	/* // TFS 46948
	//Find the last file exported via this mecnanism today.
	counter := 1;  // first one is always 1.
	fileName := exportDir &amp; "/" &amp; baseFileName &amp; counter.String &amp; ".xml";
	
	create checkFileExists;
	checkFileExists.mode := File.Mode_Input;
	checkFileExists.fileName := fileName;
	while true do
		if checkFileExists.isAvailable then
			//its been used, increment teh counter and try again.
			counter := counter + 1;
			fileName := exportDir &amp; "/" &amp; baseFileName &amp; counter.String &amp; ".xml";
			checkFileExists.fileName := fileName;
		else
			//file name has not been used...
			break;
		endif;
	endwhile;
	delete checkFileExists;
	*/
		
	create file;
	file.fileName := fileName;
	file.mode := File.Mode_Output;
	file.shareMode := File.Share_Exclusive;
	file.kind := File.Kind_Unknown_Text;
	file.hidden := false;
	
	createInvoiceXML(file, invoice);
	file.close;
	
	invoice.incrementExportCount(false);				//22.07.2019 cnwma1 TFS #45577
epilog

	delete file; 
	delete fFolder;
	//delete checkFileExists; // TFS 46948
	
end;</source>
        <Parameter name="invoice" type="CM_Invoice" usage="input"/>
    </JadeMethod>
    <JadeMethod name="exportToFile" id="c12beb2f-214d-4b49-b168-addc606ae6e9">
        <source>exportToFile(invoice: CM_Invoice input; fileNameBase: String);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 September 2017	jlgndl1	Initial creation
22 July 2019		cnwma1	ChangeRequest 45577: ASPA - JMT Interface to AR Oracle
*/

vars

	file : File;
	

begin
	
	create file;
	file.fileName := fileNameBase;
	file.mode := File.Mode_Output;
	file.shareMode := File.Share_Exclusive;
	file.hidden := false;
	
	self.createInvoiceXML( file, invoice );
	file.close;
	
	
	invoice.incrementExportCount(false);			//22.07.2019 cnwma1 TFS #45577

	
epilog

	delete file; 
	
	
end;</source>
        <Parameter name="invoice" type="CM_Invoice" usage="input"/>
        <Parameter name="fileNameBase" type="String"/>
    </JadeMethod>
    <JadeMethod name="formatAsXML" id="76d43e80-bbd1-41fc-83cf-41d50aac9ca1">
        <source>formatAsXML(pTag: String; pValue: String): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 September 2017	jlgndl1	Initial creation

*/

vars

	work : String;
	result : String;
	
begin

	if pValue = null then
		result := '&lt;' &amp; pTag &amp; '/&gt;';
	else
		work := pValue.xmlReplaceReservedChars(true);
		result := '&lt;' &amp; pTag &amp; '&gt;' &amp; work &amp; '&lt;/' &amp; pTag &amp; '&gt;';
	endif;
	
	return result;
	
end;</source>
        <Parameter name="pTag" type="String"/>
        <Parameter name="pValue" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getChargeXML" id="f620b9dc-e4b3-4028-8f4a-2dfd2ed3b3ee">
        <source>getChargeXML( _charge: CM_Charge input; _voyage: CM_Voyage ):String;
/*

Purpose:			

Parameters:			

Return Value:		
/* Changes

Date		Name	TFS#		Description
============================================================================
12 Sep 2017	jlgndl1	TFS 6938	Initial creation	
10 Apr 2018	jlgrh7 	TFS #38024	STWO - Icorp Extract Rate and Total 3 Decimal Places 
04 Jul 2019	jlgka1	TFS 45372	STWO - Change the Invoice extract GLDDate from  Ship Exchange Start Date to General Lading Date.
19 Sep 2019	jlgdi1	46043		Changed the source of data for Bill of Lading
23 Sep 2019	jlgzm1	TFS 46054	STWO - Adding Extra Details to Manual Invoice Lines
10 Dec 2019	jlgzm1	TFS 47944	STWO - Fields on merged cargo zero on exported invoices
26 May 2021 cnwma1  Bug 51218:  STWO - Cargo data missing in invoice export
============================================================================*/
constants

	DateFormatStr : String = "dd/MM/yy";
	TimeFormatStr : String = "HH:mm";
vars
	returnStr 			: String;
	inv 				: CM_Invoice;
	invLine 			: CM_InvoiceLine;
	debtor	 			: CM_Debtor;
	txnType 			: String;
	operCode 			: String;
	consigneeDesc 		: String;
	consignorDesc 		: String;
	shipOperDesc 		: String;
	isoTypeStr 			: String;
	imexStr 			: String;
	voyage 				: CM_Voyage;
	voyageCode 			: String;
	clientRef 			: String;
	ti 					: CM_TrackedItem;
	widthStr 			: String;
	localVoyArrAct 		: TimeStamp;
	localVoyArrActStr 	: String;
	term 				: CM_Terminal;
	totWeightStr 		: String;
	totVolumeStr 		: String;
	totQuantityStr 		: String;
	lengthStr 			: String;
	freightTonsStr		: String;	// TFS 46054
	int 				: Integer;
	numberDaysTransit 	: String;
	id 					: String;
	houseBol 			: String;
	heightStr 			: String;
	destPort 			: String;
	comStr 				: String;
	commodityObj 		: CM_Commodity;
	comGroupObj 		: CM_CommodityGroup;
	commGrpStr 			: String;
	cargoTypeDesc 		: String;
	cargoSubTypeDesc 	: String;
	cargoDesc 			: String;
	billOfLading 		: String;
	drCode 				: String;
	vessel 				: CM_Vessel;
	vesselCode 			: String;
	vesselName 			: String;
	localArrDateExp 	: TimeStamp;
	localArrDateExpStr	: String;	
	localGLDate 		: Date;			
	localGLDateStr 		: String;				//jlgka1 TFS 44753 &lt;--
	locationId 			: String;
	drLongName 			: String;
	calcType 			: CM_CalculationType;
	calcTypeDesc 		: String;
	localDepDateExp 	: TimeStamp;
	localDepDateExpStr 	: String;
	invType 			: CM_InvoiceDesc;
	extRef 				: String;
	tiTrx 				: CM_TITransaction;
	deciTotal 			: Decimal[16,3];	//11 May 2018	NDL	TFS 38528
	deciRate 			: Decimal[16,3]; 	//11 May 2018	NDL	TFS 38528
begin

	invLine  := _charge.invoiceLine;
	inv      := invLine.invoice;
	term     := inv.myTerminal;
	debtor   := invLine.debtor;
	calcType := invLine.getCalcType;
	invType  := inv.getInvoiceType;
	
	if debtor &lt;&gt; null then
		drCode := debtor.decfinName;
		drLongName := debtor.longName;
	endif;
	
	if calcType &lt;&gt; null then
		calcTypeDesc := calcType.description;
	endif;
		
	if invType &lt;&gt; null then
		extRef := invType.externalReference;
	endif;
	
	if _charge.total &lt;&gt; null then
		deciTotal := _charge.total;
	endif;
	
	if _charge.getRate &lt;&gt; null then
		deciRate := _charge.getRate;
	endif;

	if invLine.myTransactionTI &lt;&gt; null then
		tiTrx 		  := invLine.myTransactionTI;
		ti            := invLine.myTransactionTI.myTrackedItem;  //26.05.2021 navma1 #51218
		txnType 	  := tiTrx.typeString;
		operCode 	  := tiTrx.operatorCode;
		consigneeDesc := tiTrx.consignee;
		consignorDesc := tiTrx.consignor;
		voyage 		  := tiTrx.getVoyage;
		
		if tiTrx.isKindOf( CM_Move ) then
			locationId := tiTrx.CM_Move.targetLocn;
		elseif tiTrx.isKindOf( CM_Storage ) then
			locationId := tiTrx.CM_Storage.location;
		elseif tiTrx.isKindOf( CM_DamageLocation ) then
			locationId := tiTrx.CM_DamageLocation.damagedInLocation;
		endif;
		
		// TFS 47944 these values may be zero on TI if it has been merged
		// so should get from the transaction
		if tiTrx.totalWeight &gt; 0 then
			totWeightStr := tiTrx.getDefaultMeasureTotalWeight;	//18 Feb 2020	NDL	TFS 48623
		endif;
		
		if tiTrx.totalVolume &gt; 0 then
			totVolumeStr := tiTrx.getDefaultMeasureTotalVolume;	//18 Feb 2020	NDL	TFS 48623
		endif;
		
		if tiTrx.totalQuantity &gt; 0 then
			totQuantityStr := tiTrx.totalQuantity.String;
		endif;
		
		if tiTrx.getFreightTons &gt; 0 then
			freightTonsStr := tiTrx.getFreightTons.asStringJMTWithPrecision(4, false);
		endif;

		billOfLading := tiTrx.billOfLading;
		imexStr  	 := tiTrx.getImExStatusStringDesc(false);
		destPort	 := tiTrx.destinationPort;
		comStr  	 := tiTrx.commodity;

		
	elseif invLine.myTransactionHMS &lt;&gt; null then
		txnType   := invLine.myTransactionHMS.typeString;
		operCode  := invLine.myTransactionHMS.myVoyage.myOperator.code;
		voyage    := invLine.myTransactionHMS.myVoyage;
		
	elseif invLine.myTransactionEvent &lt;&gt; null then
		txnType := invLine.myTransactionEvent.getTypeString;
		voyage  := invLine.myTransactionEvent.getVoyage;
	elseif invLine.trackedItem &lt;&gt; null then                     //26.05.2021 navma1 #51218
		ti 		:= invLine.trackedItem;
	endif;

	//26.05.2021 navma1 #51218
	if ti &lt;&gt; null then
		id 		 		 := ti.id;
		houseBol 		 := ti.houseBillOfLading;
		
		cargoTypeDesc 	 := ti.cargoTypeDescr;
		cargoSubTypeDesc := ti.getCargoSubTypeDescr;
		cargoDesc 		 := ti.description;
		isoTypeStr 		 := ti.getISOType;
		clientRef 		 := ti.clientRef;
		int 			 := ti.getNumDaysAsCurrentStatus;
		
		if int &gt; 0 then
			numberDaysTransit := int.String;
		endif;
		
		if ti.width &gt; 0 then
			widthStr := ti.getDefaultMeasureWidth;
		endif;	
		
		if ti.length &gt; 0 then
			lengthStr := ti.getDefaultMeasureLength;
		endif;
		
		if ti.height &gt; 0 then
			heightStr := ti.getDefaultMeasureHeight;
		endif;
		
		if operCode = null then
			operCode := ti.operatorCode;
		endif;
		
		if consigneeDesc = null then
			consigneeDesc := ti.consignee;
		endif;
		
		if consignorDesc = null then
			consignorDesc := ti.consignor;
		endif;
		
		if invLine.myTransactionTI = null then
			if totWeightStr = null then
				totWeightStr := ti.getDefaultMeasureTotalWeight();
			endif;
			
			if totVolumeStr = null then
				totVolumeStr := ti.getDefaultMeasureTotalVolume();
			endif;
			
			if totQuantityStr = null then
				totQuantityStr := ti.totalQuantity.String;
			endif;
			
			if freightTonsStr = null then
				freightTonsStr := ti.getFreightTons.asStringJMTWithPrecision(4, false);
			endif;
		endif;
		
		if locationId = null then
			locationId := ti.locationId;
		endif;
		
		if billOfLading = null then
			billOfLading := ti.billOfLading;
		endif;
		
		if imexStr = null then
			imexStr := ti.getImExStatusStringDesc(false);
		endif;
		
		if destPort = null then
			destPort := ti.destinationPort;
		endif;
		
		if comStr = null then
			comStr := ti.commodity;
		endif;
		
		if comStr &lt;&gt; null then
			commodityObj := app.myRoot.allCommodities[ comStr ];
			if commodityObj &lt;&gt; null then
				comGroupObj := commodityObj.myCommodityGroup;
				if comGroupObj &lt;&gt; null then
					commGrpStr := comGroupObj.code;
				endif;
			endif;
		endif;
	endif;
	//26.05.2021 navma1 #51218
	
	if voyage = null then	// TFS 46054
		voyage := _voyage;	// TFS 46054
	endif;
	
	if voyage &lt;&gt; null then
		voyageCode := voyage.code;
		vessel     := voyage.myVessel;
		
		if voyage.myOperator &lt;&gt; null then
			shipOperDesc := voyage.myOperator.description;
		endif;
		
		if vessel &lt;&gt; null then
			vesselCode := vessel.code;
			vesselName := vessel.name;
		endif;
		
		if voyage.arrivedDT.Date.isValid then
			localVoyArrAct    := voyage.arrivedDT.systemToLocalTimeUsingObject( term );
			localVoyArrActStr := localVoyArrAct.Date.format(DateFormatStr) &amp; " " &amp; localVoyArrAct.Time.format(TimeFormatStr);
		endif;
		
		if voyage.estimatedArrivalDT.Date.isValid then
			localArrDateExp    := voyage.estimatedArrivalDT.systemToLocalTimeUsingObject( term );
			localArrDateExpStr := localArrDateExp.Date.format(DateFormatStr) &amp; " " &amp; localArrDateExp.Time.format(TimeFormatStr);
		endif;

		if voyage.generalLandingDate.Date.isValid then			
			localGLDate    := voyage.generalLandingDate;
			localGLDateStr := localGLDate.Date.format(DateFormatStr) &amp; " 00:00" ;
		endif;
		
		if voyage.departedDT.Date.isValid then
			localDepDateExp    := voyage.departedDT.systemToLocalTimeUsingObject( term );
			localDepDateExpStr := localDepDateExp.Date.format(DateFormatStr) &amp; " " &amp; localDepDateExp.Time.format(TimeFormatStr);
		endif;
	endif;
	
	
		
/*#01*/	returnStr := returnStr &amp; self.formatAsXML( 'LineNumber', 			 invLine.sequenceNum.String );
/*#02*/	returnStr := returnStr &amp; self.formatAsXML( 'InvoiceNumber', 		 inv.sequenceNum.String );
/*#03*/	returnStr := returnStr &amp; self.formatAsXML( 'Qty', 					 invLine.quantity.String );
/*#04*/	returnStr := returnStr &amp; self.formatAsXML( 'Description', 			 invLine.invoiceLineDesc.narration );
/*#05*/	returnStr := returnStr &amp; self.formatAsXML( 'Status', 				 invLine.getStatusDescription(invLine.status) );
/*#06*/	returnStr := returnStr &amp; self.formatAsXML( 'ItemDetails', 			 invLine.trackedItemId );
/*#07*/	returnStr := returnStr &amp; self.formatAsXML( 'Txn', 					 txnType );
/*#08*/	returnStr := returnStr &amp; self.formatAsXML( 'Debtor', 				 drLongName );
/*#09*/	returnStr := returnStr &amp; self.formatAsXML( 'ChargesOverridden', 	 invLine.overriddenChargeCount.String );
/*#10*/	returnStr := returnStr &amp; self.formatAsXML( 'Rate', 					 deciRate.String );								//+TFS38024
/*#11*/	returnStr := returnStr &amp; self.formatAsXML( 'Total', 				 deciTotal.String );								//+TFS38024
/*#12*/	returnStr := returnStr &amp; self.formatAsXML( 'CargoOperator', 		 operCode );
/*#13*/	returnStr := returnStr &amp; self.formatAsXML( 'Consignee', 			 consigneeDesc );
/*#14*/	returnStr := returnStr &amp; self.formatAsXML( 'Consignor', 			 consignorDesc );
/*#15*/	returnStr := returnStr &amp; self.formatAsXML( 'ShipOperator', 			 shipOperDesc );
/*#16*/	returnStr := returnStr &amp; self.formatAsXML( 'ISOType',				 isoTypeStr );
/*#17*/	returnStr := returnStr &amp; self.formatAsXML( 'IMEX', 					 imexStr );
/*#18*/	returnStr := returnStr &amp; self.formatAsXML( 'Voyage', 				 voyageCode );
/*#19*/	returnStr := returnStr &amp; self.formatAsXML( 'ClientRef',				 clientRef );

/*#20*/	returnStr := returnStr &amp; self.formatAsXML( 'Width',				 	 widthStr );
/*#21*/	returnStr := returnStr &amp; self.formatAsXML( 'VoyageArrivalActual',	 localVoyArrActStr );
/*#22*/	returnStr := returnStr &amp; self.formatAsXML( 'TotalWeight', 		 	 totWeightStr );
/*#23*/	returnStr := returnStr &amp; self.formatAsXML( 'TotalVolume',		 	 totVolumeStr );
/*#24*/	returnStr := returnStr &amp; self.formatAsXML( 'TotalQuantity',		 	 totQuantityStr );
/*#25*/	returnStr := returnStr &amp; self.formatAsXML( 'NumberDaysTransit',  	 numberDaysTransit );
/*#26*/	returnStr := returnStr &amp; self.formatAsXML( 'Length',             	 lengthStr );
/*#27*/	returnStr := returnStr &amp; self.formatAsXML( 'ItemVoyage', 		 	 voyageCode );
/*#28*/	returnStr := returnStr &amp; self.formatAsXML( 'ID', 				 	 id );
/*#29*/	returnStr := returnStr &amp; self.formatAsXML( 'HouseBOL', 			  	 houseBol );

/*#30*/	returnStr := returnStr &amp; self.formatAsXML( 'Height', 			 	 heightStr );
/*#31*/	returnStr := returnStr &amp; self.formatAsXML( 'Destination', 	     	 destPort );
/*#32*/	returnStr := returnStr &amp; self.formatAsXML( 'CommodityGroup',     	 commGrpStr );
/*#33*/	returnStr := returnStr &amp; self.formatAsXML( 'Commodity',          	 comStr );
/*#34*/	returnStr := returnStr &amp; self.formatAsXML( 'CargoType',          	 cargoTypeDesc );
/*#35*/	returnStr := returnStr &amp; self.formatAsXML( 'CargoSubtype',       	 cargoSubTypeDesc );
/*#36*/	returnStr := returnStr &amp; self.formatAsXML( 'CargoDescription',       cargoDesc );
/*#37*/	returnStr := returnStr &amp; self.formatAsXML( 'BillOfLading',        	 billOfLading );
/*#38*/	returnStr := returnStr &amp; self.formatAsXML( 'DebtorCode', 		 	 drCode );
/*#39*/	returnStr := returnStr &amp; self.formatAsXML( 'VesselName', 		 	 vesselName );

/*#40*/	returnStr := returnStr &amp; self.formatAsXML( 'ArrivalDateExpected',	 localArrDateExpStr );
/*#41*/	returnStr := returnStr &amp; self.formatAsXML( 'GLDDate', 			 	 localGLDateStr );
/*#42*/	returnStr := returnStr &amp; self.formatAsXML( 'SeaGoing', 			 	 null );
/*#43*/	returnStr := returnStr &amp; self.formatAsXML( 'Location', 			 	 locationId );
/*#44*/	returnStr := returnStr &amp; self.formatAsXML( 'CustomsStatus', 	 	 null );
/*#45*/	returnStr := returnStr &amp; self.formatAsXML( 'Incoterm', 		         null );
/*#46*/	returnStr := returnStr &amp; self.formatAsXML( 'VesselCode', 		   	 vesselCode );
/*#47*/	returnStr := returnStr &amp; self.formatAsXML( 'CalculationType',    	 calcTypeDesc );
/*#48*/	returnStr := returnStr &amp; self.formatAsXML( 'VoyageActualDepartDate', localDepDateExpStr );
/*#49*/	returnStr := returnStr &amp; self.formatAsXML( 'StatusType', 			 extRef );
/*#50*/	returnStr := returnStr &amp; self.formatAsXML( 'TerminalCode',	     	 term.code );
/*#51*/ returnStr := returnStr &amp; self.formatAsXML( 'FreightTonnes',	     	 freightTonsStr );

return returnStr;

epilog

end;</source>
        <Parameter name="_charge" type="CM_Charge" usage="input"/>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getNiceName" id="1f9ad246-a414-451b-b2e0-be61df76e703">
        <source>getNiceName(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 September 2017	jlgndl1	Initial creation	TFS 6938

*/

vars

begin
	return "iCorp STWR";

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getVoyage" id="135c908c-0818-46f6-bb9f-fd2598488d9e">
        <source>getVoyage(_invoice : CM_Invoice) : CM_Voyage;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
23 September 2019	jlgzm1	Initial creation TFS46054 STWO Adding Extra Details to Manual Invoice Lines

*/

vars
	line : CM_InvoiceLine;
begin
	if _invoice = null then
		return null;
	endif;
	
	if _invoice.myVoyage &lt;&gt; null then
		return _invoice.myVoyage;
	endif;
	
	foreach line in _invoice.invoiceLines do
		if line.trackedItem &lt;&gt; null then
			return line.trackedItem.myVoyage;
		endif;
	endforeach;
	
	return null;
epilog

end;</source>
        <Parameter name="_invoice" type="CM_Invoice"/>
        <ReturnType type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="mapper" id="f775fce4-3a86-4b2b-943c-6d03a8814f30">
        <source>mapper(_object ,_ti: Object ;_key :String) :String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 May 2021	navma1	Initial creation

*/

vars
	debtor 		: CM_Debtor;
	calcType	: CM_CalculationType;
	invType     : CM_InvoiceDesc;
begin
	
	if _object.isKindOf(CM_Invoice) then
	
	
	elseif _object.isKindOf(CM_InvoiceLine) then
		
	
	elseif _object.isKindOf(CM_TITransaction) then
		
	elseif _object.isKindOf(CM_TrackedItem) then
		
	elseif _object.isKindOf(CM_Debtor) then
		debtor := _object.CM_Debtor;
		if _key = 'DebtorCode' then
			return debtor.decfinName;
		elseif _key = 'Debtor' then
			return debtor.longName;			
		endif;
	elseif _object.isKindOf(CM_CalculationType) then
		calcType := _object.CM_CalculationType;
		if _key = 'CalculationType' then
			return calcType.description;	
		endif;
	elseif _object.isKindOf(CM_InvoiceDesc) then
		invType := _object.CM_InvoiceDesc;
		if _key = 'StatusType' then
			return invType.externalReference;	
		endif;
	endif;
	return null;
epilog

end;</source>
