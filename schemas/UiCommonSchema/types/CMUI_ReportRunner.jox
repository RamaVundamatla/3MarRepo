    <JadeMethod name="printBGPReport" id="eb28039b-a875-45b6-91f8-067a2b53db90">
        <source>printBGPReport() protected;
// ---------------------------------------------------------------------------
// Created:     13 December 2002		cnwth2	
//
// Purpose:     Prints an existing BGP report
//			 
// ----------   ----------  --------------------------------------------------
vars
	userReport				: CM_MenuUserReport;
	table					: CM_DataTable;
	jadeReport				: CM_JadeReport;
	csvFileName				: String;
	pxyEmail				: CM_EmailTemplate;
	emailSetupSuccessful		: Boolean;
	
begin
	table := self.tblBGPReports;
	
	userReport := table.accessRow(table.row).itemObject.CM_MenuUserReport;
	
	if userReport = null then
//		app.msgBox('Please select a report to print','Nothing selected',0);	// cnwrl1 11/11/2009 PAR 19951 - what it was
		app.msgBox(	app.getString( CMUI_Please_Select, app.getString( Report ), app.getString( INV_Print ) ),
					app.getString( Nothing_Selected ),
					MsgBox_OK_Only );
		return;
	endif;
	
	if userReport.allMenuCSVFileData.size &gt; 0 then //it's a CSV report
		csvFileName := self.tblPrintOptions.getValueByName(ETRow_CsvFileName).String;
		if csvFileName = null then
//			app.msgBox('You must enter a valid file name first','Invalid file name',0);	// cnwrl1 11/11/2009 PAR 19951 - what it was
			app.msgBox(	app.getString( Must_EnterValid_FileName_First ),
						app.getString( Invalid_File_Name ),
						MsgBox_OK_Only );
			return;
		endif;
		
		if self.tblPrintOptions.getValueByName(ETRow_DoEmail).Boolean then
			if userReport.myEmailTemplate &lt;&gt; null then
				pxyEmail := app.createUpdateProxy(userReport.myEmailTemplate).CM_EmailTemplate;	
			else
				create pxyEmail transient;
			endif;
			app.mousePointer := MousePointer_Default; 
			if not self.doDisplayEmailForm(csvFileName, pxyEmail, false) then
				return;
			endif;
			emailSetupSuccessful := true;
			app.mousePointer := MousePointer_HourGlass; 
		endif;
		
		if not userReport.writeCSVBlobToFile(csvFileName) then
//			app.msgBox("Error opening file.", "Report", MsgBox_Information_Icon	);	// cnwrl1 11/11/2009 PAR 19951 - what it was
//			statusLine.caption := "Error running report";	// cnwrl1 11/11/2009 PAR 19951 - what it was
			app.msgBox(	app.getString( Error_Opening_File ),
						app.getString( Report ),
						MsgBox_OK_Only + MsgBox_Information_Icon );
			statusLine.caption := app.getString( Error_Running_Report );
			return;	
		else
			if emailSetupSuccessful then
				self.createEmail(pxyEmail);
//				statusLine.caption := "Selected report was successfully run and emailed";	// cnwrl1 11/11/2009 PAR 19951 - what it was
				statusLine.caption := app.getString( Selected_Rpt_SuccessEmailed );
			else
//				statusLine.caption := "Selected report was successfully run but not emailed";	// cnwrl1 11/11/2009 PAR 19951 - what it was
				statusLine.caption := app.getString( Selected_Rpt_SuccessNotEmailed );
			endif;
		endif;
	else
		jadeReport := userReport.myJadeReport;
		if jadeReport &lt;&gt; null and jadeReport.printArray.size &gt; 0 then
			// Set every time just in case it has been changed.
			if self.tblPrintOptions.getValueByName(ETRow_PrintPreview).Boolean then
				app.printPreview(jadeReport, false);
			else
				app.printer.printPreview := false;
				app.printerFixPAR34782(jadeReport);
				app.printer.printReport(jadeReport);
			endif;
//		statusLine.caption := "Selected report was successfully printed";	// cnwrl1 11/11/2009 PAR 19951 - what it was
			statusLine.caption := app.getString( Selected_Rpt_SuccessPrinted );
		else
//			app.msgBox('Selected report has not generated any output','Error',0);	// cnwrl1 11/11/2009 PAR 19951 - what it was
//			statusLine.caption := "Selected report did has not generated any output";	// cnwrl1 11/11/2009 PAR 19951 - what it was
			app.msgBox(	app.getString( Selected_Rpt_GeneratedOutput ),
						app.getString( Error ),
						MsgBox_OK_Only );
			statusLine.caption := app.getString( Selected_Rpt_GeneratedOutput );
		endif;	
	endif;
	
epilog
	delete pxyEmail;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="progressFinish" id="a75bf190-9fa7-4199-8349-aa3322fc72f7">
        <source>progressFinish();
// ---------------------------------------------------------------------------
// Created:     15 January 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	cmifMonitor		: CMIF_Monitor;
begin
	inheritMethod();
	cmifMonitor := app.myPassport.myCMIFMonitor;
	
	if cmifMonitor = null then
		return;
	endif;
	
	if cmifMonitor.monitorReturnValue = CMIF_Monitor.MonitorReturnValue_Cancel then
//		self.statusLine.caption := self.myReportAgent.myQryReport.reportName &amp; ' report cancelled by user';	// cnwrl1 11/11/2009 PAR 19951 - what it was
		self.statusLine.caption := app.getString( Report_Cancelled_By_User, self.myReportAgent.myQryReport.reportName );
	else
//		self.statusLine.caption := app.getErrorString(QueryingComplete) &amp; " - " &amp; self.myReportAgent.myQryReport.reportName;	// cnwrl1 11/11/2009 PAR 19951 - what it was
		self.statusLine.caption := app.getString( QueryingComplete, self.myReportAgent.myQryReport.reportName );
	endif;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="reportExceptionHandler" id="808797b1-b4c1-4965-bce2-c72c883761a4">
        <source>reportExceptionHandler(_exObj: Exception; _passport: CM_Passport): Integer;
//----------------------------------------------------------------
//	Created:	24 May 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
/*

Date		Who		Reason
09 Mar 2009	cnwkpd1	Add in Stack dump for unexpected exceptions

*/

vars
	str 			: String;
	stackDump		: CnStackDump;
	
begin
	if CM_Exception.hasInstance(_exObj) 
	or app.passBackAllExceptions then
		return Ex_Pass_Back;
	endif;
	
	if _exObj.errorCode = 1027 and LockException.hasInstance(_exObj) then		// lock exception
		str := app.getErrorString(ReportLockedData) ;
	
	elseif _exObj.errorCode = 5030 and _exObj.isKindOf(FileException) then		
		str := app.getErrorString(ReportOpenFile);
	
	else
		str := "Error: Error code " &amp; _exObj.errorCode.String &amp; CrLf &amp; CrLf &amp; 
				"Unexpected report error.  Contact developer." &amp; CrLf &amp; CrLf &amp; _exObj.currentMethodDesc.display;
		
		create stackDump transient;
		stackDump.dumpStack(_exObj);
	endif;
	
	abortTransaction;
	abortTransientTransaction;
	
	app.msgBox(str, "Report Error", MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
	
	if _exObj.resumable then
		return Ex_Resume_Next;
	else
		return Ex_Abort_Action;
	endif;	


epilog
	delete stackDump;
	
end;</source>
        <Parameter name="_exObj" type="Exception"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="requiredFieldsOK" id="cd4b3c1d-0847-4328-a848-8fd42abc6bba">
        <source>requiredFieldsOK(_validate : Boolean): Boolean protected;
// ---------------------------------------------------------------------------
// Created:		05 February 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------

vars
	ok			:	Boolean;
	fields		:	String;
	fieldName,processOption 	:	String;
	theRow : Integer;
	cellObj			: JadeTableCell;
begin
	if self.myReportAgent.myQryReport = null then
		return true;
	endif;
	
	if self.myReportAgent.myQryReport.requiredFields.isEmpty then
		return true;
	endif;
	
	ok := false;
	fields := "";

	processOption := self.tblPrintOptions.getValueByName(ETRow_ProcessOption).String;
	//required fields are an EITHER/OR situation.  i.e.  must have at least one of the fields
	foreach fieldName in self.myReportAgent.myQryReport.requiredFields do
		if fieldName = 'voyage' and not _validate then
			ok := true;
			continue;
		endif;
		//epr par 32220 12/12/13
		if fieldName = ETRow_ProcessDate and (processOption = self.PROCESS_TEMPLATE or self.myReportAgent.state = CMUI_ReportAgent.STATE_TEMPLATE_EDIT) then
			theRow := self.tblParameter.getRow(fieldName);
			if theRow &lt;&gt; 0 then
				cellObj			:=	self.tblParameter.accessCell(theRow, CM_EntryTable.ColumnValue);
				if cellObj.text &lt;&gt; Empty_String then
					ok := ok or true;
				else
					ok := ok or false;
				endif;
			
			endif;
		else
			//add your not allowed value here!
			if self.tblParameter.getValueByName(fieldName).String &lt;&gt; Any_String and
			   self.tblParameter.getValueByName(fieldName).String &lt;&gt; None_Selected_String and
			   self.tblParameter.getValueByName(fieldName).String &lt;&gt; Empty_String then
				ok := ok or true;
			else
				//write  self.tblParameter.getValue(1);
				//write self.tblParameter.getValueByName(fieldName).String ;
				ok := ok or false;
			endif;
		endif;
		
		
		//setup fields string just incase
		if fields = "" then
			fields := fieldName;
		else
			fields := fields &amp; " or " &amp; fieldName;
		endif;
	
	endforeach;	  
	
	
	if not ok then
//		app.msgBox("You must set the " &amp; fields &amp; " to run this report","Required Field", MsgBox_OK_Only + MsgBox_Information_Icon);	// cnwrl1 11/11/2009 PAR 19951 - what it was
		app.msgBox(	app.getString( Required_Fields_Run_Report, fields ),
					app.getString( Required_Fields ),
					MsgBox_OK_Only + MsgBox_Information_Icon );
	endif;
	
	return ok;
	
end;</source>
        <access>protected</access>
        <Parameter name="_validate" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="runBackgroundFileType" id="9a0331b6-e00c-431e-9b9c-abb6a2b69c5f">
        <updating/>
        <source>runBackgroundFileType(
	_filter			: CMQF_FilterReports; 
	_extraDetail	: CM_ExtraDetail;
	_profName		: String ) updating, protected;
// ---------------------------------------------------------------------------
// Created:     27 August 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
// 12 Jan 2018	jlgmd1		TFS #36427 - DQM - Vessel Schedule Report
vars
	printerName				: String;
	networkFilepath			: String;
	reportName				: String;
	reportDescr				: String;
	formatOption			: Integer;
	doEmail					: Boolean;
	stopEmailWhenNoDataRpt	: Boolean;
	emailTemplate			: CM_EmailTemplate;
	userSet					: CM_UserSet;
	user					: CM_User;
	pxyFilter				: CMQF_FilterReports;		//TFS 36427
	eventData				: CM_EventDataByTypeDict;	//TFS 36427
	theResult : Integer;	//13 Jan 2020 NDL	TFS 46815
    destination             : Integer;
	ftpEntity               : CM_FTPEntity;	
begin
	if self.cmbPrinter.listObject &lt;&gt; null then
		printerName := self.cmbPrinter.listObject.CM_PrinterDef.physicalPrinterName; //epr TFS 2401 21/7/16;
	endif;
	
	doEmail := self.tblPrintOptions.getValueByNameIfVisible(ETRow_DoEmail).Boolean;
	if self.myReportAgent.state = self.myReportAgent.STATE_TEMPLATE_VIEW then
		if doEmail then
			emailTemplate := app.createUpdateProxy(self.myMenuEntity.CM_MenuUserReport.myEmailTemplate).CM_EmailTemplate;
		endif;
		reportName 	:= self.tblPrintOptions.getValueByName(ETRow_TemplateName).String;
		reportDescr := self.tblPrintOptions.getValueByName(ETRow_TemplateDescription).String;
		user 		:= self.myMenuEntity.CM_MenuUserReport.myReportTemplate.myUserToRunAs;
	else
		reportName  := self.tblPrintOptions.getValueByName(ETRow_ReportName).String;
		reportDescr := self.tblPrintOptions.getValueByName(ETRow_ReportDescription).String;
		if doEmail then
			create emailTemplate transient;
		endif;
		user := app.getMyUser();
	endif;

	networkFilepath 		:= self.tblPrintOptions.getValueByNameIfVisible(ETRow_ServerFilePath).String;
	stopEmailWhenNoDataRpt  := not self.tblPrintOptions.getValueByNameIfVisible(ETRow_EmailNoDataRpt).Boolean;
	

    
	if doEmail then
		app.mousePointer := MousePointer_Default;
		if not self.doDisplayEmailForm(null, emailTemplate, true) then
			return;
		endif;
		app.mousePointer := MousePointer_HourGlass; 
	endif;
    
	formatOption := self.cmbFormat.itemData[self.cmbFormat.listIndex];
    
    if self.cmbFTPEntity.listObject &lt;&gt; null then                            //MTN-36668
        ftpEntity   := self.cmbFTPEntity.listObject.CM_FTPEntity;           //MTN-36668
    endif; 
	
	create userSet transient;
	userSet.add(user);
	
	//TFS 36427
	pxyFilter := _filter;
	if self.myMenuEntity.isKindOf(CM_MenuUserReport) then
		// If we are pressing print from a template, then grab any data from that instead
		if self.myMenuEntity.CM_MenuUserReport.isReportTemplate then
			eventData := self.myMenuEntity.CM_MenuUserReport.myReportTemplate.myReportRequest.allEventData;
			pxyFilter := _filter.cloneSelf(true);
			pxyFilter.setFromTemplate(_filter, app.actualTimeServer.date, eventData);
		endif;
	endif;
	
	//13 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxCA.trxCreateAndRunBackgroundRpt(	false,
												reportName,
												reportDescr,
												_profName,
												printerName,
												networkFilepath,
												formatOption,
												self.getOutputType(),
												stopEmailWhenNoDataRpt,
												pxyFilter,
												self.myReportAgent.myQryReport,
												_extraDetail,
												emailTemplate,
												user.code,
												userSet,
                                                ftpEntity,           //MTN-36668
												app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			statusLine.caption := app.getString( Report_Running_In_Background );
			break;
		else
			theResult := app.showErrorWarningDialog( statusLine.caption, app.myPassport, ErrWarnMode_Add );
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		statusLine.caption := app.getString( Report_Creation_Failed );
		return;
		
	endwhile;

	
epilog
	delete userSet;
	delete emailTemplate;
	if pxyFilter &lt;&gt; null and pxyFilter.isTransient then
		delete pxyFilter;
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="_filter" type="CMQF_FilterReports"/>
        <Parameter name="_extraDetail" type="CM_ExtraDetail"/>
        <Parameter name="_profName" type="String"/>
    </JadeMethod>
    <JadeMethod name="runBackgroundStandard" id="2a400f1e-cd87-4e18-89cb-df8addcafb75">
        <updating/>
        <source>runBackgroundStandard(
	_filter			: CMQF_FilterReports; 
	_extraDetail	: CM_ExtraDetail;
	_profName		: String) updating, protected;
// ---------------------------------------------------------------------------
// Created:     27 August 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
// 12 Jan 2018	jlgmd1		TFS #36427 - DQM - Vessel Schedule Report
vars
	reportName				: String;
	reportDescr				: String;
	printerName				: String;
	networkFilepath			: String;
	doEmail					: Boolean;
	stopEmailWhenNoDataRpt	: Boolean;
	emailTemplate			: CM_EmailTemplate;
	userSet					: CM_UserSet;
	user					: CM_User;
	pxyFilter				: CMQF_FilterReports;		//TFS 36427
	eventData				: CM_EventDataByTypeDict;	//TFS 36427
	theResult : Integer;	//13 Jan 2020 NDL	TFS 46815
	
begin
	if self.cmbPrinter.listObject &lt;&gt; null then
		printerName := self.cmbPrinter.listObject.CM_PrinterDef.physicalPrinterName; //epr TFS 2401 21/7/16;
	endif;
	
	doEmail := self.tblPrintOptions.getValueByNameIfVisible(ETRow_DoEmail).Boolean;
	if self.myReportAgent.state = self.myReportAgent.STATE_TEMPLATE_VIEW then
		if doEmail then
			emailTemplate := app.createUpdateProxy(self.myMenuEntity.CM_MenuUserReport.myEmailTemplate).CM_EmailTemplate;
		endif;
		reportName := self.tblPrintOptions.getValueByName(ETRow_TemplateName).String;
		reportDescr := self.tblPrintOptions.getValueByName(ETRow_TemplateDescription).String;
		user := self.myMenuEntity.CM_MenuUserReport.myReportTemplate.myUserToRunAs;
	else
		reportName := self.tblPrintOptions.getValueByName(ETRow_ReportName).String;
		reportDescr := self.tblPrintOptions.getValueByName(ETRow_ReportDescription).String;
		if doEmail then
			create emailTemplate transient;
		endif;
		user := app.getMyUser();
	endif;
	
	networkFilepath := self.tblPrintOptions.getValueByNameIfVisible(ETRow_ServerFilePath).String;
	stopEmailWhenNoDataRpt := not self.tblPrintOptions.getValueByNameIfVisible(ETRow_EmailNoDataRpt).Boolean;
		
	if doEmail then
		app.mousePointer := MousePointer_Default;
		if not self.doDisplayEmailForm(null, emailTemplate, true) then
			return;
		endif;
		app.mousePointer := MousePointer_HourGlass; 
	endif;
	
	create userSet transient;
	
	userSet.add(app.getMyUser());
	
	//TFS 36427
	pxyFilter := _filter;
	if self.myMenuEntity.isKindOf(CM_MenuUserReport) then
		// If we are pressing print from a template, then grab any data from that instead
		if self.myMenuEntity.CM_MenuUserReport.isReportTemplate then
			eventData := self.myMenuEntity.CM_MenuUserReport.myReportTemplate.myReportRequest.allEventData;
			pxyFilter := _filter.cloneSelf(true);
			pxyFilter.setFromTemplate(_filter, app.actualTimeServer.date, eventData);
		endif;
	endif;
	
	//13 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxCA.trxCreateAndRunBackgroundRpt(	false,
												reportName,
												reportDescr,
												_profName,
												printerName,
												networkFilepath,
												JadeReportWriterReport.PRINTER,
												self.getOutputType(),
												stopEmailWhenNoDataRpt,
												pxyFilter,
												self.myReportAgent.myQryReport,
												_extraDetail,
												emailTemplate,
												user.code,
												userSet,
                                                null,           //MTN-36668
												app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			statusLine.caption := app.getString( Report_Running_In_Background );
			break;
		else
			theResult := app.showErrorWarningDialog( statusLine.caption, app.myPassport, ErrWarnMode_Add );
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		statusLine.caption := app.getString( Report_Creation_Failed );
		return;
		
	endwhile;

	
epilog	
	delete userSet;
	delete emailTemplate;
	if pxyFilter &lt;&gt; null then
		if pxyFilter.isTransient then
			delete pxyFilter;
		endif;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_filter" type="CMQF_FilterReports"/>
        <Parameter name="_extraDetail" type="CM_ExtraDetail"/>
        <Parameter name="_profName" type="String"/>
    </JadeMethod>
    <JadeMethod name="runForegroundFileType" id="6eae6ff3-087a-4960-b8c8-0c4f729403b7">
        <updating/>
        <source>runForegroundFileType(_filter : CMQF_FilterReports; 
				_extraDetail : CM_ExtraDetail;
				_profName : String) updating, protected;
// ---------------------------------------------------------------------------
// Created:     27 August 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	fileName				: String;
	doEmail					: Boolean;
	formatOpt				: Integer;
	email					: CM_EmailTemplate;
	cmifMonitor				: CMIF_Monitor;
	noDataEmail				: Boolean;				// 10/08/2010 cnwmh5 #25358
begin
	if app.myPassport.myCMIFMonitor = null then
		create cmifMonitor transient;
		cmifMonitor.myParent := self;
		app.myPassport.setMyCMIFMonitor(cmifMonitor);
	endif;
	
	fileName := self.tblPrintOptions.getValueByName(ETRow_CsvFileName).String;
	if fileName = null then
//		app.msgBox('Please enter a file name', 'Report Runner', MsgBox_Stop_Icon);	// cnwrl1 11/11/2009 PAR 19951 - what it was
		app.msgBox(	app.getString( Must_EnterValid_FileName_First ),
					app.getString( Report_Runner ),
					MsgBox_OK_Only + MsgBox_Stop_Icon );
		return;
	endif;
	
	doEmail := self.tblPrintOptions.getValueByName(ETRow_DoEmail).Boolean;
	if doEmail then
		create email transient;
		app.mousePointer := MousePointer_Default;
		if not self.doDisplayEmailForm(fileName, email, true) then
			return;
		endif;
		app.mousePointer := MousePointer_HourGlass; 
	endif;

	self.modalDialogReturnValue	:= ModalDialogReturn_Null;
//	self.modalDialogShow(null, 'Return Data', 'Cancel', null, 'Searching for data', null);	// cnwrl1 11/11/2009 PAR 19951 - what it was
	self.modalDialogShow(	null,
							app.getString( ReturnData ),
							app.getString( Cancel ),
							null,
							app.getString( SearchingForData ),
							null );
	
	formatOpt := self.cmbFormat.itemData[self.cmbFormat.listIndex];
	self.myReportAgent.runForegroundReport(	self.myReportAgent.myQryReport,
											_filter,
											_extraDetail,
											_profName,
											formatOpt,
											fileName,
											null,
											self.tblPrintOptions.getValueByName(ETRow_PrintPreview).Boolean, 
											noDataEmail);						// 10/08/2010 cnwmh5 #25358
	if doEmail and not noDataEmail then						// 10/08/2010 cnwmh5
		self.createEmail(email);
	endif;
	
epilog
	self.progressFinish();
	delete email;
	delete cmifMonitor;
	app.myPassport.setMyCMIFMonitor(null);
	
end;</source>
        <access>protected</access>
        <Parameter name="_filter" type="CMQF_FilterReports"/>
        <Parameter name="_extraDetail" type="CM_ExtraDetail"/>
        <Parameter name="_profName" type="String"/>
    </JadeMethod>
    <JadeMethod name="runForegroundStandard" id="adc58c4d-c780-4678-8fc1-cbda1854c76d">
        <updating/>
        <source>runForegroundStandard(
	_filter			: CMQF_FilterReports; 
	_extraDetail	: CM_ExtraDetail; 
	_profName		: String ) updating, protected;
// ---------------------------------------------------------------------------
// Created:     27 August 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	cmifMonitor				: CMIF_Monitor;
	noDataEmail				: Boolean;					// 10/08/2010 cnwmh5 #25358
begin
	if app.myPassport.myCMIFMonitor = null then
		create cmifMonitor transient;
		cmifMonitor.myParent := self;
		app.myPassport.setMyCMIFMonitor(cmifMonitor);
	endif;
	
	self.modalDialogReturnValue	:= ModalDialogReturn_Null;
//	self.modalDialogShow(null, 'Return Data', 'Cancel', null, 'Searching for data', null);	// cnwrl1 11/11/2009 PAR 19951 - what it was
	self.modalDialogShow(	null,
							app.getString( ReturnData ),
							app.getString( Cancel ),
							null,
							app.getString( SearchingForData ),
							null );
	
	self.myReportAgent.runForegroundReport(	self.myReportAgent.myQryReport,
											_filter,
											_extraDetail,
											_profName,
											JadeReportWriterReport.PRINTER,
											null,
											null,
											self.tblPrintOptions.getValueByName(ETRow_PrintPreview).Boolean,
											noDataEmail);											// 10/08/2010 cnwmh5 #25358
	
epilog
	self.progressFinish();
	delete cmifMonitor;
	app.myPassport.setMyCMIFMonitor(null);
	
end;</source>
        <access>protected</access>
        <Parameter name="_filter" type="CMQF_FilterReports"/>
        <Parameter name="_extraDetail" type="CM_ExtraDetail"/>
        <Parameter name="_profName" type="String"/>
    </JadeMethod>
    <JadeMethod name="runSelectorQueryForCargoIDs" id="23e2a205-242e-4191-bf5c-63e371afa15f">
        <updating/>
        <source>runSelectorQueryForCargoIDs(_qryReport : CM_QryReport) : CM_EnqControllerTI updating, protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 13/02/2018	jlgdap1		Initial creation TFS 37030 SSL Demurrage Report
//
vars
	filter : CMQF_InvoiceProforma;
	selectorQuery : CM_MenuUserQuery;
	invalid : Boolean;
	name : String;
	enqController : CM_EnqControllerTI;
	queryDefinition : CM_QueryDefinition;
	any : Any;
	ti : CM_TrackedItem;
	str, id : String;

begin
	if _qryReport = null or _qryReport.myFilterObject = null or not _qryReport.myFilterObject.isKindOf(CMQF_InvoiceProforma) then
		return null;
	endif;
	
	// we have a proforma invoice query - do we have a selector query?
	filter := _qryReport.myFilterObject.CMQF_InvoiceProforma;
	selectorQuery := self.myReportAgent.CMUI_ReportAgentStd.getSelectedQuery();
	if selectorQuery = null then
		return null;
	endif;
	on Exception do app.handleDeletedObject(exception, selectorQuery, invalid);
	name := selectorQuery.heading;
	if invalid then
		return null;
	endif;
	
	// run the selector query, and put the resulting list of cargo IDs in the cargo ID criteria
	queryDefinition := app.myRoot.allQueryDefinitionObjects[CM_QueryDefinition.TrackedItem_Query_Type, 0];
	create enqController transient;
	create enqController.allObjects as ObjectSet transient;
	enqController.myCriteriaLineHolder := selectorQuery.allCriteriaLineHolders.first;
	enqController.doQuery(queryDefinition);
	
	// get the ids of all the returned TIs
	foreach any in enqController.allObjects discreteLock do
		ti := any.CM_TrackedItem;
		if str &lt;&gt; null then
			str := str &amp; ",";
		endif;
		str := str &amp; ti.id;
	endforeach;
	
	id := self.tblParameter.getValueByNameIfVisible(ETRow_CargoId).String;
	if id &lt;&gt; null then
		str := str &amp; "," &amp; id;
	endif;
	self.tblParameter.setValueByName(ETRow_CargoId, str);
	
	return enqController;// ### TFS CR 65817 TASK 65819 27AUG2024 NAVAB1

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_qryReport" type="CM_QryReport"/>
        <ReturnType type="CM_EnqControllerTI"/>
    </JadeMethod>
    <JadeMethod name="selectorControlLostFocus" id="fbedef0c-e5e2-461a-be46-8dbaac476b8f">
        <updating/>
        <source>selectorControlLostFocus(_table : CM_EntryTable input;
						_row : Integer;
						_rowName : String;
						_value : Any) updating;
// ---------------------------------------------------------------------------
// Created:     20 January 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
// 04 Sep 2019	jlgsl4	TFS 46287 - SNO - Selector Query Invoice Report error

vars
	control			: Control;
	value			: String;
	entRowEntity	: EntTableRowTransient;
	str				: String;
begin
	control := _table.accessCell(_row, _table.ColumnValue).cellControl;

	if ComboBox.hasInstance(control) then
		_table.setCellText(_row, _table.ColumnValue, control.ComboBox.text);
	elseif TextBox.hasInstance(control) then
		_table.setCellText(_row, _table.ColumnValue, control.TextBox.text);
	elseif CMUI_ListTable.hasInstance(control) then
		//par 19979 cnwjo3, accidently removed line during par 17512
		entRowEntity := _table.accessRow(_row).itemObject.EntTableRowTransient;
		
		_table.accessedRow.height := self.saveRowHeight.Integer;
		self.saveRowHeight := 0;
		_table.scrollBars := _table.ScrollBars_Both;
		//global.processDebug("CNWJC2", true);
		// For selector controls the shortHeading contains the field name, hence no terminology translation
		str := control.CMUI_ListTable.getSelectedString(entRowEntity.shortHeading);
		
		_table.setValue(_row, str);
		if entRowEntity.getHeadingUnaltered() &lt;&gt; self.INVOICETYPE_ISONEOF then // TFS 46287 - stops **Any** being left in a too-high row...
			_table.adjustHeight(300);
		endif; // TFS 46287
	elseif CMUI_DateMask.hasInstance(control) then
		_table.setCellText(_row, _table.ColumnValue, control.CMUI_DateMask.text);		
	elseif CMUI_TimeMask.hasInstance(control) then	//23 Jun 2020	NDL	TFS 49221
		_table.setCellText(_row, _table.ColumnValue, control.CMUI_TimeMask.text);		
	endif;	
end;</source>
        <Parameter name="_table" type="CM_EntryTable" usage="input"/>
        <Parameter name="_row" type="Integer"/>
        <Parameter name="_rowName" type="String"/>
        <Parameter name="_value" type="Any"/>
    </JadeMethod>
    <JadeMethod name="setColorsFromController" id="b14383c9-3742-4e66-b099-985481802b64">
        <updating/>
        <source>setColorsFromController(_colorControl: CM_ColorController) updating;
// ---------------------------------------------------------------------------
// Created:     28 July 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpBackColor	: Integer;

begin
	inheritMethod(_colorControl);
	
	tmpBackColor := self.backColor;
	
	self.frmHeaderDtl.backColor		:= tmpBackColor;
	
	self.grpLeft.backColor			:= tmpBackColor;
	self.grpOutputOptions.backColor	:= tmpBackColor;
	self.grpReports.backColor		:= tmpBackColor;
	self.grpRight.backColor			:= tmpBackColor;
	self.grpTerminals.backColor		:= tmpBackColor;
	self.grpBoxTemplate.backColor	:= tmpBackColor;
	
	self.lbReportTree.backColor		:= self.colorControlBack;

	self.setColorsForEntryTable(self.tblBGPEnt);
	self.setColorsForTable(self.tblBGPReports);
	self.setColorsForEntryTable(self.tblParameter);
	self.setColorsForEntryTable(self.tblPrintOptions);
	
	self.fldReport.backColor		:= tmpBackColor;
	
	self.setColorsForMultiSelectGrpBox(self.multiGrpOutput);
	self.multiGrpOutput.backColor	:= tmpBackColor;
	
	self.setColorsForMultiSelectGrpBox(self.multiGrpEdit);
	self.multiGrpEdit.backColor	:= tmpBackColor;

end;</source>
        <Parameter name="_colorControl" type="CM_ColorController"/>
    </JadeMethod>
