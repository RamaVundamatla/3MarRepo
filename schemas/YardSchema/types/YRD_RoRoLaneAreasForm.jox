    <JadeMethod name="doMnuResetFreedAllClick" id="86893620-21c6-47b4-a35e-e8cd86c17434">
        <updating/>
        <source>doMnuResetFreedAllClick(_menuItem: MenuItem input) protected, updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
15 January 2010	cnwjk3	Initial creation

*/

vars
	ta	: CM_RoRoLaneArea;
	lc	: CM_RoRoController;
begin
	if _menuItem.userObject &lt;&gt; null and _menuItem.userObject.isKindOf(CM_RoRoLaneArea) then
		ta := _menuItem.userObject.CM_RoRoLaneArea;
		foreach lc in ta.allLanesById do
			//if lc.freedLength &gt; 0 then	// cnwjk3 PAR 23443 26/03/2010 
				app.myTrxUA.trxUpdateRoRoLaneFreedLength(lc, 0, app.myPassport );
			//endif;						// cnwjk3 PAR 23443 26/03/2010 
		endforeach;
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_menuItem" type="MenuItem" usage="input"/>
