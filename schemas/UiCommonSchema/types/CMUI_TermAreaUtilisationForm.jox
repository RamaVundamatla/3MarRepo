    <JadeMethod name="setupForm" id="ccb234cd-1dcc-4344-a57d-84606830542c">
        <updating/>
        <source>setupForm() updating;
// ---------------------------------------------------------------------------
// Created:		November 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars

begin

	self.usesQueryFrame := true;
	self.useTableInfo := true;
	self.useTableSorting := true;
	self.toolbarStyle := self.ToolbarStyle_ShowNoHide;
	self.showToolbar := true;
	
	inheritMethod();
	
	create self.myQueryAgent transient;
	create self.mySummaryLine transient;
	create self.myBSSummary transient;
	create self.myBulkSummary transient;
	create self.myGCSummary transient;
	create self.myGridSummary transient;
	create self.myRoroSummary transient;
	
	self.mnuContextHide.visible := false;
	
	self.splMain.top := 0;
	self.splMain.hideRightControl(true);
	
	self.doListBoxTermAreaBuild();
	
	self.doComboTABuild();
	
	self.initTableData(null);
	
	self.mnuContextColourLegend.visible := false;
	self.mnuColumnOrganiser.visible := false;

	self.doResetSearch();
	self.getXMLSettingsForSetup();
end;</source>
