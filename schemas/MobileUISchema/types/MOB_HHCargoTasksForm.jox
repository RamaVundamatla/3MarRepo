    <JadeMethod name="addToDoTask" id="e4d96ff2-0cdc-41bf-a05f-dc22d1c8c981">
        <source>addToDoTask(_ti: CM_TrackedItem ;  _toDo: CM_ToDoTaskDesc) : Boolean;
//20 June 2014	cnwdw1	
//
vars

begin
	if _ti = null or _ti.hasToDoTaskToDoWithCode(_toDo.code) then
		return true;
	endif;
	
	return self.getSessionAgent().updateTiToDoTask(_toDo.code, true);
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_toDo" type="CM_ToDoTaskDesc"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
