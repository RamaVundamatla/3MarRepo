    <JadeMethod name="setOptions" id="5a8f3f69-e99e-42e0-8dce-06e971df0a99">
        <source>setOptions();
// ---------------------------------------------------------------------------
// Created:		06 September 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	type, idx : Integer;
	value : Boolean;
begin

	self.allOptions.clear;
	self.allValues.clear;
	
	foreach idx in 1 to 4 do
		type := self.tblData.accessCell(idx, self.TblCol_Type).text.Integer;
		value := self.tblData.accessCell(idx, self.TblCol_Tick).text.Integer.Boolean;
		
		self.allOptions.add(type);
		self.allValues.add(value);
	
	endforeach;

end;</source>
    </JadeMethod>
    <JadeMethod name="setYardAreaFlipped" id="ddc0b7bb-9daf-4bb3-afca-18ebdc794245">
        <source>setYardAreaFlipped();
// ---------------------------------------------------------------------------
// Created:		09 October 2006 By Andrew Bishop cnwab1
//
// Purpose:		In the yard grid areas the users can flipped the display. If they have 
//					we need to flip the row and col that we use in the dict to sort the TIs
//
// ---------------------------------------------------------------------------
vars
	userWindow		: CM_UserWindow;
	theXML, theXMLValue : String;
	flipH, flipV, hideL,hideT,hideM : Boolean;
	zoomScale : Real;
begin
	userWindow := app.getUserWindow("YRD_GridAreasForm", false);
	if userWindow = null then
		return;
	endif;
	theXML := userWindow.xmlInfo;

	// #### FLIP HORIZONTAL
 	theXMLValue := theXML.cnEcGetTagValueOfName("FH");
 	flipH := false;
 	if theXMLValue &lt;&gt; null then
 		flipH := theXMLValue.Integer.Boolean;
 	endif;
 	
 	// #### FLIP VERTICAL
 	theXMLValue := theXML.cnEcGetTagValueOfName("FV");
 	flipV := false;
 	if theXMLValue &lt;&gt; null then
 		flipV := theXMLValue.Integer.Boolean;
 	endif;
	
	if self.chkColReversed.value then // they want to plan from the opposite ends of the rows so reverse the columns
		flipH := not flipH;
	endif;

	self.myController.setYardAreaFlipped(flipH, flipV);
end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="541f212e-7942-4670-bece-332ff5e45fd7">
        <updating/>
        <source>setupForm() updating;
// ---------------------------------------------------------------------------
// Created:		29 August 2006 By Andrew Bishop cnwab1
//
//	Changed On   Changed By  Reason
//	19/2/2009	 cnwcp2		 PAR# 18073 - app method call can result in incorrect terminal being returned
// ---------------------------------------------------------------------------
vars
	str : String;
	totTIs, aveWGT : Integer;
	midTI : CM_TrackedItem;
begin
//	self.grpMain.ignoreSkin := true;
	self.grpYard.ignoreSkin := true;
	self.grpYardTop.ignoreSkin := true;
	self.grpYardBot.ignoreSkin := true;
	self.grpOther.ignoreSkin := true;
	self.grpWeight.ignoreSkin := true;
	self.btnUnplan.enabled := false;	
	self.btnShowNonPlan.enabled := false;
	self.handleMenusForModalDisplay();
	self.toolbarStyle	:= self.ToolbarStyle_ShowNoHide;
	self.showToolbar	:= true;
	if self.myTerminal = null then // This is already set elsewhere so don't need to set it here unless it is null
		self.myTerminal	:= app.getMyTerminalDO_NOT_USE();
	endif;
	self.getXMLSettingsForSetup();
	
	inheritMethod();

	
	if self.myCurrentVoyage &lt;&gt; null then
		self.caption := "Fully Load Plan " &amp; self.myCurrentVoyage.code;
	elseif self.myCurrentJS &lt;&gt; null then
		self.myCurrentVoyage := self.myCurrentJS.myVoyage;
		self.caption := self.myCurrentVoyage.code &amp; " - Fully Load Plan " &amp; self.myCurrentJS.crane;
	elseif self.allJobs &lt;&gt; null then
		str := self.allJobs.getName();
		if str.length &gt; 50 then
			str := self.allJobs.size.String &amp; " Jobs";
		endif;
		self.caption := "Fully Load Plan Jobs - " &amp; str;
		if self.allJobs.isEmpty then
		else
			self.myCurrentVoyage := self.allJobs.first.CM_VoyageJob.myVoyage;
			self.caption := self.myCurrentVoyage.code &amp; " - " &amp; self.caption;
		endif;
	endif;

	if self.allJobs.isEmpty then
		
		self.unloadForm();
		app.msgBox("Please select some load export jobs to plan.", "No Jobs",MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	
	create self.myController transient;
	self.init(true);
	/*
	self.myController.init(self.myTerminal, self.mode, self.allJobs, self.myCurrentJS, self.myCurrentVoyage, false, null, null, null, null, self,false,null,null );
	self.myController.initQuery();
	self.setYardAreaFlipped();

	self.getAverageWeight();
	self.doDisplayStatus(null);
	*/
end;</source>
    </JadeMethod>
