    <JadeMethod name="isStockControlled" id="8c321dfa-646b-47ad-a4da-e5a10b6389db">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <source>isStockControlled(set: Boolean; _value: Boolean io) mapping, updating;
// ---------------------------------------------------------------------------
// Created:     24 May 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	tmpLC	: CM_LocationsController;
	ls		: Boolean;

begin

	if (not set) then
		_value := self.isStockControlled;
	else
		app.cmsBeginLoad(ls);	
		sharedLock(self);
		if self.isStockControlled = _value then
			// no change
			return;
		endif;
	
		foreach tmpLC in self.allLocationsControllers do
			sharedLock(tmpLC);
			if tmpLC.canBeStockControlled then
				if tmpLC.numTIs &gt; 0 then
					app.raiseCMException(StockControlFlagAreaNotEmpty, 'isStockControlled', null);
					break;
				endif;
			endif;
		endforeach;
	endif;

epilog
	app.cmsEndLoad(ls);	

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Boolean" usage="io"/>
    </JadeMethod>
