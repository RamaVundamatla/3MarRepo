    <JadeMethod name="logExcelException" id="4b9c2010-f364-42a1-83e3-5b1abd910e7e">
        <source>logExcelException( ex : Exception );

/*****************************************************
	Written by	:	cnwpra1		10 May 2004
	Description	:	

	Change history
	--------------
	Date		By		Reason
******************************************************/

vars
	// used to trap exceptions in the Excel app
	log : JadeLog ;
	
begin
	create log transient ;
	log.fileName := 'ExcelSchema';
	log.infoServer( "================================================================") ;
	log.infoServer( "Exception Occured at: " &amp; app.actualTimeServer.String ) ;
	log.infoServer( ex.errorCode.String ) ;
	log.infoServer( ex.errorItem ) ;
	log.infoServer( ex.extendedErrorText ) ;
	if ex.currentMethodDesc &lt;&gt; null then
		log.infoServer( ex.currentMethodDesc.getName ) ;
	endif ;
	if ex.reportingMethodDesc &lt;&gt; null then
		log.infoServer( ex.reportingMethodDesc.getName ) ;
	endif ;
	ex.logExceptionHistory(log.getActualFileNameServer);
	ex.logProcessHistory(log.getActualFileNameServer);
	
epilog
	delete log ;
end;</source>
        <Parameter name="ex" type="Exception"/>
    </JadeMethod>
