    <JadeMethod name="findLocationOutward" id="9d894f60-9e01-4f23-b50e-c7b8e1c02cd1">
        <source>findLocationOutward() : CM_LocationsController;
// 09/02/2010	cnwjre1	CCMS 1101
vars
	lc,
	lcOut : CM_LocationsController;
begin
	foreach lc in self.allYardControllers do
		if lc.allTrackedItems.size &gt; 0 then
			lcOut := lc;
			break;
		endif;
	endforeach;

	return lcOut;
end;
</source>
        <ReturnType type="CM_LocationsController"/>
    </JadeMethod>
    <JadeMethod name="getAllocationRanges" id="a7a1a31b-cc27-4f39-a0e7-2388757c8505">
        <source>getAllocationRanges( _strArray : StringArray input );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 February 2014	cnwndl1	Initial creation	Par 33607

*/

vars

	blockIn : CM_YABlock;

begin

	if _strArray = null then
		return;
	endif;
	
	_strArray.clear();

	//07 Mar 2014	NDL	Par 33665
	foreach blockIn in self.allYABlocksIn do	
		_strArray.add( blockIn.getDisplayDetails(false) );
	endforeach;

epilog

end;</source>
        <Parameter name="_strArray" type="StringArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getAuditText" id="c7473b06-efb4-492f-85a9-5067553e4248">
        <source>getAuditText(): String;
// ---------------------------------------------------------------------------
// Created:     07 February 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	txt,
	tmpStr : String;
	ta : CM_TerminalArea;
	criteria : CM_YACriteria;
begin
	txt[10000] := '*';
	txt := null;
	txt := inheritMethod();
	return(txt);
	foreach criteria in self.allCriteria do
//		tmpStr := criteria.auditId();
//		if tmpStr &lt;&gt; null then
//			txt := txt &amp; criteria.auditIdDisplay() &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;
//		endif;
		tmpStr := criteria.getAuditText();
		if tmpStr &lt;&gt; null then
			txt := txt &amp; tmpStr;
		endif;
	endforeach;
	foreach ta in self.allTerminalAreas do
		tmpStr := ta.auditId();
		if tmpStr &lt;&gt; null then
			txt := txt &amp; ta.auditIdDisplay() &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;
		endif;
	endforeach;
	if self.myYAOverstowRule &lt;&gt; null then
		txt := txt &amp; self.myYAOverstowRule.auditIdDisplay();
	endif;
	return txt;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getAuditTextForProperty" id="ec7cbbf5-db49-45f7-ab17-b01799c84ee5">
        <source>getAuditTextForProperty(_property: Property): String;

vars
	block : CM_YABlock;
	criteria : CM_YACriteria;
	txt : String;
begin
//	Revised auditing of criteria during rework of yard allocations - SFW1030 21/08/2008
/*	txt[10000] := '*';
	txt := null;
	if _property.name = CM_YardAllocation::allCriteria.name then
		txt := txt &amp; self.formatAuditText(_property.name, null);
		foreach criteria in self.allCriteria do
			txt := txt &amp; criteria.getAuditText();
			return txt;
		endforeach;
	endif;
*/
	if _property.name = CM_YardAllocation::allCriteria.name then
		return self.formatAuditText( _property.name, self.getCriteriaString().replaceString(Cr, ", ") );
	elseif _property.name = CM_YardAllocation::allYardControllers.name then
		return self.formatAuditText( _property.name, self.allYardControllers.getDisplay() );
	elseif _property.name = CM_YardAllocation::allYABlocksOut.name then
		foreach block in self.allYABlocksIn do
			txt := txt &amp; self.formatAuditText( "allYABlocks[" &amp; block.auditId &amp; "]", block.getAuditDisplayForYA() );
		endforeach;
		return inheritMethod(_property) &amp; txt;
	elseif _property.name = CM_YardAllocation::allowOthersOption.name then
		return self.formatAuditText( _property.name, app.yaOverlapFlagToString(self.allowOthersOption) );
	elseif _property.name = CM_YardAllocation::expiryType.name then
		return self.formatAuditText( _property.name, app.yaExpiryFlagToString(self.expiryType) );
	elseif _property.name = CM_YardAllocation::fillOptionIn.name then
		return self.formatAuditText( _property.name, app.yaFillOptionToString(self.fillOptionIn) );
	elseif _property.name = CM_YardAllocation::fillOptionOut.name then
		return self.formatAuditText( _property.name, app.yaFillOptionToString(self.fillOptionOut) );
	elseif _property.name = CM_YardAllocation::noLocationOption.name then
		return self.formatAuditText( _property.name, app.yaNoLocationFlagToString(self.noLocationOption) );
	endif;

	return inheritMethod(_property);
end;</source>
        <Parameter name="_property" type="Property"/>
        <ReturnType type="String"/>
    </JadeMethod>
