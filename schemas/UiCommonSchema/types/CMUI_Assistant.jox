    <JadeMethod name="comboBoxCustomDetails" id="4cf9580a-9504-447c-900c-296fd8f43cb2">
        <source>comboBoxCustomDetails(pCmb : ComboBox input; customDetails : String; pConsignor :CM_ConsigneeConsignor );
// ---------------------------------------------------------------------------
// Created:     29 April 2002 by cnwdf1
//
// Purpose:     FOR POPULATE CUSTOM EXPORT ENTRY NUMBER 
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	pCmb.sorted := false;
	pCmb.clear;
    pCmb.addItem(CUSTOMDETAILS_VARIOUS);
    pCmb.addItem(CUSTOMDETAILS_TRANSSHIPMENT);
    pCmb.addItem(CUSTOMDETAILS_EXEMPT);
    pCmb.addItem(CUSTOMDETAILS_NIL_CUSTOMS);
    if pConsignor &lt;&gt; null then
  	 	if pConsignor.derogationNumber &lt;&gt; null then
    		pCmb.addItem(pConsignor.derogationNumber);
    	endif;
    endif;	
	if customDetails &lt;&gt; null then
		pCmb.text := customDetails;
	endif;
end;</source>
        <Parameter name="pCmb" type="ComboBox" usage="input"/>
        <Parameter name="customDetails" type="String"/>
        <Parameter name="pConsignor" type="CM_ConsigneeConsignor"/>
    </JadeMethod>
    <JadeMethod name="comboBoxCustomerPriority" id="37f5fc32-c454-4f56-8483-a4cca9174b4f">
        <source>comboBoxCustomerPriority(_cmb : ComboBox input; _customerPriority : CM_CustomerPriority);
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 14 November 2023
TFS#		: 61130
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

vars
	customerPriorityDict	: CM_CustomerPriorityByCodeDict;
	customerPriority		: CM_CustomerPriority;
	form					: Form;
	
begin
	_cmb.clear();
	customerPriorityDict := app.myRoot.allCustomerPriorities;
	_cmb.addItem("");
	
	form := _cmb.form;
	
	foreach customerPriority in customerPriorityDict do
		_cmb.itemObject[_cmb.addItem(customerPriority.getDisplayDetails(false))] := customerPriority;
	endforeach;
	
	customerPriority := null; //Reset from above
	
	if _customerPriority &lt;&gt; null then
		customerPriority := customerPriorityDict[_customerPriority.code];
	endif;
	
	if customerPriority &lt;&gt; null then
		_cmb.listObject := customerPriority;
	endif;
	
end;</source>
        <Parameter name="_cmb" type="ComboBox" usage="input"/>
        <Parameter name="_customerPriority" type="CM_CustomerPriority"/>
    </JadeMethod>
    <JadeMethod name="comboBoxCustomsAgent" id="331818d3-ffaa-45fd-a6ef-0c8d1c995262">
        <source>comboBoxCustomsAgent(_cmb : ComboBox input; _customsAgent : CM_CustomsAgent);
// ---------------------------------------------------------------------------
// Created:     May 2006 cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	_cmb.sorted := true;
	_cmb.listCollection(app.myRoot.allCustomsAgents, true, 0);
	if _customsAgent &lt;&gt; null then
		_cmb.listIndex := _cmb.findObject(_customsAgent);
	endif;
end;</source>
        <Parameter name="_cmb" type="ComboBox" usage="input"/>
        <Parameter name="_customsAgent" type="CM_CustomsAgent"/>
    </JadeMethod>
    <JadeMethod name="comboBoxCustomsAgentCashOnlyDr" id="5959fa6c-73b7-42d4-ad07-190ecc20513d">
        <source>comboBoxCustomsAgentCashOnlyDr(_combo : ComboBox input; _customsAgent : CM_CustomsAgent; _term : CM_Terminal);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 November 2013	cnwndl1	Initial creation

*/

vars
	customsAgent : CM_CustomsAgent;
	passport : CM_Passport;
	failedDAC : CM_DataAccessController;
	terminal : CM_Terminal;
begin

	_combo.clear();
	
	passport	:= app.myPassport;
	terminal := _term;
	if terminal = null and passport &lt;&gt; null then
		terminal := passport.myTerminal;
	endif;

	foreach customsAgent in app.myRoot.allCustomsAgents do
		//if we don't have access to the customsAgent passed in, list it - it SHOULD be included regardless
		if (not customsAgent.canUserAccessSelf(null, failedDAC, passport) or customsAgent.isNotAvailableForEntry) and (customsAgent &lt;&gt; _customsAgent) then
			continue;
		endif;
		
		if customsAgent.myDebtor = null or not customsAgent.myDebtor.isCashOnlyDebtor( terminal ) then
			continue;
		endif;
		
		_combo.itemObject[_combo.addItem(self.displayEntryCustomsAgent(customsAgent))] := customsAgent;
	endforeach;
	
	if _customsAgent &lt;&gt; null and _combo.findObject(_customsAgent) &gt; 0 then			
		_combo.listObject := _customsAgent;
	endif;

end;</source>
        <Parameter name="_combo" type="ComboBox" usage="input"/>
        <Parameter name="_customsAgent" type="CM_CustomsAgent"/>
        <Parameter name="_term" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="comboBoxCustomsEntryField" id="6a89e3e4-96c3-455e-9c20-397a5489c010">
        <source>comboBoxCustomsEntryField(_cmb : ComboBox input; _value : Integer);

vars
	baseScm 			: Schema;
	category 			: ConstantCategory;
	constDict			: ConstantNDict;
	const 				: Constant;
	idx, lstIdx 		: Integer;
	newEntryIndex	: Integer;
	text : String;
begin
	baseScm := rootSchema.getSchema(PortSchemaName);
	category := baseScm.getCategory(StopRequiredFields);
	constDict := category.getConstants();
	_cmb.clear();
	foreach const in constDict do
//write 'name='&amp;const.name&amp;' text='&amp;const.text&amp;' source='&amp;const.source.String;
	newEntryIndex := _cmb.addItem(const.text);
		_cmb.itemData[newEntryIndex] := const.getSource().Integer;
		idx := idx + 1;
		if const.getSource().Integer = _value then
			lstIdx := idx;
			text := const.text;
		endif;
	endforeach;
	if lstIdx &lt;&gt; 0 then
		_cmb.listIndex := lstIdx;
		_cmb.lostFocus(_cmb);
	endif;
end;
</source>
        <Parameter name="_cmb" type="ComboBox" usage="input"/>
        <Parameter name="_value" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="comboBoxDamageCodes" id="59efa20f-1ad3-4788-aa5c-89cb34fed8fc">
        <source>comboBoxDamageCodes(_cmb : ComboBox; _damageInterface : IF_DamageDetails);
//----------------------------------------------------------------------
//  Created by cnwsh3
//	Date 22 July 2009
//
// Implemented version: 7.7.3
// 22/07/2009 	cnwsh3 		CCMS SFW1066 PAR20321 - Recording Damage Details Changes.
//----------------------------------------------------------------------
vars
	damageCode : CM_DamageDefinitionCode;
	idx : Integer;
	collection : CM_DamageDefinitionByCodeDict;
begin
	create collection transient;

	if 	_damageInterface &lt;&gt; null then
		_damageInterface.getDamageCodes(collection);
	endif;
	
	foreach damageCode in collection do
		idx := _cmb.addItem(damageCode.code &amp; ' - ' &amp; damageCode.description);
		_cmb.itemObject[idx] := damageCode;
	endforeach;

epilog
	delete collection;
end;</source>
        <Parameter name="_cmb" type="ComboBox"/>
