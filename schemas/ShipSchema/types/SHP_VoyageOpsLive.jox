    <JadeMethod name="buildComboCargoType" id="bb022cb5-df2f-40c5-8eea-7c0de6ba42e9">
        <source>buildComboCargoType();
/*
Purpose:			

Date		Who		Reason
02 March 2023	navab1	TFS CR 56806 TASK 56807
*/

vars
	ct : CM_CargoType;
	cbt : CM_CargoBOLType;
	idx : Integer;
begin
	self.cmbCargoType.clear();
	self.cmbCargoType.sorted := true;
	
	foreach cbt in self.myTerminal.allCargoBOLTypes do
		if cbt.isKindOf(CM_BOLType) then // ### CUX BUG 57417 30MAR2023 NAVAB1
			continue;
		endif;
		
		ct := cbt.CM_CargoType;
		idx := self.cmbCargoType.addItemObject(ct.description, ct);
	endforeach;
	
	self.cmbCargoType.sorted := false;
	self.cmbCargoType.addItemAt("",1);
epilog

end;</source>
    </JadeMethod>
