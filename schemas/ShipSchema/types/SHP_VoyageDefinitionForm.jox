    <JadeMethod name="getMovementsWithOrientToChange" id="30c59a22-21e9-4a5c-97de-f5c0414d2bfb">
        <source>getMovementsWithOrientToChange(	_realVoyage,
								_pxyVoyage : CM_Voyage;
								_movementsToUpdate : HMS_VoyageMovementSet input);
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28 Sep 2009	cnwer1	Initial creation
19 Feb 2024	jlika1	TFS 62137 CUX | Shortlanded cargo
*/

vars
	allMovementsAtPhysicalWharf : HMS_MovementSet;
	sideTo ,result		: Integer;
	listTableSelectForm : CMUI_ListTableSelectForm;
	orientDesc 	: String;		
begin
	_movementsToUpdate.clear;
	if _realVoyage.myHMSVoyageData = null then
		return;
	endif;
	
	create allMovementsAtPhysicalWharf transient;
	if _pxyVoyage.starboardBerthed	then
		sideTo:= OrientPortSideTo ;
		orientDesc:=app.sideToNumToString(OrientStarboardSideTo);
	else
		sideTo:= OrientStarboardSideTo ;
		orientDesc:=app.sideToNumToString(OrientPortSideTo);
	endif;
	
	_realVoyage.myHMSVoyageData.getAllMovementsPhysicalWharf(allMovementsAtPhysicalWharf,sideTo);
	
	if allMovementsAtPhysicalWharf.size = 1 then
		result:=app.msgBox(app.getErrorString1(Voyage_Movement_Orientation,orientDesc),app.getErrorString(Update_Movements_Orientation),MsgBox_Yes_No);
		if result = MsgBox_Return_Yes then
			allMovementsAtPhysicalWharf.copy(_movementsToUpdate);
		endif;
	elseif allMovementsAtPhysicalWharf.size &gt; 1 then
		create listTableSelectForm transient;
		listTableSelectForm.initForm(app.getErrorString1(Voyage_Movement_Orientation,orientDesc) &amp; CrLf &amp; app.getErrorString(Select_Movements_Update) ,allMovementsAtPhysicalWharf,HMS_Movement::getDescription.name, false);
		listTableSelectForm.caption:=app.getErrorString(Update_Movements_Orientation);
		listTableSelectForm.btnOk.caption:=app.getErrorString(Yes);
		listTableSelectForm.btnCancel.caption:=app.getErrorString(No);
		result :=listTableSelectForm.showModal;
		if result = IDOK then
			listTableSelectForm.lstSelect.allSelectedObjects.copy(_movementsToUpdate);	
		endif;
	endif;

epilog
	delete allMovementsAtPhysicalWharf;
	delete listTableSelectForm;
end;</source>
        <Parameter name="_realVoyage" type="CM_Voyage"/>
        <Parameter name="_pxyVoyage" type="CM_Voyage"/>
        <Parameter name="_movementsToUpdate" type="HMS_VoyageMovementSet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getOpCriteriaColl" id="5d428c28-8a0f-484f-9441-a242fe43abed">
        <source>getOpCriteriaColl(_opCriteriaColl : CM_YACriteriaTypeArray io);
// --------------------------------------------------------------------------------
// Created:		7 December 2009 by cnwjo3
//
// Purpose:		Get operational criteria from allSelected string array.  Note, this order needs to be specific.  Has to follow the
//				same order as what is in the listbox.  NOTE: Copied from SHP_VoyageDefinitionForm.  Maybe move to
//				CMUI_Assistant ???????
//
vars
	s : String;
	ct : CM_YACriteriaType;
	indx : Integer;
	critDesc : String;
begin
	foreach indx in 1 to self.allSelected.size do
		ct := null;
		critDesc := self.allSelected[indx];
		foreach ct in self.allCriteriaTypesForVoyage do
			if critDesc = ct.description then
				_opCriteriaColl.add(ct);
				break;
			endif;
		endforeach;
	endforeach;
end;</source>
        <Parameter name="_opCriteriaColl" type="CM_YACriteriaTypeArray" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getRecCutoffDefaultsPN" id="9408c4c0-e93d-499f-a67c-5db0a830eb7c">
        <source>getRecCutoffDefaultsPN(_recCutoffTerminal :CM_ReceivalCutoffTermDef; _operator : CM_Operator;
						_table :CM_DataTable input; _row, _startCol :Integer) protected;
/*
Purpose - 	
Who - NAVAB1
Date - 06MAR025
ADO - JIRA 34233

// ### JIRA 34549 07APR 2025 NAVAB1 - remove uneccessary code

*/

vars
	operator		: CM_Operator;
	coll			: CM_RecCutoffOpTermByDefDict;
	recCutoffDefOp	: CM_ReceivalCutoffOpTerm;
	cutoffToShow : CM_ReceivalCutoffDef;
	defnCutoff : CM_ReceivalCutoffTermDef;
	pxyVoyageCutoff : CM_ReceivalCutoffVoyage;
	defRelativeTo,
	minutes			: Integer;
		defEarliest, 
	defCutoffPN ,
	defEarliestPN, 
	defCutoff 		:Decimal[7,2];
	targetTS, earliestTS, cutoffTS,
	earliestTSPN, cutoffTSPN,
	voyageDepartedDT:TimeStamp;
	earlyTSStr, earlyTSStrPN, earlyHours, 
	cutoffTSStr, cutoffTSStrPN, cutoffHours :String;
begin
	operator 	:= _operator;
	
	cutoffTS :=self.systemToLocalTime(app.actualTimeServer);// 20 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	
	cutoffTSStr := cutoffTS.asStringJMT();

	if self.myCurrentVoyage &lt;&gt; null then
		if self.myCurrentVoyage.departedDT.isValid then
			voyageDepartedDT := self.systemToLocalTime(self.myCurrentVoyage.departedDT);// 20 May 2016	cnwns1	TFS 488 - Multi Timezone Support
			if voyageDepartedDT &lt; cutoffTS then
				// set cut off default to Voyage Depart
				cutoffTSStr := voyageDepartedDT.asStringJMT();
			endif;
		endif;
	endif;
	
	if operator &lt;&gt; null then
		recCutoffDefOp := operator.getTerminalReceivalCutoff(_recCutoffTerminal);
	endif;
	
	if recCutoffDefOp &lt;&gt; null then
		defRelativeTo 	:= recCutoffDefOp.defaultRelativeTo;
		defEarliest		:= recCutoffDefOp.defaultEarliestReceival;	// hours
		defCutoff		:= recCutoffDefOp.defaultCutoff;			// hours
		// ### JIRA 34233 06MAR 2025 NAVAB1
		cutoffToShow := recCutoffDefOp;
		defEarliestPN		:= recCutoffDefOp.defaultEarliestReceivalPN;	// hours
		defCutoffPN		:= recCutoffDefOp.defaultCutoffPN;			// hours
	else
		defRelativeTo 	:= _recCutoffTerminal.defaultRelativeTo;
		defEarliest		:= _recCutoffTerminal.defaultEarliestReceival;	// hours
		defCutoff		:= _recCutoffTerminal.defaultCutoff;			// hours
		// ### JIRA 34233 06MAR 2025 NAVAB1
		cutoffToShow := _recCutoffTerminal;
		defnCutoff := _recCutoffTerminal;
		defEarliestPN		:= _recCutoffTerminal.defaultEarliestReceivalPN;	// hours
		defCutoffPN		:= _recCutoffTerminal.defaultCutoffPN;			// hours
	endif;
				
	targetTS := self.getCutoffRelativeToTS (defRelativeTo);		// par 29158 - march 2012
	
	if targetTS &lt;&gt; null then	
		if not _recCutoffTerminal.isEDIType and defEarliest &lt;&gt; null then	// par 29279 - march 2012
			// work out earliest receival date/time but only if:
			// - we are CARGO cutoff and
			// - earliest hours &lt;&gt; 0
			earliestTS 		:= targetTS.subtractHoursAndMinutes (defEarliest);
			earlyTSStr :=  earliestTS.time.shortFormatJMT() &amp; " " &amp;earliestTS.date.shortFormatJMT();
			
			earliestTSPN 		:= targetTS.subtractHoursAndMinutes (defEarliestPN);
			earlyTSStrPN :=  earliestTSPN.time.shortFormatJMT() &amp; " " &amp; earliestTSPN.date.shortFormatJMT();
			
		endif;
		if _recCutoffTerminal.isEDIType or defCutoff &lt;&gt; null then	// par 29279 - march 2012
			// work out cutoff date/time but only if:
			// - we are EDI cutoff OR
			// - cutoff hours &lt;&gt; 0
			cutoffTS		:= targetTS.subtractHoursAndMinutes (defCutoff);
			cutoffTSStr :=  cutoffTS.time.shortFormatJMT() &amp; " " &amp; cutoffTS.date.shortFormatJMT();

			cutoffTSPN		:= targetTS.subtractHoursAndMinutes (defCutoffPN);
			cutoffTSStrPN :=  cutoffTSPN.time.shortFormatJMT() &amp; " " &amp; cutoffTSPN.date.shortFormatJMT();

		endif;
	endif;
	
	if not _recCutoffTerminal.isEDIType and defEarliest &lt;&gt; null then // par 29279 - march 2012
		// only display earliest receival hours for CARGO
		earlyHours		:= defEarliest.asStringJMT();
	endif;
	
	if _recCutoffTerminal.defaultRelativeTo &lt;&gt; DefaultRelativeTo_RecCutOff  then
		if _recCutoffTerminal.isEDIType or defCutoff &lt;&gt; null then	// par 29279 - march 2012
			cutoffHours		:= defCutoff.asStringJMT();
		endif;
	else
		cutoffTS := null;
		earliestTS := null;
		cutoffTSPN := null;
		earliestTSPN := null;
		defCutoff := null;
		defCutoffPN := null;
		defEarliest := null;
		defEarliestPN := null;
		earlyTSStr := null;
		earlyTSStrPN := null;
		cutoffTSStr := null;
		cutoffTSStrPN := null;
		cutoffHours := null;
		earlyHours := null;
	endif;
	
	if _recCutoffTerminal.isEDIType then
		earliestTS := null;
		earliestTSPN := null;
		earlyTSStr := null;
		earlyTSStrPN := null;

	endif;

	_table.accessCell(_row, self.TblRecCutoffsCol_Code).text 		:= _recCutoffTerminal.code;
	_table.accessCell(_row, self.TblRecCutoffsCol_Code).fontBold 	:= true;

	if earlyTSStr&lt;&gt; null then
		earlyTSStr := earlyTSStr &amp; " (" &amp; earlyTSStrPN &amp; ")";
	endif;
	
	if cutoffTSStr&lt;&gt; null then
		cutoffTSStr := cutoffTSStr &amp; " (" &amp; cutoffTSStrPN &amp; ")";
	endif;
	
	if earlyHours &lt;&gt; null then
		earlyHours := earlyHours &amp; " (" &amp; defEarliestPN.asStringJMT() &amp; ")";
	endif;
	
	if cutoffHours &lt;&gt; null then
		cutoffHours := cutoffHours &amp; " (" &amp; defCutoffPN.asStringJMT() &amp; ")";
	endif;
	
	_table.accessCell(_row, _startCol).text := earlyHours &amp; Tab &amp; earlyTSStr &amp; Tab &amp; 
												cutoffHours &amp; Tab &amp; cutoffTSStr;
	
	// ### create a transient voyage cut off object for the table.
	 // ### JIRA 34524 08APR2025 NAVAB1 - these must be server timestamps, what we display will be in the UI's local
	 cutoffTS := self.localToSystemTime(cutoffTS);
	 earliestTS := self.localToSystemTime(earliestTS);
	 cutoffTSPN := self.localToSystemTime(cutoffTSPN);
	 earliestTSPN := self.localToSystemTime(earliestTSPN);
	 
	
	create pxyVoyageCutoff transient;
	pxyVoyageCutoff.setProxy(cutoffToShow.getCode(), cutoffTS, earliestTS,self.myCurrentVoyage, operator,  cutoffTSPN, earliestTSPN,defCutoff,defCutoffPN,defEarliest, defEarliestPN,defRelativeTo);
	pxyVoyageCutoff.setRecCutoffDef(defnCutoff);
	_table.accessRow(_row).itemObject := pxyVoyageCutoff; // ### JIRA 34233 06MAR 2025 NAVAB1
	self.allProxyCutoffs.add(pxyVoyageCutoff);
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_recCutoffTerminal" type="CM_ReceivalCutoffTermDef"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_table" type="CM_DataTable" usage="input"/>
        <Parameter name="_row" type="Integer"/>
        <Parameter name="_startCol" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getXMLSettingsForSave" id="7ee6364e-1a9b-4364-b3a8-c4602a72ab12">
        <updating/>
        <source>getXMLSettingsForSave(): String updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 June 2011	cnwer1	Initial creation CCMS MES 1116

*/

vars
	xml		: String;
begin
	xml	:=	inheritMethod();
	
	if self.shtVesselStruct.visible then
		if self.grpExtRamps.visible then
			xml:=xml &amp; self.tblExtRamps.getXmlStrForColumns(true);
		endif;
		
		xml:=xml &amp; self.tblSections.getXmlStrForColumns(true);
		
		xml:=xml &amp; self.tblTanks.getXmlStrForColumns(true);
	endif;
	
	// 32692 save movements table settings (sort columns in this case); also tblDelays and tblHDocuments which weren't saved
	xml := xml &amp; self.tblHMSMovements.getXmlStrForColumns(true) &amp; self.tblDelays.getXmlStrForColumns(true) &amp; self.tblHDocuments.getXmlStrForColumns(true);
	return xml;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getYACriteriaTypeByDescription" id="f6c39247-77c7-4110-8562-5e553b505088">
        <source>getYACriteriaTypeByDescription(_description : String) : CM_YACriteriaType;
// --------------------------------------------------------------------------------
// Created:		7 December 2009 by cnwjo3
//
// Purpose:		Returns the CM_YACriteriaType object from the _description.
//
vars
	ct : CM_YACriteriaType;
begin
	foreach ct in self.allCriteriaTypesForVoyage do
		if ct.description = _description then
			return ct;
		endif;
	endforeach;
	
	return null;
end;</source>
        <Parameter name="_description" type="String"/>
        <ReturnType type="CM_YACriteriaType"/>
    </JadeMethod>
    <JadeMethod name="handleChangeOfStructure" id="52793975-732c-4d90-8687-469bb7282af3">
        <source>handleChangeOfStructure();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 Mar 2013	cnwpjs1	Initial creation  PAR # 31232

*/

vars
	isLOLO, isRORO, isHOLDS : Boolean;
begin
	isLOLO := tblVesselStruct.getValueByName(ETRow_IncludesLOLO).Boolean;
	isRORO := tblVesselStruct.getValueByName(ETRow_IncludesRORO).Boolean;
	isHOLDS := tblVesselStruct.getValueByName(ETRow_IncludesHolds).Boolean;
	
	if isLOLO  or isRORO  then	// PAR 21745 CCMS MES 1031
		if self.mode &lt;&gt; self.Mode_View then
			self.cmbMoveMapRec.enabled := false;
			self.cmbMoveMapRel.enabled := false;					
		//	self.ckbCreateStructu.enabled := true;
		endif;
	//	if _setStructures then
	//		self.ckbCreateStructu.value := true;		
	//	endif;	
	else
		self.cmbMoveMapRec.enabled := false;
		self.cmbMoveMapRel.enabled := false;		
	//	self.ckbCreateStructu.enabled := false;
	//	self.ckbCreateStructu.value := false;						
	endif;
	
	// If it is GCHOLDS or just Ship Block Controller
	self.dateNonPlanned.enabled := not isLOLO and not isRORO;
	self.timeNonPlanned.enabled := not isLOLO and not isRORO;
	
	//19 Mar 2021	NDL	TFS 50977
	if not self.dateNonPlanned.enabled then
		self.dateNonPlanned.text := null;
		self.timeNonPlanned.text := null;
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="handleNotificationRefreshView" id="9eb587f0-e263-4af0-a4b7-84e7eb7dda0e">
        <updating/>
        <source>handleNotificationRefreshView(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;
//--------------------------------------------------
// Created:	05 April 2005 By: cnwgd1
//--------------------------------------------------
vars

begin
	self.myHarbour := self.myTerminal.myHarbour;
	self.doBaseFormCancel();
end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
    <JadeMethod name="handleSystemNotification" id="30276705-f1ea-465d-b9e6-84dcfb1be90b">
        <updating/>
        <source>handleSystemNotification(eventType: Integer; theObject: Object; eventTag: Integer) updating;
//--------------------------------------------------
// Created:	26 September 2005 By: cnwgd1
//--------------------------------------------------
vars

begin

	if eventType = Object_Delete_Event then
		if theObject = self.myCurrentVoyage then
			if self.cmbVoyage.listObject &lt;&gt; null
			and theObject &lt;&gt; self.cmbVoyage.listObject then	//cnwvu1 - when the same user deletes a voyage and Voyage Enquiry and Voyage Defintion are both opened, the user gets this misleading message.
				app.msgBox(app.getErrorString1(ObjectDeletedByOtherUser, self.caption), 'Warning', MsgBox_OK_Only + MsgBox_Information_Icon);
			endif;
			self.cmbVoyage.clear();
			self.doBaseFormCancel();	
		elseif theObject.isKindOf(CM_FileData) then
			self.setMyCurrentVoyage(self.myCurrentVoyage);
		endif;
 
	elseif eventType = Object_Update_Event then
		if theObject = self.myCurrentVoyage then
			if self.mode &lt;&gt; self.Mode_View then
				if app.msgBox(app.getErrorString1(ObjectUpdatedByAnotherUserEdit, self.caption), 'Warning', MsgBox_OK_Cancel + MsgBox_Exclamation_Mark_Icon) = MsgBox_Return_OK then
					self.doBaseFormCancel();
					self.doBtnEdit();
				else
					self.doBaseFormCancel();
				endif;
			else
				self.setMyCurrentVoyage(self.myCurrentVoyage);
			endif;
		endif;	
		
	elseif eventType = Object_Create_Event then

		if theObject.isKindOf(CM_FileData) then
			if theObject.CM_FileData.myParent = self.myCurrentVoyage then
				self.setMyCurrentVoyage(self.myCurrentVoyage);
			endif;
		endif;

	endif;	

end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="hideShowCutoffsFrame" id="3b5d5188-d8b7-4fd0-858b-47ac90d13716">
        <source>hideShowCutoffsFrame(_visible : Boolean);
/*
Purpose:	

Date		Who		Reason
12 March 2025	navab1	JIRA 34233
 // ### JIRA 34553 08APR2025 NAVAB1 pass in boolean
*/

vars
	table : CM_DataTable;
begin
	table := self.tblVoyageCutoffs;
	
	self.frmCutoffDataEntry.visible := _visible;
	if self.frmCutoffDataEntry.visible then
		table.top := 200;
	else
		table.top := 65;
	
	endif;
	self.frmCutoffDataEntry.enabled := self.ckbOverrideDef.value;
	
	table.height := table.parent.height - table.top - 20;  // ### JIRA 34524 08APR2025 NAVAB1
	
epilog

end;</source>
        <Parameter name="_visible" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="initComboBoxes" id="9d4d59d0-162e-4c06-bd20-b97eefb4fe30">
        <updating/>
        <source>initComboBoxes() updating;
//--------------------------------------------------
// Created:	27 July 2005 By: cnwgd1
//
// 11 Mar 2013		PJS		PAR # 31232
// 17/07/2018		jlgdap1	TFS 39685 PEL1 Pilots vs Harbours
//--------------------------------------------------
vars
	assistant : CMUI_Assistant;
	
begin
	self.cmbVessel.isVesselComboByName := self.myTerminal.getConfig(VesselComboByName).Boolean;
	self.cmbShippingAgent.isDisplayByName := self.myTerminal.getConfig(ComboByNameAgent).Boolean;
	self.cmbShippingLine.isDisplayByName := self.myTerminal.getConfig(ComboByNameLine).Boolean;
	self.cmbVoyage.isDisplayByVesselName := self.cmbVessel.isVesselComboByName;
	self.cmbVoyage.includeDisplayNeverVoyages := true;
	
	self.initComboInvoiceStatus();	
	
	self.cmbVessel.initialise(false);
	self.cmbShippingLine.initialise(false);
	
	if self.allFilterVoyages.size = null then
		self.cmbVoyage.initialise(false);
	else
		self.cmbVoyage.listCollection(self.allFilterVoyages,false,null);
		self.cmbVoyage.setInitialised(true);
	endif;
	
	//epr 
	if self.grpCellulaVoyage.visible then
		self.cmbCusresAltVoy.initialise(false);
	endif;
	
	assistant := self.myAssistant;
	// PAR #31232
	// assistant.comboBoxVesselStructureType(self.cmbStructureType, null);
	assistant.comboBoxVisitType(self.cmbVisitType, null);
	assistant.comboBoxStopCharging(cmbWStopCharging, null);

	self.cmbAccessType.clear();
	self.cmbAccessType.addItem(null);	
//	self.cmbAccessType.addItem(VESSEL_TYPE_LOLO_DESCR);
//	self.cmbAccessType.addItem(VESSEL_TYPE_RORO_DESCR);
	//12 Mar 2018	NDL	TFS 37444
	self.cmbAccessType.addItem( app.vesselAccessTypeEnumToStr(VESSEL_TYPE_LOLO) );
	self.cmbAccessType.addItem( app.vesselAccessTypeEnumToStr(VESSEL_TYPE_RORO) );
	
	if self.shtPortsOfCall.visible then
		// licensed for cargo module
		assistant.comboBoxBankNotSuspended(self.cmbBank, null);
		assistant.comboBoxMoveMap(self.cmbMoveMapRec);
		assistant.comboBoxMoveMap(self.cmbMoveMapRel);
//		assistant.comboBoxVoyagePlanningCode(self.cmbVoyPlanCode);
		self.cmbTrade.initialise(false);
		
		setupComboStatus();		//cnwmc5 - 26 July 2013 - PAR 31714
	endif;	
	
	if (not self.shtHMSHarborData.visible) then
		// Not licensed for HMS module
		return;
	endif;

	self.cmbPortFrom.myTerminal := self.myTerminal;
	self.cmbPortTo.myTerminal := self.myTerminal;
	self.cmbPortTo.myAssistant:= self.myAssistant;
	self.cmbPortFrom.myAssistant := self.myAssistant;
	self.cmbPortFrom.initialise(false);
	self.cmbPortTo.initialise(false);
	self.cmbShippingAgent.initialise(false);
	self.cmbCountry.initialise(false);
	
	// Pilot/Master
	//assistant.comboBoxHMSPilot(self.cmbPilot, self.cmbPilot.listObject.HMS_Pilot);							// TFS 39685
	assistant.comboBoxHMSPilot(self.cmbPilot, self.cmbPilot.listObject.HMS_Pilot, self.myTerminal.myHarbour);	// TFS 39685
	assistant.comboBoxHMSMaster(self.cmbMaster, self.myTerminal.myHarbour, self.cmbMaster.listObject.HMS_Master);

	assistant.comboBoxHMSTidalClass(self.cmbTidalClassAr, app.myRoot.allTidalClasses.first);
	assistant.comboBoxHMSTidalClass(self.cmbTidalClassDpt, self.cmbTidalClassAr.listObject.HMS_TidalClass);

	// Load Berth Booking Priority list
	self.cmbBerthPriority.sorted := false;
	self.cmbBerthPriority.addItem('1 - High');
	self.cmbBerthPriority.addItem('2');
	self.cmbBerthPriority.addItem('3');
	self.cmbBerthPriority.addItem('4');
	self.cmbBerthPriority.addItem('5 - Medium');
	self.cmbBerthPriority.addItem('6');
	self.cmbBerthPriority.addItem('7');
	self.cmbBerthPriority.addItem('8');
	self.cmbBerthPriority.addItem('9');
	self.cmbBerthPriority.addItem('10 - Low');						

	
	assistant.comboBoxHMSLineCompany(self.cmbLineCompany, null);
	assistant.comboBoxHMSVesselCategory(self.cmbCatArrive, app.myRoot.allVesselCategories.first);	
	assistant.comboBoxHMSVesselCategory(self.cmbCatDepart, self.cmbCatArrive.listObject.HMS_VesselCategory);		
	assistant.comboBoxHMSVesselType(self.cmbShipType, app.myRoot.allVesselTypes.first);
	assistant.comboBoxHMSBerth(self.cmbBerth, self.myTerminal.myHarbour, null, true);			
	assistant.comboBoxHMSPaymentType(self.cmbPaymentType, null);		// 25/6/18 MAP TFS39250
end;</source>
    </JadeMethod>
    <JadeMethod name="initComboInvoiceStatus" id="b1e032d2-3e4f-4bde-96f2-a6c813952f40">
        <source>initComboInvoiceStatus();
// ---------------------------------------------------------------------------
// Created:		16 August 2005  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	combo : CMUI_ComboBox;
	idx : Integer;
begin
	combo := self.cmbInvoiceStatus;
	combo.clear;
	combo.sorted := false;
	
	idx := combo.addItem(Voyage_Invoice_StatStr_FullGen);
	combo.itemData[idx] := Voyage_Invoice_Status_FullGen;
	idx := combo.addItem(Voyage_Invoice_StatStr_PartGen);
	combo.itemData[idx] := Voyage_Invoice_Status_PartGen;
	idx := combo.addItem(Voyage_Invoice_StatStr_NotGen);
	combo.itemData[idx] := Voyage_Invoice_Status_NotGen;
	idx := combo.addItem(Voyage_Invoice_StatStr_NotReq);
	combo.itemData[idx] := Voyage_Invoice_Status_NotReq;
end;</source>
    </JadeMethod>
    <JadeMethod name="initComboVoyageStatus" id="66c9f2e0-62f7-4cb1-9ddb-7f59acf98b11">
        <updating/>
        <source>initComboVoyageStatus(	_voyageProcess : CM_VoyageProcess input;
						_currentStatus : Integer) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Name	TFS#		Description
============================================================================
02/11/2018	jlger1	41523		Initial creation 
09/08/2019	jlgka1 	TFS 45921	PEL1 - Cannot make IMSR after Completing WO Permit Request - Manual Etmal IMSR
============================================================================*/

vars
	statuses : CM_VoyageStatusByPriority;
	status 	 : CM_VoyageStatus;
	vStatus	 : CM_VoyageStatus;
begin
	create statuses transient;
	if _voyageProcess &lt;&gt; null then	//09 Nov 2018	NDL	- found during testing
		_voyageProcess.getNextValidStatuses(self.myCurrentVoyage, statuses, self.chkAllStatus.value);
		//navra1 - MTN-34347 - 13th March 2025 - allow all status changes - start
		//navra1 - MTN-33086 - 21st Oct 2024 - start
		//auto processing and auto processing paused are not allowed to be set while creating the voyage
		/*
		if _voyageProcess.isAutomaticProcess() then
			foreach status in statuses where status.description = Voyage_Status_AutoOn_Auto_Str or status.description = Voyage_Status_Autoff_Auto_Str do
				statuses.remove(status);
			endforeach;
		endif;
		//navra1 - MTN-33086 - 21st Oct 2024 - end
		*/
		//navra1 - MTN-34347 - 13th March 2025 - allow all status changes - end
	endif;
	
	self.cmbStatus.clear();
	self.cmbStatus.sorted := false;
	self.cmbStatus.addItem(" ");
	foreach status in statuses do
		if  status.userCanSet(self.myTerminal) then
			self.cmbStatus.addItemObject(status.description, status);
		endif;
	endforeach;
	//jlgka1 	TFS 45921 --&gt;
	if self.validatecurrentStatusInProcess(_voyageProcess, _currentStatus) then	
		if _currentStatus &lt;&gt; null then		
			self.cmbStatus.listIndex := self.cmbStatus.findString(0, app.voyageStatusEnumToString(_currentStatus, false));
		elseif self.cmbStatus.listCount &gt; 1 then	//09 Nov 2018	NDL	- found during testing
			self.cmbStatus.listIndex := 2;
		endif;
	else
		self.checkandsetCmbStatus(_voyageProcess, null);		
	endif;
	//jlgka1 	TFS 45921 &lt;--
epilog
	delete statuses;
end;</source>
        <Parameter name="_voyageProcess" type="CM_VoyageProcess" usage="input"/>
        <Parameter name="_currentStatus" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="initDelayTables" id="d5412788-b57f-4dde-8e11-92c2945f4180">
        <source>initDelayTables();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 December 2015	cnwma1	Initial PAR #37329 System is not saving ship delays and we have a ship in and working

*/


vars
	entTableDef : EntTableDef;
	tmpTable : CM_DataTable;
begin
	tmpTable := self.tblDelays;
	//entTableDef	:= app.myController.getEntTableDef(ETDef_HMSVoyageDelay);	// PAR #35397
	entTableDef	:= app.myController.getEntTableDef(ETDef_DelaysEnquiryTbl);		// PAR #35397
	tmpTable.setTblDataEntRowsFromDef(entTableDef);
	tmpTable.selectMode := Table.SelectMode_CurrentRow;
	tmpTable.selectionType := CM_DataTable.SelectionType_Row;
	tmpTable.accessRow(1).backColor := self.colorHeadingColumn;		
  	tmpTable.userInputEnabled := false;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="initDimensionsTbl" id="1adcc295-7d8a-4e42-9c73-f5489b6a7946">
        <updating/>
        <source>initDimensionsTbl() updating;
//-----------------------------------------
// Created: Augus 2005 By: cnwgd1
//-----------------------------------------
constants
	MetreUnits ="m";
	TonneUnits = "T";
vars
	
	entTableDef : EntTableDef;
	entTableRow  : EntTableRow;
	newRow, maxLength,decimals		: Integer;
	unit 		: String;
	view		: EntTableView;
begin
	
	self.tblNewDimensions.visible:=true;
	self.tblNewDimensions.borderColorSingle:=self.getSystemColor(Control.Color_3DShadow);
	self.tblNewDimensions.clear;
	self.tblNewDimensions.columns:=3;
	self.tblNewDimensions.sortColumn[1] := 1; // PAR 33644
	self.tblNewDimensions.sortType[1] := Table.SortType_Alpha; // PAR 33644
	
	entTableDef := app.myRoot.myEntTableDataRoot.allEntTableDefs[ETDef_KeyDimensions];

	self.tblNewDimensions.accessColumn(2).width:=60;
	self.tblNewDimensions.accessColumn(3).width:=25;
	self.tblNewDimensions.accessColumn(1).width:= self.tblNewDimensions.clientWidth -  100;
	self.tblNewDimensions.accessColumn(3).enabled:=false;
	
	self.tblNewDimensions.addItemAt(Tab &amp; app.getErrorString(Value) &amp; Tab &amp;app.getErrorString(Unit) ,1);
	//self.tblNewDimensions.addItemAt(Tab &amp; app.getErrorString(Value).asStringJMT &amp; Tab &amp;app.getErrorString(Unit).asStringJMT ,1);
	self.tblNewDimensions.fixedRows:=1;
	self.tblNewDimensions.rows:=1;

	// 20/8/19 MAP TFS45926 Always use all dimensions
//	if self.shtHMSHarborData.visible then
		view:=entTableDef.allEntTableViews["hmsDimensions"];
//	else
//		view:=entTableDef.allEntTableViews["noHMSDimensions"];
//	endif;
	
	foreach entTableRow in view.allEntTableRows do
		newRow:=self.tblNewDimensions.addItemObject(entTableRow,entTableRow.getHeading(null,self.myTerminal,app.myCurrentLocale));
		
		if entTableRow.name = ETRow_DeadWeight or 
			entTableRow.name = ETRow_GrossRegTonnes or
			entTableRow.name = ETRow_NetRegTonnes then	// QNS 2178
			unit := TonneUnits;
		else
			unit := MetreUnits;
		endif;
		self.tblNewDimensions.accessCell(newRow,2).inputType:=entTableRow.inputType;
		if entTableRow.myEntTableCellControl &lt;&gt; null then
			maxLength:= entTableRow.myEntTableCellControl.getMaxLength;
			decimals := entTableRow.myEntTableCellControl.getDecimals;
			if maxLength &lt;&gt; 0 then
				self.tblNewDimensions.accessCell(newRow,2).maxLength:=maxLength;
			endif;
			if decimals &lt;&gt; 0 then
				self.tblNewDimensions.accessCell(newRow,2).decimals:=decimals;
			endif;
			
		endif;
		self.tblNewDimensions.accessCell(newRow,3).text:=unit.asStringJMT;
	endforeach;
		
		
		
	

end;</source>
    </JadeMethod>
    <JadeMethod name="initDocumentsTable" id="42bbd679-b2d2-4629-9dad-63a38d21079c">
        <source>initDocumentsTable();
// ---------------------------------------------------------------------------
// Created:     23 January 2007 by #usercode
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	entTableDef : EntTableDef;
	tmpTable : CM_DataTable;
begin
	tmpTable := self.tblHDocuments;
	entTableDef	:= app.myController.getEntTableDef(ETDef_FileDocument);
	tmpTable.setTblDataEntRowsFromDef(entTableDef);
	tmpTable.userInputEnabled := false;
	tmpTable.selectMode := Table.SelectMode_CurrentRow;
	tmpTable.selectionType := CM_DataTable.SelectionType_Row;
	tmpTable.accessRow(1).backColor := self.colorHeadingColumn;	

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="initForm" id="502e2be4-ef76-4965-b00c-d2cde73b635a">
        <updating/>
        <source>initForm()updating;
//--------------------------------------------------
// Created:	25 July 2005 By: cnwgd1
//--------------------------------------------------

// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 30/10/2008	consw1		SFW1030 - Remove unused auto plan flags
// 11/3/2013	PJS			PAR #31232 - SFW 1274 Voyage rationalisation
// 17/12/2015   cnwma1      PAR #37329 System is not saving ship delays and we have a ship in and working
// 11/04/2017	cnwdap1		TFS 4050 LNX Job ID Enhancements
// 08/06/2020   cnwma1 		ChangeRequest 49400: ASPA - Invoice Enhancements for Barges
vars
	
begin
	self.lblShowDefault_1.caption := self.myTerminal.getConfig(VoyDepartedGracePeriod).Integer.asStringJMT;
	
	if not app.myRoot.isTerminal_PortsOfCallTranship( self.myTerminal ) then
		self.mnuPOCAddTranship.visible	:= false;
		self.mnuPOCMakeActual.visible	:= false;
		self.mnuPOCMakeTranship.visible	:= false;
	endif;
	
	// 01/02/2013 cnwar2 #31108
	if not app.myCurrentUserCan(self.myTerminal, PmVoyageArchive) then
		self.btnArchive.enabled := false;
	endif;
	
	self.btnShippingLine.enabled := false;
	self.btnShippingAgent.enabled := false;			
	
	self.fldMain.tabsStyle := Folder.TabsStyle_RightSloped;
	
	self.fldMain.useSheetBackColors := true;
	self.fldMain.setDefaultSheetBackColors();
	self.fldMain.initSheetBackColors();
	self.initDocumentsTable();
	self.initDelayTables();        //17/12/2015 cnwma1 PAR #37329 
	if self.shtHMSHarborData.visible then
		// licensed for HMS							
		self.initHMSTables();
	else
		self.ckbCreateHMSData.visible := false;
		self.initHMSMulSelect();		// 2/9/19 MAP TFS45926
	endif;
	
	self.initDimensionsTbl();
	
	self.initMulOperators;			// cnwrl1 28/05/2009 PAR 19672
	
	self.initTblWOOpHrs();	//02 Apr 2012	NDL	Par 29369
	
	self.cmbMoveMapRec.enabled := false;
	self.cmbMoveMapRel.enabled := false;
	self.lblRecMoveMap.enabled := false;
	self.lblRelMoveMap.enabled := false;
		
	//self.ckbCreateStructu.bubbleHelp := 'Un-tick to delete existing planning structures.' &amp; Cr &amp; 'Only available if Voyage Type is Container';//
	
	self.initRecCutoffsTbl();	// 26/05/2009 cnwar2 CCMS1040
	
	self.initVoyageAllocationSheet(false);  //cnwjo3 par 21837 
	
	self.initStructuralTables(); //epr 9/6/11 CCMS 1116
	
	//31232
	tblVesselStruct.setValueColumn(0, getSystemColor(Color_Window), false, false);
	self.setColorsForEntryTable(tblVesselStruct);
	self.initTblVesselStructure(self.tblVesselStruct, ETDef_VesselStructTbl);	
	
	if self.myTerminal.getConfig(CannotUpdateExternalCode).Boolean then			// TFS 4050
		self.txtExternalCode.enabled := false;									// TFS 4050
	endif;																		// TFS 4050
	
	if self.myTerminal.getConfig(CannotUpdateVoyGrpCode).Boolean then           //03/06/2020 cnwma1 TFS #49400
		self.txtGroupCode.enabled := false;	
	endif;
	self.beginClassNotification(CM_Voyage, false, Object_Update_Event, Response_Continuous, 0);
	self.beginClassNotification(CM_Voyage, false, Object_Delete_Event, Response_Continuous, 0);	
end;</source>
    </JadeMethod>
    <JadeMethod name="initHMSMulSelect" id="dc78cc58-0ad5-4ea3-8f31-afc8043122a9">
        <source>initHMSMulSelect();
//--------------------------------------------------
// Created:	25 July 2005 By: cnwgd1
// 08 May 2025 navrv30	MTN 34672: MTN | Multigroup Selection Filter Phase 3
//--------------------------------------------------
vars
	tmpMulSel : CMUI_MultiSelectFilterGroupBox;
begin
	
	tmpMulSel := self.mulStevedoreDisc;		
	tmpMulSel.availableHeading := 'Available Stevedores For Discharge';
	tmpMulSel.selectedHeading := 'Selected Stevedores For Discharge';	
	tmpMulSel.formDisplayEntryMethodName := SHP_VoyageDefinitionForm::displayMultiSelectDetail.name;  
	tmpMulSel.myBaseForm := self;
	tmpMulSel.mySelectedListBox.sorted := true;
	tmpMulSel.multiSelect := ListBox.MultiSelect_Extended;	
	tmpMulSel.setAvailable(app.myRoot.allStevedores, true);		

	tmpMulSel := self.mulStevedoreLoad;			
	tmpMulSel.availableHeading := 'Available Stevedores For Load';
	tmpMulSel.selectedHeading := 'Selected Stevedores For Load';	
	tmpMulSel.formDisplayEntryMethodName := SHP_VoyageDefinitionForm::displayMultiSelectDetail.name;  
	tmpMulSel.myBaseForm := self;
	tmpMulSel.mySelectedListBox.sorted := true;
	tmpMulSel.multiSelect := ListBox.MultiSelect_Extended;	
	tmpMulSel.setAvailable(app.myRoot.allStevedores, true);						
	
	if (not self.shtHMSHarborData.visible) then
		// not licensed for HMS
		return;
	endif;	
	
	/*tmpMulSel := self.mulCommodityDisc;
	tmpMulSel.availableHeading := 'Available Commodities To Discharge';
	tmpMulSel.selectedHeading := 'Selected Commodities To Discharge';
	tmpMulSel.formDisplayEntryMethodName := SHP_VoyageDefinitionForm::displayMultiSelectDetail.name; 
	tmpMulSel.myBaseForm := self;
	tmpMulSel.mySelectedListBox.sorted := true;
	tmpMulSel.multiSelect := ListBox.MultiSelect_Extended;	
	tmpMulSel.setAvailable(app.myRoot.allCommodities, true);

	tmpMulSel := self.mulCommodityLoad;	
	tmpMulSel.availableHeading := 'Available Commodities To Load';
	tmpMulSel.selectedHeading := 'Selected Commodities To Load';
	tmpMulSel.formDisplayEntryMethodName := SHP_VoyageDefinitionForm::displayMultiSelectDetail.name; 
	tmpMulSel.myBaseForm := self;
	tmpMulSel.mySelectedListBox.sorted := true;
	tmpMulSel.multiSelect := ListBox.MultiSelect_Extended;			
	tmpMulSel.setAvailable(app.myRoot.allCommodities, true);*/

end;</source>
    </JadeMethod>
    <JadeMethod name="initHMSTables" id="f4e67bcb-27cc-42d5-854e-de0cdf8d6154">
        <updating/>
        <source>initHMSTables()updating;
//--------------------------------------------------
// Created:	25 July 2005 By: cnwgd1
//--------------------------------------------------
// Changed On	By			Reason
// ----------	--------	---------------------------------------------
// 24/01/2014	cnwdap1		PAR #33337 CCMS PTR 2214 HMS Enhancements
// 31/12/2014	cnwdap1		PAR #35397 CCMS SFW 1394 Voyage Rationalisation - HMS_VoyageDelays are now CM_Delays
// 16/12/2015   cnwma1      PAR # 37329 System is not saving ship delays and we have a ship in and working
vars
	entTableDef : EntTableDef;
	tmpTable : CM_DataTable;
begin
	
	if (not self.shtHMSHarborData.visible) then    
		// not licensed for HMS
		return;
	endif;
	self.lstResTypeArriva.tabStop	:=	true;							// PAR #33337
	self.lstResTypeDepart.tabStop	:=	true;							// PAR #33337
	self.lstResTypeShift.tabStop	:=	true;							// PAR #33337
	/*
	// Delay table
	tmpTable := self.tblDelays;
	//entTableDef	:= app.myController.getEntTableDef(ETDef_HMSVoyageDelay);	// PAR #35397
	entTableDef	:= app.myController.getEntTableDef(ETDef_DelaysEnquiryTbl);		// PAR #35397
	tmpTable.setTblDataEntRowsFromDef(entTableDef);
	tmpTable.selectMode := Table.SelectMode_CurrentRow;
	tmpTable.selectionType := CM_DataTable.SelectionType_Row;
	tmpTable.accessRow(1).backColor := self.colorHeadingColumn;		
  	tmpTable.userInputEnabled := false;
	*/

	// Movement table
	tmpTable := self.tblHMSMovements;
	entTableDef	:= app.myController.getEntTableDef(ETDef_HMSVoyageMovement);
	tmpTable.setTblDataEntRowsFromDef(entTableDef);
	tmpTable.userInputEnabled := false;
	tmpTable.selectMode := Table.SelectMode_CurrentRow;
	tmpTable.selectionType := CM_DataTable.SelectionType_Row;
	tmpTable.accessRow(1).backColor := self.colorHeadingColumn;	
	tmpTable.allTblDataSortColumns.clear;										// PAR #35397
	tmpTable.allTblDataSortDescending.clear;									// PAR #35397
	tmpTable.allTblDataSortColumns.add("occursOnDTNEW");						// PAR #35397
	tmpTable.allTblDataSortDescending.add(false);								// PAR #35397
	tmpTable.resort();															// PAR #35397
	
	// Berth Preferences Table
	tmpTable := self.tblBerthPref;	
	entTableDef	:= app.myController.getEntTableDef(ETDef_BerthPrefVoyage);
	tmpTable.setTblDataEntRowsFromDef(entTableDef);
	tmpTable.selectMode := Table.SelectMode_CurrentRow;
	tmpTable.selectionType := CM_DataTable.SelectionType_Row;
	tmpTable.autoSize := tmpTable.AutoSize_Column;
	tmpTable.tabKey := J_key_Tab;
	tmpTable.accessRow(1).backColor := self.colorHeadingColumn;

	self.initHMSMulSelect();
	self.initHMSTidalClassTbl(self.tblCurrentsArriv);
	self.initHMSTidalClassTbl(self.tblCurrentsDepar);
	
end;</source>
    </JadeMethod>
    <JadeMethod name="initHMSTidalClassTbl" id="b2247698-e4c6-41b6-8a97-53d3cb6e1d18">
        <source>initHMSTidalClassTbl(_theTable : CM_DataTable input);

vars	
	tmpStr : String;
begin
	
	// Make table readOnly
	_theTable.readOnly := true;
	_theTable.rows := 0;

	// Set table input modes
	_theTable.accessMode := _theTable.AccessMode_Column;
	_theTable.column := 1;
	_theTable.inputType := _theTable.InputType_None;	
	_theTable.column := 2;
	_theTable.inputType := _theTable.InputType_None;
	_theTable.alignment := _theTable.Alignment_Right;
	_theTable.column := 3;
	_theTable.inputType := _theTable.InputType_None;
	_theTable.alignment := _theTable.Alignment_Center;


	// Set dimensions table headings
	tmpStr := "Direction and Tide Type" &amp; Tab &amp; "Max current " &amp; Tab &amp; "Unit ";
	_theTable.addItem(tmpStr);
	_theTable.accessRow(1).backColor  :=  self.colorHeadingColumn;

	// Set enteries in "Titles" column
	tmpStr := "Arrival, maximum flood tide" &amp; Tab &amp; ' ' &amp; Tab &amp; "knots";
	_theTable.addItem(tmpStr);	
	tmpStr := "Arrival, maximum ebb tide" &amp; Tab &amp; ' ' &amp; Tab &amp; "knots";
	_theTable.addItem(tmpStr);
	tmpStr := "Departure, maximum flood tide" &amp; Tab &amp; ' ' &amp; Tab &amp; "knots";
	_theTable.addItem(tmpStr);	
	tmpStr := "Departure, maximum ebb tide" &amp; Tab &amp; ' ' &amp; Tab &amp; "knots";
	_theTable.addItem(tmpStr);
	
	_theTable.fixedRows := 1;
	_theTable.fixed3D := true;
	
end;</source>
        <Parameter name="_theTable" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="initMulOperators" id="49df6928-ad79-4a12-9271-99c6f35e9991">
        <source>initMulOperators() protected;

/*

Purpose:		
Parameters:		
Return Value:	

Date				Who		Reason
28 May 2009			cnwrl1	Initial creation as part of PAR 19672

*/
	
vars
	
begin
	self.mulOperators.multiSelect				:= ListBox.MultiSelect_Extended;
	self.mulOperators.availableHeading			:= app.getErrorString( Available_Operators );
