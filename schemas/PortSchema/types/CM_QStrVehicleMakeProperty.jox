    <JadeMethod name="create" id="1c7b1bb8-3322-46f2-98ec-40b345a87f19">
        <updating/>
        <source>create() updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 19/09/2013	cnwdap1		Initial creation PAR #32215 CCMS DPH 2290 New Car Attributes
//
vars
	oper : CM_QueryOperator;
	
begin
	if self.isTransient then 
		return;
	endif;
	
	create oper as CM_QStringIsOneOf persistent;
	self.allAllowedOperators.add(oper);
epilog

end;</source>
    </JadeMethod>
