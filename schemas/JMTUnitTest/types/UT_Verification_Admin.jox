	methEndTS					: TimeStamp;
	elapsedTime					: TimeStampInterval;
	resultStr					: String;
	tempStr						: String;
	str							: String;
	
begin

	/*
	self.assertNotNull(_unitTestRun);

	create detailsToOutput transient;
	methStartTS := app.actualTimeServer;

	// set the endConfig details
	create agent transient;
	_testController.getConfigAsXMLDocument(agent);
	beginTransaction;
	_unitTestRun.updateConfigEndDetails(agent.xmlDoc.writeToString());	
	commitTransaction;
	
	//create xmlDocPrev transient;
	xmlDocPrev := _testController.currentConfigDetails;
	self.assertNotNull(xmlDocPrev);
	
	create xmlDocCurr transient;
