    <JadeMethod name="buildcmbVoyage" id="dfa89bb2-10ec-4103-a758-3ab084f14996">
        <source>buildcmbVoyage();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 Feb 2023	navhl20	ChangeRequest 56631:[56185] EUP - Transport Mode change - UI Changes

*/

vars
	cmb : CMUI_ComboBox;
	voyage : CM_Voyage;
begin
	cmb := self.cmbVoyage;
	cmb.clear();
	foreach voyage in self.myTerminal.allVoyagesByCode do 
		cmb.addItemObject(voyage.code, voyage);
	endforeach;
epilog

end;</source>
