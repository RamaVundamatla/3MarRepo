    <JadeMethod name="getDescription" id="5b5dbcb7-35ee-4b7a-b810-6b7a807d4960">
        <source>getDescription() : String;
// ---------------------------------------------------------------------------
// Created:		18 September 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	tmpStr : String;
begin
	if self.myCraneJobSheet &lt;&gt; null then
		tmpStr := tmpStr &amp; self.myCraneJobSheet.getMyWorkPoint.code &amp; " ";
	endif;
	if self.myDeck &lt;&gt; null then
		tmpStr := tmpStr &amp; "Deck " &amp; self.myDeck.code &amp; ", ";
	endif;
	
	tmpStr := tmpStr &amp; self.getTotalItems().String &amp; " ";
	if self.isDischarge() then
		tmpStr := tmpStr &amp; "discharge items";
	else
		tmpStr := tmpStr &amp; "load items";
	endif;
	
	return tmpStr;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="d992c117-b290-4036-ad51-76d00f65cc89">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
05 September 2011	cnwer1	Initial creation CCMS MES 1033

*/

vars
	aJob : CM_VoyageJob;
	jStr : String;
begin

	if _attrName = ETRow_Deck then
		if self.myDeck = null then
			return self.id;
		endif;
		return self.myDeck.code;
	elseif _attrName = ETRow_Job then
		if self.allJobs.size = 0 then
			return self.order.asStringJMT;
		endif;
		foreach aJob in self.allJobs do
			if jStr = "" then
				jStr := aJob.jobNum ;
			else
				jStr := jStr &amp; ", " &amp; aJob.jobNum;
			endif; 
		endforeach;
		return jStr;
		
	elseif  _attrName = ETRow_Discharge20 then
		return self.discIMP20.zeroNotAllowed;
	elseif _attrName = ETRow_Discharge40 then
		return self.discIMP40.zeroNotAllowed;
	elseif _attrName = ETRow_DischargeGC then
		return self.discGC.zeroNotAllowed;
	elseif _attrName = ETRow_DischDLR20 then
		return self.discDLR20.zeroNotAllowed;
	elseif _attrName = ETRow_DischDLR40 then
		return self.discDLR40.zeroNotAllowed;	
	elseif _attrName = ETRow_DischDLRGC then
		return self.discDLRGC.zeroNotAllowed;	
	elseif _attrName = ETRow_Load20 then
		return self.loadEXP20.zeroNotAllowed;
	elseif _attrName = ETRow_Load40 then
		return self.loadEXP40.zeroNotAllowed;
	elseif _attrName = ETRow_LoadGC then
		return self.loadGC.zeroNotAllowed;
	elseif _attrName = ETRow_LoadDLR20 then
		return self.loadDLR20.zeroNotAllowed;
	elseif _attrName = ETRow_LoadDLR40 then
		return self.loadDLR40.zeroNotAllowed;
	elseif _attrName = ETRow_LoadDLRGC then
		return self.loadDLRGC.zeroNotAllowed;
	elseif _attrName = ETRow_Sob20 then
		return (self.discSOB20 + self.loadSOB20 ).zeroNotAllowed();
	elseif _attrName = ETRow_Sob40 then
		return	(self.discSOB40 + self.loadSOB40).zeroNotAllowed();
	elseif _attrName = ETRow_SobGC then
		return	(self.discSOBGC + self.loadSOBGC).zeroNotAllowed();	
	elseif _attrName = ETRow_Refeer20 then
		return	(self.discREF20 + self.loadREF20).zeroNotAllowed();
	elseif _attrName = ETRow_Reefer40 then
		return	(self.discREF40 + self.loadREF40).zeroNotAllowed();
	elseif _attrName = ETRow_DeckTotal then
		return self.getTotalItems.zeroNotAllowed();
	elseif _attrName = ETRow_WorkPointTotal then
		return null;
	else
		return inheritMethod(_attrName, _short);
	endif;
epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
