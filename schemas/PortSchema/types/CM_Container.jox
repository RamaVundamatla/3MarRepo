    <JadeMethod name="isGroundPlacedExpROROCont" id="bbc6dad0-29bc-48d4-87a3-4e95d0e01cce">
        <source>isGroundPlacedExpROROCont() : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
26 July 2024		jlizm1	Initial creation TFS 65245 CUX Re-queue grounded RORO containers
01 August 2024		jlizm1	TFS 65492 Issues with requeueing containers already queued

*/

vars
	voyage 		: CM_Voyage;
	voyStatus 	: CM_VoyageStatus;
	
begin
	if self.myTerminal = null
	or not self.myTerminal.getConfig(QueueGroundExportRORO).Boolean then	
		return false;
	endif;
	
	voyage := self.myVoyage;
	if voyage = null or voyage.isNullVoyage then
		return false;
	endif;
	
	if voyage.myROROStructure = null or voyage.myCellularVoyageStructure &lt;&gt; null then
		// not a roro voyage
		return false;
	endif;
	
	if not self.isExport
	or not self.isOnSite()
	or self.isOnMAFI()
	or self.isOnTransport() then
		return false;
	endif;
	
	voyStatus := voyage.getVoyageStatusObject();
	if voyage.myVoyageProcess = null or voyStatus = null then
		return false;
	endif;
	
	if voyStatus.priority &lt; voyage.myVoyageProcess.getWorkingPriority then
		return false;
	endif;
	
	return true;
	
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
