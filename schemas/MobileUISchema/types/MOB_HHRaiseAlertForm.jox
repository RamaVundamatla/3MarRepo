    <JadeMethod name="cmbPredefined_click" id="d9f94614-0dc8-4a99-b40a-afd9fb991e21">
        <controlMethod name="ComboBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbPredefined_click(combobox: ComboBox input) updating;
// ---------------------------------------------------------------------------
// Created:	12 January 2009 By Graeme Black cnwgb1
// Status: 	Unfinished
// Purpose:	
// ---------------------------------------------------------------------------
vars
begin
	// Need to remember the old message that was selected so that we can go back to it if the user
	// doesn't wish to continue with the change
	if not changedText or showWarningMessage then
		selectedMessageIndex := combobox.listIndex;
		self.doHandleValueChange();
	else
		combobox.listIndex := selectedMessageIndex;
	endif;
epilog
end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
