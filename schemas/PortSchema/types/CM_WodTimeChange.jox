    <JadeMethod name="getCurrentLocation" id="9bacd58e-ab6c-490d-9af4-e6359cbd5590">
        <source>getCurrentLocation(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 October 2018	jlgndl1	Initial creation	TFS 41272

*/

vars
	workOrderDtl : CM_WorkOrderDtl;
begin
	if  self.myWorkOrderToUpdate &lt;&gt; self.getMyParent and self.myWorkOrderToUpdate &lt;&gt; null then
		workOrderDtl :=   self.myWorkOrderToUpdate.allWoDtls.first;
		if workOrderDtl &lt;&gt; null and workOrderDtl.isKindOf(CM_WodHMSRequestCancel) then
			if workOrderDtl.CM_WodHMSRequestCancel.myWorkOrderToCancel &lt;&gt;  self.getMyParent then
		
				return self.myWorkOrderToUpdate.getCurrentLocation();
			endif;
		endif;
	endif;
	
	return null;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayString" id="78fb7858-247b-4f9e-a83f-afcb013b22f8">
        <source>getDisplayString(_useShortDesc: Boolean): String;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 18/05/2018	jlgdap1		Initial creation TFS 38560 PEL1 Voyage Work Orders
// 29 Sep 2021  navma1 		ChangeRequest 51925: SAL - Web Portal Cargo Work Orders


vars
	displayString : String;
	typeDesc      : String;
begin
	
	typeDesc := self.getTypeDescription();							   //29.09.2021 navma1 #51925
	
	if _useShortDesc then
		displayString := typeDesc;
	else
		displayString := self.getLongDescription(typeDesc,null);		//29.09.2021 navma1 #51925
	endif;
	
	return displayString;
epilog

end;</source>
        <Parameter name="_useShortDesc" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
