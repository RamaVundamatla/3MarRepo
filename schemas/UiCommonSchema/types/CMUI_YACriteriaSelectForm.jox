    <JadeMethod name="timerEvent" id="3bdfc61c-e0ea-44f9-9f51-725dd855d395">
        <updating/>
        <source>timerEvent(eventTag: Integer) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
20 October 2022	navgm20ChangeRequest 55106: EUP - Filtered Drop-downs and Lists FIND LISTS
27/07/2023	navkc1	Bug 57701: FR | 54538 - EUP - Filtered Drop-downs and Lists - Find lists filter
*/

vars
	text : String;
begin
