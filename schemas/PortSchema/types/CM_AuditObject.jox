    <JadeMethod name="addToBothText" id="58ed78a7-590d-4427-8557-67e8533b10f4">
        <updating/>
        <source>addToBothText(tag, value: String) updating;
/*

Purpose:			Add a tag, and value, to an exisitng audit object, for cases where information should
					be shown on an update audit despite no changes being made to the value

Parameters:			tag: the name of the audited property
					value: the value of the audited property

Return Value:		

Date				Who		Reason
03 February 2022	jlizm1	Initial creation TFS 52364 PIBT Audit Details

*/

vars

	newString: String;
	
begin
	
	newString := tag &amp; AuditStringSeparator &amp; value.length.String &amp; AuditStringSeparator &amp; value &amp; AuditStringSeparator;
	self.auditText := auditText &amp; newString;
	self.postAuditText := self.postAuditText &amp; newString;
	
epilog

end;</source>
        <Parameter name="tag" type="String"/>
        <Parameter name="value" type="String"/>
    </JadeMethod>
    <JadeMethod name="addToPostText" id="d5a18bf5-2598-4cb6-80d8-c220073785a4">
        <updating/>
        <source>addToPostText(tag, newValue: String) updating;
/*

Purpose:			Add an additional value to the post audit text

Parameters:			

Return Value:		

Date				Who		Reason
03 February 2022	jlizm1	Initial creation TFS 52364 PIBT Audit Details

*/

vars

	newString: String;
	
begin

	newString := tag &amp; AuditStringSeparator &amp; newValue.length.String &amp; AuditStringSeparator &amp; newValue &amp; AuditStringSeparator;
	self.postAuditText := self.postAuditText &amp; newString;
	
end;</source>
        <Parameter name="tag" type="String"/>
        <Parameter name="newValue" type="String"/>
    </JadeMethod>
    <JadeMethod name="addToText" id="a22042ed-f563-4735-81ca-fe2f5858ccf9">
        <updating/>
        <source>addToText(tag, previousValue: String) updating;

vars
	newString: String;
	
begin
	newString := tag &amp; AuditStringSeparator &amp; previousValue.length.String &amp; AuditStringSeparator &amp; previousValue &amp; AuditStringSeparator;
	self.auditText := self.auditText &amp; newString;
end;</source>
        <Parameter name="tag" type="String"/>
        <Parameter name="previousValue" type="String"/>
    </JadeMethod>
    <JadeMethod name="getAllTags" id="558382eb-148b-49d8-979a-3b0eabf34494">
        <source>getAllTags(_usePreText: Boolean) : String;
// ---------------------------------------------------------------------------
// Created:		October 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	tagStr, auditStr, tagList : String;
	idx, pos, tmp, ignore : Integer;
begin

//	auditStr := "lastDisconnectDT^26^16 December 2005, 11:32:00^onPower^2^No^";
	if _usePreText then
		auditStr := self.auditText;
	else
		auditStr := self.postAuditText;
	endif;
	idx := 1;
	ignore := 0;
	while true do
		tmp := tmp + 1; if tmp &gt; 1000 then break; endif;
		
		pos := auditStr.pos(AuditStringSeparator, idx);
		if pos = 0 then
			break;
		endif;
		ignore := ignore + 1;

		if ignore = 1 then
			tagStr := auditStr[idx:(pos - idx)];
			if tagList = null then
				tagList := tagList &amp; tagStr;
			else
				tagList := tagList &amp; "/" &amp; tagStr;
			endif;
		endif;
		if ignore &gt;= 3 then
			ignore := 0;
		endif;
		idx := pos + 1;
		
	endwhile;

	return tagList;
end;</source>
        <Parameter name="_usePreText" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getAuditObjectImage" id="87e4c43a-7431-40c4-9d35-37c22770a4a1">
        <source>getAuditObjectImage() : CM_AuditObjectImage;
// ---------------------------------------------------------------------------
// Created:     13 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	aoi : CM_AuditObjectImage;
	
begin
	// caller is responsible for deleting the image object
	create aoi transient;
	aoi.initialiseFromAudit(self);
	return aoi;
	
end;</source>
        <ReturnType type="CM_AuditObjectImage"/>
    </JadeMethod>
    <JadeMethod name="getClassTag" id="6d349ee6-545b-4ea4-9575-5918b5ce31b5">
        <source>getClassTag() : String protected;

vars
	s : String;
	startPos, endPos, i : Integer;
	
begin
	s := self.subjectIdString;
	if s = null then
		return null;
	endif;
	startPos := s.pos(TagClassStart, 1);
	if startPos &lt; 1 then
		return null;
	endif;
	i := startPos + TagClassStart.length;
	if i &gt; s.length then
		return null;
	endif;
	endPos := s.pos(TagEnd, i);
	if endPos &lt; i then
		return null;
	endif;
	return s[startPos : (endPos - startPos) + TagEnd.length];
end;</source>
        <access>protected</access>
        <ReturnType type="String"/>
    </JadeMethod>
