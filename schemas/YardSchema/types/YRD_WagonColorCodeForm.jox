        <updating/>
        <source>cmbConsignee_click(combobox: ComboBox input) updating;
// ---------------------------------------------------------------------------
// Created:     21 August 2009 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
