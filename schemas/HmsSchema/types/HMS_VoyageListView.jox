    <JadeMethod name="initForm" id="176e8da6-f424-4129-a04d-ce18006e1e29">
        <updating/>
        <source>initForm(_parentForm : HMS_GraphicalViewX)updating;
//--------------------------------------------------------------
//Created: 21 July 2003 By: cnwgd1
//--------------------------------------------------------------
vars

begin
  	self.myGraphicalViewForm := _parentForm;
	self.myViewController := _parentForm.myViewController;
	self.buildEntireForeground();
	self.setNavigatorHeading(self.caption);
end;</source>
        <Parameter name="_parentForm" type="HMS_GraphicalViewX"/>
