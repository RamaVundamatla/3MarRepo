    <JadeMethod name="delete" id="c28afcaa-77cd-4fa5-8f69-7a6e75d8f532">
        <updating/>
        <source>delete() updating;
// ---------------------------------------------------------------------------
// Created:     16 May 2002 by cnwrs2
//
