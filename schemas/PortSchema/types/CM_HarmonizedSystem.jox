    <JadeMethod name="setProxy" id="73a2bf2e-957f-4e1c-a1c9-79c8267365c8">
        <updating/>
        <source>setProxy(_id : String; _desc : String; _isActive : Boolean; 
		_notAvailable : Boolean; _remarks : String) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date					Who		Reason
25 November 2022		jlizm1	Initial creation TFS 55280 Harmonized System Codes

*/

vars

begin
	self.id				:= _id;
	self.description 	:= _desc;
	self.isActive	 	:= _isActive;
	self.notAvailableForEntry := _notAvailable;
	self.remarks 		:= _remarks;
	self.myRoot			:= app.myRoot;
	
epilog

end;</source>
