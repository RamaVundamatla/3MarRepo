	self.myMonthLabel.text := _date.format("MMMM");
epilog

end;</source>
        <Parameter name="_date" type="Date"/>
    </JadeMethod>
    <JadeMethod name="setValuesToDate" id="7e1c57f3-a8e1-43e0-a118-452594f1bffb">
        <updating/>
        <source>setValuesToDate(_date : Date) updating;
/*

Date		    Who			Reason
01 November 2010	cnwas3	  Initial creation

*/

vars

begin
	self.selectedDate := _date;
	self.myMonthLabel.text := _date.format("MMMM");
	self.setYear(_date.year());
epilog

