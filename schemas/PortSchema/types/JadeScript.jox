    <JadeMethod name="rel831_par35164" id="3da8232a-4d4f-4400-8731-ef59ca661b28">
        <source>rel831_par35164();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 November 2014	cnwndl1	Initial creation	Par 35164

*/

vars

	iter : Iterator;
	iter2 : Iterator;
	iter3 : Iterator;
	rail : CM_Rail;
	alloc : CM_YardAllocation;
	allocInvalidObj : Boolean;
	railAlloc : CM_RailAllocation;
	wagCont : CM_WagonController;
	wagContInvalidObj : Boolean;
	wagon : CM_Wagon;
	wagonSet : CM_WagonSet;

begin

	app.initialize();

	//get a collection of all wagons that reference a rail allocation, hanging off a Rail area
	create wagonSet transient;
	
	on Exception do app.handleDeletedObject( exception, alloc, allocInvalidObj );
	on Exception do app.handleDeletedObject( exception, wagCont, wagContInvalidObj );

	iter := CM_Rail.instances.createIterator;
	while iter.next( rail ) do
		iter2 := rail.allYardAllocations.createIterator;
		while iter2.next( alloc ) do
			allocInvalidObj := false;
			if not alloc.isRailAllocation then
				continue;
			endif;
			if allocInvalidObj then
				continue;
			endif;
			railAlloc := alloc.CM_RailAllocation;
			iter3 := railAlloc.allWagonControllers.createIterator;
			while iter3.next( wagCont ) do
				wagContInvalidObj := false;
				wagon := wagCont.myWagon;
				if wagContInvalidObj or wagon = null then
					continue;
				endif;
				wagonSet.addNoDuplicates(wagon,false);
			endwhile;
			delete iter3;
		endwhile;
		delete iter2;
	endwhile;
	delete iter;
	
	//If the wagon has departed, clear the association with the Rail allocation.
	iter := wagonSet.createIterator;
	while iter.next( wagon ) do
		if  wagon.isDeparted then
			beginTransaction;
			wagon.setRailAllocation( null, app.myPassport);
			commitTransaction;
		endif;
	endwhile;
	
epilog

	delete iter;
	delete iter2;
	delete iter3;
	delete wagonSet;

end;</source>
    </JadeMethod>
    <JadeMethod name="rel832_par34945" id="e0a3baf9-df17-4e82-99ce-50aaefbe1bf8">
        <source>rel832_par34945();
/*

Date		Who		Reason
28 October 2014	cnwer1	Initial creation PAR

*/

vars
	etAgent	: EntTableAgent;
	array : StringArray;
	menuRoot	: CM_MenuRootForRoot;
	menuItem : CM_MenuItem ;
	const : Constant;
	menuAgent		: CM_MenuAgent;
begin
	
	app.initialize();
	
	create array transient;
	array.add("ETDef_ContainerFull");
	array.add("ETDef_ContainerEmpty");
	array.add("ETDef_ContainerFullReefer");
	array.add("ETDef_GeneralCargo");
	array.add("ETDef_GeneralCargoReefer");
	
	create etAgent transient;
	etAgent.myEntTableDataRoot := app.myRoot.myEntTableDataRoot;
	etAgent.trxUpdateFromConstant(array);
	
	const :=currentSchema.getConstant("PmShipPrenoteMaint");
	
	
	if const &lt;&gt; null then
		create menuAgent transient;
		beginTransaction;
		menuAgent.sendMsgWithParams("loadJMTDefaultMenuDetails",const,false,menuAgent.myJMTMenuRoot);
		commitTransaction;
	endif;
	
	return;
	write ETDef_ContainerFull;
	write ETDef_ContainerEmpty;
	write ETDef_ContainerFullReefer;
	write ETDef_GeneralCargo;
	write ETDef_GeneralCargoReefer;
	write PmShipPrenoteMaint;
epilog
	delete menuAgent;
	delete etAgent;
	delete array;
end;</source>
    </JadeMethod>
    <JadeMethod name="rel832_par35008" id="5f228d41-94ca-4342-a21b-7a9db63fd790">
        <source>rel832_par35008();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 October 2014	cnwndl1	Initial creation	PAR 35008

*/

vars

	termRole : CM_SecurityRoleTerminalRoot;
	sysRole : CM_SecurityRoleSystemRoot;
	newPerms : IntegerArray;
	
	etAgent	: EntTableAgent;
	array : StringArray;
	
	transAgent 	: CM_TranslationAgent;
	tmpArray 	: StringArray;
	
	term : CM_Terminal;
	index : Integer;
	iter : Iterator;
	vbSlot : CM_VehicleBookingTimeSlot;
	
begin

	app.initialize();

	create newPerms transient;
	newPerms.add(PmAdmVBTypeView);	
	newPerms.add(PmAdmVBTypeMaint);

	termRole := CM_SecurityRoleTerminalRoot.firstInstance;
	sysRole := CM_SecurityRoleSystemRoot.firstInstance;
	beginTransaction;
		//system based
		termRole.setPermissionsFromIntArray(newPerms,false);
		sysRole.setPermissionsFromIntArray(newPerms,true);
	commitTransaction;
	
	create etAgent transient;
	create array transient;
	etAgent.myEntTableDataRoot := app.myRoot.myEntTableDataRoot;
	
	array.add("ETRow_Volume");
	array.add("ETDef_CreateNewCargo");
	array.add("ETGrp_VehicleSchedule");
	array.add("ETRow_CargoBookingIds");
	array.add("ETRow_Id");
	array.add("ETRow_Code");
	array.add("ETRow_Description");
	array.add("ETRow_NotAvailableForEntry");
	array.add("ETRow_TsType");
	array.add("ETRow_VehicleBookingSlots");
	array.add("ETRow_VvsBooking");
	array.add("ETRow_CargoReleaseIds");
	array.add("ETDef_TimeSlotTemplate");
	array.add("ETDef_VehicleSlotDisplay");
	array.add("ETDef_AssociateBooking");
	array.add("ETDef_AssociateBooking");
	array.add("ETDef_VBTimeslotSearch");
	array.add("ETDef_BookRefThumb");
	array.add("ETDef_BookRefDataTbl");
	array.add("ETDef_MTReleaseDataTable");
	array.add("ETDef_MTReleaseThumb");
	array.add("ETDef_VisitRecordThumb");
	array.add("ETDef_VBTimeSlotType");
	
	etAgent.trxUpdateFromConstant(array);
	
	create transAgent transient;
	create tmpArray transient;
	tmpArray.add('Must_have_carri_befor_assoc_ve');
	tmpArray.add("Marke_not_avail_entry_will_cle");
	tmpArray.add("VehicleBookingId");
	tmpArray.add("Active_booking_not_found");
	transAgent.trxLoadSpecificErrors(tmpArray);
	
	foreach term in app.myRoot.allTerminals where term.myVehicleBookingTerminal &lt;&gt; null do
		if term.getConfig(VsUseVehicleScheduling).Boolean then
			index := 0;
			iter := term.myVehicleBookingTerminal.allBookingsByTS.createIterator;
			while iter.next( vbSlot ) do
				if index &gt; 9990 then
					index := 0;
				endif;
				vbSlot.setIdForConversion( index );
			endwhile;
			delete iter;
		endif;
	endforeach;

	return;
	
	write ETGrp_VehicleSchedule;
	write ETRow_CargoBookingIds;
	write ETRow_Id;
	write ETRow_Code;
	write ETRow_Description;
	write ETRow_NotAvailableForEntry;
	write ETRow_TsType;
	write ETDef_TimeSlotTemplate;
	write ETDef_VehicleSlotDisplay;
	write ETDef_AssociateBooking;
	write ETDef_VBTimeslotSearch;
	write ETRow_VehicleBookingSlots;
	write ETDef_BookRefThumb;
	write ETView_MultiBR;
	write ETView_BookRefNoMulti;
	write ETDef_BookRefDataTbl;
	write ETDef_MTReleaseDataTable;
	write ETDef_MTReleaseThumb;
	write ETRow_VvsBooking;
	write ETDef_VisitRecordThumb;
	write ETRow_CargoReleaseIds;
	write Must_have_carri_befor_assoc_ve;
	write Marke_not_avail_entry_will_cle;
	write VehicleBookingId;
	write Active_booking_not_found;
	write ETDef_VBTimeSlotType;
	
	
	
epilog

	delete newPerms;
	delete etAgent;
	delete array;
	delete transAgent;
	delete tmpArray;
	delete iter;

end;
</source>
    </JadeMethod>
