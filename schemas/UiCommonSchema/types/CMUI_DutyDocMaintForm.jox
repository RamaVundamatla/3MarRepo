        <updating/>
        <source>cmbConsignee_lostFocus(combobox: ComboBox input) updating;
begin
	
	if combobox.listObject.CM_ConsigneeConsignor &lt;&gt; null then
		self.lblConExpiryVal.caption := combobox.listObject.CM_ConsigneeConsignor.licenseExpiryDate.asStringJMT();
		// PAR 32897
		if combobox.listObject.CM_ConsigneeConsignor.hasExpired then
			self.lblConExpiryVal.foreColor := Red;
		else
			self.lblConExpiryVal.foreColor := Black;
		endif;
	else
		self.lblConExpiryVal.caption := null;
	endif;
end;</source>
