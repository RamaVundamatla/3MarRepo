    <JadeMethod name="doOK" id="6798ad21-cd48-414d-88b2-edcbba3e61cb">
        <updating/>
        <source>doOK() updating;
// ---------------------------------------------------------------------------
// Created:     07 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	oldPass,
	newPass,
	newPass2	: String;
	term		: CM_Terminal;
	tmpError	: CM_Error;
	theResult : Integer;	//13 Jan 2020 NDL	TFS 46815
	
begin

	app.mousePointer := MousePointer_HourGlass;

	// Par 13796
	//oldPass 	:= txtOldPassword.text.toUpper;		
	//newPass 	:= txtNewPassword.text.toUpper;
	//newPass2	:= txtNewPassword2.text.toUpper;
	
	oldPass 	:= txtOldPassword.text;		
	newPass 	:= txtNewPassword.text;
	newPass2	:= txtNewPassword2.text;
	
	//13 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxUA.trxUpdatePassword(true, app.getMyUserCode, oldPass, newPass, newPass2, app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			modalResult := 0;
			unloadForm;
			return;
		else
			theResult := app.showErrorWarningDialog('Error(s)', app.myPassport, ErrWarnMode_Update);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		tmpError := app.myPassport.allErrors.first;
		if ( tmpError &lt;&gt; null and tmpError.errorCode = ERR_PASSWORD )
		or oldPass = null	//22 Mar 2021	NDL	TFS 50978
		then
			txtOldPassword.setFocus;
		else
			txtNewPassword.setFocus;
		endif;
		
		break;	//22 Mar 2021	NDL	TFS 50978
		
	endwhile;

epilog
	app.mousePointer := MousePointer_Default;
	
end;</source>
    </JadeMethod>
