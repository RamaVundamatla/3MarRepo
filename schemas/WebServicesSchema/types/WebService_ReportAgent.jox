    <JadeMethod name="doGetQueryFilter" id="a92d3655-5303-40d5-8ecc-417442bb0604">
        <updating/>
        <source>doGetQueryFilter() : CMQF_FilterReports updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 Sep 2008	cnwkao1	Initial creation
18 Jan 2012	cnwkpd1	PAR #28954 - Add handling of user parameter input
18 Sep 2019	jlgdap1	TFS 45769 JMT Web Portal selector query parameters
19 Nov 2024 navah1	Bug 19289: CUX - Case # 00572807 - Report Runner shows "No Data to Display"
*/

vars
	filterObject		: CMQF_FilterReports;
	critHolder,
	clonedCritHolder	: CM_QueryCriteriaLineHolder;
	critLine,
	clonedCritLine		: CM_SelectorCriteriaLine;
	param				: CM_QueryReportParam;
	transParam			: CM_QueryReportParam;
	inputParam			: WS_ReportParameter;
	edition : Integer;	//18 July 2016	NDL	TFS 2329
	invalid : Boolean;	//18 July 2016	NDL	TFS 2329
	clonedOp			: CM_QueryOperator;
	clonedProp			: CM_QueryProperty;
	value				: Any;
	valuesToDelete		: ObjectArray;						// TFS 45769
	rangeArray			: IntegerArray;						//22.11.2024 navah1 #19289
	reportAgent			: CMUI_ReportAgentStd;				//22.11.2024 navah1 #19289
begin

	on Exception do app.handleDeletedObject( exception, param, invalid );	//18 July 2016	NDL	TFS 2329
	
	create valuesToDelete transient;						// TFS 45769
	filterObject := self.myQryReport.createFilter();
	if filterObject &lt;&gt; null then
		filterObject.initialize();
		filterObject.allQueryReportParams.clear();
		
		//setup any actual parameters
		foreach param in self.myQryReport.allQueryReportParams do
			
			//18 July 2016	NDL	TFS 2329
			invalid := false;
			edition := param.edition;
			if invalid then
				continue;
			endif;
		
			transParam := param.cloneSelf(true);
			// PAR 328954 - handle input user parameters
			inputParam := self.allWSReportParams[transParam.paramName];		
			if inputParam &lt;&gt; null then
				transParam.setDefaultValue(inputParam.value);
			endif;

			filterObject.allQueryReportParams.add(transParam);		
		endforeach;
			
		//setup filtering details
		if self.myQryReport.mySelectorQuery &lt;&gt; null then
			filterObject.selectorMode := self.myQryReport.mySelectorQuery.queryMode;
			foreach critHolder in self.myQryReport.mySelectorQuery.allCriteriaLineHolders do
				clonedCritHolder := filterObject.addClonedQryCriteria( critHolder, true );	//18 July 2016	NDL	TFS 2329
				//epr TFS 45769 30/7/19
				if clonedCritHolder = null then
					continue;
				endif;
				//epr need to add here to get transients deleted
				self.allCriteriaLineHolders.add(clonedCritHolder);
				foreach critLine in critHolder.allCriteriaByPropertyName do
					clonedCritLine := critLine.cloneSelf(true);
					clonedCritLine.setMyCriteriaLineHolder(clonedCritHolder);
					if critLine.isUnavailableAtRunTime then
						continue;
					endif;
					
					clonedProp := clonedCritLine.myQueryProperty;
					clonedOp := clonedCritLine.myQueryOperator;
					inputParam := self.allWSReportParams[critLine.propName];
					if inputParam = null and critLine.propName = CM_TrackedItem::getAllTransactions.name then				// TFS 45769
						inputParam := self.allWSReportParams[ETRow_TransactionType];										// TFS 45769
					elseif inputParam = null and critLine.propName = CM_TrackedItem::getAllocationsForMyTermArea.name then	// TFS 45769
						inputParam := self.allWSReportParams[ETRow_YardAllocations];										// TFS 45769
					endif;																									// TFS 45769
					if inputParam &lt;&gt; null then
						
						value := clonedProp.translateToSearchValueForWeb(inputParam.value, false);							// TFS 45769
						if clonedOp.isKindOf(CM_QDateDayRange) then															//22.11.2024 navah1 #19289
							create rangeArray transient;
							create reportAgent transient;
							reportAgent.getRangesFromString(value.asString,rangeArray);
							value := rangeArray;
						endif;
						clonedOp.setSearchValue(value);
						if value.isKindOf(Collection) then				// TFS 45769
							valuesToDelete.add(value.Collection);		// TFS 45769
						endif;											// TFS 45769
					
					endif;		
					
				endforeach;
			endforeach;
		else
			filterObject.setFromAgent(self);
		endif;
	endif;
	return filterObject;
epilog
	delete reportAgent;					//22.11.2024 navah1 #19289
	delete rangeArray;					//22.11.2024 navah1 #19289
	if valuesToDelete &lt;&gt; null then		// TFS 45769
		valuesToDelete.purge;			// TFS 45769
	endif;								// TFS 45769
	delete valuesToDelete;				// TFS 45769
end;</source>
        <ReturnType type="CMQF_FilterReports"/>
    </JadeMethod>
    <JadeMethod name="doGetUserQueries" id="d7ca76c1-c7f7-4c90-9dfb-4766853adbae">
        <source>doGetUserQueries(_menuEntity : CM_MenuEntity; _queries : CM_MenuEntityArray input);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 04/10/2019	jlgdap1		Initial creation TFS 46315 JMT Proforma Report Issue
//
vars
	subEntity : CM_MenuEntity;

begin
	if _menuEntity.isKindOf(CM_MenuUserQuery) then
		if _menuEntity.CM_MenuUserQuery.getQueryDefinition.isCargoType then
			_queries.addExclusive(_menuEntity.CM_MenuUserQuery);
		endif;
	else
		foreach subEntity in _menuEntity.allChildren do
			self.doGetUserQueries(subEntity, _queries);
		endforeach;
	endif;
epilog

end;</source>
        <Parameter name="_menuEntity" type="CM_MenuEntity"/>
        <Parameter name="_queries" type="CM_MenuEntityArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doGetUserQueryFromName" id="f1b8261a-b56f-4fc7-bd3f-1fc65b4f59ed">
        <source>doGetUserQueryFromName(_menuEntity : CM_MenuEntity; _queryName : String) : CM_MenuUserQuery;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 04/10/2019	jlgdap1		Initial creation TFS 46315 JMT Proforma Report Issue
//
vars
	subEntity : CM_MenuEntity;

begin
	if _menuEntity.isKindOf(CM_MenuUserQuery) then
		if _menuEntity.CM_MenuUserQuery.getHeading = _queryName then
			return _menuEntity.CM_MenuUserQuery;
		endif;
	else
		foreach subEntity in _menuEntity.allChildren do
			self.doGetUserQueryFromName(subEntity, _queryName);
		endforeach;
	endif;
epilog

end;</source>
        <Parameter name="_menuEntity" type="CM_MenuEntity"/>
        <Parameter name="_queryName" type="String"/>
        <ReturnType type="CM_MenuUserQuery"/>
    </JadeMethod>
    <JadeMethod name="doLoadTerminals" id="7b4f234d-3a8b-4785-844e-46ad14abd5f1">
        <updating/>
        <source>doLoadTerminals(_qryReport: CM_QryReport): String updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
23 September 2008	cnwkao1	Initial creation
30 Jan 2009	cnwkpd1	PAR #17554 - Development of new RIA Web Service application
					Restrict reporting to currently signed on Terminal only

*/

vars
	user			: CM_User;
	userTerminal	: CM_UserTerminal;
	terminal		: CM_Terminal;
	
begin
	if _qryReport = null then
		return null;
	endif;
	
	user := app.myPassport.myUser;
	if user = null then
		return null;
	endif;
	
	if app.myPassport.myTerminal &lt;&gt; null then
		self.allTerminals.add(app.myPassport.myTerminal);
	endif;

/*	KPD - run only for current Terminal

	foreach userTerminal in user.allUserTerminals do
		terminal := userTerminal.getMyTerminal();
		
		if (not userTerminal.canDoReport(_qryReport.menuId)) then
			continue;
		endif;
		
		if not self.allTerminals.includes(terminal) then
			self.allTerminals.add(terminal);
		endif;		
	endforeach;
*/

	return null;
	
epilog

end;</source>
        <Parameter name="_qryReport" type="CM_QryReport"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="doParseIMEX" id="3dda18c0-2265-47d1-a1f2-1bca96a20b97">
        <source>doParseIMEX(_col : CM_IMEXStatusByCodeDict) : String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 September 2008	cnwkao1 - copied directly from WebSchema

*/

constants
	DoubleQuote = '"';
	Comma = ',';
vars
	str 	: String;
	imex	: CM_IMEXStatus;
	
begin

	if _col.isEmpty then 
		return null;
	endif;
	
//	str := DoubleQuote;
	
	foreach imex in _col do
	
	//	str :=  str &amp; imex.getOidString() &amp; Comma;
		str :=  str &amp; Comma &amp; imex.getOidString();
		
	endforeach;
	
	
//	return 	str &amp; DoubleQuote;

	if str.length &gt; 1 then
		return str[2:end];
	endif;
	
	return str;
	
end;</source>
        <Parameter name="_col" type="CM_IMEXStatusByCodeDict"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getBinaryData" id="a3cf70da-b00e-4660-99bf-532f0629a5fb">
        <source>getBinaryData() : Binary;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 September 2008	cnwkao1	Initial creation - following the WebSchema implementation

*/
vars

begin

	if self.myReportData &lt;&gt; null then
		return self.myReportData.getDataAsBinary();
	endif;
	return null;


end;</source>
        <ReturnType type="Binary"/>
    </JadeMethod>
    <JadeMethod name="getDefaultValue" id="68cb99da-3c13-4e04-975c-fa05f4f1c75a">
        <source>getDefaultValue(_type : String; _objectOids : String output) : Object protected;


/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 September 2008	cnwkao1	- copied directly from WebSchema
29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
*/

vars

	filterObject	: CMQF_FilterReports;
	obj				: Object;

begin

	if self.myQryReport &lt;&gt; null and self.myQryReport.myFilterObject &lt;&gt; null then
		filterObject := self.myQryReport.myFilterObject;
		
		if _type = ETRow_TerminalAreaType then
			if filterObject.terminalAreaTypes.isNotEmpty then
				obj := app.myRoot.allTerminalAreaTypes[filterObject.terminalAreaTypes.first];
			endif;
		elseif _type = ETRow_CargoType then
			obj := filterObject.getMyCargoType;
		elseif _type = ETRow_CarrierCode then
			if filterObject.isKindOf(CMQF_LogTransaction) then
				obj :=  app.myRoot.allCarriers[filterObject.CMQF_LogTransaction.carrierCode];
			elseif filterObject.isKindOf(CMQF_Log) then
				obj := app.myRoot.allCarriers[filterObject.CMQF_Log.carrierCode];
			endif;
		elseif _type = ETRow_Consignee then
			obj :=  app.myRoot.allConsigneeConsignors[filterObject.consignee];
		elseif _type = ETRow_Consignor then
			obj := app.myRoot.allConsigneeConsignors[filterObject.consignor];
		elseif _type = ETRow_IsoTypeGroup then
			if filterObject.isKindOf(CMQF_TrackedItem) then
				obj := filterObject.CMQF_TrackedItem.getMyISOTypeGroup;
			elseif filterObject.isKindOf(CMQF_BulkRelease) then
				obj := filterObject.CMQF_BulkRelease.getMyISOTypeGroup;
			endif;
		elseif _type = ETRow_LoadPort then
			if filterObject.isKindOf(CMQF_TrackedItem) then
				obj := filterObject.CMQF_TrackedItem.getMyLoadPort;
			endif;
		elseif _type = ETRow_Operator then
			obj := filterObject.myOperator;
		elseif _type = ETRow_OperatorGroup then
			if filterObject.isKindOf(CMQF_TrackedItem) then
				obj := filterObject.CMQF_TrackedItem.getMyOperatorGroup;
			elseif filterObject.isKindOf(CMQF_BulkRelease) then
				obj := filterObject.CMQF_BulkRelease.getMyOperatorGroup;
			endif;
		elseif _type = ETRow_DischargePort then
			if filterObject.isKindOf(CMQF_TrackedItem) then
				obj := filterObject.CMQF_TrackedItem.getMyPort;
			elseif filterObject.isKindOf(CMQF_SOHLocationLog) then
				obj := filterObject.CMQF_SOHLocationLog.getMyDischargePort; 
			endif;
		elseif _type = ETRow_TerminalAreaId then
			obj := filterObject.getMyTerminalArea;
		elseif _type = ETRow_IMEXStatuses then		
			_objectOids := self.doParseIMEX(filterObject.CMQF_TrackedItem.allQryIMEXStatuses);
			obj := null;
		endif;
	endif;

epilog
	
	if obj &lt;&gt; null then
		_objectOids := obj.getOidString();
	endif;
	
	return obj;

end;</source>
        <access>protected</access>
        <Parameter name="_type" type="String"/>
        <Parameter name="_objectOids" type="String" usage="output"/>
        <ReturnType type="Object"/>
    </JadeMethod>
    <JadeMethod name="getReportFileName" id="32858f1b-6221-4832-a021-0a9856def9d5">
        <source>getReportFileName() : String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 September 2008	cnwkao1	Initial creation - copied d

*/

vars

begin

	if self.myQryReport &lt;&gt; null then
		return self.myQryReport.reportName.doInvalidCharacterSweep();
	endif;
	
	return 'tmp';

end;</source>
        <ReturnType type="String"/>
