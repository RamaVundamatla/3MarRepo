    <JadeMethod name="getAuditText" id="01fec289-a089-4d62-be65-41d06e32aac8">
        <source>getAuditText(): String;
/*
Purpose:			

Date		Who		Reason
21 July 2023	navab1	// ### TFS CR 58246 TASK 58249 21JUL2023 NAVAB1
*/

vars
	txt,
	tmpStr	: String;
	
begin
	txt[10000] 	:= '*';
	txt 		:= null;
	txt 		:= inheritMethod();
	
	if self.myInvoiceLine &lt;&gt; null then
		tmpStr := self.myInvoiceLine.sequenceNum.String;
		if tmpStr &lt;&gt; null then
			txt := txt &amp;'Invoice Line'&amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp;tmpStr &amp; AuditStringSeparator;
		endif;
	endif;
	
	return txt;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
