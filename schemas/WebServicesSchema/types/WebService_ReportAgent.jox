    <JadeMethod name="getSelectedIMEXStat" id="f4be11c0-5f01-45de-81d6-666186377c10">
        <source>getSelectedIMEXStat(_imexArray: IntegerArray input);
/*

Purpose:			Get the imex statuses from the report parameters

Parameters:			_imexArray: The array to be filled with selected IMEX status codes

Date				Who		Reason
15 February 2019	jlgzm1	TFS42515 IMEX status report parameters not working from WEB.
12 Aug 2022 navtnr20 Bug 52451: MTN - WebServices not using getObjectOfTypeFromOid
*/

vars
	
	str 		: String;
	strArray	: StringArray;
	imex		: CM_IMEXStatus;
	reportParam	: WS_ReportParameter;
	
begin

	//raise error if methid parameter is null
	if _imexArray = null then
		app.raiseCMException2(MethodWithNullParam, method.name, '_imexArray', null, null);
		return;
	endif;

	//get the IMEX status oids from report parameters
	reportParam := self.allWSReportParams.getAtKey(ETRow_IMEXStatuses);
	if reportParam &lt;&gt; null then
		str := reportParam.value;
	endif;	

	//get IMEX status objects from the string, and add to array
	if str.length &gt; 0 then
		create strArray transient;
		str.getTokensForDelimiter("|", strArray);
		foreach str in strArray do
			//imex := str.asOid.CM_IMEXStatus;	 //12.08.2022 navtnr20 52451
			imex := app.myPassport.getObjectOfTypeFromOid(str,CM_IMEXStatus).CM_IMEXStatus;		//12.08.2022 navtnr20 52451
			if imex &lt;&gt; null then
				_imexArray.add(imex.code);
			endif;
		endforeach;
	endif;

epilog
	delete strArray;
end;</source>
        <Parameter name="_imexArray" type="IntegerArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getSelectedIMEXStatuses" id="46776f37-feb8-4307-9699-1ad0599dc0af">
