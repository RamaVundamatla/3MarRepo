    <JadeMethod name="populateAllWagonsOnCreate" id="0e61725a-e687-4bf5-aa54-42a60c8d7806">
        <source>populateAllWagonsOnCreate() protected;

/*

Purpose:			

Only called during a create of a persistant object.
To find all of the existing CM_Wagon objects that should be related to me
when the CM_WagonMaster is created.
( i.e. data conversion for pre-existing systems)  

Parameters:			

Return Value:		


Date		Who		Reason
02 July 2009	cnwndl1	Initial creation

*/

vars

	uniqueId : String;

	iter : Iterator;
	terminal : CM_Terminal;
	
	iter2 : Iterator;
	startWagon : CM_Wagon;
	wagon : CM_Wagon;
	
begin

	self.raiseExceptionIfTransient(method);
	
	uniqueId := self.id;

	iter := app.myRoot.allTerminals.createIterator;
	while iter.next( terminal ) do

		startWagon := terminal.allWagons.getAtKeyLeq(uniqueId,null);
		if startWagon = null or startWagon.id &lt;&gt; uniqueId then
			continue;
		endif;
		
		iter2 := terminal.allWagons.createIterator;
		iter2.startAtObject(startWagon);

		while iter2.next( wagon ) do
			if wagon.id &lt;&gt; uniqueId then
				break;
			endif;
			wagon.setMyWagonMaster(self,null);
		endwhile;
		delete iter2;
		
	endwhile;
	
epilog

	delete iter;
	delete iter2;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
