    <JadeMethod name="cmbTerminal_click" id="f55a2ec2-a7fa-41c2-9b9e-12f45b5a9472">
        <controlMethod name="CMUI_ComboBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbTerminal_click(combobox: ComboBox input) updating;

// Created by cnwdvb1 on 09 November 2006

vars
	
	class : Class;
	terminal : CM_Terminal;
	finIO:   CM_ExtFinanceIO;
begin

	class := self.cmbTaskTypes.listObject.Class;
	terminal:=self.cmbTerminal.listObject.CM_Terminal;
	if class = CM_AutoTaskStockAdjustment then
		self.myAssistant.comboBoxLCByType(self.cmbLocations, TA_TYPE_BULK,terminal);
	endif;
	if class = CM_AutoTaskKPISpaceUtilisation then
		self.doListBoxTermAreaBuild(terminal);
	endif;
	
	//jlier1 TFS 53286 13/4/22
	if class = CM_AutoTaskIFS then
		if terminal &lt;&gt; null then
			self.myAssistant.myTerminal:=terminal;
			self.myAssistant.comboBoxBank(self.cmbBank,null);
			finIO := terminal.getConfig(FinancialIOClass).CM_ExtFinanceIO;
			if finIO &lt;&gt; null and finIO.isKindOf(CM_SALInterface) then
				self.tblTaskCreation.setValueByName(ETRow_BgpExternalFinInterface,finIO.getNiceName);
				self.tblTaskCreation.setValueByName(ETRow_BgpAutoDirectoryPath,finIO.exportPath);
			else
				self.tblTaskCreation.setValueByName(ETRow_BgpExternalFinInterface,null);
				self.tblTaskCreation.setValueByName(ETRow_BgpAutoDirectoryPath,null);
			endif;
		endif;
	endif;

end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
