    <JadeMethod name="btnClose_click" id="f4cf0e57-2f12-4c6b-9672-dfaa5152f0fd">
        <controlMethod name="JadeMask::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnClose_click(jadeMask: JadeMask input) updating;
/*
*/
begin
	self.unloadForm;
end;</source>
        <Parameter name="jadeMask" type="JadeMask" usage="input"/>
    </JadeMethod>
    <JadeMethod name="cmbChangeClasses_click" id="40eda30d-ffa0-4c8d-8817-ffcc8971eeba">
        <controlMethod name="ComboBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbChangeClasses_click(combobox: ComboBox input) updating;
/*
*/
begin
	tblChanges.displayCollection(combobox.listObject.JSSCTChangeTrackingClass.allChangesByOid, true, 0, null);
	cmbDeleteClasses.listIndex := cmbDeleteClasses.findStringExact(1, cmbChangeClasses.text);
	if cmbDeleteClasses.listIndex &gt; 0 then
		tblDeletes.displayCollection(cmbDeleteClasses.listObject.JSSCTChangeTrackingClass.allChangesByOid, true, 0, null);
	else
		tblDeletes.clear;
		self.initializeDeleteTable();
	endif;
end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="cmbChangeClasses_displayEntry" id="36898388-168f-4c42-9ee9-570418687e46">
