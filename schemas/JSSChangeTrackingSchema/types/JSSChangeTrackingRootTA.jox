<Class name="JSSChangeTrackingRootTA" id="a3dd9938-7646-452e-b320-978b523a3447">
    <superclass name="JSSCTTransactionAgent"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="jssct_transient"/>
    <PrimAttribute name="daysToKeepTrackingChanges" id="7da3f376-39a8-4e30-963d-a25b42f0c0af">
        <embedded/>
        <type name="Integer"/>
    </PrimAttribute>
    <ImplicitInverseRef name="myChangeTrackingRoot" id="160bc446-0f50-48c1-b21a-14c4c7e7eab4">
        <embedded/>
        <type name="JSSCTChangeTrackingRoot"/>
    </ImplicitInverseRef>
    <JadeMethod name="doCreate" id="7eec8fed-6a7c-4688-a715-b2eef7073e1f">
        <updating/>
        <source>doCreate(): Boolean updating, protected;
/*
*/
begin
	create self.myChangeTrackingRoot persistent;
	self.myChangeTrackingRoot.createEntity(self);

	return(true);
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doUpdate" id="f9fb6287-1c20-40df-8e90-e514eab0e911">
        <updating/>
        <source>doUpdate(): Boolean updating, protected;
/*
*/
begin
	self.myChangeTrackingRoot.updateEntity(self);

	return(true);
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="lockEntity" id="76c39dca-c447-4e2e-b696-0fb37e8dd3d2">
        <source>lockEntity(): Boolean protected;
/*
*/
begin
	if self.tryLockingObject(self.myChangeTrackingRoot) then
		return (true);
	else
		return (false);
	endif;
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
