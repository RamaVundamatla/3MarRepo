    <JadeMethod name="tblItems_contextMenu" id="fdc1dbb4-9ed8-4b84-bef0-d4a331eea2bc">
        <controlMethod name="Table::contextMenu"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblItems_contextMenu(table: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating;
// ---------------------------------------------------------------------------
// Created:     08 August 2008 by cnwab1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	tranNum : String;
	entity : CMGTE_Entity;
begin
	self.mnuUpdateVehicle.visible := false;
	self.mnuUpdateVehicle.userObject := null;
	
	if self.myRealVVR &lt;&gt; null and app.isSpecial() then
		tranNum := self.myRealVVR.visitNumber;
		self.mnuUpdateVehicle.caption := "Update Transaction " &amp; tranNum &amp; " Vehicle Details";
		self.mnuUpdateVehicle.userObject := self.myRealVVR;
		self.mnuUpdateVehicle.visible := true;
	endif;
	if table.row &gt; table.fixedRows then
		self.mnuInspect.visible       := app.isAllowedToInspect();
		self.mnuInspect.userObject    := table.accessRow(table.row).itemObject;
		self.mnuPrintLabel.userObject := table.accessRow(table.row).itemObject;
		
		//27 May 2011	NDL	Par 27585
		if self.myRealVVR &lt;&gt; null and not self.myRealVVR.isUpdatable then
			self.mnuRemove.visible := false;
			entity := table.accessRow(table.row).itemObject.CMGTE_Entity;
			if entity &lt;&gt; null then
				if self.myRealVVR.getWLEForGateEntity(entity) = null and entity.myYardRequest = null then
					self.mnuRemove.visible := app.myPassport.myUser.canDo(self.myTerminal, PmAdmFlexiGateRemove);
				endif;
			endif;
		endif;
		
		self.doBuildMenuCargo();
		
		return self.showContextMenu(self.mnuContext,table,conwin,mouse,x, y);
	endif;

epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
