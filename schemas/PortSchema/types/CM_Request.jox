        <source>removeBulkReleaseTI(_ti : CM_TrackedItem input) updating;
// ---------------------------------------------------------------------------
// Created:		22 July 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------

vars
	bulkRel : CM_BulkRelease; //cnwrd1 28.5.09 ccms 1804
begin
	bulkRel := self.bulkRelease;
	self.setBulkRelease(null);
	
	if _ti&lt;&gt; null then // TFS 3190
		_ti.removeBulkRelease(bulkRel);
	endif;
end;</source>
