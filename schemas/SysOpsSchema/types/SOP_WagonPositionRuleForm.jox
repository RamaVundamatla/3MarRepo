    <JadeMethod name="tblWagonPos_click" id="290e33a7-951a-4a9f-9fea-3959523ece1b">
        <controlMethod name="Table::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblWagonPos_click(table: Table input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 August 2009	cnwndl1	Initial creation

*/

vars

	isSelected : Boolean;
	obj : Object;
	
begin

	obj := self.tblWagonPos.accessRow(self.tblWagonPos.row).itemObject;
	if obj &lt;&gt; null then
		isSelected := self.tblWagonPos.accessRow(self.tblWagonPos.row).selected;
	endif;
	
	btnEditRule.enabled := isSelected;
	btnDeleteRule.enabled := isSelected;
	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		btnEditRule.enabled := false;
		btnDeleteRule.enabled := false;

	endif;
	
epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
