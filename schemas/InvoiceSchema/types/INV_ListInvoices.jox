    <JadeMethod name="doCmbConsigneeBuild" id="d1ba84f0-6daf-4cd3-a738-2c3048775048">
        <source>doCmbConsigneeBuild();
// 30931 build consignee combo

vars

	consignee : CM_ConsigneeConsignor;
begin
	self.cmbCnee.clear;
	self.cmbCnee.style := ComboBox.Style_DropDownComboList;	// 33528

	self.cmbCnee.addItem(" ");
	self.cmbCnee.itemData[self.cmbCnee.newIndex] := null;
	self.cmbCnee.listIndex := self.cmbCnee.newIndex;

	foreach consignee in app.myRoot.allConsigneeConsignors do
		if not consignee.isNotAvailableForEntry then
			if consignee.isConsignee then
				self.cmbCnee.addItem(consignee.description &amp; " " &amp; Tab &amp; consignee.code);	// 33528 show description then code to make searching easier
				self.cmbCnee.itemObject[self.cmbCnee.newIndex] := consignee;
			endif;
		endif;
	endforeach;
end;</source>
    </JadeMethod>
    <JadeMethod name="doCmbCurrencyType" id="3027727c-ab8f-4a14-9357-76e2ab7c264c">
        <source>doCmbCurrencyType(_debtor : CM_Debtor);
/*

Purpose:			Populates the currency type combo box on the form

Parameters:			_debtor	CM_Debtor	The debtor to use to load the saved currency type for the combo box

Return Value:		NONE

Date		Who		Reason
22 August 2022	navpw1	Initial creation TFS: 54564 (54382)

*/

vars
	currencyType,
	debtorCurrencyType : CM_CurrencyType;
	
begin
	self.cmbCurrencyType.clear();
	
	if _debtor &lt;&gt; null then
		foreach currencyType in app.myRoot.allCurrencyTypes discreteLock do 
			self.cmbCurrencyType.addItemObject(currencyType.code, currencyType);
		endforeach;
		
		debtorCurrencyType :=  _debtor.getDebtorCurrencyType();
		
		if self.cmbCurrencyType.listCount() &gt; 0 then
			if self.myCurrentInvoice &lt;&gt; null and self.myCurrentInvoice.myCurrencyType &lt;&gt; null then
				currencyType := self.myCurrentInvoice.myCurrencyType;
				self.cmbCurrencyType.listObject := currencyType;
				self.cmbCurrencyType.listIndex  := self.cmbCurrencyType.findObject(currencyType);
				
			elseif debtorCurrencyType &lt;&gt; null then
				self.cmbCurrencyType.listObject := debtorCurrencyType;
				self.cmbCurrencyType.listIndex  := self.cmbCurrencyType.findObject(debtorCurrencyType);
				
			endif;
		endif;
	endif;
	
end;</source>
        <Parameter name="_debtor" type="CM_Debtor"/>
    </JadeMethod>
    <JadeMethod name="doCmbDebtorAddressBuild" id="431de631-b28a-4270-a02e-28fcead1d61c">
        <source>doCmbDebtorAddressBuild(_debtor : CM_Debtor);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 July 2019	cnwma1	ChangeRequest 45577: ASPA - JMT Interface to AR Oracle
09 Aug	2019	jlgdi1	46052 Added check on myCurrentInvoice null state
*/

vars
	address : CM_Address;
begin
	self.cmbDebtorAddressProp.clear();
	
	if _debtor &lt;&gt; null then
		foreach address in _debtor.allAddressesByCode discreteLock do 
			
			self.cmbDebtorAddressProp.addItemObject(address.description,address);
			
		endforeach;

		if self.cmbDebtorAddressProp.listCount() &gt; 0 then		// 19/8/19 MAP TFS45577
			if (self.myCurrentInvoice &lt;&gt; null)  and (self.myCurrentInvoice.myBillingAddress &lt;&gt; null) then
				self.cmbDebtorAddressProp.listObject := self.myCurrentInvoice.myBillingAddress;
				self.cmbDebtorAddressProp.listIndex  := self.cmbDebtorAddressProp.findObject(self.myCurrentInvoice.myBillingAddress);
			elseif _debtor.getDefaultDebtorAddress &lt;&gt; null then
				self.cmbDebtorAddressProp.listObject := _debtor.getDefaultDebtorAddress;
				self.cmbDebtorAddressProp.listIndex  := self.cmbDebtorAddressProp.findObject(_debtor.getDefaultDebtorAddress);
			endif;
			self.tblInvProperties.setValueByControlName(self.cmbDebtorAddressProp.name, self.cmbDebtorAddressProp.text); // 07/02/2022	navkc1	CR55305 TASK 55536
		endif;
	endif;
epilog

end;</source>
        <Parameter name="_debtor" type="CM_Debtor"/>
    </JadeMethod>
    <JadeMethod name="doCmbDebtorAltAddressBuild" id="ae9f544b-bbd4-4023-a608-483e2a1cf8be">
        <source>doCmbDebtorAltAddressBuild(_debtor : CM_Debtor);
/*

Purpose:			Populates the debtor alternative address combo box on the form

Parameters:			_debtor	CM_Debtor	The debtor to use to load the saved alternative addresses for the combo box

Return Value:		NONE

Date		Who		Reason
19 August 2022	navpw1	Initial creation TFS: 54564 (54381)

*/

vars
	address,
	debtorAltAddress,
	debtorDefaultAddress	: CM_Address;
	
begin
	self.cmbDebtorAltAddrProp.clear();
	
	if _debtor &lt;&gt; null then
		foreach address in _debtor.allAddressesByCode discreteLock do 
			self.cmbDebtorAltAddrProp.addItemObject(address.description,address);
		endforeach;
		
		debtorAltAddress 		:= _debtor.getDebtorAlternativeAddress();
		debtorDefaultAddress 	:= _debtor.getDefaultDebtorAddress();
		
		if self.cmbDebtorAltAddrProp.listCount() &gt; 0 then
			if self.myCurrentInvoice &lt;&gt; null  and self.myCurrentInvoice.myAlternativeAddress &lt;&gt; null then
				address := self.myCurrentInvoice.myAlternativeAddress;
				self.cmbDebtorAltAddrProp.listObject := address;
				self.cmbDebtorAltAddrProp.listIndex  := self.cmbDebtorAltAddrProp.findObject(address);
				self.tblInvProperties.setValueByControlName(self.cmbDebtorAltAddrProp.name, self.cmbDebtorAltAddrProp.text);
				
			elseif debtorAltAddress &lt;&gt; null then
				self.cmbDebtorAltAddrProp.listObject := debtorAltAddress;
				self.cmbDebtorAltAddrProp.listIndex  := self.cmbDebtorAltAddrProp.findObject(debtorAltAddress);
				self.tblInvProperties.setValueByControlName(self.cmbDebtorAltAddrProp.name, self.cmbDebtorAltAddrProp.text);
				
			elseif debtorDefaultAddress &lt;&gt; null then
				self.cmbDebtorAltAddrProp.listObject := debtorDefaultAddress;
				self.cmbDebtorAltAddrProp.listIndex  := self.cmbDebtorAltAddrProp.findObject(debtorDefaultAddress);
				self.tblInvProperties.setValueByControlName(self.cmbDebtorAltAddrProp.name, self.cmbDebtorAltAddrProp.text);
				
			endif;
		endif;
	endif;
	
end;</source>
        <Parameter name="_debtor" type="CM_Debtor"/>
    </JadeMethod>
    <JadeMethod name="doCmbDebtorBuild" id="ca3c1ab3-0d8e-4adf-9be9-fc19379f5421">
        <source>doCmbDebtorBuild(_combo : CMUI_ComboBox input);
// ---------------------------------------------------------------------------
// Created:		March 2004 By Andrew Bishop cnwab1
//
// Purpose:		
// 03/02/2023	navkc1	TFS CR 55305 Task 55536 UI - Invoice Credit Note UI
// ---------------------------------------------------------------------------

vars

	debtor : CM_Debtor;

begin

	_combo.clear;
	_combo.sorted := false;
	
	// 03/02/2023	navkc1	TFS CR 55305 TASK 55536
	//_combo.addItem(app.getErrorString(CM_All_Debtors));
	//_combo.itemObject[_combo.newIndex] := null;
	//_combo.listIndex := _combo.newIndex;

	// Par 14209
	foreach debtor in app.myRoot.myRootCompany.debtors where not debtor.isSuspended do
		_combo.addItem(debtor.name);
		_combo.itemObject[_combo.newIndex] := debtor;
	endforeach;

	_combo.listIndex := 1;
	self.tblInvProperties.setValueByControlName(_combo.name, _combo.text);
end;</source>
