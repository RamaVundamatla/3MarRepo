    <JadeMethod name="translateCommodity" id="17cc1b4f-f1e4-4ba5-8dc5-9dec3d4536e9">
        <updating/>
        <source>translateCommodity(_xlationOperator :CM_Operator) updating, protected;
/*
Date		Who		Reason
10 Apr 2013	cnwcs5	Initial Creation - CCMS POL 2097/par 31259
18 Mar 2019	jlgrs1	TFS 41913 STWR - Reconfiguration of the EDI Operation form to better handle EDI collection locks while loading 
21 Nov 2022	navma1	ChangeRequest 55424: MTN - Improve the performance of Edi file loading
*/
vars
	hasCommodity   : Boolean;
	hasDescription : Boolean;
begin
	//hasCommodity   := self.class.getPropertyInHTree(ETRow_Commodity) &lt;&gt; null;					//21.11.2022 navma1 #55424
	//hasDescription := self.class.getPropertyInHTree(ETRow_CommodityDescription) &lt;&gt; null;      //21.11.2022 navma1 #55424
	
	hasCommodity   := self.hasPropCommodity;													//21.11.2022 navma1 #55424
	hasDescription := self.hasPropCommodityDescription;											
	
	if hasCommodity and hasDescription then
		self.translateCommodityWithDescr(_xlationOperator);
	elseif hasCommodity then
		self.translateCommodityNoDescr(_xlationOperator);
	endif;
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_xlationOperator" type="CM_Operator"/>
    </JadeMethod>
    <JadeMethod name="translateCommodityNoDescr" id="f1c2d951-8e16-4c04-acb7-6d91bf80f9ad">
        <updating/>
        <source>translateCommodityNoDescr(_xlationOperator :CM_Operator) updating, protected;
/*
12 Mar 2019	jlgrs1	TFS 41913 STWR - Reconfiguration of the EDI Operation form to better handle EDI collection locks while loading 
21 Nov 2022	navma1	ChangeRequest 55424: MTN - Improve the performance of Edi file loading
07 Dec 2022 navma1	ChangeRequest 55783: MTN - Removing unnecessary calls for Class::getPropertyInHTree() method while setting EDI property values
*/
vars
	hasCommodity  : Boolean;
	foundMatch    : Boolean;
	commodityText : String;
	description   : String;
	lTemperature  : Real;
begin
	lTemperature := NULL_TEMPERATURE;
	//if self.class.getPropertyInHTree(ETRow_Temperature) &lt;&gt; null then				//21.11.2022 navma1 #55424
	if self.hasPropTemperature then													//21.11.2022 navma1 #55424
		lTemperature := self.getPropertyValue(ETRow_Temperature).Real;
	endif;
	
	//hasCommodity := self.class.getPropertyInHTree(ETRow_Commodity) &lt;&gt; null;		//21.11.2022 navma1 #55424
	hasCommodity := self.hasPropCommodity;											//21.11.2022 navma1 #55424
	if hasCommodity then
		commodityText := self.getPropertyValue(ETRow_Commodity).String;
	endif;
	
	if commodityText = null then
		// had to store it in extraData in case it was &gt; 4 characters
		//global.getExtraData (self.allExtraData, ETRow_Commodity, commodityText);	//21.11.2022 navma1 #55424
		commodityText := self.rawDataCommodity;										//21.11.2022 navma1 #55424
	endif;
	
	if commodityText &lt;&gt; null then
		if _xlationOperator &lt;&gt; null then
			commodityText := _xlationOperator.getXlationSystemCode_Commodity(commodityText, foundMatch, lTemperature);
		endif;
		if foundMatch then
			self.setStringValue(ETRow_Commodity, commodityText,4);					//07.12.2022 navma1	#55783
		else
			self.setStringValue(ETRow_Commodity, commodityText[1:30],30);           //07.12.2022 navma1	#55783
		endif;
	endif;
	
	if commodityText = null then
		global.getExtraData (self.allExtraData, ETRow_CommodityDesc, description);
		if description &lt;&gt; null then
			if _xlationOperator &lt;&gt; null then
				commodityText := _xlationOperator.getXlationSystemCode_Commodity(description, foundMatch, lTemperature);
			endif;
		endif;
	endif;
	if foundMatch then
		self.setStringValue(ETRow_Commodity, commodityText[1:4],4);					//07.12.2022 navma1	#55783
	else
		self.setStringValue(ETRow_Commodity, commodityText[1:30],30);				//07.12.2022 navma1	#55783
	endif;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_xlationOperator" type="CM_Operator"/>
    </JadeMethod>
    <JadeMethod name="translateCommodityWithDescr" id="906fc464-818a-4a45-91f1-2a333e8d94f7">
        <updating/>
        <source>translateCommodityWithDescr(_xlationOperator :CM_Operator) updating, protected;
/*
 01 Apr 2019	jlgrs1	TFS 41913 STWR - Reconfiguration of the EDI Operation form to better handle EDI collection locks while loading 
 21 Nov 2022	navma1	ChangeRequest 55424: MTN - Improve the performance of Edi file loading
 07 Dec 2022    navma1	ChangeRequest 55783: MTN - Removing unnecessary calls for Class::getPropertyInHTree() method while setting EDI property values
*/ 
vars
	commodityObj 	      : CM_Commodity;
	invalidCommodityOK    : Boolean;
	foundMatch 		      : Boolean;
	description 	   	  : String;
	lTemperature 	      : Real;
	lCommodityDescription : String;
	lCommodity 			  : String;
	tokens 				  : HugeStringArray;
    code 				  : String;
	str 				  : String;
	root				  : CM_Root;
begin
	
	invalidCommodityOK := self.allowInvalidCommodities;
	lTemperature 	   := NULL_TEMPERATURE;

	
	//if self.class.getPropertyInHTree(ETRow_Temperature) &lt;&gt; null then		//21.11.2022 navma1 #55424
	if self.hasPropTemperature then											//21.11.2022 navma1 #55424
		lTemperature := self.getPropertyValue(ETRow_Temperature).Real;
	endif;
	
	//if self.class.getPropertyInHTree(ETRow_Commodity) &lt;&gt; null then		//21.11.2022 navma1 #55424
	if self.hasPropCommodity then											//21.11.2022 navma1 #55424
		lCommodity := self.getPropertyValue(ETRow_Commodity).String;
		if lCommodity &lt;&gt; null then
			if _xlationOperator &lt;&gt; null then
				lCommodity := _xlationOperator.getXlationSystemCode_Commodity(lCommodity, foundMatch, lTemperature);
				if foundMatch then
					self.setStringValue(ETRow_Commodity, lCommodity,4);		//07.12.2022 navma1	#55783												
				endif;
			endif;
			commodityObj := app.myRoot.allCommodities[lCommodity];
			if commodityObj &lt;&gt; null then
				return;
			endif;
		endif;
	endif;
	
	//if self.class.getPropertyInHTree(ETRow_CommodityDescription) &lt;&gt; null then				//21.11.2022 navma1 #55424
	if self.hasPropCommodityDescription then												//21.11.2022 navma1 #55424
		lCommodityDescription := self.getPropertyValue(ETRow_CommodityDescription).String;
	endif;
	
	if description = null then
		//global.getExtraData(self.allExtraData, ETRow_Commodity, description);				//21.11.2022 navma1 #55424
		description := self.rawDataCommodity;												//21.11.2022 navma1 #55424
	endif;
	if description = null then
		description := lCommodityDescription;
	endif;
	if description = null then
		global.getExtraData(self.allExtraData, ETRow_CommodityDesc, description);
	endif;
	if description = null then
		global.getExtraData(self.allExtraData, ETRow_CommodityDesc&amp;'3', description);
	endif;
	if description = null then
		if description = null then
			global.getExtraData(self.allExtraData, ETRow_CommodityDesc&amp;'7', description);
		endif;
	endif;
	
	if lCommodityDescription = null then
		if description &lt;&gt; null then
			lCommodityDescription :=  description[1:30];
			self.setStringValue(ETRow_CommodityDescription, lCommodityDescription,30);	//07.12.2022 navma1	#55783
		endif;
	endif;
	if description &lt;&gt; null then
		if _xlationOperator &lt;&gt; null then
			code := _xlationOperator.getXlationSystemCode_Commodity(description, foundMatch, lTemperature)[1:4];
		endif;
		if foundMatch then
			lCommodity :=  code;
			self.setStringValue(ETRow_Commodity, lCommodity,4);							//07.12.2022 navma1	#55783
		else
			root			   := app.myRoot;											//21.11.2022 navma1 #55424
			
			if lTemperature = NULL_TEMPERATURE then
				commodityObj := root.getCommodityByDesc(description);
				if commodityObj = null then
					commodityObj := root.allCommodities[description];
				endif;

				if commodityObj &lt;&gt; null then
					lCommodity :=  commodityObj.code;
					self.setStringValue(ETRow_Commodity, lCommodity,4);				  //07.12.2022 navma1 #55783	
				elseif invalidCommodityOK then
					self.setStringValue(ETRow_Commodity, description[1:4],4);         //07.12.2022 navma1 #55783
				endif;
			else
				commodityObj := root.getCommodityByDesc(description);
				if commodityObj = null then
					commodityObj := root.allCommodities[description];
				endif;
				if commodityObj &lt;&gt; null and
				   lTemperature &lt;= commodityObj.maxTemp and
				   lTemperature &gt;= commodityObj.minTemp then
					lCommodity :=  commodityObj.code;
					self.setStringValue(ETRow_Commodity, lCommodity,4);				//07.12.2022 navma1 #55783
				endif;
			endif;
			
			if lCommodity = null then
				create tokens transient;
				description.getTokensForDelimiterHuge (":", tokens);  //11/09/2015 cnwma1 PAR #36737
				foundMatch	:= false;
				foreach str in tokens do 
					if _xlationOperator &lt;&gt; null then
						code := _xlationOperator.getXlationSystemCode_Commodity (str, foundMatch, lTemperature); 
					endif;
					// always update description
					lCommodityDescription :=  str[1:30];
					self.setStringValue(ETRow_CommodityDescription, lCommodityDescription,30);				//07.12.2022 navma1	#55783
					if foundMatch then
						lCommodity :=  code;
						self.setStringValue(ETRow_Commodity, lCommodity,4);									//07.12.2022 navma1	#55783
						break;
					else
						// maybe they pass us a real commodity code
						if str.length &lt;= 4 then
							commodityObj := root.allCommodities[str];
							if commodityObj &lt;&gt; null then
								lCommodity :=  str;
								self.setStringValue(ETRow_Commodity, lCommodity,4);						  //07.12.2022 navma1	#55783
								break;
							endif;
						endif;
					endif;
				endforeach;
			endif;
		endif;
	endif;
epilog
	delete tokens;
end;</source>
        <access>protected</access>
        <Parameter name="_xlationOperator" type="CM_Operator"/>
    </JadeMethod>
    <JadeMethod name="translateValue" id="7b857828-d005-4c95-8833-4b0886d9f578">
        <source>translateValue(_fieldName : String; _xlationOperator : CM_Operator; _processedValue : String io) protected;
//----------------------------------------------------------------
//	Created:	cnwrs1 CCMS 1976 1 dec 2010
//----------------------------------------------------------------
// 14 Dec 2010  cnwrs1      ccms 1976 - need to keep XML and CSV EDI Files types working the same so this method 
//                          is in CM_EDIFieldMapping and in CM_EDITrackedItem they both must be kept in step in 782 the CM_EDIFieldMapping method will be removed in 791	
// 07/03/2013	cnwcs5		CCMS POL 2097 / par 31259 - remove commodity, voyage xlations, they are done later
//14 Aug 2023	jlirs1	TFS 59845 (57770) Port of Origin BOP
vars
	foreignCode 		: String;
	operatorTerminal 	: CM_OperatorTerminal;
	xlationValue 		: String;
	foundMatch 			: Boolean;
begin
	if _fieldName = ETRow_CarrierCode then
		xlationValue := _xlationOperator.getXlationSystemCode(_processedValue, XLATION_TYPE_CARRIER_BYOP, foundMatch);
				
	elseif _fieldName = ETRow_Consignee or _fieldName = ETRow_Consignor then
		xlationValue := _xlationOperator.getXlationSystemCode(_processedValue, XLATION_TYPE_CONSIGNEE_BYOP, foundMatch);
		
	elseif _fieldName = ETRow_CustomsAgent then
		xlationValue := app.myRoot.getXlationSystemCode(_processedValue, XLATION_TYPE_CUSTOMSAGENT, foundMatch);	// par 31259 March 2013
		
	elseif _fieldName = ETRow_IsoType then
		xlationValue := _xlationOperator.getXlationSystemCode(_processedValue, XLATION_TYPE_ISOTYPE_BYOP, foundMatch);
		
	elseif _fieldName = ETRow_OperatorCode then
		xlationValue := _xlationOperator.getXlationSystemCode(_processedValue, XLATION_TYPE_OPERATOR_BYOP, foundMatch);
		
		if xlationValue = _processedValue then
			xlationValue := app.myRoot.getXlationSystemCode(_processedValue, XLATION_TYPE_OPERATOR, foundMatch);	// par 31259 March 2013
		endif;
		
	elseif _fieldName = ETRow_DischargePort or _fieldName = ETRow_DestinationPort or _fieldName = ETRow_LoadPort or _fieldName = ETRow_PortOfOrigin then		//14 Aug 2023	jlirs1	TFS 59845 (57770) Port of Origin BOP
		xlationValue := _xlationOperator.getXlationSystemCode(_processedValue, XLATION_TYPE_PORT_BYOP, foundMatch);
		
	elseif _fieldName = ETRow_ShippingLine then
		xlationValue := app.myRoot.getXlationSystemCode(_processedValue, XLATION_TYPE_SHIPPINGLINE, foundMatch);	// par 31259 March 2013
		
	elseif _fieldName = ETRow_VesselName then
		// ******************* TAKE NOTE ************************/
		// the translation returns a vessel CODE not NAME !!!
		// this is WRONG but has been there too long to back it out
		xlationValue := app.myRoot.getXlationSystemCode(_processedValue, XLATION_TYPE_VESSEL, foundMatch);			// par 31259 March 2013
				
	else
		xlationValue := _processedValue;
	endif;
	
	_processedValue := xlationValue;
end;


</source>
        <access>protected</access>
        <Parameter name="_fieldName" type="String"/>
        <Parameter name="_xlationOperator" type="CM_Operator"/>
        <Parameter name="_processedValue" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="translateVesselVoyage" id="31c37af9-9d04-4778-8013-0674c99be7b2">
        <updating/>
        <source>translateVesselVoyage(_xlationOperator :CM_Operator) updating, protected;
/*
Date		Who		Reason
11 Apr 2013	cnwcs5	Initial Creation - CCMS POL 2097/par 31259
20 Jun 2013	cnwcs5	par 31854 - use getpropertyInHTree instead of getProperty
25 Feb 2019 jlgsl4  TFS 42728 - SNO - file callsign doesn't match Voyage Code translation's vessel's callsign
04 Mar 2019	jlgrs1	TFS 41913 STWR - Reconfiguration of the EDI Operation form to better handle EDI collection locks while loading 
29 Aug 2019	jlgrs1	TFS 45967 JMT TFS 41913 missed setting the customsStopTI mvVoyage 
26 Nov 2019	jlgrs1	TFS 47739 the vessel is only looked up by the vesselcode not the vessel name.
21 Nov 2022	navma1	ChangeRequest 55424: MTN - Improve the performance of Edi file loading
*/
vars
	vesselCode 			: String;
	vesselName 			: String;
	voyageDesc 			: String;
	voyageCode 		    : String;
	vessel     		    : CM_Vessel;
	foundMatch 			: Boolean;
	voyage    			: CM_Voyage;
	root				: CM_Root;
	terminal			: CM_Terminal;
begin
	
	if _xlationOperator = null then
		return;
	endif;
	
	
	
	//if class.getPropertyInHTree(ETRow_VoyageCode) = null then 					//21.11.2022 navma1 #55424
	if not self.hasPropVoyageCode then 												//21.11.2022 navma1 #55424
		return;
	endif;
	
	terminal			:= self.getMyTerminal();									//21.11.2022 navma1 #55424
	// if we already have a valid voyageCode then dont do anything
	voyageCode := self.getVoyageCode();
	if voyageCode &lt;&gt; null then
		voyage := terminal.lookupVoyage(voyageCode, null, false);					//21.11.2022 navma1 #55424
		if voyage &lt;&gt; null then
			if self.getMyVoyage = null then
				self.setVoyage(voyage);
			endif;
			return;
		endif;
	endif;
	// we previously saved the raw input in extra data
	//global.getExtraData (self.allExtraData, ETRow_VoyageCode, voyageDesc);	//21.11.2022 navma1 #55424
	voyageDesc := self.rawDataVoyageCode;										//21.11.2022 navma1 #55424
	
	if voyageDesc = null and  voyageCode &lt;&gt; null then
		voyageDesc := voyageCode;
	endif;
	
	//if class.getPropertyInHTree(ETRow_VesselName) &lt;&gt; null then 			   //21.11.2022 navma1 #55424
	if self.hasPropVesselName then 											   //21.11.2022 navma1 #55424
		// the vessel translation actually returns a vessel code :-(
		vesselCode 	:= self.getPropertyValue(ETRow_VesselName).String;
	endif;
	
	if vesselCode &lt;&gt; null then
		root   := app.myRoot;									//21.11.2022 navma1 #55424
		vessel := root.allVessels[vesselCode];					//21.11.2022 navma1 #55424
		
		if vessel &lt;&gt; null then
			vesselName := vessel.name;
		else
			vessel := root.getVesselByName(vesselCode);			//21.11.2022 navma1 #55424
			if vessel &lt;&gt; null then
				vesselName := vessel.name;
			endif;
		endif;
	endif;
	
	//if we have a vessel name then try to translate
	if vesselName &lt;&gt; null or not terminal.isEnforceCallsignForXlation() then // TFS 42728 - make what comment above suggests should happen here, happen
		voyageCode 	:= _xlationOperator.getXlationSystemCode_Voyage(voyageDesc, vesselName, null, null, foundMatch); // TFS 42728 - if Enforce is enabled
	endif; // TFS 42728
	
	self.setVoyageCode (voyageCode);
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_xlationOperator" type="CM_Operator"/>
    </JadeMethod>
    <JadeMethod name="validateCommodityPlus" id="68d30110-7018-413f-974f-a8737578bd85">
        <source>validateCommodityPlus( _commodity : CM_Commodity );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 March 2021	navndl1	Initial creation	TFS 50740
06 NOV   2022   NAVSP1  TFS Bug 52673: MTN - Error while creating prenote via EDI 
*/

vars
	term : CM_Terminal;
	cargoTypeObj : CM_CargoType;
begin	
	if self.cargoType &lt;&gt; null then
		cargoTypeObj := self.myCargoType();
	endif;
	if cargoTypeObj &lt;&gt; null and _commodity &lt;&gt; null and not cargoTypeObj.isCommodityRequired then //06NOV2022 NAVSP1 TFS 52673
		//if cargo type does not require commodity then raise exception
		app.raiseCMException2(CargoType_NotRequire_Commodity, self.cargoTypeDescr,  _commodity.code, ETRow_CargoTypeDescr, self );
	endif;
	term := self.getMyTerminal;	
	if term &lt;&gt; null and term.getConfig( EdiNoDefaultComm ).Boolean then  					
		if _commodity = null then
			if cargoTypeObj &lt;&gt; null then
				if cargoTypeObj.isCommodityRequired then
					app.raiseCMException( Commodity_required, app.getString( Commodity ), self );
				endif;
			endif;				
		else			
			if _commodity.isNotAvailableForEntry then
				app.raiseCMException1( Commodity_available_entry, _commodity.code, app.getString( Commodity ), self );
			endif;					
			if cargoTypeObj &lt;&gt; null and not _commodity.allCargoTypes.includes( cargoTypeObj ) then 
				app.raiseCMException2(CargoType_NotValid4_Commodity, self.cargoTypeDescr, _commodity.code, app.getString( Commodity ), self );
			endif;			
		endif;				
	endif;
epilog
end;</source>
        <Parameter name="_commodity" type="CM_Commodity"/>
    </JadeMethod>
    <JadeMethod name="verifyCargoGroup" id="1f1c5988-3c36-49f3-894b-95a2a2705a31">
        <source>verifyCargoGroup();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 Aug 2022	navma1	ChangeRequest 54219: EUP - Cargo Group to be mandatory
19/09/2022  navds20 Bug 54884: Wrong error message
*/

vars

begin
	if not app.isCargoGroupEnabled then
		return;
	endif;
	
	if self.myCargoType = null then
		return;
	endif;
	
	if self.getCargoGroupId &lt;&gt; null then
		return;
	endif;
	
	if self.myCargoType &lt;&gt; null and self.myCargoType.isCargoGroupRequired then
		//app.raiseCMException(Cargo_group_assignm_require,null,self);
		app.raiseCMException(Cargo_group_id_required,null,self);			//21/09/2022 navds20 TFS 54484
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="verifyCountryOfOrigin" id="0d824f7c-eb73-44c4-99d9-285bb885b9a5">
        <source>verifyCountryOfOrigin();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 September 2022	jlier1	Initial creation 54846

*/

vars

begin
	if self.countryOfOriginCode = null then
