    <JadeMethod name="action" id="cb076829-e14e-4ad9-8148-c6f780611aa0">
        <updating/>
        <source>action(): Boolean updating;

// cnwdvb1 22 January 2003 
vars

	errCode	: Integer;
	errTxt	: String;
begin
	
	on Exception do app.alertExceptionHandler(exception, null, self.getErrorDesc(), errCode, errTxt, true, true);
	on LockException do app.alertLockExceptionHandler(exception);
	
	self.setUser();
	self.processEdiRequest();

epilog	
	if errCode &lt;&gt; null then
		app.myTrxUA.trxUpdateBGPRequest(self, true, errCode, errTxt, app.myPassport);
	endif;
	inheritMethod();
	return true;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="checkControllerNode" id="1991b7c1-226a-4b9e-958a-a283f7a46695">
        <source>checkControllerNode() : Boolean protected;

// cnwdvb1 30 January 2003 

vars

begin

	if not self.myProcessingController.myBGPManager.isRunOnServer then
		// Not sure about this serverTask sign on code when running as thin client, started remotely. Something wrong with Jade?
		if self.myProcessingController.myProcess.signOnUserCode = 'ServerTaskUser' or
		   self.myProcessingController.myProcess.isUsingThinClient then
			app.raiseCMException1(BackgroundErrorGeneral, 'The Auto EDI application should not be running as a thin client session', null, null);
		endif;
	endif;
	return true;

end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getDisplay" id="2e4a34ce-8118-4d20-a480-0d59ffaab3c3">
        <source>getDisplay(): String;

// cnwdvb1 17 February 2003 
//
// 24/10/2012	cnwcs5	par 30297 - Remove "Run EDI Root" BGP task type
// 12/11/2015   cnwma1	PAR #36781 1090 Error on BGP Storage Process

vars
	str, detail	: String;
	termCode    : String;
begin
	str 	:= inheritMethod();
	
	if self.myTerminal&lt;&gt; null then
		termCode:= self.myTerminal.code;
	else
		termCode:= null;
	endif;
	//detail 	:= 'Process EDI Terminal ' &amp; self.myTerminal.code;  // -cnwma1 12/11/2015 PAR #36781
   	detail 	:= 'Process EDI Terminal ' &amp; termCode;
	
	return str &amp; Tab &amp; detail;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getErrorDesc" id="4697c8dc-2d6d-4a61-9332-35568cc8fcec">
        <source>getErrorDesc(): String;
//
// 08 Nov 2016	cnwrs1	TFS 2913 Par 38341 EDI files that are open are not being processed
//
vars
	msg : String;
begin
	msg := app.myPassport.getMyBGPAgent.getErrorDesc();
	return msg;
end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getInstances" id="05e74539-d3af-48be-be08-1cf5e47ffd57">
        <source>getInstances(_task : CM_AutoTask): Integer;
//
// par 27178 cmwrs1 16 Mar 2010 only count those created by BGP Timer and count those 
//                              created for the same type of task
// 22/06/2011	cnwcs5	par 27167 - 
// 24/10/2012	cnwcs5	par 30297 - Remove "Run EDI Root" BGP task type
// 21 Sep 2016	cnwrs1	TFS 2705 - ignore isProcessed requests
// 03 Oct 2016	cnwrs1	TFS 2756 PAR38267 allow Cams to run per terminal
vars
	count 	: Integer;
	request : BGP_EdiRequest;
	obj 	: Object;
	invalidObj : Boolean;
	edition : Integer;
	isDeleteOldData : Boolean;
begin

	//on Exception do app.handleDeletedObject( exception, request, invalidObj );	//25 Jul 2014	NDL	Par 34528
	on Exception do app.handleDeletedObject( exception, obj, invalidObj );	//25 Jul 2014	NDL	Par 34528
	
	if _task &lt;&gt; null and _task.isKindOf(CM_AutoTaskEDITerminal) then
		isDeleteOldData:=_task.CM_AutoTaskEDITerminal.deleteOldData;
	endif;
		
	
	foreach obj in self.class.instances do
		//25 Jul 2014	NDL	Par 34528
		invalidObj := false;
		edition := obj.edition;
		//if request = null or invalidObj then
		if invalidObj then
			continue;
		endif;

		request := obj.BGP_EdiRequest;
		if request.isProcessed and
		   self.myProcessingController = null then
			continue;
		endif;
		
		if request.myTerminal &lt;&gt; _task.myTerminal then
			continue;
		endif;
		
		//epr TFS 36431 8/2/18
		if isDeleteOldData and not request.deleteOldData then
			continue;
		endif;
		
		
		if request.specificTrackedItemID = null and
		   not request.trainCustomsRequest and
		   not request.voyageStopRequest and	// par 27167
		   not request.voyageCustomsRequest and
		   not request.voyageOperatorRequest then
		
				count := count + 1;
		
		endif;
	endforeach;
	
	return count;
end;
</source>
        <Parameter name="_task" type="CM_AutoTask"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
