    <JadeMethod name="setCmbYATemplateBehaviour" id="6bb68c74-7ab4-4e91-9195-4009b5a139d6">
        <updating/>
        <source>setCmbYATemplateBehaviour() updating;
// adm 190509 Par 19238
vars

begin
	if self.myYardAllocation = null then
		if self.cmbYATemplate.style &lt;&gt; ComboBox.Style_DropDownComboList then
			self.cmbYATemplate.style	:= ComboBox.Style_DropDownComboList;
		endif;
		if not self.cmbYATemplate.enabled then
			self.cmbYATemplate.enabled		:= true;
			self.btnFindTemplate.enabled	:= true;
		endif;
	else
		if self.cmbYATemplate.style	&lt;&gt; ComboBox.Style_DropDownList then
			self.cmbYATemplate.style	:= ComboBox.Style_DropDownList;
		endif;
		if self.cmbYATemplate.enabled then
			self.cmbYATemplate.enabled		:= false;
			self.btnFindTemplate.enabled	:= false;
		endif;
	endif;
end;
</source>
    </JadeMethod>
    <JadeMethod name="setCriteriaResizeScrollBar" id="31a7e1c8-2c8f-4712-8c39-87c9c8e092c5">
        <updating/>
        <source>setCriteriaResizeScrollBar() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28/11/2023	navkc1 Bug 60782: FR | 54089 EUP -Invoice Contracts - Criteria screen width issues
21 Oct 2024 navlc30 JIRA 12602 STWO - Yard Allocation Maintenance screen does not display fields like before

*/

vars
	max			: Integer;
	numOfCrit	: Integer;
begin

	//numOfCrit := self.getNumCriteriaToDisplay();					//21.10.2024 navlc30 #12602
	numOfCrit := self.allOperationalCriteria.size();				//21.10.2024 navlc30 #12602	
	max := (numOfCrit * (self.frmCriteria.height)).Integer;

	if self.picCriteria.height &lt; max then
		self.picCriteria.scrollBars := Picture.ScrollBar_Vertical;
		self.picCriteria.setScrollRange(ScrollBar_Vertical, 0, max, 20, 100);
	else
		self.picCriteria.scrollBars := 0;
	endif;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setIMEXDefaultColour" id="d839d9d9-5ebe-4308-a8b7-6ce72e394cdc">
        <source>setIMEXDefaultColour();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 January 2009	cnwjk3	SFW1030

*/

vars
	yaIMEXConfig 	: CM_YAIMEXConfig;
	imex 			: CM_IMEXStatus;
	yaConfig		: CM_YAConfig;
begin

	// If a real object exists then use the existing color
	if self.myProxyYA &lt;&gt; null and self.myProxyYA.pxyGetRealObject &lt;&gt; null then
		self.clrYAColour.setColor(self.myProxyYA.color);
	else	
		imex := self.cmbIMEX.listObject.CM_IMEXStatus;    
		yaConfig := self.myTerminal.myYAConfig;
		if yaConfig &lt;&gt; null then
			yaIMEXConfig := yaConfig.allYAIMEXConfigs[imex.code];
			if yaIMEXConfig &lt;&gt; null then 
				self.clrYAColour.setColor(yaIMEXConfig.colour);
			endif;
		endif;
	endif;
end;</source>
    </JadeMethod>
