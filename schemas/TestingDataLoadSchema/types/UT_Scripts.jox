    <JadeMethod name="uDeleteTrackedItemInTerminal" id="6af84954-2193-46c4-af7d-6c8689c83638">
        <source>uDeleteTrackedItemInTerminal();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 August 2014	cnwndl1	Initial creation
// 06 Sep 2016	cnwrs1	TFS 2586 dont always include archived voyages and lookup reveresed even if we found data in non reverese lookup
*/

vars

	terminalName : String;
	terminal : CM_Terminal;
	trackedItemId: String;
	tiSet		: CM_TISet;
	ti : Object;
begin

	terminalName := "Enter Terminal Name";
	read terminalName;
	terminal := app.myRoot.allTerminals[terminalName];
	if terminal &lt;&gt; null then
	
		trackedItemId := "id";
		read trackedItemId;

		create tiSet transient;
		terminal.lookupAllTIsOfIdCargoType(trackedItemId, null, tiSet, false, false, null);
		
		if tiSet.isEmpty and trackedItemId.pos(".",1) &gt; 0 then
			ti := trackedItemId.asOid;
			if ti &lt;&gt; null and CM_TrackedItem.hasInstance(ti) then
				tiSet.add( ti.CM_TrackedItem );
			endif;
		endif;
		
		if not tiSet.isEmpty then
			self.deleteTrackedItem(tiSet.first, false);
		endif;
	
	endif;
	
epilog

	delete tiSet;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="uDeleteTrain" id="137ea279-1d4b-40f3-a8e5-77142e70a32d">
        <source>uDeleteTrain( /*_train : CM_Train*/ );

/*

Purpose:			Deletes Train, wagons, cargo, jobs, audits, non-invoiced transactions

Parameters:			

Return Value:		


Date		Who		Reason
11 May 2011	cnwndl1	Initial creation

*/

vars

	term : CM_Terminal;
	trainId : String;
	allTrains : CM_TrainSet;
	potentialTrain : CM_Train;
	_train : CM_Train;
	iter : Iterator;
	msg : String;

begin

	term := self.getTerminal;
	
	trainId := "&lt;Train Code&gt;";
	read trainId;

	potentialTrain := term.allTrainsOnTerminal.getAtKeyGeq(trainId.toUpper,null);
	
	if potentialTrain = null then
		msg := "Values entered did not resolve to a train called '" &amp; trainId &amp; "' on terminal '" &amp; term.code &amp; "'.";
		self.assertTrueMsg(potentialTrain &lt;&gt; null, msg);
		return;
	else
		create allTrains transient;
		iter := term.allTrainsOnTerminal.createIterator;
		iter.startAtObject( potentialTrain );
		while iter.next( potentialTrain ) do
			if potentialTrain.code.toUpper &lt;&gt; trainId.toUpper then
				break;
			endif;
			allTrains.add(potentialTrain);
		endwhile;
		
		if allTrains.size = 1 then
			_train := allTrains.first;
		else
			delete iter;
			iter := allTrains.createIterator;
			while iter.next( potentialTrain ) do
				msg := allTrains.size.String &amp; " trains have the code '" &amp; potentialTrain.code &amp; "' on terminal '" &amp; term.code &amp; "'.";
				msg := msg &amp; "Do you want to delete the one that arrived at '" &amp; potentialTrain.arrivalDT.String &amp; "'?";
				if app.msgBox(msg,"Delete this Train?",MsgBox_Yes_No) = MsgBox_Return_Yes then
					_train := potentialTrain;
				endif;
			endwhile;
			msg := "No train selected to delete from the  '" &amp; allTrains.size.String &amp; "' offered.";
			self.assertTrueMsg(_train &lt;&gt; null, msg);
			return;
		endif;
	endif;
	
	self.deleteTrainAndAssociatedObjs( _train );
	

epilog

	delete iter;
	delete allTrains;

end;</source>
    </JadeMethod>
    <JadeMethod name="uDeleteTruck" id="d493646c-774a-4178-92c3-da4e49ad32fd">
        <source>uDeleteTruck();
//21 August 2009	cnwdw1	
//
vars
	truck, state: String;
	vehicle: CM_Vehicle;
	termID : String;
begin
	truck := "Enter Truck Name";
	read truck;
	state := "Enter Truck State";
	read state;
	termID := "Enter Terminal Code";
	read termID;
	
	if state = "Enter Truck State" then
		state := null;
	endif;
	
	if termID &lt;&gt; "Enter Terminal Code" and termID.trimBlanks &lt;&gt; null then
		// i.e. "NDL";
		self.opts.addAssoc("Terminal", termID.toUpper);
	endif;
	
	vehicle := self.getTerminal.vehicles[truck.toUpper, state];
	deleteVehicle(vehicle);
end;</source>
    </JadeMethod>
    <JadeMethod name="uDeleteVoyage" id="aa8398f3-11f2-4806-96d5-9c6a8ac1f1ff">
        <source>uDeleteVoyage();
//21 September 2010	cnwdw1	
//
vars
	voyageName: String;
	prefix , mess : String;
	voyage: CM_Voyage;
begin
	voyageName := "Enter Voyage Name (or prefix *)";
	
	
	

	read voyageName;
	
	if voyageName[voyageName.length] = "*" then
		prefix := voyageName[1:voyageName.length-1];
		if voyageName.length = 1 then
			mess := "' ?";
		else
			mess := "' with a prefix of '" &amp; prefix &amp; "' ?";
		endif;
		if app.msgBox("Delete All Voyages for Terminal '" &amp; self.getTerminal().code &amp; mess, "BULK DELETE VOYAGES", MsgBox_Yes_No) = MsgBox_Return_No then
			return;
		endif;
		
		foreach voyage in self.getTerminal.allVoyagesByCode do
			if voyage.isNullVoyage() then
				continue;
			endif;
			
			if voyage.code = "BISH160011" then
				continue;
			endif;
			
			if voyage.code.startsWith(prefix) then
				self.logMessageNow("Delete Voyage: " &amp; voyage.code);
				self.deleteVoyage(voyage.code);
			endif;
		endforeach;
	else		
		self.deleteVoyage(voyageName);
	endif;
	self.logMessageNow("FINISHED");
end;</source>
    </JadeMethod>
    <JadeMethod name="uDeleteVoyageCargo" id="55be52dd-dbe3-46a0-b89b-21988ea6c0ce">
