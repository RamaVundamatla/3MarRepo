    <JadeMethod name="addToolbarControls" id="c8057cae-34d6-4713-b9f0-459dd2932235">
        <updating/>
        <source>addToolbarControls() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 Sep 2022 navma1	ChangeRequest 53900: EUP - VBS MTN - [4] - Search Screen
11 Oct 2022	navak20 ChangeRequest 54046: EUP - VBS MTN - [7] - Email configuration and notifications
13 Dec 2022 navhl20	CR 53900: Task 55833: EUP - VBS MTN - [4] - Search Screen - Add Text Filtering
19 Jul 2023 navhl20 Bug 59181: EUP | VBS changes MTN - VBS Enquiry refresh issue
*/

vars
	toolbar		    : CMUI_Toolbar;
	showCaptions	: Boolean;
	leftAlignment	: Integer;
begin
	
	inheritMethod;
	
	toolbar		  := self.frmToolbar;
	showCaptions  := toolbar.showCaptions;
	leftAlignment :=  CMUI_Toolbar.Control_Alignment_Left;
	
	toolbar.addButton(self.btnPrint, leftAlignment);	
	toolbar.addButton(self.btnExportCSVQE, leftAlignment);	

	toolbar.addSeperator(leftAlignment);

	toolbar.addButton(self.btnNew, leftAlignment);
	toolbar.addButton(self.btnShowSearcher, leftAlignment);
	toolbar.addButton(self.btnEditItem, leftAlignment);	
	toolbar.addButton(self.btnDelete, leftAlignment);	
	toolbar.addButton(self.btnEmailLayout, leftAlignment);			// 11.10.2022 navak20 TFS 54046
	toolbar.addButton(self.btnRefresh, leftAlignment);				//19.7.2023 navhl20 #59181

/*	//05/06/2024	navkc1 CR 63736 Task 63770 - Replaced with new control
	//Start 13.12.2022 navhl20 TFS 55833
	toolbar.addSeperator(leftAlignment);
	self.frmFilterBox.visible := true;
	toolbar.addFrame(self.frmFilterBox, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnClearFilter, leftAlignment); 
	//End 13.12.2022 navhl20 TFS 55833
*/	
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);					//05/06/2024	navkc1 CR 63736 Task 63770
	toolbar.addFrame(self.frmTblFilter, CMUI_Toolbar.Control_Alignment_Left); 	//05/06/2024	navkc1 CR 63736 Task 63770
	self.frmTblFilter.visible := true;										//05/06/2024	navkc1 CR 63736 Task 63770
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="addToolbarControlsQuery" id="8ff4396d-e221-488a-9052-f675fb62bf90">
        <source>addToolbarControlsQuery() protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 Sep 2022 navma1	ChangeRequest 53900: EUP - VBS MTN - [4] - Search Screen

*/

vars
	queryToolbar			: CMUI_Toolbar;
begin
	
	queryToolbar := self.frmQueryToolbar;

	queryToolbar.addButton(self.btnQuery, CMUI_Toolbar.Control_Alignment_Left);
	queryToolbar.addButton(self.btnResetSearch, CMUI_Toolbar.Control_Alignment_Left);
	queryToolbar.addButton(self.btnHideSearcher, CMUI_Toolbar.Control_Alignment_Left);

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="btnEmailLayout_click" id="cea1e8c2-3da4-47ca-922d-7b7b498ac1d9">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnEmailLayout_click(btn: Button input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 Oct 2022	navak20 ChangeRequest 54046: EUP - VBS MTN - [7] - Email configuration and notifications

*/

vars
	form : CMUI_VBSEmailConfigure;
begin
	if form = null then
		form := app.loadForm (CMUI_VBSEmailConfigure, CMUI_Assistant, false, false, true , self.myTerminal, null).CMUI_VBSEmailConfigure; 
	endif;
	if form = null then
		return;
	endif;
	form.myParentForm := self;
	form.showModal();
epilog

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnNew_click" id="6096e389-f85f-4731-94bd-f924d4f22c72">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnNew_click(btn: Button input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 Sep 2022 navma1	ChangeRequest 53900: EUP - VBS MTN - [4] - Search Screen

*/
vars
	slotMaintForm : CMUI_VehicleBookingAdvMaint;
begin

	slotMaintForm := app.loadForm(CMUI_VehicleBookingAdvMaint, CMUI_Assistant, false, false, false, self.myTerminal, null).CMUI_VehicleBookingAdvMaint;
	if slotMaintForm &lt;&gt; null then
		slotMaintForm.show;
	endif;
epilog

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnRefresh_click" id="e5cbf1a6-3426-40b0-93b3-d8fc9a927044">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnRefresh_click(btn: Button input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 July 2023	navhl20	Bug 59181: EUP | VBS changes MTN - VBS Enquiry refresh issue

*/

vars
	vbTerminal : CM_VehicleBookingTerminal;
begin
	self.tblData.clearAllData();
	vbTerminal := self.myTerminal.myVehicleBookingTerminal;
	self.populateVbsSlots(vbTerminal.allVBTimeslotsById , false);
epilog

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
