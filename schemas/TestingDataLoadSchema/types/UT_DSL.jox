    <JadeMethod name="addBerth" id="6ea3ca2b-3c0f-4e1f-9f48-31822dff6a99">
        <source>addBerth(_berthId, _berthDesc : String; _harbour : HMS_Harbour; _startPosition, _length : Integer; _minDepth : Decimal; _noMarineServices : Boolean; _wharf : HMS_Wharf) : HMS_Berth;

/*

Purpose:		Add Berth	

Date			Who		Reason
20/12/2011		cnwmh5	Initial creation

*/

vars

	pxyBerth			: HMS_Berth;
	berth				: HMS_Berth;

begin

	self.deleteBerth(_berthId, _harbour);
	
	create pxyBerth transient;
	pxyBerth.setProxy(_harbour,						// Harbour
					  0);							// Default cargo operation
					  
					  
	pxyBerth.setPropertyValue("code", _berthId);
	pxyBerth.setPropertyValue("description", _berthDesc);
	pxyBerth.setStartPositionLength(_startPosition, _length);
	pxyBerth.setPropertyValue("minimumDepth", _minDepth);
	pxyBerth.setPropertyValue("noMarineServices", _noMarineServices);
	pxyBerth.setPropertyValue("myWharf", _wharf);
	if self.opts.includesKey("DefaultCargoOperation") then
		pxyBerth.setPropertyValue("defaultCargoOperation", self.opts.int("DefaultCargoOperation"));
	endif;
	

	app.myTrxCA.trxCreateBerth(pxyBerth, berth, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	if self.opts.includesKey("HarbourRegion") then
		beginTransaction;
		berth.setPropertyValue("myHarbourRegion", app.myRoot.allHMSHarbourRegions[self.opts.str("HarbourRegion")]);
		commitTransaction;
	endif;
	
	return berth;
	
epilog
	
	delete pxyBerth;

end;</source>
        <Parameter name="_berthId" type="String"/>
        <Parameter name="_berthDesc" type="String"/>
        <Parameter name="_harbour" type="HMS_Harbour"/>
        <Parameter name="_startPosition" type="Integer"/>
        <Parameter name="_length" type="Integer"/>
        <Parameter name="_minDepth" type="Decimal"/>
        <Parameter name="_noMarineServices" type="Boolean"/>
        <Parameter name="_wharf" type="HMS_Wharf"/>
        <ReturnType type="HMS_Berth"/>
    </JadeMethod>
    <JadeMethod name="addBlockStack" id="48a6d609-90d3-4dbb-ab07-9b6899c87c2b">
        <source>addBlockStack(_name: String; _max: Integer; _icArea :Any): CM_BlockStack;
//01 September 2008	cnwdw1	 
//
vars
	
	pxyBlockStack	: CM_BlockStack;
	realTA 			: CM_TerminalAreaMaster;
	pDO				: CM_YADeckingOptionsTA;
	icArray 		: CM_InterchangeAreaArray;
	rows			: Integer;
	cols			: Integer;
	comment			: String;
	max				: Integer;
	defaultInterchangeArea	: CM_InterchangeArea;
begin
	self.deleteTerminalArea(_name);
	if _icArea &lt;&gt; null  then
		create icArray transient;
		if _icArea.isKindOf (CM_InterchangeArea) then
			icArray.add(_icArea.CM_InterchangeArea);
		elseif _icArea.isKindOf (ObjectArray) then
			_icArea.ObjectArray.copy (icArray);
		endif;
	endif;
	
	rows := self.opts.int("rows");
	if rows = 0 then
		rows := 5;
	endif;
	cols := self.opts.int("cols");
	if cols = 0 then
		cols := 5;
	endif;
	comment := self.opts.str("comment");
	max := _max;
	if max = 0 then
		max := 999;
	endif;
	defaultInterchangeArea := self.opts.obj("DefaultYIC").CM_InterchangeArea;
	
	create pxyBlockStack transient;
	pxyBlockStack.setProxy(_name, 
					comment,
					TA_TYPE_BLOCK_STACK, 
					max,
					rows,
					cols,
					false,
					"", 
					max,
					true, 
					null,
					self.getTerminal,
					false,
					false,
					false,
					false,
					false,
					icArray,
					defaultInterchangeArea, //null,
					false
					);
	create pDO transient;
	pDO.setProxy(false, true, pxyBlockStack);
	pDO.setProxyRules(DeckingRule_Default, DeckingRule_Default);

	if self.opts.includesKey("ActAsReleasePoint") then
		pxyBlockStack.setPropertyValue(CM_BlockStack::actAsReleasePoint.name, self.opts.int("ActAsReleasePoint"));
	endif;
	
	if self.opts.includesKey("StockControlled") then
		pxyBlockStack.setPropertyValue(CM_BlockStack::isStockControlled.name, self.opts.bool("StockControlled"));
	endif;
	
	//if self.opts.includesKey("Comment") then
	//	pxyBlockStack.setPropertyValue(CM_BlockStack::comment.name, self.opts.str("Comment"));
	//endif;
	
	//if self.opts.includesKey("DefaultYIC") then
	//	pxyBlockStack.setPropertyValue(CM_BlockStack::myDefaultInterchangeArea.name, self.opts.obj("DefaultYIC").CM_YardInterchangeArea);
	//endif;
	
	app.myTrxCA.trxCreateTerminalArea(pxyBlockStack, realTA, app.myPassport);
	if not self.opts.includesKey("ExpectErrors") then
		self.assertNoTrxErrorsOrWarnings();
	endif;

	if realTA = null then
		return null;
	else
		return realTA.CM_BlockStack;
	endif;
epilog
	delete pxyBlockStack;		//+cnwml2 MSL CCMS 1012  pDo gets deleted when deleting pxyBlockStack
	//delete pDO;
	delete icArray;
end;</source>
        <Parameter name="_name" type="String"/>
        <Parameter name="_max" type="Integer"/>
        <Parameter name="_icArea" type="Any"/>
        <ReturnType type="CM_BlockStack"/>
    </JadeMethod>
    <JadeMethod name="addBookingForContainer" id="f87204dd-0c92-402d-9cf1-6092a630db08">
        <updating/>
        <source>addBookingForContainer(_bookingRef: String;
						_operator: CM_Operator;
						_voyage: CM_Voyage;
						_dischargePort: String;
						_isoType: String;
						_commodity: String): CM_BookingRef updating;
/* Changes
Date		Name	TFS#			Description
============================================================================
06/07/2009	cnwdw1					Create a booking for a container with a mt release
23/04/2012	cnwcs5	CCMS POL 2172 
					/ par 29480 	coparn release updates
27/05/2013	cnwdap1	PAR #31596 		added freight forwarder parameter
28/02/2014	cnwma1					add special lift
09 Sep 2014	cnwrs1	CCMS 2351 		att Sequence to Release request 
05 Jun 2018	jlgrs1	TFS 39018 		SNO Cargo Operator in COPRAR
25/01/2019	jlgka1	41708			As a result of the changes in the CM_BulkRelease.setProxy
									we also need to add myBOLIn here.
02 Oct 2020 cnwma1					ChangeRequest 50112: ASPA - GCI Stevedores
//19/07/2022	navtnr20	ChangeRequest 53974: EUP - OUT - Additional Fields on Release Line Level
28 June 2023 navmv20 CR 58410 Task 58411: UI - Cargo Review - Release Request	
6/12/2023	navcs2	ChangeRequest 57537: EUP | Release Request By Type - with Weight																
============================================================================*/
vars
	pxyBooking, 
	booking				: CM_BookingRef;
	pxyBookingItem		: CM_BRefItemContainer;
	release				: CM_BulkRelease;
	packAsInteger		: Integer;			// cnwrl1 20/04/2010 PAR 23624
	dischargePorts		: StringArray;
	hazards				: ObjectArray;
	pxyBulkRelease		: CM_BulkRelease;
	pxyReserveSelection	: CM_ReserveSelection;
	number 				: Integer;
	releaseTis 			: Any;
	stock 				: Boolean;
	isoGroup 			: String;
	temperature 		: Real;
	specialLift			: ObjectArray;
	spLift 				: CM_SpecialLiftByCodeDict;
	specialStow 		: CM_SpecialStow;
	shippingRef  		: String;
	
	humidity : Decimal[6,2];
	carbonDioxide : Decimal[6,2];
	oxygen : Decimal[6,2];
	
begin
	create dischargePorts transient;
	create hazards transient;
	
	create pxyBooking transient;
	if self.opts.includesKey("Stock") then
		stock := self.opts.bool("Stock");
	else
		stock := false;
	endif;

	//+cnwml2 MSL CCMS 1012
	if self.opts.includesKey("number") then
		number := self.opts.int("number");
	else
		number := 1;
	endif;

	// PAR #28803
	if self.opts.includesKey("ISO Group") then
		isoGroup := self.opts.str("ISO Group");
	else
		isoGroup := null;
	endif;
	
	if self.opts.includesKey("Temp") then
		temperature := self.opts.real("Temp");
	else
		temperature := NULL_TEMPERATURE;
	endif;

	// cnwrl1 20/04/2010 PAR 23624 - start of coding
	packAsInteger	:= app.bookingPackAsStringToEnumb(self.opts.str(ETRow_PackAs));
	if packAsInteger &lt; 0 then
		packAsInteger	:= 0;
	endif;
	// cnwrl1 20/04/2010 PAR 23624 - end of coding
	
	// cnwma1 28/02/2014 add SpecialLift
	create spLift transient;
	if self.opts.includesKey("SpecialLift") then
		specialLift := self.opts.obj("SpecialLift").ObjectArray;
		self.opts.obj("SpecialLift").ObjectArray.copy(spLift);
	endif;
	
	if self.opts.includesKey("SpecialStow") then
		specialStow := self.opts.obj("SpecialStow").CM_SpecialStow;
	endif;
	
	if self.opts.includesKey("ShippingRef") then					// 02/02/2016 cnmwh5
		shippingRef := self.opts.str("ShippingRef");
	endif;

	pxyBooking.setProxy(_bookingRef, 0, false, null,null, null,	null, _dischargePort,null, dischargePorts, // adm 160310 Par 22937 remove bolType
						hazards, NULL_HUMIDITY, false, "", null, null, _operator, _voyage, number, null,
						null, NULL_TEMPERATURE, NULL_VENTILATION, 0,0,0,null,null,null, null, 0, 0, 0, 0, 0, 
						self.getTerminal, null, true, stock, null, null, shippingRef,null, null, null, null, null,
						false, false, false, false, null, false,
						self.opts.bool( ETRow_OverDimension ),			// cnwrl1 20/04/2010 PAR 23624
						false, false, BOOKING_REF_ACTIVE,
						null, 
						specialLift,            //cnwma1 28/02/2014 Special Lift
						null, false, null,
						packAsInteger,							// cnwrl1 20/04/2010 PAR 23624
						null,		// customsAgent	// cnwrl1 18/02/2010 PAR 22393
						null, 		// edivoyageCode
						null,		// ediVesselName //cnwrs1 CCMS 1882 03 June 2010
						self.opts.bool("DD"),	// direct delivery
						null,					// freight forwarder
						null, 	//carrier
						null    //stevedore //02.10.2020 cnwma1 TFS #50112
						);
						
	//09 Apr 2020	NDL	TFS 47958
	if self.opts.includesKey("Humidity") then	
		humidity := self.opts.dec("Humidity");
	else
		humidity := NULL_HUMIDITY;
	endif;
	if self.opts.includesKey("CarbonDioxide") then	
		carbonDioxide := self.opts.dec("CarbonDioxide");
	else
		carbonDioxide := NULL_CARBON_DIOXIDE;
	endif;
	if self.opts.includesKey("Oxygen") then
		oxygen := self.opts.dec("Oxygen");
	else
		oxygen := NULL_OXYGEN;
	endif;
	
	
	create pxyBookingItem transient;	
	pxyBookingItem.setProxy(TI_CargoType_Container, 
							_commodity, 
							null,
							null, 
							null, 
							_isoType,
							number,
							2000, 
							0, 
							0, 
							humidity, 
							temperature, 
							NULL_VENTILATION, 
							0,
							carbonDioxide, 
							oxygen, 
							false, 
							false, 
							false, 
							specialStow, 
							isoGroup, 
							false, 
							spLift,
							null,
							null, // cnwma1 28/02/2014 Add SpecialLift
							CM_BookingRefItem.BASIC_MATCH);		//navra1 - CR 63764/Task 64227 - 23rd May 2024
	//+cnwml2 MSL CCMS 1012
	if opts.includesKey("releaseTIs") then
		releaseTis := opts.obj("releaseTIs");
	else
		releaseTis := null;
	endif;
	
	if releaseTis &lt;&gt; null then
		create pxyBulkRelease transient;
		pxyBulkRelease.setProxy(pxyBooking.bookingReference, //code same as this booking reference number
								BR_TYPE_ROAD, //always road from this form
								true,  //release by type - not chkIsReservedOnly
								BR_ACTIVE,
								null, ///availability grades null set on reserve selections
								null,//booking confirmation 
								self.getProfileSetting(UT_Profile.P_CARRIER).asString, //carrier
								null, //cargo remarks
								null,//consignee code 
								null, //_pxyBookingRef.consigneeDesc, //consigneeDesc				//-cnwml2 PAR19845 CCMS SFW 1079
								null,//consignor code
								null, //_pxyBookingRef.consignorDesc,//consignor desc				//-cnwml2 PAR19845 CCMS SFW 1079
								null,//_consignorVoyageCode 
								null, //date requested
								null,//_dateEstimatedRequired
								null,//_deliveryReasonCode
								null,//_deliveryReasonDescr
								null,//_deliveryReleaseNumber
								null,//_doorsDirection
								null,//_freightPayerCode
								pxyBooking,//CM_BookingRef
								null,//_loadPort
								null,//_destinationPort
								getRoot.allPorts[_dischargePort],//_dischargePort
								null,//_freightForwarder
								null,//_transferToTerminal
								pxyBooking.myTerminal,
								pxyBooking.myOperator,//_operator
								null,//_operatorGroup
								pxyBooking.myVoyage,//_voyage
								null,		//_businessUnit	
// TFS 2686								null,		//_removeStops,
								null,		//_fullRelease	
								null,
								null,
								null,
// cnwdad1 27/01/2010 - PAR #22205.
//								self.getTerminal.getConfig(MySubTerminalForSourceBulkRoad).CM_SubTerminal,
								self.getTerminal.getDefaultSubTerminalForRel(BR_TYPE_ROAD),
								null, // subterm target//cnwrd1 par 23219 17.3.2010
								null,	//_assignedTrain : CM_Train
								false,				//_allPackLocations	
								null,				// cnwrl1 19/02/2010 PAR 22393
								false,				// cnwrl1 19/02/2010 PAR 22393
								false, false,				// May 2011 cnwjre1 27097 POL CCMS 2043
								false, 	// par 29480 April 2012
								null,	// CCMS POL 2122 / PAR 28696 cnwrs1
								null,
								null,	// jlgka1 TFS 41708
								null	// ### TFS 53953 27June2022 NAVPW1
								);
		create pxyReserveSelection transient;
		pxyReserveSelection.setMyHeader(pxyBulkRelease);
		pxyReserveSelection.setProxy(CM_ReserveSelection.PackType_Parent, 
									getRoot.allCargoTypesById[TI_CargoType_Container],
									pxyBookingItem,
									getRoot.allISOTypes[_isoType],
									null,  //cnwrd1 par 20810 9/10/9
									null,
									null,
									null,
									1,
									null, //avail grades
									null,//clean
									null, //iso check
									false, //heavy rated
									null, //mask ids
									1,
									null,
									null,
									null,
									null,
									null,
									null,
									null,
									null,
									null,
									null,
									null,
									null,
									null,
									null,
									null,
									false,
									null,
									null,null,null,null,null,false,false,null,null,null,null,null,null,null,null,
									null,	// ### TFS 53953 11July2022 NAVPW1
									null,null,  //12-07-2022 navtnr20 53974
									null, //28/06/2023 navmv20 CR 58410 Task 58411
									false,	// 6/12/2023 navcs2 ChangeRequest 57537
									false, //19/02/2023	navkc1 CR 60078 Task 62450
									null,	//24/04/2025	navrv30	MTN 34319
									null);
		pxyBulkRelease.createRequests;
		
		if releaseTis.isKindOf(CM_TISet) then
			releaseTis.CM_TISet.copy(pxyReserveSelection.allTrackedItems);
		else
			pxyReserveSelection.allTrackedItems.add(releaseTis.CM_TrackedItem);
		endif;
	endif;		

	pxyBooking.allBookingRefItems.add(pxyBookingItem);
	
	app.myTrxCA.trxCreateBookingBulkRel(pxyBooking, booking, release, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();

	return booking;
epilog
	/*if pxyBooking &lt;&gt; null then
		if pxyBooking.allSpecialLifts.isTransient then
			pxyBooking.allSpecialLifts.purge();
		endif;
	endif;*/
	delete pxyBooking;
	delete dischargePorts;
	delete hazards;
	delete spLift;
//	delete specialLift;
	
end;</source>
        <Parameter name="_bookingRef" type="String"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_dischargePort" type="String"/>
        <Parameter name="_isoType" type="String"/>
        <Parameter name="_commodity" type="String"/>
        <ReturnType type="CM_BookingRef"/>
    </JadeMethod>
    <JadeMethod name="addBookingForGeneralCargo" id="40e5341e-3ca7-4560-abc6-32e4a3038420">
        <source>addBookingForGeneralCargo(_bookingRef: String; _operator: CM_Operator; _voyage: CM_Voyage; _dischargePort: String; _cargoType: Integer; _number: Integer): CM_BookingRef;
//06 July 2009	cnwdw1	
//
// 29/07/2011	cnwmh5	Remove passing of opts from signature
// 27/05/2013	cnwdap1	PAR #31596 Added freight forwarder parameter
// 05 Jun 2018	jlgrs1	TFS 39018 SNO Cargo Operator in COPRAR
// 02 Oct 2020  cnwma1  ChangeRequest 50112: ASPA - GCI Stevedores
vars
	pxyBooking, booking: CM_BookingRef;
	pxyBookingItem: CM_BRefItemContainer;
	release: CM_BulkRelease;
	dischargePorts: StringArray;
	hazards: ObjectArray;
	destPort	:String;
begin
	destPort := self.opts.str ("DestinationPort");	// cnwcs5 June 2012
	
	create dischargePorts transient;
	create hazards transient;

	create pxyBooking transient;
	pxyBooking.setProxy(_bookingRef, 0, false, null,null, null,	destPort, _dischargePort,null, dischargePorts,	// adm 160310 Par 22937 remove bolType
						hazards, NULL_HUMIDITY, false, "", null, null, _operator, _voyage, 0, null,
						null, NULL_TEMPERATURE, NULL_VENTILATION, 0,0,0,null,null,null, null, 0, 0, 0, 0, 0, 
						self.getTerminal, null, true, false, null, null, null, null, null, null, null, null,
						false, false, false, false, null, false, false, false, false, BOOKING_REF_ACTIVE,
						null, null, null, false, null, null,
						null, 		// customsAgent	// cnwrl1 18/02/2010 PAR 22393
						null, 		// edivoyageCode
						null,		// ediVesselName //cnwrs1 CCMS 1882 03 June 2010
						null,	//direct delivery
						null,	// freight forwarder
						null, 	//carrier
						null    //04.11.2020 cnwma1 TFS #50112
						);
	create pxyBookingItem transient;		
	pxyBookingItem.setProxy(_cargoType, null, null, null, null, null, _number, 2000, 0, 0, NULL_INTEGER, NULL_TEMPERATURE, NULL_VENTILATION, 0
							, NULL_INTEGER, NULL_INTEGER, false, false, false, null, null, false, null, null, null, CM_BookingRefItem.BASIC_MATCH);		//navra1 - CR 63764/Task 64227 - 23rd May 2024

	pxyBooking.allBookingRefItems.add(pxyBookingItem);
	
	app.myTrxCA.trxCreateBookingBulkRel(pxyBooking, booking, release, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();

	return booking;
epilog
	delete pxyBooking;
	delete dischargePorts;
	delete hazards;
end;
</source>
        <Parameter name="_bookingRef" type="String"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_dischargePort" type="String"/>
        <Parameter name="_cargoType" type="Integer"/>
        <Parameter name="_number" type="Integer"/>
        <ReturnType type="CM_BookingRef"/>
    </JadeMethod>
    <JadeMethod name="addBookingForProduct" id="a8fcf4e5-8726-41c2-8300-34dc68701a5f">
        <source>addBookingForProduct(_code: String; _operator: CM_Operator;_product: CM_Product; _quantity: Integer; _voyage: CM_Voyage): CM_BookingRef;
//26 January 2009	cnwdw1	
//
vars
	pxyBooking, booking: CM_BookingRef;
	cmifBooking: CMIF_BookingRef;
	cmifBookingItem: CMIF_BookingRefItem;
	dischargePorts: StringArray;
	hazards: ObjectArray;
begin

	create pxyBooking transient;
	create cmifBooking transient;
	create cmifBookingItem transient;
	create dischargePorts transient;
	create hazards transient;
	
	cmifBooking.setMyProxyBookingRef(pxyBooking); // adm 160310 Par 22937 remove bolType
	cmifBooking.setProxy(_code, BOOKING_REF_ACTIVE, 0, false, "", "", "", "", "",null, dischargePorts, hazards, 0, false, "", null, null, _operator, _voyage, 0, 
		"", "",NULL_TEMPERATURE, 0, 0, 0, 0,"", "", "", "", 0, 0, 0, 0, 0, self.getTerminal, null, true, true, null, "", "", null,false);
	
	cmifBookingItem := cmifBooking.createInterfaceItem(null, null);
	cmifBookingItem.set(_product.cargoType, false, "", "", hazards, 0, false, "", _quantity, "", NULL_TEMPERATURE, 0, // adm 160310 Par 22937 remove bolType
		NULL_INTEGER, NULL_INTEGER, false, 0, 0, 0, "", "", "", "", "", 0, 0, 0, 0, 0, _product, false, null, "", null); //cnwrd1 23.2.09 #18220 
		
	app.myTrxCA.trxCreateBookingRefMulti(cmifBooking, app.myPassport, null, booking);
	self.assertNoTrxErrorsOrWarnings();
	
	return booking;

epilog
	delete pxyBooking;
	delete cmifBooking;
	//delete cmifBookingItem;
	delete dischargePorts;
	delete hazards;
end;</source>
        <Parameter name="_code" type="String"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_product" type="CM_Product"/>
        <Parameter name="_quantity" type="Integer"/>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <ReturnType type="CM_BookingRef"/>
    </JadeMethod>
