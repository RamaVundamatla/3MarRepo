    <JadeMethod name="btnReserve_click" id="fe5d64a3-226d-43e0-a2b0-9c0fca0c07e5">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnReserve_click(btn: Button input) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 Sep 2008	cnwer1	Initial creation
13 Mar 2023 navma1 ChangeRequest 56457:[56458] EUP - [Refactor] - Allowing different sets of cargo items per work order task;
17 Apr 2023 navhl20 ChangeRequest 55443:[54991] EUP - Receive Cargo Work Order - Enhancements
23/06/2023	navkc1	CR 58406 Task 58408: Jade - Release Request All Tracked Items
*/

vars
	tiArray: CM_TIArray;
begin
	if self.tblBookingItems.allSelectedObjects.isNotEmpty then			//06.03.2023 navma1 #56457:[56458]
		create tiArray transient;
		self.getAllReservedTIs(tiArray);
		self.myAssistant.showCargoSearchForm(self, 
											self.chkNoEmptiesOut.value,
											tiArray, 
											self.tblBookingItems.allSelectedObjects.first.CM_BookingRefItem, 
											null,  																			//cnwrd1 par 21162 added null for reserveDetail
											self.tblBookingItems.allSelectedObjects.first.CM_BookingRefItem.myCargoType,	//13.03.2023 navma1 #56457:[56458]
											null,null,																		//17.4.2023 navhl20 #55443[54991]
											null); 
	endif;
epilog
	delete tiArray;
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
