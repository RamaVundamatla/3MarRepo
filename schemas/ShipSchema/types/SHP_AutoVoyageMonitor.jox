    <JadeMethod name="doQuery" id="e643dde7-5007-4c3e-8423-44242a8df095">
        <source>doQuery();
/*
Purpose:	

Date		Who		Reason
10 July 2024	navab1	CR 64617 TASK 64638
*/

vars
	stage : CM_VoyageStage;
	progress : CM_VoyageProgress;
	
	startTS, endTS : TimeStamp;
begin
	startTS.setDate(self.mskStart.getDate()); 
	endTS.setDate(self.mskEnd.getDate()); 
	startTS.setTime(self.mskStartTime.getTime()); 
	endTS.setTime(self.mskEndTime.getTime()); 
	
	self.tblData.rows := self.tblData.fixedRows;
	self.allNotableObjects.clear();

	
	if endTS.isValid and endTS &lt; startTS then
		app.msgBox(app.getErrorString2(ERR_DateRangeInvalid, "Start", "End"), app.getErrorString(Problem), MsgBox_OK_Only);
		return;
	endif;

	progress := self.myCurrentVoyage.myVoyageProgress;
	
	if progress = null then
		return;
	endif;
	
	foreach stage in progress.allStages discreteLock do
		if not self.doIncludeObject(stage) then
			continue;
		endif;
	
		self.addRowToTable(stage);
	endforeach;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doTblDataContMenu" id="a141264e-66c1-4983-8f84-634f6785a26b">
        <updating/>
        <source>doTblDataContMenu(cntrl: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating, protected;
/*
Purpose - 	
Who - NAVAB1
Date - 18JUL2024
ADO - CR 64612 TASK 64659
*/

vars
	canEdit		: Boolean;
	x1,
	y1			: Real;
	voyStage : CM_VoyageStage;
begin
	x1 := x;
	y1 := y;
	if (not mouse) then
	    x1 := 1;
	    y1 := 1;
	endif;
	conwin.windowToScreen(x1, y1);
	self.screenToWindow(x1, y1);
	
	//navra1 - MTN-33017 - 11th Oct 2024 - start
	if tblData &lt;&gt; null and tblData.accessRow(tblData.row) &lt;&gt; null and tblData.accessRow(tblData.row).itemObject &lt;&gt; null and tblData.row &lt;&gt; 1 then		//navra1 - MTN-34348 - 13th March 2025
		voyStage := tblData.accessRow(tblData.row).itemObject.CM_VoyageStage;
		if voyStage &lt;&gt; null then
			if voyStage.stage = CM_VoyageStage.VoyStage_DischCompLoad or 
				voyStage.stage = CM_VoyageStage.VoyStage_LoadCompLoad then				
				self.mnuCompareErrors.visible := true;
				self.mnuCargoComparison.visible := true;						//navra1 - MTN-34348 - 13th March 2025
				self.mnuCargoComparison.enabled := true;						//navra1 - MTN-34348 - 13th March 2025
				if voyStage.description &lt;&gt; null then
					self.mnuCompareErrors.enabled := true;					
				else
					self.mnuCompareErrors.enabled := false;					
				endif;
			else				
				self.mnuCompareErrors.visible := false;
				self.mnuCargoComparison.visible := false;						//navra1 - MTN-34348 - 13th March 2025
				self.mnuCargoComparison.enabled := false;						//navra1 - MTN-34348 - 13th March 2025
			endif;
		endif;
	endif;
	//navra1 - MTN-33017 - 11th Oct 2024 - end
	
	self.mnuColumnOrganiser.visible := true;
	self.mnuColumnOrganiser.userObject := self.tblData;
	self.mnuInspectObject.visible := app.isAllowedToInspect(); 
	self.popupMenu(self.mnuContext, x1.Integer, y1.Integer);
	return false;

end;</source>
        <access>protected</access>
        <Parameter name="cntrl" type="Table" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getColourForStatus" id="38347c48-e321-4cf7-84d2-3ed84f721b79">
        <source>getColourForStatus(_status : Integer) : Integer;
/*
Purpose:	

Date		Who		Reason
19 July 2024	navab1	CR 64612 TASK 64659
*/

vars

begin
	if _status = CM_VoyageStage.STATUS_FAILED then
		return LightRed;
	elseif _status = CM_VoyageStage.STATUS_SUCCESS then
		return PaleGreen;
	elseif _status = CM_VoyageStage.STATUS_WAITING then
		return LightOrange;
	elseif _status = CM_VoyageStage.STATUS_UNKNOWN then
		return Red;
	endif;
epilog

end;</source>
        <Parameter name="_status" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getXMLSettingsForSave" id="7aa11f9f-c3e5-40f7-ab1a-18d5d980f018">
        <updating/>
        <source>getXMLSettingsForSave(): String updating;
/*
Purpose - 	
Who - NAVAB1
Date - 18JUL2024
ADO - CR 64612 TASK 64659
*/

vars
	theXML : String;
begin
	theXML := inheritMethod();
	theXML := theXML &amp; self.tblData.getXmlStrForColumns(false);
	theXML := theXML &amp; global.formatAsXML("SHOWCOLOURS", self.chkShowColours.value.String);
	return theXML;

epilog

end;</source>
