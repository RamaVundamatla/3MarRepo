    <JadeMethod name="mnuMacro_click" id="fa3b9942-2f28-4088-9ed6-3b250b465ee7">
        <controlMethod name="MenuItem::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mnuMacro_click(menuItem: MenuItem input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 August 2009	cnwml2	Initial creation

*/

vars

begin
	if self.tblExtraInfo.visible then
		self.tblExtraInfo.visible := false;
		self.intTblHeight := self.tblExtraInfo.height;
		self.height := self.height - self.intTblHeight;

	else
		self.tblExtraInfo.visible := true;
		self.height := self.height + self.intTblHeight;
	endif;
	
epilog

end;</source>
