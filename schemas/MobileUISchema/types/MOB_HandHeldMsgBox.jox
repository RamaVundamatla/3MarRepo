    <JadeMethod name="logFormDiagnostics" id="0eca5b00-c982-4e56-bb67-bed2fa0ca7fc">
        <source>logFormDiagnostics(_logInvisibleItems : Boolean) protected;
/*

Purpose:			Dump out diagnostic control positional information for all the controls on the
					form

Parameters:			None

Return Value:		None

Date		Who		Reason
13 Dec 2013	cnwkpd1	PAR #33170 - Problem with positioning of buttons and text on some devices


*/

vars
	control			: Control;
	count			: Integer;
	features		: StringArray;
	msg,
	feature			: String;
	
begin
	create features transient;
	features.add(Window::name.name);
	features.add(Window::left.name);
	features.add(Window::top.name);
	features.add(Window::width.name);
	features.add(Window::height.name);
	features.add(Window::visible.name);
	
	msg := self.String;
		
	foreach feature in features do
		msg := msg &amp; ', ' &amp; feature &amp; '=' &amp; self.getPropertyValue(feature).String;
	endforeach;
	
	app.writeLog(msg, LogDEBUG);	//25 Nov 2019	NDL	TFS 47053

	features.add(Control::parent.name);

	foreach count in 1 to self.controlCount() do
		control := self.controls(count);
		
		if _logInvisibleItems or control.visible then
			msg := self.String &amp; ', ' &amp; control.String;
			
			foreach feature in features do
				msg := msg &amp; ', ' &amp; feature &amp; '=' &amp; control.getPropertyValue(feature).String;
			endforeach;
			
			app.writeLog(msg, LogDEBUG);	//25 Nov 2019	NDL	TFS 47053
		endif;
	endforeach;
	
	
epilog
	delete features;
	
end;</source>
        <access>protected</access>
        <Parameter name="_logInvisibleItems" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="repositionControls" id="843d2404-bc09-468e-b8d9-604dc873721f">
        <source>repositionControls() protected;
// --------------------------------------------------------------------------------
// Created:		15 February 2006 by cnwdad1
//
// Purpose:		Horizontally centers the remaining visible buttons at the bottom of
//				the form, and vertically centers the visible icon picture.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	button1Obj		: Button;
	button2Obj		: Button;
	button3Obj		: Button;
	pictureObj		: Picture;
	allButtonsObj	: ObjectArray;
	visibleCount	: Integer;
	leftPos			: Real;
	topPos			: Real;
	
begin
	create allButtonsObj transient;
	
	if btnDialog1.visible then
		allButtonsObj.add(btnDialog1);
	endif;
	
	if btnDialog2.visible then
		allButtonsObj.add(btnDialog2);
	endif;
	
	if btnDialog3.visible then
		allButtonsObj.add(btnDialog3);
	endif;
	
	visibleCount	:=	allButtonsObj.size();
	
	if visibleCount = 1 then
		button1Obj	:=	allButtonsObj[1].Button;
		leftPos		:=	(self.frmBtns.clientWidth / 2) - (button1Obj.width / 2);
		button1Obj.move(leftPos, button1Obj.top, button1Obj.width, button1Obj.height);
		
	elseif visibleCount = 2 then
		button1Obj	:=	allButtonsObj[1].Button;
		leftPos		:=	(self.frmBtns.width / 2) - button1Obj.width - 3;
		button1Obj.move(leftPos, button1Obj.top, button1Obj.width, button1Obj.height);
		
		button2Obj	:=	allButtonsObj[2].Button;
		leftPos		:=	(self.frmBtns.width / 2) + 3;
		button2Obj.move(leftPos, button2Obj.top, button2Obj.width, button2Obj.height);
		
	elseif visibleCount = 3 then
		button2Obj	:=	allButtonsObj[2].Button;
		leftPos		:=	(self.frmBtns.width / 2) - (button2Obj.width / 2);
		button2Obj.move(leftPos, button2Obj.top, button2Obj.width, button2Obj.height);
		
		button1Obj	:=	allButtonsObj[1].Button;
		leftPos		:=	button2Obj.left - button1Obj.width - 6;
		button1Obj.move(leftPos, button1Obj.top, button1Obj.width, button1Obj.height);
		
		button3Obj	:=	allButtonsObj[3].Button;
		leftPos		:=	button2Obj.left + button2Obj.width + 6;
		button3Obj.move(leftPos, button3Obj.top, button3Obj.width, button3Obj.height);
		
	endif;
	
	/*if picExclam.visible then
		pictureObj	:=	picExclam;
	elseif picInfo.visible then
		pictureObj	:=	picInfo;
	elseif picQuestion.visible then
		pictureObj	:=	picQuestion;
	elseif picStop.visible then
		pictureObj	:=	picStop;
	endif;
	
	if pictureObj &lt;&gt; null then
		topPos	:=	(lblText.height / 2) - (pictureObj.height / 2);
		pictureObj.move(pictureObj.left, topPos, pictureObj.width, pictureObj.height);
	endif;*/
epilog
	delete allButtonsObj;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setFormColors" id="3db3e94e-ee2b-4dd4-b19e-b94202b43bd8">
        <updating/>
        <source>setFormColors(_background:Integer; _foreground:Integer) updating;
// --------------------------------------------------------------------------------
// Created:		25 January 2006 by cnwdad1
//
// Purpose:		Sets the background/foreground colors of the receiver.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.backColor		:=	_background;
	lblText.backColor	:=	_background;
	lblText.foreColor	:=	_foreground;
end;</source>
        <Parameter name="_background" type="Integer"/>
        <Parameter name="_foreground" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setMessage" id="d8317cbf-06c0-46ff-95bb-5ba48c6796f2">
        <updating/>
        <source>setMessage(_message: String; _title: String; _flags: Integer) updating;
// --------------------------------------------------------------------------------
// Created:		25 January 2006 by cnwdad1
//
// Purpose:		Sets up the form's message text, title caption and flag attributes
//				in preparation for the setupForm method which will use them to set
//				up the form controls.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.aMessage	:=	_message;
	self.aTitle		:=	_title;
	self.aFlags		:=	_flags;
end;</source>
        <Parameter name="_message" type="String"/>
        <Parameter name="_title" type="String"/>
        <Parameter name="_flags" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setMessageFontSize" id="f484820c-c397-4243-9b0d-15da255d6314">
        <source>setMessageFontSize(_size : Integer; _bold : Boolean);
// ---------------------------------------------------------------------------
// Created:		28 December 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
begin	
	if _size &lt;= 0 then
		self.lblText.fontBold := false;
		self.lblText.fontSize := 10;
	else
		self.lblText.fontBold := _bold;
		self.lblText.fontSize := _size;
	endif;
end;</source>
        <Parameter name="_size" type="Integer"/>
        <Parameter name="_bold" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="6a1f6d7b-bbb6-4940-9903-1c83d7001994">
        <updating/>
        <source>setupForm() updating, protected;
// --------------------------------------------------------------------------------
// Created:		25 January 2006 by cnwdad1
//
// Purpose:		Standard method for setting up a form.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	
	inheritMethod();
	
	//17 May 2017	NDL	TFS 4460
	if self.myTerminal &lt;&gt; null then
		if self.myTerminal.getConfig(HhErrorBeeps).Boolean then
			app.beep();
		endif;	
	endif;
	
	self.setupFormLayout();	
	self.doResize();
	self.repositionControls();
	self.windowState := self.WindowState_Normal;
	
	self.minButton := false;	//13 Apr 2012	NDL	Par 29436
	self.controlBox := false;	//13 Apr 2012	NDL	Par 29436

	executeWhen JMTDevelopmentEnvironment;
	if app.cnwkpd1_IsUser then
		self.logFormDiagnostics(false);
	endif;
	endExecuteWhen;
	
epilog	
	app.mousePointer	:=	Idle;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupFormLayout" id="ce6d209a-844b-4bfa-a611-a47de5f26659">
        <updating/>
        <source>setupFormLayout() updating, protected;
// --------------------------------------------------------------------------------
// Created:		13 February 2006 by cnwdad1
//
// Purpose:		Sets up the caption and the buttons that are available etc.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	buttonFlag		: Integer;
	defaultFlag		: Integer;
	iconFlag		: Integer;
	delta			: Real;
	defaultButton	: Button;
	
begin
	self.aIsKeyStrokeReceived	:=	false;
	lblText.borderStyle			:=	BorderStyle_None;	// It wasn't thus so it would be visible in painter
	lblText.caption				:=	self.handleAmpersands(aMessage);
	self.caption				:=	self.aTitle;

	buttonFlag	:=	self.aFlags.bitAnd(7);
	iconFlag	:=	self.aFlags.bitAnd(MsgBox_Stop_Icon + MsgBox_Question_Mark_Icon + MsgBox_Information_Icon);
	defaultFlag	:=	self.aFlags.bitAnd(MsgBox_Default_Second + MsgBox_Default_Third);


	if buttonFlag = MsgBox_OK_Only or buttonFlag &gt; MsgBox_Retry_Cancel then
		modalResult			:=	MsgBox_Return_OK;
		btnDialog1.caption	:=	"OK";//$MsgBox_Caption_OK;
		btnDialog1.tag		:=	MsgBox_Return_OK.String;
		
		if defaultFlag = MsgBox_Default_First then
			defaultButton	:=	btnDialog1;
		endif;

		if buttonFlag = MsgBox_OK_Only then
			btnDialog1.cancel	:=	true;
		endif;

		btnDialog2.visible	:=	false;
		btnDialog3.visible	:=	false;

	elseif buttonFlag = MsgBox_OK_Cancel then
		modalResult			:=	MsgBox_Return_Cancel;
		btnDialog1.caption	:=	"OK";//$MsgBox_Caption_OK;
		btnDialog1.tag		:=	MsgBox_Return_OK.String;
		
		if defaultFlag = MsgBox_Default_First then
			defaultButton	:=	btnDialog1;
		endif;

		btnDialog2.caption	:=	"Cancel";//$MsgBox_Caption_Cancel;
		btnDialog2.tag		:=	MsgBox_Return_Cancel.String;
		btnDialog2.cancel	:=	true;
		
		if defaultFlag = MsgBox_Default_Second then
			defaultButton	:=	btnDialog2;
		endif;

		btnDialog3.visible	:=	false;

	elseif buttonFlag = MsgBox_Abort_Retry_Ignore then
		btnDialog1.caption	:=	"Abort";//$MsgBox_Caption_Abort;
		btnDialog1.tag		:=	MsgBox_Return_Abort.String;
		
		if defaultFlag = MsgBox_Default_First then
			defaultButton	:=	btnDialog1;
		endif;

		btnDialog2.caption	:=	"Retry";//$MsgBox_Caption_Retry;
		btnDialog2.tag		:=	MsgBox_Return_Retry.String;
		
		if defaultFlag = MsgBox_Default_Second then
			defaultButton	:=	btnDialog2;
		endif;

		btnDialog3.caption	:=	"Ignore";//$MsgBox_Caption_Ignore;
		btnDialog3.tag		:=	MsgBox_Return_Ignore.String;
		
		if defaultFlag = MsgBox_Default_Third then
			defaultButton	:=	btnDialog3;
		endif;

	elseif buttonFlag = MsgBox_Yes_No_Cancel then
		modalResult			:=	MsgBox_Return_Cancel;
		btnDialog1.caption	:=	"Yes";//$MsgBox_Caption_Yes;
		btnDialog1.tag		:=	MsgBox_Return_Yes.String;
		
		if defaultFlag = MsgBox_Default_First then
			defaultButton	:=	btnDialog1;
		endif;

		btnDialog2.caption	:=	"No";//$MsgBox_Caption_No;
		btnDialog2.tag		:=	MsgBox_Return_No.String;
		
		if defaultFlag = MsgBox_Default_Second then
			defaultButton	:=	btnDialog2;
		endif;

		btnDialog3.caption	:=	"Cancel";//$MsgBox_Caption_Cancel;
		btnDialog3.tag		:=	MsgBox_Return_Cancel.String;
		btnDialog3.cancel	:=	true;
		
		if defaultFlag = MsgBox_Default_Third then
			defaultButton	:=	btnDialog3;
		endif;

	elseif buttonFlag = MsgBox_Yes_No then
		btnDialog1.caption	:=	"Yes";//$MsgBox_Caption_Yes;
		btnDialog1.tag		:=	MsgBox_Return_Yes.String;
		
		if defaultFlag = MsgBox_Default_First then
			defaultButton	:=	btnDialog1;
		endif;

		btnDialog2.caption	:=	"No";//$MsgBox_Caption_No;
		btnDialog2.tag		:=	MsgBox_Return_No.String;
		
		if defaultFlag = MsgBox_Default_Second then
			defaultButton	:=	btnDialog2;
		endif;

		btnDialog3.visible	:=	false;

	elseif buttonFlag = MsgBox_Retry_Cancel then
		modalResult			:=	MsgBox_Return_Cancel;
		btnDialog1.caption	:=	"Retry";//$MsgBox_Caption_Retry;
		btnDialog1.tag		:=	MsgBox_Return_Retry.String;
		
		if defaultFlag = MsgBox_Default_First then
			defaultButton	:=	btnDialog1;
		endif;

		btnDialog2.caption	:=	"Cancel";//$MsgBox_Caption_Cancel;
		btnDialog2.tag		:=	MsgBox_Return_Cancel.String;
		btnDialog2.cancel	:=	true;
		
		if defaultFlag = MsgBox_Default_Second then
			defaultButton	:=	btnDialog2;
		endif;

		btnDialog3.visible	:=	false;
	else
		modalResult	:=	0;
	endif;

	if defaultButton &lt;&gt; null then
//		setDefaultButton(defaultButton);
		defaultButton.setFocus();	//09 Nov 2015	NDL	Par 37152
	endif;

	if btnDialog1.visible then
		if btnDialog1.default then
			btnDialog1.setFocus();
		endif;
	endif;

	if btnDialog2.visible then
		if btnDialog2.default then
			btnDialog2.setFocus();
		endif;
	endif;

	if btnDialog3.visible then
		if btnDialog3.default then
			btnDialog3.setFocus();
		endif;
	else
		if btnDialog2.visible then							// Change container position and width
			delta	:=	btnDialog2.left - btnDialog1.left;
		else
			delta	:=	btnDialog3.left - btnDialog1.left;
		endif;
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="translateForm" id="7115ebc9-d1be-43c1-8da5-dbc03f4df975">
        <updating/>
        <source>translateForm(locale : CM_Locale) updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	
begin
	// Determine the locale for translations.
	inheritMethod(locale);
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0013063, locale);
	btnDialog1.translateCaption(Xlat_0013064, locale);
	btnDialog2.translateCaption(Xlat_0013065, locale);
	btnDialog3.translateCaption(Xlat_0013066, locale);
end;</source>
        <Parameter name="locale" type="CM_Locale"/>
    </JadeMethod>
</GUIClass>
