    <JadeMethod name="loadDB" id="115e3c7e-2f49-40a5-a416-a9ea05e7e9e3">
        <source>loadDB(_validateOnly: Boolean; _passport: CM_Passport input);
/*

Date		Who		Reason
27 November 2014	cnwer1	Initial creation PAR 35304

*/

vars
	real,
	proxy 	: CM_Carrier;
begin
	self.verifySelf();
	
	if _validateOnly then
		return;
	endif;

	if self.action = self.EDI_ACTION_ADD then
		proxy:=self.createProxy();
		app.myUtilityCA.utlCreateCarrier(proxy, real, _passport);
	elseif self.action = self.EDI_ACTION_UPDATE then
		proxy:=self.createProxy();
		app.myUtilityUA.utlUpdateCarrier(proxy,_passport);
	elseif self.action = self.EDI_ACTION_DELETE then
		real:=self.getCarrier();
		app.myUtilityDA.utlDeleteCarrier(real,_passport);
	endif;
	
epilog
	delete proxy;

end;</source>
        <Parameter name="_validateOnly" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="153b5054-b7a8-4179-bab9-74b06bc35c1a">
        <updating/>
        <source>setForUpdate(_proxyEDITI: SelfType) updating;
/*

Date		Who		Reason
11 June 2015	cnwer1	Initial creation PAR

*/

vars

begin
	inheritMethod(_proxyEDITI);
	self.action:=_proxyEDITI.action;
	self.code:=_proxyEDITI.code;
	self.debtorName:=_proxyEDITI.debtorName;
	self.isRail:=_proxyEDITI.isRail;
	self.isRoad:=_proxyEDITI.isRoad;
	self.notAvailable:=_proxyEDITI.notAvailable;
	self.colour := _proxyEDITI.colour;
	self.isSubCarrier := _proxyEDITI.isSubCarrier;
epilog

end;</source>
        <Parameter name="_proxyEDITI" type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="verifySelf" id="41b92e9c-1c62-49c8-8e4d-f229505e03ba">
        <source>verifySelf();
/*

Date		Who		Reason
27 November 2014	cnwer1	Initial creation PAR 35304

*/

vars
	carrier : CM_Carrier;
begin
	if self.action &lt;&gt; CM_EDITrackedItem.EDI_ACTION_ADD 
			and self.action &lt;&gt; CM_EDITrackedItem.EDI_ACTION_DELETE
			and self.action &lt;&gt; CM_EDITrackedItem.EDI_ACTION_UPDATE then
			app.raiseCMException1(EDI_Action_Is_Invalid, action, ETRow_Action, self);
			return;
	endif;
		
	if self.code = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Code', null, null);
		app.raiseCMException(Input_required_field_code, null, null); // cnwdb2	PAR 35364
	else
		carrier:=self.getCarrier;
		if action  = CM_EDITrackedItem.EDI_ACTION_ADD then
			if carrier &lt;&gt; null then
				app.raiseCMException1(VB_DUPLICATED_ITEM, self.code, null, null);
			endif;
		elseif action = CM_EDITrackedItem.EDI_ACTION_UPDATE then
			if carrier = null then
				app.raiseCMException2(Does_not_exist_cannot_update,app.getErrorString(Carrier), self.code, null, null);
			endif;
		elseif action = CM_EDITrackedItem.EDI_ACTION_DELETE then
			if carrier = null then
				app.raiseCMException2(Object_DoesNotExist_Too_Delete,app.getErrorString(Carrier),self.code, null, null);
			endif;
		endif;	
	endif;
	
	if self.description = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Description', null, null);
		app.raiseCMException(Input_required_field_Desc, null, null); // cnwdb2	PAR 35364
	endif;
epilog

end;</source>
    </JadeMethod>
</Class>
