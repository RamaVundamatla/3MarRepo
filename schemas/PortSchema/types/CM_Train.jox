    <JadeMethod name="getAuditTextForProperty" id="aee36f3c-2800-41c1-ac0f-92a5035f7d90">
        <source>getAuditTextForProperty(_property: Property): String;
// TFS BUG 58789 26JUNE2023 NAVAB1
vars
	heading,
	result,
	propName	: String;
	propValue	: String;
	
begin
	propName := _property.name;

	if propName = CM_Train::status.name then
		return self.formatAuditText(propName, app.trainStatusEnumToString(self.status.Integer));
	else
		return inheritMethod(_property);
	endif;

end;</source>
