    <JadeMethod name="getHumidityAsString" id="9275cafe-f419-45b6-be68-081e7329a8fc">
        <source>getHumidityAsString() : String;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 November 2009	cnwdap1	Initial creation
*/
vars

begin
	if self.getHumidity &lt;&gt; NULL_HUMIDITY then
	   return self.getHumidity.asStringJMT;
	endif;
	
	return null;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
