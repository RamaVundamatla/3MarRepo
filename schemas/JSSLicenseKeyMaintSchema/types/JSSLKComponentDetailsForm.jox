    <JadeMethod name="btnCancel_click" id="395e8eb6-0002-4e51-a8b5-d7b07f0298e4">
        <controlMethod name="JadeMask::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnCancel_click(jadeMask: JadeMask input) updating;
// --------------------------------------------------------------------------------
// Created:		21 January 2003 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	modalResult	:=	self.JSS_MODAL_CANCEL;
	unloadForm();
end;</source>
        <Parameter name="jadeMask" type="JadeMask" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnOk_click" id="2c7392cc-f520-4d22-bb75-25bc899fc6f8">
        <controlMethod name="JadeMask::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnOk_click(jadeMask: JadeMask input) updating;
// --------------------------------------------------------------------------------
// Created:		21 January 2003 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	app.mousePointer	:=	Busy;
	
	if self.doFormUpdate(false) then
		modalResult	:=	self.JSS_MODAL_UPDATE;
		unloadForm();
	endif;
epilog
	app.mousePointer	:=	Idle;
end;</source>
        <Parameter name="jadeMask" type="JadeMask" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doFormInitialize" id="7c80413b-996d-485d-a30d-863a2ebc9595">
        <updating/>
        <source>doFormInitialize() updating, protected;
// --------------------------------------------------------------------------------
// Created:		21 January 2003 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theComponent	: JSSLKComponent;
	
begin
	inheritMethod();
	
	theComponent	:=	self.aMyComponent;
	
	if theComponent = null then
		txtId.text			:=	null;
		txtDescription.text	:=	null;
	else
		txtId.text			:=	theComponent.componentId.String;
		txtDescription.text	:=	theComponent.componentDescription;
		
		self.resynchObjectAndSetEdition(theComponent);
	endif;
	
	modalResult	:=	self.JSS_MODAL_CANCEL;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doFormUpdate" id="53b9fe04-6b38-429c-8c8f-c403e71d3d27">
        <updating/>
        <source>doFormUpdate(pIsDelete: Boolean): Boolean updating, protected;
// --------------------------------------------------------------------------------
// Created:		21 January 2003 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theComponent			: JSSLKComponent;
	theProduct				: JSSLKProduct;
	componentId				: Integer;
	componentDescription	: String;
	
begin
	theComponent			:=	self.aMyComponent;
	theProduct				:=	self.aMyProduct;
	componentId				:=	txtId.text.trimBlanks().Integer;
	componentDescription	:=	txtDescription.text.trimBlanks();
	
	if theComponent = null then
		app.myTA.trxCreateComponent(componentId, componentDescription, theProduct, theComponent);
	else
		app.myTA.trxUpdateComponent(theComponent, self.aObjectEdition, componentId, componentDescription, theProduct);
	endif;
	
	return inheritMethod(pIsDelete);
end;</source>
        <access>protected</access>
        <Parameter name="pIsDelete" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setComponent" id="41e7762a-b187-488a-a14f-5a1906342347">
        <updating/>
        <source>setComponent(pTheComponent:JSSLKComponent; pTheProduct:JSSLKProduct) updating;
// --------------------------------------------------------------------------------
// Created:		21 January 2003 by cnwdad1
//
// Purpose:		Sets a reference to the specified component and its owning product
//				objects on the form.
//
// Parameters:	pTheComponent - The reference to the component object.
//				pTheProduct - The reference to the product object.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.aMyComponent	:=	pTheComponent;
	self.aMyProduct		:=	pTheProduct;
end;</source>
        <Parameter name="pTheComponent" type="JSSLKComponent"/>
        <Parameter name="pTheProduct" type="JSSLKProduct"/>
    </JadeMethod>
</GUIClass>
