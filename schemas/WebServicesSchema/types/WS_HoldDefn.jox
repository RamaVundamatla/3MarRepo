<Class name="WS_HoldDefn" id="8683634b-7afd-48b9-b4af-b96a29ef0c78">
    <superclass name="WS_ProxyObject"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>Internal use only. No external support</text>
    <DbClassMap file="webservice"/>
    <ImplicitInverseRef name="allBays" id="be725676-94c0-4bc6-9044-ff47a1f426e8">
        <memberTypeInverse/>
        <type name="WS_BayDefnArray"/>
    </ImplicitInverseRef>
    <PrimAttribute name="ordinal" id="f0876004-d93c-4f80-9cde-d479e31011a8">
        <embedded/>
        <type name="Integer"/>
    </PrimAttribute>
    <JadeMethod name="createProxy" id="db863a75-6b89-40e8-b051-36cde017bd0f">
        <source>createProxy(pxyVessel :CM_CellularVesselStructure; _oldOrdinal : Integer) : CM_VesselHold;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 February 2013	cnwer1	Initial creation HAT 2189

*/

vars
	completedOK : Boolean;
	pxyBay,bay		: CM_Bay;
	pxyHold,realHold : CM_VesselHold;
	wsBay 			: WS_BayDefn;
	realVessel : CM_CellularVesselStructure;
begin
	
	if not pxyVessel.isTransient then
		realVessel:=pxyVessel;
	else
		realVessel:=pxyVessel.pxyGetRealObject.CM_CellularVesselStructure;
	endif;
	
	if realVessel &lt;&gt; null and _oldOrdinal &lt;&gt; 0 then
		realHold:=realVessel.allHolds[_oldOrdinal].CM_VesselHold;
	endif;
	
	if realHold &lt;&gt; null then
		beginLoad;
		pxyHold:=realHold.pxyCreateUpdateProxy;
		endLoad;
	else
		create pxyHold transient;
	endif;
	pxyHold.setProxy(pxyVessel,self.ordinal);
	foreach wsBay in self.allBays discreteLock do
		wsBay.createProxy(pxyVessel,pxyHold, self);
	endforeach;		
	
	completedOK := true;
	return  pxyHold;
epilog
	
	if not completedOK then
		delete pxyHold;
	endif;
end;</source>
        <Parameter name="pxyVessel" type="CM_CellularVesselStructure"/>
        <Parameter name="_oldOrdinal" type="Integer"/>
        <ReturnType type="CM_VesselHold"/>
    </JadeMethod>
    <JadeMethod name="delete" id="25ae07ca-a8af-421c-90ec-4610f348c4f9">
        <updating/>
        <source>delete() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 November 2017	jlger1	Initial creation 7521

*/

vars

begin
	self.allBays.purge;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setProxyFromObject" id="20ffd521-3357-430d-9aca-9a636397b79c">
        <updating/>
        <source>setProxyFromObject(_hold: CM_Hold) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 January 2013	cnwer1	Initial creation HAT 2189

*/

vars
	bay : CM_Bay;
	wsBay : WS_BayDefn;
begin
	inheritMethod(_hold);
	self.ordinal:=_hold.ordinalHold;
	
	foreach bay in _hold.allBays discreteLock do
		create wsBay transient;
		wsBay.setProxyFromObject(bay);
		self.allBays.add(wsBay);
	endforeach;
epilog

end;</source>
        <Parameter name="_hold" type="CM_Hold"/>
    </JadeMethod>
    <JadeMethod name="setProxyFromObjectBay" id="7aa8e2b2-cdc7-4828-bc77-df3c73c4e1b5">
        <updating/>
        <source>setProxyFromObjectBay(_hold: CM_Hold) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 January 2013	cnwer1	Initial creation HAT 2189

*/

vars
	bay : CM_Bay;
	wsBay : WS_BayDefn;
begin
	self.cmObjectEdition	:= _hold.edition();
	self.cmObjectId			:= _hold.getOidAsString();
	self.ordinal:=_hold.ordinalHold;
	
	foreach bay in _hold.allBays discreteLock do
		create wsBay transient;
		wsBay.setProxyFromObjectBay(bay);
		self.allBays.add(wsBay);
	endforeach;
epilog

end;</source>
        <Parameter name="_hold" type="CM_Hold"/>
    </JadeMethod>
</Class>
