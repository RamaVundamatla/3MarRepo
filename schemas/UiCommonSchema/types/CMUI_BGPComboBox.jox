// -------------------------------------------
// Created 07 November 2003 by cnwdvb1
// -------------------------------------------
vars

begin
	inheritMethod(combobox);
	if self.myFrame &lt;&gt; null then
		self.myFrame.doGotFocus(self);
	endif;


end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="lostFocus" id="a475f2b1-f009-4ce3-aa48-5230a91e3b09">
        <updating/>
        <source>lostFocus(combobox: ComboBox input) updating;

// cnwdvb1 18 December 2002 

vars

begin
	inheritMethod(combobox);
	if self.myFrame &lt;&gt; null then
		self.myFrame.doLostFocus(self);
	endif;

end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setMyFrame" id="afd90d95-535e-4ae8-bae4-63e4975faa5a">
        <updating/>
        <source>setMyFrame(_frame : CMUI_Frame) updating;

// cnwdvb1 18 December 2002 

vars

begin

	self.myFrame := _frame;

end;</source>
        <Parameter name="_frame" type="CMUI_Frame"/>
    </JadeMethod>
