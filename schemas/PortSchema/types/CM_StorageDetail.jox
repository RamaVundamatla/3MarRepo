    <JadeMethod name="doesCalendarIncludeDate" id="6768115f-7874-47e5-b308-8d5c8e86df18">
        <source>doesCalendarIncludeDate(_freeDaysType: Integer; _date : Date) : Boolean;
/*
Purpose:			

Date		Who		Reason
21AUG2023	NAVAB1	BUG 65740 
*/

vars
	calendar : CM_Calendar;
begin

	foreach calendar in self.allAdditionalCalendars discreteLock do
		if calendar.doesCalendarIncludeDate(_date) then
			return true;
		endif;
	endforeach;
	

	return false;

epilog

end;</source>
        <Parameter name="_freeDaysType" type="Integer"/>
        <Parameter name="_date" type="Date"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getAuditText" id="1a063830-4296-49b7-8d8a-a202d0d0f70d">
        <source>getAuditText(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08/06/2023	navkc1	CR 58007 Task 58008: JADE - Storage Config - Audits

*/

vars
	audTxt, 
	tmpStr			: String;	
	calendar		: CM_Calendar;
begin
	
	audTxt[10000] 	:= '*';
	audTxt			:= null;
	
	audTxt := inheritMethod();
	
	if self.allAdditionalCalendars.size() &gt; 0 then
		audTxt := audTxt &amp; self.allAdditionalCalendars.getName() &amp; AuditStringSeparator;
		
		foreach calendar in self.allAdditionalCalendars do
			if calendar &lt;&gt; null then
				tmpStr := calendar.description &amp; Cr &amp; tmpStr;
			endif;
		endforeach;
		
		audTxt := audTxt &amp; CM_StorageDetail::allAdditionalCalendars.name &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp;tmpStr &amp; AuditStringSeparator;
	endif;
	
	return audTxt;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getAuditTextForProperty" id="ba984087-4700-4237-b956-ba2020decab1">
        <source>getAuditTextForProperty(_property: Property): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 May 2016	cnwndl1	Initial creation	TFS 1981
08/06/2023	navkc1	CR 58007 Task 58008: JADE - Storage Config - Audits
16/06/2023	navkc1	CR 58221 Task 58222: UI - Ownership Change Free Days
*/

vars

begin
	if _property.name = CM_StorageDetail::allFutureStorageMappings.name then
		return self.formatAuditText( _property.name, self.allFutureStorageMappings.getStorageDetailAuditText );
	elseif _property.name = CM_StorageDetail::unpackReceivalType.name then //08/06/2023	navkc1	CR 58007 Task 58008
		return self.formatAuditText(_property.name, self.getReceivalDateOptionStr(self.unpackReceivalType));
	elseif _property.name = CM_StorageDetail::roadReceivalType.name then //08/06/2023	navkc1	CR 58007 Task 58008
		return self.formatAuditText(_property.name, self.getReceivalDateOptionStr(self.roadReceivalType));
	elseif _property.name = CM_StorageDetail::railReceivalType.name then //08/06/2023	navkc1	CR 58007 Task 58008
		return self.formatAuditText(_property.name, self.getReceivalDateOptionStr(self.railReceivalType));
	elseif _property.name = CM_StorageDetail::shipReceivalType.name then //08/06/2023	navkc1	CR 58007 Task 58008
		return self.formatAuditText(_property.name, self.getShipReceDescption());
	elseif _property.name = CM_StorageDetail::freeDaysType.name then //16/06/2023	navkc1	CR 58221 Task 58222
		return self.formatAuditText(_property.name, self.getDayTypes(self.freeDaysType));
	elseif _property.name = CM_StorageDetail::chargedDaysType.name then //16/06/2023	navkc1	CR 58221 Task 58222
		return self.formatAuditText(_property.name, self.getDayTypes(self.chargedDaysType));
	elseif _property.name = CM_StorageDetail::cooFreeDaysType.name then //16/06/2023	navkc1	CR 58221 Task 58222
		return self.formatAuditText(_property.name, self.getDayTypes(self.cooFreeDaysType));
	endif;

	return inheritMethod(_property);

epilog

end;</source>
        <Parameter name="_property" type="Property"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getChargedDaysAre" id="08d0369e-4097-4d9c-aa39-f95d84ab2f51">
        <source>getChargedDaysAre():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 Oct 2023	navma1 ChangeRequest 60920: EUP | Cargo Enquiry Performance - Work Packet 1

*/

vars

begin
	if self.chargedDaysType = Working_Days then
		return self.chargeDays.asStringJMT &amp; " " &amp; app.getErrorString(Working_days); 
	elseif self.chargedDaysType = Calendar_Days then
		return self.chargeDays.asStringJMT &amp; " " &amp; app.getErrorString(All_Days); 
	elseif self.chargedDaysType = Calendar_Months then
		return self.chargeDays.asStringJMT &amp; " " &amp; app.getErrorString(Calendar_months);
	elseif self.chargedDaysType = Working_Compulsory_Days then 
		return self.chargeDays.asStringJMT &amp; " " &amp; app.getErrorString(Working_compulsory_days);
	endif;
	return null;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getContentForTable" id="ad7d15fc-e8c7-4ed2-9029-40b957d2bcad">
        <source>getContentForTable() : String;

vars
	line,
	tmpDesc	: String;
	critType	: CM_YACriteriaType;
	criteria : CM_YACriteria;
begin
	foreach critType in self.myStorageConfig.allYACriteriaTypes do
		criteria := self.allCriteriaByType[critType.type];
		if criteria = null then
			line := " ";
		else
			line := critType.getDataDisplay(criteria.myYAData);
		endif;
		//	TFS 2056 clean up table display of attributes
		if tmpDesc = null then
			tmpDesc := line &amp; Tab;
		else
			tmpDesc := tmpDesc &amp; line &amp; Tab;
		endif;
	endforeach;
	return tmpDesc;

end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getCooFreeStorageDays" id="c49440e9-ba2c-4841-a880-fae14d6fb567">
        <source>getCooFreeStorageDays():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 Oct 2023	navma1 ChangeRequest 60920: EUP | Cargo Enquiry Performance - Work Packet 1

*/

vars

begin
	if self.cooFreeDaysType = Working_Days then
		return self.cooFreeStorageDays.asStringJMT &amp; " " &amp; app.getErrorString(Working_days);
	elseif self.cooFreeDaysType = Calendar_Days then
		return self.cooFreeStorageDays.asStringJMT &amp; " " &amp; app.getErrorString(All_Days);
	elseif self.cooFreeDaysType = Calendar_Months then
		return self.cooFreeStorageDays.asStringJMT &amp; " " &amp; app.getErrorString(Calendar_months);
	elseif self.cooFreeDaysType = Working_Compulsory_Days then
		return self.cooFreeStorageDays.asStringJMT &amp; " " &amp; app.getErrorString(Working_compulsory_days);
	endif;
	return null;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDayTypes" id="418d52bc-eeed-4942-98aa-836533e42eca">
        <source>getDayTypes(_dayType : Integer):String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 Feb 2021 cnwma1 STWO - 1- Calculate storage/ demurrage charges for all cargo discharged from a vessel either Import or Transshipment.

*/

vars

begin
	if _dayType = Working_Days then
		return  app.getErrorString(Working_days);
	
	elseif _dayType = Calendar_Days then
		return  app.getErrorString(All_Days);
	
	elseif _dayType = Calendar_Months then
		return app.getErrorString(Calendar_months);
	
	elseif _dayType = Working_Compulsory_Days then	
		return  app.getErrorString(Working_compulsory_days);
	endif;
epilog

end;</source>
        <Parameter name="_dayType" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDefaultDescription" id="f093566d-198e-4233-9c1f-1bffe7995874">
        <source>getDefaultDescription() : String;
/*
Purpose:			
Date				Who			Reason
MAY 2014		CNWAB1		Initial creation
*/

vars
	port : CM_Port;
	criteria : CM_YACriteria;	
	imex : CM_IMEXStatus;
	type : CM_CargoType;
	tmpDesc : String;
	iso : CM_ISOType;
	isoGroup : CM_ISOTypeGroup;
	
begin

	criteria := self.getCriteriaOfTypeValue(YACriteriaType_ImexStatus);
	if criteria &lt;&gt; null then
		imex := criteria.myYAData.CM_YADataObjects.allObjects.first().CM_IMEXStatus;
		if imex &lt;&gt; null then
			tmpDesc := imex.abbreviation[1];
		endif;
	endif;

	// PAR 28581 the desc was hand crafted, now is auto and uses all attributes.
	foreach criteria in self.allCriteriaByType discreteLock do
	
		if criteria.myYACriteriaType.type = YACriteriaType_ImexStatus then
			continue;
		endif;
		tmpDesc := tmpDesc &amp; " " &amp; criteria.myYACriteriaType.getDataDisplay(criteria.myYAData);
	endforeach;
	
	
return tmpDesc;	

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayForLogging" id="71bf0b8e-b13f-4748-ab19-2df164de948f">
        <source>getDisplayForLogging() : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
05 Oct 2022	navma1	Bug 52967: STWO - Cargo Delivery Process &amp; System Lock Details

*/
vars
	line,
	tmpDesc	 		: String;
	criteria 		: CM_YACriteria;
	criteriaType	: CM_YACriteriaType;
begin
	
	foreach criteria in self.allCriteriaByType discreteLock do
		criteriaType := criteria.myYACriteriaType;
		line 		 := criteriaType.description &amp; ": " &amp; criteriaType.getDataDisplay(criteria.myYAData);
		
		if tmpDesc = null then
			tmpDesc := "[" &amp;  self.priorityValue.String &amp; "] " &amp;  line;	//18 May 2016	NDL	TFS 1981 - add priority
		else
			tmpDesc := tmpDesc &amp; "; " &amp; line;
		endif;
		
	endforeach;
	
	return tmpDesc;

end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="eb0e71f6-6432-4bb7-b8b6-90c472d7886a">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19/09/2012	cnwer1	Initial creation SFW 1295
07/09/2016	cnwdap1	TFS 2570 Stop Complete Free Storage Days
21 Jul 2017	cnwma1	TFS #5409:STWO - Storage Slab Auto Commercial Hold
19/06/2023	navkc1	CR 58221 Task 58223: UI - Storage Detail List
31 Oct 2023	navma1  ChangeRequest 60920: EUP | Cargo Enquiry Performance - Work Packet 1
*/

vars
	receiveStart	: Integer;
	freeStorageDaysString : String;
	criteria : CM_YACriteria;
begin
	if _attrName = ETRow_CargoType then
		criteria:= self.getCriteriaOfTypeValue( YACriteriaType_CargoType );
		if criteria &lt;&gt; null then
			return criteria.getDisplayForYAMTableColumn();
		endif;
	elseif _attrName = ETRow_Commodity then
		criteria:= self.getCriteriaOfTypeValue( YACriteriaType_Commodity );
		if criteria &lt;&gt; null then
			return criteria.getDisplayForYAMTableColumn();
		endif;
	elseif _attrName = ETRow_CommodityGroup then
		criteria:= self.getCriteriaOfTypeValue( YACriteriaType_CommodityGroup );
		if criteria &lt;&gt; null then
			return criteria.getDisplayForYAMTableColumn();
		endif;
	elseif _attrName = ETRow_ContainerLength then
		criteria:= self.getCriteriaOfTypeValue( YACriteriaType_ContainerLength );
		if criteria &lt;&gt; null then
			return criteria.getDisplayForYAMTableColumn();
		endif;
	elseif _attrName = ETRow_ContentsStatus then
		criteria:= self.getCriteriaOfTypeValue( YACriteriaType_ContentsStatus );
		if criteria &lt;&gt; null then
			return criteria.getDisplayForYAMTableColumn();
		endif;
	elseif _attrName = ETRow_ImexStatus then
		criteria:= self.getCriteriaOfTypeValue( YACriteriaType_ImexStatus );
		if criteria &lt;&gt; null then
			return criteria.getDisplayForYAMTableColumn();
		endif;
	elseif _attrName = ETRow_IsoType then
		criteria:= self.getCriteriaOfTypeValue( YACriteriaType_ISO );
		if criteria &lt;&gt; null then
			return criteria.getDisplayForYAMTableColumn();
		endif;
	elseif _attrName = ETRow_IsoGroup then
		criteria:= self.getCriteriaOfTypeValue( YACriteriaType_ISOGroup );
		if criteria &lt;&gt; null then
			return criteria.getDisplayForYAMTableColumn();
		endif;
	elseif _attrName = ETRow_CargoSubType then
		criteria:= self.getCriteriaOfTypeValue( YACriteriaType_Product );	
		if criteria &lt;&gt; null then
			return criteria.getDisplayForYAMTableColumn();
		endif;
	elseif _attrName = ETRow_IsOverDimension then
		criteria:= self.getCriteriaOfTypeValue( YACriteriaType_IsOverDimension );
		if criteria &lt;&gt; null then
			return criteria.getDisplayForYAMTableColumn();
		endif;
	elseif _attrName =ETRow_SubTerminal then
		criteria:= self.getCriteriaOfTypeValue( YACriteriaType_SubTerminal );
		if criteria &lt;&gt; null then
			return criteria.getDisplayForYAMTableColumn();
		endif;
	elseif _attrName =ETRow_IsHazardous then
		criteria:= self.getCriteriaOfTypeValue( YACriteriaType_IsHazardous );
		if criteria &lt;&gt; null then
			return criteria.getDisplayForYAMTableColumn();
		endif;
	elseif _attrName = ETRow_IsPowered then
		criteria:= self.getCriteriaOfTypeValue( YACriteriaType_RequiresPower );
		if criteria &lt;&gt; null then
			return criteria.getDisplayForYAMTableColumn();
		endif;
	elseif _attrName = ETRow_IsHazAL then
		criteria:= self.getCriteriaOfTypeValue( YACriteriaType_IsHazAllLimited );
		if criteria &lt;&gt; null then
			return criteria.getDisplayForYAMTableColumn();
		endif;
	elseif _attrName =ETRow_IsHazNL then
		criteria:= self.getCriteriaOfTypeValue( YACriteriaType_IsHazNotLimited );
		if criteria &lt;&gt; null then
			return criteria.getDisplayForYAMTableColumn();
		endif;
	elseif _attrName = ETRow_IsHazOL then
		criteria:= self.getCriteriaOfTypeValue( YACriteriaType_IsHazOrLimited );
		if criteria &lt;&gt; null then
			return criteria.getDisplayForYAMTableColumn();
		endif;
	elseif _attrName = ETRow_IsDamaged then
		criteria:= self.getCriteriaOfTypeValue( YACriteriaType_Damaged );
		if criteria &lt;&gt; null then
			return criteria.getDisplayForYAMTableColumn();
		endif;
	elseif _attrName =ETRow_IsEmpty then
		criteria:= self.getCriteriaOfTypeValue( YACriteriaType_IsEmpty);
		if criteria &lt;&gt; null then
			return criteria.getDisplayForYAMTableColumn();
		endif;
	elseif _attrName = ETRow_FreeStorageDays then		//31.10.2023 navma1 #60920
		return self.getFreeStorageDays();
	elseif _attrName = ETRow_CooFreeStorageDays then 	//19/06/2023	navkc1	CR 58221 Task 58223
		return self.getCooFreeStorageDays();			//31.10.2023 navma1 #60920
	elseif _attrName = ETRow_ChargedDaysAre then		//31.10.2023 navma1 #60920
		return self.getChargedDaysAre();
	elseif _attrName = "receiveStart" then
		receiveStart := self.getReceiveStart();
		if receiveStart = 0 then
			return app.getErrorString(Receive);
		elseif receiveStart = 1 then
			return app.getErrorString(PackComplete);
		else
			return "";
		endif;
		
	elseif _attrName = ETRow_StopCompleteFreeDays then														// TFS 2570
		return self.stopCompletionFreeDays.asStringJMT &amp; " " &amp; app.getErrorString(All_Days); //20 Sep 2017	NDL	TFS 7032
	
	elseif _attrName = ETRow_FsStop then	 //21.07.2017 cnwma1 TFS #5409
		if self.myFutureStorageStop&lt;&gt; null then
			return self.myFutureStorageStop.heading;
		else
			return "";
		endif;
	elseif _attrName = ETRow_Fsmappings then	 // TFS 5225
		return  (not self.allFutureStorageMappings.isEmpty).getYesNo();
	elseif _attrName = ETRow_Priority then		 // TFS 5225
		return self.priorityValue.String;
	else
		return inheritMethod(_attrName, _short);
	endif;
epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getFreeStorageDays" id="70899658-bd54-4550-bc62-c4b3e6c12602">
        <source>getFreeStorageDays():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 Oct 2023	navma1 ChangeRequest 60920: EUP | Cargo Enquiry Performance - Work Packet 1

*/

vars

begin
	if self.freeDaysType = Working_Days then
		return self.freeStorageDays.asStringJMT &amp; " " &amp; app.getErrorString(Working_days);
	elseif self.freeDaysType = Calendar_Days then
		return self.freeStorageDays.asStringJMT &amp; " " &amp; app.getErrorString(All_Days);
	elseif self.freeDaysType = Calendar_Months then
		return self.freeStorageDays.asStringJMT &amp; " " &amp; app.getErrorString(Calendar_months);
	elseif self.freeDaysType = Working_Compulsory_Days then	 //20 Sep 2017	NDL	TFS 7032
		return self.freeStorageDays.asStringJMT &amp; " " &amp; app.getErrorString(Working_compulsory_days);
	endif;
	return null;
epilog

end;</source>
        <ReturnType type="String"/>
