    <JadeMethod name="setForUpdate" id="d5111b7e-b2b7-40d1-afc2-5653dddaaeaa">
        <updating/>
        <source>setForUpdate(_proxy: CM_HSCodeSubCode) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date					Who		Reason
28 November 2022		jlizm1	Initial creation TFS 55280 Harmonized System Codes

*/

vars

begin
	inheritMethod(_proxy);
	
	if _proxy.myHSCode &lt;&gt; null then
		self.myHSCode := _proxy.myHSCode;
	else
		self.myHSCode := _proxy.getParentFromRoot();
	endif;
	
	self.externalRef1 	:= _proxy.externalRef1;
	self.externalRef2 	:= _proxy.externalRef2;
	self.externalRef3 	:= _proxy.externalRef3;
	self.unitQuantity	:= _proxy.unitQuantity;

epilog

end;</source>
        <Parameter name="_proxy" type="CM_HSCodeSubCode"/>
    </JadeMethod>
