    <JadeMethod name="doesMatchToDoType" id="3f0d9800-7962-45bf-bd8c-c579f8ecfb29">
        <source>doesMatchToDoType(_todoType : Integer) : Boolean;
/*
Purpose:	

Date		Who		Reason
25 October 2024	navab1	JIRA 14793
*/

vars

begin

	if _todoType = TODO_TYPE_GROUP_VOYAGE then
		return self.classNameToCreate = CM_WOToDo_Voyage.name;
	elseif _todoType = TODO_TYPE_GROUP_TRAIN then
		return self.classNameToCreate = CM_WOToDo_Train.name;
	elseif _todoType = TODO_TYPE_GROUP_WAGON then
		return self.classNameToCreate = CM_WOToDo_Wagon.name;
	elseif _todoType = TODO_TYPE_GROUP_VEHICLEBOOKING then
		return self.classNameToCreate = CM_WOToDo_VBS.name;
	elseif _todoType = TODO_TYPE_GROUP_VEHICLE then
		return self.classNameToCreate = CM_WOToDo_Truck.name;
	elseif _todoType = TODO_TYPE_GROUP_NONOPS then
		return self.classNameToCreate = CM_WOToDo_NonOps.name;
	elseif _todoType = TODO_TYPE_GROUP_TI then
		return self.classNameToCreate = CM_WOTI_ToDoTask.name;
	elseif _todoType = TODO_TYPE_GROUP_CARGOGROUP then
		return self.classNameToCreate = CM_WOTI_ToDoTask.name;
	endif;
	
	return false;
epilog

end;</source>
        <Parameter name="_todoType" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getAuditText" id="7800adb6-4cac-47a2-8e6b-c2ac76bb3853">
        <source>getAuditText(): String;
// ---------------------------------------------------------------------------
// Created:     
//
// Purpose:     
// ---------------------------------------------------------------------------

vars
	txt		: String;
	tmpStr	: String;
	port    : CM_Port;
begin
