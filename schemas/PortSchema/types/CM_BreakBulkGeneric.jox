    <JadeMethod name="getDefaultWeightForQuantity" id="5e0b8b0f-d3b1-4765-990b-f79f340bc1d7">
        <source>getDefaultWeightForQuantity(_quantity : Integer): String;
/*

divides self.totalWeight by quanity then converts to the default measurement weight value

Date		Who		Reason
16 October 2013	cnwer1	Initial creation PAR 32445

*/

vars
	convertedWeight : Decimal[14,4];
	measureType : CM_MeasurementType;
	product : CM_Product;
begin
	
	if _quantity = 0 then
		return null;
	endif;
	product:=self.getProductForMeasurementConv;
	if product &lt;&gt; null then
		measureType := product.getDefaultMeasurementForType(Type_Weight);
	else
		measureType := app.getDefaultMeasurementForType(Type_Weight);
	endif;
	
	convertedWeight:=self.totalWeight  * (_quantity/self.totalQuantity);
	
	return app.convertMeasurementForDisplay(measureType.shortName,convertedWeight);
	
	
	return null;
epilog

end;</source>
        <Parameter name="_quantity" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDensityStr" id="87fa35de-5191-4cd8-b8f1-b6dcd4b422c5">
        <source>getDensityStr() : String;
/*
----------   ----------  --------------------------------------------------
Created:	31 May 2006 By cnwth2

Purpose:	Used bt JRW - don't remove

Changed On   Changed By  Reason
31 Oct 2023	navma1 ChangeRequest 60920: EUP | Cargo Enquiry Performance - Work Packet 1	
----------   ----------  --------------------------------------------------
*/
vars
	val		 : String;
	product  : CM_Product;
begin
	
	product := self.myProduct;					//31.10.2023 navma1 #60920
	
	if product = null then
		return null;
	endif;
	
	val := product.getTIDisplayValueForAttribute(self, ETRow_Density);
	if val = null then
		val := self.density.String;
	endif;
	
	return val;
	
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
