    <JadeMethod name="allowsSnapShotEdit" id="fd4b58f7-f844-429f-9255-dd50ce0049c8">
        <source>allowsSnapShotEdit():Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 February 2021	navndl1	Initial creation	TFS 50835

*/

vars

begin

	if self.classNameToCreate = CMEVT_WagonTransaction.name then
		if self.type = EVT_WagonCargoConfirmed
		or self.type = EVT_WagonCargoMoved
		or self.type = EVT_WagonCargoReceive
		or self.type = EVT_WagonCargoRelease
		then
			return true;
		endif;
	endif;
	
	return false;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
