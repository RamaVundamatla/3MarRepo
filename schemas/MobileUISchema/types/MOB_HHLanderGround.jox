    <JadeMethod name="setupForm" id="b7abcfad-c699-457c-9fb2-c31a050a2edb">
        <updating/>
        <source>setupForm() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14 May 2010	cnwndl1	Initial creation	Par 23603

*/

vars

begin

	self.myHandHeldCheckerAgent := app.myHandHeldCheckerAgent;
	
	//10 Jul 2012	NDL	Par 29961
	self.myMobileGenericAgent.setHHLanderGroundingOpt();

	if not self.myMobileGenericAgent.checksState = self.myMobileGenericAgent.ShipDischargeCargo or self.myMobileGenericAgent.hhLanderGroundingOpt = NoOpts then
		// not allowed to grround anything but discharges....
		self.doBackButtonClick();
	endif;

	self.setupCmdButtons( 2, app.getErrorString(Complete), app.getErrorString(Back), null, null, null );

	self.myTrackedItem := self.myMobileGenericAgent.myNextTiToAction;
		
	inheritMethod();
	
	self.setupControls();

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="translateForm" id="805602a0-198e-482a-8c74-a5c14697917d">
        <updating/>
        <source>translateForm(locale : CM_Locale) updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	
begin
	// Determine the locale for translations.
	inheritMethod(locale);
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0014801, locale);
	btnInTransit.translateCaption(Xlat_0018056, locale);
	lblCargoId.translateCaption(Xlat_0014802, locale);
	lblGroundCargo.translateCaption(Xlat_0014803, locale);
	lblLane.translateCaption(Xlat_0014804, locale);
	lblTerminalArea.translateCaption(Xlat_0014805, locale);
end;</source>
        <Parameter name="locale" type="CM_Locale"/>
    </JadeMethod>
</GUIClass>
