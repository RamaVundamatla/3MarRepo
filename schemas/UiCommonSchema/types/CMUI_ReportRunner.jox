		self.switchDateBoxComboBox(false, ETRow_FilterDateOut, self.cmbCloseDate);
		
		self.switchDateBoxComboBox (false,ETRow_ExpectedArrivalDateFrom, self.cmbExpArrDFrom);					//+TFS39280
		self.switchDateBoxComboBox (false,ETRow_ExpectedArrivalDateTo, self.cmbExpArrDTo);
		self.switchDateBoxComboBox (false,ETRow_ExpectedDepartDateFrom, self.cmbExpDepDFrom);
		self.switchDateBoxComboBox (false,ETRow_ExpectedDepartDateTo, self.cmbExpDepDTo);
		
		self.switchDateBoxComboBox(false, ETRow_DateToRun, self.cmbOpenDate);	//14 Aug 2019	NDL	TFS 46131
		self.switchDateBoxComboBox(false, ETRow_DateYearStart, self.cmbCloseDate);	//14 Aug 2019	NDL	TFS 46131
		
		self.switchDateBoxComboBox(false, ETRow_StartOfYearDate, self.cmbCloseDate);	//21 Jun 2021	NDL	TFS 51245

		// Switch dynamic query report parameter date fields to Date Box
		self.switchQryParamsDateBoxToCmb(false);  // 27-oct-25 navec1 MTN-36160: switch all date fields in allQueryReportParams to date box

		
	elseif _state = self.myReportAgent.STATE_BGR_RUN then	
		self.lblRepName.caption := 'Background Reports:';
		self.btnEdit.enabled 			:= true;
		self.btnDeleteBGR.enabled 		:= true;
		self.btnPrint.enabled 			:= true;
		self.tblBGPReports.visible 		:= true;
		
	elseif _state = self.myReportAgent.STATE_BGR_EDIT then
		self.tblBGPEnt.visible 			:= true;
//		self.btnPrint.caption			:= '&amp;Save';		// cnwrl1 30/11/2009 PAR 19950 - what it was
//		self.btnDeleteBGR.caption 		:= '&amp;Cancel';	// cnwrl1 30/11/2009 PAR 19950 - what it was
		// cnwrl1 30/11/2009 PAR 19950 - start of coding
		// change the button captions using the translatable values.
		self.btnPrint.translateCaption( Xlat_0005398, null );			// &amp;Save
		self.btnDeleteBGR.translateCaption( Xlat_0005393, null );		// &amp;Cancel
		// cnwrl1 30/11/2009 PAR 19950 - end of coding
		self.btnPrint.enabled 			:= true;
		self.btnDeleteBGR.enabled 		:= true;
		
	elseif _state = self.myReportAgent.STATE_BGR_SAVE then
		self.lblRepName.visible 		:= true;	
		self.btnPrint.enabled 			:= true;
		self.tblParameter.visible 		:= true;
		
		self.tblParameter.showRowByName(ETRow_TemplateName, true);
		self.tblParameter.setFocus();
		self.tblParameter.goToRowByName(ETRow_TemplateName);
		
	elseif _state = self.myReportAgent.STATE_TEMPLATE_SAVE then
		self.lblRepName.visible 		:= true;
		self.btnPrint.enabled 			:= true;
		self.tblParameter.visible 		:= true;
		self.tblTerminals.enabled		:= true;
//		self.btnPrint.caption		:= '&amp;Save';	// cnwrl1 30/11/2009 PAR 19950 - what it was
		// cnwrl1 30/11/2009 PAR 19950 - start of coding
		// change the button captions using the translatable values.
		self.btnPrint.translateCaption( Xlat_0005398, null );				// &amp;Save
