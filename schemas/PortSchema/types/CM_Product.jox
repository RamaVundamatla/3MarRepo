    <JadeMethod name="validateProdAttrForRange" id="fd2a319a-2b3d-4e6f-8ea8-a664bfcffe91">
        <source>validateProdAttrForRange(_errorString : String output) : Boolean;
/* ---------------------------------------------------------------------------
Created:	15 February 2010	by cnwvu1

Purpose:	PAR 22189. Checking whether values are in the range.
   
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars
	attrDec	: CM_ProdAttrDecimal;
	attrInt	: CM_ProdAttrInteger;
	valueDec: Decimal[12,3];
	valueInt: Integer;

begin


	// HEIGHT
	attrDec := self.getMyHeight().CM_ProdAttrDecimal;
	if attrDec.maxValue &lt; attrDec.minValue then
		_errorString := app.getErrorString1( ERR_IncorrectRangeFormat, app.getErrorString(Height) );
		return false;
	endif;
	valueDec:= attrDec.value;
	if not self.validateMyHeightValue(valueDec) then
		_errorString := app.getErrorString4( ERR_ValueOutOfRange, app.getErrorString(Height), valueDec.asStringJMT(), attrDec.minValue.asStringJMT(), attrDec.maxValue.asStringJMT() );
		return false;
	endif;

	// LENGTH
	attrDec := self.getMyLength().CM_ProdAttrDecimal;
	if attrDec.maxValue &lt; attrDec.minValue then
		_errorString := app.getErrorString1( ERR_IncorrectRangeFormat, app.getErrorString(CM_Length) );
		return false;
	endif;
	valueDec:= attrDec.value;
	if not self.validateMyLengthValue(valueDec) then
		_errorString := app.getErrorString4( ERR_ValueOutOfRange, app.getErrorString(CM_Length), valueDec.asStringJMT(), attrDec.minValue.asStringJMT(), attrDec.maxValue.asStringJMT() );
		return false;
	endif;

	// WEIGHT
	attrDec := self.getMyWeight().CM_ProdAttrDecimal;
	if attrDec.maxValue &lt; attrDec.minValue then
		_errorString := app.getErrorString1( ERR_IncorrectRangeFormat, app.getErrorString(CM_Weight) );
		return false;
	endif;
	valueDec:= attrDec.value;
	if not self.validateMyWeightValue(valueDec) then
		_errorString := app.getErrorString4( ERR_ValueOutOfRange, app.getErrorString(CM_Weight), valueDec.asStringJMT(), attrDec.minValue.asStringJMT(), attrDec.maxValue.asStringJMT() );
		return false;
	endif;
	
	// WIDTH
	attrDec := self.getMyWidth().CM_ProdAttrDecimal;
	if attrDec.maxValue &lt; attrDec.minValue then
		_errorString := app.getErrorString1( ERR_IncorrectRangeFormat, app.getErrorString(CM_Width) );
		return false;
	endif;
	valueDec:= attrDec.value;
	if not self.validateMyWidthValue(valueDec) then
		_errorString := app.getErrorString4( ERR_ValueOutOfRange, app.getErrorString(CM_Width), valueDec.asStringJMT(), attrDec.minValue.asStringJMT(), attrDec.maxValue.asStringJMT() );
		return false;
	endif;

	// QUANTITY
	attrInt := self.myQuantity.CM_ProdAttrInteger;
	if attrInt.maxValue &lt; attrInt.minValue then
		_errorString := app.getErrorString1( ERR_IncorrectRangeFormat, app.getErrorString(CM_Quantity) );
		return false;
	endif;
	valueInt:= attrInt.value;
	if not self.validateMyQuantityValue(valueInt) then
		_errorString := app.getErrorString4( ERR_ValueOutOfRange, app.getErrorString(CM_Quantity), valueInt.asStringJMT(), attrInt.minValue.asStringJMT(), attrInt.maxValue.asStringJMT() );
		return false;
	endif;

	return true;
	
end;</source>
        <Parameter name="_errorString" type="String" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
