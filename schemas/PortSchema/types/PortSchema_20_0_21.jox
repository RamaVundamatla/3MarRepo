    <JadeMethod name="createRoadProcessObjs" id="d766289d-684b-467d-bef1-b7c80f295d5c">
        <source>createRoadProcessObjs( _updController : CnEcReleaseController );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 October 2020	jlgndl1	Initial creation	TFS 49189

*/

vars

	pxyRoadProcess : CM_RoadProcess;
	roadProcess : CM_RoadProcess;
	terminal : CM_Terminal;
	securityRoleTerminal : CM_SecurityRoleTerminal;

begin

	if self.hasScriptBeenRunAtAll(method.name, _updController) then
		return;
	endif;
	
	app.writeLog(method.qualifiedName &amp; " Creating Road Process Objects and Setting PmAdmEnterVVR", LogINFO);
	if _updController &lt;&gt; null then
		_updController.logEntry(" Creating Road Process Objects and Setting PmAdmEnterVVR") ;	
	endif;
	
	beginTransaction;
	
	// Default process
	if not app.myRoot.allRoadProcesses.isEmpty then
		roadProcess := app.myRoot.allRoadProcesses.getAtKey( CM_RoadProcess.DEFAULT ).CM_RoadProcess;
	endif;
	
	if roadProcess = null then
		create pxyRoadProcess transient;
		pxyRoadProcess.setCode(CM_RoadProcess.DEFAULT);
		pxyRoadProcess.setDescription("MTN Default Road Process");
		
		create roadProcess persistent;
		roadProcess.setForCreate( pxyRoadProcess );
		delete pxyRoadProcess;
		
		foreach terminal in CM_Terminal.instances do
			terminal.setPropertyValue( "myRoadProcess", roadProcess );
		endforeach;
		
		roadProcess := null;	
	endif;
	
	// ASPA Process 
	if not app.myRoot.allRoadProcesses.isEmpty then
		roadProcess := app.myRoot.allRoadProcesses.getAtKey( CM_RoadProcess.ASPA_GCI ).CM_RoadProcess;
	endif;
	
	if roadProcess = null then
		create pxyRoadProcess transient;
		pxyRoadProcess.setCode(CM_RoadProcess.ASPA_GCI);
		pxyRoadProcess.setDescription("ASPA GCI Road Process");
		
		create roadProcess persistent;
		roadProcess.setForCreate( pxyRoadProcess );
		delete pxyRoadProcess;
		
		roadProcess := null;
	endif;
	
	foreach securityRoleTerminal in CM_SecurityRoleTerminal.instances do
		if securityRoleTerminal.permissions.size &lt; PmAdmEnterVVR or not securityRoleTerminal.permissions[PmAdmEnterVVR] then
			securityRoleTerminal.permissions[PmAdmEnterVVR] := true;
		endif;
	endforeach;
	
	commitTransaction;
	
	app.writeLog(method.qualifiedName &amp; " Creating Road Process Objects and Setting PmAdmEnterVVR complete", LogINFO);
	if _updController &lt;&gt; null then
		_updController.logEntry(" Creating Road Process Objects and Setting PmAdmEnterVVR complete") ;	
	endif;
	
	self.addScriptRun(method.name);
	
epilog

	delete pxyRoadProcess;

end;</source>
        <Parameter name="_updController" type="CnEcReleaseController"/>
    </JadeMethod>
    <JadeMethod name="createStorageExpiryDetail" id="fca108b8-cbf6-4783-95bf-3ce25e5c7693">
        <source>createStorageExpiryDetail(_updController : CnEcReleaseController);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 September 2023 navmv20 CR 58250 Task 58251: Jade - Upgrade script

*/

vars
	terminal : CM_Terminal;
	dict : Dictionary;
	iterator : Iterator;
	ti : CM_TrackedItem;
	storageExpDetl : CM_StorageExpiryDetail;
	operator : CM_Operator;
	operatorCode : String;
	transaction : CM_TITransaction;
	dateTime : TimeStamp;
	totalQuantity : Integer;
	totalWeight,
	totalVolume : Decimal[14,4];
begin
	if self.hasScriptBeenRunAtAll(method.name, _updController) then
		return;
	endif;
	
	
	app.writeLog(method.qualifiedName &amp; " Creating Storage Expiry Detail for each On Site Cargo", LogINFO);
	if _updController &lt;&gt; null then
		_updController.logEntry(" Creating Storage Expiry Detail for each On Site Cargo") ;	
	endif;
	
	beginTransaction;
	
	foreach terminal in app.myRoot.allTerminals do
		dict := terminal.getDictForTISelector(TI_SITE_ONSITE, null, false, false);
		iterator := dict.createIterator;
		while iterator.next(ti) do
			ti.allStorageExpiryDetails.purge();
			create storageExpDetl persistent;
			transaction := ti.allTransactions.findFirstReceivalTrans();
			if transaction &lt;&gt; null then
				dateTime := transaction.dateTime;
				totalQuantity := transaction.totalQuantity;
				totalWeight := transaction.totalWeight;
				totalVolume := transaction.totalVolume;
			else
				totalQuantity := 0;
				totalWeight := 0;
				totalVolume := 0;
				dateTime := null;
			endif;
			operator := ti.getReceiveOperator();
			if operator &lt;&gt; null then
				operatorCode := operator.code;
			endif;
			
			storageExpDetl.setProxy(ti.additionalStorageDays,dateTime,null,ti.getFreeDaysType(),null,ti.freeStorageDays,null,ti.getFreeStExpDTFirstTime().TimeStamp,ti.plannedDT,null,
			null,ti.getMatchingFreeStorageDetail(null),ti,operatorCode,null,ti.getFreeStorageChangeReason(),totalQuantity,totalVolume,totalWeight,ti.getChargedDaysType());
			
		endwhile;
	endforeach;
	
	commitTransaction;
	
	app.writeLog(method.qualifiedName &amp; " Creating Storage Expiry Detail for each On Site Cargo complete", LogINFO);
	if _updController &lt;&gt; null then
		_updController.logEntry(" Creating Storage Expiry Detail for each On Site Cargo complete") ;	
	endif;
	
	self.addScriptRun(method.name);
epilog

end;</source>
        <Parameter name="_updController" type="CnEcReleaseController"/>
    </JadeMethod>
    <JadeMethod name="createTrailerContentStatus" id="79af7148-3d47-4f35-887e-f765b20c8c29">
        <source>createTrailerContentStatus(_controller : CnEcReleaseController);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 August 2022	jlier1	Initial creation 54700

*/

vars
	toCreate : Integer;
	desc : String;
	abbr : String;
	aStatus : CM_ContentsStatus;
	aPStatus : CM_ContentsStatus;
begin
	if self.hasScriptBeenRunAtAll(method.name, _controller) then
		return;
	endif;

	app.writeLog(method.qualifiedName &amp; " Creating Trailer Content status objects", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry(" Creating Trailer Content status objects") ;	
	endif;

	if  app.myRoot.allContentsStatuses[TI_CONTENTS_STATUS_FULLLASHED] = null then
		//jlier1 TFS 54700 31/8/22
		toCreate := TI_CONTENTS_STATUS_FULLLASHED;	
		desc := "Full Lashed";
		abbr := "FLH";
		create aPStatus transient;
		aPStatus.setProxyForNewStructure(toCreate, White, desc, abbr);
		beginTransaction;
		create aStatus persistent;
		aStatus.setForCreate(aPStatus);
		commitTransaction;
		delete aPStatus;
	endif;
	
	if app.myRoot.allContentsStatuses[TI_CONTENTS_STATUS_PRTLOADLASH] = null then
		toCreate := TI_CONTENTS_STATUS_PRTLOADLASH;	
		desc := "Partially Loaded Lashed";
		abbr := "PLL";
		create aPStatus transient;
		aPStatus.setProxyForNewStructure(toCreate, White, desc, abbr);
		beginTransaction;
		create aStatus persistent;
		aStatus.setForCreate(aPStatus);
		commitTransaction;
		delete aPStatus;
	endif;
	
	if app.myRoot.allContentsStatuses[TI_CONTENTS_STATUS_PRTLOAD] = null then
		toCreate := TI_CONTENTS_STATUS_PRTLOAD;	
		desc := "Partially Loaded";
		abbr := "PLD";
		create aPStatus transient;
		aPStatus.setProxyForNewStructure(toCreate, White, desc, abbr);
		beginTransaction;
		create aStatus persistent;
		aStatus.setForCreate(aPStatus);
		commitTransaction;
		delete aPStatus;
	endif;
	
	app.writeLog(method.qualifiedName &amp; " Creating Trailer Content status objects complete", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry(" Creating Trailer Content status objects complete") ;	
	endif;
	
	self.addScriptRun(method.name);
	
epilog

end;</source>
