    <JadeMethod name="searchForRequest" id="4b5dd128-50ac-4636-a80a-dc9ea391dd9a">
        <updating/>
        <source>searchForRequest(_requestTxt : String) updating;
// ---------------------------------------------------------------------------
// Created:     16 April 2008 by cnwaer1
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	requestObj : CM_BulkRelease;
begin
	requestObj := self.myMobileDataAgent.getPackReleaseById(_requestTxt);

	if requestObj &lt;&gt; null then
		self.myRequest := requestObj;
	else
		app.msgBox("Release not found to be active or for packing" ,null , MsgBox_Exclamation_Mark_Icon);
		self.txt_RequestNo.text := "";
		self.myRequest := null;
	endif;
end;</source>
        <Parameter name="_requestTxt" type="String"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="d6ba9af6-b073-431a-9836-6de8f181f712">
        <updating/>
        <source>setupForm() updating, protected;
// ---------------------------------------------------------------------------
// Created:     16 April 2008 by cnwaer1
//
// Purpose:     
// ---------------------------------------------------------------------------
begin
	inheritMethod();
	
	self.lbl_CargoType.caption	:=	app.getErrorString(CM_Cargo_Type); 
	self.lbl_CargoID.caption	:=	app.getErrorString(CargoId);
	self.lbl_TareWeight.caption	:=	app.getErrorString(Tare_weight);
	self.lbl_RequestNo.caption	:=	app.getErrorString(RequestNumber);
	self.lbl_Title.caption		:=	app.getErrorString(PackingCargo);
	self.lbl_Location.caption   :=  app.getErrorString(Location);
	self.clearValues();
	self.loadComboBoxCargoType(self.cmb_CargoType, TI_CargoType_Container);
	self.txt_ContainerID.case	:=	self.txt_ContainerID.Case_Upper;
	self.txt_RequestNo.case		:=	self.txt_RequestNo.Case_Upper;
	self.cmb_CargoType.setFocus();
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="translateForm" id="c40417e4-6c85-4edb-ad34-d84deb784e3a">
