<Class name="CnEcHtmlTableRowTag" id="00dca2db-bf9e-48a1-9831-052da199b645">
    <superclass name="CnEcHtmlTableObject"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
