        <controlMethod name="Frame::mouseMove"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>splitterHorz2_mouseMove(frame: Frame input; button: Integer; shift: Integer; x: Real; y: Real) updating;

vars
	pos : Integer;
	h : Real;

begin
	if not self.splitterMoving then
		return;
	endif;

	if self.statusLine.visible then
		h := self.clientHeight - self.statusLine.height;
	else	
		h := self.clientHeight;
	endif;
	pos := (self.splitterHorz2.top + y).Integer;
	if pos &lt; (self.splitterHorz1.top + self.splitterHorz1.height + SplitSizeLimit) or
	   pos &gt; (h - SplitSizeLimit - splitterHorz1.height)
	then
		return;
	endif;

	self.drawLine(0, self.mouseMileage + 3, self.clientWidth, self.mouseMileage + 3, White);
	self.mouseMileage := pos;
	self.drawLine(0, self.mouseMileage + 3, self.clientWidth, self.mouseMileage + 3, White);
end;</source>
