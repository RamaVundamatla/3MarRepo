<Class name="CM_ObjectVolatilityConverter" id="3e5a1e89-cbe3-467a-939f-758cb8a29b1d">
    <superclass name="CM_UpgradeAgent"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>Created for PAR #23525.

This class encapsulates all the required behaviour to enable the setting/clearing of Stable Object Volatility
options on the designated list of collections determined to be the primary ones which can improve overall 
JMT performance.

Specific methods to deal with the collections for various classes are reimplementations of 

CM_Object::doObjectVolatilityConversion</text>
    <DbClassMap file="cmtrans"/>
    <Constant name="Time_Between_Commits" id="68af14c4-cf35-49c5-90aa-56527fddf24a">
        <source>4000</source>
        <type name="Decimal"/>
    </Constant>
    <PrimAttribute name="lastCommit" id="311dab9e-6245-4088-bb7a-e28613ed2cd6">
        <precision>20</precision>
        <embedded/>
        <type name="Decimal"/>
        <access>protected</access>
    </PrimAttribute>
    <PrimAttribute name="logMessages" id="5546217d-97e8-4049-8a9e-c9ea3216662c">
        <embedded/>
        <type name="Boolean"/>
    </PrimAttribute>
    <PrimAttribute name="multipleTransactions" id="1fd31ae0-d88d-4514-982e-8c4e14a075d5">
        <embedded/>
        <type name="Boolean"/>
    </PrimAttribute>
    <PrimAttribute name="newVolatility" id="972692a3-2446-463d-965f-b0e064185c5d">
        <embedded/>
        <type name="Integer"/>
    </PrimAttribute>
    <JadeMethod name="create" id="51296d54-9821-427b-9ade-02231b47132b">
        <updating/>
        <source>create() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 April 2010	cnwkpd1	PAR #23525 - System performance enhancements

*/

vars

begin
	self.newVolatility := -1;		// Ensure this is set before any work is done
	
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="createLogFile" id="06ed3705-b9ca-4e47-813d-0e8c562836ad">
        <updating/>
        <source>createLogFile() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 Jan 2011	cnwkpd1	PAR #25822 - Make logging conditional for CM_ObjectVolatilityConverter

*/

vars

begin
	// Only create a log file if logMessages is true (not by default)
	if self.logMessages then
		inheritMethod();
	endif;
	

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doChangeEntTableCollVolatility" id="ebe664fd-91dc-461b-8ea6-12077f57c7d0">
        <updating/>
        <source>doChangeEntTableCollVolatility(_indent : Integer) protected, updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 Apr 2010	cnwkpd1	PAR #23525 - System performance enhancements

*/

vars
	entTableRoot	: CM_EntTableDataRoot;
	entTableGroup	: EntTableGroup;
	entTableRow		: EntTableRow;
	entTableRowHeader : EntTableRowHeader;
	entTableView	: EntTableView;
	entTableDef		: EntTableDef;
	indent			: Integer;
	
begin
	self.logMessage("Processing Ent Table related objects", _indent);
	indent := _indent + 1;
	
	foreach entTableRoot in CM_EntTableDataRoot.instances do
		self.doChangeVolatilityOfObject(entTableRoot.allEntTableDefs, indent);
		self.doChangeVolatilityOfObject(entTableRoot.allEntTableGroups, indent);
		self.doChangeVolatilityOfObject(entTableRoot.allEntTableRowHeadersByName, indent);
		self.doChangeVolatilityOfObject(entTableRoot.allEntTableRowsByNumber, indent);
	endforeach;
	
	foreach entTableGroup in EntTableGroup.instances do
		self.doChangeVolatilityOfObject(entTableGroup.allEntTableDefsByName, indent);
		self.doChangeVolatilityOfObject(entTableGroup.allEntTableRowsByErrorRtn, indent);
		self.doChangeVolatilityOfObject(entTableGroup.allEntTableRowsByName, indent);
	endforeach;

	foreach entTableRow in EntTableRow.instances do
		self.doChangeVolatilityOfObject(entTableRow.allDependencies, indent);
		self.doChangeVolatilityOfObject(entTableRow.allEntTableDefs, indent);
		self.doChangeVolatilityOfObject(entTableRow.allEntTableViews, indent);
	endforeach;
	
	foreach entTableRowHeader in EntTableRowHeader.instances do
		self.doChangeVolatilityOfObject(entTableRowHeader.allEntTableRows, indent);
	endforeach;
	
	foreach entTableView in EntTableView.instances do
		self.doChangeVolatilityOfObject(entTableView.allEntTableRows, indent);
	endforeach;

	foreach entTableDef in EntTableDef.instances do
		self.doChangeVolatilityOfObject(entTableDef.allEntTableRows, indent);
		self.doChangeVolatilityOfObject(entTableDef.allEntTableViews, indent);
	endforeach;

	self.logMessage("Finished processing Ent Table related objects", _indent);
	
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_indent" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doChangeRootCollVolatility" id="a23a2ed5-c6fb-4070-9aa8-70319a2aa74f">
        <updating/>
        <source>doChangeRootCollVolatility(_root : CM_Root;
						   _indent : Integer) protected, updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 Apr 2010	cnwkpd1	PAR #23525 - System performance enhancements
14 Feb 2017	cnwkpd1	TFS 3369 - Push Events application
21 Mar 2018	jlgkpd1	TFS 37427 - Voyage Status Enhancements
20 Sep 2019	jlgzm1	TFS 7286 - Additional stable collections required to improve performance

*/

vars
	indent			: Integer;
	stopTable		: CM_StopsTable;
	locale			: CM_Locale;
	terminalAreaType	: CM_TerminalAreaType;
	stateObjects	: CM_StateObjectArray;
	voyageProcess	: CM_VoyageProcess;
	voyageStatus	: CM_VoyageStatus;
	
begin
	self.logMessage("Processing collections for " &amp; _root.String, _indent);
	indent := _indent + 1;
	
	self.doChangeVolatilityOfObject(_root.allAuditConfigs, indent);
	self.doChangeVolatilityOfObject(_root.allAuditedClassProperties, indent);
	self.doChangeVolatilityOfObject(_root.allAvailabilityGrades, indent);
	self.doChangeVolatilityOfObject(_root.allAvailableAvailabilityGrades, indent);
	self.doChangeVolatilityOfObject(_root.allBOLTypes, indent);
	self.doChangeVolatilityOfObject(_root.allCargoTypesById, indent);
	self.doChangeVolatilityOfObject(_root.allCodeGroupTypes, indent);
	self.doChangeVolatilityOfObject(_root.allCodeGroups, indent);
	self.doChangeVolatilityOfObject(_root.allCommodities, indent);
	self.doChangeVolatilityOfObject(_root.allCommodityGroups, indent);
	self.doChangeVolatilityOfObject(_root.allContentsStatuses, indent);
	self.doChangeVolatilityOfObject(_root.allConsigneeConsignors, indent);
	self.doChangeVolatilityOfObject(_root.allDataDumpClasses, indent);		// TFS 3369
	self.doChangeVolatilityOfObject(_root.allDrawingAttributes, indent);
	self.doChangeVolatilityOfObject(_root.allDrawingAttributesByTypePri, indent);	// 22/1/18 MAP TFS36749
	self.doChangeVolatilityOfObject(_root.allDrawingAttributesByTypeType, indent);	// 22/1/18 MAP TFS36749
	self.doChangeVolatilityOfObject(_root.allDamageDefinitionCodes, indent);
	self.doChangeVolatilityOfObject(_root.allDebtorTypes, indent);
	self.doChangeVolatilityOfObject(_root.allHazardClasses, indent);
	self.doChangeVolatilityOfObject(_root.allImexStatuses, indent);
	self.doChangeVolatilityOfObject(_root.allInterestedWarnings, indent);
	self.doChangeVolatilityOfObject(_root.allISOTypeGroups, indent);
	self.doChangeVolatilityOfObject(_root.allISOTypes, indent);
	self.doChangeVolatilityOfObject(_root.allLocales, indent);				// TFS 7286
	self.doChangeVolatilityOfObject(_root.allLocodesByShortCode, indent);	// TFS 7286
	self.doChangeVolatilityOfObject(_root.allMachineTypeGroups, indent);
	self.doChangeVolatilityOfObject(_root.allMachineTypes, indent);
	self.doChangeVolatilityOfObject(_root.allMachines, indent);
	self.doChangeVolatilityOfObject(_root.allMeasurementTypesByShortName, indent);	// TFS 7286
	self.doChangeVolatilityOfObject(_root.allOperatorGroups, indent);
	self.doChangeVolatilityOfObject(_root.allOperatorShippingLines, indent);
	self.doChangeVolatilityOfObject(_root.allOperators, indent);
	self.doChangeVolatilityOfObject(_root.allPortGroups, indent);
	self.doChangeVolatilityOfObject(_root.allPortLocodes, indent);
	self.doChangeVolatilityOfObject(_root.allPorts, indent);
	self.doChangeVolatilityOfObject(_root.allStopsTable, indent);
	self.doChangeVolatilityOfObject(_root.allTerminalAreaTypes, indent);
	self.doChangeVolatilityOfObject(_root.allTerminals, indent);
	self.doChangeVolatilityOfObject(_root.allTerminologyHdrs, indent);
	self.doChangeVolatilityOfObject(_root.allTerminologyTypes, indent);
	self.doChangeVolatilityOfObject(_root.allTransactionTypes, indent);
	self.doChangeVolatilityOfObject(_root.allUsers, indent);				// TFS 7286
	self.doChangeVolatilityOfObject(_root.allVesselCategories, indent);
	self.doChangeVolatilityOfObject(_root.allVesselCellularStructures, indent);
	self.doChangeVolatilityOfObject(_root.allVesselClasses, indent);
	self.doChangeVolatilityOfObject(_root.allVessels, indent);
	self.doChangeVolatilityOfObject(_root.allVesselTypes, indent);
	self.doChangeVolatilityOfObject(_root.allVoyageProcesses, indent);		// TFS 37427
	self.doChangeVolatilityOfObject(_root.allXLAT_Categories, indent);
	self.doChangeVolatilityOfObject(_root.allXLAT_TranslatableText, indent);
	self.doChangeVolatilityOfObject(_root.allXLAT_Translations, indent);
	self.doChangeVolatilityOfObject(_root.allXlationTables, indent);
	
	foreach stopTable in _root.allStopsTable discreteLock do
		self.doChangeVolatilityOfObject(stopTable.allStopTableTemplates, indent);
	endforeach;
	
	foreach locale in _root.allLocales discreteLock do
		self.doChangeVolatilityOfObject(locale.allTranslationKeywords, indent);
		self.doChangeVolatilityOfObject(locale.allXlatTranslationsByCatNumber, indent);
	endforeach;

	foreach terminalAreaType in _root.allTerminalAreaTypes discreteLock do
		self.doChangeVolatilityOfObject(terminalAreaType.allRTQueueMultiRulesFrom, indent);
		self.doChangeVolatilityOfObject(terminalAreaType.allRTQueueMultiRulesTo, indent);
		self.doChangeVolatilityOfObject(terminalAreaType.allTerminalAreasByTerminal, indent);
	endforeach;

	foreach voyageProcess in _root.allVoyageProcesses discreteLock do			// TFS 37427
		self.doChangeVolatilityOfObject(voyageProcess.allStatuses, indent);
		foreach voyageStatus in voyageProcess.allStatuses discreteLock do
			self.doChangeVolatilityOfObject(voyageStatus.allEventsToCreate, indent + 1);
		endforeach;
	endforeach;
	
	stateObjects := _root.getPropertyValue(CM_Root::allStateObjects.name).CM_StateObjectArray;
	self.doChangeStateObjectArrayVol(stateObjects, indent);
	
	self.logMessage("Finished processing collections for " &amp; _root.String, _indent);
	
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_root" type="CM_Root"/>
        <Parameter name="_indent" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doChangeStateObjectArrayVol" id="ce3dc478-d65f-408b-b0f8-e7fcbd8534b9">
        <updating/>
        <source>doChangeStateObjectArrayVol(_stateObjects : CM_StateObjectArray;
							_indent : Integer) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 Apr 2010	cnwkpd1	PAR #23525 - System performance enhancements

*/

vars
	stateObject		: CM_StateObject;
	indent			: Integer;
	
begin
	self.doChangeVolatilityOfObject(_stateObjects, _indent);
	indent := _indent + 1;
	
	foreach stateObject in _stateObjects discreteLock do
		self.doChangeVolatilityOfObject(stateObject.allStateData, indent);
	endforeach;
	

epilog

end;</source>
        <Parameter name="_stateObjects" type="CM_StateObjectArray"/>
        <Parameter name="_indent" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doChangeSystemVolatility" id="7b71b7ba-f784-484e-a2d4-e4d1a114d9e8">
        <updating/>
        <source>doChangeSystemVolatility(_indent : Integer) protected, updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 Apr 2010	cnwkpd1	PAR #23525 - System performance enhancements
14 Feb 2017	cnwkpd1	TFS 3369 - Push Events application
20 Sep 2019	jlgzm1	TFS 7286 - Additional stable collections required to improve performance

*/

vars
	root			: CM_Root;
	terminal		: CM_Terminal;
	vessel			: CM_Vessel;
	isoTypeGroup 	: CM_ISOTypeGroup;
	ddClass			: CM_DataDumpClass;
	user			: CM_User; 	// TFS 7286
	
begin
	if self.newVolatility &lt;&gt; Volatility_Volatile and
	   self.newVolatility &lt;&gt; Volatility_Stable then
		self.logMessage("New Volatility is not set, exiting", _indent);
		return;
	endif;
	
	root := CM_Root.firstInstance();
	if root = null then
		self.logMessage("No CM_Root object found, exiting", _indent);
		return;
	endif;
	
	self.logMessage("Changing System Collection Volatility to " &amp; self.newVolatility.String, _indent);
	
	self.doChangeRootCollVolatility(root, _indent);
	
	foreach terminal in root.allTerminals discreteLock do
		terminal.doObjectVolatilityConversion(self, _indent);
	endforeach;
	
	foreach vessel in root.allVessels discreteLock do
		vessel.doObjectVolatilityConversion(self, _indent);
	endforeach;

	foreach isoTypeGroup in root.allISOTypeGroups discreteLock do
		isoTypeGroup.doObjectVolatilityConversion(self, _indent);
	endforeach;
	
	foreach ddClass in root.allDataDumpClasses discreteLock do			// TFS 3369
		ddClass.doObjectVolatilityConversion(self, _indent);
	endforeach;
	
	foreach user in root.allUsers discreteLock do			// TFS 7286
		user.doObjectVolatilityConversion(self, _indent);	// TFS 7286
	endforeach;
		
	self.doChangeEntTableCollVolatility(_indent);
	
	self.doChangeXLATCollVolatility(_indent);
	
	// Store current stability setting for future new objects being created
	root.setUseStableObjects(self.newVolatility = Volatility_Stable);
	
	self.logMessage("Finished changing System Collection Volatility to " &amp; self.newVolatility.String, _indent);
	
		
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_indent" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doChangeVolatilityOfObject" id="d353a769-fb6e-4b25-b78c-bb745fc9801e">
        <updating/>
        <source>doChangeVolatilityOfObject(_obj : Object;
						   _indent : Integer) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 Apr 2010	cnwkpd1	PAR #23525 - System performance enhancements

*/

vars
	
begin
	self.logMessage("Setting volatility of " &amp; _obj.String &amp; " to " &amp; self.newVolatility.String, _indent);
	self.changeObjectVolatility(_obj, self.newVolatility, false);
	
	// If using multiple commits, then check here if we need to commit
	if self.multipleTransactions then
		if (app.relativeMachineTime() - self.lastCommit) &gt; self.Time_Between_Commits then
			commitTransaction;
			beginTransaction;
			self.lastCommit := app.relativeMachineTime();
		endif;
	endif;
	
	
epilog

end;</source>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_indent" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doChangeXLATCollVolatility" id="69cd69b8-3aef-44b3-b3c6-ab71e01ca4d8">
        <updating/>
        <source>doChangeXLATCollVolatility(_indent : Integer) protected, updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 April 2010	cnwkpd1	PAR #23525 - System performance enhancements

*/

vars
	objects			: ObjectArray;
	iter			: Iterator;
	xlat			: XLAT_TranslatableText;
	indent			: Integer;

begin
	create objects transient;
	XLAT_TranslatableText.allInstances(objects, 0, true);
	
	self.logMessage("Processing collections for " &amp; objects.size.String &amp; " " &amp; XLAT_TranslatableText.name &amp; " instances", _indent);

	indent := _indent + 1;
	
	iter := objects.createIterator();
	while iter.next(xlat) do
		self.doChangeVolatilityOfObject(xlat.allTextByLocale, indent);
	endwhile;

	self.logMessage("Finished processing collections for " &amp; objects.size.String &amp; " " &amp; XLAT_TranslatableText.name &amp; " instances", _indent);


epilog
	delete objects;
	delete iter;
	
end;</source>
        <access>protected</access>
        <Parameter name="_indent" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getLogFileName" id="147a4566-fd0f-4aa9-bd8f-4346aa2a4533">
        <source>getLogFileName(): String protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
23 April 2010	cnwkpd1	PAR #23525 - System performance enhancements

*/

vars

begin
	return global.cnGetServerLogPath &amp; "/" &amp; 
		   self.class.name &amp; "_" &amp; 
		   app.actualTimeServer.getNumeralString &amp; "_" &amp;
		   self.getInstanceIdForObject(process).String &amp;
		   ".log";
	
	
epilog

end;</source>
        <access>protected</access>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="makeSystemObjectsStable" id="3eba7b03-7f8f-4f1c-b960-092b3e54b0d0">
        <updating/>
        <source>makeSystemObjectsStable() updating;

/*

Purpose:			Make all the designated objects in the system stable.  Will be called from the
					standard upgrade, and can be called from a JadeScript if required, while the
					system is running.

Parameters:			None

Return Value:		None


Date		Who		Reason
09 Apr 2010	cnwkpd1	PAR #23525 - System performance enhancements

*/

vars

begin
	self.newVolatility := Volatility_Stable;
	self.multipleTransactions := true;
	
	beginTransaction;
	self.doChangeSystemVolatility(null);
	commitTransaction;
	
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="makeSystemObjectsVolatile" id="46008ff5-1668-48ed-bf2f-902bb41d5835">
        <updating/>
        <source>makeSystemObjectsVolatile() updating;

/*

Purpose:			Make all the designated objects in the system volative.  Can be called from a 
					JadeScript if required, while the system is running, to undo the effect of making
					all the designated objects stable.

Parameters:			None

Return Value:		None


Date		Who		Reason
09 Apr 2010	cnwkpd1	PAR #23525 - System performance enhancements

*/

vars

begin
	self.newVolatility := Volatility_Volatile;
	self.multipleTransactions := true;
	
	beginTransaction;
	self.doChangeSystemVolatility(null);
	commitTransaction;
	
	
epilog

end;</source>
    </JadeMethod>
</Class>
