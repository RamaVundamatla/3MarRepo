    <JadeMethod name="showModalFrame" id="ce0ac3c2-675b-4348-bf41-70d0464a8f63">
        <source>showModalFrame() protected;
// ---------------------------------------------------------------------------
// Created:     15 May 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars

	scalerCode		: String;
	cntrl			: Control;
	idx				: Integer;

begin

	foreach idx in 1 to self.controlCount do
	    cntrl := controls(idx);
		if not cntrl.isKindOf(CMUI_SplitContainer) then
			cntrl.enabled := false;
		endif;
	endforeach;
	
	self.frmEditDtl.parent := self;
	self.frmEditDtl.top := 155;
	
	self.frmEditDtl.parent.enabled := true;
	self.frmEditDtl.enabled := true;
	self.frmEditDtl.left := (self.width / 2) - (self.frmEditDtl.width /2);
	self.frmEditDtl.visible := true;
	self.lblEntDetail.enabled := true;
	
	self.btnCancelDtl.enabled := true;
	self.btnSaveDtl.enabled := true;
	self.tblEntDetail.enabled := true;
	self.cmbScaler.enabled := true;

end;</source>
        <access>protected</access>
