    <JadeMethod name="btnAddBerthPref_click" id="b0914f79-7238-499d-bd03-d6f08d6d6997">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnAddBerthPref_click(btn: Button input) updating;
//--------------------------------------------------
// Created:	20 September 2005 By: cnwgd1
//--------------------------------------------------
vars

begin
	if self.mode &lt;&gt; self.Mode_Update
	and self.mode &lt;&gt; self.Mode_Add then
		return;
	endif;
	self.loadBerthPrefRow(null);
	self.tblPrefBerth.setFocus();
	self.tblPrefBerth.column := 1;
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnBayDefinition_click" id="f1692675-39e3-4479-937f-897126c81c6d">
