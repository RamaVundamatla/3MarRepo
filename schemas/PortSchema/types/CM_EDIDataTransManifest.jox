    <JadeMethod name="isVoyageCutOffsValid" id="fe649537-d65a-41e7-8662-95bb05077a39">
        <source>isVoyageCutOffsValid(_voyage : CM_Voyage):Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 August 2023	navsp1	Initial creation TFS ChangeRequest 59751: EUP | Manifest and Calloff - AutoDB Load config

*/

vars

