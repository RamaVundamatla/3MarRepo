    <JadeMethod name="doYAIMEXConfigEdit" id="889ea898-2e1c-47a2-88af-3a701d29875f">
        <updating/>
        <source>doYAIMEXConfigEdit( _imexStatus : Integer ) updating;
/*

Purpose:		Display form to edit defaults for IMEX

Parameters:			

Return Value:		


Date			Who		Reason
29 August 2008	consw1	Initial creation

*/

vars
	imexConfig 	: CM_YAIMEXConfig;
	imexStatus 	: CM_IMEXStatus;
	theForm 	: CMUI_YAIMEXConfigForm;
	
	
begin
	imexStatus := app.myRoot.allImexStatuses[_imexStatus];
	imexConfig := self.getRealYAConfig.allYAIMEXConfigs[_imexStatus];
	
	if imexStatus = null or imexConfig = null then
		return;
	endif;

	theForm := app.loadForm(CMUI_YAIMEXConfigForm, CMUI_Assistant, false, false, true, self.myTerminal, null).CMUI_YAIMEXConfigForm;
	if theForm = null then
		return;
	endif;

	theForm.set( imexConfig );
	theForm.setParentForm(self);
	theForm.showModal();
	
	self.populateOpCriteria();
	
epilog
	delete theForm;
end;</source>
        <Parameter name="_imexStatus" type="Integer"/>
    </JadeMethod>
