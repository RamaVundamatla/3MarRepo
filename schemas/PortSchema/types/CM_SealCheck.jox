    <JadeMethod name="getSealCheckDetailForSealType" id="65de13b3-8e6d-4786-86f5-a12b13130de4">
        <source>getSealCheckDetailForSealType( _sealType : String) : CM_SealCheckDetail;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 September 2010	cnwndl1	Initial creation

*/

vars

	detail : CM_SealCheckDetail;
	
begin

	foreach detail in self.allSealCheckDetails do
		if detail.sealType = _sealType then
			return detail;
		endif;
	endforeach;
	
	return null;

epilog

end;</source>
        <Parameter name="_sealType" type="String"/>
        <ReturnType type="CM_SealCheckDetail"/>
    </JadeMethod>
    <JadeMethod name="getSealCheckDetails" id="1463af9a-1eee-4a96-8417-122b36959474">
        <source>getSealCheckDetails() : String protected;
// Jan 2012 CCMS 1262 Transaction Enquiry, factor out this code
vars

	str : String;
	sealCheckDetail : CM_SealCheckDetail;

begin

	// get the type of check.  (Its the same for each one,
	// so just use the first one... )
	if not self.allSealCheckDetails.isEmpty then
		sealCheckDetail := self.allSealCheckDetails.first();
		if str = null then
			str := sealCheckDetail.getSealCheckTypeString;
		else
			str := str &amp; ", " &amp; sealCheckDetail.getSealCheckTypeString;
		endif;
	endif;
	
	// now get the specific detail for each one.
	foreach sealCheckDetail in self.allSealCheckDetails do
		if str = null then
			str := sealCheckDetail.displayDetails;
		else
			str := str &amp; ", " &amp; sealCheckDetail.displayDetails;
		endif;
	endforeach;
	
	return str;

epilog

end;</source>
        <access>protected</access>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getSealNumbersArray" id="484efd83-fb49-4f7a-891c-53b7aae28ec3">
        <source>getSealNumbersArray(_sealType : String; _theSealNumbers: StringArray input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 Sep 2018	jlgsl4	TFS 39801 - SNO - Codeco needs 'at Receive' details
*/

vars
	sealCheckDetail : CM_SealCheckDetail;
begin
	foreach sealCheckDetail in self.allSealCheckDetails do
		if sealCheckDetail.sealType = _sealType then
			sealCheckDetail.sealAfter.getTokensForDelimiter(",", _theSealNumbers);
			break;
		endif;
	endforeach;
epilog

end;
</source>
        <Parameter name="_sealType" type="String"/>
        <Parameter name="_theSealNumbers" type="StringArray" usage="input"/>
    </JadeMethod>
