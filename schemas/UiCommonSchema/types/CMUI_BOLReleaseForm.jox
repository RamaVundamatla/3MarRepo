    <JadeMethod name="doDeleteRelease" id="4d0f6ce7-152f-441b-903e-caf5cc95fdcb">
        <updating/>
        <source>doDeleteRelease(_release : CM_BulkRelease) updating, protected;
/*
----------   ----------  --------------------------------------------------
Created:	28 March 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	result		: Integer;
begin
	if _release = null then
		return;
	endif;
	
	if app.msgBox(app.getErrorString1(Lit_Confirm_Delete, 'release ' &amp; _release.code),app.getErrorString(Are_You_Sure), MsgBox_Yes_No) &lt;&gt; MsgBox_Return_Yes then
		return;
	endif;
	
	while true do
		app.myTrxDA.trxDeleteBulkRelease(_release, app.myPassport);
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			break;
		else
			result := app.showErrorWarningDialog(self.caption, app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
		endif;
		return;
	endwhile;


end;


</source>
        <access>protected</access>
        <Parameter name="_release" type="CM_BulkRelease"/>
    </JadeMethod>
    <JadeMethod name="doPrintDockDeliveryReceipt" id="6d1b4d5e-e11f-4006-a824-d3b7834e0d9d">
        <updating/>
        <source>doPrintDockDeliveryReceipt() updating;
vars
	dialog	: CMUI_ReceiptCopies;
	obj : Object;
begin
	obj := self.myCurrentBOL;
	if obj = null then
		obj := self.tblReleases.accessRow(self.tblReleases.row).itemObject;
	endif;
	if obj = null then
		app.msgBox('Please select a Release Record or Bill Of Lading to print.', 'Select Item', MsgBox_OK_Only+MsgBox_Information_Icon);	
		return;
	endif;	
		
	create dialog transient;
	dialog.init(true, self.myTerminal.getConfig(GateReceiptCopies).Integer);
	dialog.centreWindow();
	
	if dialog.showModal &lt;&gt; MsgBox_Return_OK then
  		return;		
  	endif;

	if dialog.copies &gt; 1 then
		return;
	endif;

	app.mousePointer := MousePointer_HourGlass;		

	self.printDeliveryReceipt(obj, dialog.copies, dialog.printPreview);

epilog
	delete dialog;
	app.mousePointer := MousePointer_Default;
end;</source>
    </JadeMethod>
    <JadeMethod name="doPrintFromVisitRecord" id="518e6391-1807-40be-be52-4f15ce709bb2">
        <updating/>
        <source>doPrintFromVisitRecord() updating;
//-----------------------------------------------------------------------
//	Created:	15 May 2006 Lorcan Bolster  (cnwlb1/lorcan)
//-----------------------------------------------------------------------

vars
	job 	: CM_RoadJob;
	dialog	: CMUI_ReceiptCopies;
	obj		: Object;
	br		: CM_BulkRelease;
	ti		: CM_TrackedItem;
	vvr		: CM_VehicleVisitRecord;

begin
//	obj := self.myCurrentBOL;
	if obj = null then
		obj := self.tblReleases.accessRow(self.tblReleases.row).itemObject;
	endif;
	if obj = null then
		app.msgBox('Please select a Release Record or Bill Of Lading to print.', 'Select Item', MsgBox_OK_Only+MsgBox_Information_Icon);	
		return;
	endif;	
	
	create dialog transient;
	dialog.init(true, self.myTerminal.getConfig(GateReceiptCopies).Integer);
	dialog.centreWindow();
	
	if dialog.showModal &lt;&gt; MsgBox_Return_OK then
  		return;		
  	endif;

	if dialog.copies &lt; 1 then
		return;
	endif;

	app.mousePointer := MousePointer_HourGlass;		

	if CM_BulkRelease.hasInstance(obj) then
		br := obj.CM_BulkRelease;			// PAR 22388 - sort out references to CM_TrackedItem.allVisitRecords
		ti := br.allTrackedItemsReleased.first;
		if ti &lt;&gt; null then
			vvr	:= ti.getVehicleVisitRelease();
			if vvr &lt;&gt; null then
				//vvr.printReceipt (dialog.copies, dialog.printPreview, self.myTerminal, self.myTerminal.getRoadReceiptReport(), null, null);//par 13812
				//12 Dec 2013	NDL	Par 33184
				vvr.printRoadReceipt(	dialog.copies,	//_copies : Integer;
										dialog.printPreview,	//_printPreview : Boolean;
										null
										);
			endif;
		endif;
		/*
		if obj.CM_BulkRelease.allTrackedItemsReleased &lt;&gt; null and obj.CM_BulkRelease.allTrackedItemsReleased.size &gt; 0 then
			//obj.CM_BulkRelease.allTrackedItemsReleased.first.allVisitRecords.first.printReceipt (dialog.copies, dialog.printPreview, self.myTerminal, self.myTerminal.getConfig(GateRoadJobReceipt).String, null);
			obj.CM_BulkRelease.allTrackedItemsReleased.first.allVisitRecords.first.printReceipt (dialog.copies, dialog.printPreview, self.myTerminal, self.myTerminal.getRoadReceiptReport(), null);//par 13812
		endif;
		*/
	endif;
		

epilog
	delete dialog;
	app.mousePointer := MousePointer_Default;

end;</source>
    </JadeMethod>
    <JadeMethod name="doRefresh" id="61482c9f-196e-4b38-b0ab-ab7de9bc86c8">
        <updating/>
        <source>doRefresh() updating, protected;
//--------------------------------------------------
// Created:	10 February 2006 By: cnwgd1
//--------------------------------------------------
vars
	tmpBOL : CM_BOLIn;
	voyage : CM_Voyage;
begin
	
	inheritMethod();
	self.tblReleases.clearAllSelected();
	self.clearNotableObjects();

	tmpBOL := self.myCurrentBOL;
	voyage := self.myCurrentVoyage;
	if self.isFirstActivateComplete then
		self.setMyCurrentVoyage(null);
	endif;

	self.cmbVoyage.isDisplayByVesselName := self.myTerminal.getConfig(VesselComboByName).Boolean;
	self.cmbVoyage.initialise(false);	
	self.cmbBol.clear();
	
	if voyage &lt;&gt; null then
		self.cmbVoyage.setObject(voyage);
		self.myCurrentVoyage := voyage;		
	else
		self.cmbVoyage.setFocus();
	endif;
	
	//self.loadComboBOL(self.cmbBol, tmpBOL, self.cmbVoyage.myObject.CM_Voyage);
	self.loadCmbBolFromVoyageBOLs(self.cmbBol, tmpBOL, self.cmbVoyage.myObject.CM_Voyage); // CCMS SFW1039 PAR18889 - US Customs &amp; Border Protection messaging changes.

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doResize" id="b4caa4ea-3866-4096-ab6b-139e4a66b35c">
        <updating/>
        <source>doResize() updating;

vars
	tmpTop : Real;
begin
	inheritMethod();
	self.grpBol.top := self.frmToolbar.height;
	self.grpBol.centreHorizontallyInParent;
	tmpTop := self.grpBol.top + self.grpBol.height;
	self.frmMainDkc.move(0, tmpTop, self.clientWidth, self.clientHeight - tmpTop);
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doTblDataDragTrackedItem" id="b034673a-eaff-4cb0-97b2-e97c16fc5d5f">
        <source>doTblDataDragTrackedItem() protected;
/*
----------   ----------  --------------------------------------------------
Created:	29 March 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	theTI	: CM_TrackedItem;
	pic		: Picture;
begin

	theTI := self.tblData.accessRow(self.tblData.row).itemObject.CM_TrackedItem;
	if theTI = null then
		return;
	endif;

	if theTI.site &lt;&gt; TI_SITE_ONSITE then
		app.msgBox('The cargo item you are attempting to drag and drop is not currently onsite.','Cannot drag and drop', MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
		
	app.myDraggedTrackedItem := theTI;
	self.tblData.dragMode := DragMode_Drag;

	create pic transient;
	self.setPictureDragCursor(pic);
	if pic.picture &lt;&gt; null then
		self.tblData.dragCursor := pic.picture;
	endif;

epilog
	delete pic;
	
end;


</source>
        <access>protected</access>
    </JadeMethod>
