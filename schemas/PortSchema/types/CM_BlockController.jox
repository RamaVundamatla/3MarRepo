    <JadeMethod name="isRailTransferArea" id="d5270495-b3fd-4371-9eff-8a08271d475a">
        <source>isRailTransferArea(): Boolean;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 29/10/2019	jlgdap1		Initial creation TFS 47079 PRP Release Qty Issue
//
vars
	ta : CM_TerminalArea;

begin
	if self.myTerminalArea.isKindOf(CM_YardTransferArea) then
		foreach ta in self.myTerminalArea.CM_YardTransferArea.allTerminalAreas discreteLock do
			if ta.isRail then
				return true;
			endif;
		endforeach;
	endif;
	
	return false;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
