        <controlMethod name="CMUI_ComboBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbTradeGroup_click(combobox: ComboBox input) updating;
// ---------------------------------------------------------------------------
// Created:		September 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

	lgd : CM_LineGroupDebtor;
	spg : CM_ShipPortGroup;

begin

	self.cmbTradeDebtor.clear;
	spg := self.cmbTradeGroup.itemObject[self.cmbTradeGroup.listIndex].CM_ShipPortGroup;
	self.myCurrentShipPortGroup := spg;
	foreach lgd in spg.lineGroupDebtors do
		self.cmbTradeDebtor.addItem(lgd.code[9:lgd.code.length-8]);
		self.cmbTradeDebtor.itemObject[self.cmbTradeDebtor.newIndex] := lgd;
	endforeach;


end;</source>
