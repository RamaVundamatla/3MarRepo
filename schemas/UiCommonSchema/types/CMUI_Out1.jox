    <JadeMethod name="getDiPic" id="f18cfd02-ce40-4551-87c9-c3e149854b99">
        <source>getDiPic(_value : Integer) : Binary;
// ---------------------------------------------------------------------------
// Created:		29 March 2006  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	if _value = 1 then
		return self.picDi1.picture;
	elseif _value = 2 then
		return self.picDi2.picture;
	elseif _value = 3 then
		return self.picDi3.picture;
	elseif _value = 4 then
		return self.picDi4.picture;
	elseif _value = 5 then
		return self.picDi5.picture;
	elseif _value = 6 then
		return self.picDi6.picture;
	endif;
end;</source>
        <Parameter name="_value" type="Integer"/>
        <ReturnType type="Binary"/>
    </JadeMethod>
    <JadeMethod name="getRandomNumber" id="83da5f25-40ec-413b-a13a-123dffc1db36">
        <source>getRandomNumber() : Integer;
// ---------------------------------------------------------------------------
// Created:		24 March 2006  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	dice : Integer;
begin
	while true do
		dice := app.random(6);
		if dice &gt; 0 then break;endif;
	endwhile;

	return dice;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getResults" id="cf8bf98d-a46e-483c-802b-4e4946959af9">
        <source>getResults();
// ---------------------------------------------------------------------------
// Created:		28 March 2006  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	result : Integer;
begin
	// ### CHANCE
	if not self.allItemsLocked[self.Index_Item_Chance] then
		if self.hasResultChance(result) then
			self.lblChanceValue.caption := result.String;
			self.lblChanceValue.foreColor := Green;
		else
			self.lblChanceValue.caption := "0";
			self.lblChanceValue.foreColor := Green;
		endif;
	endif;
	// ### FULL HOUSE
	if not self.allItemsLocked[self.Index_Item_FullHouse] then
		if self.hasResultsFullHouse() then
			self.lblFullHseValue.caption := "25";
			self.lblFullHseValue.foreColor := Green;
		else
			self.lblFullHseValue.caption := "0";
			self.lblFullHseValue.foreColor := Green;
		endif;
	endif;	
	// ### LONG STRAIGHT
	if not self.allItemsLocked[self.Index_Item_StraightLong] then
		if self.hasResultLongStraight() then
			self.lblStrLongValue.caption := "40";
			self.lblStrLongValue.foreColor := Green;
		else
			self.lblStrLongValue.caption := "0";
			self.lblStrLongValue.foreColor := Green;
		endif;
	endif;
	// ### SHORT STRAIGHT
	if not self.allItemsLocked[self.Index_Item_StraightShort] then
		if self.hasResultShortStraight() then
			self.lblStrSmallValue.caption := "30";
			self.lblStrSmallValue.foreColor := Green;
		else
			self.lblStrSmallValue.caption := "0";
			self.lblStrSmallValue.foreColor := Green;
		endif;
	endif;
	if not self.allItemsLocked[self.Index_Item_AllOnes] then
		if self.hasResultAllSame(result,1) then
			self.lblAllOnesValue.caption := result.String;
			self.lblAllOnesValue.foreColor := Green;
		else
			self.lblAllOnesValue.caption := "0";
			self.lblAllOnesValue.foreColor := Green;
		endif;
	endif;
	if not self.allItemsLocked[self.Index_Item_AllTwos] then
		if self.hasResultAllSame(result,2) then
			self.lblAllTwosValue.caption := result.String;
			self.lblAllTwosValue.foreColor := Green;
		else
			self.lblAllTwosValue.caption := "0";
			self.lblAllTwosValue.foreColor := Green;
		endif;
	endif;
	if not self.allItemsLocked[self.Index_Item_AllThrees] then
		if self.hasResultAllSame(result,3) then
			self.lblAllThreeValue.caption := result.String;
			self.lblAllThreeValue.foreColor := Green;
		else
			self.lblAllThreeValue.caption := "0";
			self.lblAllThreeValue.foreColor := Green;
		endif;
	endif;
	if not self.allItemsLocked[self.Index_Item_AllFours] then
		if self.hasResultAllSame(result,4) then
			self.lblAllFoursValue.caption := result.String;
			self.lblAllFoursValue.foreColor := Green;
		else
			self.lblAllFoursValue.caption := "0";
			self.lblAllFoursValue.foreColor := Green;
		endif;
	endif;
	if not self.allItemsLocked[self.Index_Item_AllFives] then
		if self.hasResultAllSame(result,5) then
			self.lblAllFivesValue.caption := result.String;
			self.lblAllFivesValue.foreColor := Green;
		else
			self.lblAllFivesValue.caption := "0";
			self.lblAllFivesValue.foreColor := Green;
		endif;
	endif;
	if not self.allItemsLocked[self.Index_Item_AllSixes] then
		if self.hasResultAllSame(result,6) then
			self.lblAllSixValue.caption := result.String;
			self.lblAllSixValue.foreColor := Green;
		else
			self.lblAllSixValue.caption := "0";
			self.lblAllSixValue.foreColor := Green;
		endif;
	endif;
	// ### THREE OF A KIND
	if not self.allItemsLocked[self.Index_Item_OfAKind3] then
		if self.hasResultXOfAKind(result,3) then
			self.lblKind3Value.caption := result.String;
			self.lblKind3Value.foreColor := Green;
		else
			self.lblKind3Value.caption := "0";
			self.lblKind3Value.foreColor := Green;
		endif;
	endif;

	// ### FOUR OF A KIND
	if not self.allItemsLocked[self.Index_Item_OfAKind4] then
		if self.hasResultXOfAKind(result,4) then
			self.lblKind4Value.caption := result.String;
			self.lblKind4Value.foreColor := Green;
		else
			self.lblKind4Value.caption := "0";
			self.lblKind4Value.foreColor := Green;
		endif;
	endif;
	// ### YAHTZEE
	if not self.allItemsLocked[self.Index_Item_OfAKind5] then
		if self.hasResultXOfAKind(result,5) then
			self.lblKind5Value.caption := "50";
			self.lblKind5Value.foreColor := Red;
		else
			self.lblKind5Value.caption := "0";
			self.lblKind5Value.foreColor := Green;
		endif;
	endif;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="hasResultAllSame" id="fba1c9fb-c2b7-49af-899d-2dc022902810">
        <source>hasResultAllSame(_result : Integer io;_value : Integer) : Boolean;
// ---------------------------------------------------------------------------
// Created:		28 March 2006  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	idx : Integer;
	
	allSame : Boolean;
begin
	_result := 0;
	foreach idx in 1 to 5 do
		if self.allValues[idx] = _value then
			allSame := true;
			_result := _result + _value;
		endif;
	endforeach;
	
	return allSame;
end;</source>
        <Parameter name="_result" type="Integer" usage="io"/>
        <Parameter name="_value" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="hasResultChance" id="5c486d07-cd60-4ebc-84d2-c44a223aabc9">
        <source>hasResultChance(_result : Integer io) : Boolean;
// ---------------------------------------------------------------------------
// Created:		28 March 2006  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	idx : Integer;
	
	allSame : Boolean;
begin
	_result := 0;
	foreach idx in 1 to 5 do
		_result := _result + self.allValues[idx];
	endforeach;
	
	return true;
end;</source>
        <Parameter name="_result" type="Integer" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="hasResultLongStraight" id="5b364c38-90d2-43b5-ab97-c335fe28b371">
        <source>hasResultLongStraight() : Boolean;
// ---------------------------------------------------------------------------
// Created:		28 March 2006  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	idx : Integer;
	allSame : Boolean;
begin
	if self.hasResultStraight(1,5,0) then
		return true;
	endif;

	if self.hasResultStraight(2,6,1) then
		return true;
	endif;

	return false;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="hasResultShortStraight" id="671140dc-e943-46da-8b32-0ef8dbf9a365">
        <source>hasResultShortStraight() : Boolean;
// ---------------------------------------------------------------------------
// Created:		28 March 2006  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	idx : Integer;
	allSame : Boolean;
begin
	if self.hasResultStraight(1,4,0) then
		return true;
	endif;

	if self.hasResultStraight(2,5,1) then
		return true;
	endif;

	if self.hasResultStraight(2,5,0) then
		return true;
	endif;

	if self.hasResultStraight(3,6,2) then
		return true;
	endif;
	if self.hasResultStraight(3,6,1) then
		return true;
	endif;
	if self.hasResultStraight(3,6,0) then
		return true;
	endif;

	return false;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="hasResultStraight" id="44f2c2a6-12a3-4601-b515-ca61d0c8e532">
        <source>hasResultStraight(_from, _to, _offset : Integer) : Boolean;
// ---------------------------------------------------------------------------
// Created:		28 March 2006  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	idx : Integer;
	allSame : Boolean;
begin
	self.allTmpValues.clear;
	self.copyValuesNoDuplicates();
//	self.allValues.copy(self.allTmpValues);
	self.allTmpValues.cnEcSort(false);
	
	// ### TEST 1 to 5
	foreach idx in _from to _to do
		if idx = self.allTmpValues[idx - _offset] then
			allSame := true;
		else
			allSame := false;
			break;
		endif;
	endforeach;
	
	if allSame then
		return true;
	endif;
	
	return false;
end;</source>
        <Parameter name="_from" type="Integer"/>
        <Parameter name="_to" type="Integer"/>
        <Parameter name="_offset" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="hasResultXOfAKind" id="9ba6c05c-e61a-4ca5-b351-30ace66e9030">
        <source>hasResultXOfAKind(_result : Integer io;_value : Integer) : Boolean;
// ---------------------------------------------------------------------------
// Created:		28 March 2006  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	theValue,idx, sub, num : Integer;
	
	allSame : Boolean;
begin
	_result := 0;
	foreach sub in 1 to 6 do // VALUES
		foreach idx in 1 to 5 do // DICE
			theValue := self.allValues[idx];
			if theValue = sub then
				num := num + 1;
				_result := _result + theValue;
			endif;
		endforeach;
		if num &gt;= _value then
			return true;
		endif;
		num := 0;
	endforeach;
	
	return false;
end;</source>
        <Parameter name="_result" type="Integer" usage="io"/>
        <Parameter name="_value" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="hasResultsFullHouse" id="60f2639a-0cc0-4f4e-929b-a6f675b49b2a">
        <source>hasResultsFullHouse() : Boolean;
// ---------------------------------------------------------------------------
// Created:		28 March 2006  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	theValue,idx, sub, num : Integer;
	
	allSame, has3, has2 : Boolean;
begin
	foreach sub in 1 to 6 do // VALUES
		num := 0;
		foreach idx in 1 to 5 do // DICE
			theValue := self.allValues[idx];
			if theValue = sub then
				num := num + 1;
			endif;
		endforeach;
		if num = 3 and not has3 then
			has3 := true;
		endif;
		if num = 2 and not has2 then
			has2 := true;
		endif;
	endforeach;
	
	return has2 and has3;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
