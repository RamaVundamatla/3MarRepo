    <JadeMethod name="getMatchingEDITIsForVoyageCode" id="90d191e1-9c5f-4447-b092-79e06026d7c7">
        <source>getMatchingEDITIsForVoyageCode(_voyageCode	: String;
								_ediTIset 	: CM_EDITISet input;
								_excludeDeparted : Boolean
								);
	
/*
Purpose:	This method will return a collection of the EDITrackedItems that
			have any thing to do with a voyage starting with the supplied VoyageCode.
			Any invalid object references with be handled by ignoring them.
	
Date			Who		Reason
10 June 2010	cnwrl1	Initial creation as part of PAR 24299 - SFW 1118 EDI Form to allow searching of EDI file by Container / Voyage
02 Nov 2015		cnwer1	PAR 37090 added parameter to exclude edi tis that are for a departed voyage
*/
	
vars
	invalid			: Boolean;
	voyageLength	: Integer;
	iEdition		: Integer;
	altVoyageCode,
	voyageCodeStr	: String;
	ediTrackedItem	: CM_EDITrackedItem;
	iter1			: Iterator;
	term : CM_Terminal;
	voyage : CM_Voyage;
begin
	on Exception do app.handleDeletedObject( exception, ediTrackedItem, invalid );
	_ediTIset.clear();
	
	voyageCodeStr	:= _voyageCode.toUpper();
	voyageLength	:= voyageCodeStr.length();
	iter1			:= self.allEDITrackedItemsByVoyageCode.createIterator;
	self.allEDITrackedItemsByVoyageCode.startKeyGeq( voyageCodeStr, null, iter1 );
	
	while iter1.next( ediTrackedItem ) do 
		// Derefernce the object to see if the Exceptionhandler will be triggered once!
		iEdition	:= ediTrackedItem.edition();
		if invalid then
			// OK so exception handler has been processed, ignore this instance and continue
			invalid	:= false;				// reset for next time around.
			continue;
		endif;
	
		// attempt to match against the special voyage cases.
		if ediTrackedItem.isKindOf( CM_EDIBookingHeaderTI ) then
			//epr par 37090 2/11/15
			altVoyageCode:=ediTrackedItem.CM_EDIBookingHeaderTI.getRawVoyageCode();
			if self.checkEDITIVoyageCodeMatches(voyageCodeStr,altVoyageCode,_excludeDeparted) then
				_ediTIset.addNoDuplicates( ediTrackedItem, false );
				continue;
			endif;
			
			altVoyageCode:=ediTrackedItem.CM_EDIBookingHeaderTI.getTranshipOriginalVoyage();
			if self.checkEDITIVoyageCodeMatches(voyageCodeStr,altVoyageCode,_excludeDeparted) then
				_ediTIset.addNoDuplicates( ediTrackedItem, false );
				continue;
			endif;
			
		elseif ediTrackedItem.isKindOf( CM_EDIBookingRefTI ) then
			altVoyageCode:=ediTrackedItem.CM_EDIBookingRefTI.getRawVoyageCode();
			if self.checkEDITIVoyageCodeMatches(voyageCodeStr,altVoyageCode,_excludeDeparted) then
				_ediTIset.addNoDuplicates( ediTrackedItem, false );
				continue;
			endif;
			
		elseif ediTrackedItem.isKindOf( CM_EDIPrenoteTI ) then
			altVoyageCode:=ediTrackedItem.CM_EDIPrenoteTI.getConsignorVoyage();
			if self.checkEDITIVoyageCodeMatches(voyageCodeStr,altVoyageCode,_excludeDeparted) then
				_ediTIset.addNoDuplicates( ediTrackedItem, false );
				continue;
			endif;
		elseif ediTrackedItem.isKindOf( CM_EDIReleaseRequestTI ) then
			altVoyageCode:=ediTrackedItem.CM_EDIReleaseRequestTI.getConsignorVoyage();
			if self.checkEDITIVoyageCodeMatches(voyageCodeStr,altVoyageCode,_excludeDeparted) then
				_ediTIset.addNoDuplicates( ediTrackedItem, false );
				continue;
			endif;
			
		elseif ediTrackedItem.isKindOf( CM_EDITranshipTI ) then
			altVoyageCode:=ediTrackedItem.CM_EDITranshipTI.getExportVoyageCode();
			if self.checkEDITIVoyageCodeMatches(voyageCodeStr,altVoyageCode,_excludeDeparted) then
				_ediTIset.addNoDuplicates( ediTrackedItem, false );
				continue;
			endif;
			
		elseif ediTrackedItem.isKindOf( CM_EDIVoyageTI ) then
			altVoyageCode:=ediTrackedItem.CM_EDIVoyageTI.getInwardCode();
			if self.checkEDITIVoyageCodeMatches(voyageCodeStr,altVoyageCode,_excludeDeparted) then
				_ediTIset.addNoDuplicates( ediTrackedItem, false );
				continue;
			endif;
		endif;
		
		//epr par 37090 2/11/15
		if _excludeDeparted and ediTrackedItem.getVoyage &lt;&gt; null and ediTrackedItem.getVoyage.hasDeparted then
			continue;
		endif;
		// now any EDITrackedItem subclass that has a suitable Voyagecode.
		if ediTrackedItem.getVoyageCode.toUpper[ 1 : voyageLength ] = voyageCodeStr then
			_ediTIset.addNoDuplicates( ediTrackedItem, false );
		elseif ediTrackedItem.getVoyageCode.toUpper[ 1 : voyageLength ] &gt; voyageCodeStr then
			break;
		endif;
	endwhile;
	
epilog
	delete iter1;
	
end;
</source>
        <Parameter name="_voyageCode" type="String"/>
        <Parameter name="_ediTIset" type="CM_EDITISet" usage="input"/>
        <Parameter name="_excludeDeparted" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getName" id="fb1c4937-ff87-4c8f-97b9-a53a1c44d45f">
        <source>getName() : String;

vars
	returnStr		: String;
	
begin
	returnStr	:= inheritMethod();
	
	if self.myTerminal &lt;&gt; null then
		returnStr	:=	returnStr &amp; Tab &amp;
						self.myTerminal.code &amp; Tab &amp;
						'EDITIs By IdStatus'  &amp; Tab &amp; self.allEDITrackedItemsByIdStatus.size.display &amp; Tab &amp;
						'EDITIs By VoyageCode' &amp; Tab &amp; self.allEDITrackedItemsByVoyageCode.size.display;
	endif;
	
	return returnStr;
	
epilog
	
end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="nextSeqNumber" id="4802f1bf-2692-424c-a7c3-230de5bf3134">
        <updating/>
        <source>nextSeqNumber():Integer updating;

vars

begin
	self.seqNumber := self.seqNumber + 1;
	if self.seqNumber &gt; 20000 then
		self.seqNumber := 1;
	endif;
	return seqNumber;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="removeTrainFromProcessing" id="00b2f2f8-b974-49ce-ae76-9a990c40955b">
        <source>removeTrainFromProcessing(_train: CM_Train);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 November 2009	cnwndl1	Initial creation	Par 21519

*/

vars

begin
	
	if self.allTrainsToProcess.includes(_train) then
		self.allTrainsToProcess.remove(_train);
	endif;

end;</source>
        <Parameter name="_train" type="CM_Train"/>
    </JadeMethod>
