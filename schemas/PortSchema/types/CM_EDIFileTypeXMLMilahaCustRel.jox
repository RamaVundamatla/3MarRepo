    <JadeMethod name="getSealNo" id="fbce595f-e520-4564-845d-75309286fb63">
        <source>getSealNo(_strSeal:String;truthSet : String) : CnStringArray;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 Jan 2017	cnwma1	TFS #2885:QNS - Additional Data Mapping in Customs Message
*/
vars
	array	: CnStringArray;
	str		: String;
	ix		: Integer;				// input index
	dx		: Integer;				// destination string index
	len		: Integer;
begin
	create array transient;

	ix 	:= 1;
	dx	:= 1;
	len := _strSeal.length;
	if truthSet.length() = null then
		return array;
	endif;

	while true do
		if ix &gt; _strSeal.length then
			if str &lt;&gt; null then
					array.add(str);
			endif;
			
			return array;
		endif;

		if truthSet.pos(_strSeal[ix], 1) &gt; null then
			array.add(str);
			str := null;
			dx := 1;
		else
			str[dx] := _strSeal[ix];
			dx := dx + 1;
		endif;

		ix := ix + 1; 
	endwhile;	

end;</source>
        <Parameter name="_strSeal" type="String"/>
        <Parameter name="truthSet" type="String"/>
        <ReturnType type="CnStringArray"/>
    </JadeMethod>
    <JadeMethod name="getStopCode" id="14d234ae-b28e-4cb2-b156-7732ba45f6fe">
        <source>getStopCode( _clearingAgency : String; _matchingFunc : Integer; _responseStatus : String; _stopCode : String output; _customsAgent : CM_CustomsAgent output ) protected;
/*

Purpose:			

Parameters:		
return stopcode (string but number)

Return Value:		


Date		Who		Reason
29 Jun 2015	NDL	Par 36543

*/

vars

	senderParty : CM_EDIParty;
	senderPartyRules : CM_EDIPartyRules;	
	anEDIRule : CM_EDIRule;
	qatarRule : CM_QatarRule;
	terminal : CM_Terminal;
	aStopsTable : CM_StopsTable;
	stopID : String;
	pos : Integer;
	
begin

	terminal 		:= app.myPassport.myTerminal;
	
	if _clearingAgency &lt;&gt; null and terminal &lt;&gt; null then
	
        senderParty := terminal.allEDIPartiesBySenderCode[ Qatar ];
		
		_customsAgent := findCustomsAgent(  _clearingAgency.trimBlanks );
		
		if senderParty = null then
			pos := _clearingAgency.pos(" ",1);
			if pos &gt; 1 then
				senderParty := terminal.allEDIPartiesBySenderCode[ _clearingAgency[1:pos-1] ];
			endif;
		endif;

		if senderParty &lt;&gt; null then
			senderPartyRules := senderParty.getRulesForFileType (EDIFileType_XML_Milaha_Customs);
		endif;
		
		
		if senderPartyRules &lt;&gt; null and senderPartyRules.isKindOf(CM_EDIPartyQatarRules) then  

			foreach anEDIRule in senderPartyRules.allEDIPartyRules do
				if not anEDIRule.isKindOf(CM_QatarRule) then
					continue;
				endif;
				qatarRule := anEDIRule.CM_QatarRule;
				if qatarRule.function &lt;&gt; _matchingFunc then
					continue;
				endif;
				
				//which stop				
				aStopsTable := self.getStopsTableFromHeading( qatarRule.stopTable);
				
				if aStopsTable &lt;&gt; null then
					_stopCode := aStopsTable.id.String;
					break;
				endif;
			endforeach;
		endif;
				
	endif;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_clearingAgency" type="String"/>
        <Parameter name="_matchingFunc" type="Integer"/>
        <Parameter name="_responseStatus" type="String"/>
        <Parameter name="_stopCode" type="String" usage="output"/>
        <Parameter name="_customsAgent" type="CM_CustomsAgent" usage="output"/>
    </JadeMethod>
    <JadeMethod name="processFile" id="b823c173-0a34-45b9-9ec3-dabc60d92bf2">
        <updating/>
        <source>processFile(_ediFile: CM_EDIFile input) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 June 2015	cnwndl1	Initial creation	Par 36543
22 Oct 2015 cnwmc5 	PAR 37085 - rewrite for new format
22 Mar 2016 cnwma1  TFS 1631  - QNS - Milaha Customs Interface (Declaration Types)
30 Mar 2016 cnwgb1  TFS 1619  - QNS - EDI administration of customs interface files
*/
//08 Oct 2015	cnwrs1	Par 36863 - make EDI consistant times when refreshing progress bar
//16 Jan 2017	cnwma1	TFS #2885:QNS - Additional Data Mapping in Customs Message
// 18 Jan 2019	jlgrs1	TFS 41659 42276 STWR Make EDI MultiThreaded Stage 8
// 07 Apr 2019	jlgrs1	TFS 41913 STWR - Reconfiguration of the EDI Operation form to better handle EDI collection locks while loading 
//
constants
	ProgressBarRefresh	: Integer = 2000;	

	ROOT_DEC			: String = 'Declaration';
	
	LCL_CARGO_ID		: Integer = 10023;
	LCL_CARGO_DESC		: String = "LCL PKGS";
	
vars
	message : String;
	passport : CM_Passport;
	terminal : CM_Terminal;
	xmlDoc : CM_XMLDocument;
	xmlElement : JadeXMLElement;
	xmlElement2 : JadeXMLElement;
	declarationElement : JadeXMLElement;
	declarationElements : JadeXMLElementArray;
	clearingAgency : String;
	releaseOrderNo : String;
	containerNo : String;
	bolNo : String;					//cnwmc5 - 9 Dec 2015 - PAR 37275
	allBOLNos : CnStringArray;		//cnwmc5 - 9 Dec 2015 - PAR 37275
	bolId : String;					//cnwmc5 - 9 Dec 2015 - PAR 37275
	cargoTypeId : Integer;			//cnwmc5 - 9 Dec 2015 - PAR 37275
	cargoType : CM_CargoType;		//cnwmc5 - 9 Dec 2015 - PAR 37275
	isLCL : Boolean;				//cnwmc5 - 21 Dec 2015 - PAR 37275
	declarationType : String;
	allContainerNos,allSealNos : CnStringArray;
	idString : String;
	responseStatus : String;
	ti : CM_TrackedItem;
	voyageNo : String;
	voyage : CM_Voyage;
	theXMLStr : String;
	stopCode : String;
	bayan : Boolean;
	matchingFunc : Integer;
	customsAgent : CM_CustomsAgent;
	declarationNo : String;
	refValueToPassToStop : String;
	stopAction : String;
	elementType : String;			//cnwmc5 - 21 Dec 2015 - PAR 37275
	amendDuesNotification : Boolean;// 16/01/2017 cnwma1 TFS #2885
	cargoDesc ,                     // 16/01/2017 cnwma1 TFS #2885
	sealOperator,					// 16/01/2017 cnwma1 TFS #2885
	sealStr: String;				// 16/01/2017 cnwma1 TFS #2885
	ediNotificationType : Integer;  // 16/01/2017 cnwma1 TFS #2885
begin

	passport := app.myPassport;	
	terminal := passport.myTerminal;

	create xmlDoc transient;
	//epr TFS 1834 15/4/16
	if passport.myCMIFMonitor &lt;&gt; null then
		passport.myCMIFMonitor.updateProgressWithCaption("Processing File Data", 4, 3, "Loading EDI file Step 3 of 3.");
	endif;
	
	message := _ediFile.getRawDataString();
	theXMLStr := message.extractXML();
    if theXMLStr &lt;&gt; null then
	
		xmlDoc.parseString(theXMLStr);
		
		if xmlDoc.rootElement.tagName = ROOT_BAYAN
		or xmlDoc.rootElement.tagName = ROOT_RELEASE
		or xmlDoc.rootElement.tagName = ROOT_AMEND
		or xmlDoc.rootElement.tagName = ROOT_CANCEL then
			xmlElement := xmlDoc.rootElement;
		else
			xmlElement := xmlDoc.rootElement.getElementByTagName(ROOT_BAYAN);
			if xmlElement = null then
				xmlElement := xmlDoc.rootElement.getElementByTagName(ROOT_RELEASE);
			endif;
			if xmlElement = null then
				xmlElement := xmlDoc.rootElement.getElementByTagName(ROOT_AMEND);
			endif;
			if xmlElement = null then
				xmlElement := xmlDoc.rootElement.getElementByTagName(ROOT_CANCEL);
			endif;
		endif;
		
		if xmlElement &lt;&gt; null then
			stopAction := CM_EDITrackedItem.EDI_ACTION_DELETE;
			elementType := xmlElement.tagName;		//cnwmc5 - 21 Dec 2015 - PAR 37275
			
			if elementType = ROOT_BAYAN then		//cnwmc5 - 21 Dec 2015 - PAR 37275	
				bayan := true;
				ediNotificationType := CM_EventRequestStops.EDI_NOTIFICATION_SUBMIT_DUES; // 16/01/2017 cnwma1 TFS #2885
			elseif elementType = ROOT_CANCEL then	//cnwmc5 - 21 Dec 2015 - PAR 37275	
				stopAction := CM_EDITrackedItem.EDI_ACTION_ADD;	
			elseif elementType = ROOT_AMEND then			 							// 16/01/2017 cnwma1 TFS #2885
				amendDuesNotification := true;              
				ediNotificationType := CM_EventRequestStops.EDI_NOTIFICATION_AMEND_DUES;
			endif;
			
			create declarationElements transient;
			xmlElement.getElementsByTagName(ROOT_DEC, declarationElements);
			foreach declarationElement in declarationElements do
				//Check for Bayan Cancel or Amend
				xmlElement2 := declarationElement.getElementByTagName('releaseOrderNumber');
				if xmlElement2 = null 
				and (xmlDoc.rootElement.tagName = ROOT_AMEND or xmlDoc.rootElement.tagName = ROOT_CANCEL) then
					bayan := true;
				endif;
				
				//work out which type we have.
				xmlElement2 := null;
				declarationType := null;
				xmlElement2 := declarationElement.getElementByTagName('declarationType');
				if xmlElement2 &lt;&gt; null then
					declarationType := xmlElement2.textData;
					//if declarationType = "IMP" then								  										//22/03/2016 cnwma1 TFS 1631
					if declarationType = "IMP" or  declarationType = "TIM"  then     										//22/03/2016 cnwma1 TFS 1631
						responseStatus := Customs_Import_Cleared;
					//elseif declarationType = "EXP" then																	//22/03/2016 cnwma1 TFS 1631
					elseif declarationType = "EXP" or declarationType = "REE" or declarationType = "TEX"  then	    		//22/03/2016 cnwma1 TFS 1631
						responseStatus := Customs_Export_Cleared;
//					else                                                                                                                                // 30/3/2016 cnwgb1 TFS 1619
//						//addFileErrors("&lt;declarationType&gt; value must be 'IMP' or 'EXP'! ", 1, _ediFile);       			//22/03/2016 cnwma1 TFS 1631// 30/3/2016 cnwgb1 TFS 1619
//						addFileErrors("&lt;declarationType&gt; value must be 'IMP','TIM','REE','TEX' or 'EXP'! ", 1, _ediFile);	//22/03/2016 cnwma1 TFS 1631// 30/3/2016 cnwgb1 TFS 1619
//						return;
					endif;
//				else                                                                                                                                    // 30/3/2016 cnwgb1 TFS 1619
//					addFileErrors("&lt;declarationType&gt; tag not found! ", 1, _ediFile);                                                                    // 30/3/2016 cnwgb1 TFS 1619
//					return;                                                                                                                             // 30/3/2016 cnwgb1 TFS 1619
				endif;
				
				//Get the 'required value'  to pass to the stop dependant on the type
				xmlElement2 := null;
				declarationNo := null;
				releaseOrderNo := null;
				refValueToPassToStop := null;
				if bayan then
					xmlElement2 := declarationElement.getElementByTagName('declarationNo');
					if xmlElement2 &lt;&gt; null then
						declarationNo := xmlElement2.textData.trimBlanks;
					endif;
					if responseStatus = Customs_Import_Cleared then
						matchingFunc := CM_QatarRule.Function_ImportBayanStop;
					elseif responseStatus = Customs_Export_Cleared then
						matchingFunc :=  CM_QatarRule.Function_ExportBayanStop;
					endif;
					refValueToPassToStop := declarationNo;
					
				else
					
					xmlElement2 := declarationElement.getElementByTagName('releaseOrderNumber');
					if xmlElement2 &lt;&gt; null then
						releaseOrderNo := xmlElement2.textData.trimBlanks;
					endif;
					if responseStatus = Customs_Import_Cleared then
						matchingFunc := CM_QatarRule.Function_ImportReleaseStop;
					elseif responseStatus = Customs_Export_Cleared then
						matchingFunc :=  CM_QatarRule.Function_ExportReleaseStop;
					endif;
					refValueToPassToStop := releaseOrderNo;
				endif;
				
				//Find the customs agency
				xmlElement2 := null;
				clearingAgency := null;
				stopCode := null;
				customsAgent := null;
				xmlElement2 := declarationElement.getElementByTagName('clearingAgency');
				if xmlElement2 &lt;&gt; null then
					clearingAgency := xmlElement2.textData.trimBlanks.toUpper;
					self.getStopCode(clearingAgency, matchingFunc, responseStatus, stopCode, customsAgent);
//					if stopCode = null then                                                         // 30/3/2016 cnwgb1 TFS 1619
//						addFileErrors("Stop code not resolved from EDI Party Rules! ", 1, _ediFile);// 30/3/2016 cnwgb1 TFS 1619
//						return;                                                                     // 30/3/2016 cnwgb1 TFS 1619
//					endif;
//				else                                                                // 30/3/2016 cnwgb1 TFS 1619
//					addFileErrors("&lt;clearingAgency&gt; tag not found! ", 1, _ediFile); // 30/3/2016 cnwgb1 TFS 1619
//					return;                                                         // 30/3/2016 cnwgb1 TFS 1619
				endif;
				
				xmlElement2 := null;
				containerNo := null;
				xmlElement2 := declarationElement.getElementByTagName('containerNo');
				if xmlElement2 &lt;&gt; null then
					containerNo := xmlElement2.textData.trimBlanks;
					xmlElement2 := null;
				else 
					addFileErrors("&lt;containerNo&gt; tag not found! ", 1, _ediFile);
					return;
				endif;
				
				xmlElement2 := null;
				voyageNo := null;
				voyage := null;
				xmlElement2 := declarationElement.getElementByTagName('voyageNo');
				if xmlElement2 &lt;&gt; null then
					voyageNo := xmlElement2.textData.trimBlanks;
					if voyageNo &lt;&gt; null then
						voyage := terminal.lookupVoyage(voyageNo, null, false);
					endif;
				endif;	
				
				//cnwmc5 - 9 Dec 2015 - PAR 37275
				xmlElement2 := null;
				bolNo := null;
				xmlElement2 := declarationElement.getElementByTagName('billOfLading');
				if xmlElement2 &lt;&gt; null then
					bolNo := xmlElement2.textData.trimBlanks;
				endif;
				
				// 16/01/2017 cnwma1 TFS #2885
				if amendDuesNotification or bayan  then
					xmlElement2 := null;
					cargoDesc := null;
					xmlElement2 := declarationElement.getElementByTagName('hscodeItemDesc');
					if xmlElement2 &lt;&gt; null then
						cargoDesc := xmlElement2.textData.trimBlanks;
					endif;
					
					xmlElement2 := null;
					sealOperator := null;
					xmlElement2 := declarationElement.getElementByTagName('sealNo');
					if xmlElement2 &lt;&gt; null then
						sealOperator := xmlElement2.textData.trimBlanks;
					endif;
				endif;
				// 16/01/2017 cnwma1 TFS #2885
				
				//cnwmc5 - 21 Dec 2015 - PAR 37275
				xmlElement2 := null;
				isLCL := false;
				xmlElement2 := declarationElement.getElementByTagName('isLCL');
				if xmlElement2 &lt;&gt; null then
					if xmlElement2.textData.trimBlanks.toUpper = 'Y' then
						isLCL := true;
					endif;
				endif;
				
				//cnwmc5 - 22 Dec 2015 - PAR 37275
				delete allBOLNos;
				allBOLNos := bolNo.cnGetTokensUsingTruthSet(", " &amp; Cr &amp; Lf);
				
				//cnwmc5 - 9 Dec 2015 - PAR 37275
				delete allContainerNos;
				allContainerNos := containerNo.cnGetTokensUsingTruthSet(", " &amp; Cr &amp; Lf);
				delete allSealNos;
				allSealNos := self.getSealNo(sealOperator,"," &amp; Cr &amp; Lf); 			 // 16/01/2017 cnwma1 TFS #2885
//				if allContainerNos = null or allContainerNos.isEmpty then           // 30/3/2016 cnwgb1 TFS 1619
//					addFileErrors("&lt;containerNo&gt; value is empty! ", 1, _ediFile);   // 30/3/2016 cnwgb1 TFS 1619
//					return;                                                         // 30/3/2016 cnwgb1 TFS 1619
//				endif;                                          
				
				//cnwmc5 - 21 Dec 2015 - PAR 37275
				if elementType = ROOT_CANCEL then
					customsAgent := null;
				endif; 
				
				//cnwmc5 - 21 Dec 2015 - PAR 37275
				bolId := null;
				if isLCL then
					foreach idString in allBOLNos do
				//		if idString = null then
				//			continue;
				//		endif;
						
						if cargoType = null then
							cargoType := app.myRoot.allCargoTypesById[LCL_CARGO_ID];
							cargoTypeId := LCL_CARGO_ID;
							if cargoType = null then
								cargoType := app.myRoot.getCargoTypeFromAbbrev(LCL_CARGO_DESC);
								if cargoType &lt;&gt; null then
									cargoTypeId := cargoType.id;
//								else                                                                                            // 30/3/2016 cnwgb1 TFS 1619
//									addFileErrors("Cargo Type '" &amp; LCL_CARGO_DESC &amp; "' not found in the system! ", 1, _ediFile);// 30/3/2016 cnwgb1 TFS 1619
//									return;                                                                                     // 30/3/2016 cnwgb1 TFS 1619
								endif;
							endif;
						endif;
						
						//cnwmc5 - 21 Dec 2015 - PAR 37275
						self.findAndProcessCargo(_ediFile, 
												idString, 
												cargoTypeId,
												responseStatus,
												voyageNo,
												voyage,
												stopAction,
												stopCode,
												refValueToPassToStop,
												customsAgent,
												idString,//BOL same as ID...
												cargoDesc,			 // 16/01/2017 cnwma1 TFS #2885
												sealOperator,        // 16/01/2017 cnwma1 TFS #2885
												ediNotificationType);// 16/01/2017 cnwma1 TFS #2885
					endforeach;
				else
                    if allContainerNos &lt;&gt; null then
                        foreach idString in allContainerNos do
                            if idString = null then
                                continue;
                            endif;
                            
                            cargoTypeId := TI_CargoType_Container;
                            
                            if elementType = ROOT_BAYAN
                            and allBOLNos.isNotEmpty then
                                bolId := allBOLNos.first;
                            endif;
                            foreach sealStr in allSealNos do  // 16/01/2017 cnwma1 TFS #2885
								break;
							endforeach;
							
                            //cnwmc5 - 21 Dec 2015 - PAR 37275
                            ti := self.findAndProcessCargo(_ediFile, 
                                                        idString, 
                                                        cargoTypeId,
                                                        responseStatus,
                                                        voyageNo,
                                                        voyage,
                                                        stopAction,
                                                        stopCode,
                                                        refValueToPassToStop,
                                                        customsAgent,
                                                        bolId,
														cargoDesc, 				// 16/01/2017 cnwma1 TFS #2885
														sealStr	,			// 16/01/2017 cnwma1 TFS #2885
														ediNotificationType);   // 16/01/2017 cnwma1 TFS #2885
							
							if allSealNos.size&gt;0 then    // 16/01/2017 cnwma1 TFS #2885
								allSealNos.remove(sealStr);
							endif;
							sealStr :=null;  // 16/01/2017 cnwma1 TFS #2885
                        endforeach;
                    endif;
				endif;
			endforeach;
		endif;
	endif;
	
epilog
	
	delete declarationElements;
	delete xmlDoc;
	delete allContainerNos;
		delete allSealNos;
	delete allBOLNos;

end;</source>
        <access>protected</access>
        <Parameter name="_ediFile" type="CM_EDIFile" usage="input"/>
    </JadeMethod>
</Class>
