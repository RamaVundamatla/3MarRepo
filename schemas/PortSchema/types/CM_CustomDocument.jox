    <JadeMethod name="getFirstTi" id="ecda1d03-60f3-4d03-8cd5-18eb157feeff">
        <source>getFirstTi() : CM_TrackedItem;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01/09/2023	navkc1	CR 59937 Task 59941: UI - Default Custom License Based on Cargo Location

*/

vars
	ti : CM_TrackedItem;
begin
	foreach ti in self.allTrackedItems discreteLock do
		if ti.isZombie() then
			continue;
		endif;
		if ti.isCargoGroupItem() then
			return ti.CM_CargoGroup.allAssignedTrackedItems.first();
		endif;
		
		return ti;
	endforeach;
epilog

end;</source>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="getFirstTiDate" id="d89561e5-d008-45e7-b197-55cffb856e67">
        <source>getFirstTiDate() : Date;
/*

Purpose:			This method get the first TI in the custom document, then return it's release date

Parameters:			

Return Value:		

Date		Who		Reason
29/08/2023	navkc1	CR 59556  Task 59593: UI - Cust Docs Auto Id
01/09/2023	navkc1	CR 59937 Task 59941: UI - Default Custom License Based on Cargo Location
*/

vars
	ti : CM_TrackedItem;
	date : Date;
begin
	
	//01/09/2023	navkc1	CR 59937 Task 59941
	ti := self.getFirstTi();
	
	// Get TI release date
	if ti &lt;&gt; null and ti.releasedDT &lt;&gt; null then
		date := ti.releasedDT.date();
	endif;
	
	return date;
	
epilog

end;</source>
        <ReturnType type="Date"/>
    </JadeMethod>
    <JadeMethod name="getPreviousCustomDocument" id="f7978c85-04bd-42b8-9381-01454e93378a">
        <source>getPreviousCustomDocument() : CM_CustomDocument;
/*
Purpose:			

Date		Who		Reason
16 August 2023	navab1	CR 59615 TASK 59620
*/

vars
	ti : CM_TrackedItem;
	subCustDetail, custDocDetail : CM_CustomDocumentDetail;
	prevseq : Integer;
	prevCustDoc : CM_CustomDocument;
begin
	foreach custDocDetail in self.allCustomDocumentDetails discreteLock where custDocDetail.included do : outerloop
		if custDocDetail.allSubDetails.isNotEmpty() then
			foreach subCustDetail in custDocDetail.allSubDetails discreteLock where custDocDetail.included do : innerloop
				ti := subCustDetail.myTrackedItem;
				if ti &lt;&gt; null then
					break outerloop;
				endif;
			
			endforeach;
		else
			ti := custDocDetail.myTrackedItem;
			if ti &lt;&gt; null then
				break outerloop;
			endif;
			
		endif;
	
	endforeach;

	if ti &lt;&gt; null then
		 // ### TFS CR 60052 TASK 60054 25AUG2023 NAVAB1
		prevCustDoc := ti.getPreviousCustomDocument(self);
		if prevCustDoc &lt;&gt; null then
			return prevCustDoc;
		endif;

		prevseq := self.sequence - 1;
		
		if ti &lt;&gt; null then
// ### TFS CR 60425 TASK 60828 13NOV2023 NAVAB1			prevCustDoc := ti.allCustomDocuments.getAtKeyGeq(prevseq,"");
			prevCustDoc := ti.allCustomDocuments.getPrevForSequence(prevseq); // ### TFS CR 60425 TASK 60828 13NOV2023 NAVAB1
			
			if prevCustDoc &lt;&gt; null 
			and prevCustDoc.sequence &lt;&gt; prevseq then
				prevCustDoc := null;
			endif;
			
			return prevCustDoc;
		endif;
	endif;

	return null;
epilog

end;</source>
        <ReturnType type="CM_CustomDocument"/>
    </JadeMethod>
    <JadeMethod name="getStatusStrFromInt" id="5115b883-c1ae-48f8-816c-ecf9ce6b921e">
        <options>4</options>
        <source>getStatusStrFromInt(_status : Integer) : String typeMethod;
/*
Purpose:			

Date		Who		Reason
14 August 2023	navab1	CR 59614 TASK 59619
*/

vars

begin
	if _status = CM_CustomDocument.Status_Cancelled then
		return CM_CustomDocument.Status_CancelledStr;
	elseif _status = CM_CustomDocument.Status_Active then
		return CM_CustomDocument.Status_ActiveStr;
	// ### TFS CR 60424 TASK 60549 19SEP2023 NAVAB1
	elseif _status = CM_CustomDocument.Status_Superseded then
		return CM_CustomDocument.Status_SupersededStr;
	endif;
	
	return CM_CustomDocument.Status_ActiveStr;

epilog

end;</source>
        <Parameter name="_status" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="handleStops" id="8a25a166-28af-4fd3-b729-3a6d20a130b6">
        <updating/>
        <source>handleStops(_oldDocType : CM_CustomDocumentType) updating;
/*
Purpose - 	
Who - NAVAB1
Date - 25AUG2023
ADO - CR 60052 TASK 60053 
*/

vars
	allTIs : CM_TISet;
	stop : CM_StopsTable;
	docType : CM_CustomDocumentType;
	ti, cgti, proxyTI : CM_TrackedItem;
	cg : CM_CargoGroup;
	pxyStop : CM_Stops;
	cdd, subCDD : CM_CustomDocumentDetail;
	docTypeChange : Boolean;
	allStops, alltiStops : CM_StopsByIdDict;
	tistop : CM_Stops;
	txnParams 			: CMIF_TITransactionController;
	tmpTransaction		: CM_TITransaction;
begin
	
	create allTIs transient; // do here so epilog is OK
	create allStops transient;
	
	docType:= self.myCustomDocumentType;
	
	if docType = null then
		return;
	endif;
	
	if docType.allStopsToApply.isEmpty
	and docType.allStopsToClear.isEmpty then
		return;
	endif;
	
	if docType &lt;&gt; _oldDocType
	and _oldDocType &lt;&gt; null then
		docTypeChange := true;
	endif;
	
	foreach cdd in self.allCustomDocumentDetails discreteLock 
				where cdd.included do

		ti := cdd.myTrackedItem;
		
		if ti.isCargoGroupItem then
			foreach subCDD in cdd.allSubDetails discreteLock 
						where subCDD.included do

				cgti := subCDD.myTrackedItem;
				proxyTI	:= app.createUpdateProxy( cgti ).CM_TrackedItem;
				
			
				// ### TFS CR 60424 TASK 60549 13OCT2023 NAVAB1
				// if this is outward we will have already created the clearing cust doc detail. The createUpdateProxy for the Ti only creates proxy stops for active stops, 
				//	the clearing cust doc detail means that the stop is no longer, however we need the proxy stop becasue we want to link this clearing CDD to the stop
				if self.isOutward() then
					foreach tistop in cgti.getAllStops() discreteLock do
						if tistop.myCustomDocumentDetlAppliedBy &lt;&gt; null then
							allStops.addNoDuplicates(tistop, false);
						endif;
					
					endforeach;
					proxyTI.createProxyStops( allStops );

				endif;
				
				
				allTIs.add(proxyTI);
				// ### Apply proxy stops to the proxy TIs
				subCDD.applyStops(proxyTI, docType.allStopsToApply, true);
				// ### Clear proxy stops for the proxy TIs
				subCDD.clearStops(proxyTI, docType.allStopsToClear);
				
				if docTypeChange then
					// ### Apply proxy stops to the proxy TIs
					subCDD.applyStops(proxyTI, _oldDocType.allStopsToClear, true);
					// ### Clear proxy stops for the proxy TIs
					subCDD.cancelStops(proxyTI, _oldDocType.allStopsToApply);
				
				
				endif;
			
			endforeach;
		else
			proxyTI	:= app.createUpdateProxy( ti ).CM_TrackedItem;
			
			// ### TFS CR 60424 TASK 60549 13OCT2023 NAVAB1
			// if this is outward we will have already created the clearing cust doc detail. The createUpdateProxy for the Ti only creates proxy stops for active stops, 
			//	the clearing cust doc detail means that the stop is no longer, however we need the proxy stop becasue we want to link this clearing CDD to the stop
			if self.isOutward() then
				foreach tistop in ti.getAllStops() discreteLock do
					if tistop.myCustomDocumentDetlAppliedBy &lt;&gt; null then
						allStops.addNoDuplicates(tistop, false);
					endif;
				
				endforeach;
				proxyTI.createProxyStops( allStops );

			endif;
			
			allTIs.add(proxyTI);
			// ### Apply proxy stops to the proxy TIs
			cdd.applyStops(proxyTI, docType.allStopsToApply, true);
			// ### Clear proxy stops for the proxy TIs
			cdd.clearStops(proxyTI, docType.allStopsToClear);
				
			if docTypeChange then
				// ### Apply proxy stops to the proxy TIs
				cdd.applyStops(proxyTI, _oldDocType.allStopsToClear, true);
				// ### Clear proxy stops for the proxy TIs
				cdd.cancelStops(proxyTI, _oldDocType.allStopsToApply);
			
			
			endif;
		
		endif;
	
		
		
	endforeach;
	
	// ### Update the stops on the TIs
	foreach ti in allTIs do
		app.myUtilityUA.utlUpdateTrackedItem(ti, null, TI_UPDMODE_NORMAL, null, null, null, app.myPassport); 
		if (not app.myPassport.noErrors) then
			break;
		endif;
	endforeach;
	
	
	// ### TFS CR 60424 TASK 60549 02OCT2023 NAVAB1
	foreach proxyTI in allTIs do
		ti := proxyTI.pxyGetRealObject().CM_TrackedItem;
		if ti = null then
			continue;
		endif;
		if ti.totalQuantity = ti.getCustDocsClearedQuantity() then // fully cleared
			// if I do not have a stop cleared transaction, add one.
			alltiStops := ti.getAllStops();
			foreach tistop in alltiStops discreteLock do
				if tistop.myStopsTable.requiresInfoForCustoms() then
					if tistop.myCustomDocumentDetlClearedBy &lt;&gt; null
					and tistop.myStopClearTxn = null then
						create txnParams transient;
						txnParams.type			:= TRANS_TYPE_STOPCLEAR;	
						txnParams.myStop			:= tistop;
						txnParams.myTrackedItem		:= ti;
						txnParams.userId			:= app.myPassport.userCode;
						txnParams.systemGenerated	:= true;
						txnParams.remarks			:= "Auto Created For Full Clearance (CUST DOCS)";
						tmpTransaction				:= ti.createTransaction( txnParams, app.myPassport );
						delete txnParams;
					endif;
				endif;
			endforeach;
		endif;
	
	endforeach;
	
	
epilog
	delete txnParams;
	delete allStops;
	allTIs.purge();
	delete allTIs;
end;</source>
        <Parameter name="_oldDocType" type="CM_CustomDocumentType"/>
    </JadeMethod>
