    <JadeMethod name="clearEditControls" id="d5b8df16-9a42-47ab-b9a8-30b78561fe3f">
        <updating/>
        <source>clearEditControls() protected, updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date				Who		Reason
06 November 2009	cnwndl1	Initial creation	Par 21519
08/06/2020		    cnwma1 ChangeRequest 49400: ASPA - Invoice Enhancements for Barges
29 July 2022		jlizm1	TFS 54165 EDI Voyage Events
*/

vars

begin
	
	self.cmbEventType.listIndex := -1;
	self.txtDate.setDate(null);
	self.txtTime.setTime(null);
	self.txtAmount.text			:= null;
	self.grpEventDetail.enabled := false;
	self.fldMain.enabled        := true;
	self.btnNewEvent.enabled    := true;
	self.btnEditEvent.enabled   := false;
	self.btnDelete.enabled      := false;
	self.btnSaveBase.enabled    := false;
	
	self.setupCmbCharge(true);
	self.txtEndDate.setDate(null);		//nds TFS 3047 13/01/17
	self.txtEndTime.setTime(null);	    //nds TFS 3047 13/01/17
	self.txtRemarks.text   := null; 	//nds TFS 3047 13/01/17
	self.cmbDebtor.visible := false; 	//03/06/2020 cnwma1 TFS #49400
	self.lblDebtor.visible := false; 	//03/06/2020 cnwma1 TFS #49400
	self.cmbDebtor.clear();          	//03/06/2020 cnwma1 TFS #49400    
	self.tblWeight.setValueDefault("0");	// TFS 54165
	
	self.tblEvents.selectMode := Table.SelectMode_None;
	
		
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="cmbDebtor_lostFocus" id="488ad324-1231-4e13-8aad-8f4aafd4d4e2">
        <controlMethod name="CMUI_ComboBox::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbDebtor_lostFocus(combobox: ComboBox input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 June 2020	jlgma1	Initial creation

*/

vars

begin
	
epilog

end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="cmbEventType_lostFocus" id="967372b7-710e-49b1-bce1-ffcbed48d3d1">
        <controlMethod name="CMUI_ComboBox::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbEventType_lostFocus(combobox: ComboBox input) updating;
/*

Date		Who		Reason
14 September 2015	cnwer1	Initial creation PAR 36902
12/03/2019	jlgns1	TFS 36423 XLAT_FormCaptions need to be sorted out
23/07/2019 	JLGNS1	ChangeRequest 45575: ASPA - Train Events
03/06/2020  cnwma1  ChangeRequest 49400: ASPA - Invoice Enhancements for Barges
01/08/2022	jlizm1	TFS 54165 EDI Voyage Events
*/
	
vars
	event 	   		: CM_EventType;
	amountText 		: String;
	currentDebtor   : CM_Debtor;
begin


	self.lblDate.caption := app.getFormCaptionsString(Xlat_0020017);
	self.lblTime.caption := app.getFormCaptionsString(Xlat_0020019);
	
	//epr par 36902 14/6/15
	if self.eventCategory = CM_EventType.VOYAGE_EVENT or self.eventCategory = CM_EventType.TRAIN_EVENT then	//ChangeRequest 45575
		event:= combobox.listObject.CM_EventType;
		if event &lt;&gt; null then
			amountText:= self.txtAmount.text;
			self.txtAmount.text:=null;
			if event.amountDecimalPlaces = 0 and
				self.txtAmount.decimals &gt; 0 then
				amountText	:= amountText.Integer.asStringJMT;
			endif;	
			
			self.txtAmount.decimals:= event.amountDecimalPlaces;
			//epr par 37047 16/10/15
			self.txtAmount.maxLength := 8;
			if event.amountDecimalPlaces &gt; 0 then
				self.txtAmount.maxLength := 9 + self.txtAmount.decimals;		
			endif;
				
			if event.unitDescription &lt;&gt; "" then																			//ChangeRequest 45575
				self.lblAmount.caption := app.getFormCaptionsString(Xlat_0020198) &amp; " (" &amp; event.unitDescription &amp; ")";	//ChangeRequest 45575
			else																										//ChangeRequest 45575
				self.lblAmount.caption := app.getFormCaptionsString(Xlat_0020198);										//ChangeRequest 45575
			endif;																										//ChangeRequest 45575
						
			self.txtAmount.text:=amountText;
			self.doShowEndDateControls(event.isFromToDateTimeRequired);//25/01/17 cnwns1 TFS3214 LNX - Voyage Operations Enhancements 
			
			if event.isFromToDateTimeRequired then
				self.lblDate.caption := app.getFormCaptionsString(Xlat_0014748); 
				self.lblTime.caption := app.getFormCaptionsString(Xlat_0015903);
			
			endif;
		endif;
	endif;
	
	if self.cmbDebtor.listObject &lt;&gt; null then					//03/06/2020 cnwma1 TFS #49400
		currentDebtor := self.cmbDebtor.listObject.CM_Debtor;
	endif;
	self.showDebtorCombo(currentDebtor);						//03/06/2020 cnwma1 Tfs #49400
	self.doShowWeightControls(event);							// TFS 54165
epilog

end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
