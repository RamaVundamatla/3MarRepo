    <JadeMethod name="doClickBtnShelves" id="b6343f36-85cd-4e0c-b42b-aab9c118cc36">
        <source>doClickBtnShelves();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 August 2013	cnwndl1	Initial creation

*/

vars

	form : SOP_GCSubLocationListForm;

begin

	create form transient;
	form.setMyTerminal(self.myTerminal);
	form.setMyRackLocation( self.myBlockController );
	
	if form.showModal = IDOK then
	endif;
	
	self.txtNumShelves.text := self.myBlockController.allSubLocations.size.String;

epilog

end;</source>
    </JadeMethod>
