    <JadeMethod name="addToolbarControls" id="996b2ae4-b9c5-412d-88ab-4e9ae8861df7">
        <updating/>
        <source>addToolbarControls() updating, protected;
//--------------------------------------------------
// Created:	22 January 2004 By: cnwgd1
//--------------------------------------------------
vars
	toolbar		: CMUI_Toolbar;
begin
	inheritMethod();
	
	toolbar := self.frmToolbar;
	toolbar.addButton(self.btnPrint, CMUI_Toolbar.Control_Alignment_Left);	
	toolbar.addButton(self.btnRedraw, CMUI_Toolbar.Control_Alignment_Left);	
	toolbar.addButton(self.btnCancelBase, CMUI_Toolbar.Control_Alignment_Right);
	self.btnSaveBase.tabStop := false;
	self.btnCancelBase.tabStop := false;


end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="advanceMinutes" id="c9f97b27-ac00-4c66-b1a4-8ba67bbbde25">
        <updating/>
        <source>advanceMinutes(_minutes : Integer) protected, updating;
/*
----------   ----------  --------------------------------------------------
Created:	17 October 2006 By cnwth2

Purpose:	

Changed On  Changed By  Reason
	
----------  ----------  --------------------------------------------------
06/08/2007	cnwdad1		PAR #14487 - added the setting of "dateMask" control.
*/
vars
	dateTime		: TimeStamp;
	oldHour			: Integer;
	str				: String;
	
begin
	dateTime := null;
	
	dateTime.setDate(self.dateMask.getDate());
	dateTime.setTime(self.txtTime.getTime());
	oldHour := dateTime.time.hour;

	dateTime := dateTime.cnEcAddMinutes(_minutes);
	
	//assumes minutes passed in is less than 60  -ugly hack, but this method is purely for my entertainmnet
	if oldHour = 23 and dateTime.time.hour = null then
		dateTime.cnEcAddDays(1);
	elseif oldHour = null and dateTime.time.hour = 23 then
		dateTime.cnEcAddDays(-1);
	endif;
	
	self.txtTime.setTime(dateTime.time);
	self.dateMask.setDate(dateTime.date);
	self.dateMask.setTextFromDate(dateTime.date);
	self.txtDate.setDate(dateTime.date);
	self.txtDate.setTextFromDate(dateTime.date);
	
	self.drawMe();
end;</source>
        <access>protected</access>
        <Parameter name="_minutes" type="Integer"/>
    </JadeMethod>
