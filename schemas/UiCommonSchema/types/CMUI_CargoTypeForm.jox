    <JadeMethod name="loadBehaviourTypes" id="c91918c1-ef49-4436-8d6e-cdbbae6b5865">
        <source>loadBehaviourTypes();
// --------------------------------------------------------------------------------
// Created:		5 February 2010 by cnwjo3
//
// Purpose:		Populate behaviour combo box with all Car graphic designs
//
vars
	bt : CM_TIBehaviourType;
	indx : Integer;
begin
	self.cmbBehaviourType.clear();

	indx := self.cmbBehaviourType.addItemObject("",null);
	foreach bt in app.myRoot.allTIBehaviourTypes do
		if bt.classNameToCreate = CM_Car.name or bt.behaviourType = TIBehaviourType_TermTrailer then
			indx := self.cmbBehaviourType.addItemObject(bt.description,bt);
			self.cmbBehaviourType.hasPictures := true;
			self.cmbBehaviourType.itemPicture[indx] := drawCargoGraphic(bt.myGraphic,White);
		endif;
	endforeach;
end;</source>
    </JadeMethod>
    <JadeMethod name="loadChars" id="2083b601-0132-4959-ac90-fc323a12ec25">
        <source>loadChars(_theFont : String);
// ---------------------------------------------------------------------------
// Created:     17 February 2003		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	idx : Integer;
begin
	if _theFont = null then
		return;
	endif;
	self.cmbChar.clear();
	self.cmbChar.sorted := false;
	self.cmbChar.fontName := _theFont;
	self.cmbChar.fontSize := 16;
	foreach idx in 1 to 255 do
		self.cmbChar.addItem(idx.Character);
	endforeach;

end;</source>
        <Parameter name="_theFont" type="String"/>
    </JadeMethod>
    <JadeMethod name="loadFonts" id="8198de17-8a8f-4dbc-a488-2a35f9ec533b">
        <source>loadFonts();
// ---------------------------------------------------------------------------
// Created:     17 February 2003		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin
	self.cmbFont.clear();
	self.cmbFont.addItem("");
	self.cmbFont.addItem("Courier");
	self.cmbFont.addItem("Courier New");
	self.cmbFont.addItem("Times New Roman");
	self.cmbFont.addItem("Helvetica");
	self.cmbFont.addItem("Arial");
	self.cmbFont.addItem("Wingdings");
	self.cmbFont.addItem("Wingdings 2");
	self.cmbFont.addItem("Wingdings 3");
	self.cmbFont.addItem("Webdings");
	self.cmbFont.sorted := true;
	self.cmbFont.listIndex := 1;
	self.cmbFont.text := "Courier";
end;</source>
    </JadeMethod>
    <JadeMethod name="loadHandlingTypes" id="76f6edc7-ecf9-4ce0-a9ed-11d878cf9eee">
        <source>loadHandlingTypes();
// ---------------------------------------------------------------------------
// Created:     25 October 2002		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	handlingTypeDict		: CM_HandlingTypesByIdDict;
	handlingType			: CM_HandlingType;
begin
	handlingTypeDict := app.myRoot.allHandlingTypes;
	self.cmbHandling.sorted := true;
	if not handlingTypeDict.isEmpty then
		self.cmbHandling.listCollection(handlingTypeDict, true, 0);
		self.cmbHandling.listObject := handlingTypeDict.first;
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="loadMeasurementCombos" id="95b0c819-ab80-4574-8c5e-6b8578a440ac">
        <source>loadMeasurementCombos();
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 20/03/2014	cnwdap1		Initial creation PAR #33606 CCMS SFW 1366 Bulk
//
vars
	measure	: CM_MeasurementType;

begin
	foreach measure in app.myRoot.allMeasurementTypesByShortName discreteLock do
		if measure.isWeight then
			self.cmbWeightType.addItem(measure.shortName);
		elseif measure.isVolume then
			self.cmbVolumeType.addItem(measure.shortName);
		endif;
	endforeach;
	
	self.cmbTrackBy.addItem(CargoType_TrackByWeightStr);
	self.cmbTrackBy.addItem(CargoType_TrackByVolumeStr);
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="loadOperators" id="4f18452d-9ffb-42a5-9181-bec81dadfea1">
        <source>loadOperators();
// ---------------------------------------------------------------------------
// Created:     02 October 2002 by cnwth2
//
// Purpose:     
//
// ----------   ----------  --------------------------------------------------
vars
	opDict 			: CM_OperatorByCodeDict;
	
begin
	opDict := app.myRoot.allOperators;
	self.cmbOperator.listCollectionWithAny(opDict, ETRow_Code);
	self.tblSearch.setValueByName(ETRow_Operator, Any_String);
	
end;</source>
