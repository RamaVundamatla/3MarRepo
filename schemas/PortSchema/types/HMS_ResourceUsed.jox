    <JadeMethod name="archive" id="8dba368c-ef00-4c7f-bd7a-a27b8bd584a1">
        <updating/>
        <source>archive(_movement : HMS_VoyageMovement; _archivedDT : TimeStamp; _passport : CM_Passport input) updating;
//--------------------------------------------------------------
//Created: 28 July 2003 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	if _movement = null then
		app.raiseUnexpectedProgramError(class.name, method.name, '_movement is null');
		return;
	endif;
	self.archived := true;
	self.archivedDT := _archivedDT;
	if (not self.archivedDT.isValid) then
		self.archivedDT := app.serverTimestampAtTrxStart;
	endif;	
	
	//Change the movement's reference to reflect being archived.
	self.myVoyageMovementArchive := _movement;
	self.myVoyageMovement := null;
	
end;</source>
        <Parameter name="_movement" type="HMS_VoyageMovement"/>
        <Parameter name="_archivedDT" type="TimeStamp"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="cancelBooking" id="7fe8058c-d6c8-4c25-b0b8-f420634db332">
        <updating/>
        <source>cancelBooking(_movement : HMS_VoyageMovement; _passport : CM_Passport input) updating;
//--------------------------------------------------------------
//Created: 28 July 2003 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	
	self.createTransaction(_movement, TRANS_TYPE_ResourceCancelled, _passport);
	
	self.archive(_movement, app.serverTimestampAtTrxStart, _passport);

end;</source>
        <Parameter name="_movement" type="HMS_VoyageMovement"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="cloneMySelf" id="c668cb0f-045f-4474-a65d-45774fcb6a83">
        <source>cloneMySelf(_transient : Boolean) : SelfType;
//--------------------------------------------------
// Created:	21 February 2005 By: cnwgd1
//--------------------------------------------------
vars
	newResourceUsed : SelfType;
begin
	newResourceUsed := self.cloneSelf(_transient);

	newResourceUsed.myHarbour := self.myHarbour;
	newResourceUsed.myResource := self.myResource;
	newResourceUsed.myResourceType := self.myResourceType;
	newResourceUsed.myVoyageMovement := self.myVoyageMovement; // CCMS 1350
	newResourceUsed.myDebtor := self.myDebtor;	//26 Nov 2018	NDL	TFS 41980
	return newResourceUsed;
end;</source>
        <Parameter name="_transient" type="Boolean"/>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="createInvoiceTranProforma" id="57b9568c-9ec6-4f8a-95bf-ac7a158b4050">
        <source>createInvoiceTranProforma() : HMS_VTMISTransaction;
/*
Purpose:			
Date				Who			Reason
DECEMBER 2014		CNWAB1		Initial creation
*/

vars
	vtmisTrans : HMS_VTMISTransaction;
begin

	create vtmisTrans transient;
	
	vtmisTrans.setForCreate(self.myVoyageMovement, self, app.myPassport);

	vtmisTrans.noCharge := false; // TFS 3844 this method is not used

	return vtmisTrans;
end;</source>
        <ReturnType type="HMS_VTMISTransaction"/>
    </JadeMethod>
    <JadeMethod name="createInvoiceTransaction" id="7f26d5a6-0b05-41f9-ab80-a9d1c744440f">
        <source>createInvoiceTransaction(_passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:		February 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	vtmisTrans : HMS_VTMISTransaction;
begin
	// ### ALREADY CHARGED
	if self.myVTMISTransaction &lt;&gt; null then
		return;
	endif;


	create vtmisTrans persistent;
	
	vtmisTrans.setForCreate(self.myVoyageMovement, self, _passport);
	vtmisTrans.createCharge(_passport);
	
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="createTransaction" id="573e7bfc-f722-45a5-8920-b0501337deae">
        <source>createTransaction(_movement : HMS_VoyageMovement; _transType : Integer; _passport : CM_Passport input) protected;
//--------------------------------------------------------------
//Created: 29 July 2003 By: cnwgd1
//--------------------------------------------------------------
vars
 	transController : CMIF_HMS_TransactionController;
begin
	if self.myResource = null then
		//Only create transactions when the resource has been set
		return;
	endif;
	
	// This method creates a transController for all the changes that take place when the 
	// permanent voyage is added NOTE: A single transController may cover changes to one or more properties
	create transController transient;

	// Set general transController properties and references
	transController.myResourceUsed := self;
	transController.myResource := self.myResource;
	transController.myVoyageMovement := _movement;
	transController.myHMSVoyageData := _movement.myHMSVoyageData;
	transController.myTerminal := _movement.myHMSVoyageData.getMyTerminal();
	transController.type := _transType;
	
	transController.createTransaction(_passport);

epilog
	delete transController;
end;</source>
        <access>protected</access>
        <Parameter name="_movement" type="HMS_VoyageMovement"/>
        <Parameter name="_transType" type="Integer"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getArchivedDTLocalTZ" id="0baa0122-c1c9-4e11-a9cb-3d98af6677bc">
        <source>getArchivedDTLocalTZ() : TimeStamp;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 June 2016	cnwns1	Initial creation
// 07 June 2016	cnwns1	TFS 488 - Multi Timezone Support
*/

vars

begin
	return self.systemToLocalTime(self.archivedDT);
epilog

end;</source>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="691dae2d-4ad2-4acf-83d9-e0b3a9e93657">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
//--------------------------------------------------
// Created:	15 February 2005 By: cnwgd1
//--------------------------------------------------
vars
	realMe : SelfType;
	invLine : CM_InvoiceLine;
begin

	if _attrName = ETRow_MyResourceType then
		if self.myResourceType &lt;&gt; null then
			return self.myResourceType.description;		
		elseif self.myResource &lt;&gt; null then
			return self.myResource.myResourceType.description;
		endif;
		return null;
	elseif _attrName = ETRow_MyResource then
		if self.myResource &lt;&gt; null then
			return self.myResource.description;
		endif;	
		return null;
	elseif _attrName = ETRow_MyVTMISTransaction then
		if self.myVTMISTransaction &lt;&gt; null then
			invLine := self.myVTMISTransaction.allInvoiceLines.first;
			if invLine &lt;&gt; null then
				return invLine.sequenceNum.String;
			else
				return null;
			endif;
		else
			return null;
		endif;
	elseif _attrName = ETRow_CreateCharge then
		return (self.myVTMISTransaction &lt;&gt; null).String;
	elseif _attrName = ETRow_QuantityUnits then
		if self.myResourceType &lt;&gt; null then
			return self.myResourceType.quantityUnits;
		endif;	
		return null;		
	elseif _attrName = ETRow_FromDate
	or _attrName = ETRow_ActionDate then
		if self.fromDateTime.isValid then
			return self.systemToLocalTime(self.fromDateTime).date.shortFormatJMT();	// 25/5/16 cnwmp6 TFS 488 - Multi timezone support
		else
			return null;
		endif;
	elseif _attrName = ETRow_FromTime 
	or _attrName = ETRow_ActionTime then	
		if self.fromDateTime.isValid then
			return self.systemToLocalTime(self.fromDateTime).time.currentLocaleFormatJMT();	// 25/5/16 cnwmp6 TFS 488 - Multi timezone support
		else
			return null;
		endif;
	elseif _attrName = ETRow_ToDate then
		if self.toDateTime.isValid then
			return self.systemToLocalTime(self.toDateTime).date.shortFormatJMT();	// 25/5/16 cnwmp6 TFS 488 - Multi timezone support
		else
			return null;
		endif;
	elseif _attrName = ETRow_ToTime then
		if self.toDateTime.isValid then
			return self.systemToLocalTime(self.toDateTime).time.currentLocaleFormatJMT();	// 25/5/16 cnwmp6 TFS 488 - Multi timezone support
		else
			return null;
		endif;
	elseif _attrName = ETRow_UnitsUsed then
		if self.unitsUsed &gt; 0 then
			return self.unitsUsed.String;
		else
			return null;
		endif;	
	elseif _attrName = ETRow_Debtor or  _attrName = ETRow_MyDebtor then	//26 Nov 2018	NDL	TFS 41980
		if self.myDebtor &lt;&gt; null then
			return self.myDebtor.name;
		else
			return null;
		endif;
	else
		return inheritMethod(_attrName, _short);
	endif;

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getFromDateTimeLocalTZ" id="b25f0362-6728-48d3-a148-ccac1f7cea9f">
