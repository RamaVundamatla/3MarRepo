    <JadeMethod name="getDataTypeFromDefName" id="1345aefc-71e4-4f44-a3ab-a996711af7d0">
        <source>getDataTypeFromDefName(_name: String): Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 November 2016	cnwndl1	Initial creation		TFS 2843 / 2604
// 15 Jun 2017	cnwrs1	TFS 4462 SNO add Terminal Operator, Unknown Seal and support multiple seals
*/

vars

begin

	if _name = ETDef_EDIHazDetailsTI then
		return EDIDataType_TIHazDets;
	elseif _name = ETDef_EDITISeal then
		return EDIDataType_TISeal;
	endif;
	
	return inheritMethod(_name);

epilog

end;</source>
        <Parameter name="_name" type="String"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStrForDefName" id="1a23d3e6-725d-4a83-9820-b57a1c339df1">
        <source>getDisplayStrForDefName(_name: String): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 November 2016	cnwndl1	Initial creation	TFS 2843 / 2604
// 15 Jun 2017	cnwrs1	TFS 4462 SNO add Terminal Operator, Unknown Seal and support multiple seals
// 18 Sep 2017	jlgrs1	TFS 5457 Make JMTInternal XML work
*/

vars

begin
	if _name = ETDef_EDITICargo then
		return app.getErrorString(Cargo);
	elseif _name = ETDef_EDIHazDetailsTI then
		return app.getErrorString(Hazardous_details);
	elseif _name = ETDef_EDITISeal then
		return "Seals";
	endif;
epilog

end;</source>
        <Parameter name="_name" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
