    <JadeMethod name="cmbGeneratorType_closeup" id="975d4263-0272-4777-baf6-ba4030c17896">
        <controlMethod name="ComboBox::closeup"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbGeneratorType_closeup(combobox: ComboBox input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 May 2018	jlgma1	Bug 38541: PENN - Chassis Maintenance

*/

vars
	genType 	: CM_GeneratorType;
	measure     : CM_MeasurementType;
begin
	genType := combobox.itemObject[cmbGeneratorType.listIndex].CM_GeneratorType;
	if genType &lt;&gt; null then
		measure := app.getDefaultMeasurementForType(Type_Weight);	                                       //15.5.2018 cnwma1	Bug 38541
		self.txtWeight.text	:= app.convertMeasurementForDisplay(measure.shortName, genType.defaultWeight);   //1
	endif;
epilog

end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
