<Class name="CnEcWebTestController" id="1d315622-3c6f-45b6-8368-48effa96ed08">
    <superclass name="CnEcWebTestEntity"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
