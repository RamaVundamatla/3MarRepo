    <JadeMethod name="getUntranslatedErrorString" id="62641413-2bc3-4f14-8971-c311f2122f1d">
        <source>getUntranslatedErrorString(errorCode : Integer) : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 January 2018	jlgndl1	Initial creation	TFS 36809

*/

vars

	translation : XLAT_Translation;

begin

	translation := self.myRoot.getLocale(StandardTextLocaleStr, true).getTranslatedText(XLAT_Exceptions, errorCode);
	if translation &lt;&gt; null then
		return translation.text;
	endif;
	
	return "Error " &amp; errorCode.String &amp; UnknownMessage;
	
epilog

end;</source>
        <Parameter name="errorCode" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getUserCommandLine" id="3bdf3917-749d-4c07-a688-b7fafc80bc5c">
        <source>getUserCommandLine(_giveError : Boolean) : String;
// ---------------------------------------------------------------------------
// Created:     28 March 2003 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 10 Jun 2008	cnwkpd1		PAR #16954 - Allow for a lower case "endjade" in 
//							the command line
// 28 Oct 2008	cnwkpd1		PAR #18383 - change to use node.getCommandLine
// ---------------------------------------------------------------------------

constants
	UserDelimiter	: String	= 'endJade';
	
vars
	commandLine,
	userData	: String;
	userStart,
	pos			: Integer;

begin
	commandLine := node.getCommandLine();		// PAR #18383 - was call getCommandLine();
    pos := 1;
    pos := commandLine.pos(UserDelimiter, pos);
	if pos = 0 then												// Allow for managed environments where endJade is all lower case
		pos := 1;
		pos := commandLine.pos(UserDelimiter.toLower, pos);
	endif;
    if pos &gt; 0 then
    	userStart	:= pos + UserDelimiter.length + 1;
    	if commandLine.length &gt;= userStart then
	    	userData := commandLine[userStart : end];
	    else
			if _giveError then
				app.writeLog('ERROR &gt;&gt; no arguments after endJade (' &amp; commandLine &amp; ')', LogINFO);
		    endif;
	    endif;
	else
		if _giveError then
			app.writeLog('ERROR &gt;&gt; endJade not found on command line (' &amp; commandLine &amp; ')', LogINFO);
		endif;
	endif;
	
	return userData;

end;</source>
        <Parameter name="_giveError" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getUserForException" id="cd275ba2-1373-4e3b-83d3-fc372ad05fef">
        <source>getUserForException(exObj : Exception) : String;
// ---------------------------------------------------------------------------
// Created:     20 December 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
/*

Date		Who		Reason
14 Sep 2012	cnwkpd1	PAR #30027 - locking framework issues
	
*/
vars
	user		: String;
	tmpProcess	: Process;
	
begin

	if LockException.hasInstance(exObj) and
	   exObj.LockException.targetLockedBy &lt;&gt; null then
	   	tmpProcess := exObj.LockException.targetLockedBy;
	elseif DeadlockException.hasInstance(exObj) and
	   exObj.DeadlockException.targetLockedBy &lt;&gt; null then
	   	tmpProcess := exObj.DeadlockException.targetLockedBy;
	endif;

	if tmpProcess &lt;&gt; null then
		on LockException do ignoreObjectLockedExHandler(exception, tmpProcess);
		user := "user " &amp; tmpProcess.userCode;
		on LockException do null;			// PAR #30027
	endif;
	
	if user = null then
		user := "an unknown user";
	endif;

	return user;

end;</source>
        <Parameter name="exObj" type="Exception"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getUserReportsForType" id="96f8b43f-f8f7-4592-aa9f-d330506b2b7a">
        <source>getUserReportsForType(_reports : CM_QryReportUserDict input; _type : Integer);
/*
Purpose - 	
Who - NAVAB1
Date - 27AUG2024
ADO - CR 65820 TASK 65822
*/

vars

	menuItemDict				: CM_MenuItemByTypeMenuIdDict;
	menuItem					: CM_MenuItem;
	qryReport					: CM_QryReportUser;
begin

	if _reports= null then
		return;
	endif;
	
	menuItemDict := app.myRoot.myReportMenuRoot.allMenuItems;
	
	foreach menuItem in menuItemDict do
		if not menuItem.isKindOf(CM_QryReportUser) then
			continue;
		endif;
		
		if menuItem.CM_QryReportUser.reportType = _type then 
			qryReport := menuItem.CM_QryReportUser;
			_reports.add(qryReport);
		endif;
	endforeach;
	
	
epilog

end;</source>
        <Parameter name="_reports" type="CM_QryReportUserDict" usage="input"/>
        <Parameter name="_type" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getVolumeForDefault" id="489b98ed-a51c-489a-a1f1-fe554c5666f9">
        <source>getVolumeForDefault(_value : Decimal) : String;
/*
Purpose:			
Date				Who			Reason
13 September 2023 navmv20 Bug 60217: EUP - COO - Release Request - Message not displaying weight as per measurement type displayed
*/
vars
	measureType : CM_MeasurementType;

begin
	measureType := app.getDefaultMeasurementForType(Type_Volume);
	if measureType = null then
		return _value.jasVolumeString;
	endif;
	return app.convertMeasurementForDisplay(measureType.shortName, _value);
epilog

end;</source>
        <Parameter name="_value" type="Decimal"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getVolumeForDefaultDisplay" id="f505c609-9004-4f27-a8b8-9ec873ebeb76">
        <source>getVolumeForDefaultDisplay(_value : Decimal) : String;
/*
Purpose:			
Date				Who			Reason
SEPT 2013		CNWAB1		Initial creation
*/
vars
	measureType : CM_MeasurementType;

begin
	measureType := app.getDefaultMeasurementForType(Type_Volume);
	if measureType = null then
		return _value.jasVolumeString &amp; " M3";
	endif;
	return app.convertMeasurementForDisplay(measureType.shortName, _value) &amp; " " &amp; measureType.shortName;
epilog

end;</source>
        <Parameter name="_value" type="Decimal"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getVoyageBusUnit" id="c18a6bae-6e1e-42d5-b4cf-b368dd9d7d29">
        <source>getVoyageBusUnit(_term : CM_Terminal; _voyage : CM_Voyage) : CM_Bank;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 March 2018	jlgndl1	Initial creation	TFS 37562 - Default behaviour when no hook code found,
							called by sendMsg from CM_HookAgent::compileAndRunHookLinkPrivate, when no hook code defined for terminal.

*/

vars

	bank : CM_Bank;
	reference : Integer;
	
begin
	
	reference := HookType_VoyageBusUnit; // here to provide some sort of reference....
										// doesn't do anything, just makes it easier to find.
	
	if _voyage &lt;&gt; null and _voyage.myDischargeCompany &lt;&gt; null then	//01 Jun 2018	NDL TFS 39032	- temp fix to retain default behaviour
		return _voyage.myDischargeCompany;
	endif;
	
	if _term &lt;&gt; null then
		bank := _term.getDefaultCompanyBank();
	endif;
	
	return bank;
	
epilog

end;</source>
        <Parameter name="_term" type="CM_Terminal"/>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <ReturnType type="CM_Bank"/>
    </JadeMethod>
    <JadeMethod name="getVoyageFullPlanFromValue" id="b084b433-5678-4314-9b38-30a2016de691">
        <source>getVoyageFullPlanFromValue(_value : Integer) : String;
// ---------------------------------------------------------------------------
// Created:		29 August 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
begin
	if _value = VoyageFullPlanOSVoyage then
		return VoyageFullPlanOSVoyageStr;
	elseif _value = VoyageFullPlanOSDischPort then
		return VoyageFullPlanOSDischPortStr;
	elseif _value = VoyageFullPlanGroundHeight then
