    <JadeMethod name="actionEventRequestNotification" id="f6d10c8d-3680-40e9-a637-74bd9579820d">
        <updating/>
        <source>actionEventRequestNotification(_trackedItem : CM_TrackedItem input; _transaction : CM_TITransaction; _passport : CM_Passport input) updating;
// --------------------------------------------------------------------------------
// Created:		23 September 2009 by cnwdad1
//
// Purpose:		Processes Event Request notifications.
//
// NOTE: This method was originally implemented on CM_Root.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	iteratorObj			: Iterator;
	tmpNotifyRequest	: CM_EventRequestNotification;
	
begin
	if _trackedItem = null then
		app.setContinueCMExceptions(false);
		app.raiseUnexpectedProgramError(class.name, method.name, 'null _trackedItem');
		return;
	endif;
	
	if _transaction = null then
		app.setContinueCMExceptions(false);
		app.raiseUnexpectedProgramError(class.name, method.name, 'null _transaction');
		return;
	endif;
	
	// Check for event notifications
	iteratorObj	:=	self.allEventRequestNotifyByCargoID.createIterator();
	self.allEventRequestNotifyByCargoID.startKeyGeq(_trackedItem.id, iteratorObj);
	
	while iteratorObj.next(tmpNotifyRequest) do
		if tmpNotifyRequest.cargoId &lt;&gt; _trackedItem.id then
			break;
		endif;
		tmpNotifyRequest.actionEventRequestNotification(_trackedItem, _transaction, _passport);
	endwhile;
epilog
	delete iteratorObj;
end;</source>
        <Parameter name="_trackedItem" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_transaction" type="CM_TITransaction"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="actionEventRequestStops" id="83972159-677d-49ca-abbe-1859f290c127">
        <source>actionEventRequestStops(_trackedItem : CM_TrackedItem input; _passport : CM_Passport input);
// --------------------------------------------------------------------------------
// Created:		23 September 2009 by cnwdad1
//
// Purpose:		Processes Event Request Stops.
//
// NOTE: This method was originally implemented on CM_Root.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 22/06/2011	cnwcs5		par 27167 - changed method to be NOT updating as it doe not call updating methods
//									  - also changed to check cargo type as well
// --------------------------------------------------------------------------------
vars
	iter			: Iterator;
	request			: CM_EventRequestStops;
	
begin
	if _trackedItem = null then
		app.setContinueCMExceptions(false);
		app.raiseUnexpectedProgramError(class.name, method.name, 'null _trackedItem');
		return;
	endif;
	
	// Check for stops
	iter	:=	self.allEventRequestStopsByCargoID.createIterator();
	self.allEventRequestStopsByCargoID.startKeyGeq(_trackedItem.id, iter);
		
	while iter.next(request) do
		if request.cargoId &lt;&gt; _trackedItem.id then
			break;
		endif;
		
		if request.myCargoType &lt;&gt; _trackedItem.myCargoType then
			// cargo type is not a key - but cargo is still matches
			continue;
		endif;
		
		if request.isActioned() then
			// do not reprocess PAR13403
			continue;
		endif;
		
		request.actionCargoUpdateRequest( _trackedItem, true,_passport);
	endwhile;
epilog
	delete iter;

end;</source>
        <Parameter name="_trackedItem" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="addBGPMutex" id="79a8af60-1398-47f5-9bf4-00d17c7d9655">
        <source>addBGPMutex(_constant : Constant; _passport : CM_Passport);
//
// 20 Sep 2018	jlgrs1	TFS 40627 STWR Make EDI MultiThreaded Stage3
//
vars
/*	stringConstant : Constant;
	terminal : CM_Terminal;
