        <source>utlCreateVoyStageForOpAndVoy(_pxyStage : CM_VoyageStage; _realStage : CM_VoyageStage output; _passport : CM_Passport input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 July 2024	navra1	Initial creation for //navra1 - CR-65068/Task-64641 - Auto Comparison - 15th July 2024

*/

vars
	theTerminal : CM_Terminal;
	voyage : CM_Voyage;
begin
	self.initialiseActivity();
	
	app.setContinueCMExceptions(false);

	create _realStage persistent;
	
	_realStage.setForCreate(_pxyStage);
	
	// ### TFS CR 64612 TASK 64659 18JUL2024 NAVAB1
	if _passport.noErrors then
		theTerminal := _passport.myTerminal;
		voyage := _realStage.getMyVoyageObject();
		app.myEventManager.createSingleObjInfoNoteEvt(voyage,theTerminal.getTerminalEvent(Event_VoyageStageCreate),_realStage);	
	endif;
epilog

end;</source>
