    </JadeMethod>
    <JadeMethod name="jssFileExt" id="de1ffa5e-c82c-4d39-99e7-35c8fa8a481a">
        <source>jssFileExt() :String;
// Return the file extension.
vars
	uniqueName	: String;
	charIndex	: Integer;
	lastCharPos	: Integer;

begin
	// Get the unqualified filename

	uniqueName	:=	self.jssUnqualName();
	charIndex	:=	1;

	while charIndex &lt;&gt; 0 and charIndex &lt; uniqueName.length() do
		lastCharPos	:=	charIndex;
		charIndex	:=	uniqueName.pos(".", (lastCharPos + 1));
	endwhile;

	if lastCharPos = 0 then
		return "";
	endif;

	return uniqueName[(lastCharPos + 1):end];		
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="jssFilePath" id="10658f2f-c81a-4339-97a6-8fbc1d1a9f6e">
        <source>jssFilePath() :String;
// Return the path part of the fully qualified filename only
// (up to and including the FINAL "\").
vars
	charIndex	: Integer;
	lastCharPos	: Integer;

begin
	charIndex	:=	1;

	while charIndex &lt;&gt; 0 do
		lastCharPos	:=	charIndex;
		charIndex	:=	fileName.pos("\", (lastCharPos + 1));
	endwhile;

	return fileName[1:lastCharPos];	
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="jssFileStem" id="41e72f41-463e-47f1-84ff-471cecd4aa16">
        <source>jssFileStem() :String;
// Return the filestem, i.e. the unqualified filename 
// without the file extension (after the FINAL ".").
vars
	uniqueName	: String;
	charIndex	: Integer;
	lastCharPos	: Integer;

begin
	// Get the unqualified filename
	uniqueName	:=	jssUnqualName();
	charIndex	:=	1;

	while charIndex &lt;&gt; 0 and charIndex &lt; uniqueName.length() do
		lastCharPos	:=	charIndex;
		charIndex	:=	uniqueName.pos(".", (lastCharPos + 1));
	endwhile;

	if lastCharPos = 0 then
		return uniqueName;
	endif;

	return uniqueName[1:(lastCharPos - 1)];
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
