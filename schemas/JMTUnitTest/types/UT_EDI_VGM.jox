<Class name="UT_EDI_VGM" id="07698205-78e4-4615-b6b0-ad6e0868513c">
    <superclass name="UT_EDI"/>
    <transient/>
    <sharedTransientAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="unitTest"/>
    <JadeMethod name="tVGMBayPlanBAPLIE22" id="cb7fe510-e6be-4de0-a176-7e74a6b1b8e6">
        <source>tVGMBayPlanBAPLIE22();

/*

Purpose:		

Date			Who		Reason
24/05/2016		cnwmh5	Initial creation
14/07/2017		cnwdap1	TFS 4492 SNO VERMAS Changes
*/
constants

	
	VoyageId						: String = "UTMDHVGMVOY9";
	VesselId						: String = "MESBIAN";

vars

	cont							: CM_Container;
	operator						: CM_Operator;
	voyage							: CM_Voyage;
	ediFile							: CM_EDIFile;
	bs								: CM_BlockStack;
	tiTransaction					: CM_TITransaction;
	ediTI 							: CM_EDITrackedItem;
	obj								: Object;
	bp								: CM_EDIDataBayPlan;
	file							: File;
	bgpGeneric 						: BGP_GenericController;
	autoSchedule					: CM_AutoSchedule;
		
	tiSet							: CM_TISet;
	
	loadedArray						: HugeStringArray;
	extractedArray					: HugeStringArray;	
	ignoreArray						: HugeStringArray;	

	tempStr							: String;	
	fileName						: String;

begin
	self.setTerminalConfig(EDIBaplieROBReplaceDef, false);
	self.setTerminalConfig(EDIBaplieROBExtRawData, false);

	create loadedArray transient;
	create extractedArray transient;
	create ignoreArray transient;

	operator := app.myRoot.allOperators["MSL"];
	self.assertNotNull(operator);
	
	// create the sailing package and bgp process
	///self.xCreatePackageTaskAutoSchedule(bgpGeneric, autoSchedule, BGP_Request.name);
	
	
	// setup the voyage
	self.deleteVoyage(VoyageId);
	voyage := self.addVoyageWithConRORO(VoyageId, VesselId, self.getProfileSetting(UT_Profile.P_OPERATOR).asString(), 
		self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), self.getProfileSetting(UT_Profile.P_TRADE).asString(), 
		0, false, true);
	self.assertNotNull(voyage);
	
	// turn off CertifiedWeightNeedsVGM
	self.setTerminalConfig(CertifiedWeightNeedsVGM, false);
	
	/*************************************************************************
	* update all vgm fields
	*************************************************************************/
	ediFile := self.ediLoadFileName(self.xVGMBayPlanBAPLIE22(1, voyage), EDIFileType_Baplie22, "BAPLIE", "BAPLIE1"&amp;method.name);
	self.assertNotNullMsg(ediFile, "10. EDI File not created - Update all VGM fields");
	
	foreach ediTI in ediFile.ediData.allEDITrackedItems do
		if not ediTI.isKindOf(CM_EDIBayPlanTI) then
			continue;
		endif;
		self.assertEqualMsg(ediTI.CM_EDIBayPlanTI.isCertifiedWeight, true, "11. Container (" &amp; ediTI.CM_EDIBayPlanTI.id &amp; ") isWeightCertified should be true");
		self.assertNotEqualMsg(ediTI.CM_EDIBayPlanTI.weightCertifiedReference, null, "12. Container (" &amp; ediTI.CM_EDIBayPlanTI.id &amp; ") weightCertifiedReference should NOT be null");
		self.assertNotEqualMsg(ediTI.CM_EDIBayPlanTI.weightCertifiedName, null, "13. Container (" &amp; ediTI.CM_EDIBayPlanTI.id &amp; ") weightCertifiedName should NOT be null");
		if ediTI.CM_EDIBayPlanTI.id = "UTMDHVGMB01" then																																	// TFS 4492
			self.assertEqualMsg(ediTI.CM_EDIBayPlanTI.vgmDocsIssuedDT.date, "24/05/2016".Date, "14. Container " &amp; ediTI.CM_EDIBayPlanTI.id &amp; ") vgmDocsIssuedDT should NOT be null");		// TFS 4492
			self.assertNotEqualMsg(ediTI.CM_EDIBayPlanTI.vgmDocumentDetails, null, "15. Container " &amp; ediTI.CM_EDIBayPlanTI.id &amp; ") vgmDocumentDetails should NOT be null");				// TFS 4492
			///self.assertNotEqualMsg(ediTI.CM_EDIBayPlanTI.vgmAuthSignature, null, "16. Container " &amp; ediTI.CM_EDIBayPlanTI.id &amp; ") vgmAuthSignature should NOT be null");					// TFS 4492
			self.assertNotEqualMsg(ediTI.CM_EDIBayPlanTI.vgmMail, null, "17. Container " &amp; ediTI.CM_EDIBayPlanTI.id &amp; ") vgmMail should NOT be null");										// TFS 4492
			self.assertNotEqualMsg(ediTI.CM_EDIBayPlanTI.vgmTelephone, null, "18. Container " &amp; ediTI.CM_EDIBayPlanTI.id &amp; ") vgmTelephone should NOT be null");							// TFS 4492
		endif;																																												// TFS 4492
	endforeach;
	
	self.ediVerify(ediFile);
	tempStr	:= 'Verify failed' &amp; CrLf &amp; app.myPassport.getErrorsAsString;
	self.assertEqualMsg(ediFile.fileStatus, CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS, tempStr);
	self.ediDBLoad(ediFile);
	tempStr	:= 'DB Load failed' &amp; CrLf &amp; app.myPassport.getErrorsAsString;
	self.assertEqualMsg(ediFile.fileStatus, CM_EDIFile.EDI_STATUS_DBLOADED, tempStr);
	
	// check the weights
	foreach ediTI in ediFile.ediData.allEDITrackedItems do
		if not ediTI.isKindOf(CM_EDIBayPlanTI) then
			continue;
		endif;
		self.assertEqualMsg(ediTI.CM_EDIBayPlanTI.weight.String, "4000.0000", "20. Container (" &amp; ediTI.CM_EDIBayPlanTI.id &amp; ") weight doesn't equal 4000.0000");
	endforeach;
	
	self.opts.purge();
	self.opts.addAssoc("ClearDetails", true);
	ediFile := self.ediLoadVerifyDBLoadActualBasic(self.xVGMBayPlanBAPLIE22(1, voyage), null, "Baplie2"&amp;method.name, EDIFileType_Baplie22, false, false, true, false, ediFile);
	
	create tiSet transient;
	voyage.getAllTrackedItems(tiSet);
	foreach obj in tiSet do
		cont := obj.CM_Container;
		self.assertEqualMsg(cont.isWeightCertified, true, "30. Container (" &amp; cont.id &amp; ") isWeightCertified should be true");
		self.assertNotEqualMsg(cont.weightCertifiedReference, null, "31. Container (" &amp; cont.id &amp; ") weightCertifiedReference should NOT be null");
		self.assertNotEqualMsg(cont.weightCertifiedName, null, "32. Container (" &amp; cont.id &amp; ") weightCertifiedName should NOT be null");
		self.assertEqualMsg(cont.totalWeight.String, "4000.0000", "33. Container (" &amp; cont.id &amp; ") weight doesn't equal 4000.0000");
		if cont.id = "UTMDHVGMB01" then																																				// TFS 4492
			self.assertNotEqualMsg(cont.myVGMDetails, null, "34. Container " &amp; cont.id &amp; ") myVGMDetails should NOT be null");														// TFS 4492
			self.assertEqualMsg(cont.myVGMDetails.vgmDocsIssuedDT.date, "24/05/2016".Date, "35. Container " &amp; ediTI.CM_EDIBayPlanTI.id &amp; ") vgmDocsIssuedDT should NOT be null");	// TFS 4492
			self.assertNotEqualMsg(cont.myVGMDetails.vgmDocumentDetails, null, "36. Container " &amp; ediTI.CM_EDIBayPlanTI.id &amp; ") vgmDocumentDetails should NOT be null");			// TFS 4492
		endif;																																										// TFS 4492
	endforeach;
	
	// extract out and compare to make sure they are they same
	delete file;
	create file transient;
	file.fileName := self.getTempDirectory() &amp; method.name &amp; ".txt";
	if file.isAvailable then
		file.purge();
	endif;
	
	bp := self.unloadBayPlan(voyage, ACTUAL_BAYPLANS, file.fileName, operator.code, operator, operator, EDIFileType_Baplie22); 
	
	// check to see that the arrays are the same
	bp.myEDIFile.getRawDataString().getTokensForDelimiterHuge(CrLf, extractedArray);
	self.xVGMBayPlanBAPLIE22(1, voyage).getTokensForDelimiterHuge(CrLf, loadedArray);
	
	ignoreArray.clear();
	ignoreArray.add("UNB+");
	ignoreArray.add("DTM+");
	ignoreArray.add("BGM+");
	ignoreArray.add("UNZ+");
	
	self.xCheckArraysMatch(loadedArray, extractedArray, ignoreArray);
	
	// call sailing package
	///self.xRunAutoTaskStopBGP(bgpGeneric, autoSchedule);
	
	///return;
	
	/*************************************************************************
	* remove certified by
	*************************************************************************/
	ediFile := self.ediLoadFileName(self.xVGMBayPlanBAPLIE22(2, voyage), EDIFileType_Baplie22, "BAPLIE", "BAPLIE3"&amp;method.name);
	self.assertNotNullMsg(ediFile, "40. EDI File not created - Update all VGM fields");
	
	foreach ediTI in ediFile.ediData.allEDITrackedItems do
		if not ediTI.isKindOf(CM_EDIBayPlanTI) then
			continue;
		endif;
		self.assertEqualMsg(ediTI.CM_EDIBayPlanTI.weightCertifiedReference, null, "41. Container (" &amp; ediTI.CM_EDIBayPlanTI.id &amp; ") weightCertifiedReference should be null");
	endforeach;
	
	self.ediVerify(ediFile);
	tempStr	:= 'Verify failed' &amp; CrLf &amp; app.myPassport.getErrorsAsString;
	self.assertEqualMsg(ediFile.fileStatus, CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS, tempStr);
	self.ediDBLoad(ediFile);
	tempStr	:= 'DB Load failed' &amp; CrLf &amp; app.myPassport.getErrorsAsString;
	self.assertEqualMsg(ediFile.fileStatus, CM_EDIFile.EDI_STATUS_DBLOADED, tempStr);
	
	// check the weights
	foreach ediTI in ediFile.ediData.allEDITrackedItems do
		if not ediTI.isKindOf(CM_EDIBayPlanTI) then
			continue;
		endif;
		self.assertEqualMsg(ediTI.CM_EDIBayPlanTI.weight.String, "4000.0000", "50. Container (" &amp; ediTI.CM_EDIBayPlanTI.id &amp; ") weight doesn't equal 4000.0000");
	endforeach;
	
	self.opts.purge();
	self.opts.addAssoc("ClearDetails", true);
	ediFile := self.ediLoadVerifyDBLoadActualBasic(self.xVGMBayPlanBAPLIE22(2, voyage), null, "Baplie4"&amp;method.name, EDIFileType_Baplie22, false, false, true, false, ediFile);
	
	tiSet.clear();
	voyage.getAllTrackedItems(tiSet);
	foreach obj in tiSet do
		cont := obj.CM_Container;
		self.assertEqualMsg(ediTI.CM_EDIBayPlanTI.weightCertifiedReference, null, "60. Container (" &amp; ediTI.CM_EDIBayPlanTI.id &amp; ") weightCertifiedReference should be null");
		self.assertEqualMsg(cont.totalWeight.String, "4000.0000", "61. Container (" &amp; cont.id &amp; ") weight doesn't equal 4000.0000");
	endforeach;
	
	// extract out and compare to make sure they are they same
	delete file;
	create file transient;
	file.fileName := self.getTempDirectory() &amp; method.name &amp; ".txt";
	if file.isAvailable then
		file.purge();
	endif;
	
	bp := self.unloadBayPlan(voyage, ACTUAL_BAYPLANS, file.fileName, operator.code, operator, operator, EDIFileType_Baplie22); 
	
	// check to see that the arrays are the same
	extractedArray.clear();
	loadedArray.clear();
	bp.myEDIFile.getRawDataString().getTokensForDelimiterHuge(CrLf, extractedArray);
	self.xVGMBayPlanBAPLIE22(2, voyage).getTokensForDelimiterHuge(CrLf, loadedArray);
	
	ignoreArray.clear();
	ignoreArray.add("UNB+");
	ignoreArray.add("DTM+");
	ignoreArray.add("BGM+");
	ignoreArray.add("UNZ+");
	
	self.xCheckArraysMatch(loadedArray, extractedArray, ignoreArray);
	
	
	/*************************************************************************
	* remove all
	*************************************************************************/
	ediFile := self.ediLoadFileName(self.xVGMBayPlanBAPLIE22(0, voyage), EDIFileType_Baplie22, "BAPLIE", "BAPLIE5"&amp;method.name);
	self.assertNotNullMsg(ediFile, "70. EDI File not created - Update all VGM fields");
	
	foreach ediTI in ediFile.ediData.allEDITrackedItems do
		if not ediTI.isKindOf(CM_EDIBayPlanTI) then
			continue;
		endif;
		self.assertEqualMsg(ediTI.CM_EDIBayPlanTI.isCertifiedWeight, false, "71. Container (" &amp; ediTI.CM_EDIBayPlanTI.id &amp; ") isWeightCertified should be false");
		self.assertEqualMsg(ediTI.CM_EDIBayPlanTI.weightCertifiedReference, null, "72. Container (" &amp; ediTI.CM_EDIBayPlanTI.id &amp; ") weightCertifiedReference should be null");
		self.assertEqualMsg(ediTI.CM_EDIBayPlanTI.weightCertifiedName, null, "73. Container (" &amp; ediTI.CM_EDIBayPlanTI.id &amp; ") weightCertifiedName should be null");
	endforeach;
	
	self.ediVerify(ediFile);
	tempStr	:= 'Verify failed' &amp; CrLf &amp; app.myPassport.getErrorsAsString;
	self.assertEqualMsg(ediFile.fileStatus, CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS, tempStr);
	self.ediDBLoad(ediFile);
	tempStr	:= 'DB Load failed' &amp; CrLf &amp; app.myPassport.getErrorsAsString;
	self.assertEqualMsg(ediFile.fileStatus, CM_EDIFile.EDI_STATUS_DBLOADED, tempStr);
	
	// check the weights
	foreach ediTI in ediFile.ediData.allEDITrackedItems do
		if not ediTI.isKindOf(CM_EDIBayPlanTI) then
			continue;
		endif;
		self.assertEqualMsg(ediTI.CM_EDIBayPlanTI.weight.String, "7000.0000", "80. Container (" &amp; ediTI.CM_EDIBayPlanTI.id &amp; ") weight doesn't equal 7000.0000");
	endforeach;
	
	self.opts.purge();
	self.opts.addAssoc("ClearDetails", true);
	ediFile := self.ediLoadVerifyDBLoadActualBasic(self.xVGMBayPlanBAPLIE22(0, voyage), null, "Baplie6"&amp;method.name, EDIFileType_Baplie22, false, false, true, false, ediFile);
	
	tiSet.clear();
	voyage.getAllTrackedItems(tiSet);
	foreach obj in tiSet do
		cont := obj.CM_Container;
		self.assertEqualMsg(cont.isWeightCertified, false, "90. Container (" &amp; cont.id &amp; ") isWeightCertified should be false");
		self.assertEqualMsg(cont.weightCertifiedReference, null, "91. Container (" &amp; cont.id &amp; ") weightCertifiedReference should be null");
		self.assertEqualMsg(cont.weightCertifiedName, null, "92. Container (" &amp; cont.id &amp; ") weightCertifiedName should be null");
		self.assertEqualMsg(cont.totalWeight.String, "7000.0000", "93. Container (" &amp; cont.id &amp; ") weight doesn't equal 7000.0000");
	endforeach;
	
	// extract out and compare to make sure they are they same
	delete file;
	create file transient;
	file.fileName := self.getTempDirectory() &amp; method.name &amp; ".txt";
	if file.isAvailable then
		file.purge();
	endif;
	
	bp := self.unloadBayPlan(voyage, ACTUAL_BAYPLANS, file.fileName, operator.code, operator, operator, EDIFileType_Baplie22); 
	
	// check to see that the arrays are the same
	bp.myEDIFile.getRawDataString().getTokensForDelimiterHuge(CrLf, extractedArray);
	self.xVGMBayPlanBAPLIE22(0, voyage).getTokensForDelimiterHuge(CrLf, loadedArray);
	
	ignoreArray.clear();
	ignoreArray.add("UNB+");
	ignoreArray.add("DTM+");
	ignoreArray.add("BGM+");
	ignoreArray.add("UNZ+");
	
	self.xCheckArraysMatch(loadedArray, extractedArray, ignoreArray);
	
	
	// turn on CertifiedWeightNeedsVGM
	self.setTerminalConfig(CertifiedWeightNeedsVGM, true);
	
	/*************************************************************************
	* update all vgm fields
	*************************************************************************/
	ediFile := self.ediLoadFileName(self.xVGMBayPlanBAPLIE22(1, voyage), EDIFileType_Baplie22, "BAPLIE", "BAPLIE7"&amp;method.name);
	self.assertNotNullMsg(ediFile, "100. EDI File not created - Update all VGM fields");
	
	foreach ediTI in ediFile.ediData.allEDITrackedItems do
		if not ediTI.isKindOf(CM_EDIBayPlanTI) then
			continue;
		endif;
		self.assertEqualMsg(ediTI.CM_EDIBayPlanTI.isCertifiedWeight, true, "110. Container (" &amp; ediTI.CM_EDIBayPlanTI.id &amp; ") isWeightCertified should be true");
		self.assertNotEqualMsg(ediTI.CM_EDIBayPlanTI.weightCertifiedReference, null, "120. Container (" &amp; ediTI.CM_EDIBayPlanTI.id &amp; ") weightCertifiedReference should NOT be null");
		self.assertNotEqualMsg(ediTI.CM_EDIBayPlanTI.weightCertifiedName, null, "130. Container (" &amp; ediTI.CM_EDIBayPlanTI.id &amp; ") weightCertifiedName should NOT be null");
	endforeach;
	
	self.ediVerify(ediFile);
	tempStr	:= 'Verify failed' &amp; CrLf &amp; app.myPassport.getErrorsAsString;
	self.assertEqualMsg(ediFile.fileStatus, CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS, tempStr);
	self.ediDBLoad(ediFile);
	tempStr	:= 'DB Load failed' &amp; CrLf &amp; app.myPassport.getErrorsAsString;
	self.assertEqualMsg(ediFile.fileStatus, CM_EDIFile.EDI_STATUS_DBLOADED, tempStr);
	
	// check the weights
	foreach ediTI in ediFile.ediData.allEDITrackedItems do
		if not ediTI.isKindOf(CM_EDIBayPlanTI) then
			continue;
		endif;
		self.assertEqualMsg(ediTI.CM_EDIBayPlanTI.weight.String, "4000.0000", "120. Container (" &amp; ediTI.CM_EDIBayPlanTI.id &amp; ") weight doesn't equal 4000.0000");
	endforeach;
	
	self.opts.purge();
	self.opts.addAssoc("ClearDetails", true);
	ediFile := self.ediLoadVerifyDBLoadActualBasic(self.xVGMBayPlanBAPLIE22(1, voyage), null, "Baplie8"&amp;method.name, EDIFileType_Baplie22, false, false, true, false, ediFile);
	
	tiSet.clear();
	voyage.getAllTrackedItems(tiSet);
	foreach obj in tiSet do
		cont := obj.CM_Container;
		self.assertEqualMsg(cont.isWeightCertified, true, "130. Container (" &amp; cont.id &amp; ") isWeightCertified should be true");
		self.assertNotEqualMsg(cont.weightCertifiedReference, null, "131. Container (" &amp; cont.id &amp; ") weightCertifiedReference should NOT be null");
		self.assertNotEqualMsg(cont.weightCertifiedName, null, "132. Container (" &amp; cont.id &amp; ") weightCertifiedName should NOT be null");
		self.assertEqualMsg(cont.totalWeight.String, "4000.0000", "133. Container (" &amp; cont.id &amp; ") weight doesn't equal 4000.0000");
	endforeach;
	
	// extract out and compare to make sure they are they same
	delete file;
	create file transient;
	file.fileName := self.getTempDirectory() &amp; method.name &amp; ".txt";
	if file.isAvailable then
		file.purge();
	endif;
	
	bp := self.unloadBayPlan(voyage, ACTUAL_BAYPLANS, file.fileName, operator.code, operator, operator, EDIFileType_Baplie22); 
	
	// check to see that the arrays are the same
	bp.myEDIFile.getRawDataString().getTokensForDelimiterHuge(CrLf, extractedArray);
	self.xVGMBayPlanBAPLIE22(1, voyage).getTokensForDelimiterHuge(CrLf, loadedArray);
	
	ignoreArray.clear();
	ignoreArray.add("UNB+");
	ignoreArray.add("DTM+");
	ignoreArray.add("BGM+");
	ignoreArray.add("UNZ+");
	
	self.xCheckArraysMatch(loadedArray, extractedArray, ignoreArray);
	
	
	/*************************************************************************
	* remove certified by
	*************************************************************************/
	ediFile := self.ediLoadFileName(self.xVGMBayPlanBAPLIE22(2, voyage), EDIFileType_Baplie22, "BAPLIE", "BAPLIE9"&amp;method.name);
	self.assertNotNullMsg(ediFile, "140. EDI File not created - Update all VGM fields");
	
	foreach ediTI in ediFile.ediData.allEDITrackedItems do
		if not ediTI.isKindOf(CM_EDIBayPlanTI) then
			continue;
		endif;
		self.assertEqualMsg(ediTI.CM_EDIBayPlanTI.weightCertifiedReference, null, "141. Container (" &amp; ediTI.CM_EDIBayPlanTI.id &amp; ") weightCertifiedReference should be null");
	endforeach;
	
	self.clearExpectedTrxErrors();
	self.expectedTrxErrors.add(Input_req_weight_certified_by);
	self.ediVerify(ediFile);
	self.assertNoTrxErrorsOrWarnings();
	
	
	/*************************************************************************
	* remove all
	*************************************************************************/
	self.clearExpectedTrxErrors();
	ediFile := self.ediLoadFileName(self.xVGMBayPlanBAPLIE22(0, voyage), EDIFileType_Baplie22, "BAPLIE", "BAPLIE10"&amp;method.name);
	self.assertNotNullMsg(ediFile, "170. EDI File not created - Update all VGM fields");
	
	foreach ediTI in ediFile.ediData.allEDITrackedItems do
		if not ediTI.isKindOf(CM_EDIBayPlanTI) then
			continue;
		endif;
		self.assertEqualMsg(ediTI.CM_EDIBayPlanTI.isCertifiedWeight, false, "171. Container (" &amp; ediTI.CM_EDIBayPlanTI.id &amp; ") isWeightCertified should be false");
		self.assertEqualMsg(ediTI.CM_EDIBayPlanTI.weightCertifiedReference, null, "172. Container (" &amp; ediTI.CM_EDIBayPlanTI.id &amp; ") weightCertifiedReference should be null");
		self.assertEqualMsg(ediTI.CM_EDIBayPlanTI.weightCertifiedName, null, "173. Container (" &amp; ediTI.CM_EDIBayPlanTI.id &amp; ") weightCertifiedName should be null");
	endforeach;
	
	self.ediVerify(ediFile);
	tempStr	:= 'Verify failed' &amp; CrLf &amp; app.myPassport.getErrorsAsString;
	self.assertEqualMsg(ediFile.fileStatus, CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS, tempStr);
	self.ediDBLoad(ediFile);
	tempStr	:= 'DB Load failed' &amp; CrLf &amp; app.myPassport.getErrorsAsString;
	self.assertEqualMsg(ediFile.fileStatus, CM_EDIFile.EDI_STATUS_DBLOADED, tempStr);
	
	// check the weights
	foreach ediTI in ediFile.ediData.allEDITrackedItems do
		if not ediTI.isKindOf(CM_EDIBayPlanTI) then
			continue;
		endif;
		self.assertEqualMsg(ediTI.CM_EDIBayPlanTI.weight.String, "7000.0000", "180. Container (" &amp; ediTI.CM_EDIBayPlanTI.id &amp; ") weight doesn't equal 7000.0000");
	endforeach;
	
	self.opts.purge();
	self.opts.addAssoc("ClearDetails", true);
	ediFile := self.ediLoadVerifyDBLoadActualBasic(self.xVGMBayPlanBAPLIE22(0, voyage), null, "Baplie11"&amp;method.name, EDIFileType_Baplie22, false, false, true, false, ediFile);
	
	tiSet.clear();
	voyage.getAllTrackedItems(tiSet);
	foreach obj in tiSet do
		cont := obj.CM_Container;
		self.assertEqualMsg(cont.isWeightCertified, false, "190. Container (" &amp; cont.id &amp; ") isWeightCertified should be false");
		self.assertEqualMsg(cont.weightCertifiedReference, null, "191. Container (" &amp; cont.id &amp; ") weightCertifiedReference should be null");
		self.assertEqualMsg(cont.weightCertifiedName, null, "192. Container (" &amp; cont.id &amp; ") weightCertifiedName should be null");
		self.assertEqualMsg(cont.totalWeight.String, "7000.0000", "193. Container (" &amp; cont.id &amp; ") weight doesn't equal 7000.0000");
	endforeach;
	
	// extract out and compare to make sure they are they same
	delete file;
	create file transient;
	file.fileName := self.getTempDirectory() &amp; method.name &amp; ".txt";
	if file.isAvailable then
		file.purge();
	endif;
	
	bp := self.unloadBayPlan(voyage, ACTUAL_BAYPLANS, file.fileName, operator.code, operator, operator, EDIFileType_Baplie22); 
	
	// check to see that the arrays are the same
	bp.myEDIFile.getRawDataString().getTokensForDelimiterHuge(CrLf, extractedArray);
	self.xVGMBayPlanBAPLIE22(0, voyage).getTokensForDelimiterHuge(CrLf, loadedArray);
	
	ignoreArray.clear();
	ignoreArray.add("UNB+");
	ignoreArray.add("DTM+");
	ignoreArray.add("BGM+");
	ignoreArray.add("UNZ+");
	
	self.xCheckArraysMatch(loadedArray, extractedArray, ignoreArray);
	
epilog

	app.myPassport.setWarningsAcknowledged(false);

	delete tiSet;
	delete loadedArray;
	delete extractedArray;
	delete ignoreArray;
	delete file;

end;</source>
    </JadeMethod>
    <JadeMethod name="tVGMCargoFieldUpdate" id="7650c5a8-f802-44dc-8e2b-787a5e6a2594">
        <source>tVGMCargoFieldUpdate();

/*

Purpose:		Check that loading of Cargo Field Update 

Date			Who		Reason
19/05/2016		cnwmh5	Initial creation

*/

constants

	ContainerId						: String = "UTMDHVGM001";
	UserDefinedCargoFieldUpdate		: String = "Unit Test VGMCargoFieldUpdate";

vars

	cont							: CM_Container;
	operator						: CM_Operator;
	ediFile							: CM_EDIFile;
	tiTransaction					: CM_TITransaction;

begin

	// create user defined file type
	self.createUserDefinedFileType(UserDefinedCargoFieldUpdate, self.xmlDef_CargoFieldUpdateVGM(UserDefinedCargoFieldUpdate));
	
	// create 2 containers
	cont := self.addContainer(ContainerId, operator, "2200", "GENL", TI_IMEX_STATUS_IMPORT).CM_Container;
	self.assertNotNull(cont);
	self.assertEqualMsg(cont.isWeightCertified, false, "1. Container (" &amp; cont.id &amp; ") isWeightCertified should be false");
	self.assertEqualMsg(cont.weightCertifiedReference, null, "2. Container (" &amp; cont.id &amp; ") weightCertifiedReference should be null");
	self.assertEqualMsg(cont.weightCertifiedName, null, "3. Container (" &amp; cont.id &amp; ") weightCertifiedName should be null");
	
	// turn off CertifiedWeightNeedsVGM
	self.setTerminalConfig(CertifiedWeightNeedsVGM, false);
	
	// set all vgm fields
	ediFile := self.ediLoadVerifyDBLoadActualBasic(self.xVGMCargoFieldUpdateDetails(1, cont.id), UserDefinedCargoFieldUpdate, UserDefinedCargoFieldUpdate&amp;'1'&amp;method.name, EDIFileType_UserDefined, 
		true, true, false, false, null);
	self.assertNotNullMsg(ediFile, "10. EDI File not created - Update all VGM fields");
	self.assertEqualMsg(cont.isWeightCertified, true, "11. Container (" &amp; cont.id &amp; ") isWeightCertified should be true");
	self.assertNotEqualMsg(cont.weightCertifiedReference, null, "12. Container (" &amp; cont.id &amp; ") weightCertifiedReference should NOT be null");
	self.assertNotEqualMsg(cont.weightCertifiedName, null, "13. Container (" &amp; cont.id &amp; ") weightCertifiedName should NOT be null");
		
	// remove certified by
	ediFile := self.ediLoadVerifyDBLoadActualBasic(self.xVGMCargoFieldUpdateDetails(2, cont.id), UserDefinedCargoFieldUpdate, UserDefinedCargoFieldUpdate&amp;'2'&amp;method.name, EDIFileType_UserDefined, 
		true, true, false, false, null);
	self.assertNotNullMsg(ediFile, "20. EDI File not created - Update all VGM fields");
	self.assertEqualMsg(cont.weightCertifiedReference, null, "21. Container (" &amp; cont.id &amp; ") weightCertifiedReference should be null");
	tiTransaction := cont.allTransactions.last;
	self.assertTrueMsg(tiTransaction.isKindOf(CM_Edit), "22. Container (" &amp; cont.id &amp; ")'s last transaction should be a CM_Edit");
	self.assertFalseMsg(tiTransaction.CM_Edit.fieldsValues.compareIDStrings("weightCertifiedReference"), "23. Container (" &amp; cont.id &amp; ")'s last transaction is not for weightCertifiedReference");
	
	// remove all vgm fields
	ediFile := self.ediLoadVerifyDBLoadActualBasic(self.xVGMCargoFieldUpdateDetails(0, cont.id), UserDefinedCargoFieldUpdate, UserDefinedCargoFieldUpdate&amp;'3'&amp;method.name, EDIFileType_UserDefined, 
		true, true, false, false, null);
	self.assertNotNullMsg(ediFile, "30. EDI File not created - Update all VGM fields");
	self.assertEqualMsg(cont.isWeightCertified, false, "31. Container (" &amp; cont.id &amp; ") isWeightCertified should be false");
	self.assertEqualMsg(cont.weightCertifiedReference, null, "32. Container (" &amp; cont.id &amp; ") weightCertifiedReference should be null");
	self.assertEqualMsg(cont.weightCertifiedName, null, "33. Container (" &amp; cont.id &amp; ") weightCertifiedName should be null");
	
	// turn on CertifiedWeightNeedsVGM
	self.setTerminalConfig(CertifiedWeightNeedsVGM, true);
	
	// set all vgm fields
	ediFile := self.ediLoadVerifyDBLoadActualBasic(self.xVGMCargoFieldUpdateDetails(1, cont.id), UserDefinedCargoFieldUpdate, UserDefinedCargoFieldUpdate&amp;'4'&amp;method.name, EDIFileType_UserDefined, 
		true, true, false, false, null);
	self.assertNotNullMsg(ediFile, "10. EDI File not created - Update all VGM fields");
	self.assertEqualMsg(cont.isWeightCertified, true, "11. Container (" &amp; cont.id &amp; ") isWeightCertified should be true");
	self.assertNotEqualMsg(cont.weightCertifiedReference, null, "12. Container (" &amp; cont.id &amp; ") weightCertifiedReference should NOT be null");
	self.assertNotEqualMsg(cont.weightCertifiedName, null, "13. Container (" &amp; cont.id &amp; ") weightCertifiedName should NOT be null");
		
	// remove certified by
	ediFile := self.ediLoadVerifyDBLoadActualBasic(self.xVGMCargoFieldUpdateDetails(2, cont.id), UserDefinedCargoFieldUpdate, UserDefinedCargoFieldUpdate&amp;'5'&amp;method.name, EDIFileType_UserDefined, 
		false, false, false, false, null);
	self.assertNotNullMsg(ediFile, "20. EDI File not created - Update all VGM fields");
	
	self.clearExpectedTrxErrors();
	self.expectedTrxErrors.add(Input_req_weight_certified_by);
	self.ediVerify(ediFile);
	self.assertNoTrxErrorsOrWarnings();
		
	// remove all vgm fields
	self.clearExpectedTrxErrors();
	ediFile := self.ediLoadVerifyDBLoadActualBasic(self.xVGMCargoFieldUpdateDetails(0, cont.id), UserDefinedCargoFieldUpdate, UserDefinedCargoFieldUpdate&amp;'6'&amp;method.name, EDIFileType_UserDefined, 
		true, true, false, false, null);
	self.assertNotNullMsg(ediFile, "30. EDI File not created - Update all VGM fields");
	self.assertEqualMsg(cont.isWeightCertified, false, "31. Container (" &amp; cont.id &amp; ") isWeightCertified should be false");
	self.assertEqualMsg(cont.weightCertifiedReference, null, "32. Container (" &amp; cont.id &amp; ") weightCertifiedReference should be null");
	self.assertEqualMsg(cont.weightCertifiedName, null, "33. Container (" &amp; cont.id &amp; ") weightCertifiedName should be null");

epilog

end;</source>
