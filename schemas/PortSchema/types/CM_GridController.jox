    <JadeMethod name="testIsDiffDischPort" id="17d8654e-7d82-409b-be6c-4bcd11ef1325">
        <source>testIsDiffDischPort(obj: CMIF_AutoMovePlan input);
//In this case, we are testing 40' next LC as well as this LC.
//ASSUMPTIONS:
//That testIsControllerFull method has been called (it checks for differing heights)
//	Changed On	By			Reason
// 	----------	--------	--------------------------------------
//	12/05/2010	cnwdap1		CCMS 1116 Tranship changes
vars
	topTI : CM_TrackedItem;
	tmpMoveMode : Integer;
	numControllers  : Real;
begin

	if obj.isTestToBeDone(TI_Test_DischargePort, self) = false then
		return;
	endif;
	//----------------
	//PAR5395. DQ. ONLY complain about discharge port if we are NOT a stored MT
	//----------------
	if obj.myTrackedItem.isStorage then
		if obj.myTrackedItem.isAttributeTrue(TI_Attrib_IsEmpty) then
			return;
		endif;
	endif;
	
	obj.updateController(null);
 	//----------------
 	//Call method to retrieve the topmost TI
 	//----------------
	topTI := getTopTI(obj.moveMode);	

	if topTI = null and obj.moveMode &lt;&gt; REAL_MODE then
	 	//----------------
		//Test for a real mode TI
	 	//----------------
	 	tmpMoveMode := REAL_MODE;
		topTI := self.getTopTI(tmpMoveMode);	
	endif;

	if topTI = null then
	 	//----------------
		//None Here. (if 40, than the same MUST be true, see Assumption above).
	 	//----------------
		obj.updateController(self);
		return;
	endif;
	if not obj.myTrackedItem.hasSameUnderStowAttribute(topTI, TI_Test_DischargePort) then
		//obj.addLogEntry("Discharge Port of item underneath is different.", IsWarning);
		obj.addLogEntry(app.getErrorString(Discha_port_item_undern_differ), IsWarning, Discha_port_item_undern_differ);
		return;
	endif;
	//-------------
	//Check 40'
	//-------------
	numControllers := self.calculateMoveLCs(obj.myTrackedItem);
	if numControllers &gt; 1 and not obj.checkingSecondary then
		if self.myNextController = null then // AKBJULY2002 removed not
			obj.addVerboseLogEntry(app.getErrorString(Next_positi_contai_longer_than), IsError, Next_positi_contai_longer_than);// PAR 17386 
			return;	//No next position. 40' cannot go here.
		endif;
		if self.myNextController.isSuitableForTI(obj) = false then
			//epr par 31492 14/8/13 if not auto planned this error has already been raised and reported
			if obj.isAutoPlanMove then
				obj.addVerboseLogEntry(app.getErrorString1(Suitab_contai_longer_than_foot,self.getFullId), obj.getLogType, Suitab_contai_longer_than_foot); // PAR 5723 PAR 17386	
			endif;
			return;
		endif;
		obj.checkingSecondary := true;
		self.myNextController.testIsDiffDischPort(obj);		
		obj.checkingSecondary := false;
		if obj.getController = null then
			//----------------
			//Next disch port is incorrect
			//----------------
			return;
		endif;
	endif;
	//----------------
	//Disch port is same.
	//----------------
	obj.updateController(self);
end;</source>
        <Parameter name="obj" type="CMIF_AutoMovePlan" usage="input"/>
    </JadeMethod>
    <JadeMethod name="testIsDiffDischPortYA" id="a15f8c69-dbee-40f0-9769-06e594f88ffb">
        <source>testIsDiffDischPortYA(_yaAgent: CM_YAAutoplanAgent input): Boolean;
// -------------------------------------------
// Created 10 May 2005 by cnwdvb1
// -------------------------------------------
//	Changed On	By			Reason
// 	----------	--------	--------------------------------------
//	12/05/2010	cnwdap1		CCMS 1116 Tranship changes
vars
/*
	topTI 			: CM_TrackedItem;
	tmpMoveMode		: Integer;
	numControllers	: Real;
	rtnValue		: Boolean;
	*/
begin

	//cnwrd1 par 28295 13.10.2011
	// this test seems unused now. 
	//autoPlanTest settings are deimplimented will just return false now.
	
	return false;
	/*

	// Always seems to test voyage in old auto planning so doing 
	// the same.
	if not self.myTerminalArea.autoPlanTest.testDischargePort then
		return false;
	endif;
	
	topTI := self.getTopTI(QUEUE_MODE);	

	// Changed 09/05/06 DVB
	if topTI = null then
		topTI := self.getTopTI(PLANNING_MODE);	
	endif;

	if topTI = null then
	 	//----------------
		//Test for a real mode TI
	 	//----------------
	 	tmpMoveMode := REAL_MODE;
		topTI := self.getTopTI(tmpMoveMode);	
	else
		// Par 12313
		//if topTI.myTranshipExport &lt;&gt; null then	// PAR #23645 CCMS 1116
			//topTI := topTI.myTranshipExport;		// PAR #23645 CCMS 1116
		//endif;									// PAR #23645 CCMS 1116
	endif;

	if topTI = null then
	 	return false;
	endif;
	
	//--------------
	//At least 1 TI here, check its discharge port
	//--------------
	if not _yaAgent.myCurrentCMIFYAAutoPlan.hasSameUnderStowAttribute(topTI, TI_Test_DischargePort) then
		_yaAgent.addLogEntry("Operator of item underneath is different", true);
		return true;
	endif;
	

	
	return false;
	*/
end;</source>
        <Parameter name="_yaAgent" type="CM_YAAutoplanAgent" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="testIsDiffIMEX" id="3f3559bd-559b-4614-b381-a37e8af600b4">
        <source>testIsDiffIMEX(obj: CMIF_AutoMovePlan input);
//In this case, we are testing 40' next LC as well as this LC.
//ASSUMPTIONS:
//That testIsControllerFull method has been called (it checks for differing heights)
//	Changed On	By			Reason
// 	----------	--------	--------------------------------------
//	12/05/2010	cnwdap1		CCMS 1116 Tranship changes
vars
	topTI : CM_TrackedItem;
	tmpMoveMode : Integer;
	numControllers : Real;
begin

	if obj.isTestToBeDone(TI_Test_ImExStatus, self) = false then
		return;
	endif;

	obj.updateController(null);
 	//----------------
 	//Call method to retrieve the topmost TI
 	//----------------
	topTI := getTopTI(obj.moveMode);	

	if topTI = null and obj.moveMode &lt;&gt; REAL_MODE then
	 	//----------------
		//Test for a real mode TI
	 	//----------------
	 	tmpMoveMode := REAL_MODE;
		topTI := getTopTI( tmpMoveMode);	
	endif;

	if topTI = null then
	 	//----------------
		//None Here. (if 40, than the same MUST be true, see Assumption above).
	 	//----------------
		obj.updateController(self);
		return;
	endif;
	//--------------
	//At least 1 TI here, check its IMEX Status
	//--------------
	if not obj.myTrackedItem.hasSameUnderStowAttribute(topTI, TI_Test_ImExStatus) then
		//obj.addLogEntry("IMEX Status of item underneath is different", IsWarning); //- cnwmd1, Par 20524
		obj.addLogEntry(app.getErrorString(Imex_status_item_undern_differ), IsWarning, Imex_status_item_undern_differ);
		return;
	endif;
	//-------------
	//Check 40'
	//-------------
	numControllers := self.calculateMoveLCs(obj.myTrackedItem);
	if numControllers &gt; 1 and not obj.checkingSecondary then
		if self.myNextController = null then // AKBJULY2002 removed not
			obj.addVerboseLogEntry(app.getErrorString(Next_positi_contai_longer_than), IsError, Next_positi_contai_longer_than);// PAR 17386 
			return;	//No next position. 40' cannot go here.
		endif;
		if self.myNextController.isSuitableForTI(obj) = false then
			//epr par 31492 14/8/13 if not auto planned this error has already been raised and reported
			if obj.isAutoPlanMove then
				obj.addVerboseLogEntry(app.getErrorString1(Suitab_contai_longer_than_foot,self.getFullId), obj.getLogType, Suitab_contai_longer_than_foot); // PAR 5723 PAR 17386			
			endif;
			return;
		endif;
		obj.checkingSecondary := true;
		self.myNextController.testIsDiffIMEX(obj);		
		obj.checkingSecondary := false;
		if obj.getController = null then
			//----------------
			//Next IMEX Status is different
			//----------------
			return;
		endif;
	endif;
	//----------------
	//IMEX is same.
	//----------------
	obj.updateController(self);

end;</source>
        <Parameter name="obj" type="CMIF_AutoMovePlan" usage="input"/>
    </JadeMethod>
    <JadeMethod name="testIsDiffIMEXYA" id="cbcaaf62-f42a-4a77-880b-9e0afe93d32d">
