    <JadeMethod name="updateMovementToController" id="74d01673-07ff-4846-b2d4-c2f2833976f8">
        <updating/>
        <source>updateMovementToController(_cntrl:HMS_GraphicalDragPicture input; _theMovement : CMIF_HMS_WorkingMovement;
							_useInputMarks, _usePreferedMarks : Boolean;
							_newBerth : HMS_Berth; _newBow, _newStern : Decimal):Boolean updating;
vars
	origMovement,
	origMovementNext,
	clonedMovement,
	clonedMovementNext,
	movementUndoPair,
	movementRedoPair	: CMIF_HMS_WorkingMovement;	// Modified by Russell 08/04/99	
	origVoyage,
	clonedVoyage		: CMIF_HMS_WorkingVoyage;
	ts1,ts2				: TimeStamp;
	berth				: HMS_Berth;
	prevMoveObj			: CMIF_HMS_WorkingMovement;
	timeDiff			: Integer;
	
begin
	// this method validates and saves changes
	if _theMovement = null then
		return false;
	endif;

	on CM_Exception do app.validationExHandler(exception, app.myPassport);
	app.setContinueCMExceptions(true);
	app.myPassport.clearErrorsWarnings();
	
	// Clone voyage and movements
	origMovement := _theMovement;
	origVoyage := origMovement.myWorkingVoyage;
	origMovementNext := origMovement.getMovementNext();

	clonedVoyage := origVoyage.createClone();
	if clonedVoyage = null then
		return false;
	endif;

	clonedMovement := origMovement.myClone;
	if clonedMovement = null then
		return false;
	endif;
	
	prevMoveObj			:=	clonedMovement.getMovementPrevious();
	clonedMovementNext	:=	clonedMovement.getMovementNext();

	// Update properties that have changed on the cloned movements
	// NOTE: Find cloned movements by origMovement.myClone
	// berth, bow/stern marks/ occursOnDT
	// For each movement that you change properties on, set the clonedMovement.cloneHasChanged property to true

	// get the timestamp values for the changes...
	if (not _useInputMarks) then
		if (not self.getTimeValuesForPosition(_cntrl, ts1, ts2)) then
 			return false;
 		endif;
 		
 		//added by cnwyl1 29052006 for par 11829. It is to validate whether the depart date is before the arrival date.
 		if ts1.isValid
		and ts2.isValid
		and (ts1 &gt;= ts2)
		then
			app.raiseCMException1(AutoScheduleDateError, "The arrival date/time must be before the departure date/time", null, null);
		endif;

	endif;
	
	if _useInputMarks then
		// remarks/meter marks are changing for the sprites current movement.
		clonedMovement.myBerth := _newBerth;
		clonedMovement.bowMarkTo := _newBow;
		clonedMovement.sternMarkTo := _newStern;
 		clonedMovement.cloneHasChanged 	:= true;

	elseif _cntrl.origEdge = HMS_Edge_Top then
		// the occurs on date is changing for the sprites next movement
		// Modified by Russell 17/03/99
		if self.controlMoveStyle = Move_WE or self.controlMoveStyle = Move_None then
 			// Do not change date if lock or WE movement only buttons are on
		else
			if clonedMovementNext &lt;&gt; null then
				clonedMovementNext.clonedMove_SetActualTimeIfReqd(ts2); // Modified by Russell 11/08/99
				clonedMovementNext.occursOnDT 	:= ts2;
			//	clonedMovementNext.occursOnDT.
				clonedMovementNext.cloneHasChanged:= true;
			endif;
		endif;
	elseif _cntrl.origEdge = HMS_Edge_Bottom then
		// Modified by Russell 17/03/99
		if self.controlMoveStyle = Move_WE or self.controlMoveStyle = Move_None then
 			// Do not change date if lock or WE movement only buttons are on
		else
			// the occurs on date is changing for the sprites current movement
			clonedMovement.clonedMove_SetActualTimeIfReqd(ts1); // Modified by Russell 11/08/99
			clonedMovement.occursOnDT 		:= ts1;
			clonedMovement.cloneHasChanged	:= true;
		endif;
	else
		// the occurs on date and meter marks are changing for the sprites current movement.
		
		if origMovementNext &lt;&gt; null then
			// We have dragged the whole sprite so the time difference should be the same.
			// BUT we cannot rely on getting the time back from the pixrl position due to
			// rounding errors (refer PAR 15965)
			timeDiff := _theMovement.occursOnDT.getDifferenceInMinutes(origMovementNext.occursOnDT);
			ts2 := ts1.addMinutes(timeDiff);
		endif;

		self.getSpritePositionForUpdate(_cntrl, clonedMovement, berth, _usePreferedMarks);
		if berth = null then
			app.msgBox(app.getErrorString(HMS_CannotMove), app.getErrorString(HMS_Berth_Not_Found), MsgBox_Information_Icon + MsgBox_OK_Only);
			return false;
		endif;
		clonedMovement.myBerth := berth;
		// Modified by Russell 17/03/99
		if self.controlMoveStyle = Move_WE then
 			// Do not change date as WE movement only buttons is on
 			clonedMovement.cloneHasChanged 	:= true;
			// Modified by Russell 08/04/99
			// --------------------------------------------------------------
			// Set reference to movement that has been changed as part of a pair
			// NOTE: The redoNext property will be set to true on the Stackchange obj
			//movementRedoPair:=clonedMovement; - Modified by Russell 14/10/99
			// --------------------------------------------------------------
 		elseif self.controlMoveStyle = Move_None then
 			// Do not change movement - lock on
		else
			clonedMovement.clonedMove_SetActualTimeIfReqd(ts1); // Modified by Russell 11/08/99
			clonedMovement.occursOnDT 		:= ts1;
			clonedMovement.cloneHasChanged 	:= true;
			// Modified by Russell 08/04/99
			// --------------------------------------------------------------
			// Set reference to movement that has been changed as part of a pair
			// NOTE: The redoNext property will be set to true on the Stackchange obj
			movementRedoPair := clonedMovement;
			// --------------------------------------------------------------
		endif;

		// the occurs on date is changing for the sprites next movement
		if clonedMovementNext &lt;&gt; null then
			// Modified by Russell 17/03/99
			if controlMoveStyle=Move_WE or controlMoveStyle=Move_None then
 				// Do not change date if lock or WE movement only buttons are on
			else
				clonedMovementNext.clonedMove_SetActualTimeIfReqd(ts2); // Modified by Russell 11/08/99
				clonedMovementNext.occursOnDT		:= ts2;
				clonedMovementNext.cloneHasChanged 	:= true;
				// Modified by Russell 08/04/99
				// --------------------------------------------------------------
				// Set reference to movement that has been changed as part of a pair
				// NOTE: The undoNext property will be set to true on the Stackchange obj
				movementUndoPair:=clonedMovementNext;
				// --------------------------------------------------------------
			endif;
		endif;
	endif;
	
	if (clonedMovement.moveType = HMSMovementTypeShift
	or clonedMovement.moveType = HMSMovementTypeDeparture)
	and prevMoveObj &lt;&gt; null
	and prevMoveObj.myBerth &lt;&gt; null
	and clonedMovement.myBerth &lt;&gt; null
	and prevMoveObj.myBerth = clonedMovement.myBerth
	then
// cnwdad1 12/09/2008 - PAR #17927.
		if clonedMovement.bowMarkTo = prevMoveObj.bowMarkTo
		and clonedMovement.sternMarkTo = prevMoveObj.sternMarkTo
		then
			app.raiseCMException(Movement_Is_To_Same_Berth, null, null);
		endif;
	endif;
	
	//	Validate voyage
	// changed by cnwyl1 04072006 for PAR (cnwdad1 - I think this was PAR 11829)
/*	if (not clonedVoyage.validateVoyage(true)) then
		return false;
	endif;

	if app.myPassport.hasErrorsOrWarnings() then
		if app.showErrorWarningDialog('Update Movement', app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings) = IDOK then
			//Warnings have been accepted
		else
			self.setAllErrorWarnings(app.myPassport);
			return false;
		endif;
	endif;
	self.clearErrorWarnings();*/

	if (not clonedVoyage.validateVoyage(self.myHarbour.isDoClearanceCheck)) then
		return false;
	endif;
	
	if app.myPassport.hasErrorsOrWarnings() then
		if app.showErrorWarningDialog('Update Movement', app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings) = IDOK then
			//Warnings have been accepted
		else
			self.setAllErrorWarnings(app.myPassport);
			return false;
		endif;
	endif;
	self.clearErrorWarnings();


	// disarm the validation ex handler	
	on CM_Exception do null;

	// Update views following the result of the validation
	foreach clonedMovement in clonedVoyage.allClonedMovements where clonedMovement.cloneHasChanged do
		if clonedMovement = movementUndoPair then
			clonedMovement.createWorkingMovement(null,true,false, false);
		elseif clonedMovement = movementRedoPair then
			clonedMovement.createWorkingMovement(null,false,true, false);
		else
			clonedMovement.createWorkingMovement(null,false,false, false);
		endif;
	endforeach;

	self.myViewController.view_BuildEntireForeground();
	return true;
epilog
	// Delete clonedVoyage, resources and movements
	if clonedVoyage &lt;&gt; null then
		
		foreach clonedMovement in clonedVoyage.allClonedMovements do
			clonedMovement.allWorkingResUsed.purge();
		endforeach;
		
		clonedVoyage.allClonedMovements.purge();
		delete clonedVoyage;
	endif;
end;</source>
        <Parameter name="_cntrl" type="HMS_GraphicalDragPicture" usage="input"/>
        <Parameter name="_theMovement" type="CMIF_HMS_WorkingMovement"/>
        <Parameter name="_useInputMarks" type="Boolean"/>
        <Parameter name="_usePreferedMarks" type="Boolean"/>
        <Parameter name="_newBerth" type="HMS_Berth"/>
        <Parameter name="_newBow" type="Decimal"/>
        <Parameter name="_newStern" type="Decimal"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="updateProgress" id="78185e43-f4b3-4730-b6a9-7cec30f66709">
        <updating/>
        <source>updateProgress(_cmifMonitor: CMIF_Monitor input) updating;
//--------------------------------------------------
// Created:	08 December 2004 By: cnwgd1
//--------------------------------------------------
vars
	startLocal,
	endLocal:	TimeStamp;
begin
	inheritMethod(_cmifMonitor);
	
	if self.btnModalDefault.visible = false then
		// the below update has already been done
		return;
	endif;
	
	if self.modalDialogReturnValue = self.ModalDialogReturn_Default then
		self.mousePointer := Window.MousePointer_HourGlass;
		//user has cancelled refresh
		self.doRangeSelectorResetDateTime(true);
		self.modalDialogShow(null, null, null, null, 'Changing Date Range',  'Please Wait....');
		
		//Check we have a valid date range and if so, make the change.
//		self.myViewController.viewStartDT.setDate(self.tblSearch.getValueByName(ETRow_FromDate).Date);
		startLocal.setDate(self.tblSearch.getValueAsDate(ETRow_FromDate));
		startLocal.setTime(self.tblSearch.getValueByName(ETRow_FromTime).Time);	// 31/5/16 cnwmp6 TFS 488 - Multi timezone support
		self.myViewController.viewStartDT := self.localToSystemTime(startLocal);
		
//		self.myViewController.viewFinishDT.setDate(self.tblSearch.getValueByName(ETRow_ToDate).Date);
		endLocal.setDate(self.tblSearch.getValueAsDate(ETRow_ToDate));
		endLocal.setTime(self.tblSearch.getValueByName(ETRow_ToTime).Time);		// 31/5/16 cnwmp6 TFS 488 - Multi timezone support
		self.myViewController.viewFinishDT := self.localToSystemTime(endLocal);
		
		// Refresh the visit view as a result of the changed view range dates
		self.myViewController.doRefreshView(true);
		self.doResize();
		self.mousePointer := Window.MousePointer_Default;
	endif;
end;</source>
        <Parameter name="_cmifMonitor" type="CMIF_Monitor" usage="input"/>
    </JadeMethod>
    <JadeMethod name="userNotify" id="55b2da24-5961-45d8-bcb6-aacd280918f6">
