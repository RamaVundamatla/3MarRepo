    <JadeMethod name="doSave" id="06123ed1-7382-4fbe-85ae-fdcdbf89e431">
        <updating/>
        <source>doSave() : Boolean protected, updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 April 2012	cnwndl1	Initial creation

*/

vars

	pxyPilotExemption : HMS_PilotExemptionCertificate;
	loadStateSet : Boolean;
	vessel : CM_Vessel;
	certifiedDate : Date;
	expiryDate : Date;
	revalidateDate : Date;
	validatingPilot : HMS_Pilot;
	result : Integer;

begin

	if self.myPilotExemptionCertificate = null then
		create pxyPilotExemption transient;
	else
		app.cmsBeginLoad( loadStateSet );
		pxyPilotExemption := self.myPilotExemptionCertificate.pxyCreateUpdateProxy();
		app.cmsEndLoad( loadStateSet );
	endif;
	
	vessel := self.cmbVessel.listObject.CM_Vessel;
	certifiedDate := self.txtCertified.getDate;
	expiryDate := self.txtExpiry.getDate;
	revalidateDate := self.txtReValidate.getDate;
	validatingPilot := self.cmbValidated.listObject.HMS_Pilot;
	
	pxyPilotExemption.setProxy(	certifiedDate,	//_certifiedDate : Date;
								expiryDate,	//_expiryDate : Date;
								revalidateDate,	//_revalidationDate : Date;
								vessel,	//_myVessel : CM_Vessel;
								validatingPilot,	//_myValidatedBy : HMS_Pilot;
								self.myHarbour,	//_myHarbour : HMS_Harbour;
								self.myMaster	//_myMaster : HMS_Master
								);
								
	while true do	
	
		if self.myPilotExemptionCertificate = null then
			//creating
			app.myTrxCA.trxCreatePilotExemptCert(pxyPilotExemption, self.myPilotExemptionCertificate, app.myPassport);
		else
			//updating
			app.myTrxUA.trxUpdatePilotExemptCert(pxyPilotExemption, app.myPassport);
		endif;
		
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			return true;
		else
			result := app.showErrorWarningDialog(self.caption, app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				// there must have just been warnings that the user has acknowledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
		endif;
		return false;
		
	endwhile;
	
	return false;
	
epilog

	delete pxyPilotExemption;

end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="populateCombos" id="82eebf30-2005-417f-9b6c-e02c293c5718">
        <source>populateCombos() protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27/04/2012	cnwndl1	Initial creation	Par 29496
17/07/2018	jlgdap1	TFS 39685 PEL1 Pilots vs Harbours
*/

vars

	newIndex : Integer;
	vessel : CM_Vessel;
	failedDAC : CM_DataAccessController;
	localVessel : CM_Vessel;

begin

	if self.myPilotExemptionCertificate &lt;&gt; null then
		localVessel := self.myPilotExemptionCertificate.myVessel;
	endif;

	self.cmbVessel.clear();
	foreach vessel in app.myRoot.allVessels do
		if vessel.isPilotExempt( self.myHarbour ) then
			//don't show vessels that don't need an exemption
			if vessel &lt;&gt; localVessel then
				// unless we already have an exemption for it.
				continue;
			endif;
		endif;
		if not vessel.canUserAccessSelf(null, failedDAC, app.myPassport) then
			if vessel &lt;&gt; localVessel then
				// unless we already have an exemption for it.
				continue;
			endif;
		endif;
		
		newIndex	:=	self.cmbVessel.addItem(self.myAssistant.displayEntryVessel(vessel));
		self.cmbVessel.itemObject[newIndex]	:=	vessel;
	endforeach;
	
	self.cmbValidated.clear();
	//self.myAssistant.comboBoxHMSPilot(self.cmbValidated, null);								// TFS 39685
	self.myAssistant.comboBoxHMSPilot(self.cmbValidated, null, self.myTerminal.myHarbour);		// TFS 39685

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="populateFields" id="cae3d589-920c-4596-b17a-6b3b0a00cba6">
        <source>populateFields() protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 April 2012	cnwndl1	Initial creation	Par 29496

*/

vars

begin

	if self.myMaster = null then
		self.lblName.caption := null;
	else
		self.lblName.caption := app.getErrorString1(Pilot_exempti_certifi_details,self.myMaster.description);
	endif;

	if self.myPilotExemptionCertificate = null then
		self.cmbVessel.listIndex := -1;
		self.lblLoaGrt.caption := null;
		self.txtCertified.setDate(null);
		self.txtExpiry.setDate(null);
		self.txtReValidate.setDate(null);
		self.cmbValidated.listIndex := -1;
		
	else
		if self.myPilotExemptionCertificate.myVessel = null then
			self.cmbVessel.listIndex := -1;
			self.lblLoaGrt.caption := null;
		else
			self.cmbVessel.listIndex := self.cmbVessel.findObject(self.myPilotExemptionCertificate.myVessel);
			self.cmbVessel.click( self.cmbVessel );
		endif;
		
		self.txtCertified.setDate(self.myPilotExemptionCertificate.certifiedDate);
		self.txtExpiry.setDate(self.myPilotExemptionCertificate.expiryDate);
		self.txtReValidate.setDate(self.myPilotExemptionCertificate.revalidationDate);
		if self.myPilotExemptionCertificate.myValidatedBy = null then
			self.cmbValidated.listIndex := -1;
		else
			self.cmbValidated.listIndex := self.cmbValidated.findObject(self.myPilotExemptionCertificate.myValidatedBy);
		endif;
	
	endif;

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setMyMasterAndHarbour" id="192857a1-7757-4e02-ad9b-750e174f8104">
        <updating/>
        <source>setMyMasterAndHarbour( _myMaster : HMS_Master; _myHarbour : HMS_Harbour ) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 April 2012	cnwndl1	Initial creation	Par 29496

*/

vars

begin

	self.myMaster := _myMaster;
	self.myHarbour := _myHarbour;
	if self.myTerminal = null then
		self.myTerminal := app.getMyTerminalDO_NOT_USE;
		if self.myTerminal = null then
			self.myTerminal := self.myHarbour.allTerminalsByCode.first;
		endif;
	endif;

epilog

end;</source>
        <Parameter name="_myMaster" type="HMS_Master"/>
        <Parameter name="_myHarbour" type="HMS_Harbour"/>
    </JadeMethod>
    <JadeMethod name="setMyPilotExemptionCertificate" id="928abc61-bfdc-4636-b0da-804af9cbe005">
        <updating/>
        <source>setMyPilotExemptionCertificate( _myPilotExemptionCertificate : HMS_PilotExemptionCertificate ) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 April 2012	cnwndl1	Initial creation

*/

vars

begin

	self.myPilotExemptionCertificate := _myPilotExemptionCertificate;
	
	if self.myPilotExemptionCertificate &lt;&gt; null then
		self.setMyMasterAndHarbour( self.myPilotExemptionCertificate.myMaster, self.myPilotExemptionCertificate.myHarbour );
	endif;

epilog

end;</source>
        <Parameter name="_myPilotExemptionCertificate" type="HMS_PilotExemptionCertificate"/>
    </JadeMethod>
