    <JadeMethod name="utlUpdateROROReqLinkSOBDLR2" id="2b3d4e79-771b-4d7e-816f-fe5e201ede8e">
        <source>utlUpdateROROReqLinkSOBDLR2(_loadSlot : CM_LocationsController input; _dischSlot : CM_LocationsController;  _loadSlotEdition, _dischSlotEdition : Integer;_passport : CM_Passport input);
/*
Purpose:			
Date				Who			Reason
SEPTEMBER 2011		CNWAB1		Initial creation
*/
vars
	tmpSlotReqLoad,
	tmpSlotReqDisch	: CM_Request;
begin

	self.initialiseActivity();

	if _loadSlot = null and _dischSlot = null then
		app.raiseCMException2(MethodWithNullParam, method.name, '_loadSlot and/or _dischSlot', null, null);
		return;
	endif;
	
	if _loadSlot &lt;&gt; null then
		exclusiveLock(_loadSlot);
		if _loadSlot.edition &lt;&gt; _loadSlotEdition then
			app.raiseCMException1(ObjectUpdatedByAnotherUserSave, app.getErrorString(Slot) &amp; ' ' &amp; _loadSlot.ident, null, null);
			return;
		endif;
		tmpSlotReqLoad := _loadSlot.getRequest(true); // PAR 28968myRORORequestLoad;
		if tmpSlotReqLoad = null then
			app.raiseCMException2(NoColorCodeForSlot, app.getErrorString(Load), _loadSlot.ident, null, null);
			return;
		endif;
		exclusiveLock(tmpSlotReqLoad);
	endif;

	if _dischSlot &lt;&gt; null then
		exclusiveLock(_dischSlot);
		if _dischSlot.edition &lt;&gt; _dischSlotEdition then
			app.raiseCMException1(ObjectUpdatedByAnotherUserSave, app.getErrorString(Slot) &amp; ' ' &amp; _dischSlot.ident, null, null);
			return;
		endif;
		tmpSlotReqDisch := _dischSlot.getRequest(false); // PAR 28968 myRORORequestDischarge;
		if tmpSlotReqDisch = null then
			app.raiseCMException2(NoColorCodeForSlot, app.getErrorString(Discharge), _dischSlot.ident, null, null);
			return;
		endif;
	endif;
	
	if tmpSlotReqLoad = null then
		app.myUtilityUA.utlUpdateRORORequestLinkSOBDLR(tmpSlotReqDisch, tmpSlotReqLoad, _passport);
	else
		app.myUtilityUA.utlUpdateRORORequestLinkSOBDLR(tmpSlotReqLoad, tmpSlotReqDisch, _passport);
	endif;
												
end;</source>
        <Parameter name="_loadSlot" type="CM_LocationsController" usage="input"/>
        <Parameter name="_dischSlot" type="CM_LocationsController"/>
        <Parameter name="_loadSlotEdition" type="Integer"/>
        <Parameter name="_dischSlotEdition" type="Integer"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateRORORequestLinkSOBDLR" id="d2240a4a-cd98-4e36-a757-946e407ab59a">
        <source>utlUpdateRORORequestLinkSOBDLR(_roroRequestFrom:CM_Request input;_roroRequestTo:CM_Request;  _passport : CM_Passport input);
/*
Purpose:			
Date				Who			Reason
SEPTEMBER 2011		CNWAB1		Initial creation
*/

vars
	theLinkSlotReq, aftSlotReq,aftAftSlotReq, pxyRequest : CM_Request;
	theLoadWLE : CM_WorkListEntry;
	aDischargeTI : CM_TrackedItem;
	theLoadSlot,
	theAftSlot	: CM_ROROSlotController;
	theSlotDefn : CM_ROROSlotDefnVoyage;
	doAutoJobCreate, doAutoJobPlan : Boolean;
	tmpVoyage		: CM_Voyage;
begin

	self.initialiseActivity();

	if _roroRequestFrom = null then
		app.raiseCMException2(MethodWithNullParam, method.name, '_roroRequestFrom', null, null);
		return;
	endif;

	exclusiveLock(_roroRequestFrom);
	
	tmpVoyage := _roroRequestFrom.getVoyage(); // PAR 28968 myROROController.myVoyage;
	
	if _roroRequestTo &lt;&gt; null then
		exclusiveLock(_roroRequestTo);

		if tmpVoyage &lt;&gt; _roroRequestTo.getVoyage() then // PAR 28968 myROROController.myVoyage then
			app.raiseUnexpectedProgramError(class.name, method.name, 'loadRequest voyage (' &amp; tmpVoyage.String &amp; 
						') does not match dischargeRequest voyage (' &amp; _roroRequestTo.getVoyage().String &amp; ')');
			return;
		endif;
	endif;

	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(_roroRequestFrom, true);
	endif;
	
	if _passport.hasErrors then
		return;
	endif;
	
	if _roroRequestTo = null then
		theLinkSlotReq := _roroRequestFrom.getDLRSOBRequestLink();
	else
		theLinkSlotReq := _roroRequestTo;
	endif;

	_roroRequestFrom.setLinkedRequest(_roroRequestTo);
/*	
	// if we are linking these after an auto create of the load then 
	// we should set the load colour coding to match the TI
	// we will take it that the commodity being null means that this auto 
	// load is here for the first time and not being re-linked
	if _roroRequestFrom &lt;&gt; null and _roroRequestTo &lt;&gt; null then // we may be de linking
		aDischargeTI := _roroRequestTo.myROROController.allTrackedItems.first;
		if _roroRequestFrom.getAttrCommodityGroup() = null then 
			// get the discharge colour coding TI
			if aDischargeTI &lt;&gt; null then
				_roroRequestFrom.setFromTI(aDischargeTI, _roroRequestTo.getAttrIs40()); // this is setting a real
				
				// if auto linking and colour coding we may need to do the CC for the 40 backends
				if _roroRequestFrom.getAttrIs40() 
				or (not _roroRequestFrom.isBackend and (_roroRequestFrom.getAttrIs30() or _roroRequestFrom.getAttrIs53() or _roroRequestFrom.getAttrIs45())) then // PAR 18823
					aftSlotReq := _roroRequestFrom.getAftRORORequest();
					if aftSlotReq = null then
						theLoadSlot := _roroRequestFrom.myROROController; 
						
						if theLoadSlot.myAftSlot = null then // PAR 20699
							app.raiseCMException3(NO_DLR_AFT_SLOT, aDischargeTI.id, aDischargeTI.getActualLength().String, theLoadSlot.getFullId(), null, theLoadSlot); // PAR 20699
						endif;
						
						theLoadSlot.createAftRORORequest(_roroRequestFrom, _passport);
						
						// PAR 18823
						if _roroRequestFrom.getAttrIs53() then
							aftSlotReq := _roroRequestFrom.getAftRORORequest();
							if aftSlotReq &lt;&gt; null then
								aftAftSlotReq := aftSlotReq.getAftRORORequest();
								if aftAftSlotReq = null then
									theLoadSlot := aftSlotReq.myROROController; 
									theLoadSlot.createAftRORORequest(aftSlotReq, _passport);
								endif;
							endif;
						endif;
					else
						// set the properties on the real slot request from the front end
						exclusiveLock(aftSlotReq);
						aftSlotReq.set40AttribsFromFrontEnd(_roroRequestFrom);
					endif;
				endif;
			endif;
		endif;
	endif;
*/
	if _passport.noErrors then
		// ################################
		// This will update the display on screen of this slot
		
		
		// PAR 28968_roroRequestFrom.myROROController.myVoyage.causeEvent(_passport.myTerminal.getTerminalEvent(EVENT_UPDATE_VOYAGE_AREA), false, _roroRequestFrom.myROROController);
		_roroRequestFrom.getVoyage().causeEvent(_passport.myTerminal.getTerminalEvent(EVENT_UPDATE_VOYAGE_AREA), false, _roroRequestFrom.getLC());
		if theLinkSlotReq &lt;&gt; null then
			// PAR 28968 theLinkSlotReq.myROROController.myVoyage.causeEvent(_passport.myTerminal.getTerminalEvent(EVENT_UPDATE_VOYAGE_AREA), false, theLinkSlotReq.myROROController);
			theLinkSlotReq.getVoyage().causeEvent(_passport.myTerminal.getTerminalEvent(EVENT_UPDATE_VOYAGE_AREA), false, theLinkSlotReq.getLC());
		endif;
		if aftSlotReq &lt;&gt; null then
			// PAR 28968 aftSlotReq.myROROController.myVoyage.causeEvent(_passport.myTerminal.getTerminalEvent(EVENT_UPDATE_VOYAGE_AREA), false, aftSlotReq.myROROController);
			aftSlotReq.getVoyage().causeEvent(_passport.myTerminal.getTerminalEvent(EVENT_UPDATE_VOYAGE_AREA), false, aftSlotReq.getLC());
		endif;
		self.myUpdateAuditAgent.audUpdateGeneric(_roroRequestFrom, false);
	endif;

epilog
	delete pxyRequest;
end;</source>
        <Parameter name="_roroRequestFrom" type="CM_Request" usage="input"/>
        <Parameter name="_roroRequestTo" type="CM_Request"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateRORORequestLnkControl" id="08b1d34f-8b27-49a6-bb78-3568912e39a0">
        <source>utlUpdateRORORequestLnkControl(_theRequests:CMIF_SlotRequestController; _passport : CM_Passport input);
/*
Purpose:			
Date				Who			Reason
SEPTEMBER 2011		CNWAB1		Initial creation
*/

vars
	leftRORORequest, rightRORORequest :CM_RORORequest;
	realLeftRORORequest, realRightRORORequest :CM_RORORequest;
	expectedEdition:Integer;
	aTI : CM_TrackedItem;
	imex : Integer;
	idx : Integer;
	realSlotController : CM_SlotController;
begin
	self.initialiseActivity();


	app.setContinueCMExceptions(true);

	if _theRequests.allProxyRORORequests.size &lt;&gt; _theRequests.allLinkedProxyRORORequests.size then
		app.raiseCMException2(ERR_INVALID_VALUE,"selected requests", "You have selected different numbers of slot requests to link.", null, null);
		return;	
	endif;
	foreach leftRORORequest in _theRequests.allProxyRORORequests do
		idx := idx + 1;
		rightRORORequest := _theRequests.allLinkedProxyRORORequests[idx];
		leftRORORequest.validateRequestLink(rightRORORequest);
	endforeach;

	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);

	if _passport.noErrors then
	endif;
	
	if _passport.noErrors then
		// de link
		idx := 0;
		foreach leftRORORequest in _theRequests.allProxyRORORequests do
			idx := idx + 1;
			realLeftRORORequest := leftRORORequest.pxyGetRealObject.CM_RORORequest;
			self.utlUpdateRORORequestLinkSOBDLR(realLeftRORORequest,null,_passport);
		endforeach;
		// re link
		idx := 0;
		foreach leftRORORequest in _theRequests.allProxyRORORequests do
			idx := idx + 1;
			rightRORORequest := _theRequests.allLinkedProxyRORORequests[idx];
			
			realLeftRORORequest := leftRORORequest.pxyGetRealObject.CM_RORORequest;
			realRightRORORequest := rightRORORequest.pxyGetRealObject.CM_RORORequest;
			self.utlUpdateRORORequestLinkSOBDLR(realLeftRORORequest,realRightRORORequest,_passport);
		endforeach;
	endif;
epilog
end;</source>
        <Parameter name="_theRequests" type="CMIF_SlotRequestController"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateROROVesselDecksOrd" id="6f27cf7a-9c08-4b04-aa86-dd7c840601f8">
        <updating/>
        <source>utlUpdateROROVesselDecksOrd(_allDecks : CM_DeckVesselByOrdinalDIct input; _passport : CM_Passport input) updating;
/*
Date		    Who			Reason
Dec 2011		cnwjre1	  	Par 28687 after CCMS 1035, implement RORO vessel deck re-ordering
*/

vars
	roroStructure : CM_ROROVesselStructure;
begin
	self.initialiseActivity();
	
	if _allDecks = null then	
		//app.raiseCMException1(ProxyMgrCannotLocateReal, _deck.code, null, null);
		return;
	endif;

	exclusiveLock(_allDecks);

	if (not _passport.noErrors) then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, app.getErrorString(Deck), null, null);
		return;
	endif;
	
	roroStructure := _allDecks.first.myROROStructure;
	
	if roroStructure &lt;&gt; null then
		roroStructure.allDecks.rearrangeOrdinals(_allDecks);
		// from 28687 Nov 2011 raise a note to refresh any enquiry forms
		roroStructure.causeEvent(EVENT_LOCATION_REFRESH, false, roroStructure);
	endif;


epilog

end;</source>
        <Parameter name="_allDecks" type="CM_DeckVesselByOrdinalDIct" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateRTDevice" id="7ff4c324-68df-4306-bbdd-78cd193e3e1b">
        <source>utlUpdateRTDevice(_proxyRTDevice : CM_RadioTelemetryDevice; _passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:		26 March 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------
//
// Date			Who		Reason
// 21/01/2019	jlgmd1	TFS 43007 - Remove Teklogix
//
vars
	cancelSave:Boolean;
	realRTDevice:CM_RadioTelemetryDevice;
	expectedEdition:Integer;
	
begin

	self.initialiseActivity();

	_proxyRTDevice.raiseExceptionIfNotProxy(method);

	app.setContinueCMExceptions(true);

	_proxyRTDevice.pxyGetRealObjectAndEdition(realRTDevice, expectedEdition);
	
	if realRTDevice = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_RadioTelemetryDevice.name, null, null);
		return;
	endif;

	app.myValUA.valRTDevice(realRTDevice, _proxyRTDevice);
	
	if (not self.checkValidationWithPassport(_passport)) then
		return;		// note that this gets "ignored" in the eplog
	endif;
	
	// cnwmc5 - par 29720  
	if not _proxyRTDevice.id.isInteger()and _proxyRTDevice.type = RTDevice_Vehicle then
		app.raiseCMException(RT_ID_NOT_NUMERIC, null, null);
	endif;

	app.setContinueCMExceptions(false);

	exclusiveLock(realRTDevice);

	if _passport.noErrors and realRTDevice.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'Radio Telemetry Device', null, null);
		return;
	endif;
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realRTDevice, true);
	endif;
	
	if _passport.noErrors then
		realRTDevice.setForUpdate(_proxyRTDevice);
	endif;

	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realRTDevice, false);
	endif;

epilog
	
	
end;</source>
        <Parameter name="_proxyRTDevice" type="CM_RadioTelemetryDevice"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateRTGMachineWorkzones" id="b8773c0a-0791-4a3b-926c-cb8f28d74964">
        <source>utlUpdateRTGMachineWorkzones(_machine : CM_Machine input; _startColumn, _endColumn : CM_RTGColumn; _passport : CM_Passport input);
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 August 2009	cnwer1	Initial creation
3 June 2010	cnwjo3	changed so if _startColumn and _endColumn are out of bounds get an appropriate value - par 24124
03 Jul 2013 cnwer1 PAR 31523 - problem not sending notes where 2 rtgs workzone access a task when 1 rtg changes workzone so
								task not able to be worked note was not getting set 
*/

vars
	startRTGLane: CM_RTGLane;
	startRTGArea,
	rtgArea,
	endRTGArea: CM_RTGArea;
	taIter,colIter : Iterator;
	oldStartCol,
	oldEndCol,
	gridColumn: CM_GridColumn;
	ta : CM_TerminalArea;
	taArray : CM_TerminalAreaArray;
	localColl : Boolean;	
	startColumn, endColumn : CM_RTGColumn;
	iter : Iterator;
	allChangedRTGColumns : ObjectSet;
	taMaster : CM_TerminalAreaMaster;
begin
	self.initialiseActivity();
	
	app.setContinueCMExceptions(false);
	
	self.raiseExceptionIfNull(_machine,"Machine is null");
	self.raiseExceptionIfNull(_startColumn,"Start bay is null");
	self.raiseExceptionIfNull(_endColumn,"End bay is null");

	_machine.validateWorkzone(_startColumn,_endColumn,Workzones );
	
	if app.myPassport.hasErrorsOrWarnings then
		if app.myPassport.hasErrors() or app.myPassport.warningsAcknowledged = false then
			return;
		endif;
	endif;
	
	//epr par 31523
	if _machine.allWorkzoneLocations.isEmpty then
		//if no begin end columns then find out what RTG Lane they are in	
		_machine.getWorkzoneDefault(oldStartCol,oldEndCol,taMaster);
	else
		_machine.getWorkzoneStartEndColumns(oldStartCol,oldEndCol,taMaster);
	endif;
	
	//cnwjo3 par 24124.  trying to add working zone out of range of physical bays
	if _machine.isBeforePhysicalLimitStart(_startColumn) then
		startColumn := _machine.myPhysicalStartBay;
	else
		startColumn := _startColumn;
	endif;
	
	//cnwjo3 par 24124.  trying to add working zone out of range of physical bays
	if _machine.isAfterPhysicalLimitEnd(_endColumn) then
		endColumn := _machine.myPhysicalEndBay;
	else
		endColumn := _endColumn;
	endif;

	startRTGArea:=startColumn.myGridArea.CM_RTGArea;
	endRTGArea:=endColumn.myGridArea.CM_RTGArea;
	
	
	if  startColumn.myGridArea &lt;&gt; endColumn.myGridArea then
		//check that they are in the same RTG Lane
		startRTGLane:=startColumn.myGridArea.allTerminalAreaGroups.first.CM_RTGLane;
		if startRTGLane = null then
			app.raiseCMException(Workzone_Span_Areas,null,null);
		endif;
		
		taArray:=startRTGLane.allTAsByTypeId;
	else
		create taArray transient;
		taArray.add(startColumn.myGridArea);
		localColl:=true;
	endif;
	
	//epr par 31523
	create allChangedRTGColumns transient;
	if oldEndCol &lt;&gt;  endColumn then	
		oldEndCol.myGridArea.getColumnsBetweenCols(oldEndCol,endColumn,allChangedRTGColumns);
	elseif oldStartCol &lt;&gt; startColumn then	
		oldStartCol.myGridArea.getColumnsBetweenCols(oldStartCol,startColumn,allChangedRTGColumns);	
	endif;
	
	_machine.allWorkzoneLocations.clear;
	
	taIter:=taArray.createIterator;
	taIter.startAtObject(startRTGArea);
	while taIter.next(ta) do :outerLoop
		rtgArea:=ta.CM_RTGArea;
		delete colIter;
		colIter:=rtgArea.allGridColumns.createIterator;
		if rtgArea = startRTGArea then
			rtgArea.allGridColumns.startKeyGeq(startColumn.column,colIter);
		endif;
		while colIter.next(gridColumn) do
			gridColumn.allControllersByRow.copy(_machine.allWorkzoneLocations);	
			if gridColumn = endColumn then
				break outerLoop;
			endif;
		endwhile;
	endwhile;

	//epr par 31523
	if _machine.myPrimaryQueue &lt;&gt; null then
		_machine.myPrimaryQueue.updateMachineCoverageForLocs(allChangedRTGColumns);
	endif;	

	_machine.causeEvent(_machine.myTerminal.getTerminalEvent(Event_Mach_Workzone_Update),false,_machine);
epilog
	delete colIter;
	delete taIter;
	if localColl then
		delete taArray;
	endif;
	delete iter;
	delete allChangedRTGColumns;
end;</source>
        <Parameter name="_machine" type="CM_Machine" usage="input"/>
        <Parameter name="_startColumn" type="CM_RTGColumn"/>
        <Parameter name="_endColumn" type="CM_RTGColumn"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateRTQueue" id="23284ae4-7050-497a-a77d-9056cfbc2241">
        <source>utlUpdateRTQueue(_pxyRTQueue : CM_RadioTelemetryQueue; _allCriteria : CMIF_Array; _passport : CM_Passport input);
//-----------------------------------------
// Created: 30 October 2003 By: cnwgd1
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 01/10/2025	jlizm1		MTN 35861 RTQueue configuration - cargo attribute criteria
// ---------------------------------------------------------------------------
vars
	realRTQueue	: CM_RadioTelemetryQueue;
	expectedEdition	: Integer;
begin

	self.initialiseActivity();

	_pxyRTQueue.raiseExceptionIfNotProxy(method);

	app.setContinueCMExceptions(true);

	_pxyRTQueue.pxyGetRealObjectAndEdition(realRTQueue, expectedEdition);
	
	if realRTQueue = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_RadioTelemetryQueue.name, null, null);
		return;
	endif;

	app.myValUA.valCM_Object( _pxyRTQueue, _passport);
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);

	exclusiveLock(realRTQueue);

	if _passport.noErrors and realRTQueue.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'Radio Telemetry Queue', null, null);
		return;
	endif;

	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realRTQueue, true);
	endif;
	
	if _passport.noErrors then
		realRTQueue.setForUpdate(_pxyRTQueue,  _passport);
	endif;
	
	if _passport.noErrors and _allCriteria &lt;&gt; null then
		realRTQueue.persistCriteria(_allCriteria, _passport);
	endif;
	
	if _passport.noErrors then
		realRTQueue.causeEvent(_passport.myTerminal.getTerminalEvent(RTQueue_Update_Event), false, realRTQueue);
		self.myUpdateAuditAgent.audUpdateGeneric(realRTQueue, false);
	endif;
end;</source>
        <Parameter name="_pxyRTQueue" type="CM_RadioTelemetryQueue"/>
        <Parameter name="_allCriteria" type="CMIF_Array"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateRTQueueMultiRule" id="df4c586d-3aea-4d57-ac62-3c32b24e65d3">
        <source>utlUpdateRTQueueMultiRule( _pxyRule: CM_RTQueueMultiRule; _passport : CM_Passport input);

// Created by cnwdvb1 on 29 August 2006

vars

	realRule			: CM_RTQueueMultiRule;
