<GUIClass name="Form">
    <JadeMethod name="extendedResize" id="f9c598a2-3248-4092-b099-7915b2b2551f">
        <updating/>
        <source>extendedResize() updating;

vars
	index:             Integer;
	depth:             Integer;
	control:           Control;
	obj:               Object;
	controlsByDepth:   CM_ObjectByIntegerDict;
begin
	height := height.max(getMinimumHeight());
	width := width.max(getMinimumWidth());

	create controlsByDepth transient;

	foreach index in 1 to controlCount do
		control := controls(index);
		depth := control.getParentDepth();
		controlsByDepth.putAtKey(depth, control);
	endforeach;

	foreach obj in controlsByDepth do
		control := obj.Control;
		control.setSizeAndPosition();
	endforeach;

epilog
	delete controlsByDepth;
end;</source>
    </JadeMethod>
