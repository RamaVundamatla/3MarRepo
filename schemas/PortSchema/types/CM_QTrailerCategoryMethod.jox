*/

vars

begin
	_value:=true;


epilog

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Boolean" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getKeyLengthForXTABDictionary" id="265ca1f8-6474-45a4-9917-2440d36bd01b">
        <source>getKeyLengthForXTABDictionary(): Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 September 2022	jlier1	Initial creation 54700

*/

vars
	length : Integer;
begin
	length :=app.trailerCategoryEnumToString(TRAILER_CATEGORY_TRAILER).length;
	
	length := length.max (app.trailerCategoryEnumToString(TRAILER_CATEGORY_MAFI).length);

	return inheritMethod();

epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
