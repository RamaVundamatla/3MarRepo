        <source>tblPlannedInfo_contextMenu(table: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating;
// ---------------------------------------------------------------------------
// Created:		22 August 2005  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

	xLeft 	: Real;
	yTop	: Real;
begin

	xLeft := x;
	yTop := y;

	conwin.windowToScreen(xLeft, yTop);
	self.screenToWindow(xLeft, yTop);   
	
	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		return false;
	endif;

	self.mnuContextTable.visible := true;
	self.mnuContextHide.visible := true;

	self.popupMenu(mnuContextTable, xLeft.Integer, yTop.Integer);

	return false;

end;</source>
