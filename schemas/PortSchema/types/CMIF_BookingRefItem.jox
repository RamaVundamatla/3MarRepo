    <JadeMethod name="getDiscrepValueFor" id="9b4555ce-8bae-46a8-8cdd-ebba08497811">
        <source>getDiscrepValueFor( _heading : String ):String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28 September 2009	cnwndl1	Initial creation	CCMS 1609 Par 20521

*/

vars

	entTableDef : EntTableDef;
	entTableRow : EntTableRow;
	name : String;
	
	haz : CM_Hazard;
	tmpStr	: String;
	bookingRef : CM_BookingRef;
	
begin

	entTableDef := app.myRoot.myEntTableDataRoot.allEntTableDefs[ETDef_BookingRefDiscrep];
	entTableRow := entTableDef.getEntTableRowByHeading(_heading);
	if entTableRow &lt;&gt; null then
		name := entTableRow.name;
	endif;
	
	if name = ETRow_Commodity then
		return self.commodity;
		
	elseif name = ETRow_Humidity then
		return self.getHumidityAsString;
		
	elseif name = ETRow_Ventilation then
		return self.getVentilation;
		
	elseif name = ETRow_CurtainsIn then
		if not self.curtainsIn then	//14 Oct 2009	NDL Par 20880
			return null;
		endif;
		return true.cnEcGetYesNo;
		
	elseif name = ETRow_CargoType then
		return cargoTypeDescr;
		
	elseif name = ETRow_Hazardous then
		if not self.allTIHazards.isEmpty then	//14 Oct 2009	NDL Par 20880
			return true.getYesNo;	
		endif;
		return null;
		
	/*	foreach haz in self.allTIHazards do
			if tmpStr &lt;&gt; null then
				tmpStr := tmpStr &amp; '; ';
			endif;
			tmpStr := tmpStr &amp; haz.getTableDisplay(false);
		endforeach;
		return tmpStr; */
			
	elseif name = ETRow_CarriageTemperature then
		return self.getTempString(false);
		
	elseif name = ETRow_ISOType then
		return self.isoType;
		
	endif;
	
	// All values from here on derived from the parent.
	if myCMIF_BookingRef = null or myCMIF_BookingRef.myProxyBookingRef = null then
		return null;
	endif;
	bookingRef := myCMIF_BookingRef.myProxyBookingRef;

	if ( name = ETRow_Consignee
	or name = ETRow_Consignor
	or name = ETRow_Destination
	or name = ETRow_DischargePort
	or name = ETRow_Voyage
	) then
		return bookingRef.getDisplayStringForAttribute(name, false);
		
	elseif name = ETRow_BookingRef or name = ETRow_BookingReference then
		return bookingRef.getDisplayStringForAttribute(ETRow_BookingRef, false);
	
	elseif name = ETRow_IsStock or name = ETRow_IsStockBookingReference then
		return bookingRef.getDisplayStringForAttribute(ETRow_IsStockBookingRef, false);
	
	elseif name = ETRow_Operator then
		return bookingRef.getDisplayStringForAttribute(ETRow_OperatorCode, false);
	
	else
		return null;
	
	endif;
	
	
epilog

end;</source>
        <Parameter name="_heading" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
