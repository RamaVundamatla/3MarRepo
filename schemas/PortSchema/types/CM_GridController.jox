    <JadeMethod name="isAccessRestricted" id="69b4591d-b738-48a4-886a-368d8ceabde7">
        <source>isAccessRestricted(): Boolean;
/*
 ------------------------------------------------------------------------
Created:			15 January 2002 by cnwdwq1
Purpose:			works out if this tracked item can be accessed by the fork lift, i.e. are there other boxes in 
							front, behind or both or on top. Whether it is overstowed is a seperate check
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/
vars
	lAccess : Integer;
begin


//	if self.myTerminalArea.isKindOf(CM_FForkLiftStack) = false then
	if not self.myTerminalArea.testRestrictedAccess() then
		//If parent is NOT a forklift stack, then quit.
		return false;
	endif;
	lAccess := self.myTerminalArea.isAccessRestricted(false, self, null,null); 

	if lAccess = TA_ACCESS_NO then
		return true;
	endif;
	return false;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
