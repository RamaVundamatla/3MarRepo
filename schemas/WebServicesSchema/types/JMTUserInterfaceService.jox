    <JadeWebServicesMethod name="getWorkingTrains" id="baa3e835-4fc2-4475-b865-7e0cbdaa7f4d">
        <source>getWorkingTrains() : WS_TrainsResponse webService;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 January 2016	cnwmc5	Initial creation
28 Jun 2022		jlika1 TFS 53971 - MTN - Rail Confirm App to React
*/

vars
	response		: WS_TrainsResponse;
	completedOK		: Boolean;
	
	allQueues		: CM_RTQueueArray;
	queue			: CM_RadioTelemetryQueue;
	entry			: CM_RTQueueEntry;
	
	wsTrain			: WS_Train;
	train			: CM_Train;
	
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	// In particular this sets passport myUser and myTerminal
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
	
	// Check security access to this message, if required
	//app.checkCurrentUserHasAccess(99999);		// Replace with appropriate permission
	if app.myPassport.hasErrors then
		completedOK := true;
		return response;
	endif;
	
	// Perform validation, start populate response
	create allQueues transient;
	app.getMyTerminalDO_NOT_USE().getAllQueues(allQueues);
	
	foreach queue in allQueues do
		if queue.isRailQueueFromTo()
		and not queue.isQueueEmpty() then
		
			foreach entry in queue.allEntries do
				train := entry.myJob.getMyTrain();
				if train &lt;&gt; null then
					create wsTrain transient;
					wsTrain.setProxyFromObject(train);
					wsTrain.setProxyWagons(train);
					response.allTrains.add(wsTrain);
				endif;
			endforeach;		
			
		endif;
	endforeach;
	
	// Got to here, everything is ok
	completedOK := true;
	return response;
	
epilog
	
	delete allQueues;
	
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
	
end;</source>
        <ReturnType type="WS_TrainsResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="getWorkingVoyages" id="1f6d93ce-06d4-4c81-92fd-818433952892">
        <source>getWorkingVoyages() : WS_VoyagesResponse webService;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 January 2016	cnwmc5	Initial creation

*/

vars
	response		: WS_VoyagesResponse;
	completedOK, createVoy		: Boolean;
	
	allQueues		: CM_RTQueueArray;
	queue, subQueue			: CM_RadioTelemetryQueue;
	
	wsVoyage, tmpVoyage		: WS_Voyage;
	wsWorkPoint : WS_WorkPoint;
	tokens : StringArray;
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	// In particular this sets passport myUser and myTerminal
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
	create tokens transient;
	// Check security access to this message, if required
	//app.checkCurrentUserHasAccess(99999);		// Replace with appropriate permission
	if app.myPassport.hasErrors then
		completedOK := true;
		return response;
	endif;
	
	// Perform validation, start populate response
	create allQueues transient;
	app.getMyTerminalDO_NOT_USE().getAllQueues(allQueues);
	
	foreach queue in allQueues do
		if queue.isVoyageQueue then // voyage, crane or workpoint queue
		
			
			// Actual queue for a voyage
			if  not queue.isCraneQueue
			and not queue.isWorkPointQueue then

				if queue.allSubQueuesById.size = 0 
				and queue.isQueueEmpty then
					continue;
				endif;
				
				// nothing in the voyage queue but it has sub queues, check if the sub queue are active.
				if queue.isQueueEmpty then
					createVoy := false;
					foreach subQueue in queue.allSubQueuesById discreteLock do
						if not subQueue.isQueueEmpty then
							createVoy := true; // at least one sub queue is active  so create a voyage for it.
							break;
						endif;
					endforeach;
					
					if not createVoy then
						continue;
					endif;
				endif;
				
				create wsVoyage transient;
				wsVoyage.setProxyFromObject(queue.CM_VoyageQueue.myVoyage);
				response.allVoyages.add(wsVoyage);
				
				foreach subQueue in queue.allSubQueuesById discreteLock do
					if not subQueue.isQueueEmpty then
						create wsWorkPoint transient;
						tokens := subQueue.id.getTokens();
						
						if tokens.size = 2 then
							wsWorkPoint.code := tokens[2];
						else
							wsWorkPoint.code := subQueue.id;
						endif;
						wsWorkPoint.description := subQueue.allEntries.size.String;
						
						wsVoyage.allWorkPoints.add(wsWorkPoint);
						
					endif;
	 
				endforeach;
			
			endif;
					
		endif;
	endforeach;
	
	// Got to here, everything is ok
	completedOK := true;
	return response;
	
epilog
	
	delete allQueues;
	delete tokens;
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
	
end;</source>
        <ReturnType type="WS_VoyagesResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="getYardAllocationRanges" id="b7228e56-7922-4301-8ba8-cc9d430c7c28">
        <source>getYardAllocationRanges() : WS_YardAllocationResponse webService;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
