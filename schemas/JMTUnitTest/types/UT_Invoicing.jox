	self.assertTrueMsg(invLine.quantity = 1, "Voyage Invoice Line Quantity SBE 1 MINIMUM is " &amp; invLine.quantity.String);
	self.assertTrueMsg(invLine.lineTotal = 400, "Voyage Invoice Line Total SBE 400 MAXIMUM is " &amp; invLine.lineTotal.String);
	self.assertTrueMsg(invLine.invoiceLineDesc = ild2, "Voyage Invoice Line SBE ild2 is " &amp; invLine.invoiceLineDesc.narration);
	invres := invLine.myTransactionHMS.myResourceUsed.myResource;
	self.assertTrueMsg(invres = resource, "Voyage Invoice Line resource SBE UTHRMIN is " &amp; invres.description);
	

epilog
	self.resetDefaultTranMap();
	delete services;
	delete costs;
	delete pxyDebtorRate;
	delete transSet;
	delete invoiceLines;
end;</source>
    </JadeMethod>
    <JadeMethod name="tHMSTimeHoursMins06" id="d6b701cb-3e94-4964-a7c9-60435d803023">
        <updating/>
        <source>tHMSTimeHoursMins06() updating;
/*
Purpose - 	 	test calc type INV_CALC_TYPE_TIME_PERIOD_HRMN with MAXIMUM AMOUNT **** MAXIMUM HOURS ****
Who - NAVAB1
Date - 23AUG2024
ADO - BUG 65780
*/

vars
	date,
	now			: Date;
	time		: Time;
	count		: Integer;
	invCount	: Integer;
	invLine		: CM_InvoiceLine;
	start		: TimeStamp;
	fromDateTime, 
	toDateTime	: TimeStamp;
	costs		: DecimalArray;
	term		: CM_Terminal;
	calcType	: CM_CalculationType;
	service		: CM_Service;
	services	: CM_ServiceByNameDict;
	invType1,
	invType2	: CM_InvoiceDesc;
	ild, ild2			: CM_InvoiceLineDesc;
	resourceType	: HMS_ResourceType;
	harbour		: HMS_Harbour;
	berth		: HMS_Berth;
	wharf		: HMS_Wharf;
	resource, invres	: HMS_Resource;
	resUsed		: HMS_ResourceUsed;
	operator	: CM_Operator;
	debtor		: CM_Debtor;
	pxyDebtorRate,
	debtorRate	: CM_DebtorRate;
	rateEntry	: CM_RateEntry;
	voyage1,
	voyage2,
	voyage3		: CM_Voyage;
	movement	: HMS_VoyageMovement;
	transSet	: CM_TransactionSet;
	invoice		: CM_Invoice;
	invoiceLines : ObjectArray;
	cargoType : CM_CargoType;
	ti1 : CM_TrackedItem;
begin

	term := self.getTerminal();
	harbour := term.myHarbour;
	berth := harbour.allBerths.last;
	wharf := berth.myWharf;
	
	// HoursMins calculation type
	service := self.myBank.services["UTHoursMins"];
	//  delete any invoice (lines, charges) using the service first so can delete the service
	if service &lt;&gt; null then
		self.deleteInvoicesUsingService(service);
	endif;
	service := self.myBank.services["UTHoursMins1"];
	//  delete any invoice (lines, charges) using the service first so can delete the service
	if service &lt;&gt; null then
		self.deleteInvoicesUsingService(service);
	endif;
	// delete the services so can delete the calculation type
	self.deleteInvoiceService("UTHoursMins", FORCED_ERASE);
	self.deleteInvoiceService("UTHoursMins1", FORCED_ERASE);
	self.deleteInvoiceCalcType("UTHM");	
	calcType := self.createInvoiceCalcType(null, INV_CALC_TYPE_TIME_PERIOD_HRMN, "UTHM", "HoursMins usage", 
										  0, 10,1, 0, null, false,
										  null, null,100, 0, 0,
										  null, null, null, null,
										  false, true, false,		// is voyage type=true
										  null, null, null, null);
	
	// HoursMins service
	service := self.createInvoiceService("UTHoursMins1","HoursMins Used", calcType, null);
	
	// Voyage monthly invoice type
	self.deleteInvoiceType("UTVoyageMonthly");
	invType1 := self.createInvoiceTypeFull(CM_InvoiceDesc.Accrue_Until_Manually_Closed,
											null,
											"UTVoyageMonthly",
											CM_InvoiceDesc.Key_Voyage,
											InvoiceTypeGeneral,
											null,
											null,
											true,
											InvTypeTrigger_Release,
											now,
											now,
											0,
											"");
	// delete transaction map
	self.deleteInvoiceTransactionMap(3, 'UT_VTMIS10');
	
	// HoursMins usage invoice line descriptions
	self.deleteInvoiceLineType("UTHoursMinsUsage1", FORCED_ERASE);
	self.deleteInvoiceLineType("UTHoursMinsUsage2", FORCED_ERASE);
	create services transient;
 	services.add(service);
	
	// invoice type
	ild := self.createInvoiceLineType("UTHoursMinsUsage1", calcType, invType1, services, "SDT4");	// charge ship operator
	ild2 := self.createInvoiceLineType("UTHoursMinsUsage2", calcType, invType1, services, "SDT4");	// charge ship operator
	
	
	
	
	
	// resource type - delete used resource first
	self.deleteHarbourResource("UTHRMIN", harbour);
	resourceType := self.addHMSResourceType("UTHrMin", "HoursMins Usage", "m3", 0, true, true,
											false, false, false, false);

	// resource
	resource := self.addHarbourResource("UTHRMIN", "HoursMins Usage", harbour, resourceType, wharf, 
										0, 0, false);
										
	create costs transient;
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);	
	debtor := operator.debtor;
// set a rate ($3.00) for the service and actual debtor
	create pxyDebtorRate transient;
	pxyDebtorRate.setProxy(service, debtor);
	costs.add(400.00);
	start.setDate("01/05/2010".Date);
	start.setTime("00:00".Time);
	rateEntry := self.addInvoiceRateEntry(pxyDebtorRate, start, null, false, costs, 0, 0, null, null);
	
	cargoType := 	self.addNewCargoType();	

	// load HMS transaction map
	self.tranMapLoadVTMIS11();
	
	
	
	
	
	
	// vessel and voyage with HMS data
	self.opts.purge();
	self.opts.addAssoc("useHMSData", true);
	self.opts.addAssoc("berth", berth);
	
	// this is the example in the BRD - ADO 63209
	fromDateTime.setFromYYYYMMDDHHmm("202405181827");
	toDateTime.setFromYYYYMMDDHHmm("202405191827"); // 24 HOURS (MAX is 10)

	voyage1 := self.createVesselVoyage4("UTINVVSL4A", "UTINVVOY4A", fromDateTime, toDateTime);
	self.updateVoyageHMS(voyage1, 11111, 12222, 20.0, 5.0, 60000, 0);
	
	// movement maintenance, add resource usage (1200 units) 
	movement := voyage1.myHMSVoyageData.allVoyageMovements.first;
	self.addHMSResourceToMovement(resourceType, resource, null, fromDateTime, toDateTime,  1200, false, movement);
	// set the move status so invoicing will take place
	beginTransaction;
	foreach movement in voyage1.myHMSVoyageData.allVoyageMovements do
		movement.setPropertyValue("moveStatusNEW", MovementStatus_Actual);
	endforeach;
	commitTransaction;
	
	ti1 := self.createGCOnShip("", "HOURMIN001", cargoType, operator, voyage1, voyage1.allPorts.first,15000);
	self.assertTrueMsg(ti1 &lt;&gt; null, "Voyage Cargo TI1 is NULL");

	// generate invoice
	self.generateVoyageInvoicing(voyage1);

	// test invoice - should be none
	invoice := voyage1.allInvoices.first;
	self.assertTrueMsg(invoice &lt;&gt; null, "Voyage Invoice, voyage 1");
	invLine := invoice.invoiceLines.first;
	
	self.assertTrueMsg(invLine &lt;&gt; null, "Voyage Invoice Line, voyage 1");
	self.assertTrueMsg(invLine.quantity = 10, "Voyage Invoice Line Quantity SBE 10 MAXIMUM is " &amp; invLine.quantity.String);
	self.assertTrueMsg(invLine.lineTotal = 4000, "Voyage Invoice Line Total SBE 4000 MAXIMUM is " &amp; invLine.lineTotal.String);
	self.assertTrueMsg(invLine.invoiceLineDesc = ild2, "Voyage Invoice Line SBE ild2 is " &amp; invLine.invoiceLineDesc.narration);
	invres := invLine.myTransactionHMS.myResourceUsed.myResource;
	self.assertTrueMsg(invres = resource, "Voyage Invoice Line resource SBE UTHRMIN is " &amp; invres.description);
	

epilog
	self.resetDefaultTranMap();
	delete services;
	delete costs;
	delete pxyDebtorRate;
	delete transSet;
	delete invoiceLines;
end;</source>
    </JadeMethod>
    <JadeMethod name="tHMSTonRange" id="ddfcf022-ab29-404d-88e3-83e0227985cb">
        <updating/>
        <source>tHMSTonRange() updating;
// cnwma1
// cnwjre1	general HMS water usage - as in Appendix A of the Invoicing User Manual
//	Variant using a Vessel Ton Range calculation type with a range of vessel GRT ranges and matching rates
vars
	now			: Date;
	time		: Time;
	count		: Integer;
	start		: TimeStamp;
	fromDateTime, 
	toDateTime	: TimeStamp;
	costs		: DecimalArray;
	ia			: IntegerArray;
	term		: CM_Terminal;
	calcType	: CM_CalculationType;
	service		: CM_Service;
	services	: CM_ServiceByNameDict;
	invType		: CM_InvoiceDesc;
	ild			: CM_InvoiceLineDesc;
	resourceType	: HMS_ResourceType;
	harbour		: HMS_Harbour;
	berth		: HMS_Berth;
	wharf		: HMS_Wharf;
	resource	: HMS_Resource;
	resUsed		: HMS_ResourceUsed;
	operator	: CM_Operator;
	debtor		: CM_Debtor;
	pxyDebtorRate,
	debtorRate	: CM_DebtorRate;
	rateEntry	: CM_RateEntry;
	voyage		: CM_Voyage;
	movement	: HMS_VoyageMovement;
	transSet	: CM_TransactionSet;
	invoice		: CM_Invoice;
	invoiceLines : ObjectArray;

begin
	term := self.getTerminal();
	harbour := term.myHarbour;
	berth := harbour.allBerths.last;
	wharf := berth.myWharf;

	// Water calculation type
	service := self.myBank.services["UTWater"];
	//  delete any invoice (lines, charges) using the service first so can delete the service
	if service &lt;&gt; null then
		self.deleteInvoicesUsingService(service);
	endif;
	// delete the service so can delete the calculation type
	self.deleteInvoiceService("UTWater", FORCED_ERASE);
	self.deleteInvoiceService("UTWater1", FORCED_ERASE);
	self.deleteInvoiceCalcType("UTH2O");
	create ia transient;
	// ton ranges
	ia.add(10000);
	ia.add(20000);
	ia.add(50000);
	calcType := self.createInvoiceCalcType(null, INV_CALC_TYPE_VESSEL_TON_RANGE, "UTH2O", "Water usage", 
										  0, 0, 0, 0, ia, false,
										  null, null, 0, 0, 0,	
										  null, null, null, null,
										  false, true, false,		// is voyage type=true
										  null, null, null, null);
	
	// Water service
	service := self.createInvoiceService("UTWater","Water Used", calcType, null);
	
	// Voyage invoice type
	self.deleteInvoiceType("UTVoyage");
	invType := self.createInvoiceTypeFull(CM_InvoiceDesc.Accrue_Until_Manually_Closed,
											null,
											"UTVoyage",
											CM_InvoiceDesc.Key_Voyage,
											InvoiceTypeGeneral,
											null,
											null,
											true,
											InvTypeTrigger_Release,
											now,
											now,
											0,
											"");

	// delete transaction map
	self.deleteInvoiceTransactionMap(3, 'UT_VTMIS1');
	
	// Water usage invoice line description
	self.deleteInvoiceLineType("UTWaterUsage", FORCED_ERASE);
	create services transient;
 	services.add(service);
	
	// invoice type
	ild := self.createInvoiceLineType("UTWaterUsage", calcType, invType, services, "SDT4");	// charge ship operator
	
	// resource type - delete used resource first
	self.deleteHarbourResource("UTWATER01", harbour);
	resourceType := self.addHMSResourceType("UTWATER", "Water Usage", "m3", 0, true, true,
											false, false, false, false);

	// resource
	resource := self.addHarbourResource("UTWATER01", "Water meter 1 usage", harbour, resourceType, wharf, 
										0, 0, false);
										
	// vessel and voyage with HMS data
	self.opts.purge();
	self.opts.addAssoc("useHMSData", true);
	self.opts.addAssoc("berth", berth);
	voyage := self.createVesselVoyage3();
	self.updateVoyageHMS(voyage, 11111, 12222, 20.0, 5.0, 60000, 0);		// GRT 12222
	
	// load HMS transaction map
	self.tranMapLoadVTMIS1();
	
	// movement maintenance, add resource usage (1200 units)
	fromDateTime.setDate(now);
	fromDateTime.setTime(time);
	movement := voyage.myHMSVoyageData.allVoyageMovements.first;
	self.addHMSResourceToMovement(resourceType, resource, null, fromDateTime, toDateTime,  1200, false, movement);
	// set the move status so invoicing will take place
	beginTransaction;
	foreach movement in voyage.myHMSVoyageData.allVoyageMovements do
		movement.setPropertyValue("moveStatusNEW", MovementStatus_Actual);
	endforeach;
	commitTransaction;

	create costs transient;
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);	
	debtor := operator.debtor;
// set rates - $3.00 for the first ton range, $4 for the second and $5 for the last - for the service and actual debtor
	create pxyDebtorRate transient;
	pxyDebtorRate.setProxy(service, debtor);
	costs.add(3.00);
	costs.add(4.00);
	costs.add(5.00);
	start.setDate("01/05/2010".Date);
	start.setTime("00:00".Time);
	rateEntry := self.addInvoiceRateEntry(pxyDebtorRate, start, null, false, costs, 0, 0, null, null);

	// generate invoice
	self.generateVoyageInvoicing(voyage);
	
	// test invoice - should be one, with one line
	foreach invoice in voyage.allInvoices do
		count := count + 1;
		validateHMSInvoice3(invoice, count);
	endforeach;
	self.assertEqualMsg(count, 1, "Voyage Invoices, test 1");
	
	// do a resync of the VTMIS transactions - should stay the same
	create transSet transient;
	foreach movement in voyage.myHMSVoyageData.allVoyageMovements do
		foreach resUsed in movement.allResourceUsed do
			if resUsed.myVTMISTransaction &lt;&gt; null then
				transSet.add(resUsed.myVTMISTransaction);
			endif;
		endforeach;
	endforeach;
	self.updateInvoiceReevaluate(transSet, null, null);
	// test invoice - should still be one, with one line
	count := 0;
	foreach invoice in voyage.allInvoices do
		count := count + 1;
		validateHMSInvoice3(invoice, count);
	endforeach;
	self.assertEqualMsg(count, 1, "Voyage Invoices, test 3");
	
	// do a re-evaluate on the invoice line - should stay the same
	create invoiceLines transient;
	foreach invoice in voyage.allInvoices do
		invoice.invoiceLines.copy(invoiceLines);
	endforeach;

	self.invoiceLineReevaluate(invoiceLines);
	// test invoice - should still be one, with one line
	count := 0;
	foreach invoice in voyage.allInvoices do
		count := count + 1;
		validateHMSInvoice3(invoice, count);
	endforeach;
	self.assertEqualMsg(count, 1, "Voyage Invoices, test 4");

	// change the rate to $24.00
	// changes the rates to $6.00 for the first ton range, $7 for the second and $8 for the last
	debtorRate := rateEntry.rate.CM_DebtorRate;
	costs.clear();
	costs.add(6.00);
	costs.add(7.00);
	costs.add(8.00);
	self.updateInvoiceRateEntry(debtorRate, rateEntry, start, null, false, costs, 0, 0, null,null);
	
	// re-test for the new invoice value - the rate should now be the calc type max of 12
	count := 0;
	foreach invoice in voyage.allInvoices do
		count := count + 1;
		validateHMSInvoice3a(invoice, count);
	endforeach;
	self.assertEqualMsg(count, 1, "Voyage Invoices, test 5");
	
	// change the vessel GRT from 12222 (second range) to 22222 (third range) and re-evaluate the invoice lines
	beginTransaction;
	voyage.myHMSVoyageData.setPropertyValue("dim_GrossRegTonnes", 22222); 
	commitTransaction;

	invoiceLines.clear();
	foreach invoice in voyage.allInvoices do
		invoice.invoiceLines.copy(invoiceLines);
	endforeach;
	
	self.invoiceLineReevaluate(invoiceLines);

	// re-test for the new quantity and value
	count := 0;
	foreach invoice in voyage.allInvoices do
		count := count + 1;
		validateHMSInvoice3b(invoice, count);
	endforeach;
	self.assertEqualMsg(count, 1, "Voyage Invoices, test 6");
	
epilog
	self.resetDefaultTranMap();												// 17/04/2013 cnwmh5
	delete ia;
	delete services;
	delete costs;
	delete pxyDebtorRate;
	delete transSet;
	delete invoiceLines;
end;</source>
    </JadeMethod>
    <JadeMethod name="tHMSVesselCategoryInContract" id="0f6c2df9-239a-4f1d-a987-16a5e27bd51b">
        <updating/>
        <source>tHMSVesselCategoryInContract() updating;
/*
Purpose:	Test in contract resource for correct vessel category		
			The transaction map has the matching vessel category in the IN contract mapping so should get an invoice line

Date		Who		Reason
12OCT2021	NAVAB1	TFS 52132
*/

vars
	date,
	now			: Date;
	time		: Time;
	count		: Integer;
	invCount	: Integer;
	invLine		: CM_InvoiceLine;
	start		: TimeStamp;
	fromDateTime, 
	toDateTime	: TimeStamp;
	costs		: DecimalArray;
	term		: CM_Terminal;
	calcType	: CM_CalculationType;
	service		: CM_Service;
	services	: CM_ServiceByNameDict;
	invType1,
	invType2	: CM_InvoiceDesc;
	ild			: CM_InvoiceLineDesc;
	resourceType	: HMS_ResourceType;
	harbour		: HMS_Harbour;
	berth		: HMS_Berth;
	wharf		: HMS_Wharf;
	resource	: HMS_Resource;
	resUsed		: HMS_ResourceUsed;
	operator	: CM_Operator;
	debtor		: CM_Debtor;
	pxyDebtorRate,
	debtorRate	: CM_DebtorRate;
	rateEntry	: CM_RateEntry;
	voyage1,
	voyage2,
	voyage3		: CM_Voyage;
	movement	: HMS_VoyageMovement;
	transSet	: CM_TransactionSet;
	invoice		: CM_Invoice;
	invoiceLines : ObjectArray;
	cat : HMS_VesselCategory;
begin

	term := self.getTerminal();
	harbour := term.myHarbour;
	berth := harbour.allBerths.last;
	wharf := berth.myWharf;

	cat := self.addHMSVesselCategory("UT_VESSCAT","UNIT TEST VESS CAT",harbour);
	
	
	// Water calculation type
	service := self.myBank.services["UTWater"];
	//  delete any invoice (lines, charges) using the service first so can delete the service
	if service &lt;&gt; null then
		self.deleteInvoicesUsingService(service);
	endif;
	service := self.myBank.services["UTWater1"];
	//  delete any invoice (lines, charges) using the service first so can delete the service
	if service &lt;&gt; null then
		self.deleteInvoicesUsingService(service);
	endif;
	// delete the services so can delete the calculation type
	self.deleteInvoiceService("UTWater", FORCED_ERASE);
	self.deleteInvoiceService("UTWater1", FORCED_ERASE);
	self.deleteInvoiceCalcType("UTH2O");	
	calcType := self.createInvoiceCalcType(null, INV_CALC_TYPE_RESOURCE_QTY, "UTH2O", "Water usage", 
										  0, 0, 0, 0, null, false,
										  null, null, 0, 0, 0,
										  null, null, null, null,
										  false, true, false,		// is voyage type=true
										  null, null, null, null);
	
	// Water service
	service := self.createInvoiceService("UTWater1","Water Used", calcType, null);
	
	// Voyage monthly invoice type
	self.deleteInvoiceType("UTVoyageMonthly");
	invType1 := self.createInvoiceTypeFull(CM_InvoiceDesc.Accrue_Until_Manually_Closed,
											null,
											"UTVoyageMonthly",
											CM_InvoiceDesc.Key_Voyage,
											InvoiceTypeGeneral,
											null,
											null,
											true,
											InvTypeTrigger_Release,
											now,
											now,
											0,
											"");
	// delete transaction map
	self.deleteInvoiceTransactionMap(3, 'UT_VTMIS9');
	
	// Water usage invoice line descriptions
	self.deleteInvoiceLineType("UTWaterUsage1", FORCED_ERASE);
	create services transient;
 	services.add(service);
	
	// invoice type
	ild := self.createInvoiceLineType("UTWaterUsage1", calcType, invType1, services, "SDT4");	// charge ship operator
	
	// resource type - delete used resource first
	self.deleteHarbourResource("UTWATER01", harbour);
	resourceType := self.addHMSResourceType("UTWATER", "Water Usage", "m3", 0, true, true,
											false, false, false, false);

	// resource
	resource := self.addHarbourResource("UTWATER01", "Water meter 1 usage", harbour, resourceType, wharf, 
										0, 0, false);
										
	create costs transient;
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);	
	debtor := operator.debtor;
// set a rate ($3.00) for the service and actual debtor
	create pxyDebtorRate transient;
	pxyDebtorRate.setProxy(service, debtor);
	costs.add(3.00);
	start.setDate("01/05/2010".Date);
	start.setTime("00:00".Time);
	rateEntry := self.addInvoiceRateEntry(pxyDebtorRate, start, null, false, costs, 0, 0, null, null);

	// load HMS transaction map
	self.tranMapLoadVTMIS9();
	
	// vessel and voyage with HMS data
	self.opts.purge();
	self.opts.addAssoc("useHMSData", true);
	self.opts.addAssoc("berth", berth);
	date := "01/06/2014".Date;
	fromDateTime.setDate(date);
	fromDateTime.setTime(time);
	toDateTime := fromDateTime.addDays(2);

	voyage1 := self.createVesselVoyage4("UTINVVSL4A", "UTINVVOY4A", fromDateTime, toDateTime);
	self.updateVoyageHMS(voyage1, 11111, 12222, 20.0, 5.0, 60000, 0);
	self.setVoyageVesselCategory(voyage1, cat);
	
	 // These do not actually get used, as 'part of contract' is set in addHMSResourceToMovement call
	self.setVoyageMoveResType(voyage1,HMSMovementTypeArrival, resourceType);
	self.setVoyageMoveResType(voyage1,HMSMovementTypeDeparture, resourceType);
	
	
	// movement maintenance, add resource usage (1200 units) 
	movement := voyage1.myHMSVoyageData.allVoyageMovements.first;
	self.addHMSResourceToMovement(resourceType, resource, null, fromDateTime, toDateTime,  1200, true, movement);
	// set the move status so invoicing will take place
	beginTransaction;
	foreach movement in voyage1.myHMSVoyageData.allVoyageMovements do
		movement.setPropertyValue("moveStatusNEW", MovementStatus_Actual);
	endforeach;
	commitTransaction;

	// generate invoice
	self.generateVoyageInvoicing(voyage1);

	// test invoice - should be one, with one line
	foreach invoice in voyage1.allInvoices do
		count := count + 1;
		foreach invLine in invoice.invoiceLines do
			invCount := invCount + 1;
			self.assertEqualMsg(invLine.quantity, 1200.Real, "line 1 quantity");
			self.assertEqualMsg(invLine.lineTotal, 3600.Decimal, "line 1 value");
			self.assertEqualMsg(invLine.invoiceLineDesc.narration, "UTWaterUsage1", "line 1 ILD ");
		endforeach;
		self.assertEqualMsg(invCount, 1, "Voyage 1 invoice lines");
	endforeach;
	self.assertEqualMsg(count, 1, "Voyage Invoices, voyage 1");
		
	

epilog
	self.resetDefaultTranMap();
	delete services;
	delete costs;
	delete pxyDebtorRate;
	delete transSet;
	delete invoiceLines;
end;</source>
    </JadeMethod>
    <JadeMethod name="tHMSVesselCategoryOutContract" id="bc25beb3-6a1f-4a66-93fd-0e5714c412df">
        <updating/>
        <source>tHMSVesselCategoryOutContract() updating;
/*
Purpose:	Test out of  contract resource for wrong vessel category		
			The transaction map has the matching vessel category in the IN contract mapping so should NOT get an invoice line
			The transaction map has the non matching vessel category in the OUT contract mapping so should NOT get an invoice line

Date		Who		Reason
12OCT2021	NAVAB1	TFS 52132
*/

vars
	date,
	now			: Date;
	time		: Time;
	count		: Integer;
	invCount	: Integer;
	invLine		: CM_InvoiceLine;
	start		: TimeStamp;
	fromDateTime, 
	toDateTime	: TimeStamp;
	costs		: DecimalArray;
	term		: CM_Terminal;
	calcType	: CM_CalculationType;
	service		: CM_Service;
	services	: CM_ServiceByNameDict;
	invType1,
	invType2	: CM_InvoiceDesc;
	ild			: CM_InvoiceLineDesc;
	resourceType	: HMS_ResourceType;
	harbour		: HMS_Harbour;
	berth		: HMS_Berth;
	wharf		: HMS_Wharf;
	resource	: HMS_Resource;
	resUsed		: HMS_ResourceUsed;
	operator	: CM_Operator;
	debtor		: CM_Debtor;
	pxyDebtorRate,
	debtorRate	: CM_DebtorRate;
	rateEntry	: CM_RateEntry;
	voyage1,
	voyage2,
	voyage3		: CM_Voyage;
	movement	: HMS_VoyageMovement;
	transSet	: CM_TransactionSet;
	invoice		: CM_Invoice;
	invoiceLines : ObjectArray;
	cat : HMS_VesselCategory;
begin

	term := self.getTerminal();
	harbour := term.myHarbour;
	berth := harbour.allBerths.last;
	wharf := berth.myWharf;

	cat := self.addHMSVesselCategory("UT_VESSCAT","UNIT TEST VESS CAT",harbour);
	
	
	// Water calculation type
	service := self.myBank.services["UTWater"];
	//  delete any invoice (lines, charges) using the service first so can delete the service
	if service &lt;&gt; null then
		self.deleteInvoicesUsingService(service);
	endif;
	service := self.myBank.services["UTWater1"];
	//  delete any invoice (lines, charges) using the service first so can delete the service
	if service &lt;&gt; null then
		self.deleteInvoicesUsingService(service);
	endif;
	// delete the services so can delete the calculation type
	self.deleteInvoiceService("UTWater", FORCED_ERASE);
	self.deleteInvoiceService("UTWater1", FORCED_ERASE);
	self.deleteInvoiceCalcType("UTH2O");	
	calcType := self.createInvoiceCalcType(null, INV_CALC_TYPE_RESOURCE_QTY, "UTH2O", "Water usage", 
										  0, 0, 0, 0, null, false,
										  null, null, 0, 0, 0,
										  null, null, null, null,
										  false, true, false,		// is voyage type=true
										  null, null, null, null);
	
	// Water service
	service := self.createInvoiceService("UTWater1","Water Used", calcType, null);
	
	// Voyage monthly invoice type
	self.deleteInvoiceType("UTVoyageMonthly");
	invType1 := self.createInvoiceTypeFull(CM_InvoiceDesc.Accrue_Until_Manually_Closed,
											null,
											"UTVoyageMonthly",
											CM_InvoiceDesc.Key_Voyage,
											InvoiceTypeGeneral,
											null,
											null,
											true,
											InvTypeTrigger_Release,
											now,
											now,
											0,
											"");
	// delete transaction map
	self.deleteInvoiceTransactionMap(3, 'UT_VTMIS9');
	
	// Water usage invoice line descriptions
	self.deleteInvoiceLineType("UTWaterUsage1", FORCED_ERASE);
	create services transient;
 	services.add(service);
	
	// invoice type
	ild := self.createInvoiceLineType("UTWaterUsage1", calcType, invType1, services, "SDT4");	// charge ship operator
	
	// resource type - delete used resource first
	self.deleteHarbourResource("UTWATER01", harbour);
	resourceType := self.addHMSResourceType("UTWATER", "Water Usage", "m3", 0, true, true,
											false, false, false, false);

	// resource
	resource := self.addHarbourResource("UTWATER01", "Water meter 1 usage", harbour, resourceType, wharf, 
										0, 0, false);
										
	create costs transient;
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);	
	debtor := operator.debtor;
// set a rate ($3.00) for the service and actual debtor
	create pxyDebtorRate transient;
	pxyDebtorRate.setProxy(service, debtor);
	costs.add(3.00);
	start.setDate("01/05/2010".Date);
	start.setTime("00:00".Time);
	rateEntry := self.addInvoiceRateEntry(pxyDebtorRate, start, null, false, costs, 0, 0, null, null);

	// load HMS transaction map
	self.tranMapLoadVTMIS9();
	
	// vessel and voyage with HMS data
	self.opts.purge();
	self.opts.addAssoc("useHMSData", true);
	self.opts.addAssoc("berth", berth);
	date := "01/06/2014".Date;
	fromDateTime.setDate(date);
	fromDateTime.setTime(time);
	toDateTime := fromDateTime.addDays(2);

	voyage1 := self.createVesselVoyage4("UTINVVSL4A", "UTINVVOY4A", fromDateTime, toDateTime);
	self.updateVoyageHMS(voyage1, 11111, 12222, 20.0, 5.0, 60000, 0);
	self.setVoyageVesselCategory(voyage1, cat);
//	self.setVoyageMoveResType(voyage1,HMSMovementTypeArrival, resourceType);
	
	
	// movement maintenance, add resource usage (1200 units) 
	movement := voyage1.myHMSVoyageData.allVoyageMovements.first;
	self.addHMSResourceToMovement(resourceType, resource, null, fromDateTime, toDateTime,  1200, false, movement);
	// set the move status so invoicing will take place
	beginTransaction;
	foreach movement in voyage1.myHMSVoyageData.allVoyageMovements do
		movement.setPropertyValue("moveStatusNEW", MovementStatus_Actual);
	endforeach;
	commitTransaction;

	// generate invoice
	self.generateVoyageInvoicing(voyage1);

	// test invoice - should be none
	self.assertEqualMsg(voyage1.allInvoices.size, 0, "Voyage Invoices, voyage 1");
	
	

epilog
	self.resetDefaultTranMap();
	delete services;
	delete costs;
	delete pxyDebtorRate;
	delete transSet;
	delete invoiceLines;
end;</source>
    </JadeMethod>
    <JadeMethod name="tHMSVoyageCharge" id="5024ae77-9da7-41e0-ad72-48758800a346">
        <updating/>
        <source>tHMSVoyageCharge() updating;
// cnwma1
// cnwjre1	par 34744 monthly marine invoices - checking that the non-monthly voyage stuff still works
//	Has a marine invoice type which is voyage.  Three voyages arrive and leave within the month.
//	There should be a new invoice for all voyages.
vars
	date,
	now			: Date;
	time		: Time;
	count		: Integer;
	invCount	: Integer;
	invLine		: CM_InvoiceLine;
	start		: TimeStamp;
	fromDateTime, 
	toDateTime	: TimeStamp;
	costs		: DecimalArray;
	term		: CM_Terminal;
	calcType	: CM_CalculationType;
	service		: CM_Service;
	services	: CM_ServiceByNameDict;
	invType1,
	invType2	: CM_InvoiceDesc;
	ild			: CM_InvoiceLineDesc;
	resourceType	: HMS_ResourceType;
	harbour		: HMS_Harbour;
	berth		: HMS_Berth;
	wharf		: HMS_Wharf;
	resource	: HMS_Resource;
	resUsed		: HMS_ResourceUsed;
	operator	: CM_Operator;
	debtor		: CM_Debtor;
	pxyDebtorRate,
	debtorRate	: CM_DebtorRate;
	rateEntry	: CM_RateEntry;
	voyage1,
	voyage2,
	voyage3		: CM_Voyage;
	movement	: HMS_VoyageMovement;
	transSet	: CM_TransactionSet;
	invoice		: CM_Invoice;
	invoiceLines : ObjectArray;

begin

	term := self.getTerminal();
	harbour := term.myHarbour;
	berth := harbour.allBerths.last;
	wharf := berth.myWharf;

	// Water calculation type
	service := self.myBank.services["UTWater"];
	//  delete any invoice (lines, charges) using the service first so can delete the service
	if service &lt;&gt; null then
		self.deleteInvoicesUsingService(service);
	endif;
	service := self.myBank.services["UTWater1"];
	//  delete any invoice (lines, charges) using the service first so can delete the service
	if service &lt;&gt; null then
		self.deleteInvoicesUsingService(service);
	endif;
	// delete the services so can delete the calculation type
	self.deleteInvoiceService("UTWater", FORCED_ERASE);
	self.deleteInvoiceService("UTWater1", FORCED_ERASE);
	self.deleteInvoiceCalcType("UTH2O");	
	calcType := self.createInvoiceCalcType(null, INV_CALC_TYPE_RESOURCE_QTY, "UTH2O", "Water usage", 
										  0, 0, 0, 0, null, false,
										  null, null, 0, 0, 0,
										  null, null, null, null,
										  false, true, false,		// is voyage type=true
										  null, null, null, null);
	
	// Water service
	service := self.createInvoiceService("UTWater1","Water Used", calcType, null);
	
	// Voyage monthly invoice type
	self.deleteInvoiceType("UTVoyageMonthly");
	invType1 := self.createInvoiceTypeFull(CM_InvoiceDesc.Accrue_Until_Manually_Closed,
											null,
											"UTVoyageMonthly",
											CM_InvoiceDesc.Key_Voyage,
											InvoiceTypeGeneral,
											null,
											null,
											true,
											InvTypeTrigger_Release,
											now,
											now,
											0,
											"");
	// delete transaction map
	self.deleteInvoiceTransactionMap(3, 'UT_VTMIS4');
	
	// Water usage invoice line descriptions
	self.deleteInvoiceLineType("UTWaterUsage1", FORCED_ERASE);
	create services transient;
 	services.add(service);
	
	// invoice type
	ild := self.createInvoiceLineType("UTWaterUsage1", calcType, invType1, services, "SDT4");	// charge ship operator
	
	// resource type - delete used resource first
	self.deleteHarbourResource("UTWATER01", harbour);
	resourceType := self.addHMSResourceType("UTWATER", "Water Usage", "m3", 0, true, true,
											false, false, false, false);

	// resource
	resource := self.addHarbourResource("UTWATER01", "Water meter 1 usage", harbour, resourceType, wharf, 
										0, 0, false);
										
	create costs transient;
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);	
	debtor := operator.debtor;
// set a rate ($3.00) for the service and actual debtor
	create pxyDebtorRate transient;
	pxyDebtorRate.setProxy(service, debtor);
	costs.add(3.00);
	start.setDate("01/05/2010".Date);
	start.setTime("00:00".Time);
	rateEntry := self.addInvoiceRateEntry(pxyDebtorRate, start, null, false, costs, 0, 0, null, null);

	// load HMS transaction map
	self.tranMapLoadVTMIS4();
	
	// vessel and voyage with HMS data
	self.opts.purge();
	self.opts.addAssoc("useHMSData", true);
	self.opts.addAssoc("berth", berth);
	date := "01/06/2014".Date;
	fromDateTime.setDate(date);
	fromDateTime.setTime(time);
	toDateTime := fromDateTime.addDays(2);

	voyage1 := self.createVesselVoyage4("UTINVVSL4A", "UTINVVOY4A", fromDateTime, toDateTime);
	self.updateVoyageHMS(voyage1, 11111, 12222, 20.0, 5.0, 60000, 0);
	
	// movement maintenance, add resource usage (1200 units) 
	movement := voyage1.myHMSVoyageData.allVoyageMovements.first;
	self.addHMSResourceToMovement(resourceType, resource, null, fromDateTime, toDateTime,  1200, false, movement);
	// set the move status so invoicing will take place
	beginTransaction;
	foreach movement in voyage1.myHMSVoyageData.allVoyageMovements do
		movement.setPropertyValue("moveStatusNEW", MovementStatus_Actual);
	endforeach;
	commitTransaction;

	// generate invoice
	self.generateVoyageInvoicing(voyage1);
	
	// test invoice - should be one, with one line
	foreach invoice in voyage1.allInvoices do
		count := count + 1;
		foreach invLine in invoice.invoiceLines do
			invCount := invCount + 1;
			self.assertEqualMsg(invLine.quantity, 1200.Real, "line 1 quantity");
			self.assertEqualMsg(invLine.lineTotal, 3600.Decimal, "line 1 value");
			self.assertEqualMsg(invLine.invoiceLineDesc.narration, "UTWaterUsage1", "line 1 ILD ");
		endforeach;
		self.assertEqualMsg(invCount, 1, "Voyage 1 invoice lines");
	endforeach;
	self.assertEqualMsg(count, 1, "Voyage Invoices, voyage 1");
	
	// VOYAGE 2
	date := "10/06/2014".Date;
	fromDateTime.setDate(date);
	fromDateTime.setTime(time);
	toDateTime := fromDateTime.addDays(2);

	voyage2 := self.createVesselVoyage4("UTINVVSL4B", "UTINVVOY4B", fromDateTime, toDateTime);
	self.updateVoyageHMS(voyage2, 11111, 12222, 20.0, 5.0, 60000, 0);
	// movement maintenance, add resource usage (1200 units) 
	movement := voyage2.myHMSVoyageData.allVoyageMovements.first;
	self.addHMSResourceToMovement(resourceType, resource, null, fromDateTime, toDateTime,  1200, false, movement);
	// set the move status so invoicing will take place
	beginTransaction;
	foreach movement in voyage2.myHMSVoyageData.allVoyageMovements do
		movement.setPropertyValue("moveStatusNEW", MovementStatus_Actual);
	endforeach;
	commitTransaction;

	// generate invoice
	self.generateVoyageInvoicing(voyage2);
	
	// test invoice - should be one, with one line
	count := 0;
	invCount := 0;
	foreach invoice in voyage2.allInvoices do
		count := count + 1;
		foreach invLine in invoice.invoiceLines do
			invCount := invCount + 1;
			self.assertEqualMsg(invLine.quantity, 1200.Real, "line 1 quantity");
			self.assertEqualMsg(invLine.lineTotal, 3600.Decimal, "line 1 value");
			self.assertEqualMsg(invLine.invoiceLineDesc.narration, "UTWaterUsage1", "line 1 ILD ");
		endforeach;
		self.assertEqualMsg(invCount, 1, "Voyage 2 invoice lines");
	endforeach;
	self.assertEqualMsg(count, 1, "Voyage Invoices, voyage 2");
	
	// VOYAGE 3
	date := "20/06/2014".Date;
	fromDateTime.setDate(date);
	fromDateTime.setTime(time);
	toDateTime := fromDateTime.addDays(2);

	voyage3 := self.createVesselVoyage4("UTINVVSL4C", "UTINVVOY4C", fromDateTime, toDateTime);
	self.updateVoyageHMS(voyage3, 11111, 12222, 20.0, 5.0, 60000, 0);
	// movement maintenance, add resource usage (1200 units) 
	movement := voyage3.myHMSVoyageData.allVoyageMovements.first;
	self.addHMSResourceToMovement(resourceType, resource, null, fromDateTime, toDateTime,  1200, false, movement);
	// set the move status so invoicing will take place
	beginTransaction;
	foreach movement in voyage3.myHMSVoyageData.allVoyageMovements do
		movement.setPropertyValue("moveStatusNEW", MovementStatus_Actual);
	endforeach;
	commitTransaction;

	// generate invoice
	self.generateVoyageInvoicing(voyage3);
	
	// test invoice - should be one, with one line
	count := 0;
	invCount := 0;
	foreach invoice in voyage3.allInvoices do
		count := count + 1;
		foreach invLine in invoice.invoiceLines do
			invCount := invCount + 1;
			self.assertEqualMsg(invLine.quantity, 1200.Real, "line 1 quantity");
			self.assertEqualMsg(invLine.lineTotal, 3600.Decimal, "line 1 value");
			self.assertEqualMsg(invLine.invoiceLineDesc.narration, "UTWaterUsage1", "line 1 ILD ");
		endforeach;
		self.assertEqualMsg(invCount, 1, "Voyage 2 invoice lines");
	endforeach;
	self.assertEqualMsg(count, 1, "Voyage Invoices, voyage 3");

epilog
	self.resetDefaultTranMap();
	delete services;
	delete costs;
	delete pxyDebtorRate;
	delete transSet;
	delete invoiceLines;
end;</source>
    </JadeMethod>
    <JadeMethod name="tHMSVoyageMovementNoCharge" id="3e95f1eb-69c7-41db-a795-9861d3d9ae16">
        <updating/>
        <source>tHMSVoyageMovementNoCharge() updating;
// cnwma1
// cnwjre1	par 37145 test setting the 'No charge' movement option (was being ignored)
vars
	date,
	now			: Date;
	time		: Time;
	count		: Integer;
	invCount	: Integer;
	invLine		: CM_InvoiceLine;
	start		: TimeStamp;
	fromDateTime, 
	toDateTime	: TimeStamp;
	costs		: DecimalArray;
	term		: CM_Terminal;
	calcType	: CM_CalculationType;
	service		: CM_Service;
	services	: CM_ServiceByNameDict;
	invType1,
	invType2	: CM_InvoiceDesc;
	ild			: CM_InvoiceLineDesc;
	resourceType	: HMS_ResourceType;
	harbour		: HMS_Harbour;
	berth		: HMS_Berth;
	wharf		: HMS_Wharf;
	resource	: HMS_Resource;
	resUsed		: HMS_ResourceUsed;
	operator	: CM_Operator;
	debtor		: CM_Debtor;
	pxyDebtorRate,
	debtorRate	: CM_DebtorRate;
	rateEntry	: CM_RateEntry;
	voyage1,
	voyage2,
	voyage3		: CM_Voyage;
	movement	: HMS_VoyageMovement;
	hmsTrans	: HMS_VTMISTransaction;
	transSet	: CM_TransactionSet;
	invoice		: CM_Invoice;
	invoiceLines : ObjectArray;

begin

	term := self.getTerminal();
	harbour := term.myHarbour;
	berth := harbour.allBerths.last;
	wharf := berth.myWharf;

	// Water calculation type
	service := self.myBank.services["UTWater"];
	//  delete any invoice (lines, charges) using the service first so can delete the service
	if service &lt;&gt; null then
		self.deleteInvoicesUsingService(service);
	endif;
	service := self.myBank.services["UTWater1"];
	//  delete any invoice (lines, charges) using the service first so can delete the service
	if service &lt;&gt; null then
		self.deleteInvoicesUsingService(service);
	endif;
	// delete the services so can delete the calculation type
	self.deleteInvoiceService("UTWater", FORCED_ERASE);
	self.deleteInvoiceService("UTWater1", FORCED_ERASE);
	self.deleteInvoiceCalcType("UTH2O");	
	calcType := self.createInvoiceCalcType(null, INV_CALC_TYPE_RESOURCE_QTY, "UTH2O", "Water usage", 
										  0, 0, 0, 0, null, false,
										  null, null, 0, 0, 0,
										  null, null, null, null,
										  false, true, false,		// is voyage type=true
										  null, null, null, null);
	
	// Water service
	service := self.createInvoiceService("UTWater1","Water Used", calcType, null);
	
	// Voyage monthly invoice type
	self.deleteInvoiceType("UTVoyageMonthly");
	invType1 := self.createInvoiceTypeFull(CM_InvoiceDesc.Accrue_Until_Manually_Closed,
											null,
											"UTVoyageMonthly",
											CM_InvoiceDesc.Key_Voyage,
											InvoiceTypeGeneral,
											null,
											null,
											true,
											InvTypeTrigger_Release,
											now,
											now,
											0,
											"");
	// delete transaction map
	self.deleteInvoiceTransactionMap(3, 'UT_VTMIS4');
	
	// Water usage invoice line descriptions
	self.deleteInvoiceLineType("UTWaterUsage1", FORCED_ERASE);
	create services transient;
 	services.add(service);
	
	// invoice type
	ild := self.createInvoiceLineType("UTWaterUsage1", calcType, invType1, services, "SDT4");	// charge ship operator
	
	// resource type - delete used resource first
	self.deleteHarbourResource("UTWATER01", harbour);
	resourceType := self.addHMSResourceType("UTWATER", "Water Usage", "m3", 0, true, true,
											false, false, false, false);

	// resource
	resource := self.addHarbourResource("UTWATER01", "Water meter 1 usage", harbour, resourceType, wharf, 
										0, 0, false);
										
	create costs transient;
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);	
	debtor := operator.debtor;
// set a rate ($3.00) for the service and actual debtor
	create pxyDebtorRate transient;
	pxyDebtorRate.setProxy(service, debtor);
	costs.add(3.00);
	start.setDate("01/05/2010".Date);
	start.setTime("00:00".Time);
	rateEntry := self.addInvoiceRateEntry(pxyDebtorRate, start, null, false, costs, 0, 0, null, null);

	// load HMS transaction map
	self.tranMapLoadVTMIS4();
	
	// vessel and voyage with HMS data
	self.opts.purge();
	self.opts.addAssoc("useHMSData", true);
	self.opts.addAssoc("berth", berth);
	date := "01/06/2014".Date;
	fromDateTime.setDate(date);
	fromDateTime.setTime(time);
	toDateTime := fromDateTime.addDays(2);

	voyage1 := self.createVesselVoyage4("UTINVVSL4A", "UTINVVOY4A", fromDateTime, toDateTime);
	self.updateVoyageHMS(voyage1, 11111, 12222, 20.0, 5.0, 60000, 0);
	
	// movement maintenance, add resource usage (1200 units) 
	movement := voyage1.myHMSVoyageData.allVoyageMovements.first;
	self.addHMSResourceToMovement(resourceType, resource, null, fromDateTime, toDateTime,  1200, false, movement);
	// set the move status so invoicing will take place
	//  AND reset the charge for move flag which is the actual test
	beginTransaction;
	foreach movement in voyage1.myHMSVoyageData.allVoyageMovements do
		movement.setPropertyValue("moveStatusNEW", MovementStatus_Actual);
		movement.setPropertyValue("chargeForMove", false);
	endforeach;
	commitTransaction;

	// generate invoice
	self.generateVoyageInvoicing(voyage1);
	
	// test invoices - should be none
	foreach invoice in voyage1.allInvoices do
		count := count + 1;
		foreach invLine in invoice.invoiceLines do
			invCount := invCount + 1;
		endforeach;
	endforeach;
	self.assertEqualMsg(count, 0, "Voyage Invoices");
	// recheck via each movement and transaction
	count := 0;
	foreach movement in voyage1.myHMSVoyageData.allVoyageMovements do
		foreach resUsed in movement.allResourceUsed do	
			foreach invLine in resUsed.myVTMISTransaction.allInvoiceLines do
				count := count + 1;
			endforeach;
		endforeach;
	endforeach;
	self.assertEqualMsg(count, 0, "Voyage Invoice lines from movements");
epilog
	self.resetDefaultTranMap();
	delete services;
	delete costs;
	delete pxyDebtorRate;
	delete transSet;
	delete invoiceLines;
end;</source>
    </JadeMethod>
    <JadeMethod name="tHMSWaterUsage" id="d641a9a7-bb0a-4ad3-8da8-815c1da8c671">
        <updating/>
        <source>tHMSWaterUsage() updating;
// cnwma1
// cnwjre1	general HMS water usage - as in Appendix A of the Invoicing User Manual
//	Works!
vars
	now			: Date;
	time		: Time;
	count		: Integer;
	start		: TimeStamp;
	fromDateTime, 
	toDateTime	: TimeStamp;
	costs		: DecimalArray;
	term		: CM_Terminal;
	calcType	: CM_CalculationType;
	service		: CM_Service;
	services	: CM_ServiceByNameDict;
	invType		: CM_InvoiceDesc;
	ild			: CM_InvoiceLineDesc;
	resourceType	: HMS_ResourceType;
	harbour			: HMS_Harbour;
	berth			: HMS_Berth;
	wharf			: HMS_Wharf;
	resource		: HMS_Resource;
	resUsed			: HMS_ResourceUsed;
	operator		: CM_Operator;
	debtor			: CM_Debtor;
	pxyDebtorRate,
	debtorRate		: CM_DebtorRate;
	rateEntry		: CM_RateEntry;
	voyage			: CM_Voyage;
	movement		: HMS_VoyageMovement;
	transSet		: CM_TransactionSet;
	invoice			: CM_Invoice;
	invoiceLines 	: ObjectArray;

begin
	term 	:= self.getTerminal();
	harbour := term.myHarbour;
	berth 	:= harbour.allBerths.last;
	wharf 	:= berth.myWharf;

	// Water calculation type
	service := self.myBank.services["UTWater"];
	//  delete any invoice (lines, charges) using the service first so can delete the service
	if service &lt;&gt; null then
		self.deleteInvoicesUsingService(service);
	endif;
	// delete the service so can delete the calculation type
	self.deleteInvoiceService("UTWater", FORCED_ERASE);
	self.deleteInvoiceService("UTWater1", FORCED_ERASE);
	self.deleteInvoiceCalcType("UTH2O");	
	calcType := self.createInvoiceCalcType(null, INV_CALC_TYPE_RESOURCE_QTY, "UTH2O", "Water usage", 
										  0, 0, 0, 0, null, false,
										  null, null, 0, 0, 0,
										  null, null, null, null,
										  false, true, false,		// is voyage type=true
										  null, null, null, null);
	
	// Water service
	service := self.createInvoiceService("UTWater","Water Used", calcType, null);
	
	// Voyage invoice type
	self.deleteInvoiceType("UTVoyage");
	invType := self.createInvoiceTypeFull(CM_InvoiceDesc.Accrue_Until_Manually_Closed,
											null,
											"UTVoyage",
											CM_InvoiceDesc.Key_Voyage,
											InvoiceTypeGeneral,
											null,
											null,
											true,
											InvTypeTrigger_Release,
											now,
											now,
											0,
											"");

	// delete transaction map
	self.deleteInvoiceTransactionMap(3, 'UT_VTMIS1');
	
	// Water usage invoice line description
	self.deleteInvoiceLineType("UTWaterUsage", FORCED_ERASE);
	create services transient;
 	services.add(service);
	
	// invoice type
	ild := self.createInvoiceLineType("UTWaterUsage", calcType, invType, services, "SDT4");	// charge ship operator
	
	// resource type - delete used resource first
	self.deleteHarbourResource("UTWATER01", harbour);
	resourceType := self.addHMSResourceType("UTWATER", "Water Usage", "m3", 0, true, true,
											false, false, false, false);

	// resource
	resource := self.addHarbourResource("UTWATER01", "Water meter 1 usage", harbour, resourceType, wharf, 
										0, 0, false);
										
	// vessel and voyage with HMS data
	self.opts.purge();
	self.opts.addAssoc("useHMSData", true);
	self.opts.addAssoc("berth", berth);
	voyage := self.createVesselVoyage3();
	self.updateVoyageHMS(voyage, 11111, 12222, 20.0, 5.0, 60000, 0);
	
	// load HMS transaction map
	self.tranMapLoadVTMIS1();
	
	// movement maintenance, add resource usage (1200 units)
	fromDateTime.setDate(now);
	fromDateTime.setTime(time);
	movement := voyage.myHMSVoyageData.allVoyageMovements.first;
	self.addHMSResourceToMovement(resourceType, resource, null, fromDateTime, toDateTime,  1200, false, movement);
	// set the move status so invoicing will take place
	beginTransaction;
	foreach movement in voyage.myHMSVoyageData.allVoyageMovements do
		movement.setPropertyValue("moveStatusNEW", MovementStatus_Actual);
	endforeach;
	commitTransaction;

	create costs transient;
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);	
	debtor := operator.debtor;
// set a rate ($3.00) for the service and actual debtor
	create pxyDebtorRate transient;
	pxyDebtorRate.setProxy(service, debtor);
	costs.add(3.00);
	start.setDate("01/05/2010".Date);
	start.setTime("00:00".Time);
	rateEntry := self.addInvoiceRateEntry(pxyDebtorRate, start, null, false, costs, 0, 0, null, null);

	// generate invoice
	self.generateVoyageInvoicing(voyage);
	
	// test invoice - should be one, with one line
	foreach invoice in voyage.allInvoices do
		count := count + 1;
		validateHMSInvoice1(invoice, count);
	endforeach;
	self.assertEqualMsg(count, 1, "Voyage Invoices, test 1");
	
	// do a resync of the VTMIS transactions - should stay the same
	create transSet transient;
	foreach movement in voyage.myHMSVoyageData.allVoyageMovements do
		foreach resUsed in movement.allResourceUsed do
			if resUsed.myVTMISTransaction &lt;&gt; null then
				transSet.add(resUsed.myVTMISTransaction);
			endif;
		endforeach;
	endforeach;
	self.updateInvoiceReevaluate(transSet, null, null);
	// test invoice - should still be one, with one line
	count := 0;
	foreach invoice in voyage.allInvoices do
		count := count + 1;
		validateHMSInvoice1(invoice, count);
	endforeach;
	self.assertEqualMsg(count, 1, "Voyage Invoices, test 3");
	
	// do a re-evaluate on the invoice line - should stay the same
	create invoiceLines transient;
	foreach invoice in voyage.allInvoices do
		invoice.invoiceLines.copy(invoiceLines);
	endforeach;
	
	self.invoiceLineReevaluate(invoiceLines);
	// test invoice - should still be one, with one line ** THIS DOES WORK **
	count := 0;
	foreach invoice in voyage.allInvoices do
		count := count + 1;
		validateHMSInvoice1(invoice, count);
	endforeach;
	self.assertEqualMsg(count, 1, "Voyage Invoices, test 4");

	// change the rate to $4.00
	debtorRate := rateEntry.rate.CM_DebtorRate;
	costs.clear();
	costs.add(4.00);
	self.updateInvoiceRateEntry(debtorRate, rateEntry, start, null, false, costs, 0, 0, null,null);
	
	// re-test for the new invoice value
	count := 0;
	foreach invoice in voyage.allInvoices do
		count := count + 1;
		validateHMSInvoice1a(invoice, count);
	endforeach;
	self.assertEqualMsg(count, 1, "Voyage Invoices, test 5");
	
	// change the resource usage units from 1200 to 600 and re-evaluate the invoice lines
	beginTransaction;
	foreach movement in voyage.myHMSVoyageData.allVoyageMovements do
		foreach resUsed in movement.allResourceUsed do
			resUsed.setPropertyValue("unitsUsed", 600.Real);
		endforeach;
	endforeach;
	commitTransaction;

	invoiceLines.clear();
	foreach invoice in voyage.allInvoices do
		invoice.invoiceLines.copy(invoiceLines);
	endforeach;
		
	self.invoiceLineReevaluate(invoiceLines);

	// re-test for the new quantity and value
	count := 0;
	foreach invoice in voyage.allInvoices do
		count := count + 1;
		validateHMSInvoice1b(invoice, count);
	endforeach;
	self.assertEqualMsg(count, 1, "Voyage Invoices, test 6");
	
epilog
	self.resetDefaultTranMap();												// 17/04/2013 cnwmh5
	delete services;
	delete costs;
	delete pxyDebtorRate;
	delete transSet;
	delete invoiceLines;
end;</source>
    </JadeMethod>
    <JadeMethod name="tInclusiveStorageDays" id="901875bd-c964-45bd-96aa-f7b39eaf6672">
        <updating/>
        <source>tInclusiveStorageDays() updating;
// cnwma1
// cnwjre1

// Uses the operator free storage days config.
// receive an MT, then release as a FULL
// Test CCMS 2109 par 26108 - this uses the new terminal config option
vars

begin

	self.inclExclStorageDays(true);
end;</source>
    </JadeMethod>
    <JadeMethod name="tInvAndInvLinesStaticData" id="45451656-43d6-450f-bd22-50043b4fe37a">
        <updating/>
        <source>tInvAndInvLinesStaticData() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 March 2024	navra1	Initial creation for TFS 57933 Invoice and Invoice Line details that need to be static &lt;&lt;54090&gt;&gt;

*/

constants
	DebtorNameOld	= "UT_DebtorOldName";
	DebtorNameNew	= "UT_DebtorNewName";
	InvoiceType = "UT_INV";
	VoyageId	= "UT_VOY1";
	ExtWebServiceDefName : String = "UT_InvoiceOracleIntf";		
	LineTypeName = "UT_TASCN";		
	UT_CurrencyCodeOld 		: String = "USD";
	UT_CurrencyCodeNew 		: String = "EUR";
	UT_LocaleOld 			: String = "Vocollect";
	UT_LocaleNew 			: String = "KIWI";
	
vars
	bank		: CM_Bank;
	terminal	: CM_Terminal;
	debtor		: CM_Debtor;
	//invType		: CM_InvoiceDesc;
	voyage		: CM_Voyage;
	invoice	: CM_Invoice;

	activeWebServiceDef : CM_ExternalWebServiceDef;
	pxyExtWebServiceDef : CM_InvoiceAPIServiceDef;
	bgpInvoiceAPIWSReq	: BGP_InvoiceAPIWSRequest;
	calcType : CM_CalculationType;
	service100 : CM_Service;
	//services : CM_ServiceByNameDict;
	invLineType		: CM_InvoiceLineDesc;
	invoiceLine		: CM_InvoiceLine;
	now             : TimeStamp;
	ewsActivity		: CM_ExternalWebServiceActivity;
	
	sentMessage : String;
	jsonHelper : JadeJson;
	transientObjs : ObjectArray;
	invoiceMessageFull : CMIF_InvoiceExtractFullObject;
	invStaticData:CMIF_InvStaticData;
	
	today		: Date;
	invType		: CM_InvoiceDesc;
	services	: CM_ServiceByNameDict;
	
	invProcess : CM_InvoiceProcess;
	debtorNodeController : CMIF_DebtorNode;
	proxyDebtor:CM_Debtor;
	
	locale : CM_Locale;
	currencyType : CM_CurrencyType;
	debtorTerminalDetail 	: CMIF_DebtorTerminalDetail;
	localeDesc : String;
	currencyDesc : String;
	
begin

	self.deleteInvoiceService("UT_ServiceCopy-1",0);
	self.deleteInvoiceType("UT_InvTypeCopy");
	self.deleteInvoiceLineType("UT_LineTypeCopy",0);
	now := app.actualTime();
	
	create pxyExtWebServiceDef as CM_InvoiceAPIServiceDef transient;
	
	pxyExtWebServiceDef.setProxy(	true,	//_active : Boolean;
									ExtWebServiceDefName,	//_name : String;  
									"http://143.96.24.26:80/",	//_baseEndpoint : String;  
									//app.pwEnCode( "test" ),	//_password : String;
									null,
									//"navis",	//_userCode : String; 
									null,
									3,	//_maxRetries : Integer;  
									1,	//_timeBetweenRetries : Integer; 
									10,	//_timeoutSeconds : Integer; 
									null,	//_restAPIAuthEndpoint : String; 
									null,	//_restAPIBaseEndpoint : String;
									null,	//_authProviderUrl : String;
									"TEST",	//_clientId : String;
									"123456",	//_clientSecret : String;
									null,	//_runAsKey : String;
									null	//_callBackUrl : String
									);	
	
	pxyExtWebServiceDef.setInvoiceLinesPerBatch(3500);
	app.myTrxCA.trxCreateExtWebService(pxyExtWebServiceDef, activeWebServiceDef, app.myPassport);
	
	terminal := self.getTerminal();
	self.assertNotNull(terminal);
	
	bank := terminal.getDefaultCompanyBank();
	self.assertNotNull(bank);
	
	debtor := self.getDebtor(DebtorNameOld);	
	self.assertNull(debtor);
	debtor := self.getDebtor(DebtorNameNew);	
	self.assertNull(debtor);
	debtor := self.addDebtor(DebtorNameOld, PaymentType_PrePay).CM_Debtor;		
	self.assertNotNullMsg(debtor,"Debtor Create Failed");	
	
	invType := self.getInvoiceType(InvoiceType);
	self.assertNotNull(invType);
	
	voyage := self.getVoyage(VoyageId);
	self.assertNotNull(voyage);	
	
	terminal := self.getTerminal();
	self.assertNotNull(terminal);
	
	bank := terminal.getDefaultCompanyBank();
	self.assertNotNull(bank);
	invProcess := app.myRoot.allInvoiceProcesses["InvoiceAPI"];
	self.assertNotNull(invProcess);
	beginTransaction;
		bank.setInvoiceProcess(invProcess);	
	commitTransaction;	
	
	calcType := app.myRoot.allCalculationTypesByCode["CCT00"];
	service100 := self.createInvoiceService("UT_ServiceCopy-1","1- Unit test for Task 61635", calcType, null);
	self.assertNotNullMsg(service100, "UT_ServiceCopy-1 not created");
	
	create services transient;
 	services.add(service100);
	
	invType := self.createInvoiceType("UT_InvTypeCopy", InvoiceTypeGeneral);
	self.assertNotNullMsg(invType, "Invoice type UT_InvTypeCopy not created");
	
	invLineType := self.createInvoiceLineType("UT_LineTypeCopy", calcType, invType, services,"SDT6");
	self.assertNotNullMsg(invLineType, "UT_LineTypeCopy not created");
	
	invoice := self.createManualInvoice(bank, debtor, voyage, invType, null);	
	self.assertNotNull(invoice);	
	locale := app.myRoot.allLocales[UT_LocaleOld];
	self.assertNotNullMsg(locale, "Locale VoCollect was null");
	self.updateInvLocale(invoice, locale);
	localeDesc := locale.localeDescription;
	currencyType := app.myRoot.allCurrencyTypes[UT_CurrencyCodeOld];
	self.assertNotNullMsg(currencyType, "Currency type USD was not found");
	self.updateInvCurrencyType(invoice, currencyType);
	currencyDesc := currencyType.description;	
	
	self.assertEqual(invoice.category, InvoiceCategory_Invoice);	
	
	beginTransaction;
		invoice.setContractId("OldContractID");			
	commitTransaction;	
	
	invoiceLine := self.createManualInvoiceLine(invLineType, invoice, 2, "UT-Copy-Inv1", now.date());		
	
	self.updateInvoiceStatus(invoice, CM_Invoice.INVOICE_PENDING, false, null, null, null, today, false);
	self.assertEqualMsg(invoice.status, CM_Invoice.INVOICE_PENDING, "Invoice status not updated to PENDING");	
	
	//make sure the static data is not filled up yet, before POSTING of the invoice
	self.assertNull(invoice.getMyInvStaticData());
	//there will be only one invoice line, who should not have any static data yet
	self.assertNull(invoice.invoiceLines.first().getMyInvLineStaticData());
	
	//we need to update it to INVOICE_POSTED_PENDING and not INVOICE_POSTED since the change to INVOICE_POSTED_PENDING 
	//from INVOICE_POSTED happens in doSave which is not called in this code path, and is only called in the UI code path
	self.updateInvoiceStatus(invoice, CM_Invoice.INVOICE_POSTED_PENDING, false, null, "200", null, today, false);
	self.assertEqualMsg(invoice.status, CM_Invoice.INVOICE_POSTED_PENDING, "Invoice status not updated to PENDING");
	
	//make sure the invoice static data is filled up after the POSTING of the invoice
	self.assertNotNull(invoice.getMyInvStaticData());
	//there will be only one invoice line, who should have any static data yet filled up
	self.assertNotNull(invoice.invoiceLines.first().getMyInvLineStaticData());
	
	//////////////////////////////////////
	//CHECK THE **DATA ON THE INVOICE**
	//////////////////////////////////////
	self.assertTrueMsg(invoice.debtor.name = DebtorNameOld, "The data on the invoice debtor name does not match before change debtor name");
	self.assertTrueMsg(invoice.debtor.longName = null, "The data on the invoice debtor long name does not match before change debtor long name");
	self.assertTrueMsg(invoice.contractIds = "OldContractID", "The data on the invoice contractid does not match before change contrct id");
	self.assertTrueMsg(invoice.myLocale.localeDescription = localeDesc, "The data on the invoice contractid does not match before change localedescription");
	self.assertTrueMsg(invoice.myCurrencyType.description = currencyDesc, "The data on the invoice contractid does not match before change currencydescription");
	
	//////////////////////////////////////
	//CHECK THE **DATA ON THE INVOICE LINE**
	//////////////////////////////////////
	self.assertTrueMsg(invoice.invoiceLines.first().debtor.name = DebtorNameOld, "The static data on the invoice debtor name does not match before change");	
	
	//////////////////////////////////////
	//CHECK THE **STATIC DATA ON THE INVOICE**
	//////////////////////////////////////
	self.assertTrueMsg(invoice.getMyInvStaticData().debtorName = DebtorNameOld, "The static data on the invoice debtor name does not match before change");
	self.assertTrueMsg(invoice.getMyInvStaticData().debtorLongName = null, "The static data on the invoice debtor long name does not match before change");
	self.assertTrueMsg(invoice.getMyInvStaticData().getContractIds() = "OldContractID", "The static data on the invoice contractid does not match before change");	
	self.assertTrueMsg(invoice.getMyInvStaticData.localeDescription = localeDesc, "The static data on the invoice localeDescription does not match before change");	
	self.assertTrueMsg(invoice.getMyInvStaticData.currencyDescription = currencyDesc, "The static data on the invoice currencyDescription does not match before change");	
	
	///////////////////////////////////////////
	//CHECK THE **STATIC DATA ON THE INVOICE LINE**
	///////////////////////////////////////////
	self.assertTrueMsg(invoice.invoiceLines.first().getMyInvLineStaticData().debtorName = DebtorNameOld, "The static data on the invoice line debtor name does not match before change");			
	self.assertTrueMsg(invoice.invoiceLines.first().getMyInvLineStaticData().invoiceLineDescNarration = "UT_LineTypeCopy", "The static data on the invoice line invoiceLineDescNarration name does not match before change(invoiceLineDescNarration)");		
	self.assertTrueMsg(invoice.invoiceLines.first().getMyInvLineStaticData().bankName = "Default Business Unit", "The static data on the invoice line bank name does not match before change(bankname)");			
	
	//send out the message which is done as a part of "export"ing the invoice, but do it manually over here
	create bgpInvoiceAPIWSReq transient;
	bgpInvoiceAPIWSReq.setDetails(invoice, invoice.myTerminal,  CM_InvoiceAPI.CONSMODE_NO_CONS, null, null,null);
	bgpInvoiceAPIWSReq.createAndSendInvoiceJSON( activeWebServiceDef.CM_InvoiceAPIServiceDef, 3);
	
	//check ths static data that was sent out as part of the message	
	foreach ewsActivity in activeWebServiceDef.CM_InvoiceAPIServiceDef.allEWSActivities do
		if ewsActivity.isKindOf(CM_EWSActivityInvoiceAPIParts) then			
			sentMessage := ewsActivity.CM_EWSActivityInvoiceAPIParts.getMessagePartString();
			
			create jsonHelper transient;
			create transientObjs transient;				
			invoiceMessageFull := jsonHelper.parse(sentMessage, CMIF_InvoiceExtractFullObject, transientObjs).CMIF_InvoiceExtractFullObject;
			invStaticData:=invoiceMessageFull.invoice.invStaticData;		
			
			///////////////////////////////////////////
			//CHECK THE **STATIC DATA ON THE INVOICE** in the data thats sent out
			///////////////////////////////////////////
			self.assertTrueMsg(invStaticData.debtorName = DebtorNameOld, "Message sent out did not have the invoice static data correct(DEBTOR NAME)");
			self.assertTrueMsg(invStaticData.debtorLongName = null, "Message sent out did not have the invoice static data correct(DEBTOR LONG NAME)");
			self.assertTrueMsg(invStaticData.contractIds = "OldContractID", "Message sent out did not have the invoice static data correct(CONTACTID)");
			self.assertTrueMsg(invStaticData.localeDescription = localeDesc, "Message sent out did not have the invoice static data correct(LOCALEDESC)");
			self.assertTrueMsg(invStaticData.currencyDescription = currencyDesc, "Message sent out did not have the invoice static data correct(CURRENCYDESC)");
			
			///////////////////////////////////////////
			//CHECK THE **STATIC DATA ON THE INVOICE LINE** in the data thats sent out
			///////////////////////////////////////////
			self.assertTrueMsg(invoiceMessageFull.invoice.invoiceLines.first().invLineStaticData.debtorName = DebtorNameOld, "Message sent out did not have the invoice static line data correct(DEBTOR NAME)");				
			self.assertTrueMsg(invoiceMessageFull.invoice.invoiceLines.first().invLineStaticData.invoiceLineDescNarration = "UT_LineTypeCopy", "Message sent out did not have the invoice static line data correct(invoiceLineDescNarration)");
			self.assertTrueMsg(invoiceMessageFull.invoice.invoiceLines.first().invLineStaticData.bankName = "Default Business Unit", "Message sent out did not have the invoice static line data correct(bankname)");			
		endif;
	endforeach;		
	
	/////////////////////////////////////////////
	//UPDATE DATA IN THE INVOICE AND INVOICE LINE
	/////////////////////////////////////////////
	create debtorNodeController transient;
	proxyDebtor := app.createUpdateProxy(debtor).CM_Debtor;
	self.setDebtorNodeController2(DebtorNameNew, debtorNodeController, proxyDebtor);
	debtorNodeController.longName := DebtorNameNew;	
	beginTransaction;
		invoice.setContractId("NewContractID");
	commitTransaction;	
	locale := app.myRoot.allLocales[UT_LocaleNew];
	self.assertNotNullMsg(locale, "Locale KIWI was null");
	self.updateInvLocale(invoice, locale);
	localeDesc := locale.localeDescription;
	currencyType := app.myRoot.allCurrencyTypes[UT_CurrencyCodeNew];
	self.assertNotNullMsg(currencyType, "Currency type EUR was not found");
	self.updateInvCurrencyType(invoice, currencyType);
	currencyDesc := currencyType.description;	
	
	app.myTrxUA.trxUpdateDebtorNode(debtorNodeController, app.myPassport);	
	
	delete debtorNodeController;
	delete proxyDebtor;
	
	//////////////////////////////////////
	//CHECK THE UPDATED **DATA ON THE INVOICE**
	//////////////////////////////////////
	self.assertTrueMsg(invoice.debtor.name = DebtorNameNew, "The static data on the invoice debtor name does not match after change");
	self.assertTrueMsg(invoice.debtor.longName = DebtorNameNew, "The static data on the invoice debtor long name does not match after change");
	self.assertTrueMsg(invoice.contractIds = "OldContractID,NewContractID", "The data on the invoice contractid does not match after change");
	self.assertTrueMsg(invoice.myLocale.localeDescription = localeDesc, "The data on the invoice localeDesc does not match after change");
	self.assertTrueMsg(invoice.myCurrencyType.description = currencyDesc, "The data on the invoice currencyDesc does not match after change");
	
	//////////////////////////////////////
	//CHECK THE UPDATED **DATA ON THE INVOICE LINE**
	//////////////////////////////////////
	self.assertTrueMsg(invoice.invoiceLines.first().debtor.name = DebtorNameNew, "The static data on the invoice line debtor name does not match after change");		
	
	//////////////////////////////////////
	//CHECK THE **STATIC DATA ON THE INVOICE** - should still have the original data
	//////////////////////////////////////
	self.assertTrueMsg(invoice.getMyInvStaticData().getDebtorName() = DebtorNameOld, "The static data on the invoice debtor name does not match after change(debtor name)");
	self.assertTrueMsg(invoice.getMyInvStaticData().getDebtorLongName() = null, "The static data on the invoice debtor long name does not match after change(debtor long name)");
	self.assertTrueMsg(invoice.getMyInvStaticData().getContractIds() = "OldContractID", "The static data on the invoice contractid does not match after change(contractid)");
	self.assertTrueMsg(invoice.getMyInvStaticData().getLocaleDescription() = "Voice Recognition", "The static data on the invoice localedesc does not match after change(localedesc)");
	self.assertTrueMsg(invoice.getMyInvStaticData().getCurrencyDesc() = "USD", "The static data on the invoice currencydesc does not match after change(currencydesc)");	
	
	///////////////////////////////////////////
	//CHECK THE **STATIC DATA ON THE INVOICE LINE** - should still have the original data
	///////////////////////////////////////////
	self.assertTrueMsg(invoice.invoiceLines.first().getMyInvLineStaticData().debtorName = DebtorNameOld, "The static data on the invoice debtor name does not match before change");	
	self.assertTrueMsg(invoice.invoiceLines.first().getMyInvLineStaticData().invoiceLineDescNarration = "UT_LineTypeCopy", "The static data on the invoice line invoiceLineDescNarration name does not match before change(invoiceLineDescNarration)");		
	self.assertTrueMsg(invoice.invoiceLines.first().getMyInvLineStaticData().bankName = "Default Business Unit", "The static data on the invoice line bank name does not match before change(bankname)");			
	
	
epilog
	self.deleteInvoice(invoice);	
	delete services;	
	delete debtorNodeController;	
	delete proxyDebtor;	
	delete jsonHelper;	
	delete invStaticData;	
	delete invoiceMessageFull;	
	delete bgpInvoiceAPIWSReq;
	delete pxyExtWebServiceDef;
	if services &lt;&gt; null then
		beginTransaction;
			services.purge();
			delete services;
		commitTransaction;
	endif;
	self.deleteDebtor(DebtorNameOld);
	self.deleteDebtor(DebtorNameNew);
	self.deleteExternalWebService(ExtWebServiceDefName);	
	delete jsonHelper;
	if transientObjs &lt;&gt; null then
		transientObjs.purge();
		delete transientObjs;
	endif;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tInvAndInvLinesStaticFields" id="c3a05273-1fb1-4dcb-97e6-643229f85b97">
        <source>tInvAndInvLinesStaticFields();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 Aug 2025	navnk30	JIRA 35575: NSW | Wharfage invoice line integrated to D365, is not the full rate

*/

constants
	DebtorName			= "UT_Debtor1";
	Service_Name_1		= "UT_ServiceContract-35585_1";
	Invoice_Type		= "UT_InvTypeContract-35585";
	Narration_1			= "UT_LineTypeContract-35585_1";
	Narration_2			= "52580";
	Calculation_Type	= "CCT00";
	VoyageId			= "UT_VOY1";
vars
	bank			: CM_Bank;
	terminal		: CM_Terminal;
	debtor			: CM_Debtor;
	invType			: CM_InvoiceDesc;
	voyage			: CM_Voyage;
	invoice			: CM_Invoice;
	calcType 		: CM_CalculationType;
	service			: CM_Service;
	services 		: CM_ServiceByNameDict;
	invLineDesc1,
	invLineDesc2	: CM_InvoiceLineDesc;
	invLine			: CM_InvoiceLine;
begin
	self.deleteInvoiceService(Service_Name_1,0);
	self.deleteInvoiceType(Invoice_Type);
	self.deleteInvoiceLineType(Narration_1,0);
	
	terminal := self.getTerminal();
	self.assertNotNull(terminal);
	
	bank := terminal.getDefaultCompanyBank();
	self.assertNotNull(bank);
	
	debtor := self.getDebtor(DebtorName);
	self.assertNotNull(debtor);
	
	calcType := app.myRoot.allCalculationTypesByCode[Calculation_Type];
	self.assertNotNull(calcType);
	
	invType := self.createInvoiceType(Invoice_Type, InvoiceTypeGeneral);
	self.assertNotNullMsg(invType, "Invoice type " &amp; Invoice_Type &amp; " not created");
	
	service := self.createInvoiceService(Service_Name_1, "1- Unit test for JIRA 35585", calcType, null);
	self.assertNotNullMsg(service, Service_Name_1 &amp; " not created");
	create services transient;
 	services.add(service);
	
	
	invLineDesc1 := self.createInvoiceLineType(Narration_1, calcType, invType, services,"SDT6");
	self.assertNotNullMsg(invLineDesc1, "UT_LineTypeContract not created");
	invLineDesc2 := self.getInvoiceLineType(Narration_2);
	self.assertNotNullMsg(invLineDesc2, "UT_LineTypeContract not created");
	
	voyage := self.getVoyage(VoyageId);
	self.assertNotNull(voyage);
	
	invoice	:= self.createManualInvoice(bank, debtor, voyage, invType, null);
	self.assertNotNull(invoice);
	
	invLine	:= self.createManualInvoiceLine(invLineDesc1, invoice, 10, Narration_1 , app.cnGetServerTime().date);
	self.assertNotNull(invLine);
	
	self.xTrxUpdateInvoiceLineConvert(invoice, invLineDesc2);
	self.assertEqualMsg(invLine.totalAmount, invLine.lineTotal, "Total Amount excl tax not updated correctly after changing Invoice Line Type");
	self.assertEqualMsg(invLine.totalAmount + invLine.getTotalTaxAmountForLine(), invLine.getLineTotalWithTax(), "Total Amount incl tax not updated correctly after changing Invoice Line Type");
	self.assertEqualMsg(invLine.totalRate, invLine.getRate(), "Total rate is not matching"); 
    
	self.deleteInvoice(invoice);
	self.deleteInvoiceService(Service_Name_1, 0);
	self.deleteInvoiceType(Invoice_Type);
	self.deleteInvoiceLineType(Narration_1, 0);
epilog
	delete services;
end;</source>
    </JadeMethod>
    <JadeMethod name="tInvConsByNarrCriteriaRate" id="26922c73-3cb0-4178-b84e-f2cdfdf880e2">
        <source>tInvConsByNarrCriteriaRate();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 February 2024	navrv30	Initial creation for CR 61911/ Task 61393

*/


constants
	DebtorName	= "UT_MDHDebtorZ";
	InvoiceType = "UT_INV";
	VoyageId	= "UT_VOY1";
	ExtWebServiceDefName : String = "UT_InvoiceOracleIntf";	
	ContID				= "UT_CONID";
	CargoTypeStr = "CANNONBALL";
	BLOCKSTACK = "BSUT8";
	VESSEL = "UTVB_001";
	VOYAGE1 = "UTVB_108";
	CARGOID1 = "VB230126";
	
vars
	bank		: CM_Bank;
	terminal	: CM_Terminal;
	debtor		: CM_Debtor;
	invType		: CM_InvoiceDesc;
	voyage		: CM_Voyage;
	invoice	: CM_Invoice;

	activeWebServiceDef : CM_ExternalWebServiceDef;
	pxyExtWebServiceDef : CM_InvoiceAPIServiceDef;
	bgpInvoiceAPIWSReq	: BGP_InvoiceAPIWSRequest;
	calcType : CM_CalculationType;
	service100 : CM_Service;
	services : CM_ServiceByNameDict;
	invLineType		: CM_InvoiceLineDesc;
	invoiceLine, invoiceLine2,
	invoiceLine3		: CM_InvoiceLine;
	now             : TimeStamp;
	realProcess     : CM_InvoiceProcess;
	theController		   : CMIF_ChargesController;
	ewsActivity		: CM_ExternalWebServiceActivity;
	transientObjs : ObjectArray;
	today,
	fromTime,
	toTime			: TimeStamp;
	realContract	    : CM_InvoiceContract;
	realContractDetails,
	realContractDetails2	: CM_InvoiceContractDetails;
	
	realRate	: CM_InvoiceContractRate;
	
	realRateEntry1,
	realRateEntry2	: CM_InvoiceContractRateEntry;
	cargoType		: CM_CargoType;
	operator		: CM_Operator;	
	bs1 : CM_BlockStack;
	product : CM_Product;
	vessel : CM_Vessel;
	port : CM_Port;
	ti1, ti2, ti3 : CM_TrackedItem;
	pxyRateEntry  : CM_InvoiceContractRateEntry;
	aCharge, pxyCharge : CM_Charge;
	
begin
	self.deleteExternalWebService(ExtWebServiceDefName);
	self.deleteInvoiceService("UT_ServiceCopy-1",0);
	self.deleteInvoiceService("UT_ServiceCopy-2",0);
	self.deleteInvoiceService("UT_ServiceCopy-3",0);
	self.deleteInvoiceType("UT_InvTypeCopy");
	self.deleteInvoiceLineType("UT_LineTypeCopy",0);
	self.deleteInvoiceLineType("UT_LineTypeCopy1",0);
	self.deleteInvoiceLineType("UT_LineTypeCopy2",0);
	self.deleteInvoiceLineType("UT_LineTypeCopy3",0);
	now := app.actualTime();
	create transientObjs transient;
	beginTransaction;
	create pxyExtWebServiceDef as CM_InvoiceAPIServiceDef transient;
	
	pxyExtWebServiceDef.setProxy(	true,	//_active : Boolean;
									ExtWebServiceDefName,	//_name : String;  
									"http://143.96.24.26:80/",	//_baseEndpoint : String;  
									null,//app.pwEnCode( "test" ),	//_password : String;
									"MTN3",	//_userCode : String; 
									3,	//_maxRetries : Integer;  
									1,	//_timeBetweenRetries : Integer; 
									10,	//_timeoutSeconds : Integer; 
									null,	//_restAPIAuthEndpoint : String; 
									null,	//_restAPIBaseEndpoint : String;
									null,	//_authProviderUrl : String;
									"MTN3",	//_clientId : String;
									null,	//_clientSecret : String;
									null,	//_runAsKey : String;
									null	//_callBackUrl : String
									);	
	
	pxyExtWebServiceDef.setInvoiceLinesPerBatch(3500);
	app.myUtilityCA.utlCreateExtWebService(pxyExtWebServiceDef, activeWebServiceDef, app.myPassport);	
	commitTransaction;
	
	terminal := self.getTerminal();
	self.assertNotNull(terminal);
	
	bank := terminal.getDefaultCompanyBank();
	self.assertNotNull(bank);
	
	debtor := self.getDebtor(DebtorName);
	self.assertNotNull(debtor);
	
	// ### JIRA 35899 02SEP2025 NAVAB1
	beginTransaction;
	debtor.setPropertyValue("externalReference",'');
	debtor.setPropertyValue("code","UT_NSWInvoice");
	commitTransaction;
	self.assertTrueMsg(debtor.externalReference  = "", "External Ref for " &amp; DebtorName &amp; " is Wrong should be blank, is " &amp; debtor.externalReference);  // ### JIRA 35899 02SEP2025 NAVAB1
	
	invType := self.getInvoiceType(InvoiceType);
	self.assertNotNull(invType);
	
	voyage := self.getVoyage(VoyageId);
	self.assertNotNull(voyage);		

	
	today := app.actualTimeServer();
	
	fromTime := today.addDays(-365);
	toTime	:= today.addDays(365);
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	
	realContract := self.newContract(debtor, ContID, false, false, fromTime, toTime, true);
	
	cargoType 				:= app.myRoot.getCargoTypeFromAbbrev("CONT");
	realContractDetails		:= self.newContractDetail(realContract, cargoType, "UT_ServiceCopy-1", "UT_InvTypeCopy", "UT_LineTypeCopy-1", "CC1", "CCDesc1");
	realContractDetails2	:= self.newContractDetail(realContract, cargoType, "UT_ServiceCopy-2", "UT_InvTypeCopy", "UT_LineTypeCopy-2", "CC2", "CCDesc2");
	//realContractDetails3	:= self.newContractDetail(realContract, cargoType, "UT_ServiceCopy-1", "UT_InvTypeCopy", "UT_LineTypeCopy-3", "CC1", "CCDesc1");
	
	beginTransaction;
	
	toTime := today.addDays(-30);
	realContractDetails2.setToTS(toTime);
	//realContractDetails3.setToTS(toTime);
	fromTime := realContractDetails2.toTS.addDays(1);	
	toTime := today.addDays(60);
	realContractDetails.setFromTS(fromTime);
	realContractDetails.setToTS(toTime);
	
	fromTime := realContractDetails.toTS.addDays(1);
	//realContractDetails3.setFromTS(fromTime);
	commitTransaction;
	
	
	invLineType := realContractDetails.myInvoiceLineType;
	calcType := invLineType.myCalculationType;	
	service100 := invLineType.services.first();	
	realRate := self.newcontractRate(realContractDetails, service100);		
	fromTime := realContractDetails.fromTS;
	toTime := realContractDetails.fromTS.addDays(10);	
	realRateEntry1 := self.newcontractRateEntry(realRate, 20.00, 1, 10, fromTime, toTime);
	beginLoad;
	pxyRateEntry := realRateEntry1.pxyCreateUpdateProxy();
	endLoad;		
	pxyRateEntry.setProxy(null,pxyRateEntry.costPerUnit,1,10,pxyRateEntry.fromTS, pxyRateEntry.toTS, realRate, realContract.myBusinessUnit);	
	app.myTrxUA.trxUpdateInvContractDtlRtEntry(pxyRateEntry,app.myPassport);	
	transientObjs.add(pxyRateEntry);
	
	
	invLineType := realContractDetails2.myInvoiceLineType;
	calcType := invLineType.myCalculationType;	
	service100 := invLineType.services.first();	
	realRate := self.newcontractRate(realContractDetails2, service100);		
	fromTime := realContractDetails2.fromTS;
	toTime := realContractDetails2.fromTS.addDays(10);	
	realRateEntry2 := self.newcontractRateEntry(realRate, 10.00, 1, 10, fromTime, toTime);
	beginLoad;
	pxyRateEntry := realRateEntry2.pxyCreateUpdateProxy();
	endLoad;		
	pxyRateEntry.setProxy(null,pxyRateEntry.costPerUnit,1,10,pxyRateEntry.fromTS, pxyRateEntry.toTS, realRate, realContract.myBusinessUnit);	
	app.myTrxUA.trxUpdateInvContractDtlRtEntry(pxyRateEntry,app.myPassport);
	transientObjs.add(pxyRateEntry);
	/*invLineType := realContractDetails3.myInvoiceLineType;
	calcType := invLineType.myCalculationType;	
	service100 := invLineType.services.first();	
	realRate := self.newcontractRate(realContractDetails3, service100);		
	fromTime := realContractDetails3.fromTS;
	toTime := realContractDetails3.fromTS.addDays(10);	
	realRateEntry3 := self.newcontractRateEntry(realRate, 10.00, 1, 10, fromTime, toTime);*/
	
	/******************************
	create cargo matching the contract information
	***********************/
	cargoType := app.myRoot.getCargoTypeFromAbbrev(CargoTypeStr);
	
	//self.tranMapLoadLineGrouping("UTLineGroup");
	
	bs1     		:= self.addBlockStack(BLOCKSTACK, 999999, null);
	product         := cargoType.allProducts.first;
	operator 		:= self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	terminal		:= self.getTerminal();
	vessel 			:= self.addVesselWithHolds(VESSEL, 2, 2);
	voyage 			:= self.addVoyageWithGeneralCargoStruc(VOYAGE1, vessel.name, vessel.myOperator.code,	self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 0);
	port 			:= app.myRoot.allPorts[voyage.myTerminal.getConfig(PortDestCode).String];
	
	ti1 := self.createGCOnShip(realContract.contractId, CARGOID1 &amp; "001", cargoType, operator, voyage, port,15000);
	
	ti2 := self.createGCOnShip(realContract.contractId, CARGOID1 &amp; "002", cargoType, operator, voyage, port,15000);
	
	ti3 := self.createGCOnShip(realContract.contractId, CARGOID1 &amp; "003", cargoType, operator, voyage, port,15000);
	
	/***************************************************************************************************************/
	
	

	
	invType := self.getInvoiceType("UT_InvTypeCopy");
	//self.createInvoiceType("UT_InvTypeCopy", InvoiceTypeGeneral);
	
	
	invoice := self.createManualInvoice(bank, debtor, voyage, invType, null);
	self.assertNotNull(invoice);
	self.assertEqual(invoice.category, InvoiceCategory_Invoice);	
	
	beginTransaction;
	invoice.sequenceNum := 999;	
	create theController transient;
	realProcess := app.myRoot.allInvoiceProcesses[InvoiceProcessInvoiceAPI];
	invoice.setMyInvoiceProcess(realProcess);
	commitTransaction;	
	self.setTerminalConfig(InvoiceAPIOpModeConfig, CM_InvoiceAPI.CONSMODE_INV_LINE_CRIT_RATE);  // ### JIRA 35902 22SEP2025 NAVAB1
	
	invLineType := realContractDetails.myInvoiceLineType;	
	invoiceLine := self.createManualInvoiceLineWithTI(invLineType, invoice, 2, "UT-Copy-Inv1", now.date(), ti1);
	foreach aCharge in invoiceLine.charges do 
		pxyCharge := app.createUpdateProxy(aCharge).CM_Charge;
		pxyCharge.setProxyRateNew(20.00);
		pxyCharge.setOverriden();
		theController.allCharges.add(pxyCharge);
		transientObjs.add(pxyCharge);
	endforeach;
	app.myTrxUA.trxUpdateChargesManual(theController,app.myPassport);
	theController.allCharges.clear();
	
	
	invLineType := realContractDetails2.myInvoiceLineType;	
	invoiceLine2 := self.createManualInvoiceLineWithTI(invLineType, invoice, 2, "UT-Copy-Inv2", now.date(), ti2);
	foreach aCharge in invoiceLine2.charges do 
		pxyCharge := app.createUpdateProxy(aCharge).CM_Charge;
		pxyCharge.setProxyRateNew(10.00);
		pxyCharge.setOverriden();
		theController.allCharges.add(pxyCharge);
		transientObjs.add(pxyCharge);
	endforeach;
	app.myTrxUA.trxUpdateChargesManual(theController,app.myPassport);
	theController.allCharges.clear();
	
	
	invLineType := realContractDetails.myInvoiceLineType;	
	invoiceLine3 := self.createManualInvoiceLineWithTI(invLineType, invoice, 2, "UT-Copy-Inv1", now.date(), ti2);
	foreach aCharge in invoiceLine3.charges do 
		pxyCharge := app.createUpdateProxy(aCharge).CM_Charge;
		pxyCharge.setProxyRateNew(20.00);
		pxyCharge.setOverriden();
		theController.allCharges.add(pxyCharge);
		transientObjs.add(pxyCharge);
	endforeach;
	app.myTrxUA.trxUpdateChargesManual(theController,app.myPassport);
	theController.allCharges.clear();
	
	beginTransaction;
	invoiceLine.setContractDetail(realContractDetails);
	invoiceLine2.setContractDetail(realContractDetails2);
	invoiceLine3.setContractDetail(realContractDetails);
	commitTransaction;
	
		
	
	create bgpInvoiceAPIWSReq transient;
	bgpInvoiceAPIWSReq.setDetails(invoice, invoice.myTerminal,  CM_InvoiceAPI.CONSMODE_INV_LINE_CRIT_RATE, null, null,null);
	bgpInvoiceAPIWSReq.createAndSendInvoiceJSON( activeWebServiceDef.CM_InvoiceAPIServiceDef,  4);
	
	foreach ewsActivity in activeWebServiceDef.CM_InvoiceAPIServiceDef.allEWSActivities do
		if ewsActivity.isKindOf(CM_EWSActivityInvoiceAPIParts) then
			self.valConsMsgByNarrCriRate(ewsActivity);
		endif;
	endforeach;	
	
epilog	
	
	delete bgpInvoiceAPIWSReq;
	delete pxyExtWebServiceDef;
	//delete pxyCharge;

	if services &lt;&gt; null then
		beginTransaction;
		services.purge();
		delete services;
		commitTransaction;
	endif;	
	delete theController;	
	if transientObjs &lt;&gt; null then
		transientObjs.purge();
	endif;
	delete transientObjs;
	//delete pxyRateEntry;
	beginTransaction;	
		delete aCharge;
		delete realContract;
		delete invoice;
		delete ti1;
		delete ti2;
		delete ti3;
	commitTransaction;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tInvLineDescCalcTypeChange" id="c705dda8-a2e8-4594-abcc-f7e01226f1ec">
        <updating/>
        <source>tInvLineDescCalcTypeChange() updating;
// cnwma1
// cnwjre1
/* ---------------------------------------------------------------------------
Created:    Apr 2012

Purpose:    SFW 1264 Invoice non-virtual fields, test invoice line description calculation type change
			now automatically propogates to invoice line quantity, plus that posting an
			invoice also automatically recalculates line quantity
        
Change Date	Who		Reason

------------------------------------------------------------------------------*/
vars
	date	: Date;
	ts		: TimeStamp;
	cargoMap	: CM_TranMap;
	theService : CM_Service;
	calType1		: CM_CalculationType;
	invType			: CM_InvoiceDesc;
	invLineType1,
	invLineType2,
	invLineType3,
	invLineType4  	: CM_InvoiceLineDesc;
	invoice		: CM_Invoice;
	services : CM_ServiceByNameDict;
	bs: CM_BlockStack;
	termArea	: CM_TerminalArea;
	loc		: CM_LocationsController;
	grid : CM_GridController;
	voy : CM_Voyage;
	cargo : CM_TrackedItem;
	aPort : CM_Port;
begin

	cargoMap := self.myBank.myCurrentTranMapCargo['Default'];
	self.assertNotNullMsg(cargoMap,"cargo map should not be null");
	app.myTrxUA.trxUpdateBankTMActive(cargoMap,app.myPassport);

	self.deleteTransactionMaps();

	// reefer area
	self.deleteTerminalArea("CTEST1");
	termArea := self.addRTGArea("CTEST1",2,2,2);
	foreach loc in termArea.allLocationsControllers where loc.isKindOf(CM_GridController) do
		grid := loc.CM_GridController;
	endforeach;

	// block stack
	bs:= self.getTerminalArea("UTSTORE").CM_BlockStack;
	if bs &lt;&gt; null then
		self.deleteInvoiceLines(bs.myLocationsController);
	endif;
	termArea:= self.getTerminalArea("CTEST1").CM_RTGArea;
	if termArea &lt;&gt; null then
		foreach loc in termArea.allLocationsControllers do
			self.deleteInvoiceLines(loc);
		endforeach;
	endif;
	self.deleteInvoiceTransactionMap(1, 'UT_Reefer');
	self.deleteInvoiceType("UT_InvTypeStore");
	self.deleteInvoiceService("UT_ServiceStore1", FORCED_ERASE);
	self.deleteInvoiceLineType("UT_LineTypeStore1", FORCED_ERASE);
	self.deleteInvoiceLineType("UT_LineTypeStore2", FORCED_ERASE);
	self.deleteInvoiceLineType("UT_LineTypeStore3", FORCED_ERASE);
	self.deleteInvoiceLineType("UT_LineTypeStore4", FORCED_ERASE);

	create services transient;

	////////////////////////////////////////////////////////////////////
	// Create Invoice Type, Services and Invoice Line Type
	////////////////////////////////////////////////////////////////////
	invType := self.createInvoiceType("UT_InvTypeStore", InvoiceTypeStorage);
	self.assertNotNullMsg(invType, "Invoice type UT_InvTypeStore not created");

	calType1 := app.myRoot.allCalculationTypesByCode['CCT02'];	// INV_CALC_TYPE_TRANSQUANTITY
	self.assertNotNullMsg(calType1, "Calculation type INV_CALC_TYPE_TRANSQUANTITY not found");
	
	
	theService := self.createInvoiceService("UT_ServiceStore1","UT Store1", calType1, null);
	self.assertNotNullMsg(theService, "UT_ServiceStore1 not created");
 	services.add(theService);
	
	invLineType1 := self.createInvoiceLineType("UT_LineTypeStore1", calType1, invType, services,"SDT1");
	invLineType2 := self.createInvoiceLineType("UT_LineTypeStore2", calType1, invType, services,"SDT1");
	invLineType3 := self.createInvoiceLineType("UT_LineTypeStore3", calType1, invType, services,"SDT1");
	invLineType4 := self.createInvoiceLineType("UT_LineTypeStore4", calType1, invType, services,"SDT1");
	
	self.assertNotNullMsg(invLineType1, "UT_LineTypeStore1 not created");
	self.assertNotNullMsg(invLineType2, "UT_LineTypeStore2 not created");
	self.assertNotNullMsg(invLineType3, "UT_LineTypeStore3 not created");
	self.assertNotNullMsg(invLineType4, "UT_LineTypeStore4 not created");

	// Need to map to above invoice line types, using quantity ranges
	self.tranMapLoadReefer();
	
	// create a container with retrospective transactions (refer example on PAR 24160)
	voy:=self.createVesselVoyage3();
	aPort := app.myRoot.allPorts["NZAKL"];


	// Create Reefer Daily Transaction
	cargo := self.createReefer("UACU7894561", grid);
	beginTransaction;
	cargo.setMyVoyage(voy, app.myPassport);
	commitTransaction;

	// base date 24/01/2011, reefer monitor 24/03/2011 but ship start date 04/01/2011 so 80 days not 60
	date.setDate(4,1,2011);
	ts.setDate(date);
	beginTransaction;
	voy.setPropertyValue("shipExchangeDate", ts);
	commitTransaction;

	self.createReeferTransactions(cargo);
	self.validateReeferTransactions(cargo, false);

	// change the calculation type of the invoice line types
	calType1 := app.myRoot.allCalculationTypesByCode['CCT06'];	// INV_CALC_TYPE_DAYS_SINCE_RECVL;
	self.assertNotNullMsg(calType1, "Calculation type INV_CALC_TYPE_DAYS_SINCE_RECVL not found");
	self.updateInvoiceLineType(invLineType1, invLineType1.narration, calType1, invLineType1.invoiceType, invLineType1.services, invLineType1.myDebtorType.code);

	self.validateCalcTypeChanged(cargo);
	
	// change the calculation type to use ship start date (will auto-recalc the invoice quantity)
	calType1 := app.myRoot.allCalculationTypesByCode['CCT108'];	// INV_CALC_TYPE_DAYSINCE_SHIP_ST
	self.assertNotNullMsg(calType1, "Calculation type INV_CALC_TYPE_DAYSINCE_SHIP_ST not found");
	self.updateInvoiceLineType(invLineType4, invLineType4.narration, calType1, invLineType4.invoiceType, invLineType4.services, invLineType4.myDebtorType.code);
	
	// base date 24/01/2011, reefer monitor 24/03/2011 now change ship start date to 14/01/2011 so 70 days not 60
	//  (no automatic invoice re-calc)
	date.setDate(14,1,2011);
	ts.setDate(date);
	beginTransaction;
	voy.setPropertyValue("shipExchangeDate", ts);
	commitTransaction;
	
	// post the invoice and check that it uses the new values
	invoice := self.findReeferTransactionInvoice(cargo);
	self.postInvoice2(invoice);
	self.validatePostedInvoice(invoice);
	
epilog
	delete services;
	termArea:= self.getTerminalArea("CTEST1").CM_RTGArea;
	if termArea &lt;&gt; null then
		foreach loc in termArea.allLocationsControllers do
			self.deleteInvoiceLines(loc);
		endforeach;
	endif;
	// delete this tran map so following tests can delete the invoice line descs etc
	cargoMap := self.myBank.myCurrentTranMapCargo['Default'];
	app.myTrxUA.trxUpdateBankTMActive(cargoMap,app.myPassport);
	self.deleteInvoiceTransactionMap(1, 'UT_Reefer');
	self.resetDefaultTranMap();												// 17/04/2013 cnwmh5
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tInvLineDescCalcTypeChange2" id="98f38127-9b1e-4f8a-ac41-1b47e06eb413">
        <updating/>
        <source>tInvLineDescCalcTypeChange2() updating;
// cnwma1
// cnwjre1
/* ---------------------------------------------------------------------------
Created:    Oct 2012

Purpose:    SFW 1264 Invoice non-virtual fields, test invoice line description calculation type of quantity from cargo weight
			now automatically propogates to invoice line quantity, plus that posting an
			invoice also automatically recalculates line quantity, when the cargo weight changes
        
Change Date	Who		Reason

------------------------------------------------------------------------------*/
vars
	cargoMap	: CM_TranMap;
	theService : CM_Service;
	calType1		: CM_CalculationType;
	invType			: CM_InvoiceDesc;
	invLineType1  	: CM_InvoiceLineDesc;
	services : CM_ServiceByNameDict;
	operator	: CM_Operator;
	bs: CM_BlockStack;
	termArea	: CM_TerminalArea;
	loc		: CM_LocationsController;
	voy : CM_Voyage;
	cargo : CM_TrackedItem;
	aPort : CM_Port;
	trans : CM_TransactionSet;
	tran : CM_TITransaction;
begin

	cargoMap := self.myBank.myCurrentTranMapCargo['Default'];
	self.assertNotNullMsg(cargoMap,"cargo map should not be null");
	app.myTrxUA.trxUpdateBankTMActive(cargoMap,app.myPassport);

	self.deleteTransactionMaps();

	// block stack
	bs:= self.getTerminalArea("UTSTORE").CM_BlockStack;
	self.deleteInvoiceLines(bs.myLocationsController);
	
	self.deleteInvoiceTransactionMap(1, 'UT_CargoWeight');
	self.deleteInvoiceType("UT_InvTypeStore");
	self.deleteInvoiceService("UT_ServiceStore1", FORCED_ERASE);
	self.deleteInvoiceLineType("UT_LineTypeStore1", FORCED_ERASE);

	create services transient;

	////////////////////////////////////////////////////////////////////
	// Create Invoice Type, Services and Invoice Line Type
	////////////////////////////////////////////////////////////////////
	invType := self.createInvoiceType("UT_InvTypeStore", InvoiceTypeStorage);
	self.assertNotNullMsg(invType, "Invoice type UT_InvTypeStore not created");

	calType1 := app.myRoot.allCalculationTypesByCode['CCT04'];
	self.assertNotNullMsg(calType1, "Calculation type CCT04 not found");
	
	theService := self.createInvoiceService("UT_ServiceStore1","UT Store1", calType1, null);
	self.assertNotNullMsg(theService, "UT_ServiceStore1 not created");
 	services.add(theService);
	
	invLineType1 := self.createInvoiceLineType("UT_LineTypeStore1", calType1, invType, services,"SDT1");
	
	self.assertNotNullMsg(invLineType1, "UT_LineTypeStore1 not created");

	// Need to map to above invoice line type
	self.tranMapLoadCargoWeight();
	
	voy:=self.createVesselVoyage3();
	
	aPort := app.myRoot.allPorts["NZAKL"];

	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString());
	cargo := self.addContainerAtLocation("UACU7894561", operator, "2200", "GENL", TI_IMEX_STATUS_IMPORT, bs);

	self.opts.addAssoc("TotalWeight", "6000");
	self.updateTrackedItem(cargo);

	create trans transient;
	foreach tran in cargo.allTransactions discreteLock do
		trans.add(tran);
	endforeach;
	self.updateInvoiceReevaluate(trans, cargo, null);
	
epilog
	delete trans;
	delete services;
	termArea:= self.getTerminalArea("CTEST1").CM_RTGArea;
	if termArea &lt;&gt; null then
		foreach loc in termArea.allLocationsControllers do
			self.deleteInvoiceLines(loc);
		endforeach;
	endif;
	// delete this tran map so following tests can delete the invoice line descs etc
	cargoMap := self.myBank.myCurrentTranMapCargo['Default'];
	app.myTrxUA.trxUpdateBankTMActive(cargoMap,app.myPassport);
	self.deleteInvoiceTransactionMap(1, 'UT_CargoWeight');
	self.resetDefaultTranMap();												// 17/04/2013 cnwmh5
end;</source>
    </JadeMethod>
    <JadeMethod name="tInvPostAndValidateAllFields" id="c28ac74a-5980-44f0-9707-c840012c5ac6">
        <source>tInvPostAndValidateAllFields();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 January 2023 navrv30	CR 61931 Task 61635, Task 61634 Initial creation

*/
constants
	DebtorName	= "UT_Debtor1";
	InvoiceType = "UT_INV";
	VoyageId	= "UT_VOY1";
	ExtWebServiceDefName : String = "UT_InvoiceOracleIntf";	
	CONTID  	= "APZU255202"; 
	CARGOID 	= "UT61925-12";
	BOL1    	= "UTBOL61925-11";
	BOL2    	= "UTBOL61925-22";
	VESSEL  	= "UTVSL61925-1";
	BS      	= "UTBS61925";
	
vars
	bank		: CM_Bank;
	terminal	: CM_Terminal;
	debtor		: CM_Debtor;
	invType		: CM_InvoiceDesc;
	voyage		: CM_Voyage;
	invoice	: CM_Invoice;
	vessel 		: CM_Vessel; 
	activeWebServiceDef : CM_ExternalWebServiceDef;
	pxyExtWebServiceDef : CM_InvoiceAPIServiceDef;
	bgpInvoiceAPIWSReq	: BGP_InvoiceAPIWSRequest;
	calcType : CM_CalculationType;
	service100 : CM_Service;
	services : CM_ServiceByNameDict;
	invLineType		: CM_InvoiceLineDesc;
	invoiceLine		: CM_InvoiceLine;
	now             : TimeStamp;
	ewsActivity		: CM_ExternalWebServiceActivity;
	
	
	
	cargoType   	: CM_CargoType;
	cont,
	cargo1			: CM_TrackedItem;
	operator    	: CM_Operator;
	bol1,
	bol2			: CM_BOL;
	aPort		    : CM_Port;
	lc              : CM_LocationsController;
	product         : CM_Product;
	pxyInvLine      : CM_InvoiceLine;
	bs1 			: CM_BlockStack;
	realProcess		: CM_InvoiceProcess;
begin
	self.deleteExternalWebService(ExtWebServiceDefName);
	self.deleteInvoiceService("UT_ServiceCopy-1",0);
	self.deleteInvoiceType("UT_InvTypeCopy");
	self.deleteInvoiceLineType("UT_LineTypeCopy",0);
	now := app.actualTime();
	
	beginTransaction;
	create pxyExtWebServiceDef as CM_InvoiceAPIServiceDef transient;
	
	pxyExtWebServiceDef.setProxy(	true,	//_active : Boolean;
									ExtWebServiceDefName,	//_name : String;  
									"http://143.96.24.26:80/",	//_baseEndpoint : String;  
									null,	//_password : String;
									"MTN",	//_userCode : String; 
									3,	//_maxRetries : Integer;  
									1,	//_timeBetweenRetries : Integer; 
									10,	//_timeoutSeconds : Integer; 
									null,	//_restAPIAuthEndpoint : String; 
									null,	//_restAPIBaseEndpoint : String;
									null,	//_authProviderUrl : String;
									"MTN",	//_clientId : String;
									null,	//_clientSecret : String;
									null,	//_runAsKey : String;
									null	//_callBackUrl : String
									);	
	pxyExtWebServiceDef.setInvoiceLinesPerBatch(3500);
	app.myUtilityCA.utlCreateExtWebService(pxyExtWebServiceDef, activeWebServiceDef, app.myPassport);	
	commitTransaction;
	
	terminal := self.getTerminal();
	self.assertNotNull(terminal);
	
	bank := terminal.getDefaultCompanyBank();
	self.assertNotNull(bank);	
	
	
	invType := self.getInvoiceType(InvoiceType);
	self.assertNotNull(invType);
	
	voyage := self.getVoyage(VoyageId);
	self.assertNotNull(voyage);	
	beginTransaction;
	voyage.setGeneralLandingDate(voyage.arrivedDT.Date.addDays(1));
	commitTransaction;
	
	vessel := self.addVesselWithHolds(VESSEL, 2, 2);
	bs1 := self.addBlockStack(BS, 9999, null);
	terminal := self.getTerminal();
	self.assertNotNull(terminal);
	
	bank := terminal.getDefaultCompanyBank();
	self.assertNotNull(bank);
	
	debtor := self.getDebtor(DebtorName);
	self.assertNotNull(debtor);
	
	calcType := app.myRoot.allCalculationTypesByCode["CCT00"];
	service100 := self.createInvoiceService("UT_ServiceCopy-1","1- Unit test for Task 61635", calcType, null);
	self.assertNotNullMsg(service100, "UT_ServiceCopy-1 not created");
	
	create services transient;
 	services.add(service100);
	
	invType := self.createInvoiceType("UT_InvTypeCopy", InvoiceTypeGeneral);
	self.assertNotNullMsg(invType, "Invoice type UT_InvTypeCopy not created");
	
	invLineType := self.createInvoiceLineType("UT_LineTypeCopy", calcType, invType, services,"SDT6");	
	self.assertNotNullMsg(invLineType, "UT_LineTypeCopy not created");	
	
	cargoType := app.myRoot.getCargoTypeFromAbbrev("UTNSCT");
	product := cargoType.allProducts.first;
	aPort := app.myRoot.allPorts[voyage.myTerminal.getConfig(PortDestCode).String];
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	self.deleteContainer(CONTID);
	self.deleteCargo(CARGOID, cargoType);

	
	cont := self.addContainerOnShip( CONTID , operator, "2200", "GENL", null, voyage, aPort.code, voyage.code);
	self.assertNotNull(cont);
	self.opts.addAssoc("Description", "CargoDesc1");
	self.opts.addAssoc("ClientRef",  "ClientRef21");
	self.opts.addAssoc("Consignee",  "UTDDC");
	self.opts.addAssoc("Consignor",  "UTMO1");
	self.updateTI(cont);
	
	self.deleteBOL(BOL1, null);
	self.deleteBOL(BOL2, null);
	bol1 := self.addBOL(BOL1, voyage, operator, null, terminal );
	
	lc := voyage.myShipBlockStack;
	//create cargo on ship
	self.opts.addAssoc("Product", product);
	self.opts.addAssoc("TotalQuantity",50); 
	cargo1 := lc.createNewCargoForLCDetailed(cargoType,product, CARGOID, aPort.code, TI_IMEX_STATUS_IMPORT, voyage, vessel.myOperator, 50, null).CM_Cargo;
	self.assertNotNull(cargo1);
	self.opts.addAssoc("TotalWeight", 5000);
	self.opts.addAssoc("Commodity", "COM1");
	self.opts.addAssoc("TotalVolume", 7000);
	self.opts.addAssoc("CargoLength", 111.0);
	self.opts.addAssoc("CargoWidth", 222.0);
	self.opts.addAssoc("CargoHeight", 333.0);
	self.opts.addAssoc("Description", "CargoDesc2");
	self.opts.addAssoc("ClientRef", "ClientRef2");
	self.opts.addAssoc("Consignee", "UTDDC");
	self.opts.addAssoc("Consignor", "UTMO1");
	self.updateTI(cargo1);
	assertEqual(cargo1.totalQuantity, 50);
	
	bol2 := self.addBOL(BOL2, voyage, operator, null, terminal );
	
	beginTransaction;
	cont.setMyVoyage(voyage, app.myPassport);
	cargo1.setMyVoyage(voyage, app.myPassport);
	cont.setBOL(bol1.number);
	cargo1.setBOL(bol2.number);
	commitTransaction;
	self.assertEqualMsg(BOL1, cont.myReceivalBOL.number, "Container receival BOL");
	
	invoice := self.createManualInvoice(bank, debtor, voyage, invType, null);
	self.assertNotNull(invoice);
	self.assertEqual(invoice.category, InvoiceCategory_Invoice);	
	
	beginTransaction;
	invoice.setPropertyValue("sequenceNum", 999);	
	realProcess := app.myRoot.allInvoiceProcesses[InvoiceProcessInvoiceAPI];
	invoice.setMyInvoiceProcess(realProcess);
	commitTransaction;
	invoiceLine := self.createManualInvoiceLine(invLineType, invoice, 2, "UT-Copy-Inv1", now.date());	
	
	beginTransaction;
	invoiceLine.setPropertyValue("sequenceNum", 999999);
	commitTransaction;
	
	beginTransaction;
	invoice.setPropertyValue("status",0); // OPEN
	commitTransaction;	
	
	if invoiceLine &lt;&gt; null then
		pxyInvLine := app.createUpdateProxy(invoiceLine).CM_InvoiceLine;
	endif;
	pxyInvLine.setRemarks("Updated with cargo1");
	pxyInvLine.setTrackedItem(cargo1);
	pxyInvLine.externalRef1 := "invLineExtRef1";
	pxyInvLine.externalRef2 := "invLineExtRef2";
	pxyInvLine.externalRef3 := "invLineExtRef3";
	pxyInvLine.externalRef4 := "invLineExtRef4";
	app.myTrxUA.trxUpdateInvoiceLineRemarks(pxyInvLine, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	
	create bgpInvoiceAPIWSReq transient;
	bgpInvoiceAPIWSReq.setDetails(invoice, invoice.myTerminal,  CM_InvoiceAPI.CONSMODE_NO_CONS, null, null,null);
	bgpInvoiceAPIWSReq.createAndSendInvoiceJSON( activeWebServiceDef.CM_InvoiceAPIServiceDef,  3);
	
	foreach ewsActivity in activeWebServiceDef.CM_InvoiceAPIServiceDef.allEWSActivities do
		if ewsActivity.isKindOf(CM_EWSActivityInvoiceAPIParts) then
			self.valEWSActivityInvAPIParts(ewsActivity);
		elseif ewsActivity.isKindOf(CM_EWSActivityInvoiceAPI) then
			self.valEWSActivityInvAPI(ewsActivity);
		endif;
	endforeach;
	
epilog
	delete bgpInvoiceAPIWSReq;
	delete pxyExtWebServiceDef;
	delete pxyInvLine;	
	if services &lt;&gt; null then
		beginTransaction;
			services.purge();
			delete services;
		commitTransaction;	
	endif;
	self.deleteExternalWebService(ExtWebServiceDefName);
	self.deleteInvoice(invoice);
end;</source>
    </JadeMethod>
    <JadeMethod name="tInvTypeDebtorSeparation" id="148d2d18-f835-4039-919f-b1d7b973271f">
        <source>tInvTypeDebtorSeparation();
/*

Purpose:			Tests Invoice Type Debtor Separation for CR 54565

Parameters:			NONE

Return Value:		NONE

Date		Who		Reason
26 August 2022	navpw1	Initial creation TFS: 54565 (54384) (54571) - EUP - Inv Config - Invoice Surcharges

*/

constants
	Ref					: String = UT_DSL.TFS54384;
	UT_Debtor1 			: String = "UT_" &amp; Ref &amp; "_Debtor1";
	UT_Debtor2 			: String = "UT_" &amp; Ref &amp; "_Debtor2";
	UT_Debtor3 			: String = "UT_" &amp; Ref &amp; "_Debtor3";
	UT_Debtor4 			: String = "UT_" &amp; Ref &amp; "_Debtor4";
	UT_Debtor5 			: String = "UT_" &amp; Ref &amp; "_Debtor5";
	UT_Debtor6 			: String = "UT_" &amp; Ref &amp; "_Debtor6";
	UT_InvoiceDesc 		: String = "UT_" &amp; Ref &amp; "_InvoiceDesc";
	UT_InvoiceDesc2 	: String = "UT_" &amp; Ref &amp; "2_InvoiceDesc";
	UT_FinancialPeriod 	: String = "UT_" &amp; Ref &amp; "_FP";
	
vars
	pxyInvTypeDebtorSeparation,
	realInvTypeDebtorSeparation 			: CM_InvTypeDebtorSeparation;
	invoiceType,
	invoiceType2							: CM_InvoiceDesc;
	debtor1,
	debtor2,
	debtor3,
	debtor4,
	debtor5,
	debtor6									: CM_Debtor;
	pxyFinancialPeriod,
	realFinancialPeriod 					: CM_FinancialPeriodEnd;
	surchargesAndExemptions,
	surchargesAndExemptions2				: CM_InvoiceTypeSurchargeExempt;
	title 									: String;
	debtorError,
	hasSeparationsError,
	relationSurchargesAndExemptionsError,
	duplicateDebtorError					: Boolean;
	error									: CM_Error;
	
begin
	/*
	** Cleanup
	*/
	debtor1 := app.myRoot.myRootCompany.debtors[UT_Debtor1];
	self.deleteDebtor(debtor1);
	
	debtor2 := app.myRoot.myRootCompany.debtors[UT_Debtor2];
	self.deleteDebtor(debtor2);
	
	debtor3 := app.myRoot.myRootCompany.debtors[UT_Debtor3];
	self.deleteDebtor(debtor3);
	
	debtor4 := app.myRoot.myRootCompany.debtors[UT_Debtor4];
	self.deleteDebtor(debtor4);
	
	debtor5 := app.myRoot.myRootCompany.debtors[UT_Debtor5];
	self.deleteDebtor(debtor5);
	
	debtor6 := app.myRoot.myRootCompany.debtors[UT_Debtor6];
	self.deleteDebtor(debtor6);
	
	self.deleteInvoiceType(UT_InvoiceDesc);
	self.deleteInvoiceType(UT_InvoiceDesc2);
	
	// delete financial period type
	realFinancialPeriod := app.myRoot.myRootCompany.allFinancialPeriods[UT_FinancialPeriod];
	if realFinancialPeriod &lt;&gt; null then
		app.myTrxDA.trxDeleteFPType(realFinancialPeriod, app.myPassport);
		self.assertNoTrxErrorsOrWarnings();
	endif;
	
	/*
	** Global Setup
	*/
	debtor1 := self.addDebtor(UT_Debtor1, PaymentType_None).CM_Debtor;
	self.assertNotNullMsg(debtor1, "Debtor1");
	
	debtor2 := self.addDebtor(UT_Debtor2, PaymentType_None).CM_Debtor;
	self.assertNotNullMsg(debtor2, "Debtor2");
	
	debtor3 := self.addDebtor(UT_Debtor3, PaymentType_None).CM_Debtor;
	self.assertNotNullMsg(debtor3, "Debtor3");
	
	debtor4 := self.addDebtor(UT_Debtor4, PaymentType_None).CM_Debtor;
	self.assertNotNullMsg(debtor4, "Debtor4");
	
	debtor5 := self.addDebtor(UT_Debtor5, PaymentType_None).CM_Debtor;
	self.assertNotNullMsg(debtor5, "Debtor5");
	
	debtor6 := self.addDebtor(UT_Debtor6, PaymentType_None).CM_Debtor;
	self.assertNotNullMsg(debtor6, "Debtor6");
	
	create pxyFinancialPeriod transient;
	pxyFinancialPeriod.setProxy(UT_FinancialPeriod, false);
	app.myTrxCA.trxCreateFPType(pxyFinancialPeriod,realFinancialPeriod,app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	realFinancialPeriod := app.myRoot.myRootCompany.allFinancialPeriods[UT_FinancialPeriod];
	self.assertNotNullMsg(realFinancialPeriod, "Financial Period");
	
	invoiceType	:= self.createInvoiceType(UT_InvoiceDesc, InvoiceTypeGeneral);
	self.assertNotNullMsg(invoiceType, "Invoice Type");
	
	self.addInvTypeSurchargeExempt(invoiceType, 0, null, null);
	
	surchargesAndExemptions	:= invoiceType.mySurchargeAndExemptions;
	self.assertNotNullMsg(surchargesAndExemptions, "Surcharges and Exemptions");
	
	invoiceType2	:= self.createInvoiceType(UT_InvoiceDesc2, InvoiceTypeGeneral);
	self.assertNotNullMsg(invoiceType, "Invoice Type2");
	
	self.addInvTypeSurchargeExempt(invoiceType2, 0, null, null);
	
	surchargesAndExemptions2	:= invoiceType2.mySurchargeAndExemptions;
	self.assertNotNullMsg(surchargesAndExemptions2, "Surcharges and Exemptions2");
	
	/*
	############################################## Start Test 1 ##############################################
	########################## 53598.010 Cargo Group Reservation/Validation via EDI ##########################
	
	Tests:
	1) Tests that trx saves Invoice Type Debtor Separation with all seperation criteria and mandatory fields
	
	*/
	
	/*
	** Setup
	*/
	debtorError 							:= false;
	hasSeparationsError 					:= false;
	relationSurchargesAndExemptionsError	:= false;
	duplicateDebtorError					:= false;
	
	/*
	** Run
	*/
	create pxyInvTypeDebtorSeparation transient;
	pxyInvTypeDebtorSeparation.setProxy(debtor1, realFinancialPeriod, true, true, true, true, true, true, true, true, surchargesAndExemptions);
	app.myTrxCA.trxCreateInvTypeDtrSeparation(pxyInvTypeDebtorSeparation, realInvTypeDebtorSeparation, app.myPassport);
	
	/*
	** Assert
	*/
	//Check Trx has no errors
	self.assertNoTrxErrorsOrWarnings();
	
	title := "Invoice Type ('" &amp; UT_InvoiceDesc &amp; "') - Surcharge Exemptions - Test 1 - Invoice Separation - ";
	
	//Check that new fields match their expected value/are set
	self.assertTrueMsg(realInvTypeDebtorSeparation.myDebtor &lt;&gt; null, "myDebtor Expected: 'Not null' | Actual: 'null'");
	self.assertTrueMsg(realInvTypeDebtorSeparation.myAccrualType &lt;&gt; null, "myAccrualType Expected: 'Not null' | Actual: 'null'");
	self.assertTrueMsg(realInvTypeDebtorSeparation.mySurchargesAndExemptions &lt;&gt; null, "mySurchargesAndExemptions Expected: 'Not null' | Actual: 'null'");
	
	self.assertTrueMsg(realInvTypeDebtorSeparation.myDebtor.name = UT_Debtor1, title &amp; "myDebtor Expected: '" &amp; UT_Debtor1 &amp; "' | Actual: '" &amp; realInvTypeDebtorSeparation.myDebtor.name &amp; "'");
	self.assertTrueMsg(realInvTypeDebtorSeparation.myAccrualType.description = UT_FinancialPeriod, "myAccrualType Expected: '" &amp; UT_FinancialPeriod &amp; "' | Actual: '" &amp; realInvTypeDebtorSeparation.myAccrualType.description &amp; "'");
	self.assertTrueMsg(realInvTypeDebtorSeparation.mySurchargesAndExemptions = surchargesAndExemptions, "mySurchargesAndExemptions Objects References do not match");
	
	self.assertTrueMsg(realInvTypeDebtorSeparation.separatedByBillOfLading = true, title &amp; "separatedByBillOfLading Expected: '" &amp; true.asStringJMT() &amp; "' | Actual: '" &amp; realInvTypeDebtorSeparation.separatedByBillOfLading.asStringJMT() &amp; "'");
	self.assertTrueMsg(realInvTypeDebtorSeparation.separatedByBooking = true, title &amp; "separatedByBooking Expected: '" &amp; true.asStringJMT() &amp; "' | Actual: '" &amp; realInvTypeDebtorSeparation.separatedByBooking.asStringJMT() &amp; "'");
	self.assertTrueMsg(realInvTypeDebtorSeparation.separatedByCargoGroupId = true, title &amp; "separatedByCargoGroupId Expected: '" &amp; true.asStringJMT() &amp; "' | Actual: '" &amp; realInvTypeDebtorSeparation.separatedByCargoGroupId.asStringJMT() &amp; "'");
	self.assertTrueMsg(realInvTypeDebtorSeparation.separatedByCargoId = true, title &amp; "separatedByCargoId: Expected '" &amp; true.asStringJMT() &amp; "' | Actual: '" &amp; realInvTypeDebtorSeparation.separatedByCargoId.asStringJMT() &amp; "'");
	self.assertTrueMsg(realInvTypeDebtorSeparation.separatedByReleaseRequest = true, title &amp; "separatedByReleaseRequest Expected: '" &amp; true.asStringJMT() &amp; "' | Actual: '" &amp; realInvTypeDebtorSeparation.separatedByReleaseRequest.asStringJMT() &amp; "'");
	self.assertTrueMsg(realInvTypeDebtorSeparation.separatedByVoyage = true, title &amp; "separatedByVoyage Expected: '" &amp; true.asStringJMT() &amp; "' | Actual: '" &amp; realInvTypeDebtorSeparation.separatedByVoyage.asStringJMT() &amp; "'");
	self.assertTrueMsg(realInvTypeDebtorSeparation.separatedByVoyageGroup = true, title &amp; "separatedByVoyageGroup Expected: '" &amp; true.asStringJMT() &amp; "' | Actual: '" &amp; realInvTypeDebtorSeparation.separatedByVoyageGroup.asStringJMT() &amp; "'");
	
	/*
	############################################### End Test 1 ###############################################
	########################## 53598.010 Cargo Group Reservation/Validation via EDI ##########################
	*/
	
	
	/*
	############################################## Start Test 2 ##############################################
	########################## 53598.010 Cargo Group Reservation/Validation via EDI ##########################
	
	Tests:
	1) Tests that trx saves Invoice Type Debtor Separation with one seperation criteria and mandatory fields
	
	*/
	
	/*
	** Setup
	*/
	delete pxyInvTypeDebtorSeparation;
	debtorError 							:= false;
	hasSeparationsError 					:= false;
	relationSurchargesAndExemptionsError	:= false;
	duplicateDebtorError					:= false;
	
	/*
	** Run
	*/
	create pxyInvTypeDebtorSeparation transient;
	pxyInvTypeDebtorSeparation.setProxy(debtor2, realFinancialPeriod, true, false, false, false, false, false, false,false, surchargesAndExemptions);
	app.myTrxCA.trxCreateInvTypeDtrSeparation(pxyInvTypeDebtorSeparation, realInvTypeDebtorSeparation, app.myPassport);
	
	/*
	** Assert
	*/
	//Check Trx has no errors
	self.assertNoTrxErrorsOrWarnings();
	
	title := "Invoice Type ('" &amp; UT_InvoiceDesc &amp; "') - Surcharge Exemptions - Test 2 - Invoice Separation - ";
	
	//Check that new fields match their expected value/are set
	self.assertTrueMsg(realInvTypeDebtorSeparation.myDebtor &lt;&gt; null, "myDebtor Expected: 'Not null' | Actual: 'null'");
	self.assertTrueMsg(realInvTypeDebtorSeparation.myAccrualType &lt;&gt; null, "myAccrualType Expected: 'Not null' | Actual: 'null'");
	self.assertTrueMsg(realInvTypeDebtorSeparation.mySurchargesAndExemptions &lt;&gt; null, "mySurchargesAndExemptions Expected: 'Not null' | Actual: 'null'");
	
	self.assertTrueMsg(realInvTypeDebtorSeparation.myDebtor.name = UT_Debtor2, title &amp; "myDebtor Expected: '" &amp; UT_Debtor2 &amp; "' | Actual: '" &amp; realInvTypeDebtorSeparation.myDebtor.name &amp; "'");
	self.assertTrueMsg(realInvTypeDebtorSeparation.myAccrualType.description = UT_FinancialPeriod, "myAccrualType Expected: '" &amp; UT_FinancialPeriod &amp; "' | Actual: '" &amp; realInvTypeDebtorSeparation.myAccrualType.description &amp; "'");
	self.assertTrueMsg(realInvTypeDebtorSeparation.mySurchargesAndExemptions = surchargesAndExemptions, "mySurchargesAndExemptions Objects References do not match");
	
	self.assertTrueMsg(realInvTypeDebtorSeparation.separatedByBillOfLading = false, title &amp; "separatedByBillOfLading Expected: '" &amp; false.asStringJMT() &amp; "' | Actual: '" &amp; realInvTypeDebtorSeparation.separatedByBillOfLading.asStringJMT() &amp; "'");
	self.assertTrueMsg(realInvTypeDebtorSeparation.separatedByBooking = false, title &amp; "separatedByBooking Expected: '" &amp; false.asStringJMT() &amp; "' | Actual: '" &amp; realInvTypeDebtorSeparation.separatedByBooking.asStringJMT() &amp; "'");
	self.assertTrueMsg(realInvTypeDebtorSeparation.separatedByCargoGroupId = false, title &amp; "separatedByCargoGroupId Expected: '" &amp; false.asStringJMT() &amp; "' | Actual: '" &amp; realInvTypeDebtorSeparation.separatedByCargoGroupId.asStringJMT() &amp; "'");
	self.assertTrueMsg(realInvTypeDebtorSeparation.separatedByCargoId = false, title &amp; "separatedByCargoId: Expected '" &amp; false.asStringJMT() &amp; "' | Actual: '" &amp; realInvTypeDebtorSeparation.separatedByCargoId.asStringJMT() &amp; "'");
	self.assertTrueMsg(realInvTypeDebtorSeparation.separatedByReleaseRequest = false, title &amp; "separatedByReleaseRequest Expected: '" &amp; false.asStringJMT() &amp; "' | Actual: '" &amp; realInvTypeDebtorSeparation.separatedByReleaseRequest.asStringJMT() &amp; "'");
	self.assertTrueMsg(realInvTypeDebtorSeparation.separatedByVoyage = true, title &amp; "separatedByVoyage Expected: '" &amp; true.asStringJMT() &amp; "' | Actual: '" &amp; realInvTypeDebtorSeparation.separatedByVoyage.asStringJMT() &amp; "'");
	self.assertTrueMsg(realInvTypeDebtorSeparation.separatedByVoyageGroup = false, title &amp; "separatedByVoyageGroup Expected: '" &amp; false.asStringJMT() &amp; "' | Actual: '" &amp; realInvTypeDebtorSeparation.separatedByVoyageGroup.asStringJMT() &amp; "'");
	
	/*
	############################################### End Test 2 ###############################################
	########################## 53598.010 Cargo Group Reservation/Validation via EDI ##########################
	*/
	
	
	/*
	############################################## Start Test 3 ##############################################
	########################## 53598.010 Cargo Group Reservation/Validation via EDI ##########################
	
	Tests:
	1) Tests that trx saves Invoice Type Debtor Separation and raises errors for mandatory fields
	
	*/
	
	/*
	** Setup
	*/
	delete pxyInvTypeDebtorSeparation;
	debtorError 							:= false;
	hasSeparationsError 					:= false;
	relationSurchargesAndExemptionsError	:= false;
	duplicateDebtorError					:= false;
	
	/*
	** Run
	*/
	create pxyInvTypeDebtorSeparation transient;
	pxyInvTypeDebtorSeparation.setProxy(null, null, false, false, false, false, false, false, false, false, null);
	app.myTrxCA.trxCreateInvTypeDtrSeparation(pxyInvTypeDebtorSeparation, realInvTypeDebtorSeparation, app.myPassport);
	
	/*
	** Assert
	*/
	//Check Trx has no errors
	title := "Invoice Type ('" &amp; UT_InvoiceDesc &amp; "') - Surcharge Exemptions - Invoice Separation - ";
	
	if app.myPassport.allErrors.isEmpty then
		self.assertTrueMsg(false, "Expected: This trx should result in an error | Actual: No error exists");
	endif;
	
	foreach error in app.myPassport.allErrors do
		if error.text.cnContains(app.getErrorString(Input_required_field_debtor)) then
			self.assertTrueMsg(error.errorCode = Input_required_field_debtor, "Expected Error Code:" &amp; Input_required_field_debtor.String &amp; " | Actual: " &amp; error.errorCode.String); 					//Check Error Code Matches Expected
			self.assertTrueMsg(error.text.cnContains(app.getErrorString(Input_required_field_debtor)), "Expected: error message to contain '" &amp; app.getErrorString(Input_required_field_debtor) &amp; "' | Actual: " &amp; error.text);	//Check Error Message Contains cargo-type or commodity
			debtorError := true;
			
		elseif error.text.cnContains(app.getErrorString(Must_have_separation_def)) then
			self.assertTrueMsg(error.errorCode = Must_have_separation_def, "Expected Error Code:" &amp; Must_have_separation_def.String &amp; " | Actual: " &amp; error.errorCode.String); 					//Check Error Code Matches Expected
			self.assertTrueMsg(error.text.cnContains(app.getErrorString(Must_have_separation_def)), "Expected: error message to contain '" &amp; app.getErrorString(Must_have_separation_def) &amp; "' | Actual: " &amp; error.text);							//Check Error Message Contains timestamp
			hasSeparationsError := true;
			
		elseif error.text.cnContains(app.getErrorString1(Must_be_related, app.getErrorString(Surcharges_exemptions))) then
			self.assertTrueMsg(error.errorCode = Must_be_related, "Expected Error Code:" &amp; Must_be_related.String &amp; " | Actual: " &amp; error.errorCode.String); 					//Check Error Code Matches Expected
			self.assertTrueMsg(error.text.cnContains(app.getErrorString1(Must_be_related, app.getErrorString(Surcharges_exemptions))), "Expected: error message to contain 'must be related to surcharges and exemptions' | Actual: " &amp; error.text);							//Check Error Message Contains timestamp
			relationSurchargesAndExemptionsError := true;
			
		endif;
		
	endforeach;
	
	if not debtorError then
		self.assertTrueMsg(debtorError, "Expected: error to be raised for required field ('" &amp; app.getErrorString(Input_required_field_debtor) &amp; "') | Actual: No Error Raised"); 				//Check Error Code Matches Expected
		
	elseif not hasSeparationsError then
		self.assertTrueMsg(hasSeparationsError, "Expected: error to be raised for required field ('" &amp; app.getErrorString(Must_have_separation_def) &amp; "') | Actual: No Error Raised"); 									//Check Error Code Matches Expected
		
	elseif not relationSurchargesAndExemptionsError then
		self.assertTrueMsg(relationSurchargesAndExemptionsError, "Expected: error to be raised for required field ('" &amp; app.getErrorString1(Must_be_related, app.getErrorString(Surcharges_exemptions)) &amp; "') | Actual: No Error Raised"); 									//Check Error Code Matches Expected
			
	endif;
	
	/*
	############################################### End Test 3 ###############################################
	########################## 53598.010 Cargo Group Reservation/Validation via EDI ##########################
	*/
	
	/*
	############################################## Start Test 4 ##############################################
	########################## 53598.010 Cargo Group Reservation/Validation via EDI ##########################
	
	Tests:
	1) Tests that trx saves Invoice Type Debtor Separation and raises errors for duplicate debtor
	
	*/
	
	/*
	** Setup
	*/
	delete pxyInvTypeDebtorSeparation;
	debtorError 							:= false;
	hasSeparationsError 					:= false;
	relationSurchargesAndExemptionsError	:= false;
	duplicateDebtorError					:= false;
	
	/*
	** Run
	*/
	create pxyInvTypeDebtorSeparation transient;
	pxyInvTypeDebtorSeparation.setProxy(debtor2, realFinancialPeriod, true, false, false, false, false, false, false, false, surchargesAndExemptions);
	app.myTrxCA.trxCreateInvTypeDtrSeparation(pxyInvTypeDebtorSeparation, realInvTypeDebtorSeparation, app.myPassport);
	
	/*
	** Assert
	*/
	//Check Trx has no errors
	title := "Invoice Type ('" &amp; UT_InvoiceDesc &amp; "') - Surcharge Exemptions - Invoice Separation - ";
	
	if app.myPassport.allErrors.isEmpty then
		self.assertTrueMsg(false, "Expected: This trx should result in an error | Actual: No error exists");
	endif;
	
	foreach error in app.myPassport.allErrors do
		if error.text.cnContains(app.getErrorString2(ObjectAlreadyInCollection, app.getErrorString(Debtor_GC), app.getErrorString(Surcharges_exemptions))) then
			self.assertTrueMsg(error.errorCode = ObjectAlreadyInCollection, "Expected Error Code:" &amp; ObjectAlreadyInCollection.String &amp; " | Actual: " &amp; error.errorCode.String); 					//Check Error Code Matches Expected
			self.assertTrueMsg(error.text.cnContains(app.getErrorString2(ObjectAlreadyInCollection, app.getErrorString(Debtor_GC), app.getErrorString(Surcharges_exemptions))), "Expected: error message to contain '" &amp; app.getErrorString(Debtor_GC) &amp; "' | Actual: " &amp; error.text);	//Check Error Message Contains cargo-type or commodity
			duplicateDebtorError := true;
			
		endif;
		
	endforeach;
	
	if not duplicateDebtorError then
		self.assertTrueMsg(duplicateDebtorError, "Expected: error to be raised for required field ('" &amp; app.getErrorString2(ObjectAlreadyInCollection, app.getErrorString(Debtor_GC), app.getErrorString(Surcharges_exemptions)) &amp; "') | Actual: No Error Raised"); 				//Check Error Code Matches Expected
		
	endif;
	
	/*
	############################################### End Test 4 ###############################################
	########################## 53598.010 Cargo Group Reservation/Validation via EDI ##########################
	*/
	
	/*
	############################################## Start Test 5 ##############################################
	########################## 53598.010 Cargo Group Reservation/Validation via EDI ##########################
	
	Tests:
	1) Tests that trx updates Invoice Type Debtor Separation
	
	*/
	
	/*
	** Setup
	*/
	delete pxyInvTypeDebtorSeparation;
