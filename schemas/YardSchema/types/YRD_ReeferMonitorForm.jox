    <JadeMethod name="setupContextMenuItems" id="d5b2af47-06d3-4226-889c-ef684d8e0363">
        <updating/>
        <source>setupContextMenuItems(conwin: Window input) updating;
// ---------------------------------------------------------------------------
// Created:     23 July 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
// 10/12/2009	cnwdap1		CCMS MES 1007 All tracked items can now be reefers, not just containers
// 09/05/2025   navsp1      JIRA-34514 MTN - Reefer Monitoring Screen Code Changes
vars
	//container : CM_Container;		// CCMS 1007
	container : CM_TrackedItem;		// CCMS 1007
begin

	inheritMethod(conwin);


	if self.myCurrentObject &lt;&gt; null then
		//container := self.myCurrentObject.CM_Container;		// CCMS 1007
		container := self.myCurrentObject.CM_TrackedItem;		// CCMS 1007
	endif;
	
	self.mnuConnect.visible				:= false;
	self.mnuDisconnect.visible			:= false;
	self.mnuAddReading.visible			:= false;
	self.mnuContainerEnquiry.visible	:= true;//6/11/2009 cnwdz2 21202
	self.mnuSelectAll.visible			:= false;
	self.mnuSeperator1.visible			:= true;
	self.mnuSeperator2.visible			:= false;
	self.mnuColourLegend.visible		:= false;
    self.mnuCreateReefJobSelected.visible  := true;     //JIRA-34514
	
	if conwin = self.tblData then
		self.mnuSelectAll.visible := true;
		self.mnuColourLegend.visible		:= true;
	
		if self.tblData.allSelectedObjects.size &gt; 1 then
			self.mnuConnect.visible := true;
			self.mnuDisconnect.visible := true;
			self.mnuAddReading.visible := true;
			self.mnuConnect.caption := "Connect Selected...";
			self.mnuDisconnect.caption := "Disconnect Selected...";
			self.mnuAddReading.caption := "Add Readings...";
		
		elseif container &lt;&gt; null then
		
			if container.isConnected then
				self.mnuDisconnect.visible	:= true;
			else
				self.mnuConnect.visible		:= true;
			endif;
			self.mnuAddReading.visible		:= true;
			//self.mnuContainerEnquiry.visible := true;//6/11/2009 cnwdz2 21202
			self.mnuSeperator2.visible		:= true;
	
			self.mnuConnect.caption := "Connect " &amp; container.id &amp; "...";
			self.mnuDisconnect.caption := "Disconnect " &amp; container.id &amp; "...";
			self.mnuAddReading.caption := "Add Reading " &amp; container.id &amp; "...";
		endif;
	elseif conwin = self.tblReadings then
		self.mnuColourLegend.visible		:= true;
		if container &lt;&gt; null then
			self.mnuAddReading.visible := true;
			self.mnuAddReading.caption := "Add Reading " &amp; container.id &amp; "...";
		endif;
	elseif conwin = self.tblReeferInfo then
		if container &lt;&gt; null then
			self.mnuContainerEnquiry.visible := true;
			self.mnuSeperator2.visible		:= true;
	
			if container.isConnected then
				self.mnuDisconnect.visible := true;
			else
				self.mnuConnect.visible := true;
			endif;
			self.mnuConnect.caption := "Connect " &amp; container.id &amp; "...";
			self.mnuDisconnect.caption := "Disconnect " &amp; container.id &amp; "...";
		endif;	
	endif;	
	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.mnuConnect.visible				:= false;
		self.mnuDisconnect.visible			:= false;
		self.mnuAddReading.visible			:= false;
		self.mnuSelectAll.visible			:= false;
		self.mnuSeperator1.visible			:= false;
		self.mnuSeperator2.visible			:= false;
	endif;
	
	self.zCloneMenu(self.mnuTblVCloneTop, self.mnuSeperator1, false);
	self.zCloneMenu(self.mnuTblVCloneTop, self.mnuColourLegend, false);
	self.zCloneMenu(self.mnuTblVCloneTop, self.mnuSelectAll, false);
	self.zCloneMenu(self.mnuTblVCloneTop, self.mnuConnect, false);
	self.zCloneMenu(self.mnuTblVCloneTop, self.mnuDisconnect, false);
	self.zCloneMenu(self.mnuTblVCloneTop, self.mnuAddReading, false);
	self.zCloneMenu(self.mnuTblVCloneTop, self.mnuSeperator2, false);
	self.zCloneMenu(self.mnuTblVCloneTop, self.mnuContainerEnquiry, false);
    self.zCloneMenu(self.mnuTblVCloneTop, self.mnuCreateReefJobSelected, false); //JIRA-34514
	

end;</source>
        <Parameter name="conwin" type="Window" usage="input"/>
    </JadeMethod>
