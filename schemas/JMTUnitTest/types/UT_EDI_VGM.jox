	elseif _format = 2 then
		// remove certified name
		ediText := 'ISO Container,' &amp; _containerId &amp; ',Export,MSC,' &amp; _voyageId &amp; ',18530,,GENL,AUSYD,Y,,Charles Manson, 2200,UTVGM1,U';
	elseif _format = 2 then
	else 
		// clear all
		ediText := 'ISO Container,' &amp; _containerId &amp; ',Export,MSC,' &amp; _voyageId &amp; ',18530,,GENL,AUSYD,,,, 2200,UTVGM1,U';
