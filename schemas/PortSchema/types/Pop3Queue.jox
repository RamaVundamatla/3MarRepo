<Class name="Pop3Queue" id="efdc88c5-c3a6-45b2-912d-4275b7747846">
    <superclass name="ANPOP_POP3"/>
    <transient/>
    <sharedTransientAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="_usergui"/>
    <Constant name="GUID" id="524ace20-40ef-4417-ba25-b2a33c7116c1">
        <source>"{ec20359f-6ccd-4978-bf38-c653f367a86a}"</source>
        <type name="String"/>
    </Constant>
    <Constant name="InterfaceGUID" id="a7f81f1a-332e-4a41-b9b9-aa547cee7b8e">
        <source>"{be44a1ec-8ebc-47a3-8221-9b03839f2fb3}"</source>
        <type name="String"/>
        <text>IPop3Queue Interface</text>
    </Constant>
    <JadeMethod name="getCurrentConnections" id="7bdb1c26-e62f-4980-998c-d3ef68518188">
        <updating/>
        <source>getCurrentConnections():Integer updating;
	// 


begin

	return _jadeActiveXInvoke('GetCurrentConnections', 1, '0.3').Integer;

end;
</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getLastError" id="d50a44b5-489b-484b-ab2b-f4978eb23bfb">
        <updating/>
        <source>getLastError():String updating;
	// 


begin

	return _jadeActiveXInvoke('GetLastError', 1, '0.8').String;

end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="listen" id="415ba9f5-7c11-451a-96eb-2feb8f84cddc">
        <updating/>
        <source>listen(port:Integer; maxConnections:Integer):Integer updating;
	// 


begin

	return _jadeActiveXInvoke('Listen', 1, '0.3,1.22,1.22', port, maxConnections).Integer;

end;
</source>
        <Parameter name="port" type="Integer"/>
        <Parameter name="maxConnections" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="receive" id="a9d9a134-ecb5-4ffc-a5af-47f28d9e4843">
        <updating/>
        <source>receive(timeout:Integer):IPop3Request updating;
	// 


begin

	return _jadeActiveXInvoke('Receive', 1, '0.16393.'&amp;IPop3Request.number.String&amp;',1.22', timeout).IPop3Request;

end;
</source>
        <Parameter name="timeout" type="Integer"/>
        <ReturnType type="IPop3Request"/>
    </JadeMethod>
    <JadeMethod name="sendRequest" id="93c6e69d-0c31-4b26-b90e-2e32b8c2756e">
        <updating/>
        <source>sendRequest(server:String; port:Integer; pop3Request:IPop3Request):Integer updating;
	// 


begin

	return _jadeActiveXInvoke('SendRequest', 1, '0.3,1.8,1.22,1.16393.'&amp;IPop3Request.number.String&amp;'', server, port, pop3Request).Integer;

end;
</source>
        <Parameter name="server" type="String"/>
        <Parameter name="port" type="Integer"/>
        <Parameter name="pop3Request" type="IPop3Request"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="stopListen" id="22949ed1-d7af-482b-b365-7cf48eb4e0d9">
        <updating/>
        <source>stopListen() updating;
	// 


begin

	_jadeActiveXInvoke('StopListen', 1, '0.24');

end;
</source>
    </JadeMethod>
</Class>
