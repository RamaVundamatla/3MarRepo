<Class name="CM_WOPackChildWLE" id="b2ab9d43-9b2a-49ef-a67d-aee8e54968f1">
    <superclass name="CM_WOPackWLE"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="cmtrans"/>
    <JadeMethod name="getChildren" id="d9fea0d8-6d5b-4147-b8a1-d3c141521b3d">
        <source>getChildren(_childColl: CM_TISet input);
// -----------------------------------------------------------------------------
//
// Purpose:		Get the cargo that is going to be packed into containers
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
// Date			Who		Reason
// 10 July 2022	navcs2	Initial creation ChangeRequest 53038: MTN - Work Order Maintenance Refactor - PortSchema
// 08 Feb  2023 navma1  ChangeRequest 56457: EUP - Allowing different sets of cargo items per work order task [Refactor]
// -----------------------------------------------------------------------------

vars
	workOrder : CM_WorkOrder;
	wod		  : CM_WorkOrderTIDtl;
begin
	if self.job = null then
		return;
	endif;

	
	/*
	08.02.2023 navma1 #56457 Task#56458
	workOrder := self.job.getWorkOrder();
	if workOrder &lt;&gt; null and workOrder.isKindOf(CM_WorkOrderTI) then
		workOrder.CM_WorkOrderTI.allTIs.copy(_childColl);
	endif;
	*/
	
	wod := self.job.myWODtl;												//08.02.2023 navma1 #56457 Task#56458
	if wod &lt;&gt; null then
		wod.CM_WodPack.allPackingTIs.copy(_childColl);		
	endif;
epilog

end;</source>
        <Parameter name="_childColl" type="CM_TISet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getTaskTypeDesc" id="4b3b0a8d-b7ef-4c31-9906-9411737af78e">
        <source>getTaskTypeDesc(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 January 2023		navma1	Initial creation

*/

vars

begin
	return "Pack Child";

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
</Class>
