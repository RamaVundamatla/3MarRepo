    <JadeMethod name="erase" id="14c8f138-891d-47b8-863b-7d90388c6824">
        <updating/>
        <source>erase(_level: Integer) updating;
// ---------------------------------------------------------------------------
// Created:     24 August 2009 by cnwcs5
// Purpose:     CCMS 1061 - gate config
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	subQueue	:CM_RadioTelemetryQueue;
begin
	foreach subQueue in self.allSubQueues do
			subQueue.erase(NORMAL_ERASE);
	endforeach;
	
	inheritMethod(_level);

epilog

end;</source>
        <Parameter name="_level" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="6899aa1f-8c57-4928-80fa-52526b6ad06b">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 August 2009	cnwer1	Initial creation

*/

vars

begin
	if _attrName = ETRow_DefaultExitGate then
		if self.myDefaultOutGate &lt;&gt; null then
			return self.myDefaultOutGate.name;
		else
			return null;
		endif;
	elseif _attrName = ETRow_IdInterchange then  //cnwrd1 par 28100 6.12.2011
		return self.id;
	else
		return inheritMethod(_attrName, _short);
	endif;
epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getOverrideQueue" id="470c1c3e-b073-4584-b955-cca668e813ab">
        <source>getOverrideQueue(): CM_SubQueue;
// ---------------------------------------------------------------------------
// Created:     15 October 2009 by cnwcs5
// Purpose:     CCMS 1061 - gate config
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 15/10/2009	cnwcs5		par 20797	
// ---------------------------------------------------------------------------
vars

begin 
	if not self.allSubRTQueues.isEmpty() then
		return self.allSubRTQueues.first.CM_SubQueue;
	endif;
	
	return inheritMethod;
epilog

end;</source>
        <ReturnType type="CM_SubQueue"/>
    </JadeMethod>
    <JadeMethod name="isSimilarQueueArea" id="283266cb-83c3-4ee6-b4c5-aeb8ebf04ecb">
        <source>isSimilarQueueArea(_location: CM_LocationsController): Boolean;
// ---------------------------------------------------------------------------
// Created:     28 June 2010 by cnwcs5
// Purpose:     par 24418
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	area	:CM_TerminalAreaMaster;
begin
	if _location.isKindOf (CM_VehicleController) then
		// use area the vehicle is located
		area := _location.getMyTerminalArea; 
	
		if area = self then
			return true;
		endif;
	
		return false;
	endif;
	
	return inheritMethod(_location);

epilog

end;</source>
        <Parameter name="_location" type="CM_LocationsController"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
