<Class name="CM_QStringLookupIsOneOf" id="2d50a5f7-5eaf-4f17-af26-229041e2f9fd">
    <superclass name="CM_QueryLookupOperators"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="query"/>
    <CompAttribute name="allSelectionValues" id="da4284ae-8f70-4f3b-b512-5d5c953de68b">
        <type name="StringArray"/>
        <access>readonly</access>
    </CompAttribute>
    <JadeMethod name="cloneReferences" id="f3451dd2-231d-4c97-87b7-0653c76f4458">
        <updating/>
        <source>cloneReferences(_targetReceiver : SelfType input) updating;
/*****************************************************
Author		: jlgka1 (Karen Alexander)
Date		: 8 November 2018
TFS#		: 40670
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/
begin
	inheritMethod(_targetReceiver);
	self.allSelectionValues.copy(_targetReceiver.allSelectionValues);
end;</source>
        <Parameter name="_targetReceiver" type="SelfType" usage="input"/>
    </JadeMethod>
    <JadeMethod name="create" id="77d9e1c9-a9e4-4329-8fc8-59bd0f7858a5">
        <updating/>
        <source>create() updating;
/*****************************************************
Author		: jlgka1 (Karen Alexander)
Date		: 8 November 2018
TFS#		: 40670
Function	: This is similar to IsOneOf operation but not pertaining
			  to a single field in the database instead it is comparing 
			  a concatenated string separated by a comma.

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

begin
	self.description := self.Operator_IsOneOf;
end;</source>
    </JadeMethod>
    <JadeMethod name="doMatch" id="579f8294-13d2-4103-856a-47fb8560e387">
        <source>doMatch(_value: String): Boolean;
/*****************************************************
Author		: jlgka1 (Karen Alexander)
Date		: 8 November 2018
TFS#		: 40670
Function	:

*** Changes ***
Date			Name		TFS#		Description
17 Feb 2023	navmv20 TFS 55626 Task 55688: Jade - Selector Query Contracts

****************************************************/
vars
	stringValue1 : String;
	stringValue2 : String;
	startPos	 : Integer;
	endPos	 	 : Integer;
	returnValue  : Boolean;	
begin
	if _value = null then
		return false;
	endif;
	
	startPos := 1;
	stringValue1 := _value.scanUntil("," , startPos);
	
	startPos := _value.pos("," , 1);
	if startPos &lt;&gt; null then
		while startPos &lt;&gt; null do
			returnValue := self.allSelectionValues.includes(stringValue1);
			
			if returnValue then
				return returnValue;
				break;
			endif;
			
			endPos := _value.pos(",", startPos + 1);
			if endPos = null then
				endPos := _value.length - startPos;
			else
				endPos := endPos - startPos;
			endif;
			
			stringValue2 := _value[startPos + 1:endPos];			
			
			returnValue := self.allSelectionValues.includes(stringValue2);
			
			//17/02/2023 navmv20 TFS 55626 Task 55688 - START 
			if returnValue then
				return returnValue;
				break;
			endif;
			//17/02/2023 navmv20 TFS 55626 Task 55688 - END
			
			startPos := _value.pos(",", endPos + 1);
		endwhile;
	else	
		returnValue := self.allSelectionValues.includes(stringValue1);
	endif;
	
	return returnValue;
end;</source>
        <Parameter name="_value" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getControlType" id="1dcc77c7-39ba-46fb-9d7f-75132c2664b7">
