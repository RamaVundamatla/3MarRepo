    <JadeMethod name="setWebPageHTMLForPage" id="1b2d2044-d647-4df6-9ba6-d1b1972a2f3c">
        <source>setWebPageHTMLForPage(_schema : Schema; _pageName : String; _pageType : Integer) protected;
// ---------------------------------------------------------------------------
// Created:     12 June 2005 by cnwrs2
//
// Purpose:     Creates/Updates the WebPageHTML from the html stored
//				within the Jade WebDocuments
// ---------------------------------------------------------------------------
vars
	tmpClass	: Class;
	tmpHTMLClass	: JadeHTMLClass;
	tmpHTMLDoc		: JadeHTMLDocument;
	tmpHTML		: String;
	tmpWebPageHTML	: CM_WebPageHTML;
begin

	tmpClass := _schema.getClass(_pageName);
	if tmpClass = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Class (' &amp; _pageName &amp; ') not found');
		return;
	endif;
	
	create tmpHTMLClass as tmpClass transient;
	tmpHTMLDoc := tmpHTMLClass.getPropertyValue(JadeHTMLClass::htmlDocument.name).JadeHTMLDocument;
	
	if tmpHTMLDoc &lt;&gt; null then
		tmpHTML := tmpHTMLDoc.getPropertyValue(JadeHTMLDocument::htmlString.name).String;
	endif;
	
	tmpWebPageHTML := self.allWebPageHTML[_pageType];
	if tmpWebPageHTML = null then
		create tmpWebPageHTML persistent;
		tmpWebPageHTML.setForCreate(tmpHTML, _pageType, self);
	else
		tmpWebPageHTML.setForUpdate(tmpHTML);
	endif;

epilog
	delete tmpHTMLClass;
end;</source>
        <access>protected</access>
        <Parameter name="_schema" type="Schema"/>
        <Parameter name="_pageName" type="String"/>
        <Parameter name="_pageType" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setWebPageHTMLFromSystem" id="aa346b33-e2d3-4219-8d83-e5a3122b3d64">
        <source>setWebPageHTMLFromSystem();
// ---------------------------------------------------------------------------
// Created:     12 June 2005 by cnwrs2
//
// Purpose:     Creates/Updates the WebPageHTML from the html stored
//				within the Jade WebDocuments
// ---------------------------------------------------------------------------
vars
	tmpSchema	: Schema;
begin

	tmpSchema := self.getWebSiteSchema(true);
	
	beginTransaction;
	self.setWebPageHTMLForPage(tmpSchema, self.changePasswordPage, Page_ChangePassword);
	self.setWebPageHTMLForPage(tmpSchema, self.currentReportsPage, Page_CurrentReports);
	self.setWebPageHTMLForPage(tmpSchema, self.criteriaPage, Page_ReportCriteria);
	self.setWebPageHTMLForPage(tmpSchema, self.eventNotifyMaintPage, Page_EventNotifyMaint);
	self.setWebPageHTMLForPage(tmpSchema, self.eventNotifyViewPage, Page_EventNotifyView);
	self.setWebPageHTMLForPage(tmpSchema, self.footerPage, Page_Footer);
	self.setWebPageHTMLForPage(tmpSchema, self.headerInPage, Page_HeaderLoggedIn);
	self.setWebPageHTMLForPage(tmpSchema, self.headerOutPage, Page_HeaderLoggedOut);
	self.setWebPageHTMLForPage(tmpSchema, self.infoPage, Page_Info);
	self.setWebPageHTMLForPage(tmpSchema, self.listPage, Page_ReportsList);
	self.setWebPageHTMLForPage(tmpSchema, self.eventReqStopMaintPage, Page_StopMaint);
	self.setWebPageHTMLForPage(tmpSchema, self.eventReqStopViewPage, Page_StopView);
	self.setWebPageHTMLForPage(tmpSchema, self.prenoteMaintPage, Page_PrenoteMaint);
	self.setWebPageHTMLForPage(tmpSchema, self.prenoteViewPage, Page_PrenoteView);
	self.setWebPageHTMLForPage(tmpSchema, self.outputPage, Page_ReportOutput);
	commitTransaction;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="validate" id="539852cd-a7ce-4f72-b979-24c3069a7f8e">
        <source>validate(_real : CM_WebSiteConfig);
// -------------------------------------------
// Created 24 November 2004 by cnwdvb1
//14/06/2022    navds20     TFS 53760 DuplicateItem not Translatable
// -------------------------------------------
vars

	webSiteConfig : CM_WebSiteConfig;
	jadeHTTPTimeout : Integer;
	iniFile	: File;
begin	

	// Par 10909
	if self.name = null then
//		app.raiseCMException1(REQUIRED_FIELD, 'Web Config Name', null, null);
		app.raiseCMException(Input_required_field_webConf, null, null); // cnwdb2	PAR 35364
	endif;
	
	webSiteConfig := app.myRoot.allWebSiteConfigs[self.name];
	
	if webSiteConfig &lt;&gt; null then
		if _real &lt;&gt; webSiteConfig or _real = null then
			//app.raiseCMException2(DuplicateItem, 'WebSiteConfig Name ' &amp; self.name, 'System', null, null); //14.06.2022 navds20 53760
			// WebSiteConfig Name %1 already exists for System : Websit_name_alread_exists_syst
			app.raiseCMException1(Websit_name_alread_exists_syst, self.name, null, null); //14.06.2022 navds20 53760
			return;
		endif;
	endif;
	
	if self.publicUser = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Anonymous User', null, null);
		app.raiseCMException(Input_required_field_anonUser, null, null); // cnwdb2	PAR 35364
	endif;
	
	

	if self.isWebServiceConfig then //cnwrd web service validation
		//do download validation
		if self.downloadFileDirectoryPath = null then
		//	app.raiseCMException1(REQUIRED_FIELD, 'Download File Directory Path', null, null);
			app.raiseCMException(Input_required_field_downFleDr, null, null); // cnwdb2	PAR 35364
		endif;
		
		if self.downloadFileDirectoryURL = null then
		//	app.raiseCMException1(REQUIRED_FIELD, 'Download File Directory URL', null, null);
			app.raiseCMException(Input_required_field_dowFleURL, null, null); // cnwdb2	PAR 35364
		endif;
		
		if self.downloadFileTimeout = null then
		//	app.raiseCMException1(REQUIRED_FIELD, 'Download File Timeout', null, null);
			app.raiseCMException(Input_required_field_dowFleTim, null, null); // cnwdb2	PAR 35364
		endif;
		
		// TFS 42010 MTN Early Terminaion of web services
		create iniFile transient;
		iniFile.usePresentationFileSystem := false;
		iniFile.mode := File.Mode_Input;
		iniFile.fileName := app.cnGetServerMiscPath &amp; "\bin_public_jadehttp\ini\jadehttp.ini";
		if iniFile.isAvailable then
			jadeHTTPTimeout := app.getProfileStringAppServer(iniFile.fileName, JMTWebService_Section, "MessageTimeout", "300").Integer;
			if self.responseTimeoutSecs &gt;= jadeHTTPTimeout then
				app.raiseCMWarning2(Web_Res_Timeout_Too_Big, self.responseTimeoutSecs.String, jadeHTTPTimeout.String, CM_WebSiteConfig::responseTimeoutSecs.name, null, null);
			endif;
		endif;

	else   // HTML page config

		if self.currentReportsPage = null then
		//	app.raiseCMException1(REQUIRED_FIELD, 'Current Reports Page', null, null);
			app.raiseCMException(Input_required_field_curRepPag, null, null); // cnwdb2	PAR 35364
		endif;
		
		if self.changePasswordPage = null then
		//	app.raiseCMException1(REQUIRED_FIELD, 'Change Password Page', null, null);
			app.raiseCMException(Input_required_field_changPass, null, null); // cnwdb2	PAR 35364
		endif;
	
		if self.criteriaPage = null then
		//	app.raiseCMException1(REQUIRED_FIELD, 'Criteria Page', null, null);
			app.raiseCMException(Input_required_field_critPage, null, null); // cnwdb2	PAR 35364
		endif;
		
		if self.infoPage = null then
		//	app.raiseCMException1(REQUIRED_FIELD, 'Information Page', null, null);
			app.raiseCMException(Input_required_field_infoPage, null, null); // cnwdb2	PAR 35364
		endif;
		
		if self.listPage = null then
		//	app.raiseCMException1(REQUIRED_FIELD, 'List Page', null, null);
			app.raiseCMException(Input_required_field_listPage, null, null); // cnwdb2	PAR 35364
		endif;
		
		if self.loginPage = null then
		//	app.raiseCMException1(REQUIRED_FIELD, 'Login Page', null, null);
			app.raiseCMException(Input_required_field_loginPage, null, null); // cnwdb2	PAR 35364
		endif;
		
		if self.outputPage = null then
		//	app.raiseCMException1(REQUIRED_FIELD, 'Output Page', null, null);
			app.raiseCMException(Input_required_field_outagePag, null, null); // cnwdb2	PAR 35364
		endif;
		
		
	//	if self.sessionTimeoutMinutes = null then
	//		app.raiseCMException1(REQUIRED_FIELD, 'Session Time Out', null, null);
	//	endif;
		
		if self.virtualDirectory = null then
		//	app.raiseCMException1(REQUIRED_FIELD, 'Virtual Diretory', null, null);
			app.raiseCMException(Input_required_field_virtDirct, null, null); // cnwdb2	PAR 35364
		endif;
		
		if self.machineName = null then
		//	app.raiseCMException1(REQUIRED_FIELD, 'Machine Name', null, null);
			app.raiseCMException(Input_required_field_machName, null, null); // cnwdb2	PAR 35364
		endif;
		
		if self.eventReqStopMaintPage = null then
		//	app.raiseCMException1(REQUIRED_FIELD, 'Stop Maintanence Page', null, null);
			app.raiseCMException(Input_required_field_stopMaint, null, null); // cnwdb2	PAR 35364
		endif;
	
		if self.eventReqStopViewPage = null then
		//	app.raiseCMException1(REQUIRED_FIELD, 'Stop View Page', null, null);
			app.raiseCMException(Input_required_field_stopView, null, null); // cnwdb2	PAR 35364
		endif;
		
		if self.prenoteMaintPage = null then
		//	app.raiseCMException1(REQUIRED_FIELD, 'Prenote Maintanence Page', null, null);
			app.raiseCMException(Input_required_field_preMaint, null, null); // cnwdb2	PAR 35364
		endif;
	
		if self.prenoteViewPage = null then
		//	app.raiseCMException1(REQUIRED_FIELD, 'Prenote View Page', null, null);
			app.raiseCMException(Input_required_field_preViewPg, null, null); // cnwdb2	PAR 35364
		endif;
		
		if self.webApplicationName = null then
		//	app.raiseCMException1(REQUIRED_FIELD, 'Web Application Name', null, null);
			app.raiseCMException(Input_required_field_webAppNam, null, null); // cnwdb2	PAR 35364
		endif;
	
	endif;
	
end;</source>
        <Parameter name="_real" type="CM_WebSiteConfig"/>
    </JadeMethod>
    <JadeMethod name="validateDirectoryPath" id="2800ea2d-689a-412b-8018-91f372563079">
        <source>validateDirectoryPath(_directoryPath:String);
// --------------------------------------------------------------------------------
// Created:		25 October 2005 by cnwdad1
//
// Purpose:		Validates the specified directory path for the receiver.
//
// Parameters:	_directoryPath - The name of the Web Site Config's directory path.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if _directoryPath = null then
//		app.raiseCMException1(REQUIRED_FIELD, 'Directory Path', null, null);
		app.raiseCMException(Input_required_field_dirctPath, null, null); // cnwdb2	PAR 35364
	endif;
end;</source>
        <Parameter name="_directoryPath" type="String"/>
    </JadeMethod>
</Class>
