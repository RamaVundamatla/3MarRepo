    <JadeMethod name="getDataTypeFromDefName" id="383860d8-2cee-493c-b213-bf81865749c9">
        <source>getDataTypeFromDefName(_name: String): Integer;
//
// cnwrs1 CCMS 1008 1036 cnwrs1 Jan 2010
//
vars

begin
	if _name = ETDef_EDITIVoyage then
		return EDIDataType_Voyage;
	elseif _name = ETDef_EDITIPort then
		return EDIDataType_Port;
	elseif _name = ETDef_EDITIVoyageCutoff then //cnwgb1 PAR 23207 17.3.2010 
		return EDIDataType_VoyageRecCutoff;
	endif;
epilog

end;</source>
        <Parameter name="_name" type="String"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
