    <JadeMethod name="initializeChangeTracker" id="318e3df9-f76a-4f79-9a9b-6e12b185047b">
        <updating/>
        <source>initializeChangeTracker(): Integer updating;
/*
*/
vars
	singleThread: JSSCTSingleThreadingObject;
	auditLog: JSSCTAuditLogInterface;
	nibblerMgr: JSSCTNibblerManager;
	nibblerTA: JSSCTNibblerManagerTA;
begin
	if self.myNibblerManager &lt;&gt; null and global.isValidObject(self.myNibblerManager) then
		return (self.NIBBLER_ALREADY_RUNNING);
	endif;
	singleThread := JSSCTSingleThreadingObject.firstInstance;
	if singleThread = null then
		beginTransaction;
		create singleThread;
		commitTransaction;
	endif;
	if not self.tryLock(singleThread, Exclusive_Lock, Session_Duration, LockTimeout_Immediate) then
		return (self.NIBBLER_ALREADY_RUNNING);
	endif;
	self.mySingleThreader := singleThread;

	// create a second instance of the single threading object // JETkgd 26/1/2004
	
	if JSSCTSingleThreadingObject.instances.size = 1 then
		beginTransaction;
		create singleThread;
		commitTransaction;
	endif;

	nibblerMgr := JSSCTNibblerManager.firstInstance;
	if nibblerMgr = null then
		create nibblerTA transient;
		nibblerTA.createEntity();
		nibblerMgr := nibblerTA.myNibblerManager;
		delete nibblerTA;
	endif;
	auditLog := JSSCTAuditLogInterface.firstInstance;
	if auditLog = null then
		beginTransaction;
		create auditLog persistent;
		commitTransaction;
	endif;
	create self.myJadeLog;
	self.myJadeLog.fileName := JSSChangeTrackerLog;

	self.myNibblerManager := nibblerMgr.cloneSelf(true);
	self.myNibblerManager.initialize(self, nibblerMgr);

	return (self.NIBBLER_INITIALIZED);
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="initializeController" id="897c0aa3-762f-4083-aa46-20a445ac20b2">
        <updating/>
        <source>initializeController() updating;
/*
	Shows the Controller form

	This method is available as an Interface Method
*/
vars
	nibblerMgr: JSSCTNibblerManager;
	nibblerTA: JSSCTNibblerManagerTA;

begin
	nibblerMgr := JSSCTNibblerManager.firstInstance;
	if nibblerMgr = null then
		create nibblerTA transient;
		nibblerTA.createEntity();
		nibblerMgr := nibblerTA.myNibblerManager;
		delete nibblerTA;
	endif;
	//	check if we have already been initialized
	if self.myControllerForm &lt;&gt; null and global.isValidObject(self.myControllerForm) then
		return;
	endif;
	//	create and initialize a ListenManager for this application
	create self.myControllerForm transient;
	self.myControllerForm.setPublicInterface(self);
	self.myControllerForm.setServiceManager(self.getManager().JSSChangeTrackingServiceMgr);
	self.myControllerForm.show;
end;</source>
    </JadeMethod>
