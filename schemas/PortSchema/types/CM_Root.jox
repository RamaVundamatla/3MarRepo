	self.setupInvStatusEmailDefault(PINEmail_InvProcDefOffset + CM_Invoice.INVOICE_PENDING, // ie. 301
									app.invoiceStatusEnumToString(CM_InvoiceProcessDefault.firstInstance, CM_Invoice.INVOICE_PENDING),
