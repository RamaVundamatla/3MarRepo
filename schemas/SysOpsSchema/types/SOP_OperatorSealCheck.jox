    <JadeMethod name="doOK" id="9dcd737f-e1f9-445c-8068-92516fc487f9">
        <updating/>
        <source>doOK()updating;
//26 August 2010	cnwml2
//+cnwml2 PAR23715 SFW CCMS1131

vars

begin
	if self.doValidateSealCheck() then
		self.modalResult := ModalResultOK;
		self.unloadForm();
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doValidateSealCheck" id="f940047e-1c01-4fd1-b8a1-14d1a5b40d60">
        <source>doValidateSealCheck(): Boolean;
//26 August 2010	cnwml2
//+cnwml2 PAR23715 SFW CCMS1131

vars

begin
	if self.cmbOperator.listObject = null then
		app.msgBox("Please enter a value for operator", "Missing entry", MsgBox_OK_Only);
		self.cmbOperator.setFocus();
		return false;
	elseif self.cmbOperation.text = null then
		app.msgBox("Please enter a value for operation", "Missing entry", MsgBox_OK_Only);
		self.cmbOperation.setFocus();
		return false;
	elseif self.cmbReceival.text = null then
		app.msgBox("Please enter a value for receival", "Missing entry", MsgBox_OK_Only);
		self.cmbReceival.setFocus();
		return false;
	elseif self.cmbRelease.text = null then
		app.msgBox("Please enter a value for operator", "Missing entry", MsgBox_OK_Only);
		self.cmbRelease.setFocus();
		return false;
	endif;
	return true;
	
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
