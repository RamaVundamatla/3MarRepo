    <JadeMethod name="contextMenu" id="1882954c-428b-4662-a1a0-fa14908f6672">
        <controlMethod name="Form::contextMenu"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>contextMenu(conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating;

vars
	x1, y1 : Real;
begin
	if (not app.isAllowedToInspect) then
		return false;
	endif;
	
	// ok to show menu
	x1 := x;
	y1 := y;
	if not mouse then  // if keyboard, use current listIndex value
	    x1 := 1;
	    y1 := 1;
	endif;

	conwin.windowToScreen(x1, y1);
	self.screenToWindow(x1, y1);   // convert x, y relative to form

	return false;
end;</source>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="convertIdToCargoOnRecInfo" id="9b2532b4-4944-452f-b972-905ecbcbbc16">
        <source>convertIdToCargoOnRecInfo( _receivalInfo : CM_ReceivalRequestInfo; _cargoId : String ):Boolean protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
30 September 2011	cnwndl1	Initial creation	Par 28285

*/

vars

	cargoType : CM_CargoType;
	term : CM_Terminal;
	flexiController : CMIF_FlexiGateController;
	recRequest : CM_ReceivalRequest;
	operator : CM_Operator;
	voyage : CM_Voyage;
	visit : CM_VehicleVisitRecord;
	pxyGateEntity : CMGTE_Receival;
	realGateEntity : CMGTE_Entity;
	result : Integer;

begin

	recRequest := _receivalInfo.myReceivalRequest;
	if recRequest &lt;&gt; null and recRequest.myGateEntity &lt;&gt; null then
		visit := recRequest.myGateEntity.myVehicleVisitRecord;
	endif;
		
	if visit = null then
		return false;
	endif;

	cargoType := _receivalInfo.myCargoType;
	term := self.myTerminal;
	
	create flexiController transient;
	flexiController.id := _cargoId;
	
	flexiController.cargoType := cargoType.id;
	flexiController.bookingNumber := _receivalInfo.myBooking.bookingReference;
	flexiController.myBookingRefItem := _receivalInfo.myBookingItem;
	if _receivalInfo.myBookingItem &lt;&gt; null then
		flexiController.consignorCode := _receivalInfo.myBookingItem.consignorCode;
		flexiController.isoTypeCode := _receivalInfo.myBookingItem.isoType;
		flexiController.myProduct := _receivalInfo.myBookingItem.myProduct;
	else
		flexiController.consignorCode := _receivalInfo.myBooking.consignorCode;
		flexiController.isoTypeCode := _receivalInfo.myBooking.isoType;
		flexiController.myProduct := _receivalInfo.myBooking.myProduct;
	endif;
	if recRequest &lt;&gt; null and recRequest.myFreightForwarder &lt;&gt; null then
		flexiController.freightForwarderCode := recRequest.myFreightForwarder.code;
	endif;
	flexiController.commodity := _receivalInfo.commodity;
	if cargoType.id = TI_CargoType_Container then
		flexiController.setOxygen( NULL_OXYGEN );	
		flexiController.setCarbonDioxide( NULL_CARBON_DIOXIDE );
	else
		flexiController.setOxygen( NULL_OXYGEN );	
		flexiController.setCarbonDioxide( NULL_CARBON_DIOXIDE );	
		flexiController.jobType := CMGTE_Entity.JobType_GeneralIN;
	endif;
	flexiController.destinationPort := _receivalInfo.myBooking.destinationPort;
	flexiController.dischargePort := _receivalInfo.myBooking.dischargePort;
	
	operator := _receivalInfo.myBooking.myOperator;
	if operator &lt;&gt; null then
		flexiController.operatorCode := operator.code;
	endif;
	
	voyage := _receivalInfo.myBooking.myVoyage;
	if voyage &lt;&gt; null then
		flexiController.voyageCode := voyage.code;
	endif;
	
	if voyage &lt;&gt; null then
		flexiController.imexStatus := TI_IMEX_STATUS_EXPORT;
	else
		flexiController.imexStatus := TI_IMEX_STATUS_STORAGE;
	endif;
		
	if _receivalInfo.myBookingItem &lt;&gt; null then
		flexiController.length := _receivalInfo.myBookingItem.length;
		flexiController.width := _receivalInfo.myBookingItem.width;
		flexiController.height := _receivalInfo.myBookingItem.height;	
		//flexiController.quantity := _receivalInfo.myBookingItem.quantity;
		flexiController.quantity := _receivalInfo.quantity;	//19 Feb 2014	NDL	Par 33529
		if flexiController.quantity = 0 then
			flexiController.quantity := _receivalInfo.myBookingItem.productQuantity;
		endif;
		flexiController.volume := _receivalInfo.myBookingItem.volume;
		if flexiController.volume = 0 then
			flexiController.volume := _receivalInfo.myBookingItem.productVolume;
		endif;
		flexiController.weightTotal := _receivalInfo.myBookingItem.weight;
		if flexiController.weightTotal = 0 then
			flexiController.weightTotal := _receivalInfo.myBookingItem.productWeight;
		endif;
	else
		flexiController.length := _receivalInfo.myBooking.length;
		flexiController.width := _receivalInfo.myBooking.width;
		flexiController.height := _receivalInfo.myBooking.height;	
		//flexiController.quantity := _receivalInfo.myBooking.quantity;
		flexiController.quantity := _receivalInfo.quantity;	//19 Feb 2014	NDL	Par 33529
		flexiController.volume := _receivalInfo.myBooking.volume;
		flexiController.weightTotal := _receivalInfo.myBooking.weight;
	endif;
	
	if flexiController.myProduct &lt;&gt; null then
		//get the default values for the product, for zero values.
		if flexiController.length = 0 then
			flexiController.length := flexiController.myProduct.length;
		endif;
		if flexiController.width = 0 then
			flexiController.width := flexiController.myProduct.width;
		endif;
		if flexiController.height = 0 then
			flexiController.height := flexiController.myProduct.height;
		endif;
		if flexiController.quantity = 0 then
			flexiController.quantity := 1;
		endif;
		if flexiController.volume = 0 then
			flexiController.volume := flexiController.myProduct.volume;
		endif;
		if flexiController.weightTotal = 0 then
			flexiController.weightTotal := flexiController.myProduct.weight;
		endif;
	endif;
	
	flexiController.myTerminal := self.myTerminal;
	
	flexiController.myVehicleVisitRecord := visit;
	flexiController.myVehicle := visit.vehicle;
	
	// create a CMGTE_Receival proxy and populate from the flexi gate controller
	pxyGateEntity := flexiController.createCMGTE_ReceivalProxy(cargoType);
	pxyGateEntity.setMoveToTruckOnly(true);

	while true do
		app.myTrxCA.trxCreateAndActionGateEntity(visit, pxyGateEntity, _receivalInfo, realGateEntity, app.myPassport);
		
		if app.myPassport.trxCompletedOK then
			app.myPassport.clearErrorsWarnings();
			break;
		else
			//If there were warnings, give the user a chance to ignore them. 
			
			// don't care about this one.
			if app.myPassport.allErrorWarnings.size = 1 and app.myPassport.allErrorWarnings.includesErrorCode(WARN_INVALID_LOCN) then
				result := IDOK;
			else
				result := app.showErrorWarningDialog(app.getErrorString(CreateCargo), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			endif;
			if app.myPassport.noErrors and result = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		return false;
	endwhile;

	return true;

epilog

	delete flexiController;
	delete pxyGateEntity;

end;</source>
        <access>protected</access>
        <Parameter name="_receivalInfo" type="CM_ReceivalRequestInfo"/>
        <Parameter name="_cargoId" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="copySelectedEntries" id="04f66cd6-20cf-4ecd-a3e6-30d3cb2532ca">
        <source>copySelectedEntries(_list :CMUI_ListBox; _coll :Collection input) protected;
// ---------------------------------------------------------------------------
// Created:     24 June 2010 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 
// ---------------------------------------------------------------------------
vars
	int, size		:Integer;
	obj				:Object;
	gotException	:Boolean;
begin
	on Exception do app.handleDeletedObject (exception, obj, gotException);
	
	_coll.clear;
	
	size := _list.listCount;

	if size = 0 then
		return;
	endif;
	
	foreach int in 1 to size do
		obj := _list.itemObject[int];
		if obj &lt;&gt; null then
			obj.edition;				// force exception
			
			if gotException then
				gotException := false;	// for next iteration
				continue;
			endif;
			
			_coll.add (obj);
		endif;
	endforeach;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_list" type="CMUI_ListBox"/>
        <Parameter name="_coll" type="Collection" usage="input"/>
    </JadeMethod>
