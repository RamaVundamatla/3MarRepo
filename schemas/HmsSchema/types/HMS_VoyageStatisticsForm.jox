    <JadeMethod name="create" id="95062d22-3f67-45e4-b718-c79aa8be1139">
        <updating/>
        <executionLocation>client</executionLocation>
        <source>create() updating, clientExecution;
//--------------------------------------------------
// Created:	23 November 2005 By: cnwgd1
//--------------------------------------------------
vars

begin

	// set to this for now, needs its own permission
	self.permissionMaint := PmShipVoyageStatView;
	self.permissionView := PmShipVoyageStatView;
	
	self.helpFileName := HelpFile_Harbour;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="displayVoyageAnalysis" id="b0d77212-593f-449d-ba29-9dce7dd1f08a">
        <source>displayVoyageAnalysis()protected;
//--------------------------------------------------
// Created:	29 November 2005 By: cnwgd1
//--------------------------------------------------
vars
	idx,
	col1,
	col2,
	cellColour,
	backColour,
	group : Integer;
	isGroupTotal : Boolean;
	tmpCMIF : CMIF_Object;
	tmpVoyageAnaly : CMIF_VoyageAnalysis;
	tmpTable : CM_DataTable;
begin
	tmpTable := self.tblData;
	
	tmpTable.rows := tmpTable.fixedRows;
	
	col1 := tmpTable.getColumnByRowName(ETRow_ChangeThisLastCYTD);
	col2 := tmpTable.getColumnByRowName(ETRow_ChangeThisLastFYTD);	
	
	foreach tmpCMIF in self.allVoyageAnalysisArray do
		tmpVoyageAnaly := tmpCMIF.CMIF_VoyageAnalysis;
		isGroupTotal := tmpVoyageAnaly.isGroupTotal();
		
		if tmpVoyageAnaly.group &lt;&gt; group 
		and (not isGroupTotal) then
			if tmpVoyageAnaly.group &lt;&gt; VoyageStat_CargoOffloaded		
			and tmpVoyageAnaly.group &lt;&gt; VoyageStat_CargoLoaded
			and tmpTable.rows &lt;&gt; tmpTable.fixedRows then			
				idx := tmpTable.addItem('');
			endif;		
			idx := tmpTable.addItem(tmpVoyageAnaly.groupDescription);
			tmpTable.accessCell(idx, 1).fontBold := true;
			if idx mod 2 = 0 then
				backColour := self.colorRow1;
				cellColour := Gray;
			else
				backColour := self.colorRow2;
				cellColour := White;
			endif;			
			tmpTable.accessRow(idx).backColor := backColour;
			//tmpTable.accessCell(idx, col1).backColor := cellColour;		
			//tmpTable.accessCell(idx, col2).backColor := cellColour;										
		endif;
		
		group := tmpVoyageAnaly.group;
		idx := tmpTable.addItemObject(tmpVoyageAnaly, tmpVoyageAnaly.getAttributeStringForDefArray(tmpTable.allTblDataEntRows));
		if isGroupTotal then
			tmpTable.accessRow(idx).fontBold := true;		
		endif;

		if idx mod 2 = 0 then
			backColour := self.colorRow1;
			cellColour := Gray;
		else
			backColour := self.colorRow2;
			cellColour := White;
		endif;			
		tmpTable.accessRow(idx).backColor := backColour;
		//tmpTable.accessCell(idx, col1).backColor := cellColour;		
		//tmpTable.accessCell(idx, col2).backColor := cellColour;				
					
	endforeach;

end;</source>
        <access>protected</access>
    </JadeMethod>
