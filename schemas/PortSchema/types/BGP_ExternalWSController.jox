    <JadeMethod name="numQueuedRequests" id="1773af6d-5903-4bf2-a30b-1ab55e943cc0">
        <methodInvocation>mapping</methodInvocation>
        <source>numQueuedRequests(set: Boolean; _value: Integer io) mapping;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 October 2018	jlger1	Initial creation 41229

*/

vars
	tmpClass	: Class;
	number		: Integer;
	className	: String;
	iter		: Iterator;
	request		: BGP_Request;
begin
	if set then
		app.raiseSetVirtualError(class.name, method.name);
		return;
	endif;

	foreach className in self.allRequestClassesToProcess do
		tmpClass := self.getClass(className);
		if tmpClass = null then
			continue;
		endif;
		delete iter;
		iter := tmpClass.instances.createIterator;
		while iter.next(request) do
			if not global.isValidObject(request) then
				continue;
			endif;
			//epr TFS 41229 29/10/18
			if self.myTerminal &lt;&gt; null and request.myTerminal &lt;&gt; null then
				if self.myTerminal &lt;&gt; request.myTerminal then
					continue;
				endif;
			endif;
			number:=number + 1;
		endwhile;
	endforeach;
	_value := number;
epilog
	delete iter;
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="setAttributesForCreate" id="5d3d72b2-4262-467b-9865-f2ffbd0b46ce">
        <updating/>
        <source>setAttributesForCreate() updating, protected;
//
// 11 June 2018	jlgrs1	TFS 39013 (37190) Pelindo BGP Web Service
