		self.tblParameter.setFocus();
		
		self.switchDateBoxComboBox(true, ETRow_BaseDate, self.cmbBaseDate);
		self.switchDateBoxComboBox(true, ETRow_CloseDate, self.cmbCloseDate);
		self.switchDateBoxComboBox(true, ETRow_PackByDate, self.cmbPackByDate);
		self.switchDateBoxComboBox(true, ETRow_MatchDateEnd, self.cmbMatchEnd);
		self.switchDateBoxComboBox(true, ETRow_MatchDateStart, self.cmbMatchStart);
		self.switchDateBoxComboBox(true, ETRow_OnDate, self.cmbOnDate);
		self.switchDateBoxComboBox(true, ETRow_OpenDate, self.cmbOpenDate);
		self.switchDateBoxComboBox(true, ETRow_OnDate, self.cmbOnDate);
		self.switchDateBoxComboBox(true, ETRow_OpenDate, self.cmbOpenDate);
		
		self.switchDateBoxComboBox(true, ETRow_StartDate, self.cmbOpenDate);
		self.switchDateBoxComboBox(true, ETRow_EndDate, self.cmbCloseDate);
		self.switchDateBoxComboBox(true, ETRow_FromPackByDate, self.cmbOpenDate);		// cnwdad1 16/11/2010 - PAR #25218.
		self.switchDateBoxComboBox(true, ETRow_ToPackByDate, self.cmbCloseDate);		// cnwdad1 16/11/2010 - PAR #25218.
		self.switchDateBoxComboBox(true, ETRow_ProcessDate, self.cmbProcDate);	//16 Nov 2009	NDL	Par 21519
		self.switchDateBoxComboBox(true, ETRow_ReportDate, self.cmbBaseDate);	//14 Sep 2012	EPR PAR 30364
	
		// HMS
	// added as combos were populating but not with what was default. HJG 26/04/05
		self.setDateComboBoxsFromText(ETRow_ArrivalsDateFrom, self.cmbArriveDFrom);
		self.setDateComboBoxsFromText(ETRow_ArrivalsDateTo, self.cmbArriveDTo);
		self.setDateComboBoxsFromText(ETRow_DepartedDateFrom, self.cmbDepartDFrom);
		self.setDateComboBoxsFromText(ETRow_DepartedDateTo, self.cmbDepartDTo);
		self.setDateComboBoxsFromText(ETRow_InPortDateFrom, self.cmbInPortDFrom);
		self.setDateComboBoxsFromText(ETRow_InPortDateTo, self.cmbInPortDTo);
		
		// 20/04/2023	navkc1	CR 55654 Task 55670 --&gt;
		self.setDateComboBoxsFromText(ETRow_ContractFromStartDate, self.cmbContractFromStartDate);
		self.setDateComboBoxsFromText(ETRow_ContractToStartDate, self.cmbContractToStartDate);
		self.setDateComboBoxsFromText(ETRow_DetailFromStartDate, self.cmbDetailFromStartDate);
		self.setDateComboBoxsFromText(ETRow_DetailToStartDate, self.cmbDetailToStartDate);
		self.setDateComboBoxsFromText(ETRow_RateFromStartDate, self.cmbRateFromStartDate);
		self.setDateComboBoxsFromText(ETRow_RateToStartDate, self.cmbRateToStartDate);
		
		self.setDateComboBoxsFromText(ETRow_ContractFromEndDate, self.cmbContractFromEndDate);
