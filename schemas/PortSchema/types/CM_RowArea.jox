    <JadeMethod name="getLabels" id="599bae2b-2153-4dbd-b69b-e1dddd4dacb2">
        <updating/>
        <source>getLabels(_labels : String) updating, protected;

vars
	
	labels	: String;
	desc	: StringArray;

begin

	self.raiseExceptionIfNotTransient(method);
	labels := _labels;
	self.allLabels.clear;
	labels.replaceChar("," , "/");
	// populate a string array splitting by the token
	desc := labels.getTokens;
	if desc.size &gt; 0 then
		desc.copy(self.allLabels);
	endif;
epilog
	delete desc;
end;</source>
        <access>protected</access>
        <Parameter name="_labels" type="String"/>
    </JadeMethod>
    <JadeMethod name="getNextGap" id="f34a0750-d076-4fda-a945-d6fafa2f9406">
        <source>getNextGap(_previous : String; _pos : Integer output) : CM_RowAreaRow protected;

vars

	prevController	: CM_RowController;
	prevRow, gapRow	: CM_RowAreaRow;
	pos, gapPos		: Integer;
	
begin

	// Get previous row controller.
	prevController := self.allRowControllersById.getAtKey(_previous);
	if prevController &lt;&gt; null then
		// Get RowAreaRow from it.
		prevRow := prevController.myRow;
		if prevRow &lt;&gt; null then
			// Find its position.
			pos := self.allRows.indexOf(prevRow);
			if pos &lt;&gt; 0 then
				// There should always be a gap to the left and to the right.
				gapPos := pos + 1;
				gapRow := self.allRows[gapPos];	
				_pos := gapPos;
			endif;
		endif;
	else
		// No specified controller. Put it at the front.
		if self.allRows.size &gt; 0 then
			gapRow := self.allRows.first;
			_pos := 1;
		endif;
	endif;
	
	if gapRow &lt;&gt; null and gapRow.allRowControllers.size = 0 then
		return gapRow;
	else
		return null;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_previous" type="String"/>
        <Parameter name="_pos" type="Integer" usage="output"/>
        <ReturnType type="CM_RowAreaRow"/>
    </JadeMethod>
    <JadeMethod name="getPrevControlFromActual" id="a57ff771-45a4-4532-a696-02c08ed8ef07">
        <source>getPrevControlFromActual(_label : String; _distanceFromPrev : Real output; _isExactMatch : Boolean) : CM_RowController protected;

vars

	row, prevGap, prevActual	: CM_RowAreaRow;
	rowController				: CM_RowController;		
	index						: Integer;

begin

	// Get row controller from supplied id.
	if _isExactMatch then
		rowController := self.allRowControllersById.getAtKey(_label);
		if  rowController &lt;&gt; null then
			// Get RowAreaRow from this rowController.
			row := rowController.myRow;	
			// Find out its position.
			index := self.allRows.indexOf(row);
			// Do we have a valid position and can we increment backwards to the next populated RowAreaRow.
			if index &lt;&gt; 0 and (index - 1 &gt; 0 )then
				// Get gap.
				prevGap := self.allRows.at(index - 1);
				// Get next populated row.
				if (index - 2 &gt; 0) then
					prevActual := self.allRows.at(index - 2);
				endif;
				// Make sure we have a gap. No controllers.
				if prevGap &lt;&gt; null and prevGap.allRowControllers.size = 0 then
					// Get gap width. This is the distance our populated RowAreaRow is from the previous RowAreaRow.
					_distanceFromPrev := prevGap.width;
					// Return the last controller on the previous RowAreaRow.
					if prevActual &lt;&gt; null and prevActual.allRowControllers.size &gt; 0 then
						return prevActual.allRowControllers.last;
					endif;
				endif;
			endif;
		endif;
	else
		rowController := self.allRowControllersById.getAtKeyLss(_label);
		if rowController &lt;&gt; null then
			return rowController;
		endif;
	endif;
	return null;

end;</source>
        <access>protected</access>
        <Parameter name="_label" type="String"/>
        <Parameter name="_distanceFromPrev" type="Real" usage="output"/>
        <Parameter name="_isExactMatch" type="Boolean"/>
        <ReturnType type="CM_RowController"/>
    </JadeMethod>
    <JadeMethod name="getPrevControlFromDistance" id="568432ea-4ffb-40e6-82ad-8ad32b89217d">
        <source>getPrevControlFromDistance(_distance : Real; _distanceFromPrev : Real output) : CM_RowController protected;

vars

	row, prevRow			: CM_RowAreaRow;
	iterator				: Iterator;
	length					: Real;

begin

	// We are return a rowController based on its position.
	iterator := self.allRows.createIterator;	
	while iterator.next(row) do
		// Get position in metres.
		length := length + row.width;
		// If the length does not full on the first gap and the length is greater or equal to the specified distance.
		if length &gt;= _distance and length &lt;&gt; 0 then
			// Is it a gap.
			if row.allRowControllers.size &gt; 0 then
				// No. Return controller.
				return row.allRowControllers.last;
			else	
				// Go back futher and see if we can get a rowController from here.
				if prevRow &lt;&gt; null and prevRow.allRowControllers.size &gt; 0 then
					return prevRow.allRowControllers.last;
				else
					// Couldn't find anything.
					return null;
				endif;
			endif;
		endif;
		// Set previous rowController reference.
		prevRow := row;
	endwhile;
	return null;
	
epilog
	// Calculate previous distance.
	if row &lt;&gt; null then
		_distanceFromPrev := (_distance - (length - row.width)).max(0);
	endif;
	delete iterator;
end;</source>
        <access>protected</access>
        <Parameter name="_distance" type="Real"/>
        <Parameter name="_distanceFromPrev" type="Real" usage="output"/>
        <ReturnType type="CM_RowController"/>
    </JadeMethod>
    <JadeMethod name="getPrevGap" id="f73f378a-8365-44ff-bc8c-a3857fa44aa1">
        <source>getPrevGap(_rowAreaRow : CM_RowAreaRow) : Real;
// ---------------------------------------------------------------------------
// Created:     09 July 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	idx			: Integer;
	_prevRow	: CM_RowAreaRow;

begin

	_prevRow := self.getPrevRow(_rowAreaRow);

	if _prevRow = null then
		return 0;
	endif;
	
	if _prevRow.allRowControllers.isEmpty then
		return _prevRow.width;
	endif;

	return 0;
	
end;</source>
        <Parameter name="_rowAreaRow" type="CM_RowAreaRow"/>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="getPrevRow" id="fc63ccb1-dbd1-4b43-92d7-a99f50137be7">
        <source>getPrevRow(_rowAreaRow : CM_RowAreaRow) : CM_RowAreaRow;
// ---------------------------------------------------------------------------
// Created:     09 July 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	idx			: Integer;
	_prevRow	: CM_RowAreaRow;

begin

	idx := self.allRows.indexOf(_rowAreaRow);
	if idx &gt; 1 then
		return self.allRows[idx-1];
	endif;

	return _prevRow;	
end;</source>
        <Parameter name="_rowAreaRow" type="CM_RowAreaRow"/>
        <ReturnType type="CM_RowAreaRow"/>
    </JadeMethod>
    <JadeMethod name="getPreviousData" id="1e968f85-a3f1-4156-a553-742ecd3f1017">
        <source>getPreviousData(_label : String; _previous : String output; _distanceFromPrevious : Real output; _typeOfSearch : Integer);

vars

	labelDistance	: Real;
	index			: Real;
	controller		: CM_RowController;
	iterator		: Iterator;
	length			: Real;

begin

	// This method returns data based on the previous populated rowAreRow.
	// Which method do we want to use. Do we have an actual rowController id or
	// do we have a specific distance we want to start from.
	if _typeOfSearch = SEARCH_ACTUAL then
		controller := getPrevControlFromActual(_label, _distanceFromPrevious, true);
	
	elseif _typeOfSearch = SEARCH_DISTANCE then
		index := self.allLabels.indexOf(_label);
		if index &lt;&gt; null then
			index := index - 1;
			labelDistance := index * self.standardWidth; 
		endif;
		controller := getPrevControlFromDistance(labelDistance, _distanceFromPrevious);
	
	elseif _typeOfSearch = SEARCH_ALPHABETICAL then
		controller := getPrevControlFromActual(_label, _distanceFromPrevious, false);
	endif;
	
	if controller &lt;&gt; null then
		_previous := controller.id;
	endif;
		
	
epilog

	delete iterator;
end;</source>
        <Parameter name="_label" type="String"/>
        <Parameter name="_previous" type="String" usage="output"/>
        <Parameter name="_distanceFromPrevious" type="Real" usage="output"/>
        <Parameter name="_typeOfSearch" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getRowForSplit" id="ee88f5d8-ae87-44f0-af01-7d74683e8e31">
        <source>getRowForSplit(_controllerId : String) : CM_RowAreaRow;

vars

	rowController : CM_RowController;

begin

	// This method will return a rowAreaRow based on the specified rowController;
	rowController := self.allRowControllersById.getAtKey(_controllerId);	
	if rowController &lt;&gt; null then
		return rowController.myRow;
	endif;
	return null;

end;</source>
        <Parameter name="_controllerId" type="String"/>
        <ReturnType type="CM_RowAreaRow"/>
    </JadeMethod>
    <JadeMethod name="getTheLabels" id="7c954e78-d5c3-4130-9184-49dbf249481d">
        <source>getTheLabels() : String;


vars

	string, stringOut : String;
	

begin

	
	foreach string in self.allLabels do
		stringOut := stringOut &amp; string &amp; ',';
	endforeach;
	return stringOut;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="insertNewRow" id="f3a6feac-08f8-41c2-94a8-5aab4751348d">
        <source>insertNewRow(_row : CM_RowAreaRow input; _previous : String; _width,  _distance : Real);


vars

	gapRow, last	: CM_RowAreaRow;
	newGapWidth		: Real;
	pos				: Integer;

	
begin

	// Set the width for the new row.
	_row.setAttributes(_width);
	// Get the gap which we want to place this new row next to.
	gapRow := self.getNextGap(_previous, pos);	
	if gapRow &lt;&gt; null then
		// Create a new left hand side gap.
		self.createRowAreaRowGap(_distance, pos);
		// Place our new row between to gaps.
		self.allRows.insert(pos + 1, _row);
		// Get new gap width. Will we have space left over etc.
		newGapWidth := (gapRow.width - (_distance + _row.width)).max(0);
		// Set right hand gap width.
		gapRow.setAttributes(newGapWidth);
		// Shrink or expand very last gap to correct size.
		last := self.allRows.last;
		if last &lt;&gt; null then
			last.setAttributes((self.lengthOfArea - rowAreaActualLength(false)).max(0));
		endif;
	else
		app.raiseCMException(GapNotFound, null, null);
	endif;
	checkWithinValidRange();
end;</source>
        <Parameter name="_row" type="CM_RowAreaRow" usage="input"/>
        <Parameter name="_previous" type="String"/>
        <Parameter name="_width" type="Real"/>
        <Parameter name="_distance" type="Real"/>
    </JadeMethod>
    <JadeMethod name="moveExistingRow" id="8d0c5792-b9a7-4331-a395-1d01863480e3">
        <source>moveExistingRow(_row : CM_RowAreaRow input; _previous : String; _width,  _distance : Real);


vars

	prev, next, last	: CM_RowAreaRow;
	gapWidth			: Real;
	pos, oldGap			: Integer;

	
begin

	// Get position of the row we want to move.
	pos := self.allRows.indexOf(_row);
	if pos &lt;&gt; 0 and (pos - 1) &gt; 0 and (pos + 1) &lt;= self.allRows.size then
		prev := self.allRows.at(pos - 1);
		next := self.allRows.at(pos + 1);
		if prev &lt;&gt; null and next &lt;&gt; null then
			// Erase this gap. We don't want to leave it behind.
			gapWidth := prev.width + _row.width;		
			prev.erase(NORMAL_ERASE);
			if self.isGapManaged then
				next.setAttributes(next.width + gapWidth);
			endif;
			// Extract the row we want to move.
			self.allRows.remove(_row);
			// Re insert the row using insertNewRow method.
			self.insertNewRow(_row, _previous, _width, _distance);
			return;
		endif;
	endif;
	app.raiseCMException(GapNotFound, null, null);

end;</source>
        <Parameter name="_row" type="CM_RowAreaRow" usage="input"/>
        <Parameter name="_previous" type="String"/>
        <Parameter name="_width" type="Real"/>
        <Parameter name="_distance" type="Real"/>
    </JadeMethod>
    <JadeMethod name="removeRowAreaRow" id="d02d5ea7-2b53-4c1f-b172-ea3be27a7590">
        <source>removeRowAreaRow(_rowAreaRow : CM_RowAreaRow input) : Boolean;

vars

	index	 				: Integer;
	prevGap, nextGap, last	: CM_RowAreaRow;
	width					: Real;

begin

	// Get position of row we want to delete.
	index := self.allRows.indexOf(_rowAreaRow);	
	// Cam we step back on to get 
	if index &lt;&gt; 0 and (index - 1 &gt; 0) and (index + 1) &lt;= self.allRows.size then
		prevGap := self.allRows.at(index - 1);		
		nextGap := self.allRows.at(index + 1);
		// Do we have a left hand gap?
		if prevGap &lt;&gt; null and prevGap.allRowControllers.size = 0 and
		   nextGap &lt;&gt; null and nextGap.allRowControllers.size = 0 then
			// Erase this gap as it is no longer required.
			width := _rowAreaRow.width + prevGap.width;
			prevGap.erase(NORMAL_ERASE);
			if self.isGapManaged then
				nextGap.setAttributes(nextGap.width + width);
			endif;			
			// Get very last gap.
			last := self.allRows.last;
			// Make sure we have a gap controller.
			if last &lt;&gt; null and last.allRowControllers.size = 0 then
				// Erase our specified row.
				_rowAreaRow.erase(NORMAL_ERASE);
				// Shrink or expand last gap.
				last.setAttributes((self.lengthOfArea - rowAreaActualLength(false)).max(0));
				return true;
			endif;
		endif;
	endif;
	return false;

end;</source>
        <Parameter name="_rowAreaRow" type="CM_RowAreaRow" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="rowAreaActualLength" id="1528f1ec-d52e-4351-b193-8129f92868f3">
        <source>rowAreaActualLength(_includeLast : Boolean) : Real protected;

vars

	iterator	: Iterator;
	row, last	: CM_RowAreaRow;
	length		: Real;
	
begin

	// Get last gap. We don't want to include this.
	last := self.allRows.last;
	if last &lt;&gt; null then
		iterator := self.allRows.createIterator;
		while iterator.next(row) do
			// If row is the last then stop.
			if row = last and not _includeLast then
				break;
			endif;
			// Get total length.
			length := length + row.width;		
		endwhile;
	endif;
	return length;

epilog
	delete iterator;
end;</source>
        <access>protected</access>
        <Parameter name="_includeLast" type="Boolean"/>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="9d405afb-ed96-4fc2-bd0e-295cc5269729">
        <updating/>
        <source>setForCreate(_proxy :CM_RowArea input; _passport : CM_Passport input) updating;
//setForCreate(_proxy : CM_proxy; _passport : CM_Passport input) updating;
//
// Changed On	By			Reason
// ----------	--------	------------------------------------------------------
// 10/06/2020	jlgdap1		TFS 49453 ASPA Satellite View Screen for Flexible Terminal Areas
vars
	
begin
	inheritMethod(_proxy, _passport);
	
	if not self.isGeneralCargoAllocArea() then				// TFS 49453
		self.setForUpdate(_proxy);
		self.createRowAreaRowGap(self.lengthOfArea, 1);
	endif;													// TFS 49453

end;</source>
        <Parameter name="_proxy" type="CM_RowArea" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="afe4bc90-d686-4258-bfff-c2d5c940997b">
        <updating/>
        <source>setForUpdate(_proxy :CM_RowArea) updating;
//setForUpdate(_proxy : CM_proxy) updating;
// Changed On	By			Reason
// ----------	--------	---------------------------------------------------
// 04/06/2020	jlgdap1		TFS 49453 Satellite View Screen for Flexible Terminal Areas
vars

begin
	inheritMethod(_proxy);
	
	if self.isGapManaged &lt;&gt; _proxy.isGapManaged then
		self.isGapManaged := _proxy.isGapManaged;
		self.setGapsToZero();	
	endif;
	
	self.isMarkedUp 	:= _proxy.isMarkedUp;
	self.lengthOfArea 	:= _proxy.lengthOfArea;
	self.standardWidth 	:= _proxy.standardWidth;
	
	self.widthOfArea	:= _proxy.widthOfArea;			// TFS 49453
	
	self.allLabels.clear;
	
	_proxy.allLabels.copy(self.allLabels);
end;</source>
        <Parameter name="_proxy" type="CM_RowArea"/>
    </JadeMethod>
    <JadeMethod name="setGapsToZero" id="25543b49-03f9-40d9-9b6b-41f573dc493c">
        <source>setGapsToZero() protected;

vars
	rowAreaRow	: CM_RowAreaRow;
	count		: Integer;

begin

	if (not self.isGapManaged) then
		foreach rowAreaRow in self.allRows do
			count := count + 1;
			if count.isOdd then
				if rowAreaRow.allRowControllers.size = 0 then
					rowAreaRow.setAttributes(0);
				endif;
			endif;
		endforeach;
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setProxy" id="05746c8d-9af6-4596-9476-84937f4037d3">
        <updating/>
        <source>setProxy(_id, _comment 		: String;
		 _type				: Integer;
		 _length			: Integer;
		 _width				: Integer;
		 _releasePoint		: Boolean;	
		 _terminal			: CM_Terminal;
		 _isGapManaged,
		 _isMarkedUp		: Boolean;
		 _labels			: String;
		 _autoRestrictions,
		 _stockControlled   : Boolean;
		 _hideFromOverView 	: Boolean;
		 _allInterchangeAreas	:CM_InterchangeAreaArray;	// par 24292
		_defaultInterchangeArea: CM_InterchangeArea) updating;   
// 26/05/2010		cnwcs5	par 24292 - change _allInterchangeAreas parameter from set to array
vars

begin

	self.raiseExceptionIfNotTransient(method);
	setProxyTerminalArea(_id, _comment, _type, _releasePoint, _terminal, _autoRestrictions, _stockControlled , _hideFromOverView, _allInterchangeAreas,_defaultInterchangeArea);
	self.isGapManaged := _isGapManaged;
	self.isMarkedUp := _isMarkedUp;
	self.lengthOfArea := _length;
	self.standardWidth := _width;
	self.getLabels(_labels);
	
end;</source>
        <Parameter name="_id" type="String"/>
        <Parameter name="_comment" type="String"/>
        <Parameter name="_type" type="Integer"/>
        <Parameter name="_length" type="Integer"/>
        <Parameter name="_width" type="Integer"/>
        <Parameter name="_releasePoint" type="Boolean"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_isGapManaged" type="Boolean"/>
        <Parameter name="_isMarkedUp" type="Boolean"/>
        <Parameter name="_labels" type="String"/>
        <Parameter name="_autoRestrictions" type="Boolean"/>
        <Parameter name="_stockControlled" type="Boolean"/>
        <Parameter name="_hideFromOverView" type="Boolean"/>
        <Parameter name="_allInterchangeAreas" type="CM_InterchangeAreaArray"/>
        <Parameter name="_defaultInterchangeArea" type="CM_InterchangeArea"/>
    </JadeMethod>
    <JadeMethod name="skipGapCreation" id="f4688249-641d-47df-9289-da99fb2e4699">
        <source>skipGapCreation() : Boolean;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 10/06/2020	jlgdap1		Initial creation TFS 49453 ASPA Satellite View Screen for Flexible Terminal Areas
//
vars

begin
	return false;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="yaFindLCs" id="ea8010de-295e-49f3-ac6f-65ad889c118f">
        <source>yaFindLCs(pFromId: String; pToId: String; pAllControllersObj: CM_LCArray input);
// --------------------------------------------------------------------------------
// Created:		13 April 2005 by cnwdad1:2
//
// Purpose:		Refer to superclass implementation.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	iteratorObj		: Iterator;
	
begin
	if self.allRowControllersById[pFromId] &lt;&gt; null then
		iteratorObj	:=	self.allRowControllersById.createIterator();
		self.allRowControllersById.startKeyGeq(pFromId, iteratorObj);
		self.yaIterateControllerRange(iteratorObj, pFromId, pToId, pAllControllersObj);
	endif;
epilog
	delete iteratorObj;
end;</source>
        <Parameter name="pFromId" type="String"/>
        <Parameter name="pToId" type="String"/>
        <Parameter name="pAllControllersObj" type="CM_LCArray" usage="input"/>
    </JadeMethod>
</Class>
