    </JadeMethod>
    <JadeMethod name="parentHasChanged" id="88e6cc2b-3d70-421e-86c4-6d2208b2911f">
        <source>parentHasChanged(_obj: CM_SecurityRole; _row: Integer): Boolean;
// ---------------------------------------------------------------------------
// Created:     25 February 2003 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	parentRow	: Integer;

begin

	if lstData.itemLevel[_row] = 1 then
		// cannot reset a row back to the top level
		return false;
	endif;
	
	parentRow := lstData.getParentRow(_row);
	
	if parentRow &gt; 0 then
		if lstData.itemObject[parentRow] &lt;&gt; _obj.myParentRole then
			return true;
		endif;
	endif;

	return false;
end;</source>
        <Parameter name="_obj" type="CM_SecurityRole"/>
        <Parameter name="_row" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="populateForm" id="1c08a371-55c2-4d36-a07c-75fe627d277d">
        <updating/>
        <source>populateForm(obj: Object; isNew: Boolean) updating;
// ---------------------------------------------------------------------------
// Created:     27 March 2001 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	role	: CM_SecurityRole;
	permObj	: CM_PermissionObject;

begin
	
	role := obj.CM_SecurityRole;
	
	if role &lt;&gt; null then
		sharedLock(role);
		self.objectEdition := role.edition;
	else
		self.objectEdition := 0;
	endif;

	if role &lt;&gt; self.myPlaceHolderObject then
		if self.allRootRoles.includes(role) or role.myParentRole = null then
			self.myPermissionAgent.setPermissionValuesFromRole(role, role);
		else
			self.myPermissionAgent.setPermissionValuesFromRole(role, role.myParentRole);
		endif;
		
		if self.viewMode = ViewSystem then
			self.setSheetsForPermission(role, self.myPermissionAgent.allSystemCategoriesForRole);
		else
			self.setSheetsForPermission(role, self.myPermissionAgent.allTerminalCategoriesForRole);
		endif;
	endif;

	if fldPermissions.topSheet &lt;&gt; shtRoleDefn then
		if fldPermissions.topSheet = shtUsers then
			self.loadDataTableForUsers( self.tblPermUsers );
		else
			self.fillTableForCategory(fldPermissions.topSheet.caption);
		endif;
	endif;
	
epilog
	if role &lt;&gt; null then
		unlock(role);
	endif;
end;</source>
        <Parameter name="obj" type="Object"/>
        <Parameter name="isNew" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setColorsFromController" id="5f71b2e6-a2bd-4ace-b07d-a758523b8399">
        <updating/>
        <source>setColorsFromController(_colorControl: CM_ColorController) updating;
// ---------------------------------------------------------------------------
// Created:     02 December 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------
// 21/03/2018	jlgdap1		TFS 37445 PEL1 Voyage Status Security
// 23/09/2022   navds20 	ChangeRequest 54253: EUP - VAS Work Orders
vars
	tmpBackColor	: Integer;
begin
	inheritMethod(_colorControl);

	tmpBackColor := self.backColor;
	
	self.shtPermCat1.backColor	:= tmpBackColor;
	self.shtPermCat10.backColor	:= tmpBackColor;
	self.shtPermCat11.backColor	:= tmpBackColor;
	self.shtPermCat12.backColor	:= tmpBackColor;
	self.shtPermCat13.backColor	:= tmpBackColor;
	self.shtPermCat14.backColor	:= tmpBackColor;
	self.shtPermCat15.backColor	:= tmpBackColor;
	self.shtPermCat2.backColor	:= tmpBackColor;
	self.shtPermCat3.backColor	:= tmpBackColor;
	self.shtPermCat4.backColor	:= tmpBackColor;
	self.shtPermCat5.backColor	:= tmpBackColor;
	self.shtPermCat6.backColor	:= tmpBackColor;
	self.shtPermCat7.backColor	:= tmpBackColor;
	self.shtPermCat8.backColor	:= tmpBackColor;
	self.shtPermCat9.backColor	:= tmpBackColor;
	self.shtReports.backColor	:= tmpBackColor;
	self.shtRoleDefn.backColor	:= tmpBackColor;
	self.shtStopsMaint.backColor:= tmpBackColor;
	self.shtStopsCancel.backColor:= tmpBackColor;		// cnwdad1 03/06/2010 - CCMS 1129.
	self.shtStopsView.backColor	:= tmpBackColor;
	self.shtToDoTasks.backColor	:= tmpBackColor;
	self.shtUsers.backColor		:= tmpBackColor;
	self.shtTransactions.backColor:= tmpBackColor;	
	self.shtStatus.backColor 	:= tmpBackColor;				// TFS 37445
	self.shtInvoiceStatus.backColor := tmpBackColor; // TFS 39618	
	self.shtworkOrderStatus.backColor := tmpBackColor; //23/09/2022 navds20 TFS 54253
	self.shtVolDiscReasons.backColor := tmpBackColor;			// 29/4/19 MAP TFS41707
	self.shtEventTypes.backColor := tmpBackColor;	//09 Mar 2020	NDL	TFS 48784
	
	self.setColorsForEntryTable(self.tblInput);
	self.setColorsForTable(self.tblPermissions);
	self.setColorsForTable(self.tblPermUsers);

end;</source>
        <Parameter name="_colorControl" type="CM_ColorController"/>
    </JadeMethod>
    <JadeMethod name="setControlsForAddEdit" id="5152b80d-ef6c-4024-9f06-1a5e5f7b86c0">
        <updating/>
        <source>setControlsForAddEdit() updating;
// ---------------------------------------------------------------------------
// Created:     28 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 21/03/2018	jlgdap1		TFS 37445 PEl1 Voyage Status Security
// 23/09/2022 	navds20 	ChangeRequest 54253: EUP - VAS Work Orders
// ---------------------------------------------------------------------------
vars
	tmpSheet	: Sheet;
begin

	tmpSheet := self.fldPermissions.topSheet;

	self.tblInput.userInputEnabled := true;
	self.tblPermissions.userInputEnabled:= true;
	self.tblPermUsers.userInputEnabled 	:= true;
	self.btnSelectAll.enabled   	:= true;
	self.btnUnselectAll.enabled 	:= true;
	self.mulToDoTasksAdd.readOnly 	:= false;
	self.mulToDoTasksComp.readOnly 	:= false;
	self.mulStopsMaint.readOnly 	:= false;
	self.mulStopsDelete.readOnly 	:= false;		// cnwdad1 03/06/2010 - CCMS 1129.
	self.mulStopsView.readOnly 		:= false;
	self.mulReports.readOnly		:= false;
	self.mulTransType.readOnly 		:= false;
	self.mulStatusMaint.readOnly	:= false;			// TFS 37445
	self.mulInvoiceStatus.readOnly 	:= false; // TFS 39618	
	self.mulVolDescReasons.readOnly	:= false;			// 30/4/19 MAP TFS41707
	self.mulWorkOrderStatus.readOnly :=false; //23/09/2022 navds20 TFS 54253
	self.btnAllowAll.enabled := true;
	self.btnDisallowAll.enabled := true;
	self.mulEventTypes.readOnly		:= false;	//09 Mar 2020	TFS 48784
		
	if self.mode = Mode_Add then
		self.tblInput.clearValues;
		
		// sgp 18 June 2003 : Default to all permissions off for a new role
		self.myPermissionAgent.setAllPermissionValues(false);
	
		fldPermissions.topSheet := shtRoleDefn;
		self.tblInput.moveFirst;
		self.tblInput.setFocus;
	else
		mulToDoTasksAdd.setSelected(self.myProxyObject.CM_SecurityRole.allToDoTasksAddRemove);
		mulToDoTasksComp.setSelected(self.myProxyObject.CM_SecurityRole.allToDoTasksComplete);
		self.fldPermissions.topSheet := tmpSheet;
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="setControlsForView" id="56caba81-4843-47ae-b279-c000074a3f5c">
