							_addToRTQ:Boolean; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:		October  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
begin

	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// DVB added 30/05/2005
	app.initialiseForStartAutoPlan(_passport);
	
	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(false);

	beginTransaction;

	app.myUtilityUA.utlUpdateYardInternalDelivery(_proxyJob, _passport);
	if _passport.noErrors then
		app.myUtilityUA.utlUpdateYardDeliveryRequest(_proxyReq, _addToRTQ, _passport);
	endif;	

epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
