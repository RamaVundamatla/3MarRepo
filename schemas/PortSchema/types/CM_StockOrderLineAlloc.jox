    <JadeMethod name="allocQuantity" id="87dd521c-09f2-460b-965b-db0929098d9e">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <source>allocQuantity(set: Boolean; _value: Decimal io) updating, mapping;
//--------------------------------------------------
// Created:	08 July 2004 By: cnwgd1
//--------------------------------------------------
vars

begin
	if (not set) and self.allocType = self.AllocType_Remaining then
		_value := self.mySOHLocation.calAvailableVolumeForStkOrder(self.myStockOrderLine, true);		
	else
		inheritMethod(set, _value);
	endif;
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Decimal" usage="io"/>
    </JadeMethod>
    <JadeMethod name="erase" id="c942526b-13f0-4578-92a2-337550edfdc0">
        <updating/>
        <source>erase(_eraseLevel: Integer) updating;
//--------------------------------------------------------------
//Created: 10 September 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	allocation 		: CM_StockOrderAllocation;
	summaryAlloc 	: CM_StockOrderSummaryAlloc;
	amtAlloc		: Real;
begin
	
	// Locate the associated summary. 
	// Erase summary if remaining quantity to allocate is zero.
	summaryAlloc := self.getSummaryAllocation();
	if summaryAlloc &lt;&gt; null then
		amtAlloc := summaryAlloc.allocQuantity;
		if amtAlloc - self.allocQuantity &lt;= 0 then
			delete summaryAlloc;
		else
			summaryAlloc.updateAllocQuantity(amtAlloc - self.allocQuantity);
		endif;
	endif;
	
	inheritMethod(_eraseLevel);

end;</source>
        <Parameter name="_eraseLevel" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getExtraInfoLogVoyOps" id="b924d23e-daaa-4432-b489-6883c22436e4">
        <source>getExtraInfoLogVoyOps(_array: HugeStringArray input; _terminalForTerminology : CM_Terminal);
//--------------------------------------------------------------
//Created: 07 August 2002 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	inheritMethod(_array,_terminalForTerminology);
	
	if self.myStockOrderLine &lt;&gt; null then
		self.myStockOrderLine.getExtraInfoLogVoyOps(_array,_terminalForTerminology);
	endif;
end;</source>
        <Parameter name="_array" type="HugeStringArray" usage="input"/>
        <Parameter name="_terminalForTerminology" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="getSummaryAllocation" id="cff6816d-8dc5-4c08-a5a5-100a60f2db0a">
        <source>getSummaryAllocation() : CM_StockOrderSummaryAlloc;
//--------------------------------------------------------------
//Created: 22 November 2002 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	
	// Protect against invalid data for Garbage Collection.
	if self.myStockOrderLine.myStockOrderSummary &lt;&gt; null then
		return self.myStockOrderLine.myStockOrderSummary.getSummaryAllocationObject(self.mySOHLocation);
	endif;
	return null;

end;</source>
        <ReturnType type="CM_StockOrderSummaryAlloc"/>
    </JadeMethod>
    <JadeMethod name="myParent" id="8ea65022-4507-4e15-a302-d4d04f952707">
        <methodInvocation>mapping</methodInvocation>
        <source>myParent(set: Boolean; _value: CM_StockOrderObject io) mapping;
// ---------------------------------------------------------------------------
// Created:     02 August 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if set then
		app.raiseSetVirtualError(class.name, method.name);
		return;
	endif;
	
	_value := self.myStockOrderLine;

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="CM_StockOrderObject" usage="io"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="1f836018-d725-4f7b-9618-6c683eeac35e">
        <updating/>
        <source>setForUpdate(_pxyAllocation : CM_StockOrderLineAlloc) updating;
//--------------------------------------------------------------
//Created: 26 July 2002 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	inheritMethod(_pxyAllocation);
	
	if (not _pxyAllocation.myStockOrderLine.isTransient) then
		self.myStockOrderLine 	:= _pxyAllocation.myStockOrderLine;
		self.myStockOrderHeader	:= _pxyAllocation.myStockOrderLine.myStockOrderHeader;			
	endif;
end;</source>
        <Parameter name="_pxyAllocation" type="CM_StockOrderLineAlloc"/>
    </JadeMethod>
    <JadeMethod name="setFromCMIF_StockOrderAlloc" id="02d05614-98bb-4ec8-ab6c-e40523c3d38a">
        <updating/>
        <source>setFromCMIF_StockOrderAlloc(_cmif: CMIF_StockOrderAllocation) updating;
//--------------------------------------------------------------
//Created: 06 September 2002 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	inheritMethod(_cmif);
	self.myStockOrderLine 	:= _cmif.myLogStockOrderLine;	
	self.myStockOrderHeader	:= _cmif.myLogStockOrderLine.myStockOrderHeader;		
	self.myStockOrderSummaryAlloc := _cmif.mySummaryAllocation;
end;</source>
        <Parameter name="_cmif" type="CMIF_StockOrderAllocation"/>
    </JadeMethod>
    <JadeMethod name="setMyStockOrderLine" id="9bff7696-a9d5-4e78-838f-7fef2489c25b">
        <updating/>
        <source>setMyStockOrderLine(_orderLine : CM_StockOrderProductLine) updating;

// cnwdvb1 23 October 2002 

vars

begin	

	self.myStockOrderLine := _orderLine;

end;</source>
        <Parameter name="_orderLine" type="CM_StockOrderProductLine"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="eaec1d0d-512f-456d-b83e-9cd3b0619204">
        <updating/>
        <source>setProxy(_allocQuantity : Real;
         _allocTypeStr : String;
		 _locnController : CM_LocationsController;
		 _sohLocation : CM_SOHLocation;
		 _stockOrderLine : CM_StockOrderProductLine) updating;
//--------------------------------------------------------------
//Created: 26 July 2002 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	self.setProxyForAllocation(_allocQuantity, _allocTypeStr, _locnController, _sohLocation);
	self.myStockOrderLine := _stockOrderLine;
end;</source>
        <Parameter name="_allocQuantity" type="Real"/>
        <Parameter name="_allocTypeStr" type="String"/>
        <Parameter name="_locnController" type="CM_LocationsController"/>
        <Parameter name="_sohLocation" type="CM_SOHLocation"/>
        <Parameter name="_stockOrderLine" type="CM_StockOrderProductLine"/>
    </JadeMethod>
    <JadeMethod name="validateMe" id="2d2fc96f-8ee1-487f-b41a-ca2d80836c7c">
        <source>validateMe() protected;
//--------------------------------------------------------------
//Created: 26 July 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	tmpProduct,
	tmpSOHProduct : CM_Product;
	tmpLotIDs,
	tmpSummaryID,
	tmpOrderIDs : String;
begin
	inheritMethod();
	if self.myStockOrderLine = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Stock Order Line', 'stockOrderLine', null);
		app.raiseCMException(Input_required_field_stckOrLne, 'stockOrderLine', null); // cnwdb2	PAR 35364
	endif;
	if self.myStockOrderLine &lt;&gt; null then
		tmpProduct := self.myStockOrderLine.myProduct;
		if self.mySOHLocation &lt;&gt; null then
			tmpSOHProduct := self.mySOHLocation.myProduct;		
			if tmpProduct &lt;&gt; tmpSOHProduct then
				app.raiseCMWarning2(ProductInconsistancyWarning, tmpProduct.getDisplayStringForAttribute(ETRow_OperatorCode, true) &amp; ' ' &amp; tmpProduct.code,
									tmpSOHProduct.getDisplayStringForAttribute(ETRow_OperatorCode, true) &amp; ' ' &amp; tmpSOHProduct.code, app.getErrorString(Product), null, tmpProduct);
			endif;
		endif;
		if not self.mySOHLocation.canAllocateToOrder(self, false, self.allocType) then
			self.mySOHLocation.getAllocatedLotAndSummaryIDs(tmpLotIDs, tmpSummaryID);
			if tmpLotIDs &lt;&gt; null then
				tmpOrderIDs := '(Order: ' &amp; tmpLotIDs &amp; ' )';
			else
				tmpOrderIDs := '(Order: ' &amp; tmpSummaryID &amp; ' )';
			endif;		
			app.raiseCMException3(ERR_CANNOT_ALLOCATE, self.mySOHLocation.myLocationsController.getID,
								  self.myStockOrderLine.dischargePort, tmpOrderIDs,
								  ETRow_Location, null);		
		endif;
		self.myStockOrderLine.validateAllocation(self.allocQuantity);		
	endif;	
end;</source>
        <access>protected</access>
    </JadeMethod>
</Class>
