    <JadeMethod name="initFromUserWindow" id="f7d95ab7-931f-4288-8a2d-d6762c383039">
        <updating/>
        <source>initFromUserWindow(_userWindow: CM_UserWindow) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 April 2021	navndl1	Initial creation	TFS 	51045

*/

vars

	xml : String;

begin

	inheritMethod(_userWindow);
	
	xml := _userWindow.xmlInfo.cnEcGetTagValueOfName(self.tblBookings.XMLTag_Table &amp; self.tblBookings.name);
	if xml &lt;&gt; null then
		self.xmlStrTblText := global.formatAsXMLPrefix(self.tblBookings.XMLTag_Table &amp; self.tblBookings.name) &amp; 
								  xml &amp;
								  global.formatAsXMLSuffix(self.tblBookings.XMLTag_Table &amp; self.tblBookings.name);
	endif;

epilog

end;</source>
        <Parameter name="_userWindow" type="CM_UserWindow"/>
    </JadeMethod>
