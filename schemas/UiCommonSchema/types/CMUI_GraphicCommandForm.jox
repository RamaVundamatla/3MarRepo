    <JadeMethod name="doBtnTBAddClick" id="de498df0-7f65-4496-863e-1c29bcc58694">
        <source>doBtnTBAddClick();
// ---------------------------------------------------------------------------
// Created:		November 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	mtLine : String;
	theReturn,theRow, b, idx : Integer;
begin
	if self.cmbGraphics.listIndex &lt; 1 then
		return;
	endif;
	mtLine := Tab &amp; ""  &amp; Tab &amp; ""  &amp; Tab &amp; 0.String &amp; Tab &amp; 0.String &amp; Tab &amp;  0.String &amp; Tab &amp; 0.String &amp; Tab &amp; "";
	
	if self.tblDim.row &gt; self.tblDim.fixedRows then
		b := self.tblDim.row + 1;
		idx := b;
		mtLine := b.String &amp; mtLine;
		self.tblDim.addItemAt(mtLine, b);
	else
		b := self.tblDim.rows - self.tblDim.fixedRows + 1;
		mtLine := b.String &amp; mtLine;
		idx := self.tblDim.addItem(mtLine);
	endif;
	self.doSetInputTypeInTable(idx);
	self.tblDim.accessCell(idx,self.COLUMN_COLOUR).backColor := Black;
	self.tblDim.accessCell(idx,self.COLUMN_FILL).backColor := Black;
/*
	self.tblDim.accessCell(idx,self.COLUMN_TYPE).cellControl := self.cmbType;
	self.tblDim.accessCell(idx,self.COLUMN_LABEL).cellControl.TextBox.selectionStyle := TextBox.SelectionStyle_SelectAll;
	self.tblDim.accessCell(idx,self.COLUMN_Y1).cellControl.TextBox.selectionStyle := TextBox.SelectionStyle_SelectAll;
	self.tblDim.accessCell(idx,self.COLUMN_X2).cellControl.TextBox.selectionStyle := TextBox.SelectionStyle_SelectAll;
	self.tblDim.accessCell(idx,self.COLUMN_Y2).cellControl.TextBox.selectionStyle := TextBox.SelectionStyle_SelectAll;
*/
	self.doRenumberTable();

end;</source>
    </JadeMethod>
    <JadeMethod name="doBtnTBDeleteClick" id="dd3d6ef3-e087-4111-a4c6-ccd5a2bce6ff">
        <source>doBtnTBDeleteClick();
// ---------------------------------------------------------------------------
// Created:		November 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

	theReturn,theRow, theX, theY, idx : Integer;
begin
	if self.tblDim.row &gt; self.tblDim.fixedRows then

		theRow := self.tblDim.row;
		theX := self.tblDim.accessCell(theRow,self.COLUMN_X1).text.Integer;
		theY := self.tblDim.accessCell(theRow,self.COLUMN_Y1).text.Integer;
		theReturn := app.msgBox("Remove Command " &amp; (theRow - 1).String &amp; "?", "Remove Confirmation", MsgBox_Yes_No + MsgBox_Question_Mark_Icon);
		if theReturn = MsgBox_Return_Yes then
			self.tblDim.deleteRow(theRow);
			self.doRenumberTable();
		endif;
	endif;
	

end;</source>
    </JadeMethod>
