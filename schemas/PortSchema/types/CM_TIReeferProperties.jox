    <JadeMethod name="setDefrostTemp" id="7ab2b210-84d6-4cf3-bd5b-ab3ac2707945">
        <updating/>
        <source>setDefrostTemp(_dateTime: TimeStamp) updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10/12/2009	cnwdap1	Initial creation
16/09/2010	cnwdap1 PAR #25754 update the edition on the tracked item, as this update otherwise
					does not touch CM_TrackedItem, and the change tracer will otherwise not pick it up
30 Aug 2012	cnwcs5	par 30292 - use updateObjectEdition instead of updateEdition 
*/
vars

begin
	if self.defrostDate &lt;&gt; null and _dateTime = null then 
		self.defrostDate := null; 					// unset defrost date
		
		self.updateObjectEdition(self.myParent);	// par 30292	// PAr #25754
		
	elseif self.defrostDate &lt;&gt; null and _dateTime &lt;&gt; null then	
		// still on defrost do nothing
		
	elseif self.defrostDate = null then
		self.defrostDate := _dateTime;				//set to firstDefost date
		
		self.updateObjectEdition(self.myParent);	// par 30292	// PAr #25754
	endif;
epilog

end;</source>
        <Parameter name="_dateTime" type="TimeStamp"/>
    </JadeMethod>
