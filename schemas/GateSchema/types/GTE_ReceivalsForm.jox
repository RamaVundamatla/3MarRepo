    <JadeMethod name="setFilterValues" id="d24abf29-4c58-48b2-b1bd-0a0b7d2fe17e">
        <updating/>
        <source>setFilterValues() updating;
// ---------------------------------------------------------------------------
// Created:     02 February 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 02 Oct 2020	cnwma1		ChangeRequest 50112: ASPA - GCI Stevedores
// 29 Jun 2022	navdap1		TFS 53362 EUP Master Data Interface Customers Between TOS and ERP
// ---------------------------------------------------------------------------
vars

begin
	self.filterBookingReference := tblSearch.getValueByName(ETRow_FilterBookingRef).String;
	if app.myRoot.getConfig(ComboByNameOperator).Boolean and self.cmbFiltOperator.listObject &lt;&gt; null then	// TFS 53362
		self.filterOperatorCode := self.cmbFiltOperator.listObject.CM_Operator.code;						// TFS 53362
	else																									// TFS 53362
		self.filterOperatorCode	:= tblSearch.getValueByName(ETRow_FilterOperator).String;
	endif;																									// TFS 53362
	if not app.myRoot.getConfig(ComboByNameStevedore).Boolean then											// TFS 53362
		self.filterStevedoreCode	:= tblSearch.getValueByName(ETRow_Stevedore).String;       //02.10.2020 cnwma1 TFS #50112
	endif;																									// TFS 53362
end;</source>
