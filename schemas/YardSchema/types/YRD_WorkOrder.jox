    <JadeMethod name="comboWOToDoTasks" id="4660eca9-c528-47be-8174-5a50535c046e">
        <source>comboWOToDoTasks(_cmb : ComboBox input; _toDoTaskDesc : CM_ToDoTaskDesc);

// navcs2 15/07/2022  ChangeRequest 53932: MTN - Jobs Changes
// navcs2 22/07/2022  Bug 54233
// 08 Feb 2023 navma1 ChangeRequest 56457: EUP - Allowing different sets of cargo items per work order task [Refactor]
vars
	task	: CM_ToDoTaskDesc;
	idx		: Integer;
	ti		: CM_TrackedItem;
begin

	_cmb.clear;
	
	idx := _cmb.addItem("");
	_cmb.itemObject[idx] := null;
	
	//ti := myPxyWorkOrder.CM_WorkOrderTI.allTIs.first;						//08.02.2023 navma1 #56457 Task#56458
	ti   := self.myPxyTask.CM_WorkOrderTIDtl.allSelectedTIs.first;			//08.02.2023 navma1 #56457 Task#56458
	
	// 22/07/2022 navcs2 Bug 54233
	if ti &lt;&gt; null then
		foreach task in app.myRoot.allToDoTaskDescriptions where task.type = TODO_TYPE_GROUP_TI  do  // ### TFS  #56634[54259] 22NOV2022 NAVAB1 do	
			if task.isAvailableForCargoType( ti.cargoType ) then
				idx := _cmb.addItem(task.description);
				_cmb.itemObject[idx] := task;
			endif;
		endforeach;
		
		if _toDoTaskDesc &lt;&gt; null then
			_cmb.listObject := _toDoTaskDesc;
		endif;
	endif;

end;</source>
        <Parameter name="_cmb" type="ComboBox" usage="input"/>
        <Parameter name="_toDoTaskDesc" type="CM_ToDoTaskDesc"/>
    </JadeMethod>
    <JadeMethod name="create" id="387cd40c-4392-4513-b3f2-06cde8a04e80">
        <updating/>
        <executionLocation>client</executionLocation>
        <source>create() updating, clientExecution;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 Mar 2022 navma1 ChangeRequest 52351: MTN - Work Order Maintenance Refactor - UI

*/

vars

begin
	self.permissionView		:= PmAdmWorkOrderEnquiry;
	self.permissionMaint	:= PmAdmWorkOrderEnqMaint;		
	self.helpFileName 		:= HelpFile_Yard;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="createProxyChildren" id="40204a77-495a-46c4-81da-8ab0e27237c2">
        <updating/>
        <source>createProxyChildren() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
08 Apr 2022	navcs2	ChangeRequest 52351: MTN - Work Order Maintenance Refactor - UI
12 Jan 2023	navma1  ChangeRequest 56141: EUP - Refactor and Remove CM_WorkOrderTISource from CM_WorkOrderTI
*/

vars
	id					: Integer;
	prxyWorkORderSource	: CM_WorkOrderTISource;
	totalReq			: Integer;
	tiString			: String;
begin
	if not self.setProxyWorkOrder(self.myPxyWorkOrder) then
		return;
	endif;

	/*
	12.01.2023 navma1 #56141 Task#56147
	if self.workOrderType = WorkOrderMode_Cargo and not myPxyWorkOrder.CM_WorkOrderTI.allTIs.isEmpty then
		id := myPxyWorkOrder.CM_WorkOrderTI.allTIs.first.cargoType;
		tiString := self.myPxyWorkOrder.CM_WorkOrderTI.allTIs.listString(Comma,CM_TrackedItem::id.name);
	endif;
	
		
	if self.workOrderType = WorkOrderMode_Cargo then
		if self.myPxyWorkOrder.CM_WorkOrderTI.mySource = null then
			if self.myPxyWorkOrder.requiresWorkOrderTISource() and self.workOrderMode = self.MODE_ADD then
				prxyWorkORderSource := self.setProxyWorkOrderSource();
			endif;
		else
			if not self.myPxyWorkOrder.CM_WorkOrderTI.mySource.hasNonIDSource() then
				self.myPxyWorkOrder.CM_WorkOrderTI.mySource.setProxy(id, tiString );
				//if self.myPxyWorkOrder.CM_WorkOrderTI.totalRequired = 0 then
				//	totalReq := self.myPxyWorkOrder.CM_WorkOrderTI.mySource.getTotalCargoCount();
				//	self.myPxyWorkOrder.CM_WorkOrderTI.setProxyWorkOrderTIDtl(totalReq);
				//endif;
				
			endif;
		endif;
	endif;	
	*/
	
	if self.myPxyWorkOrder.allWoDtls.isEmpty  and self.workOrderMode = self.MODE_ADD then
		self.setProxyWorkOrderTasks(self.myPxyWorkOrder);
	endif;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="createPxyWorkOrder" id="d4a92555-b42c-413c-8268-2eceb21906be">
        <updating/>
        <source>createPxyWorkOrder() protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 Mar 2022	navma1	ChangeRequest 52351: MTN - Work Order Maintenance Refactor - UI
28 Jul 2022	navcs2	Bug 54319: MTN - Work Order - Export Return task details tab showing as Blank
15 Dec 2022	navcs2	ChangeRequest 56840:[54265] EUP - [Framework] - VAS Work Order Maintenance Sceen
12 Jan 2023	navma1  ChangeRequest 56141:[56147] EUP - Refactor and Remove CM_WorkOrderTISource from CM_WorkOrderTI
11 Mar 2024	navma1  Bug 62810: MTN - Notifications causing updates to combo box in cargo work order
*/


vars
	ls : Boolean;
begin
	app.cmsBeginLoad(ls);
	
	if self.workOrderMode = self.MODE_ADD then
		if self.workOrderType = WorkOrderMode_Cargo then														
			create self.myPxyWorkOrder as CM_WorkOrderTI transient;
			self.myPxyWorkOrder.setTaskStatus(WO_STATUS_USERENTRY);
			self.myPxyWorkOrder.setMyUser(app.myPassport.getUserCode());		//11.03.2023 navma1 #62810

		elseif 	self.workOrderType = WorkOrderMode_Voyage then																								
			create self.myPxyWorkOrder as CM_WorkOrderVoyage transient;	
			self.myPxyWorkOrder.setTaskStatus(WO_STATUS_USERENTRY);				// 28/07/2022	navcs2	Bug 54319
			self.myPxyWorkOrder.setMyUser(app.myPassport.getUserCode());		//11.03.2023 navma1 #62810
		else 
			create self.myPxyWorkOrder as CM_WorkOrderToDo transient;	
			self.myPxyWorkOrder.setTaskStatus(WO_STATUS_PENDING);
			self.myPxyWorkOrder.setMyUser(app.myPassport.getUserCode());		//11.03.2023 navma1 #62810
		endif;																									
	elseif self.workOrderMode = MODE_UPDATE then
		if self.workOrderType = WorkOrderMode_Cargo then														
			self.myPxyWorkOrder := app.createUpdateProxy(self.myWorkOrder).CM_WorkOrderTI;
		elseif self.workOrderType = WorkOrderMode_Voyage then																							
			self.myPxyWorkOrder := app.createUpdateProxy(self.myWorkOrder).CM_WorkOrderVoyage;	
		else
			self.myPxyWorkOrder := app.createUpdateProxy(self.myWorkOrder).CM_WorkOrderToDo;				
		endif;																									
	endif;

epilog			
	app.cmsEndLoad(ls);
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="createResourceUsedPxys" id="588485fa-0fbb-445d-afc3-51bc6eb03ef6">
        <source>createResourceUsedPxys( _table : CM_DataTable input; _resourceUsedSet : HMS_ResourceUsedSet input ):Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
28 April 2022	navgm20	ChangeRequest 52351: MTN - Work Order Maintenance Refactor - UI

*/

vars
	rowIndex : Integer;
	inclColIndex : Integer;
	rtColIndex : Integer;
	rColIndex : Integer;
	uColIndex : Integer;
	fdColIndex : Integer;
	ftColIndex : Integer;
	tdColIndex : Integer;
	ttColIndex : Integer;
	drColIndex : Integer;
	
	resource : HMS_Resource;
	resourceType : HMS_ResourceType;
	wodMarineServiceDet : CM_WodMarineServiceDetail;
	units : Decimal[23,6];
	fromDate : Date;
	fromTime : Time;
	fromTS : TimeStamp;
	toDate : Date;
	toTime : Time;
	toTS : TimeStamp;
	sysFromTS : TimeStamp;
	sysToTS : TimeStamp;
	
	resourceUsed : HMS_ResourceUsed;
	include : Boolean;
	
	drName : String;
	drIndex : Integer;
	debtor: CM_Debtor;
	
	resourceDesc : String;
	resIndex : Integer;
	
	harbour : HMS_Harbour;
	
begin

	harbour := self.myTerminal.myHarbour;
	
	inclColIndex := _table.getColumnByRowName( ETRow_Include );
	rtColIndex := _table.getColumnByRowName( ETRow_MyResourceType );
	rColIndex := _table.getColumnByRowName( ETRow_MyResource );
	uColIndex := _table.getColumnByRowName( ETRow_UnitsUsed );
	fdColIndex := _table.getColumnByRowName( ETRow_FromDate );
	ftColIndex := _table.getColumnByRowName( ETRow_FromTime );
	tdColIndex := _table.getColumnByRowName( ETRow_ToDate );
	ttColIndex := _table.getColumnByRowName( ETRow_ToTime );
	drColIndex := _table.getColumnByRowName( ETRow_Debtor );
	
	if inclColIndex &gt; 0 and rtColIndex &gt;0 and rColIndex &gt;0 and uColIndex &gt; 0 and fdColIndex &gt;0 and ftColIndex &gt;0 and tdColIndex &gt; 0 and ttColIndex &gt;0 and drColIndex &gt;0 then
	
		foreach rowIndex in 1 to _table.rows do
			if rowIndex &lt;= _table.fixedRows then
				continue;
			endif;
			if _table = self.tblResources and self.myPxyTask.isKindOf(CM_WodCargoRequest) then	
				include := true;
			else
				include := _table.accessCell( rowIndex, inclColIndex ).text = "1"; //Selected
			endif;
			if not include then
				continue;
			endif;
			sysFromTS := null;
			sysToTS := null;
			//collect up the raw data
			if rtColIndex &gt; 0 then
				resourceType := _table.accessCell( rowIndex, rtColIndex ).itemObject.HMS_ResourceType;
			else
				resourceType := null;
			endif;
			if _table = self.tblResources and self.myPxyTask.isKindOf(CM_WodCargoRequest) then
				resource := null;
				debtor := null;
			else
				resource := _table.accessCell( rowIndex, rColIndex ).itemObject.HMS_Resource;
			endif;
			wodMarineServiceDet := _table.accessCell( rowIndex, uColIndex ).itemObject.CM_WodMarineServiceDetail;
			units := _table.accessCell( rowIndex, uColIndex ).text.asDecimalJMT;
			fromDate := _table.accessCell( rowIndex, fdColIndex ).text.asDateJMT;
			fromTime := _table.accessCell( rowIndex, ftColIndex ).text.asTimeJMT;
			if fromDate.isValid then
				fromTS.setDate( fromDate );
				fromTS.setTime( fromTime );
				sysFromTS := fromTS.localToSystemTimeUsingObject(self.myTerminal);
			endif;
			toDate := _table.accessCell( rowIndex, tdColIndex ).text.asDateJMT;
			toTime := _table.accessCell( rowIndex, ttColIndex ).text.asTimeJMT;
			if toDate.isValid then
				toTS.setDate( toDate );
				toTS.setTime( toTime );
				sysToTS := toTS.localToSystemTimeUsingObject(self.myTerminal);
			endif;
			
			//26 Nov 2018	NDL	TFS 41980
			if _table = self.tblResources and self.myPxyTask.isKindOf(CM_WodCargoRequest) then
				resourceDesc := _table.accessCell( rowIndex, rColIndex ).text;
				if resourceDesc &lt;&gt; null and resourceType &lt;&gt; null then
					//re-populate teh combo, because it may have been used for something else
					resourceType.getResourcesForCmbList( self.cmbResource, harbour );
					resIndex := self.cmbResource.findStringExact( 1, resourceDesc );
					if resIndex &gt; 0 then
						resource := self.cmbResource.itemObject[resIndex].HMS_Resource;
					endif;
				endif;
				if resource = null then
					app.msgBox( app.getErrorString( Input_require_resourc_field ), app.getErrorString(Error), MsgBox_OK_Only );
					return false;
				endif;
				drName := _table.accessCell( rowIndex, drColIndex ).text;
				if drName &lt;&gt; null then
					drIndex := self.cmbDebtor.findStringExact( 1, drName );
					if drIndex &gt; 0 then
						debtor := self.cmbDebtor.itemObject[drIndex].CM_Debtor;
					endif;
				endif;
				if debtor = null then
					app.msgBox( app.getErrorString1( Debtor_required_resource, resourceDesc ), app.getErrorString(Error), MsgBox_OK_Only );
					return false;
				endif;
			endif;
			
			if resource = null or resourceType = null then
				// should never happen....
				continue;
			endif;
			
			//validation
			if resourceType.isQuantityRequired  and units &lt;= 0 then
				app.msgBox( app.getErrorString1( Input_required_field_untsUsed, resourceType.description), app.getErrorString(Error), MsgBox_OK_Only );
				return false;
			endif;
			if resourceType.isActionDateTimeRequired and sysFromTS = null then
				app.msgBox( app.getErrorString1( Action_date_time_require, resourceType.description), app.getErrorString(Error), MsgBox_OK_Only );
				return false;
			endif;
			if resourceType.isFromToDateTimeRequired and ( sysFromTS = null or sysToTS = null ) then
				if sysFromTS = null then
					app.msgBox( app.getErrorString1( Input_required_field_frmDate, resourceType.description), app.getErrorString(Error), MsgBox_OK_Only );
					return false;
				endif;
				if sysToTS = null then
					app.msgBox( app.getErrorString1( Input_required_field_toDate, resourceType.description), app.getErrorString(Error), MsgBox_OK_Only );
					return false;
				endif;
			endif;
			
			//26 Nov 2018	NDL	TFS 41980
			if _table = self.tblResources and self.myPxyTask.isKindOf(CM_WodCargoRequest) and wodMarineServiceDet &lt;&gt; null then
				// This is either a Permit type with cargo details and marinve service deatils or a Voyage Cargo type with the same.
				wodMarineServiceDet.setProxyBaseValues(	sysFromTS,	//_fromDateTime : TimeStamp;
														sysToTS,	//_toDateTime : TimeStamp;
														units.Real,	//_unitsUsed : Real;
														resourceType,	//_myResourceType : HMS_ResourceType;
														resource,	//_myResource : HMS_Resource;
														debtor	//_myDebtor : CM_Debtor
														);
			
			else
				//proxy create
				create resourceUsed transient;
				resourceUsed.setUnitsUsed( units.Real );
				resourceUsed.setDetailsFromWorkOrder( sysFromTS, sysToTS );
				resourceUsed.setMyResource( resource );
				_resourceUsedSet.add( resourceUsed );
			
			endif;
			
		endforeach;
	endif;
	return true;
epilog

end;</source>
        <Parameter name="_table" type="CM_DataTable" usage="input"/>
        <Parameter name="_resourceUsedSet" type="HMS_ResourceUsedSet" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="displayResources" id="17a483e7-25c4-466f-8911-f294747e3c21">
        <source>displayResources(ta:CM_WorkOrderDtl);
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
25 April 2022	navhl20	ChangeRequest 52351: MTN - Work Order Maintenance Refactor - UI

*/

vars
	voy : CM_Voyage;
	processHarbour : CM_ProcessHarbour;		
	resources: HMS_ResourceByTypeDict;	
	harbour : HMS_Harbour;
	voyageStatus : CM_VoyageStatus;
begin
	voy := self.myVoyage;
	harbour := self.myTerminal.myHarbour;
	
	if ta.isKindOf(CM_WodShiftMovement) then
		if voy &lt;&gt; null and voy.myVoyageProcess &lt;&gt; null and harbour &lt;&gt; null then
			processHarbour := voy.myVoyageProcess.allProcessHarbours[voy.myVoyageProcess, harbour];	
			if processHarbour &lt;&gt; null then
				resources := processHarbour.allHMSResourcesForShift;											
			endif;
			self.popTblResourcesForShift( self.tblResources, ta.CM_WodShiftMovement, null, resources);
			if ta.CM_WodShiftMovement.isComplete then
				self.tblResources.enabled := false;
			endif;
		endif;
	elseif ta.isKindOf(CM_WodCargoRequest) then
		if harbour &lt;&gt; null then
			self.popTblResourcesCrV3( self.tblResources, ta.CM_WodCargoRequest, harbour );
			if ta.CM_WodCargoRequest.isComplete then
				self.tblResources.enabled := false;
			endif;
		endif;
	elseif ta.isKindOf(CM_WodExtension) then
		if voy &lt;&gt; null and voy.myVoyageProcess &lt;&gt; null then
			processHarbour := voy.myVoyageProcess.allProcessHarbours[voy.myVoyageProcess, harbour];
			if processHarbour &lt;&gt; null then 
				resources := processHarbour.allHMSResourcesForExt;									
				self.popTblResourcesForShift( self.tblResources, null, ta.CM_WodExtension, resources);		
				if ta.CM_WodExtension.isComplete then
					self.tblResources.enabled := false;
				endif;
			endif;
		endif;
	elseif ta.isKindOf(CM_WodMarineServicesDepart) then
		if voy &lt;&gt; null and voy.myVoyageProcess &lt;&gt; null then
			if voy.myVoyageProcess.isMTNWOProcess then 
				voyageStatus := voy.myVoyageProcess.allStatusesById[ Voyage_Status_DepServPending ];
			endif;
			self.popTblResources( self.tblResources, ta.CM_WodMarineServicesDepart, voyageStatus );
			if ta.CM_WodMarineServicesDepart.isComplete then
				self.tblResources.enabled := false;
			endif;
		endif;
	elseif ta.isKindOf(CM_WodMarineServicesInitial) then
		if voy &lt;&gt; null and voy.myVoyageProcess &lt;&gt; null then
			if voy.myVoyageProcess.isMTNWOProcess then
				voyageStatus := voy.myVoyageProcess.allStatusesById[ Voyage_Status_ServicesPending ];		
			endif;
			self.popTblResources( self.tblResources, ta.CM_WodMarineServicesInitial, voyageStatus );
			if ta.CM_WodMarineServicesInitial.isComplete then
				self.tblResources.enabled := false;
			endif;
		endif;
	endif;
epilog

end;</source>
        <Parameter name="ta" type="CM_WorkOrderDtl"/>
    </JadeMethod>
    <JadeMethod name="displayTasks" id="03dadaf8-1704-4cb1-a7db-09968086a960">
        <source>displayTasks(_newTask : CM_WorkOrderDtl) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
30 March 2022	navma1	ChangeRequest 52351: MTN - Work Order Maintenance Refactor - UI

*/

vars
	cargoRequest : CM_WodCargoRequest;
	wodtl 		: CM_WorkOrderDtl;
	idx,
	pos 		: Integer;
	
begin
	self.lstTasks.clear();
	
	foreach wodtl in self.myPxyWorkOrder.allWoDtls do
		pos := pos + 1;
		self.lstTasks.addObjectAt(wodtl.getDisplayString(true), pos, wodtl, 1, false);
	
		if wodtl.isKindOf(CM_WodPermitRequest) then
			if wodtl.CM_WodPermitRequest.permitType = INV_WO_PERMIT_CARGOPENALTY 
			or wodtl.CM_WodPermitRequest.permitType = INV_WO_PERMIT_CARGONOPENALTY then

				foreach cargoRequest in wodtl.CM_WodPermitRequest.allCargoDetails do
					idx := self.lstTasks.addItem(cargoRequest.getDisplayString(false));
					self.lstTasks.itemObject[idx]:= cargoRequest;
				endforeach;
				
			endif;
		endif;
	endforeach;
	
	if _newTask &lt;&gt; null then
		self.lstTasks.listObject := _newTask;
		self.lstTasks.selectObject(_newTask);
		self.lstTasks.click(self.lstTasks);
		
	else
		if self.lstTasks.listCount &gt; 0 then
			self.lstTasks.listIndex := 1;
			self.lstTasks.click(self.lstTasks);		 
		endif;
	endif;
	
	//self.enableTaskActions();
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_newTask" type="CM_WorkOrderDtl"/>
    </JadeMethod>
    <JadeMethod name="displayVoyageCombo" id="f3aca22c-a33d-454b-b53f-acb3463c4f10">
        <source>displayVoyageCombo() protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		 Reason
23 Apr 2022	navhl20	 ChangeRequest 52351: MTN - Work Order Maintenance Refactor - UI
04 Aug 2022 navtnr20 Bug 54347: MTN - Voyage Work Orders - When selecting any task the voyage gets disappeared
20 Feb 2023 navma1   Bug 56605: MTN - Cancelled voyages in voyage work orders issues and proxy deletion issues on exceptions
*/

vars
	voyage  : CM_Voyage;
	str 	: String;
begin
	
	if self.myVoyage &lt;&gt; null then
		voyage := self.myVoyage;
	elseif self.myPxyTask &lt;&gt; null then
		voyage := self.myPxyTask.getMyVoyageObject;
	elseif self.myWorkOrder.getMyVoyageObject &lt;&gt; null then
		voyage := self.myWorkOrder.getMyVoyageObject;
	endif;
	
	
	if voyage &lt;&gt; null and self.cmbVoyageDetails.findObject(voyage) = -1  then					//20.02.2023 navma1 #56605
		str := voyage.code &amp; Tab &amp; voyage.description;
		self.cmbVoyageDetails.itemObject[self.cmbVoyageDetails.addItem(str)] := voyage;
	endif;
	
	self.cmbVoyageDetails.listObject := voyage;
	self.cmbVoyageDetails.enabled 	 := false;
	
	if voyage &lt;&gt; null then
		self.txtVoyageExtCode.text := voyage.voyageCodeExternal;
	endif;
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="displayWorkOrderToDoTasks" id="ca457a42-d6e0-4225-8aff-550cea0e6e06">
        <source>displayWorkOrderToDoTasks(_wodDtl : CM_WorkOrderTIDtl);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 May 2022	navcs2	ChangeRequest 52351: MTN - Work Order Maintenance Refactor - UI
*/

vars
	todoSet : CM_ToDoTaskDescSet;
begin
	
	if not _wodDtl.allToDoRequests.isEmpty then
		create todoSet transient;
		_wodDtl.getAllToDoTaksDescsUsed( todoSet );
		self.mulToDoTasks.setSelected( todoSet );
	endif; 
	
epilog
	delete todoSet;
end;</source>
        <Parameter name="_wodDtl" type="CM_WorkOrderTIDtl"/>
    </JadeMethod>
    <JadeMethod name="doAddUserEmail" id="30e089fe-5e67-4b5f-8747-e78a96b21792">
        <source>doAddUserEmail();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 Mar 2022 navma1  CangeRequest 52351: MTN - Work Order Maintenance Refactor - UI
17/07/2022	navcs2	ChangeRequest 53932: MTN - Jobs Changes
15 Feb 2023 navma1  ChangeRequest 56561: FR 53944 | EUP - Simplified Voyage Work Order
*/

vars
	user : CM_User;
	email : CM_EmailEntity;
begin

	user := app.getMyUser();		
	
	if  user.myEmailEntity &lt;&gt; null then															//16.12.2022 navma1 #54234
		if not self.myEmailController.allToAddresses.includes( user.myEmailEntity )  then
			self.myEmailController.allToAddresses.add( user.myEmailEntity );
			self.txtEmail.text := myPxyWorkOrder.allEmailAddresses.String;
		endif;
	endif;
	
	// TFS 53932 NAVCS2 15/07/2022
	foreach email in myPxyWorkOrder.allEmailAddresses do 
		if not self.myEmailController.allToAddresses.includes( email ) then
			self.myEmailController.allToAddresses.add(email);
		endif;
	endforeach;
	
	self.txtEmail.text := myPxyWorkOrder.getEmailsString;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doBaseFormSave" id="06268681-dbba-4b2a-8f83-69911fa15aac">
        <updating/>
        <source>doBaseFormSave() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 Apr 2022	navcs2	ChangeRequest 52351: MTN - Work Order Maintenance Refactor - UI
12 Jan 2023	navma1  ChangeRequest 56141: EUP - Refactor and Remove CM_WorkOrderTISource from CM_WorkOrderTI
26 Mar 2024	navpw1	TFS: 62849 (62927) - Reverted Code by changing call to trxUpdateWorkOrder

*/

vars
	newWorkOrder		: CM_WorkOrder;
	ls					: Boolean;
	result				: Integer;
	task			: CM_WorkOrderDtl;
begin
	if not self.doSaveTask() then
		return;
	endif;
	self.createProxyChildren();

	while true do
		if self.workOrderMode = self.MODE_ADD then
			app.myTrxCA.trxCreateWorkOrder(self.myPxyWorkOrder, newWorkOrder, app.myPassport);			//12.01.2023 navma1 #56141 Task#56147
		elseif self.workOrderMode = self.MODE_UPDATE then
			app.myTrxUA.trxUpdateWorkOrder(self.myPxyWorkOrder, true, app.myPassport);					//12.01.2023 navma1 #56141 Task#56147
		elseif self.workOrderMode = self.MODE_UPDATECOMPLETED then
			app.myTrxUA.trxUpdateCompletedWorkOrder(self.myPxyWorkOrder, app.myPassport); 				//13/11/2024	navkc1 JIRA Story MTN-33012 Allow user to update certain fields for a completed work order
		endif;

		if app.myPassport.trxCompletedOK then
			self.clearErrorWarnings();
			self.workOrderMode := self.MODE_VIEW;
			if self.myWorkOrder = null then
				self.myWorkOrder := newWorkOrder;
			endif;
			self.modalResult := IDOK;
			self.unloadForm();
			return;
		else
			result := app.showErrorWarningDialog(self.caption, app.myPassport, ErrWarnMode_Add + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);
		endif;
		
		return;
	endwhile;

epilog
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doBtnAddCargo" id="068c4ef1-6f1a-4e22-b2b1-d33df597db5e">
        <updating/>
        <source>doBtnAddCargo(isPackChild: Boolean) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 Mar 2022 navma1 	ChangeRequest 52351: MTN - Work Order Maintenance Refactor - UI
23 May 2022	NAVCS2 	ChangeRequest 52351: MTN - Work Order Maintenance Refactor - UI
12 Jan 2023	navma1  ChangeRequest 56141: EUP - Refactor and Remove CM_WorkOrderTISource from CM_WorkOrderTI
08 Feb 2023 navma1  ChangeRequest 56457:[56458] EUP - [Refactor] - Allowing different sets of cargo items per work order task
27 Jan 2023	navhl20	ChangeRequest 55443:[54991] EUP - Receive Cargo Work Order - Enhancements
17 Apr 2023 navhl20 ChangeRequest 57322:[57323] EUP - VAS Task linked with Receive Cargo work Order
07 Jun 2023 navhl20 Bug 58520: MTN - WO - 1090 exception when clicking on Add Child Items button on the Pack Work Order
04 Jul 2023	navma1	Bug 58952: MTN - Unable to add the tracked item when using the Export Booking for Release Cargo Work Order
*/

vars
	tiArray			: CM_TIArray;
	ti     			: CM_TrackedItem;
	releaseRequest	: CM_ReserveDetail;
	bookingItem		: CM_BookingRefItem;
	bol 			: CM_BOL;		
	cargoType		: CM_CargoType;
	voyage			: CM_Voyage;
begin
	create tiArray transient;
	
	self.doSaveCargoProxy();	//24.01.2023 navma1 #56141 Task#56147
	
	if myPxyTask.isKindOf(CM_WodRelease) then
		if self.cmbReleaseRequest.listObject &lt;&gt; null then
			releaseRequest := myPxyTask.CM_WodRelease.getMyReleaseRequest.allReserveDetails.first;
		elseif self.cmbBookingItem.listObject &lt;&gt; null then										//04.07.2023 navma1 #58952
			bookingItem := self.cmbBookingItem.listObject.CM_BookingRefItem;					//04.07.2023 navma1 #58952
			cargoType	:= bookingItem.myCargoType;												//04.07.2023 navma1 #58952
		endif;
	
	elseif myPxyTask.isKindOf(CM_WodReceive) then
		if self.cmbBooking.listObject &lt;&gt; null  then												//17.4.2023 navhl20 #57322[57323]
			if self.cmbBookingItem.listObject &lt;&gt; null then
				bookingItem := myPxyTask.CM_WodReceive.myBookingRefItem;
				cargoType   := bookingItem.myCargoType;											//04.07.2023 navma1 #58952
			else
				bookingItem := myPxyTask.CM_WodReceive.myBookingRef.allBookingRefItems.first;
				cargoType   := bookingItem.myCargoType;											abortTransaction;
			endif;
		else 
			voyage := myPxyTask.CM_WodReceive.myVoyage;
			bol    := myPxyTask.CM_WodReceive.myBillOfLading;				
		endif;
	endif;
	
	if self.myPxyWorkOrder &lt;&gt; null and self.isPackItems &lt;&gt; true then

		foreach ti in self.myPxyTask.CM_WorkOrderTIDtl.allSelectedTIs do    //08.02.2023 navma1 #56457[56458]
			tiArray.add(ti);
		endforeach;
	elseif self.myPxyTask &lt;&gt; null then
		foreach ti in self.myPxyTask.CM_WodPack.allPackingTIs do
			tiArray.add(ti);
		endforeach;
	endif;
		
	if isPackChild = true then
		cargoType := self.getMyTerminal.getCargoTypeFromAbbrevOrDescr(self.getMyTerminal.defaultCargoType.String);
		if myPxyTask.isKindOf(CM_WodPack)																	//18.4.2023 navhl20 #55442[57629]
		and self.myPxyTask.CM_WodPack.myReleaseRequest &lt;&gt; null	then										//7.6.2023 navhl20 #58520
			releaseRequest := self.myPxyTask.CM_WodPack.myReleaseRequest.allReserveDetails.first;
		endif;
	else
		if myPxyTask.isKindOf(CM_WodPack) or myPxyTask.isKindOf(CM_WodUnpack) then							//06.03.2023 navma1 #56457:[56458]
			cargoType := self.getMyTerminal.getCargoTypeFromAbbrevOrDescr("ISO CONTAINER");
			if myPxyTask.isKindOf(CM_WodPack)																//18.4.2023 navhl20 #55442[57629]
			and self.myPxyTask.CM_WodPack.myReleaseRequest &lt;&gt; null	then									//7.6.2023 navhl20 #58520
				releaseRequest := self.myPxyTask.CM_WodPack.myReleaseRequest.allReserveDetails.first;
			endif;
		endif;
	endif;
	
	self.myAssistant.showCargoSearchForm(self, 
										null, 
										tiArray, 
										bookingItem,
										releaseRequest,
										cargoType,
										voyage,bol,				//17.4.2023 navhl20 #57322[57323]
										self.myPxyTask);  		//13.03.2023 navma1 #56457:[56458]
	
epilog
	delete tiArray;
end;</source>
        <Parameter name="isPackChild" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doBtnCancel" id="7d8b38e4-feb6-4ae3-ab19-4d4757f2475d">
        <updating/>
        <source>doBtnCancel()	updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 Mar 2022 navma1  ChangeRequest 52351: MTN - Work Order Maintenance Refactor - UI
05 Oct 2023 navhl20 Bug 60373: MTN - Expected to see a validation message to save the changes before closing the work order form.
*/

vars
	close : Boolean;
begin
	close := self.doCancel();					//05.10.2023 navhl20 #60373
	
	if close then								//05.10.2023 navhl20 #60373
		if self.myPxyTask &lt;&gt; null then                       
			delete self.myPxyTask;
		endif;
		
		if self.myPxyWorkOrder &lt;&gt; null then
			delete self.myPxyWorkOrder;
		endif;
		
		delete self.myEmailController;
		
		self.unloadForm();
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doBtnClickAttachCargo" id="9ec9ad21-1880-441c-ac3e-cecd4be17af9">
        <updating/>
        <source>doBtnClickAttachCargo(btn: Button input)updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 Jan 2023	navhl20	ChangeRequest 55443:[54991] EUP - Receive Cargo Work Order - Enhancements
07 Feb 2023	navcs2	ChangeRequest 55440: EUP - Cargo Work Order Enhancements (54990)
08 Feb 2023 navma1  ChangeRequest 56457: EUP - Allowing different sets of cargo items per work order task [Refactor]
17 Apr 2023 navhl20 ChangeRequest 57322:[57323] EUP - VAS Task linked with Receive Cargo work Order
04 Jul 2023	navma1	Bug 58952: MTN - Unable to add the tracked item when using the Export Booking for Release Cargo Work Order
24 Jul 2023	navma1	ChangeRequest 59275: MTN - Transport Mode should be used to filter prenotes
20 Oct 2023 navsaa30 ChangeRequest 60819: EUP | Ship Operations in DD - [54176.010] - [Release] Attach cargo items for selected voyage
03 May 2024 navhl20 ChangeRequest 63971: FR | 54176 - Ship operations in Delivery Dispatch screen
04 Dec 2024	navhl20 Bug MTN-33579: EUP - Attach cargo from booking is not doing anything for release ship work order
*/

vars
	entTableDef : EntTableDef;
	tbl			: CM_DataTable;
	xmlStr		: String;
	tiSet		: CM_TISet;
	task 		: CM_WorkOrderDtl; 
	booking 	: CM_BookingRef;
	bookingItem : CM_BookingRefItem;
	bol			: CM_BOL;
	bolDtl		: CM_BOLDtl;
	voyage		: CM_Voyage;
	bulkRelease : CM_BulkRelease;
	ti			: CM_TrackedItem;
begin
	self.doSaveCargoProxy();
	create tiSet transient;
	
	task := self.myPxyTask;
	
	if task = null then
		return;
	endif;
	
	entTableDef := app.myController.getEntTableDef(ETDef_CargoEnqDefaultData);	
	tbl			:= self.tblSelectedCargo;
	
	xmlStr := self.enquiryTypeDef_Cargo;
		
	if xmlStr &lt;&gt; null then
		self.tblSelectedCargo.setTblDataEntRowsFromXML(entTableDef, xmlStr);	
	else	
		tbl.setTblDataEntRowsFromDef(entTableDef);
	endif;
	
	tbl.setMyDataClass(CM_TrackedItem);
	tbl.fixedColumns    := 0;
	tbl.fixedRows 	    := 1;
	tbl.selectMode 		:= CM_DataTable.SelectMode_FixedRow;
	tbl.selectionType   := CM_DataTable.SelectionType_Row;
	tbl.multiSelect 	:= CM_BaseTable.MultiSelect_Simple;	
	self.setColorsForTable(tbl);
	
	if task.isKindOf(CM_WodReceive) then
		if self.cmbTransMode.text = TI_TRANSMODE_SHIP_STR then
			bol 	:= task.CM_WodReceive.myBillOfLading;
			bolDtl	:= task.CM_WodReceive.myBillOfLadingDtl;
			if bolDtl &lt;&gt; null then
				tiSet := bolDtl.allTrackedItems;
			else
				if bol &lt;&gt; null then
					tiSet := bol.allTrackedItems;
				endif;
			endif;
		else
			bookingItem := task.CM_WodReceive.myBookingRefItem;			//17.4.2023 navhl20 #57322[57323]
			booking     := task.CM_WodReceive.myBookingRef;				//17.4.2023 navhl20 #57322[57323]
			
			if bookingItem &lt;&gt; null then									//17.4.2023 navhl20 #57322[57323]
				bookingItem.getPrenotedTrackedItems(tiSet,task);		//24.07.2023 navma1 #59275
			else
				if booking &lt;&gt; null then
					booking.getPrenotedTrackedItems(tiSet,task);		//24.07.2023 navma1 #59275
				endif;
			endif;
		endif;
	elseif task.isKindOf(CM_WodRelease) then
		if self.optBtnRelease.value then
			bulkRelease	:= task.CM_WodRelease.myReleaseRequest;
			
			if bulkRelease &lt;&gt; null then									//03.05.2024 navhl20 #63971
				tiSet := bulkRelease.allTrackedItemsAssigned;
			endif;
		elseif self.optBtnBooking.value then
			booking 	:= self.cmbBooking.listObject.CM_BookingRef;	//04.07.2023 navma1 #58952			
			bookingItem := task.CM_WodRelease.myBookingRefItem;			//07.7.2023 navhl20 #58952
			
			if bookingItem &lt;&gt; null then									//07.7.2023 navhl20 #58952
				bookingItem.getPrenotedTrackedItems(tiSet,task);
				bookingItem.getOnsiteTrackeditems(tiSet,task);			//04.12.2024 navhl20 #33579
			elseif booking &lt;&gt; null then
				booking.getPrenotedTrackedItems(tiSet,task);
				bookingItem.getOnsiteTrackeditems(tiSet,task);			//04.12.2024 navhl20 #33579
			else														//03.05.2024 navhl20 #63971
				voyage 	:= task.CM_WodRelease.myVoyage;
				voyage.allNotifiedTIsByCargoTypeId.copy(tiSet);
				voyage.allOnsiteTIsByCargoTypeId.copy(tiSet);
				foreach ti in tiSet do
					if ti.getImExStatus() &lt;&gt; TI_IMEX_STATUS_EXPORT then
						tiSet.tryRemove(ti);
					endif;
				endforeach;
			endif;
		endif;
	endif;

	self.myPxyTask.CM_WorkOrderTIDtl.allSelectedTIs.clear();
	tiSet.tryCopy(self.myPxyTask.CM_WorkOrderTIDtl.allSelectedTIs);
	
	self.loadTabCargoTis();																		//08.02.2023 navma1 #56457[56458]
epilog
	
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doBtnClickBooking" id="f4cc4f2a-bf02-4842-b391-81e6ad011365">
        <source>doBtnClickBooking();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 March 2023	navhl20	ChangeRequest 55443:[54991] EUP - Receive Cargo Work Order - Enhancements
23 Dec 2024	navbs1	Initial creation Bug MTN-33524: MTN - Notifications in the work order details screen update the release request assigned as a new work order is created

*/

vars
	subSys : CMUI_SubSystem;
	formCls,
	assistCls: Class;
	bookingRefForm : CM_BaseForm;
begin
	subSys := app.myController.allSubSystems['GateSchema'];
	
	if subSys &lt;&gt; null then
		subSys.getFormDetails('GTE_BookingRequestForm', formCls, assistCls);
	endif;
	if formCls = null then
		return;
	endif;
	
	bookingRefForm := app.loadForm(formCls, 
							assistCls, 
							false, 
							false,
							false, 
							self.myTerminal,
							self.myMasterMenuAction).CM_BaseForm;	

	if bookingRefForm = null then
		return;
	endif;
	bookingRefForm.myParentForm := self;			//23.12.2024 navbs1 #33524
	if self.btnMaintainBooking.caption = app.getErrorString(Create_booking) then
		bookingRefForm.show;
		if self.cmbTransport.listObject.isKindOf(CM_Voyage) then
			bookingRefForm.setBookingDetails(self.txtWorkOrderId.text,self.cmbTransport.listObject.CM_Voyage,self.cmbTransMode.text);
		else	
			bookingRefForm.setBookingDetails(self.txtWorkOrderId.text,null,self.cmbTransMode.text);
		endif;
		bookingRefForm.setFormObject(null);
	else
		bookingRefForm.setFormObject(self.cmbBooking.listObject);
		bookingRefForm.show;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doBtnClickCreateBol" id="81bb949e-416b-4d9b-abf5-9eeef57c9292">
        <updating/>
        <source>doBtnClickCreateBol()updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 January 2023	navhl20	ChangeRequest 55443:[54991] EUP - Receive Cargo Work Order - Enhancements
23 Dec 2024	navbs1	Initial creation Bug MTN-33524: MTN - Notifications in the work order details screen update the release request assigned as a new work order is created

*/

vars
	voyage : CM_Voyage;
	form   : CMUI_BOLMaintForm;
begin				
	if self.cmbTransport.listObject.isKindOf(CM_Voyage) then
		voyage := self.cmbTransport.listObject.CM_Voyage;
	endif;
	
	form := app.loadForm(CMUI_BOLMaintForm,
									self.myAssistant.class,
									false,
									false,
									false,
									self.myTerminal, null).CMUI_BOLMaintForm;
	
	if form = null then
		return;
	endif;
	
	form.myParentForm := self;			//23.12.2024 navbs1 #33524
	if self.btnMaintainBol.caption = app.getErrorString(Add_Bill_lading) then
		form.txtBOL.text := self.txtWorkOrderId.text;
		form.setMyVoyage(voyage);
		form.setCaption(app.getErrorString(Add_ship_BOL)); 
		form.setMode(form.Mode_Add);
		form.setMyCurrentBOL(null);
	else
		form.setCaption(app.getErrorString(Edit_ship_BOL)); 
		form.setMode(form.Mode_Update);
		form.setMyCurrentBOL(self.cmbBol.listObject.CM_BOL);
	endif;
		
	form.fromOnshipForm := true;
	form.setMyBOLType(app.myRoot.allBOLTypes[BOLType_GeneralBillOfLading]);
	form.show();
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doBtnClickCreateCargo" id="d76f8c96-5468-44c1-83b3-60eed9db350c">
        <updating/>
        <source>doBtnClickCreateCargo()updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 Mar 2023	navhl20	ChangeRequest 55443:[54991] EUP - Receive Cargo Work Order - Enhancements
10 Apr 2023 navhl20 ChangeRequest 56628:[54992] EUP - Receive Cargo Form- Enhancement
27 Jun 2023	navlw1	ChangeRequest 58730: EUP | Link bill of lading item to Receive work orders
10 Jul 2023 navhl20 Defect 59072: EUP- Bill of lading is not been defaulted on the Receive cargo form
11 Jul 2023 navma1	Defect 59094: MTN - 1090 exception when clicking on Create Cargo On Ship button without selecting Bill of Lading
11 Jul 2023 navma1	Defect 59095: EUP - Able to save the Receive Cargo Work Order without the Booking selected when the VAS Subscription is on/off
11 Jul 2023 navhl20 Defect 59092: EUP - On the Add Cargo form the Cargo SubType list is empty
24 Jul 2023 navma1	Bug 59257: MTN - Error 1090 when trying creating Prenote Receive Rail work orders
*/

vars
	voyage		: CM_Voyage;
	form 		: CMUI_ReceiveCargoForm;
	assistant	: CMUI_Assistant;
	bol			: CM_BOL;
	transport   : Object;
begin
	assistant := self.myAssistant;
	transport := self.cmbTransport.listObject;				//24.07.2023 navma1 #59257
	
	form := app.loadForm(	CMUI_ReceiveCargoForm,
								CMUI_Assistant,
								false,
								false,
								false,
								self.myTerminal, null).CMUI_ReceiveCargoForm;
	
	form.setColumnsAndControlWidth(3, 160);	// columns, default control width
		
	if self.cmbTransMode.text = TI_TRANSMODE_SHIP_STR then
		if  transport &lt;&gt; null and transport.isKindOf(CM_Voyage) then
			voyage := transport.CM_Voyage;
		endif;
		form.initFromOnshipForm(self, null, null, null, null, voyage, null);
		
		bol := self.cmbBol.listObject.CM_BOL;											//11.07.2023 navma1 #59094	
		if bol &lt;&gt; null then
			form.txtBOLNumber.setValue(bol.number);
		endif;
		form.setBolDtl(self.cmbBolItems.listObject.CM_BOLDtl);							//10.7.2023 navhl20 #59072
	else
		form.initFromPreNoteForm(self, null, null, null, self.cmbTransMode.text);
		if self.cmbBooking.listObject &lt;&gt; null then 										//27.06.2023 navlw1 #58730
			form.txtBookingRef.setValue(self.cmbBooking.listObject.CM_BookingRef.bookingReference);
			if self.cmbBookingItem.listObject &lt;&gt; null then
				form.myBookingRefItem := self.cmbBookingItem.listObject.CM_BookingRefItem;
			endif;
		endif;
	endif;
	
	form.setIsNewItem(true);
	form.myParentForm := self;

	if self.cmbTransMode.text = TI_TRANSMODE_RAIL_STR then								//10.4.2023 navhl20	#56628[54992]
		if transport &lt;&gt; null and transport.isKindOf(CM_Train) then						//24.07.2023 navma1 #59257
			form.txtWagonTrain.setValue(transport.CM_Train.code);
		endif;
	endif;
	
	form.show();
	form.cmbType_hasLostFocus(form.cmbType);											//11.7.2023 navhl20 #59092
epilog
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doBtnClickCreateRelease" id="ca496fba-88b7-4452-bff3-d8c4bfbf30cf">
        <source>doBtnClickCreateRelease();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20/03/2023	navcs2	ChangeRequest 55440:[54990]: EUP - Release Cargo Work Order - Enhancement
14 Jun 2023 navhl20 Bug 58634: MTN - Release by Type option should be disabled if there is no VAS subscription 
14 Dec 2023 navhl20 ChangeRequest 61092:[61621] EUP | Ship Operations in DD - [54176.050] Mobile App changes - Pack Load by Request
23 Dec 2024	navbs1	Bug MTN-33524: MTN - Notifications in the work order details screen update the release request assigned as a new work order is created
*/

vars
	bulkRelease,
	pxyProxyBulkRelease	: CM_BulkRelease;
	assistant			: CMUI_Assistant;
	integerType			: Integer;
	voyage				: CM_Voyage;
begin

	assistant 	:= self.myAssistant;
	bulkRelease := self.cmbReleaseRequest.listObject.CM_BulkRelease;
	
	if bulkRelease = null then
		create pxyProxyBulkRelease transient;
		
		if self.cmbTransMode.text = TI_TRANSMODE_SHIP_STR then
			integerType := BR_TYPE_SHIP;
		elseif self.cmbTransMode.text = TI_TRANSMODE_RAIL_STR then
			integerType := BR_TYPE_RAIL;
		elseif self.cmbTransMode.text = TI_TRANSMODE_ROAD_STR then
			integerType := BR_TYPE_ROAD;
		endif;
		
		if integerType &lt;&gt; BR_TYPE_RAIL then
			voyage := self.cmbTransport.listObject.CM_Voyage;													//14.12.2023 navhl20 #61092[61621]
			if voyage &lt;&gt; null then																				//14.12.2023 navhl20 #61092[61621]
				pxyProxyBulkRelease.setMyVoyage(voyage);
			endif;
		endif;
		//assistant.releaseRequestAdd(pxyProxyBulkRelease, integerType, self.myMasterMenuAction,1);			//14.6.2023 navhl20 #58634
		self.releaseRequestAddOrUpdate(pxyProxyBulkRelease, integerType, self.myMasterMenuAction,1, CMUI_TreeViewForm.Mode_Add);				//23.12.2024 navbs1 #33524
	else 
		//assistant.releaseRequestUpdate(bulkRelease, self.myMasterMenuAction,1);								//14.6.2023 navhl20 #58634
		self.releaseRequestAddOrUpdate(bulkRelease,null, self.myMasterMenuAction,1, CMUI_TreeViewForm.Mode_Update);										//23.12.2024 navbs1 #33524
	endif;

epilog
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doBtnSelectEmail" id="f2a4a09d-2b54-44ea-b497-874408674954">
        <source>doBtnSelectEmail();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 Mar 2022 navma1 ChangeRequest 52351: MTN - Work Order Maintenance Refactor - UI

*/

vars
	form : CMUI_RecipientSelector;
begin
	create form transient;
	
	self.setNavigatorHeading(form.caption);
	form.myEmailController := self.myEmailController;
	form.myTerminal		   := self.myTerminal;
	form.mode 			   := CMUI_RecipientSelector.Mode_To;
	form.setDisable(true, true, false);
	form.centreWindow;
	form.showModal;
	
	if form.modalResult = IDOK then
		//self.hasChanged := true;
		self.txtEmail.text 		:= self.myEmailController.allToAddresses.getNames();
		self.chkSendEmail.value := not self.txtEmail.text = null ; 
	endif;
epilog
	delete form;
end;</source>
    </JadeMethod>
    <JadeMethod name="doBtnTaskAdd" id="b9240f65-e5f3-498e-b45d-a058acb4a5f6">
        <updating/>
        <source>doBtnTaskAdd(_autoCreate : Boolean) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		 Reason
30 Mar 2022	navma1	 ChangeRequest 52351: MTN - Work Order Maintenance Refactor - UI
04 Aug 2022 navtnr20 Bug 54347: MTN - Voyage Work Orders - When selecting any task the voyage gets disappeared
19 Dec 2022	navcs2	 ChangeRequest 56840:[54265] EUP - [Framework] - VAS Work Order Maintenance Sceen
20 Mar 2023 navma1   ChangeRequest 56842:[56843] EUP - VAS Task Priority
17 Feb 2025	navhl20 CR MTN-14693: EUP | Work Order improvement - automatic WO Tasks for Release Cargo Work Order Line items &lt;&lt;54014&gt;&gt;
*/

vars
	form	: YRD_WorkOrderTasks;
	task 	: CM_WorkOrderDtl;
	now	 	: TimeStamp;
	voyage	: CM_Voyage;
	wodArr	: CM_WorkOrderDtlArray;
begin
	if not _autoCreate then										//17.02.2025 navhl20 #14693
		form := app.loadForm(YRD_WorkOrderTasks, YRD_Assistant, false, false, false, self.myTerminal, self.myMasterMenuAction).YRD_WorkOrderTasks;
		
		if form = null then
			return;
		endif;
		
		form.setWorkOrderMode(self.workOrderType);
		form.setProxyWorkOrder(self.myPxyWorkOrder);
		form.showModal();
	else
		self.myPxyWorkOrder.createProxyWorkOrderTasks(WO_TASK_RELEASE,
														self.myPxyWorkOrder.requiredByDT, 
														self.myPxyWorkOrder.startAtDT,  
														null);
	endif;
	
	if _autoCreate or form.modalResult = IDOK then				//17.02.2025 navhl20 #14693
		if self.myPxyWorkOrder.allWoDtls.size = 0 then
			app.raiseCMException(Please_select_task,null,null);
			return;
		endif;	
		
		task   := self.myPxyWorkOrder.allWoDtls.last.CM_WorkOrderDtl;
		now    := app.actualTimeAppServer();
		voyage := self.myVoyage;	

		if task.detailType = WO_TASK_BILLINGADJ and voyage &lt;&gt; null then
			if voyage.departedDT &gt; now then
				self.myPxyWorkOrder.allWoDtls.remove(task);				
				self.handleActions();//05-08-2022 navtnr20 TFS 54347
				app.raiseCMException(Canno_billi_adjus_unles_voyag_,null,null);				
				return;
			endif;
			if not voyage.isWorkOrderForExtension() then
				self.myPxyWorkOrder.allWoDtls.remove(task);
				self.handleActions();//05-08-2022 navtnr20 TFS 54347
				app.raiseCMException(Only_billi_adjus_voyag_with_ex,null,null);				
				return;
			endif;
		endif;
		//26.05.2022 navsrk20 TFS 52351 ends
		
		self.displayTasks(task);
		
		if self.workOrderType = WorkOrderMode_Cargo then
			self.loadCargoTaskDetails(task.detailType);
		elseif self.workOrderType = WorkOrderMode_Voyage then
			self.cmbWorkOrderStatus.listIndex := 1;
			self.loadVoyageTaskDetails(task.detailType);
			self.cmbVoyageDetails.enabled := false;		//04.08.2022 navtnr20 #54347
		else
			self.loadToDoTaskDetails(task.detailType); 	// 19.12.2022 navcs2 #56840:[54265]
		endif;
		self.canMaintainTasks(task.getStatus());
	endif;
	
	create wodArr transient;							//20.03.2023 navma1 #56842:[56843]
	self.myPxyWorkOrder.allWoDtls.copy(wodArr);
	self.updateTaskId(wodArr);
epilog
	delete wodArr;
	delete form;
end;</source>
        <Parameter name="_autoCreate" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doBtnTaskDelete" id="736ff3b8-cdcd-4368-96dd-206cf36c599d">
        <updating/>
        <source>doBtnTaskDelete(_task : CM_WorkOrderDtl io) protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 Mar 2022 navma1 	ChangeRequest 52351: MTN - Work Order Maintenance Refactor - UI  TFS 52351
12/07/2022	navcs2	ChangeRequest 53932: MTN - Jobs Changes
28/07/2022  navcs2 	Bug 54402: MTN - Work Order Maintenance - The 'Selected Cargo Items' Is Not Shown Correctly in Voyage Work Order Creation Screen
20 Mar 2023 navma1  ChangeRequest 56842:[56843] EUP - VAS Task Priority
*/

vars
	currentPos, 
	lstIndexNow, 
	collSize 		  : Integer;
	nextTaskToDisplay : CM_WorkOrderDtl;
	wodArr		  	  : CM_WorkOrderDtlArray;
begin
	
	if _task &lt;&gt; null then
		//validation
		_task.validateForDelete();
		
		//Calculate the next task to display in the tasks listbox
		currentPos := self.myPxyWorkOrder.allWoDtls.indexOf(_task);
		if currentPos = 1 then
			lstIndexNow := currentPos + 1;
		else
			lstIndexNow := currentPos - 1;
		endif;
		
		if self.myPxyWorkOrder.allWoDtls.size &gt; 1 then
			nextTaskToDisplay := self.myPxyWorkOrder.allWoDtls[lstIndexNow].CM_WorkOrderDtl;
		endif;
		
		//remove the task
		self.myPxyWorkOrder.allWoDtls.remove(_task);
		if _task &lt;&gt; null and self.workOrderType = WorkOrderMode_Voyage then
			self.doDisableSheets(_task.detailType);
		endif;
		delete _task;
		
		//redisplay tasks
		//self.myPxyWorkOrder := null;  //Setting to null will prevent the new selected object to be saved
		self.displayTasks(nextTaskToDisplay);
		self.myPxyTask := nextTaskToDisplay;
	endif;
	
	// 12/07/2022	navcs2 53932
	if myPxyTask &lt;&gt; null then
		self.canMaintainTasks(self.myPxyTask.getStatus());
	else
		// 28/07/2022 navcs2 Bug 54402
		self.btnTaskDelete.enabled := false;
		self.btnTaskAdd. enabled := true;
		if self.workOrderType = WorkOrderMode_Cargo then
			self.loadCargoTaskDetails(null);
		elseif self.workOrderType = WorkOrderMode_Voyage then
			if self.myPxyTask &lt;&gt; null then
				self.loadVoyageTaskDetails(self.myPxyTask.detailType);
			endif;
		else
			self.loadToDoTaskDetails(null);
		endif;
	endif;
	
	/*
	update Task Id 
	20.03.2023 navma1 #56842:[56843]
	*/
	create wodArr transient;
	self.myPxyWorkOrder.allWoDtls.copy(wodArr);
	self.updateTaskId(wodArr);
epilog
	delete wodArr;
end;</source>
        <access>protected</access>
        <Parameter name="_task" type="CM_WorkOrderDtl" usage="io"/>
    </JadeMethod>
    <JadeMethod name="doCancel" id="3727aa84-e0e7-42ac-8b35-535c26889b9e">
        <updating/>
        <source>doCancel() : Boolean updating, protected;
/*
Purpose:			'Cancel' button click - checks form update and unloads form

Parameters:			None

Return Value:		None

Date		Who		Reason
05 Oct 2023 navhl20 Bug 60373: MTN - Expected to see a validation message to save the changes before closing the work order form.
*/
vars
	warn,
	invalidObject	: Boolean;
	edition			: Integer;
begin
	on Exception do app.handleDeletedObject(exception, self.myPxyWorkOrder, invalidObject);
	on Exception do app.handleDeletedObject(exception, self.myWorkOrder, invalidObject);
	
	invalidObject := false;
	edition 	  := self.myPxyWorkOrder.edition;
	
	if invalidObject then
		return true;
	endif;
	
	if self.myPxyWorkOrder &lt;&gt; null and self.myWorkOrder &lt;&gt; null and self.myPxyWorkOrder.allWoDtls.size &lt;&gt; self.myWorkOrder.allWoDtls.size then
		warn := true;
	elseif self.myWorkOrder = null and self.myPxyWorkOrder.allWoDtls.size &gt; 0 then
		warn := true;
	endif;
	
	if warn then
		if app.msgBox(app.getErrorString(EditChangedAndClosing), app.getErrorString(MSGBOX_UnsavedChangesTitle), MsgBox_Yes_No + MsgBox_Question_Mark_Icon) &lt;&gt; MsgBox_Return_Yes then
			return false;
		endif;	
	endif;
	return true;
epilog
	
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doChangeCargoSubType" id="5318819c-9534-416d-ade0-44aea8815fb6">
        <updating/>
        <source>doChangeCargoSubType(_cargoSubType : CM_Product) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
25 April 2022	navgm20	ChangeRequest 52351: MTN - Work Order Maintenance Refactor - UI

*/

vars
weight, volume : String;

begin
	if _cargoSubType &lt;&gt; null then
		// set measurement type on weight / volume fields
		weight := _cargoSubType.getDefaultMeasurementForType(Type_Weight).shortName;
		volume := _cargoSubType.getDefaultMeasurementForType(Type_Volume).shortName;
		self.txtCargoWeight.accessCell(1, 3).text := weight;
		self.txtTareWeight.accessCell(1, 3).text := weight;
		self.txtTotalWeight.accessCell(1, 3).text := weight;
		self.txtTotalVolume.accessCell(1, 3).text := volume;
	endif;
epilog

end;</source>
        <Parameter name="_cargoSubType" type="CM_Product"/>
    </JadeMethod>
    <JadeMethod name="doChangeCargoType" id="c9a3f768-a9af-4a6b-9b23-02869ee19b9b">
        <updating/>
        <source>doChangeCargoType(_cargoType : CM_CargoType) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 April 2022	navgm20	ChangeRequest 52351: MTN - Work Order Maintenance Refactor - UI

*/

vars
weight, volume : String;

begin

	if _cargoType = null then
		return;
	endif;
	
	if _cargoType.hasProductTypes then
		self.cmbCargoSubType.listCollection(_cargoType.allProducts, true, 0);
		self.cmbCargoSubType.enabled := true;
	else
		self.cmbCargoSubType.clear;
		self.cmbCargoSubType.enabled := false;
		// use cargo type default weight / volume type to set weight / volume fields
		weight := _cargoType.getDefaultMeasurementForType(Type_Weight).shortName;
		volume := _cargoType.getDefaultMeasurementForType(Type_Volume).shortName;
		self.txtCargoWeight.accessCell(1, 3).text := weight;
		self.txtTareWeight.accessCell(1, 3).text := weight;
		self.txtTotalWeight.accessCell(1, 3).text := weight;
		self.txtTotalVolume.accessCell(1, 3).text := volume;
	endif;
	self.txtTotalWeight.enabled := true;
	if _cargoType.isTrackByWeight then
		self.txtTotalVolume.enabled := false;
	elseif _cargoType.isTrackByVolume then
		self.txtTotalVolume.enabled := true;
		self.txtTotalWeight.enabled := false;
	endif;
	if _cargoType.isAllowDuplicates then
		self.txtTotalQuantity.enabled := true;
	else
		self.txtTotalQuantity.enabled := false;
	endif;
	if _cargoType.useTareCargoWeight then
		self.txtCargoWeight.enabled := true;
		self.txtTareWeight.enabled := true;
	else
		self.txtCargoWeight.enabled := false;
		self.txtTareWeight.enabled := false;
	endif;
	if _cargoType.allCommodities.isEmpty then
		self.cmbCommodity.clear;
		self.cmbCommodity.enabled := false;
	else
		self.cmbCommodity.listCollection(_cargoType.allCommodities, true, 0);
		self.cmbCommodity.enabled := true;
	endif;
epilog

end;</source>
        <Parameter name="_cargoType" type="CM_CargoType"/>
    </JadeMethod>
    <JadeMethod name="doClickCmbTransMode" id="1f0194f0-81eb-48ae-a14b-154e62ce1565">
        <updating/>
        <source>doClickCmbTransMode(combobox: ComboBox input)updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
08 Mar 2023		navhl20	ChangeRequest 55443:[54991] EUP - Receive Cargo Work Order - Enhancements
07 Feb 2023		navcs2	ChangeRequest 55440:[54990] EUP - Cargo Work Order Enhancements
02 May 2023 	navma1	Defect 57816: MTN - WO - The release requests are not filtering correctly based on the transport mode selected
27 Jun 2023 	navlw1	
04 Jul 2023		navma1	Bug 58952: MTN - Unable to add the tracked item when using the Export Booking for Release Cargo Work Order
11 Jul 2023 	navhl20 Defect 59093: EUP - Invalid Property error when creating multiple receive cargo work orders
19 Jul 2023 	navhl20 Bug 59175: MTN - Issues with selected cargo items when Loading cargo Receive and Release work orders 
19 Jul 2023 	navhl20 Bug 59200: MTN - Release Rail Work order showing Prenote Button
09 Nov 2023 	navhl20 Bug 61167: MTN - Wrong button is displayed on the Release cargo work order when selecting the transport mode as Ship
*/

vars
	voyage : CM_Voyage;
	
begin
	self.buildCmbTransport(combobox.text);
	
	if combobox.text = TI_TRANSMODE_RAIL_STR then
		self.lblTransport.visible := false;
		self.lblTrain.visible 	  := true;
		self.lblTrain.parent	  := self.grpReceiveDetails;
	else
		self.lblTransport.visible := true;
		self.lblTrain.visible 	  := false;
	endif;
	
	if self.myPxyTask.isKindOf(CM_WodReceive) then
		self.grpBookingItems.caption := app.getErrorString(Items) &amp; ':';
		self.btnCreateCargo.visible  := true;
		
		if combobox.text = TI_TRANSMODE_SHIP_STR then
			self.lblBooking.visible 			:= false;
			self.cmbBooking.visible 			:= false;
			self.lblBOL.visible 				:= true;
			self.cmbBol.visible 				:= true;
			self.cmbBolItems.visible 			:= true;
			self.lblBolItems.visible 			:= true;
			self.lblBolItems.top				:= self.lblBookingItem.top;
			self.cmbBolItems.top				:= self.cmbBookingItem.top;
			self.lblBookingItem.visible 		:= false;
			self.cmbBookingItem.visible 		:= false;
			self.btnMaintainBooking.visible 	:= false;
			self.btnCreateCargo.caption 		:= app.getErrorString(Create_cargo_ship);
			self.btnMaintainBol.visible 		:= true;
			self.initTableItems(ETDef_BOLItems);
			
			voyage := self.myPxyTask.CM_WodReceive.myVoyage;
			if voyage = null then
				voyage := self.cmbTransport.listObject.CM_Voyage;
			endif;
			//self.buildCmbBol(self.myPxyTask.CM_WodReceive.myVoyage);				//19.7.2023 navhl20 #59175
			self.buildCmbBol(voyage);												// ### TFS 64308 (64309) 28May2024 NAVPW1
			self.cmbBol_click(self.cmbBol);											//19.7.2023 navhl20 #59175
		else
			self.lblBooking.visible 			:= true;
			self.cmbBooking.visible				:= true;
			self.lblBOL.visible				    := false;
			self.cmbBol.visible 				:= false;
			self.lblBolItems.visible			:= false;
			self.cmbBolItems.visible 			:= false;
			self.lblBookingItem.visible 		:= true;
			self.cmbBookingItem.visible 		:= true;
			self.lblCustomExportEntryNumber.top := self.lblBookingItem.top + self.lblBookingItem.height + 10;
			self.txtCustomNumber.top 			:= self.cmbBookingItem.top + self.cmbBookingItem.height + 10;
			self.btnMaintainBol.visible 		:= false;
			self.btnCreateCargo.caption 		:= app.getErrorString(Create_prenote);
			self.btnMaintainBooking.visible 	:= true;
			self.initTableItems(ETDef_BookReqItem);
			self.buildCmbBooking(self.myPxyTask.CM_WodReceive.myVoyage);			//19.7.2023 navhl20 #59175
			self.cmbBooking_click(self.cmbBooking);									//19.7.2023 navhl20 #59175
		endif;
	elseif self.myPxyTask.isKindOf(CM_WodRelease) then
		self.grpBookingItems.caption := app.getErrorString(Released_items) &amp; ':';
		if combobox.text = TI_TRANSMODE_SHIP_STR then
			//self.btnMaintainBooking.visible 	  := true;							//04.07.2023 navma1 #58952  //09.11.2023 navhl20 #61167
			self.optBtnRelease.enabled 			  := true;
			self.optBtnBooking.enabled 			  := true;
		else
			if combobox.text = TI_TRANSMODE_RAIL_STR then
				self.lblTrain.parent			  := self.grpReleaseDetails;
				self.lblTrain.visible 	 		  := true;
			endif;
			self.optBtnRelease.value 			  := true;
			self.optBtnRelease.click(self.optBtnRelease);
			self.optBtnRelease.enabled 			  := false;
			self.optBtnBooking.enabled 			  := false;
		endif;
		if self.optBtnBooking.value then								//19.7.2023 navhl20 #59175
			self.initTableItems(ETDef_BookReqItem);
			self.buildCmbBooking(self.myPxyTask.CM_WodRelease.myVoyage);
			self.cmbBooking_click(self.cmbBooking);
		else
			self.initTableItems(ETDef_ResDetails);
			self.buildCmbRelease();
			self.cmbReleaseRequest_click(self.cmbReleaseRequest);
		endif;
	endif; 
	
	self.maintainBtnAttachCargo(); 									//30.03.2023 navcs2 #55440[54990]
epilog

end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doControlEvent" id="f724cdc2-97ae-4ec4-940b-773276b26c6e">
        <updating/>
        <source>doControlEvent(_control: Control) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13/01/2023	navcs2	ChangeRequest 56840:[54265] EUP - [Framework] - VAS Work Order Maintenance Sceen
21/03/2023	navcs2	Defect 57231: MTN - WO - Available debtors disappears when selecting an operator while creating a Non Operational to do work order
*/

vars
	groupBox : CMUI_MultiSelectGroupBox;
begin
	groupBox := self.mulToDoSecondaryEntites;
	
	if (_control = groupBox.myAvailableListBox and groupBox.mySelectedListBox.listCount = 0) then		// 21/03/2023	navcs2	Defect #57231
		return;																							// 21/03/2023	navcs2	Defect #57231
	elseif     _control = groupBox.myAvailableListBox 
		or _control = groupBox.mySelectedListBox
		or _control = groupBox.myAddSelectedBtn 
		or _control = groupBox.myAddAllBtn 
		or _control = groupBox.myRemoveAllBtn 
		or _control = groupBox.myRemoveSelectedBtn then
		
		self.updateDebtorSelectionBox();
	endif;
epilog

end;</source>
        <Parameter name="_control" type="Control"/>
    </JadeMethod>
    <JadeMethod name="doDisableSheets" id="8ae6b505-a87a-4444-8a3e-a62b51c6927a">
        <updating/>
        <source>doDisableSheets(_taskType : Integer) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 May 2022	navgm20	ChangeRequest 52351: MTN - Work Order Maintenance Refactor - UI

*/

vars

begin
	if _taskType = WO_TASK_TIMECHANGE then
		self.shtTimeChange.visible := false;
	elseif _taskType = WO_TASK_WATER then
		self.shtWaterRequest.visible := false;
	elseif _taskType = WO_TASK_EXTENSION then
		self.shtExtension.visible := false;
		self.shtVoyageResources.visible	:= false;
	elseif _taskType = WO_TASK_HMSCANCEL then
		self.shtHMSCancel.visible	:= false;
	elseif _taskType = WO_TASK_BILLINGADJ then
		self.shtBillingAdj.visible	:= false;
	elseif _taskType = WO_TASK_MARINEINITIAL then
		self.shtMarineI.visible	:=	false;
		self.shtVoyageResources.visible	:= false;
	elseif _taskType = WO_TASK_NEWVOYAGE then 
		self.shtVoyageNewRequest.visible	:= false;
	elseif _taskType = WO_TASK_MARINEDEPART then 
		self.shtMarineD.visible	:= false;
		self.shtVoyageResources.visible	:= false;
	elseif _taskType = WO_TASK_PERMIT then 
		self.shtPermit.visible	:= false;
	elseif _taskType = WO_TASK_SHIFTMOVEMENT then 
		self.shtShift.visible	:= false;
		self.shtVoyageResources.visible	:= false;
	elseif _taskType = WO_TASK_CARGOREQUEST then
		self.shtCargoRequest.visible	:= false;
	endif;
epilog

end;</source>
        <Parameter name="_taskType" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doMnuFormContextMenu" id="deb12004-b5ad-4643-a4cd-e6213d1418ba">
        <updating/>
        <source>doMnuFormContextMenu(table : CM_DataTable input; mouse: Boolean; x: Integer; y: Integer): Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 January 2023	navhl20	ChangeRequest 55443:[54991] EUP - Receive Cargo Work Order - Enhancements

*/

vars
	isShowDataMenus		: Boolean;
	isDataValidRow		: Boolean;
	x1, y1				: Real;
begin
	isShowDataMenus	:=	(table = self.tblItems);
	
	self.mnuRemoveTi.visible := false;
	self.mnuColumnOrganiser.visible := true;
	self.mnuColumnOrganiser.userObject := table;
	
	if isShowDataMenus then
		isDataValidRow	:=	(self.tblItems.row &gt; self.tblItems.fixedRows);
	endif;

	x1	:=	x;
	y1	:=	y;
	
	if (not mouse) then  // if keyboard, use current listIndex value
	    x1	:=	1;
	    y1	:=	1;
	endif;

	table.windowToScreen(x1, y1);
	self.screenToWindow(x1, y1);   // convert x, y relative to form
	self.popupMenu(self.mnuWorkOrder, x1.Integer, y1.Integer);
	return false;
epilog

end;</source>
        <Parameter name="table" type="CM_DataTable" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doMnuRemoveTi" id="0a4998fb-352b-40f0-b6b6-c72845562c55">
        <source>doMnuRemoveTi();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 Jan 2023	navhl20	ChangeRequest 55443:[54991] EUP - Receive Cargo Work Order - Enhancements
08 Feb 2023 navma1  ChangeRequest 56457: EUP - Allowing different sets of cargo items per work order task [Refactor]
*/

vars
	allSelectedItems : CM_TIArray;
	ti : CM_TrackedItem;
	iter : Iterator;
	idx : Integer;
begin
	create allSelectedItems transient;
	
	self.tblSelectedCargo.allSelectedObjects.copy(allSelectedItems);
	if allSelectedItems.size = 0  then
		app.msgBox(app.getErrorString2(CMUI_Please_Select, "cargo item(s)", "remove"),app.getErrorString(NOTHING_SELECTED), MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	
	foreach ti in allSelectedItems do
		self.tblSelectedCargo.removeItemObject(ti);
		//self.allSelectedTis.remove(ti);								//08.02.2023 navma1 #56457 Task#56458
		//self.myPxyWorkOrder.CM_WorkOrderTI.allTIs.clear();			//08.02.2023 navma1 #56457 Task#56458
		self.myPxyTask.CM_WorkOrderTIDtl.allSelectedTIs.remove(ti); 	//08.02.2023 navma1 #56457 Task#56458
	endforeach;
	
	self.loadTabCargoTis();												//08.02.2023 navma1 #56457 Task#56458
epilog
	delete allSelectedItems;
end;</source>
    </JadeMethod>
    <JadeMethod name="doPermissionCheck" id="c34c8eb0-930d-4be4-9743-ce5589955938">
        <source>doPermissionCheck();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 June 2022	navgm20	ChangeRequest 52351: MTN - Work Order Maintenance Refactor - UI

