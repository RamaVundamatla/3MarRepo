    <JadeMethod name="addObjectsToTable" id="3ebc6b31-5154-4614-9d96-0719f2a48732">
        <updating/>
        <source>addObjectsToTable(_numItems: Integer io) updating;
// ---------------------------------------------------------------------------
// Created:     22 October 2003 by cnwrs2
//
// Purpose:
//   
// Updated	by CNWTH2 9/03/07  - optimsed performance. 
//				Also added logic for having Release# partial match text field instead of the dropdownbox
//				(controlled by app.getMyTerminalConfig(GateRelNoSearchText).Boolean then
// 11/08/2011	cnwdap1		PAR #27972 Bulk release type no longer translatable, replaced by string constants
// 23/11/2011	cnwcs5		CCMS POL 2122 / par 28696 - new type of Unknown
// 16/02/2012	cnwcs5		CCMS POL 2151 / par 29137 - 
// 04/01/2015	cnwdap1		PAR #35397 CCMS SFW 1394 Voyage Rationalisation
// 11/07/2025	naviv1		MTN-35226 : MTN - Usage of Iterator.getCurrentKeys  
// ---------------------------------------------------------------------------
vars
	releaseNoKey, 
	filterReleaseNo				: String;
	type, status, 
	typeKey, statusKey			: Integer;
	tsKey						: TimeStamp;
	statusColl,	typesColl		: IntegerArray;
	breakOut					: Boolean;
	passport			: CM_Passport;
	iter 				: Iterator;
	dict				: CM_BulkReleaseByTypeStCodeDict;
	opTerm				: CM_OperatorTerminal;
	bulkRelease			: CM_BulkRelease;
	reserveDetail 		: CM_ReserveDetail;
	pin					: CM_PinNo;
 	obj					: Object;
begin

	self.setIgnoreFilterStatus (false);
	self.setIgnoreFilterType (false);
	
	if (not self.isFirstActivateComplete) then
		// PAR 11209, takes too long to load, let them filter data
		return;
	endif;
	
	passport 			:= app.myPassport;
	self.columnPinNo 	:= self.tblData.getColumnByRowName(ETRow_MyPinNo);				

	if self.myFilterBulkRelease &lt;&gt; null then
		if self.includeObject(self.myFilterBulkRelease, passport) then
			self.addObjectToTable(self.myFilterBulkRelease, _numItems, breakOut);
		endif;
		return;

	elseif self.filterPIN &lt;&gt; null and self.permissionMaint = PmGteEmptyReleaseMaintAll then
		pin := self.myTerminal.allPinNos[self.filterPIN];
		
		if pin &lt;&gt; null then
			foreach obj in pin.allItems discreteLock do //+ cnwmd1 Par 25448 added dicreteLock
				if CM_BulkRelease.hasInstance(obj) and
		   	       self.includeObject(obj.CM_BulkRelease, passport) then
					self.addObjectToTable(obj.CM_BulkRelease, _numItems, breakOut);
				endif;
				if breakOut then
					break;
				endif;
			endforeach;
		endif;
		return;
	endif;
	
	create typesColl transient;
	create statusColl transient;
	//	get bulkRelease types to search - N.B we don't include type 
	//	of 0 as these appear to be system created ones that they don't want to see

	if self.typeMode = BR_TYPE_ROAD_STR then														// PAR #27972
		typesColl.add(BR_TYPE_ROAD);
	
	elseif self.typeMode = BR_TYPE_RAIL_STR then													// PAR #27972
		typesColl.add(BR_TYPE_RAIL);
	
	elseif self.typeMode = BR_TYPE_PACKING_STR then													// PAR #27972
		typesColl.add(BR_TYPE_PACKING);
	
	elseif self.typeMode = BR_TYPE_SHIP_STR then													// PAR #27972
		typesColl.add(BR_TYPE_SHIP);
	
	elseif self.typeMode = BR_TYPE_UNKNOWN_STR then	// par 28696
		typesColl.add (BR_TYPE_UNKNOWN);			// par 28696
		
	elseif self.typeMode = null or self.typeMode = BR_TYPE_ALL_STR then								// PAR #27972
		if self.canViewRoad then				// par 28696
			typesColl.add(BR_TYPE_ROAD);
		endif;
		if self.canViewRail then				// par 28696
			typesColl.add(BR_TYPE_RAIL);
		endif;
		if self.canViewPacking then				// par 28696
			typesColl.add(BR_TYPE_PACKING);
		endif;
		if self.canViewShip then				// par 28696
			typesColl.add(BR_TYPE_SHIP);
		endif;
		if self.canViewUnknown then				// par 28696
			typesColl.add (BR_TYPE_UNKNOWN);	// par 28696
		endif;
	else
		app.raiseUnexpectedProgramError(class.name, method.name, 'Unhandled bulk release type (' &amp; self.typeMode &amp; ')');
	endif;
	
	//get bulkRelease statuses to search
	if (self.viewStatusMode = BR_ACTIVE_STRING &amp; ' &amp; ' &amp; BR_PENDING_STRING) then
		statusColl.add(BR_ACTIVE);
		statusColl.add(BR_PENDING);
		
	elseif self.viewStatusMode = BR_PENDING_STRING then
		statusColl.add(BR_PENDING);
		
	elseif self.viewStatusMode = BR_COMPLETE_STRING then
		statusColl.add(BR_COMPLETE);
		
	elseif self.viewStatusMode = BR_ARCHIVE_STRING then 
	   statusColl.add(BR_ARCHIVE);
	   
	elseif self.viewStatusMode = BR_ACTIVE_STRING then
		statusColl.add(BR_ACTIVE);

	elseif self.viewStatusMode = BR_TYPE_ALL_STR then												// PAR #27972
		statusColl.add(BR_PENDING);
		statusColl.add(BR_ACTIVE);
		statusColl.add(BR_COMPLETE);
		statusColl.add(BR_ARCHIVE);
	else
		app.raiseUnexpectedProgramError(class.name, method.name, 'Unhandled bulk release status (' &amp; self.viewStatusMode &amp; ')');
		return;
	endif;
	
	if self.myFilterOperator &lt;&gt; null then
		opTerm := self.myFilterOperator.getOperatorTerminal(self.myTerminal, false);
		
		if opTerm &lt;&gt; null then
			dict := opTerm.allBulkReleases;
		endif;
	endif;
	
	if dict = null then
		dict := self.myTerminal.allBulkReleaseByTypeByStByCd;
	endif;
	
	iter := dict.createIterator();
	//start the iter at each of the types in the CM_BulkReleaseByTypeStCodeDict dict 
	//cnwmd1 Par 25448, no dicrete lock lock required because the collections are both integer arrays
	filterReleaseNo := self.filterReleaseNo;	// so we don't do repeated getpropertyValue in loop
	
	foreach type in typesColl do : typeLoop 
		foreach status in statusColl do : statusLoop
			
			dict.startKeyGeq(type, status, filterReleaseNo, null, iter);
			
			while iter.next(bulkRelease) do				
				
				iter.getCurrentKeys(typeKey,statusKey,releaseNoKey,tsKey); //MTN-35226
				
				if typeKey &lt;&gt; type then
					continue typeLoop;
				endif;
				
				if statusKey &lt;&gt; status then
					continue statusLoop;
				endif;
				
				if filterReleaseNo &lt;&gt; null and (not releaseNoKey.startsWith(filterReleaseNo)) then
					continue statusLoop;
				endif;
				
				if self.myFilterVoyage &lt;&gt; null and bulkRelease.myVoyage &lt;&gt; self.myFilterVoyage then		// PAR #35397
					continue;																			// PAR #35397
				endif;																					// PAR #35397
				
				if self.includeObject(bulkRelease, passport) then
					if self.showFullReq then
						// RS2 - We should never be showing TI's here, only reserve details
						foreach reserveDetail in bulkRelease.allReserveDetails discreteLock do //+ cnwmd1 Par 25448 added dicreteLock
							self.addObjectToTable(reserveDetail, _numItems, breakOut);
						endforeach;
					else
						self.addObjectToTable(bulkRelease, _numItems, breakOut);
					endif;
					
					self.progressUpdate();
					
					if breakOut then
						break typeLoop;
					endif;
					
				endif;
			endwhile;
		endforeach;
	endforeach;
epilog
	delete iter;
	delete statusColl;
	delete typesColl;
	
	self.progressFinish();
end;</source>
        <Parameter name="_numItems" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="addToolbarControls" id="09e9ddf7-e17f-4789-8090-f9ae79fb3fd1">
        <source>addToolbarControls()  protected;
// ---------------------------------------------------------------------------
// Created:		November 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// 15/02/2010	cnwcs5	ccms 1925 / par 22295 Release Summaries
// 14/12/2011	cnwcs5	par 28756 - hide save button
// 04 Oct 2022 	navtnr20 ChangeRequest 54967: EUP - INB/OUT - Operational Instructions
// 12 Sep 2023	navlw1	CR 60415: MTN - Add Text Filter to Release Request Enquiry Screen
vars
	toolbar			: CMUI_Toolbar;
begin
	inheritMethod();

	self.btnSaveBase.visible	:= false;
	
	toolbar := self.frmToolbar;
	
	// summarise all - added for release summaries
	toolbar.addSeperator (CMUI_Toolbar.Control_Alignment_Left);						// 15/02/2010 cnwcs5 ccms 1925 / par 22295
	toolbar.addButton (self.btnSummariseAll, CMUI_Toolbar.Control_Alignment_Left); 	// 15/02/2010 cnwcs5 ccms 1925 / par 22295

	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnFullReq, CMUI_Toolbar.Control_Alignment_Left);

	// CCMS 1412
	if self.allowGeneratePin then
		toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
		toolbar.addButton(self.btnGeneratePin, CMUI_Toolbar.Control_Alignment_Left);
		toolbar.addButton(self.btnDeletePIN, CMUI_Toolbar.Control_Alignment_Left);
	else
		self.btnGeneratePin.visible := false;
		self.btnDeletePIN.visible := false;
	endif;
	//th2 removed archive button - this is now right-click menu to set status
	
	toolbar.addSeperator( CMUI_Toolbar.Control_Alignment_Left );					// cnwrl1 24/07/2009 PAR 20349
	toolbar.addButton( self.btnEditStatus, CMUI_Toolbar.Control_Alignment_Left );	// cnwrl1 24/07/2009 PAR 20349
	toolbar.addButton( self.btnDepotEnq, CMUI_Toolbar.Control_Alignment_Left );	
	
	//03 Sep 2014	NDL Par 34717
	toolbar.addSeperator( CMUI_Toolbar.Control_Alignment_Left );
	toolbar.addButton( self.btnMoveIt, CMUI_Toolbar.Control_Alignment_Left );	
	toolbar.addButton( self.btnInstruction, CMUI_Toolbar.Control_Alignment_Left );	//03.10.2022 navtnr20 TFS 54967
	toolbar.positionToolbarControls();
	toolbar.visible := true;
	
	toolbar := self.frmToolbarPrint;
	toolbar.addButton(self.btnPrintPrint, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnPrintCancel, CMUI_Toolbar.Control_Alignment_Right);
	toolbar.positionToolbarControls();
	toolbar.visible := true;
	
/*	//05/06/2024	navkc1 CR 63736 Task 63770 - Replaced with new control
	// ### #60415 12Sep2023 navlw1 -- start
	self.frmToolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	self.frmToolbar.addFrame(self.frmFilter,CMUI_Toolbar.Control_Alignment_Left);
	self.txtFilterBox.parent 	:= self.frmFilter;
	self.txtFilterBox.visible 	:= true;
	self.txtFilterBox.left 		:= 0;
	self.txtFilterBox.top 		:= 2;
	self.frmToolbar.addButton(self.btnClearFilter,CMUI_Toolbar.Control_Alignment_Left);
	// ### #60415 12Sep2023 navlw1 -- end
*/
	
	//05/06/2024	navkc1 CR 63736 Task 63770
	self.frmToolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	self.frmToolbar.addFrame(self.frmTableFilter,CMUI_Toolbar.Control_Alignment_Left);
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="armNotesForObject" id="77f9ffe4-d946-4d76-8a84-203d61e65597">
        <source>armNotesForObject(_obj: Object);
// ---------------------------------------------------------------------------
// Created:		October 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	tmpTI : CM_TrackedItem;
	tmpBR : CM_BulkRelease;
begin
	
	if CM_TrackedItem.hasInstance(_obj) then
		tmpTI := _obj.CM_TrackedItem;
		foreach tmpBR in tmpTI.allBulkReleasesAssigned do
			self.beginNotification(tmpBR, Any_System_Event, Response_Continuous, 0);				
		endforeach;

	elseif CM_ReserveDetail.hasInstance(_obj) then
		self.beginNotification(_obj.CM_ReserveDetail.myReserveHeader, Any_System_Event, Response_Continuous, 0);		
	endif;
	
	//th2 - PAR 12392 
	inheritMethod(_obj);
end;</source>
        <Parameter name="_obj" type="Object"/>
    </JadeMethod>
