    <JadeMethod name="setExtraDetails" id="f1080c3c-fcbb-43c2-8f77-28d95f98b8f5">
        <source>setExtraDetails(_entry : DTO_RTQueueEntry) protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06 October 2010	cnwer1	Initial creation PAR 25923

*/

vars
	extraDetailsStr : String;
	extraDetailsRow,
	extraDetailsHeight	: Integer;
	
begin
	if self.myVMAgent.getMyRTVehicleConfig.canRemoveSplitScreen then
		return;
	endif;
	
	extraDetailsStr:=_entry.getMoveExtraDetailsFromTI(app.myVMAgent);
	self.myMoveTableDetails.setEntRowVisible(ETRow_ExtraDetails,extraDetailsStr &lt;&gt; null);//(ETRow_ExtraDetails,extraDetailsStr &lt;&gt; null);
	if extraDetailsStr &lt;&gt; null then
		self.myMoveTableDetails.addDataForEntRowName(ETRow_ExtraDetails,extraDetailsStr);
		extraDetailsRow:=self.myMoveTableDetails.findRowWithEntRowName(ETRow_ExtraDetails);
		extraDetailsHeight:=self.tblMoveEntry.getTextHeightForWidth(extraDetailsStr,self.tblMoveEntry.accessCell(extraDetailsRow,2).getCellWidth);
		self.myMoveTableDetails.myTable.accessRow(extraDetailsRow).height:=extraDetailsHeight;
		self.myMoveTableDetails.myTable.fitColumnWidth(2,0);
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_entry" type="DTO_RTQueueEntry"/>
    </JadeMethod>
    <JadeMethod name="setFramesVisible" id="5f322532-7e2c-4f8c-881f-79afb128f57e">
        <updating/>
        <source>setFramesVisible() protected, updating;
/*
	frmBody is parent to 3 frames
		- frmMove holds all move details including the graphics and director task stuff
		- frmGetTask holds get task stuff when no task or tasks are offered.
		- frmTaskTable holds table with list of tasks

Date		Who		Reason
12 February 2014	cnwer1	Initial creation PAR

*/

vars
	hasWorkingTask : Boolean;
	moveState	: Integer;
begin
	hasWorkingTask:=self.hasWorkingTask();
	if self.isEnquiryMode then
		self.frmGetTask.visible:=false; //always not visible in 
		self.frmTaskTable.visible:=not hasWorkingTask;
	elseif self.isShowOverstowCargo then
		self.frmGetTask.visible:=false;
		self.frmTaskTable.visible:=false;
		self.frmMove.visible:=true;
		if self.isSettingDown then
			self.frmDirector.visible:=false;
		else
			self.frmDirector.visible:=true;
		endif;
	else
		
		if  self.myVMAgent.isIMV then
			self.frmGetTask.visible:=true;
			self.frmTaskTable.visible:=false;
			return;
		endif;
		
		if  hasWorkingTask then
			self.frmGetTask.visible:=false;
			self.frmTaskTable.visible:=false;
		else	
			self.frmGetTask.visible:=not self.myVMAgent.showingTaskList;
			self.frmTaskTable.visible:=self.myVMAgent.showingTaskList;	
			
		
		endif;
		self.btnTaskMode.enabled:=self.myMachine.currentQueueTask = null;
		self.btnReject.enabled:=self.frmTaskTable.visible or self.myMachine.currentQueueTask &lt;&gt; null;
		
	endif;
	
	self.btnTandem.visible:=self.frmTaskTable.visible and (self.myMachine.isTandemLift or self.myMachine.isTwinLift);	
	self.frmMove.visible:=hasWorkingTask;
	if not self.frmMove.visible then
		self.btnGraphic.caption:=app.getErrorString(Graphic);
	endif;
	self.frmMoveEntry.visible:= hasWorkingTask;
	
	if self.isEnquiryMode then
		self.setupFrmTop(true);
	else
		self.setupFrmTop(self.frmTaskTable.visible);
	endif;	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setFrmMoveEntryScollRange" id="a4f4de3f-9e7d-41bf-9a63-d79440b5ad58">
        <source>setFrmMoveEntryScollRange();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 November 2012	cnwer1	Initial creation CCMS HAT 2200

*/

vars

	maxYScroll : Integer;
begin

	self.tblMoveEntry.fitTableHeight();
	maxYScroll:= ((self.tblMoveEntry.clientHeight + self.tblMoveEntry.top).Integer -self.frmMoveEntry.clientHeight).max(0);

	self.frmMoveEntry.setScrollRange(ScrollBar_Vertical, 0,maxYScroll , 20, 100);
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setIsEnquiryMode" id="fb97cd0e-2116-4477-8863-d28644a2c049">
        <updating/>
        <source>setIsEnquiryMode(_value : Boolean) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
07 May 2010	cnwer1	Initial creation
07 Dec 2010 cnwer1 	par 25611
*/

vars

begin
	if self.isEnquiryMode = _value then
		return;
	endif;
	self.isEnquiryMode:=_value;
	if isEnquiryMode then 	
		self.myVMAgent.stopNotes;
		self.frmGetTask.visible:=false;
		self.frmTaskTable.visible:=true;
		self.frmMove.visible:=false;
		self.btnTaskMode.visible:=false;
		self.btnVoyDischarge.visible:=false; //epr par 27440 11/5/11
		self.addInfoDisplay(app.getErrorString(Cargo_enquiry_mode)) ;
		self.loadEnquiryCargo(self.tblTasks,null);
		
		//self.txtSearch.visible:=true;
		self.setupFrmTop(true);
		
	endif;
	
	
epilog

end;</source>
        <Parameter name="_value" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setTableMargins" id="39ea74d5-455f-4a08-8ece-d4964be574c4">
        <source>setTableMargins(_table : Table input) protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 April 2010	cnwer1	Initial creation

*/

vars
	i,
	numSheets	: Integer;
	tmpSheet	: JadeTableSheet;
begin
	
	numSheets := _table.sheets;
	foreach i in 1 to numSheets do
		tmpSheet := _table.accessSheet(i);
		tmpSheet.marginLeft := 10;
		tmpSheet.marginRight := 2;
		tmpSheet.marginTop := 1;
	endforeach;
epilog	

end;</source>
