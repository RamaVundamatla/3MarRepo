    <JadeMethod name="initReport" id="cfff409f-6913-463d-8d8e-22a1377cafc7">
        <updating/>
        <source>initReport() protected, updating;
// -------------------------------------------
// Created 11 May 2004 by cnwdvb1
// -------------------------------------------
// Changed On	By			Reason
// ----------	--------	-------------------------------------------
// 21/05/2014	cnwdap1		PAR #34176 Work Order Report dates option
vars
	now	,
	startDT,
	endDT 		: TimeStamp;
begin

	now := app.actualTimeServer;
	//if self.initStartDT = null then											// PAR #34176
	if self.initStartDT = null or self.myHarbour.woDateTimeSameAsView then		// PAR #34176
		startDT:=now;
	else
		startDT:=self.initStartDT;
	endif;
	
	//if self.initEndDT = null then												// PAR #34176
	if self.initEndDT = null or self.myHarbour.woDateTimeSameAsView then		// PAR #34176
		endDT:= now.cnEcAddDays(1);
	else
		endDT:=self.initEndDT;
	endif;
	//Par 9758: From date/time is now, to date/time is now + 1 day

	// set the defaults for the report
	self.tblEntry.setValueByName(ETRow_FromDate, startDT.date.shortFormatJMT);
//	self.txtFromDate.setTextFromDate(now.date);
	self.tblEntry.setValueByName(ETRow_FromTime, startDT.time.shortFormatJMT());
//	self.txtFromTime.time := now.time;
	
	//Increment the date by one

	self.tblEntry.setValueByName(ETRow_ToDate, endDT.date.shortFormatJMT());
//	self.txtToDate.setTextFromDate(now.date);
	self.tblEntry.setValueByName(ETRow_ToTime, endDT.time.shortFormatJMT());
//	self.txtToTime.time := now.time;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="initTable" id="11c4cd73-7bc8-4fd4-80b8-fe85cccab508">
        <source>initTable() protected;
// -------------------------------------------
// Created 11 May 2004 by cnwdvb1
// 06 Oct 2017	cnwma1  TFS #7257 JMT - Refactoring - Commodity Planning
// 17/07/2018	jlgdap1	TFS 39685 PEL1 Pilots vs Harbours
// -------------------------------------------
vars

	entTableControl : EntTableDef;

begin
	inheritMethod();
	entTableControl := app.myController.getEntTableDef(ETDef_WorkOrderReport);
	self.tblEntry.setEntTableDef(entTableControl, null, 'entTableDefSetupWarning');
	
	self.tblEntry.resetSize();
	self.tblEntry.optimiseHeadingColumn();
	self.setColorsForEntryTable(self.tblEntry);
	
	//self.myAssistant.comboBoxHMSPilot(self.cmbPilot, null);								// TFS 39685
	self.myAssistant.comboBoxHMSPilot(self.cmbPilot, null, self.myTerminal.myHarbour);		// TFS 39685
				
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="loadDataForFirstTime" id="8473d323-c218-44e1-a096-5595b84b40fd">
        <updating/>
        <source>loadDataForFirstTime() updating, protected;
//--------------------------------------------------
// Created:	01 December 2004 By: cnwgd1
//--------------------------------------------------
vars

begin
	inheritMethod();
	// Load user settings for report
	if self.myHarbour &lt;&gt; null then
		self.reportParam := self.myHarbour.allReportParams[app.getMyUserCode];
	endif;
	if self.reportParam &lt;&gt; null then
		
		//There is a Pilot class so use combo box instead of free text field
		self.cmbPilot.listIndex := self.cmbPilot.findString(1, self.reportParam.reportParam_Pilot);
		self.tblEntry.setValueByControlName(self.cmbPilot.name, self.cmbPilot.text);
		
		/*There is no class of object for the following. These fileds are free text fields in HMS6.3.4.
		//Tugmaster
		self.cmbTugmaster.listIndex := self.cmbTugmaster.findString(1, self.reportParam.reportParam_TugMaster);
		self.tblEntry.setValueByControlName(self.cmbTugmaster.name, self.cmbTugmaster.text);				
		//Supervisor
		self.cmbSupervisor.listIndex := self.cmbSupervisor.findString(1, self.reportParam.reportParam_Supervisor);
		self.tblEntry.setValueByControlName(self.cmbSupervisor.name, self.cmbSupervisor.text);		
		//Launchmaster
		self.cmbLaunchmaster.listIndex := self.cmbLaunchmaster.findString(1, self.reportParam.reportParam_Launchmaster);
		self.tblEntry.setValueByControlName(self.cmbLaunchmaster.name, self.cmbLaunchmaster.text);
		*/				
		
		//self.tblEntry.setValueByName(ETRow_Pilot, self.reportParam.reportParam_Pilot);
		
		self.tblEntry.setValueByName(ETRow_Tugmaster, self.reportParam.reportParam_TugMaster);		
		self.tblEntry.setValueByName(ETRow_Launchmaster, self.reportParam.reportParam_Launchmaster);
		self.tblEntry.setValueByName(ETRow_Supervisor, self.reportParam.reportParam_Supervisor);
	endif;
	
	self.tblEntry.moveFirst();
	self.tblEntry.setFocus();
end;</source>
        <access>protected</access>
    </JadeMethod>
