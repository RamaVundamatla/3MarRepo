    <JadeMethod name="createdByUnitTest" id="f336cf60-acb8-4944-a141-270d1e39dc5d">
        <source>createdByUnitTest(_remarks : String) : String;

/*

Purpose:		

Date			Who		Reason
14/07/2015		cnwmh5	Initial creation

*/
vars

	createdBy					: String;

begin

	createdBy := "Created by unit test " &amp; self.currentMethodBeingRun.getSchemaType().name &amp; "::" &amp; self.currentMethodBeingRun.name;
	if _remarks.cnContains(createdBy) then
		createdBy := null;
	endif;

	return createdBy;

epilog

end;</source>
