    <JadeMethod name="isSrcTermArea_Match" id="445f563a-4f02-4aff-a683-5a285dfeeb42">
        <source>isSrcTermArea_Match(_yaData: CM_YADataObjects): Boolean;
/*

Purpose:		TFS 41427	

Parameters:			

Return Value:		

Date		Who		Reason
12 October 2018	jlgab1	Initial creation

*/

vars
	transaction : CM_TITransaction;
	terminal : CM_Terminal;
	locn : String;
	location : CM_LocationsController;
	height : Integer;
	terminalArea : CM_TerminalArea;
	matches : Boolean;
begin

	transaction := self.myTransaction;
	if transaction = null then
		return false;
	endif;
	
	terminal := transaction.myTerminal;
	if terminal = null then
		return false;
	endif;
	
	locn := transaction.getLocationStr();
	
	if locn = null then
		return false;
	endif;
	
	terminal.findLocationFromString(locn, true, location, height);

	if location = null then
		return false;
	endif;
	
	terminalArea := location.myTerminalArea;
	
	matches :=  _yaData.matches(terminalArea);

	return matches; 

epilog

end;</source>
        <Parameter name="_yaData" type="CM_YADataObjects"/>
        <ReturnType type="Boolean"/>
