    <JadeMethod name="setSerialWeighbridge" id="b044f353-db3e-43d7-9d86-a281f4780449">
        <updating/>
        <source>setSerialWeighbridge(_laneDirection : Integer) : Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 February 2017	cnwns1	Initial creation
//2/10/2017  jlgns1 TFS 6865 PKT - Weighbridge Connection Issue
*/

vars
	wBridge : CM_WeighBridgeObj;
begin
	if app.computerName &lt;&gt; null then
		wBridge:= self.myTerminal.getWeighbridgeForComputer(_laneDirection = IN_YO);
		if wBridge &lt;&gt; null and	 wBridge.mySerialDetails &lt;&gt; null then
			self.myWeighBridge :=	wBridge;
			return true;
		endif;		
	endif;
	
	return false;
epilog

end;</source>
        <Parameter name="_laneDirection" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
