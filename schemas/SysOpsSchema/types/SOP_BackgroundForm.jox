vars

begin
	inheritMethod(_showCaptions);
	self.splitter1.top 	:= self.topMargin;
	self.splitter1.height := self.clientHeight - self.topMargin;
	self.splitter1.width	:= self.clientWidth;
	self.splitter1.cnEcResizeContents();
end;</source>
        <Parameter name="_showCaptions" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="edc3d9df-ed2a-4f2f-ab8c-af0eaf2a0eba">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 11 September 2025 22:10:16.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0006955, locale);
	btnAbort.translateBubbleHelp(Xlat_0003752, locale);
	btnAbort.translateCaption(Xlat_0003760, locale);
	btnAddBGP.translateBubbleHelp(Xlat_0003753, locale);
	btnAddBGP.translateCaption(Xlat_0003761, locale);
	btnDeleteBGP.translateBubbleHelp(Xlat_0003754, locale);
	btnDeleteBGP.translateCaption(Xlat_0003762, locale);
	btnEditBGP.translateBubbleHelp(Xlat_0003755, locale);
	btnEditBGP.translateCaption(Xlat_0003763, locale);
	btnErrorSetup.translateBubbleHelp(Xlat_0003748, locale);
	btnErrorSetup.translateCaption(Xlat_0003750, locale);
	btnFutureActorsDtls.translateCaption(Xlat_0026872, locale);
	btnOpenAuto.translateBubbleHelp(Xlat_0003756, locale);
	btnOpenAuto.translateCaption(Xlat_0003764, locale);
	btnStartBGP.translateBubbleHelp(Xlat_0003757, locale);
	btnStartBGP.translateCaption(Xlat_0003765, locale);
	btnStopAllBGP.translateBubbleHelp(Xlat_0003749, locale);
	btnStopAllBGP.translateCaption(Xlat_0003751, locale);
	btnStopBGP.translateBubbleHelp(Xlat_0003758, locale);
	btnStopBGP.translateCaption(Xlat_0003766, locale);
	btnViewBGP.translateBubbleHelp(Xlat_0003759, locale);
	btnViewBGP.translateCaption(Xlat_0003767, locale);
	mnuAdd.translateCaption(Xlat_0006956, locale);
	mnuBackground.translateCaption(Xlat_0006957, locale);
	mnuClear.translateCaption(Xlat_0006958, locale);
	mnuClearSingleRequest.translateCaption(Xlat_0006959, locale);
	mnuDebug.translateCaption(Xlat_0006960, locale);
	mnuDelete.translateCaption(Xlat_0006961, locale);
	mnuEdit.translateCaption(Xlat_0006962, locale);
	mnuInspect.translateCaption(Xlat_0015818, locale);
	mnuLogInfo.translateCaption(Xlat_0006963, locale);
	mnuProcessRequest.translateCaption(Xlat_0006964, locale);
	mnuRequests.translateCaption(Xlat_0006965, locale);
	mnuStart.translateCaption(Xlat_0006966, locale);
	mnuStop.translateCaption(Xlat_0006967, locale);
	mnuView.translateCaption(Xlat_0006968, locale);
end;</source>
    </JadeMethod>
