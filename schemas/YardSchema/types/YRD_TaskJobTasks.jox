        <source>txtMoveOnTime_lostFocus(editMask: JadeEditMask input) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 22/05/2018	jlgdap1		Initial creation TFS 38560 PEL1 Voyage Work Orders
