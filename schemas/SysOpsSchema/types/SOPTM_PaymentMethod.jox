    <JadeMethod name="setControlsForAddEdit" id="0c7639b4-a3aa-400e-b767-44a1f1a08292">
        <updating/>
        <source>setControlsForAddEdit() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 July 2012	cnwndl1	Initial creation	Par 29968

*/

vars
	theForm : SOP_TableMaintForm;

begin
  
  theForm := self.myForm;
	theForm.tblInput1.userInputEnabled := true;
			
	if theForm.mode = theForm.Mode_Add then
		theForm.tblInput1.clearValues;
		theForm.tblInput1.enableRowByName(ETRow_Code);
		theForm.tblInput1.enableRowByName(ETRow_Description);
		theForm.tblInput1.enableRowByName(ETRow_IsCheque);
		theForm.tblInput1.enableRowByName(ETRow_IsPOS);
		theForm.tblInput1.moveFirst();
		// call this last as sets cell input type (case etc)
		// if not called can get problems with case on entry. 
		theForm.tblInput1.gotFocus(theForm.tblInput1);		
		
	else
		// refresh the data from the newly created proxy
		self.showThumbnail(theForm.myProxyObject.CM_PaymentMethod);
		// cannot update code		
		theForm.tblInput1.enableRowByName(ETRow_Code);
		theForm.tblInput1.enableRowByName(ETRow_Description);
		theForm.tblInput1.enableRowByName(ETRow_IsCheque);
		theForm.tblInput1.enableRowByName(ETRow_IsPOS);
	endif;

	

end;</source>
    </JadeMethod>
