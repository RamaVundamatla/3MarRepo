    <JadeMethod name="processAttributeDependencies" id="813384c5-dff3-48a8-a877-468722e1b47f">
        <updating/>
        <source>processAttributeDependencies(_ediUserDefinedAssist : CMIF_EDIUserDefinedAssist input; _strIdentifier : String; _reset : Boolean; _xlationOperator :CM_Operator) updating;
//
// Date			Who		Reason
// 28 Apr 2011	cnwrs1	ccms 2044 - added strIdentifier
//20 Mar 2015	cnwrs1	Par 34702 - Add support for JMT XML with implied header
// 20 Sep 2017	jlgrs1	TFS 5457 Make JMTInternal XML work
// 08 May 2018	jlgrs1	TFS 36425 SingleLine Booking partial processing not working
// 04 Mar 2019	jlgrs1	TFS 41913 STWR - Reconfiguration of the EDI Operation form to better handle EDI collection locks while loading 
//
vars
	ediTI : CM_EDITrackedItem;
	str : String;
begin
	inheritMethod(_ediUserDefinedAssist, _strIdentifier, _reset, _xlationOperator);
	if _reset then
		foreach ediTI in _ediUserDefinedAssist.allChildrenEDITIs do
			str := str &amp; ediTI.String&amp;' ';
			if ediTI.id = null then
				ediTI.setId(self.id);
			endif;
		endforeach;
		_ediUserDefinedAssist.allChildrenEDITIs.clear;
//		_ediUserDefinedAssist.myCurrentBOLHeader := null;
//		_ediUserDefinedAssist.myCurrentBOLDetail := null;
//		_ediUserDefinedAssist.currentBOLCode := null;
	else	
		if self.myEDIData.isKindOf(CM_EDIDataShipManifest) then 
	//		_ediUserDefinedAssist.currentVoyageCode := self.voyageCode;	// cnwrl1 09/06/2010 PAR 24299 - what it was
			_ediUserDefinedAssist.currentVoyageCode := self.getVoyageCode();
		endif;
		
		_ediUserDefinedAssist.myCurrentBOLHeader	:=	self;	// cnwdad1 01/07/2010 - PAR #24177.
		_ediUserDefinedAssist.myCurrentBOLDetail	:=	null;	// cnwdad1 01/07/2010 - PAR #24177.
		_ediUserDefinedAssist.currentBOLCode		:=	self.id;
	endif;
end;</source>
        <Parameter name="_ediUserDefinedAssist" type="CMIF_EDIUserDefinedAssist" usage="input"/>
        <Parameter name="_strIdentifier" type="String"/>
        <Parameter name="_reset" type="Boolean"/>
        <Parameter name="_xlationOperator" type="CM_Operator"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="e62c5bc4-fe7d-43aa-a0ec-37a6407b2318">
        <updating/>
        <source>setForUpdate(_proxyEDITI: SelfType) updating;
//
// cnwrs1 sept 2009 CCMS Messina 1008
//
// Changed On	By			Reason
// ----------	--------	----------------------------------------------------
// 03/12/2013	cnwdap1		PAR #33019 CCMS DPH 2285 New BOL Fields
// 09/09/2015   cnwma1      PAR #36797 Can't create BOL via EDI
// 01/12/2022   navma1 		ChangeRequest 55424: MTN - Improve the performance of Edi file loading
vars
	prop : Property;
	propDict : PropertyNDict;
begin
	inheritMethod(_proxyEDITI);
	
	propDict := self.class.getProperties;
	foreach prop in propDict do
		if self.canUserSet(prop.name) then
			// bypass all type integrity checking in the name of convenience!!!
			self.setPropertyValue(prop.name, _proxyEDITI.getPropertyValue(prop.name));
		endif;
	endforeach;
	
	/*
	01.12.2022 navma1 #55424
	self.setServiceOrderNbr(_proxyEDITI.CM_EDIBOLHdrTI.getServiceOrderNbr());		// PAR #33019
	self.setPONbr(_proxyEDITI.CM_EDIBOLHdrTI.getPONbr());							// PAR #33019
	self.setVehicle(_proxyEDITI.CM_EDIBOLHdrTI.getVehicle());						// PAR #36797
	*/
end;</source>
        <Parameter name="_proxyEDITI" type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setPONbr" id="a6d8ff5e-9914-48ef-97ca-bff852b0db86">
        <updating/>
