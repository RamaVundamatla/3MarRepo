        <type name="TestAppControl"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="myXMLSessionScript" id="4204c069-2e4a-4859-9cba-c97c52c49009">
        <embedded/>
        <type name="XMLSessionScript"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <PrimAttribute name="runningSilent" id="aa39fd8b-e2b3-4419-bceb-ace19f04a457">
        <embedded/>
        <type name="Boolean"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="doProcessUpdateNote" id="86d2954c-3fde-4eb2-8410-c82c4d6c89de">
        <updating/>
        <source>doProcessUpdateNote() updating;

/*

Purpose:			


Return Value:		


Date		Who		Reason
28 October 2004	cnwkpd1	Initial creation

*/

vars
	i				: Integer;
	returnedMsg,
	xmlMessage		: String;
	payload			: XMLMessagePayload;

begin
	runningSilent := false;
	
	logMessage("Update notification received");
	
	if myControl.state = TestAppControl.STATE_GO then
	
		if not setupMyXMLSession then
			return;
		endif;

		setCaption;
		
		// If not logging on for each iteration, then logon first
		if not myControl.logonForEachIteration then
			if not self.sendLogonMessage(self.myXMLSessionScript) then
				return;
			endif;
		endif;
	
		runningSilent := myControl.silentMode;
		
		while i &lt; myControl.numMessages do : outerLoop

			logMessage("Starting script iteration " &amp; (i + 1).String &amp; " of " &amp; myControl.numMessages.String);

			if myControl.logonForEachIteration then
				if not self.sendLogonMessage(self.myXMLSessionScript) then
					return;
				endif;
			endif;
		
			foreach payload in myXMLSessionScript.allXMLMessages do

				// Need to get latest version of control object
				// in case we've been told to stop
				sharedLock(myControl);
				unlock(myControl);
	
				if myControl.state = TestAppControl.STATE_STOP then
					logMessage("Told to stop processing");
					break outerLoop;
				elseif myControl.state = TestAppControl.STATE_TERMINATE then
					break outerLoop;
				endif;
				
				// Must be a go, so send message
				sendWebServiceMessage(payload);

				// Uncomment to introduce a delay between messages
//					process.sleep(10000);
				
			endforeach;
			
			i := i + 1;
		endwhile;
	endif;
	
	runningSilent := false;
	
	if myControl.state = TestAppControl.STATE_TERMINATE then
		logMessage("Terminate requested");
		terminate;
	endif;
	
	logMessage("Stopped processing");


epilog
	if myXMLSessionScript &lt;&gt; null then
		unlock(myXMLSessionScript);
	endif;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="getLogStatistics" id="f9960141-3ef0-4438-80aa-bfa330bf3760">
