//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	// deleted via parent-child relationship
	create self.myUpdateAuditAgent transient;

end;</source>
    </JadeMethod>
    <JadeMethod name="exHandlerConsigneeCmbOrderFlag" id="c3904bb7-2ed1-4cd3-9fed-bff65023088d">
        <source>exHandlerConsigneeCmbOrderFlag(exObj : Exception; pCC : CM_ConsigneeConsignor) : Integer protected;
// ---------------------------------------------------------------------------
// Created:     19 August 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
constants
	KeyAlreadyUsed	: Integer = 1310;
	
vars
	theCode	: String;

begin
	
	if exObj.errorCode &lt;&gt; KeyAlreadyUsed then
		return Ex_Pass_Back;
	endif;
	
	abortTransaction;
   
	if pCC &lt;&gt; null then
		theCode := pCC.code;
	else
		theCode := '&lt;unknown&gt;';
	endif;	
  
	app.raiseCMException1(DupConsigneeDescrForCombo, theCode, null, null);
	
	return Ex_Abort_Action;
	
end;</source>
        <access>protected</access>
        <Parameter name="exObj" type="Exception"/>
        <Parameter name="pCC" type="CM_ConsigneeConsignor"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getRealObjectAndEditionCheck" id="39ed80bb-de27-474b-b46c-a9581d7ceb4b">
        <source>getRealObjectAndEditionCheck(_pxyObject : CM_Object; _objDescr : String;
						_passport : CM_Passport input) : CM_Object protected;
// ---------------------------------------------------------------------------
// Created:     03 February 2003 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	realObject		: CM_Object;
	expectedEdition	: Integer;

begin

	app.setContinueCMExceptions(false);

	_pxyObject.pxyGetRealObjectAndEdition(realObject, expectedEdition);

	if realObject = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, _pxyObject.class.name, null, null);
		return realObject;
	endif;
	
	exclusiveLock(realObject);
	if _passport.noErrors and realObject.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, _objDescr, null, null);
		return realObject;
	endif;
	
epilog
	return realObject;

end;</source>
        <access>protected</access>
        <Parameter name="_pxyObject" type="CM_Object"/>
        <Parameter name="_objDescr" type="String"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="reinstateRejectTrackedItem" id="106e7af0-7d00-4d32-90bf-5ca59c4d733e">
        <source>reinstateRejectTrackedItem(_ti : CM_TrackedItem input; _reason : String; _location : CM_LocationsController;
				_passport : CM_Passport input) : Boolean protected;

// cnwdvb1 29 November 2002 

vars
	moveController	: CMIF_MoveController;
	cancelSave		: Boolean;
begin

	exclusiveLock(_ti);

	// LEAVE VALIDATION ON LOG FOR NOW.		
	// need to do validation here
//	_ti.validateTrackedItem(updCntrl);

	create moveController transient;
	moveController.isForcedMove		:= true;
	moveController.isSystemMove 	:= true;
	moveController.setMoveMode(REAL_MODE);
	moveController.setMyTrackedItem(_ti);
	moveController.setMyToPrimaryLocation(_location);
	moveController.tiTransType	:= TRANS_TYPE_ReinstateReject;

	app.myUtilityUA.utlUpdateMoveTrackedItem(moveController, _passport);
	
epilog
	delete moveController;
	
	return _passport.noErrors;
	
end;</source>
        <access>protected</access>
        <Parameter name="_ti" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_reason" type="String"/>
        <Parameter name="_location" type="CM_LocationsController"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="rejectTrackedItem" id="020ee460-f355-4f44-a883-22f063467ea6">
        <source>rejectTrackedItem(_ti: CM_TrackedItem input; _updCntrl : CMIF_TIUpdateController input;
				_passport : CM_Passport input) : Boolean protected;

// Protected as should only be called from a utl.

vars

begin

	exclusiveLock(_ti);
		
	// need to do validation here
	_ti.validateTrackedItem(_updCntrl, _passport);

	if _passport.noErrors then
		_ti.rejectTrackedItem(_updCntrl, _passport);
	endif;
				
epilog
	return _passport.noErrors;
	
end;</source>
        <access>protected</access>
        <Parameter name="_ti" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_updCntrl" type="CMIF_TIUpdateController" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setupInvoiceStatus" id="9762c2a1-606d-4f7b-8c37-42761de2959a">
        <source>setupInvoiceStatus(	_invoiceProcess : CM_InvoiceProcess;
					_statusId 		: Integer;
					_priority 		: Integer;
					_description	: String;
					_colour			: Integer; // 29 Nov 2022 navvt20 TFS 55548
					_pinEmailOffset : Integer	) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 Jan 2019	jlgsl4	TFS 39618 - LNX - Initial creation
29 Nov 2022 navvt20 Task CR 55298 TASK 55548: UI - Add Colour to Invoice Status maintenance.
*/

vars
	template : CM_EmailTemplate;
	pxyStatus, realStatus, status : CM_InvoiceStatus;
	rootRole : CM_SecurityRoleTerminalRoot;
	invalidId : Boolean;
begin
	realStatus := _invoiceProcess.allStatuses[_statusId];
	
	// jlgmd1 21/01/2021 8.6.2.100 Cut
	// A bit of a bodge, but handle Statuses being renumbered. (Which they shouldn't be!)
	// eg. LNX 'Approved' went from 10 to 11
	if realStatus = null then
		foreach status in _invoiceProcess.allStatuses do
			if status.description = _description then
				realStatus := status;
				invalidId := true;
				break;
			endif;
		endforeach;
	endif;
	
	if realStatus = null then
		create template transient; // ### TFS 52184 20OCT2021 NAVAB1
		template.setProxyForInvStatus(_pinEmailOffset,_statusId,_invoiceProcess.code &amp; " " &amp;  _description); // ### TFS 52184 20OCT2021 NAVAB1

		create pxyStatus transient;
		// pxyStatus.setProxy(_statusId, _priority, _description, _invoiceProcess, template); // ### TFS 52184 20OCT2021 NAVAB1 // 29 Nov 2022 navvt20 TFS 55548
		pxyStatus.setProxy(_statusId, _priority, _description, _invoiceProcess, _colour,template);  // ### TFS 52184 20OCT2021 NAVAB1 // 29 Nov 2022 navvt20 TFS 55548
		
		
		app.myUtilityCA.utlCreateInvoiceStatus(pxyStatus, realStatus, app.myPassport);
	else
		pxyStatus := app.createUpdateProxy(realStatus).CM_InvoiceStatus;
		// pxyStatus.setProxy(_statusId, _priority, pxyStatus.description, _invoiceProcess, null); // 29 Nov 2022 navvt20 TFS 55548
// ### TFS BUG 60902 16OCT2023 NAVAB1		pxyStatus.setProxy(_statusId, _priority, pxyStatus.description, _invoiceProcess,_colour, null); // 29 Nov 2022 navvt20 TFS 55548
		pxyStatus.setProxy(_statusId, _priority, pxyStatus.description, _invoiceProcess,pxyStatus.colour, null); // 29 Nov 2022 navvt20 TFS 55548 // ### TFS BUG 60902 16OCT2023 NAVAB1	- use current colour

		app.myUtilityUA.utlUpdateInvoiceStatusNew(pxyStatus, app.myPassport);
	endif;
	
	if not app.myPassport.noErrors then
		app.writeLog(method.qualifiedName &amp; " Failed to create CM_InvoiceStatus " &amp; _description &amp; "!!!", LogINFO);
		app.writeLog(method.qualifiedName &amp; " " &amp; app.myPassport.getErrorsAsString, LogINFO);
	else
		// ### JIRA 35465 28JUL2025 NAVAB1
		foreach rootRole in CM_SecurityRoleTerminalRoot.instances do
			rootRole.allInvoiceStatusesMaint.addNoDuplicates(realStatus,false);
			app.writeLog(method.qualifiedName &amp; " Adding invoice status to terminal root role " &amp; _description &amp; "!!!", LogINFO);
		endforeach;		
	
	endif;

epilog
	delete pxyStatus;
end;</source>
        <access>protected</access>
        <Parameter name="_invoiceProcess" type="CM_InvoiceProcess"/>
        <Parameter name="_statusId" type="Integer"/>
        <Parameter name="_priority" type="Integer"/>
        <Parameter name="_description" type="String"/>
        <Parameter name="_colour" type="Integer"/>
        <Parameter name="_pinEmailOffset" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setupVoyageStatus" id="42c3c9df-f3df-4d96-8346-28c79d0e439c">
        <source>setupVoyageStatus(	_voyageProcess : CM_VoyageProcess; 
					_statusId : Integer;
					_priority : Integer;
					_description : String	) protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 05/06/2018	jlgdap1		Initial creation TFS 38851 PEL1 Voyage Statuses INAPORTNET
// 11 Oct 2021	jlier1		TFS 51963
vars
	pxyStatus, realStatus : CM_VoyageStatus;
	rootRole : CM_SecurityRoleTerminalRoot;

begin
		
	realStatus := _voyageProcess.allStatusesById[_statusId];
	if realStatus = null then
		create pxyStatus transient;
		pxyStatus.setProxy(_statusId, _priority, _description, _voyageProcess, null, null,false);
	else
		pxyStatus := app.createUpdateProxy(realStatus).CM_VoyageStatus;
		pxyStatus.setProxy(pxyStatus.id, _priority, pxyStatus.description, _voyageProcess, null, pxyStatus.reportToRun,false);
	endif;
	
	if realStatus = null then
		app.myUtilityCA.utlCreateVoyageStatus(pxyStatus, realStatus, app.myPassport);
	else
		app.myUtilityUA.utlUpdateVoyageStatus(pxyStatus, app.myPassport);
	endif;
	if app.myPassport.noErrors then
		foreach rootRole in CM_SecurityRoleTerminalRoot.instances do
			rootRole.allVoyageStatusesMaint.addNoDuplicates(realStatus, false);
		endforeach;		
	else
		app.writeLog(method.qualifiedName &amp; " Failed to create CM_VoyageStatus " &amp; _description &amp; "!!!", LogINFO);
		app.writeLog(method.qualifiedName &amp; " " &amp; app.myPassport.getErrorsAsString, LogINFO);
	endif;

epilog
	delete pxyStatus;
end;</source>
        <access>protected</access>
        <Parameter name="_voyageProcess" type="CM_VoyageProcess"/>
        <Parameter name="_statusId" type="Integer"/>
        <Parameter name="_priority" type="Integer"/>
        <Parameter name="_description" type="String"/>
    </JadeMethod>
    <JadeMethod name="setupVoyageStatusDelPriority" id="f67d8d6c-dd9b-4aee-b301-1c822278d0aa">
        <source>setupVoyageStatusDelPriority(_process :CM_VoyageProcess) protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 05/06/2018	jlgdap1		Initial creation TFS 38851 PEL1 Voyage Statuses INAPORTNET
//
vars
	statusesToDelete : CM_ObjectArray;
	iter : Iterator;
	status : CM_VoyageStatus;
	obj : Object;

begin
	create statusesToDelete transient;
	iter := _process.allStatuses.createIterator();
	_process.allStatuses.startKeyGeq(10000, iter);
	while iter.next(status) do
		statusesToDelete.add(status);
	endwhile;
	if statusesToDelete.size &lt;&gt; null then
		app.writeLog(method.qualifiedName &amp; " Need to delete " &amp; statusesToDelete.size.String &amp; " statuses for process " &amp; _process.description, LogINFO);
		foreach obj in statusesToDelete do
			app.writeLog(method.qualifiedName &amp; " Deleting status " &amp; obj.CM_VoyageStatus.description &amp; " with priority " &amp; obj.CM_VoyageStatus.priority.String, LogINFO);
		endforeach;
	endif;
	statusesToDelete.purge;

epilog
	delete statusesToDelete;
	delete iter;
end;</source>
        <access>protected</access>
        <Parameter name="_process" type="CM_VoyageProcess"/>
    </JadeMethod>
    <JadeMethod name="setupVoyageStatusMovePriority" id="f86e5feb-c794-40a9-bd1d-256aa88f3c7f">
        <source>setupVoyageStatusMovePriority(_process : CM_VoyageProcess) protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 05/06/2018	jlgdap1		Initial creation TFS 38851 PEL1 Voyage Statuses For INAPORTNET
//
vars
	currentStatuses : CM_ObjectArray;
	obj : Object;
	realStatus : CM_VoyageStatus;

begin
	// in case there's been a change in priority, get everything in priority order out of the way
	// Add 10000 to all current priorities
	create currentStatuses transient;
	_process.allStatuses.copy(currentStatuses);
	foreach obj in currentStatuses do
		realStatus := obj.CM_VoyageStatus;
		realStatus.setPropertyValue(CM_VoyageStatus::priority.name, realStatus.priority + 10000);
	endforeach;
epilog
	delete currentStatuses;
end;</source>
        <access>protected</access>
        <Parameter name="_process" type="CM_VoyageProcess"/>
    </JadeMethod>
    <JadeMethod name="trxSealsChkDamLandTeklogix" id="55c9ac23-d365-471e-a600-5f7d4a61ccc5">
        <source>trxSealsChkDamLandTeklogix( _ti : CM_TrackedItem input;
							_groundLC : CM_LocationsController input;
							_job : CM_VoyageJob;
							_wle : CM_WorkListEntry;
							_passport : CM_Passport input);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
13 April 2011	cnwndl1	Initial creation	CCMS 1216

*/

vars

	rtQueueEntry : CM_RTQueueEntry;
	
begin

	if _ti = null then
		return;
	endif;
		
	if _ti.getPrimaryLocation(QUEUE_MODE) = null then
		if _ti.getPrimaryLocation(PLANNING_MODE) &lt;&gt; null then
			_ti.doQueuedMoveToPlan(null, _passport);// ### TFS 51988 17SEP2021 NAVAB1
			// Added this secondary check to handle the autoplanning of DLRs
			if _ti.getPrimaryLocation(QUEUE_MODE) = null then
				_ti.autoPlan(QUEUE_MODE, _job, null, null, _passport);
			endif;
		else
			_ti.autoPlan(QUEUE_MODE, _job, null, null, _passport);
		endif;
			
		if _passport.hasErrors then
			return;
		endif;
	endif;
	
	_ti.receiveFromShip(null, _groundLC,null,null, null,  _passport); // ### TFS 51988 17SEP2021 NAVAB1
	
	foreach rtQueueEntry in  _wle.allRTQueueEntries do
		rtQueueEntry.sendNotesForRelatedEntry();
	endforeach;
		
epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_groundLC" type="CM_LocationsController" usage="input"/>
        <Parameter name="_job" type="CM_VoyageJob"/>
        <Parameter name="_wle" type="CM_WorkListEntry"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxUpdateROROGraphicPolygon" id="69cc5d65-c5ca-4769-8955-991127a98d93">
        <updating/>
        <source>trxUpdateROROGraphicPolygon(_realDeckItemLayout:CM_DeckItemLayout input; _points : PointArray; _passport : CM_Passport input) updating;
//
//22 Jan 2013	cnwrs1	Par30951 include Exports as ROBs for EDI Proposed
//
vars
	 
begin
	
	_realDeckItemLayout.setPointsPolygon( _points);
	
	if _realDeckItemLayout.type = DeckItemLayoutType_Lane then // TFS 39254
		_realDeckItemLayout.myDeckItem.setLengthFromLayout(_points); // TFS 39254
	endif; // TFS 39254
	
	// PAR 28318
	 if not _realDeckItemLayout.moveAftWithForward(false) then	//22 Jan 2013	cnwrs1	Par30951 include Exports as ROBs for EDI Proposed
	 	 _realDeckItemLayout.moveForwardWithAft(false);	//22 Jan 2013	cnwrs1	Par30951 include Exports as ROBs for EDI Proposed
	endif;

	 _realDeckItemLayout.causeEvent(EVENT_RORO_ITEM_UPDATE,true,null);
epilog
	
end;</source>
        <Parameter name="_realDeckItemLayout" type="CM_DeckItemLayout" usage="input"/>
        <Parameter name="_points" type="PointArray"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="updAuditConfigSetIsEnable" id="6f339411-c48e-4aaa-824e-72729b37599a">
        <source>updAuditConfigSetIsEnable( _isEnable : Boolean; _real : CM_AuditConfig input; _passport : CM_Passport input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 January 2021	jlgndl1	Initial creation	TFS 50152

*/

vars

begin

	self.initialiseActivity();
	
	app.setContinueCMExceptions(true);
	
	//special non standard validation on this one
	if _real = null then
		app.raiseCMException(Invalid_persistent_object, null, null );
	endif;
	if _real.isEnabled = _isEnable then
		//nothing to do
		return;
	endif;
	if _real.isEnabled and not _isEnable then
		//they are disabling auditing, give warning
		app.raiseCMWarning1( Sure_want_disable_auditin, _real.getDescription, null, null, null );
	endif;
	
	app.setContinueCMExceptions(false);

	exclusiveLock( _real );
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(_real, true);		
	endif;
	
	_real.setIsEnabled( _isEnable );
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(_real, false);		
	endif;


epilog

end;</source>
        <Parameter name="_isEnable" type="Boolean"/>
        <Parameter name="_real" type="CM_AuditConfig" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="updRealInvoicePaymentStat" id="5d52ae2f-4623-4bfa-a81d-45ef6140f857">
        <source>updRealInvoicePaymentStat( invoice : CM_Invoice input; _paymentStatus : Integer; _wsdl : String; _msgArray : String200Array input; _passport : CM_Passport input );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 June 2019	jlgndl1	Initial creation	TFS 45312

*/

vars

	baseMsg : String;
	msg : String;

begin

	self.initialiseActivity();
	
	
	baseMsg :=  method.qualifiedName &amp; ' ' &amp; _wsdl &amp; " "; 
	
	app.setContinueCMExceptions(true);

	exclusiveLock( invoice );
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric( invoice, true );
	endif;
	
	if _passport.noErrors then
		invoice.setPaymentStatus( _paymentStatus );
		if _passport.noErrors then
			msg :=  baseMsg &amp; "Update Invoice Payment Status to " &amp; _paymentStatus.String &amp; " Invoice :" &amp; invoice.exportCurrencyCode;
			_msgArray.add( msg );
		endif;
	endif;
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(invoice, false);
		invoice.causeEvent( invoice.myTerminal.getTerminalEvent(Event_InvoiceUpdate), false, invoice );	
	endif;
	
epilog

end;</source>
        <Parameter name="invoice" type="CM_Invoice" usage="input"/>
        <Parameter name="_paymentStatus" type="Integer"/>
        <Parameter name="_wsdl" type="String"/>
        <Parameter name="_msgArray" type="String200Array" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="updateCommodityMapCode" id="79988e48-01ad-43cc-a550-d20b2e37421a">
        <source>updateCommodityMapCode(_oldCode, _newCode : String);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 06/12/2018	jlgdap1		Initial creation TFS 42083 PEL1 Cargo Transaction Map - Commodity update
//
vars
	commodityMap : CM_CommodityMap;
	maps: DynaDictionary;
	iter : Iterator;

begin
	create maps transient;
	maps.setMembership(CM_CommodityMap);
	maps.addMemberKey(CM_CommodityMap::commodityCode.name, false, false);
	maps.endKeys(true);
	
	CM_CommodityMap.instances.copy(maps);
	
	iter := maps.createIterator;
	maps.startKeyGeq(_oldCode, iter);
	while iter.next(commodityMap) do
		if commodityMap.commodityCode &lt;&gt; _oldCode then
			break;
		endif;
		
		commodityMap.setCommodityCode(_newCode);
	endwhile;
epilog
	delete maps;
	delete iter;
end;</source>
        <Parameter name="_oldCode" type="String"/>
        <Parameter name="_newCode" type="String"/>
    </JadeMethod>
    <JadeMethod name="updateTICustomsEntryNum" id="1f942750-4875-4bae-9c72-905268262269">
        <source>updateTICustomsEntryNum(_theRealTI : CM_TrackedItem io; _theCENumber : String; _ediVoyageCode: String; _clear : Boolean; _passport : CM_Passport input);
//
// cnwrs1 22953 5 feb 2010
//
vars
	txnParams		: CMIF_ConnectParams;
	aTITrans		: CM_TITransaction;
begin
	if _clear and (_theCENumber.trimBlanks = null) then
		//this is required so raise exception
	//	app.raiseCMException1(REQUIRED_FIELD, 'Customs Entry Number', 'Customs Entry Number', self);
		app.raiseCMException(Input_required_field_custEnt, 'Customs Entry Number', self); // cnwdb2	PAR 35364
		return;
	endif;	
	
	if not _clear then
		return;
	endif;
	
	create txnParams transient;
	txnParams.type			:= TRANS_TYPE_CUSTSTOP_CLRD;
	txnParams.myTrackedItem := _theRealTI;
	txnParams.urNumber 		:= "1";
	txnParams.userId 		:= _passport.userCode;
	aTITrans := _theRealTI.createTransaction(txnParams, _passport);	
	aTITrans.CM_CustomStopClear.setCustomsDetails(_theCENumber, _ediVoyageCode);
	
	_theRealTI.setCustomsEntryNumber(_theCENumber);
	if _theCENumber &lt;&gt; null then
		_theRealTI.removeStopsToBeProcessed(StopProcessEDICustomImport); //cnwrs1 July 2007 par 14494 stops
	endif;
	// no need to cause event as theRealTI is updated above so the
	// event will get sent through by JADE
	//theRealTI.causeEvent(Object_Update_Event, false, theRealTI); // AKB2004DEC.
epilog
	delete txnParams;
end;
</source>
        <Parameter name="_theRealTI" type="CM_TrackedItem" usage="io"/>
        <Parameter name="_theCENumber" type="String"/>
        <Parameter name="_ediVoyageCode" type="String"/>
        <Parameter name="_clear" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlActivateStopRequest" id="90f72ec4-7700-4ae4-be1a-7c1e18470c00">
        <source>utlActivateStopRequest(_request :CM_EventRequestStops input; _passport :CM_Passport input);
// ---------------------------------------------------------------------------
// Created:     14 December 2010 by cnwcs5 ccms mes 1112 / par 24464
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	expectedEdition	: Integer;
begin
	self.initialiseActivity();
	
	// do any pre-validation locks
	
	// do validation
	self.raiseExceptionIfNull(_request, 'Stop Request');

	app.setContinueCMExceptions(true);
	
	app.myValUA.valActivateStopRequest (_request);
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;

	if _passport.noErrors then
		// This is only required if the class is being auditted
		self.myUpdateAuditAgent.audUpdateGeneric(_request, true);
	endif;

	if _passport.noErrors then
		// do updates
		_request.activate;
	endif;

	if _passport.noErrors then
		// This is only required if the class is being auditted
		self.myUpdateAuditAgent.audUpdateGeneric(_request, false);
	endif;

end;</source>
        <Parameter name="_request" type="CM_EventRequestStops" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlAddHMSResourceUsed" id="c49e587c-809d-43a8-a9ff-50db64f0ca73">
        <updating/>
        <source>utlAddHMSResourceUsed(_pxyResourceUsed : HMS_ResourceUsed input; _movement : HMS_VoyageMovement input; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     14 June 2012 by cnwjre1
//
// Purpose:     Add an HMS resource used to a voyage movement without going through the unnecessary update of the movement
//
// Parameters:  Proxy resource usage, persistent movement, passport
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	resourceUsed	: HMS_ResourceUsed;

begin

	self.initialiseActivity();
	
	// do any pre-validation locks
	
	// do validation
	self.raiseExceptionIfNull(_pxyResourceUsed, 'HMS Resource Used');
	self.raiseExceptionIfNull(_movement, 'Movement null');

	app.setContinueCMExceptions(true);
	
	_pxyResourceUsed.validateForUpdate(_passport);

	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	if _passport.noErrors then
		// do updates
 			create resourceUsed persistent;
			// Add resource to perm coll 
			_movement.allResourceUsed.add(resourceUsed);
			// Create 'Resource Booking' Transaction
			resourceUsed.setForCreate(_pxyResourceUsed, _passport);
	endif;

end;</source>
        <Parameter name="_pxyResourceUsed" type="HMS_ResourceUsed" usage="input"/>
        <Parameter name="_movement" type="HMS_VoyageMovement" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlAddToReserveDetail" id="735e35fa-a0f0-4c17-8c03-d04e3dc8c1a1">
        <updating/>
        <source>utlAddToReserveDetail(_reserveDetail : CM_ReserveDetail input; _ti : CM_TrackedItem input; _passport : CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 September 2014	cnwndl1	Initial creation	Par 34717 / CCMS 2384

*/

vars

	br : CM_BulkRelease;
begin

	_reserveDetail.addTI( _ti ); 
	
	//09 Nov 2015	NDL	Par 37152
	//01 Jul 2016	NDL the code above conditionally adds an 'Release Assigned trx'
	br := _reserveDetail.myReserveHeader;
	
	if br &lt;&gt; null then	
		//epr TFS 2329 26/7/16 check for same trx done in createAssignedTransaction method
		br.createAssignedTransaction( _ti, false );	
	endif;
	
	self.updateObjectEdition(_reserveDetail);
	if _reserveDetail.myReserveHeader &lt;&gt; null then
		self.updateObjectEdition(_reserveDetail.myReserveHeader);
	endif;

epilog

end;</source>
        <Parameter name="_reserveDetail" type="CM_ReserveDetail" usage="input"/>
        <Parameter name="_ti" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlAddVVRWayBillPrint" id="80314985-fec7-44ae-8f50-9946d97c38fb">
        <updating/>
        <source>utlAddVVRWayBillPrint(	_vvr : CM_VehicleVisitRecord input;
						_pxyWaybillPrint : CM_WaybillPrintDetail;
						_passport : CM_Passport input
						) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 August 2015	cnwndl1	Initial creation	Par 36777

*/

vars
	realWaybillPrint : CM_WaybillPrintDetail;
	vvrd : CM_VehicleVisitRecordDetail;
begin
	// create the VVRD to record the waybill print details.
	create realWaybillPrint;
	realWaybillPrint.setForUpdate( _pxyWaybillPrint );
	
	vvrd := _vvr.createVisitRecordDetail (VisitRecord_WayBillPrint, realWaybillPrint, null);
	if vvrd &lt;&gt; null then
		_vvr.causeEvent(_vvr.myTerminal.getTerminalEvent(EVENT_VEHICLEVISIT_UPDATE), false, _vvr);
	else
		delete realWaybillPrint;
	endif;

epilog

end;</source>
        <Parameter name="_vvr" type="CM_VehicleVisitRecord" usage="input"/>
        <Parameter name="_pxyWaybillPrint" type="CM_WaybillPrintDetail"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlAddVVRWeighing" id="d58fdf6c-637a-43a3-91b6-b97a4007d677">
        <updating/>
        <source>utlAddVVRWeighing(_vvr : CM_VehicleVisitRecord input; _pxyWeighing :CM_VehicleVisitWeighing; _passport: CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 March 2014	cnwndl1	Initial creation	Par 33268

*/

vars
	weighing : CM_VehicleVisitWeighing;
	visitType : Integer;
	weightDiff,
	weightingIn,
	cargoWeight  : Decimal[16,4];
	cargo : CM_TrackedItem;
	allTIs : CM_TISet;
	tiUpdateCntrlr : CMIF_TIUpdateController;
	lastOutwardReading : CM_VehicleVisitRecordDetail;
begin
	// create the VVRD for the weighing
	create weighing;
	weighing.setForUpdateFromProxy( _pxyWeighing, app.myPassport );
	//epr TFS 44965 3/7/19
	visitType:=VisitRecord_WeighBridge;
	if _pxyWeighing.myWeighBridge &lt;&gt; null and _pxyWeighing.myWeighBridge.isTwoReadings then
		if _vvr.hasWeighInVVRD then
			visitType:=VisitRecord_WeighBridgeOut;
			weightingIn:=_vvr.getWeighBridgeWeight(VisitRecord_WeighBridgeIn);
			if _vvr.isOnlyReceivingCargo then
				if not _vvr.vehicle.locationsController.allTrackedItems.isEmpty then
					//not unloaded yet, wants another weigh in record!
					visitType:=VisitRecord_WeighBridgeIn;
				else
					cargoWeight:=weightingIn - weighing.weighFromWeightBridge;	
					create allTIs transient;
					_vvr.getReceivedCargoInYard(allTIs);
					cargo:=allTIs.first;
					if cargo &lt;&gt; null then
						if cargo.myCargoType.allowDuplicates then
							lastOutwardReading := _vvr.getVVRDOfType(VisitRecord_WeighBridgeOut);	//09 Jul 2019	NDL	TFS 44965
							if lastOutwardReading = null then
								weightDiff := cargoWeight - _vvr.getTotalWeightReceived();
							else
								//if there is already an existiong weigh outward, we only want to adjust the cargo weight, by the difference between these two
								// beacuase the cargo will have alreday been adjusted relative to teh inward weight.
								weightDiff := cargoWeight - ( lastOutwardReading.getExtraInfo_WeighingWeight() - _pxyWeighing.weighFromWeightBridge );
							endif;
						else
							weightDiff := cargoWeight - cargo.totalWeight;
						endif;
					endif;
				endif;
	
			elseif _vvr.isOnlyReleasingCargo then
				if _vvr.vehicle.locationsController.allTrackedItems.isEmpty then
					//not loaded yet, wants another weigh in record!
					visitType:=VisitRecord_WeighBridgeIn;
				else
					cargoWeight:= weighing.weighFromWeightBridge - weightingIn;
					cargo:=_vvr.getVehicle.locationsController.allTrackedItems.first;
					if cargo.myCargoType.allowDuplicates then
						weightDiff:=cargoWeight - _vvr.getTotalWeightReleased();
					else
						weightDiff:=cargoWeight - cargo.totalWeight;
					endif;
				endif;
				
			endif;
			if cargoWeight &gt; 0 then
				
				if cargo &lt;&gt; null then
					if (cargo.totalWeight + weightDiff) &gt; 0 then
						tiUpdateCntrlr := app.createTIUpdateControl(TI_UPDMODE_RECEIPT, app.myPassport.userCode, null);
						tiUpdateCntrlr.transactionType := TRANS_TYPE_WEIGH;
						tiUpdateCntrlr.newWeight := cargo.totalWeight + weightDiff;
							// CCMS 1319
						tiUpdateCntrlr.weighBridgeName := _pxyWeighing.weighBridgeName;	//08 Jul 2019	NDL	TFS 44965
						cargo.setTotalWeight( cargo.totalWeight + weightDiff,tiUpdateCntrlr,_passport);
					
					endif;
				endif;
			endif;
		else
			visitType:=VisitRecord_WeighBridgeIn;
		endif;
	endif;
	
	_vvr.createVisitRecordDetail (visitType, weighing, null);	
	_vvr.causeEvent(_vvr.myTerminal.getTerminalEvent(EVENT_VEHICLEVISIT_UPDATE), false, _vvr);

epilog
	delete allTIs;
	delete tiUpdateCntrlr;
end;</source>
        <Parameter name="_vvr" type="CM_VehicleVisitRecord" usage="input"/>
        <Parameter name="_pxyWeighing" type="CM_VehicleVisitWeighing"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlAggregateBreakBulk" id="4baf3d75-ef2a-43c6-acdc-b61df1742a57">
        <updating/>
        <source>utlAggregateBreakBulk(	_targetTi : CM_Bulk io;
						_cargoToAggregate : CM_Cargo input;
						_pkgWeight : Decimal;
						_passport : CM_Passport input
						) updating;
/*


Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 April 2014	cnwndl1	Initial creation

*/

vars

begin

	_targetTi.aggregate(_cargoToAggregate.CM_BreakBulkGeneric,_pkgWeight,_passport);
	
epilog

end;</source>
        <Parameter name="_targetTi" type="CM_Bulk" usage="io"/>
        <Parameter name="_cargoToAggregate" type="CM_Cargo" usage="input"/>
