// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 17/12/2014	cnwdap1		Initial creation PAR #35397 CCMS SFW 1394 Voyage Rationalisation
// 07/05/2015	cnwdap1		PAR #36157 Fix the autoplan and queue menu functions
//
vars

	profiler       			: JadeProfiler;
	startTM					: Decimal[19,0];
begin
	if process.isMohamed then
		app.myRoot.startJadeProfiler(profiler,method.getNiceName() ,10,false,'MA',startTM);
	endif;
	//self.doMove_Queue(QUEUE_MODE, true, menuItem.userObject.CM_DataTable);		// PAR #36157
	self.doAutoPlanQueue(QUEUE_MODE, true, menuItem.userObject.CM_DataTable);		// PAR #36157
	app.myRoot.stopJadeProfiler(profiler,startTM);
epilog

end;</source>
