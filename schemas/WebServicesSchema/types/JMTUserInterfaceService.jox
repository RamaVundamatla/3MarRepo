		response.allFormPermissions.add(formPermission);
		
		if not response.doesContain(PmHHCargoEnquiry) then
			create cargoEnqFormPermission transient;
			cargoEnqFormPermission.id := PmHHCargoEnquiry;
			response.allFormPermissions.add(cargoEnqFormPermission);
		endif;
	endif;
	if app.myCurrentUserCan(term, PmHHReeferConnect) then // Reefer Connect
		create formPermission transient;
