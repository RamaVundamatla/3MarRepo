    <JadeMethod name="queryMoveTo" id="91dafb6e-7203-4e6c-ae32-59cf257c2fd4">
        <source>queryMoveTo(_params : CMIF_MoveParams io);
// ---------------------------------------------------------------------------
// Created:     
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
// ---------------------------------------------------------------------------


constants
	ERR_ALREADY_HERE = 25124;
	WARN_DIFF_SHIP_VOYAGE = 28066;
	//ERR_INVALID_MODE	25151
vars
	ti : CM_TrackedItem;
	msgStr : String;
begin
	//move mode can only be real mode
	if _params.mode &lt;&gt; REAL_MODE then
	 	_params.errorCode := ERR_INVALID_MODE;
	endif;

	if _params.trackedItem &lt;&gt; null then
		ti := _params.trackedItem;
	 	
	 	if ti.getPrimaryLocation(REAL_MODE) = self then //ti cannot be here already
	 		_params.errorCode := ERR_ALREADY_HERE;
	 		return;
	 	endif;

		//ti cannot be SOB or DLR or TRANSIT ?

	   	//ti check for different voyage
   		if ti.myVoyage &lt;&gt; self.myVoyage then
			msgStr := app.getErrorString(WARN_DIFF_SHIP_VOYAGE);
			//msgStr := "TI has different voyage OK ?";
			if app.msgBox(msgStr, "Query Move", MsgBox_Yes_No + MsgBox_Question_Mark_Icon) = MsgBox_Return_No	then
				_params.errorCode := VB_USER_CANCELED_TRANS;
				return;
			endif;
		endif;
	//ti must be onsite ??
	endif;
end;</source>
        <Parameter name="_params" type="CMIF_MoveParams" usage="io"/>
    </JadeMethod>
