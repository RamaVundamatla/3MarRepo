    <JadeMethod name="getDisplayStringForAttribute" id="a88b45e7-47a7-4b36-baba-3e0736357a72">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 10 March 2022	navdap1		Initial creation TFS 52746 PNL Custom Hold Clearance for Export Units using BOL with TSW EDI
//
vars

begin
	if _attrName = ETRow_AllowBOLForExports then
		return app.myRoot.getConfig(AllowBOLForExports).Boolean.asStringJMT;
	endif;
	
	return inheritMethod(_attrName, _short);

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="ebe2c2a5-bc11-432b-8b31-fba237364c9b">
        <source>pxyCreateUpdateProxy(): SelfType;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 11/08/2016	cnwdap1		Initial creation TFS #1832 TSW Changes
//
vars
	pxyWebService : CM_TSWWebService;
	webServiceTerminal, pxyWebServiceTerminal : CM_TSWWebServiceTerminal;

begin
	pxyWebService := inheritMethod();
	foreach webServiceTerminal in self.allTSWWebServiceTerminals do
		pxyWebServiceTerminal := webServiceTerminal.pxyCreateUpdateProxy();
		pxyWebServiceTerminal.setMyTSWWebService(pxyWebService);
	endforeach;
	
	return pxyWebService;

epilog

end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="f19e9bd7-204e-4872-a4de-12b97473497c">
        <updating/>
        <source>setForCreate(_pxyWebService : SelfType) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 10/08/2016	cnwdap1		Initial creation TFS #1832 TSW Changes
//
vars

begin
	_pxyWebService.raiseExceptionIfNotTransient(method);
	self.setForUpdate(_pxyWebService);
	self.myRoot := app.myRoot;
epilog

end;</source>
        <Parameter name="_pxyWebService" type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="74631879-8e5e-4c08-a2e3-c32bda12eb1a">
        <updating/>
        <source>setForUpdate(_pxyWebService : SelfType) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 10/08/2016	cnwdap1		Initial creation TFS #1832 TSW Changes
//
vars
	pxyTSWTerminal, realTSWTerminal : CM_TSWWebServiceTerminal;

begin
	self.name 		:= _pxyWebService.name;
	self.submitter 	:= _pxyWebService.submitter;
	
	self.allTSWWebServiceTerminals.purge;
	foreach pxyTSWTerminal in _pxyWebService.allTSWWebServiceTerminals do
		create realTSWTerminal persistent;
		realTSWTerminal.setForUpdate(pxyTSWTerminal);
	endforeach;
epilog

end;</source>
        <Parameter name="_pxyWebService" type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="72b89ff4-0761-4137-9220-58c19c0af2f1">
        <updating/>
        <source>setProxy(_name, _submitter : String) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 10/08/2016	cnwdap1		Initial creation TFS #1832 TSW Changes
//
vars

begin
	self.name 		:= _name;
	self.submitter 	:= _submitter;
	
	self.allTSWWebServiceTerminals.purge;
epilog

end;</source>
        <Parameter name="_name" type="String"/>
        <Parameter name="_submitter" type="String"/>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="21efa03c-ca01-4af0-a975-bb80c5878b21">
        <source>validateForCreate();
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 10/08/2016	cnwdap1		Initial creation TFS #1832 TSW Changes
//
vars

begin
	if app.myRoot.allTSWWebServices[self.name] &lt;&gt; null then 
		app.raiseCMException1(VB_DUPLICATED_ITEM, self.name, null, null);
	endif;

	self.validateMe;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="validateForDelete" id="7867eeab-1fed-43e6-b011-628fb1bb6e09">
        <source>validateForDelete();
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 10/07/2020	jlgdap1		Initial creation TFS 49714 POL TSW Web Service Definition Deleted while in use
//
vars
	tswTask : CM_AutoTaskTSWWebService;

begin
	foreach tswTask in CM_AutoTaskTSWWebService.instances discreteLock do
		if tswTask.name = self.name then
			app.raiseCMException2(Service_used_by_task, self.name, tswTask.description, null, null);
		endif;
	endforeach;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="79afeaef-b47b-49f6-b917-f94bef9db56f">
        <source>validateForUpdate();
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 10/08/2016	cnwdap1		Initial creation TFS #1832 TSW Changes
//
vars

begin
	self.validateMe();
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="validateMe" id="0f137eee-74ac-4966-9d0a-d1002086687f">
        <source>validateMe() protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 10/08/2016	cnwdap1		Initial creation TFS #1832
//
vars

begin
	if self.name.trimBlanks = null then
		app.raiseCMException(Input_required_field_name, null, null);
	endif;
	if self.submitter.trimBlanks = null then
		app.raiseCMException(Input_required_field_submit, null, null);
	endif;
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
</Class>
