    <JadeMethod name="initShtMultiSelect" id="b2ca3619-bc65-4862-af42-09de3eb8c146">
        <source>initShtMultiSelect();
// ---------------------------------------------------------------------------
// Created:     06 August 2002 by cnwdf1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

	theForm	: SOP_TableMaintForm;
	theTerm : CM_Terminal;
	cargoTypes : CM_CargoTypeSet;
begin
	theForm := self.myForm;
	
	
	theTerm := theForm.myTerminal; // PAR 35158
	create cargoTypes transient; // PAR 35158
	if theTerm &lt;&gt; null then // PAR 35158
		theTerm.getAllCargoTypes(cargoTypes,true); // PAR 35158
	else
		app.myRoot.allCargoTypesById.copy(cargoTypes); // PAR 35158
	endif;
	
	inheritMethod;	
	
	theForm.btnSetDefault1.visible := true;
	theForm.btnSetDefault2.visible := true;
	
	self.initShtMultiSelect1();

	
	theForm.mulSelect2.setVisibleButtons(true,true,false);
//	self.setupMultiSelect2('Cargo Types Access',app.myRoot.allCargoTypesById,SOP_TableMaintForm::displayEntryCargoType.name);	// cnwrl1 20/05/2009 PAR 19668 - CCMS 1814
	self.setupMultiSelect2(	app.getErrorString( Cargo_Types_Access ),
							cargoTypes,  // PAR 35158 app.myRoot.allCargoTypesById,
							SOP_TableMaintForm::displayEntryCargoType.name );
	
	// CCMS 1438
	theForm.mulSelect3.setVisibleButtons(true,true,false);
//	self.setupMultiSelect3('Content Statuses',app.myRoot.allContentsStatuses,SOP_TableMaintForm::displayEntryContentStatus.name);	// cnwrl1 20/05/2009 PAR 19668 - CCMS 1814
	self.setupMultiSelect3(	app.getErrorString( Content_Statuses ),
							app.myRoot.allContentsStatuses,
							SOP_TableMaintForm::displayEntryContentStatus.name );
							

	theForm.shtMultiAlign.visible	:= true;
epilog
	delete cargoTypes;
end;</source>
