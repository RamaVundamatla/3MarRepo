    <JadeMethod name="addToJobTotals" id="03ae2d4d-32af-43f1-8bb6-7d0072d8afd1">
        <source>addToJobTotals(_theTotals: CMIF_JobTITotals input);
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 August 2011	cnwer1	Initial creation CCMS MES 1033

*/

vars
	numTI, workListEntrySize			: Integer;
	isEmpty : Boolean; 	//cnwas3 PAR 24273
	is40,
	is20 	: Boolean;		//cnwas3 PAR 24273
	is30 : Boolean;		//CNWAB1 PAR 30342
	is45 : Boolean;		//CNWAB1 PAR 30342
	is53 : Boolean;		//CNWAB1 PAR 30342
	ti      : CM_TrackedItem;
	is30Included, is45Included, is53Included : Boolean;
begin
	is30Included	:= self.myTerminal.getConfig (Is30IncludedForReports).Integer = ISOTypeOtherIncludedAsOwn;	//CNWAB1 PAR 30342
	is45Included	:= self.myTerminal.getConfig (Is45IncludedForReports).Integer = ISOTypeOtherIncludedAsOwn;	//CNWAB1 PAR 30342
	is53Included	:= self.myTerminal.getConfig (Is53IncludedForReports).Integer= ISOTypeOtherIncludedAsOwn;	//CNWAB1 PAR 30342
	
	
	_theTotals.myJob := self.myJob.CM_VoyageJob;
	workListEntrySize := self.allWorkListEntries.size;
	
	if workListEntrySize = 0 then
		return;
	endif;
	isEmpty := self.getAttrEmpty();	//cnwas3 PAR 24273
	//is40 := self.getAttrIs40();		//cnwas3 PAR 24273
	is40 := self.getAttrIs40();		//cnwas3 PAR 24273
	is30 := self.getAttrIs30();		//CNWAB1 PAR 30342
	is45 := self.getAttrIs45();		//CNWAB1 PAR 30342
	is53 := self.getAttrIs53();		//CNWAB1 PAR 30342
	is20:=not is30 and not is40 and not is45 and not is53;
	// load colour coding didn't specify a length then need to get length from the ti
	if not is20 and not is40 and not is30 and not is45 and not is53 then
		ti:=self.allWorkListEntries.first.myTrackedItem;
		if ti &lt;&gt; null then
			is20:=ti.is20;
			is30:=ti.is30;//CNWAB1 PAR 30342
			is40:=ti.isForty;
			is45:=ti.is45;//CNWAB1 PAR 30342
			is53:=ti.is53;//CNWAB1 PAR 30342
		endif;
	endif;
	
	// PAR 30342 if not individual show as 40s
	if is30 and not is30Included then
		is30 := false;
		is40 := true;
	elseif is45 and not is45Included then
		is45 := false;
		is40 := true;
	elseif is53 and not is53Included then
		is53 := false;
		is40 := true;
	endif;
	
	if self.moveType = LOAD_MOVETYPE or self.moveType = DISCHARGE_MOVETYPE then
		if self.getAttrOverDimensioned() then // PAR 7685
			_theTotals.numOD := _theTotals.numOD + workListEntrySize; // PAR 7685
		endif;
		if is20  then
			_theTotals.numTwentyFoot := _theTotals.numTwentyFoot + workListEntrySize;
			if self.getAttrPowerRequired() and self.moveType = LOAD_MOVETYPE then
				_theTotals.numPoweredRequested := _theTotals.numPoweredRequested + workListEntrySize;
			endif;
			if isEmpty then    //cnwas3 par 24273
				_theTotals.numEmpty := _theTotals.numEmpty + workListEntrySize;
				_theTotals.numEmpty20 := _theTotals.numEmpty20 + workListEntrySize;
			else
				_theTotals.numFull := _theTotals.numFull + workListEntrySize;
				_theTotals.numFull20 := _theTotals.numFull20 + workListEntrySize;
			endif;
		elseif is40 then //cnwas3 par 24273
			_theTotals.numFortyFoot := _theTotals.numFortyFoot + workListEntrySize;
			if isEmpty then    //cnwas3 par 24273
				_theTotals.numEmpty := _theTotals.numEmpty + workListEntrySize;
				_theTotals.numEmpty40 := _theTotals.numEmpty40 + workListEntrySize;
			else
				_theTotals.numFull := _theTotals.numFull + workListEntrySize;
				_theTotals.numFull40 := _theTotals.numFull40 + workListEntrySize;
			endif;
		elseif is30 then //CNWAB1 PAR 30342
			_theTotals.numThirtyFoot := _theTotals.numThirtyFoot + workListEntrySize;
			if isEmpty then    
				_theTotals.numEmpty := _theTotals.numEmpty + workListEntrySize;
				_theTotals.numEmpty30 := _theTotals.numEmpty30 + workListEntrySize;
			else
				_theTotals.numFull := _theTotals.numFull + workListEntrySize;
				_theTotals.numFull30 := _theTotals.numFull30 + workListEntrySize;
			endif;					//...cnwgb1 29 May 2008 PAR16415
		elseif is45 then  //CNWAB1 PAR 30342
			_theTotals.numFortyFive := _theTotals.numFortyFive + workListEntrySize;
			if isEmpty then    
				_theTotals.numEmpty := _theTotals.numEmpty + workListEntrySize;
				_theTotals.numEmpty45 := _theTotals.numEmpty45 + workListEntrySize;
			else
				_theTotals.numFull := _theTotals.numFull + workListEntrySize;
				_theTotals.numFull45 := _theTotals.numFull45 + workListEntrySize;
			endif;
		elseif is53 then		//CNWAB1 PAR 30342
			_theTotals.numFiftyThree := _theTotals.numFiftyThree + workListEntrySize;
			if isEmpty then    
				_theTotals.numEmpty := _theTotals.numEmpty + workListEntrySize;
				_theTotals.numEmpty53 := _theTotals.numEmpty53 + workListEntrySize;
			else
				_theTotals.numFull := _theTotals.numFull + workListEntrySize;
				_theTotals.numFull53 := _theTotals.numFull53 + workListEntrySize;
			endif;
		
		endif;					//...cnwgb1 29 May 2008 PAR16415
	elseif self.isRehandle then
		if self.getAttrOverDimensioned() then // PAR 7685
			_theTotals.numODRH := _theTotals.numODRH + workListEntrySize; // PAR 7685
		endif;
		if is20 then
			_theTotals.numTwentyFoot := _theTotals.numTwentyFoot + workListEntrySize;
			if isEmpty then    //cnwas3 par 24273
				_theTotals.numEmptyRH := _theTotals.numEmptyRH + workListEntrySize;
				_theTotals.numEmpty20RH := _theTotals.numEmpty20RH + workListEntrySize;
			else
				_theTotals.numFullRH := _theTotals.numFullRH + workListEntrySize;
				_theTotals.numFull20RH := _theTotals.numFull20RH + workListEntrySize;
			endif;				
		elseif is40 then //cnwas3 par 24273
			_theTotals.numFortyFoot := _theTotals.numFortyFoot + workListEntrySize;
			if isEmpty then    //cnwas3 par 24273
				_theTotals.numEmptyRH := _theTotals.numEmptyRH + workListEntrySize;
				_theTotals.numEmpty40RH := _theTotals.numEmpty40RH + workListEntrySize;
			else
				_theTotals.numFullRH := _theTotals.numFullRH + workListEntrySize;
				_theTotals.numFull40RH := _theTotals.numFull40RH + workListEntrySize;
			endif;
		elseif is30 then  //CNWAB1 PAR 30342
			_theTotals.numThirtyFoot := _theTotals.numThirtyFoot + workListEntrySize;
			if isEmpty then  
				_theTotals.numEmptyRH := _theTotals.numEmptyRH + workListEntrySize;
				_theTotals.numEmpty30RH := _theTotals.numEmpty30RH + workListEntrySize;
			else
				_theTotals.numFullRH := _theTotals.numFullRH + workListEntrySize;
				_theTotals.numFull30RH := _theTotals.numFull30RH + workListEntrySize;
			endif;
		elseif is45 then  //CNWAB1 PAR 30342
			_theTotals.numFortyFive := _theTotals.numFortyFive + workListEntrySize;
			if isEmpty then  
				_theTotals.numEmptyRH := _theTotals.numEmptyRH + workListEntrySize;
				_theTotals.numEmpty45RH := _theTotals.numEmpty45RH + workListEntrySize;
			else
				_theTotals.numFullRH := _theTotals.numFullRH + workListEntrySize;
				_theTotals.numFull45RH := _theTotals.numFull45RH + workListEntrySize;
			endif;
		elseif is53 then  //CNWAB1 PAR 30342
			_theTotals.numFiftyThree := _theTotals.numFiftyThree + workListEntrySize;
			if isEmpty then  
				_theTotals.numEmptyRH := _theTotals.numEmptyRH + workListEntrySize;
				_theTotals.numEmpty53RH := _theTotals.numEmpty53RH + workListEntrySize;
			else
				_theTotals.numFullRH := _theTotals.numFullRH + workListEntrySize;
				_theTotals.numFull53RH := _theTotals.numFull53RH + workListEntrySize;
			endif;
		endif;					
	elseif self.isSoB and not self.isLoad then // do not include the load part of the SOB, as it doubles up the figures
		if self.getAttrOverDimensioned() then // PAR 7685
			_theTotals.numODSOB := _theTotals.numODSOB + workListEntrySize; // PAR 7685
		endif;
		
		if is20 then
			_theTotals.numTwentyFoot := _theTotals.numTwentyFoot + workListEntrySize;
			if isEmpty then    //cnwas3 par 24273
				_theTotals.numEmptySOB := _theTotals.numEmptySOB + workListEntrySize;
				_theTotals.numEmpty20SOB := _theTotals.numEmpty20SOB + workListEntrySize;
			else
				_theTotals.numFullSOB := _theTotals.numFullSOB + workListEntrySize;
				_theTotals.numFull20SOB := _theTotals.numFull20SOB + workListEntrySize;
			endif;
		
		elseif is40 then //cnwas3 par 24273
			_theTotals.numFortyFoot := _theTotals.numFortyFoot + workListEntrySize;
			if isEmpty then    //cnwas3 par 24273
				_theTotals.numEmptySOB := _theTotals.numEmptySOB + workListEntrySize;
				_theTotals.numEmpty40SOB := _theTotals.numEmpty40SOB + workListEntrySize;
			else
				_theTotals.numFullSOB := _theTotals.numFullSOB + workListEntrySize;
				_theTotals.numFull40SOB := _theTotals.numFull40SOB + workListEntrySize;
			endif;
		endif;
	endif;
epilog

end;</source>
        <Parameter name="_theTotals" type="CMIF_JobTITotals" usage="input"/>
    </JadeMethod>
    <JadeMethod name="clearAllocation" id="b63cfd68-ff37-4dae-afd0-afea4a450eb0">
        <updating/>
        <source>clearAllocation(): Boolean updating;
// ---------------------------------------------------------------------------
// Created:     15 July 2013 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	if not self.myROROController.isOOTL() then
		return false;
	endif;
	
	self.allAllocations.clear();
	self.quantity := 1;
	self.myLayout.setRealDrawFillColour(White);
	return true;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
