    <JadeMethod name="doBtnDoItClick" id="67abcbab-d757-4579-beff-39b299337fe3">
        <source>doBtnDoItClick();
// ---------------------------------------------------------------------------
// Created:		June 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
10 Oct 2016	cnwkpd1	TFS JMT 2805 - JADE 7.1.08 upgrade
	
*/

vars
	aTerminal : CM_Terminal;
	theSVG : String;
	theSVGFile : File;
	result : Integer;
	fileName,rastaFileName : String;
begin

	// ##############
	// CREATE SVG
	fileName := "C:\akb\SVG\rasta\convert\terminal01.svg";
	create theSVGFile;
	theSVGFile.mode := File.Mode_Output; // 3/3/16  cnwns1 PAR 36286 unicode version
	aTerminal := CM_Terminal.firstInstance;
	theSVG := aTerminal.getSVGForTerminalAll();
	theSVGFile.fileName := fileName;
	theSVGFile.writeString(theSVG);
	theSVGFile.close;
	
	// ##############
	// CONVERT TO PNG
	rastaFileName := "-jar C:\akb\SVG\rasta\batik-rasterizer.jar  "; // -bg 0.255.255.255
	
	// java -jar batik-rasterizer.jar terminal01.svg	
	result := call _shellExecute(null, 'open','java', rastaFileName &amp; fileName, null, 0);
	if result &lt; 32 then
		app.msgBox('Unable to open Rasta (' &amp; result.String &amp; ')', 'Warning',MsgBox_Exclamation_Mark_Icon);
	endif;
	self.picture01.picture := app.loadPicture("C:\akb\SVG\rasta\convert\terminal01.png");

epilog
	delete theSVGFile;	
	
end;</source>
    </JadeMethod>
