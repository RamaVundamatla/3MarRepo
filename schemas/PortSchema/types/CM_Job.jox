    <JadeMethod name="setJobPlannedLocation" id="ab090576-3973-44bd-81fc-740e4623299b">
        <updating/>
        <source>setJobPlannedLocation(_set : Boolean 	//26/08/2024	navkc1 CR 63588 Task 63589
					) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 Feb 2024 navhl20 ChangeRequest 61869: EUP | FR | 53891 - Mobile App changes for Delivery Dispatch - Source Location
01 Apr 2024 navhl20 ChangeRequest 63251: FR | 53729 - Delivery Dispatch screen - Further issues and Remedial work
*/

vars
	term		: CM_Terminal;
	woDtl		: CM_WorkOrderDtl;
	lc			: CM_LocationsController; 
begin
	
	//if self.plannedLocations &lt;&gt; null then
//	if self.plannedLocation &lt;&gt; null then //26/08/2024	navkc1 CR 63588 Task 63589
	if not _set // ### JIRA 33678 17DEC2024 NAVAB1
	and self.plannedLocation &lt;&gt; null then
		return;
	endif;
	
	if not app.myPassport.isVASEnabled then
		return;
	endif;
	
	term := self.getMyTerminal;
	
	if term &lt;&gt; null and not term.isUseYardJobsForCargoWo then
		return;
	endif;
	
	if not self.allowUpdatePlanLocation() then																				//01.04.2024 navhl20 #63251
		return;
	endif;

	self.getFirstLocationId(_set); //26/08/2024	navkc1 CR 63588 Task 63589 - We always set the plannedLocation, plannedLocations, plannedTerminalAreas even if no WO
	
	woDtl := self.getMyWorkOrderDtl();
	if woDtl = null then
		return;
	endif;
	
	if not woDtl.CM_WorkOrderTIDtl.allowUpdatePlanLocation() then															//01.04.2024 navhl20 #63251
		return;
	endif;
	
	if not self.requiredByDT.isValid then
		return;
	endif;

	/* //26/08/2024	navkc1 CR 63588 Task 63589
	if not woDtl.isKindOf(CM_WodUnpack) then																		//01.04.2024 navhl20 #63251
		self.plannedLocations := self.getFirstLocationId();
	else
		self.plannedLocations := woDtl.CM_WodUnpack.myUnpackToLocation.getFullId();
	endif;
	*/
	//26/08/2024	navkc1 CR 63588 Task 63589
	if woDtl.isKindOf(CM_WodUnpack) then
		lc := woDtl.CM_WodUnpack.myUnpackToLocation;
		if lc &lt;&gt; null then
			self.plannedLocation := lc.getFullId();
			self.plannedLocations := lc.getFullId();			
			self.plannedTerminalAreas := lc.terminalAreaId;
		endif;
	endif;
epilog

end;</source>
        <Parameter name="_set" type="Boolean"/>
    </JadeMethod>
