/*
Purpose:			

Date		Who		Reason
08 January 2024	navab1	CR 58085 TASK 61342
*/

vars
	invoice : CM_Invoice;
begin
	foreach invoice in self.allOtherInvoices discreteLock do
		if invoice.isVoided
		and invoice.isTASCreditNote then
