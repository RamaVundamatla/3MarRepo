<Class name="CM_WOVoyageToDoWLE" id="b7fe2191-1a12-4644-8c52-63f53955edfd">
    <superclass name="CM_WOToDoWLE"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="cmtrans"/>
    <ExplicitInverseRef name="myVoyage" id="9addcfd0-232d-4266-8016-3f82317607fb">
        <transientToPersistentAllowed/>
        <embedded/>
        <type name="CM_Voyage"/>
        <access>readonly</access>
        <Inverse name="CM_Voyage::allWorkOrderWLEs"/>
    </ExplicitInverseRef>
    <JadeMethod name="addToDoTask" id="be8406fc-7fd7-4451-bcf6-d0960c3a4afd">
        <updating/>
        <source>addToDoTask() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
23 November 2022	navcs2	ChangeRequest 56691:[56120] EUP - Allow Completing ToDo Work order tasks at Complete ToDo Task Screen

*/

vars
	toDoDesc 		: CM_ToDoTaskDesc;
	voyTask			: CM_ToDoTask;
	passport 		: CM_Passport;
	
begin
	
	if self.myVoyage = null then
		//throw error
		return;
	endif;
	
	passport := app.myPassport;
	
	toDoDesc := self.job.CM_WOToDoTaskJob.myToDoTaskDesc;

	if voyTask = null then //add task
		voyTask := self.myVoyage.createToDoTask(toDoDesc.code, self.job.myWorkOrderDtlToDo); // ### TFS CR 54345 TASK 54267 01JUN2023 NAVAB1
		self.job.myWorkOrderDtlToDo.allToDoTasks.add(voyTask);
	endif;
	
	self.myToDoTask := voyTask;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="d8aed7bb-44e9-4f10-905c-abbd5c043d65">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
08 Feb 2023		navcs2	ChangeRequest 56318:[56319] EUP - Enable ToDo Work Order job on Yard Operation Screen 

*/

vars
	voyage : CM_Voyage;
begin
	
	if _attrName = ETRow_VoyageCode then 			//16.03.2023 navma1 #56318
		voyage := self.myVoyage;
		if voyage &lt;&gt; null then
			return voyage.code;
		endif;
		return null;
	else
		return inheritMethod (_attrName, _short);	
	endif;
epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setMyVoyage" id="b5ca9ca8-4740-42de-8aae-e553becf758c">
        <updating/>
        <source>setMyVoyage(_voyage : CM_Voyage) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
23 November 2022	navcs2	ChangeRequest 54344: EUP - VAS Work Orders - Jobs

*/

vars

begin
	self.myVoyage := _voyage;
	
	self.addToDoTask();
epilog

end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
    </JadeMethod>
</Class>
