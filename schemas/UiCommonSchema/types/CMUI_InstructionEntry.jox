    <JadeMethod name="translateForm" id="a7a8c5df-7a3d-43dd-9dfc-045bd59c10f4">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 28 November 2022 08:57:41.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0025195, locale);
	btnClear.translateCaption(Xlat_0025196, locale);
	btnSave.translateCaption(Xlat_0025197, locale);
	btnclose.translateCaption(Xlat_0025198, locale);
	lblExternalInstructions.translateCaption(Xlat_0025199, locale);
	lblInstructions.translateCaption(Xlat_0025200, locale);
	lblinternalInstructions.translateCaption(Xlat_0025201, locale);
end;</source>
    </JadeMethod>
