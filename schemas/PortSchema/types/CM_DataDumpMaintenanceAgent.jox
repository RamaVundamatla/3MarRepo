    <JadeMethod name="xCM_EventTransaction" id="713873c3-3ae3-4bfd-86c1-9916c013f4a7">
        <updating/>
        <source>xCM_EventTransaction(_features : CMIF_ExternalDBFeatureSet input) updating;
//
//16 Mar 2016	cnwrs1	TFS 1656 SQL Native Event Type and Event Transaction
//26/10/2017	jlgdap1	TFS 7076 LNX added myJob for CMEVT_VoyageEvent
//23/07/2019 	JLGNS1	ChangeRequest 45575: ASPA - Train Events
//25/02/2021    cnwma1  ChangeRequest 50851: ASPA - IsBarge on Ship Transactions
//09/04/2025	jlizm1	MTN 34568 PEN Expose vessel fields to event stream
//6/6/2025      navsaa30 MTN-34919 PEN | Event Stream Voyage Information
//
vars
	xdbFeature  : CMIF_ExternalDBFeature;
begin
	create xdbFeature transient;
	xdbFeature.setupAndBuildSet(CM_EventTransaction::dateTime.name, "CM_EventTransaction", "dateTime", "", _features);
	create xdbFeature transient;
	xdbFeature.setupAndBuildSet(CM_EventTransaction::myTerminal.name, "CM_EventTransaction", "myTerminal", "", _features);
	create xdbFeature transient;
	xdbFeature.setupAndBuildSet(CM_EventTransaction::noCharge.name, "CM_EventTransaction", "noCharge", "", _features);
	create xdbFeature transient;
	xdbFeature.setupAndBuildSet(CM_EventTransaction::myEventType.name, "CM_EventTransaction", "myEventType", "", _features);
	create xdbFeature transient;
	xdbFeature.setupAndBuildSet(CM_EventTransaction::amount.name, "CM_EventTransaction", "amount", "", _features);
	create xdbFeature transient;
	xdbFeature.setupAndBuildSet(CM_EventTransaction::getOperator.name, "CM_EventTransaction", "getOperator", "", _features);
	create xdbFeature transient;
	xdbFeature.setupAndBuildSet(CM_EventTransaction::getVoyage.name, "CM_EventTransaction", "getVoyage", "", _features);
	create xdbFeature transient;
	xdbFeature.setupAndBuildSet(CM_EventTransaction::getTrain.name, "CM_EventTransaction", "getTrain", "", _features);
	create xdbFeature transient;
	xdbFeature.setupAndBuildSet(CM_EventTransaction::getWagon.name, "CM_EventTransaction", "getWagon", "", _features);
	create xdbFeature transient;
	xdbFeature.setupAndBuildSet(CM_EventTransaction::getVehicleVisit.name, "CM_EventTransaction", "getVehicleVisit", "", _features);
	create xdbFeature transient;
	xdbFeature.setupAndBuildSet(CMEVT_BookingRefDiscrep::getDiscrepancyText.name, "CM_EventTransaction", "getDiscrepancyText", "CMEVT_BookingRefDiscrep", _features);
	create xdbFeature transient;
	xdbFeature.setupAndBuildSet(CM_EventTransaction::getTrackedItem.name, "CM_EventTransaction", "getTrackedItem", "", _features);
	
	create xdbFeature transient;
	xdbFeature.setupAndBuildSet(CMEVT_VoyageEvent::getVoyagePortCode.name, "CM_EventTransaction", "getVoyagePortCode", "CMEVT_VoyageEvent", _features); //6/6/25  navsaa30 #34919
	create xdbFeature transient;
	xdbFeature.setupAndBuildSet(CMEVT_VoyageEvent::getNextPortInRotationCode.name, "CM_EventTransaction", "getNextPortInRotationCode", "CMEVT_VoyageEvent", _features);   //6/6/25  navsaa30 #34919
	create xdbFeature transient;
	xdbFeature.setupAndBuildSet(CM_EventTransaction::getDescription.name, "CM_EventTransaction", "getDescription", "", _features);
	create xdbFeature transient;
	xdbFeature.setupAndBuildSet(CM_EventTransaction::userCode.name, "CM_EventTransaction", "userCode", "", _features);
	create xdbFeature transient;
	xdbFeature.setupAndBuildSet(CM_EventTransaction::getEndTS.name, "CM_EventTransaction", "dateTimeEnd", "", _features);
	create xdbFeature transient;
	xdbFeature.setupAndBuildSet(CMEVT_VoyageEvent::remarks.name, "CM_EventTransaction", "remarks", "CMEVT_VoyageEvent", _features);
	create xdbFeature transient;
	xdbFeature.setupAndBuildSet(CMEVT_VoyageEvent::shiftCode.name, "CM_EventTransaction", "shiftCode", "CMEVT_VoyageEvent", _features);
	create xdbFeature transient;
	xdbFeature.setupAndBuildSet(CMEVT_VoyageEvent::shiftStart.name, "CM_EventTransaction", "shiftStart", "CMEVT_VoyageEvent", _features);
	create xdbFeature transient;
	xdbFeature.setupAndBuildSet(CMEVT_VoyageEvent::shiftEnd.name, "CM_EventTransaction", "shiftEnd", "CMEVT_VoyageEvent", _features);
	create xdbFeature transient;
	xdbFeature.setupAndBuildSet(CMEVT_VoyageEvent::unitDescription.name, "CM_EventTransaction", "unitDescription", "CMEVT_VoyageEvent", _features);
	create xdbFeature transient;																									// TFS 7076
	xdbFeature.setupAndBuildSet(CMEVT_VoyageEvent::myJob.name, "CM_EventTransaction", "myJob", "CMEVT_VoyageEvent", _features);		// TFS 7076
	
	//MTN 34568
	create xdbFeature transient;
	xdbFeature.setupAndBuildSet(CMEVT_VoyageEvent::getVoyageEstimatedArrivalDT.name, "CM_EventTransaction", "getVoyageEstimatedArrivalDT", "CMEVT_VoyageEvent", _features);
	create xdbFeature transient;
	xdbFeature.setupAndBuildSet(CMEVT_VoyageEvent::getVoyageEstimatedDepartureDT.name, "CM_EventTransaction", "getVoyageEstimatedDepartureDT", "CMEVT_VoyageEvent", _features);
	create xdbFeature transient;
	xdbFeature.setupAndBuildSet(CMEVT_VoyageEvent::getVoyageShippingLineName.name, "CM_EventTransaction", "getVoyageShippingLineName", "CMEVT_VoyageEvent", _features);
	create xdbFeature transient;
	xdbFeature.setupAndBuildSet(CMEVT_VoyageEvent::getVesselName.name, "CM_EventTransaction", "getVesselName", "CMEVT_VoyageEvent", _features);
	create xdbFeature transient;
	xdbFeature.setupAndBuildSet(CMEVT_VoyageEvent::getVesselLloydsNumber.name, "CM_EventTransaction", "getVesselLloydsNumber", "CMEVT_VoyageEvent", _features);
	create xdbFeature transient;
	xdbFeature.setupAndBuildSet(CMEVT_VoyageEvent::getVesselLengthOverall.name, "CM_EventTransaction", "getVesselLengthOverall", "CMEVT_VoyageEvent", _features);
	
	//24 Aug 2018	NDL	 TFS 40309
	create xdbFeature transient;																								
	xdbFeature.setupAndBuildSet(CMEVT_VoyageEvent::myVoyageDelay.name, "CM_EventTransaction", "myVoyageDelay", "CMEVT_VoyageEvent", _features);	
	
	create xdbFeature transient;																																//ChangeRequest 45575
	xdbFeature.setupAndBuildSet(CMEVT_TrainTransaction::remarks.name, "CM_EventTransaction", "remarks", "CMEVT_TrainTransaction", _features);					//ChangeRequest 45575
	create xdbFeature transient;																																//ChangeRequest 45575
	xdbFeature.setupAndBuildSet(CMEVT_TrainTransaction::unitDescription.name, "CM_EventTransaction", "unitDescription", "CMEVT_TrainTransaction", _features);	//ChangeRequest 45575
	
	//18 May 2020	NDL	TFS 49285
	create xdbFeature transient;
	xdbFeature.setupAndBuildSet(CM_EventTransaction::createdTime.name, "CM_EventTransaction", "createdTime", "", _features);
	
	//22 Feb 2021	NDL	TFS 50835
	create xdbFeature transient;
	xdbFeature.setupAndBuildSet(CM_EventTransaction::mySnapShot.name, "CM_EventTransaction", "mySnapShot", "", _features);
	
	//25.02.2021 cnwma1 #50851
	create xdbFeature transient;																								
	xdbFeature.setupAndBuildSet(CMEVT_VoyageEvent::isBarge.name, "CM_EventTransaction", "isBarge", "CMEVT_VoyageEvent", _features);
	
	//20/02/2022 jlizm1	TFS 56675
	create xdbFeature transient;
	xdbFeature.setupAndBuildSet(CMEVT_TruckEvent::remarks.name, "CM_EventTransaction", "remarks", "CMEVT_TruckEvent", _features);
	
	//20/03/2024	navkc1 CR 62694 Task 62899
	create xdbFeature transient;
	xdbFeature.setupAndBuildSet(CMEVT_TruckEvent::getJobSheetCode.name, "CM_EventTransaction", "getJobSheetCode", "CMEVT_TruckEvent", _features);
	//20/03/2024	navkc1 CR 62694 Task 62899
	create xdbFeature transient;
	xdbFeature.setupAndBuildSet(CMEVT_TruckEvent::getJobId.name, "CM_EventTransaction", "getJobId", "CMEVT_TruckEvent", _features);
	//20/03/2024	navkc1 CR 62694 Task 62899
	create xdbFeature transient;
	xdbFeature.setupAndBuildSet(CMEVT_TruckEvent::getJobStart.name, "CM_EventTransaction", "getJobStart", "CMEVT_TruckEvent", _features);
	//20/03/2024	navkc1 CR 62694 Task 62899
	create xdbFeature transient;
	xdbFeature.setupAndBuildSet(CMEVT_TruckEvent::getJobEnd.name, "CM_EventTransaction", "getJobEnd", "CMEVT_TruckEvent", _features);
	//20/03/2024	navkc1 CR 62694 Task 62899
	create xdbFeature transient;
	xdbFeature.setupAndBuildSet(CMEVT_TruckEvent::getJobType.name, "CM_EventTransaction", "getJobType", "CMEVT_TruckEvent", _features);
	//20/03/2024	navkc1 CR 62694 Task 62899
	create xdbFeature transient;
	xdbFeature.setupAndBuildSet(CMEVT_TruckEvent::getJobDesc.name, "CM_EventTransaction", "getJobDesc", "CMEVT_TruckEvent", _features);
	
end;</source>
