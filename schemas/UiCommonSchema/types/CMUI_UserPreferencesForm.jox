    <JadeMethod name="doOK" id="42093d18-0127-48c1-a23d-50e21130a6da">
        <updating/>
        <source>doOK() updating;
// ---------------------------------------------------------------------------
// Created:     18 September 2007 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
27 May 2014	cnwkpd1	PAR #34210 - CCMS SFW 1350 - Online Documentation
	
*/

vars
	skinName : String;
	window	 : CM_BaseForm;
	index	 : Integer;
	nav		 : CMUI_Navigator;
begin
	if self.saveUser() then
		inheritMethod();
	endif;
	
	//cnwmc5 - PAR 31051
	skinName := app.myPassport.myUser.getUseAppSkinName();
	
	if skinName &lt;&gt; null then
		app.setApplicationSkinByName(skinName);
	else
		app.setApplicationSkin(null);
	endif;
	
	// PAR #34210 - Hide/show help menu as required
	app.handleHelpFormatChange();
	
end;</source>
    </JadeMethod>
    <JadeMethod name="populateHelpFormats" id="ed05c71c-807c-46ec-a49f-e74eac31e3c3">
        <source>populateHelpFormats() protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 May 2014	cnwkpd1	PAR #34210 - CCMS SFW 1350 - Online Documentation

*/

vars
	combo			: CMUI_ComboBox;
	idx				: Integer;
	
begin
	combo			:= self.cmbHelpFormat;
	combo.sorted 	:= false;

	idx := combo.addItem(HelpFile_TypeDefaultDescr);
	combo.itemData[idx] := HelpFile_TypeDefault;
	idx := combo.addItem(HelpFile_TypePDFDescr);
	combo.itemData[idx] := HelpFile_TypePDF;
	idx := combo.addItem(HelpFile_TypeHTMLDescr);
	combo.itemData[idx] := HelpFile_TypeHTML;
	
	combo.listIndex := 1;
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="populateRemSSOSession" id="6414d13a-2fb1-4a5b-9e82-b2aec400d6b3">
        <source>populateRemSSOSession() protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
21 September 2022	navam1	54866 - MTN - SSO - Not remembering session when 'Remember Single Sign On Session Default' is set

*/

vars
	combo			: CMUI_ComboBox;
	idx				: Integer;
begin
	combo			:= self.cmbSSOSession;
	combo.sorted 	:= false;

	idx := combo.addItem(RemSSOSessionDefaultDescr);
	combo.itemData[idx] := RemSSOSessionDefault;
	idx := combo.addItem(RemSSOSessionEnableDescr);
	combo.itemData[idx] := RemSSOSessionEnabled;
	idx := combo.addItem(RemSSOSessionDisabledDescr);
	combo.itemData[idx] := RemSSOSessionDisabled;
	
	combo.listIndex := 1;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="populateSkins" id="c7222391-f0b5-4125-85d2-8acf07ca2163">
        <source>populateSkins();
/*
Date		Who		Reason
20 Feb 2013	cnwmc5	Initial creation
11 Jun 2013	cnwcs5	par 31718 - use executeWhen instead of app.isSpecial
*/

vars
	combo	:CMUI_ComboBox;
begin
	combo			:= self.cmbSkin;
	combo.sorted 	:= false;
	
	combo.addItem("None");
	combo.addItem("JMT Blue");
	combo.addItem("JMT Orange");
	combo.addItem("JMT Green");
	combo.addItem("JMT Red");
	combo.addItem("JMT XP");
	
	executeWhen JMTDevelopmentEnvironment;
	combo.addItem("JMT Doug");
	combo.addItem("JMT Pirate");
	endExecuteWhen;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="saveUser" id="241adb6e-e970-49b3-b630-18d2a6b2e77b">
        <updating/>
        <source>saveUser() : Boolean updating;
// ---------------------------------------------------------------------------
// Created:     01 May 2007 by cnwyl1
//
// Purpose:     
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
27 May 2014	cnwkpd1	PAR #34210 - CCMS SFW 1350 - Online Documentation
	
*/
vars
	prefs			: CMIF_UserPreference;
	result 			: Integer;
	errObj			: CM_Error;
	helpFormat		: Integer;
	ssoSession		: Integer;	//54866
begin
	prefs					:= self.myCMIF_UserPreference;
	prefs.ackTodoStop		:= self.chkAckTodoStop.value;
	//21.09.2022 navam1 #54866
	if self.cmbSSOSession.listIndex &gt; 0 then
		ssoSession := self.cmbSSOSession.itemData[self.cmbSSOSession.listIndex];
	endif;
	prefs.ssoRememberSession	:= ssoSession;
	//cnwmc5 - PAR 31051
	prefs.appSkin			:= convertSkinName(self.cmbSkin.text, true);
	prefs.isUsePartialTxt	:= self.chkUsePartialTxt.value;
	prefs.myLocale			:= self.cmbLanguage.listObject.CM_Locale;
	
	if self.cmbHelpFormat.listIndex &gt; 0 then
		helpFormat := self.cmbHelpFormat.itemData[self.cmbHelpFormat.listIndex];
	endif;
	prefs.helpFileFormat	:= helpFormat;
	
	prefs.helpFileBaseURL	:= self.txtHelpFileURL.text;
	
	while true do
		app.myTrxUA.trxUpdateUserPreference(prefs, app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			self.clearErrorWarnings();
			app.setLocale(prefs.myLocale);
			return true;
		else
			result := app.showErrorWarningDialog('User Preference', app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			
			if app.myPassport.noErrors and
			   result = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;

			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window

			errObj := app.myPassport.allErrorWarnings.first;
			
			if errObj &lt;&gt; null then
				self.goToErrorItem(errObj);
			endif;
		endif;
		
		return false;	
	endwhile;
	
	return false;
end;
</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setControls" id="4a6ac5f0-ea85-4112-9f3d-78dbf45624d3">
        <source>setControls() protected;
// ---------------------------------------------------------------------------
// Created:     18 September 2007 by cnwrs2
//
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
27 May 2014	cnwkpd1	PAR #34210 - CCMS SFW 1350 - Online Documentation
	
*/

vars
	prefs	:CMIF_UserPreference;
	cmUser	: CM_User;	//20.07.2022 navam1 #52824
begin
	prefs := self.myCMIF_UserPreference;
	cmUser	:= app.getMyUser();		//20.07.2022 navam1 #52824
	
	self.chkAckTodoStop.value	:=	prefs.ackTodoStop;
	self.cmbSSOSession.listIndex := self.cmbSSOSession.findItemData(prefs.ssoRememberSession); //21.09.2022 navam1 #54866
	self.cmbSkin.text			:=	convertSkinName(prefs.appSkin, false);
	self.chkUsePartialTxt.value	:=	prefs.isUsePartialTxt;
	
	self.cmbLanguage.setObject(prefs.myLocale);
	
	self.cmbHelpFormat.listIndex := self.cmbHelpFormat.findItemData(prefs.helpFileFormat);		// PAR #34210
	self.txtHelpFileURL.text := prefs.helpFileBaseURL;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setUser" id="afd706bc-c74c-489a-ba87-86327502e382">
        <updating/>
        <source>setUser(_user : CM_User) updating;
// ---------------------------------------------------------------------------
// Created:     18 September 2007 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	delete self.myCMIF_UserPreference;
	create self.myCMIF_UserPreference transient;
	
	self.myCMIF_UserPreference.setFromUser(_user);
	
end;</source>
        <Parameter name="_user" type="CM_User"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="1702ce94-72fe-48e1-9f6c-c1bf75cc7d64">
        <updating/>
        <source>setupForm() updating;
// ---------------------------------------------------------------------------
// Created:		April  2007 By Andrew Yi Liu (cnwyl1)
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 27 May 2014	cnwkpd1	PAR #34210 - CCMS SFW 1350 - Online Documentation
// 24 Nov 2025 	navec1		MTN-36234: Okta SSO - Remember SSO Session
// ---------------------------------------------------------------------------
vars
	ssoProvider	: Integer; //20.07.2022 navam1 #52824
begin
	inheritMethod();

	self.showToolbar 	:= false;
	self.myTerminal 	:= app.myPassport.myTerminal;
	
	self.populateSkins();
	self.populateHelpFormats();		// PAR #34210
	self.populateRemSSOSession();	// 54866, AjitM, navam1
	self.setControls();

	//20.07.2022 navam1 #52824
	if app.getMyUser.canDo( null, PmAdmRememberSSOSession) then
		ssoProvider	:=  app.myRoot.getConfig(SsoProvider).Integer;
		if ssoProvider = app.mySSOAgent.SSO_Provider_Microsoft or ssoProvider = app.mySSOAgent.SSO_Provider_Okta then	// MTN-36234 - navec1 - Okta Remember SSO Session
			lblSSOSession.visible := true;
			cmbSSOSession.visible := true;
		endif;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="207d754b-e413-4b4a-a02b-205b6ff6c751">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 07 September 2022 08:59:43.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0008245, locale);
	lblAckTodoStop.translateCaption(Xlat_0008246, locale);
	lblHelpFormat.translateCaption(Xlat_0019733, locale);
	lblHelpURL.translateCaption(Xlat_0019734, locale);
	lblLanguage.translateCaption(Xlat_0008247, locale);
	lblSSOSession.translateCaption(Xlat_0025023, locale);
	lblSkin.translateCaption(Xlat_0018875, locale);
	lblUsePartialTxt.translateCaption(Xlat_0008248, locale);
end;</source>
    </JadeMethod>
</GUIClass>
