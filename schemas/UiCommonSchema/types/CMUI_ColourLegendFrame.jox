    <JadeMethod name="displayExport" id="2b5ce843-7c4b-48e5-b0bc-3c33cc6b6567">
        <source>displayExport() protected;
// ---------------------------------------------------------------------------
// Created:		March  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 01 Jun 2010	cnwkpd1		PAR #21914 - Improve legend load performance when loading entire table
// ---------------------------------------------------------------------------
vars
	voy				: CM_Voyage;
	voySet			: CM_VoyageSet;
	ls				: Boolean;
	term			: CM_Terminal;
begin
	self.myLegendTable.rows := 0;
	self.addRow("Exports",Red,null,true);
	self.myLegendTable.fixedRows := 1;

	app.cmsBeginLoad(ls);
	term := self.form.CM_BaseForm.myTerminal;
	if term = null then
		return;
	endif;
	
	create voySet transient;
	term.getAllCurrentCellularVoyages(voySet, true, true);
	
	foreach voy in voySet do
		self.addRow(voy.code.trimBlanks, voy.colour, voy, false);
	endforeach;
epilog
	delete voySet;
	app.cmsEndLoad(ls);
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="displayExportBookRef" id="39963c34-930d-430b-aeee-2fa338642531">
        <updating/>
        <source>displayExportBookRef(controller : CMIF_DrawingAttrController) updating, protected;
// Add a list of Export Booking References to the legend table
vars
	bookRef : CM_BookingRef;
	viewObjectColour : CM_ViewObjectColour;
	iter : Iterator;
begin
	self.viewMode := VIEW_BOOKREF_EXPORT;
	self.myLegendTable.rows := 0;
	self.addRow("Export Booking", Red, null,true);
	self.myLegendTable.fixedRows := 1;
	
	iter := controller.allExportBookRefs.createIterator;
	while iter.next(viewObjectColour) do
		if viewObjectColour.myObject &lt;&gt; null then
			bookRef := viewObjectColour.myObject.CM_BookingRef;
		endif;
		self.addRow(viewObjectColour.code, viewObjectColour.colour, bookRef, false);
	endwhile;
	
epilog
	delete iter;
end;</source>
        <access>protected</access>
        <Parameter name="controller" type="CMIF_DrawingAttrController"/>
    </JadeMethod>
