    <JadeMethod name="tLabourRestrictionReason" id="5bcbbc89-ec9a-42e2-bab0-4e0367120108">
        <source>tLabourRestrictionReason();

/*

Purpose:		

Date			Who		Reason
09/10/2015		cnwmh5	Initial creation

*/

vars

	pxyLRReason					: CM_LabourRestrictionReasonCode;
	lrReason					: CM_LabourRestrictionReasonCode;
	

begin

	lrReason := app.myRoot.allLabourRestictionsCodes["Michael's Test - DONT USE"];
	if lrReason &lt;&gt; null then
		app.myTrxDA.trxDeleteLRReasonCode(lrReason, app.myPassport);
		self.assertNoTrxErrorsOrWarnings();
	endif;

	create pxyLRReason transient;
	pxyLRReason.setProxy("UTMDHLRZ", "Michael's Test - DONT USE", true);
	
	app.myTrxCA.trxCreateLRReasonCode(pxyLRReason, lrReason, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
