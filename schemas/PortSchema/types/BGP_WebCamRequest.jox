<Class name="BGP_WebCamRequest" id="ef8dd70b-8336-4808-9233-9410e1602171">
    <superclass name="BGP_Request"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>&lt;display&gt;Web Cam Update&lt;/display&gt;
&lt;displayShort&gt;Web Cam&lt;/displayShort&gt;</text>
    <DbClassMap file="backgroundprocess"/>
    <PrimAttribute name="webCamFileName" id="e6da1681-74a9-4d4c-937f-afde95d2a4b9">
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="action" id="c691cc3b-235a-486a-a2fe-76ca2807147f">
        <updating/>
        <source>action(): Boolean updating;
// -------------------------------------------
// Created 21 January 2004 by cnwdvb1
// -------------------------------------------

vars

	errCode	: Integer;
	errTxt	: String;
begin

	on Exception do app.alertExceptionHandler(exception, null, self.getErrorDesc(), errCode, errTxt, true, true);
	on LockException do app.alertLockExceptionHandler(exception);
	
	// NO set user. Called to often.
	self.loadWebCamPic();

epilog	
	if errCode &lt;&gt; null then
		app.myTrxUA.trxUpdateBGPRequest(self, true, errCode, errTxt, app.myPassport);
	endif;
	inheritMethod();
	return true;


end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getDisplay" id="8cc3e7ba-9683-4094-b0a5-22801d07050a">
        <source>getDisplay(): String;
// -------------------------------------------
// Created 21 January 2004 by cnwdvb1
// -------------------------------------------
vars

	str, detail : String;

begin

	str := inheritMethod();

	return str &amp; Tab &amp; 'Updating Web Cam picture for terminal ' &amp; self.myTerminal.code;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="initRequestFromTask" id="1bf7f55c-7bee-4360-b959-e80a6c9e9373">
        <updating/>
        <source>initRequestFromTask(_task : CM_AutoTaskWebCam) updating;
// -------------------------------------------
// Created 21 January 2004 by cnwdvb1
// -------------------------------------------
vars

begin

	self.webCamFileName := _task.webCamFileName;
	inheritMethod(_task);


end;</source>
        <Parameter name="_task" type="CM_AutoTaskWebCam"/>
    </JadeMethod>
    <JadeMethod name="loadWebCamPic" id="69081e8a-6efb-49e9-b54e-d2f805fcd745">
        <source>loadWebCamPic() protected;
// -------------------------------------------
// Created 21 January 2004 by cnwdvb1
// -------------------------------------------
//03 Jan 2013	cnwrs1	32983 crash after user deleted.
vars

	file		: File;
	fileLength	: Integer;
	blob		: Binary;
	msg : String;
begin

	if self.myTerminal = null then
		app.raiseCMException1(Err_InvalidTerminal, 'Null', null, null);
	endif;
	
	create file transient;

	file.mode			:= File.Mode_Input;
	file.shareMode		:= File.Share_Read;
	file.fileName 		:= self.webCamFileName;
	file.kind			:= File.Kind_Binary;	

	if file.tryOpen then
		msg := 'Successfully opened web cam file ' &amp; self.webCamFileName &amp; ' for terminal ' &amp; self.myTerminal.code;
		app.writeLog(msg, LogINFO);	//25 Nov 2019	NDL	TFS 47053
		
		fileLength	:=	file.fileLength();
		blob := file.readBinary(fileLength);
		beginTransaction;
		self.myTerminal.setConfig(PicWebCamPicture01, blob);
		commitTransaction;
		self.myTerminal.causeEvent(self.myTerminal.getTerminalEvent(EVENT_WEBCAM_ONE_UPDATE),true,null);
		
	else
		msg := 'Unable to open web cam file &lt;' &amp; self.webCamFileName &amp; '&gt; for terminal ' &amp; self.myTerminal.code;
		app.writeLog(msg, LogINFO);
//		app.raiseCMException1(Full_Replacement_Message, 'Unable to open web cam file &lt;' &amp; self.webCamFileName &amp; '&gt; for terminal ' &amp; self.myTerminal.code, null, null);
	endif;
epilog
	if file &lt;&gt; null then //cnwrs1 sept 2006 get 2 exceptions if terminal is null
		file.close;
		delete file;
	endif;

end;</source>
        <access>protected</access>
    </JadeMethod>
</Class>
