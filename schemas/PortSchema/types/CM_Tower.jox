    <JadeMethod name="getOtherTrackedItem" id="3385c26a-fb7f-46c5-8d19-df2e74b710e7">
        <source>getOtherTrackedItem(_theAction : Integer): CM_TrackedItem;
// ---------------------------------------------------------------------------
// Created:		August  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	if self.nextPortHole &lt;&gt; null then
		return self.nextPortHole;
	elseif self.prevPortHole &lt;&gt; null then
		return self.prevPortHole;
	else
		return null;
	endif;

end;</source>
        <Parameter name="_theAction" type="Integer"/>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="getPicture" id="252dfe39-f6dd-4800-9223-63fc02397895">
        <source>getPicture(): Binary;
// ---------------------------------------------------------------------------
// Created:		June  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

	thePicture : Binary;
begin
	if not self.myTerminal.getConfig(ShowCargoPicture).Boolean then
		return null;
	endif;
	thePicture := app.myRoot.getConfig(PicCargoTower).Binary;
	
	return thePicture;
end;</source>
        <ReturnType type="Binary"/>
    </JadeMethod>
    <JadeMethod name="isOverStowed" id="1ff2e879-886d-462a-995f-e0f7711539ef">
        <source>isOverStowed(mode: Integer): Boolean;
/*
 ------------------------------------------------------------------------
Created:			14 September 2001 by cnwdwq1
Purpose:			Returns True if we are overstowed by another object.
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/
vars
	array : CM_LCArray;
	lc : CM_LocationsController;
begin
	lc := self.getPrimaryLocation(mode);
	array := self.getLocationsArray(mode, 0);
	if array = null then
		return false;
	endif;
	
	foreach lc in array do
		if lc.isTopTI(self, mode) = false then
			//------------------
			//Not the TOP item, overstowed!
			//------------------
			return true;
		endif;
	endforeach;
	return false;
end;</source>
        <Parameter name="mode" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="nextLocationId" id="766e16ff-1667-471c-a848-bad008cbd6db">
        <methodInvocation>mapping</methodInvocation>
        <source>nextLocationId(set: Boolean; _value: String io) mapping;
//Replaces C++. Returns the location of the stack position
//to the 'right' of this tower
vars
	tmpLC	: CM_LocationsController;
	tc : CM_TowerController;
	hgt : Integer;
	ti : CM_TrackedItem;
begin
	if set then
		app.raiseSetVirtualError(class.name, method.name);
		return;
	endif;

	tmpLC := self.getPrimaryLocation(REAL_MODE);
   	if tmpLC &lt;&gt; null and tmpLC.isKindOf(CM_TowerController) then
   		tc := tmpLC.CM_TowerController;
   		_value := tc.getMyNextController(CM_StackController).CM_StackController.getFullId;		
		foreach hgt in 1 to tc.numTIs do				//Get stack height
			ti := tc.allTrackedItems.at(hgt);
			if ti = self then
				break;
			endif;
  		endforeach;
   		_value := _value &amp; hgt.String;				//Append stack height
   	else
   		_value := null;
   	endif;

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="prevLocationId" id="3391f8cf-767c-41d0-b942-cea4ae286977">
        <methodInvocation>mapping</methodInvocation>
        <source>prevLocationId(set: Boolean; _value: String io) mapping;
//Replaces C++. Returns the location of the stack position
//to the 'left' of this tower
vars
	tmpLC	: CM_LocationsController;
	tc : CM_TowerController;
	hgt : Integer;
	ti : CM_TrackedItem;
begin

	if set then
		app.raiseSetVirtualError(class.name, method.name);
		return;
	endif;

	tmpLC := self.getPrimaryLocation(REAL_MODE);
   	if tmpLC &lt;&gt; null and tmpLC.isKindOf(CM_TowerController) then
   		tc := tmpLC.CM_TowerController;
   		_value := tc.getMyPreviousController(CM_StackController).CM_StackController.getFullId;
		foreach hgt in 1 to tc.numTIs do		//Get stack height
			ti := tc.allTrackedItems.at(hgt);
			if ti = self then break; endif;
		endforeach;
		_value := _value &amp; hgt.String;       //Append stack height
   	else
   		_value := null;				//Can't use towers outside of straddle stacks
   	endif;
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="f26cde17-0de7-4131-9182-b26034b12f52">
        <source>pxyCreateUpdateProxy(): SelfType;
// ---------------------------------------------------------------------------
// Created:		August  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy
// ---------------------------------------------------------------------------

vars
	aTower : CM_Tower;
	completedOK		: Boolean;
begin
	aTower :=  inheritMethod();

	aTower.nextPortHole := self.nextPortHole;	
	aTower.prevPortHole := self.prevPortHole;

	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return aTower;
	
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete aTower;
	endif;	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="queryConnectPortHole" id="b1584ec8-4502-4fb0-a43b-52900369aec4">
        <source>queryConnectPortHole(_theParams : CMIF_ConnectParams input ;ti : CM_TrackedItem; towerIsPrevious : Boolean; connectMode : Integer);
//NFS 3814 AJA 25/9/01: Modified to use connectMode so we can use it in connection code
/*Also found a bug: 'Is previous' refers to the position of the tower as seen by the stack controller
However, in this code, a stack controller which sees this tower as previous will be the next
stack controller from the perspective of the tower

*/
vars
	term	:	CM_Terminal;
	msgStr	:	String;
	commod		 	: CM_Commodity;
	ph 					: CM_Container;
	otherTi:      CM_Container;
	locnId	:	String;
	loopState	:	Integer;
	stackIsPrevious : Boolean;
	cntr : CM_Container;
begin
	stackIsPrevious := not towerIsPrevious;
	
	term := self.myTerminal;
	if ti = null then
		app.setContinueCMExceptions(false);
		app.raiseCMException1(ERR_NO_OBJECT, "TI Ref in QueryConnectTowerJade", null, null);
		return;	
	elseif not ti.isKindOf(CM_Container) then
		return;		//Only interested in containers
	else
		cntr := ti.CM_Container;	
	endif;	
	
	if not cntr.requiresTemperature then
		//Does not need temperature settings
		return;
	endif;

	if cntr.typeAttributes.bitAnd(ISO_INTEGRAL) &lt;&gt; 0 or cntr.hasCOU then
		//Integrals / COU's dont need tower.
		return;
	endif;

	self.exclusiveLock(self); 

	locnId	:= self.locationId;

	//---------------
	//Ensure these is no TI in spot we want
	//---------------
	if stackIsPrevious then
	  	ph := prevPortHole;
	else
	  	ph := nextPortHole;
	endif;
	
 	if connectMode &lt;&gt; QUERY_CONNECT and ph &lt;&gt; null then
		//Already has a TI connected
		app.setContinueCMExceptions(false);
		app.raiseCMException2(ERR_TOWER_CONNECTED, self.id.trimRight, ph.id.trimRight, null, null);
		return;		
 	endif;
 	//--------------------
 	//Start a loop, and set a state machine
 	//--------------------
 	loopState := OPERATIONAL;
	while true do
    	if loopState = OPERATIONAL then
    		loopState := SLIDE;
			if self.nonOperational then
				//I'm dead!

				if connectMode = QUERY_CONNECT then
					if _theParams.radioTelemetryUser then
						term.createStringAlert(SEVERE_WARNING, app.getErrorString2(ERR_TOWER_NONOP, self.id, locnId), null );		
					endif;
					app.setContinueCMExceptions(false);
					app.raiseCMException2(ERR_TOWER_NONOP, self.id, locnId, null, null);
					return;
				endif;

				if _theParams.radioTelemetryIgnoreWarnings then
					continue;	//R/T Warnings get gobbled if this is set.
				endif;
				if _theParams.radioTelemetryUser then
					//Radio telemetry user. Create an alert, and raise an execption
					term.createStringAlert(SEVERE_WARNING, app.getErrorString(ERR_MOVE_RT_ERR), app.getErrorString2(WARN_TOWER_NONOP, self.id.trimRight, self.locationId) );
					
					app.setContinueCMExceptions(false);
					app.raiseCMException(ERR_MOVE_RT_ERR, null, null);
					return;					
				endif;
				app.raiseCMException2(WARN_TOWER_NONOP, self.id.trimRight, self.locationId, null, null);
				_theParams.radioTelemetryGaveWarning := true;
			endif;

		elseif loopState = SLIDE then
			/* Rules here are:
			1: If only one container is connected to a tower then a slide must slide over
			the portholes on the far side of the tower to prevent the cold air escaping. 
			2: If the slide on the far side is non-functional then the far side must 
			have a container connected or the cold air will escape from the tower
			3: If the far slide is disabled and there is no container on the far side
			then we cannot connect to the tower as it can't maintain the set temperature 
			
			Nb the slides become disabled if their sliding mechanism is damaged, becomes
			corroded, or freezes up
			*/
			loopState := FAULT;
			if stackIsPrevious then
		  		if self.nextSlideDisabled then
					//----------------
					//Other slide dead, if no porthole, problem!
					//----------------
					if self.nextPortHole = null then
						if connectMode = QUERY_CONNECT then
							if _theParams.radioTelemetryUser then
								term.createStringAlert(SEVERE_WARNING, app.getErrorString2(ERR_OTHER_SLIDE_OPEN, self.id, locnId), null );		
							endif;
							app.setContinueCMExceptions(false);
							app.raiseCMException2(ERR_OTHER_SLIDE_OPEN, self.id, locnId, null, null);
							return;
						endif;

						if _theParams.radioTelemetryIgnoreWarnings then
							continue;	//R/T Warnings get gobbled if this is set.
						endif;
						if _theParams.radioTelemetryUser then
							//Radio telemetry user. Create an alert, and raise an execption
							term.createStringAlert(SEVERE_WARNING, app.getErrorString(ERR_MOVE_RT_ERR), app.getErrorString2(WARN_OTHER_SLIDE_OPEN,  self.id.trimRight, locnId));
							app.setContinueCMExceptions(false);
							app.raiseCMException(ERR_MOVE_RT_ERR, null, null);
							return;							
						endif;
						app.raiseCMException2(WARN_OTHER_SLIDE_OPEN, self.id.trimRight, locnId, null, null);
						_theParams.radioTelemetryGaveWarning := true;
					endif;
		  	endif;
		  else
		  	if self.prevSlideDisabled then
					//Other slide dead, if no porthole, problem!
					if self.prevPortHole = null then
						if connectMode = QUERY_CONNECT then
							if _theParams.radioTelemetryUser then
								term.createStringAlert(SEVERE_WARNING, app.getErrorString2(ERR_OTHER_SLIDE_OPEN, self.id, locnId), null );		
							endif;
							app.setContinueCMExceptions(false);
							app.raiseCMException2(ERR_OTHER_SLIDE_OPEN, self.id, locnId, null, null);
							return;
						endif;

						if _theParams.radioTelemetryIgnoreWarnings then
							continue;	//R/T Warnings get gobbled if this is set.
						endif;
						if _theParams.radioTelemetryUser then
							//Radio telemetry user. Create an alert, and raise an execption
							term.createStringAlert(SEVERE_WARNING, app.getErrorString(ERR_MOVE_RT_ERR), app.getErrorString2(WARN_OTHER_SLIDE_OPEN, self.id.trimRight, self.locationId) );
							app.setContinueCMExceptions(false);
							app.raiseCMException(ERR_MOVE_RT_ERR, null, null);
							return;							
						endif;
						app.raiseCMException2(WARN_OTHER_SLIDE_OPEN, self.id.trimRight, locnId, null, null);
						_theParams.radioTelemetryGaveWarning := true;
					endif;
		  	endif;
		  endif;

		elseif loopState = FAULT then
			/*Rules here are:
			1: If the connection mechanism on our side of the tower has a fault then we assume
			that the consequence is that we are unable to connect a container to that side
			2: If the connection mechanism on the far side of the tower is faulty then we assume
			that we can still connect to our side, since the tower has not been set as non-operational
			
			Nb: The variable names used are misleading: these are not slide faults, but faults with
			the connection mechanism or machinery of the tower
			*/
			loopState := TEMPERATURE;
			if stackIsPrevious then
		  		if self.prevSlideFault.trimRight &lt;&gt; null then
					if connectMode = QUERY_CONNECT then
						if _theParams.radioTelemetryUser then
							term.createStringAlert(SEVERE_WARNING, app.getErrorString3(ERR_TOWER_FAULT, self.id, locnId, prevSlideFault), null );		
						endif;
						app.setContinueCMExceptions(false);
						app.raiseCMException3(ERR_TOWER_FAULT, self.id, locnId, prevSlideFault, null, null);
						return;
					endif;

					if _theParams.radioTelemetryIgnoreWarnings = true then
						continue;	//R/T Warnings get gobbled if this is set.
					endif;
					if _theParams.radioTelemetryUser then
						//Radio telemetry user. Create an alert, and raise an execption
						term.createStringAlert(SEVERE_WARNING, app.getErrorString(ERR_MOVE_RT_ERR), app.getErrorString3(WARN_TOWER_FAULT, self.id.trimRight, self.locationId, self.prevSlideFault) );
						app.setContinueCMExceptions(false);
						app.raiseCMException2(ERR_MOVE_RT_ERR, self.id.trimRight, locnId, null, null);
						return;					  
					endif;
					app.raiseCMException3(WARN_TOWER_FAULT, self.id.trimRight, locnId, self.prevSlideFault, null, null);
					_theParams.radioTelemetryGaveWarning := true;
				endif;
		  	else			//Look at next tower
		  		if self.nextSlideFault.trimRight &lt;&gt; null then

					if connectMode = QUERY_CONNECT then
						if _theParams.radioTelemetryUser then
							term.createStringAlert(SEVERE_WARNING, app.getErrorString3(ERR_TOWER_FAULT, self.id, locnId, nextSlideFault), null );		
						endif;
						app.setContinueCMExceptions(false);
						app.raiseCMException3(ERR_TOWER_FAULT, self.id, locnId, nextSlideFault, null, null);
						return;
					endif;

					if _theParams.radioTelemetryIgnoreWarnings then
						continue;	//R/T Warnings get gobbled if this is set.
					endif;
					if _theParams.radioTelemetryUser then
						//Radio telemetry user. Create an alert, and raise an execption
						term.createStringAlert(SEVERE_WARNING, app.getErrorString(ERR_MOVE_RT_ERR), app.getErrorString3(WARN_TOWER_FAULT, self.id.trimRight, self.locationId, self.nextSlideFault) );
						app.setContinueCMExceptions(false);
						app.raiseCMException2(ERR_MOVE_RT_ERR, self.id.trimRight, locnId, null, null);
						return;						
					endif;
					app.raiseCMException3(WARN_TOWER_FAULT, self.id.trimRight, locnId, self.nextSlideFault, null, null);
					_theParams.radioTelemetryGaveWarning := true;
				 endif;
		 	endif;

		elseif loopState = TEMPERATURE then
			//NFS 3814: This is the only case where we give a warning at connect time. This is because it
			//is physically possible to connect two boxes of different temps to the same tower, but it
			//would be unwise to do so and should give some kind of alert
			
			loopState := FINALISE;
			//--------------
			//Check temperature compatibility
			//--------------
			commod := app.myRoot.allCommodities[cntr.commodity];

			if not commod.hasTemp then
		  	//-------------------
		  	//No temperature, TI can still go here.
		  	//-------------------
				return;
		 	endif;

			// get the ti on the other side if it is there.
			if stackIsPrevious then
				otherTi := nextPortHole;
			else
				otherTi := prevPortHole;
			endif;
			if otherTi = null then
		  	//-------------------
		  	//No TI on other side, fine.
		  	//-------------------
		  	return;
		  endif;
			if otherTi.contentsStatus = TI_CONTENTS_STATUS_EMPTY or otherTi.contentsStatus = TI_CONTENTS_STATUS_NULL then
				//--------------
				//Its empty, or a null commodity. Quit here.
				//--------------
				break;
			endif;
		  //-------------
		  //Check prospective TI's temperature against the
		  //temperature of the commodity on the other side of the tower
		  //-------------
		  if (otherTi.getTemperature = NULL_TEMPERATURE) then
		  	return;
		  endif;
		  //-----------------
		  //Temperature test. For moves, the test is triggered by the autoPlanTest setup. For connections, we
		  //only care if the tower temp is outside the temp range for the commodity. This is a (the only)
		  //warning for manual query connect and is an exception for RT connections
		  //-----------------
			if self.getPrimaryLocation(REAL_MODE).CM_TowerController.myTerminalArea.autoPlanTest.testTowerSpecificTemperature = true 
				and connectMode &lt;&gt; QUERY_CONNECT then
			  if (otherTi.getTemperature &lt;&gt; cntr.getTemperature) then
					if _theParams.radioTelemetryIgnoreWarnings then
						continue;	//R/T Warnings get gobbled if this is set.
					endif;
					if _theParams.radioTelemetryUser then
						//Radio telemetry user. Create an alert, and raise an execption
						term.createStringAlert(SEVERE_WARNING, app.getErrorString(ERR_MOVE_RT_ERR), app.getErrorString2(WARN_TOWER_STEMPERATURE, self.id.trimRight, self.locationId) );
						app.setContinueCMExceptions(false);
						app.raiseCMException2(ERR_MOVE_RT_ERR, self.id.trimRight, locnId, null, null);
						return;
					endif;
					app.raiseCMException2(WARN_TOWER_STEMPERATURE, self.id.trimRight, locnId, null, null);
					_theParams.radioTelemetryGaveWarning := true;
			  else
			  	//Its good!
			  	return;
			  endif;	
			else
		 	 if ((otherTi.getTemperature &lt; commod.minTemp) or (otherTi.getTemperature &gt; commod.maxTemp)) then

					if connectMode = QUERY_CONNECT and _theParams.radioTelemetryUser then
						//Connecting via RT only (via app is handled as below)
						term.createStringAlert(SEVERE_WARNING, app.getErrorString2(WARN_TOWER_TEMPERATURE, id.trimRight, locationId), null );
						app.setContinueCMExceptions(false);
						app.raiseCMException2(WARN_TOWER_TEMPERATURE, id.trimRight, locationId, null, null);
						return;					
					endif;
					if _theParams.radioTelemetryIgnoreWarnings then
						continue;	//R/T Warnings get gobbled if this is set.
					endif;
					if _theParams.radioTelemetryUser then
						//Radio telemetry user. Create an alert, and raise an execption
						term.createStringAlert(SEVERE_WARNING, app.getErrorString(ERR_MOVE_RT_ERR), app.getErrorString2(WARN_TOWER_TEMPERATURE, self.id.trimRight, self.locationId) );
						app.setContinueCMExceptions(false);
						app.raiseCMException2(ERR_MOVE_RT_ERR, self.id.trimRight, locnId, null, null);
						return;					
					endif;
					app.raiseCMException2(WARN_TOWER_TEMPERATURE, id.trimRight, locnId, null, null);
					_theParams.radioTelemetryGaveWarning := true;
			 	endif;
		  endif;
		endif;

		if loopState = FINALISE then
			break;
		endif;
	endwhile;
end;</source>
        <Parameter name="_theParams" type="CMIF_ConnectParams" usage="input"/>
        <Parameter name="ti" type="CM_TrackedItem"/>
        <Parameter name="towerIsPrevious" type="Boolean"/>
        <Parameter name="connectMode" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="a7bbe9f1-2fef-4f99-9ed7-6f02da3be5df">
        <updating/>
        <source>setForUpdate(_pxyTI: CM_Tower; 
			_tiUpdateCntrl : CMIF_TIUpdateController input; 
			_extraParams : CMIF_TIUpdateExtraParams; //cnwrd1 28.8.09 par 20545
			_isCheckEdition : Boolean;
			_passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:		August  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	inheritMethod(_pxyTI, _tiUpdateCntrl, _extraParams, _isCheckEdition, _passport); //cnwrd1 28.8.09 par 20545

	self.nextPortHole := _pxyTI.nextPortHole;
	self.nextSlideDisabled := _pxyTI.nextSlideDisabled;
	self.nextSlideFault := _pxyTI.nextSlideFault;
	
	self.nonOperational := _pxyTI.nonOperational;
	
	self.prevPortHole := _pxyTI.prevPortHole;
	self.prevSlideDisabled := _pxyTI.prevSlideDisabled;
	self.prevSlideFault := _pxyTI.prevSlideFault;
	self.temperature := _pxyTI.temperature;
	self.remarks := _pxyTI.remarks;
end;</source>
        <Parameter name="_pxyTI" type="CM_Tower"/>
        <Parameter name="_tiUpdateCntrl" type="CMIF_TIUpdateController" usage="input"/>
        <Parameter name="_extraParams" type="CMIF_TIUpdateExtraParams"/>
        <Parameter name="_isCheckEdition" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setNonOperational" id="af77138d-5ebc-4744-b706-ca636c0b6ac4">
        <updating/>
        <source>setNonOperational(_value : Boolean) updating;
// ---------------------------------------------------------------------------
// Created:		August  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	if _value &lt;&gt; self.nonOperational then
		self.nonOperational := _value;
	endif;

end;</source>
        <Parameter name="_value" type="Boolean"/>
