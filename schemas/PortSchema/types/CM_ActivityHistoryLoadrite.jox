    <JadeMethod name="getDetailForDisplay" id="92b253e3-b727-445c-9402-ea2b9401e495">
        <source>getDetailForDisplay(_array: HugeStringArray input): Boolean;

// Created by cnwdvb1 on 03 October 2006

vars

begin

	if not inheritMethod(_array) then
		return false;
	endif;

	self.addToArray(app.getErrorString(Machine), self.machine, _array);
	self.addToArray(app.getErrorString(Driver), self.driver, _array);
	self.addToArray(app.getErrorString(Message), self.loadriteMsg, _array);
	
	return true;
end;</source>
        <Parameter name="_array" type="HugeStringArray" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
