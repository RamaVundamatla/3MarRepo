    <JadeMethod name="getSealCheckTypeForContext" id="2d452df7-f436-4393-a2f1-da2d6ed7a9b5">
        <source>getSealCheckTypeForContext( _context : Integer ): Integer;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
01 September 2010	cnwndl1	Initial creation	Par 23715
02 Feb 2024			jlier1 TFS  62142
*/

vars

	returnType : Integer;
	
begin

	if _context.isOneOf(CARGO_CHECK_CONTEXT_TRUKUNLOAD,CARGO_CHECK_CONTEXT_GATE_REC, CARGO_CHECK_CONTEXT_ROAD_REC ) then	//07 May 2014	NDL	Par 34076
		returnType := self.sealCheckRoadReceival;
//	elseif _context.isOneOf(CARGO_CHECK_CONTEXT_TRUKLOAD,CARGO_CHECK_CONTEXT_GATE_REL) then
	elseif _context.isOneOf(CARGO_CHECK_CONTEXT_TRUKLOAD,CARGO_CHECK_CONTEXT_GATE_REL, CARGO_CHECK_CONTEXT_ROAD_REL ) then	//19 Nov 2019	NDL	TFS 47568
		returnType := self.sealCheckRoadRelease;
	elseif _context = CARGO_CHECK_CONTEXT_SHIP_LOAD  or _context = CARGO_CHECK_CONTEXT_VOYOP_LOAD  then
		returnType := self.sealCheckShipRelease;
	elseif _context = CARGO_CHECK_CONTEXT_SHIP_DISC or _context = CARGO_CHECK_CONTEXT_VOYOP_DISC then
		returnType := self.sealCheckShipReceival;
	elseif _context = CARGO_CHECK_CONTEXT_RAIL_REC then
		returnType := self.sealCheckRailReceival;
	elseif _context = CARGO_CHECK_CONTEXT_RAIL_REL then
		returnType := self.sealCheckRailRelease;
	endif;
	
	return returnType;

epilog

end;</source>
        <Parameter name="_context" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
