//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 17/02/2015	cnwdap1		Initial creation PAR #35526 Change visit number of vehicle visit
//							"170" in Penn terninal's system to "V170"
//
vars
	terminal 	: CM_Terminal;
	vvr 		: CM_VehicleVisitRecord;

begin
	app.initialize;
	terminal := app.myRoot.allTerminals["PTI"];
	if terminal = null then
		return;
	endif;
	vvr := "3100.1183".asOid.CM_VehicleVisitRecord;
	if vvr = null or (vvr &lt;&gt; null and vvr.visitNumber &lt;&gt; "170") then
		return;
	endif;
	
	beginTransaction;
	vvr.setPropertyValue(CM_VehicleVisitRecord::visitNumber.name, "V170");
	commitTransaction;
epilog

end;</source>
