    <JadeMethod name="translateForm" id="9450e4be-a549-40a9-81a5-f42f97d8d6ca">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0008397, locale);
	btnAdd.translateCaption(Xlat_0004201, locale);
	btnAll.translateCaption(Xlat_0004202, locale);
	btnClear.translateBubbleHelp(Xlat_0004200, locale);
	btnClear.translateCaption(Xlat_0004203, locale);
	btnDelete.translateCaption(Xlat_0004204, locale);
	btnRetrieve.translateCaption(Xlat_0004205, locale);
	clrOne.translateCaption(Xlat_0004206, locale);
	clrOneDark.translateCaption(Xlat_0004207, locale);
	clrThree.translateCaption(Xlat_0004208, locale);
	clrTwo.translateCaption(Xlat_0004209, locale);
	lblMask.translateCaption(Xlat_0004210, locale);
	mnuAdd.translateCaption(Xlat_0008398, locale);
	mnuAddAll.translateCaption(Xlat_0008399, locale);
	mnuCargoEnquiry.translateCaption(Xlat_0008400, locale);
	mnuRemove.translateCaption(Xlat_0008401, locale);
	mnuTableContext.translateCaption(Xlat_0008402, locale);
	shtBuildStatus.translateCaption(Xlat_0004199, locale);
	shtBuildType.translateCaption(Xlat_0004211, locale);
end;</source>
    </JadeMethod>
    <JadeMethod name="updLoadProgress" id="ef4b7809-d63d-464b-87ed-463f34c72247">
        <updating/>
        <source>updLoadProgress() updating;
// ---------------------------------------------------------------------------
// Created:		12 August 2003 by cnwsgp1
// ---------------------------------------------------------------------------
vars
	count : Integer;

begin
	progressPartsDone := progressPartsDone + 1;
	count := progressPartsDone;

	if progressUpdateAfter &gt; 0 and count mod progressUpdateAfter = 0 then
		self.modalDialogUpdateInfo('Loaded ' &amp; count.String &amp; ' of ' &amp; self.progressTotalParts.String);
		self.pbProgressBar.partsDone := count;
		self.pbProgressBar.doWindowEvents(0);
	endif;
	
	self.btnModalDefault.doWindowEvents(0);
	if self.modalDialogReturnValue = ModalDialogReturn_Null then
		// see if the user has pressed the Cancel button
		self.btnModalOpt1.doWindowEvents(0);
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="updSearchProgress" id="e8ccc4ca-8029-4d9f-91fa-f58a86696ca8">
        <updating/>
        <source>updSearchProgress(itemsFound : Integer) updating;
// ---------------------------------------------------------------------------
// Created:		12 August 2003 by cnwsgp1
// ---------------------------------------------------------------------------
vars
	count : Integer;

begin
	progressPartsDone := progressPartsDone + 1;
	count := progressPartsDone;

	if progressUpdateAfter &gt; 0 and count mod progressUpdateAfter = 0 then
		self.modalDialogUpdateInfo('Searched ' &amp; count.String &amp; '  found ' &amp; itemsFound.String);
		self.pbProgressBar.partsDone := count;
		self.pbProgressBar.doWindowEvents(0);
	endif;
	
	self.btnModalDefault.doWindowEvents(0);
	if self.modalDialogReturnValue = ModalDialogReturn_Null then
		// see if the user has pressed the Cancel button
		self.btnModalOpt1.doWindowEvents(0);
	endif;
end;</source>
        <Parameter name="itemsFound" type="Integer"/>
    </JadeMethod>
</GUIClass>
