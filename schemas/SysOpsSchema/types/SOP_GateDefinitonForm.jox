	// ### TFS 52773 04MAY2022 NAVPW1
	
	col := table.getColumnByRowName (ETRow_Lane_rfid_tag_read);
	
	if col &gt; 0 then
		table.accessColumn (col).cellControl	:= cmbRFIDReader;
	endif;
	
	col := table.getColumnByRowName (ETRow_Lane_rfid_tag_assign);
	
	if col &gt; 0 then
		table.accessColumn (col).cellControl	:= cmbRFIDReaderA;
	endif;
	
	col := table.getColumnByRowName (ETRow_Lane_boom_in);
	
	if col &gt; 0 then
		table.accessColumn (col).cellControl	:= cmbBoom; 
	endif;
	
	col := table.getColumnByRowName (ETRow_Lane_boom_out);
	
	if col &gt; 0 then
		table.accessColumn (col).cellControl	:= cmbBoomOut;
	endif;
	
	col := table.getColumnByRowName (ETRow_Lane_kiosk);
	
	if col &gt; 0 then
		table.accessColumn (col).cellControl	:= cmbKiosk;
		
		// don't show kiosk column if they don't have a license for it
