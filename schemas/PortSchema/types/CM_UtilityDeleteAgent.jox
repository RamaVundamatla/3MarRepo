    <JadeMethod name="utlDeleteDebtorAddress" id="27d9d387-2056-4875-a1a4-92f505235b2e">
        <updating/>
        <source>utlDeleteDebtorAddress(_address : CM_Address input; _passport : CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 July 2019	cnwma1	ChangeRequest 45577: ASPA - JMT Interface to AR Oracle
*/
vars
	debtorBefore : String;
	debtor       : CM_Debtor;
begin
	self.initialiseActivity();

	app.setContinueCMExceptions(true);

	app.myValDA.valDebtorAddress(_address);

	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;

	app.setContinueCMExceptions(false);
	
	debtorBefore := _address.myDebtor.getAuditText;
	debtor		 := _address.myDebtor;
	

	if _passport.noErrors then
		_address.erase(NORMAL_ERASE);
	endif;
	
	if _passport.noErrors then
		app.myAA.auditUpdateTrx(debtor, debtorBefore, debtor.getAuditText());
	endif;

end;</source>
        <Parameter name="_address" type="CM_Address" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
