    <JadeMethod name="setForCreate" id="367bf7e9-0508-4fba-8148-d786e366c7db">
        <updating/>
        <source>setForCreate(_pxyObject: CM_ITSInterfaceRequestInternal; _passport : CM_Passport input) updating;

/*

Purpose:			

Parameters:			

Return Value:		None


Date		Who		Reason
26 Nov 2009	consw1	PAR #21593 - Development of CCMS MES 1014 - RDT ITS Interface

*/

vars

begin
	self.createdTS		:= _pxyObject.createdTS;
	self.priority		:= _pxyObject.priority;

	self.myUser			:= _pxyObject.myUser;
	self.myMachine		:= _pxyObject.myMachine;
	
	self.myITSInterfaceDefinition := _pxyObject.myITSInterfaceDefinition;
	
epilog

end;</source>
        <Parameter name="_pxyObject" type="CM_ITSInterfaceRequestInternal"/>
