    <JadeMethod name="doMnuUnplanClick" id="5eba5c22-7bcd-4fd2-8588-e90a21b9e510">
        <updating/>
        <source>doMnuUnplanClick(_menuItem : MenuItem input) updating;
//----------------------------------------------------------------
//	Created:	14 August 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------

vars

begin

	if _menuItem.helpKeyword = self.UnplanMenu_TypeMain then
		return;
	endif;
	if _menuItem.helpKeyword = self.UnplanMenu_TypeRehandle then
		 return;
	endif;

	if _menuItem.userObject.isKindOf(CM_TrackedItem) then
		if _menuItem.userObject.CM_TrackedItem.getPrimaryLocation(QUEUE_MODE) &lt;&gt; null then 		
			doUnqueueTI(_menuItem.userObject.CM_TrackedItem);
		else
			self.doUnplanTI(_menuItem.userObject.CM_TrackedItem,(_menuItem.helpKeyword = "LOAD"));
		endif;
	elseif _menuItem.userObject.isKindOf(CM_FutureMove) then // PAR 18962
		self.doUnqueueTIbyFM(_menuItem.userObject.CM_FutureMove);// PAR 18962
	
	endif;
end;</source>
        <Parameter name="_menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doNoteHandlingObject" id="03ba7fb5-9ad9-4b7b-9935-288e486fbf32">
        <updating/>
        <source>doNoteHandlingObject(_object: CMIF_NotificationRecord) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
30 May 2025			jlizm1	Initial creation MTN 34728 Handle notifications cargo enquiry

*/

vars
	eventType	: Integer;
	eventTag	: Integer;
	noteObj		: CM_Object;
	userInfo	: Any;
	
begin
	eventType := _object.eventType;
	eventTag := _object.eventTag;
	noteObj := _object.myObject.CM_Object;
	
	if eventType = Object_Update_Event then
		self.zTblDataSysNotifyUpdate(eventType, noteObj, eventTag);
		
	elseif eventType = Object_Create_Event then
		self.zTblDataSysNotifyCreate(eventType, noteObj, eventTag);
		
	elseif eventType = Object_Delete_Event then
		self.zTblDataSysNotifyDelete(eventType, noteObj, eventTag);
	
	else
		if _object.myUserInfo &lt;&gt; null then
			userInfo := _object.myUserInfo;
		else
			userInfo := _object.userInfoString;
		endif;
		self.doUserNotes(eventType, noteObj, eventTag, userInfo);
	
	endif;

epilog

end;</source>
        <Parameter name="_object" type="CMIF_NotificationRecord"/>
    </JadeMethod>
