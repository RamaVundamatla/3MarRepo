    <JadeMethod name="initCarrierCombo" id="22bbe5ac-14db-4c0b-bc0d-bbbd66a6e088">
        <source>initCarrierCombo();
// ---------------------------------------------------------------------------
// Created:     07 August 2008 by cnwab1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//	12/10/2009		cnwas3			PAr 20798
//	Mar 2011		cnwjre1			25096 limit to road carriers
// ---------------------------------------------------------------------------

vars
	aCarrier : CM_Carrier;
	combo : CMUI_ComboBox;
begin
	combo := self.cmbCarrier;
	combo.clear();
	//foreach aCarrier in app.myRoot.allCarriers discreteLock do //cnwas3 PAR 20798 commented out
	// 25096 limit to visible road-only carriers
	foreach aCarrier in app.myRoot.allCarriersRoad discreteLock where not aCarrier.isNotAvailableForEntry do //cnwas3 PAR 20798
		combo.addItemObject(aCarrier.description, aCarrier);
	endforeach;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="initReleases" id="9cf731c2-6932-44d4-bf04-d49bbea7866f">
        <source>initReleases();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 September 2011	cnwndl1	Initial creation	Par 24455

*/

vars

	entDef : EntTableDef;
	col : Integer;
	size : Integer;

begin

	self.splReleases.cnEcResizeContents();
	
	tblBulkRelease.setTerminologyRelevant(null,self.myTerminal);
	self.tblBulkRelease.selectMode := Table.SelectMode_CurrentRow;

	entDef := app.myController.getEntTableDef(ETDef_MTReleaseDataTable);
	tblBulkRelease.setMyEntTableDef(entDef);	
	tblBulkRelease.setTblDataEntRowsFromDef(entDef);	
	if not self.myTerminal.isSubTerminalsOn() then
		self.tblBulkRelease.hideColumnByColPropertyName(ETRow_MySubTerminal);
	endif;
	
	// stop the user from changing any of the check box values.
	size := self.tblBulkRelease.allTblDataColInputTypes.size;
	foreach col in 1 to size do
		if self.tblBulkRelease.allTblDataColInputTypes[col] = 1 then
			self.tblBulkRelease.accessColumn(col).enabled := false;
		endif;
	endforeach; 

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="initSubCarrierCombo" id="7e517f11-975e-4523-a061-306f48b9d476">
        <updating/>
        <source>initSubCarrierCombo() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 May 2022	navhl20	ChangeRequest 53430: EUP - Sub Carrier registration in MTN 

*/

vars
	aCarrier : CM_Carrier;
	combo    : CMUI_ComboBox;
begin
	combo := self.cmbSubCarrier;
