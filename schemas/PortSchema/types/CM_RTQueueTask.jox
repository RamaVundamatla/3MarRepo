    <JadeMethod name="matchesTIorRegNum" id="84a7bb21-31a1-4b48-956f-b5f8337cab03">
        <source>matchesTIorRegNum(	_search, _twinSearch : String;
					_machine : CM_Machine) : Boolean;
/*

Date		Who		Reason
18 August 2014	cnwer1	Initial creation PAR

*/

vars
	ti 			: CM_TrackedItem;
	regNum 		: String;
	matches 	: Boolean;
	wle 		: CM_WorkListEntry;
	job			: CM_Job;
	rfid		: CM_RFIDTag;
begin
	matches:=false;

	//have to check ti matches 
	ti :=self.myEntry.getTrackedItem();
	if ti &lt;&gt; null then
		if ti.id.startsWith(_search) then
			matches:= true;
		endif;
		
		if not matches and  ti.idReversed.startsWith(_search.reverse) then
			matches:= true;
		endif;
		
		if _twinSearch &lt;&gt; null then
			if not matches and ti.id.startsWith(_twinSearch) then
				matches:= true;
			endif;
			
			if  not matches and ti.idReversed.startsWith(_twinSearch.reverse) then
				matches:= true;
			endif;
		endif;
	endif;
	
	// if there is a twin search criteria not searching to reg
	if  _twinSearch = null  then
		// at this stage only when the target is vehicle because drivers don't have a container to see to type container id in
		wle:=self.myEntry.myWorkListEntry;
		if wle &lt;&gt; null  then
			job:=wle.job;
			if job &lt;&gt; null and job.isKindOf(CM_RoadJob) then
				// receival from a truck - 
				regNum:= job.CM_RoadJob.regNumber;
				if regNum &lt;&gt; null and not matches and (regNum =_search) then // (regNum.startsWith(_search) or regNum.reverse.startsWith(_search.reverse))   then
					matches:= true;
				endif;
				
				rfid := job.CM_RoadJob.myRFIDTag;
				if rfid &lt;&gt; null then
					if not matches and (rfid.code = _search)   then
						matches:= true;
					endif;
				endif;
			endif;
		endif;
	endif;	
	
	if not matches then
		return false;
	endif;
	
	//already working the task don't bother re doing the query machine assign
	if self.machine &lt;&gt; null and self.machine = _machine then
		return true;
	endif;
	
	return self.queryMachineAssign(_machine,true,false,true,false,true,null);
epilog

end;</source>
        <Parameter name="_search" type="String"/>
        <Parameter name="_twinSearch" type="String"/>
        <Parameter name="_machine" type="CM_Machine"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="f5bce307-d721-4ab0-99e1-128282ab5a4b">
        <source>pxyCreateUpdateProxy(): SelfType;
// ---------------------------------------------------------------------------
// Created:		February  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy
// ---------------------------------------------------------------------------

vars
	lTask : CM_RTQueueTask;
	completedOK		: Boolean;
begin
	lTask := inheritMethod();

	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return lTask;

epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete lTask;
	endif;	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="queryEntryMachineTypeGroup" id="dbeecc10-4e84-429c-9168-253a01a8ec21">
        <source>queryEntryMachineTypeGroup(	_mach : CM_Machine; 
							_messageLogger : CM_MessageLogger ): Boolean protected;
/*

Purpose:		Does 2 checks to do with machine type
						1. Checks the queues machine types matches the machine type
						2. Checks the queue entrys machine type matches the machine type

Parameters:			

Return Value:		


Date		Who		Reason
19 August 2010	cnwer1	Initial creation PAR 25433

*/

vars
	entryMachineTypeGrp,
	machineGrp : CM_MachineTypeGroup;
	aStr		: String;
begin

	machineGrp:=_mach.getMachineTypeGroup;
	if machineGrp = null then
		return true;
	endif;
	//moved from query Machine Assign
	if not self.queue.compareQueueToType(machineGrp) then
		aStr:=app.getErrorString3(MACH_QUEUE_MACH_TYPE,_mach.id,self.queueId,machineGrp.description);
		if _messageLogger &lt;&gt; null then
			_messageLogger.addLog(aStr,SEVERE_WARNING, MACH_QUEUE_MACH_TYPE);
		endif;
		return false;
	endif;
	

	//no move method rule hence why there is no machine type group then is just a pickup or setdown can return true
	if self.myEntry.machineTypeGroup = 0 then
		return true;
	endif;
	
	/*note we are only testing the machine type group on the entry the machine type grp on tasks are for what machine type grp is used on pickup,
		or what machine type grp is used on setdown or on the move
		e.g. with entries created with machine rule Fork Lift -&gt; Source IC -&gt; Straddle
			the first entry will have machine type grp Fork Lift
				- pickup task machine type grp will be Fork lift
				- setdown task  machine type will be  Source IC
			the second entry will have machine type grp Straddle
				- pickup task machine type grp will be Source IC
				- setdown task  machine type will be  Straddle
	*/
	
	entryMachineTypeGrp:=app.myRoot.allMachineTypeGroups[self.myEntry.machineTypeGroup].CM_MachineTypeGroup;
	
	if entryMachineTypeGrp &lt;&gt; machineGrp then
		if _messageLogger &lt;&gt; null then
			aStr:=app.getErrorString3(MACH_QENTRY_DIFF_TYPE_GRP, _mach.id,machineGrp.description,entryMachineTypeGrp.description);
			_messageLogger.addLog(aStr,SEVERE_WARNING, MACH_QENTRY_DIFF_TYPE_GRP);
		endif;
		return false;
	endif;
	
	return true;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_mach" type="CM_Machine"/>
        <Parameter name="_messageLogger" type="CM_MessageLogger"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="queryIMVSwitch" id="20ff1c00-51a3-4d11-aa74-07ceda35723e">
        <source>queryIMVSwitch( _allMachines : CM_MachineByIdDict io) : Boolean;

/*

Purpose:	CCMS SFW 1124 switch RTQ job onto correct IMV		

Parameters:			

Return Value:		


Date		Who		Reason
22 April 2010	cnwrd1	Initial creation

*/

vars
	machineDict,
	inheritedMachines : CM_MachineByIdDict;
	machine : CM_Machine;
	messageLogger : CM_IndentedMessageLogger;
	foundMachine : Boolean;
	allowIMVWorkRTLoggedOff : Boolean;
begin



	if _allMachines = null then
		return false;
	endif;
	
	allowIMVWorkRTLoggedOff :=  self.myEntry.getMyTerminal().getConfig(AllowIMVWorkRTLoggedOff).Boolean; //cnwrd1 for par 31382 
	foundMachine:=false;

	
	create machineDict transient;
	self.queue.getAllMachines(machineDict,false,false,false);
	
	create messageLogger transient;
	messageLogger.indent:=Tab;
	
	if machineDict.size &gt; 0 then
	endif;
	
	foreach machine in machineDict  where machine.machineType = MACHINETYPE_IMV
	do
		if self.queryMachineAssign(machine,true,false,false,true,true,messageLogger) and ( machine.loggedOn or allowIMVWorkRTLoggedOff) then //cnwrd1 for par 31382 
			if not _allMachines.includes( machine) and self.machine &lt;&gt; machine then  //cnwrd1 par 31382 IMV's working whilst not loged on.
				_allMachines.add(machine);
			endif;
			foundMachine:=true;
		endif;

	endforeach;
	
	create inheritedMachines transient;
	self.queue.getAllMachines(inheritedMachines,false,true,false);

	foreach machine in inheritedMachines  where machine.machineType = MACHINETYPE_IMV
	do
		if machineDict.includes(machine) then
			continue;
		endif;
		
		if self.queryMachineAssign(machine,true,false,false,true,true,messageLogger) and ( machine.loggedOn or allowIMVWorkRTLoggedOff) then//cnwrd1 for par 31382 
			// add to collection
			if not _allMachines.includes( machine) and self.machine &lt;&gt; machine then
				_allMachines.add(machine);
			endif;			
			foundMachine:=true;
		endif;		
	endforeach;
	
	
	return foundMachine;
epilog
	delete machineDict;
	delete inheritedMachines;
	delete messageLogger;
end;</source>
        <Parameter name="_allMachines" type="CM_MachineByIdDict" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="queryMachineAccessTarget" id="6bdd5505-ee2c-4dca-9f60-1848f6e831e0">
        <source>queryMachineAccessTarget( 	_mach : CM_Machine;
							sourceLocationParent : CM_Object;
							_messageLogger : CM_MessageLogger input)  : Boolean protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 August 2010	cnwer1	Initial creation

*/

vars
	targetLocationParent : CM_Object;
	machId,
	aStr	: String;
	nextEntry : CM_RTQueueEntry;
	edition : Integer;
	invalid : Boolean;
	setdownTask : CM_RTQueueTask;
begin
	machId:=_mach.id.trimRight;
	
	//cnwrd1 par 25681 18.11.2010 multi machine director moves
	if self.targetLocation = null and self.taskType &lt;&gt; TASK_DIRECTOR and self.taskType &lt;&gt; TASK_BREAKBULK and not self.isFirstDirectorTask and not self.isPlanOnPickup and not self.myEntry.isMachineInitiatedMove then
		// epr ccms 1100  ok if going to an imv
		nextEntry:=self.myEntry.getNextRelatedEntry();  //epr par 35702 CCMS 2457 17/2/15
		if nextEntry = null or
			nextEntry.allTasks.first.taskType &lt;&gt; TASK_MOVE then
			
			//jlier1 TFS 54701 19/9/22
			//if it is setdown on a MAFI it can pick up the task because it does not need to know the MAFI Yet
			setdownTask:= self.myEntry.getTaskOfType(TASK_SETDOWN,null);
			if setdownTask = null or setdownTask.machineTypeGroup &lt;&gt; MACHINETYPEGRP_MAFI then
			
				if _messageLogger &lt;&gt; null then
					//_messageLogger.addLog("Machine :" &amp; machId &amp;  "  Target location is NULL!!! (Error).",SEVERE_INFO,0);
					aStr := app.getErrorString1(Machine_target_location_null, machId);
					_messageLogger.addLog(aStr,SEVERE_INFO,Machine_target_location_null);
				endif;
				return false;
			endif;
		endif;
	endif;	

	if targetLocation = null then
		return true;
	endif;
	
	//08 Jan 2020	NDL	TFS 48204
	on Exception do app.handleDeletedObject( exception, self.targetLocation, invalid );
	edition := self.targetLocation.edition;
	if invalid then
		if _messageLogger &lt;&gt; null then
			_messageLogger.addLog(aStr,SEVERE_INFO, Targe_locat_move_this_item_inv);
		endif;
		return false;
	endif;
	
	targetLocationParent:=self.getTargetLocationParent(_mach);
		
	if targetLocationParent.isKindOf(CM_Voyage) then
		//--------------
		//To SHIP, only a CRANE can do this! BUT ONLY if source is a Crane Transfer Area
		//--------------
		//27 Mar 2018	NDL	TFS 37569 - Remove this check
	/*	if sourceLocationParent.isKindOf(CM_CraneTransferArea) then
			if not _mach.isKindOf(CM_Crane) then
				if _messageLogger &lt;&gt; null then
					_messageLogger.addLog(app.getErrorString2(MACH_ACCESS_CTA,machId,sourceLocation.getParent.CM_CraneTransferArea.id.asStringJMT),SEVERE_INFO,MACH_ACCESS_CTA);
				endif;
				return false;
			endif;
		endif; */
	else
		if targetLocationParent.isKindOf(CM_Machine) then
			//Is a machine, users have trued to stuff with the task, its target is a machine
			//when it was originally a terminal area. This is OK.
			//mach.addLogEntry("Machine task sourcelocation... Is OK.");
			return true;
		endif;
		if targetLocationParent.isKindOf(CM_TerminalArea) and 
			not _mach.canMachineAccessTAObj(targetLocationParent.CM_TerminalArea, self.getAreaIsTarget) then
			//RTGs don't need swap jobs just give error 
			if self.myEntry.machineTypeGroup = MACHINETYPEGRP_RTG then
				aStr := app.getErrorString2(MACH_ACCESS_TARGET,machId, targetLocation.getFullId);
				if _messageLogger &lt;&gt; null then
					_messageLogger.addLog(aStr,SEVERE_INFO,MACH_ACCESS_TARGET);
				endif;
				return false;
			endif;
			
			//----------------
			//If the taskType is a director task, the machine MUST be able to enter target to get it.
			//----------------
			if taskType = TASK_DIRECTOR then
				
				//epr par 25373 13/8/10
				if self.myEntry.myRTMoveMethodRule &lt;&gt; null then
					/*if the machine types groups are &gt; 1 it means that the machine is going to put the container either on an IMV or
					// in a interchange area . So testing the ultimate target location is incorrest and in most cases this will be an
					//area the machine can not access. 
					*/
					if self.myEntry.myRTMoveMethodRule.myRTMoveMethod.allMachineTypeGroups.size &gt; 1 then
						return true;
					endif;
				endif;
			
			
				aStr := app.getErrorString2(MACH_ACCESS_TARGET_DIRECTOR,machId, targetLocation.getFullId);
				if _messageLogger &lt;&gt; null then
					_messageLogger.addLog(aStr,SEVERE_INFO, MACH_ACCESS_TARGET_DIRECTOR);
				endif;
				return false;
			endif;
			//----------------
			//If the configuration says "no create a swap job", puke..
			//----------------
			if (not self.getMyTerminal().isAutoPlanGenerateSwapJob) then   //SFW1030 04/08/2008
				aStr := app.getErrorString2(MACH_ACCESS_TARGET_SWAP,machId,targetLocation.getFullId);
				if _messageLogger &lt;&gt; null then
					_messageLogger.addLog(aStr,SEVERE_INFO, MACH_ACCESS_TARGET_SWAP);
				endif;
				
				return false;
			endif;
			//--------------
			//Make SURE this is NOT already a SwapJob. We cannot Swap a Swap Job!
			//--------------
			if self.myEntry.myJob.isKindOf(CM_YardInternalJob) then
				if self.myEntry.myJob.CM_YardInternalJob.isSwapJob then
					//--------------
					//This is a swapJob, created because a previous machine could not access the
					//target area. If this machine cannot access it, tough titty.
					//--------------
					aStr := app.getErrorString2(MACH_MOVE_ALREADY_SWAP, machId,targetLocation.getFullId); 
					if _messageLogger &lt;&gt; null then
						_messageLogger.addLog(aStr,SEVERE_INFO, MACH_MOVE_ALREADY_SWAP);
					endif;
					
					return false;
				endif;
				if not self.getMyTerminal().isAutoPlanGenSwapForYardInt() then   //SFW1030 04/08/2008
					//-----------------
					//No generate swapJobs for Yard Internal Jobs
					//-----------------
					aStr := app.getErrorString2(MACH_ACCESS_TARGET_SWAP,machId,targetLocation.getFullId);
					if _messageLogger &lt;&gt; null then
						_messageLogger.addLog(aStr,SEVERE_INFO, MACH_ACCESS_TARGET_SWAP);
					endif;
				
					return false;
				endif;
			endif;
		endif;
	endif;

	
	return true;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_mach" type="CM_Machine"/>
        <Parameter name="sourceLocationParent" type="CM_Object"/>
        <Parameter name="_messageLogger" type="CM_MessageLogger" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="queryMachineAssign" id="cdb0576b-82a7-4284-9e4d-e119412f62c3">
        <source>queryMachineAssign(	mach 				: CM_Machine; 
					isNextForcedTask 	: Boolean;
					ignoreRejectedTasks : Boolean;
					_checkEntryStatus 	: Boolean;
					_strictAccessCheck  : Boolean;
					_checkMultiMoves 	: Boolean;
					_messageLogger 		: CM_MessageLogger input) : Boolean;

/*

Purpose:			This method manages the initial setup of a machine to a specific task
					Once a task has become enqueued, then a machines asks for it. This 
					initial method checks that the machine can in fact perform ALL of the tasks
					in the entry.
					If the isNextForcedTask flag is set, then we ignore the fact that the machine is currently
					doing a current task (basically, skip the last test)
					If the ignoreRejectedTasks flag is set, then just ignore the rejected tasks, as the driver
					has specifically asked for the selected task
					
					_strictAccessCheck parameter has been added if set will check restricted access and multi machine moves will have to have been completed
					           - for viewing a task list users like to see tasks the are about to work or might be able to in a few minutes i.e. restricted access
							     the container restricting could potentially be moved
							   - also added for RTGs that want to see discharge jobs before they are on the imvs
					

Return Value:		True if the task assignment is OK


Date		Who		Reason
11 Feb 2009	cnwkpd1	PAR #18743 - CCMS 1784 - Voice Directed Changes for Twin Lift
12 feb 2010 cnwer1	CCMS 1100 - changes for multi-machine queueing with interchange areas
01 Jul 2010 cnwer1  PAR 24658 -  added multi machine rt queue tasks validation
02 Jul 2010 cnwer1  PAR 24734 24710 - added parameter _checkRestrictedAccess - apps that display a list will display tasks regardless of 
								whether access is restricted (because the apps can't listen for all moves in that area that might affect access)
								- the pickup will validate the access retriction 
10 Mar 2011 cnwer1 	PAR 26986 - added parameter - check multi moves - want to be able to check indiviual tasks need a way around this check
01 Jul 2024	jlika1	TFS 64829 CUX - Vehicle App Displays Queued Moves for Disallowed Cargo Types
25 Jul 2024 jlika1	TFS 65359 Error when discharging the cargo to machine using Cargo Lander.
*/

vars
	aStr					: String;
	machId 					: String;
	entry				    : CM_RTQueueEntry;
	sourceLocationParent 	: CM_Object;
	workzoneLocationToCheck : CM_LocationsController;
	machineIsIMV			: Boolean;
begin
	
	machId := mach.id.trimRight;
	entry  := self.myEntry;

	if _messageLogger &lt;&gt; null then
		_messageLogger.setMyQueueEntry(entry);
		_messageLogger.setMyMachine(mach);
	endif;
	
	if _checkEntryStatus then
		// epr par 25206 3/9/10
		//if the tasks is being worked by another machine don't show it
		if self.machine &lt;&gt; null and self.machine &lt;&gt; mach then
			if _messageLogger &lt;&gt; null then
				aStr:=app.getErrorString1(MACH_ENTRY_ALREADY_WORKING,machId);
				_messageLogger.addLog(aStr,SEVERE_WARNING, MACH_ENTRY_ALREADY_WORKING);
			endif;
			return false;
		endif;
	
		// epr par 25206 3/9/10
		// if task is complete machine can't work it -exception is do IMV switch - this should not be checking entry status
		if self.status = TASK_COMPLETE then
			if _messageLogger &lt;&gt; null then
				aStr:=app.getErrorString1(MACH_ENTRY_COMPLETE,machId);
				_messageLogger.addLog(aStr,SEVERE_WARNING, MACH_ENTRY_COMPLETE);
			endif;
			return false;
		endif;
	
		if entry.status = ENTRY_USER_HELD or
			 entry.status = ENTRY_SYSTEM_HELD then
			if _messageLogger &lt;&gt; null then
				aStr:=app.getErrorString1(MACH_ENTRY_HELD,machId);
				_messageLogger.addLog(aStr,SEVERE_WARNING, MACH_ENTRY_HELD);
			endif;
			return false;
		endif;	
	
		if entry.status &lt;&gt; ENTRY_UNACTIONED then
			//This entry is either working, or complete or whatever, we dont want it!
			if entry.status &lt;&gt; ENTRY_COMPLETE then 
				//epr par 35702 CCMS 2457 17/2/15
				if not (entry.status = ENTRY_WORKING and  entry.isMachineWorkingEntry(mach)) then					
					//epr CCMS 1395 19/9/14
					if not mach.isQueueEntryAllocated( entry ) then
						aStr:=app.getErrorString1(MACH_ENTRY_ALREADY_WORKING,machId);
						if _messageLogger &lt;&gt; null then
							_messageLogger.addLog(aStr,SEVERE_WARNING, MACH_ENTRY_ALREADY_WORKING);
						endif;
						return false;
					endif;
				//epr CCMS 1099 task is assigned to another machine do not give them it
					if self.intendedMachine &lt;&gt; null and  self.intendedMachine  &lt;&gt; mach then
							aStr:=app.getErrorString1(MACH_ENTRY_ALREADY_WORKING,machId);
						if _messageLogger &lt;&gt; null then
							_messageLogger.addLog(aStr,SEVERE_WARNING, MACH_ENTRY_ALREADY_WORKING);
						endif;
						return false;
					endif;
				endif;
			endif;
		endif;
	endif;
	
	//epr par 25433 19/8/10
	if not queryEntryMachineTypeGroup(mach,_messageLogger) then
		return false;
	endif;
	//---------------
	//has machine been offered &amp; rejected task?
	//---------------
	if not ignoreRejectedTasks and mach.rejectedRTQueueTasks.includes(self) then
		aStr := app.getErrorString2(MACH_ALREADY_REJECT_TASK,machId, self.myEntry.id.trimRight);
		if _messageLogger &lt;&gt; null then
			_messageLogger.addLog(aStr,SEVERE_INFO, MACH_ALREADY_REJECT_TASK);
		endif;
		return false;
	endif;

	//------------------
	//Can machine access areas?
	//------------------
	if self.sourceLocation = null then
		//epr CCMS 1100 12/2/10
		if self.myEntry.getPreviousEntryFirstMoveTask = null  then //cnwrd1 par 25681 18.11.2010 multi machine director moves
			if _messageLogger &lt;&gt; null then
				aStr := app.getErrorString1(Machine_source_location_null, machId);
				_messageLogger.addLog(aStr,SEVERE_INFO,Machine_target_location_null);
			endif;
			return false;
		endif;
	endif;
	
	//epr par 21521 30/10/09
	sourceLocationParent:=self.getSourceLocationParent(mach);

	if sourceLocationParent.isKindOf(CM_Voyage) then
		//if it is on a ship then must be the first entry in a multi machine move
		// basically the previous entry must be null for it to come of a ship on to this task
		if self.myEntry.getPreviousRelatedEntry() &lt;&gt; null then //epr par 35702 CCMS 2457 17/2/15
			aStr := app.getErrorString2(MACH_ACCESS_SOURCE,machId, sourceLocationParent.CM_Voyage.code);
			if _messageLogger &lt;&gt; null then
				_messageLogger.addLog(aStr,SEVERE_INFO, MACH_ACCESS_SOURCE);
			endif;
			return false;
		endif;
		
		if self.myEntry.myJob.isKindOf(CM_VoyageROROJob) then
			if self.ti &lt;&gt; null and not mach.canMachineMoveTI(self.ti, self.myEntry, self.targetLocation, false, _messageLogger) then	
				return false;
			endif;	
			return true;
		endif;
		
		//if it is on ship and going to an IMV that is ok 
		//epr par 25214 26/7/10
		if self.queue.isKindOf(CM_VoyageCraneQueue) and self.queue.CM_VoyageCraneQueue.dischargeMachinesMode = CM_VoyageCraneQueue.UseShipLanderApp then
			if 	self.myEntry.machineTypeGroup &lt;&gt; MACHINETYPEGRP_IMV and (	
				self.myEntry.myPreviousRelatedEntry = null or 
				self.myEntry.myPreviousRelatedEntry.machineTypeGroup &lt;&gt; MACHINETYPEGRP_IMV) then
				
				//From SHIP, only a CRANE can do this!
				if not mach.isKindOf(CM_Crane) then
					aStr := app.getErrorString2(MACH_TASK_SHIP,machId,self.myEntry.id);
					if _messageLogger &lt;&gt; null then
						_messageLogger.addLog(aStr,SEVERE_INFO, MACH_TASK_SHIP);
					endif;
					return false;
				endif;
			
			endif;
		endif;
		//epr ccms 1033 30/8/11
		if self.queue.isKindOf(CM_VoyageWorkPointQueue) and self.queue.CM_VoyageWorkPointQueue.dischargeMachinesMode = CM_VoyageCraneQueue.UseShipLanderApp then
			if 	self.myEntry.machineTypeGroup &lt;&gt; MACHINETYPEGRP_IMV and (	
				self.myEntry.myPreviousRelatedEntry = null or 
				self.myEntry.myPreviousRelatedEntry.machineTypeGroup &lt;&gt; MACHINETYPEGRP_IMV) then			
				return false;
			endif;
		endif;

	elseif sourceLocationParent.isKindOf(CM_Machine) then
		//Is a machine, users have tried to stuff with the task, its source is a machine
		//when it was originally a terminal area. This is OK.
		return true;

	elseif sourceLocationParent.isKindOf(CM_TerminalArea) and
		self.getAreaIsTarget and 
		not mach.canMachineAccessTAObj(sourceLocationParent.CM_TerminalArea, false) then
		
		
		aStr := app.getErrorString2(MACH_ACCESS_SOURCE,machId, sourceLocationParent.CM_TerminalArea.id);
		if _messageLogger &lt;&gt; null then
			_messageLogger.addLog(aStr,SEVERE_INFO,MACH_ACCESS_SOURCE);
		endif;
 		return false;
	endif;

	//epr par 25373 10/8/10 - refactor block that tested target location access
	if not queryMachineAccessTarget(mach,sourceLocationParent,_messageLogger) then
		return false;
	endif;
	
	//------------------
	//Machine can access TA, can physically work the TI?
	//------------------
	if self.isMachineTask then
		//epr CCMS 1099 added target location as parameter to stop getting jobs with labour restrictions or straddle seperation
		if not self.isPlanOnPickup then		
			if not mach.canMachineMoveTI(ti, self.myEntry,  self.targetLocation, _strictAccessCheck,_messageLogger) then	
				return false;
			endif;
		endif;
	elseif  self.taskType = TASK_BREAKBULK then //cnwrd1 ccms 2274
		if not self.queryMachineDirectorTasks(mach,_messageLogger) then
			return false;
		endif;
	else
		//---------------
		//Not a machine task! Check to see if its a director, if so, then OK
		//---------------
		if self.taskType &lt;&gt; TASK_DIRECTOR then
			aStr := app.getErrorString1(MACH_TASK_NOT_DIRECTOR,machId);
			if _messageLogger &lt;&gt; null then
				_messageLogger.addLog(aStr,SEVERE_INFO,MACH_TASK_NOT_DIRECTOR);
			endif;
			return false;
		endif;
		//epr CCMS 1099 29/4/10
		if not self.queryMachineDirectorTasks(mach,_messageLogger) then
			return false;
		endif;
	endif;
	//------------------
	//Is machine busy
	//------------------
	machineIsIMV:=mach.isIMV();
	
	if machineIsIMV then // IMVs can do &gt;1 item at once
	//	if self.taskType &lt;&gt; TASK_MOVE then
		if self.taskType &lt;&gt; TASK_MOVE and not self.isMultiMachineDirector  then //cnwrd1 par 25681 18.11.2010 multi machine director moves
			aStr := app.getErrorString(Task_move_task_type_must_move_);
			if _messageLogger &lt;&gt; null then
				_messageLogger.addLog(aStr,SEVERE_INFO, Task_move_task_type_must_move_);
			endif;
			return false;
		endif;
	//epr par 25052 16/7/10 if twin or tandem tasks can't just check that the task is the currentTask i.e. first task in the allCurrentTasks collection
	elseif (isNextForcedTask = false) and (mach.allCurrentQueueTasks.isNotEmpty) and (not mach.allCurrentQueueTasks.includes(self)) then
		
		if not mach.isMultiLift and not self.isBreakBulkMove then //epr CCMS 1391 warehouse VMT app
			aStr := app.getErrorString2(MACH_WORKING_TASK,machId,mach.currentQueueTask.queue.id);
			if _messageLogger &lt;&gt; null then
				_messageLogger.addLog(aStr,SEVERE_INFO, MACH_WORKING_TASK);
			endif;
			return false;
		endif;
	endif;
	
	//epr 1/7/10 par 24658
	
	if not machineIsIMV and _checkMultiMoves then
		//epr 1/7/10 par 24658
		if not self.queryMachineMultiMoves(mach,_messageLogger) then
			return false;
		endif;
	endif;
		
	//ccms 1076 query mach workzone assigned
	// epr par 30464 23/10/12 if the machine is RTG/RMG and task is not multi-machine task have to check workzone for both source and target 
	if (mach.machineType = MACHINETYPE_RTG or mach.machineType = MACHINETYPE_RMG) and
		(not self.myEntry.isMultiMachineMove) then
		
		if not mach.canMachineAccessLocInWorkzone(self.sourceLocation,_messageLogger) then
			aStr:=app.getErrorString2(MACH_ACCESS_WORKZONE,machId,self.sourceLocation.getFullId());
			if _messageLogger &lt;&gt; null then
				_messageLogger.addLog(aStr,SEVERE_WARNING, MACH_ACCESS_WORKZONE);
			endif;
	
			return false;			
		endif;
		
		if not mach.canMachineAccessLocInWorkzone(self.targetLocation,_messageLogger) then
			aStr:=app.getErrorString2(MACH_ACCESS_WORKZONE,machId,self.targetLocation.getFullId());
			if _messageLogger &lt;&gt; null then
				_messageLogger.addLog(aStr,SEVERE_WARNING, MACH_ACCESS_WORKZONE);
			endif;
	
			return false;			
		endif;
	
	else
	
		// RTGs if area is target then we are setting down in target location if we are an rtg have to check the source
		if   sourceLocationParent.isKindOf(CM_TerminalArea) and self.getAreaIsTarget  then
			workzoneLocationToCheck:=self.sourceLocation;
		else
			workzoneLocationToCheck:=self.targetLocation;
		endif;
		
		if not mach.canMachineAccessLocInWorkzone(workzoneLocationToCheck,_messageLogger) then
			aStr:=app.getErrorString2(MACH_ACCESS_WORKZONE,machId,workzoneLocationToCheck.getFullId());
			if _messageLogger &lt;&gt; null then
				_messageLogger.addLog(aStr,SEVERE_WARNING, MACH_ACCESS_WORKZONE);
			endif;
	
			return false;
			
		endif;
	endif;
	//--------------
	//Well, seems ok so far...
	//--------------
	return true;
end;</source>
        <Parameter name="mach" type="CM_Machine"/>
        <Parameter name="isNextForcedTask" type="Boolean"/>
        <Parameter name="ignoreRejectedTasks" type="Boolean"/>
        <Parameter name="_checkEntryStatus" type="Boolean"/>
        <Parameter name="_strictAccessCheck" type="Boolean"/>
        <Parameter name="_checkMultiMoves" type="Boolean"/>
        <Parameter name="_messageLogger" type="CM_MessageLogger" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="queryMachineCoverage" id="bba55a14-dedf-4244-b246-14ad8fd7fcf3">
        <source>queryMachineCoverage(_allMessages : StringArray512 input) : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 Sep 2009	cnwer1	Initial creation
21 Sep 2010 cnwer1  PAR 25206 included query of machines secondary queues 
31 Mar 2011 cnwer1 	PAR 27196 - turned off the strict access check here
18 May 2011	cnwkpd1	PAR #27579 - Improve performance of check when messages are not
					being returned

*/

vars
	machineDict,
	inheritedMachines : CM_MachineByIdDict;
	machine : CM_Machine;
	messageLogger : CM_IndentedMessageLogger;
	foundMachine : Boolean;
	aStr : String;

begin

	foundMachine:=false;
	
	create machineDict transient;
	self.queue.getAllMachines(machineDict,true,false,false);
	
	if _allMessages = null then	// 17 Oct 2012	NDL	Par 30609 - Don't do all the logging stuff, if its not being returned.
		
		foreach machine in machineDict  do
			if machine.loggedOn then
				if self.queryMachineAssign(machine,true,false,true,true,true,null) then  //epr TFS 3127 14/12/16 changed to be like what is done on the VMT app
					foundMachine := true;
					return foundMachine;
				endif;
			endif;
		endforeach;
		
		create inheritedMachines transient;
		self.queue.getAllMachines(inheritedMachines,false,true,false);
		
		foreach machine in inheritedMachines  do
			if machineDict.includes(machine) then
				continue;
			endif;
			if machine.loggedOn then
				if self.queryMachineAssign(machine,true,false,true,true,true,null) then				
					foundMachine:=true;					
					return foundMachine;
				endif;
			endif;
		endforeach;

	elseif _allMessages &lt;&gt; null then
	
		create messageLogger transient;
		messageLogger.indent:=Tab;
	
		aStr := app.getErrorString2(Querying, self.tiId, self.taskTypeId);
		messageLogger.addLog( aStr, null, Querying );
		
		if machineDict.size &gt; 0 then
			aStr := app.getErrorString1(Querying_machines_queue, self.queue.id);
			messageLogger.addLog( aStr, null, Querying_machines_queue );
		else
			aStr := app.getErrorString1(No_Machines_queue, self.queue.id);
			messageLogger.addLog( aStr, null, No_Machines_queue );
		endif;
		foreach machine in machineDict  do
			messageLogger.indentLevel:=1;
			if machine.myPrimaryQueue &lt;&gt; queue then
				aStr := app.getErrorString1(Queryin_machine_second_queue, machine.id);
				messageLogger.addLog( aStr, null, Queryin_machine_second_queue );
			else
				aStr := app.getErrorString1(Querying_machine, machine.id);
				messageLogger.addLog( aStr, null, Querying_machine );
			endif;
			messageLogger.indentLevel:=2;
			
			if machine.loggedOn then
				if self.queryMachineAssign(machine,true,false,true,true,true,messageLogger) then
					aStr := app.getErrorString1(Machine_work_task, machine.id);
					messageLogger.addLog( aStr.toUpper, null, Machine_work_task );
					foundMachine := true;
				endif;
			else
				aStr := app.getErrorString1(Machine_no_work_not_logged_on, machine.id);
				messageLogger.addLog( aStr, null, Machine_no_work_not_logged_on );
				continue;
			endif;
			
		endforeach;
		
		
		create inheritedMachines transient;
		self.queue.getAllMachines(inheritedMachines,false,true,false);
		messageLogger.indentLevel:=0;
		if inheritedMachines.size - machineDict.size  &gt; 0 then
			aStr := app.getErrorString(Queryin_machine_parent_queues);
			messageLogger.addLog( aStr, null, Queryin_machine_parent_queues );
		else
			aStr := app.getErrorString(No_Machines_parent_queues);
			messageLogger.addLog( aStr, null, No_Machines_parent_queues );
		endif;
		
		foreach machine in inheritedMachines  do
			if machineDict.includes(machine) then
				continue;
			endif;
			messageLogger.indentLevel:=1;
			aStr := app.getErrorString2(Querying_machine_in_queue, machine.id, machine.myPrimaryQueue.id);
			messageLogger.addLog( aStr, null, Querying_machine_in_queue );
			messageLogger.indentLevel:=2;
			
			if machine.loggedOn then
				if self.queryMachineAssign(machine,true,false,true,true,true,messageLogger) then
					aStr := app.getErrorString1(Machine_work_task, machine.id);
					messageLogger.addLog( aStr.toUpper, null, Machine_work_task );
					foundMachine:=true;
				endif;
			else
				aStr := app.getErrorString1(Machine_no_work_not_logged_on, machine.id);
				messageLogger.addLog( aStr, null, Machine_no_work_not_logged_on );
				continue;
			endif;
			
		endforeach;
		
		messageLogger.allMessages.copy(_allMessages);
	
	endif;
	
	return foundMachine;
epilog
	delete machineDict;
	delete inheritedMachines;
	delete messageLogger;
end;</source>
        <Parameter name="_allMessages" type="StringArray512" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="queryMachineDirectorTasks" id="285fbce4-d57c-4489-aa12-54453ae5dfc7">
        <source>queryMachineDirectorTasks( mach : CM_Machine; _messageLogger : CM_MessageLogger ) : Boolean protected;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29/04/2010	cnwer1	Initial creation
05/09/2014	cnwdap1	PAR #33203 Don't show director task if machine can't handle cargo type
*/
vars
	otherMachine : CM_Machine;
	aStr,
	machId			: String;
	request			: CM_Request;			// PAR #33230
	deliveryRequest	: CM_DeliveryRequest;	// PAR #33230
begin
	//--------------
	//Do we have a machine separation problem
	//--------------
	if mach = null then
		return true;
	endif;
	
	machId:=mach.id;
	
	if mach.isStraddleSeparated(self.sourceLocation,otherMachine) = false then
		aStr:=app.getErrorString3(MACH_ACCESS_SOURCE_STRAD_SEP,  machId,self.sourceLocation.getFullId(),otherMachine.id);
		if _messageLogger &lt;&gt; null then
			_messageLogger.addLog(aStr,SEVERE_WARNING, MACH_ACCESS_SOURCE_STRAD_SEP);
		endif;
		
		return false;
	endif;
	if self.targetLocation &lt;&gt; null and mach.isStraddleSeparated(self.targetLocation,otherMachine) = false then
		aStr := app.getErrorString3(MACH_ACCESS_TARGET_STRAD_SEP,machId,self.targetLocation.getFullId(),otherMachine.id); 
		if _messageLogger &lt;&gt; null then
			_messageLogger.addLog(aStr,SEVERE_WARNING, MACH_ACCESS_TARGET_STRAD_SEP);
		endif;
	
		return false;
	endif;
	//--------------
	//Test for labour restriction in the Target/source area
	//--------------
    // AKB 18/12/2000 581 testing. Added to resynch after restrictions have been removed
	if self.targetLocation &lt;&gt; null and self.targetLocation.hasRestrictions(LABOUR_RESTRICTION) then
		aStr:=app.getErrorString2(MACH_ACCESS_TARGET_LABOUR,machId,self.targetLocation.getFullId());
		if _messageLogger &lt;&gt; null then
			_messageLogger.addLog(aStr,SEVERE_WARNING, MACH_ACCESS_TARGET_LABOUR);
		endif;
		
		return false;
	endif;

    // AKB 18/12/2000 581 testing. Added to resynch after restrictions have been removed
	if self.sourceLocation &lt;&gt; null and self.sourceLocation.hasRestrictions(LABOUR_RESTRICTION) then
		aStr:=app.getErrorString2(MACH_ACCESS_SOURCE_LABOUR,machId,self.sourceLocation.getFullId());
		if _messageLogger &lt;&gt; null then
			_messageLogger.addLog(aStr,SEVERE_WARNING, MACH_ACCESS_SOURCE_LABOUR);
		endif;
	
		return false;
	endif;
	
	// PAR #33230 can this machine access the cargo type of the director task?
	if self.myEntry.myWorkListEntry &lt;&gt; null and self.myEntry.myWorkListEntry.myRequest &lt;&gt; null then
		request := self.myEntry.myWorkListEntry.myRequest;
		if request &lt;&gt; null and request.isKindOf(CM_DeliveryRequest) then
			if request.CM_DeliveryRequest.myCargoType &lt;&gt; null and not mach.allAllowedCargoTypes.includes(request.CM_DeliveryRequest.myCargoType) then
				if _messageLogger &lt;&gt; null then
					_messageLogger.addLog( app.getErrorString1( Suita_this_check_machi_area_ac, mach.code),SEVERE_WARNING, Suita_this_check_machi_area_ac );
				endif;
				return false;
			endif;
			//29 Sep 2014	NDL	Par 34944
			if not mach.allAllowableContentsStatuses.isEmpty and	//03 Oct 2014	NDL	Par 34944
			not mach.allAllowableContentsStatuses.includes( app.myRoot.allContentsStatuses[TI_CONTENTS_STATUS_EMPTY] ) then
				if request.CM_DeliveryRequest.commodity = request.myTerminal.getDefaultEmptyCommodity() then
					if _messageLogger &lt;&gt; null then
						_messageLogger.addLog( app.getErrorString1( Suita_this_check_machi_area_ac, mach.code),SEVERE_WARNING, Suita_this_check_machi_area_ac );
					endif;
					return false;
				elseif request.CM_DeliveryRequest.myOriginatingBulkRelease &lt;&gt; null and not request.CM_DeliveryRequest.myOriginatingBulkRelease.fullRelease then
					if _messageLogger &lt;&gt; null then
						_messageLogger.addLog( app.getErrorString1( Suita_this_check_machi_area_ac, mach.code),SEVERE_WARNING, Suita_this_check_machi_area_ac );
					endif;
					return false;
				endif;
			endif;
		endif;
	endif;
	// PAR #33230 end
	
	return true;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="mach" type="CM_Machine"/>
        <Parameter name="_messageLogger" type="CM_MessageLogger"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="queryMachineMultiMoves" id="0ba61d99-55f0-44bb-a0e7-aa03e1b7f41e">
        <source>queryMachineMultiMoves( _mach : CM_Machine; _messageLogger : CM_MessageLogger ) : Boolean protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 July 2010	cnwer1	Initial creation

*/

vars
	aStr,
	machId	: String;
	prevEntry : CM_RTQueueEntry;
begin
	if _mach = null then
		return true;
	endif;
	
	machId:=_mach.id;

	prevEntry:=self.myEntry.getPreviousRelatedEntry(); //epr par 35702 CCMS 2457 17/2/15
	
	if prevEntry &lt;&gt; null then
		if prevEntry.machineTypeGroup = MACHINETYPEGRP_IMV then	
			//must have a previous entry that is complete
			// or previous entry was an IMV coming from a CTA which case won't have another entry
			if prevEntry.getPreviousRelatedEntry() &lt;&gt; null then
				if not prevEntry.getPreviousRelatedEntry().status = ENTRY_COMPLETE then
					aStr := app.getErrorString2(MACH_TASK_MULTI_PREV,machId,self.myEntry.id);
					if _messageLogger &lt;&gt; null then
						_messageLogger.addLog(aStr,SEVERE_INFO, MACH_TASK_MULTI_PREV);
					endif;
					return false;
				endif;
			endif;
		else
			if not prevEntry.status = ENTRY_COMPLETE then
				aStr := app.getErrorString2(MACH_TASK_MULTI_PREV,machId,self.myEntry.id);
				if _messageLogger &lt;&gt; null then
					_messageLogger.addLog(aStr,SEVERE_INFO, MACH_TASK_MULTI_PREV);
				endif;
				return false;
			endif;
		endif;
	endif;

	return true;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_mach" type="CM_Machine"/>
        <Parameter name="_messageLogger" type="CM_MessageLogger"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="queryRTGWorkzone" id="50e0105b-5832-4ac6-897e-d8467f06df2b">
        <source>queryRTGWorkzone(	_mach : CM_Machine input;
					_messageLogger : CM_MessageLogger input	 ) : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 July 2013	cnwer1	Initial creation epr par 31523

*/

vars
	aStr,machId : String;
	workzoneLocationToCheck : CM_LocationsController;
	 sourceLocationParent : CM_Object;
begin
	
	
	if not (_mach.machineType = MACHINETYPE_RTG or _mach.machineType = MACHINETYPE_RMG) then
		return true;
	endif;
	
	// epr par 30464 23/10/12 if the machine is RTG/RMG and task is not multi-machine task have to check workzone for both source and target 
	machId := _mach.id.trimRight;
	if not self.myEntry.isMultiMachineMove() then //epr par 35702 CCMS 2457 17/2/15
		
		if not _mach.canMachineAccessLocInWorkzone(self.sourceLocation,_messageLogger) then
			if _messageLogger &lt;&gt; null then
				aStr:=app.getErrorString2(MACH_ACCESS_WORKZONE,machId,self.sourceLocation.getFullId());
				_messageLogger.addLog(aStr,SEVERE_WARNING, MACH_ACCESS_WORKZONE);
			endif;
	
			return false;			
		endif;
		
		if not _mach.canMachineAccessLocInWorkzone(self.targetLocation,_messageLogger) then
			if _messageLogger &lt;&gt; null then
				aStr:=app.getErrorString2(MACH_ACCESS_WORKZONE,machId,self.targetLocation.getFullId());
				_messageLogger.addLog(aStr,SEVERE_WARNING, MACH_ACCESS_WORKZONE);
			endif;
	
			return false;			
		endif;
	else
		sourceLocationParent:=self.getSourceLocationParent(_mach);
		// RTGs if area is target then we are setting down in target location if we are an rtg have to check the source
		if   sourceLocationParent.isKindOf(CM_TerminalArea) and self.getAreaIsTarget  then
			workzoneLocationToCheck:=self.sourceLocation;
		else
			workzoneLocationToCheck:=self.targetLocation;
		endif;
		
		if not _mach.canMachineAccessLocInWorkzone(workzoneLocationToCheck,_messageLogger) then
			if _messageLogger &lt;&gt; null then
				aStr:=app.getErrorString2(MACH_ACCESS_WORKZONE,machId,workzoneLocationToCheck.getFullId());	
				_messageLogger.addLog(aStr,SEVERE_WARNING, MACH_ACCESS_WORKZONE);
			endif;
	
			return false;
			
		endif;
	
	endif;
	
	return true;
epilog

end;</source>
        <Parameter name="_mach" type="CM_Machine" usage="input"/>
        <Parameter name="_messageLogger" type="CM_MessageLogger" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="queue" id="8b4e7c69-6c36-4899-9145-068155de9561">
        <methodInvocation>mapping</methodInvocation>
        <source>queue(set: Boolean; value: CM_RadioTelemetryQueue io) mapping;
vars

begin
	value := null;
	if set then
		app.raiseSetVirtualError(class.name, method.name);
		return;
	endif;
	if self.myEntry = null then
		return;
	endif;
	value := self.myEntry.myQueue;
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="value" type="CM_RadioTelemetryQueue" usage="io"/>
    </JadeMethod>
    <JadeMethod name="queueId" id="20822a20-705c-4430-85dd-a7042ab2ab03">
        <methodInvocation>mapping</methodInvocation>
        <source>queueId(set: Boolean; value: String io) mapping;
//Returns the string of where this task is located.
vars

begin
	value := "";
	if set then
		app.raiseSetVirtualError(class.name, method.name);
		return;
	endif;
	if self.myEntry = null then
		return;
	endif;
	if self.myEntry.myQueue = null then
		return;
	endif;
	value := self.myEntry.myQueue.id;
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="value" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="refreshTaskQueue" id="8771b3a3-40d3-4f34-8d47-14d6ef2ae0f6">
        <updating/>
        <source>refreshTaskQueue() updating;
//The entry has been moved/changed, update our references to the queue
//and the TI's references as well.
/*

Date		Who		Reason
19 May 2010	cnwkpd1	PAR #20728 - remove isValidObject calls for performance
07/03/2011	cnwmh5	PAR #27142 - Change to local variable rather than self for handleDeleteObject exception
*/

vars
	invalid 		: Boolean;
	trackedItem		: CM_TrackedItem;
begin
	// Par 9644
	//if self.ti = null then
	// Invalid ti caused a really stick situation in 
	// the queues.
//	if not global.isValidObject(self.ti) then
	trackedItem := self.ti;
	if trackedItem = null then
		return;
	endif;
	
	on Exception do app.handleDeletedObject(exception, trackedItem, invalid);
	
	exclusiveLock(trackedItem);
	
	if not invalid then
		trackedItem.addToQueue(self.queue);
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="removeMachine" id="80884479-17e7-4ce5-a999-7c9f4d043e1d">
        <updating/>
        <source>removeMachine() updating;
//This method strips the machine from the task (if its assigned).
//it then leaves the task and machine in a normal state.

// 25/11/2010	cnwcs5	par 23714/ccms 1132 - record machine history
// 30 Aug 2012	cnwcs5	par 30292 - use updateObjectEdition instead of updateEdition 
vars
	term : CM_Terminal;
	mach : CM_Machine;
begin
	exclusiveLock(self);

	if self.machine = null then
		if self.intendedMachine = null then	//Nothing to remove!
			return;
		endif;
	endif;
	
	if (self.status &lt;&gt; TASK_UNACTIONED and 
		self.status &lt;&gt; TASK_OFFERED and
		self.status &lt;&gt; TASK_ALLOCATED and 
		 self.status &lt;&gt;  TASK_MACH_OFFLINE) then
		//We are not happy!
		return;
	endif;	
	
	//if setdown its on a machine then can't unallocate
	if self.isSetDown then
		return;
	endif;
	
	//if machine is offline and status to restore to is working then can't remove machine
	if self.status = TASK_MACH_OFFLINE and self.statusToRestoreTo = TASK_WORKING then
		return;
	endif;
	
	if self.status = TASK_MACH_OFFLINE and self.myMachine.myMachineController.allTrackedItems.includes(self.ti) then
		self.statusToRestoreTo:=TASK_WORKING;
		return;
	endif;
	
	
	
//	25/11/2010 cnwcs5 par 23714/ccms 1132 - start	
	if self.machine &lt;&gt; null then
		self.machine.addInfoToHistory (CM_MachineInfoHistory.InfoType_Remove_Machine, self, null,null);
		
	elseif self.intendedMachine &lt;&gt; null then
		self.intendedMachine.addInfoToHistory (CM_MachineInfoHistory.InfoType_Remove_Machine, self, null,null);
	endif;
	
	self.setStatus(TASK_UNACTIONED);
	
	self.setMachine(null);
	
	//epr CCMS 1395 only send when the last allocated task has been removed
	if self.intendedMachine &lt;&gt; null and self.intendedMachine.allAllocatedQueueTasks.size = 1 then	
		app.myEventManager.createSingleObjInfoNoteEvt(self.intendedMachine,Event_Machine_Task_Unallocated,self.myEntry);	
	endif;
	//Remove allocation.
	intendedMachine := null;
	
	self.updateObjectEdition (self.myEntry);	// par 30292
	
	//14 Feb 2011	NDL	Par 26260
	if self.myEntry &lt;&gt; null then
		//Other RT Q screens (than the one initiating the remove machine) were not refreshing the Queue Entry,
		// so still showing it as assigned to the machine in the 'Assigned column'
		if self.myEntry.myQueue &lt;&gt; null then
			term := self.myEntry.myQueue.getMyTerminal();
		endif;
		
		if term &lt;&gt; null then
			app.myEventManager.createSingleObjInfoNoteEvt(self.myEntry, term.getTerminalEvent(RTQueueEntry_Update_Event), null);
		endif;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="requiresSystemHold" id="14923728-7ca9-4768-a338-57d784b0535f">
        <source>requiresSystemHold(_checkTasks : Boolean; _restrictionToDelete : CM_LabourRestriction; _reason : String output) : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 April 2015	cnwndl1	Initial creation	Par 36014

*/

vars

	result 		: Boolean;
	today		: Date;
//	targetLocn	: CM_LocationsController;
	actualLocn	: CM_LocationsController;
	queueStatus : Integer;
	entryStatus : Integer;
	task 		: CM_RTQueueTask;

begin

	if self.ti &lt;&gt; null then
		result := self.ti.isHeldRTQueueStatus( _checkTasks, _restrictionToDelete, _reason );
		
	else
		// Probably a director task so....
		// run the subset of the rules on CM_TrackedItem::isHeldRTQueueStatus that apply to director task. 
		today := app.actualTimeServer.Date;
		result := false;
		
		//I'm queued to a target location covered by a labour restriction
		if targetLocation &lt;&gt; null and CM_YardController.hasInstance(targetLocation) then 
			if targetLocation.CM_YardController.allLabourRestrictions.size = 1 and targetLocation.CM_YardController.allLabourRestrictions.first = _restrictionToDelete then
			elseif targetLocation.CM_YardController.hasRestrictions(LABOUR_RESTRICTION) then
				result := true;
				_reason := _reason &amp; app.getErrorString(Queued_To_Locn_With_Labour) &amp; CrLf;
			endif;
		endif;
		
		//I'm queued from a source location covered by a labour restriction
		if sourceLocation &lt;&gt; null and CM_YardController.hasInstance(sourceLocation) then
			if sourceLocation.CM_YardController.allLabourRestrictions.size = 1 and sourceLocation.CM_YardController.allLabourRestrictions.first = _restrictionToDelete then
			elseif sourceLocation.CM_YardController.hasRestrictions(LABOUR_RESTRICTION) then
				result := true;
				_reason := _reason &amp; app.getErrorString(Current_Location_Labour_Res) &amp; CrLf;
			endif;
		endif;
		
		if _checkTasks then
			
			//Is the queue I'm in suspended?
			if self.myEntry &lt;&gt; null and  self.myEntry.myQueue &lt;&gt; null then
				queueStatus := self.myEntry.myQueue.status;
				if queueStatus = QSTATUS_HELD then
					result := true;
					_reason := _reason &amp; app.getErrorString(RT_Queue_Suspended) &amp; CrLf;
				endif;
				
				entryStatus := self.myEntry.status;
				if entryStatus = ENTRY_USER_HELD then
					result := true;
					_reason := _reason &amp; app.getErrorString(Queue_Entry_Manually_Held) &amp; CrLf;

				else
					foreach task in self.myEntry.allTasks do
						if task.status = TASK_USER_HELD then
							result := true;
							_reason := _reason &amp; app.getErrorString(Queue_Entry_Manually_Held) &amp; CrLf;
							break;
						endif;
					endforeach;
					
				endif;			
			endif;
			
		endif;
		
	endif;

epilog

	if _reason &lt;&gt; null then
		_reason := _reason[1:_reason.length-1];
	endif;
	
	return result;

end;</source>
        <Parameter name="_checkTasks" type="Boolean"/>
        <Parameter name="_restrictionToDelete" type="CM_LabourRestriction"/>
        <Parameter name="_reason" type="String" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="restoreStatus" id="0888fb54-c3ce-4dc7-8c8d-1d6383970b2f">
        <updating/>
        <source>restoreStatus() updating;
//Called when we are undoing an "error" condition for a task.
//We dont use the setStatus as we are restoring a previous state, NOT
//progressing to the next logical state.
// 24/11/2010	cnwcs5	par 23714/ccms 1132 - record restore in machine history
// 21/11/2012	cnwdap1	PAR #30762 CCMS QNS 2233 TASK_SYSTEM_HELD now treated as TASK_HELD
vars
	machine	:CM_Machine;	//	24/11/2010 cnwcs5 par 23714/ccms 1132
begin
	if self.status &lt;&gt; TASK_ERROR and 
		 self.status &lt;&gt; TASK_MACH_OFFLINE and
		 self.status &lt;&gt; TASK_USER_HELD and
		 self.status &lt;&gt; TASK_SYS_HELD then		// PAR #30762
		return;	//Nothing to restore.
	endif;
	
	if self.statusToRestoreTo = TASK_NULL then
		return;
	endif;
//	24/11/2010 cnwcs5 par 23714/ccms 1132 - start	
	machine := self.machine;
	
	if machine &lt;&gt; null then
		machine.addInfoToHistory (CM_MachineInfoHistory.InfoType_Restore_Status, self, self.statusToRestoreTo,null);
	endif;
//	24/11/2010 cnwcs5 par 23714/ccms 1132 - end	

	//22 Apr 2015	NDL Par 36014
	if self.status = TASK_USER_HELD then
		// use the proper process, in case it wants to add a system held instead.
		self.setStatus( TASK_UNACTIONED );
		return;
	endif;
	
	self.status 			:= self.statusToRestoreTo;
	self.statusToRestoreTo 	:= TASK_NULL;
	//----------------
	//Update the parents status
	//----------------
	self.myEntry.updateStatus(status);
end;</source>
    </JadeMethod>
    <JadeMethod name="sendLabourRestrictionWarning" id="9259b51a-9df9-4547-86b0-f0ad54ef1765">
        <source>sendLabourRestrictionWarning(_labourRestriction : CM_LabourRestriction );
/*

Date			Who		Reason
15 June 2017	cnwer1	Initial creation TFS 4620
16 April 2019	jlgzm1	TFS44160 No warning from target location if not separate pickup/setdown

*/

vars
	locationId 		: String;
	location 		: CM_LocationsController;
	ultimateTarget	: CM_LocationsController;
begin
	if self.machine = null then
		return;
	endif;
	/*
	if not (self.status = TASK_OFFERED 
		or self.status = TASK_ACCEPTED
		or self.status = TASK_WORKING 
		or self.status = TASK_PENDING)	then
		return;
	endif;
	*/
	//tfs44160
	if not self.isEntryWorking() then
		return;
	endif;
	
	if self.taskType =  TASK_PICKUP then 
		if  self.sourceLocation &lt;&gt; null then
			location :=  self.sourceLocation;
		endif;
	elseif self.taskType =  TASK_SETDOWN or self.taskType = TASK_MOVE then
		if self.targetLocation &lt;&gt; null then
			location := self.targetLocation;
		endif;
	endif;

	if 	location= null then
		return;
	endif;
	
	ultimateTarget := self.ultimateTargetLocation();	//tfs44160
	
	//does restriction include next location, if not does it include the final location
	if not _labourRestriction.allLocationControllers.includes( location ) then
		//tfs44160 start
		if ultimateTarget = null then
			return;
		else
			if not _labourRestriction.allLocationControllers.includes( ultimateTarget ) then
				return;
			endif;
			location := ultimateTarget;
		endif;
		//tfs44160 end
	endif;
	
	locationId:=location.getFullId();
	//'Warning - Queue task %s currently has machine %s working in an area affected by this Labour restriction'			
	app.raiseCMWarning2(WARN_NEW_LABREST_TASK,self.taskDescription,  self.machine.id.trimLeft , null, null, _labourRestriction);	// changed by machine #25562 23/09/2010
	// notification
	machine.sendBroadcastMessage(app.getErrorString1(Labour_restrict_at_location, locationId), false);		// 15/07/2010 cnwar2 #25017	// changed by currentMachine #25562 23/09/2010
	
	if machine.loggedOn then
		machine.addInfoToHistory(CM_MachineInfoHistory.InfoType_LabourRestriction,self,null,locationId);
	endif;
	//alert			
	//this one - attached to the rtqueue entry
	app.myPassport.createAlert(SEVERE_ERROR, 
			app.getErrorString3(Labour_restrict_machine_work, locationId, _labourRestriction.id, machine.id.trimLeft),	// 15/07/2010 cnwar2 #25017	// changed by currentMachine #25562 23/09/2010
			EVENT_AT_LabourRestriction,
			self.myEntry);
	app.commitAlert();
epilog

end;</source>
        <Parameter name="_labourRestriction" type="CM_LabourRestriction"/>
    </JadeMethod>
    <JadeMethod name="setAssignedDT" id="712c37bc-f368-49a5-881f-cf95b84d7cc0">
