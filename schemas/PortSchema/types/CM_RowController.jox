    <JadeMethod name="testIsControllerLocnRestricted" id="7d535228-0205-4134-b60e-1fdf8af8ed01">
        <source>testIsControllerLocnRestricted(obj: CMIF_AutoMovePlan input);
// ---------------------------------------------------------------------------
// Created:     30 September 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if not app.myPassport.myTerminal.isAutoPlanUserRestrictions() then		//SFW1030 31/10/2008
		return;
	endif;
	
	if not obj.isTestToBeDone(TI_Test_LocnRest, self) then
		return;
	endif;
	

	/*if obj.isTestToBeDone(TI_Test_LocnRest, self) = false or app.myPassport.myTerminal.getConfig(AutoPlanUseAllocations).Boolean then
		return;
	endif;*/

	sharedLock(self);

	if self.myLocationRestriction = null then
		obj.updateController(self);
		return;
	endif;

	//----------------
	//There is a location Restriction
	//----------------
	if (not self.testControllerLocnRestriction(self.myLocationRestriction, obj)) then
		obj.updateController(null);
		return;
	endif;
/*
	if (not obj.myTrackedItem.isCompatibleWithRestriction(self.myLocationRestriction, obj)) then
		obj.updateController(null);
		return;
	endif;
*/

	//---------------
	//If we have got this far, this area is a candidate
	//---------------
	obj.updateController(self);
epilog
	unlock(self);
end;</source>
        <Parameter name="obj" type="CMIF_AutoMovePlan" usage="input"/>
    </JadeMethod>
