        <source>utlUpdateBOLType(pProxyBOLType : CM_BOLType; _passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
