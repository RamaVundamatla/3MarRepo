<Class name="CM_DBPurgeAgent">
    <JadeMethod name="doDevActivityHistory" id="0479036c-e399-4b1e-b920-cc24ce3b8fba">
        <source>doDevActivityHistory();
//
//26 June 2018	jlgrs1	Initial creation
//
vars
	coll : CM_ActivityByCreatedTsTypeDict;	// par 29450
	iter : Iterator;
	activity : CM_ActivityHistory;
	terminal : CM_Terminal;
	count : Integer;
	idx : Integer;
begin
	app.myPassport.clearErrorsWarnings();
	self.monitor(method.name&amp;' '&amp;"Getting activityHistory..."); 
	if self.abortStatus = true then
		return;
	endif;
	create coll transient;

	foreach terminal in app.myRoot.allTerminals do
		idx := idx + 1;
		app.myPassport.setMyTerminal(terminal);
		count := count + coll.size;
		coll.clear;
		iter := terminal.allActivityHistory.createIterator();
		
		while iter.next(activity) do
			if activity.dateTime.date &lt; self.date then			//No point in checking further
				coll.add(activity);
			endif;
		endwhile;
		
		delete iter;
		if idx = 1 then	// only do this once
			iter := app.myRoot.allActivityHistory.createIterator();
			
			while iter.next(activity) do
				if activity.dateTime.date &lt; self.date then			//No point in checking further
					coll.add(activity);
				else
					break;
				endif;
			endwhile;
			
			delete iter;	//04 Mar 2015	NDL	Par 34583
		endif;
		self.monitor("Finding " &amp; coll.size.userNumberFormat($CNEC_NO_DECIMALS) &amp; " activityHistory for items to delete from terminal "&amp;terminal.code&amp;"...");
		app.myTrxDA.trxDeleteActitivityHistory(coll,app.myPassport);
		
		if not app.myPassport.trxCompletedOK() then
			app.remoteErrorWarningToAlert('Unable to clear activity history for terminal ' &amp; terminal.code, 
										null, app.myPassport.allErrors, null, true, true);
		endif;
	endforeach;
	count := count + coll.size;
	self.monitor("Task Complete: " &amp; count.userNumberFormat($CNEC_NO_DECIMALS) &amp; " activityHistory erased ");
epilog
	delete iter;
	delete coll;
end;</source>
    </JadeMethod>
    <JadeMethod name="doDevAllEDI" id="9138fa44-f620-4bd0-af40-89fde7210f7f">
        <source>doDevAllEDI();
//
//26 June 2018	jlgrs1	Initial creation
//
vars
	ediFile: CM_EDIFile;
	ediData: CM_EDIData;
	ediError : CM_EDIError;
	objArray: ObjectArray;
	object: Object;
	now : Date;
begin
	app.myPassport.clearErrorsWarnings();
 	create objArray transient;
	CM_EDIFile.allInstances(objArray, 0, true);
	self.monitor("Unload edifiles.");
 	foreach object in objArray do
 		ediFile := object.CM_EDIFile;
		if tryLock(ediFile, Exclusive_Lock, Session_Duration, LockTimeout_Immediate) then
			if ediFile &lt;&gt; null and
			   ediFile.creationTime.date &lt; self.date then			//No point in checking further
				beginTransaction;
				if ediFile.ediData &lt;&gt; null then
					ediFile.ediData.unload;
//					delete ediFile.ediData;
				endif;
				ediFile.unload;
				delete ediFile;
				app.cmsCommitTransaction((app.myPassport));
			endif;
		endif;
		if isLockedByMe(ediFile) then
			unlock(ediFile);
		endif;
 	endforeach; 
	objArray.clear;
	self.monitor("Unload edidata.");
	CM_EDIData.allInstances(objArray,0,true);
	foreach object in objArray do
		ediData := object.CM_EDIData;
		if ediData.createdTime.date &lt; self.date then			//No point in checking further
			beginTransaction;
			ediData.unload;
			delete ediData;			
			app.cmsCommitTransaction((app.myPassport));
		endif;
	endforeach;
//	return;
	if now = self.date then
		beginTransaction;
		objArray.clear;
		self.monitor("Delete edi trackedItems.");
		CM_EDITrackedItem.allInstances(objArray,0,true);
		app.cmsCommitTransaction((app.myPassport));
		beginTransaction;
		objArray.purge;
		objArray.clear;
		self.monitor("Delete edi file.");
		CM_EDIFile.allInstances(objArray,0,true);
		app.cmsCommitTransaction((app.myPassport));
		beginTransaction;
		objArray.purge;
		objArray.clear;
		self.monitor("Delete edi data.");
		CM_EDIData.allInstances(objArray,0,true);
		app.cmsCommitTransaction((app.myPassport));
		beginTransaction;
		objArray.purge;
		objArray.clear;
		self.monitor("Delete long strings.");
		CM_LongString.allInstances(objArray,0,true);
		objArray.purge;
		app.cmsCommitTransaction((app.myPassport));
		objArray.clear;
		self.monitor("Delete ediError.");
		CM_EDIError.allInstances(objArray,0,true);
		foreach object in objArray do
			beginTransaction;
			ediError := object.CM_EDIError;
			delete ediError;			
			app.cmsCommitTransaction((app.myPassport));
		endforeach;
	endif;
//	self.monitor("Delete outstanding emails.");
//	if CM_AutoConfig.firstInstance &lt;&gt; null then
//		beginTransaction;
//		CM_AutoConfig.firstInstance.emails.purge;
//		CM_AutoConfig.firstInstance.deadFiles.clear;
//		CM_AutoConfig.firstInstance.seqNumber := 0;
//		app.cmsCommitTransaction((app.myPassport));
//	endif;
	self.monitor("Finished.");
epilog
	delete objArray;			// PAR #27874
end;</source>
    </JadeMethod>
    <JadeMethod name="doDevArchiveVoyages" id="f60375be-633f-4478-8b39-2e7df01b9ff2">
        <source>doDevArchiveVoyages();
//
//26 June 2018	jlgrs1	Initial creation
//
constants
	MaxTransactionTime = 20000;	// 20 seconds
vars
	lastCommit : Decimal[20];
	now : Decimal[20];
	count : Integer;
	errorCount : Integer;
	voy : CM_Voyage;
	iter : Iterator;
	size : String;
    dict, array : CM_VoyageArray;
	archiveInt : CMIF_ArchiveVoyage;
	error : CM_Error;
begin
	lastCommit := app.relativeMachineTime();
	app.myPassport.clearErrorsWarnings();
	self.monitor(method.name&amp;' '&amp;"Getting Voyages..."); 
	if self.abortStatus = true then
		return;
	endif;

	create dict transient;
	create array transient;

	CM_Voyage.allInstances(array,0,true); 
	size := array.size.userNumberFormat($CNEC_NO_DECIMALS);
	count := 0;
	self.monitor("Checking " &amp; size &amp; " Voyages for items to Archive...");
	if self.abortStatus = true then
		return;
	endif;

	foreach voy in array do

		count := count + 1;
//		if count mod 100  = 0 then
		now := app.relativeMachineTime();
		if now - lastCommit &gt; MaxTransactionTime then
			lastCommit := app.relativeMachineTime();
			self.monitor("Voyages checked: " &amp; count.userNumberFormat($CNEC_NO_DECIMALS) &amp; " of " &amp; size
				&amp; ". Voyages to archive: " &amp; dict.size.userNumberFormat($CNEC_NO_DECIMALS));
			if self.abortStatus = true then
				return;							//Exits here can just go straight back
			endif;
		endif;

		if voy.archived = false and
		   voy.hasDeparted() and
		   not voy.isNullVoyage() and
		   voy.departedDT.date &lt; self.date then
			dict.add(voy);
		endif;
	endforeach;

	self.monitor("There are " &amp; dict.size.userNumberFormat($CNEC_NO_DECIMALS) &amp; " voyages to archive"); 
	if self.abortStatus = true then
		return;
	endif;

	size := dict.size.userNumberFormat($CNEC_NO_DECIMALS);
	iter := dict.createIterator;
	count :=  0;

	create archiveInt transient;
	archiveInt.removeEDITrackedItems := true;
	archiveInt.removeNonWorkedTrackedItems := true;
	archiveInt.removePreNotifiedTrackedItems := true;
	archiveInt.removeTBATrackedItems := true;
	archiveInt.removeBookingRefs := true;
	archiveInt.archiveBookingRef := false;//10 Sep 2009	NDL	Par 10413
		
	on Exception do self.objEraseExceptionHandler(exception);
	
	while iter.next(voy) do

		self.monitor("Archiving "&amp;voy.code&amp;" "&amp;voy.String); 
		if self.abortStatus = true then
			return;
		endif;
		archiveInt.myVoyage := voy;
		
		app.myTrxUA.trxUpdateVoyageArchive(archiveInt,app.myPassport);
		app.myPassport.myActivityCapture.stopCaptureDebugMisc();
		if (not app.myPassport.trxCompletedOK) then
			foreach error in app.myPassport.allWarnings do
				self.monitor(class.name&amp;'::'&amp;method.name&amp;' '&amp;voy.code&amp;" WARNING: "&amp;error.text);
			endforeach;
			foreach error in app.myPassport.allErrors do
				self.monitor(class.name&amp;'::'&amp;method.name&amp;' '&amp;voy.code&amp;" ERROR: "&amp;error.text);
			endforeach;
			errorCount := errorCount + 1;
//			app.showErrorWarningDialog(app.getErrorString(VoyageArchive), app.myPassport, ErrWarnMode_Update);
//			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
//			return false;
		else
//			self.clearErrorWarnings();
//			global.beep;
			count := count + 1;
			self.monitor('The selected voyage(s) has been successfully archived.');
		endif;
		app.myPassport.clearErrorsWarnings();
	endwhile;
	
	self.monitor("Task Complete: " &amp; count.userNumberFormat($CNEC_NO_DECIMALS) &amp; " Voyages archived. "&amp;errorCount.userNumberFormat($CNEC_NO_DECIMALS)&amp;' failed.');
	
	if self.abortStatus = true then
		return;
	endif;
	
epilog
	delete iter;
	delete dict;
	delete array;
	delete archiveInt;
	on Exception do null;
end;</source>
    </JadeMethod>
    <JadeMethod name="doDevAuditObjects" id="ac8c573d-2c60-42e7-85a3-80402f2d2177">
        <source>doDevAuditObjects();
//
//26 June 2018	jlgrs1	Initial creation
//
constants
	MaxTransactionTime = 20000;	// 20 seconds
vars
	lastCommit : Decimal[20];
	now : Decimal[20];
	count : Integer;
	auditObject : CM_AuditObject;
	iter : Iterator;
	size : String;
    dict, objArray : ObjectArray;
    obj: Object;
begin
	lastCommit := app.relativeMachineTime();
	app.myPassport.clearErrorsWarnings();
	self.monitor(method.name&amp;' '&amp;"Getting auditObject..."); 
	if self.abortStatus = true then
		return;
	endif;

	create dict transient;
    create objArray transient;

	CM_AuditObject.allInstances(objArray,0,true); 
	size := objArray.size.userNumberFormat($CNEC_NO_DECIMALS);
	count := 0;
	self.monitor("Checking " &amp; size &amp; " auditObject for items to delete...");
	if self.abortStatus = true then
		return;
	endif;

	foreach obj in objArray do
		auditObject := obj.CM_AuditObject;
		count := count + 1;
//		if count mod 100000  = 0 then
		now := app.relativeMachineTime();
		if now - lastCommit &gt; MaxTransactionTime then
			lastCommit := app.relativeMachineTime();
			self.monitor("auditObject checked: " &amp; count.userNumberFormat($CNEC_NO_DECIMALS) &amp; " of " &amp; size
				&amp; ". auditObject to erase: " &amp; dict.size.userNumberFormat($CNEC_NO_DECIMALS));
			if self.abortStatus = true then
				return;							//Exits here can just go straight back
			endif;
		endif;

		if auditObject.timestamp = null then
			dict.add(auditObject);
		elseif auditObject.timestamp.date &lt; self.date then			//No point in checking further
			dict.add(auditObject);
		endif;
	endforeach;

	self.monitor("There are " &amp; dict.size.userNumberFormat($CNEC_NO_DECIMALS) &amp; " items to delete"); 
	if self.abortStatus = true then
		return;
	endif;

	size := dict.size.userNumberFormat($CNEC_NO_DECIMALS);
	iter := dict.createIterator;
	count :=  0;
	lastCommit := app.relativeMachineTime();

	beginTransaction;
	on Exception do self.objEraseExceptionHandler(exception);
	while iter.next(auditObject) do
//		if count mod 10000 = 0 then
		now := app.relativeMachineTime();
		if now - lastCommit &gt; MaxTransactionTime then
			lastCommit := app.relativeMachineTime();
			commitTransaction;		//commit every 1000 items
			self.monitor("Erased auditObject: " &amp; count.userNumberFormat($CNEC_NO_DECIMALS) &amp; " of " &amp; size);
			if self.abortStatus = true then
				return;
			endif;
			beginTransaction;
		endif;
//		app.writeLog("Deleting "&amp;auditObject.String&amp;" "&amp;auditObject.String,0); 
		if not process.isInTransactionState then
			beginTransaction;
		endif;
		auditObject.erase(NORMAL_ERASE);
		if process.isInTransactionState then
			count := count + 1;
		endif;
	endwhile;
	commitTransaction;
	//abortTransaction;
	self.monitor("Task Complete: " &amp; count.userNumberFormat($CNEC_NO_DECIMALS) &amp; " auditObject erased ");
	if self.abortStatus = true then
		return;
	endif;
epilog
	delete dict;
	on Exception do null;
	delete objArray;
	delete iter;			// PAR #26678
end;</source>
    </JadeMethod>
    <JadeMethod name="doDevBookingRef" id="4c9d8af8-7a3e-4235-a40f-20106e69dbed">
        <source>doDevBookingRef();
//
//26 June 2018	jlgrs1	Initial creation
//
constants
	MaxTransactionTime = 20000;	// 20 seconds
vars
	lastCommit : Decimal[20];
	now : Decimal[20];
	count : Integer;
	iter : Iterator;
	size : String;
	bookingRef : CM_BookingRef;
    array : ObjectArray;
begin
	lastCommit := app.relativeMachineTime();
	app.myPassport.clearErrorsWarnings();
	self.monitor(method.name&amp;' '&amp;"Getting BookingRef Items..."); 
	if self.abortStatus = true then
		return;
	endif;

	create array transient;
	iter := app.getMyTerminalDO_NOT_USE().allBookingRefsByRef.createIterator;

	size := app.getMyTerminalDO_NOT_USE().allBookingRefsByRef.size.userNumberFormat($CNEC_NO_DECIMALS);
	count := 0;
	self.monitor("Checking " &amp; size &amp; " BookingRefs for items to delete...");
	if self.abortStatus = true then
		return;
	endif;
	
	while iter.next(bookingRef) do
		count := count + 1;
//		if count mod 10000 = 0 then
		now := app.relativeMachineTime();
		if now - lastCommit &gt; MaxTransactionTime then
			lastCommit := app.relativeMachineTime();
			self.monitor("BookingRefs checked: " &amp; count.userNumberFormat($CNEC_NO_DECIMALS) &amp; " of " &amp; size
				&amp; ". BookingRefs to erase: " &amp; array.size.userNumberFormat($CNEC_NO_DECIMALS));
			if self.abortStatus = true then
				return;							//Exits here can just go straight back
			endif;
		endif;

		if bookingRef.createdTime.date &lt; self.date then
			array.add(bookingRef);
		endif;
	endwhile;

	self.monitor("There are " &amp; array.size.userNumberFormat($CNEC_NO_DECIMALS) &amp; " items to delete"); 
	if self.abortStatus = true then
		return;
	endif;

	size := array.size.userNumberFormat($CNEC_NO_DECIMALS);
	delete iter;
	iter := array.createIterator;
	count :=  0;
	lastCommit := app.relativeMachineTime();

	beginTransaction;
	on Exception do self.objEraseExceptionHandler(exception);
	while iter.next(bookingRef) do
//		if count mod 1000 = 0 then
		now := app.relativeMachineTime();
		if now - lastCommit &gt; MaxTransactionTime then
			lastCommit := app.relativeMachineTime();
			commitTransaction;		//Commit every 50 items
			self.monitor("BookingRefs deleted: " &amp; count.userNumberFormat($CNEC_NO_DECIMALS) &amp; " of " &amp; size);
			if self.abortStatus = true then
				return;
			endif;
			beginTransaction;
		endif;
		if not process.isInTransactionState then
			beginTransaction;
		endif;
		bookingRef.erase(NORMAL_ERASE);
		if process.isInTransactionState then
			count := count + 1;
		endif;
	endwhile;
	commitTransaction;
	//abortTransaction;
	self.monitor("Task Complete: " &amp; count.userNumberFormat($CNEC_NO_DECIMALS) &amp; " BookingRefs erased ");
	if self.abortStatus = true then
		return;
	endif;
epilog
	delete iter;
	delete array;
	on Exception do null;
end;</source>
    </JadeMethod>
    <JadeMethod name="doDevBulkRelease" id="38cb80e2-edbb-430d-8367-fea4ae318cc5">
        <source>doDevBulkRelease();
//
//26 June 2018	jlgrs1	Initial creation
//
constants
	MaxTransactionTime = 20000;	// 20 seconds
vars
	lastCommit : Decimal[20];
	now : Decimal[20];
	count : Integer;
	iter : Iterator;
	size : String;
	bulkRelease : CM_BulkRelease;
    array : ObjectArray;
begin
	lastCommit := app.relativeMachineTime();
	app.myPassport.clearErrorsWarnings();
	self.monitor(method.name&amp;' '&amp;"Getting BulkRelease Items..."); 
	if self.abortStatus = true then
		return;
	endif;

	create array transient;
//	iter := app.getMyTerminal().allBulkReleaseByStatusByCode.createIterator; // AKB2005MAY
//	size := app.getMyTerminal().allBulkReleaseByStatusByCode.size.userNumberFormat($CNEC_NO_DECIMALS); // AKB2005MAY
	iter := app.getMyTerminalDO_NOT_USE().allBulkReleaseByTypeByStByCd.createIterator;
	size := app.getMyTerminalDO_NOT_USE().allBulkReleaseByTypeByStByCd.size.userNumberFormat($CNEC_NO_DECIMALS);
	
	
	count := 0;
	self.monitor("Checking " &amp; size &amp; " BulkReleases for items to delete...");
	if self.abortStatus = true then
		return;
	endif;
	lastCommit := app.relativeMachineTime();
	
	while iter.next(bulkRelease) do
		count := count + 1;
//		if count mod 10000 = 0 then
		now := app.relativeMachineTime();
		if now - lastCommit &gt; MaxTransactionTime then
			lastCommit := app.relativeMachineTime();
			self.monitor("BulkReleases checked: " &amp; count.userNumberFormat($CNEC_NO_DECIMALS) &amp; " of " &amp; size
				&amp; ". BulkReleases to erase: " &amp; array.size.userNumberFormat($CNEC_NO_DECIMALS));
			if self.abortStatus = true then
				return;							//Exits here can just go straight back
			endif;
		endif;
//		if bulkRelease.status = BR_COMPLETE and
		if bulkRelease.createdTime.date &lt; self.date then
			array.add(bulkRelease);
		endif;
	endwhile;

	self.monitor("There are " &amp; array.size.userNumberFormat($CNEC_NO_DECIMALS) &amp; " items to delete"); 
	if self.abortStatus = true then
		return;
	endif;

	size := array.size.userNumberFormat($CNEC_NO_DECIMALS);
	delete iter;
	iter := array.createIterator;
	count :=  0;
	lastCommit := app.relativeMachineTime();

	beginTransaction;
	on Exception do self.objEraseExceptionHandler(exception);
	while iter.next(bulkRelease) do
//		if count mod 1000 = 0 then
		now := app.relativeMachineTime();
		if now - lastCommit &gt; MaxTransactionTime then
			lastCommit := app.relativeMachineTime();
			commitTransaction;		//Commit every 50 items
			self.monitor("BulkReleases deleted: " &amp; count.userNumberFormat($CNEC_NO_DECIMALS) &amp; " of " &amp; size);
			if self.abortStatus = true then
				return;
			endif;
			beginTransaction;
		endif;
		if not process.isInTransactionState then
			beginTransaction;
		endif;
		bulkRelease.erase(NORMAL_ERASE);
		if process.isInTransactionState then
			count := count + 1;
		endif;
	endwhile;
	commitTransaction;
	//abortTransaction;
	self.monitor("Task Complete: " &amp; count.userNumberFormat($CNEC_NO_DECIMALS) &amp; " BulkReleases erased ");
	if self.abortStatus = true then
		return;
	endif;
epilog
	delete iter;
	delete array;
	on Exception do null;
end;</source>
    </JadeMethod>
    <JadeMethod name="doDevCamTaskHistory" id="bc79f333-fd41-4a12-bb27-7f53fbda82c3">
        <source>doDevCamTaskHistory();
//
//26 June 2018	jlgrs1	Initial creation
//
vars
	camTaskHistory : CM_CamTaskHistory;
	camProtocol : CM_CamProtocol;
	object : Object;
//	objectArray : ObjectArray;
	terminal : CM_Terminal;
begin
	foreach terminal in app.myRoot.allTerminals do
		app.myPassport.setMyTerminal(terminal);
		foreach camProtocol in terminal.camProtocols do
	/*		if camProtocol.camTask &lt;&gt; null then	//17 May 2012	cnwrs1		Par 26914 - make cam task transient and remove camprotocol::camTask
				beginTransaction;
				camProtocol.camTask.erase(NORMAL_ERASE);
				camProtocol.setCamTask(null);
				commitTransaction;
			endif;*/
			foreach camTaskHistory in camProtocol.taskHistoryByProtocolSeq  do
				if camTaskHistory.runDateTime.date &lt; self.date then
					beginTransaction;
					camProtocol.taskHistoryByProtocolSeq.remove(camTaskHistory);
					delete camTaskHistory;
					commitTransaction;
				endif;
			endforeach;
			if camProtocol.taskHistoryByProtocolSeq.isEmpty then
				beginTransaction;
				camProtocol.lastRunDateTime := null;
		
		/*		if camProtocol.camTask &lt;&gt; null then	//17 May 2012	cnwrs1		Par 26914 - make cam task transient and remove camprotocol::camTask
					camProtocol.camTask.erase(NORMAL_ERASE);
				endif;
				camProtocol.setCamTask(null);*/	//17 May 2012	cnwrs1		Par 26914 - make cam task transient and remove camprotocol::camTask
	//			create objectArray transient;
	//			CM_CamTask.allInstances(objectArray, 0, true);
	//			foreach object in objectArray do
	//				delete object;
	//			endforeach;
	//			delete objectArray;
				commitTransaction;
			endif;
		endforeach;
	endforeach;
epilog
//	delete objectArray;		// PAR #27874
end;</source>
    </JadeMethod>
    <JadeMethod name="doDevDataDumpExtractHistory" id="88673c34-37cf-4d28-8245-e8d7d1f58869">
        <source>doDevDataDumpExtractHistory();
//
//26 June 2018	jlgrs1	Initial creation
//
constants
	MaxTransactionTime = 20000;	// 20 seconds
vars
	lastCommit : Decimal[20];
	now : Decimal[20];
	count : Integer;
	iter : Iterator;
	size : String;
	dataDumpExtractHistory : CM_DataDumpExtractHistory;
    array : ObjectArray;
	terminal : CM_Terminal;
begin
	lastCommit := app.relativeMachineTime();
	app.myPassport.clearErrorsWarnings();
	self.monitor(method.name&amp;' '&amp;"Getting DataDumpExtractHistory Items..."); 
	if self.abortStatus = true then
		return;
	endif;

	create array transient;
	foreach terminal in app.myRoot.allTerminals do
		app.myPassport.setMyTerminal(terminal);
		array.clear;
		iter := CM_DataDumpExtractDef.firstInstance.allDataDumpExtractHistory.createIterator;
	
		size := CM_DataDumpExtractDef.firstInstance.allDataDumpExtractHistory.size.userNumberFormat($CNEC_NO_DECIMALS);
		count := 0;
		self.monitor("Checking " &amp; size &amp; " DataDumpExtractHistory for items to delete...");
		if self.abortStatus = true then
			return;
		endif;
		
		while iter.next(dataDumpExtractHistory) do
			count := count + 1;
//			if count mod 10000 = 0 then
			now := app.relativeMachineTime();
			if now - lastCommit &gt; MaxTransactionTime then
				lastCommit := app.relativeMachineTime();
				self.monitor("DataDumpExtractHistory checked: " &amp; count.userNumberFormat($CNEC_NO_DECIMALS) &amp; " of " &amp; size
					&amp; ". DataDumpExtractHistory to erase: " &amp; array.size.userNumberFormat($CNEC_NO_DECIMALS));
				if self.abortStatus = true then
					return;							//Exits here can just go straight back
				endif;
			endif;
			if dataDumpExtractHistory.createdTime.date &lt; self.date then
				array.add(dataDumpExtractHistory);
			endif;
		endwhile;
	
		self.monitor("There are " &amp; array.size.userNumberFormat($CNEC_NO_DECIMALS) &amp; " items to delete"); 
		if self.abortStatus = true then
			return;
		endif;
	
		size := array.size.userNumberFormat($CNEC_NO_DECIMALS);
		delete iter;
		iter := array.createIterator;
		count :=  0;
		lastCommit := app.relativeMachineTime();
	
		beginTransaction;
		on Exception do self.objEraseExceptionHandler(exception);
		while iter.next(dataDumpExtractHistory) do
//			if count mod 1000 = 0 then
			now := app.relativeMachineTime();
			if now - lastCommit &gt; MaxTransactionTime then
				lastCommit := app.relativeMachineTime();
				commitTransaction;		//Commit every 50 items
				self.monitor("DataDumpExtractHistory deleted: " &amp; count.userNumberFormat($CNEC_NO_DECIMALS) &amp; " of " &amp; size);
				if self.abortStatus = true then
					return;
				endif;
				beginTransaction;
			endif;
			if not process.isInTransactionState then
				beginTransaction;
			endif;
			dataDumpExtractHistory.erase(NORMAL_ERASE);
			if process.isInTransactionState then
				count := count + 1;
			endif;
		endwhile;
		commitTransaction;
		delete iter;
		//abortTransaction;
		self.monitor("Task Complete: " &amp; count.userNumberFormat($CNEC_NO_DECIMALS) &amp; " DataDumpExtractHistory erased ");
		if self.abortStatus = true then
			return;
		endif;
	endforeach;
epilog
	delete iter;
	delete array;
	on Exception do null;
end;</source>
    </JadeMethod>
    <JadeMethod name="doDevDeleteArchivedVoyages" id="a84eaeef-0b42-4567-90e7-116b085c6c5e">
        <source>doDevDeleteArchivedVoyages();
//
//26 June 2018	jlgrs1	Initial creation
//
constants
	MaxTransactionTime = 20000;	// 20 seconds
vars
	lastCommit : Decimal[20];
	now : Decimal[20];
	count : Integer;
	voy : CM_Voyage;
	iter : Iterator;
	size : String;
    dict, array : CM_VoyageArray;
	invalid : Boolean;
begin
	lastCommit := app.relativeMachineTime();
	app.myPassport.clearErrorsWarnings();
	self.monitor(method.name&amp;' '&amp;"Getting Voyages..."); 
	if self.abortStatus = true then
		return;
	endif;

	create dict transient;
	create array transient;

	CM_Voyage.allInstances(array,0,true); 
	size := array.size.userNumberFormat($CNEC_NO_DECIMALS);
	count := 0;
	self.monitor("Checking " &amp; size &amp; " Archived Voyages for items to delete...");
	if self.abortStatus = true then
		return;
	endif;

	foreach voy in array do
		count := count + 1;
//		if count mod 100  = 0 then
		now := app.relativeMachineTime();
		if now - lastCommit &gt; MaxTransactionTime then
			lastCommit := app.relativeMachineTime();
			self.monitor("Voyages checked: " &amp; count.userNumberFormat($CNEC_NO_DECIMALS) &amp; " of " &amp; size
				&amp; ". Voyages to erase: " &amp; dict.size.userNumberFormat($CNEC_NO_DECIMALS));
			if self.abortStatus = true then
				return;							//Exits here can just go straight back
			endif;
		endif;

		if not voy.isNullVoyage() and
		   voy.archived = true then
			if voy.archivedDT &lt;&gt; null and voy.archivedDT.date &lt; self.date then
				dict.add(voy);
			endif;
		endif;
	endforeach;

	self.monitor("There are " &amp; dict.size.userNumberFormat($CNEC_NO_DECIMALS) &amp; " items to delete"); 
	if self.abortStatus = true then
		return;
	endif;

	size := dict.size.userNumberFormat($CNEC_NO_DECIMALS);
	iter := dict.createIterator;
	count :=  0;

	on Exception do self.objEraseExceptionHandler(exception);
	on Exception do app.handleDeletedObject(exception, voy, invalid); 
	while iter.next(voy) do

		self.monitor("Erased Voyages: " &amp; count.userNumberFormat($CNEC_NO_DECIMALS) &amp; " of " &amp; size);
		if self.abortStatus = true then
			return;
		endif;
		//Forced erase deletes all associated TIs as well. 
		//If there are still onsite TIs, an exception is raised.
		invalid := false;
		app.writeLog("Deleting "&amp;voy.code&amp;" "&amp;voy.String,0); 
		if not invalid then
			if not process.isInTransactionState then
				beginTransaction;
			endif;
			voy.erase(NORMAL_ERASE);
			count := count + 1;
			if process.isInTransactionState then
				commitTransaction;
			endif;
		endif;
	endwhile;
	//abortTransaction;
	self.monitor("Task Complete: " &amp; count.userNumberFormat($CNEC_NO_DECIMALS) &amp; " Voyages erased ");
	if self.abortStatus = true then
		return;
	endif;
epilog
	delete iter;
	delete dict;
	delete array;
	on Exception do null;
end;</source>
    </JadeMethod>
    <JadeMethod name="doDevDiscrepancies" id="47bf44d7-2687-4dde-aefa-5b6e161e750c">
        <source>doDevDiscrepancies();
//
//26 June 2018	jlgrs1	Initial creation
//
constants
	MaxTransactionTime = 20000;	// 20 seconds
vars
	lastCommit : Decimal[20];
	now : Decimal[20];
	count : Integer;
	disc : CM_Discrepancy;
	iter : Iterator;
	size : String;
    dict, discArray : CM_DiscrepancyArray;
begin
	lastCommit := app.relativeMachineTime();
	app.myPassport.clearErrorsWarnings();
	self.monitor(method.name&amp;' '&amp;"Getting Discrepancies..."); 
	if self.abortStatus = true then
		return;
	endif;

	create dict transient;
    create discArray transient;

	CM_TIDiscrepancy.allInstances(discArray,0,true); 
	size := discArray.size.userNumberFormat($CNEC_NO_DECIMALS);
	count := 0;
	self.monitor("Checking " &amp; size &amp; " Discrepancies for items to delete...");
	if self.abortStatus = true then
		return;
	endif;

	foreach disc in discArray do

		count := count + 1;
//		if count mod 10000  = 0 then
		now := app.relativeMachineTime();
		if now - lastCommit &gt; MaxTransactionTime then
			lastCommit := app.relativeMachineTime();
			self.monitor("Discrepancies checked: " &amp; count.userNumberFormat($CNEC_NO_DECIMALS) &amp; " of " &amp; size
				&amp; ". Discrepancies to erase: " &amp; dict.size.userNumberFormat($CNEC_NO_DECIMALS));
			if self.abortStatus = true then
				return;							//Exits here can just go straight back
			endif;
		endif;

		if disc.date.date &lt; self.date then
			dict.add(disc);
		elseif not global.isValidObject(disc.CM_TIDiscrepancy.trackedItem) or disc.CM_TIDiscrepancy.trackedItem = null then
			dict.add(disc);
		endif;
	endforeach;

	self.monitor("There are " &amp; dict.size.userNumberFormat($CNEC_NO_DECIMALS) &amp; " items to delete"); 
	if self.abortStatus = true then
		return;
	endif;

	size := dict.size.userNumberFormat($CNEC_NO_DECIMALS);
	iter := dict.createIterator;
	count :=  0;
	lastCommit := app.relativeMachineTime();

	beginTransaction;
	on Exception do self.objEraseExceptionHandler(exception);
	while iter.next(disc) do
//		if count mod 1000 = 0 then
		now := app.relativeMachineTime();
		if now - lastCommit &gt; MaxTransactionTime then
			lastCommit := app.relativeMachineTime();
			commitTransaction;		//commit every 1000 items
			self.monitor("Erased Discrepancies: " &amp; count.userNumberFormat($CNEC_NO_DECIMALS) &amp; " of " &amp; size);
			if self.abortStatus = true then
				return;
			endif;
			beginTransaction;
		endif;
//		app.writeLog("Deleting "&amp;disc.userNumberFormat($CNEC_NO_DECIMALS)&amp;" "&amp;disc.String,0); 
		if not process.isInTransactionState then
			beginTransaction;
		endif;
		disc.erase(NORMAL_ERASE);
		if process.isInTransactionState then
			count := count + 1;
		endif;
	endwhile;
	commitTransaction;
	//abortTransaction;
	self.monitor("Task Complete: " &amp; count.userNumberFormat($CNEC_NO_DECIMALS) &amp; " Discrepancies erased ");
	if self.abortStatus = true then
		return;
	endif;
epilog
	delete iter;
	delete dict;
	on Exception do null;
	delete discArray;
end;</source>
    </JadeMethod>
    <JadeMethod name="doDevEDISndrRecipFileTypeHist" id="5061afd5-42ed-4f6a-b680-48a195df946f">
        <source>doDevEDISndrRecipFileTypeHist();
//
//05 July 2018	jlgrs1	Initial creation
//
constants
	MaxTransactionTime = 20000;	// 20 seconds
vars
	lastCommit : Decimal[20];
	now : Decimal[20];
	count : Integer;
	ediSenderRecipFileTypeHist : CM_EDISenderRecipFileTypeHist;
	iter : Iterator;
	size : String;
    dict, objArray : ObjectArray;
    obj: Object;
begin
	lastCommit := app.relativeMachineTime();
	app.myPassport.clearErrorsWarnings();
	self.monitor(method.name&amp;' '&amp;"Getting EDISenderRecipFileTypeHist..."); 
	if self.abortStatus = true then
		return;
	endif;

	create dict transient;
    create objArray transient;

	CM_EDISenderRecipFileTypeHist.allInstances(objArray, 0, true); 
	size := objArray.size.userNumberFormat($CNEC_NO_DECIMALS);
	count := 0;
	self.monitor("Checking " &amp; size &amp; " EDISenderRecipFileTypeHist for items to delete...");
	if self.abortStatus = true then
		return;
	endif;

	foreach obj in objArray do
		ediSenderRecipFileTypeHist := obj.CM_EDISenderRecipFileTypeHist;
		count := count + 1;
//		if count mod 100000  = 0 then
		now := app.relativeMachineTime();
		if now - lastCommit &gt; MaxTransactionTime then
			lastCommit := app.relativeMachineTime();
			self.monitor("EDISenderRecipFileTypeHist checked: " &amp; count.userNumberFormat($CNEC_NO_DECIMALS) &amp; " of " &amp; size
				&amp; ". EDISenderRecipFileTypeHist to erase: " &amp; dict.size.userNumberFormat($CNEC_NO_DECIMALS));
			if self.abortStatus = true then
				return;							//Exits here can just go straight back
			endif;
		endif;

		if ediSenderRecipFileTypeHist.createdTime = null then
			dict.add(ediSenderRecipFileTypeHist);
		elseif ediSenderRecipFileTypeHist.createdTime.date &lt; self.date then			//No point in checking further
			dict.add(ediSenderRecipFileTypeHist);
		endif;
	endforeach;

	self.monitor("There are " &amp; dict.size.userNumberFormat($CNEC_NO_DECIMALS) &amp; " items to delete"); 
	if self.abortStatus = true then
		return;
	endif;

	size := dict.size.userNumberFormat($CNEC_NO_DECIMALS);
	iter := dict.createIterator;
	count :=  0;

	lastCommit := app.relativeMachineTime();
	beginTransaction;
	on Exception do self.objEraseExceptionHandler(exception);
	while iter.next(ediSenderRecipFileTypeHist) do
//		if count mod 10000 = 0 then
		now := app.relativeMachineTime();
		if now - lastCommit &gt; MaxTransactionTime then
			lastCommit := app.relativeMachineTime();
			commitTransaction;		//commit every 1000 items
			self.monitor("Erased EDISenderRecipFileTypeHist: " &amp; count.userNumberFormat($CNEC_NO_DECIMALS) &amp; " of " &amp; size);
			if self.abortStatus = true then
				return;
			endif;
			beginTransaction;
		endif;
//		app.writeLog("Deleting "&amp;ediSenderRecipFileTypeHist.String&amp;" "&amp;ediSenderRecipFileTypeHist.String,0); 
		if not process.isInTransactionState then
			beginTransaction;
		endif;
		ediSenderRecipFileTypeHist.erase(NORMAL_ERASE);
		if process.isInTransactionState then
			count := count + 1;
		endif;
	endwhile;
	commitTransaction;
	//abortTransaction;
	self.monitor("Task Complete: " &amp; count.userNumberFormat($CNEC_NO_DECIMALS) &amp; " EDISenderRecipFileTypeHist erased ");
	if self.abortStatus = true then
		return;
	endif;
epilog
	delete dict;
	on Exception do null;
	delete objArray;
	delete iter;			// PAR #26678
end;</source>
    </JadeMethod>
    <JadeMethod name="doDevEventTransactions" id="00d8e65c-70b7-4b86-b6ce-d11d87e92b7e">
        <source>doDevEventTransactions();
//
//26 June 2018	jlgrs1	Initial creation
//
constants
	MaxTransactionTime = 20000;	// 20 seconds
vars
	lastCommit : Decimal[20];
	now : Decimal[20];
	count : Integer;
	eventTransaction : CM_EventTransaction;
	iter : Iterator;
	size : String;
    dict, objArray : ObjectArray;
    obj: Object;
begin
	lastCommit := app.relativeMachineTime();
	app.myPassport.clearErrorsWarnings();
	self.monitor(method.name&amp;' '&amp;"Getting eventTransaction..."); 
	if self.abortStatus = true then
		return;
	endif;

	create dict transient;
    create objArray transient;

	CM_EventTransaction.allInstances(objArray,0,true); 
	size := objArray.size.userNumberFormat($CNEC_NO_DECIMALS);
	count := 0;
	self.monitor("Checking " &amp; size &amp; " eventTransaction for items to delete...");
	if self.abortStatus = true then
		return;
	endif;

	foreach obj in objArray do
		eventTransaction := obj.CM_EventTransaction;
		count := count + 1;
//		if count mod 100000  = 0 then
		now := app.relativeMachineTime();
		if now - lastCommit &gt; MaxTransactionTime then
			lastCommit := app.relativeMachineTime();
			self.monitor("eventTransaction checked: " &amp; count.userNumberFormat($CNEC_NO_DECIMALS) &amp; " of " &amp; size
				&amp; ". eventTransaction to erase: " &amp; dict.size.userNumberFormat($CNEC_NO_DECIMALS));
			if self.abortStatus = true then
				return;							//Exits here can just go straight back
			endif;
		endif;

		if eventTransaction.createdTime = null then
			dict.add(eventTransaction);
		elseif eventTransaction.createdTime.date &lt; self.date then			//No point in checking further
			dict.add(eventTransaction);
		endif;
	endforeach;

	self.monitor("There are " &amp; dict.size.userNumberFormat($CNEC_NO_DECIMALS) &amp; " items to delete"); 
	if self.abortStatus = true then
		return;
	endif;

	size := dict.size.userNumberFormat($CNEC_NO_DECIMALS);
	iter := dict.createIterator;
	count :=  0;
	lastCommit := app.relativeMachineTime();

	beginTransaction;
	on Exception do self.objEraseExceptionHandler(exception);
	while iter.next(eventTransaction) do
//		if count mod 10000 = 0 then
		now := app.relativeMachineTime();
		if now - lastCommit &gt; MaxTransactionTime then
			lastCommit := app.relativeMachineTime();
			commitTransaction;		//commit every 1000 items
			self.monitor("Erased eventTransaction: " &amp; count.userNumberFormat($CNEC_NO_DECIMALS) &amp; " of " &amp; size);
			if self.abortStatus = true then
				return;
			endif;
			beginTransaction;
		endif;
//		app.writeLog("Deleting "&amp;vehicleVisitRecord.String&amp;" "&amp;vehicleVisitRecord.String,0); 
		if not process.isInTransactionState then
			beginTransaction;
		endif;
		eventTransaction.erase(NORMAL_ERASE);
		if process.isInTransactionState then
			count := count + 1;
		endif;
	endwhile;
	if process.isInTransactionState then
		commitTransaction;
	endif;
	//abortTransaction;
	self.monitor("Task Complete: " &amp; count.userNumberFormat($CNEC_NO_DECIMALS) &amp; " eventTransaction erased ");
	if self.abortStatus = true then
		return;
	endif;
epilog
	delete dict;
	on Exception do null;
	delete objArray;
	delete iter;			// PAR #26678
end;</source>
    </JadeMethod>
    <JadeMethod name="doDevGarbageTIs" id="6e4e36da-0406-4ce9-9be6-a3f5eaa38ca3">
        <source>doDevGarbageTIs(_flags : Integer);
//
//26 June 2018	jlgrs1	Initial creation
//
constants
	MaxTransactionTime = 20000;	// 20 seconds
	ERASE_DELETED = 2;
	ERASE_OFFSITE = 1;
	ERASE_ONSHIP = 3;
vars
	lastCommit : Decimal[20];
	now : Decimal[20];
	count,number : Integer;
	iter : Iterator;
	size : Integer;
	ti,child : CM_TrackedItem;
    dict, tiArray : CM_TIArray;
    eraseOffsite, eraseDeleted, eraseOnship : Boolean;
	nullVoy: CM_Voyage;
	snapShot: CM_SnapShot;
	children : CM_TISet;//PAR 22954
	bank : CM_Bank;
begin
	lastCommit := app.relativeMachineTime();
	app.myPassport.clearErrorsWarnings();
	bank := CM_Bank.firstInstance;
	self.monitor(method.name&amp;' '&amp;"Getting TIs..."); 
	if self.abortStatus = true then
		return;
	endif;

	if _flags.bitAnd(ERASE_OFFSITE) &gt; 0 then
		eraseOffsite := true;
	endif;

	if _flags.bitAnd(ERASE_DELETED) &gt; 0 then
		eraseDeleted := true;
	endif;

	if _flags.bitAnd(ERASE_ONSHIP) &gt; 0 then
		eraseOnship := true;
	endif;

	create dict transient;
    create tiArray transient;

	CM_TrackedItem.allInstances(tiArray,0,true); 
	size := tiArray.size;
	if self.abortStatus = true then
		return;
	endif;
	
	create children transient;
	
	count := 0;
	lastCommit := app.relativeMachineTime();
	beginTransaction;
	foreach ti in tiArray do
//		break;
//		if ti.hazards &lt;&gt; null then
//			delete ti.hazards;
//			ti.hazards := null;
//		endif;
		count := count + 1;
//		if count mod 1000 = 0 then
		now := app.relativeMachineTime();
		if now - lastCommit &gt; MaxTransactionTime then
			lastCommit := app.relativeMachineTime();
			commitTransaction;		//Commit every 50 items
			self.monitor("Checking for invalid voyages: " &amp; count.userNumberFormat($CNEC_NO_DECIMALS) &amp; " of " &amp; size.userNumberFormat($CNEC_NO_DECIMALS));
			if self.abortStatus = true then
				return;
			endif;
			beginTransaction;
		endif;
		if not global.isValidObject(ti.companyOid) then
			ti.setPropertyValue("companyOid", bank);
		endif;
		if not global.isValidObject(ti.myTerminal) then
			ti.setPropertyValue("myTerminal", null);
		endif;
		if not global.isValidObject(ti.myVoyage) then
			if ti.state &lt;&gt; TI_STATE_ONSHIP and
			   ti.state &lt;&gt; TI_STATE_EDI then
				   if ti.myTerminal &lt;&gt; null then
						nullVoy := ti.myTerminal.getNullVoyage();
						if nullVoy &lt;&gt; null then
						//ti.getAllChildren(children);//PAR 22954
						//foreach child in children do//cnwsh3 - PAR25103 - allChildren collection has been unprotected reversing the need for changes from PAR22954
						foreach child in ti.allChildren do
							child.setMyVoyage(nullVoy, app.myPassport);
						endforeach;
						ti.setMyVoyage(nullVoy, app.myPassport);
					endif;
				endif;
				if not ti.isKindOf(CM_TILC) then
					ti.changeState(TI_STATE_DELETED, app.myPassport);
					number := number + 1;
				endif;
			endif;
		endif;
		ti.snapShots.rebuild;
	endforeach;
	commitTransaction;
	self.monitor("Fixed " &amp; number.userNumberFormat($CNEC_NO_DECIMALS) &amp; " TIs with invalid voyages...");

	count := 0;
	self.monitor("Checking " &amp; size.userNumberFormat($CNEC_NO_DECIMALS) &amp; " TIs for items to delete...");
	if self.abortStatus = true then
		return;
	endif;
	lastCommit := app.relativeMachineTime();

	dict.clear;
	foreach ti in tiArray do
		count := count + 1;
//		if count mod 10000 = 0 then
		now := app.relativeMachineTime();
		if now - lastCommit &gt; MaxTransactionTime then
			lastCommit := app.relativeMachineTime();
			self.monitor("TIs checked: " &amp; count.userNumberFormat($CNEC_NO_DECIMALS) &amp; " of " &amp; size.userNumberFormat($CNEC_NO_DECIMALS)
				&amp; ". TIs to erase: " &amp; dict.size.userNumberFormat($CNEC_NO_DECIMALS));
			if self.abortStatus = true then
				return;							//Exits here can just go straight back
			endif;
		endif;
		if ti.myTerminal = null or 
		   not global.isValidObject(ti.myTerminal) then
			dict.add(ti);
			continue;
		endif;
		if not ti.isChild then
			if ti.state = TI_STATE_DELETED then
				if eraseDeleted and ti.deletedDT.date &lt; self.date then
					dict.add(ti);
				endif;
			elseif ti.site = TI_SITE_OFFSITE then
				if eraseOffsite and ti.releasedDT.date &lt; self.date then
					dict.add(ti);
				endif;
			elseif ti.state = TI_STATE_ONSHIP or
			       ti.state = TI_STATE_EDI then
				if eraseOnship then
				   	nullVoy := ti.myTerminal.getNullVoyage();
					if ti.myVoyage = nullVoy then
						dict.add(ti);
					elseif ti.myVoyage = null then
						dict.add(ti);
					elseif not global.isValidObject(ti.myVoyage) then
						dict.add(ti);
					endif;
				endif;
			endif;
		endif;
//		if dict.size &gt; 1000 then
//			break;		//Debug !!!
//		endif;
	endforeach;

	self.monitor("There are " &amp; dict.size.userNumberFormat($CNEC_NO_DECIMALS) &amp; " items to delete"); 
	if self.abortStatus = true then
		return;
	endif;

	size := dict.size;
	iter := dict.createIterator;
	count :=  0;

	lastCommit := app.relativeMachineTime();
	beginTransaction;
	on Exception do self.objEraseExceptionHandler(exception);
	while iter.next(ti) do
//		if count mod 1000 = 0 then
		now := app.relativeMachineTime();
		if now - lastCommit &gt; MaxTransactionTime then
			lastCommit := app.relativeMachineTime();
			commitTransaction;		//Commit every 50 items
			self.monitor("Erased TIs deleted: " &amp; count.userNumberFormat($CNEC_NO_DECIMALS) &amp; " of " &amp; size.userNumberFormat($CNEC_NO_DECIMALS));
			if self.abortStatus = true then
				return;
			endif;
			beginTransaction;
		endif;
		if global.isValidObject(ti) then
			if not process.isInTransactionState then
				beginTransaction;
			endif;
			if (ti.getPrimaryLocation(QUEUE_MODE) &lt;&gt; null or
			   not ti.allQueuedFutureMoves.isEmpty) or
			   (ti.getPrimaryLocation(PLANNING_MODE) &lt;&gt; null or
			   not ti.allPlannedFutureMoves.isEmpty) then
			else
				ti.erase(NORMAL_ERASE);
				commitTransaction;
				beginTransaction;
			endif;
			if global.isValidObject(ti) then
				if global.isValidObject(ti) then
					self.monitor("Erase of "&amp;ti.id&amp;' '&amp;ti.String&amp;' failed.');
			if self.abortStatus = true then
				commitTransaction;
				return;
			endif;
				endif;
			endif;
		endif;
//		self.btnStop.doWindowEvents(0);			//Check the cancel button
		if process.isInTransactionState then
			count := count + 1;
		endif;
	endwhile;
	commitTransaction;
	//abortTransaction;
	tiArray.clear;
	CM_TrackedItem.allInstances(tiArray,0,true); 
	self.monitor("Task Complete: " &amp; count.userNumberFormat($CNEC_NO_DECIMALS) &amp; " TI's were to be erased, and erased "&amp;(size-tiArray.size).userNumberFormat($CNEC_NO_DECIMALS));
	if self.abortStatus = true then
		return;
	endif;
epilog
	delete iter;
	delete dict;
	delete tiArray;
	delete children;//PAR 22954
	on Exception do null;
end;</source>
        <Parameter name="_flags" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doDevInfoEDISent" id="3c5663a9-0b10-4ca8-8e14-3cba1e950aa0">
        <source>doDevInfoEDISent();
//
//26 June 2018	jlgrs1	Initial creation
//
constants
	MaxTransactionTime = 20000;	// 20 seconds
vars
	lastCommit : Decimal[20];
	now : Decimal[20];
	count : Integer;
	infoEDISent : CM_InfoEDISent;
	iter : Iterator;
	size : String;
    dict, objArray : ObjectArray;
    obj: Object;
begin
	lastCommit := app.relativeMachineTime();
	app.myPassport.clearErrorsWarnings();
	self.monitor(method.name&amp;' '&amp;"Getting infoEDISent..."); 
	if self.abortStatus = true then
		return;
	endif;

	create dict transient;
    create objArray transient;

	CM_InfoEDISent.allInstances(objArray,0,true); 
	size := objArray.size.userNumberFormat($CNEC_NO_DECIMALS);
	count := 0;
	self.monitor("Checking " &amp; size &amp; " infoEDISent for items to delete...");
	if self.abortStatus = true then
		return;
	endif;

	foreach obj in objArray do
		infoEDISent := obj.CM_InfoEDISent;
		count := count + 1;
//		if count mod 100000  = 0 then
		now := app.relativeMachineTime();
		if now - lastCommit &gt; MaxTransactionTime then
			lastCommit := app.relativeMachineTime();
			self.monitor("infoEDISent checked: " &amp; count.userNumberFormat($CNEC_NO_DECIMALS) &amp; " of " &amp; size
				&amp; ". infoEDISent to erase: " &amp; dict.size.userNumberFormat($CNEC_NO_DECIMALS));
			if self.abortStatus = true then
				return;							//Exits here can just go straight back
			endif;
		endif;

		if infoEDISent.dateTime = null then
			dict.add(infoEDISent);
		elseif infoEDISent.dateTime.date &lt; self.date then			//No point in checking further
			dict.add(infoEDISent);
		endif;
	endforeach;

	self.monitor("There are " &amp; dict.size.userNumberFormat($CNEC_NO_DECIMALS) &amp; " items to delete"); 
	if self.abortStatus = true then
		return;
	endif;

	size := dict.size.userNumberFormat($CNEC_NO_DECIMALS);
	iter := dict.createIterator;
	count :=  0;

	lastCommit := app.relativeMachineTime();
	beginTransaction;
	on Exception do self.objEraseExceptionHandler(exception);
	while iter.next(infoEDISent) do
//		if count mod 10000 = 0 then
		now := app.relativeMachineTime();
		if now - lastCommit &gt; MaxTransactionTime then
			lastCommit := app.relativeMachineTime();
			commitTransaction;		//commit every 1000 items
			self.monitor("Erased infoEDISent: " &amp; count.userNumberFormat($CNEC_NO_DECIMALS) &amp; " of " &amp; size);
			if self.abortStatus = true then
				return;
			endif;
			beginTransaction;
		endif;
//		app.writeLog("Deleting "&amp;infoEDISent.String&amp;" "&amp;infoEDISent.String,0); 
		if not process.isInTransactionState then
			beginTransaction;
		endif;
		infoEDISent.erase(NORMAL_ERASE);
		if process.isInTransactionState then
			count := count + 1;
		endif;
	endwhile;
	commitTransaction;
	//abortTransaction;
	self.monitor("Task Complete: " &amp; count.userNumberFormat($CNEC_NO_DECIMALS) &amp; " infoEDISent erased ");
	if self.abortStatus = true then
		return;
	endif;
epilog
	delete dict;
	on Exception do null;
	delete objArray;
	delete iter;			// PAR #26678
end;</source>
    </JadeMethod>
    <JadeMethod name="doDevInformation" id="bb8c4202-9770-4ad0-9a41-7eb8b232e9d6">
