    <JadeMethod name="setHasChanged" id="f3ad7dc0-94a3-45c1-9763-71ed68210e86">
        <updating/>
        <source>setHasChanged(_changed :Boolean) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 May 2017	cnwns1	Initial creation
//12/03/2019	jlgns1	TFS 36423 XLAT_FormCaptions need to be sorted out
*/

vars

begin
	if _changed &lt;&gt; self.sourceHasChanged then
		self.sourceHasChanged := _changed;
	endif;
epilog

end;</source>
        <Parameter name="_changed" type="Boolean"/>
    </JadeMethod>
