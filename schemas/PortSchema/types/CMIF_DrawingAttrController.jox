    <JadeMethod name="handleRelease" id="5f48f1fe-71eb-4021-abe9-01905ec40c22">
        <source>handleRelease(release : CM_BulkRelease; _viewModeCode : String; _code : String output; _color :Integer output; _object : Object output) protected;
vars
	iter		: Iterator;
	trimCode,
	theCode,
	codeKey		: String;
	theColor,
	colorKey	: Integer;
	theObject : Object;
	
	viewObjectColour : CM_ViewObjectColour;
	
begin

	trimCode := release.code.trimBlanks;

	if trimCode = null or (_viewModeCode &lt;&gt; null and _viewModeCode &lt;&gt; trimCode) then
		_code 	:= null;
		_color	:= NullColour;
		return;
	endif;

	theCode		:= null;
	theColor	:= NullColour;

	iter := self.myIterRelease;
	self.allReleases.startKeyGeq(trimCode, 0, iter);
	self.allReleases.getIteratorKeys(codeKey, colorKey, iter);

	if codeKey = trimCode then
		// found the right one
		theCode		:= trimCode;
		theColor	:= colorKey;
		iter.next(theObject);
	else
		create viewObjectColour transient;
		viewObjectColour.code := release.code;
		viewObjectColour.colour := self.allReleases.size.colourSpread();
		viewObjectColour.myObject := release;
		self.allReleases.add(viewObjectColour);
		theCode	:= viewObjectColour.code;
		theColor := viewObjectColour.colour;
		theObject := viewObjectColour.myObject;
	endif;

	_code	:= theCode;
	_color	:= theColor;
	_object := theObject;
end;</source>
        <access>protected</access>
        <Parameter name="release" type="CM_BulkRelease"/>
        <Parameter name="_viewModeCode" type="String"/>
        <Parameter name="_code" type="String" usage="output"/>
        <Parameter name="_color" type="Integer" usage="output"/>
        <Parameter name="_object" type="Object" usage="output"/>
    </JadeMethod>
    <JadeMethod name="handleShippingLine" id="d394cbbd-c759-4582-bb9c-3bf32edd7642">
        <source>handleShippingLine(_shippingLine : String; _ship : CM_ShippingLine; _viewModeCode : String; _code : String output; _color :Integer output; _object : Object output)protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 May 2022	navtnr20	ChangeRequest 53204: EUP - GEN/REP/INB - Additional Cargo Field – Shipping Line - UI

*/

vars
	iter		: Iterator;
	trimCode,
	theCode,
	codeKey		: String;
	theColor,
	colorKey	: Integer;
	theObject : Object;
	invalidShip : Boolean;
begin

	trimCode := _shippingLine.trimBlanks;

	if trimCode = null or (_viewModeCode &lt;&gt; null and _viewModeCode &lt;&gt; trimCode) then
		_code 	:= null;
		_color	:= NullColour;
		return;
	endif;

	iter := self.myIterShippingLine;
	self.allShippingLines.startKeyGeq(trimCode, 0, iter);
	self.allShippingLines.getIteratorKeys(codeKey, colorKey, iter);
	
	theCode		:= null;
	theColor	:= NullColour;
	if codeKey = trimCode then
		// found the right one
		theCode		:= trimCode;
		theColor	:= colorKey;
		iter.next(theObject);
	else
		if _ship &lt;&gt; null then
			invalidShip := false;
			on Exception do app.handleDeletedObject(exception,_ship,invalidShip); 
			self.allShippingLines.addNoDuplicates(_ship,false);
			self.beginNotification(_ship, EVENT_CODE_COLOUR_CHANGE, Response_Continuous, null);
			theCode		:= trimCode;
			theColor	:= _ship.colour;
			theObject := _ship;
			
			if invalidShip then 
				return; 
			endif;
		endif;
	endif;

	_code	:= theCode;
	_color	:= theColor;
	_object := theObject;

end;</source>
        <access>protected</access>
        <Parameter name="_shippingLine" type="String"/>
        <Parameter name="_ship" type="CM_ShippingLine"/>
        <Parameter name="_viewModeCode" type="String"/>
        <Parameter name="_code" type="String" usage="output"/>
        <Parameter name="_color" type="Integer" usage="output"/>
        <Parameter name="_object" type="Object" usage="output"/>
    </JadeMethod>
    <JadeMethod name="handleShippingLine2" id="4acb73da-e719-431e-96c6-c2ca4feb22ce">
        <source>handleShippingLine2(_code : String; _ship : CM_ShippingLine; _codesStr, _colourStr, _objStr : String io);
