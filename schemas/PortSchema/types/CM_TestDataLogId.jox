<Class name="CM_TestDataLogId" id="7180cfbb-5ee3-450d-a43a-ff3c01f524b5">
    <superclass name="CM_TestDataEntity"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="testData"/>
    <PrimAttribute name="lastNum" id="39eca011-df11-4879-a1e1-8a877935ac1f">
        <embedded/>
        <type name="Integer"/>
        <access>readonly</access>
    </PrimAttribute>
    <ExplicitInverseRef name="myTestDataRoot" id="8c3d13f5-5514-46f8-aa6e-72cf33a62491">
        <kind>child</kind>
        <updateMode>automatic</updateMode>
        <embedded/>
        <type name="CM_TestDataRoot"/>
        <access>readonly</access>
        <Inverse name="CM_TestDataRoot::myLogId"/>
    </ExplicitInverseRef>
    <JadeMethod name="incrementNumber" id="107b2c80-9fbe-477e-a19d-cdae78f083a8">
        <updating/>
        <source>incrementNumber(_numToGet : Integer) : Integer updating;
// ---------------------------------------------------------------------------
// Created:     06 June 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	firstNum	: Integer;
	
begin

	exclusiveLock(self);
	
	firstNum := self.lastNum + 1;
	self.lastNum := self.lastNum + _numToGet;
	return firstNum;

end;</source>
        <Parameter name="_numToGet" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
</Class>
