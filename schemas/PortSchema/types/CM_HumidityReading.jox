<Class name="CM_HumidityReading" id="753421be-997c-4533-85ba-211fc0f8e27c">
    <superclass name="CM_TITransaction"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="tempreading"/>
    <ExplicitInverseRef name="myHumidReading" id="ab538868-5d6e-4c6b-b9fc-6c1f979e9096">
        <embedded/>
        <type name="CM_HumidReading"/>
        <access>readonly</access>
        <Inverse name="CM_HumidReading::myHumidityReading"/>
    </ExplicitInverseRef>
    <JadeMethod name="cloneForTrackedItemRefs" id="1adbf2f9-5b63-46e6-916a-0ce5c46d35ce">
        <updating/>
        <source>cloneForTrackedItemRefs(_ti: CM_TrackedItem; _orginalTransaction: CM_HumidityReading) updating, protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 17/03/2015	cnwdap1		Initial creation PAR #35874 TFS 265
//
vars

begin
	inheritMethod(_ti, _orginalTransaction);
	self.myHumidReading := _orginalTransaction.myHumidReading.cloneSelf(self.isTransient);
	self.myHumidReading.cloneForTrackedItemRefs(_ti);
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_orginalTransaction" type="CM_HumidityReading"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="a4aa168d-5799-4e0f-83a8-69cf50f4db6b">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 17/03/2015	cnwdap1		Initial creation PAR #35874 TFS 265
//
vars
	detail	: String;
	humid	: CM_HumidReading;

begin
	if _attrName = ETRow_Details or _attrName = ETRow_Humidity then
		if self.deleted then
			return self.getDeletedDetails();		// 15/10/18 MAP TFS41191
		else
			humid := self.myHumidReading;
			if humid &lt;&gt; null then
				detail := humid.getDisplayHumidity();
			endif;
			return detail;
		endif;
	
	else
		return inheritMethod(_attrName, _short);
	endif;

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setFromCMIF_TITransactionCntrl" id="2a8d4bbf-2804-4bb7-8727-f6932a8a3cce">
        <updating/>
        <source>setFromCMIF_TITransactionCntrl(_tiTransCntrl: CMIF_TITransactionController; _passport: CM_Passport input) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 17/03/2015	cnwdap1		Initial creation PAR #35874 TFS 265
//
vars

begin
	self.setHumidReading(_tiTransCntrl.CMIF_HumidTransController.myHumidReading);
	inheritMethod(_tiTransCntrl, _passport);

epilog

end;</source>
        <Parameter name="_tiTransCntrl" type="CMIF_TITransactionController"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setHumidReading" id="c4a44eb9-5ddd-4f7b-9c81-5c232d344e8e">
        <updating/>
        <source>setHumidReading(_humidReading : CM_HumidReading) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 17/03/2015	cnwdap1		Initial creation PAR #35874 TFS 265
//
vars

begin
	self.myHumidReading := _humidReading;
epilog

end;</source>
        <Parameter name="_humidReading" type="CM_HumidReading"/>
    </JadeMethod>
</Class>
