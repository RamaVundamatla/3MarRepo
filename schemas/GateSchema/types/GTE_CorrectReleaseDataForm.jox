    <JadeMethod name="saveXMLStrForTblColumns" id="951301f9-7d05-4585-8904-77ff9fcb938c">
        <updating/>
        <source>saveXMLStrForTblColumns(table: CM_DataTable input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
31 January 2024	navcs2	ChangeRequest 57088: EUP | Correct Info on Departed Transport for Itemized Cargo
13.10.25	Navcs2	MTN-36202	MTN | Invoice Form displaying empty rows when rows are added from Selector form

*/

vars
	xmlStr, onsite : String;
begin
	xmlStr := self.tblReleasedTrackedItems.getXmlStrForColumns(true);			// 13.10.25	Navcs2	MTN-36202
	onsite := self.tblOnsiteTrackedItems.getXmlStrForColumns(true);				// 13.10.25	Navcs2	MTN-36202			

	self.enquiryTypeDef_Cargo := xmlStr;										// 13.10.25	Navcs2	MTN-36202
	self.enquiryTypeDef_OnsiteCargo := onsite;									// 13.10.25	Navcs2	MTN-36202
epilog

end;</source>
        <Parameter name="table" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setTableDataFromOrganiser" id="2cde2203-7426-445d-b6d1-830ff3858172">
        <updating/>
        <source>setTableDataFromOrganiser(table: CM_DataTable input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 January 2024	navcs2	ChangeRequest 57088: EUP | Correct Info on Departed Transport for Itemized Cargo
13.10.25	Navcs2	MTN-36202	MTN | Invoice Form displaying empty rows when rows are added from Selector form

*/

vars

begin
	self.doRefresh();
	self.onsiteCMIFs.clear();											// 13.10.25	Navcs2	MTN-36202
	self.releasedCMIFs.clear();											// 13.10.25	Navcs2	MTN-36202
	self.tblReleasedTrackedItems.getAllRowObjects(self.releasedCMIFs);	// 13.10.25	Navcs2	MTN-36202
	self.tblOnsiteTrackedItems.getAllRowObjects(self.onsiteCMIFs);		// 13.10.25	Navcs2	MTN-36202
	
	if table = self.tblReleasedTrackedItems then
		self.saveXMLStrForTblColumns(table);
		self.buildTableCargoReleased(false);							// 13.10.25	Navcs2	MTN-36202
	else
		self.saveXMLStrForTblColumns(table);
		self.buildTblOnsiteCargo(false);								// 13.10.25	Navcs2	MTN-36202
	endif;
epilog

end;</source>
        <Parameter name="table" type="CM_DataTable" usage="input"/>
    </JadeMethod>
