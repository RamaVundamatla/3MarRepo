    <JadeMethod name="cmbRFIDTags_click" id="08fda79a-cfd7-4bd0-9fcc-8fa600e876cc">
        <controlMethod name="CMUI_ComboBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbRFIDTags_click(combobox: ComboBox input) updating;
// --------------------------------------------------------------------------------
// Created:		31 August 2009 by cnwjo3, par 20582
//
// Purpose:		set the value of the table field and check that the RFID has not been selected already in lanes

// cnwcs5	10/09/2009	ccms 1061 - don't bother checking if nothing is selected
vars
	tbl				: CM_DataTable;
	jCell			: JadeTableCell;
	gRow 			: Integer;
	tagColumn 		: Integer;
	tagFoundInTable : Integer;
	tagReader 		: CM_RFIDTagReader;
	cellText 		: String;
begin
	tbl 		:= self.tblGateLanes;
	tagColumn 	:= tbl.getColumnByRowName(ETRow_RFIDTagReader);
	
	if tbl.row &lt; tbl.fixedRows + 1 or tbl.column &lt;&gt; tagColumn then
		return;
	endif;
	
//	if combobox.text = null then										// cnwcs5 10/09/2009
		jCell 				:= tbl.accessCell(tbl.row, tbl.column);		// cnwcs5 11/09/2009
		jCell.text 			:= combobox.text;							// cnwcs5 11/09/2009
		jCell.itemObject 	:= combobox.listObject;//the selected rfid	// cnwcs5 11/09/2009
		return;															// cnwcs5 10/09/2009
//	endif;																// cnwcs5 10/09/2009
	
	// the model validate methods will check if a reader is used more than once for the inertchange area 
	
	//count the number of instances a RFID tag reader is used in the current Yard Interchange Area
	foreach gRow in tbl.fixedRows + 1 to tbl.rows do
		cellText	:= tbl.accessCell(gRow, tagColumn).text;
		tagReader	:= self.getRFIDTagReaderByDescOrCode(cellText);
		
		if cellText = combobox.text then
			tagFoundInTable := tagFoundInTable + 1;
		elseif tagReader &lt;&gt; null then
			if tagReader.description = combobox.text or tagReader.code = combobox.text then
				tagFoundInTable := tagFoundInTable + 1;
			endif;
		endif;
	endforeach;
	
	//if we have more than 0 then raise message box
	if tagFoundInTable &gt; 0 then
		app.msgBox(app.getErrorString1(RFID_reader_in_use,combobox.text) ,self.caption,0);
		combobox.text := null;
	else
		jCell 				:= tbl.accessCell(tbl.row, tbl.column);
		jCell.text 			:= combobox.text;
		jCell.itemObject 	:= combobox.listObject;//the selected rfid
	endif;

end;

</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
