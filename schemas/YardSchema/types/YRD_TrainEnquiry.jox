    <JadeMethod name="setTableDataXML" id="50f841b7-2004-4e85-9a2e-517fbc43fd33">
        <source>setTableDataXML(): String protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
11 November 2009	cnwas3	Initial creation

*/

vars
	str : String;
	defaultXML, secondaryXML : String;
begin

	str := self.tblData.getXmlStrForColumns(true);

	if self.xmlStrTblDataArray.size &gt;= 1 then
		if self.xmlStrTblDataArray.size = 3 then 
			defaultXML := global.formatAsXMLPrefix(ETView_TrainEnqDefView) &amp; self.xmlStrTblDataArray[1]&amp;self.xmlStrTblDataArray[3]&amp; global.formatAsXMLSuffix(ETView_TrainEnqDefView);
		else
			defaultXML := global.formatAsXMLPrefix(ETView_TrainEnqDefView) &amp; self.xmlStrTblDataArray[1]&amp; global.formatAsXMLSuffix(ETView_TrainEnqDefView);
		endif;
	endif;
	if self.xmlStrTblDataArray.size &gt;= 2 then
		if self.xmlStrTblDataArray.size = 3 then
			secondaryXML := global.formatAsXMLPrefix(ETView_TrainEnqSecView) &amp; self.xmlStrTblDataArray[2]&amp;self.xmlStrTblDataArray[3]&amp; global.formatAsXMLSuffix(ETView_TrainEnqSecView);
		else
			secondaryXML := global.formatAsXMLPrefix(ETView_TrainEnqSecView) &amp; self.xmlStrTblDataArray[2]&amp; global.formatAsXMLSuffix(ETView_TrainEnqSecView);
		endif;
	endif;

	
	if self.optSecView.value then //Over-ride the current option
		secondaryXML := global.formatAsXMLPrefix(ETView_TrainEnqSecView) &amp; str &amp; global.formatAsXMLSuffix(ETView_TrainEnqSecView);
	elseif self.optDefView.value then
		defaultXML := global.formatAsXMLPrefix(ETView_TrainEnqDefView) &amp; str &amp; global.formatAsXMLSuffix(ETView_TrainEnqDefView);
	endif;

	str := defaultXML &amp; secondaryXML;

	return str;
end;</source>
        <access>protected</access>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setToday" id="9bb6ea60-8134-4f1b-bfce-362c08b01a71">
        <updating/>
        <source>setToday() updating;
// ---------------------------------------------------------------------------
// Created:		May 2009 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 09 May 2016	cnwns1	TFS 488 - Multi Timezone Support
// ---------------------------------------------------------------------------

vars
	t : Time;
begin
	self.mskArrivalDT.setFocus();
	self.mskArrivalDT.setDate(self.systemToLocalTime(app.actualTimeServer).date);// 09 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	t.setTime(0, 0,0,0);
	self.mskArrivalTM.setTime(t);
end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="9aa49ba7-716b-46bc-a080-b3119faa507d">
        <updating/>
        <source>setupForm() updating;
// ---------------------------------------------------------------------------
// Created:		October  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 20 Apr 2022  navtnr20	TFS 53142 Cargo Forecast on Voyage &amp; Train
// ---------------------------------------------------------------------------

vars

begin
	self.usesQueryFrame := true;

	self.toolbarStyle := self.ToolbarStyle_ShowNoHide;
	self.showToolbar := true;
	self.useTableSorting := true;
	self.useTableInfo := true;
	
	self.frmPrnQuery.visible := false;		//+ 25/05/2009, cnwmd1, CCMS 1067, Par 19710
	
	inheritMethod();

	self.setCaption(app.getErrorString(Train) &amp; " " &amp; app.getErrorString(Enquiry));
	self.setNavigatorHeading(self.caption);
	self.optDefView.value := true;		//cnwas3 CCMS MSL 1013
	self.optSecView.value := false;		//cnwas3 CCMS MSL 1013
	self.initTableData(ETDef_TrainList);	
	
	self.mnuContextColourLegend.visible := false;

	self.tblInfo.rows := 0;
	
	//+cnwml2 PAR26072
	self.cmbOrigin.myAssistant 	:= self.myAssistant;
	self.cmbOrigin.isRail       := true;
	self.cmbOrigin.bubbleHelp   := app.getErrorString(BUBHELP_WAGONORGPORT);
	
		//+cnwml2 PAR26072
	self.cmbDestination.myAssistant 	:= self.myAssistant;
	self.cmbDestination.isRail       	:= true;
	self.cmbDestination.bubbleHelp   	:= app.getErrorString(BUBHELP_WAGONDESTPORT);
	
	self.doBuildComboTrainStatus();//navsp1 17MAY2022 TFS#53619
	
	self.beginClassNotification(CM_Train, false, Object_Create_Event, Response_Continuous, null);
	//jlier1 JIRA#33496 5/12/24 - will begin object notification for train so this would  get x2 notifications
	//self.beginClassNotification(CM_Train, false, Object_Update_Event, Response_Continuous, null);
	//self.beginClassNotification(CM_Train, false, Object_Delete_Event, Response_Continuous, null);

	if self.txtCode.text.trimBlanks() &lt;&gt; null then
		self.doQuery();
	else
		//self.setToday();
		self.setDefaultQuery();		// 10/03/2010 cnwjre1 par 22753 request to initialise to 'default' not today
	endif;
	self.btnCargoForecast.enabled := false;		//	25-Apr-2022	TFS 53142
end;</source>
    </JadeMethod>
    <JadeMethod name="showCargo" id="e2c7b1f6-4004-4d3c-8b48-6925debc99e0">
        <source>showCargo(_in : Boolean);
// ---------------------------------------------------------------------------
// Created:     21 May 2009 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	train : CM_Train;
	wagon : CM_Wagon;
	obj : Object;
	objArray : CM_TIArray;
begin


	create objArray transient;
	
	foreach obj in self.tblData.allSelectedObjects discreteLock do
		train := obj.CM_Train;
		
		if _in then
			if train.allTIsReceived.isEmpty() then
				foreach wagon in train.allWagonsByIdInward discreteLock do
					wagon.getAllTrackedItems(true, objArray, false);
				endforeach;
			else
				train.allTIsReceived.copy(objArray);
			endif;
		else
			if train.allTIsReleased.isEmpty() then
				foreach wagon in train.allWagonsByIdOutward discreteLock do
					wagon.getAllTrackedItems(false, objArray, false);
				endforeach;
			else
				train.allTIsReleased.copy(objArray);
			endif;
		endif;
	endforeach;
	
	if objArray.isEmpty() then
		app.msgBox(app.getErrorString(No_Cargo_For_Train), app.getErrorString(Cargo_Enquiry), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
	else
		self.myAssistant.showCargoEnquiryForTIs(objArray[1].CM_TrackedItem, objArray, self.myMasterMenuAction, false);
	endif;

epilog
	delete objArray;
end;</source>
        <Parameter name="_in" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="showColumnOrganiser" id="e550ee27-93bb-4fb0-9423-67054d645d3a">
        <source>showColumnOrganiser();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
11 November 2009	cnwas3	Initial creation
27 Apr 2021 navmd1	TFS 51086 - Workaround JADE 2020 variable string arrays by defaulting member size back to pre-2020 values

*/

constants
	HSA_DEFAULT_SIZE	: Integer = 2048;	// default size pre-2020
vars
	defBefore, defAfter, typeTag : String;
	maxLen		: Integer;
begin
	
	if self.tblData = null then
		return;
	endif;
	
	defBefore := self.tblData.getXmlStrForColumns(true);
	inheritMethod();
	defAfter := self.tblData.getXmlStrForColumns(true);
	
	if defBefore &lt;&gt; defAfter then //Update the array if columns have changed via the column organiser.  The array is saved when form is closed
		
		maxLen := HugeStringArray.memberTypeSize;
		if maxLen &lt; 0 then
			maxLen := HSA_DEFAULT_SIZE;
		endif;
		
		if self.optSecView.value then //Over-ride the current option
			if defAfter.length() &gt;= maxLen then
				self.xmlStrTblDataArray[2] := defAfter.padTrimTo(maxLen-1);				
				self.xmlStrTblDataArray[3] := defAfter[maxLen:defAfter.length()];
			else
				self.xmlStrTblDataArray[2] := defAfter;
				//self.xmlStrTblDataArray[3] := "";
			endif;
		elseif self.optDefView.value then			
			if defAfter.length() &gt;= maxLen then
				self.xmlStrTblDataArray[1] := defAfter.padTrimTo(maxLen-1);				
				self.xmlStrTblDataArray[3] := defAfter[maxLen:defAfter.length()];
			else
				self.xmlStrTblDataArray[1] := defAfter;
				//self.xmlStrTblDataArray[3] := "";
			endif;
		endif;
		
	endif;

epilog

end;</source>
    </JadeMethod>
