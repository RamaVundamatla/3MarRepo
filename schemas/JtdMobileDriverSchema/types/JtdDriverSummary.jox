    <JadeMethod name="jtdInitialize" id="9d2de196-b3f0-47fe-9e45-781e0b23965f">
        <updating/>
        <source>jtdInitialize() updating;

begin
	self.jtdTotalDeadlocks := 0;
	self.jtdTotalLocks := 0;
	self.jtdTotalReadErrs := 0;
	self.jtdTotalReadGenSecs := 0;
	self.jtdTotalReadTrxSecs := 0;
	self.jtdTotalReads := 0;
	self.jtdTotalUnhandledExceptions := 0;
	self.jtdTotalUpdErrs := 0;
	self.jtdTotalUpdGenSecs := 0;
	self.jtdTotalUpdTrxSecs := 0;
	self.jtdTotalUpds := 0;
end;</source>
    </JadeMethod>
    <JadeMethod name="jtdInitializeSecs" id="3c60f844-dd92-4a33-a90b-043ff60ecb2c">
        <updating/>
        <source>jtdInitializeSecs() updating;

begin
	self.jtdTotalReadGenSecs := 0;
	self.jtdTotalReadTrxSecs := 0;
	self.jtdTotalUpdGenSecs := 0;
	self.jtdTotalUpdTrxSecs := 0;
end;</source>
    </JadeMethod>
    <JadeMethod name="jtdSet" id="dca96385-a332-468f-99fe-c9e28db5d3f4">
        <updating/>
        <source>jtdSet(_deadlocks, _locks, _readErrs : Integer; _readGenSecs, _readTrxSecs : Real;
	_reads, _unhandledExceptions, _updErrs : Integer; _updGenSecs, _updTrxSecs : Real;
	_upds : Integer) updating;

begin
	self.jtdTotalDeadlocks := _deadlocks;
	self.jtdTotalLocks := _locks;
	self.jtdTotalReadErrs := _readErrs;
	self.jtdTotalReadGenSecs := _readGenSecs;
	self.jtdTotalReadTrxSecs := _readTrxSecs;
	self.jtdTotalReads := _reads;
	self.jtdTotalUnhandledExceptions := _unhandledExceptions;
	self.jtdTotalUpdErrs := _updErrs;
	self.jtdTotalUpdGenSecs := _updGenSecs;
	self.jtdTotalUpdTrxSecs := _updTrxSecs;
	self.jtdTotalUpds := _upds;
end;</source>
        <Parameter name="_deadlocks" type="Integer"/>
        <Parameter name="_locks" type="Integer"/>
        <Parameter name="_readErrs" type="Integer"/>
        <Parameter name="_readGenSecs" type="Real"/>
        <Parameter name="_readTrxSecs" type="Real"/>
        <Parameter name="_reads" type="Integer"/>
        <Parameter name="_unhandledExceptions" type="Integer"/>
        <Parameter name="_updErrs" type="Integer"/>
        <Parameter name="_updGenSecs" type="Real"/>
        <Parameter name="_updTrxSecs" type="Real"/>
        <Parameter name="_upds" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="jtdSetElapsedSecs" id="8649b1c5-d114-4799-bc40-482385707036">
        <updating/>
        <source>jtdSetElapsedSecs(_readSecs, _updSecs : Real) updating;

begin
	self.jtdTotalReadGenSecs := 0;
	self.jtdTotalReadTrxSecs := _readSecs;
	
	self.jtdTotalUpdGenSecs := 0;
	self.jtdTotalUpdTrxSecs := _updSecs;
end;</source>
        <Parameter name="_readSecs" type="Real"/>
        <Parameter name="_updSecs" type="Real"/>
    </JadeMethod>
    <JadeMethod name="jtdSetFromString" id="8b7b6c83-a74a-479f-8251-2a063a5a2948">
        <updating/>
        <source>jtdSetFromString(details : String) updating;

vars
	s, propName, typ : String;
	trimmedDetails : String;
	n, detailsLen : Integer;
	
begin
	self.jtdInitialize;

	trimmedDetails := details.trimBlanks;

	detailsLen := trimmedDetails.length;

	if detailsLen &lt; 1 then
		return;
	endif;
	
	n := 1;

	foreach propName in self.jtdAllPropertyNames do
		if n &gt; detailsLen then
			// past the end of the string, so nothing more to do
			break;
		endif;
		
		s := trimmedDetails.scanUntil(';', n).trimBlanks;
		
		if n &lt; 1 then
			// no delimiter found, so assume that whatever's left is junk
			break;
		endif;
		
		n := n + 1; // move past the delimiter for the next iteration

		if s = null then
			// property has already been initialized, so on to the next one
			continue;
		endif;

		typ := propName[1];
		propName := propName[2 : end];
			
		if typ = 'R' then
			self.setPropertyValue(propName, s.Real);
		else
			// assume integer
			self.setPropertyValue(propName, s.Integer);
		endif;
	endforeach;
end;</source>
        <Parameter name="details" type="String"/>
    </JadeMethod>
    <JadeMethod name="jtdSetMaxSecs" id="3cd8bc30-6362-4ee3-b779-b92f35b5675b">
        <updating/>
        <source>jtdSetMaxSecs(readGenSecs, readTrxSecs, updGenSecs, updTrxSecs : Real) updating;

begin
	if readGenSecs &gt; self.jtdTotalReadGenSecs then
		self.jtdTotalReadGenSecs := readGenSecs;
	endif;
	if readTrxSecs &gt; self.jtdTotalReadTrxSecs then
		self.jtdTotalReadTrxSecs := readTrxSecs;
	endif;
	if updGenSecs &gt; self.jtdTotalUpdGenSecs then
		self.jtdTotalUpdGenSecs := updGenSecs;
	endif;
	if updTrxSecs &gt; self.jtdTotalUpdTrxSecs then
		self.jtdTotalUpdTrxSecs := updTrxSecs;
	endif;
end;</source>
        <Parameter name="readGenSecs" type="Real"/>
        <Parameter name="readTrxSecs" type="Real"/>
        <Parameter name="updGenSecs" type="Real"/>
        <Parameter name="updTrxSecs" type="Real"/>
    </JadeMethod>
    <JadeMethod name="jtdSubtractSummary" id="761f0fc6-df08-4a97-9854-30e8d748e008">
        <updating/>
        <source>jtdSubtractSummary(jds : JtdDriverSummary; subtractSecs : Boolean) updating;

begin
	if jds = null then
		return;
	endif;

	self.jtdTotalDeadlocks := self.jtdTotalDeadlocks - jds.jtdTotalDeadlocks;
	self.jtdTotalLocks := self.jtdTotalLocks - jds.jtdTotalLocks;
	self.jtdTotalReadErrs := self.jtdTotalReadErrs - jds.jtdTotalReadErrs;
	self.jtdTotalReads := self.jtdTotalReads - jds.jtdTotalReads;
	self.jtdTotalUnhandledExceptions := self.jtdTotalUnhandledExceptions - jds.jtdTotalUnhandledExceptions;
	self.jtdTotalUpdErrs := self.jtdTotalUpdErrs - jds.jtdTotalUpdErrs;
	self.jtdTotalUpds := self.jtdTotalUpds - jds.jtdTotalUpds;

	if self.jtdTotalDeadlocks &lt; 0 then
		self.jtdTotalDeadlocks := 0;
	endif;
	if self.jtdTotalLocks &lt; 0 then
		self.jtdTotalLocks := 0;
	endif;
	if self.jtdTotalReadErrs &lt; 0 then
		self.jtdTotalReadErrs := 0;
	endif;
	if self.jtdTotalReads &lt; 0 then
		self.jtdTotalReads := 0;
	endif;
	if self.jtdTotalUnhandledExceptions &lt; 0 then
		self.jtdTotalUnhandledExceptions := 0;
	endif;
	if self.jtdTotalUpdErrs &lt; 0 then
		self.jtdTotalUpdErrs := 0;
	endif;
	if self.jtdTotalUpds &lt; 0 then
		self.jtdTotalUpds := 0;
	endif;

	if not subtractSecs then
		return;
	endif;
	
	self.jtdTotalReadGenSecs := self.jtdTotalReadGenSecs - jds.jtdTotalReadGenSecs;
	self.jtdTotalReadTrxSecs := self.jtdTotalReadTrxSecs - jds.jtdTotalReadTrxSecs;
	self.jtdTotalUpdGenSecs := self.jtdTotalUpdGenSecs - jds.jtdTotalUpdGenSecs;
	self.jtdTotalUpdTrxSecs := self.jtdTotalUpdTrxSecs - jds.jtdTotalUpdTrxSecs;

	if self.jtdTotalReadGenSecs &lt; 0 then
		self.jtdTotalReadGenSecs := 0;
	endif;
	if self.jtdTotalReadTrxSecs &lt; 0 then
		self.jtdTotalReadTrxSecs := 0;
	endif;
	if self.jtdTotalUpdGenSecs &lt; 0 then
		self.jtdTotalUpdGenSecs := 0;
	endif;
	if self.jtdTotalUpdTrxSecs &lt; 0 then
		self.jtdTotalUpdTrxSecs := 0;
	endif;
end;</source>
        <Parameter name="jds" type="JtdDriverSummary"/>
        <Parameter name="subtractSecs" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="jtdUpdateStatistics" id="5ec2b4a4-0018-49ef-a789-9f972cc0423e">
        <updating/>
        <source>jtdUpdateStatistics(isUpdateTrx : Boolean; genSecs, trxSecs : Real; trxErrNo, exErrNo : Integer) updating;

constants
	ObjectLocked = 1027;
	Deadlock = 1081;

begin
	if exErrNo &lt;&gt; 0 then
		self.jtdTotalUnhandledExceptions := self.jtdTotalUnhandledExceptions + 1;
		
		if exErrNo = ObjectLocked then
			self.jtdTotalLocks := self.jtdTotalLocks + 1;
		elseif exErrNo = Deadlock then
			self.jtdTotalDeadlocks := self.jtdTotalDeadlocks + 1;
		endif;
	endif;
	
	if isUpdateTrx then
		self.jtdTotalUpds := self.jtdTotalUpds + 1;
		self.jtdTotalUpdGenSecs := self.jtdTotalUpdGenSecs + genSecs;
		self.jtdTotalUpdTrxSecs := self.jtdTotalUpdTrxSecs + trxSecs;
		
		if trxErrNo &lt;&gt; 0 then
			self.jtdTotalUpdErrs := self.jtdTotalUpdErrs + 1;
		endif;
	else
		self.jtdTotalReads := self.jtdTotalReads + 1;
		self.jtdTotalReadGenSecs := self.jtdTotalReadGenSecs + genSecs;
		self.jtdTotalReadTrxSecs := self.jtdTotalReadTrxSecs + trxSecs;
		
		if trxErrNo &lt;&gt; 0 then
			self.jtdTotalReadErrs := self.jtdTotalReadErrs + 1;
		endif;
	endif;		
end;</source>
        <Parameter name="isUpdateTrx" type="Boolean"/>
        <Parameter name="genSecs" type="Real"/>
        <Parameter name="trxSecs" type="Real"/>
        <Parameter name="trxErrNo" type="Integer"/>
        <Parameter name="exErrNo" type="Integer"/>
    </JadeMethod>
</Class>
