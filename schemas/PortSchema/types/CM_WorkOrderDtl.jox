    <JadeMethod name="getAllVehicleVisitsStr" id="bea65431-2ed4-4921-9a50-767e0f4ab829">
        <source>getAllVehicleVisitsStr() : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26/11/2024	navkc1 JIRA Story MTN-19092: EUP | 54014 - Work Orders Enhancements - Improved Search and usability

*/

vars
	str		: String;
	vvr		: CM_VehicleVisitRecord;
	vvrs	: CM_VehicleVisitRecordSet;
begin
	create vvrs transient;
	
	self.getAllVehicleVisits(vvrs);
	
	foreach vvr in vvrs do
		if vvr.visitNumber = null then
			continue;
		endif;
		
		/*
		if str = null then
			str := vvr.visitNumber;
		else
			if str.pos(vvr.visitNumber, 1) &gt; null then
				continue;
			else
				str &amp;= Comma &amp; vvr.visitNumber;
			endif;
		endif;
		*/
		
		str.addStringToList(vvr.visitNumber, Comma); //04/04/2025	navkc1 JIRA Story MTN-33940
	endforeach;
	
	return str;
epilog
	delete vvrs;
end;</source>
