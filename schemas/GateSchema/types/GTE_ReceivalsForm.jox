// ---------------------------------------------------------------------------
// Created:     02 October 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	voyageCombo	: ComboBox;
	tmpVoyage	: CM_Voyage;
	voyageCode	: String;
	pos			: Integer;
	saveOperator	: CM_Operator;
begin
	voyageCombo := self.cmbVoyage;
//	pos := 1;
	tmpVoyage	:= voyageCombo.listObject.CM_Voyage;
	// strip off the description
//	if voyageCode &lt;&gt; null then
//		voyageCode := voyageCode.scanUntil(Tab, pos).trimRight;
//	endif;

	if combobox.myVoyage = tmpVoyage then
		return;
	endif;

//	tmpVoyage := voyageCombo.listObject.CM_Voyage;
	if tmpVoyage = null then
		tmpVoyage := self.myAssistant.getVoyageFromCombo(voyageCode);
	endif;
	
	saveOperator := combobox.myOperator; 

	combobox.clear;

	// need to reset list	
	combobox.setObjectAndVoyage(saveOperator, tmpVoyage);
	combobox.gotFocus(combobox); //call again to reset// will only get this far if voyage changed again. 

//	self.myAssistant.comboBoxOperator(combobox, combobox.listObject.CM_Operator, tmpVoyage);

end;</source>
