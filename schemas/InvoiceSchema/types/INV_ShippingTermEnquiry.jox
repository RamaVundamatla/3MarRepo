    <JadeMethod name="doBtnNewClick" id="390ab249-b7cd-4769-986f-a5fbb555b895">
        <source>doBtnNewClick();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 Jan 2023 navtnr20	TFS CR 55622 Task 55692: UI - Shipping Terms Maint

*/

vars
	form : INV_ShippingTermMaint;
	bank :CM_Bank;
begin
	form := app.loadForm(INV_ShippingTermMaint, INV_Assistant, false, false,false, self.myTerminal,null).INV_ShippingTermMaint;
	if form &lt;&gt; null then
		form.mode := false;
		form.btnRemove.enabled := false;
		form.btnAdd.enabled := false;
		form.btnUpdate.enabled := false;
		form.btnAudits.enabled := false;
		form.setMyCurrentBank(self.myCurrentBank);
		//form.setBank(bank);
		form.centreWindow();
		form.show;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doBtnUpdateClick" id="967a7aa5-a172-4b4e-82c3-e902e542f7e6">
        <source>doBtnUpdateClick();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 Jan 2023 navtnr20	TFS CR 55622 Task 55692: UI - Shipping Terms Maint

*/

vars
	form : INV_ShippingTermMaint;
	pxyShipMapping : CM_InvoiceShipTermMapping;
	shipterm:CM_InvoiceContractShipTerm;
begin
	shipterm := self.tblShipTerm.accessRow(self.tblShipTerm.row).itemObject.CM_InvoiceContractShipTerm;
	if shipterm = null then
		app.msgBox("No record selected", "Warning",MsgBox_OK_Only);
		return;
	endif;
	if shipterm &lt;&gt; null then
	//	pxyShipMapping := self.tblShipTerm.allSelectedObjects.first.CM_InvoiceShipTermMapping;
		form := app.loadForm(INV_ShippingTermMaint, INV_Assistant, false, false,false, self.myTerminal,null).INV_ShippingTermMaint;
		if form &lt;&gt; null then
			form.mode := true;
			form.setShipTerm(shipterm);
			form.setMyCurrentBank(self.myCurrentBank);
			form.centreWindow();
			form.show;
		endif;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doCmbBUBuild" id="bd93b918-fb92-40eb-bc5a-27e42a3aa938">
        <source>doCmbBUBuild(_combo : CMUI_ComboBox input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 Jan 2023 navtnr20	TFS CR 55622 Task 55692: UI - Shipping Terms Maint

*/

vars
	aTerm : CM_Terminal;
	company:  CM_Bank;
begin
	_combo.clear;
	_combo.sorted := false;


	foreach company in self.myTerminal.companies do
		if company.isBusinessUnit then
			_combo.addItem(company.code);
			_combo.itemObject[_combo.newIndex] := company;
		endif;
	endforeach;

	if self.myCurrentBank &lt;&gt; null then
		_combo.listObject := self.myCurrentBank;
	endif;

end;</source>
        <Parameter name="_combo" type="CMUI_ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doHandleNotification" id="7f683642-e93a-487b-866b-6f70cea60186">
        <updating/>
        <source>doHandleNotification( eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any)updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 Jan 2023 navtnr20	TFS CR 55622 Task 55692: UI - Shipping Terms Maint

*/

vars
	dataLine	: String;
	shipTerm : CM_InvoiceContractShipTerm;
	event : Integer;
	idx : Integer;
	theDataLine : String;
begin
	self.mousePointer := Window.MousePointer_HourGlass;

	event := self.myTerminal.getEventFromTerminalEvent(eventType);
	
	if userInfo.isKindOf(CM_InvoiceContractShipTerm) then
		shipTerm := userInfo.CM_InvoiceContractShipTerm;
	elseif theObject.isKindOf(CM_InvoiceContractShipTerm) then
		shipTerm := theObject.CM_InvoiceContractShipTerm;
	endif;
	
	if event = Event_InvShipTermCreate then
		if shipTerm &lt;&gt; null then			
			self.tblDisplayRow();
		endif;
	elseif event = Event_InvShipTermUpdate then
		if shipTerm &lt;&gt; null then
			self.tblShipTerm.findObjectInRow(shipTerm,idx);
			if idx &gt; self.tblShipTerm.fixedRows then
				theDataLine := shipTerm.getAttributeStringForDefArray(self.tblShipTerm.allTblDataEntRows);
				self.tblShipTerm.accessCell(idx, 1).text := theDataLine;
			endif;
		endif;
	elseif event = Event_InvShipTermDelete then
		self.tblShipTerm.removeItemObject(shipTerm);
		self.doNotableClear();
	endif;
epilog
	self.mousePointer := Window.MousePointer_Default;
end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
