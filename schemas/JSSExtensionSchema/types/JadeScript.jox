    <JadeMethod name="cnwdad1_List_Translatables" id="aa562717-6a82-48cc-a1b0-e7ff14d6cb3b">
        <source>cnwdad1_List_Translatables();
// --------------------------------------------------------------------------------
// Created:		20 November 2000 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theBaseSchema		: Schema;
	allXstrings			: ConstantNDict;
	localeArray			: ObjectArray;
	theConstantObject	: Constant;
	theLocaleObject		: Object;
	localeName			: String;
	startTime			: Integer;
	
begin
	startTime		:=	app.clock();
	theBaseSchema	:=	rootSchema.getSchema("BaseSchema");

	create localeArray transient;
	
	theBaseSchema.getAllBaseLocales(localeArray);

	foreach theLocaleObject in localeArray do
		localeName	:=	theLocaleObject.Locale.makeLocaleName();
		allXstrings	:=	theLocaleObject.Locale.getTranslatableStrings();
		
		foreach theConstantObject in allXstrings do
			write localeName &amp; ": " &amp; theConstantObject.TranslatableString.display();
		endforeach;
	endforeach;
epilog
	delete localeArray;
	
	write CrLf &amp; "Translatable String list completed in " &amp; startTime.jssClockDifference().String &amp; " seconds.";
end;</source>
    </JadeMethod>
