    <JadeMethod name="doDelete" id="a870a4a1-6648-494d-a665-271c8c54e009">
        <updating/>
        <source>doDelete() : Boolean updating;
// ---------------------------------------------------------------------------
// Created:     05 April 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	bolOut						: CM_BOLOut;
	deletionController			: CMIF_BOLOutDeletionController;
	theResult : Integer;	//14 Jan 2020 NDL	TFS 46815
begin
	bolOut := self.myCurrentMasterObject.CM_BOLOut;
	//PAR 9207 - enforce location
	if self.cmbLocation.listObject = null and (not bolOut.allTrackedItems.isEmpty) then 
		app.msgBox('You must select a location before continuing', 'No Location selected', MsgBox_Exclamation_Mark_Icon);
		return false;
	endif;
	
	create deletionController transient;
	
	deletionController.myBOLOut 			:= bolOut;
	deletionController.myToLocation 		:= self.cmbLocation.listObject.CM_LocationsController;
	
	deletionController.createReceivalTxns	:= self.chkReceivalTxns.value;
	deletionController.createReceiveCharges	:= self.chkReceiveCharge.value;
	//following three flags are ignored if there is no master container/process option wasn't 'Pack'
	deletionController.createUnpackTxns		:= self.chkUnpackTxns.value;
	deletionController.createUnpackCharges 	:= self.chkUnpackCharges.value;
	
	//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxDA.trxDeleteBOLGeneralCargo(deletionController, app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			self.showHideDeleteDocketFrm(false);
			return true;
		else
			theResult := app.showErrorWarningDialog('Deleting ' &amp; self.getDataEntityDescription(true), 
									app.myPassport,
									ErrWarnMode_Add + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		break;
		
	endwhile;
	
epilog
	delete deletionController;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doDetailAdd" id="ef363b8e-5662-4752-a63b-86499ce67fa6">
        <updating/>
        <source>doDetailAdd()updating;
// ---------------------------------------------------------------------------
// Created:     25 July 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars
	proxy	: CMIF_BOLOutLine;
	row		:	Integer;
	tblDetail : CM_DataTable;
	defailtFromLineAbove	: Boolean;

begin
	
	if self.mode &lt;&gt; self.Mode_New then
		// currently cannot edit docket - need to review this!!!
		return;
	endif;
	
	tblDetail := self.tblDataDetail;

	create proxy transient;

	row := tblDetail.rows;
	if row &gt; tblDetail.fixedRows then
		// get the details from the previous line to default
		proxy.myCargoType	:= self.getTblDataDetailCargoType(row);
		proxy.myProduct		:= self.getTblDataDetailProduct(row);
	endif;
	
	self.myCurrentDetailObject	:= proxy;

	self.allDetailObjects.add(proxy);
	self.addProxyObjectToDetailTable(self.tblDataDetail, proxy);
	//self.allDetailObjects.add(proxy);
	
	// row is added in method addProxyObjectToDetailTable
	row := tblDetail.rows;
	
	tblDetail.clearAllSelected();
	tblDetail.selectRow(row, true);
	tblDetail.row := row;
	if tblDetail.row =(tblDetail.fixedRows + 1) then 
		tblDetail.column := 1; // is first row so start at begining
	else
		tblDetail.column := self.colItem; // has been added so will have defaults from above so start at id column PAR11162
	endif;
	tblDetail.setFocus();

end;</source>
    </JadeMethod>
    <JadeMethod name="doDocketStatusChange" id="e6cffa79-3a32-464d-b3cf-d732d0f3bff3">
        <updating/>
        <source>doDocketStatusChange(_allPreviousOrFuture,
					_fowards 				: Boolean; 
					_statusToAssign 		: Integer) updating, protected;
// ---------------------------------------------------------------------------
// Created:     02 June 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	bolOut					: CM_BOLOut;
	bolArchiveController	: CMIF_BOLArchiveController;
	terminal				: CM_Terminal;
	bolOutDict				: CM_BOLOutByTypeStatusNumDTDict;
	iter					: Iterator;
	statusToCollect			: Integer;
	theResult : Integer;	//14 Jan 2020 NDL	TFS 46815
begin
	bolOut := self.myCurrentMasterObject.CM_BOLOut;
	 
	if bolOut = null then
		app.msgBox('Please select a docket to archive', 'Nothing selected', MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	
	if _statusToAssign = BOL_STATUS_ARCHIVED then
		statusToCollect := BOL_STATUS_NORMAL;
		if _allPreviousOrFuture then
			if app.msgBox('Are you sure you want to change the status of all dockets up to, and including, ' &amp; bolOut.dateTime.String &amp; ' to "Archived"?', 'Are you sure?', MsgBox_OK_Cancel) &lt;&gt; MB_OK then
				return;
			endif;
		endif;
						
	elseif _statusToAssign = BOL_STATUS_NORMAL then
		statusToCollect := BOL_STATUS_ARCHIVED;
		if _allPreviousOrFuture then
			if app.msgBox('Are you sure you want to change the status of all dockets foward of, and including, ' &amp; bolOut.dateTime.String &amp; ' to "Normal"?', 'Are you sure?', MsgBox_OK_Cancel) &lt;&gt; MB_OK then
				return;
			endif;
		endif;	
	else
		app.raiseUnexpectedProgramError(class.name, method.name, 'No statusToAssign value was passed in');
		return;
	endif;
	
	create bolArchiveController transient;
	bolArchiveController.archiveStatus := _statusToAssign;
	
	if _allPreviousOrFuture then
		self.myTerminal.getBOLsForTypeStatusDate(bolArchiveController.allBOLOuts,
												BOLType_GeneralDocket,
												statusToCollect,
												bolOut.dateTime,
												_fowards,
												bolOut.number);
	
	else
		bolArchiveController.allBOLOuts.add(bolOut);
	endif;
	
	//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxUA.trxUpdateBOLStatus(bolArchiveController, app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			self.zDoSearch();
			break;
		else
			theResult := app.showErrorWarningDialog('Docket Stauts Update', app.myPassport, ErrWarnMode_Update);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		break;
		
	endwhile;
	
epilog
	delete bolArchiveController;
end;</source>
        <access>protected</access>
        <Parameter name="_allPreviousOrFuture" type="Boolean"/>
        <Parameter name="_fowards" type="Boolean"/>
        <Parameter name="_statusToAssign" type="Integer"/>
    </JadeMethod>
