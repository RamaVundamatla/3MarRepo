    <JadeMethod name="setForCreate" id="93f2c401-c971-44ce-8cae-8e07702226e0">
        <updating/>
        <source>setForCreate(_proxy : CM_Product) updating;
// ---------------------------------------------------------------------------
// Created:     20 April 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	
begin
	self.setForUpdate(_proxy);
	//these references should NOT be changed after initial creation, so
	//we'll assume these are never updated
	self.myCargoType 				:=	_proxy.myCargoType;
	if self.code &lt;&gt; SystemProductCode then	//ccms 1080, PAR 19704. Special system product type no to be included into cargoType.allProducts collection. See cargoType.mySystemProduct type info.
		self.myCargoTypeExtBreakBulkGen	:=	_proxy.myCargoType.myCargoExtension.CM_CargoTypeExtBreakBulkGen;
	endif;
	
end;</source>
        <Parameter name="_proxy" type="CM_Product"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="f6456709-3fad-464d-a1a5-b426c0d3de6e">
        <updating/>
        <source>setForUpdate(_proxy : CM_Product) updating;
// ---------------------------------------------------------------------------
// Created:     11 June 2002 by cnwth2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 30/11/2009	cnwdap1		CCMS 1007 - added reefer attributes
// ---------------------------------------------------------------------------
vars
	needsRefresh : Boolean;
begin
	self.myHandlingType 	:=	_proxy.myHandlingType;
	self.myHandlingSubType 	:=	_proxy.myHandlingSubType;	//31 Mar 2017	NDL	TFS 3414
	self.myProductGroup		:=	_proxy.myProductGroup;
	self.code				:=	_proxy.code;
	if self.description &lt;&gt; _proxy.description then	//04 Apr 2019	NDL	TFS 44194
		self.description	:=	_proxy.description;
		needsRefresh 		:= true;	//04 Apr 2019	NDL	TFS 44194
	endif;
	self.colour				:=	_proxy.colour;
	self.storageCharge		:=	_proxy.storageCharge;
	self.setAttributesForUpdate(_proxy);
	self.defaultCommodityCode := _proxy.defaultCommodityCode;
	self.myOperator 				:=	_proxy.myOperator; //epr par 30752 28/11/12
	// CCMS 1007
	self.isReefer			:= _proxy.isReefer;
	self.isPowered			:= _proxy.isPowered;
	self.isIntegral			:= _proxy.isIntegral;
	self.isFan				:= _proxy.isFan;
	self.isNotActive		:= _proxy.isNotActive; //epr TFS 1846 18/4/16
	
	self.autoVolumeCalculate := _proxy.autoVolumeCalculate;	//10 June 2016	NDL	TFS 2141
	self.autoWeightCalculate := _proxy.autoWeightCalculate;	//18 Jan 2018	NDL	TFS 36697

	//04 Apr 2019	NDL	TFS 44194
	if needsRefresh then
		if app.myAlternateDict &lt;&gt; null then
			app.myAlternateDict.setProductDictNeedsRefresh();
		endif;
	endif;
	
end;</source>
        <Parameter name="_proxy" type="CM_Product"/>
    </JadeMethod>
    <JadeMethod name="setFromCopy" id="4df6fefc-c8dd-448c-829c-2a69bbb7e750">
        <updating/>
        <source>setFromCopy(_copy : CM_Product; _operator : CM_Operator) updating;
// ---------------------------------------------------------------------------
// Created:     
//
// Purpose:     
// 
// Changed		Who			Why
// ----------   ----------  --------------------------------------------------
// 30/11/2009	cnwdap1		CCMS 1007 - reefer indicators
vars

begin
	self.myCargoType 				:=	_copy.myCargoType;
	self.myCargoTypeExtBreakBulkGen	:=	_copy.myCargoType.myCargoExtension.CM_CargoTypeExtBreakBulkGen;
	self.myOperator					:=	_operator;
	self.myProductGroup				:=	_copy.myProductGroup;
	self.myHandlingType				:=	_copy.myHandlingType;
	self.myHandlingSubType 			:=	_copy.myHandlingSubType;	//31 Mar 2017	NDL	TFS 3414

	if _copy.myDensityDec &lt;&gt; null then								// ### TFS 52193 22Nov2021 NAVPW1
		self.myDensityDec := _copy.myDensityDec.cloneSelf(false);	// ### TFS 52193 22Nov2021 NAVPW1
		self.myDensityDec.setFromCopy(_copy.myDensityDec);			// ### TFS 52193 22Nov2021 NAVPW1
	else
		create self.myDensityDec persistent;						// ### TFS 52193 22Nov2021 NAVPW1
	endif;

	if _copy.myHeight &lt;&gt; null then
		self.myHeight := _copy.myHeight.cloneSelf(false);
		self.myHeight.setFromCopy(_copy.myHeight);
	else
		create self.myHeight.CM_ProdAttrDecimal persistent;
	endif;

	if _copy.myHeightString &lt;&gt; null then
		self.myHeightString := _copy.myHeightString.cloneSelf(false);
		self.myHeightString.setFromCopy(_copy.myHeightString);
	else
		create self.myHeightString persistent;
	endif;

	if _copy.myLength &lt;&gt; null then
		self.myLength := _copy.myLength.cloneSelf(false);
		self.myLength.setFromCopy(_copy.myLength);
	else
		create self.myLength.CM_ProdAttrDecimal persistent;
	endif;
	
	if _copy.myLengthString &lt;&gt; null then
		self.myLengthString := _copy.myLengthString.cloneSelf(false);
		self.myLengthString.setFromCopy(_copy.myLengthString);
	else
		create self.myLengthString persistent;
	endif;

	if _copy.myQuantity &lt;&gt; null then
		self.myQuantity := _copy.myQuantity.cloneSelf(false);
		self.myQuantity.setFromCopy(_copy.myQuantity);
	else
		create self.myQuantity persistent;
	endif;

	if _copy.myType &lt;&gt; null then
		self.myType := _copy.myType.cloneSelf(false);
		self.myType.setFromCopy(_copy.myType);
	else
		create self.myType persistent;
	endif;

	if _copy.myVolume &lt;&gt; null then
		self.myVolume := _copy.myVolume.cloneSelf(false);
		self.myVolume.setFromCopy(_copy.myVolume);
	else
		create self.myVolume persistent;
	endif;

	if _copy.myWeight &lt;&gt; null then
		self.myWeight := _copy.myWeight.cloneSelf(false);
		self.myWeight.setFromCopy(_copy.myWeight);
	else
		create self.myWeight.CM_ProdAttrDecimal persistent;
	endif;

	if _copy.myWidth &lt;&gt; null then
		self.myWidth := _copy.myWidth.cloneSelf(false);
		self.myWidth.setFromCopy(_copy.myWidth);
	else
		create self.myWidth.CM_ProdAttrDecimal persistent;
	endif;

	if _copy.myWidthString &lt;&gt; null then
		self.myWidthString := _copy.myWidthString.cloneSelf(false);
		self.myWidthString.setFromCopy(_copy.myWidthString);
	else
		create self.myWidthString persistent;
	endif;
	
	// CCMS 1007
	self.isReefer		:= _copy.isReefer;
	self.isPowered		:= _copy.isPowered;
	self.isIntegral		:= _copy.isIntegral;
	self.isFan			:= _copy.isFan;

end;</source>
        <Parameter name="_copy" type="CM_Product"/>
        <Parameter name="_operator" type="CM_Operator"/>
    </JadeMethod>
