    <JadeMethod name="doEnqTrackedItem" id="cb45853c-3e11-42c2-99b6-cdfeff5aef7b">
        <updating/>
        <source>doEnqTrackedItem() protected, updating;
/*

Date		Who		Reason
16 Jan 2006	cnwdvb1	Created
05 Mar 2008	cnwkpd1	PAR #16010 - CCMS Otago 1502 - Thin Client RT Enhancements

*/

vars
	tiId,
	errorStr		: String;
	
begin
	self.tableEnqInitialize();
	self.tableToDoInitialize();
	self.tableGradeInitialize();
	tiId	:=	self.txtContainerID.text.trimRight();
	
	if app.myRTGuiAgent.enqTrackedItem(self, tiId, errorStr, self.aState) then
		self.aIsSaveRequired	:=	false;
		self.updateFromState();
	else
		self.showMessage(errorStr, true);
	endif;
	
	self.setEnquiryScrollButtons();		// PAR #16010
	
	return;
end;</source>
