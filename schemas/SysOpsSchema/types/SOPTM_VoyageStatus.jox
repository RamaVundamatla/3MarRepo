    <JadeMethod name="create" id="ff9def5e-acab-4ac3-867c-817c98be0fd7">
        <updating/>
        <source>create() updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 07/03/2018	jlgdap1		Initial creation TFS 37427 PEL1 Voyage Status Enhancements
//
vars

begin
	self.name				:=	SOP_TableMaintForm.Table_VoyageStatus;
	self.permissionView		:=	PmAdmVoyageStatusView;
	self.permissionMaint	:=	PmAdmVoyageStatusMaint;
	self.myDataClass		:=	CM_VoyageStatus;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doSave" id="000f6f7e-8bbe-4bb3-a9ff-14f903995ad1">
        <updating/>
        <source>doSave(): Boolean updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 08/03/2018	jlgdap1		Initial creation TFS 37427 PEL1 Voyage Status Enhancements
// 11/10/2021 	jlier1		TFS 51963
vars
	pxyStatus : CM_VoyageStatus;
	form : SOP_TableMaintForm;
	description : String;
	emailTemplate : CM_EmailTemplate;
	reportToRun : String;	//05 Jun 2018	NDL	TFS 38905
	autoApplyStatus : Boolean;
begin
	form := self.myForm;
	description := form.tblInput1.getValueByName(ETRow_Description).String;
	reportToRun := form.tblInput1.getValueByName(ETRow_ReportToRun).String;	//05 Jun 2018	NDL	TFS 38905
	if form.tblInput1.isRowVisible(ETRow_AutoApplyStatus) then
		autoApplyStatus :=form.tblInput1.getValueByName(ETRow_AutoApplyStatus).Boolean;
	endif;
	// Add is not valid for these items, so we only need to worry about Edit
	if form.myProxyObject = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Proxy object is null for update');
		return false;
	endif;
	
	pxyStatus := form.myProxyObject.CM_VoyageStatus;
	// the proxy's allowed event types and hms resources haved already been set 
	pxyStatus.setProxy(pxyStatus.id, pxyStatus.priority, description, pxyStatus.myProcess, emailTemplate, reportToRun,autoApplyStatus);
	app.myTrxUA.trxUpdateVoyageStatus(pxyStatus, app.myPassport);
	
	return app.myPassport.trxCompletedOK;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doShowEmailForm" id="404d49c6-5f7e-4cd2-bbc0-93e795c943f9">
        <source>doShowEmailForm();
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 09/03/2018	jlgdap1		Initial creation TFS 37427 PEL1 Voyage Status Enhancements
// 19/03/2018	jlgdap1		TFS 37540 PEl1 Voyage Statuses Pelindo 1
//
vars
	form : SOP_TableMaintForm;
	status, pxyStatus : CM_VoyageStatus;
	emailDefault, pxyEmailDefaults : CM_VoyStatusDefaultEmail;
	emailAdding : Boolean;
	pxyEmailTemplate, oldTemplate : CM_EmailTemplate;
	modalResult : Integer;
	loadState : Boolean;					// TFS 37540

begin
	form := self.myForm;
	status := form.myCurrentObject.CM_VoyageStatus;
	pxyStatus := form.myProxyObject.CM_VoyageStatus;
	if status.myEmailTemplate = null then
		
		emailDefault := app.myRoot.allVoyStatusDefaultEmails[PINEmail_VoyagePendingStatus + status.id];
		
		//08/08/2024	navkc1 Bug 65499 - If we already have a proxy template, use it instead of creating a new proxy;
		if pxyStatus.myEmailTemplate &lt;&gt; null then
			pxyEmailTemplate := pxyStatus.myEmailTemplate;
		else
			emailAdding := true;
			pxyEmailTemplate := pxyStatus.createPxyEmailTemplate();
		endif;
		
	else
		app.cmsBeginLoad(loadState);											// TFS 37540
		pxyEmailTemplate := pxyStatus.myEmailTemplate.pxyCreateUpdateProxy();	// TFS 37540
		app.cmsEndLoad(loadState);												// TFS 37540
		emailDefault := app.myRoot.allVoyStatusDefaultEmails[status.myEmailTemplate.type];
	endif;
	
	pxyEmailDefaults := emailDefault.cloneSelf(true).CM_VoyStatusDefaultEmail;
	
	if not emailAdding then	// there is some email info saved on voyage status before
		pxyEmailDefaults.setFromEmailTemplate(pxyEmailTemplate);	//prepare self.myEmailDefaults from persistent stored email template
		pxyEmailDefaults.setAddressees(pxyEmailTemplate.bccAddresses, pxyEmailTemplate.ccAddresses, pxyEmailTemplate.toAddresses);
		pxyEmailDefaults.setSendtoOperatorCargo( pxyEmailTemplate.sendtoOperatorCargo );	//24 Apr 2018	NDL TFS 39198
		pxyEmailDefaults.setSendtoOperatorVoyage( pxyEmailTemplate.sendtoOperatorVoyage );	//24 Apr 2018	NDL TFS 39198
		pxyEmailDefaults.setSendToOperatorCargoReqs( pxyEmailTemplate.sendToOperatorCargoReqs );	//15 Oct 2018	NDL	TFS 41387
	endif;
	
	modalResult := form.myAssistant.showVoyageStatusEmailOptions(pxyEmailDefaults, false);
	
	if modalResult = IDOK then
		pxyEmailTemplate.setFromObjectEmail(pxyEmailDefaults);	//saving email info on the voyage status
		oldTemplate := pxyStatus.myEmailTemplate;
		if oldTemplate &lt;&gt; pxyEmailTemplate then
			delete oldTemplate;
		endif;
		pxyEmailTemplate.setMyParent(pxyStatus);
		if pxyEmailTemplate.canBeDeletedForVoyageStatus then
			pxyEmailTemplate.setMyParent(null);
			delete pxyEmailTemplate;
		endif;
	endif;
	
epilog
	if modalResult &lt;&gt; IDOK then
		delete pxyEmailTemplate;
	endif;
	delete pxyEmailDefaults;
	if loadState then						// TFS 37540
		app.cmsEndLoad(loadState);			// TFS 37540
	endif;									// TFS 37540
end;</source>
    </JadeMethod>
    <JadeMethod name="doShowEventSelectForm" id="bf85c907-9f9c-400b-bb0e-0e0b15c73b5b">
        <source>doShowEventSelectForm();
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 12/03/2018	jlgdap1		Initial creation TFS 37427 PEL1 Voyage Status Enhancements
//
vars
	form : SOP_TableMaintForm;
	allSelectedEvents, allVoyageEvents : CM_EventTypeByNameDict;
	event : CM_EventType;

begin
	form := self.myForm;
	create allSelectedEvents transient;
	create allVoyageEvents transient;
	
	form.myProxyObject.CM_VoyageStatus.allEventsToCreate.copy(allSelectedEvents);
	
	foreach event in app.myRoot.allEventTypesByType discreteLock where event.category = CM_EventType.VOYAGE_EVENT do
		allVoyageEvents.add(event);
	endforeach;
	if form.myAssistant.showMultiSelectForm(app.getErrorString(Event_Types), allVoyageEvents, allSelectedEvents, true,false,null) = IDOK then
		form.myProxyObject.CM_VoyageStatus.setPxyEventsToCreate(allSelectedEvents);
	endif;
	
epilog
	delete allSelectedEvents;
	delete allVoyageEvents;
end;</source>
    </JadeMethod>
    <JadeMethod name="doShowHMSSelectAppForm" id="e035536c-4c62-4fd3-bbd1-c724b81b038f">
        <source>doShowHMSSelectAppForm();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 August 2018	jlgndl1	Initial creation	TFS 39900

*/

vars
	form : SOP_TableMaintForm;
	allSelectedResources, allResources : HMS_ResourceByTypeDict;
	resource : HMS_Resource;
	harbour : HMS_Harbour;

begin
	form := self.myForm;
	create allSelectedResources transient;
	create allResources transient;
	form.myProxyObject.CM_VoyageStatus.allHMSResourcesApproval.copy(allSelectedResources);
	
	foreach harbour in app.myRoot.allHarbours discreteLock do
		foreach resource in harbour.allResources discreteLock where not resource.isNotAvailableForEntry do
			if resource.myResourceType = null then
				continue;
			endif;
			if resource.myResourceType.isMarineService then
				continue;
			endif;
			allResources.add(resource);
		endforeach;
	endforeach;
	
	if form.myAssistant.showMultiSelectForm(app.getErrorString(Resources_approval), allResources, allSelectedResources, true,false,null) = IDOK then
		form.myProxyObject.CM_VoyageStatus.setPxyHMSResourcesForApp(allSelectedResources);
	endif;
	
epilog
	delete allSelectedResources;
end;</source>
    </JadeMethod>
    <JadeMethod name="doShowHMSSelectEstForm" id="7cbcef11-9b24-4774-b3fe-6e1463f9b504">
        <source>doShowHMSSelectEstForm();
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 12 March 2018	jlgdap1		Initial creation TFS 
//
vars
	form : SOP_TableMaintForm;
	allSelectedResources, allResources : HMS_ResourceByTypeDict;
	resource : HMS_Resource;
	harbour : HMS_Harbour;

begin
	form := self.myForm;
	create allSelectedResources transient;
	create allResources transient;
	form.myProxyObject.CM_VoyageStatus.allHMSResourcesAllowed.copy(allSelectedResources);
	
	foreach harbour in app.myRoot.allHarbours discreteLock do
		foreach resource in harbour.allResources discreteLock where not resource.isNotAvailableForEntry do
			if resource.myResourceType = null then
				continue;
			endif;
			if resource.myResourceType.isMarineService then
				continue;
			endif;
			allResources.add(resource);
		endforeach;
	endforeach;
	
	if form.myAssistant.showMultiSelectForm(app.getErrorString(Resources_estimate), allResources, allSelectedResources, true,false,null) = IDOK then
		form.myProxyObject.CM_VoyageStatus.setPxyHMSResourcesForEst(allSelectedResources);
	endif;
	
epilog
	delete allSelectedResources;
end;</source>
    </JadeMethod>
