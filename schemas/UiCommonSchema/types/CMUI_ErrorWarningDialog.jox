    <JadeMethod name="doMnuCopyToClipboard" id="3a5be398-e3c8-4aff-b207-dd925c13eaa6">
        <source>doMnuCopyToClipboard() protected;

/*

Purpose:		This method will copy the error/warning message(s) to the clipboard.
				If 1 or more lines are selected (highlighted) then only those
				are copied else the whole table.
	
Date				Who		Reason
29 May 2009	cnwrl1/cnwam1	Initial creation

*/
	
vars
	bSomeSelected	: Boolean;
	index			: Integer;
	startRow		: Integer;
	maxRow			: Integer;
	str				: String;
	table			: Table;
	
begin
	table		:= tblData;
	startRow	:= table.fixedRows + 1;
	maxRow		:= table.rows;
	
	// check if any row(s) have been selected.
	bSomeSelected	:= table.getSelectedRowCount &gt;= 1;
	foreach index in startRow to maxRow do
		if bSomeSelected and not table.getCellSelected( index, 1 ) then
			continue;
		endif;
		if str = null then
			str	:= table.getCellText( index, 1 );
		else
			str	:= str &amp; CrLf &amp; table.getCellText( index, 1 );
		endif;
	endforeach;
	
	app.copyStringToClipboard( str );
	
epilog
	
end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="init" id="6827537c-2db4-41ec-9c7b-2bddc4620d25">
        <updating/>
        <source>init(_heading : String; _passport : CM_Passport; _mode : Integer) updating;
// ---------------------------------------------------------------------------
// Created:     28 January 2003 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	err			: CM_Error;
	count		: Integer;
	rowNo,
	cellHeight	: Integer;
	tblRow		: JadeTableRow;
	tmpStr		: String;
	onlyShowErrors : Boolean;
	maxTextWidth : Integer;
begin

	self.mode 			:= _mode;
	self.hasErrors		:= (not _passport.allErrors.isEmpty);
	self.hasWarnings	:= (not _passport.allWarnings.isEmpty);
	maxTextWidth 		:= tblData.width.Integer - 16; // to allow for the scroll bar
	
	onlyShowErrors := not _passport.errorsToIgnore.isEmpty(); // PAR 17703 AKB2008SEP
	
	self.setHeadings(_heading);
	
	// load of Milaha transaction map got more than 32000 errors - limit here
	foreach err in _passport.allErrors do
	
		// PAR 17703 AKB2008SEP
		if onlyShowErrors then
			if _passport.errorsToIgnore.includes(err.errorCode) then
				continue;
			endif;
		endif;
		
		count := count + 1;
		if count &gt; 31999 then
			app.msgBox("Only the first 32000 errors shown", "Too many errors", 0);
			break;
		endif;
		tblData.fitTextToCell(err.text, tmpStr, maxTextWidth, cellHeight);
		rowNo := tblData.addItemObject(err,tmpStr); // NAVAB1 23OCT12 // ### TFS CR 60424 TASK 60549 12OCT2023 NAVAB1
		tblRow := tblData.accessRow(rowNo);
		tblRow.foreColor := Red;
		tblRow.height := cellHeight;
	endforeach;

	
	if not onlyShowErrors then // PAR 17703 AKB2008SEP
		foreach err in _passport.allWarnings do
			count := count + 1;
			if count &gt; 31999 then
				app.msgBox("Only the first 32000 errors and warnings shown", "Too many errors", 0);
				break;
			endif;
			tblData.fitTextToCell(err.text, tmpStr, maxTextWidth, cellHeight);
			rowNo := tblData.addItemObject(err,tmpStr); // NAVAB1 23OCT12 // ### TFS CR 60424 TASK 60549 12OCT2023 NAVAB1
			tblRow := tblData.accessRow(rowNo);
			tblRow.foreColor := Blue;
			tblRow.height := cellHeight;
		endforeach;
	endif;
	
	tblData.stretchHeight	:= true;
	tblData.stretchWidth	:= true;
	
	self.savePointer := app.mousePointer;
	app.mousePointer := MousePointer_Default;

end;</source>
        <Parameter name="_heading" type="String"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <Parameter name="_mode" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="initWithoutPassport" id="1844b70a-bfe1-48e1-9812-01451fae6e18">
        <updating/>
        <source>initWithoutPassport(_heading : String; _allErrors:HugeStringArray; _allWarnings:HugeStringArray; _mode : Integer) updating;
// --------------------------------------------------------------------------------
// Created:		17 January 2008 by cnwdad1
//
// Purpose:		Initializes the receiver using string arrays rather than Passport
//				errors/warnings.
//
// Parameters:	_heading - The heading for the dialog form.
//				_errors - An array of error messages.
//				_warnings - An array of warning messages.
//				_mode - The mode of the error/warning form.
//
//				Mode	= ErrWarnMode_Update
//						= ErrWarnMode_AddUpdate
//						= ErrWarnMode_Add + ErrWarnMode_CanAckWarnings
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 15/10/2008	CONCMS1		CCMS 1035 - use mode to decide isNontransaction value
// --------------------------------------------------------------------------------
vars
	tableObj		: CM_BaseTable;
	errorMsg		: String;
	rowNum			: Integer;
	cellHeight		: Integer;
	rowObj			: JadeTableRow;
	displayValue	: String;
	
begin 
	self.mode 				:=	_mode; 
	
	self.isNonTransaction	:=	not _mode.bitAnd(ErrWarnMode_Add).Boolean and			// concms1 15/10/2008
								not _mode.bitAnd(ErrWarnMode_AddUpdate).Boolean and		// concms1 15/10/2008
								not _mode.bitAnd(ErrWarnMode_Update).Boolean and		// concms1 15/10/2008
								not _mode.bitAnd(ErrWarnMode_Delete).Boolean ;		// concms1 15/10/2008
	
	tableObj				:=	self.tblData;
	
	if _allErrors &lt;&gt; null then
		self.hasErrors		:=	not _allErrors.isEmpty();
		
		foreach errorMsg in _allErrors do
			tableObj.fitTextToCell(errorMsg, displayValue, tableObj.width.Integer, cellHeight);
			rowNum	:=	tableObj.addItem(displayValue);
			rowObj	:=	tableObj.accessRow(rowNum);
			rowObj.foreColor	:=	Red;
			rowObj.height		:=	cellHeight;
		endforeach;
	endif;
	
	if _allWarnings &lt;&gt; null then
		self.hasWarnings	:=	not _allWarnings.isEmpty();
		
		foreach errorMsg in _allWarnings do
			tableObj.fitTextToCell(errorMsg, displayValue, tableObj.width.Integer, cellHeight);
			rowNum	:=	tableObj.addItem(displayValue);
			rowObj	:=	tableObj.accessRow(rowNum);
			rowObj.foreColor	:=	Blue;
			rowObj.height		:=	cellHeight;
		endforeach;
	endif;
	
	tableObj.stretchHeight	:= true;
	tableObj.stretchWidth	:= true;
	
	self.setHeadings(_heading);
	
	self.savePointer	:=	app.mousePointer;
	app.mousePointer	:=	Idle;
end;</source>
        <Parameter name="_heading" type="String"/>
        <Parameter name="_allErrors" type="HugeStringArray"/>
        <Parameter name="_allWarnings" type="HugeStringArray"/>
        <Parameter name="_mode" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="isModeDelete" id="2bc324a9-880e-4fda-a1b5-95ced92527ac">
        <methodInvocation>mapping</methodInvocation>
        <source>isModeDelete(set: Boolean; _value: Boolean io) mapping;
// ---------------------------------------------------------------------------
// Created:     04 February 2003 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
