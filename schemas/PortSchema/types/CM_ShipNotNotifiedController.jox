    <JadeMethod name="getQueues" id="ecb44b59-9e98-4ce5-b3ef-e8b4238a0c7d">
        <source>getQueues(_queueSet: CM_RTQueueSet io);
/*

Date		Who		Reason
05 June 2015	cnwer1	Initial creation PAR 36261 just return the voyage queue

*/

vars
begin

	_queueSet.clear;
	if self.myVoyage.myQueue &lt;&gt; null then
		_queueSet.add(self.myVoyage.myQueue);
	endif;	

epilog

end;</source>
        <Parameter name="_queueSet" type="CM_RTQueueSet" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getTiTxnTypesForMoveFromToNULL" id="b780f40e-7f21-4c6f-8f09-4ed97261698b">
        <source>getTiTxnTypesForMoveFromToNULL(_moveController: CMIF_MoveController; _intArray: IntegerArray input);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 September 2011	cnwndl1	Initial creation	Par 28173

*/

vars

begin

	inheritMethod(_moveController, _intArray);
		return; //epr par 34837 1/9/14 will be done in CM_VoyageController
//	if not self.myVoyage.isNonPlannedVoyage and not self.myVoyage.isNonWorkedVoyage then
		// because otherwise it has already been done in the super class
		_intArray.add(TRANS_TYPE_REC_SHIP);
		app.addTiTxnSubTerminalReceive(_moveController.myTrackedItem, TI_TRANSMODE_SHIP, _intArray);
		
		_intArray.add(TRANS_TYPE_WHARFAGE);
	
		app.addTiTxnSubTerminalRelease(_moveController.myTrackedItem, TI_TRANSMODE_ROAD, _intArray);	// PAR 20706 (swap order)
		_intArray.add(TRANS_TYPE_REL_ROAD);	
//	endif;
	

epilog

end;</source>
        <Parameter name="_moveController" type="CMIF_MoveController"/>
        <Parameter name="_intArray" type="IntegerArray" usage="input"/>
    </JadeMethod>
</Class>
