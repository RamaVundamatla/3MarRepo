    <JadeMethod name="doApplyVehicleMountedColours" id="332b93a3-db0d-4d0c-ad6f-29e3f41c066d">
        <updating/>
        <source>doApplyVehicleMountedColours(): Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 May 2010	cnwer1	Initial creation

*/

vars
	backColorGen	: Integer;
	foreColorGen	: Integer;
	backColorTable	: Integer;
	foreColorTable	: Integer;
	numControls		: Integer;
	controlIndex	: Integer;
	controlObj		: Control;
	rtScreenMode	: CM_RTScreenConfig;
begin
	if app.myVMAgent = null then
		return false;
	endif;
	rtScreenMode:=app.myVMAgent.getMyScreenMode;
	if rtScreenMode = null then
		return false;
	endif;
	backColorGen	:=	rtScreenMode.screenBackColour;
	backColorTable	:=	rtScreenMode.tableBackColour;
	foreColorGen	:=	rtScreenMode.screenForeColour;
	foreColorTable	:=	rtScreenMode.tableForeColour;
	numControls		:=	self.controlCount();
	
	foreach controlIndex in 1 to numControls do
		controlObj	:=	self.controls(controlIndex);		
		
		if controlObj.isKindOf(Label)
		or controlObj.isKindOf(Sheet) 
		or	controlObj.isKindOf(Button) 
		or controlObj.isKindOf(GroupBox) 
		or  controlObj.isKindOf(OptionButton) 
		or 	controlObj.isKindOf(CheckBox)then
			controlObj.setBackForeColor(backColorGen, foreColorGen);
			
		elseif controlObj.isKindOf(Table) then
			if controlObj = self.tblF1Help then
				controlObj.setBackForeColor(backColorGen, foreColorGen);
			else
				controlObj.setBackForeColor(backColorTable, foreColorTable);
			endif;
		elseif controlObj.isKindOf(TextBox)or controlObj.isKindOf(ComboBox) then
			controlObj.borderStyle:=TextBox.BorderStyle_Single;
			controlObj.borderColorSingle:=controlObj.getSystemColor(Control.Color_3DFace);
			controlObj.foreColor:=foreColorGen;
			controlObj.backColor:=backColorTable;
		elseif controlObj.isKindOf(Folder) then
			controlObj.backColor:=backColorGen;
			controlObj.Folder.tabActiveColor := backColorGen;
			controlObj.Folder.tabInactiveColor := backColorGen;
			controlObj.foreColor:=foreColorGen;
		elseif controlObj.isKindOf(Frame) then
			controlObj.borderStyle:=TextBox.BorderStyle_Single;
			controlObj.borderColorSingle:=controlObj.getSystemColor(Control.Color_3DFace);
			controlObj.setBackForeColor(backColorGen, foreColorGen);
		elseif controlObj.isKindOf(JadeDockBase) then
			controlObj.backColor:=backColorGen;
			controlObj.foreColor:=foreColorGen;
		endif;
		
		
		controlObj.fontSize:=app.myVMAgent.getMyRTVehicleConfig.tableFontSize;
		controlObj.fontName:="Tahoma";
	endforeach;		
	
	self.backColor := backColorGen;
	
	return true;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doKeyDown" id="d7a4fe44-c440-4216-9b26-1d4ef42f7509">
        <updating/>
        <source>doKeyDown(keyCode: Integer io; shift: Integer) updating;
/*
	Created on 11 April 2008
	
	by Debby Hutchison
	
	Purpose:
	
	Note see registerKeyCodes for list of keys that we actually get.
*/

vars

begin
	if keyCode = J_key_F1 then
		handleF1Key;
	elseif keyCode = J_key_F2 then
		handleF2Key;
	elseif keyCode = J_key_F3 then
		handleF3Key;
	elseif keyCode = J_key_F4 then
		handleF4Key;
	elseif keyCode = J_key_F5 then
		handleF5Key;
	elseif keyCode = J_key_F6 then
		handleF6Key;
	elseif keyCode = J_key_F7 then
		handleF7Key;
	elseif keyCode = J_key_F8 then
		handleF8Key;
	elseif keyCode = J_key_F9 then
		handleF9Key;
	elseif keyCode = J_key_F10 then
		handleF10Key;
	elseif keyCode = J_key_F11 then
		self.handleF11Key();
	elseif keyCode = J_key_Delete then
		handleDeleteKey;	
	
	elseif keyCode = J_key_F12 then
		if (app.isSpecial() or app.isDevelopmentSystem()) and shift.cnEcIsCtrlKey() then
			if shift.cnEcIsShiftKey() then
				self.cnEcShowContents();
			else
				self.cnEcShowGuiInfo();
			endif;
		endif;
	endif;
end;</source>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doParseLocationString" id="3c54c708-1bea-435a-af40-cd9f3c483eda">
        <updating/>
        <source>doParseLocationString(	pLocationString:String;
						pIsSortForIn:Boolean;
						pProxyYAObj:CM_YardAllocation;
						pAllBlockGroupsIn:CM_YABlockGroupArray input;
						pAllBlockGroupsOut:CM_YABlockGroupArray input):Boolean updating, protected;
// --------------------------------------------------------------------------------
// Created:		08 May 2008 by cnwdad1
//
// Purpose:		Using the location(s) string entered by the user, add one or more
//				locations to a new default YA Block.
//
// The location string can contain the following:
//
//	A 1102-1206; D 1102, 1420, 2306
//
// ...where different areas are separated with a semi-colon.  Locations within an
// Area can be entered as a range (separated by a hyphen), or as a list (separated
// by a colon).
//
// Parameters:	pLocationString - A string of location Ids to parse.
//				pIsSortForIn - True if the new locations are to be sorted for "IN"
//				pProxyYAObj - A reference to the proxy Yard Allocation object.
//				pAllBlockGroupsIn - A reference to an array of Block Groups "IN".
//				pAllBlockGroupsOut - A reference to an array of Block Groups "OUT".
//
// Returns:		True if the location is successfully parsed, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 02/07/2014	cnwdap1		PAR #34488 Rejig code because of changes in MOB_AllocateStorageForm::doSave
//							parserObj already has block groups, so we need to manually remove and add
// --------------------------------------------------------------------------------
vars
	parserObj				: CM_YAParser;
	blockGroupObj			: CM_YABlockGroup;
	targetLocation			: String;
	block					: CM_YABlock;									// PAR #34488
	
begin
	targetLocation	:=	pLocationString;
	
	if targetLocation = null then
		app.setContinueCMExceptions(false);
		app.raiseCMException1(ERR_INVALID_LOCN_YA, "Please enter the location to add.", null, null);
		
		return false;
	endif;
	
	create parserObj transient;
	
	// Note that the Blocks always belong to at least one (default) Block Group.
	create blockGroupObj transient;
	blockGroupObj.setDescription(pProxyYAObj.getNextBlockGroupDescription());
	
	// Ok, now parse the location string.
	
	if parserObj.parseLocations(pProxyYAObj, targetLocation) then
		//parserObj.allYABlocksIn.copy(blockGroupObj.allYABlocksIn);		// PAR #34488
		//parserObj.allYABlocksOut.copy(blockGroupObj.allYABlocksOut);		// PAR #34488
		foreach block in parserObj.allYABlocksIn do							// PAR #34488
			block.myYABlockGroupIn.allYABlocksIn.remove(block);				// PAR #34488
			blockGroupObj.allYABlocksIn.add(block);							// PAR #34488
		endforeach;															// PAR #34488
		foreach block in parserObj.allYABlocksOut do						// PAR #34488
			block.myYABlockGroupOut.allYABlocksOut.remove(block);			// PAR #34488
			blockGroupObj.allYABlocksOut.add(block);						// PAR #34488
		endforeach;															// PAR #34488
		pAllBlockGroupsIn.add(blockGroupObj);
		pAllBlockGroupsOut.add(blockGroupObj);
		
		return true;
	else
		app.msgBox(parserObj.errorMessage, "Error", MsgBox_Exclamation_Mark_Icon + MsgBox_OK_Only);
		return false;
	endif;
epilog
	delete parserObj;
end;</source>
        <access>protected</access>
        <Parameter name="pLocationString" type="String"/>
        <Parameter name="pIsSortForIn" type="Boolean"/>
        <Parameter name="pProxyYAObj" type="CM_YardAllocation"/>
        <Parameter name="pAllBlockGroupsIn" type="CM_YABlockGroupArray" usage="input"/>
        <Parameter name="pAllBlockGroupsOut" type="CM_YABlockGroupArray" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doTerminate" id="044e734a-fb9d-482a-a7f1-def0a0f9e536">
        <updating/>
        <source>doTerminate()updating;
/*
	Created on 02 April 2008
	
	by Debby Hutchison
	
	Purpose:
*/

vars

begin
	if app.msgBox(app.getErrorString(Terminate), app.getErrorString(Terminate), MsgBox_Question_Mark_Icon + MsgBox_Yes_No) = MsgBox_Return_Yes then
		self.unloadForm();
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="enableAllControls" id="ab78009c-36ba-4995-b3c8-f0b1b1458050">
        <source>enableAllControls();

/*

Purpose: 

Parameters:			

Return Value:		


Date		Who		Reason
09 July 2010	cnwrd1	Initial creation

*/

vars
	intCntrl : Integer;
	cntrl : Control;
	txtBox : TextBox;
	cmbBox : ComboBox;
	chkBox : CheckBox;
	button : Button;
	table  : Table;
	frame : Frame;
begin

	intCntrl := 1;

	while intCntrl &lt;= controlCount do
	
		cntrl := controls(intCntrl);
		
		if cntrl.isKindOf( TextBox ) then
			txtBox := cntrl.TextBox;
			txtBox.readOnly := false;
		elseif cntrl.isKindOf( ComboBox ) then
			cmbBox := cntrl.ComboBox;
			cmbBox.enabled := true;
		elseif cntrl.isKindOf( CheckBox ) then			
			chkBox := cntrl.CheckBox;
			chkBox.enabled := true;
		elseif cntrl.isKindOf( Button ) then
			button := cntrl.Button;
			button.enabled := true;			
		elseif cntrl.isKindOf( Table ) then
			table := cntrl.Table;
			table.enabled := true;			
		elseif cntrl.isKindOf( Frame ) then
			frame := cntrl.Frame;
			frame.enabled := true;					
		endif;
	intCntrl := intCntrl + 1;
	endwhile;
	
epilog

end;</source>
    </JadeMethod>
