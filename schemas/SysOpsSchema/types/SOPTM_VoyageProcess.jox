    <JadeMethod name="doSave" id="272c3e18-ed6f-4f15-a33d-5857d8c68e3c">
        <updating/>
        <source>doSave(): Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 May 2018	jlgndl1	Initial creation	TFS 38517

*/

vars

	proxy : CM_VoyageProcess;
	form : SOP_TableMaintForm;

begin
	
	form := self.myForm;
	
	// Add is not valid for these items, so we only need to worry about Edit
	if form.myProxyObject = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Proxy object is null for update');
		return false;
	endif;
	
	proxy := form.myProxyObject.CM_VoyageProcess;
	proxy.setDescription( form.tblInput1.getValueByName(ETRow_Description).String );
	proxy.setReportNames(	form.tblInput1.getValueByName(ETRow_EdiPrenoteFormat).String,	//_ediPrenoteFormat : String;
							form.tblInput1.getValueByName(ETRow_ReportInvoiceEstimate).String,	//_reportInvoiceEstimate : String;
							form.tblInput1.getValueByName(ETRow_ReportInvoicePreinvoice).String,	//_reportInvoicePreinvoice : String;
							form.tblInput1.getValueByName(ETRow_ReportInvoiceTaxinvoice).String,	//_reportInvoiceTaxinvoice : String
							form.tblInput1.getValueByName(ETRow_WorkOrderReceivalReport).String,//_workOrderReceivalReport,	//_workOrderReceiveReport : String;
							form.tblInput1.getValueByName(ETRow_WorkOrderReleaseReport).String//_workOrderReleaseReport	//_workOrderReleaseReport : String
							);
	

	app.myTrxUA.trxUpdateVoyageProcess(proxy, app.myPassport);
	
	return app.myPassport.trxCompletedOK;
		

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doShowAddReportsForm" id="dca0a74d-ba4d-4a9b-aa15-0d27a36cd216">
        <source>doShowAddReportsForm( _parent : CM_BaseForm; _voyageProcess : CM_VoyageProcess );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 February 2019	jlgndl1	Initial creation	TFS 43240

*/

vars

	form : CMUI_AdditionalReportsForm;
	str : String;

begin

	create form transient;
	form.setMyVoyageProcess( _voyageProcess, self.allReportNamesByView );
	
	form.showModal;
	
	//refresh the lines in case we changed the number of reports configured...
	str := self.myForm.tblDataDisplayRow(self.myForm.tblData, _voyageProcess);
	self.myForm.tblData.setCellText( self.myForm.tblData.row, 1, str );

epilog

end;</source>
        <Parameter name="_parent" type="CM_BaseForm"/>
        <Parameter name="_voyageProcess" type="CM_VoyageProcess"/>
    </JadeMethod>
