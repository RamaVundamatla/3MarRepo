    <JadeMethod name="trxDatabaseAdminUpdate" id="555d7387-240a-47bb-84b3-1fb97bbfb7f6">
        <updating/>
        <source>trxDatabaseAdminUpdate(	pDatabaseAdminObj:CnEcDatabaseAdmin input;
						pRequiredEdition:Integer;
						pBackupDirectory:String;
						pIsIncludeSystemFiles:Boolean;
						pIsVerifyFiles:Boolean;
						pIsCompressFiles:Boolean;
						pIsOverwriteFiles:Boolean;
						pIsQuiesce:Boolean):String updating;
// --------------------------------------------------------------------------------
// Created:		21 July 2001 by cnwdad2
//
// Purpose:		Update a DataBase Admin's details.
//
// Parameters:	The first parameter is the object to be updated.
//              If pRequiredEdition is greater than zero, the method will check that
//              the latest edition of the object is equal to pRequiredEdition. If not
//              then an ObjectOutOfDate error will be returned.
//
//              The remaining parameters are the object properties to update.
//
// Returns:		Null if the transaction is successful, otherwise an error message.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	errorMessage	: String;

begin
	// Initialize the activity first.
	self.agentInitializeActivity();

	// Arm our base exception handlers (local exception handlers which are
	// disarmed when the method returns).
	on Exception do self.agentExceptionHandler(exception);
	on LockException do self.agentLockExceptionHandler(exception);

	errorMessage	:=	self.valDatabaseAdminUpdate(pDatabaseAdminObj,
													pBackupDirectory,
													pIsIncludeSystemFiles,
													pIsVerifyFiles,
													pIsCompressFiles,
													pIsOverwriteFiles,
													pIsQuiesce);

	if errorMessage &lt;&gt; null then
		return errorMessage;
	endif;

	// If the object is invalid, we want our exception handler to return the specified error.
	self.agentRegisterObjectAndError(pDatabaseAdminObj, "The Database Administration being updated is either null or is not valid.");

	beginTransaction;

	// Exclusive transaction lock to obtain the latest edition of the object and
	// lock it. We need the latest edition to check it against requiredEdition.
	// This lock be released automatically at the next commit/abort transaction.
	// We obtain an exclusive lock (as opposed to a shared lock) as we're about
	// about to update the object, and JADE will automatically try to lock it
	// exclusively (if we don't already have it) before updating it. Getting an
	// exclusive lock up front avoids JADE having to upgrade the lock from shared
	// to exclusive at the point the object is updated.
	exclusiveLock(pDatabaseAdminObj);

	// If the exclusiveLock gets an exception, our handler will resume to here.
	if self.lastError = null and pRequiredEdition &gt; 0 then
		// We obtained the lock, now check the edition.
		if pDatabaseAdminObj.edition() &lt;&gt; pRequiredEdition then
			// The edition has changed, so the object on which the sender based
			// this update is out of date.
			self.agentSetError("The Database Administration has been changed by another process.  Please refresh and try again.");
		endif;
	endif;

	// If we're still error free, perform the operation.
	if self.lastError = null then
		pDatabaseAdminObj.updateMe(	pBackupDirectory,
									pIsIncludeSystemFiles,
									pIsVerifyFiles,
									pIsCompressFiles,
									pIsOverwriteFiles,
									pIsQuiesce);
	endif;

	// If the operation raises an exception, our handler will resume to here.
	if self.lastError = null then
		// No errors, so commit.
		commitTransaction;
	else
		// We got an error so abort the transaction. Although TransactionAgent
		// exception handlers abort the transaction before resuming, we do so
		// here as well for completeness and symmetry with the beginTransaction.
		// An abortTransaction when not in transaction state does nothing.
		abortTransaction;
	endif;
epilog
	// Always return the error code to the caller (which will be zero if no errors).
	return self.lastError;
end;</source>
        <Parameter name="pDatabaseAdminObj" type="CnEcDatabaseAdmin" usage="input"/>
        <Parameter name="pRequiredEdition" type="Integer"/>
        <Parameter name="pBackupDirectory" type="String"/>
        <Parameter name="pIsIncludeSystemFiles" type="Boolean"/>
        <Parameter name="pIsVerifyFiles" type="Boolean"/>
        <Parameter name="pIsCompressFiles" type="Boolean"/>
        <Parameter name="pIsOverwriteFiles" type="Boolean"/>
        <Parameter name="pIsQuiesce" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="valBaseRootLastLogUpdate" id="b8d629e2-4965-4509-b2be-13683d721a3d">
        <updating/>
        <source>valBaseRootLastLogUpdate(pBaseRootObj:CnEcBaseRoot;
						pLastBackedUpLog:Integer):String updating, protected;
// --------------------------------------------------------------------------------
// Created:		21 July 2001 by cnwdad2
//
// Purpose:		Validation for updating BaseRoot with the number of the last backed
//				up log file.
//
// Parameters:	The object's (changeable) properties.
//
// Returns:		Null if the transaction is successful, otherwise an error message.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	// Initialize the activity first.
	self.agentInitializeActivity();

	// Arm our base exception handlers.
	on Exception do self.agentExceptionHandler(exception);
	on LockException do self.agentLockExceptionHandler(exception);

	if pBaseRootObj = null then
		return self.agentSetError("The BaseSchema Root object being updated is either null or is not valid.");
	endif;

	if pLastBackedUpLog = 0 then
		return self.agentSetError("The Log File number name cannot be zero.");
	elseif pLastBackedUpLog &lt;= pBaseRootObj.lastBackedUpLog then
		return self.agentSetError("The new Log File number must be greater than the last Log File [" &amp; pBaseRootObj.lastBackedUpLog.String &amp; "].");
	endif;

	// If object is invalid, we want our handlers to return an invalid object message.
	self.agentRegisterObjectAndError(pBaseRootObj, "The BaseSchema Root object being updated is either null or is not valid.");

	sharedLock(pBaseRootObj);
	
	// If the above operation gets an exception, our handler will resume to here.
	if self.lastError &lt;&gt; null then
		return self.lastError;
	endif;

	return null;
epilog
	// Release our locks in the epilog so that we'll release them even if we exit via an
	// exception. If we don't have an object locked, the unlock does nothing. If we're
	// in transaction state, transaction duration locks won't be released until the next
	// commit or abort transaction (even if we explicitly unlock them). That allows a
	// method to be well behaved and release its locks without having to be aware of the
	// transaction state of the process.
	if pBaseRootObj &lt;&gt; null then
		unlock(pBaseRootObj);
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="pBaseRootObj" type="CnEcBaseRoot"/>
        <Parameter name="pLastBackedUpLog" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
