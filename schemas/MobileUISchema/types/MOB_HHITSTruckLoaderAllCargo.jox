    <JadeMethod name="doBtnLoadClick" id="ad5004a5-85c5-453c-9cf4-c38739ea6402">
        <updating/>
        <source>doBtnLoadClick() : Boolean updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 February 2010	cnwndl1	Initial creation

*/

vars

	ti : CM_TrackedItem;
	targetTerminal : CM_Terminal;
	errMsg : String;
	truck : CM_Vehicle;
	interTermJob : CM_InterTermVehicleJob;
	pProxyInterTermMove : CM_InterTerminalMove;
	pNewInterTermMove   : CM_InterTerminalMove;
	result : Integer;
	
begin
	
	ti := self.getTrackedItem;
	if ti = null then
		self.msgBox(app.getErrorString(No_Cargo_selected), app.getErrorString(Error), MsgBox_OK_Only, true);
		return false;
	endif;
	
	targetTerminal := self.cmbTargetTerm.listObject.CM_Terminal;
	if targetTerminal = null then
		errMsg := app.getErrorString(Target_terminal_required);
		self.msgBox(errMsg, app.getErrorString(Error), MsgBox_OK_Only, true);
		return false;
	endif;
	
	//21 Nov 2014	NDL	Par 35093
	if not self.doValidate( ti ) then
		return false;
	endif;
	
	truck := self.myMobileGenericAgent.myTruck;
	interTermJob := truck.getInterTerminalJob();
		
	// need a trx to create the inter terminal move here
	create pProxyInterTermMove transient;
	pProxyInterTermMove.setProxy(	ti.id,	//_cargoID : String;
									ti.myOperator,	//_operator : CM_Operator;
									ti,	//_sourceTI : CM_TrackedItem;
									self.myMobileGenericAgent.myInterTerminal,	//_sourceTerminal : CM_Terminal;
									targetTerminal,	// _targetTerminal : CM_Terminal;
									truck,	//_sourceVehicle : CM_Vehicle;
									truck.regNumber,	//_vehicleId : String;
									ITT_LOADING,	//_status : Integer;
									interTermJob	//_myInterTermVehicleJob : CM_InterTermVehicleJob
									);
									
	
	
	while true do
		app.myTrxCA.trxCreateInterTerminalMove(pProxyInterTermMove, pNewInterTermMove, app.myPassport); 
		if app.myPassport.trxCompletedOK then
			app.myPassport.clearErrorsWarnings();
			break;
		else
			//If there were warnings, give the user a chance to see them. If there are no errors they may decide to acknowledge
			//them and update anyway.
			result := app.showErrorWarningDialog(app.getErrorString(Load), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and result = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		return false;
	endwhile;
	
	self.gotoForm( MOB_HHITSTruckLoaderAllCargo, true );	// to force complete refresh of form.
	return true;
												


epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
