    <JadeMethod name="createTerminal" id="f747a9ea-dba0-41f3-af15-7a275088a4bf">
        <source>createTerminal();
//12 October 2010	cnwdw1	
//
vars
	term: CM_Terminal;
begin
	// Set yard allocations
	// Create SubTerminals and set defaults
	// Single Gate S_GATE with no pcheck
	// Dual Gate D_GATE with P_IN and P_OUT
	self.deleteTerminal("FOO");
	term := self.addTerminal("FOO terminal", "FOO");
	assertNotNull(term);	
	
end;</source>
    </JadeMethod>
    <JadeMethod name="deleteTerminal" id="0d053e81-4d67-41d1-9bc9-616f3c97bf4c">
        <source>deleteTerminal(_id: String);
//12 October 2010	cnwdw1	
//
vars
	terminal: CM_Terminal;
begin
	terminal := self.getRoot.allTerminals[_id];
	if terminal &lt;&gt;  null then
		beginTransaction;
		delete terminal;
		commitTransaction;
	endif;
end;</source>
        <Parameter name="_id" type="String"/>
    </JadeMethod>
