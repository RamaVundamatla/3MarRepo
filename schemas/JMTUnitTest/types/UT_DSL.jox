    </JadeMethod>
    <JadeMethod name="setTaskStatus" id="13eaa62e-037a-4e6c-9c60-dd2efefde756">
        <source>setTaskStatus(_status: Integer; _queueTask: CM_RTQueueTask input );
//17 December 2010	cnwdw1	
//
vars

begin
	if _queueTask &lt;&gt; null then
		app.myTrxUA.trxUpdateQueueTaskStatus(_queueTask, _status, app.myPassport);
		if app.isGarbageCollectionProcess then
			return;
		endif;
		self.assertNoTrxErrorsOrWarnings();									// 31/10/2012 cnwmh5
