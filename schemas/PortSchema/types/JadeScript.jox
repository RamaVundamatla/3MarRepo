    <JadeMethod name="aaaaaaa" id="14200ccb-9fa2-4078-9c0c-e99df73ea310">
        <source>aaaaaaa();
vars

	httpConn			: JadeHTTPConnection;
	returnVal		: String;
	sendSuccess, statusCodeSuccess		: Boolean;
	jsonDATA, queryInfo : String;
	resultCode : Integer;
		timeoutMS		: Integer;
		bod : Binary;
begin
	create httpConn transient;
	
	// Set timeouts of required
		timeoutMS := 5000;
		httpConn.connectTimeout := timeoutMS;
		httpConn.sendTimeout := timeoutMS;
		httpConn.receiveTimeout := timeoutMS;
	
	jsonDATA :=
'{"allTableData": [{"gkey": 317885213455631,"tableName": "inv_wi","termOid": "2351.52","carrier_locid": "NOHMS210721","carrier_loctype": "VESSEL","che_gkey": 317885247,"est_move_time": 0,"facility_gkey": 3178852,"move_kind": "DSCH","move_stage": "PLANNED","mvhs_carry_che_id": 0,"mvhs_fetch_che_id": 299,"mvhs_put_che_id": 0,"mvhs_t_carry_complete": 0,"mvhs_t_discharge": 0,"mvhs_t_fetch": 0,"mvhs_t_put": 0,"pos_loc_gkey": 0,"uyv_gkey": 0,"work_queue_gkey": 3178852389929,"wq_pkey": 0,}],"facilityGkey": 3178852,"facilityId": "BISH","oid": "2424.13455631","sequenceNumber": "","updateAction": "U","updateTimeStamp": 1629681973952,"updateType": "WLE",}';

	
	
	httpConn.url := "http://127.0.0.1:5052/OpsView/";
	sendSuccess := httpConn.sendRequest("PUT", "Content-Type: application/json", jsonDATA);
	resultCode := httpConn.queryStatusCode();	
	
	bod := httpConn.readBody(1000);
	returnVal := httpConn.responseBody.StringUtf8.String;
//	queryInfo := httpConn.queryInfo();
//	statusCodeSuccess := httpConn.isStatusCodeSuccess();

write httpConn.state;
	write bod;

end;</source>
