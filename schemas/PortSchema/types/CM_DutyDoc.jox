    <JadeMethod name="getDisplayStringForAttribute" id="5301657e-6e8d-42ab-8aaa-6f3830947d0f">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 December 2012	cnwer1	Initial creation HAT 2189

*/

vars

begin
	if _attrName = ETRow_BillNumber then
		return self.id;
	elseif _attrName = ETRow_BillType then
		return self.type;
	elseif _attrName =ETRow_ConsigneeExpiry then
		if self.consigneeExpiryDate &lt;&gt; null then
				return self.consigneeExpiryDate.asStringJMT();
		endif;
		return null;
	elseif _attrName = ETRow_GroupSupervisor then
		return self.groupSuperUserId;
	elseif _attrName = ETRow_DataEntryUser then
		return self.dutyDocUserId;
	elseif _attrName = ETRow_DeliveryExpiry then
		if self.deliveryOrderExpiryDate &lt;&gt; null then
			return self.deliveryOrderExpiryDate.asStringJMT();
		endif;
		return null;
	elseif _attrName = ETRow_Discharge then
		return self.dischargePort;
	elseif _attrName = ETRow_Destination then
		return self.destination;
	elseif _attrName = ETRow_DocInCharge then
		return self.docInChargeUserId;
	elseif _attrName = ETRow_Forwarder then
		return self.forwarder;
	elseif _attrName = ETRow_ForwarderExpiry then
		if self.forwarderExpiryDate &lt;&gt; null then
			return self.forwarderExpiryDate.asStringJMT();
		endif;
		return null;
	elseif _attrName = ETRow_CustomsInspector then
		return self.customsInspectorUser;
	elseif _attrName = ETRow_ReExportNo then
		return self.reExportNumber;
	elseif _attrName = ETRow_SupervisorUser then
		return self.supervisorUserId;
	elseif _attrName = ETRow_Status then
		return self.getStatusString();
	else
		return inheritMethod(_attrName, _short);
	endif;
epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDocInChargeUserDateLocalTZ" id="d7091cb4-5781-4f6c-ba66-e08b18ba30c7">
        <source>getDocInChargeUserDateLocalTZ() : TimeStamp;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 May 2016	cnwns1	Initial creation
