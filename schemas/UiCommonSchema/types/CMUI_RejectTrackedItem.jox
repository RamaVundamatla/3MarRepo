    <JadeMethod name="loadDataForFirstTime" id="7ad847e8-31f2-492a-87b4-65c86922a7a5">
        <updating/>
        <source>loadDataForFirstTime() updating, protected;
// ---------------------------------------------------------------------------
// Created:     30 September 2002 by cnwth2
//
// Purpose:     
//
// ----------   ----------  --------------------------------------------------
vars

begin
	inheritMethod();
	self.optDocket.visible := false;
	self.optLocation.left := self.optDocket.left;
	self.loadReasonRecovery();
	
end;</source>
