    <Constant name="HELP_DESCRIPTION" id="967995f6-a676-4468-bb61-1c9da8059993">
        <constantUsages>
            <GlobalConstant name="CrLf"/>
        </constantUsages>
        <source>"Type a partial container ID in the search box and click the search button to find a Container." &amp; CrLf &amp; CrLf &amp;
"Once a container has been selected, its current location will be displayed under the 'Current Location' label." &amp; CrLf &amp;CrLf &amp;
"You can either enter the location you wish to move the selected container to using the 'Target Location' text box or use the combo boxes to find the location you want. Each combo box gets populated as the one above it has an item selected in it. The move button will become enabled once a value is entered in the 'Target Location' text box."</source>
        <type name="String"/>
    </Constant>
