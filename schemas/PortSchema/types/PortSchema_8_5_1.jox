	self.updateShipConfigToDLRPlanError(); //TFS 1661 epr
	self.setYATypeCommReeferUnused(pControllerObj); //26/04/2016 cnwma1 PAR #36914 TFS1768 
	self.updateCargoSubtypeEDIXlations();	//13 May 2016	cnwrs1	TFS 1987 CargoSubType EDI Xlation
	self.updateVGMCargoPermission(pControllerObj);
	self.updateVGMConfigs(pControllerObj);
