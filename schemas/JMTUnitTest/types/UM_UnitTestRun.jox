    <JadeMethod name="create" id="65061e51-d214-4059-ba4b-b69d27bbdfe6">
        <updating/>
        <source>create() updating;

/*

Purpose:		

Date			Who		Reason
30/09/2013		cnwmh5	Initial creation
// 12 May 2016		cnwns1			TFS 488 - Multi Timezone Support
*/

vars

	root					: UM_Root;
	
	ts						: TimeStamp;

begin

	root := UM_Root.firstInstance;
	if root = null then
		create root;
	endif;
	
	if not self.isTransient then
		self.myRoot := root;
	endif;
	
	ts := app.actualTimeServer();// 12 May 2016		cnwns1			TFS 488 - Multi Timezone Support
	self.startTS := ts;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getLastRunTestTS" id="c9839221-512b-406c-b09a-a1a900f4b288">
        <source>getLastRunTestTS() : TimeStamp;

/*

Purpose:		Gets the timestamp for the last test run.

Date			Who		Reason
14/10/2013		cnwmh5	Initial creation

*/

vars				

	mergeIter				: MergeIterator;
	result					: UM_UnitTestResult;

	ts						: TimeStamp;
	tempTS					: TimeStamp;

begin

	tempTS.setDate("31/12/2999".Date);
	tempTS.setTime("23:59:59".Time);
	
	create mergeIter transient;
	mergeIter.addCollection(self.allFailed);
	mergeIter.addCollection(self.allPassed);
	
	mergeIter.startKeyGeq(tempTS);

	while mergeIter.back(result) do
		ts := result.methodRunStartTS;
		ts := ts.addSeconds(result.elapsedTime.Integer);
	endwhile;
	

	return ts;
	
epilog

	delete mergeIter;

end;</source>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="getPreviousTest" id="287b241e-d62e-4bd5-a90c-ad583c40ef8c">
        <source>getPreviousTest():UM_UnitTestRun;
/*

Purpose:	Find the previous run test		

Parameters:			

Return Value:		

Date		Who		Reason
16 October 2025	navsp1	Initial creation   MTN-34201  MTN - Dump Config before first unit test and last unit test for comparison - Phase2

*/

vars

	
	iter						: Iterator;
    root						: UM_Root;
    testRun						: UM_UnitTestRun;
begin
    root := UM_Root.firstInstance;
    iter := root.allUnitTestRuns.createIterator;
	while iter.back(testRun) do
        if testRun.startTS &lt;&gt; self.startTS then
            break;
        endif;
    endwhile;
    
    return testRun;

epilog

	delete iter;

end;</source>
        <ReturnType type="UM_UnitTestRun"/>
    </JadeMethod>
    <JadeMethod name="getTestForSpecifiedTime" id="b5bb6b67-aac7-4cd6-86d0-79563de382d7">
        <source>getTestForSpecifiedTime(_timeStamp : TimeStamp) : UM_UnitTestResult;

/*

Purpose:		Get the test at for the specified TimeStamp

Date			Who		Reason
17/02/2017		cnwmh5	Initial creation

*/

vars

	testResult					: UM_UnitTestResult;
	
	mergeIter					: MergeIterator;

begin

	testResult := null;

	// time stamp null or invalid so return null
	if _timeStamp = null or not _timeStamp.isValid() then
		return testResult;
	endif;
	
	// get the test result
	create mergeIter transient;
	mergeIter.addCollection(self.allFailed);
	mergeIter.addCollection(self.allPassed);
	
	mergeIter.startKeyLeq(_timeStamp);
	mergeIter.back(testResult);

	return testResult;

epilog

	delete mergeIter;

end;</source>
        <Parameter name="_timeStamp" type="TimeStamp"/>
        <ReturnType type="UM_UnitTestResult"/>
    </JadeMethod>
