<Class name="SOPVM_CodeGeneric" id="edd6eea5-7ea5-4583-83f6-9e45506c06db">
    <superclass name="SOP_ViewModelObject"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="cmtrans"/>
    <JadeMethod name="create" id="1889a450-98c0-4f2e-b54d-deb1fdb012cc">
        <updating/>
        <source>create() updating;
// ---------------------------------------------------------------------------
// Created:     11 June 2002 by cnwth2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	self.canAddChild 	:= false;
	self.canAddPeer 	:= true;
	self.canEdit 		:= true;
	self.canDelete 		:= true;
	expanded := true;
end;</source>
    </JadeMethod>
    <JadeMethod name="createEmptyChild" id="9b3abf3e-8fcf-4e43-b7b0-fa5b46f375ab">
        <updating/>
        <source>createEmptyChild(_parent: SOP_ViewModelObject) updating;
// ---------------------------------------------------------------------------
// Created:     04 June 2002 by cnwth2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	create myObject as CM_CodeGeneric transient;
	myObject.CM_CodeGeneric.setProxy(null, null,null, _parent.myObject.CM_CodeGroup);
	myParent := _parent;
end;</source>
        <Parameter name="_parent" type="SOP_ViewModelObject"/>
    </JadeMethod>
    <JadeMethod name="createEmptyPeer" id="b63d4857-44de-4caf-aa66-3ad7335cd541">
        <updating/>
        <source>createEmptyPeer(_parent: SOP_ViewModelObject) updating;
// ---------------------------------------------------------------------------
// Created:     04 June 2002 by cnwth2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	proxyCode: CM_CodeGeneric;
begin
	create proxyCode transient;
	proxyCode.setProxy(null, null, null, _parent.myObject.CM_CodeGroup);
	self.myObject := proxyCode;	
	self.myParent := _parent;
end;</source>
        <Parameter name="_parent" type="SOP_ViewModelObject"/>
    </JadeMethod>
    <JadeMethod name="doDelete" id="1462c06f-c66a-4541-85ca-bacee9b10440">
        <updating/>
        <source>doDelete() :Boolean updating;
// ---------------------------------------------------------------------------
// Created:     04 June 2002 by cnwth2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin	
	app.myTrxDA.trxDeleteCodeGeneric(self.myObject.CM_CodeGeneric, app.myPassport);
	return app.myPassport.trxCompletedOK;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSave" id="a382a94f-4f0f-42c4-8176-16d5fa7541f4">
        <updating/>
        <source>doSave(): Boolean updating;
// ---------------------------------------------------------------------------
// Created:     04 June 2002 by cnwth2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	proxyCode 		: CM_CodeGeneric;
	newCode			: CM_Code;
begin

	if self.myForm.mode = self.myForm.Mode_Add then
		if self.myForm.myProxyObject &lt;&gt; null then
			self.myForm.myProxyObject.erase(NORMAL_ERASE);
		endif;
		
		create self.myForm.myProxyObject as CM_CodeGeneric transient;
	endif;
	
	proxyCode := self.myForm.myProxyObject.CM_CodeGeneric;
	
	proxyCode.setProxy(self.myForm.tblInput1.getValueByName(ETRow_Code).String.removeTabCrLfs(),	// 18/04/2013 cnwar2 #27130
							self.myForm.tblInput1.getValueByName(ETRow_Description).String,
							self.myForm.tblInput1.getValueByName(ETRow_NotAvailableForEntry).Boolean,
							self.myObject.CM_CodeGeneric.myCodeGroup);
								
	if self.myForm.mode = self.myForm.Mode_Add then
		app.myTrxCA.trxCreateCodeGeneric(proxyCode, newCode,app.myPassport);
		if app.myPassport.trxCompletedOK then
			delete self.myObject;  // delete the transient holder
			self.myObject := newCode;
		endif;
	
	elseif self.myForm.mode = self.myForm.Mode_Update then
		app.myTrxUA.trxUpdateCodeGeneric(proxyCode, app.myPassport);
	endif;
	
	self.myForm.myProxyObject := proxyCode;
	return app.myPassport.trxCompletedOK();

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getPeerClass" id="cd5fa76f-5384-4449-86b2-4641b53d1748">
        <source>getPeerClass(): Class protected;
// ---------------------------------------------------------------------------
