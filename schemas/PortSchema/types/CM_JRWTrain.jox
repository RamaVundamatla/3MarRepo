<Class name="CM_JRWTrain" id="f4749a6d-8ef1-4673-bcb3-6f70eefb3840">
    <superclass name="CM_JRWTransient"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="query"/>
    <ImplicitInverseRef name="allTrains" id="f17516b5-e67e-45ae-9ae8-4660dfd09dd1">
