    <JadeMethod name="cnEcFileExt" id="1f192636-577a-46b3-a82e-93e001e40451">
        <source>cnEcFileExt() :String;
// --------------------------------------------------------------------------------
// Created:		10 March 2001 by cnwdad1
//
// Purpose:		Return the extension of the node's name.
//
// Parameters:	None.
//
// Returns:		The file/folder name's extension.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 08/05/2002	cnwdad1		If the node name did not have an extension, then the
//							name (from 2nd character onwards) was being returned.
// --------------------------------------------------------------------------------
vars
	uniqueName	: String;
	charIndex	: Integer;
	lastCharPos	: Integer;

begin
	// Get the unqualified filename

	uniqueName	:=	self.cnEcUnqualName();
	charIndex	:=	1;
	
	if uniqueName.pos(".", 1) = 0 then		// cnwdad1 08/05/2002
		return null;						// cnwdad1 08/05/2002
	endif;									// cnwdad1 08/05/2002
	
	while charIndex &lt;&gt; 0 and charIndex &lt; uniqueName.length do
		lastCharPos	:=	charIndex;
		charIndex	:=	uniqueName.pos(".", (lastCharPos + 1));
	endwhile;

	if lastCharPos = 0 then
		return "";
	endif;

	return uniqueName[(lastCharPos + 1):end];		
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="cnEcFilePath" id="2250ae52-7d16-4186-a89d-820cb39e6f58">
        <source>cnEcFilePath() :String;
// Return the path part of the fully qualified filename only
// (up to and including the FINAL "\").
vars
	charIndex	: Integer;
	lastCharPos	: Integer;

begin
	charIndex	:=	1;

	while charIndex &lt;&gt; 0 do
		lastCharPos	:=	charIndex;
		charIndex	:=	fileName.pos(global.cnEcGetFileSeparator(), (lastCharPos + 1));
	endwhile;

	return fileName[1:lastCharPos];	
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="cnEcFileStem" id="91135d49-0014-4dcb-8ba0-9baac85f9854">
        <source>cnEcFileStem() :String;
// --------------------------------------------------------------------------------
// Created:		10 March 2001 by cnwdad1
//
// Purpose:		Return the filestem, i.e. the unqualified filename without the file
//				extension (after the FINAL ".").
//
// Parameters:	None.
//
// Returns:		The stem of the node's name.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 08/05/2002	cnwdad1		If the node name did not have an extension, then no
//							name was being returned at all.
// --------------------------------------------------------------------------------
vars
	uniqueName	: String;
	charIndex	: Integer;
	lastCharPos	: Integer;

begin
	// Get the unqualified filename
	uniqueName	:=	self.cnEcUnqualName();
	charIndex	:=	1;
	
	if uniqueName.pos(".", 1) = 0 then		// cnwdad1 08/05/2002
		return uniqueName;					// cnwdad1 08/05/2002
	endif;									// cnwdad1 08/05/2002
	
	while charIndex &lt;&gt; 0 and charIndex &lt; uniqueName.length do
		lastCharPos	:=	charIndex;
		charIndex	:=	uniqueName.pos(".", (lastCharPos + 1));
	endwhile;

	if lastCharPos = 0 then
		return uniqueName;
	endif;

	return uniqueName[1:(lastCharPos - 1)];
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
