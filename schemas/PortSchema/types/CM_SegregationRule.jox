    <JadeMethod name="getColour" id="b3717956-9476-4912-a4bd-ae2bd9ffb429">
        <source>getColour() : Integer;
/*
----------   ----------  --------------------------------------------------
Created:	28 August 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	return self.mySegregationCondition.colour;

end;


</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getDisplayDescr" id="7eb92644-87ea-4a12-8bdf-ef0e31407ab3">
        <source>getDisplayDescr() : String;
/*
----------   ----------  --------------------------------------------------
Created:	27 October 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	if self.myConstituentEntity1 &lt;&gt; null and self.myConstituentEntity2 &lt;&gt; null then
		return self.myConstituentEntity1.CM_HazardClass.code &amp; ' with ' &amp; self.myConstituentEntity2.CM_HazardClass.code;
	endif;
	

end;


</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getErrorDescr" id="6b7ad5fe-7337-443f-959d-7c5edeacedcd">
        <source>getErrorDescr() : String;
/*
----------   ----------  --------------------------------------------------
Created:	24 November 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	str			: String;
begin
	str := self.mySegregationCondition.code &amp; ' - ' &amp; self.mySegregationCondition.description;

	if self.myConstituentEntity1 &lt;&gt; null and self.myConstituentEntity2 &lt;&gt; null then
		str := str &amp; ' (Hazards ' &amp; self.myConstituentEntity1.CM_HazardClass.code &amp; ' with ' &amp; self.myConstituentEntity2.CM_HazardClass.code &amp; ')';
	endif;
	
	return str;
end;


</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="084a073d-6258-4752-873a-4f06e6cb4f9f">
        <source>pxyCreateUpdateProxy(): SelfType;
/*
----------   ----------  --------------------------------------------------
Created:	29 August 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
20/04/2011	 cnwmh5		 PAR #27401 - Add code to handle prossible exceptions occurring when
						 trying to create the proxy	
----------   ----------  --------------------------------------------------
*/
vars
	newSelf		: SelfType;
	completedOK		: Boolean;
begin
	newSelf := inheritMethod();
	newSelf.myConstituentEntity1 := self.myConstituentEntity1;
	newSelf.myConstituentEntity2 := self.myConstituentEntity2;
	newSelf.mySegregationCondition := self.mySegregationCondition;
	newSelf.myTerminal := self.myTerminal;
	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return newSelf;
	
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete newSelf;
	endif;	
end;


</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="20183637-b03d-4ebb-a9d6-0c0cbf4bda65">
        <updating/>
        <source>setForUpdate(_pxySegRule : CM_SegregationRule) updating;
/*
----------   ----------  --------------------------------------------------
Created:	29 August 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	self.myConstituentEntity1 	:= _pxySegRule.myConstituentEntity1;
	self.myConstituentEntity2 	:= _pxySegRule.myConstituentEntity2;
	self.mySegregationCondition := _pxySegRule.mySegregationCondition;
	self.myTerminal				:= _pxySegRule.myTerminal;
	
end;


</source>
        <Parameter name="_pxySegRule" type="CM_SegregationRule"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="f2195292-a085-4e03-9d9b-63898c787376">
        <updating/>
        <source>setProxy(_entity1, 
		_entity2 		: CM_Object;
		_segCondition 	: CM_SegregationCondition;
		_terminal 		: CM_Terminal) updating;
/*
----------   ----------  --------------------------------------------------
Created:	28 August 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	self.myConstituentEntity1 	:= _entity1;
	self.myConstituentEntity2 	:= _entity2;
	self.mySegregationCondition := _segCondition;
	self.myTerminal				:= _terminal;
	
	
end;


</source>
        <Parameter name="_entity1" type="CM_Object"/>
        <Parameter name="_entity2" type="CM_Object"/>
        <Parameter name="_segCondition" type="CM_SegregationCondition"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="type" id="29dd5870-03e4-480b-82d6-f95cb54987ba">
        <methodInvocation>mapping</methodInvocation>
        <source>type(set: Boolean; _value: Integer io) mapping;
/*
----------   ----------  --------------------------------------------------
Created:	22 August 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	if set then
		app.raiseSetVirtualError(class.name, method.name);
	else
		_value := self.mySegregationCondition.type;
	endif;



end;


</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="043dddbe-f825-411e-8c05-18ccb4bcc000">
        <source>validateForUpdate();
/*
----------   ----------  --------------------------------------------------
Created:	29 August 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	if self.myConstituentEntity1 = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Constituent entity 1 is null');
	endif;

	if self.myConstituentEntity2 = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Constituent entity 2 is null');
	endif;
	
	if self.mySegregationCondition = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Segregation rule is null');
	endif;

	if self.myTerminal = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Terminal is null');
	endif;

end;


</source>
    </JadeMethod>
</Class>
