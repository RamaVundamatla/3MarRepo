    <JadeMethod name="utlUpdateCustDocCancellation" id="68ec2f9f-2ec2-40e1-8aa9-bad5675b2bc9">
        <updating/>
        <source>utlUpdateCustDocCancellation(_realObject : CM_CustomDocument input;_passport : CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 November 2023 navmv20 CR 60425 Task 60987: Jade - Cust Doc Cancellation TRX

*/
vars
	tiTrans		: CM_TITransaction;
	theTerminal : CM_Terminal;
	status : Integer;
begin
	self.initialiseActivity();
	
	app.setContinueCMExceptions(true);

	exclusiveLock(_realObject);

	self.myUpdateAuditAgent.audUpdateGeneric(_realObject, true);
	theTerminal := _realObject.myTerminal;
	
	// ### TFS  CR 60425 TASK 60828 13NOV2023 NAVAB1
	app.myValUA.valCustDocHeaderCancel(_realObject);
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;

	if _passport.noErrors then
		_realObject.setStatus(CM_CustomDocument.Status_Cancelled);
		_realObject.reverseStops(); // ### TFS CR 60425 TASK 60828 13NOV2023 NAVAB1
	endif;
	
	self.myUpdateAuditAgent.audUpdateGeneric(_realObject, false);
			
	app.myEventManager.createSingleObjInfoNoteEvt(theTerminal,theTerminal.getTerminalEvent(Event_CustDocHeaderUpdate),_realObject);
	
	if _passport.noErrors then
		_realObject.createTransactionForTI(TRANS_TYPE_CUSTDOCCANCEL);
	endif;
end;</source>
        <Parameter name="_realObject" type="CM_CustomDocument" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateCustDocDetail" id="61062cd0-f593-4154-a2c2-b6a49c9f7b82">
        <updating/>
        <source>utlUpdateCustDocDetail(_pxyObject : CM_CustomDocumentDetail; _passport : CM_Passport input) updating;
// ##### CR 56094  TASK 59616 NAVAB1 08AUG2023
vars
	realObject		: CM_CustomDocumentDetail;
	expectedEdition	: Integer;
	theTerminal : CM_Terminal;
	header : CM_CustomDocument;
	nowIncluded,nowRemoved : Boolean;
begin

	self.initialiseActivity();
	
	// do any pre-validation locks
	
	// do validation
	self.raiseExceptionIfNull(_pxyObject, 'Cust Doc Type');

	app.setContinueCMExceptions(true);
	
	app.myValUA.valCustDocDetail(_pxyObject);

	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	realObject := self.getRealObjectAndEditionCheck(_pxyObject, 'Cust Doc Type', _passport).CM_CustomDocumentDetail;
	
	// ### TFS CR 60424 TASK 60549 26SEP2023 NAVAB1
	if realObject.included &lt;&gt; _pxyObject.included then
		nowIncluded := _pxyObject.included = true;
		nowRemoved := _pxyObject.included = false;
	endif;

	if _passport.noErrors then
		// This is only required if the class is being auditted
		self.myUpdateAuditAgent.audUpdateGeneric(realObject, true);
	endif;

	if _passport.noErrors then
		// do updates
		realObject.setForUpdate(_pxyObject);
		
		if nowIncluded then // was not included, now is included, apply the stops
			realObject.handleStops(null);
		elseif nowRemoved then // was  included, now is not included, clear the stops
			realObject.reverseStops();
		endif;
		// ### TFS CR 60425 TASK 60828 16NOV2023 NAVAB1
		if _passport.noErrors then
			realObject.createTransactionForTI(TRANS_TYPE_CUSTDOCUPDATED);
		endif;
	endif;

	if _passport.noErrors then
		// This is only required if the class is being auditted
		self.myUpdateAuditAgent.audUpdateGeneric(realObject, false);
		
		// ### TFS CR 59615 TASK 59620 15AUG2023 NAVAB1
		header := realObject.getCustomDocumentHeader(); 
		if header &lt;&gt; null then
			if nowIncluded then // was not included, now is included, apply the stops
				header.addTI(realObject.myTrackedItem);
			elseif nowRemoved then // was  included, now is not included, clear the stops
				header.removeTI(realObject.myTrackedItem);
			endif;
				
			 theTerminal := header.myTerminal;
			app.myEventManager.createSingleObjInfoNoteEvt(header,theTerminal.getTerminalEvent(Event_CustDocDetailUpdate),realObject);	
			
			//23/02/2023	navkc1 CR 62580 Task 62581
			realObject.myTrackedItem.updateNoteForTransport();
		endif;
	endif;

end;</source>
        <Parameter name="_pxyObject" type="CM_CustomDocumentDetail"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateCustDocExtRef" id="c2df50b3-3a0f-408b-a0f4-a7d89919db21">
        <updating/>
        <source>utlUpdateCustDocExtRef(_pxyObject : CM_CustomDocument; _passport : CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08/09/2023	navkc1	CR 60347  Task 60348: Jade - TRX to Accept CSV File For Updating Ext Ref on Custom Document

*/

vars
	realObject		: CM_CustomDocument;
	theTerminal : CM_Terminal;
begin
	self.initialiseActivity();
	
	// do validation
	self.raiseExceptionIfNull(_pxyObject, 'Cust Doc');

	app.setContinueCMExceptions(true);
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	realObject := self.getRealObjectAndEditionCheck(_pxyObject, 'Cust Doc', _passport).CM_CustomDocument;

	if _passport.noErrors then
		// This is only required if the class is being auditted
		self.myUpdateAuditAgent.audUpdateGeneric(realObject, true);
	endif;

	if _passport.noErrors then
		realObject.setUpdateExternalReference(_pxyObject.externalRef1);
	endif;

	if _passport.noErrors then
		theTerminal := realObject.myTerminal;
		// This is only required if the class is being auditted
		self.myUpdateAuditAgent.audUpdateGeneric(realObject, false);
		
		app.myEventManager.createSingleObjInfoNoteEvt(theTerminal,theTerminal.getTerminalEvent(Event_CustDocHeaderUpdate),realObject);	
	endif;
epilog

end;</source>
        <Parameter name="_pxyObject" type="CM_CustomDocument"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateCustDocHeader" id="2a7c0fbf-4124-4208-aa23-0c60e4bee299">
        <updating/>
        <source>utlUpdateCustDocHeader(_pxyObject : CM_CustomDocument; _partialUpdate : Boolean; _passport : CM_Passport input) updating;
// ##### CR 56094  TASK 59616 NAVAB1 08AUG2023
// 29/08/2023	navkc1	CR 59556  Task 59593: UI - Cust Docs Auto Id
//05/09/2023	navkc1	CR 59934 Task 59935: Jade - Cust Doc Cargo Transactions
vars
	realObject		: CM_CustomDocument;
	expectedEdition	: Integer;
	theTerminal : CM_Terminal;
	custDocType, oldDocType	: CM_CustomDocumentType;
	autoIdGen	: CM_AutoIdCustomDocs;
	firstTI		: CM_TrackedItem;
	date		: Date;
	tiTrans		: CM_TITransaction;
	genAutoId	: Boolean;
begin

	self.initialiseActivity();
	
	// do any pre-validation locks
	
	// do validation
	self.raiseExceptionIfNull(_pxyObject, 'Cust Doc');

	app.setContinueCMExceptions(true);
	
	app.myValUA.valCustDocHeader(_pxyObject);

	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	realObject := self.getRealObjectAndEditionCheck(_pxyObject, 'Cust Doc', _passport).CM_CustomDocument;

	if _passport.noErrors then
		// This is only required if the class is being auditted
		self.myUpdateAuditAgent.audUpdateGeneric(realObject, true);
	endif;

	oldDocType := realObject.myCustomDocumentType;// ### TFS CR 59942 TASK 59943 04SEP2023 NAVAB1
	theTerminal := realObject.myTerminal; // ### TFS CR 60424 TASK 60549 24OCT2023 NAVAB1
	
	
	// ### TFS CR 60424 TASK 60549 24OCT2023 NAVAB1 - only Rewmarks and External Ref can be changed.
	if _partialUpdate then
		// do updates
		realObject.setForUpdate(_pxyObject);
		self.myUpdateAuditAgent.audUpdateGeneric(realObject, false);
		
		app.myEventManager.createSingleObjInfoNoteEvt(theTerminal,theTerminal.getTerminalEvent(Event_CustDocHeaderUpdate),realObject);	
	
	else
	
		if _passport.noErrors then
			//29/08/2023	navkc1	CR 59556  Task 59593 - check do we want to use Auto ID before making changes
			realObject.checkDoUpdateCode(_pxyObject, genAutoId);
			// do updates
			realObject.setForUpdate(_pxyObject);
			
		endif;

		if _passport.noErrors then
			//29/08/2023	navkc1	CR 59556  Task 59593 Do Auto id if needed
			custDocType := realObject.myCustomDocumentType;
			if genAutoId and custDocType.hasAutoId then
				autoIdGen := theTerminal.getMyAutoIdGenerator(CM_AutoIdCustomDocs).CM_AutoIdCustomDocs;
				if autoIdGen &lt;&gt; null then
					date := realObject.getFirstTiDate();
					realObject.setCode(autoIdGen.getNextIdForYear(date));
				endif;
			endif;
			// This is only required if the class is being auditted
			self.myUpdateAuditAgent.audUpdateGeneric(realObject, false);
			
			app.myEventManager.createSingleObjInfoNoteEvt(theTerminal,theTerminal.getTerminalEvent(Event_CustDocHeaderUpdate),realObject);	
		endif;
		
		realObject.handleStops(oldDocType); // ### TFS CR 59942 TASK 59943 04SEP2023 NAVAB1
	endif;
	
	if _passport.noErrors then // ### TFS CR 60424 TASK 60549 24OCT2023 NAVAB1
		//05/09/2023	navkc1	CR 59934 Task 59935
		realObject.createTransactionForTI(TRANS_TYPE_CUSTDOCUPDATED);
	endif;
end;</source>
        <Parameter name="_pxyObject" type="CM_CustomDocument"/>
        <Parameter name="_partialUpdate" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateCustDocType" id="fbfa5640-12d5-4654-91b7-15607afa02fa">
