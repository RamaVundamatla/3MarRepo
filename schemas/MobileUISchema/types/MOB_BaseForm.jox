    <JadeMethod name="addF1HelpAction" id="d49f0e7d-114e-493b-ba63-f1b25258c12d">
        <source>addF1HelpAction(_tableDecorator : CMIF_EntTableLikeFormDecorator;
				_key : Integer;
				_entRowName : String ) protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
15 June 2010	cnwer1	Initial creation

*/

vars
	actionDesc : String;
	action : Integer;
begin
	action:=self.getActionForFunctionKey(_key);
	if action &gt; 0 then
		actionDesc:=self.getDescriptionForAction(action);
	endif;
	
	_tableDecorator.setEntRowVisible(_entRowName,actionDesc &lt;&gt; null);
	if actionDesc &lt;&gt; null then
		_tableDecorator.addDataForEntRowName(_entRowName,actionDesc);
	endif;
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_tableDecorator" type="CMIF_EntTableLikeFormDecorator"/>
        <Parameter name="_key" type="Integer"/>
        <Parameter name="_entRowName" type="String"/>
    </JadeMethod>
