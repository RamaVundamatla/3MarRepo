    <JadeMethod name="isDefaultGradeAnywhere" id="2a35709c-9170-41fd-8594-28275f31620b">
        <source>isDefaultGradeAnywhere(_termStr : String output) : Boolean;
/* ---------------------------------------------------------------------------
Created:     13 January 2010 by cnwrs2

Purpose:     Checks if this is used as the default grade at any terminals
        
Change Date	Who		Reason

------------------------------------------------------------------------------*/
vars
	tmpTerm		: CM_Terminal;
begin

	foreach tmpTerm in app.myRoot.allTerminals do
		if 	self.code = tmpTerm.getConfig(DefAvailabilityGrade).Integer then
			if _termStr = null then
				_termStr := tmpTerm.code;
			else
				_termStr := _termStr &amp; ', ' &amp; tmpTerm.code;
			endif;
		endif;
	endforeach;

	if _termStr &lt;&gt; null then
	// give error "Availability Grade XXXX is the default grade for terminals YYY.  You can not remove it from security role"
		return true;
	endif;
	
	return false;


epilog

end;</source>
        <Parameter name="_termStr" type="String" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="639aa8d8-eaba-4c31-88ad-16a4be7c22ed">
        <source>pxyCreateUpdateProxy(): SelfType;
// ---------------------------------------------------------------------------
// Created:     09 February 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy
// ---------------------------------------------------------------------------
vars
	proxyAvailabilityGrade	: CM_MTGrade;
	pxyMTGrade				: CM_MTGradeCode;
	mtGradeCode				: CM_Code;
	completedOK		: Boolean;
	
begin

	proxyAvailabilityGrade := inheritMethod();

	// RJS - need to add other references here, including collections
	// self.ports is inversed and this is the auto end so no need
	// to copy to the proxy
	
	foreach mtGradeCode in self.allCodeTranslations do
		create pxyMTGrade transient;
		pxyMTGrade.setForProxy(mtGradeCode.code, mtGradeCode.description, mtGradeCode.myCodeGroup, proxyAvailabilityGrade);
	endforeach;
	
	//14 Oct 2010	NDL Par 23991
	if not self.allAllowedReleaseTerms.isEmpty then
		self.allAllowedReleaseTerms.copy( proxyAvailabilityGrade.allAllowedReleaseTerms );
	endif;
	if not self.allAllowedEditSubTerms.isEmpty then
		self.allAllowedEditSubTerms.copy( proxyAvailabilityGrade.allAllowedEditSubTerms );
	endif;
	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return proxyAvailabilityGrade;
	
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete proxyAvailabilityGrade;
	endif;	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setAllAllowedEditSubTerms" id="7e908c5a-ae40-434d-894e-b3fca2b51936">
        <updating/>
        <source>setAllAllowedEditSubTerms( _allSubTerminals : CM_SubTerminalByCodeDict )updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14 October 2010	cnwndl1	Initial creation	Par 23991 - for data migration

*/

vars

begin

	self.allAllowedEditSubTerms.clear();
	if not _allSubTerminals.isEmpty then
		_allSubTerminals.copy( self.allAllowedEditSubTerms );
	endif;
	
epilog

end;</source>
        <Parameter name="_allSubTerminals" type="CM_SubTerminalByCodeDict"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="a6adfbaa-1495-4e40-a483-e48d5c638e89">
        <updating/>
        <source>setForCreate(pProxyAvailabilityGrade:CM_MTGrade) updating;
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	pProxyAvailabilityGrade.raiseExceptionIfNotTransient(method);
	
	setForUpdate(pProxyAvailabilityGrade);
	self.myRoot := app.myRoot;

end;</source>
        <Parameter name="pProxyAvailabilityGrade" type="CM_MTGrade"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="abac1111-5951-4cf7-bdac-257085ebf116">
        <updating/>
        <source>setForUpdate(_proxy:CM_MTGrade) updating;
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 16/04/2013	cnwcs5		CCMS POL 2097 / par 31259
// ---------------------------------------------------------------------------
vars

begin
	// par 31259 - make sure xlations updated with new code
	if self.code &lt;&gt; _proxy.code then
		self.updateXlations_Code (_proxy.code.String, self.code.String, self.allXlations);
	endif;
	
	self.code 					:= _proxy.code;
	self.description 			:= _proxy.description.trimBlanks;
	self.isSuitableForRelease	:= _proxy.isSuitableForRelease;
	self.isNotAvailableForEntry	:= _proxy.isNotAvailableForEntry;
	self.colour 				:= _proxy.colour;					//29 July 2011	NDL	Par 27890
	
	//14 Oct 2010	NDL Par 23991
	self.allAllowedReleaseTerms.clear();
	
	if not _proxy.allAllowedReleaseTerms.isEmpty then
		_proxy.allAllowedReleaseTerms.copy( self.allAllowedReleaseTerms );
	endif;
	
	self.allAllowedEditSubTerms.clear();
	
	if not _proxy.allAllowedEditSubTerms.isEmpty then
		_proxy.allAllowedEditSubTerms.copy( self.allAllowedEditSubTerms );
	endif;
	
end;</source>
        <Parameter name="_proxy" type="CM_MTGrade"/>
    </JadeMethod>
    <JadeMethod name="setMyRoot" id="c24f7ddd-94aa-400f-8dd5-cdd9050a6a6e">
        <updating/>
        <source>setMyRoot() updating;
// ---------------------------------------------------------------------------
// Created:     04 July 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	self.myRoot := app.myRoot;

end;</source>
    </JadeMethod>
    <JadeMethod name="setProxy" id="e8484083-6cca-4bce-8424-dd9bb1639798">
        <updating/>
        <source>setProxy(	pCode:Integer;
			pDescription:String;
			pIsSuitableForRelease : Boolean;
			_isNotAvailableForEntry : Boolean;
			_colour : Integer;	//NDL Par 27890	
			_selectedTerminals : CM_TerminalSet;	//13 Oct 2010	NDL Par 23991
			_selectedSubTerminals : CM_SubTerminalByCodeDict	//13 Oct 2010	NDL Par 23991
			) updating;

vars

begin

	self.raiseExceptionIfNotTransient(method);

	self.code := pCode;
	self.description := pDescription[1:30];
	self.isSuitableForRelease := pIsSuitableForRelease;
	self.isNotAvailableForEntry := _isNotAvailableForEntry;
	self.colour := _colour;	//29 July 2011	NDL	Par 27890
	self.myRoot := app.myRoot;
	
	
	//13 Oct 2010	NDL Par 23991
	self.allAllowedReleaseTerms.clear();
	if _selectedTerminals &lt;&gt; null and not _selectedTerminals.isEmpty then
		_selectedTerminals.copy( self.allAllowedReleaseTerms );
	endif;
	self.allAllowedEditSubTerms.clear();
	if _selectedSubTerminals &lt;&gt; null and not _selectedSubTerminals.isEmpty then
		_selectedSubTerminals.copy( self.allAllowedEditSubTerms );
	endif;
	
end;</source>
        <Parameter name="pCode" type="Integer"/>
        <Parameter name="pDescription" type="String"/>
        <Parameter name="pIsSuitableForRelease" type="Boolean"/>
        <Parameter name="_isNotAvailableForEntry" type="Boolean"/>
        <Parameter name="_colour" type="Integer"/>
        <Parameter name="_selectedTerminals" type="CM_TerminalSet"/>
        <Parameter name="_selectedSubTerminals" type="CM_SubTerminalByCodeDict"/>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="c1d86261-a410-4e6b-be1b-4746630221df">
        <source>validateForCreate();
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin	
	if app.myRoot.allAvailabilityGrades[code] &lt;&gt; null then
		app.raiseCMException1(VB_DUPLICATED_ITEM, self.code.String, null, null);
	endif;

	self.validateMe;
end;</source>
    </JadeMethod>
    <JadeMethod name="validateForDelete" id="2648f7a9-de12-48cf-bea9-e5ac11911df8">
        <source>validateForDelete();
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

	theID : Integer;
	aTerm : CM_Terminal;
begin
	foreach aTerm in app.myRoot.allTerminals do
		theID := aTerm.getConfig(DefAvailabilityGrade).Integer;
		if theID = self.code then
//			app.raiseCMException(ERR_USED_IN_CONFIG,null, null);
			app.raiseCMException2(ERR_USED_IN_CONFIG,"AV Grades", "Terminal " &amp; aTerm.code,null, null);
		endif;
	endforeach;

	if app.myRoot.isGradeUsedInTemplate(self.code) then
		app.raiseCMException2(ObjectStillHasEntries, self.description, "to do task template", null, null);
	endif;


/*
	if self.ports.size &gt; 0 then
		app.raiseCMException1(ObjectStillHasEntries, self.code, "ports", null);
	endif;
*/
end;</source>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="fcf2192f-2be9-4cc0-b995-b05144f3d1c0">
