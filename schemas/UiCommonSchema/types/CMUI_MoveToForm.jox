    <JadeMethod name="translateForm" id="a12956aa-ff07-4792-bb96-d6a8ffa6b5de">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0007813, locale);
	btnMoveIt.translateBubbleHelp(Xlat_0000559, locale);
	btnMoveIt.translateCaption(Xlat_0000560, locale);
	mnuCargoEnquiry.translateCaption(Xlat_0007814, locale);
	mnuContext.translateCaption(Xlat_0007815, locale);
	mnuInspectObject.translateCaption(Xlat_0007816, locale);
	shtItems.translateCaption(Xlat_0000561, locale);
	shtMove.translateCaption(Xlat_0000562, locale);
end;</source>
    </JadeMethod>
</GUIClass>
