    <JadeMethod name="displayLine" id="06082749-495b-4009-b261-ec90f887a179">
        <source>displayLine(_theObject : Object) : String;
// ---------------------------------------------------------------------------
// Created:		May 2004 By Andrew Bishop cnwab1
//
