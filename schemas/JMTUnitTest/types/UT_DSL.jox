    <JadeMethod name="updateEDITIRemarks" id="2c857b52-e3e5-446f-8aff-5c6fb2d0d1dc">
        <source>updateEDITIRemarks(_ediFile : CM_EDIFile io);

/*

Purpose:		

Date			Who		Reason
14/07/2015		cnwmh5	Initial creation
21 Nov 2022		navma1	ChangeRequest 55424: MTN - Improve the performance of Edi file loading
*/

vars
	
	ediTi						: CM_EDITrackedItem;
	
	remarks 					: String;
	createdBy					: String;
	xlationOper					: CM_Operator;
begin

	xlationOper := _ediFile.ediData.getXlationOperator();					//21.11.2022 navma1 #55424
	
	foreach ediTi in _ediFile.ediData.allEDITrackedItems discreteLock do
		if ediTi.class.getPropertyInHTree("remarks") = null then
			continue;
		endif;
		remarks := ediTi.getPropertyValue("remarks").String;
		if remarks &lt;&gt; null then
			remarks := remarks &amp; CrLf;
		endif;
		createdBy := self.createdByUnitTest(remarks);
		beginTransaction;
		ediTi.setEDITIProperty("remarks",  remarks &amp; createdBy, _ediFile, null, null,xlationOper); //21.11.2022 navma1 #55424
		commitTransaction;
	endforeach;	

epilog

end;</source>
        <Parameter name="_ediFile" type="CM_EDIFile" usage="io"/>
    </JadeMethod>
    <JadeMethod name="updateEDIVoyageCutoff" id="e2ead47c-3c7b-4e01-91b9-ba24375e8862">
        <source>updateEDIVoyageCutoff(_code :String; _type :Integer; _dataTypes :IntegerArray; _cutoff :Decimal):CM_ReceivalCutoffTermDef;
/*
Date		Who		Reason
01/03/2012	cnwcs5	Initial creation - par 29158 EDI Booking Cutoff
17/03/2012	cnwcs5	par 29257 - conversion of extension object properties
*/
vars
	proxy, cutoff	:CM_ReceivalCutoffTermDef;
	dummy			:CMIF_Array;
	terminal		:CM_Terminal;
begin
	terminal := self.getTerminal;
	cutoff	 := terminal.allReceivalCutoffDefs[_code];
	
	self.assertNotNullMsg (cutoff, 'Invalid code for cutoff');
	
	beginLoad;
	proxy := cutoff.pxyCreateUpdateProxy;
	endLoad;
	
	proxy.setValues (_code, _code, proxy.sortKey, _type, _cutoff, 0, true, CM_ReceivalCutoffTermDef.CriteriaType_EDI, terminal, 
						_cutoff, 	//04/03/2025	navkc1 JIRA Story MTN-34227
						0); 	//04/03/2025	navkc1 JIRA Story MTN-34227
	
	proxy.allEDIDataTypes.clear;			// par 29257 - march 2012
	_dataTypes.copy (proxy.allEDIDataTypes);// par 29257 - march 2012
	
	create dummy transient;
	
	app.myTrxUA.trxUpdateRecRestrictionDef (proxy, dummy, app.myPassport);
	
	self.assertNoTrxErrorsOrWarnings;
	self.assertNotNull (cutoff);
	self.assertEqualMsg (cutoff.code, _code, 'Incorrect code');
	self.assertEqualMsg (cutoff.description, _code, 'Incorrect description');
	self.assertEqualMsg (cutoff.defaultRelativeTo, _type, 'Incorrect default relative to');
	self.assertEqualMsg (cutoff.defaultEarliestReceival, 0.Decimal, 'Incorrect default earliest');
	self.assertEqualMsg (cutoff.defaultCutoff, _cutoff, 'Incorrect default cutoff');
	self.assertEqualMsg (cutoff.criteriaType, CM_ReceivalCutoffTermDef.CriteriaType_EDI, 'Invalid criteris type');
	self.assertNotNullMsg (cutoff.allEDIDataTypes, 'No data types specified');
	self.assertTrueMsg (cutoff.allEDIDataTypes.size = _dataTypes.size, 'Incorrect data types');
	self.assertTrueMsg (cutoff.allEDIDataTypes.asCSV(false) = _dataTypes.asCSV(false), 'Incorrect data types');
	return cutoff;
epilog
	endLoad;													// 19/04/2013 cnwmh5 #31457
	delete dummy;
	delete proxy;
end;</source>
        <Parameter name="_code" type="String"/>
        <Parameter name="_type" type="Integer"/>
        <Parameter name="_dataTypes" type="IntegerArray"/>
        <Parameter name="_cutoff" type="Decimal"/>
        <ReturnType type="CM_ReceivalCutoffTermDef"/>
    </JadeMethod>
    <JadeMethod name="updateEmailAddress" id="21b885b8-ec4d-448a-8ae4-cf896d4f824a">
