    <JadeMethod name="doFilterCodes" id="c08ad938-8b9c-4560-a932-a25f0acdbf1f">
        <source>doFilterCodes();
/*

Purpose:			

Parameters:			

Return Value:		

Date					Who		Reason
15 December 2022		jlizm1	Initial creation TFS 55280 Harmonized System Codes

*/

vars
	filterText		: String;
	rowIdx,
	colIdx,
	start			: Integer;
	cell			: JadeTableCell;
	cellText		: String;
	
begin
	filterText := self.txtFilter.text.toUpper();
	start := self.tblCodes.fixedRows + 1;
	
	if (filterText = "") then
		foreach rowIdx in start to self.tblCodes.rows do
			self.tblCodes.accessRow(rowIdx);
			self.tblCodes.accessedRow.visible := true;
		endforeach;
		return;
	endif;
	
	foreach rowIdx in start to self.tblCodes.rows do	: rowLoop
		self.tblCodes.accessRow(rowIdx);
		foreach colIdx in 1 to self.tblCodes.columns do
			cell := self.tblCodes.accessCell(rowIdx, colIdx);
			cellText := cell.text.toUpper;
			if cellText.length &gt; 0 and cellText.pos(filterText, 1) &gt; 0 then
				self.tblCodes.accessedRow.visible := true;
				continue rowLoop;
			endif;
		endforeach;
		self.tblCodes.accessedRow.visible := false;
	endforeach;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doOpenMaintForm" id="9496b5a5-be6d-4aca-a6dd-01a9a9a5116f">
        <source>doOpenMaintForm();
