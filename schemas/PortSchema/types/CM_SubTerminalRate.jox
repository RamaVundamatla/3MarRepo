    <JadeMethod name="setDetails" id="97638fbe-79b3-4a3b-9b54-dadb6d853d0c">
        <updating/>
        <source>setDetails(	_costPerUnit : Decimal;
			_mySubTerminal : CM_SubTerminal;
			_myRateEntry : CM_RateEntry
			) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 June 2018	jlgndl1	Initial creation	TFS 39338

*/

vars

begin

	self.setCostPerUnit( _costPerUnit );
