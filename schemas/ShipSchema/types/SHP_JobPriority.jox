    <JadeMethod name="doLstPriorityDragDrop" id="1dde540d-639f-4439-bda4-581b79ef2af2">
        <updating/>
        <source>doLstPriorityDragDrop(listbox: CM_QueueListBox input; win: Window input; x: Real; y: Real) updating;
// ---------------------------------------------------------------------------
// Created:		07 April 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	aJP, dragJP, dropJP : CM_JobPriority;
	idx, dragIdx, dropIdx, dragPri, dropPri : Integer;
	rtn, movingUP : Boolean;
begin

	if listbox.myDragObject &lt;&gt; null then
		idx := listbox.getListIndex(x,y);
		
		if idx &lt; 0 then
			return;
		endif;
		
			
		dragJP := listbox.myDragObject.CM_JobPriority;
		dropJP := listbox.itemObject[idx].CM_JobPriority;
		dropPri := listbox.itemData[idx];
		dragPri := listbox.itemData[listbox.origIndex];
		
		if dragJP &lt;&gt; null and dropJP &lt;&gt; null then
			dragIdx := self.getIndexForPriority(dragPri, dragJP.craneType);
			dropIdx := self.getIndexForPriority(dropPri, dropJP.craneType);
			
			if dragJP.isGroup() then
				if dragJP.craneType &lt;&gt; dropJP.craneType then
					app.msgBox('Cannot drag priority ' &amp; dragJP.priority.String &amp; " to a different crane type - " &amp; dragJP.getCraneTypeDescription() &amp; " to " &amp; dropJP.getCraneTypeDescription(), null, MsgBox_OK_Only);
					return;
				else
					
					movingUP := (dropIdx &lt; dragIdx);
					
					if movingUP then
					dropIdx := dropIdx -1;
					else
					dropIdx := dropIdx- 1;
					
					endif;
					
					
								
					listbox.cnEcMoveTreeInSelf(listbox.origIndex, dropIdx, false, self.LevelPriority); // this copies
						
					idx := self.getIndexForObject(dragJP,not movingUP );
					listbox.removeItem(idx);
			
			
					self.reNumberPriorities(JobTypePriority_Crane1);
					self.reNumberPriorities(JobTypePriority_Crane2);
					listbox.clearAllSelected();
					
					
					
					return;
				endif;
			endif;
		endif;
		
		if listbox.itemLevel[idx] = self.LevelCrane then
			app.msgBox(app.getErrorString(Please_select_priorit_group), null, MsgBox_OK_Only); // PAR 34655
			return;
		endif;
		
		if self.checkForDuplicates (listbox.myDragObject.CM_JobPriority, idx) then
			app.msgBox(app.getErrorString(Lift_crane_already), null, MsgBox_OK_Only); // PAR 34655
			return;
		endif;
		
		rtn := self.checkForJobType (listbox.myDragObject.CM_JobPriority, idx);
		if rtn then
			app.msgBox(app.getErrorString(This_cannot_droppe_this_groupi), null, MsgBox_OK_Only); // PAR 34655
				return;
		endif;
		
		listbox.removeItem(listbox.origIndex);
		aJP := listbox.myDragObject.CM_JobPriority;
		if listbox.origIndex &gt; idx then
			idx := idx + 1;
		endif;
		listbox.addItemAt(app.getJobPriorityJobName(aJP.jobType),idx);
		listbox.itemLevel[listbox.newIndex] := self.LevelJobType;
		listbox.itemData[listbox.newIndex] := aJP.jobType;
		listbox.itemObject[listbox.newIndex] := listbox.myDragObject;
		
		self.reNumberPriorities(JobTypePriority_Crane1);
		self.reNumberPriorities(JobTypePriority_Crane2);
	endif;	
		//populateList ("Drag Down");
epilog
	listbox.dragMode := Window.DragMode_None;
	self.lstJobPriority.enableEvent("mouseMove",false);


end;</source>
        <Parameter name="listbox" type="CM_QueueListBox" usage="input"/>
        <Parameter name="win" type="Window" usage="input"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="doLstPriorityMouseDown" id="9f5e8ec7-497a-42af-8a98-ecdd26a8c6cc">
        <updating/>
        <source>doLstPriorityMouseDown(listbox: CM_QueueListBox input; button: Integer; shift: Integer; x: Real; y: Real) updating;
// ---------------------------------------------------------------------------
// Created:		07 April 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
begin

	if listbox.listIndex &lt; 0 then
		return;
	endif;
	//added by cnwyl1 for par 12216
	if button = Window.MouseButton_Left then
		self.origXPos := x;
		self.origYPos := y;
	endif;
	//added end
	self.lstJobPriority.setOriginals(x.Integer,y.Integer,listbox.listIndex,listbox.itemObject[listbox.listIndex]);
	self.lstJobPriority.enableEvent("mouseMove",true);

end;</source>
        <Parameter name="listbox" type="CM_QueueListBox" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
