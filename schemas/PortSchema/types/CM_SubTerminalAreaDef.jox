        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="13c04359-03b9-42bb-a3b4-45864305f05e">
        <source>pxyCreateUpdateProxy(): SelfType;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 November 2014	cnwndl1	Initial creation	Par 35295

*/

vars
	proxy : CM_SubTerminalAreaDef;
	completedOK	 : Boolean;
	
begin

	proxy := inheritMethod();
	
	proxy.myTerminal := self.myTerminal;
	proxy.mySubTerminal := self.mySubTerminal;
	
	completedOK := true;
	return proxy;
	
epilog
	if not completedOK then
		delete proxy;
	endif;	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
