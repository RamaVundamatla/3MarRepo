    <JadeMethod name="delete" id="534bb410-d0dc-401c-8ad9-852c7b230773">
        <updating/>
        <source>delete() updating;
/*
----------   ----------  --------------------------------------------------
Created:	30 October 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
//	self.allDamageInstances.purge();
	
	if global.isValidObject(self.myButton) then
		self.myButton.visible := false;
		delete self.myButton;
	endif;
	
	if self.myPxyTrackedItem &lt;&gt; null then
		//app.myProxyManager.deleteProxyLink(self.myPxyTrackedItem);
		delete self.myPxyTrackedItem;
	endif;
	
	self.myButton := null;
	
end;


</source>
    </JadeMethod>
    <JadeMethod name="is40" id="6f2e5aaf-3b44-4b0b-9fbe-89585ce10791">
        <source>is40() : Boolean;
/*
----------   ----------  --------------------------------------------------
Created:	28 November 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/


vars
	isoType			: CM_ISOType;
begin

	isoType := app.myRoot.allISOTypes[self.isoTypeCode];
	if isoType &lt;&gt; null then
		return isoType.is40ftLong;
	endif;
	
end;






</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setButtonCaption" id="fcb83ffa-7408-40c6-b00f-7a4fab188847">
        <source>setButtonCaption();
/*
----------   ----------  --------------------------------------------------
Created:	24 October 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	if self.myButton = null then
		return;
	endif;
	self.myButton.enabled := true;
	if self.confirmed then
		self.myButton.caption := 'Container ' &amp; self.idx.String &amp; ': Confirmed' &amp; CrLf &amp; 
										self.containerId;
	elseif self.hadErrors then
		self.myButton.caption := 'Container ' &amp; self.idx.String &amp; ': Had Errors';
	else
		self.myButton.caption := 'Container ' &amp; self.idx.String &amp; ': Awaiting Info' &amp; CrLf &amp;  
										self.containerId;
	endif;
	
end;


</source>
    </JadeMethod>
    <JadeMethod name="setMyRealTrackedItem" id="82006c97-890e-4471-8970-f58cf997aa39">
        <updating/>
        <source>setMyRealTrackedItem(_ti : CM_TrackedItem) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 November 2009	cnwer1	Initial creation

*/

vars

begin
	
	if self.myPxyTrackedItem &lt;&gt; null then
		delete self.myPxyTrackedItem;
	endif;
	
	self.myRealTrackedItem:=_ti;
	
	if _ti &lt;&gt; null then
		self.myPxyTrackedItem:= app.createUpdateProxy(_ti).CM_TrackedItem;
	endif;

epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="setSelfFromTI" id="d57e1a1d-4b49-41df-95c3-c9c7715dc603">
        <updating/>
        <source>setSelfFromTI() updating;
/*
----------   ----------  --------------------------------------------------
Created:	27 October 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	self.allDamageInstancesByDmgePos.clear();
	
	if self.myRealTrackedItem = null then	
		self.containerId :=null;
		return;
	endif;
	self.containerId 	:= self.myRealTrackedItem.id;
	//self.confirmed 		:= true;
	self.hadErrors 		:= false;
	//self.hazardousChecked := true;
	self.myRealTrackedItem.allDamageInstancesByPos.copy(self.allDamageInstancesByDmgePos);
	
	//15 Sep 2010	NDL	Par 25608 - change to using method 'getSealNumCustoms' or 'getSealNumCustomsFirst'
	self.customsSeal 	:= self.myRealTrackedItem.getSealNumCustomsFirst;
	//15 Sep 2010	NDL	Par 25608 - change from direct ref to using method 'getSealNum'
	self.operatorSeal 	:= self.myRealTrackedItem.getSealNum;
	//15 Sep 2010	NDL	Par 25608 - change from direct ref to using method 'getSealNumShipper'
	self.shipperSeal 	:= self.myRealTrackedItem.getSealNumShipper;
	
	
	if (not CM_Container.hasInstance(self.myRealTrackedItem)) then
		return;
	endif;
	

	self.isoTypeCode 	:= self.myRealTrackedItem.getISOType;
	
	
	
	
end;


</source>
    </JadeMethod>
</Class>
