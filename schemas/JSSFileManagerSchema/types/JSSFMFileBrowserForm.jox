    <JadeMethod name="doFetchSubdirectoriesServer" id="69d07353-d684-44e4-a62e-d3f9c6d7ad21">
        <executionLocation>server</executionLocation>
        <source>doFetchSubdirectoriesServer(pPathName:String; pTheContainer:JSSFMFolder input) protected, serverExecution;
// --------------------------------------------------------------------------------
// Created:		05 July 2002 by cnwdad1
//
// Purpose:		This method is a wrapper for the doFetchSubdirectories method.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
constants
