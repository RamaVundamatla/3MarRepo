    <JadeMethod name="setForCreateInternal" id="2455978e-9681-480f-9ecd-313a9ffad972">
        <updating/>
        <source>setForCreateInternal(_cmifJobParam: CMIF_WorkOrderJobParams; _terminal: CM_Terminal) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 Jun 2023 navma1  ChangeRequest 58296: EUP - [Framework] Delivery Dispatch Screen - Linking Road Jobs
10 Jul 2023	navma1	ChangeRequest 54550: EUP | Delivery Dispatch Screen - Pack Operation
*/

vars
	woDtl 			: CM_WorkOrderDtl;
	priorityDefault : Integer; 
begin
	
epilog
	
	woDtl := _cmifJobParam.myWorkOrderDtl;
	
	self.setRequiredByDT(woDtl.requiredByDT);
	
	self.jobType 	 := JOB_TYPE_WORKORDER;
	self.myTerminal  := _terminal;
	self.id 		 := _cmifJobParam.jobId;
	
	if woDtl.isKindOf(CM_WorkOrderTIDtl) then
		self.myWODtl	 := _cmifJobParam.myWorkOrderDtl.CM_WorkOrderTIDtl;
		
		self.allTrackedItems.clear();
		_cmifJobParam.allTIs.copy(self.allTrackedItems);										//10.07.2023 navma1 #54550
		
		if woDtl.isKindOf(CM_WodToDo)then
			priorityDefault			:= woDtl.CM_WodToDo.priority;
		endif;
		
	elseif woDtl.isKindOf(CM_WorkOrderToDoDtl) then
		self.myWorkOrderDtlToDo := _cmifJobParam.myWorkOrderDtl.CM_WorkOrderToDoDtl;
		priorityDefault 		:= self.myWorkOrderDtlToDo.CM_WorkOrderToDoDtl.priority;
	endif;
	
	//02.06.2023 navma1 #58296
	if priorityDefault = 0 then
		self.setPriority(3);
	else
		self.setPriority(priorityDefault);
	endif;
	

end;</source>
        <Parameter name="_cmifJobParam" type="CMIF_WorkOrderJobParams"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="edb1d711-a84f-4c44-a815-dfa1e701d868">
