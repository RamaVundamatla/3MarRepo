    <JadeMethod name="userNotificationYardAllocation" id="cae1e989-b319-4737-a358-324bc40f3290">
        <updating/>
        <source>userNotificationYardAllocation(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;
/*
Purpose:			
Date				Who			Reason
SEPT 2013		CNWAB1		Initial creation
*/

vars
	yalloc 			: CM_YardAllocation;
	anObject 		: Object;
	invalidObject	: Boolean;
	
begin
	if self.myTerminalArea = null then
		return;
	endif;
	anObject := userInfo.Object;

//app.writeStatement( class.name &amp; '::' &amp; method.name &amp; ' 1.' &amp; anObject.String &amp; " " &amp; eventType.String);
	if anObject &lt;&gt; null then
		yalloc := anObject.CM_YardAllocation;
		
		on Exception do app.handleDeletedObject(exception, yalloc, invalidObject);	// PAR #16814

		if eventType = self.myTerminal.getTerminalEvent(Event_YardAllocationUpdate)
		or eventType = self.myTerminal.getTerminalEvent(Event_YardAllocationUpdate)
		or eventType = self.myTerminal.getTerminalEvent(Event_YardAllocationUpdate) then
			self.drawSelf(true);
		endif;

		if  self.myGCBlockAreaForm  &lt;&gt; null then
	//		self.myGCBlockAreaForm.setYardAllocLegend();
		endif;
		
	
	endif;
epilog
end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
</Class>
