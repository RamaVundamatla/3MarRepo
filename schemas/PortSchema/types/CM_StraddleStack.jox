    <JadeMethod name="hasPower" id="e26542fd-8da4-426a-b578-909ccccfa8af">
        <methodInvocation>mapping</methodInvocation>
        <source>hasPower(set: Boolean; _value: Boolean io) mapping;
// ---------------------------------------------------------------------------
// Created:		August  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	lc	: CM_LocationsController;
	iHavePower : Boolean;
begin

	if set then
		return;
	endif;
	
	iHavePower := false;
	foreach lc in self.allLocationsControllers do
		if lc.hasPower then
			iHavePower := true;
			break;
		endif;
	endforeach;

	_value := iHavePower;
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Boolean" usage="io"/>
    </JadeMethod>
    <JadeMethod name="isOtagoStraddleAreaAorC" id="ee625fcc-170a-4d38-a552-d920d346526e">
        <source>isOtagoStraddleAreaAorC(): Boolean;
// --------------------------------------------------------------------------------
// Created:		02 June 2010 by cnwdad1
//
// Purpose:		Refer to superclass implementation.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
constants
	AREA_A		: String = "A";
	AREA_C		: String = "C";
	
begin
	if app.myRoot.isClientPortOtago() then
		if self.id = AREA_A or self.id = AREA_C then
			return true;
		endif;
	endif;
	
	return false;
end;</source>
        <ReturnType type="Boolean"/>
