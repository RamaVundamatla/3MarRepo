    <JadeMethod name="rel832_par35215" id="b1a7a9c7-e002-4ac2-9510-8fb663621941">
        <source>rel832_par35215();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 November 2014	cnwndl1	Initial creation	Par 35215

*/

vars

	iter : Iterator;
	userQuery : CM_MenuUserQuery;
	strArray : StringArray;
	attrName : String;
	
	pos : Integer;											
	revPos : Integer;							
	measureStr : String;							
	measure : CM_MeasurementType;
	
	newAttrName : String;
	
	queryDef	: CM_QueryDefinition;
	propDict	: CM_QueryPropertyDict;
	queryProp	: CM_QueryProperty;
	
begin

	app.initialize();
	
	iter := CM_MenuUserQuery.instances.createIterator;
	while iter.next( userQuery ) do
		strArray := userQuery.allVisibleColumns;
		foreach attrName in strArray do
			if attrName.pos("Row_",1) &gt; 0 then
			
				queryDef := userQuery.getQueryDefinition();
				propDict := queryDef.allQueryProperties;
	
				pos := attrName.pos("_", 1);										
				revPos := attrName.reversePos("_");
				measureStr := attrName[revPos+1:end];
				newAttrName := measureStr &amp; "_" &amp; attrName[pos+1:revPos-pos-1];
				
				queryProp := propDict[newAttrName];
				
				if queryProp &lt;&gt; null then
					beginTransaction;
					userQuery.replaceVisibleColumnName( attrName, newAttrName );
					commitTransaction;
				endif;
			endif;
		endforeach;
	endwhile;

epilog

	delete iter;

end;</source>
    </JadeMethod>
    <JadeMethod name="rel832_par35255" id="00ec04cb-02d2-41a4-b5ba-01cc0760c0a0">
        <source>rel832_par35255();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 November 2014	cnwgb1	Initial creation

*/

vars
	terminal : CM_Terminal;
	camProtocol : CM_CamProtocol;
begin
	app.initialize;
	foreach terminal in app.myRoot.allTerminals do 
		foreach camProtocol in terminal.camProtocols do
			if camProtocol.protocolDesc &lt;&gt; null then
                if camProtocol.protocolDesc.type = EDIFileTypeCams_SuzanoConfirm then
                    if camProtocol.allTrainEventTypes.isEmpty then
                        beginTransaction;
                            camProtocol.allTrainEventTypes.add(app.myRoot.allEventTypesByType [EVT_EDIFileReceived]);
                        commitTransaction;
                    endif;
                elseif camProtocol.protocolDesc.type = EDIFileTypeCams_SuzanoReceive then
                    if camProtocol.allTrainEventTypes.isEmpty then
                        beginTransaction;
                            camProtocol.allTrainEventTypes.add(app.myRoot.allEventTypesByType [EVT_TruckDeparture]);
                            camProtocol.allTrainEventTypes.add(app.myRoot.allEventTypesByType [EVT_VoyageDeparture]);
                        commitTransaction;
                    endif;
                    
                endif;
			endif;
		endforeach;
	endforeach;
epilog
end;</source>
    </JadeMethod>
