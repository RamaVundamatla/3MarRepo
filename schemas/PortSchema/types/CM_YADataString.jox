    <JadeMethod name="validate" id="5723507c-6c85-4d3a-9f4c-ec542ea5260f">
        <source>validate();
//14 December 2009	cnwml2


vars
	pattern : CMIF_YAPattern;
begin
	create pattern transient;
	if self.myCriteriaType &lt;&gt; null then
		pattern.setPattern(self.value, myCriteriaType.getPatternType);
		if not pattern.validate(pattern.pattern,null) then
			app.raiseCMException2(ErrInvalidYACriteriaPattern,self.myCriteriaType.description, self.value, null, null);
		endif;	
	endif;

epilog
	delete pattern;
end;</source>
    </JadeMethod>
