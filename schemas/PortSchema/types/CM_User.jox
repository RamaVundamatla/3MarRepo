// Parameters:	None
// Returns:			Nothing
// Changed On	Changed By		Reason
// ----------			----------			--------------------------------------------------
//
// ---------------------------------------------------------------------------
begin
	self.status := _value;
end;</source>
        <Parameter name="_value" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="updateUserWindow" id="ea2afba7-a06f-440c-813d-58ebd7cb907e">
        <source>updateUserWindow(_pxyUserWindow : CM_UserWindow);
// ---------------------------------------------------------------------------
// Created:     09 May 2001 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
20 Dec 2013	cnwkpd1	PAR #33225 - Deadlock error during RIA signoff with multiple open windows
	
*/

vars
	realUserWindow	: CM_UserWindow;
	
begin
	// PAR #33225 - Prevent upgrade deadlock on allUserWindowsForOpen collection
	reserveLock(self.allUserWindowsForOpen);
	
	realUserWindow := self.allUserWindowsForOpen[_pxyUserWindow.windowClassName];
	if realUserWindow = null then
		create realUserWindow as CM_UserWindowForOpen persistent;
		realUserWindow.setForCreate(_pxyUserWindow, self);
	else
		realUserWindow.setForUpdate(_pxyUserWindow);
	endif;
end;</source>
        <Parameter name="_pxyUserWindow" type="CM_UserWindow"/>
    </JadeMethod>
    <JadeMethod name="useCaseSensitive" id="9bfc36ae-99ad-417b-aefd-d4e80e9cb2a6">
        <source>useCaseSensitive(): Boolean;

vars
	setPasswordComplex : Boolean;
begin
	//AER 14 June 2007
	//assume that the passord is not strong by default.
	setPasswordComplex := false;
	// check to see if all the MinUpperChars, MinLowerChars, MinNumberChars, MinSpecialChars are 0
	// which means that in the Terminal Configuration there is no specification for a strong password
	
	  if (app.myRoot.getConfig(MinUpperChars).Integer &lt;&gt; 0) or 
	     (app.myRoot.getConfig(MinLowerChars).Integer &lt;&gt; 0) then
		 //(app.myRoot.getConfig(MinNumberChars).Integer &lt;&gt; 0) or 
		 //(app.myRoot.getConfig(MinSpecialChars).Integer &lt;&gt; 0) then
	  // if any of the settings is different from 0 then the passord must be strong defined.
			setPasswordComplex :=true;
	  endif;
	
	return setPasswordComplex;
end;
</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="useStrongPassord" id="6d382eeb-b158-4e1f-86cc-9048910f27ae">
        <source>useStrongPassord():Boolean;
// ---------------------------------------------------------------------------
// Created:     05 April 2007 by cnwaer1
//
// Purpose:     
// ---------------------------------------------------------------------------
// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
vars

begin
	if (self.datePassword.date &gt; app.actualTimeServer.addMonths(1).date) or (self.userName.toUpper() &lt;&gt; SUPERUSER_Str) then// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
		return true;
	else 
	    return false;
	endif;
end;
</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="b081848c-9722-45cd-b457-bd8ad7bcccda">
        <source>validateForCreate(_passport : CM_Passport);

// 09/12/2014 cnwdb2 PAR 35364
vars

begin

	if app.myRoot.allUsers[self.code.toUpper] &lt;&gt; null then
	//	app.raiseCMException3(ERR_DUPLICATE_KEY,"User",self.code.toUpper,null,null,null);
		app.raiseCMException1(Already_exists_user,self.code.toUpper,null,null); //cnwdb2 PAR 35364
	endif;

	self.validateMe(_passport);
end;</source>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="validateForDelete" id="c6bce358-07ad-4b17-9e97-0e9a2cbc8533">
        <source>validateForDelete();

/*
Date		Who		TFS		Reason
29 Aug 2019	jlgdi1	45802	Added an exception when deleting JMTSUPPORT user
19 Sep 2019	jlgzm1	46636	Deleting a user assigned to a BGP Controller breaks it
19 Jun 2020 jlgmd1	49615	Add validation to prevent 'important system' users from being disabled/deleted
21 Sep 2020 cnwma1		    ChangeRequest 49758: MTN - Navis Smart Data API - Snapshot Data
*/

vars
	/*int : Integer;
	machine	: CM_Machine;
	machineDict	: CM_MachineByIdTerminalDict;	// 29099
	bgpManager :	BGP_Manager;		// TFS 46636
	bgpController :  BGP_Controller;	// TFS 46636*/
begin
	//Don't delete superuser as we need it for releases and development.
	if self.isInternalSystemUser() then
		app.raiseCMException(SystemUserCannotBeDeleted, null, self);
	endif;
	
	if self.isLoggedIn() then
		app.raiseCMException(ERR_USER_LOGGEDON,null,self);
	endif;

	if (not self.allEventRequestsNotify.isEmpty)
	or (not self.allEventRequestsStops.isEmpty) then	
		app.raiseCMWarning(EventRequestForUser, null, null, self);
	endif;	
	
	// TFS 49615 Moved to validateNotInUse
	// PAR 22351 - Do it this way so we only call the collection size once.
	/*int := self.allReportsToRunForUser.size();
	if int &gt; 0 then
		app.raiseCMException2(UserRunReportsErr, self.code, int.String, null, self);
	endif;

	// 29211 Mar 2012 can't delete if logged onto a machine
	machineDict := app.myRoot.allMachines;
	foreach machine in machineDict do
		if machine.user = self then
			app.raiseCMException1(User_logged_machin_cannot_dele, self.code, null, self);
		endif;
	endforeach;
	
	// don't delete if assigned to a BGP Controller
	foreach bgpManager in app.myRoot.allBGPManagers do				// TFS 46636
		foreach bgpController in bgpManager.allBGPControllers do	// TFS 46636
			if bgpController.myUser = self then						// TFS 46636
				app.raiseCMException1(User_assigned_bgp_controller, bgpController.displayString, null, self);			// TFS 46636
			endif;
		endforeach;
	endforeach;*/
	
	app.setContinueCMExceptions(true);	// show all errors for this user, not just the first one
	self.validateNotInUse(self, false);
	app.setContinueCMExceptions(false);
	
end;</source>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="635ee09c-c87d-43d3-aa08-2b8b0a5b221d">
        <source>validateForUpdate(_realUser : CM_User; _passport : CM_Passport);

vars
	realDAC,
	pxyDAC		: CM_DataAccessController;
	ssoUser		: CM_User;
	allSsoUsers : CM_UsersBySSOIdEmailDict;
begin
	
	// User doing the updating doesn't have access to update this user
	if (not _realUser.canUserUpdateMe(_passport.myUser)) then
		app.raiseCMException1(NoPermission, 'update user ' &amp; self.code, null, null);
		return;
	endif;
	
	// Changing security roles to something the updating user doesn't have
	if self.mySystemSecurityRole &lt;&gt; null and
	   self.mySystemSecurityRole &lt;&gt; _realUser.mySystemSecurityRole and
	   self.mySystemSecurityRole &lt;&gt; _passport.myUser.mySystemSecurityRole then
		
		// If the new role isn't a child of what the editing user has then raise an error
		if (not self.mySystemSecurityRole.isChildOf(_passport.myUser.mySystemSecurityRole))
		and not _passport.myUser.mySystemSecurityRole.allChildMaintenanceRoles.includes( app.myRoot.mySecurityRoleSystem )	//26 Jun 2018	NDL	TFS 38768
		then
		
			// TFS 42655 the user editing must have my system security role in their 'editable' list
			if  not _passport.myUser.mySystemSecurityRole.allChildMaintenanceRoles.includes(self.mySystemSecurityRole )	then // TFS 42655
				app.raiseCMException1(NoPermission, 'set user ' &amp; self.code &amp; ' to system security role ' &amp; self.mySystemSecurityRole.name, ETRow_SystemSecurityRole, null);
				return;
			endif;
		endif;
	endif;
	
	if _passport.myUser = _realUser and		// user is updating themselves
	   _realUser.mySystemSecurityRole = app.myRoot.mySecurityRoleSystem and	// has root security role
	   self.mySystemSecurityRole &lt;&gt; _realUser.mySystemSecurityRole then		// role has been changed
		app.raiseCMException(ErrCannotTakeRootRoleFromSelf, ETRow_SystemSecurityRole, null);
	endif;

	// Only allow 'System Root' users to change data access controllers
	if _passport.myUser.mySystemSecurityRole &lt;&gt; app.myRoot.mySecurityRoleSystem
	and not _passport.myUser.mySystemSecurityRole.allChildMaintenanceRoles.includes( app.myRoot.mySecurityRoleSystem )	//14 Feb 2018	NDL	TFS 36947
	then
	
	
		// TFS 42655 the user editing must have my system security role in their 'editable' list
		if  not _passport.myUser.mySystemSecurityRole.allChildMaintenanceRoles.includes(self.mySystemSecurityRole )	then // TFS 42655
	
			// only system root role users can change other users data access controllers
			if _realUser.allDataAccessControllers.size &lt;&gt; self.allDataAccessControllers.size then
				app.raiseCMException1(NoPermission, 'update user ' &amp; self.code &amp; ' data access restrictions', ETRow_SystemSecurityRole, null);
			else
				foreach realDAC in _realUser.allDataAccessControllers do
					pxyDAC := self.allDataAccessControllers[realDAC.classContainedName];
					if pxyDAC = null or (pxyDAC &lt;&gt; null and realDAC &lt;&gt; pxyDAC) then
						app.raiseCMException1(NoPermission, 'update user ' &amp; self.code &amp; ' data access restrictions', ETRow_SystemSecurityRole, null);
					endif;
				endforeach;
			endif;
		endif;
	endif;
	
	// TFS 49615 If we're disabling the user, then make sure its not currently in use
	if self.isDisabled and not _realUser.isDisabled then
		self.validateNotInUse(_realUser, true);
	endif;
	
	// Prevent changing 'special' users statuses
	if self.isInternalSystemUser() and
	( self.status &lt;&gt; _realUser.status or self.isNotAvailableForEntry &lt;&gt; _realUser.isNotAvailableForEntry ) and 
	not app.isSpecial then	//17 Jun 2021	NDL	TFS 51310
		app.raiseCMException1(NoPermission, 'update user ' &amp; self.code, null, null);
		return;
	endif;
	
	// 30/03/2023	TFS 57335 Check for existing SSO matching ID to avoid 1310
	// If the SSO Matching ID has changed, make sure no one else is using it.
	// We're not currently, but perhaps we should actually be clearing that after linking the UID
	if self.ssoMatchingId &lt;&gt; null and self.ssoMatchingId &lt;&gt; _realUser.ssoMatchingId then
		allSsoUsers := app.myRoot.allUsersBySSOIdEmail;
		foreach ssoUser in allSsoUsers discreteLock where ssoUser.ssoMatchingId = self.ssoMatchingId do
			if ssoUser &lt;&gt; null and ssoUser.ssoMatchingId = self.ssoMatchingId then
				app.raiseCMException3(ERR_SSO_UPN_Already_exists, app.getEntTableRowTranslation(ETRow_SsoMatchingId, ETGrp_UserMaint), self.ssoMatchingId, ssoUser.code, null, null);
			endif;
			// Because ssoMatchingId is a key, JADE optomises this to only contain the relevant entries
			// Meaning this should be redudnant, but belts and breaces and all that
			break;
		endforeach;
	endif;
	
	self.validateMe(_passport);
end;</source>
        <Parameter name="_realUser" type="CM_User"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="validateMe" id="f6d14116-7918-4811-856a-dce9a203ee1f">
        <source>validateMe(_passport : CM_Passport) protected;
// 29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
// 01 Oct 2019	jlgdi1		45802 Include JMTSupport user to skip the validation checks
// 05/10/2020	jlgmd1		49758 Move 'special' user checking to one place
// 07/11/2025	navlw1		JIRA-36547: Validation is not displaying and the system allows creating a new user without a 'System Security Role' value
// 18/11/2025	navlw1		JIRA-36674: UE 96966 When Initialising Root
vars
	tmpUT			: CM_UserTerminal;
	passportUser	: CM_User;
	passportDAC,
	userDAC			: CM_DataAccessController;
	passportOrg,
	userOrg			: CM_Organisation;
	failedDAC  :CM_DataAccessController;

begin
	if self.code.trimBlanks = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'User Code', ETRow_Code, null);
		app.raiseCMException(Input_required_field_userCode, ETRow_Code, null); // cnwdb2	PAR 35364
	endif;
	

	if not self.isInternalSystemUser() then
		if self.myOrganisation = null then
		//	app.raiseCMException1(REQUIRED_FIELD, 'Organisation', ETRow_MyOrganisation, null);
			app.raiseCMException(Input_required_field_org, ETRow_MyOrganisation, null); // cnwdb2	PAR 35364
		elseif (not self.myOrganisation.canUserAccessSelf(null, failedDAC, _passport)) then
			app.raiseCMException1(NoPermission, 'set user ' &amp; self.code &amp; ' to organisation ' &amp; self.myOrganisation.name, ETRow_MyOrganisation, null);
		// do NOT do this anymore as due to 6-&gt;7 upgrade 'external' users
		// were created as internal =&gt; cannot update
		//elseif self.myOrganisation.isExternal and (not self.isExternal) then
		//	app.raiseCMException2(IntUserCannotBelongToExtOrg, self.code, self.myOrganisation.name, ETRow_MyOrganisation, null);
		endif;

		passportUser := _passport.myUser;
		
		if passportUser.mySystemSecurityRole &lt;&gt; app.myRoot.mySecurityRoleSystem
		and not passportUser.mySystemSecurityRole.allChildMaintenanceRoles.includes( app.myRoot.mySecurityRoleSystem )	//14 Feb 2018	NDL	TFS 36947
		then
			// TFS 42655 the user editing must have my system security role in their 'editable' list
			if  not passportUser.mySystemSecurityRole.allChildMaintenanceRoles.includes(self.mySystemSecurityRole )	then // TFS 42655
				// If user updating does not have root rights then data access controllers must
				// be set to the same as the updating user
				if passportUser.allDataAccessControllers.size &lt;&gt; self.allDataAccessControllers.size then
					app.raiseCMException2(ErrUserMustHaveSameDACs, passportUser.code, self.code, null, null);
				else
					foreach passportDAC in passportUser.allDataAccessControllers do
						userDAC := self.allDataAccessControllers[passportDAC.classContainedName];
						if userDAC = null or (userDAC &lt;&gt; null and userDAC &lt;&gt; passportDAC) then
							app.raiseCMException2(ErrUserMustHaveSameDACs, passportUser.code, self.code, null, null);
							break;
						endif;
					endforeach;
				endif;
			endif;
			// need to check respective organisations here as well.
			if _passport.noErrors then
				passportOrg	:= passportUser.myOrganisation;
				userOrg		:= self.myOrganisation;
				if passportOrg &lt;&gt; userOrg then
					foreach passportDAC in passportOrg.allDataAccessControllers do
						userDAC := userOrg.allDataAccessControllers[passportDAC.classContainedName];
						if userDAC = null or (userDAC &lt;&gt; null and userDAC &lt;&gt; passportDAC) then
							app.raiseCMException2(ErrUserMustHaveSameOrgDACs, passportOrg.name, self.code, null, null);
							break;
						endif;
					endforeach;
				endif;
			endif;
		endif;
	endif;
	
	if self.myRoot = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'User Root', null, null);
		app.raiseCMException(Input_required_field_UserRoot, null, null); // cnwdb2	PAR 35364
	endif;
	
	if not self.isInternalSystemUser() then 							// navlw1 JIRA-36674 18/11/2025
		if self.mySystemSecurityRole = null then
			app.raiseCMException(User_Security_Role_Not_Set,null,null); // navlw1 JIRA-36547 07/11/2025	
		endif;
		//cmwrs1 6/8/2002 this dosn't work for creation of superuser in CMS_InitialForm
		foreach tmpUT in self.allUserTerminals do
			tmpUT.validateMe();
		endforeach;
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="validateNotInUse" id="df10501f-0691-4b7c-8f1a-b31f611041fb">
        <source>validateNotInUse(_realUser : CM_User; _warnings : Boolean);
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
19 June 2020	jlgmd1	TFS 49615 Prevent 'important' users from being diabled

*/

vars
	config			: CM_WebSiteConfig;
	bgpManager		: BGP_Manager;
	bgpController	: BGP_Controller;
	numReports		: Integer;
	machine			: CM_Machine;
	machineDict		: CM_MachineByIdTerminalDict;
	autoTask 		: CM_AutoTask;	//12 Jan 2021	NDL	TFS 50602
begin
	// Check Web Service configs
	foreach config in app.myRoot.allWebSiteConfigs do	// lock out anyone adding new configs while we do this
		if _realUser.code = config.publicUser then	// :'( its stored as a string!
			if _warnings then
				// Warn users this is a bad idea and their webservices will not function correctly
				app.raiseCMWarning2(UserInUseByWebConf, _realUser.code, config.name, null, null, config);
				// %1 is currently being used by Web Configuration %2. If you disable this user then your Web Services will not function correctly.
			else
				app.raiseCMException2(UserInUseByWebConf, _realUser.code, config.name, null, config);
			endif;
		endif;
	endforeach;
	
	// Check BGP Controllers
	foreach bgpManager in app.myRoot.allBGPManagers do
		foreach bgpController in bgpManager.allBGPControllers do
			if bgpController.myUser = _realUser then
				if _warnings then
					// Warn users that this is *probably* a bad idea too
					app.raiseCMWarning2(UserInUseByBGP, _realUser.code, bgpController.displayString, null, null, bgpController);
					// %1 is currently being used by BGP Controller %2. If you disable this user then your BGP tasks may not function correctly.
				else
					// Moved from validateForDelete
					app.raiseCMException1(User_assigned_bgp_controller, bgpController.displayString, null, _realUser);
				endif;
			endif;
		endforeach;
	endforeach;
	
	//Make more Steve proof	12 Jan 2021	NDL	TFS 50602
	foreach autoTask in app.myRoot.allAutoTasks do
		if autoTask.myUser = self then
			app.raiseCMException1(User_assigne_more_tasks, _realUser.code, null, _realUser);
			break;
		endif;
	endforeach;
	
	// Check Reports
	numReports := self.allReportsToRunForUser.size();
	if numReports &gt; 0 then
		if _warnings then
			// Warn users that these reports will not function as intended (no access)
			app.raiseCMWarning2(UserInUseByReports, _realUser.code, numReports.String, null, null, null);
			// %1 has %2 report template(s). If you disable this user the reports may not function correctly.
		else
			// Moved from validateForDelete
			app.raiseCMException2(UserRunReportsErr, _realUser.code, numReports.String, null, _realUser);
		endif;
	endif;
	
	// Machines
	machineDict := app.myRoot.allMachines;
	foreach machine in machineDict do
		if machine.user = _realUser then
			if _warnings then
				// Do we care ?
			else
				// Moved from validateForDelete
				app.raiseCMException1(User_logged_machin_cannot_dele, _realUser.code, null, _realUser);
			endif;
		endif;
	endforeach;
	
epilog

end;</source>
        <Parameter name="_realUser" type="CM_User"/>
        <Parameter name="_warnings" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validatePassword" id="3ca7c831-c807-4797-a897-a2df164199b1">
        <source>validatePassword(_value : String) protected;
// ---------------------------------------------------------------------------
// Created:			06 April 2001 by cnwdwq1
// Purpose:			!     
// Parameters:	None
// Returns:			Nothing
// Changed On	Changed By		Reason
// ----------			----------			--------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	minLengthPsw : Integer;
begin
	minLengthPsw :=app.myRoot.getConfig(MinLengthPassword).Integer;
	// check password format for a new user only
	if _value.length &lt; minLengthPsw or _value.length &gt; self.MaxPasswordLength then
		app.setContinueCMExceptions(false);
		app.raiseCMException2(InvalidPasswordLength, minLengthPsw.String, MaxPasswordLength.String ,null, null);
		return;	
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_value" type="String"/>
    </JadeMethod>
    <JadeMethod name="validatePasswordChange" id="c01aa756-0191-41bd-b9cf-c351f3258b16">
        <updating/>
        <source>validatePasswordChange(checkOldPassword : Boolean; pOldPass, pNewPass, pNewPass2 : String) updating;
// ---------------------------------------------------------------------------
// Created:     07 March 2001 by cnwrs2
//
// Purpose:     
// validate the old and new passwords prior to a password change
// note an old password is not checked if a superuser is resetting another users' password 
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	
begin
	if checkOldPassword then
		// check the old password is correct
		if not self.isValidPassword(pOldPass) then
			app.setContinueCMExceptions(false);
			app.raiseCMException(ERR_INVALID_PASSWORD, null, null);
			return;
		endif;
	endif;

	//  --- authenticated with old pasword ---

	// check the new passwords match
	if pNewPass &lt;&gt; pNewPass2 then
		app.setContinueCMExceptions(false);
		app.raiseCMException(ERR_PSWDS_DIFFER, null, null);
		return;
	endif;

	// check the new password length
	self.validatePassword(pNewPass);

	// PAR 12373 - need to remove usage of checkOldPassword if
	// user is changing.

	if app.encryptPassword(self.code, pNewPass, self.isNewEncryptionImplemented) = self.currentPassword then
		app.setContinueCMExceptions(false);
		app.raiseCMException(UserPWOldIsNew, null, null);
		return;
	endif;

	// check the new password is not a recently used password
	
	if self.isRecentlyUsedPassword(pNewPass) then
		app.setContinueCMExceptions(false);
		app.raiseCMException(ERR_PASSWORD_UNCHANGED, null, null);
		return;		
	endif;

	/*
	PAR 12373 - commented out this - replaced with code above
	if checkOldPassword then
		// check the new password has changed

		if pOldPass = pNewPass then
			app.setContinueCMExceptions(false);
			app.raiseCMException(UserPWOldIsNew, null, null);
			return;
		endif;
	
		// check the new password is not a recently used password
		if self.isRecentlyUsedPassword(pNewPass) then
			app.setContinueCMExceptions(false);
			app.raiseCMException(ERR_PASSWORD_UNCHANGED, null, null);
			return;		
		endif;
	endif;
	*/
end;</source>
        <Parameter name="checkOldPassword" type="Boolean"/>
        <Parameter name="pOldPass" type="String"/>
        <Parameter name="pNewPass" type="String"/>
        <Parameter name="pNewPass2" type="String"/>
    </JadeMethod>
</Class>
