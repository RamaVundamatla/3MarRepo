    <JadeMethod name="addDelayType" id="4c713f7b-fe94-4bcb-9281-bc27acf02fa9">
        <source>addDelayType(_delayTypeDescription : String) : CM_DelayType;

/*

Purpose:		Add delay type

Date			Who		Reason
27/02/2014		cnwmh5	Initial creation

*/

vars

	delayType						: CM_DelayType;
	pxyDelayType					: CM_DelayType;
	
	allDelayTypeGroups				: CM_DelayTypeGroupSet;
	
	refersToVoyage					: Boolean;
	isOperational					: Boolean;
	canScheduleInAdvance			: Boolean;
	refersToMachine					: Boolean;
	delayTypeOrder					: Integer;
	
begin

	self.deleteDelayType(_delayTypeDescription);


	create allDelayTypeGroups transient;
	
	// 13/03/2018 jlgmh5
	if self.opts.includesKey("RefersToVoyage") then
		refersToVoyage := self.opts.bool("RefersToVoyage").Boolean;
	endif;
	
	if self.opts.includesKey("IsOperational") then
		isOperational := self.opts.bool("IsOperational").Boolean;
	endif;
	
	if self.opts.includesKey("CanSchduleInAdvance") then
		canScheduleInAdvance := self.opts.bool("CanSchduleInAdvance").Boolean;
	endif;
	
	if self.opts.includesKey("RefersToMachine") then
		refersToMachine := self.opts.bool("RefersToMachine").Boolean;
	endif;
	
	if self.opts.includesKey("DelayTypeOrder") then
		delayTypeOrder := self.opts.int("DelayTypeOrder").Integer;
	endif;

	create pxyDelayType transient;
	pxyDelayType.setProxy(app.myRoot, 						
		allDelayTypeGroups,						// DelayTypeGroupSet
		null,									// MachineAvailability
		_delayTypeDescription,								
		false, 
		refersToMachine,
		refersToVoyage,
		false,
		isOperational,
		canScheduleInAdvance, 
		delayTypeOrder);

	app.myTrxCA.trxCreateDelayType(pxyDelayType, delayType, app.myPassport);	
	self.assertNoTrxErrorsOrWarnings();
	
	return delayType;
		
epilog

	delete pxyDelayType;
	delete allDelayTypeGroups;

end;</source>
        <Parameter name="_delayTypeDescription" type="String"/>
        <ReturnType type="CM_DelayType"/>
    </JadeMethod>
    <JadeMethod name="addDeliveryReleaseReason" id="2c3a5c11-831c-4068-be68-e8b11823c98b">
        <source>addDeliveryReleaseReason(_delReleaseReasonName : Integer; _delReleaseReasonDesc : String) : CM_DeliveryReleaseReason;

/*

Purpose:			

Parameters:			

Return Value:		


Date			Who		Reason
12 January 2012	cnwmh5	Initial creation

*/

vars

	pxyDeliveryReleaseReason			: CM_DeliveryReleaseReason;
	deliveryReleaseReason				: CM_DeliveryReleaseReason;
	

begin

	self.deleteDeliveryReleaseReason(_delReleaseReasonName.Integer);

