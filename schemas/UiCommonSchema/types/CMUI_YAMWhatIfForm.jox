    <JadeMethod name="addCriteriaFrame" id="a4597022-8e73-469b-ae2b-0441d53b5d2a">
        <updating/>
        <source>addCriteriaFrame(_i: Integer; _tabIndex: Integer io): CMUI_YACriteriaCntl updating;
// 24 Jun 2013	cnwcs5	par 31712
vars
	criteriaFrame: CMUI_YACriteriaCntl;
	width: Integer;
	scrollheight : Integer;
begin
	//width 			:= self.shtCriteria.width.Integer - 10;	// par 31712
	criteriaFrame 	:= self.frmCriteria.getControl(_i).CMUI_YACriteriaCntl;
	
	if criteriaFrame = null then
		criteriaFrame := self.frmCriteria.loadControl(_i).CMUI_YACriteriaCntl;
		criteriaFrame.parentRightOffset:=10;
		criteriaFrame.txtCriteriaValue.parentAspect:=Control.ParentAspect_StretchRight;
		criteriaFrame.btnValuePicker.parentAspect:=Control.ParentAspect_AnchorRight;
		
	endif;
	
	//08 Oct 2013	NDL	Par 32456
	width := self.picCriteria.clientWidth.Integer;
	criteriaFrame.parent := self.picCriteria;
	
	criteriaFrame.setLabelVisible(false);
	
	criteriaFrame.visible := true;
	
	criteriaFrame.setWidth(width);
	
	criteriaFrame.width := width;
		
	criteriaFrame.setTabIndex(_tabIndex);

	criteriaFrame.top := ((_i - 1) * criteriaFrame.height);


	//08 Oct 2013	NDL	Par 32456
	scrollheight := ((criteriaFrame.top - picCriteria.height).Integer + criteriaFrame.height + 10 ).Integer;
	if scrollheight &lt; 0 then
		scrollheight := 0;
	endif;
	
	self.picCriteria.setScrollRange(ScrollBar_Vertical, 0, scrollheight, 20, 100);
	
	criteriaFrame.setCriteria( null );
	criteriaFrame.setMasterControl(self.frmCriteria);	//cnwmc5 - PAR 31255	
	criteriaFrame.visible := true;
	criteriaFrame.formCriteriaChangeMethodName:=CMUI_YAMWhatIfForm::doCriteriaChanged.name;
	
	self.allClonedFrames.add(criteriaFrame);
	
	
	
	return criteriaFrame;
end;
</source>
        <Parameter name="_i" type="Integer"/>
        <Parameter name="_tabIndex" type="Integer" usage="io"/>
        <ReturnType type="CMUI_YACriteriaCntl"/>
    </JadeMethod>
