    <JadeMethod name="hasEventsOfCategory" id="ad58ebdf-d83d-4807-b52b-138864e7e0c7">
        <source>hasEventsOfCategory(_category : Integer) : Boolean;
/*
Purpose:			
Date		Who		Reason
02 February 2017	cnwab1	Initial creation
*/

vars
	event : CM_EventType;
begin
	foreach event in self.allEventTypes discreteLock do
		if event.category = _category then
			return true;
		endif;
	
	endforeach;
	
	return false;
epilog

end;</source>
        <Parameter name="_category" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="ed2564ba-3b21-4fad-9e88-06e46efe5f7d">
        <source>pxyCreateUpdateProxy(): SelfType;
// ---------------------------------------------------------------------------
// Created:     cnwyl1  Yi Liu
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy
// ---------------------------------------------------------------------------
vars
	eventGroup 		: SelfType;
	completedOK		: Boolean;
begin
	eventGroup := inheritMethod();
	self.allEventTypes.copy(eventGroup.allEventTypes);
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return eventGroup;
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete eventGroup;
	endif;

end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="238febd6-999f-4a4d-8f92-3298be36b552">
        <updating/>
        <source>setForCreate(_pxyEventGroup : CM_EventTypeGroup) updating;
// ---------------------------------------------------------------------------
// Created:     cnwyl1  Yi Liu
//
