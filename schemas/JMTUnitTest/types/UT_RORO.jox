C,A,BOL29246,,,,CANNON,,,,,,,,,,,,AUSYD,D1101G,,,,'&amp;GCCargoId04&amp;',1,,,,,,,,,'&amp;TestOperator&amp;',,,,,,,,,,,,,22111,,,,,'&amp;VoyageName&amp;'
C,A,BOL29246,,,,CANNON,,,,,,,,,,,,AUSYD,D1101G,,,,'&amp;GCCargoId03&amp;',1,,,,,,,,,'&amp;TestOperator&amp;',,,,,,,,,,,,,23555,,,,,'&amp;VoyageName&amp;'
C,A,BOL29246,,,,CANNON,,,,,,,,,,,,AUSYD,D1101G,,,,'&amp;GCCargoId02&amp;',1,,,,,,,,,'&amp;TestOperator&amp;',,,,,,,,,,,,,26748,,,,,'&amp;VoyageName&amp;'
C,A,BOL29246,,,,CANNON,,,,,,,,,,,,AUSYD,D1101G,,,,'&amp;GCCargoId01&amp;',1,,,,,,,,,'&amp;TestOperator&amp;',,,,,,,,,,,,,19558,,,,,'&amp;VoyageName&amp;'
C,A,BOL29246,,,,CONT,,,GENL,,,,,,1003,,,AUSYD,D1055R,,,,'&amp;FlatId01&amp;',1,4260,,,,,,,,'&amp;TestOperator&amp;',,,,,,,,,,,,,12589,,,,,'&amp;VoyageName&amp;'
C,A,BOL29246,,,,CONT,,,GENL,,,,,,1003,,,AUSYD,D1055R,,,,'&amp;FlatId02&amp;',1,4260,,,,,,,,'&amp;TestOperator&amp;',,,,,,,,,,,,,12589,,,,,'&amp;VoyageName&amp;',,,,,'&amp;FlatId01&amp;',CONT,
C,A,BOL29246,,,,CONT,,,GENL,,,,,,1003,,,AUSYD,D1055R,,,,'&amp;FlatId03&amp;',1,4260,,,,,,,,'&amp;TestOperator&amp;',,,,,,,,,,,,,12589,,,,,'&amp;VoyageName&amp;',,,,,'&amp;FlatId01&amp;',CONT
C,A,BOL29246,,,,CONT,,,GENL,,,,,,1003,,,AUSYD,D1055R,,,,'&amp;FlatId04&amp;',1,4260,,,,,,,,'&amp;TestOperator&amp;',,,,,,,,,,,,,12589,,,,,'&amp;VoyageName&amp;',,,,,'&amp;FlatId01&amp;',CONT
C,A,BOL29246,,,,CONT,,,GENL,,,,,,1003,,,AUSYD,D1055R,,,,'&amp;FlatId05&amp;',1,4260,,,,,,,,'&amp;TestOperator&amp;',,,,,,,,,,,,,12589,,,,,'&amp;VoyageName&amp;',,,,,'&amp;FlatId01&amp;',CONT
C,A,BOL29246,,,,CONT,,,GENL,,,,,,1003,,,AUSYD,D1055R,,,,'&amp;FlatId06&amp;',1,4260,,,,,,,,'&amp;TestOperator&amp;',,,,,,,,,,,,,12589,,,,,'&amp;VoyageName&amp;',,,,,'&amp;FlatId01&amp;',CONT
C,A,BOL29246,,,,CONT,,,GENL,,,,,,1003,,,AUSYD,D1055R,,,,'&amp;FlatId07&amp;',1,4260,,,,,,,,'&amp;TestOperator&amp;',,,,,,,,,,,,,12589,,,,,'&amp;VoyageName&amp;',,,,,'&amp;FlatId01&amp;',CONT
L,D2008,S,,Yes,2X5
C,A,BOL29246,,,,CONT,,,GENL,,,,,,40BX,,,AUSYD,D2008R,,,,'&amp;ContainerId03&amp;',1,4200,,,,,,,,'&amp;TestOperator&amp;',,,,,,,,,,,,,12589,,,,,'&amp;VoyageName&amp;'
C,A,BOL29246,,,,CONT,,,GENL,,,,,,40BX,,,AUSYD,D2008R,,,,'&amp;ContainerId04&amp;',1,4200,,,,,,,,'&amp;TestOperator&amp;',,,,,,,,,,,,,12589,,,,,'&amp;VoyageName&amp;'
C,A,BOL29246,,,,CONT,,,GENL,,,,,,40BX,,,AUSYD,D2032,,,,'&amp;ContainerId05&amp;',1,4200,,,,,,,,'&amp;TestOperator&amp;',,,,,,,,,,,,,12589,,,,,'&amp;VoyageName&amp;'
C,A,BOL29246,,,,CONT,,,GENL,,,,,,40BX,,,AUSYD,D2032,,,,'&amp;ContainerId06&amp;',1,4200,,,,,,,,'&amp;TestOperator&amp;',,,,,,,,,,,,,12589,,,,,'&amp;VoyageName&amp;'
C,A,BOL29246,,,,CONT,,,GENL,,,,,,40BX,,,AUSYD,D2004R,,,,'&amp;ContainerId07&amp;',1,4200,,,,,,,,'&amp;TestOperator&amp;',,,,,,,,,,,,,12589,,,,,'&amp;VoyageName;

/*
L,D12070,G
P,D1207O,1,  78.74,  -5.52,
P,D1207O,2,  81.19,  -5.52,
P,D1207O,3,  81.19,   0.61,
P,D1207O,4,  78.74,   0.61,
P,D1207O,5,  78.74,  -5.52,
*/
	// take the edi Data string make it binary and set up the required EDI Message Type.
	binaryMsg := ediText.Binary;
	bSynchronous := true;									// true = load, false = queue
	messageType := UserDefinedShipManifest[1 : fileTypeUser.name.maxLength];						// ie 63
	idx := idx + 1;
	clientRef := method.name[1 : ediControllerAgent.ediClientRef.maxLength-1]&amp;idx.String;		// ie 30
	ediControllerAgent.setEdiClientRef(clientRef);
	
	// make sure all of the objects are deleted and created correctly.
	ediFile := ediControllerAgent.getEDIFile_By_ediClientRef(clientRef);
	if ediFile &lt;&gt; null then
		beginTransaction;
		if ediFile.ediData = null then
			delete ediFile;
		else
			ediData := ediFile.ediData;
			delete ediData;
		endif;
		commitTransaction;
	endif;
	ediFile := ediControllerAgent.getEDIFile_By_ediClientRef(clientRef);
	if ediFile &lt;&gt; null then
		beginTransaction;
		if ediFile.ediData = null then
			delete ediFile;
		else
			ediData := ediFile.ediData;
			delete ediData;
		endif;
		commitTransaction;
	endif;
	ediFile := ediControllerAgent.getEDIFile_By_ediClientRef(clientRef);
	self.assertIsDeleted(ediFile);

	// Load and DB load the message
	ediControllerAgent.loadMessageFromWeb(messageType, binaryMsg, ediFile, bSynchronous, null); //jlgka1 TFS 45332
	errorStr := 'Failed to load edi data ';
	errorStr :=	errorStr &amp; CrLf &amp; app.myPassport.getAllErrorsWarningsAsString();
	ediControllerAgent.getEDIFile_EDIData_Status();			// gets ediStatusCode and ediStatusDesc
	self.assertEqualMsg(ediControllerAgent.ediStatusCode, CM_EDIFile.EDI_STATUS_DBLOADED.display, errorStr);
	ediFile := ediControllerAgent.getEDIFile_By_ediClientRef(clientRef);

/*	ediFile := self.ediLoadFileName(ediText, EDIFileType_UserDefined, UserDefinedShipManifest, UserDefinedShipManifest&amp;method.name);
	self.assertNotNull(ediFile);
	
	self.clearExpectedTrxErrors();
	self.expectTrxError(WarningPileHeightExceed2);	
	self.ediVerify(ediFile);
	tempStr	:= 'Verify Failed' &amp; CrLf &amp; app.myPassport.getErrorsAsString;
	// status 3 is verify status and 14 is verified warnings
	//self.assertEqualMsg(ediFile.fileStatus, CM_EDIFile.EDI_STATUS_VERIFIED_ERRORS, tempStr);
	self.assertIsOneOf(ediFile.fileStatus, tempStr, CM_EDIFile.EDI_STATUS_VERIFIED, CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS);
	
	self.ediDBLoad(ediFile);
	tempStr	:= 'DB Load Failed' &amp; CrLf &amp; app.myPassport.getErrorsAsString;
	self.assertEqualMsg(ediFile.fileStatus, CM_EDIFile.EDI_STATUS_DBLOADED, tempStr);*/
 
	foreach ediTI in ediFile.ediData.allEDITrackedItems do
		if ediTI.isKindOf(CM_EDIVoyageHeaderTI) then
			voyCountLoad := voyCountLoad + 1;
		elseif ediTI.isKindOf(CM_EDILayoutTI) then
			layoutCountLoad := layoutCountLoad + 1;
		elseif ediTI.isKindOf(CM_EDILayoutPointTI) then
			layoutPointCountLoad := layoutPointCountLoad + 1;
		elseif ediTI.isKindOf(CM_EDICargoOnShipTI) then
			tiCountLoad := tiCountLoad + 1;
		endif;
	endforeach;
	container := self.getTrackedItemOnVoy(ContainerId01, VoyageName).CM_Container;
//	self.assertEqual(container.getHazardsAsString(), "1.1, 1.2 (0450, 0440), 1.3 (0889)");
	create ediDataParams transient;
	ediFileType := app.myRoot.allEDIFileTypeUsersByName[UserDefinedShipManifest];
	if ediFileType &lt;&gt; null then
		clientRefNum := clientRefNum + 1;
		clientRef := method.name[1 : ediControllerAgent.ediClientRef.maxLength-1]&amp;clientRefNum.String;		// ie 30
		ediControllerAgent.setEdiClientRef(clientRef);
		ediData := ediControllerAgent.loadDeckPlanTIs(voyage, ACTUAL_BAYPLANS, clientRef, voyage.myOperator, ediFileType);
		ediDataParams.operator := voyage.myOperator;
		ediFile := ediData.ediFileArray.last;//should be the one we just created 
		ediControllerAgent.extractFile(ediFile, ediData.number, ediDataParams);
	endif;
	foreach ediTI in ediFile.ediData.allEDITrackedItems do
		if ediTI.isKindOf(CM_EDIVoyageHeaderTI) then
			voyCountExtract := voyCountExtract + 1;
		elseif ediTI.isKindOf(CM_EDILayoutTI) then
			layoutCountExtract := layoutCountExtract + 1;
		elseif ediTI.isKindOf(CM_EDILayoutPointTI) then
			layoutPointCountExtract := layoutPointCountExtract + 1;
		elseif ediTI.isKindOf(CM_EDICargoOnShipTI) then
			tiCountExtract := tiCountExtract + 1;
			if ediTI.id = ContainerId01 then
				self.assertEqual(ediTI.CM_EDICargoOnShipTI.getHazardsAsString(), "1.1, 1.2 (0450, 0440), 1.3");
			endif;
		endif;
	endforeach;
	self.assertEqual(voyCountExtract, voyCountLoad);
//	self.assertEqual(layoutCountExtract, layoutCountLoad);//layoutCountLoad);
//	self.assertEqual(layoutPointCountExtract, layoutPointCountLoad); //layoutPointCountLoad);
	self.assertEqual(tiCountExtract, tiCountLoad);
	
	// now check the data lines
	create unloadArray transient;
	unloadArray.add("V,A,UT_EDIPLANS1009,JJRORO");
	unloadArray.add("L,D1099O,S,0.0000,false,");
	unloadArray.add("P,D1099O,1,-0.70,0.00");
	unloadArray.add("P,D1099O,2,5.30,0.00");
	unloadArray.add("P,D1099O,3,5.30,2.40");
	unloadArray.add("P,D1099O,4,-0.70,2.40");
	unloadArray.add("P,D1099O,5,-0.70,0.00");
	unloadArray.add("L,D1101G,S,0.0000,false,");
	unloadArray.add("P,D1101G,1,52.40,-1.70");
	unloadArray.add("P,D1101G,2,60.50,-1.70");
	unloadArray.add("P,D1101G,3,67.50,0.10");
	unloadArray.add("P,D1101G,4,68.20,9.90");
	unloadArray.add("P,D1101G,5,59.00,10.90");
	unloadArray.add("P,D1101G,6,52.40,5.70");
	unloadArray.add("P,D1101G,7,52.40,-1.70");
	unloadArray.add("L,D2008,,0.0000,true,2X5");
	unloadArray.add("C,A,BOL29246,,,,ISO Container,,,GENL,General,,,DFBU,,,,,AUSYD,D1029R1,,0.0000,,OOTL9900342,Remain On Board,4200,0.0000,,,,,,,MSK,,,0.0000,0.0000,0.0000,0.0000,0.0000,00:00:00,,,,,12589,,,,0.000,UT_EDIPLANS1009,,,0.0000,,,,false,,");
	unloadArray.add("C,A,BOL29246,,,,ISO Container,,,GENL,General,,,DFBU,,,,,AUSYD,D1055R1,,0.0000,,LMCU0700020,Remain On Board,4260,0.0000,,,,,,,MSK,,,0.0000,0.0000,0.0000,0.0000,0.0000,00:00:00,,,,,12589,,,,0.000,UT_EDIPLANS1009,,,0.0000,,,,false,,");
	unloadArray.add("C,A,BOL29246,,,,ISO Container,,,GENL,General,,,DFBU,,,,,AUSYD,D1055R1,,0.0000,,LMCU0700035,Remain On Board,4260,0.0000,,,,,,,MSK,,,0.0000,0.0000,0.0000,0.0000,0.0000,00:00:00,,,,,12589,,,,0.000,UT_EDIPLANS1009,,,0.0000,,LMCU0700020,ISO Container,false,,");
	unloadArray.add("C,A,BOL29246,,,,ISO Container,,,GENL,General,,,DFBU,,,,,AUSYD,D1055R1,,0.0000,,LMCU0700040,Remain On Board,4260,0.0000,,,,,,,MSK,,,0.0000,0.0000,0.0000,0.0000,0.0000,00:00:00,,,,,12589,,,,0.000,UT_EDIPLANS1009,,,0.0000,,LMCU0700020,ISO Container,false,,");
	unloadArray.add("C,A,BOL29246,,,,ISO Container,,,GENL,General,,,DFBU,,,,,AUSYD,D1055R1,,0.0000,,LMCU0700056,Remain On Board,4260,0.0000,,,,,,,MSK,,,0.0000,0.0000,0.0000,0.0000,0.0000,00:00:00,,,,,12589,,,,0.000,UT_EDIPLANS1009,,,0.0000,,LMCU0700020,ISO Container,false,,");
	unloadArray.add("C,A,BOL29246,,,,ISO Container,,,GENL,General,,,DFBU,,,,,AUSYD,D1055R1,,0.0000,,LMCU0700060,Remain On Board,4260,0.0000,,,,,,,MSK,,,0.0000,0.0000,0.0000,0.0000,0.0000,00:00:00,,,,,12589,,,,0.000,UT_EDIPLANS1009,,,0.0000,,LMCU0700020,ISO Container,false,,");
	unloadArray.add("C,A,BOL29246,,,,ISO Container,,,GENL,General,,,DFBU,,,,,AUSYD,D1055R1,,0.0000,,LMCU0700077,Remain On Board,4260,0.0000,,,,,,,MSK,,,0.0000,0.0000,0.0000,0.0000,0.0000,00:00:00,,,,,12589,,,,0.000,UT_EDIPLANS1009,,,0.0000,,LMCU0700020,ISO Container,false,,");
	unloadArray.add("C,A,BOL29246,,,,ISO Container,,,GENL,General,,,DFBU,,,,,AUSYD,D1055R1,,0.0000,,LMCU0700080,Remain On Board,4260,0.0000,,,,,,,MSK,,,0.0000,0.0000,0.0000,0.0000,0.0000,00:00:00,,,,,12589,,,,0.000,UT_EDIPLANS1009,,,0.0000,,LMCU0700020,ISO Container,false,,");
	unloadArray.add("C,A,BOL29246,,,,ISO Container,,,GENL,General,,,DFBU,,,,,AUSYD,D1099O,1.1 1.2:+0450 1.2:+0440 1.3,0.0000,,OOTL9900341,Remain On Board,4200,0.0000,,,,,,,MSK,,,0.0000,0.0000,0.0000,0.0000,0.0000,00:00:00,,,,,14777,,,,0.000,UT_EDIPLANS1009,,,0.0000,,,,false,,");
	unloadArray.add("C,A,BOL29246,,,,Cannon,,,,,,,DFBU,,,,,AUSYD,D1101G,,0.0000,,GCGC2277884,Remain On Board,,0.0000,,,,,,,MSK,,,,,,,,00:00:00,,,,,22111,,,,0.000,UT_EDIPLANS1009,,,0.0000,,,,false,,");
	unloadArray.add("C,A,BOL29246,,,,Cannon,,,,,,,DFBU,,,,,AUSYD,D1101G,,0.0000,,GCGC2277883,Remain On Board,,0.0000,,,,,,,MSK,,,,,,,,00:00:00,,,,,23555,,,,0.000,UT_EDIPLANS1009,,,0.0000,,,,false,,");
	unloadArray.add("C,A,BOL29246,,,,Cannon,,,,,,,DFBU,,,,,AUSYD,D1101G,,0.0000,,GCGC2277882,Remain On Board,,0.0000,,,,,,,MSK,,,,,,,,00:00:00,,,,,26748,,,,0.000,UT_EDIPLANS1009,,,0.0000,,,,false,,");
	unloadArray.add("C,A,BOL29246,,,,Cannon,,,,,,,DFBU,,,,,AUSYD,D1101G,,0.0000,,GCGC2277881,Remain On Board,,0.0000,,,,,,,MSK,,,,,,,,00:00:00,,,,,19558,,,,0.000,UT_EDIPLANS1009,,,0.0000,,,,false,,");
	unloadArray.add("C,A,BOL29246,,,,ISO Container,,,GENL,General,,,DFBU,,,,,AUSYD,D20041R,,0.0000,,OOTL9900347,Remain On Board,4200,0.0000,,,,,,,MSK,,,0.0000,0.0000,0.0000,0.0000,0.0000,00:00:00,,,,,12589,,,,0.000,UT_EDIPLANS1009,,,0.0000,,,,false,,");
	unloadArray.add("C,A,BOL29246,,,,ISO Container,,,GENL,General,,,DFBU,,,,,AUSYD,D20081R,,0.0000,,OOTL9900343,Remain On Board,4200,0.0000,,,,,,,MSK,,,0.0000,0.0000,0.0000,0.0000,0.0000,00:00:00,,,,,12589,,,,0.000,UT_EDIPLANS1009,,,0.0000,,,,false,,");
	unloadArray.add("C,A,BOL29246,,,,ISO Container,,,GENL,General,,,DFBU,,,,,AUSYD,D20082R,,0.0000,,OOTL9900344,Remain On Board,4200,0.0000,,,,,,,MSK,,,0.0000,0.0000,0.0000,0.0000,0.0000,00:00:00,,,,,12589,,,,0.000,UT_EDIPLANS1009,,,0.0000,,,,false,,");
	unloadArray.add("C,A,BOL29246,,,,ISO Container,,,GENL,General,,,DFBU,,,,,AUSYD,D20321,,0.0000,,OOTL9900345,Remain On Board,4200,0.0000,,,,,,,MSK,,,0.0000,0.0000,0.0000,0.0000,0.0000,00:00:00,,,,,12589,,,,0.000,UT_EDIPLANS1009,,,0.0000,,,,false,,");
	unloadArray.add("C,A,BOL29246,,,,ISO Container,,,GENL,General,,,DFBU,,,,,AUSYD,D20322,,0.0000,,OOTL9900346,Remain On Board,4200,0.0000,,,,,,,MSK,,,0.0000,0.0000,0.0000,0.0000,0.0000,00:00:00,,,,,12589,,,,0.000,UT_EDIPLANS1009,,,0.0000,,,,false,,");
	unloadArray.add("L,D1058O,S,0.0000,false,");
	unloadArray.add("P,D1058O,1,-6.70,0.00");
	unloadArray.add("P,D1058O,2,-0.80,0.00");
	unloadArray.add("P,D1058O,3,-0.80,2.40");
	unloadArray.add("P,D1058O,4,-6.70,2.40");
	unloadArray.add("P,D1058O,5,-6.70,0.00");
//	unloadArray.add("L,D1060O,G,0,false,");
//	unloadArray.add("P,D1060O,1,0,0");
//	unloadArray.add("P,D1060O,2,0,0");
//	unloadArray.add("P,D1060O,3,0,2.4");
//	unloadArray.add("P,D1060O,4,0,2.4");
//	unloadArray.add("P,D1060O,5,0,0");
	//unloadArray.add("L,D1099O,S,0,false,");
	//unloadArray.add("P,D1099O,1,-0.7,0");
	//unloadArray.add("P,D1099O,2,5.3,0");
	//unloadArray.add("P,D1099O,3,5.3,2.4");
	//unloadArray.add("P,D1099O,4,-0.7,2.4");
	//unloadArray.add("P,D1099O,5,-0.7,0");
	//unloadArray.add("L,D2008,,0,true,2X5");

	idx := 0;
	create theLines transient;
	ediFile.myEDIFileType.rawDataToHSA(ediFile, theLines);
	foreach ediText in theLines do
		idx := idx + 1;
//		write ediText;
		self.assertEqualMsg(ediText, unloadArray[idx], "line "&amp;idx.String&amp;" error.");
	endforeach;
epilog
	delete unloadArray;
	delete ediControllerAgent;
	delete pxyFileTypeUser;
	delete ediDataParams;
	delete theLines;
end;
</source>
        <text>&lt;?xml version="1.0"?&gt;
&lt;UT_Additional&gt;
  &lt;Categories&gt;
    &lt;Category CanDelete="true"&gt;Michael_PAR31258&lt;/Category&gt;
