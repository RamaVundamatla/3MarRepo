    <JadeMethod name="unload" id="34ce92ac-717a-40de-8b41-271b2391ac1e">
        <controlMethod name="Form::unload"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>unload() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 November 2022	navhl20	 ChangeRequest 54253: EUP - VAS Work Orders
*/

vars

begin
	if self.myWoStatusAgent &lt;&gt; null then 
		self.myWoStatusAgent.allWoStatusItems.purge();
	endif;
	delete self.myWoStatusAgent;	
	self.zClearProxyDetails();
	self.exitForm();
	inheritMethod;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="zSetFormDefaults" id="fb810b08-7eb9-471b-9bfa-2c54871e6e5d">
        <updating/>
        <source>zSetFormDefaults() updating, protected;
//--------------------------------------------------
// Created:	21 August 2003 By: cnwgd1
//--------------------------------------------------
vars

begin
	inheritMethod();

	if app.myCurrentUserCan(self.myTerminal, PmSecurityRoleUpdate) then
		self.allowAdd	 := true;
		self.allowDelete := true;
		self.allowUpdate := true;
	else
		self.allowAdd	 := false;
		self.allowDelete := false;
		self.allowUpdate := false;
	endif;

	if app.isSpecial() then
		self.btnRootReset.visible := true;
	else
		self.btnRootReset.visible := false;
	endif;
	
	self.cmbParentRole.automaticCellControl := true;
	self.cmbMode.left 	:= WinLeftMargin;
	self.cmbMode.sorted := false;
	self.lblFilterDesc.left:= self.cmbMode.left + self.cmbMode.width + WinLeftMargin; //epr Tfs 36402 1/2/18
	self.allowPrint  := false;

	self.fldPermissions.stretchToParent := true;
	self.fldPermissions.useSheetBackColors := true;
	self.fldPermissions.setDefaultSheetBackColors();
	self.fldPermissions.initSheetBackColors();
	
end;</source>
        <access>protected</access>
    </JadeMethod>
</GUIClass>
