    <JadeMethod name="setFromCMIF_TITransactionCntrl" id="8750d6c4-380b-43eb-8c2a-7765f00d4aca">
        <updating/>
        <source>setFromCMIF_TITransactionCntrl(_tiTransCntrl: CMIF_TITransactionController; _passport: CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 May 2021	navndl1	Initial creation	TFS 51243

*/

vars

begin

	if CMIF_ActionTransController.hasInstance(_tiTransCntrl) then
		self.action := _tiTransCntrl.CMIF_ActionTransController.action;
	endif;

	inheritMethod(_tiTransCntrl, _passport);
	
	if self.action = ACTION_BLEND_PARENT then
		self.location := self.myTrackedItem.myPrimaryActualLocation.getFullId();
	endif;

epilog

end;</source>
        <Parameter name="_tiTransCntrl" type="CMIF_TITransactionController"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setMyParentBlendTrx" id="507624f8-f0eb-414a-90e2-49dd85322e0d">
        <updating/>
        <source>setMyParentBlendTrx( _parentBlend : CM_Blend ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 May 2021	navndl1	Initial creation	TFS 51243

*/

vars

begin

	self.myParentBlendTrx := _parentBlend;
	if _parentBlend &lt;&gt; null then
		self.location := _parentBlend.location;
		self.myRecipe := _parentBlend.myRecipe;
		self.setOtherTrackedItem( _parentBlend.myTrackedItem );
	endif;

epilog

end;</source>
        <Parameter name="_parentBlend" type="CM_Blend"/>
    </JadeMethod>
