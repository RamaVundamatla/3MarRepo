    <JadeMethod name="setDetailFromTransaction" id="79cdaa26-a778-43d8-b644-b6efa113c728">
        <updating/>
        <source>setDetailFromTransaction(_tran : CM_TITransaction) updating;
// ---------------------------------------------------------------------------
// Created:     28 May 2010 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
// 04/08/2010		cnwcs5			CCMS MES 1033 - RORO KPI
// ---------------------------------------------------------------------------

vars
	kpiDetail 	: CM_KPIVoyageMoveDtl;
	
	length 		: Integer;
	contents	: Integer;
	moveType	: Integer;
	isTranship	: Boolean;
	
	cargoType		: CM_CargoType;
	cargoSubType	: CM_Product;
	
begin
	if _tran = null then
		return;
	endif;
		
	moveType := _tran.transitStatus;

	if moveType &lt;&gt; VoyageMoveType_DLR and moveType &lt;&gt; VoyageMoveType_SOB then
		if _tran.isKindOf(CM_ReceiveShip) then
			moveType := VoyageMoveType_Discharge;
		elseif _tran.isKindOf(CM_ReleaseShip) then
			moveType := VoyageMoveType_Load; // PAR 25719
		else
			app.raiseUnexpectedProgramError(class.name, method.name, 'Unhandled transaction type ' &amp; _tran.String);
			return;
		endif;
	endif;
	
	// get the cargo type and subtype from the transaction
	_tran.getCargoTypeAndSubType (cargoType, cargoSubType);
	
	isTranship	:= (_tran.imExStatus = TI_IMEX_STATUS_TRANSHIP);
	
	if cargoType.id = TI_CargoType_Container then
		contents 	:= _tran.contentsStatus;
		length 		:= _tran.getTILength();
		kpiDetail 	:= self.allKPIVoyageMoveDtls_Container[moveType, length, contents, isTranship];
				
		if kpiDetail = null then
			create kpiDetail as CM_KPIVoyageMoveDtl_Container persistent;

			kpiDetail.setKeyValues(cargoType, cargoSubType, moveType, length, contents, isTranship, self);
		endif;
	else
		kpiDetail 	:= self.allKPIVoyageMoveDtls_GC[moveType, cargoType, cargoSubType, isTranship];
		
		if kpiDetail = null then
			create kpiDetail as CM_KPIVoyageMoveDtl_GC persistent;
		endif;
		
		kpiDetail.setKeyValues(cargoType, cargoSubType, moveType, null, null, isTranship, self);
	endif;
	
	kpiDetail.setDetailValues(_tran);
epilog

end;</source>
        <Parameter name="_tran" type="CM_TITransaction"/>
    </JadeMethod>
    <JadeMethod name="setFromTransaction" id="b65aba85-808a-4b03-8ec2-01125d744db0">
        <updating/>
        <source>setFromTransaction(_shipTran: CM_TITransaction) updating;
/*

Date		Who		Reason
08 August 2011	cnwcs5	Initial creation - CCMS MES 1033 / par 27951 RORO KPI
*/

vars
	ti : CM_TrackedItem;
begin
	if _shipTran = null or _shipTran.isChild then 
		return;
	endif;
	
	ti := _shipTran.myTrackedItem;
	
	self.allTrackedItems.addNoDuplicates(ti, false);	
	self.allTransactions.addNoDuplicates(_shipTran,false);
	
	if ti.isContainer then
		self.movesTEU 	:= self.movesTEU + ti.getNumTEU();	
	endif;
	
	self.movesTI 	:= self.movesTI + 1;
	
	self.setDetailFromTransaction(_shipTran);
	
end;</source>
        <Parameter name="_shipTran" type="CM_TITransaction"/>
    </JadeMethod>
    <JadeMethod name="setHoursDown" id="95e0db52-5348-407e-8415-2e666a19df11">
        <updating/>
