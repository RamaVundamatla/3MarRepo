    <JadeMethod name="gpha_setDetailFromInvoiceLine" id="64dbd172-8a27-4ed5-af2c-9f0e3cb6a47c">
        <updating/>
        <source>gpha_setDetailFromInvoiceLine(_invoiceLine: CM_InvoiceLine) updating;
/*

Date		Who		Reason
17 Aug 2015	cnwer1	Initial creation PAR 36778
07 Jun 2016	cnwrs1	TFS2107 round all values to this field
28 Oct 2021 navma1  ChangeRequest 52163: SAL - Unicode Arabic Support Business Requirements
*/

vars
	count		: Integer;
	ts			: TimeStamp;
	taxValue1,
	taxValue2	: Decimal[16, 6];
	taxCodes	: ObjectArray;
	obj			: Object;
	taxCode		: CM_TaxCode;
	taxRate1,
	taxRate2	: CM_TaxRate;
	voyage 		:  CM_Voyage;
	hookExempt  : Boolean;
begin
	create taxCodes transient;

	// get the configured cash tax codes
	_invoiceLine.getTerminal.getAllCashTaxCodes(taxCodes);
	
	if _invoiceLine.debtor &lt;&gt; null and
	   not _invoiceLine.debtor.isZeroRatedTax then
		foreach obj in taxCodes do
			taxCode := obj.CM_TaxCode;
			count := count + 1;
			// tax code 1 is NHIL, 2 is VAT
			// feedback from Ghana 5/04/2016 the tax values column is to be both NHIL and VAT taxes
			ts := _invoiceLine.chargeTime;
			if count = 1 then
				taxRate1 := taxCode.getTimeRate(ts);
			elseif count = 2 then
				taxRate2 := taxCode.getTimeRate(ts);
			endif;
		endforeach;

		// TFS 37562 exempt by voyage
		voyage := _invoiceLine.getMyVoyageObject();
		if voyage &lt;&gt; null then
			hookExempt := app.myRoot.getVoyageTaxExempt( voyage.myTerminal, voyage ).Boolean;
			if hookExempt then
				taxRate1 := null;
				taxRate2 := null;
			endif;
		endif;
	endif;

	self.gpha_cargoId				 := _invoiceLine.trackedItemId;
	self.gpha_invoiceLineNarration   := _invoiceLine.invoiceLineDesc.narration;	//28.10.2021 navma1 #52163
	self.gpha_lineRate 			     := _invoiceLine.getRate().roundedTo(2);
	self.gpha_lineTotalLessTax 		 := _invoiceLine.lineTotal;
	self.gpha_myTrackedItem			 := _invoiceLine.trackedItem;
	
	// feedback from Ghana 5/04/2016 the tax values column is to be both NHIL and VAT taxes
	if taxRate1 &lt;&gt; null then
		taxValue1 := ((_invoiceLine.lineTotal * taxRate1.rate) / 100);
	endif;
	if taxRate2 &lt;&gt; null then
		taxValue2 := ((_invoiceLine.lineTotal * taxRate2.rate) / 100);
	endif;
	self.gpha_lineTaxValue := taxValue1 + taxValue2;
	self.gpha_lineTotal := _invoiceLine.lineTotal + taxValue1 + taxValue2; 
	
epilog
	delete taxCodes;
end;</source>
        <Parameter name="_invoiceLine" type="CM_InvoiceLine"/>
    </JadeMethod>
    <JadeMethod name="setDetailFromInvoiceLine" id="39c1c99d-c376-4915-b44c-eee3792ef248">
        <updating/>
        <source>setDetailFromInvoiceLine(_invoiceLine: CM_InvoiceLine; _voyage : CM_Voyage) updating;
/*

Date		Who		Reason
17 Aug 2015	cnwer1	Initial creation PAR 36778
01 Nov 2018 cnwma1	Bug 41739: Pel1- Pelindo1- Currency Conversion via Allcashreceiptreporting  
28 Oct 2021 navma1  ChangeRequest 52163: SAL - Unicode Arabic Support Business Requirements
*/

vars
	voyage : CM_Voyage;
	tmpVeseslType : HMS_VesselType;
	ti : CM_TrackedItem;
	tmpHMSData : HMS_VoyageData;
begin

	if _invoiceLine = null then
		return;
	endif;
	
	self.lineDescription 			   := _invoiceLine.invoiceLineDesc.narration;   				//28.10.2021 navma1 #52163
	self.lineUnit 					   := _invoiceLine.invoiceLineDesc.unitNarration; 
	self.lineValue		    		   := _invoiceLine.lineTotal;
	self.lineQuantity 				   := _invoiceLine.quantity;
	self.lineRate 					   := _invoiceLine.getRate; 
	self.lineRemarks 				   := _invoiceLine.remarks;  									  // 36354 add the truncation
	self.lineDateTime 	   		       := _invoiceLine.chargeTime;  
	self.myTrackedItem 				   := _invoiceLine.trackedItem;
	self.lineTaxAmount 				   := _invoiceLine.taxValue; // ### TFS CR 62992 TASK 62994 21MAR2024 NAVAB1 _invoiceLine.getTaxAmountForLine(); 						  // TFS 8307
	self.lineTaxRate 				   := _invoiceLine.taxRate;  // ### TFS CR 62992 TASK 62994 21MAR2024 NAVAB1 _invoiceLine.getTaxRateForLine();   						  // TFS 8307
	self.lineTaxCode 				   := _invoiceLine.taxCode; // ### TFS CR 62992 TASK 62994 21MAR2024 NAVAB1 _invoiceLine.getTaxCode(false);    						  // TFS 8307
	self.storageDays 				   := _invoiceLine.calculateStorageDays();
	self.isStorage 					   := _invoiceLine.isTransactionOfType(TRANS_TYPE_STORAGE);		  //05 May 2017	NDL	TFS 4168
	self.currencyConversionNotRequired := _invoiceLine.invoiceLineDesc.currencyConversionNotRequired; //01.11.2018 cnwma1 TFs #41739
	
	// ### TFS CR 65830 TASK 65832 27AUG2024 NAVAB1
	voyage := _voyage;
	if voyage &lt;&gt; null then
		self.voyageCode := voyage.code;
		self.voyageArrivalDT := voyage.arrivedDT;
		self.voyageDepartedDT := voyage.departedDT;
		self.voyageOperatorCode := voyage.operatorCode;
		self.vesselCode := voyage.vesselCode;
		self.vesselName := voyage.vesselName;
		//self.vesselTypeDesc := voyage.getVesselTypeDescr();
		// ### JIRA 33667 17DEC2024 NAVAB1     
		tmpHMSData:=  voyage.myHMSVoyageData;
		if tmpHMSData &lt;&gt; null then
			self.vesselGRT := tmpHMSData.dim_GrossRegTonnes;
			
			tmpVeseslType := tmpHMSData.myVesselType;
		
			if tmpVeseslType &lt;&gt; null then	
				self.vesselTypeDesc :=  tmpVeseslType.description;
			else
				self.vesselTypeDesc :=  voyage.getVesselTypeDescr();
			endif;
		endif;
		self.termininalCode := voyage.myTerminal.code;
		self.terminalPortCode := voyage.myTerminal.getConfig(PortDestCode).String;
	endif;
	
	self.externalRef1 := _invoiceLine.externalRef1;
	self.externalRef2 := _invoiceLine.externalRef2;
	self.externalRef3 := _invoiceLine.externalRef3;
	self.externalRef4 := _invoiceLine.externalRef4;
	self.dateTime := app.actualTimeAppServer;
	self.invoiceTypeDesc := _invoiceLine.invoiceLineDesc.invoiceType.description; // ### JIRA 33667 17DEC2024 NAVAB1 _invoiceLine.invoiceLineDesc.narration;
	
	/* for proforma this transaction has been deleted so this will never work
	if global.isValidObject(_invoiceLine.myTransactionHMS) then
		self.resourceCode := _invoiceLine.myTransactionHMS.getResourceCode();
		self.resourceDescription := _invoiceLine.myTransactionHMS.getResourceDesc();
	endif;
	*/
	
	self.oumCode := _invoiceLine.uomCode;
	
	ti := _invoiceLine.trackedItem;
	if ti &lt;&gt; null then
		self.cargoFreightForwarderCode := ti.freightForwarderCode;
		self.cargoOperatorCode := ti.operatorCode;
		self.cargoConsigneeCode := ti.consignee;
		self.cargoConsignorCode := ti.consignor;
		if ti.myCustomsAgent &lt;&gt; null then
			self.cargoCustomsAgentCode := ti.myCustomsAgent.code;
		endif;
	endif;

epilog

end;</source>
        <Parameter name="_invoiceLine" type="CM_InvoiceLine"/>
        <Parameter name="_voyage" type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="setTaxDetailsFromPayment" id="78880add-08ac-4ac4-aaba-8cc1a4215cd3">
        <updating/>
        <source>setTaxDetailsFromPayment(_cashPayment : CM_CashPayment)updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 Feb 2020	jlgma1	Bug 48450: ADP 

*/

vars
	service		 : CM_Service;
	invLineDesc  : CM_InvoiceLineDesc;
begin

	if not _cashPayment.hasTax then
		return;
	endif;
	
	if _cashPayment.myInvoiceLine &lt;&gt; null then
		invLineDesc := _cashPayment.myInvoiceLine.invoiceLineDesc;
	elseif _cashPayment.myProformaDetail &lt;&gt; null then
		invLineDesc := _cashPayment.myProformaDetail.myInvoiceLineType;
	endif;
	
	
	self.lineTaxAmount := _cashPayment.myCashPaymentForTax.cashValue;
	
	if self.lineTaxAmount &gt; 0 then
		if invLineDesc &lt;&gt; null then
			service := invLineDesc.services.first();
		endif;	
		
		
		if service &lt;&gt; null then
			if service.myTaxCode &lt;&gt; null then
				self.lineTaxCode := service.myTaxCode.code;
				self.lineTaxRate := service.getTaxRate(_cashPayment.myCashReceipt.myDebtorTerminal.myDebtor, _cashPayment.dateTime); 
			endif;
		endif;
	endif;
epilog

end;</source>
        <Parameter name="_cashPayment" type="CM_CashPayment"/>
    </JadeMethod>
</Class>
