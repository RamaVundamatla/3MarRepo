    <JadeMethod name="initModes" id="018d0670-9b43-46c8-804f-78082dd9b566">
        <updating/>
        <source>initModes() updating;
/*
Purpose:			
Date		Who		Reason
01 August 2011	cnwab1	Initial creation
*/

vars

begin
	if self.myCargoSideViewForm.myROROPlanningForm &lt;&gt; null then
		self.modeView := self.myCargoSideViewForm.myROROPlanningForm.modeView;
		self.modeViewSub := self.myCargoSideViewForm.myROROPlanningForm.myROROPlanDrawController.modeViewSub;
		self.modeWork := self.myCargoSideViewForm.myROROPlanningForm.modeWork;
		self.setScale(1, true, true);
		self.setAttrPositions(self.modeView);
	endif;

epilog

end;</source>
