        <source>isBOL_Match(_yaData: CM_YADataString): Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 January 2014	cnwrd1	Initial creation

*/

vars

begin
	//cnwrd1 par 32823 test bol
	return _yaData.doesValueMatch(self.bolNumber);

epilog

end;</source>
