        <Parameter name="pControlIsEnabled" type="Boolean"/>
        <Parameter name="pControlIsVisible" type="Boolean"/>
        <Parameter name="pControlName" type="String"/>
        <Parameter name="pLogDirectory" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="valTLessonUpdate" id="98cecfe6-fdb4-4d62-9c6a-414af00d6437">
        <updating/>
        <source>valTLessonUpdate(	pLessonToUpdate		:CnEcTLesson;
					pRequiredEdition	: Integer;
					pName 				: String;
					pFormName 			: String;
					pNextLessonName 	: String;
					pText 				: String;
					pCheckControlEnabled: Boolean;
					pCheckControlValue 	: Boolean;
					pCheckControlVisible: Boolean;
					pControlHasAValue 	: Boolean;
					pControlIsEnabled 	: Boolean;
					pControlIsVisible 	: Boolean;
					pControlName 		: String;
					pLogDirectory 		: String	):String updating;
// --------------------------------------------------------------------------------
// Created:		09 June 2000 by cnwsmc1
//
// Purpose:		Validation for updating a Lesson.
//
// Parameters:	The object's (changeable) properties.
//
// Returns:		Null if the transaction is successful, otherwise an error message.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	trimmedName	: String;
	lesson		: CnEcTLesson;
begin

	// Initialize the activity first.
	self.agentInitializeActivity();

	// Arm our base exception handlers.
	on Exception do self.agentExceptionHandler(exception);
	on LockException do self.agentLockExceptionHandler(exception);

	if pLessonToUpdate = null then
		return self.agentSetError("The Lesson being updated is either null or is not valid.");
	endif;

	// If object is invalid, we want our handlers to return an invalid object message.
	self.agentRegisterObjectAndError(pLessonToUpdate, "The Lesson being updated is either null or is not valid.");

	sharedLock(pLessonToUpdate);

	if app.myBaseRoot = null then
		return self.agentSetError("The BaseRoot object is missing or not set.");
	endif;

	trimmedName	:=	pName.trimBlanks;
	if trimmedName = null then
		return self.agentSetError("The Lesson Name cannot be null.");
	elseif trimmedName.length &gt; 40 then
		return self.agentSetError("Update Lesson: name too long '" &amp; trimmedName &amp; "'") ;
	endif;

	trimmedName	:=	pFormName.trimBlanks;
	if trimmedName = null then
		return self.agentSetError("The Form Name cannot be null.");
	endif;


	if pControlName.length = 0 then
		if pCheckControlVisible or pCheckControlEnabled or pCheckControlValue then
			return self.agentSetError("Update Lesson: form set checking is enabled, but no control is specified");
		endif;
	else
		if not ( pCheckControlVisible or pCheckControlEnabled or pCheckControlValue ) then
			return self.agentSetError("Update Lesson: no form set up checking is specified for " &amp; pControlName);
		endif;
	endif;

	// If the above operation gets an exception, our handler will resume to here
	if self.lastError &lt;&gt; null then
		return self.lastError;
	endif;

	return null;
epilog
	// Release our locks in the epilog so that we'll release them even if we exit via an
	// exception. If we don't have an object locked, the unlock does nothing. If we're
	// in transaction state, transaction duration locks won't be released until the next
	// commit or abort transaction (even if we explicitly unlock them). That allows a
	// method to be well behaved and release its locks without having to be aware of the
	// transaction state of the process.
	if pLessonToUpdate &lt;&gt; null then
		unlock(pLessonToUpdate);
	endif;
end;</source>
