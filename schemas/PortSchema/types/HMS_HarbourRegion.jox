end;</source>
        <ReturnType type="HMS_Harbour"/>
    </JadeMethod>
    <JadeMethod name="getLastMovementFromWaypoint" id="f97873ba-96c0-4973-8ba3-2f0303a4817b">
        <source>getLastMovementFromWaypoint(_time : TimeStamp; _lastMovement : HMS_Movement;_getArrival, _getDeparting  : Boolean;_voyagesToIgnore : CM_VoyageSet; _movementTime : TimeStamp output) : HMS_Movement;
//-----------------------------------------------------------------------
//	Created:	07 February 2007 Lorcan Bolster  (cnwlb1/lorcan)
//
//	Changed 	04 Apr 08	cnwrs2	PAR 16433
//							Need to look at other movements departure times from the berth, not occursOnDT
//				04 Apr 08	cnwrs2	PAR 16440
//							Need to take into account arriving movements
//				16 Apr 08	cnwer1	PAR 16514 take into account whether to check departures and arrivals
//-----------------------------------------------------------------------
vars
	movement,
	ourMovement	: HMS_Movement;
	berth		: HMS_Berth;
	iter	 	: Iterator;
	found		: Boolean;
	tmpCheckTime	: TimeStamp;
begin

	_movementTime := null;
	
	foreach berth in self.allBerthsInRegion do
		if _getDeparting then
			iter := berth.getAllDepartingMovements.createIterator ();
			berth.getAllDepartingMovements.startKeyLeq(_time, iter);
			
			found := false;
			
			while iter.back(movement) do
				if movement = _lastMovement then
					continue;
				endif;
				//epr par 16541 18/4/08
				if _voyagesToIgnore &lt;&gt; null and _voyagesToIgnore.includes(movement.getVoyage) then
					continue;
				endif;
				if movement.getDepartureTimeFromBerth(berth) &lt;= _time then
					found := true;
					break;
				endif;
			endwhile;
			
			if found then
			
				tmpCheckTime := movement.getDepartureTimeFromBerth(berth);
				if tmpCheckTime &gt; _time then
					tmpCheckTime := movement.getArrivalTimeAtBerth(berth);
				endif;
			
				
				
				if ourMovement = null or tmpCheckTime &gt; _movementTime then
					ourMovement := movement;
					_movementTime := tmpCheckTime;
				endif;
			endif;
			delete iter;
		endif;
		
		if _getArrival then
			
			movement:=berth.getClosestArrivalMovement(_time,_voyagesToIgnore);
			
			//if movement &lt;&gt; null and movement &lt;&gt; _lastMovement then
			//if movement &lt;&gt; null and movement &lt;&gt; _lastMovement then
			if movement &lt;&gt; null then
			
					
				tmpCheckTime := movement.getArrivalTimeAtBerth(berth);
					
				if ourMovement = null or _time.getDifferenceInMinutes(tmpCheckTime)&lt; _time.getDifferenceInMinutes(_movementTime)  then
					ourMovement := movement;
					_movementTime := tmpCheckTime;
				
				endif;
			endif;
			delete iter;
		endif;
	endforeach;
	
	return ourMovement;
	
epilog
	delete iter;
end;</source>
        <Parameter name="_time" type="TimeStamp"/>
        <Parameter name="_lastMovement" type="HMS_Movement"/>
        <Parameter name="_getArrival" type="Boolean"/>
        <Parameter name="_getDeparting" type="Boolean"/>
        <Parameter name="_voyagesToIgnore" type="CM_VoyageSet"/>
        <Parameter name="_movementTime" type="TimeStamp" usage="output"/>
        <ReturnType type="HMS_Movement"/>
    </JadeMethod>
    <JadeMethod name="getMinimumSteamingTime" id="a5123d39-4d30-4232-80ce-c0e50964c32c">
        <source>getMinimumSteamingTime(_toRegionObj:HMS_HarbourRegion; _vessel : CM_Vessel):Integer;
// --------------------------------------------------------------------------------
// Created:		03 March 2008 by cnwdad1
//
// Purpose:		Returns the minimum steaming time between the receiver and the
//				specified Harbour Region.
//
// Parameters:	_toRegionObj - A reference to the destination Harbour Region.
//				_vessel - A reference to the Vessel sailing between the regions.
//
// Returns:		The minimum steaming time, in minutes, or zero.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	steamingTime	: Integer;
	movePathObj		: HMS_MovementPath;
	pathSegmentObj	: HMS_PathSegment;
	
begin
	movePathObj	:=	app.myRoot.getMovementPath(self, _toRegionObj, false);
	
	if movePathObj &lt;&gt; null then
		steamingTime	:=	movePathObj.getMinimumSteamingTime(_vessel);
	else
		pathSegmentObj	:=	app.myRoot.getPathSegment(self, _toRegionObj);
		
		if pathSegmentObj &lt;&gt; null then
// cnwdad1 02/04/2008 - PAR #16282.
//			steamingTime	:=	pathSegmentObj.minSteamingTime;
			steamingTime	:=	pathSegmentObj.getMinimumSteamingTime(_vessel);
		endif;
	endif;

	return steamingTime;
end;</source>
        <Parameter name="_toRegionObj" type="HMS_HarbourRegion"/>
        <Parameter name="_vessel" type="CM_Vessel"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getMinimumWaitingTime" id="d90be938-4d76-46a7-a4d3-2bcc7d5aca12">
        <source>getMinimumWaitingTime(_cargoOperation : Integer):Integer;
// --------------------------------------------------------------------------------
// Created:		11 February 2008 by cnwdad1
//
// Purpose:		Returns the minimum waiting time for a Vessel at the Harbour Region.
//
// Parameters:	None
//
// Returns:		The minimum waiting time, in minutes.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.myTerminal = null then
		return 0;
	else
		return self.myTerminal.getTimeAtTerminal(null, _cargoOperation);
	endif;
end;</source>
        <Parameter name="_cargoOperation" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getPreferredBerthForVessel" id="f30a4e2a-750d-486c-8840-4386f398f34e">
        <source>getPreferredBerthForVessel(pVessel :CM_Vessel) :HMS_Berth;

vars
	terminal			: CM_Terminal;
	vesselTerminalData	: CM_VesselTerminalData;
	
begin
	//terminal	:= self.getTerminal();
	// we want to get the real terminal in this case
	terminal	:= self.myTerminal;
	
	if terminal &lt;&gt; null then
		vesselTerminalData	:= pVessel.allTerminalDatas[terminal];
		
		if vesselTerminalData &lt;&gt; null
		and vesselTerminalData.myPreferredBerth &lt;&gt; null
		and allBerthsInRegion.includes(vesselTerminalData.myPreferredBerth)
		then
			return vesselTerminalData.myPreferredBerth;
		endif;
	endif;
	
	return getArrivalBerth;
end;
</source>
        <Parameter name="pVessel" type="CM_Vessel"/>
        <ReturnType type="HMS_Berth"/>
    </JadeMethod>
    <JadeMethod name="getShiftBerth" id="a466dae8-e631-4b5a-96fc-dbeb8efba6b8">
        <source>getShiftBerth(): HMS_Berth;
//-----------------------------------------------------------------------
//	Created:	15 September 2006 Lorcan Bolster  (cnwlb1/lorcan)
//-----------------------------------------------------------------------
vars
	berth : HMS_Berth;
begin	
	if self.myPreferredBerth &lt;&gt; null then
		return self.myPreferredBerth;
	endif;
	
	if self.getHarbourReal() &lt;&gt; null then
		berth := self.getHarbourReal().getDefaultBerthForMoveType(HMSMovementTypeShift);
	endif;
	
	return berth;
epilog

end;</source>
        <ReturnType type="HMS_Berth"/>
    </JadeMethod>
    <JadeMethod name="getSteamingTimeToRegion" id="abb4cfd6-931c-4440-b38c-76bdb0e46b30">
        <source>getSteamingTimeToRegion(_vessel : CM_Vessel; _toRegion : HMS_HarbourRegion; _giveError : Boolean) : Integer;
//-----------------------------------------------------------------------
//	Created:	04 December 2006 Lorcan Bolster  (cnwlb1/lorcan)
//-----------------------------------------------------------------------
vars
	movementPath	: HMS_MovementPath;
	pathSegment		: HMS_PathSegment;
	steaming		: Integer;
	
begin
	if _toRegion = null then
		return 0;
	endif;

	movementPath	:=	app.myRoot.getMovementPath(self,_toRegion, false);
	
	if movementPath &lt;&gt; null then
		steaming	:=	movementPath.getSteamingTimeForVessel(_vessel);
	else
		pathSegment	:=	app.myRoot.getPathSegment(self, _toRegion);
		
		if pathSegment &lt;&gt; null then
			steaming	:=	pathSegment.getSteamingTimeForVessel(_vessel);
		elseif _giveError then
			/*app.raiseCMException1(Full_Replacement_Message, 'There is no Movement Path or Path Segments setup between ' &amp;
					self.code &amp; ' and ' &amp; _toRegion.code &amp; '. Steaming time cannot be derived.', null, null); */ //- cnwmd1, Par 20524
			app.raiseCMException2(There_movem_path_path_segme_se, self.code, _toRegion.code, null, null);
		endif;
	endif;

	return steaming;
end;</source>
        <Parameter name="_vessel" type="CM_Vessel"/>
        <Parameter name="_toRegion" type="HMS_HarbourRegion"/>
        <Parameter name="_giveError" type="Boolean"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
