        <source>trxUpdateUserStateData( _user : CM_User; _configGrp : Integer; _key, _value : String; _passport : CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 Oct 2015	cnwmc5	Initial creation
07 Jun 2024	navdap1	TFS 64351 EUP - Deadlocks on Users and StateData when using Rest APIs 
*/

vars

begin

	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(false);
		
	beginTransaction;
	
	// TFS 64351 Lock things up front
	app.exclusiveLock(_user);
	app.exclusiveLock(_user.allSubSystemStateObjects);
	// TFS 64351 end

	app.myUtilityUA.utlUpdateUserStateData( _user, _configGrp, _key, _value);

epilog	
	self.finaliseActivityWithPassport(_passport);

end;</source>
