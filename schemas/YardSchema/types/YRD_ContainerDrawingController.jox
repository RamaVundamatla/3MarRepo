    <JadeMethod name="getScenarioAPLocation" id="36d92c74-454f-43fa-81d5-64d9ca6bd0b3">
        <source>getScenarioAPLocation(_ti : CM_TrackedItem): CM_LocationsController;
// ---------------------------------------------------------------------------
// Created:		May 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	tmpLocn : CM_LocationsController;
	locnStr	: String;
	intReturn : Integer;
begin

	tmpLocn := app.autoPlanTiYATest(self.myTerminal, null, _ti, false);  // PAR 19412
	if tmpLocn &lt;&gt; null then
		locnStr := tmpLocn.getFullId();
		intReturn := app.msgBox(_ti.id &amp; " will be queued to " &amp; locnStr &amp; ". Do you want to view logging?","Test Auto Plan",MsgBox_Yes_No);
		if intReturn = MsgBox_Return_Yes then 
			if self.myYardGridAreaForm &lt;&gt; null then // PAR 17357
				self.myYardGridAreaForm.myAssistant.showLoggingInformation(app.myYAAgent);
			elseif self.myGridOverviewForm &lt;&gt; null then // PAR 17357
				self.myGridOverviewForm.myAssistant.showLoggingInformation(app.myYAAgent); // PAR 17357
			endif;
		endif;
	else
		intReturn := app.msgBox(_ti.id &amp; " could not be auto planned. Do you want to view logging?","Test Auto Plan",MsgBox_Yes_No);
		if intReturn = MsgBox_Return_Yes then 
			if self.myYardGridAreaForm &lt;&gt; null then // PAR 17357
				self.myYardGridAreaForm.myAssistant.showLoggingInformation(app.myYAAgent); 
			elseif self.myGridOverviewForm &lt;&gt; null then // PAR 17357
				self.myGridOverviewForm.myAssistant.showLoggingInformation(app.myYAAgent); // PAR 17357
			endif;
		endif;
	endif;
	
	return tmpLocn;
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="CM_LocationsController"/>
    </JadeMethod>
