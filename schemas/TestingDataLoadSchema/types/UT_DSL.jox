    <JadeMethod name="deleteISOGroup" id="7bc9c355-1c21-4998-9156-17114e50e089">
        <source>deleteISOGroup(_isoGroupId : String);

/*

Purpose:		Delete an iso Group	

Date			Who		Reason
29/11/2011		cnwmh5	Initial creation

*/

vars

	isoGroup			: CM_ISOTypeGroup;
	isoType				: CM_ISOType;
	isoSubTypeGroup     : CM_ISOTypeGroup;
	reserve 			: CM_ReserveSelection;
	obj					: Object;
	release				: CM_BulkRelease;
	
	objArray 			: ObjectArray;

begin

	create objArray transient;
	
	isoGroup := app.myRoot.allISOTypeGroups[_isoGroupId];
	if isoGroup &lt;&gt; null then
	
		beginTransaction;
		
		foreach isoType in isoGroup.allISOTypes discreteLock do
			isoGroup.allISOTypes.remove(isoType);		
		endforeach;
		
		foreach  isoSubTypeGroup in isoGroup.allSubstitutingISOGroups discreteLock do
			isoGroup.allSubstitutingISOGroups.remove(isoSubTypeGroup);
		endforeach;
		
		commitTransaction;

		
		// remove from release requests
		CM_BulkRelease.allInstances( objArray, 0, true);
		foreach obj in objArray discreteLock do
			release := obj.CM_BulkRelease;
			if release.myISOGroup = isoGroup then
				self.deleteReleaseRequest(release.code);
			endif;
		endforeach;
		
		// remove from reserve selection
		objArray.clear();
		CM_ReserveSelection.allInstances( objArray, 0, true);
		foreach obj in objArray discreteLock do
			reserve := obj.CM_ReserveSelection;
			if reserve.myISOGroup = isoGroup then
				self.deleteReleaseRequest(reserve.myReserveHeader.code);
			endif;
		endforeach;
		
//		commitTransaction;
		
		
		app.myTrxDA.trxDeleteISOTypeGroup(isoGroup, app.myPassport);
		self.assertNoTrxErrorsOrWarnings();
	endif;

epilog

	delete objArray;

end;</source>
        <Parameter name="_isoGroupId" type="String"/>
    </JadeMethod>
