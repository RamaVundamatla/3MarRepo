    <JadeMethod name="doPrint" id="9f36403a-c2f9-4953-824c-23ab09c80bee">
        <source>doPrint();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 August 2010	cnwndl1	Initial creation

*/

vars

	report : NDLTestPrint;
	index : Integer;
	point : Point;
	x : Integer;
	y : Integer;
	repX : Integer;
	repY : Integer;
	text : String;
	xRatio : Decimal [10,4];
	yRatio : Decimal [10,4];
	baseX : Integer;
	baseY : Integer;
	textLength : Integer;
	textHeight : Integer;
	xOffSet : Integer;
	yOffSet : Integer;
	elipseOffSet : Integer;
	
begin

	self.doPrintViaDummy( self.picMap.picture );
	return;

	//self.picMap.clearGraphics;
	
	app.printer.printPreview := true;

	create report transient;
	report.picMap.picture := self.picMap.picture;
	
	xRatio := report.picMap.width / self.picMap.pictureWidth;
	yRatio := report.picMap.height / self.picMap.pictureHeight;
	baseX := ( report.frmMap.left + report.picMap.left).Integer;
	baseY := report.picMap.top.Integer;
	
	app.printer.orientation := 2;
	
	app.printer.print(report.frmMap);
	
	app.printer.setPrintPosition(0);
	
	report.frmMap.fontSize := 8;
	app.printer.drawFontSize := report.frmMap.fontSize;
	
	if mapLocations.size &gt; 0 then
		foreach index in 1 to mapLocations.size do
			// position on original picture.
			point := mapLocations[index];
			x := point.x;
			y := point.y;
			
			if x &lt;&gt; 0 or y &lt;&gt; 0 then
				repX := baseX + ( x * xRatio ).Integer;
				repY := baseY + ( y * yRatio ).Integer;
				text := index.String;
				
				textLength := report.frmMap.getTextExtent(text);
				textHeight := report.frmMap.getTextHeight(text);
				
				xOffSet := ( textLength / 2 ).Integer;
				yOffSet := ( textHeight / 2 ).Integer;
				
				if xOffSet &gt; yOffSet then
					elipseOffSet := xOffSet;
				else
					elipseOffSet := yOffSet;
				endif;
				
				app.printer.drawWidth := 1;
				app.printer.drawFillColor := Red;
				app.printer.drawEllipse(repX - elipseOffSet, repY - elipseOffSet, repX + elipseOffSet, repY + elipseOffSet,Red);
				
			//	app.printer.drawWidth := 9;
			//	app.printer.drawTextAt( ".",repX,repY,Red);
			//	app.printer.drawWidth := 3;
				app.printer.drawFontSize := report.frmMap.fontSize;
				write app.printer.drawFontSize;
				app.printer.drawTextAt(text,repX - xOffSet, repY - yOffSet, Black);
			endif;
		endforeach;
	endif;
	
	

epilog
	app.printer.close;
	delete report;
end;</source>
    </JadeMethod>
    <JadeMethod name="doPrintViaDummy" id="380fc211-3fd2-4fc1-b2ae-2d61ca9a8a64">
        <source>doPrintViaDummy( binaryPic : Binary );

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 August 2010	cnwndl1	Initial creation

*/

vars

	dummyReport : NDLTestPrint;
	index : Integer;
	point : Point;
	x : Integer;
	y : Integer;
	text : String;
	textLength : Integer;
	textHeight : Integer;
	xOffSet : Integer;
	yOffSet : Integer;
	elipseOffSet : Integer;
	
	picWidth : Integer;
	picHeight : Integer;
	
	overDrawnPicture : Binary;
	
	report2 : NDLTestPrint;
	
begin

	create dummyReport transient;	// so we can populate a picture and draw on it.
	dummyReport.picMap.picture := binaryPic;
	
	binaryPic.pictureSize(picWidth, picHeight);
	
	dummyReport.picMap.width := picWidth;
	dummyReport.picMap.height := picHeight;
	dummyReport.picMap.fontSize := 10;
	
	if mapLocations.size &gt; 0 then
		foreach index in 1 to mapLocations.size do
			// position on original picture.
			point := mapLocations[index];
			x := point.x;
			y := point.y;
			
			dummyReport.picMap.autoRedraw := true;
			
			if x &lt;&gt; 0 or y &lt;&gt; 0 then
				
				text := index.String;
			
				textLength := dummyReport.picMap.getTextExtent(text);
				textHeight := dummyReport.picMap.getTextHeight(text);
				
				xOffSet := ( textLength / 2 ).Integer;
				yOffSet := ( textHeight / 2 ).Integer;
				
				if xOffSet &gt; yOffSet then
					elipseOffSet := xOffSet;
				else
					elipseOffSet := yOffSet;
				endif;
				
				dummyReport.picMap.drawWidth := 1;
				dummyReport.picMap.drawFillColor := Red;
				dummyReport.picMap.drawEllipse(x - elipseOffSet, y - elipseOffSet, x + elipseOffSet, y + elipseOffSet,Red);
				dummyReport.picMap.drawTextAt(text,x - xOffSet, y - yOffSet, Black);
				
			endif;
		endforeach;
	endif; 
	
	// now grab our new our over drawn image.
	overDrawnPicture := dummyReport.picMap.createPictureIndirect(true, true);
	
	// print it.
	app.printer.printPreview := true;
	app.printer.orientation := 2;
	create report2 transient;
	report2.picMap.picture := overDrawnPicture;
	app.printer.print(report2.frmMap);

epilog

	app.printer.close;	
	delete report2;
	delete dummyReport;

	
end;</source>
        <Parameter name="binaryPic" type="Binary"/>
    </JadeMethod>
    <JadeMethod name="doResize" id="c7f1d505-16f5-4014-8fa1-a9235f7ccff4">
        <updating/>
        <source>doResize() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 August 2010	cnwndl1	Initial creation

*/

vars

begin

	self.fld1.height := self.height; 
	self.fld1.width := self.width; 

	self.btnClose.left := self.width - self.btnClose.width - 20;
	self.btnClose.top := self.height - self.btnClose.height - 60;
	
	self.btnPrint.left := self.btnClose.left - self.btnPrint.width - 10;
	self.btnPrint.top := self.btnClose.top;
	
	self.btnPicture.left := self.btnPrint.left - self.btnPicture.width - 10;
	self.btnPicture.top := self.btnPrint.top;
	
	self.picMap.width := self.width - self.picMap.left - 20;
	self.picMap.height := self.btnClose.top - self.picMap.top - 10;


epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getTermAreaDetailsForQuery" id="fda3ea9d-6342-43df-b589-d146bb6f43a8">
        <source>getTermAreaDetailsForQuery( _terminal : CM_Terminal output;
							_terminalAreas : CM_TAMasterByIdDict io;
							_gridRows : CM_GridObjectSet io;
							_enqController : CM_EnquiryController output;
							_viewMode : Integer output
							);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21 July 2011	cnwndl1	Initial creation

*/

vars

	termArea : CM_TerminalAreaMaster;

begin

	_terminal := app.myPassport.myTerminal;
	
	termArea := _terminal.allTerminalAreaMastersById.getAtKey("NDLBLK");
	if termArea &lt;&gt; null then
		_terminalAreas.add(termArea);
	endif;
	
	termArea := _terminal.allTerminalAreaMastersById.getAtKey("NDLBK2");
	if termArea &lt;&gt; null then
		_terminalAreas.add(termArea);
	endif;
	
	termArea := _terminal.allTerminalAreaMastersById.getAtKey("NDLST2");
	if termArea &lt;&gt; null then
		_terminalAreas.add(termArea);
	endif;
	
	termArea := _terminal.allTerminalAreaMastersById.getAtKey("NDLSTR");
	if termArea &lt;&gt; null then
		_terminalAreas.add(termArea);
	endif;
	
	_viewMode := VIEW_DWELL_DAYS;


epilog

end;</source>
        <Parameter name="_terminal" type="CM_Terminal" usage="output"/>
        <Parameter name="_terminalAreas" type="CM_TAMasterByIdDict" usage="io"/>
        <Parameter name="_gridRows" type="CM_GridObjectSet" usage="io"/>
        <Parameter name="_enqController" type="CM_EnquiryController" usage="output"/>
        <Parameter name="_viewMode" type="Integer" usage="output"/>
    </JadeMethod>
