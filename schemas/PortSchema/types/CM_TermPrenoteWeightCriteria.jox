<Class name="CM_TermPrenoteWeightCriteria" id="0cbbb1e6-60c3-4ee7-9a70-ef6f722b539d">
    <superclass name="CM_ObjectMatchCriteria"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="admin"/>
    <ExplicitInverseRef name="myTerminal" id="a7ac2fde-8ed3-4afb-b598-fc0ee2525298">
        <kind>child</kind>
        <transientToPersistentAllowed/>
        <updateMode>manual</updateMode>
        <embedded/>
        <type name="CM_Terminal"/>
        <access>readonly</access>
        <Inverse name="CM_Terminal::myPrenoteWeightCriteria"/>
    </ExplicitInverseRef>
    <JadeMethod name="getDisplayStringForAttribute" id="8e7e8073-b006-49d0-8617-985991a8718c">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*

Date		Who		Reason
13 May 2016	cnwer1	Initial creation PAR

*/

vars
	criteria: CM_YACriteria;
	text : String;
begin
	
	if _attrName = ETRow_PrenoteCertWeightValCrit then
		foreach criteria in self.allCriteria do
			text := text &amp; criteria.getListDisplay &amp; " ";
		endforeach;
		return text;
	else
		return inheritMethod(_attrName, _short);
	endif;

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setMyTerminal" id="8d28c713-8d23-4139-85fb-6c010d468287">
        <updating/>
        <source>setMyTerminal(_terminal : CM_Terminal) updating;
/*

Date		Who		Reason
13 May 2016	cnwer1	Initial creation TFS 1882

*/

vars

begin
	self.myTerminal:=_terminal;
epilog

end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
</Class>
