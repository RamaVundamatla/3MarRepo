    <JadeMethod name="doDateSearch" id="f0b47f60-600d-4030-b176-dad29f251c64">
        <updating/>
        <source>doDateSearch()updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 April 2021	navndl1	Initial creation	TFS 50906

*/

vars
	iter : Iterator;
	eventTrx : CM_EventTransaction;
	locAct : CMEVT_LocationActivity;
	keyTimeStamp : TimeStamp;
	keyType : Integer;
	breakOut : Boolean;
	passport : CM_Passport;
	eventTypeObj : CM_EventType;
	type : Integer;
	localEventTypes : CM_EventTypeSet;
	startObject : CM_EventTransaction;
	
begin
	passport := app.myPassport;
	
	create localEventTypes transient;
	if eventTypes.isEmpty then
		localEventTypes.add( app.myRoot.allEventTypesByType[EVT_LocationMove] );
		localEventTypes.add( app.myRoot.allEventTypesByType[EVT_LocationDiscrepDecrease] );
		localEventTypes.add( app.myRoot.allEventTypesByType[EVT_LocationDiscrepIncrease] );
		localEventTypes.add( app.myRoot.allEventTypesByType[EVT_LocationBalance] );
	else
		eventTypes.copy(localEventTypes);
	endif;
	
	foreach eventTypeObj in localEventTypes do
	
		type := eventTypeObj.type;

		iter :=	self.myTerminal.allEventsByTypeDateTime.createIterator();
		self.myTerminal.allEventsByTypeDateTime.startKeyGeq( type, self.startDateTime, iter);
		
		while iter.next( eventTrx ) do
			iter.getCurrentKeys( keyType, keyTimeStamp );
			if keyType &lt;&gt; type then
				break;
			endif;
			
			if (self.endDateTime &lt;&gt; null and keyTimeStamp &gt; self.endDateTime) then
				break;
			endif;
			locAct := eventTrx.CMEVT_LocationActivity;
			if self.includesObject(locAct, breakOut, passport) then
				self.addObjectToSet(locAct);
			endif;
				
			if breakOut or self.breakOutOfSearch then
				break;
			endif;
		endwhile;
		
		delete iter;
	
	endforeach;
		
epilog

	delete iter;
	delete localEventTypes;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doQuery" id="7e1dcc62-8c8e-42f0-86b5-77d289960e86">
        <updating/>
        <source>doQuery(_qDef: CM_QueryDefinition) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 April 2021	navndl1	Initial creation	TFS 50906

*/

vars

	now : TimeStamp;
	crit : CM_SelectorCriteriaLine;
	termSet : CM_TerminalSet;
	ut : CM_UserTerminal;
	eventType : CM_EventType;
	term : CM_Terminal;
	locationSet : CM_LCSet;
	taSet : CM_TerminalAreaMasterSet;
	trainSet : CM_TrainSet;
	vvrSet : CM_VehicleVisitRecordSet;
	voyageSet : CM_VoyageSet;
	lc : CM_LocationsController;
	ta : CM_TerminalAreaMaster;
	train : CM_Train;
	vvr : CM_VehicleVisitRecord;
	voyage : CM_Voyage;
	voyageCodeArray : StringArray;
	voyageCode : String;
	trainCodeArray : StringArray;
	trainCode : String;
	oldDate : TimeStamp;
	startTrain : CM_Train;
	iter : Iterator;
	vvrVisitNumber : String;
	vvrVisitNumberArray : StringArray;
	termTrainSet : CM_TrainSet;
	termVvrSet : CM_VehicleVisitRecordSet;
	termVoyageSet : CM_VoyageSet;
	taIdsArray : StringArray;
	taId : String;
	lcIdsArray : StringArray;
	lcId : String;
	foundHeight : Integer;

begin

	self.reset();
	now := app.actualTimeServer();
	
	crit := self.myCriteriaLineHolder.allCriteriaByPropertyName[CMEVT_LocationActivity::dateTime.name, _qDef.className];
	if crit &lt;&gt; null then
		if crit.myQueryOperator.isKindOf(CM_QDateEquals) then
			self.startDateTime.setDate( crit.myQueryOperator.getSearchValue().Date );
			self.endDateTime.setDate( crit.myQueryOperator.getSearchValue().Date );
			self.endDateTime.setTime('23:59:59:999'.Time);
		elseif crit.myQueryOperator.isKindOf(CM_QDateGreaterThan) then
			self.startDateTime.setDate( crit.myQueryOperator.getSearchValue().Date );
			self.endDateTime := null;
		elseif crit.myQueryOperator.isKindOf(CM_QDateLessThan) then
			self.endDateTime.setDate( crit.myQueryOperator.getSearchValue().Date );
			if self.myContext = null then
				self.endDateTime.setTime('23:59:59:999'.Time);
			endif;
			self.startDateTime := null;
		elseif crit.myQueryOperator.isKindOf(CM_QDateRange) then
			self.startDateTime.setDate( crit.myQueryOperator.CM_QDateRange.getSearchValueFromDate() );
			self.endDateTime.setDate( crit.myQueryOperator.CM_QDateRange.getSearchValueToDate() );
			if self.myContext = null then
				self.endDateTime.setTime('23:59:59:999'.Time);
			endif;
		endif;
	endif;
	
	crit := self.myCriteriaLineHolder.allCriteriaByPropertyName[CMEVT_LocationActivity::myEventType.name, _qDef.className];
	if crit &lt;&gt; null then
		crit.myQueryOperator.getSearchValueAsObjectSet(self.eventTypes);
	endif;
	
	create termSet transient;
	create voyageSet transient;
	create taSet transient;
	create trainSet transient;
	create vvrSet transient;
	create locationSet transient;
	
	crit := self.myCriteriaLineHolder.allCriteriaByPropertyName['myTerminal', _qDef.className];
	if crit &lt;&gt; null then
		crit.myQueryOperator.getSearchValueAsObjectSet(termSet);
	else
		foreach ut in app.myPassport.myUser.allUserTerminals do
			termSet.add(ut.getMyTerminal);
		endforeach;
	endif;
	
	if termSet &lt;&gt; null and not termSet.isEmpty then
		self.myTerminal := termSet.first;
	endif;
	
	//voyages
	crit := self.myCriteriaLineHolder.allCriteriaByPropertyName[CMEVT_LocationActivity::mySourceVoyage.name, _qDef.className];
	if crit &lt;&gt; null then
		crit.myQueryOperator.getSearchValueAsObjectSet(voyageSet);
	endif;
	crit := self.myCriteriaLineHolder.allCriteriaByPropertyName[CMEVT_LocationActivity::myTargetVoyage.name, _qDef.className];
	if crit &lt;&gt; null then
		crit.myQueryOperator.getSearchValueAsObjectSet(voyageSet);
	endif;

	crit := self.myCriteriaLineHolder.allCriteriaByPropertyName[CMEVT_LocationActivity::getVoyageCodes.name, _qDef.className];
	if crit &lt;&gt; null then
		create termVoyageSet transient;
		self.myTerminal.getValidLocationActivityObjs( null, termVoyageSet, null, null );
		
		if crit.myQueryOperator.isKindOf(CM_QStringIsOneOf) then
			create voyageCodeArray transient;
			crit.myQueryOperator.getSearchValueAsStringArray(voyageCodeArray);
			foreach voyage in termVoyageSet do
				if voyageCodeArray.includes( voyage.code) then
					voyageSet.addNoDuplicates( voyage, false );
				endif;
			endforeach;
			
		elseif crit.myQueryOperator.isKindOf(CM_QStringLookup) then
			voyageCode := crit.myQueryOperator.getSearchValue.String;
			if voyageCode &lt;&gt; null then
				foreach voyage in termVoyageSet do
					if voyage.code = voyageCode then
						voyageSet.addNoDuplicates( voyage, false );
					endif;
					break;
				endforeach;
			endif;
			
		endif;
		
	endif;
	
	//Terminal areas
	crit := self.myCriteriaLineHolder.allCriteriaByPropertyName[CMEVT_LocationActivity::mySourceTA.name, _qDef.className];
	if crit &lt;&gt; null then
		crit.myQueryOperator.getSearchValueAsObjectSet(taSet);
	endif;
	crit := self.myCriteriaLineHolder.allCriteriaByPropertyName[CMEVT_LocationActivity::myTargetTA.name, _qDef.className];
	if crit &lt;&gt; null then
		crit.myQueryOperator.getSearchValueAsObjectSet(taSet);
	endif;
	
	crit := self.myCriteriaLineHolder.allCriteriaByPropertyName[CMEVT_LocationActivity::getTerminalAreaIds.name, _qDef.className];
	if crit &lt;&gt; null then
		if crit.myQueryOperator.isKindOf(CM_QStringIsOneOf) then
			create taIdsArray transient;
			crit.myQueryOperator.getSearchValueAsStringArray(taIdsArray);
			
			foreach ta in self.myTerminal.allTerminalAreas discreteLock do
				if taIdsArray.includes( ta.id ) then
					taSet.addNoDuplicates( ta, false );
				endif;
			endforeach;
			
		elseif crit.myQueryOperator.isKindOf(CM_QStringLookup) then
			taId := crit.myQueryOperator.getSearchValue.String;
			if taId &lt;&gt; null then
				ta := self.myTerminal.allTerminalAreas.getAtKey( taId );
				if ta &lt;&gt; null then
					taSet.addNoDuplicates( ta, false );
				endif;
			endif;
		endif;
	endif;
	
	//trains
	crit := self.myCriteriaLineHolder.allCriteriaByPropertyName[CMEVT_LocationActivity::mySourceTrain.name, _qDef.className];
	if crit &lt;&gt; null then
		crit.myQueryOperator.getSearchValueAsObjectSet(trainSet);
	endif;
	crit := self.myCriteriaLineHolder.allCriteriaByPropertyName[CMEVT_LocationActivity::myTargetTrain.name, _qDef.className];
	if crit &lt;&gt; null then
		crit.myQueryOperator.getSearchValueAsObjectSet(trainSet);
	endif;
	
	crit := self.myCriteriaLineHolder.allCriteriaByPropertyName[CMEVT_LocationActivity::getTrainCodes.name, _qDef.className];
	if crit &lt;&gt; null then
		create termTrainSet transient;
		self.myTerminal.getValidLocationActivityObjs( termTrainSet, null, null, null );
		
		if crit.myQueryOperator.isKindOf(CM_QStringIsOneOf) then
			create trainCodeArray transient;
			crit.myQueryOperator.getSearchValueAsStringArray(trainCodeArray);
			
			foreach train in termTrainSet discreteLock do
				if trainCodeArray.includes( train.code ) then
					trainSet.addNoDuplicates( train, false );
				endif;
			endforeach;
	
		elseif crit.myQueryOperator.isKindOf(CM_QStringLookup) then
			trainCode := crit.myQueryOperator.getSearchValue.String;
			if trainCode &lt;&gt; null then
				foreach train in termTrainSet discreteLock do
					if trainCode = train.getCodeDate then
						trainSet.addNoDuplicates( train, false );
						break;
					endif;
				endforeach;
			endif;
		endif;
		
	endif;
	
	//vvrs
	crit := self.myCriteriaLineHolder.allCriteriaByPropertyName[CMEVT_LocationActivity::mySourceVVR.name, _qDef.className];
	if crit &lt;&gt; null then
		crit.myQueryOperator.getSearchValueAsObjectSet(vvrSet);
	endif;
	crit := self.myCriteriaLineHolder.allCriteriaByPropertyName[CMEVT_LocationActivity::myTargetVVR.name, _qDef.className];
	if crit &lt;&gt; null then
		crit.myQueryOperator.getSearchValueAsObjectSet(vvrSet);
	endif;
	
	crit := self.myCriteriaLineHolder.allCriteriaByPropertyName[CMEVT_LocationActivity::getVvrVisitNumbers.name, _qDef.className];
	if crit &lt;&gt; null then
		create termVvrSet transient;
		self.myTerminal.getValidLocationActivityObjs( null, null, termVvrSet, null );
		
		if crit.myQueryOperator.isKindOf(CM_QStringIsOneOf) then
			create vvrVisitNumberArray transient;
			crit.myQueryOperator.getSearchValueAsStringArray(vvrVisitNumberArray);
			foreach vvr in termVvrSet discreteLock do
				if vvrVisitNumberArray.includes( vvr.visitNumber ) then
					vvrSet.addNoDuplicates( vvr, false );
				endif;
			endforeach;
			
		elseif crit.myQueryOperator.isKindOf(CM_QStringLookup) then
			vvrVisitNumber := crit.myQueryOperator.getSearchValue.String;
			foreach vvr in termVvrSet discreteLock do
				if vvrVisitNumber = vvr.visitNumber then
					vvrSet.addNoDuplicates( vvr, false );
					break;
				endif;
			endforeach;
			
		endif;
		
	endif;
	
	
	//locations
	crit := self.myCriteriaLineHolder.allCriteriaByPropertyName[CMEVT_LocationActivity::mySourceLocation.name, _qDef.className];
	if crit &lt;&gt; null then
		crit.myQueryOperator.getSearchValueAsObjectSet(locationSet);
	endif;
	crit := self.myCriteriaLineHolder.allCriteriaByPropertyName[CMEVT_LocationActivity::myTargetLocation.name, _qDef.className];
	if crit &lt;&gt; null then
		crit.myQueryOperator.getSearchValueAsObjectSet(locationSet);
	endif;
	
	crit := self.myCriteriaLineHolder.allCriteriaByPropertyName[CMEVT_LocationActivity::getYardLocationIds.name, _qDef.className];
	if crit &lt;&gt; null then
		if crit.myQueryOperator.isKindOf(CM_QStringIsOneOf) then
			create lcIdsArray transient;
			crit.myQueryOperator.getSearchValueAsStringArray(lcIdsArray);
		
			foreach lcId in lcIdsArray discreteLock do
				self.myTerminal.findLocationFromString( lcId ,true, lc, foundHeight);
				if lc &lt;&gt; null then
					locationSet.addNoDuplicates( lc, false );
				endif;
			endforeach; 
			
		elseif crit.myQueryOperator.isKindOf(CM_QStringLookup) then
			lcId := crit.myQueryOperator.getSearchValue.String;
			if lcId &lt;&gt; null then
				self.myTerminal.findLocationFromString( lcId ,true, lc, foundHeight);
				if lc &lt;&gt; null then
					locationSet.addNoDuplicates( lc, false );
				endif;
			endif;
		endif;
		
	endif;
	

	if not locationSet.isEmpty then	
		foreach lc in locationSet do
			self.myLocationsController := lc;
			self.doSearch;
		endforeach;
	elseif not voyageSet.isEmpty then
		foreach voyage in voyageSet do
			self.myVoyage := voyage;
			self.doSearch;
		endforeach;
	elseif not taSet.isEmpty then
		foreach ta in taSet do
			self.myTerminalAreaMaster := ta;
			self.doSearch;
		endforeach;
	elseif not trainSet.isEmpty then
		foreach train in trainSet do
			self.myTrain := train;
			self.doSearch;
		endforeach;
	elseif not vvrSet.isEmpty then
		foreach vvr in vvrSet do
			self.myVVR := vvr;
			self.doSearch;
		endforeach;
	elseif not termSet.isEmpty then
		foreach term in termSet do
			self.myTerminal := term;
			self.doDateSearch;
		endforeach;
	endif;
	
epilog

	endLoad;
	self.myContext := null;
	delete termSet;
	delete voyageSet;
	delete taSet;
	delete trainSet;
	delete vvrSet;
	delete locationSet;
	delete voyageCodeArray;
	delete iter;
	delete termTrainSet;
	delete termVvrSet;
	delete termVoyageSet;
	delete taIdsArray;
	delete lcIdsArray;
	
end;</source>
        <Parameter name="_qDef" type="CM_QueryDefinition"/>
    </JadeMethod>
    <JadeMethod name="doSearch" id="8f7160a2-97d4-4f1d-852d-353a6b806399">
        <updating/>
        <source>doSearch() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 April 2021	navndl1	Initial creation	TFS 50906

*/

vars

	iter : Iterator;
	locAct : CMEVT_LocationActivity;
	keyTimeStamp : TimeStamp;
	keyType : Integer;
	breakOut : Boolean;
	passport : CM_Passport;

begin

	passport := app.myPassport;
	
	if self.myLocationsController  &lt;&gt; null then
		iter :=	self.myLocationsController.allLocationActivity.createIterator();
	elseif self.myVoyage &lt;&gt; null then
		iter :=	self.myVoyage.allLocationActivity.createIterator();	
	elseif self.myTrain  &lt;&gt; null then
		iter :=	self.myTrain.allLocationActivity.createIterator();		
	elseif self.myVVR  &lt;&gt; null then
		iter :=	self.myVVR.allLocationActivity.createIterator();		
	elseif self.myTerminalAreaMaster &lt;&gt; null then
		iter :=	self.myTerminalAreaMaster.allLocationActivity.createIterator();	
	else
		return;
	endif;
	
	while iter.next( locAct ) do
		
		if (self.endDateTime &lt;&gt; null and locAct.dateTime &gt; self.endDateTime) then
			break;
		endif;
		
		if self.includesObject(locAct, breakOut, passport) then
			self.addObjectToSet(locAct);
		endif;
			
		if breakOut or self.breakOutOfSearch then
			break;
		endif;
		
	endwhile;
		
epilog

	delete iter;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="reset" id="b948db70-8fbc-4058-8135-5083ee25fcd6">
        <updating/>
        <source>reset() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date	Who	Reason
29 Apr 2021	navndl1	Initial creation	TFS 50906
18 Aug 2023 navsaa30 Bug 59389: MSL | Error 1039 Object already added - Selector
*/

vars

begin
	inheritMethod();
	self.eventTypes.clear();					//18.08.2023 navsaa30 #59389
	self.myTerminal := null;
	self.myTerminalAreaMaster := null;
	self.myTrain := null;
	self.myVVR := null;
	self.myVoyage := null;
	self.myLocationsController := null;
	self.startDateTime := null;
	self.endDateTime := null;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setMyFilterClass" id="f0b02cab-2093-4d6a-b7d6-b018911b24a0">
        <updating/>
        <source>setMyFilterClass() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 April 2021	navndl1	Initial creation	TFS 50906

*/

vars

begin
	self.myFilterClass := CMEVT_LocationActivity;

epilog

end;</source>
    </JadeMethod>
</Class>
