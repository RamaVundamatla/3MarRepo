    <JadeMethod name="getAttrISOType" id="c2b5d4b1-9cbb-4243-ba85-1d59dea79606">
        <source>getAttrISOType() : CM_ISOType;
/*
Purpose:			
Date				Who			Reason
SEPTEMBER 2014		CNWAB1		Initial creation
*/

vars
	criteria : CM_YACriteria;	
begin
	
	if self.useVoyageAllocations  then 
		criteria := self.getAttrByType(YACriteriaType_ISO); 
		if criteria &lt;&gt; null then
			return criteria.myYAData.CM_YADataObjects.allObjects.first.CM_ISOType;
		endif;
		criteria := self.getAttrByType(YACriteriaType_ISOGroup);
		if criteria &lt;&gt; null then
			if not criteria.myYAData.CM_YADataObjects.allObjects.isEmpty then
				return criteria.myYAData.CM_YADataObjects.allObjects.first.CM_ISOTypeGroup.allISOTypes.first;
			endif;
		endif;
	endif;

	return null;
epilog

end;</source>
        <ReturnType type="CM_ISOType"/>
    </JadeMethod>
    <JadeMethod name="getAttrIs20" id="2a21352d-828b-4c25-84c8-5870fc5334bf">
        <source>getAttrIs20(): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 August 2011	cnwer1	Initial creation CCMS MES 1033

*/

vars
	criteria : CM_YACriteria;	
begin
	
	//epr TFS 3284 7/2/17
	criteria := self.getAttrByType(YACriteriaType_IsTwenty);
	if criteria &lt;&gt; null then
		if criteria.myYAData.CM_YADataBoolean.getDataValue().Integer = CM_YADataBoolean.VALUE_TRUE then
			return true;
		endif;
	endif;
	criteria := self.getAttrByType(YACriteriaType_ISOGroup); 
	if criteria &lt;&gt; null then
		if self.getAttrCheckAllValuesCriteria(criteria.myYAData.CM_YADataObjects.allObjects,CM_ISOTypeGroup,CM_ISOTypeGroup::is20ftLong.name) then
			return true;
		endif;
	endif;
	criteria := self.getAttrByType(YACriteriaType_ISO); 
	if criteria &lt;&gt; null then
		if  self.getAttrCheckAllValuesCriteria(criteria.myYAData.CM_YADataObjects.allObjects,CM_ISOType,CM_ISOType::is20ftLong.name) then
			return true;
		endif;
	endif;
	
	return not (self.getAttrIs40() or self.getAttrIs30() or self.getAttrIs45() or self.getAttrIs53()); // PAR 16415 CCMS 1029

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getAttrIs30" id="7bc4ffe4-a307-4af4-bac7-0ddb46075541">
        <source>getAttrIs30() : Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
11 December 2009	cnwas3	Initial creation

*/

vars
	criteria : CM_YACriteria;
	intValue : Integer;
begin
	
	if self.useVoyageAllocations  then 
		// PAR 23263 criteria := self.allAllocations.last().CM_VoyageAllocation.getCriteriaOfTypeValue(YACriteriaType_IsThirty);
		criteria := self.getAttrByType(YACriteriaType_IsThirty); // PAR 23263 
		if criteria &lt;&gt; null then
			intValue := criteria.myYAData.CM_YADataBoolean.getDataValue().Integer;	//13 Apr 2015	NDL	Par 3603
			if intValue = CM_YADataBoolean.VALUE_FALSE then
				return false;
			elseif intValue = CM_YADataBoolean.VALUE_TRUE then
				return true;
			elseif intValue = CM_YADataBoolean.VALUE_EITHER then
				// do nothing here... try the other options
			endif;						
		endif;
		criteria := self.getAttrByType(YACriteriaType_ISOGroup); // PAR 23817 CHECK ISO GROUP
		if criteria &lt;&gt; null then
			//return criteria.myYAData.CM_YADataObjects.allObjects.first().CM_ISOTypeGroup.is30ftLong();	
			//cnwjo3 par 26153
			return self.getAttrCheckAllValuesCriteria(criteria.myYAData.CM_YADataObjects.allObjects,CM_ISOTypeGroup,CM_ISOTypeGroup::is30ftLong.name);
		endif;
		criteria := self.getAttrByType(YACriteriaType_ISO); // PAR 23817 CHECK ISO TYPE
		if criteria &lt;&gt; null then
			//return criteria.myYAData.CM_YADataObjects.allObjects.first().CM_ISOType.is30ftLong();	
			//cnwjo3 par 26153
			return self.getAttrCheckAllValuesCriteria(criteria.myYAData.CM_YADataObjects.allObjects,CM_ISOType,CM_ISOType::is30ftLong.name);
		endif;
	else
		return self.is30;
	endif;
	return false;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getAttrIs40" id="40670508-35c7-49f9-9533-d3d437c4c4dd">
        <source>getAttrIs40() : Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
11 December 2009	cnwas3	Initial creation
// 11/10/2022	navkc1	Bug 54935: MSL - Roro planning - Slow on big decks/large vessels
*/

vars
	criteria : CM_YACriteria;
	intValue : Integer;
	voyAllocation : CM_VoyageAllocation;
begin
	
	if self.useVoyageAllocations  then 
		voyAllocation := self.allAllocations.first().CM_VoyageAllocation; // 11/10/2022	navkc1	#54935
		if voyAllocation &lt;&gt; null then // 11/10/2022	navkc1	#54935
			// PAR 23263 criteria := self.allAllocations.last().CM_VoyageAllocation.getCriteriaOfTypeValue(YACriteriaType_IsForty);
			//criteria := self.getAttrByType(YACriteriaType_IsForty); // PAR 23263 
			criteria := voyAllocation.getCriteriaOfTypeValue(YACriteriaType_IsForty); // 11/10/2022	navkc1	#54935
			if criteria &lt;&gt; null then
				intValue := criteria.myYAData.CM_YADataBoolean.getDataValue().Integer;	//13 Apr 2015	NDL	Par 36032
				if intValue = CM_YADataBoolean.VALUE_FALSE then
					return false;
				elseif intValue = CM_YADataBoolean.VALUE_TRUE then
					return true;
				elseif intValue = CM_YADataBoolean.VALUE_EITHER then
					// do nothing here... try the iso stuff.
				endif;						
			endif;
			//criteria := self.getAttrByType(YACriteriaType_ISOGroup); // PAR 23817 CHECK ISO GROUP
			criteria := voyAllocation.getCriteriaOfTypeValue(YACriteriaType_ISOGroup); // 11/10/2022	navkc1	#54935
			if criteria &lt;&gt; null then		
				//cnwjo3 par 26153
				return self.getAttrCheckAllValuesCriteria(criteria.myYAData.CM_YADataObjects.allObjects,CM_ISOTypeGroup,CM_ISOTypeGroup::is40ftLong.name);
			endif;
			//criteria := self.getAttrByType(YACriteriaType_ISO); // PAR 23817 CHECK ISO TYPE
			criteria := voyAllocation.getCriteriaOfTypeValue(YACriteriaType_ISO); // 11/10/2022	navkc1	#54935
			if criteria &lt;&gt; null then						
				//cnwjo3 par 26153
				return self.getAttrCheckAllValuesCriteria(criteria.myYAData.CM_YADataObjects.allObjects,CM_ISOType,CM_ISOType::is40ftLong.name);
			endif;
		endif;
	else
		return (self.fortyFront);
	endif;
	return false;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getAttrIs45" id="ed411ec4-4fa7-41a4-8c57-bb85a89acd54">
        <source>getAttrIs45() : Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
11 December 2009	cnwas3	Initial creation
// 11/10/2022	navkc1	Bug 54935: MSL - Roro planning - Slow on big decks/large vessels
*/

vars
	criteria : CM_YACriteria;
	intValue : Integer;
	voyAllocation : CM_VoyageAllocation;
begin
	
	if self.useVoyageAllocations  then 
		voyAllocation := self.allAllocations.first().CM_VoyageAllocation; // 11/10/2022	navkc1	#54935
		if voyAllocation &lt;&gt; null then // 11/10/2022	navkc1	#54935
			 // PAR 23263 criteria := self.allAllocations.last().CM_VoyageAllocation.getCriteriaOfTypeValue(YACriteriaType_IsFortyFive);
			//criteria := self.getAttrByType(YACriteriaType_IsFortyFive); // PAR 23263 
			criteria := voyAllocation.getCriteriaOfTypeValue(YACriteriaType_IsFortyFive); // 11/10/2022	navkc1	#54935
			if criteria &lt;&gt; null then
				intValue := criteria.myYAData.CM_YADataBoolean.getDataValue().Integer;	//13 Apr 2015	NDL	Par 3603
				if intValue = CM_YADataBoolean.VALUE_FALSE then
					return false;
				elseif intValue = CM_YADataBoolean.VALUE_TRUE then
					return true;
				elseif intValue = CM_YADataBoolean.VALUE_EITHER then
					// do nothing here... try the other options
				endif;						
			endif;
			//criteria := self.getAttrByType(YACriteriaType_ISOGroup); // PAR 23817 CHECK ISO GROUP
			criteria := voyAllocation.getCriteriaOfTypeValue(YACriteriaType_ISOGroup); // 11/10/2022	navkc1	#54935
			if criteria &lt;&gt; null then
				//return criteria.myYAData.CM_YADataObjects.allObjects.first().CM_ISOTypeGroup.is45ftLong();	
				//cnwjo3 par 26153
				return self.getAttrCheckAllValuesCriteria(criteria.myYAData.CM_YADataObjects.allObjects,CM_ISOTypeGroup,CM_ISOTypeGroup::is45ftLong.name);
			endif;
			//criteria := self.getAttrByType(YACriteriaType_ISO); // PAR 23817 CHECK ISO TYPE
			criteria := voyAllocation.getCriteriaOfTypeValue(YACriteriaType_ISO); // 11/10/2022	navkc1	#54935
			if criteria &lt;&gt; null then
				//return criteria.myYAData.CM_YADataObjects.allObjects.first().CM_ISOType.is45ftLong();								
				//cnwjo3 par 26153
				return self.getAttrCheckAllValuesCriteria(criteria.myYAData.CM_YADataObjects.allObjects,CM_ISOType,CM_ISOType::is45ftLong.name);
			endif;
		endif;
	else
		return self.is45;
	endif;
	return false;
epilog

end;
</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getAttrIs53" id="b3db06a3-029c-43e7-a26a-88a5870447de">
        <source>getAttrIs53() : Boolean;

/*

Purpose:			

Parameters:			

