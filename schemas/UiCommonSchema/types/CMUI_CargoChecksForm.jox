    <JadeMethod name="updateAlternativeId" id="971087b5-ce75-43dd-ba47-22bfd3f43e92">
        <updating/>
        <source>updateAlternativeId(_alternativeId : String; _toDoTaskCode : Integer; _addingToDo : Boolean) : Boolean updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 15/07/2014	cnwdap1		Initial creation PAR #34568 CCMS SFW 1389 Alternative Id Cargo Check
//
vars
	load 		: Boolean;
	pxyTI		: CM_TrackedItem;
	controller	: CMIF_TIUpdateController;
	pxyGTE		: CMGTE_Receival;
	toDoTask	: CM_ToDoTaskDesc;
	toDoTasks 	: CM_ToDoTaskDescByCode;

begin
	if self.myTrackedItem &lt;&gt; null then
		if _addingToDo then
			if not self.updateTrackedItemAddToDoTask( _toDoTaskCode ) then
				return false;
			endif;
		endif;
	
		app.cmsBeginLoad(load);
		pxyTI := self.myTrackedItem.pxyCreateUpdateProxy;
		app.cmsEndLoad(load);
		
		controller := app.createTIUpdateControl(TI_UPDMODE_NORMAL, app.myPassport.userCode, null);
		pxyTI.zSetPxyAlternativeId(_alternativeId);
		
		return self.updateTrackedItem( pxyTI );
		
	elseif self.myGTEReceival &lt;&gt; null then
	
		app.cmsBeginLoad(load);
		pxyGTE := self.myGTEReceival.pxyCreateUpdateProxy;
		app.cmsEndLoad(load);
		
		pxyGTE.setPxyAlternativeId(_alternativeId);
		
		if _addingToDo and _toDoTaskCode &lt;&gt; null then
			toDoTask := app.myRoot.allToDoTaskDescriptions.getAtKey( _toDoTaskCode );
			if toDoTask &lt;&gt; null and not pxyGTE.allToDoTasks.includes(toDoTask) then
				create toDoTasks transient;
				toDoTasks.add(toDoTask);
				pxyGTE.setPxyToDoTasks( toDoTasks );
				delete toDoTasks;
			endif;
		endif;

		return self.updateGTEProxy( pxyGTE ); 
		
	endif;
	
	return false;

epilog
	// 34972 missing proxy deletes
	delete controller;
	delete pxyGTE;
	delete pxyTI;
end;</source>
        <Parameter name="_alternativeId" type="String"/>
        <Parameter name="_toDoTaskCode" type="Integer"/>
        <Parameter name="_addingToDo" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="updateCargoDimensions" id="8fa32de3-4c59-4e6f-b9ba-c8a912ab2b28">
        <updating/>
        <source>updateCargoDimensions(	_width, _length, _height : Decimal; _toDoTaskCode : Integer; _addingToDo : Boolean):Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 May 2014	cnwndl1	Initial creation

*/

vars

	load : Boolean;
	prxyTI	: CM_TrackedItem;
	prxyGTE : CMGTE_Receival;
	toDoTasks : CM_ToDoTaskDescByCode;
	toDoTask : CM_ToDoTaskDesc;	

begin
	
	if self.myTrackedItem &lt;&gt; null then
	
		if _addingToDo then
			if not self.updateTrackedItemAddToDoTask( _toDoTaskCode ) then
				return false;
			endif;
		endif;
	
		app.cmsBeginLoad(load);
		prxyTI := self.myTrackedItem.pxyCreateUpdateProxy.CM_Container;
		app.cmsEndLoad(load);
		
		// update the container over dimensions information
		prxyTI.setWidth(_width );
		prxyTI.setLength(_length );
		prxyTI.setHeight(_height );
		
		return self.updateTrackedItem( prxyTI );
		
	elseif self.myGTEReceival &lt;&gt; null then
	
		app.cmsBeginLoad(load);
		prxyGTE := self.myGTEReceival.pxyCreateUpdateProxy;
		app.cmsEndLoad(load);
		
		prxyGTE.setPxyCargoDimensions(	_width,	//_width : Decimal;
										_length,	//_length : Decimal;
										_height	//_height : Decimal
										);
		
		if _addingToDo and _toDoTaskCode &lt;&gt; null then
			toDoTask := app.myRoot.allToDoTaskDescriptions.getAtKey( _toDoTaskCode );
			if toDoTask &lt;&gt; null and not prxyGTE.allToDoTasks.includes(toDoTask) then
				create toDoTasks transient;
				toDoTasks.add(toDoTask);
				prxyGTE.setPxyToDoTasks( toDoTasks );
				delete toDoTasks;
			endif;
		endif;
			
		return self.updateGTEProxy( prxyGTE ); 
	
	endif;
	
	return false;

epilog

	app.cmsEndLoad(load);
	delete prxyTI;
	delete prxyGTE;
	delete toDoTasks;

end;</source>
        <Parameter name="_width" type="Decimal"/>
        <Parameter name="_length" type="Decimal"/>
        <Parameter name="_height" type="Decimal"/>
        <Parameter name="_toDoTaskCode" type="Integer"/>
        <Parameter name="_addingToDo" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="updateContainerDimensions" id="019bbee0-7b54-43f7-806f-3b3ea2859d0a">
        <updating/>
        <source>updateContainerDimensions(	_left, _right, _back, _front, _height : Decimal; _toDoTaskCode : Integer; _addingToDo : Boolean):Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 May 2014	cnwndl1	Initial creation	Par 33268

*/

vars
	
	load : Boolean;
	prxyTI	: CM_Container;
	prxyGTE : CMGTE_Receival;
	toDoTasks : CM_ToDoTaskDescByCode;
	toDoTask : CM_ToDoTaskDesc;

begin

	if self.myTrackedItem &lt;&gt; null then
	
		if _addingToDo then
			if not self.updateTrackedItemAddToDoTask( _toDoTaskCode ) then
				return false;
			endif;
		endif;
		
		app.cmsBeginLoad(load);
		prxyTI := self.myTrackedItem.pxyCreateUpdateProxy.CM_Container;
		app.cmsEndLoad(load);
			
		prxyTI.setOverWidthLeft(_left, null, app.myPassport);
		prxyTI.setOverWidthRight(_right, null, app.myPassport);
		prxyTI.setOverLengthRear(_back, null, app.myPassport);
		prxyTI.setOverLengthFront(_front, null, app.myPassport);
		prxyTI.setOverHeight(_height, null, app.myPassport);
		
		return self.updateTrackedItem( prxyTI );
		
		
	elseif self.myGTEReceival &lt;&gt; null then
	
		app.cmsBeginLoad(load);
		prxyGTE := self.myGTEReceival.pxyCreateUpdateProxy;
		app.cmsEndLoad(load);
		
		prxyGTE.setPxyContainerDimensions(	_front,	//_dimLenFront : Decimal;
											_back,	//_dimLenRear : Decimal;
											_left,	//_dimWidthLeft : Decimal;
											_right,	//_dimWidthRight : Decimal;
											_height	//_height : Decimal
											);
		
		if _addingToDo and _toDoTaskCode &lt;&gt; null then
			toDoTask := app.myRoot.allToDoTaskDescriptions.getAtKey( _toDoTaskCode );
			if toDoTask &lt;&gt; null and not prxyGTE.allToDoTasks.includes(toDoTask) then
				create toDoTasks transient;
				toDoTasks.add(toDoTask);
				prxyGTE.setPxyToDoTasks( toDoTasks );
				delete toDoTasks;
			endif;
		endif;
			
		return self.updateGTEProxy( prxyGTE ); 
		
	endif;
	
	return false;

epilog

	app.cmsEndLoad(load);
	delete prxyTI;
	delete prxyGTE;
	delete toDoTasks;

end;</source>
        <Parameter name="_left" type="Decimal"/>
