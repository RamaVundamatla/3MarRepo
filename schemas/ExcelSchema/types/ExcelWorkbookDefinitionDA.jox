    <JadeMethod name="doGetDataFromHostApplication" id="41bebb08-defb-407d-af95-fad1495cc1b7">
        <updating/>
        <source>doGetDataFromHostApplication():Boolean updating;

/*****************************************************
	Written by	:	cnwgrp1		12 May 2004
	Description	:	

	Change history
	--------------
	Date		By		Reason
******************************************************/

vars
	hsa : ExcelHugeStringArray;
	str : String;
begin
	create hsa transient;
	myControllingAppsDA.invokeMethod(myControllingAppsContext,
									myControllingAppsDataMethod,
	 								hsa,
	 								myWorkbookDefinition.myApplicationExtractOptions,
	 								associatedObjectType,
	 								associatedObjectName,
	 								myAssociatedObject,
	 								true);
	
	if hsa.size = 0 then
	//	app.msgBox('Excel not started as no data was selected', 'No Data', MsgBox_OK_Only);
		return false;
	endif;
	myExcelDA.pasteArrayInDatasheet(hsa);
	return true;
epilog
	delete hsa;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doMaintainWorkbook" id="268aa6f9-c297-42c7-b68d-19fac60a14b1">
        <updating/>
        <source>doMaintainWorkbook() updating;

constants
	Option_Load_Form = 1;
	Option_Activate_Form = 2;
	
vars
	frm		: ExcelWorkbookSearchForm;
	cls		: ExcelWorkbookSearchForm;
	root 	: Root;
begin
	on Exception do app.defaultExceptionHandler(exception);
	app.statusBusy(true);
	
	self.initialiseRoot();
	
	create frm;
	myExcelWorkbookSearchForm := frm;
	frm.setMyDA(self);
	frm.loadForm;
	allOpenForms.add(frm);
	myControllingAppsDA.invokeMethod(myControllingAppsContext, myControllingAppsShowMethod, frm, Option_Load_Form);
	frm.top := frm.top + 30;
	frm.show;
epilog
	app.statusBusy(false);

end;</source>
    </JadeMethod>
    <JadeMethod name="doRunWizardStep" id="4156871c-9843-4ff7-bd89-c34f7bd95e17">
        <updating/>
        <source>doRunWizardStep(pStep : Integer) updating;

/*****************************************************
	Written by	:	cnwgrp1		05 May 2004
	Description	:	This method is called after the step has been incremented and
					sets things up for the next step in the process

	Change history
	--------------
	Date		By		Reason
******************************************************/

vars

begin
	if pStep = 1 then
		doWorkbookDefnWizardStep1;
	elseif pStep = 2 then
		doWorkbookDefnWizardStep2;
	elseif pStep = 3 then
		doWorkbookDefnWizardStep3;
	elseif pStep = 4 then
		doWorkbookDefnWizardStep4;
	elseif pStep = 5 then
		doWorkbookDefnWizardStep5;
	elseif pStep = 6 then
		doWorkbookDefnWizardStep6;
	endif;

epilog

end;</source>
        <Parameter name="pStep" type="Integer"/>
    </JadeMethod>
