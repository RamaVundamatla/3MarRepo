    <JadeMethod name="getProcessProfileName" id="85f5f7ab-1c7d-482d-87bb-c879aa883af6">
        <source>getProcessProfileName(proc:Process):String;

vars
	i,j:Integer;
begin
	i:=1;
	return (proc.userInfo&amp;"///@").scanUntil("/",i);
end;
</source>
        <Parameter name="proc" type="Process"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getProfileString" id="a5fe0726-b13e-4bb3-b005-1cf7de50311d">
        <source>getProfileString(fileName,section,keyName,default:String):String;
//	To avoid having many ini files, dynamically return the expected values.
begin
	if section = "VehicleMounted" and keyName = "VehicleMountedDevice" then
		return app.jmtComputerName;
	else
		return inheritMethod(fileName, section, keyName, default);
	endif;
end;
</source>
        <Parameter name="fileName" type="String"/>
        <Parameter name="section" type="String"/>
        <Parameter name="keyName" type="String"/>
        <Parameter name="default" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getUserCmdLine" id="deb8b2ef-e46b-43d7-96ae-1ec9a53ad49f">
        <updating/>
        <source>getUserCmdLine():String updating;

vars
	s,t:String;
	i,j:Integer;
begin
	if app.isUnicode then
		s:=(call jtdGetCommandLineW);
	else
		s:=(call jtdGetCommandLineA);
	endif;
//	logMessage("&lt;"&amp;s&amp;"&gt;");
	i:=s.toLower.pos(" endjade ",1);
	if i=0 then return null; endif;  // No endJade token
	return s[i+8:end].trimBlanks;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
