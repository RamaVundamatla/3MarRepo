<Class name="CM_MachineRTQueueEntryLogger" id="072efc2b-1737-4e91-b034-77de4291bfe5">
    <superclass name="CM_MessageLogger"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="cmtrans"/>
    <ImplicitInverseRef name="myMachine" id="3ab28f18-b531-404b-9301-96373457f483">
        <embedded/>
        <type name="CM_Machine"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="myQueueEntry" id="827429e0-b65e-4f3f-aa57-61d1267d82bb">
        <embedded/>
        <type name="CM_RTQueueEntry"/>
    </ImplicitInverseRef>
    <JadeMethod name="addLog" id="fd0d76e1-6366-47ba-aeed-ac98afb8ceeb">
        <source>addLog(_message: String; _msgSeverity: Integer; _errorCode : Integer);
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 September 2009	cnwer1	Initial creation

*/

vars

begin
	if self.myMachine &lt;&gt; null then
		self.myMachine.addLogEntry(_message);
	endif;
	if self.myQueueEntry &lt;&gt; null  then
		self.myQueueEntry.addAlert(_message, _msgSeverity);
	endif;
	self.allMessages.add(_message);
	//13 Sep 2012	NDL	Par 30633
	if _errorCode &gt; 0 then
		if not self.allErrorCodesUsed.includes( _errorCode ) then
			self.allErrorCodesUsed.add( _errorCode );
		endif;
	endif;
epilog

end;</source>
        <Parameter name="_message" type="String"/>
        <Parameter name="_msgSeverity" type="Integer"/>
        <Parameter name="_errorCode" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setMyMachine" id="e065939c-6c34-4993-ae61-c8718dbc3735">
        <updating/>
        <source>setMyMachine(_mach: CM_Machine) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 September 2009	cnwer1	Initial creation

*/

vars

begin
	self.myMachine:=_mach;

epilog

end;</source>
        <Parameter name="_mach" type="CM_Machine"/>
    </JadeMethod>
    <JadeMethod name="setMyQueueEntry" id="f0790134-1c39-476a-b6b6-dd1d4220d906">
        <updating/>
        <source>setMyQueueEntry(_value: CM_RTQueueEntry) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 September 2009	cnwer1	Initial creation

*/

vars

begin
	self.myQueueEntry:=_value;

epilog

end;</source>
        <Parameter name="_value" type="CM_RTQueueEntry"/>
    </JadeMethod>
</Class>
