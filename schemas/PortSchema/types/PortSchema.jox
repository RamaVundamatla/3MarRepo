    <JadeMethod name="canUserAccessRelationalView" id="0e65ef42-a424-4f87-8bb3-61a691f5f57d">
        <source>canUserAccessRelationalView(_rv : RelationalView; _user : CM_User) : Boolean;
/*
Purpose:			Check user permission to access the requested relational view

Parameters:			

Return Value:		

Date		Who		Reason
07/11/2012	cnwdap1	Initial creation PAR #30668 CCMS APM 2208
*/
constants
	PermPrefix	= "PmAdmOdbc";
vars
	permName	: String;
	const		: Constant;

begin
	// permission name is built from 'PmAdmOdbc' and relational view name
	app.writeLog(method.qualifiedName &amp; " checking user " &amp; _user.code &amp; " can access relational view " &amp; _rv.name, LogDEBUG);	//25 Nov 2019	NDL	TFS 47053
	permName := PermPrefix &amp; _rv.name;
	app.writeLog(method.qualifiedName &amp; " looking for a permission for global constant name " &amp; permName, LogERROR);	//25 Nov 2019	NDL	TFS 47053
	const := currentSchema.findGlobalConstantInBranch(permName);
	if const = null or not const.getSource.isInteger then
		app.writeLog(method.qualifiedName &amp; " could not find permission for global constant name " &amp; permName, LogERROR);	//25 Nov 2019	NDL	TFS 47053
		return false;
	endif;
	
	if not _user.canDo(null, const.getSource.Integer) then
		app.writeLog(method.qualifiedName &amp; " user " &amp; _user.code &amp; " has no permission to access " &amp; _rv.name &amp; " relational view", LogERROR);	//25 Nov 2019	NDL	TFS 47053
		return false;
	endif;
	
	return true;
epilog

end;</source>
        <Parameter name="_rv" type="RelationalView"/>
        <Parameter name="_user" type="CM_User"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
