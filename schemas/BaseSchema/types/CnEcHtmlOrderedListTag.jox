    <DbClassMap file="basehtml"/>
    <PrimAttribute name="listStart" id="88474109-cf93-42aa-98b4-d228f8fb8f27">
        <embedded/>
        <type name="Integer"/>
    </PrimAttribute>
    <JadeMethod name="buildTagBody" id="9509366c-4603-4de0-bbc5-e63c2cb30c47">
        <source>buildTagBody(): String protected;
// --------------------------------------------------------------------------------
// Created:		06 December 2001 by cnwdad1
//
// Purpose:		Refer to the CnEcHtmlTagObject implementation.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	htmlString	: String;
	
begin
	if self.listStart &lt;&gt; 0 then
		htmlString	:=	' START="' &amp; self.getListEntry(self.listStart) &amp; '"';
	endif;
	
	if self.listType &lt;&gt; null then
		htmlString	:=	htmlString &amp; ' TYPE="' &amp; self.listType.String &amp; '"';
	endif;
	
	htmlString	:=	htmlString &amp; '&gt;' &amp; CrLf &amp; self.buildListEntries() &amp; inheritMethod();
	
	return htmlString;
end;</source>
        <access>protected</access>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getHtml" id="b1202ca8-4aac-4fa7-ae53-0d552b212eac">
        <source>getHtml(): String;
// --------------------------------------------------------------------------------
// Created:		06 December 2001 by cnwdad1
//
// Purpose:		Refer to the CnEcHtmlTagObject implementation.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return '&lt;OL' &amp; self.buildTagBody() &amp; '&lt;/OL&gt;';
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="isValidType" id="6e6cee71-e704-4f42-89db-1ea44986e4c3">
        <source>isValidType(pType:String):Boolean protected;
// --------------------------------------------------------------------------------
// Created:		06 December 2001 by cnwdad1
//
// Purpose:		Validates the receiver's list type setting.
//
// Parameters:	pType - The receiver's list type setting.
//
// Returns:		True if the list type setting is valid, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if pType = self.TYPE_ARABIC_NUMBERS
	or pType = self.TYPE_LOWER_ALPHA
	or pType = self.TYPE_UPPER_ALPHA
	or pType = self.TYPE_LOWER_ROMAN
	or pType = self.TYPE_UPPER_ROMAN
	then
		return true;
	else
		CnEcBaseHtmlException.raise_(CNEC_X_22003, '"' &amp; pType &amp; '" is not a valid Ordered List tag type');
	endif;
	
	return false;
end;</source>
        <access>protected</access>
        <Parameter name="pType" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
