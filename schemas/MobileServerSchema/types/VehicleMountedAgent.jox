    <JadeMethod name="userNotification" id="6f7d5321-a7e5-4f85-814b-3d780bf85245">
        <updating/>
        <source>userNotification(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
19 September 2006	cnwer1	Initial creation - PAR#xxxx

*/

vars
	theEvent : Integer;
	sendNote : Boolean;
	infoStr : String;
	info		: DTO_VehicleMountedInfo;
	currentQueueTask : CM_RTQueueTask;
	errorMsgs : DTO_HandHeldGateErrorDict;
	allRTQueues : CM_RadioTelemQueueByIdDict;
	theRTQueueEntry : CM_RTQueueEntry;
	eventAdd,
	eventRemove : Integer;
	eventObject : Object;
	objectEdition : Integer;
	invalidUserInfo : Boolean;
begin	
	eventAdd	:= self.myTerminal.getTerminalEvent(Event_New_Queue_Entry);
	eventRemove	:= self.myTerminal.getTerminalEvent(Event_Delete_Queue_Entry);
	//write method.name &amp; Tab &amp; eventType.String;
	// We have been told about a queue entry that has been added to this terminal.
	on Exception do app.handleDeletedObject(exception,eventObject,invalidUserInfo);
	
	theEvent := self.myTerminal.getEventFromTerminalEvent(eventType);
	//write method.name &amp; " " &amp;  theObject.String &amp; " " &amp; theEvent.String &amp; "  "  &amp; userInfo.String &amp; " " &amp; isBusy.String;
	//self.writeLog(method.name &amp; theEvent.String &amp; "  "  &amp; userInfo.String &amp; " " &amp; isBusy.String);

	if  theObject = self.myMachine then
		theEvent:=eventType;
		if eventType = EVENT_MACHQUEUE_ALTERED then
			self.myRTQueue:=self.myMachine.myPrimaryQueue;
			infoStr := "Transfer to RT Queue: " &amp; theObject.CM_Machine.queueId.trimRight();
			sendNote := true;
			self.resetNotes;
		elseif eventType = EVENT_MACH_BROADCAST_MSG then
			infoStr := userInfo.String;
			sendNote := infoStr &lt;&gt; null;
		elseif eventType = EVENT_RESET_MEDIATOR then
			create errorMsgs transient;
			currentQueueTask:=self.myMachine.currentQueueTask;
			if currentQueueTask &lt;&gt; null then
				self.doCancelTask(currentQueueTask.myEntry,false,errorMsgs);
			endif;
			if errorMsgs.isEmpty then
				self.doLogoff();
				infoStr := "RT Control has reset your session ";
				sendNote := true;	
			else
				sendNote := false;
			endif;
		endif;	
	elseif theObject.isKindOf(CM_RadioTelemetryQueue) and self.canSeeQueue(theObject.CM_RadioTelemetryQueue) then		
		if userInfo.isKindOf(CM_RTQueueEntry) and self.useNewTableLoad then
			eventObject:=userInfo.CM_RTQueueEntry;
			objectEdition:=eventObject.edition;
		endif;
		if theEvent = Event_New_Queue_Entry then
			sendNote:=not isBusy;
		elseif theEvent = Event_Delete_Queue_Entry then
			// theObjects invalid so can't really test anything so just
			sendNote:=not isBusy;
		elseif theEvent = Event_Update_Queue_Entry or theEvent = RTQueueEntry_Update_Event then
			if invalidUserInfo then
				return;
			endif;
			theEvent:=Event_New_Queue_Entry;
			sendNote:=not isBusy;
		endif;
		
		//if busy we need to queue notes so when refreshTableEntry is called when can update all other changed queue entries
		if not sendNote and self.useNewTableLoad  then
			self.updateQueuedNoteInfo(eventObject,theEvent);
		else
			self.removeQueuedNoteInfo(eventObject);
		endif;
	else
		return;
	endif;
	
	// Send the appropriate note.
	if sendNote then
		create info transient;
		info.event := theEvent + Event_Factor;
		info.eventMessage := infoStr;
		info.eventObject:=eventObject;
		self.causeEvent(self.Event_Server_Note, true, info);
	endif;

epilog
	if allRTQueues &lt;&gt; null then
		delete allRTQueues;
	endif;
end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
</Class>
