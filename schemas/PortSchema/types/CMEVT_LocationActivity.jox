    <JadeMethod name="auditId" id="bfa8502c-1b1f-4554-af70-b558b01732fa">
        <source>auditId(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 May 2021	navndl1	Initial creation	TFS 50906

*/

vars

	oidString : String;
	pos : Integer;
	str : String;

begin
	//Everything that helps to identify this can change, so we have to use the id part of the oid.

	oidString := self.getOidString();
	pos := oidString.pos(".", 1);
	str := oidString[ pos+1 : end ];
	
	return str;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="autoSetMyNextBalance" id="d6325592-4722-46db-87a9-90e96cabb7ee">
        <source>autoSetMyNextBalance( _sourceLocation : CM_LocationsController; _reCalcBalanceSet : CMEVT_LocationActivityByDate input ) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 April 2021	navndl1	Initial creation	TFS 50905 - we may effectively be inserting a 'balance' if the user has changed the data
													to a date preceding existing data of this cargotype/operator at this location.

*/

vars

	nextLocationBalance : CMEVT_LocationActivity;
	nextTS : TimeStamp;

begin

	nextTS := self.dateTime.cnEcAddDays( 1 );
	nextLocationBalance := _sourceLocation.getLocationActivity( self.cargoType, self.operatorCode, EVT_LocationBalance, nextTS );
	
	if nextLocationBalance &lt;&gt; null then
		//found one, link it and set it to be re-calculated because its starting balance value will be wrong.
		nextLocationBalance.setMyPrevBalance( self );
		nextLocationBalance.setNeedsRecalculating( true, _reCalcBalanceSet );
	endif;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_sourceLocation" type="CM_LocationsController"/>
        <Parameter name="_reCalcBalanceSet" type="CMEVT_LocationActivityByDate" usage="input"/>
    </JadeMethod>
