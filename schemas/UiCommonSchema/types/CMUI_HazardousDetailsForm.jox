    <JadeMethod name="btnUpdate_click" id="94267fb1-d5b9-44bd-9d86-2e03789be4d2">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnUpdate_click(btn: Button input) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 10/11/2016	cnwdap1		Initial creation TFS 2842 Hazardous Details Enhancements
//
vars

begin
	if self.mySnapShot &lt;&gt; null then
		self.doUpdateSnapHazards(); // TFS 40336
	else
		self.doUpdateTIHazards(false);
	endif;
epilog

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="clearAfterAdd" id="22fd5e05-0902-4163-a4c9-18c85a750f00">
        <updating/>
        <source>clearAfterAdd() updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 14/11/2016	cnwdap1		Initial creation TFS 2842 STWR Hazardous Details Enhancements
//
vars

begin
	self.clearDetails();
	self.tblHazards.clearAllSelected();
	self.btnUpdate.enabled := false;
	self.btnRemove.enabled := false;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="clearDetails" id="5fc873f8-d835-4f78-adf7-af638ecec917">
        <updating/>
        <source>clearDetails() updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 10/11/2016	cnwdap1		Initial creation TFS 2842 Hazardous Details Enhancements
//
vars

begin
	self.cmbHazClass.listIndex := -1;
	self.txtUNCodes.text := null;
	self.chkLimitedQty.value := false;
	self.cmbPackGroup.listIndex := -1;
	self.txtFlashpoint.text := null;
	self.cmbMarinePoll.listIndex := -1;
	self.cmbAcidBase.listIndex := -1;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="cmbHazClass_click" id="3811abc0-b924-4e7c-ae75-badc084dc8fe">
        <controlMethod name="CMUI_ComboBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbHazClass_click(combobox: ComboBox input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 April 2019	jlgab1	Initial creation

*/

vars

	haz : CM_HazardClass;
	undg : CM_UNDangerousGoods;
begin
	if process.isJLGAB1() then
		haz := combobox.listObject.CM_HazardClass;
		
		if haz &lt;&gt; null then
			undg := haz.allUNDGCodes.first;
			
			if undg &lt;&gt; null then
				self.txtUNCodes.text := undg.code;
				self.cmbPackGroup.text := undg.allPackingGroups.first;
				self.txtUNCodes_change(self.txtUNCodes);
			endif;
		endif;
	endif;


epilog

end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="cmbHazClass_displayRow" id="a4ee79e7-fbe1-4327-981b-8e30ea4f3146">
        <controlMethod name="ComboBox::displayRow"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbHazClass_displayRow(combobox: ComboBox input; obj: Object; lstIndex: Integer; bcontinue: Boolean io):String updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 14/11/2016	cnwdap1		Initial creation TFS 2842 Hazardous Details Enhancements
//
vars

begin
	if obj = null or obj.CM_HazardClass.isNotAvailableForEntry then
		return null;
	endif;
	
	return obj.CM_HazardClass.code &amp; Tab &amp; obj.CM_HazardClass.description;
epilog

end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
        <Parameter name="obj" type="Object"/>
        <Parameter name="lstIndex" type="Integer"/>
        <Parameter name="bcontinue" type="Boolean" usage="io"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="create" id="18f354f5-e37d-4e7b-bdec-0fa245bbc720">
        <updating/>
        <source>create() updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 16/11/2016	cnwdap1		Initial creation TFS 2842 STWR Hazardous Details Enhancements
//
vars

begin
	self.permissionView := PmAdmCargoEnquiryView;
	self.permissionMaint := PmAdmCargoEnquiryMaint;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doOK" id="86436987-32ea-4cdb-971e-36b6722bf89a">
        <updating/>
        <source>doOK() updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 14/11/2016	cnwdap1		Initial creation TFS 2842 Hazardous Details Enhancements
// 30/11/2016	cnwdap1		TFS 3058 Correct handling of hazards being updated
//
vars
	hazDict : CM_HazardByCodeDict;
	row : Integer;
	obj : Object;										// TFS 3058
	hazard : CM_TIHazard;

begin
	if self.mySnapShot &lt;&gt; null then // TFS 40336
		inheritMethod();
	
	else
		create hazDict transient;
		foreach row in self.tblHazards.fixedRows + 1 to self.tblHazards.rows do
			hazard := self.tblHazards.accessRow(row).itemObject.CM_TIHazard;
			hazDict.add(hazard);
		endforeach;
		
		// tidy up deleted hazard proxies																		// TFS 3058
		foreach obj in self.allDeletedProxies do																// TFS 3058
			hazard := obj.CM_TIHazard;																			// TFS 3058
			if self.myPxyBooking &lt;&gt; null and self.myPxyBooking.allTIHazards.includes(hazard) then				// TFS 3058
				self.myPxyBooking.allTIHazards.remove(hazard);													// TFS 3058
			elseif self.myPxyBookingItem &lt;&gt; null and self.myPxyBookingItem.allTIHazards.includes(hazard) then	// TFS 3058
				self.myPxyBookingItem.allTIHazards.remove(hazard);												// TFS 3058
			elseif self.myPxyTrackedItem &lt;&gt; null and self.myPxyTrackedItem.allTIHazards.includes(hazard) then	// TFS 3058
				hazard.setMyTrackedItem(null);																	// TFS 3058
			endif;																								// TFS 3058
		endforeach;																								// TFS 3058
		
		if self.myParentForm.updateHazardsFromDetailForm(hazDict) then
			inheritMethod();
		endif;
	endif;
epilog
	delete hazDict;
end;</source>
    </JadeMethod>
    <JadeMethod name="doRemoveHazard" id="cc4f22c0-72d8-4ce3-a5bf-618c96936b65">
        <updating/>
        <source>doRemoveHazard() updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 10/11/2016	cnwdap1		Initial creation TFS 2842 Hazardous Details Enhancements
//
vars
	pxyObject : Object;

begin
	if self.tblHazards.row &lt;= self.tblHazards.fixedRows or self.tblHazards.row &gt; self.tblHazards.rows then
		return;
	endif;
	pxyObject := self.tblHazards.accessRow(self.tblHazards.row).itemObject.Object;
	if pxyObject = null then
		return;
	endif;
	
	self.tblHazards.removeItemObject(pxyObject);
	self.allDeletedProxies.add(pxyObject);
	
	self.clearDetails;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doUpdateSnapHazards" id="b495d87e-0de9-40ce-bef0-bc6a4aab9a74">
        <updating/>
        <source>doUpdateSnapHazards() updating;
/*
Purpose:	TFS 40336		
/* Changes

Date		Name	TFS#		Description
============================================================================
SEPT 2018	CNWAB1	TFS 40336	Initial creation
23/05/2019	jlgka1	TFS 43346	LNX - Multiple Hazardous Details with same Hazardous Class.
============================================================================*/
vars
	thisProxy 	 : CM_HazardSnapShot;
	hazClass 	 : CM_HazardClass;
	flashPoint 	 : Real;
	packingGroup : String;
	id 			 : String;									
begin
	if not self.validateDetails then
		return;
	endif;
	
	thisProxy := self.tblHazards.accessRow(self.tblHazards.row).itemObject.CM_HazardSnapShot;
	// hazards collection on TI must be unique by hazard class code
	if self.myPxyTrackedItem &lt;&gt; null then												
		id := self.myPxyTrackedItem.id;													
	elseif self.myPxyBooking &lt;&gt; null then											
		id := self.myPxyBooking.bookingReference;										
	elseif self.myPxyBookingItem &lt;&gt; null then											
		id := self.myPxyBookingItem.myBookingReference.bookingReference;				
	endif;		
	
	if thisProxy = null then
		create thisProxy transient;
	endif;
	
	hazClass := self.cmbHazClass.listObject.CM_HazardClass;
	if self.txtFlashpoint.text &lt;&gt; null then
		//flashPoint := self.txtFlashpoint.text.Real;
		flashPoint := self.txtFlashpoint.text.String.asRealJMT;	//03 May 2017	NDL	TFS 4054
	else
		flashPoint := NULL_TEMPERATURE;
	endif;
	
	packingGroup := self.cmbPackGroup.text;
	if not packingGroup.isOneOf("I", "II", "III") then
		packingGroup := null;
	endif;
	
	thisProxy.setProxy(	hazClass.code, 
						hazClass.description, 
						self.txtUNCodes.text,
						self.mySnapShot,
						self.chkLimitedQty.value,
						self.cmbPackGroup.text,
						flashPoint,
						app.isMarinePollutantStringToEnum(self.cmbMarinePoll.text),
						self.cmbAcidBase.text	);
						
	self.tblHazards.updateItemObject(thisProxy, self.colorRow1, self.colorRow2, app.myPassport);
	
	self.clearAfterAdd();	
epilog
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doUpdateTIHazards" id="db3f6f9d-5c6a-424d-93e9-66df5c499b6d">
        <updating/>
        <source>doUpdateTIHazards(_isAdd : Boolean) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
/* Changes

Date		Name	TFS#		Description
============================================================================
10/11/2016	cnwdap1	TFS 2842 	Initial creation Hazardous Details Enhancements
02/12/2016	cnwdap1	TFS 3066 	Fix 1090 when adding duplicate hazard class to a booking or booking item
23/05/2019	jlgka1	TFS 43346	LNX - Multiple Hazardous Details with same Hazardous Class.
============================================================================*/
vars
	thisProxy	 : CM_TIHazard;
	hazClass 	 : CM_HazardClass;
	flashPoint 	 : Real;
	packingGroup : String;
	id 			 : String;								// TFS 3066
	
begin
	if not self.validateDetails then
		return;
	endif;
	
	// are we doing an update or an add?
	if not _isAdd then
		thisProxy := self.tblHazards.accessRow(self.tblHazards.row).itemObject.CM_TIHazard;
	endif;
	// hazards collection on TI must be unique by hazard class code
	if self.myPxyTrackedItem &lt;&gt; null then												// TFS 3066
		id := self.myPxyTrackedItem.id;													// TFS 3066
	elseif self.myPxyBooking &lt;&gt; null then												// TFS 3066
		id := self.myPxyBooking.bookingReference;										// TFS 3066
	elseif self.myPxyBookingItem &lt;&gt; null then											// TFS 3066
		id := self.myPxyBookingItem.myBookingReference.bookingReference;				// TFS 3066
	endif;																				// TFS 3066
	
	if thisProxy = null then
		create thisProxy transient;
	endif;
	
	hazClass := self.cmbHazClass.listObject.CM_HazardClass;
	if self.txtFlashpoint.text &lt;&gt; null then
		//flashPoint := self.txtFlashpoint.text.Real;
		flashPoint := self.txtFlashpoint.text.String.asRealJMT;	//03 May 2017	NDL	TFS 4054
	else
		flashPoint := NULL_TEMPERATURE;
	endif;
	
	packingGroup := self.cmbPackGroup.text;
	if not packingGroup.isOneOf("I", "II", "III") then
		packingGroup := null;
	endif;
	
	thisProxy.setProxy(	hazClass.code, 
						hazClass.description, 
						self.txtUNCodes.text,
						self.myPxyTrackedItem,
						self.chkLimitedQty.value,
						self.cmbPackGroup.text,
						flashPoint,
						app.isMarinePollutantStringToEnum(self.cmbMarinePoll.text),
						self.cmbAcidBase.text	);
						
	//self.addOrUpdateChildEntityInTable(pxyTI);
	self.tblHazards.updateItemObject(thisProxy, self.colorRow1, self.colorRow2, app.myPassport);
	
	self.clearAfterAdd();	
epilog
	
end;</source>
        <Parameter name="_isAdd" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="loadCombos" id="44eb04f1-96ac-4fc5-8036-9df4b8693e0e">
        <updating/>
        <source>loadCombos() updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 10/11/2016	cnwdap1		Initial creation TFS 2842 Hazardous Details Enhancements
//
vars
	hazClass : CM_HazardClass;
	hazTempRange : CM_HazTempRange;
	
begin
	self.cmbAcidBase.clear;
	self.cmbAcidBase.addItem(null);
	self.cmbAcidBase.addItem(CM_TIHazard.ACID);
	self.cmbAcidBase.addItem(CM_TIHazard.BASE);
	
	self.cmbHazClass.clear;
	self.cmbHazClass.addItem(null);
	foreach hazClass in app.myRoot.allHazardClasses where not hazClass.isNotAvailableForEntry do
		self.cmbHazClass.addItemObject(hazClass.code &amp; Tab &amp; hazClass.description, hazClass);
	endforeach;
	
	self.cmbPackGroup.clear;
	self.cmbPackGroup.addItem(null);
	self.cmbPackGroup.addItem("I");
	self.cmbPackGroup.addItem("II");
	self.cmbPackGroup.addItem("III");
	
	self.cmbMarinePoll.addItem(MarinePollutant_NullString);
	self.cmbMarinePoll.addItem(MarinePollutant_NoString);
	self.cmbMarinePoll.addItem(MarinePollutant_YesString);
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="populateDetails" id="53ee6f31-f569-43bb-9e38-3dca7ede56ca">
        <source>populateDetails(_tiHazard : CM_TIHazard);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 10/11/2016	cnwdap1		Initial creation TFS 2842 Hazardous Details Enhancements
// 08/01/2025   navsp1      MTN-19916 MTN - Hazard Packing Group Behaviour is incorrect
vars
	idx : Integer;
	hazClass : CM_HazardClass;
	packGrp	 : String;
begin
	if _tiHazard = null then
		return;
	endif;
	
	hazClass := app.myRoot.allHazardClasses[_tiHazard.code];
	if hazClass &lt;&gt; null then
		idx := self.cmbHazClass.findObject(hazClass);
		self.cmbHazClass.listIndex := idx;
	endif;
	self.txtUNCodes.text := _tiHazard.getUndgCodesAsString(false);	//25 Sep 2019	NDL	TFS 46633 - use full string not truncated version
	self.chkLimitedQty.value := _tiHazard.limitedQuantity;
	packGrp := _tiHazard.packingGroup;													//MTN-19916
	if packGrp &lt;&gt; null and self.cmbPackGroup.findStringExact(1, packGrp) = -1 then		//MTN-19916
		self.cmbPackGroup.addItem(packGrp);												//MTN-19916
	endif;																				//MTN-19916
	self.cmbPackGroup.listIndex := self.cmbPackGroup.findStringExact(1, packGrp);
	
	if _tiHazard.flashpointTemperature &lt;&gt; NULL_TEMPERATURE then
		self.txtFlashpoint.text := _tiHazard.flashpointTemperature.asStringJMT;
	endif;
	self.cmbMarinePoll.listIndex := self.cmbMarinePoll.findStringExact(1, app.isMarinePollutantEnumToString(_tiHazard.isMarinePollutant));
	self.cmbAcidBase.listIndex := self.cmbAcidBase.findString(1, _tiHazard.acidsBases);
epilog

end;</source>
        <Parameter name="_tiHazard" type="CM_TIHazard"/>
    </JadeMethod>
    <JadeMethod name="populateDetailsSnap" id="668d2f3b-5ea2-4765-aee4-a7ba105aa490">
        <source>populateDetailsSnap(_hazsnap : CM_HazardSnapShot);
/*
Purpose:	TFS 40336		
Date				Who			Reason
SEPTEMBER 2018		CNWAB1		Initial creation
*/

vars
	idx : Integer;
	hazClass : CM_HazardClass;
	marinePolly : Integer;
begin
	if _hazsnap = null then
		return;
	endif;
	
	hazClass := app.myRoot.allHazardClasses[_hazsnap.code];
	if hazClass &lt;&gt; null then
		idx := self.cmbHazClass.findObject(hazClass);
		self.cmbHazClass.listIndex := idx;
	endif;
	self.txtUNCodes.text := _hazsnap.undgCodes;
	self.chkLimitedQty.value := _hazsnap.limitedQuantity;
	self.cmbPackGroup.listIndex := self.cmbPackGroup.findStringExact(1, _hazsnap.packingGroup);
	if _hazsnap.flashpointTemperature &lt;&gt; NULL_TEMPERATURE then
		self.txtFlashpoint.text := _hazsnap.flashpointTemperature.asStringJMT;
	endif;
	
	self.cmbMarinePoll.listIndex := self.cmbMarinePoll.findStringExact(1, app.isMarinePollutantEnumToString(_hazsnap.isMarinePollutant));
	self.cmbAcidBase.listIndex := self.cmbAcidBase.findString(1, _hazsnap.acidsBases);
epilog

end;</source>
        <Parameter name="_hazsnap" type="CM_HazardSnapShot"/>
    </JadeMethod>
