    <JadeMethod name="valEDIIgnoreEDITrackedItem" id="6635fa0a-1e20-4730-b83a-370cabf271b4">
        <source>valEDIIgnoreEDITrackedItem(_coll :CM_EDITISet);
/*
Date		Who		Reason
22 Aug 2013	cnwcs5	CCMS POL 2221 / par 32094(2)
*/
vars
	ediTI	:CM_EDITrackedItem;
begin
	foreach ediTI in _coll do
		if ediTI.status &lt;&gt; CM_EDITrackedItem.EDI_STATUS_SKIP_PROCESSING_X then
			app.raiseCMException1 (INVALID_STATUS_IGNORE, ediTI.displayStatus, null, null);
		endif;
	endforeach;
epilog

end;</source>
        <Parameter name="_coll" type="CM_EDITISet"/>
    </JadeMethod>
