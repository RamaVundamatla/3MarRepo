    <JadeMethod name="doDrawTerminal" id="609bc845-f17d-43fd-b924-44891dac1d05">
        <updating/>
        <source>doDrawTerminal() updating;
// ---------------------------------------------------------------------------
// Created:		May 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars
	theTerminal : CM_Terminal;
	aPoint : Point;
	thePoints,rotatedPoints : PointArray;
//	theScaleFactor : Decimal[3,2];
	pntX1, pntX2, pntY1, pntY2, maxX, maxY : Real;
	theColour, theTop , theLeft : Integer;
	theTerminalArea : CM_TerminalArea;
	theGraphic : CM_Graphic;
	thePicture : Binary;
	theFrame : CMUI_PointDrawingFrame;
	theSDF : CMUI_ScrollableDrawingFrame;
	theLGraphic : CM_LayoutGraphic;
begin
	
	theTerminal := self.myTerminal;
	if theTerminal = null then
		return;
	endif;
	if theTerminal.allLayoutGraphics.isEmpty then
		return;
	endif;
	self.allAreaObjects.clear;
	theSDF := self.mySDF;
	self.mySDFTop.myDrawingFrame.CMUI_PointDrawingFrame.doBtnClearClick(true);
	// ###########
	// THE TERMINAL. Is drawn on the background SDF
	theFrame := self.mySDFBackground.myDrawingFrame.CMUI_PointDrawingFrame;
	theFrame.doBtnClearClick(true);
	
	foreach theGraphic in theTerminal.allLayoutGraphics  do
		thePoints := theGraphic.pointsPolygon;
		theColour := theGraphic.CM_LayoutGraphic.drawLineColour;
		self.doAddPolygonToFrame(theFrame,thePoints,theColour,true,theTerminal);
	endforeach;
	theFrame.drawAllPolygons(null);
	self.allAreaObjects.clear;
	
	self.doZOrder();

end;</source>
    </JadeMethod>
    <JadeMethod name="doDrawTerminalAreas" id="da568931-12a1-4ce7-baeb-127510fad3f9">
        <updating/>
        <source>doDrawTerminalAreas() updating;
// ---------------------------------------------------------------------------
// Created:		May 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars
	theTerminal : CM_Terminal;
	aPoint : Point;
	thePoints,rotatedPoints : PointArray;
	pntX1, pntX2, pntY1, pntY2, maxX, maxY : Real;
	theColour, theTop , theLeft : Integer;
	theTerminalArea : CM_TerminalArea;
	theGraphic : CM_Graphic;
	thePicture : Binary;
	theFrame : CMUI_PointDrawingFrame;
	theSDF : CMUI_ScrollableDrawingFrame;
	theLGraphic : CM_LayoutGraphic;
begin
	
	theTerminal := self.myTerminal;
	if theTerminal = null then
		return;
	endif;
	if theTerminal.allLayoutGraphics.isEmpty then
		return;
	endif;
	self.allAreaObjects.clear;
	theSDF := self.mySDF;
	self.mySDFTop.myDrawingFrame.CMUI_PointDrawingFrame.doBtnClearClick(true);

	// ###########
	// THE TERMINAL AREA. Is drawn on the foreground SDF
	theFrame := theSDF.myDrawingFrame.CMUI_PointDrawingFrame;
	theFrame.doBtnClearClick(true);
//	theTerminalArea	:= theTerminal.allTerminalAreas["WR2"];
//	if theTerminalArea &lt;&gt; null then
	foreach theTerminalArea	in theTerminal.allTerminalAreas do
		if theTerminalArea.hideFromOverView then
			continue;
		endif;
		theLGraphic := theTerminalArea.myLayoutGraphic;
		if theLGraphic &lt;&gt; null then
			thePoints := theLGraphic.pointsPolygon;
			theLGraphic.getLeftTop(theTop,theLeft);
			if theLeft &lt;&gt; 0 then
				thePoints := thePoints.movePolygon(theTop,theLeft);
			endif;
			
			self.doAddPolygonToFrame(theFrame,thePoints,theLGraphic.drawLineColour,false,theTerminalArea);			
		endif;
	endforeach;
//	endif;
	theFrame.drawAllPolygons(null);
	self.doZOrder();

end;</source>
    </JadeMethod>
    <JadeMethod name="doFrameDrawContextMenuEvent" id="458afe17-3235-4857-b305-18c509961c1b">
        <updating/>
        <source>doFrameDrawContextMenuEvent(cntrl: Frame input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating;
// ---------------------------------------------------------------------------
// Created:		May 2003 By Andrew Bishop cnwab1
//
// Purpose:		CALL BACK from CMUI_PointDrawingFrame
// ---------------------------------------------------------------------------
vars
	theTerminalArea : CM_TerminalArea;
	aLGraphic : CM_LayoutGraphic;
	thePoints : PointArray;
	anObjectObj, anObjectPoint : Object;
	idx : Integer;
	theTable : CM_ColourLegendTable;

begin
	self.doBuildMnuZoom();
	self.scrollPercentageY := y;
	self.scrollPercentageX := x;
	self.mnuZoom.userObject := null;
	
	foreach anObjectObj	in self.allAreaObjects do
		idx := idx + 1;
		if not anObjectObj.isKindOf(CM_TerminalArea) then
			continue;
		endif;
		aLGraphic := self.mySDF.myDrawingFrame.CMUI_PointDrawingFrame.allPointGraphics[idx].CM_LayoutGraphic;
		thePoints := aLGraphic.pointsPolygon;
		if thePoints.isPointInPolygon(x.Integer,y.Integer, 1) then
			theTerminalArea := anObjectObj.CM_TerminalArea;
			self.mnuZoom.userObject := theTerminalArea;
			break;
		endif;
	endforeach;
	self.mnuHideLegend.visible := false;
	
	if self.mode = self.Mode_Display then
		self.doVisibleMenus(true);		
	
		if theTerminalArea &lt;&gt; null then	
			self.mnuArea.userObject := theTerminalArea;
			self.mnuArea.caption := theTerminalArea.id &amp; " View &amp;Area...";
			self.mnuArea.visible := true;
			self.mnuRestrictions.visible := true;
			self.mnuRestrictions.userObject := theTerminalArea;
			self.mnuCargoHeight.visible := false;
			self.mnuCargoHeight.caption := theTerminalArea.id &amp; " Cargo &amp;Height";
			self.mnuCargoHeight.userObject := theTerminalArea;

			self.mnuRestrictions.caption := theTerminalArea.id &amp; " Location &amp;Maintenance...";
		endif;
	else
		self.doVisibleMenus(true);		
		self.mnuCargoHeight.visible := false;
		self.mnuCargoHeightAll.visible := false;
		self.mnuSavePositions.visible := true;
	endif;

	if cntrl.isKindOf(CMUI_ColourLegendFrame) then
		theTable :=	cntrl.CMUI_ColourLegendFrame.myLegendTable;
		self.mnuChangeColour.visible := false;
		
		if theTable.row &gt; theTable.fixedRows and theTable.row &lt;= theTable.rows then
			self.mnuChangeColour.visible := true;
			self.mnuChangeColour.caption := "Change &amp;Colour For '" &amp; theTable.accessCell(theTable.row,1).text &amp; "'...";
	
//			return self.showContextMenu(self.mnuContext, cntrl, conwin, mouse, x, y);
		endif;
	endif;

	self.mnuCargoHeightAll.visible := false;
	self.mnuCargoHeight.visible := false;
	
	return self.showContextMenu(self.mnuContext, cntrl, conwin, mouse, x, y);


end;</source>
        <Parameter name="cntrl" type="Frame" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doFrameDrawMouseDbClickEvent" id="4ddb7d45-05eb-41c4-aac8-1c2029d0bc06">
        <updating/>
        <source>doFrameDrawMouseDbClickEvent(frame: Frame input; x : Integer; y : Integer) updating;
// ---------------------------------------------------------------------------
// Created:		August 2003 By Andrew Bishop cnwab1
//
// Purpose:		CALL BACK from CMUI_PointDrawingFrame
//
// ---------------------------------------------------------------------------

vars

	aLGraphic : CM_LayoutGraphic;

	theTerminalArea : CM_TerminalArea;
	thePoints : PointArray;
	anObjectObj, anObjectPoint : Object;
	idx,tmpX,tmpY : Integer;
	found : Boolean;
begin
	foreach anObjectObj	in self.allAreaObjects do
		idx := idx + 1;
		if not anObjectObj.isKindOf(CM_TerminalArea) then
			continue;
		endif;

		theTerminalArea := anObjectObj.CM_TerminalArea;
		aLGraphic := self.mySDF.myDrawingFrame.CMUI_PointDrawingFrame.allPointGraphics[idx].CM_LayoutGraphic;
		thePoints := aLGraphic.pointsPolygon;
		if thePoints.isPointInPolygon(x.Integer,y.Integer, 1) then
			found := true;
			break;
		endif;
	endforeach;

	if found and  theTerminalArea &lt;&gt; null then
		self.doShowArea(theTerminalArea);
	endif;
end;</source>
        <Parameter name="frame" type="Frame" usage="input"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doFrameDrawMouseDownEvent" id="ec8417dd-0106-4e6a-ac6a-6583075c1798">
        <updating/>
        <source>doFrameDrawMouseDownEvent(frame: Frame input; button: Integer; shift: Integer; x: Real; y: Real) updating;
// ---------------------------------------------------------------------------
// Created:		May 2003 By Andrew Bishop cnwab1
//
// Purpose:		CALL BACK from CMUI_PointDrawingFrame
// ---------------------------------------------------------------------------
vars
	aLGraphic : CM_LayoutGraphic;

	theTerminalArea : CM_TerminalArea;
	thePoints : PointArray;
	anObjectObj, anObjectPoint : Object;
	idx,tmpX,tmpY : Integer;
begin

	if button = Window.MouseButton_Left then
//		if self.mode = self.Mode_Display then
			foreach anObjectObj	in self.allAreaObjects do
				idx := idx + 1;
				if not anObjectObj.isKindOf(CM_TerminalArea) then
					continue;
				endif;
		
				theTerminalArea := anObjectObj.CM_TerminalArea;
				aLGraphic := self.mySDF.myDrawingFrame.CMUI_PointDrawingFrame.allPointGraphics[idx].CM_LayoutGraphic;
				thePoints := aLGraphic.pointsPolygon;
				if thePoints.isPointInPolygon(x.Integer,y.Integer, 1) then
					tmpX := (x.Integer - self.mySDF.myHScroll.value );
					tmpY := (y.Integer - self.mySDF.myVScroll.value) + 20;
					self.doShowToolTip(theTerminalArea.typeString &amp; " " &amp; theTerminalArea.id,tmpX,tmpY);
					break;
				endif;
			endforeach;
//		endif;	
	endif;	
end;</source>
        <Parameter name="frame" type="Frame" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
