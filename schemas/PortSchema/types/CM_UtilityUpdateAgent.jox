	// do validation
	self.raiseExceptionIfNull( _pxyObject, app.getErrorString( InterfaceHistory ) );
	
	app.setContinueCMExceptions( true );
	
	app.myValUA.valInterfaceHistory( _pxyObject );
	
	if not self.checkValidationWithPassport( _passport ) then
		return;
	endif;
	
	realObject	:= self.getRealObjectAndEditionCheck(	_pxyObject,
														app.getErrorString( InterfaceHistory ),
														_passport ).CM_InterfaceHistory;
	
	if _passport.noErrors then
		// This is only required if the class is being audited
		self.myUpdateAuditAgent.audUpdateGeneric( realObject, true );
	endif;
	
	if _passport.noErrors then
		// do updates
		realObject.setForUpdate( _pxyObject );
	endif;
	
	if _passport.noErrors then
		// This is only required if the class is being audited
		self.myUpdateAuditAgent.audUpdateGeneric( realObject, false );
	endif;
	
epilog
	
end;
</source>
