        <source>utlUpdateDataDumpExtrClassTs(_realExtractClass : CM_DataDumpExtractClass io; _expectedEdition: Integer;
		_extractedUpTo: TimeStamp; _passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:     Jan 2006 by cnwrs1
// ---------------------------------------------------------------------------
vars
	
begin
	self.initialiseActivity();
	
	if _realExtractClass = null then
		self.raiseExceptionIfNull(_realExtractClass, 'dataDumpExtractClass');
	endif;

	_realExtractClass.raiseExceptionIfTransient(method);

	app.setContinueCMExceptions(true);

	if (not self.checkValidationWithPassport(_passport)) then
		return;
	endif;

	app.setContinueCMExceptions(false);

	exclusiveLock(_realExtractClass);

	if _passport.noErrors and _realExtractClass.edition &lt;&gt; _expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'dataDumpExtractClass', null, null);
		return;
	endif;
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(_realExtractClass, true);
	endif;
	
	_realExtractClass.setExtractedUpTo(_extractedUpTo);

	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(_realExtractClass, false);
	endif;
end;</source>
        <Parameter name="_realExtractClass" type="CM_DataDumpExtractClass" usage="io"/>
