end;</source>
    </JadeMethod>
    <JadeMethod name="showPropertyFrame" id="d95d613e-1f57-4bc5-8230-5b40e677fb4a">
        <updating/>
        <source>showPropertyFrame(_entTableView : String; _mode : Integer; _actualHeight: Integer) updating;
// ---------------------------------------------------------------------------
// Created:		March 2004 By Andrew Bishop cnwab1
//
// Purpose:		Show the property frame for a new entry
//09/02/2017 cnwma1  TFS #2901:ADP - Variable storage charges based on weight and time
// ---------------------------------------------------------------------------
//07 June 2018	jlgsl4	TFS 38711 - STWO - exception when copying Move transactions
// 15/05/2023	navkc1	CR 57927 Task 54268 - Transaction Map

vars
	theTable : CM_EntryTable;
	theFrame : Frame;
	theFolder : CMUI_Folder;
	theHeight : Integer;
	doEdit : Boolean;
begin

	theTable := self.tblProperties;
	
	if _mode = self.ModeProperty_TransMap then
		if not self.displayTransMap() then
			return;
		endif;
		theHeight := (theTable.rows * 16) + 30;
	
	elseif _mode = self.ModeProperty_CargoAlloc then // PAR 35833
		self.showCargoAllocationsForm(); // PAR 35833
		return;
	elseif _mode = self.ModeProperty_Inventory then  // ### TFS 51219 25MAY2021 NAVAB1
		self.showCargoAllocationsForm();  // ### TFS 51219 25MAY2021 NAVAB1
		return;
	elseif _mode = self.ModeProperty_CargoType then
		self.displayCargoType();
		return;
	elseif _mode = self.ModeProperty_IMEX then
		self.displayIMEX();
		return;
	elseif _mode = self.ModeProperty_Contents then
		self.displayContents();
		return;
	elseif _mode = self.ModeProperty_Commodity then
		self.displayCommodities();
		return;
	elseif _mode = self.ModeProperty_ProductGroup then
		self.displayProductGroups();
		return;
	elseif _mode = self.ModeProperty_Product then
		self.displayProducts();
		return;
	elseif _mode = self.ModeProperty_Quantity then
		self.displayQuantity();
		return;
	elseif _mode = self.ModeProperty_QuantityRange then
		self.displayQuantityRange();
		return;
	elseif _mode = self.ModeProperty_SubQuantity then  		//09/02/2017 cnwma1 TFS #2901
		self.displaySubQuantity();
		return;
	elseif _mode = self.ModeProperty_SubQuantityRange then 	//09/02/2017 cnwma1 TFS #2901
		self.displaySubQuantityRange();	
		return;
	elseif _mode = self.ModeProperty_TransType then
		self.displayTransactionTypes();
		return;
	elseif _mode = self.ModeProperty_Invoice then
		if self.myCurrentMapTMSS = null then
			self.showMappingFrame();
		else
			self.displaySnapShotInvoiceMap();
		endif;
		return;
	elseif _mode = self.ModeProperty_Debtor then
		self.displayDebtors();
		return;
	elseif _mode = self.ModeProperty_Resource then
		self.displayResource();
		return;
	elseif _mode = self.ModeProperty_ResourceType or		//06 Jan 2010 NDL CCMS MES 1006
			_mode = self.ModeProperty_EventResourceType or  // 15/05/2023	navkc1	CR 57927 Task 54268
			_mode = self.ModeProperty_WOResourceType then	// 15/05/2023	navkc1	CR 57927 Task 54268
		self.displayResourceType();
		return;
	elseif _mode = self.ModeProperty_Event then
		self.displayEvent();
		return;
	elseif _mode = self.ModeProperty_WorkOrder then // TFS 39236
		self.displayWorkOrder();
		return;
	elseif _mode = self.ModeProperty_BOL then // 01 Nov 2019	NDL	TFS 47100
		self.displayBOL();
		return;
	elseif _mode = self.ModeProperty_Move then
		// doEdit := app.myPassport.myUser.canDo(self.myTerminal,PmAdmInvLineDescrMaint); // TFS 38711
		// 30872 no edit of VOID inv line type
		//if self.myCurrentMapInvoiceLineType.isVoid then // TFS 38711
		//	doEdit := false; // TFS 38711
		//endif; // TFS 38711
		self.displayTransactionTypes(); // TFS 38711
		//self.myAssistant.INV_Assistant.showInvoiceLineTypeForm(self.myCurrentMapInvoiceLineType, self.myMasterMenuAction, true, doEdit); // TFS 38711	
		return;
	elseif _mode = self.ModeProperty_InvoiceLine then		// 13/11/18 MAP TFS40358
		 doEdit := app.myPassport.myUser.canDo(self.myTerminal,PmAdmInvLineDescrMaint);
		// 30872 no edit of VOID inv line type
		if self.myCurrentMapInvoiceLineType.isVoid then
			doEdit := false;
		endif;
		self.myAssistant.INV_Assistant.showInvoiceLineTypeForm(self.myCurrentMapInvoiceLineType, self.myMasterMenuAction, true, doEdit);
		return;
	elseif _mode = self.ModeProperty_SnapShot then
		self.displaySnapShotMap();
		return;
	else
		app.msgBox("Invalid Property Mode '" &amp; _mode.String &amp; "'.", "Show Property", MsgBox_OK_Only);
		return ;
	endif;

	theFrame := self.frmProperties;
	theFolder := self.fldProperties;
	
	theTable.height := theHeight;

	theFolder.height := theHeight;
	theFolder.width := theFrame.clientWidth - 10;
	theFolder.left := 5;	
	theFolder.top := self.frmPropToolbar.clientHeight + 5;

	theTable.width := theFolder.clientWidth;
	theTable.left := 0;
	theTable.top := 0;
	theTable.accessColumn(1).width := 100;
	theTable.accessColumn(2).width := (theTable.width - 100).Integer;

	theFrame.height := self.frmPropToolbar.height + theHeight + 30;
	theFrame.zOrder(1);
	theFrame.centreWindow();
	theFrame.visible := true;
	self.lstData.enabled := false;
	self.frmToolbar.enabled := false;
	theTable.setFocus;
end;</source>
        <Parameter name="_entTableView" type="String"/>
        <Parameter name="_mode" type="Integer"/>
        <Parameter name="_actualHeight" type="Integer"/>
    </JadeMethod>
