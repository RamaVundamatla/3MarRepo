end;</source>
    </JadeMethod>
    <JadeMethod name="loadFormOfClass" id="0eac1660-d41d-41c7-84f8-4744568f0861">
        <updating/>
        <source>loadFormOfClass(_theTerminal : CM_Terminal;formClass: Class; permissionCode:Integer; permLabel:String): Form updating;

vars
	frm:          Form;
begin

	app.mousePointer := MP_HOURGLASS;

	if not checkSecurity(permissionCode,permLabel) then
		return null;
	endif;


	frm := app.getForm(formClass.name);
	if frm = null then
		create frm as formClass;
		frm.setPropertyValue("myTerminal",_theTerminal);
		frm.show;
	else
		if frm.windowState = 1 then
			frm.windowState := 0;
		endif;
		frm.setPropertyValue("myTerminal",_theTerminal);
		frm.setFocus;
	endif;
	return frm;
epilog
	app.mousePointer := MP_DEFAULT;
end;</source>
        <Parameter name="_theTerminal" type="CM_Terminal"/>
        <Parameter name="formClass" type="Class"/>
        <Parameter name="permissionCode" type="Integer"/>
        <Parameter name="permLabel" type="String"/>
        <ReturnType type="Form"/>
    </JadeMethod>
