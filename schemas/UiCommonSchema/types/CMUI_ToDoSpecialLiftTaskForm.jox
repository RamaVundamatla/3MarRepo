<GUIClass name="CMUI_ToDoSpecialLiftTaskForm" id="71757ebc-7439-4f0b-afe5-9a668f8dfc18">
    <superclass name="CMUI_Modal"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <ImplicitInverseRef name="allSelectedSpecLifts" id="ec168ef8-7b78-4546-9f4d-fbf1314be92f">
        <memberTypeInverse/>
        <type name="CM_SpecialLiftByCodeDict"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="frmMain" id="3183ab7f-ea18-4222-a1ce-a00b3bdf72bf">
        <embedded/>
        <type name="CMUI_Frame"/>
    </ImplicitInverseRef>
