    <JadeMethod name="setTrackedItem" id="3dede00e-1224-49fe-bbca-a24acc72e65d">
        <updating/>
        <source>setTrackedItem(_ti: CM_TrackedItem) updating;
//-------------------------------------------------------------------
//	Created:	10 December 2008	by Jared Oelderink-Wale (cnwjo3)
//
//	Reason:		Need to be able to find cargo for trackedItem
//-------------------------------------------------------------------
vars

begin
	if self.myTrackedItem = null then 
		self.myTrackedItem := _ti;
	endif;
	
	if _ti &lt;&gt; null then //cnwrs1 June 2009 required for testing
		if not self.allTrackedItems.includes(_ti) then	// cnwdad1 09/04/2010 - PAR #22153.
			self.allTrackedItems.add(_ti);
		endif;
	endif;
end;
</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="setVoyageCode" id="5d576df2-d8a8-420b-84bc-8ecaf906d9a8">
        <updating/>
        <source>setVoyageCode( _value : String ) updating;
/*
Date			Who		Reason
09 June 2010	cnwrl1	Initial creation as part of PAR 24299 - SFW 1118 EDI Form to allow searching of EDI file by Container / Voyage
11 April 2013	cnwcs5	Make use of local variables
// 20 Nov 2018	jlgrs1	TFS 41659 STWR Make EDI MultiThreaded Stage 6
*/
vars
	config			:CM_EDIConfig;
	coll			:CM_EDITIsByVoyageCodeDict;
	code, codeUpper	:String;
begin
	// need to make sure the manual collection on CM_EDIConfig gets maintained correctly, this collection
	// keeps track of all EDITrackedITems that have some connection to a voyageCode of some kind.
	config := self.myEDIConfig;
	
	if config &lt;&gt; null then
		coll := config.allEDITrackedItemsByVoyageCode;
	endif;
	
	code := self.voyageCode;
	
	// remove the previous non-null value from this collection
	if code &lt;&gt; null and coll &lt;&gt; null then
		codeUpper := code.toUpper;
		
		if coll.includesKey( codeUpper, self ) then
			coll.removeKeyEntry( codeUpper, self, self );
		endif;
	endif;

	// now change it and add this new value to the manual collection (if not null).
	code			:= _value[ 1 : self.voyageCode.maxLength ];
	self.voyageCode	:= code;
	
	if not self.isTransient and
	   code &lt;&gt; null and coll &lt;&gt; null then
		codeUpper := code.toUpper;
		
		if not coll.includesKey( codeUpper, self ) then
			coll.putAtKey( codeUpper, self, self );
		endif;
	endif;
	
epilog
	
end;
</source>
        <Parameter name="_value" type="String"/>
    </JadeMethod>
    <JadeMethod name="vesselNameVerify" id="5f48c6b1-c128-4ad0-8acd-2b2e9d92581c">
        <source>vesselNameVerify(_terminal : CM_Terminal):String;

vars
	voyageOid	: CM_Voyage;
	message		: String;
	value		: Integer;
	
begin
	value := VALID;
//	voyageOid := _terminal.lookupVoyage(self.voyageCode, null, false);	// cnwrl1 09/06/2010 PAR 24299 - what it was
	voyageOid := _terminal.lookupVoyage(self.getVoyageCode(), null, false);
	
	if voyageOid = null
	or voyageOid.vesselName.trimBlanks() &lt;&gt; self.vesselName.trimBlanks()
	then
		value := WARNING;
		message := "Vessel name does not match.";
	endif;
	
	return value.String &amp; message;
end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="voyageCodeVerify" id="3998123e-927a-4530-9994-1e45b4bdad1c">
        <source>voyageCodeVerify(_terminal : CM_Terminal) :String;
vars
	value: Integer;
	message: String;
	voyageCodeStr	: String;
	
begin
	value := WARNING;
//	if _terminal.lookupVoyage(voyageCode.trimBlanks, null, false) &lt;&gt; null		// cnwrl1 09/06/2010 PAR 24299 - what it was
//	or _terminal.lookupVoyage(voyageCode.trimBlanks &amp; " ", null, false) &lt;&gt; null	// cnwrl1 09/06/2010 PAR 24299 - what it was
	voyageCodeStr	:= self.getVoyageCode().trimBlanks;
	if _terminal.lookupVoyage( voyageCodeStr, null, false) &lt;&gt; null
	or _terminal.lookupVoyage( voyageCodeStr &amp; " ", null, false) &lt;&gt; null
	then
		value := VALID;
	else
		message := "Voyage Code is not valid.";
	endif;
	return value.String &amp; message;
end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <ReturnType type="String"/>
    </JadeMethod>
</Class>
