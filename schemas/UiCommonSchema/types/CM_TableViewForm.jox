    <JadeMethod name="doCancel" id="d691400e-2d24-4b70-b332-7419ffa831d7">
        <updating/>
        <source>doCancel() : Boolean updating;
// ---------------------------------------------------------------------------
// Created:     02 March 2001 by cnwrs2
//
// Purpose:     Developer should put code in here to delete the current item
//
// Parameters:  None
//
// Returns:     True if the item was deleted.
//				False if the item was not deleted
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
constants
	CANCEL_UNLOAD = 1;
vars

	reason,
	cancel	: Integer;
	rtn		: Boolean;

begin

	reason := QueryUnload_User;
	self.doQueryUnload(cancel, reason);
	rtn := cancel &lt;&gt; CANCEL_UNLOAD;
	
	return rtn;
	
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
