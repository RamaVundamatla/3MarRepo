    <JadeMethod name="getVesselVisitCountStr" id="c5a6e8b7-44e0-4be1-9276-6075da2d2bae">
        <source>getVesselVisitCountStr(_vesselCode : String; _endDT : TimeStamp) : String;
//--------------------------------------------------
// Created:	17 March 2005 By: cnwgd1
//--------------------------------------------------
vars
	tmpHVdata : HMS_VesselDataHarbour;
	tmpVessel : CM_Vessel;
	cnt : Integer;
	term : CM_Terminal;
begin
	
	if _vesselCode = null then
		return null;
	endif;
	
	tmpVessel := app.myRoot.allVessels[_vesselCode];
	if tmpVessel &lt;&gt; null then
		if tmpVessel.myHMSVesselData &lt;&gt; null then
			tmpHVdata := tmpVessel.myHMSVesselData.allVesselDataForHarbour[self];
			if tmpHVdata &lt;&gt; null then
				cnt := tmpHVdata.initialVoyageCount;
			endif;
		endif;
	endif;
	
	foreach term in self.allTerminalsByCode do
		cnt := cnt + term.getVesselVisitCount(_vesselCode, _endDT);
	endforeach;
	return cnt.String;
end;</source>
        <Parameter name="_vesselCode" type="String"/>
        <Parameter name="_endDT" type="TimeStamp"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getVesselsLastVoyage" id="64fe4c60-419a-4dc6-9aee-1165ee335925">
        <source>getVesselsLastVoyage(_vesselCode : String) : CM_Voyage;
//--------------------------------------------------
// Created:	1 April 2005 By: cnwgd1
//--------------------------------------------------
vars
	lastVoyage,
	tmpVoyage : CM_Voyage;
	term : CM_Terminal;
begin
	
	if _vesselCode = null then
		return null;
	endif;

	foreach term in self.allTerminalsByCode discreteLock do
		tmpVoyage := term.getVesselsLastVoyage(_vesselCode);
		if tmpVoyage &lt;&gt; null then
			if lastVoyage = null then
				lastVoyage := tmpVoyage;
			elseif tmpVoyage.arrivedDT &gt; lastVoyage.arrivedDT then
				lastVoyage := tmpVoyage;
			endif;
		endif;
	endforeach;
	return lastVoyage;
end;</source>
        <Parameter name="_vesselCode" type="String"/>
        <ReturnType type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="3339dec2-7caa-4d95-a709-535b7be86592">
        <source>pxyCreateUpdateProxy(): SelfType;
//--------------------------------------------------------------
//Created: 11 July 2003 By: cnwgd1
//--------------------------------------------------------------
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy

vars
	proxy : HMS_Harbour;
	completedOK		: Boolean;
begin
	proxy := inheritMethod();

	proxy.myRoot 				:= self.myRoot;
	proxy.ofBunkersGroup 		:= self.ofBunkersGroup;	
	proxy.ofMoveTimeCheckLock 	:= self.ofMoveTimeCheckLock;	
	proxy.ofPhoneGroup 			:= self.ofPhoneGroup;	
	proxy.defaultArrvBerth 		:= self.defaultArrvBerth;
	proxy.defaultDepartBerth 	:= self.defaultDepartBerth;
	proxy.myEmailGroup			:= self.myEmailGroup;
	proxy.myDefaultTerminal		:= self.myDefaultTerminal;

	self.allWharfDisplayOrderArray.copy(proxy.allWharfDisplayOrderArray);
	self.allTerminalsByCode.copy(proxy.allTerminalsByCode);	
	self.allWharves.copy(proxy.allWharves);	

	self.defaultOrderTimesArrive.copy(proxy.defaultOrderTimesArrive);
	self.defaultOrderTimesDepart.copy(proxy.defaultOrderTimesDepart);
	self.defaultOrderTimesShift.copy(proxy.defaultOrderTimesShift);	

	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return proxy;
	
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete proxy;
	endif;	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="removeWharfFromDisplay" id="b1fe5175-73a7-42ab-99b6-2f753379008e">
        <updating/>
        <source>removeWharfFromDisplay(_wharf : HMS_Wharf) updating;
//********************************************************************
//
// Created by: cnwsh3
//
// Date: 17 December 2004
//
// self.allWharfDisplayOrderArray holds the order wharves are being displayed
// on the Graphical View.  We need to remove the wharf from this array when it is
// being deleted.
//********************************************************************
vars

begin
	if _wharf = null then
		return;
	endif;
	
	if self.allWharfDisplayOrderArray.includes(_wharf) then
		self.allWharfDisplayOrderArray.remove(_wharf);
	endif;

	
end;</source>
        <Parameter name="_wharf" type="HMS_Wharf"/>
    </JadeMethod>
    <JadeMethod name="requiresPilotFor" id="1cec8cd7-dcd4-4945-a62e-9d9d48eaac33">
        <source>requiresPilotFor( _vessel : CM_Vessel; _voyage : CM_Voyage; _movement : HMS_VoyageMovement ):Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
30 April 2012	cnwndl1	Initial creation	Par 29496

*/

vars

	pilotRule : HMS_PilotExemptionRule;

begin

	if _voyage &lt;&gt; null then
	
		foreach pilotRule in self.allPilotExemptionRules do
			if pilotRule.voyageRequiresPilotForRule( _voyage, _movement ) then
				return true;
			endif;
		endforeach;
	
	else

		foreach pilotRule in self.allPilotExemptionRules do
			if pilotRule.vesselRequiresPilotForRule( _vessel ) then
				return true;
			endif;
		endforeach;
	
	endif;
	
	return false;

epilog

end;</source>
        <Parameter name="_vessel" type="CM_Vessel"/>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_movement" type="HMS_VoyageMovement"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
