epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setProxy" id="8e470c75-9143-441a-8037-ba074134a510">
        <updating/>
        <source>setProxy(	_allowHiCube : Boolean;
			_code : String;
			_description : String;
			_maxHeight : Decimal;
			_maxWeightWagon : Decimal;
			_maxWidth : Decimal;
			_isNotAvailableForEntry : Boolean;
			_maxWeight : Decimal;
			_noMTs : Boolean
			) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 June 2009	cnwndl1	Initial creation

*/

vars

begin

	self.raiseExceptionIfNotTransient(method);
	
	self.allowHiCube := _allowHiCube;
	self.description := _description;
	self.maxHeight := _maxHeight;
	self.maxWeightWagon := _maxWeightWagon;
	self.maxWidth := _maxWidth;
	self.isNotAvailableForEntry := _isNotAvailableForEntry;
	self.maxWeight := _maxWeight; // PAR 23176
	self.noEmptyWagons := _noMTs; // PAR 23176
	self.code := _code.toUpper.trimBlanks;

epilog

end;</source>
        <Parameter name="_allowHiCube" type="Boolean"/>
        <Parameter name="_code" type="String"/>
        <Parameter name="_description" type="String"/>
        <Parameter name="_maxHeight" type="Decimal"/>
        <Parameter name="_maxWeightWagon" type="Decimal"/>
        <Parameter name="_maxWidth" type="Decimal"/>
        <Parameter name="_isNotAvailableForEntry" type="Boolean"/>
        <Parameter name="_maxWeight" type="Decimal"/>
        <Parameter name="_noMTs" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="c69b5a20-e6ff-4c9f-b319-bb46d3ebba8c">
        <source>validateForCreate();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 June 2009	cnwndl1	Initial creation

*/

vars

begin
	if app.myRoot.allTrackClearances[code] &lt;&gt; null then
		app.raiseCMException1(VB_DUPLICATED_ITEM, self.code, null, null);
	endif;

	self.validateMe;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="validateForDelete" id="110198b9-76a5-43e7-86ee-119e5493d3f1">
        <source>validateForDelete();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 June 2009	cnwndl1	Initial creation

*/

vars

begin

	if not self.allTrainsByTerminal.isEmpty then
		app.raiseCMException( Unabl_delet_this_gauge_clear_t, null, null );
	endif;
	
epilog

end;</source>
    </JadeMethod>
