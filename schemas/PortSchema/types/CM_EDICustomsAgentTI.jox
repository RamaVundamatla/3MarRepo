    <JadeMethod name="loadDB" id="c082ebe1-05b5-46ae-bb50-3936ec8fc074">
        <source>loadDB(_validateOnly: Boolean; _passport: CM_Passport input);
/*

Date		Who		Reason
28 November 2014	cnwer1	Initial creation PAR 35304

*/

vars

real,
	proxy 	: CM_CustomsAgent;
begin
	self.verifySelf();
	
	if _validateOnly then
		return;
	endif;

	if self.action = self.EDI_ACTION_ADD then
		proxy:=self.createProxy();
		app.myUtilityCA.utlCreateCustomsAgent(proxy, real, _passport);
	elseif self.action = self.EDI_ACTION_UPDATE then
		proxy:=self.createProxy();
		app.myUtilityUA.utlUpdateCustomsAgent(proxy,_passport);
	elseif self.action = self.EDI_ACTION_DELETE then
		real:=self.getCustomsAgent();
		app.myUtilityDA.utlDeleteCustomsAgent(real,_passport);
	endif;
	
epilog
	delete proxy;


end;</source>
        <Parameter name="_validateOnly" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="5292594a-88ed-49c4-b544-50f557bafe9e">
        <updating/>
        <source>setForUpdate(_proxyEDITI: SelfType) updating;
/*
Date		Who		Reason
11 June 2015	cnwer1	Initial creation PAR 36435
// 22 Feb 2016	cnwrs1	TFS 3401 fixup EDI Operations update of EDI TIs
*/

vars

begin
	inheritMethod(_proxyEDITI);
	self.action := _proxyEDITI.action;
	self.code := _proxyEDITI.code;
	self.debtorName := _proxyEDITI.debtorName;
	self.name := _proxyEDITI.name;
	self.notAvailable := _proxyEDITI.notAvailable;
epilog

end;</source>
        <Parameter name="_proxyEDITI" type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="verifySelf" id="68a7b3c2-081d-4bd7-a447-2f3477477ef8">
        <source>verifySelf();
/*

Date		Who		Reason
28 November 2014	cnwer1	Initial creation PAR 35304

*/

vars
	customsAgent : CM_CustomsAgent;
begin
	if self.action &lt;&gt; CM_EDITrackedItem.EDI_ACTION_ADD 
			and self.action &lt;&gt; CM_EDITrackedItem.EDI_ACTION_DELETE
			and self.action &lt;&gt; CM_EDITrackedItem.EDI_ACTION_UPDATE then
			app.raiseCMException1(EDI_Action_Is_Invalid, action, ETRow_Action, self);
			return;
	endif;
	
	if self.code = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Code', null, null);
		app.raiseCMException(Input_required_field_code, null, null); // cnwdb2	PAR 35364
	else
		customsAgent:=self.getCustomsAgent;
		if action  = CM_EDITrackedItem.EDI_ACTION_ADD then
			if customsAgent &lt;&gt; null then
				app.raiseCMException1(VB_DUPLICATED_ITEM, self.code, null, null);
			endif;
		elseif action = CM_EDITrackedItem.EDI_ACTION_UPDATE then
			if customsAgent = null then
				app.raiseCMException2(Does_not_exist_cannot_update,app.getErrorString(CM_Customs_Agent), self.code, null, null);
			endif;
		elseif action = CM_EDITrackedItem.EDI_ACTION_DELETE then
			if customsAgent = null then
				app.raiseCMException2(Object_DoesNotExist_Too_Delete,app.getErrorString(CM_Customs_Agent),self.code, null, null);
			endif;
		endif;	
	endif;
	
	if self.name = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Name', null, null);
		app.raiseCMException(Input_required_field_name, null, null); // cnwdb2	PAR 35364


	endif;
epilog

end;</source>
    </JadeMethod>
</Class>
