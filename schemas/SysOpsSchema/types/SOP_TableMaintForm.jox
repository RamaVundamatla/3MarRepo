    <JadeMethod name="doControlEvent" id="5f785e27-d07f-4a86-a606-51ee2492d174">
        <updating/>
        <source>doControlEvent(_control: Control) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date				Who		Reason
23 September 2009	cnwer1	Initial creation
11 August 2023		jlizm1	TFS 59549 Kiosk maintenance terms and conditions

*/

vars
	
begin
	if self.myCurrentTableItem.isKindOf(SOPTM_Machine) then
		if  _control = self.mulSelect1.myAddSelectedBtn or  _control = self.mulSelect1.myRemoveSelectedBtn  then
			if self.myProxyObject &lt;&gt; null then
				self.myProxyObject.CM_Machine.setMyPhysicalStartBay( self.cmbMachPhyStart.listObject.CM_RTGColumn);
				self.myProxyObject.CM_Machine.setMyPhysicalEndBay(self.cmbMachPhysEnd.listObject.CM_RTGColumn);

			endif;
			self.myCurrentTableItem.SOPTM_Machine.setupPhysicalLimitCombos(self.myProxyObject.CM_Machine);
		endif;
	
	elseif self.myCurrentTableItem.isKindOf(SOPTM_Kiosk) then
		if  _control = self.mulSelect1.myAddSelectedBtn or  _control = self.mulSelect1.myRemoveSelectedBtn  then
			self.myCurrentTableItem.SOPTM_Kiosk.populateLocaleCombo();
		endif;
	
	endif;
	inheritMethod(_control);
epilog

end;</source>
        <Parameter name="_control" type="Control"/>
    </JadeMethod>
    <JadeMethod name="doCurrentTableChange" id="a312ea8a-1e12-409a-8f66-74f38d444ec5">
        <updating/>
        <source>doCurrentTableChange(_showData : Boolean) updating;
// ---------------------------------------------------------------------------
// Created:     02 April 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 31/10/2008	consw1		SFW1030 - Rework of Yard Allocations
// 04/06/2009	concms1		par 19828 - rouge tbldata5 being displayed	
// 30/04/2013	cnwdap1		PAR #31155 CCMS SFW 1321 Imperial Measurements
// ---------------------------------------------------------------------------
vars
	row		: Integer;
	tmpCell	: JadeTableCell;
	
begin
	btnAdvanced.visible		:=	false;
	
	if self.myCurrentTableItem = null then
		return;
	endif;
	
	self.allowSearch := false;
	self.filterTableDefName	:=	null;
	
//	self.btnExportCSV.visible := false;

	// Par 11258 DVB
	self.setupPermissions();
	
	chkShowNotAvail.visible	:=	self.myCurrentTableItem.isNotAvailableForEntryUsed();
	self.myCurrentTableItem.includeNotAvailableEntries := self.chkShowNotAvail.value;	
	
	self.setNavigatorHeading(self.myCurrentTableItem.name);
	self.permissionMaint	:= self.myCurrentTableItem.permissionMaint;
	self.permissionView		:= self.myCurrentTableItem.permissionView;
	// reposition and redisplay the buttons according to the new settings
	self.zClearTblData();
	self.setupTableDetails();
	
	self.zPositionBottomControls();
	self.zSetControlsForView();

	self.useTblDataContextMenu := app.myAA.isAnAuditedClass(self.myDataClass);	
	self.initShtMultiSelect();

	self.initShtTblInput2();
	self.initShtTblInput3();	// par 19828
	self.initShtTblInput4();	//27 Apr 2012	NDL	Par 29496
	
	self.cmbWeightType.visible := false;						// PAR #31155
	self.lblWeightType.visible := false;						// PAR #31155
	
	self.myCurrentTableItem.loadDataForFirstTime(); // AKB2003NOV
	self.myCurrentTableItem.initShtViewTable1();
	self.myCurrentTableItem.initShtViewTable2();
	self.myCurrentTableItem.initShtViewTable3();	// cnwrl1 15/05/2009 PAR 19668 - CCMS 1814
	self.myCurrentTableItem.initShtDataTable1();
	self.myCurrentTableItem.initShtFld1();			//+cnwml2 PAR23715 SFW CCMS1131 //cnwrd1 removed 30.8.2010
	self.myCurrentTableItem.initShtTranslations();	// TFS 59549 jlizm1 11/08/2023
	
	self.initFilterTable();
	
	if shtTblInput1.visible then
		shtTblInput1.cnEcResizeContents;
	endif;
//	if shtMultiSelect1.visible then
//		shtMultiSelect1.cnEcResizeContents();
//	endif;

	if _showData then
		self.zTblDataSortAndShow(false);
	endif;
	
	self.fldInput.initSheetBackColors(); 
	self.doResize();
end;</source>
        <Parameter name="_showData" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doDelete" id="b85d8613-2b8e-4c82-a5f1-2c9b8a397441">
        <updating/>
        <source>doDelete(): Boolean updating;
// ---------------------------------------------------------------------------
// Created:     25 May 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	result	: Boolean;
	theReturn : Integer;
begin
/* WAS, did not handle warnings on DELETE
	self.myCurrentTableItem.doDelete(self.myCurrentObject);

	result := app.myPassport.noErrors() and (not app.myPassport.hasWarningsToAcknowledge);	
	if app.myPassport.hasErrors() then
		app.showErrorWarningDialog('Delete', app.myPassport, ErrWarnMode_Delete);
		self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
	else
		self.clearErrorWarnings();
	endif;

	return result;
	NOW */
	
	while true do
		self.myCurrentTableItem.doDelete(self.myCurrentObject);
		result := app.myPassport.noErrors() and (not app.myPassport.hasWarningsToAcknowledge);	

		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			global.beep;
			break;
		else
			theReturn := app.showErrorWarningDialog("Delete", app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			return result;
		endif;
		break;
	endwhile;
	return result;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
