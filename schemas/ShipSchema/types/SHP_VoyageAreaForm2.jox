    <JadeMethod name="clearLegendAndAttributes" id="e3a24c8b-930c-4c9d-8d23-f313f73f0b14">
        <source>clearLegendAndAttributes(_bdc: SHP_BayDrawingController input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 December 2017	jlgmp6	Initial creation	TFS7494

*/

vars
	dac: CMIF_DrawingAttrController;
begin
	if _bdc = null then
		return;
	endif;
	
	_bdc.allAttributeCodes.clear();
	
	dac := _bdc.myDrawingAttrController;
	
	if dac &lt;&gt; null then
		dac.allCommodities.clear();
		dac.allCommodityGroups.clear();
		dac.allConsignees.clear();
		dac.allLoadPorts.clear();
		dac.allDischargePorts.clear();
		dac.allISOTypes.clear();
		dac.allOperators.clear();
		dac.allYardAllocations.clear();
	endif;
epilog

end;</source>
        <Parameter name="_bdc" type="SHP_BayDrawingController" usage="input"/>
    </JadeMethod>
