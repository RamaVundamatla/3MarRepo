    <JadeMethod name="button1_1_click" id="bcf7538b-ba88-4b78-bf34-01490ccb7ae1">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>button1_1_click(btn: Button input) updating;
/*
Purpose:			
Date		Who		Reason
12 September 2012	cnwab1	Initial creation
*/

vars

begin
	self.frame1_1.clearGraphics;
	self.frame1_1.autoRedraw := true;
	self.frame1_1.drawFillStyle := Frame.DrawFillStyle_Solid;
	self.frame1_1.drawFillColor := Red;
	self.frame1_1.drawFilledRectangle(250,10,350,100,Red);
	self.frame1_1.drawFillStyle := Frame.DrawFillStyle_Transparent;
	self.frame1_1.drawFilledRectangle(300,10,400,100,Blue);

epilog

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="button1_click" id="e8e2d40d-d950-4585-9e07-2ebc529ab627">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>button1_click(btn: Button input) updating;
// ---------------------------------------------------------------------------
// Created:		15 December 2005  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	btn.enableEvent("click",true);
	doButton();
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doButton" id="0c3aa92b-7365-4620-ac17-1bd5eafe7eed">
        <source>doButton();
// ---------------------------------------------------------------------------
// Created:		15 December 2005  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	self.frame1.clearGraphics;
	self.frame1.autoRedraw := true;
	self.frame1.drawFilledRectangle(300,100,400,200,Red);
end;</source>
    </JadeMethod>
