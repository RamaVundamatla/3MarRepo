    <JadeMethod name="setForProxy" id="31c5b9cf-ad00-44e7-9543-bc80d09bf6c5">
        <updating/>
        <source>setForProxy(pAvail, pUsage, pGridRow, pGridColumn 	: Integer;
			pName 									: String;
			pWidth 									: Real;
			pPower,	pPowerDamaged 					: Boolean;
			pRemarks 								: String;
			pGridArea								: CM_GridArea; _is45Ft : Boolean; _offset45 : Integer; _is30Ft : Boolean; _offset30 : Integer; _is53Ft : Boolean; _offset53 : Integer) updating;
// ---------------------------------------------------------------------------
// Created:     27 January 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

	avail : Integer;
	
begin

	self.raiseExceptionIfNotTransient(method);
	
	avail := pAvail;
	pGridArea.getAvailUse(pGridRow, avail); 
	self.availability	:= avail;
	self.usage			:= pUsage;
	inheritMethod(pAvail, pUsage, pGridRow, pGridColumn, pName, pWidth, pPower,	pPowerDamaged, pRemarks, pGridArea, _is45Ft, _offset45, _is30Ft,_offset30,_is53Ft,_offset53);

end;</source>
        <Parameter name="pAvail" type="Integer"/>
        <Parameter name="pUsage" type="Integer"/>
        <Parameter name="pGridRow" type="Integer"/>
        <Parameter name="pGridColumn" type="Integer"/>
        <Parameter name="pName" type="String"/>
        <Parameter name="pWidth" type="Real"/>
        <Parameter name="pPower" type="Boolean"/>
        <Parameter name="pPowerDamaged" type="Boolean"/>
        <Parameter name="pRemarks" type="String"/>
        <Parameter name="pGridArea" type="CM_GridArea"/>
        <Parameter name="_is45Ft" type="Boolean"/>
        <Parameter name="_offset45" type="Integer"/>
        <Parameter name="_is30Ft" type="Boolean"/>
        <Parameter name="_offset30" type="Integer"/>
        <Parameter name="_is53Ft" type="Boolean"/>
        <Parameter name="_offset53" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="e5a1bbcc-3cc4-4154-bca2-b8b8e94666fb">
        <updating/>
        <source>setForUpdate(pProxy: CM_StackController; pGridArea: CM_GridArea) updating;
// 09/03/2011	cnwcs5	CCMS CPL 2017/PAR 27126
vars
	
begin

	inheritMethod(pProxy, pGridArea);
	
	// CCMS CPL 2017/PAR 27126
	self.createTALocationsAudits_Usage (pProxy, pGridArea);	
	
	// audit change to location availability
	self.createTALocationsAudits_Avail (pProxy, pGridArea);
	// CCMS CPL 2017/PAR 27126 - end

	self.availability 	:= pProxy.availability;
	self.usage 			:= pProxy.usage;
	
	// PAR 7220 AKB2004JAN added 
	if self.availability = PAD_AVAILABLE and self.usage = UNAVAILABLE_USE then
		self.usage := NORMAL_USE;
	endif;
end;</source>
        <Parameter name="pProxy" type="CM_StackController"/>
        <Parameter name="pGridArea" type="CM_GridArea"/>
    </JadeMethod>
