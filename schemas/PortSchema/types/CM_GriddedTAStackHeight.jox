    <JadeMethod name="setForUpdate" id="8f72dcde-d256-4793-be7e-b601ec71e2c1">
        <updating/>
        <source>setForUpdate( _proxy: CM_GriddedTAStackHeight ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 September 2020	jlgndl1	Initial creation	TFS 49984

*/

vars

begin

	inheritMethod(_proxy);
	
	self.maxStackHeight := _proxy.maxStackHeight;
	self.name := _proxy.name;
	self.neverMix := _proxy.neverMix;
	self.myTerminalAreaMaster := _proxy.myTerminalAreaMaster;

epilog

end;</source>
