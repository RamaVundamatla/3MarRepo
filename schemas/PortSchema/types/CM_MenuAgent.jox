    <JadeMethod name="create" id="f92d6137-83c3-4516-8c26-9e1d3d065138">
        <updating/>
        <source>create() updating;
// ---------------------------------------------------------------------------
// Created:     11 July 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if (not self.isTransient) then
		app.setContinueCMExceptions(false);
		app.raiseCMException1(CannotCreatePersistentMdlTrans, self.class.String, null, null);
		return;
	endif;
	
	if app = null then
		app.raiseCMException1(ERR_APP_NOT_INITIALIZED, null, null,null);
	endif;
	//developer deisgned rots hang of these:
	self.trxCreateJMTMenuRoot();
	self.trxCreateJMTMenuReportRoot();
	self.trxCreateJMTMenuToolbarRoot();
	self.trxCreateJMTMenuRootForSysEnts();
	//administrator menu structures hang off these
	self.trxCreateSystemMenuRoot();
	self.trxCreateSystemMenuReportRoot();
	self.trxCreateSystemMenuToolbarRoot();
	self.trxCreateSysMenuRootForSysEnts();
	
end;</source>
    </JadeMethod>
    <JadeMethod name="getNextMenuHdrTransientValue" id="cb296a0e-eb46-48bd-a106-0bcf2c55b8a8">
        <updating/>
        <source>getNextMenuHdrTransientValue() : Integer updating;
// ---------------------------------------------------------------------------
// Created:     10 January 2003		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin

	self.maxMenuHdrTransientValue := self.maxMenuHdrTransientValue + 1;
	return self.maxMenuHdrTransientValue;

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="loadJMTDefaultMenuChildren" id="bf6204c1-493a-4ab3-b866-e35bd0a5e8d3">
        <source>loadJMTDefaultMenuChildren(_const : Constant; _tag : String; _menuRoot : CM_MenuRoot input);
// ---------------------------------------------------------------------------
// Created:     12 July 2002 by cnwrs2
//
// Purpose:		Sets the children to the correct parent order for the menuHdrs that 
//				were created in the loadJMTDefaultMenuHdrs method.
// ---------------------------------------------------------------------------
vars
	str,
	id		: String;
	menuHdr	: CM_MenuHdrSystem;

begin

	str := _const.text;

	str := str.cnEcGetTagValueOfName(_tag);
	if str = null then
		app.writeStatement( class.name &amp; '::' &amp; method.name &amp; '  MenuHdr text is null for (' &amp; _const.name &amp; ')');
		return;
	endif;
	
	id := str.cnEcGetTagValueOfName(XMLTag_Id);
	if id = null then
		app.writeStatement( class.name &amp; '::' &amp; method.name &amp; '  id text is null for (' &amp; _const.name &amp; ')');
		return;
	endif;
	
	if id = MenuRootID then
		_menuRoot.setFromXML(_const.text);
		return;
	endif;

	menuHdr := _menuRoot.getMenuHdrSystem(id);
	if menuHdr = null then
		// This should never happen as the menuHdrs should have been created 
		// in the method loadJMTDefaultMenuHdrs
		app.writeStatement( class.name &amp; '::' &amp; method.name &amp; '  MenuHdr not found for (' &amp; id &amp; ')');
		return;
	endif;

	menuHdr.setChildrenFromXML(_const.text, _menuRoot);

end;</source>
        <Parameter name="_const" type="Constant"/>
        <Parameter name="_tag" type="String"/>
        <Parameter name="_menuRoot" type="CM_MenuRoot" usage="input"/>
    </JadeMethod>
    <JadeMethod name="loadJMTDefaultMenuDetails" id="798ac5de-22c8-486a-bf4c-5fc5852e6153">
        <source>loadJMTDefaultMenuDetails(_const : Constant; _systemOnly : Boolean; _menuRoot : CM_MenuRootForRoot) protected;
// ---------------------------------------------------------------------------
// Created:     12 July 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	str,
	id				: String;
	menuDtl			: CM_MenuDtlSystem;
	childValue		: Integer;
	tmpChildrenStr,
	permStr			: String;
	pos,
	permInt			: Integer;
	dict			: CM_MenuDtlsByConstantValueDict;
	tmpChildValues	: IntegerArray;

begin

	str := _const.text;
	if str = null then
		return;
	endif;
	
	// need to do this before getting XMLTag_MenuDtl as the
	// permType is in the &lt;Permission&gt; section of the XML
	permStr := str.cnEcGetTagValueOfName(CM_PermissionObject.XMLTag_PermType);
	if permStr = null then
		return;
	endif;
	
	permInt := permStr.Integer;
	
	if _systemOnly then
		if permInt = 0 then
			return;
		endif;
		dict := self.myJMTMenuRootForSysEntites.allMenuDtlsByPermValue;
	else
		if permInt = 1 then
			return;
		endif;
		dict := self.myJMTMenuRoot.allMenuDtlsByPermValue;
	endif;

	str := str.cnEcGetTagValueOfName(XMLTag_MenuDtl);
	if str = null then
		return;
	endif;
	
	id := str.cnEcGetTagValueOfName(XMLTag_Id);
	if id = null then
		app.writeStatement( class.name &amp; '::' &amp; method.name &amp; ' ERROR &gt;&gt; id is null for MenuDtl constant ' &amp; _const.name);
		return;
	endif;
	
	create tmpChildValues transient;

//	childValue := _const.text.cnEcGetTagValueOfName(CM_PermissionObject.XMLTag_Child).Integer;
//	tmpChildValues.add(childValue);

	tmpChildrenStr := _const.text.cnEcGetTagValueOfName(CM_PermissionObject.XMLTag_Children);
	if tmpChildrenStr &lt;&gt; null then
		pos := 1;
		while true do
			childValue := tmpChildrenStr.cnEcGetNextTagValueOfName(CM_PermissionObject.XMLTag_Child, pos).Integer;
			if pos &lt;= 0 then
				break;
			endif;
			if childValue = 0 then
				continue;
			endif;
			childValue := childValue + Mod_BaseView;
			if (not tmpChildValues.includes(childValue)) then
				tmpChildValues.add(childValue);
			endif;
		endwhile;
	endif;
	
	menuDtl := _menuRoot.allMenuItems[MenuType_DetailSystem, id].CM_MenuDtlSystem;
	if menuDtl = null then
		menuDtl := dict[_const.valueAsInteger].CM_MenuDtlSystem;
	endif;
	
	if menuDtl = null then
		// this is a create
		create menuDtl persistent;
		menuDtl.setFromXML(str, _menuRoot, _const.valueAsInteger, tmpChildValues, _systemOnly, null);
	else
		menuDtl.setFromXML(str, _menuRoot, _const.valueAsInteger, tmpChildValues, _systemOnly, null);
	endif;
	
	if _systemOnly then
		if menuDtl.isSystemDtl then
			
			self.removeFromDeleteSet(menuDtl);
		else
			
		endif;
	else
		if (not menuDtl.isSystemDtl) then
			
			self.removeFromDeleteSet(menuDtl);
		else
			
		endif;
	endif;

epilog
	delete tmpChildValues;
end;</source>
        <access>protected</access>
        <Parameter name="_const" type="Constant"/>
        <Parameter name="_systemOnly" type="Boolean"/>
        <Parameter name="_menuRoot" type="CM_MenuRootForRoot"/>
    </JadeMethod>
    <JadeMethod name="loadJMTDefaultMenuHdrs" id="a56c89e5-1f1e-49ec-8118-92a503107ae4">
        <source>loadJMTDefaultMenuHdrs(_const : Constant; _tag : String; _menuRoot : CM_MenuRoot);
// ---------------------------------------------------------------------------
// Created:     12 July 2002 by cnwrs2
//
// Purpose:     Loads the default JMT Navigator menu hdrs
// ---------------------------------------------------------------------------
vars
	str,
	id		: String;
	menuHdr	: CM_MenuHdrSystem;

begin

	str := _const.text.cnEcGetTagValueOfName(_tag);
	if str = null then
		app.writeStatement( class.name &amp; '::' &amp; method.name &amp; ' ERROR &gt;&gt; text is null for MenuHdr constant ' &amp; _const.name);
		return;
	endif;
	
	id := str.cnEcGetTagValueOfName(XMLTag_Id);
	if id = null then
		app.writeStatement( class.name &amp; '::' &amp; method.name &amp; ' ERROR &gt;&gt; id tag is null for MenuHdr constant ' &amp; _const.name);
		return;
	endif;
	
	if id = MenuRootID then
		return;
	endif;

	menuHdr := _menuRoot.getMenuHdrSystem(id);
	
	if menuHdr = null then
		// this is a create
		create menuHdr persistent;
		menuHdr.setFromXML(str, _menuRoot, _const.valueAsInteger, null, false, null);
	else
		self.removeFromDeleteSet(menuHdr);
		menuHdr.setFromXML(str, _menuRoot, _const.valueAsInteger, null, false, null);
	endif;

end;</source>
        <Parameter name="_const" type="Constant"/>
        <Parameter name="_tag" type="String"/>
        <Parameter name="_menuRoot" type="CM_MenuRoot"/>
    </JadeMethod>
    <JadeMethod name="loadJMTMenuReportDetails" id="34e37ce2-d946-42c3-b187-069a574bf740">
        <source>loadJMTMenuReportDetails(_const : Constant; _menuRoot : CM_MenuRootReportForRoot);

vars
	theMenuId,
	str					: String;
	menuDtl				: CM_QryReportSystem;
	secRole				: CM_SecurityRole;
begin
	
	str := _const.text.cnEcGetTagValueOfName(XMLTag_CM_QueryReport);
	if str = null then
		return;
	endif;
	
	theMenuId := '_rpt' &amp; _const.valueAsInteger.String;
	menuDtl := _menuRoot.allMenuItems[MenuType_DetailSystem, theMenuId].CM_QryReportSystem;

	if menuDtl &lt;&gt; null then
		self.removeFromDeleteSet(menuDtl);
	endif;
	
	if menuDtl = null then
		create menuDtl persistent;
		menuDtl.setFromXML(str, _menuRoot, _const.valueAsInteger, null, false, theMenuId);
	else
		menuDtl.setFromXML(str, _menuRoot, _const.valueAsInteger, null, false, theMenuId);
	endif;
	
	// Add report to root security role
	if (not menuDtl.allSecurityRoles.includes(app.myRoot.mySecurityRoleTerminal)) then
		menuDtl.allSecurityRoles.add(app.myRoot.mySecurityRoleTerminal);
	endif;
	
	/*
	As CM_SecurityRole is abstract this would never have done anything
	//temp to fix data
	foreach secRole in CM_SecurityRole.instances do
		if not (menuDtl.allSecurityRoles.includes(secRole)) then
			menuDtl.allSecurityRoles.add(secRole);
		endif;
	endforeach;
	*/

end;</source>
        <Parameter name="_const" type="Constant"/>
        <Parameter name="_menuRoot" type="CM_MenuRootReportForRoot"/>
    </JadeMethod>
    <JadeMethod name="loadMenuSysHdrTransients" id="8c2f4d45-2f37-4eb2-9b0a-03cf090b4c0f">
        <updating/>
        <source>loadMenuSysHdrTransients(_const : Constant; _passport : CM_Passport) updating;
// ---------------------------------------------------------------------------
// Created:     13 February 2003		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	str,
	id		: String;
	menHdr	: CM_MenuHdrTransient;

begin

	str := _const.text.cnEcGetTagValueOfName(XMLTag_MenuSysHdr);
	if str = null then
		return;
	endif;
	
	if _const.valueAsInteger &gt; self.maxMenuHdrTransientValue then
		self.maxMenuHdrTransientValue := _const.valueAsInteger;
	endif;
	
	create menHdr transient;
	menHdr.setFromConstant(str, _const);
	
	self.allMenuHdrTransients.add(menHdr);

end;</source>
        <Parameter name="_const" type="Constant"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
