<Class name="JtdMethodProfile" id="c6414abc-0c8e-464d-8b93-97d7f284f32e">
    <superclass name="JtdProfile"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
