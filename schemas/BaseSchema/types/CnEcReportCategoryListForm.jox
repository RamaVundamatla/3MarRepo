    <JadeMethod name="btnClose_click" id="b8048b61-a946-42f2-ba18-6c5406587bc9">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnClose_click(btn: Button input) updating;

begin
	app.mousePointer	:=	Busy;
	modalResult	:=	1;
	unloadForm();
epilog
	app.mousePointer	:=	Idle;
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnDelete_click" id="388ee967-e66e-404a-aa6c-0886d937da07">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnDelete_click(btn: Button input) updating;

begin
	app.mousePointer	:=	Busy;
	self.doFormUpdate(true);
epilog
	app.mousePointer	:=	Idle;
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnNew_click" id="2eee598c-7075-44ad-9ff5-ad5765241c50">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnNew_click(btn: Button input) updating;

vars
	categoryForm	: CnEcReportCategoryEditSuper;

begin
	app.mousePointer	:=	Busy;
	create categoryForm as global.cnEcGetReportModuleForm(CnEcReportCategoryEditSuper);
	categoryForm.showModal();
epilog
	app.mousePointer	:=	Idle;
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnUpdate_click" id="e9e67388-f3c1-4247-9504-85bf88916189">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnUpdate_click(btn: Button input) updating;

vars
	categoryForm	: CnEcReportCategoryEditSuper;

begin
	app.mousePointer	:=	Busy;

	if (lstCategory.listIndex &lt;&gt; CNEC_NULL_INDEX) then
		create categoryForm as global.cnEcGetReportModuleForm(CnEcReportCategoryEditSuper);
		categoryForm.setReportCategory(lstCategory.listObject.CnEcReportCategory);
		categoryForm.showModal();
	endif;		
epilog
	app.mousePointer	:=	Idle;
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doFormLoad" id="2b35cbe2-2729-4307-8ddf-73fd22170e78">
        <updating/>
        <source>doFormLoad() updating, protected;
// --------------------------------------------------------------------------------
// Created:		27 July 2000 by cnwdad1
//
// Purpose:		Standard form load method.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	inheritMethod();
	lstCategory.listCollection(app.myBaseRoot.allReportCategories, true, 0);
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doFormUpdate" id="ab1cef02-07b2-40b6-b704-0872ac016c5f">
        <updating/>
        <source>doFormUpdate(pIsDelete: Boolean): Boolean updating, protected;
// --------------------------------------------------------------------------------
// Created:		27 July 2000 by cnwdad1
//
// Purpose:		Standard form update method.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	reportCategory	: CnEcReportCategory;
	categoryName	: String;
	listbox			: ListBox;

begin
	listbox	:=	lstCategory;

	if pIsDelete and listbox.listIndex &lt;&gt; CNEC_NULL_INDEX then
		categoryName	:=	listbox.itemText[listbox.listIndex];
		reportCategory	:=	listbox.listObject.CnEcReportCategory;

		if global.cnEcConfirmDelete(categoryName) then
			self.aError	:=	self.aMyTA.trxReportCategoryDelete(reportCategory);
		endif;
	endif;
epilog
	return self.doShowError();
end;</source>
        <access>protected</access>
        <Parameter name="pIsDelete" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="enableButtons" id="d7462db7-eab0-4ccb-a887-2db5a4a3e30b">
        <updating/>
        <source>enableButtons() updating, protected;

begin
	if lstCategory.listObject = null then
		btnUpdate.enabled	:=	false;
		btnDelete.enabled	:=	false;
	else
		btnUpdate.enabled	:=	true;
		btnDelete.enabled	:=	(lstCategory.listObject.CnEcReportCategory.allReportDefinitions.isEmpty());
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="lstCategory_click" id="6638bc01-f29f-4bbc-a079-fa72efe3da11">
        <controlMethod name="ListBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>lstCategory_click(listbox: ListBox input) updating;
// --------------------------------------------------------------------------------
// Created:		08 August 2000 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.enableButtons();
end;</source>
        <Parameter name="listbox" type="ListBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="lstCategory_dblClick" id="99db7d93-b82d-4dc2-8b76-735ec4e9fe7f">
        <controlMethod name="ListBox::dblClick"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>lstCategory_dblClick(listbox: ListBox input) updating;
// --------------------------------------------------------------------------------
// Created:		08 August 2000 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	btnUpdate.click(btnUpdate);
end;</source>
        <Parameter name="listbox" type="ListBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="lstCategory_displayEntry" id="a46af18c-9da2-4880-9251-de61938150a3">
        <controlMethod name="ListBox::displayEntry"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>lstCategory_displayEntry(listbox: ListBox input; obj: Any; lstIndex: Integer):String updating;
// --------------------------------------------------------------------------------
// Created:		08 August 2000 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return obj.CnEcReportCategory.categoryName;
end;</source>
        <Parameter name="listbox" type="ListBox" usage="input"/>
        <Parameter name="obj" type="Any"/>
        <Parameter name="lstIndex" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="lstCategory_sysNotify" id="f61df85c-f970-418a-8752-381d594981f5">
        <controlMethod name="ListBox::sysNotify"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>lstCategory_sysNotify(listbox: ListBox input; eventType: Integer; theObject: Object; eventTag: Integer) updating;
// --------------------------------------------------------------------------------
// Created:		08 August 2000 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.enableButtons();
end;</source>
        <Parameter name="listbox" type="ListBox" usage="input"/>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
</GUIClass>
