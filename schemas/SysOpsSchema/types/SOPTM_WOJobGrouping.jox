    <JadeMethod name="includeObject" id="9e4cf136-fb9a-4da3-85e7-cc17cc81f8b7">
        <updating/>
        <source>includeObject(_obj: Object; _passport: CM_Passport): Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 Sep 2023 navhl20 ChangeRequest 60063: EUP | Ship Operations in DD - Terminal Config for grouping attributes
*/

vars

begin
	if self.includeNotAvailableEntries then
		return true;
	else
		return not _obj.CM_WorkOrderJobGroupMethod.isNotAvailableForEntry;
	endif;

epilog

end;</source>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="initShtMultiSelect" id="db2cf884-4683-46b7-b324-53178b525f48">
        <source>initShtMultiSelect();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 Sep 2023 navhl20 ChangeRequest 60063: EUP | Ship Operations in DD - Terminal Config for grouping attributes	

*/

vars
	theForm		: SOP_TableMaintForm;
	crit		: CM_Association;
	critArr		: ObjectArray;
	count 		: Integer;
begin
	inheritMethod();
	theForm := self.myForm;	
	
	create critArr transient;
	foreach count in 1 to 6 do
		create crit transient;
		crit.setValue(count);
		critArr.insert( count, crit);
	endforeach;
	
	theForm.mulSelect1.setVisibleButtons(false,true,true);
	self.setupMultiSelect1("Grouping Criteria ",critArr,SOP_TableMaintForm::displayEntryGroupCrit.name);	
	
	theForm.mulSelect1.multiSelect					:= ListBox.MultiSelect_Extended;
	theForm.mulSelect1.myAvailableListBox.sorted 	:= false;
	theForm.mulSelect1.mySelectedListBox.sorted 	:= false;
	
	theForm.mulSelect2.setVisibleButtons(false,true,true);
	self.setupMultiSelect2("Vessels ",app.myRoot.allVessels,SOP_TableMaintForm::displayEntryVesselWO.name);	
	
	theForm.mulSelect2.multiSelect					:= ListBox.MultiSelect_Extended;
	theForm.mulSelect2.myAvailableListBox.sorted 	:= false;
	theForm.mulSelect2.mySelectedListBox.sorted 	:= false;
epilog

end;</source>
    </JadeMethod>
