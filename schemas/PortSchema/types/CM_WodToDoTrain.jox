    <JadeMethod name="getAdvWOTransactionType" id="39cd9067-8453-4913-8ee4-faa32afcc31b">
        <source>getAdvWOTransactionType(transType : Integer): Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
04 October 2022		navcs2	ChangeRequest 56633:[56211] 54253.101 - Work order Transactions

*/

vars

begin
	if transType = TRANS_CREATED then
		return TRANS_TYPE_WO_TODO_TRN_CREATED;
	elseif transType = TRANS_UPDATED then
		return TRANS_TYPE_WO_TODO_TRN_UPDATED;
	else
		return TRANS_TYPE_WO_TODO_TRN_COMPLET;
	endif;
epilog

end;</source>
        <Parameter name="transType" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getCarrier" id="db2a736f-ab31-45cc-b352-e99402e0d288">
        <source>getCarrier(): CM_Carrier;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 Jun 2023	navma1	Defect 58904: MTN - Carrier/Sub Carrier is not populated for the Rail Jobs
*/

vars
	train : CM_Train;
begin
	train := self.allTrains.first;
	if train &lt;&gt; null then
		return train.myCarrier;
	endif;

epilog

end;</source>
        <ReturnType type="CM_Carrier"/>
    </JadeMethod>
