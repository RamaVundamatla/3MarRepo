    <JadeMethod name="getMyTrain" id="5e46c5c9-fa22-452e-ba0b-e92678a6f0b2">
        <source>getMyTrain() : CM_Train;
// ---------------------------------------------------------------------------
// Created:     11 June 2009 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
// 25 Sep 2024 		navhl20			Bug 64789: EUP | FR 53891 - Mobile App Delivery Dispatch Rail - Quantity Display
// 06 Mar 2025	 	navma1 			MTN-34179 MTN | Dead Lock (1081) on CM_WLEArray
// 29 Apr 2025		navhl20 		Bug MTN-34745: MSL- Incorrect Train Code Displayed in Outward Mode of Rail Operations
// ---------------------------------------------------------------------------

vars
	train : CM_Train;
	wagon : CM_Wagon;
	wle	  : CM_WorkListEntry;
	theTI : CM_TrackedItem;
	lc	  : CM_WagonController;
begin
	
	train := self.myJobSheet.getTrain();
	
	//Train from wagon
	if train = null then
		wagon := self.allWagons.first;
		
		if wagon = null then									// ### TFS 54010 28JUN2022 NAVAB1 if wagon is colour coded and then using auto plan this is needed.
			wagon := self.getMyWagon(); 						// ### TFS 54010 28JUN2022 NAVAB1
		endif;
		
		if wagon &lt;&gt; null then
			if self.isRelease then
				train := wagon.myTrainOutwards;
			else
				train := wagon.myTrainInwards;
			endif;
		endif;
	endif;
	
	if train &lt;&gt; null then										//30.04.2025 navhl20 #34745
		return train;
	endif;
	
	//Train from trackeditem of WLE
	wle := self.workListEntries.first();
	if wle &lt;&gt; null then
		theTI := wle.myTrackedItem;
		if theTI &lt;&gt; null and theTI.state = TI_STATE_PLACEHOLDER then
			train := theTI.myRRPTrain;
		endif;
	endif;
	
	if train &lt;&gt; null then										//30.04.2025 navhl20 #34745
		return train;
	endif;
	
	//Train from location from WLE
	foreach wle in self.workListEntries discreteLock do			//06.03.2025 navma1 #MTN-34179
	
		if not wle.isYardWle then
			continue;
		endif;
		
		lc := wle.CM_YardWLE.allLocationControllers.first;
		
		if lc &lt;&gt; null then
			wagon := lc.myWagon;
			break;
		endif;
		
	endforeach;

	if wagon &lt;&gt; null then										//25.09.2024 navhl20 #64789
		if self.isRelease then
			train := wagon.myTrainOutwards;
		else
			train := wagon.myTrainInwards;
		endif;
	endif;
	
	return train;
	
epilog

end;</source>
        <ReturnType type="CM_Train"/>
    </JadeMethod>
    <JadeMethod name="getMyWagon" id="dd29a319-41c1-4597-9ee5-8997ec0b2874">
        <source>getMyWagon() : CM_Wagon;
// ---------------------------------------------------------------------------
// Created:     24 July 2009 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
// 19 Mar 2024 		navma1			Bug 62865: MTN - Error 4s During Performance Runs (getMyWagon)
// ---------------------------------------------------------------------------

vars
	wagon  		: CM_Wagon;
	wle    	    : CM_WorkListEntry;
	ti 	   		: CM_TrackedItem;
	invalidObj  : Boolean;
	edition 	: Integer;
begin
	
	on Exception do app.handleDeletedObject(exception,ti,invalidObj);		//19.03.2024 navma1 #62865
	
	wagon := self.allWagons.first; // This will be set from 773, but if not go the long way around.
	
	if  wagon = null then
		wle := self.workListEntries.first;
		if wle &lt;&gt; null then
			ti := wle.myTrackedItem;
			if ti &lt;&gt; null then
				
				edition := ti.edition;
				
				if invalidObj then											 //19.03.2024 navma1 #62865
					return null;
				endif;
				
				wagon := ti.getMyWagon();
			endif;
		endif;
	endif;
	
	return wagon;
epilog

end;</source>
        <ReturnType type="CM_Wagon"/>
    </JadeMethod>
    <JadeMethod name="getNewStatus" id="85149e7d-4307-4df2-b280-eeb60409ed4d">
        <source>getNewStatus(): Integer;
// refactored out of updateStatus for 31890 so can also use in job print
vars
	newStatus	:	Integer;
begin

	newStatus := self.status;
	if self.workListEntries.isEmpty then
		newStatus := JOB_COMPLETE;
		return newStatus;	
	endif;
		
	if areWLEsAllStatus(WLE_COMPLETED) and workListEntries.size &gt; 0 then
		//---------------------
		//Rail release special processing
		//---------------------
		if self.containsIncompleteRailRelease() or self.containsIncompleteReceipt() then
			//-----------------------
			//At least one release/receipt of a TI is NOT on a wagon (in a RTA)
			//They cannot clear the rake until all TI's are on a wagon
			//-----------------------
			newStatus := JOB_PART_COMPLETE;
		else
			newStatus := JOB_COMPLETE;
		endif;

		return newStatus;
	endif;

	if areWLEsAllStatus(WLE_UNACTIONED) then
		newStatus := JOB_UNACTIONED;
		return newStatus;
	endif;

	//Must be partially underway...
	newStatus := JOB_PART_COMPLETE;
	return newStatus;
epilog

end;
</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getRailCarrier" id="a2a5d215-6e1a-4a96-968f-023185a55a1a">
        <source>getRailCarrier(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 May 2023	navhl20	ChangeRequest 57714:[57764] EUP - Delivery Dispatch – Gate
22 Jun 2023 navhl20 ChangeRequest 57758: EUP - Delivery Dispatch – Un Allocated Rail
29 Jan 2023 navhl20 ChangeRequest 62166: EUP | 53729 - Delivery Dispatch Screen - outstanding issues
08 Apr 2024 navhl20 ChangeRequest 63251: FR | 53729 - Delivery Dispatch screen - Further issues and Remedial work - 1
06 Mar 2025 navma1  MTN-34179 MTN | Dead Lock (1081) on CM_WLEArray
*/

vars
	wagon	  : CM_Wagon;
	wle		  : CM_WorkListEntry;
	objSet	  : CM_ObjectSet;
	inTrain,
	outTrain  : CM_Train;
	lc		  : CM_WagonController;
begin
	
	wagon := self.getMyWagon;
	
	if wagon &lt;&gt; null then
		if wagon.myCarrier &lt;&gt; null then										//22.6.2023 navhl20 #57758
			return wagon.myCarrier.code;
		endif;
		
		inTrain := wagon.myTrainInwards;
		
		if inTrain &lt;&gt; null and 	inTrain.myCarrier &lt;&gt; null then
			return inTrain.myCarrier.description;
		endif;
		
		outTrain := wagon.myTrainOutwards;
		
		if outTrain &lt;&gt; null and outTrain.myCarrier &lt;&gt; null then
			return outTrain.myCarrier.description;
		endif;
	endif;
	
	create objSet transient;
	
	foreach wle in self.workListEntries discreteLock do									//29.01.2023 navhl20 #62166
		
		if wle.isYardWle then
			lc := wle.CM_YardWLE.allLocationControllers.first;
			if lc &lt;&gt; null then
				wagon := lc.myWagon;
				if wagon&lt;&gt; null then
					objSet.tryAddIfNotNull(wagon.myCarrier);
				endif;
			endif;
			
		endif;
	endforeach;
	
	if objSet.isNotEmpty then
		return objSet.listString(Comma,CM_Carrier::description.name);
	endif;
	
	return null;
epilog
	delete objSet;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getRakeSheet" id="20ad5e82-ca56-45ad-b106-a0404b218dea">
        <source>getRakeSheet(_ioType : Integer; _railTransAreaId : String) : CM_RailJSInOutRake;
// ---------------------------------------------------------------------------
// Created:		January  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	tmpRailJobSheet : CM_RailJobSheet;
	returnRake,
	tmpIORake : CM_RailJSInOutRake;
	tmpDict : CM_RailJSInOutRakeByRakeDict;
begin

	tmpRailJobSheet := self.myTerminal.myRailJobSheet;
	
	if _ioType = Rail_JSIO_Type_Build then
		tmpDict := tmpRailJobSheet.inouts[Rail_JSIO_Type_Build].inoutRakes;
		/*foreach tmpIORake in tmpDict do
			if tmpIORake.rake = self.railTransAreaId.trimBlanks then //CM_RailJSInOutRake.BUILD_PRIORITY then
				returnRake := tmpIORake;			
				break;
			endif;
		endforeach;*/
		
	elseif _ioType = Rail_JSIO_Type_In then
		tmpDict := tmpRailJobSheet.inouts[Rail_JSIO_Type_In].inoutRakes;
	
	elseif _ioType = Rail_JSIO_Type_Out then
		tmpDict := tmpRailJobSheet.inouts[Rail_JSIO_Type_Out].inoutRakes;
	
	elseif _ioType = Rail_JSIO_Type_Transit then
		tmpDict := tmpRailJobSheet.inouts[Rail_JSIO_Type_Transit].inoutRakes;		
	endif;
	
	if tmpDict = null then
		app.setContinueCMExceptions(false);
		app.raiseUnexpectedProgramError(class.name, method.name, 'Dict not found for _ioType ' &amp; _ioType.String);
		return null;
	endif;
	
	foreach tmpIORake in tmpDict do
		if tmpIORake.rake = _railTransAreaId then
			returnRake := tmpIORake;
			break;
		endif;
	endforeach;			

	if returnRake = null then
		//no matching rake for _railTransAreaId, must have one so return the first for the terminal
		returnRake := tmpDict.first;
	endif;

	if returnRake = null then
		app.setContinueCMExceptions(false);
		app.raiseUnexpectedProgramError(class.name, method.name, 'returnRake not found for _ioType ' &amp; _ioType.String);
		return null;
	endif;	
			
	return returnRake;
	
end;</source>
        <Parameter name="_ioType" type="Integer"/>
        <Parameter name="_railTransAreaId" type="String"/>
        <ReturnType type="CM_RailJSInOutRake"/>
    </JadeMethod>
    <JadeMethod name="getReleaseTransferAreaLocation" id="960f9b0a-51fd-4a2b-9e03-c17d9ca7544c">
        <source>getReleaseTransferAreaLocation(): CM_LocationsController;
//--------------------------------------------------
// Created:	25 June 2004 By: cnwgd1
//--------------------------------------------------
vars
	transArea : CM_TerminalArea;
begin
	transArea := self.myTerminal.lookupTerminalArea(self.railTransAreaId);
	if transArea &lt;&gt; null then
		return transArea.getLocationsController();
	endif;
	return null;
end;</source>
        <ReturnType type="CM_LocationsController"/>
    </JadeMethod>
    <JadeMethod name="getRowColour" id="35b93473-52d5-4ac4-8fc7-f257eddc7f49">
        <source>getRowColour(_foreColour : Integer output; _backColour : Integer output);
//--------------------------------------------------------------
//Created: TFS 42872 JLGAB1 this method is used to colour containers in the rail graphic. 
//					Completed moves where drawing the container white instead of grey
//--------------------------------------------------------------
vars
	isRelease : Boolean;
begin
	_backColour := White;
	_foreColour := Black;
	
	isRelease := self.isRelease;
	if self.status = JOB_UNACTIONED then
		if isRelease then
			_foreColour := CM_Job.Colour_ReleaseUnactioned;
		else
			_foreColour := CM_Job.Colour_ReceiptUnactioned;		
		endif;
	elseif self.status = JOB_PART_COMPLETE then
		if isRelease then
			_foreColour := CM_Job.Colour_ReleasePartComplete;
		else
			_foreColour := CM_Job.Colour_ReceiptPartComplete;		
		endif;
	elseif self.status = JOB_COMPLETE then
		if isRelease then
			_foreColour := CM_Job.Colour_ReleaseComplete; // TFS 42872 JLGAB1 changed to forecolor
		else
			_foreColour := CM_Job.Colour_ReceiptComplete;	 // TFS 42872 JLGAB1 changed to forecolor	
		endif;
		_backColour := White; // TFS 42872 JLGAB1 changed to backcolor			
	else
		_foreColour := White;			
		_backColour := Mauve;				
	endif;
			
					
end;</source>
        <Parameter name="_foreColour" type="Integer" usage="output"/>
        <Parameter name="_backColour" type="Integer" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getTotalQuantity" id="2103ed81-50cc-4741-ac21-70940738b195">
        <source>getTotalQuantity(): Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 Aug 2024 navma1	Bug 64789: EUP | FR 53891 - Mobile App Delivery Dispatch Rail - Quantity Display

*/

vars
	request : CM_Request;
	reserve : CM_ReserveDetail;
begin
	
	request := self.allRequests.first;
	
	if request &lt;&gt; null and request.isAnyAmount then
		if request.isDeliveryRequest then
			reserve := request.CM_DeliveryRequest.myReserveDetail;
			
			if reserve &lt;&gt; null and reserve.isRailType() then
				return reserve.totalRequested;
			endif;
		endif;
	else
		return inheritMethod();
	endif;

epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getTrainNumber" id="3f02054b-d690-462a-9d24-6dd401a3235d">
