    <JadeMethod name="jobId" id="57318064-3868-46b2-aa2e-c010fc8028c8">
        <methodInvocation>mapping</methodInvocation>
        <source>jobId(set: Boolean; value: String io) mapping;

/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
28 September 2022	navcs2	ChangeRequest 54344: EUP - VAS Work Orders - Jobs

*/

vars

	aStr : String;
	//maxLen : Integer;
	reqst : CM_Request;
	delReq : CM_YardDeliveryRequest;
	req	:	CM_YardMoveRequest;
begin
	value := null;
	if set then
		app.raiseSetVirtualError(class.name, method.name);
		return;
	endif;
	if self.id.trimBlanks &lt;&gt; null then
		value := self.id;
		return;
	endif;
	reqst := self.allRequests.first;
	if reqst = null then
		value := "Unknown";
		return;
	endif;
	if reqst.isKindOf(CM_YardMoveRequest) then
		req := reqst.CM_YardMoveRequest;
		value := req.mySourceLocation.getFullId &amp; "-&gt;";
		if req.myTargetLocation &lt;&gt; null then
			value := value &amp; req.myTargetLocation.getFullId &amp; " " &amp; req.totalRequested.String;
		else
			value := value &amp; 'Unknown ' &amp; req.totalRequested.String;
		endif;
		return;
	elseif reqst.isKindOf(CM_YardDeliveryRequest) then
		delReq := reqst.CM_YardDeliveryRequest;
		if delReq.sourceLocation &lt;&gt; null then
			value := delReq.sourceLocation.getFullId;
		else
			value := "Unknown";
		endif;
		if delReq.targetLocation &lt;&gt; null then
			value := value &amp; " =&gt; "&amp; delReq.targetLocation &amp; " " &amp; delReq.totalRequested.String;
		else
			value := value &amp; " =&gt; "&amp; 'Unknown '  &amp; delReq.totalRequested.String;
		endif;
		return;	
	endif;

	if workListEntries.size &gt; 0 then
		if workListEntries.first.myTrackedItem &lt;&gt; null then
				aStr :=  workListEntries.first.myTrackedItem.id.trimBlanks &amp; "- Internal" ;
		endif;
	endif;

	if aStr = null then
		aStr := "Internal " &amp; getOidString();	
	endif;

	//maxLen := CM_Job.getProperty("jobId").getLength;
	if aStr.length &gt; JOBID_LEN -1 then
		aStr := aStr[1:JOBID_LEN -1];
	endif;
	value := aStr;

epilog

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="value" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="setForCreateInternal" id="e06f848b-4af6-4e7a-8758-6c945a80b624">
        <updating/>
        <source>setForCreateInternal(_cmifJobParam : CMIF_WorkOrderJobParams;_terminal : CM_Terminal) updating;

/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
28 Sep 2022	navcs2	ChangeRequest 54344: EUP - VAS Work Orders - Jobs
17 Mar 2023	navcs2	ChangeRequest 56842:[56843]: EUP - VAS Task Priority
02 Jun 2023 navma1  ChangeRequest 58296: EUP - [Framework] Delivery Dispatch Screen - Linking Road Jobs

*/

vars
	req 			: CM_WOTiToDoRequest;
begin

	inheritMethod(_cmifJobParam, _terminal);												//02.06.2023 navma1 #58296
	
	self.myToDoTaskDesc 	:= _cmifJobParam.myToDoTaskDesc;								//02.06.2023 navma1 #58296
	
	if _cmifJobParam.myWorkOrderDtl.isKindOf(CM_WodToDo) then
		//---------------
		//Build a Request
		//---------------
		create req;	
		req.setForCreateInternal(self, _cmifJobParam);
		//---------------
		//Build the WLEs' from the request.
		//---------------
		self.createWLEs();
	endif;	
end;</source>
        <Parameter name="_cmifJobParam" type="CMIF_WorkOrderJobParams"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="f09b32c2-a8e3-4515-8f06-f656d9594fc5">
        <updating/>
        <source>setForUpdate(_proxyJob: CM_Job; _theTerminal: CM_Terminal) updating;

/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
28 September 2022	navcs2	ChangeRequest 54344: EUP - VAS Work Orders - Jobs

*/

vars

begin
	self.myToDoTaskDesc := _proxyJob.CM_WOToDoTaskJob.myToDoTaskDesc;
	inheritMethod(_proxyJob, _theTerminal);
epilog

end;</source>
