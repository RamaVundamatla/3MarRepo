<Class name="CM_CO2ReadingTransaction" id="7d722e9e-9411-41b5-b177-b8fa92bd6907">
    <superclass name="CM_TITransaction"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="transact"/>
    <ImplicitInverseRef name="myCO2Reading" id="fa5b40d3-bb63-4ee6-a280-e0c6d9ac170c">
        <embedded/>
        <type name="CM_CO2Reading"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <JadeMethod name="cloneForTrackedItemRefs" id="9128c8fc-178b-4229-87a1-9dc34f042d1b">
        <updating/>
        <source>cloneForTrackedItemRefs(_ti: CM_TrackedItem; _orginalTransaction: CM_CO2ReadingTransaction) updating, protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 17/12/2025	navdap1		Initial creation MTN-36569 CPL | Reefer Runner Integration
//
vars

begin
	inheritMethod(_ti, _orginalTransaction);
	
	self.myCO2Reading := _orginalTransaction.myCO2Reading.cloneSelf(self.isTransient);
	self.myCO2Reading.cloneForTrackedItemRefs(_ti);

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_orginalTransaction" type="CM_CO2ReadingTransaction"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="5cd91764-c3ea-4915-abdc-59d2b14f26c6">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 20 January 2026	navdap1		Initial creation TFS 
//
vars
	co2 : CM_CO2Reading;
	detail : String;

begin
	if _attrName = ETRow_Details or _attrName = ETRow_CO2 then
		if self.deleted then
			return self.getDeletedDetails();
		else
			co2 := self.myCO2Reading;
			if co2 &lt;&gt; null then
				detail := co2.co2.asStringJMT;
			endif;
			return detail;
		endif;
	endif;
	
	return inheritMethod(_attrName, _short);

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setFromCMIF_TITransactionCntrl" id="004bebcb-a1e3-4919-9131-0bb3fd1974f0">
        <updating/>
        <source>setFromCMIF_TITransactionCntrl(_tiTransCntrl: CMIF_TITransactionController; _passport: CM_Passport input) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 20/01/2026	navdap1		Initial creation MTN-36569 CPL | Reefer Runner Integration
//
vars

begin
	self.setMyCO2Reading(_tiTransCntrl.CMIF_CO2TransController.myCO2Reading);
	inheritMethod(_tiTransCntrl, _passport);

epilog

end;</source>
        <Parameter name="_tiTransCntrl" type="CMIF_TITransactionController"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setMyCO2Reading" id="abe7efc7-5c3d-402d-87bc-7a2febe0652b">
        <updating/>
        <source>setMyCO2Reading(_co2Reading : CM_CO2Reading) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 16/12/2025	navdap1		Initial creation MTN-36569 CPL | Reefer Runner Integration
//
vars

begin
	self.myCO2Reading := _co2Reading;
epilog

end;</source>
        <Parameter name="_co2Reading" type="CM_CO2Reading"/>
    </JadeMethod>
</Class>
