    <JadeMethod name="setupCargoList" id="f33cb1e2-af5e-42d6-849e-ac2551c76f66">
        <updating/>
        <source>setupCargoList() updating;
// --------------------------------------------------------------------------------
// Created:		31 August 2010 by cnwjo3
//
// Purpose:		Set up all the entries in the tblCargoList table (from the voyageJob)
//
// Notes:		what about XML?  has not been implemented yet
vars
	tbl : CM_DataTable;
	entTableDef : EntTableDef;
	 idx : Integer;
	totalSelected : Integer;
	startSelecting : Boolean;

begin
	
	tbl := self.tblCargoList;	
	tbl.rows := 0;
	tbl.clear();
	tbl.selectMode := Table.SelectMode_WholeRows;
	
	entTableDef := app.myController.getEntTableDef(ETDef_ShipOperations);
	tbl.setTblDataEntRowsFromDef(entTableDef);
	
	totalSelected:=self.loadCargoList;
	
	if totalSelected &lt; 2 then  //they have selected nothing or just 1 WLE.  So we want to go into SELECT TO END mode
		self.wleSelectMode := self.WLE_SELECTTOEND;
	else
		self.wleSelectMode := self.WLE_SELECTINDIVIDUAL;
	endif;	
	
	//we want to do a select to end (to make it easier), so find the first selected item in the table (set above)
	//and continue to select to the bottomw/end
	if self.wleSelectMode = self.WLE_SELECTTOEND then
		foreach idx in 1 to tbl.rows do
			if tbl.accessRow(idx).selected = true or startSelecting then
				startSelecting := true;
				tbl.accessRow(idx).selected := true;
			endif;
		endforeach;
	endif;		
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupCraneCombo" id="9329b680-9772-4bb2-b916-e402b94b34b8">
        <source>setupCraneCombo();
// --------------------------------------------------------------------------------
// Created:		31 August 2010 by cnwjo3
//
// Purpose:		Setup the combo box with all the Cranes for the Voyage
//
vars
	idx : Integer;
	voyageJobSheet : CM_VoyageJobSheet;
	selectIndex : Integer;
	workPointObj : CM_Object;
	isForWP  : Boolean; // isForCrane
	wpCrane		: CM_Crane;
begin

// TFS 3558	isForCrane:=not self.myVoyageJob.isKindOf(CM_VoyageDeckJob);
	isForWP:= self.myVoyageJob.isKindOf(CM_VoyageDeckJob) or self.myVoyageJob.isKindOf(CM_VoyageHoldJob); // TFS 3558

	if self.myVoyage &lt;&gt; null then
		//get all the cranes from the voyage jobs
		foreach voyageJobSheet in self.myVoyage.allJobSheets discreteLock do
			workPointObj := voyageJobSheet.getMyWorkPointObject;
			if workPointObj = null then
				continue;
			endif;
			
			wpCrane:=workPointObj.IF_VoyageWorkPoint.getCrane;
//	TFS 3558		if isForCrane and wpCrane = null then
			if not isForWP and wpCrane = null then // TFS 3558
				continue;
//	TFS 3558		elseif not isForCrane and wpCrane &lt;&gt; null then
			elseif  isForWP and wpCrane &lt;&gt; null then // TFS 3558
				continue;				
			endif;

			idx := self.cmbCrane.addItemObject(workPointObj.IF_VoyageWorkPoint.getID,workPointObj);
			//the current crane we are adding to the listbox is the selected crane so
			//set index so combo is automatically selected
			if workPointObj = self.myWorkPoint then
				selectIndex := idx;
			endif;
		
		endforeach;
	endif;

	if self.cmbCrane.listCount &gt; 0 and selectIndex = 0 then
		selectIndex :=1;
	endif;
	
	if selectIndex &gt; 0 then
		self.cmbCrane.listIndex := selectIndex;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="2c5a60c6-bf3e-4e92-9120-f407c29d4f8a">
        <updating/>
        <source>setupForm() updating;
// --------------------------------------------------------------------------------
// Created:		31 August 2010 by cnwjo3
//
// Purpose:		
//
// Changed On	By			Reason
// ----------	----------	-------------------------------------------------------
// 16/12/2019	jlgdap1		TFS 47144 JMT Refactor OOW Job Split Transfer
vars

begin
	inheritMethod();
	self.minimumWidth := 420;
	
	self.handleMenusForModalDisplay();

	self.openWithSavedSettings();	
	
	self.displayCraneDetails();
	//if self.allVoyageJobs.size &gt; 1 then							// TFS 47144
	if self.mode = self.Mode_Transfer then							// TFS 47144
		self.caption := app.getErrorString1(Bulk_transfer_jobs,self.allVoyageJobs.listString(", ",CM_Job::id.name));
		self.lblInstructions.visible:=false;
		self.lblInstructions2.visible:=false; // TFS 8158
		self.lblInstructions3.visible:=false; // TFS 8158
		self.lblInstructions4.visible:=false; // TFS 8158
		self.tblCargoList.visible:=false;
		self.height:=190;
		self.minimumHeight:=190;
	else
		self.caption := app.getErrorString1(SplitTransfer_JobDetails,self.myVoyageJob.id);
		self.lblInstructions3.visible := false;						// TFS 47144
		self.lblInstructions4.top := self.lblInstructions3.top;		// TFS 47144
		self.minimumHeight := 490;
		self.setupCargoList();
	endif;
	self.setupCraneCombo();
	self.setNewJobIDtxtValue(self.cmbCrane.listObject.CM_Object);
		
end;</source>
    </JadeMethod>
