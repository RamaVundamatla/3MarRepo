    <JadeMethod name="translateForm" id="a2f9d228-82e0-4b4e-b903-f3fb70ff9746">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
//	self.translateCaption(Xlat_0017683, locale);
	frmReport.translateCaption(Xlat_0007005, locale);
	lblReport.translateCaption(Xlat_0007006, locale);
end;</source>
    </JadeMethod>
    <JadeMethod name="userNotify" id="992229c1-7f02-4b05-96d7-0f4539375aca">
        <controlMethod name="Form::userNotify"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>userNotify(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
16 October 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars
	fault : CM_Fault;
	numItems : Integer;
	breakOut : Boolean;
	event : Integer;
begin
	
	event := self.myTerminal.getEventFromTerminalEvent(eventType);
	if event = Event_Fault_Add then

		if userInfo &lt;&gt; null then
			fault:=userInfo.CM_Fault;
			
			if self.includeObject(fault, app.myPassport) then
			
				self.addObjectToTable(fault, numItems, breakOut);
			endif;
		endif;
	endif;

epilog

end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
