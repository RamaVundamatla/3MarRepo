    <JadeMethod name="zInitControls" id="7176a403-ea07-4a59-b975-8c6d6417e8db">
        <updating/>
        <source>zInitControls() updating, protected;
// ---------------------------------------------------------------------------
// Created:     10 May 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	self.zSetControlsForView();
	
	self.initDataList();

	if self.initialSptMainRatio = 0 then
		self.initialSptMainRatio := 40;
	endif;
	sptMain.setLeftToRightRatio(self.initialSptMainRatio);

	sptThumbEdit.hideRightControl(true);
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="zLstDataDisplayRow" id="9f8a94f7-b174-4bec-8a5d-54ee36a87ce9">
        <updating/>
        <source>zLstDataDisplayRow(table: Table input; theSheet: Integer; obj: Object; theRow: Integer; bcontinue: Boolean io):String updating, protected;
// ---------------------------------------------------------------------------
// Created:     10 January 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
begin

	if obj = null then
		return null;
	endif;
	
	on Exception do zLstDataDisplayRowExHandler(exception);
	
	return lstDataDisplayRow(obj);
	
end;</source>
        <access>protected</access>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="theSheet" type="Integer"/>
        <Parameter name="obj" type="Object"/>
        <Parameter name="theRow" type="Integer"/>
        <Parameter name="bcontinue" type="Boolean" usage="io"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="zLstDataDisplayRowExHandler" id="f4e6c70f-841f-485c-af5f-43395fd5dcb9">
        <updating/>
        <source>zLstDataDisplayRowExHandler(exObj : Exception) : Integer updating, protected;
// ---------------------------------------------------------------------------
// Created:     01 June 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
constants
	ObjectNotFound	: Integer = 4;
	ObjectDeleted	: Integer = 1072;
	
vars

begin

	if exObj.errorCode = ObjectNotFound or
	   exObj.errorCode = ObjectDeleted then
	   	return Ex_Abort_Action;
	endif;
	
	return Ex_Continue;

end;</source>
        <access>protected</access>
        <Parameter name="exObj" type="Exception"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="zLstDataFindObject" id="98df4481-a7dc-4f28-9907-38094b5cd3a5">
        <source>zLstDataFindObject(pObject : Object) : Integer protected;
// ---------------------------------------------------------------------------
// Created:     11 May 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	
begin

	return lstData.findObject(pObject);

end;</source>
        <access>protected</access>
        <Parameter name="pObject" type="Object"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="zLstDataSelectObject" id="9f9b4ac2-8686-481d-a029-21d309e5f881">
        <updating/>
        <source>zLstDataSelectObject(pObject : CM_Object) updating, protected;
// ---------------------------------------------------------------------------
// Created:     02 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	theObject	: Object;
	savePointer,
	idx			: Integer;
	
begin

	savePointer := app.mousePointer;
	app.mousePointer := MousePointer_HourGlass;

	lstData.clearAllSelected();
	
	if pObject &lt;&gt; null then
		idx := lstData.findObject(pObject);
		if idx &gt; 0 then
			theObject := pObject;
		endif;
	endif;
	
	if theObject = null then
		if lstData.listCount &gt; 1 then
			idx := 1;
			theObject := lstData.itemObject[idx].Object;
		endif;
	endif;
	
	if theObject &lt;&gt; null and idx &gt; 0 then
		lstData.listIndex := idx;
		if theObject &lt;&gt; self.myPlaceHolderObject then
			self.zShowThumbnailData(theObject);
		else
			self.zClearThumbnailData();
		endif;
	else
		self.zClearThumbnailData();
	endif;

epilog
	app.mousePointer := savePointer;
	
end;</source>
        <access>protected</access>
        <Parameter name="pObject" type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="zLstDataShow" id="6d1fe650-5c74-4a1c-a4a9-8a3b85830a73">
        <updating/>
        <source>zLstDataShow() updating, protected;
// ---------------------------------------------------------------------------
// Created:     01 December 2000 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	idx	: Integer;

begin

	self.resetNotifications();
	self.lstData.clear;
	self.showLstData();
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="zLstDataSysNotifyCreate" id="f2d92a1c-b8c6-448d-aea9-88f023a4ea89">
        <updating/>
        <source>zLstDataSysNotifyCreate(eventType: Integer; theObject: Object; eventTag: Integer) updating, protected;
// ---------------------------------------------------------------------------
// Created:     11 May 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	theRow	: Integer;
	tmpBool	: Boolean;

begin

//	if (not self.myDynaDict.includes(theObject)) then
//		self.myDynaDict.add(theObject);
//	endif;
	
	if self.mode = Mode_Add or
	   self.mode = Mode_Update then
	   	// Do not need to set timer as the "Save" or "Cancel" will do refresh
	   	return;
	endif;

	theRow := self.zLstDataFindObject(theObject);
	
	if theRow &gt; 0 then
		self.zBeginTimerForRefresh();
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="zLstDataSysNotifyDelete" id="fb27ca84-bd73-4a61-9871-79a82721a4c3">
        <updating/>
        <source>zLstDataSysNotifyDelete(eventType: Integer; theObject: Object; eventTag: Integer) updating, protected;
// ---------------------------------------------------------------------------
// Created:     11 May 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	theRow	: Integer;

begin

	theRow := self.zLstDataFindObject(theObject);
	
	if theRow &gt; 0 then
		if self.mode = Mode_Add then
			self.zBeginTimerForRefresh();

		elseif self.mode = Mode_Update then
			if theObject = self.myCurrentObject then
				app.msgBox(app.getErrorString1(ObjectDeletedByOtherUser, self.caption), 'Warning', MsgBox_OK_Only);
				self.myCurrentObject := null;
				self.zDoCancel();
			else
				self.zBeginTimerForRefresh();
			endif;

		elseif self.mode = Mode_View then		
			self.zBeginTimerForRefresh();
		endif;
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="zLstDataSysNotifyUpdate" id="752f5725-d253-47b9-a687-81c83c23c245">
        <updating/>
        <source>zLstDataSysNotifyUpdate(eventType: Integer; theObject: Object; eventTag: Integer) updating, protected;
// ---------------------------------------------------------------------------
// Created:     11 May 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	rtnCode,
	theRow	: Integer;
	tmpBool	: Boolean;

begin

	if self.mode = Mode_Add then
		// do nothing as the Save/Cancel will do a refresh
		self.needLstDataRefresh := true;
		return;
	endif;

	// See if the object updated is currently loaded into tblData
	theRow := self.zLstDataFindObject(theObject);
	
	if theRow &gt; 0 then
	
		if self.parentHasChanged(theObject, theRow) then
			// need to determine if the parent has changed and then
			// trigger a full redisplay
			self.zLstDataShow();
			return;
		endif;
		
		if self.mode = Mode_View or
		   self.addUpdateTransactionComplete then
			lstData.itemText[theRow] := self.lstDataDisplayRow(theObject);
			if theObject = self.myCurrentObject then
				self.showThumbnailData(theObject);
			endif;

		elseif self.mode = Mode_Update then
			if theObject = self.myCurrentObject then
			
				// user is editting the object that has just been changed.
				rtnCode := app.msgBox(app.getErrorString1(ObjectUpdatedByAnotherUserEdit, self.caption), 'Warning', MsgBox_OK_Cancel);
				if rtnCode = MsgBox_Return_OK then
					self.zDoCancel();
					self.zDoEdit();
				else
					self.zDoCancel();
				endif;

			else
				// just redisplay the row changed
				lstData.itemText[theRow] := self.lstDataDisplayRow(theObject);
			endif;
		endif;
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="zSetControlsForAddEdit" id="d547c487-42b7-47d6-ab35-29e715c24129">
        <updating/>
        <source>zSetControlsForAddEdit() updating, protected;
// ---------------------------------------------------------------------------
// Created:     28 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	btnNewTV.enabled		:= false;
	btnNewChildTV.enabled	:= false;
	btnPrintTV.enabled 		:= false;
	btnEditTV.enabled		:= false;
	btnDeleteTV.enabled		:= false;

	if self.allowAdd or self.allowAddChild or self.allowUpdate then
		btnSaveBase.enabled		:= true;
		btnCancelBase.enabled	:= true;
	endif;

	// disable other controls to force user to save/cancel add/update first.

	lstData.enabled		:= false;
	
	self.setControlsForAddEdit();

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="zSetControlsForNext" id="b87db36a-a530-452b-9356-cfcf8bf65b97">
        <updating/>
