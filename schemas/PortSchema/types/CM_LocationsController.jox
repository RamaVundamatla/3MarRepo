    </JadeMethod>
    <JadeMethod name="executePostUndoMove" id="cb5e4bb0-08b0-4143-956c-1c6741a665d7">
        <updating/>
        <source>executePostUndoMove(control : CMIF_MoveController; _passport : CM_Passport input) updating;
//--------------------------------------------------
// Created:	24 September 2003 By: cnwgd1
//--------------------------------------------------
vars

begin
	if control = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Null _moveController. Contact Developer.');
		return;
	elseif (not control.isUndoMove) then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Invalid mode - not an undo move.');	
	endif;
end;</source>
