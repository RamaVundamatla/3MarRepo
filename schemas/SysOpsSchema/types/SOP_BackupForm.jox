    <JadeMethod name="tblJournalHist_contextMenu" id="cc9e2eeb-acc2-4b1a-9795-efc17c98cc22">
        <controlMethod name="Table::contextMenu"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblJournalHist_contextMenu(table: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating;
// -------------------------------------------
// Created August 2004 by cnwrs1
// -------------------------------------------
vars
	x1: Real;
	y1: Real;
begin

	x1 := x;
	y1 := y;
	if (not mouse) then  // if keyboard, use current listIndex value
	    x1 := 20;
	    if table.row &lt; 0 then
	        y1 := 5;
	    else
	        y1 := table.positionTop();
	    endif;
	endif;

	conwin.windowToScreen(x1, y1);
	self.screenToWindow(x1, y1);   // convert x, y relative to form
	self.popupMenu(self.mnuContext, x1.Integer, y1.Integer);
	return false;                  // cancel further processing
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="timerEvent" id="f6681934-3193-4f8b-a309-4c30f1f5173f">
        <updating/>
        <source>timerEvent(eventTag: Integer) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 Mar 2010	cnwkpd1	PAR #22945 - Handle flood of notes using timers

*/

vars

begin
	if eventTag = self.Timer_Refresh then
		self.refreshTimerStarted := false;
		
		self.doRefresh();
	endif;		
		
		
epilog

end;</source>
        <Parameter name="eventTag" type="Integer"/>
