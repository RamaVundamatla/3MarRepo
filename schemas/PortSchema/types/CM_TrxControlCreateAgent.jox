    <JadeMethod name="trxCreateBOLOutAndLoadOutLogs" id="495eb425-e0b4-4dea-8904-eff71a770356">
        <updating/>
        <source>trxCreateBOLOutAndLoadOutLogs(_intBOLOut:CMIF_BOLOut input; _passport : CM_Passport input) updating;
/*

Purpose:					Combines 	app.myTrxCA.trxCreateBOLOut and 
										app.myTrxUA.trxMoveBOLOutLogWithSplit

Parameters:			

Return Value:		

Date		Who		Reason
26 June 2015	cnwndl1	Initial creation	Par 36031

*/

vars

	_bol : CM_BOLOut;
	moveController 		: CMIF_MoveController;
	tiSet	: CM_TISet;
	ext		: CM_BOLExtLogOut;
	logLoadError	: CM_LogLoadError;
	logLoadErrorSet	: CM_LogLoadErrorSet;

begin

	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);
	
	_passport.useTITransactionDeferUpdate := true;
	_passport.useTIDictDeferUpdate := true;
	
	create moveController transient;	
	create tiSet transient;
	create logLoadErrorSet transient;
	
	// Start the transaction
	beginTransaction;

	// Perform the operation
	app.myUtilityCA.utlCreateBOLOut(_intBOLOut, _passport);
	
	if _passport.hasErrors then
		return;
	endif;
	
	//Now do the move from app.myTrxUA.trxMoveBOLOutLogWithSplit without the split shite
	
	_bol := _intBOLOut.myPersistentBOL.CM_BOLOut;
	ext := _bol.myExtension.CM_BOLExtLogOut;
	
	// delete all existing log errors that are associated with an existing TI
	foreach logLoadError in ext.allLogLoadErrors do
		exclusiveLock(logLoadError);
		if logLoadError.myLog &lt;&gt; null then
			logLoadErrorSet.add(logLoadError);
		endif;
	endforeach;
	
	if (not logLoadErrorSet.isEmpty) then
		logLoadErrorSet.purge;
	endif;
	
	ext.setLogsToLoadOut(tiSet, _passport);

	//epr TFS 2432 19/9/16  make sure the _passport.doDeferredUpdates always happens even if there are no tis i.e no returns without errors
	if not tiSet.isEmpty then
		// Initialise move controller parameters.
		moveController.isSystemMove 	:= true;
		moveController.isForcedMove 	:= true;
		moveController.setMoveMode(REAL_MODE);
		moveController.setJobForMove(_bol.myYardJob);		
		moveController.setMyToPrimaryLocation(_bol.myPlannedLocation);
		if ext.loadDateTime.isValid then
			moveController.setEffectiveTimeStampOverride(ext.loadDateTime);
		endif;	
		moveController.setMyTrackedItem(tiSet.first);
		moveController.setAllOtherTrackedItems(tiSet);
		
		app.setContinueCMExceptions(false);
	
		app.myUtilityUA.utlUpdateMoveTrackedItem(moveController, _passport);
	endif;
	
	if _passport.hasErrors then
		return;
	endif;

	ext.setPartiallyLoaded();
	if (not ext.isInError) then
		ext.setIsFullyLoaded(true);
	endif;
	
	_passport.doDeferredUpdates();

epilog

	self.finaliseActivityWithPassport(_passport);
	
	delete moveController;
	delete tiSet;
	delete logLoadErrorSet;

end;</source>
        <Parameter name="_intBOLOut" type="CMIF_BOLOut" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
