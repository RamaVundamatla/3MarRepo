    <JadeMethod name="checkCombinedTrxQuantity" id="8465a81e-bc95-436e-9aa5-7e9768c0c7a7">
        <source>checkCombinedTrxQuantity(	_cargoLocalName : String;
							_movedCargoItem : CM_TrackedItem;
							_expectedRecCount : Integer;
							_expectedRelCount : Integer;
						//	_expectedStorCount : Integer;
							_expectedOtherCount : Integer
							) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 November 2014	cnwndl1	Initial creation	Par 35015

*/

vars

	intArray : IntegerArray;
	trxType : Integer;

	transSet : CM_TITransactionSet;
	trx : CM_TITransaction;
	quantity : Integer;

begin

	create intArray transient;
	intArray.add( TRANS_TYPE_REC_SHIP );				//30
	intArray.add( TRANS_TYPE_REC_ST_DEPOT_SHIP );		//124
	intArray.add( TRANS_TYPE_REC_ST_MARINE_SHIP );		//128
	intArray.add( TRANS_TYPE_REC_ST_WHOUSE_SHIP );		//132
	intArray.add( TRANS_TYPE_REL_SHIP );				//33
	intArray.add( TRANS_TYPE_REL_ST_DEPOT_SHIP );		//136
	intArray.add( TRANS_TYPE_REL_ST_MARINE_SHIP );		//140
	intArray.add( TRANS_TYPE_REL_ST_WHOUSE_SHIP );		//119
	intArray.add( TRANS_TYPE_WHARFAGE );				//26
//	intArray.add( TRANS_TYPE_STORAGE );					//40
	
	foreach trxType in intArray do
		trx := _movedCargoItem.getLastTransOfType( trxType );
		if trxType = TRANS_TYPE_REC_SHIP then
			quantity := _expectedRecCount;
			if trx = null then
				if quantity = 0 then
					//that's OK
					continue;
				else
					self.assertTrueMsg(false, "Transaction type 'Receive_Ship' quantity expected " &amp; quantity.String &amp; ", got none for " &amp; _cargoLocalName );
				endif;
			endif;
		elseif trxType = TRANS_TYPE_REC_ST_DEPOT_SHIP or trxType = TRANS_TYPE_REC_ST_MARINE_SHIP or trxType = TRANS_TYPE_REC_ST_WHOUSE_SHIP then
			quantity := _expectedRecCount;
			if trx = null then
				continue;
			endif;
		elseif trxType = TRANS_TYPE_REL_SHIP then 
			quantity := _expectedRelCount;
			if trx = null then
				if quantity = 0 then
					//that's OK
					continue;
				else
					self.assertTrueMsg(false, "Transaction type 'Release_Ship' quantity expected " &amp; quantity.String &amp; ", got none for " &amp; _cargoLocalName );
				endif;
			endif;
		elseif trxType = TRANS_TYPE_REL_ST_DEPOT_SHIP or trxType = TRANS_TYPE_REL_ST_MARINE_SHIP or trxType = TRANS_TYPE_REL_ST_WHOUSE_SHIP then
			quantity := _expectedRelCount;
			if trx = null then
				continue;
			endif;
		else
			quantity := _expectedOtherCount;
			if trx = null then
				// thats' OK
				continue;
			endif;
		endif;
		
		if trx.totalQuantity &lt;&gt; quantity then
			self.assertTrueMsg(false, "Transaction type " &amp; trxType.String &amp; " quantity expected " &amp; quantity.String &amp; ", got " &amp; trx.totalQuantity.String &amp; " for " &amp; _cargoLocalName );
		endif;

	endforeach;

epilog

	delete intArray;
	
end;</source>
        <access>protected</access>
        <Parameter name="_cargoLocalName" type="String"/>
        <Parameter name="_movedCargoItem" type="CM_TrackedItem"/>
        <Parameter name="_expectedRecCount" type="Integer"/>
        <Parameter name="_expectedRelCount" type="Integer"/>
        <Parameter name="_expectedOtherCount" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doWorkPointCargoRateTest" id="c250d2e7-0d7c-47e9-9561-fa183f9d1dd4">
        <source>doWorkPointCargoRateTest( _jobSheet : CM_JobSheet input );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 March 2018	jlgndl1	Initial creation	TFS 37437

*/

vars

	loadJob : CM_VoyageJob;
	loadTi : CM_TrackedItem;
	dischargeJob : CM_VoyageJob;
	dischargeTi : CM_TrackedItem;
	cargoType : CM_CargoType;
	product : CM_Product;
	wp : CM_WorkPoint;
	wpr : CM_WorkPointCargoRates;
	wprLoadRebar : CM_Object;
	rateInteger : Integer;
	expectedWeightRate : Integer;

begin

	//get the raw data - already existing
	loadJob := _jobSheet.allJobsByOrder.first.CM_VoyageJob;
	dischargeJob := _jobSheet.allJobsByOrder.last.CM_VoyageJob;
	dischargeTi := dischargeJob.allReceiveTrackedItems.first;
	cargoType := dischargeTi.myCargoType;
	product := dischargeTi.myProduct;
	wp := _jobSheet.CM_VoyageJobSheet.getMyWorkPoint;
	
	
	//Add default rate to WorkPoint for our cargo type.
	self.opts.purge();
	self.opts.addAssoc("cargoType", cargoType);
	self.opts.addAssoc("targetRatePHQuantity", 100.Integer);
	wpr := self.addWorkPointCargoRate( wp );
	
	// A call to get the rate for any job should get the default because there is no specific load or discharge
	rateInteger := wp.getDefinedTargetRateStr( loadJob ).Integer;
	self.assertTrueMsg( rateInteger = 100, "test 1 - Raw Target Rate value for Load job s/be 100.");
	wp.getDefinedTargetRate( loadJob, null,  loadTi ); // to get the first ti based on the job.
	//Target rate "weight/hour" is based on the first ti for the job times the rate per hour, so
	expectedWeightRate := (loadTi.totalWeight * rateInteger).Integer;
	self.assertTrueMsg( wp.getDefinedTargetRateWeight( loadJob ) = expectedWeightRate, "test 2 - Weight Rate / Hour should be " &amp; expectedWeightRate.String );
	
	rateInteger := wp.getDefinedTargetRateStr( dischargeJob ).Integer;
	self.assertTrueMsg( rateInteger = 100, "test 3 - Raw Target Rate value for Discharge job s/be 100.");
	wp.getDefinedTargetRate( dischargeJob, null, dischargeTi );
	expectedWeightRate := (dischargeTi.totalWeight * rateInteger).Integer;
	self.assertTrueMsg( wp.getDefinedTargetRateWeight( dischargeJob ) = expectedWeightRate, "test 4 - Weight Rate / Hour should be " &amp; expectedWeightRate.String );
	
	//Add specific load, discharge and sob rates. ( should have 4 rates after this )
	self.opts.purge();
	self.opts.addAssoc("cargoType", cargoType);
	self.opts.addAssoc("targetRatePHQuantity", 110.Integer);
	self.opts.addAssoc("jobType", JOB_TYPE_DISCHARGE.Integer);
	wpr := self.addWorkPointCargoRate( wp );
	
	self.opts.purge();
	self.opts.addAssoc("cargoType", cargoType);
	self.opts.addAssoc("targetRatePHQuantity", 90.Integer);
	self.opts.addAssoc("jobType", JOB_TYPE_LOAD.Integer);
	wprLoadRebar := self.addWorkPointCargoRate( wp );
	
	self.opts.purge();
	self.opts.addAssoc("cargoType", cargoType);
	self.opts.addAssoc("targetRatePHQuantity", 50.Integer);
	self.opts.addAssoc("jobType", JOB_TYPE_SOB.Integer);
	wpr := self.addWorkPointCargoRate( wp );
	
	//And a couple of a different cargo type to mix it up.
	cargoType := app.myRoot.allCargoTypesById.getAtKey(TI_CargoType_Container);
	self.opts.purge();
	self.opts.addAssoc("cargoType", cargoType);
	self.opts.addAssoc("targetRatePHQuantity", 40.Integer);
	self.opts.addAssoc("jobType", JOB_TYPE_DISCHARGE.Integer);
	wpr := self.addWorkPointCargoRate( wp );
	
	self.opts.purge();
	self.opts.addAssoc("cargoType", cargoType);
	self.opts.addAssoc("targetRatePHQuantity", 45.Integer);
	self.opts.addAssoc("jobType", JOB_TYPE_LOAD.Integer);
	wpr := self.addWorkPointCargoRate( wp );
	
	self.assertTrueMsg( wp.allWorkPointRates.size = 6, "test 5 - Work Point Cargo Rates count s/be 6.");
	
	// Now the calls for rates against jobs should find their own respective rates
	
	rateInteger := wp.getDefinedTargetRateStr( loadJob ).Integer;
	self.assertTrueMsg( rateInteger = 90, "test 6 - Raw Target Rate value for Load job s/be 90.");
	wp.getDefinedTargetRate( loadJob, null, loadTi );
	expectedWeightRate := (loadTi.totalWeight * rateInteger).Integer;
	self.assertTrueMsg( wp.getDefinedTargetRateWeight( loadJob ) = expectedWeightRate, "test 7 - Weight Rate / Hour should be " &amp; expectedWeightRate.String );
	
	rateInteger := wp.getDefinedTargetRateStr( dischargeJob ).Integer;
	self.assertTrueMsg( rateInteger = 110, "test 8 - Raw Target Rate value for Discharge job s/be 110.");
	wp.getDefinedTargetRate( dischargeJob, null, dischargeTi );
	expectedWeightRate := (dischargeTi.totalWeight * rateInteger).Integer;
	self.assertTrueMsg( wp.getDefinedTargetRateWeight( dischargeJob ) = expectedWeightRate, "test 9 - Weight Rate / Hour should be " &amp; expectedWeightRate.String );
	
	//now delete the specific load wpr and check we revert to the default one.
	
	app.myTrxDA.trxDeleteCMObject( wprLoadRebar, app.myPassport );
	self.assertTrueMsg( wp.allWorkPointRates.size = 5, "test 10 - Post delete Work Point Cargo Rates count s/be 5.");
	
	rateInteger := wp.getDefinedTargetRateStr( loadJob ).Integer;
	self.assertTrueMsg( rateInteger = 100, "test 11 - Raw Target Rate value for Load job s/be 100.");
	wp.getDefinedTargetRate( loadJob, null, loadTi );
	expectedWeightRate := (loadTi.totalWeight * rateInteger).Integer;
	self.assertTrueMsg( wp.getDefinedTargetRateWeight( loadJob ) = expectedWeightRate, "test 12 - Weight Rate / Hour should be " &amp; expectedWeightRate.String );
	

epilog

end;</source>
        <Parameter name="_jobSheet" type="CM_JobSheet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="moveBulkInSteps" id="e306bbdf-590e-420d-997e-d457ada70ba0">
        <source>moveBulkInSteps( 	_ti : CM_TrackedItem input;
					_numMoves : Integer;
					_quantityPerMove : Integer;
					_toLocation : CM_LocationsController
					):CM_TrackedItem protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 November 2014	cnwndl1	Initial creation	Par 35015

*/

vars

	cargoAfterMove : CM_TrackedItem;
	index : Integer;
	moveController	: CMIF_MoveController;

begin

	if _ti.myPrimaryPlannedLocation &lt;&gt; null then
		self.unplanTI( _ti );
	endif;

	create moveController transient;
	moveController.setMyTrackedItem(_ti);
	moveController.setMyToPrimaryLocation(_toLocation);
	moveController.setMoveMode(PLANNING_MODE);
	moveController.setQuantity( ( _quantityPerMove * _numMoves ) );

	ignoreTrxWarnings(true);
	
	while true do
		app.myTrxUA.trxMoveTrackedItem(moveController, app.myPassport);
		if app.myPassport.trxCompletedOK then
			break;
		else 
			if app.myPassport.noErrors then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		break;
	endwhile;
	
	delete moveController;
		
	foreach index in 1 to _numMoves do
	
		create moveController transient;
		moveController.setMyTrackedItem(_ti);
		moveController.setMyToPrimaryLocation(_toLocation);
		moveController.setMoveMode(REAL_MODE);
		moveController.setQuantity(_quantityPerMove);
	
		ignoreTrxWarnings(true);
		
		while true do
			app.myTrxUA.trxMoveTrackedItem(moveController, app.myPassport);
			if app.myPassport.trxCompletedOK then
				break;
			else 
				if app.myPassport.noErrors then
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
			endif;
			break;
		endwhile;
		
		delete moveController;
		
		if app.myPassport.hasErrors then
			break;
		endif;
		
	endforeach;
	
	self.assertTrueMsg(app.myPassport.noErrors, " Move [" &amp; index.String &amp; "] for '" &amp; _ti.id &amp; "' to '" &amp; _toLocation.getFullId &amp; "' failed - " &amp; app.myPassport.getErrorsAsString );

	cargoAfterMove := _toLocation.allTrackedItemsById.getAtKey( _ti.id, _ti.cargoType );
	
	self.assertTrueMsg(cargoAfterMove &lt;&gt; null, _ti.id &amp; " post move cargo not found." );

epilog

	return cargoAfterMove;
	delete moveController;

end;</source>
        <access>protected</access>
        <Parameter name="_ti" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_numMoves" type="Integer"/>
        <Parameter name="_quantityPerMove" type="Integer"/>
        <Parameter name="_toLocation" type="CM_LocationsController"/>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="tAggregateBreakBulk" id="4611256e-c576-4be5-aff1-b1800ad657fc">
        <source>tAggregateBreakBulk();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 October 2017	jlgndl1	Initial creation	TFS 5744

*/
constants

	Cargo_TypeBB : String = "UTREBAR";
	Cargo_TypeB : String = "SCRAP";
	
vars

	bbCargoType : CM_CargoType;
	bCargoType : CM_CargoType;
	bs : CM_BlockStack;
	cargo1 : CM_TrackedItem;
	cargo2 : CM_TrackedItem;
	oper : CM_Operator;
	
	allTisToAggregate : CM_TISet;
	aggregatedTi : CM_TrackedItem;
	txnController : CMIF_TITransactionController;
	newTITxn : CM_TITransaction;
	term : CM_Terminal;
	
begin

	oper := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	term := self.getTerminal;

	bbCargoType := app.myRoot.getCargoTypeFromAbbrev( Cargo_TypeBB );
	self.assertTrueMsg( bbCargoType &lt;&gt; null, "No UTREBAR cargo type pre test" );
	bCargoType := app.myRoot.getCargoTypeFromAbbrev( Cargo_TypeB );
	self.assertTrueMsg( bCargoType &lt;&gt; null, "No SCRAP Cargo Type pre test" );
	
	deleteTerminalArea( "UTBS1" );
	bs := self.addBlockStack( "UTBS1", 200, null );
	self.assertTrueMsg( bs &lt;&gt; null, "No Block stack pre test" );
	
	self.deleteAllCargo( "UTAGG1", bbCargoType );
	self.deleteAllCargo( "UTAGG2", bbCargoType );
	self.deleteAllCargo( "UTAGG3", bCargoType );
	cargo1 := self.addCargoAtLocation( "UTAGG1", bbCargoType, oper, bs.myLocationsController );
	cargo2 := self.addCargoAtLocation( "UTAGG2", bbCargoType, oper, bs.myLocationsController );
	
	self.assertNoTrxErrors();
	self.assertTrueMsg( cargo1 &lt;&gt; null, "No BB UTAGG1 pre test" );
	self.assertTrueMsg( cargo2 &lt;&gt; null, "No BB UTAGG2 pre test" );
	
	self.assertEqual( cargo1.myPrimaryActualLocation, bs.myLocationsController );
	
	beginTransaction;
	cargo1.setTotalQuantity(50);
	cargo1.setMyTotalVolume(5000);
	cargo1.setTotalWeightWithoutTrans(5000);
	cargo2.setTotalQuantity(50);
	cargo2.setMyTotalVolume(5000);
	cargo2.setTotalWeightWithoutTrans(5000);	
	commitTransaction;
	
	create allTisToAggregate transient;
	allTisToAggregate.add(cargo1);
	allTisToAggregate.add(cargo2);
	 								
	app.myTrxUA.trxAggregateBreakBulk(	null,	//_targetTi : CM_Bulk;
										0,	//_pkgWeight : Decimal;
										"UTAGG3",	//_id : String;
										bCargoType,	//_cargoType : CM_CargoType;
										null,	//_product : CM_Product;
										oper,	//_operator : CM_Operator;
										bs.myLocationsController,	//_location : CM_LocationsController;
										allTisToAggregate,	//_allItemsToBeMerged : CM_TISet;
										aggregatedTi,	//_aggregateTi : CM_TrackedItem output;
										app.myPassport	//_passport : CM_Passport input
										);
	
	self.assertTrueMsg( aggregatedTi &lt;&gt; null, "UTAGG3 not created : " &amp; app.myPassport.getErrorsAndWarningsAsString );	
		
	self.assertTrueMsg( cargo1.getLastTransOfClass(CM_Aggregated) &lt;&gt; null, "UTAGG1  'Aggregated' transaction not created" );
	self.assertTrueMsg( cargo2.getLastTransOfClass(CM_Aggregated) &lt;&gt; null, "UTAGG2  'Aggregated' transaction not created" );
	self.assertTrueMsg( aggregatedTi.getLastTransOfClass(CM_Aggregated) &lt;&gt; null, "UTAGG3  'Aggregated' transaction not created" );
	
	create txnController transient;
	txnController.type := TRANS_TYPE_AGGREGATEDCOMPLETE;
	txnController.noCharge := false; 
	txnController.myTerminal := term;
	txnController.myTrackedItem := aggregatedTi;
	
	app.myTrxCA.trxCreateTITransaction(txnController, newTITxn, app.myPassport);
	
	self.assertTrueMsg( newTITxn &lt;&gt; null, "UTAGG3 Aggregated complete transaction not created : " &amp; app.myPassport.getErrorsAndWarningsAsString );	

epilog

	delete allTisToAggregate;
	delete txnController;

end;</source>
    </JadeMethod>
    <JadeMethod name="tBreakBulkBasicMachineMove" id="1d903acc-ca58-4a31-9413-d6f4d87ad705">
        <source>tBreakBulkBasicMachineMove();
// cnwer1
//cnwrd1
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 May 2013	cnwrd1	Initial creation

*/

constants
	Cargo_Type			: String = "UTREBAR";
vars
	bs1, bs2 : CM_BlockStack;
	q1: CM_RadioTelemetryQueue;
	cargo : CM_TrackedItem;
	straddle: CM_Machine;
	tas: StringArray;
	
	cargoTypeObj : CM_CargoType;
	moveController		: CMIF_MoveController;
begin

	//create bbk cargo type with allow duplicates
	
	cargoTypeObj	:=	app.myRoot.getCargoTypeFromAbbrev(Cargo_Type);

	// create block stack 1
	// create cargo with quantity
	deleteTerminalArea("UTBS1");
	bs1:=self.addBlockStack("UTBS1",200,null);
	self.assertNotNull(bs1);
	
	
	self.deleteAllCargo("UTREBAR1",cargoTypeObj);
	cargo:=self.addCargoAtLocation("UTREBAR1",cargoTypeObj,self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString), bs1.myLocationsController);
	self.assertNotNull(cargo);
	self.assertEqual(cargo.myPrimaryActualLocation,bs1.myLocationsController);
	
	beginTransaction;
	cargo.setTotalQuantity(50);
	cargo.setMyTotalVolume(50000);
	cargo.setTotalWeightWithoutTrans(50000);
	commitTransaction;
	
	self.assertEqual(cargo.totalQuantity,50);
	self.assertEqual(cargo.totalVolume.Real,50000.Real);
	self.assertEqual(cargo.totalWeight.Decimal,50000.Decimal);

	//create block stack 2
	deleteTerminalArea("UTBS2");
	bs2:=self.addBlockStack("UTBS2",200,null);
	self.assertNotNull(bs2);
	
	q1 := self.addQueue("UT_Q", bs2, null, false);

	self.moveQueued(cargo, bs2);
	
	create tas transient;
	tas.add(bs1.id); 
	tas.add(bs2.id);
	self.opts.purge();
	self.opts.addAssoc("WeightDifference", 500);
	self.opts.addAssoc("WeightMaxLift", 20000);
	self.addStraddleTwin("UTS1", 91, tas, q1.id);
	
	straddle := self.getMachine("UTS1");
	app.isRTApp:=true;  
	self.machineLogon(straddle);
	
	// Test that cannot twin lift 20ft with 40ft
	self.expectTrxError(ERR_MACH_ASSIGN); 
	self.machineAcceptSpecifiedTwinTask(straddle, cargo.allQueuedFutureMoves.first.myWorkListEntry.allRTQueueEntries.first,null);

	self.machinePickup(straddle);

	self.machineSetdownTwinTask(straddle, straddle.allCurrentQueueTasks.first,null,bs2.id);
										
	self.machineLogOff(straddle);
	assertEqual(cargo.getPrimaryLocation(REAL_MODE), bs2.getLocationsController);
	
	self.assertEqual(cargo.totalQuantity,50);
	self.assertEqual(cargo.totalVolume.Real,50000.Real);
	self.assertEqual(cargo.totalWeight.Decimal,50000.Decimal);
	
epilog
	app.isRTApp:=false;  
	delete tas;
end;</source>
    </JadeMethod>
    <JadeMethod name="tBreakBulkDischarge" id="7112276a-9b00-4744-b411-7e3128fee039">
        <source>tBreakBulkDischarge();
// cnwer1
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 October 2013	cnwdw1	Initial creation
11 July 2022	navak20	TFS 53862 EUP - WMS - Damage Recording Extra Details
*/
// 25 Jul 2018	jlgrs1	TFS 38804 SNO Changes to repaired transactions
// 12 Jun 2025  navhn30 Bug 35040: TPT - Instructions are lost when splitting cargo
constants
	Cargo_Type			: String = "UTREBAR";
vars
	vessel: CM_Vessel;
	voyage: CM_Voyage;
	bs1: CM_BlockStack;
	cargoType : CM_CargoType;
	cargoOnship, cargoOnSite: CM_TrackedItem;
	lc: CM_LocationsController;
	height: Integer;
	tis: CM_TISet;
	expected, received, damaged: Integer;
begin

	vessel := self.addVesselWithHolds("UT_VHOLDS", 2, 2);
	voyage := self.addVoyageWithGeneralCargoStruc("UT_VHOLDS", vessel.name, vessel.myOperator.code,	self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 0);
	bs1 := self.addBlockStack("UTBS9", 9999, null);

	cargoType := app.myRoot.getCargoTypeFromAbbrev(Cargo_Type);
	
	self.getTerminal.findLocationFromString("UT_VHOLDS 0101", true, lc, height); 
	
	deleteCargo("UTREBAR9999A", cargoType);
	
	cargoOnship := self.addCargoBreakBulkAtLocation("UTREBAR9999A", cargoType, 50, lc, null, TI_IMEX_STATUS_IMPORT, voyage, vessel.myOperator);
	self.opts.addAssoc("TotalWeight", 50);
	self.opts.addAssoc("Instructions", "Code_1");	//	12.06.2025 navhn30 #35040
	self.updateTI(cargoOnship);
	assertEqual(cargoOnship.totalQuantity, 50);
	
	moveBreakBulk(cargoOnship, bs1, 20);
	moveBreakBulk(cargoOnship, bs1, 25);
	
	create tis transient;
	getTrackedItems("UTREBAR9999A", tis);
	assertEqual(tis.size, 2);
	
	cargoOnSite := tis.first;
	if cargoOnSite.myPrimaryActualLocation = lc then
		cargoOnSite := tis.last;
	endif;
	
	addDamage(cargoOnSite, "BENT", "All", null, 1, "XXX");	// 11.07.2022 navak20 TFS 53862
	addDamage(cargoOnSite, "BENT", "All", null, 2, "XXX");	// 11.07.2022 navak20 TFS 53862
	
	expected := cargoOnSite.getShipReceivalQuantity();
	assertEqual(expected, 45);
	
	received := cargoOnSite.getShipDischargeQuantity();
	assertEqual(received, 45);
	
	// 12.06.2025 navhn30 #35040 start
	assertEqual(cargoOnship.myInstructions.myInstructionType, cargoOnSite.myInstructions.myInstructionType);
	assertEqual(cargoOnship.myInstructions.internalInstructions, cargoOnSite.myInstructions.internalInstructions);
	assertEqual(cargoOnship.myInstructions.externalInstruction, cargoOnSite.myInstructions.externalInstruction);
	// 12.06.2025 navhn30 #35040 end
	
	damaged := cargoOnSite.getDamageQuantity();
	assertEqual(damaged, 3);
	
	moveBreakBulk(cargoOnship, bs1, 5);
	expected := cargoOnSite.getShipReceivalQuantity();
	assertEqual(expected, 50);
	received := cargoOnSite.getShipDischargeQuantity();
	assertEqual(received, 50);
	
epilog
	delete tis;
end;</source>
    </JadeMethod>
    <JadeMethod name="tBreakBulkDischargeAndRel" id="52bafd34-6a07-4cc2-8487-28da0237ff92">
        <source>tBreakBulkDischargeAndRel();
// cnwrs1
constants
	Cargo_Type : String = "UTREBAR";
	Vessel_Name : String = "UT_VHOLDS";
	Voyage_Name : String = "UT_VHOLDS";
	Cargo_Id : String = "UTREBAR9999A";
	Block_Stack : String = "UTBS1";
	Truck01 : String = "UTTRUCK1";
	Truck02 : String = "UTTRUCK2";
	Driver01 : String = "UTDRIVER1";
	Driver02 : String = "UTDRIVER2";
vars
	vessel : CM_Vessel;
	voyage : CM_Voyage;
	bs1 : CM_BlockStack;
	cargoType : CM_CargoType;
	cargoOnShip : CM_TrackedItem;
	cargoOnSite : CM_TrackedItem;
	lc : CM_LocationsController;
	height : Integer;
	tis : CM_TISet;
	expected : Integer;
	received : Integer;
	gate: CM_Gate;
	vvr1 : CM_VehicleVisitRecord;
	vvr2 : CM_VehicleVisitRecord;
begin
	cargoType := app.myRoot.getCargoTypeFromAbbrev(Cargo_Type);
	gate := self.getGate(self.getProfileSetting(UT_Profile.P_SGATE).asString);
	self.assertNotNull(gate);
	
	self.deleteCargo(Cargo_Id, cargoType);

	deleteTerminalArea(Block_Stack);
	bs1 := self.addBlockStack(Block_Stack, 9999, null);
	self.assertNotNull(bs1);
	
	self.deleteVoyage(Voyage_Name);
	self.assertNull(self.getVoyage(Voyage_Name));
	self.deleteVessel(Vessel_Name);
	self.assertNull(self.getVessel(Vessel_Name));
	
	vessel := self.addVesselWithHolds(Vessel_Name, 2, 2);
	voyage := self.addVoyageWithGeneralCargoStruc(Voyage_Name, vessel.name, vessel.myOperator.code,	self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 0);
	self.getTerminal.findLocationFromString(Voyage_Name&amp;" 0101", true, lc, height); 

	cargoOnShip := self.addCargoBreakBulkAtLocation(Cargo_Id, cargoType, 50, lc, null, TI_IMEX_STATUS_IMPORT, voyage, vessel.myOperator);
	self.opts.addAssoc("TotalWeight", 50);
	self.updateTI(cargoOnShip);
	self.assertEqual(cargoOnShip.totalQuantity, 50);
	
	self.moveBreakBulk(cargoOnShip, bs1, 20);
	self.moveBreakBulk(cargoOnShip, bs1, 25);
	
	create tis transient;
	self.getTrackedItems(Cargo_Id, tis);
	self.assertEqual(tis.size, 2);
	
	cargoOnSite := tis.first;
	if cargoOnSite.myPrimaryActualLocation = lc then
		cargoOnSite := tis.last;
	endif;
	
	expected := cargoOnSite.getShipReceivalQuantity();
	self.assertEqual(expected, 45);
	
	received := cargoOnSite.getShipDischargeQuantity();
	self.assertEqual(received, 45);
	
	self.deleteVehicle(Truck01);
	self.opts.purge();
	self.opts.addAssoc("TotalRequested", 15);
	vvr1 := self.gateOutGC(Truck01, "", Driver01, cargoOnSite, gate, null);
	self.assertNotNull(cargoOnSite.getPrimaryLocation(QUEUE_MODE));
	self.assertEqual(vvr1.myRoadJob.workListEntries.size, 1);
	self.assertEqual(vvr1.myRoadJob.workListEntries.first.myTrackedItem, cargoOnSite);
	self.workVehicle(vvr1);
	self.roadExit(vvr1);
	self.assertNull(vvr1.myRoadJob);
	self.assertEqual(vvr1.status, CM_VehicleVisitRecord.Status_Complete);
	self.assertNull(vvr1.vehicle.myPrimaryActualLocation);	

	self.moveBreakBulk(cargoOnShip, bs1, 5);
	expected := cargoOnSite.getShipReceivalQuantity();
	self.assertEqual(expected, 50);
	received := cargoOnSite.getShipDischargeQuantity();
	self.assertEqual(received, 50);
	
		
	self.deleteVehicle(Truck02);
	self.opts.purge();
	self.opts.addAssoc("TotalRequested", 35);
	vvr2 := self.gateOutGC(Truck02, "", Driver02, cargoOnSite, gate, null);
	self.assertNotNull(cargoOnSite.getPrimaryLocation(QUEUE_MODE));
	self.assertEqual(vvr2.myRoadJob.workListEntries.size, 1);
	self.assertEqual(vvr2.myRoadJob.workListEntries.first.myTrackedItem, cargoOnSite);
	self.workVehicle(vvr2);
	self.roadExit(vvr2);
	self.assertNull(vvr1.myRoadJob);
	self.assertEqual(vvr1.status, CM_VehicleVisitRecord.Status_Complete);
	self.assertNull(vvr1.vehicle.myPrimaryActualLocation);	
epilog
	delete tis;
end;
</source>
    </JadeMethod>
    <JadeMethod name="tBreakBulkMachineMoveMerge" id="814fb7f2-177b-4f94-a1a9-24b814ade4de">
        <source>tBreakBulkMachineMoveMerge();
// cnwer1
//cnwrd1
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 May 2013	cnwrd1	Initial creation

*/

constants
	Cargo_Type			: String = "UTREBAR";
vars
	bs1, bs2 : CM_BlockStack;
	q1: CM_RadioTelemetryQueue;
	cargo, cargo2 : CM_TrackedItem;
	straddle: CM_Machine;
	tas: StringArray;
	
	cargoTypeObj : CM_CargoType;
	moveController		: CMIF_MoveController;
begin

	//create bbk cargo type with allow duplicates
	
	cargoTypeObj	:=	app.myRoot.getCargoTypeFromAbbrev(Cargo_Type);
	
	// create block stack 1
	// create cargo with quantity
	deleteTerminalArea("UTBS1");
	bs1:=self.addBlockStack("UTBS1",200,null);
	self.assertNotNull(bs1);
	
	//create block stack 2
	deleteTerminalArea("UTBS2");
	bs2:=self.addBlockStack("UTBS2",200,null);
	self.assertNotNull(bs2);
	
	
	self.deleteAllCargo("UTREBAR1",cargoTypeObj);
	cargo:=self.addCargoAtLocation("UTREBAR1",cargoTypeObj,self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString), bs1.myLocationsController);
	self.assertNotNull(cargo);
	self.assertEqual(cargo.myPrimaryActualLocation,bs1.myLocationsController);
	
	
	//self.deleteAllCargo("UTREBAR2",cargoTypeObj);
	cargo2:=self.addCargoAtLocation("UTREBAR1",cargoTypeObj,self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString), bs2.myLocationsController);
	self.assertNotNull(cargo2);
	self.assertEqual(cargo2.myPrimaryActualLocation,bs2.myLocationsController);
	
	beginTransaction;
	cargo.setTotalQuantity(50);
	cargo.setMyTotalVolume(50000);
	cargo.setTotalWeightWithoutTrans(50000);
	cargo2.setTotalQuantity(50);
	cargo2.setMyTotalVolume(50000);
	cargo2.setTotalWeightWithoutTrans(50000);	
	commitTransaction;
	
	self.assertEqual(cargo.totalQuantity,50);
	self.assertEqual(cargo.totalVolume.Real,50000.Real);
	self.assertEqual(cargo.totalWeight.Decimal,50000.Decimal);
	
	self.assertEqual(cargo2.totalQuantity,50);
	self.assertEqual(cargo2.totalVolume.Real,50000.Real);
	self.assertEqual(cargo2.totalWeight.Decimal,50000.Decimal);

	
	q1 := self.addQueue("UT_Q", bs2, null, false);

	self.moveQueued(cargo, bs2);
	
	create tas transient;
	tas.add(bs1.id); 
	tas.add(bs2.id);
	self.opts.purge();
	self.opts.addAssoc("WeightDifference", 500);
	self.opts.addAssoc("WeightMaxLift", 20000);
	self.addStraddleTwin("UTS1", 91, tas, q1.id);
	
	straddle := self.getMachine("UTS1");
	app.isRTApp:=true;  
	self.machineLogon(straddle);
	
	// Test that cannot twin lift 20ft with 40ft
	self.expectTrxError(ERR_MACH_ASSIGN); 
	self.machineAcceptSpecifiedTwinTask(straddle, cargo.allQueuedFutureMoves.first.myWorkListEntry.allRTQueueEntries.first,null);

	self.machinePickup(straddle);

	self.machineSetdownTwinTask(straddle, straddle.allCurrentQueueTasks.first,null,bs2.id);
										
	self.machineLogOff(straddle);
	assertEqual(cargo.getPrimaryLocation(REAL_MODE),null);
	
	self.assertEqual(cargo2.totalQuantity,100);
	self.assertEqual(cargo2.totalVolume.Real,100000.Real);
	self.assertEqual(cargo2.totalWeight.Decimal,100000.Decimal);
	
	
epilog
	app.isRTApp:=false;  
	delete tas;
end;</source>
    </JadeMethod>
    <JadeMethod name="tBreakBulkMultiMoves" id="6316fe12-514c-4206-b542-49f66e3ee423">
        <source>tBreakBulkMultiMoves();
/*

Date		Who		Reason
23 February 2015	cnwer1	Initial creation PAR

*/

constants
	Cargo_Type			: String = "UTREBAR";
vars
	bs1, bs2 : CM_BlockStack;
	q1: CM_RadioTelemetryQueue;
	cargo, cargo2 : CM_TrackedItem;
	imv,
	fork1,
	fork2: CM_Machine;
	tas: StringArray;	
	cargoTypeObj : CM_CargoType;
	moveController		: CMIF_MoveController;
	masterBBEntry,
	masterQEntry : CM_RTQueueEntry;
	wle : CM_WorkListEntry;
begin

	//create bbk cargo type with allow duplicates
	
	cargoTypeObj	:=	app.myRoot.getCargoTypeFromAbbrev(Cargo_Type);
	
	// create block stack 1
	// create cargo with quantity
	deleteTerminalArea("UTBS1");
	bs1:=self.addBlockStack("UTBS1",200,null);
	self.assertNotNull(bs1);
	
	//create block stack 2
	deleteTerminalArea("UTBS2");
	bs2:=self.addBlockStack("UTBS2",200,null);
	self.assertNotNull(bs2);
	
	
	self.deleteAllCargo("UTREBAR1",cargoTypeObj);
	cargo:=self.addCargoAtLocation("UTREBAR1",cargoTypeObj,self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString), bs1.myLocationsController);
	self.assertNoTrxErrors();
	self.assertNotNull(cargo);
	self.assertEqual(cargo.myPrimaryActualLocation,bs1.myLocationsController);
	
	
	//self.deleteAllCargo("UTREBAR2",cargoTypeObj);
	cargo2:=self.addCargoAtLocation("UTREBAR1",cargoTypeObj,self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString), bs2.myLocationsController);
	self.assertNotNull(cargo2);
	self.assertEqual(cargo2.myPrimaryActualLocation,bs2.myLocationsController);
	
	beginTransaction;
	cargo.setTotalQuantity(50);
	cargo.setMyTotalVolume(50000);
	cargo.setTotalWeightWithoutTrans(50000);
	cargo2.setTotalQuantity(50);
	cargo2.setMyTotalVolume(50000);
	cargo2.setTotalWeightWithoutTrans(50000);	
	commitTransaction;
	
	self.assertEqual(cargo.totalQuantity,50);
	self.assertEqual(cargo.totalVolume.Real,50000.Real);
	self.assertEqual(cargo.totalWeight.Decimal,50000.Decimal);
	
	self.assertEqual(cargo2.totalQuantity,50);
	self.assertEqual(cargo2.totalVolume.Real,50000.Real);
	self.assertEqual(cargo2.totalWeight.Decimal,50000.Decimal);

	//Fork -&gt; IMV -&gt; Fork
	self.opts.purge;
	 self.opts.addAssoc("FullMoveQueueing",null);
	self.addMachineRule(bs1,bs2,RTMoveMethod_4);
	q1 := self.addQueue("UT_Q", bs1,bs2, false);

	self.opts.purge;
	self.opts.addAssoc("TotalQuantity",20);
	self.moveQueued(cargo, bs2);
	
	self.assertNotNull(cargo.allQueuedFutureMoves.first);
	wle:=cargo.allQueuedFutureMoves.first.myWorkListEntry;
	self.assertNotNull(wle);
	self.assertEqual(wle.quantity,20);
	
	masterQEntry:=wle.allRTQueueEntries.first;
	self.assertNotNull(masterQEntry);
	//bb fork -imv - fork
	self.assertEqual(wle.allRTQueueEntries.size,3);
	
	masterBBEntry:=wle.allRTQueueEntries.first;
	self.assertEqual(masterBBEntry.isBreakBulkGenericMaster,true);
	self.assertEqual(masterBBEntry.quantity,20);
	self.assertEqual(wle.allRTQueueEntries.last.isBreakBulkGenericMaster,true);
	self.assertEqual(wle.allRTQueueEntries.last.quantity,20);
	self.assertEqual(wle.allRTQueueEntries[2].allTasks.size, 1);
	self.assertEqual(wle.allRTQueueEntries[2].allTasks.first.isMove,true);
	
	
	
	create tas transient;
	tas.add(bs1.id); 
	tas.add(bs2.id);
	self.opts.purge();
	self.opts.addAssoc("WeightDifference", 500);
	self.opts.addAssoc("WeightMaxLift", 20000);
	
	fork1:=self.addForkLift("UFL1", 94, tas, q1.id);
	fork2:=self.addForkLift("UFL2", 95, tas, q1.id);
	imv:=self.addIMV("UIMV",96, tas,q1.id);
	self.assertNotNull(imv);
	app.isRTApp:=true;  
	self.machineLogon(fork1);
	self.machineLogon(fork2);
	
	
	
	// Test that cannot twin lift 20ft with 40ft
	//self.expectTrxError(ERR_MACH_ASSIGN); 
	self.machineAcceptSpecifiedTwinTask(fork1, masterBBEntry,null);
	self.opts.purge;
	self.opts.addAssoc("QUANTITY",5);
	self.machinePickup(fork1);
	
	self.assertEqual(wle.quantity,15);
	self.assertEqual(masterBBEntry.quantity,20);
	self.assertEqual(masterBBEntry.totalMoved,5);
	self.assertEqual(masterBBEntry.allBreakBulkMoves.size,1);
	self.assertEqual(cargo.totalQuantity,45);
	self.machineAcceptSpecifiedTwinTask(fork2, masterQEntry,null);
	self.opts.purge;
	self.opts.addAssoc("QUANTITY",10);	
	self.machinePickup(fork2);		

	
	self.assertEqual(wle.quantity,5);
	self.assertEqual(masterBBEntry.quantity,20);
	self.assertEqual(masterBBEntry.totalMoved,15);
	
	self.assertEqual(masterBBEntry.allBreakBulkMoves.size,2);
	self.assertEqual(wle.allRTQueueEntries.size,3);
	self.assertEqual(cargo.totalQuantity,35);
	
//	return;
	
	self.machineSetdownTwinTask(fork1, fork1.currentQueueTask ,null,imv.id);
	self.assertEqual(masterBBEntry.allBreakBulkMoves.size,2);
	self.assertEqual(wle.allRTQueueEntries.size,3);
	self.assertEqual(cargo.totalQuantity,35);
	self.assertEqual(imv.myMachineController.allTrackedItems.size, 1);
	self.assertEqual(imv.myMachineController.allTrackedItems.first.totalQuantity, 5);
	
	self.machineAcceptSpecifiedTwinTask(fork1, masterBBEntry,null);
	self.opts.purge;
	self.opts.addAssoc("QUANTITY",5);
	self.machinePickup(fork1);
	self.assertEqual(wle.quantity,5);
	self.assertEqual(masterBBEntry.allBreakBulkMoves.size,3);
	self.assertEqual(wle.allRTQueueEntries.size,4);
	self.assertEqual(cargo.totalQuantity,30);
	
	self.machineSetdownTwinTask(fork2, fork2.currentQueueTask ,null,imv.id);
	self.assertEqual(masterBBEntry.allBreakBulkMoves.size,3);
	
	self.assertEqual(cargo.totalQuantity,30);
	self.assertEqual(imv.myMachineController.allTrackedItems.size, 1);
	self.assertEqual(imv.myMachineController.allTrackedItems.first.totalQuantity, 15);
	
	self.machineSetdownTwinTask(fork1, fork1.currentQueueTask ,null,imv.id);
	self.assertEqual(masterBBEntry.allBreakBulkMoves.size,0);
	//self.assertEqual(wle.allRTQueueEntries.size,3);
	self.assertEqual(cargo.totalQuantity,30);
	self.assertEqual(imv.myMachineController.allTrackedItems.size, 1);
	self.assertEqual(imv.myMachineController.allTrackedItems.first.totalQuantity, 20);
	self.assertEqual(masterBBEntry.status,ENTRY_COMPLETE);
	self.assertEqual(masterBBEntry.totalMoved,20);
	self.assertEqual(wle.quantity,20);
	self.assertEqual(wle.allRTQueueEntries.size,3);
	self.assertEqual(masterBBEntry.allBreakBulkMoves.size,0);
	//the wle cargo is now the one split off and on the imv
	cargo:=imv.myMachineController.allTrackedItems.first;
	self.assertEqual(wle.myTrackedItem, cargo);
	//cargo moved to to imv 
	masterBBEntry:=wle.allRTQueueEntries.last;
	//break bulk master from imv to bs2 
	//cargo should be that on imv too
	self.assertEqual(masterBBEntry.allTasks.first.ti, cargo);
	
	//accept task
	self.machineAcceptSpecifiedTwinTask(fork1, masterBBEntry,null);
	self.opts.purge;
	self.opts.addAssoc("QUANTITY",5);
	self.machinePickup(fork1);
	self.assertEqual(wle.quantity,15);
	self.assertEqual(masterBBEntry.allBreakBulkMoves.size,1);
	self.assertEqual(wle.allRTQueueEntries.size,3);
	//cargo on imv 
	self.assertEqual(cargo.totalQuantity,15);
	
	self.machineAcceptSpecifiedTwinTask(fork2, masterBBEntry,null);
	self.opts.purge;
	self.opts.addAssoc("QUANTITY",10);
	self.machinePickup(fork2);
	self.assertEqual(wle.quantity,5);
	self.assertEqual(masterBBEntry.allBreakBulkMoves.size,2);
	self.assertEqual(wle.allRTQueueEntries.size,3);
	//cargo on imv 
	self.assertEqual(cargo.totalQuantity,5);
	
	
	self.machineSetdownTwinTask(fork1, fork1.currentQueueTask ,null,bs2.id);
	self.assertEqual(masterBBEntry.allBreakBulkMoves.size,2);
	self.assertEqual(wle.allRTQueueEntries.size,3);
	self.assertEqual(cargo.totalQuantity,5);
	self.assertEqual(cargo2.totalQuantity,55);
	
	self.machineAcceptSpecifiedTwinTask(fork1, masterBBEntry,null);
	self.opts.purge;
	self.opts.addAssoc("QUANTITY",5);
	self.machinePickup(fork1);
	self.assertEqual(wle.quantity,5);
	self.assertEqual(masterBBEntry.allBreakBulkMoves.size,3);
	self.assertEqual(wle.allRTQueueEntries.size,4);
	//cargo on imv 
	//cargo.inspect;
	self.assertEqual(cargo.totalQuantity,5);
	
	self.machineSetdownTwinTask(fork2, fork2.currentQueueTask ,null,bs2.id);
	self.assertEqual(masterBBEntry.allBreakBulkMoves.size,3);
	self.assertEqual(wle.allRTQueueEntries.size,4);
	self.assertEqual(cargo2.totalQuantity,65);
	
	self.machineSetdownTwinTask(fork1, fork1.currentQueueTask ,null,bs2.id);
	self.assertDeleted(masterBBEntry.String);
	self.assertDeleted(wle.String);
	self.assertEqual(cargo2.totalQuantity,70);
epilog
	app.isRTApp:=false;  
	delete tas;

end;</source>
    </JadeMethod>
    <JadeMethod name="tBreakBulkMultiTruckRelease" id="b5dad7d5-2efb-4d3e-9e64-06eab3735931">
        <source>tBreakBulkMultiTruckRelease();
// cnwer1
//cnwdw1
constants
	Cargo_Type			: String = "UTREBAR";
	RoadReleaseId		: String = "UTRRoad1";
	VehicleID1 			: String = 'UTTRUCK1';
	VehicleID2			: String = 'UTTRUCK2';
	DriverID1 			: String = 'UTDRIVER1';
	DriverID2 			: String = 'UTDRIVER2';
	CargoRemarks		: String = "Cargo Remarks";
vars
	bs1 			: CM_BlockStack;
	releaseRequest	: CM_BulkRelease;
	cargoTypeObj 	: CM_CargoType;
	vvr1, vvr2		: CM_VehicleVisitRecord;
	gate			: CM_Gate;
	cargo,
	cargo2 			: CM_TrackedItem;
	wle1, wle2		: CM_WorkListEntry;
begin

	cargoTypeObj	:=	app.myRoot.getCargoTypeFromAbbrev(Cargo_Type);
	
	deleteVehicle(VehicleID1);
	deleteVehicle(VehicleID2);
	
	// create block stack 1
	// create cargo with quantity
	deleteTerminalArea("UTBS1");
	bs1:=self.addBlockStack("UTBS1", 200, null);
	self.assertNotNull(bs1);
		
	self.deleteAllCargo("UTREBAR1",cargoTypeObj);
	cargo:=self.addCargoAtLocation("UTREBAR1", cargoTypeObj, self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString), bs1.myLocationsController);
	self.assertNotNull(cargo);
	self.assertEqual(cargo.myPrimaryActualLocation, bs1.myLocationsController);
	
	beginTransaction;
	cargo.setTotalQuantity(50);
	cargo.setMyTotalVolume(50000);
	cargo.setTotalWeightWithoutTrans(50000);
	cargo.setRemarks(CargoRemarks, false);	// test for 34620
	commitTransaction;
	
	self.assertEqual(cargo.totalQuantity,50);
	self.assertEqual(cargo.totalVolume.Real,50000.Real);
	self.assertEqual(cargo.totalWeight.Decimal,50000.Decimal);
	
	self.opts.purge();
	self.opts.addAssoc("TotalRequested", 10);
	releaseRequest := self.addReleaseById(RoadReleaseId, BR_TYPE_ROAD, cargo);
	self.assertNotNull(releaseRequest);
	self.assertEqual(releaseRequest.status, BR_ACTIVE);

	gate := self.getGate(self.getProfileSetting(UT_Profile.P_SGATE).asString);
	assertNotNull(gate);
	
	self.opts.purge();
	self.opts.addAssoc("TotalRequested", 10);
	vvr1 := gateOutGC(VehicleID1, "", DriverID1, cargo, gate, null);
	assertNotNull(cargo.getPrimaryLocation(QUEUE_MODE));
	assertEqual(vvr1.myRoadJob.workListEntries.size, 1);
	assertEqual(vvr1.myRoadJob.workListEntries.first.myTrackedItem, cargo);

	vvr2 := gateOutGC(VehicleID2, "", DriverID2, cargo,gate, null);
	assertNotNull(cargo.getPrimaryLocation(QUEUE_MODE));
	assertEqual(vvr2.myRoadJob.workListEntries.size, 1);
	assertEqual(vvr2.myRoadJob.workListEntries.first.myTrackedItem, cargo);

	workVehicle( vvr1 );
	
	workVehicle( vvr2 );
	
	self.roadExit(vvr1);
	self.assertEqualMsg(cargo.remarks, CargoRemarks, "cargo remarks cleared");	// test for 34620
	
	assertNull(vvr1.myRoadJob);
	assertEqual(vvr1.status, CM_VehicleVisitRecord.Status_Complete);
	//assertTrue(vvr1.allReleasedTrackedItems.includes(cargo2));
	assertNull(vvr1.vehicle.myPrimaryActualLocation);	

	self.roadExit(vvr2);
	self.assertEqualMsg(cargo.remarks, CargoRemarks, "cargo remarks cleared");	// test for 34620
	assertNull(vvr1.myRoadJob);
	assertEqual(vvr1.status, CM_VehicleVisitRecord.Status_Complete);
	//assertTrue(vvr1.allReleasedTrackedItems.includes(cargo2));
	assertNull(vvr1.vehicle.myPrimaryActualLocation);	
epilog
end;
</source>
    </JadeMethod>
    <JadeMethod name="tBreakBulkMultipleMachineMove" id="d7b9e9a8-6e89-42f8-a317-25c0e69ad4d1">
        <source>tBreakBulkMultipleMachineMove();
// cnwer1
//cnwrd1
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 May 2013	cnwrd1	Initial creation

*/

constants
	Cargo_Type			: String = "UTREBAR";
vars
	bs1, bs2 : CM_BlockStack;
	q1: CM_RadioTelemetryQueue;
	cargo, cargo2 : CM_TrackedItem;
	straddle1: CM_Machine;
	straddle2: CM_Machine;
	tas: StringArray;	
	cargoTypeObj : CM_CargoType;
	moveController		: CMIF_MoveController;
	masterQEntry : CM_RTQueueEntry;
begin

	//create bbk cargo type with allow duplicates
	
	cargoTypeObj	:=	app.myRoot.getCargoTypeFromAbbrev(Cargo_Type);
	
	// create block stack 1
	// create cargo with quantity
	deleteTerminalArea("UTBS1");
	bs1:=self.addBlockStack("UTBS1",200,null);
	self.assertNotNull(bs1);
	
	//create block stack 2
	deleteTerminalArea("UTBS2");
	bs2:=self.addBlockStack("UTBS2",200,null);
	self.assertNotNull(bs2);
	
	
	self.deleteAllCargo("UTREBAR1",cargoTypeObj);
	cargo:=self.addCargoAtLocation("UTREBAR1",cargoTypeObj,self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString), bs1.myLocationsController);
	self.assertNotNull(cargo);
	self.assertEqual(cargo.myPrimaryActualLocation,bs1.myLocationsController);
	
	
	//self.deleteAllCargo("UTREBAR2",cargoTypeObj);
	cargo2:=self.addCargoAtLocation("UTREBAR1",cargoTypeObj,self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString), bs2.myLocationsController);
	self.assertNotNull(cargo2);
	self.assertEqual(cargo2.myPrimaryActualLocation,bs2.myLocationsController);
	
	beginTransaction;
	cargo.setTotalQuantity(50);
	cargo.setMyTotalVolume(50000);
	cargo.setTotalWeightWithoutTrans(50000);
	cargo2.setTotalQuantity(50);
	cargo2.setMyTotalVolume(50000);
	cargo2.setTotalWeightWithoutTrans(50000);	
	commitTransaction;
	
	self.assertEqual(cargo.totalQuantity,50);
	self.assertEqual(cargo.totalVolume.Real,50000.Real);
	self.assertEqual(cargo.totalWeight.Decimal,50000.Decimal);
	
	self.assertEqual(cargo2.totalQuantity,50);
	self.assertEqual(cargo2.totalVolume.Real,50000.Real);
	self.assertEqual(cargo2.totalWeight.Decimal,50000.Decimal);

	
	q1 := self.addQueue("UT_Q", bs2, null, false);

	self.moveQueued(cargo, bs2);
	
	masterQEntry:=cargo.allQueuedFutureMoves.first.myWorkListEntry.allRTQueueEntries.first;
	self.assertNotNull(masterQEntry);
	
	create tas transient;
	tas.add(bs1.id); 
	tas.add(bs2.id);
	self.opts.purge();
	self.opts.addAssoc("WeightDifference", 500);
	self.opts.addAssoc("WeightMaxLift", 20000);
	self.addStraddleTwin("UTS1", 91, tas, q1.id);
	self.addForkLift("UTFL", 94, tas, q1.id);
	
	straddle1 := self.getMachine("UTS1");
	straddle2 := self.getMachine("UTFL");
	app.isRTApp:=true;  
	self.machineLogon(straddle1);
	self.machineLogon(straddle2);
	// Test that cannot twin lift 20ft with 40ft
	self.expectTrxError(ERR_MACH_ASSIGN); 
	self.machineAcceptSpecifiedTwinTask(straddle1, masterQEntry,null);
	self.opts.purge;
	self.opts.addAssoc("QUANTITY",20);
	self.machinePickup(straddle1);
	
	self.machineAcceptSpecifiedTwinTask(straddle2, masterQEntry,null);
	self.opts.purge;
	self.opts.addAssoc("QUANTITY",10);	
	self.machinePickup(straddle2);		

	self.machineSetdownTwinTask(straddle1, straddle1.currentQueueTask ,null,bs2.id);

	self.machineAcceptSpecifiedTwinTask(straddle1, masterQEntry,null);
	self.opts.purge;
	self.opts.addAssoc("QUANTITY",20);
	self.machinePickup(straddle1);
	
	

	self.machineSetdownTwinTask(straddle1, straddle1.currentQueueTask ,null,bs2.id);
	
	self.machineSetdownTwinTask(straddle2, straddle2.currentQueueTask,null,bs2.id);
										
	self.machineLogOff(straddle1);
	self.machineLogOff(straddle2);
	//assertEqual(cargo.getPrimaryLocation(REAL_MODE),null);
	
	self.assertEqual(cargo2.totalQuantity,100);
	self.assertEqual(cargo2.totalVolume.Real,100000.Real);
	self.assertEqual(cargo2.totalWeight.Decimal,100000.Decimal);
	
	self.assertEqual(cargo.totalQuantity,0);
	
epilog
	app.isRTApp:=false;  
	delete tas;
end;</source>
    </JadeMethod>
    <JadeMethod name="tBreakBulkPrenoteReceive" id="535f15c4-fcf5-442c-a445-7dc37a3f9784">
        <source>tBreakBulkPrenoteReceive();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 May 2013	cnwer1	Initial creation CCMS DPH 2274

*/

constants
	Cargo_Type			: String = "UTREBAR";
	Truck1			: String = "REBARTRUCK";
	Truck2			: String = "REBARTRUCK2";
vars
	cargoTypeObj : CM_CargoType;
	preCargo , onsiteCargo	: CM_TrackedItem;
ifArray: CMIF_TIObjectArray;
	ifPreNote: CMIF_PreNote;
	truck, truck2 : CM_Vehicle;
	bs1 	: CM_BlockStack;
begin
	create ifArray transient;
	create ifPreNote transient;	
	//create bbk cargo type with allow duplicates
	
	cargoTypeObj	:=	app.myRoot.getCargoTypeFromAbbrev(Cargo_Type);
	
	bs1:=self.addBlockStack("BREBAR",999,null);

	self.deleteAllCargo("UTREBARPRE",cargoTypeObj);
	ifPreNote.id := "UTREBARPRE";
	ifPreNote.myTerminal := self.getTerminal;
	ifPreNote.cargoType := cargoTypeObj.id;
	ifPreNote.imExStatus := getRoot.allImexStatuses[TI_IMEX_STATUS_STORAGE];
	ifPreNote.operatorCode := self.getProfileSetting(UT_Profile.P_OPERATOR).asString;
	ifPreNote.transportMode := TI_TRANSMODE_ROAD_STR;
	ifPreNote.numberOfItems :=100;
	ifArray.add(ifPreNote);
	self.ignoreTrxWarnings(true);
	//app.myPassport.setWarningsIgnored(true);
	app.myTrxCA.trxCreatePreNotes(ifArray, false, app.myPassport);
	self.assertNoTrxErrorsOrWarnings;
	
	preCargo := self.getTerminal.lookupTrackedItem(ifPreNote.id, cargoTypeObj.id, TI_STATE_NOTIFIED, null, false);

	self.assertNotNull(preCargo);
	self.assertEqual(preCargo.totalQuantity,100);
	self.assertEqual(preCargo.state,TI_STATE_NOTIFIED);
	self.assertNotNull(preCargo.myPinNo);
	
	// Gate in from 
	truck := self.getVehicle(Truck1);
	if truck &lt;&gt; null then
		self.deleteVehicle(Truck1);
	endif;
	self.gateInGC(Truck1,null,Truck1,preCargo.id,cargoTypeObj.description,self.getProfileSetting(UT_Profile.P_OPERATOR).asString,null,self.getGate(self.getProfileSetting(UT_Profile.P_DGATE).asString),50);

	truck := self.getVehicle(Truck1);
	self.assertNotNull(truck);
	//pre note cargo should still be prenoted total quanity should = 50
	self.assertEqual(preCargo.state,TI_STATE_NOTIFIED);
	self.assertEqual(preCargo.totalQuantity,50);
	
	onsiteCargo:= self.getTerminal.lookupTrackedItem(ifPreNote.id, cargoTypeObj.id, TI_STATE_NORMAL, null, false);
	self.assertNotNull(onsiteCargo);
	self.assertEqual(onsiteCargo.myPrimaryActualLocation,truck.locationsController);
	self.assertEqual(onsiteCargo.totalQuantity,50);
	self.unqueueTI(onsiteCargo);
	self.moveQueued(onsiteCargo,bs1.myLocationsController);
	self.moveQueuedCargo(onsiteCargo.jobRoadReceive.workListEntries.first);
	self.assertEqual(onsiteCargo.myPrimaryActualLocation,bs1.myLocationsController);
	
	//gate in last 50 should just move prenote cargo onsite
	// Gate in from 
	truck2 := self.getVehicle(Truck2);
	if truck2 &lt;&gt; null then
		self.deleteVehicle(Truck2);
	endif;
	self.gateInGC(Truck2,null,Truck2,preCargo.id,cargoTypeObj.description,self.getProfileSetting(UT_Profile.P_OPERATOR).asString,null,self.getGate(self.getProfileSetting(UT_Profile.P_DGATE).asString),50);
	
	truck2 := self.getVehicle(Truck2);
	self.assertNotNull(truck2);
	self.assertEqual(preCargo.state,TI_STATE_NORMAL);
	self.assertEqual(preCargo.totalQuantity,50);
	self.assertEqual(preCargo.myPrimaryActualLocation,truck2.locationsController);
	self.unqueueTI(preCargo);
	self.moveQueued(preCargo,bs1.myLocationsController);
	self.moveQueuedCargo(preCargo.jobRoadReceive.workListEntries.first);
	self.assertEqual(preCargo.myPrimaryActualLocation,null);
	self.assertEqual(onsiteCargo.totalQuantity,100);
epilog
	delete ifArray;
	delete ifPreNote;
	self.deleteAllCargo("UTREBARPRE",cargoTypeObj);
end;</source>
    </JadeMethod>
    <JadeMethod name="tBreakBulkROROGCJobsWorked" id="cb369a37-a252-44f6-a37f-d59cb67c1ad4">
        <updating/>
        <source>tBreakBulkROROGCJobsWorked() updating;
/*

Purpose:		Load cargo from a block stack to a roro deck, cargo is break bulk and is in a RORO job. Machine is a forklift. Machine rule is for Fork Lift only
				Discharge cargo from a RORO deck,  cargo is break bulk and is in a RORO job. Machine is a forklift. Machine rule is for Fork Lift only

Parameters:			

Return Value:		

Date		Who		Reason
20 May 2013	cnwer1	Initial creation CCMS DPH 2274

*/
constants
	Cargo_Type			: String = "UTREBAR";
vars
	vesselName 	, voyageName: String;
	vessel 		: CM_Vessel;	 
	voyage 		: CM_Voyage;
	voyageCellularStructure : CM_CellularVoyageStructure;
	voyageROROStructure 	: CM_ROROVoyageStructure;
	voyageDeck 				: CM_DeckVoyage;
	cargoTypeObj : CM_CargoType;
	wpC : CM_WorkPoint;
	bs1 : CM_BlockStack;
	 trade : CM_Trade;
	 gcDischargePort : CM_Port;
	  operator : CM_Operator;
	gcController :  CM_ROROGCController;
	gcCargo : CM_TrackedItem;
	job : CM_VoyageJob;
	wle : CM_WorkListEntry;
	moveController	: CMIF_MoveController;
	masterQEntry : CM_RTQueueEntry;
	straddle1: CM_Machine;
		q1: CM_RadioTelemetryQueue;
		fork : CM_Machine;
tas: StringArray;
	request : CM_Request;
	gcLayer : CM_DeckLayerLayout;
	lcSet : CM_LCSet;
	shipReceival : CM_ReceiveShip;
	kpi : CM_KPIVoyageTotals;
	kpiDisch,
	kpiLoad 	: CM_KPIVoyageMoveDtl_GC;
	totalQuantity : Integer;
	shipRecTxn : CM_TITransaction;
	locnDefnGC : CM_ROROGCDefnVoyage;
	wpaType, bsaType : CM_TerminalAreaType;
begin


	// ### DELETE and CREATE VESSEL and VOYAGE
	vesselName:="UT_ROROBB";
	voyageName:="UT_ROROBB01";
	self.deleteVessel(vesselName);
	self.deleteVoyage(voyageName);
	self.assertNull(self.getVessel(vesselName));
	
	vessel:=self.xCreateROROVesselStructure(vesselName);
	voyage:=self.addVoyageWithConRORO(voyageName, vesselName, "ANL", "ANZ", null, 0, false, true);
	operator := voyage.myOperator;
	voyageCellularStructure:=voyage.myCellularVoyageStructure;
	//check cellularStructure created
	self.assertNotNullMsg(voyageCellularStructure,"has cellular structure");
	voyageROROStructure:=voyage.myROROStructure;
	self.assertNotNullMsg(voyageROROStructure,"has roro structure");
	
	// ### GET CARGOTYPE - BREAKBULK
	cargoTypeObj	:=	app.myRoot.getCargoTypeFromAbbrev(Cargo_Type);
	
	// ### ADD WORKPOINT FOR THE RORO JOB
	wpC := self.addWorkPoint("WPC", true);
	self.addWorkPointTransferArea("WPC_IC", wpC);
	self.assertNotNull(wpC.myWorkPointInterchangeArea);
	
	// Blocks Stack for exports
	deleteTerminalArea("UTBS1");
	bs1:=self.addBlockStack("UTBS1",200,null);
	
	// ### Add Machine Rule WPTA to BS = FORK LIFT ONLY
	if wpC.myWorkPointInterchangeArea &lt;&gt; null then
		wpaType := wpC.myWorkPointInterchangeArea.myType;
	endif;
	if bs1 &lt;&gt; null then
		bsaType := bs1.myType;
	endif;
	self.addMachineRuleType(wpaType, bsaType, RTMoveMethod_24, FullMoveQueuing);
	self.addMachineRuleType(bsaType, wpaType, RTMoveMethod_24, FullMoveQueuing);
	
	// ### CREATE TRADE
	trade:= app.myRoot.allTradesByDescription["Doug World"];
	self.assertTrueMsg(trade &lt;&gt; null, "Trade 'Doug World' missing in set up");

	gcDischargePort :=  trade.allPortRotations.first.myPort;
	if gcDischargePort = self.getTerminal.getDefaultPort then
		gcDischargePort :=  trade.allPortRotations.last.myPort;
	endif;
	
	
	// #### LOAD JOB
	// ### GET THE RORO DECK AND CREATE ONE CARGO ITEM IN BLOCK STACK AND PUT IN A LOAD JOB, PLAN IT TO THE VOYAGE
	voyageDeck:=voyage.myROROStructure.allDecks.first;
	self.assertNotNull(voyageDeck);
	
	self.opts.addAssoc("TotalQuantity", 30);
	self.opts.addAssoc("RequestQuantity", 20);
	self.createGCLoadJobForRORO(voyage, wpC, voyageDeck, 20, -10, gcDischargePort.code, cargoTypeObj, operator,"REBAR", 10, 10, bs1, null);
	self.assertNoTrxErrorsOrWarnings();
	
	
	gcController:=voyageDeck.allROROGCControllers.first;
	self.assertNotNull(gcController);
	self.assertNotNull(gcController.myRORORequestLoad);
	self.assertTrue(gcController.myRORORequestLoad.quantity = 20);
	
	gcCargo:=bs1.myLocationsController.allTrackedItems.first;
	self.assertNotNull(gcCargo);
	self.assertTrue(gcCargo.isKindOf(CM_BreakBulkGeneric));
	self.assertTrue(gcCargo.totalQuantity = 30);
	
	job:= wpC.allJobSheets.first.allJobsByOrder.first.CM_VoyageJob;
	self.assertNotNull(job);
	
	self.loadVoyJobToOps(job,true,true);
	self.assertTrue(job.workListEntries.size = 1);
	
	wle:=job.workListEntries.first;
	self.assertNotNull(wle);
	
	self.assertNotNull(wle.myFutureMove);
	self.assertTrue(wle.myFutureMove.isKindOf(CM_FutureMovePlanned));
	
	// ### ADD A RT QUEUE
	q1 := self.addQueue("UT_Q", bs1, null, false);
	
	// ### QUEUE THE LOAD CARGO TO THE VOYAGE
	create moveController transient;
	moveController.setMyTrackedItem(wle.myTrackedItem);
	moveController.setMyWorkListEntry(wle);
	moveController.setMyToPrimaryLocation(wle.myFutureMove.CM_FutureMovePlanned.allLocationsControllers.first);
	moveController.setMoveMode(QUEUE_MODE);
	app.myTrxUA.trxMoveTrackedItem(moveController, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();	
	
	self.assertTrue(wle.myFutureMove.isKindOf(CM_FutureMoveQueued));
	
	// ### CREATE A FORK LIFT, GIVE IT ACCESS TO THE WORK POINT AND THE BLOCK STACK, PLACE IN OUR QUEUE
	masterQEntry:=wle.allRTQueueEntries.first;
	self.assertNotNull(masterQEntry);
	create tas transient;
	tas.add(bs1.id); 
	tas.add(wpC.myWorkPointInterchangeArea.id);
	self.opts.purge();
	self.opts.addAssoc("WeightDifference", 500);
	self.opts.addAssoc("WeightMaxLift", 20000);
	self.addForkLift("UTBB", 94, tas, q1.id);
	fork := self.getMachine("UTBB");
	app.isRTApp:=true; 
	
	// ###  LOG IN FORK LIFT
	self.machineLogon(fork);
	self.expectTrxError(ERR_MACH_ASSIGN); 
	
	// ### GIVE THE LOAD MOVE TO TEH FORK LIFT
	self.machineAcceptSpecifiedTwinTask(fork, masterQEntry,null);
	
	// ### PICKUP PART OF THE CARGO FOR LOAD
	self.opts.purge;
	self.opts.addAssoc("QUANTITY",10);
	self.machinePickup(fork);
	
	//at this point should split ti and split wles will end up with 2 wles 10 quantity for original and 10 for split ti on the machine

	self.assertEqual(job.workListEntries.size, 2);
	self.assertEqual(job.workListEntries.first.quantity,10);
	self.assertEqual(job.workListEntries.last.quantity,10);
	request:=job.allRequests.first;
	
	// ### SETDOWN CARGO FOR VOYAGE
	self.machineSetdownTwinTask(fork, fork.currentQueueTask ,null,fork.currentQueueTask.myEntry.allQueuedFutureMoves.first.allLocationsControllers.first.getID);

	// ASIGN REST OF JOB TO FORK LIFT
	self.machineAcceptSpecifiedTwinTask(fork, masterQEntry,null);
	
	// ### PICKUP REST OF CARGO FOR LOAD
	self.opts.purge;
	self.opts.addAssoc("QUANTITY",10);
	self.machinePickup(fork);
	self.machineSetdownTwinTask(fork, fork.currentQueueTask ,null,fork.currentQueueTask.myEntry.allQueuedFutureMoves.first.allLocationsControllers.first.getID);
	//still 2 wles now both complete
	self.assertEqual(job.workListEntries.size, 2);
	self.assertEqual(job.workListEntries.first.quantity,10);
	self.assertEqual(job.workListEntries.first.status,WLE_COMPLETED);
	self.assertEqual(job.workListEntries.last.quantity,10);
	self.assertEqual(job.workListEntries.last.status,WLE_COMPLETED);
	
	self.assertEqual(job.allRequests.size,1);
	
	
	self.assertEqual(request.allWorkListEntries.size,2);
	
	self.assertEqual(request.getNumTIsOfMode(PLANNING_MODE, true),0);
	self.assertEqual(request.getNumTIsOfMode(REAL_MODE, true),20);
	self.assertEqual(voyageDeck.allShipReleases.size,2);
	
	self.assertEqual(job.allShipReleases.size , 2);
	self.assertEqual(job.allShipReleases.first.CM_ReleaseShip.totalQuantity, 10);
	self.assertEqual(job.allShipReleases.last.CM_ReleaseShip.totalQuantity , 10);
	
	
	// ### CREATE CARGO ON DECK FOR DISCHARGE ADD TO A JOB
	app.isRTApp:=false;  
	//voyageDeck.myVoyageStructure.createQuickCargoGC(null, cargoTypeObj, 50, 0, voyageDeck, 1);
	self.createQuickCargoGC(voyageDeck.myVoyageStructure, locnDefnGC, cargoTypeObj, 50, 0, voyageDeck, 1);					// 10/09/2015 cnwmh5
	gcLayer :=voyageDeck.getGCLayer;
	self.assertNotNull(gcLayer);
	create lcSet transient;
	self.assertNotNull(gcLayer.allROROGCDefnByCode.last.CM_ROROGCDefnVoyage.myGCController);
	gcCargo:=gcLayer.allROROGCDefnByCode.last.CM_ROROGCDefnVoyage.myGCController.allTrackedItems.first;
	beginTransaction;
	gcCargo.setTotalQuantity(50);
	commitTransaction;
	lcSet.add(gcLayer.allROROGCDefnByCode.last.CM_ROROGCDefnVoyage.myGCController);
	app.myTrxCA.trxCreateRORODischargeCCs(lcSet,app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	self.createGCDischJobsForRORO( voyageDeck, wpC);
	
	wle:=gcCargo.allWorklistEntries.first;

	self.assertNotNull(wle);
	job:=wle.job.CM_VoyageJob;

	// ### AUTO PLAN/ QUEUE CARGO FROM VOYAGE TO YARD
	delete moveController;
	create moveController transient;
	moveController.setMyTrackedItem(gcCargo);
	moveController.setMyWorkListEntry(wle);
	moveController.setMyToPrimaryLocation(bs1.myLocationsController);
	moveController.setMoveMode(QUEUE_MODE);
	app.myTrxUA.trxMoveTrackedItem(moveController, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();	
	
	self.assertTrue(wle.myFutureMove.isKindOf(CM_FutureMoveQueued));
	
	masterQEntry:=wle.allRTQueueEntries.first;
	self.assertNotNull(masterQEntry);
	app.isRTApp:=true;  
	
	// ### ASSIGN DISCHARGE JOB TO FORK LIFT
	self.expectTrxError(ERR_MACH_ASSIGN); 
	self.machineAcceptSpecifiedTwinTask(fork, masterQEntry,null);
	
	// ### PICKUP PART OF THE CARGO AND SETDOWN IN BLOCK STACK
	self.opts.purge;
	self.opts.addAssoc("QUANTITY",10);
	self.machinePickup(fork);
	self.machineSetdownTwinTask(fork, fork.currentQueueTask ,null,fork.currentQueueTask.myEntry.allQueuedFutureMoves.first.allLocationsControllers.first.getID);
	self.assertEqual(job.workListEntries.size, 2);
	self.assertEqual(job.workListEntries.first.quantity,40);
	self.assertEqual(job.workListEntries.first.status,WLE_PART_COMPLETE);
	self.assertEqual(job.workListEntries.last.quantity,10);
	self.assertEqual(job.workListEntries.last.status,WLE_COMPLETED);
 
	
	// ### PICKUP ANOTHER 20 OF THE CARGO AND SETDOWN IN BLOCK STACK
	self.expectTrxError(ERR_MACH_ASSIGN); 
	self.machineAcceptSpecifiedTwinTask(fork, masterQEntry,null);
	self.opts.purge;
	self.opts.addAssoc("QUANTITY",20);
	self.machinePickup(fork);
	self.machineSetdownTwinTask(fork, fork.currentQueueTask ,null,fork.currentQueueTask.myEntry.allQueuedFutureMoves.first.allLocationsControllers.first.getID);
	self.assertEqual(job.workListEntries.size, 3);
	self.assertEqual(job.workListEntries.first.quantity,20);
	self.assertEqual(job.workListEntries.first.status,WLE_PART_COMPLETE);
	self.assertEqual(job.workListEntries.last.quantity,20);
	self.assertEqual(job.workListEntries.last.status,WLE_COMPLETED);
	
	// ### PICKUP REST OF THE CARGO AND SETDOWN IN BLOCK STACK
	self.expectTrxError(ERR_MACH_ASSIGN); 
	self.machineAcceptSpecifiedTwinTask(fork, masterQEntry,null);
	self.opts.purge;
	self.opts.addAssoc("QUANTITY",20);
	self.machinePickup(fork);
	self.machineSetdownTwinTask(fork, fork.currentQueueTask ,null,fork.currentQueueTask.myEntry.allQueuedFutureMoves.first.allLocationsControllers.first.getID);
	self.assertEqual(job.workListEntries.size, 3);
	self.assertEqual(job.workListEntries.first.quantity,20);
	self.assertEqual(job.workListEntries.first.status,WLE_COMPLETED);
	self.assertEqual(job.workListEntries.last.quantity,20);
	self.assertEqual(job.workListEntries.last.status,WLE_COMPLETED);
	self.assertEqual(job.status,JOB_COMPLETE);
	
	self.assertEqual(voyageDeck.allShipReceivals.size, 3);
	foreach shipRecTxn in job.allShipReceivals discreteLock do
		totalQuantity := totalQuantity + shipRecTxn.totalQuantity;
	endforeach;
	self.assertEqual(totalQuantity, 50);
	
	//update the kpi stats
	app.myTrxUA.trxUpdateVoyageKPIStats(voyage,true, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	//check kpis correct
	kpi := voyage.getKPIByType(KPI_Type_Voyage).CM_KPIVoyageTotals;
	self.assertNotNull(kpi);
	
	//should be 2 gc move kpis 1 for discharge &amp; load
	self.assertEqual(kpi.allKPIVoyageMoveDtls_GC.size,2);
	
	kpiDisch:=kpi.allKPIVoyageMoveDtls_GC[VoyageMoveType_Discharge,cargoTypeObj,null,false];
	self.assertNotNull(kpiDisch);
	self.assertEqual(kpiDisch.quantity,50);
	kpiLoad:=kpi.allKPIVoyageMoveDtls_GC[VoyageMoveType_Load,cargoTypeObj,null,false];
	self.assertNotNull(kpiLoad);
	self.assertEqual(kpiLoad.quantity,20);
	
	self.doWorkPointCargoRateTest( job.myJobSheet );	//08 Mar 2018	NDL	TSF 37437
epilog	
	//self.deleteVessel(vesselName);
//	self.deleteVoyage(voyageName);
	app.isRTApp:=false;  
	delete moveController;
	delete tas;
	delete lcSet;
end;</source>
        <text>&lt;?xml version="1.0"?&gt;
&lt;UT_Additional&gt;
  &lt;Categories&gt;
    &lt;Category CanDelete="true"&gt;test1aasdfakhsdflkj&lt;/Category&gt;
    &lt;Category CanDelete="true"&gt;WorkPointDeleteIssue&lt;/Category&gt;
  &lt;/Categories&gt;
&lt;/UT_Additional&gt;</text>
    </JadeMethod>
    <JadeMethod name="tBreakBulkRoadReleaseByID" id="5c0d8a42-4c99-4cce-947b-8604690a4975">
        <source>tBreakBulkRoadReleaseByID();
// cnwer1
//cnwdw1	
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 May 2013	cnwrd1	Initial creation

*/
constants
	Cargo_Type			: String = "UTREBAR";
	VehicleID 			: String = 'RJDUTV3';
	DriverID 			: String = 'RJDDRIVER';
vars
	bs1 			: CM_BlockStack;
	q1				: CM_RadioTelemetryQueue;
	tas				: StringArray;
	cargoTypeObj 	: CM_CargoType;
	vvr				: CM_VehicleVisitRecord;
	gateOut			: CM_GateArea;
	masterQEntry 	: CM_RTQueueEntry;
	cargo,
	cargo2 			: CM_TrackedItem;
	straddle1,
	straddle2		: CM_Machine;
	toLocn 			: CM_LocationsController;
	wle			: CM_WorkListEntry;
	theTarget  : String;
	receiveTx : CM_TITransaction;
	storageTx: CM_TITransaction;
	receciveTxDateTime: TimeStamp;
begin

	//create bbk cargo type with allow duplicates
	cargoTypeObj	:=	app.myRoot.getCargoTypeFromAbbrev(Cargo_Type);
	deleteVehicle(VehicleID);
	
	// create block stack 1
	// create cargo with quantity
	deleteTerminalArea("UTBS1");
	bs1:=self.addBlockStack("UTBS1",200,null);
	self.assertNotNull(bs1);
	
	
	self.deleteAllCargo("UTREBAR1",cargoTypeObj);
	cargo:=self.addCargoAtLocation("UTREBAR1",cargoTypeObj,self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString), bs1.myLocationsController);
	self.assertNotNull(cargo);
	self.assertEqual(cargo.myPrimaryActualLocation,bs1.myLocationsController);
	
	// Set the receive date in past so can check for storage tx
	receiveTx := cargo.getTransReceiveFirst();
		self.assertNotNull(receiveTx);
	receciveTxDateTime := receiveTx.dateTime.addDays(-10);	
	self.updateTITransactionDateTime(receiveTx, receciveTxDateTime);
	
	
	beginTransaction;
	cargo.setTotalQuantity(50);
	cargo.setMyTotalVolume(50000);
	cargo.setTotalWeightWithoutTrans(50000);
	commitTransaction;
	
	self.assertEqual(cargo.totalQuantity,50);
	self.assertEqual(cargo.totalVolume.Real,50000.Real);
	self.assertEqual(cargo.totalWeight.Decimal,50000.Decimal);
		
	
	self.opts.addAssoc("TotalRequested", 30);
	self.opts.addAssoc("addRelease", true);
	
	q1 := self.addQueue("UT_Q", bs1, null, false);
		
	gateOut := self.getPGate(self.getProfileSetting(UT_Profile.P_DGATE_POUT).asString);
	assertNotNull(gateOut);
	
	vvr := gateOutGC(VehicleID, "", DriverID, cargo,gateOut.getFirstExitGate, null);
	assertNotNull(cargo.getPrimaryLocation(QUEUE_MODE));
	assertEqual(vvr.myRoadJob.workListEntries.size, 1);
	assertEqual(vvr.myRoadJob.workListEntries.first.myTrackedItem, cargo);

	
	masterQEntry:=cargo.allQueuedFutureMoves.first.myWorkListEntry.allRTQueueEntries.first;
	wle := cargo.allQueuedFutureMoves.first.myWorkListEntry;
	toLocn := wle.getLocationForMode(QUEUE_MODE);
	
	theTarget  := wle.locationTarget;
	
	self.assertNotNull(masterQEntry);
	
	create tas transient;
	tas.add(bs1.id); 
	tas.add('P_OUT');
	tas.add('P_IN');
	tas.add('YIA');
	tas.add('VTA');
	tas.add('VTA_A');
	tas.add('D_IC');
	tas.add('VTA_P');
	self.opts.purge();
	self.opts.addAssoc("WeightDifference", 500);
	self.opts.addAssoc("WeightMaxLift", 20000);
	self.addStraddleTwin("UTS1", 91, tas, q1.id);
	self.addForkLift("UTFL", 94, tas, q1.id);
	
	straddle1 := self.getMachine("UTS1");
	straddle2 := self.getMachine("UTFL");
	app.isRTApp:=true;  
	self.machineLogon(straddle1);
	self.machineLogon(straddle2);
	// Test that cannot twin lift 20ft with 40ft
	//self.expectTrxError(ERR_MACH_ASSIGN); 
	self.machineAcceptSpecifiedTwinTask(straddle1, masterQEntry,null);
	self.opts.purge;
	self.opts.addAssoc("QUANTITY",10);
	self.machinePickup(straddle1);
	cargo2 := straddle1.myMachineController.allTrackedItems.first;
	
	self.machineAcceptSpecifiedTwinTask(straddle2, masterQEntry,null);
	self.opts.purge;
	self.opts.addAssoc("QUANTITY",20);	
	self.machinePickup(straddle2);		


	self.machineSetdownTwinTask(straddle1, straddle1.currentQueueTask ,null, theTarget);
	self.machineSetdownTwinTask(straddle2, straddle2.currentQueueTask,null,theTarget);
										
	self.machineLogOff(straddle1);
	self.machineLogOff(straddle2);
	
	
	assertTrue(cargo2.getPrimaryLocation(REAL_MODE).isKindOf(CM_VehicleController));
	assertEqual(cargo2.totalQuantity, 30);
	
	self.roadExit(vvr);
	assertNull(vvr.myRoadJob);
	assertEqual(vvr.status, CM_VehicleVisitRecord.Status_Complete);
	assertTrue(vvr.allReleasedTrackedItems.includes(cargo2));
	assertNull(vvr.vehicle.myPrimaryActualLocation);	
	assertNull(cargo2.myPrimaryActualLocation);
	
	storageTx := cargo2.getLastTransOfType(TRANS_TYPE_STORAGE);
		assertNotNull(storageTx);
		assertEqual(storageTx.CM_Storage.startTransaction, receiveTx);
		assertEqual(cargo2.allPriorTransactions.size, 1);
		
epilog
	app.isRTApp:=false;  
	delete tas;
end;
</source>
    </JadeMethod>
    <JadeMethod name="tBreakBulkSplitMerge" id="1668c558-d841-4070-bc68-991bf814001f">
        <source>tBreakBulkSplitMerge();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 April 2013	cnwer1	Initial creation CCMS DPH 2274

*/
constants
	Cargo_Type			: String = "UTREBAR";
vars
	cargoTypeObj : CM_CargoType;
	bs1,bs2 	: CM_BlockStack;
	cargo , splitCargo	: CM_TrackedItem;
	moveController		: CMIF_MoveController;
	splitTrans, splitTrans2 : CM_Split;
	mergeTrans, mergeTrans2 : CM_Merge;
	wle 		: CM_WorkListEntry;
	job : CM_Job;
begin

	//create bbk cargo type with allow duplicates
	
	cargoTypeObj	:=	app.myRoot.getCargoTypeFromAbbrev(Cargo_Type);
	
	// create block stack 1
	// create cargo with quantity
	deleteTerminalArea("UTBS1");
	bs1:=self.addBlockStack("UTBS1",200,null);
	self.assertNotNull(bs1);
	
	self.deleteAllCargo("UTREBAR1",cargoTypeObj);
	cargo:=self.addCargoAtLocation("UTREBAR1",cargoTypeObj,self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString), bs1.myLocationsController);
	self.assertNotNull(cargo);
	self.assertEqual(cargo.myPrimaryActualLocation,bs1.myLocationsController);
	
	beginTransaction;
	cargo.setTotalQuantity(50);
	cargo.setMyTotalVolume(50000);
	cargo.setTotalWeightWithoutTrans(50000);
	commitTransaction;
	
	self.assertEqual(cargo.totalQuantity,50);
	self.assertEqual(cargo.totalVolume.Real,50000.Real);
	self.assertEqual(cargo.totalWeight.Decimal,50000.Decimal);

	//create block stack 2
	deleteTerminalArea("UTBS2");
	bs2:=self.addBlockStack("UTBS2",200,null);
	self.assertNotNull(bs2);
	
	
	create moveController transient;
	moveController.setMyTrackedItem(cargo);	
	moveController.setMyToPrimaryLocation(bs2.myLocationsController);
	
	//queue the entire 50 to bs2
	moveController.setMoveMode(QUEUE_MODE);
	moveController.setQuantity(50);  //split move 25 to bs2
	
	app.myPassport.setWarningsIgnored(true);
	app.myPassport.setWarningsAcknowledged(true);
	app.myTrxUA.trxMoveTrackedItem(moveController, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertEqual(cargo.myPrimaryQueuedLocation,bs2.myLocationsController);
	self.assertNotNull(cargo.allQueuedFutureMoves.first);
	wle:=cargo.allQueuedFutureMoves.first.myWorkListEntry;
	self.assertNotNull(wle);
	self.assertEqual(wle.quantity,50);
	job:=wle.job;
	self.assertNotNull(job);
	
	//move 20 to bs2 set move wle to 
	moveController.setMyWorkListEntry(wle);
	moveController.setMoveMode(REAL_MODE);
	moveController.setQuantity(20);  //split move 25 to bs2
	
	
	app.myPassport.setWarningsIgnored(true);
	app.myPassport.setWarningsAcknowledged(true);
	app.myTrxUA.trxMoveTrackedItem(moveController, app.myPassport);
	
	self.assertNoTrxErrorsOrWarnings();
	self.assertEqual(cargo.totalQuantity,30);
	self.assertEqual(cargo.totalWeight.Decimal,30000.Decimal);
	self.assertEqual(cargo.totalVolume.Real,30000.Real);
	self.assertEqual(cargo.myPrimaryActualLocation,bs1.myLocationsController);
	self.assertEqual(bs2.myLocationsController.allTrackedItems.size,1);
	splitCargo:=bs2.myLocationsController.allTrackedItems.first;
	
	splitTrans:=cargo.getLastTransOfType(TRANS_TYPE_SPLIT).CM_Split;
	self.assertNotNull(splitTrans);
	self.assertEqual(splitTrans.quantity,30);
	self.assertEqual(splitTrans.weight.Decimal,30000.Decimal);
	self.assertEqual(splitTrans.volume.Real,30000.Real);
	self.assertEqual(splitTrans.locationId,"UTBS1");
	self.assertEqual(splitTrans.action, CM_Split.ACTION_PARENT);
	self.assertEqual(splitTrans.getOtherTrackedItem, splitCargo);
		

	self.assertEqual(splitCargo.myCargoType,cargoTypeObj);
	self.assertEqual(splitCargo.id,cargo.id);
	self.assertEqual(splitCargo.totalQuantity,20);
	self.assertEqual(splitCargo.totalWeight.Decimal,20000.Decimal);
	self.assertEqual(splitCargo.totalVolume.Real,20000.Real);
	
	splitTrans2:=splitCargo.getLastTransOfType(TRANS_TYPE_SPLIT).CM_Split;
	self.assertNotNull(splitTrans2);
	self.assertEqual(splitTrans2.quantity,20);
	self.assertEqual(splitTrans2.weight.Decimal,20000.Decimal);
	self.assertEqual(splitTrans2.volume.Real,20000.Real);
	self.assertEqual(splitTrans2.locationId,"UTBS2");
	self.assertEqual(splitTrans2.action, CM_Split.ACTION_CHILD);
	self.assertEqual(splitTrans2.myParentSplit,splitTrans);
	self.assertEqual(splitTrans2.getOtherTrackedItem,cargo);
	
	//test the merge
	//move remaining 10 in bs1 to bs2
	moveController.setMyTrackedItem(cargo);
	moveController.setMyWorkListEntry(wle);
	moveController.setMyToPrimaryLocation(bs2.myLocationsController);
	moveController.setQuantity(10);
	app.myPassport.setWarningsIgnored(true);
	app.myPassport.setWarningsAcknowledged(true);
	app.myTrxUA.trxMoveTrackedItem(moveController, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	self.assertEqual(cargo.totalQuantity,20);
	self.assertEqual(cargo.totalWeight.Decimal,20000.Decimal);
	self.assertEqual(cargo.totalVolume.Real,20000.Real);
	self.assertEqual(cargo.myPrimaryActualLocation,bs1.myLocationsController);

	mergeTrans:=cargo.getLastTransOfType(TRANS_TYPE_MERGE).CM_Merge;
	self.assertNotNull(mergeTrans);
	self.assertEqual(mergeTrans.quantity,20);
	self.assertEqual(mergeTrans.oldQuantity,30);
	self.assertEqual(mergeTrans.weight.Decimal,20000.Decimal);
	self.assertEqual(mergeTrans.volume.Real,20000.Real);
	self.assertEqual(mergeTrans.locationId,"UTBS1");
	
	self.assertEqual(splitCargo.totalQuantity,30);
	self.assertEqual(splitCargo.totalWeight.Decimal,30000.Decimal);
	self.assertEqual(splitCargo.totalVolume.Real,30000.Real);
	mergeTrans2:=splitCargo.getLastTransOfType(TRANS_TYPE_MERGE).CM_Merge;
	self.assertNotNull(mergeTrans2);
	self.assertEqual(mergeTrans2.quantity,30);
	self.assertEqual(mergeTrans2.oldQuantity,20);
	self.assertEqual(mergeTrans2.weight.Decimal,30000.Decimal);
	self.assertEqual(mergeTrans2.volume.Real,30000.Real);
	self.assertEqual(mergeTrans2.locationId,"UTBS2");
	
	//move the remaining 20 will null out all terminal coll so can't be found
	moveController.setMyTrackedItem(cargo);
	moveController.setMyToPrimaryLocation(bs2.myLocationsController);
	moveController.setMyWorkListEntry(wle);
	moveController.setQuantity(20);
	app.myPassport.setWarningsIgnored(true);
	app.myPassport.setWarningsAcknowledged(true);
	app.myTrxUA.trxMoveTrackedItem(moveController, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	self.assertEqual(cargo.totalQuantity,0);
	self.assertEqual(cargo.totalWeight.Decimal,0.Decimal);
	self.assertEqual(cargo.totalVolume.Real,0.Real);
	self.assertEqual(cargo.myPrimaryActualLocation,null);
	self.assertEqual(cargo.locationId,null);
	self.assertEqual(cargo.myTerminal,splitCargo.myTerminal);
	
	self.assertEqual(cargo.getPropertyValue(CM_TrackedItem::myOffsiteTerminal.name),null);
	self.assertEqual(cargo.getPropertyValue(CM_TrackedItem::myOnsiteTerminal.name),null);
	self.assertEqual(cargo.getPropertyValue(CM_TrackedItem::myOnsiteOperatorTerminal.name),null);
	self.assertEqual(cargo.getPropertyValue(CM_TrackedItem::myOnshipVoyage.name),null);
	self.assertEqual(cargo.getPropertyValue(CM_TrackedItem::myOnsiteVoyage.name),null);
	self.assertEqual(cargo.allWorklistEntries.size,0);
	self.assertEqual(cargo.state,TI_STATE_MERGED);
	
	mergeTrans:=cargo.getLastTransOfType(TRANS_TYPE_MERGE).CM_Merge;
	self.assertNotNull(mergeTrans);
	self.assertEqual(mergeTrans.quantity,0);
	self.assertEqual(mergeTrans.oldQuantity,20);
	self.assertEqual(mergeTrans.weight.Decimal,0.Decimal);
	self.assertEqual(mergeTrans.volume.Real,0.Real);
	self.assertEqual(mergeTrans.locationId,"UTBS1");
	
	self.assertEqual(splitCargo.totalQuantity,50);
	self.assertEqual(splitCargo.totalWeight.Decimal,50000.Decimal);
	self.assertEqual(splitCargo.totalVolume.Real,50000.Real);
	mergeTrans2:=splitCargo.getLastTransOfType(TRANS_TYPE_MERGE).CM_Merge;
	self.assertNotNull(mergeTrans2);
	self.assertEqual(mergeTrans2.quantity,50);
	self.assertEqual(mergeTrans2.oldQuantity,30);
	self.assertEqual(mergeTrans2.weight.Decimal,50000.Decimal);
	self.assertEqual(mergeTrans2.volume.Real,50000.Real);
	self.assertEqual(mergeTrans2.locationId,"UTBS2");
	
	//check original cargo and split cargo have now wles or queued future moves
	self.assertEqual(cargo.allWorklistEntries.size,0);
	self.assertEqual(cargo.allQueuedFutureMoves.size,0);
	self.assertEqual(cargo.allQueues.size,0);
	self.assertEqual(splitCargo.allWorklistEntries.size,0);
	self.assertEqual(splitCargo.allQueuedFutureMoves.size,0);
	self.assertEqual(splitCargo.allQueues.size,0);
	
	
	//check delete merged tis
	
	//move splitCargo offsite
	
	self.moveOffsite(splitCargo);
	
	//erase splitCargo set isGarbageCollect to true
	app.isGarbageCollectionProcess:=true;
	beginTransaction;
		splitCargo.erase(NORMAL_ERASE);
	commitTransaction;
	app.isGarbageCollectionProcess:=false;
	//should of deleted splitCargo and the merged cargo
	
	self.assertDeleted(splitCargo.String);
	self.assertDeleted(cargo.String);
	
epilog
	app.isGarbageCollectionProcess:=false;
	delete moveController;
end;</source>
    </JadeMethod>
    <JadeMethod name="tBreakBulkSplitMergeAttachment" id="f074d3d7-2fe8-46df-b2c3-0c2855a3aec7">
        <source>tBreakBulkSplitMergeAttachment();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 December 2025	navsp1	Initial creation MTN-36700 STWO - Damage Photos Not Visible for Multi-Quantity Cargo IDs After Full Discharge

*/
constants
	Cargo_Type			: String = "UTREBAR";
    TerminalArea        : String = "BS1";
    CargoID             : String = "UTTI36700";
    VesselCode          : String = "UTVES63";
    VoyageCode          : String = "UTVOY63";
    
vars
	cargoTypeObj        : CM_CargoType;
	bs1 	            : CM_BlockStack;
    resourcesForm       : PictureResourcesForm;
    photo               : Binary;
    result              : CM_Photo;
	photoDesc           : String;
    thumbPhoto          : Binary;
    voyage              : CM_Voyage;
    vessel              : CM_Vessel;
    lc                  : CM_LocationsController;
	height              : Integer;
    tis                 : CM_TISet;
    cargoOnSite, 
    cargoOnShip         : CM_TrackedItem;
begin

	//Initial setup
	cargoTypeObj	:=	app.myRoot.getCargoTypeFromAbbrev(Cargo_Type);
	vessel := self.addVesselWithHolds(VesselCode, 2, 2);
    voyage := self.addVoyageWithGeneralCargoStruc(VoyageCode, vessel.name, vessel.myOperator.code,	self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 0);
    self.getTerminal.findLocationFromString(VoyageCode&amp;" 0101", true, lc, height); 
    
    //Add blockstack
	deleteTerminalArea(TerminalArea);
	bs1:=self.addBlockStack(TerminalArea,200,null);
	self.assertNotNull(bs1);
	
    //Add cargo
	self.deleteAllCargo(CargoID,cargoTypeObj);    
    cargoOnShip :=self.addCargoBreakBulkAtLocation(CargoID, cargoTypeObj, 50, lc, null, TI_IMEX_STATUS_IMPORT, voyage, vessel.myOperator);
	self.assertNotNull(cargoOnShip);
	self.assertEqual(cargoOnShip.myPrimaryActualLocation, lc);
	self.assertEqual(cargoOnShip.totalQuantity,50);

    //Add attachment
    resourcesForm := PictureResourcesForm.createPrintForm();
	photo := resourcesForm.picExamplePhoto.picture;
    
    thumbPhoto  := self.createThumbnailContent(photo);
    photoDesc := "a photo descrption for "&amp;CargoID;
    
	result := self.addCargoPhoto(cargoOnShip, photoDesc, photo);
	
	self.assertEqual(result.description, "a photo descrption for "&amp;CargoID);
	self.assertEqual(result.getPhotoContent(), photo);
	self.assertEqual(result.getThumbnailContent(), thumbPhoto);
	
	self.assertTrue(cargoOnShip.allAttachments.size &gt; 0);
	self.assertTrue(cargoOnShip.allAttachments.includes(result));
	self.assertTrue(cargoOnShip.numAttachments(CM_Attachment.Type_Photo) = 1);
    
    //Move cargo , quantity 20
    moveBreakBulk(cargoOnShip, bs1, 20);
    
    //Find the moved cargo
    create tis transient;
	getTrackedItems(CargoID, tis);
	assertEqual(tis.size, 2);
	
	cargoOnSite := tis.first;
	if cargoOnSite.myPrimaryActualLocation = lc then
		cargoOnSite := tis.last;
	endif;
    
    self.assertEqual(cargoOnSite.totalQuantity,20);
    self.assertEqual(cargoOnShip.totalQuantity,30);
    self.assertTrueMsg(cargoOnSite.allAttachments.size&gt; 0, "Attachment has not been copied to the split cargo");
    
    self.assertTrueMsg(cargoOnShip.allAttachments.size&gt; 0, "Attachment has been deleted from the onship cargo");
    
    
    //Move the remaining quantity
    moveBreakBulk(cargoOnShip, bs1, 30);
    
    self.assertEqual(cargoOnSite.totalQuantity,50);
    self.assertEqual(cargoOnShip.totalQuantity,0);
    
    self.assertTrueMsg(cargoOnShip.allAttachments.size = 0, "Attachment still exists with the zombie cargo");
    
    self.assertTrueMsg(cargoOnSite.allAttachments.size = 1, "Attachment has not been properly copied to the onsite cargo");
epilog
	delete tis;
    delete resourcesForm;
end;</source>
    </JadeMethod>
    <JadeMethod name="tBreakBulkSplitWithStops" id="94773b39-dbd9-48b4-aa5f-4071fb15436e">
        <source>tBreakBulkSplitWithStops();

/*

Purpose:		Split a break bulk item that has stops.  Stops should end up on split	

Date			Who		Reason
16/10/2015		cnwmh5	Initial creation
// 10 Sep 2019	cnwrs1	TFS 46030
*/

vars

	bs						: CM_BlockStack;
	bs1						: CM_BlockStack;
	cargo					: CM_TrackedItem;
	cargo1					: CM_TrackedItem;
	cargoType				: CM_CargoType;
	voyage					: CM_Voyage;
	moveController			: CMIF_MoveController;
	stop					: CM_Stops;
	isDoClearanceCheck : Boolean;
begin
	isDoClearanceCheck := self.getMyTerminal.myHarbour.isDoClearanceCheck;
	self.setHarbourIsDoClearanceCheck(false);
	bs := self.addBlockStack("UTMHJN", 500, null);
	self.assertNotNull(bs);
	
	bs1 := self.addBlockStack("UTMHJN1", 500, null);
	self.assertNotNull(bs1);
	
	cargoType := app.myRoot.getCargoTypeFromAbbrev("TMBR");
	self.assertNotNull(cargoType);
	
	self.deleteVoyage("UTMHJN1");
	voyage := self.addVoyageWithContainerStructur("UTMHJN1", "TRIP", self.getProfileSetting(UT_Profile.P_OPERATOR).asString(), 
		self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	self.assertNotNull(voyage);
	
	cargo := self.addCargoBreakBulkAtLocation("UTMHREBAR80", cargoType, 750, bs.myLocationsController, "NZAKL", TI_IMEX_STATUS_EXPORT, 
		voyage, self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString()));
	self.assertNotNull(cargo);
	self.assertEqual(cargo.getAllStops().size, 1);
	
	create moveController transient;
	moveController.setMyTrackedItem(cargo);	
	moveController.setMyToPrimaryLocation(bs1.myLocationsController);
	
	moveController.setMoveMode(REAL_MODE);
	moveController.setQuantity(300);
	
	app.myPassport.setWarningsIgnored(true);
	app.myPassport.setWarningsAcknowledged(true);
	app.myTrxUA.trxMoveTrackedItem(moveController, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	cargo1 := self.getTrackedItemAtLocation("UTMHREBAR80", bs1.myLocationsController);
	self.assertNotNull(cargo1);
	
	foreach stop in cargo.getAllStops() do
		self.assertNotNull(cargo1.getAllStops[stop.id]);	
	endforeach;
epilog
	self.setHarbourIsDoClearanceCheck(isDoClearanceCheck);
	app.myPassport.setWarningsIgnored(false);
	app.myPassport.setWarningsAcknowledged(false);

	delete moveController;

end;</source>
        <text>MTN-TEST</text>
    </JadeMethod>
    <JadeMethod name="tBreakBulkSplitandMerge" id="714cc7bf-6a7e-416a-8ade-1a2783e80e91">
        <source>tBreakBulkSplitandMerge();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 Jun 2025 navhn30 Bug 35040: TPT - Instructions are lost when splitting cargo

*/

constants
	Cargo_Type			: String = "UTREBAR";
vars
	vessel: CM_Vessel;
	voyage: CM_Voyage;
	bs1: CM_BlockStack;
	cargoType : CM_CargoType;
	cargoOnship, cargoOnSite: CM_TrackedItem;
	lc: CM_LocationsController;
	height: Integer;
	tis: CM_TISet;
begin

	vessel := self.addVesselWithHolds("UT_VHOLDS-H", 2, 2);
	voyage := self.addVoyageWithGeneralCargoStruc("UT_VHOLDS-H", vessel.name, vessel.myOperator.code,	self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 0);
	bs1    := self.addBlockStack("UTBSH9", 9999, null);

	cargoType := app.myRoot.getCargoTypeFromAbbrev(Cargo_Type);
	
	self.getTerminal.findLocationFromString("UT_VHOLDS 0101", true, lc, height); 
	
	self.deleteCargo("UTREBAR9998A", cargoType);
	
	cargoOnship := self.addCargoBreakBulkAtLocation("UTREBAR9998A", cargoType, 50, lc, null, TI_IMEX_STATUS_IMPORT, voyage, vessel.myOperator);
	self.opts.addAssoc("TotalWeight", 50);
	self.opts.addAssoc("Instructions", "Code_2");
	self.updateTI(cargoOnship);
	self.assertEqual(cargoOnship.totalQuantity, 50);
	
	//moving partial quantity
	self.moveBreakBulk(cargoOnship, bs1, 25);
	
	create tis transient;
	self.getTrackedItems("UTREBAR9998A", tis);
	self.assertEqual(tis.size, 2);
	
	cargoOnSite := tis.first;
	if cargoOnSite.myPrimaryActualLocation = lc then
		cargoOnSite := tis.last;
	endif;
	
	//checking instructions
	self.assertEqual(cargoOnship.myInstructions.myInstructionType, cargoOnSite.myInstructions.myInstructionType);
	self.assertEqual(cargoOnship.myInstructions.internalInstructions, cargoOnSite.myInstructions.internalInstructions);
	self.assertEqual(cargoOnship.myInstructions.externalInstruction, cargoOnSite.myInstructions.externalInstruction);
	
	//moving whole quantity, so that onship cargo will become zombie
	self.moveBreakBulk(cargoOnship, bs1, 25);
	
	//after merging we're deleting instructions on zombie cargo
	self.assertEqual(cargoOnship.myInstructions,null);
	
epilog
	delete tis;
end;</source>
    </JadeMethod>
    <JadeMethod name="tBreakBulkStops" id="5a2150bc-6eb6-4ba6-9ff8-c116ad6e4c9c">
        <source>tBreakBulkStops();
// cnwer1
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 September 2013	cnwdw1	Initial creation
*/
constants
	Cargo_Type			: String = "UTREBAR";
vars
	vessel: CM_Vessel;
	voyage: CM_Voyage;
	cargoType : CM_CargoType;
	cargo: CM_TrackedItem;
	lc: CM_LocationsController;
	selectedTypes: CM_CargoBOLTypeSet;
	stopsTable: CM_StopsTable;
	opts : CM_AssociationDict;
	bs1, bs2: CM_BlockStack;
begin

	vessel := self.addVesselWithHolds("UT_VHOLDS", 2, 2);
	voyage := self.addVoyageWithGeneralCargoStruc("UT_VHOLDS", vessel.name, vessel.myOperator.code,	self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 0);
	
	cargoType	:=	app.myRoot.getCargoTypeFromAbbrev(Cargo_Type);
	
	foreach lc in voyage.allVoyageLocations do
		if lc.isKindOf(CM_GeneralCargoController) then
			break;
		endif;
	endforeach;
	
	assertNotNull(lc);
	cargo := self.addCargoAtLocationDetailed("UTREBAR9999", cargoType, cargoType.allProducts.first, lc, null, TI_IMEX_STATUS_IMPORT, voyage, vessel.myOperator);
	beginTransaction;
	cargo.setTotalQuantity(50);
	commitTransaction;

	deleteStopsTable(99);
	// Create a Stop Type
	create selectedTypes transient;
	create opts transient;
	selectedTypes.add(cargoType);
	stopsTable := addStopsTable(99, "UT", "Unit Test", selectedTypes, opts);
	addStop(cargo, stopsTable);
	
	bs1 := self.addBlockStack("UTBS1", 9999, null);
	
	self.opts.purge();
	self.opts.addAssoc("TotalQuantity", 20);
//	move(cargo, bs1);
	
epilog
	delete selectedTypes;
	delete opts;
	
end;</source>
        <text>&lt;?xml version="1.0"?&gt;
&lt;UT_Additional&gt;
  &lt;Categories&gt;
    &lt;Category CanDelete="true"&gt;test1aasdfakhsdflkj&lt;/Category&gt;
  &lt;/Categories&gt;
&lt;/UT_Additional&gt;</text>
    </JadeMethod>
    <JadeMethod name="tBreakBulkStorage" id="4fa78e71-7b7a-42a7-bb87-9895dff929cd">
        <source>tBreakBulkStorage();
/*

Date		Who		Reason
10 January 2017	cnwer1	Initial creation TFS 2884
25 August 2025 - re wrote to use with storage expiry details

PURPOSE - configure the storage trigger for Merge and check that the storage transaction is created on a split/merge
NOTE - this should not occur for cargo that are zombies and have never been received.
NOTE - this is driven only by the 'source' TI only the source TI will attempt to create a storage traction for this trigger. Storage transactions are only created if the TI has a storage expiry detail object, which is created as part of receival.

Scenario 1 - Merge trigger is ON. Discharge Part. there should not be a storage transaction on the source or the target. Discharge rest. there should not be a storage transaction on the source or the target.
Scenario 2 - Merge trigger is ON. Discharge whole. No storage transactions. Move parts to 2nd LC there should be a storage trans on the 'source' TI, then move rest there should be a single storage trans on the zombie. Nothing on the target.


*/

vars
	vessel: CM_Vessel;
	voyage: CM_Voyage;
	bs1, bs2: CM_BlockStack;
	breakBulkCargoType, bulkCargoType : CM_CargoType;
	cargo, cargoOnSite1, cargoOnSite2: CM_TrackedItem;
	cargoId: String;
	lc: CM_LocationsController;
	height: Integer;
	expected, received, damaged: Integer;
	expectedWeight, receivedWeight: Decimal[14,4];
	txns: CM_TransactionSet;
	criteriaTypes : CM_YACriteriaTypeArray;
	pxyStorageTrigger : CM_StorageTrigger;
	triggers : CM_StorageTriggerByType;
		storageConfig	: CM_StorageConfig;
			values		: ObjectArray;
			criteria	: IntegerArray;
			storageDetail : CM_StorageDetail;
	txn 		: CM_Transaction;
	firstReceive,
	receiveTxn, receiveTxn2,
	storageTxn: CM_TITransaction;
	newDT, receiveTS : TimeStamp;
begin
	
	vessel := self.addVesselWithHolds("UT_VHOLDS", 2, 2);
	voyage := self.addVoyageWithGeneralCargoStruc("UT_VHOLDS", vessel.name, vessel.myOperator.code,	self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 0);
	bs1 := self.addBlockStack("UTBS1", 9999, null);
	bs2 := self.addBlockStack("UTBS2", 9999, null);// NAVAB1 FIX UT 25AUG2025
	breakBulkCargoType := app.myRoot.getCargoTypeFromAbbrev("UTREBAR");
	bulkCargoType  := app.myRoot.getCargoTypeFromAbbrev("UTCOAL");
	self.getTerminal.findLocationFromString("UT_VHOLDS 0101", true, lc, height); 

	self.deleteStorageConfig( false );
	
	create criteriaTypes transient;
	criteriaTypes.add(app.myRoot.allYACriteriaTypes[YACriteriaType_CargoType]);
	
	// PAR 36472
	create pxyStorageTrigger transient;
	 pxyStorageTrigger.setProxy( CargoSplitMerge, false, null);
	 
	 create triggers transient;
	 triggers.add(pxyStorageTrigger);
	
	storageConfig := self.createStorageConfig(criteriaTypes, triggers, null, null, true, true,
											  null, CM_StorageConfig.ShipReceivalActualDischarge, CM_StorageConfig.ShipReleaseActualLoad, null, null,null, -1, -1, -1);

	create values transient;
	values.add(breakBulkCargoType);
	create criteria transient;
	criteria.add(YACriteriaType_CargoType);
	storageDetail:=self.addStorageDetail(storageConfig,"UTREBAR Storage",criteria,values,0,0,false,false,0,CM_StorageDetail.RecievalDateRuleLastByLocn,true,null); //21.07.2017 cnwma1 TFS #5409
	self.assertNotNull(storageDetail);
	
	// #############################################
	// #############################################
	// #############################################
	// ##### SCENARIO 1

	// change storage detail to so storage created agains the last receival txn
	beginTransaction;
	storageDetail.setPropertyValue(CM_StorageDetail::receivalDateRule.name,CM_StorageDetail.RecievalDateRuleLastByLocn);
	storageDetail.setPropertyValue(CM_StorageDetail::noStorageIfNotFullyReceived.name,true);
	commitTransaction;
	

	// Move break bulk cargo in parts
	cargoId := "UTREBAR9999B";
	deleteCargo(cargoId, breakBulkCargoType);
	cargo := self.addCargoBreakBulkAtLocation(cargoId, breakBulkCargoType, 50, lc, null, TI_IMEX_STATUS_IMPORT, voyage, vessel.myOperator);
	self.opts.addAssoc("TotalWeight", 50);
	self.updateTI(cargo);
	assertEqual(cargo.totalQuantity, 50);
	self.opts.purge;
	
	// NAVAB1 FIX UT 25AUG2025
	receiveTS := receiveTS.addDays(-2);
	self.opts.addAssoc("EffectiveTimeStamp",receiveTS);
	moveBreakBulk(cargo, bs1, 20);
	
	// MOVE PART
	cargoOnSite1 := getTrackedItemAtLocation(cargoId, bs1.myLocationsController);
	
	self.assertTrueMsg(cargoOnSite1.totalQuantity = 20, "cargoOnSite1 total quantity should be 20, is " &amp; cargoOnSite1.totalQuantity.String);
	self.assertTrueMsg(cargoOnSite1.totalWeight = 20, "cargoOnSite1 total quantity should be 20 is " &amp; cargoOnSite1.totalWeight.String);
		
	receiveTxn:=cargoOnSite1.getLastTransOfType(	TRANS_TYPE_REC_SHIP);
	self.assertNotNull(receiveTxn);	

	self.assertNull(cargo.getLastTransOfType(	TRANS_TYPE_STORAGE));
	
	// MOVE 2nd PART
	moveBreakBulk(cargo, bs1, 25);
	self.assertTrueMsg(cargoOnSite1.totalQuantity = 45, "cargoOnSite1 total quantity should be 45, is " &amp; cargoOnSite1.totalQuantity.String);
	self.assertTrueMsg(cargoOnSite1.totalWeight = 45, "cargoOnSite1 total quantity should be 45 is " &amp; cargoOnSite1.totalWeight.String);
	
	self.assertNull(cargo.getLastTransOfType(	TRANS_TYPE_STORAGE));
	
	// MOVE REST
	moveBreakBulk(cargo, bs1, 0); // removing remaining
	self.assertTrueMsg(cargoOnSite1.totalQuantity = 50, "cargoOnSite1 total quantity should be 45, is " &amp; cargoOnSite1.totalQuantity.String);
	self.assertTrueMsg(cargoOnSite1.totalWeight = 50, "cargoOnSite1 total quantity should be 45 is " &amp; cargoOnSite1.totalWeight.String);
	
	receiveTxn:=cargoOnSite1.getLastTransOfType(	TRANS_TYPE_REC_SHIP);
	self.assertNotNull(receiveTxn);	
	
	storageTxn:=cargo.getLastTransOfType(	TRANS_TYPE_STORAGE);
	self.assertNullMsg(storageTxn, "Onship Zombie, NOT expecting Transaction of type: TRANS_TYPE_STORAGE A1 | " &amp; "storageTxn");
	storageTxn:=cargoOnSite1.getLastTransOfType(	TRANS_TYPE_STORAGE);
	self.assertNullMsg(storageTxn, "Onsite item, NOT expecting Transaction of type: TRANS_TYPE_STORAGE A1 | " &amp; "storageTxn");
	

	// #############################################
	// #############################################
	// #############################################
	// ###### SCENARIO 2
	
	// change storage detail to so storage created agains the last receival txn and storage creted with every receival
	beginTransaction;
	storageDetail.setPropertyValue(CM_StorageDetail::receivalDateRule.name,CM_StorageDetail.RecievalDateRuleLastByLocn);
	storageDetail.setPropertyValue(CM_StorageDetail::noStorageIfNotFullyReceived.name,false);
	commitTransaction;
	
	create txns transient;
	txns.clear;
	cargoId := "UTREBAR9999C";
	deleteCargo(cargoId, breakBulkCargoType);
	cargo := self.addCargoBreakBulkAtLocation(cargoId, breakBulkCargoType, 50, lc, null, TI_IMEX_STATUS_IMPORT, voyage, vessel.myOperator);
	self.opts.addAssoc("TotalWeight", 50);
	self.updateTI(cargo);
	assertEqual(cargo.totalQuantity, 50);
	self.opts.purge;
	
	// NAVAB1 FIX UT 25AUG2025
	
	// ### MOVE WHOLE
	receiveTS := receiveTS.addDays(-2);
	self.opts.addAssoc("EffectiveTimeStamp",receiveTS);
	moveBreakBulk(cargo, bs1, 50); // move all, now merge split should create storage
	
	cargoOnSite1 := getTrackedItemAtLocation(cargoId, bs1.myLocationsController);
		expected := cargoOnSite1.getShipReceivalQuantity();
		assertEqual(expected, 50);
		expectedWeight := cargoOnSite1.getShipReceivalWeight();
		assertEqual(expectedWeight, 50.Decimal);
		received := cargoOnSite1.getShipDischargeQuantity();
		assertEqual(received, 50);
		receivedWeight := cargoOnSite1.getShipDischargeWeight();
		assertEqual(receivedWeight, 50.Decimal);
		
	receiveTxn:=cargoOnSite1.getLastTransOfType(	TRANS_TYPE_REC_SHIP);
	self.assertNotNull(receiveTxn);	
	self.assertTrueMsg(receiveTxn.dateTime = receiveTS, "Receive should be on " &amp; receiveTS.String &amp; " is on " &amp; receiveTxn.dateTime.String);
	txns.addNoDuplicates(receiveTxn,false);
	
	
	storageTxn:=cargoOnSite1.getLastTransOfType(	TRANS_TYPE_STORAGE);
	self.assertNullMsg(storageTxn, "Storage trans should be null A1");

	
	
	// ### MOVE PART on site
	moveBreakBulk(cargo, bs2, 25);

	cargoOnSite2 := getTrackedItemAtLocation(cargoId, bs2.myLocationsController);
	
	self.assertTrueMsg(cargoOnSite1.totalQuantity = 25, "cargoOnSite1 total quantity should be 25, is " &amp; cargoOnSite1.totalQuantity.String);
	self.assertTrueMsg(cargoOnSite1.totalWeight = 25, "cargoOnSite1 total quantity should be 25, is " &amp; cargoOnSite1.totalWeight.String);
	self.assertTrueMsg(cargoOnSite2.totalQuantity = 25, "cargoOnSite2 total quantity should be 25, is " &amp; cargoOnSite2.totalQuantity.String);
	self.assertTrueMsg(cargoOnSite2.totalWeight = 25, "cargoOnSite2 total quantity should be 25, is " &amp; cargoOnSite2.totalWeight.String);
	
			
	receiveTxn:=cargoOnSite1.getLastTransOfType(	TRANS_TYPE_REC_SHIP);
	self.assertTrueMsg(receiveTxn &lt;&gt; null, "B1 should not be null");

	storageTxn:=cargoOnSite1.getLastTransOfType(	TRANS_TYPE_STORAGE);
	self.assertTrueMsg(storageTxn &lt;&gt; null, "B2 should not be null");

	txns.addNoDuplicates(receiveTxn,false);
	txns.addNoDuplicates(storageTxn,false);
	
	storageTxn:=cargoOnSite2.getLastTransOfType(	TRANS_TYPE_STORAGE);
	self.assertTrueMsg(storageTxn = null, "B3 should be null");


	
	moveBreakBulk(cargo, bs2, 0); // removing remaining

	self.assertTrueMsg(cargoOnSite2.totalQuantity = 50, "cargoOnSite2 total quantity should be 50, is " &amp; cargoOnSite2.totalQuantity.String);
	self.assertTrueMsg(cargoOnSite2.totalWeight = 50, "cargoOnSite2 total quantity should be 50, is " &amp; cargoOnSite2.totalWeight.String);
	
	self.assertTrueMsg(cargoOnSite1.totalQuantity = 0, "cargoOnSite1 total quantity should be 0, is " &amp; cargoOnSite1.totalQuantity.String);
	self.assertTrueMsg(cargoOnSite1.totalWeight = 0, "cargoOnSite1 total quantity should be 0, is " &amp; cargoOnSite1.totalWeight.String);
	self.assertTrueMsg(cargoOnSite1.isZombie(), "cargoOnSite1 should be a zombie");
	
	
	receiveTxn:=cargoOnSite1.getLastTransOfType(	TRANS_TYPE_REC_SHIP);
	self.assertTrueMsg(receiveTxn &lt;&gt; null, "B1 should not be null");

	storageTxn:=cargoOnSite1.getLastTransOfType(	TRANS_TYPE_STORAGE);
	self.assertTrueMsg(storageTxn &lt;&gt; null, "B2 should not be null");

	txns.addNoDuplicates(receiveTxn,false);
	txns.addNoDuplicates(storageTxn,false);

	//storage should be only created on last and with the last receival txn
	self.assertEqual(storageTxn.CM_Storage.startTransaction, receiveTxn);
	
	storageTxn:=cargoOnSite2.getLastTransOfType(	TRANS_TYPE_STORAGE);
	self.assertTrueMsg(storageTxn = null, "B3 should be null");
	

	
	
epilog
	triggers.purge;
	delete triggers;
	delete criteriaTypes;
	delete values;
	delete criteria;
	delete txns;
	self.deleteStorageConfig( true );
end;</source>
        <text>MTN-90</text>
    </JadeMethod>
    <JadeMethod name="tBulkDischargeAndDelivery" id="086c61ff-7be9-4e39-91de-78067fd59d46">
        <source>tBulkDischargeAndDelivery();
// cnwer1
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 October 2013	cnwdw1	Initial creation
*/
constants
	Cargo_Type			: String = "UTCOAL";
vars
	vessel: CM_Vessel;
	voyage: CM_Voyage;
	cargoType : CM_CargoType;
	cargoOnship: CM_TrackedItem;
	gate: CM_Gate;
	vvr1, vvr2: CM_VehicleVisitRecord;
	lc: CM_LocationsController;
	height: Integer;
begin

	vessel := self.addVesselWithHolds("UT_VHOLDS", 2, 2);
	voyage := self.addVoyageWithGeneralCargoStruc("UT_VHOLDS", vessel.name, vessel.myOperator.code,	self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 0);

	cargoType := app.myRoot.getCargoTypeFromAbbrev(Cargo_Type);
	
	self.getTerminal.findLocationFromString("UT_VHOLDS 0101", true, lc, height); 
	
	deleteCargo("UTCOAL", cargoType);
	
	cargoOnship := self.addCargoBulkAtLocation("UTCOAL", cargoType, 5000, lc, null, TI_IMEX_STATUS_IMPORT, voyage, vessel.myOperator, null);
		assertEqual(cargoOnship.totalWeight, 5000.Decimal);

	gate := self.getGate(self.getProfileSetting(UT_Profile.P_SGATE).asString);
		assertNotNull(gate);
		
	deleteVehicle("UTTRUCK1");
	self.opts.purge();
	self.opts.addAssoc("TotalWeight", 2000);
	vvr1 := gateOutGC("UTTRUCK1", "", "UTDRIVER1", cargoOnship, gate, null);
		assertNotNull(cargoOnship.getPrimaryLocation(QUEUE_MODE));
		assertEqual(vvr1.myRoadJob.workListEntries.size, 1);
		assertEqual(vvr1.myRoadJob.workListEntries.first.myTrackedItem, cargoOnship);

	deleteVehicle("UTTRUCK2");
	self.opts.purge();
	self.opts.addAssoc("TotalWeight", 3000);
	vvr2 := gateOutGC("UTTRUCK2", "", "UTDRIVER2", cargoOnship, gate, null);
		assertNotNull(cargoOnship.getPrimaryLocation(QUEUE_MODE));
		assertEqual(vvr2.myRoadJob.workListEntries.size, 1);
		assertEqual(vvr2.myRoadJob.workListEntries.first.myTrackedItem, cargoOnship);	

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="tBulkSplitMerge" id="92e20c7c-20fe-436b-8fb2-e0017b19f9bd">
        <source>tBulkSplitMerge();
/*

Date		Who		Reason
11 March 2014	cnwer1	Initial creation PAR

*/
constants
	Cargo_Type			: String = "UTCOAL";
vars
		cargoTypeObj : CM_CargoType;
	bs1,bs2 	: CM_BlockStack;
	cargo , splitCargo	: CM_TrackedItem;
	moveController		: CMIF_MoveController;
	splitTrans, splitTrans2 : CM_Split;
	mergeTrans, mergeTrans2 : CM_Merge;
	wle 		: CM_WorkListEntry;
	job : CM_Job;	
begin
	cargoTypeObj	:=	app.myRoot.getCargoTypeFromAbbrev(Cargo_Type);
	
	// create block stack 1
	// create cargo with quantity
	deleteTerminalArea("UTBS1");
	bs1:=self.addBlockStack("UTBS1",200,null);
	self.assertNotNull(bs1);
	
	self.deleteAllCargo("UTCOAL1",cargoTypeObj);
	cargo:=self.addCargoAtLocation("UTCOAL1",cargoTypeObj,self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString), bs1.myLocationsController);
	self.assertNoTrxErrors();
	self.assertNotNull(cargo);
	self.assertEqual(cargo.myPrimaryActualLocation,bs1.myLocationsController);
	beginTransaction;
	cargo.setTotalWeightWithoutTrans(50000); //50000kgs
	cargo .setMyTotalVolume(cargo.totalWeight/cargo.getDensity);
	commitTransaction;
	self.assertEqual(cargo.totalWeight.Decimal,50000.Decimal);
	
	//create block stack 2
	deleteTerminalArea("UTBS2");
	bs2:=self.addBlockStack("UTBS2",200,null);
	self.assertNotNull(bs2);
	
	
	create moveController transient;
	moveController.setMyTrackedItem(cargo);	
	moveController.setMyToPrimaryLocation(bs2.myLocationsController);
	
	//queue the entire 50 to bs2
	moveController.setMoveMode(QUEUE_MODE);
	moveController.setWeight(25000);  //split move 25000 kgs to bs2
	
	app.myPassport.setWarningsIgnored(true);
	app.myPassport.setWarningsAcknowledged(true);
	app.myTrxUA.trxMoveTrackedItem(moveController, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertEqual(cargo.myPrimaryQueuedLocation,bs2.myLocationsController);
	self.assertNotNull(cargo.allQueuedFutureMoves.first);
	wle:=cargo.allQueuedFutureMoves.first.myWorkListEntry;
	self.assertNotNull(wle);
	self.assertEqual(wle.weight,25000.Decimal);
	job:=wle.job;
	self.assertNotNull(job);
	
	
	//move 10000 to bs2 set move wle to 
	moveController.setMyWorkListEntry(wle);
	moveController.setMoveMode(REAL_MODE);
	moveController.setWeight(10000);  //split move 25 to bs
	
	app.myPassport.setWarningsIgnored(true);
	app.myPassport.setWarningsAcknowledged(true);
	app.myTrxUA.trxMoveTrackedItem(moveController, app.myPassport);
	
	self.assertNoTrxErrorsOrWarnings();
	self.assertEqual(cargo.totalWeight.Decimal,40000.Decimal);
	self.assertEqual(cargo.myPrimaryActualLocation,bs1.myLocationsController);
	self.assertEqual(bs2.myLocationsController.allTrackedItems.size,1);
	splitCargo:=bs2.myLocationsController.allTrackedItems.first;
	
	splitTrans:=cargo.getLastTransOfType(TRANS_TYPE_SPLIT).CM_Split;
	self.assertNotNull(splitTrans);
	self.assertEqual(splitTrans.weight.Decimal,40000.Decimal);
	self.assertEqual(splitTrans.locationId,"UTBS1");
	self.assertEqual(splitTrans.action, CM_Split.ACTION_PARENT);
	self.assertEqual(splitTrans.getOtherTrackedItem, splitCargo);
		

	self.assertEqual(splitCargo.myCargoType,cargoTypeObj);
	self.assertEqual(splitCargo.id,cargo.id);
	self.assertEqual(splitCargo.totalWeight.Decimal,10000.Decimal);
	splitTrans2:=splitCargo.getLastTransOfType(TRANS_TYPE_SPLIT).CM_Split;
	
	self.assertNotNull(splitTrans2);
	self.assertEqual(splitTrans2.weight.Decimal,10000.Decimal);

	self.assertEqual(splitTrans2.locationId,"UTBS2");
	self.assertEqual(splitTrans2.action, CM_Split.ACTION_CHILD);
	self.assertEqual(splitTrans2.myParentSplit,splitTrans);
	self.assertEqual(splitTrans2.getOtherTrackedItem,cargo);
	
	//10 Mar 2021	NDL	TFS 50909 / 50796 - Don't allow move of a zombie.
	self.move( splitCargo, bs1 ); // merge it back into the original, to create the zombie
	self.opts.purge();
	self.opts.addAssoc("ExpectErrors",true);
	self.move( splitCargo, bs2 );	// Now try to move the zombie.
	self.assertTrueMsg( app.myPassport.allErrors.includesErrorCode( Cargo_been_merge_longe_able_mo ), "Should have errored during move of zombied cargo");
	
	
epilog
	delete moveController;
end;</source>
    </JadeMethod>
    <JadeMethod name="tBulkSplitMergeWithAgent" id="9f62a436-84c8-407d-96b1-0888e3fbe44d">
        <source>tBulkSplitMergeWithAgent();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 June 2016	cnwns1	Initial creation
08 Jan 2024	jlirs1	TFS 60575 - Jade 2022 upgrade fixing unitTests
*/

constants

	Cargo_Type : String = "UTREBAR";
	BS_Area : String = "UTBSM";
	Base_Cargo_ID : String = "UTBSM";
	Cargo_ID1 : String = "UTBSM1";
	Cargo_ID2 : String = "UTBSM2";
	Cargo_ID3 : String = "UTBSM3";
	
vars

	bs : CM_BlockStack;
	cargoType : CM_CargoType;
	ti,otherTi : CM_TrackedItem;
	cargoTypeId : Integer;
	newTiIds : StringArray;
	index : Integer;
	tisToMerge,tisToMergeB : CM_TISet;
	id : String;
	agent :	CMIF_MobileGenericAgent;
	success : Boolean;
	//matchingTIs :CM_TIArray;
begin
	self.setTerminalConfig(ReeferBookingReqsTemp, false);
	self.setTerminalConfig(PrenoteUniqBooking, false);

	cargoType := app.myRoot.getCargoTypeFromAbbrev(Cargo_Type);
	cargoTypeId := cargoType.id;
	
	// create a block stack to use
	bs := self.addBlockStack(BS_Area,200,null);
	self.assertTrueMsg(bs &lt;&gt; null,"test 3. Block stack '" &amp; BS_Area &amp; "' failed to create.");
	
	//create some Break-Bulk with a 50 items in it.
	ti := self.addCargoAtLocation(Cargo_ID1,cargoType,self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString), bs.myLocationsController);
	self.assertTrueMsg(ti &lt;&gt; null,"test 4. Tracked item '" &amp; Cargo_ID1 &amp; "' failed to create.");
	self.assertTrueMsg(ti.myPrimaryActualLocation = bs.myLocationsController,"test 4. Tracked item '" &amp; Cargo_ID1 &amp; "' not created in " &amp; BS_Area &amp; ".");
	beginTransaction;
	ti.setTotalQuantity(50);
	commitTransaction;
	self.assertTrueMsg(ti.totalQuantity = 50,"test 5. Tracked item '" &amp; Cargo_ID1 &amp; "' total Quantity should be 50.");

	//split the existing cargo item into two of 25 items each in teh same location.
	create newTiIds transient;
	newTiIds.add(Cargo_ID2);
	newTiIds.add(Cargo_ID3);
	app.myTrxUA.trxSplitBreakBulkToNewID(	ti.CM_Cargo,	//_sourceTi : CM_Cargo;
											newTiIds,	//_newTiIds : StringArray;
											25,	//_quantity : Integer;
											0,	// _weightOrVolume : Decimal;
											ti.myOperator,	//_operator : CM_Operator;
											true,
											true,
											true,
											true,
											app.myPassport	//_passport : CM_Passport input
											);
	self.assertFalseMsg(app.myPassport.hasErrors,"test 6. Error '" &amp; app.myPassport.getErrorsAsString );
	self.assertTrueMsg(ti.totalQuantity = 0,"test 7. Tracked item '" &amp; ti.id &amp; "' total Quantity should now be 0.");
											
	ti := self.getTerminal.allOnsiteTIsByCargoTypeId.getAtKey( cargoTypeId, Cargo_ID3 );
	self.assertTrueMsg(ti &lt;&gt; null,"test 8. Tracked item '" &amp; Cargo_ID3 &amp; "' failed to create.");
	self.assertTrueMsg(ti.myPrimaryActualLocation = bs.myLocationsController,"test 9. Tracked item '" &amp; ti.id &amp; "' not created in " &amp; BS_Area &amp; ".");
	self.assertTrueMsg(ti.totalQuantity = 25,"test 10. Tracked item '" &amp; ti.id &amp; "' total Quantity should be 25.");
	
	ti := self.getTerminal.allOnsiteTIsByCargoTypeId.getAtKey( cargoTypeId, Cargo_ID2 );
	self.assertTrueMsg(ti &lt;&gt; null,"test 11. Tracked item '" &amp; Cargo_ID2 &amp; "' failed to create.");
	self.assertTrueMsg(ti.myPrimaryActualLocation = bs.myLocationsController,"test 12. Tracked item '" &amp; ti.id &amp; "' not created in " &amp; BS_Area &amp; ".");
	self.assertTrueMsg(ti.totalQuantity = 25,"test 13. Tracked item '" &amp; ti.id &amp; "' total Quantity should be 25.");
	
	//take 'Cargo_ID2' , and split into 25 individual cargo items
	newTiIds.clear();
	foreach index in 1 to 25 do
		newTiIds.add( Base_Cargo_ID &amp; "-" &amp; index.String );
	endforeach;
	
	

	
	app.myTrxUA.trxSplitBreakBulkToNewID(	ti.CM_Cargo,	//_sourceTi : CM_Cargo;
											newTiIds,	//_newTiIds : StringArray;
											1,	//_quantity : Integer;
											0,	// _weightOrVolume : Decimal;
											ti.myOperator,	//_operator : CM_Operator;
											true,
											true,
											true,
											true,
											app.myPassport	//_passport : CM_Passport input
											);
	
	
	
	
	
	self.assertFalseMsg(app.myPassport.hasErrors,"test 14. Error '" &amp; app.myPassport.getErrorsAsString );
	ti := self.getTerminal.allOnsiteTIsByCargoTypeId.getAtKey( cargoTypeId, newTiIds.last );
	self.assertTrueMsg(ti &lt;&gt; null,"test 15. Tracked item '" &amp; newTiIds.last &amp; "' failed to create.");
	self.assertTrueMsg(ti.myPrimaryActualLocation = bs.myLocationsController,"test 16. Tracked item '" &amp; ti.id &amp; "' not created in " &amp; BS_Area &amp; ".");
	self.assertTrueMsg(ti.totalQuantity = 1,"test 17. Tracked item '" &amp; ti.id &amp; "' total Quantity should be 1.");
	
	foreach id in newTiIds do
		if id &lt;&gt; ti.id then
		otherTi := self.getTerminal.allOnsiteTIsByCargoTypeId.getAtKey( cargoTypeId, id );
		
		beginTransaction;
			otherTi.setTotalWeightWithoutTrans(20);
		commitTransaction;
		endif;
	endforeach;
	
	
	
	create agent transient;
	agent.setDoNotShowMsgBox(true);
	//now merge the 25 items back together (24 individulas into the 25th one)
	create tisToMerge transient;
	create tisToMergeB transient;
//	foreach index in 1 to 24 do
//		ti := self.getTerminal.allOnsiteTIsByCargoTypeId.getAtKey( cargoTypeId, newTiIds[index] );
//		if ti &lt;&gt; null then
//		//	tisToMerge.add(ti);
//		endif;
//	endforeach;
	
	
	
	
	ti := self.getTerminal.allOnsiteTIsByCargoTypeId.getAtKey( cargoTypeId, newTiIds.last );
	
	agent.setMyTerminal( self.getTerminal );
	success :=	agent.getMatchingTIsForMerge(ti.CM_Cargo,  tisToMerge);
	self.assertTrueMsg(success  = true,"test 19. agent.getMatchingTIsForMerge return value should be true.");
	self.assertTrueMsg(tisToMerge.size = 24,"test 20. tisToMerge should contain 24 TIs. It contains " &amp; tisToMerge.size.String );
	
	
	
	success :=	agent.doMergeCargo(ti.CM_Cargo,tisToMerge);
	
	self.assertTrueMsg(success  = true,"test 21. agent.doMergeCargo return value should be true.");
	
	//Try again with an empty set
	success :=	agent.doMergeCargo(ti.CM_Cargo,tisToMergeB);
	self.assertTrueMsg(success  = false,"test 22. agent.doMergeCargo return value should be false.");
	
	success :=	agent.getMatchingTIsForMerge(ti.CM_Cargo,  tisToMerge);
	self.assertTrueMsg(success  = false,"test 23. agent.getMatchingTIsForMerge return value should be false.");
									
									
									
	self.assertFalseMsg(app.myPassport.hasErrors,"test 24. Error '" &amp; app.myPassport.getErrorsAsString );
	self.assertTrueMsg(ti.totalQuantity = 25,"test 25. Tracked item '" &amp; ti.id &amp; "' total Quantity should be 25. It is " &amp; ti.totalQuantity.String );
	
epilog

	//get rid of any (will need clean-up if it ever fails during the process)
	self.deleteCargo(Cargo_ID1, cargoType);
	self.deleteCargo(Cargo_ID2, cargoType);
	self.deleteCargo(Cargo_ID3, cargoType);
	if newTiIds &lt;&gt; null then
		foreach id in newTiIds do
			self.deleteCargo(id, cargoType);
		endforeach;
	endif;
	
	delete newTiIds;
	delete tisToMerge;
	delete tisToMergeB;
	delete agent;
//	delete matchingTIs;
	
	
end;
</source>
    </JadeMethod>
    <JadeMethod name="tBulkTransactionMerging" id="713b0da5-3245-4b23-bf93-ea5b05695d3a">
        <source>tBulkTransactionMerging();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 November 2014	cnwndl1	Initial creation	Par 35015

*/

constants

	BBCargo_Type : String = "UTREBAR";
	BS1 : String = "UTBS1";
	BS2 : String = "UTBS2";
	VesselCodeString : String = "UTBG";
	VoyageCodeString1 : String = "UTBG1";
	VoyageCodeString2 : String = "UTBG2";
	VoyageCodeString3 : String = "UTBG3";
	CargoV1X : String = "CargoX";
	CargoV1Y : String = "CargoY";
	CargoV1Z : String = "CargoZ";
	CargoBS1Z : String = "CargoZ";
	CargoV2A : String = "CargoA";
	CargoV3A : String = "CargoA";
	CargoV1B : String = "CargoB";
	CargoBS1C : String = "CargoC";
	CargoBS2C : String = "CargoC";
	CargoBS2D : String = "CargoD";
	CargoBS2E : String = "CargoE";
	
	
vars

	bbCargoType : CM_CargoType;
	bs1 : CM_BlockStack;
	bs2 : CM_BlockStack;
	operator : CM_Operator;
	shippingLineStr : String;
	vessel: CM_Vessel;
	voyage1 : CM_Voyage;
	voyage2 : CM_Voyage;
	voyage3 : CM_Voyage;
	cargoV1X : CM_TrackedItem;
	cargoV1Y : CM_TrackedItem;
	cargoV1Z : CM_TrackedItem;
	cargoBS1Z : CM_TrackedItem;
	cargoV2A : CM_TrackedItem;
	cargoV3A : CM_TrackedItem;
	cargoV1B : CM_TrackedItem;
	cargoBS1C : CM_TrackedItem;
	cargoBS2C : CM_TrackedItem;
	cargoBS2D : CM_TrackedItem;
	cargoBS2E : CM_TrackedItem;
	movedCargo1 : CM_TrackedItem;
	movedCargo2 : CM_TrackedItem;
	movedCargo3 : CM_TrackedItem;
	movedCargo4 : CM_TrackedItem;
	movedCargo5 : CM_TrackedItem;
	movedCargo6 : CM_TrackedItem;
	movedCargo7 : CM_TrackedItem;
	movedCargo8 : CM_TrackedItem;
	movedCargo9 : CM_TrackedItem;
	movedCargo10 : CM_TrackedItem;
	movedCargo11 : CM_TrackedItem;
	movedCargo12 : CM_TrackedItem;
	movedCargo13 : CM_TrackedItem;
	tiArray : CM_TIArray;
	ti : CM_TrackedItem;
	invalidObject : Boolean;
	tiTrx : CM_TITransaction;
	count : Integer;
	trx1 : CM_TITransaction;
	trx2 : CM_TITransaction;

begin

	return;  // 06 May 2015	NDL	Par 35945 - Not game enough to delete it yet in case the we decide to do it again later.

	//onsite cargo
	self.deleteAllCargo(CargoV1X, bbCargoType);
	self.deleteAllCargo(CargoV1Y, bbCargoType);
	self.deleteAllCargo(CargoV1Z, bbCargoType);
	self.deleteAllCargo(CargoBS1Z, bbCargoType);
	self.deleteAllCargo(CargoV2A, bbCargoType);
	self.deleteAllCargo(CargoV3A, bbCargoType);
	self.deleteAllCargo(CargoV1B, bbCargoType);
	self.deleteAllCargo(CargoBS1C, bbCargoType);
	self.deleteAllCargo(CargoBS2C, bbCargoType);
	self.deleteAllCargo(CargoBS2D, bbCargoType);
	self.deleteAllCargo(CargoBS2E, bbCargoType);
	
	create tiArray transient;
	voyage1 := self.getVoyage(VoyageCodeString1);
	if voyage1 &lt;&gt; null then
		foreach ti in voyage1.myShipBlockStack.allTrackedItems do
			tiArray.add(ti);
		endforeach;
		foreach ti in voyage1.allNotifiedTIsByCargoTypeId do
			tiArray.add(ti);
		endforeach;
	endif;
	
	voyage2 := self.getVoyage(VoyageCodeString2);
	if voyage2 &lt;&gt; null then
		foreach ti in voyage2.myShipBlockStack.allTrackedItems do
			tiArray.add(ti);
		endforeach;
		foreach ti in voyage2.allNotifiedTIsByCargoTypeId do
			tiArray.add(ti);
		endforeach;
	endif;
	
	voyage3 := self.getVoyage(VoyageCodeString3);
	if voyage3 &lt;&gt; null then
		foreach ti in voyage3.myShipBlockStack.allTrackedItems do
			tiArray.add(ti);
		endforeach;
		foreach ti in voyage3.allNotifiedTIsByCargoTypeId do
			tiArray.add(ti);
		endforeach;
	endif;
	
	app.isGarbageCollectionProcess := true;
	foreach ti in tiArray do
		if global.isValidObject(ti) then
			self.unplanTI(ti);
			self.deleteTrackedItem(ti, true);
		endif;
	endforeach;
	app.isGarbageCollectionProcess := false;

	self.deleteTerminalArea(BS1);
	self.deleteTerminalArea(BS2);

	self.deleteVoyage(VoyageCodeString1);
	self.deleteVoyage(VoyageCodeString2);
	self.deleteVoyage(VoyageCodeString3);
	self.deleteVessel(VesselCodeString);
	
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	self.assertTrueMsg(operator &lt;&gt; null, "Operator type not found");
	
	shippingLineStr := self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString;
	self.assertTrueMsg(shippingLineStr &lt;&gt; null, "Shipping Line type not found");
	
	bbCargoType := app.myRoot.getCargoTypeFromAbbrev(BBCargo_Type);
	self.assertTrueMsg(bbCargoType &lt;&gt; null, BBCargo_Type &amp; " cargo type not found");
	
	vessel := self.addVesselGeneralCargo(VesselCodeString, operator, 0);
	self.assertTrueMsg(vessel &lt;&gt; null, VesselCodeString &amp; " vessel not created");
	
	voyage1 := self.addVoyageWithGeneralCargoStruc(	VoyageCodeString1, 
													VesselCodeString,
													operator.code, 
													shippingLineStr,
													0
													);
	self.assertTrueMsg(voyage1 &lt;&gt; null, VoyageCodeString1 &amp; " voyage not created");
	
	voyage2 := self.addVoyageWithGeneralCargoStruc(	VoyageCodeString2, 
													VesselCodeString,
													operator.code, 
													shippingLineStr,
													0
													);
	self.assertTrueMsg(voyage2 &lt;&gt; null, VoyageCodeString2 &amp; " voyage not created");
	
	voyage3 := self.addVoyageWithGeneralCargoStruc(	VoyageCodeString3, 
													VesselCodeString,
													operator.code, 
													shippingLineStr,
													0
													);
	self.assertTrueMsg(voyage3 &lt;&gt; null, VoyageCodeString3 &amp; " voyage not created");
	
	bs1 := self.addBlockStack(BS1,200,null);
	self.assertTrueMsg(bs1 &lt;&gt; null, BS1 &amp; " terminal area not created");
	
	bs2 :=self.addBlockStack(BS2,200,null);
	self.assertTrueMsg(bs2 &lt;&gt; null, BS2 &amp; " terminal area not created");
	
	cargoV1X := self.addCargoBreakBulkAtLocation(CargoV1X, bbCargoType, 100, voyage1.myShipBlockStack, null, TI_IMEX_STATUS_IMPORT, voyage2, operator);
	self.assertTrueMsg(cargoV1X.totalQuantity = 100, CargoV1X &amp; " cargo on " &amp; VoyageCodeString1 &amp; " not created");
	
	cargoV1Y := self.addCargoBreakBulkAtLocation(CargoV1Y, bbCargoType, 100, voyage1.myShipBlockStack, null, TI_IMEX_STATUS_IMPORT, voyage2, operator);
	self.assertTrueMsg(cargoV1Y.totalQuantity = 100, CargoV1Y &amp; " cargo on " &amp; VoyageCodeString1 &amp; " not created");
	
	cargoV1Z := self.addCargoBreakBulkAtLocation(CargoV1Z, bbCargoType, 100, voyage1.myShipBlockStack, null, TI_IMEX_STATUS_IMPORT, voyage2, operator);
	self.assertTrueMsg(cargoV1Z.totalQuantity = 100, CargoV1Z &amp; " cargo on " &amp; VoyageCodeString1 &amp; " not created");
	
	cargoV1B := self.addCargoBreakBulkAtLocation(CargoV1B, bbCargoType, 100, voyage1.myShipBlockStack, null, TI_IMEX_STATUS_IMPORT, voyage2, operator);
	self.assertTrueMsg(cargoV1B.totalQuantity = 100, CargoV1B &amp; " cargo on " &amp; VoyageCodeString1 &amp; " not created");
	
	cargoV2A := self.addCargoBreakBulkAtLocation(CargoV2A, bbCargoType, 100, voyage2.myShipBlockStack, null, TI_IMEX_STATUS_IMPORT, voyage2, operator);
	self.assertTrueMsg(cargoV2A.totalQuantity = 100, CargoV2A &amp; " cargo on " &amp; VoyageCodeString2 &amp; " not created");
	
	cargoV3A := self.addCargoBreakBulkAtLocation(CargoV3A, bbCargoType, 100, voyage3.myShipBlockStack, null, TI_IMEX_STATUS_IMPORT, voyage3, operator);
	self.assertTrueMsg(cargoV3A.totalQuantity = 100, CargoV3A &amp; " cargo on " &amp; VoyageCodeString3 &amp; " not created");
	
	cargoBS1Z := self.addCargoBreakBulkAtLocation(CargoBS1Z, bbCargoType, 100, bs1.myLocationsController, null, TI_IMEX_STATUS_EXPORT, voyage2, operator);
	self.assertTrueMsg(cargoBS1Z.totalQuantity = 100, CargoBS1Z &amp; " cargo in " &amp; BS1 &amp; " not created");
	
	cargoBS1C := self.addCargoBreakBulkAtLocation(CargoBS1C, bbCargoType, 100, bs1.myLocationsController, null, TI_IMEX_STATUS_EXPORT, voyage2, operator);
	self.assertTrueMsg(cargoBS1C.totalQuantity = 100, CargoBS1C &amp; " cargo in " &amp; BS1 &amp; " not created");
	
	cargoBS2C := self.addCargoBreakBulkAtLocation(CargoBS2C, bbCargoType, 100, bs2.myLocationsController, null, TI_IMEX_STATUS_EXPORT, voyage2, operator);
	self.assertTrueMsg(cargoBS2C.totalQuantity = 100, CargoBS2C &amp; " cargo in " &amp; BS2 &amp; " not created");
	
	cargoBS2D := self.addCargoBreakBulkAtLocation(CargoBS2D, bbCargoType, 100, bs2.myLocationsController, null, TI_IMEX_STATUS_EXPORT, voyage2, operator);
	self.assertTrueMsg(cargoBS2D.totalQuantity = 100, CargoBS2D &amp; " cargo in " &amp; BS2 &amp; " not created");
	
	cargoBS2E := self.addCargoBreakBulkAtLocation(CargoBS2E, bbCargoType, 50, bs2.myLocationsController, null, TI_IMEX_STATUS_EXPORT, voyage2, operator);
	self.assertTrueMsg(cargoBS2E.totalQuantity = 50, CargoBS2E &amp; " cargo in " &amp; BS2 &amp; " not created");

	//ship to barge
	movedCargo1 := self.moveBulkInSteps( cargoV1X, 2, 50, voyage2.myShipBlockStack ); 
	self.checkCombinedTrxQuantity( "movedCargo1", movedCargo1, 100, 100, 100 );
	
	//ship to 2 barges
	movedCargo2 := self.moveBulkInSteps( cargoV1Y, 2, 25, voyage2.myShipBlockStack ); 
	movedCargo3 := self.moveBulkInSteps( cargoV1Y, 2, 25, voyage3.myShipBlockStack ); 
	self.assertTrueMsg(movedCargo2 &lt;&gt; movedCargo3, movedCargo2.id &amp; " should be different tracked item to " &amp; movedCargo3.id );
	self.checkCombinedTrxQuantity( "movedCargo2", movedCargo2, 50, 50, 50 );
	self.checkCombinedTrxQuantity( "movedCargo3", movedCargo3, 50, 50, 50 );
	
	//ship to barge &amp; yard to barge
	movedCargo4 := self.moveBulkInSteps( cargoV1Z, 2, 50, voyage2.myShipBlockStack ); 
	movedCargo5 := self.moveBulkInSteps( cargoBS1Z, 2, 50, voyage2.myShipBlockStack );  // from yard, should be no receieved trx on moved cargo
	self.assertTrueMsg(movedCargo4 = movedCargo5, movedCargo4.id &amp; " should be the same tracked item as " &amp; movedCargo5.id );
	self.checkCombinedTrxQuantity( "movedCargo4", movedCargo4, 100, 200, 200 );
	
	//2 barges to ship
	movedCargo6 := self.moveBulkInSteps( cargoV2A, 2, 25, voyage1.myShipBlockStack ); 
	movedCargo7 := self.moveBulkInSteps( cargoV3A, 2, 25, voyage1.myShipBlockStack ); 
	self.assertTrueMsg(movedCargo6 = movedCargo7, movedCargo6.id &amp; " should be the same tracked item as " &amp; movedCargo7.id );
	self.checkCombinedTrxQuantity( "movedCargo6", movedCargo6, 100, 100, 100 );
	
	//ship to 2 yard positions
	movedCargo8 := self.moveBulkInSteps( cargoV1B, 2, 25, bs1.myLocationsController ); 
	movedCargo9 := self.moveBulkInSteps( cargoV1B, 2, 25, bs2.myLocationsController );
	self.assertTrueMsg(movedCargo8 &lt;&gt; movedCargo9, movedCargo8.id &amp; " should be different tracked item to " &amp; movedCargo9.id );
	self.checkCombinedTrxQuantity( "movedCargo8", movedCargo8, 50, 0, 50 );
	self.checkCombinedTrxQuantity( "movedCargo9", movedCargo9, 50, 0, 50 );
	
	//2 yard positions to barge
	movedCargo10 := self.moveBulkInSteps( cargoBS1C, 2, 25, voyage2.myShipBlockStack ); 
	movedCargo11 := self.moveBulkInSteps( cargoBS2C, 2, 25, voyage2.myShipBlockStack ); 
	self.assertTrueMsg(movedCargo10 = movedCargo11, movedCargo10.id &amp; " should be the same tracked item as " &amp; movedCargo11.id );
	self.checkCombinedTrxQuantity( "movedCargo10", movedCargo10, 0, 100, 100 );
	
	//Par 35945  Load a GC cargo item in full to voyage A, then discharge the same item to yard and load to voyage B.
	self.move( cargoBS2D, voyage2.myShipBlockStack );
	self.opts.purge();
	self.opts.addAssoc('IMEXStatus', TI_IMEX_STATUS_IMPORT);
	self.updateTI(cargoBS2D);
	self.move( cargoBS2D, bs2.myLocationsController );
	self.opts.purge();
	self.opts.addAssoc('Voyage', voyage3);
	self.opts.addAssoc('IMEXStatus', TI_IMEX_STATUS_EXPORT);
	self.updateTI(cargoBS2D);
	self.move( cargoBS2D, voyage3.myShipBlockStack );
	
	foreach tiTrx in cargoBS2D.allTransactions do
		if tiTrx.isKindOf( CM_ReleaseShip ) then
			count := count + 1;
			if count = 1 then
				trx1 := tiTrx;
			elseif count = 2 then
				trx2 := tiTrx;
			endif;
		endif;
	endforeach;
	
	self.assertTrueMsg(count = 2,"Should be two Ship Release transactions for " &amp; cargoBS2D.id );
	self.assertTrueMsg(trx1 &lt;&gt; null,"First Ship Release transaction = null" );
	self.assertTrueMsg(trx1.getMyVoyage = voyage2,"First Ship Release transaction is for the wrong voyage for " &amp; cargoBS2D.id );
	self.assertTrueMsg(trx2 &lt;&gt; null,"Second Ship Release transaction = null" );
	self.assertTrueMsg(trx2.getMyVoyage = voyage3,"Second Ship Release transaction is for the wrong voyage for " &amp; cargoBS2D.id );
	
	// GC Item in yard quantity of 50.
	//Load 10 to location on voyage. Load another 10 to the same location on voyage. Discharge 10 of the onship cargo item back to the yard.
	movedCargo12 := self.moveBulkInSteps( cargoBS2E, 2, 10, voyage2.myShipBlockStack );
	self.opts.purge();
	self.opts.addAssoc('IMEXStatus', TI_IMEX_STATUS_IMPORT);
	self.updateTI(movedCargo12);
	movedCargo13 := self.moveBulkInSteps( movedCargo12, 1, 10, bs2.myLocationsController );
	
	
	
//	process.debug;

epilog
	
	app.isGarbageCollectionProcess := false;
	
	delete tiArray;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tCargoDiscrepancyTransOnShip" id="455b0e30-c7f5-414a-999c-a02844c15247">
        <source>tCargoDiscrepancyTransOnShip();
/*

Purpose:			
		This UT tests the update of ONSHIP TI using discrepancy creates a CM_ShipDescrepancy transaction		
Parameters:			

Return Value:		

Date		Who		Reason
03 Apr 2023	navkc1	Initial creation CR# 56430  Task 56436: Jade - Unit Tests
17 May 2023	jlika1	TFS 56398 EUP - OUT - Overlanded Cargo Handling - Web

*/

constants
	VoyageID 	= "UT56436_VOY";
	VesselID 	= "56436_VSL";
	CargoID 	= "56436CARGO";
	CargoTypeID = "UT56436_BB";
vars

	operator	: CM_Operator;
	voyage		: CM_Voyage;
	vessel		: CM_Vessel;
	cargoType 	: CM_CargoType;
	shippingLine: String;
	lc			: CM_LocationsController;
	height		: Integer;
	cargoOnShip : CM_TrackedItem;
begin

	operator 		:= self.getOperator((self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	shippingLine 	:= self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString();
	cargoType 		:= self.addCargoType(CargoTypeID, false);
	
	// Create Vesse; and Voyage
	vessel := self.addVesselWithHolds(VesselID, 2, 2);
	voyage := self.addVoyageWithGeneralCargoStruc(VoyageID, vessel.name, vessel.myOperator.code, shippingLine, 0);
	
	self.getTerminal.findLocationFromString(VoyageID, true, lc, height); 
	
	// Create Cargo and put it on ship
	cargoOnShip := self.addCargoBreakBulkAtLocation(CargoID, cargoType, 50, lc, null, TI_IMEX_STATUS_IMPORT, voyage, vessel.myOperator);
	self.opts.purge();
	self.opts.addAssoc("TotalWeight", 500);
	self.updateTI(cargoOnShip);
	
	// Do the discrepancy
	// Expecting the discrepancy transaction created to be "CM_ShipDescrepancy" because the TI is onShip;
	app.myTrxUA.trxBreakBulkOverage(cargoOnShip, null, 45, 450, 400, 50, "UT56436_ONSHPDISC", true, false, false, app.myPassport);
	if app.myPassport.hasErrorsOrWarnings() then
		app.myPassport.warningsAcknowledged	:= true;
		app.myTrxUA.trxBreakBulkOverage(cargoOnShip, null, 45, 450, 400, 50, "UT56436_ONSHPDISC", true, false, false, app.myPassport);
	endif;
	
	self.assertTrue(cargoOnShip.hasTransactionOfType(TRANS_TYPE_DISCREPANCY_SHIP));
	
	// Clean up
	self.deleteTrackedItem(cargoOnShip, false);
	self.deleteCargoType(CargoTypeID);
	self.deleteVoyage(VoyageID);
	self.deleteVessel(VesselID);
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="tCargoOverlandedTransaction" id="a4ffeea0-2b5d-460d-8867-a438ca6d0c03">
        <source>tCargoOverlandedTransaction();
/*

Purpose:			
		This UT tests the creation of new cargo creates an OVerlanded transaction when "CMIF_PreNote::attributeisOverlanded" is TRUE;
Parameters:			

Return Value:		

Date		Who		Reason
30 March 2023	navkc1	Initial creation CR# 56430  Task 56436: Jade - Unit Tests

*/
constants
	CargoTypeID = "UT56436_BB";
	PreNoteID	= "UT56436_PRENOTE";
vars
	cargoType 	: CM_CargoType;
	operator	: CM_Operator;
	actualTi	: CM_TrackedItem;
	
begin
	
	// First do the clean up
	actualTi := self.getTrackedItem(PreNoteID);
	self.deleteTrackedItem(actualTi, false);
	self.assertNull(actualTi);
	
	// Set up
	cargoType := self.addCargoType(CargoTypeID, false);
	self.assertNotNull(cargoType);
	
	operator := self.getOperator((self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	
	self.opts.purge();

	self.opts.addAssoc("CargoType", cargoType.id);
	self.opts.addAssoc(UTTI_IMEX, TI_IMEX_STATUS_STORAGE);
	self.opts.addAssoc("OperatorCode", operator.code);
	self.opts.addAssoc("TotalQuantity", 1);
	self.opts.addAssoc("TareWeight", 1000);
	self.opts.addAssoc("CargoWeight", 100);
	self.opts.addAssoc("TotalWeight", 1100);
	// Overlanded to True, expecting the TrackedItem has a Overlanded transaction created
	self.opts.addAssoc("IsOverlanded", true);
	
	actualTi := self.addPrenoted(PreNoteID);
	self.assertNotNull(actualTi);
	// Test Overlanded transaction created
	self.assertTrue(actualTi.hasTransactionOfType(TRANS_TYPE_OVERLANDED));
	
	self.deleteTrackedItem(actualTi, false);
	
	// Overlanded to False, NOT expecting Overlanded transaction created
	self.opts.addAssoc("IsOverlanded", false);
	actualTi := self.addPrenoted(PreNoteID);
	self.assertNotNull(actualTi);
	// Test Overlanded transaction NOT created
	self.assertFalse(actualTi.hasTransactionOfType(TRANS_TYPE_OVERLANDED));
	
	// Clean up
	self.deleteTrackedItem(actualTi, false);
	self.deleteCargoType(CargoTypeID);
epilog
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tCargoShortlandedTransaction" id="29fc4ecf-db59-4ff0-b87b-911549458fe4">
        <source>tCargoShortlandedTransaction();
/*

Purpose:			
		This UT tests the update of TI using discrepancy creates a Shortlanded transaction
			AND
		If Terminal Config "State for Zero Weight/Quantity Shortlanded" is KeepAsIs, TI's Site and State should not get changed;
Parameters:			

Return Value:		

Date		Who		Reason
30 Mar 2023	navkc1	Initial creation CR# 56430  Task 56436: Jade - Unit Tests
17 May 2023	jlika1	TFS 56398 EUP - OUT - Overlanded Cargo Handling - Web

*/
constants
	TrainInCode 	: String = "TR_56436";
	WagonInCode 	: String = "W_56436";
	WagonClassCode 	: String = "UTMH1";
	RailAreaId 		: String = "KC56436";
	CargoID 		: String = "BB_56436";
	CargoID2 		: String = "BB_56436_2";
	CargoTypeID 	: String = "UT56436_BB";
	BlockStackID	: String = "BS_56436";

vars
	term 		: CM_Terminal;
	cargoType 	: CM_CargoType;
	pxyTI,
	pxyTI2,
	ti,
	ti2			: CM_TrackedItem;
	wagonMaster	: CM_WagonMaster;
	wagonClass	: CM_WagonClass;
	operator	: CM_Operator;
	train		: CM_Train;
	railArea	: CM_Rail;
	wagon		: CM_Wagon;
	wagonCont	: CM_WagonController;
	railLine	: CM_RailLine;
	wle			: CM_WorkListEntry;
	blockStack	: CM_BlockStack;
	
begin
	term 		:= self.getTerminal();
	cargoType 	:= self.addCargoType(CargoTypeID, false);
	wagonClass 	:= app.myRoot.allWagonClasses.getAtKey( WagonClassCode );
	operator 	:= self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	
	// First do clean up
	ti 			:= self.getTrackedItem(CargoID);
	self.deleteTrackedItem(ti, false);
	
	wagonMaster := self.getRoot.allWagonMasters[ WagonInCode ];
	if wagonMaster &lt;&gt; null then
		self.deleteWagonMasterAndWagons( wagonMaster );
	endif;
	
	self.deleteTrain( TrainInCode, null );
	self.deleteRailArea( RailAreaId );
	self.deleteTerminalArea(BlockStackID);
	
	// Now set up data
	train := self.addTrain(TrainInCode,null);
	self.assertTrueMsg( train &lt;&gt; null, "Train not created during set up!");
	
	railArea := self.addRailArea(RailAreaId, 2, 5);
	self.assertTrueMsg( railArea &lt;&gt; null, "Rail Area not created during set up!");
	
	wagon := self.addWagonInRailArea(WagonInCode, WagonClassCode, railArea, train);
	blockStack := self.addBlockStack(BlockStackID, 10, null);
	
	// Tracked Item 1
	pxyTI := app.myPassport.myTerminal.createTI(cargoType, true);
	pxyTI.setPxyFromDefaultTI( app.myPassport.myTerminal, cargoType.id, CargoID, null, operator );
	pxyTI.zSetPxyImexStatus( TI_IMEX_STATUS_STORAGE );
	pxyTI.setReceiptTransportMode( TI_TRANSMODE_RAIL );
	pxyTI.setWagon( wagon.id, wagon, wagon.myWagonClass, false );
	pxyTI.setTotalQuantity( 50 );
	pxyTI.setTotalWeight( 5000, null, app.myPassport );
	app.myTrxCA.trxCreateTrackedItem( pxyTI, ti, app.myPassport );
	self.assertTrueMsg(app.myPassport.allErrorWarnings.isEmpty(), "Errors creating pre-note&gt;&gt;&gt; " &amp; app.myPassport.getAllErrorsWarningsAsString());
	
	// Tracked Item 2
	pxyTI2 := app.myPassport.myTerminal.createTI(cargoType, true);
	pxyTI2.setPxyFromDefaultTI( app.myPassport.myTerminal, cargoType.id, CargoID2, null, operator );
	pxyTI2.zSetPxyImexStatus( TI_IMEX_STATUS_STORAGE );
	pxyTI2.setReceiptTransportMode( TI_TRANSMODE_RAIL );
	pxyTI2.setWagon( wagon.id, wagon, wagon.myWagonClass, false );
	pxyTI2.setTotalQuantity( 10 );
	pxyTI2.setTotalWeight( 1000, null, app.myPassport );
	app.myTrxCA.trxCreateTrackedItem( pxyTI2, ti2, app.myPassport );
	self.assertTrueMsg(app.myPassport.allErrorWarnings.isEmpty(), "Errors creating pre-note 2&gt;&gt;&gt; " &amp; app.myPassport.getAllErrorsWarningsAsString());
	
	// Move TIs to Wagon
	wagonCont := wagon.allLocationsControllersArray[1];
	self.moveTiToWagon(ti, wagonCont);
	self.moveTiToWagon(ti2, wagonCont);
	self.assertTrueMsg(app.myPassport.allErrorWarnings.isEmpty(), "Errors in move Ti to Wagon&gt;&gt;&gt; " &amp; app.myPassport.getAllErrorsWarningsAsString());
	
	// Confirm Wagon in
	railLine := railArea.allRailLinesByIndex.first;
	railLine.switchPositions(wagon, 01);	
	self.assertTrueMsg(app.myPassport.allErrorWarnings.isEmpty(), "Wagon set rail position Errors &gt;&gt;&gt; " &amp; app.myPassport.getAllErrorsWarningsAsString());
	
	app.myTrxUA.trxUpdateWagonConfirmTrain(null, true, train, true, app.myPassport);
	self.assertTrueMsg(app.myPassport.allErrorWarnings.isEmpty(), "Train Confirm IN Errors &gt;&gt;&gt; " &amp; app.myPassport.getAllErrorsWarningsAsString());
	
	// Move Track Items to Terminal Area;
	wle := ti.allWorklistEntries.first();
	self.opts.purge();
	self.opts.addAssoc("SetWorkListEntry", wle );
	self.moveBreakBulk(ti, blockStack.myLocationsController, 50);
	
	wle := ti2.allWorklistEntries.first();
	self.opts.purge();
	self.opts.addAssoc("SetWorkListEntry", wle );
	self.moveBreakBulk(ti2, blockStack.myLocationsController, 50);
	
	self.setTerminalConfig(StateShortlandZeroQtyWgt, CMIF_ConfigTerminal.State_Merged);
	
	// Tracked Item 1 do discrepancy, set Shortlanded to TRUE. 
	// Expecting Site to be UNDEFINED and State to be MERGED
	app.myTrxUA.trxBreakBulkOverage(ti, null, 0, 0, 0, 0, "UT56436_SHORTLAND", true, false, false, app.myPassport);

	if app.myPassport.hasErrorsOrWarnings() then
		app.myPassport.warningsAcknowledged	:= true;
		app.myTrxUA.trxBreakBulkOverage(ti, null, 0, 0, 0, 0, "UT56436_SHORTLAND", true, false, false, app.myPassport);
	endif;
	
	self.assertTrue(ti.totalQuantity = 0);
	self.assertTrue(ti.weight = 0);
	self.assertTrue(ti.totalWeight = 0);
	self.assertTrue(ti.site = TI_SITE_UNDEFINED);
	self.assertTrue(ti.state = TI_STATE_MERGED);
	self.assertTrue(ti.hasTransactionOfType(TRANS_TYPE_SHORTLANDED));
	
	self.setTerminalConfig(StateShortlandZeroQtyWgt, CMIF_ConfigTerminal.State_KeepAsIs);
	
	// Tracked Item 2 do discrepancy, set Shortlanded to TRUE
	// Expecting Site to be ONSITE and State to be NORMAL
	app.myTrxUA.trxBreakBulkOverage(ti2, null, 0, 0, 0, 0, "UT56436_KEEPASIS", true, false, false, app.myPassport);
	if app.myPassport.hasErrorsOrWarnings() then
		app.myPassport.warningsAcknowledged	:= true;
		app.myTrxUA.trxBreakBulkOverage(ti2, null, 0, 0, 0, 0, "UT56436_KEEPASIS", true, false, false, app.myPassport);
	endif;
	
	self.assertTrue(ti2.totalQuantity = 0);
	self.assertTrue(ti2.weight = 0);
	self.assertTrue(ti2.totalWeight = 0);
	self.assertTrue(ti2.site = TI_SITE_ONSITE);
	self.assertTrue(ti2.state = TI_STATE_NORMAL);
	self.assertTrue(ti2.hasTransactionOfType(TRANS_TYPE_SHORTLANDED));
	
	// Clean up
	self.deleteTrackedItem(ti, false);
	self.deleteTrackedItem(ti2, false);
	self.deleteCargoType(CargoTypeID);
	wagonMaster := self.getRoot.allWagonMasters[ WagonInCode ];
	if wagonMaster &lt;&gt; null then
		self.deleteWagonMasterAndWagons( wagonMaster );
	endif;
	self.deleteTrain( TrainInCode, null );
	self.deleteRailArea( RailAreaId );
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="tExportConsignRebar" id="5c8b6b6e-21e3-4e44-9034-25389ed9e216">
        <updating/>
        <source>tExportConsignRebar() updating;

/*

Purpose:		

Date			Who		Reason
22/07/2014		cnwmh5	Initial creation
17/08/2016 		cnwrh7		TFS	2501

*/

constants

	VesselId				: String = "MESDIAM";
	VoyageId				: String = "UTREB101";

vars

	cargoType				: CM_CargoType;
	booking					: CM_BookingRef;
	operator				: CM_Operator;
	voyage					: CM_Voyage;
	ti						: CM_TrackedItem;
	vvr 					: CM_VehicleVisitRecord;
	bs						: CM_BlockStack;
	fork1	 				: CM_Machine;
	fork2					: CM_Machine;
	ya						: CM_YardAllocation;
	gate					: CM_Gate;
	gateArea				: CM_GateArea;
	queue					: CM_RadioTelemetryQueue;
	task					: CM_RTQueueTask;
	entry					: CM_RTQueueEntry;
	tas 					: StringArray;
	removeVisibleQueueEntry	: StringArray;
	vesselName 				: String ; 
	vessel 					: CM_Vessel;	 
	wpC 					: CM_WorkPoint ; 
	voyageDeck 				: CM_DeckVoyage;
	gcDischargePort 		: CM_Port;
	trade 					: CM_Trade ; 
	pxyRTDevice				: CM_RTDeviceVehicleMount;
	rtDevice				: CM_RTDeviceVehicleMount;
	terminal : CM_Terminal;
	taType : CM_TerminalAreaType;
	machineRule		: CM_RTQueueMultiRule;
begin

	terminal := self.getMyTerminal();
/*	beginTransaction;
	terminal.setConfig(AutoPlanGenerateSwapJob, true);
	terminal.setConfig(AutoPlanGenerateSwapForYardInt, true);
	commitTransaction;*/
	
	self.disableAllYA(true);
	
	operator := app.myRoot.allOperators[self.getProfileSetting(UT_Profile.P_OPERATOR).asString].CM_Operator;
	self.assertNotNull(operator);

	bs := self.addBlockStack("UTBSDB1", 300, null);
	self.assertNotNull(bs);
	
	self.opts.purge();
	self.opts.addAssoc("AllowDuplicateId", true);
	cargoType := self.addCargoType("UTREBAR101", false);
	self.assertNotNull(cargoType);
	
	self.deleteYA("UT_DBREB101");
	ya := self.addYA1("UT_DBREB101", YACriteriaType_CargoType, cargoType, bs.allLocationsControllers.first);
	self.assertNotNull(ya);
	
	// 21/105/2015 cnwmh5 - Start
	fork1 := self.getMachine("UTDT1");
	if fork1 &lt;&gt; null then
		rtDevice := fork1.myRTDevice;
		self.assertNotNull(rtDevice);
		beginLoad;
		create pxyRTDevice transient;
		pxyRTDevice := rtDevice.pxyCreateUpdateProxy();
		if pxyRTDevice &lt;&gt; null then
			pxyRTDevice.setProxyRTDevice(rtDevice.id, rtDevice.myRadioTelemetry, rtDevice.model, "CNWMH5B", 
				rtDevice.useSerialConnection, rtDevice.useLocalTCPConnection, rtDevice.cameraType, rtDevice.myLabelPrinter);		// +17/08/2016 cnwrh7	TFS	2501
			app.myTrxUA.trxUpdateRTDevice(pxyRTDevice, app.myPassport);
			self.assertNoTrxErrorsOrWarnings();
			self.assertEqual(self.getMachine("UTD1").myRTDevice.computerName, "CNWMH5B");
		endif;
		endLoad;
	endif;
	// 21/105/2015 cnwmh5 - End
	
	self.deleteMachine("UTD1");
	self.deleteMachine("UTD2");
	self.deleteRTDevice("94");
	self.deleteRTDevice("95");
	
	gate := self.getGate(self.getProfileSetting(UT_Profile.P_DGATE).asString);
	self.assertNotNull(gate);
	gateArea := gate.getFirstAGate_IN();
	self.assertNotNull(gateArea);
	
	taType := self.getRoot.allTerminalAreaTypes[TA_TYPE_GATE_ROAD];
	// delete old rule first
	machineRule := self.getTerminal.allRTQueueMultiRuleTATypes[taType, bs.myType];
	if machineRule &lt;&gt; null then
		beginTransaction;
			delete machineRule;
		commitTransaction;
	endif;
	// create machine(s)
	create tas transient;
	tas.add(bs.id);
	tas.add(gateArea.id);
	tas.add(self.getTerminalArea("D_IC").id);
	tas.add(self.getTerminalArea("P_IN").id);
	tas.add(self.getTerminalArea("P_OUT").id);
	tas.add(self.getTerminalArea("UTBOISE").id);
	create removeVisibleQueueEntry transient;
	removeVisibleQueueEntry.add("labRestrictSource");
	removeVisibleQueueEntry.add("labRestrictSourceText");
	removeVisibleQueueEntry.add("labRestrictTarget");
	removeVisibleQueueEntry.add("labRestrictTargetText");
	removeVisibleQueueEntry.add("overlappingSource");
	removeVisibleQueueEntry.add("overlappingSourceText");
	removeVisibleQueueEntry.add("overlappingTarget");
	removeVisibleQueueEntry.add("overlappingTargetText");
	self.opts.purge();
	self.opts.addAssoc("RemoveVisibleQueueEntry", removeVisibleQueueEntry);
	self.opts.addAssoc("MachineLiftType", TWIN_LIFT);
	fork1 := self.addForkLift ("UTD1", 94, tas, "D_IC");
	assertNotNull(fork1);
	fork2 := self.addForkLift ("UTD2", 95, tas, "D_IC");
	assertNotNull(fork2);
	
	//CREATE VESSEL
	vesselName:="UT_REBVES1";
	self.deleteVoyage(VoyageId);
	self.deleteVessel(vesselName);
	self.assertNull(self.getVessel(vesselName)); //CHECKS is deleted

	vessel:=self.xCreateROROVesselStructure(vesselName);
	
	voyage := self.addVoyageWithConRORO(VoyageId, vesselName, operator.code, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString, 
		self.getProfileSetting(UT_Profile.P_TRADE).asString, 0, false, true);
	self.assertNotNull(voyage);
	
	self.deleteBooking(BOOKINGREF &amp; "RBAR101");
	booking := self.addBookingForGeneralCargo(BOOKINGREF &amp; "RBAR101", operator, voyage, "NZAKL", cargoType.id, 500);
	self.assertNotNull(booking);
	
	ti := self.getTrackedItem("UTREBAR101A");
	
	self.deleteTrackedItem(ti, false);
	self.opts.purge();
	self.opts.addAssoc("CargoType", cargoType.id);
	self.opts.addAssoc("BookingItem", booking.allBookingRefItems.first);
	ti := self.addPrenoted("UTREBAR101A");
	self.assertNotNull(ti);
	
	self.opts.purge();
	self.opts.addAssoc("TotalQuantity", 500);
	self.updateTI(ti);
	self.assertEqual(ti.totalQuantity, 500);
	
	self.opts.purge();
	self.opts.addAssoc("BookingItem", booking.allBookingRefItems.first);
	self.opts.addAssoc("IMEX", TI_IMEX_STATUS_EXPORT);
	self.opts.addAssoc("DischargePort", "NZAKL");
	self.deleteVehicle("UTDB1");
	vvr := self.gateInGC("UTDB1", null, "UTDB1", ti.id, cargoType.description, operator.code, null, gate, 250);
	
	self.assertNotNull(vvr);
	self.assertNotNull(vvr.myRoadJob.allEntries.first);
	write vvr.myRoadJob.allEntries.first.queueId;
	
	queue := self.getQueue("D_IC");
	self.assertNotNull(queue);
	
	self.machineAssignToQueue(fork1, queue);
	self.machineAssignToQueue(fork2, queue);
	
	app.isRTApp := true;
	//self.moveQueued(ti, bs);
	
	self.machineLogon(fork1);
	self.machineLogon(fork2);
	task := queue.allEntries.last.allTasks.first;
	self.assertNotNull(task);	
	entry := task.myEntry;
	self.assertNotNull(entry);
	
	self.opts.purge();
	self.opts.addAssoc("QUANTITY", 50);
	self.machineAcceptSpecifiedTwinTask(fork1, entry, null);
	self.machinePickup(fork1);
	self.machineSetdown(fork1, ti, bs.id);
	
	self.opts.purge();
	self.opts.addAssoc("QUANTITY", 50);
	self.machineAcceptSpecifiedTwinTask(fork2, entry, null);
	self.machinePickup(fork2);
	self.machineSetdown(fork2, ti, bs.id);
	
	self.opts.purge();
	self.opts.addAssoc("QUANTITY", 50);
	self.machineAcceptSpecifiedTwinTask(fork1, entry, null);
	self.machinePickup(fork1);
	self.machineSetdown(fork1, ti, bs.id);
	
	self.opts.purge();
	self.opts.addAssoc("QUANTITY", 50);
	self.machineAcceptSpecifiedTwinTask(fork2, entry, null);
	self.machinePickup(fork2);
	self.machineSetdown(fork2, ti, bs.id);
	
	self.opts.purge();
	self.opts.addAssoc("QUANTITY", 25);
	self.machineAcceptSpecifiedTwinTask(fork1, entry, null);
	self.machinePickup(fork1);
	self.machineSetdown(fork1, ti, bs.id);
	
	self.opts.purge();
	self.opts.addAssoc("QUANTITY", 25);
	self.machineAcceptSpecifiedTwinTask(fork2, entry, null);
	self.machinePickup(fork2);
	self.machineSetdown(fork2, ti, bs.id);
	//gate in another 250
	self.opts.purge();
	self.opts.addAssoc("BookingItem", booking.allBookingRefItems.first);
	self.opts.addAssoc("IMEX", TI_IMEX_STATUS_EXPORT);
	self.opts.addAssoc("DischargePort", "NZAKL");
	self.deleteVehicle("UTDB3");
	vvr := self.gateInGC("UTDB3", null, "UTDB3", ti.id, cargoType.description, operator.code, null, gate, 250);
	
	task := queue.allEntries.last.allTasks.first;
	self.assertNotNull(task);	
	entry := task.myEntry;
	self.assertNotNull(entry);
	
	self.opts.purge();
	self.opts.addAssoc("QUANTITY", 25);
	self.machineAcceptSpecifiedTwinTask(fork1, entry, null);
	self.machinePickup(fork1);
	self.machineSetdown(fork1, ti, bs.id);
	
	self.opts.purge();
	self.opts.addAssoc("QUANTITY", 25);
	self.machineAcceptSpecifiedTwinTask(fork2, entry, null);
	self.machinePickup(fork2);
	self.machineSetdown(fork2, ti, bs.id);
	
	self.opts.purge();
	self.opts.addAssoc("QUANTITY", 75);
	self.machineAcceptSpecifiedTwinTask(fork1, entry, null);
	self.machinePickup(fork1);
	self.machineSetdown(fork1, ti, bs.id);
	
	self.opts.purge();
	self.opts.addAssoc("QUANTITY", 75);
	self.machineAcceptSpecifiedTwinTask(fork2, entry, null);
	self.machinePickup(fork2);
	self.machineSetdown(fork2, ti, bs.id);
	
	self.opts.purge();
	self.opts.addAssoc("QUANTITY", 25);
	self.machineAcceptSpecifiedTwinTask(fork1, entry, null);
	self.machinePickup(fork1);
	self.machineSetdown(fork1, ti, bs.id);
	
	self.opts.purge();
	self.opts.addAssoc("QUANTITY", 25);
	self.machineAcceptSpecifiedTwinTask(fork2, entry, null);
	self.machinePickup(fork2);
	self.machineSetdown(fork2, ti, bs.id);
	 
	self.machineLogOff(fork2);
	self.machineLogOff(fork1);
	
	//voyage
	//setup load details
	self.opts.purge();
	self.opts.addAssoc("Voyage", voyage);
	wpC := self.addWorkPoint("WPC", true);
		self.assertNotNull(wpC) ; 
	voyageDeck:=voyage.myROROStructure.allDecks.first;
		self.assertNotNull(voyageDeck) ; 
		
	trade:= app.myRoot.allTradesByDescription["Doug World"];
		self.assertNotNull(trade) ; 
	gcDischargePort :=  trade.allPortRotations.first.myPort;
		self.assertNotNull(gcDischargePort) ; 
		
	self.opts.purge() ; 
	self.opts.addAssoc("myTi",ti) ; 
	self.opts.addAssoc("PlanCargo",bs);
	self.opts.addAssoc("TotalQuantity",250) ; 
	self.createGCLoadJobForRORO(voyage, wpC, voyageDeck, 20, -10, gcDischargePort.code, cargoType, operator,"REBAR", 10, 10, bs, null);
	self.assertNoTrxErrorsOrWarnings()  ;
	
epilog

	app.isRTApp := false;
	self.disableAllYA(false);

	delete tas;
	delete removeVisibleQueueEntry;
	delete pxyRTDevice;
	
end;</source>
        <text>&lt;?xml version="1.0"?&gt;
&lt;UT_Additional&gt;
  &lt;Categories&gt;
    &lt;Category CanDelete="true"&gt;WorkPointDeleteIssue&lt;/Category&gt;
  &lt;/Categories&gt;
&lt;/UT_Additional&gt;</text>
    </JadeMethod>
    <JadeMethod name="tMultiSplitForBarges" id="a899ec3f-9197-4ffe-8bbe-4375418addf2">
        <source>tMultiSplitForBarges();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 Jun 2020	jlgndl1	Initial creation	TFS 49401
21 May 2021	navdap1	TFS 50878 ASPA Bulk Barge Cargo Creation
*/

constants

	Vessel1 : String = "BARGE1";
	BargePrefix : String = "BARGVOY";
	BlockStack : String = "BS49401";
	BOLInNumber : String = "49401";
	BQTI : String = "BQTI000";
	BWTI : String = "BWTI000";
	BVTI : String = "BVTI000";
	Suffix1 : String = "1";
	Suffix2 : String = "2";
	Suffix3 : String = "3";
	Suffix4 : String = "4";
		
vars

	operator : CM_Operator;
	vessel : CM_Vessel;
	trade : CM_Trade;
	shipLine : CM_ShippingLine;
	eventTypes : CM_EventTypeSet;
	terminal : CM_Terminal;
	bank : CM_Bank;
	extReference : String;
	arrDateTime : TimeStamp;
	depDateTime : TimeStamp;
	dummyVoyage : CM_Voyage;
	pxyVoyage : CM_Voyage;
	voyage1 : CM_Voyage;
	voyage2 : CM_Voyage;
	voyage3 : CM_Voyage;
	voyage4 : CM_Voyage;
	now : TimeStamp;
	voyageName : String;
	testNumber : String;
	bs : CM_BlockStack;
	nullVoyage : CM_Voyage;
	bol : CM_BOLIn;
	bqTi : CM_TrackedItem;
	bwTi : CM_TrackedItem;
	bvTi : CM_TrackedItem;
	tiId : String;
	
	allTiIdsToCreate : StringArray; 
	quantityArray : IntegerArray;
	weightArray : DecimalArray;
	voyageArray : CM_VoyageArray;
	disPort : String;
	specialStow : String;
	bolStr : String;
	ti : CM_TrackedItem;
	suffixStr : String;
	suffixs : StringArray;
	index : Integer;
	vessels : CM_ObjectArray;			// TFS 50878

begin

	terminal := self.getTerminal;
	self.setTerminalConfig(BOLDuplicateCheckPeriod,true);
	nullVoyage := terminal.getNullVoyage;
	create suffixs transient;
	suffixs.add(Suffix1);
	suffixs.add(Suffix2);
	suffixs.add(Suffix3);
	suffixs.add(Suffix4);

	//cleanup
	tiId := BQTI;
	self.deleteTrackedItem( tiId, false);
	foreach suffixStr in suffixs do
		tiId := BQTI &amp; suffixStr;
		self.deleteTrackedItem( tiId, false);
	endforeach;
	tiId := BWTI;
	self.deleteTrackedItem( tiId, false);
	foreach suffixStr in suffixs do
		tiId := BWTI &amp; suffixStr;
		self.deleteTrackedItem( tiId, false);
	endforeach;
	tiId := BVTI;
	self.deleteTrackedItem( tiId, false);
	foreach suffixStr in suffixs do
		tiId := BVTI &amp; suffixStr;
		self.deleteTrackedItem( tiId, false);
	endforeach;
	
	self.deleteBOL( BOLInNumber, null );
	
	self.deleteTerminalArea( BlockStack );
	
	self.deleteVoyage(BargePrefix &amp; '1');
	self.deleteVoyage(BargePrefix &amp; '2');
	self.deleteVoyage(BargePrefix &amp; '3');
	self.deleteVoyage(BargePrefix &amp; '4');
	
	self.deleteVessel(Vessel1);

	
	//setup
	
	
	operator := app.myRoot.allOperators.getAtKey("DOUG");
	trade := app.myRoot.allTradesByDescription.getAtKey("Doug World");
	shipLine := app.myRoot.allShippingLines.getAtKey("DOUG");
	bs := self.addBlockStack( BlockStack, 30, null );
	
	self.opts.purge();
	self.opts.addAssoc("isBarge",true);
	self.opts.addAssoc("VesselTrade",trade);
	self.opts.addAssoc(ETRow_LloydsNumber,"49401");
	self.opts.addAssoc("ShippingLine",shipLine);
	self.opts.addAssoc(ETRow_CallSign,"Duggy");
	self.opts.addAssoc("YearOfBuild",2019);
	vessel := addVesselCellular( Vessel1, operator );
	
	//Use the 'Multi Barge Create' to create four barge voyages from the template barge vessel
	
	create eventTypes transient;
	
	bank := terminal.getDefaultCompanyBank();
	extReference := "ExternalRefOne";
	arrDateTime.setDate( now.date );
	arrDateTime.setTime( now.time.cnEcAddMinutes(-1) );
	depDateTime.setDate( now.date + 1 );
	depDateTime.setTime( now.time.cnEcAddMinutes(1) );
	
	create dummyVoyage transient;
	dummyVoyage.setArrivalDepartureDT( arrDateTime, depDateTime, false);
	dummyVoyage.pxySetBaseBarge( operator, shipLine, bank, extReference, vessel );
	pxyVoyage := dummyVoyage.pxyFromBargeUsingVesselAndCode( vessel, BargePrefix &amp; "1", terminal );
	delete dummyVoyage;
	
	create vessels transient;		// TFS 50878
	
	while true do
		// TFS 50878 add base vessel to array 4 times (creating 4 vyages, all with same vessel)
		vessels.clear;
		vessels.add(vessel);
		vessels.add(vessel);
		vessels.add(vessel);
		vessels.add(vessel);
		// TFS 50878 end
	
		//app.myTrxCA.trxCreateBarges( pxyVoyage, eventTypes, BargePrefix, 4, 1, app.myPassport );				// TFS 50878
		app.myTrxCA.trxCreateBarges( pxyVoyage, eventTypes, BargePrefix, 4, 1, null, vessels, app.myPassport );	// TFS 50878
		if app.myPassport.trxCompletedOK then
			break;	
		elseif not app.myPassport.hasErrors then
			app.myPassport.warningsAcknowledged	:= true;
			continue;
		endif;
		break;
	endwhile;
	delete pxyVoyage;
	
	voyageName := BargePrefix &amp; '1';
	voyage1 := self.getVoyage( voyageName );
	testNumber := " (Pre Test setup)";
	self.assertTrueMsg( voyage1 &lt;&gt; null, voyageName  &amp; " Voyage not found" &amp; testNumber &amp; " : " &amp; app.myPassport.getErrorsAndWarningsAsString);
	
	voyage2 := self.getVoyage( BargePrefix &amp; '2' );
	voyage3 := self.getVoyage( BargePrefix &amp; '3' );
	voyage4 := self.getVoyage( BargePrefix &amp; '4' );
	
	//add a BOL and Cargo 
	bol := self.addBolBasic( BOLInNumber, nullVoyage );
	
	bqTi := self.addCargoAtLocation( BQTI, "UTBYQ", operator, bs.myLocationsController );
	self.assertTrueMsg( bqTi &lt;&gt; null, BQTI &amp; " not created" &amp; testNumber &amp; " : " &amp; app.myPassport.getErrorsAndWarningsAsString);
	self.opts.purge();
	self.opts.addAssoc("TotalQuantity",1000);
	self.opts.addAssoc("TotalWeight",1000);
	self.opts.addAssoc("BolNumber",BOLInNumber);
	self.updateTI(bqTi);
	
	bwTi := self.addCargoAtLocation( BWTI, "UTBYW", operator, bs.myLocationsController );
	self.assertTrueMsg( bwTi &lt;&gt; null, BWTI &amp; " not created" &amp; testNumber &amp; " : " &amp; app.myPassport.getErrorsAndWarningsAsString);
	self.opts.purge();
	self.opts.addAssoc("TotalWeight",1000);
	self.opts.addAssoc("BolNumber",BOLInNumber);
	self.updateTI(bwTi);
	
	bvTi := self.addCargoAtLocation( BVTI, "UTBYV", operator, bs.myLocationsController );
	self.assertTrueMsg( bvTi &lt;&gt; null, BVTI &amp; " not created" &amp; testNumber &amp; " : " &amp; app.myPassport.getErrorsAndWarningsAsString);
	self.opts.purge();
	self.opts.addAssoc("TotalVolume",1000);
	self.opts.addAssoc("TotalWeight",1000);
	self.opts.addAssoc("BolNumber",BOLInNumber);
	self.updateTI(bvTi);
	
	//start tests
	create allTiIdsToCreate transient; 
	create quantityArray transient;
	create weightArray transient;
	create voyageArray transient;
	
	//split BulkByQuantity
	testNumber := " (Test 1)";
	
	disPort := trade.allPortRotations.first.myPort.code;
	specialStow := "ARROW";
	bolStr := BOLInNumber;
	
	allTiIdsToCreate.clear(); quantityArray.clear(); weightArray.clear(); voyageArray.clear();
	allTiIdsToCreate.add( bqTi.id &amp; Suffix1); quantityArray.add(75); /*weightArray.add();*/ voyageArray.add( voyage1 );
	allTiIdsToCreate.add( bqTi.id &amp; Suffix2); quantityArray.add(60); /*weightArray.add();*/ voyageArray.add( voyage2 );
	allTiIdsToCreate.add( bqTi.id &amp; Suffix3); quantityArray.add(45); /*weightArray.add();*/ voyageArray.add( voyage3 );
	allTiIdsToCreate.add( bqTi.id &amp; Suffix4); quantityArray.add(30); /*weightArray.add();*/ voyageArray.add( voyage4 );
	
	app.myTrxUA.trxMultiCargoSplit(	bqTi.CM_Cargo,	//_sourceTi : CM_Cargo;
									allTiIdsToCreate,	//_allTiIdsToCreate : StringArray;
									quantityArray,	//_quantityArray : IntegerArray;
									weightArray,	// _weightArray : DecimalArray;
									voyageArray,	//_voyageArray : CM_VoyageArray;
									disPort,	//_disPort : String;
									specialStow,	//_specialStow : String;
									bolStr,	//_bol : String;
									app.myPassport	//_passport : CM_Passport input
									);
									
	self.assertTrueMsg( app.myPassport.trxCompletedOK, bqTi.id &amp; " trxMultiCargoSplit failed " &amp; testNumber &amp; " : " &amp; app.myPassport.getErrorsAndWarningsAsString );
	self.assertTrueMsg( voyage1.allBOLInByTypeStatusNumDT.getFirstWithNumber( bolStr ) &lt;&gt; null, voyage1.code &amp; " should have had a BOL created " &amp; testNumber );
	self.assertTrueMsg( voyage2.allBOLInByTypeStatusNumDT.getFirstWithNumber( bolStr ) &lt;&gt; null, voyage2.code &amp; " should have had a BOL created " &amp; testNumber );
	self.assertTrueMsg( voyage3.allBOLInByTypeStatusNumDT.getFirstWithNumber( bolStr ) &lt;&gt; null, voyage3.code &amp; " should have had a BOL created " &amp; testNumber );
	self.assertTrueMsg( voyage4.allBOLInByTypeStatusNumDT.getFirstWithNumber( bolStr ) &lt;&gt; null, voyage4.code &amp; " should have had a BOL created " &amp; testNumber );
	index := 0;
	foreach tiId in allTiIdsToCreate do
		index := index + 1;
		ti := bs.myLocationsController.allTrackedItemsById.getAtKeyGeq( tiId, null );
		self.assertTrueMsg( ti.id = tiId, tiId &amp; " not found " &amp; testNumber );
		self.assertTrueMsg( ti.dischargePort = disPort, tiId &amp; " should have had discharge Port set to " &amp; disPort &amp; testNumber );
		self.assertTrueMsg( ti.specialStow = specialStow, tiId &amp; " should have had special stow set to " &amp; specialStow &amp; testNumber );
		self.assertTrueMsg( ti.billOfLading = bolStr, tiId &amp; " should have had billOfLading set to " &amp; bolStr &amp; testNumber );
		self.assertTrueMsg( ti.myVoyage = voyageArray[index], tiId &amp; " should have voyage set to " &amp; voyageArray[index].code &amp; testNumber );
		self.assertTrueMsg( ti.totalQuantity = quantityArray[index], tiId &amp; " should have total quantity set to " &amp; quantityArray[index].String &amp; testNumber );
	endforeach;


	//split BulkByWeight
	testNumber := " (Test 2)";
	allTiIdsToCreate.clear(); quantityArray.clear(); weightArray.clear(); voyageArray.clear();
	allTiIdsToCreate.add( bwTi.id &amp; Suffix1);/* quantityArray.add(75); */ weightArray.add(77.777); voyageArray.add( voyage1 );
	allTiIdsToCreate.add( bwTi.id &amp; Suffix2);/* quantityArray.add(60); */ weightArray.add(66.666); voyageArray.add( voyage2 );
	allTiIdsToCreate.add( bwTi.id &amp; Suffix3);/* quantityArray.add(45); */ weightArray.add(55.555); voyageArray.add( voyage3 );
	allTiIdsToCreate.add( bwTi.id &amp; Suffix4);/* quantityArray.add(30); */ weightArray.add(44.444); voyageArray.add( voyage4 );
	
	app.myTrxUA.trxMultiCargoSplit(	bwTi.CM_Cargo,	//_sourceTi : CM_Cargo;
									allTiIdsToCreate,	//_allTiIdsToCreate : StringArray;
									quantityArray,	//_quantityArray : IntegerArray;
									weightArray,	// _weightArray : DecimalArray;
									voyageArray,	//_voyageArray : CM_VoyageArray;
									disPort,	//_disPort : String;
									specialStow,	//_specialStow : String;
									bolStr,	//_bol : String;
									app.myPassport	//_passport : CM_Passport input
									); 
									
	self.assertTrueMsg( app.myPassport.trxCompletedOK, bwTi.id &amp; " trxMultiCargoSplit failed " &amp; testNumber &amp; " : " &amp; app.myPassport.getErrorsAndWarningsAsString );
	self.assertTrueMsg( voyage1.allBOLInByTypeStatusNumDT.size = 1 , voyage1.code &amp; " should not have had another BOL created " &amp; testNumber );
	index := 0;
	foreach tiId in allTiIdsToCreate do
		index := index + 1;
		ti := bs.myLocationsController.allTrackedItemsById.getAtKeyGeq( tiId, null );
		self.assertTrueMsg( ti.id = tiId, tiId &amp; " not found " &amp; testNumber );
		self.assertTrueMsg( ti.dischargePort = disPort, tiId &amp; " should have had discharge Port set to " &amp; disPort &amp; testNumber );
		self.assertTrueMsg( ti.specialStow = specialStow, tiId &amp; " should have had special stow set to " &amp; specialStow &amp; testNumber );
		self.assertTrueMsg( ti.billOfLading = bolStr, tiId &amp; " should have had billOfLading set to " &amp; bolStr &amp; testNumber );
		self.assertTrueMsg( ti.myVoyage = voyageArray[index], tiId &amp; " should have voyage set to " &amp; voyageArray[index].code &amp; testNumber );
		self.assertTrueMsg( ti.totalWeight = weightArray[index], tiId &amp; " should have total weight set to " &amp; weightArray[index].String &amp; testNumber );
	endforeach;
	
	
	//split BulkByVolume
	testNumber := " (Test 3)";
	allTiIdsToCreate.clear(); quantityArray.clear(); weightArray.clear(); voyageArray.clear();
	allTiIdsToCreate.add( bvTi.id &amp; Suffix1);/* quantityArray.add(75); */ weightArray.add(2.2); voyageArray.add( voyage1 );
	allTiIdsToCreate.add( bvTi.id &amp; Suffix2);/* quantityArray.add(60); */ weightArray.add(20.02); voyageArray.add( voyage2 );
	allTiIdsToCreate.add( bvTi.id &amp; Suffix3);/* quantityArray.add(45); */ weightArray.add(18.8); voyageArray.add( voyage3 );
	allTiIdsToCreate.add( bvTi.id &amp; Suffix4);/* quantityArray.add(30); */ weightArray.add(103); voyageArray.add( voyage4 );
	
	app.myTrxUA.trxMultiCargoSplit(	bvTi.CM_Cargo,	//_sourceTi : CM_Cargo;
									allTiIdsToCreate,	//_allTiIdsToCreate : StringArray;
									quantityArray,	//_quantityArray : IntegerArray;
									weightArray,	// _weightArray : DecimalArray;
									voyageArray,	//_voyageArray : CM_VoyageArray;
									disPort,	//_disPort : String;
									specialStow,	//_specialStow : String;
									bolStr,	//_bol : String;
									app.myPassport	//_passport : CM_Passport input
									);
									
	self.assertTrueMsg( app.myPassport.trxCompletedOK, bvTi.id &amp; " trxMultiCargoSplit failed " &amp; testNumber &amp; " : " &amp; app.myPassport.getErrorsAndWarningsAsString );
	self.assertTrueMsg( voyage1.allBOLInByTypeStatusNumDT.size = 1 , voyage1.code &amp; " should not have had another BOL created " &amp; testNumber );
	index := 0;
	foreach tiId in allTiIdsToCreate do
		index := index + 1;
		ti := bs.myLocationsController.allTrackedItemsById.getAtKeyGeq( tiId, null );
		self.assertTrueMsg( ti.id = tiId, tiId &amp; " not found " &amp; testNumber );
		self.assertTrueMsg( ti.dischargePort = disPort, tiId &amp; " should have had discharge Port set to " &amp; disPort &amp; testNumber );
		self.assertTrueMsg( ti.specialStow = specialStow, tiId &amp; " should have had special stow set to " &amp; specialStow &amp; testNumber );
		self.assertTrueMsg( ti.billOfLading = bolStr, tiId &amp; " should have had billOfLading set to " &amp; bolStr &amp; testNumber );
		self.assertTrueMsg( ti.myVoyage = voyageArray[index], tiId &amp; " should have voyage set to " &amp; voyageArray[index].code &amp; testNumber );
		self.assertTrueMsg( ti.totalWeight = weightArray[index], tiId &amp; " should have total weight set to " &amp; weightArray[index].String &amp; testNumber );
	endforeach;
	
	
	//clean up, it worked.
	tiId := BQTI;
	self.deleteTrackedItem( tiId, false);
	foreach suffixStr in suffixs do
		tiId := BQTI &amp; suffixStr;
		self.deleteTrackedItem( tiId, false);
	endforeach;
	tiId := BWTI;
	self.deleteTrackedItem( tiId, false);
	foreach suffixStr in suffixs do
		tiId := BWTI &amp; suffixStr;
		self.deleteTrackedItem( tiId, false);
	endforeach;
	tiId := BVTI;
	self.deleteTrackedItem( tiId, false);
	foreach suffixStr in suffixs do
		tiId := BVTI &amp; suffixStr;
		self.deleteTrackedItem( tiId, false);
	endforeach;
	
	self.deleteBOL( BOLInNumber, null );
	
	self.deleteTerminalArea( BlockStack );
	
	self.deleteVoyage(BargePrefix &amp; '1');
	self.deleteVoyage(BargePrefix &amp; '2');
	self.deleteVoyage(BargePrefix &amp; '3');
	self.deleteVoyage(BargePrefix &amp; '4');
	
	self.deleteVessel(Vessel1);

epilog

	delete dummyVoyage;
	delete pxyVoyage;
	delete eventTypes;
	
	delete allTiIdsToCreate; 
	delete quantityArray;
	delete weightArray;
	delete voyageArray;
	delete suffixs;
	delete vessels;				// TFS 50878

end;</source>
    </JadeMethod>
    <JadeMethod name="tPackageBulk" id="ec88d84a-59ad-4706-ac1c-ef28678fd591">
        <source>tPackageBulk();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 October 2017	jlgndl1	Initial creation	TFS 5744

*/
constants

	Cargo_TypeBB : String = "UTREBAR";
	Cargo_TypeB : String = "SCRAP";
	
vars

	bbCargoType : CM_CargoType;
	bCargoType : CM_CargoType;
	bs : CM_BlockStack;
	cargo1 : CM_TrackedItem;
	cargo2 : CM_TrackedItem;
	cargo3 : CM_TrackedItem;
	oper : CM_Operator;
	
	allTiIds : StringArray;
	
	txnController : CMIF_TITransactionController;
	newTITxn : CM_TITransaction;
	term : CM_Terminal;
	
begin

	oper := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	term := self.getTerminal;

	bbCargoType := app.myRoot.getCargoTypeFromAbbrev( Cargo_TypeBB );
	self.assertTrueMsg( bbCargoType &lt;&gt; null, "No UTREBAR cargo type pre test" );
	bCargoType := app.myRoot.getCargoTypeFromAbbrev( Cargo_TypeB );
	self.assertTrueMsg( bCargoType &lt;&gt; null, "No SCRAP Cargo Type pre test" );
	
	deleteTerminalArea( "UTBS1" );
	bs := self.addBlockStack( "UTBS1", 200, null );
	self.assertTrueMsg( bs &lt;&gt; null, "No Block stack pre test" );
	
	self.deleteAllCargo( "UTPKG1", bCargoType );
	self.deleteAllCargo( "UTPKG2", bbCargoType );
	self.deleteAllCargo( "UTPKG3", bbCargoType );
	cargo1 := self.addCargoAtLocation( "UTAGG1", bCargoType, oper, bs.myLocationsController );
	
	self.assertNoTrxErrors();
	self.assertTrueMsg( cargo1 &lt;&gt; null, "No BB UTAGG1 pre test" );
	
	self.assertEqual( cargo1.myPrimaryActualLocation, bs.myLocationsController );
	
	beginTransaction;
	cargo1.setTotalQuantity(1);
//	cargo1.setMyTotalVolume(5000);
	cargo1.setTotalWeightWithoutTrans(5000);
	commitTransaction;
	
	create allTiIds transient;
	allTiIds.add("UTPKG2");
	allTiIds.add("UTPKG3");
	
	app.myTrxUA.trxPackageBulk(	cargo1.CM_Bulk,	//_sourceTi : CM_Bulk;
								allTiIds,	//_newTiIds : StringArray;
								20,	//_quantityPerId : Integer;
								100,	// _itemNettWeight : Decimal;
								bbCargoType,	//_cargoType : CargoType;
								null,	//_product : CM_Product;
								oper,	//_operator : CM_Operator;
								1,	// _pkgingWeight : Decimal;
								bs.myLocationsController,	//_lc : CM_LocationsController
								app.myPassport	//_passport : CM_Passport input
								);
	
	cargo2 := term.allOnsiteTIsByCargoTypeId.getAtKey( bbCargoType.id, "UTPKG2" );
	cargo3 := term.allOnsiteTIsByCargoTypeId.getAtKey( bbCargoType.id, "UTPKG3" );
	
	self.assertTrueMsg( cargo2 &lt;&gt; null, "UTPKG2 not created : " &amp; app.myPassport.getErrorsAndWarningsAsString );
	self.assertTrueMsg( cargo3 &lt;&gt; null, "UTPKG3 not created : " &amp; app.myPassport.getErrorsAndWarningsAsString );	
		
	self.assertTrueMsg( cargo1.getLastTransOfClass(CM_Packaged) &lt;&gt; null, "UTAGG1  'Packaged' transaction not created" );
	self.assertTrueMsg( cargo2.getLastTransOfClass(CM_Packaged) &lt;&gt; null, "UTPKG2  'Packaged' transaction not created" );
	self.assertTrueMsg( cargo3.getLastTransOfClass(CM_Packaged) &lt;&gt; null, "UTPKG3  'Packaged' transaction not created" );
	
	self.assertTrueMsg( cargo2.totalWeight = 2020, "UTPKG2 should weigh 2020 kg");	//18 Feb 2020	NDL	TFS 48532
	self.assertTrueMsg( cargo3.totalWeight = 2020, "UTPKG3 should weigh 2020 kg");	//18 Feb 2020	NDL	TFS 48532
	
	
	create txnController transient;
	txnController.type := TRANS_TYPE_PACKAGE_COMPLETED;
	txnController.noCharge := false; 
	txnController.myTerminal := term;
	txnController.myTrackedItem := cargo1;
	
	app.myTrxCA.trxCreateTITransaction(txnController, newTITxn, app.myPassport);
	
	self.assertTrueMsg( newTITxn &lt;&gt; null, "UTPKG1 'Packaged Complete' transaction not created : " &amp; app.myPassport.getErrorsAndWarningsAsString );	

epilog

	delete allTiIds;
	delete txnController;

end;</source>
    </JadeMethod>
    <JadeMethod name="tSTWO51141" id="9c9408ec-7965-45e5-bb5e-dae5ffb1daa0">
        <source>tSTWO51141();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 May 2021	navma1	Bug 51141: STWO - Volume Discrepancy Transaction displays Changes in Height reflect as " TEXT = NEW LENGTH instead of NEW HEIGHT"

*/
constants
	Cargo_TypeBB : String = "UTREBAR";
	CARGO1       : String = "UTREBAR51141";
vars
	
	bbCargoType : CM_CargoType;
	bs 			: CM_BlockStack;
	cargo1		: CM_TrackedItem;
	term 		: CM_Terminal;
	oper 		: CM_Operator;
	reason      : CM_VolumeDiscrepancyReason;
	trans       : CM_TITransaction;
	detail      : String;
begin
	oper := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	term := self.getTerminal;

	bbCargoType := app.myRoot.getCargoTypeFromAbbrev( Cargo_TypeBB );
	self.assertTrueMsg( bbCargoType &lt;&gt; null, "No UTREBAR cargo type pre test" );
	deleteTerminalArea( "UTBS151141" );
	bs := self.addBlockStack( "UTBS151141", 200, null );
	self.assertTrueMsg( bs &lt;&gt; null, "No Block stack pre test" );
	
	self.deleteAllCargo( CARGO1, bbCargoType );
	cargo1 := self.addCargoAtLocation( CARGO1, bbCargoType, oper, bs.myLocationsController );
	self.assertNoTrxErrors();
	self.assertTrueMsg( cargo1 &lt;&gt; null, "No BB CARGO1 pre test" );
	self.assertEqual( cargo1.myPrimaryActualLocation, bs.myLocationsController );
	
	beginTransaction;
	cargo1.setTotalQuantity(50);
	cargo1.setMyTotalVolume(5000);
	cargo1.setTotalWeightWithoutTrans(5000);
	cargo1.setTotalQuantity(50);
	cargo1.setMyTotalVolume(5000);
	cargo1.setTotalWeightWithoutTrans(5000);	
	cargo1.setLength(11);
	cargo1.setWidth(12);
	cargo1.setHeight(13);
	commitTransaction;
	reason := app.myRoot.allVolumeDiscrepancyReasons["UTVRCODE"];
	app.myTrxUA.trxVolumeDiscrepancy(true,cargo1,60,1,22,21,23,5010,5020,"Remarks1", reason, app.myPassport);
	
	trans := cargo1.getTransactionOfType(TRANS_TYPE_AUTOVOLUME); 
	self.assertTrueMsg( trans &lt;&gt; null, "No BB CARGO1 Volume Discrepancy Transaction " );
	self.assertEqual( cargo1.length,"21".Decimal );
	self.assertEqual( cargo1.width,"22".Decimal );
	self.assertEqual( cargo1.height,"23".Decimal );
	self.assertEqual( cargo1.totalQuantity,"60".Integer );
	self.assertEqual( cargo1.totalWeight,"5010".Decimal );
	self.assertEqual( cargo1.totalVolume,"5020".Decimal );
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="tShipReceiveSingleTxn" id="baae0cc9-e2e1-4956-8e1a-58034b3974fb">
        <source>tShipReceiveSingleTxn();

// cnwer1
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 October 2013	cnwdw1	Initial creation
*/
constants
vars
	vessel: CM_Vessel;
	voyage: CM_Voyage;
	bs1: CM_BlockStack;
	breakBulkCargoType, bulkCargoType : CM_CargoType;
	cargo, cargoOnSite: CM_TrackedItem;
	cargoId: String;
	lc: CM_LocationsController;
	height: Integer;
	expected, received, damaged: Integer;
	expectedWeight, receivedWeight: Decimal[14,4];
	txns: CM_TransactionSet;
begin

	vessel := self.addVesselWithHolds("UT_VHOLDS", 2, 2);
	voyage := self.addVoyageWithGeneralCargoStruc("UT_VHOLDS", vessel.name, vessel.myOperator.code,	self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 0);
	bs1 := self.addBlockStack("UTBS1", 9999, null);
	breakBulkCargoType := app.myRoot.getCargoTypeFromAbbrev("UTREBAR");
	bulkCargoType  := app.myRoot.getCargoTypeFromAbbrev("UTCOAL");
	self.getTerminal.findLocationFromString("UT_VHOLDS 0101", true, lc, height); 

	create txns transient;

	// Move break bulk cargo 
	cargoId := "UTREBAR9999A";
	deleteCargo(cargoId, breakBulkCargoType);
	cargo := self.addCargoBreakBulkAtLocation(cargoId, breakBulkCargoType, 30, lc, null, TI_IMEX_STATUS_IMPORT, voyage, vessel.myOperator);	//all transaction CM_Create; CM_Move quantity is 1;
	self.opts.addAssoc("TotalWeight", 30);
	self.updateTI(cargo);
		assertEqual(cargo.totalQuantity,30);
	self.opts.purge;

		moveBreakBulk(cargo, bs1, 15);
		cargoOnSite := getTrackedItemAtLocation(cargoId, bs1.myLocationsController);
		expected := cargoOnSite.getShipReceivalQuantity();								//by here, already got all transaction with right figures
		assertEqual(expected, 15);
		expectedWeight := cargoOnSite.getShipReceivalWeight();
		assertEqual(expectedWeight, 15.Decimal);
		received := cargoOnSite.getShipDischargeQuantity();
		assertEqual(received, 15);
		receivedWeight := cargoOnSite.getShipDischargeWeight();
		assertEqual(receivedWeight, 15.Decimal);
		txns.clear;
		self.getTiTxnsOfType(cargoOnSite, TRANS_TYPE_REC_SHIP, txns);
		assertEqual(1, txns.size);
		assertEqual(15, cargo.totalQuantity);      // no zombies ti is moved to yard
		
		delete txns;
			
		create txns transient;
	
		moveBreakBulk(cargo, bs1, 15);
		cargoOnSite := getTrackedItemAtLocation(cargoId, bs1.myLocationsController);
		expected := cargoOnSite.getShipReceivalQuantity();								//by here, already got all transaction with right figures
		assertEqual(expected, 30);
		expectedWeight := cargoOnSite.getShipReceivalWeight();
		assertEqual(expectedWeight, 30.Decimal);
		received := cargoOnSite.getShipDischargeQuantity();
		assertEqual(received, 30);
		receivedWeight := cargoOnSite.getShipDischargeWeight();
		assertEqual(receivedWeight, 30.Decimal);
		txns.clear;
		self.getTiTxnsOfType(cargoOnSite, TRANS_TYPE_REC_SHIP, txns);
		assertEqual(2, txns.size);
		assertEqual(0, cargo.totalQuantity);      // no zombies ti is moved to yard
		
	epilog
	delete txns;
end;</source>
    </JadeMethod>
    <JadeMethod name="tShipReceiveTxn" id="cdc55c5d-8241-4b42-9884-9a69bc3a6fbc">
        <source>tShipReceiveTxn();
// cnwer1
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 October 2013	cnwdw1	Initial creation
11 July 2022	navak20	TFS 53862 EUP - WMS - Damage Recording Extra Details
*/
// 25 Jul 2018	jlgrs1	TFS 38804 SNO Changes to repaired transactions
constants
vars
	vessel: CM_Vessel;
	voyage: CM_Voyage;
	bs1: CM_BlockStack;
	breakBulkCargoType, bulkCargoType : CM_CargoType;
	cargo, cargoOnSite: CM_TrackedItem;
	cargoId: String;
	lc: CM_LocationsController;
	height: Integer;
	expected, received, damaged: Integer;
	expectedWeight, receivedWeight: Decimal[14,4];
	txns: CM_TransactionSet;

begin

	vessel := self.addVesselWithHolds("UT_VHOLDS", 2, 2);
	voyage := self.addVoyageWithGeneralCargoStruc("UT_VHOLDS", vessel.name, vessel.myOperator.code,	self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 0);
	bs1 := self.addBlockStack("UTBS1", 9999, null);
	breakBulkCargoType := app.myRoot.getCargoTypeFromAbbrev("UTREBAR");
	bulkCargoType  := app.myRoot.getCargoTypeFromAbbrev("UTCOAL");
	self.getTerminal.findLocationFromString("UT_VHOLDS 0101", true, lc, height); 

	self.deleteStorageConfig( false );
	
	
	 
	
	create txns transient;

	// Move break bulk cargo 
	cargoId := "UTREBAR9999A";
	deleteCargo(cargoId, breakBulkCargoType);
	cargo := self.addCargoBreakBulkAtLocation(cargoId, breakBulkCargoType, 30, lc, null, TI_IMEX_STATUS_IMPORT, voyage, vessel.myOperator);
	self.opts.addAssoc("TotalWeight", 30);
	self.updateTI(cargo);
		assertEqual(cargo.totalQuantity, 30);
	self.opts.purge;

	moveBreakBulk(cargo, bs1, 30);
	cargoOnSite := getTrackedItemAtLocation(cargoId, bs1.myLocationsController);
		expected := cargoOnSite.getShipReceivalQuantity();
		assertEqual(expected, 30);
		expectedWeight := cargoOnSite.getShipReceivalWeight();
		assertEqual(expectedWeight, 30.Decimal);
		received := cargoOnSite.getShipDischargeQuantity();
		assertEqual(received, 30);
		receivedWeight := cargoOnSite.getShipDischargeWeight();
		assertEqual(receivedWeight, 30.Decimal);
		txns.clear;
		self.getTiTxnsOfType(cargoOnSite, TRANS_TYPE_REC_SHIP, txns);
		assertEqual(1, txns.size);
		assertEqual(30, cargo.totalQuantity);      // no zombies ti is moved to yard

	// Move break bulk cargo to existing pile in yard
	cargoId := "UTREBAR9999D";
	deleteCargo(cargoId, breakBulkCargoType);
	cargoOnSite := self.addCargoBreakBulkAtLocation(cargoId, breakBulkCargoType, 150, bs1.myLocationsController, null, TI_IMEX_STATUS_IMPORT, voyage, vessel.myOperator);
	cargo := self.addCargoBreakBulkAtLocation(cargoId, breakBulkCargoType, 50, lc, null, TI_IMEX_STATUS_IMPORT, voyage, vessel.myOperator);
	self.opts.addAssoc("TotalWeight", 50);
	self.updateTI(cargo);
		assertEqual(cargo.totalQuantity, 50);
	self.opts.purge;

	moveBreakBulk(cargo, bs1, 50);
		assertFalse(cargo = cargoOnSite);
		expected := cargoOnSite.getShipReceivalQuantity();
		assertEqual(expected, 50);
		received := cargoOnSite.getShipDischargeQuantity();
		assertEqual(received, 50);
		txns.clear;
		self.getTiTxnsOfType(cargoOnSite, TRANS_TYPE_REC_SHIP, txns);
		assertEqual(1, txns.size);
		assertEqual(0, cargo.totalQuantity);      
		assertEqual(200, cargoOnSite.totalQuantity); 

	// Move break bulk cargo to existing pile in yard using zero
	cargoId := "UTREBAR9999E";
	deleteCargo(cargoId, breakBulkCargoType);
	cargoOnSite := self.addCargoBreakBulkAtLocation(cargoId, breakBulkCargoType, 150, bs1.myLocationsController, null, TI_IMEX_STATUS_IMPORT, voyage, vessel.myOperator);
	cargo := self.addCargoBreakBulkAtLocation(cargoId, breakBulkCargoType, 50, lc, null, TI_IMEX_STATUS_IMPORT, voyage, vessel.myOperator);
	self.opts.addAssoc("TotalWeight", 50);
	self.updateTI(cargo);
		assertEqual(cargo.totalQuantity, 50);
	self.opts.purge;

	moveBreakBulk(cargo, bs1, 0);
		assertFalse(cargo = cargoOnSite);
		expected := cargoOnSite.getShipReceivalQuantity();
		assertEqual(expected, 50);
		received := cargoOnSite.getShipDischargeQuantity();
		assertEqual(received, 50);
		txns.clear;
		self.getTiTxnsOfType(cargoOnSite, TRANS_TYPE_REC_SHIP, txns);
		assertEqual(1, txns.size);
		assertEqual(0, cargo.totalQuantity);      
		assertEqual(200, cargoOnSite.totalQuantity); 

	// Move break bulk cargo using zero amount
	cargoId := "UTREBAR9999C";
	deleteCargo(cargoId, breakBulkCargoType);
	cargo := self.addCargoBreakBulkAtLocation(cargoId, breakBulkCargoType, 50, lc, null, TI_IMEX_STATUS_IMPORT, voyage, vessel.myOperator);
	self.opts.addAssoc("TotalWeight", 50);
	self.updateTI(cargo);
		assertEqual(cargo.totalQuantity, 50);
	self.opts.purge;

	moveBreakBulk(cargo, bs1, 0);
	cargoOnSite := getTrackedItemAtLocation(cargoId, bs1.myLocationsController);
		expected := cargoOnSite.getShipReceivalQuantity();
		assertEqual(expected, 50);
		received := cargoOnSite.getShipDischargeQuantity();
		assertEqual(received, 50);
		txns.clear;
		self.getTiTxnsOfType(cargoOnSite, TRANS_TYPE_REC_SHIP, txns);
		assertEqual(1, txns.size);
		assertEqual(50, cargo.totalQuantity);      // no zombies ti is moved to yard

	// Move break bulk cargo in parts
	cargoId := "UTREBAR9999B";
	deleteCargo(cargoId, breakBulkCargoType);
	cargo := self.addCargoBreakBulkAtLocation(cargoId, breakBulkCargoType, 50, lc, null, TI_IMEX_STATUS_IMPORT, voyage, vessel.myOperator);
	self.opts.addAssoc("TotalWeight", 50);
	self.updateTI(cargo);
		assertEqual(cargo.totalQuantity, 50);
	self.opts.purge;
	
	moveBreakBulk(cargo, bs1, 20);
	cargoOnSite := getTrackedItemAtLocation(cargoId, bs1.myLocationsController);
		expected := cargoOnSite.getShipReceivalQuantity();
		assertEqual(expected, 20);
		expectedWeight := cargoOnSite.getShipReceivalWeight();
		assertEqual(expectedWeight, 20.Decimal);
		received := cargoOnSite.getShipDischargeQuantity();
		assertEqual(received, 20);
		receivedWeight := cargoOnSite.getShipDischargeWeight();
		assertEqual(receivedWeight, 20.Decimal);
		
		
		
		
		
	moveBreakBulk(cargo, bs1, 25);
		expected := cargoOnSite.getShipReceivalQuantity();
		assertEqual(expected, 45);
		expectedWeight := cargoOnSite.getShipReceivalWeight();
		assertEqual(expectedWeight, 45.Decimal);
		received := cargoOnSite.getShipDischargeQuantity();
		assertEqual(received, 45);
		receivedWeight := cargoOnSite.getShipDischargeWeight();
		assertEqual(receivedWeight, 45.Decimal);
	
	moveBreakBulk(cargo, bs1, 0); // removing remaining
		expected := cargoOnSite.getShipReceivalQuantity();
		assertEqual(expected, 50);
		expectedWeight := cargoOnSite.getShipReceivalWeight();
		assertEqual(expectedWeight, 50.Decimal);
		received := cargoOnSite.getShipDischargeQuantity();
		assertEqual(received, 50);
		receivedWeight := cargoOnSite.getShipDischargeWeight();
		assertEqual(receivedWeight, 50.Decimal);
		txns.clear;
		self.getTiTxnsOfType(cargoOnSite, TRANS_TYPE_REC_SHIP, txns);
		assertEqual(3, txns.size);
		assertEqual(0, cargo.totalQuantity);
	
	addDamage(cargoOnSite, "BENT", "All", null, 1, "XXX");		// 11.07.2022 navak20 TFS 53862
	addDamage(cargoOnSite, "BENT", "All", null, 2, "XXX");		// 11.07.2022 navak20 TFS 53862
	damaged := cargoOnSite.getDamageQuantity();
		assertEqual(damaged, 3);
	
	// Move Bulk cargo
	cargoId := "UTCOAL9999A";
	deleteCargo(cargoId, breakBulkCargoType);
	cargo := self.addCargoBulkAtLocation(cargoId, bulkCargoType, 100, lc, null, TI_IMEX_STATUS_IMPORT, voyage, vessel.myOperator, null);
		assertEqual(cargo.totalWeight, 100.Decimal);

	moveBulk(cargo, bs1, 100);
	cargoOnSite := getTrackedItemAtLocation(cargoId, bs1.myLocationsController);
		assertTrue(cargoOnSite = cargo);
		expectedWeight := cargoOnSite.getShipReceivalWeight();
		assertEqual(expectedWeight, 100.Decimal);
		receivedWeight := cargoOnSite.getShipDischargeWeight();
		assertEqual(receivedWeight, 100.Decimal);
		txns.clear;
		self.getTiTxnsOfType(cargoOnSite, TRANS_TYPE_REC_SHIP, txns);
		assertEqual(1, txns.size);
		assertEqual(1, cargo.totalQuantity);      // no zombies ti is moved to yard

	// Move Bulk cargo using zero amount
	cargoId := "UTCOAL9999C";
	deleteCargo(cargoId, breakBulkCargoType);
	cargo := self.addCargoBulkAtLocation(cargoId, bulkCargoType, 100, lc, null, TI_IMEX_STATUS_IMPORT, voyage, vessel.myOperator, null);
		assertEqual(cargo.totalWeight, 100.Decimal);

	moveBulk(cargo, bs1, 0);
	cargoOnSite := getTrackedItemAtLocation(cargoId, bs1.myLocationsController);
		assertTrue(cargoOnSite = cargo);
		expectedWeight := cargoOnSite.getShipReceivalWeight();
		assertEqual(expectedWeight, 100.Decimal);
		receivedWeight := cargoOnSite.getShipDischargeWeight();
		assertEqual(receivedWeight, 100.Decimal);
		txns.clear;
		self.getTiTxnsOfType(cargoOnSite, TRANS_TYPE_REC_SHIP, txns);
		assertEqual(1, txns.size);
		assertEqual(1, cargo.totalQuantity);      // no zombies ti is moved to yard
		assertEqual(100.Decimal, cargo.totalWeight);      // no zombies ti is moved to yard

	// Move Bulk cargo to existing pile on yard
	cargoId := "UTCOAL9999D";
	deleteCargo(cargoId, breakBulkCargoType);
	cargoOnSite := self.addCargoBulkAtLocation(cargoId, bulkCargoType, 150, bs1.myLocationsController, null, TI_IMEX_STATUS_IMPORT, voyage, vessel.myOperator, null);
		assertEqual(cargoOnSite.totalWeight, 150.Decimal);
	cargo := self.addCargoBulkAtLocation(cargoId, bulkCargoType, 100, lc, null, TI_IMEX_STATUS_IMPORT, voyage, vessel.myOperator, null);
		assertEqual(cargo.totalWeight, 100.Decimal);

	moveBulk(cargo, bs1, 0);
		assertFalse(cargoOnSite = cargo);
		expectedWeight := cargoOnSite.getShipReceivalWeight();
		assertEqual(expectedWeight, 100.Decimal);
		receivedWeight := cargoOnSite.getShipDischargeWeight();
		assertEqual(receivedWeight, 100.Decimal);
		txns.clear;
		self.getTiTxnsOfType(cargoOnSite, TRANS_TYPE_REC_SHIP, txns);
		assertEqual(1, txns.size);
		assertEqual(1, cargo.totalQuantity);      
		assertEqual(0.Decimal, cargo.totalWeight);   
		assertEqual(250.Decimal, cargoOnSite.totalWeight);   

	// Move break bulk cargo in parts
	cargoId := "UTCOAL9999B";
	deleteCargo(cargoId, breakBulkCargoType);
	cargo := self.addCargoBulkAtLocation(cargoId, bulkCargoType, 100, lc, null, TI_IMEX_STATUS_IMPORT, voyage, vessel.myOperator, null);
		assertEqual(cargo.totalWeight, 100.Decimal);
	
	moveBulk(cargo, bs1, 20);
	cargoOnSite := getTrackedItemAtLocation(cargoId, bs1.myLocationsController);
		assertFalse(cargoOnSite = cargo);
		expectedWeight := cargoOnSite.getShipReceivalWeight();
		assertEqual(expectedWeight, 20.Decimal);
		receivedWeight := cargoOnSite.getShipDischargeWeight();
		assertEqual(receivedWeight, 20.Decimal);
		txns.clear;
		self.getTiTxnsOfType(cargoOnSite, TRANS_TYPE_REC_SHIP, txns);
		assertEqual(1, txns.size);
		assertEqual(20.Decimal, cargoOnSite.totalWeight); 
		txns.clear;
		self.getTiTxnsOfType(cargo, TRANS_TYPE_REC_SHIP, txns);
		assertEqual(0, txns.size);
		assertEqual(80.Decimal, cargo.totalWeight);      
		assertEqual(1, cargo.totalQuantity);      
		
	moveBulk(cargo, bs1, 25);
		assertFalse(cargoOnSite = cargo);
		expectedWeight := cargoOnSite.getShipReceivalWeight();
		assertEqual(expectedWeight, 45.Decimal);
		receivedWeight := cargoOnSite.getShipDischargeWeight();
		assertEqual(receivedWeight, 45.Decimal);
		txns.clear;
		self.getTiTxnsOfType(cargoOnSite, TRANS_TYPE_REC_SHIP, txns);
		assertEqual(2, txns.size);
		assertEqual(55.Decimal, cargo.totalWeight);      
		assertEqual(1, cargo.totalQuantity);      
		assertEqual(45.Decimal, cargoOnSite.totalWeight); 
	
	moveBulk(cargo, bs1, 0);  // remove remaining
		assertFalse(cargoOnSite = cargo);
		expectedWeight := cargoOnSite.getShipReceivalWeight();
		assertEqual(expectedWeight, 100.Decimal);
		receivedWeight := cargoOnSite.getShipDischargeWeight();
		assertEqual(receivedWeight, 100.Decimal);
		txns.clear;
		self.getTiTxnsOfType(cargoOnSite, TRANS_TYPE_REC_SHIP, txns);
		assertEqual(3, txns.size);
		assertEqual(0.Decimal, cargo.totalWeight);      
		assertEqual(1, cargo.totalQuantity);      
		assertEqual(100.Decimal, cargoOnSite.totalWeight); 
		
epilog
	delete txns;
	
	
	self.deleteStorageConfig( true );
end;</source>
    </JadeMethod>
    <JadeMethod name="tShipReleaseTxn" id="5fa1629a-a6c2-49ce-b0c1-42b2c11a71d5">
        <source>tShipReleaseTxn();
// cnwer1
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 October 2013	cnwdw1	Initial creation
*/
constants
vars
	vessel: CM_Vessel;
	voyage: CM_Voyage;
	bs1: CM_BlockStack;
	breakBulkCargoType, bulkCargoType : CM_CargoType;
	cargo, cargoOnShip: CM_TrackedItem;
	cargoId: String;
	lc: CM_LocationsController;
	height: Integer;
	expected, received, damaged: Integer;
	expectedWeight, receivedWeight: Decimal[14,4];
	txns: CM_TransactionSet;
begin

	vessel := self.addVesselWithHolds("UT_VHOLDS", 2, 2);
	voyage := self.addVoyageWithGeneralCargoStruc("UT_VHOLDS", vessel.name, vessel.myOperator.code,	self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 0);
	bs1 := self.addBlockStack("UTBS1", 9999, null);
	breakBulkCargoType := app.myRoot.getCargoTypeFromAbbrev("UTREBAR");
	bulkCargoType  := app.myRoot.getCargoTypeFromAbbrev("UTCOAL");
	self.getTerminal.findLocationFromString("UT_VHOLDS 0101", true, lc, height); 

	create txns transient;

	// Move break bulk cargo 
	cargoId := "UTREBAR9999A";
	deleteCargo(cargoId, breakBulkCargoType);
	cargo := self.addCargoBreakBulkAtLocation(cargoId, breakBulkCargoType, 50, bs1.myLocationsController, null, TI_IMEX_STATUS_EXPORT, voyage, vessel.myOperator);
	self.opts.addAssoc("TotalWeight", 50);
	self.updateTI(cargo);
		assertEqual(cargo.totalQuantity, 50);
	self.opts.purge;

	moveBreakBulk(cargo, lc, 50);
	cargoOnShip := getTrackedItemAtLocation(cargoId, lc);
		expected := cargoOnShip.getShipReleaseQuantity();
		assertEqual(expected, 50);
		txns.clear;
		self.getTiTxnsOfType(cargoOnShip, TRANS_TYPE_REL_SHIP, txns);
		assertEqual(1, txns.size);
		assertEqual(50, cargoOnShip.totalQuantity);     
//		assertEqual(0, cargo.totalQuantity);     
  

	// Move break bulk cargo to existing pile in ship
	cargoId := "UTREBAR9999D";
	deleteCargo(cargoId, breakBulkCargoType);
	cargoOnShip := self.addCargoBreakBulkAtLocation(cargoId, breakBulkCargoType, 150, lc, null, TI_IMEX_STATUS_EXPORT, voyage, vessel.myOperator);
	cargo := self.addCargoBreakBulkAtLocation(cargoId, breakBulkCargoType, 50, bs1.myLocationsController, null, TI_IMEX_STATUS_EXPORT, voyage, vessel.myOperator);
	self.opts.addAssoc("TotalWeight", 50);
	self.updateTI(cargo);
		assertEqual(cargo.totalQuantity, 50);
	self.opts.purge;

	moveBreakBulk(cargo, lc, 50);
		assertFalse(cargo = cargoOnShip);
		expected := cargoOnShip.getShipReleaseQuantity();
		assertEqual(expected, 51);  // Includes Release of the cargo placed directly on ship above.
		txns.clear;
		self.getTiTxnsOfType(cargoOnShip, TRANS_TYPE_REL_SHIP, txns);
		assertEqual(2, txns.size);   // Includes Release of the cargo placed directly on ship above.
		assertEqual(200, cargoOnShip.totalQuantity); 
		assertEqual(0, cargo.totalQuantity);      

	// Move break bulk cargo to existing pile in ship using zero
	cargoId := "UTREBAR9999E";
	deleteCargo(cargoId, breakBulkCargoType);
	cargoOnShip := self.addCargoBreakBulkAtLocation(cargoId, breakBulkCargoType, 150, lc, null, TI_IMEX_STATUS_EXPORT, voyage, vessel.myOperator);
	cargo := self.addCargoBreakBulkAtLocation(cargoId, breakBulkCargoType, 50, bs1.myLocationsController, null, TI_IMEX_STATUS_EXPORT, voyage, vessel.myOperator);
	self.opts.addAssoc("TotalWeight", 50);
	self.updateTI(cargo);
		assertEqual(cargo.totalQuantity, 50);
	self.opts.purge;

	moveBreakBulk(cargo, lc, 0);
		assertFalse(cargo = cargoOnShip);
		expected := cargoOnShip.getShipReleaseQuantity();
		assertEqual(expected, 51);
		txns.clear;
		self.getTiTxnsOfType(cargoOnShip, TRANS_TYPE_REL_SHIP, txns);
		assertEqual(2, txns.size);   // Includes Release of the cargo placed directly on ship above.
		assertEqual(200, cargoOnShip.totalQuantity); 
		assertEqual(0, cargo.totalQuantity);      

	// Move break bulk cargo using zero amount
	cargoId := "UTREBAR9999C";
	deleteCargo(cargoId, breakBulkCargoType);
	cargoOnShip := self.addCargoBreakBulkAtLocation(cargoId, breakBulkCargoType, 150, lc, null, TI_IMEX_STATUS_EXPORT, voyage, vessel.myOperator);
	cargo := self.addCargoBreakBulkAtLocation(cargoId, breakBulkCargoType, 50, bs1.myLocationsController, null, TI_IMEX_STATUS_EXPORT, voyage, vessel.myOperator);
	self.opts.addAssoc("TotalWeight", 50);
	self.updateTI(cargo);
		assertEqual(cargo.totalQuantity, 50);
	self.opts.purge;

	moveBreakBulk(cargo, lc, 0);
		assertFalse(cargo = cargoOnShip);
		expected := cargoOnShip.getShipReleaseQuantity();
		assertEqual(expected, 51);
		txns.clear;
		self.getTiTxnsOfType(cargoOnShip, TRANS_TYPE_REL_SHIP, txns);
		assertEqual(2, txns.size);   // Includes Release of the cargo placed directly on ship above.
		assertEqual(200, cargoOnShip.totalQuantity); 
		assertEqual(0, cargo.totalQuantity);      

	// Move break bulk cargo in parts
	cargoId := "UTREBAR9999B";
	deleteCargo(cargoId, breakBulkCargoType);
	cargo := self.addCargoBreakBulkAtLocation(cargoId, breakBulkCargoType, 50, bs1.myLocationsController, null, TI_IMEX_STATUS_EXPORT, voyage, vessel.myOperator);
	self.opts.addAssoc("TotalWeight", 50);
	self.updateTI(cargo);
		assertEqual(cargo.totalQuantity, 50);
	self.opts.purge;
	
	moveBreakBulk(cargo, lc, 20);
	cargoOnShip := getTrackedItemAtLocation(cargoId, lc);
		expected := cargoOnShip.getShipReleaseQuantity();
		assertEqual(expected, 20);
		
	moveBreakBulk(cargo, lc, 25);
		expected := cargoOnShip.getShipReleaseQuantity();
		assertEqual(expected, 45);
	
	moveBreakBulk(cargo, lc, 0); // removing remaining
		expected := cargoOnShip.getShipReleaseQuantity();
		assertEqual(expected, 50);
		txns.clear;
		self.getTiTxnsOfType(cargoOnShip, TRANS_TYPE_REL_SHIP, txns);
		assertEqual(3, txns.size);
		assertEqual(0, cargo.totalQuantity);

/*	
	// Move Bulk cargo
	cargoId := "UTCOAL9999A";
	deleteCargo(cargoId, breakBulkCargoType);
	cargo := self.addCargoBulkAtLocation(cargoId, bulkCargoType, 100, lc, null, TI_IMEX_STATUS_IMPORT, voyage, vessel.myOperator);
		assertEqual(cargo.totalWeight, 100.Decimal);

	moveBulk(cargo, bs1, 100);
	cargoOnShip := getTrackedItemAtLocation(cargoId, bs1.myLocationsController);
		assertTrue(cargoOnShip = cargo);
		expectedWeight := cargoOnShip.getShipReceivalWeight();
		assertEqual(expectedWeight, 100.Decimal);
		receivedWeight := cargoOnShip.getShipDischargeWeight();
		assertEqual(receivedWeight, 100.Decimal);
		txns.clear;
		self.getTiTxnsOfType(cargoOnShip, TRANS_TYPE_REC_SHIP, txns);
		assertEqual(1, txns.size);
		assertEqual(1, cargo.totalQuantity);      // no zombies ti is moved to yard

	// Move Bulk cargo using zero amount
	cargoId := "UTCOAL9999C";
	deleteCargo(cargoId, breakBulkCargoType);
	cargo := self.addCargoBulkAtLocation(cargoId, bulkCargoType, 100, lc, null, TI_IMEX_STATUS_IMPORT, voyage, vessel.myOperator);
		assertEqual(cargo.totalWeight, 100.Decimal);

	moveBulk(cargo, bs1, 0);
	cargoOnShip := getTrackedItemAtLocation(cargoId, bs1.myLocationsController);
		assertTrue(cargoOnShip = cargo);
		expectedWeight := cargoOnShip.getShipReceivalWeight();
		assertEqual(expectedWeight, 100.Decimal);
		receivedWeight := cargoOnShip.getShipDischargeWeight();
		assertEqual(receivedWeight, 100.Decimal);
		txns.clear;
		self.getTiTxnsOfType(cargoOnShip, TRANS_TYPE_REC_SHIP, txns);
		assertEqual(1, txns.size);
		assertEqual(1, cargo.totalQuantity);      // no zombies ti is moved to yard
		assertEqual(100.Decimal, cargo.totalWeight);      // no zombies ti is moved to yard

	// Move Bulk cargo to existing pile on yard
	cargoId := "UTCOAL9999D";
	deleteCargo(cargoId, breakBulkCargoType);
	cargoOnShip := self.addCargoBulkAtLocation(cargoId, bulkCargoType, 150, bs1.myLocationsController, null, TI_IMEX_STATUS_IMPORT, voyage, vessel.myOperator);
		assertEqual(cargoOnShip.totalWeight, 150.Decimal);
	cargo := self.addCargoBulkAtLocation(cargoId, bulkCargoType, 100, lc, null, TI_IMEX_STATUS_IMPORT, voyage, vessel.myOperator);
		assertEqual(cargo.totalWeight, 100.Decimal);

	moveBulk(cargo, bs1, 0);
		assertFalse(cargoOnShip = cargo);
		expectedWeight := cargoOnShip.getShipReceivalWeight();
		assertEqual(expectedWeight, 100.Decimal);
		receivedWeight := cargoOnShip.getShipDischargeWeight();
		assertEqual(receivedWeight, 100.Decimal);
		txns.clear;
		self.getTiTxnsOfType(cargoOnShip, TRANS_TYPE_REC_SHIP, txns);
		assertEqual(1, txns.size);
		assertEqual(1, cargo.totalQuantity);      
		assertEqual(0.Decimal, cargo.totalWeight);   
		assertEqual(250.Decimal, cargoOnShip.totalWeight);   

	// Move break bulk cargo in parts
	cargoId := "UTCOAL9999B";
	deleteCargo(cargoId, breakBulkCargoType);
	cargo := self.addCargoBulkAtLocation(cargoId, bulkCargoType, 100, lc, null, TI_IMEX_STATUS_IMPORT, voyage, vessel.myOperator);
		assertEqual(cargo.totalWeight, 100.Decimal);
	
	moveBulk(cargo, bs1, 20);
	cargoOnShip := getTrackedItemAtLocation(cargoId, bs1.myLocationsController);
		assertFalse(cargoOnShip = cargo);
		expectedWeight := cargoOnShip.getShipReceivalWeight();
		assertEqual(expectedWeight, 20.Decimal);
		receivedWeight := cargoOnShip.getShipDischargeWeight();
		assertEqual(receivedWeight, 20.Decimal);
		txns.clear;
		self.getTiTxnsOfType(cargoOnShip, TRANS_TYPE_REC_SHIP, txns);
		assertEqual(1, txns.size);
		assertEqual(20.Decimal, cargoOnShip.totalWeight); 
		txns.clear;
		self.getTiTxnsOfType(cargo, TRANS_TYPE_REC_SHIP, txns);
		assertEqual(0, txns.size);
		assertEqual(80.Decimal, cargo.totalWeight);      
		assertEqual(1, cargo.totalQuantity);      
		
	moveBulk(cargo, bs1, 25);
		assertFalse(cargoOnShip = cargo);
		expectedWeight := cargoOnShip.getShipReceivalWeight();
		assertEqual(expectedWeight, 45.Decimal);
		receivedWeight := cargoOnShip.getShipDischargeWeight();
		assertEqual(receivedWeight, 45.Decimal);
		txns.clear;
		self.getTiTxnsOfType(cargoOnShip, TRANS_TYPE_REC_SHIP, txns);
		assertEqual(2, txns.size);
		assertEqual(55.Decimal, cargo.totalWeight);      
		assertEqual(1, cargo.totalQuantity);      
		assertEqual(45.Decimal, cargoOnShip.totalWeight); 
	
	moveBulk(cargo, bs1, 0);  // remove remaining
		assertFalse(cargoOnShip = cargo);
		expectedWeight := cargoOnShip.getShipReceivalWeight();
		assertEqual(expectedWeight, 100.Decimal);
		receivedWeight := cargoOnShip.getShipDischargeWeight();
		assertEqual(receivedWeight, 100.Decimal);
		txns.clear;
		self.getTiTxnsOfType(cargoOnShip, TRANS_TYPE_REC_SHIP, txns);
		assertEqual(3, txns.size);
		assertEqual(0.Decimal, cargo.totalWeight);      
		assertEqual(1, cargo.totalQuantity);      
		assertEqual(100.Decimal, cargoOnShip.totalWeight); 
*/
		
epilog
	delete txns;
end;</source>
    </JadeMethod>
    <JadeMethod name="tUserBreakBulkSplitMerge" id="26163069-cd61-4f99-a705-ad875abe4c04">
        <source>tUserBreakBulkSplitMerge();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 May 2013	cnwndl1	Initial creation

*/

constants

	Cargo_Type : String = "UTREBAR";
	BS_Area : String = "UTBBSM";
	Base_Cargo_ID : String = "UTBBSM";
	Cargo_ID1 : String = "UTBBSM1";
	Cargo_ID2 : String = "UTBBSM2";
	Cargo_ID3 : String = "UTBBSM3";
	
vars

	bs : CM_BlockStack;
	cargoType : CM_CargoType;
	ti : CM_TrackedItem;
	cargoTypeId : Integer;
	newTiIds : StringArray;
	index : Integer;
	tisToMerge : CM_TISet;
	id : String;
	
begin
	self.setTerminalConfig(ReeferBookingReqsTemp, false);
	self.setTerminalConfig(PrenoteUniqBooking, false);

	cargoType := app.myRoot.getCargoTypeFromAbbrev(Cargo_Type);
	cargoTypeId := cargoType.id;
	
	// create a block stack to use
	bs := self.addBlockStack(BS_Area,200,null);
	self.assertTrueMsg(bs &lt;&gt; null,"test 3. Block stack '" &amp; BS_Area &amp; "' failed to create.");
	
	//create some Break-Bulk with a 50 items in it.
	ti := self.addCargoAtLocation(Cargo_ID1,cargoType,self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString), bs.myLocationsController);
	self.assertTrueMsg(ti &lt;&gt; null,"test 4. Tracked item '" &amp; Cargo_ID1 &amp; "' failed to create.");
	self.assertTrueMsg(ti.myPrimaryActualLocation = bs.myLocationsController,"test 4. Tracked item '" &amp; Cargo_ID1 &amp; "' not created in " &amp; BS_Area &amp; ".");
	beginTransaction;
	ti.setTotalQuantity(50);
	commitTransaction;
	self.assertTrueMsg(ti.totalQuantity = 50,"test 5. Tracked item '" &amp; Cargo_ID1 &amp; "' total Quantity should be 50.");

	//split the existing cargo item into two of 25 items each in teh same location.
	create newTiIds transient;
	newTiIds.add(Cargo_ID2);
	newTiIds.add(Cargo_ID3);
	app.myTrxUA.trxSplitBreakBulkToNewID(	ti.CM_Cargo,	//_sourceTi : CM_Cargo;
											newTiIds,	//_newTiIds : StringArray;
											25,	//_quantity : Integer;
											0,	// _weightOrVolume : Decimal;
											ti.myOperator,	//_operator : CM_Operator;
											true,
											true,
											true,
											true,
											app.myPassport	//_passport : CM_Passport input
											);
	self.assertTrueMsg(not app.myPassport.hasErrors,"test 6. Error '" &amp; app.myPassport.getErrorsAsString );
	self.assertTrueMsg(ti.totalQuantity = 0,"test 7. Tracked item '" &amp; ti.id &amp; "' total Quantity should now be 0.");
											
	ti := self.getTerminal.allOnsiteTIsByCargoTypeId.getAtKey( cargoTypeId, Cargo_ID3 );
	self.assertTrueMsg(ti &lt;&gt; null,"test 8. Tracked item '" &amp; Cargo_ID3 &amp; "' failed to create.");
	self.assertTrueMsg(ti.myPrimaryActualLocation = bs.myLocationsController,"test 9. Tracked item '" &amp; ti.id &amp; "' not created in " &amp; BS_Area &amp; ".");
	self.assertTrueMsg(ti.totalQuantity = 25,"test 10. Tracked item '" &amp; ti.id &amp; "' total Quantity should be 25.");
	
	ti := self.getTerminal.allOnsiteTIsByCargoTypeId.getAtKey( cargoTypeId, Cargo_ID2 );
	self.assertTrueMsg(ti &lt;&gt; null,"test 11. Tracked item '" &amp; Cargo_ID2 &amp; "' failed to create.");
	self.assertTrueMsg(ti.myPrimaryActualLocation = bs.myLocationsController,"test 12. Tracked item '" &amp; ti.id &amp; "' not created in " &amp; BS_Area &amp; ".");
	self.assertTrueMsg(ti.totalQuantity = 25,"test 13. Tracked item '" &amp; ti.id &amp; "' total Quantity should be 25.");
	
	//take 'Cargo_ID2' , and split into 25 individual cargo items
	newTiIds.clear();
	foreach index in 1 to 25 do
		newTiIds.add( Base_Cargo_ID &amp; "-" &amp; index.String );
	endforeach;
	app.myTrxUA.trxSplitBreakBulkToNewID(	ti.CM_Cargo,	//_sourceTi : CM_Cargo;
											newTiIds,	//_newTiIds : StringArray;
											1,	//_quantity : Integer;
											0,	// _weightOrVolume : Decimal;
											ti.myOperator,	//_operator : CM_Operator;
											true,
											true,
											true,
											true,
											app.myPassport	//_passport : CM_Passport input
											);
	
	self.assertTrueMsg(not app.myPassport.hasErrors,"test 14. Error '" &amp; app.myPassport.getErrorsAsString );
	ti := self.getTerminal.allOnsiteTIsByCargoTypeId.getAtKey( cargoTypeId, newTiIds.last );
	self.assertTrueMsg(ti &lt;&gt; null,"test 15. Tracked item '" &amp; newTiIds.last &amp; "' failed to create.");
	self.assertTrueMsg(ti.myPrimaryActualLocation = bs.myLocationsController,"test 16. Tracked item '" &amp; ti.id &amp; "' not created in " &amp; BS_Area &amp; ".");
	self.assertTrueMsg(ti.totalQuantity = 1,"test 17. Tracked item '" &amp; ti.id &amp; "' total Quantity should be 1.");
	
	//now merge the 25 items back together (24 individulas into the 25th one)
	create tisToMerge transient;
	foreach index in 1 to 24 do
		ti := self.getTerminal.allOnsiteTIsByCargoTypeId.getAtKey( cargoTypeId, newTiIds[index] );
		if ti &lt;&gt; null then
			tisToMerge.add(ti);
		endif;
	endforeach;
	ti := self.getTerminal.allOnsiteTIsByCargoTypeId.getAtKey( cargoTypeId, newTiIds.last );
	app.myTrxUA.trxMergeBreakBulk(	ti.CM_Cargo,	//_targetTi : CM_Cargo;
									tisToMerge,	//_allItemsToBeMerged : CM_TISet;
									app.myPassport	//_passport : CM_Passport input
									);
	self.assertTrueMsg(not app.myPassport.hasErrors,"test 18. Error '" &amp; app.myPassport.getErrorsAsString );
	self.assertTrueMsg(ti.totalQuantity = 25,"test 19. Tracked item '" &amp; ti.id &amp; "' total Quantity should be 25.");
	
epilog

	//get rid of any (will need clean-up if it ever fails during the process)
	self.deleteCargo(Cargo_ID1, cargoType);
	self.deleteCargo(Cargo_ID2, cargoType);
	self.deleteCargo(Cargo_ID3, cargoType);
	if newTiIds &lt;&gt; null then
		foreach id in newTiIds do
			self.deleteCargo(id, cargoType);
		endforeach;
	endif;
	
	delete newTiIds;
	delete tisToMerge;
	
end;
</source>
    </JadeMethod>
    <JadeMethod name="tUserBreakBulkSplitMergeNewLoc" id="b1a19648-92c8-491e-a575-f6a3f43b1c82">
        <source>tUserBreakBulkSplitMergeNewLoc();

/*

Purpose:		Split and merge to a new location

Date			Who		Reason
19/05/2015		cnwmh5	Initial creation

*/
constants

	Cargo_Type 					: String = "UTREBAR";
	BsId1						: String = "UTBSVG1";
	BsId2						: String = "UTBSVG2";
	CargoId1					: String = "UTMHREBAR01";
	CargoId2					: String = "UTMHREBAR02";
	
vars

	cargoType					: CM_CargoType;
	bs1							: CM_BlockStack;
	bs2							: CM_BlockStack;
	ti							: CM_TrackedItem;
	
	
	newTiIds 					: StringArray;
	
begin

	cargoType := app.myRoot.getCargoTypeFromAbbrev(Cargo_Type);
	self.assertNotNull(cargoType);
	
	bs1 := self.addBlockStack(BsId1, 100, null);
	self.assertNotNull(bs1);
	
	bs2 := self.addBlockStack(BsId2, 100, null);
	self.assertNotNull(bs2);
	
	self.deleteCargo(CargoId1, cargoType);
	self.deleteCargo(CargoId2, cargoType);
	
	ti := self.addCargoAtLocation(CargoId1, cargoType, self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString), bs1.myLocationsController);
	self.assertNotNull(ti);
	beginTransaction;
	ti.setTotalQuantity(66);
	commitTransaction;
	
	create newTiIds transient;
	newTiIds.add(CargoId2);
	
	app.myTrxUA.trxSplitBreakBulkToNewIDAndLoc(	ti.CM_Cargo, CargoId2, 33, 0, bs2.myLocationsController, null, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	// trxBreakBulkOverage
	ti := self.getTrackedItemByCargoType(CargoId2, cargoType.id);
	self.assertNotNull(ti);
	self.opts.purge();
	self.opts.addAssoc("Reason", "Coz I need to");
	self.opts.addAssoc("Weight", 25000.Decimal);
	self.addDiscrepancy(ti, 65); 
	self.assertEqual(ti.totalQuantity, 65);
	self.assertTrue(ti.allTransactions.last.isKindOf(CM_BBDiscrepancy));
	self.assertEqual(ti.allTransactions.last.CM_BBDiscrepancy.reason, "Coz I need to");
	self.assertEqual(ti.allTransactions.last.CM_BBDiscrepancy.totalQuantity, 65);
	
epilog

	delete newTiIds;

end;</source>
        <text>&lt;?xml version="1.0"?&gt;
&lt;UT_Additional&gt;
  &lt;Categories&gt;
    &lt;Category CanDelete="true"&gt;Fails1006&lt;/Category&gt;
  &lt;/Categories&gt;
&lt;/UT_Additional&gt;</text>
    </JadeMethod>
    <JadeMethod name="uBreakBulkMultiMachinMovSplit" id="c8271b03-77b0-4abc-85a5-259cc4ba8cb6">
        <source>uBreakBulkMultiMachinMovSplit();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 October 2016	cnwns1	Initial creation

*/
constants
	Cargo_Type			: String = "UTREBAR";
vars
	bs1, bs2 : CM_BlockStack;
	q1: CM_RadioTelemetryQueue;
	cargo, cargo2 : CM_TrackedItem;
	imv,
	fork1,
	fork2: CM_Machine;
	tas: StringArray;	
	cargoTypeObj : CM_CargoType;
	moveController		: CMIF_MoveController;
	masterBBEntry,
	masterQEntry : CM_RTQueueEntry;
	wle : CM_WorkListEntry;
begin

	//create bbk cargo type with allow duplicates
	
	cargoTypeObj	:=	app.myRoot.getCargoTypeFromAbbrev(Cargo_Type);
	
	// create block stack 1
	// create cargo with quantity
	deleteTerminalArea("UTBS1");
	bs1:=self.addBlockStack("UTBS1",200,null);
	self.assertNotNull(bs1);
	
	//create block stack 2
	deleteTerminalArea("UTBS2");
	bs2:=self.addBlockStack("UTBS2",200,null);
	self.assertNotNull(bs2);
	
	
	self.deleteAllCargo("UTREBAR1",cargoTypeObj);
	cargo:=self.addCargoAtLocation("UTREBAR1",cargoTypeObj,self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString), bs1.myLocationsController);
	self.assertNoTrxErrors();
	self.assertNotNull(cargo);
	self.assertEqual(cargo.myPrimaryActualLocation,bs1.myLocationsController);
	
	
	//self.deleteAllCargo("UTREBAR2",cargoTypeObj);
	cargo2:=self.addCargoAtLocation("UTREBAR1",cargoTypeObj,self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString), bs2.myLocationsController);
	self.assertNotNull(cargo2);
	self.assertEqual(cargo2.myPrimaryActualLocation,bs2.myLocationsController);
	
	beginTransaction;
	cargo.setTotalQuantity(50);
	cargo.setMyTotalVolume(50000);
	cargo.setTotalWeightWithoutTrans(50000);
	cargo2.setTotalQuantity(50);
	cargo2.setMyTotalVolume(50000);
	cargo2.setTotalWeightWithoutTrans(50000);	
	commitTransaction;
	
	self.assertEqual(cargo.totalQuantity,50);
	self.assertEqual(cargo.totalVolume.Real,50000.Real);
	self.assertEqual(cargo.totalWeight.Decimal,50000.Decimal);
	
	self.assertEqual(cargo2.totalQuantity,50);
	self.assertEqual(cargo2.totalVolume.Real,50000.Real);
	self.assertEqual(cargo2.totalWeight.Decimal,50000.Decimal);

	//Fork -&gt; IMV -&gt; Fork
	self.opts.purge;
	 self.opts.addAssoc("FullMoveQueueing",null);
	self.addMachineRule(bs1,bs2,RTMoveMethod_4);
	q1 := self.addQueue("UT_Q", bs1,bs2, false);

	self.opts.purge;
	self.opts.addAssoc("TotalQuantity",50);
	self.moveQueued(cargo, bs2);
	
	self.assertNotNull(cargo.allQueuedFutureMoves.first);
	wle:=cargo.allQueuedFutureMoves.first.myWorkListEntry;
	self.assertNotNull(wle);
	self.assertEqual(wle.quantity,50);
	
	masterQEntry:=wle.allRTQueueEntries.first;
	self.assertNotNull(masterQEntry);
	//bb fork -imv - fork
	self.assertEqual(wle.allRTQueueEntries.size,3);
	
	masterBBEntry:=wle.allRTQueueEntries.first;
	self.assertEqual(masterBBEntry.isBreakBulkGenericMaster,true);
	self.assertEqual(masterBBEntry.quantity,50);
	self.assertEqual(wle.allRTQueueEntries.last.isBreakBulkGenericMaster,true);
	self.assertEqual(wle.allRTQueueEntries.last.quantity,50);
	self.assertEqual(wle.allRTQueueEntries[2].allTasks.size, 1);
	self.assertEqual(wle.allRTQueueEntries[2].allTasks.first.isMove,true);
	
	
	
	create tas transient;
	tas.add(bs1.id); 
	tas.add(bs2.id);
	self.opts.purge();
	self.opts.addAssoc("WeightDifference", 500);
	self.opts.addAssoc("WeightMaxLift", 20000);
	
	fork1:=self.addForkLift("UFL1", 94, tas, q1.id);
	fork2:=self.addForkLift("UFL2", 95, tas, q1.id);
	imv:=self.addIMV("UIMV",96, tas,q1.id);
	self.assertNotNull(imv);
	app.isRTApp:=true;  
	self.machineLogon(fork1);
	self.machineLogon(fork2);
	
	
	
	// Test that cannot twin lift 20ft with 40ft
	//self.expectTrxError(ERR_MACH_ASSIGN); 
	//
	//Do Move 1
	//Pick up
	self.machineAcceptSpecifiedTwinTask(fork1, masterBBEntry,null);
	self.opts.purge;
	self.opts.addAssoc("QUANTITY",10);
	self.machinePickup(fork1);	
	self.assertEqual(wle.quantity,40);
	self.assertEqual(masterBBEntry.quantity,50);
	self.assertEqual(masterBBEntry.totalMoved,10);
	self.assertEqualMsg(masterBBEntry.allBreakBulkMoves.size,1,"masterBBEntry.allBreakBulkMoves.size -a");
	self.assertEqual(cargo.totalQuantity,40);
	//Set down on IMV
	self.machineSetdownTwinTask(fork1, fork1.currentQueueTask ,null,imv.id);
	self.assertEqualMsg(masterBBEntry.allBreakBulkMoves.size,1,"masterBBEntry.allBreakBulkMoves.size -b");
	self.assertEqualMsg(wle.allRTQueueEntries.size,3,"wle.allRTQueueEntries.size -a");
	self.assertEqual(cargo.totalQuantity,40);
	self.assertEqualMsg(imv.myMachineController.allTrackedItems.size, 1,"imv.myMachineController.allTrackedItems.size -a");
	self.assertEqual(imv.myMachineController.allTrackedItems.first.totalQuantity, 10);
	//Do Move 2
	//Pick up
	self.machineAcceptSpecifiedTwinTask(fork1, masterBBEntry,null);
	self.opts.purge;
	self.opts.addAssoc("QUANTITY",10);
	self.machinePickup(fork1);	
	self.assertEqual(wle.quantity,30);
	self.assertEqual(masterBBEntry.quantity,50);
	self.assertEqual(masterBBEntry.totalMoved,20);
	self.assertEqualMsg(masterBBEntry.allBreakBulkMoves.size,2,"masterBBEntry.allBreakBulkMoves.size -c");
	self.assertEqual(cargo.totalQuantity,30);
	//Set down on IMV
	self.machineSetdownTwinTask(fork1, fork1.currentQueueTask ,null,imv.id);
	self.assertEqualMsg(masterBBEntry.allBreakBulkMoves.size,2,"masterBBEntry.allBreakBulkMoves.size -d");
	self.assertEqualMsg(wle.allRTQueueEntries.size,3,"wle.allRTQueueEntries.size -b");
	self.assertEqual(cargo.totalQuantity,30);
	self.assertEqualMsg(imv.myMachineController.allTrackedItems.size, 1,"imv.myMachineController.allTrackedItems.size -b");
	self.assertEqual(imv.myMachineController.allTrackedItems.first.totalQuantity, 20);
	
	//Do Move 3
	//Pick up
	self.machineAcceptSpecifiedTwinTask(fork1, masterBBEntry,null);
	self.opts.purge;
	self.opts.addAssoc("QUANTITY",10);
	self.machinePickup(fork1);	
	self.assertEqualMsg(wle.quantity,10,"wle.quantity -a");
	self.assertEqual(masterBBEntry.quantity,50);
	self.assertEqualMsg(masterBBEntry.totalMoved,30,"masterBBEntry.totalMoved");
	self.assertEqualMsg(masterBBEntry.allBreakBulkMoves.size,3,"masterBBEntry.allBreakBulkMoves.size -d");
	self.assertEqual(cargo.totalQuantity,20);
	//Set down on IMV
	self.machineSetdownTwinTask(fork1, fork1.currentQueueTask ,null,imv.id);
	self.assertEqualMsg(masterBBEntry.allBreakBulkMoves.size,3,"masterBBEntry.allBreakBulkMoves.size -e");
	self.assertEqualMsg(wle.allRTQueueEntries.size,3,"wle.allRTQueueEntries.size -b");
	self.assertEqualMsg(cargo.totalQuantity,20,"cargo.totalQuantity");
	self.assertEqualMsg(imv.myMachineController.allTrackedItems.size, 1,"imv.myMachineController.allTrackedItems.size -c");
	self.assertEqualMsg(imv.myMachineController.allTrackedItems.first.totalQuantity, 30,"imv.myMachineController.allTrackedItems.first.totalQuantity");
	
	//Do Move 4
	//Pick up
	self.machineAcceptSpecifiedTwinTask(fork1, masterBBEntry,null);
	self.opts.purge;
	self.opts.addAssoc("QUANTITY",10);
	self.machinePickup(fork1);	
	self.assertEqualMsg(wle.quantity,20,"wle.quantity -b");
	self.assertEqual(masterBBEntry.quantity,50);
	self.assertEqualMsg(masterBBEntry.totalMoved,40,"masterBBEntry.totalMoved");
	self.assertEqualMsg(masterBBEntry.allBreakBulkMoves.size,4,"masterBBEntry.allBreakBulkMoves.size -d");
	self.assertEqual(cargo.totalQuantity,10);
	//Set down on IMV
	self.machineSetdownTwinTask(fork1, fork1.currentQueueTask ,null,imv.id);
	self.assertEqualMsg(masterBBEntry.allBreakBulkMoves.size,4,"masterBBEntry.allBreakBulkMoves.size -e");
	self.assertEqualMsg(wle.allRTQueueEntries.size,3,"wle.allRTQueueEntries.size -b");
	self.assertEqualMsg(cargo.totalQuantity,10,"cargo.totalQuantity");
	self.assertEqualMsg(imv.myMachineController.allTrackedItems.size, 1,"imv.myMachineController.allTrackedItems.size -c");
	self.assertEqualMsg(imv.myMachineController.allTrackedItems.first.totalQuantity, 40,"imv.myMachineController.allTrackedItems.first.totalQuantity");
	
	
	
	//Do Move 5
	//Pick up
	self.machineAcceptSpecifiedTwinTask(fork1, masterBBEntry,null);
	self.opts.purge;
	self.opts.addAssoc("QUANTITY",10);
	self.machinePickup(fork1);	
	self.assertEqualMsg(wle.quantity,40,"wle.quantity -c");
	self.assertEqual(masterBBEntry.quantity,50);
	self.assertEqualMsg(masterBBEntry.totalMoved,50,"masterBBEntry.totalMoved");
	self.assertEqualMsg(masterBBEntry.allBreakBulkMoves.size,5,"masterBBEntry.allBreakBulkMoves.size -e");
	self.assertEqualMsg(cargo.totalQuantity,10,"cargo.totalQuantity");
	//Set down on IMV
	self.machineSetdownTwinTask(fork1, fork1.currentQueueTask ,null,imv.id);
	self.assertEqualMsg(masterBBEntry.allBreakBulkMoves.size,0,"masterBBEntry.allBreakBulkMoves.size -e");
	self.assertEqualMsg(wle.allRTQueueEntries.size,3,"wle.allRTQueueEntries.size -b");
	self.assertEqualMsg(cargo.totalQuantity,0,"cargo.totalQuantity");
	self.assertEqualMsg(imv.myMachineController.allTrackedItems.size, 1,"imv.myMachineController.allTrackedItems.size -c");
	self.assertEqualMsg(imv.myMachineController.allTrackedItems.first.totalQuantity, 50,"imv.myMachineController.allTrackedItems.first.totalQuantity");
	
	
	
	//Do Move 1
	//Pick up
//	self.machineAcceptSpecifiedTwinTask(fork2,fork2.allCurrentQueueTasks.first,null);
	self.machineAcceptSpecifiedTwinTask(fork2, masterBBEntry,null);
	self.opts.purge;
	self.opts.addAssoc("QUANTITY",10);
	self.machinePickup(fork2);	
	self.assertEqualMsg(wle.quantity,10,"wle.quantity -c");
	self.assertEqual(masterQEntry.quantity,50);
	self.assertEqualMsg(masterQEntry.totalMoved,50,"masterBBEntry.totalMoved");
	self.assertEqualMsg(masterQEntry.allBreakBulkMoves.size,5,"masterBBEntry.allBreakBulkMoves.size -e");
	self.assertEqualMsg(cargo.totalQuantity,10,"cargo.totalQuantity");
	//Set down on IMV
	self.machineSetdownTwinTask(fork2, fork2.currentQueueTask ,null,bs2.id);
	self.assertEqualMsg(masterQEntry.allBreakBulkMoves.size,0,"masterBBEntry.allBreakBulkMoves.size -e");
	self.assertEqualMsg(wle.allRTQueueEntries.size,3,"wle.allRTQueueEntries.size -b");
	self.assertEqualMsg(cargo.totalQuantity,0,"cargo.totalQuantity");
	self.assertEqualMsg(imv.myMachineController.allTrackedItems.size, 1,"imv.myMachineController.allTrackedItems.size -c");
	self.assertEqualMsg(imv.myMachineController.allTrackedItems.first.totalQuantity, 50,"imv.myMachineController.allTrackedItems.first.totalQuantity");
	return;
	
	self.machineAcceptSpecifiedTwinTask(fork2, masterQEntry,null);
	
	
	
	
	self.opts.purge;
	self.opts.addAssoc("QUANTITY",10);	
	self.machinePickup(fork2);		

	
	self.assertEqual(wle.quantity,35);
	self.assertEqual(masterBBEntry.quantity,50);
	self.assertEqual(masterBBEntry.totalMoved,15);
	
	self.assertEqualMsg(masterBBEntry.allBreakBulkMoves.size,2,"masterBBEntry.allBreakBulkMoves.size is wrong -a");
	self.assertEqual(wle.allRTQueueEntries.size,3);
	self.assertEqual(cargo.totalQuantity,35);
	
	
	
	self.machineSetdownTwinTask(fork1, fork1.currentQueueTask ,null,imv.id);
	self.assertEqualMsg(masterBBEntry.allBreakBulkMoves.size,2,"masterBBEntry.allBreakBulkMoves.size -b");
	self.assertEqual(wle.allRTQueueEntries.size,3);
	self.assertEqual(cargo.totalQuantity,35);
	self.assertEqual(imv.myMachineController.allTrackedItems.size, 1);
	self.assertEqual(imv.myMachineController.allTrackedItems.first.totalQuantity, 5);
	
	self.machineAcceptSpecifiedTwinTask(fork1, masterBBEntry,null);
	self.opts.purge;
	self.opts.addAssoc("QUANTITY",5);
	self.machinePickup(fork1);
	self.assertEqualMsg(wle.quantity,30,"wle.quantity is not 5 bro");
	self.assertEqual(masterBBEntry.allBreakBulkMoves.size,3);
	self.assertEqual(wle.allRTQueueEntries.size,3);
	self.assertEqual(cargo.totalQuantity,30);
	
	self.machineSetdownTwinTask(fork2, fork2.currentQueueTask ,null,imv.id);
	self.assertEqual(masterBBEntry.allBreakBulkMoves.size,3);
	
	self.assertEqual(cargo.totalQuantity,30);
	self.assertEqual(imv.myMachineController.allTrackedItems.size, 1);
	self.assertEqual(imv.myMachineController.allTrackedItems.first.totalQuantity, 15);
		
	self.machineSetdownTwinTask(fork1, fork1.currentQueueTask ,null,imv.id);
	self.assertEqualMsg(masterBBEntry.allBreakBulkMoves.size,3,"masterBBEntry.allBreakBulkMoves.size should be 3");
	//self.assertEqual(wle.allRTQueueEntries.size,3);
	
	self.assertEqual(cargo.totalQuantity,30);
	self.assertEqual(imv.myMachineController.allTrackedItems.size, 1);
	self.assertEqual(imv.myMachineController.allTrackedItems.first.totalQuantity, 20);
	
	//	return;
	self.assertEqual(masterBBEntry.totalMoved,20);
	self.assertEqual(wle.quantity,20);
	self.assertEqual(wle.allRTQueueEntries.size,3);
	self.assertEqualMsg(masterBBEntry.allBreakBulkMoves.size,3,"masterBBEntry.allBreakBulkMoves.size is wrong -a");
	
	//***************************

	
	//***************************
	
	//the wle cargo is now the one split off and on the imv
	cargo:=imv.myMachineController.allTrackedItems.first;
	self.assertEqual(wle.myTrackedItem, cargo);
	//cargo moved to to imv 
	masterBBEntry:=wle.allRTQueueEntries.last;
	//break bulk master from imv to bs2 
	//cargo should be that on imv too
	self.assertEqual(masterBBEntry.allTasks.first.ti, cargo);
	
	
	
	
	//accept task
	self.machineAcceptSpecifiedTwinTask(fork1, masterBBEntry,null);
	self.opts.purge;
	self.opts.addAssoc("QUANTITY",5);
	self.machinePickup(fork1);
	self.assertEqual(wle.quantity,15);
	self.assertEqual(masterBBEntry.allBreakBulkMoves.size,1);
	self.assertEqual(wle.allRTQueueEntries.size,3);
	//cargo on imv 
	self.assertEqual(cargo.totalQuantity,15);
	
	
	
	
	self.machineAcceptSpecifiedTwinTask(fork2, masterBBEntry,null);
	self.opts.purge;
	self.opts.addAssoc("QUANTITY",10);
	self.machinePickup(fork2);
	self.assertEqual(wle.quantity,5);
	self.assertEqualMsg(masterBBEntry.allBreakBulkMoves.size,0,"masterBBEntry.allBreakBulkMoves.size should be 0-a");
	self.assertEqual(wle.allRTQueueEntries.size,3);
	//cargo on imv 
	self.assertEqual(cargo.totalQuantity,5);
	
	
	self.machineSetdownTwinTask(fork1, fork1.currentQueueTask ,null,bs2.id);
	self.assertEqualMsg(masterBBEntry.allBreakBulkMoves.size,0,"masterBBEntry.allBreakBulkMoves.size should be 0-b");
	self.assertEqual(wle.allRTQueueEntries.size,3);
	self.assertEqual(cargo.totalQuantity,5);
	self.assertEqual(cargo2.totalQuantity,55);
	
	self.machineAcceptSpecifiedTwinTask(fork1, masterBBEntry,null);
	self.opts.purge;
	self.opts.addAssoc("QUANTITY",5);
	self.machinePickup(fork1);
	self.assertEqual(wle.quantity,15);
	self.assertEqual(masterBBEntry.allBreakBulkMoves.size,3);
	self.assertEqual(wle.allRTQueueEntries.size,4);
	//cargo on imv 
	//cargo.inspect;
	self.assertEqual(cargo.totalQuantity,5);
	
	self.machineSetdownTwinTask(fork2, fork2.currentQueueTask ,null,bs2.id);
	self.assertEqual(masterBBEntry.allBreakBulkMoves.size,3);
	self.assertEqual(wle.allRTQueueEntries.size,4);
	self.assertEqual(cargo2.totalQuantity,65);
	
	self.machineSetdownTwinTask(fork1, fork1.currentQueueTask ,null,bs2.id);
	self.assertDeleted(masterBBEntry.String);
	self.assertDeleted(wle.String);
	self.assertEqual(cargo2.totalQuantity,70);
epilog
	app.isRTApp:=false;  
	delete tas;

end;</source>
    </JadeMethod>
    <JadeMethod name="uBreakBulkStorage" id="f910268c-3341-446b-9b19-1faf93ecb2f1">
        <source>uBreakBulkStorage();
/*

Date		Who		Reason
10 January 2017	cnwer1	Initial creation TFS 2884
25 AUG 2025 - this is a backup of the original tBreakBulkStorage, this will always fail
*/

vars
	vessel: CM_Vessel;
	voyage: CM_Voyage;
	bs1: CM_BlockStack;
	breakBulkCargoType, bulkCargoType : CM_CargoType;
	cargo, cargoOnSite: CM_TrackedItem;
	cargoId: String;
	lc: CM_LocationsController;
	height: Integer;
	expected, received, damaged: Integer;
	expectedWeight, receivedWeight: Decimal[14,4];
	txns: CM_TransactionSet;
	criteriaTypes : CM_YACriteriaTypeArray;
	pxyStorageTrigger : CM_StorageTrigger;
	triggers : CM_StorageTriggerByType;
		storageConfig	: CM_StorageConfig;
			values		: ObjectArray;
			criteria	: IntegerArray;
			storageDetail : CM_StorageDetail;
	txn 		: CM_Transaction;
	firstReceive,
	receiveTxn,
	storageTxn: CM_TITransaction;
	newDT : TimeStamp;
begin
	
	vessel := self.addVesselWithHolds("UT_VHOLDS", 2, 2);
	voyage := self.addVoyageWithGeneralCargoStruc("UT_VHOLDS", vessel.name, vessel.myOperator.code,	self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 0);
	bs1 := self.addBlockStack("UTBS1", 9999, null);
	breakBulkCargoType := app.myRoot.getCargoTypeFromAbbrev("UTREBAR");
	bulkCargoType  := app.myRoot.getCargoTypeFromAbbrev("UTCOAL");
	self.getTerminal.findLocationFromString("UT_VHOLDS 0101", true, lc, height); 

	self.deleteStorageConfig( false );
	
	create criteriaTypes transient;
	criteriaTypes.add(app.myRoot.allYACriteriaTypes[YACriteriaType_CargoType]);
	
	// PAR 36472
	create pxyStorageTrigger transient;
	 pxyStorageTrigger.setProxy( CargoSplitMerge, false, null);
	 
	 create triggers transient;
	 triggers.add(pxyStorageTrigger);
	
	storageConfig := self.createStorageConfig(criteriaTypes, triggers, null, null, true, true,
											  null, CM_StorageConfig.ShipReceivalActualDischarge, CM_StorageConfig.ShipReleaseActualLoad, null, null,null, -1, -1, -1);

	create values transient;
	values.add(breakBulkCargoType);
	create criteria transient;
	criteria.add(YACriteriaType_CargoType);
	storageDetail:=self.addStorageDetail(storageConfig,"UTREBAR Storage",criteria,values,0,0,false,false,0,CM_StorageDetail.RecievalDateRuleFirstByLocn,true,null); //21.07.2017 cnwma1 TFS #5409
	self.assertNotNull(storageDetail);
	
	// Move break bulk cargo in parts
/*	cargoId := "UTREBAR9999A";
	deleteCargo(cargoId, breakBulkCargoType);
	cargo := self.addCargoBreakBulkAtLocation(cargoId, breakBulkCargoType, 50, lc, null, TI_IMEX_STATUS_IMPORT, voyage, vessel.myOperator);
	self.opts.addAssoc("TotalWeight", 50);
	self.updateTI(cargo);
		assertEqual(cargo.totalQuantity, 50);
	self.opts.purge;
	
	self.assertNull(cargo.getLastTransOfType(	TRANS_TYPE_STORAGE));
	
	moveBreakBulk(cargo, bs1, 20);
	
	cargoOnSite := getTrackedItemAtLocation(cargoId, bs1.myLocationsController);
		expected := cargoOnSite.getShipReceivalQuantity();
		assertEqual(expected, 20);
		expectedWeight := cargoOnSite.getShipReceivalWeight();
		assertEqual(expectedWeight, 20.Decimal);
		received := cargoOnSite.getShipDischargeQuantity();
		assertEqual(received, 20);
		receivedWeight := cargoOnSite.getShipDischargeWeight();
		assertEqual(receivedWeight, 20.Decimal);
		
	receiveTxn:=cargoOnSite.getLastTransOfType(	TRANS_TYPE_REC_SHIP);
	self.assertNotNull(receiveTxn);	
	beginTransaction;
	receiveTxn.updateDateTime(receiveTxn.dateTime.addDays(-2));	
	commitTransaction;
	
	self.assertNull(cargo.getLastTransOfType(	TRANS_TYPE_STORAGE));
	
		
	moveBreakBulk(cargo, bs1, 25);
		expected := cargoOnSite.getShipReceivalQuantity();
		assertEqual(expected, 45);
		expectedWeight := cargoOnSite.getShipReceivalWeight();
		assertEqual(expectedWeight, 45.Decimal);
		received := cargoOnSite.getShipDischargeQuantity();
		assertEqual(received, 45);
		receivedWeight := cargoOnSite.getShipDischargeWeight();
		assertEqual(receivedWeight, 45.Decimal);
	
	self.assertNull(cargo.getLastTransOfType(	TRANS_TYPE_STORAGE));
	
	moveBreakBulk(cargo, bs1, 0); // removing remaining
		expected := cargoOnSite.getShipReceivalQuantity();
		assertEqual(expected, 50);
		expectedWeight := cargoOnSite.getShipReceivalWeight();
		assertEqual(expectedWeight, 50.Decimal);
		received := cargoOnSite.getShipDischargeQuantity();
		assertEqual(received, 50);
		receivedWeight := cargoOnSite.getShipDischargeWeight();
		assertEqual(receivedWeight, 50.Decimal);
	
	storageTxn:=cargo.getLastTransOfType(	TRANS_TYPE_STORAGE);
	self.assertNotNull(storageTxn);
	
	//storage should be only created on last and with the first receival txn
	self.assertEqual(storageTxn.CM_Storage.startTransaction, receiveTxn);*/
	
	// change storage detail to so storage created agains the last receival txn
	beginTransaction;
	storageDetail.setPropertyValue(CM_StorageDetail::receivalDateRule.name,CM_StorageDetail.RecievalDateRuleLastByLocn);
	commitTransaction;
	
	//DO THE SAME AS ABOVE
	// Move break bulk cargo in parts
	cargoId := "UTREBAR9999B";
	deleteCargo(cargoId, breakBulkCargoType);
	cargo := self.addCargoBreakBulkAtLocation(cargoId, breakBulkCargoType, 50, lc, null, TI_IMEX_STATUS_IMPORT, voyage, vessel.myOperator);
	self.opts.addAssoc("TotalWeight", 50);
	self.updateTI(cargo);
	assertEqual(cargo.totalQuantity, 50);
	self.opts.purge;
	
	moveBreakBulk(cargo, bs1, 20);
	
	cargoOnSite := getTrackedItemAtLocation(cargoId, bs1.myLocationsController);
		expected := cargoOnSite.getShipReceivalQuantity();
		assertEqual(expected, 20);
		expectedWeight := cargoOnSite.getShipReceivalWeight();
		assertEqual(expectedWeight, 20.Decimal);
		received := cargoOnSite.getShipDischargeQuantity();
		assertEqual(received, 20);
		receivedWeight := cargoOnSite.getShipDischargeWeight();
		assertEqual(receivedWeight, 20.Decimal);
		
	receiveTxn:=cargoOnSite.getLastTransOfType(	TRANS_TYPE_REC_SHIP);
	self.assertNotNull(receiveTxn);	
	beginTransaction;
	receiveTxn.updateDateTime(receiveTxn.dateTime.addDays(-2));	
	commitTransaction;
	
	self.assertNull(cargo.getLastTransOfType(	TRANS_TYPE_STORAGE));
	
		
	moveBreakBulk(cargo, bs1, 25);
		expected := cargoOnSite.getShipReceivalQuantity();
		assertEqual(expected, 45);
		expectedWeight := cargoOnSite.getShipReceivalWeight();
		assertEqual(expectedWeight, 45.Decimal);
		received := cargoOnSite.getShipDischargeQuantity();
		assertEqual(received, 45);
		receivedWeight := cargoOnSite.getShipDischargeWeight();
		assertEqual(receivedWeight, 45.Decimal);
	
	self.assertNull(cargo.getLastTransOfType(	TRANS_TYPE_STORAGE));
	
	moveBreakBulk(cargo, bs1, 0); // removing remaining
		expected := cargoOnSite.getShipReceivalQuantity();
		assertEqual(expected, 50);
		expectedWeight := cargoOnSite.getShipReceivalWeight();
		assertEqual(expectedWeight, 50.Decimal);
		received := cargoOnSite.getShipDischargeQuantity();
		assertEqual(received, 50);
		receivedWeight := cargoOnSite.getShipDischargeWeight();
		assertEqual(receivedWeight, 50.Decimal);
	
	receiveTxn:=cargoOnSite.getLastTransOfType(	TRANS_TYPE_REC_SHIP);
	self.assertNotNull(receiveTxn);	
	
	storageTxn:=cargo.getLastTransOfType(	TRANS_TYPE_STORAGE);
	self.assertNotNullMsg(storageTxn, "Expecting Transaction of type: TRANS_TYPE_STORAGE | " &amp; "storageTxn");
	
	//storage should be only created on last and with the last receival txn
	self.assertEqual(storageTxn.CM_Storage.startTransaction, receiveTxn);
	
		// change storage detail to so storage created agains the last receival txn and storage creted with every receival
	beginTransaction;
	storageDetail.setPropertyValue(CM_StorageDetail::receivalDateRule.name,CM_StorageDetail.RecievalDateRuleLastByLocn);
	storageDetail.setPropertyValue(CM_StorageDetail::noStorageIfNotFullyReceived.name,false);
	commitTransaction;
	
	create txns transient;
	txns.clear;
	//DO THE SAME AS ABOVE
	// Move break bulk cargo in parts
	cargoId := "UTREBAR9999C";
	deleteCargo(cargoId, breakBulkCargoType);
	cargo := self.addCargoBreakBulkAtLocation(cargoId, breakBulkCargoType, 50, lc, null, TI_IMEX_STATUS_IMPORT, voyage, vessel.myOperator);
	self.opts.addAssoc("TotalWeight", 50);
	self.updateTI(cargo);
	assertEqual(cargo.totalQuantity, 50);
	self.opts.purge;
	
	moveBreakBulk(cargo, bs1, 20);
	
	cargoOnSite := getTrackedItemAtLocation(cargoId, bs1.myLocationsController);
		expected := cargoOnSite.getShipReceivalQuantity();
		assertEqual(expected, 20);
		expectedWeight := cargoOnSite.getShipReceivalWeight();
		assertEqual(expectedWeight, 20.Decimal);
		received := cargoOnSite.getShipDischargeQuantity();
		assertEqual(received, 20);
		receivedWeight := cargoOnSite.getShipDischargeWeight();
		assertEqual(receivedWeight, 20.Decimal);
		
	receiveTxn:=cargoOnSite.getLastTransOfType(	TRANS_TYPE_REC_SHIP);
	self.assertNotNull(receiveTxn);	
	beginTransaction;
	receiveTxn.updateDateTime(receiveTxn.dateTime.addDays(-2));	
	commitTransaction;
	
	storageTxn:=cargo.getLastTransOfType(	TRANS_TYPE_STORAGE);
	self.assertNotNull(storageTxn);
	txns.addNoDuplicates(receiveTxn,false);
	txns.addNoDuplicates(storageTxn,false);
	
	
		
	moveBreakBulk(cargo, bs1, 25);
		expected := cargoOnSite.getShipReceivalQuantity();
		assertEqual(expected, 45);
		expectedWeight := cargoOnSite.getShipReceivalWeight();
		assertEqual(expectedWeight, 45.Decimal);
		received := cargoOnSite.getShipDischargeQuantity();
		assertEqual(received, 45);
		receivedWeight := cargoOnSite.getShipDischargeWeight();
		assertEqual(receivedWeight, 45.Decimal);
	
			
	receiveTxn:=cargoOnSite.getLastTransOfType(	TRANS_TYPE_REC_SHIP);
	self.assertNotNull(receiveTxn);		
	storageTxn:=cargo.getLastTransOfType(	TRANS_TYPE_STORAGE);
	self.assertNotNull(storageTxn);
	txns.addNoDuplicates(receiveTxn,false);
	txns.addNoDuplicates(storageTxn,false);
	
	
	//self.assertNull(cargo.getLastTransOfType(	TRANS_TYPE_STORAGE));
	
	moveBreakBulk(cargo, bs1, 0); // removing remaining
		expected := cargoOnSite.getShipReceivalQuantity();
		assertEqual(expected, 50);
		expectedWeight := cargoOnSite.getShipReceivalWeight();
		assertEqual(expectedWeight, 50.Decimal);
		received := cargoOnSite.getShipDischargeQuantity();
		assertEqual(received, 50);
		receivedWeight := cargoOnSite.getShipDischargeWeight();
		assertEqual(receivedWeight, 50.Decimal);
	
	
	
	receiveTxn:=cargoOnSite.getLastTransOfType(	TRANS_TYPE_REC_SHIP);
	self.assertNotNull(receiveTxn);	
	
	storageTxn:=cargo.getLastTransOfType(	TRANS_TYPE_STORAGE);
	self.assertNotNull(storageTxn);
	txns.addNoDuplicates(receiveTxn,false);
	txns.addNoDuplicates(storageTxn,false);
	//storage should be only created on last and with the last receival txn
	self.assertEqual(storageTxn.CM_Storage.startTransaction, receiveTxn);
	
	self.assertEqual(txns.size, 4);  //3 receival &amp; 1 storage;
	foreach txn in txns do
		if txn.isKindOf(CM_Storage) then
			self.assertEqual(txn.CM_Storage.startTransaction, receiveTxn);
		endif;
	endforeach;
	
	
		// change storage detail to so storage created agains the last receival txn and storage creted with every receival
	beginTransaction;
	storageDetail.setPropertyValue(CM_StorageDetail::receivalDateRule.name,CM_StorageDetail.RecievalDateRuleFirstByTerm);
	storageDetail.setPropertyValue(CM_StorageDetail::noStorageIfNotFullyReceived.name,false);
	commitTransaction;
	

	txns.clear;
	//DO THE SAME AS ABOVE
	// Move break bulk cargo in parts
	cargoId := "UTREBAR9999D";
	deleteCargo(cargoId, breakBulkCargoType);
	cargo := self.addCargoBreakBulkAtLocation(cargoId, breakBulkCargoType, 50, lc, null, TI_IMEX_STATUS_IMPORT, voyage, vessel.myOperator);
	self.opts.addAssoc("TotalWeight", 50);
	self.updateTI(cargo);
	assertEqual(cargo.totalQuantity, 50);
	self.opts.purge;
	
	moveBreakBulk(cargo, bs1, 20);
	
	cargoOnSite := getTrackedItemAtLocation(cargoId, bs1.myLocationsController);
		expected := cargoOnSite.getShipReceivalQuantity();
		assertEqual(expected, 20);
		expectedWeight := cargoOnSite.getShipReceivalWeight();
		assertEqual(expectedWeight, 20.Decimal);
		received := cargoOnSite.getShipDischargeQuantity();
		assertEqual(received, 20);
		receivedWeight := cargoOnSite.getShipDischargeWeight();
		assertEqual(receivedWeight, 20.Decimal);
		
	receiveTxn:=cargoOnSite.getLastTransOfType(	TRANS_TYPE_REC_SHIP);
	self.assertNotNull(receiveTxn);	
	beginTransaction;
	receiveTxn.updateDateTime(receiveTxn.dateTime.addDays(-2));	
	commitTransaction;
	firstReceive:=receiveTxn;
	storageTxn:=cargo.getLastTransOfType(	TRANS_TYPE_STORAGE);
	self.assertNotNull(storageTxn);
	txns.addNoDuplicates(receiveTxn,false);
	txns.addNoDuplicates(storageTxn,false);
	
	
		
	moveBreakBulk(cargo, bs1, 25);
		expected := cargoOnSite.getShipReceivalQuantity();
		assertEqual(expected, 45);
		expectedWeight := cargoOnSite.getShipReceivalWeight();
		assertEqual(expectedWeight, 45.Decimal);
		received := cargoOnSite.getShipDischargeQuantity();
		assertEqual(received, 45);
		receivedWeight := cargoOnSite.getShipDischargeWeight();
		assertEqual(receivedWeight, 45.Decimal);
	
			
	receiveTxn:=cargoOnSite.getLastTransOfType(	TRANS_TYPE_REC_SHIP);
	self.assertNotNull(receiveTxn);		
	storageTxn:=cargo.getLastTransOfType(	TRANS_TYPE_STORAGE);
	self.assertNotNull(storageTxn);
	txns.addNoDuplicates(receiveTxn,false);
	txns.addNoDuplicates(storageTxn,false);
	
	
	//self.assertNull(cargo.getLastTransOfType(	TRANS_TYPE_STORAGE));
	
	moveBreakBulk(cargo, bs1, 0); // removing remaining
		expected := cargoOnSite.getShipReceivalQuantity();
		assertEqual(expected, 50);
		expectedWeight := cargoOnSite.getShipReceivalWeight();
		assertEqual(expectedWeight, 50.Decimal);
		received := cargoOnSite.getShipDischargeQuantity();
		assertEqual(received, 50);
		receivedWeight := cargoOnSite.getShipDischargeWeight();
		assertEqual(receivedWeight, 50.Decimal);
	
	
	receiveTxn:=cargoOnSite.getLastTransOfType(	TRANS_TYPE_REC_SHIP);
	self.assertNotNull(receiveTxn);	
	
	storageTxn:=cargo.getLastTransOfType(	TRANS_TYPE_STORAGE);
	self.assertNotNull(storageTxn);
	txns.addNoDuplicates(receiveTxn,false);
	txns.addNoDuplicates(storageTxn,false);
		
	self.assertEqual(txns.size, 4);  //3 receival &amp; 1 storage;
	foreach txn in txns do
		if txn.isKindOf(CM_Storage) then
			self.assertEqual(txn.CM_Storage.startTransaction, firstReceive);
		endif;
	endforeach;
	
	
epilog
	triggers.purge;
	delete triggers;
	delete criteriaTypes;
	delete values;
	delete criteria;
	delete txns;
	self.deleteStorageConfig( true );
end;</source>
    </JadeMethod>
