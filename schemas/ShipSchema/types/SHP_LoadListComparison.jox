    <JadeMethod name="doPrint" id="12c26b8c-d434-4fcc-9f20-595e51aa43c2">
        <updating/>
        <source>doPrint() updating;
// ---------------------------------------------------------------------------
// 08/03/2011	cnwmh5	PAR #27142 - Change to local variable rather than self for handleDeleteObject exception
// ----------   ----------  --------------------------------------------------
vars
	caption 	: String;
	header		: String;
	isInvalid	: Boolean;				// cnwrl1 16/08/2010 PAR 24337
	iEdition	: Integer;				// cnwrl1 16/08/2010 PAR 24337
	currentVoyage	: CM_Voyage;
begin
	self.testRecompareAll();
	
	// cnwrl1 16/08/2010 PAR 24337 - start of coding
	// Need to handle the case where the voyage has been deleted from the combo box.
	on Exception do app.handleDeletedObject( exception, currentVoyage, isInvalid );
	currentVoyage := self.myCurrentVoyage;
	if currentVoyage &lt;&gt; null then
		// Check availability by doing a de-reference
		iEdition	:= currentVoyage.edition;
		if isInvalid then
			// Attempt to correct the issue by rebuilding the combo and let
			// the users select again - will default to app.myCurrentVoyage.
			self.doCmbVoyageBuild();
			self.doCmbVoyageClick();
		endif;
	endif;
	// cnwrl1 16/08/2010 PAR 24337 - end of coding
	
	// Par 11293 Please don't use colons in report names as it screws emailing.
	//caption := 'Load List Comparison ' &amp; self.cmbView.text;
	//par 18603
	caption := app.getErrorString(List_Comparison) &amp; ' ' &amp; self.cmbView.text;
	if currentVoyage &lt;&gt; null then
		if self.cmbView.text = self.VIEW_DISCREPS then
			header := caption &amp; CrLf  &amp; " Voyage - " &amp; currentVoyage.code &amp; "   Vessel - " &amp; currentVoyage.vesselName &amp; " Total Items - " &amp; numOfDiscrepTI.asStringJMT;
		else
			header := caption &amp; CrLf  &amp; " Voyage - " &amp; currentVoyage.code &amp; "   Vessel - " &amp; currentVoyage.vesselName &amp; " Total Items - " &amp; (self.tblData.rows-1).asStringJMT;
		endif;
	endif;
	
	self.myAssistant.showReportOptions(self.tblData, caption ,header, true);
	
epilog
	
end;
</source>
    </JadeMethod>
    <JadeMethod name="doRTSSave" id="a9a07021-1bb2-4765-9f15-5609b8f45235">
        <updating/>
        <source>doRTSSave(): Boolean updating;
//----------------------------------------------------------------
//	Created:	03 February 2004	by Jason Chapman  (cnwjc2)
//
//	Return false if cancelled by user/system 
//
//----------------------------------------------------------------
vars
	returnVal	: Integer;
	iEdition	: Integer;								// cnwrl1 11/08/2010 PAR 24337
	isInvalid	: Boolean;								// cnwrl1 11/08/2010 PAR 24337
	object		: Object;								// cnwrl1 11/08/2010 PAR 24337
	tiRTS		: CM_TIArray;
	tiNotRTS	: CM_TIArray;
	ediTI		: CM_EDITrackedItem;
	passport	: CM_Passport;
	errors		: CM_ErrorSet;
	cmifMonitor	: CMIF_Monitor;
	theResult : Integer;	//14 Jan 2020 NDL	TFS 46815
	
begin
	on Exception do app.handleDeletedObject( exception, object, isInvalid );	// cnwrl1 11/08/2010 PAR 24337
	
	passport := app.myPassport;
	
	if not self.myLLCAgent.comparisonComplete then 
		app.msgBox(app.getErrorString(Comparison_Has_Not_Run) ,self.caption, MsgBox_OK_Only + MsgBox_Information_Icon);
		return true;
	endif;

	returnVal := app.msgBox(app.getErrorString(RTSSave_Are_You_Sure),self.caption, MsgBox_Yes_No_Cancel + MsgBox_Question_Mark_Icon);
	
	//do you want to update RTS based on the current comp?		
	if returnVal = MsgBox_Return_Cancel then
		//stop
		return false;
	elseif returnVal = MsgBox_Return_No then
		//do nothing but continue in calling method
		return true;
	endif;
	
	//this update will cause unwanted notes for all TI's
	endNotificationForSubscriber(self);

	//must be MsgBox_Return_Yes
	if passport.myCMIFMonitor = null then
		create cmifMonitor transient;
		cmifMonitor.myParent := self;
		passport.setMyCMIFMonitor(cmifMonitor);
	endif;
	self.initModalDialog();
	self.lblModalMessage.caption := Cr &amp; "Updating Ready to Ship flag";
	self.frmModalDialog.visible := true;
	self.doWindowEvents(0);

	create tiRTS transient;
	create tiNotRTS transient;
	create errors transient;
	
	foreach ediTI in self.myLLCAgent.allMatchingTIs do
		// cnwrl1 11/08/2010 PAR 24337 - start of coding
		// Make sure the TrackedItem still exists by doing a de-reference
		object		:= ediTI.CM_EDILoadListComparisonTI.myTrackedItem;
		iEdition	:= object.edition();
		if isInvalid then
			self.myLLCAgent.validateAgentReferences( object );
			isInvalid	:= false;	// allow the next one to be OK!
			continue;				// skip this one and continue around loop
		endif;
		// cnwrl1 11/08/2010 PAR 24337 - end of coding
		
		tiRTS.add(ediTI.CM_EDILoadListComparisonTI.myTrackedItem);
	endforeach;
	
	foreach ediTI in self.myLLCAgent.allDiscrepancyTIs do
		// cnwrl1 11/08/2010 PAR 24337 - start of coding
		// Make sure the TrackedItem still exists by doing a de-reference
		object		:= ediTI.CM_EDILoadListComparisonTI.myTrackedItem;
		iEdition	:= object.edition();
		if isInvalid then
			self.myLLCAgent.validateAgentReferences( object );
			isInvalid	:= false;	// allow the next one to be OK!
			continue;				// skip this one and continue around loop
		endif;
		// cnwrl1 11/08/2010 PAR 24337 - end of coding
		
		tiNotRTS.add(ediTI.CM_EDILoadListComparisonTI.myTrackedItem);
	endforeach;
	
	self.rtsSaved := true;
	//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxUA.trxUpdateTIsReadyToShip(tiRTS, true, passport);
	
		if app.myPassport.trxCompletedOK then
			break;
		else
			theResult := app.showErrorWarningDialog('Update RTS', passport, ErrWarnMode_Update);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		self.rtsSaved := false;
		break;
		
	endwhile;

	if self.rtsSaved then
		//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
		while true do
		
			app.myTrxUA.trxUpdateTIsReadyToShip(tiNotRTS, false, passport);
		
			if app.myPassport.trxCompletedOK then
				break;
			else
				theResult := app.showErrorWarningDialog('Update RTS', passport, ErrWarnMode_Update);
				if app.myPassport.noErrors and theResult = IDOK then
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
			endif;
			
			self.rtsSaved := false;
			break;
			
		endwhile;
		
	endif;
	
	if self.cmbView.text = null then
		self.cmbView.text := self.VIEW_MATCHING;
	endif;
	
	self.doShowView(self.cmbView.text,false);
	self.reDoNotes();
	
	return self.rtsSaved;
	
epilog
	delete tiRTS;
	delete tiNotRTS;
	delete errors;
	delete cmifMonitor;
	self.frmModalDialog.visible := false;
	
end;
</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doRefresh" id="8935b81e-ce7f-4df5-b7cf-0552ae6595dc">
        <updating/>
        <source>doRefresh() updating, protected;
//--------------------------------------------------
// Created:	05 November 2003 By: cnwgd1
//--------------------------------------------------
vars

begin	
	inheritMethod();
	
	/* //- cnwmd1, Par 23513 - Doesn't remove newly added prenote items
	if self.comparisonMode &lt;&gt; VOYAGE_DETAILS_COMPARISON then
		self.doRunComparisonClick(true);
	else
		self.initiateCompareVoyDet(true);
	endif;*/
	
	//+ cnwmd1 Par 23513
	if self.comparisonMode &lt;&gt; VOYAGE_DETAILS_COMPARISON then
		self.doRunComparisonClick(false);
	else
		self.initiateCompareVoyDet(false);
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
