    <JadeMethod name="outputAsXML" id="5253085e-6fb8-4207-86e1-6715acb0badc">
        <source>outputAsXML(_xmlHdrTag : String) : String;
// ---------------------------------------------------------------------------
// Created:     16 July 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	xmlStr,	
	childStr	: String;
	menEnt		: CM_MenuEntity;
	
begin

	foreach menEnt in self.allChildren do
		if (not menEnt.isKindOf(CM_MenuItem)) or menEnt.isKindOf(CM_QryReportUser) then
			continue;
		endif;
		childStr := childStr &amp; 
			self.formatAsXML(XMLTag_Id, menEnt.CM_MenuItem.menuId);
	endforeach;

	if childStr &lt;&gt; null then
		childStr := self.formatAsXMLPrefix(XMLTag_Children) &amp;
					childStr &amp;
					self.formatAsXMLSuffix(XMLTag_Children);
	endif;
		
	xmlStr := self.formatAsXMLPrefix(_xmlHdrTag) &amp; 
			self.formatAsXML(XMLTag_Id, MenuRootID) &amp;
//			self.formatAsXML(XMLTag_Heading, self.heading) &amp;
			self.formatAsXML(XMLTag_PictureButton, self.pictureStringButton) &amp; 
			self.formatAsXML(XMLTag_PictureButtonDown, self.pictureStringButtonDown) &amp; 
			self.formatAsXML(XMLTag_PictureIcon, self.pictureStringIcon) &amp; 
//			self.formatAsXML(XMLTag_ToolTip, self.toolTip) &amp; 
			childStr &amp;
			self.formatAsXMLSuffix(_xmlHdrTag);

	return xmlStr;

end;</source>
        <Parameter name="_xmlHdrTag" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="removeFoldersWithNoChildren" id="cd848ccd-9fd2-4ae5-8504-4e88073557c3">
        <source>removeFoldersWithNoChildren();
// ---------------------------------------------------------------------------
// Created:     16 April 2003 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	delSet : CM_MenuEntitySet;

begin

	create delSet transient;
	self.getItemsWithNoChildren(delSet);
	
	if (not delSet.isEmpty) then
		delSet.purge;
	endif;

epilog
	delete delSet;
end;</source>
    </JadeMethod>
    <JadeMethod name="removeItemsWithNoPerm" id="98259265-7ee5-4763-8bd6-bba7cdd7d544">
        <source>removeItemsWithNoPerm();
// ---------------------------------------------------------------------------
// Created:     03 December 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	delSet : CM_MenuEntitySet;

begin

	create delSet transient;
	self.getItemsToDelete(delSet);
	
	if (not delSet.isEmpty) then
		delSet.purge;
	endif;

epilog
	delete delSet;
end;</source>
    </JadeMethod>
    <JadeMethod name="resetMenu" id="a7e150ce-6ec9-4103-aaef-9221becc6a79">
        <updating/>
        <source>resetMenu(_source : CM_MenuRoot; _clearFirst : Boolean) updating;
// ---------------------------------------------------------------------------
// Created:     03 December 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	menuEnt	: CM_MenuEntity;

begin
	exclusiveLock(self);

	if _clearFirst then
		self.clearMenu();
	endif;

	// First pass to add any items
	foreach menuEnt in _source.allChildren do
		menuEnt.addToUserMenuFromMenu(self);
	endforeach;
	self.removeItemsWithNoPerm();
	self.removeFoldersWithNoChildren();

end;</source>
        <Parameter name="_source" type="CM_MenuRoot"/>
        <Parameter name="_clearFirst" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setFromXML" id="0261de01-8d2e-4853-9936-b69c659cf83f">
        <updating/>
        <source>setFromXML(_str : String) updating;
// ---------------------------------------------------------------------------
// Created:     16 July 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	idStr,
	childStr	: String;
	pos			: Integer;
	tmpItem		: CM_MenuItem;
	dict		: CM_MenuItemByTypeMenuIdDict;
	
begin
/*
&lt;Children&gt;
&lt;Id&gt;GTE123&lt;/Id&gt;
&lt;Id&gt;GTE222&lt;/Id&gt;
&lt;Id&gt;GTE446&lt;/Id&gt;
&lt;/Children&gt;
*/

	self.pictureStringButton	:= _str.cnEcGetTagValueOfName(XMLTag_PictureButton);
	self.pictureStringButtonDown:= _str.cnEcGetTagValueOfName(XMLTag_PictureButtonDown);
	self.pictureStringIcon		:= _str.cnEcGetTagValueOfName(XMLTag_PictureIcon);

	dict := self.getMenuItemsDict();
	if dict = null then
		app.writeStatement( class.name &amp; '::' &amp; method.name &amp; '  ERROR - child not handled');
		return;
	endif;

	self.allChildren.clear;

	childStr := _str.cnEcGetTagValueOfName(XMLTag_Children);
	
	pos := 1;
	while (pos &lt;&gt; 0) do
		idStr := childStr.cnEcGetNextTagValueOfName(XMLTag_Id, pos);
		
		if idStr &lt;&gt; null then
			tmpItem := dict[MenuType_DetailSystem, idStr];
			if tmpItem = null then
				tmpItem := dict[MenuType_HeaderSystem, idStr];
			endif;
			
			if tmpItem &lt;&gt; null then
				tmpItem.setParent(self);
			else
				app.writeStatement( class.name &amp; '::' &amp; method.name &amp; '  unknown child &gt;&gt;' &amp; idStr &amp; '&lt;&lt;');
			endif;
		endif;
	endwhile;

end;</source>
        <Parameter name="_str" type="String"/>
    </JadeMethod>
</Class>
