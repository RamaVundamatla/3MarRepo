    <JadeMethod name="rs1" id="d2c05f6d-e771-4daa-9e23-ffdfd979fcb0">
        <source>rs1();

vars

	str : String;
	terminal : CM_Terminal;
	job : CM_VoyageJob;
	wles : CM_WLESet;
	wle : CM_WorkListEntry;
begin
	app.initialize;
	terminal := app.myRoot.allTerminals["UT"];
	if terminal = null then
		app.writeStatement('Can not find required terminal ' &amp; "UT");
		return;
	endif;
	app.myPassport.setMyTerminal(terminal);
	app.myPassport.setMyUserFromCode(SUPERUSER_Str);
	job := "2271.491404".asOid.CM_VoyageJob;
	create wles transient;
	beginTransaction;
	job.unQueueJob(app.myPassport);
	foreach wle in job.workListEntries do
		wles.add(wle);
	endforeach;
	foreach wle in wles do
		wle.unQueueWLE(app.myPassport);
	endforeach;
	commitTransaction;
	beginTransaction;
	job.unplanFutureMove(PLANNING_MODE, null, app.myPassport);
	job.unplanFutureMove(QUEUE_MODE, null, app.myPassport);
	commitTransaction;
	beginTransaction;
	job.erase(NORMAL_ERASE);
	commitTransaction;
epilog
	delete wles;
end;
</source>
    </JadeMethod>
