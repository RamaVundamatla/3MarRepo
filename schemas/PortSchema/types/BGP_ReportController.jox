    </JadeMethod>
    <JadeMethod name="setAttributesForCreate" id="12870c40-407a-4fc1-ad8d-a1087af0e319">
        <updating/>
        <source>setAttributesForCreate() updating, protected;

vars

begin
	
	self.name				:= 'Reports';
	self.schemaName			:= 'UiCommonSchema';
	// Need this for 7.2.3b upgrade.
	self.allRequestClassesToProcess.clear();
	self.allRequestClassesToProcess.add(BGP_ReportRequest.name);
	// Even though the system doesn't need this class to pick
	// up the notification it needs it for the BGP window display.
	self.allRequestClassesToProcess.add(BGP_ReportPDFEmailerRequest.name);
	self.allRequestClassesToProcess.add(BGP_RptPDFEmailerFileRequest.name);	
	self.allRequestClassesToProcess.add(BGP_RptPrintEmailPDFRequest.name);	
	self.allRequestClassesToProcess.add(BGP_ReportRequestPackageRunner.name);	
		
	self.isEditable			:= true;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setCMIF" id="00777e3a-a3ba-411b-a80a-9ad09ed484c3">
        <source>setCMIF(_cmif: CMIF_BGPManagerChildren input);
// -------------------------------------------
// Created 12 April 2005 by cnwdvb1
// -------------------------------------------
vars

begin
	inheritMethod(_cmif);
	_cmif.myPDFPrinter := self.myPDFPrinter;
	_cmif.tempFileLocation 		:= self.tempFileLocation;

end;</source>
        <Parameter name="_cmif" type="CMIF_BGPManagerChildren" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="8c356ee7-72a4-4894-92e3-0690ad18123d">
        <updating/>
        <source>setForUpdate(_cmif: CMIF_BGPManagerChildren) updating;
// -------------------------------------------
// Created 12 April 2005 by cnwdvb1
// -------------------------------------------
vars

begin
	inheritMethod(_cmif);
	self.myPDFPrinter := _cmif.myPDFPrinter;
	self.tempFileLocation := _cmif.tempFileLocation;

end;</source>
        <Parameter name="_cmif" type="CMIF_BGPManagerChildren"/>
    </JadeMethod>
</Class>
