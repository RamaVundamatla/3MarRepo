	delete self.portLogo;
	

end;</source>
    </JadeMethod>
    <JadeMethod name="getOperatorCodeDesc" id="3eaee935-31e1-4236-88c4-c385ced20564">
        <source>getOperatorCodeDesc(): String;
//24 February 2010	cnwml2


vars

begin	
	if self.myOperator &lt;&gt; null then
		return self.myOperator.code &amp; " - " &amp; self.myOperator.description;
	else
		return null;
	endif;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTerminalString" id="1c38ff96-6527-4bb9-b162-5563318a8648">
        <source>getTerminalString(): String;
//----------------------------------------------------------------
//	Created:	10 November 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	str		: String;
	term	: CM_Terminal;
begin

	foreach term in self.allTerminals do
		if str = null then
			str := term.code;
		else
			str := str &amp; ", " &amp; term.code;
		endif;
	
	endforeach;

	return str;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="noOutputReturned" id="54ccd280-0679-4baa-a774-e386a267bd00">
