    <JadeMethod name="getAuditTextForProperty" id="77b37fde-21da-4472-8e54-ac7a25b71777">
        <source>getAuditTextForProperty(_property: Property): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
07 September 2009	cnwndl1	Initial creation

*/

vars

	propName	: String;

begin

	propName	:=	_property.name;

	if propName = CMEVT_BookingRefDiscrep::isClosed.name then  
		if self.isClosed then
			return self.formatAuditText(propName, app.getErrorString(Closed) );	
		else
			return self.formatAuditText(propName, app.getErrorString(Pending) );	
		endif;
	elseif propName = CMEVT_BookingRefDiscrep::remarks.name then
		return self.formatAuditText(propName, self.remarks);
	else
		return inheritMethod(_property);
	endif;

epilog

end;</source>
        <Parameter name="_property" type="Property"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getBookingRefDiscrepFieldValue" id="00ebc44d-4ea8-4766-b57d-5ac603f4fdc5">
        <source>getBookingRefDiscrepFieldValue( _fieldName : String ):CM_BookingRefDiscrepFieldValue ;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
07 September 2009	cnwndl1	Initial creation

*/

vars

	bookingRefDiscrepFieldValue : CM_BookingRefDiscrepFieldValue;
	
begin

	if self.allBookingRefDiscrepFieldVs.isEmpty then
		return null;
	endif;
	bookingRefDiscrepFieldValue := self.allBookingRefDiscrepFieldVs.getAtKey(_fieldName);

	return bookingRefDiscrepFieldValue;

epilog

end;</source>
        <Parameter name="_fieldName" type="String"/>
        <ReturnType type="CM_BookingRefDiscrepFieldValue"/>
    </JadeMethod>
