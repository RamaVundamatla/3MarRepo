    <JadeMethod name="getSelectedCargoType" id="87cae34c-3d61-4573-82e7-496ee4659082">
        <source>getSelectedCargoType(): CM_CargoType;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 September 2008	cnwkao1	Initial creation - based on WebSchema implementation
12 Aug 2022 navtnr20 Bug 52451: MTN - WebServices not using getObjectOfTypeFromOid
*/

vars
	tmpStr		: String;
	cargoType	: CM_CargoType;
	reportParam	: WS_ReportParameter;
	
begin

	reportParam := self.allWSReportParams.getAtKey(ETRow_CargoType);
	if reportParam &lt;&gt; null then
		tmpStr := reportParam.value;
	endif;	
	
	//global.getExtraData(self.allQueryCriteria, ETRow_CargoType, tmpStr);
	
	//cargoType := tmpStr.asOid.CM_CargoType;	//12.08.2022 navtnr20 52451
