    <JadeMethod name="getTreeDescription" id="ce36f710-cf29-46cd-b0bd-96802c5da937">
        <source>getTreeDescription() : String;
//--------------------------------------------------
// Created:	16 October 2003 By: cnwgd1
//--------------------------------------------------
// 03/09/2009	cnwcs5	ccms1061 - use transalable strings for receive/release
/*

Date		Who		Reason
19 May 2010	cnwkpd1	PAR #20728 - remove isValidObject calls for performance
					Reason for original 15215 issue woudl actually be the receiver itself getting deleted,
					so we need to arm an exception handler to deal with this
14/06/2022 	navcs2 	ChangeRequest 53038: MTN - Work Order Maintenance Refactor - PortSchema
06 Mar 2025 navma1  MTN-34179 MTN | Dead Lock (1081) on CM_WLEArray
*/

vars
	wle			: CM_WorkListEntry;
	str,
	strID		: String;
	firstTime,
	invalid		: Boolean;
	
begin
	on Exception do app.handleDeletedObject(exception, self, invalid);

	if self.workListEntries.isEmpty then
		return self.jobId;
	endif;
	
	if invalid then
		return null;
	endif;
	
	firstTime := true;
	foreach wle in self.workListEntries discreteLock do		//06.03.2025 navma1 #MTN-34179
		// //14/06/2022 navcs2 TFS 53038
		if wle.isKindOf(CM_WOToDoWLE) then
			continue;
		endif;
		if wle.isReceipt then
			str := str &amp; app.getErrorString1 (XLAT_WLE_TREE_RECEIPT, wle.getTreeDescription);
		elseif CM_TIRequest.hasInstance(wle.myRequest) then
			str := str &amp; app.getErrorString1 (XLAT_WLE_TREE_RELEASE, wle.getTreeDescription);
		elseif firstTime then
			str := str &amp; app.getErrorString1 (XLAT_WLE_TREE_RELEASE, wle.getTreeDescription);
			firstTime := false;
		endif;
	endforeach;
	
	return str;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTypesToCreate" id="e43c811e-3857-4dd1-a3d3-ed80fa3965f5">
        <source>getTypesToCreate(_action : Integer; _eventType, _vvrType, _woTransType, _cargoTransType : Integer output);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14/03/2024	navkc1 CR 62896 Task 62897: Jade - Job Create Transactions and Events

*/

vars

begin
	if _action = Job_Action_Start then
		if self.isRoadJob() then
			_eventType 		:= EVT_TruckJobStart;
		elseif self.isRail() then
			_eventType 		:= EVT_WagonJobStart;
		endif;
		_vvrType 		:= VisitRecord_JobStart;
		_woTransType 	:= TRANS_TYPE_WOJOBSTART;
		_cargoTransType := TRANS_TYPE_TIJOBSTART;
		
	elseif _action = Job_Action_Stop then
		if self.isRoadJob() then
			_eventType 		:= EVT_TruckJobStop;
		elseif self.isRail() then
			_eventType 		:= EVT_WagonJobStop;
		endif;
		_vvrType 		:= VisitRecord_JobStop;
		_woTransType 	:= TRANS_TYPE_WOJOBSTOP;
		_cargoTransType := TRANS_TYPE_TIJOBSTOP;
		
	elseif _action = Job_Action_Resume then
		if self.isRoadJob() then
			_eventType 		:= EVT_TruckJobResume;
		elseif self.isRail() then
			_eventType 		:= EVT_WagonJobResume;
		endif;
		_vvrType 		:= VisitRecord_JobResume;
		_woTransType 	:= TRANS_TYPE_WOJOBRESUME;
		_cargoTransType := TRANS_TYPE_TIJOBRESUME;
		
	elseif _action = Job_Action_Complete then
		if self.isRoadJob() then
			_eventType 		:= EVT_TruckJobComplete;
		elseif self.isRail() then
			_eventType 		:= EVT_WagonJobComplete;
		endif;
		_vvrType 		:= VisitRecord_JobComplete;
		_woTransType 	:= TRANS_TYPE_WOJOBCOMPLETE;
		_cargoTransType := TRANS_TYPE_TIJOBCOMPLETE;
	endif;
epilog

end;</source>
        <Parameter name="_action" type="Integer"/>
        <Parameter name="_eventType" type="Integer" usage="output"/>
        <Parameter name="_vvrType" type="Integer" usage="output"/>
        <Parameter name="_woTransType" type="Integer" usage="output"/>
        <Parameter name="_cargoTransType" type="Integer" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getUnplannedWLEForRequest" id="7fac3e31-6b75-459c-a081-b4e4ce90e80c">
        <source>getUnplannedWLEForRequest(_request : CM_Request) : CM_WorkListEntry;
/*

Purpose:			Searches the job's workListEntries for an unplanned WLE with the passed in request

Parameters:			

Return Value:		Unplanned WLE for the request

Date				Who		Reason
05 July 2019		jlgzm1	TFS 42863 MSL - Direct Release Between RORO Voyages and Rail 

*/

vars
	wle : CM_WorkListEntry;
	
begin
	if _request = null then
		return null;
	endif;
	
	foreach wle in self.workListEntries  discreteLock do
		if wle.myRequest &lt;&gt; _request then
			continue;
		endif;
		if wle.status = WLE_COMPLETED  then
			continue;
		endif;
		if wle.myFutureMove &lt;&gt; null or 
		   wle.myFutureMoveDR &lt;&gt; null then
			continue;
		endif;
		
		return wle;
	endforeach;
	
	return null;
epilog

end;</source>
        <Parameter name="_request" type="CM_Request"/>
        <ReturnType type="CM_WorkListEntry"/>
    </JadeMethod>
    <JadeMethod name="getUnplannedWLEForTI" id="35910b2c-94c7-4980-aab8-781bfb9fd49f">
        <source>getUnplannedWLEForTI(_ti : CM_TrackedItem) : CM_WorkListEntry;
/*

Purpose:			Searches the job's workListEntries for an unplanned WLE with the passed in TI

Parameters:			

Return Value:		Unplanned WLE for the tracked item

Date				Who		Reason
05 July 2019		jlgzm1	TFS 42863 MSL - Direct Release Between RORO Voyages and Rail 

*/

vars
	wle : CM_WorkListEntry;
	
begin
	if _ti = null then
		return null;
	endif;
	
	foreach wle in self.workListEntries  discreteLock do
		if wle.myTrackedItem &lt;&gt; _ti then
			continue;
		endif;
		if wle.status = WLE_COMPLETED  then
			continue;
		endif;
		if wle.myFutureMove &lt;&gt; null or 
		   wle.myFutureMoveDR &lt;&gt; null then
			continue;
		endif;
		
		return wle;
	endforeach;
	
	return null;
epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="CM_WorkListEntry"/>
    </JadeMethod>
    <JadeMethod name="getVesselType" id="895b045d-2c57-4ba8-92ec-36e713700114">
        <source>getVesselType():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 May 2024 navhl20 ChangeRequest 63971: FR | 54176 - Ship operations in Delivery Dispatch screen

*/

vars
	voyage 			: CM_Voyage;
	vessel			: CM_Vessel;
	hmsVesselData	: HMS_VesselData;
	vesselType		: HMS_VesselType;
begin
	voyage := self.getMyVoyage();
	
	if voyage = null then
		return null;
	endif;
	
	vessel := voyage.myVessel;
	
	if vessel = null then
		return null;
	endif;
	
	hmsVesselData := vessel.myHMSVesselData;
	
	if hmsVesselData = null then
		return null;
	endif;
	
	vesselType := hmsVesselData.myVesselType;
	
	if vesselType = null then
		return null;
	endif;
	
	return vesselType.description;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getWLEForBOL" id="d8d2481b-d580-4125-88a1-b3dcdf8bece2">
        <source>getWLEForBOL(_bol : CM_BOL) : CM_WorkListEntry;
//--------------------------------------------------------------
//Created: 02 July 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	wle : CM_WorkListEntry;
begin
	foreach wle in self.workListEntries do
		if wle.myBOL &lt;&gt; null and wle.myBOL = _bol then
			return wle;
		endif;
	endforeach;
	return wle;
 
end;</source>
        <Parameter name="_bol" type="CM_BOL"/>
        <ReturnType type="CM_WorkListEntry"/>
    </JadeMethod>
    <JadeMethod name="getWLEForTI" id="015912e8-6d6a-456d-b6db-62c26b51eac5">
        <source>getWLEForTI(_ti : CM_TrackedItem) : CM_WorkListEntry;
//--------------------------------------------------
// Created:	27 August 2003 By: cnwgd1
//06 Mar 2025 navma1 MTN-34179 MTN | Dead Lock (1081) on CM_WLEArray
//--------------------------------------------------
vars
	wle : CM_WorkListEntry;
begin
	
	if _ti = null then
		app.raiseCMException2(MethodWithNullParam, method.name, 'Tracked Item reference', null, null);
		return null;	
	endif;	
	
	foreach wle in self.workListEntries discreteLock where wle.myTrackedItem = _ti do		//06.03.2025 navma1 #MTN-34179
		return wle;
	endforeach;
	return null;
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="CM_WorkListEntry"/>
    </JadeMethod>
    <JadeMethod name="getWLEforTIwithStatus" id="85698061-bf85-42bd-9d25-a8b42511a899">
        <source>getWLEforTIwithStatus(	_ti : CM_TrackedItem input;
						_tiID : String;
						_isComplete : Boolean;
						_isReceipt : Boolean;
						_request : CM_Request input) : CM_WorkListEntry;
/*

Date		Who		Reason
27 April 2016	cnwer1	Initial creation TFS 1842 returns first wle matching ti with status and receipt

*/

vars
	wle : CM_WorkListEntry;
begin
	foreach wle in self.workListEntries discreteLock do
		//looking for complete
		if _isComplete then
			if wle.status &lt;&gt; WLE_COMPLETED then
				continue;
			endif;
		else
			if wle.status = WLE_COMPLETED then
				continue;
			endif;
		endif;
		if wle.isReceipt &lt;&gt; _isReceipt then
			continue;
		endif;
		
		if _request &lt;&gt; null and wle.myRequest &lt;&gt; _request then
			continue;
		endif;
		
		if _ti &lt;&gt; null then
			if wle.myTrackedItem = _ti then
				return wle;
			endif;
		else
			if wle.myTrackedItem.id = _tiID then
				return wle;
			endif;
		endif;
			
	endforeach;
	
	return null;
epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_tiID" type="String"/>
        <Parameter name="_isComplete" type="Boolean"/>
        <Parameter name="_isReceipt" type="Boolean"/>
        <Parameter name="_request" type="CM_Request" usage="input"/>
        <ReturnType type="CM_WorkListEntry"/>
    </JadeMethod>
    <JadeMethod name="getWLEsForTI" id="a85a5cc8-8584-47a9-944f-b0bf6e7c15fe">
        <source>getWLEsForTI(_ti : CM_TrackedItem;
			 _wles : CM_WLEArray input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 January 2018	jlger1	Initial creation tfs 36534

*/

vars
	wle : CM_WorkListEntry;
begin
	
	
	foreach wle in self.workListEntries discreteLock do
		if wle.myTrackedItem = _ti then
			_wles.add(wle);
		endif;
	endforeach;
epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_wles" type="CM_WLEArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getWLEsMatchingReserveDetail" id="192e83d2-dac1-46c0-a483-d3e74edb9489">
        <source>getWLEsMatchingReserveDetail(_reserveDetail : CM_ReserveDetail input; _allWLES : CM_WLEArray input);
/*

Date		Who		Reason
22 September 2015	cnwer1	Initial creation PAR 36908

*/

vars
	wle : CM_WorkListEntry;
	reserveDetail : CM_ReserveDetail;
begin
	foreach wle in self.workListEntries where wle.status &lt;&gt; WLE_COMPLETED do
		if wle.myRequest = null then
			continue;
		endif;
	
		reserveDetail:=wle.myRequest.myReserveDetail;	
		if reserveDetail.myReserveHeader = null then
			continue;
		endif;	
		if wle.isReleaseByType then		
			if wle.myTrackedItem &lt;&gt; null then
				continue;
			endif;		
		endif;
		
		if reserveDetail.myReserveHeader &lt;&gt; _reserveDetail.myReserveHeader then
			continue;
		endif;
		if reserveDetail.getProductISOTypeDescr &lt;&gt; _reserveDetail.getProductISOTypeDescr() then
			continue;
		endif;
		_allWLES.add(wle);
	endforeach;
epilog

end;</source>
        <Parameter name="_reserveDetail" type="CM_ReserveDetail" usage="input"/>
        <Parameter name="_allWLES" type="CM_WLEArray" usage="input"/>
    </JadeMethod>
