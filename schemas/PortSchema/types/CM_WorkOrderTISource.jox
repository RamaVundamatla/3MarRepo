//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------

vars
	proxy : CM_WorkOrderRequestByType;

begin

	if _woRequest = null then
		return;
	endif;
	
	self.raiseExceptionIfNotTransient(method);

	_woRequest.raiseExceptionIfNotTransient(method);

	if _woRequest.myWorkOrderTISource &lt;&gt; null then
		app.raiseUnexpectedProgramError(class.name, method.name, "Request already assigned");
	endif;
	
	self.allWORequestByType.add(_woRequest);
	
epilog

end;</source>
