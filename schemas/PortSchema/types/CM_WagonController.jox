    <JadeMethod name="setRailAllocation" id="0c4b63e2-804d-4690-8edb-30a2ea1321e7">
        <updating/>
        <source>setRailAllocation(_railAlloc : CM_RailAllocation input) updating;
/*
----------   ----------  --------------------------------------------------
Created:	14 November 2006 By cnwth2

Purpose:	Will clean up old allocation if self is the last one left in its old allocation
			Will also add self's terminal area to allocation if not already present
Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	self.raiseExceptionIfTransient(method);
	
	if self.myRailAllocation &lt;&gt; _railAlloc then
		if self.myRailAllocation &lt;&gt; null and self.myRailAllocation.allWagonControllers.size = 1 then
			//must be only me left and I'm about to change teams, so nuke it
			delete self.myRailAllocation;
		endif;
		self.myRailAllocation := _railAlloc;
		
		if self.myTerminalArea &lt;&gt; null and _railAlloc &lt;&gt; null then
			if (not _railAlloc.allTerminalAreas.includes(self.myTerminalArea)) then
				_railAlloc.allTerminalAreas.add(self.myTerminalArea);
			endif;
		endif;
	endif;
	
	
end;


</source>
        <Parameter name="_railAlloc" type="CM_RailAllocation" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setTwistLocks" id="1b6acd8f-edf7-4a7f-b870-7412931c4ea1">
        <updating/>
        <source>setTwistLocks(pTLHas, pTLUp, pAvail : Boolean) updating, protected;
//-----------------------------------------
//Created: April 2003 By: cnwgd1
//-----------------------------------------
vars

begin

	if self.hasTwistlocks &lt;&gt; pTLHas or
       self.isAvailable &lt;&gt; pAvail or
	   self.twistlocksAreUp &lt;&gt; pTLUp then
		app.myEventManager.createSingleObjInfoNoteEvt(self.myWagon, self.myTerminal.getTerminalEvent(Wagon_Update_Event), self.myWagon);
	
		self.hasTwistlocks := pTLHas;
		self.isAvailable := pAvail;
		self.twistlocksAreUp := pTLUp;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="pTLHas" type="Boolean"/>
        <Parameter name="pTLUp" type="Boolean"/>
        <Parameter name="pAvail" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setupForPremove" id="3f0500f9-6aea-4a09-82a6-efaa7284ef62">
        <source>setupForPremove( _cmif : CMIF_MoveController input);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 November 2010	cnwndl1	Initial creation	Par 25442

*/

vars

	useRailAutoSwitch : Boolean;
	wle : CM_WorkListEntry;
	yardWle : CM_YardWLE;
	isDirectorTask : Boolean;
	request : CM_Request;
	wleTargetLoc : CM_LocationsController;
	newTargetLoc : CM_LocationsController;
	otherLocn : CM_LocationsController;
	job : CM_Job;
	iter : Iterator;
	otherWle : CM_WorkListEntry;
	foundWle : Boolean;
	
begin

	useRailAutoSwitch := self.myTerminal.getConfig(RailAutoSwitch).Boolean;
	if not useRailAutoSwitch then
		//option for auto switching of cargo queued director tasks on outward rail not allowed
		return;
	endif;
	
	wle := _cmif.myWorkListEntry;
	if wle = null or not wle.isKindOf(CM_YardWLE) then
		// not a yard wle
		return;
	endif;
	
	yardWle := wle.CM_YardWLE;
	
	if yardWle.isReceipt then
		// not a release.
		return;
	endif;
	
	request := yardWle.myRequest;
	if request = null then
		// no associated  request.
		return;
	endif;
	
	wleTargetLoc := yardWle.allLocationControllers.first;
	if wleTargetLoc = null or not wleTargetLoc.isWagon then
		// wasn't targetting a wagon - can't swap
		return;
	endif;
	
	newTargetLoc := _cmif.myToPrimaryLocation;
	if newTargetLoc = null or not newTargetLoc.isWagon then
		// isn't targetting a wagon - can't swap
		return;
	endif;
	
	if wleTargetLoc = _cmif.myTargetLocation then
		// its the same, so no switch required.
		return;
	endif;
	
	job := yardWle.job;
	if job = null then
		// no associated  job.
		return;
	endif;
	
	foundWle := false;
	iter := job.workListEntries.createIterator;
	while iter.next( otherWle ) do
		if otherWle = yardWle then
			continue;
		endif;
		if not otherWle.isKindOf(CM_YardWLE) then
			continue;
		endif;
		if otherWle.CM_YardWLE.allLocationControllers.isEmpty then
			continue;
		endif;
		if otherWle.myTrackedItem &lt;&gt; null then	//23 Dec 2010	NDL	 Par 26498
			// its no longer just a frigging director task
			// cos its got cargo....
			continue;
		endif;
		
		otherLocn := otherWle.CM_YardWLE.allLocationControllers.first;
		if otherLocn = newTargetLoc then
			foundWle := true;
			break;
		endif;
	endwhile;
		
	if foundWle then
		// we need to swap locations on 'otherWle' and 'yardWle'.
		app.myUtilityUA.utlSwapWlePlannedLocations( yardWle,  otherWle.CM_YardWLE, app.myPassport);
	endif;
	
epilog
	
	delete iter;

end;</source>
        <Parameter name="_cmif" type="CMIF_MoveController" usage="input"/>
    </JadeMethod>
    <JadeMethod name="testIsControllerLabrRestricted" id="20e9b661-357e-4758-82ca-b18364ed50f5">
        <source>testIsControllerLabrRestricted(obj : CMIF_AutoMovePlan input);

//implimented in Yard controller super-class
//Returns true if this LC has a labour restriction.
vars
begin

	obj.updateController(null);
	if obj.myTrackedItem = null then
		app.setContinueCMExceptions(false);
		app.raiseCMException2(MethodWithNullParam, method.name, "Tracked Item Reference", null, null); // Do NOT translatio
		return;	
	endif;
	if not hasRestrictions(LABOUR_RESTRICTION) then
		obj.updateController(self); 
  endif;
end;</source>
        <Parameter name="obj" type="CMIF_AutoMovePlan" usage="input"/>
    </JadeMethod>
    <JadeMethod name="updateTwistLocksForMove" id="9c80dcec-b62d-47bc-af1d-e458a9a8a9a5">
        <updating/>
        <source>updateTwistLocksForMove(_control : CMIF_MoveController; _passport : CM_Passport input; _moveFrom : Boolean)updating;
//----------------------------------------------------------------------------
// Created:	04 November 2003 By: cnwgd1
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 12/08/2009	consw1		PAR 19913 - SFW1067 Rail Simplifications
//----------------------------------------------------------------------------
vars
	max,
	cnt : Integer;
	available : Boolean;
	nextLC : CM_WagonController;
	
begin
	if _control.moveMode &lt;&gt; REAL_MODE then
		return;
	endif;

	if _moveFrom then
		if not self.allTrackedItems.isEmpty() then
			return;
		endif;
	else
		if self.allTrackedItems.size &gt; 1 then
			return;
		endif;
	endif;
	
	max := _control.myTrackedItem.getLengthInUnits().Integer;

	self.setTwistLocks(true, true, true);
	
	cnt := 1;
	nextLC := self.myNextController;
	
	while true do
		if nextLC = null then
			break;
		endif;
		cnt := cnt + 1;
		if cnt &lt; max then
			nextLC.CM_WagonController.setTwistLocks(true, false, true);
			nextLC := nextLC.myNextController;
		elseif cnt = max then
			nextLC.CM_WagonController.setTwistLocks(true, true, true);
			break;
		else
			break;
		endif;
	endwhile;

end;
</source>
        <Parameter name="_control" type="CMIF_MoveController"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <Parameter name="_moveFrom" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateCargoMatchForMultiMove" id="4755f7b0-5558-41ca-9c14-3cb8c3665e9d">
        <source>validateCargoMatchForMultiMove(_ti: CM_TrackedItem): Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 March 2012	cnwndl1	Initial creation

*/

vars

begin
	return true;

epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateCargoRestrictions" id="17d477cd-7c41-4938-aeef-1fba0c1c658d">
        <source>validateCargoRestrictions( control : CMIF_MoveController input; cmifAutoPlan : CMIF_YAAutoPlan; _wle : CM_YardWLE ):Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 February 2014	cnwndl1	Initial creation	Par 33439 - CCMS POL 2311

*/

vars

	criteria : CM_YACriteria;
	noMatchReason : String;
	scenario : CMIF_YAAutoPlanSenario;
	request : CM_DeliveryRequest;
	wagMaster : CM_WagonMaster;
	cargoRestriction : CM_CargoRestrictionCriteria;
	errCount : Integer;

begin

	errCount := app.myPassport.allErrorWarnings.size;

	if self.hasCargoRestrictions
	and self.myWagon.confirmed
	and self.myWagon.myTerminal &lt;&gt; null
	then
	
		if _wle &lt;&gt; null then
		
			if  _wle.myRequest &lt;&gt; null and  _wle.myRequest.isDeliveryRequest then
				request := _wle.myRequest.CM_DeliveryRequest;
				create scenario transient;
				scenario.populateCriteriaFromRequest( request );
				foreach criteria in self.myRailAllocation.allCriteria do
					if not scenario.isCriteriaMatch(criteria) then
						noMatchReason := app.getErrorString3(Item_does_match_with_criter, request.deliveryNumber, criteria.getDescription, null);
						if not app.getMyUser.canDo(self.myWagon.myTerminal, PmWagonCargoRestrict) then
							app.raiseCMException1(Wagon_cargo_restrict, noMatchReason, null, self.myWagon);
						else
							app.raiseCMWarning1(WarningNoMatchReason,  noMatchReason, null, null, self.myWagon);
						endif;
					endif; 
				endforeach;
				delete scenario;
			endif;
		
		elseif control &lt;&gt; null and cmifAutoPlan &lt;&gt; null and control.myTrackedItem &lt;&gt; null then
			foreach criteria in self.myRailAllocation.allCriteria do
				if not criteria.isCMIFAutoPlanDataMatch(cmifAutoPlan) then
					noMatchReason := app.getErrorString3(Item_does_match_with_criter, control.myTrackedItem.id, criteria.getDescription, null);
					if not app.getMyUser.canDo(self.myWagon.myTerminal, PmWagonCargoRestrict) then
						app.raiseCMException1(Wagon_cargo_restrict, noMatchReason, null, self.myWagon);
					else
						app.raiseCMWarning1(WarningNoMatchReason,  noMatchReason, null, null, self.myWagon);
					endif;
				endif;
			endforeach;
			
		endif;
		
	elseif not self.myWagon.confirmed then
		// check when in planning mode before the wagon arrives
		if control &lt;&gt; null and cmifAutoPlan &lt;&gt; null and control.myTrackedItem &lt;&gt; null then
			if self.myWagon &lt;&gt; null then
				wagMaster := self.myWagon.myWagonMaster;
				if wagMaster &lt;&gt; null then
					cargoRestriction := wagMaster.getMyObjectMatchCriteriaFor( control.myTrackedItem.myTerminal );
				endif;
			endif;
			if cargoRestriction &lt;&gt; null then
				foreach criteria in cargoRestriction.allCriteria do
					if not criteria.isCMIFAutoPlanDataMatch(cmifAutoPlan) then
						noMatchReason := app.getErrorString3(Item_does_match_with_criter, control.myTrackedItem.id, criteria.getDescription, null);
						if not app.getMyUser.canDo(self.myWagon.myTerminal, PmWagonCargoRestrict) then
							app.raiseCMException1(Wagon_cargo_restrict, noMatchReason, null, self.myWagon);
						else
							app.raiseCMWarning1(WarningNoMatchReason,  noMatchReason, null, null, self.myWagon);
						endif;
					endif;
				endforeach;
			endif;
		endif;
		
	endif;
	
epilog

	return (errCount = app.myPassport.allErrorWarnings.size);

	delete scenario;

end;</source>
        <Parameter name="control" type="CMIF_MoveController" usage="input"/>
        <Parameter name="cmifAutoPlan" type="CMIF_YAAutoPlan"/>
        <Parameter name="_wle" type="CM_YardWLE"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateConsigneeRestrict" id="5737abb6-40d6-479f-bdcd-ab8465254986">
        <source>validateConsigneeRestrict(control: CMIF_MoveController) protected;
/*
 ------------------------------------------------------------------------
Created:			12 September 2001 by cnwdwq1
Purpose:			
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/
vars
	str : String;
begin
	str := control.myTrackedItem.consignee.trimBlanks;
	if str = null then
		return;
	endif; 
	if self.myWagon.myWagonClass.allConsigneeCodesRestricted.includes(str) then
		app.raiseCMWarning2(WARN_WAGON_CONSIGN, control.myTrackedItem.id, str, null, null, self);
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="control" type="CMIF_MoveController"/>
    </JadeMethod>
    <JadeMethod name="validateMoveFrom" id="d1c7dc5d-78f6-4b6b-9efb-ab3ef4849a1d">
        <source>validateMoveFrom(control: CMIF_MoveController);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 November 2012	cnwndl1	Initial creation	Par 30522

*/

vars

	theTI : CM_TrackedItem;

begin

	inheritMethod(control);
	
	if control.isForcedMove then
		return;
	endif;
	
	if self &lt;&gt; control.myOriginatingLocation then
		return;
	endif;
	
	if control.moveMode &lt;&gt; PLANNING_MODE then
		theTI := control.myTrackedItem;
		if self.wagonIsSealed() and theTI &lt;&gt; null and not theTI.isNotified then
			app.raiseCMWarning1(Wagon_currently_sealed, self.myWagon.id, null, null, null);
		endif;
	endif;
	
	self.myWagon.validateMoveFrom(control);

epilog

end;</source>
        <Parameter name="control" type="CMIF_MoveController"/>
    </JadeMethod>
    <JadeMethod name="validateMoveLabourRestriction" id="c7a9303d-5552-4602-aafe-b4e30ba3049c">
        <source>validateMoveLabourRestriction(control: CMIF_MoveController);
/*
 ------------------------------------------------------------------------
Created:			31 July 2001 by cnwdwq1
Purpose:			
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/
begin
	self.myWagon.validateMoveLabourRestriction(control);
end;</source>
        <Parameter name="control" type="CMIF_MoveController"/>
    </JadeMethod>
    <JadeMethod name="validateMoveOverstow" id="750aeb24-a37f-49f5-9f3d-411becb7dcc2">
        <source>validateMoveOverstow( control: CMIF_MoveController input; _moveTI : CM_TrackedItem; _secondaryLoc: CM_LocationsController input) : Boolean;
// ---------------------------------------------------------------------------
// Created:		July 2009 By Simon Ward consw1
//
// Purpose:		Overstow checks
//
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	

begin
	
	return true;
	
epilog

end;</source>
        <Parameter name="control" type="CMIF_MoveController" usage="input"/>
        <Parameter name="_moveTI" type="CM_TrackedItem"/>
        <Parameter name="_secondaryLoc" type="CM_LocationsController" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateMoveTo" id="6a418b51-4cb8-42f0-8c8a-a8452803c811">
        <source>validateMoveTo(control: CMIF_MoveController input);
/*
 ------------------------------------------------------------------------
Created:			30 July 2001 by cnwdwq1
Purpose:			Do the work to validate the move to me as the primary target
Parameters:		None
Returns:			Nothing

Changed On	Changed By	Reason
----------	----------	--------------------------------------------------
06/07/2009	consw1		PAR 20194 - Overstow checks needed
//15 May 2013	cnwrs1	par31549 stop removal of unused options
03/11/2015   	cnwma1	PAR #37125 Releasing rail that requires operator pin
--------------------------------------------------------------------------
*/
vars
	lc 					: CM_LocationsController;
	allocMatch			: Boolean;
	noMatchReason, dummyString		: String;
	startExceptionState : Boolean;
	cmifAutoPlan : CMIF_YAAutoPlan;
	theTI, tmpTI : CM_TrackedItem;
	isInterTermTrsfr : Boolean;
	isROBorLoaded : Boolean;
	childTi : CM_TrackedItem;
	
begin
	// PAR 22051
	create cmifAutoPlan as CMIF_YAAutoPlanNormal transient;
	cmifAutoPlan.attachTI(control.myTrackedItem);
	cmifAutoPlan.setQuantity(control.quantity);	//13 Sep 2013	NDL	Par 32452
	theTI := control.myTrackedItem;
	
	if control.moveMode &lt;&gt; PLANNING_MODE then
		if self.wagonIsSealed() and theTI &lt;&gt; null and not theTI.isNotified then
			app.raiseCMWarning1(Wagon_currently_sealed, self.myWagon.id, null, null, null);
		endif;
	endif;

	if self = control.myToPrimaryLocation then

		inheritMethod(control);
		//------------------- RE-ENTRANT PROTECTION PORTION - CALLED ONCE -----------------------------
		//As the primary target we have already been locked by the control object.
		//(or by the caller)
		//-------------------
		//------------------
		//Validate for Labour Restriction in the area we are moving TO
		//------------------
		//self.validateMoveLabourRestriction(control); //Already done in the inheritMethod();
		
		
		// ## PAR 25526
		if control.moveMode = QUEUE_MODE  then
			if self.myTerminal.getConfig(RailDisallowOutwardQueue).Boolean then
				foreach tmpTI in self.allTrackedItems discreteLock do
						if tmpTI.myPrimaryQueuedLocation = null then
							//17 Oct 2014	NDL	Par 35040 - DMAST only...
							isROBorLoaded := tmpTI.isROB or not self.myWagon.allReportTIsInwards.includes(tmpTI);  // it is a remain on board or was just loaded
							if not isROBorLoaded then
								// So it was already here, and should have been queued off before allowing our one to be queued on.
								//cnwmc5 - 27 Feb 2014 - PAR 33600
								if self.isBoxcarCont() then
									app.raiseCMWarning3(Cargo_that_locat_not_queue_WAG, tmpTI.id, self.getFullId,theTI.id, null, null, null);
								else
									app.raiseCMException3(Cargo_that_locat_not_queue_WAG, tmpTI.id, self.getFullId,theTI.id, null, null);
								endif;
							endif;
						endif;
				endforeach;
			endif;
		endif;
		
		
		//cnwrd1 CCMS POL 2032 par 25594 10.12.2010 - validate move to wagon for operator release pins, requires a release
		if  theTI.myOperator &lt;&gt; null 
		//and theTI.myOperator.getRequiresImpOperatorPIN()  // should have an operator but at times timing may cause us not to have 
		and theTI.myOperator.getRequiresRailRelWagonMoves() // cnwma1 3/11/2015 PAR #37125
		and theTI.getImExStatus() = TI_IMEX_STATUS_IMPORT then	// 22/09/2011 cnwar2 #28081
			/*isInterTermTrsfr := theTI.isNotified and theTI.myMoveCloneFromTI &lt;&gt; null;	//26 Nov 2012	NDL	Par 30784
			if isInterTermTrsfr then	//26 Nov 2012	NDL	Par 30784
				// don't check when putting a pre-note created by an inter-term trsfr onto a wagon.
			else*/
			if not theTI.isNotified then	// 18/12/2013 cnwar2 #32808 - should skip check for any prenotes, not just inter-term
				if theTI.getBulkReleaseAssignedOfType(BR_TYPE_RAIL, BR_ACTIVE) = null then
					app.raiseCMException2(Operator_requires_rail_release, theTI.myOperator.code, theTI.id, null, null);
				endif;
			endif;
		endif;
		
		//------------------
		//get the extent of the TI in terms of other LC's of this type we have to span
		//------------------
		
		startExceptionState := app.continueCMExceptions;
		app.setContinueCMExceptions(true);
// PAR 22750 		if (not self.getSpannedToLCs(control)) then
		if  self.getSpannedToLCsNEW( control) &lt;&gt; null then
			//Not enough space!
			app.raiseCMException2(ERR_NO_SPACE, control.myTrackedItem.id, self.myWagon.id, null, null);
		endif;

		app.setContinueCMExceptions(startExceptionState);
		//------------------
		//check each one of these, RENTRANT call.
		//------------------
		control.doToSecondaryLocationsLock();

		foreach lc in control.myToSecondaryLocations do
			lc.validateMoveTo(control);			
		endforeach;
		
		//21 Oct 2009	NDL	Par 21415 - we care about whether the last position is damaged too, but only enough to warn.
		if control.myToSecondaryLocations.size &gt; 1 then	
			if not control.myToSecondaryLocations.last.CM_WagonController.isAvailable then 
				app.raiseCMWarning1(Canno_move_this_wagon_locat_be, control.myToSecondaryLocations.last.getFullId(), null, null, self.myWagon);
			endif;
		endif;
		
		// Par 12837 DVB changed to raise todo task warning when moving to a wagon. 09/11/2006
		if not control.myTrackedItem.allToDoTasksToDo.isEmpty() then
			//app.raiseCMWarning3(TI_TestReqAvailable, control.myTrackedItem.id, 'Unavailable for Release', "Available for release. Has ToDo Tasks", null, null, control.myTrackedItem); 
			app.raiseCMWarning1(Cargo_item_avail_statu_unava_r, control.myTrackedItem.id,null, null, control.myTrackedItem); 
		endif;
		
		//th2 raise warning if wagon is color coded
		if self.myRailAllocation &lt;&gt; null then
			
			//10 Feb 2014	NDL	Par 33439 - CCMS POL 2311
			if not self.validateCargoRestrictions( control, cmifAutoPlan, null ) then
				return;
			endif;
			
			allocMatch := self.myWagon.autoAllocationMatch(control.myTrackedItem, noMatchReason, null, cmifAutoPlan);
			if (not allocMatch) then
				//app.raiseCMWarning1(Full_Replacement_Message, 'Warning: ' &amp; noMatchReason, null, null, self.myWagon);
				app.raiseCMWarning1(WarningNoMatchReason,  noMatchReason, null, null, self.myWagon);
				
			endif;
		
		//12 Feb 2014	NDL	Par 33439 - CCMS POL 2311
		elseif ( control.moveMode = PLANNING_MODE and not self.myWagon.confirmed ) then
			self.validateCargoRestrictions( control, cmifAutoPlan, null );
			
		endif;
		
		if control.moveMode = REAL_MODE  then // TFS 3972
			control.myTrackedItem.hasUnactionedDocumentActions(false,true,dummyString); // TFS 3972
			
			//28 Aug 2017	NDL	TFS 6686
			if not control.myTrackedItem.allChildren.isEmpty then
				foreach childTi in control.myTrackedItem.allChildren do
					childTi.hasUnactionedDocumentActions( false, true, dummyString );	// raise errors.
				endforeach;
			endif;
			
			// ### TFS CR 60424 TASK 60549 02OCT2023 NAVAB1
			control.myTrackedItem.validateCustDocTransportMove(control, app.myPassport);
		
		endif; // TFS 3972
	endif;

	// DVB put this here so a forced move still sets up secondary locations. 02/09/03
	if control.isForcedMove then
		return;
	endif;
	
//	if not self.isAvailable then // PAR 20682
	if not self.myWagon.confirmed and not self.isAvailable then	// 10 Aug 2010	NDL	Par 25316
		//app.raiseCMException1(Canno_move_this_wagon_locat_be, self.getFullId(), null, self.myWagon);
		app.raiseCMWarning1(Canno_move_this_wagon_locat_be, self.getFullId(), null, null, self.myWagon);	//20 Oct 2009	NDL Par 21425
	endif;
	//---------------------------
	//  TEST : Overstows
	//---------------------------
	if self = control.myToPrimaryLocation and self.myWagon.myWagonClass.maxNumInStack &gt; 1 then
		if self.validateMoveOverstow(control, control.myTrackedItem, null) then
			foreach lc in control.myToSecondaryLocations do
				if not self.validateMoveOverstow(control, control.myTrackedItem, lc) then
					break;
				endif;
			endforeach;
		endif;
	endif;
	//------------------------
	//This is the standard stuff to validate any move here	
	//------------------------
	if self.includesTI(control.myTrackedItem, control.moveMode) then
		//-----------------
		//If the TI is already here, then simply return. They must be shifting it?
		//-----------------
		return;
	endif;
	//---------------------------
	//  TEST : Vertically full
	//---------------------------
	// rs1 June 2006 ccms 1031 allow prenote to overload a wagon

	if not self.isSkeletonCarCont() then		// TFS 2533
		if self.isStackFull(control.moveMode, control.myTrackedItem) then
			if control.myTrackedItem.state &lt;&gt; TI_STATE_NOTIFIED then 
				app.raiseCMException(ERR_GTMAX_HEIGHT, null, control.myTrackedItem);
			else
				app.raiseCMWarning(ERR_GTMAX_HEIGHT, null, null, control.myTrackedItem);
			endif;
		endif;
	endif;		
	// SHIFTED - now done in wagon.validateMoveTo();
	//self.validateConsigneeRestrict(control);

	//-------------------------
	//Perform these tests only once
	//-------------------------

	if self &lt;&gt; control.myToPrimaryLocation then
		return;
	endif;
	
	self.myWagon.validateMoveTo(control);
	/* SHIFTED TO THE WAGON OBJECT
	//Validate that the same consignees are on this wagon
	//-------------------------	
	self.myWagon.validateSameConsignees(control);
	//-------------------------
	//Validate we dont overload the wagon
	//-------------------------
	self.myWagon.validateMaxLoadWeight(control);*/	
epilog
		delete cmifAutoPlan;
end;</source>
        <Parameter name="control" type="CMIF_MoveController" usage="input"/>
    </JadeMethod>
    <JadeMethod name="wagonIsSealed" id="7bfaf14c-85ba-492b-b677-a8ea51caf682">
        <source>wagonIsSealed(): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 March 2015	cnwndl1	Initial creation

*/

vars

begin

	return self.myWagon.isSealed();

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
