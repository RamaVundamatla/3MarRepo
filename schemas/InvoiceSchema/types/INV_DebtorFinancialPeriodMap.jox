    <JadeMethod name="doCmbBankBuild" id="b7a40a0c-d0b8-4e63-90f3-823c70f0a4d4">
        <source>doCmbBankBuild();
//	35874 build combo for business unit query
vars
	company			: CM_Bank;
	businessUnits	: CM_CompanyByCodeDict;
	currentBU		: CM_Bank;
	combo			: CMUI_ComboBox;
begin

	combo := self.cmbBank;
	create businessUnits transient;
	currentBU := self.myTerminal.getAvailableCompanies(businessUnits);
	foreach company in businessUnits do
		combo.addItem(company.code);
		combo.itemObject[combo.newIndex] := company;
	endforeach;
	if currentBU &lt;&gt; null then
		combo.listObject := currentBU;
	endif;
epilog
	delete businessUnits;
end;
</source>
    </JadeMethod>
    <JadeMethod name="doCmbDebtorBuild" id="e7037f20-79e9-41ba-988d-5f374261724e">
        <source>doCmbDebtorBuild();

vars
	idx : Integer;
	aDebtor : CM_Debtor;
begin
	self.cmbDebtors.clear;
	foreach aDebtor in app.myRoot.myRootCompany.debtors do
		idx := self.cmbDebtors.addItem(aDebtor.name);
		self.cmbDebtors.itemObject[idx] := aDebtor;
	endforeach;
end;</source>
    </JadeMethod>
    <JadeMethod name="doCmbPeriodsBuild" id="6e6b6dae-1cf9-482a-9776-0dcf930d4ce1">
        <source>doCmbPeriodsBuild();

vars

	idx : Integer;
	anFPE : CM_FinancialPeriodEnd;
begin
	self.cmbPeriods.clear;
	foreach anFPE in app.myRoot.myRootCompany.allFinancialPeriods do
		idx := self.cmbPeriods.addItem(anFPE.description);
		self.cmbPeriods.itemObject[idx] := anFPE;
	endforeach;
end;</source>
    </JadeMethod>
    <JadeMethod name="doCmbTypesBuild" id="b6e9554b-85ee-4db8-a583-4c4a504c41c5">
        <source>doCmbTypesBuild();

vars
	idx : Integer;
	anILD : CM_InvoiceDesc;
begin
	self.cmbInvoiceTypes.clear;
	foreach anILD in self.myCurrentBank.invoiceTypes where not anILD.isNotAvailableForEntry do
		idx := self.cmbInvoiceTypes.addItem(anILD.description);
		self.cmbInvoiceTypes.itemObject[idx] := anILD;
	endforeach;
end;</source>
    </JadeMethod>
    <JadeMethod name="doComboDebtorBuild" id="96c2cef2-671b-4c54-abbc-02c1399d1fd0">
        <source>doComboDebtorBuild();
//
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------
// 17/06/2014	cnwdap1		PAR #34422 Remove beginLock / endLock
vars
	debtor : CM_DebtorNode;

begin

	self.cmbDebtor.clear;
	self.cmbDebtor.sorted := true;
	self.cmbDebtor.addItem(" All Debtors");
	
	foreach debtor in app.myRoot.myRootCompany.debtorNodes do
		self.cmbDebtor.addItem(debtor.name);
		self.cmbDebtor.itemObject[self.cmbDebtor.newIndex] := debtor;
	endforeach;
	self.cmbDebtor.listIndex := 1;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doComboDebtorUpdateBuild" id="aacee1ff-1c20-4ab8-b2da-18589083e92c">
        <source>doComboDebtorUpdateBuild(_theDebtors : CM_DebtorNodeByNameDict);
//
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------------
// 17/06/2014	cnwdap1		PAR #34422 Remove beginLock / endLock
vars
	debtor : CM_DebtorNode;

begin

	self.cmbDebtors.clear;
	self.cmbDebtors.sorted := true;
	
	foreach debtor in _theDebtors do
		if debtor.isKindOf(CM_DebtorGroup) then
			continue;
		endif;
		
		self.cmbDebtors.addItem(debtor.name);
		self.cmbDebtors.itemObject[self.cmbDebtors.newIndex] := debtor;
	endforeach;
epilog

end;</source>
        <Parameter name="_theDebtors" type="CM_DebtorNodeByNameDict"/>
    </JadeMethod>
    <JadeMethod name="doDelete" id="7424d6c1-a76b-4e95-899b-3a6af0045b51">
        <updating/>
        <source>doDelete() updating;

vars
	realMapping : CM_DebtorBankInvTypeDtl;
	theReturn : Integer;
begin
	// 35872 use query bank
	realMapping := self.myCurrentBank.allDebtorBankInvTypeDtls[self.myCurrentDebtor.CM_Debtor, self.myCurrentInvType];

	if realMapping = null then	
		return;
	endif;

	while true do
		app.myTrxDA.trxDeleteFinancialPeriodMap(realMapping, app.myPassport);

		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			self.frmProperties.visible := false;
			global.beep;
			break;
		else
			theReturn := app.showErrorWarningDialog("Mapping Remove", app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			return;
		endif;
		break;
	endwhile;

end;</source>
    </JadeMethod>
