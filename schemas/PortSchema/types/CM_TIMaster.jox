    <JadeMethod name="getAttacheesAuditText" id="8ef0ed88-c0bc-46a2-971e-9951b957c579">
        <source>getAttacheesAuditText():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 Feb 2018	cnwma1  ChangeRequest 36813: PEN - Gen Sets, Chassis &amp; Reefers
*/

vars
	genMaster : CM_TIMaster;
	txt : String;
begin
		foreach genMaster in self.allTIMasterAttachees do
		txt := txt &amp; genMaster.id &amp; ', ';
	endforeach;

	return txt;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getAuditText" id="2c0bc577-be54-460b-8701-1eaec066a3ee">
        <source>getAuditText(): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 Feb 2018	cnwma1  ChangeRequest 36813: PEN - Gen Sets, Chassis &amp; Reefers
*/

vars
	txt,
	tmpStr,str	: String;
	genMaster   : CM_TIMaster;
begin
	txt[10000] 	:= '*';
	txt 		:= null;
	txt 		:= inheritMethod();
	
	tmpStr := null;
	str    :=null;
	
	if self.allTIMasterAttachees.size &gt; 0 then
		foreach genMaster in self.allTIMasterAttachees do
			if genMaster = null then
				break;
			endif;
			tmpStr := genMaster.id;
			tmpStr :=tmpStr&amp; " " &amp;str ;
		endforeach;
		tmpStr := tmpStr.trimLeft;
		txt := txt &amp;'Generator Attached' &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp;tmpStr &amp; AuditStringSeparator;
	endif;
	
	tmpStr := null;
	str    :=null;

	if self.allTIMasterAttachers.size &gt; 0 then
		foreach genMaster in self.allTIMasterAttachers do
			if genMaster = null then
				break;
			endif;
			tmpStr := genMaster.id;
			tmpStr :=tmpStr&amp; " " &amp;str ;
		endforeach;
		tmpStr := tmpStr.trimLeft;
		txt := txt &amp;'Master  Attached' &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp;tmpStr &amp; AuditStringSeparator;
	endif;
	
	return txt;
	

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getAuditTextForProperty" id="64b07e23-6105-45da-8f55-98255818ae0c">
        <source>getAuditTextForProperty(_property: Property): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 December 2008	cnwrd1	Initial creation
*/


vars
	propName	: String;
	
begin
	propName := _property.name;

	if propName = CM_TIMaster::allStopsNew.name then
		return self.formatAuditText(propName, self.getStopsAuditText());			
	elseif propName = CM_TIMaster::allDamageInstancesByPos.name then
		return self.formatAuditText(propName, self.getDamageAuditText());
	elseif propName = CM_TIMaster::allToDoTaskDesc.name then				
		return self.formatAuditText(propName, self.getToDoTaskAuditText());
	else
		return inheritMethod(_property);
	endif;

epilog

end;</source>
        <Parameter name="_property" type="Property"/>
        <ReturnType type="String"/>
    </JadeMethod>
