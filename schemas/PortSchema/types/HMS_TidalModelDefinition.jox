    <JadeMethod name="getLatestDateDescr" id="75596a25-c86e-4a4a-bba9-2bdda6677071">
        <source>getLatestDateDescr() : String;
/*
----------   ----------  --------------------------------------------------
Created:	10 October 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	tidalData			: HMS_TidalData;
begin
	tidalData := self.allHMSTidalData.last;
