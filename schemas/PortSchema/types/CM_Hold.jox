    <ExplicitInverseRef name="allHatchLids" id="806eb777-1ce2-4684-b31e-2c65d50abe83">
        <kind>parent</kind>
        <transientToPersistentAllowed/>
        <updateMode>automatic</updateMode>
        <type name="CM_HatchLidSet"/>
