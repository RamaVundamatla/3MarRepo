    <JadeMethod name="loadCriteria" id="bd2d18b4-2f5c-41d0-a087-37fd175d6253">
        <updating/>
        <source>loadCriteria(_report : CM_QryReport) updating, protected;
// -----------------------------------------------------------------------------
// Created:		13 June 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
// 19/11/2009	cnwdad1		PAR #21640. Ignore Sub-Terminals if no ST license.
// 8/12/2015	cnwma1		PAR #37254 JH - Report Error (14011). Invalid property array index
// 17/07/2018	jlgmd1		TFS #39407 SNO - Fixed Bulk Release criteria not saving on the tempalte
// -----------------------------------------------------------------------------
vars
	entTableDef 	: EntTableDef;	
	entRow			: EntTableRow;
	entView			: EntTableView;
	entRowArray 	: EntTableRowArray;
	isUserReport,
	visibleTick,
	includesTick 	: Boolean;
	row				: Integer;
	table			: CM_BaseTable;
	defaultTemplate	: CMQF_FilterReports;
	defName,
	defaultValueStr	: String;
	control			: Control;
	inputType		: Integer;
	cell			: JadeTableCell;
	newUserReport	: CM_QryReportUser;
	isSubTermLic	: Boolean;
	idx 			: Integer;
	rptType			: Integer;
	
begin
	self.tblCriteria.rows := self.tblCriteria.fixedRows;
	table := self.tblCriteria;
	isUserReport	:=	CM_QryReportUser.hasInstance(_report);
	isSubTermLic	:=	app.isSubTerminalsLicensed;			// cnwdad1 19/11/2009 - PAR #21640.

	if self.mode = self.Mode_Add
	and CM_QryReportUser.hasInstance(self.myPlaceHolderObject) then
		newUserReport := self.myPlaceHolderObject.CM_QryReportUser;
	endif;			


	if isUserReport or _report = null then
		if self.mode = self.Mode_View  then     //8/12/2015  cnwma1 PAR #37254
			if _report.reportType = CM_QryReportUser.ReportType_TrackedItem then
					if self.getETDefName(CM_QryReportUser.ReportType_TrackedItem) &lt;&gt; null then
						idx := self.cmbReportType.findItemData(CM_QryReportUser.ReportType_TrackedItem);
						if idx &lt; 0 then
							self.cmbReportType.itemData[self.cmbReportType.addItem(CM_QryReportUser.ReportTypeDescr_TrackedItem)] 		:= CM_QryReportUser.ReportType_TrackedItem;			//4
							idx := self.cmbReportType.findItemData(CM_QryReportUser.ReportType_TrackedItem);
							self.cmbReportType.listIndex:=idx;
						endif;
							
					endif;
				endif;
		endif;                                //8/12/2015  cnwma1 PAR #37254
		rptType := cmbReportType.itemData[cmbReportType.listIndex];		// TFS 39407
		entTableDef := app.myController.getEntTableDef(self.getETDefName(rptType));
		
		if entTableDef &lt;&gt; null then
			// Bulk Releases are special, and should use an EntDef View instead		// TFS 39407
			if rptType = CM_QryReportUser.ReportType_BulkReleases then
				entView := entTableDef.allEntTableViews[ETView_ContRelView];
				if entView &lt;&gt; null then
					entRowArray := entView.allEntTableRows;
				endif;
			else
				entRowArray := entTableDef.allEntTableRows;
			endif;
			//app.writeStatement(self.class.name &amp; ' &gt;&gt;' &amp; method.name &amp; '&gt;&gt; Group: ' &amp; entTableDef.myEntTableGroup.name &amp; '&gt;&gt; Def: ' &amp; entTableDef.name &amp; " pos 1. ");
		endif;
	else
		entTableDef := app.myController.getEntTableDef(_report.tableDefName);
		if entTableDef &lt;&gt; null then
			entView := entTableDef.allEntTableViews[_report.tableDefViewName];
			
			if entView &lt;&gt; null then
				entRowArray := entView.allEntTableRows;
				//app.writeStatement(self.class.name &amp; ' &gt;&gt;' &amp; method.name &amp; '&gt;&gt; Group: ' &amp; entTableDef.myEntTableGroup.name &amp; '&gt;&gt; Def: ' &amp; entTableDef.name &amp; '&gt;&gt; View: ' &amp; entView.name &amp; " 2. ");
			endif;
		endif;
	endif;
	
	if entRowArray = null then
		return;
	endif;

	if _report &lt;&gt; null then
		defaultTemplate := _report.myFilterObject;
	endif;

	foreach entRow in entRowArray do
// cnwdad1 19/11/2009 - PAR #21640.
		if not isSubTermLic then
			if entRow.name = ETRow_MySubTerminal then
				continue;
			endif;
		endif;
		
		includesTick := true;
		visibleTick := true;
		defaultValueStr := null;
		if isUserReport then
			includesTick := (_report.CM_QryReportUser.viewRows.includes(entRow.name));
			visibleTick := (_report.CM_QryReportUser.allVisibleRows.includes(entRow.name));
		endif;
	
		self.myReportAgent.loadParameterByName(defaultTemplate, entRow, entRow.name, defaultValueStr);
		row := table.addItem(entRow.getHeading(table.myTerminologyCargoBOLType, table.myTerminologyTerminal, app.myCurrentLocale) &amp; Tab &amp; 
					defaultValueStr &amp; Tab &amp; 
					includesTick.cnEcGetTableCheckBoxValue &amp; Tab &amp; 
					visibleTick.cnEcGetTableCheckBoxValue);
		table.accessRow(row).itemObject := entRow;

		if newUserReport &lt;&gt; null then
			newUserReport.viewRows.add(entRow.name);
		endif;		
		
		if entRow.controlName &lt;&gt; null then
			control := self.getPropertyValue(entRow.controlName).Control;
			table.accessCell(row, self.Column_DefaultValue).cellControl := control;
		else
			inputType := entRow.inputType;
			if inputType = CM_BaseTable.InputType_Time then
				cell := table.accessCell(row, self.Column_DefaultValue);
				// reformat the text data
				//cell.text := cell.text.Time.shortFormatJMT();//par16017
				table.initCellForTime(cell);
			//if it's a date field - change it to be the corresponding templateDate combo control
			elseif inputType = CM_BaseTable.InputType_Date then
				control := self.getPropertyValue(self.myReportAgent.getTemplateDateComboControl(entRow.name)).Control;
				table.accessCell(row, self.Column_DefaultValue).cellControl := control;
			else
				table.accessCell(row, self.Column_DefaultValue).inputType := inputType;
			endif;
		endif;
	endforeach;
	
//	jrwReport := self.myReportAgent.myJRWReport;

//	if jrwReport &lt;&gt; null then
//app.writeStatement('CNWJC2 ' &amp; class.name &amp; " " &amp; method.name &amp;  " jrwReport &lt;&gt; null" );
		//self.myReportAgent.doShowHideProfiles(jrwReport);	
//	endif;
epilog
	self.setTblCriteriaHeight();
end;</source>
        <access>protected</access>
        <Parameter name="_report" type="CM_QryReport"/>
    </JadeMethod>
    <JadeMethod name="loadDataForFirstTime" id="64bfdd02-6ec3-40ae-8ecf-acc95aaf2b56">
        <updating/>
        <source>loadDataForFirstTime() updating, protected;
// ---------------------------------------------------------------------------
// Created:     06 January 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	aTime	: Time;
begin
	
	if self.myQueryParamLogicAgent = null then
		create self.myQueryParamLogicAgent transient;
	endif;
	
	if self.myQryReportLogicAgent = null then
		create self.myQryReportLogicAgent transient;
	endif;
	
	if self.myReportAgent = null then
		create self.myReportAgent transient;
		self.myReportAgent.init(self);
	endif;
	
	self.myReportAgent.setState(self.myReportAgent.STATE_TEMPLATE_EDIT);
	
	inheritMethod();

	//SET TIMES//////////////////////
	aTime.setTime(0, 0, 0, 0);
	self.myReportAgent.setValueByName(ETRow_MatchTimeStart, aTime);
	aTime.setTime(23, 59, 59, 99);
	self.myReportAgent.setValueByName(ETRow_MatchTimeEnd, aTime);
	
	self.selectFirstRow(true);
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="loadJRWViews" id="601b2fe4-3330-4352-a672-6271ef4f2dd8">
        <updating/>
        <source>loadJRWViews() updating, protected;
// ---------------------------------------------------------------------------
// Created:     18 August 2003	cnwth2
//
// Purpose:     
//
// ----------   ----------  --------------------------------------------------
vars
	jrwView			: CMUI_JRWEntityRepresentation;
	cmb				: CMUI_ComboBox;
	selectedStr		: String;
begin

	cmb := self.cmbReportView;
	selectedStr := cmb.text;
	cmb.clear;
	
	delete self.myJRWRepresentationAgent;
	create self.myJRWRepresentationAgent transient;
	self.myJRWRepresentationAgent.loadJRWRepresentationObjects();

	foreach jrwView in self.myJRWRepresentationAgent.allJRWViews do
		cmb.itemObject[cmb.addItem(jrwView.name)] := jrwView;
	endforeach;

	if cmb.findString(1, selectedStr) &gt; -1 then
		cmb.text := selectedStr;
	endif;
	
//	cmb.click(cmb);
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="loadParamTypes" id="18ff2a8c-c1ca-421c-bf2f-f41fc9703b8d">
        <source>loadParamTypes() protected;
// ---------------------------------------------------------------------------
// Created:     20 August 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	cmb				: CMUI_ComboBox;
begin
	cmb := self.cmbParamType;
	cmb.clear();
	
	cmb.itemData[cmb.addItem(Binary.name)] := Binary.number;
	cmb.itemData[cmb.addItem(Boolean.name)] := Boolean.number;
	cmb.itemData[cmb.addItem(Character.name)] := Character.number;
	cmb.itemData[cmb.addItem(Date.name)] := Date.number;
	cmb.itemData[cmb.addItem(Decimal.name)] := Decimal.number;
	cmb.itemData[cmb.addItem(Integer.name)] := Integer.number;
	cmb.itemData[cmb.addItem(String.name)] := String.number;
	cmb.itemData[cmb.addItem(Time.name)] := Time.number;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="loadReportFilterTypes" id="d64f8248-7c46-4d14-bb82-97984d19d720">
        <source>loadReportFilterTypes() protected;
// ---------------------------------------------------------------------------
// Created:     14 January 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	cmb			: CMUI_ComboBox;
begin
	cmb := self.cmbReportFilter;
	cmb.sorted := false;
	cmb.clear();
	cmb.itemData[cmb.addItem('User Defined Report')] := null;
	cmb.itemData[cmb.addItem(CM_QryReport.ReportTypeDescr_SystemDefined)] := CM_QryReport.ReportType_SystemDefined;
	cmb.itemData[cmb.addItem(CM_QryReport.ReportTypeDescr_External)] := CM_QryReport.ReportType_External;
	cmb.itemData[cmb.addItem(CM_QryReport.ReportTypeDescr_Selector)] := CM_QryReport.ReportType_Selector;
	cmb.listIndex := 1;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="loadSelectorQueries" id="f1e66e55-aa6d-4a0d-8358-0a20c614e0af">
        <source>loadSelectorQueries() protected;
// ---------------------------------------------------------------------------
// Created:     31 October 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
// 29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
vars
	selectorType	: Integer;
	queryRoot		: CM_MenuRootQuery;
	menuEntity		: CM_MenuEntity;
	cmb				: CMUI_ComboBox;
begin
	cmb := self.cmbSelector;
	cmb.clear();
	queryRoot := app.myRoot.myQueryMenuRoot;
	
	foreach menuEntity in queryRoot.allMenuUserItemsWithAMenuItem do
		// from 34442 filter out query types not handled in reporting such as BOLs
		if menuEntity.isKindOf(CM_MenuUserQuery) then
			selectorType := menuEntity.CM_MenuUserQuery.getType();
			if selectorType = CM_QueryDefinition.BOL_Query_Type or
			   selectorType = CM_QueryDefinition.BookRef_Query_Type or
			   selectorType = CM_QueryDefinition.Release_Query_Type then
				continue;
			endif;
		endif;
		cmb.itemObject[cmb.addItem(menuEntity.CM_MenuUserQuery.heading)] := menuEntity;
	endforeach;

	cmb.text := null;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="lstFormats_displayRow" id="74e4959b-701a-4dd1-8e47-3cd18060ab00">
        <controlMethod name="Table::displayRow"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>lstFormats_displayRow(table: Table input; theSheet: Integer; obj: Object; theRow: Integer; bcontinue: Boolean io):String updating;
// -------------------------------------------
// Created 29 October 2004 by cnwdvb1
// -------------------------------------------
vars

	selected	: Boolean;

	
begin

	selected := table.CMUI_ListTable.allSelectedObjects.includes(obj);
	
	if selected then
		return TableCheckBox_Selected  &amp; Tab &amp; obj.CMIF_ReportFormats.formatDescription;
	else
		return  TableCheckBox_NotSelected &amp; Tab &amp; obj.CMIF_ReportFormats.formatDescription;
	endif;	



end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="theSheet" type="Integer"/>
        <Parameter name="obj" type="Object"/>
        <Parameter name="theRow" type="Integer"/>
        <Parameter name="bcontinue" type="Boolean" usage="io"/>
        <ReturnType type="String"/>
    </JadeMethod>
