    <JadeMethod name="setupForm" id="0c2b0266-5734-440f-81a3-61d77edce8fd">
        <updating/>
        <source>setupForm() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
01 December 2009	cnwndl1	Initial creation	CCMS 1023
05 Jun 2014	cnwkpd1	PAR #34210 - CCMS SFW 1350 - Online Documentation

*/

vars

begin

	create self.myAssistant;
	self.beginClassNotification( CM_OutputFormat_SS, false, EVENT_SummaryTable_Update, Response_Continuous, null );
	self.beginClassNotification( CM_OutputFormat_SS, false, EVENT_SummaryTable_Delete, Response_Continuous, null );
	self.beginClassNotification( CM_SnapshotData, false, Any_System_Event, Response_Continuous, null);

	inheritMethod();
	
	self.toolbarStyle	:= self.ToolbarStyle_ShowNoHide;
	self.showToolbar	:= true;
	
	self.frmSSDef.cnEcResizeContents;
	
	self.setCaption( app.getErrorString(Snap_shot_summary) );
	self.helpKeyword := 'Snap Shot Summary';		// PAR #34210
	
	self.btnPrint.bubbleHelp := "Print Table";
	self.btnExportCSVQE.bubbleHelp := "Export Table to CSV";
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupNewDataFrame" id="81292c0e-e356-4149-b406-5eba2756c916">
        <updating/>
        <source>setupNewDataFrame() updating, protected;
// CCMS 1043 par 21800 Oct 2010 cnwjre1 add option to create new snapshot data plus invoicing to handle
//  missed background runs.  A different selector can be chosen to get historical data.
vars
	queryRoot	: CM_MenuRootQuery;
	format_SS : CM_OutputFormat;
	menuEntity	: CM_MenuEntity;

begin
	self.frmNewData.top := 80;
	self.frmNewData.left := 100;
	self.lblNew.caption := "Create new snapshot data and associated invoice lines for the date given below, using the alternative Selector Query.";
	self.frmNewData.zOrder(1);

	queryRoot := app.myRoot.myQueryMenuRoot;
	foreach menuEntity in queryRoot.allMenuUserItemsWithAMenuItem do
		self.cmbSelector.itemObject[self.cmbSelector.addItem(menuEntity.CM_MenuUserQuery.heading)] := menuEntity;
	endforeach;
	self.mskSnapDate.setDate(app.actualTimeServer.Date);

end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="showInvoicingResult" id="70b93295-9e18-4c3e-bec9-2da880762416">
        <source>showInvoicingResult(_snapShotData : CM_SnapshotData; _startTime : TimeStamp);

vars
	isNew	: Boolean;
	count	: Integer;
	dos		: CM_DynamicObject_Snapshot;
	invLine	: CM_InvoiceLine;
begin
	foreach dos in _snapShotData.allSnapshotData do
		foreach invLine in dos.allInvoiceLines do 
			if invLine.createdTime.date &lt; _startTime.date then
				isNew := false;
			elseif invLine.createdTime.time.truncateToSecond &lt; _startTime.time.truncateToSecond then
				isNew := false;
			else
				isNew := true;
			endif;
			if isNew then
				count := count + 1;
			endif;
		endforeach;
	endforeach;
	
	app.msgBox(count.String &amp; " invoice lines created", "SnapShot Summary Invoicing", MsgBox_OK_Only + MsgBox_Information_Icon);
end;
</source>
        <Parameter name="_snapShotData" type="CM_SnapshotData"/>
        <Parameter name="_startTime" type="TimeStamp"/>
    </JadeMethod>
