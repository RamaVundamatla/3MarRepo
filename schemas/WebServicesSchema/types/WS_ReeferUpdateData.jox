<Class name="WS_ReeferUpdateData" id="e11313cc-3c2b-4a29-a8f3-2e8eceabc803">
    <superclass name="WS_ProxyObject"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="webservice"/>
    <Constant name="TypeBoolean" id="54d10567-354c-4e9b-96d2-d0b8ad4f0fea">
        <source>"boolean"</source>
        <type name="String"/>
    </Constant>
    <Constant name="TypeDecimal" id="22599c45-e007-48b0-9078-d853b8533e82">
        <source>"decimal"</source>
        <type name="String"/>
    </Constant>
    <Constant name="TypeInteger" id="c1d8b5da-b32e-4f52-8c60-174645a9af41">
        <source>"integer"</source>
        <type name="String"/>
    </Constant>
    <PrimAttribute name="name" id="98d86bcf-c8d6-4cd9-b3ce-385c7340344e">
        <length>31</length>
        <embedded/>
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="new" id="02b0f1d2-1ba3-4439-88ad-21d715403c9b">
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="old" id="215b2c70-fdaa-4505-9fac-36ab883e153d">
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="type" id="99ef7b51-11c0-40b9-bc1b-da04c2bd662c">
        <length>31</length>
        <embedded/>
        <type name="String"/>
    </PrimAttribute>
    <JadeMethod name="setProxyTI" id="16d1c615-c263-444f-886f-807faa512e3c">
        <source>setProxyTI(	_pxyTI : CM_TrackedItem input; 
			_connectParams, _disconnectParams : CMIF_ConnectParams input;
			_tempReading : CMIF_TempReading output;
			_humidReading : CMIF_HumidReading output;
			_ventReading : CMIF_VentReading output	) : Boolean;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 22/10/2020	jlgdap1		Initial creation TFS 49227 MTN Navis API - nReefer API
// 20/01/2021	jlgdap1		TFS 50672 MTN Reefer Wants Power and On Power Issue
// 23/02/2021	navdap1		TFS 50512 MTN Reefer Monitor App Layout
// 27/09/2021	navdap1	TFS 52081 MTN Cannot Add Reading for a Reefer for a time other than Now
//
vars
	coolingType, voltageType : Integer;
	idStr : String;

begin
	// This process uses an ent table definition ETDef_ReeferAPI in group ReeferAPI to contain the list 
	// of valid fields that can be sent to the API. A subset of those fields are available for update
	// Currently limited to 
	//		carbon dioxide
	//		humidity
	//		is connected
	//		oxygen
	//		reefer remarks
	//		temperature (C)
	//		ventilation 
	// 		voltage type
	//		is externally monitored added 23 Feb 2021
	
	// has anything changed?
	idStr := _pxyTI.id;
	app.writeLog(method.qualifiedName &amp; Tab &amp; idStr &amp; " old is " &amp; self.old &amp; ", new is " &amp; new, LogDEBUG);
	if self.old = self.new then
		app.writeLog(method.qualifiedName &amp; Tab &amp; idStr &amp; " Nothing changed - returning" &amp; new, LogDEBUG);
		return true;
	endif;
	
	// connected or disconnected?
	//if self.name = ETRow_RmOnPower then			// TFS 50672
	if self.name = ETRow_IsConnected then			// TFS 50672
		if self.old.convertToBoolean = true and self.new.convertToBoolean = false then
			// disconnected
			app.writeLog(method.qualifiedName &amp; Tab &amp; "Processing " &amp; idStr &amp; " as a Disconnect", LogDEBUG);
			_disconnectParams.allTrackedItems.add(_pxyTI);
		elseif self.old.convertToBoolean = false and self.new.convertToBoolean = true then
			// connected
			app.writeLog(method.qualifiedName &amp; Tab &amp; "Processing " &amp; idStr &amp; " as a Connect", LogDEBUG);
			_connectParams.allTrackedItems.add(_pxyTI);
		endif;
		
		return true;
	
	// carbon dioxide reading?
	elseif self.name = ETRow_CarbonDioxide then
		app.writeLog(method.qualifiedName &amp; Tab &amp; "Processing " &amp; idStr &amp; " as a CO2 change", LogDEBUG);
		_pxyTI.setCarbonDioxide(self.new.Decimal);
		return true;
		
	// humidity reading?
	elseif self.name = ETRow_Humidity then
		app.writeLog(method.qualifiedName &amp; Tab &amp; "Processing " &amp; idStr &amp; " as a Humidity reading", LogDEBUG);
		create _humidReading transient;
		_humidReading.myTrackedItem := _pxyTI;
		_humidReading.dateTime := app.actualTimeServer;
		_humidReading.userId := app.getMyUserCode;
		_humidReading.myTerminal := app.myPassport.myTerminal;
		_humidReading.setHumidity(self.new.Decimal);
		return true;
		
	// oxygen reading?
	elseif self.name = ETRow_Oxygen then
		app.writeLog(method.qualifiedName &amp; Tab &amp; "Processing " &amp; idStr &amp; " as an Oxygen change", LogDEBUG);
		_pxyTI.setOxygen(self.new.Decimal);
		return true;
		
	// reefer remarks?
	elseif self.name = ETRow_ReeferRemarks then
		app.writeLog(method.qualifiedName &amp; Tab &amp; "Processing " &amp; idStr &amp; " as a Remarks change", LogDEBUG);
		if _pxyTI.getReeferRemarks &lt;&gt; null then
			_pxyTI.setReeferRemarks(_pxyTI.getReeferRemarks &amp; CrLf &amp; self.new);
		else
			_pxyTI.setReeferRemarks(self.new);
		endif;
		return true;
		
	// temperature reading?
	elseif self.name = ETRow_Temperature then
		app.writeLog(method.qualifiedName &amp; Tab &amp; "Processing " &amp; idStr &amp; " as a Temperature reading", LogDEBUG);
		create _tempReading transient;
	/*	_tempReading.dateTime := app.actualTimeServer;
		_tempReading.userId := app.getMyUserCode;
		_tempReading.myTerminal := app.myPassport.myTerminal;
		_tempReading.isRefConReading := false;
		_tempReading.isRefConAlarm := false;
		_tempReading.refConRawData := null;
		_tempReading.myTrackedItem := _pxyTI;
		_tempReading.temperature := self.new.Decimal; */
		
		//01 Sep 2021	NDL	TFS 51874 - Use common code instead of 14 different variant copies....
		_tempReading.initialise( 	_pxyTI,	//_reefer : CM_TrackedItem;
									false,	//_defaultNoChargeValue : Boolean;
									app.actualTimeServer,	//_dateTime : TimeStamp;		// TFS 52081
									self.new.Decimal	//_temperature : Real
									);
									
		return true;
		
	// ventilation reading?
	elseif self.name = ETRow_Ventilation then
		app.writeLog(method.qualifiedName &amp; Tab &amp; "Processing " &amp; idStr &amp; " as a Ventilation reading", LogDEBUG);
		create _ventReading transient;
		_ventReading.myTrackedItem := _pxyTI;
		_ventReading.dateTime := app.actualTimeServer;
		_ventReading.userId := app.getMyUserCode;
		_ventReading.myTerminal := app.myPassport.myTerminal;
		_ventReading.ventilation := self.new.Real;
		return true;
		
	// cooling type change?
	elseif self.name = ETRow_CoolingType then
		app.writeLog(method.qualifiedName &amp; Tab &amp; "Processing " &amp; idStr &amp; " as a Cooling Type change", LogDEBUG);
		coolingType := app.coolingTypeStringToENum(self.new);
		_pxyTI.setCoolingType(coolingType);
		return true;
		
	// voltage type change?
	elseif self.name = ETRow_VoltageType then
		app.writeLog(method.qualifiedName &amp; Tab &amp; "Processing " &amp; idStr &amp; " as a Voltage Type change", LogDEBUG);
		voltageType := app.voltageTypeStringToENum(self.new);
		_pxyTI.setVoltageType(voltageType);
		return true;
		
	// TFS 50512 Is Externally Monitored change
	elseif self.name = ETRow_IsExternallyMonitored then
		app.writeLog(method.qualifiedName &amp; Tab &amp; "Processing " &amp; idStr &amp; " as a Externally Monitored change", LogDEBUG);
		_pxyTI.setExternalMonitoring(self.new.Boolean);
		return true;
	// TFS 50512 end
	
	//elseif self.name = ETRow_RmWantPower or self.name = "rmLastRecordTime" or self.name = ETRow_VentUnit then									// TFS 50672
	elseif self.name = ETRow_RmOnPower or self.name = ETRow_RmWantPower or self.name = "rmLastRecordTime" or self.name = ETRow_VentUnit then	// TFS 50672
		return true;
		
	endif;
	
	return false;
epilog

end;</source>
        <Parameter name="_pxyTI" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_connectParams" type="CMIF_ConnectParams" usage="input"/>
        <Parameter name="_disconnectParams" type="CMIF_ConnectParams" usage="input"/>
        <Parameter name="_tempReading" type="CMIF_TempReading" usage="output"/>
        <Parameter name="_humidReading" type="CMIF_HumidReading" usage="output"/>
        <Parameter name="_ventReading" type="CMIF_VentReading" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateData" id="becc87db-8532-4ba6-9e82-c4b1dbcbb7bc">
        <source>validateData() : Boolean;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 15/12/2020	jlgdap1		Initial creation TFS 50508 MTN Reefer App - Job List
//
vars
	exRaised, check : Boolean;

begin
	if self.type = self.TypeDecimal and not self.new.isDecimalJMT then
		exRaised := true;
		app.raiseCMException1(Value_must_decimal, self.name, null, null);
		
	elseif self.type = self.TypeInteger and not self.new.isInteger then
		exRaised := true;
		app.raiseCMException(Value_must_integer, self.name, null);
		
	elseif self.type = self.TypeBoolean and self.new.cnIsTrueOrFalse(check) &lt;&gt; CN_OK then
		exRaised := true;
		app.raiseCMException1(Value_not_valid_boolean, self.name, null, null);
		
	elseif self.name = ETRow_CoolingType and not self.new.isOneOf(ContainerAirCooledStr, ContainerWaterCooledStr) then
		exRaised := true;
		app.raiseCMException1(Cooling_type_invalid, self.name, null, null);
		
	elseif self.name = ETRow_VoltageType and not self.new.isOneOf(ContainerDualVoltStr, ContainerSingleVoltStr) then
		exRaised := true;
		app.raiseCMException1(Voltage_type_invalid, self.name, null, null);
		
	endif;
	
epilog
	if exRaised then
		return false;
	else
		return true;
	endif;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
