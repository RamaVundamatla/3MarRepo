    <JadeMethod name="disableYA" id="64f7b4a9-2379-4006-8c95-b93e784eec96">
        <source>disableYA(_ya: CM_YardAllocation input; _disable: Boolean);
//20 November 2008	cnwdw1	
//
vars
	proxyYA: CM_YardAllocation;
	proxyCriterias: CMIF_Array;
begin
	proxyYA := app.createUpdateProxy(_ya).CM_YardAllocation;

	proxyYA.setDisabled(_disable);
	create proxyCriterias transient;
	app.myTrxUA.trxUpdateYardAllocation(proxyYA, proxyCriterias, app.myPassport);
	self.assertNoTrxErrorsOrWarnings;
epilog
	delete proxyYA;
	delete proxyCriterias;
end;</source>
        <Parameter name="_ya" type="CM_YardAllocation" usage="input"/>
        <Parameter name="_disable" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doCargoIdConversionSetup" id="fed8d7ef-3997-43c5-86d6-407e7ec7912d">
        <source>doCargoIdConversionSetup( _setUp : Boolean; _cleanUp : Boolean );
/*

Purpose:			

Parameters:			If you change this method, consider changing:

					WebServicesSchema  WS_UnitTestAgent  wsQueryCargoIdConv
					JMTUnitTest  UT_JMT  tScannedCargoIdsConv

Return Value:		

Date		Who		Reason
07 July 2016	cnwndl1	Initial creation	TFS 2275/2216

*/

constants

	BlockStackId1 : String = "UTWBS1";
	CargoTypeAbbrev : String = "AUTOGEN";
	
vars

	expectdIdArray : StringArray;
	expectdId : String;
	bs1 : CM_BlockStack;
	ti : CM_TrackedItem;
	cargoType : CM_CargoType;
	operator : CM_Operator;
	commodity : CM_Commodity;

begin

	cargoType := self.getRoot().getCargoTypeFromAbbrevOrDescr( CargoTypeAbbrev );
	commodity := cargoType.allCommodities.first;
	operator := app.myRoot.allOperators[self.getProfileSetting(UT_Profile.P_OPERATOR).asString].CM_Operator;
	
	create expectdIdArray transient;
	expectdIdArray.add( "MMEMC71XXGH031214" );
	expectdIdArray.add( "JTJHY00W6G4213860" );
	expectdIdArray.add( "1C3CCCABXGN177954" );
	expectdIdArray.add( "DUMMYLENGTHGTRTHAN20" );
	expectdIdArray.add( "MR1KU8FS2G0011903" );	//08 Aug 2016	NDL	TFS 2504
	expectdIdArray.add( "KNAPH813DG5251131" );	//10 Aug 2016	NDL	TFS 2519
	
	if _cleanUp then
		foreach expectdId in expectdIdArray do
			self.deleteTrackedItem(expectdId, false);
		endforeach;
		deleteTerminalArea(BlockStackId1);
	endif;
	
	if _setUp then
		bs1 := self.addBlockStack(BlockStackId1, 99, null);
		foreach expectdId in expectdIdArray do
			ti := self.addCargoOpts(expectdId, "", commodity.code, operator, cargoType.id);
			self.move( ti, bs1 );
		endforeach;
	endif;
	
epilog

	delete expectdIdArray;

end;</source>
        <Parameter name="_setUp" type="Boolean"/>
        <Parameter name="_cleanUp" type="Boolean"/>
    </JadeMethod>
