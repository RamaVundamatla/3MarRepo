    <JadeMethod name="onGateChange" id="28000a9d-2ab3-4f72-8244-e6da05a5ec2e">
        <updating/>
        <source>onGateChange() protected, updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date			Who		Reason
24 August 2009	cnwjk3	Initial creation
21/09/2009		cnwcs5	Changed so as not to show closed lanes or outward lanes
07/05/2017 		cnwrh7  TFS4311       #CPL - Default VTA area
12/07/2022		navmd1	TFS 52777 Tidy up/review code
*/

vars
	gate 				: CM_Gate;
	gateArea 			: CM_GateArea;
	laneNumber			: Integer;
	lc					: CM_LaneController;
begin
	// Assuming one A-gate per terminal 
	self.cmbGateLanes.clear();
	gate := self.cmbGate.listObject.CM_Gate;
	
	if gate &lt;&gt; null then
		gateArea := gate.getFirstAGate_IN();
		if gateArea &lt;&gt; null then
			if gateArea.laneCount &gt; 0 then
				self.cmbGateLanes.enabled := true;
				
				self.lblGateLane.visible := true; //cnwrd1 par 21158 18.3.2010
				self.cmbGateLanes.visible := true; //cnwrd1 par 21158 18.3.2010
				foreach laneNumber  in 1 to gateArea.laneCount	do
					lc := gateArea.getLaneByNumber(laneNumber);
					
					if lc.isUnavailable or 										// cnwcs5 21/09/2009
						lc.laneDirection &lt;&gt; CM_LaneController.Is_In_Lane then	// cnwcs5 21/09/2009
						continue;												// cnwcs5 21/09/2009
					endif;														// cnwcs5 21/09/2009
					
					self.cmbGateLanes.addItemObject(laneNumber.String, lc);
				endforeach;
			else
				self.cmbGateLanes.enabled := false;
				
				self.lblGateLane.visible := false;  //cnwrd1 par 21158 18.3.2010
				self.cmbGateLanes.visible := false;//cnwrd1 par 21158 18.3.2010
			endif;
		endif;
		self.cmbGateLanes.setIndex(1);
		
	endif;
	
	self.loadPrinterCombo();
	
	// TFS 52777
	self.setupGenericWeightInterface();
	if not self.clearingForm then
		self.myAssistant.populateScanData(false, true, self.detailsChangedVehicle, self.txtRegno, self.txtDriverCode, self.txtDriverName,
			self.txtChassisIDIn, null, self.cmbRFID, self.cmbCarrier, null, null);
	endif;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="onPINChange" id="5f766eaa-c795-4168-83d7-f7133e3b5eb6">
        <updating/>
        <source>onPINChange(_pinCode : String) updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


/* Changes

Date		Name	TFS#				Description
============================================================================
17 Jun 2009	cnwjk3						Initial creation
10 Dec 2015 cnwma1  PAR #37193 			Appointment Number Not Displayed on Receive Cargo Screen
11 Jan 2018	jlgmd1	TFS #36410 			Road Gate - Carrier not changing issue
14 May 2018	jlgdap1	TFS 38501 			PEL1 Work Order Changes
11 Mar 2019	jlgns1	TFS 3827 			XLAT_FormCaptions need to be sorted out
12/04/2019	jlgka1	TFS 44368			Add isCompleted flag to identify what error message to display when doing a road gate.
11/05/2023	navpw1	TFS: 54049 (55840)	Added validation, association and lookup for slot type valdiation vbs process
31 Aug 2023 navhl20 Bug 60183: FR | 53429 - VBS changes - Quantity assigned in the VBS is not remembered during Road Gate announcement
09 Aug 2024 navcs2	ChangeRequest 63928: EUP | Trailer Type in a VBS Slot
27 Nov 2024	navhl20 CR MTN-33483: TPT | Vehicle Truck Booking Auto Associate with Release Request
05 Feb 2025	navhl20 Bug MTN-19856: MTN - VBS Slot validation is not using the retrospective date/time entered in the gate.
21 Feb 2025	naviv1	JIRA-29374- EUP | Transaction Instrumentation - Gate
21 Mar 2025 navlc30 JIRA 34264-TPT | FR 33661.020 VBS - One Release Request and VBS slot per Truck - No VBS Appointment
01/04/2024	navcs2	MTN-34172	CUX - Additional Remarks of cargo does not pop up in Road Gate Screen during Cargo Release
14 Jan 2026 navhl20 Bug MTN-35897: PEN - System Locking Errors (1000010 - Unknown message)
============================================================================*/	
vars
	pickerShown			: Boolean;
	pinNo				: CM_PinNo;
	iter		 		: Iterator;
	obj					: Object;
	item				: Object;
	bulkRelease			: CM_BulkRelease;
	reserve				: CM_ReserveDetail;
	ti					: CM_TrackedItem;
	itemIds				: StringArray;
	vbt					: CM_VehicleBookingTerminal;
	vbsts				: CM_VehicleBookingTimeSlot;
	msg 				: String;
	tiSet				: CM_TISet;
	firstStagingLC		: CM_LocationsController;
	stagedCount			: Integer;
	outstandingCount 	: Integer;
	doAutoProcess		: Boolean;
	allowAutoPreStage 	: Boolean;
	pinCode 			: String;						// TFS 38501
	strArray 			: StringArray;
	isCompleted			: Boolean;						
	result				: Boolean;						
	terminal			: CM_Terminal;					
	vbsProcess			: CM_VBSProcess;				
	isUsingVbsSlotValidation : Boolean;
	isValid				: Boolean;
	vbsti,vbstii		: CM_VehicleBookingTimeSlotItem;
	retroDateTime		: TimeStamp;
	msgNo				: Integer;
	isUsingEnhancedStdVBS : Boolean;
	vbsEnhancedModalResult: Integer;
	reserveTI			: CM_TrackedItem;
begin
	if _pinCode = null then
		return;
	endif;
	
	pinCode := _pinCode;									
	
	terminal   := self.myTerminal;											// ### TFS 54049 (55840) 03May2023 NAVPW1
	vbsProcess := self.myVBSProcess;										// ### TFS 54049 (55840) 03May2023 NAVPW1
	
	if self.chkOpsRetrospective.value then									//05.02.2025 navhl20 #19856
		retroDateTime.setDate(self.txtDateIn.text.asDateJMT);
		retroDateTime.setTime(self.txtTimeIn.text.asTimeJMT);
	
		if retroDateTime.isValid and retroDateTime &gt; app.actualTimeServer() then	//14.02.2025 navhl20 #19856
			app.raiseCMException(Retro_date_time_shoul_not_futu, null, null);
		endif;
	endif;
	
	//20 Oct 2014	NDL	Par 35008
	//if self.myTerminal &lt;&gt; null then
	if terminal &lt;&gt; null then												// ### TFS 54049 (55840) 03May2023 NAVPW1
		isUsingVbsSlotValidation := terminal.isUsingVbsSlotValProcess();	//21.08.2023 navma1 #59709		
		vbt						 := terminal.myVehicleBookingTerminal;
		
		result 					 := self.checkVBSSlot(vbt, pinCode, vbsts);	// ### TFS 54049 (55840) 03May2023 NAVPW1
		
		if not result then
			return;
		endif;
		
		// ### TFS 54049 (55840) 03May2023 NAVPW1 - Old Code
		/*if vbt &lt;&gt; null then
			//vbsts := vbt.allVBTimeslotsById.getAtKey( _pinCode.trimBlanks.toUpper );		// TFS 38501
			vbsts := vbt.allVBTimeslotsById.getAtKey( pinCode.trimBlanks.toUpper );			// TFS 38501
			if self.myRealVVR &lt;&gt; null
			and self.myRealVVR.myVehicleBookingTimeslot &lt;&gt; null
			and self.myRealVVR.myVehicleBookingTimeslot &lt;&gt; vbsts then
				msg := app.getErrorString1( Vehic_booki_times_alrea_been_a,  self.myRealVVR.myVehicleBookingTimeslot.id );
				app.msgBox( msg, app.getErrorString(Error), MsgBox_OK_Only );
				return;
			endif;
			if vbsts &lt;&gt; null then
				self.populateFromVehicleBookingTS( vbsts );
				self.myVehicleBookingTimeslot := vbsts;        //10/12/2015 cnwma1 PAR #37193
			endif;
		endif;*/
		// ### TFS 54049 (55840) 03May2023 NAVPW1 - Old Code
		
		// ### TFS 54049 (55840) 05May2023 NAVPW1
		//if vbsts &lt;&gt; null and vbsProcess &lt;&gt; null and vbsProcess.isVbsSlotValidation then
		if vbsts &lt;&gt; null and isUsingVbsSlotValidation and self.myRealVVR &lt;&gt; null then										// ### TFS 57756 (57896) 26May2023 NAVPW1
			//result := self.myAssistant.validateVehicleAganistVBSSlot(vbsts, vbt, self.myRealVVR.allVehicleBookingSlots);	// ### TFS 57756 (57896) 26May2023 NAVPW1	//05.02.2025 navhl20 #19856
			result := self.myAssistant.validateVehicleAganistVBSSlot(vbsts, vbt, self.myRealVVR.allVehicleBookingSlots,retroDateTime);	//05.02.2025 navhl20 #19856
			
			if not result then
				return;
			endif;
		endif;
		// ### TFS 54049 (55840) 05May2023 NAVPW1
	endif;
	
	//21 Feb 2019	NDL	TFS 43491
	if pinCode.trimBlanks.pos(" ",1) &gt; 1 then
		//Contains a space, could be Pelindo passing a WO Pin, and a Container Id
		strArray := pinCode.getTokens();
		if strArray.size = 2 then
			pinNo := self.myTerminal.allPinNos[ strArray[1] ];
			if pinNo &lt;&gt; null and pinNo.isWorkOrderPin then
				ti := pinNo.getContainerFromWO( strArray[2] ); 
				if ti &lt;&gt; null then
					if ti.isNotified then
						self.openSubScreenFromTI(ti, null);
						self.doVvrAssocToVbtsStandard(vbsts);
						self.setTxtPinToNullOrVbsId();
						return;
					elseif ti.isOnSite then
						obj := ti;
						if not ti.allReserveDetails.isEmpty then
							self.openSubScreenFromBulkRelease(pinCode, ti.allReserveDetails.first.myReserveHeader, ti.allReserveDetails.first, ti,	null);			//31.8.2023 navhl20 #60183
						else
							self.openSubScreenFromTI(ti, null);
						endif;
						self.doVvrAssocToVbtsStandard(vbsts);
						self.setTxtPinToNullOrVbsId();
						return;
					else
						ti := null;
					endif;
				endif;
			endif;
		endif;
	endif;
	
	//pinNo := self.myTerminal.allPinNos[_pinCode];			// TFS 38501
	pinNo := self.myTerminal.allPinNos[pinCode];			// TFS 38501
	//if pinNo &lt;&gt; null then									// TFS 38501
	if pinNo &lt;&gt; null and not pinNo.isWorkOrderPin then		// TFS 38501
		//31 March 2011	#cnwdz2	 par27146 start
		if pinNo.status = PIN_InProcess then
			app.msgBox(app.getErrorString(ERR_PIN_INPROCESS),app.getFormCaptionsString(Xlat_0010495), MsgBox_Exclamation_Mark_Icon);
			return;
		endif;
		//31 March 2011	#cnwdz2	 par27146 end
		
		self.openFormFromPinNo(pinNo);
		return;
	else

		/*
		Moved Up 21.08.2023 navma1 #59709
		*/
		// ### TFS 54049 (55840) 16May2023 NAVPW1
		if vbsts &lt;&gt; null then
			if isUsingVbsSlotValidation  and self.myRealVVR = null then																				//21.08.2023 navma1 #59709		
				//isValid := self.myAssistant.validateVehicleAganistVBSSlot(vbsts, vbt, self.allVehicleBookingTimeslots);		//21.08.2023 navma1	#59709	//05.02.2025 navhl20 #19856
				isValid := self.myAssistant.validateVehicleAganistVBSSlot(vbsts, vbt, self.allVehicleBookingTimeslots,retroDateTime);	//05.02.2025 navhl20 #19856
				if isValid then
					self.doVvrAssocToVbtsSlotValidation(vbsts);
				else
					return;
				endif;

			endif;
			
			// 09 Aug 2024 navcs2	ChangeRequest 63928 Start
			if vbsts.myTILCType &lt;&gt; null then
				self.cmbTrlrTypeIn.listObject := vbsts.myTILCType;
			endif;
			// 09 Aug 2024 navcs2	ChangeRequest 63928 End
		endif;
		// ### TFS 54049 (55840) 16May2023 NAVPW1
		
		//14 Mar 2017	NDL	TFS 3701
		//if self.myRealVVR = null then			//11 Jan 2018	MPD TFS 36410
		//Need to make sure our vehicle visit record is updated if details on the road gate are changed
		if not self.isOKToProceed() then
			return;
		endif;
		
		// TFS 38501 Work Orders with pins will have either a booking 		// TFS 38501
		// (with prenotes) or a release request by id attached				// TFS 38501
		if pinNo &lt;&gt; null and pinNo.isWorkOrderPin then						// TFS 38501
			if self.getWorkOrderDetailsToDisplay(pinNo) then				// TFS 38501
				return;														// TFS 38501
			endif;															// TFS 38501
		endif;																// TFS 38501
		
		
		isUsingEnhancedStdVBS := terminal.getConfig(VsEnhancedStdVBS).Boolean;				//21.03.2025 navlc30 #34264
		
		if isUsingEnhancedStdVBS and not isUsingVbsSlotValidation then						//21.03.2025 navlc30 #34264
			vbsEnhancedModalResult := self.doEnhancedVBSAssociationForRR(_pinCode);
			if vbsEnhancedModalResult = ModalResultCancel then
				return;
			endif;	
		endif;
		
		if  isUsingVbsSlotValidation then									//21.08.2023 navma1 #59709
			if vbsts &lt;&gt; null then
				obj := self.myAssistant.getMatchingObjectSlotTypeVal(vbt, _pinCode, self, self.myRealVVR, pickerShown);
			else
				obj := self.getMatchingObjectToSelect(pinCode, pickerShown, isCompleted);
			endif;
		else
			obj := self.getMatchingObjectToSelect(pinCode, pickerShown, isCompleted);
		endif;
		// ### TFS 54049 (55840) 16May2023 NAVPW1
		
		// Cancelled from Picker?
		if pickerShown and obj = null then
			return;
		endif;
		
		//06 Oct 2020	NDL	TFS 49189
		if obj &lt;&gt; null and obj.isKindOf(CM_BOLDtl) then
			if obj.CM_BOLDtl.hasCargoOnShip() then
				app.msgBox("Selected BOL Detail still has cargo 'On Ship'", app.getErrorString(Warning), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon );
			endif;
			self.openSubScreenFromBOLDtl(obj.CM_BOLDtl);
			//self.doVvrAssocToVbtsStandard(vbsts);
			self.doVvrAssocToVbts(vbsts);			// ### TFS 54049 (55840) 10May2023 NAVPW1
			self.setTxtPinToNullOrVbsId();
			return;
		endif;
		
		// Booking Ref check
		if obj &lt;&gt; null and obj.isKindOf(CM_BookingRefItem) then
			self.openSubScreenFromBookingRef(obj.CM_BookingRefItem);
			//self.txtPIN.text := null;
			//self.doVvrAssocToVbtsStandard(vbsts);	//20 Oct 2014	NDL	Par 35008
			self.doVvrAssocToVbts(vbsts);			// ### TFS 54049 (55840) 10May2023 NAVPW1
			self.setTxtPinToNullOrVbsId();
			return;
		endif;
		
		// Bulk Release check
		if obj &lt;&gt; null then
			if obj.isKindOf(CM_ReserveDetail) then
				
				reserve			:= obj.CM_ReserveDetail;
				bulkRelease		:= reserve.myReserveHeader;
				if vbsts &lt;&gt; null then// ### TFS CR 59942 TASK 59943 04SEP2023 NAVAB1
					foreach vbsti in vbsts.allVehicleBookingItems do
						if vbsti.myReserveDetails &lt;&gt; null and vbsti.myReserveDetails = reserve then
							vbstii := vbsti;
						endif;
					endforeach;
				endif;
				
				//14 Feb 2017	NDL	TFS 3368
				if bulkRelease &lt;&gt; null then
					// 01/04/2024	navcs2	MTN-34172 start
					if not bulkRelease.releaseByType then
						if reserve &lt;&gt; null then
							reserveTI := reserve.CM_ReserveTI.getTI();
							if reserveTI &lt;&gt; null then
								self.showAdditionalRemarks(reserveTI.remarksAdditional1, reserveTI.remarksAdditional2);
							endif;
						endif;
					endif;
					// 01/04/2024	navcs2	MTN-34172 end
					
					if not bulkRelease.validateExpiryDateNow( msg ) then
						app.msgBox( msg, app.getErrorString(Error), MsgBox_OK_Only );
						return;
					endif;
					if msg &lt;&gt; null then
						msgNo := app.msgBox( msg, app.getErrorString(Continue), MsgBox_Yes_No);
						if msgNo &lt;&gt; MsgBox_Return_Yes then
							return;
						endif;
					endif;
					  
					self.showAdditionalRemarks( bulkRelease.remarksAdditional1, bulkRelease.remarksAdditional2 );	//11 May 2018	NDL	TFS 38566
					
					vbsts := bulkRelease.getVBTimeSlot();															//27.11.2024 navhl20 #33483
				endif;
				
				//14 Oct 2015	NDL	Par 37033 - allow for pre-staged cargo to be automatically processed thru the screens
				allowAutoPreStage := self.myTerminal.getConfig(AutoGatePreStaged).Boolean;
				if allowAutoPreStage then
					create tiSet transient;
					stagedCount := reserve.getTotalStaged( tiSet, firstStagingLC, null );
					outstandingCount := reserve.getTotalOutstanding;
					if stagedCount &gt; 0 and stagedCount = outstandingCount then
						if self.isOKToProceed() then
							msg := app.getErrorString1(Items_this_relea_alrea_stage_w, stagedCount.String );
							doAutoProcess := app.msgBox( msg, app.getErrorString(Process_automatically), MsgBox_Yes_No) = MsgBox_Return_Yes;
						endif;
					endif;
				endif;
				if allowAutoPreStage and doAutoProcess then
					self.createCMGTEsFormStagedCargo( tiSet, reserve );
				else
					//self.openSubScreenFromBulkRelease(_pinCode, bulkRelease, reserve);	// TFS 38501
					self.openSubScreenFromBulkRelease(pinCode, bulkRelease, reserve, null, vbstii);		// TFS 38501		//31.8.2023 navhl20 #60183
				endif;
				//self.txtPIN.text := null;
				//self.doVvrAssocToVbtsStandard(vbsts);	//20 Oct 2014	NDL	Par 35008
				self.doVvrAssocToVbts(vbsts);			// ### TFS 54049 (55840) 10May2023 NAVPW1
				self.setTxtPinToNullOrVbsId();
				
				return;
			endif;
			
			
		endif;
		
		// Tracked Item check
		if obj &lt;&gt; null and obj.isKindOf(CM_TrackedItem) then
			self.openSubScreenFromTI(obj.CM_TrackedItem, null);
			//self.txtPIN.text := null;
			//self.doVvrAssocToVbtsStandard(vbsts);	//20 Oct 2014	NDL	Par 35008
			self.doVvrAssocToVbts(vbsts);			// ### TFS 54049 (55840) 10May2023 NAVPW1
			self.setTxtPinToNullOrVbsId();
			
			self.showAdditionalRemarks( obj.CM_TrackedItem.remarksAdditional1, obj.CM_TrackedItem.remarksAdditional2 );	//11 May 2018	NDL	TFS 38566
			return;
		endif;
		// 29287 Apr 2012 multi-select pre-notes in road gate, passed back as an array
		if obj.isKindOf(ObjectArray) then
			if obj.ObjectArray.size &gt; 0 then
				item := obj.ObjectArray.first;
				if item &lt;&gt; null and item.isKindOf(CM_TrackedItem) then
					ti := item.CM_TrackedItem;
					create itemIds transient;
					foreach item in obj.ObjectArray do
						if item.isKindOf(CM_TrackedItem) then
							itemIds.add(item.CM_TrackedItem.id);
						endif;
					endforeach;
					self.openSubScreenFromTI(ti, itemIds);
					//self.txtPIN.text := null;
					//self.doVvrAssocToVbtsStandard(vbsts);	//20 Oct 2014	NDL	Par 35008
					self.doVvrAssocToVbts(vbsts);			// ### TFS 54049 (55840) 10May2023 NAVPW1
					self.setTxtPinToNullOrVbsId();
					return;
				endif;
			endif;
		endif;
		//jlgka1 TFS 44368 --&gt;
		if isCompleted then
			app.msgBox(app.getErrorString(Warning_RelReq_NotActive),app.getFormCaptionsString(Xlat_0010495), MsgBox_Exclamation_Mark_Icon);
		else 
			app.msgBox(app.getErrorString1(WARNING_ITEM_NUMBER,null),app.getFormCaptionsString(Xlat_0010495), MsgBox_Exclamation_Mark_Icon);
		endif;
		//jlgka1 TFS 44368 &lt;--
		self.txtPIN.setFocus();
		self.txtPIN.selectAll();
	endif;
epilog
	delete iter;
	if obj &lt;&gt; null and
	   obj.isKindOf(ObjectArray) then
		delete obj;
	endif;
	delete itemIds;
	delete tiSet;
	delete strArray;
	app.mousePointer := Window.MousePointer_Default;
end;</source>
        <access>protected</access>
        <Parameter name="_pinCode" type="String"/>
    </JadeMethod>
    <JadeMethod name="onRegChanged" id="2c9d230f-8128-4aab-b08e-09e7178abd69">
        <updating/>
        <source>onRegChanged() protected, updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24/09/2009	cnwjk3	Initial creation
02/12/2014	cnwer1	par 35304
17/05/2016	cnwdap1	TFS STWR #1970 Correct checking of current vehicle visit record
14/09/2016	cnwma1	TFS #2619:SPT - Road Gate loading incorrect release/prenote details when entering the Reg Code
30/09/2016	cnwdap1	TFS 2720 Correct the checking of whether there is already a vvr for this truck
04/03/2019	jlgdap1	TFS 48688 SNO Driver Identity Checking for Some Variances in Road Gate Process
10/06/2024	jlizm1	TFS 63908 Allow duplicate driver names
21/02/2025	naviv1	JIRA-29374- EUP | Transaction Instrumentation - Gate
14 Jan 2026 navhl20 Bug MTN-35897: PEN - System Locking Errors (1000010 - Unknown message)
*/
vars
	vehicle : CM_Vehicle;
	driver 	: CM_DriverDetails;
begin
	vehicle := self.getVehicle();					// TFS 2720
	
	if vehicle = null then
		return;
	endif;
	
	self.cmbCarrier.cnEcSetObjectIndex(vehicle.carrier);
	self.populateTblBulkRelease(self.cmbCarrier.listObject.CM_Carrier); //epr par 36674 2/9/15
	if self.cmbCarrier.listObject &lt;&gt; null and self.cmbDriver.visible then
		self.cmbCarrier.enabled:=false;
	else
		self.cmbCarrier.enabled:=true;
	endif;
	
	self.cmbDriver.clear;
	self.cmbDriverCode.clear;
	self.cmbDriverCode.visible := false;
	if self.cmbDriver.visible then
		self.cmbDriver.listCollection(vehicle.allDrivers,true,ComboBox.DisplayCollection_Forward);	
	elseif not self.myTerminal.getConfig(HideRGateDriverCodeName).Boolean then 
		self.txtDriverCode.visible := true;
	endif;
	
	driver := vehicle.getOnlyDriverForTerminal;
	if driver &lt;&gt; null then
		if not self.btnCheckID.visible then					// TFS 48688
			if self.txtDriverCode.visible and self.txtDriverCode.text.trimBlanks = null then
				self.txtDriverCode.text:=driver.code;
			endif;
			if self.txtDriverName.visible and self.txtDriverName.text.trimBlanks = null then
				self.txtDriverName.text:=driver.name;
			endif;
			
			if self.cmbDriver.visible and self.cmbDriver.listObject = null then
				self.cmbDriver.listObject:=driver;
			endif;
		else												// TFS 48688
			self.txtDriverCode.text := null;				// TFS 48688
			self.txtDriverName.text := null;				// TFS 48688
			self.cmbDriver.listIndex := -1;					// TFS 48688
		endif;												// TFS 48688
	endif;
	
	//04 Nov 2015	NDL	Par 36886
	if self.myRealVVR = null then
		if self.checkVehicleVisit(vehicle) then //epr TFS 1602 1/3/17
			self.myRealVVR:=null; 
		endif;
	endif;
	
epilog
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="onTrailerIdINChange" id="b2f62f50-65cd-418c-b8ea-3ca71dcf5cd6">
        <source>onTrailerIdINChange(_id : String) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 September 2009	cnwjk3	Initial creation

*/

vars
	masterTrailer : CM_TIMasterTILC;
	trailer : CM_TILC;
	startObject : CM_TrackedItem;
	iter : Iterator;
	prospect : CM_TrackedItem;
	preNotedTrailer : CM_TrackedItem;
begin
	if self.myTerminal.getConfig(FleetFileTrailerDetails).Boolean then
		masterTrailer := app.myRoot.findTIMasterTrailerByID(_id);
		if masterTrailer &lt;&gt; null then
			self.setChassisInFieldsFromMaster(masterTrailer);
		else
			self.clearChassisInFields();
		endif;
	endif;
	//epr par 34004 20/5/14
	if masterTrailer = null then
		if self.myTerminal.getConfig(PrefillPreNoteRoadGate).Boolean then
			trailer := self.myTerminal.lookupTrailerOffsite(_id,null);
			if trailer &lt;&gt; null then
				self.cmbTrlrTypeIn.setIndexFromObject (trailer.myTILCType);
				self.cmbTrlrTypeIn.click(self.cmbTrlrTypeIn);
				self.cmbOperatorIn.setObject(trailer.myOperator);
				if trailer.myOperator = null and self.myTerminal.roadProcessIsASPA then	//28 Oct 2020	NDL	TFS S50113
					self.cmbOperatorIn.setObject( self.myTerminal.getConfig(DefRecTrailOper).CM_Operator );
				endif;
				
			endif;
		
		endif;
	endif;
	
	//21 Aug 2019	NDL	TFS 46040
	if trailer &lt;&gt; null and trailer.isNotified then
		preNotedTrailer := trailer;
	else
		startObject := self.myTerminal.allNotifiedTIsByIdCargoType.getAtKeyGeq( _id, null );
		if startObject &lt;&gt; null and startObject.id = _id then
			iter := self.myTerminal.allNotifiedTIsByIdCargoType.createIterator;
			iter.startAtObject( startObject );
			while iter.next( prospect ) do
				if prospect.id &lt;&gt; _id then
					break;
				endif;
				if not prospect.isChassis then
					continue;
				endif;
				preNotedTrailer := prospect;
				break;
			endwhile;
		endif;
	endif;
	if preNotedTrailer &lt;&gt; null then
		self.showAdditionalRemarks( preNotedTrailer.remarksAdditional1, preNotedTrailer.remarksAdditional2 );
	endif;
	
epilog

	delete iter;
	
end;</source>
        <access>protected</access>
        <Parameter name="_id" type="String"/>
    </JadeMethod>
    <JadeMethod name="onTrailerIdOUTChange" id="df24bf85-ad96-4a7a-baf4-f43db3860097">
        <source>onTrailerIdOUTChange(_id : String) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 September 2009	cnwjk3	Initial creation

*/

vars
	locText : String;
	trailer : CM_TILC;
begin
	trailer := self.getChassisLocation(_id,  locText);
	self.displayChassisOutLoc(locText);
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_id" type="String"/>
    </JadeMethod>
    <JadeMethod name="onTrlTypeINChange" id="2a17b2b7-caaf-43b3-83be-817e4b44e1c0">
        <source>onTrlTypeINChange(_trlType : CM_TILCType) protected;

/*
Date			Who		Reason
11 April 2013	cnwar2	#31332
26 Sept 2013	cnwdap1	PAR #32536 Tare Weight In field is now a measurement table
*/
vars
	measure	: CM_MeasurementType;

begin
	if _trlType &lt;&gt; null then
		measure 						:= app.getDefaultMeasurementForType(Type_Weight);
		//self.txtTareChassIN.decimals	:= measure.getDecimalPrecision;															// PAR #32536
		//self.txtTareChassIN.text		:= app.convertMeasurementForDisplay(measure.shortName, _trlType.tareWeight);			// PAR #32536
		self.txtTareChassIN.setValues(app.convertMeasurementForDisplay(measure.shortName, _trlType.tareWeight) &amp; Space &amp; measure.shortName);	// PAR #32536
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_trlType" type="CM_TILCType"/>
    </JadeMethod>
    <JadeMethod name="openFormFromPinNo" id="51ac391f-5c16-48b9-897b-7d8418a29c41">
        <updating/>
        <source>openFormFromPinNo(_pinNo : CM_PinNo) updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17/06/2009	cnwjk3	Initial creation
14/05/2018	jlgdap1	TFS 38501 PEL1 Work Order Changes
07/01/2022	navdap1	TFS 52268 AAT 1-Stop VBS Integration
31 Aug 2023 navhl20 Bug 60183: FR | 53429 - VBS changes - Quantity assigned in the VBS is not remembered during Road Gate announcement
*/

	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	item		: Object;
	ti			: CM_TrackedItem;
	br,bulkRelease	: CM_BulkRelease;		//cnwas3 par26675
	reserve		: CM_ReserveDetail;
	msg : String;
	
begin
	foreach item in _pinNo.allItems discreteLock do  //+ cnwmd1 Par 25448 added dicreteLock
		if item.isKindOf(CM_TrackedItem) then	
			ti := item.CM_TrackedItem;
			
			// TFS 52268 if this is a prenote container, check for VBS slots
			if self.myTerminal.is1STOPVBS and self.myTerminal.is1STOPVBSConfigured then
				if not self.checkFor1StopVBS(ti) then
					return;
				endif;
			endif;
			// TFS 52268 end of this bit

			self.showAdditionalRemarks( ti.remarksAdditional1, ti.remarksAdditional2 );	//11 May 2018	NDL	TFS 38566
			
			self.openSubScreenFromTI(ti, null);
		elseif item.isKindOf(CM_BulkRelease) then
			br := item.CM_BulkRelease;												//cnwas3 par26675
			if self.myTerminal.allBulkReleasesByCodeDate.includes(br) then			//cnwas3 par26675
				bulkRelease := br;													//cnwas3 par26675
			endif;
			if self.myAssistant.getReserveDetailFromCode(br.code, bulkRelease, reserve, true) then
				if not bulkRelease.isActiveRoadRelease() then
					
					app.msgBox(app.getErrorString(WARNING_PIN_NOT_ACTIVE_RR), app.getFormCaptionsString(Xlat_0010495), MsgBox_Exclamation_Mark_Icon);		
					self.txtPIN.setFocus();
					self.txtPIN.selectAll();
					return;
				endif;	
				
				// TFS 52268 if this is a release by type for containers, check for 1-Stop VBS slots
				if self.myTerminal.is1STOPVBS and self.myTerminal.is1STOPVBSConfigured then
					if not self.checkFor1StopVBS(bulkRelease) then
						return;
					endif;
				endif;
				// TFS 52268 end of this bit
				
				self.showAdditionalRemarks( bulkRelease.remarksAdditional1, bulkRelease.remarksAdditional2 );	//11 May 2018	NDL	TFS 38566
					
				self.openSubScreenFromBulkRelease(br.code, bulkRelease, reserve, null, null);					//31.8.2023 navhl20 #60183
			endif;				
			
		elseif item.isKindOf(CM_WorkOrderTI) then						// TFS 38501
			// This is just here so we don't get an exception below		// TFS 38501
			
		else
			//app.raiseUnexpectedProgramError(class.name, method.name,'Unknown object in CM_PinNo.allItems (' &amp; item.String &amp; ')');
			app.raiseUnexpectedProgramError(class.name, method.name,app.getErrorString1(ERROR_UNKNOWN_PIN,item.String ));
		endif;
	endforeach;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_pinNo" type="CM_PinNo"/>
    </JadeMethod>
    <JadeMethod name="openSubScreenFromBOLDtl" id="754ab20a-dd47-42aa-ac18-e193a3766449">
        <updating/>
        <source>openSubScreenFromBOLDtl( _bolDtl : CM_BOLDtl )updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 October 2020	jlgndl1	Initial creation	TFS 49189
31 Aug 2023 	navhl20 Bug 60183: FR | 53429 - VBS changes - Quantity assigned in the VBS is not remembered during Road Gate announcement
*/

vars
	commodity : CM_Commodity;	
begin
	if self.myRealVVR &lt;&gt; null or self.isOKToProceed() then
		self.myAssistant.showCargoReleaseFromFlexiGate(self, false, CMUI_FlexiCargoForm.FLEXI_CARGO_GENERAL, 2, 200, null, false, null, null, null, null, null, _bolDtl, self.myRealVVR, null, null);	//31.8.2023 navhl20 #60183		
	endif;
epilog

end;</source>
        <Parameter name="_bolDtl" type="CM_BOLDtl"/>
    </JadeMethod>
    <JadeMethod name="openSubScreenFromBookingRef" id="97df8483-c202-4019-ad0d-48977687d123">
        <updating/>
        <source>openSubScreenFromBookingRef(_bookingRefItem : CM_BookingRefItem) updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14/07/2009	cnwjk3	Initial creation
14/10/2009	cnwdap1	PAR #21334 Make receival form non-modal
*/

vars
	commodity : CM_Commodity;	
begin
	if self.myRealVVR &lt;&gt; null or self.isOKToProceed() then
		
		if _bookingRefItem.cargoType = TI_CargoType_Container then
			commodity := app.myRoot.allCommodities[_bookingRefItem.commodity];
			if commodity &lt;&gt; null and commodity.isEmpty then
				self.myAssistant.showCargoReceiptFromFlexiGate(self, false, CMUI_FlexiCargoForm.FLEXI_CARGO_EMPTY, 3, 160, null, false, null, null, null, null, _bookingRefItem, null, self.myRealVVR, null);
			else
				self.myAssistant.showCargoReceiptFromFlexiGate(self, false, CMUI_FlexiCargoForm.FLEXI_CARGO_FULL, 3, 160, null, false, null, null, null, null, _bookingRefItem, null, self.myRealVVR, null);
			endif;
		else
			self.myAssistant.showCargoReceiptFromFlexiGate(self, false, CMUI_FlexiCargoForm.FLEXI_CARGO_GENERAL, 3, 200, null, false, null, null, null, null, _bookingRefItem, null, self.myRealVVR, null);		
		endif;
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_bookingRefItem" type="CM_BookingRefItem"/>
    </JadeMethod>
    <JadeMethod name="openSubScreenFromBulkRelease" id="797c50d4-5297-4636-970d-07f239d267cb">
        <updating/>
        <source>openSubScreenFromBulkRelease( _pinCode : String; _bulkRelease : CM_BulkRelease; _reserve : CM_ReserveDetail; _selectedTi : CM_TrackedItem; _vbsti : CM_VehicleBookingTimeSlotItem )updating, protected;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04/08/2009	cnwdap1	Initial creation
14/10/2009	cnwdap1	PAR #21334 Make form non-modal
14/05/2018	jlgdap1	TFS 38501 PEL1 Work Order Changes
20/07/2018	jlgdap1	TFS 39697 PEN Carrier **** is not assigned to release
31 Aug 2023 navhl20 Bug 60183: FR | 53429 - VBS changes - Quantity assigned in the VBS is not remembered during Road Gate announcement
*/
vars
	str	: String;
	cargoType 	: CM_CargoType;
	ti			: CM_TrackedItem;
begin
	if _bulkRelease.type &lt;&gt; BR_TYPE_ROAD then
		return;
	endif;
	
	if _bulkRelease.status &lt;&gt; BR_ACTIVE then
		self.txtPIN.setFocus();
		app.msgBox(app.getErrorString2(WARNING_STATUS_RELEASE_JOB, _pinCode, _bulkRelease.statusString) &amp; 
		CrLf &amp; CrLf &amp; app.getErrorString(WARNING_STATUS_RR_MUST_ACTIVE), self.caption, MsgBox_OK_Only + MsgBox_Information_Icon);
		return;
	endif;
	
	//if self.myRealVVR &lt;&gt; null or self.isOKToProceed() then		// TFS 39697
	if self.isOKToProceed() or self.myRealVVR &lt;&gt; null then			// TFS 39697
		cargoType := _reserve.getCargoType();
	//	if cargoType = null then
		if cargoType = null and _reserve.myBOLIn = null then		//18 Feb 2014	NDL	Par 33524
			app.raiseCMException(ERROR_UNDETERMINED_CARGO_RR,null,null); //epr par 36593 9/10/15
		endif;
		
	//	if cargoType.id = TI_CargoType_Container then
		if ( cargoType = null and _reserve.myBOLIn &lt;&gt; null  ) or cargoType.id = TI_CargoType_Container then		//18 Feb 2014	NDL	Par 33524
			if (_selectedTi &lt;&gt; null and not _selectedTi.isEmpty()) or _bulkRelease.fullRelease then				// 19/9/19 MAP TFS46539 if TI is known, determine whether container is full/empty from it, instead of from release
				// Open Release Full and populate fields from bulk release and resreve detail
				self.myAssistant.showCargoReleaseFromFlexiGate(self, false, CMUI_FlexiCargoForm.FLEXI_CARGO_FULL, 2, 200, null, false, null, _bulkRelease, _reserve, _selectedTi, null, null, self.myRealVVR, null, _vbsti);	//31.8.2023 navhl20 #60183
			else
				// Open Release Empty and populate fields from bulk release and resreve detail
				self.myAssistant.showCargoReleaseFromFlexiGate(self, false, CMUI_FlexiCargoForm.FLEXI_CARGO_EMPTY, 2, 200, null, false, null, _bulkRelease, _reserve, _selectedTi, null, null, self.myRealVVR, null, _vbsti);	//31.8.2023 navhl20 #60183

			endif;
		else
			self.myAssistant.showCargoReleaseFromFlexiGate(self, false, CMUI_FlexiCargoForm.FLEXI_CARGO_GENERAL, 2, 200, null, false, null, _bulkRelease, _reserve, _selectedTi, null, null, self.myRealVVR, null, _vbsti);		//31.8.2023 navhl20 #60183
		endif;	
	endif;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_pinCode" type="String"/>
        <Parameter name="_bulkRelease" type="CM_BulkRelease"/>
        <Parameter name="_reserve" type="CM_ReserveDetail"/>
        <Parameter name="_selectedTi" type="CM_TrackedItem"/>
        <Parameter name="_vbsti" type="CM_VehicleBookingTimeSlotItem"/>
    </JadeMethod>
    <JadeMethod name="openSubScreenFromTI" id="aa373b3f-533b-4ab4-9deb-c1d586cd0486">
        <updating/>
        <source>openSubScreenFromTI(_ti : CM_TrackedItem; _itemIds : StringArray) updating, protected;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14/07/2009	cnwjk3	Initial creation
14/10/2009	cnwdap1	PAR #21334 Make receival form non-modal
Apr 2012 			29287 multi-select pre-notes in road gate, itemIds passed in
14/05/20148	jlgdap1	TFS 38501 PEL1 Work Order Changes
31 Aug 2023 navhl20 Bug 60183: FR | 53429 - VBS changes - Quantity assigned in the VBS is not remembered during Road Gate announcement
20 Sep 2023 navhl20 ChangeRequest 60417: EUP | FR | 53429 VBS Changes - Assigning of Release line items to VBS Slots for gate Picker screen
*/
vars
	commodity : CM_Commodity;	
begin
		if _ti.state = TI_STATE_NORMAL then // ti is on site
							
			// This will be from the Cargo Release Imports Screen and will result in a Release by ID.
				
			if self.myRealVVR &lt;&gt; null or self.isOKToProceed() then  // Ensures a persistent VVR is created before we go any further 
				commodity := _ti.getCommodityObject();
				if commodity &lt;&gt; null then 
					if commodity.isEmpty then
						// Open Release Empty and populate fields from the TI
						self.myAssistant.showCargoReleaseFromFlexiGate(self, false, CMUI_FlexiCargoForm.FLEXI_CARGO_EMPTY, 2, 200, null, false, null, null, null, _ti, null, null, self.myRealVVR, null, null);	//31.8.2023 navhl20 #60183
					else
						// Open Release Full and populate fields from the TI
						self.myAssistant.showCargoReleaseFromFlexiGate(self, false, CMUI_FlexiCargoForm.FLEXI_CARGO_FULL, 2, 200, null, false, null, null, null, _ti, null, null, self.myRealVVR, null, null);	//31.8.2023 navhl20 #60183
					endif;
				else																																															//20.9.2023 navhl20 #60417
					self.myAssistant.showCargoReleaseFromFlexiGate(self, false, CMUI_FlexiCargoForm.FLEXI_CARGO_GENERAL, 2, 200, null, false, null, null, null, _ti, null, null, self.myRealVVR, null, null);
				endif;				
			endif;				
				
		elseif _ti.state = TI_STATE_NOTIFIED then	//pre-noted
			
			if self.myRealVVR &lt;&gt; null or self.isOKToProceed() then  // Ensures a persistent VVR is created before we go any further 
				if _ti.cargoType = TI_CargoType_Container then
					commodity := _ti.getCommodityObject();
					if commodity &lt;&gt; null then 
						if commodity.isEmpty then
							// Open Receive Empty and populate fields from the prenote TI
							self.myAssistant.showCargoReceiptFromFlexiGate(self, false, CMUI_FlexiCargoForm.FLEXI_CARGO_EMPTY, 3, 160, null, false, null, null, null, _ti, null, null, self.myRealVVR, _itemIds);
						else
							// Open Receive Full and populate fields from the prenote TI
							self.myAssistant.showCargoReceiptFromFlexiGate(self, false, CMUI_FlexiCargoForm.FLEXI_CARGO_FULL, 3, 160, null, false, null, null, null, _ti, null, null, self.myRealVVR, _itemIds);
						endif;
					else
						// Assume prenote is for MT
						self.myAssistant.showCargoReceiptFromFlexiGate(self, false, CMUI_FlexiCargoForm.FLEXI_CARGO_EMPTY, 3, 160, null, false, null, null, null, _ti, null, null, self.myRealVVR, _itemIds);
					endif;
				else
						// General Cargo
						self.myAssistant.showCargoReceiptFromFlexiGate(self, false, CMUI_FlexiCargoForm.FLEXI_CARGO_GENERAL, 3, 160, null, false, null, null, null, _ti, null, null, self.myRealVVR, _itemIds);				
				endif;
				
			endif;
		endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_itemIds" type="StringArray"/>
    </JadeMethod>
