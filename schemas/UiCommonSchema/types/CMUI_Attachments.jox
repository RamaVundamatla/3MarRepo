    <JadeMethod name="addItem" id="ade43116-da9d-4ec8-94f8-bd0797591922">
        <updating/>
        <source>addItem() updating;
// ---------------------------------------------------------------------------
// Created:     08 February 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	intFaceAttach		: CMIF_InOutAttachment;
	cargoType			: Integer;
	rowName				: String;	

begin
	rowName := ETRow_Id; //see epilog for use - default to the Id Row
	
	if cmbTiType.listObject &lt;&gt; null then
		cargoType := cmbTiType.listObject.CM_CargoType.id;
	endif;

	create intFaceAttach transient;

	if self.myCurrentView.name = 'Default' then
		intFaceAttach.set(self.myTerminal,
						  cargoType, 
						  tblItem.getValueByName(ETRow_Id).String,
						  tblItem.getValueByName(ETRow_IsoType).String,
						  tblItem.getValueByName(ETRow_WeightTotal).Integer);

	elseif self.myCurrentView.name = 'LogAttachment' then
		cargoType := TI_CargoType_Log;
		intFaceAttach.setLog(self.myTerminal,
						     TI_CargoType_Log, 
							 tblItem.getValueByName(ETRow_LogId).String,
							 tblItem.getValueByName(ETRow_SedMax).Integer,
							 tblItem.getValueByName(ETRow_SedMin).Integer,
							 tblItem.getValueByName(ETRow_LogCondition).String);
	endif;

	// check all fields have been entered

	on CM_Exception do addExceptionHandler(exception, app.myPassport);

	app.setContinueCMExceptions(true);

	intFaceAttach.checkFieldsNotNull(cargoType);
	self.checkForDuplicates(intFaceAttach);

	if app.myPassport.hasErrors then
		app.showErrorWarningDialog('Attachments', app.myPassport, ErrWarnMode_Add);
		delete intFaceAttach;
		return;
	endif;
	
	self.allAttachments.add(intFaceAttach);
	self.tblAll_ShowAttachment(intFaceAttach, 0);
	tblItem.setFocus();
epilog
	self.tblItem.setFocus;
	self.tblItem.goToRowByName(rowName);
	app.myPassport.clearErrorsWarnings();	
end;</source>
    </JadeMethod>
    <JadeMethod name="checkForDuplicates" id="a8bd8e9e-997e-4d2f-b030-77fbe9ce1e25">
        <source>checkForDuplicates(_checkObj : CMIF_Object)protected;
//--------------------------------------------------------------
//Created: 12 April 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	obj : CMIF_InOutAttachment;
	intFaceObj : CMIF_InOutAttachment;
begin
	if _checkObj.isKindOf(CMIF_InOutAttachment) then
		intFaceObj := _checkObj.CMIF_InOutAttachment;
	else
		return; //error
	endif;
		
	foreach obj in self.allAttachments do
		if obj.id = intFaceObj.id then
			app.raiseCMException1(VB_DUPLICATED_ITEM, 'Cargo Item ' &amp; intFaceObj.id, 'id', null);
		endif;
	endforeach;
end;</source>
        <access>protected</access>
        <Parameter name="_checkObj" type="CMIF_Object"/>
    </JadeMethod>
