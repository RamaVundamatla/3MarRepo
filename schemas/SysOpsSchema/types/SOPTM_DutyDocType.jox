    <JadeMethod name="getImex" id="ab4590a0-d4d5-4268-96f0-0457c64216ee">
        <source>getImex(str : String) : Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 March 2013	cnwer1	Initial creation PAR 31299

*/

vars
	imexStatus : CM_IMEXStatus;
begin
	
	foreach imexStatus in 	app.myRoot.allImexStatuses discreteLock do
		if imexStatus.description = str then
			return imexStatus.code;
		endif;
	endforeach;
	
	return 0;
epilog

end;</source>
        <Parameter name="str" type="String"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
