    <JadeMethod name="purgeDatabase" id="77f1576b-f2a0-423e-aa1f-c819355d57fd">
        <updating/>
        <source>purgeDatabase(_bgpRequest : BGP_DatabasePurgeRequest; _terminal : CM_Terminal; _date : Date) : Boolean updating;
// -------------------------------------------
// Created 23 August 2004 by cnwdvb1
// -------------------------------------------
//23/05/2012	cnwrs1		Par 29613
//01 Nov 2017	jlgns1		TFS 6960 QNS - Disk space issues and house keeping inside JMT
//9/11/17 		jlgns1 		TFS 6960 QNS - Disk space issues and house keeping inside JMT
// 24/09/2021	navdap1		TFS 52072 AAT Customs Stops Removed from Voyage BOLs
// 20 September 2022 navmv20 ChangeRequest 53403: MTN - Garbage Collection of Release Request
//14 Feb 2023 	navhl20 	ChangeRequest 54900:[56518] EUP - Garbage Collection for Document Attachments
//21 Jul 2023 	navhl20 	ChangeRequest 58158: EUP | [Framework] - Delivery Dispatch Garbage Collection
//11 Aug 2025 	navhl20 	Story MTN-35650: TPT | Uploading of Photos into MTN Production | 2 | Thin Client Changes
vars
	errCode		: Integer;
	errTxt		: String;
	returnCode	: Boolean;
	objArray	: ObjectArray;
	object		: Object;
	psRelease 	: PortSchemaRelease;
	
begin
	on Exception do app.alertExceptionHandler(exception, null, app.getErrorString(Garbage_Collection), errCode, errTxt, true, false);
	on Exception do self.xHandlerLogError(exception);
	
	app.cnEcSetBaseRoot(true);			// TFS 52072
	
	self.myBGPRequest	:= _bgpRequest;
	self.myTerminal		:= _terminal;
	self.date			:= _date;
	
	self.createActivityHistory(app.getErrorString1(Activate_Database_Purge, _terminal.name)&amp;' For User ' &amp; self.myBGPRequest.getUserCode()[1:10].trimBlanks&amp;' upto '&amp;_date.String, false, false);
	
	if self.myBGPRequest.maxDurationMinutes &gt; 0 then													//TFS 6960
		self.finishTimeStamp := app.actualTimeServer.addMinutes(self.myBGPRequest.maxDurationMinutes);	//TFS 6960
	endif;																								//TFS 6960
	
	if self.myBGPRequest.purgeArchivedVoyages then
		self.setCurrentArchiveType(app.getErrorString(Archived_Voyages));//TFS 6960
		app.sendHeartbeatIfRequired();		// 5/9/17 MAP TFS5551
		if not self.doPurgeArchivedVoyages() then
			returnCode := false;
			return returnCode;
		endif;
	endif;
	if self.abort() then
		returnCode := false;
		return returnCode;
	endif;
	
	if self.myBGPRequest.purgeArchivedLocations then
		self.setCurrentArchiveType(app.getErrorString(Archived_Locations));//TFS 6960
		app.sendHeartbeatIfRequired();		// 5/9/17 MAP TFS5551
		if not self.doPurgeArchivedLocations() then
			returnCode := false;
			return returnCode;
		endif;
	endif;
	if self.abort() then
		returnCode := false;
		return returnCode;
	endif;
	
	if self.myBGPRequest.purgeOffsiteTis then
		self.setCurrentArchiveType(app.getErrorString(Off_Site_Deleted_Tracked_Items));//TFS 6960
		app.sendHeartbeatIfRequired();		// 5/9/17 MAP TFS5551
		if not self.doPurgeOffsiteTis() then
			returnCode := false;
			return returnCode;
		endif;
	endif;
	if self.abort() then
		returnCode := false;
		return returnCode;
	endif;
	
	 // ### TFS 50669 06AUG2021 NAVAB1
	if self.myBGPRequest.purgeNavisSmartActivity then
		self.setCurrentArchiveType(app.getErrorString(Archive_navis_smart_activit));//TFS 6960
		app.sendHeartbeatIfRequired();		// 5/9/17 MAP TFS5551
		if not self.doPurgeNavisSmartActivity() then
			returnCode := false;
			return returnCode;
		endif;
	endif;
	if self.abort() then
		returnCode := false;
		return returnCode;
	endif;
	
	
	//22 Jun 2015	NDL	Par 36338
	if app.isCargoGroupEnabled then
		if self.myBGPRequest.purgeReleasedCargoGroups then
			app.sendHeartbeatIfRequired();		// 5/9/17 MAP TFS5551
			self.setCurrentArchiveType(app.getErrorString(Cargo_group_with_remai_onsit_c));//TFS 6960
			if not self.doPurgeReleasedCargoGroups() then
				returnCode := false;
				return returnCode;
			endif;
		endif;
		if self.abort() then
			returnCode := false;
			return returnCode;
		endif;
	endif;
	
	if self.myBGPRequest.purgePrenotedTis then
		self.setCurrentArchiveType(app.getErrorString(Prenotes));//TFS 6960
		app.sendHeartbeatIfRequired();		// 5/9/17 MAP TFS5551
		if not self.doPurgePrenotedTis() then
			returnCode := false;
			return returnCode;
		endif;
	endif;

	if self.myBGPRequest.purgeBookingRefTis then
		self.setCurrentArchiveType(app.getErrorString(BookingRef));//TFS 6960
		app.sendHeartbeatIfRequired();		// 5/9/17 MAP TFS5551
		if not self.doPurgeBookingRefTis() then
			returnCode := false;
			return returnCode;
		endif;
	endif;

	if self.abort() then
		returnCode := false;
		return returnCode;
	endif;
	
	if self.myBGPRequest.purgeEmptyBOLIns then
		self.setCurrentArchiveType(app.getErrorString(Receival_Dockets));//TFS 6960
		app.sendHeartbeatIfRequired();		// 5/9/17 MAP TFS5551
		if not self.doPurgeEmptyBOLIns() then
			returnCode := false;
			return returnCode;
		endif;
	endif;
	if self.abort() then
		returnCode := false;
		return returnCode;
	endif;

	if self.myBGPRequest.purgeMachineHistory then
		self.setCurrentArchiveType(app.getErrorString(Machine_History));//TFS 6960
		app.sendHeartbeatIfRequired();		// 5/9/17 MAP TFS5551
		if not self.doPurgeMachineHistory() then
			returnCode := false;
			return returnCode;
		endif;
	endif;
	if self.abort() then
		returnCode := false;
		return returnCode;
	endif;
	
	if self.myBGPRequest.purgeNonContainerDiscrepancies then
		self.setCurrentArchiveType(app.getErrorString(Non_Container_Discrepancies));//TFS 6960
		app.sendHeartbeatIfRequired();		// 5/9/17 MAP TFS5551
		if not self.doPurgeDiscrepancies() then
			returnCode := false;
			return returnCode;
		endif;
	endif;
	if self.abort() then
		returnCode := false;
		return returnCode;
	endif;
	
	if self.myBGPRequest.purgeDDExtractHistory then
		self.setCurrentArchiveType(app.getErrorString(Data_extract));//TFS 6960
		app.sendHeartbeatIfRequired();		// 5/9/17 MAP TFS5551
		if not self.doPurgeDDExtractHistory() then
			returnCode := false;
			return returnCode;
		endif;
	endif;
	if self.abort() then
		returnCode := false;
		return returnCode;
	endif;

	if self.myBGPRequest.purgeLockTransactions then
		self.setCurrentArchiveType(app.getErrorString(Lock_transactions));//TFS 6960
		app.sendHeartbeatIfRequired();		// 5/9/17 MAP TFS5551
		if not self.doPurgeLockTransactions() then
			returnCode := false;
			return returnCode;
		endif;
	endif;
	if self.abort() then
		returnCode := false;
		return returnCode;
	endif;

	if self.myBGPRequest.purgeEDIData then
		self.setCurrentArchiveType(app.getErrorString(EDI_data));//TFS 6960
		app.sendHeartbeatIfRequired();		// 5/9/17 MAP TFS5551
		if not self.doPurgeEDIData() then
			returnCode := false;
			return returnCode;
		endif;
	endif;
	if self.abort() then
		returnCode := false;
		return returnCode;
	endif;

	if self.myBGPRequest.purgeSundry then
		self.setCurrentArchiveType(app.getErrorString(Sundry));//TFS 6960
		app.sendHeartbeatIfRequired();		// 5/9/17 MAP TFS5551
		if not self.doPurgeSundry() then
			returnCode := false;
			return returnCode;
		endif;
	endif;
	// ccms 1042 sept 2006 cnwrs1
	if self.myBGPRequest.purgeXlations then
		self.setCurrentArchiveType(app.getErrorString(PurgeTranslations));//TFS 6960
		app.sendHeartbeatIfRequired();		// 5/9/17 MAP TFS5551
		if not self.doPurgeXlations() then
			returnCode := false;
			return returnCode;
		endif;
	endif;

	//par16530 cnwrs1 May 2008
	if self.myBGPRequest.purgeYardAllocationLogTrans then
		self.setCurrentArchiveType(app.getErrorString(PurgeYardAllocationLogs));//TFS 6960
		app.sendHeartbeatIfRequired();		// 5/9/17 MAP TFS5551
	//	if not self.doPurgeInformationTransactions(YardAllocationLogging) then
		if not self.doPurgeInformationTransactions(IsYardAllocationInfo) then	//29 Nov 2013	NDL	Par 32991
			returnCode := false;
			return returnCode;
		endif;
	endif;
	//par17772 cnwrs1 Aug 2008
	if self.myBGPRequest.purgeMenuUserItems then
		self.setCurrentArchiveType(app.getErrorString(Saved_reports));//TFS 6960
		app.sendHeartbeatIfRequired();		// 5/9/17 MAP TFS5551
		if not self.doPurgeMenuUserItems() then
			returnCode := false;
			return returnCode;
		endif;
	endif;
	//par17772 cnwrs1 Aug 2008
	if self.myBGPRequest.purgeLogCheckScaleHdr then
		self.setCurrentArchiveType(app.getErrorString(Check_scale_header));//TFS 6960
		app.sendHeartbeatIfRequired();		// 5/9/17 MAP TFS5551
		if not self.doPurgeLogCheckScaleHdr() then
			returnCode := false;
			return returnCode;
		endif;
	endif;
	
	//15 Apr 2013	NDL	Par 31393
	if self.myBGPRequest.purgeVehicleBookings then
		self.setCurrentArchiveType(app.getErrorString(Vehicle_schedul_booking_slot));//TFS 6960
		app.sendHeartbeatIfRequired();		// 5/9/17 MAP TFS5551
		if not self.doPurgeVehicleBookings() then
			returnCode := false;
			return returnCode;
		endif;
	endif;
	
	//par17772 cnwrs1 Aug 2008
	if self.myBGPRequest.purgeVehicleVisit then
		self.setCurrentArchiveType(app.getErrorString(Vehicle_visit_records));//TFS 6960
		app.sendHeartbeatIfRequired();		// 5/9/17 MAP TFS5551
		if not self.doPurgeVehicleVisitRecords() then
			returnCode := false;
			return returnCode;
		endif;
	endif;
	
	//01/12/2009 cnwdz2 par21808
	if self.myBGPRequest.purgeCargoPhotos then
		self.setCurrentArchiveType(app.getErrorString(Cargo_photos));//TFS 6960
		app.sendHeartbeatIfRequired();		// 5/9/17 MAP TFS5551
		if not self.doPurgeCargoPhotos() then
			returnCode := false;
			return returnCode;
		endif;
	endif;
//23/05/2012	cnwrs1	Par 29613
	if self.myBGPRequest.purgeEventRequests then
		self.setCurrentArchiveType(app.getErrorString(Event_Requests));//TFS 6960
		app.sendHeartbeatIfRequired();		// 5/9/17 MAP TFS5551
		if not self.doPurgeEventRequests() then
			returnCode := false;
			return returnCode;
		endif;
	endif;
	
	if self.abort() then
		returnCode := false;
		return returnCode;
	endif;
	
	//21 Dec 2012	NDL	Par 30901
	if self.myBGPRequest.purgeDutyDocs then
		self.setCurrentArchiveType(app.getErrorString(Duty_documents));//TFS 6960
		app.sendHeartbeatIfRequired();		// 5/9/17 MAP TFS5551
		if not self.doPurgeDutyDocs() then
			returnCode := false;
			return returnCode;
		endif;
	endif;
	
	//epr TFS 4157 28/4/17
	if self.myBGPRequest.purgeInterTerminalRailBOLs then	
		self.setCurrentArchiveType(app.getErrorString(Inter_termin_rail_releas_docke));//TFS 6960
		app.sendHeartbeatIfRequired();		// 5/9/17 MAP TFS5551
		if not self.doPurgeInterTerminalRailBOLs() then
			returnCode := false;
			return returnCode;
		endif;	
	endif;
	
	//13 Sep 2021	NDL	TFS 51718
	if self.myBGPRequest.truncateEDIInfoXML then
		self.setCurrentArchiveType(app.getErrorString(Truncate_EDIInfo_XML));
		app.sendHeartbeatIfRequired();
		if not self.doTruncateEDIInfoXML() then
			returnCode := false;
			return returnCode;
		endif;	
	endif;
	
	//12 Feb 2021	NDL	TFS 50761 - Remove " stops / todo to dos and damage instances " associated with zombies.
	// potentially too big to run as part of a release.
	psRelease := self.findLatestPortSchemaRelease();
	if psRelease &lt;&gt; null then
		if not psRelease.hasScriptBeenRunAtAll( CM_DBPurgeAgent::doRemoveZombieRefs.name, null ) then
			self.setCurrentArchiveType("MTN Internal Housekeeping");
			app.sendHeartbeatIfRequired();
			if not self.doRemoveZombieRefs( psRelease ) then
				returnCode := false;
				return returnCode;
			endif;
		else																													// TFS 52072
			self.createActivityHistory("MTN Internal Housekeeping - doRemoveZombieRefs has already been run", false, false);	// TFS 52072
		endif;
	endif;
	
	if self.abort() then
		returnCode := false;
		return returnCode;
	endif;
	
	// ### TFS 51994 01Oct2021 NAVPW1
	if self.myBGPRequest.purgeSecGateUnknTrucks then
		self.setCurrentArchiveType(app.getErrorString(Security_Gate_Unknown_Trucks));
		app.sendHeartbeatIfRequired();
		if not self.doPurgeSecGateUnknTrucks() then
			returnCode := false;
			return returnCode;
		endif;
	endif;
	if self.abort() then
		returnCode := false;
		return returnCode;
	endif;
	// ### TFS 51994 01Oct2021 NAVPW1
	
	//16/09/2022 navmv20 TFS 53403 - start
	if self.myBGPRequest.purgeReleaseRequests then
		self.setCurrentArchiveType(app.getErrorString(Release_Requests));
		app.sendHeartbeatIfRequired();		
		if not self.doPurgeReleaseRequests() then
			returnCode := false;
			return returnCode;
		endif;
	endif;
	//16/09/2022 navmv20 TFS 53403 - end
	
	if self.myBGPRequest.purgeAttachmentCargoTypes then					//14/02/2023 navhl20 #54900[56518]
		self.setCurrentArchiveType(app.getErrorString(Attachment_files_cargotypes));
		app.sendHeartbeatIfRequired();		
		if not self.doPurgeAttachFilesCargoTypes() then
			returnCode := false;
			return returnCode;
		endif;
	endif;
	
	if self.myBGPRequest.purgeAttachmentContract then					//14/02/2023 navhl20 #54900[56518]
		self.setCurrentArchiveType(app.getErrorString(Attachment_files_contracts));
		app.sendHeartbeatIfRequired();		
		if not self.doPurgeAttachFilesContract() then
			returnCode := false;
			return returnCode;
		endif;
	endif;
	
	if self.myBGPRequest.purgeAttachmentInvoices then					//14/02/2023 navhl20 #54900[56518]
		self.setCurrentArchiveType(app.getErrorString(Attachment_files_invoices));
		app.sendHeartbeatIfRequired();		
		if not self.doPurgeAttachFilesInvoices() then
			returnCode := false;
			return returnCode;
		endif;
	endif;
	
	if self.myBGPRequest.purgeAttachmentVoyages then					//14/02/2023 navhl20 #54900[56518]
		self.setCurrentArchiveType(app.getErrorString(Attachment_files_voyages));
		app.sendHeartbeatIfRequired();		
		if not self.doPurgeAttachFilesVoyages() then
			returnCode := false;
			return returnCode;
		endif;
	endif;
	
	if self.myBGPRequest.purgeAttachmentWorkOrders then					//14/02/2023 navhl20 #54900[56518]
		self.setCurrentArchiveType(app.getErrorString(Attachment_files_workorders));
		app.sendHeartbeatIfRequired();		
		if not self.doPurgeAttachFilesWO() then
			returnCode := false;
			return returnCode;
		endif;
	endif;
	
	if self.myBGPRequest.purgeWorkOrderJobSheets then					//21.7.2023 navhl20 #58158
		self.setCurrentArchiveType(app.getErrorString(Workorder_sheets));
		app.sendHeartbeatIfRequired();		
		if not self.doPurgeWorkOrderJobSheets() then
			returnCode := false;
			return returnCode;
		endif;
	endif;
	
	if self.myBGPRequest.purgeVisitPhotos then							//11.08.2025 navhl20 #35650
		self.setCurrentArchiveType(app.getErrorString(Visit_photos));
		app.sendHeartbeatIfRequired();		
		if not self.doPurgeVisitPhotos() then
			returnCode := false;
			return returnCode;
		endif;
	endif;
	
	//navra1 - MTN-35875- 5th Sep 2025-2 - start
	if self.myBGPRequest.purgeAgGatewayMessages then
		self.setCurrentArchiveType(app.getErrorString(Aggateway_messages));
		app.sendHeartbeatIfRequired();		
		if not self.doPurgeAgGatewayMessages() then
			returnCode := false;
			return returnCode;
		endif;
	endif;
	//navra1 - MTN-35875- 5th Sep 2025-2 - end
	
	// now garbage collection has finished time to cleanup the temp activity records
	create objArray transient;
	CM_ActivityHistoryDBPurge.allInstances(objArray,0,true);
	app.sendHeartbeatIfRequired();		// 5/9/17 MAP TFS5551
	beginTransaction;
	foreach object in objArray do
		if object.CM_ActivityHistoryDBPurge.temp then
			object.CM_ActivityHistoryDBPurge.erase(0);
		endif;
	endforeach;
	commitTransaction;
	returnCode := true;
	return returnCode;
epilog
	if returnCode then
		self.createActivityHistory(app.getErrorString1(Finished_Database_Purge, _terminal.name)&amp;' For User ' &amp; self.myBGPRequest.getUserCode()[1:10].trimBlanks&amp;' upto '&amp;_date.String, false, false);
	else
		self.createActivityHistory(app.getErrorString1(Aborted_Database_Purge, _terminal.name)&amp;' For User ' &amp; self.myBGPRequest.getUserCode()[1:10].trimBlanks&amp;' upto '&amp;_date.String, false, false);
	endif;
	delete objArray;
	return returnCode;
end;</source>
        <Parameter name="_bgpRequest" type="BGP_DatabasePurgeRequest"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_date" type="Date"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setCurrentArchiveType" id="dcba9792-90c7-4020-a9d5-f7302b16424e">
