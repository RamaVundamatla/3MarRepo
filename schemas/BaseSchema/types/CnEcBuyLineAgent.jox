        <Parameter name="pRequiredEdition" type="Integer"/>
        <Parameter name="pResponse" type="String"/>
        <Parameter name="pTransactionAccepted" type="Boolean" usage="io"/>
        <ReturnType type="String"/>
    </JadeMethod>
