    <text>DO NOT USE - Been replaced with CM_WOUnpackWLE</text>
    <DbClassMap file="cmtrans"/>
    <JadeMethod name="erase" id="c0a3541b-8535-43c1-a7b9-f8da904f19d7">
        <updating/>
        <source>erase(_eraseLevel: Integer) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
12 January 2010	cnwrd1	Initial creation

*/


vars
begin
	
	// Lock all for update
	exclusiveLock(self);
	sharedLock(myRequest);
	if self.myRequest.myJob &lt;&gt; null then
		//AJA 31/3/00: Yard internals
		sharedLock(self.myRequest.myJob);
	endif;

	self.causeEvent(self.job.getMyTerminal.getTerminalEvent(WLE_Delete_Event), false, self);				  	

  	inheritMethod(_eraseLevel);
epilog

end;</source>
        <Parameter name="_eraseLevel" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="a973840a-eb46-4ea6-9d25-e471432d00a7">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
31 July 2009	cnwrd1	Initial creation
18 July 2017	cnwma1	TFS #5410:Yard Operations - Invalid property value issues
26 Jun 2025  	navbs1	Story 35185: MTN - Refactor Required to Stop Using getDisplayStringForAttribute() for Known Attributes
*/

vars
	rtStr : String;
begin
	if _attrName = ETRow_WorkEntry then
		rtStr := "Unpack";
		return rtStr;
	elseif _attrName = ETRow_RadioTelemetry then
		return '';
	elseif _attrName = ETRow_Remarks then //cnwma1 TFS #5410 18/07/2017  
		return '';
	else
		return inheritMethod(_attrName, _short);
	endif;

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getRequestType" id="c574e6ae-fc45-4749-ac4b-76e176658263">
        <source>getRequestType(): Integer;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06 August 2009	cnwrd1	Initial creation

*/

vars

begin

	if self.job.myWODtl &lt;&gt; null then
		return REQ_TI_WORKORDER;
	else
		return REQ_TI_RELEASE;
	endif;


epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
