    <JadeMethod name="getDisplay" id="2f70d730-be2d-43da-bf36-42a2c2ad2ed2">
        <source>getDisplay(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 May 2023	jlier1	Initial creation 57936

*/

vars
	detail : String;
	vvr : CM_VehicleVisitRecord;
	invalidObj : Boolean;
begin
	on Exception do app.handleDeletedObject(exception,self.myParentObject,invalidObj);

	vvr:=self.myParentObject.CM_VehicleVisitRecord;

	detail := "Barrier Code Release Process";
	detail :=  detail								 &amp; Tab &amp; 
			   self.actionTimeStamp.asStringJMT &amp; Tab &amp;
			   vvr.myTerminal.code 					 &amp; Tab &amp;
			   vvr.visitNumber;
			  
	if invalidObj then
		return null;
	endif;
	
	return detail;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
