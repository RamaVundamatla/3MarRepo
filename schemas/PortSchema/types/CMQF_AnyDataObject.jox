    <JadeMethod name="getCollectionDataCopyTo" id="66616a78-bf0b-481f-afac-635fb67034cb">
        <source>getCollectionDataCopyTo( _toColl : Collection input );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 December 2013	cnwndl1	Initial creation	Par 33184

*/

vars

	iter : Iterator;
	oidStr : String;
	obj : Object;
	invalid : Boolean;
	edition : Integer;
	memberType : Type;

begin

	if self.allGroupingAttributes.isEmpty or _toColl = null then
		return;
	endif;
	memberType := _toColl.cnEcGetMemberType;
	if not memberType.isKindOf( Class ) then
		return;
	endif;
	
	on Exception do app.handleDeletedObject( exception, obj, invalid );
	
	iter := self.allGroupingAttributes.createIterator;
	while iter.next( oidStr ) do
		obj := oidStr.asOid;
		if obj = null then
			continue;
		endif;
		invalid := false;
		edition := obj.edition;
		if not invalid then
			if not obj.isKindOf( memberType.Class ) then
				continue;
			endif;
			if not _toColl.includes( obj ) then
				_toColl.add( obj );
			endif;
		endif;
	endwhile;

epilog

	delete iter;

end;</source>
        <Parameter name="_toColl" type="Collection" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getMyDataObject" id="21e787a9-f741-4b86-96c1-0c7c83bac509">
        <source>getMyDataObject():CM_Object;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 July 2016	cnwndl1	Initial creation	TFS 2329

*/

vars

	object : CM_Object;
	edition : Integer;
	invalidObj : Boolean;

begin

	object := self.myDataObject;

	if object = null then
		return null;
	endif;
	
	on Exception do app.handleDeletedObject( exception, object, invalidObj );
	edition := object.edition;
	
	if invalidObj then
		return null;
	endif;
	
	return object;

epilog

end;</source>
        <ReturnType type="CM_Object"/>
    </JadeMethod>
