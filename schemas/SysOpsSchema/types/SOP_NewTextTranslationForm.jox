    <JadeMethod name="changeCategory" id="0605f76f-599e-4787-8391-e0985d901e08">
        <updating/>
        <source>changeCategory(category : XLAT_Category) updating;

vars

begin
	setNextConstantValue(category);
	txtNzShortText.enabled := category.usesShortText;
	lnzShortText.enabled := category.usesShortText;

	// make up constant name
	setSuggestedConstantName;

end;</source>
        <Parameter name="category" type="XLAT_Category"/>
    </JadeMethod>
    <JadeMethod name="cmbCategory_change" id="93f02f6f-fc18-46c8-bbb8-cfded0fe1137">
        <controlMethod name="ComboBox::change"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbCategory_change(combobox: ComboBox input) updating;

vars

begin
	changeCategory(combobox.listObject.XLAT_Category);
end;</source>
