    <JadeMethod name="isTodayEOP" id="cd4e4297-4b8c-411c-92c8-628d285c9f36">
        <source>isTodayEOP(_period : CM_FinancialPeriodEnd) : TimeStamp;
// ---------------------------------------------------------------------------
// 24016 new parameter to limit date check to given financial period
// Created:		March 2002 By Andrew Bishop cnwab1
//
// Purpose:		To run the evaluation of storage on TIs automatically at the financial End Of Period (EOP)
//				Mark Finnie wants it to run after the EOP TimeStamp, which is normally 1 minute before midnight on the EOP Date,
//				so  we take one day away from the start date so that it will be run auto within the first hour of the day after EOP
//				if EOP Date is 31stJuly 23:59:59, we want to run the evaluation after that date so we set up a range of 1 day prior to today:
//				If today is the 31stJuly we will have a range of 30thJuly 00:00:00 to 31stJuly 23:59:59, as this process is run hourly and 
//				we want it to run after the time stamp, it will not pick it up on the actual EOP day so
//				If today is the 1stAug we will have a range of 31stJuly 00:00:00 to 1stAug 23:59:59, this will pick up the EOP date from the collection correctly
//				and then it will check that the actual EOP timestamp is less than now (1stAug) and will run.
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
// ---------------------------------------------------------------------------
constants
	Friday = 5;
vars
	lNow, lNowFrom, lNowTo , 
	lEOPDate : TimeStamp;
	lTime : Time;
	lDate : Date;
	anFPDT : CM_FinancialPeriodDateTime;
begin
	lTime := app.actualTimeServer.time(); // PAR 8176 added// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	lDate := app.actualTimeServer.date(); // PAR 8176 added// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support

	
	//epr par 36579 12/10/15 leaking transients
	lNow.setTime(lTime);
	lNow.setDate(lDate);

	// ######################
	// create a range of dates, basically from today to today, unless today is Friday then Friday to Sunday
	lNowFrom.setTime(null);

	// AKB2002AUG - Mark Finnie wants it to run after the EOP TimeStamp, which is normally 1 minute before midnight on the EOP Date,
	//				so  we take one day away from the start date so that it will be run auto within the first hour of the day after EOP	
	lNowFrom.setDate(lDate - 1);

	lTime.setTime(23,59,59,0);
	lNowTo.setTime(lTime);

	// ######################
	// if today is Friday extend the search for an EOP to Sunday
	if lDate.dayOfWeek = Friday then
		lNowTo.setDate(lDate + 2);
	else
		lNowTo.setDate(lDate);
	endif;
	

	// ######################
	// go through all of the EOP dates of the given period type and see if today is the EOP
	lEOPDate := null;

	foreach 	anFPDT in _period.allFinancialPeriodEndDates do
			// is it within our date range?
			
		if anFPDT.dateTime &gt;= lNowFrom
		and anFPDT.dateTime &lt;= lNowTo then
			// it is within our date range, but is NOW after the time on the EOP time stamp
			if anFPDT.dateTime &lt;= lNow then
				lEOPDate := anFPDT.dateTime;
				break;
			endif;
		endif;
	endforeach;

	return	lEOPDate;
end;</source>
        <Parameter name="_period" type="CM_FinancialPeriodEnd"/>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="isTodayEOPOld" id="bcc3cb39-ba20-4539-96cf-121bff3c88d3">
        <source>isTodayEOPOld() : TimeStamp;
// ---------------------------------------------------------------------------
// Created:		March 2002 By Andrew Bishop cnwab1
//
// Purpose:		To run the evaluation of storage on TIs automatically at the financial End Of Period (EOP)
//				Mark Finnie wants it to run after the EOP TimeStamp, which is normally 1 minute before midnight on the EOP Date,
//				so  we take one day away from the start date so that it will be run auto within the first hour of the day after EOP
//				if EOP Date is 31stJuly 23:59:59, we want to run the evaluation after that date so we set up a range of 1 day prior to today:
//				If today is the 31stJuly we will have a range of 30thJuly 00:00:00 to 31stJuly 23:59:59, as this process is run hourly and 
//				we want it to run after the time stamp, it will not pick it up on the actual EOP day so
//				If today is the 1stAug we will have a range of 31stJuly 00:00:00 to 1stAug 23:59:59, this will pick up the EOP date from the collection correctly
//				and then it will check that the actual EOP timestamp is less than now (1stAug) and will run.
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//	saved before 24016 add item selector and financial period// ---------------------------------------------------------------------------
// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
constants
	Friday = 5;
vars
	lNow, lNowFrom, lNowTo,
	lEOPDate : TimeStamp;
	lTime : Time;
	lDate : Date;
	anFPE : CM_FinancialPeriodEnd;
	anFPDT : CM_FinancialPeriodDateTime;
begin
	lTime := app.actualTimeServer.time(); // PAR 8176 added// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	lDate := app.actualTimeServer.date(); // PAR 8176 added// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	
	//epr par 36579 12/10/15 leaking transients
	lNow.setTime(lTime);
	lNow.setDate(lDate);

	// ######################
	// create a range of dates, basically from today to today, unless today is Friday then Friday to Sunday
	lNowFrom.setTime(null);

	// AKB2002AUG - Mark Finnie wants it to run after the EOP TimeStamp, which is normally 1 minute before midnight on the EOP Date,
	//				so  we take one day away from the start date so that it will be run auto within the first hour of the day after EOP	
	lNowFrom.setDate(lDate - 1);
	lTime.setTime(23,59,59,0);
	lNowTo.setTime(lTime);

	// ######################
	// if today is Friday extend the search for an EOP to Sunday
	if lDate.dayOfWeek = Friday then
		lNowTo.setDate(lDate + 2);
	else
		lNowTo.setDate(lDate);
	endif;
	

	// ######################
	// go through all of the EOP dates and see if to day is the EOP
	lEOPDate := null;
	

	foreach 	anFPE in app.myRoot.myRootCompany.allFinancialPeriods do
		foreach 	anFPDT in anFPE.allFinancialPeriodEndDates do
			// is it within our date range?
			
			if anFPDT.dateTime &gt;= lNowFrom
			and anFPDT.dateTime &lt;= lNowTo then
				// it is within our date range, but is NOW after the time on the EOP time stamp
				if anFPDT.dateTime &lt;= lNow then
					lEOPDate := anFPDT.dateTime;
					break;
				endif;
			endif;
		endforeach;
	endforeach;		
	return	lEOPDate;
end;</source>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
