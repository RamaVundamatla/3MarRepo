    <JadeMethod name="trxUpdateVoyagesInBulk" id="7cb9a9b0-3c2b-4390-bbd4-422aa9f33cfd">
        <updating/>
        <source>trxUpdateVoyagesInBulk(_cmifUpdate : CMIF_VoyageBulkUpdate; _allVoyages : CM_ObjectArray; _passport : CM_Passport input) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 14/06/2021	navdap1		Initial creation TFS 51326 ASPA Bulk Edit Voyages
//
vars
	voyStr : String;
	obj : Object;

begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(false);
	
	// confirmation.....
	foreach obj in _allVoyages do
		if voyStr = null then
			voyStr := obj.CM_Voyage.code &amp; Space &amp; Left_Round_Bracket &amp; obj.CM_Voyage.vesselName &amp; Right_Round_Bracket;
		else
			voyStr := voyStr &amp; Comma &amp; Space &amp; obj.CM_Voyage.code &amp; Space &amp; Left_Round_Bracket &amp; obj.CM_Voyage.vesselName &amp; Right_Round_Bracket;
		endif;
	endforeach;
	app.raiseCMWarning1(Sure_bulk_update_voyages, voyStr, null, null, null);

	beginTransaction;

	app.myUtilityUA.utlUpdateVoyagesInBulk(_cmifUpdate, _allVoyages, _passport);

epilog
	self.finaliseActivityWithPassport(_passport);

end;</source>
        <Parameter name="_cmifUpdate" type="CMIF_VoyageBulkUpdate"/>
        <Parameter name="_allVoyages" type="CM_ObjectArray"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxUpdateVvrStevedore" id="62cdb64b-a890-4faa-b7ec-b2385b212c77">
        <updating/>
        <source>trxUpdateVvrStevedore(_vvr : CM_VehicleVisitRecord input; _stevedore : CM_Stevedore; _passport : CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 Nov 2020 cnwma1 ChangeRequest 50112: ASPA - GCI Stevedores

*/

vars

begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);


	app.setContinueCMExceptions(false);
	
	if _vvr = null then
		app.raiseCMException1(ERR_DEL_NULLOBJECT, app.getErrorString(Vehicle_visit_record), null, null);
		return;
	endif;
	
	if not _vvr.myTerminal.roadProcessIsASPA then
		if _vvr.myTerminal.getMyRoadProcess &lt;&gt; null then 
			app.raiseCMException2(Road_opera_form_not_suppo_term, _vvr.myTerminal.getMyRoadProcess.code, method.qualifiedName, null, null); 
		else
			app.raiseCMException2(Road_opera_form_not_suppo_term, "&lt;" &amp; app.getErrorString(NoneSelected) &amp; "&gt;", method.qualifiedName, null, null); 
		endif;
		return;
	endif;

	
	_passport.useTITransactionDeferUpdate	:= true;
	_passport.useTIDictDeferUpdate			:= true;

	beginTransaction;

	
	if _passport.hasErrors then
		return;
	endif;
	
	app.myUtilityUA.utlUpdateVvrStevedore( _vvr, _stevedore, _passport);
	
	_passport.doDeferredUpdates();

epilog

	self.finaliseActivityWithPassport(_passport);

end;</source>
        <Parameter name="_vvr" type="CM_VehicleVisitRecord" usage="input"/>
        <Parameter name="_stevedore" type="CM_Stevedore"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxUpdateWLEAllocateWodTI" id="fe3fb339-e0c3-4ab4-b660-c7287b7d2150">
        <updating/>
        <source>trxUpdateWLEAllocateWodTI(_wle : CM_WorkListEntry input; _ti : CM_TrackedItem; _passport : CM_Passport input) updating;
// -----------------------------------------------------------------------------
// Created:		28 July 2009 by consw1
//
// Purpose:		Allocate available TI from Work Order to WLE.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------

begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);
	
	app.setContinueCMExceptions(true);

	beginTransaction;
	_passport.useTITransactionDeferUpdate := true;
	_passport.useTIDictDeferUpdate := true;

	reserveLock(_wle);
	
	app.myUtilityUA.utlUpdateWLEAllocateWodTI(_wle, _ti, _passport);
	
	if _passport.noErrors then
		_passport.doDeferredUpdates();
	endif;

epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_wle" type="CM_WorkListEntry" usage="input"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxUpdateWLEAssignTI" id="6ce68772-525e-4c89-9d64-068382d40f3e">
        <updating/>
        <source>trxUpdateWLEAssignTI(_moveControl : CMIF_MoveController input;
					 _passport 	  : CM_Passport input) updating;
//-----------------------------------------
//Created: February 2003 By: cnwgd1
//25 Oct 2024 navma1 MTN-33231 MTN - Enable Deferred Updates For Train and Wagon Events 
//-----------------------------------------
begin

	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);
	
	app.setContinueCMExceptions(true);

	beginTransaction;
	_passport.useTITransactionDeferUpdate := true;
	_passport.useTIDictDeferUpdate 		  := true;
	_passport.useEventDeferUpdate		  := true;					//25.10.2024 navma1 #MTN-33231

	app.myUtilityUA.utlUpdateWLEAssignTI(_moveControl, _passport);
	
	if _passport.noErrors then
		_passport.doDeferredUpdates();
	endif;

epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_moveControl" type="CMIF_MoveController" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxUpdateWLEAssignTIs" id="884acbce-b1c8-4102-9835-b286692131bf">
        <updating/>
        <source>trxUpdateWLEAssignTIs(_allMoveControllers : ObjectSet; _passport : CM_Passport input) updating;
/*

Date		Who		Reason
15 September 2015	cnwer1	Initial creation PAR 36908

*/

vars
	moveControl : CMIF_MoveController;
	obj : Object;
begin
		// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);
	
	app.setContinueCMExceptions(true);

	beginTransaction;
	_passport.useTITransactionDeferUpdate := true;
	_passport.useTIDictDeferUpdate := true;

	foreach obj in _allMoveControllers do
		moveControl:= obj.CMIF_MoveController;
		if  moveControl.myWorkListEntry &lt;&gt; null and moveControl.myWorkListEntry.isReleaseByType then
		
			app.myUtilityUA.utlUpdateWLEAssignTI(moveControl, _passport);
		else
			app.myUtilityUA.utlUpdateMoveTrackedItem(moveControl,_passport);
		endif;
		if _passport.hasErrors then
			return;
		endif;
	
	endforeach;
	
	if _passport.noErrors then
		_passport.doDeferredUpdates();
	endif;

epilog
	self.finaliseActivityWithPassport(_passport);

end;</source>
        <Parameter name="_allMoveControllers" type="ObjectSet"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxUpdateWLEAutoplan" id="d283e279-40ea-4b17-8af6-1edf000084aa">
        <updating/>
        <source>trxUpdateWLEAutoplan(_wle:CM_WorkListEntry input; _moveMode : Integer; _passport : CM_Passport input) updating;
//--------------------------------------------------------------
//Created: 05 March 2002 By: cnwgd1
//--------------------------------------------------------------
begin

	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// DVB added 30/05/2005
	app.initialiseForStartAutoPlan(_passport);
	
	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(false);

	beginTransaction;

	app.myUtilityUA.utlUpdateWLEAutoplan(_wle, _moveMode, _passport);

epilog
	self.finaliseActivityWithPassport(_passport);

end;</source>
        <Parameter name="_wle" type="CM_WorkListEntry" usage="input"/>
        <Parameter name="_moveMode" type="Integer"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxUpdateWLEAutoplanToWagon" id="6f199ae3-516c-4a09-b03c-4f6d8aea1fc0">
        <updating/>
        <source>trxUpdateWLEAutoplanToWagon(_wleArray 	: CM_WLEArray input;
							_wlesWithWarnings : CM_WLEArray input;
							_moveMode 	: Integer;
							_railArea	: CM_Rail;
							_train		: CM_Train;
							_wagon		: CM_Wagon;
							_passport 	: CM_Passport input) updating;
/*
----------   ----------  --------------------------------------------------
Created:	20 November 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	tmpTI : CM_TrackedItem;
	wle : CM_WorkListEntry;
	toLocn : CM_LocationsController;
	autoPlan,
	alertCreated : Boolean;
	hadException	: Boolean;
	id		: String;
	moveController : CMIF_MoveController;
	errorSet	: CM_ErrorSet;	
	
begin

	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// DVB added 30/05/2005
	app.initialiseForStartAutoPlan(_passport);
	
	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(false);

	app.myEventManager.setMultiTransactionTrx();
	
	create errorSet transient;
	// 36290 handle deleted WLEs in the input
	on Exception do app.handleDeletedObject (exception, wle, hadException);

	foreach wle in _wleArray do
		// 36290 check for invalid WLE and skip if any
		hadException := false;
		id := wle.id;
		if hadException then
			continue;
		endif;

		beginTransaction;
		if wle.status = WLE_COMPLETED then
			app.raiseCMException3(ERR_QUEUE_WLE_STAT, wle.getTreeDescription(), 'complete', 'auto-planned', null, null);
		endif;
		
		if _passport.noErrors() then
			app.myUtilityUA.utlUpdateWLEAutoplanToWagon(wle, _moveMode, _railArea, _train, _wagon, _passport);
		endif;
		
		if _passport.isOkToCommit(false) then
			app.cmsCommitTransaction(_passport);
		else
			app.cmsAbortTransaction;
			if _passport.hasErrors then
				app.convertErrorsWarningsToAlert('Entry ' &amp; wle.getFullDescription() 
												&amp; ' could not be auto-planned to a wagon', _passport.allErrorWarnings);				
				alertCreated := true;
			elseif _passport.hasWarnings then
				_wlesWithWarnings.add(wle);
			endif;
			_passport.moveErrorsToSet(errorSet);
			_passport.initialiseTransaction();				
		endif;
	endforeach;

	if _passport.noErrors and (not process.isInTransactionState) then
		// Done so that finaliseActivityWithPassport will commit correctly
		beginTransaction;
	endif;
	_passport.addErrorsFromSet(errorSet);
	if alertCreated then
		app.raiseCMException1(SystemAlertCreated, 'work list entries', null, self);
	endif;	
	
epilog
	self.finaliseActivityWithPassport(_passport);
	delete errorSet;
	delete moveController;	
end;</source>
        <Parameter name="_wleArray" type="CM_WLEArray" usage="input"/>
        <Parameter name="_wlesWithWarnings" type="CM_WLEArray" usage="input"/>
        <Parameter name="_moveMode" type="Integer"/>
        <Parameter name="_railArea" type="CM_Rail"/>
        <Parameter name="_train" type="CM_Train"/>
        <Parameter name="_wagon" type="CM_Wagon"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
