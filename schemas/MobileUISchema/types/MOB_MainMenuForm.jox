    <JadeMethod name="adjustFormForDevice" id="1c24b8e1-f845-4d97-b84a-08aad1c2ad03">
        <updating/>
        <source>adjustFormForDevice() updating, protected;
// ---------------------------------------------------------------------------
// Created:	14 August 2009 By Graeme Black cnwgb1
// Status: 	Unfinished
// Purpose:	
// ---------------------------------------------------------------------------
vars
	scaleFactorX : Real;
	scaleFactorY : Real;
	left, top, width, height : Integer;
begin
	self.getDeskTopWorkArea(left, top, width, height );
	if self.width &gt; 400 then // Probably PocketPC
		return;
	endif;
	inheritMethod();

	self.left := left;
	self.top := top;
	self.width := width;
	self.height := height;
	scaleFactorX :=  self.width / 658.0;
	scaleFactorY :=  self.height / 458.0;
/*
	app.msgBox( "Scrn H W L T " &amp; height.asStringJMT &amp; " " &amp; width.asStringJMT &amp; " " &amp; left.asStringJMT &amp; " " &amp; top.asStringJMT &amp; CrLf &amp; 
	"H W L T" &amp; CrLf &amp; "Form " &amp; self.height.asStringJMT &amp; " " &amp; self.width.asStringJMT &amp; " " &amp; self.left.asStringJMT &amp; " " &amp; self.top.asStringJMT
	&amp; CrLf &amp; "S OP " &amp; sht_Options.height.asStringJMT &amp; " " &amp; sht_Options.width.asStringJMT &amp; " " &amp; sht_Options.left.asStringJMT &amp; " " &amp; sht_Options.top.asStringJMT
	&amp; CrLf &amp; "SF X Y  " &amp; scaleFactorX.asStringJMT &amp; " " &amp; scaleFactorY.asStringJMT
	&amp; CrLf &amp; "F Tasks " &amp; fld_Tasks.height.asStringJMT &amp; " " &amp; fld_Tasks.width.asStringJMT &amp; " " &amp; fld_Tasks.left.asStringJMT &amp; " " &amp; fld_Tasks.top.asStringJMT
	&amp; CrLf &amp; "B Logoff " &amp; btn_LogOff.height.asStringJMT &amp; " " &amp; btn_LogOff.width.asStringJMT &amp; " " &amp; btn_LogOff.left.asStringJMT &amp; " " &amp; btn_LogOff.top.asStringJMT, "Form Size", MsgBox_OK_Only );
*/
	sht_Tasks.top := (sht_Tasks.top*scaleFactorY).roundedUp;
	sht_Tasks.left := (sht_Tasks.left*scaleFactorX).roundedUp;
	sht_Tasks.height := (sht_Tasks.height*scaleFactorY).roundedUp;	
	sht_Tasks.width := (sht_Tasks.width*scaleFactorX).roundedUp;
	sht_Tasks.fontSize := (sht_Tasks.fontSize*scaleFactorY).roundedUp;

	sht_Options.top := (sht_Options.top*scaleFactorY).roundedUp;
	sht_Options.left := (sht_Options.left*scaleFactorX).roundedUp;
	sht_Options.height := (sht_Options.height*scaleFactorY).roundedUp;	
	sht_Options.width := (sht_Options.width*scaleFactorX).roundedUp;
	sht_Options.fontSize := (sht_Options.fontSize*scaleFactorY).roundedUp;
	
	tbl_OptionsDtl.top := (tbl_OptionsDtl.top*scaleFactorY).roundedUp;
	tbl_OptionsDtl.left := (tbl_OptionsDtl.left*scaleFactorX).roundedUp;
	tbl_OptionsDtl.height := (tbl_OptionsDtl.height*scaleFactorY).roundedUp;	
	tbl_OptionsDtl.width := (tbl_OptionsDtl.width*scaleFactorX).roundedUp;
	tbl_OptionsDtl.fontSize := (tbl_OptionsDtl.fontSize*scaleFactorY).roundedUp;

  	fld_Tasks.fontSize := (fld_Tasks.fontSize*scaleFactorY).roundedUp;
	fld_Tasks.tabsHeight := (fld_Tasks.tabsHeight*scaleFactorY).roundedUp;

	pic_Logo.top := (pic_Logo.top*scaleFactorY).roundedUp;
	pic_Logo.left := (pic_Logo.left*scaleFactorX).roundedUp;
	pic_Logo.height := (pic_Logo.height*scaleFactorY).roundedUp;	
	pic_Logo.visible := false;

	btn_Allocate.top := (btn_Allocate.top*scaleFactorY).roundedUp;
	btn_Allocate.left := (btn_Allocate.left*scaleFactorX).roundedUp;
	btn_Allocate.height := (btn_Allocate.height*scaleFactorY).roundedUp;	
	btn_Allocate.width := (btn_Allocate.width*scaleFactorX).roundedUp;
	btn_Allocate.fontSize := (btn_Allocate.fontSize*scaleFactorY).roundedUp;

	btn_CargoEnquiry.top := (btn_CargoEnquiry.top*scaleFactorY).roundedUp;
	btn_CargoEnquiry.left := (btn_CargoEnquiry.left*scaleFactorX).roundedUp;
	btn_CargoEnquiry.height := (btn_CargoEnquiry.height*scaleFactorY).roundedUp;	
	btn_CargoEnquiry.width := (btn_CargoEnquiry.width*scaleFactorX).roundedUp;
	btn_CargoEnquiry.fontSize := (btn_CargoEnquiry.fontSize*scaleFactorY).roundedUp;

	btn_ChangePass.top := (btn_ChangePass.top*scaleFactorY).roundedUp;
	btn_ChangePass.left := (btn_ChangePass.left*scaleFactorX).roundedUp;
	btn_ChangePass.height := (btn_ChangePass.height*scaleFactorY).roundedUp;	
	btn_ChangePass.width := (btn_ChangePass.width*scaleFactorX).roundedUp;
	btn_ChangePass.fontSize := (btn_ChangePass.fontSize*scaleFactorY).roundedUp;
	
	btn_Down.top := (btn_Down.top*scaleFactorY).roundedUp;
	btn_Down.left := (btn_Down.left*scaleFactorX).roundedUp;
	btn_Down.height := (btn_Down.height*scaleFactorY).roundedUp;	
	btn_Down.width := (btn_Down.width*scaleFactorX).roundedUp;
	btn_Down.fontSize := (btn_Down.fontSize*scaleFactorY).roundedUp;

	btn_Load.top := (btn_Load.top*scaleFactorY).roundedUp;
	btn_Load.left := (btn_Load.left*scaleFactorX).roundedUp;
	btn_Load.height := (btn_Load.height*scaleFactorY).roundedUp;	
	btn_Load.width := (btn_Load.width*scaleFactorX).roundedUp;
	btn_Load.fontSize := (btn_Load.fontSize*scaleFactorY).roundedUp;

	btn_LocSummary.top := (btn_LocSummary.top*scaleFactorY).roundedUp;
	btn_LocSummary.left := (btn_LocSummary.left*scaleFactorX).roundedUp;
	btn_LocSummary.height := (btn_LocSummary.height*scaleFactorY).roundedUp;	
	btn_LocSummary.width := (btn_LocSummary.width*scaleFactorX).roundedUp;
	btn_LocSummary.fontSize := (btn_LocSummary.fontSize*scaleFactorY).roundedUp;

	btn_Location.top := (btn_Location.top*scaleFactorY).roundedUp;
	btn_Location.left := (btn_Location.left*scaleFactorX).roundedUp;
	btn_Location.height := (btn_Location.height*scaleFactorY).roundedUp;	
	btn_Location.width := (btn_Location.width*scaleFactorX).roundedUp;
	btn_Location.fontSize := (btn_Location.fontSize*scaleFactorY).roundedUp;

	btn_LogOff.top := (btn_LogOff.top*scaleFactorY).roundedUp;
	btn_LogOff.left := (btn_LogOff.left*scaleFactorX).roundedUp;
	btn_LogOff.height := (btn_LogOff.height*scaleFactorY).roundedUp;	
	btn_LogOff.width := (btn_LogOff.width*scaleFactorX).roundedUp;
	btn_LogOff.fontSize := (btn_LogOff.fontSize*scaleFactorY).roundedUp;

	btn_LogOffExit.top := (btn_LogOffExit.top*scaleFactorY).roundedUp;
	btn_LogOffExit.left := (btn_LogOffExit.left*scaleFactorX).roundedUp;
	btn_LogOffExit.height := (btn_LogOffExit.height*scaleFactorY).roundedUp;	
	btn_LogOffExit.width := (btn_LogOffExit.width*scaleFactorX).roundedUp;
	btn_LogOffExit.fontSize := (btn_LogOffExit.fontSize*scaleFactorY).roundedUp;

	btn_Move.top := (btn_Move.top*scaleFactorY).roundedUp;
	btn_Move.left := (btn_Move.left*scaleFactorX).roundedUp;
	btn_Move.height := (btn_Move.height*scaleFactorY).roundedUp;	
	btn_Move.width := (btn_Move.width*scaleFactorX).roundedUp;
	btn_Move.fontSize := (btn_Move.fontSize*scaleFactorY).roundedUp;

	btn_Pack.top := (btn_Pack.top*scaleFactorY).roundedUp;
	btn_Pack.left := (btn_Pack.left*scaleFactorX).roundedUp;
	btn_Pack.height := (btn_Pack.height*scaleFactorY).roundedUp;	
	btn_Pack.width := (btn_Pack.width*scaleFactorX).roundedUp;
	btn_Pack.fontSize := (btn_Pack.fontSize*scaleFactorY).roundedUp;

	btn_Preferences.top := (btn_Preferences.top*scaleFactorY).roundedUp;
	btn_Preferences.left := (btn_Preferences.left*scaleFactorX).roundedUp;
	btn_Preferences.height := (btn_Preferences.height*scaleFactorY).roundedUp;	
	btn_Preferences.width := (btn_Preferences.width*scaleFactorX).roundedUp;
	btn_Preferences.fontSize := (btn_Preferences.fontSize*scaleFactorY).roundedUp;

	btn_Unload.top := (btn_Unload.top*scaleFactorY).roundedUp;
	btn_Unload.left := (btn_Unload.left*scaleFactorX).roundedUp;
	btn_Unload.height := (btn_Unload.height*scaleFactorY).roundedUp;	
	btn_Unload.width := (btn_Unload.width*scaleFactorX).roundedUp;
	btn_Unload.fontSize := (btn_Unload.fontSize*scaleFactorY).roundedUp;

	btn_Up.top := (btn_Up.top*scaleFactorY).roundedUp;
	btn_Up.left := (btn_Up.left*scaleFactorX).roundedUp;
	btn_Up.height := (btn_Up.height*scaleFactorY).roundedUp;	
	btn_Up.width := (btn_Up.width*scaleFactorX).roundedUp;
	btn_Up.fontSize := (btn_Up.fontSize*scaleFactorY).roundedUp;

	btn_Voyage.top := (btn_Voyage.top*scaleFactorY).roundedUp;
	btn_Voyage.left := (btn_Voyage.left*scaleFactorX).roundedUp;
	btn_Voyage.height := (btn_Voyage.height*scaleFactorY).roundedUp;	
	btn_Voyage.width := (btn_Voyage.width*scaleFactorX).roundedUp;
	btn_Voyage.fontSize := (btn_Voyage.fontSize*scaleFactorY).roundedUp;
/*
	app.msgBox( "H W L T" &amp; CrLf &amp; "Form " &amp; self.height.asStringJMT &amp; " " &amp; self.width.asStringJMT &amp; " " &amp; self.left.asStringJMT &amp; " " &amp; self.top.asStringJMT
	&amp; CrLf &amp; "S OP " &amp; sht_Options.height.asStringJMT &amp; " " &amp; sht_Options.width.asStringJMT &amp; " " &amp; sht_Options.left.asStringJMT &amp; " " &amp; sht_Options.top.asStringJMT
	&amp; CrLf &amp; "SF X Y  " &amp; scaleFactorX.asStringJMT &amp; " " &amp; scaleFactorY.asStringJMT
	&amp; CrLf &amp; "F Tasks " &amp; fld_Tasks.height.asStringJMT &amp; " " &amp; fld_Tasks.width.asStringJMT &amp; " " &amp; fld_Tasks.left.asStringJMT &amp; " " &amp; fld_Tasks.top.asStringJMT
	&amp; CrLf &amp; "B Logoff " &amp; btn_LogOff.height.asStringJMT &amp; " " &amp; btn_LogOff.width.asStringJMT &amp; " " &amp; btn_LogOff.left.asStringJMT &amp; " " &amp; btn_LogOff.top.asStringJMT, "Form Size", MsgBox_OK_Only );
*/	

epilog
end;</source>
