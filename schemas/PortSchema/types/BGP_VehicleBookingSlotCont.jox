    <JadeMethod name="handleLoggingOfException" id="2dd237d8-7b68-4798-ba04-00abcbec44cf">
        <source>handleLoggingOfException( _exception : Exception; _msg : String output ) : Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 January 2014	cnwndl1	Initial creation	Par 33198

*/

vars

begin

	_msg := _exception.errorCode.String &amp; ' ' &amp; _exception.extendedErrorText;
	
	return Ex_Pass_Back;

epilog

end;</source>
        <Parameter name="_exception" type="Exception"/>
        <Parameter name="_msg" type="String" usage="output"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="initApp" id="cc8b5830-4e1d-4978-8452-8e86ed90b891">
        <updating/>
        <source>initApp() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 April 2013	cnwndl1	Initial creation	Par 31393
*/
//03 Jan 2013	cnwrs1	32983 crash after user deleted.

vars
	ls : Boolean;
	str : String;
	errorText : String;
	errorCode : Integer;
	msg : String;
	startDate : Date;
	endDate : Date;
	term : CM_Terminal;
begin
	on Exception do self.xHandlerGlobal(exception) global;
	on LockException do app.alertLockExceptionHandler(exception) global;
	str := self.getOidString();
	str.replaceChar('.' , '_');
	app.logFileNameSpecific := 'BGPController_' &amp; self.logFileName() &amp; '_' &amp; str; 
	
	app.setCnAppAlias(self.class.name);		 //epr TFS 36655 29/4/19
	
	app.initialize();

	app.setIsBackGroundApp(true);
 	app.cmsBeginLoad(ls);
	exclusiveLock(self);
	if self.isRunning() then
		app.isBGPAppAbort := true;
		msg := 'ERR &gt;&gt; app is already running';
		app.writeLog(msg, LogFATAL);	//25 Nov 2019	NDL	TFS 47053
		
		app.exitLogFile();
		terminate;
	endif;
	term := self.myTerminal;
	if term = null and self.myCurrentRequest &lt;&gt; null then
		term := self.myCurrentRequest.myTerminal;
	endif;
	if term = null or not term.isVehicleBookingEnabled then
		app.isBGPAppAbort := true;
		if term = null then
			msg := 'ERR &gt;&gt; Terminal = null';
		else
			msg := 'ERR &gt;&gt; Terminal ' &amp; term.name &amp; ' does not use Vehicle Scheduling';
		endif;
		app.writeLog(msg, LogFATAL);	//25 Nov 2019	NDL	TFS 47053
		
		app.exitLogFile();
		terminate;
	endif;
	
	if app.myPassport &lt;&gt; null then
 		app.myPassport.setMyUser(self.myUser);
  	endif;
	app.myTrxUA.trxUpdateBGPControllerProcess(self, process, process.signOnTime, true, app.myPassport);
	self.beginNotification(self, BGP_Object.BGP_TerminateAppRequest, Response_Cancel , null);
	self.beginNotification(self, BGP_Object.BGP_DebugLevelChangeEvent, Response_Continuous , null);
	self.beginNotification(self, BGP_Object.BGP_OutputInfo, Response_Continuous , null);
	self.beginNotification(self, BGP_Object.BGP_ApplicationStartRequest, Response_Continuous , null);
	
	self.doTheNeedful();	//06 Aug 2013	NDL	Par 32077
//	startDate := app.actualTimeAppServer.Date;
//	endDate := startDate + term.getConfig( VsGenerateDaysInAdvance ).Integer;
	
//	term.myVehicleBookingTerminal.generateSlotsFromTemplate( startDate, endDate );

	
epilog
	app.cmsEndLoad(ls);
	// we've finished now, so just do a finish to tidy ourselves up and stop
	//self.finish();	06 Aug 2013	NDL	Par 32077 - Removed line 
end;</source>
    </JadeMethod>
