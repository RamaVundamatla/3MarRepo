    <JadeMethod name="setProxyAttributes" id="59117469-62a8-464e-8c89-701e20f549e1">
        <source>setProxyAttributes(_pxyProduct : CM_Product) : Boolean;
// ---------------------------------------------------------------------------
// Created:     08 October 2002 by cnwth2
//
// Purpose:     Setting of codes is set real time, so this method sets the prodAttrs
//				that have a validation of Value or Range
// Changed On	By			Reason
// ----------   ----------  --------------------------------------------------
// 15/03/2013	cnwdap1		PAR #31155 CCMS SFW 1321 Imperial Measurements
vars
	rangeErrorStr		: String;
	prodAttrsViewable	: StringArray;
	table				: CM_DataTable;
	row					: Integer;	
	rangeStr,
	prodAttrStr			: String;
	prodAttr			: CM_ProductAttr;
	cargoTypeObj		: CM_CargoType;
	tmpValue			: Any;
	measure				: CM_MeasurementType;			//PAR #31155
begin
	table := self.tblAttributes;
	//set prodAttribute references
	cargoTypeObj		:=	self.myProxyObject.CM_Product.myCargoType;
	prodAttrsViewable	:=	cargoTypeObj.allAttributesOnProduct;
	// This is the new one for after 7.4.1 release	
	//prodAttrsViewable := cargoType.getAttributeValue(CM_CargoTypeExtBreakBulkGen::allAttributesOnProduct.name).StringArray;
	
	foreach prodAttrStr in prodAttrsViewable do
		foreach row in table.fixedRows + 1 to table.rows do
			prodAttr := table.accessRow(row).itemObject.CM_ProductAttr;
			
			if prodAttr.name = prodAttrStr then
				//assign appropriate values depending on the validation type and primitive type of
				//the prod attribute
				prodAttr.setIsViewable((table.getCellText(row, table.getColumnByRowName(ETRow_IsViewable))="1").Boolean);
				prodAttr.setDisplayName(table.getCellText(row, table.getColumnByRowName(ETRow_DisplayName)));
				
				if prodAttr.validationType = CM_ProductAttr.ValidationType_Value then
					//its OK if these are null - at the gate in stage they can over-ride any value set anyway
					tmpValue := table.getCellText(row, table.getColumnByRowName(ETRow_Value));
					measure := prodAttr.myMeasurementType;																			// PAR #31155
					if measure &lt;&gt; null then																							// PAR #31155
						prodAttr.setValue(app.convertMeasurementForStorage(measure.shortName, tmpValue.Decimal));					// PAR #31155
					else																											// PAR #31155
						prodAttr.setValue(tmpValue.String.asDecimalJMT());	//PAR 22189 Feb 2010
					endif;																											// PAR #31155
					//prodAttr.setMultiplier(table.getCellText(row, table.getColumnByRowName(ETRow_Multiplier)).asDecimalJMT());	// PAR #31155
					rangeStr := table.getCellText(row, table.getColumnByRowName(ETRow_Range)).String;
					
					if rangeStr &lt;&gt; null then	
						rangeErrorStr := prodAttr.parseAndAssignRange(rangeStr);
						
						if rangeErrorStr &lt;&gt; null then
							app.msgBox('Incorrect range format entered for ' &amp; prodAttr.displayName &amp; ':' &amp; CrLf &amp; rangeErrorStr, 'Range error', MsgBox_Exclamation_Mark_Icon);
							return false;
						endif;
					else
						prodAttr.clearRange();
					endif;
					
					break;
				elseif prodAttr.validationType = CM_ProductAttr.ValidationType_Codes then
					//do nothing because codes should already be set
					break;
				else
					app.msgBox(app.getErrorString(NoValidatioForCargoSubAttrib), 'Error', 0);
					return false;
				endif;
			endif;
		endforeach;
	endforeach;
	
	return true;
end;</source>
        <Parameter name="_pxyProduct" type="CM_Product"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setProxyProductData" id="2fd3d6e0-0f55-4b2b-9096-0955a9bdf115">
        <source>setProxyProductData(_pxyProduct : CM_Product input) : Boolean;
// ---------------------------------------------------------------------------
// Created:     08 October 2002 by cnwth2
//
// Purpose:     
//
// Changed		Who			Why
// ----------   ----------  --------------------------------------------------
// 30/11/2009	cnwdap1		CCMS 1007 - new CM_Product attributes
vars
	terminalObj			: CM_Terminal;
	cargoTypeObj		: CM_CargoType;
	operatorObj			: CM_Operator;
	commodityObj		: CM_Commodity;
	defaultCommodityCode: String;
	prodGroupObj		: CM_ProductGroup;
	handlingTypeObj	  	: CM_HandlingType;
	code,
	descr				: String;
	storageCharge		: Decimal[12,4];
	colour				: Integer;
	errorFound			: Boolean;
	reefer, powered,					// CCMS 1007
	integral, fan		: Boolean;		// CCMS 1007
	isNotAvail : Boolean;
	autoVolumeCalculate : Boolean;	//10 Jun 2016	NDL	TFS 2141
	handlingSubType : CM_HandlingSubType;	//31 Mar 2017	NDL	TFS 3414
	allowAutoWeightCalculate : Boolean; //18 Jan 2018	NDL	TFS 36697
begin

	
	if _pxyProduct = null then
		return false;
	endif;
	
	terminalObj		:=	self.myTerminal;
	cargoTypeObj	:=	self.cmbEntCargoType.listObject.CM_CargoType;
	operatorObj		:=	self.cmbEntOperator.myObject.CM_Operator;
	commodityObj	:= self.cmbCommodity.listObject.CM_Commodity;	// ccms 1080 - cmbCommodity added. July 2009
	if commodityObj &lt;&gt; null then
		defaultCommodityCode := commodityObj.code;
	endif;
	handlingTypeObj	:=	self.cmbEntHandling.listObject.CM_HandlingType;
	handlingSubType	:=	self.cmbSubHandl.listObject.CM_HandlingSubType;	//31 Mar 2017	NDL	TFS 3414
	prodGroupObj	:=	self.cmbProdGroup.listObject.CM_ProductGroup;
	storageCharge	:=	self.tblEntDetail.getValueByName(ETRow_StorageCharge).Decimal;
	code	:=	self.tblEntDetail.getValueByName(ETRow_Code).String;
	descr	:=	self.tblEntDetail.getValueByName(ETRow_Description).String;
	colour	:=	self.tblEntDetail.getValueByName(ETRow_Colour).Integer;
	
	// CCMS 1007
	reefer		:= self.tblEntDetail.getValueByName(ETRow_Reefer).Boolean;
	powered		:= self.tblEntDetail.getValueByName(ETRow_Powered).Boolean;
	integral	:= self.tblEntDetail.getValueByName(ETRow_Integral).Boolean;
	fan			:= self.tblEntDetail.getValueByName(ETRow_Fan).Boolean;
	isNotAvail 	:= self.tblEntDetail.getValueByName(ETRow_IsNotAvailableForEntry).Boolean;
	autoVolumeCalculate := self.tblEntDetail.getValueByName(ETRow_AutoVolumeCalculate).Boolean; //10 Jun 2016	NDL	TFS 2141
	allowAutoWeightCalculate := self.tblEntDetail.getValueByName(ETRow_AutoWeightCalculate).Boolean; //18 Jan 2018	NDL	TFS 36697
	
	_pxyProduct.setProxy(cargoTypeObj,
						operatorObj,
						defaultCommodityCode,
						prodGroupObj,
						handlingTypeObj,
						handlingSubType,		//31 Mar 2017	NDL	TFS 3414
						storageCharge,
						code,
						descr,
						colour,
						reefer,		// CCMS 1007
						powered,	// CCMS 1007
						integral,	// CCMS 1007
						fan,
						isNotAvail,
						autoVolumeCalculate,
						allowAutoWeightCalculate
						);		// CCMS 1007

	return true;

end;</source>
        <Parameter name="_pxyProduct" type="CM_Product" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setupControls" id="7c58bfd6-41e2-468c-9ece-1c85c067841d">
        <updating/>
        <source>setupControls() updating;
// ---------------------------------------------------------------------------
// Created:     22 August 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
constants
	HorzGap = 5;
vars
	buttoneHeight,
	buttonWidth			: Integer;
begin
	
	//self.sptThumbEdit.showLeftControl(0, false);
	self.sptThumbEdit.showRightControl(0, false);
	self.sptThumbEdit.setLeftToRightRatioAndResize(35);
	
	self.frmDetailsBottom.width := self.frmDetailsBottom.parent.width;
	
	self.tblAttributes.visible := true;
	self.tblAttributes.stretchHeight := true;
	self.tblAttributes.stretchWidth := true;
	self.tblAttributes.visible := true;
	
	self.tblAttributes.left := 0;
	self.tblAttributes.top := 0;
	self.tblAttributes.width := self.sptThumbEdit.width;
	self.tblAttributes.height := self.tblAttributes.parent.height;
	
	self.frmEditCode.left := 0;
	self.frmEditCode.top := 0;
	self.frmEditCode.width := self.frmEditCode.parent.width;
	self.frmEditCode.height := self.frmEditCode.parent.height;

	self.lblEntCode.left := HorzGap;
	self.lblEntCode.top := HorzGap;
	self.lblEntCode.width := self.lblEntCode.parent.width;
	self.lblEntCode.height := 30;
		
	self.tblEntCode.left := HorzGap;
	self.tblEntCode.top := self.lblEntCode.top + self.lblEntCode.height + self.HorizontalSpacing;
	self.tblEntCode.width := 255;
	self.tblEntCode.height := HorzGap * 8;

	buttonWidth := 65;
	buttoneHeight := 25;
	self.btnAddCode.left := HorzGap;
	self.btnAddCode.top := self.tblEntCode.top + self.tblEntCode.height + HorzGap;	
	self.btnAddCode.width := buttonWidth;
	self.btnAddCode.height := buttoneHeight;
	
	self.btnUpdateCode.left := self.btnAddCode.left + self.btnAddCode.width + HorzGap;
	self.btnUpdateCode.top := self.tblEntCode.top + self.tblEntCode.height + HorzGap;	
	self.btnUpdateCode.width := buttonWidth;
	self.btnUpdateCode.height := buttoneHeight;
	
	self.btnRemoveCode.left := self.btnUpdateCode.left + self.btnUpdateCode.width + HorzGap;
	self.btnRemoveCode.top := self.tblEntCode.top + self.tblEntCode.height + HorzGap;	
	self.btnRemoveCode.width := buttonWidth;
	self.btnRemoveCode.height := buttoneHeight;
	
	self.btnCloneCodes.left := self.tblEntCode.width + (HorzGap * 2);
	self.btnCloneCodes.top := self.tblEntCode.top;	
	self.btnCloneCodes.width := 95;
	self.btnCloneCodes.height := buttoneHeight;
	
	self.btnBack.width := buttonWidth;
	self.btnBack.height := buttoneHeight;
	
	self.frmCloneProduct.left := 0;
	self.frmCloneProduct.top := 0;
	
	self.staMain.visible := true;	// cnwdad1 18/11/2005 - changed visible to true.
	self.bottomMargin	 := self.staMain.height;
	self.tblCodeData.top := self.btnAddCode.top + self.btnAddCode.height + self.HorizontalSpacing;
	
	// force the tables to show the left column
	self.tblAttributes.leftColumn	:= 1;
	self.tblThumb.leftColumn	:= 1;
end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="f94cb23d-6a73-4a12-81ef-6ade10e65af2">
        <updating/>
        <source>setupForm() updating;
// ---------------------------------------------------------------------------
// Created:     02 October 2002 by cnwth2
//
// Purpose:     
//
// ----------   ----------  --------------------------------------------------
vars

begin
	inheritMethod();
	self.setupControls();
	self.tblEntCode.optimiseHeadingColumn();
	self.tblEntCode.adjustHeight(200);
	self.zDoSearch();
	self.tblAttributes.tabKey := J_key_Tab;

	self.setColorsForTable(self.tblAttributes);
	self.setColorsForEntryTable(self.tblEntDetail);
	self.frmDetailsTop.backColor := self.backColor;
	self.frmCloneProduct.backColor := self.backColor;

	self.tblData.setFocus();
end;</source>
    </JadeMethod>
    <JadeMethod name="showCloneOptions" id="773a314e-bdc4-45d8-9d34-8b8d508835f9">
        <updating/>
        <source>showCloneOptions(_isCloningCodes : Boolean) updating;
// ---------------------------------------------------------------------------
// Created:     08 October 2002 by cnwth2
//
// Purpose:     The _isCloningCodes param is passed in and sets the form.isCloningCodes so that
//				the form knows weather to clone an entire product, or just the codesDict from a 
//				single product attribute 
//
// ----------   ----------  --------------------------------------------------
vars
	
begin

	self.isCloningCodes := _isCloningCodes;
	
	if self.cmbEntCargoType.listObject = null then	//PAR 21348. Oct 2009
		app.msgBox(app.getErrorString(Please_select_cargo_type), ' ', MsgBox_Information_Icon  + MsgBox_OK_Only);
		return;
	endif;
	
	//load clone combos - we do it here rather than in the loadCombos method because it is
	//more than likely the user has added products/codes since the execution of that method
	self.loadCloneCargoTypes();
	self.loadCloneProducts();
	self.loadCloneAttributes();
	self.isCloning := true;
	
	//disable stuff	
	self.btnCloneProduct.enabled := false;
	self.btnCloneCodes.visible := false;
	self.frmDetailsBottom.enabled := false;
//	self.btnCancel.visible := false;
//	self.btnSave.visible := false;
	self.frmCloneProduct.width := self.frmDetailsTop.width;	
	self.frmDetailsTop.enabled := true;
	self.lblSelectClone.caption := app.getErrorString(SelectCargSubAttrFromWhichCloC);	
	self.chkOverwriteCode.visible := true;
	
	if not _isCloningCodes then //we're cloning a product
		self.cmbCloneAttr.visible := false;
		self.lblCloneAttr.visible := false;
		self.chkOverwriteCode.visible := false;
		self.lblSelectClone.caption := app.getErrorString(SelectCargoSubFromWhichToClon_);	

	endif;

	
	self.frmCloneProduct.visible := true;
	
end;</source>
        <Parameter name="_isCloningCodes" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="showEditCodes" id="0ba011a3-f31f-4a85-952e-0cb49454307e">
        <updating/>
        <source>showEditCodes()updating;
// ---------------------------------------------------------------------------
// Created:     04 October 2002 by cnwth2
//
// Purpose:     Displays the frame for editing codes and loads in the codes for the selected prod attr
//
// ----------   ----------  ------------------------------------------------

vars
	prodAttr			: CM_ProductAttr;
	productCode			: String;
	prodCode			: CM_ProductAttributeCode;
	idx					: Integer;
begin
//	self.btnCancel.enabled := false;
//	self.btnSave.enabled := false;
	self.btnCloneProduct.enabled := false;
	self.frmDetailsTop.enabled := false;
	self.tblAttributes.visible := false;
	
	productCode := self.myProxyObject.CM_Product.code;
	prodAttr := self.myCurrentProdAttr;
	if productCode = null or prodAttr = null then
		productCode := app.getErrorString(New_Cargo_Subtype);
	endif;
	
	self.lblEntCode.caption := 'Editing codes for ' &amp; prodAttr.displayName &amp; 
								' of ' &amp; productCode &amp; ' for type ' &amp; 
								self.cmbEntCargoType.listObject.CM_CargoType.description;	
	
	//load existing codes into te code data table
	self.tblCodeData.rows := self.tblCodeData.fixedRows;
	foreach prodCode in prodAttr.allCodes do	
		idx := self.tblCodeData.addItem(prodCode.code &amp; Tab &amp; prodCode.description);
		self.tblCodeData.accessRow(idx).itemObject := prodCode;
	endforeach;
	
	self.frmEditCode.visible := true;

	self.tblEntCode.setValueByName(ETRow_EntCode, null);
	self.tblEntCode.setValueByName(ETRow_EntDescription, null);
	self.tblEntCode.setFocus();
	self.tblEntCode.goToRowByName(ETRow_EntCode);

end;</source>
    </JadeMethod>
    <JadeMethod name="showEditCodesForm" id="fa4d7284-50e2-418d-b73f-6c0b05e9f4f7">
        <updating/>
        <source>showEditCodesForm() updating;
// ---------------------------------------------------------------------------
// Created:     16 August 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars
	//theForm : GC_CodeMaintForm;
begin

	// commented by CCMS1080, PAR197040 July 2009
	// now, there is new from for editing attributes, which calls Codes editing.

	
	
	
/*
	theForm := app.loadForm(GC_CodeMaintForm, CMUI_Assistant, false, false, false, self.myTerminal, null).GC_CodeMaintForm;
	
	if theForm = null then
		return;
	endif;

//	this is set so after codes are edited and the user trys to cancel out of this 
//	screen without saving then message can be raised to user to warn them. 
	self.isCodesEdited := true;
		
	
	theForm.productCode := self.myProxyObject.CM_Product.code;
	theForm.myProductAttr := self.myCurrentProdAttr;
	theForm.myParentForm := self;
	theForm.myProduct := self.myCurrentObject.CM_Product;
	
	theForm.showModal();
*/
end;</source>
    </JadeMethod>
    <JadeMethod name="showHideDefaultCommodity" id="7a8de6f5-1d69-4920-881c-4421b6bef6ff">
        <source>showHideDefaultCommodity() protected;
/* ---------------------------------------------------------------------------
Created:	16 July 2009	by cnwvu1

Purpose:	CCMS 1080, PAR19704. July 2009
			Default Commodity has been added.
   
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars
	cargoType	: CM_CargoType;
	
begin

	self.tblEntDetail.hideRowByName(ETRow_DefaultCommodityCode, false);
	
	cargoType := self.cmbEntCargoType.listObject.CM_CargoType;
	if cargoType &lt;&gt; null then
		self.loadCommodities(cargoType);	// 33720 populate the commodity combo on change of cargo type so the product default commodity can be found there
		if cargoType.isCommodityRequired then
			self.tblEntDetail.showRowByName(ETRow_DefaultCommodityCode, false);
		endif;
	endif;

	self.tblEntDetail.cnEcResizeContents();
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="showThumbnailData" id="619ffe25-2e7e-4652-87bb-2c0ec64ffdf6">
        <updating/>
        <source>showThumbnailData(obj: Object) updating;
// ---------------------------------------------------------------------------
// Created:     02 October 2002 by cnwth2
//
// Purpose:     
//
// ----------   ----------  --------------------------------------------------
vars
	pro		: CM_Product;
begin
	pro := obj.CM_Product;

	self.tblThumb.rows := 0;
	self.tblThumb.columns := 2;
	self.showThumbnailForDef(ETDef_ProductThumb, pro);
	self.tblAttributes.rows := self.tblAttributes.fixedRows;
	self.displayAttributes(pro);
	self.setNavigatorHeading(pro.code);
	tblThumb.optimiseHeadingColumn(tblThumb.accessSheet(tblThumb.topSheet));
//	tblThumb.accessColumn(1).width := 125;
// cnwdad1 20/03/2009 - PAR #18813.
	sptThumbEdit.setLeftToRightRatio(45);
end;</source>
        <Parameter name="obj" type="Object"/>
    </JadeMethod>
    <JadeMethod name="showThumbnailForDef" id="061e2cbe-50d9-4645-91a8-e89445794211">
        <source>showThumbnailForDef(pDefName: String; _obj: CM_Object);
/* ---------------------------------------------------------------------------
Created:	16 July 2009	by cnwvu1

Purpose:
   
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars
	productType	: CM_Product;
	cargoType	: CM_CargoType;
	
begin

	inheritMethod(pDefName, _obj);

	productType := self.myCurrentObject.CM_Product;
	
	// hide default commodity for non-commodity cargo type. CCMS 1080 PAR19704 July 2009
	self.tblThumb.showRowFromHeading(self.tblEntDetail.getHeadingByName(ETRow_DefaultCommodityCode));
	
	if productType = null then
		self.tblThumb.hideRowFromHeading(self.tblEntDetail.getHeadingByName(ETRow_HandlingSubType));	//31 Mar 2017	NDL	TFS 3414
		return;
	else
		//31 Mar 2017	NDL	TFS 3414
		if productType.myHandlingType = null or not productType.myHandlingType.hasSubTypes then
			self.tblThumb.hideRowFromHeading(self.tblEntDetail.getHeadingByName(ETRow_HandlingSubType));
		else
			self.tblThumb.showRowFromHeading(self.tblEntDetail.getHeadingByName(ETRow_HandlingSubType));
		endif;
	endif;

	if not productType.myCargoType.isCommodityRequired then
		self.tblThumb.hideRowFromHeading(self.tblEntDetail.getHeadingByName(ETRow_DefaultCommodityCode));
	endif;
	
end;</source>
        <Parameter name="pDefName" type="String"/>
        <Parameter name="_obj" type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="showWithObject" id="dd844e5d-d574-492e-b9bd-536a26bf53a8">
        <updating/>
        <source>showWithObject(pObj: CM_Object; _thumbnailOnly: Boolean; _doEdit: Boolean) updating;
// --------------------------------------------------------------------------------
// Created:		05 December 2005 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 07/05/2020	jlgdap1		TFS 49252 CPL Cargo Types not showing in System Admin
// --------------------------------------------------------------------------------
vars
	int : Integer;
	cargoType : CM_CargoType;
begin
	inheritMethod(pObj, _thumbnailOnly, _doEdit);
//	cmbFiltCargoType.cnEcSetItemData(self.LIST_ENTRY_ALL);

	if pObj &lt;&gt; null and pObj.isKindOf(CM_CargoType)then 
		cargoType := pObj.CM_CargoType;
		if cargoType.id &gt; TI_CargoBOLType_Max 
			//and cargoType.id &lt; TI_CargoBOLType_JMTMax then									// TFS 49252
			and (cargoType.id &lt; TI_CargoBOLType_JMTMax or app.myRoot.isClientCentrePort) then	// TFS 49252
	//		and cargoType.myTIBehaviourType.class = CM_TIBehaviourBreakBulkGeneric then
	
			app.setMyCurrentCargoType(pObj.CM_CargoType);
			cmbFiltCargoType.listObject	:=	pObj;
			self.myFilterCargoType := pObj.CM_CargoType;
		else
			app.setMyCurrentCargoType(null);
			cmbFiltCargoType.listObject	:=	null;
			self.myFilterCargoType := null;
		endif;
	endif;
	
	self.doRefresh(); //02/04/2009 cnwdz2 PAR19302
end;</source>
        <Parameter name="pObj" type="CM_Object"/>
        <Parameter name="_thumbnailOnly" type="Boolean"/>
        <Parameter name="_doEdit" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="tblAttributes_click" id="98a9d9ae-f571-449c-996e-fbdabfe8c105">
        <controlMethod name="Table::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblAttributes_click(table: Table input) updating;
// JLGAB1 5SEP19
// TFS 46467
vars
	col : Integer;
	row : Integer;
	value : Boolean;
	attrib : CM_ProductAttr;
begin

	if self.mode &lt;&gt; Mode_Update then
		return;
	endif;
	
	col := table.column;
	row := table.row;
	
	if col = 1 then
		table.accessCell(row,col);
		table.accessRow(row);
		value := table.accessedCell.text.Integer.Boolean;
		
		if table.accessedRow.itemObject.isKindOf(CM_ProductAttr) then
			attrib := table.accessedRow.itemObject.CM_ProductAttr;
			attrib.setIsViewable(not value);
			table.accessedCell.text := (not value).Integer.String;
		endif;
	endif;
	
	
end;
</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="tblAttributes_contextMenu" id="e39c155a-57c2-4f7c-8b7b-bd8ad34b2c85">
        <controlMethod name="Table::contextMenu"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblAttributes_contextMenu(table: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating;
// ---------------------------------------------------------------------------
// Created:     23 August 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars

begin
	// must be clicking on the tblAttributes so show its context menu
	//(putting this code in tblAttributes contect menu method didnt work)
	
	// comented by CCSM 1080 PAR19704 July 2009 cnwvu1	
	//return self.doTblAttributeContext(conwin, mouse, x, y);
	// now there is new form specifically designed for Edit attributes
	// tblAttributes is readonly always
	return self.doShowContextMenuTblAttributes(self.mnuContext, table, conwin, mouse, x, y);
	
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
