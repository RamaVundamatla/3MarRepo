    <JadeMethod name="buildCommonEventReqSearchDef" id="595dfa3f-dbd2-4e5d-9f54-b5f16fc74677">
        <updating/>
        <source>buildCommonEventReqSearchDef() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 August 2008	cnwkao1	Initial creation

*/
constants
	Parent_Column1	: String = "column1";
	Parent_Column2	: String = "column2";
	
vars
	entTableGroup	: EntTableGroup;
	entTableDef		: EntTableDef;
	entTableRow		: EntTableRow;
	fieldDef		: WS_FieldDefinition;
	column1Rows		: StringArray; //perhaps a more appropriate collection should be used
	column2Rows		: StringArray;
	parent			: String;
	rowName			: String;
	//defaultCargoTypeId : Integer;
begin
	//get the applicable group
	entTableGroup := CM_EntTableDataRoot.firstInstance.allEntTableGroups.getAtKey(ETGrp_EventRequest);
	
	//get the applicable definition
	entTableDef := entTableGroup.allEntTableDefsByName.getAtKey(ETDef_EventRequestSearch);
	
	create column1Rows transient;
	column1Rows.add(ETRow_Status);			//Status
	column1Rows.add(ETRow_MyCargoType);		//cargo type
	column1Rows.add(ETRow_FromDate);		//fromDate
	column1Rows.add(ETRow_ToDate);			//toDate	
	
	self.buildGroupHeader(	Parent_Column1,
							null,
							null); //hold above entries
	
	
	create column2Rows transient;
	column2Rows.add(ETRow_MyOrganisation);	//Organisation
	column2Rows.add(ETRow_MyUser);			//User
	column2Rows.add(ETRow_Reference);		//Reference
	column2Rows.add(ETRow_Event);
	/*if self.formName = Cargo_Stop_Search then
		column2Rows.add(ETRow_Stops);	
	else
		column2Rows.add(ETRow_Event);			//Request
	endif;*/
	self.buildGroupHeader(Parent_Column2,
							null,
							null); //hold above entries
			
	//setup each row
	foreach entTableRow in entTableDef.allEntTableRows where not entTableRow.name = ETRow_EmailAddresses do
		fieldDef := self.loadFieldFromRow(entTableRow);	
	endforeach;
		
	//set any additional details
	foreach rowName in column1Rows do
		fieldDef := self.allFormFieldsByKey.getAtKey(rowName);
		fieldDef.parent := Parent_Column1;
	endforeach;
	
	foreach rowName in column2Rows do
		fieldDef := self.allFormFieldsByKey.getAtKey(rowName);
		fieldDef.parent := Parent_Column2;
	endforeach;
	
	//setup defaults
	fieldDef := self.allFormFieldsByKey.getAtKey(ETRow_CargoId);
	fieldDef.isUppercaseText := true;
	
	//20/11/2011 cnwdz2 27891
	fieldDef := self.allFormFieldsByKey.getAtKey(ETRow_Reference);
	fieldDef.maxTextLength := WS_EventRequestStops::reference.length;
	//fieldDef := self.allFormFieldsByKey.getAtKey(ETRow_MyCargoType);
	//defaultCargoTypeId := app.myPassport.myTerminal.defaultCargoType;
	//fieldDef.defaultId := defaultCargoTypeId.asStringJMT();
	//fieldDef.defaultDescription := app.myRoot.allCargoTypesById[defaultCargoTypeId].description;
	
	//fieldDef := self.allFormFieldsByKey.getAtKey(ETRow_Status);
	//fieldDef.defaultId := EventRequestStatusAny.asStringJMT();
	//fieldDef.defaultDescription := 	EventRequestAnyStr;
	
	fieldDef := self.allFormFieldsByKey.getAtKey(ETRow_Event); //was ETRow_UpdateDetails
	fieldDef.controlType := ControlType_ListBox;
epilog
	delete column1Rows;
	delete column2Rows;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="buildField" id="77fa4c28-0abb-4cc0-99c2-79cd2333bf32">
        <source>buildField(	key					: String;
			label				: String;
			controlType			: Integer;
			parent				: String;
			dataStore			: String;
			readOnly			: Boolean;
			dataList			: String;
			storeIdField		: String;
			storeDescField 		: String;
			repeatedStoreField	: String;
			defaultId			: String;
			defaultDesc			: String 
			) : WS_FieldDefinition protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 August 2008	cnwkao1	Initial creation

*/

vars
	fieldDef : WS_FieldDefinition;
	
begin
	create fieldDef transient;
	//epr tfs 37479 9/3/17
	if not self.isWebportalReport then
		fieldDef.myFormDefinition		:= self;
	endif;
	fieldDef.key					:= key;
	fieldDef.label					:= label;
	fieldDef.controlType			:= controlType;
	fieldDef.readOnly				:= readOnly;
	fieldDef.dataStore				:= dataStore;
	fieldDef.dataList				:= dataList;
	fieldDef.storeIdField			:= storeIdField;
	fieldDef.storeDescriptionField	:= storeDescField;
	fieldDef.repeatedStoreField		:= repeatedStoreField;
	fieldDef.parent					:= parent;
	fieldDef.defaultId				:= defaultId;
	fieldDef.defaultDescription	    := defaultDesc;

	//cnwmc5 - PAR 32450 - 9 Sep 2013
	if key = 'colour' then
		if not app.myPassport.myTerminal.getConfig(ValidateColour).Boolean then
			fieldDef.controlType := 0;
		endif;
	endif;
	
	//cnwmc5 - 2 June 2016 - TFS 2039 - default to true....
	fieldDef.useRealObject := true;
	
	return fieldDef;
epilog

end;
</source>
        <access>protected</access>
        <Parameter name="key" type="String"/>
        <Parameter name="label" type="String"/>
        <Parameter name="controlType" type="Integer"/>
        <Parameter name="parent" type="String"/>
        <Parameter name="dataStore" type="String"/>
        <Parameter name="readOnly" type="Boolean"/>
        <Parameter name="dataList" type="String"/>
        <Parameter name="storeIdField" type="String"/>
        <Parameter name="storeDescField" type="String"/>
        <Parameter name="repeatedStoreField" type="String"/>
        <Parameter name="defaultId" type="String"/>
        <Parameter name="defaultDesc" type="String"/>
        <ReturnType type="WS_FieldDefinition"/>
    </JadeMethod>
