    <JadeMethod name="performDelayedDirectionChange" id="ea8c0019-c80c-41b9-ba42-ba35999030ad">
        <updating/>
        <source>performDelayedDirectionChange()updating;
// ---------------------------------------------------------------------------
// Created:     25 August 2009 by cnwcs5:1
// Purpose:     CCMS 1061 - Gate Config Changes  
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin 
	self.raiseExceptionIfTransient (method);

	if  self.laneDirection &lt;&gt; self.vehicleDirection and self.allVehicleMachines.size = 1 then
		
		self.vehicleDirection := self.laneDirection;
		
		self.myTerminalArea.causeEvent(self.myTerminal.getTerminalEvent(Event_GateLane_Change), false, self.myTerminalArea);
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="b6f85dd3-89f9-4cfe-87b8-f4603932ca91">
        <source>pxyCreateUpdateProxy(): SelfType;
// ---------------------------------------------------------------------------
// Created:     22 June 2009 by concms1:1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy
// ---------------------------------------------------------------------------
vars
	proxy		:SelfType;
	ld, pxyLD	:CM_LaneDevice;
	completedOK		: Boolean;
begin
	proxy := inheritMethod();

	foreach ld in self.allLaneDevices do
		pxyLD := ld.pxyCreateUpdateProxy;
		
		pxyLD.setMyLaneController (proxy);	// updates proxy.allLaneDevices
	endforeach;
	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return proxy;
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete proxy;
	endif;

end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setBoom" id="7269775c-21af-4d7b-ae50-ff64aad9f3df">
        <updating/>
        <source>setBoom(_boom : CM_Boom; _inBoom : Boolean) updating;
// ---------------------------------------------------------------------------
// Created:     29 June 2009 by concms1
// Purpose:     CCMS 1061 - Gate Config Changes  
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	ld	:CM_LDBoom;
begin
	self.raiseExceptionIfNotTransient (method);
	
	ld := self.getLaneDevice_Boom(_inBoom);

	if _boom = null and ld &lt;&gt; null then
		// they are reseting the boom
		delete ld;
		return;
	endif;
	
	if ld = null then
		create ld transient;
		if _inBoom then
			ld.setType(CM_LaneDevice.Type_BoomIn);
		else
			ld.setType(CM_LaneDevice.Type_BoomOut);
		endif;
		ld.setMyLaneController (self);
	endif;
	
	ld.setBoom(_boom);
end;</source>
        <Parameter name="_boom" type="CM_Boom"/>
        <Parameter name="_inBoom" type="Boolean"/>
    </JadeMethod>
