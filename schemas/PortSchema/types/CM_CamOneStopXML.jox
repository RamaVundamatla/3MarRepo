    </JadeMethod>
    <JadeMethod name="makeReeferInfoSectXML" id="8515a590-801e-493e-ae28-ce720c670f3a">
        <source>makeReeferInfoSectXML( _ti : CM_TrackedItem; _parentElem : JadeXMLElement input ) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 August 2016	cnwndl1	Initial creation	TFS 2561 / 2277

*/

vars

	rootElem : JadeXMLElement;
	xmlElem : JadeXMLElement;
	workStr : String;
	reeferProp : CM_TIReeferProperties;
	
begin

	rootElem := _parentElem.addElement('ReeferInformation');
	
	if _ti = null then
		return;
	endif;
	reeferProp := _ti.myReeferProperties;
	
	if reeferProp = null then
		return;
	endif;
	
	if reeferProp.coolingType = ContainerWaterCooled then
		workStr := "W";
	else
		workStr := "A";
	endif;
	xmlElem := rootElem.addElement('RefrigeratorType');
	xmlElem.setText( workStr );
	
	self.makeControlTempSubSectXML( reeferProp, rootElem );
	
	self.makeStorageTempSubSectXML( reeferProp, rootElem );
	
	self.makeTransportTempSubSectXML( reeferProp, rootElem );
	
	self.makeEmergTempSubSectXML( reeferProp, rootElem );
	
	xmlElem := rootElem.addElement('Humidity');
	xmlElem.setText( reeferProp.getHumidityAsString );
	
	self.makeVentSettingSubSectXML( reeferProp, rootElem );
	
	self.makeReeferMonSubSectXML( reeferProp, rootElem );

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_parentElem" type="JadeXMLElement" usage="input"/>
    </JadeMethod>
    <JadeMethod name="makeReeferMonSubSectXML" id="e85d590e-2cc7-4246-a0aa-aede1f8a23e2">
        <source>makeReeferMonSubSectXML( _reeferProp : CM_TIReeferProperties; _parentElem : JadeXMLElement input ) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 August 2016	cnwndl1	Initial creation	TFS 2561 / 2277

*/

vars

	rootElem : JadeXMLElement;
	xmlElem : JadeXMLElement;
	latest : CM_TempReading;
	
begin

	rootElem := _parentElem.addElement('ReeferMonitor');
	
	if _reeferProp = null then
		return;
	endif;
	
	if _reeferProp.allTemperatureReadings.isEmpty then
		return;
	endif;
	
	latest := _reeferProp.allTemperatureReadings.last;
	
	xmlElem := rootElem.addElement('MonitorTemperature');
	xmlElem.setText( latest.getTemperatureValue.Decimal.roundedTo(1).String );
	
	xmlElem := rootElem.addElement('MonitorTimeStamp');
	xmlElem.setText( latest.dateTime.asXMLFormat );

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_reeferProp" type="CM_TIReeferProperties"/>
        <Parameter name="_parentElem" type="JadeXMLElement" usage="input"/>
    </JadeMethod>
    <JadeMethod name="makeRefNumbersSectXML" id="1e723725-6a55-4210-9392-300b596bac82">
        <source>makeRefNumbersSectXML( _ti : CM_TrackedItem; _parentElem : JadeXMLElement input ) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 August 2016	cnwndl1	Initial creation	TFS 2561 / 2277

*/

vars

	rootElem : JadeXMLElement;
	xmlElem : JadeXMLElement;
	workStr : String;
	
begin

	rootElem := _parentElem.addElement('ReferenceNumbers');
	
	if _ti = null then
		return;
	endif;
	
	xmlElem := rootElem.addElement('ShippingLineBooking');
	xmlElem.setText( _ti.bookingReference );
/*	
	xmlElem := rootElem.addElement('EmptyReleaseNumber');
	xmlElem.setText( null );
*/	
	if _ti.customExportEntryNumber &lt;&gt; null then
		workStr := _ti.customExportEntryNumber;
	elseif _ti.customsEntryNumber &lt;&gt; null then
		workStr := _ti.customsEntryNumber;
	endif;
	xmlElem := rootElem.addElement('CustomsAuthorityNumber');
	xmlElem.setText( workStr );
/*	
	xmlElem := rootElem.addElement('ExportExemptionCode');
	xmlElem.setText( null );
	
	xmlElem := rootElem.addElement('ExportClearanceNumber');
	xmlElem.setText( null );
	
	xmlElem := rootElem.addElement('ExportDeclarationNumber');
	xmlElem.setText( null );
	
	xmlElem := rootElem.addElement('ACEAN');
	xmlElem.setText( null );
	
	xmlElem := rootElem.addElement('ManifestReferenceNumber');
	xmlElem.setText( null );
*/	
	if _ti.customsEntryNumber &lt;&gt; null then
		workStr := _ti.customsEntryNumber;
	elseif _ti.customExportEntryNumber &lt;&gt; null then
		workStr := _ti.customExportEntryNumber;
	endif;
	xmlElem := rootElem.addElement('CustomsReleaseNumber');
	xmlElem.setText( workStr );
/*	
	xmlElem := rootElem.addElement('ConsolidatedReferenceNumber');
	xmlElem.setText( null );
	
	xmlElem := rootElem.addElement('CommercialReleaseNumbers');
	xmlElem.setText( null );
	
	xmlElem := rootElem.addElement('ShipperCargoReference');
	xmlElem.setText( null );
	
	xmlElem := rootElem.addElement('RailOrderNumber');
	xmlElem.setText( null );
*/
epilog

end;</source>
