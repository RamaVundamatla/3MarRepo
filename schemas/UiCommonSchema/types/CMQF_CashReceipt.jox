<Class name="CMQF_CashReceipt">
    <JadeMethod name="setFromAgent" id="5c144c85-3f19-4672-b30a-8235ee74ac41">
        <updating/>
        <source>setFromAgent(_agent: CMUI_ReportAgent input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14 August 2012	cnwndl1	Initial creation
21/05/2014	cnwjre1	Financial reports additional selection/filtering parameters
*/

vars
	voyage	: CM_Voyage;
begin
	inheritMethod(_agent);
	
	if _agent.isRowIncluded(ETRow_CashDebtors) then
		_agent.getSelectedCashDebtors( self.allDebtors );
	endif;
	
	if _agent.isRowIncluded(ETRow_ToDate) then
		if _agent.state = _agent.STATE_TEMPLATE_SAVE or
		   _agent.state = _agent.STATE_TEMPLATE_EDIT then
			self.setTemplateDateFields(_agent.getValueForTemplateDates(ETRow_FromDate), 
								self.startDateTplType, self.startDateTplFactor, ETRow_FromDate);
								
			self.setTemplateDateFields(_agent.getValueForTemplateDates(ETRow_ToDate), 
								self.endDateTplType, self.endDateTplFactor, ETRow_ToDate);
		else
			self.startDate := _agent.getValueByNameForDateIfVisible(ETRow_FromDate);
			self.endDate := _agent.getValueByNameForDateIfVisible(ETRow_ToDate);
		endif;
	endif; 

	if _agent.isRowIncluded(ETRow_BillOfLading) then
		self.billOfLading := _agent.getValueByNameIfVisible(ETRow_BillOfLading).String;
	endif;
	if _agent.isRowIncluded(ETRow_Number) then
		self.cashReceiptNumber := _agent.getValueByNameIfVisible(ETRow_Number).String;
	endif;
	if _agent.isRowIncluded(ETRow_CustomsEntryNumber) then
		self.customsEntryNumber := _agent.getValueByNameIfVisible(ETRow_CustomsEntryNumber).String;
	endif;
	if _agent.isRowIncluded(ETRow_CargoId) then
		self.cargoId := _agent.getValueByNameIfVisible(ETRow_CargoId).String;
	endif;
	if _agent.isRowIncluded(ETRow_Voyage) then
		self.setMyVoyage( _agent.getSelectedCellularVoyage() );
	endif;
epilog

end;</source>
        <Parameter name="_agent" type="CMUI_ReportAgent" usage="input"/>
    </JadeMethod>
</Class>
