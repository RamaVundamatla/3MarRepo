	_filter.filterObjects(jrwTrans.allVoyageSummaryObjects, _passport);
	
//	_filter.allTerminals.copy(jrwTrans.allTerminals);
	jrwTrans.setAllTerminals(_filter.allTerminals);
	jrwTrans.blockLength 			:= _filter.blockLength;
	jrwTrans.baseDate				:= _filter.baseDate;
	jrwTrans.ageType				:= _filter.ageType;
	jrwTrans.myVoyage 				:= _filter.getMyVoyage;
	jrwTrans.myOperator 			:= _filter.myOperator;
	jrwTrans.orderedByHeading1 		:= _filter.orderKey1;
	jrwTrans.orderedByHeading2 		:= _filter.orderKey2;
	
	jrwTrans.orderedByOption 		:= _filter.orderKey1;
	jrwTrans.modeDescription 		:= _filter.modeDescr;
	jrwTrans.planningStateDescr 	:= _filter.planningStateDescr;
	jrwTrans.actualProposedHeading	:= _filter.actualProposedOption;

	jrwTrans.departDateFrom	:= _filter.departDateFrom;
	jrwTrans.departDateTo	:= _filter.departDateTo;
	jrwTrans.departTimeFrom	:= _filter.departTimeFrom;
	jrwTrans.departTimeTo	:= _filter.departTimeTo;
	
	numSelected := jrwTrans.allVoyageSummaryObjects.size;

epilog
	
	return numSelected;
end;</source>
