    <JadeMethod name="initCnCntrlForJMT" id="0617c71e-6279-478e-b09b-ab861bf1cf90">
        <source>initCnCntrlForJMT();
// ---------------------------------------------------------------------------
// Created:     07 January 2008 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
23 Sep 2008	cnwkpd1	PAR #18009 - Allow ini file control of transient check

*/

vars

begin

	if app.myCnCntrl = null then
		// CnCntrl not initialised so no need to do anything
		return;
	endif;

	if self.isDevelopmentSystem() then
//		app.myCnCntrl.setLogToScreen(true);
//		app.myCnCntrl.setCheckTransientsOnShutDown(true); - removed PAR #18009
		app.myCnCntrl.setExceptionHandlerType(CnCntrl.Exception_Handler_Jade);
	endif;
	
	if app.myCnCntrl.karmaControl then
		// is a managed system so can return out
		return;
	endif;
	
	// hard wire the following so no need to rely
	// on end users to have ini file correct
	
	app.myCnCntrl.setSuppressManagementDialogs(true);
	app.myCnCntrl.setOmitBinaryVersionControlChk(true);
	app.myCnCntrl.setLogToScreen(false);
//	app.myCnCntrl.setCheckTransientsOnShutDown(false);		- removed PAR #18009
	app.myCnCntrl.setExceptionHandlerType(CnCntrl.Exception_Handler_CardSchema);
	app.myCnCntrl.setExceptionDisplayModal(false);

end;</source>
    </JadeMethod>
    <JadeMethod name="initJMTCheckPatchReleaseApp" id="0118f9a7-4fa9-4c7e-99e7-87583880e372">
        <source>initJMTCheckPatchReleaseApp(_params : HugeStringArray);
// ---------------------------------------------------------------------------
// Created:     Sept 2008 cnwrs1 par 17878
//
// Purpose:     Initialize the patch release application
//
// Parameters:  On the command line have something like
//					endJade version=7.1.5 patch=a
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 08/04/2011	cnwmh5		PAR #27347 - Add cmsEndLoad or endLoad to epilog so that if error occurs it will not leave it in beginLoad state
// 23/11/2023	navmd1		Add HugeStringArray to allow running manually via the IDE
// ---------------------------------------------------------------------------
constants
	Version		: String = 'version';
	Patch		: String = 'patch';
	
vars
	releaseClass		: Class;
	newRelController	: CnEcReleaseController;
	commandLine,
	patchNumber,
	releaseClassName,
	currVersion,
	currPatch		: String;
//	master				: CnEcReleaseHistoryMaster;
	result,
	loadStateSet 		: Boolean;
	paramNames,
	paramValues			: StringArray;
	numRows,
	idx					: Integer;
	userExitCode: Integer;
	file : File; //add application file for Jari
	fileMessage : String;
begin
	userExitCode := 63;
	app.initialize();
	create file transient;
	file.mode := File.Mode_Output;	// 4/3/16 cnwmp6 PAR 36286 unicode version
	file.fileName := app.myCnCntrl.logPath&amp;"\app_upgrade.log";
	file.usePresentationFileSystem := false;
	if file.isAvailable then
		file.purge;
	endif;
	fileMessage := "UpgradeError";

	commandLine := self.getUserCommandLine(true);
	if commandLine = null and _params.size &gt;= 1 then
		commandLine := _params.concatenate(" ");
	endif;
	
	if commandLine &lt;&gt; null then
		app.writeLog('Parsing command line (' &amp; commandLine &amp; ')', LogINFO);
		create paramNames transient;
		create paramValues transient;
		self.parseCommandLine(commandLine, paramNames, paramValues);
		
		numRows := paramNames.size;
		foreach idx in 1 to numRows do
			if paramNames[idx] = Version then
				releaseClassName := paramValues[idx];
			elseif paramNames[idx] = Patch then
				patchNumber := paramValues[idx];
			endif;
		endforeach;
	else
		app.writeLog('Commandline is null - aborting', LogINFO);
		return;
	endif;

	if releaseClassName = null or
	   patchNumber = null then
		app.writeLog('Release class or patch not found in command line - Aborting', LogINFO);
		return;
	endif;
	app.writeLog('Checking Patch Release for (' &amp; releaseClassName &amp; ' ' &amp; patchNumber &amp; ')', LogINFO);

	self.cmsBeginLoad(loadStateSet);
	sharedLock(self.myRoot);
	currVersion	:= self.myRoot.versionString;
	currPatch	:= self.myRoot.patchLevel;
	self.cmsEndLoad(loadStateSet);

	app.writeLog('Checking Patch Release - current version is (' &amp; currVersion &amp; ' ' &amp; currPatch &amp; ')', LogINFO);
	
	releaseClassName.replaceChar('.', '_');
	releaseClassName := 'PortSchema_' &amp; releaseClassName;

	releaseClass := currentSchema.getClass(releaseClassName);
	
	if releaseClass = null then
		app.writeLog('Release class (' &amp; releaseClassName &amp; ') not found - Aborting', LogINFO);
	endif;

//	self.cnEcInitializeBaseSchema();

	create newRelController transient;
	result := newRelController.checkPatchReleaseNumber(releaseClass, patchNumber, currVersion, currPatch);
	
	if result then
		userExitCode := 0;	
		fileMessage := "completedOK";
	else
		fileMessage := 'Checking Patch Release - current version is (' &amp; currVersion &amp; ' ' &amp; currPatch &amp; ')';						// TFS 52095 navmd1 30/09/21
		fileMessage := fileMessage &amp; CrLf &amp; 'Checking Patch Release for (' &amp; releaseClassName &amp; ' ' &amp; patchNumber &amp; ')';			// TFS 52095 navmd1 30/09/21
		fileMessage := fileMessage &amp; CrLf &amp; "Release error. The database is on the wrong release level to install this patch.";
	endif;
	file.writeLine(fileMessage);
epilog
	app.cmsEndLoad(loadStateSet);				// 08/04/2011 cnwmh5 #27347
	file.close;
	delete file;
	delete newRelController;
	delete paramNames;
	delete paramValues;
	beginTransaction;
	node.userExitCode := userExitCode;
	commitTransaction;
	terminate;
end;
</source>
        <Parameter name="_params" type="HugeStringArray"/>
    </JadeMethod>
    <JadeMethod name="initJMTDeployDelayApp" id="4d02cfd5-491e-4907-b4ac-25b422067b6d">
        <updating/>
        <source>initJMTDeployDelayApp(_initializeParam : Object) updating;

/*

Purpose:			Initialisation method for the internal deploy delay application.
					This application will be passed a parameter with the number of minutes to 
					delay the transition of an online deployment, and will create a 
					server\c_misc\deploy_hold.htm file with the calculated timestamp that the transition
					can start in it.  Then it will wait, checking the file every minute until
					the time in it has passed, and it will then start the server\c_misc\post_deploy_delay.bat
					command file (if it exists) before removing the server\c_misc\deploy_hold.htm and
					terminating.

Parameters:			Dummy object parameter to allow jadclient run

Return Value:		None


Date		Who		Reason
06 Aug 2015	cnwkpd1	JADE PAR #Auto deployment to BA and Implementation environments
					
*/

constants
	DelayString			= "DelayInMinutes=";
	DeployHoldName		= "deploy_hold.htm";
	PostDeployName		= "post_deploy_delay.bat";
		
vars
	deployHoldFile	: File;
	postDeployFile	: File;
	miscPath,
	line			: String;

	commandLine,
	userData		: String;
	delayInMinutes,
	pos				: Integer;
	transitionStart	: TimeStamp;
	
	args			: StringArray;
	result1,
	result2			: Integer;
	
	deleteHoldFile	: Boolean;
	
begin
	self.initialize();
	
	// Initialise JMT and CardSchema exception handling - do not pass anything back, because
	// we are a background application
	app.setPassBackExceptions(false, false);
	
	// Needs to be a background app so no lock dialogs are shown
	app.setIsBackGroundApp(true);

	commandLine := process.getCommandLine;
	pos := commandLine.toLower().pos('endjade', 1);
	if pos &lt;&gt; 0 then
		userData := commandLine[pos + 7:end];
	endif;
	
	app.writeLog('Initializing ' &amp; app.name &amp; ' with (' &amp; userData &amp; ')', LogINFO);	//25 Nov 2019	NDL	TFS 47053

    pos := userData.pos(DelayString, 1);
	if pos = 0 then
		app.writeLog('Error - "' &amp; DelayString &amp; '" not found on command line (' &amp; userData &amp; ')', LogINFO);	//25 Nov 2019	NDL	TFS 47053
		return;
	endif;
	
	pos := pos + DelayString.length;
	if pos &lt;= userData.length then
		delayInMinutes := userData.scanUntil(" ", pos).trimBlanks.Integer;
	endif;
	if delayInMinutes = null then
		app.writeLog( 'Delay in minutes is null (' &amp; userData &amp; ')', LogINFO);	//25 Nov 2019	NDL	TFS 47053
		return;
	endif;
	app.writeLog('Delay in minutes = ' &amp; delayInMinutes.String, LogINFO);	//25 Nov 2019	NDL	TFS 47053

	miscPath := app.cnGetServerMiscPath &amp; "\";
	
	// Calculate time for transition to start
	transitionStart := app.actualTimeServer().addMinutes(delayInMinutes);
	
	app.writeLog('Setting transition start to ' &amp; transitionStart.asStringJMT(), LogINFO);	//25 Nov 2019	NDL	TFS 47053
	
	// Create deploy_hold.htm file to signal JSM deployment engine to wait
	create deployHoldFile transient;
	deployHoldFile.usePresentationFileSystem := false;
	deployHoldFile.openOutput(miscPath &amp; DeployHoldName);
	deployHoldFile.writeLine(transitionStart.asStringJMT());
	deployHoldFile.close();
	deployHoldFile.kind := File.Kind_Unknown_Text; // 3/3/16  cnwns1 PAR 36286 unicode version
	deployHoldFile.mode := File.Mode_Input;
	
	app.writeLog('File ' &amp; deployHoldFile.fileName &amp; ' created, waiting for transition time', LogINFO);	//25 Nov 2019	NDL	TFS 47053
	
	// Now go into a waiting loop before removing the deploy_hold file
	while true do
		// Check the file every minute
		app.doWindowEvents(60000);
		
		// Check that the file hasn't been removed
		if not deployHoldFile.isAvailable() then
			app.writeLog('File ' &amp; deployHoldFile.fileName &amp; ' has been removed by another process, exiting', LogINFO);	//25 Nov 2019	NDL	TFS 47053
			break;
		endif;
		
		// Open the file and read the timestamp
		deployHoldFile.open();
		deployHoldFile.seek(0);
		if deployHoldFile.endOfFile() then
			app.writeLog('File ' &amp; deployHoldFile.fileName &amp; ' is empty, exiting', LogINFO);	//25 Nov 2019	NDL	TFS 47053
			deployHoldFile.close();
			break;
		endif;
		
		line := deployHoldFile.readLine();
		deployHoldFile.close();

		transitionStart := line.TimeStamp;
		
		if not transitionStart.isValid then
			app.writeLog('Timestamp in file ' &amp; deployHoldFile.fileName &amp; ' is invalid, exiting', LogINFO);	//25 Nov 2019	NDL	TFS 47053
			break;
		endif;
		
		if app.actualTimeServer() &gt; transitionStart then
			app.writeLog('Timestamp (' &amp; transitionStart.asStringJMT() &amp; ') in file ' &amp; deployHoldFile.fileName &amp; ' has passed, exiting', LogINFO);	//25 Nov 2019	NDL	TFS 47053
			break;
		endif;
		
		app.writeLog('Timestamp (' &amp; transitionStart.asStringJMT() &amp; ') in file ' &amp; deployHoldFile.fileName &amp; ' has not yet been reached, waiting...', LogINFO);	//25 Nov 2019	NDL	TFS 47053

	endwhile;

	// Now check for presence post deploy file and execute it
	create postDeployFile transient;
	postDeployFile.usePresentationFileSystem := false;
	postDeployFile.fileName := miscPath &amp; PostDeployName;
	
	if postDeployFile.isAvailable() then
		// Start post_deploy_delay.bat file
		app.writeLog('Starting ' &amp; postDeployFile.fileName &amp; ' ...', LogINFO);	//25 Nov 2019	NDL	TFS 47053
		
		create args transient;
		result1 := node.createExternalProcess('.',
											  postDeployFile.fileName,
											  args,
											  null,
											  false,
											  true,
											  result2);
		
		app.writeLog('Finished ' &amp; postDeployFile.fileName &amp; ' result1=' &amp; result1.String &amp; ' result2=' &amp; result2.String, LogINFO);	//25 Nov 2019	NDL	TFS 47053

	else
		app.writeLog(postDeployFile.fileName &amp; ' does not exist', LogINFO);	//25 Nov 2019	NDL	TFS 47053
	
	endif;							   
	
	// Finally delete the deploy_hold.htm file
	if deployHoldFile.isAvailable() then
		app.writeLog('Deleting ' &amp; deployHoldFile.fileName, LogINFO);	//25 Nov 2019	NDL	TFS 47053
		deployHoldFile.purge();
	endif;
		
epilog
	delete deployHoldFile;
	delete postDeployFile;
	delete args;
	terminate;
	
end;</source>
        <Parameter name="_initializeParam" type="Object"/>
    </JadeMethod>
    <JadeMethod name="initJMTLoadEntTable" id="7654255a-58e7-43f1-ae2d-fc3b89f89663">
        <source>initJMTLoadEntTable();

vars
	userExitCode : Integer;
	js : JadeScript;
	portSchemaRelease : PortSchemaRelease;
	objArray : ObjectArray;
	file : File; //add application file for Jari
	fileMessage : String;
begin
	userExitCode := 63;
	app.initialize();
	create file transient;
	file.mode := File.Mode_Output;	// 4/3/16 cnwmp6 PAR 36286 unicode version
	file.fileName := app.myCnCntrl.logPath&amp;"\app_upgrade.log";
	if file.isAvailable then
		file.purge;
	endif;
	fileMessage := "UpgradeError";
	///////////////////////////////////////
	create objArray transient;
	PortSchemaRelease.allInstances(objArray, 0, true);	
	portSchemaRelease := objArray[1].PortSchemaRelease;
//	app.myRoot.loadErrMsgsFromGlbConstantsOLD();
//	app.myRoot.createQueryDefinitionObjects();
	portSchemaRelease.sendMsg(PortSchemaRelease::loadEntTableDetails.name);
//	portSchemaRelease.sendMsg("loadGraphics");
// rs 24/11/2003 this fails in unlicensed schemas so cant be done in the conversion
//	portSchemaRelease.sendMsg("resetRootSecurityRoles");
//	portSchemaRelease.sendMsg("loadToolbarIcons");
//	portSchemaRelease.sendMsg("resetAllJMTMenus");
//	portSchemaRelease.sendMsg("resetCargoTypes");
//	portSchemaRelease.sendMsg("resetHandlingTypes");
//	portSchemaRelease.sendMsg("resetAuditedClassProperties");

	app.writeStatement( "end Load Entable Def");	
	userExitCode := 0;	
	///////////////////////////////////////
	fileMessage := "completedOK";
	file.writeLine(fileMessage);
epilog
	if file &lt;&gt; null then
		file.close;
		delete file;
	endif;
	delete js;
	delete objArray;		// PAR #27874 
	beginTransaction;
	node.userExitCode := userExitCode;
	commitTransaction;
	terminate;

end;</source>
    </JadeMethod>
    <JadeMethod name="initJMTLoadTranslatableText" id="22d02413-14ea-4880-8c45-245c75193bb7">
        <source>initJMTLoadTranslatableText();
