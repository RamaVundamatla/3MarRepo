    <JadeMethod name="populateTblAreas" id="c63ab2c1-5f64-41ee-879b-2f91ae2a0454">
        <source>populateTblAreas() protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 Apr 2014	cnwndl1	Initial creation	Par 33995
25 Jun 2020	jlgdap1	TFS 49453 APA Satellite View Screen for Flexible Terminal Areas
01 Jun 2022 		Bug 53591: CUX - 75768 Error when trying to create a "Trailer Area"
08 Sep 2022	jlika1	TFS 54699 - CUX - MAFI Handling Enhancements - MAFI Heap Terminal Area
*/

vars

	iter : Iterator;
	ta : CM_TerminalArea;
	
begin

	self.tblAreas.rows := 1;
	
	// navcs2 	01/06/2022 53591
	iter := self.myTerminal.allTerminalAreas.createIterator;
	while iter.next( ta ) do
		if ta.type = TA_TYPE_BLOCK_STACK
		or ta.type = TA_TYPE_BULK
		or ta.type = TA_TYPE_CONT_PACK_REPACK
		or ta.type = TA_TYPE_COU_CRIB_PACK_UNPACK
		or ta.type = TA_TYPE_COU_STORE_AREA
		or ta.type = TA_TYPE_DAIRY
		or ta.type = TA_TYPE_DEPOT_LCL
		or ta.type = TA_TYPE_FORK_LIFT_STACK
		or ta.type = TA_TYPE_FUMIGATION_AREA
		or ta.type = TA_TYPE_GENERATOR_STORE_AREA
		or ta.type = TA_TYPE_HIDE
		or ta.type = TA_TYPE_IRREGULAR_BLOCK_AREA
		or ta.type = TA_TYPE_PTI
		or ta.type = TA_TYPE_REPAIR
		or ta.type = TA_TYPE_RMG
		or ta.type = TA_TYPE_RORO_LANE_AREA
		or ta.type = TA_TYPE_RTG
		or ta.type = TA_TYPE_STRADDLE_STACK
		or ta.type = TA_TYPE_SUBBLOCK_STACK
		or ta.type = TA_TYPE_WASH_AREA
		or ta.type = TA_TYPE_YARD_INTERCHANGE
		or ta.type = TA_TYPE_GEN_CARGO_ALLOC_ROW		// TFS 49453
		or ta.type = TA_TYPE_MAFI
		then
			self.addTerminalAreaToTable( ta );
		endif;
		
	endwhile;

	

epilog

	delete iter;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="refreshTableHighlighting" id="0a529bf7-42f3-4508-95b8-a018efc93eab">
        <source>refreshTableHighlighting() protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 Apr 2014	cnwndl1	Initial creation	Par 33995
25 Jun 2020	jlgdap1	TFS 49453 ASPA Satellite View Screen for Flexible Terminal Areas
*/

vars

	index : Integer;
	obj : Object;
	ta : CM_TerminalArea;
	gridObject : CM_GridObject;
	lc : CM_LocationsController;
	taIndex : Integer;
	subAreaIndex : Integer;
	jadeTableRow : JadeTableRow;
	defaultColour : Integer;
	directSelected : Boolean;

begin

	defaultColour := self.tblAreas.backColor;
	foreach index in self.tblAreas.fixedRows + 1 to self.tblAreas.rows do
		jadeTableRow := self.tblAreas.accessRow( index );
		jadeTableRow.backColor := defaultColour;
	endforeach;

	foreach index in self.tblAreas.fixedRows + 1 to self.tblAreas.rows do
		jadeTableRow := self.tblAreas.accessRow( index );
		obj :=  jadeTableRow.itemObject;
		if obj = null then
			continue;
		endif;
		
		if obj.isKindOf( CM_TerminalArea ) then
			ta := obj.CM_TerminalArea;
			directSelected := self.tblAreas.accessCell( index, Col_Incl_TA ).text = Item_Selected;
			taIndex := index;
			self.tblAreas.accessCell( taIndex, Col_Incl_TA).backColor := defaultColour;
			self.tblAreas.accessCell( taIndex, Col_Incl_TA).enabled := true;
			if not jadeTableRow.enabled then
				self.tblAreas.setCellText( index, Col_Expand_TA, Exp_Hide);
				jadeTableRow.backColor := Colour_IncludedInAnother;
				continue;
			endif;
			if directSelected then
				self.tblAreas.setCellText( index, Col_Expand_TA, Exp_Hide);
				jadeTableRow.backColor := Colour_SelectedInCurrent;
			endif;
			continue;
			
		elseif obj.isKindOf( CM_GridObject ) then
			gridObject := obj.CM_GridObject;
			directSelected := self.tblAreas.accessCell( index, Col_Incl_SubArea ).text = Item_Selected;
			subAreaIndex := index;
			self.tblAreas.accessCell( subAreaIndex, Col_Incl_SubArea).backColor := defaultColour;
			self.tblAreas.accessCell( subAreaIndex, Col_Incl_SubArea).enabled := true;
			if not jadeTableRow.enabled then
				self.tblAreas.setCellText( index, Col_Expand_SubArea, Exp_Hide);
				jadeTableRow.backColor := Colour_IncludedInAnother;
				self.tblAreas.accessCell( taIndex, Col_Incl_TA).enabled := false;
				self.tblAreas.accessCell( taIndex, Col_Incl_TA).backColor := Colour_IncludedInAnother;
				continue;
			endif;
			if directSelected then
				self.tblAreas.setCellText( index, Col_Expand_SubArea, Exp_Hide);
				jadeTableRow.backColor := Colour_SelectedInCurrent;
				self.tblAreas.accessRow( taIndex ).backColor := Colour_ChildItemsIncluded;
			endif;
			continue;
			
		elseif obj.isKindOf( CM_LocationsController ) then
			if subAreaIndex &lt; taIndex then
				subAreaIndex := 0;
			endif;
			lc := obj.CM_LocationsController;
			//if lc.isKindOf( CM_RoRoController ) then													// TFS 49453
			if lc.isKindOf( CM_RoRoController ) or lc.isKindOf( CM_GeneralCargoAllocGroup ) then		// TFS 49453
				directSelected := self.tblAreas.accessCell( index, Col_Incl_SubArea ).text = Item_Selected;
			else
				directSelected := self.tblAreas.accessCell( index, Col_Incl_Location ).text = Item_Selected;
			endif;
			//if not jadeTableRow.enabled and lc.isInAnyLOBExcluding(self.myCurrentWorkArea) then
			if not jadeTableRow.enabled and  self.locationAlreadyUsed( lc ) then
				jadeTableRow.backColor := Colour_IncludedInAnother;
				if subAreaIndex &gt; 0 then
					self.tblAreas.accessCell( subAreaIndex, Col_Incl_SubArea).enabled := false;
					self.tblAreas.accessCell( subAreaIndex, Col_Incl_SubArea).backColor := Colour_IncludedInAnother;
				endif;
				self.tblAreas.accessCell( taIndex, Col_Incl_TA).enabled := false;
				self.tblAreas.accessCell( taIndex, Col_Incl_TA).backColor := Colour_IncludedInAnother;
				
			elseif directSelected then
				jadeTableRow.backColor := Colour_SelectedInCurrent;
				self.tblAreas.accessRow( taIndex ).backColor := Colour_ChildItemsIncluded;
				if subAreaIndex &gt; 0 then
					if self.tblAreas.accessRow( subAreaIndex ).backColor &lt;&gt; Colour_SelectedInCurrent then
						self.tblAreas.accessCell( subAreaIndex, Col_Incl_SubArea).enabled := false;
						self.tblAreas.accessCell( subAreaIndex, Col_Incl_SubArea).backColor := Colour_ChildItemsIncluded;
					endif;
				endif;
				if self.tblAreas.accessRow( taIndex ).backColor &lt;&gt; Colour_SelectedInCurrent then
					self.tblAreas.accessCell( taIndex, Col_Incl_TA).enabled := false;
					self.tblAreas.accessCell( taIndex, Col_Incl_TA).backColor := Colour_ChildItemsIncluded;
				endif;
				
			elseif self.allSelectedObjects.includes(lc) then
				jadeTableRow.enabled := false;
				jadeTableRow.backColor := Colour_IncludedInCurrent;
				if subAreaIndex &gt; 0 then
					if self.tblAreas.accessRow( subAreaIndex ).backColor &lt;&gt; Colour_SelectedInCurrent then
						self.tblAreas.accessCell( subAreaIndex, Col_Incl_SubArea).enabled := false;
						self.tblAreas.accessCell( subAreaIndex, Col_Incl_SubArea).backColor := Colour_ChildItemsIncluded;
					endif;
				endif;
				if self.tblAreas.accessRow( taIndex ).backColor &lt;&gt; Colour_SelectedInCurrent then
					self.tblAreas.accessCell( taIndex, Col_Incl_TA).enabled := false;
					self.tblAreas.accessCell( taIndex, Col_Incl_TA).backColor := Colour_ChildItemsIncluded;
				endif;
				
			else
				jadeTableRow.enabled := true;
				
			endif;
			continue;
			
		endif;
		
	endforeach; 

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="selectGridObject" id="9a6e99e0-ad68-4195-8983-b7f3d4d3e70c">
        <source>selectGridObject( _gridObject : CM_GridObject; _selected : Boolean; _refresh : Boolean) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 April 2014	cnwndl1	Initial creation	Par 33995

*/

vars

	index : Integer;
	obj : Object;
	lc : CM_LocationsController;
	locationControllerArray : ObjectArray;

begin

	if _selected then 
		self.allSelectedObjects.addNoDuplicates( _gridObject, false );
	else
		if self.allSelectedObjects.includes( _gridObject ) then
			self.allSelectedObjects.remove( _gridObject );
		endif;
	endif;
	
	create locationControllerArray transient;
	_gridObject.getAllLocationsControllers( locationControllerArray, false );
	
	if locationControllerArray.size &gt; 1 then
		foreach obj in locationControllerArray do
			lc := obj.CM_LocationsController;
			self.selectLocation( lc, _selected, false );
		endforeach;
	endif;
	
	if _refresh then
		self.refreshTableHighlighting();
	endif;

epilog

	delete locationControllerArray;

end;</source>
        <access>protected</access>
        <Parameter name="_gridObject" type="CM_GridObject"/>
        <Parameter name="_selected" type="Boolean"/>
        <Parameter name="_refresh" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="selectLocation" id="e490de5d-85dd-4d02-8e48-02c140e86cfa">
        <source>selectLocation( _lc : CM_LocationsController; _selected : Boolean; _refresh : Boolean ) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 April 2014	cnwndl1	Initial creation	Par 33995

*/

vars

	index : Integer;
	obj : Object;

begin

	if _selected then 
		self.allSelectedObjects.addNoDuplicates( _lc, false );
		
	else
		if self.allSelectedObjects.includes( _lc ) then
			self.allSelectedObjects.remove( _lc );
		endif;
		
	endif;
	
	if _refresh then
		self.refreshTableHighlighting();
	endif;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_lc" type="CM_LocationsController"/>
        <Parameter name="_selected" type="Boolean"/>
        <Parameter name="_refresh" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="selectTerminalArea" id="f2b61fa0-d8b8-4502-a3ed-6cb5011efc50">
        <source>selectTerminalArea( _ta : CM_TerminalArea; _selected : Boolean) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 April 2014	cnwndl1	Initial creation	Par 33995

*/

vars

	index : Integer;
	obj : Object;
	gridArea : CM_GridArea;
	iter : Iterator;
	gridObject : CM_GridObject;

begin

	if _selected then 
		self.allSelectedObjects.addNoDuplicates( _ta, false );
	else
		if self.allSelectedObjects.includes( _ta ) then
			self.allSelectedObjects.remove( _ta );
		endif;
	endif;
	
	// If we are selecting or unselecting the whole area, we don't need to keep the children..
	if _ta.isKindOf( CM_GridArea ) then
		gridArea := _ta.CM_GridArea;
		iter := gridArea.allGridColumns.createIterator;
		while iter.next( gridObject ) do
			self.selectGridObject( gridObject, false, false );
		endwhile;
		delete iter;
		iter := gridArea.allGridRows.createIterator;
		while iter.next( gridObject ) do
			self.selectGridObject( gridObject, false, false );
		endwhile;
		delete iter;
	endif;
	
	self.refreshTableHighlighting();

epilog

	delete iter;

end;</source>
        <access>protected</access>
        <Parameter name="_ta" type="CM_TerminalArea"/>
        <Parameter name="_selected" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setMyCurrentWorkArea" id="66b5277e-6abf-482f-bf77-4a1dc21e7aac">
        <updating/>
        <source>setMyCurrentWorkArea(_labourWorkArea: CM_WorkArea) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 April 2014	cnwndl1	Initial creation	Par 33995

*/

vars

begin

	self.myCurrentWorkArea := _labourWorkArea;
	self.allSelectedObjects.clear();
	
	if _labourWorkArea = null then
		
	else
		if not _labourWorkArea.allTerminalAreas.isEmpty then
			_labourWorkArea.allTerminalAreas.copy( self.allSelectedObjects );
		endif;
		if not _labourWorkArea.allGridObjects.isEmpty then
			_labourWorkArea.allGridObjects.copy( self.allSelectedObjects );
		endif;
		if not _labourWorkArea.allLocationsControllers.isEmpty then
			_labourWorkArea.allLocationsControllers.copy( self.allSelectedObjects );
		endif;
	endif;

epilog

end;</source>
        <Parameter name="_labourWorkArea" type="CM_WorkArea"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="2e818dcd-79b9-4000-b753-494195c8be29">
        <updating/>
        <source>setupForm() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 April 2014	cnwndl1	Initial creation	Par 33995

*/

vars

	userWindow	: CM_UserWindow;

begin

	create self.myAssistant as SOP_Assistant;
	self.myAssistant.myTerminal := self.myTerminal;

	inheritMethod();
	
	self.initTblAreas();
	self.populateTblAreas();
	self.showSelections();
	
	if app.getMyUser &lt;&gt; null then
		userWindow := self.myUserWindow;
		if userWindow = null then
			userWindow := app.getUserWindow(self.name, false);
		endif;
		if userWindow &lt;&gt; null then
			self.initFromUserWindow(userWindow);
		endif;
	endif;

epilog

	app.mousePointer := Window.MousePointer_Default;

end;</source>
    </JadeMethod>
    <JadeMethod name="showSelections" id="4d27e760-3eb1-4a53-8300-9583101d9334">
        <source>showSelections() protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 Apr 2014	cnwndl1	Initial creation	Par 33995
25 Jun 2020	jlgdap1	TFS 49453 ASPA Satellite View Screen for Flexible Terminal Areas
*/

vars

	localCopy : ObjectSet;
	index : Integer;
	obj : Object;

begin

	if self.myCurrentWorkArea = null then
		self.txtCode.text := null;
		self.txtDescription.text := null;
		self.chkAvailable.value := false;
	else
		self.txtCode.text := self.myCurrentWorkArea.code;
		self.txtDescription.text := self.myCurrentWorkArea.description;
		self.chkAvailable.value := self.myCurrentWorkArea.notAvailableForEntry;
	endif;

	if not self.allSelectedObjects.isEmpty then
	
		create localCopy transient;
		self.allSelectedObjects.copy( localCopy );
	
		foreach index in self.tblAreas.fixedRows + 1 to self.tblAreas.rows do
			obj := self.tblAreas.accessRow( index ).itemObject;
			if obj = null then
				continue;
			endif;
			if not localCopy.includes( obj ) then
				continue;
			else
				localCopy.remove( obj );
			endif;
			if obj.isKindOf( CM_TerminalArea ) then
				self.tblAreas.setCellText( index, Col_Incl_TA, Item_Selected);
				self.tblAreas.setCellText( index, Col_Expand_TA, Exp_Hide);
				
			elseif obj.isKindOf( CM_GridObject ) then
				self.tblAreas.setCellText( index, Col_Incl_SubArea, Item_Selected);
				self.tblAreas.setCellText( index, Col_Expand_SubArea, Exp_Hide);
				
			elseif obj.isKindOf( CM_LocationsController ) then
			
				//if obj.isKindOf( CM_RoRoController) then												// TFS 49453
				if obj.isKindOf( CM_RoRoController) or obj.isKindOf(CM_GeneralCargoAllocGroup) then		// TFS 49453
					self.tblAreas.setCellText( index, Col_Incl_SubArea, Item_Selected);
				else
					self.tblAreas.setCellText( index, Col_Incl_Location, Item_Selected);
				endif;
				
			endif;
			
			if localCopy.isEmpty then
				break;
			endif;
			
		endforeach;
		
	endif;
	
	self.refreshTableHighlighting;

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="tblAreas_contextMenu" id="6f2b35ff-871f-4b1b-92b3-1574863b393f">
        <controlMethod name="Table::contextMenu"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblAreas_contextMenu(table: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 April 2014	cnwndl1	Initial creation	Par 33995

*/

vars

	xLeft 	: Real;
	yTop	: Real;

begin

	conwin.windowToScreen(xLeft, yTop);
	self.screenToWindow(xLeft, yTop);   // convert x, y relative to form
	
	xLeft := xLeft + ( self.clientWidth / 3 );
	yTop := yTop + ( self.clientHeight / 3 );

	self.popupMenu(self.mnuContext, xLeft.Integer, yTop.Integer);

	return true;

epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="tblAreas_mouseUp" id="b31b060c-a5cb-4a1c-ab01-7bcbfbc62326">
        <controlMethod name="CM_DataTable::mouseUp"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblAreas_mouseUp(table: Table input; button: Integer; shift: Integer; x: Real; y: Real) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 Apr 2014	cnwndl1	Initial creation
25 Jun 2020	TFS 49453 ASPA Satellite View Screen for Flexible Terminal Areas
*/

vars

	row : Integer;
	column : Integer;
	obj : Object;
	str : String;

begin

	row := self.tblAreas.row;
	column := self.tblAreas.column;

	if row &lt;= self.tblAreas.fixedRows or row &gt; self.tblAreas.rows then
		return;
	endif;
	
	obj := self.tblAreas.accessRow(row).itemObject;
	if obj = null then
		return;
	endif;
	
	str := self.tblAreas.accessCell(row,column).text.trimBlanks; 
	
	if column = Col_Incl_TA and obj.isKindOf(CM_TerminalArea) then
		self.clickTerminalAreaInclude(row);
	elseif column = Col_Expand_TA and str &lt;&gt; null then
		self.clickTerminalAreaExpand(row);
		if self.tblAreas.accessCell( row, Col_Expand_TA).text = Exp_Contract then
			self.tblAreas.topRow := row;
		endif;
	elseif column = Col_Incl_SubArea and obj.isKindOf(CM_GridObject) then
		self.clickSubAreaInclude(row);
	elseif column = Col_Incl_SubArea and obj.isKindOf(CM_RoRoController) then
		self.clickSubAreaInclude(row);
	elseif column = Col_Incl_SubArea and obj.isKindOf(CM_GeneralCargoAllocGroup) then	// TFS 49453
		self.clickSubAreaInclude(row);													// TFS 49453
	elseif column = Col_Expand_SubArea and str &lt;&gt; null then
		self.clickSubAreaExpand(row);
	elseif column = Col_Incl_Location and obj.isKindOf(CM_LocationsController) then
		self.clickSubSubAreaInclude(row);
	endif;

epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="1d76101d-f289-4137-9cdb-ea86209eff18">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 January 2015.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0020216, locale);
	btnCancel.translateCaption(Xlat_0019617, locale);
	btnSave.translateCaption(Xlat_0019618, locale);
	chkAvailable.translateCaption(Xlat_0019619, locale);
	lblCode.translateCaption(Xlat_0019620, locale);
	lblDescription.translateCaption(Xlat_0019621, locale);
	mnuContext.translateCaption(Xlat_0019622, locale);
	mnuLegend.translateCaption(Xlat_0019623, locale);
end;</source>
    </JadeMethod>
</GUIClass>
