    <JadeMethod name="erase" id="42bf0e1a-2868-4283-bc06-88f4fe47c08f">
        <updating/>
        <source>erase(_eraseLevel: Integer) updating;

// Created by cnwdvb1 on 11 September 2007

vars

begin

	self.myTerminalArea.causeEvent(self.myTerminalArea.myTerminal.getTerminalEvent(Event_TALocation_Delete), false, self);
	inheritMethod(_eraseLevel);

end;</source>
        <Parameter name="_eraseLevel" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getAuditTALocationDetails" id="9efab64a-d78b-4b12-9799-5905eb3bd389">
        <source>getAuditTALocationDetails():String;
// ---------------------------------------------------------------------------
// Created:     03 March 2011 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	str	:String;
begin
	str := self.myISOTypeGroup.code;

	str := str &amp; ", " &amp; self.description;
	
	return str;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getLocations" id="04ba01bf-1239-43e9-bcca-a3b7185a4ad4">
        <source>getLocations(_coll :CM_LCSet input);
// ---------------------------------------------------------------------------
// Created:     08 March 2011 by cnwcs5 CCMS CPL 2017/PAR 27126
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	ddl	:CM_DoorDirectionLocation;
begin
	foreach ddl in self.allDoorDirectionLocations do
		_coll.addNoDuplicates (ddl.myLocationsController, false);
	endforeach;
epilog

end;</source>
        <Parameter name="_coll" type="CM_LCSet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="1f1cf5b7-3827-4c73-9983-2dbb5ec6fa46">
        <updating/>
        <source>setForCreate(_pxyDoorDirectionRule : CM_DoorDirectionRule; _lcSet : CM_LCSet input) updating;

// Created by cnwdvb1 on 16 August 2007

vars

	lc 		: CM_LocationsController;
	dcLc	: CM_DoorDirectionLocation;

begin

	self.description			:= _pxyDoorDirectionRule.description;
	self.doorDirectionWording	:= _pxyDoorDirectionRule.doorDirectionWording;
	self.colour					:= _pxyDoorDirectionRule.colour;
	self.myISOTypeGroup			:= _pxyDoorDirectionRule.myISOTypeGroup;
	self.myTerminalArea			:= _pxyDoorDirectionRule.myTerminalArea;
	
	foreach lc in _lcSet where lc.myTerminalArea = self.myTerminalArea do
		create dcLc persistent;
		dcLc.setForCreate(self.myISOTypeGroup, lc, self);
	endforeach;

end;</source>
        <Parameter name="_pxyDoorDirectionRule" type="CM_DoorDirectionRule"/>
        <Parameter name="_lcSet" type="CM_LCSet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setForProxy" id="ff782e1e-ed0e-44db-9a44-7fcbe16d755c">
        <updating/>
        <source>setForProxy(	_terminalArea			: CM_TerminalArea;
				_doorDirectionWording,
				_description			: String;
				_colour					: Integer;
				_isoTypeGroup			: CM_ISOTypeGroup) updating;

// Created by cnwdvb1 on 16 August 2007

vars

	ddLocation	: CM_DoorDirectionLocation;
	lc			: CM_LocationsController;

begin

	self.doorDirectionWording	:= _doorDirectionWording;
	self.description 			:= _description;
	self.colour		 			:= _colour;
	self.myISOTypeGroup			:= _isoTypeGroup;
	self.myTerminalArea			:= _terminalArea;

end;</source>
        <Parameter name="_terminalArea" type="CM_TerminalArea"/>
        <Parameter name="_doorDirectionWording" type="String"/>
        <Parameter name="_description" type="String"/>
        <Parameter name="_colour" type="Integer"/>
        <Parameter name="_isoTypeGroup" type="CM_ISOTypeGroup"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="272c0bd4-5d47-403c-9f65-a93ab301e794">
        <updating/>
        <source>setForUpdate(_pxyDoorDirectionRule : CM_DoorDirectionRule; _lcSet : CM_LCSet input) updating;

// Created by cnwdvb1 on 16 August 2007

vars

begin

	self.allDoorDirectionLocations.purge();
	self.setForCreate(_pxyDoorDirectionRule, _lcSet);

end;</source>
        <Parameter name="_pxyDoorDirectionRule" type="CM_DoorDirectionRule"/>
        <Parameter name="_lcSet" type="CM_LCSet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validate" id="f1ed9889-1473-4b00-bf5d-5a3c295094e7">
        <source>validate(_lcSet : CM_LCSet input);

// Created by cnwdvb1 on 16 August 2007
// 31/01/2017 cnwrh7        TFS3212    Hazardous location shows sub area colours on the Location Maintenance screen

vars

	lc 			: CM_LocationsController;
	ddLcReal,
	ddLc		: CM_DoorDirectionLocation;
	realRule,
	otherRule	: CM_DoorDirectionRule;

begin

	if self.description = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Description', null, null);
		//app.raiseCMException(Input_required_field_Desc, null, null); // cnwdb2	PAR 35364				//-TFS3212
		app.raiseCMException(Input_required_field_code, null, null); // cnwdb2	PAR 35364						//+TFS3212
	endif;
	
	if self.doorDirectionWording = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Door Direction Wording', null, null);
		app.raiseCMException(Input_required_field_drDrtWrd, null, null); // cnwdb2	PAR 35364

	endif;
	
	if self.myTerminalArea = null then
		app.raiseCMException3(UNEXPECTED_PROGRAM_ERROR, class.name, method.name, 'Terminal Area is null', null, null);
	endif;
	
	if self.myISOTypeGroup = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'ISO Type Group', null, null);
		app.raiseCMException(Input_required_field_isoTypGrp, null, null); // cnwdb2	PAR 35364
		return;
	endif;
	
	realRule := self.pxyGetRealObject();
	
	foreach otherRule in self.myTerminalArea.allDoorDirectionRules where otherRule &lt;&gt; realRule do
		if otherRule.myISOTypeGroup = self.myISOTypeGroup and otherRule.doorDirectionWording = self.doorDirectionWording then
			// Warning telling the user that they are entering two rules for the same area with same iso group but different locations.
			app.raiseCMException1(WARN_DoorDirectionRuleDuplicat, self.doorDirectionWording, null, self);
		endif;
	endforeach;

	if _lcSet.isEmpty then		// exception DoorDirectionRule should have at least one location.
			app.raiseCMException(WARN_DoorDirectionRuleLocation, null, self);	endif;
	
	foreach lc in _lcSet where lc.myTerminalArea = self.myTerminalArea do
		ddLc := lc.allDoorDirectionLocations[self.myISOTypeGroup];
		if ddLc &lt;&gt; null and (realRule = null or (realRule &lt;&gt; null and not realRule.allDoorDirectionLocations.includes(ddLc))) then
			// "You have specified a location which over laps with another rule which has specified the same iso group type. Please reselect."
			app.raiseCMException1(WARN_DoorDirectionRuleOverLaps, self.myISOTypeGroup.code, null, null);
		endif;
	endforeach;

end;</source>
        <Parameter name="_lcSet" type="CM_LCSet" usage="input"/>
    </JadeMethod>
