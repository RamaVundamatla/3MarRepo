    <JadeMethod name="getAuditText" id="982e891e-d313-4eae-9444-224152438eca">
        <source>getAuditText(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 December 2022 navhl20	ChangeRequest 53424: MTN - MOB - Input Remarks - Jade

*/

vars
	txt,
	tmpStr: String;
begin
	txt[10000] 	:= '*';
	txt 		:= null;
	txt 		:= inheritMethod();

	tmpStr := null;
	tmpStr := app.getDefTextIntToStr(self.context);
	txt := txt &amp; 'Context' &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;
	
	return txt;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="72881ca9-7218-4d6e-9cc7-71653697605d">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
07 October 2022	navvt20	ChangeRequest 53424: MTN - MOB - Input Remarks - Jade

*/

vars

begin
	if _attrName = ETRow_Context then
		return app.getDefTextIntToStr(self.context);
	endif;
	return inheritMethod(_attrName, _short);
epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
