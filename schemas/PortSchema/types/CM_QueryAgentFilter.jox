        <source>qryOrganisationAccess(_filter : CMQF_FilterReports input; _passport : CM_Passport) : Integer updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14 August 2012	cnwndl1	Initial creation	Par 29968

*/

vars

	numSelected : Integer;
	jrwTrans : CM_JRWTrackedItems;
	filter : CMQF_OrganisationAccess;
	
begin

	on CM_BreakOutException do self.xHandlerBreakOut(exception);
	
	filter := _filter.CMQF_OrganisationAccess;
	jrwTrans := self.createJRWTransient(CM_JRWTrackedItems).CM_JRWTrackedItems;
	
	_filter.filterObjects(jrwTrans.allOrganisationCargo, _passport);
	
	jrwTrans.qryStartDate	:= _filter.startDate;
	jrwTrans.qryEndDate 	:= _filter.endDate;
	if filter.allQrySites.size &gt; 0 then
		jrwTrans.qrySiteStateString := app.siteEnumToString(filter.allQrySites[1]);
	endif;
	jrwTrans.myVoyage := filter.getMyVoyage;
	
	numSelected := jrwTrans.allOrganisationCargo.size; 

epilog
	
	return numSelected;
end;</source>
