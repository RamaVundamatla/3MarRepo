    <JadeMethod name="doMnuEditQuery" id="cc1ffa14-0cd2-463d-af52-57d8c5bb14ff">
        <source>doMnuEditQuery( menuItem : MenuItem );

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
31 October 2011	cnwndl1	Initial creation	Par 28466

*/

vars

	userQuery : CM_MenuUserQuery;
	theSelector : CMUI_Selector;

begin

	userQuery := menuItem.userObject.CM_MenuUserQuery;
	
	theSelector := app.getSelectorForm(self, self.myMasterMenuAction);	
