<Class name="CM_RTDeviceHandHeld">
    <JadeMethod name="importPLXMLReference" id="edb9b686-b9eb-4249-9049-464eaea20703">
        <source>importPLXMLReference(_name, _theCode, _referencesBlock: String): Object;

vars

begin
	if _name = CM_RTDeviceHandHeld::myRadioTelemetry.name then
		return app.getMyTerminalDO_NOT_USE().radioTelemetry;
	else
		return null;
	endif;
end;</source>
        <Parameter name="_name" type="String"/>
        <Parameter name="_theCode" type="String"/>
        <Parameter name="_referencesBlock" type="String"/>
        <ReturnType type="Object"/>
    </JadeMethod>
</Class>
