    <JadeMethod name="doTblDataUserNoteTI" id="f06fce3f-5ff7-4845-91be-dbec3882f00c">
        <updating/>
        <source>doTblDataUserNoteTI(_ti : CM_TrackedItem; _event : Integer) updating;
// ---------------------------------------------------------------------------
// Created:		12 July 2005 By Andrew Bishop cnwab1
//
// Purpose:		 // PAR 10328 AKB2005JUL
//
// ---------------------------------------------------------------------------

vars
	row : Integer;
	str : String;
	anLC : CM_LocationsController;
begin
	if _ti = null then
		return;
	endif;

	 // PAR 10328 AKB2005JUL
	if _event = EVENT_TI_MOVE_FROM_LOCATION then
		if self.tblData.findObjectInRow(_ti, row) then
			self.tblData.removeItem(row);
		endif;
		if row &gt; self.tblData.fixedRows then
			if row &gt; self.tblData.rows then
				row := self.tblData.rows;
			endif;
			self.myCurrentObject := self.tblData.accessRow(row).itemObject;
			self.zTblDataSelectObject(self.myCurrentObject);
		endif;
	elseif _event = EVENT_TI_MOVE_TO_LOCATION then
		//733 testing - fixed for 741
		if (not _ti.isAttributeTrue(TI_Attrib_MonitorConnection)) then
			return;
		endif;
		
		anLC := _ti.myPrimaryActualLocation;
	
		if anLC = null then
			return;
		endif;
				
		if anLC.myTerminalArea &lt;&gt; self.filterTerminalArea then
			return;
		endif;

	
		str := self.tblDataDisplayRow(tblData, _ti);
	
		if str = null then
			return ;
		endif;
			
		if app.isDevelopmentSystem then
			str := str &amp; Tab &amp; _ti.getOidString;	
		endif;
		row := tblData.addItemObject(_ti, str); 
		self.tblData.accessedRow.backColor := self.colorRow1;
		self.tblDataShowDataSpecial(row, _ti);
	endif;
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_event" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doTblDataUserNotify" id="817284be-2d63-4a69-b4cf-2c2b7b59b2fd">
        <updating/>
        <source>doTblDataUserNotify(table: Table input; eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;
// ---------------------------------------------------------------------------
// Created:		JULY By Andrew Bishop cnwab1
//
// Purpose:		 // PAR 10328 AKB2005JUL
//
// ---------------------------------------------------------------------------
vars
	event		: Integer;
	anObject : Object;
	theTI : CM_TrackedItem;
begin


	inheritMethod(table, eventType, theObject, eventTag, userInfo);
	event := self.myTerminal.getEventFromTerminalEvent(eventType);
	
 // PAR 10328 AKB2005JUL
// ### change this to use new EVENT_TI_MOVE_FROM_LOCATION and EVENT_TI_MOVE_TO_LOCATION notes.

// ### NOTE actual TI update is already handled by tableviewform, so should only be adding or removing lines as cargo is moved

	if event = EVENT_TI_MOVE_FROM_LOCATION 
	or event = EVENT_TI_MOVE_TO_LOCATION then
		if userInfo &lt;&gt; null then
			if userInfo.isKindOf(CM_TrackedItem) then
				theTI := userInfo.CM_TrackedItem;
			endif;
		endif;
	
		self.doTblDataUserNoteTI(theTI, event);
	endif;

epilog
	
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
    <JadeMethod name="getRefConCommMessage" id="f6d2c319-f8f9-4506-808c-05995c0dd635">
        <source>getRefConCommMessage(_timOut: Integer): String;
//----------------------------------------------------------------
//	Created:	02 July 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	msg : String;
begin

	msg := 'Check communication status with RefCon?' &amp; CrLf;
	if _timOut &gt; 1 then
		msg := msg &amp; "(No = check for RefCon reading in the last " &amp; _timOut.String &amp; " hours.";
	elseif _timOut &gt; 0 then
		msg := msg &amp; "(No = check for RefCon reading in the last " &amp; _timOut.String &amp; " hour.";
	else
		msg := msg &amp; "(No = check for any RefCon readings).";
	endif;

	return msg;

end;</source>
        <Parameter name="_timOut" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
