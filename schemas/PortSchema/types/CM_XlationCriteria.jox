    <JadeMethod name="validateTemperatureRange" id="95839906-8ae2-4b53-81a0-1783ec82abe9">
        <source>validateTemperatureRange(_from, _to :Real) protected;
/*
Date		Who		Reason
26 Mar 2013	cnwcs5	Initial Creation - CCMS POL 2097/par 31259
11 Jun 2013	cnwcs5	par 31658 - null temperature handling
*/
vars

begin	
	if (_from = NULL_TEMPERATURE and _to &lt;&gt; NULL_TEMPERATURE) or 
		(_from &lt;&gt; NULL_TEMPERATURE and _to = NULL_TEMPERATURE) then
		// need to enter both
		app.raiseCMException (TEMP_RANGE_ERROR1, null, null);
		return;
	endif;
	
	if _from &gt; _to then
		// from must be less than or equal to to
		app.raiseCMException (TEMP_RANGE_ERROR2, null, null);
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_from" type="Real"/>
        <Parameter name="_to" type="Real"/>
    </JadeMethod>
</Class>
