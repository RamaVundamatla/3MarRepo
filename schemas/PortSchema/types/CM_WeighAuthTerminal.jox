<Class name="CM_WeighAuthTerminal" id="3559f096-3737-45fa-b212-7352e749fbfb">
    <superclass name="CM_Object"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="terminal"/>
    <ExplicitInverseRef name="allVGMDetails" id="e8cd48e2-260e-4e11-8f21-d541b8fc260e">
        <transientToPersistentAllowed/>
        <updateMode>automatic</updateMode>
        <type name="CM_VGMDetailsByContainerDict"/>
        <access>readonly</access>
        <Inverse name="CM_VGMDetails::myWeighAuthTerminal"/>
    </ExplicitInverseRef>
    <PrimAttribute name="isDefaultForTerminal" id="a05e57b0-ed79-4994-9de7-cd62049a472d">
        <embedded/>
        <type name="Boolean"/>
        <access>readonly</access>
    </PrimAttribute>
    <ExplicitInverseRef name="myTerminal" id="64da5098-c9e5-46cb-8f48-c54e35c6a586">
        <transientToPersistentAllowed/>
        <embedded/>
        <type name="CM_Terminal"/>
        <access>readonly</access>
        <Inverse name="CM_Terminal::allWeighAuthTerminals"/>
    </ExplicitInverseRef>
    <ExplicitInverseRef name="myWeighAuthority" id="012836fd-bde9-4561-8f35-c1f485eb392c">
        <kind>child</kind>
        <transientToPersistentAllowed/>
        <updateMode>manual</updateMode>
        <embedded/>
        <type name="CM_WeighAuthority"/>
        <access>readonly</access>
        <Inverse name="CM_WeighAuthority::allWeighAuthTerminals"/>
    </ExplicitInverseRef>
    <JadeMethod name="setForCreate" id="d7c3f886-5a87-4bc0-86fc-4ecb9c62ab04">
        <updating/>
        <source>setForCreate(_isDefault : Boolean; _weighAuth : CM_WeighAuthority; _terminal : CM_Terminal) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 21/06/2017	cnwdap1		Initial creation TFS 4492 SNO VERMAS Changes
//
vars

begin
	self.isDefaultForTerminal := _isDefault;
	self.myWeighAuthority := _weighAuth;
	self.myTerminal := _terminal;
epilog

end;</source>
        <Parameter name="_isDefault" type="Boolean"/>
        <Parameter name="_weighAuth" type="CM_WeighAuthority"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="setIsDefaultForTerminal" id="7c8308db-6daa-46f0-9768-64e1fa9b71e0">
        <updating/>
        <source>setIsDefaultForTerminal(_value : Boolean) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 23/06/2017	cnwdap1		Initial creation TFS 4492 SNO VERMAS Changes
//
vars
	authTerm : CM_WeighAuthTerminal;

begin
	if self.isDefaultForTerminal &lt;&gt; _value then
		if _value then
			// we're changing to default, update the edition of myTerminal so we get notifications
			self.updateObjectEdition(self.myTerminal);
		endif;
		self.isDefaultForTerminal := _value;
	endif;
	
	if _value then
		foreach authTerm in self.myTerminal.allWeighAuthTerminals do
			if authTerm.isDefaultForTerminal and authTerm &lt;&gt; self then
				authTerm.setIsDefaultForTerminal(false);
			endif;
		endforeach;
	endif;
epilog

end;</source>
        <Parameter name="_value" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateForDelete" id="da20c621-4076-4748-9b05-e7b64172b50a">
        <source>validateForDelete();
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 19/06/2017	cnwdap1		Initial creation TFS 4492 SNO VERMAS Changes
//
vars

begin
	if self.isDefaultForTerminal then
		app.raiseCMException2(Cannot_Unassign_Default, self.myWeighAuthority.getKeyName, self.myTerminal.code, null, null);
	endif;
	
	if not self.allVGMDetails.isEmpty then
		app.raiseCMException2(Cant_Remove_WeighAuthTerm, self.myWeighAuthority.certifiedName &amp; Space &amp; self.myWeighAuthority.authorisedName, self.myTerminal.code, null, null);
	endif;
epilog

end;</source>
    </JadeMethod>
</Class>
