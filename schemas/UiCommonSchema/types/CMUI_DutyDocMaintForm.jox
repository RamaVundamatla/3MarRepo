    <JadeMethod name="translateForm" id="539f44b2-1dbe-4fe8-9374-3d1e31e0f706">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 11 March 2019 19:40:51.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0018681, locale);
	btnAddCargo.translateCaption(Xlat_0018682, locale);
	btnCharges.translateCaption(Xlat_0018684, locale);
	btnCurrentChrges.translateCaption(Xlat_0018685, locale);
	btnDelete.translateCaption(Xlat_0018683, locale);
	btnDeleteCargo.translateCaption(Xlat_0018686, locale);
