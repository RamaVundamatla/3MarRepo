    <JadeMethod name="tblJobsAllocated_click" id="286a05c3-0c12-4226-928f-59859b3cb791">
        <controlMethod name="Table::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblJobsAllocated_click(table: Table input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
01 Jun 2023	navhl20	ChangeRequest 57747:[57748] EUP - Delivery Dispatch – Allocate Jobs to Gangs
02 Jun 2023	navlw1	ChangeRequest 58294 : EUP | Delivery Dispatch Screen - Setting Priority
03 Apr 2024	navpw1	TFS: 62859 (62860) - Checked for invalid object using exception handler
03 May 2024 navhl20 ChangeRequest 63857: EUP - Bulk Load ship in retrospective mode
*/

vars
	invalidObject	: Boolean;
	obj				: Object;
	
begin
	if not self.tblJobsAllocated.allSelectedObjects.size = 1 then
		return;
	endif;
	
	obj := self.tblJobsAllocated.allSelectedObjects.first;
	
	on Exception do app.handleDeletedObject(exception, obj, invalidObject);
	
	obj.edition;
	
	if invalidObject then
		return;
	endif;
	
	self.mnuSetPriority.visible := true; // ### TFS 58294 02June2023 navlw1 
	self.loadTblWleAllocated(obj);
	if obj.CM_Job.isRelByType then						//03.05.2024 navhl20 #63857
		self.chkBulkMode.value := false;
		self.chkBulkMode.enabled := false;
		self.chkBulkMode_click(self.chkBulkMode);
	else
		self.chkBulkMode.enabled := true;
	endif;
epilog
	on Exception do null;
	
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
