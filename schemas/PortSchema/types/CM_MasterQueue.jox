    <JadeMethod name="updateMachines" id="78c315c3-0e68-4968-80a9-1bd2d10a878f">
        <updating/>
        <source>updateMachines() updating;
//Checks that machines are correctly in the queue
vars
	mach : CM_Machine;
	machDict : CM_MachineByIdDict;
begin
	//--------------
	//For each machine, check that its in a queue, and the queue confirms that.
	//--------------
	machDict := self.myTerminal.machines;
	
	foreach mach in machDict do
		exclusiveLock(mach);
		//-----------------
		//If the machine is a Crane, no R/T needed but still has a primary queue
		//-----------------
		// DVB Changed 6/09/04 for not available for entry
		if mach.isNotAvailableForEntry then
			mach.deQueue();
			continue;
		endif;
		
		if mach.hasRadioTelemetry or mach.isKindOf(CM_Crane) then
			if mach.myPrimaryQueue = null then
				self.addMachine(mach);
			endif;
		else
			//NO R/T, check that its STILL not in Queue
			if mach.myPrimaryQueue &lt;&gt; null then
				mach.deQueue;	//queue.releaseMachine(mach);
			endif;
		endif;
	endforeach;
end;</source>
    </JadeMethod>
</Class>
