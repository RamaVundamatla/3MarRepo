        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <ImplicitInverseRef name="photoBytes" id="b2b09db0-7739-4d34-a187-094c1a11dd26">
        <embedded/>
        <type name="CM_Bytes"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="thumbnailBytes" id="fd85a5f5-6d04-4cb6-a5a0-9086642715fc">
