    <JadeMethod name="getLastGateOutVVRD" id="8fc8715e-bdab-42d3-b102-47490193e311">
        <source>getLastGateOutVVRD():CM_VehicleVisitRecordDetail protected;
// ---------------------------------------------------------------------------
// Created:     19 May 2009 by concms1
// Purpose:     Par 19715 - Vehicle Visit Record Detail Changes
// Parameters:  None
// Returns:     The last VVRD with record type VehicleVisit_GateOut
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 
// ---------------------------------------------------------------------------
vars
	detail	: CM_VehicleVisitRecordDetail;
begin
	foreach detail in self.allVehicleVisitRecordDetails reversed do
		if detail.recordType = VisitRecord_Arrive_PGate_Out then
			// return last out-gate (arrive p-gate (out)) that we find
			return detail;
		endif;
	endforeach;
	
	return null;
epilog

end;</source>
        <access>protected</access>
        <ReturnType type="CM_VehicleVisitRecordDetail"/>
    </JadeMethod>
