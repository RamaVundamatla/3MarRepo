        <updating/>
        <source>tblPrintOptions_dblClick(table: CM_EntryTable input) updating;
// -------------------------------------------
// Created 13 December 2004 by cnwdvb1
// -------------------------------------------
vars

begin

	if table.row &lt;&gt; table.getRowByName(ETRow_CsvFileName) then
		return;
	endif;
	
	self.getCSVFilePath();


