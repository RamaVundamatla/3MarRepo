    <JadeMethod name="getMyHold" id="4452470a-a5a4-4c21-99fb-1463f0e28bda">
        <source>getMyHold () :  CM_Hold ;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 July 2017	jlgrh7	Initial creation

*/

vars
	voyage : CM_Voyage;
	myBay 		: CM_Bay;
	myHold		: CM_Hold;
begin
	voyage := self.myVoyage;
	if voyage &lt;&gt; null then
		myBay := voyage.lookupBayVoyage(self.bayId);
		if myBay &lt;&gt; null then
			myHold := myBay.myHold;
		endif;
		return myHold;
	endif;
	return null;
epilog

end;</source>
