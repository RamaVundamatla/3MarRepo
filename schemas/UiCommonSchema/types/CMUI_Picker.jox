    <JadeMethod name="defaultSelectRow" id="81a9d97a-db8f-4478-9a6f-00ed73f7decb">
        <updating/>
        <source>defaultSelectRow() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date			Who		Reason
26 August 2009	cnwas3	Initial creation
12 August 2010	cnwjo3	changed it so disabled rows are not selected
26 June 2014	cnwdap1	PAR #34066 If the row is disabled, make sure it stays unselected
*/
vars
	idx : Integer;
begin
	if tblList.rows &gt; 1 then
		foreach idx in 2 to tblList.rows do
			if tblList.accessRow(idx).enabled = true then
				self.selectedObject := tblList.accessRow(idx).itemObject;
				tblList.accessedRow.selected := true;
				tblList.row := idx;
				break;
			else
				//tblList.accessRow(idx).selected := not tblList.accessRow(idx).selected;	// PAR #34066
				tblList.accessRow(idx).selected := false;									// PAR #34066
				if self.tblList.accessedRow.itemObject = self.selectedObject then			// PAR #34066
					self.selectedObject := null;											// PAR #34066
				endif;																		// PAR #34066
			endif;
		endforeach;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="doCancel" id="3c9b2c93-b3f6-4aa8-b7cc-ab3884d52bf7">
        <updating/>
        <source>doCancel() updating, protected;

vars

begin

	app.mousePointer := MousePointer_HourGlass;

	self.selectedObject := null;
	self.modalResult := MsgBox_Return_Cancel;
	self.unloadForm();
epilog
	app.mousePointer := MousePointer_Default;		
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doClickCreateJobsSelected" id="b2058a3f-5dda-44d2-a40c-74ec53aa4d99">
        <updating/>
        <source>doClickCreateJobsSelected() updating;
/*

Purpose:			

Parameters:			

Return Value:		

/* Changes

Date		Name	TFS#		Description
============================================================================
22 Dec 2016	cnwndl1	TFS 3134 
					/ 2683		Initial creation	
08 Apr 2019	jlgka1	44250		Stackdump when using Create Jobs for Selected 
								due to myTerminal is currently not set.
07 May 2025	navcs2	MTN-34773
20/11/2025	navcs2	MTN-36557	MTN | Booking with Release Empties Issue when clicking on Create Jobs for Selected from Picker
============================================================================*/

vars

	row 			: Integer;
	objectArray		: ObjectArray;
	obj 			: Object;
	msg 			: String;
	firstTi 		: CM_TrackedItem;
	
	jobQueueNum 	: Integer;
	allGTEs 		: CMGTE_EntitySet;
	gte 			: CMGTE_Entity;	
	gteRelease 		: CMGTE_Release;
	pxyGTERelease 	: CMGTE_Release;
	pxyGTEReceival 	: CMGTE_ReceivalByType;		// 20/11/2025	navcs2	MTN-36557
	ti 				: CM_TrackedItem;
	flexiController : CMIF_FlexiGateController;
	arrayOfProxies 	: CMGTE_EntityArray;
	saveObject 		: Object;
	
	gteClass 		: Class;
	pxyGTEEntity 	: CMGTE_Entity;
	size 			: Integer;
	
	firstResDet 	: CM_ReserveDetail;	//14 Mar 2017	NDL	TFS 3701
	resDet 			: CM_ReserveDetail;	//14 Mar 2017	NDL	TFS 3701
	br 				: CM_BulkRelease;	//14 Mar 2017	NDL	TFS 3701
	ct 				: CM_CargoType;
	totalToProcess	: Integer;	//16 Oct 2019	NDL	TFS 47012
	index			: Integer;	//16 Oct 2019	NDL	TFS 47012
	term : CM_Terminal;	//16 Oct 2019	NDL	TFS 47012
	firstBookingItem,							// 20/11/2025	navcs2	MTN-36557
	bookingItem		: CM_BookingRefItem;		// 20/11/2025	navcs2	MTN-36557
begin

	create objectArray transient;
	
	foreach row in self.tblList.fixedRows + 1 to self.tblList.rows do
		if self.tblList.accessRow(row).selected and self.tblList.accessRow(row).enabled then
			obj := self.tblList.accessRow(row).itemObject;
			if obj.isKindOf( CM_TrackedItem ) then
				if firstTi = null then
					firstTi := obj.CM_TrackedItem;
				endif;
				objectArray.add(obj);
			endif;
		endif;
	endforeach;
	
	//14 Mar 2017	NDL	TFS 3701
	if objectArray.isEmpty then
		foreach row in self.tblList.fixedRows + 1 to self.tblList.rows do
			if self.tblList.accessRow(row).selected and self.tblList.accessRow(row).enabled then
				obj := self.tblList.accessRow(row).itemObject;
				if obj.isKindOf( CM_ReserveDetail ) then
					if br = null then
						firstResDet := obj.CM_ReserveDetail;
						br := firstResDet.myReserveHeader;
					elseif obj.CM_ReserveDetail.myReserveHeader &lt;&gt; br then
						continue;
					endif;
					objectArray.add(obj);
				endif;
			endif;
		endforeach;
	endif;
	
	// 20/11/2025	navcs2	MTN-36557 Start
	if objectArray.isEmpty then
		foreach row in self.tblList.fixedRows + 1 to self.tblList.rows do
			if self.tblList.accessRow(row).selected and self.tblList.accessRow(row).enabled then
				obj := self.tblList.accessRow(row).itemObject;
				if obj.isKindOf( CM_BookingRefItem ) then
					if firstBookingItem = null then
						firstBookingItem := obj.CM_BookingRefItem;
					endif;
					objectArray.add(obj);
					
				endif;
			endif;
		endforeach;
	endif;
	// 20/11/2025	navcs2	MTN-36557 End
	
	if objectArray.isEmpty then
		return;
	endif;
	

/*	09 Feb 2017	NDL	TFS 3134 - Don't use the std validation this week....
	if not self.validateMultiSelection(oa,msg) then
		if msg &lt;&gt; null then
			app.msgBox(msg, app.getErrorString(Error), MsgBox_OK_Only);
		else
			app.msgBox(app.getErrorString(Selec_items_must_be_singl_book), app.getErrorString(Error), MsgBox_OK_Only);
		endif;	
		return;
	endif; */

	jobQueueNum := 1000;

	create arrayOfProxies transient;
	
	if firstTi &lt;&gt; null then
		foreach obj in objectArray do
		
			ti := obj.CM_TrackedItem;
			self.showAdditionalRemarks(ti.remarksAdditional1, ti.remarksAdditional2);		// 07 May 2025	navcs2	MTN-34773
			
			if ti.isOnSite then
			
				create pxyGTERelease transient;
				pxyGTERelease.setIsReleaseById(true);
			//	pxyGTERelease.setPXYFromBulkRelease(_reserveDetail.myReserveHeader, _reserveDetail);
				
				create flexiController transient;
				flexiController.setFromExistingPrenote( ti );	// sets up the majority of the std fields
				
				pxyGTERelease.setPXYFromController( flexiController );
				delete flexiController;
				
				pxyGTERelease.setPxyFromTI( ti );	// sets up the job type data.
				
				pxyGTERelease.setJobQueueNum( jobQueueNum + arrayOfProxies.size );
				arrayOfProxies.add(pxyGTERelease);
			
			elseif ti.isNotified then
				gteClass := ti.getGTEClassToCreate();
				create pxyGTEEntity as gteClass transient;
				pxyGTEEntity.setPxyFromTI( ti );
				
				pxyGTEEntity.setJobQueueNum( jobQueueNum + arrayOfProxies.size );
				arrayOfProxies.add( pxyGTEEntity );
				
			endif;
			
		endforeach;
		self.btnOK.enabled := true; // TFS 3702
	elseif firstResDet &lt;&gt; null then
		foreach obj in objectArray do
		
			term := self.myTerminal;	//16 Oct 2019	NDL	TFS 47012
		
			resDet := obj.CM_ReserveDetail;
			ct := resDet.getCargoType;
			if ct = null then
				continue;
			endif;
			
			//16 Oct 2019	NDL	TFS 47012
			if term = null then
				term := resDet.getMyTerminal();
			endif;
			
			//16 Oct 2019	NDL	TFS 47012
			if ct.isBreakBulk
			and not ct.isBreakBulkMulti
			and resDet.getQuantityRemaining() &gt; 1
			and term.getConfig( MultiJobForNoDupBB ).Boolean = true
			then
				totalToProcess := resDet.getQuantityRemaining();
				foreach index in 1 to totalToProcess do
					create pxyGTERelease transient;
					self.setProxyGTEForJobCreation( arrayOfProxies, jobQueueNum, pxyGTERelease, br, resDet, ct );
					pxyGTERelease.setTotalQuantity(1); //jlier1 34193 5/3/25
				endforeach;
			
			else
				create pxyGTERelease transient;
				self.setProxyGTEForJobCreation( arrayOfProxies, jobQueueNum, pxyGTERelease, br, resDet, ct );
				
			endif;
			
	/*		16 Oct 2019	NDL	TFS 47012 - moved to its own method 'setProxyGTEForJobCreation'
			pxyGTERelease.setPXYFromBulkRelease( br, resDet );
			
			pxyGTERelease.setWeight(resDet.getWeightOutstanding);
			
			create flexiController transient;
			if ct.isContainer then
				
				if br.isForMTs then
					flexiController.mtOnly := true;
					flexiController.jobType 	:= CMGTE_Entity.JobType_EmptyOUT;
				else 
					flexiController.jobType 	:= CMGTE_Entity.JobType_FullOUT;
				endif;
			elseif ct.isTrailer then
				flexiController.jobType 		:= CMGTE_Entity.JobType_ChassisOut;
			else					
				flexiController.jobType 		:= CMGTE_Entity.JobType_GeneralOUT;
			endif;
			flexiController.myTerminal := br.myTerminal;
			if self.myCallingForm &lt;&gt; null and self.myCallingForm.class.name = "GTE_FlexiGateForm" then
			flexiController.myVehicleVisitRecord := self.myCallingForm.getPropertyValue('myRealVVR').CM_VehicleVisitRecord;
			endif;
			
			if ct.isBreakBulkMulti then
				flexiController.numItems := resDet.getQuantityRemaining();
			elseif ct.isBulkMulti then
				flexiController.weight := resDet.getWeightOutstanding;
			endif;
			
			flexiController.myBulkRelease := br;
			flexiController.myReserveDetail := resDet;
			flexiController.operatorCode := resDet.getOperatorCode;
			flexiController.operatorGroupCode := resDet.getOperatorGroupCode;
			flexiController.isoTypeCode := resDet.getISOTypeCode;
			flexiController.isoGroup := resDet.getISOGroupCode;
			flexiController.cargoType := ct.id;
			flexiController.myProduct := resDet.getMyProduct;
			flexiController.voyageCode := resDet.getVoyageCode;
			flexiController.yardInstructions := resDet.yardInstruction;
			
			flexiController.remarks := resDet.remarks;
			flexiController.myBookingRefItem := resDet.myBookingRefItem;
			if resDet.myBookingRefItem &lt;&gt; null then
				flexiController.bookingNumber := resDet.myBookingRefItem.myBookingReference.bookingReference;
			endif;
			flexiController.freightForwarderCode := resDet.getFreightForwarderCode;
			flexiController.consigneeCode := resDet.getConsigneeCode;
			flexiController.consignorVoyageCode := resDet.getConsignorVoyageCode;
			flexiController.density := resDet.getDensity.Integer;
			flexiController.billOfLading := resDet.getBOLNumber;
			if br.mySubTerminal &lt;&gt; null then
				flexiController.subTerminalCode := br.mySubTerminal.code;
			endif;
			
			if resDet.isKindOf( CM_ReserveSelection ) then
				flexiController.clean := resDet.CM_ReserveSelection.clean;
				flexiController.colour := resDet.CM_ReserveSelection.colour;
				flexiController.heavyRated := resDet.CM_ReserveSelection.heavyRated;
				flexiController.markNumber := resDet.CM_ReserveSelection.markNumber.String;
				flexiController.mark := resDet.CM_ReserveSelection.markSelection;
				if not resDet.CM_ReserveSelection.allAvailabilityGrades.isEmpty then
					resDet.CM_ReserveSelection.allAvailabilityGrades.copy(flexiController.allAvailabilityGrades);
				endif;
			endif;
				
			pxyGTERelease.setPXYFromController( flexiController );
			delete flexiController; 
			
			pxyGTERelease.setJobQueueNum( jobQueueNum + arrayOfProxies.size );
			arrayOfProxies.add(pxyGTERelease); */
			
		endforeach;
		
	// 20/11/2025	navcs2	MTN-36557 Start
	elseif firstBookingItem &lt;&gt; null then
		foreach obj in objectArray do
			term := self.myTerminal;
			
			bookingItem := obj.CM_BookingRefItem;
			ct := bookingItem.myCargoType;
			if ct = null then
				continue;
			endif;
			
			if term = null then
				term := bookingItem.getMyTerminal();
			endif;
			
			if ct.isBreakBulk
			and not ct.isBreakBulkMulti
			and resDet.getQuantityRemaining() &gt; 1
			and term.getConfig( MultiJobForNoDupBB ).Boolean = true
			then
				totalToProcess := bookingItem.getQuantity;
				foreach index in 1 to totalToProcess do
					create pxyGTEReceival transient;
					self.setProxyGTEBookingForJob( arrayOfProxies, jobQueueNum, pxyGTEReceival, bookingItem, bookingItem.myBookingReference, ct );
					pxyGTEReceival.setTotalQuantity(1); //jlier1 34193 5/3/25
				endforeach;
			
			else
				create pxyGTEReceival transient;
					self.setProxyGTEBookingForJob( arrayOfProxies, jobQueueNum, pxyGTEReceival, bookingItem, bookingItem.myBookingReference, ct );
			endif;
			
		endforeach;
	// 20/11/2025	navcs2	MTN-36557 End	
		
	endif;
	saveObject := arrayOfProxies;	
	//jlgka1 TFS 44250 --&gt;
	if app.myPassport.myTerminal = null then
		if self.myCallingForm.myTerminal &lt;&gt; null then
			app.myPassport.setMyTerminal(self.myCallingForm.myTerminal);
		endif;
	endif;
	//jlgka1 TFS 44250 &lt;--
	if self.myCallingForm.saveGateEntity( false, saveObject, false, null) then
		size := self.tblList.rows;
		foreach row in 1 to size reversed do	
			obj := self.tblList.accessRow(row).itemObject;
			if objectArray.includes(obj) then
				self.tblList.removeItem(row);
			endif;
		endforeach;
	endif;
	
	if self.tblList.rows &lt;= 1 then
		self.doCancel();
	endif;
	
epilog

	delete objectArray;
//	delete flexiController;
	
	if arrayOfProxies &lt;&gt; null then
		arrayOfProxies.purge();
		delete arrayOfProxies;
	endif;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doClickDeSelectAll" id="e5fbbc5d-56d8-48d7-90fa-f61323fd4e15">
        <source>doClickDeSelectAll();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 February 2017	cnwndl1	Initial creation

*/

vars

	row : Integer;

begin

	foreach row in self.tblList.fixedRows + 1 to self.tblList.rows do
		if self.tblList.accessRow(row).selected and self.tblList.accessRow(row).enabled then
			self.tblList.accessRow(row).selected := false;
		endif;
	endforeach;
	
	self.btnSelectAll.enabled := true;
	self.btnOK.enabled := true;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doClickSelectAll" id="e4f7a96f-95cf-4a00-a54d-bb23d0023948">
        <source>doClickSelectAll();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 Dec 2016	cnwndl1	Initial creation	TFS 3134 / 2683
23 Apr 2024	jlika1	TFS 63740 CUX - "Select All" button in Picker doesn't select all prenotes - GoLCrit 01
20Jun 2024	jlier1  TFS 64592
*/

vars

	row : Integer;
	oa : ObjectArray;
	obj : Object;
	firstTi : CM_TrackedItem;
	ti : CM_TrackedItem;
	diff : Decimal [16,4];
	firstResDet : CM_ReserveDetail;	//14 Mar 2017	NDL	TFS 3701
	resDet : CM_ReserveDetail;	//14 Mar 2017	NDL	TFS 3701
	br : CM_BulkRelease;	//14 Mar 2017	NDL	TFS 3701
	
begin

	create oa transient;

	foreach row in self.tblList.fixedRows + 1 to self.tblList.rows do
		if self.tblList.accessRow(row).selected and self.tblList.accessRow(row).enabled and self.tblList.accessRow(row).visible then
			obj := self.tblList.accessRow(row).itemObject;
			oa.add(obj);
		endif;
	endforeach;
	
	if oa.size &gt; 1 then
		//we are de-selecting everything
		foreach row in self.tblList.fixedRows + 1 to self.tblList.rows do
			if self.tblList.accessRow(row).selected and self.tblList.accessRow(row).enabled then
				self.tblList.accessRow(row).selected := false;
			endif;
		endforeach;
		
	else
		//we are selecting all similar tis, based on the one TI ( already selected) or the first available to select (or Reserve Details on the same basis.)
		if oa.size = 1 and oa.first.isKindOf(CM_TrackedItem) then
			firstTi := oa.first.CM_TrackedItem;
		elseif oa.size = 1 and oa.first.isKindOf(CM_ReserveDetail) then		//14 Mar 2017	NDL	TFS 3701
			firstResDet := oa.first.CM_ReserveDetail;
		else
			foreach row in self.tblList.fixedRows + 1 to self.tblList.rows do
				if self.tblList.accessRow(row).enabled then
					obj := self.tblList.accessRow(row).itemObject;
					if obj &lt;&gt; null and obj.isKindOf(CM_TrackedItem) then
						firstTi := obj.CM_TrackedItem;
						break;
					elseif obj &lt;&gt; null and obj.isKindOf(CM_ReserveDetail) then		//14 Mar 2017	NDL	TFS 3701
						firstResDet := obj.CM_ReserveDetail;
						break;
					endif;
				endif;
			endforeach;
		endif;
		
		if firstResDet &lt;&gt; null then		//14 Mar 2017	NDL	TFS 3701
		
			br := firstResDet.myReserveHeader;
			
			foreach row in self.tblList.fixedRows + 1 to self.tblList.rows do
				if self.tblList.accessRow(row).enabled then
					obj := self.tblList.accessRow(row).itemObject;
					if obj &lt;&gt; null and obj.isKindOf(CM_ReserveDetail) then
						resDet := obj.CM_ReserveDetail;
						if resDet = firstResDet then
							self.tblList.accessRow(row).selected := true;
						else
							//multi-select rules		
							if resDet.myReserveHeader &lt;&gt; br then
								continue;
							endif;
							
							self.tblList.accessRow(row).selected := true;
						endif;
					endif;
				endif;
			endforeach;
			
			if self.tblList.selectedCount &gt; 1 then
				self.btnSelectAll.enabled := false;
				self.btnOK.enabled := false;
			endif;
			
			return;
			
		elseif firstTi &lt;&gt; null then
			
			foreach row in self.tblList.fixedRows + 1 to self.tblList.rows do
				if self.tblList.accessRow(row).enabled then
					obj := self.tblList.accessRow(row).itemObject;
					if obj &lt;&gt; null and obj.isKindOf(CM_TrackedItem) then
						ti := obj.CM_TrackedItem;
						if ti = firstTi then
							self.tblList.accessRow(row).selected := true;
						else
							//multi-select rules		
							if ti.damaged then
								//Not allowed to be damaged
								continue;
							endif;
							if not ti.allAttachments.isEmpty then
								//Not allowed to have attachments ( includes photos )
								continue;
							endif;
							if not ti.allChildren.isEmpty then
								//Not allowed to have children
								continue;
							endif;
							if not ti.allSeals.isEmpty then
								//Not allowed to have seals
								continue;
							endif;
							
							// TFS 3702
							if self.chkPrenotesByBookItem.value then
								if (firstTi.isPreNote and ti.isPreNote) and (firstTi.myBookingRefItem = ti.myBookingRefItem) then
									self.tblList.accessRow(row).selected := true;
									self.btnOK.enabled := false;									
									continue;
								else// so we can separate cargo with null booking too in the matching and also match them together if neeeded...
									continue;
								endif;
							
							else
								if firstTi.cargoType &lt;&gt; ti.cargoType then
								continue;
								elseif firstTi.myProduct &lt;&gt; ti.myProduct then
									continue;
								elseif firstTi.getImExStatus &lt;&gt; ti.getImExStatus then
									continue;
								elseif firstTi.totalWeight &lt;&gt; ti.totalWeight then
									if firstTi.totalWeight &gt; ti.totalWeight then
										diff := firstTi.totalWeight - ti.totalWeight;
									else
										diff := ti.totalWeight - firstTi.totalWeight;
									endif;
									if diff &gt; Measure_AllowableDifference then
										continue;
									endif;
								elseif firstTi.totalVolume &lt;&gt; ti.totalVolume then
									continue;
								elseif firstTi.commodity &lt;&gt; ti.commodity then
									continue;
								elseif firstTi.isoTypeDesc &lt;&gt; ti.isoTypeDesc then
									continue;
								endif;
							endif;
							self.tblList.accessRow(row).selected := true;
						endif;
					endif;
				endif;
			endforeach;
			
			return;
		
		endif;
		
		
	endif;

epilog

	delete oa;

end;</source>
    </JadeMethod>
    <JadeMethod name="doDiscardGenericScan" id="49627b49-17bb-42e8-8f6b-abf2b3802c4d">
        <updating/>
        <source>doDiscardGenericScan() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who			Reason
12 April 2022	navsrk20	Initial creation	TFS 52777

*/

vars

begin
