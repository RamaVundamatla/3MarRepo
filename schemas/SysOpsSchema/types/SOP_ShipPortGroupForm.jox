    <JadeMethod name="clearProxyDetails" id="16d4d4ad-83b0-47b9-b507-188c8b4d42f6">
        <updating/>
        <source>clearProxyDetails() updating;

vars

begin
	if self.myProxyShipPortGroup &lt;&gt; null then
		self.myProxyShipPortGroup.erase(NORMAL_ERASE);
		self.myProxyShipPortGroup := null;
	endif;
end;</source>
    </JadeMethod>
