    <JadeMethod name="utlCreateRestAuthAndDelOld" id="89649324-214c-4c4b-974a-7c49ffd5f25c">
        <source>utlCreateRestAuthAndDelOld(_pxyToken : CM_RestAuthToken; _realToken : CM_RestAuthToken output; _delToken : CM_RestAuthToken input; _passport : CM_Passport input);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 08/10/2020	jlgdap1		Initial creation TFS 49227 MTN Navis API - nReefer API
//
vars

begin
	self.initialiseActivity();
	
	app.setContinueCMExceptions(true);
	
	app.myValCA.valRestAuthToken(_pxyToken);

	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);
	
	// create the new token
	create _realToken persistent;
	_realToken.setForCreate(_pxyToken, _passport);
	
	// and delete the old
	_delToken.erase(NORMAL_ERASE);
epilog

end;</source>
        <Parameter name="_pxyToken" type="CM_RestAuthToken"/>
        <Parameter name="_realToken" type="CM_RestAuthToken" usage="output"/>
        <Parameter name="_delToken" type="CM_RestAuthToken" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
