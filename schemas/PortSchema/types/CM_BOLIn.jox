    <JadeMethod name="getTfrFromTrnsFor" id="e07a6ae4-310f-433a-8155-11867f941b78">
        <source>getTfrFromTrnsFor( _trns : CM_BOLTrnsactByTypeDateDict input; _ti : CM_TrackedItem );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 April 2016	cnwndl1	Initial creation	TFS 1903
	gets the transactions going up the tree.

*/

vars

	trx : CM_BOLTransaction;
	otherBOLTrx : CM_BOLTransferTransaction;
	otherBOL : CM_BOLIn;
	
	parentTi : CM_TrackedItem;
	otherBols : CM_BOLInByTypeStatusNumDTDict;

begin

	create otherBols transient;
	
	foreach trx in self.allBOLTransactions discreteLock do
		if trx.type = TRANS_TYPE_BOL_TRANSFER then
			if trx.CM_BOLTransferTransaction.myTrackedItem = _ti then
				_trns.addNoDuplicates( trx, false );
				otherBOLTrx := trx.CM_BOLTransferTransaction.myFromTfrTransaction;
				if otherBOLTrx &lt;&gt; null then
					otherBOL := otherBOLTrx.myBOL.CM_BOLIn;
					otherBOL.getTfrFromTrnsFor( _trns, _ti );
					otherBols.add( otherBOL );
				endif;
			endif;
		endif;
	endforeach;
	
	//17 Jun 2016	NDL	TFS 1904
	parentTi := _ti.getMySplitFromParent;
	if parentTi &lt;&gt; null then
		foreach otherBOL in otherBols do
			otherBOL.getTfrFromTrnsFor( _trns, parentTi );
		endforeach;
	endif;

epilog

	delete otherBols;

end;</source>
        <Parameter name="_trns" type="CM_BOLTrnsactByTypeDateDict" usage="input"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="getTotalTIQtyDelivered" id="3c40206c-6912-4125-88d8-232510790159">
        <source>getTotalTIQtyDelivered() :Integer;
//--------------------------------------------------
// Created:	24 March 2006 By: cnwgd1
//--------------------------------------------------
vars
	total : Integer;
	ti : CM_TrackedItem;
begin

	foreach ti in self.allTrackedItems do
		if ti.releasedDT.isValid() then
			total := total + ti.quantity;
		endif;
	endforeach;

	return total;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
