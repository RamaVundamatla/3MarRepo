    <JadeMethod name="doComboJobTypeBuild" id="512514d3-fd95-43d7-a41b-48bec3cf82db">
        <source>doComboJobTypeBuild(combo : CMUI_ComboBox input);
// ---------------------------------------------------------------------------
// Created:		11 April 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
//	combo : CMUI_ComboBox;
	aTerm : CM_Terminal;
	aJT : CM_JobType;
begin


	
	combo.clear;
	combo.sorted := true;
	
	aTerm := app.getMyTerminalDO_NOT_USE();
	
	foreach aJT in app.myRoot.allJobTypes do
		combo.addItemObject(aJT.name,aJT);
	endforeach;
end;</source>
        <Parameter name="combo" type="CMUI_ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doComboPhysicalLimits" id="258f9347-c02f-47bd-b985-5fd14ff09ff3">
        <source>doComboPhysicalLimits(_combo : CMUI_ComboBox input);
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 September 2009	cnwer1	Initial creation

*/

vars
	
	ta : CM_TerminalArea;
	iter : Iterator;
	combo  : CMUI_ComboBox;
	gridColumn	: CM_GridColumn;
	rtgLane : CM_RTGLane;
	taArray : CM_TerminalAreaArray;
	dynaDict : DynaDictionary;	
	rtgLaneId : String;
	rtgLaneIdx : Integer;
begin


	
	_combo.clear;
	_combo.sorted:=false;
	
	create taArray transient;

	self.myForm.mulSelect1.getSelected(taArray);	
	
	
	create dynaDict transient;
	// set the membership of our dynamic dictionary
	dynaDict.setMembership(CM_RTGArea);
	//rtg lane name
	dynaDict.addExternalKey(String,	13 ,false,false);
	//indx in rtg lane
	dynaDict.addExternalKey(Integer,8 ,false,false);
	dynaDict.endKeys(true);
	
	
	iter:=taArray.createIterator;
	while iter.next(ta) do
		if not ta.isKindOf(CM_RTGArea) then
			continue;
		endif;
		rtgLaneId:=null;
		rtgLaneIdx:=null;
		rtgLane:= ta.allTerminalAreaGroups.first.CM_RTGLane;
		if rtgLane &lt;&gt; null then
			rtgLaneId:=rtgLane.id;
			rtgLaneIdx:=rtgLane.allTAsByTypeId.indexOf(ta);
		endif;
		dynaDict.putAtKey(rtgLaneId,rtgLaneIdx,ta);
	endwhile;
	
	delete iter;
	iter:=dynaDict.createIterator;
	while iter.next(ta) do
		if not ta.isKindOf(CM_RTGArea) then
			continue;
		endif;
		foreach gridColumn in ta.CM_RTGArea.allGridColumns do
			_combo.addItemObject(gridColumn.CM_RTGColumn.getFullID(false),gridColumn);
		endforeach;
	endwhile;
	
	
epilog
	delete taArray;
	delete iter;
	delete dynaDict;
end;</source>
        <Parameter name="_combo" type="CMUI_ComboBox" usage="input"/>
    </JadeMethod>
