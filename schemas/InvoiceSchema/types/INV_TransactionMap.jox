    <JadeMethod name="doLstCopyPathClick" id="6716addd-694a-477e-acad-de5167881f00">
        <updating/>
        <source>doLstCopyPathClick() updating;

vars
	listObject	: CM_Object;
begin
	if self.lstCopyPath.listIndex &gt;= 0 then
		listObject := self.lstCopyPath.itemObject[self.lstCopyPath.listIndex].CM_Object;
		if listObject = null then
			self.lstCopyList.clear();
			return;
		endif;

		if listObject.isKindOf(CM_ProductMap) then
			self.doBuildListboxIMEX(listObject.CM_ProductMap);
		elseif listObject.isKindOf(CM_ImexServiceMap) then	
			self.doBuildListboxContents(listObject.CM_ImexServiceMap);
		elseif listObject.isKindOf(CM_ContentsMap) then
			self.doBuildListboxCommodity(listObject.CM_ContentsMap);
		elseif listObject.isKindOf(CM_CommodityMap) then
			self.doBuildListboxTransactions(listObject.CM_CommodityMap);
		endif;
	endif;

end;
</source>
    </JadeMethod>
    <JadeMethod name="doLstDataClick" id="572b6662-5381-4d48-802d-3c545ac1bc70">
        <updating/>
        <source>doLstDataClick(listbox: ListBox input) updating;
// ---------------------------------------------------------------------------
// Created:		May 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	transactionMap:INV_TransactionMap;
	theTMC : CMIF_TranMapController;
	level	: Integer;
	row : Integer;
	obj : Object;
	test : Boolean;
	reachedMaxSize : Boolean;
begin

	on Exception do app.handleUE14025(exception, reachedMaxSize);	//04 Oct 2017	NDL	TFS 7055

	transactionMap := self;
	if listbox.listIndex &gt;= 0 then
		row := listbox.listIndex;
		level := listbox.itemLevel[row];
		test := listbox.itemHasSubItems(row);
		theTMC := listbox.itemObject[row].CMIF_TranMapController;
		if not test then
			theTMC.populate(listbox, level, row+1);		// 35386
			
			//04 Oct 2017	NDL	TFS 7055
			if reachedMaxSize then
				//Tell the user if we haven't already.
				self.refreshWarned := true;
				app.msgBox( app.getErrorString(More_than_30000_lines_curre_lo), app.getErrorString(Warning), MsgBox_OK_Only);
				return;
			endif;
			
		endif;
		if theTMC.isKindOf(CMIF_TMCRoot) then
			self.myCurrentMapTM := null;
		elseif theTMC.isKindOf(CMIF_TMCGroup) then
			self.myCurrentMapTM := theTMC.CMIF_TMCGroup.getMyTransactionMap();
			theTMC.CMIF_TMCGroup.setMyCurrent(transactionMap);
		elseif theTMC.isKindOf(CMIF_TMCInvLineDesc) then
			theTMC.CMIF_TMCInvLineDesc.setMyCurrent(transactionMap);
		endif;
		theTMC.setEnableObjects(transactionMap);
	else

	endif;
	
	row := listbox.listIndex;
	if row &gt; 0 and row &lt;= listbox.listCount() then
		obj :=listbox.itemObject[row];
	endif;

	if obj &lt;&gt; null then
		if obj.isKindOf(CMIF_TranMapController) then
			if self.showBubbleHelp then
				listbox.bubbleHelp := obj.CMIF_TranMapController.getDescription();
			else
				listbox.bubbleHelp := "";
			endif;
		else
			app.writeStatement( class.name &amp; '::' &amp; method.name &amp;  ' 1. ' &amp; obj.String);
		endif;
	endif;
	
	self.statusLine.caption := "";

	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.setViewOnly();
		return;
	endif;

end;</source>
        <Parameter name="listbox" type="ListBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doLstDataContextMenu" id="4d2ea7bb-29f7-4960-b639-dbbca9774210">
        <updating/>
        <source>doLstDataContextMenu(listbox: ListBox input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer): Boolean updating;
// ---------------------------------------------------------------------------
// Created:		May 2004 By Andrew Bishop cnwab1
//
// Purpose:		
// 02 Feb 2017 TFS #3286:Issues with Invoicing Audits
// ---------------------------------------------------------------------------

vars
	selectedObj		: Object;
begin
	self.mnuInspectObject.visible := app.isAllowedToInspect();
	self.mnuTMVCheck.visible := self.myCurrentMapTMVoyage &lt;&gt; null;
	self.mnuSepBottom.visible := self.myCurrentMapTMVoyage &lt;&gt; null or app.isSpecial();
	self.mnuSepAboveDelete.visible  := self.menuSItemDelete.visible;
	
	//02/02/2017 cnmwa1 TFS #3286
	self.mnuAudits.visible :=true;
	selectedObj := self.lstData.listObject;  
	if  selectedObj&lt;&gt; null then
		if selectedObj.isKindOf(CMIF_TMCGroup) then
			selectedObj:=	selectedObj.CMIF_TMCGroup.getRealMapObject;
			if  selectedObj.isKindOf(CM_TranMapSSSummary) then
				self.mnuAudits.visible :=false;
			endif;
		endif;
	
	endif;
	
	return self.showContextMenu(self.menuSItem, listbox, conwin, mouse, x, y);

end;</source>
        <Parameter name="listbox" type="ListBox" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doLstDataDblClick" id="a2c4b99a-efd5-41d3-ad31-1a14043f0ccc">
        <updating/>
        <source>doLstDataDblClick( listbox : ListBox input ) updating;

/*
Purpose:	Expand / collapse all tree branches from clicked level.

Date				Who		Reason
05 November 2009	cnwrl1	Initial creation as part of PAR 20883
*/
	
vars

begin
	app.mousePointer	:=	Busy;
	// if the transaction map is already expanded then collapse it else expand it and child branches.
	if listbox.itemExpanded[ listbox.listIndex ] then
		listbox.itemExpanded[ listbox.listIndex ]	:= false;
	else
		listbox.cnEcExpandItem( listbox.listIndex, true );
	endif;
	
epilog
	app.mousePointer	:=	Idle;
	self.currentLineRow := 0;
end;
</source>
        <Parameter name="listbox" type="ListBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doLstDataKeyDown" id="797e9c36-8959-44dc-844b-12de8f524392">
        <updating/>
        <source>doLstDataKeyDown(listbox: ListBox input; keyCharCode: Integer io) updating;

vars
	i		: Integer;
	keyCode : Integer;
begin
	keyCode := keyCharCode;
	if keyCode = J_key_RightArrow then
		if  listbox.itemPictureType[listbox.listIndex] = 2 then
			keyCode := 0;
		else
			if not listbox.itemExpanded[listbox.listIndex] then 
				listbox.pictureClick(listbox, listbox.listIndex, listbox.listIndex);
				keyCode := 0;
			endif;
		endif;
	elseif keyCode = J_key_LeftArrow then
		if  listbox.itemPictureType[listbox.listIndex] = 1 then
			listbox.pictureClick(listbox, listbox.listIndex, listbox.listIndex);
		else
			i := listbox.listIndex;
			while i &gt; 1 do			
				i := i - 1;
				if listbox.itemLevel[i] &lt; listbox.itemLevel[listbox.listIndex] then
					listbox.listIndex := i;
					listbox.click(listbox);
					break;
				endif;
			endwhile;
		endif;
		keyCode := 0;
		
	endif;
end;
</source>
        <Parameter name="listbox" type="ListBox" usage="input"/>
        <Parameter name="keyCharCode" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="doLstDataKeyUp" id="0846db0d-625d-4c29-a29e-19d492ba1e52">
        <updating/>
        <source>doLstDataKeyUp(listbox: ListBox input; keyCharCode: Integer io) updating;

vars
	keyCode : Integer;
begin
	keyCode := keyCharCode;
	if keyCharCode = J_key_NumPadMinus and
	   listbox.itemExpanded[listbox.listIndex] or
	   keyCharCode = J_key_NumPadPlus and
	   not listbox.itemExpanded[listbox.listIndex] then
		listbox.pictureClick(listbox, listbox.listIndex, listbox.listIndex);
	endif;
end;
</source>
        <Parameter name="listbox" type="ListBox" usage="input"/>
        <Parameter name="keyCharCode" type="Integer" usage="io"/>
    </JadeMethod>
