    <JadeMethod name="drawGridBottomColHeaderTopDown" id="efb76553-dd1a-442a-abb8-d0f3bfd03ef5">
        <source>drawGridBottomColHeaderTopDown(_x1, _y1, _x2, _y2 : Real; _frame : Frame input; _scaleFactor : Real;  _isLandScape, _flipH, _flipV : Boolean; _mode : Integer; _isGapCol : Boolean)protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21/06/2011	cnwdz2	Initial creation 27732
29 May 2012 cnwer1	PAR 29588
*/
vars
	lc 				: CM_LocationsController;
	gridLc			: CM_GridController;
	headerX, headerY,
	noAccessDrawY,
	widthPixels	: Real;
	label 	: String;
	labelTextHeight : Real;
	forkLiftStack : CM_ForkLiftStack;
	tmpTA	: CM_GridArea;
	gridRow 	: CM_GridRow;
begin	
	if  _frame = null then
		return;
	endif;
	
	lc := self.getLocationController();
	if lc = null or not lc.isKindOf(CM_GridController) then
		return;
	endif;
	
	gridLc := lc.CM_GridController;
	
	tmpTA := gridLc.getMyTerminalArea.CM_GridArea;
	//17/06/2011 cnwdz2 27732
	if tmpTA.isKindOf(CM_ForkLiftStack) then
		forkLiftStack := tmpTA.CM_ForkLiftStack;
	endif;
	gridRow:=gridLc.myGridRow;
	
	if _isLandScape then
		widthPixels := self.getSizeInPixels(self.heightFt, _scaleFactor);
		label := gridLc.getColumnLabel(true);
	else
		widthPixels := self.getSizeInPixels(self.widthFt, _scaleFactor);
		label := gridLc.getRowLabel();
	endif;
	
	//08/10/2010 cnwdz2 par25671
	if lc.isGap() then
		if _isGapCol then
			widthPixels := lc.getGapWidthPixels(widthPixels);
		endif;
	endif;
	
	if _flipH then 
		headerX := _x2 - widthPixels/2;
	else
		headerX := _x1 + widthPixels/2;		
	endif;

	labelTextHeight := _frame.drawTextHeight(label);
	
	if _flipV then
		headerY := _y2 + (_y2-_y1)/2 - labelTextHeight/2;
	else
		headerY := _y1 + (_y2-_y1)/2 - labelTextHeight/2;
	endif;
	
	_frame.drawTextAlign := Frame.DrawTextAlign_Center;
	_frame.drawTextAt(label, headerX, headerY, Black);
			
	//17/06/2011 cnwdz2 27732
	if forkLiftStack &lt;&gt; null and _isLandScape  then 
		// col lcs passed in are always for the top row because this is the bottom label row test is oppposite to the top col headings
		if	((not forkLiftStack.accessFront and gridLc.myGridRow.row = tmpTA.allGridRows.size)  or
			(not forkLiftStack.accessBack and gridLc.myGridRow.row = 1 )) then
	
			if _flipV then 
				noAccessDrawY := _y2+1;
			else			
				noAccessDrawY := _y1+1;
			endif;
			_frame.drawWidth := 3;
			_frame.drawLine(_x1,noAccessDrawY,_x2,noAccessDrawY,Red);		
		endif;
	endif;		

end;</source>
        <access>protected</access>
        <Parameter name="_x1" type="Real"/>
        <Parameter name="_y1" type="Real"/>
        <Parameter name="_x2" type="Real"/>
        <Parameter name="_y2" type="Real"/>
