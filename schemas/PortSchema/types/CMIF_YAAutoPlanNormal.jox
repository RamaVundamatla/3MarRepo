    <JadeMethod name="isSrcTermAreaType_Match" id="5251d928-8801-43a7-a37f-221e58c67e89">
        <source>isSrcTermAreaType_Match(_yaData: CM_YADataObjects): Boolean;
// -------------------------------------------
// Created 27 May 2005 by cnwdvb1
// -------------------------------------------
vars

	terminalArea : CM_TerminalArea;
	type: CM_TerminalAreaType;
	lc : CM_YardController;
begin
	// Only priorities will be empty.
	if _yaData.isEmpty() then
		return true;
	endif;

	terminalArea := self.myTrackedItem.myTerminalArea;
	
	if terminalArea = null then
		if self.myTrackedItem.isOnShip then   // PAR 25693
			type := app.myRoot.allTerminalAreaTypes[TA_TYPE_CRANE_TRANS];
		endif;
		
		//epr par 32208 23/9/13
		lc := self.myTrackedItem.getLastTALocation;
		if lc &lt;&gt; null then
			terminalArea:= lc.myTerminalArea;
			if terminalArea &lt;&gt; null then
				type:= terminalArea.myType;
			endif;
		endif;
	else
		type := terminalArea.myType;
	endif;

	if type = null then
		return false;
	endif;
	
	return _yaData.matches(type);


end;</source>
        <Parameter name="_yaData" type="CM_YADataObjects"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isSrcTermArea_Match" id="b7e98127-45bb-4288-a4b8-d7cfdf3b09ba">
        <source>isSrcTermArea_Match(_yaData: CM_YADataObjects): Boolean;
// -------------------------------------------
// Created 27 May 2005 by cnwdvb1
// -------------------------------------------
//9/09/2019 	JLGNS1	Bug 46452: PEN - Testing Error

vars

	terminalArea	: CM_TerminalArea;
	job				: CM_VoyageJob;
	crane			: CM_Machine;
	terminal		: CM_Terminal;
	vehicle			: CM_Vehicle;
	gateIn			: CM_Gate;
	lc 				: CM_YardController;
	location 		: CM_LocationsController;//Bug 46452
	tilc 			: CM_TILC;				 //Bug 46452

begin

	// Only priorities will be empty.
	if _yaData.isEmpty() then
		return true;
	endif;

	terminalArea := self.myTrackedItem.myTerminalArea;

	if terminalArea = null then
		if self.myTrackedItem.isOnShip() then
			foreach job in self.myTrackedItem.allJobsShipReceive discreteLock do
				terminal := job.myTerminal;
				// DVB added terminal comparison. 13/07/07
				if terminal &lt;&gt; null and terminal = self.myTerminal then
					foreach crane in terminal.machines discreteLock where crane.machineType = MACHINETYPE_PORTAINER_CRANE  do
						if crane = job.getJobCrane then
							if _yaData.isEmpty() or _yaData.matches(crane.CM_Crane.transferArea) then
								return true;
							endif;
						endif;
					endforeach;
				endif;
			endforeach;
		endif;
		if self.myTrackedItem.isOnTruck() then   // PAR 25237
			location := self.myTrackedItem.myPrimaryActualLocation;							//Bug 46452
			if location.isKindOf(CM_VehicleController) then									//Bug 46452
				vehicle := location.CM_VehicleController.vehicle;							//Bug 46452
			elseif location.isKindOf(CM_TILCRow) then										//Bug 46452
				tilc := location.CM_TILCRow.myTILC;											//Bug 46452
				if tilc &lt;&gt; null then														//Bug 46452
					vehicle := tilc.myPrimaryActualLocation.CM_VehicleController.vehicle;	//Bug 46452
				endif;																		//Bug 46452
			endif;																			//Bug 46452
			if vehicle &lt;&gt; null then															//Bug 46452
				gateIn := vehicle.getGateIn();
				if gateIn &lt;&gt; null then
					terminalArea := gateIn.getFirstAGate_IN();
					return _yaData.matches(terminalArea);
				endif;
			endif;
		endif;
		
		//epr par 32208 23/9/13
		lc := self.myTrackedItem.getLastTALocation;
		if lc &lt;&gt; null then
			terminalArea:= lc.myTerminalArea;
			return _yaData.matches(terminalArea);
		endif;
		
		return false;
	endif;
	
	
	return _yaData.matches(terminalArea);


end;</source>
        <Parameter name="_yaData" type="CM_YADataObjects"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isStops_Match" id="0853918a-d7b6-44c8-9d29-782b31ea2718">
        <source>isStops_Match(_yaData: CM_YADataObjects): Boolean;
// -------------------------------------------
// Created 27 May 2005 by cnwdvb1
//
// Changed for PAR 20395 to also check for pending Stops.
// -------------------------------------------
vars
	stop 		: CM_Stops;
	tmpStops	: CM_StopsByIdDict;
	
begin
	if self.myTrackedItem.state &lt;&gt; TI_STATE_NORMAL then
		// TI is NOT on-site, so need to check any pending stop requests
		// that maybe applly/remove stops when it is received.
		return self.isStops_Match_IfOffsite(_yaData);
	endif;
	
	// Changes below MAY also need to be made in isStops_Match_IfOffsite method.
	
//	tmpStops := self.myTrackedItem.getAllStops();
	create tmpStops transient;
	self.myTrackedItem.getAllActiveStops( tmpStops );
	if tmpStops.isEmpty() then
		return false;
	endif;
	
	// Only priorities will be empty.
	if _yaData.isEmpty() then
		return true;
	endif;
	
	foreach stop in tmpStops discreteLock do
		if _yaData.matches(stop.myStopsTable) then
			return true;
		endif;
	endforeach;
	
	return false;
	
epilog
	delete tmpStops;
	
end;</source>
        <Parameter name="_yaData" type="CM_YADataObjects"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isStops_Match_IfOffsite" id="dc135307-c0d5-49f0-852c-a3d8bac08404">
        <source>isStops_Match_IfOffsite(_yaData: CM_YADataObjects): Boolean protected;
/* -------------------------------------------
	Created 29 Sep 2009   CNWRS2
	
	If ti is off-site then need to also consider any pending stop requests
	
	This method was implemented for PAR 20395.
-------------------------------------------*/
vars
	stop 			: CM_Stops;
	stopTable		: CM_StopsTable;
	tmpStops		: CM_StopsByIdDict;
	tmpStopsTable	: CM_StopsTableSet;
	
begin
	create tmpStopsTable transient;
	
//	tmpStops := self.myTrackedItem.getAllStops();	// cnwrl1 15/12/2009 PAR 21889 - what it was
	create tmpStops transient;
	self.myTrackedItem.getAllActiveStops( tmpStops );
	
	foreach stop in tmpStops do
		tmpStopsTable.add(stop.myStopsTable);
	endforeach;

	self.myTrackedItem.myTerminal.getPendingEventRequestStops(self.myTrackedItem, tmpStopsTable);

	// from old method

	if tmpStopsTable.isEmpty() then
		return false;
	endif;
	
	// Only priorities will be empty.
	if _yaData.isEmpty() then
		return true;
	endif;
	
	foreach stopTable in tmpStopsTable discreteLock do
		if _yaData.matches(stopTable) then
			return true;
		endif;
	endforeach;
	
	return false;
epilog
	delete tmpStopsTable;
	delete tmpStops;
	
end;
</source>
        <access>protected</access>
        <Parameter name="_yaData" type="CM_YADataObjects"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isSubTerminal_Match" id="82dc0618-d77d-4f3f-8d96-e7eebb9ca78c">
