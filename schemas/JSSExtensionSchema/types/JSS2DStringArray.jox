    <JadeMethod name="clear" id="9d9c6e0f-354b-4bdb-a4d3-f1fcd623d8fa">
        <lockReceiver/>
        <updating/>
        <source>clear() updating, lockReceiver;
// --------------------------------------------------------------------------------
// Created:		06 September 2002 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	inheritMethod();
	self.secondArray.clear();
end;</source>
    </JadeMethod>
    <JadeMethod name="jssAdd" id="e89e8deb-c4b2-4448-8046-dcf84f48a46e">
        <lockReceiver/>
        <updating/>
        <source>jssAdd(pFirstValue:String; pSecondValue:String) lockReceiver, updating;
// --------------------------------------------------------------------------------
// Created:		06 September 2002 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.add(pFirstValue);
	self.secondArray.add(pSecondValue);
end;</source>
        <Parameter name="pFirstValue" type="String"/>
        <Parameter name="pSecondValue" type="String"/>
    </JadeMethod>
    <JadeMethod name="jssChange" id="44b5f1bc-0b32-4187-b565-27239ade82a6">
        <source>jssChange(pFirstValue:String; pSecondValue:String io; pPos:Integer);
// --------------------------------------------------------------------------------
// Created:		06 September 2002 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if pPos &lt;= self.size() then
		self[pPos]				:=	pFirstValue;
		self.secondArray[pPos]	:=	pSecondValue;
	endif;
end;</source>
        <Parameter name="pFirstValue" type="String"/>
        <Parameter name="pSecondValue" type="String" usage="io"/>
        <Parameter name="pPos" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="jssGet" id="842af200-e992-4f5b-8a31-d13bb32c3193">
        <source>jssGet(pFirstValue:String io; pSecondValue:String io; pPos:Integer);
// --------------------------------------------------------------------------------
// Created:		06 September 2002 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if pPos &lt;= self.size() then
		pFirstValue		:=	self[pPos];
		pSecondValue	:=	self.secondArray[pPos];
	endif;
end;</source>
        <Parameter name="pFirstValue" type="String" usage="io"/>
        <Parameter name="pSecondValue" type="String" usage="io"/>
        <Parameter name="pPos" type="Integer"/>
    </JadeMethod>
