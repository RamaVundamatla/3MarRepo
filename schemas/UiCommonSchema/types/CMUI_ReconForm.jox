    <JadeMethod name="resize" id="6531ab93-6467-4ee0-91c1-2c0fa4ee0c5f">
        <controlMethod name="Form::resize"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>resize() updating;
//09 October 2009	cnwml2


vars

begin

	//+cnwml2 PAR21101
	if self.sptRight.getMyRightControl.width &lt;= self.sptRight.getMyRightControl.getMinimumWidth then
		self.sptRight.getMyRightControl.width := self.sptRight.getMyRightControl.getMinimumWidth + 5;
		self.width := self.frmExpected.width.Integer + self.frmActual.width.Integer + self.sptRight.getMyRightControl.width + 20;
	else
		self.sptRight.getMyRightControl.width := self.width - (self.frmExpected.width.Integer + self.frmActual.width.Integer + 20);
	endif;
	
epilog

end;</source>
    </JadeMethod>
