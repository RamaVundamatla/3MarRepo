        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doNewSubDeck" id="f64bd133-ea76-4abb-8f08-a8d49658d417">
        <source>doNewSubDeck() protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
01 June 2011	cnwer1	Initial creation CCMS MES 1116

*/

vars

	deck : CM_DeckVoyage;
begin

	if self.tbRoRolDecks.accessRow(self.tbRoRolDecks.row) = null then
		return;
	endif;
	deck:=self.tbRoRolDecks.accessRow(self.tbRoRolDecks.row).itemObject.CM_DeckVoyage;
	
	if deck &lt;&gt; null then
		if deck.isKindOf(CM_DeckVoyageSub) then
			deck:=deck.CM_DeckVoyageSub.myParentDeck;
		endif;
		self.myAssistant.SHP_Assistant.showROROVoyageDeckDefn(deck,null,SHP_RORODeckDefinitionForm.Mode_New);
	endif;

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doOpenDeck" id="55746ce1-18a6-41f0-a390-1e6de8c922fe">
        <source>doOpenDeck(_deck: CM_DeckVoyage) protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
01 June 2011	cnwer1	Initial creation CCMS MES 1116

*/

vars

begin
	self.myAssistant.SHP_Assistant.showROROVoyageDeckDefn(self.myROROVoyageStructure,_deck,SHP_RORODeckDefinitionForm.Mode_View);


epilog

end;</source>
