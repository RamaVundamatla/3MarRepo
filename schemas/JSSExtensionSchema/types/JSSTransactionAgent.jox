    <ImplicitInverseRef name="allRegisteredErrors" id="2ff922c5-a0e2-4e38-bffc-b13c42003d0a">
        <memberTypeInverse/>
        <type name="JSSArray"/>
        <access>protected</access>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="allRegisteredObjects" id="897f5e94-fbe3-4561-966a-a420cf25c137">
        <memberTypeInverse/>
        <type name="ObjectArray"/>
        <access>protected</access>
    </ImplicitInverseRef>
    <PrimAttribute name="lastError" id="d17923e1-9f9a-4527-bc41-9cadf0710fee">
        <type name="String"/>
        <access>protected</access>
    </PrimAttribute>
    <JadeMethod name="agentExceptionHandler" id="9efd2cdc-8b90-44c2-a58f-45a09edfa15d">
        <updating/>
        <source>agentExceptionHandler(pExceptionObject:Exception):Integer updating, protected;
// --------------------------------------------------------------------------------
// Purpose:		Base exception handler for TransactionAgents.
//              It translates object not found errors and object deleted errors for
//              registered objects into model error codes. Deadlock exceptions are
//              returned as ResourceLocked errors. For all other exceptions it
//              simply captures the exception error code.
//              Note that we don't abort the transaction here.
//              It's the responsibility of each specific TransactionAgent subclass
//              to do so if required.
//
// Parameters:	The exception object.
//
// Returns:		Ex_Resume_Next for all exceptions to pass control back to the top-
//              level activity method.
// --------------------------------------------------------------------------------
constants
	OBJECT_NOT_FOUND	: Integer = 4;
	OBJECT_DELETED		: Integer = 1072;

vars
	errorIndex		: Integer;
	errorObject		: Object;
	errorMessage	: String;

begin
	abortTransaction;

	// If we have an object not found or object deleted error we must check to see if
	// it's for one of our registered objects.
	if pExceptionObject.errorCode = OBJECT_NOT_FOUND or pExceptionObject.errorCode = OBJECT_DELETED then
		errorIndex	:=	1;

		// Get each registered object.
		foreach errorObject in self.allRegisteredObjects do
			// Is this the one the error is for?
			if pExceptionObject.errorObject() = errorObject then
				// Yes, so set our error code to the registered error and return.
				self.lastError	:=	self.allRegisteredErrors.getStringAt(errorIndex);
				return Ex_Resume_Next;
			endif;

			errorIndex	:=	errorIndex + 1;
		endforeach;
	endif;

	if pExceptionObject.isKindOf(DeadlockException) then
		// Return ResourceLocked for deadlock exceptions.
		self.lastError	:=	"Object is locked by another Process.";
	else
		// Not an error 4 or 1072 for one of our registered objects, or a deadlock.
		// Just capture the exception error code.
		errorMessage	:=	pExceptionObject.errorItem;
		
		if errorMessage = null then
			errorMessage	:=	process.getErrorText(pExceptionObject.errorCode);
		endif;
		
		self.lastError	:=	errorMessage;
	endif;

	// Resume to the next statement in the method that armed the exception handler.
	return Ex_Resume_Next;
end;</source>
        <access>protected</access>
        <Parameter name="pExceptionObject" type="Exception"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="agentInitializeActivity" id="4ada40a4-f885-4448-afe8-a85247ffbb95">
        <updating/>
        <source>agentInitializeActivity() updating, protected;
// --------------------------------------------------------------------------------
// Created:		03 June 2000 by cnwdad2
//
// Purpose:		Initialize the TransactionAgent by clearing the error message and
//              the registered object and error message collections.
//              This should be called at the start of every public activity
//				(transaction) method.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.lastError	:=	null;
	self.allRegisteredObjects.clear();
	self.allRegisteredErrors.clear();
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="agentLockExceptionHandler" id="03963573-5ba1-4e49-8f00-da00e029f4ce">
        <updating/>
        <source>agentLockExceptionHandler(pTheLockException:LockException):Integer updating, protected;
// --------------------------------------------------------------------------------
// Purpose:		Base lock exception handler for TransactionAgents. It prompts the
//              user to retry the lock and will continue doing so until the lock
//              is obtained, or the user cancels the operation. If the lock is not
//              obtained the error code is set to the error code of the exception.
//
// Parameters:	The lock exception object.
//
// Returns:		Ex_Continue if the lock is obtained; Ex_Resume_Next if it isn't.
// --------------------------------------------------------------------------------
vars
	lockedByUser	: String;
	retryCount		: Integer;

begin
	// Prompt the user so they can retry or cancel the operation using the common
	// lock exception handler message box from CommonSchema (click so that the
	// cursor is over "lockExceptionHandlerMsgBox" and press F11 to bring up the
	// code for this method).

	retryCount	:=	0;

	// Build a string representing the user/process that holds the lock.
	if pTheLockException.targetLockedBy.userCode &lt;&gt; null then
		lockedByUser	:=	"user " &amp; pTheLockException.targetLockedBy.userCode;
	else
		lockedByUser	:=	"an unknown user ";
	endif;

	if currentSession &lt;&gt; null then
		// We're running over the web so we don't want to put up an interactive
		// message or allow the user to retry. Just give a general error message
		// and return false.
		app.msgBox(	"Operation cannot proceed because a resource is locked." &amp; CrLf &amp; CrLf &amp;
					"Click OK to cancel the current operation.",
                   "Resource Locked",
                   MsgBox_OK_Only);
	else
		while true do
			// Prompt the user.
			if app.msgBox(	"Object " &amp; getOidStringForObject(pTheLockException.lockTarget()) &amp;
							" is locked by " &amp; lockedByUser &amp; "." &amp; CrLf &amp; CrLf &amp;
							"Retries: " &amp; retryCount.String &amp; CrLf &amp; CrLf &amp;
							"Do you want to retry or cancel the operation?",
							"Resource Locked",
							MsgBox_Retry_Cancel + MsgBox_Exclamation_Mark_Icon) = MsgBox_Return_Retry
	        then
	        	// We're to retry the lock.
				retryCount	:=	retryCount + 1;
				// tryLock attempts to lock an object but returns a boolean indicating success or
				// failure instead of raising an exception.
				if tryLock(pTheLockException.lockTarget, pTheLockException.lockType, pTheLockException.lockDuration, LockTimeout_Immediate) then
					// We got the lock
					return Ex_Continue;
				endif;
			else
				// Had enough of retrying
				break;
			endif;
		endwhile;
	endif;

	// The user wants to cancel the operation. Set the error code and return.
	self.lastError	:=	pTheLockException.errorItem;
	abortTransaction;
	return Ex_Resume_Next;
end;</source>
        <access>protected</access>
        <Parameter name="pTheLockException" type="LockException"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="agentRegisterObjectAndError" id="f581a98d-b093-48e7-875e-da3c52205a03">
        <source>agentRegisterObjectAndError(pTheObject:Object; pError:String) protected;
// --------------------------------------------------------------------------------
// Purpose:		Registers object and error code pairs for the TransactionAgent
//              exception handlers.  See the agentExceptionHandler method.
//
// Parameters:	pTheObject - the object to register.
//              pError - the error message to be raised if an exception is caught
//                       for the supplied object.
// --------------------------------------------------------------------------------
begin
	self.allRegisteredObjects.add(pTheObject);
	self.allRegisteredErrors.addString(pError);
end;</source>
        <access>protected</access>
        <Parameter name="pTheObject" type="Object"/>
        <Parameter name="pError" type="String"/>
    </JadeMethod>
    <JadeMethod name="agentSetError" id="9c41122d-a457-4986-bca3-4bb468be2cd4">
        <updating/>
        <source>agentSetError(pErrorMessage:String):String updating, protected;
// --------------------------------------------------------------------------------
// Created:		03 June 2000 by cnwdad2
//
// Purpose:		Helper routine to set and return the specified error code.
//              Allows us to write code linke:
//                  return agentSetError("&lt;error message&gt;");
//
// Parameters:	pErrorMessage - the error message to set.
//
// Returns:		The supplied error message.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.lastError	:=	pErrorMessage;
	return pErrorMessage;
end;</source>
        <access>protected</access>
        <Parameter name="pErrorMessage" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="agentUnregisterObject" id="cc57c537-8995-4424-9266-cc17ef7d2d6f">
        <source>agentUnregisterObject(pUnregisterObject:Object) protected;
// --------------------------------------------------------------------------------
// Created:		03 June 2000 by cnwdad2
//
// Purpose:		Unregister all object and error pairs for the supplied object.
//              For a details about object an error code registration, refer to
//              the agentRegisterObjectAndError and agentExceptionHandler methods.
//
// Parameters:	The object to unregister.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	registeredObjectCount	: Integer;
	errorIndex				: Integer;

begin
	registeredObjectCount	:=	self.allRegisteredObjects.size();
	errorIndex				:=	1;

	// Go through all registered objects.
	while errorIndex &lt;= registeredObjectCount do
		// If the object the one we're looking for?
		if self.allRegisteredObjects[errorIndex] = pUnregisterObject then
			// Yes, so remove the object and its error code.
			self.allRegisteredObjects.removeAt(errorIndex);
			self.allRegisteredErrors.removeAt(errorIndex);
			// Remain at our current index as all entries in the arrays will have
			// been moved down one position because of the remove, but we've now
			// got one less element in each array.
			registeredObjectCount	:=	registeredObjectCount - 1;
		else
			// No, so on to the next array element.
			errorIndex	:=	errorIndex + 1;
		endif;
	endwhile;
end;</source>
        <access>protected</access>
        <Parameter name="pUnregisterObject" type="Object"/>
    </JadeMethod>
    <JadeMethod name="create" id="adffccf6-1169-4a0a-b4bc-3f4188bbccff">
        <updating/>
        <source>create() updating;
// --------------------------------------------------------------------------------
// Created:		05 September 2002 by cnwdad1
//
// Purpose:		Enforces the rule that persistent CnEcAgent instances are not allowed.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if not self.isTransient then
		JSSException.raise_(JSS_X_03001, "Persistent instances of a Transaction Agent class are not permitted.");
	endif;
end;</source>
    </JadeMethod>
</Class>
