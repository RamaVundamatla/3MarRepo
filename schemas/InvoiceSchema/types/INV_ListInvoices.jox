    <JadeMethod name="refreshInvoice" id="ddd60196-2a1a-45bf-97ef-cd7f3aaa42e7">
        <updating/>
        <source>refreshInvoice( _inv : CM_Invoice ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 September 2017	jlgndl1	Initial creation

*/

vars

	row : Integer;
	dataString : String;

begin

	if self.myCurrentInvoice = _inv and _inv &lt;&gt; null then
		//needs to be re-displayed in the table. At least status, and teh new refs to posted  invs and pending invs.
		row := self.tblData.row;
		if self.tblData.accessRow( row ).itemObject = _inv then
		
			dataString := _inv.getAttributeStringForDefArray(self.tblData.allTblDataEntRows);
			self.tblData.setCellText( row, 1, dataString );
			self.doFilterVisibilityForNote( self.tblData, row );
			
			if _inv.myReversedCreditInvoice &lt;&gt; null then
				self.doQueryAddItem( _inv.myReversedCreditInvoice );
			endif;
			
			if _inv.myReversedPendingInvoice &lt;&gt; null then
				self.doQueryAddItem( _inv.myReversedPendingInvoice );
			endif;
			
		endif;
		
	endif;

epilog

end;</source>
        <Parameter name="_inv" type="CM_Invoice"/>
    </JadeMethod>
