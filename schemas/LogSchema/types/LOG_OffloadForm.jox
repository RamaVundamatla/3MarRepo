    <JadeMethod name="tblSelectData_contextMenu" id="4869ff2f-2d29-450f-8399-8782b4c89129">
        <controlMethod name="Table::contextMenu"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblSelectData_contextMenu(table: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating;
// -------------------------------------------
// Created 07 July 2004 by cnwdvb1
// -------------------------------------------

vars
	x1 : Real;
	y1 : Real;
begin

	x1 := x;
	y1 := y;
	if (not mouse) then  // if keyboard, use current listIndex value
	    x1 := 20;
	    if table.row &lt; 0 then
	        y1 := 5;
	    else
	        y1 := table.positionTop();
	    endif;
	endif;

	conwin.windowToScreen(x1, y1);
	self.screenToWindow(x1, y1);   // convert x, y relative to form
	self.popupMenu(self.mnuColumnOrganiser, x1.Integer, y1.Integer);
	return false;                  // cancel further processing

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="tblSelectData_dblClick" id="519e3973-280a-4df4-8568-e8a16174b7e6">
        <controlMethod name="CM_DataTable::dblClick"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblSelectData_dblClick(table: Table input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
11 September 2008	#cnwdz2	 15385 add the ability to double-click to sort the table for ease of use.

*/

vars

begin
	if table.row &gt; table.fixedRows then
		return;
	endif;
	self.tblSelectData.resortTableByColumn(table.column);
	self.tblSelectData.colourRows(self.colorRow1, self.colorRow2);	
epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
