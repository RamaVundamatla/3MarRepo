/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 July 2023 navtnr20	TFS CR 58233	Task 58238: UI - Notifications
*/

vars

begin
	self.endNotificationForSubscriber(self.myOwnershipChange);

	self.beginNotification(self.myOwnershipChange, self.myTerminal.getTerminalEvent(Event_COODtlCreate), Response_Continuous, null);
	self.beginNotification(self.myOwnershipChange, self.myTerminal.getTerminalEvent(Event_COODtlUpdate), Response_Continuous, null);
	self.beginNotification(self.myOwnershipChange, self.myTerminal.getTerminalEvent(Event_COODtlDelete), Response_Continuous, null);
epilog

end;</source>
