    <JadeMethod name="btnBrowse_click" id="46127c1d-a620-4a3e-9739-496a35955394">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnBrowse_click(btn: Button input) updating;
// ---------------------------------------------------------------------------
// Created:     23 January 2007 by #usercode
//
// Purpose:     
//31 Mar 2022			navhl20  TFS 53185 Screen validation issue for File Attachment
// 13 Dec 2022			navvt20  Defect 55796: MTN - can only add a single document at a time
// ---------------------------------------------------------------------------
vars
	//dlg : CMDFileOpen;
	int : Integer;
	title : String;
begin
	//create dlg transient; // 13 Dec 2022 navvt20 TFS 55796
	create self.file transient;
	//dlg.open;		// 13 Dec 2022 navvt20 TFS 55796
	// Start 13 Dec 2022 navvt20 TFS 55796
	self.file.allowMultiSelect := true;
	if self.file.open = 0 then
		self.count := self.file.getMultiSelectCount();
		if self.count &lt; 2 then
			self.txtFileName.text := self.file.fileTitle;
		elseif self.count &gt; 10 then	// 15 Dec 2022 navvt20 TFS 55796
			app.msgBox(app.getErrorString(Only_Ten_files_attache_time),app.getErrorString(Warning),MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);// 15 Dec 2022 navvt20 TFS 55796
			return;// 15 Dec 2022 navvt20 TFS 55796
		else
			foreach int in 1 to self.count do 
				if title &lt;&gt; null then
					title := title &amp; ",";
				endif;
				title:= title &amp; self.file.getMultiSelectFileTitle(int);
			endforeach;
			self.txtFileName.text := title;
		endif;
	endif;
	//txtFileName.text := dlg.fileTitle;//fileName;		
	if self.txtFileName.text &lt;&gt; null then                 //TFS 53185
		self.btnOk.enabled := true;                       //TFS 53185
	endif;                                                //TFS 53185
	// End 13 Dec 2022 navvt20 TFS 55796
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="create" id="b2d08e5d-0764-4b43-9a84-b9335245a96b">
        <updating/>
        <source>create() updating;
//----------------------------------------------------------------------
//
//  Created by cnwsh3
//
//	Date 23 January 2007
//
//----------------------------------------------------------------------

vars

begin
	
	//app.writeStatement('TO DO - Need to set up permissions for CMUI_FileLoad form at some stage - Anca reminder');
	self.permissionView  := PmShipFileLoadView;
	self.permissionMaint := PmShipFileLoadMaint;

end;</source>
    </JadeMethod>
    <JadeMethod name="doOK" id="5804e734-7259-4edd-b579-1bc2372054f7">
        <updating/>
        <source>doOK() updating;
// ---------------------------------------------------------------------------
// Created:     23 January 2007 by #usercode
//
// Purpose:     
// ---------------------------------------------------------------------------
// 01 Dec 2022 navvt20 TFS CR 55299 Task 55520: UI - File Load and File Attachment UI changes 
// 13 Dec 2022 navvt20	Defect 55796: MTN - can only add a single document at a time
// 15 Feb 2023 navds21 ChangeRequest 56625:[56517] EUP - Print Documents at Kiosk
vars
	int       : Integer;
	title     : String;
	theReturn : Integer;
	context   : Integer;
begin

	app.mousePointer := MP_HOURGLASS;				// 15 Dec 2022 navvt20 TFS 55796

	if self.chkAutoPrint.value then					//22.2.2023 navhl20	#56625[56517]
		context := FileContext_AutoPrintOnKiosk;
	else
		context := FileContext_Null;
	endif;
	
	// ### TFS DEFECT 56155 13JAN2023 NAVAB1 wrap TRX call in while loop to show errors.
	while true do
		if self.count &lt; 2 then
		app.myTrxUA.trxAddFile(self.myMasterObject, txtFileName.text, txtDescription.text, txtHeading.text, self.cmbCategory.listObject.CM_FileDataCategory,txtRemarks.text,context ,app.myPassport); //22.2.2023 navhl20 #56625[56517]
		
		else
			foreach int in 1 to self.count do
				title := self.file.getMultiSelectFileTitle(int); // 13 Dec 2022 navvt20 TFS 55796
				app.myTrxUA.trxAddFile(self.myMasterObject, title, txtDescription.text, txtHeading.text, self.cmbCategory.listObject.CM_FileDataCategory,txtRemarks.text,context ,app.myPassport); //22.2.2023 navhl20	#56625[56517]
				if app.myPassport.hasErrorsOrWarnings() then
					break;
				endif;
			endforeach;
		endif;
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			global.beep;
			break;
		else
			theReturn := app.showErrorWarningDialog("File Issue", app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			return;
		endif;
		break;
	endwhile;
	
	
	inheritMethod(); // ### TFS DEFECT 56155 13JAN2023 NAVAB1 moved this to be after so can handle exception messages.

epilog
	//Clean up any notes
	app.mousePointer := MP_DEFAULT; 			// 15 Dec 2022 navvt20 TFS 55796
	self.endNotificationForSubscriber(self);  	// 13 Dec 2022 navvt20 TFS 55796
	delete self.file;  							// 13 Dec 2022 navvt20 TFS 55796
end;</source>
    </JadeMethod>
    <JadeMethod name="editFormDetailsl" id="aa2825ad-cd6d-4723-969d-52a0a7a137c4">
        <source>editFormDetailsl();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
