    <JadeMethod name="addNonRailMove" id="7efab066-6812-49f8-bb62-026a1baf4063">
        <updating/>
        <source>addNonRailMove(	_sourceCont : CM_LocationsController;
				_targetCont : CM_LocationsController;
				_ti : CM_TrackedItem
				) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 November 2009	cnwndl1	Initial creation	Par 21519

*/

vars

	source : String;
	target : String;
	
begin
		
		if _sourceCont.isVehicle then
			source := RoadMoves;
		elseif _sourceCont.isKindOf(CM_VoyageController) or _sourceCont.isKindOf(CM_CraneLaneController) then
			source := ShipMoves;
		else
			source := YardMoves;
		endif;
		
		if _targetCont.isVehicle then
			target := RoadMoves;
		elseif _targetCont.isKindOf(CM_VoyageController) or _targetCont.isKindOf(CM_CraneLaneController) then
			target := ShipMoves;
		else
			target := YardMoves;
		endif;
		
		if source = target then
			// not a load or discharge, just a re-position 
			return;
		endif;
			
		// Ok we have a real move....
		if target = RoadMoves then
			self.addRoadLoad(_ti);
			if source = ShipMoves then
				self.addShipDischarge(_ti);
			elseif source = YardMoves then
				self.addYardPickUp(_ti);
			endif;
			
		elseif target = ShipMoves then
			self.addShipLoad(_ti);
			if source = RoadMoves then
				self.addRoadDischarge(_ti);
			elseif source = YardMoves then
				self.addYardPickUp(_ti);
			endif;
			
		elseif target = YardMoves then
			self.addYardSetDown(_ti);
			if source = RoadMoves then
				self.addRoadDischarge(_ti);
			elseif source = ShipMoves then
				self.addShipDischarge(_ti);
			endif;
			
		endif;
		
epilog

end;</source>
        <Parameter name="_sourceCont" type="CM_LocationsController"/>
        <Parameter name="_targetCont" type="CM_LocationsController"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="addRailMove" id="542f322e-58da-40de-8986-56cbd6c40971">
        <updating/>
        <source>addRailMove(	_sourceCont : CM_LocationsController;
				_targetCont : CM_LocationsController;
				_ti : CM_TrackedItem
				) updating;

/*

Purpose:			
	// only need to process the other leg of these
Parameters:			

Return Value:		


Date		Who		Reason
18 November 2009	cnwndl1	Initial creation	Par 21519

*/

vars

	source : String;
	target : String;
	
begin
		
	if _targetCont = null then // loading a wagon
		if _sourceCont.isVehicle then
			source := RoadMoves;
		elseif _sourceCont.isKindOf(CM_VoyageController) or _sourceCont.isKindOf(CM_CraneLaneController) then
			source := ShipMoves;
		else
			source := YardMoves;
		endif;

	elseif _sourceCont = null then	//discharging a wagon
		if _targetCont.isVehicle then
			target := RoadMoves;
		elseif _targetCont.isKindOf(CM_VoyageController) or _targetCont.isKindOf(CM_CraneLaneController) then
			target := ShipMoves;
		else
			target := YardMoves;
		endif;
		
	endif;
	
	if source = null and target = null then
		// not a load or discharge, just a re-position
		return;
	endif;
		
	// Ok we have a real move....
	if source = RoadMoves then
		self.addRoadDischarge(_ti);
		
	elseif source = ShipMoves then
		self.addShipDischarge(_ti);
		
	elseif source = YardMoves then
		self.addYardPickUp(_ti);
		
	elseif target = RoadMoves then
		self.addRoadLoad(_ti);
		
	elseif target = ShipMoves then
		self.addShipLoad(_ti);
		
	elseif target = YardMoves then
		self.addYardSetDown(_ti);
		
	endif;
		
epilog

end;</source>
        <Parameter name="_sourceCont" type="CM_LocationsController"/>
        <Parameter name="_targetCont" type="CM_LocationsController"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="addRoadDischarge" id="eccfaa52-8c89-4a4d-a86f-3fabc81f5fc1">
        <updating/>
        <source>addRoadDischarge( _ti : CM_TrackedItem ) updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 November 2009	cnwndl1	Initial creation	Par 21519

*/

vars

begin

	if _ti.is20 then
		self.roadDischarge20 := self.roadDischarge20 + 1;
		self.totTeu := self.totTeu  + 1;
	elseif _ti.isForty then
		self.roadDischarge40 := self.roadDischarge40 + 1;
		self.totTeu := self.totTeu  + 2;
	elseif _ti.is30 then
		self.roadDischarge30 := self.roadDischarge30 + 1;
		self.totTeu := self.totTeu  + _ti.getNumTEU.Integer;
	elseif _ti.is45 then
		self.roadDischarge45 := self.roadDischarge45 + 1;
		self.totTeu := self.totTeu  + _ti.getNumTEU.Integer;
	elseif _ti.is53 then
		self.roadDischarge53 := self.roadDischarge53 + 1;
		self.totTeu := self.totTeu  + _ti.getNumTEU.Integer;
	endif;
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
