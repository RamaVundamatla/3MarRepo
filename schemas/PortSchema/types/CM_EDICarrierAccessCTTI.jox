    <JadeMethod name="processCarrierString" id="41bd1e0c-f2e2-4fb7-94d1-2a116168912a">
        <source>processCarrierString(_string : String; _array : StringArray input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 February 2025	navah1	Initial creation

*/

vars
	pos, count : Integer;
	output, carrierCodeStr : String;
begin
	pos := 1;  
	carrierCodeStr := _string;
	while pos &lt;= carrierCodeStr.length do			 
		if carrierCodeStr[pos] = "'" then 			 
			count +=1; 
		elseif carrierCodeStr[pos] = " " and count mod(2) = 1 then
			output := output &amp; self.Temp_Delimiter;
		else
			output := output &amp; carrierCodeStr[pos];
		endif;
		pos += 1;
	endwhile;
	carrierCodeStr := output;				 
	carrierCodeStr := carrierCodeStr.replaceString(Comma, Space);        
	carrierCodeStr := carrierCodeStr.replaceString("  ", Space);
	carrierCodeStr.getTokensForDelimiter(Space, _array); 
epilog

end;</source>
        <Parameter name="_string" type="String"/>
        <Parameter name="_array" type="StringArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="a6a393d8-4175-444f-b2c4-8e412fed5f90">
        <updating/>
        <source>setForUpdate(_proxyEDITI: SelfType) updating;
//
// 08 Aug 2018	jlgrs1	TFS 39619 PEN - Approved Carriers For Operator 
// 12 Aug 2019	jlgdap1	TFS 45836 PEN Approved Carrier for ISO Type and Trailer Type
//
vars
	carrierCodeStr : String;

begin
	inheritMethod(_proxyEDITI);
	self.carrierCodes := _proxyEDITI.carrierCodes;
	
	// remove any commas from carrier codes							// TFS 45836
	carrierCodeStr := self.carrierCodes;							// TFS 45836
	carrierCodeStr := carrierCodeStr.replaceString(",", Space);		// TFS 45836
	carrierCodeStr := carrierCodeStr.replaceString("  ", Space);	// TFS 45836
	self.carrierCodes := carrierCodeStr;							// TFS 45836
	self.cargoSubType := _proxyEDITI.cargoSubType;					// TFS 45836
	self.isoType := _proxyEDITI.isoType;							// TFS 45836
	self.trailerType := _proxyEDITI.trailerType;					// TFS 45836
epilog

end;</source>
        <Parameter name="_proxyEDITI" type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="verifySelf" id="3d23ed38-72af-4c69-af95-3fd877e81dd4">
        <source>verifySelf();
//
// 21 Aug 2018	jlgrs1	TFS 39619 PEN - Approved Carriers For Operator 
// 04 Mar 2019	jlgrs1	TFS 41913 STWR - Reconfiguration of the EDI Operation form to better handle EDI collection locks while loading 
// 20 Aug 2019	jlgdap1	TFS 45836 PEN Approved Carrier for ISO Type and Trailer Type
// 03 Feb 2025	navah1		Bug 33429: MTN - Carrier Access File doesn't work with spaces in the carrier code
vars
	carrier : CM_Carrier;
	cargoTypeObj : CM_CargoType;
	xlOperator : CM_Operator;
	cargoTypeCode : String;
	subType : CM_Product;				// TFS 45836
	iso : CM_ISOType;					// TFS 45836
	trailer : CM_TILCType;				// TFS 45836
	carrierCodeArray : StringArray;		// TFS 45836
	carrierCode : String;				// TFS 45836
	foundMatch : Boolean;				// TFS 45836
	//carrierCodeStr : String;			// TFS 45836  // 03.02.2025 navah1 #33429
begin
	if self.messageMode &lt;&gt; CM_EDITrackedItem.EDI_ACTION_ADD and
	   self.messageMode &lt;&gt; CM_EDITrackedItem.EDI_ACTION_DELETE and
	   self.messageMode &lt;&gt; CM_EDITrackedItem.EDI_ACTION_UPDATE then
		app.raiseCMException1(EDI_Action_Is_Invalid, messageMode, ETRow_Action, self);
		return;
	endif;
	cargoTypeCode := self.cargoTypeDescr;
	cargoTypeObj := self.myEDIData.CM_EDIDataOpCarrierAcessByCT.getCargoType(cargoTypeDescr);
	if cargoTypeObj = null then
		app.raiseCMException1(Cargot_not_valid_cargot_system, cargoTypeCode, null, self);
	endif;
	// TFS 45836
	if self.cargoSubType &lt;&gt; null then
		subType := cargoTypeObj.allProducts[null, self.cargoSubType];
		if subType = null then
			xlOperator := self.myEDIData.getXlationOperator();
			if xlOperator &lt;&gt; null then
				subType := cargoTypeObj.allProducts[xlOperator.code, self.cargoSubType];
			endif;
		endif;
		if subType = null then
			app.raiseCMException2(CargoSubtype_Invalid, cargoTypeCode, self.cargoSubType, null, self);
		endif;
	endif;
	if self.isoType &lt;&gt; null then
		if not cargoTypeObj.isContainer then
			app.raiseCMException(Container_req_for_isotype, null, null);
		endif;
		iso := app.myRoot.allISOTypes[self.isoType];
		if iso = null then
			app.raiseCMException2(ERR_ISOTYPE_FIELD, self.isoType, app.getErrorString(ISO_Type), null, self);
		endif;
	endif;
	if self.trailerType &lt;&gt; null then
		if not cargoTypeObj.isTrailer then
			app.raiseCMException(Chassis_req_for_trailertype, null, null);
		endif;
		trailer := app.myRoot.allTILCTypes[null, self.trailerType];
		if trailer = null then
			app.raiseCMException1(ERR_INVALID_TRAILER_TYPE, self.trailerType, null, self);
		endif;
	endif;
	// TFS 45836 end
	if self.carrierCodes &lt;&gt; null then
		create carrierCodeArray transient;										// TFS 45836
		/*	// 03.02.2025 navah1 #33429
		carrierCodeStr := self.carrierCodes;									// TFS 45836
		carrierCodeStr := carrierCodeStr.replaceString(",", Space);				// TFS 45836
		carrierCodeStr := carrierCodeStr.replaceString("  ", Space);			// TFS 45836
		carrierCodeStr.getTokensForDelimiter(Space, carrierCodeArray);			// TFS 45836
		*/
		self.processCarrierString(self.carrierCodes,carrierCodeArray); 			// 03.02.2025 navah1 #33429
		xlOperator := self.myEDIData.getXlationOperator();						// TFS 45836
		//carrier := self.getCarrier(xlOperator);								// TFS 45836
		foreach carrierCode in carrierCodeArray do								// TFS 45836
			carrierCode := carrierCode.replaceString(self.Temp_Delimiter, Space);				// 03.02.2025 navah1 #33429
			if xlOperator &lt;&gt; null then											// TFS 45836
				carrierCode := xlOperator.getXlationSystemCode(carrierCode, XLATION_TYPE_CARRIER_BYOP, foundMatch);	// TFS 45836
			endif;																// TFS 45836
			carrier := app.myRoot.allCarriers[carrierCode];
			if carrier = null then 
				app.raiseCMWarning2(ERR_FIELD_ID, carrierCode, "Carrier", ETRow_CarrierCodes, null, self);
			endif;
		endforeach;																// TFS 45836
	endif;
epilog
	delete carrierCodeArray;		// TFS 45836
end;</source>
    </JadeMethod>
</Class>
