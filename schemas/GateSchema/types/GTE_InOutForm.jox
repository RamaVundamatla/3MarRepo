    </JadeMethod>
    <JadeMethod name="resizeSheet" id="90338a25-faec-4b4c-9093-22eef28bddf3">
        <source>resizeSheet(pSheet : GTE_Sheet);
// ---------------------------------------------------------------------------
// Created:     07 February 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 10/07/2008	cnwkpd1		PAR #17483 - Tidy up resizing to stop clipping of table
// ---------------------------------------------------------------------------
vars
	indx	: Integer;
	cntrl	: Control;
	delBtn	: Button;
	inputSplitter	: CMUI_SplitContainer;
	mainTbl,
	extraTbl	: CM_EntryTable;
	colWidth	: Integer;
	
begin

	// set the delete button
	// btnDelete is no longer on the sheet (rjs 25/5/01)
//	delBtn 		:= pSheet.getControlByName('btnDeleteSheet').Button;
//	delBtn.top 	:= pSheet.height - VerticalSpacing - delBtn.height;
//	delBtn.left	:= pSheet.width - WinRightMargin - delBtn.width;
			
	// set the split container
	inputSplitter 		:= pSheet.getControlByName('sptInput').CMUI_SplitContainer;
	inputSplitter.top	:= 0;//WinTopMargin/2;
	inputSplitter.left	:= 0;//WinLeftMargin/2;

	//	inputSplitter.height := delBtn.top - (VerticalSpacing * 2);
//	inputSplitter.height := pSheet.height;// - WinTopMargin;
//	inputSplitter.width	 := pSheet.width;// - WinLeftMargin;
	inputSplitter.height := pSheet.clientHeight;//pSheet.height;// - WinTopMargin;		// PAR #17483
	inputSplitter.width	 := pSheet.clientWidth;//pSheet.width;// - WinLeftMargin;
	
	inputSplitter.cnEcResizeContents();
		
	mainTbl 	:= pSheet.myTblMain;
	extraTbl 	:= pSheet.myTblExtra;
	
	self.myAssistant.GTE_Assistant.mainExtraSplitterRatio(mainTbl, extraTbl, inputSplitter);

end;</source>
        <Parameter name="pSheet" type="GTE_Sheet"/>
    </JadeMethod>
    <JadeMethod name="saveChassisReleaseActionType" id="8e983589-039a-4fe1-8c5b-f817a8969342">
        <updating/>
        <source>saveChassisReleaseActionType(_chassis : CM_TIMaster) : CMIF_TIObject updating;
//----------------------------------------------------------------------
//
//  Created by cnwsh3
//
//	Date 14 August 2007
//
//----------------------------------------------------------------------

vars
	cmifObj : CMIF_TIObject;
	cargoType : CM_CargoType;
	releaseByID	: CMIF_ReleaseById;
	cmifReleaseType : CMIF_ReleaseByType;
	cargoTypeId : Integer;
begin
	if _chassis = null then
		create cmifObj as CMIF_ReleaseByType transient;
	else
		create cmifObj as CMIF_ReleaseById transient;
	endif;
	
	cmifObj.myTerminal := self.myTerminal;
	if cmifObj.isKindOf(CMIF_ReleaseByType) then
		cmifReleaseType := cmifObj.CMIF_ReleaseByType;
		cmifReleaseType.isLCRelease := true;
		cmifReleaseType.quantity := 1;
		cmifReleaseType.isoType := 'CHAS';
		if self.cmbOpChassis.listObject &lt;&gt; null then
			cmifReleaseType.operatorCode := self.cmbOpChassis.listObject.CM_Operator.code;
		endif;
		if self.cmbTILCType.listObject &lt;&gt; null then
			cmifReleaseType.myCargoType := self.cmbTILCType.listObject.CM_TILCType.myCargoType;
		endif;
	else
		releaseByID := cmifObj.CMIF_ReleaseById;
		releaseByID.id := _chassis.id;//self.cmbTILCOut.text;
		releaseByID.cargoType := _chassis.cargoType;
		releaseByID.setMyTrackedItem(true);
	endif;
	
	return cmifObj;
epilog

end;</source>
        <Parameter name="_chassis" type="CM_TIMaster"/>
        <ReturnType type="CMIF_TIObject"/>
    </JadeMethod>
    <JadeMethod name="saveData" id="4083e673-61a6-4409-9a41-d97bcd30c865">
        <updating/>
        <source>saveData() : Boolean updating;
// ---------------------------------------------------------------------------
// Created:     13 December 2000 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
// 15/09/2009	cnwcs5	ccms1061 - save selected gate (was saving default gate always)
vars
	idx					: Integer;
	intFaceArray		: CMIF_TIObjectArray;
	intFaceCommon		: CMIF_InOutCommon;
	intFaceItem			: CMIF_TIObject;
	intFaceChassis		: CMIF_Chassis;
//	intFaceChassisOut	: CMIF_ReleaseById; // PAR 17505
	numItems			: Integer;
	contFrm				: GTE_ContainerFrame;
	defRoadTransArea	: String;
	result				: Integer;
	job					: CM_RoadJob;
	strGate				: String;
	passport			: CM_Passport;
	prenoteId			: String;
	
begin

	self.savePreCheckOfSheets();
	
	passport := app.myPassport;
	
	create intFaceArray transient;

	// save the data entered in the common table
	create intFaceCommon transient;
	intFaceCommon.myTerminal := self.myTerminal;
	intFaceCommon.setUserDetails(tblCommon);
	self.tblCommon.setObjectFromTable(intFaceCommon, null, false);
	
	// Need to do this as if this row is hidden then the setObjectFromTable ignores it
	intFaceCommon.autoComplete := tblCommon.getValueByName(ETRow_AutoComplete).Boolean;
	
	// In Gate always defaults to the default gate configured for the terminal
	intFaceCommon.myGateEntry	:= self.myTerminal.getDefaultGate_IN();	// 21313 
	
	// save the data entered in the sheets.
	numItems := trkLayoutIn.allContainerFrames.size();
	
	//CCMS1015 US Customization 
	//Chassis save chassis details about here
	//Trucks sometimes leave the trailer in the terminal but we don't need to do this if no chassis details have been entered.
//	if app.myRoot.canDo(PmTrailer) then
	if app.myRoot.canDo(Mod_BaseSystem) then	//07 Oct 2019	NDL	TFS 46169
		if self.tblCommon.getValueByName(ETRow_ChassisNoIn).String &lt;&gt; null then
			create intFaceChassis transient;
			self.setChassisDetails(intFaceChassis, true);
			intFaceChassis.setMyInOutCommon(intFaceCommon);
			intFaceArray.add(intFaceChassis);
		endif;
	endif;
	
	// Save receipts first then releases as this effects the queue order	
	foreach idx in numItems to 1 step -1 do
		contFrm := trkLayoutIn.allContainerFrames[idx];
		
		if contFrm &lt;&gt; null and contFrm.visible then
			intFaceItem := self.saveSheet(contFrm.mySheet, contFrm, intFaceCommon);
			intFaceArray.add(intFaceItem);
		endif;
	endforeach;
	
	numItems := trkLayoutOut.allContainerFrames.size();
	
	// Save releases last as this affects the queue order
//	if app.myRoot.canDo(PmTrailer) then
	if app.myRoot.canDo(Mod_BaseSystem) then	//07 Oct 2019	NDL	TFS 46169
		if self.tblCommon.getValueByName(ETRow_ChassisNumReq).Boolean = true then
			intFaceItem := self.saveChassisReleaseActionType(self.cmbTILCOut.listObject.CM_TIMaster);
			intFaceItem.setMyInOutCommon(intFaceCommon);
			//create intFaceChassisOut transient; // PAR 17505 removed
			//intFaceChassisOut.setMyInOutCommon(intFaceCommon); // PAR 17505 removed
			intFaceArray.add(intFaceItem);
			//global.schDoErrorBreak();
		endif;
	endif;
	
	foreach idx in 1 to numItems do
		contFrm := trkLayoutOut.allContainerFrames[idx];
		
		if contFrm &lt;&gt; null and contFrm.visible then
			intFaceItem := self.saveSheet(contFrm.mySheet, contFrm, intFaceCommon);
			intFaceArray.add(intFaceItem);
		endif;
	endforeach;
	
	// 06/07/2010 cnwar2 #24865
	if self.myGTESheetRequiresRefresh &lt;&gt; null then
		// recevial sheet failed edition check of prenote
		if self.myGTESheetRequiresRefresh.myMenuAction.myObject.isKindOf(CM_TrackedItem) then			//only do if it is a Tracked Item +cnwml2 PAR24780
			prenoteId := self.myGTESheetRequiresRefresh.myMenuAction.myObject.CM_TrackedItem.id;
			app.msgBox(app.getErrorString1(PrenoteModifiedByAnotherUser, prenoteId), app.getErrorString(Error), MsgBox_OK_Only);
			return false;
		endif;
	endif;
	
	while true do
		//app.myTrxCA.trxCreateInOutVehicle(intFaceCommon, passport);				//cnwmc5 - 22 Jan 2015 - PAR 35518
		app.myTrxCA.trxCreateInOut(intFaceCommon, intFaceArray, passport, null);	//TFS 53107, AjitM, navam1
		
		if passport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			break;
		else
			
			// PAR 20338 18807
			if passport.replayingDeadlocks = false then
				result := app.showErrorWarningDialog(app.getErrorString(GateInOut), passport, ErrWarnMode_Add + ErrWarnMode_CanAckWarnings);
			else
				if passport.silentDeadlockRetryCount = 0 or
				   passport.silentDeadlockRetryCount &gt; passport.silentDeadlockLimit then
					result := app.showErrorWarningDialog(app.getErrorString(GateInOut), passport, ErrWarnMode_Add + ErrWarnMode_CanAckWarnings);
				endif;
			endif;

			if passport.noErrors and
			   result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				passport.warningsAcknowledged	:= true;
				continue;
			endif;
			
			// 05/07/2010 cnwar2 #24865 - removed, this is now done during saveSheet
			//PAR 23408 - if a prenote's edition changed and error "updated by another" occurred, need to handle GUI interface - to allow users to refresh GTE_Sheet
			//self.setControlsWhenPrenoteChanged(app.myPassport);
			
			self.setAllErrorWarnings(passport);	// copies errors to this form and shows in err/warnings window
		endif;

		return false;
	endwhile;

	if app.myController.useAnimation then
		self.trkLayoutIn.hideTruck;
		self.trkLayoutOut.driveOff();
		self.trkLayoutIn.showTruck;
		self.trkLayoutOut.cnEcResizeContents;
	endif;
	
	self.myAssistant.GTE_Assistant.checkRoadQueue(true, self.myTerminal);

	/*epr gdansk  pre -gate data entry 
	if the save is successful - must be we're here then
	- if autoplanned  has  successfully planned receival items to the yard then
	- display dialog with receivals details (planned location ) and rfid dialog
	- saving the dialog will associate the RFID with the job in the db and appear in job operations
	- cancel will put the job on hold
	*/

	job:=intFaceCommon.myRoadJob;
	self.myAssistant.GTE_Assistant.showRFIDTagFormForRoadEntry(job);
	
	//valid object check allows for autocomplete as job is blown away by this stage
	if self.myTerminal.getConfig(PrintBuckslip).Boolean and global.isValidObject(job) then
		job.printDriverDetails(1, true, null, null);
	endif;
	
	return true;
epilog
	if intFaceArray &lt;&gt; null then
		intFaceArray.purge();
		delete intFaceArray;
	endif;
	
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="saveEntTblSpecial" id="2c02102e-5be9-4a3d-9fc3-ae256bca9580">
        <updating/>
        <source>saveEntTblSpecial(_attrName : String;
				_strValue : String;
				_obj : Object input;
				_tbl : CM_EntryTable input) : Boolean updating, protected;
// ---------------------------------------------------------------------------
// Created:     19 August 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	
begin
	//epr TFS 2889 1/11/16
	if _obj &lt;&gt; null and _obj.isKindOf(CMIF_BOLIn) then
		if _obj.CMIF_BOLIn.stripCarriageReturns(_attrName,_strValue) then
			return true;
		endif;
	endif;

	return self.myAssistant.GTE_Assistant.saveEntTblSpecial(_attrName, _strValue, _obj, _tbl);

end;</source>
        <access>protected</access>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_strValue" type="String"/>
        <Parameter name="_obj" type="Object" usage="input"/>
        <Parameter name="_tbl" type="CM_EntryTable" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="savePreCheckOfSheets" id="af7954cb-0bda-4ed2-92ea-ccc84f9120ac">
        <updating/>
        <source>savePreCheckOfSheets() updating;
// ---------------------------------------------------------------------------
// Created:     13 June 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	cntrl	: Control;
	numControls,
	idx		: Integer;
	keyField,
	keyValue,
	code	: String;
	mainTbl	: CM_EntryTable;
	cargoType : Integer;	
begin

	
	if fldInOut.sheets &gt; 2 then
		numControls := self.controlCount;
		// iterate in reverse order as we may be
		// deleting some controls on the way through
		foreach idx in numControls to 1 step -1 do
			cntrl := controls(idx);
			if cntrl.isKindOf(GTE_Sheet) and 
			   cntrl.parent = fldInOut and 
			   cntrl.visible and
			   cntrl.GTE_Sheet.myMenuAction &lt;&gt; null then
			   	code := cntrl.GTE_Sheet.myMenuAction.code;
			   	if code = NavObj_GTE_In then
				   	cargoType := cntrl.GTE_Sheet.getCargoBOLTypeId();			   	
			   		if cargoType = BOLType_Log or
			   		   cargoType = BOLType_GeneralDocket or
			   		   cargoType = BOLType_GeneralBillOfLading then
			   			keyField := ETRow_BolNumber;
			   		else
			   			keyField := ETRow_IdTextBox;
			   		endif;
			   	elseif code = NavObj_GTE_OutByType then
					keyField := ETRow_IsoType;	//	RDD 18/9/2001 Xpose 1380 was releaseNoCmb, but this is not necessarily required//			   		keyField := 'releaseNoCmb';
												//	Also Xpose 1473 / PNL308 raised the same issue -- added here 16/10/01 RDD
			   	elseif code = NavObj_GTE_OutByType  then
			   		keyField := ETRow_IdCombo;
				// Par 18126 - AER 14/10/2008
				// For any Release GTE_Sheet created, the myMenuAction.code is always "NavObj_GTE_Out".The other two elseif above are never true.
				elseif code = NavObj_GTE_Out then
					mainTbl := cntrl.GTE_Sheet.myTblMain;
			   		if mainTbl &lt;&gt; null then
						if mainTbl.getValueByName(ETRow_ReleaseByType).Boolean then
							keyField := ETRow_IsoType;
						else
							keyField := ETRow_IdCombo;
						endif;
			   		endif;
			   	endif;
			   
				if keyField &lt;&gt; null then
			   		mainTbl := cntrl.GTE_Sheet.myTblMain;
			   		if mainTbl &lt;&gt; null then
			   			keyValue := mainTbl.getValueByName(keyField).String;
			   		endif;
			   		if keyValue = null then
			   			cntrl.setFocus;
 			   			if app.msgBox('You have not entered sufficient information to save this sheet.  Do you wish to delete it?',
			   						'Warning', MsgBox_Yes_No + MsgBox_Default_Second) = MsgBox_Return_Yes then		//	change in wording for Xpose 1219 RDD 3 8 2001
							self.deleteSheet(cntrl.GTE_Sheet);
						endif;
			   		else
			   			// set to null for the next sheet
				   		keyValue := null;
						keyField := null; // Par 18126 - AER 14/10/2008
			   		endif;
			   	endif;
			endif;
		endforeach;
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="saveSheet" id="079be705-6503-417f-bdc9-4f7da389dbd2">
        <updating/>
        <source>saveSheet(pSheet : GTE_Sheet input; pContFrm : GTE_ContainerFrame; pIntFaceCommon : CMIF_InOutCommon input) : CMIF_TIObject updating;
// ---------------------------------------------------------------------------
// Created:     20 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
/*

Date		Who		Reason
14 Sep 2012	cnwkpd1	PAR #29274 - Replace Object::getInstanceIdForObjectXX with RootSchema methods
	
*/

vars
	intFaceCOU		: CMIF_InOutCOU;
	intFaceRelType	: CMIF_ReleaseByType;
	intFaceItem		: CMIF_TIObject;
	intFaceClass	: Class;
	assistant		: GTE_Assistant;
	tmpBR			: CM_BulkRelease;
	tmpTblMain		: CM_EntryTable;
	tmpTblExtra		: CM_EntryTable;
	powerReq		: String;
	gradesTable		: CMUI_ListTable;
	cargoDocketId	: Integer;
	tmpCode			: String;
	stopTable		: CM_StopsTable;
	stop			: CM_Stops;
	cmb				: ComboBox;
	anObject		: Object;
	tmpTI			: CM_TrackedItem;
	subTerminalCmb	: CMUI_ComboBox;
	allStops		: CM_StopsByIdDict;
	
begin
	assistant	:=	self.myAssistant.GTE_Assistant;
	tmpCode		:=	pSheet.getTypeCode();
	tmpTblMain	:=	pSheet.myTblMain;

	if pSheet.myMenuAction &lt;&gt; null then
		if pSheet.myMenuAction.extraTableDef = null then
			tmpTblExtra := null;
		else
			tmpTblExtra := pSheet.myTblExtra;
		endif;
	endif;

	cargoDocketId := pSheet.getCargoBOLTypeId();
	intFaceClass := self.myAssistant.GTE_Assistant.getIntFaceClass(tmpCode, cargoDocketId, tmpTblMain);
	create intFaceItem as intFaceClass transient;
	intFaceItem.myTerminal		:=	self.myTerminal;
	
// cnwdad1 16/04/2009 - CCMS 1735.
	subTerminalCmb				:=	pSheet.getControlByName(self.Cntrl_cmbSubTerminal).CMUI_ComboBox;
	if subTerminalCmb &lt;&gt; null then
		intFaceItem.mySubTerminal	:=	subTerminalCmb.listObject.CM_SubTerminal;
	else
		intFaceItem.mySubTerminal	:=	null;
	endif;

	//check the type is OK - put in to prevent crap data getting into Road Ops - Need a review of releases of these types
	if (cargoDocketId = BOLType_Log and intFaceItem.isKindOf(CMIF_BOLOut))
	or (cargoDocketId = TI_CargoType_Log and intFaceItem.isKindOf(CMIF_ReleaseById))
	then
		app.raiseCMException(Relea_this_type_curre_permi_co, null, null);
		return null;
	endif;

	if intFaceItem.isKindOf(CMIF_BOL) then
		//in the rare event that the weighBridge docket has been deleted within the space of time that it was 
		//associated with the sheet
		if global.isValidObject(pSheet.myLogDocketData) then
			intFaceItem.CMIF_BOL.myLogDocketData := pSheet.myLogDocketData;
		endif;
	endif;
	
	if cargoDocketId = BOLType_Log then
		self.saveSheetForLogBOL(intFaceItem.CMIF_BOL, pSheet, tmpTblMain, tmpTblExtra, pIntFaceCommon);
		return intFaceItem;

	elseif cargoDocketId = BOLType_GeneralDocket then
		intFaceItem.setDataFromTable(tmpTblMain, tmpTblExtra, pIntFaceCommon, self.myAssistant);
		assistant.receival_SaveAttachments(intFaceItem, pSheet.allAttachments, pIntFaceCommon, pSheet);
		self.saveEntTblSpecial(ETRow_ConsigneeCode, tmpTblExtra.getValueByName(ETRow_ConsigneeCode).String, intFaceItem, tmpTblExtra);
		self.saveEntTblSpecial(ETRow_ConsignorCode, tmpTblExtra.getValueByName(ETRow_ConsignorCode).String, intFaceItem, tmpTblExtra);
		//21/11/2006 par#12903 Mohammad
		self.saveEntTblSpecial(ETRow_FreightForwarderCode, tmpTblExtra.getValueByName(ETRow_FreightForwarderCode).String, intFaceItem, tmpTblExtra);
		intFaceItem.CMIF_BOL.hasAttachments := (intFaceItem.allSubItems.size &gt; 0);
		
		intFaceItem.CMIF_BOL.transportMode := TI_TRANSMODE_ROAD;				
		//intFaceItem.myTerminal := self.myTerminal;
		intFaceItem.CMIF_BOL.bolType := BOLType_GeneralDocket;
	
		//assistant.receival_SaveAttachments(intFaceItem, pSheet.allAttachments, pIntFaceCommon, pSheet);
		return intFaceItem;
	endif;
	

	assistant.receival_SaveData(intFaceItem, tmpTblMain,
								 tmpTblExtra,
								 pSheet.getControlByName(Cntrl_lstHazardList).CMUI_HazardsListTable,
								 pSheet.getControlByName(Cntrl_lstDischarge).CMUI_ListTable, null, null,
								 pIntFaceCommon,
								 pSheet,
								 self.myTerminal,
								 null);
								// pSheet.getControlByName(cmbBRItem.name).GTE_TextBox); // AER 12/01/2008 CCMS 1003	

	assistant.receival_SaveCOU(	intFaceItem,
								intFaceCOU,
								tmpTblExtra,
								pIntFaceCommon,
								pSheet);
	
	assistant.receival_SaveAttachments(	intFaceItem,
										pSheet.allAttachments,
										pIntFaceCommon,
										pSheet);
	// 25/07/2008 cnwar2 #17525
	if intFaceItem.isKindOf(CMIF_Receival) then
		if pSheet.myMenuAction.myObject &lt;&gt; null then	//+cnwml2 PAR24972
			//+cnwml2 PAR24780
			if not tmpTblExtra.isRowVisible(ETRow_AllSpecialLifts) then
				if pSheet.myMenuAction.myObject.isKindOf(CM_TrackedItem) then
					pSheet.myMenuAction.myObject.CM_TrackedItem.allSpecialLifts.copy(intFaceItem.CMIF_Receival.allSpecialLifts);
					if pSheet.tiEdition &lt;&gt; pSheet.myMenuAction.myObject.CM_TrackedItem.edition then
						self.setControlsWhenPrenoteChanged(pSheet);
					endif;
				elseif pSheet.myMenuAction.myObject.isKindOf(CM_BRefItemContainer) then
					pSheet.myMenuAction.myObject.CM_BRefItemContainer.allSpecialLifts.copy(intFaceItem.CMIF_Receival.allSpecialLifts);
					if pSheet.tiEdition &lt;&gt; pSheet.myMenuAction.myObject.CM_BRefItemContainer.edition then
						self.setControlsWhenPrenoteChanged(pSheet);
					endif;
				endif;
			endif;
			//intFaceItem.CMIF_Receival.tiEdition := pSheet.tiEdition;
			// 05/07/2010 cnwar2 #24865 - edition check now done here
			//-cnwml2 PAR24780
			//if pSheet.tiEdition &lt;&gt; pSheet.myMenuAction.myObject.CM_TrackedItem.edition then
			//	self.setControlsWhenPrenoteChanged(pSheet);
			//endif;
		endif;
		intFaceItem.CMIF_Receival.doorsDirection := pContFrm.getDoorsDir;		// 25/11/2010 cnwmh5 #26396
	endif;
	
	if intFaceClass = CMIF_ReleaseByType then
		intFaceRelType := intFaceItem.CMIF_ReleaseByType;
		intFaceRelType.releaseNo := assistant.mainExtraGetValue(tmpTblMain, tmpTblExtra, ETRow_ReleaseNoCmb).String;
		
		tmpBR := tmpTblMain.accessCell(tmpTblMain.getRowByName(ETRow_ReleaseNoCmb),CM_EntryTable.ColumnValue).cellControl.ComboBox.listObject.CM_BulkRelease;
		intFaceRelType.myBulkRelease := tmpBR;
		intFaceRelType.doorsDirection := pContFrm.getDoorsDir;
		cmb := pSheet.getControlByName(Cntrl_cmbDestTerminal).ComboBox;
		
		if cmb &lt;&gt; null then
			intFaceRelType.myTransferToTerminal := cmb.listObject.CM_Terminal;
		endif;
		
		if intFaceRelType.releaseNo = null then
			// Par 8380 - need a commond factor between interface items created from same sheet
			intFaceRelType.systemBulkReleaseCode := pSheet.getInstanceIdForObject64(pSheet).String;
		endif;
		
		// Always reset quantity to 1 as a seperate intFaceItem will be created for each
		// container being released (this is so multiple can be shown on the image and that
		// the ordering of the job can be done correctly.
		intFaceRelType.quantity := 1;
		gradesTable := pSheet.getControlByName(GTE_InOutForm::lstMTGrade.name).CMUI_ListTable;
		
		if gradesTable &lt;&gt; null then
			assistant.saveListTableMTGrades(gradesTable, intFaceRelType.allAvailabilityGrades);
		endif;
		
		powerReq := tmpTblMain.getValueByName(ETRow_PowerRequirements).String;
		assistant.handlePowerRequirements(powerReq, intFaceRelType.needCOU,	intFaceRelType.needGenerator);

	elseif intFaceClass = CMIF_ReleaseById then
		
		intFaceItem.CMIF_ReleaseById.id := tmpTblMain.getValueByName('idCombo').String;
		intFaceItem.CMIF_ReleaseById.customEntryNumber := tmpTblMain.getValueByName(ETRow_CustomsEntryNumber).String;
		
		intFaceItem.CMIF_ReleaseById.importReleasePIN := tmpTblMain.getValueByName(ETRow_OperatorImportReleasePIN).String; //cnwrd1 6.11.08 CCMS JMT 1743/1764 
		
		anObject := pSheet.myMenuAction.myObject; // ### AKB2005MAY 
		if anObject.isKindOf(CM_BulkRelease) then
			tmpBR := anObject.CM_BulkRelease;
		endif;

		tmpTI :=  intFaceItem.CMIF_ReleaseById.myTrackedItem;
		if tmpTI = null or (tmpTI &lt;&gt; null and (tmpTI.id &lt;&gt; intFaceItem.CMIF_ReleaseById.id or tmpTI.cargoType &lt;&gt; intFaceItem.CMIF_ReleaseById.cargoType)) then
			tmpTI := self.myTerminal.allOnsiteTIsByIdCargoType[intFaceItem.CMIF_ReleaseById.id, intFaceItem.CMIF_ReleaseById.cargoType];
		endif;
		
		if tmpBR = null and tmpTI &lt;&gt; null then
			if tmpTI.isHeldForRelease then
				tmpBR := tmpTI.allBulkReleasesAssigned[BR_TYPE_ROAD, null, intFaceItem.CMIF_ReleaseById.deliveryReleaseNumber, null];
			endif;
		endif;
		
		intFaceItem.CMIF_ReleaseById.myBulkRelease := tmpBR;
		intFaceItem.CMIF_ReleaseById.doorsDirection := pContFrm.getDoorsDir;
		powerReq := tmpTblMain.getValueByName(ETRow_PowerRequirements).String;
		assistant.handlePowerRequirements(	powerReq,
											intFaceItem.CMIF_ReleaseById.needCOU,
											intFaceItem.CMIF_ReleaseById.needGenerator);
		cmb := pSheet.getControlByName(Cntrl_cmbDestTerminal).ComboBox;
		
		if cmb &lt;&gt; null then
			intFaceItem.myTransferToTerminal := cmb.listObject.CM_Terminal;
		endif;
		
		intFaceItem.CMIF_ReleaseById.allStopsArray.clear();
		
		// CCMS 1235 Leave this as is because shows only stops that are already set.
		if tmpTI &lt;&gt; null then
			//foreach stopTable in self.myTerminal.myRoot.allStopsTable do
//			foreach stop in tmpTI.getAllStops() do	// cnwrl1 15/12/2009 PAR 21889 - what it was
			create allStops transient;
			tmpTI.getAllActiveStops(allStops);
			
			foreach stop in allStops do
				stopTable := stop.myStopsTable;
				if not tmpTblMain.isRowVisible(stopTable.getAttrName()) then
					//can't remove
					intFaceItem.CMIF_ReleaseById.allStopsArray.add(stopTable.id);
				elseif tmpTblMain.getValueByName(stopTable.getAttrName()).Boolean then
					//checked
					intFaceItem.CMIF_ReleaseById.allStopsArray.add(stopTable.id);
				else
					//must be unchecked - will be removed from the TI if not added to intFaceItem.allStopsArray
				endif;
				//if tmpTblMain.getValueByName(stopTable.getAttrName()).Boolean then
				//	intFaceItem.CMIF_ReleaseById.allStopsArray.add(stopTable.id);
				//endif;
			endforeach;
		endif;
	endif;

    return intFaceItem;
epilog
	delete allStops;
end;</source>
        <Parameter name="pSheet" type="GTE_Sheet" usage="input"/>
        <Parameter name="pContFrm" type="GTE_ContainerFrame"/>
        <Parameter name="pIntFaceCommon" type="CMIF_InOutCommon" usage="input"/>
        <ReturnType type="CMIF_TIObject"/>
    </JadeMethod>
    <JadeMethod name="saveSheetForLogBOL" id="0ea61082-04a4-48d3-b3e4-9ba3b0a30649">
        <source>saveSheetForLogBOL(_intFaceItem : CMIF_BOL input; pSheet : GTE_Sheet; _tblMain, _tblExtra : CM_EntryTable input; pIntFaceCommon : CMIF_InOutCommon);
// ---------------------------------------------------------------------------
// Created:     20 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	tmpComboBox : ComboBox;
	tmpDocketError : CM_DocketError;
	coll : CM_DocketErrorByCodeDict;
	docketErrorType : Object;
	docketErrorCount : Integer;
begin

	_intFaceItem.setUserDetails(pSheet);
	_intFaceItem.setMyInOutCommon(pIntFaceCommon);
	
	_tblMain.setObjectFromTable(_intFaceItem, GTE_InOutForm::saveEntTblSpecial.name, false);
	//_tblExtra.setObjectFromTable(_intFaceItem, null, false);
	_tblExtra.setObjectFromTable(_intFaceItem, GTE_InOutForm::stripCarriageReturns.name, false);	// 23/10/2014 cnwar2 #35094
	
	tmpComboBox := pSheet.getControlByName(self.Cntrl_cmbConsignorTop).ComboBox;
	if tmpComboBox &lt;&gt; null and 
	   tmpComboBox.listObject &lt;&gt; null then
		_intFaceItem.consignorCode := tmpComboBox.listObject.CM_ConsigneeConsignor.code;
	endif;
	
// cnwdad1 14/04/2009 - CCMS 1735.
	tmpComboBox := pSheet.getControlByName(self.Cntrl_cmbSubTerminal).ComboBox;
	if tmpComboBox &lt;&gt; null then
		_intFaceItem.mySubTerminal	:=	tmpComboBox.listObject.CM_SubTerminal;
	else
		_intFaceItem.mySubTerminal	:=	null;
	endif;
	
	//added for par14844
	tmpComboBox := pSheet.getControlByName(self.Cntrl_cmbConsignee).ComboBox;
	if tmpComboBox &lt;&gt; null and 
	   tmpComboBox.listObject &lt;&gt; null then
		_intFaceItem.consigneeCode := tmpComboBox.listObject.CM_ConsigneeConsignor.code;
	endif;
	//add end
	
	tmpComboBox := pSheet.getControlByName(self.Cntrl_cmbTerminal).ComboBox;
	if tmpComboBox &lt;&gt; null and 
	   tmpComboBox.listObject &lt;&gt; null then
		_intFaceItem. terminal := tmpComboBox.listObject.CM_Terminal.code;
	endif;

	_intFaceItem.operatorCode 	:= _tblMain.getValueByName(ETRow_Supplier).String;
	tmpComboBox := pSheet.getControlByName(Cntrl_cmbSupplier).ComboBox;
	if tmpComboBox &lt;&gt; null then
		_intFaceItem.myOperator := tmpComboBox.listObject.CM_Operator;
	endif;

	_intFaceItem.bolType 		:= BOLType_Log;
	_intFaceItem.transportMode 	:= TI_TRANSMODE_ROAD;

	tmpComboBox :=  pSheet.getControlByName(Cntrl_cmbSupplier).ComboBox;
	if tmpComboBox.listObject &lt;&gt; null then
		_intFaceItem.operatorCode := tmpComboBox.listObject.CM_Operator.code;
	endif;
	
	if _intFaceItem.isKindOf(GTEIF_BOLIn) then	
		_intFaceItem.sourceLocation			:= _intFaceItem.GTEIF_BOLIn.forest;
		_intFaceItem.sourceSubLocation		:= _intFaceItem.GTEIF_BOLIn.compartment;
		_intFaceItem.sourceSubSubLocation	:= _intFaceItem.GTEIF_BOLIn.stand;		

		tmpComboBox :=  pSheet.getControlByName(GTE_InOutForm::cmbLogLocation.name).ComboBox;
		if tmpComboBox.listObject &lt;&gt; null then
			_intFaceItem.myPlannedLocation := tmpComboBox.listObject.CM_LogController;
		endif;
		self.myAssistant.receival_SaveTicketSequences(_intFaceItem.CMIF_BOLIn, pSheet.allTicketSequences);	
		
		//docketErrorType := pSheet.getControlByName('cmbDocketError').GTE_ComboBox.listObject;	//ccms 1110
		//ccms 1110 - cnwsh3 PAR23894.  Changed to get rid of literal for combo box to capture references if the control is removed.
		docketErrorType := pSheet.getControlByName(GTE_InOutForm::cmbDocketError.name).GTE_ComboBox.listObject;	
				
		if docketErrorType &lt;&gt; null then
			create tmpDocketError as CM_DocketError transient;
			tmpDocketError.setMyDocketErrorType(docketErrorType.CM_DocketErrorType);	
		
			_intFaceItem.GTEIF_BOLIn.allDocketErrors.add(tmpDocketError);
		endif;
				
	else
		tmpComboBox :=  pSheet.getControlByName(GTE_InOutForm::cmbLogLocation.name).ComboBox;
		if tmpComboBox.listObject &lt;&gt; null then
			_intFaceItem.CMIF_BOLOut.myYardLocation := tmpComboBox.listObject.CM_LocationsController;
		endif;	
		//this cannot be right
		//_intFaceItem.consignorCode := _tblMain.getValueByName(ETRow_ConsigneeCode).String;
	
		tmpComboBox :=  pSheet.getControlByName(Cntrl_cmbStockOrder).ComboBox;
		if tmpComboBox.listObject &lt;&gt; null then
			_intFaceItem.CMIF_BOLOut.myStockOrder := tmpComboBox.listObject.CM_StockOrderHeader;
		endif;
		_intFaceItem.CMIF_BOLOut.partialLoadout := true;					
	endif;

end;</source>
        <Parameter name="_intFaceItem" type="CMIF_BOL" usage="input"/>
        <Parameter name="pSheet" type="GTE_Sheet"/>
        <Parameter name="_tblMain" type="CM_EntryTable" usage="input"/>
        <Parameter name="_tblExtra" type="CM_EntryTable" usage="input"/>
        <Parameter name="pIntFaceCommon" type="CMIF_InOutCommon"/>
    </JadeMethod>
    <JadeMethod name="setAutoComplete" id="bce75a0d-dacf-4413-95e6-168740bb807e">
        <source>setAutoComplete();
// ---------------------------------------------------------------------------
// Created:     26 June 2002 by cnwth2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	autoComplete	:Boolean;
begin
	//set the auto complete checkbox
	autoComplete := self.myTerminal.getConfig(GateInAutoComplete).Boolean;
	tblCommon.setValueByName(ETRow_AutoComplete, autoComplete);
end;</source>
    </JadeMethod>
    <JadeMethod name="setAutomaticCellControls" id="a23f0825-4a7c-4583-92d8-44d21f735dc2">
        <source>setAutomaticCellControls();
// ---------------------------------------------------------------------------
// Created:     16 October 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin

	//self.cmbCustomDetails.automaticCellControl		:= true;
	self.cmbTI.automaticCellControl		:= true;
	self.cmbTiType.automaticCellControl	:= true;
	self.cmbScaler.automaticCellControl	:= true;
	self.cmbBRItem.automaticCellControl	:= true;// AER 12/01/2008 CCMS 1003
// commented out 8/06/05 HJG - Par 10281 was playing up with way combo displayed entry. 
//	self.cmbLoggingOrg.automaticCellControl	:= true;
	self.cmbSubTerminal.automaticCellControl	:=	true;

	self.txtBOLNumber.automaticCellControl	:= true;
	self.txtBookingRef.automaticCellControl := true;
	self.txtDPCount.automaticCellControl := true;
	
	//self.txtFellDate.automaticCellControl	:= true;
	self.txtRegNumber.automaticCellControl	:= true;
	self.txtTrackedItemID.automaticCellControl	:= true;
	self.txtTrailerNumber.automaticCellControl	:= true;

end;</source>
    </JadeMethod>
    <JadeMethod name="setAvailabilityGrades" id="3b74f8bb-baa1-4cc6-a196-e1a5343475d5">
        <source>setAvailabilityGrades();
// -------------------------------------------
// Created 27 October 2004 by cnwdvb1
// -------------------------------------------
vars

	tmpComboOp,
	tmpComboAvGrade,
	tmpComboOpGroup			: ComboBox;
	operator				: CM_Operator;
	operatorGroup			: CM_OperatorGroup;
	pSheet					: GTE_Sheet;
	tmpAvGradeLst			: GTE_ListTable;
	obj						: Object;
	
begin

	
	pSheet := self.topSheet;
	
	if pSheet = null then
		return;
	endif;
	
	tmpComboOp := pSheet.getControlByName(self.Cntrl_cmbOperator).ComboBox;
	
	if tmpComboOp &lt;&gt; null then
		operator := tmpComboOp.listObject.CM_Operator;
	endif;
	
	tmpComboOpGroup := pSheet.getControlByName(self.Cntrl_cmbOperatorGroup).ComboBox;
	if tmpComboOpGroup &lt;&gt; null then
		operatorGroup := tmpComboOpGroup.listObject.CM_OperatorGroup;
	endif;
	
	tmpComboAvGrade := pSheet.getControlByName(self.Cntrl_cmbAvGrade).ComboBox;
	
	if tmpComboAvGrade &lt;&gt; null then
		obj := tmpComboAvGrade.CMUI_ComboBoxMTGrade.myObject;
		tmpComboAvGrade.CMUI_ComboBoxMTGrade.setObjectAndOperator(obj, operator, operatorGroup);
		//tmpComboAvGrade.CMUI_ComboBoxMTGrade.setObjectAndOperator(null, operator, operatorGroup);
	endif;
	
	tmpAvGradeLst := pSheet.getControlByName(self.Cntrl_lstMTGrade).GTE_ListTable;
	if tmpAvGradeLst &lt;&gt; null then
		self.myAssistant.listTableMTGrade(tmpAvGradeLst, operator, operatorGroup);
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="setBtnRefresh" id="bee05618-72fc-4196-a153-0916505fe50d">
        <source>setBtnRefresh() protected;
/* ---------------------------------------------------------------------------
Created:	22 April 2010	by cnwvu1

Purpose:	
   
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars

begin

	self.btnRefresh.enabled := (self.fldInOut.topSheet = self.myGTESheetRequiresRefresh);	//PAR23408 22/04/2010

	if self.myGTESheetRequiresRefresh &lt;&gt; null then
		self.myGTESheetRequiresRefresh.backColor := Red;
	endif;


end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setCargoTypeFields" id="371e81fc-1b50-4ff5-bb82-7ee81062f88e">
        <updating/>
        <source>setCargoTypeFields(pSheet : GTE_Sheet) updating;
// ---------------------------------------------------------------------------
// Created:     08 February 2001 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
// 20/11/2009	cnwmh5		PAR21492 - Add setting of cmbSysSubType
// 12/12/2012	cnwcs5		par 30852- trailer types
// ---------------------------------------------------------------------------
vars
	cargoType				: CM_CargoType;
	docketType				: CM_BOLType;
	isoType					: CM_ISOType;
	mainTable,
	extraTable				: CM_EntryTable;
	tmpCombo				: ComboBox;
	assistant				: GTE_Assistant;
	contFrm					: GTE_ContainerFrame;
	row						: Integer;
	tmpCell					: JadeTableCell;
	productCntrl			: CMUI_ComboProduct;
	product					: CM_Product;				// 20/11/2009 cnwmh5 par21492
	typeString				: String;
	tmpBookingRefItem		: CM_BookingRefItem;
begin
	if pSheet = null then
		return;
	endif;
	
	cargoType := pSheet.getCargoType();
	
	// Check if it's a BOL Type
	if cargoType = null then
		docketType := pSheet.getDocketType();
		
		if docketType &lt;&gt; null then
			self.setDocketTypeFields(pSheet, docketType);
		endif;
		return;
	endif;
	
	// Cargo Types from here.
	productCntrl := pSheet.getControlByName(GTE_InOutForm::cmbProduct.name).CMUI_ComboProduct;
	
	if productCntrl &lt;&gt; null then
		productCntrl.setCargoType(cargoType);	
		
		if not cargoType.allProducts.includes (productCntrl.myObject.CM_Product) then
			// Lorcan the selected product type does not include the selected product so we refresh the product list
			extraTable 			:= pSheet.myTblExtra;
			productCntrl.text 	:= null;
			
			if extraTable.getRowByName(ETRow_MyProduct) &lt;&gt; null then
				tmpCell 		:= extraTable.accessCell(extraTable.getRowByName(ETRow_MyProduct), CM_EntryTable.ColumnValue);
				tmpCell.text	:= null;
			endif;
		endif;
	endif;
	
	foreach contFrm in pSheet.allContainerFrames do
		if cargoType.id = TI_CargoType_Container then
			// only a container has doors
			contFrm.setHasDoors(true);
		else
			contFrm.setHasDoors(false);
		endif;
	endforeach;
	
	// Set up main table.
	assistant	:= self.myAssistant.GTE_Assistant;
	mainTable	:= pSheet.myTblMain;

	self.setTblMainViewCargoType(cargoType, mainTable);
	assistant.setTIHeading(cargoType.idHeading, mainTable, false);

	// Set up extra table if needed.
	extraTable := pSheet.myTblExtra;
	
	if extraTable = null then
		return;
	endif;
	
	//th2 PAR 12544 - auto bol number for individual items
	if app.getMyTerminalConfigDO_NOT_USE(GateInAutoBOLNumber).Boolean then
		row := extraTable.getRowByName(ETRow_BillOfLading);
		
		if row &gt; 1 then
			extraTable.setValueByName(ETRow_BillOfLading, app.getErrorString(BOLNumber_AutoGen));
			extraTable.accessRow(row).enabled := false;
		endif;
	endif;
	
	extraTable.setValueByName(ETRow_HasAttachments, true);
	
	row 		:= extraTable.getRowByControlName(Cntrl_cmbOperator);
	tmpCombo 	:= pSheet.getControlByName(Cntrl_cmbOperator).ComboBox;	
	
	extraTable.setControl(row, tmpCombo);
	
	extraTable.setTerminologyRelevant(cargoType,self.myTerminal);
	extraTable.setRowNamesFromTerminology();
	
	isoType	:= pSheet.getISOType();
	
	// Show rows based on crago type view.
	assistant.receival_ShowRows(cargoType, isoType, mainTable, extraTable, self.myTerminal);
	
	//th2 CCMS#1452 - stops and todo task visible for entry in pre-note screen - but uses 
	//the same entDef for here (gateInOut) so need to hide them explicitly
	extraTable.hideRowByName(ETRow_AllStops, false);
	extraTable.hideRowByName(ETRow_ToDoTasks, false);
	
	//show/hide GC rows in the view
	assistant.showHideGenCargoRows(cargoType, extraTable);

	//always hide the wagon field
	assistant.showHideWagonField(extraTable, TI_TRANSMODE_ROAD_STR);
	extraTable.hideRowByName(ETRow_EmailOptions, false);

	if cargoType &lt;&gt; null then
		tmpCombo := pSheet.getControlByName(Cntrl_cmbTI).ComboBox;
		
		if tmpCombo &lt;&gt; null then
			if cargoType.id = TI_CargoType_Log then
				// for logs there are too many values to make the combo useful.  The
				// combo style allows the user to input text anyhow, but further work
				// is needed here once TollOwens decide what is required.
				tmpCombo.clear();
			else
				assistant.comboBoxTrackedItemCmb(tmpCombo, cargoType.id, TI_STATE_NORMAL, null);
			endif;
		endif;
	endif;
	
	assistant.showHideCEDOField(extraTable, 1); // ### CCMS 1294 AKB2005JAN

	tmpCombo := pSheet.getControlByName(Cntrl_cmbImexStatus).ComboBox;
	
	if tmpCombo &lt;&gt; null then		
		tmpCombo.lostFocus(tmpCombo);
	endif;
	
	if productCntrl &lt;&gt; null then		
		extraTable.setValueByControlName(GTE_InOutForm::cmbProduct.name, productCntrl.text);	
	endif;
	
	//23/06/2009 cnwdz2 20072
	if not app.isSubTerminalsOn(self.myTerminal) then
		extraTable.hideRowByName(ETRow_MySubTerminal, false);
		mainTable.hideRowByName(ETRow_MySubTerminal, false);	
		extraTable.hideRowByName(ETRow_SubTerminalDesc, false);//6/11/2009 cnwdz2 20781
	endif;
	
	// 20/11/2009 cnwmh5 PAR21492 - Start
	typeString 	:= "|~~NULL~~|";
	tmpCombo 	:= pSheet.getControlByName(self.cmbBRItem.name).ComboBox;
	
	if tmpCombo &lt;&gt; null then
		tmpBookingRefItem := tmpCombo.listObject.CM_BookingRefItem;
		
		if tmpBookingRefItem &lt;&gt; null then
			typeString := tmpBookingRefItem.typeString;
		endif;
	endif;	
	
	tmpCombo := pSheet.getControlByName(self.Cntrl_cmbSysSubType).ComboBox;
	
	if tmpCombo &lt;&gt; null and tmpCombo.visible = true then			// 06/07/2010 cnwmh5 #24525 - Only do if visible e.g. on In 
		if productCntrl &lt;&gt; null then
			product := productCntrl.listObject.CM_Product;
			if product = null then
				product := cargoType.mySystemProductType;
			endif;
		endif;
		assistant.comboboxSysSubType(product, cargoType, typeString, tmpCombo.CMUI_ComboBox, extraTable);
	endif;
	
	// 23/02/2010 cnwar2 #22457
	tmpCombo := pSheet.getControlByName(GTE_InOutForm::cmbTrailerType.name).ComboBox;
	
	if cargoType.id = TI_CargoType_Chassis and tmpCombo &lt;&gt; null then
		assistant.comboBoxTrailerType(tmpCombo, cargoType, null, self.myTerminal);
	endif;
end;</source>
        <Parameter name="pSheet" type="GTE_Sheet"/>
    </JadeMethod>
    <JadeMethod name="setCellTextFromControl" id="da3be5a2-5390-4a19-85dd-5b8582517f2c">
        <source>setCellTextFromControl(pSheet : GTE_Sheet; pControl : Control; pText : String);
// ---------------------------------------------------------------------------
// Created:     12 January 2001 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	entTable	: CM_EntryTable;
	row			: Integer;
begin

	entTable := pControl.parent.CM_EntryTable;
	row := entTable.getRowByControlName(pControl.name);

	if row &gt; 0 then
		entTable.setValue(row, pText);
	endif;

end;</source>
        <Parameter name="pSheet" type="GTE_Sheet"/>
        <Parameter name="pControl" type="Control"/>
        <Parameter name="pText" type="String"/>
    </JadeMethod>
    <JadeMethod name="setChassisDetails" id="ed15a47b-821a-4b07-99ec-87fa02b6fc13">
        <updating/>
        <source>setChassisDetails(intFaceChassis : CMIF_Chassis input; _isReceival : Boolean)updating;
//----------------------------------------------------------------------
//
//  Created by cnwsh3
//
//	Date 24 May 2007
//	29/05/2025 navcs2 MTN-34844
//----------------------------------------------------------------------

vars
	chassisNo : String;
	masterChassis : CM_TIMasterTILC;
begin
	chassisNo := self.tblCommon.getValueByName(ETRow_ChassisNoIn).String;
	if chassisNo &lt;&gt; null then
		intFaceChassis.id := chassisNo;
	endif;
		
	masterChassis := self.cmbTILCTypes.myObject.CM_TIMasterTILC;
	if masterChassis &lt;&gt; null then
		intFaceChassis.setTIMasterTILCTI(masterChassis);
	endif;
	
	if self.cmbOperator.myObject &lt;&gt; null then
		intFaceChassis.operatorCode := self.cmbOperator.myObject.CM_Operator.code;
	endif;
	
	intFaceChassis.cargoType := masterChassis.cargoType;
	intFaceChassis.floorType := masterChassis.floorType;	// MTN-34844
	intFaceChassis.myTerminal := self.myTerminal;
	intFaceChassis.setUserDetails(self.tblCommon);
epilog

end;</source>
        <Parameter name="intFaceChassis" type="CMIF_Chassis" usage="input"/>
        <Parameter name="_isReceival" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setColorsFromController" id="b883c1bc-796e-491a-a373-406575e692b3">
        <updating/>
        <source>setColorsFromController(_colorControl: CM_ColorController) updating;
// ---------------------------------------------------------------------------
// Created:     28 July 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpBackColor	: Integer;

begin
	inheritMethod(_colorControl);
	
	tmpBackColor := self.backColor;
	
	self.frmData.backColor			:= tmpBackColor;
	self.fldInOut.backColor			:= tmpBackColor;
	self.fldLeft.backColor			:= tmpBackColor;
	
	self.splMain.backColor			:= tmpBackColor;
	self.sptInput.backColor			:= tmpBackColor;
	
	self.setColorsForEntryTable(self.tblCommon);
	self.setColorsForEntryTable(self.tblExtra);
	self.setColorsForEntryTable(self.tblMain);
	
	self.setColorsForTable(self.tblBulkRelease);
	self.setColorsForTable(self.tblLogDocketData);	
	self.setColorsForTable(self.tblTransfers);	

	self.trkLayoutIn.backColor		:= tmpBackColor;
	self.trkLayoutOut.backColor		:= tmpBackColor;
	
	self.staMain.backColor			:= tmpBackColor;
	
	self.dkcReleaseJobTxt.backColor	:= tmpBackColor;
	self.txtBulkRelease.backColor	:= self.colorControlBack;
	
end;</source>
        <Parameter name="_colorControl" type="CM_ColorController"/>
    </JadeMethod>
    <JadeMethod name="setControlsWhenPrenoteChanged" id="27bdfabc-80cb-4db0-9298-a46e7681a7c8">
        <updating/>
        <source>setControlsWhenPrenoteChanged(_gteSheet : GTE_Sheet) updating, protected;
/* ---------------------------------------------------------------------------
Created:	21 April 2010	by cnwvu1

Purpose:	PAR 23408. When there is an error of edition changed, need to
			allow users to refresh a GTE_Sheet
			
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars
	
begin
		
	self.myGTESheetRequiresRefresh := _gteSheet;
	self.fldInOut.topSheet	:= _gteSheet;		//making Sheet active on the screen
	self.fldInOut.topSheet.setFocus();
	
	self.setBtnRefresh();					// set btnRefresh enabled
	
	
end;
</source>
        <access>protected</access>
        <Parameter name="_gteSheet" type="GTE_Sheet"/>
    </JadeMethod>
    <JadeMethod name="setDefaultsCallBack" id="636104ff-79a2-4910-987d-8480b9827f20">
        <source>setDefaultsCallBack(pTbl : CM_EntryTable input; pAttrName : String; pRow : Integer; pObj : Object) : Boolean;

/*
	Created on 18 January 2008
	
	by Debby Hutchison for CCMS1618
	
	Purpose:  This method replaces the old setDefaultsCallBack method which has been renamed 
			to setDefaultsCallBackOld.	Thi method allows use of the interface IF_TIField to 
			fetch fields from the object regardless of whether the object is a TI or a Booking 
			Ref or a BookingRefItem.
// 07 Jun 2017	cnwrs1	TFS 4462 SNO add Terminal Operator, Unknown Seal and support multiple seals
*/
vars
	theVoyage		: CM_Voyage;
	tmpBookingRef	: CM_BookingRef;
	tmpBookingRefItem	: CM_BookingRefItem;
	theGrade		: CM_MTGrade;
	str			: String;
	theRowObject : CM_Object;
	operator 	: CM_Operator;
	assistant	: GTE_Assistant;
	rtnCode		: Boolean;
	tmpTextBox	: TextBox;
	tmpListTbl	: CMUI_ListTable;
	tmpHazList	: CMUI_HazardsListTable;
	tmpComboObj	: CMUI_ComboBoxObject;
	tmpCombo	: ComboBox;
	tmpInt		: Integer;
	tmpReal		: Real;
	sheet		: GTE_Sheet;
	pos			: Integer;
	space		: String;
	theDischargePort : CM_Port;
begin
	assistant := self.myAssistant.GTE_Assistant;
	sheet := self.topSheet;
	if sheet = null then
		return false;
	endif;

	if pObj.isKindOf(CM_LogDocketData) then
		return false;
	endif;
	
	rtnCode := true;
	if pAttrName = ETRow_AllDischargePorts then
		tmpListTbl := sheet.getControlByName(Cntrl_lstDischarge).CMUI_ListTable;
		assistant.setListTablePorts(tmpListTbl, pObj.IF_CargoField.getAllDischargePorts);
		str := tmpListTbl.getSelectedString('code');
		
	elseif pAttrName = ETRow_BookingReference then
		tmpBookingRef := sheet.getBookingRefFromMenuAction();
		if tmpBookingRef = null and
		   CM_TrackedItem.hasInstance(pObj) and pObj.CM_TrackedItem.myBookingRef &lt;&gt; null then
			tmpBookingRef := pObj.CM_TrackedItem.myBookingRef;
		endif;
		if tmpBookingRef &lt;&gt; null then
			str := tmpBookingRef.bookingReference;
		else	// If ti.myBookingReference = null what about ti.referenceBooking?	//Par 16777 cnwvu1
			if CM_TrackedItem.hasInstance(pObj) and pObj.CM_TrackedItem.bookingReference &lt;&gt; null then
				rtnCode := false;	// we should populate ti.referenceBooking as simple text. Par 16777 cnwvu1
			else
				str := null;
			endif;
		endif;
		
	elseif pAttrName = ETRow_MyBookingRefItem then
		if CM_BookingRefItem.hasInstance(pObj) then
			str := pObj.CM_BookingRefItem.getShortDisplay;
		elseif CM_TrackedItem.hasInstance(pObj) and pObj.CM_TrackedItem.myBookingRefItem &lt;&gt; null then
			str := pObj.CM_TrackedItem.myBookingRefItem.getShortDisplay;
		else
			tmpBookingRefItem := sheet.getBRefItemFromMenuAction;
			if tmpBookingRefItem &lt;&gt; null then
				str := tmpBookingRefItem.getShortDisplay;
			endif;
		endif;
	elseif pAttrName = ETRow_AllTIHazards then		//CCMS 1203 JC
		tmpHazList := sheet.getControlByName(Cntrl_lstHazardList).CMUI_HazardsListTable;
		tmpHazList.setSelectedFromObject(pObj); 	//
		str := pObj.CM_Object.getDisplayStringForAttribute(pAttrName, false);//tmpListTbl.getSelectedString('code');	
	elseif pAttrName = ETRow_AvailabilityGradeCode then
		if pObj.isKindOf(CM_Container) then
			tmpCombo := sheet.getControlByName(Cntrl_cmbAvGrade).ComboBox;		
			theRowObject := app.getCargoFieldObject(pObj, ETRow_AvailabilityGradeCode);
			operator := app.getCargoFieldObject(pObj, ETRow_OperatorCode).CM_Operator;
			tmpCombo.CMUI_ComboBoxMTGrade.setObjectAndOperator(theRowObject, operator, null);
		endif;
	elseif pAttrName = ETRow_DischargePort then
		tmpCombo := sheet.getControlByName(self.cmbDischarge.name).ComboBox;
		theVoyage := app.getCargoFieldObject(pObj, ETRow_VoyageCode).CM_Voyage;
		str := app.getCargoFieldString(pObj, ETRow_DischargePort);
		tmpCombo.GTE_ComboPorts.setObjectFromCodeAndVoyage(str, theVoyage);
		//str := tmpCombo.text;
	elseif pAttrName = ETRow_MyTranshipToPort then
		tmpCombo := sheet.getControlByName(self.cmbTranship.name).ComboBox;
		theVoyage := app.getCargoFieldObject(pObj, ETRow_VoyageCode).CM_Voyage;
		theDischargePort := app.getCargoFieldObject(pObj, ETRow_DischargePort).CM_Port;
		//str := app.getCargoFieldString(pObj, ETRow_DischargePort);
		tmpCombo.GTE_ComboPorts.setObjectAndVoyageDischPort(theDischargePort, theVoyage);
	elseif pAttrName = ETRow_VoyageCode then
		tmpCombo := sheet.getControlByName(self.cmbVoyage.name).ComboBox;
		str := app.getCargoFieldString(pObj, ETRow_VoyageCode);
		theRowObject := app.getCargoFieldObject(pObj, ETRow_VoyageCode);
		tmpInt := tmpCombo.findObject(theRowObject);
		if tmpInt &gt; -1 then
			tmpCombo.listIndex := tmpInt;
			tmpCombo.lostFocus(tmpCombo);
		else
			// Voyage is no longer current at this terminal, maybe archived or departed
			tmpCombo.text := str;
		endif;		
		//par13479 Mohammad 1/3/2007
		pos :=1;
		space := ' '; // this value depends on the seperator used b/w the code and the description in CM_Voyage::getDisplayDetails()!
		if str &lt;&gt; null then
			// strip off the description
			str := str.scanUntil(' ', pos).trimRight;
		endif;
	elseif pAttrName = ETRow_Commodity then
		tmpComboObj := sheet.getControlByName(Cntrl_cmbCommodity).CMUI_ComboBoxObject;
		theRowObject := app.getCargoFieldObject(pObj, ETRow_Commodity);
		tmpComboObj.setObject(theRowObject);
		str := tmpComboObj.text;
	elseif pAttrName = ETRow_ConsigneeCode then
		tmpCombo := sheet.getControlByName(Cntrl_cmbConsignee).ComboBox;
		theRowObject := app.getCargoFieldObject(pObj, ETRow_ConsigneeCode);
		tmpCombo.CMUI_ComboConsignors.setObject(theRowObject);
		str := tmpCombo.text;
	elseif pAttrName = ETRow_ConsignorCode then
		tmpCombo := sheet.getControlByName(Cntrl_cmbConsignor).ComboBox;
		theRowObject := app.getCargoFieldObject(pObj, ETRow_ConsignorCode);
		tmpCombo.CMUI_ComboConsignors.setObject(theRowObject);
		str := tmpCombo.text;
	elseif pAttrName = ETRow_FreightForwarderCode then
		tmpCombo := sheet.getControlByName(Cntrl_cmbFreightFwdr).ComboBox;
		theRowObject := app.getCargoFieldObject(pObj, ETRow_FreightForwarderCode);
		tmpCombo.CMUI_ComboConsignors.setObject(theRowObject);
		str := tmpCombo.text;
	elseif pAttrName = ETRow_DestinationPort then
		tmpCombo := sheet.getControlByName(self.cmbDestination.name).ComboBox;
		str := app.getCargoFieldString(pObj, ETRow_DestinationPort);
		theRowObject := app.getCargoFieldObject(pObj, ETRow_DestinationPort);
		tmpCombo.GTE_ComboPorts.setObject(theRowObject);
	//	str := tmpCombo.text;
	elseif pAttrName = ETRow_MyGeneratorType then
		if pObj.isKindOf(CM_Generator) then
			tmpCombo := sheet.getControlByName(self.cmbGenSetType.name).ComboBox;
			str := app.getCargoFieldString(pObj, ETRow_MyGeneratorType);
			theRowObject := app.getCargoFieldObject(pObj, ETRow_MyGeneratorType);
			tmpCombo.CMUI_ComboBoxGeneratorType.setObject(pObj.CM_Generator.myGeneratorType);
		endif;
	elseif pAttrName = ETRow_OperatorCode then
		tmpCombo := sheet.getControlByName(Cntrl_cmbOperator).ComboBox;
		theRowObject := app.getCargoFieldObject(pObj, ETRow_OperatorCode);
		tmpCombo.GTE_ComboOperator.setObject(theRowObject);
		str := tmpCombo.text;
	elseif pAttrName = ETRow_CargoType 
		or pAttrName = ETRow_CarriageTempC 
		or pAttrName = ETRow_CarriageTempF 
		or pAttrName = ETRow_CoolingType 
		or pAttrName = ETRow_VoltageType 
		or pAttrName = ETRow_Humidity 
		or pAttrName = ETRow_IdTextBox 
		or pAttrName = ETRow_Quantity 
		or pAttrName = ETRow_StatusString 
		or pAttrName = ETRow_Ventilation 
		or pAttrName = ETRow_CarbonDioxide						// CCMS 1654 - slw 16/09/2008
		or pAttrName = ETRow_Oxygen								// CCMS 1654 - slw 16/09/2008
		or pAttrName = ETRow_SealNum	//03 Dec 2010	NDL	Par 26506
		or pAttrName = ETRow_SealNumCustoms	//03 Dec 2010	NDL	Par 26506
		or pAttrName = ETRow_SealNumShippers	//03 Dec 2010	NDL	Par 26506
		or pAttrName = ETRow_SealNumVent	//03 Dec 2010	NDL	Par 26506
		or pAttrName = ETRow_SealNumTerminalOperator
		or pAttrName = ETRow_SealNumUnknown
		or pAttrName = ETRow_WeightTotal then
			str := pObj.IF_CargoField.getStringForETRow(pAttrName);
		
	else
		rtnCode := false;
	endif;
	
	if str &lt;&gt; null then
		pTbl.setValue(pRow, str);
	endif;
	return rtnCode;
end;</source>
        <Parameter name="pTbl" type="CM_EntryTable" usage="input"/>
        <Parameter name="pAttrName" type="String"/>
        <Parameter name="pRow" type="Integer"/>
        <Parameter name="pObj" type="Object"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setDefaultsCallBackForSheet" id="0eae6cd1-907c-4eea-a202-888ec7c8c0f9">
        <updating/>
        <source>setDefaultsCallBackForSheet(pTable : CM_EntryTable input;
							pOldCntrl, pNewCntrl : Control;
							pAttrName : String; pRow : Integer;
							_strValue : String) : Boolean updating;
//--------------------------------------------------------------
//Created: 15 May 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	assistant	: GTE_Assistant;
	tmpCombo	: ComboBox;
	tmpInt		: Integer;
begin
	assistant := self.myAssistant.GTE_Assistant;
	if pAttrName = ETRow_CargoType and pNewCntrl &lt;&gt; null then
		tmpCombo := pNewCntrl.CMUI_ComboBox;
		tmpInt := tmpCombo.findObject(pOldCntrl.CMUI_ComboBox.listObject);
		if tmpInt &gt; -1 then
			tmpCombo.listIndex := tmpInt;
			tmpCombo.click(tmpCombo);
		endif;
		return true;
		
	elseif pAttrName = ETRow_VoyageCode and pNewCntrl &lt;&gt; null then
		tmpCombo := pNewCntrl.CMUI_ComboBox;
		assistant.comboBoxVoyageCurrent(tmpCombo,
										pOldCntrl.CMUI_ComboBox.listObject.CM_Voyage,
										true,
										false,
										false,
										true,
										true,
										true,
										true,
										false,
										true);
		tmpCombo.lostFocus(tmpCombo);
		return true;
	elseif pAttrName = ETRow_DischargePort and pNewCntrl &lt;&gt; null then
	// DON'T NEED THIS AS GETS TAKEN CARE OF AUTOMATICALLY LATER
	//	tmpCombo := pNewCntrl.CMUI_ComboBox;
	//	tmpCombo.GTE_ComboPorts.setObject(pOldCntrl.GTE_ComboPorts.myObject);
	//	assistant.setDefaultDischargePort(_strValue, tmpCombo, null);
	elseif pAttrName = ETRow_DestinationPort and pNewCntrl &lt;&gt; null then
	// DON'T NEED THIS AS GETS TAKEN CARE OF AUTOMATICALLY LATER
	//	tmpCombo := pNewCntrl.CMUI_ComboBox;
	//	tmpCombo.GTE_ComboPorts.setObjectFromCode(_strValue);
	/*	tmpInt := tmpCombo.findStringExact(0, pOldCntrl.CMUI_ComboBox.text);
		if tmpInt &gt; -1 then
			tmpCombo.listIndex := tmpInt;
			tmpCombo.lostFocus(tmpCombo);
		endif;*/
	elseif pAttrName = ETRow_LogLocation and pNewCntrl &lt;&gt; null then
		tmpCombo := pNewCntrl.CMUI_ComboBox;
		tmpCombo.gotFocus(tmpCombo);
		tmpInt := tmpCombo.findObject(pOldCntrl.CMUI_ComboBox.listObject);
		if tmpInt &gt; -1 then
			tmpCombo.listIndex := tmpInt;
			tmpCombo.lostFocus(tmpCombo);
		endif;	
		return true;
	endif;

	return false;	
end;</source>
        <Parameter name="pTable" type="CM_EntryTable" usage="input"/>
        <Parameter name="pOldCntrl" type="Control"/>
        <Parameter name="pNewCntrl" type="Control"/>
        <Parameter name="pAttrName" type="String"/>
        <Parameter name="pRow" type="Integer"/>
        <Parameter name="_strValue" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setDefaultsForAttachments" id="3aedd81d-8361-4a3d-8c7c-995f1411993e">
        <updating/>
        <source>setDefaultsForAttachments(pChildren : CM_TISet) updating;
// ---------------------------------------------------------------------------
// Created:     16 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	assistant		: GTE_Assistant;
	child			: CM_TrackedItem;
	intFaceAttach	: CMIF_InOutAttachment;
	tmpRow			: Integer;
	mainTbl,
	extraTbl		: CM_EntryTable;
	numChildren		: Integer;
	sheet			: GTE_Sheet;
	
begin

	assistant := self.myAssistant.GTE_Assistant;
	sheet := self.topSheet;
	
	if sheet = null then
		return;
	endif;
	
	mainTbl := sheet.myTblMain;
	extraTbl := sheet.myTblExtra;
	
	if pChildren = null then
		numChildren := 0;
	else
		numChildren := pChildren.size;
	endif;

	if numChildren = 0 then
		assistant.mainExtraSetValue(mainTbl, extraTbl, ETRow_HasAttachments, false);
		assistant.showHideAttachmentFields(extraTbl, false);
		return;
	endif;

	// need to add children
	// create intFaceInOutAttachment (with proxy)
	assistant.mainExtraSetValue(mainTbl, extraTbl, ETRow_HasAttachments, true);
	foreach child in pChildren do
		create intFaceAttach transient;
		//intFaceAttach.set(self.myTerminal, child.cargoType, child.id, child.getISOType, child.weight);			//-cnwml2 MSL CCMS 1017
		intFaceAttach.set(self.myTerminal, child.cargoType, child.id, child.getISOType, child.totalWeight);			//+cnwml2 MSL CCMS 1017
		//intFaceAttach.setMasterItem(self.topSheet);
		//intFaceAttach.setMyProxyTrackedItem(child);
		sheet.allAttachments.add(intFaceAttach);
	endforeach;

	tmpRow := extraTbl.getRow(ETRow_AddAttachment);
	if tmpRow &gt; 0 then
		assistant.showAttachments(sheet.allAttachments, extraTbl, tmpRow);
	endif;
	assistant.showHideAttachmentFields(extraTbl, true);
end;</source>
        <Parameter name="pChildren" type="CM_TISet"/>
    </JadeMethod>
    <JadeMethod name="setDefaultsFromObject" id="9f15513d-3a9d-4de4-b3bd-0d48b054cc3b">
        <updating/>
        <source>setDefaultsFromObject(_sheet : GTE_Sheet input; _obj : Object) updating, protected;
/*
	Created on 21 January 2008
	
	by Debby Hutchison
	
	Purpose:  This method replaces the old method  setDefaultsFromObjectOld (which has not been deleted).
			It was needed so that an interface could be used to retrieve fields from objects of different types.
			Thie is required for multi item booking refs for ccms 1618.	
			
04 Jun 2009	concms1	par 19807
*/
vars
	assistant		: GTE_Assistant;
	tmpCombo,
	opCombo			: ComboBox;
	cargoId,
	imexName,
	carrier,
	cargoTypeDesc,
	customDetails	: String;
	theBookingRef	: CM_BookingRef;
	theBookingRefItem	: CM_BookingRefItem;
	theTI			: CM_TrackedItem;
	theCOU			: CM_ClipOnUnit;
	theCarrier 		: CM_Carrier;
	mainTbl,
	extraTbl		: CM_EntryTable;
	consign			: CM_ConsigneeConsignor;
	theContainer	: CM_Container;
	isoType			: CM_ISOType;
	operator		: CM_Operator;	
	custAgent		: CM_CustomsAgent;
	
	objIsLogDocketData : Boolean;
	numItems : Integer;
	productCombo	: CMUI_ComboProduct;
	genSetType 		: CM_GeneratorType; //cnwrd1 par 18222 24.2.09
	
	product			: CM_Product;
	combobox2Update	: CMUI_ComboBox;
	//children 		: CM_TISet;//PAR 22954
	
begin

	mainTbl 	:= _sheet.myTblMain;
	extraTbl 	:= _sheet.myTblExtra;
	assistant 	:= self.myAssistant.GTE_Assistant;
	
	productCombo := _sheet.getControlByName(GTE_InOutForm::cmbProduct.name).CMUI_ComboProduct;	

	if _obj = null then
	elseif CM_BookingRef.hasInstance(_obj) then
		theBookingRef := _obj.CM_BookingRef;
		//Par #17483 cnwdz2 if the theBookingRef has a product then set it as the object of the product combo box.
		if productCombo &lt;&gt; null and
		   theBookingRef.myProduct &lt;&gt; null then
			productCombo.setObject(theBookingRef.myProduct);	
		endif;
		
		//custAgent := app.myRoot.allCustomsAgents[theBookingRef.customsAgent];		//+cnwml2 PAR26255
		custAgent := theBookingRef.getCustomsAgentObject();		// PAR 26922 - change to use new method

	elseif CM_BookingRefItem.hasInstance(_obj) then
		theBookingRefItem := _obj.CM_BookingRefItem;
		//Par #17483 cnwdz2 if the theBookingRefItem has a product then set it as the object of the product combo box.
		if productCombo &lt;&gt; null and
		   theBookingRefItem.myProduct &lt;&gt; null then
			productCombo.setObject(theBookingRefItem.myProduct);	
		endif;

		//custAgent := app.myRoot.allCustomsAgents[theBookingRefItem.myBookingReference.customsAgent];			//+cnml2 PAR26255
		custAgent := theBookingRefItem.myBookingReference.getCustomsAgentObject();		// PAR 26922 - change to use new method

	elseif CM_LogDocketData.hasInstance(_obj) then
		objIsLogDocketData := true;
		cargoTypeDesc := 'Log Docket';
/*	elseif CM_Container.hasInstance(_obj) then
		theContainer := _obj.CM_Container;
		theTI := theContainer;
		if theTI.myBookingRefItem &lt;&gt; null then
			theBookingRefItem :=theTI.myBookingRefItem;
		endif;
		if theTI.myBookingRef &lt;&gt; null then
			theBookingRef :=theTI.myBookingRef;
		endif;
	dh 9/7/2008 this should happen for all tracked items, not just containers
	do moved it below:
*/
	//PAR17498 - cnwsh3	the imexname was not set for container cargo causing problems for storage items as they were defaulted to export 
	//that requires a discharge port.
	elseif CM_TrackedItem.hasInstance(_obj) then
		theTI := _obj.CM_TrackedItem;
		// dh cont'd - moved it here
		if theTI.myBookingRefItem &lt;&gt; null then
			theBookingRefItem :=theTI.myBookingRefItem;
		endif;
		if theTI.myBookingRef &lt;&gt; null then
			theBookingRef :=theTI.myBookingRef;
		endif;
			
		//Par #17483 cnwdz2 if the tracked item has a product then set it as the object of the product combo box.
		if productCombo &lt;&gt; null and theTI.myProduct &lt;&gt; null then
			
			productCombo.setObject(theTI.myProduct);	
		endif;
		
		imexName := theTI.getImExStatusStringDesc(true);

		extraTbl.setValueByName(ETRow_ExportReleaseNumber, theTI.getOperatorExpReleaseNo() ); //cnwrd1 21.11.08 CCMS JMT 1743/1764 
				
		if app.isSubTerminalsOn(self.myTerminal) and	// par 19807 - only do this if terminal uses sub-terminals
			theTI.mySubTerminal &lt;&gt; null then
			tmpCombo := _sheet.getControlByName(self.Cntrl_cmbSubTerminal).CMUI_ComboBox;	
			tmpCombo.listIndex	:=	tmpCombo.findObject(theTI.mySubTerminal);
		endif;
		
	endif;
	
	if theBookingRefItem &lt;&gt; null then
		theBookingRef := theBookingRefItem.myBookingReference;
	endif;
	
	if theBookingRef &lt;&gt; null then
		if theBookingRef.myOperator &lt;&gt; null then
			tmpCombo := _sheet.getControlByName(self.Cntrl_cmbSupplier).GTE_ComboBox;	
			//tmpCombo.GTE_ComboBox.listObject := theBookingRef.myOperator;		//par 17166 - temporary fix so it wont fall over.
			tmpCombo.GTE_ComboBox.listIndex := tmpCombo.GTE_ComboBox.findObject(theBookingRef.myOperator); //par 17166 - temporary fix so it wont fall over.
			tmpCombo.lostFocus(tmpCombo);
		endif;
	endif;
	numItems 		:= _obj.IF_CargoField.getNumItems(); // this uses an interface to retrieve the field from the object 
	isoType 		:= app.getCargoFieldObject(_obj, ETRow_IsoType).CM_ISOType;  // regardless  of its type.
	cargoId			:= _obj.IF_CargoField.getID();
	cargoTypeDesc 	:= _obj.IF_CargoField.getStringForETRow(ETRow_CargoType);
	customDetails 	:= _obj.IF_CargoField.getCustomsDetails();
	theCarrier 		:= app.getCargoFieldObject(_obj, ETRow_Carrier).CM_Carrier;
	
	genSetType		:= _obj.IF_CargoField.getObjectForETRow(ETRow_MyGeneratorType).CM_GeneratorType; //cnwrd1 par 18222 24.2.09

	tmpCombo := _sheet.getControlByName(Cntrl_cmbGenSetType).CMUI_ComboBoxGeneratorType;//cnwrd1 par 18222 24.2.09
	
	if genSetType &lt;&gt; null then //cnwrd1 par 18222 24.2.09
		tmpCombo.CMUI_ComboBoxGeneratorType.setObject(genSetType);
		tmpCombo.lostFocus(tmpCombo);
	endif;
	
	if numItems &lt;&gt; null then
		assistant.mainExtraSetValue(mainTbl, extraTbl, ETRow_NumItems, numItems);
	endif;
	if theCarrier &lt;&gt; null then
		self.cmbCarrier.setObject(theCarrier);
		self.cmbCarrier.lostFocus(cmbCarrier);
	endif;
	
	_sheet.setSubHeading(cargoId);
	// Export is the default, need to set this otherwise port fields will be hidden
	if imexName = null then
		imexName := app.getIMEXStringFromIMEXStatus(TI_IMEX_STATUS_EXPORT);
	endif;
	tmpCombo := _sheet.getControlByName(Cntrl_cmbImexStatus).ComboBox;
	if tmpCombo &lt;&gt; null then
		tmpCombo.text := imexName;
		tmpCombo.lostFocus(tmpCombo);
	endif;	
	
	self.cmbBRItem.setObject(theBookingRefItem);
	assistant.mainExtraSetValue(tblMain, tblExtra, ETRow_MyBookingRefItem, cmbBRItem.text);
	
	//set the cargo type first as table view based on cargo type
	tmpCombo := _sheet.getControlByName(Cntrl_cmbTiType).ComboBox;
	//th2 removed and condition - was not correctly show/hiding rows for cargoBOLType if user default is
	//same as bookingref bolType or cargoType
	if cargoTypeDesc &lt;&gt; null then //and cargoTypeDesc &lt;&gt; tmpCombo.text then
		tmpCombo.text := cargoTypeDesc;
		tmpCombo.click(tmpCombo);
	endif;
	
	mainTbl.setTableFromObject(_obj, GTE_InOutForm::setDefaultsCallBack.name);
	extraTbl.setTableFromObject(_obj, GTE_InOutForm::setDefaultsCallBack.name);
	//set fields where row name diff to prop name
	mainTbl.setValueByControlName(tmpCombo.name, tmpCombo.text);
	
	if CM_LogDocketData.hasInstance(_obj) then
		return;//we're done
	endif;
	
	if isoType &lt;&gt; null then
		tmpCombo := _sheet.getControlByName(Cntrl_cmbISOType).GTE_ComboISOType;	
		tmpCombo.GTE_ComboISOType.setObject(isoType);		
		tmpCombo.lostFocus(tmpCombo);
	endif;
	
	//+cnwml2 PAR26255
	if custAgent &lt;&gt; null then
		tmpCombo := _sheet.getControlByName(self.cmbCustomsAgent.name).CMUI_ComboBoxCustomsAgent;
		tmpCombo.CMUI_ComboBoxCustomsAgent.setObject(custAgent);
		extraTbl.setValueByName(ETRow_CustomsAgentCode, custAgent.code ); 
	endif;
	
	if theTI &lt;&gt; null then
		if theContainer &lt;&gt; null then
			assistant.showHideTemperatureFields(TI_CargoType_Container, theContainer.getISOTypeObject(), theContainer.operatorCode, extraTbl, theContainer.myTerminal);
			if  theContainer.getCou &lt;&gt; null then
				theCOU := theContainer.getCou; 
				assistant.mainExtraSetValue(mainTbl, mainTbl, ETRow_HasCOU, true);
				assistant.mainExtraSetValue(mainTbl, extraTbl, ETRow_CouId, theCOU.id);
				assistant.mainExtraSetValue(mainTbl, extraTbl, ETRow_CouISOType, theCOU.isoType);
				assistant.mainExtraSetValue(mainTbl, extraTbl, ETRow_CouType, app.couTypeEnumToString(theCOU.couType));
				assistant.showHideCOUFields(extraTbl, true);
			endif;
		endif;
		//theTI.getAllChildren(children);//PAR 22954
		//setDefaultsForAttachments(children);
		setDefaultsForAttachments(theTI.allChildren);//cnwsh3 - PAR25103 - allChildren collection has been unprotected reversing the need for changes from PAR22954
		
		assistant.showHideDimensionFields(extraTbl, theTI.isOverDimensions, theTI.myCargoType);
		
		// 20/11/2009 cnwmh5 PAR21492 - Start
		if theTI.isBulkOrBreakBulkGeneric and not theTI.isBulkCargo then
			extraTbl.setValueByName(ETRow_MyHeightString, theTI.CM_BreakBulkGeneric.heightString);
			extraTbl.setValueByName(ETRow_MyWidthString, theTI.CM_BreakBulkGeneric.widthString);
			extraTbl.setValueByName(ETRow_MyLengthString, theTI.CM_BreakBulkGeneric.lengthString);
			product := theTI.CM_BreakBulkGeneric.myProduct;
			if product = null then
				product := theTI.CM_BreakBulkGeneric.myCargoType.mySystemProductType;
			endif;
			combobox2Update := _sheet.getControlByName(Cntrl_cmbSysSubType).CMUI_ComboBox;	
			self.myAssistant.GTE_Assistant.comboboxSysSubType(product, _sheet.getControlByName(Cntrl_cmbTiType).CMUI_ComboBox.listObject.CM_CargoType, theTI.CM_BreakBulkGeneric.type, combobox2Update, 
				extraTbl);
		endif;
		// 20/11/2009 cnwmh5 PAR21492 - End
		
		// 07/03/2011 cnwar2 #27105
		extraTbl.setValueByName(ETRow_CurtainsIn, theTI.getCurtainsIn());
		extraTbl.setValueByName(ETRow_AllowableTimeOffPower, theTI.getAllowableTimeOffPower());
		
		extraTbl.setValueByName(ETRow_Volume, theTI.totalVolume.asStringJMT());		// 15/03/2013 cnwar2 #30744
		
	else
		assistant.clearAttachmentLines(extraTbl);
	endif;
epilog
	//delete children;
end;</source>
        <access>protected</access>
        <Parameter name="_sheet" type="GTE_Sheet" usage="input"/>
        <Parameter name="_obj" type="Object"/>
    </JadeMethod>
    <JadeMethod name="setDefaultsReceival" id="5809ddd5-db30-40d7-9292-780a40933ca2">
        <updating/>
        <source>setDefaultsReceival(pSheet : GTE_Sheet;
	pCommodity : CM_Commodity;
	pConsignor : CM_ConsigneeConsignor;
	pCouISOType : CM_ISOType;
	pDestination : CM_Port;
	pDischargePort : CM_Port;
	pDischargePorts : StringArray;
	pHazards : StringArray;
	pISOType : CM_ISOType;
	pOperator : CM_Operator;
	pCargoType : Integer;
	pVessel : CM_Vessel;
	pVoyage : CM_Voyage;
	
	pBookingReference : String;
	pCarriageTemperature : Real;
	pClean : Boolean;
	pConsignorVoyageCode : String;
	pCubicMetres : Real;
	pDescription : String;
	pHeight, pHumidity : Integer;
	pId : String;
	pInspected : Boolean;
	pLength : Integer;
	pPackTemperature : Real;
	pPackDateTime : TimeStamp;
	pQuantity : Integer;
	pRemarks : String;
	pStatus : Integer;
	pVentilation : Decimal; //par19252 cnwrs1 may 2009
	pWeight, pWidth : Integer;
	pCou : CM_ClipOnUnit;
	pChildren : CM_TISet;
	pCustomExportEntryNumber : String; //FD for adding custom details to trackedItem
	pOffsiteCleaned : Boolean;
	pOffsitePreTrip : Boolean
	
) protected, updating;
// ---------------------------------------------------------------------------
// Created:     09 February 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//	14/5/01			AA			Added COUs into the mix
// ---------------------------------------------------------------------------
//These are extra details not able to be set by setTableFromObject so we set them here
vars
	assistant	: GTE_Assistant;
	lstTable	: CMUI_ListTable;
	hazListTable: CMUI_HazardsListTable;
	cmb			: ComboBox;
	mainTbl,
	extraTbl	: CM_EntryTable;
	pDerogationNumber : String;
begin

	mainTbl 	:= pSheet.myTblMain;
	extraTbl 	:= pSheet.myTblExtra;

	assistant := self.myAssistant.GTE_Assistant;
	
	cmb := pSheet.getControlByName(Cntrl_cmbConsignor).ComboBox;
	if cmb &lt;&gt; null then
		cmb.CMUI_ComboConsignors.setObject(pConsignor);
		assistant.mainExtraSetValue(mainTbl, extraTbl, ETRow_ConsignorCode, cmb.text);
	endif;
	
	
	lstTable := pSheet.getControlByName(Cntrl_lstDischarge).CMUI_ListTable;
	if lstTable &lt;&gt; null then
		assistant.setListTablePorts(lstTable, pDischargePorts);
		assistant.mainExtraSetValue(mainTbl, extraTbl, ETRow_AllDischargePorts, lstTable.getSelectedString('code'));
	endif;

	hazListTable := pSheet.getControlByName(Cntrl_lstHazardList).CMUI_HazardsListTable;
	if hazListTable &lt;&gt; null then
		assistant.setListTableHazards(hazListTable, pHazards);
		assistant.mainExtraSetValue(mainTbl, extraTbl, ETRow_AllTIHazards, hazListTable.getSelectedString());
	endif;
	
	//property name is totalWeight - ETRow_WeightTotal referenced in reports
	assistant.mainExtraSetValue(mainTbl, extraTbl, ETRow_WeightTotal, pWeight);

	//Do the COU
	if pCou &lt;&gt; null then
		assistant.mainExtraSetValue(mainTbl, extraTbl, ETRow_HasCOU, true);
		assistant.mainExtraSetValue(mainTbl, extraTbl, ETRow_CouId, pCou.id);
		assistant.mainExtraSetValue(mainTbl, extraTbl, ETRow_CouISOType, pCou.isoType);
		assistant.mainExtraSetValue(mainTbl, extraTbl, ETRow_CouType, app.couTypeEnumToString(pCou.couType));
		assistant.showHideCOUFields(extraTbl, true);		
	else
		assistant.mainExtraSetValue(mainTbl, extraTbl, ETRow_HasCOU, false);
		assistant.showHideCOUFields(extraTbl, false);	
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="pSheet" type="GTE_Sheet"/>
        <Parameter name="pCommodity" type="CM_Commodity"/>
        <Parameter name="pConsignor" type="CM_ConsigneeConsignor"/>
        <Parameter name="pCouISOType" type="CM_ISOType"/>
        <Parameter name="pDestination" type="CM_Port"/>
        <Parameter name="pDischargePort" type="CM_Port"/>
        <Parameter name="pDischargePorts" type="StringArray"/>
        <Parameter name="pHazards" type="StringArray"/>
        <Parameter name="pISOType" type="CM_ISOType"/>
        <Parameter name="pOperator" type="CM_Operator"/>
        <Parameter name="pCargoType" type="Integer"/>
        <Parameter name="pVessel" type="CM_Vessel"/>
        <Parameter name="pVoyage" type="CM_Voyage"/>
        <Parameter name="pBookingReference" type="String"/>
        <Parameter name="pCarriageTemperature" type="Real"/>
        <Parameter name="pClean" type="Boolean"/>
        <Parameter name="pConsignorVoyageCode" type="String"/>
        <Parameter name="pCubicMetres" type="Real"/>
        <Parameter name="pDescription" type="String"/>
        <Parameter name="pHeight" type="Integer"/>
        <Parameter name="pHumidity" type="Integer"/>
        <Parameter name="pId" type="String"/>
        <Parameter name="pInspected" type="Boolean"/>
        <Parameter name="pLength" type="Integer"/>
        <Parameter name="pPackTemperature" type="Real"/>
        <Parameter name="pPackDateTime" type="TimeStamp"/>
        <Parameter name="pQuantity" type="Integer"/>
        <Parameter name="pRemarks" type="String"/>
        <Parameter name="pStatus" type="Integer"/>
        <Parameter name="pVentilation" type="Decimal"/>
        <Parameter name="pWeight" type="Integer"/>
        <Parameter name="pWidth" type="Integer"/>
        <Parameter name="pCou" type="CM_ClipOnUnit"/>
        <Parameter name="pChildren" type="CM_TISet"/>
        <Parameter name="pCustomExportEntryNumber" type="String"/>
        <Parameter name="pOffsiteCleaned" type="Boolean"/>
        <Parameter name="pOffsitePreTrip" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setDocketTypeFields" id="0c697136-69e8-483c-8894-6c301f6d7c44">
        <updating/>
        <source>setDocketTypeFields(pSheet : GTE_Sheet; pDocketType : CM_BOLType) updating;
//--------------------------------------------------------------
//Created: 17 January 2002 By: cnwgd1
//--------------------------------------------------------------
vars

	mainTable,
	extraTable	: CM_EntryTable;
	entTableDef	: EntTableDef;	
	assistant	: GTE_Assistant;
	row			: Integer;
	tmpCombo	: ComboBox;
	operator	: CM_Operator;

begin


	assistant := self.myAssistant.GTE_Assistant;

	mainTable  := pSheet.myTblMain;
	extraTable := pSheet.myTblExtra;
	if extraTable = null then
		return;
	endif;
	
	//do not remove!! - see th2
	if pDocketType.id = BOLType_GeneralDocket then
		self.tblCommon.setValueByName(ETRow_AutoComplete, '1');
		extraTable.hideRowByName(ETRow_HasAttachments, false);
		if app.getMyTerminalConfigDO_NOT_USE(GateInAutoBOLNumber).Boolean then
			mainTable.setValueByName(ETRow_BolNumber, app.getErrorString(BOLNumber_AutoGen));
			mainTable.accessRow(mainTable.getRowByName(ETRow_BolNumber)).enabled := false;
		endif;
	else
		extraTable.showRowByName(ETRow_HasAttachments, false);
	endif;
	
	extraTable.setValueByName(ETRow_HasAttachments, true);
	//Display the view for this docketType
	assistant.receival_ShowDocketRows(pDocketType, mainTable, extraTable, self.myTerminal);
	assistant.setTIHeading(pDocketType.idHeading, mainTable, false);

	tmpCombo := pSheet.getControlByName(Cntrl_cmbSupplier).ComboBox;
	row := mainTable.getRowByControlName(Cntrl_cmbSupplier);
	mainTable.setControl(row, tmpCombo);
	
	//6/11/2009 cnwdz2 20863
	if not app.isSubTerminalsOn(self.myTerminal) then
		extraTable.hideRowByName(ETRow_MySubTerminal, false);	
		mainTable.hideRowByName(ETRow_MySubTerminal, false);
	endif;
end;</source>
        <Parameter name="pSheet" type="GTE_Sheet"/>
        <Parameter name="pDocketType" type="CM_BOLType"/>
    </JadeMethod>
    <JadeMethod name="setISOTypeFields" id="927ebffb-702b-4115-bcb0-2496ef9c843d">
        <source>setISOTypeFields(pSheet : GTE_Sheet);

vars
	isoType		: CM_ISOType;
	mainTable,
	extraTable	: CM_EntryTable;
	tmpCombo	: ComboBox;
	cargoBOLType	: CM_CargoBOLType;
	type		: Integer;
	
begin

	isoType 	:= pSheet.getISOType;
	cargoBOLType	:= pSheet.getCargoBOLType;
		
	mainTable  	:= pSheet.myTblMain;
	extraTable 	:= pSheet.myTblExtra;

//	app.myController.GTE_Controller.setTablesByISOType(isoType, tiType.type, mainTable, extraTable);
	self.myAssistant.GTE_Assistant.receival_ShowRows(cargoBOLType, isoType, mainTable, extraTable, self.myTerminal);	
	
	//th2 CCMS#1452 - stops and todo task visible for entry in pre-note screen - but uses 
	//the same entDef for here (gateInOut) so need to hide them explicitly
	extraTable.hideRowByName(ETRow_AllStops, false);
	extraTable.hideRowByName(ETRow_ToDoTasks, false);
	
	//23/06/2009 cnwdz2 20072
	if not app.isSubTerminalsOn(self.myTerminal) then
		extraTable.hideRowByName(ETRow_MySubTerminal, false);
		mainTable.hideRowByName(ETRow_MySubTerminal, false);
	endif;
end;</source>
        <Parameter name="pSheet" type="GTE_Sheet"/>
    </JadeMethod>
    <JadeMethod name="setInputSplitterRatio" id="facfefd6-ef51-468c-8473-1ad7895ab1f6">
        <source>setInputSplitterRatio(pMainTbl, pExtraTbl : CM_EntryTable io; pSplitter : CMUI_SplitContainer io);
// ---------------------------------------------------------------------------
// Created:     26 April 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	tmpHeight,
	ratio			: Integer;

begin

	// calculate the number of rows in the main Table and determine the splitter percentage
	if pExtraTbl.visible then
		tmpHeight := pMainTbl.getMaxHeight();
	
		if tmpHeight &gt; pSplitter.height then
			// calculate height of extra table and
			tmpHeight := pExtraTbl.getMaxHeight();
			ratio := (tmpHeight / pSplitter.height * 100).Integer + 2;
			if ratio &gt; 20 then
				// set ratio to max of 20% of total height for the extra table
				ratio := 20;
			endif;
			// reverse ratio as it applies to the main table.
			ratio := 100 - ratio;
		else
			ratio := (tmpHeight / pSplitter.height * 100).Integer + 2;
			if ratio &gt; 90 then
				ratio := 90;
			endif;
		endif;
	else
		ratio := 100;
	endif;
	
	pSplitter.setLeftToRightRatioAndResize(ratio);

end;</source>
        <Parameter name="pMainTbl" type="CM_EntryTable" usage="io"/>
        <Parameter name="pExtraTbl" type="CM_EntryTable" usage="io"/>
