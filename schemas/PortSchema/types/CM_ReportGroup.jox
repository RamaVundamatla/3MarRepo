    <JadeMethod name="addToTable" id="da992b55-dc10-4e5b-ba3b-801e260695df">
        <source>addToTable(_tbl: Table input; _root: CM_ReportGroupRoot);
//----------------------------------------------------------------
//	Created:	15 September 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	reportGroup : CM_ReportGroup;
	obj			: Object;
	idx			: Integer;
	grpSum		: CMIF_Object;//LoadListSummaryObject;
	grpHDesc,
	grpFDesc	: String;
	class		: Class;
	portBackColour	: Integer;
	portForeColour	: Integer;
	
begin
	
	if self.allSubGroupsInPrintOrder.isEmpty() then
		foreach obj in self.allGroupedObjects do
			idx := _tbl.addItem(obj.CMIF_Object.getReportTableDisplay());
			_tbl.accessRow(idx).itemObject := obj;
		endforeach;
	else
		if self.description.trimWhiteSpace = null then
			grpHDesc := self.description &amp; "???";
			grpFDesc := self.description &amp; "??? Totals";
		else
			grpHDesc := self.description;
			grpFDesc := self.description &amp; " Totals";
		endif;
		
		idx := _tbl.addItem(self.getTableSortKey());	//spacing
		_tbl.accessRow(idx).height := 4;
		_tbl.accessRow(idx).backColor := LightYellow;
		_tbl.accessCell(idx,2).mergeCells := Table.MergeCells_Merge;
		
		//group header
		idx := _tbl.addItem(self.getTableSortKey() &amp; self.GroupStartKey &amp; Tab &amp; grpHDesc);
		_tbl.accessRow(idx).fontBold := true;
		_tbl.accessRow(idx).fontUnderline := true;
		
		if self.myRoot &lt;&gt; null then	//top group
			_tbl.accessCell(idx, 2).mergeCells := Table.MergeCells_Merge;
			_tbl.accessRow(idx).backColor := Grey;
			_tbl.accessCell(idx,1).text := self.getTableSortKey() &amp; self.GroupStartKey &amp; Tab &amp; grpHDesc.toUpper();
			grpFDesc := grpFDesc &amp; Tab;
		else
			_tbl.accessCell(idx, 3).mergeCells := Table.MergeCells_Merge;
			//18 Nov 2009	NDL	CCMS 1864 Par 21652 - set cell colour for discharge port when it is the group header
			portBackColour := 0;
			portForeColour := 0;
			self.getColoursForDischargePort( portBackColour, portForeColour );
			if portBackColour &lt;&gt; 0 or portForeColour &lt;&gt; 0 then
				_tbl.accessCell(idx, 3).backColor := portBackColour;
				_tbl.accessCell(idx, 3).foreColor := portForeColour;
			endif;
			
		endif;
		
		foreach reportGroup in self.allSubGroupsInPrintOrder do
			reportGroup.addToTable(_tbl, _root);
		endforeach;
		
		//summary row here
		create grpSum as _root.summaryClass transient;
		_root.saveTransient(grpSum);
		
		//group footer
		idx := _tbl.addItem(self.getTableSortKey() &amp; self.GroupKeyEnd &amp; Tab &amp; grpFDesc &amp; Tab &amp; grpSum.getGrpSumDisplay(self.allGroupedObjects));
		_tbl.accessRow(idx).itemObject := grpSum;
		_tbl.accessedRow.fontBold := true;

		if self.myRoot &lt;&gt; null then	//top group
			_tbl.accessRow(idx).backColor := Grey;
			_tbl.accessCell(idx,2).mergeCells := Table.MergeCells_Merge;
			_tbl.accessCell(idx,4).mergeCells := Table.MergeCells_NotAvailable;
		endif;
	endif;
end;</source>
        <Parameter name="_tbl" type="Table" usage="input"/>
        <Parameter name="_root" type="CM_ReportGroupRoot"/>
    </JadeMethod>
    <JadeMethod name="getColoursForDischargePort" id="d92cc229-4f36-4c78-b3e5-f157f3741d76">
        <source>getColoursForDischargePort( _backgroundColour : Integer output; _foregroundColour : Integer output ) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 November 2009	cnwndl1	Initial creation	CCMS 1864 Par 21652

*/

vars

	obj : Object;
	cmif : CMIF_LoadListSummaryObject;
	port : CM_Port;
	req : CM_Request;
	invalidObj : Boolean;
	uCode : String;
begin

	on Exception do app.handleDeletedObject( exception, req, invalidObj); // 32670 cnwrd1 exception handler for deleted requests.
	
	obj := self.allGroupedObjects.first;
	if obj &lt;&gt; null then
		if CMIF_LoadListSummaryObject.hasInstance( obj ) then
			cmif := obj.CMIF_LoadListSummaryObject;
			
			//21 Nov 2012	NDL	Par 30754
			req := cmif.allLoadRequests.first;
	
			if req &lt;&gt; null then
				uCode := req.userCode;
			
				if not invalidObj then
					if req.getFirstAllocation &lt;&gt; null then
						if req.isVoyageRequest then
							_backgroundColour := req.getAllocationColour;
							_foregroundColour := _backgroundColour.getInverseColour;
							return;
							
						elseif req.isSlotRequest then
							_backgroundColour := req.getAllocationColour;
							_foregroundColour := _backgroundColour.getInverseColour;
							return;
						
						endif;
					endif;
				endif;
				
			endif;
			

			
			if cmif.dischargePort &lt;&gt; null and description.pos(cmif.dischargePort,1) &gt; 0 then
				port := app.myRoot.allPortLocodes[cmif.dischargePort];
				if port &lt;&gt; null then
					_backgroundColour := port.colour;
					_foregroundColour := _backgroundColour.getInverseColour;
				endif;
			endif;
			
		endif;
	endif;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_backgroundColour" type="Integer" usage="output"/>
        <Parameter name="_foregroundColour" type="Integer" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getRoot" id="9753a244-e431-4294-8495-9b863060e7cf">
        <source>getRoot():CM_ReportGroupRoot;
//----------------------------------------------------------------
//	Created:	09 November 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin

	if self.myRoot = null then
		if self.myParentGroup &lt;&gt; null then
			return self.myParentGroup.getRoot();
		else	
			app.raiseUnexpectedProgramError(class.name, method.name, 'invalid report group structure');
			return null;
		endif;
	else
		return self.myRoot;
	endif;
	
end;</source>
        <ReturnType type="CM_ReportGroupRoot"/>
    </JadeMethod>
    <JadeMethod name="getSummaryClass" id="058cdfcc-8948-48db-9011-5d59e51b5b44">
        <source>getSummaryClass(): Class;
//----------------------------------------------------------------
//	Created:	30 September 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin

	return self.getRoot.summaryClass; 

end;</source>
        <ReturnType type="Class"/>
    </JadeMethod>
    <JadeMethod name="getTableSortKey" id="1f8c642c-5f1c-4120-9ffa-e0dea18e1dce">
        <source>getTableSortKey(): String;
//----------------------------------------------------------------
//	Created:	21 September 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	strKey		: String;
begin
	
	if self.key = null then
		strKey := '0';
	else
		strKey := self.key;
	endif;
	
	if self.myParentGroup &lt;&gt; null then
		return self.myParentGroup.getTableSortKey &amp; strKey;	
	else
		return strKey;	
	endif;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="groupLevel" id="c9ca717f-c7fc-4a32-a8ed-a65e121e29ee">
        <methodInvocation>mapping</methodInvocation>
        <source>groupLevel(set: Boolean; _value: Integer io) mapping;
//----------------------------------------------------------------
//	Created:	09 November 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin
	if set then
		return;
	else
		if self.myParentGroup = null then
			if self.myRoot = null then
				//error no root object when root object expected
				_value := null;
			else
				_value := self.myRoot.groupLevel + 1;
			endif;
		else
			_value := self.myParentGroup.groupLevel + 1;
		endif;
		
	endif;

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="groupObject" id="5c261258-6702-4057-af86-d28abb9b6cb5">
        <source>groupObject(_obj: Object);
//----------------------------------------------------------------
//	Created:	09 November 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	keyPropValue	: Any;
	propName		: String;
	repGroup		: CM_ReportGroup;
begin
	
	propName := self.getRoot().allGroupPropertyNames[self.groupLevel];
	
	keyPropValue := _obj.getPropertyValue(propName);
	
	if keyPropValue.isKindOf(Integer) then
		//if integer then value is treated as the sort order
		repGroup := self.allSubGroupsInPrintOrder[keyPropValue.Integer];	
	elseif keyPropValue.isKindOf(String) then
		repGroup := self.allSubGroupsByKeyValue[keyPropValue.String];
	else
		app.writeStatement('CNWJC2 ' &amp; class.name &amp; " " &amp; method.name &amp;  " unsupported property type - add type");
	endif;
	
	
	if repGroup = null then
		create repGroup transient;
		repGroup.setForCreateGroup(self, propName, keyPropValue, _obj);
	endif;
	
	repGroup.allGroupedObjects.add(_obj);

	//do sub grouping...
	
	if self.getRoot().allGroupPropertyNames.size &gt; self.groupLevel then
		//if there are n group property names then there should be n levels
		//if the number of property names is greater than the current level then keep grouping
		repGroup.groupObject(_obj);
	endif;
	
	
end;</source>
        <Parameter name="_obj" type="Object"/>
    </JadeMethod>
    <JadeMethod name="removeObject" id="026ec780-1934-4b54-a0db-91f60288ad40">
        <source>removeObject(_obj: Object);
//----------------------------------------------------------------
//	Created:	21 September 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	keyPropValue	: Any;
	propName		: String;
	repGroup		: CM_ReportGroup;
	theObject		: Object;
begin
	theObject := _obj;
	propName := self.getRoot().allGroupPropertyNames[self.groupLevel];
	
	keyPropValue := theObject.getPropertyValue(propName);
	
	if keyPropValue.isKindOf(Integer) then
		//if integer then value is treated as the sort order
		repGroup := self.allSubGroupsInPrintOrder[keyPropValue.Integer];	
	elseif keyPropValue.isKindOf(String) then
		repGroup := self.allSubGroupsByKeyValue[keyPropValue.String];
	else
		app.writeStatement('CNWJC2 ' &amp; class.name &amp; " " &amp; method.name &amp;  " unsupported property type - add type");
	endif;
	
	
	if repGroup = null then
		//can't find
		return;
	endif;
	
	repGroup.allGroupedObjects.remove(theObject);

	//do sub grouping...
	
	if self.getRoot().allGroupPropertyNames.size &gt; self.groupLevel then
		//if there are n group property names then there should be n levels
		//if the number of property names is greater than the current level then keep grouping
		repGroup.removeObject(theObject);
	else
		delete theObject;
	endif;
	
	
end;</source>
        <Parameter name="_obj" type="Object"/>
    </JadeMethod>
    <JadeMethod name="setForCreateGroup" id="ff20de98-9485-4d06-b23c-ddcbae732168">
        <updating/>
        <source>setForCreateGroup(_parent: CM_ReportGroup; _label: String; _key: Any; _theObject: Object) updating;
//----------------------------------------------------------------
//	Created:	09 November 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	str		: String;
	int		: Integer;
	strKey	: String;
begin

	self.label := _label;
	self.key := _key.String;
	self.myParentGroup := _parent;

	//sort order set here
	_theObject.sendMsgWithParams('setReportGroupFromSelf', self);


/*


	if _key.isKindOf(Integer) then
		self.sortOrder := _key.Integer;

	elseif _key.isKindOf(String) then
		strKey := _key.String;

		foreach int in 1 to strKey.length do
			if int &gt; 5 then
				break;
			endif;
			str := str &amp; strKey[int:1].Integer.String;
		endforeach;

		
		self.sortOrder := str.Integer;	
		
	endif;
*/	
end;</source>
        <Parameter name="_parent" type="CM_ReportGroup"/>
        <Parameter name="_label" type="String"/>
        <Parameter name="_key" type="Any"/>
        <Parameter name="_theObject" type="Object"/>
    </JadeMethod>
    <JadeMethod name="setGroupRoot" id="741218e5-abfb-4eba-a46e-502f837f88a2">
        <updating/>
        <source>setGroupRoot(_theRoot: CM_ReportGroupRoot) updating;
//----------------------------------------------------------------
//	Created:	09 November 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin
	self.myRoot := _theRoot;

end;</source>
        <Parameter name="_theRoot" type="CM_ReportGroupRoot"/>
    </JadeMethod>
