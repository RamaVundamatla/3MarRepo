    <JadeMethod name="startBlame" id="2ea24135-52c5-41ab-a41e-e96658437558">
        <source>startBlame( _name : String ):UM_Blame;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
31 December 2010	cnwndl1	Initial creation

*/

vars

	blame : UM_Blame;

begin

	beginTransaction;
	create blame;
