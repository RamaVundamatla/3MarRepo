    <JadeMethod name="doMatch" id="5c209e35-27ba-4019-8dfe-d4e08ee4e420">
        <updating/>
        <source>doMatch() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 November 2019	jlgab1	Initial creation

*/

vars
	updateTI, pxyTI : CM_TrackedItem;
	theReturn : Integer;
begin
	if self.myTBAItem = null then
		return;
	endif;
	
	if self.tblData.row &lt;= self.tblData.fixedRows then
		return;
	endif;
	
	updateTI := self.tblData.accessRow(self.tblData.row).itemObject.CM_TrackedItem;
	
	if updateTI = null then
		return;
	endif;
	
	pxyTI := app.createUpdateProxy(updateTI).CM_TrackedItem;
	
	self.setProxy(pxyTI);
			
	while true do
		app.myTrxUA.trxUpdateTrackedItemFromTBA(pxyTI, null, TI_UPDMODE_NORMAL, self.myTBAItem, app.myPassport);
		if app.myPassport.trxCompletedOK then
			self.clearErrorWarnings();
			global.beep;
			break;
		else
			theReturn := app.showErrorWarningDialog(app.getErrorString(TBAList), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			return;
		endif;
		break;
	endwhile;

	
epilog
	delete pxyTI;
end;</source>
    </JadeMethod>
    <JadeMethod name="doQuery" id="08918916-5d98-4704-a42d-a5cdfa02c670">
        <source>doQuery();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 November 2019	jlgab1	Initial creation

*/

vars
	theTI : CM_TrackedItem;
	iter : Iterator;
	
	tis : CM_TISet;
	theDataLine : String;
	idx, colid, colv, cold : Integer;
begin

	self.tblData.rows := self.tblData.fixedRows;
	
	if self.myTBAItem = null then
		return;
	endif;
	
	create tis transient;
	
	// POSSIBLE MATCH TO TRANSHIP and EXPORT CONTAINERS THAT ARE ON SITE
	iter := self.myTerminal.allOnsiteTIsByCargoTypeId.createIterator();
	theTI := self.myTerminal.allOnsiteTIsByCargoTypeId.getAtKeyGeq(TI_CargoType_Container,null);
	
	if theTI &lt;&gt; null
	and theTI.cargoType = TI_CargoType_Container then
	
		
		iter.startAtObject(theTI);
		while iter.next(theTI) do
			if theTI.cargoType &lt;&gt; TI_CargoType_Container then
				break;
			endif;
			
			if theTI.isPlannedToShip then
				continue;
			endif;
			
			if not theTI.isTranshipItem 
			and not theTI.isExport then
				continue;
			endif;
			
			if theTI.isTranshipItem then
				if theTI.id = self.myTBAItem.id then
					tis.addNoDuplicates(theTI,false);
				elseif theTI.myVoyageTranshipExport = self.myTBAItem.myVoyage 
				// We are only looking at on site tranships so at this point the discharge port on the TI is the same as on the T/S Details
				and theTI.getDischargePortObject() = self.myTBAItem.getDischargePortObject() then
					tis.addNoDuplicates(theTI,false);
				endif;
			elseif  theTI.isExport then
				if theTI.id = self.myTBAItem.id then
					tis.addNoDuplicates(theTI,false);
				elseif theTI.myVoyage = self.myTBAItem.myVoyage 
				and theTI.dischargePort = self.myTBAItem.dischargePort then
					tis.addNoDuplicates(theTI,false);
				endif;
			endif;
		endwhile;
	endif;
	
	
	// POSSIBLE MATCH TO PRENOTE CARGO
	iter := self.myTerminal.allNotifiedTIsByCargoTypeId.createIterator();
	theTI := self.myTerminal.allNotifiedTIsByCargoTypeId.getAtKeyGeq(TI_CargoType_Container,null);
	
	if theTI &lt;&gt; null
	and theTI.cargoType = TI_CargoType_Container then
		iter.startAtObject(theTI);
		while iter.next(theTI) do
			if theTI.cargoType &lt;&gt; TI_CargoType_Container then
				break;
			endif;
			
			if theTI.isPlannedToShip then
				continue;
			endif;

			if theTI.id = self.myTBAItem.id then
				tis.addNoDuplicates(theTI,false);
			elseif theTI.myVoyage = self.myTBAItem.myVoyage 
			and theTI.dischargePort = self.myTBAItem.dischargePort then
				tis.addNoDuplicates(theTI,false);
			endif;
		
		endwhile;
	
	endif;
	
	
	// ### DISPLAY CONTAINERS
	
	colid := self.tblData.getColumnByRowName(ETRow_Id);
	colv := self.tblData.getColumnByRowName(ETRow_VoyageCode);
	cold := self.tblData.getColumnByRowName(ETRow_DischargePort);
	
	foreach theTI in tis discreteLock do
		theDataLine := theTI.getAttributeStringForDefArray(self.tblData.allTblDataEntRows);
		idx := self.tblData.addItemObject(theTI, theDataLine.trimBlanks);
		
		if theTI.id = self.myTBAItem.id then
			if colid &gt; 0 then
				self.tblData.accessCell(idx,colid).backColor := LightYellow;
			endif;
		else	
			if colv &gt; 0 then
				self.tblData.accessCell(idx,colv).backColor := LightYellow;
			endif;
			if cold &gt; 0 then
				self.tblData.accessCell(idx,cold).backColor := LightYellow;
			endif;
			
		endif;
	
	endforeach;
	

epilog
	delete tis;
end;</source>
    </JadeMethod>
