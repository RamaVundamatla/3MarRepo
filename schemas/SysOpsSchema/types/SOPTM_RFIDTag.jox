    <JadeMethod name="doSave" id="dd6cc115-2031-4fd8-8bd7-4d16f600ec45">
        <updating/>
        <source>doSave(): Boolean updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
17 August 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars
	theForm : SOP_TableMaintForm;
	tbl		: CM_EntryTable;
	code,
	description,
	remarks,
	internalNumber : String;
	isAvailable : Boolean;
	proxyRFIDTag : CM_RFIDTag;
begin

	theForm := self.myForm;
	tbl := theForm.tblInput1;
	
	code := tbl.getValueByName(ETRow_Code).String;
	description := tbl.getValueByName(ETRow_Description).String;
	internalNumber := tbl.getValueByName(ETRow_SerialNumber).String;
	isAvailable := tbl.getValueByName(ETRow_IsAvailableForEntry).Boolean;
	remarks:=tbl.getValueByName(ETRow_Remarks).String;
	
	//23 Apr 2012	NDL	Par 29417
	if internalNumber = null then
		internalNumber := code;
	endif;
	
	if theForm.myProxyObject = null then
		if theForm.mode = theForm.Mode_Add then
			create theForm.myProxyObject as CM_RFIDTag transient;
		endif;
		if theForm.myProxyObject = null then
			app.raiseUnexpectedProgramError(class.name, method.name, 'Proxy object is null for update');
			return false;
		endif;
	endif;

	proxyRFIDTag:=theForm.myProxyObject.CM_RFIDTag;
	proxyRFIDTag.setProxy(code,description,internalNumber,isAvailable,remarks);
	
	if theForm.mode = theForm.Mode_Add then
		app.myTrxCA.trxCreateRFIDTag(proxyRFIDTag,
									 theForm.myCurrentObject,
									 theForm.myTerminal,
									app.myPassport);
	else
		app.myTrxUA.trxUpdateRFIDTag(proxyRFIDTag,theForm.myTerminal,
									app.myPassport);
	endif;
	return app.myPassport.trxCompletedOK;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
