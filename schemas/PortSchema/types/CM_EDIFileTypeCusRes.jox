    <JadeMethod name="getVehicleCargoTypeId" id="803e3ae2-b6e3-4e25-96af-c9b2f29a3fb5">
        <source>getVehicleCargoTypeId() : Integer;
//
// 05 Oct 2018	jlgrs1 TFS40858 CPL - CUSRES file not finding the car cargotype in systems created after the TI_CargoType_Car was deprecated, mainly testing systems
//
vars
	cargoType : CM_CargoType;
begin
	foreach cargoType in app.myRoot.allCargoTypesById do
		if cargoType.isVehicle then
			break;
		endif;
	endforeach;
	if cargoType.isVehicle then
		return cargoType.id;
	else
		return 0;
	endif;
epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="processCustomsResponse" id="f2804607-1054-464b-8c43-436260bead19">
        <source>processCustomsResponse(_fieldValue: String; _responseStatus: String output; _ableToProcess: Boolean output);
//----------------------------------------------------------------
//	Created:	01 September 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	okToProcess	: Boolean;
	response	: String;
begin
	response	:= _fieldValue;
	
	if response = Customs_Import_Cleared 		//import goods cleared				834
	or response = Customs_Export_Cleared 		//export goods cleared				846
	or response = Customs_Deliver_BreakBulk 	//customs clearance Break bulk		819
	or response = Customs_Tranship_Cleared 		//customs clearance Tranship		850
	or response = Customs_Import_Cancel 		//customs clearance revoked			848
	or response = Customs_Export_Cancel 		//customs clearance revoked			849
	or response = Customs_Tranship_Cancel		//customs clearance revoked			851
	or response = MAF_ContainerCancellation		//MAF cancellation					857
	or response = MAF_ActionRequired 			//MAF action required				855
	or response = SEP_ContainerCancellation		//SEP cancellation					854
	or response = SEP_ContainerRelease			//SEP Release						853
	or response = SEP_InspectionRequired 		//SEP Inspection required			852
	then
		okToProcess := true;
	else
		okToProcess := false;
	endif;

epilog
	_responseStatus	:= response;
	_ableToProcess := okToProcess;
end;</source>
        <Parameter name="_fieldValue" type="String"/>
        <Parameter name="_responseStatus" type="String" usage="output"/>
        <Parameter name="_ableToProcess" type="Boolean" usage="output"/>
    </JadeMethod>
    <JadeMethod name="processFile" id="03fb316f-bc24-41b4-9ad3-d0b893ebc965">
        <updating/>
        <source>processFile(_ediFile: CM_EDIFile input) protected, updating;
// create container.id
// 15 aug 2012 cnwrs1 par 30203 failing to load with muliple UNH/UNTs
// 07/03/2013	cnwcs5	CCMS POL 2097 / par 31259 - include _foundMatch in method signatures
// 16 Sep 2013 cnwah9 removed error messages and unnecessary code
// 09 Dec 2013 cnwah9 par 31825 check for EQD segment to both catter to cars packed in containers, and to release BOL numbers.
//12 Jan 2015	cnwrs1	Par 35504 - Refactor EDI file load for .NET
//10 Sep 2015	cnwrs1	Par 32883 - EDI File Type sequence number
//08 Oct 2015	cnwrs1	Par 36863 - make EDI consistant times when refreshing progress bar
// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
// 04 Aug 2016	cnwrs1	Par 38117 make deleted EDI for finable
// 08 May 2018	jlgrs1	TFS 36425 SingleLine Booking partial processing not working
// 19 Sep 2018	jlgrh7 TFS40858 CPL - CUSRES file to handle PAC+++VN as Vehicle
// 05 Oct 2018	jlgrs1 TFS40858 CPL - CUSRES file not finding the car cargotype in systems created after the TI_CargoType_Car was deprecated, mainly testing systems
// 18 Jan 2019	jlgrs1	TFS 41659 42276 STWR Make EDI MultiThreaded Stage 8
// 08 Apr 2019	jlgrs1	TFS 41913 STWR - Reconfiguration of the EDI Operation form to better handle EDI collection locks while loading 
// 08 Sep 2022	jlizm1	TFS 54673 SNO Additional data mappings for CUSRES
// 19 Sep 2025  navvk1  MTN-35857 SNO - Add support to CUSRES for trailer cargo type
//
constants
	ProgressBarRefresh	: Integer = 2000;	
vars
	existingEDITI			: CM_EDICustomStopTI;
	ediTI					: CM_EDICustomStopTI;
	prevEDITI				: CM_EDICustomStopTI;
	ediData					: CM_EDIDataCustomStop;
	existingTI				: CM_EDITrackedItem;
	int						: Integer;
	group					: Integer;
	untCount				: Integer;
	msgCount				: Integer;
	numMsgs					: Integer;
	generatedContainerNo	: Integer;
	lineStr					: String;
	responseStatus			: String;
	ableToClear				: Boolean;
	voyageCode				: String;
	message					: String;
	vesselName				: String;
	tiId					: String;
	billOfLading			: String;		// cnwrl1 19/02/2010 PAR 20113 (was bkRef)
	entryNumber				: String;
	entryNumberEdition		: String;
	operatorSenderCode		: String;			// cnwrl1 22/07/2010 PAR 25093
	operatorVoyageCode		: String;			// cnwrl1 20/07/2010 PAR 25046
	lloydsNumber			: String;			// cnwrl1 20/07/2010 PAR 25046
	callSign				: String;			// cnwrl1 20/07/2010 PAR 25046
	operatorVoyage			: CM_Operator;		// cnwrl1 21/07/2010 PAR 25093
	operatorSender			: CM_Operator;		// cnwrl1 22/07/2010 PAR 25093
	passport				: CM_Passport;
	tmpStr					: String;
	consignor				: String;
	details					: String;
	freeText				: String;
	msgDate					: Date;
	msgTime					: Time;
	fileID					: String;
	aTIID					: String;
	msgRef					: String;
	msgHelper				: CMIF_EDIFACTHelper;
	mafActions				: String;
	quarantineInstructions	: String;
	clientRef				: String;
	customsAgent			: String;
	consignee				: String;
	importItem				: Boolean;
	ignoreTillNextDOC		: Boolean;
	carPacProcessed			: Boolean;
	isEQD					: Boolean;
//	binaryLine				: Binary;
	isExistingFound			: Boolean;
	packCount				: Integer;
	vesselCode 				: String;	//par 26022 cnwrs1 19 Oct 2010
	vessel 					: CM_Vessel;
	foundMatch				: Boolean;
	theLines	 			: HugeStringArray;
	rawSenderCode 			: String;
	creationTS 				: TimeStamp;
	sequence 				: String;
	fileType 				: String;
	version 				: String;
	recipientCode 			: String;
	progressInt				: TimeStampInterval;
	progressTS 				: TimeStamp;
	tmpField 				: String;
	tiDescription			: String;
begin
	progressTS := app.actualTimeServer();// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	passport 				:= app.myPassport;
	generatedContainerNo 	:= 1;
	ediData 				:= _ediFile.ediData.CM_EDIDataCustomStop;
	ableToClear 			:= false;
	responseStatus 			:= Customs_Deliver_Null;
	fileID 					:= _ediFile.fileName.getFileName();       
	isEQD					:= false; // Par 31825 cnwah9
	
	create msgHelper transient;
	msgHelper.setEDIFile(_ediFile);

	create theLines transient;
	self.rawDataToHSA(_ediFile, theLines);
	numMsgs	:= theLines.size;
	foreach lineStr in theLines do
		msgCount	:=	msgCount + 1;
		
		progressInt := app.actualTimeServer() - progressTS;// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		if passport.myCMIFMonitor &lt;&gt; null  and (progressInt.getMilliseconds &gt;= ProgressBarRefresh) then
			passport.myCMIFMonitor.updateProgressWithCaption("Processing File Data", numMsgs, msgCount, "Loading EDI file Step 3 of 3.");
			progressTS := app.actualTimeServer();// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		endif;

		msgHelper.setNextMessage(lineStr);	//set the current message
		
		//get current
		message := msgHelper.currentMessage;
		if ignoreTillNextDOC then  //ccms 1058
			if msgHelper.currentTag &lt;&gt; "DOC" and
			   msgHelper.currentTag &lt;&gt; "EOF" and
			   msgHelper.currentTag &lt;&gt; "UNT" and
			   msgHelper.currentTag &lt;&gt; "UNZ" then
				untCount := untCount + 1; //cnwgb1 PAR 18492 27.11.08
				continue;
			else
				ignoreTillNextDOC := false;
			endif;
		endif;
//BGM
		if msgHelper.currentTag = "BGM" then
			untCount := untCount + 1;
			msgHelper.setNextField;
			if msgHelper.currentSubItem = "932" then	//delivery order
				msgHelper.setNextField;
				entryNumber := msgHelper.currentSubItem;
				msgHelper.setNextSubItem;
				entryNumberEdition := "";
				if msgHelper.currentSubItem &lt;&gt; null then
					entryNumberEdition := msgHelper.currentSubItem;
					entryNumber := entryNumber &amp; "/" &amp; entryNumberEdition;
				endif;
			elseif msgHelper.currentSubItem = "962" then	//Inspection Audit Requirement
				msgHelper.setNextField;
				entryNumber := msgHelper.currentSubItem;
				msgHelper.setNextSubItem;
				entryNumberEdition := "";
				if msgHelper.currentSubItem &lt;&gt; null then
					entryNumberEdition := msgHelper.currentSubItem;
					entryNumber := entryNumber &amp; "/" &amp; entryNumberEdition;
				endif;
			endif;
			mafActions := null;
			ableToClear := false;
			responseStatus := Customs_Deliver_Null;
			
//DOC
		elseif msgHelper.currentTag = "DOC" then
			untCount := untCount + 1;
			msgHelper.setNextField;
			freeText := msgHelper.currentField;
			tiDescription := null;
			if freeText = "964" then
				msgHelper.setNextField();
			endif;
			if freeText = "25" or
			   freeText = "964"  then//par13136 dec 2006 cnwrs1
				if ediTI &lt;&gt; null then
					ediTI.setFTXdata(mafActions, quarantineInstructions);
				endif;
				quarantineInstructions := null;
				
				// cnwrl1 20/07/2010 PAR 25046 - start of coding
				// Use the operator voyage code translation if it exists.
				voyageCode	:= self.getXlationOperatorVoyageCode(	operatorSender,
																	operatorVoyage,
																	voyageCode,
																	vesselName,
																	lloydsNumber,
																	callSign );
				// cnwrl1 20/07/2010 PAR 25046 - end of coding
				
				if ableToClear then
					create ediTI;
					ediTI.setForCreateNew(ediData);
					ediTI.setMyEDIFile(_ediFile);
					ediTI.setCSTIDetails(voyageCode, vesselName, entryNumber, entryNumberEdition, responseStatus, freeText, consignor, consignee, customsAgent, clientRef, msgDate, msgTime, fileID, msgRef);
				else
					//test a file with this missing - preferably a multi message file
					self.addFileErrors("Missing GIS+?" &amp; Tab &amp; group.String &amp; Tab &amp; msgHelper.currentMessage, msgHelper.currentMessageNumber, _ediFile );
					create ediTI;
					ediTI.setForCreateNew(ediData);
					ediTI.setMyEDIFile(_ediFile);
					ediTI.setCSTIDetails(voyageCode, vesselName, entryNumber, entryNumberEdition, responseStatus, freeText, consignor, consignee, customsAgent, clientRef, msgDate, msgTime, fileID, msgRef);
				endif;
			endif;
//EQD
		elseif msgHelper.currentTag = "EQD" then
			isEQD:=true;
			untCount := untCount + 1;
			if group = 0 then
				group := 0;
				msgHelper.setNextField;
				if ediTI &lt;&gt; null then
					if msgHelper.currentField = "CN" then
						if carPacProcessed then
							// cnwrl1 20/07/2010 PAR 25046 - start of coding
							// Use the operator voyage code translation if it exists.
							voyageCode	:= self.getXlationOperatorVoyageCode(	operatorSender,
																				operatorVoyage,
																				voyageCode,
																				vesselName,
																				lloydsNumber,
																				callSign );
							// cnwrl1 20/07/2010 PAR 25046 - end of coding
							
							prevEDITI := ediTI;
							create ediTI;
							ediTI.setForCreateNew(ediData);
							ediTI.setMyEDIFile(_ediFile);
							ediTI.setCSTIDetails(voyageCode, vesselName, entryNumber, entryNumberEdition, responseStatus, freeText, consignor, consignee, customsAgent, clientRef, msgDate, msgTime, fileID, msgRef);
						endif;
						ediTI.setCargoType(TI_CargoType_Container);
						msgHelper.setNextField;
						
						//cnwmc5 - 8 June 2016 - TFS 2121 - changed to use 'msgHelper.currentSubItem'
						//tiId := msgHelper.currentField[1:12].trimBlanks;
						tiId := msgHelper.currentSubItem[1:12].trimBlanks;
						if tiId.length &lt; 12 then
							aTIID := tiId;			//format  XXXXNNNNNNN
							//container.id := tiId;			//format  XXXXNNNNNNN
						else
							aTIID := tiId[1:4] &amp; tiId[6:7];	//format  XXXX NNNNNNN
							//container.id := tiId[1:4] &amp; tiId[6:7];	//format  XXXX NNNNNNN
						endif;
						
						msgHelper.setNextField;
						msgHelper.setNextField;
						msgHelper.setNextField;
						msgHelper.setNextField;
						if msgHelper.currentField = "4" then
							ediTI.fullOrMT := "E";		//MT
						elseif msgHelper.currentField = "5" then
							ediTI.fullOrMT := "F";		//FCL
						elseif msgHelper.currentField = "7" then
							ediTI.fullOrMT := "L";		//LCL
						elseif msgHelper.currentField = "8" then
							ediTI.fullOrMT := "B";		//Bulk consignment - ??
						endif;
					
					elseif msgHelper.currentField = "TE" then // MTN-35857 Trailer support 19/09/2025
						ediTI.setCargoType(passport.myTerminal.defaultTrailerCargoType);
                        msgHelper.setNextField;
                        aTIID := msgHelper.currentSubItem.trimBlanks;
                        ediTI.fullOrMT := "B"; // MTN-35857 Trailer support 19/09/2025
						
						
					elseif msgHelper.currentField = "BB" or 		//break bulk
					msgHelper.currentField = "PA" then				//pallet
						ediTI.setCargoType(TI_CargoType_BreakBulk);
						msgHelper.setNextField;
						aTIID := msgHelper.currentField.trimBlanks;
						//container.id := msgHelper.currentField.trimBlanks;
						ediTI.fullOrMT := "B";
					
				
					endif;
					
					if aTIID &lt;&gt; null then
						//check for dups - container.id will already be unique so updating it could cause dup key error
						existingEDITI := ediData.allUnprocCustByRespID[ediTI.responseStatus, aTIID];
						if existingEDITI &lt;&gt; null then
							//remove it from collection
							existingEDITI.setStatus(CM_EDIFile.EDI_STATUS_DBLOADED);
						endif;

						ediTI.setId(aTIID);
					endif;
					
					int := int + 1;
				endif;
			endif;
//ERC
		elseif msgHelper.currentTag = "ERC" then
			untCount := untCount + 1;
//ERP
		elseif msgHelper.currentTag = "ERP" then
			untCount := untCount + 1;
//FTX
		elseif msgHelper.currentTag = "FTX" then
			untCount := untCount + 1;
			if group = 0 then
				msgHelper.setNextField;
				tmpField := msgHelper.currentField;
				if tmpField = "AAA"
				or tmpField = "AAI"
				or tmpField = "ACD"
				or tmpField = "ICN"
				or tmpField = "QIN"
				or tmpField = "DIN" then
					msgHelper.setNextField;
					msgHelper.setNextField;
					msgHelper.setNextField;
					freeText := msgHelper.currentSubItem;
					
					if tmpField = "AAA" then 		// TFS 54673
						tiDescription := (tiDescription &amp; " " &amp; freeText).trimBlanks();
						msgHelper.setNextSubItem();
						// loop to append any subitems together
						while msgHelper.currentSubItem &lt;&gt; null do
							tiDescription := tiDescription &amp; " " &amp; msgHelper.currentSubItem;
							msgHelper.setNextSubItem();
						endwhile;
						if ediTI &lt;&gt; null then
							ediTI.setDescription(tiDescription);
						endif;

					elseif tmpField = "AAI" then	// TFS 54673
						msgHelper.setNextSubItem();
						// loop to append any subitems together
						while msgHelper.currentSubItem &lt;&gt; null do
							freeText := freeText &amp; " " &amp; msgHelper.currentSubItem;
							msgHelper.setNextSubItem();
						endwhile;
						if ediTI &lt;&gt; null then
							ediTI.setRemarksAdditional1((ediTI.remarksAdditional1 &amp; " " &amp; freeText).trimBlanks);
						endif;
						
					elseif tmpField = "ACD"
						or tmpField = "ICN" then
						freeText := freeText[1:30];
						
					elseif tmpField = "QIN" then
						quarantineInstructions := freeText;
						
					elseif tmpField = "DIN" then
						mafActions := freeText;
						freeText := freeText[1:30]; //also add this to description for BBLK dlivery orders
					endif;
				endif;
			endif;
//GIS
		elseif msgHelper.currentTag = "GIS"
			or msgHelper.currentTag = "GEI" then // TFS 54673
			untCount := untCount + 1;
			msgHelper.setNextField;
			
			self.processCustomsResponse(msgHelper.currentSubItem, responseStatus, ableToClear);

//LOC
		elseif msgHelper.currentTag = "LOC" then
			untCount := untCount + 1;
			msgHelper.setNextField;
			if msgHelper.currentField = "11" then
				msgHelper.setNextField;
				if msgHelper.currentField = app.getMyTerminalDO_NOT_USE().getConfig(PortDestCode).String then
				   importItem := true;
				endif;
			endif;
//NAD
		elseif msgHelper.currentTag = "NAD" then
			untCount := untCount + 1;
			if group &lt; 0 then
				group := 0;
			endif;
			msgHelper.setNextField;
			if msgHelper.currentField = "AL" then // client, receiver
				msgHelper.setNextField;
				if app.getMyTerminalDO_NOT_USE().getConfig(EDICusresConsignorCode).Boolean then
					msgHelper.setNextField;
				endif;
				if importItem then
					consignee := msgHelper.currentSubItem;
				else
					consignor := msgHelper.currentSubItem;
				endif;
			elseif msgHelper.currentField = "CB" then
				msgHelper.setNextField;
// cnwdad1 23/07/2010 - PAR 24534, was not translating the Customs Agent. If a translation is not found, the original value is returned.
//				customsAgent := msgHelper.currentSubItem;
				customsAgent	:=	app.myRoot.getXlationSystemCode(msgHelper.currentSubItem, XLATION_TYPE_CUSTOMSAGENT, foundMatch);	// par 31259
				
				if ediTI &lt;&gt; null then	//cnwrs1 par 22838 9 mar 2010
					ediTI.setCustomsAgent(customsAgent);
				endif;
				
			elseif msgHelper.currentField = "CZ" then	// TFS 54673
				msgHelper.setNextField;					// TFS 54673
				if app.getMyTerminalDO_NOT_USE().getConfig(EDICusresConsignorCode).Boolean then	// TFS 54673
					msgHelper.setNextField;				// TFS 54673
					msgHelper.setNextField;				// TFS 54673
				endif;
				consignor := msgHelper.currentSubItem;	// TFS 54673
				
			elseif msgHelper.currentField = "SU" then //supplier 
				msgHelper.setNextField;
				if app.getMyTerminalDO_NOT_USE().getConfig(EDICusresConsignorCode).Boolean then
					msgHelper.setNextField;
				endif;
				if importItem then
					consignor := msgHelper.currentSubItem;
				else
					consignee := msgHelper.currentSubItem;
				endif;
			endif;
//PAC
		elseif msgHelper.currentTag = "PAC" then
			untCount := untCount + 1;
			
			msgHelper.setNextField;
			
			ignoreTillNextDOC := false;
			details := msgHelper.currentField;
			
			msgHelper.setNextField;
			msgHelper.setNextField;
			
			details := details &amp; " x " &amp; msgHelper.currentField;
			
			//if msgHelper.currentField = "VE" then																													//-TFS40858
			if msgHelper.currentField = "VE" or msgHelper.currentField = "VN" then												//+TFS40858 UN/EDIFACT standards recommends VN for Vehicle 
				ediTI.setCargoType(self.getVehicleCargoTypeId);
				ediTI.setPackCount(details.Integer); //ccms 1058 //cnwrs1 par 27278 24 March 2011
				
				if ediTI.packCount = 0 then
					ignoreTillNextDOC := true;
					delete ediTI;
					
					ediTI := null;
					continue;
				endif;
				
				ediTI.setPackDetail(details);
				
				carPacProcessed := true;
			else
				if not carPacProcessed then	//cnwrs1 par27278 24 March 2011
					ediTI.setCargoType(TI_CargoType_BreakBulk);
					ediTI.setPackCount(details.Integer); //ccms 1058 //cnwrs1 par 27278 24 March 2011
					
					if ediTI.packCount = 0 then
						ignoreTillNextDOC := true;
						delete ediTI;
						
						ediTI := null;
						continue;
					endif;
					ediTI.setPackDetail(details);
				endif;
			endif;
//RFF
		elseif msgHelper.currentTag = "RFF" then
			untCount := untCount + 1;
			
			msgHelper.setNextField();
			if ediTI &lt;&gt; null then
				// ABU = Parcel Number (for mail)
				if msgHelper.currentSubItem = "BM"			// BM = Bill of Lading (for freight)
				or msgHelper.currentSubItem = "HWB"				// HWB = House Waybill (for air freight)
				then
					msgHelper.setNextSubItem();
					billOfLading := msgHelper.currentSubItem.trimBlanks();
					ediTI.setBillOfLading(billOfLading);
					generatedContainerNo := generatedContainerNo + 1;
					ediTI.fullOrMT := "B";
					
// cnwdad1 02/08/2010 - CCMS 1816 (PAR #25523).
					isExistingFound	:=	false;
					
					if ediTI.billOfLading &lt;&gt; null and ediTI.cargoType &lt;&gt; null then
						foreach existingTI in ediData.allEDITrackedItems do
							if existingTI.CM_EDICustomStopTI.billOfLading = ediTI.billOfLading
							and existingTI.cargoType = TI_CargoType_Car
							and existingTI &lt;&gt; ediTI
							then
								// Merge the current container with the existing one, then delete the current container.
								isExistingFound	:=	true;
								packCount	:=	existingTI.CM_EDICustomStopTI.packCount;
								existingTI.CM_EDICustomStopTI.setPackCount(packCount + ediTI.packCount);
								// 09 Dec 2013 cnwah9 par 31825
								if isEQD = false then
									delete ediTI;		//03 Dec 2013	NDL	Par 31825 commented out delete fro CPts file format with multiple cars in 1 container.
								endif;
								break;
							endif;
						endforeach;
						
						if isExistingFound then
							continue;
						endif;
					endif;
					
				elseif msgHelper.currentSubItem = "SN" then		// SN = Seal Number
					msgHelper.setNextSubItem();
					ediTI.addCustomsSeal(msgHelper.currentSubItem);
				endif;
				
				int := int + 1;
			endif;
			
//TDT
		elseif msgHelper.currentTag = self.TDT then
			untCount := untCount + 1;
			msgHelper.setNextField;
			if msgHelper.currentField = "20" then
				if group = 0 then
					group := 0;
					
					// Note: We might not use all of the returned strings but this is a standard method for TDT+20.
					self.getVoyageDetailsFromTDT(	msgHelper,
													voyageCode,
													operatorVoyageCode,
													operatorVoyage,			// cnwrl1 26/07/2010 PAR 25093
													vesselName,
													lloydsNumber,
													callSign);
					
					// cnwrl1 26/07/2010 PAR 25093
					// Because some of Nelson's clients (ANL and COS) in particular do not send
					// through the mandatory UNB record the operator is not getting set up.
					// To cater for this we will use the first valid TDT+20 operator
					// if and only if the operator is not already set up.
					if operatorSender = null then
						operatorSender		:= operatorVoyage;
						operatorSenderCode	:= operatorVoyageCode;
					endif;

					vesselCode := app.myRoot.getXlationSystemCode(vesselName, XLATION_TYPE_VESSEL, foundMatch);	//par 31259 March 2013, par 26022 cnwrs1 19 Oct 2010
					vessel := app.myRoot.allVessels[vesselCode];
					if vessel &lt;&gt; null then
						vesselName := vessel.name;
					endif;
				endif;
			endif;

		elseif msgHelper.currentTag = self.UNB then
			
			// cnwrl1 22/07/2010 PAR 25093 -
			// get The translated Sender Operator and Code.
			self.getUNB_ElementData(msgHelper,
									operatorSenderCode,
										operatorSender, rawSenderCode, recipientCode, creationTS, sequence);

			// Now continue and get the date and time
			msgHelper.setNextField;
			msgHelper.setNextField;
			
			tmpStr := msgHelper.currentSubItem;
			
			if tmpStr.length &gt; 5
			and tmpStr.isInteger then
				msgDate.setDate(msgHelper.currentSubItem[5:2].Integer, msgHelper.currentSubItem[3:2].Integer, msgHelper.currentSubItem[1:2].Integer);		
			
				msgHelper.setNextSubItem;
				
				tmpStr := msgHelper.currentSubItem;
				if tmpStr.length &gt; 3
				and tmpStr.isInteger then
					msgTime.setTime(msgHelper.currentSubItem[1:2].Integer, msgHelper.currentSubItem[3:2].Integer, 0,0);		
				endif;
			endif;
//UNH
		elseif msgHelper.currentTag = "UNH" then
			msgHelper.setNextField;
			msgRef := msgHelper.currentField.trimBlanks;
			msgHelper.setNextField;
			fileType := msgHelper.currentSubItem;
			msgHelper.setNextSubItem;
			msgHelper.setNextSubItem;
			version := msgHelper.currentSubItem;
			msgHelper.setNextField;
			clientRef := msgHelper.currentField.trimBlanks;
			untCount := 1;
			ediTI := null;
			ableToClear := false;
			responseStatus := Customs_Deliver_Null;
			if _ediFile.ediData.status &lt;&gt; CM_EDIFile.EDI_STATUS_OUTOFSEQUENCE and
			   not self.processSenderRecipientSeq(rawSenderCode, recipientCode, fileType, version, _ediFile.ediData.fileName, creationTS, sequence, _ediFile.ediData, passport.myTerminal) then
				ediData.status := CM_EDIFile.EDI_STATUS_OUTOFSEQUENCE;
			endif;
//UNT
		elseif msgHelper.currentTag = "UNT" then
			untCount := untCount + 1;
			group := 0;
			msgHelper.setNextField;
			if ediTI &lt;&gt; null then
				ediTI.setFTXdata(mafActions, quarantineInstructions);
			endif;
			ediTI := null;
			ableToClear := false;
			responseStatus := Customs_Deliver_Null;
//UNZ
		else
			untCount := untCount + 1;
		endif;
	endforeach;
	_ediFile.causeEvent(passport.myTerminal.getTerminalEvent(Event_CusResEDITI_Create), false, ediData);
epilog
	delete theLines;
	delete msgHelper;
end;
</source>
        <access>protected</access>
        <Parameter name="_ediFile" type="CM_EDIFile" usage="input"/>
    </JadeMethod>
</Class>
