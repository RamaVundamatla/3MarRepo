    <JadeMethod name="delete" id="6a55d8e1-9fe6-47bb-a516-b935c7d59632">
        <updating/>
        <source>delete() updating;
/*
Purpose:			If this is the last Block for its Yard Allocation in a particular Terminal Area,
					remove the link between Yard Allocation and Terminal Area (many-to-many set link)
Parameters:			

Return Value:		

Date		Who		Reason
15/10/2009	cnwdap1	PAR #21350 Initial creation
*/
vars
	block	: CM_YABlock;
	ya		: CM_YardAllocation;
	found	: Boolean;

begin
	if self.isTransient then
		return;
	endif;
	
	// check to see if any other blocks in my yard allocation have the same terminal area as me
	// ignore invalid objects, as if we're deleting a yard allocation, it automatically deletes 
	// its blocks, adn some of the entries in allYABlocksIn may no longer be there
	ya := self.myYardAllocationIn;
	
	if ya = null then
		return;
	endif;
	
	foreach block in ya.allYABlocksIn where block &lt;&gt; self and app.isValidObject(block) do
		if block.myTerminalArea = self.myTerminalArea then
			found := true;
			break;
		endif;
	endforeach;
	
	// if no blocks in my yard allocation have the same terminal area, remove my yard allocation from 
	// the terminal area's set of yard allocations
	if not found and ya.allTerminalAreas.includes(self.myTerminalArea) then
		ya.allTerminalAreas.remove(self.myTerminalArea);
	endif;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getAuditDisplayForYA" id="b536642e-1035-427e-a0dc-9885d8525e16">
        <source>getAuditDisplayForYA() : String;

/*

Purpose:		Formats a display for inclusion in the audit of a Yard Allocation.

Parameters:			

Return Value:	


Date			Who		Reason
28 August 2008	consw1	Initial creation

*/

vars

begin
	return 		"Status: " &amp; self.getStatusDisplay() 
			&amp;	", Minimum height: " &amp; self.getMinHeight.String
			&amp;	", Maximum height: " &amp; self.getMaxHeight.String;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayDetails" id="d9421541-51f4-4135-aa48-15b7e111998f">
        <source>getDisplayDetails(_short: Boolean): String;
//----------------------------------------------------------------
//	Created:	09 June 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin
	if _short then
		return self.myTerminalArea.id &amp; " " &amp; self.getLocationsString; 
	else
		return self.getYAListDisplay(true);
	endif;
	
end;</source>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="1d48394d-49bc-4e4f-9110-72583430e2dc">
        <source>getDisplayStringForAttribute(_attrName :String; _short:Boolean) :String;
vars
	display: String;
begin
	if _attrName = ETRow_Code then
		return self.getYAMDisplay(false) &amp; " " &amp; self.getYAMLocationsHeightString();
	elseif _attrName = ETRow_Stacking then
		return self.myDeckingOptions.getStringForPicture;
	elseif _attrName = ETRow_HideShow then
		return null;
	elseif _attrName = ETRow_PriorityValue then
		return null;
	elseif _attrName = ETRow_DeckingSequence then
		return null;
	elseif self.myLocationStatistics &lt;&gt; null then
		display := self.myLocationStatistics.getDisplayStringForAttribute(_attrName, _short);
		if display &lt;&gt; null then
			if display.Integer = 0 then
				return "";
			endif;

			return display;
		endif;
	endif;
end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getFifo" id="72b1cc8a-d399-481e-920a-0e18f2387bb3">
        <source>getFifo(_isIn : Boolean) : Date;
/*
// -------------------------------------------
// Created 05 April 2005 by cnwdvb1
// -------------------------------------------
21 Jun 25	jlier1 JIRA-13860 
*/
vars
	fDate,
	fCompareDate	: Date;
	lc				: CM_LocationsController;
	sortedByDate 	: CM_TIByReceiveDT;

begin

	fCompareDate := null;

	create sortedByDate transient;
	
	foreach lc in self.allYardControllers do
		fDate := lc.getFIFOTimeStampYA(_isIn, sortedByDate).date;
		if fDate = null then
			continue;
		endif;
		if _isIn then	
			if fCompareDate = null or fDate &gt; fCompareDate then
				fCompareDate := fDate;
			endif;
		else
			if fCompareDate = null or fDate &lt; fCompareDate then
				fCompareDate := fDate;
			endif;
		endif;
	endforeach;
	
	return fCompareDate;
epilog
	delete sortedByDate;	
end;</source>
        <Parameter name="_isIn" type="Boolean"/>
        <ReturnType type="Date"/>
    </JadeMethod>
