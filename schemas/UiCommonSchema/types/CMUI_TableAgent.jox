    <JadeMethod name="addBlankRow" id="e552c4cb-d596-4689-b38a-f9f8725cd036">
        <source>addBlankRow(row, column : Integer io) protected;
// ---------------------------------------------------------------------------
// Created:      25 June 2003 by cnwsgp1
// ---------------------------------------------------------------------------

begin
	self.mergeRemainingColumns(row, column);
	row := self.myTable.addItem(null);
	column := 1;
end;</source>
        <access>protected</access>
        <Parameter name="row" type="Integer" usage="io"/>
        <Parameter name="column" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="addBlockToTable" id="4b52b02f-7062-4a04-8e88-bf06608d658e">
        <source>addBlockToTable(block : CM_DataContainerBlock; row, column : Integer io) protected;
// ---------------------------------------------------------------------------
// Created:      24 June 2003 by cnwsgp1
// ---------------------------------------------------------------------------
vars
	item : CM_DataContainerItem;

begin
	if (column &lt; 1) then
	   // no row yet
		self.addBlankRow(row, column);
		
	elseif column &gt; 1 then
		if ((column - 1) + self.getNumberOfColsForBlock(block)) &gt; maxColumns then
			// block won't fit on this row
			self.addBlankRow(row, column);

		elseif block.hasAllHeaders or block.hasAllLabelHeaders or block.hasAllData then// or block.hasAllIcons then
			// header, data and icon only columns are displayed on their own line
			self.addBlankRow(row, column);
		endif;
	endif;

	foreach item in block.allItems do
		self.addItemToTable(item, row, column);
	endforeach;

	if block.hasAllLabelHeaders or block.hasAllData then //or block.hasAllIcons then
		// header and data only columns are displayed on their own line
		self.mergeRemainingColumns(row, column);
	endif;	
end;</source>
        <access>protected</access>
        <Parameter name="block" type="CM_DataContainerBlock"/>
        <Parameter name="row" type="Integer" usage="io"/>
        <Parameter name="column" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="addDataToTable" id="21326d53-2a23-4d59-89e5-f0a0dcabc381">
        <updating/>
        <source>addDataToTable(_data : CM_DataContainer;_table : CM_BaseTable input; _reset : Boolean;
		_maxColumns : Integer; _useBigFont : Boolean;
		_colsForData, _colsForHeader, _colsForIcon, _colsForLabel : Integer; displayMode : Integer; _exportIfTooLarge : Boolean) updating;
// ---------------------------------------------------------------------------
// Created:      24 June 2003 by cnwsgp1
// ---------------------------------------------------------------------------
//23/05/2018 	Jlgns1	Bug 38662: STWO - Transaction resync for 2291 transactions gives error 14051

vars
	row : Integer;
	column : Integer;
	block : CM_DataContainerBlock;
	idx, numrows : Integer;
	count 		: Integer;
	captionText : String;
begin
		
	if _exportIfTooLarge then																					//Bug 38662
		foreach block in  _data.allBlocks do																	//Bug 38662
			count := count + (block.allItems.size / 2).Integer;													//Bug 38662
		endforeach;																								//Bug 38662
		if count &gt; JadeTableRowLimit then																		//Bug 38662
			if _table.parent &lt;&gt; null and _table.parent.isKindOf(CMUI_SystemAlertsDetails) then					//Bug 38662
				captionText := _table.parent.CMUI_SystemAlertsDetails.caption;									//Bug 38662
				 _table.parent.CMUI_SystemAlertsDetails.unloadForm;												//Bug 38662
			endif;																								//Bug 38662
			if  app.msgBox(app.getErrorString1(MaxTablesRowsExport, JadeTableRowLimit.String)					//Bug 38662
			, app.getErrorString(Warning), MsgBox_Yes_No + MsgBox_Question_Mark_Icon ) = MsgBox_Return_Yes then	//Bug 38662
				//do file browser																				//Bug 38662
				exportDataToCSV(_data, captionText);															//Bug 38662
			endif;																								//Bug 38662
			return;																								//Bug 38662
		endif;																									//Bug 38662
	endif;																										//Bug 38662
			
	
	self.setForCreate(_data, _table, _maxColumns, _useBigFont,
			_colsForData, _colsForHeader, _colsForIcon, _colsForLabel);

	if _reset then
		self.myTable.rows := 0;
	endif;
	self.formatTable();

	foreach block in self.myDataContainer.allBlocks do
		self.addBlockToTable(block, row, column);
	endforeach;	
	
	
	self.mergeRemainingColumns(row, column);
	
	// TFS 2682
	if displayMode = CMUI_SystemAlertsDetails.DisplayMode_TransactionLog then
		numrows := _table.rows - _table.fixedRows;
		
		if numrows	 &gt; 0 then
			foreach idx in _table.fixedRows + 1 to numrows discreteLock do
				if _table.accessCell(idx,2).text.toUpper().pos("VOID",1) &gt; 0 then
					_table.accessedCell.foreColor := Red;
				elseif _table.accessCell(idx,2).text.toUpper().pos("DEFAULT",1) &lt; 1 then
					_table.accessedCell.foreColor := Green;
				endif;
				
			endforeach;
		endif;
	endif;
end;</source>
        <Parameter name="_data" type="CM_DataContainer"/>
        <Parameter name="_table" type="CM_BaseTable" usage="input"/>
        <Parameter name="_reset" type="Boolean"/>
        <Parameter name="_maxColumns" type="Integer"/>
        <Parameter name="_useBigFont" type="Boolean"/>
        <Parameter name="_colsForData" type="Integer"/>
        <Parameter name="_colsForHeader" type="Integer"/>
        <Parameter name="_colsForIcon" type="Integer"/>
        <Parameter name="_colsForLabel" type="Integer"/>
        <Parameter name="displayMode" type="Integer"/>
        <Parameter name="_exportIfTooLarge" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="addItemToTable" id="6c97accb-2cd5-4204-a955-011d1c7352f3">
        <source>addItemToTable(item : CM_DataContainerItem; row, column : Integer io) protected;
// ---------------------------------------------------------------------------
// Created:      24 June 2003 by cnwsgp1
// ---------------------------------------------------------------------------
//23/05/2018 	Jlgns1	Bug 38662: STWO - Transaction resync for 2291 transactions gives error 14051
vars
	cell : JadeTableCell;
	colsToMerge : Integer;

begin
	colsToMerge := self.getNumberOfColsToMerge(item);

	if item.isMoreInfo then
		// displayed on new line
		self.addBlankRow(row, column);

	else
		if column &gt; 1 and (((column - 1) + (colsToMerge)) &gt; self.maxColumns) then
			// won't fit on the current line
			self.addBlankRow(row, column);
		endif;
	endif;
	
	//limit has been reached - don't add new stuff	
	if row = 0 then			//Bug 38662
		return;				//Bug 38662
	endif;					//Bug 38662
	
	
	// add the item details
	cell := self.myTable.accessCell(row, column);
	if item.isIcon then
		cell.text := item.CM_DataContainerIcon.character;
	else
		cell.text := item.text;
	endif;
	cell.itemObject := item.myObject;
	
	self.mergeColumns(row, colsToMerge, column);
	
	// format the cell
	if item.isHeader then
		self.formatHeaderCell(cell);
		
	elseif item.isLabel or item.isIconLabel then
		self.formatLabelCell(cell);
	elseif item.isWarning then// or item.isIconLabel then
		self.formatWarningCell(cell);
		
	elseif item.isData then
		if item.myBlock.hasAllData then
			// must be a data column with a column header
			self.formatColumnDataCell(cell);
		else
			self.formatDataCell(cell);
		endif;	
	
	elseif item.isMoreInfo then
		self.formatMoreInfoCell(cell);
		
	elseif item.isIcon then
		self.formatIconCell(cell, item.CM_DataContainerIcon.font, item.CM_DataContainerIcon.colour);
		
	elseif item.isLabelHeader then
		self.formatLabelHeaderCell(cell);
				
	endif;

	column := column + 1;

	if item.isMoreInfo then
		// moreInfo columns are displayed on their own line
		self.mergeRemainingColumns(row, column);
	endif;
	// removed, add 	self.myTable.autoSize := Table.AutoSize_Row &amp; self.myTable.wordWrap := true in self.formatTable()

	//	self.myTable.optimiseHeightForRow(cell.inputType, row, cell.text);

	

	
	
end;</source>
        <access>protected</access>
        <Parameter name="item" type="CM_DataContainerItem"/>
        <Parameter name="row" type="Integer" usage="io"/>
        <Parameter name="column" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="exportDataToCSV" id="5e682ea5-d3e0-4159-965d-0555e3a0cbda">
        <updating/>
        <source>exportDataToCSV(_dataContainer : CM_DataContainer; _captionText : String ) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21 May 2018	jlgns1	Initial creation
23/05/2018 	Jlgns1	Bug 38662: STWO - Transaction resync for 2291 transactions gives error 14051
*/
vars

	
	block 			: CM_DataContainerBlock;
	item 			: CM_DataContainerItem;
	lineName	 	: String;
	lineDetail	 	: String;
	fileSaveDialogue: CMDFileSave;
	outputFile 		: File;	
	lineNo 			: Integer;
	itemNo 			: Integer;
	
begin

	create outputFile transient;		
	create fileSaveDialogue transient;
	
	//setup Dialogue
	fileSaveDialogue.allowMultiSelect := false;
	fileSaveDialogue.dialogTitle 	:=  app.getErrorString(Save) &amp; Space &amp; _captionText;	
	fileSaveDialogue.initDir		:= "c:\temp";
	fileSaveDialogue.filter 		:= "Comma Separated Value Files (*.csv)|*.csv|Text Files (*.txt)|*.txt|All Files|*.*";
	fileSaveDialogue.defaultExt		:= "csv";
	
	//show Dialogue
	if fileSaveDialogue.open &lt;&gt; 0 then
		return;
	endif;
	
	app.mousePointer := Window.MousePointer_HourGlass;
	
	//setup File
	outputFile.usePresentationFileSystem := true;		
	outputFile.mode := File.Mode_Output; 
	outputFile.fileName := fileSaveDialogue.fileName;
	if (not outputFile.tryOpen) then
		CnEcBaseSchemaException.raise_(CNEC_X_13999, "Cannot open '" &amp; outputFile.fileName &amp; "'");
		return;
	endif;
	outputFile.mode := File.Mode_Output; 
	
	//export the data
	foreach block in  _dataContainer.allBlocks do
		foreach item in block.allItems do
			itemNo := itemNo + 1;
			if  itemNo.isOdd then
				lineName := item.text.cnFormatForCSVFile(true);
			else
				lineDetail := item.text.cnFormatForCSVFile(false);
				outputFile.writeLine(lineName &amp; lineDetail);
				lineDetail := "";
				lineName := "";
				lineNo := lineNo + 1;
			endif;
		endforeach;	
	endforeach;
	outputFile.close();
	
	app.mousePointer := Window.MousePointer_Default;
	
	app.msgBox("Exported " &amp; lineNo.String &amp; " Lines to " &amp; outputFile.fileName ,"EXPORT", MsgBox_OK_Only);  
	
epilog
	app.mousePointer := Window.MousePointer_Default;
	delete fileSaveDialogue;
	delete outputFile;
	
end;</source>
        <Parameter name="_dataContainer" type="CM_DataContainer"/>
        <Parameter name="_captionText" type="String"/>
    </JadeMethod>
