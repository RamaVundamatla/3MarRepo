    <JadeMethod name="doUpdateBlockGroup" id="280495fe-33f9-4533-8762-46b2331645c4">
        <updating/>
        <source>doUpdateBlockGroup(_isAdd:Boolean; _isDelete:Boolean; _isUpdate:Boolean) updating;
// --------------------------------------------------------------------------------
// Created:		14 May 2006 by cnwdad1
//
// Purpose:		Updates a Block Group location.
//
// Parameters:	_isAdd - True if adding a Block Group.
//				_isDelete - True if deleting a Block Group.
//				_isUpdate - True if updating a Block Group (description only).
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	blockObj		: CM_YABlock;
	groupObj		: CM_YABlockGroup;
	listPointer		: Integer;
	parentPointer	: Integer;
	blockName		: String;
	isUpdated		: Boolean;
	
begin
	isUpdated	:=	false;
	
	// Add a new Block Group, with the (next) default name.
	
	if _isAdd then
		create groupObj transient;
		groupObj.setDescription(self.myProxyYA.getNextBlockGroupDescription());
		self.allBlockGroupsIn.add(groupObj);
		self.allBlockGroupsOut.add(groupObj);
		self.myProxyYA.allYABlockGroupsIn.add(groupObj);
		self.myProxyYA.allYABlockGroupsOut.add(groupObj);
		isUpdated	:=	true;
		
		return;
	endif;
	
	// We're not adding a new Block Group, so find that one that is currently selected.
	
	if not self.myLstLocations.getBlockOrGroup(blockObj, groupObj) then
		return;
	endif;
	
	if blockObj &lt;&gt; null then
		listPointer		:=	self.myLstLocations.listIndex;
		parentPointer	:=	self.myLstLocations.cnEcFindParent(listPointer);
		
		if parentPointer = CNEC_NULL_INDEX then
			return;
		endif;
		
		groupObj	:=	self.myLstLocations.itemObject[parentPointer].CM_YABlockGroup;
	endif;
	
	if groupObj = null then
		return;
	endif;
	
	// Delete the selected Block Group.
	
	if _isDelete then
		if global.cnEcConfirmDelete(groupObj.description) then
			if self.allBlockGroupsIn.includes(groupObj) then
				self.doMoveBlocksToNewGroup(groupObj, true);
				self.allBlockGroupsIn.remove(groupObj);
			endif;
			
			if self.allBlockGroupsOut.includes(groupObj) then
				self.doMoveBlocksToNewGroup(groupObj, false);
				self.allBlockGroupsOut.remove(groupObj);
			endif;
			
			if self.allBlockGroupsIn.isEmpty()
			or self.allBlockGroupsOut.isEmpty()
			then
				self.doClearLocations(null);
			endif;
			
			isUpdated	:=	true;
		endif;
		
	// Update the selected Block Group.
	
	elseif _isUpdate then
		blockName	:=	self.cnEcGetUserInput("Edit Group Block", "Enter the name of the Group Block:", groupObj.description);
		
		if blockName &lt;&gt; null and blockName &lt;&gt; groupObj.description then
			if self.allBlockGroupsIn.isNameUsed(blockName, groupObj) then
				app.raiseCMException1(ERR_INVALID_LOCN_YA, "Please enter the location to add.", null, null);
			else
				groupObj.setDescription(blockName);
				isUpdated	:=	true;
			endif;
		endif;
	else
		return;
	endif;
epilog
	if isUpdated then
		self.populateLocationsListbox(self.myOptSortIn.value);
		self.enableDeckingOptionsButtons(self.myLstLocations.listIndex &lt;&gt; CNEC_NULL_INDEX and not(CM_YABlockBlock.hasInstance(self.myLstLocations.listObject)));
	endif;
end;</source>
        <Parameter name="_isAdd" type="Boolean"/>
        <Parameter name="_isDelete" type="Boolean"/>
        <Parameter name="_isUpdate" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="enableDeckingOptionsButtons" id="7d20c649-5248-4a32-a5de-d614d1a015fa">
        <source>enableDeckingOptionsButtons(pIsEnabled:Boolean);
// --------------------------------------------------------------------------------
// Created:		27 April 2005 by cnwdad1
//
// Purpose:		Enables or disables the YA Block Decking Options buttons.
//
// Parameters:	pIsEnabled - True if the buttons should be enabled.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
