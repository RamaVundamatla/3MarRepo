    <JadeMethod name="translateForm" id="27c4dba9-3471-4794-ae42-309a5c66ff5a">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 03 December 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
//	self.translateCaption(Xlat_0017730, locale);
	btnEditCTA.translateBubbleHelp(Xlat_0019386, locale);
	btnEditCTA.translateCaption(Xlat_0019387, locale);
	grpAreasCovered1.translateCaption(Xlat_0004579, locale);
	grpAreasCovered2.translateCaption(Xlat_0004578, locale);
	grpFrmLocations.translateCaption(Xlat_0008824, locale);
	grpMachineTypeGr.translateCaption(Xlat_0004972, locale);
	grpToLocations.translateCaption(Xlat_0008825, locale);
	optGetNext1.translateCaption(Xlat_0004580, locale);
	optGetNext2.translateCaption(Xlat_0004581, locale);
	optGetSame1.translateCaption(Xlat_0004582, locale);
	optGetSame2.translateCaption(Xlat_0004583, locale);
	shtFromAreas.translateCaption(Xlat_0010423, locale);
	shtMachineTypes.translateCaption(Xlat_0010424, locale);
	shtQueueData.translateCaption(Xlat_0010425, locale);
	shtRTGBays.translateCaption(Xlat_0010426, locale);
	shtToAreas.translateCaption(Xlat_0010427, locale);
	tblMain.translateBubbleHelp(Xlat_0004584, locale);
end;</source>
    </JadeMethod>
</GUIClass>
