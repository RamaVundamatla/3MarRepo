    <JadeMethod name="setupForm" id="eb6c5311-48ba-4e9d-bffa-22a09bce9933">
        <updating/>
        <source>setupForm() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 July 2013	cnwndl1	Initial creation	Par 31965
22 Jan  2005    cnwma1  PAR #35519 1035 Error String Too Long
11 Feb	2016	cnwdap1	PAR #36766 Bulk Graphical Representation - extra columns in table
*/

vars

	userWindow	: CM_UserWindow;
	idx : Integer;
	theCmb : CMUI_ComboBox;

begin

	self.minimumWidth := 550;
	self.minimumHeight := 400;
	self.width	:= 520;
	self.height	:= 400;

	self.grpDetail.borderStyle := 0;
	self.showToolbar := false;
	self.txtLocationName.maxLength :=30; //22/01/2015 cnwma1 PAR #35519
	
	theCmb := self.cmbOnShipCrane;
	theCmb.clear;
	theCmb.sorted := false;
		
	idx := theCmb.addItem(BayOnShipCraneStr_None);
	theCmb.itemData[idx] := BayOnShipCrane_None;
	idx := theCmb.addItem(BayOnShipCraneStr_OnP);
	theCmb.itemData[idx] := BayOnShipCrane_OnP;
	idx := theCmb.addItem(BayOnShipCraneStr_OnC);
	theCmb.itemData[idx] := BayOnShipCrane_OnC;
	idx := theCmb.addItem(BayOnShipCraneStr_OnS);
	theCmb.itemData[idx] := BayOnShipCrane_OnS;
	idx := theCmb.addItem(BayOnShipCraneStr_Before);
	theCmb.itemData[idx] := BayOnShipCrane_Before;
	idx := theCmb.addItem(BayOnShipCraneStr_After);
	theCmb.itemData[idx] := BayOnShipCrane_After;

	inheritMethod();
	
	self.populateData();
	
	self.centreOverParent(100);
	
	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.btnAdd.enabled:= false;
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="tblItems_click" id="9812ba4f-23f7-46d0-b436-10cb16627852">
