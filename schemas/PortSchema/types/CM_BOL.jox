    <JadeMethod name="setMyLogControllerOID" id="51aa5e27-a44c-49d4-b31d-3997b420bd39">
        <updating/>
        <source>setMyLogControllerOID( _locationsController : CM_LocationsController) updating;

/*

Purpose:	cnwrd1 par 35101 ccms 1134 hold first log controller OID for logs

Parameters:			

Return Value:		


Date		Who		Reason
20 October 2014	cnwrd1	Initial creation

*/

vars

begin

	if _locationsController = null then 
		return;
	endif;
	
	if not _locationsController.isKindOf(CM_LogController) then
		return;
	endif;
	
	if self.myLogControllerOID &lt;&gt; null then //only set it once
		return;
	endif;
	
	self.myLogControllerOID := _locationsController.getOidAsString();

epilog

end;</source>
        <Parameter name="_locationsController" type="CM_LocationsController"/>
    </JadeMethod>
    <JadeMethod name="setNetWeightFromCargo" id="4eafb99c-d4ef-4a0f-895c-8e21cfaf2ff5">
        <updating/>
        <source>setNetWeightFromCargo() updating;
/*

Date		Who		Reason
27 April 2017	cnwer1	Initial creation TFS 4157

*/

vars
	ti : CM_TrackedItem;
	totalWeight : Decimal[16,4];
begin
	
	foreach ti in self.allTrackedItems discreteLock do
		totalWeight:= totalWeight + ti.totalWeight;
	endforeach;
	
	self.weightNet:=totalWeight;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setNumber" id="b585d7ed-5d94-4c45-a1bf-9545fe11d177">
        <updating/>
        <source>setNumber(_value : String) updating;
/*

Purpose:			Set the number property on the receiver, and perform "manual" dictionary maintenance
					on the related key path dictionaries of the receiver is persistent.
					Created as a workaround for JADE fault #60667

Parameters:			New number value

Return Value:		None

Date		Who		Reason
29 Nov 2013	cnwkpd1	PAR #33107 - Docket number changes corrupting dictionary keys

*/

vars
	termsByBT		: ObjectByObjectDict;
	bolTerms		: ObjectSet;
	bolTerm			: CM_BOLTerminal;
	term			: CM_Terminal;
	iter			: Iterator;
	
begin
	if self.number &lt;&gt; _value then
	
		// For a persistent receiver, need to save off all the myTerminal references of the related CM_BOLTerminal
		// objects and clear them, to remove them from the dictionaries that are being corrupted
		if not self.isTransient then
		
			create termsByBT transient;
			create bolTerms transient;
			
			self.allBOLTerminals.copy(bolTerms);
			iter := bolTerms.createIterator();
			
			while iter.next(bolTerm) do
				if bolTerm.myTerminal &lt;&gt; null then
					app.writeLog(method.qualifiedName &amp; " " &amp; bolTerm.String &amp; " setting myTerminal from " &amp;
								   bolTerm.myTerminal.String &amp; " to null", LogDEBUG);	//25 Nov 2019	NDL	TFS 47053
					// Save off original value
					termsByBT.putAtKey(bolTerm, bolTerm.myTerminal);
					// And clear it
					bolTerm.setPropertyValue(CM_BOLTerminal::myTerminal.name, null);
				endif;
			endwhile;
		
		endif;
	
		// Change the property value
		self.number := _value;
		
		// And now restore the myTerminal references to their previous values
		if not self.isTransient then
		
			iter.reset();
			while iter.next(bolTerm) do
				term := termsByBT[bolTerm].CM_Terminal;
				
				if term &lt;&gt; null then
					app.writeLog(method.qualifiedName &amp; " " &amp; bolTerm.String &amp; " restoring myTerminal to " &amp; term.String, LogDEBUG);	//25 Nov 2019	NDL	TFS 47053
					bolTerm.setPropertyValue(CM_BOLTerminal::myTerminal.name, term);
				endif;
			endwhile;
		endif;
		
	endif;

epilog
	delete termsByBT;
	delete bolTerms;
	delete iter;
	
end;</source>
        <Parameter name="_value" type="String"/>
    </JadeMethod>
    <JadeMethod name="setOrigLocation" id="9be522cb-6273-4cc7-921b-cf73d423c9c0">
        <updating/>
        <source>setOrigLocation() updating;
//--------------------------------------------------------------
//Created: 26 June 2002 By: cnwgd1
//--------------------------------------------------------------
vars

begin

end;</source>
    </JadeMethod>
    <JadeMethod name="setProductForProxy" id="668eb273-ba1f-4b94-9a67-82222f23a99c">
        <updating/>
        <source>setProductForProxy(_cargoType : Integer; _prodCode : String; _passport : CM_Passport input; _guiObject : Object) updating;
// ---------------------------------------------------------------------------
// Created:     03 June 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	pxyProduct,
	realProduct	: CM_Product;
	bolExtLog	: CM_BOLExtLog;

begin

	self.raiseExceptionIfNotTransient(method);
	
	if _passport.hasErrors then
		return;
	endif;

	realProduct := self.myOperator.allProducts[_cargoType, _prodCode];
	if realProduct = null then
		if self.bolType = BOLType_Log and
		   self.myExtension.isKindOf(CM_BOLExtLog) then
		   
		   	bolExtLog := self.myExtension.CM_BOLExtLog;
		   	
			// create a proxy.  This will get converted to persistent in the setForCreate method
	
			create pxyProduct as CM_ProductLog transient;
			pxyProduct.CM_ProductLog.setProxyLogProductFromCodes(_prodCode, self.myOperator, 
								bolExtLog.logSpeciesCode,
								bolExtLog.logGradeCode,
								bolExtLog.logTypeCode,
								bolExtLog.logTreatmentCode,
								bolExtLog.lengthCode,
								_passport, _guiObject);
			self.myProduct := pxyProduct;
		else
			self.myProduct := null;
		endif;
	else
		self.myProduct := realProduct;
	endif;

end;</source>
        <Parameter name="_cargoType" type="Integer"/>
        <Parameter name="_prodCode" type="String"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <Parameter name="_guiObject" type="Object"/>
    </JadeMethod>
    <JadeMethod name="setProductForRelease715h" id="42684059-c5c7-41c8-9d2f-bd37857fef6c">
        <updating/>
        <source>setProductForRelease715h(_passport : CM_Passport input) updating;

vars
	tmpProdCode	: String;
	realProduct,
	pxyProduct	: CM_ProductLog;
	bolExtLog	: CM_BOLExtLog;
begin

	if self.myExtension = null or self.bolType &lt;&gt; BOLType_Log then
		return;
	endif;
	
	tmpProdCode := self.myExtension.getProductCode();
	realProduct := self.myOperator.allProducts[TI_CargoType_Log, tmpProdCode].CM_ProductLog;

	if realProduct = null then
		if self.bolType = BOLType_Log and
		   self.myExtension.isKindOf(CM_BOLExtLog) then
		   
		   	bolExtLog := self.myExtension.CM_BOLExtLog;
		   	
			// create a proxy.  This will get converted to persistent in the setForCreate method
	
			create pxyProduct as CM_ProductLog transient;
			pxyProduct.CM_ProductLog.setProxyLogProductFromCodes(tmpProdCode, self.myOperator, 
								bolExtLog.logSpeciesCode,
								bolExtLog.logGradeCode,
								bolExtLog.logTypeCode,
								bolExtLog.logTreatmentCode,
								bolExtLog.lengthCode,
								_passport, null);
			app.myUtilityCA.utlCreateProduct(pxyProduct, self.myProduct, _passport);
			delete pxyProduct;		
		else
			self.myProduct := null;
		endif;
	else
		self.myProduct := realProduct;
	endif;


epilog
	delete pxyProduct;		
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="c9078113-139f-4050-9a4d-3938bf2502db">
        <updating/>
        <source>setProxy(_bolNumber : String;
		_voyage : CM_Voyage;
		_operator : CM_Operator;
		_notifyParty : String;
		_numItems : Integer; 
		_bolType : Integer; 
		_terminal : CM_Terminal; 
		_subTerminal : CM_SubTerminal;
		_destination : String;
		_dischargePort : String;
		_loadPort : String;
		_directDelivery : Boolean;
		_serviceOrder : String;					// PAR #33019
		_poNbr : String;							// PAR #33019
		_outturnRemark	: String;		//13/07/2022 navgm20 Tfs 54095
		_generalLanding : Date // TFS 4272
		)updating;
//18 January 2010	cnwml2
// Changed On	By			Reason
// ---------- 	--------	------------------------------------------------------------
// 27/11/2013	cnwdap1		PAR #33019 CCMS DPH 2285 New BOL Fields
// 29 Nov 2013	cnwkpd1		PAR #33107 - Docket number changes corrupting dictionary keys
// 13/07/2022   navgm20     ChangeRequest 54095: EUP - Outturn Remarks on BOL

vars

begin
//	self.number := _bolNumber;
	self.setNumber(_bolNumber);					// PAR #33107
	self.myOperator := _operator;
	self.notifyParty := _notifyParty;
	
	self.numItems := _numItems;
	self.bolType := _bolType;
	self.myTerminal := _terminal;
	self.mySubTerminal := _subTerminal;
	
	self.destinationPort := _destination;
	self.dischargePort := _dischargePort;
	self.loadPortCode := _loadPort;
	
	self.setDirectDelivery( _directDelivery );	//29 Jan 2013	NDL	Par 31102
	
	self.clientRef1 := _serviceOrder;			// PAR #33019
	self.clientRef2 := _poNbr;					// PAR #33019
	
	self.generalLandingDate := _generalLanding;  // TFS 4272
	self.outturnRemarks		:= _outturnRemark;	//13/07/2022 navgm20 Tfs 54095
epilog

end;</source>
        <Parameter name="_bolNumber" type="String"/>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_notifyParty" type="String"/>
        <Parameter name="_numItems" type="Integer"/>
        <Parameter name="_bolType" type="Integer"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_subTerminal" type="CM_SubTerminal"/>
        <Parameter name="_destination" type="String"/>
        <Parameter name="_dischargePort" type="String"/>
        <Parameter name="_loadPort" type="String"/>
        <Parameter name="_directDelivery" type="Boolean"/>
        <Parameter name="_serviceOrder" type="String"/>
        <Parameter name="_poNbr" type="String"/>
        <Parameter name="_outturnRemark" type="String"/>
        <Parameter name="_generalLanding" type="Date"/>
    </JadeMethod>
    <JadeMethod name="setProxyDocketReconcile" id="ac650362-f6cb-43c1-b11c-271a01aaaf45">
        <updating/>
        <source>setProxyDocketReconcile(_docketNumber : String; _numItems : Integer) updating;
//--------------------------------------------------------------
//Created: 25 October 2002 By: cnwgd1
//--------------------------------------------------------------
// 29 Nov 2013	cnwkpd1	PAR #33107 - Docket number changes corrupting dictionary keys

vars

begin
	exclusiveLock(self);
	
	if self.number &lt;&gt; _docketNumber then
//		self.number := _docketNumber;
		self.setNumber(_docketNumber);				// PAR #33107
	endif;
	
	self.numItems	:= _numItems;

end;</source>
        <Parameter name="_docketNumber" type="String"/>
        <Parameter name="_numItems" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setPxyFromCMIF_BOL" id="d68f2f4d-3a27-49c1-b0bb-6b8bd441338d">
        <updating/>
        <source>setPxyFromCMIF_BOL(_intFace : CMIF_BOL; _passport : CM_Passport input) updating;
//--------------------------------------------------------------
//Created: 17 June 2002 By: cnwgd1
//--------------------------------------------------------------
// 29 Nov 2013	cnwkpd1	PAR #33107 - Docket number changes corrupting dictionary keys

vars
	
begin

	self.raiseExceptionIfNotTransient(method);
	
	self.bolType 					:= _intFace.bolType;
	self.carrierCode				:= _intFace.carrierCode;
	self.consignor					:= _intFace.consignorCode;
	self.consignee					:= _intFace.consigneeCode;
	self.notifyParty				:= _intFace.notifyPartyCode;
	self.dateTime					:= app.serverTimestampAtTrxStart;
	self.destinationPort			:= _intFace.destinationPort;
	self.setDirectDelivery( _intFace.directDelivery );	//29 Jan 2013	NDL	Par 31102
	self.dischargePort				:= _intFace.dischargePort;
	self.handlingContractor1Code 	:= _intFace.handlingContractor1;
	self.handlingContractor2Code	:= _intFace.handlingContractor2;
	self.handlingSubContractor1Code	:= _intFace.handlingSubContractor1;
	self.isCharged					:= not _intFace.noCharge;
	self.loadPortCode				:= _intFace.loadPortCode;		

	self.myManifest					:= _intFace.myManifest;
	self.myPlannedLocation 			:= _intFace.myPlannedLocation;
	self.myTerminal					:= _intFace.myTerminal;
	
	self.numItems					:= _intFace.numItems;
//	self.number 					:= _intFace.bolNumber;
	self.setNumber(_intFace.bolNumber);							// PAR #33107
//	self.purchaseOrder				:= _intFace.purchaseOrder;		
	self.processOption				:= _intFace.processOption;	
	self.referenceDate				:= _intFace.referenceDate;
	self.remarks					:= _intFace.remarks;
	
	self.sourceLocation				:= _intFace.sourceLocation;
	self.sourceSubLocation			:= _intFace.sourceSubLocation;
	self.sourceSubSubLocation		:= _intFace.sourceSubSubLocation;
	self.transportMode				:= _intFace.transportMode;
	self.trailerNumber				:= _intFace.trailerNumber;
	self.truckNumber				:= _intFace.truckNumber;
	self.vehicle					:= _intFace.regNumber;

	self.weightGrossTonnes			:= _intFace.weightGrossTonnes;
	self.weightNetTonnes			:= _intFace.weightNetTonnes;
	self.weightTareTonnes			:= _intFace.weightTareTonnes;
	
	if app.isSubTerminalsOn(self.myTerminal) then		// cnwdad1 09/10/2009 - PAR #21118.
		self.setSubTerminal(_intFace.mySubTerminal);	// cnwdad1 17/04/2009 - CCMS 1735.
	endif;
	
	// NB: allTrackedItems is set on a re-implementation of this
	// method on the CM_BOLIn class.  For CM_BOLOut the allTrackedItems
	// is set using the setTIsForCreate() method instead.
	
	self.setMyExtension();
	
	if self.myExtension &lt;&gt; null then
		self.myExtension.setPxyFromCMIF_BOL(_intFace);
	endif;
	
	self.myOperator := _intFace.myOperator;
	if self.myOperator &lt;&gt; null then
		self.myOperatorTerminal	:= self.myOperator.getOperatorTerminal(self.myTerminal, (not self.isTransient));
	endif;

end;</source>
        <Parameter name="_intFace" type="CMIF_BOL"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
