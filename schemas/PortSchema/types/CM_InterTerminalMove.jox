    <JadeMethod name="getCompletedDTLocalTZ" id="86a33971-f1a7-44b2-9f35-3a0a40dd60bd">
        <source>getCompletedDTLocalTZ() :TimeStamp;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 May 2016	cnwns1	Initial creation
// 30 May 2016	cnwns1	TFS 488 - Multi Timezone Support
*/

vars

begin
	return self.systemToLocalTime(self.completedDT);
epilog

end;</source>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="138cb845-0bbd-476d-94e9-d0f80e82d2e7">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*
Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
17 February 2010	cnwndl1	Initial creation
10/03/2011	cnwmh5	PAR #27142 - Change to local variable rather than self for handleDeleteObject exception
*/
vars
	tmpISO	 : CM_ISOType;
	vehicleStr : String;
	invalidTI : Boolean;
	invalidSV : Boolean;
	sourceTI	: CM_TrackedItem;
begin
	
	on Exception do app.handleDeletedObject(exception, self.mySourceTI, invalidTI); 
	on Exception do app.handleDeletedObject(exception, self.mySourceVehicle, invalidSV); 


	if _attrName = ETRow_PickupTime then
		return self.systemToLocalTime(self.vehiclePickupDT).String;	// 5/5/16 cnwmp6 TFS 488 - Multi timezone support
	elseif _attrName = ETRow_SetdownTime then
		return self.systemToLocalTime(self.vehicleSetdownDT).String;	// 5/5/16 cnwmp6 TFS 488 - Multi timezone support
	elseif _attrName = ETRow_Vehicle then
		if self.mySourceVehicle &lt;&gt; null then
			vehicleStr := self.mySourceVehicle.regNumber ;
			if self.mySourceVehicle.state &lt;&gt; null then
				vehicleStr := vehicleStr &amp; ' (' &amp; self.mySourceVehicle.state &amp;  ')';
			endif;
		elseif self.myTargetVehicle &lt;&gt; null then
			vehicleStr := self.myTargetVehicle.regNumber ;
			if self.myTargetVehicle.state &lt;&gt; null then
				vehicleStr := vehicleStr &amp; ' (' &amp; self.myTargetVehicle.state &amp; ')';
			endif;
		else
			vehicleStr := self.vehicleID;
		endif;
		return vehicleStr;

	elseif _attrName = ETRow_SourceTerminal then
		if self.mySourceTerminal &lt;&gt; null then
			return self.mySourceTerminal.code;
		else
			return null;
		endif;
	elseif _attrName = ETRow_TargetTerminal then
		if self.myTargetTerminal &lt;&gt; null then
			return self.myTargetTerminal.code;
		else
			return null;
		endif;
	elseif _attrName = ETRow_CargoType then
		sourceTI := self.mySourceTI;
		if sourceTI &lt;&gt; null then
			on Exception do app.handleDeletedObject(exception, sourceTI, invalidTI); // shouldnt be but due to unit test am deleting the ti's
			return sourceTI.cargoTypeDescr;
		else
			return null;
		endif;
	elseif _attrName = ETRow_Status then
		return getStatusString;
	elseif _attrName = ETRow_Commodity then
		if self.mySourceTI &lt;&gt; null then
			return self.mySourceTI.getCommodityDesc();			
		else
			return null;
		endif;
	elseif _attrName = ETRow_IsoType then
		sourceTI := self.mySourceTI;
		if sourceTI&lt;&gt; null then
			on Exception do app.handleDeletedObject(exception, sourceTI, invalidTI); // shouldnt be but due to unit test am deleting the ti's
			tmpISO := app.myRoot.allISOTypes[sourceTI.getISOType];
			if tmpISO &lt;&gt; null then
				return tmpISO.code; // &amp; '  ' &amp; tmpISO.description;
			else
				return null;
			endif;						
		//	return self.mySourceTI.isoTypeDesc;
		else
			return null;
		endif;
	elseif _attrName = ETRow_Driver then
		if self.myInterTermVehicleJob &lt;&gt; null then
			return self.myInterTermVehicleJob.driverID;
		endif;
		if self.mySourceVehicleVisit &lt;&gt; null then
			return self.mySourceVehicleVisit.driversName;
		else
			if self.myTargetVehicleVisit &lt;&gt; null then
				return self.myTargetVehicleVisit.driversName;
			else
				return null;
			endif;
		endif; 
	endif;

	return inheritMethod(_attrName, _short);

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getMyTerminal" id="bc6fc759-aa90-4ae0-9853-26c40f610cb5">
        <source>getMyTerminal(): CM_Terminal;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 May 2016	cnwmp6	Initial creation

*/

vars

begin
	return self.mySourceTerminal;

epilog

end;</source>
        <ReturnType type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="getStatusString" id="aab1f71e-3708-4e3b-ad0c-40079f309deb">
        <source>getStatusString() : String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 February 2010	cnwrd1	Initial creation

*/

vars
	invalidTI : Boolean;
begin
	
	on Exception do app.handleDeletedObject(exception, self.myTargetTI, invalidTI); 

	
	if self.status = ITT_LOADED then
		return ITT_LOADED_STR;
	elseif self.status = ITT_LOADING then
		return ITT_LOADING_STR;
	elseif self.status = ITT_UNLOADED then
		if self.myTargetTerminal &lt;&gt; self.myTargetTI.myTerminal then // unloaded somewhere other than target terminal
			return ITT_UNLOADED_STR &amp; ' (' &amp; self.myTargetTI.myTerminal.code &amp;')' ;
		else
			return ITT_UNLOADED_STR;
		endif;
	elseif self.status = ITT_UNLOADING then
		return ITT_UNLOADING_STR;		
	else
		return 'Unknown';
	endif;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="8b5e47e1-0a9d-4a6b-b28d-e1b0eb4d3bdf">
        <source>pxyCreateUpdateProxy(): SelfType;

/*

Purpose:			

Parameters:			

Return Value:		


Date				Who		Reason
19 February 2010	cnwrd1	Initial creation
20/04/2011			cnwmh5	PAR #27401 - Add code to handle prossible exceptions occurring when
							trying to create the proxy
*/

vars
	pxyITM : CM_InterTerminalMove;
	completedOK		: Boolean;
begin

	pxyITM := inheritMethod();
	
	pxyITM.myInterTermVehicleJob := self.myInterTermVehicleJob;
	pxyITM.myOperator := self.myOperator;
	pxyITM.myReceiveRoadInterTerrminal := self.myReceiveRoadInterTerrminal;
	pxyITM.myReleaseRoadInterTerminal := self.myReleaseRoadInterTerminal;
	pxyITM.mySourceTI := self.mySourceTI;
	pxyITM.mySourceTerminal := self.mySourceTerminal;
	pxyITM.mySourceVehicle := self.mySourceVehicle;
	pxyITM.mySourceVehicleVisit := self.mySourceVehicleVisit;
	pxyITM.myTargetLC := self.myTargetLC;
	pxyITM.myTargetTI := self.myTargetTI;
	pxyITM.myTargetTerminal := self.myTargetTerminal;
	pxyITM.myTargetVehicle := self.myTargetVehicle;
	pxyITM.myTargetVehicleVisit := self.myTargetVehicleVisit;
	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return pxyITM;

epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete pxyITM;
	endif;

end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
