    <JadeMethod name="setComboValues" id="8a756f15-815b-4355-89b5-5f1c85b247b2">
        <source>setComboValues(_combo: ComboBox input; _params: CM_QueryCriteriaLineHolder; _queryOperator: CM_QueryOperator; _passport: CM_Passport);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 19/09/2013	cnwdap1		Initial creation PAR #32215 CCMS DPH 2290 New Car Attributes
//
vars
	carType		: CM_VehicleType;
	carTypeDict	: CM_VehicleTypeByType;
	
begin
	_combo.clear();
	carTypeDict := app.myDutyDocRoot.allVehicleTypes;
	
	foreach carType in carTypeDict do
		_combo.itemObject[_combo.addItem(carType.type)] := carType;
	endforeach;
	
	if CM_QStringLookup.hasInstance(_queryOperator) then
		_combo.listObject := carTypeDict[_queryOperator.CM_QStringLookup.selectionValue];
	elseif CM_QStringLookupNotEqual.hasInstance(_queryOperator) then
		_combo.listObject := carTypeDict[_queryOperator.CM_QStringLookupNotEqual.selectionValue];
	endif;
epilog

end;</source>
        <Parameter name="_combo" type="ComboBox" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_queryOperator" type="CM_QueryOperator"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setListValues" id="7f58d076-3f9d-44f6-b988-aee051e0c6fc">
        <source>setListValues(_tbl: Table input; _params: CM_QueryCriteriaLineHolder; _operator: CM_QueryOperator; _passport: CM_Passport);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 19/09/2013	cnwdap1		Initial creation PAR #322156 CCMS DPH 2290 New Car Attributes
//
vars
	carType 		: CM_VehicleType;
	carTypeDict 	: CM_VehicleTypeByType;
	selectionValue,
	idx				: Integer;
	array			: ObjectArray;
	
begin
	carTypeDict := app.myDutyDocRoot.allVehicleTypes;
	
	_tbl.rows := _tbl.fixedRows;
	
	//doesn't know about CMUI_ListTable - so have to do this:
	array := _tbl.getPropertyValue('allSelectedObjects').ObjectArray;
	array.clear;
	
	foreach carType in carTypeDict do
		selectionValue := 0;
		if _operator &lt;&gt; null and  _operator.CM_QStringIsOneOf.allSelectionValues.includes(carType.type) then
			selectionValue := 1;
			array.add(carType);
		endif;
		idx := _tbl.addItem(selectionValue.String &amp; Tab  &amp; carType.type);
		_tbl.accessRow(idx).itemObject := carType;
	endforeach;
epilog

end;</source>
        <Parameter name="_tbl" type="Table" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_operator" type="CM_QueryOperator"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setValuesFromList" id="0a9b3de1-430a-428f-8c2a-72fe7d005343">
        <source>setValuesFromList(_tbl: Table input; _op: CM_QueryOperator input);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 19/09/2013	cnwdap1		Initial creation PAR #33215 CCMS DPH 2290 New Car Attributes
//
vars
	carType		: CM_VehicleType;
	str			: String;
	numRows,
	idx			: Integer;
	sa			: StringArray;

begin
	create sa transient;
	
	numRows := _tbl.rows;
	foreach idx in (_tbl.fixedRows + 1) to numRows do
		str := _tbl.accessCell(idx, 1).text;
		if str = TableCheckBox_Selected then
			carType := _tbl.accessRow(idx).itemObject.CM_VehicleType;
			sa.add(carType.type);
		endif;
	endforeach;
	
	_op.setSearchValue(sa);

epilog
	delete sa;
end;</source>
        <Parameter name="_tbl" type="Table" usage="input"/>
        <Parameter name="_op" type="CM_QueryOperator" usage="input"/>
    </JadeMethod>
    <JadeMethod name="translateToDisplayValue" id="cf6188b8-67c1-4f70-9c99-73ffb0d64838">
        <source>translateToDisplayValue(_value: Any): String;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 19/09/2013	cnwdap1		Initial creation PAR #33215 CCMS DPH 2290 New Car Attributes
//
vars

begin
	if _value.isKindOf(CM_VehicleType) then
		if _value &lt;&gt; null then
			return _value.CM_VehicleType.type;
		else 
			return null;
		endif;
	else
		return _value.String;
	endif;

epilog

end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="translateToSearchValue" id="6a9b822d-9a15-4d2b-9ea6-fa29354bb1e8">
        <source>translateToSearchValue(_value: Any): Any;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 19/09/2013	cnwdap1		Initial creation PAR #32215 CCMS DPH 2290 New Car Attributes
//
vars
	invalidObj 		: Boolean;
	object			: CM_VehicleType;
	returnVal		: String;
	
begin
	if _value &lt;&gt; null then
		if _value.isKindOf(Collection) then			// PAR #18348
			return _value;
		endif;

		if _value.isKindOf(CM_VehicleType) then
			object := _value.CM_VehicleType;
		endif;
	endif;
	
	if object &lt;&gt; null then
		on Exception do app.handleDeletedObject(exception, object, invalidObj);
		returnVal := object.type;
	endif;
	
	return returnVal;
epilog

end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="translateToSearchValueForWeb" id="bff67bd6-5fb2-4b41-b4ea-1081c0db929e">
        <source>translateToSearchValueForWeb(_value: Any; _sending : Boolean): Any;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 24/09/2019	jlgdap1		Initial creation TFS 45769 JMT Web Portal selector query parameters
//
vars

begin
	if _value.isKindOf(String) then	
		return _value.String;
	endif;
	
	return inheritMethod(_value, _sending);

epilog

end;</source>
        <Parameter name="_value" type="Any"/>
        <Parameter name="_sending" type="Boolean"/>
        <ReturnType type="Any"/>
    </JadeMethod>
</Class>
