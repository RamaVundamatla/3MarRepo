    <JadeMethod name="getBulkRelease" id="1e327c0c-6e27-40ec-926b-4f6868b9013c">
        <source>getBulkRelease(): CM_BulkRelease;

/*

Purpose:			
//cnwrd1 par 28274 30.9.11 ccms 1241

Parameters:			

Return Value:		


Date		Who		Reason
28 September 2011	cnwrd1	Initial creation

*/

vars
	aRequest : CM_Request;
begin

	aRequest := self.myRealQueueEntry.CM_RTQueueEntry.myWorkListEntry.myRequest;
	
	if aRequest = null then  //hopefully not!
		return null; 
	endif;
		
	if aRequest.myOriginatingBulkRelease &lt;&gt; null then
		return aRequest.myOriginatingBulkRelease;
	endif;
		
	if aRequest.isKindOf(CM_YardDeliveryRequest) then
		if aRequest.CM_YardDeliveryRequest.myRelease &lt;&gt; null then
			return aRequest.CM_YardDeliveryRequest.myRelease;
		endif;
	endif;
		
	return null;
epilog

end;</source>
        <ReturnType type="CM_BulkRelease"/>
    </JadeMethod>
    <JadeMethod name="getDamaged" id="8a59fe24-e080-42c7-abfd-4125fad79bfe">
        <source>getDamaged():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 May 2013	cnwndl1	Initial creation	Par 31493

*/

vars

	ti : CM_TrackedItem;

begin

	ti := self.getTI;
	if ti = null then
		return null;
	else
		return ti.getDisplayStringForAttribute(ETRow_Damaged,false);
	endif;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="65f6fb80-11a5-4bb4-b239-9ffc702d9edb">
        <source>getDisplayStringForAttribute(_attrName: String; _short : Boolean) : String;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 April 2010	cnwer1	Initial creation
24 August 2011	cnwdap1	PAR #28047 CCMS POL 2095 extra location display information
20 June 2022	navdap1	TFS 53362 EUP Master Data interface customers between TOS and ERP
*/

vars
	tmpLC : CM_LocationsController;
	tmpTI : CM_TrackedItem;
	tmpStr : String;
	twinOpts: Integer;
	aBR 	: CM_BulkRelease;
	isoGrp 	: CM_ISOTypeGroup;
	task : CM_RTQueueTask;
	job : CM_Job;
	vvr : CM_VehicleVisitRecord;
	op : CM_Operator;				// TFS 53362
	iCarrier : CM_Carrier;
	iConsign: CM_ConsigneeConsignor;
begin
	if _attrName = ETRow_ContainerID then
		return self.containerID;
	elseif _attrName = ETRow_SourceLocation then
		//return self.currentLocationID;		// PAR #28047
		return self.getLocationSourceExtra;		// PAR #28047
	elseif _attrName = ETRow_TargetLocation then
		//return self.queuedLocationID;			// PAR #28047
		return self.getLocationTargetExtra;		// PAR #28047
	elseif _attrName = ETRow_Ostow then
		return self.isOverstow.getYes.asStringJMT;
	elseif _attrName = ETRow_Hazard then
		return self.isHazardous.getYes.asStringJMT;
	elseif _attrName = ETRow_Type then
		return self.type.asStringJMT;
	elseif _attrName = ETRow_VehicleID then
		return self.moveVehicleID;
	elseif _attrName = ETRow_Carrier then // 16/12/2010 cnwdz2 26582
		//TFS#53362 navsp1 20Jun2022
		if app.myRoot.getConfig(CarrierCmbOrdDescr).Boolean then  
			iCarrier := app.myRoot.allCarriers[self.carrier];
			if iCarrier&lt;&gt; null then
				return iCarrier.description;
			endif;
		endif;
		return self.carrier; //20/12/2010 cnwdz2 26582
	elseif _attrName = ETRow_ElapsedTime then
		return self.timeElapsedInMins.asDHMString;
	elseif _attrName = ETRow_Status then
		return self.taskStatus;
	elseif _attrName = ETRow_DoorDirection then
		return self.doorDirection;
	elseif _attrName = ETRow_Operator then
		// TFS 53362 start
		tmpTI := self.getTI;
		if tmpTI &lt;&gt; null and app.myRoot.getConfig(ComboByNameOperator).Boolean then
			op := tmpTI.myOperator;
			if op &lt;&gt; null then
				return op.description;
			endif;
		endif;
		// TFS 53362 end
		return self.operator;
	elseif _attrName = ETRow_IsoType then
		return self.isoType;
	elseif _attrName = ETRow_IsoGroup then
		tmpTI := self.getTI();
		if tmpTI = null then
			return null;
		endif;
		isoGrp:= tmpTI.getISOTypeGroup();
		if isoGrp &lt;&gt; null then
			return isoGrp.code;
		endif;
	elseif _attrName = ETRow_Remarks then
		return self.remarks;
	elseif _attrName = ETRow_SubTerminal then
		return self.subTerminal;
	elseif _attrName = ETRow_QueueID then
		return self.queueID;
	elseif _attrName = ETRow_JobID then
		return self.jobID;
	elseif _attrName = ETRow_ToDoTasks then
		return self.todoTasks;
	elseif _attrName = ETRow_Grade then
		return self.grade;
	elseif _attrName = ETRow_Commodity then
		return self.commodity;
	elseif _attrName = ETRow_Consignee then
		//TFS#53362 navsp1 20Jun2022
		if app.myRoot.getConfig(ConsigneeConsignorCmbOrdDescr).Boolean then  
			iConsign := app.myRoot.allConsigneeConsignors[self.consignee];
			if iConsign &lt;&gt; null then
				return iConsign.description;
			endif;
		endif;
		return self.consignee;
	elseif _attrName = ETRow_DischargePort then
		return self.dischargePort;
	elseif _attrName = ETRow_ImexStatus then
		return self.imexStatus;
	elseif _attrName = ETRow_TempC then
		return self.tempC;
	elseif _attrName = ETRow_TempF then
		return self.tempF;
	elseif _attrName = ETRow_Weight then
		return self.weight;
	elseif _attrName = ETRow_TwinLift then
		// CCMS 1210 Show Twin Lift Cannot use the graphics as Windows CE doesnot support the font
		twinOpts := self.myRealQueueEntry.CM_RTQueueEntry.getTwinCarryFlag;
		if twinOpts = CM_RTQueueEntry.TWIN_NEXT then
			return "Next";
		elseif  twinOpts = CM_RTQueueEntry.TWIN_PREV then
			return "Prev"; 
		elseif  twinOpts = CM_RTQueueEntry.TWIN_BOTH then
			return "Both";
		endif;
		return null;
	elseif _attrName = ETRow_OrigSourceLoc then
		return self.originalSourceLocID;
	elseif _attrName = ETRow_FinalTargetLoc then
		return self.finalTargetLocID;
	elseif _attrName = ETRow_LabRestrictSource then
		tmpLC := self.getLocationSource();
		if tmpLC = null then
			return "";
		endif;
		return tmpLC.hasRestrictions(LABOUR_RESTRICTION).getYes.asStringJMT;
	elseif _attrName = ETRow_LabRestrictSourceText then
		tmpLC := self.getLocationSource();
		if tmpLC = null then
			return "";
		endif;
		return tmpLC.getRestrictionsDesc(LABOUR_RESTRICTION);
	elseif _attrName = ETRow_LabRestrictTarget then
		tmpLC := self.getLocationTarget();
		if tmpLC = null then
			return "";
		endif;
		return tmpLC.hasRestrictions(LABOUR_RESTRICTION).getYes.asStringJMT;
	elseif _attrName = ETRow_LabRestrictTargetText then
		tmpLC := self.getLocationTarget();
		if tmpLC = null then
			return "";
		endif;
		return tmpLC.getRestrictionsDesc(LABOUR_RESTRICTION);
	elseif _attrName = ETRow_Overdimensional then
		tmpTI := self.getTI();
		if tmpTI = null then
			return null;
		endif;
		return tmpTI.isOverDimensions.getYes.asStringJMT;
	elseif _attrName = ETRow_OverdimensionalText then
		tmpTI := self.getTI();
		if tmpTI = null then
			return null;
		endif;
		return tmpTI.getODDescription.asStringJMT;
	elseif _attrName = ETRow_OverlappingSource then
		tmpLC := self.getLocationSource();
		if tmpLC = null then
			return "";
		endif;
		tmpStr := tmpLC.getOverlappingDesc();
		if tmpStr.trimBlanks() &lt;&gt; null then
			return "YES";
		else
			return null;
		endif;
	elseif _attrName = ETRow_OverlappingSourceText then
		tmpLC := self.getLocationSource();
		if tmpLC = null then
			return "";
		endif;
		tmpStr := tmpLC.getOverlappingDesc();
		if tmpStr &lt;&gt; null then
			return tmpStr &amp; " SOURCE";
		else
			return null;
		endif;
	elseif _attrName = ETRow_OverlappingTarget then
		tmpLC := self.getLocationTarget();
		if tmpLC = null then
			return "";
		endif;
		tmpStr := tmpLC.getOverlappingDesc();
		if tmpStr.trimBlanks() &lt;&gt; null then
			return "YES";
		else
			return null;
		endif;
	elseif _attrName = ETRow_OverlappingTargetText then
		tmpLC := self.getLocationTarget();
		if tmpLC = null then
			return "";
		endif;
		tmpStr := tmpLC.getOverlappingDesc();
		if tmpStr &lt;&gt; null then
			return tmpStr &amp; " TARGET";
		else
			return null;
		endif;
	elseif _attrName = ETRow_DoorsText then
		return self.doorDirection;
	elseif _attrName = ETRow_IsCA then
		tmpTI := self.getTI();
		if tmpTI = null then
			return null;
		endif;
		return tmpTI.isControlledAtmosphere.getYes.asStringJMT();
	
	elseif _attrName = ETRow_IsChilled then
		tmpTI := self.getTI();
		if tmpTI = null then
			return null;
		endif;
		return tmpTI.isChilled.getYes.asStringJMT();
	elseif _attrName = ETRow_CargoType then
		tmpTI := self.getTI();
		if tmpTI = null then
			return null;
		endif;
		return tmpTI.myCargoType.abbreviation;
	elseif _attrName = ETRow_CargoSubType or
		_attrName = ETRow_MyProduct then
		tmpTI := self.getTI();
		if tmpTI = null then
			return null;
		endif;
		return tmpTI.getCargoSubTypeCode();
	elseif _attrName = ETRow_ReleaseRequestNumber then	 //cnwrd1 par 28274 30.9.11 ccms 1241
		aBR := self.getBulkRelease(); 
		if aBR = null then
			return null;
		else
			return aBR.code;
		endif;		
	elseif _attrName = ETRow_TotalRequested then //cnwrd1 par 28274 30.9.11 ccms 1241
		tmpTI := self.getTI();
		if tmpTI &lt;&gt; null then
			return null;
		endif;
		aBR := self.getBulkRelease();
		if aBR = null then
			return null;
		else
			return aBR.getTotalRequested().asStringJMT();
		endif;		
	elseif _attrName = ETRow_Ptid then //cnwrd1 par 28274 30.9.11 ccms 1241
		tmpTI := self.getTI();
		if tmpTI = null then
			return null;
		endif;
		return app.getYesNo(tmpTI.getPreTripDT.isValid);		
	elseif _attrName = ETRow_PtiReqd then //cnwrd1 par 28274 30.9.11 ccms 1241
		return app.getYesBlank(self.getIsPTIRequired());
	elseif _attrName = ETRow_PtidOffsite then //cnwrd1 par 28274 30.9.11 ccms 1241
		tmpTI := self.getTI();
		if tmpTI = null then
			return null;
		endif;
		if tmpTI.isKindOf(CM_Container) then
			return app.getYesBlank(tmpTI.CM_Container.offsitePreTrip);
		else 
			return null;
		endif;
	elseif _attrName = ETRow_DwellDays or _attrName = ETRow_DwellDaysNumeric then //cnwrd1 par 28274 30.9.11 ccms 1241		//cnwmc5 - 4 Feb 2016 - PAR 37494
		tmpTI := self.getTI();
		if tmpTI = null then
			return null;
		endif;
		return tmpTI.getDwellDays().asStringJMT();
	elseif _attrName = ETRow_LoadOrder then //cnwrd1 par 28274 30.9.11 ccms 1241
		tmpTI := self.getTI();
		if tmpTI = null then
			return null;
		endif;
		return tmpTI.getDisplayStringForAttribute(ETRow_LoadOrder, false);
	elseif _attrName = ETRow_RfidTag then	//24 Apr 2012	NDL	Par 29417
		return self.getRfidCode();
	elseif _attrName = ETRow_Damaged then	//24 May 2013	NDL	Par 31493
		return self.getDamaged();
	elseif _attrName = ETRow_Voyage then	//cnwmc5 - 31 July 2013 - PAR 31550
		return self.getVoyageCode();
	elseif _attrName = ETRow_Quantity then
		//epr  par 32978 13/11/13
		tmpTI := self.getTI();
		if tmpTI = null then
			return null;
		endif;
		return tmpTI.quantity.asStringJMT;
	elseif _attrName = ETRow_IsOSmove then
		if self.myRealQueueEntry &lt;&gt; null then
			task:= self.myRealQueueEntry.CM_RTQueueEntry.getFirstUncompletedTask();
		endif;
		if task &lt;&gt; null then
			return task.isOverstowTask.getYesNo.asStringJMT();
		endif;
	elseif _attrName = ETRow_ModifiedIsoType then
		//epr par 33425 CCMS 2333 14/2/14
		tmpTI := self.getTI();
		if tmpTI = null then
			return null;
		endif;
		return tmpTI.myTerminal.myRTVehicleConfig.getIsoTypeHookString(tmpTI);
	elseif _attrName = ETRow_ModifiedSource then
		//epr par 33425 CCMS 2333 14/2/14
		if self.myRealQueueEntry &lt;&gt; null then
			task:= self.myRealQueueEntry.CM_RTQueueEntry.getDirectorOrPickupTask();
		endif;
		if task &lt;&gt; null then
			return myRealQueueEntry.CM_RTQueueEntry.getMyTerminal.myRTVehicleConfig.getLocationHookString(task,true);
		endif;
	elseif _attrName = ETRow_ModifiedTarget then
		//epr par 33425 CCMS 2333 14/2/14
		if self.myRealQueueEntry &lt;&gt; null then
			task:= self.myRealQueueEntry.CM_RTQueueEntry.getDirectorOrSetDownTask();
		endif;
		if task &lt;&gt; null then
			return myRealQueueEntry.CM_RTQueueEntry.getMyTerminal.myRTVehicleConfig.getLocationHookString(task,false);
		endif;
	elseif _attrName = ETRow_ModifiedDoor then
		//epr par 33425 CCMS 2333 14/2/14
		if self.myRealQueueEntry &lt;&gt; null then
			task:= self.myRealQueueEntry.CM_RTQueueEntry.getFirstUncompletedTask();
		endif;
		if task &lt;&gt; null then
			return myRealQueueEntry.CM_RTQueueEntry.getMyTerminal.myRTVehicleConfig.getDoorDirHookString(task,task.isPickUp);
		endif;
	elseif _attrName = ETRow_Amount then
		if self.myRealQueueEntry = null then
			return null;
		endif;
		
		if self.myRealQueueEntry.CM_RTQueueEntry.isBreakBulkMove then
			task:= self.myRealQueueEntry.CM_RTQueueEntry.getFirstUncompletedTask(); 
			if task &lt;&gt; null and task.isSetDown then
				return self.myRealQueueEntry.CM_RTQueueEntry.getAmountMovedDisplay(true);
			endif;
		endif;
		
		return self.myRealQueueEntry.CM_RTQueueEntry.getAmountLeftToMoveDisplay(); 
	//30 May 2017	NDL	TFS 4587
	elseif _attrName = ETRow_AllTIHazards then
		tmpTI := self.getTI();
		if tmpTI &lt;&gt; null then
			return tmpTI.getDisplayStringForAttribute( ETRow_AllTIHazards, _short );
		endif;
		
		return null;
	
	//01 May 2018	NDL	TFS 38353
	elseif _attrName = ETRow_VisitNumber then
		if self.myRealQueueEntry = null then
			return null;
		endif;
		job := self.myRealQueueEntry.CM_RTQueueEntry.myJob;
		if job &lt;&gt; null and job.isRoadJob then
			vvr := job.CM_RoadJob.myVehicleVisit;
		endif;
		if vvr &lt;&gt; null then
			return vvr.visitNumber;
		endif;
		
		return null;
	
	endif;
	
	return null;
epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getIsPTIRequired" id="61c9a56f-7c08-423f-8761-54274d5a4655">
        <source>getIsPTIRequired() : Boolean;

/*

Purpose:			
//cnwrd1 par 28274 30.9.11 ccms 1241
Parameters:			

Return Value:		


Date		Who		Reason
30 September 2011	cnwrd1	Initial creation

*/

vars

	aRequest : CM_Request;
	aReserve : CM_ReserveDetail;
begin

	aRequest := self.myRealQueueEntry.CM_RTQueueEntry.myWorkListEntry.myRequest;
	
	if aRequest = null then  //hopefully not!
		return false; 
	endif;
		
	if aRequest.myReserveDetail &lt;&gt; null then
		aReserve := aRequest.myReserveDetail;
	else				
		if aRequest.isKindOf(CM_YardDeliveryRequest) then
			if aRequest.CM_YardDeliveryRequest.myReleaseItem &lt;&gt; null then
				aReserve := aRequest.CM_YardDeliveryRequest.myReleaseItem;
			endif;
		endif;		
	endif;
	
	if aReserve = null then 
		return false;
	endif;

	if aReserve.myBookingRefItem = null then
		return false;
	endif;
	
	return aReserve.myBookingRefItem.inspected;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getLocationSource" id="0b87f719-0ed4-43b0-9d48-cb2bfa772f79">
        <source>getLocationSource() : CM_LocationsController;
// ---------------------------------------------------------------------------
// Created:     28 September 2010 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	rtTask : CM_RTQueueTask;
	tmpLC : CM_LocationsController;

begin
	if self.myRealQueueEntry = null then
		return null;
	endif;
	rtTask := self.myRealQueueEntry.CM_RTQueueEntry.getDirectorOrPickupTask;
	
	if rtTask &lt;&gt; null then	//17 Nov 2014	NDL	Par 35210
		tmpLC := rtTask.getSourceLocation();
	endif;

	return tmpLC;
epilog

end;</source>
        <ReturnType type="CM_LocationsController"/>
    </JadeMethod>
