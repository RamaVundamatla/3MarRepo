    <JadeMethod name="setForUpdate" id="d31de420-095c-4a50-9d9b-c4a90fbbbe2c">
        <updating/>
        <source>setForUpdate(_proxy:SelfType; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	self.endsMidCell := _proxy.endsMidCell;
	self.ordinalStartBay := _proxy.ordinalStartBay;
	self.ordinalEndBay := _proxy.ordinalEndBay;
	self.ordinalODStartCell := _proxy.ordinalODStartCell;
	self.ordinalODEndCell := _proxy.ordinalODEndCell;
	self.ordinalUDStartCell := _proxy.ordinalUDStartCell;
	self.ordinalUDEndCell := _proxy.ordinalUDEndCell;
	self.startsMidCell := _proxy.startsMidCell;
	self.endsMidCell := _proxy.endsMidCell;
	
	//created for JATOS epr 19/8/2013
	self.setForUpdateLayouts(_proxy,_passport);
end;</source>
        <Parameter name="_proxy" type="SelfType"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="44b5d018-3e3f-44c3-9f5a-f19418351cb0">
        <updating/>
        <source>setProxy(_ordinalStartBay,_ordinalEndBay,_ordinalODStartCell,_ordinalODEndCell,_ordinalUDStartCell,_ordinalUDEndCell:Integer; 
			_startsMidCell,_endsMidCell:Boolean; _allHolds : CM_VesselHoldSet; _baySet: CM_BaySet)  updating;
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

begin

	self.raiseExceptionIfNotTransient(method);

	self.ordinalStartBay := _ordinalStartBay;
	self.ordinalEndBay := _ordinalEndBay;
	self.ordinalODStartCell := _ordinalODStartCell;
	self.ordinalODEndCell := _ordinalODEndCell;
	self.ordinalUDStartCell := _ordinalUDStartCell;
	self.ordinalUDEndCell := _ordinalUDEndCell;
	self.startsMidCell := _startsMidCell;
	self.endsMidCell := _endsMidCell;

	self.setProxyBays(_baySet);

	self.allHolds.clear();
	if _allHolds = null then
		return;	//hack until we get it all sorted.
	endif;
	_allHolds.copy(self.allHolds);	
	
end;</source>
        <Parameter name="_ordinalStartBay" type="Integer"/>
        <Parameter name="_ordinalEndBay" type="Integer"/>
        <Parameter name="_ordinalODStartCell" type="Integer"/>
        <Parameter name="_ordinalODEndCell" type="Integer"/>
        <Parameter name="_ordinalUDStartCell" type="Integer"/>
        <Parameter name="_ordinalUDEndCell" type="Integer"/>
        <Parameter name="_startsMidCell" type="Boolean"/>
        <Parameter name="_endsMidCell" type="Boolean"/>
        <Parameter name="_allHolds" type="CM_VesselHoldSet"/>
        <Parameter name="_baySet" type="CM_BaySet"/>
    </JadeMethod>
    <JadeMethod name="setProxyBay" id="8d730e11-2adb-4a76-a7f9-d6df169822d3">
        <updating/>
        <source>setProxyBay(_bay: CM_Bay;_add : Boolean) updating;
// ---------------------------------------------------------------------------
// Created:		October 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars

begin
	self.raiseExceptionIfNotTransient(method);
	
	if _bay &lt;&gt; null then
		if _add then
			if not self.allBays.includes(_bay) then
				self.allBays.add(_bay);
			endif;
		else
			if self.allBays.includes(_bay) then
				self.allBays.remove(_bay);
			endif;
		endif;
		if not self.allBays.isEmpty then
			self.ordinalStartBay := self.allBays.first.ordinalBay;
			self.ordinalEndBay := self.allBays.last.ordinalBay;
		endif;
	endif;

end;</source>
        <Parameter name="_bay" type="CM_Bay"/>
        <Parameter name="_add" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setProxyBays" id="a5399421-aa15-42f5-a8c3-f6faa0768a4d">
        <updating/>
        <source>setProxyBays(_bayDefns: CM_BaySet) updating;
// ---------------------------------------------------------------------------
// Created:		December 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 25/02/2021	navmd1		TFS 49052 MACS3 Vessel Library API
// ---------------------------------------------------------------------------

vars

begin
	self.raiseExceptionIfNotTransient(method);
	
	self.allBays.clear;
	
	if _bayDefns &lt;&gt; null and _bayDefns.size &gt; 0 then
		_bayDefns.copy(self.allBays);

		self.ordinalStartBay := self.allBays.first.ordinalBay;
		self.ordinalEndBay := self.allBays.last.ordinalBay;
	endif;

end;</source>
        <Parameter name="_bayDefns" type="CM_BaySet"/>
    </JadeMethod>
    <JadeMethod name="setProxyMidCell" id="9166fa14-fa14-4fee-a591-e52ab11419e2">
        <updating/>
        <source>setProxyMidCell(_startsMidCell: Boolean; _endsMidCell: Boolean) updating;
// ---------------------------------------------------------------------------
// Created:		December 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	self.raiseExceptionIfNotTransient(method);

	self.startsMidCell := _startsMidCell;
	self.endsMidCell := _endsMidCell;
	
end;</source>
        <Parameter name="_startsMidCell" type="Boolean"/>
        <Parameter name="_endsMidCell" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="sideAbbreviation" id="b73cd183-6e89-456f-b9f7-0abf8afe1ba6">
        <methodInvocation>mapping</methodInvocation>
        <source>sideAbbreviation(set: Boolean; _value: String io) mapping;
/*
------------------------------------------------------------------------
Created:			08 October 2003 by cnwdwq1
Purpose:			
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/

vars
	side : Integer;
begin
	if set then
		return;
	endif;
	side := self.getSide();
	if side = JobSideCentre then
		_value := "C";
	elseif side = JobSidePort then
		_value := "P";
	elseif side = JobSideStarboard then
		_value := "S";
	else
		_value := "?";
	endif;
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="startsAtBay" id="e6c1015f-6176-4275-9e73-a7c1323d7552">
        <source>startsAtBay(ordinalBay : Integer) : Boolean;
/*
------------------------------------------------------------------------
Created:			21 November 2002 by cnwdwq1
Purpose:			
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
------------	------------	-----------------------------------------
---------------------------------------------------------------------------
*/
begin
	return ( self.ordinalStartBay = ordinalBay);
end;</source>
        <Parameter name="ordinalBay" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
