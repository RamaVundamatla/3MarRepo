<GUIClass name="CnEcMsgBoxForm" id="7323710f-d415-4b51-a05b-fa0e933ce5e4">
    <superclass name="CnEcDialogForm"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>___________________________________________________________________________

