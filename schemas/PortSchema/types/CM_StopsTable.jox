    <JadeMethod name="isStopApply" id="62e88b9f-1462-4d4a-bb29-8d5db9adc206">
        <source>isStopApply(_stopType : Integer; _terminal : CM_Terminal) : Boolean protected;
// ---------------------------------------------------------------------------
// Created:		27 February 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------
// 01/07/2010	cnwcs5	par 24341 - improve performance by not creating transient
vars
	template : CM_StopTableTemplate;
begin
	if _stopType = StopNull then
		return true;
	endif;
	
	template := self.allStopTableTemplates[_terminal, self]; //cnwrs1 par 17129 June 2008
	
	if  template = null then
		// can't possible apply as not set up
		return false;
	endif;
	
	return template.allApplyAreas.includes(_stopType);
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_stopType" type="Integer"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isStopApplyToArea" id="634ca908-a793-426f-920a-0f96a226d92b">
        <source>isStopApplyToArea(_stopType : Integer; _terminal : CM_Terminal) : Boolean;
// ---------------------------------------------------------------------------
// Created:     01 July 2010 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	return self.isStopApply (_stopType, _terminal);
epilog

end;</source>
        <Parameter name="_stopType" type="Integer"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isStopApplyToTI" id="afe5f0c9-59c1-46c5-8c98-8f981879bd31">
        <source>isStopApplyToTI(_ti : CM_TrackedItem) : Boolean;
/* ---------------------------------------------------------------------------
Created:     10 July 2008 by cnwrs2

Purpose:     PAR-17454 - need to check if this Stop should apply to this container
        
Change Date	Who		Reason
29/06/2010	cnwcs5	par 24341 - tranship auto apply option.  do not use isTranshipImport/isTranshipExport
17/06/2016  CNWMA1	par #37932 tfs#2143 PNL - Stop not being added
19 Aug 2022	navak20	TFS ChangeRequest 53862: EUP - WMS - Damage Recording Extra Details
30 May 2024 navma1	ChangeRequest 64367: MTN - Future Actors Performance Improvements
//19/12/2024    navsaa30 MTN-33636 TPT | Stops Configuration for Standard Damage
------------------------------------------------------------------------------*/
vars
	stopTableTemplate 	: CM_StopTableTemplate;
	includesImex,
	result 				: Boolean;
	portDict			: CM_PortByCodeDict;
	thisPort,
	dischargePort,
	transhipLoadPort	: CM_Port;
	thisCountry,
	dischargeCountry,
	transhipLoadCountry : CM_Country;
	root				: CM_Root;
begin
	
	if _ti = null then	
		return false;
	endif;
	
	stopTableTemplate := self.allStopTableTemplates[_ti.myTerminal, self];

	if stopTableTemplate = null then
		return false;
	endif;
	
	root := app.myRoot;						//30.05.2024 navma1 #64367
	
	portDict := app.myRoot.allPorts;
	thisPort := portDict[_ti.myTerminal.getConfig(PortDestCode).String];
	
	if thisPort &lt;&gt; null then
		thisCountry := thisPort.myCountry;
	endif;

	//epr TFS 1946 25/5/16
	result:= false;
	if 	stopTableTemplate.allApplyAreas.includes(StopApplyTranship) then
		if stopTableTemplate.allProcessAreas.includes(StopProcessTransLoadSameCty) then		// 21/7/17 MAP TFS4916
			if _ti.myTranshipDetail &lt;&gt; null then
				dischargePort := _ti.myTranshipDetail.myDischargePort;
				if dischargePort &lt;&gt; null then
					dischargeCountry := dischargePort.myCountry;
				endif;
				transhipLoadPort := portDict[_ti.myTranshipDetail.importOriginalLoadPort];
				if transhipLoadPort &lt;&gt; null then
					transhipLoadCountry := transhipLoadPort.myCountry;
				endif;
			endif;
			
			if _ti.isTranshipItem and transhipLoadCountry &lt;&gt; null and thisCountry &lt;&gt; null and dischargeCountry &lt;&gt; null and transhipLoadCountry = thisCountry and dischargeCountry &lt;&gt; thisCountry then
				result := true;
				includesImex := true;
			endif;
		else
			result :=_ti.getImExStatus = TI_IMEX_STATUS_TRANSHIP;				//30.05.2024 navma1 #64367
			includesImex:=true;
		endif;
	endif;
	
	if stopTableTemplate.allApplyAreas.includes(StopApplyExport) then
		if stopTableTemplate.allProcessAreas.includes(StopProcessTransLoadSameCty) then		// 7/8/17 MAP TFS4916
			dischargePort := portDict[_ti.dischargePort];
			if dischargePort &lt;&gt; null then
				dischargeCountry := dischargePort.myCountry;
			endif;

			if _ti.isExport and thisCountry &lt;&gt; null and dischargeCountry &lt;&gt; null and dischargeCountry &lt;&gt; thisCountry then
				result := true;
				includesImex := true;
			endif;
		else
			result:=result or _ti.isExport;
			includesImex:=true;
		endif;
	endif;
	
	// 19.08.2022 navak20 TFS 53862
	if stopTableTemplate.allApplyAreas.includes(StopApplyDamagedAndRefused) then
        result:=result or _ti.canSetDamageStopHasRefused();  // ### TFS 53862 15SEP2022 NAVAB1 // ### TFS 55314 07NOV2022 NAVAB1 method name changed
    endif;
    if stopTableTemplate.allApplyAreas.includes(StopApplyDamagedNotRefused) then
        result:=result or _ti.canSetDamageStopNoneRefused();  // ### TFS 53862 15SEP2022 NAVAB1 // ### TFS 55314 07NOV2022 NAVAB1 method name changed
    endif;
	if stopTableTemplate.allApplyAreas.includes(StopApplyDamaged) then			//19/12/24 navsaa30 33636
        result:=result or _ti.canSetDamageStop(); 
    endif;
	// 19.08.2022 navak20 TFS 53862
	
	if stopTableTemplate.allApplyAreas.includes(StopApplyImport) then
		result:=result or _ti.isImport;
		includesImex:=true;
	endif;
	
	if stopTableTemplate.allApplyAreas.includes(StopApplyPackComplete) then    //17/06/2016 cnwma1 PAR #37932 TFS #2143
		result:= result or _ti.isPackingComplete;
		includesImex:=true;
		
	endif;
	
	if stopTableTemplate.allApplyAreas.includes(StopApplyUnpackComplete) then  //17/06/2016 cnwma1 PAR #37932 TFS #2143
		result:= result or _ti.unpackedDT &lt;&gt;null;
		includesImex:=true;
	endif;
	

	if stopTableTemplate.allApplyAreas.includes(StopApplySOLASVGM) and (result or not includesImex)   then
		result :=_ti.myCargoType.canWeightBeCertified and not _ti.hasVGMDetails;
	endif;
	
	return result;
	
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isStopCEDOApplicable" id="fff2a249-c6b1-4009-85ef-45a4ff131a5d">
        <source>isStopCEDOApplicable( _ti : CM_TrackedItem) : Boolean;

/*
Purpose:			 

Parameters:			

Return Value:		


Date		Who		Reason
29 March 2010	cnwrd1	Initial creation
par 22903 

*/

vars
	mtCommodity : String;
begin

	if not self.isCEDOStop( _ti.myTerminal ) then
		return true;
	endif;
	
	if _ti.cargoType &lt;&gt; TI_CargoType_Container then //in reality a cedo stop should only be set for ISO Containers
		//we are a cedo stop BUT looking at a non Container cargo. 
		// we cant be empty so the stop should always apply
		return true;
	endif;
	
	
	//for create an empty TI wont be isEmpty here as content status hasnt been updated
	// therefore contentstatus will be null
	if _ti.isEmpty or _ti.getContentsStatus() = TI_CONTENTS_STATUS_NULL then
		// we are an empty ( possibly, contentstatus is likely wrong here!)
	
		if _ti.getContentsStatus() = TI_CONTENTS_STATUS_NULL then  //cnwrd1 par 24009 29.4.2010 - try and determine the state of contents
		// this is most likely because we are a new TI and havnt had our content status updated yet (happens further down CM_TrackedItem::setForCreate than where we are called from)
		// so we check the commodity - as we are definatly a container here!
			mtCommodity := _ti.myTerminal.getDefaultEmptyCommodity();
			if _ti.commodity = mtCommodity then
				//were an empty
				if  _ti.myTerminal.getConfig(CedoAppliesToEmpties).Boolean then			
					return true; //apply to empty
				else
					return false; // dont apply
				endif;
			else
				// not an empty
				return true;
			endif;
		endif;
	
		if  _ti.myTerminal.getConfig(CedoAppliesToEmpties).Boolean then			
			return true; //apply to empty
		else
			return false; // dont apply
		endif;
	else
		// must be a full so return true (MT/full check done elsewhere)		
		return true;
	endif;

	return true;
	
epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isStopHookCodeCompileTest" id="1bfe6440-b011-4001-bfb5-02be5a10b129">
        <updating/>
        <source>isStopHookCodeCompileTest(_ti : CM_TrackedItem; _result : Boolean io) updating;
//
// cnwrs1 Mar 2008 Stop Hook code
// self is the the stop table
// _ti is the trackedItem
// _result input is the current setting from the cargo type and other settings
// _result is the final settings true if the stop is to be applied false if the stop is not to be applied
vars

begin
   //sample code
   // this stop table can only be applied to containers
    if not _ti.isKindOf(CM_Container) then
        _result := false;
    endif;
 // if dray (import received by road or rail then this stop table does not apply
	if _ti.getImExStatus() = TI_IMEX_STATUS_IMPORT and
	   (_ti.receiptTransportMode &lt;&gt; TI_TRANSMODE_RAIL or
	    _ti.receiptTransportMode &lt;&gt; TI_TRANSMODE_ROAD) then
		_result := false;
	endif;
// dont apply this stop table to any cargo item with consignor ABC
	if _ti.consignor = 'ABC' then
		_result := false;
	endif;
end;
</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_result" type="Boolean" usage="io"/>
    </JadeMethod>
    <JadeMethod name="isStopPrevent" id="c24f07da-f70b-4ffb-98be-121136bd8d0c">
        <source>isStopPrevent(_stopType : Integer; _terminal : CM_Terminal) : Boolean protected;
// ---------------------------------------------------------------------------
// Created:		May 2002 By Andrew Bishop cnwab1
// ---------------------------------------------------------------------------
vars
	stopTableTemplate : CM_StopTableTemplate;
	deleteTransient : Boolean;
begin
	//par cnwrs1 may 2008
	if _stopType = StopNull then
		return true;
	endif;
	stopTableTemplate := self.allStopTableTemplates[_terminal, self]; //cnwrs1 par 17129 June 2008
	if  stopTableTemplate = null then
		//epr 2/2/16 par 37446 performance 
		return false;
	endif;
	return stopTableTemplate.allPreventAreas.includes(_stopType);
epilog
	
end;
</source>
        <access>protected</access>
        <Parameter name="_stopType" type="Integer"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isStopProcess" id="44f4bffb-1ae2-453c-bce9-622af5cbbd5d">
        <source>isStopProcess(_stopType : Integer; _terminal : CM_Terminal) : Boolean;
// ---------------------------------------------------------------------------
// Created:		Apr 2007 cnwrs1
// ---------------------------------------------------------------------------
vars
	stopTableTemplate : CM_StopTableTemplate;
	
begin
	//par cnwrs1 may 2008
	if _stopType = StopNull then
		return true;
	endif;
	stopTableTemplate := self.allStopTableTemplates[_terminal, self]; //cnwrs1 par 17129 June 2008
	if  stopTableTemplate = null then
		//epr 2/2/16 par 37446 performance 
		return false;
	endif;
	return stopTableTemplate.allProcessAreas.includes(_stopType);
epilog
	
end;
</source>
        <Parameter name="_stopType" type="Integer"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isStopProcessActionOK" id="4e9d5fcf-ae57-45a5-bc09-f0be85b86585">
        <source>isStopProcessActionOK( _ti : CM_TrackedItem) : Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
05 November 2008	cnwrd1	Initial creation

*/

vars
	processAreas : IntegerArray;
	checkAreas : IntegerArray;
	operator : CM_Operator;
	result :	Boolean;
begin

	result := true;
	create processAreas transient;
	// check stoptable template process action to include StopProcessOpImpReleasePIN or StopProcessOpExpReleaseNo 
	// if not return true - i.e. apply stop (if other conditions are met).
	// n.b. should have already filtered for import or export so dont need to worry about that in here


	// has the stop got a requires info flag? If so we are intrested in it
	if self.requiresInfo then
		
		//get the stops process areas
		self.getAllProcessAreas(_ti.myTerminal, processAreas);			
		
		//and the ti's operator
		operator := _ti.myOperator;		
		
		// if stop has requireinfotype AND processAction but the operator does NOT have the relevant flag return false - i.e. do not apply the stop
		// have to check both as stop can only have one requiresInfoType but More than one process action.
	
		if self.requiresInfoType = ImportReleasePIN  and 
		   processAreas.includes(StopProcessOpImpReleasePIN) then
			//check operator
			if not operator.getRequiresImpOperatorPIN() then
				return false;
			else
				// we should apply the stop but only if the info field is blank
				if _ti.getOperatorImportReleasePIN() &lt;&gt; '' then
					return false;
				endif;
			endif;
		endif;
		
		if self.requiresInfoType = DeliveryRelease and 
		   processAreas.includes(StopProcessOpImpDeliverRel) then //ccms1845 cnwrs1 nov 2009
			// we should apply the stop but only if the info field is blank
			if _ti.deliveryRelease &lt;&gt; '' then
				return false;
			endif;
		endif;
		
		if self.requiresInfoType = ExportReleaseNumber  and processAreas.includes(StopProcessOpExpReleaseNo) then		
			if not operator.getRequiresExportOperatorNo() then
				return false;
			else
			// we should apply the stop but only if the info field is blank
				if _ti.getOperatorExpReleaseNo() &lt;&gt; '' then
					return false;
				endif;
			endif;
		endif;
		
		if self.requiresInfoType = CustomsReference  then	//03 Jul 2015	NDL	Par 36543
			// we should apply the stop but only if the info field is blank
			if _ti.customsReference &lt;&gt; '' then
				return false;
			endif;
		endif;

		
	else
	//if not then do not stop the stop being applied
		result := true;
	endif;
	
	return result;
epilog
	delete processAreas;
	delete checkAreas;
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isStopRelevant" id="6612fa90-190d-4e9d-90a0-0a2f48c3d981">
        <source>isStopRelevant(_ti : CM_TrackedItem) : Boolean;
//isStopRelevant(_cargoType : Integer; _ti : CM_TrackedItem) : Boolean;	// cnwrl1 10/02/2010 PAR 22307 - what it was
//
// cnwrs1 May 2007 Par13378 Stops should be the stop be applied to this item
//	10/02/2010	cnwrl1		PAR 22307 = Removed cargoType from method signiture since it is never actually used.
// 30/06/2010	cnwcs5		par 24341 - remove tranship checking (it is not going to stay)
// 20 Oct 2022	navsj20	ChangeRequest 53862: EUP - WMS - Damage Recording Extra Details
vars
	result : Boolean;
	ti : CM_TrackedItem;
begin
	ti := _ti;
	
	//if self.isValidForCargoType(_ti.cargoType)	//20.10.2022	navsj20	TFS 53862
	if self.isValidForStopCriteria(_ti)				//20.10.2022	navsj20	TFS 53862
	//and self.isValidForTranshipSetting(_ti.isTranshipItem, _ti.myTerminal) //cnwrs1 Jan 2010
	and self.isValidForCoastalSetting(_ti.isCoastalInbound, _ti.isCoastalOutbound, _ti.myTerminal) //cnwrs1 par 17129 June 2008  //cnwrs1 par25912 1 Oct 2010
	and self.isValidForChildSetting(_ti.isChild, _ti.myTerminal) //cnwrs1 par 17129 June 2008
	and (self.isValidForMTs(_ti.isEmpty(), _ti.myTerminal)  //cnwrs1 par 17129 June 2008
	or self.isValidForFulls(_ti.isEmpty(), _ti.myTerminal)) //cnwrs1 par 17129 June 2008
	then
		result := true;
	else
		result := false;
	endif;
	
	
	
	// Note that the user hook is called in all cases to give the user the option to 
	// override both a true and a false result cnwgb1 12.11.08
	app.myHookAgent.runHookLinkPublic(HookType_IsStopRelevant, self, self, ti, result);
	
	if not result then
			app.writeLog(method.qualifiedName &amp; " STOPS " &amp; self.heading &amp; " is not relevant - HOOK CODE", LogDEBUG);
	endif;
	return result;
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isStopRelevantBOL" id="81e0d3b9-1127-4b9b-901a-cab2195638eb">
        <source>isStopRelevantBOL( _ti : CM_BOL ) : Boolean;
//isStopRelevantBOL(_cargoType : Integer; _ti : CM_BOL) : Boolean;	// cnwrl1 10/02/2010 PAR 22307 - what it was
//
// cnwrs1 May 2007 Par13378 Stops should be the stop be applied to this item
// 10/02/2010	cnwrl1		PAR 22307 = Removed cargoType from method signiture since it is never actually used.
//
vars
	result : Boolean;
begin
	if self.isValidForCargoType(_ti.bolType) then
		result := true;
	else
		result := false;
	endif;
	return result;
end;

</source>
        <Parameter name="_ti" type="CM_BOL"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isStopRelevantHook" id="c49ca5ac-e845-46ee-b1fd-373318f658fc">
        <updating/>
        <source>isStopRelevantHook(_ti : CM_TrackedItem; _result : Boolean io) updating;
//
// cnwrs1 May 2007 Stop Hook code
// _ti is the trackedItem
// _result input is the current setting from the cargo type and other settings
// _result is the final settings true if the stop is to be applied false if the stop is not to be applied
vars

begin
	//sample code
	// all stops can only be applied to containers
    if not self.isKindOf(CM_Container) then 
        _result := false;
    endif;
	// if dray (import received by road or rail stopId 1 does not apply
	if self.id = 1 and
	   _ti.getImExStatus() = TI_IMEX_STATUS_IMPORT and 
	   (_ti.receiptTransportMode &lt;&gt; TI_TRANSMODE_RAIL or
	   _ti.receiptTransportMode &lt;&gt; TI_TRANSMODE_ROAD) then
		_result := false;
	endif;
	// dont apply stop 2 to any container with consignor ABC
	if self.id = 2 and
	   _ti.consignor = 'ABC' then
		_result := false;
	endif;
end;
</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_result" type="Boolean" usage="io"/>
    </JadeMethod>
