        <source>addItemObject(_text:String; _obj:Object):Integer;
// --------------------------------------------------------------------------------
// Created:		20 February 2006 by cnwdad1
//
// Purpose:		Adds an object to the combobox control, with text.
//
// Parameters:	_text - The text to display for the entry.
//				_obj - A reference to the object for the entry.
//
// Returns:		Nothing
