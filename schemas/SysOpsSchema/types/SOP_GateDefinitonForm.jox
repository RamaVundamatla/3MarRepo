    <JadeMethod name="setControlsForView" id="60093267-922c-41e2-bf54-c1e334c9b332">
        <updating/>
        <source>setControlsForView()updating;
// ---------------------------------------------------------------------------
// Created:     25 June 2009 by concms1
// Purpose:     CCMS 1061 - Gate Config Changes  
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 23/02/2010	cnwcs5		par 18061 - RFID prompt
// ---------------------------------------------------------------------------
vars

begin
	inheritMethod;
	
	txtName.readOnly		:= true;
	cmbICArea.enabled		:= false;
	chkEntry.enabled		:= false;
	chkExit.enabled			:= false;
	chkPrompt.enabled		:= false;	// 23/02/2010 cnwcs5 par 18061
	cmbTroubleIn.enabled	:= false; 
	self.chkBarrierCodes.enabled:=false; //jlier1 TFS 57936 19/5/23
	tblGateAreas.userInputEnabled	:= false;
	tblGateLanes.userInputEnabled	:= false;
	
	
	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.grpGate.enabled := false;
		self.tblGateAreas.readOnly := false;
		self.tblGateLanes.readOnly := false;
		self.tblMeasurement.readOnly := false;
		self.tblGateAreas.readOnly := false;
	endif;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setGateAreaPicture" id="efa8aa13-4921-424b-97be-9b0c6c330de8">
        <source>setGateAreaPicture(_usage :CM_GateAreaUsage; _row :Integer)protected;
// ---------------------------------------------------------------------------
// Created:     27 July 2009 by cnwcs5:1
// Purpose:     CCMS 1061 - Gate Config Changes  
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	table	:CM_DataTable;
	col		:Integer;
begin
	table	:= tblGateAreas;
	col 	:= table.getColumnByRowName (ETRow_Area_in_out);
	
	if _usage.type = CM_GateAreaUsage.Type_IN then
		table.accessCell (_row, col).picture := self.picIn.picture;
		table.accessedCell.text	:= null;
	elseif _usage.type = CM_GateAreaUsage.Type_OUT then
		table.accessCell (_row, col).picture := self.picOut.picture;
		table.accessedCell.text := null;
	else
		app.raiseUnexpectedProgramError (self.class.name, method.name, 'Invalid value for In/Out');
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_usage" type="CM_GateAreaUsage"/>
        <Parameter name="_row" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setGateLaneTableNeedsRefresh" id="c59da989-5f4f-4151-a9fb-2f994f71f73a">
        <source>setGateLaneTableNeedsRefresh(_value :Boolean) protected;
// ---------------------------------------------------------------------------
// Created:     29 June 2009 by concms1
// Purpose:     CCMS 1061 - Gate Config Changes  
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	if _value then
		tblGateLanes.tag := self.GateLaneTable_Refresh; 
	else
		tblGateLanes.tag := null;
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_value" type="Boolean"/>
