    <JadeMethod name="setResourceParent" id="694d10b9-ee1f-42a7-93ab-a466e394d774">
        <updating/>
        <source>setResourceParent() updating, protected;

vars
	tmpLstCount,
	count,
	lastParentPosn,
	oldLastParentPosn : Integer;
	setParentUsed :	Boolean;
begin
  	// This method sets the back colour on the Resource Description (parent at level 1) to 
  	// parentSetColor when one or more of its child resources is being used.
  	count := 1;
  	oldLastParentPosn := 1;
  	lastParentPosn := 1;
  	tmpLstCount := lstResourceList.listCount;
  	
  	while count &lt;= tmpLstCount do 
  		if lstResourceList.itemLevel[count] = 1 then
  			lastParentPosn := count;
  			if oldLastParentPosn &lt;&gt; lastParentPosn then
  				// Parent has changed - set backColor on last parent and new oldLastParentPosn
  				if setParentUsed = true then
  					lstResourceList.itemBackColor[oldLastParentPosn] := ResourceParentUsed;
  					oldLastParentPosn := lastParentPosn;
  					setParentUsed := false;
  				else
  					// Set backcolor to lbxbackground
  					lstResourceList.itemBackColor[oldLastParentPosn] := lstResourceList.backColor;
  					oldLastParentPosn := lastParentPosn;
  					setParentUsed := false;
  				endif;
  			else
  				// first item in list
  				lstResourceList.itemBackColor[1] := lstResourceList.backColor;
  			endif;
  		elseif lstResourceList.itemLevel[count] = 2 then
  			if lstResourceList.itemSelected[count] = true then
  				setParentUsed := true;
  			endif;
  		endif;
  		count := count+1;
  	endwhile;
  	// Set lastParentPosn in list
  	if setParentUsed = true then
  		lstResourceList.itemBackColor[oldLastParentPosn] := ResourceParentUsed;
  	endif;


end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setResourcesUsed" id="6bd60166-25d1-4acc-b16e-7a1e2f83f9a6">
        <updating/>
        <source>setResourcesUsed() updating, protected;

vars
 	resourceUsed:	CMIF_HMS_ResourceUsed;
 	posn:			Integer;
begin
	if self.aMySelectedMovement = null then
		return;
	endif;
 	// This method set the resource used list for resources that are held in the 
 	// movements collection of resources used
 	foreach resourceUsed in self.aMySelectedMovement.allWorkingResUsed do
 		if resourceUsed.myResource &lt;&gt; null then
	 		posn := self.lstResourceList.findObject(resourceUsed.myResource);
	 		if posn &gt; 0 then
 				// This resource is used on this movement - set to selected in the list
 				self.lstResourceList.itemSelected[posn] := true;
	 		endif;
	 	endif;
	 	
	 	if resourceUsed.myResourceType &lt;&gt; null then

	 		posn := self.lstResourceList.findObject(resourceUsed.myResourceType);
	 		if posn &gt; 0 then
 				// This resource is used on this movement - set to selected in the list
				if resourceUsed.myResource &lt;&gt; null then
					self.lstResourceList.itemBackColor[posn] := ResourceParentUsed;				
				else
					self.lstResourceList.itemBackColor[posn] := Red;
				endif;
			endif;
	 	endif;
 	endforeach;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setTblResourceCells" id="1bb079d9-b0cd-48d7-8f68-b0fafe77cda0">
        <updating/>
        <source>setTblResourceCells(_theRow : Integer; _resourceUsed : CMIF_HMS_ResourceUsed; _resourceType : HMS_ResourceType) updating, protected;
//--------------------------------------------------
// Created:	February 2005 By: cnwgd1
//11 Aug 2025	  navhn30 MTN-35592: 14050 Error when adding Resources on the Movement Maintenance form in Harbour Management
//--------------------------------------------------
vars
	backColour : Integer;
	tmpTable : CM_DataTable;
begin

	tmpTable := self.tblResources;
	if _resourceUsed.myPersistentResourceUsed &lt;&gt; null then
		if _resourceUsed.myPersistentResourceUsed.myVTMISTransaction &lt;&gt; null then
			//Already invoiced, disable row as cannot change once invoiced
			tmpTable.accessRow(_theRow).enabled := false;
			tmpTable.accessRow(_theRow).backColor := Gray;	
			return;
		endif;
	endif;
	
	backColour := tmpTable.accessedRow.backColor;
	tmpTable.setBackColor(_theRow,self.aColResource,White);		//11.08.2025	navhn30 	MTN-35592
	tmpTable.setBackColor(_theRow,self.aColResourceType,White);	//11.08.2025	navhn30 	MTN-35592

	//Currently cannot update these two from here
	tmpTable.setBackColor(_theRow,self.aColCreateCharge,White);		//11.08.2025	navhn30 	MTN-35592
	tmpTable.setBackColor(_theRow,self.aColPartOfContract,White);	//11.08.2025	navhn30 	MTN-35592
									
	//disable cells that do not need input
	if (not _resourceType.isQuantityRequired) then
		tmpTable.enableCell(_theRow,self.aColUnitsUsed,false);		//11.08.2025	navhn30 	MTN-35592
		tmpTable.setBackColor(_theRow,self.aColUnitsUsed,backColour);//11.08.2025	navhn30 	MTN-35592

	else
		tmpTable.enableCell(_theRow,self.aColUnitsUsed,true);	//11.08.2025	navhn30 	MTN-35592
		tmpTable.setBackColor(_theRow,self.aColUnitsUsed,White);	//11.08.2025	navhn30 	MTN-35592
	endif;
	
	if (not _resourceType.isActionDateTimeRequired)
	and (not _resourceType.isFromToDateTimeRequired) then
		tmpTable.enableCell(_theRow,self.aColDateFrom,false);		//11.08.2025	navhn30 	MTN-35592  start
		tmpTable.enableCell(_theRow,self.aColTimeFrom,false);
		tmpTable.enableCell(_theRow,self.aColTimeTo,false);
		tmpTable.enableCell(_theRow,self.aColDateTo,false);
		tmpTable.setBackColor(_theRow, self.aColDateTo,backColour);
		tmpTable.setBackColor(_theRow, self.aColDateFrom,backColour);
		tmpTable.setBackColor(_theRow, self.aColTimeFrom,backColour);
		tmpTable.setBackColor(_theRow, self.aColTimeTo,backColour);	//11.08.2025	navhn30 	MTN-35592	end
	elseif _resourceType.isActionDateTimeRequired
	and (not _resourceType.isFromToDateTimeRequired) then
		tmpTable.enableCell(_theRow,self.aColDateFrom,true);	//11.08.2025	navhn30 	MTN-35592	start
		tmpTable.enableCell(_theRow,self.aColTimeFrom,true);
		tmpTable.enableCell(_theRow,self.aColTimeTo,false);
		tmpTable.enableCell(_theRow,self.aColDateTo,false);
		tmpTable.setBackColor(_theRow, self.aColDateTo,backColour);
		tmpTable.setBackColor(_theRow, self.aColDateFrom,White);
		tmpTable.setBackColor(_theRow, self.aColTimeFrom,White);
		tmpTable.setBackColor(_theRow, self.aColTimeTo,backColour);	//11.08.2025	navhn30 	MTN-35592	end		
	else
		//isActionDateTimeRequired not required and isFromToDateTimeRequired is required don't disable any DT columns
		tmpTable.enableCell(_theRow,self.aColDateFrom,true);	//11.08.2025	navhn30 	MTN-35592 start
		tmpTable.enableCell(_theRow,self.aColTimeFrom,true);
		tmpTable.enableCell(_theRow,self.aColTimeTo,true);
		tmpTable.enableCell(_theRow,self.aColDateTo,true);
		tmpTable.setBackColor(_theRow, self.aColDateTo,White);
		tmpTable.setBackColor(_theRow, self.aColDateFrom,White);
		tmpTable.setBackColor(_theRow, self.aColTimeFrom,White);
		tmpTable.setBackColor(_theRow, self.aColTimeTo,White);	//11.08.2025	navhn30 	MTN-35592  end
	endif;			
	// ### PAR 10579 CCMS 1350
	if not self.aCanUpdateFull then
		if not self.aCanUpdatePartial then
			// View Only
			tmpTable.accessRow(_theRow).enabled := false;
		else
			// Partial Only - no generate invoiceline now or in/out contract
			tmpTable.enableCell(_theRow,self.aColPartOfContract,false);	//11.08.2025	navhn30 	MTN-35592
			tmpTable.enableCell(_theRow,self.aColCreateCharge,false);	//11.08.2025	navhn30 	MTN-35592
		endif;
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="_theRow" type="Integer"/>
        <Parameter name="_resourceUsed" type="CMIF_HMS_ResourceUsed"/>
        <Parameter name="_resourceType" type="HMS_ResourceType"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="a5bb57bf-70af-4190-9c31-66b6ccf41b0c">
