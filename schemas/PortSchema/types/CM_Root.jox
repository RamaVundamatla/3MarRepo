	self.setupInvStatusEmailDefault(PINEmail_InvProcDefOffset + CM_Invoice.INVOICE_OPEN, // ie. 300
									app.invoiceStatusEnumToString(CM_InvoiceProcessDefault.firstInstance, CM_Invoice.INVOICE_OPEN),
