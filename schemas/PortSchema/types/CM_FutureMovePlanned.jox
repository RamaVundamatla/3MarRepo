    <JadeMethod name="isLCNextToFM" id="7204a0d3-3711-4b23-9d48-8ef9b3cd141e">
        <source>isLCNextToFM(_lc : CM_LocationsController) : Boolean;
// ---------------------------------------------------------------------------
// Created:     20 January 2009 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	lc : CM_LocationsController;
begin

	lc := self.allLocationsControllers.last;
	
	if lc = null then
		return false;
	endif;
	
	if not lc.isGridLocation() then
		return false;
	endif;
	
	if lc.CM_GridController.myNextController = _lc then
		return true;
	endif;
	
	return false;
epilog

end;</source>
        <Parameter name="_lc" type="CM_LocationsController"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="removeLocationController" id="b16545bb-345a-4602-b9cc-738eea807895">
        <source>removeLocationController(_location : CM_LocationsController);
// ---------------------------------------------------------------------------
// Created:		October 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	if self.allLocationsControllers.includes(_location) then
		self.allLocationsControllers.remove(_location);
	endif;
end;</source>
        <Parameter name="_location" type="CM_LocationsController"/>
    </JadeMethod>
    <JadeMethod name="resetLocations" id="feeeec36-72e8-4f57-8329-790509b04e33">
        <updating/>
        <source>resetLocations(_control: CMIF_MoveController) updating;
// -------------------------------------------
// Created 18 December 2003 by cnwdvb1
// -------------------------------------------
/*

Date		Who		Reason
27 Feb 2009	cnwkpd1	Fix Grid form refresh for target location changes
29 Aug 2012	cnwcs5	par 30292 - use updateObjectEdition instead of updateEdition 
*/

vars

begin

	self.allLocationsControllers.clear();
	_control.allToLocations.copy(self.allLocationsControllers);
	self.updateObjectEdition(self);	// par 30292

end;</source>
        <Parameter name="_control" type="CMIF_MoveController"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="d8437d57-6d4e-4ab8-961a-66105a9ef6c0">
        <updating/>
        <source>setForCreate(_control : CMIF_MoveController; _moveType : Integer; arrayIndex : Integer ) updating;
/*
 ------------------------------------------------------------------------
Created:			05 August 2002 by cnwdwq1
Purpose:			
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------	--------------	-----------------------------------------
12/05/2010		cnwdap1			CCMS 1116 Tranship changes
04/10/2010		cnwdap1			PAR #25938 Correct setting of location IDs for future moves
21/05/2019		jlgzm1			TFS 42840 MSL Direct Release between Voyages and Rail
22/08/2019		jlgzm1			TFS 42872 Direct Release Between Hold Voyages and Rail
06/11/2024		navdap1			MTN-18897 EUP | FR 53485 EUP - Warehouse Yard Allocation
---------------------------------------------------------------------------
*/
vars
	wle : CM_WorkListEntry;
	ti : CM_TrackedItem;
	source, target : String;
	aFM : CM_FutureMovePlanned;
	lc : CM_LocationsController;
begin
	// ### PAR 9089. The setting of the wle was further down but it is needed in the setLocations method.
	wle := _control.myWorkListEntry;
	if wle = null then
		if _control.jobForMove &lt;&gt; null then
			if _control.myTrackedItem &lt;&gt; null then
				wle := _control.jobForMove.getWLEForTI(_control.myTrackedItem); // PAR 9288 changed to pass in the TI on the controller not on the WLE
			endif;
		endif;
	endif;
	
	//epr par 31831 18/6/13
	if wle &lt;&gt; null then
		if wle.myFutureMove &lt;&gt; null and  wle.myFutureMove.isKindOf(CM_FutureMoveQueued) then
			wle.myFutureMove.CM_FutureMoveQueued.setMyFutureMovePlanned(self);
		else
			self.setMyWorkListEntry(wle, true);
		endif;
	else
		self.setMyWorkListEntry(wle, true);
	endif;
	
	self.moveType := _moveType;
	self.setLocations(_control.allToLocations);
	self.isMoveToFullGCArea := _control.isPlannedToFullGCArea;			// MTN-18897
	
	if _control.myTrackedItem = null and _moveType = TI_FutureMoveEDI then
		//-------------------------------
		//EDI moves have a special "null" future move as an array element placeholder
		//on all of the CM_SlotControlelrs that DONT have a TI future move for THIS SLOT.
		//This way, we can ask for the "x"th futuremove for an EDI bayplan display, and in 
		//this instance, display null (i.e. no trackeditem in this edi bayplan).
		//DQ 10/Feb/2003
		//DQ 21/Feb/2003. These are now handled by a specific sub-class  CM_FutureMoveEDI
		//-------------------------------
		app.raiseCMException1(Err_InvalidFutureMove, 'EDI for Non edi class', null, null);
		return;
	endif;

	// TFS 42840 start
	if _control.myDDWorkListEntry &lt;&gt; null then
		self.myWorkListEntryDR := _control.myDDWorkListEntry;
	endif;
	// TFS 42840 end
	
	if self.myWorkListEntryDR &lt;&gt; null then	// TFS 42872
		// For Direct Release moves, TI can have several planned future moves
		// want to make sure we append to collection, not override 
		_control.myTrackedItem.setPlannedFutureMove(0, self);	// TFS 42872
	else
		_control.myTrackedItem.setPlannedFutureMove(arrayIndex, self);
	endif;

	self.myTerminal := self.myTrackedItem.myTerminal;

	//Always update the primary location property
	ti := _control.myTrackedItem;
	ti.refreshMyFutureLocations(PLANNING_MODE,null);

//	self.setMyWorkListEntry(wle);PAR 9089 moved up
	if wle &lt;&gt; null 
	and self.moveType &lt;&gt; TI_FutureMoveDLRLoad then // PAR 22335
		if _control.myOriginatingLocation.isKindOf(CM_VoyageController) then
			source := _control.myOriginatingLocation.getStowageId(ti);			
		elseif ti &lt;&gt; null and ti.locationId &lt;&gt; null and _moveType &lt;&gt; TI_FutureMoveDLRLoad then // to get the stack height, not just the location ID
			source := ti.locationId;
		else 
			source := _control.getOriginatingLocationId();
		endif;
		if _control.myToPrimaryLocation.isKindOf(CM_VoyageController) then
			target := _control.myToPrimaryLocation.getStowageId(ti);
		else 
			//target := _control.getPrimaryLocationId();
			target := _control.myToPrimaryLocationString;
		endif;
		wle.setLocations(source,target);		
		// ### PAR 8820. if an unlinked load SOB WLE then try to get the discharge WLE and set the locations to be the same.
		self.setForCreateCheckSOBWLEs(wle,ti);
		
		// if this is a tranship and it has already been planned to the export ship set the source location on the export load move
		if ti &lt;&gt; null and ti.isTranshipOnInboundVoyage() then
			//aFM := ti.myTranshipExport.getFutureMoveOfType(PLANNING_MODE, TI_FutureMovePlanned).CM_FutureMovePlanned;	// PAR #23645 CCMS 1116
			aFM := ti.getFutureMoveOfType(PLANNING_MODE, TI_FutureMovePlanned).CM_FutureMovePlanned;					// PAR #23645 CCMS 1116
			// if there is no loade FM yet we cannot know where this is from
			// PAR #25938 we need to check the future move to see if it's actually for the export voyage,
			// and we're not just finding the discharge future move we just created
			if aFM &lt;&gt; null then
				lc := aFM.allLocationsControllers.first;														// PAR #25938
				if CM_SlotController.hasInstance(lc) and lc.CM_SlotController.myVoyage = ti.myExportVoyage then	// PAR #25938
					aFM.myWorkListEntry.setLocations(target,aFM.myWorkListEntry.locationTarget);
				endif;																							// PAR #25938
			endif;
			
		endif;
	endif;
	
	if self.myWorkListEntryDR &lt;&gt; null and 		// TFS 42872
	   self.myTrackedItem &lt;&gt; null and			// TFS 42872
	   self.myTrackedItem.myVoyage &lt;&gt; null and	// TFS 42872
	   self.myTerminal &lt;&gt; null then				// TFS 42872
		// raise notifications of being assigned to direct release
		app.myEventManager.createSingleObjInfoNoteEvt(self.myTrackedItem.myVoyage, self.myTerminal.getTerminalEvent(WLE_Update_Event), self.myWorkListEntryDR); // TFS 42872
	endif;
	
end;</source>
        <Parameter name="_control" type="CMIF_MoveController"/>
        <Parameter name="_moveType" type="Integer"/>
        <Parameter name="arrayIndex" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setForCreateCheckSOBWLEs" id="35946bdc-8f87-4b74-8e23-ab2091f8b562">
        <source>setForCreateCheckSOBWLEs(_wle : CM_WorkListEntry;_ti : CM_TrackedItem);
// ---------------------------------------------------------------------------
// Created:		August 2004 By Andrew Bishop cnwab1
//
// Purpose:		PAR 8820. if an unlinked load SOB WLE then try to get the discharge WLE and set the locations to be the same.

//
// ---------------------------------------------------------------------------
vars
	wle, sobWLE : CM_WorkListEntry;
	source, target : String;
	vWLE,vWLE2 : CM_VoyageWLE;
	wleSR : CM_Request;

begin
	wle := _wle;
	source := wle.locationSource;
	target := wle.locationTarget;
	
	// ### PAR 8820. if an unlinked load SOB WLE then try to get the discharge WLE and set the locations to be the same.
	if not wle.isKindOf(CM_VoyageWLE) then
		return;
	endif;
	
	vWLE := wle.CM_VoyageWLE;
	wleSR := vWLE.myRequest;
	// ## unlinked load SOB
	if vWLE.isSOB 
	and not wleSR.isLinked
	and wleSR.getAttrIsLoad then
		// get the discharge SOB
		foreach wle in _ti.allWorklistEntries do
			if wle.status = WLE_COMPLETED then
				continue;
			endif;
			if wle.isKindOf(CM_VoyageWLE) then
				vWLE := wle.CM_VoyageWLE;
				wleSR := vWLE.myRequest;
				if vWLE.isSOB 
				and not wleSR.isLinked
				and wleSR.getAttrIsDischarge then
					sobWLE := wle;
					break;
				endif;
			endif;
		endforeach;
		if sobWLE &lt;&gt; null then
			sobWLE.setLocations(source,target);		
		endif;
	endif;


end;</source>
        <Parameter name="_wle" type="CM_WorkListEntry"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="setFromFMQueued" id="93e884a2-cc6f-4f35-94a9-fa221e654157">
        <updating/>
        <source>setFromFMQueued(_theFM : CM_FutureMoveQueued) updating;
/*

Purpose:				Sets up object based on the passed in Queued Future Move.
						Useful for when a QueuedFM needs to be downgraded to a PlannedFM
						but doesn't have a link to one.
						In particular, unqueuing a Direct Release move from Road to Hold Voyage;
						the road wle only has a queued fm, and the hold wle needs to be reset back
						to its original planned fm that was thrown out when it was set for direct release

Parameters:			

Return Value:		

Date					Who		Reason
04 September 2019		jlgzm1	Initial creation TFS 42878 Direct Release Between Road and Voyage

*/

vars
	wle 	: CM_WorkListEntry;
	wleDR 	: CM_WorkListEntry;
	ti		: CM_TrackedItem;
begin
	if _theFM = null then
		// can't do much else can we
		return;
	endif;
	
	wle := _theFM.myWorkListEntry;
	wleDR := _theFM.myWorkListEntryDR;
	ti := _theFM.myTrackedItem;
	
	self.setMyWorkListEntry(wle, true);
	self.setMyWorkListEntryDR(wleDR, true);
	self.setMyTrackedItem(ti);
	self.myOriginalSplitTrackedItem := _theFM.myOriginalSplitTrackedItem;
	self.myTerminal := _theFM.myTerminal;
	// movetype can't be set from a QueuedFM, just use the default
	self.moveType := TI_FutureMovePlanned;
	self.setLocations(_theFM.allLocationsControllers);
	
	
epilog

end;</source>
        <Parameter name="_theFM" type="CM_FutureMoveQueued"/>
    </JadeMethod>
    <JadeMethod name="setLocations" id="a113bde2-8112-4827-8254-c0880ac17d83">
        <updating/>
        <source>setLocations(_allLocationsControllers: CM_LCArray) updating;
/*
------------------------------------------------------------------------
Created:			10 February 2003 by cnwdwq1
Purpose:			Dave Q's code
Parameters:		See Method signature above. Special comment:
Returns:			See Method signature above. Special comment:
Changed On		Changed By		Reason
------------	------------	-----------------------------------------
10/03/2017		cnwdap1			TFS 3516 LNX Hold Planning Quantity
------------------------------------------------------------------------
*/
vars
	anLC : CM_LocationsController;
	lWLE, aWLE : CM_WorkListEntry;
	theTI : CM_TrackedItem;
	aFM : CM_FutureMovePlanned;
	linkedRequest : CM_Request;
begin
	self.allLocationsControllers.clear;
	
	if _allLocationsControllers = null then
		return;
	endif;
	if not _allLocationsControllers.isEmpty then
		_allLocationsControllers.copy(self.allLocationsControllers);
	endif;
	
	aWLE := self.myWorkListEntry;
	if aWLE &lt;&gt; null then
		aWLE.setLocations(aWLE.locationSource, self.getPrimaryLocationId());		
		
		if self.moveType = TI_FutureMoveDLRDischarge  then
			theTI := aWLE.myTrackedItem;
			//if theTI &lt;&gt; null then												// TFS 3516
			if theTI &lt;&gt; null and not aWLE.job.isVoyageHoldJob then				// TFS 3516
				aFM := theTI.getFutureMoveOfType(PLANNING_MODE,TI_FutureMoveDLRLoad).CM_FutureMovePlanned;
				if aFM &lt;&gt; null then
					aWLE := aFM.myWorkListEntry;
					if aWLE &lt;&gt; null then
						aWLE.setLocations(self.getPrimaryLocationId(),aWLE.locationTarget);		
					endif;
				
				endif;
			
			endif;
		// PAR 13646
		elseif self.moveType = TI_FutureMoveSOB then
				// PAR 16346
				if aWLE.myTrackedItem &lt;&gt; null then
					linkedRequest := aWLE.myTrackedItem.getMatchingDLRSOBSlotRequest(aWLE.myRequest);
					if linkedRequest &lt;&gt; null then
						lWLE := linkedRequest.allWorkListEntries.first;
						if lWLE &lt;&gt; null then
							lWLE.setLocations(lWLE.locationSource, self.getPrimaryLocationId());		
						endif;
					endif;
				endif;
		endif;
		
		
	endif;
end;</source>
        <Parameter name="_allLocationsControllers" type="CM_LCArray"/>
    </JadeMethod>
    <JadeMethod name="setMyOriginalSplitCargo" id="72e23e99-51de-4440-ac60-8c0e8cf07db7">
        <updating/>
        <source>setMyOriginalSplitCargo(_cargo : CM_Cargo input) updating;

// Created by cnwdvb1 on 02 November 2006

vars

begin

	self.myOriginalSplitTrackedItem := _cargo;

end;</source>
        <Parameter name="_cargo" type="CM_Cargo" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setMyTrackedItem" id="89cb5c7c-de12-45dc-9b27-49b2a735a0da">
        <updating/>
        <source>setMyTrackedItem(_ti: CM_TrackedItem input) updating;

// Created by cnwdvb1 on 02 November 2006

vars

begin
	
	_ti.setPlannedFutureMove(0, self);

	// jlgzm1 tfs42863 05/07/2019
	if self.myTerminal = null then
		self.myTerminal := _ti.myTerminal;
	endif;
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem" usage="input"/>
    </JadeMethod>
</Class>
