    <JadeMethod name="loadReceivalsTable" id="266c2502-87f8-4965-b411-a66e20ebb8bb">
        <updating/>
        <source>loadReceivalsTable()updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06 August 2009	cnwml2	Initial creation

*/

vars
	wle : CM_WorkListEntry;
	job : CM_RoadJob;
begin
	job := self.myVisitRecord.myRoadJob;
	
	if job = null then
		return;
	endif;
	
	self.allReceiveWLEs.clear();
	
	self.tblReceivals.clearAllData();
	self.tblReceivals.rows := self.tblReceivals.fixedRows;
	self.tblReceivals.multiSelect := CM_BaseTable.MultiSelect_Simple;	
	self.tblReceivals.selectionType := CM_BaseTable.SelectionType_Row;

	foreach wle in self.myVisitRecord.myRoadJob.workListEntries do
		if wle.isReceipt then
			self.addReceiveWorkEntry(wle);
		endif;
	endforeach;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="loadReleasesTable" id="da09a28e-b61b-4532-ae14-672ffd4518a4">
        <updating/>
        <source>loadReleasesTable()updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06 August 2009	cnwml2	Initial creation

*/

vars

	wle : CM_WorkListEntry;
	job : CM_RoadJob;
begin
	job := self.myVisitRecord.myRoadJob;
	
	if job = null then
		return;
	endif;
	
	self.allReleaseWLEs.clear();

	self.tblReleases.clearAllData();
	self.tblReleases.rows := self.tblReleases.fixedRows;
	self.tblReleases.multiSelect := CM_BaseTable.MultiSelect_Simple;
	self.tblReleases.selectionType := CM_BaseTable.SelectionType_Row;

	
	foreach wle in self.myVisitRecord.myRoadJob.workListEntries do
		if not wle.isReceipt then
			self.addReleaseWorkEntry(wle);
		endif;
	endforeach;

epilog

end;</source>
    </JadeMethod>
