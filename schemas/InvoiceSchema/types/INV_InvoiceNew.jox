    <JadeMethod name="cmbStatusInvProp_lostFocus" id="a011170c-4759-4056-bc05-99587660b2cb">
        <controlMethod name="CMUI_ComboBox::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbStatusInvProp_lostFocus(combobox: ComboBox input) updating;
/*

Purpose:			The lost focus event of the combo box to set the invoice status on the form

Parameters:			combobox	ComboBox	The combo box that was used

Return Value:		NONE

Date				Who		Reason
30 September 2022	navpw1	Initial creation
05 December 2024	navtr3	JIRA 12565 MTN - 14011 Error when attempting to save a manual invoice
*/

vars
	invoiceProcess : CM_InvoiceProcess; 
begin
	//self.tblInvProperties.setValueByControlName(combobox.name,combobox.text);	//05.12.2024 navtr3 #12565
	
	if(self.myTerminal &lt;&gt; null and self.myTerminal.getDefaultCompanyBank() &lt;&gt; null) then //05.12.2024 navtr3 #12565
	 invoiceProcess := self.myTerminal.getDefaultCompanyBank().myInvoiceProcess;
	endif;
	
	if((combobox.name = self.cmbStatusInvProp.name)
		and (invoiceProcess &lt;&gt; null)
		and (combobox.text &lt;&gt; invoiceProcess.allStatuses[CM_Invoice.INVOICE_PENDING].description) 
		and (combobox.text &lt;&gt; invoiceProcess.allStatuses[CM_Invoice.INVOICE_OPEN].description) 
		and (combobox.text &lt;&gt; invoiceProcess.allStatuses[CM_Invoice.INVOICE_PENDING_APPROVAL].description)) then
			if(invoiceProcess.isLinxProcess()) then
				self.tblInvProperties.setValueByControlName(self.cmbStatusInvProp.name, invoiceProcess.allStatuses[CM_Invoice.INVOICE_PENDING_APPROVAL].description);
				self.cmbStatusInvProp.listIndex	:= self.cmbStatusInvProp.findStringExact(1,invoiceProcess.allStatuses[CM_Invoice.INVOICE_PENDING_APPROVAL].description); 
			else
				self.tblInvProperties.setValueByControlName(self.cmbStatusInvProp.name, invoiceProcess.allStatuses[CM_Invoice.INVOICE_PENDING].description);
				self.cmbStatusInvProp.listIndex	:= self.cmbStatusInvProp.findStringExact(1,invoiceProcess.allStatuses[CM_Invoice.INVOICE_PENDING].description); 
			endif;
	 else
	    self.tblInvProperties.setValueByControlName(combobox.name,combobox.text);
	endif;	
end;
</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
