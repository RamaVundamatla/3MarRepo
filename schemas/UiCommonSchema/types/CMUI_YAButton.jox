    <JadeMethod name="click" id="5460809f-3b68-4d79-9f87-a8b85e2b6561">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>click(btn: Button input) updating, clientExecution;
// --------------------------------------------------------------------------------
// Created:		28 February 2005 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	app.mousePointer	:=	Busy;
	inheritMethod(btn);
	
//	beginLoad;
	
	if self.myYAControl &lt;&gt; null then
		if self.isLocationAdd then
			self.myYAControl.doAddLocation(null);
		elseif self.isLocationDelete then
			self.myYAControl.doDeleteLocation();
		elseif self.isClearLocations then
			self.myYAControl.doClearLocations(null);
		elseif self.isMoveUp then
			self.myYAControl.doMoveMultipleBlocks(true);
		elseif self.isMoveDown then
			self.myYAControl.doMoveMultipleBlocks(false);
		elseif self.isDODefault then
			self.myYAControl.doDeckingOptionsDefault();
		elseif self.isDOSpecify then
			self.myYAControl.doDeckingOptionsSpecify();
		endif;
		
	elseif self.myYACriteriaControl &lt;&gt; null then
		if self.isCriteriaTypeUpdate then
			self.myYACriteriaControl.doCriteriaValueUpdate();
		elseif self.isCriteriaTypeAdd then
			self.myYACriteriaControl.doCriteriaValueAdd();
		elseif self.isCriteriaTypeDelete then
			self.myYACriteriaControl.doCriteriaValueDelete();
		elseif self.isListSelect then
			self.myYACriteriaControl.doSelect(false);
		elseif self.isListSelectAll then
			self.myYACriteriaControl.doSelect(true);
		elseif self.isListUnselect then
			self.myYACriteriaControl.doUnselect(false);
		elseif self.isListUnselectAll then
			self.myYACriteriaControl.doUnselect(true);
		endif;
		
	endif;
	
//	endLoad;
epilog
	app.mousePointer	:=	Idle;
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setCriteriaControl" id="632cb7e3-f228-47b8-ae5e-e2a89f2ba810">
        <updating/>
        <source>setCriteriaControl(	pYACControlObj:CMUI_YASelectCriteriaCntl;
					pIsUpdateCriteriaAttribute:Boolean;
					pIsAddCriteriaAttribute:Boolean;
					pIsDeleteCriteriaAttribute:Boolean;
					pIsSelect:Boolean;
					pIsSelectAll:Boolean;
					pIsUnselect:Boolean;
					pIsUnselectAll:Boolean) updating;
// --------------------------------------------------------------------------------
// Created:		28 February 2005 by cnwdad1
//
// Purpose:		Sets a reference to the parent Yard Allocation Criteria control,
//				and sets the "function" for which the receiver is used.
//
// Parameters:	pYACControlObj - A reference to the parent Yard Allocation Criteria control.
//				pIsAddCriteriaAttribute - True if the receiver is used to add a Criteria Attribute.
//				pIsDeleteCriteriaAttribute - True if the receiver is used to delete a Criteria Attribute.
//				pIsSelect - True if the receiver is used to select an item from the "available" listbox.
//				pIsSelectAll - True if the receiver is used to select all items in the "available" listbox.
//				pIsUnselect - True if the receiver is used to remove an item from the "selected" listbox.
//				pIsUnselectAll - True if the receiver is used to remove all items in the "selected" listbox.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.myYACriteriaControl	:=	pYACControlObj;
	self.isCriteriaTypeUpdate	:=	pIsUpdateCriteriaAttribute;
	self.isCriteriaTypeAdd		:=	pIsAddCriteriaAttribute;
	self.isCriteriaTypeDelete	:=	pIsDeleteCriteriaAttribute;
	self.isListSelect			:=	pIsSelect;
	self.isListSelectAll		:=	pIsSelectAll;
	self.isListUnselect			:=	pIsUnselect;
	self.isListUnselectAll		:=	pIsUnselectAll;
end;</source>
        <Parameter name="pYACControlObj" type="CMUI_YASelectCriteriaCntl"/>
        <Parameter name="pIsUpdateCriteriaAttribute" type="Boolean"/>
        <Parameter name="pIsAddCriteriaAttribute" type="Boolean"/>
        <Parameter name="pIsDeleteCriteriaAttribute" type="Boolean"/>
        <Parameter name="pIsSelect" type="Boolean"/>
        <Parameter name="pIsSelectAll" type="Boolean"/>
        <Parameter name="pIsUnselect" type="Boolean"/>
        <Parameter name="pIsUnselectAll" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setYAControl" id="941b5339-8562-4805-b4a5-d1a8e22af4a0">
        <updating/>
        <source>setYAControl(	pYAControl:CMUI_YardAllocationControl;
				pIsAddLocation:Boolean;
				pIsDeleteLocation:Boolean;
				pIsClearLocations:Boolean;
				pIsMoveUp:Boolean;
				pIsMoveDown:Boolean;
				pIsDODefault:Boolean;
				pIsDOSpecify:Boolean) updating;
// --------------------------------------------------------------------------------
// Created:		28 February 2005 by cnwdad1
//
// Purpose:		Sets a reference to the parent Yard Allocation control, and sets
//				the "function" for which the receiver is used.
//
// Parameters:	pYAControl - A reference to the parent Yard Allocation control.
//				pIsAddLocation - True if the receiver is used to add Locations.
//				pIsDeleteLocation - True if the receiver is used to delete Locations.
//				pIsClearLocations - True if all YA Location Blocks are to be cleared.
//				pIsMoveUp - True if a YA Block is to be moved up the list.
//				pIsMoveDown - True if a YA Block is to be moved down the list.
//				pIsDODefault - True if the receiver is used to set the default Decking
//					Options of a YA Block.
//				pIsDOSpecify - True if the receiver is used to specify the Decking
//					Options of a YA Block.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.myYAControl		:=	pYAControl;
	self.isLocationAdd		:=	pIsAddLocation;
	self.isLocationDelete	:=	pIsDeleteLocation;
	self.isClearLocations	:=	pIsClearLocations;
	self.isMoveUp			:=	pIsMoveUp;
	self.isMoveDown			:=	pIsMoveDown;
	self.isDODefault		:=	pIsDODefault;
	self.isDOSpecify		:=	pIsDOSpecify;
end;</source>
        <Parameter name="pYAControl" type="CMUI_YardAllocationControl"/>
        <Parameter name="pIsAddLocation" type="Boolean"/>
        <Parameter name="pIsDeleteLocation" type="Boolean"/>
        <Parameter name="pIsClearLocations" type="Boolean"/>
        <Parameter name="pIsMoveUp" type="Boolean"/>
        <Parameter name="pIsMoveDown" type="Boolean"/>
        <Parameter name="pIsDODefault" type="Boolean"/>
        <Parameter name="pIsDOSpecify" type="Boolean"/>
    </JadeMethod>
