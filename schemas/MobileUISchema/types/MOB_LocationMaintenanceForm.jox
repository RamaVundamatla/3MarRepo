    <JadeMethod name="translateForm" id="dc70d58c-ad66-41c6-8a27-25eec3bf41bc">
        <updating/>
        <source>translateForm(locale : CM_Locale) updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	
begin
	// Determine the locale for translations.
	inheritMethod(locale);
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0017610, locale);
	btnCancel.translateCaption(Xlat_0013165, locale);
	btnOk.translateCaption(Xlat_0013166, locale);
	btnRemoveAlloc.translateCaption(Xlat_0013167, locale);
	lblAvailable.translateCaption(Xlat_0013168, locale);
	lblClosed.translateCaption(Xlat_0013169, locale);
	lblLocation.translateCaption(Xlat_0013170, locale);
end;</source>
        <Parameter name="locale" type="CM_Locale"/>
    </JadeMethod>
