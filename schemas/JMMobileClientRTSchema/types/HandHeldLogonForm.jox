    <JadeMethod name="doBtnLogonClick" id="3ffbc82c-71fa-4862-8359-d296940c60e6">
        <updating/>
        <source>doBtnLogonClick() updating, protected;
/*
----------   ----------  --------------------------------------------------
Created:	11 September 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	userName,
	password,
	errorStr		: String;
	foundDevice		: CM_RadioTelemetryDevice;
	frm				: Form;
begin
	
	userName	:=	self.txtUsername.text.trimBlanks();
	password	:=	self.txtPassword.text.trimBlanks();
	
	app.myLogonGuiAgent.doLogon(userName, password,  errorStr);
	
	if errorStr &lt;&gt; null then
		app.msgBox(errorStr, 'Logon Error', MsgBox_Exclamation_Mark_Icon);
		self.txtPassword.setFocus();
		return;
	endif;
	
	if app.myHandHeldLogonGuiAgent &lt;&gt; null then 
		self.doShowOptions();
	else		
		create frm as app.myHandHeldGuiAgent.getMainForm() transient;
		
		frm.show();
		self.unloadForm;
	endif;
		
	
		
end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doExit" id="39c4fc3f-3d22-41b8-8f3c-0025526523bc">
        <updating/>
        <source>doExit() protected, updating;
/*
----------   ----------  --------------------------------------------------
Created:	11 September 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	frmClass			: Class;
	frm					: Form;
begin
	if app.msgBox('Exiting will close this application. Are you sure you wish to exit?','Are you sure?',MsgBox_Yes_No) &lt;&gt; MsgBox_Return_Yes then
		return;
	endif;
	self.frmMain.visible := false;
	self.frmOptions.visible := false;
	
	
	self.unloadForm;
	//app.msgBox(self.String, null, null);
	frm := app.getForm(self.class.name);
	if frm &lt;&gt; null then
	//	frm.unloadForm;
	endif;
	
end;


</source>
        <access>protected</access>
    </JadeMethod>
