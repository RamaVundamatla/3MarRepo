    <JadeMethod name="addJobToTable" id="c565ba10-22d6-4d0a-a7d8-9ef0c1df00a4">
        <source>addJobToTable(_job : CM_VoyageJob; _firstVisibleColumn, _atIdx : Integer) protected;
//--------------------------------------------------
// Created:	28 January 2004 By: cnwgd1
//--------------------------------------------------
// 18/07/2011	cnwmh5	#27479 - Work out with column to add 'Load' heading to
vars
	idx : Integer;
	isSOB : Boolean;
	jobTypeDescr : String;
	column 		: Integer;
	index		: Integer;
begin
	
	if (not CM_VoyageJob.hasInstance(_job)) then
		return;
	endif;
	
	if _firstVisibleColumn &lt; 1 then
		return;
	endif;
	
	isSOB := _job.isSOB;
	
	if _job.isSOB then
		jobTypeDescr := 'SOB';
	elseif _job.isDischarge then
		jobTypeDescr := 'Discharge';
	else
		jobTypeDescr := 'Load';
	endif;
	
	if _job.isRehandle then
		jobTypeDescr := jobTypeDescr &amp; Tab &amp; ' (has DLR)';
	endif;
	
	if _atIdx &lt;&gt; null then
		self.tblData.addItemAt(null, _atIdx);
		idx := _atIdx;
	else
		idx := self.tblData.addItem(null);
	endif;
	
	self.tblData.accessRow(idx).itemObject := _job;
	
	self.tblData.setCellText(idx, _firstVisibleColumn, 'Job No:' &amp; _job.jobNum);
	
	// 19/07/2011 cnwmh5 #27479
	index := _firstVisibleColumn + 1;				
	foreach column in index to 6 do
		if self.tblData.accessColumn(column).visible = true then
			break;
		endif;
	endforeach;
	
	self.tblData.setCellText(idx, column, jobTypeDescr);		// 19/07/2011 cnwmh5 #27479
	
	self.tblData.accessRow(idx).backColor := self.ColourYellowLight;
	self.tblData.accessedRow.foreColor := Green;
	
end;</source>
        <access>protected</access>
        <Parameter name="_job" type="CM_VoyageJob"/>
        <Parameter name="_firstVisibleColumn" type="Integer"/>
        <Parameter name="_atIdx" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="addToolbarControls" id="41cb8f63-cbc5-4be0-8fd1-f54a2d1652e7">
        <updating/>
        <source>addToolbarControls() updating, protected;
// ---------------------------------------------------------------------------
// Created:     09 September 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	frm				: CMUI_Toolbar;
begin	
	frm := self.frmToolbar;
	frm.addButton(self.btnShowSearcher, CMUI_Toolbar.Control_Alignment_Left);
	
	inheritMethod();

	frm.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnLocate, CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnMoveUp, CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnMoveDown, CMUI_Toolbar.Control_Alignment_Left);

	
end;</source>
        <access>protected</access>
    </JadeMethod>
