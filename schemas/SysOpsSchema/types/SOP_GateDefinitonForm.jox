    <JadeMethod name="doSave" id="0dfe59ce-bbb9-4d8f-9bc7-bb2f23d3c8c0">
        <updating/>
        <source>doSave():Boolean updating;
// ---------------------------------------------------------------------------
// Created:     25 June 2009 by concms1
// Purpose:     CCMS 1061 - Gate Config Changes  
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	newGate		:CM_Gate;
	result		:Integer;
begin
	if self.myProxyObject = null then
		app.raiseUnexpectedProgramError (self.class.name, method.name, 'Null Gate proxy object');
	endif;
	
	while true do
		if self.mode = Mode_Add then
			app.myTrxCA.trxCreateGate(self.myProxyObject.CM_Gate, newGate, app.myPassport);
		else
			app.myTrxUA.trxUpdateGate(self.myProxyObject.CM_Gate, app.myPassport);
		endif;

		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			break;
		else
			result := app.showErrorWarningDialog(self.caption, app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
		endif;
		return false;
	endwhile;

	if self.mode = Mode_Add then
		self.myCurrentObject := newGate;
	else
		// they may have changed order or added/removed gate lanes so we refresh the list just in case
		self.zBeginTimerForRefresh ();
	endif;
	
	return true;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSetGateAreaId" id="1328e89a-947a-4bac-8b9d-95ca681a4391">
        <source>doSetGateAreaId(_value :String)protected;
// ---------------------------------------------------------------------------
// Created:     28 July 2009 by cnwcs5
// Purpose:     CCMS 1061 - gate config
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	gateArea	:CM_GateArea;
begin
	if self.mode &lt;&gt; self.Mode_Add and self.mode &lt;&gt; self.Mode_Update then
		return;
	endif;
	
	gateArea := self.getSelected_GateArea;
	
	if gateArea &lt;&gt; null then
		gateArea.setID (_value);
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_value" type="String"/>
    </JadeMethod>
    <JadeMethod name="doSetGateEntry" id="d3587805-fbd9-4fec-96cc-b7b78c034eac">
        <updating/>
        <source>doSetGateEntry() updating, protected;
// ---------------------------------------------------------------------------
// Created:     31 July 2009 by cnwcs5:1
// Purpose:     CCMS 1061 - Gate Config Changes  
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	area	:CM_GateArea;
	gate	:CM_Gate;
	int		:Integer;
begin
	if self.myProxyObject = null then
		return;
	endif;
	
	gate := self.myProxyObject.CM_Gate;
	
	if gate.isInGate then
		if not gate.allGateAreas_IN.isEmpty then
			int := app.msgBox (app.getErrorString (Gate_Warning2), app.getErrorString (Warning), MsgBox_Yes_No);			
			
			if int = MsgBox_Return_No then
				chkEntry.value := true;
				return;
			endif;
		endif;
	endif;
	
	gate.setIsInGate (chkEntry.value);
	
	area := self.getSelected_GateArea;
		
	if gate.isInGate then
		// create a-gate
		if not gate.hasAGateArea then
			// don't expect one but there were during testing
			gate.pxyAddNewGateArea (null, null, CM_GateArea.AreaType_A, true, false);
			
			self.loadGateAreas (gate);	
			self.loadGateLanes;
		elseif area &lt;&gt; null and area.laneCount = 0 then
			self.loadGateLanes;
		endif;		
	else
		if not gate.allGateAreas_IN.isEmpty then
			gate.pxyRemoveAllUsages (true);
			
			self.loadGateAreas (gate);
			self.loadGateLanes;
			self.setTroubleInCombo (gate);
			return;
		endif;
		
		if area &lt;&gt; null and area.laneCount = 0 then
			// re-display gate lanes table
			self.loadGateLanes;
		endif;

	endif;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doSetGateExit" id="75abc06b-1e99-4147-9411-7993fb32d2c6">
        <updating/>
        <source>doSetGateExit() updating, protected;
// ---------------------------------------------------------------------------
// Created:     31 July 2009 by cnwcs5:1
// Purpose:     CCMS 1061 - Gate Config Changes  
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	area	:CM_GateArea;
	gate	:CM_Gate;
	int 	:Integer;
begin
	if self.myProxyObject = null then
		return;
	endif;
	
	gate := self.myProxyObject.CM_Gate;
	
	if gate.isOutGate then
		if not gate.allGateAreas_OUT.isEmpty then
			int := app.msgBox (app.getErrorString (Gate_Warning3), app.getErrorString (Warning), MsgBox_Yes_No);			
			
			if int = MsgBox_Return_No then
				chkExit.value := true;
				return;
			endif;
		endif;
	endif;
	
	gate.setIsOutGate (chkExit.value);
	
	area := self.getSelected_GateArea;
		
	if not gate.isOutGate then
		if not gate.allGateAreas_OUT.isEmpty then
			gate.pxyRemoveAllUsages (false);
			
			self.loadGateAreas (gate);
			self.loadGateLanes;
			return;
		endif;
		
		if area &lt;&gt; null and area.laneCount = 0 then
			// re-display gate lanes table
			self.loadGateLanes;
		endif;
	endif;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
