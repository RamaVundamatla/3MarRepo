    <JadeMethod name="run" id="dc4d6668-21d6-41dd-9740-b6163640266f">
        <updating/>
        <source>run(_isPrintPreview: Boolean; _isCSV: Boolean; _extraDetail: CM_ExtraDetail): Binary updating;
/*
	Purpose:			
	Parameters:			
	Return Value:		

Date			Who		Reason
22 July 2008	concms1	Par 17592 / 17593 initial creation
*/

vars

begin
	// we don't use the superclass methodto determine whether we have any data as all we really
	// need is a voyage
	
	app.printer.printPreview 	:= _isPrintPreview;
	self.myJRWVoyageSummary 	:= app.myQAFilter.allJRWTransients.first.CM_JRWVoyageSummary;
	
	if self.myJRWVoyageSummary.myVoyage = null then
		// if we don't have a voyage reference we can't go on
		self.setNoDataDisplay();
		app.printer.print(self.frmNoData);
		return null;
	endif;
	self.doLoad();
	
	return null;
epilog
	app.printer.close;
end;</source>
        <Parameter name="_isPrintPreview" type="Boolean"/>
        <Parameter name="_isCSV" type="Boolean"/>
        <Parameter name="_extraDetail" type="CM_ExtraDetail"/>
        <ReturnType type="Binary"/>
    </JadeMethod>
    <JadeMethod name="setNoDataDisplay" id="a6c38ce4-c91f-4c5f-8753-52a4eedbd7a3">
        <source>setNoDataDisplay();
/*	
	Purpose:		Print message in the event there is no data to display	
	Parameters:		n/a	
	Return Value:	n/a

Date			Who		Reason
22 July 2008	concms1	Par 17592 / 17593 Initial creation
*/

vars

begin
	self.lblNoData.caption := 'No Data To Display For Vessel Operations Report';
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setTableHeight" id="2f1a64e9-e239-4f96-a3ab-cc576951a1b9">
        <source>setTableHeight(_table :Table input)protected;
/*
	Purpose:		Set table height based on cumulative size o rows		
	Parameters:			
	Return Value:		

Date			Who		Reason
23 July 2008	concms1	Initial creation
*/

vars
	row, rows	:Integer;
	int			:Integer;
begin
	rows := _table.rows;
	
	foreach row in 1 to rows do
		int := int + _table.accessRow(row).height;
	endforeach;
	
	_table.height := int;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setupControls" id="c7afac3e-7fbd-4573-b13a-804a08a9efdf">
        <source>setupControls()protected;
/*
	Purpose:			
	Parameters:			
	Return Value:		

Date		Who		Reason
22 July 2008	concms1	Initial creation
*/

vars

begin
	self.tblReport.visible	:= true;
	self.frmTable.visible	:= true;
	
	self.frmTable.left 		:= 0;
	self.frmTable.width 	:= app.printer.pageWidth;
	
	self.tblReport.left 	:= 0;
	self.tblReport.width 	:= self.frmTable.clientWidth;	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupHeader" id="426d8ced-6871-41b9-9628-6e8a3cd54000">
        <source>setupHeader() protected;
/*
	Purpose:			
	Parameters:			
	Return Value:		

Date			Who		Reason
22 July 2008	concms1	Initial creation
*/

constants
	Gap = 5;
vars

begin
	self.frmHeader.height 	:= 145;
	self.frmHeader.width	:= app.printer.pageWidth;
	
	self.lblHeading1.autoSize	:= true;
	self.lblHeading1.fontSize 	:= 14;
	self.lblHeading1.alignment	:= Label.Alignment_Center_Middle;
	
	self.lblHeading1.centreHorizontallyInParent;
	
	self.lblHeading2.visible	:= false;
	
	self.lblPage.top 		:= self.lblPrinted.top;
	self.lblHeading3_1.top 	:= self.lblPrinted.top;
	self.lblHeading3_1.left := self.frmHeader.clientWidth - self.lblHeading3_1.width;
	self.lblPage.left		:= self.lblHeading3_1.left - self.lblPage.width;
	
	self.lblTerminalName.visible	:= true;
	self.lblReportId.visible 		:= true;
	self.lblReportExtra.visible		:= true;
	
	//term label
	self.lblTerminalName.fontSize := 8;
	self.lblTerminalName.caption := "Terminal:     " &amp; self.myJRWVoyageSummary.getTerminalString;
	self.lblTerminalName.top := self.lblHeading1.top + self.lblHeading1.height + Gap;
	self.lblTerminalName.left := self.picJadeLogo.left + self.picJadeLogo.width + Gap;
	self.lblTerminalName.height := 15;

	//user label
	self.lblReportId.fontSize := 8;
	self.lblReportId.caption := "User Code:   " &amp; process.userCode;
	self.lblReportId.top := self.lblTerminalName.top + self.lblTerminalName.height + Gap;
	self.lblReportId.left := self.picJadeLogo.left + self.picJadeLogo.width + Gap;
	self.lblReportId.height := 15;
	
	self.lblPrinted.top		:= self.picPortLogo.top + self.picPortLogo.height + Gap;
	self.lblPrintTime.top 	:= self.lblPrinted.top;
	self.lblPrintedDtl.top	:= self.lblPrinted.top;
	
	self.lblPrintTime.left	:= self.frmHeader.clientWidth - self.lblPrintTime.width;
	self.lblPrintedDtl.left := self.lblPrintTime.left - self.lblPrintedDtl.width;
	self.lblPrinted.left 	:= self.lblPrintedDtl.left - self.lblPrinted.width;
	
	self.picJadeLogo.picture := app.getPicLogoProduct;
	
	self.picPortLogo.picture 	:= app.getPicLogoPort;
	self.picPortLogo.left		:= self.frmHeader.clientWidth - self.picPortLogo.width;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupTable_Times" id="2453a341-87ce-4e4a-855a-0c0df5d506a7">
        <source>setupTable_Times()protected;
/*
	Purpose:		Populate times table (except for ship working crane time which 
					differs between internal and external reports)
	Parameters:			
	Return Value:		

Date		Who		Reason
01 August 2008	concms1	Initial creation
*/

vars
	row 	:Integer;
	tbl		:Table;
	voyage	:CM_Voyage;
begin
	tbl			:= self.tblReport;
	tbl.clear;
	tbl.rows 	:= 0;
	tbl.columns	:= 5;
		
	tbl.accessColumn(1).width 	:= 200;	tbl.accessColumn(1).alignment := Table.Alignment_Right;	tbl.accessedColumn.fontBold := true;
	tbl.accessColumn(2).width 	:= 120;	tbl.accessColumn(2).alignment := Table.Alignment_Left;	
	tbl.accessColumn(3).width 	:= 10;		
	tbl.accessColumn(4).width 	:= 200;	tbl.accessColumn(4).alignment := Table.Alignment_Right;	tbl.accessedColumn.fontBold := true;
	tbl.accessColumn(5).width 	:= tbl.width.Integer - 530;		tbl.accessColumn(5).alignment := Table.Alignment_Center;	
	
	voyage	:= self.getVoyage;
	
	row := tbl.addItem ("TIMES");
	tbl.accessCell (row, 1).mergeCells	:= Table.MergeCells_Merge; tbl.accessedCell.alignment := Table.Alignment_Left; tbl.accessedCell.fontBold := true;
	
	row := tbl.addItem ('Pilots Aboard' &amp; Tab &amp; voyage.pilotOnBoardDT.asStringJMT);
	row := tbl.addItem ('Berth Arrival' &amp; Tab &amp; voyage.arrivedDT.asStringJMT);
	row := tbl.addItem ('Labour Aboard' &amp; Tab &amp; voyage.labourOnBoard.asStringJMT);
	row := tbl.addItem ('Ship Exchange Started' &amp; Tab &amp; voyage.shipExchangeDate.asStringJMT);
	row := tbl.addItem ('Ship Exchange Completed' &amp; Tab &amp; voyage.shipExchangeCompleteDT.asStringJMT);
	row := tbl.addItem ('Labour Onshore' &amp; Tab &amp; voyage.labourOnShore.asStringJMT &amp; Tab &amp; Tab &amp; 'Ship Working Incl. Lashing' &amp; Tab &amp; '***');
	row := tbl.addItem ('Vessel Departed' &amp; Tab &amp; voyage.departedDT.asStringJMT &amp; Tab &amp; Tab &amp; 'Alongside Time' &amp; Tab &amp; voyage.getHoursAtBerth_HHMM);
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="updateArrayEntry" id="34aff978-febb-4c57-8cff-e97e73f83af3">
        <source>updateArrayEntry(_array :Array input; _index :Integer; _value :Decimal)protected;
/*
	Purpose:			
	Parameters:			
	Return Value:		

Date			Who		Reason
24 July 2008	concms1	Initial creation
*/

vars
	value	:Decimal [23, 8];
begin
	if _array.size &gt;= _index then
		if _array.isKindOf (DecimalArray) then
			value := _array.DecimalArray[_index];
		elseif _array.isKindOf (IntegerArray) then
			value := _array.IntegerArray[_index];
		endif;
	endif;
	
	value := value + _value;
	
	if _array.isKindOf (IntegerArray) then
		_array.IntegerArray[_index] := value.Integer;
	elseif _array.isKindOf (DecimalArray) then
		_array.DecimalArray[_index] := value;
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_array" type="Array" usage="input"/>
        <Parameter name="_index" type="Integer"/>
        <Parameter name="_value" type="Decimal"/>
    </JadeMethod>
</GUIClass>
