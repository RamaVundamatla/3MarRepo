    <JadeMethod name="buildNibbler_Bounce" id="f8dd101e-0a2e-4375-9d5a-a382666f0225">
        <source>buildNibbler_Bounce(): String;
/*
*/
begin
	return JSSCT_Nibbler_Bounce.String &amp; SEPARATOR;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="buildNibbler_Calling" id="3ab52c29-a793-4925-875e-b2ea564c2a55">
