    <JadeMethod name="getTerminals" id="6973ae09-95b5-4abf-83b4-e4ea4d2773c6">
        <source>getTerminals(_allTerminals : CM_TerminalSet input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 January 2025	jlier1	Initial creation 33694

*/

vars

	terminalCodes : StringArray;
	terminalCode : String;
	terminal : CM_Terminal;
begin
	if _allTerminals = null then
		return;
	endif;
	
	create terminalCodes transient;
	self.terminals.getTokensForDelimiter("|",terminalCodes);
	
	foreach terminalCode in terminalCodes do
		terminal:=app.myRoot.allTerminals[terminalCode.trimBlanks];		
		_allTerminals.tryAddIfNotNull(terminal);
	endforeach;
	
epilog
	delete terminalCodes;

end;</source>
        <Parameter name="_allTerminals" type="CM_TerminalSet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="loadDB" id="57bca03f-6e00-484b-95b0-9ee6e997f45c">
        <source>loadDB(_validateOnly: Boolean; _passport: CM_Passport input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 January 2025	jlier1	Initial creation 33694

*/

vars
	proxyDeliveryParty,
	realDeliveryParty: CM_DeliveryParty;
	address : CM_Address;
begin
	if self.messageMode = self.EDI_ACTION_ADD or self.messageMode = self.EDI_ACTION_UPDATE then
		proxyDeliveryParty:=self.createProxy();
		if self.messageMode = self.EDI_ACTION_ADD then
			proxyDeliveryParty.validateForCreate;
			foreach address in proxyDeliveryParty.allAddresses do	
				address.validateForCreate;
			endforeach;
			
		elseif self.messageMode = self.EDI_ACTION_UPDATE then
			proxyDeliveryParty.validateForUpdate;
			foreach address in proxyDeliveryParty.allAddresses do	
				address.validateForUpdate;
			endforeach;
		endif;
	elseif  self.messageMode = self.EDI_ACTION_DELETE  then
		realDeliveryParty:=app.myRoot.allDeliveryParties[self.code];
		realDeliveryParty.validateForDelete;
	endif;

	
	if _validateOnly then
		return;
	endif;
	
	if self.messageMode = self.EDI_ACTION_ADD then
		app.myUtilityCA.utlCreateDeliveryParty(proxyDeliveryParty, realDeliveryParty, _passport);
	elseif self.messageMode = self.EDI_ACTION_UPDATE then
	
		app.myUtilityUA.utlUpdateDeliveryParty(proxyDeliveryParty,_passport);
	elseif self.messageMode = self.EDI_ACTION_DELETE then
		
		app.myUtilityDA.utlDeleteDeliveryParty(realDeliveryParty,_passport);
	endif;
	
epilog
	delete proxyDeliveryParty;
end;</source>
        <Parameter name="_validateOnly" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="5f490b9c-c498-4b16-8079-f9c4ea512b8a">
        <updating/>
        <source>setForUpdate(_proxyEDITI: SelfType) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 January 2025	jlier1	Initial creation 33694

*/

vars

begin
	inheritMethod(_proxyEDITI);
	self.code :=_proxyEDITI.code;
	self.name:=_proxyEDITI.name;
	self.terminals:=_proxyEDITI.terminals;
epilog

end;</source>
        <Parameter name="_proxyEDITI" type="SelfType"/>
    </JadeMethod>
