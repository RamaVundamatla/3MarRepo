    <JadeMethod name="addNdlTestData" id="afe78252-93c1-4016-9018-1ee1b0224d36">
        <updating/>
        <source>addNdlTestData( voySummaryDict : CMIF_VoyageSummaryByValueDict input; doTotal : Boolean ) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
15 April 2010	cnwndl1	Initial creation

*/

vars

	int : Integer;
	
begin
	
	// only callable in development for testing
	
	executeWhen JMTDevelopmentEnvironment;
	
	// Imports
	
	self.numImportGen20 := self.numImportGen20 + 1;
	self.numImportGen30 := self.numImportGen30 + 2;
	self.numImportGen40 := self.numImportGen40 + 3;			
	self.numImportGen45 := self.numImportGen45 + 4;			
	self.numImportGen53 := self.numImportGen53 + 5;
	
	self.numImportReef20 := self.numImportReef20 + 6;
	self.numImportReef30 := self.numImportReef30 + 7;
	self.numImportReef40 := self.numImportReef40 + 8;			
	self.numImportReef45 := self.numImportReef45 + 9;			
	self.numImportReef53 := self.numImportReef53 + 10;
	
	self.numImportGenMT20 := self.numImportGenMT20 + 11;
	self.numImportGenMT30 := self.numImportGenMT30 + 12;
	self.numImportGenMT40 := self.numImportGenMT40 + 13;			
	self.numImportGenMT45 := self.numImportGenMT45 + 14;			
	self.numImportGenMT53 := self.numImportGenMT53 + 15;	
				
	self.numImportReefMT20 := self.numImportReefMT20 + 16;
	self.numImportReefMT30 := self.numImportReefMT30 + 17;
	self.numImportReefMT40 := self.numImportReefMT40 + 18;			
	self.numImportReefMT45 := self.numImportReefMT45 + 19;			
	self.numImportReefMT53 := self.numImportReefMT53 + 20;
	
	// Import Transships
	
	self.numImportTransGen20 := self.numImportTransGen20 + 21;
	self.numImportTransGen30 := self.numImportTransGen30 + 22;
	self.numImportTransGen40 := self.numImportTransGen40 + 23;			
	self.numImportTransGen45 := self.numImportTransGen45 + 24;			
	self.numImportTransGen53 := self.numImportTransGen53 + 25;
	
	self.numImportTransReef20 := self.numImportTransReef20 + 26;
	self.numImportTransReef30 := self.numImportTransReef30 + 27;
	self.numImportTransReef40 := self.numImportTransReef40 + 28;			
	self.numImportTransReef45 := self.numImportTransReef45 + 29;			
	self.numImportTransReef53 := self.numImportTransReef53 + 30;
	
	self.numImportTransMT20 := self.numImportTransMT20 + 31;
	self.numImportTransMT30 := self.numImportTransMT30 + 32;
	self.numImportTransMT40 := self.numImportTransMT40 + 33;			
	self.numImportTransMT45 := self.numImportTransMT45 + 34;			
	self.numImportTransMT53 := self.numImportTransMT53 + 35;	
	
	self.numImportTransMTReef20 := self.numImportTransMTReef20 + 36;
	self.numImportTransMTReef30 := self.numImportTransMTReef30 + 37;
	self.numImportTransMTReef40 := self.numImportTransMTReef40 + 38;			
	self.numImportTransMTReef45 := self.numImportTransMTReef45 + 39;			
	self.numImportTransMTReef53 := self.numImportTransMTReef53 + 40;	
			
	// Exports
	
	self.numExportGen20 := self.numExportGen20 + 41;
	self.numExportGen30 := self.numExportGen30 + 42;
	self.numExportGen40 := self.numExportGen40 + 43;			
	self.numExportGen45 := self.numExportGen45 + 44;			
	self.numExportGen53 := self.numExportGen53 + 45;	
	
	self.numExportReef20 := self.numExportReef20 + 46;
	self.numExportReef30 := self.numExportReef30 + 47;
	self.numExportReef40 := self.numExportReef40 + 48;			
	self.numExportReef45 := self.numExportReef45 + 49;			
	self.numExportReef53 := self.numExportReef53 + 50;
	
	self.numExportMT20 := self.numExportMT20 + 51;
	self.numExportMT30 := self.numExportMT30 + 52;
	self.numExportMT40 := self.numExportMT40 + 53;			
	self.numExportMT45 := self.numExportMT45 + 54;			
	self.numExportMT53 := self.numExportMT53 + 55;			
	
	self.numExportMTReef20 := self.numExportMTReef20 + 56;
	self.numExportMTReef30 := self.numExportMTReef30 + 57;
	self.numExportMTReef40 := self.numExportMTReef40 + 58;			
	self.numExportMTReef45 := self.numExportMTReef45 + 59;			
	self.numExportMTReef53 := self.numExportMTReef53 + 60;			
	
	// Export Tranships			
	
	self.numExportTransGen20 := self.numExportTransGen20 + 61;
	self.numExportTransGen30 := self.numExportTransGen30 + 62;
	self.numExportTransGen40 := self.numExportTransGen40 + 63;			
	self.numExportTransGen45 := self.numExportTransGen45 + 64;			
	self.numExportTransGen53 := self.numExportTransGen53 + 65;
	
	self.numExportTransReef20 := self.numExportTransReef20 + 66;
	self.numExportTransReef30 := self.numExportTransReef30 + 67;
	self.numExportTransReef40 := self.numExportTransReef40 + 68;			
	self.numExportTransReef45 := self.numExportTransReef45 + 69;			
	self.numExportTransReef53 := self.numExportTransReef53 + 70;		
	
	self.numExportTransMT20 := self.numExportTransMT20 + 71;
	self.numExportTransMT30 := self.numExportTransMT30 + 72;
	self.numExportTransMT40 := self.numExportTransMT40 + 73;			
	self.numExportTransMT45 := self.numExportTransMT45 + 74;			
	self.numExportTransMT53 := self.numExportTransMT53 + 75;			
	
	self.numExportTransMTReef20 := self.numExportTransMTReef20 + 76;
	self.numExportTransMTReef30 := self.numExportTransMTReef30 + 77;
	self.numExportTransMTReef40 := self.numExportTransMTReef40 + 78;			
	self.numExportTransMTReef45 := self.numExportTransMTReef45 + 79;			
	self.numExportTransMTReef53 := self.numExportTransMTReef53 + 80;			
	
	// restows
	
	self.numDLRGen20 := self.numDLRGen20 + 81;
	self.numDLRGen30 := self.numDLRGen30 + 82;
	self.numDLRGen40 := self.numDLRGen40 + 83;			
	self.numDLRGen45 := self.numDLRGen45 + 84;			
	self.numDLRGen53 := self.numDLRGen53 + 85;
				
	self.numDLRReef20 := self.numDLRReef20 + 86;
	self.numDLRReef30 := self.numDLRReef30 + 87;
	self.numDLRReef40 := self.numDLRReef40 + 88;			
	self.numDLRReef45 := self.numDLRReef45 + 89;			
	self.numDLRReef53 := self.numDLRReef53 + 90;	
	
	self.numDLRMT20 := self.numDLRMT20 + 91;
	self.numDLRMT30 := self.numDLRMT30 + 92;
	self.numDLRMT40 := self.numDLRMT40 + 93;			
	self.numDLRMT45 := self.numDLRMT45 + 94;			
	self.numDLRMT53 := self.numDLRMT53 + 95;			
	
	self.numDLRMTReef20 := self.numDLRMTReef20 + 96;
	self.numDLRMTReef30 := self.numDLRMTReef30 + 97;
	self.numDLRMTReef40 := self.numDLRMTReef40 + 98;			
	self.numDLRMTReef45 := self.numDLRMTReef45 + 99;			
	self.numDLRMTReef53 := self.numDLRMTReef53 + 100;			
	
	// shifts on board
	
	self.numSOBGen20 := self.numSOBGen20 + 101;
	self.numSOBGen30 := self.numSOBGen30 + 102;
	self.numSOBGen40 := self.numSOBGen40 + 103;			
	self.numSOBGen45 := self.numSOBGen45 + 104;			
	self.numSOBGen53 := self.numSOBGen53 + 105;	
	
	self.numSOBReef20 := self.numSOBReef20 + 106;
	self.numSOBReef30 := self.numSOBReef30 + 107;
	self.numSOBReef40 := self.numSOBReef40 + 108;			
	self.numSOBReef45 := self.numSOBReef45 + 109;			
	self.numSOBReef53 := self.numSOBReef53 + 110;	
	
	self.numSOBMT20 := self.numSOBMT20 + 111;
	self.numSOBMT30 := self.numSOBMT30 + 112;
	self.numSOBMT40 := self.numSOBMT40 + 113;			
	self.numSOBMT45 := self.numSOBMT45 + 114;			
	self.numSOBMT53 := self.numSOBMT53 + 115;			
	
	self.numSOBMTReef20 := self.numSOBMTReef20 + 116;
	self.numSOBMTReef30 := self.numSOBMTReef30 + 117;
	self.numSOBMTReef40 := self.numSOBMTReef40 + 118;			
	self.numSOBMTReef45 := self.numSOBMTReef45 + 119;			
	self.numSOBMTReef53 := self.numSOBMTReef53 + 120;	
	
	foreach int in 1 to 120 do
		self.total := self.total + int;
	endforeach;
	
	if doTotal and voySummaryDict &lt;&gt; null then
		voySummaryDict[CMQF_VoyageExchangeSummary.TOTALS_ID, null].addNdlTestData( null, false );
	endif;
	
	endExecuteWhen;
	
		
			
epilog

end;</source>
        <Parameter name="voySummaryDict" type="CMIF_VoyageSummaryByValueDict" usage="input"/>
        <Parameter name="doTotal" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getSummaryDescriptionLine" id="a2427155-6b7c-43c0-87f3-922ef31a15ca">
        <source>getSummaryDescriptionLine() : String;
// ---------------------------------------------------------------------------
// Created:     10 September 2004	cnwth2
//
// Purpose:     Used for exchange summary report CCMS#1273 -
// ----------   ----------  --------------------------------------------------
vars
	str			: String;
begin
	if self.numOverdimension20 &lt;&gt; null then
		str := str &amp; self.numOverdimension20.String &amp; ' x 20ft Overdimension';
	endif;
	
	//14 Apr 2010 NDL Par 23048
	if self.numOverdimension30 &lt;&gt; null then
		if str &lt;&gt; null then
			str := str &amp; ', ';
		endif;
		str := str &amp; self.numOverdimension30.String &amp; ' x 30ft Overdimension';
	endif;
	
	if self.numOverdimension40 &lt;&gt; null then
		if str &lt;&gt; null then
			str := str &amp; ', ';
		endif;
		str := str &amp; self.numOverdimension40.String &amp; ' x 40ft Overdimension';
	endif;
	
	//14 Apr 2010 NDL Par 23048
	if self.numOverdimension45 &lt;&gt; null then
		if str &lt;&gt; null then
			str := str &amp; ', ';
		endif;
		str := str &amp; self.numOverdimension45.String &amp; ' x 45ft Overdimension';
	endif;
	
	//14 Apr 2010 NDL Par 23048
	if self.numOverdimension53 &lt;&gt; null then
		if str &lt;&gt; null then
			str := str &amp; ', ';
		endif;
		str := str &amp; self.numOverdimension53.String &amp; ' x 53ft Overdimension';
	endif;
	
	if self.numHazardous20 &lt;&gt; null then
		if str &lt;&gt; null then
			str := str &amp; ', ';
		endif;
		str := str &amp; self.numHazardous20.String &amp; ' x 20ft Hazardous';
	endif;
	
	//14 Apr 2010 NDL Par 23048
	if self.numHazardous30 &lt;&gt; null then
		if str &lt;&gt; null then
			str := str &amp; ', ';
		endif;
		str := str &amp; self.numHazardous30.String &amp; ' x 30ft Hazardous';
	endif;
	
	if self.numHazardous40 &lt;&gt; null then
		if str &lt;&gt; null then
			str := str &amp; ', ';
		endif;
		str := str &amp; self.numHazardous40.String &amp; ' x 40ft Hazardous';
	endif;
	
	//14 Apr 2010 NDL Par 23048
	if self.numHazardous45 &lt;&gt; null then
		if str &lt;&gt; null then
			str := str &amp; ', ';
		endif;
		str := str &amp; self.numHazardous45.String &amp; ' x 45ft Hazardous';
	endif;
	
	//14 Apr 2010 NDL Par 23048
	if self.numHazardous53 &lt;&gt; null then
		if str &lt;&gt; null then
			str := str &amp; ', ';
		endif;
		str := str &amp; self.numHazardous53.String &amp; ' x 53ft Hazardous';
	endif;
	
	if self.numBreakBulk &lt;&gt; null then
		if str &lt;&gt; null then
			str := str &amp; ', ';
		endif;
		str := str &amp; self.numBreakBulk.String &amp; ' x Break Bulk';
	endif;
	
	if self.numTimber &lt;&gt; null then
		if str &lt;&gt; null then
			str := str &amp; ', ';
		endif;
		str := str &amp; self.numTimber.String &amp; ' x Timber';
	endif;
	
	return str;
	
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTerminal" id="04663dbd-fa57-433a-8dec-6446a136c736">
        <source>getTerminal():CM_Terminal;
/*
Date		Who		Reason
27 Nov 2012	cnwcs5	Initial creation - par 30816
*/
vars
	voyage		:CM_Voyage;
	terminal	:CM_Terminal;
begin
	voyage	:= self.myVoyage;
	
	if voyage &lt;&gt; null then
		terminal := voyage.myTerminal;
	endif;
	
	return terminal;
epilog

end;</source>
        <ReturnType type="CM_Terminal"/>
    </JadeMethod>
