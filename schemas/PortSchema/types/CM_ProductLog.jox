    <JadeMethod name="logLength" id="10506b70-5a38-4718-97fb-fef358301ec0">
        <methodInvocation>mapping</methodInvocation>
        <source>logLength(set: Boolean; _value: Decimal io) mapping;
// ---------------------------------------------------------------------------
// Created:     25 October 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if set then
		app.raiseSetVirtualError(class.name, method.name);
		return;
	endif;
	
	// Once all changes for CM_Products are done then should
	// use the length on CM_Product and remove this virtual
	// NOTE:  Log Lengths are in metres

	if self.myLogLength &lt;&gt; null then
		_value := self.myLogLength.code.Decimal;
	endif;

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Decimal" usage="io"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="952de4bb-7705-4505-b39d-160bf390a31a">
        <source>pxyCreateUpdateProxy(): SelfType;
// ---------------------------------------------------------------------------
// Created:     13 June 2002 by cnwth2
// ---------------------------------------------------------------------------
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy

vars
	proxy : CM_ProductLog;
	completedOK		: Boolean;
	
begin

	proxy := inheritMethod();

	proxy.myLogGrade		:= self.myLogGrade;
	proxy.myLogLength		:= self.myLogLength;
	proxy.myLogSpecies		:= self.myLogSpecies;
	proxy.myLogTreatment	:= self.myLogTreatment;
	proxy.myLogType			:= self.myLogType;
	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return proxy;

epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete proxy;
	endif;	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="47c9ba75-600c-4be2-8631-2543ceed32d9">
        <updating/>
        <source>setForCreate(_proxy: CM_ProductLog) updating;
// ---------------------------------------------------------------------------
// Created:     20 April 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	inheritMethod(_proxy);

	self.myLogSpecies	:= _proxy.myLogSpecies;
	self.myLogGrade		:= _proxy.myLogGrade;
	self.myLogType		:= _proxy.myLogType;
	self.myLogTreatment	:= _proxy.myLogTreatment;
	self.myLogLength	:= _proxy.myLogLength;
	
end;</source>
        <Parameter name="_proxy" type="CM_ProductLog"/>
    </JadeMethod>
    <JadeMethod name="setProxyLogProduct" id="33dc0e2a-90a5-446f-a5fa-a569b3d88e48">
        <updating/>
        <source>setProxyLogProduct(_code 			: String; 
					_operator 		: CM_Operator; 
					_species 		: CM_LogSpecies; 
					_grade 			: CM_LogGrade; 
				   	_type 			: CM_LogType; 
				   	_treatment 		: CM_LogTreatment; 
				   	_length 		: CM_LogLength) updating;
// ---------------------------------------------------------------------------
// Created:     20 April 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 30/11/2009	cnwdap1		CCMS 1007 - new paramaters for setProxy
// ---------------------------------------------------------------------------
vars
	theCargoType	: CM_CargoType;
	handlingTypeLog	: CM_HandlingType;
	
begin
	handlingTypeLog	:=	app.myRoot.allHandlingTypes[TI_HandlingType_Log];
	theCargoType	:=	app.myRoot.allCargoTypesById[TI_CargoType_Log].CM_CargoType;
	
	self.setProxy(theCargoType,
					_operator,
					null,
					null,
					handlingTypeLog,
					null,		//31 Mar 2017	NDL	TFS 3414
					null,
					_code,
					null,
					null,
					false,
					false,
					false,
					false,
					false,
					false,
					false	//18 Jan 2018	NDL	TFS 36697
					);

	self.myLogSpecies	:= _species;
	self.myLogGrade		:= _grade;
	self.myLogType		:= _type;
	self.myLogTreatment	:= _treatment;
	self.myLogLength	:= _length;
end;</source>
        <Parameter name="_code" type="String"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_species" type="CM_LogSpecies"/>
        <Parameter name="_grade" type="CM_LogGrade"/>
        <Parameter name="_type" type="CM_LogType"/>
        <Parameter name="_treatment" type="CM_LogTreatment"/>
        <Parameter name="_length" type="CM_LogLength"/>
    </JadeMethod>
    <JadeMethod name="setProxyLogProductFromCodes" id="b51dd02d-e5ce-4747-a485-cb1c9f0abf86">
        <updating/>
        <source>setProxyLogProductFromCodes(_code : String; 
					_operator 	: CM_Operator;
					_speciesCode,
					_gradeCode,
				   	_typeCode,
				   	_treatmentCode,
				   	_lengthCode	: String;
				   	_passport : CM_Passport input;
				   	guiObject : Object) updating;
// ---------------------------------------------------------------------------
// Created:     20 April 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 30/11/2009	cnwdap1		CCMS 1007 - new parameters for setProxy
// 15/102/104	cnwdap1		PAR #35077 Cater for situation where log length of 5.60 is in file, 
//							but should match against 5.6 stored in JMT
// ---------------------------------------------------------------------------
vars
	theCargoType	: CM_CargoType;
	handlingTypeLog	: CM_HandlingType;
	tmpLogSpecies	: CM_LogSpecies;
	tmpLogGrade		: CM_LogGrade;
	tmpStr			: String;
	length			: String;					// PAR #35077
	changedLength	: Boolean;					// PAR #35077
	ediBOLOutLogTI	: CM_EDIBOLOutLogTI;		// PAR #35077
	
begin
	handlingTypeLog := app.myRoot.allHandlingTypes[TI_HandlingType_Log];
	theCargoType := app.myRoot.allCargoTypesById[TI_CargoType_Log].CM_CargoType;
	
	self.setProxy(theCargoType, 
					_operator,
					null,
					null,
					handlingTypeLog, 
					null, 	//31 Mar 2017	NDL	TFS 3414
					null, 
					_code, 
					null,
					null,
					false,		// CCMS 1007
					false,		// CCMS 1007
					false,		// CCMS 1007
					false,false,false,false);		// CCMS 1007

	if _operator = null then
		tmpStr := app.getTerminologyAlternate(null, _passport.myTerminal, CM_TerminologyOperator, CM_TermExpressionSingular, 'Operator');
	//	app.raiseCMException1(REQUIRED_FIELD, tmpStr, 'operator', guiObject);
		app.raiseCMException1(Input_required_field_Required, tmpStr, 'operator', guiObject);

		return;
	endif;

	if _speciesCode = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'species', 'species', guiObject);
		app.raiseCMException(Input_required_field_species, 'species', guiObject); // cnwdb2	PAR 35364
	endif;

	if _gradeCode = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'grade', 'grade', guiObject);
		app.raiseCMException(Input_required_field_grade, 'grade', guiObject); // cnwdb2	PAR 35364
	endif;

	if _lengthCode = null then
//		app.raiseCMException1(REQUIRED_FIELD, 'length', 'length', guiObject);
		app.raiseCMException(Input_required_field_length, 'length', guiObject); // cnwdb2	PAR 35364
	endif;

	if _passport.hasErrors then
		return;
	endif;
	
	tmpLogSpecies	:= _operator.getLogSpecies(_speciesCode);
	if tmpLogSpecies = null then
		app.raiseCMException2(ERR_FIELD_SPECIES_CODE, _speciesCode, 'Species code', 'speciesCode', guiObject);
		return;
	endif;
	
	self.myLogSpecies	:= tmpLogSpecies;

	tmpLogGrade			:= tmpLogSpecies.allLogGrades[_gradeCode].CM_LogGrade;
	if tmpLogGrade = null then
		app.raiseCMException2(ERR_FIELD_GRADE, _gradeCode, 'Grade code', 'gradeCode', guiObject);
		return;
	endif;

	self.myLogGrade	:= tmpLogGrade;
	
	self.myLogType		:= tmpLogGrade.allLogTypes[_typeCode];
	if _typeCode &lt;&gt; null and self.myLogType = null then
		app.raiseCMException2(ERR_FIELD_TYPE, _typeCode, 'type code', 'typeCode', guiObject);
	endif;

	self.myLogTreatment	:= tmpLogGrade.allLogTreatments[_treatmentCode];
	if _treatmentCode &lt;&gt; null and self.myLogTreatment = null then
		app.raiseCMException2(ERR_FIELD_TREATMENT, _treatmentCode, 'treatment code', 'treatmentCode', guiObject);
	endif;

	self.myLogLength	:= tmpLogGrade.allLogLengths[_lengthCode];
	if _lengthCode &lt;&gt; null and self.myLogLength = null then
		// try again with a zero on the end, if length code has two characters after the decimal place		// PAR #35077
		if _lengthCode.length - _lengthCode.pos(".", 1) = 2 then											// PAR #35077
			length := _lengthCode[1:_lengthCode.length-1];													// PAR #35077
			self.myLogLength := tmpLogGrade.allLogLengths[length];											// PAR #35077
			if self.myLogLength = null then																	// PAR #35077
				app.raiseCMException2(ERR_FIELD_LENGTH, _lengthCode, 'length code', 'lengthCode', guiObject);
			else																							// PAR #35077
				changedLength := true;																		// PAR #35077
			endif;																							// PAR #35077
		endif;																								// PAR #35077
		if changedLength then																				// PAR #35077
			// have to update self.logLength and self.speciesCode											// PAR #35077
			self.code := self.speciesCode &amp; ":" &amp; self.gradeCode &amp; ":" &amp; self.typeCode &amp; ":" &amp;				// PAR #35077
							self.treatmentCode &amp; ":" &amp; length;												// PAR #35077
			ediBOLOutLogTI := guiObject.CM_EDIBOLOutLogTI;													// PAR #35077
			ediBOLOutLogTI.setPropertyValue(CM_EDIBOLOutLogTI::productCode.name, self.code);				// PAR #35077
			ediBOLOutLogTI.setPropertyValue(CM_EDIBOLOutLogTI::logLengthCode.name, length);					// PAR #35077
		endif;																								// PAR #35077
	endif;

	// Check if type/treatment are required
	if tmpLogGrade.allLogTreatments.size &gt; 0 then
		if _treatmentCode = null then
		//	app.raiseCMException1(REQUIRED_FIELD, 'Log Treatment', ETRow_LogTreatmentCode, guiObject);
			app.raiseCMException(Input_required_field_logTreat, ETRow_LogTreatmentCode, guiObject); // cnwdb2	PAR 35364
		endif;	
	endif;
	
	if tmpLogGrade.allLogTypes.size &gt; 0 then
		if _typeCode = null then
//			app.raiseCMException1(REQUIRED_FIELD, 'Log Type', ETRow_LogTypeCode, guiObject);
			app.raiseCMException(Input_required_field_logType, ETRow_LogTypeCode, guiObject); // cnwdb2	PAR 35364
		endif;	
	endif;

end;</source>
        <Parameter name="_code" type="String"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_speciesCode" type="String"/>
        <Parameter name="_gradeCode" type="String"/>
        <Parameter name="_typeCode" type="String"/>
        <Parameter name="_treatmentCode" type="String"/>
        <Parameter name="_lengthCode" type="String"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <Parameter name="guiObject" type="Object"/>
    </JadeMethod>
