    <JadeMethod name="getDateTime" id="bce85253-5b17-497b-b7cb-3644c5fb5ffa">
        <source>getDateTime() : TimeStamp;

begin
	if transaction = null then
		return null;
	endif;
	return transaction.dateTime;
end;</source>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="getDateTimeLocalTZ" id="98ed09b3-626b-405c-bdc4-35fcb359f47f">
        <source>getDateTimeLocalTZ():TimeStamp;
/*

Purpose:			Return the local timezone version of the receiver's dateTime (for JRW)

Parameters:			None

Return Value:		

Date		Who		Reason
19 May 2016	cnwns1	TFS 488 - Multi Timezone Support

*/

vars

begin
	
	if self.transaction = null then
		return null;
	endif;
	
	return self.systemToLocalTime(self.transaction.dateTime);
epilog

end;</source>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="63c5e238-aefc-4ec9-adbf-3bf125798f75">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
// ---------------------------------------------------------------------------
// Created:		March 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
19 May 2010	cnwkpd1	PAR #20728 - remove isValidObject calls for performance
07/03/2011	cnwmh5	PAR #27142 - Change to use local variable rather than self for handleDeletedObject
*/

vars
	invalid			: Boolean;
	returnVal		: String;
	ti				: CM_TrackedItem;
	tiTxn			: CM_TITransaction;
	tiTxnTS			: TimeStamp;
	
begin
	if _attrName = ETRow_SequenceNum  then
		return self.sequenceNum.String;	
	elseif _attrName = ETRow_Description  then
		return self.getDetails();	
	elseif _attrName = ETRow_User  then
		tiTxn := self.transaction;				// 07/03/2011 cnwmh5 #27142
		if tiTxn = null then
			return null;
		else
			on Exception do app.handleDeletedObject(exception, tiTxn, invalid);
			returnVal :=  tiTxn.userId;
			return returnVal;
		endif;
	elseif _attrName = ETRow_EndDate  then
		tiTxn := self.transaction;					// 07/03/2011 cnwmh5 #27142
		if tiTxn = null then 
			return null;
		else
			on Exception do app.handleDeletedObject(exception, tiTxn, invalid);
			tiTxnTS := self.systemToLocalTime(tiTxn.dateTime);
			returnVal := tiTxnTS.date.shortFormat() &amp; " " &amp; tiTxnTS.time.currentLocaleFormatJMT();	// 5/5/16 cnwmp6 TFS 488 - Multi timezone support
			return returnVal;
		endif;
	elseif _attrName = ETRow_Ti  then
		ti := self.getTrackedItem();
		if ti &lt;&gt; null then 
			return ti.id;
		else
			return null;	
		endif;
	else
		return inheritMethod(_attrName, _short);
	endif;


end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getPropertyCol" id="1d8ce52c-a79f-4c7b-8d9b-8335741bcca5">
        <source>getPropertyCol(): String;

/*

Date		Who		Reason
19 May 2010	cnwkpd1	PAR #20728 - remove isValidObject calls for performance
07/03/2011	cnwmh5	PAR #27142 - Change to local variable rather than self for handleDeleteObject exception
*/

vars
	temp,
	str 			: String;
	invalid			: Boolean;
	tiTransaction	: CM_TITransaction;
	ti				: CM_TrackedItem;
	
begin
	str := sequenceNum.String &amp; Tab;
	str := str &amp; getDetails &amp; Tab;
	tiTransaction := self.transaction;				// 07/03/2011 cnwmh5 #27142
	if tiTransaction = null then
		str := str &amp; Tab &amp; Tab;
	else
		on Exception do app.handleDeletedObject(exception, tiTransaction, invalid);
		temp := null;
		temp := tiTransaction.userId;
		str := str &amp; temp &amp; Tab;
		temp := null;
		temp := tiTransaction.dateTime.date.shortFormatJMT() &amp; " " &amp; tiTransaction.dateTime.time.currentLocaleFormatJMT();
		str := str &amp; temp &amp; Tab;
		on Exception do null;
	endif;

	ti := self.trackedItem;							// 07/03/2011 cnwmh5 #27142
	if ti &lt;&gt; null then
		on Exception do app.handleDeletedObject(exception, ti, invalid);
		str := str &amp; ti.id;
	endif;

	return str;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTrackedItem" id="cc8bb298-b6c4-466f-be8b-2416c4b0868c">
        <source>getTrackedItem() : CM_TrackedItem;

/*

Date		Who		Reason
19 May 2010	cnwkpd1	PAR #20728 - remove isValidObject calls for performance
07/03/2011	cnwmh5	PAR #27142 - Change to local variable rather than self for handleDeleteObject exception
*/

vars
	invalidTI		: Boolean;
	id				: String;
	ti				: CM_TrackedItem;
begin

	ti	:= self.trackedItem;				// 07/03/2011 cnwmh5 #27142
	if ti &lt;&gt; null then
		on Exception do app.handleDeletedObject(exception, ti, invalidTI);
		// Dereference TI to check it is valid
		id := ti.id;
	endif;
	
	if invalidTI then
		return null;
	else
		return ti;
	endif;

end;</source>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="getTypeDescription" id="a1826a96-a980-497a-8b8c-5f1393875f50">
        <source>getTypeDescription(): String;

begin
	return "Error With Transaction";
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getUserId" id="2a87288d-0464-4c62-8a9f-61f989aa77be">
        <source>getUserId() : String;

begin
	if transaction = null then
		return "";
	endif;
	return transaction.userId;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setInvalidReference" id="b2d5da3f-8a2f-49e6-b7da-67cf4316bc30">
        <updating/>
        <source>setInvalidReference(_pName: String; _fixit: Boolean) updating;//serverExecution;
// cnwrs1 mar 2006
// ----------   ----------  --------------------------------------------------
// 03 Mar 2008	conks1a		PAR #16047 - remove unnecessary serverExecution for performance
// ---------------------------------------------------------------------------
vars

begin
	if not _pName = CM_AuditOfError::trackedItem.name then
		inheritMethod(_pName, _fixit);
	endif;
end;</source>
        <Parameter name="_pName" type="String"/>
        <Parameter name="_fixit" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setTrackedItem" id="23770f34-de8c-4edf-a5d8-e3479e3e74ed">
        <updating/>
        <source>setTrackedItem(_ti : CM_TrackedItem) updating;
// ---------------------------------------------------------------------------
// Created:     Mar 2006 cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	self.trackedItem := _ti;

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="setTransaction" id="05d4c6ee-4e14-4c76-ba49-87ca4eb857c7">
        <updating/>
        <source>setTransaction(_trans: CM_TITransaction) updating;
//----------------------------------------------------------------
//	Created:	mar 2006 cnwrs1
//----------------------------------------------------------------
vars

begin
	self.transaction := _trans;
end;</source>
        <Parameter name="_trans" type="CM_TITransaction"/>
    </JadeMethod>
