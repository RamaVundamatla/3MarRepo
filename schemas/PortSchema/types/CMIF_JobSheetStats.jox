    </JadeMethod>
    <JadeMethod name="setGraphPoints" id="0ae4607c-9248-4e2b-aeaf-705259e9411f">
        <updating/>
        <source>setGraphPoints() updating, protected;
// ---------------------------------------------------------------------------
// Created:     25 May 2005 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	lastWLE	: TimeStamp;
	aWLE					: CM_WorkListEntry;
	theX, theY, tmpX, tmpY	: Integer;
	numMinsSinceLastWLE,
	totalMins, idx, theRate	: Integer;
	tmpPoint	: Point;
begin

	self.allGraphPoints.purge;

	idx := 0;
	lastWLE := null;
	totalMins := 0;
	numMinsSinceLastWLE := null;
	theRate := 0;

	foreach aWLE in self.myJobSheet.allCompletedWLEsByDate discreteLock do
		if aWLE.completedDate = null then
			continue;
		endif;
		idx := idx + 1;
		theX := idx;
		
		if lastWLE.isValid then
			numMinsSinceLastWLE := lastWLE.cnMinutesDifference(aWLE.completedDate);
		else
			if self.workStarted.cnEcIsLessThanOrEqual(aWLE.completedDate) then
				numMinsSinceLastWLE := self.workStarted.cnMinutesDifference(aWLE.completedDate);
			else
				numMinsSinceLastWLE := 10;
			endif;
		endif;
		
		lastWLE := aWLE.completedDate;

		if numMinsSinceLastWLE &gt; 10 then
			numMinsSinceLastWLE := 10;
		endif;
	
		totalMins := totalMins + numMinsSinceLastWLE;

		if totalMins &gt; 0 then
			theRate := (idx/(totalMins/60)).Integer;
		else
			theRate := idx;
		endif;
		
		theY := (theRate * 2).Integer;
		
		tmpPoint.setX(theX);
		tmpPoint.setY(theY);
		
		self.allGraphPoints.add(tmpPoint);

	endforeach;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setGraphPointsFromTransactions" id="765b5c5e-76bc-4c5a-8b6d-8a5c72e86ee2">
        <updating/>
        <source>setGraphPointsFromTransactions() updating;
// ---------------------------------------------------------------------------
// Created:     25 May 2005 by cnwrs2
//
// Purpose:      // PAR 36118
// ---------------------------------------------------------------------------
vars
	lastWLE	: TimeStamp;
	atran					: CM_TITransaction;
	theX, theY, tmpX, tmpY	: Integer;
	numMinsSinceLastWLE,
	totalMins, idx, theRate	: Integer;
	tmpPoint	: Point;
	crane : String;
begin

	self.allGraphPoints.purge;

	idx := 0;
	lastWLE := null;
	totalMins := 0;
	numMinsSinceLastWLE := null;
	theRate := 0;

	foreach atran in self.myVoyageStats.myVoyage.allTITransactionsByDTType discreteLock do
		if atran.dateTime = null then
			continue;
		endif;
		
		crane := "";
		if  atran.isKindOf(CM_ReleaseShip) then
			crane := atran.CM_ReleaseShip.craneID;
		elseif atran.isKindOf(CM_ReceiveShip) then
			crane := atran.CM_ReceiveShip.craneID;
		else
			continue;
		endif;
		
		if crane = "" then
			continue;
		endif;
		if self.description.pos(crane, 1) &lt;= 0 then
			continue;
		endif;
		
		idx := idx + 1;
		theX := idx;
		
		if lastWLE.isValid then
			numMinsSinceLastWLE := lastWLE.cnMinutesDifference(atran.dateTime);
		else
			if self.workStarted.cnEcIsLessThanOrEqual(atran.dateTime) then
				numMinsSinceLastWLE := self.workStarted.cnMinutesDifference(atran.dateTime);
			else
				numMinsSinceLastWLE := 10;
			endif;
		endif;
		
		lastWLE := atran.dateTime;

		if numMinsSinceLastWLE &gt; 10 then
			numMinsSinceLastWLE := 10;
		endif;
	
		totalMins := totalMins + numMinsSinceLastWLE;

		if totalMins &gt; 0 then
			theRate := (idx/(totalMins/60)).Integer;
		else
			theRate := idx;
		endif;
		
		theY := (theRate * 2).Integer;
		
		tmpPoint.setX(theX);
		tmpPoint.setY(theY);
		
		self.allGraphPoints.add(tmpPoint);

	endforeach;
	
end;</source>
    </JadeMethod>
