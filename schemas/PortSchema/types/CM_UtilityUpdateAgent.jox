    </JadeMethod>
    <JadeMethod name="utlUpdateTIAndExtraInfo" id="2cad22cf-4e63-44aa-a6ea-8e1757aef106">
        <updating/>
        <source>utlUpdateTIAndExtraInfo(_pxyTI 					: CM_TrackedItem input;
					 	_updateMode 			: Integer;
						_extraParams			: CMIF_TIUpdateExtraParams;
					 	_txnControllerDict 		: CMIF_TITxnContrlrByTypeDTDict;
						_comment				: String;
					 	_passport 				: CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     12 September 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
// Changed On 	By			Reason
// ----------	--------	--------------------------------------------------
// 12/05/2010	cnwdap1		CCMS 1116 Tranship changes
// 10/11/2022	navkc1		Bug 55382: MTN - Cargo Group Details recalculated after each change to TI when bulk editing
vars
	realTI				: CM_TrackedItem;
	expectedEdition			: Integer;
	cargoGroupSiteTrxAction  : CMIF_TrxActionCargoGroup;	//TFS 53390
	completeToDoTask : CM_ToDoTaskDesc;
	completeTrx : CM_TITransaction;
	allResourceTypes : CM_ResourceTypeUsageSet;
begin
	_pxyTI.pxyGetRealObjectAndEdition(realTI, expectedEdition);
	
	if realTI = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_TrackedItem.name, null, null);
		return;
	endif;
		
	self.utlUpdateTrackedItem(_pxyTI, _comment , _updateMode, _txnControllerDict,_extraParams, null, _passport); //cnwrd1 28.8.09 par 20545
	
	if (not _passport.noErrors) then
		return;
	endif;
	
	if _extraParams.hasEditedToDoTasks then
		self.utlUpdateTIToDoTasks(_extraParams.allTasksToAdd, _extraParams.allTasksToComplete, _extraParams.allTasksToRemove, realTI, _passport);
		//jlier1 TFS 54703 28/9/22
		allResourceTypes:=_extraParams.allPxyResourceUsages;
		if _extraParams.allTasksToComplete.size = 1 and allResourceTypes &lt;&gt; null and  allResourceTypes.first &lt;&gt; null then
			completeToDoTask:=app.myRoot.allToDoTaskDescriptions[_extraParams.allTasksToComplete.first];
			if completeToDoTask &lt;&gt; null  then
				if completeToDoTask.trxTypeOnCompletion &lt;&gt; 0 then
					completeTrx:=realTI.getLastTransOfType(completeToDoTask.trxTypeOnCompletion);
				else
					completeTrx:=realTI.getLastTransOfType(TRANS_TYPE_TASKCOMPLETE);
				endif;
				if completeTrx &lt;&gt; null then					
					completeTrx.addResourcesFromProxys(allResourceTypes);					
				endif;
			endif;
		endif;
	
	endif;
	
	CMIF_TrxActionCargoGroup@createAction(realTI, null, _passport); // 10/11/2022	navkc1	#55382
	
	/*	// 10/11/2022	navkc1	#55382 Moved to CMIF_TrxActionCargoGroup@createAction
	//TFS 53390
	if _passport.noErrors() and realTI.myCargoGroup &lt;&gt; null then
		create cargoGroupSiteTrxAction transient;
		cargoGroupSiteTrxAction.setMyCargoGroup(realTI.myCargoGroup);
		_passport.addTrxPostAction(cargoGroupSiteTrxAction);
	endif;
	*/	// 10/11/2022	navkc1	#55382
end;</source>
        <Parameter name="_pxyTI" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_updateMode" type="Integer"/>
        <Parameter name="_extraParams" type="CMIF_TIUpdateExtraParams"/>
        <Parameter name="_txnControllerDict" type="CMIF_TITxnContrlrByTypeDTDict"/>
        <Parameter name="_comment" type="String"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateTIBehaviourType" id="43a042d4-73f8-402d-8077-cdc9423691ad">
        <source>utlUpdateTIBehaviourType(_pxyTIBehaviourType : CM_TIBehaviourType; _realTIBehaviourType : CM_TIBehaviourType io);
// -------------------------------------------
// Created 03 November 2005 by cnwdvb1
// -------------------------------------------
vars

	realTIBehaviourType : CM_TIBehaviourType;
	edition				: Integer;

begin

	self.initialiseActivity();
	
	
	self.exclusiveLock(_realTIBehaviourType);
			
	_realTIBehaviourType.setForUpdate(_pxyTIBehaviourType);
	

end;</source>
        <Parameter name="_pxyTIBehaviourType" type="CM_TIBehaviourType"/>
        <Parameter name="_realTIBehaviourType" type="CM_TIBehaviourType" usage="io"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateTICEDO" id="827b1ab0-6833-47b8-b958-c8d447745702">
        <source>utlUpdateTICEDO(_theProxyTI: CM_TrackedItem input; _theCEDONumber : String; _ediVoyageCode: String; _clear : Boolean;
					_passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:		Jan 2007 cnwrs1
// 20/06/2018   cnwma1		ChangeRequest 38815: PEL1 - WP TI Work Order Changes
// ---------------------------------------------------------------------------

vars
	theRealTI		: CM_TrackedItem;
	expectedEdition : Integer;
	txnParams		: CMIF_ConnectParams;
	aTITrans		: CM_TITransaction;
begin
	self.initialiseActivity();
	//20.6.2018 cnwma1 TFS #38815
	if  _theProxyTI.isTransient then
		_theProxyTI.raiseExceptionIfNotProxy(method);
		_theProxyTI.pxyGetRealObjectAndEdition(theRealTI, expectedEdition);
	else
		theRealTI:=_theProxyTI;
		expectedEdition:=theRealTI.edition;
	endif;
	
	exclusiveLock(theRealTI);

	if _passport.noErrors and theRealTI.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'TI CEDO', null, null);
		return;
	endif;
		
	if _clear and (_theCEDONumber.trimBlanks = null) then
		//this is required so raise exception
	//	app.raiseCMException1(REQUIRED_FIELD, 'CEDO', 'CEDO', self);
		app.raiseCMException(Input_required_field_CEDO, 'CEDO', self); // cnwdb2	PAR 35364
		return;
	endif;	
	
	if not _clear then
		return;
	endif;
	
	create txnParams transient;
	txnParams.type			:= TRANS_TYPE_CUSTSTOP_CLRD;
	txnParams.myTrackedItem := theRealTI;
	txnParams.urNumber 		:= "1";
	txnParams.userId 		:= _passport.userCode;
	aTITrans := theRealTI.createTransaction(txnParams, _passport);	
	aTITrans.CM_CustomStopClear.setCustomsDetails(_theCEDONumber, _ediVoyageCode);
	
	theRealTI.setCEDO(_theCEDONumber);
	theRealTI.removeCEDOStop();

	// no need to cause event as theRealTI is updated above so the
	// event will get sent through by JADE
	//theRealTI.causeEvent(Object_Update_Event, false, theRealTI); // AKB2004DEC.

epilog

	delete txnParams;

end;</source>
        <Parameter name="_theProxyTI" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_theCEDONumber" type="String"/>
        <Parameter name="_ediVoyageCode" type="String"/>
        <Parameter name="_clear" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateTICheckCompleted" id="c934880b-728c-4971-a8f3-2645014ba4b4">
        <updating/>
        <source>utlUpdateTICheckCompleted(_context : Integer; _complete : Boolean; _ti : CM_TrackedItem input; _effectiveDT : TimeStamp; _passport : CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date					Who		Reason
01 February 2024		jlizm1	Initial creation TFS 62142 Perform checks from voyage ops live
14 February 2024		jlizm1	TFS 62437 Create edit transaction for check complete
20 Feb 2024 navhl20 ChangeRequest 62525: EUP | Retrospective Operations - [54177.060] - Cargo &amp; Truck Checks
*/

vars
	idx : Integer;
	str	: String;
	
begin
	self.initialiseActivity();
	
	if _ti = null then
		app.raiseCMException2(MethodWithNullParam, method.name, app.getErrorString(TrackedItem), null, null);
		return;
	endif;
	
	exclusiveLock(_ti);
	
	if _context &lt;= 0 then
		app.raiseCMException1(Invalid_cargo_check_context, _context.asStringJMT(), null, null);
		return;
	endif;
	
	if _complete then
		if _ti.isCargoCheckComplete(_context) then
			// already complete
			return;
		endif;
		
		_ti.setCargoCheckComplete(_context, true);
		str := app.getErrorString(Cargo_checks_completed) &amp; ": " &amp; app.cargoCheckContextENumToString(_context);
		app.createEditTransaction(_ti, str, _effectiveDT, _passport);				//20.02.2024 navhl20 #62525
		
	else
		if _context &lt;= _ti.cargoChecksCompleted.size then
			_ti.setCargoCheckComplete(_context, false);
		endif;
	endif;
	
epilog

end;</source>
        <Parameter name="_context" type="Integer"/>
        <Parameter name="_complete" type="Boolean"/>
        <Parameter name="_ti" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_effectiveDT" type="TimeStamp"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateTICompanyOid" id="788f7dd3-b782-40d2-a877-a3dfc0b5d89f">
        <source>utlUpdateTICompanyOid(_istParam : CMIF_InterStorageTransport; _passport : CM_Passport input);
//-----------------------------------------
// Created: January 2004 By: cnwgd1
//-----------------------------------------
vars

begin

	self.initialiseActivity();
	self.raiseExceptionIfNull(_istParam, '_istParam');

	app.setContinueCMExceptions(true);
	_istParam.validate(_passport);

	if (not self.checkValidationWithPassport(_passport)) then
		return;
	endif;

	app.setContinueCMExceptions(false);
	
	_istParam.action(_passport);

end;</source>
        <Parameter name="_istParam" type="CMIF_InterStorageTransport"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateTIConsign" id="9dbf38a7-a368-4343-8f2f-e2f0833fcbd9">
        <source>utlUpdateTIConsign(tiSet : CM_TISet; pIncorrectConsign, pCorrectConsign : CM_ConsigneeConsignor;
					_passport : CM_Passport input);
//--------------------------------------------------------------
//Created: November 2001 By: cnwgd1
//--------------------------------------------------------------
vars
	iter	: Iterator;
	ti		: CM_TrackedItem;
	incorrectCode	: String;
	correctCode		: String;
	tiUpdateCntrl	: CMIF_TIUpdateController;
	tiAuditCntrl	: CM_TIAuditController;
	sa				: StringArray;

begin

	self.initialiseActivity();

	incorrectCode := pIncorrectConsign.code;
	correctCode := pCorrectConsign.code;

	tiUpdateCntrl := app.createTIUpdateControl(TI_UPDMODE_NORMAL, _passport.userCode, null);
	tiAuditCntrl := _passport.getTIAuditController();
	create sa transient;
	sa.add(CM_TrackedItem::consignor.name);
	sa.add(CM_TrackedItem::consignee.name);
	tiAuditCntrl.setAuditSpecific(CM_TrackedItem, sa);
	
	foreach ti in tiSet do

		exclusiveLock(ti);
		
		/*if _passport.noErrors then
			self.myUpdateAuditAgent.audUpdateGeneric(ti, true);
		endif;*/
		
		if ti.consignee = incorrectCode then
			ti.setConsignee(correctCode, tiUpdateCntrl, _passport);
		endif;
		if ti.consignor = incorrectCode then
			ti.setConsignor(correctCode, tiUpdateCntrl, _passport);
		endif;
		
		/*if _passport.noErrors then
			ao := self.myUpdateAuditAgent.audUpdateGeneric(ti, false);
		endif;

		// ao can be null if no actual change was made
		if _passport.noErrors and ao &lt;&gt; null then
			ti.createEditTransactionFromAudit(ao);
		endif;*/

		if (not _passport.noErrors) then
			break;
		endif;

	endforeach;

epilog
	if tiAuditCntrl &lt;&gt; null then
		tiAuditCntrl.resetIsAudited(true);
	endif;
	delete sa;
	delete tiUpdateCntrl;
end;</source>
        <Parameter name="tiSet" type="CM_TISet"/>
        <Parameter name="pIncorrectConsign" type="CM_ConsigneeConsignor"/>
        <Parameter name="pCorrectConsign" type="CM_ConsigneeConsignor"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateTIConsignee" id="dddbdade-e715-4211-92fb-fc6b5b886989">
        <updating/>
        <source>utlUpdateTIConsignee(pTI : CM_TrackedItem input; pCorrectConsign : CM_ConsigneeConsignor;
					_passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:		February  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	//ao 		: CM_AuditObject;
	tiUpdateCntrl	: CMIF_TIUpdateController;
	consCode		: String;
begin

	self.initialiseActivity();

	tiUpdateCntrl := app.createTIUpdateControl(TI_UPDMODE_NORMAL, _passport.userCode, null);
	
	exclusiveLock(pTI);

	if pCorrectConsign &lt;&gt; null then
		consCode := pCorrectConsign.code;
	endif;

	pTI.setConsignee(consCode, tiUpdateCntrl, _passport);
epilog
	delete tiUpdateCntrl;
end;</source>
        <Parameter name="pTI" type="CM_TrackedItem" usage="input"/>
        <Parameter name="pCorrectConsign" type="CM_ConsigneeConsignor"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateTICustomsEntryNum" id="d3805bc6-0ac8-46bc-9dcc-827b202911ef">
        <source>utlUpdateTICustomsEntryNum(_theProxyTI: CM_TrackedItem input; _theCENumber : String; _ediVoyageCode: String; _clear : Boolean;
					_passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:		17 March 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------

vars
	theRealTI		: CM_TrackedItem;
	expectedEdition : Integer;
	txnParams		: CMIF_ConnectParams;
	aTITrans		: CM_TITransaction;
begin
	self.initialiseActivity();

	_theProxyTI.raiseExceptionIfNotProxy(method);
	_theProxyTI.pxyGetRealObjectAndEdition(theRealTI, expectedEdition);

	exclusiveLock(theRealTI);

	if _passport.noErrors and theRealTI.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'TI Customs Entry Number', null, null);
		return;
	endif;
	self.updateTICustomsEntryNum(theRealTI, _theCENumber, _ediVoyageCode, _clear, _passport); //par 22953 cnwrs1 Feb 2010
/*		
	if _clear and (_theCENumber.trimBlanks = null) then
		//this is required so raise exception
		app.raiseCMException1(REQUIRED_FIELD, 'Customs Entry Number', 'Customs Entry Number', self);
		return;
	endif;	
	
	if not _clear then
		return;
	endif;
	
	create txnParams transient;
	txnParams.type			:= TRANS_TYPE_CUSTSTOP_CLRD;
	txnParams.myTrackedItem := theRealTI;
	txnParams.urNumber 		:= "1";
	txnParams.userId 		:= _passport.userCode;
	aTITrans := theRealTI.createTransaction(txnParams, _passport);	
	aTITrans.CM_CustomStopClear.setCustomsDetails(_theCENumber, _ediVoyageCode);
	if app.myRoot.client = Client_DCTGdansk then
		theRealTI.setCEDO(_theCENumber); //???
	endif;
	
	theRealTI.setCustomsEntryNumber(_theCENumber);
	if _theCENumber &lt;&gt; null then
		theRealTI.removeStopsToBeProcessed(StopProcessEDICustomImport); //cnwrs1 July 2007 par 14494 stops
	endif;
	// no need to cause event as theRealTI is updated above so the
	// event will get sent through by JADE
	//theRealTI.causeEvent(Object_Update_Event, false, theRealTI); // AKB2004DEC.

epilog

	delete txnParams;
*/
end;</source>
        <Parameter name="_theProxyTI" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_theCENumber" type="String"/>
        <Parameter name="_ediVoyageCode" type="String"/>
        <Parameter name="_clear" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateTIDamage" id="6595e1d5-da17-45ae-a256-d2bac6584d8c">
        <source>utlUpdateTIDamage(_pxyTI    : CM_TrackedItem input;
				  _passport : CM_Passport input);
/*
----------   ----------  --------------------------------------------------
Created:	30 August 2006 By cnwth2

Purpose:	

/* Changes

Date		Name	TFS#		Description
============================================================================
19/09/2016	cnwma1	TFS #2627 
					PAR38186 	PEN - Security Roles not working properly for Tasks		
06/05/2019	jlgka1	TFS 44287	JMT - Add Edit Transaction when deleting or updating 
								Damage Instances from 'Mobile' apps both new and old.
19/05/2023	navcs2	Defect 58032 MTN - Mobile Apps cargo damage refused doesn't add stop 
27/09/2023	navcs2	ChangeRequest 60695: EUP | FR 54536 - Damage and Repair - Transaction Changes
20 Feb 2024 navhl20 ChangeRequest 62525: EUP | Retrospective Operations - [54177.060] - Cargo &amp; Truck Checks
============================================================================*/
vars
	realTI 				: CM_TrackedItem;
	tiUpdateCntrl		: CMIF_TIUpdateController;
	expectedEdition 	: Integer;
begin
	self.initialiseActivity();
	
	self.raiseExceptionIfNull(_pxyTI, 'Tracked Items Proxy');
	
	_pxyTI.pxyGetRealObjectAndEdition(realTI, expectedEdition);
	self.raiseExceptionIfNull(realTI, 'Tracked Item proxy');
	
	tiUpdateCntrl := app.createTIUpdateControl(TI_UPDMODE_NORMAL, _passport.userCode, null);
	_pxyTI.validateDamageInstances(tiUpdateCntrl);
	
	if _pxyTI.damagedDT.isValid then						//20.02.2024 navhl20 #62525
		tiUpdateCntrl.dateTime := _pxyTI.damagedDT;
	endif;
	
	if not _passport.noErrors then
		return;
	endif;
	
	exclusiveLock(realTI);
	
	//realTI.setDamageInstances(_pxyTI); 	// 19/9/2016 cnwma1 TFS #2627
	//realTI.setDamageInstances(_pxyTI,true); // 19/9/2016 cnwma1 TFS #2627  // jlgka1 TFS 44287 comment out
	
	// Removed as it just calls setDamageInstances which is now called in the setForUpdate on tracked item
	//realTI.setForUpdateDamageInstanceMob(_pxyTI, tiUpdateCntrl, true, _passport); // jlgka1 TFS 44287;		// 27/09/2023 navcs2 ChangeRequest 60695
	
	//realTI.setRemarksDamaged(_pxyTI.remarks, null, _pxyTI.damaged, tiUpdateCntrl, _passport); //-cnwas3 par 24175
	realTI.setRemarksDamaged(_pxyTI.remarks, null, _pxyTI.damaged, tiUpdateCntrl, _passport); //+cnwas3 par 24175

	realTI.setForUpdate(_pxyTI, tiUpdateCntrl, null, false, app.myPassport);					// 19/05/2023	navcs2	Defect 58032
epilog

	delete tiUpdateCntrl; //10 Jan 2010 NDL	Unit test transient leaks.

end;
</source>
        <Parameter name="_pxyTI" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateTIDischargePort" id="d11895ee-f602-4bd6-8c53-00e092e34a78">
        <updating/>
        <source>utlUpdateTIDischargePort(_ti : CM_TrackedItem input; _dischargePort : CM_Port; _passport : CM_Passport input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 March 2010	cnwas3	par 23043

*/

vars
	
	portCode		: String;
begin

	self.initialiseActivity();	
	
	exclusiveLock(_ti);

	if _dischargePort &lt;&gt; null then
		portCode := _dischargePort.code;
	endif;
	
	_ti.setDischargePort(portCode);
		
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_dischargePort" type="CM_Port"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateTIDoEDIAction" id="e08a2a38-32ea-4fbf-828c-b1754a67c2be">
        <source>utlUpdateTIDoEDIAction(_theProxyTI: CM_TrackedItem input; _theEDITI : CM_EDICustomStopTI; _passport : CM_Passport input);
//----------------------------------------------------------------
//	Created:	02 September 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
// 30 Jul 2018	jlgsl4	TFS 39133 - Trade Single Window - NZCS &amp; MPI stops
// 10 Sep 2018	jlgsl4	TFS 39133 - TSW - IM1 &amp; EX1 'all clear' message
// 30 Aug 2023	navpw1	TFS: 60146 (60173) - Added a roleCode not equal to TT check to the Mode of Transport Key file segment

vars
	theRealTI		: CM_TrackedItem;
	expectedEdition : Integer;
	aTITrans		: CM_TITransaction;
	ediFileType		: CM_EDIFileType;
	ediAction		: CM_EDIAction;
	action			: Boolean;
	txnParams		: CMIF_TITransactionController;
	aStringArray	: HugeStringArray;
	updated			: Boolean;
	actionObject	: CM_Object;
	invalid 		: Boolean;
	allClearTSW,				// TFS 39133 14/9/18
	tswDTRClearance	: String; 	// ### TFS 60682 (60705) 05Oct2023 NAVPW1
	roleCode		: String;	// ### TFS 58831 (58833) 03July2023 NAVPW1
	
begin
	self.initialiseActivity();

	_theProxyTI.raiseExceptionIfNotProxy(method);
	_theProxyTI.pxyGetRealObjectAndEdition(theRealTI, expectedEdition);

	if theRealTI = null then
		app.raiseUnexpectedProgramError(class.name, method.name, "can't locate real object");
		return;
	endif;

	exclusiveLock(theRealTI);
	// 24/08/2009 	cnwsh3 		CCMS SFW1868 PAR20300 - CSI Inspection Stop revmoval via CUSRES Removed this now it is included in the update of the an Export Clear response.
/*	if _passport.noErrors and theRealTI.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'TI Customs Entry Number', null, null);
		return;
	endif;
*/	
	ediFileType := _theEDITI.myEDIFile.myEDIFileType; // TFS 39133
	if ediFileType = null or ediFileType.type &lt;&gt; EDIFileType_JMTInternal then // TFS 39133
		ediFileType := app.myRoot.allEDIFileTypes.getAtKeyGeq(EDIFileType_CusRes, null);	
		if ediFileType = null or ediFileType.type &lt;&gt; EDIFileType_CusRes then
		//	app.raiseCMException1(REQUIRED_FIELD, 'Customs EDI File Type', 'EDI File Type', self);
			app.raiseCMException(Input_required_field_custEdiFl, 'EDI File Type', self); // cnwdb2	PAR 35364
			return;
		endif;
	endif; // TFS 39133
	
	create aStringArray transient;
	create txnParams transient;
	txnParams.type 			:= TRANS_TYPE_EDIT;
	txnParams.myTrackedItem := theRealTI;
	txnParams.userId 		:= _passport.userCode;
	
	on Exception do app.handleDeletedObject(exception, actionObject, invalid);
	
	//do some action stuff
	foreach ediAction in ediFileType.allEDIActions do
		action := false;
		
		roleCode := ediAction.roleCode;	// ### TFS 58831 (58833) 07July2023 NAVPW1
		
		if (ediAction.keyFileSegment = EDIKeySegment_FTXDIN	and _theEDITI.mafInstructions.pos(ediAction.keyword, 1) &gt; 0) or
			(ediAction.keyFileSegment = EDIKeySegment_FTXQIN and _theEDITI.quarantineInstructions.pos(ediAction.keyword, 1) &gt; 0) or
			//(ediAction.keyFileSegment = EDIKeyField_Clearance and _theEDITI.responseStatus.pos(ediAction.keyword, 1) &gt; 0) or // TFS 39133
			(ediAction.keyFileSegment = EDIKeyField_Clearance and _theEDITI.responseStatus.pos(ediAction.keyword, 1) &gt; 0) and roleCode = _theEDITI.roleCode or										// ### TFS 58831 (58833) 06July2023 NAVPW1
			(ediAction.keyFileSegment = EDIKeyField_Clearance and _theEDITI.responseStatus.pos(ediAction.keyword, 1) &gt; 0) and roleCode = null and _theEDITI.roleCode &lt;&gt; CM_EDIAction.RoleCode_TT or	// ### TFS 58831 (58833) 07July2023 NAVPW1 - Do what we used to do before if it is not TT
			(ediAction.keyFileSegment = EDIKeySegment_MOT and _theEDITI.statementCode.pos(ediAction.keyword, 1) &gt; 0) and _theEDITI.roleCode &lt;&gt; CM_EDIAction.RoleCode_TT or							// ### TFS 58834 (58836) 11July2023 NAVPW1
			(ediAction.keyFileSegment = EDIKeySegment_GIS) then
			// something we can process
			action := true;
		endif;
		
		if action then
			actionObject := ediAction.myActionObject;	// a stop or todo task
			
			if actionObject &lt;&gt; null then
				invalid := false;
				allClearTSW := _theEDITI.isTSWAllClearMessage();																// TFS 39133 - EX1/IM1
				tswDTRClearance := theRealTI.isTSWClearBeforeSet(actionObject, _theEDITI.responseStatus, _theEDITI.roleCode);	// ### TFS 60682 (60705) 05Oct2023 NAVPW1
				if allClearTSW &lt;&gt; null then																						// TFS 39133 - EX1/IM1
					updated := actionObject.actionTI(theRealTI, allClearTSW, _passport);										// TFS 31933 - EX1/IM1
				elseif tswDTRClearance &lt;&gt; null and ediAction.keyFileSegment = EDIKeyField_Clearance then						// ### TFS 60682 (60705) 05Oct2023 NAVPW1
					updated := actionObject.actionTI(theRealTI, tswDTRClearance, _passport);									// ### TFS 60682 (60705) 05Oct2023 NAVPW1
				else																											// TFS 39133 - EX1/IM1
					updated := actionObject.actionTI(theRealTI, ediAction.actionType, _passport);
				endif;																											// TFS 39133	- EX1/IM1
				if invalid then
					app.raiseUnexpectedProgramError(class.name, method.name, 'the action item has been deleted - update the EDI Action (' &amp; ediAction.name &amp; ') in SysOps');
					return;
				endif;
				
				if updated then
					// RECORD This event
					aStringArray.add("EDIAction =&gt; " &amp; ediAction.actionType &amp; " " &amp; actionObject.getEDIActionName);
				endif;
			endif;
		endif;
	endforeach;

	on Exception do null;
	
	if not aStringArray.isEmpty then
		aTITrans := theRealTI.createTransaction(txnParams, _passport);	
		
		aTITrans.CM_Edit.fieldsValues.addStrings(aStringArray);
	endif;
epilog
	delete txnParams;
	delete aStringArray;
end;</source>
        <Parameter name="_theProxyTI" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_theEDITI" type="CM_EDICustomStopTI"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateTIExternalMonitoring" id="7d3baa4a-0b34-492f-95ff-2ff1c4c12e2d">
        <source>utlUpdateTIExternalMonitoring(	_theTI: CM_TrackedItem input;
								_externallyMonitored : Boolean;
								_passport : CM_Passport input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 October 2015	cnwmc5	Initial creation

*/

vars

begin
	
	self.initialiseActivity();
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(_theTI, true);
	endif;
	
	if _passport.noErrors then
		_theTI.setExternalMonitoring(_externallyMonitored);
	endif;

	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(_theTI, false);
	endif;
	
epilog

end;</source>
        <Parameter name="_theTI" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_externallyMonitored" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateTIExternalProfileID" id="be1b921a-b378-463f-8e4c-b871a314f08e">
        <source>utlUpdateTIExternalProfileID(_theProxyTI: CM_TrackedItem input; _profileID, _profileSecret: String; _passport: CM_Passport input);

/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 November 2018	jlgmp6	Initial creation	TFS41999

*/

vars
	theRealTI : CM_TrackedItem;
	expectedEdition : Integer;
	tiUpdateCntrlr : CMIF_TIUpdateController;
begin
	self.initialiseActivity();

	_theProxyTI.raiseExceptionIfNotProxy(method);
	_theProxyTI.pxyGetRealObjectAndEdition(theRealTI, expectedEdition);

	exclusiveLock(theRealTI);

	if _passport.noErrors and theRealTI.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'TI External Profile ID', null, null);
		return;
	endif;
	
	tiUpdateCntrlr := app.createTIUpdateControl(TI_UPDMODE_NORMAL, _passport.userCode, null);
	
	theRealTI.setExternalProfileID(_profileID, _profileSecret);

epilog
	delete tiUpdateCntrlr;
end;</source>
        <Parameter name="_theProxyTI" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_profileID" type="String"/>
        <Parameter name="_profileSecret" type="String"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateTIForBulkEdit" id="75ab3a2e-5ef0-4a0c-a564-00909ed43d20">
        <updating/>
        <source>utlUpdateTIForBulkEdit(_pxyTI, 
					_realTI  			: CM_TrackedItem input;
					_updateMode 		: Integer;
					_updateController 	: CMIF_TIUpdateController input;
					_allTasksToAdd,
					_allTasksToComplete,
					_allTasksToRemove	: IntegerArray;
					_extraParams		: CMIF_TIUpdateExtraParams;
					_passport 			: CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     26 March 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
// Changed On 	By			Reason
// ----------	--------	--------------------------------------------------
// 12/05/2010	cnwdap1		CCMS 1116 Tranship changes
// 19 May 2010	cnwkpd1		PAR #20728 - remove isValidObject calls for performance
// 09/11/2022	navkc1		Bug 55382: MTN - Cargo Group Details recalculated after each change to TI when bulk editing
// 09/04/2024	navdap1		TFS 63307 EUP | Performance - Cargo Enquiry Bulk Updates
vars
	
begin
	
	_pxyTI.raiseExceptionIfNotProxy(method);

	if _realTI = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_TrackedItem.name, null, null);
		return;
	endif;	

	// Move validation to do before this call when not in transaction state
	
	_realTI.setForUpdate(_pxyTI, _updateController, _extraParams, true, _passport); //cnwrd1 28.8.09 par 20545
	
	if (not _passport.noErrors) then
		return;
	endif;
	
//	if global.isValidObject(_realTI) then //par 15781 cnwrs1 jan 2008
	// the above line is a bodg to get around the problem is the realti has been deleted at the end of ti::setForUpdate
	// hopefully an alternative will be found in dmast for 761
		self.utlUpdateTIToDoTasks(_allTasksToAdd,
								_allTasksToComplete,
								_allTasksToRemove,
								_realTI,
								_passport);
//	endif;
	
	if not app.myPassport.allowProgressiveUpdates then									// TFS 63307
		CMIF_TrxActionCargoGroup@createAction(_realTI, null, _passport); //	navkc1	10/11/2022	#55382
	endif;																				// TFS 63307
	
epilog
	
end;</source>
        <Parameter name="_pxyTI" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_realTI" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_updateMode" type="Integer"/>
        <Parameter name="_updateController" type="CMIF_TIUpdateController" usage="input"/>
        <Parameter name="_allTasksToAdd" type="IntegerArray"/>
        <Parameter name="_allTasksToComplete" type="IntegerArray"/>
        <Parameter name="_allTasksToRemove" type="IntegerArray"/>
        <Parameter name="_extraParams" type="CMIF_TIUpdateExtraParams"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateTIFreeStorageDays" id="826a33f4-0d60-45c5-a1c9-5f1fa8579bec">
        <source>utlUpdateTIFreeStorageDays(_theProxyTI: CM_TrackedItem input; _freeStorageDays : Integer;
					_passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:		February  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
//	ao 		: CM_AuditObject;
	theRealTI : CM_TrackedItem;
	expectedEdition : Integer;
begin
	self.initialiseActivity();

	_theProxyTI.raiseExceptionIfNotProxy(method);
	_theProxyTI.pxyGetRealObjectAndEdition(theRealTI, expectedEdition);

	exclusiveLock(theRealTI);

	if _passport.noErrors and theRealTI.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'TI Remarks', null, null);
		return;
	endif;
	theRealTI.setFreeStorageDays(_freeStorageDays);

end;</source>
        <Parameter name="_theProxyTI" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_freeStorageDays" type="Integer"/>
