	self.resetAllFilters();
	ct := self.myCurrentBOLDetail.myCargoType; 
	self.filterAllCargoType := ct;
	// to show this selection
	//self.cmbFilterCargoTy.listObject := ct; //- cnwmd1, Par 22846

	self.refreshTables();

end;

</source>
