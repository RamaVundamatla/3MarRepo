    <JadeMethod name="doPrintJobs" id="81df9258-b2df-4a75-9d24-f0ae5ca3a5d9">
        <source>doPrintJobs();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 Aug 2009	cnwndl1	Initial creation - CCMS 1094 - copy of 'doPrintJobs' version on YRD_TrainForm
18 Mar 2010	consw1	PAR #22886 - Leaking report transients

*/

vars
	qryReport 			: CM_QryReport;
	jrwManager			: JadeReportWriterManager;
	jrwReport			: JadeReportWriterReport;
	jrwFileName			: String;
	jrwTransient		: CM_JRWTrackedItems;
	tmpJadeReport,
	jadeReport			: JadeReport;
	tmpPrintData,
	pxyPrintData		: JadePrintData;
	tiArray				: CM_TIArray;
	strProfile,
	rptCaption			: String;
	selectedProfiles	: StringArray;
	pxyCloned			: Boolean;
	termDict			: CM_TerminalByCodeDict;
	train				: CM_Train;
	inOutDesc			: String;
begin
	if self.myDefaultTrain = null then
		return;
	endif;
	train := self.myDefaultTrain;
	
	qryReport := app.myRoot.getQryReport(app.getErrorString(Rail_rake_info));
	
	if qryReport = null then
		return;
	endif;
	
	jrwTransient := app.myQAFilter.createJRWTransient(CM_JRWContainer).CM_JRWContainer;
	
	if jrwTransient = null then
		app.raiseUnexpectedProgramError(class.name, method.name, app.getErrorString(JRW_Transient_Failed));
		return;
	endif;
	
	create selectedProfiles transient;
	self.setSelectedProfiles(selectedProfiles);
	
	create tiArray transient;
	
	jrwTransient.allTrackedItems.clear();
	
	train.getAllTrackedItems(self.optCInwards.value = true, tiArray);
	tiArray.copy(jrwTransient.allTrackedItems);						
		
	jrwTransient.rptClearRakeHeading := rptCaption[1:50];

	create termDict transient;
	termDict.add(self.myTerminal);
	jrwTransient.setAllTerminals(termDict);
			
	jrwManager := app.createReportWriterManager();
	
	create jadeReport transient;

	app.printer.printPreview := false;

	jrwFileName := qryReport.jrwReportName.first;
	jrwReport := jrwManager.getReport(jrwFileName);
	jrwReport.setOutputDestination(JadeReportWriterReport.PRINTER);
	jadeReport.description := jrwReport.name;
	
	if optCInwards.value = true then  
		inOutDesc := app.getErrorString(Inward);
	else
		inOutDesc := app.getErrorString(Outward);
	endif;
	
	jrwReport.setParameter(app.getErrorString(Inwardoutward), inOutDesc);
	jrwReport.setParameter(app.getErrorString(Trainname), train.description);
	
	foreach strProfile in selectedProfiles do
		jrwReport.setProfile(strProfile);
		
		
		app.printer.setReport(jadeReport);	// need to do for each
		
		jrwReport.run();
	
		if not pxyCloned then
			tmpJadeReport := jadeReport.cloneSelf(true);
			tmpJadeReport.description := qryReport.heading;
			pxyCloned := true;
		endif;
		foreach pxyPrintData in jadeReport.printArray do
			tmpPrintData := pxyPrintData.cloneSelf(true);
			tmpJadeReport.printArray.add(tmpPrintData);
		endforeach;
		jadeReport.printArray.purge;	//pages have been cloned on to tmpJadeReport

	endforeach;	
	
	app.printPreview(tmpJadeReport, true);
	
epilog

	delete selectedProfiles;
	delete jadeReport;
	delete tiArray;
	delete jrwManager;
	delete jrwReport;
	delete termDict;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doPrintRailManifest" id="74e2b633-965d-49aa-a8e6-d8719b8f8dae">
        <source>doPrintRailManifest();
// ---------------------------------------------------------------------------
// Created:     07 August 2009 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	if self.myDefaultTrain = null then
		return;
	endif;
	
	self.myAssistant.printTrainManifest(self.myDefaultTrain, optMInwards.value, self.chkPrintPreview.value);
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doPrintTrainManifest" id="6825b379-53ac-4d77-83cf-1aa52faac9e9">
        <source>doPrintTrainManifest();
// --------------------------------------------------------------------------------
// Created:		6 November 2009 by cnwjo3
//
// Purpose:		print plain manifest inward/outwards
//				MES 1013
vars

begin
	if self.myDefaultTrain = null then
		return;
	endif;
	
	self.myAssistant.printPlainManifest(self.myDefaultTrain, self.optPMIn.value, self.chkPrintPreview.value);
end;</source>
    </JadeMethod>
    <JadeMethod name="doSave" id="dcbdba9f-f680-4210-9cbb-28c20e936b99">
        <updating/>
        <source>doSave(): Boolean updating;
//--------------------------------------------------------------
//Created: 07 April 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	
	trainForm : YRD_TrainForm;
	enqForm : YRD_TrainEnquiry;
	trainName : String;
	direction : String;
	
begin

	app.mousePointer := Busy;
	
	//epr TFS 2260 4/8/16
	if self.chkPrintManifest.value then	
		self.doPrintTrainManifest();
	endif;
	
	//cnwjo3 MES 1013
	if self.chkPrintPM.value then
		self.doPrintRailManifest();	
	endif;
	
	if self.chkPrintCargo.value then	
		self.doPrintJobs;
	endif;
	
	if self.myParentForm &lt;&gt; null and self.myParentForm.isKindOf(YRD_TrainForm) then
		trainForm := self.myParentForm.YRD_TrainForm;
	elseif self.myParentForm &lt;&gt; null and self.myParentForm.isKindOf(YRD_TrainEnquiry) then // PAR 23176
		enqForm := self.myParentForm.YRD_TrainEnquiry; // PAR 23176
	endif;
	
	if trainForm &lt;&gt; null then
		trainName := self.myAssistant.displayEntryTrain(self.myDefaultTrain);
		if chkPrintWagons.value then
			if trainForm.optDirInTB.value then
				direction :=  app.getErrorString(Inward);
			else
				direction :=  app.getErrorString(Outward);
			endif;
			self.doPrintOutTable(trainForm.tblWagons, (trainName &amp; " " &amp; direction &amp; " " &amp; app.getErrorString(Wagons)).String[1:100], chkPrintPreview.value, false, true, false);
		endif;
		
		if chkPrintWarnings.value then
			self.doPrintOutTable(trainForm.tblWarnings, (trainName &amp; " " &amp; app.getErrorString(Warning)).String[1:100], chkPrintPreview.value, false, true, false);
		endif;
		if chkPrintTrans.value then
			self.doPrintOutTable(trainForm.tblTrans, (trainName &amp; " " &amp; app.getErrorString(Transactions)).String[1:100], chkPrintPreview.value, false, true, false);
		endif;
		
		if chkPrintStats.value then
			self.doPrintOutTable(trainForm.tblCargoStat, (trainName &amp; " " &amp; app.getErrorString(Cargo)&amp; " " &amp; app.getErrorString(Statistics)).String[1:100], chkPrintPreview.value, false, true, false);
			self.doPrintOutTable(trainForm.tblWagonStat, (trainName &amp; " " &amp; app.getErrorString(Wagon)&amp; " " &amp; app.getErrorString(Statistics)).String[1:100], chkPrintPreview.value, false, true, false);
		endif;
	endif;
	 // PAR 23176
	if enqForm &lt;&gt; null then
		if chkPrintTrains.value then
			self.doPrintOutTable(enqForm.tblData, (app.getErrorString(Trains)).String[1:100], chkPrintPreview.value, false, true, false);
		endif;
	endif;
	return true;
epilog
	
	app.mousePointer := Idle;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
