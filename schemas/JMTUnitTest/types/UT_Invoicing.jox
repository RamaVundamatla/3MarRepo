    <JadeMethod name="validateRateChanged1" id="7db7c6d9-d6b3-43fa-83b4-62d9a8b2adfa">
        <source>validateRateChanged1(_invoice : CM_Invoice; _step : Integer);

vars
	invCount	: Integer;
	invLine	: CM_InvoiceLine;
begin
	foreach invLine in _invoice.invoiceLines do
		invCount := invCount + 1;
		if invCount = 1 then
			self.assertEqualMsg(invLine.quantity, 10.Real, "line 1 quantity");
			self.assertEqualMsg(invLine.lineTotal, 270.Decimal, "line 1 after " &amp; _step.String &amp; " value");
		elseif invCount = 2 then
			self.assertEqualMsg(invLine.quantity, 5.Real, "line 2 quantity");
			self.assertEqualMsg(invLine.lineTotal, 135.Decimal, "line 2 after " &amp; _step.String &amp; " value");
		elseif invCount = 3 then
			self.assertEqualMsg(invLine.quantity, 10.Real, "line 3 quantity");
			self.assertEqualMsg(invLine.lineTotal, 270.Decimal, "line 3 after " &amp; _step.String &amp; " value");
		elseif invCount = 4 then
			self.assertEqualMsg(invLine.quantity, 5.Real, "line 4 quantity");
			self.assertEqualMsg(invLine.lineTotal, 75.Decimal, "line 4 after " &amp; _step.String &amp; " value");
		endif;
	endforeach;
	self.assertEqualMsg(invCount, 6, "Invoice lines");
end;
</source>
