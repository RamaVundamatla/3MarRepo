        <source>resize() updating;
/*

Purpose:			Resize form event

Parameters:			

Return Value:		

Date		Who		Reason
04 November 2021	navpw1	Initial creation TFS: 52202

*/

begin
	self.splHorizMain.cnEcResizeContents();
	self.frmFilter.cnEcResizeContents();
	self.splCodeCompare.cnEcResizeContents(); //Resize our split container contents
	self.splData.cnEcResizeContents(); //Resize our split container contents
	self.splLeft.cnEcResizeContents(); //Resize our split container contents
	self.splRight.cnEcResizeContents(); //Resize our split container contents
end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="8ddf2106-acf1-4f85-bac8-db7973dea360">
        <updating/>
        <source>setupForm() updating;
/*

Purpose:			Sets up our form

Parameters:			

Return Value:		

Date		Who		Reason
02 November 2021	navpw1	Initial creation TFS: 52202

*/

vars
	sourceCompareReport : DEV_SourceCompareReport;
	sourceCompareRoot 	: DEV_SourceCompareRoot;
	index				: Integer;
	
begin
	if not app.defaultMdi then
		self.centreWindow;
	endif;
	
	self.width := 1085;
	
	if process.isPW() then
		self.width := 1163;
	endif;
	
	self.splHorizMain.cnEcResizeContents();
	self.splCodeCompare.cnEcResizeContents(); //Resize our split container contents
	self.splData.cnEcResizeContents(); //Resize our split container contents
	self.splLeft.cnEcResizeContents(); //Resize our split container contents
	self.splRight.cnEcResizeContents(); //Resize our split container contents
	
	self.splLeft.borderStyle := 0;
	self.splRight.borderStyle := 0;
	self.frmGlobalConstants.borderStyle := 0;
	self.frmMissingMethods.borderStyle := 0;
	self.frmClassData.borderStyle := 0;
	self.frmDifferingMethods.borderStyle := 0;
	
	/*
	*	Setup Data
	*/
	self.lblCurrLastModified.caption := "";
	self.lblLoadLastModified.caption := "";
	
	self.jeLoaded.text := "Double-click the results down the bottom to show detailed info";
	
	if app.myCnKarmaCntrl.environmentId[1:8].toUpper() = "NAVWMAST" then
		self.gbCurrent.caption := "Current (WMAST)";
		self.gbLoaded.caption := "Loaded (DMAST)";
	endif;
	
	self.qlbMissingMethods.clear();
	self.qlbGlobalConstants.clear();
	self.qlbDifferentMethods.clear();
	self.qlbClassData.clear();
	
	self.qlbMissingMethods.refreshNow();
	self.qlbGlobalConstants.refreshNow();
	self.qlbDifferentMethods.refreshNow();
	self.qlbClassData.refreshNow();
	
	if self.differentClasses.size() &gt; 0 then
		self.differentClasses.purge();
	endif;
	
	self.cmbSelectReport.sorted := false;
	sourceCompareRoot := DEV_SourceCompareRoot.instances.first.DEV_SourceCompareRoot;
	
	if sourceCompareRoot &lt;&gt; null and sourceCompareRoot.allSourceCompareReports &lt;&gt; null then
		foreach sourceCompareReport in sourceCompareRoot.allSourceCompareReports reversed, discreteLock where sourceCompareReport.isAvailable do
			index := self.cmbSelectReport.addItem(sourceCompareReport.getDisplayName);
			self.cmbSelectReport.itemObject[index] := sourceCompareReport;
			
			if sourceCompareReport.reportType = DEV_SourceCompareReport.ReportType_Manual then
				self.cmbSelectReport.itemBackColor[index] := PalePink;
			endif;
			
		endforeach;
	endif;
	
	self.checkWinMergeAvailable();
	self.checkNppAvailable();
	
	/*
	*	Setup Jade Editor
	*	Loaded Source Jade Editor
	*/
	self.setupJadeEditor(self.jeLoaded);
	
	/*
	*	Setup Jade Editor
	*	Current Source Jade Editor
	*/
	self.setupJadeEditor(self.jeCurrent);
	
	self.cmbSelectReport.setFocus();
	
	self.mnuDetails.visible := true;
	
	if process.isPW or process.isMPD then
		mnuInspect.visible := true;
	endif;
	
	if process.isPW then
		self.btnAutoResolveForUser.visible := true;
		self.btnLoadJadeChange.visible := true;
	endif;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="setupJadeEditor" id="abc03352-81c6-4573-8d07-2419264e5b7d">
        <updating/>
        <source>setupJadeEditor(_jadeEditor : JadeEditor io) protected, updating;
/*

Purpose:			Sets up a Jade Editor

Parameters:			_jadeEditor:	JadeEditor	The jade editor we are setting up

Return Value:		

Date		Who		Reason
19 November 2021	navpw1	Initial creation TFS: 52202

*/

begin
	_jadeEditor.configureFor_Jade();
	_jadeEditor.initializeJadeEditor(false);
	_jadeEditor.setCurrentSchema(currentSchema);	// enable class name highlighting
	
	
	_jadeEditor.tabWidth		:= 4;
	_jadeEditor.fontSize		:= 12;				// has no effect ...
	_jadeEditor.currentPosition := 17;
	_jadeEditor.viewLinenumbers := true;
	_jadeEditor.readOnly 		:= true;
	
	_jadeEditor.setNamedAttribute("caret.line.back.color", PaleGreen);
	_jadeEditor.setLinemarkAttributes(JadeTextEdit.MARKER_JAD_LINEMARK, JadeTextEdit.SC_MARK_BACKGROUND, 0, PalePink);
end;</source>
        <access>protected</access>
        <Parameter name="_jadeEditor" type="JadeEditor" usage="io"/>
    </JadeMethod>
    <JadeMethod name="showDetails" id="c35820bb-62e9-45f4-a20f-598c58ac56ae">
        <source>showDetails(_listbox: ListBox input) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 December 2021	navpw1	Initial creation TFS: 52202

*/

vars
	itemObject					: Object;
	sourceComparisonAttributes 	: DEV_SourceComparisonAttributes;
	
begin
	if _listbox.text &lt;&gt; null then
		itemObject := _listbox.itemObject[_listbox.listIndex];
		create sourceComparisonAttributes transient;
		
		if itemObject.isKindOf(DEV_Class) then
			//Load comparison form
			sourceComparisonAttributes.loadClass(itemObject.DEV_Class);
			sourceComparisonAttributes.show();
			
		elseif itemObject.isKindOf(DEV_Attribute) then
			//Load comparison form
			sourceComparisonAttributes.loadAttribute(itemObject.DEV_Attribute);
			sourceComparisonAttributes.show();
			
		elseif itemObject.isKindOf(DEV_Reference) then
			//Load comparison form
			sourceComparisonAttributes.loadReference(itemObject.DEV_Reference);
			sourceComparisonAttributes.show();
			
		elseif itemObject.isKindOf(DEV_ClassConstant) then
			//Load comparison form
			sourceComparisonAttributes.loadConstant(itemObject.DEV_ClassConstant);
			sourceComparisonAttributes.show();
			
		elseif itemObject.isKindOf(DEV_GlobalConstantCategory) then
			//Load comparison form
			sourceComparisonAttributes.loadGlobalConstantCategory(itemObject.DEV_GlobalConstantCategory);
			sourceComparisonAttributes.show();
			
		elseif itemObject.isKindOf(DEV_GlobalConstant) then
			//Load comparison form
			sourceComparisonAttributes.loadGlobalConstant(itemObject.DEV_GlobalConstant);
			sourceComparisonAttributes.show();
		else
			// A list entry with children was double clicked, so expand them
			_listbox.cnEcExpandItem(_listbox.listIndex, true);
		endif;
		
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="_listbox" type="ListBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="showTableViewDiffMethods" id="3d92b10c-dfbd-4b1f-a70c-6aacec279dfd">
        <source>showTableViewDiffMethods();
/*
Purpose:	// ### JIRA 36455 23OCT2026 NAVAB1

Date		Who		Reason
23 October 2025	navab1
*/

vars
	reporter : DEV_SourceCompareReport;

begin

epilog
	self.tblDiffMethods.parent := self.frmDifferingMethods;
	self.tblDiffMethods.visible := true;
	self.tblDiffMethods.move(0,0,frmDifferingMethods.width,self.frmDifferingMethods.height);
	self.tblDiffMethods.parentAspect := Control.ParentAspect_StretchBoth;
	
	
	self.qlbDifferentMethods.parent := self;
	self.qlbDifferentMethods.visible := false;
	
	reporter := self.myReport;

	reporter.setTableDataDiffMethods(self.txtSearchString.text, self.tblDiffMethods);
	
end;</source>
    </JadeMethod>
