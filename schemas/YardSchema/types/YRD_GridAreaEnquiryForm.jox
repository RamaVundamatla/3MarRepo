    <JadeMethod name="showPopupInfoFrame" id="9aa607e6-65b1-487e-a8ab-eddc11e8b474">
        <source>showPopupInfoFrame(thePIC: CMIF_PopupInfoController input);
// ---------------------------------------------------------------------------
// Created:		November 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	
begin

	if self.frmPopupInfo.visible then
		return;
	endif;
	
