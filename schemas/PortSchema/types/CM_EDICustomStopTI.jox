    <JadeMethod name="setCustomsSealsFromString" id="51d8a377-c96d-4283-9b64-73c7794c8795">
        <source>setCustomsSealsFromString(_str : String);
//
//06 August 2018	jlgrs1	TFS 40086 JMT Not all EDI TrackedItem stringArray are exposed to the EDI JMT Internal
//
// 30 Apr 2019	jlgrs1	TFS40086 JMT Not all EDI TrackedItem stringArray are exposed to the EDI JMT Internal
//
vars
	strArray : StringArray;
	str : String;
begin
	self.allCustomsSeals.clear();
	strArray := _str.getTokens();
/*	if strArray &lt;&gt; null and 
	   not strArray.isEmpty then
		strArray.copy(self.allCustomsSeals);
