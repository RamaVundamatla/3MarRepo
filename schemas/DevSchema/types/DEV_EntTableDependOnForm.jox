    <JadeMethod name="getCaseDescr" id="07711fd5-c20f-4d68-9468-4e3ede781785">
        <source>getCaseDescr(_value : Integer) : String protected;
// ---------------------------------------------------------------------------
// Created:     05 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if _value = TextBox.Case_Lower then
		return TextBox.Case_Lower.String &amp; ' - All Lower';
	elseif _value = TextBox.Case_Upper then
		return TextBox.Case_Upper.String &amp; ' - All Upper';
	elseif _value = TextBox.Case_UpperFirst then
		return TextBox.Case_UpperFirst.String &amp; ' - First Upper';
	elseif _value = TextBox.Case_LowerFirst then
		return TextBox.Case_LowerFirst.String &amp; ' - First Lower';
	else
		return TextBox.Case_None.String &amp; ' - None';
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="_value" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="init" id="e280159e-c31e-482b-a8c3-0a2951d39123">
        <updating/>
        <source>init(pAttrName : String; pEntTableRow : EntTableRow io; _entGroup : EntTableGroup) : Boolean updating;
// ---------------------------------------------------------------------------
// Created:     02 March 2001 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin

	self.attributeName	:= pAttrName;
	self.myEntTableRow	:= pEntTableRow;
	self.myGroup		:= _entGroup;
	self.myEntTableRow.allDependencies.copy(self.allSelectedRows);
	
	return true;
	
end;</source>
        <Parameter name="pAttrName" type="String"/>
        <Parameter name="pEntTableRow" type="EntTableRow" usage="io"/>
        <Parameter name="_entGroup" type="EntTableGroup"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="initTblDependOn" id="5b153fae-56eb-4ac1-b6a6-0c8adca701c9">
        <updating/>
        <source>initTblDependOn() updating, protected;
// ---------------------------------------------------------------------------
// Created:     02 March 2001 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpEntRow	: EntTableRowEntity;
	tmpName		: String;
begin

	self.tblDependOn.rows := self.tblDependOn.fixedRows;
	self.tblDependOn.accessCell(1,1).text := 'Attribute' &amp; Tab &amp; 'Dependent';
	
	self.tblDependOn.accessColumn(2).inputType := Table.InputType_CheckBox;
	
	foreach tmpEntRow in self.myGroup.allEntTableRowsByName do
		// add the row to the table
		tmpName := tmpEntRow.name;
		if tmpName = self.attributeName then
			// do NOT include ourself as one of the options
			continue;
		endif;
		if self.allSelectedRows.includes(tmpName) then
			self.tblDependOn.addItem(tmpName &amp; Tab &amp; '1');
		else
			self.tblDependOn.addItem(tmpName &amp; Tab &amp; '0');
		endif;
	endforeach;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="load" id="e034e731-1026-4e76-8b88-96631da7cd0f">
        <controlMethod name="Form::load"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>load() updating;
// ---------------------------------------------------------------------------
// Created:     02 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	str	: String;
	
begin
	self.frmToolbarBtns.left := 7000;
	self.handleMenusForModalDisplay();
	
	self.modalResult := MsgBox_Return_Cancel;
	
	if self.viewOnly then
		btnOK.visible := false;
		self.tblDependOn.userInputEnabled := false;
	endif;
	if self.myTerminal &lt;&gt; null then
		self.caption := self.myTerminal.code &amp; " " &amp; self.attributeName &amp; ' properties';
	endif;
	self.setLabel();	
	self.initTblDependOn();

end;</source>
    </JadeMethod>
    <JadeMethod name="saveData" id="229b2c6f-b437-4323-9617-12fe6aa57956">
        <updating/>
        <source>saveData() updating, protected;
// ---------------------------------------------------------------------------
// Created:     02 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	idx,
	numRows	: Integer;
	tmpValue	: Boolean;
	
begin

	self.myEntTableRow.allDependencies.clear;
	numRows := self.tblDependOn.rows;
	
	foreach idx in self.tblDependOn.fixedRows + 1 to numRows do
		tmpValue := (self.tblDependOn.accessCell(idx, 2).text = '1');
		if tmpValue then
			app.writeStatement( class.name &amp; '::' &amp; method.name &amp; ' saving ' &amp; self.tblDependOn.accessCell(idx, 1).text);
			self.myEntTableRow.allDependencies.add(self.tblDependOn.accessCell(idx, 1).text);
		endif;
	endforeach;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setLabel" id="42d63501-2c47-4c3b-b40f-49b06d064664">
        <updating/>
        <source>setLabel() updating, protected;
// ---------------------------------------------------------------------------
// Created:     02 March 2001 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	
begin
	self.lblInputType.caption := 'Dependencies for ' &amp; self.attributeName;
end;</source>
        <access>protected</access>
    </JadeMethod>
</GUIClass>
