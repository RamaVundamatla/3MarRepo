        <Parameter name="value" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="delete" id="0a79d209-955b-4fb0-b2af-62ddef46364f">
        <updating/>
        <executionLocation>client</executionLocation>
        <source>delete() updating, clientExecution;
// --------------------------------------------------------------------------------
// Created:		07 March 2005 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.allSelectedCPs.purge();
	self.allDeletedCPs.purge();
end;</source>
    </JadeMethod>
    <JadeMethod name="disableAllChildren" id="4a5618c2-13c1-4537-9cdc-6475e1a525ab">
        <source>disableAllChildren();
/*
Purpose:			
Date		Who		Reason
08 July 2016	cnwab1	Initial creation
*/

vars
	children : CnEcControlArray;
	child : Control;
begin
	create children transient;
	self.cnEcGetAllChildControls(children, true);
	
	foreach child in children	discreteLock do
		child.enabled := false;
	
	endforeach;
	
	
epilog
	delete children;
end;</source>
    </JadeMethod>
    <JadeMethod name="doClearValues" id="42b32e44-7dfe-43d7-863c-bac2aa903f36">
        <source>doClearValues();
// --------------------------------------------------------------------------------
// Created:		11 May 2005 by cnwdad1
//
// Purpose:		Clears all of the receiver's Criteria/priority values.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	elementObj		: CMIF_Object;
	transientObj	: CMIF_YACriteriaPriority;
	
begin
	foreach elementObj in self.allSelectedCPs do
		transientObj	:=	elementObj.CMIF_YACriteriaPriority;
		transientObj.setFlag(false, false, true);
		self.allDeletedCPs.add(transientObj);
	endforeach;
	
	self.allSelectedCPs.clear();
	self.myDisplayWindow.yaRefreshCriteriaPriority(null);
end;</source>
    </JadeMethod>
    <JadeMethod name="doCriteriaTypeSelected" id="74540897-ce07-4cf1-9fef-7248898d9393">
        <source>doCriteriaTypeSelected();
// --------------------------------------------------------------------------------
// Created:		02 March 2005 by cnwdad1
//
// Purpose:		Processes the event of a user selecting a Criteria Attribute in the
//				combobox control.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 30/11/2009	cnwmh5		PAR 21660 - change so filters correctly
// 11/03/2010	consw1		PAR 22784 - Allow for Criteria Priority with string value
// --------------------------------------------------------------------------------
vars
	criteriaTypeObj		: CM_YACriteriaType;
	transientObj		: CMIF_YACriteriaPriority;
	allCriteriaValues	: ObjectSet;
	criteriaValueObj	: Object;
	listboxObj			: ListBox;
	listPointer			: Integer;
	str					: String;
	
begin
	criteriaTypeObj	:=	self.getSelectedCriteriaType();
	
	self.myLblStringValue.visible	:=	false;
	self.myTxtStringValue.visible	:=	false;
	self.myTxtStringValue.cnEcSet(null);
	
	if criteriaTypeObj = null then
		self.myGrpTrueFalse.visible		:=	false;
		self.myLblTransportMode.visible	:=	false;
		self.myLstTransportMode.visible	:=	false;
		self.myLstAvailable.visible		:=	true;
		self.myLstSelected.visible		:=	true;
		self.myBtnSelect.visible		:=	true;
		self.myBtnSelectAll.visible		:=	true;
		self.myBtnUnselect.visible		:=	true;
		self.myBtnUnselectAll.visible	:=	true;
		self.myTxtItemCode.cnEcSet(null);
	
	else
		self.myTxtItemCode.cnEcSet(criteriaTypeObj.description.cnEcUpto(self.myTxtItemCode.maxLength));
		
		if criteriaTypeObj.isKindOf(CM_YATypeHazardous) then			//+cnwml2 PAR24472
			self.loadCriteria(criteriaTypeObj);
		elseif criteriaTypeObj.isBooleanType() then
			self.myGrpTrueFalse.visible		:=	true;
			self.myLblTransportMode.visible	:=	false;
			self.myLstTransportMode.visible	:=	false;
			self.myLstAvailable.visible		:=	false;
			self.myLstSelected.visible		:=	false;
			self.myBtnSelect.visible		:=	false;
			self.myBtnSelectAll.visible		:=	false;
			self.myBtnUnselect.visible		:=	false;
			self.myBtnUnselectAll.visible	:=	false;
			
		elseif criteriaTypeObj.isStringType() then
			self.myLblStringValue.visible	:=	true;
			self.myTxtStringValue.visible	:=	true;
			self.myGrpTrueFalse.visible		:=	false;
			self.myLblTransportMode.visible	:=	false;
			self.myLstTransportMode.visible	:=	false;
			self.myLstAvailable.visible		:=	false;
			self.myLstSelected.visible		:=	false;
			self.myBtnSelect.visible		:=	false;
			self.myBtnSelectAll.visible		:=	false;
			self.myBtnUnselect.visible		:=	false;
			self.myBtnUnselectAll.visible	:=	false;
			
		elseif criteriaTypeObj.isTransportModeType() then
			self.myGrpTrueFalse.visible		:=	false;
			self.myLblTransportMode.visible	:=	true;
			self.myLstTransportMode.visible	:=	true;
			self.myLstAvailable.visible		:=	false;
			self.myLstSelected.visible		:=	false;
			self.myBtnSelect.visible		:=	false;
			self.myBtnSelectAll.visible		:=	false;
			self.myBtnUnselect.visible		:=	false;
			self.myBtnUnselectAll.visible	:=	false;
			
		else
			self.loadCriteria(criteriaTypeObj);				//+cnwml2 PAR24472
		endif;		
		
	endif;
	
	if self.myDisplayWindow &lt;&gt; null then
		transientObj	:=	self.getCriteriaPriorityForType(criteriaTypeObj);
		self.myDisplayWindow.yaSetCriteriaPriority(transientObj);
	endif;
epilog
end;</source>
    </JadeMethod>
    <JadeMethod name="doCriteriaValueAdd" id="35d10ce2-c035-4011-bb86-84db45a9d825">
        <source>doCriteriaValueAdd();
// --------------------------------------------------------------------------------
// Created:		28 February 2005 by cnwdad1
//
// Purpose:		Adds the selected Criteria to the Criteria table.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.doCriteriaValueAddEdit(true);
end;</source>
    </JadeMethod>
    <JadeMethod name="doCriteriaValueAddEdit" id="ae1ac748-c0f2-477b-bbd4-48aff6e1d7e2">
        <source>doCriteriaValueAddEdit(pIsAdd:Boolean) protected;
/* --------------------------------------------------------------------------------
// Created:		22 March 2005 by cnwdad1
//
// Purpose:		Adds the selected Criteria to the Criteria table.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
11 Mar 2010		consw1		PAR #22784 - Allow for Criteria Priority with string value
10 Sep 2012		cnwer1		PAR 29524 -Intended release mode 
16/03/2015		cnwmh5		Tranisent Leaks
// --------------------------------------------------------------------------------*/
vars
	allStringValues		: StringArray;
	allValuesObj		: ObjectSet;
	itemCode			: String;
	criteriaPriorityObj	: CM_YACriteriaPriority;
	transientObj		: CMIF_YACriteriaPriority;
	criteriaTypeObj		: CM_YACriteriaType;
	listboxObj			: ListBox;
	listPointer			: Integer;
	listCount			: Integer;
	allDataValues		: IntegerArray;
	booleanValue		: Integer;
	str 				: String;
	hazString			: String;
	pos					: Integer;
begin
	if not self.validateCriteria((not pIsAdd), false) then
		return;
	endif;
	
	criteriaTypeObj	:=	self.getSelectedCriteriaType();
	
	if criteriaTypeObj = null then
		return;
	endif;
	
	if (not pIsAdd) then
		transientObj		:=	self.myDisplayWindow.yaGetCriteriaPriority();
		criteriaPriorityObj	:=	transientObj.myProxy;
	endif;
	
	itemCode		:=	self.myTxtItemCode.cnEcString();
	
	if criteriaTypeObj.isKindOf(CM_YATypeHazardous) then		//+cnwml2 PAR24472
		create allStringValues transient;
		self.getSelectedCriteriaStringValue(allStringValues);
		
		if self.isCriteria and allStringValues.isEmpty() then
			return;
		endif;
		
		if pIsAdd then
			if self.isCriteria then
				create criteriaPriorityObj as CM_YACriteria transient;
			else
				create criteriaPriorityObj as CM_YAPriority transient;
			endif;
		endif;
		
		foreach str in allStringValues do
			pos := 1;
			if hazString &lt;&gt; null then
				hazString := hazString &amp; ", " &amp; str.scanUntil("-", pos).trimBlanks;
			else
				hazString := str.scanUntil("-", pos).trimBlanks;
			endif;
		endforeach;
		
		
		criteriaPriorityObj.setProxy(criteriaTypeObj, hazString, itemCode);
	
	elseif criteriaTypeObj.isBooleanType() then
		if not self.myOptTrue.value
		and not self.myOptFalse.value
		and not self.myOptEither.value
		then
			return;
		endif;
		
		if pIsAdd then
			if self.isCriteria then
				create criteriaPriorityObj as CM_YACriteria transient;
			else
				create criteriaPriorityObj as CM_YAPriority transient;
			endif;
		endif;
		
		if self.myOptTrue.value then
			booleanValue	:=	CM_YADataBoolean.VALUE_TRUE;
		elseif self.myOptFalse.value then
			booleanValue	:=	CM_YADataBoolean.VALUE_FALSE;
		elseif self.myOptEither.value then
			booleanValue	:=	CM_YADataBoolean.VALUE_EITHER;
		endif;
		
		criteriaPriorityObj.setProxy(criteriaTypeObj, booleanValue, itemCode);
		
	elseif criteriaTypeObj.isStringType() then
		
		if pIsAdd then
			if self.isCriteria then
				create criteriaPriorityObj as CM_YACriteria transient;
			else
				create criteriaPriorityObj as CM_YAPriority transient;
			endif;
		endif;
		
		criteriaPriorityObj.setProxy(criteriaTypeObj, self.myTxtStringValue.cnEcString(), itemCode);
		
	elseif criteriaTypeObj.isTransportModeType() then
		listboxObj	:=	self.myLstTransportMode;
		
		if listboxObj.listIndex = CNEC_NULL_INDEX then
			return;
		endif;
		
		if pIsAdd then
			if self.isCriteria then
				create criteriaPriorityObj as CM_YACriteria transient;
			else
				create criteriaPriorityObj as CM_YAPriority transient;
			endif;
		endif;
		
		listCount	:=	listboxObj.listCount;
		create allDataValues transient;
		
		foreach listPointer in 1 to listCount do
			if listboxObj.itemSelected[listPointer] then
				/*epr par 29524 10/9/12
				Intended Release mode was stuffed up the Transport List uses TITransportModeConstant constants
				the intenedRelease mode uses TI_IntendedReleaseModeConstant constants which mean the same except
				rail and road have different values */
				if criteriaTypeObj.isKindOf(CM_YATypeIntendedRelMode) then
					if listPointer = TI_TRANSMODE_ROAD  then
						allDataValues.add(listboxObj.itemData[TI_IntendedReleaseMode_ROAD]);
					elseif listPointer = TI_TRANSMODE_RAIL then
						allDataValues.add(listboxObj.itemData[TI_IntendedReleaseMode_RAIL]);
					else
						allDataValues.add(listboxObj.itemData[listPointer]);
					endif;
				else
			
					allDataValues.add(listboxObj.itemData[listPointer]);
				endif;
			endif;
		endforeach;
		
		criteriaPriorityObj.setProxy(criteriaTypeObj, allDataValues, itemCode);
		
	else
		create allValuesObj transient;
		self.getSelectedCriteriaValues(allValuesObj);
		
		if self.isCriteria and allValuesObj.isEmpty() then
			return;
		endif;
		
		if pIsAdd then
			if self.isCriteria then
				create criteriaPriorityObj as CM_YACriteria transient;
			else
				create criteriaPriorityObj as CM_YAPriority transient;
			endif;
		endif;
		
		criteriaPriorityObj.setProxy(criteriaTypeObj, allValuesObj, itemCode);
	endif;
	
	if pIsAdd then
		transientObj	:=	criteriaPriorityObj.getTransient();
		transientObj.setFlag(true, false, false);
		self.allSelectedCPs.add(transientObj);
	else
		if transientObj.myProxy.pxyIsProxy then // PAR 10489 AKB2005JUL, this is an existing criteria being updated
			transientObj.setFlag(false, true, false);
		else
			 // PAR 10489 AKB2005JUL. If a new criteria has additional items added it was being set as a change, when it actually was a new
			transientObj.setFlag(true,false, false);
		
		endif;
	endif;
	
	self.myDisplayWindow.yaRefreshCriteriaPriority(transientObj);
epilog
	delete allValuesObj;
	delete allDataValues;
	delete allStringValues;
end;</source>
        <access>protected</access>
        <Parameter name="pIsAdd" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doCriteriaValueDelete" id="fd6c7f60-eae5-4306-836d-bc88e030dac6">
        <source>doCriteriaValueDelete();
// --------------------------------------------------------------------------------
// Created:		28 February 2005 by cnwdad1
//
// Purpose:		Adds the selected Criteria from the Criteria table.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	transientObj	: CMIF_YACriteriaPriority;
	
begin
	if not self.validateCriteria(false, true) then
		return;
	endif;
	
	transientObj	:=	self.myDisplayWindow.yaGetCriteriaPriority();
	
	if transientObj = null then
		return;
	endif;
	
	transientObj.setFlag(false, false, true);
	self.allSelectedCPs.remove(transientObj);
	self.allDeletedCPs.add(transientObj);
	self.myDisplayWindow.yaRefreshCriteriaPriority(null);
end;</source>
    </JadeMethod>
    <JadeMethod name="doCriteriaValueUpdate" id="40e4f262-6764-4460-bd19-814c325c78a7">
        <source>doCriteriaValueUpdate();
// --------------------------------------------------------------------------------
// Created:		22 March 2005 by cnwdad1
//
// Purpose:		Updates the selected Criteria in the Criteria table.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.doCriteriaValueAddEdit(false);
end;</source>
    </JadeMethod>
    <JadeMethod name="doSelect" id="4e4d810b-eba5-4fa3-ae7f-de38093fa45b">
        <source>doSelect(pIsAll:Boolean);
// --------------------------------------------------------------------------------
// Created:		28 February 2005 by cnwdad1
//
// Purpose:		Moves one (or all) items from the available listbox control into the
//				selected listbox control.
//
// Parameters:	pIsAll - True if all items are to be selected from the "available"
//					listbox.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	tmpCriteriaPriority	: CMIF_YACriteriaPriority;

begin
	if pIsAll then
		self.myLstAvailable.cnEcMoveAll(self.myLstSelected);
	else
		self.myLstAvailable.cnEcMoveSelected(self.myLstSelected);
	endif;
	
	if self.isCriteria then
		if self.myDisplayWindow.yaGetCriteriaPriority() = null then
			self.doCriteriaValueAdd();
		else
			self.doCriteriaValueUpdate();
		endif;
	endif;
	
//if app.getMyUserCode = 'CNWRS2' then
//	tmpCriteriaPriority := self.getCriteriaPriorityForType(self.getSelectedCriteriaType());
//	if tmpCriteriaPriority &lt;&gt; null then
//		self.myDisplayWindow.yaSetCriteriaPriority(tmpCriteriaPriority);
//		self.doCriteriaValueAddEdit(false);
//	else
//		self.doCriteriaValueAddEdit(true);
//	endif;
//endif;
end;</source>
        <Parameter name="pIsAll" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doUnselect" id="eaaf3783-cb5b-488c-9719-e15e8a79808f">
        <source>doUnselect(pIsAll:Boolean);
// --------------------------------------------------------------------------------
// Created:		28 February 2005 by cnwdad1
//
// Purpose:		Moves one (or all) items from the selected listbox control into the
//				available listbox control.
//
// Parameters:	pIsAll - True if all items are to be removed from the "selected"
//					listbox.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if pIsAll then
		self.myLstSelected.cnEcMoveAll(self.myLstAvailable);
	else
		self.myLstSelected.cnEcMoveSelected(self.myLstAvailable);
	endif;
end;</source>
        <Parameter name="pIsAll" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getBooleanValue" id="5d0065e7-0859-494b-9c3c-9598f5b0f944">
        <source>getBooleanValue():Boolean;
// --------------------------------------------------------------------------------
// Created:		14 March 2005 by cnwdad1
//
// Purpose:		Returns the currently selected boolean value from the true/false
//				group box.
//
// Parameters:	None
//
// Returns:		The selected boolean value.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return self.myOptTrue.value;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getCriteriaPriorityForType" id="c29cd8ac-f82c-44ad-80a6-c1b36a9425f8">
        <source>getCriteriaPriorityForType(pCriteriaTypeObj:CM_YACriteriaType):CMIF_YACriteriaPriority protected;
// --------------------------------------------------------------------------------
// Created:		20 May 2005 by cnwdad1
//
// Purpose:		Returns the CriteriaType object in the table if it has already been
//				selected.
//
// Parameters:	pCriteriaTypeObj - A reference to the Criteria Type in question.
//
// Returns:		The Criteria Type object.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	allSelectedCriteriaObj	: CMIF_Array;
	elementObj				: CMIF_Object;
	transientObj			: CMIF_YACriteriaPriority;
	criteriaPriorityObj		: CM_YACriteriaPriority;
	
begin
	allSelectedCriteriaObj	:=	self.allSelectedCPs;
	
	foreach elementObj in allSelectedCriteriaObj do
		transientObj		:=	elementObj.CMIF_YACriteriaPriority;
		criteriaPriorityObj	:=	transientObj.myProxy;
		
		if criteriaPriorityObj.myYACriteriaType = pCriteriaTypeObj then
			return transientObj;
		endif;
	endforeach;
	
	return null;
end;</source>
        <access>protected</access>
        <Parameter name="pCriteriaTypeObj" type="CM_YACriteriaType"/>
        <ReturnType type="CMIF_YACriteriaPriority"/>
    </JadeMethod>
    <JadeMethod name="getIntegerValue" id="453e99b7-6917-4c85-a166-00b7f1c59e45">
        <source>getIntegerValue():Integer;
// --------------------------------------------------------------------------------
// Created:		14 March 2005 by cnwdad1
//
// Purpose:		Returns the currently selected integer value for the Transport Mode.
//
// Parameters:	None
//
// Returns:		The selected integer value.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	listPointer	: Integer;
	
begin
	listPointer		:=	self.myLstTransportMode.listIndex;
	
	if listPointer = CNEC_NULL_INDEX then
		return 0;
	else
		return self.myLstTransportMode.itemData[listPointer];
	endif;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getSelectedCriteriaStringValue" id="4063b319-7a9f-4808-8f80-376acfb7651a">
        <source>getSelectedCriteriaStringValue(pAllStringValues : StringArray input) protected;
//+cnwml2 PAR24472
vars
	valueObj	: String;
	listboxObj	: ListBox;
	rowPointer	: Integer;
	rowCount	: Integer;
	
begin
	listboxObj	:=	self.myLstSelected;
	
	rowCount	:=	listboxObj.listCount;
	rowPointer	:=	0;
	
	foreach rowPointer in 1 to rowCount do
		valueObj	:=	listboxObj.itemText[rowPointer];
		pAllStringValues.add(valueObj);
	endforeach;
end;</source>
        <access>protected</access>
        <Parameter name="pAllStringValues" type="StringArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getSelectedCriteriaType" id="0936f878-4939-4e85-9061-47dba7513ff2">
        <source>getSelectedCriteriaType():CM_YACriteriaType protected;
// --------------------------------------------------------------------------------
// Created:		07 March 2005 by cnwdad1
//
// Purpose:		Returns a reference to the currently selected Criteria Type in the
//				combobox control.
//
// Parameters:	None
//
// Returns:		A reference to the selected Criteria Type, or null.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return self.myCmbCriteriaType.listObject.CM_YACriteriaType;
end;</source>
        <access>protected</access>
        <ReturnType type="CM_YACriteriaType"/>
    </JadeMethod>
    <JadeMethod name="getSelectedCriteriaValues" id="49b98769-f40e-419c-ac65-f0a3cfc5f7c4">
        <source>getSelectedCriteriaValues(pAllValuesObj:ObjectSet input) protected;
// --------------------------------------------------------------------------------
// Created:		04 March 2005 by cnwdad1
//
// Purpose:		Populates the collection parameter with all of the currently selected
//				Criteria values.
//
// Parameters:	pAllValuesObj - A reference to the collection of Criteria value objects.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	valueObj	: Object;
	listboxObj	: ListBox;
	rowPointer	: Integer;
	rowCount	: Integer;
	
begin
	listboxObj	:=	self.myLstSelected;
	
	rowCount	:=	listboxObj.listCount;
	rowPointer	:=	0;
	
	foreach rowPointer in 1 to rowCount do
		valueObj	:=	listboxObj.itemObject[rowPointer];
		pAllValuesObj.add(valueObj);
	endforeach;
end;</source>
        <access>protected</access>
        <Parameter name="pAllValuesObj" type="ObjectSet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="hideCriteriaCode" id="1add373f-e88a-4363-886f-816f67da7b6c">
        <updating/>
        <source>hideCriteriaCode() updating;
// --------------------------------------------------------------------------------
// Created:		18 March 2005 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.isCriteriaCodeHidden		:=	true;
	self.myLblCriteriaCode.visible	:=	false;
	self.myTxtItemCode.visible		:=	false;
	self.myGrpTrueFalse.move(160, 45, self.myGrpTrueFalse.width, self.myGrpTrueFalse.height);
	self.myLblTransportMode.move(5, 30, 80, 21);
	self.myLstTransportMode.move(90, 35, 298, 110);
	self.myLstAvailable.move(5, 35, 175, 110);
	self.myBtnSelect.move(184, 35, 25, 25);
	self.myBtnSelectAll.move(self.myBtnSelect.left, 63, 25, 25);
	self.myBtnUnselect.move(self.myBtnSelect.left, 91, 25, 25);
	self.myBtnUnselectAll.move(self.myBtnSelect.left, 119, 25, 25);
	self.myLstSelected.move(213, self.myLstAvailable.top, self.myLstAvailable.width, self.myLstAvailable.height);
	self.myBtnUpdate.move(112, 148, 90, 25);
	self.myBtnAdd.move((self.myBtnUpdate.left + self.myBtnUpdate.width + 3), self.myBtnUpdate.top, 90, 25);
	self.myBtnDelete.move((self.myBtnAdd.left + self.myBtnAdd.width + 3), self.myBtnUpdate.top, 90, 25);
end;</source>
    </JadeMethod>
    <JadeMethod name="isCriteriaTypeAlreadyUsed" id="6f052e09-4e42-46a9-b606-715dd3bd23cc">
        <source>isCriteriaTypeAlreadyUsed(pCriteriaTypeObj:CM_YACriteriaType; pAllValues:Any):Boolean protected;
// --------------------------------------------------------------------------------
// Created:		20 May 2005 by cnwdad1
//
// Purpose:		Returns a boolean flag to indicate whether the specified Criteria
//				Type has already been selected.  The rule is, that a Criteria Type
//				can only be used once.
//
// Parameters:	pCriteriaTypeObj - A reference to the Criteria Type in question.
//				pAllValues - An array of data values to check (for whether they're
//					already used).  The Type of the array will depend upon the Type
//					of the data values being checked.
//
// Returns:		True if the Criteria Type has already been selected, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	allSelectedCriteriaObj	: CMIF_Array;
	elementObj				: CMIF_Object;
	transientObj			: CMIF_YACriteriaPriority;
	criteriaPriorityObj		: CM_YACriteriaPriority;
	
begin
	allSelectedCriteriaObj	:=	self.allSelectedCPs;
	
	foreach elementObj in allSelectedCriteriaObj do
		transientObj		:=	elementObj.CMIF_YACriteriaPriority;
		criteriaPriorityObj	:=	transientObj.myProxy;
		
		if criteriaPriorityObj.myYACriteriaType = pCriteriaTypeObj then
			if self.isCriteria then
				return true;
			else
				if transientObj.isValueUsed(pAllValues) then
					return true;
				endif;
			endif;
		endif;
	endforeach;
	
	return false;
end;</source>
        <access>protected</access>
        <Parameter name="pCriteriaTypeObj" type="CM_YACriteriaType"/>
        <Parameter name="pAllValues" type="Any"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="loadCriteria" id="f492036b-71ef-4b67-9c2b-f7076d415246">
        <source>loadCriteria(_criteriaTypeObj : CM_YACriteriaType);
//23 July 2010	cnwml2
//+cnwml2 PAR24472

vars
	allCriteriaValues	: ObjectSet;
	allStringValues		: StringArray;
	criteriaValueObj	: Object;
	listboxObj			: ListBox;
	listPointer			: Integer;
	str					: String;
begin
	listboxObj	:=	self.myLstAvailable;
	listboxObj.clear();
	self.myLstSelected.clear();
	

	if _criteriaTypeObj.isKindOf(CM_YATypeHazardous) then
		create allStringValues transient;
		_criteriaTypeObj.CM_YATypeHazardous.getAllHazardValues(self.form.CM_BaseForm.myTerminal, allStringValues, YAFilterOpt_None);
	
		foreach str in allStringValues do
			//str := criteriaValueObj.getYADisplay();		
			if str &lt;&gt; null then
				listPointer	:=	listboxObj.addItem(str);
				///listPointer	:=	listboxObj.addItem(criteriaValueObj.getYADisplay());
				//listboxObj.itemObject[listPointer]	:=	criteriaValueObj;
			endif;
		endforeach;
	else
		create allCriteriaValues transient;
		//cnwmc5 - PAR 31255
		_criteriaTypeObj.getAllCriteriaValues(self.form.CM_BaseForm.myTerminal, allCriteriaValues, YAFilterOpt_None, null); //YAFilterOpt_None Needs to be replaced with filter
	
		foreach criteriaValueObj in allCriteriaValues do
			str := criteriaValueObj.getYADisplay();		// 30/11/2009 cnwmh5 #21660
			if str &lt;&gt; null then
				listPointer	:=	listboxObj.addItem(str);
				///listPointer	:=	listboxObj.addItem(criteriaValueObj.getYADisplay());
				listboxObj.itemObject[listPointer]	:=	criteriaValueObj;
			endif;
		endforeach;
	endif;
	
	self.myGrpTrueFalse.visible		:=	false;
	self.myLblTransportMode.visible	:=	false;
	self.myLstTransportMode.visible	:=	false;
	self.myLstAvailable.visible		:=	true;
	self.myLstSelected.visible		:=	true;
	self.myBtnSelect.visible		:=	true;
	self.myBtnSelectAll.visible		:=	true;
	self.myBtnUnselect.visible		:=	true;
	self.myBtnUnselectAll.visible	:=	true;
epilog
	delete allCriteriaValues;
	delete allStringValues;
end;</source>
        <Parameter name="_criteriaTypeObj" type="CM_YACriteriaType"/>
    </JadeMethod>
    <JadeMethod name="loadDetails" id="50662995-20ef-44a7-9ae7-fe8f985e5257">
        <source>loadDetails(pCriteriaPriorityObj:CMIF_YACriteriaPriority);
/* --------------------------------------------------------------------------------
// Created:		22 March 2005 by cnwdad1
//
// Purpose:		Pre-sets the details for the specified Yard Allocation Criteria/
//				Priority object.
//
// Parameters:	pCriteriaPriorityObj - A reference to the Criteria/Priority object.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
30/11/2009		cnwmh5		PAR #21660 - Change so filters correctly
11/03/2010		consw1		PAR #22784 - Allow for Criteria Priority with string value
10 Sep 2012		cnwer1		PAR 29524 -Intended release mode 
// --------------------------------------------------------------------------------*/
vars
	criteriaPriorityObj	: CM_YACriteriaPriority;
	dataObj				: CM_YAData;
	listboxObj			: ListBox;
	transportListboxObj	: ListBox;
	valueObj			: Object;
	listPointer			: Integer;
	integerValue		: Integer;
	str					: String;			// 30/11/2009 cnwmh5 #21660
	strArray			: StringArray;
	haz					: CM_HazardClass;
	strHaz				: String;
	intHaz				: Integer;
begin
	if pCriteriaPriorityObj = null then
		self.myCmbCriteriaType.listIndex	:=	CNEC_NULL_INDEX;
		self.myLstTransportMode.listIndex	:=	CNEC_NULL_INDEX;
		self.myTxtItemCode.cnEcSet(null);
		self.myLstAvailable.clear();
		self.myLstSelected.clear();
		
		return;
	endif;
	
	criteriaPriorityObj	:=	pCriteriaPriorityObj.myProxy;
	if criteriaPriorityObj.myYACriteriaType.isKindOf(CM_YATypeHazardous) then			//PAR 24673
		self.loadCriteria(criteriaPriorityObj.myYACriteriaType);
	endif;
	
	if self.myCmbCriteriaType.listObject &lt;&gt; criteriaPriorityObj.myYACriteriaType then
		// This avoids a stack overflow if the Criteria Type combobox has just been
		// clicked, and we're just preselecting stuff for a Criteria/Priority that
		// has already been set up.
		self.myCmbCriteriaType.cnEcSetObjectIndex(criteriaPriorityObj.myYACriteriaType);
		self.doCriteriaTypeSelected();
	endif;
	
	self.myTxtItemCode.cnEcSet(criteriaPriorityObj.code);
	
	dataObj		:=	criteriaPriorityObj.myYAData;
	listboxObj	:=	self.myLstAvailable;

	if dataObj.isPrimitiveValue() then
		//+cnwml2 PAR24472
		if criteriaPriorityObj.myYACriteriaType.isKindOf(CM_YATypeHazardous) then
			create strArray transient;
			//if criteriaPriorityObj.myYAData.CM_YADataString.value.containsOneOf(",") then				//-cnwml2 PAR25298
			if criteriaPriorityObj.myYAData.CM_YADataString.value &lt;&gt; null and criteriaPriorityObj.myYAData.CM_YADataString.value.containsOneOf(",") then			//+cnwml2 PAR25298				
				criteriaPriorityObj.myYAData.CM_YADataString.value.getTokensForDelimiter(",", strArray);
				foreach str in strArray do
					str := str.trimBlanks();
					listPointer	:=	listboxObj.findString(1, str);
					if not listPointer = CNEC_NULL_INDEX then
						listboxObj.removeItem(listPointer);
						if str &lt;&gt; null then
							strHaz := str;
							if strHaz.containsOneOf("L") then
								intHaz := strHaz.pos("L", 1);
								if intHaz = strHaz.length then
									strHaz := strHaz.truncatedAt(strHaz.length -1);
								endif;
							endif;
							haz := app.myRoot.allHazardClasses[strHaz];
							
							self.myLstSelected.addItem(str &amp; " - " &amp; haz.description);
						endif;
					endif;
				endforeach;
			endif;
		elseif dataObj.isBooleanValue() then
			self.myOptTrue.cnEcSet(dataObj.CM_YADataBoolean.value = CM_YADataBoolean.VALUE_TRUE);
			self.myOptFalse.cnEcSet(dataObj.CM_YADataBoolean.value = CM_YADataBoolean.VALUE_FALSE);
			self.myOptEither.cnEcSet(dataObj.CM_YADataBoolean.value = CM_YADataBoolean.VALUE_EITHER);
			
		elseif dataObj.isIntegerValue() then
			transportListboxObj	:=	self.myLstTransportMode;
			transportListboxObj.clearAllSelected();
			foreach integerValue in dataObj.CM_YADataInteger.allValues do
				/*epr par 29525 10/9/12
				Intended Release mode was stuffed up the Transport List uses TITransportModeConstant constants
				the intenedRelease mode uses TI_IntendedReleaseModeConstant constants which are the same except
				rail and road have different values */
				if criteriaPriorityObj.myYACriteriaType.isKindOf(CM_YATypeIntendedRelMode) then
					if integerValue = TI_IntendedReleaseMode_ROAD then
						listPointer	:=	transportListboxObj.findItemData(TI_TRANSMODE_ROAD);
					elseif integerValue = TI_IntendedReleaseMode_RAIL then
						listPointer	:=	transportListboxObj.findItemData(TI_TRANSMODE_RAIL);
					else
						listPointer	:=	transportListboxObj.findItemData(integerValue);
					endif;
				else
					listPointer	:=	transportListboxObj.findItemData(integerValue);
				endif;
				
				
				if listPointer &lt;&gt; CNEC_NULL_INDEX then
					transportListboxObj.itemSelected[listPointer]	:=	true;
				endif;
			endforeach;
		elseif dataObj.isStringValue() then
			self.myTxtStringValue.cnEcSet(dataObj.CM_YADataString.value);
		endif;
	else
		foreach valueObj in dataObj.CM_YADataObjects.allObjects do
			listPointer	:=	listboxObj.findObject(valueObj);
			if not listPointer = CNEC_NULL_INDEX then
				listboxObj.removeItem(listPointer);
				str := valueObj.getYADisplay();					// 30/11/2009 cnwmh5 #21660
				if str &lt;&gt; null then
					self.myLstSelected.itemObject[self.myLstSelected.addItem(str)]	:=	valueObj;
				endif;
			endif;
		endforeach;
	
	endif;

epilog
	delete strArray; 
end;</source>
        <Parameter name="pCriteriaPriorityObj" type="CMIF_YACriteriaPriority"/>
    </JadeMethod>
    <JadeMethod name="preloadCriteriaPriorities" id="b062fa88-b9ae-45d2-a0b4-d3f6e2a8e24a">
        <source>preloadCriteriaPriorities(pAllCriteria:CM_YACriteriaPriorityArray);
// --------------------------------------------------------------------------------
// Created:		16 March 2005 by cnwdad1
//
// Purpose:		Pre-loads existing Criteria.
//
// Parameters:	pAllCriteria - A collection of Yard Allocation Criteria.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	criteriaPriorityObj	: CM_YACriteriaPriority;
	transientObj		: CMIF_YACriteriaPriority;
	
begin
	self.allDeletedCPs.purge();
	self.allSelectedCPs.purge();
	
	foreach criteriaPriorityObj in pAllCriteria do
		transientObj	:=	criteriaPriorityObj.getTransient();
		self.allSelectedCPs.add(transientObj);
	endforeach;
end;</source>
        <Parameter name="pAllCriteria" type="CM_YACriteriaPriorityArray"/>
    </JadeMethod>
    <JadeMethod name="setDisplayWindow" id="ba35d39c-b026-48dc-9534-792bd00716c5">
        <updating/>
        <source>setDisplayWindow(pWindowObj:Window) updating;
// --------------------------------------------------------------------------------
// Created:		16 March 2005 by cnwdad1
//
// Purpose:		Sets a reference to the form or control that is used to display the
//				Yard Allocation Criteria.
//
// Parameters:	pWindowObj - A reference to the display window.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.myDisplayWindow	:=	pWindowObj;
end;</source>
        <Parameter name="pWindowObj" type="Window"/>
    </JadeMethod>
    <JadeMethod name="setTabOrders" id="bce8a80e-44c1-4c07-abf8-c4bffb2e21e7">
        <source>setTabOrders();
// --------------------------------------------------------------------------------
// Created:		02 May 2005 by cnwdad1
//
// Purpose:		Sets the tab ordering of the receiver's child controls.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 11/03/2010	consw1		PAR 22784 - Allow for Criteria Priority with string value
// --------------------------------------------------------------------------------
begin
	self.myLblCriteriaType.tabIndex		:=	self.tabIndex + 1;
	self.myCmbCriteriaType.tabIndex		:=	self.myLblCriteriaType.tabIndex + 1;
	self.myLblCriteriaCode.tabIndex		:=	self.myCmbCriteriaType.tabIndex + 1;
	self.myTxtItemCode.tabIndex			:=	self.myLblCriteriaCode.tabIndex + 1;
	self.myLblStringValue.tabIndex		:=	self.myTxtItemCode.tabIndex + 1;
	self.myTxtStringValue.tabIndex		:=	self.myLblStringValue.tabIndex + 1;
	self.myLstAvailable.tabIndex		:=	self.myTxtStringValue.tabIndex + 1;
	self.myBtnSelect.tabIndex			:=	self.myLstAvailable.tabIndex + 1;
	self.myBtnSelectAll.tabIndex		:=	self.myBtnSelect.tabIndex + 1;
	self.myBtnUnselect.tabIndex			:=	self.myBtnSelectAll.tabIndex + 1;
	self.myBtnUnselectAll.tabIndex		:=	self.myBtnUnselect.tabIndex + 1;
	self.myLstSelected.tabIndex			:=	self.myBtnUnselectAll.tabIndex + 1;
	self.myGrpTrueFalse.tabIndex		:=	self.myLstSelected.tabIndex + 1;
	self.myOptTrue.tabIndex				:=	self.myGrpTrueFalse.tabIndex + 1;
	self.myOptFalse.tabIndex			:=	self.myOptTrue.tabIndex + 1;
	self.myOptEither.tabIndex			:=	self.myOptFalse.tabIndex + 1;
	self.myLblTransportMode.tabIndex	:=	self.myOptEither.tabIndex + 1;
	self.myLstTransportMode.tabIndex	:=	self.myLblTransportMode.tabIndex + 1;
	self.myBtnUpdate.tabIndex			:=	self.myLstTransportMode.tabIndex + 1;
	self.myBtnAdd.tabIndex				:=	self.myBtnUpdate.tabIndex + 1;
	self.myBtnDelete.tabIndex			:=	self.myBtnAdd.tabIndex + 1;
end;</source>
    </JadeMethod>
    <JadeMethod name="setupChildControls" id="ad04b4b4-c753-4030-9564-b5441ce5eb7f">
        <updating/>
        <source>setupChildControls() updating, protected;
// --------------------------------------------------------------------------------
// Created:		28 February 2005 by cnwdad1
//
// Purpose:		Sets up the receiver's child controls.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 29/03/2006	cnwdad1		Made the Criteria Type and Code labels 20 longer (to
//							accomodate the new Verdana font), and moved their
//							respective fields to the right by 20.
// 11/03/2010	consw1		PAR 22784 - Allow for Criteria Priority with string value
// --------------------------------------------------------------------------------
vars
	listPointer	: Integer;
	
begin
	create self.myLblCriteriaType transient;
	self.myLblCriteriaType.caption			:=	"Criteria Attribute";
	self.myLblCriteriaType.transparent		:=	true;
	self.myLblCriteriaType.parent			:=	self;
	self.myLblCriteriaType.parentAspect	:=	Control.ParentAspect_None;
	self.form.addControl(self.myLblCriteriaType);
	self.myLblCriteriaType.move(5, 10, 100, 21);
	
	create self.myCmbCriteriaType transient;
	self.myCmbCriteriaType.parent			:=	self;
	self.myCmbCriteriaType.parentAspect		:=	Control.ParentAspect_None;
	self.form.addControl(self.myCmbCriteriaType);
	self.myCmbCriteriaType.move(110, 8, 278, 21);
	self.myCmbCriteriaType.setCriteriaControl(self);
	
	// The following Criteria Code textbox will only be visible when the receiver
	// is used standalone.  If the receiver is used in conjunction with the Yard
	// Allocation control, then this code is not used.
	
	create self.myLblCriteriaCode transient;
	self.myLblCriteriaCode.caption			:=	"Attribute Code";
	self.myLblCriteriaCode.alignment		:=	Label.Alignment_Left_Middle;
	self.myLblCriteriaCode.transparent		:=	true;
	self.myLblCriteriaCode.parent			:=	self;
	self.myLblCriteriaCode.parentAspect		:=	Control.ParentAspect_None;
	self.form.addControl(self.myLblCriteriaCode);
	self.myLblCriteriaCode.move(5, 33, 100, 21);
	
	create self.myTxtItemCode transient;
	self.myTxtItemCode.maxLength			:=	10;
	self.myTxtItemCode.parent				:=	self;
	self.myTxtItemCode.parentAspect			:=	Control.ParentAspect_None;
	self.form.addControl(self.myTxtItemCode);
	self.myTxtItemCode.move(110, 33, 150, 21);

	create self.myLblStringValue transient;
	self.myLblStringValue.caption			:=	"Attribute Value";
	self.myLblStringValue.alignment		:=	Label.Alignment_Left_Middle;
	self.myLblStringValue.transparent		:=	true;
	self.myLblStringValue.parent			:=	self;
	self.myLblStringValue.parentAspect		:=	Control.ParentAspect_None;
	self.form.addControl(self.myLblStringValue);
	self.myLblStringValue.move(5, 60, 100, 21);
	
	create self.myTxtStringValue transient;
	self.myTxtStringValue.maxLength			:=	62;	// Max length for StringArray
	self.myTxtStringValue.scrollHorizontal	:=	true;
	self.myTxtStringValue.parent			:=	self;
	self.myTxtStringValue.parentAspect		:=	Control.ParentAspect_None;
	self.form.addControl(self.myTxtStringValue);
	self.myTxtStringValue.move(110, 60, 278, 21);
	
	// The following three controls will normally be invisible, unless a specific
	// type of Criteria Attribute is selected in the above combobox control, in
	// which case these three controls will be visible and the lists of available
	// and selected items will become invisible.
	
	create self.myGrpTrueFalse transient;
	self.myGrpTrueFalse.caption				:=	null;
	self.myGrpTrueFalse.transparent			:=	true;
	self.myGrpTrueFalse.parent				:=	self;
	self.myGrpTrueFalse.parentAspect		:=	Control.ParentAspect_None;
	self.form.addControl(self.myGrpTrueFalse);
	self.myGrpTrueFalse.move(160, 70, 100, 85);
	
	create self.myOptTrue transient;
	self.myOptTrue.caption					:=	"True";
	self.myOptTrue.value					:=	true;
	self.myOptTrue.transparent				:=	true;
	self.myOptTrue.parent					:=	self.myGrpTrueFalse;
	self.myOptTrue.parentAspect				:=	Control.ParentAspect_None;
	self.form.addControl(self.myOptTrue);
	self.myOptTrue.move(30, 10, 60, 21);
	
	create self.myOptFalse transient;
	self.myOptFalse.caption					:=	"False";
	self.myOptFalse.value					:=	false;
	self.myOptFalse.transparent				:=	true;
	self.myOptFalse.parent					:=	self.myGrpTrueFalse;
	self.myOptFalse.parentAspect			:=	Control.ParentAspect_None;
	self.form.addControl(self.myOptFalse);
	self.myOptFalse.move(self.myOptTrue.left, 35, 60, 21);
	
	create self.myOptEither transient;
	self.myOptEither.caption				:=	"Either";
	self.myOptEither.value					:=	false;
	self.myOptEither.transparent			:=	true;
	self.myOptEither.parent					:=	self.myGrpTrueFalse;
	self.myOptEither.parentAspect			:=	Control.ParentAspect_None;
	self.form.addControl(self.myOptEither);
	self.myOptEither.move(self.myOptTrue.left, 60, 60, 21);
	
	// As per the above myGrpTrueFalse group box, the following combobox (and its associated
	// label) will normally be invisible, unless a specific type of Criteria Attribute
	// is selected in the above combobox control, in which case these controls will be
	// visible and the lists of available and selected items will become invisible.
	
	create self.myLblTransportMode transient;
	self.myLblTransportMode.caption			:=	"Transport Mode";
	self.myLblTransportMode.transparent		:=	true;
	self.myLblTransportMode.alignment		:=	Label.Alignment_Left_Middle;
	self.myLblTransportMode.parent			:=	self;
	self.myLblTransportMode.parentAspect	:=	Control.ParentAspect_None;
	self.form.addControl(self.myLblTransportMode);
	self.myLblTransportMode.move(5, 59, 90, 21);
	
	create self.myLstTransportMode transient;
	self.myLstTransportMode.multiSelect		:=	ListBox.MultiSelect_Extended;
	self.myLstTransportMode.parent			:=	self;
	self.myLstTransportMode.parentAspect	:=	Control.ParentAspect_None;
	self.form.addControl(self.myLstTransportMode);
	self.myLstTransportMode.move(100, self.myLblTransportMode.top - 1, 288, 110);
	
	listPointer	:=	self.myLstTransportMode.addItem(TI_TRANSMODE_RAIL_STR);
	self.myLstTransportMode.itemData[listPointer]	:=	TI_TRANSMODE_RAIL;
	listPointer	:=	self.myLstTransportMode.addItem(TI_TRANSMODE_ROAD_STR);
	self.myLstTransportMode.itemData[listPointer]	:=	TI_TRANSMODE_ROAD;
	listPointer	:=	self.myLstTransportMode.addItem(TI_TRANSMODE_SHIP_STR);
	self.myLstTransportMode.itemData[listPointer]	:=	TI_TRANSMODE_SHIP;
	listPointer	:=	self.myLstTransportMode.addItem(TI_TRANSMODE_NULL_STR);
	self.myLstTransportMode.itemData[listPointer]	:=	TI_TRANSMODE_NULL;
	
	// The following two listboxes, the Select/Unselect buttons, and the Add/Delete
	// buttons will become invisible when the above true/false group box is made
	// visible, which is dependant upon the type of Criteria Attribute that is
	// selected in the combobox at the top of this control.
	
	create self.myLstAvailable transient;
	self.myLstAvailable.sortAsc			:=	true;
	self.myLstAvailable.sortCased		:=	true;
	self.myLstAvailable.sorted			:=	true;
	self.myLstAvailable.multiSelect		:=	ListBox.MultiSelect_Extended;
	self.myLstAvailable.parent			:=	self;
	self.myLstAvailable.parentAspect	:=	Control.ParentAspect_None;
	self.myLstAvailable.setCriteriaControl(self, true, false);
	self.form.addControl(self.myLstAvailable);
	self.myLstAvailable.move(5, 61, 175, 110);
	
	create self.myBtnSelect transient;
	self.myBtnSelect.caption			:=	"&gt;";
	self.myBtnSelect.fontBold			:=	true;
	self.myBtnSelect.parent				:=	self;
	self.myBtnSelect.parentAspect		:=	Control.ParentAspect_None;
	self.myBtnSelect.setCriteriaControl(self, false, false, false, true, false, false, false);
	self.form.addControl(self.myBtnSelect);
	self.myBtnSelect.move(184, 61, 25, 25);
	
	create self.myBtnSelectAll transient;
	self.myBtnSelectAll.caption			:=	"&gt;&gt;";
	self.myBtnSelectAll.fontBold		:=	true;
	self.myBtnSelectAll.parent			:=	self;
	self.myBtnSelectAll.parentAspect	:=	Control.ParentAspect_None;
	self.myBtnSelectAll.setCriteriaControl(self, false, false, false, false, true, false, false);
	self.form.addControl(self.myBtnSelectAll);
	self.myBtnSelectAll.move(self.myBtnSelect.left, 89, 25, 25);
	
	create self.myBtnUnselect transient;
	self.myBtnUnselect.caption			:=	"&lt;";
	self.myBtnUnselect.fontBold			:=	true;
	self.myBtnUnselect.parent			:=	self;
	self.myBtnUnselect.parentAspect		:=	Control.ParentAspect_None;
	self.myBtnUnselect.setCriteriaControl(self, false, false, false, false, false, true, false);
	self.form.addControl(self.myBtnUnselect);
	self.myBtnUnselect.move(self.myBtnSelect.left, 117, 25, 25);
	
	create self.myBtnUnselectAll transient;
	self.myBtnUnselectAll.caption		:=	"&lt;&lt;";
	self.myBtnUnselectAll.fontBold		:=	true;
	self.myBtnUnselectAll.parent		:=	self;
	self.myBtnUnselectAll.parentAspect	:=	Control.ParentAspect_None;
	self.myBtnUnselectAll.setCriteriaControl(self, false, false, false, false, false, false, true);
	self.form.addControl(self.myBtnUnselectAll);
	self.myBtnUnselectAll.move(self.myBtnSelect.left, 145, 25, 25);
	
	create self.myLstSelected transient;
	self.myLstSelected.sortAsc			:=	true;
	self.myLstSelected.sortCased		:=	true;
	self.myLstSelected.sorted			:=	true;
	self.myLstSelected.multiSelect		:=	ListBox.MultiSelect_Extended;
	self.myLstSelected.parent			:=	self;
	self.myLstSelected.parentAspect		:=	Control.ParentAspect_None;
	self.myLstSelected.setCriteriaControl(self, false, true);
	self.form.addControl(self.myLstSelected);
	self.myLstSelected.move(213, self.myLstAvailable.top, self.myLstAvailable.width, self.myLstAvailable.height);
	
	create self.myBtnUpdate transient;
	self.myBtnUpdate.caption			:=	"Update";
	self.myBtnUpdate.parent				:=	self;
	self.myBtnUpdate.parentAspect		:=	Control.ParentAspect_None;
	self.myBtnUpdate.setCriteriaControl(self, true, false, false, false, false, false, false);
	self.form.addControl(self.myBtnUpdate);
	self.myBtnUpdate.move(112, 173, 90, 25);
	
	create self.myBtnAdd transient;
	self.myBtnAdd.caption				:=	"Add";
	self.myBtnAdd.parent				:=	self;
	self.myBtnAdd.parentAspect			:=	Control.ParentAspect_None;
	self.myBtnAdd.setCriteriaControl(self, false, true, false, false, false, false, false);
	self.form.addControl(self.myBtnAdd);
	self.myBtnAdd.move((self.myBtnUpdate.left + self.myBtnUpdate.width + 3), self.myBtnUpdate.top, 90, 25);
	
	create self.myBtnDelete transient;
	self.myBtnDelete.caption			:=	"Delete";
	self.myBtnDelete.parent				:=	self;
	self.myBtnDelete.parentAspect		:=	Control.ParentAspect_None;
	self.myBtnDelete.setCriteriaControl(self, false, false, true, false, false, false, false);
	self.form.addControl(self.myBtnDelete);
	self.myBtnDelete.move((self.myBtnAdd.left + self.myBtnAdd.width + 3), self.myBtnUpdate.top, 90, 25);
	
	self.doCriteriaTypeSelected();
	self.setTabOrders();
end;</source>
        <access>protected</access>
