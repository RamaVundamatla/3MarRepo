/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 February 2019	jlger1	Initial creation TFS 41398

*/

vars
	measurmentTypes : StringArray;
	measurementType 		: CM_MeasurementType;
	str,
	tmpStr	: String;
begin
	//epr TFS 41398 19/2/19
	create measurmentTypes transient;
	self.getAllMeasurementTypesUsed(measurmentTypes);
	foreach str in measurmentTypes discreteLock do
		measurementType:=str.asOid.CM_MeasurementType;
		if tmpStr = null then
			tmpStr := self.getTotalsByUnit(true,false,measurementType);
		else
			tmpStr := tmpStr &amp; ", " &amp;self.getTotalsByUnit(true,false,measurementType);		
		endif;
	endforeach;
	return tmpStr;
epilog
	delete measurmentTypes;
end;</source>
