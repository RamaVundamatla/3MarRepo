    <JadeMethod name="jssSetCellBackColor" id="7fdee8b4-8cc2-4031-a549-d75cc4033dfb">
        <updating/>
        <source>jssSetCellBackColor(pRow:Integer; pColumn:Integer; pColor:Integer) updating;
// --------------------------------------------------------------------------------
// Created:		02 May 1999 - cnEcSetCellBackColor
// By:			cnwdad1
//
// Purpose:		Assigns the specified backcolor to a cell for the specified row and column.
//
// Parameters:	pRow (Integer) - The cell row number.
//				pColumn (Integer) - The cell column.
//				pColor (Integer) - The colour to assign to the cell's backcolor.
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	cRow	: Integer;
	cColumn	: Integer;
	mode	: Integer;

begin
	mode			:=	self.accessMode;
	self.accessMode	:=	Table.AccessMode_Cell;
	cRow			:=	self.row;
	cColumn			:=	self.column;
	self.row		:=	pRow;
	self.column		:=	pColumn;
	self.backColor	:=	pColor;
	self.row		:=	cRow;
	self.column		:=	cColumn;
	self.accessMode	:=	mode;
end;</source>
        <text>___________________________________________________________________________

