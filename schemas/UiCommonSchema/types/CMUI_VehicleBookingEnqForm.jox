    <JadeMethod name="buildCmbCarrier" id="17d8a05c-1323-4967-8a7d-0652f774b458">
        <source>buildCmbCarrier();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 September 2022	navhl20	ChangeRequest 53900: EUP - VBS MTN - [4] - Search Screen
*/

vars
	carrier : CM_Carrier;
begin
	self.cmbCarrier.clear();
	
	self.cmbCarrier.addItem(Empty_String);

	foreach carrier in app.myRoot.allCarriersRoad do
		self.cmbCarrier.addItemObject(carrier.description, carrier);
	endforeach;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="buildCmbCreationMethod" id="ad9d5346-1674-408c-a1cf-2d6dfa813584">
        <source>buildCmbCreationMethod();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 Jul 2023	navma1	ChangeRequest 59136: EUP | VBS Edi Enhancement [1]

*/

vars

begin
	self.cmbCreationMethod.clear();
	self.cmbCreationMethod.addItemWithData(CreationMethod_Any_Value, CreationMethod_Any_Item);
	self.cmbCreationMethod.addItemWithData(app.getErrorString(BGP), 	CM_VehicleBookingTimeSlot.Creation_Method_BGP);
	self.cmbCreationMethod.addItemWithData(app.getErrorString(EDI), 	CM_VehicleBookingTimeSlot.Creation_Method_EDI);
	self.cmbCreationMethod.addItemWithData(app.getErrorString(Manual),  CM_VehicleBookingTimeSlot.Creation_Method_MANUAL);
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="buildCmbDirection" id="53c1bfe2-404a-4b58-8a24-20775f5cc032">
        <source>buildCmbDirection();
/*

Purpose:			

Parameters:			

Return Value:		

Date		 Who		Reason
23 Sept 2022 navhl20	ChangeRequest 53900: EUP - VBS MTN - [4] - Search Screen
25 Aug 2023	navlw1		Bug 60046:[60047] FR | 53429 - VBS MTN - Enquiry Screen issues

*/

vars

begin
	self.cmbDirection.clear;
	self.cmbDirection.addItemWithData(app.getErrorString(VBS_direction_pickup),   DIRECTION_PICKUP);
	self.cmbDirection.addItemWithData(app.getErrorString(VBS_direction_delivery), DIRECTION_DELIVERY);
	self.cmbDirection.addItemWithData(self.Direction_Any_Value, self.DIRECTION_ANY);
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="buildCmbDiver" id="efce3aae-91df-412a-b263-d326389eaa62">
        <source>buildCmbDiver();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 September 2022	navhl20	ChangeRequest 53900: EUP - VBS MTN - [4] - Search Screen

*/

vars
	iter : Iterator;
	driver : CM_DriverDetails;
	carrier : CM_Carrier;
	idx : Integer;
begin
	self.cmbDriver.clear();
	
	self.cmbDriver.addItem(Empty_String);
	carrier := self.cmbCarrier.getCurrentItemObject.CM_Carrier;
	if carrier &lt;&gt; null then
		self.cmbDriver.enabled := true; 
		iter := carrier.allDrivers.createIterator;
		while iter.next( driver ) do
			if driver.myTerminal = self.myTerminal then
				idx := self.cmbDriver.addItem( driver.name );
				self.cmbDriver.itemObject[idx] := driver;
			endif;
		endwhile;
	endif;
epilog
	delete iter;
end;</source>
    </JadeMethod>
    <JadeMethod name="buildCmbMonth" id="eb900a28-1a65-46f0-b943-76e6ef9a0399">
        <source>buildCmbMonth();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 September 2022	navhl20	ChangeRequest 53900: EUP - VBS MTN - [4] - Search Screen

*/

vars

begin
	self.cmbMonth.clear;
	
	self.cmbMonth.addItemAt("January",1);
	self.cmbMonth.addItemAt("February",2);
	self.cmbMonth.addItemAt("March",3);
	self.cmbMonth.addItemAt("April",4);
	self.cmbMonth.addItemAt("May",5);
	self.cmbMonth.addItemAt("June",6);
	self.cmbMonth.addItemAt("July",7);
	self.cmbMonth.addItemAt("August",8);
	self.cmbMonth.addItemAt("September",9);
	self.cmbMonth.addItemAt("October",10);
	self.cmbMonth.addItemAt("November",11);
	self.cmbMonth.addItemAt("December",12);
	
	self.cmbMonth.listIndex := app.cnGetServerTime().Date.month;
epilog

end;</source>
