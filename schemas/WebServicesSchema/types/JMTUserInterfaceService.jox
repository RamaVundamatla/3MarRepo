    <JadeWebServicesMethod name="getSubTerminals" id="f9f164a4-b066-43d4-b802-2f6f66270dfc">
        <source>getSubTerminals() : WS_SubTerminalResponse webService;

/*

Purpose:			Get all the valid SubTerminals the current user.

Parameters:			None

Return Value:		


Date		Who		Reason
22 Apr 2009	cnwdz2	CCMS1735

*/

vars
	response		: WS_SubTerminalResponse;
	completedOK		: Boolean;
	myTerminal		: CM_Terminal;
	
	subTerminal		: CM_SubTerminal;
	proxySubTerminal: WS_SubTerminal;
	failedDAC  		: CM_DataAccessController;
	passport		: CM_Passport;
	
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);

	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
	
	passport := app.myPassport;
	myTerminal := passport.myTerminal;
	
	//epr TFS 2526 29/9/16
	if not app.isSubTerminalsOn(myTerminal) then
		completedOK :=true;
		return response;
	endif;
	
	// Populate response - cloned from CMUI_ComboCommodity
	foreach subTerminal in myTerminal.allSubTerminals discreteLock do		
		if not subTerminal.canUserAccessSelf(null, failedDAC, passport) then
			continue;
		endif;
		
		create proxySubTerminal transient;
		proxySubTerminal.setProxyFromObject(subTerminal);
		response.allSubTerminals.add(proxySubTerminal);
		
	endforeach;
	
	
	// Got to here, everything is OK
	completedOK := true;
	return response;
	

epilog
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
	
end;</source>
        <text>Get all the valid SubTerminals the current user.</text>
        <wsdlName>getSubTerminals</wsdlName>
        <ReturnType type="WS_SubTerminalResponse"/>
    </JadeWebServicesMethod>
