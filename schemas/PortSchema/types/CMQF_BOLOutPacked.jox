<Class name="CMQF_BOLOutPacked" id="b08a79bb-05eb-4ffd-abe9-da69e76756e5">
    <superclass name="CMQF_BOLOut"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="query"/>
    <JadeMethod name="includesObject" id="b5395544-4e24-4dd3-991e-3e3dd6a8a61c">
        <updating/>
        <source>includesObject(_bol: CM_BOL; _passport : CM_Passport; _breakOut : Boolean output): Boolean updating, protected;
// ---------------------------------------------------------------------------
// Created:     06 September 2002 by cnwth2
//
// Purpose:     
//
// ----------   ----------  --------------------------------------------------
vars
	queryBol			: CMQF_BOLOutPacked;
	masterTI			: CM_TrackedItem;
	failedDAC  :CM_DataAccessController;
begin
	queryBol := self;
	queryBol.numSearched := queryBol.numSearched + 1;
	
	if CM_BOLOut.hasInstance(_bol) then
		if (_bol.dateTime.date &gt;= self.startDate or self.startDate = null) and
		(self.bolType = null or self.bolType = _bol.bolType) and
		(_bol.dateTime.date &lt;= self.endDate or self.endDate = null) and
		(_bol.transportMode = self.transportMode or self.transportMode = null) and
		(_bol.processOption = Process_Pack) and
		(self.myOperator = null or self.myOperator = _bol.myOperator) and
		(self.getMySubTerminal = null or self.getMySubTerminal = _bol.mySubTerminal) and //29/04/2009 cnwdz2 ccms1735
		(_bol.canUserAccessSelf(null, failedDAC, _passport)) then	//now testing all data access	PAR 10614	
			queryBol.numFound := queryBol.numFound +1;
			
			self.outwardsDockets := self.outwardsDockets + 1;
			self.outwardsTIs := self.outwardsTIs + _bol.allTrackedItems.size;
			self.outwardsVolume := outwardsVolume + _bol.getTotalTIVolume;
			self.outwardsWeight := outwardsWeight + _bol.getTotalTIWeight();
			self.totalPackingCharge := self.totalPackingCharge + _bol.CM_BOLOut.getContainerCharge;
			self.numOutwards := self.numOutwards + _bol.allTrackedItems.size;
			
			masterTI := _bol.CM_BOLOut.myMasterTI;
			if CM_Container.hasInstance(masterTI) then
				self.numContainers := self.numContainers + 1;
				if (not masterTI.CM_Container.is40) then
					self.num20ft := self.num20ft + 1;
				else
					self.num40ft := self.num40ft + 1;				
				endif;
			endif;
			
			return true;
		endif;
	endif;
	
	return false;

end;</source>
        <access>protected</access>
        <Parameter name="_bol" type="CM_BOL"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <Parameter name="_breakOut" type="Boolean" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
