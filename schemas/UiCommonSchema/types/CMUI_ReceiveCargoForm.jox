/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 July 2009	cnwdap1	Initial creation

*/

vars

begin
	self.btnAdditional.move(self.widestCaptionExtent + _fieldGeneric.HORIZONTAL_SPACING, 0, self.btnAdditional.width, self.btnAdditional.height);
	self.btnAdditional.zOrder(1);
epilog

end;</source>
        <Parameter name="_fieldGeneric" type="CMUI_FieldGeneric" usage="input"/>
    </JadeMethod>
