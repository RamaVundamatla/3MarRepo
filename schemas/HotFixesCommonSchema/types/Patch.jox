    <JadeMethod name="getSchemaOrder" id="73e0ab20-6c50-4038-a6cd-045a9ce37374">
        <source>getSchemaOrder(schemaStr : String; schemaCollection : SchemaColl) : Integer;
/*****************************************************
Author		: jlgka1 (Karen Alexander)
Date		: 05 June 2019
TFS#		: 41865
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/
vars
	sortOrder	 : Integer;
	schema		 : Schema;	
begin		
	foreach schema in schemaCollection do
		sortOrder := sortOrder + 1;
		if schema.name = schemaStr then
			break;
		endif;
	endforeach;	
	
	return sortOrder;
end;
</source>
        <Parameter name="schemaStr" type="String"/>
        <Parameter name="schemaCollection" type="SchemaColl"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
