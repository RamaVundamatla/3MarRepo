    <JadeMethod name="addToolbarControls" id="ea51d33d-6ac9-4e6c-90b3-b998a8aa6902">
        <updating/>
        <source>addToolbarControls() updating, protected;
// -------------------------------------------
// Created 28 August 2003 by cnwdvb1
// -------------------------------------------
vars

	toolbar	: CMUI_Toolbar;
	
begin
	inheritMethod();

	toolbar := self.frmToolbar;
	
	toolbar.addButton(self.btnPrint, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnQuery, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnShowPlanning, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnReset, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnShowNonPlan, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnUnplan, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnCancelBase, CMUI_Toolbar.Control_Alignment_Right);
	
	toolbar.visible := true;

end;</source>
        <access>protected</access>
    </JadeMethod>
