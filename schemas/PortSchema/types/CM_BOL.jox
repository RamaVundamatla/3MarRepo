    <JadeMethod name="setStopsToBeApplied" id="5a57424b-0b1b-4f3f-9dc4-457c6067ae67">
        <updating/>
        <source>setStopsToBeApplied() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 Apr 2014	cnwmc5	Initial creation	CCMS 2532
15 Dec 2022 navma1	Defect 55852: MTN - 1090 exception while loading a Ship Manifest and BOL via EDI
*/

vars

	stopTable 	: CM_StopsTable;
	theStops	: IntegerArray;
	tmpDict		: CM_StopsTableByIdDict;
	stopType	: Integer;
	
begin

	self.raiseExceptionIfTransient(method);
	
	if app.myPassport &lt;&gt; null and app.myPassport.isInEdiVerifyMode then		//15.12.2022 navma1 #55852
		return;
	endif;
	
	stopType := StopApplyBOL;
	
	create theStops transient;
	
	tmpDict := app.myRoot.allAvailableStopsTables;

	foreach stopTable in tmpDict do
		if stopTable.isToBeAppliedBOL(stopType, self) 
		and not self.hasStopOfType(stopTable)
		and not self.hasHadStop(stopTable.id) then
			theStops.add(stopTable.id);
		endif;
	endforeach;
	
	self.createStopsBulk(theStops, app.myPassport);
	
epilog
	
	if theStops &lt;&gt; null then	//15.12.2022 navma1 #55852											
		delete theStops;
	endif;

end;</source>
    </JadeMethod>
