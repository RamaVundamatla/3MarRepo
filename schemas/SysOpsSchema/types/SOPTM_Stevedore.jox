    </JadeMethod>
    <JadeMethod name="doSave" id="022c4c67-9548-4df5-90a3-26ec0f877175">
        <updating/>
        <source>doSave(): Boolean updating;
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------
// 30/05/2019	jlgdap1		TFS 44554 AAT Stevedore Data Access
vars
	errObj:CM_Error;
	idx:Integer;
	tmpListBox:ListBox;
	notAvailable,
	ignoreWarnings,rtnValue:Boolean;
	proxyStevedore:CM_Stevedore;
	lCode,lDescription:String;
	theForm : SOP_TableMaintForm;
	debtor : CM_Debtor;					// TFS 44554
begin
  theForm := self.myForm; 

	lCode := theForm.tblInput1.getValueByName(ETRow_Code).String;
	lDescription := theForm.tblInput1.getValueByName(ETRow_Description).String;
	notAvailable := theForm.tblInput1.getValueByName(ETRow_NotAvailableForEntry).Boolean;
	debtor := theForm.cmbDebtor.myObject.CM_Debtor;							// TFS 44554
	
	if theForm.myProxyObject = null then
		if theForm.mode = theForm.Mode_Add then
			create theForm.myProxyObject as CM_Stevedore transient;
		else
			app.raiseUnexpectedProgramError(class.name, method.name, 'Proxy object is null for update');
			return false;
		endif;
	endif;

	proxyStevedore := theForm.myProxyObject.CM_Stevedore;
	//proxyStevedore.setProxy(lCode, lDescription, notAvailable);			// TFS 44554
	proxyStevedore.setProxy(lCode, lDescription, notAvailable, debtor);		// TFS 44554
	proxyStevedore.allContacts.clear();
	theForm.mulSelect1.getSelected(proxyStevedore.allContacts);
	
	if theForm.mode = theForm.Mode_Add then
		app.myTrxCA.trxCreateStevedore(proxyStevedore, theForm.myCurrentObject,app.myPassport);
		rtnValue :=app.myPassport.trxCompletedOK;
	elseif theForm.mode = theForm.Mode_Update then
		app.myTrxUA.trxUpdateStevedore(proxyStevedore,app.myPassport);
		rtnValue := app.myPassport.trxCompletedOK;
	else
		app.raiseUnexpectedProgramError(class.name, method.name, '  Invalid mode (' &amp; theForm.mode.String &amp; ')');
		return false;
	endif;
	return rtnValue;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
