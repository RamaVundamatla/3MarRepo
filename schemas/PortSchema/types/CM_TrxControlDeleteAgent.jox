    <JadeMethod name="trxDeleteCMObjects" id="0e48dbca-3906-4ebe-956c-d8beb157be03">
        <updating/>
        <source>trxDeleteCMObjects(_cmObjArray : CM_ObjectArrayActual; _passport : CM_Passport input) updating;
//--------------------------------------------------------------
//Created: April 2005 By: cnwgd1
//--------------------------------------------------------------
vars
	obj : CM_Object;
	invalidObj : Boolean;															//navra1 - TFS 60149/Task 64397 - 14th June 2024
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);
	
	on Exception do app.handleDeletedObject(exception, obj, invalidObj);			//navra1 - TFS 60149/Task 64397 - 14th June 2024

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(false);
	// Start the transaction
	beginTransaction;
	
	foreach obj in _cmObjArray do
		exclusiveLock(obj);
		app.myUtilityDA.utlDeleteCMObject(obj, _passport);
	endforeach;

epilog		
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_cmObjArray" type="CM_ObjectArrayActual"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
