    <JadeMethod name="create" id="f57068ba-2784-4267-a5d9-0e36a3ae321c">
        <updating/>
        <source>create(_cargoGroup : CM_CargoGroup) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date			Who		Reason
16 May 2022		navam1	Initial creation TFS 53390
18 May 2023		navmd1	TFS 56062 Code tidy up
*/

vars
	dict : DynaDictionary;

begin
/* // ### TFS BUG 58853 10JUL2023 NAVAB1
	create dict transient;
	//TFS 53390
	dict.setMembership(CM_CargoGroupDetail);
	dict.addMemberKey(CM_CargoGroupDetail::myCargoGroup.name, false, true);// ### TFS  CR 58857 TASK 58967  30JUN2023 NAVAB1 changed this to be cargo group instead of voyage
	dict.addMemberKey(CM_CargoGroupDetail::transportCode.name, false, true);
	dict.addMemberKey(CM_CargoGroupDetail::site.name, false, true);
	dict.endKeys(false);
	
	self.allDetailsByTransportSite := dict;
	*/
	self.myCargoGroup	:= _cargoGroup;
	
	// ### JIRA: MTN-33614 06Dec2024 NAVPW1
	if _cargoGroup &lt;&gt; null then
		self.myTerminal	:= _cargoGroup.myTerminal;
	endif;
	// ### JIRA: MTN-33614 06Dec2024 NAVPW1
	
epilog

end;</source>
        <Parameter name="_cargoGroup" type="CM_CargoGroup"/>
    </JadeMethod>
