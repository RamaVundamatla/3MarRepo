    <JadeMethod name="comboBoxBankNotSuspended" id="8790789c-d5fc-4e1b-92ff-303e47b97efa">
        <source>comboBoxBankNotSuspended(_cmb:ComboBox input; _bank: CM_Bank);
//********************************************************************
//
// Created by: cnwsh3
//
// Date: 11 February 2004
//
//********************************************************************
vars
	bank : CM_Bank;
	bankColl : CM_CompanyByCodeDict;
begin
	create bankColl transient;
	
	foreach bank in self.myTerminal.companies where (not bank.isSuspended) do
		bankColl.add(bank);
	endforeach;
	
	_cmb.listCollection(bankColl, false, null);
	if _bank &lt;&gt; null and bankColl.includes(_bank) then
		_cmb.listObject := _bank;
		_cmb.text := self.displayEntryBank(_bank);
	endif;
epilog

	delete bankColl;
end;</source>
        <Parameter name="_cmb" type="ComboBox" usage="input"/>
        <Parameter name="_bank" type="CM_Bank"/>
    </JadeMethod>
    <JadeMethod name="comboBoxBatNumber" id="49b37e53-d12e-42c0-b845-9f4f2b2ae45e">
        <updating/>
        <source>comboBoxBatNumber(pTbl : CM_EntryTable input; pAttrName : String; pBatNumber : CM_BatNumber) updating;
//comboBoxBatNumber(pCmb : ComboBox io; pBatNumber : CM_BatNumber; pAvailable : Boolean);
// ---------------------------------------------------------------------------
// Created:     10 January 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	theRow	: Integer;
	iter	: Iterator;
	dict	: CM_BatNumberByCodeDict;
	batNo	: CM_BatNumber;
	str		: String;
	ls,
	found	: Boolean;
	
begin

	theRow := pTbl.getRow(pAttrName);
	if theRow = 0 then
		return;
	endif;

	dict := self.myTerminal.batNumbers;
	
	app.cmsBeginLoad(ls);
	iter := dict.createIterator;
	while iter.next(batNo) do
		sharedLock(batNo);
		if (not batNo.testInUse(self.myTerminal)) then
			if str = null then
				str := batNo.code;
			else
				str := str &amp; Tab &amp; batNo.code;
			endif;
			if batNo = pBatNumber then
				found := true;
			endif;
		endif;
	endwhile;
	endLoad;

	pTbl.setComboValues(theRow, str);

	if found then
		pTbl.setValue(theRow, pBatNumber.code);
	else
		pTbl.setValue(theRow, '');
	endif;

/*	
	pCmb.listCollection(app.thisTerminal.batNumbers, true, 0);
	
	if pBatNumber &lt;&gt; null then
		pCmb.text := self.displayEntryBatNumber(pBatNumber, pAvailable);
		pCmb.listObject := pBatNumber;
	endif;
*/
epilog
	delete iter;
	app.cmsEndLoad(ls);
end;</source>
        <Parameter name="pTbl" type="CM_EntryTable" usage="input"/>
        <Parameter name="pAttrName" type="String"/>
        <Parameter name="pBatNumber" type="CM_BatNumber"/>
    </JadeMethod>
