    <JadeMethod name="clickAdd" id="6bbf0ece-3d8f-4cbd-a4ef-dc2790337971">
        <updating/>
        <source>clickAdd()updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 November 2016	cnwndl1	Initial creation	TFS 2918 / 2419

*/

vars

	itemSelected : Object;

begin

	itemSelected := self.tblAvail.accessRow( self.tblAvail.row ).itemObject;
	if itemSelected &lt;&gt; null then
		self.addSelected(itemSelected,null);
		self.removeAvailable(itemSelected);
		self.updated := true;
	endif;
	
	self.tblSelect.leftColumn := 1;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="clickOptButton" id="17e7aea8-725d-4f83-852e-d75716c69f6a">
        <updating/>
        <source>clickOptButton( _optBtn : OptionButton )updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 November 2016	cnwndl1	Initial creation	TFS 2918 / 2419
27 Jul 2022	navsj20	TFS 53862	EUP - WMS - Damage Recording Extra Details

*/

vars

	availableSet : CM_ObjectSet;
	user : CM_User;
	taskDict : CM_ToDoTaskDescByCode;
	taskDesc : CM_ToDoTaskDesc;
	filterText : String;
	stopTablesDict : CM_StopsTableByIdDict;
	stopTable : CM_StopsTable;
	cargoType : CM_CargoType;
	obj : Object;
	rowIndex : Integer;
	index : Integer;
	remark : String;
	msg : String;
	criteria	:	CM_YACriteria;		// 27 Jul 2022	navsj20	TFS 53862
begin

	self.frmMain.visible := self.optStop.value or self.optTask.value;
	self.btnOne.enabled := self.allowMaint;

	if self.updated then
		msg := app.getErrorString(MSGBOX_Discard_Unsaved_Changes);
		if app.msgBox( msg, app.getErrorString(Warning),MsgBox_Yes_No) = MsgBox_Return_No then
			if _optBtn &lt;&gt; null then
				if _optBtn = self.optStop then
					self.optStop.value := false;
					self.optTask.value := true;
				elseif _optBtn = self.optTask then
					self.optTask.value := false;
					self.optStop.value := true;
				endif;
			endif;
			return;
		endif;
	endif;
	
	self.updated := false;
	
	create availableSet transient;
	user := app.getMyUser;
	filterText := self.txtFilter.text.toUpper.trimBlanks;
	//07 Dec 2016	NDL	TFS 3089
	if filterText = self.lblFilter.caption.toUpper then
		filterText := null;
	endif;
	
	if self.myDocumentAction &lt;&gt; null then
		cargoType := self.myDocumentAction.getCargoType();
	elseif self.myBookingRefItem &lt;&gt; null then
		cargoType := app.myRoot.allCargoTypesById.getAtKey( self.myBookingRefItem.cargoType );
	elseif self.myReserveDetail &lt;&gt; null then
		cargoType := self.myReserveDetail.getCargoType();
	endif;
	
	self.tblAvail.fixedColumns := 0;
	self.tblAvail.rows := 1;
	self.tblAvail.columns := 1;
	self.tblAvail.fixedRows := 1;
	
	self.tblSelect.fixedColumns := 0;
	self.tblSelect.rows := 1;
	
	if self.optStop.value then
	
		if self.allowMaint then
			stopTablesDict := user.getStopsToMaintForTerminal(self.myTerminal);
		else
			stopTablesDict := user.getStopsToViewForTerminal(self.myTerminal);
		endif;
		foreach stopTable in stopTablesDict do
			if filterText &lt;&gt; null and stopTable.heading.toUpper.pos(filterText, 1) &lt; 1 then
				continue;
			endif;
			if stopTable.requiresInfoString &lt;&gt; null then
				continue;
			endif;
			// START 27 Jul 2022	navsj20	TFS 53862
			foreach criteria in stopTable.myStopCriteria.allCriteria where criteria.myYACriteriaType.type = YACriteriaType_CargoType do
				//if cargoType &lt;&gt; null and not stopTable.allCargoTypesNew.includes( cargoType ) then
				if cargoType &lt;&gt; null and stopTable.myStopCriteria &lt;&gt; null and not criteria.myYAData.CM_YADataObjects.allObjects.includes( cargoType ) then 	
					continue;
				endif;
			endforeach;
			/*if cargoType &lt;&gt; null and not stopTable.allCargoTypesNew.includes( cargoType ) then
				continue;
			endif;*/
			// END 27 Jul 2022	navsj20	TFS 53862
			availableSet.addNoDuplicates( stopTable, false );
		endforeach;
		
		self.tblAvail.accessCell(1,1).text := app.getErrorString(Available_stops);
		self.tblAvail.accessCell(1,1).fontBold := true;
		foreach obj in availableSet do
			self.addAvailable( obj );
		endforeach;
		
		self.tblSelect.columns := 1;
		self.tblSelect.fixedRows := 1;
		self.tblSelect.accessCell(1,1).text := app.getErrorString(Selected_stops);
		self.tblSelect.accessCell(1,1).fontBold := true;
		if self.myDocumentAction &lt;&gt; null then
			foreach stopTable in self.myDocumentAction.allStopTablesToAdd do
				self.addSelected(stopTable,null);
				self.removeAvailable(stopTable);
			endforeach;	
		endif;
		
	elseif self.optTask.value then
	
		create taskDict transient;
		user.getToDoTasksAddRemoveForTerm(self.myTerminal, taskDict);
		foreach taskDesc in taskDict do
			if filterText &lt;&gt; null and taskDesc.description.toUpper.pos(filterText, 1) &lt; 1 then
				continue;
			endif;
			if cargoType &lt;&gt; null and not taskDesc.allCargoTypes.includes( cargoType ) then
				continue;
			endif;
			availableSet.addNoDuplicates( taskDesc, false );
		endforeach;
		
		self.tblAvail.accessCell(1,1).text := app.getErrorString(Available_tasks);
		self.tblAvail.accessCell(1,1).fontBold := true;
		foreach obj in availableSet do
			self.addAvailable( obj );
		endforeach;
		
		self.tblSelect.columns := 2;
		self.tblSelect.fixedRows := 1;
		self.tblSelect.accessCell(1,1).text := app.getErrorString(Selected_tasks) &amp; Tab &amp; app.getErrorString(Remarks);
		self.tblSelect.accessCell(1,1).fontBold := true;
		self.tblSelect.accessCell(1,2).fontBold := true;
		if self.myDocumentAction &lt;&gt; null then
			foreach index in 1 to self.myDocumentAction.allTaskDescsToAdd.size do
				taskDesc := self.myDocumentAction.allTaskDescsToAdd[index];
				remark := self.myDocumentAction.allTaskRemarkToAdd[index];
				self.addSelected(taskDesc,remark);
				self.removeAvailable(taskDesc);
			endforeach;
		endif;
		
	else
		self.btnOne.enabled := false;
	endif;
	
	self.tblAvail.cnAdjustColumnWidths;
	self.tblAvail.row := 1;
	self.tblAvail.column := 1;
	
	self.tblSelect.cnAdjustColumnWidths;
	self.tblSelect.row := 1;
	self.tblSelect.column := 1;
	
	self.tblSelect.leftColumn := 1;

epilog

	delete taskDict;
	delete availableSet;

end;</source>
        <Parameter name="_optBtn" type="OptionButton"/>
    </JadeMethod>
    <JadeMethod name="clickRemove" id="9c311435-0fab-470c-8adb-12504a23a968">
        <updating/>
        <source>clickRemove()updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
