    <JadeMethod name="lostFocus" id="6597c7d0-ac77-40b6-89cf-d19e45dd75ad">
        <controlMethod name="CMUI_TimeMask::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>lostFocus(editMask: JadeEditMask input) updating, clientExecution;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
15 July 2009	cnwdap1	Initial creation

*/

vars

begin
	inheritMethod(editMask);
	self.myFieldFrame.hasLostFocus(self.myFieldFrame);
epilog

end;</source>
        <Parameter name="editMask" type="JadeEditMask" usage="input"/>
    </JadeMethod>
    <JadeMethod name="parentName" id="e8236ed4-4d4b-4c28-88aa-89fcc1482fb4">
        <source>parentName() : String;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 September 2009	cnwdap1	Initial creation
*/
vars

begin
	return self.myFieldFrame.name;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="windowCreated" id="38f70093-c0cd-4fbd-94ee-758988573691">
        <controlMethod name="CMUI_TimeMask::windowCreated"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>windowCreated(cntrl: Control input; persistCntrl: Control) updating, clientExecution;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 February 2013	cnwmc5	Initial creation	PAR 31051

*/

vars

begin
	inheritMethod(cntrl, persistCntrl);
	
	if not self.isInPainter then
		if app.isUsingSkin() then
			self.height := self.height - 1;
		endif;
	endif;
epilog

end;</source>
        <Parameter name="cntrl" type="Control" usage="input"/>
        <Parameter name="persistCntrl" type="Control"/>
    </JadeMethod>
