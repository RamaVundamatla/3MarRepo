    <JadeMethod name="cargoIF_GetObjectForETRow" id="651b1a3c-20b9-4a74-88d6-958065b3bc12">
        <source>cargoIF_GetObjectForETRow(pAttrName: String): CM_Object;
/* ---------------------------------------------------------------------------
Created:	15 October 2008	by cnwvu1

Purpose:	
   
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars

begin

	if pAttrName = ETRow_MyGeneratorType then
		return self.myGeneratorType;
		
	else
		return inheritMethod(pAttrName);
		
	endif;

end;</source>
