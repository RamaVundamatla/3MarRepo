    <JadeMethod name="createSelf" id="c6fa611d-f0a7-4a5d-9cf4-44e92d31a66a">
        <updating/>
        <source>createSelf(_field :CM_XTABField;_heading :String)updating;
// ---------------------------------------------------------------------------
// Created:     19 November 2008 by concms1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	
begin
	// set hard-codeed property values
	self.heading 		:= _heading;
	self.index			:= _field.getIndex;	
	self.decimals		:= _field.decimals;
	self.useSeperator	:= _field.useSeperator;
epilog

end;</source>
        <Parameter name="_field" type="CM_XTABField"/>
        <Parameter name="_heading" type="String"/>
    </JadeMethod>
    <JadeMethod name="getCollectionForDrillDown" id="48111966-9a74-4d4e-a49e-a1b77c37d7c1">
        <source>getCollectionForDrillDown():ObjectSet;
// ---------------------------------------------------------------------------
// Created:     22 February 2010 by cnwcs5
// Purpose:     CCMS 1925 / PAR 22295 Release Summaries
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 22/02/2010	cnwcs5		par 22435 - release summary changes
// ---------------------------------------------------------------------------
vars

begin
	return self.myParent.allObjects;
epilog

end;</source>
        <ReturnType type="ObjectSet"/>
    </JadeMethod>
