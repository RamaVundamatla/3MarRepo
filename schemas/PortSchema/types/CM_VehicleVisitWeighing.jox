    <JadeMethod name="getTotalWeightString" id="3cd933fd-dd0b-47e2-9da5-17caf5363b16">
        <source>getTotalWeightString():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 March 2014	cnwndl1	Initial creation	Par 33268

*/

vars

	kgsDecimal : Decimal [16,4];
	retString : String;

begin

	kgsDecimal := self.weighFromWeightBridge;
	
	if self.weightAdjustment &lt;&gt; 0 then
		if self.adjustmentIsAddingWeight then
			kgsDecimal := kgsDecimal + self.weightAdjustment;
		else
			kgsDecimal := kgsDecimal - self.weightAdjustment;
			if kgsDecimal &lt; 0 then
				kgsDecimal := 0;
			endif;
		endif;
	endif;
	
	if self.myWeighingMeasurementType &lt;&gt; null then
		retString := self.myWeighingMeasurementType.convertMeasurementForDisplay( kgsDecimal )&amp; " " &amp; self.myWeighingMeasurementType.shortName;
	else
		retString := app.getDefaultMeasurementForType(Type_Weight).convertMeasurementForDisplay( kgsDecimal )&amp; " " &amp; app.getDefaultMeasurementForType(Type_Weight).shortName;
	endif;
	
	if self.weightAdjustment &lt;&gt; 0 then
		retString := retString &amp; "*";
	endif;
	
	return retString;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getWeighBridgeAndWeightString" id="20334487-7f44-42c3-a7cf-895da9d01ba3">
        <source>getWeighBridgeAndWeightString():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 March 2014	cnwndl1	Initial creation

*/

vars

begin

	return self.weighBridgeName &amp; " " &amp; self.getTotalWeightString();

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setForUpdateFromProxy" id="62760caf-861f-48d1-a8c7-a171c74df51d">
        <updating/>
        <source>setForUpdateFromProxy(_pxy : CM_VehicleVisitWeighing; _passport: CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 March 2014	cnwndl1	Initial creation	Par 33268

*/

vars

begin
	
	self.adjustmentIsAddingWeight := _pxy.adjustmentIsAddingWeight;
	self.adjustmentReason := _pxy.adjustmentReason;
	self.chassisName := _pxy.chassisName;
	self.generatorName := _pxy.generatorName;
	self.myCargoType := _pxy.myCargoType;
	self.myGenerator := _pxy.myGenerator;
	self.myGeneratorType := _pxy.myGeneratorType;
	self.myISOType := _pxy.myISOType;
	self.myProduct := _pxy.myProduct;
	self.myTrackedItem := _pxy.myTrackedItem;
	self.myTrailer := _pxy.myTrailer;
	self.myChassisType := _pxy.myChassisType;
	self.myVehicle := _pxy.myVehicle;
	self.myWeighBridge := _pxy.myWeighBridge;
	self.tiId := _pxy.tiId;
	self.vehicleName := _pxy.vehicleName;
	self.weighBridgeName := _pxy.weighBridgeName;
	self.weighFromWeightBridge := _pxy.weighFromWeightBridge;
	self.weightAdjustment := _pxy.weightAdjustment;
	self.weightCargo := _pxy.weightCargo;
	self.weightChassis := _pxy.weightChassis;
	self.weightGenerator := _pxy.weightGenerator;
	self.weightIsCertified := _pxy.weightIsCertified;
	self.weightVehicle := _pxy.weightVehicle;
	self.myWeighingMeasurementType := _pxy.myWeighingMeasurementType;
	

epilog

end;</source>
        <Parameter name="_pxy" type="CM_VehicleVisitWeighing"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
