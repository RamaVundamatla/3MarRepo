    <JadeMethod name="outputHeader_UNH_BGM" id="7aea53e4-87b5-47e9-90fb-18fa3e133e34">
        <updating/>
        <source>outputHeader_UNH_BGM(_camFile: CM_CamFile input; _camTaskHistory: CM_CamTaskHistory input; _activity: Integer; _unhSeq: Integer io; _segmentCount: Integer io; _coll: HugeStringArray input) : String updating, protected;
/*
Purpose:			
Parameters:			
Return Value:		
Date		Who		Reason
16 October 2014	cnwmc5	Initial creation
*/
//29 Jan 2015	cnwrs1	Par 35544 - Change CamMessage to use HugeStringArray
//25 Feb 2015	cnwrs1	Par 35544 - Refactor Cams file storage to string
constants
	COARRI = "COARRI";
	LOAD = "270";
	DISCHARGE = "98";
vars
	strLine : String;
begin
	if _activity = COARRI_SHIPLOAD then
		strLine := strLine &amp; self.makeMessageHeader(_camFile, _camTaskHistory, _unhSeq, LOAD, COARRI, _coll);
		
		_segmentCount := _segmentCount + 2;
		
	elseif _activity = COARRI_SHIPDISCHARGE then
		strLine := strLine &amp; self.makeMessageHeader(_camFile, _camTaskHistory, _unhSeq, 	DISCHARGE, COARRI, _coll);
		
		_segmentCount := _segmentCount + 2;
	endif;
	return strLine;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_camFile" type="CM_CamFile" usage="input"/>
        <Parameter name="_camTaskHistory" type="CM_CamTaskHistory" usage="input"/>
        <Parameter name="_activity" type="Integer"/>
        <Parameter name="_unhSeq" type="Integer" usage="io"/>
        <Parameter name="_segmentCount" type="Integer" usage="io"/>
        <Parameter name="_coll" type="HugeStringArray" usage="input"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="specialFileName" id="2f7acd70-0e3d-4193-9892-06caa3d71851">
        <source>specialFileName(_camGroup: CM_CamGroup; _startDateTime: TimeStamp; _runDateTime : TimeStamp): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 October 2014	cnwmc5	Initial creation

*/

vars
	timeStamp 	: TimeStamp;
	utcString 	: String;
	
begin
	timeStamp := _runDateTime.localToUTCTime();
	utcString := timeStamp.date.longYearEDI() &amp; timeStamp.time.formatAsHHMMSS();
	
	return "CPL_PIL_COARRI_" &amp; utcString;

epilog

end;</source>
        <Parameter name="_camGroup" type="CM_CamGroup"/>
        <Parameter name="_startDateTime" type="TimeStamp"/>
        <Parameter name="_runDateTime" type="TimeStamp"/>
        <ReturnType type="String"/>
    </JadeMethod>
</Class>
