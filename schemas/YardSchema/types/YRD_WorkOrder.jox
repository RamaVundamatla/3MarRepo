    <JadeMethod name="cmbPackVoyage_click" id="37bd2a83-7ab0-4912-a341-ac9336659eea">
        <controlMethod name="CMUI_ComboBoxObject::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbPackVoyage_click(combobox: ComboBox input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
02 August 2022	navcs2	Bug 54396 - MTN - Work Order Maintenance - Discharge Port of Pack Job Should Follow Selected Voyage
*/

vars
	port 	: CM_Port;
	voyage  : CM_Voyage;
	portRotation : CM_PortRotation;
	operator : CM_Operator;
begin
	self.cmbPackDishPort.clear;
	
	if self.cmbPackVoyage.listObject = null then
		self.cmbPackDishPort.setObjectFromCodeAndVoyage (self.cmbPackDishPort.getCode(), null);
	else
		voyage := self.cmbPackVoyage.listObject.CM_Voyage;
		self.cmbPackDishPort.setObjectFromCodeAndVoyage (self.cmbPackDishPort.getCode(), voyage);
		cmbPackOperator.resetCollectionForVoyage(voyage);
 	endif;
epilog

end;</source>
