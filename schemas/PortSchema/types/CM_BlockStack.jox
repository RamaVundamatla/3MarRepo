    <JadeMethod name="getAvailableCapacity" id="4946e609-fff0-4677-9e8a-605c47815ae2">
        <source>getAvailableCapacity(): Integer;
// 24/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
vars
	num : Integer;
begin
	//num := self.myLocationsController.allTrackedItems.size;
	num := self.myLocationsController.getTrackedItemCount();  //cnwrd1 31736 break bulk counting
	
	return (self.maxCapacity - num - 
			self.myLocationsController.numPlannedTIs - self.myLocationsController.numQueuedTIs); 
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
