    <JadeMethod name="doResizeControls" id="59edffa8-e543-4346-ad70-3d7b64384c3e">
        <updating/>
        <source>doResizeControls(_initialSetup: Boolean) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 March 2015	cnwndl1	Initial creation

*/

vars

	left : Real;
	stdHeight : Real;
	stdWidth : Real;
	top : Real;
	width : Real;
	tabIndex : Integer;
	
	formToDisplay : Class;

begin

	self.setResizeableMarginAndFontSize();
	left :=  self.resizedMargin;
	top :=  self.resizedMargin;
	stdWidth :=  self.clientWidth - (self.resizedMargin * 2);
	stdHeight := self.getStdControlHeight;
	tabIndex := 4000;
	
	if _initialSetup then
		self.txtWagonId.setAndIncrementTabIndex( tabIndex );
		self.txtWagonId.visible := true;
		self.txtWagonId.enabled := false;
		self.txtWagonId.text := self.myWagon.id;
	endif;
	self.txtWagonId.move(	left,
							top,
							stdWidth,
							stdHeight );
							
	if self.myTerminal.hasNoCargoCheckItemsFor(self.context) then	//31 May 2012	NDL Par 29038
		self.tblCargoChecks.visible := false;
	else
		self.tblCargoChecks.visible := true;
		self.myHandHeldCheckerAgent.setupContextChecksTable(	self.tblCargoChecks,
															self.context,
															self,
															self.btnTick, self.btnCross, self.btnTickDown, self.btnCrossDown, self.btnButton,
															formToDisplay,
															self.myWagon );
	endif;
							
	inheritMethod(_initialSetup);

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_initialSetup" type="Boolean"/>
    </JadeMethod>
