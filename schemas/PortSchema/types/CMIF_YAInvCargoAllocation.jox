    <JadeMethod name="isInboundShipOperator_Match" id="d174bbfc-e853-4051-b873-07d475a075e6">
        <source>isInboundShipOperator_Match(_yaData: CM_YADataObjects): Boolean;
// TFS 3258
vars
	op : CM_Operator;
begin

	if self.myTransaction.myTrackedItem = null then
		return false;
	endif;
	
	// Only priorities will be empty.
	if _yaData.isEmpty() then
		return true;
	endif;
	
	op := self.myTransaction.myTrackedItem.getTranshipImportOperator;
	if op = null then
		return false;
	endif;

	if _yaData.isKindOf(CM_YADataPattern) then
		if _yaData.CM_YADataPattern.pattern = op.code then
			return true;
		endif;
	else
		return _yaData.matches(op);
	endif;
end;
</source>
        <Parameter name="_yaData" type="CM_YADataObjects"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
