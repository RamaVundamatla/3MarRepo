    <JadeMethod name="create" id="1613b63f-12b3-40fc-b388-c418d61d609b">
        <updating/>
        <source>create() updating;
// ---------------------------------------------------------------------------
// Created:		December 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	self.permissionView  := PmAdmLoadlistView;
	self.permissionMaint := PmAdmLoadlistMaint;

	self.helpFileName := HelpFile_Voyage;
	
	create self.mySummaryReport transient;
	self.mySummaryReport.setSummaryClass(CMIF_LoadListSummaryObject);
	create self.mySummaryFilter transient;
// PAR 33933	self.noteTimes.atPut(SR_Note_Tag, 0);
// PAR 33933	self.noteTimes.atPut(TI_Note_Tag, 0);
	
end;</source>
    </JadeMethod>
    <JadeMethod name="createFiltersFromObjects" id="858b6af4-5c86-4fbb-b9b7-01d6862c89f3">
        <updating/>
        <source>createFiltersFromObjects( _objArray : CM_ObjectArray ) updating;

/*

Purpose:			

Parameters:			

Return Value:	

This form used to have its own filtering based on being passed a collection of cargo to load.
We now create filters based on this set of cargo	


Date		Who		Reason
25 January 2012	cnwndl1	Initial creation	Par 25297

*/

vars

	tableObj : Object;
	table : Table;
	tables : ObjectArray;
	
	filterStrings : StringArray;
	
	entableRow : EntTableRow;
	entableRowHeading : String;
	columIndex : Integer;
	
	obj : Object;
	ti : CM_TrackedItem;
	id : String;
	invalid : Boolean;
	
	filter : CM_ColumnFilter;
	
	visibleCount : Integer;
	tsCount, tbaCount : Integer;
	dlrCount : Integer;
	plannedCount : Integer;
	nonplannedCount : Integer;
	allCount : Integer;

begin

	if _objArray = null or _objArray.isEmpty then
		return;
	endif;
	
	if self.allColumnFilters = null then
		create self.allColumnFilters transient;  // this is a non exclusive collection.
	endif;
	
	create filterStrings transient;
	
	if not validateCreateFilters() then
		return;
	endif;
	
	create tables transient;
	tables.add( self.tblData );
	tables.add( self.tblPlanned );
	tables.add( self.tblDLR );
	tables.add( self.tblAll );
	tables.add( self.tblTranShip );
	tables.add( self.tblTBA ); // TFS 45590
	
	on Exception do app.handleDeletedObject( exception, ti, invalid );
	
	foreach obj in _objArray do
		if CM_TrackedItem.hasInstance( obj ) then
			invalid := false;
			ti := obj.CM_TrackedItem;
			id := ti.id;
			if invalid then
				continue;
			endif;
			if not filterStrings.includes(id) then
				filterStrings.add(id);
			endif;
		endif;
	endforeach;

	foreach tableObj in tables do
		table := tableObj.Table;
		self.allColumnFilters.replaceAllFiltersForTable(table,null);
		columIndex := table.CM_DataTable.getColumnByRowName( ETRow_Id );
		if columIndex &lt; 1 then
			continue;
		endif;
		entableRow := table.CM_DataTable.getEntTableRowAtColumn( columIndex );
		if entableRow = null then
			continue;
		endif;
		
		visibleCount := 0;
		entableRowHeading := entableRow.getHeading(table.getMyTerminologyCargoBOLType, table.getMyTerminologyTerminal, app.myCurrentLocale);
		self.allColumnFilters.updateColumnFilter( table.CM_DataTable, columIndex, entableRowHeading, filterStrings, false);
		
		visibleCount := self.applyColumnFilter(table.CM_DataTable);
		
		if table = self.tblTranShip then
			tsCount := visibleCount;			
		elseif table = self.tblDLR then
			dlrCount := visibleCount;			
		elseif table = self.tblPlanned then
			plannedCount := visibleCount;
		elseif table = self.tblData then
			nonplannedCount := visibleCount;
		elseif table = self.tblAll then
			allCount := visibleCount;
		endif;
		
	endforeach;
	
	if (plannedCount &gt;= nonplannedCount
	and plannedCount &gt;= dlrCount)
	then
		self.fldMain.topSheet	:=	self.shtPlanned;
	elseif (nonplannedCount &gt;= plannedCount
	and nonplannedCount &gt;= dlrCount)
	then
		self.fldMain.topSheet	:=	self.shtNonplanned;
	else
		self.fldMain.topSheet	:=	self.shtDLR;
	endif;

epilog

	delete tables;
	delete filterStrings;

end;</source>
        <Parameter name="_objArray" type="CM_ObjectArray"/>
    </JadeMethod>
    <JadeMethod name="delete" id="e6093992-1b76-403b-a3c4-687e2b4f93d0">
        <updating/>
        <executionLocation>client</executionLocation>
        <source>delete() updating, clientExecution;
//----------------------------------------------------------------
//	Created:	15 September 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin

	self.mySummaryReport.reset();
	delete self.mySummaryReport;
	delete self.mySummaryFilter;
	
	//22 Dec 2011	NDL	Par 25297
	if self.allColumnFilters &lt;&gt; null then
		delete self.allColumnFilters;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="displayAllTable" id="d0d4f636-4985-43b7-8c6e-4f76378330ec">
        <updating/>
        <source>displayAllTable() updating;
// ---------------------------------------------------------------------------
// Created:     08 January 2008 by cnwaer1
//
// Purpose:     
// ---------------------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------
// 30/03/2016	cnwdap1		PAR #35843 Make monitor time-based rather than object count based
vars
	obj 			: Object;
	numZeros,
	idx  		 	: Integer;
	ti				: CM_TrackedItem;
	filterObject	: CMQF_ShipLoadListTIs;
	cmifMonitor		: CMIF_Monitor;
	partsInJob		: Integer;
	lastUpdate		: Decimal [20];						// PAR #35843
	
begin

	self.mousePointer := Window.MousePointer_HourGlass;
	
	if app.myPassport.myCMIFMonitor = null then
		create cmifMonitor transient;
		cmifMonitor.myParent := self;
		app.myPassport.setMyCMIFMonitor(cmifMonitor);
	endif;
	
	cmifMonitor := app.myPassport.myCMIFMonitor;
	cmifMonitor.partsDone := 0;
	cmifMonitor.monitorReturnValue := null;
	self.modalDialogReturnValue	:= ModalDialogReturn_Null;
	self.modalDialogShow('Displaying', null, 'Cancel', null, null, 'Displaying data');
	self.pbProgressBar.visible := true;
	
	foreach obj in self.tblAll.allTableObjects do
			ti := obj.CM_TrackedItem;	
			idx := idx + 1;
			self.doQueryAddItem(self.tblAll, 0, ti, numZeros);
		
			cmifMonitor.partsDone := cmifMonitor.partsDone + 1;
			//if (cmifMonitor.partsDone mod 10 = 0) then												// PAR #35843
			if (app.relativeMachineTime - lastUpdate) &gt; CMIF_Monitor.Monitor_TimeBetweenUpdates then	// PAR #35843
				self.lblModalInfo.caption := cmifMonitor.partsDone.String &amp; ' items displayed';
				self.pbProgressBar.partsDone	:= cmifMonitor.partsDone;
				self.frmModalDialog.doWindowEvents(0);
				
				if (cmifMonitor.monitorReturnValue = CMIF_Monitor.MonitorReturnValue_Return) or
			   		(cmifMonitor.monitorReturnValue = CMIF_Monitor.MonitorReturnValue_Cancel)  then
					break;
				endif;
				lastUpdate := app.relativeMachineTime;													// PAR #35843
			endif;		
	endforeach;

		// Have to resort the table
	self.tblAll.setSortColumnsForMaxNumCols();				
					
	self.doTblDataRenumberItems(self.tblAll, 0);

epilog
	app.myPassport.setMyCMIFMonitor(null);
	delete cmifMonitor;
	self.progressFinish();
	self.mousePointer := Window.MousePointer_Default;
end;</source>
    </JadeMethod>
    <JadeMethod name="displayTable" id="5bc1ff96-79d3-4f30-ab21-2c82aeb686da">
        <updating/>
        <source>displayTable(_table : CM_DataTable input) updating;
// ---------------------------------------------------------------------------
// Created:		October  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 30/03/2016	cnwdap1		PAR #35843 Make monitor time-based rather than object count based
// ---------------------------------------------------------------------------

vars
	obj 			: Object;
	numZeros,
	idx  		 	: Integer;
	ti				: CM_TrackedItem;
	filterObject	: CMQF_ShipLoadListTIs;
	cmifMonitor		: CMIF_Monitor;
	partsInJob		: Integer;
	lastUpdate		: Decimal[20];						// PAR #35843
begin

	self.mousePointer := Window.MousePointer_HourGlass;
	_table.rows := _table.fixedRows;

	if self.myQuery = null then
		return;
	endif;
	
	filterObject := self.myQuery;
	partsInJob := filterObject.allQryTrackedItems.size;
	numZeros := partsInJob.String.length();
	if app.myPassport.myCMIFMonitor = null then
		create cmifMonitor transient;
		cmifMonitor.myParent := self;
		app.myPassport.setMyCMIFMonitor(cmifMonitor);
	endif;
	
	cmifMonitor := app.myPassport.myCMIFMonitor;
	cmifMonitor.partsDone := 0;
	cmifMonitor.partsInJob := partsInJob;
	cmifMonitor.monitorReturnValue := null;
	self.modalDialogReturnValue	:= ModalDialogReturn_Null;
	self.modalDialogShow('Displaying', null, 'Cancel', null, null, 'Displaying data');
	self.pbProgressBar.visible := true;
	
	if _table.allTableObjects &lt;&gt; null
	and (not _table.allTableObjects.noKeys) then
		
		_table.allTableObjects.clear();
		
		foreach ti in filterObject.allQryTrackedItems do
			_table.allTableObjects.addObject(ti);
		endforeach;
		
		foreach obj in _table.allTableObjects do
			ti := obj.CM_TrackedItem;	
			idx := idx + 1;
			self.doQueryAddItem(_table, 0, ti, numZeros);
		
			cmifMonitor.partsDone := cmifMonitor.partsDone + 1;
			//if (cmifMonitor.partsDone mod 10 = 0) then												// PAR #35843
			if (app.relativeMachineTime - lastUpdate) &gt; CMIF_Monitor.Monitor_TimeBetweenUpdates then	// PAR #35843
				self.lblModalInfo.caption := cmifMonitor.partsDone.String &amp; ' out of ' &amp; partsInJob.String &amp; ' items displayed';
				self.pbProgressBar.partsInJob	:= cmifMonitor.partsInJob;	
				self.pbProgressBar.partsDone	:= cmifMonitor.partsDone;
				self.frmModalDialog.doWindowEvents(0);
				
				if (cmifMonitor.monitorReturnValue = CMIF_Monitor.MonitorReturnValue_Return) or
			   		(cmifMonitor.monitorReturnValue = CMIF_Monitor.MonitorReturnValue_Cancel)  then
					break;
				endif;
				lastUpdate := app.relativeMachineTime;													// PAR #35843
			endif;
	
		endforeach;	
	
	else		
	
		foreach ti in filterObject.allQryTrackedItems do	
			idx := idx + 1;
			self.doQueryAddItem(_table, 0, ti, numZeros);
		
			cmifMonitor.partsDone := cmifMonitor.partsDone + 1;
			if (cmifMonitor.partsDone mod 10 = 0) then
				self.lblModalInfo.caption := cmifMonitor.partsDone.String &amp; ' out of ' &amp; partsInJob.String &amp; ' items displayed';
				self.pbProgressBar.partsInJob	:= cmifMonitor.partsInJob;	
				self.pbProgressBar.partsDone	:= cmifMonitor.partsDone;
				self.frmModalDialog.doWindowEvents(0);
				
				if (cmifMonitor.monitorReturnValue = CMIF_Monitor.MonitorReturnValue_Return) or
			   		(cmifMonitor.monitorReturnValue = CMIF_Monitor.MonitorReturnValue_Cancel)  then
					break;
				endif;
			endif;
	
		endforeach;

		// Have to resort the table
		_table.setSortColumnsForMaxNumCols();				
					
	endif;

	self.doTblDataRenumberItems(_table, 0);

epilog
	app.myPassport.setMyCMIFMonitor(null);
	delete cmifMonitor;
	self.progressFinish();
	self.mousePointer := Window.MousePointer_Default;
end;</source>
        <Parameter name="_table" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doBtnCargoUnplanCLick" id="3774c0a5-c3a2-435b-bf51-077cc6872281">
        <updating/>
        <source>doBtnCargoUnplanCLick() updating;
// ---------------------------------------------------------------------------
// Created:		23 August 2005  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// 08/04/2011	cnwmh5	PAR #27347 - Add cmsEndLoad or endLoad to epilog so that if error occurs it will not leave it in beginLoad state
vars
	anObj : Object;
	tmpWLE : CM_WorkListEntry;
	aTI : CM_TrackedItem;
	str : String;
	idx : Integer;
	ls : Boolean;
	wles : CM_WLEArray;
begin
	if self.tblPlanned.allSelectedObjects.isEmpty then
		return;
	endif;

	create wles transient;
	
	foreach anObj in self.tblPlanned.allSelectedObjects do
		idx := idx + 1;
		aTI := anObj.CM_TrackedItem;
		// PAR 18695 from here
		if aTI &lt;&gt; null then
		
			tmpWLE := aTI.getVoyageWLEUnactioned(true);	
			if tmpWLE &lt;&gt; null then 
				wles.add(tmpWLE);
		// PAR 18695 to here
				
				if str = null then
					str := aTI.id;
				else
					if idx mod 3 = 0 then
						str := str &amp; ", " &amp; Cr &amp; aTI.id;
					else
						str := str &amp; ", " &amp; aTI.id;
					endif;
				endif;
			endif;
		endif;
	endforeach;
	
	// PAR 18695
	if wles.isEmpty() then
		app.msgBox("Please select some cargo to unplan.","Problem",MsgBox_OK_Only);
		return;
	else
		if app.msgBox(app.getErrorString(Unplan_GC) &amp; str &amp; "?", app.getErrorString(SHP_Confirm_Unplan_Cargo),MsgBox_Yes_No + MsgBox_Question_Mark_Icon) = MsgBox_Return_No then
			global.beep;
			return;
		endif;
	endif;
	
	app.cmsBeginLoad(ls);

	/* PAR 28522 WAS
	if self.tblPlanned.allSelectedObjects.size = 1 then
		aTI := anObj.CM_TrackedItem;
		self.doUnplanTI(aTI,true);
	else
		self.doUnplanTIs(wles);
	endif;
	NOW */

	self.doUnplanTIs(wles, PLANNING_MODE);	// Dec 2011 cnwjre1 28636 RORO unplanning of queued load moves
	
epilog
	app.cmsEndLoad(ls);
	delete wles;
end;</source>
    </JadeMethod>
    <JadeMethod name="doBtnEnquireClick" id="3593e531-d5f1-483d-927d-41a0a321d0c1">
        <source>doBtnEnquireClick();
// ---------------------------------------------------------------------------
// Created:		December 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	theObject : Object;
	objArray : ObjectArray;
begin
	//epr par 32613 1/10/13
	create objArray transient;
	getSelectedTIs(objArray);
	
	if objArray.isEmpty then
		return;
	endif;
	
	theObject:=objArray.first;
	
	if theObject &lt;&gt; null and theObject.isKindOf(CM_TrackedItem) then
		if objArray.size &gt; 1 then
			self.myAssistant.showCargoEnquiryForTIs(theObject.CM_TrackedItem, objArray,	self.myMasterMenuAction, false);
		else
			self.myAssistant.showCargoEnquiryForm(theObject.CM_TrackedItem, self.myMasterMenuAction, true, false);	
		endif;
	endif;
epilog
	delete objArray;
end;</source>
    </JadeMethod>
    <JadeMethod name="doBtnLocateClick" id="9300708d-8a1c-4990-823e-69cca038e130">
        <updating/>
        <source>doBtnLocateClick(_theTable : CM_DataTable) updating;
// ---------------------------------------------------------------------------
// Created:		December 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	theTable : CM_DataTable;

begin
//	self.mousePointer := Window.MousePointer_HourGlass;

	if fldMain.topSheet = self.shtDLR then
		theTable := self.tblDLR;
	elseif fldMain.topSheet = self.shtTranship then
		theTable := self.tblTranShip;
	elseif fldMain.topSheet = self.shtTBA then // TFS 45590
		theTable := self.tblTBA;
	elseif fldMain.topSheet = self.shtNonplanned then
		theTable := self.tblData;
	elseif fldMain.topSheet = self.shtPlanned then
		theTable := self.tblPlanned;
	elseif fldMain.topSheet = self.shtAll then
		theTable := self.tblAll;
	elseif fldMain.topSheet = self.shtSummary then
		return;
	endif;
	inheritMethod(theTable);
	
epilog

	
end;</source>
        <Parameter name="_theTable" type="CM_DataTable"/>
    </JadeMethod>
    <JadeMethod name="doBtnLocateYardEnqClick" id="0af9c212-52d1-46dc-93b0-4d83a03ddd7d">
        <updating/>
        <source>doBtnLocateYardEnqClick() updating;
// ---------------------------------------------------------------------------
// Created:		September 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	objs : ObjectSet;
	theENQ : CM_EnquiryController;
begin
	self.mousePointer := Window.MousePointer_HourGlass;
	create objs transient;

	if self.fldMain.topSheet = self.shtNonplanned then
		self.tblData.allSelectedObjects.copy(objs);
	elseif self.fldMain.topSheet = self.shtPlanned then
		self.tblPlanned.allSelectedObjects.copy(objs);
	elseif self.fldMain.topSheet = self.shtDLR then
		self.tblDLR.allSelectedObjects.copy(objs);
	elseif self.fldMain.topSheet = self.shtTranship then
		self.tblTranShip.allSelectedObjects.copy(objs);
	elseif self.fldMain.topSheet = self.shtTBA then // TFS 45590
		self.tblTBA.allSelectedObjects.copy(objs);
	elseif self.fldMain.topSheet = self.shtAll then
		self.tblAll.allSelectedObjects.copy(objs);
	endif;

	theENQ := self.myAssistant.SHP_Assistant.doGetSelectorTIsLoadList(objs, self.myCurrentVoyage);

	self.myAssistant.showYardRowEnquiryForm(objs, self.myMasterMenuAction, theENQ, true, VIEW_DISPORT, 1, null);
epilog
	self.mousePointer := Window.MousePointer_Default;
end;</source>
    </JadeMethod>
    <JadeMethod name="doBtnPlanClick" id="c8949632-d17a-43ca-a5a8-8a537dfd41ee">
        <updating/>
        <source>doBtnPlanClick() updating;
// ---------------------------------------------------------------------------
// Created:		December 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

	theMoveController	: CMIF_MoveController;
	lTI : CM_TrackedItem;
	lController : CM_LocationsController;
	result,
	theReturn : Integer;
	invalidVoyage : Boolean;
begin
	on Exception do app.handleDeletedObject(exception, self.myCurrentVoyage, invalidVoyage); //10/10/08 cnwdz2 Par 17732
	

	if self.myCurrentTrackedItem = null then
		app.msgBox(app.getErrorString(SH_Please_Select_A_TrackedItem) &amp; self.myCurrentVoyage.code ,app.getErrorString(SHP_Auto_Plan_Error),	MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	if self.myCurrentTrackedItem.isAttributeTrue(TI_Attrib_IsOverStowed) then
		theReturn := app.msgBox(self.myCurrentTrackedItem.id &amp; app.getErrorString(SHP_Is_OverStowed) &amp; Cr &amp;  self.myCurrentTrackedItem.dischargePortDescription &amp; ", "
						&amp; self.myCurrentTrackedItem.commodity &amp; Cr &amp; app.getErrorString(SHP_Do_You_Want_To_Continue)
						,app.getErrorString(SHP_Auto_Plan_Error),	MsgBox_Yes_No + MsgBox_Question_Mark_Icon);
		if theReturn = MsgBox_Return_No then
			return;
		endif;
	endif;
	if self.myTerminal.allOnsiteTIsByCargoTypeId[TI_CargoType_Container,self.myCurrentTrackedItem.id] = null then
		theReturn := app.msgBox(self.myCurrentTrackedItem.id &amp; app.getErrorString(SHP_Is_Not_On_Site) &amp; Cr &amp;  self.myCurrentTrackedItem.dischargePortDescription &amp; ", "
						&amp; self.myCurrentTrackedItem.commodity &amp; Cr &amp; app.getErrorString(SHP_Do_You_Want_To_Continue)
						,app.getErrorString(SHP_Auto_Plan_Error), MsgBox_Yes_No + MsgBox_Question_Mark_Icon);
		if theReturn = MsgBox_Return_No then
			return;
		endif;
	endif;

	if self.myCurrentTrackedItem.isKindOf(CM_BreakBulk) then
		app.msgBox("Unable to auto-plan Break Bulk - SEE DEVELOPER!","Auto Plan Error",	MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
			
	if app.jobMode = 3 then //DISCHARGE_JOB_MODE then
	
	else
		if app.myCurrentSlotControllerPlanned = null then
			app.msgBox(app.getErrorString(SHP_Please_Select_Slot_On_Voy) &amp; self.myCurrentVoyage.code &amp; app.getErrorString(SHP_To_Plan) &amp; self.myCurrentTrackedItem.id &amp; " To.",app.getErrorString(SHP_Auto_Plan_Error),
				MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
			return;
		else
			self.mousePointer := Window.MousePointer_HourGlass;

			create theMoveController transient;
			delete app.myMoveController; //cnwrs1 mar 2007 stop memory leak
			app.myMoveController := theMoveController;
			theMoveController.setMyToPrimaryLocation(app.myCurrentSlotControllerPlanned);
			theMoveController.setMoveMode(PLANNING_MODE);
			theMoveController.isSystemMove := true;
//			theMoveController.setJobForMove(self.myVoyageJob);
			theMoveController.setMyTrackedItem(self.myCurrentTrackedItem);
			
			while true do
				app.myTrxUA.trxMoveTrackedItem(theMoveController, app.myPassport);
				if app.myPassport.trxCompletedOK then
					
					break;
				else
					result := app.showErrorWarningDialog(app.getErrorString(Move), app.myPassport, ErrWarnMode_Update + ErrWarnMode_CanAckWarnings);
					if app.myPassport.noErrors and
					   result = IDOK then
						// there must have just been warnings that the user has acknoledged so ..
						app.myPassport.warningsAcknowledged	:= true;
						continue;
					endif;
					
				endif;
				break;
			endwhile;
				
		endif;
	endif;
	
epilog
	app.myMoveController := null;
	if theMoveController &lt;&gt; null then
		delete theMoveController;
	endif;
	self.mousePointer := Window.MousePointer_Default;
end;</source>
    </JadeMethod>
    <JadeMethod name="doBtnRTSClick" id="5754d858-9b9d-42b8-8312-5242a504e57f">
        <updating/>
        <source>doBtnRTSClick(table : Table) updating;
// ---------------------------------------------------------------------------
// Created:		January 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	ignoreWarnings 	: Boolean;
	theObject 		: Object;
	tiArray			: CM_TIArray;
	rts				: Boolean;
	result			: Integer;
begin

	//12 Jan 2018	NDL	TFS 36559
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		return;
	endif;

	self.mousePointer := Window.MousePointer_HourGlass;

	if table.CM_DataTable.allSelectedObjects.size = 0 then
		app.msgBox(app.getErrorString(SHP_Please_Select_TrackedItem) ,app.getErrorString(SHP_Ready_To_Ship_Error),	MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	
	create tiArray transient;
	foreach theObject in table.CM_DataTable.allSelectedObjects where CM_TrackedItem.hasInstance(theObject) do
		tiArray.add(theObject.CM_TrackedItem);
	endforeach;
	
	rts := (not tiArray.first.readyToShip);
	while true do
		app.myTrxUA.trxUpdateTIsReadyToShip(tiArray, rts, app.myPassport);
		if app.myPassport.trxCompletedOK then
		
			break;
		else
			result := app.showErrorWarningDialog('Ready To Ship', app.myPassport, ErrWarnMode_Update + ErrWarnMode_CanAckWarnings);
			
			if app.myPassport.noErrors and result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;

			
		endif;
		break;
	endwhile;

epilog
	delete tiArray;
	self.mousePointer := Window.MousePointer_Default;
end;</source>
        <Parameter name="table" type="Table"/>
    </JadeMethod>
    <JadeMethod name="doBtnSummariseAll" id="7a95ccdb-17e1-4cba-b5f1-6cfcd8c9ed7f">
        <source>doBtnSummariseAll();

/*

Purpose:		
Parameters:		
Return Value:	

Date				Who		Reason
18 February 2009	cnwrl1	Initial creation (CCMS SFW 1047 - Totals Only Lists)

*/
	
vars
	coll				: ObjectSet;
	cm_DataTable		: CM_DataTable;
	
begin
	app.mousePointer	:= Busy;
	create coll transient;
	
	// Get a collection of ALL the objects to pass to the Summary Definition form.
	cm_DataTable	:= self.getCurrentDataTable();
	cm_DataTable.getAllRowObjects( coll );
	self.myAssistant.showXTABSummaryDefinitionForm( coll, false, false, false, true );
	
epilog
	delete coll;
	app.mousePointer	:= Idle;
	
end;
</source>
    </JadeMethod>
    <JadeMethod name="doCentralisedTINoteUpdate" id="9f8d60aa-1c74-4882-a176-1ca60020f407">
        <updating/>
        <source>doCentralisedTINoteUpdate() updating;
// ---------------------------------------------------------------------------
// Created:		21 December 2005  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	startTime		: TimeStamp;
	tmpTI :			 CM_TrackedItem;
	renumberPlanned,
	renumberDLR,
	doSummaryRebuild,
	renumberData,
	renumberAll,
	renumberTBA,
    renumberTranship: Boolean;
	//request			: CM_SlotRequest;
	request			: CM_Request;
	tmpStr      : String;
begin
	//
	// PAR 21787
	//	
	tmpStr := method.qualifiedName;
	self.cnStartTransaction(tmpStr[1:50]);

	self.startedTimer := false;
	
	self.resetSummaryCriteria();
	
	doSummaryRebuild := (self.allTIsSummaryUpdate.size &gt; 150);
	
	foreach tmpTI in self.allTIsSummaryUpdate do
		self.doCentralisedTIUpdate(tmpTI, renumberPlanned, renumberData, renumberDLR, renumberTranship,renumberTBA, renumberAll);
		if not doSummaryRebuild then
			self.updateSummaryTIFromNote(tmpTI);
		endif;
	endforeach;
	
	foreach request in self.allRequestsSummUpdate do
		self.updateSummarySR(request);
	endforeach;
	
	foreach request in self.allRequestsSummDelete do
		self.removeSRFromSummary(request);
	endforeach;
	
	if renumberPlanned then
		self.doTblDataRenumberItems(self.tblPlanned, 0);
	endif;
	
	if renumberDLR then
		self.doTblDataRenumberItems(self.tblDLR, 0);
	endif;
	
	//+cnwml2 PAR26141
	if renumberTranship then
		self.doTblDataRenumberItems(self.tblTranShip, 0);
	endif;
	
	if renumberTBA then // TFS 45590
		self.doTblDataRenumberItems(self.tblTBA, 0); // TFS 45590
	endif;
	
	if renumberData then
		self.doTblDataRenumberItems(self.tblData, 0);
	endif;
	if renumberAll then
		self.doTblDataRenumberItems(self.tblAll, 0);
	endif;
	
	if doSummaryRebuild then
		self.doSummaryQuery();
	else
		//self.initSummaryTable();
		self.tblSummary.rows := self.tblSummary.fixedRows;
		self.mySummaryReport.populateTable(self.tblSummary);
	endif;
	
	self.allTIsSummaryUpdate.clear;
	
epilog
	self.updateShtCaptions();
	//
	// PAR 21787
	//
	self.cnEndTransaction();
end;</source>
    </JadeMethod>
    <JadeMethod name="doCentralisedTIUpdate" id="50dde2fd-8b82-459f-8744-77d5ae550853">
        <updating/>
        <source>doCentralisedTIUpdate(_theTI : CM_TrackedItem; _renumberPlanned, _renumberData, 
									_renumberDLR, _renumberTranship, _renumberTBA, _renumberAll : Boolean output) updating;
// ---------------------------------------------------------------------------
// Created:		December 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// 29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
vars
	aTI : CM_TrackedItem;
	theRow : Integer;
	breakOut : Boolean;
	invalidObj : Boolean;
	str : String;
	isUnplannedTranship : Boolean;
begin
	on Exception do app.handleDeletedObject(exception,aTI,invalidObj);
	
	aTI := _theTI;

	if aTI &lt;&gt; null then
		str := aTI.id;  //cause exception
	endif;
	
	//added for par15901
	if not self.mySummaryFilter.checkStatusIncludesObject(aTI, app.myPassport, breakOut) then
		return;
	endif;
	//add end
	
	// ### REMOVE NO LONGER REQUIRED
	//if not app.isValidObject(aTI) 
	//cnwjo3 par 26028
	if invalidObj 
	or not aTI.includeOnLoadList(self.myCurrentVoyage, self.myTerminal) then
		if self.tblPlanned.findObjectInRow(aTI, theRow) then
			self.tblPlanned.removeItemObject(aTI);
			//self.doTblDataRenumberItems(self.tblPlanned, 0);
			_renumberPlanned := true;
			self.doNotableRemove(aTI);
		elseif self.tblData.findObjectInRow(aTI, theRow) then
			// If non planned is to be removed (eg voyage changed) then need to update summary immediately so can be removed from totals. 
			self.updateSummaryTI(aTI,false); // this is called here so summary is updated BEFORE object is removed from table(special case)							
			self.tblData.removeItemObject(aTI);
			//self.doTblDataRenumberItems(self.tblData, 0);
			_renumberData := true;
			self.doNotableRemove(aTI);
		elseif self.tblDLR.findObjectInRow(aTI, theRow) then
			self.tblDLR.removeItemObject(aTI);
			//self.doTblDataRenumberItems(self.tblDLR, 0);
			_renumberDLR := true;
			self.doNotableRemove(aTI);
		elseif self.tblTranShip.findObjectInRow(aTI, theRow) then		// 1/10/19 MAP TFS 45590
			self.tblTranShip.removeItemObject(aTI);
			_renumberTranship := true;
			self.doNotableRemove(aTI);
		elseif self.tblTBA.findObjectInRow(aTI, theRow) then		// 1/10/19 MAP TFS 45590
			self.tblTBA.removeItemObject(aTI);
			_renumberTBA := true;
			self.doNotableRemove(aTI);
		elseif self.tblAll.findObjectInRow(aTI, theRow) then
			self.tblAll.removeItemObject(aTI);
			//self.doTblDataRenumberItems(self.tblDLR, 0);
			_renumberAll := true;
			self.doNotableRemove(aTI);
		endif;
	else
		//##
		//if aTI.hasFutureMoveLoad(PLANNING_MODE) then
		//cnwjo3 26028
		if aTI.hasFutureMoveLoadForVoyage(PLANNING_MODE,aTI.myVoyage) then
			if self.tblData.findObjectInRow(aTI, theRow) then
				self.tblData.removeItemObject(aTI);
				//self.doTblDataRenumberItems(self.tblData, 0);
				_renumberData := true;
			elseif self.tblDLR.findObjectInRow(aTI, theRow) then
				self.tblDLR.removeItemObject(aTI);
				//self.doTblDataRenumberItems(self.tblDLR, 0);
				_renumberDLR := true;
			elseif self.tblTranShip.findObjectInRow(aTI, theRow) then		// 1/10/19 MAP TFS 45590
				self.tblTranShip.removeItemObject(aTI);
				_renumberTranship := true;
			elseif self.tblTBA.findObjectInRow(aTI, theRow) then		// 1/10/19 MAP TFS 45590
				self.tblTBA.removeItemObject(aTI);
				_renumberTBA := true;
			elseif self.tblAll.findObjectInRow(aTI, theRow) then
				self.tblAll.removeItemObject(aTI);
				//self.doTblDataRenumberItems(self.tblDLR, 0);
				_renumberAll := true;
			endif;
			self.tblPlanned.removeItemObject(aTI);
			self.updateTableItem(self.tblPlanned, aTI);
			
			//par 18788 cnwjo3
			self.tblAll.removeItemObject(aTI);
			if self.tblAll.rows &gt; 1 then  //don't add to tblAll if not setup
				self.updateTableItem(self.tblAll,aTI);
			endif;
			
			_renumberPlanned := true;
			_renumberAll := true;
		else
		
			//30 Mar 2020	NDL TFS 47004
			if aTI.isTranshipItem then
				if aTI.myExportVoyage &lt;&gt; null then
					isUnplannedTranship := not aTI.hasFutureMoveLoadForVoyage(PLANNING_MODE,aTI.myExportVoyage);
					if aTI.myPrimaryActualLocation &lt;&gt; null and aTI.myPrimaryActualLocation.isVoyageController and aTI.myPrimaryActualLocation.CM_VoyageController.myVoyage = aTI.myExportVoyage then
						// its already on the export voyage or queued, don't show it any more
						isUnplannedTranship := false;
					endif;
				endif;
			endif;
			
			//+cnwml2 PAR26141
	//		if not aTI.isTranshipItem and self.tblTranShip.findObjectInRow(aTI, theRow) then
			if not isUnplannedTranship and self.tblTranShip.findObjectInRow(aTI, theRow) then	//30 Mar 2020	NDL TFS 47004
				self.tblTranShip.removeItemObject(aTI);
			//elseif aTI.isTranshipItem and self.tblTranShip.findObjectInRow(aTI, theRow) then
			elseif isUnplannedTranship and self.tblTranShip.findObjectInRow(aTI, theRow) then	//30 Mar 2020	NDL TFS 47004
				self.tblTranShip.removeItemObject(aTI);
				self.updateTableItem(self.tblTranShip, aTI);
				
				self.tblAll.removeItemObject(aTI);
				if self.tblAll.rows &gt; 1 then //don't add to tblAll if not setup
					self.updateTableItem(self.tblAll,aTI);
				endif;
				
				_renumberTranship := true;
				_renumberAll := true;
			endif;
			if self.tblPlanned.findObjectInRow(aTI, theRow) then
				self.tblPlanned.removeItemObject(aTI);
				
				//par 18788 cnwjo3
				self.tblAll.removeItemObject(aTI);
				if self.tblAll.rows &gt; 1 then //don't add to tblAll if not setup
					self.updateTableItem(self.tblAll,aTI);
				endif;
				
				//self.doTblDataRenumberItems(self.tblPlanned, 0);
				_renumberPlanned := true;
				_renumberAll := true;
			endif;
			if aTI.isRehandle then // rehandles were being added
				//if aTI.site &lt;&gt; TI_SITE_ONSHIP
				if self.tblDLR.findObjectInRow(aTI, theRow) then
					self.tblDLR.removeItemObject(aTI);
				endif;
				//if aTI.site &lt;&gt; TI_SITE_ONSHIP then // has been added to ship 
				 self.updateTableItem(self.tblDLR, aTI);
				_renumberDLR := true;
				//endif;
		//	elseif aTI.isTranshipItem then // TFS 45590
			elseif aTI.isTranshipItem and isUnplannedTranship then //30 Mar 2020	NDL TFS 47004
				if self.tblTranShip.findObjectInRow(aTI, theRow) then // TFS 45590
					self.tblTranShip.removeItemObject(aTI); // TFS 45590
				endif;
				 self.updateTableItem(self.tblTranShip, aTI); // TFS 45590
				_renumberTranship := true; // TFS 45590
			elseif aTI.isTBAorIsRRP then // TFS 45590
				if self.tblTBA.findObjectInRow(aTI, theRow) then // TFS 45590
					self.tblTBA.removeItemObject(aTI); // TFS 45590
				endif;
				 self.updateTableItem(self.tblTBA, aTI); // TFS 45590
				_renumberTBA := true; // TFS 45590
			endif;
			self.tblData.removeItemObject(aTI);
			if aTI.site &lt;&gt; TI_SITE_ONSHIP // if is on ship then dont need to be added to the non planned table table
			and not aTI.isTBAorIsRRP then // TFS 45590
				self.updateTableItem(self.tblData, aTI);
				_renumberData := true;
			endif;
		endif;
	endif;
	
// Move up.
//	self.updateSummaryTIFromNote(aTI);

end;</source>
        <Parameter name="_theTI" type="CM_TrackedItem"/>
        <Parameter name="_renumberPlanned" type="Boolean" usage="output"/>
        <Parameter name="_renumberData" type="Boolean" usage="output"/>
        <Parameter name="_renumberDLR" type="Boolean" usage="output"/>
        <Parameter name="_renumberTranship" type="Boolean" usage="output"/>
        <Parameter name="_renumberTBA" type="Boolean" usage="output"/>
        <Parameter name="_renumberAll" type="Boolean" usage="output"/>
    </JadeMethod>
    <JadeMethod name="doCentralisedWLENoteUpdate" id="34e0e741-3e27-4677-b203-c257741823ad">
        <updating/>
        <source>doCentralisedWLENoteUpdate() updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25/11/2010	cnwdap1	Initial creation PAR #26426 CCMS MES 1102 Release requests on ship load list
*/
vars
	tmpStr				: String;
	doSummaryRebuild	: Boolean;
	wle					: CM_WorkListEntry;

begin
	tmpStr := method.qualifiedName;
	self.cnStartTransaction(tmpStr[1:50]);

	self.startedTimer := false;
	
	self.resetSummaryCriteria();
	
	doSummaryRebuild := (self.allWLEsSummaryUpdate.size &gt; 150);
	
	foreach wle in self.allWLEsSummaryUpdate do
		//self.doCentralisedWLEUpdate(wle);
		if not doSummaryRebuild then
			self.updateSummaryWLEFromNote(wle);
		endif;
	endforeach;
	
	if doSummaryRebuild then
		self.doSummaryQuery();
	else
		self.tblSummary.rows := self.tblSummary.fixedRows;
		self.mySummaryReport.populateTable(self.tblSummary);
	endif;
	
	self.allWLEsSummaryUpdate.clear;
	
epilog
	self.updateShtCaptions();
	self.cnEndTransaction();
end;</source>
    </JadeMethod>
    <JadeMethod name="doCentralisedWLEUpdate" id="a1fd630a-0b99-41a0-9417-6ea9c31aac9a">
        <updating/>
        <source>doCentralisedWLEUpdate(_wle : CM_WorkListEntry) updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25/11/2010	cnwdap1	Initial creation PAR #26426 CCMS MES 1102 Release Requests on Ship Load List
29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
*/
vars
	wle			: CM_WorkListEntry;
	invalidObj	: Boolean;
	str			: String;
	breakOut	: Boolean;

begin
	on Exception do app.handleDeletedObject(exception, wle, invalidObj);
	
	wle := _wle;

	if wle &lt;&gt; null then
		str := wle.id;  //cause exception
	endif;
	
	if not invalidObj then
		if not self.mySummaryFilter.checkStatusIncludesObject(wle, app.myPassport, breakOut) then
			return;
		endif;
	endif;
	
	self.updateSummaryWLE(wle, false);
epilog

end;</source>
        <Parameter name="_wle" type="CM_WorkListEntry"/>
    </JadeMethod>
    <JadeMethod name="doCmbVoyageBuild" id="6c7b1b11-c72c-4d7c-b42c-d2c6b9cd0fee">
        <updating/>
        <source>doCmbVoyageBuild() updating;
// ---------------------------------------------------------------------------
// Created:		December 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

	aVoyage 		: CM_Voyage;
	idx 			: Integer;
	theVoyages 		: CM_VoyageSet;	
begin

	
	self.cmbVoyageNote.armNotification(self.myTerminal);
	self.cmbVoyageNote.clear;
	self.cmbVoyageNote.sorted := true;
	
	create theVoyages transient;
	self.myTerminal.getAllCurrentCellularVoyages(theVoyages, false, false);

	foreach aVoyage in theVoyages do
		self.cmbVoyageNote.addItemObject(aVoyage.code &amp; " - " &amp; aVoyage.description,aVoyage );		
	endforeach;

	if self.myCurrentVoyage &lt;&gt; null then	
		idx := self.cmbVoyageNote.findObject(self.myCurrentVoyage);
		if idx &gt; 0 then
			self.cmbVoyageNote.listIndex := idx;
		endif;
	endif;
epilog
	delete theVoyages;

end;</source>
    </JadeMethod>
    <JadeMethod name="doCmbVoyageClick" id="aaefaf21-b421-4536-9d26-4aaf3a4ab859">
        <updating/>
        <source>doCmbVoyageClick(_combo : ComboBox) updating;
// ---------------------------------------------------------------------------
// Created:		October 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// 03 Nov 2016	cnwrs1	TFS 2902 change the current Voyage after selecting a new voyage
vars
	
begin
	//epr TFS 5617  25/8/17 we only set myCurrentVoyage when the find button is clicked
	self.doComboOperatorBuild();
	self.doComboPortBuild();
end;</source>
        <Parameter name="_combo" type="ComboBox"/>
    </JadeMethod>
    <JadeMethod name="doComboCargoBuild" id="5641474e-e309-440e-8e6c-6f7027c42920">
        <updating/>
        <source>doComboCargoBuild() updating;
// ---------------------------------------------------------------------------
// Created:		October 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 22/12/2014	cnwdap1		PAR #35397 CCMS SFW 1394 Voyage Rationalisation - sort cargo types in alphabetical order
// ---------------------------------------------------------------------------

vars

	aCargoType : CM_CargoType;
	idx : Integer;
	object			: Object;
	terminalArea	: CM_TerminalArea;
	anArray : ObjectArray;
	alphaDict		: DynaDictionary;												// PAR #35397
	obj				: Object;														// PAR #35397
begin
	self.lstCargoTypes.rows := 0;
	self.lstCargoTypes.zOrder(1);
	
	create alphaDict transient;														// PAR #35397
	alphaDict.setMembership(CM_CargoType);											// PAR #35397
	alphaDict.addMemberKey(CM_CargoType::abbreviation.name, false, true);			// PAR #35397
	alphaDict.endKeys(false);														// PAR #35397
	
	foreach aCargoType in app.myRoot.allCargoTypesById do
		// from 31981 skip not-available-for-entry cargo types
		if aCargoType.isNotAvailableForEntry then
			continue;
		endif;
	
		if not aCargoType.allTerminals.includes(self.myTerminal) then // PAR 22862
			continue;
		endif;
		alphaDict.addNoDuplicates(aCargoType, false);								// PAR #35397
	endforeach;																		// PAR #35397
	foreach obj in alphaDict do														// PAR #35397
		aCargoType := obj.CM_CargoType;												// PAR #35397
		self.lstCargoTypes.addItemObject(aCargoType.abbreviation &amp; " - " &amp; aCargoType.description,aCargoType);
		
		// #################
		// DEFAULT TO CONTAINER
		if aCargoType.id = TI_CargoType_Container then
			self.lstCargoTypes.rowChecked(lstCargoTypes.rows);

			if not self.lstCargoTypes.allSelectedObjects.includes(aCargoType) and aCargoType &lt;&gt; null then
				self.lstCargoTypes.allSelectedObjects.add(aCargoType);
			endif;


		endif;
	endforeach;
	aCargoType := app.myRoot.allCargoTypesById[TI_CargoType_Container];
	create anArray transient;
	anArray.add(aCargoType);
	self.lstCargoTypes.setSelected(anArray);
	
epilog
	delete anArray;
	delete alphaDict;					// PAR #35397
end;</source>
    </JadeMethod>
    <JadeMethod name="doComboOperatorBuild" id="2007119f-0ff8-45fa-9272-e050edcbcc10">
        <updating/>
        <source>doComboOperatorBuild() updating;
// ---------------------------------------------------------------------------
// Created:		January 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 08/03/2011	cnwmh5	PAR #27142 - Change to local variable rather than self for handleDeleteObject exception
//  2/09/2019 	JLGNS1	Bug 46164: LNX - Criteria of Voyage Cutoff Code Does Not Work

// ---------------------------------------------------------------------------

vars
	aOperator : CM_Operator;
	idx : Integer;
	passport : CM_Passport;
	opDict : CM_OperatorByCodeDict;
	failedDAC  :CM_DataAccessController;
	invalidVoyage : Boolean;
	currentVoyage		: CM_Voyage;
begin
	on Exception do app.handleDeletedObject(exception, currentVoyage, invalidVoyage); //10/10/08 cnwdz2 Par 17732
	
	passport := app.myPassport;
	self.lstOperators.zOrder(1);
	self.lstOperators.rows := 0;

	currentVoyage := self.cmbVoyageNote.listObject.CM_Voyage; //epr TFS 5617  25/8/17
	if currentVoyage &lt;&gt; null then
		opDict := currentVoyage.allOperators;
		//10/10/08 cnwdz2 Par 17732
		if invalidVoyage then					
			return;
		endif;
	else
		opDict := app.myRoot.allOperators;
	endif;
	
	foreach aOperator in opDict discreteLock do
		if aOperator.canUserAccessSelf(null, failedDAC, passport) then
			idx := self.lstOperators.addItemObject(aOperator.code &amp; " - " &amp; aOperator.description,aOperator);
//	PAR 35996		if aOperator.allVoyageReceiveOnHold.includes(currentVoyage) then
			if  aOperator.hasReceivalCutOffForVoyage(currentVoyage,null) then //	PAR 35996	//Bug 46164
				self.lstOperators.accessRow(idx).backColor := Red;
				self.lstOperators.accessRow(idx).foreColor := White;
			else
				self.lstOperators.accessRow(idx).backColor := White;
				self.lstOperators.accessRow(idx).foreColor := Black;
				
			endif;
		endif;
	endforeach;
	self.lstOperators.setSelected(null);

	
	self.lstOperators.userInputEnabled := false;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doComboPortBuild" id="7de3020d-bee4-4f19-b98a-f5a9fc5f9d9e">
        <updating/>
        <source>doComboPortBuild() updating;
// ---------------------------------------------------------------------------
// Created:		January 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 08/03/2011	cnwmh5	PAR #27142 - Change to local variable rather than self for handleDeleteObject exception
// ---------------------------------------------------------------------------

vars
	aPort : CM_Port;
	portDict : CM_PortByCodeDict;
	portCmbOrderDescrFirst : Boolean;
	invalidVoyage : Boolean;
	currentVoyage 	: CM_Voyage;
begin
	on Exception do app.handleDeletedObject(exception, currentVoyage, invalidVoyage); //10/10/08 cnwdz2 Par 17732

	self.lstPorts.zOrder(1);
	self.lstPorts.rows := 0;
	create portDict transient;

	currentVoyage := self.cmbVoyageNote.listObject.CM_Voyage; //epr TFS 5617  25/8/17
	if currentVoyage &lt;&gt; null then
		currentVoyage.allPorts.copyNoDupsNoTransaction(portDict); // adm 190609 Par 19892 cater for duplicates in allPorts array
		//10/10/08 cnwdz2 Par 17732
		if invalidVoyage then		
			app.msgBox(app.getErrorString(ERR_DELETED_VOYAGE),"",MsgBox_OK_Only+MsgBox_Exclamation_Mark_Icon);
			return;
		endif;
	else
		app.myRoot.allActivePorts.copy(portDict);
	endif;
	
	portCmbOrderDescrFirst := app.myRoot.getConfig(PortCmbOrderDescrFirst).Boolean;
	
	foreach aPort in portDict discreteLock do
		self.lstPorts.addItemObject(aPort.getDisplayFormatted(portCmbOrderDescrFirst), aPort);
	endforeach;

	self.lstPorts.setSelected(null);
	
epilog
	delete portDict;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doContextMenuBuild" id="b01ed048-bf6d-41f4-acbb-b7e1998533a1">
        <source>doContextMenuBuild();
// ---------------------------------------------------------------------------
// Created:		19 September 2005  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	
begin
	self.mnuContextTIEdit.visible := true;
	self.mnuContextTIEnquire.visible := true;
	self.mnuContextLocate.visible := false; // leave for 733 hotfix true;
	self.mnuContextLocate.caption := self.btnLocateYardEnq.caption;
	self.mnuContextLocate.enabled := 	self.btnLocateYardEnq.enabled;		
	self.mnuLoadListPlanLoad.visible := false;
	self.mnuContextSelectAll.visible := true;
	self.mnuLLLocateGridArea.visible := true;
	self.mnuContextShowOverstow.visible := false;	// PAR 21532 CCMS SFW 1025
	self.mnuContextMoveOverstow.visible := false;	// PAR 21532 CCMS SFW 1025
	self.mnuLLReadyToShip.visible := true;
	self.mnuLLUnplan.visible := false;
	self.mnuContextSep01.visible := true;
	
	// cnwrl1 13/02/2009 - (CCMS SFW 1047 - Totals Only Lists) - start of coding
	self.mnuSummarise.visible	:= false;	// default this menu level to invisible, makes sub-menu invisible.
	if self.bAllowSummaryDefn then
		self.mnuSummarise.visible			:= true;
		// the summarise selected is only enabled if something is actually selected.
		self.mnuSummariseSelected.visible	:= not self.getCurrentDataTable.allSelectedObjects.isEmpty;
	endif;
	// cnwrl1 13/02/2009 - (CCMS SFW 1047 - Totals Only Lists) - end of coding
	
	// PAR 21532 CCMS SFW 1025
	if self.myCurrentTrackedItem &lt;&gt; null and
	   self.myCurrentTrackedItem.isOverStowed(REAL_MODE) then//isAttributeTrue(TI_Attrib_IsOverStowed) then
		self.mnuContextShowOverstow.visible := true;
		self.mnuContextMoveOverstow.visible := true;
	endif;

	
	// TFS 2198 CNWAB1
	
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.mnuContextTIEdit.visible := false;
		self.mnuContextLocate.visible := false; 
		self.mnuLoadListPlanLoad.visible := false;
		self.mnuLLLocateGridArea.visible := false;
		self.mnuContextShowOverstow.visible := false;	
		self.mnuContextMoveOverstow.visible := false;	
		self.mnuLLReadyToShip.visible := false;
		self.mnuLLUnplan.visible := false;
		self.mnuContextSep01.visible := false;

	endif;
	
	
epilog


	
end;</source>
    </JadeMethod>
    <JadeMethod name="doEdit" id="73de2bab-0f15-440a-8149-5855039f8229">
        <updating/>
        <source>doEdit() updating;
// ---------------------------------------------------------------------------
// Created:		January 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	theObject : Object;
	objArray : ObjectArray;
begin
	
	create objArray transient;
	getSelectedTIs(objArray);
	
	if objArray.isEmpty then
		return;
	endif;
	
	if objArray[1].isKindOf(CM_TrackedItem) then
		self.myAssistant.showCargoEnquiryForTIs(objArray[1].CM_TrackedItem, objArray, self.myMasterMenuAction, true);
	endif;
epilog
	delete objArray;
end;</source>
