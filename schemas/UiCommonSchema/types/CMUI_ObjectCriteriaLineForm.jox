    <JadeMethod name="disableExcludedCriteria" id="85c26df1-f4db-4916-8100-5551eab1592c">
        <source>disableExcludedCriteria();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 November 2015	cnwndl1	Initial creation	Par 37094
6 July 2022 navtnr20 ChangeRequest 53697: EUP - VBS MTN - [1] - VBS Slot Types
09/08/2023	navkc1	CR 59580	Task 59588: UI - CustDocs Customs Shipping Line Status
*/

vars

	i : Integer;
	criteriaFrame : CMUI_YACriteriaCntl;
	criteriaTypes : CM_YACriteriaTypeArray;
	criteriaType: CM_YACriteriaType;
	allCritTypes : CM_YACritetriaTypeByTypeDict;
begin

	create criteriaTypes transient;
	allCritTypes := app.myRoot.allYACriteriaTypes;
//	if self.context = CM_ObjectMatchCriteria.ReleaseByTypeInt or self.context = CM_ObjectMatchCriteria.VvrPackageInt then
	if self.context = CM_ObjectMatchCriteria.ReleaseByTypeInt
	or self.context = CM_ObjectMatchCriteria.RoadGateCargoCheckInt	//21 Oct 2019	NDL	TFS 46911
	or self.context = CM_ObjectMatchCriteria.VBSMatchingCriteriaInt		//27.06.2022 navtnr20 TFS 53697
	or self.context = CM_ObjectMatchCriteria.ShipLineStatusInt //09/08/2023	navkc1	CR 59580	Task 59588
	then
		foreach criteriaType in allCritTypes do
			if self.excludeCriteriaType( null, criteriaType ) then
				criteriaTypes.add( criteriaType );
			endif;
		endforeach;
	endif;
	
	if criteriaTypes.isEmpty then
		return;
	endif;

	i := 1;
	criteriaFrame := self.frmCriteria.getControl(i).CMUI_YACriteriaCntl;
	while criteriaFrame &lt;&gt; null do
		foreach criteriaType in criteriaTypes do
			criteriaFrame.disableCriteriaType( criteriaType );
		endforeach;
		i := i + 1;
		criteriaFrame := self.frmCriteria.getControl(i).CMUI_YACriteriaCntl;
	endwhile;

epilog

	delete criteriaTypes;

end;</source>
    </JadeMethod>
    <JadeMethod name="doCancel" id="f203d0d0-5ef8-4653-8e29-0b30d447cdce">
        <updating/>
        <source>doCancel() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 April 2018	jlgsl4	Initial creation

*/

vars

begin
	if self.context = CM_ReportFormatMatchCriteria.ImexTransitionInt then
		self.myParentForm.CMUI_CargoIMEXTransitionEdit.setCancel;
	endif;
	inheritMethod();

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doControlEvent" id="de2164eb-e2a5-4b68-8dee-e334c6a44d39">
        <updating/>
        <source>doControlEvent(_control: Control) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
22 November 2023	navpw1	Initial creation TFS: 58761 (60739)

*/

vars
	groupBox : CMUI_MultiSelectGroupBox;
	
begin
	groupBox := self.mulAvailableResourceGroups;
	
	if (_control = groupBox.myAvailableListBox and groupBox.mySelectedListBox.listCount = 0) then
		return;
	elseif     _control = groupBox.myAvailableListBox 
		or _control = groupBox.mySelectedListBox
		or _control = groupBox.myAddSelectedBtn 
		or _control = groupBox.myAddAllBtn 
		or _control = groupBox.myRemoveAllBtn 
		or _control = groupBox.myRemoveSelectedBtn then
		
		self.updateMandatorySelectionBox();
	endif;
	
end;</source>
        <Parameter name="_control" type="Control"/>
    </JadeMethod>
    <JadeMethod name="doSave" id="d9b6d967-ed66-4f68-9118-4478029533df">
        <updating/>
        <source>doSave() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 December 2013	cnwndl1	Initial creation

*/

vars

begin
	 
	 if not self.saveData( false ) then
		self.zOrder(1);
	 endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doSetupCriteriaFrames" id="0bb313c1-0954-4528-acf4-32d834bc4dcb">
        <updating/>
        <source>doSetupCriteriaFrames() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 December 2013	cnwndl1	Initial creation	Par 33184

*/

vars

	opCriteria: CM_YACriteriaArray;
	criteriaType: CM_YACriteriaType;
	allCriteria : CMIF_Array;
	criteria : CM_YACriteria;
	proxyCriteria : CM_YACriteria;
	
begin

	self.allOperationalCriteria.purge();
	self.allTemplateCriteria.purge();
	
	create opCriteria transient;
	foreach criteriaType in app.myRoot.allYACriteriaTypes do
		if allCriteria &lt;&gt; null and allCriteria.size &gt; 0 then
			criteria:=self.getCriteriaOfTypeFromTI(allCriteria,criteriaType.type);
		endif;
		//02 Nov 2015	NDL	Par 37094
		if self.excludeCriteriaType( null, criteriaType ) then
			continue;
		endif;
		create proxyCriteria transient;
		if criteria = null then
			proxyCriteria.setProxy(criteriaType, "", "");			
		else
			proxyCriteria.setProxy(criteria.myYACriteriaType, criteria.myYAData.getDataValue(), criteria.code);
			opCriteria.add(criteria);
		endif;
		self.allOperationalCriteria.add( proxyCriteria.getTransient());
	endforeach;

	if self.myObjectMatchCriteria &lt;&gt; null then
		foreach criteria in self.myObjectMatchCriteria.allCriteria do
			if not opCriteria.includes(criteria) and criteria.myYACriteriaType.type &lt;&gt; YACriteriaType_ImexStatus then
				//02 Nov 2015	NDL	Par 37094
				if self.excludeCriteriaType( null, criteria.myYACriteriaType ) then
					continue;
				endif;
				create proxyCriteria transient;
				proxyCriteria.setProxy(criteria.myYACriteriaType, criteria.myYAData.getDataValue(), criteria.code);
				self.allTemplateCriteria.add( proxyCriteria.getTransient() );
			endif;
		endforeach; 
	endif; 
	
	self.populateCriteriaFrames(true);
	
epilog

	if allCriteria &lt;&gt; null then
		allCriteria.purge();
		delete allCriteria;
	endif;
	
	delete opCriteria;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="excludeCriteriaType" id="e7e454b2-22bc-4b7e-a201-24e570154491">
        <source>excludeCriteriaType( _criteriaFrame: CMUI_YACriteriaCntl; _criteriaType: CM_YACriteriaType ):Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 November 2015	cnwndl1	Initial creation	Par 37094 -
6 July 2022 navtnr20 ChangeRequest 53697: EUP - VBS MTN - [1] - VBS Slot Types
21 Dec 2022 navtnr20 Bug 56015: FR 53383 | EUP - Release Request by Type Commodity Criteria
09/08/2023	navkc1	CR 59580	Task 59588: UI - CustDocs Customs Shipping Line Status
07 Mar 2024 navrv30 Bug 61941: FR | 53383 - Release Request by Type - Cargo Group (part II)
*/

vars

	type : Integer;

begin

	if self.context = CM_ObjectMatchCriteria.RoadGateCargoCheckInt then	//21 Oct 2019	NDL	TFS 46911
		//Only 3 valid ones for Road Gate Cargo Check Availability
		if _criteriaType = null then
			return true;
		endif;
		type := _criteriaType.type;
		if type.isOneOf( YACriteriaType_CargoType, YACriteriaType_Product, YACriteriaType_OperatorItem ) then
			return false;
		else
			return true;
		endif;
	
	elseif self.context = CM_ObjectMatchCriteria.ReleaseByTypeInt then	
	
		 //We disable these suckers on the selection form for Releases, because
		 // the values are hard coded on the release form, so should not be SOFT filters as well..
	
		
		if _criteriaType = null then
			return false;
		endif;
		type := _criteriaType.type;
	
		if type = YACriteriaType_AvGrade
		or type = YACriteriaType_BOL
		or (type = YACriteriaType_BookingRef and not self.includesCritName(YACriteriaType_BookingRef)) //12 Aug 2016	NDL	TFS 2527	//navra1 - BUG 63499 - 30th April 2024
		or type = YACriteriaType_CargoType
		or type = YACriteriaType_Clean
		//or type = YACriteriaType_Commodity //12 Aug 2016	NDL	TFS 2527 	navtnr20 TFS 56015 21/12/2022
		or type = YACriteriaType_CommodityGroup //12 Aug 2016	NDL	TFS 
		or type = YACriteriaType_Consignee
		or type = YACriteriaType_FreightForward
		or type = YACriteriaType_ISO
		or type = YACriteriaType_ISOGroup
		//or type = YACriteriaType_ImexStatus       //07 Mar 2024 navrv30 Bug 61941
		or type = YACriteriaType_OperatorItem
		or type = YACriteriaType_Product
		or type = YACriteriaType_RailReleaseReq //12 Aug 2016	NDL	TFS 2527
		or type = YACriteriaType_RequiresPower //12 Aug 2016	NDL	TFS 2527
		or type = YACriteriaType_TrailerType  //12 Aug 2016	NDL	TFS 2527
		or type = YACriteriaType_TransactionType  //12 Aug 2016	NDL	TFS 2527
		or type = YACriteriaType_SrcTermArea
		or type = YACriteriaType_SrcTermAreaType //12 Aug 2016 2016	NDL TFS 2527
		or type = YACriteriaType_Stops	//21 Mar 2016	NDL	TFS 1691
		or type = YACriteriaType_SubTerminal
		or type = YACriteriaType_ToDoTasks	//21 Mar 2016	NDL	TFS 1691
		or type = YACriteriaType_Voyage
		//or type = YACriteriaType_Weight  //TFS 53671 14/6/22
		then
			if _criteriaFrame &lt;&gt; null then
				_criteriaFrame.disableCriteriaType( _criteriaType );
			endif;
			return true;
		endif;
		
	//Start	21.06.2022 navtnr20 TFS 53697
	elseif self.context = CM_ObjectMatchCriteria.VBSMatchingCriteriaInt then
		
		if _criteriaType = null then
			return true;
		endif;
		type := _criteriaType.type;
		if type.isOneOf( YACriteriaType_CargoType, YACriteriaType_Commodity,YACriteriaType_Carrier,YACriteriaType_Product,YACriteriaType_OperatorItem ) then
			return false;
		else
			return true;
		endif;
	//END 21.06.2022 navtnr20 TFS 53697
/*	
	elseif self.context = CM_ObjectMatchCriteria.VvrPackageInt then		// 8/3/18 MAP TFS37340
		if _criteriaType = null then
			return false;
		endif;
		type := _criteriaType.type;
	
		if type = YACriteriaType_AvGrade
		or type = YACriteriaType_Clean
		or type = YACriteriaType_Carrier
		or type = YACriteriaType_Clean
		or type = YACriteriaType_CommReefer
		or type = YACriteriaType_Hazardous
		or type = YACriteriaType_HeavyDuty
		or type = YACriteriaType_IsCoastal
		or type = YACriteriaType_IsForty
		or type = YACriteriaType_IsOverDimension
		or type = YACriteriaType_RecTransMode
		or type = YACriteriaType_RelTransMode
		or type = YACriteriaType_RequiresPower
		or type = YACriteriaType_Rehandles
		or type = YACriteriaType_SrcTermArea
		or type = YACriteriaType_SrcTermAreaType
		or type = YACriteriaType_Stops
		or type = YACriteriaType_ToDoTasks
		or type = YACriteriaType_VoyageTrade
		or type = YACriteriaType_VoyagePlanCode
		or type = YACriteriaType_WaterCooled
		or type = YACriteriaType_Weight
		or type = YACriteriaType_IsTransShip
		or type = YACriteriaType_IsHazardous
		or type = YACriteriaType_IsFortyFive
		or type = YACriteriaType_RailReleaseReq
		or type = YACriteriaType_IsCA
		or type = YACriteriaType_IsFiftyThree
		or type = YACriteriaType_IsThirty
		or type = YACriteriaType_TrailerType
		or type = YACriteriaType_IsTwenty
		or type = YACriteriaType_ContainerLength
		or type = YACriteriaType_IsHazOrLimited
		or type = YACriteriaType_CurtainsIn
		or type = YACriteriaType_SubTerminal
		or type = YACriteriaType_Train
		or type = YACriteriaType_IntendedRelMode
		or type = YACriteriaType_IsAvailable
		or type = YACriteriaType_ID
		or type = YACriteriaType_TranshipToPort
		or type = YACriteriaType_SpecialStow
		or type = YACriteriaType_TotalWeight
		or type = YACriteriaType_CargoLength
		or type = YACriteriaType_CargoWidth
		or type = YACriteriaType_CargoHeight
		or type = YACriteriaType_SpecialLift
		or type = YACriteriaType_VoyageInbound
		or type = YACriteriaType_VoyageOutbound
		or type = YACriteriaType_IsHazAllLimited
		or type = YACriteriaType_IsHazNotLimited
		or type = YACriteriaType_DestTerminal
		or type = YACriteriaType_TranshipDischPt
		or type = YACriteriaType_Damaged
		or type = YACriteriaType_IsEmpty
		or type = YACriteriaType_IsReefer
		or type = YACriteriaType_Colour
		or type = YACriteriaType_Mark
		or type = YACriteriaType_VehicleMake
		or type = YACriteriaType_VehicleModel
		or type = YACriteriaType_VehicleType
		or type = YACriteriaType_VehicleYear
		or type = YACriteriaType_IsNewVehicle
		or type = YACriteriaType_VehicleNbrDoors
		or type = YACriteriaType_IsSelfPropelled
		or type = YACriteriaType_TransactionType
		or type = YACriteriaType_Temperature
		or type = YACriteriaType_CargoGroup
		or type = YACriteriaType_DwellDays
		or type = YACriteriaType_HasExternalMon
		or type = YACriteriaType_FreightTons
		or type = YACriteriaType_IsWeightCert
		or type = YACriteriaType_ServiceOrder
		or type = YACriteriaType_MTPoolParty
		or type = YACriteriaType_InShipOper
		or type = YACriteriaType_OutShipOper
		or type = YACriteriaType_TransitStatus
		or type = YACriteriaType_DirectDelivery
		then
			if _criteriaFrame &lt;&gt; null then
				_criteriaFrame.disableCriteriaType( _criteriaType );
			endif;
			return true;
		endif;
*/
	elseif self.context = CM_ObjectMatchCriteria.ShipLineStatusInt then //09/08/2023	navkc1	CR 59580	Task 59588
		if _criteriaType = null then
			return false;
		endif;
		type := _criteriaType.type;
		
		if type.isOneOf(YACriteriaType_ShippingLine,
						YACriteriaType_CountryOfOrigin,
						YACriteriaType_LoadPort,
						YACriteriaType_DischargePort,
						YACriteriaType_CountryOfDest
						) then
			return false;
		else
			return true;
		endif;
		
	endif;
	
	return false;

epilog

end;</source>
        <Parameter name="_criteriaFrame" type="CMUI_YACriteriaCntl"/>
        <Parameter name="_criteriaType" type="CM_YACriteriaType"/>
