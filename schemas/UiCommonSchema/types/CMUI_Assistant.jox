    <JadeMethod name="listWeighAuthorityCoys" id="99328872-daab-4cba-8cf0-888feccaff57">
        <source>listWeighAuthorityCoys( _comboBox : ComboBox input; _term : CM_Terminal );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 August 2017	jlgndl1	Initial creation	TFS 5803

*/

vars

	certifiedName : String;
	iter : Iterator;
	weighAuthority : CM_WeighAuthority;
	addedArray : String200Array;
	index : Integer;

begin

	_comboBox.clear();
	 _comboBox.addItem(null);

	create addedArray transient;
	iter := app.myRoot.allWeighAuthorities.createIterator;
	while iter.next( weighAuthority ) do
		if weighAuthority.notAvailableForUse then
			continue;
		endif;
		if weighAuthority.allWeighAuthTerminals[self.myTerminal] = null then
			continue;
		endif;
		certifiedName := weighAuthority.certifiedName;
		if addedArray.includes( certifiedName ) then
			continue;
		endif;
		index := _comboBox.addItem(certifiedName);
		_comboBox.itemObject[index] := weighAuthority;
		addedArray.add( certifiedName );
	endwhile;

epilog

	delete iter;
	delete addedArray;

end;</source>
        <Parameter name="_comboBox" type="ComboBox" usage="input"/>
        <Parameter name="_term" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="listWeighAuthorityPersons" id="e0ec94d4-2547-43ea-81b4-f2974484ae31">
        <source>listWeighAuthorityPersons(  _comboBox : ComboBox input; _term : CM_Terminal; _certifiedName : String );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 August 2017	jlgndl1	Initial creation	TFS 5803

*/

vars

	certifiedName : String;
	authorisedPerson : String;
	iter : Iterator;
	weighAuthority : CM_WeighAuthority;
	startObject : Object;
	index : Integer; 
	
begin

	_comboBox.clear();
	 _comboBox.addItem(null);
	
	if _certifiedName = null then
		return;
	endif;

	iter := app.myRoot.allWeighAuthorities.createIterator;
	startObject := app.myRoot.allWeighAuthorities.getAtKeyGeq( _certifiedName, null );
	if startObject &lt;&gt; null then
		iter.startAtObject( startObject );
		while iter.next( weighAuthority ) do
			certifiedName := weighAuthority.certifiedName;
			if certifiedName &lt;&gt; _certifiedName then
				break;
			endif;
			if weighAuthority.notAvailableForUse then
				continue;
			endif;
			if weighAuthority.allWeighAuthTerminals[self.myTerminal] = null then
				continue;
			endif;
			authorisedPerson := weighAuthority.authorisedName;
			index := _comboBox.addItem( authorisedPerson );
			_comboBox.itemObject[index] := weighAuthority;
		endwhile;
	endif;

epilog

	delete iter;

end;</source>
        <Parameter name="_comboBox" type="ComboBox" usage="input"/>
        <Parameter name="_term" type="CM_Terminal"/>
        <Parameter name="_certifiedName" type="String"/>
    </JadeMethod>
    <JadeMethod name="listWorkOrderCargoTasks" id="da8a93ee-7650-40ce-a15d-dce6b18834c5">
        <source>listWorkOrderCargoTasks(_lstBox : CMUI_ListBox input; _terminal : CM_Terminal);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 Mar 2022 navma1  ChangeRequest 52351: MTN - Work Order Maintenance Refactor - UI
24 Jan 2023	navma1 	ChangeRequest 56141: EUP - Refactor and Remove CM_WorkOrderTISource from CM_WorkOrderTI

*/

vars
	workOrderDetailType : CM_WorkOrderDetailType;
begin
	
	_lstBox.clear();
	
	foreach  workOrderDetailType in app.myRoot.allWorkOrderTaskTypes do
		
		if workOrderDetailType.type = WorkOrderMode_Cargo then
			_lstBox.addTreeObject(workOrderDetailType.description, workOrderDetailType, 1, true);
		endif;
		
	endforeach;
epilog
end;</source>
        <Parameter name="_lstBox" type="CMUI_ListBox" usage="input"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="listWorkOrderTasks" id="a5408272-5efb-41bb-9990-215b27521407">
        <source>listWorkOrderTasks(_lstBox : CMUI_ListBox input; _terminal : CM_Terminal);
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24/08/2009	cnwmd1	Initial creation
07/05/2018	jlgdap1	TFS 38501 PEL1 Work Order Changes
29/09/21 	navma1  ChangeRequest 51925: SAL - Web Portal Cargo Work Orders
*/
vars
	taskDict		: CM_ToDoTaskDescByCode;
	tmpToDo			: CM_ToDoTaskDesc;
	dynaDict		: DynaDictionary;	//11 Jul 2018	NDL	TFS 39638
	obj 			: Object;			//11 Jul 2018	NDL	TFS 39638
begin
	_lstBox.clear();
	
	_lstBox.addTreeObject(app.myRoot.getWorkOrderTaskDescByType(WorkOrderMode_Cargo,WO_TASK_MOVE), null, 1, true);			//29.09.2021 navma1 #51925 
	_lstBox.addTreeObject(app.myRoot.getWorkOrderTaskDescByType(WorkOrderMode_Cargo,WO_TASK_PACK), null, 1, true);			//29.09.2021 navma1 #51925 
	_lstBox.addTreeObject(app.myRoot.getWorkOrderTaskDescByType(WorkOrderMode_Cargo,WO_TASK_UNPACK), null, 1, true);		//29.09.2021 navma1 #51925 
	
	_lstBox.addTreeObject(app.myRoot.getWorkOrderTaskDescByType(WorkOrderMode_Cargo,WO_TASK_EXPORTRETURN), null, 1, true);	//29.09.2021 navma1 #51925
	_lstBox.addTreeObject(app.myRoot.getWorkOrderTaskDescByType(WorkOrderMode_Cargo,WO_TASK_CHANGEVOYAGE), null, 1, true);	//29.09.2021 navma1 #51925
	_lstBox.addTreeObject(app.myRoot.getWorkOrderTaskDescByType(WorkOrderMode_Cargo,WO_TASK_RECEIVE), null, 1, true);	    //29.09.2021 navma1 #51925
	_lstBox.addTreeObject(app.myRoot.getWorkOrderTaskDescByType(WorkOrderMode_Cargo,WO_TASK_RELEASE), null, 1, true);	    //29.09.2021 navma1 #51925
	_lstBox.addTreeObject(app.myRoot.getWorkOrderTaskDescByType(WorkOrderMode_Cargo,WO_TASK_TODO), null, 1, true);	    	//29.09.2021 navma1 #51925
	
	create taskDict transient;
	app.myPassport.myUser.getToDoTasksAddRemoveForWOTerm(_terminal, null, taskDict);

	
	//11 Jul 2018	NDL	TFS 39638
	create dynaDict transient;
	dynaDict.setMembership( CM_ToDoTaskDesc );
	dynaDict.addMemberKey( CM_ToDoTaskDesc::description.name, false, true );
	dynaDict.endKeys( true );
	
	taskDict.copy( dynaDict );
	
	foreach obj in dynaDict do
		tmpToDo	:= obj.CM_ToDoTaskDesc;
		_lstBox.addTreeObject( tmpToDo.description, tmpToDo, 2, true);
	endforeach;
	
epilog
	delete taskDict;
	delete dynaDict;	//11 Jul 2018	NDL	TFS 39638
end;</source>
        <Parameter name="_lstBox" type="CMUI_ListBox" usage="input"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="listWorkOrderToDoTasks" id="4e4825b7-2ecf-4924-81d5-3424ad3255f6">
        <source>listWorkOrderToDoTasks(_listbox : CMUI_ListBox input; _terminal : CM_Terminal);

/*

Purpose:			

Parameters:			

Return Value:		


Date			Who		Reason
15 Dec 2022		navcs2  ChangeRequest 56840:[54265] EUP - [Framework] - VAS Work Order Maintenance Sceen
24 Jan 2023		navma1  ChangeRequest 56141: EUP - Refactor and Remove CM_WorkOrderTISource from CM_WorkOrderTI
13 Mar 2023 	navma1  ChangeRequest 56457:[56458] EUP - [Refactor] - Allowing different sets of cargo items per work order task
*/

vars
	workOrderDetailType : CM_WorkOrderDetailType;
	root				: CM_Root;
begin
	
	root			:= app.myRoot;
	_listbox.clear;
	_listbox.sorted := false;

	//13.03.2023 navma1 #56457:[56458]
	//_listbox.addTreeObject(root.getWorkOrderTaskDescByType(WorkOrderMode_Cargo,WO_TASK_TODO), root.allWorkOrderTaskTypes[WorkOrderMode_Cargo,WO_TASK_TODO], 1, true);	 
	
	foreach  workOrderDetailType in root.allWorkOrderTaskTypes do
		
		if workOrderDetailType.type = WorkOrderMode_ToDo then
			_listbox.addTreeObject(workOrderDetailType.description, workOrderDetailType, 1, true);
		endif;
		
	endforeach;
	
epilog

end;</source>
        <Parameter name="_listbox" type="CMUI_ListBox" usage="input"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="listWorkOrderVoyageTasks" id="2741bc94-3a64-4581-846f-ad07550f594e">
        <source>listWorkOrderVoyageTasks(_listbox : CMUI_ListBox input; _terminal : CM_Terminal);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 Jan 2022			navma1  ChangeRequest 52510: SAL - Web Portal - Berth display in Cargo Request
12 Jan 2023	navma1  ChangeRequest 56141: EUP - Refactor and Remove CM_WorkOrderTISource from CM_WorkOrderTI
*/

vars
	workOrderDetail : CM_WorkOrderDetailType;
	root			: CM_Root;
begin
	
	_listbox.clear;
	_listbox.sorted := false;
	root 			:= app.myRoot;
	
	_listbox.addTreeObject(app.getErrorString(Voyage_shift_movement),  		 root.allWorkOrderTaskTypes[WorkOrderMode_Voyage,WO_TASK_SHIFTMOVEMENT],  1, true);
	_listbox.addTreeObject(app.getErrorString(Permit_request),				 root.allWorkOrderTaskTypes[WorkOrderMode_Voyage,WO_TASK_PERMIT],   		1 , true);
	_listbox.addTreeObject(app.getErrorString(Voyage_time_change), 		     root.allWorkOrderTaskTypes[WorkOrderMode_Voyage,WO_TASK_TIMECHANGE],		1, true);
	_listbox.addTreeObject(app.getErrorString(Voyage_extension), 			 root.allWorkOrderTaskTypes[WorkOrderMode_Voyage,WO_TASK_EXTENSION], 		1, true);
	_listbox.addTreeObject(app.getErrorString(Voyage_water_request), 		 root.allWorkOrderTaskTypes[WorkOrderMode_Voyage,WO_TASK_WATER], 			1, true);
	_listbox.addTreeObject(app.getErrorString(Voyage_HMS_request_cancel),	 root.allWorkOrderTaskTypes[WorkOrderMode_Voyage,WO_TASK_HMSCANCEL],		1, true);
	
	
	//29.09.2021 navma1 #51925
	if app.getMyUser.canDo(self.myTerminal,PmAdmWorkOrderBillingAdjust) then
		workOrderDetail := root.allWorkOrderTaskTypes[WorkOrderMode_Voyage,WO_TASK_BILLINGADJ];
		if workOrderDetail &lt;&gt; null then	
			_listbox.addTreeObject(workOrderDetail.description,	 	workOrderDetail,		1, true);
		endif;
	endif;
epilog

end;</source>
        <Parameter name="_listbox" type="CMUI_ListBox" usage="input"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="loadAutoTimerCombos" id="96ddd9e0-b5bb-4fa8-836e-936b2e5ed7ee">
        <source>loadAutoTimerCombos(_cmb : ComboBox; num:Integer;factor:Integer);

vars
	trailer: String;
begin
	if factor = 1 then
		trailer := "sec";
	elseif factor = 60 then
		trailer := "min";
	elseif factor = 3600 then
		trailer := "hour";
	endif;
	if trailer &lt;&gt; null then
		_cmb.addItem(num.String &amp; " " &amp; trailer);
		_cmb.itemData[_cmb.newIndex] := num*factor;
	endif;

end;</source>
        <Parameter name="_cmb" type="ComboBox"/>
        <Parameter name="num" type="Integer"/>
        <Parameter name="factor" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="loadXTABFunctionsForQueryProp" id="3232a088-54b3-4646-8449-d0da64d32673">
        <source>loadXTABFunctionsForQueryProp(_property :CM_QueryProperty; _combo :ComboBox);
// ---------------------------------------------------------------------------
// Created:     12 February 2010 by cnwcs5
// Purpose:     par 22140
// Parameters:  _property 	- query property to load functions for
//				_combo		- combobox to load into
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 12/02/2010	cnwcs5	par 22140 - Refactored code when adding new functions
// ---------------------------------------------------------------------------
vars
	index :Integer;
begin
	index := _combo.addItem( app.getErrorString( COUNT ) );
	_combo.itemData[ index ] := CM_XTABField.Function_Count;
	
	if _property = null then
		return;
	endif;
	
	if _property.isDecimalOrInteger then
		// add the other allowed functions for integers and decimals.
		index := _combo.addItem( app.getErrorString( SUM ) );
		_combo.itemData[ index ] := CM_XTABField.Function_Sum;
		index := _combo.addItem( app.getErrorString( AVERAGE ) );
		_combo.itemData[ index ] := CM_XTABField.Function_Average;
		index := _combo.addItem( app.getErrorString( MAX ) );
		_combo.itemData[ index ] := CM_XTABField.Function_Max;
		index := _combo.addItem( app.getErrorString( MIN ) );
		_combo.itemData[ index ] := CM_XTABField.Function_Min;
		index := _combo.addItem( app.getErrorString( COUNT_ZERO ) );		// 15/12/2010		
		_combo.itemData[ index ] := CM_XTABField.Function_Count_Zero;		// 15/12/2010	
		index := _combo.addItem( app.getErrorString( COUNT_NOT_ZERO ) );	// 15/12/2010		
		_combo.itemData[ index ] := CM_XTABField.Function_Count_NotZero;	// 15/12/2010		
		
	elseif _property.isBoolean then												
		index := _combo.addItem( app.getErrorString( COUNT_TRUE ) );		
		_combo.itemData[ index ] := CM_XTABField.Function_Count_True;		
		index := _combo.addItem( app.getErrorString( COUNT_FALSE ) );		
		_combo.itemData[ index ] := CM_XTABField.Function_Count_False;		
	else
		// count_null &amp; count_notNull for strings
		index := _combo.addItem( app.getErrorString( COUNT_NULL ) );		
		_combo.itemData[ index ] := CM_XTABField.Function_Count_Null;		
		index := _combo.addItem( app.getErrorString( COUNT_NOT_NULL ) );	
		_combo.itemData[ index ] := CM_XTABField.Function_Count_NotNull;	
	endif;
epilog

end;</source>
        <Parameter name="_property" type="CM_QueryProperty"/>
        <Parameter name="_combo" type="ComboBox"/>
    </JadeMethod>
    <JadeMethod name="mainExtraGetTableAndRow" id="484b7b13-b851-4f46-b396-cb4bc14e417f">
        <source>mainExtraGetTableAndRow(pTblMain, pTblExtra : CM_EntryTable input; pName : String; pTable : CM_EntryTable output) : Integer;
// ---------------------------------------------------------------------------
// Created:     24 April 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	row	: Integer;
	
begin

	pTable := null;
	
	if pTblMain &lt;&gt; null then
		row := pTblMain.getRow(pName);
		if row &gt; 0 then
			pTable := pTblMain;
		elseif pTblExtra &lt;&gt; null then
			row := pTblExtra.getRow(pName);
			if row &gt; 0 then
				pTable := pTblExtra;
			endif;
		endif;
	endif;
	
	return row;
	
end;</source>
        <Parameter name="pTblMain" type="CM_EntryTable" usage="input"/>
        <Parameter name="pTblExtra" type="CM_EntryTable" usage="input"/>
        <Parameter name="pName" type="String"/>
        <Parameter name="pTable" type="CM_EntryTable" usage="output"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="mainExtraGetValue" id="4963be35-84d8-4d24-83bb-3bc8a4814633">
        <source>mainExtraGetValue(pTblMain, pTblExtra : CM_EntryTable input; pName : String) : Any;
// ---------------------------------------------------------------------------
// Created:     24 April 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	row	: Integer;
	
begin

	row := pTblMain.getRow(pName);
	if row &gt; 0 then
		//return pTblMain.getValue(row);

		// Need to check if row is visible.  If not then
		// return null (PAR-12565)
		if pTblMain.accessRow(row).visible then
			return pTblMain.getValue(row);
		else
			return null;
		endif;
	elseif pTblExtra &lt;&gt; null then
		//return pTblExtra.getValueByName(pName);

		// Need to check if row is visible.  If not then
		// return null (PAR-12565)
		row := pTblExtra.getRow(pName);
		if row &gt; 0 and pTblExtra.accessRow(row).visible then
			return pTblExtra.getValue(row);
		else
			return null;
		endif;
	else
		return null;
	endif;
	
end;</source>
        <Parameter name="pTblMain" type="CM_EntryTable" usage="input"/>
        <Parameter name="pTblExtra" type="CM_EntryTable" usage="input"/>
        <Parameter name="pName" type="String"/>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="mainExtraHideRow" id="1a27449f-a636-440b-9737-d5b5b55e1205">
        <source>mainExtraHideRow(pTblMain, pTblExtra : CM_EntryTable input; pName : String);
// ---------------------------------------------------------------------------
// Created:     24 April 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	row	: Integer;
	
begin

	row := pTblMain.getRow(pName);
	if row &gt; 0 then
		pTblMain.hideRow(row);
	else
		pTblExtra.hideRowByName(pName, true);
	endif;
	
end;</source>
        <Parameter name="pTblMain" type="CM_EntryTable" usage="input"/>
        <Parameter name="pTblExtra" type="CM_EntryTable" usage="input"/>
        <Parameter name="pName" type="String"/>
    </JadeMethod>
    <JadeMethod name="mainExtraListTableLostFocus" id="7dd0e81e-b3f1-4deb-ad23-2fbfc3ccea15">
        <source>mainExtraListTableLostFocus(pTblMain, pTblExtra : CM_EntryTable io; pListTable : CMUI_ListTable; pAttrName : String; saveRowHeight : Real io; _useDisplay : Boolean);
// ---------------------------------------------------------------------------
// Created:     24 April 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	row			: Integer;
	entryTable	: CM_EntryTable;
	str			: String;
begin

	row := pTblMain.myEntTableDef.getRowByControlName(pListTable.name);
	if row &lt;&gt; 0 then
		entryTable := pTblMain;
	else
		row := pTblExtra.myEntTableDef.getRowByControlName(pListTable.name);
		if row &lt;&gt; 0 then
			entryTable := pTblExtra;
		endif;
	endif;
	
	if entryTable = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Unable to action as listTable (' &amp; pListTable.name &amp; ') not found in main/extra tables');
		return;
	endif;
	
	entryTable.accessRow(row).height := saveRowHeight.Integer;
	saveRowHeight := 0;		// set to 0 so that can use in pTable.cellInputReady;
	entryTable.scrollBars := Table.ScrollBars_Both;
	
	if _useDisplay then
		str := pListTable.getSelectedFromDisplay();
	else
		str := pListTable.getSelectedString(pAttrName);
	endif;
	entryTable.setValue(row, str);

end;</source>
        <Parameter name="pTblMain" type="CM_EntryTable" usage="io"/>
        <Parameter name="pTblExtra" type="CM_EntryTable" usage="io"/>
        <Parameter name="pListTable" type="CMUI_ListTable"/>
        <Parameter name="pAttrName" type="String"/>
        <Parameter name="saveRowHeight" type="Real" usage="io"/>
        <Parameter name="_useDisplay" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="mainExtraSetValue" id="49ed411a-fed9-43ff-b42d-1b01b22cfd36">
        <source>mainExtraSetValue(pTblMain, pTblExtra : CM_EntryTable io; pName : String; pValue : Any);
// ---------------------------------------------------------------------------
// Created:     24 April 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	row	: Integer;
	
begin
	row := pTblMain.getRow(pName);
	if row &gt; 0 then
		pTblMain.setValue(row, pValue);
	else
		pTblExtra.setValueByName(pName, pValue);
	endif;
	
end;</source>
        <Parameter name="pTblMain" type="CM_EntryTable" usage="io"/>
        <Parameter name="pTblExtra" type="CM_EntryTable" usage="io"/>
        <Parameter name="pName" type="String"/>
        <Parameter name="pValue" type="Any"/>
    </JadeMethod>
    <JadeMethod name="mainExtraSetValueByControl" id="9ad7535f-7c56-4792-9c01-bc849f9a76ea">
        <source>mainExtraSetValueByControl(pTblMain, pTblExtra : CM_EntryTable input; pControlName : String; pValue : Any);
// ---------------------------------------------------------------------------
// Created:     24 April 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	row	: Integer;
	
begin
	row := pTblMain.getRowByControlName(pControlName);

	if row &gt; 0 then
		pTblMain.setValue(row, pValue);
	else
		pTblExtra.setValueByControlName(pControlName, pValue);
	endif;

end;</source>
        <Parameter name="pTblMain" type="CM_EntryTable" usage="input"/>
        <Parameter name="pTblExtra" type="CM_EntryTable" usage="input"/>
        <Parameter name="pControlName" type="String"/>
        <Parameter name="pValue" type="Any"/>
