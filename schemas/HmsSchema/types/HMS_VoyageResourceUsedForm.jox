        <updating/>
        <source>mskQueryDateFrom_lostFocus(editMask: JadeEditMask input) updating;
// ---------------------------------------------------------------------------
// Created:		11 August 2005  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	if editMask.isValid() then		// cnwdad1 04/08/2009 - PAR #20417.
		self.queryDateFrom := editMask.getTextAsDate();
	else
		self.queryDateFrom	:=	null;
	endif;
end;</source>
