epilog

end;</source>
        <Parameter name="_theTI" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_isLoad" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doUnqueueTI" id="7f4e3db6-cfa7-4a2c-83cd-960680f65d49">
        <updating/>
        <source>doUnqueueTI(_theTI : CM_TrackedItem input) updating;
//----------------------------------------------------------------
//	Created:	14 August 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

	idx : Integer;
	lTI	: CM_TrackedItem;
	aStr : String;
	lResult : Integer;
	lMoveControl : CMIF_MoveController;
	lTransferArea : CM_TerminalArea;
	lQEntry : CM_RTQueueEntry;
	result	: Integer;
begin
	mousePointer := MousePointer_HourGlass;	
	
	if _theTI = null then
		app.msgBox(app.getErrorString(Please_Select_A_Tracked_Item),"Unqueuing", MsgBox_OK_Only +MsgBox_Information_Icon);
		return;
	endif;
	
	create lMoveControl transient;
	lMoveControl.setMoveMode(QUEUE_MODE);
	lMoveControl.setMyTrackedItem(_theTI);
	lMoveControl.setMyWorkListEntry(_theTI.allWorklistEntries.last);
	
	//08 Feb 2011	NDL	Par 26913
	if lMoveControl.myWorkListEntry &lt;&gt; null and lMoveControl.myWorkListEntry.myFutureMove = null then
		lMoveControl.setMyWorkListEntry(null);
	endif;
	///////
	
	while true do
		app.myTrxUA.trxUpdateMoveTIUndo(lMoveControl, app.myPassport);
		if app.myPassport.trxCompletedOK then
			self.clearErrorWarnings();
			break;
		else
			result := app.showErrorWarningDialog('Unqueue', app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
				result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
		endif;
		break;
	endwhile;

epilog 
	if lMoveControl &lt;&gt; null then
		delete lMoveControl;
	endif;
	mousePointer := MousePointer_Default;	
end;</source>
        <Parameter name="_theTI" type="CM_TrackedItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doUnqueueTIbyFM" id="846ad3e0-5ed3-4418-ae47-37ec12b1d378">
        <updating/>
        <source>doUnqueueTIbyFM(_fm: CM_FutureMove) updating;
/*

Date		Who		Reason
28 May 2014	cnwer1	Initial creation PAR

*/

vars

begin
	 //shouldn't need this but if menu is cloned you get 1010 exception like it doesn't no that this form inherits from base form 
	inheritMethod(_fm);

epilog

end;</source>
        <Parameter name="_fm" type="CM_FutureMove"/>
    </JadeMethod>
    <JadeMethod name="doUpdateFromBookingRefChange" id="293c5bc5-c5f1-46e1-af41-af0d1b414568">
        <updating/>
        <source>doUpdateFromBookingRefChange(_table : CM_EntryTable input) updating;
/*
Purpose:			
Parameters:			
Return Value:		

Date		Who		Reason
22 May 2009	cnwrd1	Initial creation
11 Jan 2012 cnwdap1	PAR #28962 CCMS CPL 2100
16/03/2015	cnwmh5	Transient Leaks
14/07/2025	naviv1	MTN-35226	MTN - Usage of Iterator.getCurrentKeys  	
*/
vars
	bookRefNumber		: String;	
	bookingRefKey		: String;
	confObj				: Any;						// cnwrl1 03/11/2010 PAR 26170
	defOperator			: CM_Operator;				// cnwrl1 03/11/2010 PAR 26170
	operator			: CM_Operator;				// cnwrl1 03/11/2010 PAR 26170
	listBookRef			: CM_BookingRef;
	terminal			: CM_Terminal;
	entRowTrans			: EntTableRowTransient;
	iter				: Iterator;
	//bookingSelectForm	: CMUI_SelectBookingRefForm;	// PAR #28962
	bookingSelectForm	: CMUI_SelectBookingNoInfoForm;	// PAR #28962
	distPort			: CM_Port;
	destPort			: CM_Port;
	proxyTI				: CM_TrackedItem;
	rowPointer			: Integer;
	editObject			: CMIF_EditObject;
	editTable			: CM_EntryTable;
	isNoInfo			: Boolean;						// PAR #28962
	obj					: Object;						// PAR #28962
	brItem				: CM_BookingRefItem;			// PAR #28962
	bookingRef			: CM_BookingRef;				// PAR #28962
	commodity			: CM_Commodity;					// PAR #28962
	carrierCode			: String;						// PAR #28962
	consigneeCode		: String;						// PAR #28962
	consignorCode		: String;						// PAR #28962
	customsAgent		: CM_CustomsAgent;				// PAR #28962
	specialStow			: String;						// PAR #28962
	hazardCodes			: StringArray;					// PAR #28962
	hazard				: CM_Hazard;					// PAR #28962
	hazStr, liftStr		: String;						// PAR #28962
	lift				: CM_SpecialLift;				// PAR #28962
	specialLifts		: CM_SpecialLiftByCodeDict;		// PAR #28962

begin
	proxyTI := self.myProxyObject.CM_TrackedItem;
	
	terminal := self.myTerminal;
	if terminal = null then
		terminal := app.getMyTerminalDO_NOT_USE();
	endif;
	
	// cnwrl1 03/11/2010 PAR 26170 - start of coding
	// Need to get the operator entered on the screen
	editTable := self.getTableForRow(ETRow_MyOperator);
	if editTable &lt;&gt; null and
	   editTable.isRowVisible( ETRow_MyOperator ) then
		operator	:= self.cmbOperator.listObject.CM_Operator;
		// If the operator selected is the NULL operator or the "No Info" operator then reset to null.
		if operator &lt;&gt; null then
			confObj	:= terminal.getConfig( DefOperator );
			if confObj &lt;&gt; null then
				defOperator	:= 	confObj.CM_Operator;
			endif;
			
			if CM_NullOperator.hasInstance( operator ) or operator = defOperator then
				operator	:= null;
			endif;
		endif;
	else
		operator	:= null;
	endif;
	// cnwrl1 03/11/2010 PAR 26170 - end of coding
	
	// PAR #28962 CCMS CPL 2100 are we editing a container and is the container a no-info container?
	isNoInfo := proxyTI.isNoInfo and CM_Container.hasInstance(proxyTI);
	if self.doingMultiEdit then
		foreach obj in self.tblData.allSelectedObjects do
			if not obj.CM_TrackedItem.isNoInfo then
				isNoInfo := false;
				break;
			endif;
		endforeach;
	endif;
	
	bookRefNumber := _table.getValueByName(ETRow_BookingReference).String.trimRight;
	
	//cnwrd1 ccms PNL 1804
	//assume we only want to do this if changed value
	rowPointer	:=	_table.getRowByName(ETRow_BookingReference);
	
	if rowPointer &gt; _table.fixedRows then
		entRowTrans := _table.accessRow(rowPointer).itemObject.EntTableRowTransient;
	endif;
	
	if entRowTrans &lt;&gt; null
	//and entRowTrans.originalValue &lt;&gt; bookRefNumber			//-cnwml2 PAR24259
	and bookRefNumber &lt;&gt; null
	and self.currentEditedBookingRef &lt;&gt; bookRefNumber
	then
		self.currentEditedBookingRef := bookRefNumber;

		iter := terminal.allBookingRefsByRef.createIterator();
		

		/*bookingSelectForm := app.getForm(CMUI_SelectBookingNoInfoForm.name).CMUI_SelectBookingNoInfoForm;
		
		if bookingSelectForm &lt;&gt; null then //doing this elsewhere
			return; //so return
		endif;*/
		
		create bookingSelectForm;
		
		bookingSelectForm.setMyTerminal(terminal);			//+cnwml2 PAR24395
		bookingSelectForm.myCurrentTrackedItem := proxyTI; 
		bookingSelectForm.isNoInfo := isNoInfo;				// PAR #28962
		terminal.allBookingRefsByRef.startKeyGeq(bookRefNumber, iter);
	
		while iter.next(listBookRef) do
			iter.getCurrentKeys(bookingRefKey);  //MTN-35226
		
			if bookRefNumber &lt;&gt; bookingRefKey then
				break;
			endif;
			
			// 19/01/2011 cnwar2 #28114
			if listBookRef.status &lt;&gt; BOOKING_REF_ACTIVE then
				continue;
			endif;
			
			/* cnwrl1 03/11/2010 PAR 26170 - what it was
			//+cnwml2 PAR25338
			if listBookRef.myOperator &lt;&gt; proxyTI.myOperator then
				continue;
			endif;		
			cnwrl1 03/11/2010 PAR 26170 - end of what it was */
			
			// cnwrl1 03/11/2010 PAR 26170 - start of replacement coding
			// Only if the operator on the form is a specific operator do we match to the booking
			// ie NULL operator oe the "No Info" operators are ignored.
			if operator &lt;&gt; null then
				if listBookRef.myOperator &lt;&gt; operator then
					continue;
				endif;
			endif;
			// cnwrl1 03/11/2010 PAR 26170 - end of coding
			
			bookingSelectForm.allBookingRefs.add(listBookRef);
		endwhile;
		
		if bookingSelectForm.allBookingRefs.size() &gt; 0 then
			// pop up the form....
			bookingSelectForm.showModal();
		
			if bookingSelectForm.modalResult = ModalResultOK then
				//have chosen a booking ref need to set some values.
				
				// voyage
				
				self.setInitialisedTableValByEntRow(ETRow_MyVoyage, bookingSelectForm.myCurrentBookingRef.myVoyage.code);
				self.myAssistant.comboBoxVoyageObject(self.cmbVoyage, bookingSelectForm.myCurrentBookingRef.myVoyage.code);
				proxyTI.setVoyageCode(bookingSelectForm.myCurrentBookingRef.myVoyage.code, app.myPassport);
					
				//+cnwml2 PAR24259
				create editObject transient;
				editObject.myBulkEditController := self.myBulkEditController;
				editObject.attrName := ETRow_MyVoyage;
	
				//discharge
				self.setInitialisedTableValByEntRow(ETRow_DischargePort, bookingSelectForm.myCurrentBookingRef.dischargePort);
				if self.myTerminal.getConfig(ShowPortOfCallTranship).Boolean then
					self.setInitialisedTableValByEntRow(ETRow_MyTranshipToPort, bookingSelectForm.myCurrentBookingRef.myTranshipToPort);
				endif;
				distPort := app.myRoot.allPorts[bookingSelectForm.myCurrentBookingRef.dischargePort];
				self.cmbDisPort.setObject(distPort);
				proxyTI.setDischargePort(bookingSelectForm.myCurrentBookingRef.dischargePort);
				proxyTI.setTranshipToPort(bookingSelectForm.myCurrentBookingRef.myTranshipToPort);
				
				//+cnwml2 PAR24259
				create editObject transient;
				editObject.myBulkEditController := self.myBulkEditController;
				editObject.attrName := ETRow_DischargePort;				
				create editObject transient;
				editObject.myBulkEditController := self.myBulkEditController;
				editObject.attrName := ETRow_MyTranshipToPort;
								
				
				//destination
				destPort := app.myRoot.allPorts[bookingSelectForm.myCurrentBookingRef.destinationPort];
				self.setInitialisedTableValByEntRow(ETRow_DestinationPort, bookingSelectForm.myCurrentBookingRef.destinationPort);
				self.cmbDestPort.setObject(destPort);
				proxyTI.setDestinationPort(bookingSelectForm.myCurrentBookingRef.destinationPort);
				
				//+cnwml2 PAR24259
				create editObject transient;
				editObject.myBulkEditController := self.myBulkEditController;
				editObject.attrName := ETRow_DestinationPort;			
				
				// PAR #28962 CCMS CPL 2100 if we have a no-info container, need to update LOTS of other things
				if isNoInfo and bookingSelectForm.optFull.value then
					brItem := bookingSelectForm.myCurrentBookingRefItem;
					bookingRef := bookingSelectForm.myCurrentBookingRef;
					
					if brItem &lt;&gt; null then
						self.setAnyTableValByEntRow(ETRow_MyBookingRefItem, brItem.getShortDisplay);
						self.loadBookingRefItems(bookingRef);
						cmbBRItem.setObject(brItem);	
					//	proxyTI.setBookingRefAndItem();
						create editObject transient;
						editObject.myBulkEditController := self.myBulkEditController;
						editObject.attrName := ETRow_MyBookingRefItem;						
					endif;
					
					// carriage temperature
					if brItem.getTemperature &lt;&gt; NULL_TEMPERATURE then
						self.setAnyTableValByEntRow(ETRow_Temperature, brItem.getTemperature);
						self.setAnyTableValByEntRow(ETRow_TemperatureInFahrenheit, app.temperatureConversion(true, brItem.getTemperature));
						proxyTI.setTemperature(brItem.getTemperature);
						create editObject transient;
						editObject.myBulkEditController := self.myBulkEditController;
						editObject.attrName := ETRow_Temperature;			
					endif;
					// carrier
					if bookingRef.myCarrier &lt;&gt; null then
						carrierCode := bookingRef.myCarrier.code;
						self.setAnyTableValByEntRow(ETRow_Carrier, carrierCode);
						self.cmbCarrier.setObject(bookingRef.myCarrier);
						proxyTI.setCarrier(carrierCode);
						create editObject transient;
						editObject.myBulkEditController := self.myBulkEditController;
						editObject.attrName := ETRow_Carrier;			
					endif;
					// cleaned
					//self.setInitialisedTableValByEntRow(ETRow_IsClean, brItem.clean);
					//proxyTI.CM_Container.setClean(brItem.clean);
					// commodity
					commodity := app.myRoot.allCommodities[brItem.commodity];
					self.setAnyTableValByEntRow(ETRow_Commodity, brItem.commodity);
					self.cmbCommodity.setObject(commodity);
					proxyTI.setCommodity(brItem.commodity);
					create editObject transient;
					editObject.myBulkEditController := self.myBulkEditController;
					editObject.attrName := ETRow_Commodity;			
					// consignee
					if bookingRef.myConsignee &lt;&gt; null then
						consigneeCode := bookingRef.myConsignee.code;
					endif;
					self.setAnyTableValByEntRow(ETRow_Consignee, consigneeCode);
					self.cmbConsignee.setObject(bookingRef.myConsignee);
					proxyTI.setConsigneeByString(consigneeCode);
					create editObject transient;
					editObject.myBulkEditController := self.myBulkEditController;
					editObject.attrName := ETRow_Consignee;			
					// consignor
					if bookingRef.myConsignor &lt;&gt; null then
						consignorCode := bookingRef.myConsignor.code;
					endif;
					self.setAnyTableValByEntRow(ETRow_Consignor, consignorCode);
					self.cmbConsignor.setObject(bookingRef.myConsignor);
					proxyTI.setConsignorByString(consignorCode);
					create editObject transient;
					editObject.myBulkEditController := self.myBulkEditController;
					editObject.attrName := ETRow_Consignor;			
					// customs agent
					customsAgent := app.myRoot.allCustomsAgents[bookingRef.customsAgent];
					self.setAnyTableValByEntRow(ETRow_MyCustomsAgent, bookingRef.customsAgent);
					self.cmbCustomsAgent.setObject(customsAgent);
					proxyTI.setCustomsAgent(customsAgent);
					create editObject transient;
					editObject.myBulkEditController := self.myBulkEditController;
					editObject.attrName := ETRow_MyCustomsAgent;			
					// description
					self.setAnyTableValByEntRow(ETRow_Description, brItem.description);
					proxyTI.setDescription(brItem.description);
					create editObject transient;
					editObject.myBulkEditController := self.myBulkEditController;
					editObject.attrName := ETRow_Description;			
					// hazards
					create hazardCodes transient;
					foreach hazard in brItem.allTIHazards do
						if hazStr &lt;&gt; null then
							hazStr := hazStr &amp; "; ";
						endif;
						hazStr := hazStr &amp; hazard.getTableDisplay(false, true);
						hazardCodes.add(hazard.code);
					endforeach;
					self.setAnyTableValByEntRow(ETRow_AllTIHazards, hazStr);
					proxyTI.setPxyTIHazardsFromStringArray(hazardCodes);
					//self.lstHazList.setSelectedFromObject(proxyTI); //epr TFS 47132
					delete hazardCodes;
					create editObject transient;
					editObject.myBulkEditController := self.myBulkEditController;
					editObject.attrName := ETRow_AllTIHazards;			
					// mark number
					self.setAnyTableValByEntRow(ETRow_Mark, brItem.markNumber);
					proxyTI.setMarkNumber(brItem.markNumber);
					create editObject transient;
					editObject.myBulkEditController := self.myBulkEditController;
					editObject.attrName := ETRow_Mark;			
					// operator
					self.setAnyTableValByEntRow(ETRow_MyOperator, bookingRef.myOperator.code);
					self.cmbOperator.setObject(bookingRef.myOperator);
					proxyTI.setOperatorCode(bookingRef.myOperator.code, app.myPassport);
					create editObject transient;
					editObject.myBulkEditController := self.myBulkEditController;
					editObject.attrName := ETRow_MyOperator;			
					// over dimensions details
					if brItem.getIsOverDimension &lt;&gt; proxyTI.isOverDimensions or brItem.height &lt;&gt; proxyTI.CM_Container.overHeight or brItem.length &lt;&gt; proxyTI.CM_Container.overLengthFront or brItem.width &lt;&gt; proxyTI.CM_Container.overWidthRight then
						self.setAnyTableValByEntRow(ETRow_IsOverDimensions, brItem.getIsOverDimension);
						self.setAnyTableValByEntRow(ETRow_OverHeight, brItem.height);
						self.setAnyTableValByEntRow(ETRow_OverLengthFront, brItem.length);
						self.setAnyTableValByEntRow(ETRow_OverLengthBack, null);
						self.setAnyTableValByEntRow(ETRow_OverWidthRight, brItem.width);
						self.setAnyTableValByEntRow(ETRow_OverWidthLeft, null);
						proxyTI.setIsOverDimensions(brItem.getIsOverDimension);
						proxyTI.CM_Container.setOverHeight(brItem.height, null, app.myPassport);
						proxyTI.CM_Container.setOverLengthFront(brItem.length, null, app.myPassport);
						proxyTI.CM_Container.setOverLengthRear(null, null, app.myPassport);
						proxyTI.CM_Container.setOverWidthRight(brItem.width, null, app.myPassport);
						proxyTI.CM_Container.setOverWidthLeft(null, null, app.myPassport);
						create editObject transient;
						editObject.myBulkEditController := self.myBulkEditController;
						editObject.attrName := ETRow_IsOverDimensions;
					endif;
					// Reefer - CO2 %
					if brItem.getCarbonDioxide &lt;&gt; NULL_CARBON_DIOXIDE then
						self.setAnyTableValByEntRow(ETRow_CarbonDioxide, brItem.getCarbonDioxide);
						proxyTI.setCarbonDioxide(brItem.getCarbonDioxide);
						create editObject transient;
						editObject.myBulkEditController := self.myBulkEditController;
						editObject.attrName := ETRow_CarbonDioxide;			
					endif;
					// Reefer - curtains in
					if brItem.getCurtainsIn then
						self.setAnyTableValByEntRow(ETRow_CurtainsIn, brItem.getCurtainsIn);
						proxyTI.setCurtainsIn(brItem.getCurtainsIn);
						create editObject transient;
						editObject.myBulkEditController := self.myBulkEditController;
						editObject.attrName := ETRow_CurtainsIn;			
					endif;
					// Reefer - Humidity
					if brItem.getHumidity &lt;&gt; null then
						self.setAnyTableValByEntRow(ETRow_Humidity, brItem.getHumidity);
						proxyTI.setHumidity(brItem.getHumidity);
						create editObject transient;
						editObject.myBulkEditController := self.myBulkEditController;
						editObject.attrName := ETRow_Humidity;			
					endif;
					// Reefer - Oxygen
					if brItem.getOxygen &lt;&gt; NULL_OXYGEN then
						self.setAnyTableValByEntRow(ETRow_Oxygen, brItem.getOxygen);
						proxyTI.setOxygen(brItem.getOxygen);
						create editObject transient;
						editObject.myBulkEditController := self.myBulkEditController;
						editObject.attrName := ETRow_Oxygen;			
					endif;
					// Reefer - ventilation
					if brItem.getVentilation &lt;&gt; NULL_VENTILATION then
						self.setAnyTableValByEntRow(ETRow_Ventilation, brItem.getVentilation);
						proxyTI.setVentilation(brItem.getVentilation);
						create editObject transient;
						editObject.myBulkEditController := self.myBulkEditController;
						editObject.attrName := ETRow_Ventilation;			
					endif;
					// remarks
					self.setAnyTableValByEntRow(ETRow_Remarks, brItem.remarks);
					proxyTI.setRemarks(brItem.remarks, false);
					create editObject transient;
					editObject.myBulkEditController := self.myBulkEditController;
					editObject.attrName := ETRow_Remarks;			
					// special lift
					create specialLifts transient;
					foreach lift in brItem.allSpecialLifts do
						if liftStr &lt;&gt; null then
							liftStr := liftStr &amp; "; ";
						endif;
						liftStr := liftStr &amp; lift.code;
						specialLifts.add(lift);
					endforeach;
					self.setAnyTableValByEntRow(ETRow_AllSpecialLifts, liftStr);
					proxyTI.zSetPxySpecialLifts(specialLifts);
					proxyTI.allSpecialLifts.copy(self.lstTblSpecialLif.allSelectedObjects);
					//create editObject transient;
					//editObject.myBulkEditController := self.myBulkEditController;
					//editObject.attrName := ETRow_AllSpecialLifts;			
					// special stow
					if brItem.mySpecialStow &lt;&gt; null then
						specialStow := brItem.mySpecialStow.code;
					endif;
					self.setAnyTableValByEntRow(ETRow_SpecialStow, specialStow);
					self.cmbSpecialStow.setObject(brItem.mySpecialStow);
					proxyTI.setSpecialStow(specialStow);
					create editObject transient;
					editObject.myBulkEditController := self.myBulkEditController;
					editObject.attrName := ETRow_SpecialStow;			
					// tranship port - handled by changing the discharge port above
					
				endif;
			endif;
		endif;
	endif;
epilog
	delete iter;
	delete bookingSelectForm;
	delete specialLifts;
	delete hazardCodes;
end;</source>
        <Parameter name="_table" type="CM_EntryTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doUserNotes" id="989b73cf-bcea-4a1b-ae92-7aae296e86b6">
        <updating/>
        <source>doUserNotes(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;
//--------------------------------------------------
// Created:	02 July 2004 By: cnwgd1
//--------------------------------------------------
vars
	event	: Integer;

begin

	inheritMethod(eventType, theObject, eventTag, userInfo);
	
	event := self.myTerminal.getEventFromTerminalEvent(eventType);
	if userInfo &lt;&gt; null and userInfo.isKindOf(CM_BOL) then
		if event = BOL_Update_Event then
			self.zTblDataSysNotifyUpdate(eventType, userInfo.CM_BOL, eventTag);
		endif;
	endif;
	// CCMS 1776 change of user config, refresh the current instance, but not if currently editing
	if event = UserConfigCargo_Update_Event then
		if self.mode = Mode_Update then
			return;
		endif;
		delete self.myUserCargoType;
		delete self.myReeferCargoType;
		self.showThumbnailData(self.myCurrentObject.CM_Object);
	endif;
end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
