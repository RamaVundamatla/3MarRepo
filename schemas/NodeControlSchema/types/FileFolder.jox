<Class name="FileFolder">
    <JadeMethod name="getServerFileList" id="a8c80b1f-33e4-4616-aa2c-c6d39b05bdfb">
        <executionLocation>server</executionLocation>
        <source>getServerFileList(startDir : String; mask : String) : String serverExecution;

vars
	ff :		FileFolder;
	fn :		FileNode;
	fileList :	String;
	fName :		String;
	pos :		Integer;
begin
	create ff;
	ff.fileName := startDir;
	ff.mask := "*.*";
	
	foreach fn in ff.files do
		if fn.isKindOf(File) then
			if node._isUnixServerPlatform then
				pos := fn.fileName.reversePos("/") + 1;
			else
				pos := fn.fileName.reversePos("\") + 1;
			endif;
			fName := fn.fileName[pos:end];
			fileList := fileList &amp; fName &amp; Tab;
		endif;
	endforeach;
	
	return fileList;
end;</source>
        <Parameter name="startDir" type="String"/>
        <Parameter name="mask" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
</Class>
