    <JadeMethod name="validateForUpdate" id="efeb5303-f0ac-4505-9256-8bf344312032">
        <source>validateForUpdate();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		 Reason
08 Nov 2023	navhn30	 ChangeRequest 59144: PEN - Reefer Jobs and connection status
*/

vars

