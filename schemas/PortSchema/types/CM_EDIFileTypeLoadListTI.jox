    <DbClassMap file="edi"/>
    <JadeMethod name="create" id="2c5679b7-56ad-4bce-b622-677136d87170">
        <updating/>
        <source>create() updating;
// ---------------------------------------------------------------------------
// Created:     09 August 2007 by cnwvu1
// ---------------------------------------------------------------------------

vars

begin

	self.name 	:= "Load List TI";
	self.type	:= EDIFileType_LoadListTI;

end;
</source>
    </JadeMethod>
    <JadeMethod name="createEDIData" id="252e6520-78a3-40c1-a704-b703c6e65432">
        <source>createEDIData(_transient: Boolean): CM_EDIDataLoadList;
//----------------------------------------------------------------
//	Created:	09 August 2007	by cnwvu1
//----------------------------------------------------------------

vars
	loadList	: CM_EDIDataLoadList;

begin
	if _transient then
		create loadList transient;
	else
		create loadList persistent;
	endif;

	return loadList;
	
end;
</source>
        <Parameter name="_transient" type="Boolean"/>
        <ReturnType type="CM_EDIDataLoadList"/>
    </JadeMethod>
    <JadeMethod name="getEDIBundle" id="19dfbf2f-70fe-4f95-94cd-64b522744ea3">
        <source>getEDIBundle(): Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23/12/2024	navkc1 JIRA Story MTN-33491: MTN | License - EDI Bundles Methods

*/

vars

begin
	
	return self.EDI_Bundle_CUSTOM;

epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
