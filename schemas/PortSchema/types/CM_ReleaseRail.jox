    </JadeMethod>
    <JadeMethod name="setTiReleasedTransportMode" id="41ec24c8-58f8-4054-a7e7-2e3b8109dbe9">
        <source>setTiReleasedTransportMode(_ti:CM_TrackedItem input);
// ---------------------------------------------------------------------------
// Created:     24 May 2004 by cnwrs1
//
// Purpose:     PAR8243
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	_ti.setReleasedTransportMode(TI_TRANSMODE_RAIL);
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="updateTI" id="700656a3-6d76-44c3-a8c0-153d6200dc37">
        <updating/>
        <source>updateTI(_passport: CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     12 June 2009 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
// 11/08/2011		cnwdap1			PAR #27972 Bulk Release Transport Mode no longer translated
// 02/05/2022		jlizm1			TFS 53083 GPHA revceival/release of tranship cargo
// ---------------------------------------------------------------------------

vars
	trainCode	: String;
	ti			: CM_TrackedItem;
	txnParams	: CMIF_TITransactionController;
	wle			: CM_WorkListEntry;
	
begin
	inheritMethod(_passport);
	
	ti := self.myTrackedItem;
	if ti = null then
		return;
	endif;

	if ti.isTranshipItem then
		if ti.getTransitStatus() &lt;&gt; TI_TransitStatusInterModal then
			// tranship cargo can only be released by rail if it has Intermodal transit status
			app.raiseCMException2(Trans_item_trans_items_canno_, ti.id, BR_TYPE_RAIL_STR, null, self);							// PAR #27972
		endif;
	endif;
	
	// 07/10/2009 cnwar2 #21059
	foreach wle in ti.allWorklistEntries do
		if wle.isReleaseWithRelReq() and wle.isRail() then
			wle.updateForRelease();
		endif;
	endforeach;
	// 25618 selector query by release train, save in allExtraData
	trainCode := ti.findReleaseTrainCode();
	if trainCode &lt;&gt; null then
		self.setExtraData(TrnsExtraDataReleaseTrain, trainCode);
	endif;
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
</Class>
