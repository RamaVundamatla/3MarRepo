    <JadeMethod name="getExtraInfo" id="779b55c7-9a1f-4078-9341-9216812518f3">
        <source>getExtraInfo(_dataContainer: CM_DataContainer);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 Jan 2023	navcs2	ChangeRequest 56822:[56823] EUP - VAS Voyage Work Order
*/

vars
	block   	: CM_DataContainerBlock;
	addStr  	: String;	
	voyage		: CM_Voyage;
begin
	
	inheritMethod(_dataContainer);

	addStr := self.allVoyages.listString(Comma,CM_Voyage::code.name);
	if addStr &lt;&gt; null then
		voyage	:= self.allVoyages.first;
		block 	:= _dataContainer.addNewBlock;
		block.addNewItem(app.getErrorString(Voyage), DC_Label, 1, voyage);
		block.addNewItem(addStr, DC_Data, 1, voyage);
	endif;	
	
	if app.isSpecial then														//08.02.2023 navma1 #56457 Task#56458
		block.addNewItem('All Actioned', DC_Label, 1, self);
		block.addNewItem(self.allVoyagesActioned.size.String, DC_Data, 1, self);
		
		block.addNewItem('All Completed', DC_Label, 1, self);
		block.addNewItem(self.allVoyagesCompleted.size.String, DC_Data, 1, self);
		
	endif;
epilog

end;</source>
        <Parameter name="_dataContainer" type="CM_DataContainer"/>
    </JadeMethod>
    <JadeMethod name="getMyBank" id="9fb81153-0ad3-4fb6-99ee-47db8b575743">
        <source>getMyBank() : CM_Bank;
/*
Purpose:			

Date		Who		Reason
23JUN2023	NAVAB1	 BUG 58790
*/

vars
	voyage : CM_Voyage;
	bank : CM_Bank;
begin
	voyage := self.allVoyages.first;
	if voyage &lt;&gt; null then
		bank := voyage.myDischargeCompany;
		if bank &lt;&gt; null then
			return bank;
		endif;
	endif;
	
	return self.myParent.getMyBank();
epilog

end;</source>
        <ReturnType type="CM_Bank"/>
    </JadeMethod>
    <JadeMethod name="getMyDebtor" id="8fa31288-9df1-4e3f-bc74-a70decbeb0c0">
        <source>getMyDebtor() : CM_Debtor;
/*
Purpose:			

Date		Who		Reason
23JUN2023	NAVAB1	 BUG 58790
*/

vars
	debtor : CM_Debtor;
	voyage : CM_Voyage;
begin
	 // ### TFS CR 56814 TASK 56813 07JUL2023 NAVAB1
	if self.myDebtor &lt;&gt; null then
		return self.myDebtor;
	endif;

	voyage := self.allVoyages.first;
	if voyage = null then
		voyage := self.allVoyagesCompleted.first;
	endif;
	
	if voyage &lt;&gt; null then
		if voyage.myOperator &lt;&gt; null then
			debtor := voyage.myOperator.debtor;
		endif;
	endif;
	
	if debtor = null then
		debtor :=  self.myParent.getMyDebtor();  // ### TFS BUG 58790 23JUN2023 NAVAB1
	endif;
	
	return debtor;
epilog

end;</source>
        <ReturnType type="CM_Debtor"/>
    </JadeMethod>
    <JadeMethod name="getMyVoyageObject" id="1c3d262b-cfc5-479d-a9ff-cef9008beca4">
        <source>getMyVoyageObject(): CM_Voyage;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 Mar 2023	navma1	Defect 57188: MTN - WO -Voyage is not correctly shown if there are multiple To Do Voyage tasks

*/

vars

begin
	
	if self.allVoyages.isEmpty then
		return null;
	endif;
	
	return self.allVoyages.first;
epilog

end;</source>
