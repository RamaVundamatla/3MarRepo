    <JadeMethod name="translateForm" id="b6d655cd-d644-4ee9-8db6-305228bc66b3">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 25 June 2021 10:06:40.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0023357, locale);
	btnAdd.translateCaption(Xlat_0001382, locale);
	btnCargoEnq.translateBubbleHelp(Xlat_0001381, locale);
	btnCargoEnq.translateCaption(Xlat_0001384, locale);
	btnRemove.translateCaption(Xlat_0001385, locale);
	btnRetrieve.translateCaption(Xlat_0001386, locale);
	btnSelector.translateCaption(Xlat_0023709, locale);
	chkUseColOrg.translateCaption(Xlat_0024333, locale);
	chkUseFilter.translateCaption(Xlat_0001387, locale);
	lblNoSelected.translateCaption(Xlat_0005502, locale);
	mnuCargoEnq.translateCaption(Xlat_0005503, locale);
	mnuColOrg.translateCaption(Xlat_0024334, locale);
end;</source>
    </JadeMethod>
    <JadeMethod name="unload" id="45abb082-3a95-41f0-b165-c2b5c069f66d">
        <controlMethod name="Form::unload"/>
        <methodInvocation>event</methodInvocation>
