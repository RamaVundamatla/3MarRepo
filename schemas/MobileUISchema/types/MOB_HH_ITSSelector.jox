    <JadeMethod name="createInterTerminalJobFor" id="42c5b311-1b9f-48da-90b6-fdc2902fee63">
        <source>createInterTerminalJobFor( _truck : CM_Vehicle; _driver : String ):CM_InterTermVehicleJob;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 February 2010	cnwndl1	Initial creation

*/

vars

	interTermJob : CM_InterTermVehicleJob;
	proxy : CM_InterTermVehicleJob;
	result : Boolean;
	
begin

	interTermJob := _truck.getInterTerminalJob();
	if interTermJob &lt;&gt; null then
		return interTermJob;
	endif;

	//if the truck doesn't have an inter terminal transfer job, then create one here.
	create proxy transient;
	proxy.setProxy(_truck, _driver);
	app.myTrxCA.trxCreateInterTermVehicleJob(proxy, interTermJob, app.myPassport);
	result	:=	app.myPassport.trxCompletedOK;
	if result = false then
		app.showErrorWarningDialog(app.getString(Inter_Terminal_Transfer), app.myPassport, ErrWarnMode_Update);
		return null;
	endif;
	
	return interTermJob;
	
epilog

	delete proxy;

end;</source>
        <Parameter name="_truck" type="CM_Vehicle"/>
        <Parameter name="_driver" type="String"/>
        <ReturnType type="CM_InterTermVehicleJob"/>
    </JadeMethod>
    <JadeMethod name="doBtnLoadClick" id="0105831f-4d88-4e37-8633-c95a0b624184">
        <updating/>
        <source>doBtnLoadClick() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
11 February 2010	cnwndl1	Initial creation	CCMS OPO 1867

*/

vars

	truck : CM_Vehicle;
	term : CM_Terminal;
	errMess : String;
	driver : String;

begin

	term := self.cmbTerminal.listObject.CM_Terminal;
	if term = null then
		self.msgBox( app.getErrorString(Select_Terminal), app.getErrorString(Error), MsgBox_OK_Only, true);
		self.cmbTerminal.setFocus();
		return;
	endif;
	

	truck := self.findTruck( errMess );
	if truck = null then
		self.msgBox( errMess, app.getErrorString(Error), MsgBox_OK_Only, true);
		self.tbxVehicle.setFocus();
		return;
	endif;
	
	driver := tbxUser.text.trimBlanks[1:30];
	if driver = null or driver = lblUser.caption.toUpper then
		errMess := app.getErrorString1(ERR_Driver_Name_Blank,null);
		self.msgBox( errMess, app.getErrorString(Error), MsgBox_OK_Only, true);
		self.tbxUser.setFocus();
		return;
	endif;
	
	//if the truck doesn't have an inter terminal transfer job, then create one here.
	self.createInterTerminalJobFor( truck, driver );
	
	self.myMobileGenericAgent.setTruck(truck);
	self.myMobileGenericAgent.setMyInterTerminal(term);
	self.myMobileGenericAgent.setInterTerminal(true);
	self.myMobileGenericAgent.setDriver(driver);
	self.gotoForm( MOB_HHITSTruckLoaderAllCargo, false );
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doBtnUnloadClick" id="0599c80b-1e37-428a-81b9-65602292f433">
        <updating/>
        <source>doBtnUnloadClick() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
11 February 2010	cnwndl1	Initial creation	CCMS OPO 1867

*/

vars

	truck : CM_Vehicle;
	term : CM_Terminal;
	errMess : String;
	interTerminalJob : CM_InterTermVehicleJob;
	driver : String;

begin

	term := self.cmbTerminal.listObject.CM_Terminal;
	if term = null then
		self.msgBox( app.getErrorString(Select_Terminal), app.getErrorString(Error), MsgBox_OK_Only, true);
		self.cmbTerminal.setFocus();
		return;
	endif;
	

	truck := self.findTruck( errMess );
	if truck = null then
		self.msgBox( errMess, app.getErrorString(Error), MsgBox_OK_Only, true);
		self.tbxVehicle.setFocus();
		return;
	endif;

	interTerminalJob := truck.getInterTerminalJob();
	if interTerminalJob = null then
		errMess := app.getErrorString(No_Inter_Term_Job_Unload);
		self.msgBox( errMess, app.getErrorString(Error), MsgBox_OK_Only, true);
		return;
	endif;
	
	if not interTerminalJob.includesMovesForTargetTerm( term ) then
		errMess := app.getErrorString1(Truck_has_no_inter_term_cargo, term.name);
		self.msgBox( errMess, app.getErrorString(Error), MsgBox_OK_Only, true);
		return;
	endif;
	
	driver := tbxUser.text.trimBlanks[1:30];
	if driver = null or driver = lblUser.caption.toUpper then
		errMess := app.getErrorString1(ERR_Driver_Name_Blank,null);
		self.msgBox( errMess, app.getErrorString(Error), MsgBox_OK_Only, true);
		self.tbxUser.setFocus();
		return;
	endif;
	
	self.myMobileGenericAgent.setTruck(truck);
	self.myMobileGenericAgent.setMyInterTerminal(term);
	self.myMobileGenericAgent.setInterTerminal(true);
	self.myMobileGenericAgent.setDriver(driver);
	self.gotoForm( MOB_HHITSTruckUnloaderAllCargo, false );	
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doResizeControls" id="3331a9d9-445a-4c2f-ab84-de5f04c596cc">
        <updating/>
        <source>doResizeControls(_initialSetup: Boolean) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 February 2015	cnwndl1	Initial creation

*/


vars
	
	localTop : Real;
	localWidth : Real;
	localHeight : Real;
	tabIndex : Integer;

begin

	self.setResizeableMarginAndFontSize();
	localTop := self.resizedMargin;
	localWidth := self.clientWidth - self.resizedMargin - self.resizedMargin;
	localHeight := self.getStdControlHeight;
	tabIndex := 4000;
	
	if _initialSetup then
		self.cmbTerminal.setAndIncrementTabIndex( tabIndex );
		self.cmbTerminal.visible := true;
	endif;
	self.cmbTerminal.move(	self.resizedMargin,
							localTop,
							localWidth,
							localHeight );
	
	localTop := localTop + self.cmbTerminal.height + self.resizedMargin;
	if _initialSetup then
		self.tbxVehicle.setAndIncrementTabIndex( tabIndex );
		self.tbxVehicle.visible := true;
	endif;
	self.tbxVehicle.move(	self.resizedMargin,
							localTop,
							localWidth,
							localHeight );
							
	localTop := localTop + self.tbxVehicle.height + self.resizedMargin;
	if _initialSetup then
		self.txtState.setAndIncrementTabIndex( tabIndex );
		self.txtState.visible := self.myMobileGenericAgent.showState;
	endif;
	self.txtState.move(	self.resizedMargin,
							localTop,
							localWidth,
							localHeight );
							
	localTop := localTop + self.txtState.height + self.resizedMargin;
	if _initialSetup then
		self.tbxUser.setAndIncrementTabIndex( tabIndex );
		self.tbxUser.visible := true;
	endif;
	self.tbxUser.move(	self.resizedMargin,
						localTop,
						localWidth,
						localHeight );
						
	inheritMethod(_initialSetup);

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_initialSetup" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="findTruck" id="74ef0a51-ca1a-4687-927b-9f6ef8ecf1f9">
        <updating/>
        <source>findTruck( errMsg : String output ):CM_Vehicle updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 February 2010	conkc1	Initial creation

*/

vars

	truckString : String;
	term : CM_Terminal;
	truck : CM_Vehicle;
	state : String;
//	visitRecord : CM_VehicleVisitRecord;
	
begin

	term := self.cmbTerminal.listObject.CM_Terminal;
	if txtState.text.trimBlanks = null or txtState.text = lblState.caption.toUpper then
		state := null;
	else
		state := txtState.text.trimBlanks;
	endif;
	
	if term = null then
		errMsg := app.getErrorString(Select_Terminal);
		self.cmbTerminal.setFocus();
		return null;
	endif;
	
	truckString := tbxVehicle.text;
	if truckString.trimBlanks = null or truckString = lblVehicle.caption.toUpper then
		errMsg := app.getErrorString(Enter_truck);
		truck := null;
		
	else
		// identify the truck from the value entered.
		truck := term.vehicles[truckString.toUpper, state];
		
		if truck = null then
			// try value as a visit number.
			//17 Jun 2013	NDL	Par 31780
	/*		visitRecord := term.getVehicleVisitRecordByTran(truckString.toUpper);
			if visitRecord &lt;&gt; null then
				truck := visitRecord.vehicle;
				if truck = null then
					if state &lt;&gt; null then
						errMsg := app.getErrorString2( Err_Unknown_Truck_Rego_State, truckString, state );
					else
						errMsg := app.getErrorString2( ERR_Truck_Unknown, truckString, null );
					endif;
				endif;
			else */
				if state &lt;&gt; null then
					errMsg := app.getErrorString2( Err_Unknown_Truck_Rego_State, truckString, state );
				else
					errMsg := app.getErrorString2( ERR_Truck_Unknown, truckString, null );
				endif;
	//		endif;
		endif;
		
	endif;

	if truck &lt;&gt; null then
	//	self.isValidTruckForAction( truck, visitRecord, errMsg);
		self.isValidTruckForAction( truck, null, errMsg);
	endif;
	
	return truck;
	

epilog

end;</source>
        <Parameter name="errMsg" type="String" usage="output"/>
        <ReturnType type="CM_Vehicle"/>
    </JadeMethod>
