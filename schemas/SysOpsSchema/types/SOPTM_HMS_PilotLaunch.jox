    <JadeMethod name="setControlsForAddEdit" id="8c168740-9a1b-4894-b158-ffb9707b61a9">
        <updating/>
        <source>setControlsForAddEdit() updating;
//--------------------------------------------------------
//
// Created by: cnwsh3 
//
// Date: 22 July 2003
//
//----------------------------------------------------------

vars
	theForm : SOP_HMS_TableMaintForm;

begin
  
  	theForm := self.myForm.SOP_HMS_TableMaintForm;
	theForm.tblInput1.userInputEnabled := true;
			
	if theForm.mode = theForm.Mode_Add then
		theForm.tblInput1.clearValues;
		theForm.tblInput1.enableRowByName(ETRow_Code);
		theForm.tblInput1.enableRowByName(ETRow_Description);
		theForm.tblInput1.setFocus;
		theForm.tblInput1.moveFirst();
		theForm.tblData1.userInputEnabled := true;
		theForm.fldInput.initSheetBackColors();	
	else
		// refresh the data from the newly created proxy
		self.showThumbnail(theForm.myProxyObject.HMS_PilotLaunch);
		// cannot update code
		theForm.tblInput1.enableRowByName(ETRow_Code);
		theForm.tblInput1.enableRowByName(ETRow_Description);
		theForm.tblData1.userInputEnabled := true;
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="setTblData1Rows" id="01a85657-f665-4c84-b6f2-e62f34f0ae36">
        <source>setTblData1Rows(pObj: HMS_PilotLaunch);
// ---------------------------------------------------------------------------
// Created:     21 February 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars
	theForm 				: SOP_HMS_TableMaintForm;
	harbour					: HMS_Harbour;
	arrResource,
	depResource, 
	shiftResource			: HMS_Resource;
	resourceForPilotLaunch	: HMS_ResourceForPilotLaunch;
	tmpDataTable			: CM_DataTable;
	idx						: Integer;	
	pilotLaunch				: HMS_PilotLaunch;
begin
  
  	theForm := self.myForm.SOP_HMS_TableMaintForm;
		
	tmpDataTable := theForm.tblData1;
	tmpDataTable.userInputEnabled := false;
	
	theForm.allClonedControls.purge();
//	theForm.newIndex := 0;
	
	tmpDataTable.rows := 1;
	//now add the user terminal security roles	

	foreach harbour in app.myRoot.allHarbours do
		if pObj &lt;&gt; null then 
			
			if pObj.isTransient then  // if transient has all details set to null so table is blank when editing exsisting tug resources. 
			pilotLaunch := pObj.pxyGetRealObject();
			else
			pilotLaunch := pObj;
			endif;
			
			resourceForPilotLaunch := pilotLaunch.allResourcesForPilotLaunch[harbour,pilotLaunch];
			
			if resourceForPilotLaunch &lt;&gt; null then 
				arrResource := 	resourceForPilotLaunch.myArrivalResource;
				depResource := resourceForPilotLaunch.myDepartResource;
				shiftResource := resourceForPilotLaunch.myShiftResource;
			endif;
		else
			arrResource := 	null;
			depResource := null;
			shiftResource := null;
		endif;
		idx := tmpDataTable.addItemObject(harbour, harbour.code);
	
		tmpDataTable.accessCell(idx, 2).itemObject := arrResource;
		if arrResource &lt;&gt; null then
			tmpDataTable.accessedCell.text := arrResource.description;
		endif;
			
		tmpDataTable.accessCell(idx, 3).itemObject := depResource;
		if depResource &lt;&gt; null then
			tmpDataTable.accessedCell.text := depResource.description;
		endif;
			
		tmpDataTable.accessCell(idx, 4).itemObject := shiftResource;
		if shiftResource &lt;&gt; null then	
			tmpDataTable.accessedCell.text := shiftResource.description;
		endif;
		
		
		self.addResourceCombosToTblData1(idx, harbour,arrResource,depResource,shiftResource);
//		tmpDataTable.accessCell(idx, 2).cellControl := theForm.cmbResourceArr;
//		tmpDataTable.accessCell(idx, 3).cellControl := theForm.cmbResourceDep;
//		tmpDataTable.accessCell(idx, 4).cellControl := theForm.cmbResourceShift;
		
	endforeach;

end;</source>
        <Parameter name="pObj" type="HMS_PilotLaunch"/>
    </JadeMethod>
    <JadeMethod name="setupThumbnailDetails" id="f4bc58c9-12f6-42ba-8d5d-d8ca08a7e66e">
        <source>setupThumbnailDetails();
//--------------------------------------------------------
//
// Created by: cnwsh3 
//
// Date: 22 July 2003
//
//----------------------------------------------------------

vars
	defName	: String;
	theForm : SOP_TableMaintForm;
begin
  
  	theForm := self.myForm;
	theForm.useProxyObject := true;
	theForm.setTblDataEntRows(ETDef_HMSPilot);
	//12/01/2011 cnwdz2 25840
	//theForm.zClearSortColumns();
	//theForm.zAddSortColumn(ETRow_Code, false);

	theForm.shtTblInput1.caption := 'Details';
	
	defName := ETDef_HMSPilot;

	theForm.initTblInput(theForm.tblInput1, defName);
	theForm.shtTblInput1.visible := true;


end;</source>
    </JadeMethod>
    <JadeMethod name="showThumbnail" id="96d45619-9624-4320-abc0-bf0f4dbce9bf">
        <updating/>
        <source>showThumbnail(pObj: HMS_PilotLaunch) updating;
//--------------------------------------------------------------
//Created: 09 July 2003 By: cnwgd1
// 03-JUL-2014  cnwma1 CCMS SFW1328 -HMS Not Available For Entry 
//--------------------------------------------------------------
vars
	theForm : SOP_HMS_TableMaintForm;
begin
  
    theForm := self.myForm.SOP_HMS_TableMaintForm;
	theForm.tblInput1.clearValues;
	theForm.tblInput1.setValueByName(ETRow_Code, pObj.code);
	theForm.tblInput1.setValueByName(ETRow_Description,pObj.description);
	theForm.tblInput1.setValueByName(ETRow_IsNotAvailableForEntry,pObj.isNotAvailableForEntry); // cnwma1  30/6/2014   CCMS SFW 1328
	theForm.myAssistant.comboBoxHMSHarbour(theForm.cmbHarbour, pObj.myCurrentHarbour);
	theForm.cmbHarbour.lostFocus(theForm.cmbHarbour);	
//	theForm.myAssistant.comboBoxHMSResource(theForm.cmbResourceArr, pObj.myArrivalResource, null, pObj.myCurrentHarbour);
//	theForm.cmbResourceArr.lostFocus(theForm.cmbResourceArr);
//	theForm.myAssistant.comboBoxHMSResource(theForm.cmbResourceDep, pObj.myDepartResource, null, pObj.myCurrentHarbour);
//	theForm.cmbResourceDep.lostFocus(theForm.cmbResourceDep);
//	theForm.myAssistant.comboBoxHMSResource(theForm.cmbResourceShift, pObj.myShiftResource, null, pObj.myCurrentHarbour);
//	theForm.cmbResourceShift.lostFocus(theForm.cmbResourceShift);

	self.setTblData1Rows(pObj);
end;</source>
        <Parameter name="pObj" type="HMS_PilotLaunch"/>
    </JadeMethod>
</Class>
