    <JadeMethod name="showEventAlarm" id="fa03667a-a38f-4d86-8a1f-056a65d48b4e">
        <source>showEventAlarm();
/*
----------   ----------  --------------------------------------------------
Created:	18 July 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	frm			: CMUI_EventAlarm;
	remain,
	opt			: Integer;
	eventEnq		: CMUI_EventEnquiryForm;
begin
	eventEnq := app.getForm(CMUI_EventEnquiryForm.name).CMUI_EventEnquiryForm;
	if eventEnq &lt;&gt; null then
		return;//already displayed - create note will update
	endif;
	
	self.btnEventAlarm.visible := true;
	
	if self.getTimerStatus(self.TIMER_EVENTALARM, opt, remain) then//timer already going
		return;
	endif;
	
	self.beginTimer(1000, Timer_Continuous, self.TIMER_EVENTALARM);
	/*
	idx := app.formsCount;
	if app.formsCount &lt; 1 then
		return;
	app.writeStatement(class.name &amp; '::' &amp; method.name &amp; '-' &amp; app.forms(1).String);
	return;	
	frm := app.getForm(CMUI_EventAlarm.name).CMUI_EventAlarm;
	if frm = null then
		create frm transient;
		
	endif;
	
	frm.show();
	
	/*
	self.frmPic.parent := self;
	self.frmPic.visible := true;
	self.frmPic.zOrder(1);
	self.frmPic.top := 10;
	self.frmPic.left := self.width - self.frmPic.width;
	*/

end;


</source>
    </JadeMethod>
    <JadeMethod name="timerEvent" id="02679656-aa88-43e8-81c2-f77a30e15fb8">
        <updating/>
        <source>timerEvent(eventTag: Integer) updating;
/*
----------   ----------  --------------------------------------------------
Created:	18 July 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	pic		: CMUI_ToolbarPicture;
begin
	
	if eventTag = self.TIMER_EVENTALARM then
		if self.btnEventAlarm.myToolbarButton = null then
			return;
		endif;
		
		pic := self.btnEventAlarm.myToolbarButton.getMyPicture();
		if pic.picture = self.picEventOff.picture then
			pic.picture := self.picEventOn.picture;
		else
			pic.picture := self.picEventOff.picture;
		endif;
	endif;
	
end;


</source>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
