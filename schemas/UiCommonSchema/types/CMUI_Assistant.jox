        <source>showReturnCargoToYardForm(_voyage : CM_Voyage; _tiArray : CM_TIArray; _masterMenuAction : CMUI_MenuAction; _isRORO : Boolean) : Boolean;
//--------------------------------------------------
// Created:	08 May 2006 By: cnwgd1
//--------------------------------------------------
vars
	returnCargoForm : CMUI_ReturnCargoToYardForm;
begin

	if _tiArray = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Null collection');
		return null;
	elseif _voyage = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Null _voyage');
		return null;
	endif;
		
	returnCargoForm := app.loadForm(CMUI_ReturnCargoToYardForm, CMUI_Assistant, false, false, true, self.myTerminal, _masterMenuAction).CMUI_ReturnCargoToYardForm;
	if returnCargoForm = null then
		return false;
	endif;	
	
	_tiArray.copy(returnCargoForm.allTrackedItems);
	returnCargoForm.myVoyage := _voyage;
	returnCargoForm.isRORO := _isRORO; //PAR 29306 - cnwmc5
	returnCargoForm.showModal();

	return returnCargoForm.modalResult = IDOK;

end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
