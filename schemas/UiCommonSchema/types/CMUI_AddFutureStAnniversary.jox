    <JadeMethod name="setupForm" id="5b189541-cade-4f21-839a-838f07203305">
        <updating/>
        <source>setupForm() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 June 2023 navmv20 CR 58373 Task 58381: Jade - Future Storage Additional Days

*/

vars

begin
	inheritMethod();
	self.lblAddFreeDays.caption := app.getErrorString(Future_storage_additio_days);
	self.caption := app.getErrorString(Future_storage_additio_days)&amp;" "&amp; self.myTerminal.code;
	self.txtAddDays.text := null;
	self.txtAddDays.maxLength := 3;
	self.width := self.width + 50;
	self.txtReason.width := self.txtReason.width+50;
	self.txtAddDays.left += 50; //21/01/2025	navkc1 JIRA Bug MTN-33812
	self.txtDate.left += 50;	//21/01/2025	navkc1 JIRA Bug MTN-33812
	self.lblDate.caption := app.getErrorString(Future_storage_anniversar); //21/01/2025	navkc1 JIRA Bug MTN-33812
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="e8ff05f7-ee1f-417e-ad3c-60be247ee401">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 21 June 2023 14:43:49.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0026114, locale);
end;</source>
    </JadeMethod>
</GUIClass>
