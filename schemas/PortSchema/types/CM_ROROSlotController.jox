    <JadeMethod name="getFwdLC" id="3eadef3a-c68f-49f3-afeb-2116281e0457">
        <source>getFwdLC(): CM_ROROSlotController;
/*
Purpose:			
Date				Who			Reason
JANUARY 2012		CNWAB1		Initial creation
*/


vars
	fwdSlot : CM_ROROSlotDefn;
	fwdLocn : CM_ROROLocnDefn;
begin
	if self.mySlotDefn = null then
		return null;
	endif;

	if self.mySlotDefn.myROROLocnDen = null then
		return null;
	endif;
	
	if self.mySlotDefn.myROROLocnDen.myAdjacentSlotFwd = null then
		return null;
	endif;
	fwdLocn := self.mySlotDefn.myROROLocnDen.myAdjacentSlotFwd;
	
	fwdSlot := fwdLocn.allROROSlotDefnByOrdinal[fwdLocn.ordinal,self.mySlotDefn.ordinal];
	
	if fwdSlot = null then
		return null;
	endif;
	
	return fwdSlot.CM_ROROSlotDefnVoyage.mySlotController;

epilog

end;</source>
