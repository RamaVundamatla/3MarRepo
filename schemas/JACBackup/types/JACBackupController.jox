    <JadeMethod name="setNumSplits" id="098bd970-dcba-4a11-9973-0c1d576edfcf">
        <updating/>
        <source>setNumSplits(_value: Integer) updating;
// ---------------------------------------------------------------------------
// Created:     
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	if self.numSplits &lt;&gt; _value then 
		self.numSplits := _value;
	endif;
end;</source>
        <Parameter name="_value" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="startBackup" id="7b11cf75-352c-4fb4-b1a1-8fe7b8a4f781">
        <updating/>
        <source>startBackup() updating;
// ---------------------------------------------------------------------------
// Created:     
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//// 19 May 2016	cnwns1	TFS 488 - Multi Timezone Support
// ---------------------------------------------------------------------------

vars
	allFiles: DbFileArray;
	dbf: DbFile;
	obj: Object;
	i, inc: Integer;
	sbsd: JACBackupSortFilesDict;
	sbs: JACBackupSortFiles;
	si: JACBackupSplitInfo;
	splitArray: ObjectArray;
	allRunning: Boolean;
	pro: Process;
	result: Boolean;
begin
	on Exception do backupException(exception);

	beginTransientTransaction;
	self.startTS := app.actualTimeServer;// 19 May 2016	cnwns1	TFS 488 - Multi Timezone Support

	// Create the objects that we use for the backup 
	create allFiles transient;
	create sbsd transient;

	// Create all the split objects
	i := 1;
	while i &lt;= self.numSplits do
		create si sharedTransient;
		si.setMyController(self);
		si.setMyNum(i);
		// Check the path is still OK.
		if app.isSDSSecondaryBackup then
			result := si.setMyPath(self.mySchedule.splitSecPaths[i]);
		else
			result := si.setMyPath(self.mySchedule.splitPaths[i]);
		endif;
		if (not result) then
			app.writeLog(class.name&amp;'::'&amp;method.name&amp;' '&amp;"Backup failed.", LogDebug);
			self.mySchedule.setStatusNotify(JACBackupFailed);
			self.mySchedule.setFinalMessageNotify("Backup failed");
			self.mySchedule.backupFinishedNotify;
			delete self;
			commitTransientTransaction;
			terminate;
		endif;
		i := i+1;
	endwhile;

	// Find what files we are going to backup
	app.myDBA.getAllDbFiles(allFiles);
	foreach dbf in allFiles do
		if dbf.excludeFromBackup or 
		   (self.excludeSys and 
		    dbf.kind = DbFile.Kind_System) or 
		   dbf.getFileLength = 0 then
			app.writeLog(class.name&amp;'::'&amp;method.name&amp;" Will exclude "&amp;dbf.name.String&amp;" of "&amp;dbf.excludeFromBackup.String, LogDebug);
			continue;
		endif;
		self.numMegs := self.numMegs + (dbf.getFileLength / 1000000).Integer;
		self.numFiles := self.numFiles + 1;
		app.writeLog(class.name &amp; '::' &amp; method.name &amp; " Will backup " &amp; dbf.name.String &amp; " of " &amp; numMegs.String, LogDebug);
		create sbs transient;
		sbs.setSize(dbf.getFileLength);
		sbs.setObj(dbf);
		sbsd.add(sbs);
	endforeach;
	commitTransientTransaction;

	beginNotification(self, NotifySplitStatusChange, Response_Continuous, null);
	beginNotification(self, NotifyDbFileBackedUp, Response_Continuous, null);
	beginNotification(self, NotifyTerminate, Response_Continuous, null);

	// Setup the array for adding the files into so we can spread them around
	create splitArray transient;
	foreach obj in self.allSplits do 
		splitArray.add(obj);
	endforeach;

	// Now go through the sorted files and add them to the splits.
	i := 1;
	inc := 1;
	beginTransientTransaction;
	foreach sbs in sbsd reversed do
		// Add this file to the current split
		splitArray[i].JACBackupSplitInfo.myFileList.add(sbs.obj.DbFile);
		app.writeLog(class.name &amp; '::' &amp; method.name &amp; " Adding " &amp; sbs.obj.DbFile.name &amp; " to split " &amp; i.String, LogDebug);
		// Modify the pointer and increment (if appropriate)
		i := i+inc;
		if i &gt; self.numSplits then
			i := self.numSplits;
			inc := -1;
		elseif i &lt;= 0 then
			i := 1;
			inc := 1;
		endif;
	endforeach;

	// Clean up
	sbsd.purge;
	delete sbsd;
	sbsd := null;
	sbs := null;
	commitTransientTransaction;

	// Start the split apps to do the backups
	foreach obj in self.allSplits do
		app.startApplicationWithParameter(currentSchema.name, JACBackupSplitAppName, obj.JACBackupSplitInfo);
	endforeach;
epilog
	if sbs &lt;&gt; null then
		delete sbs;
	endif;
	if sbsd &lt;&gt; null then
		delete sbsd;
	endif;
	delete allFiles;
	delete splitArray;		// PAR #27874
	
end;</source>
    </JadeMethod>
    <JadeMethod name="userNotification" id="f740e962-6389-4064-9b8f-e484cf0fdffa">
        <updating/>
        <source>userNotification(_eventType: Integer; _theObject: Object; _eventTag: Integer; _userInfo: Any) updating;
// ---------------------------------------------------------------------------
// Created:     
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	fileLength	: Decimal[19];

begin

	on Exception do backupException(exception);
	app.writeLog(class.name&amp;'::'&amp;method.name&amp;' eventType ='&amp;_eventType.String&amp;' userInfo ='&amp;_userInfo.String, LogDebug);

	if _eventType = NotifyDbFileBackedUp then
		self.handleFileBackedUp(_userInfo.DbFile);
	elseif _eventType = NotifySplitStatusChange then
		app.writeLog(class.name&amp;'::'&amp;method.name&amp;'  SplitStatusChange for '&amp;_userInfo.String, LogDebug);
		self.handleSplitStatusChange(_userInfo.JACBackupSplitInfo);
	elseif _eventType = JadeDatabaseAdmin.FileBackupCompleteEvent then
		on Exception do self.handle3036Exception(exception);
		fileLength := _userInfo.DbFile.getFileLength;
		app.writeLog(class.name&amp;'::'&amp;method.name&amp;"File backup completed for "&amp;_userInfo.DbFile.name&amp;", size="&amp;fileLength.String, LogAlways);
	elseif _eventType = NotifyTerminate then
		app.writeLog(class.name&amp;'::'&amp;method.name&amp;'  NotifyTerminate.'&amp;_userInfo.String, LogDebug);
		terminate;
	else
		app.logUnhandledNotification(class.name, method.name, _eventType, _eventTag, _userInfo);
	endif;
end;</source>
        <Parameter name="_eventType" type="Integer"/>
        <Parameter name="_theObject" type="Object"/>
        <Parameter name="_eventTag" type="Integer"/>
        <Parameter name="_userInfo" type="Any"/>
    </JadeMethod>
    <JadeMethod name="wrapup" id="e2cbf2dc-200c-4885-b69d-3bcdc86ef8bb">
        <updating/>
        <source>wrapup() updating;
// ---------------------------------------------------------------------------
// Created:     
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// Mar 2010    cnwrs1       par 23288 to replace the code from delete as the whole thing crashed if delete got an exception as self was not deleted and the app not terminated
// ---------------------------------------------------------------------------

vars
	canDeleteSchedule, complete: Boolean;
	spl: JACBackupSplitInfo;
	currLog, message, backupPath: String;
	ts: TimeStamp;
	file: File;	
	kc : CnKarmaCntrl;
begin
//	on Exception do deleteExceptionHandler(exception);
//write class.name&amp;'::'&amp;method.name&amp;' ';
	beginTransientTransaction;
	kc := app.myCnKarmaCntrl;
	complete := true;
	app.writeLog(class.name&amp;'::'&amp;method.name&amp;' Attempting to delete '&amp;self.String, LogDebug);
	if self.mySchedule.status = JACBackupAborted then
		complete := false;
	endif;

	endNotificationForSubscriber(self);

	// Make sure all splits are complete
	foreach spl in self.allSplits do
		if not spl.status = SplitComplete then
			app.writeLog(class.name&amp;'::'&amp;method.name&amp;' '&amp;"Split not complete.", LogDebug);
			complete := false;
			break;
		endif;
	endforeach;

	// check if the binary backup should be done
	if app.isSDSSecondaryBackup then
		backupPath := app.myServerAppObject.binarySecBackupPath;
	else
		backupPath := app.myServerAppObject.binaryBackupPath;
	endif;
	app.writeLog(class.name&amp;'::'&amp;method.name&amp;' '&amp;"Backup binary to "&amp;backupPath&amp;'.', LogDebug);
	if backupPath &lt;&gt; null then
		if not app.myServerAppObject.copyFolder(app.getJadeInstallDir, backupPath) then
			complete := false;
			return;
		endif;
		create file transient;
		file.fileName := app.getIniFileName;
		app.writeLog(class.name&amp;'::'&amp;method.name&amp;' '&amp;" Copy "&amp;file.fileName&amp;' to '&amp;backupPath&amp;'\..\', LogDebug);
//		file.cnEcCopy(backupPath&amp;'\..\jmtjade.ini');
		kc.copyFile(file.fileName, backupPath&amp;'\..\jmtjade.ini', false); //cnwrs1 par 20382 july 2009
		delete file;
	endif;	
	// Finish the backup off if we were split
	if app.myDBA &lt;&gt; null and 
	   global.isValidObject(app.myDBA) and 
	   self.dbInBackupMode then
		if complete then
			app.writeLog(class.name &amp; '::' &amp; method.name &amp; ' Attempting to delete ' &amp; self.String &amp; ' - committing backup', LogDebug);
			app.myDBA.commitBackup;	
			currLog := app.myDBA.getCurrentLogName();
			if not app.isSDSSecondaryBackup then //Jade 6.1.12 causes exception
				app.writeLog(class.name &amp; '::' &amp; method.name &amp; ' Attempting to close current log (' &amp; currLog &amp; ')', LogDebug);
				app.myDBA.closeCurrentJournal();
			endif;
			if app.myServerAppObject.binaryBackupPath &lt;&gt; null then
				if not app.myServerAppObject.copyFolder(app.getJadeInstallDir, app.myServerAppObject.binaryBackupPath) then
					complete := false;
					return;
				endif;
				create file transient;
				file.fileName := app.getIniFileName;
//				file.cnEcCopy(app.myServerAppObject.binaryBackupPath);
				kc.copyFile(file.fileName, app.myServerAppObject.binaryBackupPath, false); //cnwrs1 par 20382 july 2009
				delete file;
			endif;	
		endif;
	endif;
	if app.isSDSSecondaryBackup then
		// if running on secondary db cleanup its journal directory
		app.myServerAppObject.secLogFileCleanup;
	endif;
	commitTransientTransaction;	
epilog
//write class.name&amp;'::'&amp;method.name&amp;' epilog vomplete='&amp;complete.String&amp;' failed='&amp;self.failed.String;
	if complete and
	   not self.failed then
		app.writeLog(class.name &amp; '::' &amp; method.name &amp; ' Attempting to delete ' &amp; self.String &amp; ' OK.', LogDebug);
	else
		app.writeLog(class.name &amp; '::' &amp; method.name &amp; ' Attempting to delete ' &amp; self.String &amp; ' failed - aborting backup', LogAlways);
		app.myDBA.abortBackup;	
	endif;
	// Update the schedule object with the status and do any recur
	if self.mySchedule &lt;&gt; null and 
	   global.isValidObject(self.mySchedule) then

		// This code is deliberately done in small transaction chunks and in
		// seperate methods so that if any one method causes an exception then
		// the exception handler can return "Ex_Resume_Next" to try and 
		// complete the task.

		if (not complete) or 
		   self.failed then
			app.writeLog(class.name &amp; '::' &amp; method.name &amp; ' Attempting to delete ' &amp; self.String &amp; ' - setStatus failed complete', LogDebug);
			message := self.finalMessage &amp; CrLf &amp; "Failed at " &amp; ts.String;
			if self.mySchedule.status &lt;&gt; JACBackupAborted then
				self.mySchedule.setStatusNotify(JACBackupFailed);
			endif;
		else
			message := self.finalMessage &amp; CrLf &amp; "Completed at " &amp; ts.String;
			self.mySchedule.setStatusNotify(JACBackupComplete);
			app.writeLog(class.name &amp; '::' &amp; method.name &amp; ' Attempting to delete ' &amp; self.String &amp; ' - setStatus ok complete', LogDebug);
		endif;

		self.mySchedule.setFinalMessageNotify(message);
		self.mySchedule.backupFinishedNotify;
	endif;
	beginTransientTransaction;
	delete self;
	commitTransientTransaction;	
	terminate;
end;</source>
    </JadeMethod>
</Class>
