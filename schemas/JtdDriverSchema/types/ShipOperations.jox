    <JadeMethod name="findNextJob" id="21bf8d33-3811-4eb0-aaa4-36fcc80d2bf0">
        <source>findNextJob(myShipMate:JmtShipMate io; voyageCode,craneId:String):Object;

vars
	btnResetSelector,btnShowSelector:Button;
	lstJobs:ListBox;
	lblJobTable:Label;
	priorIndex,priorItemLevel:Integer;
	voyage:CM_Voyage;
	cmbVoyage:ComboBox;
begin
	if myShipMate = null then  // load a new ops form
		create myShipMate;
		myCMUI_Navigator.lstTest.listIndex:=app.atcgGetListHierarchicalIndex(myCMUI_Navigator.lstTest, 'Port Otago|Voyage Functions|Operations|Job Operations|', 0);
		myCMUI_Navigator.lstTest.itemSelected[myCMUI_Navigator.lstTest.listIndex]:=true;
		myCMUI_Navigator.lstTest.dblClick(myCMUI_Navigator.lstTest);
		if pauseAndStop(shortPause) then return myShipMate; endif;  // "safe" way to add a delay
		
		myShipMate.myForm:=app.getForm('SHP_VoyageOperationsForm').Form;
		app.logMessage(method.qualifiedName&amp;" opened form "&amp;myShipMate.myForm.String&amp;" "&amp;myShipMate.myForm.caption);
		
		// Added for JMT 8.2.1
		voyage := CM_Terminal.firstInstance().lookupVoyage(voyageCode, null, false);
		cmbVoyage:=myShipMate.myForm.getPropertyValue('cmbVoyage').ComboBox;
		cmbVoyage.listIndex:=app.atcgGetComboStringIndex(cmbVoyage, 1, voyageCode&amp;' '&amp;voyage.vesselName, 0);
		cmbVoyage.click(cmbVoyage);
		if pauseAndStop(shortPause) then return myShipMate; endif;
		
		lstJobs:=myShipMate.myForm.getPropertyValue('lstJobs').ListBox;
		lstJobs.listIndex:=app.atcgGetListHierarchicalIndex(lstJobs, 'Voyage Operations|'&amp;voyageCode&amp;'|', 0);
		lstJobs.topIndex:=(lstJobs.listIndex-2).max(2);  // scroll to keep it visible
		lstJobs.pictureClick(lstJobs, lstJobs.listIndex, ListBox.PictureClick_PlusMinus);
		lstJobs.listIndex:=app.atcgGetListHierarchicalIndex(lstJobs, 'Voyage Operations|'&amp;voyageCode&amp;'|'&amp;craneId&amp;'|', 0);
		lstJobs.pictureClick(lstJobs, lstJobs.listIndex, ListBox.PictureClick_PlusMinus);
		priorIndex:=app.atcgGetListHierarchicalIndex(lstJobs, 'Voyage Operations|'&amp;voyageCode&amp;'|'&amp;craneId&amp;'|', 0);
		myShipMate.voyageCode:=voyageCode;
		myShipMate.craneId:=craneId;
	
	else  // take the next job on the existing form
		lstJobs:=myShipMate.myForm.getPropertyValue('lstJobs').ListBox;
		//priorIndex:=lstJobs.listIndex;
		priorIndex:=app.atcgGetListHierarchicalIndex(lstJobs, 'Voyage Operations|'&amp;myShipMate.voyageCode&amp;'|'&amp;myShipMate.craneId&amp;'|'&amp;myShipMate.jobNumber&amp;'|', 0);
		priorItemLevel:=lstJobs.itemLevel[priorIndex];
	endif;
	btnResetSelector:=myShipMate.myForm.getPropertyValue("btnResetSelector").Button;
	btnShowSelector:=myShipMate.myForm.getPropertyValue('btnShowSelector').Button;

	while true do  // find the next unactioned job for this crane
		btnResetSelector.click(btnResetSelector);
		if pauseAndStop(shortPause) then return myShipMate; endif;  // "safe" way to add a delay
		
		lstJobs.listIndex:=priorIndex + 1;
		assert(lstJobs.itemLevel[lstJobs.listIndex] = priorItemLevel or priorItemLevel = 0, self);  // detect end of list of jobs for this crane
		lstJobs.topIndex:=(lstJobs.listIndex-2).max(2);  // scroll to keep it visible
		lstJobs.itemSelected[lstJobs.listIndex]:=true;
		lstJobs.mouseDown(lstJobs, Window.MouseButton_Left, 0, 0, 0);  // this does the select in JMT code
		//write lstJobs.itemText[lstJobs.listIndex];
		lstJobs.dblClick(lstJobs);
		if pauseAndStop(shortPause) then return myShipMate; endif;  // "safe" way to add a delay
		
		lblJobTable:=myShipMate.myForm.getPropertyValue('lblJobTable').Label.getControl(2);
		if lblJobTable.caption.atcgContains('Job Part Complete') then  // finish it off first (any remaining moves must already be queued)
			app.logMessage(method.qualifiedName&amp;" working "&amp;lblJobTable.caption);
			break;
		
		elseif lblJobTable.caption.atcgContains('Job Unactioned') then  // don't want to try to action jobs that are completed or part completed
			app.logMessage(method.qualifiedName&amp;" working "&amp;lblJobTable.caption);
			queueIt(myShipMate.myForm);
			break;
		endif;
		app.logMessage(method.qualifiedName&amp;" skipping "&amp;lblJobTable.caption);
		priorIndex:=lstJobs.listIndex;
		btnShowSelector.click(btnShowSelector);
		if pauseAndStop(shortPause) then return myShipMate; endif;  // "safe" way to add a delay
	endwhile;
	myShipMate.jobNumber:=lstJobs.itemText[lstJobs.listIndex];
	//write myShipMate.display;
	return myShipMate;
end;
</source>
        <Parameter name="myShipMate" type="JmtShipMate" usage="io"/>
        <Parameter name="voyageCode" type="String"/>
        <Parameter name="craneId" type="String"/>
        <ReturnType type="Object"/>
    </JadeMethod>
    <JadeMethod name="handleShowModal" id="78ac9877-0000-4a95-adfe-1fc3d022046e">
        <updating/>
        <source>handleShowModal():Integer updating;

begin
	myCMUI_ErrorWarningDialog:=app.getForm('CMUI_ErrorWarningDialog').CMUI_ErrorWarningDialog;
	myCMUI_ErrorWarningDialog.show;
	myCMUI_ErrorWarningDialog.activate;
	if pauseAndStop(shortPause) then return 0; endif;  // "safe" way to add a delay
	
	myCMUI_ErrorWarningDialog.btnOk.click(myCMUI_ErrorWarningDialog.btnOk);  // should be only warnings
	if pauseAndStop(shortPause) then return 0; endif;  // "safe" way to add a delay

	if app.isValidObject(myCMUI_ErrorWarningDialog) then
		myCMUI_ErrorWarningDialog.unloadForm;
	endif;
	myCMUI_ErrorWarningDialog:=null;
	return 0;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="queueIt" id="5ddd09e4-b0ce-4dbb-8377-71cff053dcf6">
        <source>queueIt(myOpsForm:Form);

vars
	tblWorkEntries:Table;
	mnuQueueAll:MenuItem;
begin
	app.logMessage(method.qualifiedName);
	tblWorkEntries:=myOpsForm.getPropertyValue('tblWorkEntries').Table.getControl(2);
	tblWorkEntries.row:=2;
	tblWorkEntries.column:=3;
	tblWorkEntries.clearAllSelected;
	tblWorkEntries.accessCell(2,3).selected:=true;
	tblWorkEntries.rowColumnChg(tblWorkEntries);
	if pauseAndStop(shortPause) then return; endif;  // "safe" way to add a delay

	tblWorkEntries.click(tblWorkEntries);
	if pauseAndStop(shortPause) then return; endif;  // "safe" way to add a delay

	mnuQueueAll:=myOpsForm.getPropertyValue('mnuQueueAll').MenuItem;
	myOpsForm.sendMsgWithParams('mnuQueueAll_click', mnuQueueAll);
end;
</source>
        <Parameter name="myOpsForm" type="Form"/>
    </JadeMethod>
    <JadeMethod name="so001_SVOF_checkCompletedJobs" id="014a65c2-2924-4447-86c8-7cdecaba4ad5">
        <source>so001_SVOF_checkCompletedJobs():Integer;

vars
	o:Object;
	myShipMate:JmtShipMate;
	myForm:Form;
	lblJobTable:Label;
	tblWorkEntries:Table;
	row:Integer;
	mnuRefreshTable:MenuItem;
begin
	foreach o in allShipMates do :outerloop
		myShipMate:=o.JmtShipMate;
		lblJobTable:=myShipMate.myForm.getPropertyValue('lblJobTable').Label.getControl(2);
		if lblJobTable.caption.atcgContains('Job Complete') then
			app.logMessage(method.qualifiedName&amp;" job completed "&amp;lblJobTable.caption);
			findNextJob(myShipMate, null, null);
		
		elseif lblJobTable.caption.atcgContains('Job Part Complete') then  // check if all done and header label unchanged
			tblWorkEntries:=myShipMate.myForm.getPropertyValue('tblWorkEntries').Table.getControl(2);
			foreach row in 2 to tblWorkEntries.rows reversed do
				if tblWorkEntries.getCellText(row, 1)[1] = "Q" then  // still something queued
					continue outerloop;
				endif;
			endforeach;
			app.logMessage(method.qualifiedName&amp;" nothing queued, refreshing table "&amp;lblJobTable.caption);
			mnuRefreshTable:=myShipMate.myForm.getPropertyValue('mnuRefreshTable').MenuItem;
			myShipMate.myForm.sendMsgWithParams('mnuRefreshTable_click', mnuRefreshTable);
			app.logMessage(method.qualifiedName&amp;" nothing queued, refreshed table "&amp;lblJobTable.caption);
		endif;
	endforeach;

	return 0;
end;
</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="startup" id="543d4a15-117a-4647-a002-b76b28d2d1de">
        <updating/>
        <source>startup() updating;

begin
	app.atcgRecordingVersion:='1.1.14.0';
	inheritMethod();
end;</source>
    </JadeMethod>
    <JadeMethod name="startup2" id="6cb2dcd0-1fd2-4dbf-b0c7-21eeb2790f9d">
        <updating/>
        <source>startup2() updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
13 Jul 2016	cnwkpd1	Added code to set Terminal timezone to UTC
02 May 2018 jlgmd1	Added code to make sure all users are available for entry

*/

vars
	sm:JmtShipMate;
	pxyM,machine:CM_Machine;
	voyage : CM_Voyage;
	departDT : TimeStamp;
	deviceID : Integer;
	rtDevice : CM_RTDeviceVehicleMount;
	terminal : CM_Terminal;
	user : CM_User;
	allUsers : CM_ObjectArray;
	obj : Object;
	
begin
	myCMUI_SuperAppForm2:=app.getForm('CMUI_SuperAppForm2').CMUI_SuperAppForm2;
	myCMUI_Navigator:=app.getForm('CMUI_Navigator').CMUI_Navigator;

	app.logMessage(method.qualifiedName&amp;" resetting RT Device IDs to a numeric value");
	deviceID := 100;
	foreach rtDevice in CM_RTDeviceVehicleMount.instances do
		if not rtDevice.id.isInteger() then
			deviceID := deviceID + 1;
			beginTransaction;
			rtDevice.setPropertyValue("id", deviceID.String);
			commitTransaction;
		endif;
	endforeach;
	app.logMessage(method.qualifiedName&amp;" done resetting RT Device IDs to a numeric value");
	
	app.logMessage(method.qualifiedName&amp;" resetting machine logons");
	foreach machine in CM_Machine.instances where machine.id[1:2] = "RT" or machine.id[1:2] = "IM" do
		pxyM := app.createUpdateProxy(machine).CM_Machine;
		app.myTrxUA.trxUpdateRTResetMediator(pxyM, app.myPassport);
		assert(app.myPassport.trxCompletedOK, self);
		delete pxyM;
	endforeach;
	app.logMessage(method.qualifiedName&amp;" done resetting machine logons");
	
	// Set timezone of Terminal to GMT
	app.logMessage(method.qualifiedName &amp; " setting Terminal Time Zone to UTC");
	terminal := CM_Terminal.firstInstance();
	beginTransaction;
	terminal.setTimeZoneID("UTC");
	commitTransaction;
	app.logMessage(method.qualifiedName &amp; " Terminal Time Zone set to UTC");
	
	departDT := app.actualTimeServer.addDays(7);
	voyage := terminal.lookupVoyage('JBL500N', null, false);
	app.logMessage(method.qualifiedName&amp;" setting departure date for voyage " &amp; voyage.String &amp; " to " &amp; departDT.String);
	beginTransaction;
	voyage.setDepartureDT(departDT);
	commitTransaction;
	app.logMessage(method.qualifiedName&amp;" departure date for voyage " &amp; voyage.String &amp; " set to " &amp; departDT.String);
	
	app.logMessage(method.qualifiedName &amp; " enabling all users");
	create allUsers transient;
	CM_User.allInstances(allUsers, 0, true);
	beginTransaction;
	foreach obj in allUsers do
		user := obj.CM_User;
		user.setPropertyValue("isNotAvailableForEntry", false);
	endforeach;
	commitTransaction;
	app.logMessage(method.qualifiedName &amp; " Finished enabling all users");
	
	/*allShipMates.add(findNextJob(sm, 'JBL100N', 'C1')); sm:=null;
	allShipMates.add(findNextJob(sm, 'JBL100N', 'C2')); sm:=null;
	allShipMates.add(findNextJob(sm, 'JBL200N', 'C3')); sm:=null;
	allShipMates.add(findNextJob(sm, 'JBL200N', 'C4')); sm:=null;/**/
	//allShipMates.add(findNextJob(sm, 'JBL300N', 'C5')); sm:=null;
	//allShipMates.add(findNextJob(sm, 'JBL300N', 'C6')); sm:=null;
	//allShipMates.add(findNextJob(sm, 'JBL400N', 'C7')); sm:=null;
	//allShipMates.add(findNextJob(sm, 'JBL400N', 'C8')); sm:=null;
	allShipMates.add(findNextJob(sm, 'JBL500N', 'C5')); sm:=null;
	allShipMates.add(findNextJob(sm, 'JBL500N', 'C6')); sm:=null;
	allShipMates.add(findNextJob(sm, 'JBL500N', 'C7')); sm:=null;
	allShipMates.add(findNextJob(sm, 'JBL500N', 'C8')); sm:=null;
	allShipMates.add(findNextJob(sm, 'JBL500N', 'C9')); sm:=null;
epilog
	delete pxyM;
end;
</source>
    </JadeMethod>
