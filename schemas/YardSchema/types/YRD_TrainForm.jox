        <updating/>
        <source>tblWagons_mouseMove(table: Table input; button: Integer; shift: Integer; x: Real; y: Real) updating;
// ---------------------------------------------------------------------------
// Created:     11 March 2010 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	if button &lt;&gt; 1 or (not app.dragDetected(x, y, self.origXPos, self.origYPos)) then
		return;
	endif;

	self.dragWagon();
epilog

end;</source>
