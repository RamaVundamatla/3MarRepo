    <JadeMethod name="utlCreateCamTaskHistory" id="5d6828d2-25a6-4fcd-bb33-e369a0849754">
        <source>utlCreateCamTaskHistory(_proxy :CM_CamTaskHistory input; _real :CM_CamTaskHistory io; _camProtocol :CM_CamProtocol; _camAgent : CM_CamControllerAgent input; _passport : CM_Passport input);
//
// 17 May 2012	cnwrs1		Par 26914 - make cam task transient and remove camprotocol::camTask
// 26/06/0212	cnwcs5		par 29601 - change usage of _camTask 
//18 Jul 2012	cnwrs1	CCMS 1269 CAMS remove CM_CamTask
vars
	new: CM_CamTaskHistory;
begin

	self.initialiseActivity();
	
	app.setContinueCMExceptions(true);

	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	app.setContinueCMExceptions(false);
	
	_real	:= _camProtocol.taskHistoryByProtocolSeq[_camProtocol, _proxy.seqNumber]; // deal with first transaction where task history already exists
	if _real = null then
		create new persistent;
		new.setForCreate(_proxy, _camProtocol, _passport);
		_real := new;
	endif;
	//epr TFS 2192/2142 could not be unique would cause multiple emails sent
	if not _camAgent.allProcessSeqNumbers.includes(_real.seqNumber) then
		_camAgent.allProcessSeqNumbers.add(_real.seqNumber);
	endif;
	_real.setStatus(CAM_EXTRACTSTATUS);
end;</source>
        <Parameter name="_proxy" type="CM_CamTaskHistory" usage="input"/>
        <Parameter name="_real" type="CM_CamTaskHistory" usage="io"/>
        <Parameter name="_camProtocol" type="CM_CamProtocol"/>
        <Parameter name="_camAgent" type="CM_CamControllerAgent" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
