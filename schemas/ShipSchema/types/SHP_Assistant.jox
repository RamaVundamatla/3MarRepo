        <source>showVoyageLoadListForm(_voyage : CM_Voyage; _tis : CM_ObjectArray input; _menuAction : CMUI_MenuAction );
// ---------------------------------------------------------------------------
// Created:		November 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	oowForm : SHP_LoadList;
	menuAction : CMUI_MenuAction;
begin
	if _voyage = null then
