// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

end;</source>
    </JadeMethod>
    <JadeMethod name="setVolumeFromHLW" id="3d04100b-7f01-4414-9874-1e86c6c54a0d">
        <source>setVolumeFromHLW( table : CM_EntryTable input);
//-----------------------------------------------------------------------
//	Created:	30 May 2006 Lorcan Bolster  (cnwlb1/lorcan)
//-----------------------------------------------------------------------
vars
	length,	width,	height	: Integer;
	product : CM_Product;
begin
	if self.mode = self.Mode_View then
		return;
	endif;
	
	length			:= table.getValueByNameIfVisible(ETRow_MyLength).Integer;
	width			:= table.getValueByNameIfVisible(ETRow_MyWidth).Integer;
	height			:= table.getValueByNameIfVisible(ETRow_MyHeight).Integer;

	//don't bother doing calculation if fields are empty;
	//or values are 0 (can't work out volume)
	if length = 0 or width = 0 or height = 0 then
		return;
	endif;	
	
	product := self.cmbProduct.listObject.CM_Product;
	
	if product = null then
		return;  //return, couldnt find product code from table
	endif;
	
	table.setValueByName ( ETRow_MyVolume, product.calculateVolume(length,width,height));	
end;</source>
        <Parameter name="table" type="CM_EntryTable" usage="input"/>
    </JadeMethod>
