Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 April 2012	cnwer1	Initial creation CCMS MES 1035

*/

vars

begin
	return false;
epilog

end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
