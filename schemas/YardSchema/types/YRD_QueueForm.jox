    </JadeMethod>
    <JadeMethod name="showMachinesForQueue" id="009ba765-38a3-435b-bcc7-3c8de77af1fc">
        <source>showMachinesForQueue(pQueue : CM_RadioTelemetryQueue; _refreshViewedMachines : Boolean);
// ---------------------------------------------------------------------------
// Created:     15 October 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 20 May 2009	cnwkpd1		PAR #18769 - Remove isValidObject for performance
// 11 Jun 2009	cnwkpd1		PAR #19844 - Handle possible null myPrimaryQueue
// 4 Nov 2010	cnwjo3		PAR #25669 - Corrected issue where highlighting machine in wrong queue
// 10 Mar 2011	cnwkpd1		PAR #26919 (version 2) - reworked code to prevent 1090 on tasks
// ---------------------------------------------------------------------------

vars
	invalidMachine,
	invalidQ				: Boolean;
	machine					: CM_Machine;
begin
	if pQueue = null then
		return;
	endif;
	
	on Exception do app.handleDeletedObject(exception, pQueue, invalidQ);
	
	if _refreshViewedMachines then
		self.allViewedMachines.clear();	
		// epr par 17426 3/7/08
		if pQueue = self.myMasterQueue then
			pQueue.CM_MasterQueue.getMasterMachines(allViewedMachines,false);
		else
			//pQueue.getAllMachines(allViewedMachines, false, false,false);
			pQueue.getPrimaryMachines(allViewedMachines, false, false);
		endif;
	endif;
	
	if invalidQ then
		return;
	endif;
	
	on Exception do app.handleDeletedObject(exception, machine, invalidMachine);	// PAR #26919

	tblMachines.rows := 0;
	tblMachines.columns := 2;
	tblMachines.accessColumn(2).visible := false;

	self.tblMachines.selectMode:=Table.SelectMode_Multiple;
	
	
	foreach machine in allViewedMachines do
		// Par NFS 14861
		if machine.isCrane() and not machine.hasRadioTelemetry then
			continue;
		endif;
		//17/08/2011 cnwdz2 27747	
		self.displayMachineInTable(machine, pQueue);
	endforeach;
	
	//17/08/2011 cnwdz2 27747 start
	if pQueue &lt;&gt; self.myMasterQueue then
		//If "show inherited" then display machiens for inherited queues
		if self.isShowInherited then
			self.displayMachinesForInheritedQ(pQueue);
		endif;
		
		//Machines that are currently queued into the selected queue
		self.displayQueuedMachinesForQueue(pQueue);
			
		//Machiens that have the selected queue as one of their defined secondary queues	
		self.displayMachinesForSecondaryQ(pQueue);
	endif;
	//17/08/2011 cnwdz2 27747 end
epilog
	
end;</source>
        <Parameter name="pQueue" type="CM_RadioTelemetryQueue"/>
        <Parameter name="_refreshViewedMachines" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="showQueueDetails" id="7c375b94-3363-40f5-bc91-0b7b6e3e9e60">
        <updating/>
        <source>showQueueDetails(pQueue : CM_RadioTelemetryQueue) updating;
// ---------------------------------------------------------------------------
// Created:     04 October 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
/*

Date		Who		Reason
06 Nov 2008	cnwkpd1	PAR #18009 - Tidy up transients
08 Mar 2011	cnwkpd1	PAR #27163 - Workaround for JADE PAR #55831 - use modifed local exception handler
18 May 2011	cnwkpd1	PAR #27579 - Added new parameter _addAtEnd to showTasksForQueueEntry, for performance
24 Aug 2020 jlgmd1	TFS #49961 - PRP - Hide Sub Queue Tasks

*/

vars
	subQ	: CM_RadioTelemetryQueue;
	entry	: CM_RTQueueEntry;
	count	: Integer;
	iter	: Iterator;
	pQueueCopy : CM_RTQueueEntryArray;
	pQueueSubQCopy : CM_RTQueueArray;
	invalidQ,
	invalidEntry,
	invalidSubQ : Boolean;
	
begin
	// Update the navigator
	on Exception do app.handleDeletedObject(exception, pQueue, invalidQ);	// PAR #27163
	
	if self.myMasterMenuAction &lt;&gt; null then
		self.setNavigatorHeading(pQueue.id); 
	endif;
	
	if invalidQ then			// PAR #27163
		return;
	endif;
	
	/*
	Date		Who		Reason
	16 Sep 2008	cnwdz2	PAR17934 to make sure the collections are not updated while iterated through it.				
	*/
	on Exception do app.handleDeletedObject(exception, entry, invalidEntry);
	
	pQueueCopy := pQueue.allEntries.cloneSelf(true);
	iter := pQueueCopy.createIterator();
	while iter.next(entry) do
		count := count + 1;
		self.showTasksForQueueEntry(entry, count, true);		// PAR #27579
	endwhile;
	
	// Only show sub-queue tasks if we actually need to
	if self.chkHideSubQTasks.value = true then
		return;
	endif;
	
	delete iter;
	pQueueSubQCopy := pQueue.allSubQueuesByOrder.cloneSelf(true);
	iter := pQueueSubQCopy.createIterator();
	while iter.next(subQ) do
		self.showQueueDetails(subQ);
	endwhile;
	

epilog	
	delete iter;
	delete pQueueCopy;
	delete pQueueSubQCopy;
	
end;</source>
        <Parameter name="pQueue" type="CM_RadioTelemetryQueue"/>
    </JadeMethod>
    <JadeMethod name="showQueueThumbnail" id="fb6685ec-ea87-476c-8e13-b50a849251f1">
        <updating/>
        <source>showQueueThumbnail(pObj : Object) updating;
// ---------------------------------------------------------------------------
// Created:     11 October 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 18 May 2011	cnwkpd1	PAR #27579 - Added new parameter _addAtEnd to showTasksForQueueEntry, for performance
// 18/03/2022	navcs2	ChangeRequest 52945: MTN - RTQueue Refresh Issue
// ---------------------------------------------------------------------------
vars
	queueIdCol : Integer;
begin

	if pObj = null then
		return;
	endif;

   	app.mousePointer := MousePointer_HourGlass;
   	self.myCurrentEntry := null;
   	self.myCurrentTask := null;
	self.myFromListObject := pObj;				// 19/03/2022 navcs2 52945
	tblQEntries.rows := tblQEntries.fixedRows;
	
	queueIdCol:=self.tblQEntries.getColumnByRowName(ETRow_QueueId);
	if queueIdCol &gt; 0 then
		tblQEntries.accessColumn(queueIdCol).visible := pObj = self.myMasterQueue;	
	endif;
	
	if pObj.isKindOf(CM_RadioTelemetryQueue) then
		self.showQueueDetails(pObj.CM_RadioTelemetryQueue);
		self.showMachinesForQueue(pObj.CM_RadioTelemetryQueue, true);
	elseif pObj.isKindOf(CM_RTQueueEntry) then
		self.showTasksForQueueEntry(pObj.CM_RTQueueEntry, 1, true);
		self.showMachinesForQueue(pObj.CM_RTQueueEntry.myQueue, true);
	endif;

epilog
	app.mousePointer := MousePointer_Default;
end;</source>
        <Parameter name="pObj" type="Object"/>
    </JadeMethod>
    <JadeMethod name="showRefreshTask" id="ce9ebcc2-ed63-4148-ad56-eef02ca13fd7">
        <source>showRefreshTask(_rtEntry : CM_RTQueueEntry; _state : Integer; _refreshTwinEntries : Boolean) protected;
// -------------------------------------------
// Created 08 December 2003 by cnwdvb1
// -------------------------------------------
/*

Date		Who		Reason
27 May 2009	cnwkpd1	PAR #19780 - Prevent 1308 exceptions accessing prev/next entry
08 Sep 2009	cnwkpd1	PAR #20399 - 1090 exceptions following Resume after invalid RT Queue Entry
29 Jun 2010	cnwkpd1	PAR #23525 - Performance changes - no need to startAtObject twice
18 May 2011	cnwkpd1	PAR #27579 - Added new parameter _addAtEnd to showTasksForQueueEntry, for performance

*/

vars
	row,
	rows,
	fixed,
	queueIndexActual,
	queueIndexCompare,
	pos						: Integer;
	entryTblOid				: String;
	hasFoundEntry			: Boolean;
	cell					: JadeTableCell;
	queue					: CM_RadioTelemetryQueue;
	colPosEntryOid,
	colPosQueuePos,
	colPosEntryPos			: Integer;
	iter 					: Iterator;
	prevEntry,
	nextEntry    			: CM_RTQueueEntry;
	loadStateSet			: Boolean;
	invalidRTQ				: Boolean;
	str : String;
	
begin
	// PAR #20399 - Arm specific handler for delete Queue Entry
	on Exception do app.handleDeletedObject(exception, _rtEntry, invalidRTQ);
	
	// We are editing or deleting so we need to remove out of date row.
	if _state &lt;&gt; State_Delete then
		queue := _rtEntry.myQueue;
		queueIndexActual := self.getQueueIndex(queue);
	endif;

	// Get fixed rows.
	fixed	:= self.tblQEntries.fixedRows;
	// Get total rows.
	rows	:= self.tblQEntries.rows;
	
	colPosEntryOid:=self.tblQEntries.getColumnByRowName(ETRow_EntryOid);
	colPosQueuePos:=self.tblQEntries.getColumnByRowName(ETRow_QueuePos);
	colPosEntryPos:=self.tblQEntries.getColumnByRowName(ETRow_TaskPos);
	
	// Lets check each row.
	foreach row in rows to fixed + 1 step -1 do
		// Get hidden row text.
		cell := self.tblQEntries.accessCell(row,colPosEntryOid);
		if cell = null then
			break;
		endif;
		entryTblOid	:= cell.text;
		if entryTblOid = null then
			break;
		endif;
		
		// We have to find out where to add this sucker in because we could be displaying all
		// queues so have to slot it in the right spot.
		if _state = State_Add then
			if queueIndexActual = 0 then
				break;
			endif;
			queueIndexCompare := self.tblQEntries.accessCell(row,colPosQueuePos).text.Integer;
			if queueIndexCompare = queueIndexActual then
				pos := self.tblQEntries.accessCell(row,colPosEntryPos).text.Integer + 1;
				break;
			endif;
		else
			// Does the entry match this row.
			// We are replacing an existing row so we find all tasks with this oid and
			// remove them from the table remembering the first pos.
			if _rtEntry.String = entryTblOid then
				if not hasFoundEntry then
					pos := self.tblQEntries.accessCell(row,colPosEntryPos).text.Integer;
				endif;
				// Remove row.
				self.tblQEntries.removeItem(row);
				hasFoundEntry := true;
				
			// We haven't found matching row and we have found one before.
			// Entries are always in blocks so jump out.
			elseif hasFoundEntry then
				break;
			endif;			
		endif;
	endforeach;
	
	// We are adding or editing.
	if _state &lt;&gt; State_Delete then
//		on Exception do self.xInvalidObject(exception, true);		- removed PAR #20399
		// Add tasks for entry.
		if pos = 0 and (not _refreshTwinEntries) and _state = State_Edit then
			return;
		endif;
		if pos = 0 then 
			pos := 1;
		endif;
		
		str := _rtEntry.status.String;	// 28 Jan 2011	NDL	Par 26316
		self.showTasksForQueueEntry(_rtEntry, pos, false);		// PAR #27579
		
		if not invalidRTQ and pos &lt;&gt; 1 and _refreshTwinEntries then			// PAR #20399
			if  self.tblQEntries.getColumnByRowName(ETRow_TwinCarry) &gt; 0 then
			
				// PAR #19780 - We need to hold a share lock on the allEntries array
				// here to ensure no updates occur while we are getting the previous and next entries
				// a 1308 exception can occur.  Use beginLoad to accomplish this.
				app.cmsBeginLoad(loadStateSet);
				iter:=_rtEntry.myQueue.allEntries.createIterator;
				
				if not invalidRTQ then						// PAR #20399
					iter.startAtObject(_rtEntry);
					iter.back(prevEntry);		
					iter.back(prevEntry);
//					iter.startAtObject(_rtEntry);			// PAR #23525 
					iter.next(nextEntry);
					iter.next(nextEntry);
				endif;
				
				app.cmsEndLoad(loadStateSet);
				
				if prevEntry &lt;&gt; null then
					self.showRefreshTask(prevEntry,State_Edit,false);
				endif;
		
				if nextEntry &lt;&gt; null then
					self.showRefreshTask(nextEntry,State_Edit,false);
				endif;
				
			endif;
		endif;
		
	endif;
	
epilog
	app.cmsEndLoad(loadStateSet);		// PAR #19780
	// Resort the table so everything is in the right place.
//	self.tblQEntries.resort;	// 27 May 2010	NDL	Par 23756	Can't use this when adding individual
								// items in the middle of teh table, because teh existing keys of the
								// other items after the inserted item will potentailly be wrong
								
	delete iter;
	
	
end;</source>
        <access>protected</access>
        <Parameter name="_rtEntry" type="CM_RTQueueEntry"/>
        <Parameter name="_state" type="Integer"/>
        <Parameter name="_refreshTwinEntries" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="showTasksForQueueEntry" id="1575d295-5c01-4e54-91f7-eb51e46a424b">
        <source>showTasksForQueueEntry(pEntry : CM_RTQueueEntry; _index : Integer; _addAtEnd : Boolean);
/* ---------------------------------------------------------------------------
// Created:     04 October 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 25 Jan 2010	cnwkpd1		PAR #21593 - Handle exceptions refreshing task
//							found during ITS interface development
// 20 Apr 2010	cnwvu1		PAR 23829 - Cannot update array during iteration
//							The entryTasks array is used.
// 24 Jun 2010	cnwkpd1		PAR #24686 - Invalid object reference when adding a task 
// 							to the queue
// 15 Feb 2011  cnwer1		PAR 26643	- overstows not showing correct destination when not showing full details
// 18 Apr 2011	cnwkpd1		PAR #27408 - Queue entries being refreshed into an incorrect position when update
//							notification received
// 18 May 2011	cnwkpd1		PAR #27579 - Added new parameter _addAtEnd to be used when the table has been
//							explicitly cleared, and entries are only to be added at the end of the table, to 
//							improve the performance of the initial load of the form when there are a large number 
//							of entries
// 30 Oct 2012	cnwkpd1		PAR #30635 - Handle deleted nextTask
// 28 Jan 2020  cnwma1	    Bug 48272: PEN - 1090 when refreshing RT Queue
// 25 Jun 2025  navbs1		Story 35185: MTN - Refactor Required to Stop Using getDisplayStringForAttribute() for Known Attributes 
// 14 Jul 2025	navbs1		Bug MTN-35345: MTN - Avoid Running Twin Lift Flag Logic for Non Container Cargo Items
// ---------------------------------------------------------------------------*/

vars
	ti						: CM_TrackedItem;
	str						: String;
	task					: CM_RTQueueTask;
	idx,
	aColourBack,aColourFore,
	count,
	queueIndex				: Integer;
	lController 			: CM_LocationsController;
	twinStr					: String;
	colCount,
	pictureCol,
	flagCol,
	queueIdCol,
	containerCol,
	twinCol,
	twinOpts,
	machAssignedCol,
	overstowCol,
	sideAccessDirection		: Integer;
	entTableRow 			: EntTableRow;
	twinCell				: JadeTableCell;
	twinLiftDraw,
	twinLiftNextDraw,
	twinLiftPrevDraw 		: CM_DrawingAttribute;
	picWorkUnAssigned 		: Binary;
	invalidTask,
	invalidNextTask,
	overstowed,
	overstowedAtMove		: Boolean;
	entryTasks				: CM_RTQueueTaskArray;
	existRTQTask,
	nextTask 				: CM_RTQueueTask;
	insertIndex 			: Integer;
	startIndex 				: Integer;
	endIndex 				: Integer;
	index,
	taskPos	,
	entryStatus				: Integer;
	invalidEntry,
	existTaskInvalid 		: Boolean;
	nextQEntry				: CM_RTQueueEntry;
	entryListIndex,
	nextEntryListIndex		: Integer;
	listObj					: Object;
	value 					: String;
	root					: CM_Root;
begin
	root	   := app.myRoot;
	queueIndex := self.getQueueIndex(pEntry.myQueue);
	
	twinLiftDraw		:= root.allDrawingAttributes[PicTATwinLiftArrows];
	twinLiftNextDraw	:= root.allDrawingAttributes[PicTATwinLiftNext];
	twinLiftPrevDraw	:= root.allDrawingAttributes[PicTATwinLiftPrev];
	picWorkUnAssigned	:= self.picMachAssign.picture;
	queueIdCol			:= null;
	pictureCol			:= null;
	flagCol				:= null;
	containerCol		:= null;
	twinCol				:= null;
	machAssignedCol		:= null;
	overstowCol			:= null;
	overstowedAtMove	:= false;
	overstowed			:= false;
	
	
	on Exception do app.handleDeletedObject(exception, nextTask, invalidNextTask);			// PAR #30635
	on Exception do app.handleDeletedObject(exception, task, invalidTask);
	on Exception do app.handleDeletedObject(exception, existRTQTask, existTaskInvalid);		// PAR #24686
	on Exception do app.handleDeletedObject(exception, pEntry, invalidEntry);				// PAR #31092
	
	entryStatus := pEntry.status;
	
	if invalidEntry then
		return;
	endif;
	
	//twinOpts   := pEntry.getTwinCarryFlag;				// PAR #21593 - moved out of loop			//14.07.2025 navbs1 #35345
	entryTasks := pEntry.allTasks.cloneSelf(true);		// copying collection to a local array. PAR23829 20/04/2010
	if entryTasks = null then							// 20/02/2013 cnwar2 #31188
		return;
	endif;

	startIndex 		:= self.tblQEntries.fixedRows + 1;

	// PAR #27408 - Need to calculate insertIndex for the (first) task based on the following rules:
	// 	1. If any of the subsequent queue entries after this one is in the table, insert at its position, else
	// 	2. Insert at the end of the table
	insertIndex := 0;
	endIndex    := self.tblQEntries.rows;
	
	// PAR #27579 - if adding at the end, ignore relative positions
	if not _addAtEnd then
	
		// Use the entries in the listbox to determine the prior and next entries
		entryListIndex := self.lstQueues.findObject(pEntry);
		
		// Entry should always be in the listbox by now, but if it isn't, then drop through and just add this entry at the end
		if entryListIndex &gt; 0 then
			
			// Firstly, try to find the first task in the table of the closest subsequent queue entry already in the table
			foreach nextEntryListIndex in (entryListIndex + 1) to self.lstQueues.listCount() do : nextEntryLoop
				listObj := self.lstQueues.itemObject[nextEntryListIndex];
				if listObj.isKindOf(CM_RTQueueEntry) then
					nextQEntry := listObj.CM_RTQueueEntry;
					
					// Find the first entry in the table for this entry
					foreach index in startIndex to endIndex do
						existRTQTask := self.tblQEntries.accessRow(index).itemObject.CM_RTQueueTask;
						if  existRTQTask &lt;&gt; null  then                          //28.01.2020 cnwma1 #48272
							if existRTQTask.myEntry = nextQEntry then    
								insertIndex := index;
								break nextEntryLoop;
							endif;
						endif;
					endforeach;
				endif;
			endforeach;
			
		endif;
	endif;

	// If we haven't found either the prior or next entry, or we have been told to add at the end, then 
	// add at the end of the table
	if insertIndex = 0 then
		insertIndex := endIndex + 1;
	endif;
	
	foreach task in entryTasks discreteLock	do 
		if not self.isFullTaskMode and not task.isFirstTask then
			continue;
		endif;
		
		count    := count + 1;
		ti       := task.ti;
		colCount := 1;
		str		 := null;
		
		foreach entTableRow in self.tblQEntries.allTblDataEntRows do
			if pictureCol = null 		 and entTableRow.name = ETRow_Status then
				pictureCol := colCount;
			elseif flagCol = null		  and entTableRow.name = ETRow_Or then
				flagCol:=colCount;
			elseif queueIdCol = null	  and entTableRow.name = ETRow_QueueId then
				queueIdCol:= colCount;
			elseif containerCol = null	  and entTableRow.name = ETRow_ItemId then
				containerCol := colCount;
			elseif machAssignedCol = null and entTableRow.name = ETRow_Assigned then
				machAssignedCol := colCount;
			elseif entTableRow.name = ETRow_TwinCarry then
				twinCol:=	colCount;
			endif;
		
			if entTableRow.name = ETRow_QueuePos  then
				str:= str &amp; queueIndex.String &amp; Tab;
			elseif entTableRow.name= ETRow_TaskPos then
				str:= str &amp; _index.String &amp; Tab;
			elseif	entTableRow.name = ETRow_EntryPos  then
				str:= str &amp; count.String &amp; Tab;
			elseif entTableRow.name = ETRow_Overstow then
				overstowCol			:=	colCount;
				sideAccessDirection :=  null;
				task.isOverStowedRTQueue(overstowed,overstowedAtMove,sideAccessDirection);
				str					:= str &amp;  app.getYesBlank(overstowed)  &amp; Tab;
			elseif entTableRow.name = ETRow_Target then
				nextTask := null;
				if not self.isFullTaskMode and task.taskType &lt;&gt; TASK_SETDOWN then
					taskPos := entryTasks.indexOf(task);
					if entryTasks.size &gt; taskPos then
						nextTask := entryTasks[taskPos + 1];
					endif;
				endif;
				
				if nextTask &lt;&gt; null then
					value := null;
					value := nextTask.getTargetLocationForDisplay();												//25.06.2025 navbs1 #35185
					str   := str &amp; value &amp; Tab;
				else
					value := null;
					value := task.getTargetLocationForDisplay();													//25.06.2025 navbs1 #35185
					str   := str &amp; value &amp; Tab;
				endif;
			elseif entTableRow.name = ETRow_Source  then
				nextTask := null;
				if not self.isFullTaskMode and task.isSetDown then
					taskPos  := entryTasks.indexOf(task);
					if taskPos &gt; 1 then
						nextTask := entryTasks[taskPos - 1];
					endif;
				endif;
				if nextTask &lt;&gt; null then
					value := null;
					value := nextTask.getSourceLocationId();														//25.06.2025 navbs1 #35185
					str   := str &amp; value &amp; Tab;
				else
					value := null;
					value := task.getSourceLocationId();															//25.06.2025 navbs1 #35185
					str   := str &amp; value &amp; Tab;
				endif;
			else
				value := null;
				value := task.getDisplayStringForAttribute(entTableRow.name,false);
				str   := str &amp; value &amp; Tab;
			endif;
			colCount := colCount + 1;
		endforeach;	

		// PAR #27408 - Rework algorithm to determine insert point before loop through tasks, so just insert task and increment 
		// insertIndex (in case we are in full task mode)
		idx := insertIndex;
		self.tblQEntries.addItemAt(str, idx);
		insertIndex := insertIndex + 1;

		
		tblQEntries.accessRow(idx).itemObject := task;
		if task.status = TASK_COMPLETE then
			aColourBack := Grey;
			aColourFore := White;
		else
			aColourBack := COLOUR_Light_2;
		endif;
		tblQEntries.accessRow(idx).backColor := aColourBack;
		if queueIdCol &lt;&gt; null then
			tblQEntries.accessCell(idx,queueIdCol).backColor := aColourBack;
		endif;
		if containerCol &lt;&gt; null then
			tblQEntries.accessCell(idx,containerCol).backColor := aColourBack;
		endif;
		
		if pictureCol &lt;&gt; null then
			tblQEntries.accessCell(idx,pictureCol).backColor := aColourBack;
			tblQEntries.accessCell(idx,pictureCol).picture := self.getStatusPicture(task);
		endif;
		
		if flagCol &lt;&gt; null then
			tblQEntries.accessCell(idx, flagCol).fontBold := true;
		endif;
		
		//if twinCol &lt;&gt; null and twinOpts &lt;&gt; null then							//14.07.2025 navbs1 #35345
		if twinCol &lt;&gt; null then													//14.07.2025 navbs1 #35345
			twinOpts  := pEntry.getTwinCarryFlag;								//14.07.2025 navbs1 #35345
			if twinOpts &lt;&gt; null then 											//14.07.2025 navbs1 #35345
				twinCell			:= tblQEntries.accessCell(idx, twinCol);
				twinCell.fontName   := twinLiftDraw.fontName;
				twinStr				:= twinLiftDraw.fontCharacter.Character.String;
				if twinOpts = CM_RTQueueEntry.TWIN_NEXT then
					twinStr := twinStr &amp; twinLiftNextDraw.fontCharacter.Character;
				elseif  twinOpts = CM_RTQueueEntry.TWIN_PREV then
					twinStr:=twinLiftPrevDraw.fontCharacter.Character &amp; twinStr; 
				elseif  twinOpts = CM_RTQueueEntry.TWIN_BOTH then
					twinStr:=  twinLiftPrevDraw.fontCharacter.Character &amp;  twinStr &amp; twinLiftNextDraw.fontCharacter.Character;
				endif;
				twinCell.text:=twinStr;
			endif;
		endif;
		
		if machAssignedCol &lt;&gt; null then
			if task.getMachineID = null and	not task.myEntry.hasMachineCoverage  then
				tblQEntries.accessCell(idx,machAssignedCol).alignment := Table.Alignment_Center;
				tblQEntries.accessCell(idx,machAssignedCol).picture   := picWorkUnAssigned;
			endif;
		endif;
		
		//epr 19/2/09 CCMS 1025 changes after review
		if overstowCol &lt;&gt; null and  overstowedAtMove then
			tblQEntries.accessCell(idx,overstowCol).foreColor := Red;
		endif;
		
		if task.isOverstowTask then
			aColourFore := Red;
			tblQEntries.accessRow(idx).foreColor := aColourFore;
		endif;
		
		if ti &lt;&gt; null and task.status = TASK_COMPLETE and task.taskType = TASK_SETDOWN then
			lController := ti.getPrimaryLocation(REAL_MODE);
			if lController &lt;&gt; null  and pEntry.myWorkListEntry &lt;&gt; null and pEntry.myWorkListEntry.myFutureMove &lt;&gt; null then
				if task.status = TASK_COMPLETE and lController.myTerminalArea &lt;&gt; null and lController.myTerminalArea.isA(CM_CraneTransferArea) then
					aColourFore := Blue;
					tblQEntries.accessRow(idx).foreColor := aColourFore;
				endif;
			endif;
		endif;
	endforeach;

epilog
	delete entryTasks;
	
end;</source>
        <Parameter name="pEntry" type="CM_RTQueueEntry"/>
        <Parameter name="_index" type="Integer"/>
        <Parameter name="_addAtEnd" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="splitter2_splitterMove" id="41be5f39-f5f0-432b-a66b-76d548f308ae">
        <controlMethod name="CMUI_SplitContainer::splitterMove"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>splitter2_splitterMove(pSplitContainer: CMUI_SplitContainer input) updating;

vars

	ratio,
	size	 : Integer;
begin

	size := pSplitContainer.width.Integer - (pSplitContainer.width * (pSplitContainer.leftToRightRatio / 100)).Integer;
	if size &lt; 43 then
		// Get correct ratio for size
	 	ratio := ((1 - (43 / pSplitContainer.width)) * 100).Integer;
		pSplitContainer.setLeftToRightRatioAndResize(ratio);
	endif;

end;</source>
        <Parameter name="pSplitContainer" type="CMUI_SplitContainer" usage="input"/>
    </JadeMethod>
    <JadeMethod name="tblDataSetupMergeHeading" id="9392467c-4052-453b-a6d8-deb1f3717e29">
        <source>tblDataSetupMergeHeading();
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
23 January 2009	cnwer1	Initial creation

*/

vars
	table : CM_DataTable;
	numCols, 
	mergeStart, 
	theFixedCols: Integer;
	tblHeadingTop,
	viewName 	: String;
	entRow		: EntTableRow;
	view		: EntTableView;
	views		: ObjectArray;
	obj			 : Object;
	firstViewCol : Boolean;
begin
	table := self.tblQEntries;
	numCols 		:= table.allTblDataColHeadings.size;
	table.fixedRows:=2;
	// Do this to force table column widths to be auto-resized
	// when new data is redisplayed
	table.columns 	:= numCols;
	
	table.fixedRows:=2;
	table.fixed3D := false;
	table.selectMode := Table.SelectMode_CurrentRow;
	mergeStart:=1;
	
	tblHeadingTop:="";
	create views transient;
	views.add(table.myEntTableDef.allEntTableViews['Information']);
	views.add(table.myEntTableDef.allEntTableViews['Task_Details']);
	views.add(table.myEntTableDef.allEntTableViews['Machine']);
	views.add(table.myEntTableDef.allEntTableViews['Task_Rest']);
	theFixedCols:=0;
	foreach obj  in views do
		view :=obj.EntTableView;
		if view.name = "Sort" then
			continue;
		endif;
		
		firstViewCol:= true;
		
		foreach entRow in view.allEntTableRows do
			if not table.allTblDataEntRows.includes(entRow) then
				continue;
			endif;
			viewName:=view.name;
			
			if view.name = "Information" then
				theFixedCols:=theFixedCols + 1;
				
			elseif view.name = "Task_Rest" then
				viewName:=null;
			elseif view.name = "Task_Details" then
				viewName:="Task Details";
			endif;
			
			if firstViewCol then
				
				table.accessCell(1,mergeStart).mergeCells := Table.MergeCells_Merge;
				tblHeadingTop:=tblHeadingTop &amp; viewName &amp; Tab;
			else
				tblHeadingTop:=tblHeadingTop &amp; Tab;
			endif;
			mergeStart:=mergeStart+1;
			firstViewCol:=false;
		endforeach;
	endforeach;
	table.fixedColumns	:=theFixedCols;
	table.accessCell(1, 1).text := tblHeadingTop;

	table.allTblDataSortColumns.clear();
	table.allTblDataSortDescending.clear();
	
	
	table.zAddSortColumn(ETRow_QueuePos, false);
	table.zAddSortColumn(ETRow_TaskPos, false);
	table.zAddSortColumn(ETRow_EntryPos, false);
	
	table.disallowColumnSorter :=false;
	table.setSortColumnsForMaxNumCols();
	
epilog
	delete views;

end;</source>
    </JadeMethod>
