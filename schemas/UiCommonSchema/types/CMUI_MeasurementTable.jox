    <JadeMethod name="loadCombo" id="cd4b0fbd-2e06-4655-9b83-2d83c058739b">
        <updating/>
        <source>loadCombo() protected, updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12/01/2013	cnwdap1	Initial creation PAR #31155 CCMS SFW 1321 Imperial Measurements
*/
vars
	measure : CM_MeasurementType;
	default : CM_MeasurementType;
	str 	: String;
	nbr 	: Integer;

begin
	foreach measure in app.myRoot.allMeasurementTypesByShortName do
		if measure.measurementType = self.measurementType and measure.isAvailableForEntry and measure.isDisplay then
			str := str &amp; measure.shortName &amp; Tab;
			nbr := nbr + 1;
			if measure.isDefault then
				default := measure;
			endif;
		endif;
	endforeach;
	if nbr = 1 then
		str := str.stripTrailingChar(Tab);
		self.accessCell(1, self.ColumnUnit).inputType := self.InputType_None;
		self.accessedCell.text := str;
		self.accessedCell.comboList := null;
		self.rowHeight[1] := self.height.Integer;
	else
		self.accessCell(1, self.ColumnUnit).comboList := str;
		if default &lt;&gt; null then
			self.accessedCell.text := default.shortName;
		endif;
	endif;

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setColumnWidths" id="3d7300c5-f90b-459b-a354-393cfd4a4cae">
        <updating/>
        <source>setColumnWidths(_valueColumn, _unitColumn : Integer) updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12/02/2013	cnwdap1	Initial creation PAR #31155 CCMS SFW 1321 Imperial Measurements
*/
vars

begin
	self.accessColumn(self.ColumnValue).width := _valueColumn;
	self.accessColumn(self.ColumnSpacer).width := 5;
	self.accessColumn(self.ColumnUnit).width := _unitColumn;
epilog

end;</source>
        <Parameter name="_valueColumn" type="Integer"/>
        <Parameter name="_unitColumn" type="Integer"/>
    </JadeMethod>
