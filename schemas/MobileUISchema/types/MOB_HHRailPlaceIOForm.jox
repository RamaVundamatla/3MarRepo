    <JadeMethod name="clickBtnInward" id="46aa899d-2509-4486-89b6-9cf901ea6ef5">
        <updating/>
        <source>clickBtnInward() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 August 2010	cnwndl1	Initial creation	Par 25215

*/

vars

begin

	app.mousePointer :=	Busy;

	self.myMobileGenericAgent.setInward( true );
	self.myMobileGenericAgent.setForward( true );	// default value
	self.myMobileGenericAgent.setMyCurrentTrain( null );
	self.myMobileGenericAgent.setMyCurrentRailLine( null  );
	self.gotoForm( MOB_HHRailPlaceTrainForm, false );
	
epilog

	app.mousePointer :=	Idle;
	
end;</source>
