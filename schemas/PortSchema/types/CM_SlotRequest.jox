    <JadeMethod name="isFwdSlotReqSameHeight" id="7f3faf91-8d7e-4d53-b502-4f59c61039e4">
        <source>isFwdSlotReqSameHeight() : Boolean;
// ---------------------------------------------------------------------------
// Created:		17 August 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	aftReq, fwdReq : CM_SlotRequest;
	fwdWLE, aftWLE : CM_VoyageWLE;
	fwdTI, aftTI : CM_TrackedItem;
	fwdISO, aftISO : CM_ISOType;
begin
	fwdReq := self.getForwardSlotRequest();
	aftReq := self;
	
	if fwdReq = null then
		return true;
	endif;
	if fwdReq.myJob &lt;&gt; self.myJob then
		return true;
	endif;
	
	if fwdReq.getAttrIs40() then
		return true;
	endif;
	if aftReq.getAttrIs40() then
		return true;
	endif;

	if fwdReq.isAftBay() then
		return true;
	endif;
	
	aftWLE := aftReq.allWorkListEntries.first.CM_VoyageWLE;
	fwdWLE := fwdReq.allWorkListEntries.first.CM_VoyageWLE;
	if aftWLE = null or fwdWLE = null then
		return true;
	endif;
	
	aftTI := aftWLE.myTrackedItem;
	fwdTI := fwdWLE.myTrackedItem;
	if aftTI = null or fwdTI = null then
	
	
		// PAR 34834 if no TI planned yet, but using Allocations we can use the ISO Type on the colour coding
		if self.useVoyageAllocations then
			fwdISO := fwdReq.getAttrISOType();
			aftISO := aftReq.getAttrISOType();
			if fwdISO &lt;&gt; null and aftISO &lt;&gt; null then
				if not fwdISO.isSameHeight(aftISO) then
					return false;
				endif;
			endif;
		endif;
	
	
		return true;
	endif;
	
	fwdISO := fwdTI.getISOTypeObject();
	aftISO := aftTI.getISOTypeObject();
	
	if fwdISO = null or aftISO = null then
		return true;
	endif;
		
	if fwdISO.isSameHeight(aftISO) then
		return true;
	endif;
	
	return false;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isFwdSlotReqSameHeightBelow" id="3dac1ff5-f0b1-4793-a59a-41b7b70618c9">
        <source>isFwdSlotReqSameHeightBelow(_reason : String output) : Boolean;
// ---------------------------------------------------------------------------
// Created:		17 August 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	underSlotDefn : CM_SlotDefn;
	underSlotController : CM_SlotController;
	underSlotReq, upperSlotReq : CM_SlotRequest;
	idx : Integer;
begin
	upperSlotReq := self;
	_reason := null;
	
	while true do
		if not upperSlotReq.isFwdSlotReqSameHeight() then
			_reason := upperSlotReq.mySlotController.getFullId();
			return false;
		endif;
		idx := idx + 1;
		if idx &gt; 30 then // stop looping
			break;
		endif;
		underSlotDefn := upperSlotReq.mySlotDefinition.myOverheadSlot;
		if underSlotDefn &lt;&gt; null then
			underSlotController := underSlotDefn.CM_SlotDefnVoyage.mySlotController;
			if underSlotController &lt;&gt; null then
				if upperSlotReq.isDischarge then
					underSlotReq := underSlotController.mySlotRequestDischarge;
				else
					underSlotReq := underSlotController.mySlotRequestLoad;
				
				endif;
				if underSlotReq &lt;&gt; null then
					if underSlotReq.myJob = upperSlotReq.myJob then
						upperSlotReq := underSlotReq;
					else
						break;
					endif;
				else
					break;
				endif;
			else
				break;
			endif;
		else
			break;
		endif;
	endwhile;
	return true;
end;</source>
        <Parameter name="_reason" type="String" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
