begin
	return true;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="remActionsIfNoCompletes" id="3b10b58a-a6fb-4b03-92a2-5fc0ad5b37c4">
        <source>remActionsIfNoCompletes( _ti : CM_TrackedItem );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 November 2016	cnwndl1	Initial creation	TFS 2968 / 2001

*/

vars

	iter : Iterator;
	invalidObj : Boolean;
	tiTrx : CM_TITransaction;
	stopTrx : CM_StopClearedDocAction;
	taskTrx : CM_TaskCompleteDocAction;
	
	docStopApplied : CM_DocumentStops;
	todoApplied : CM_DocumentToDoTask;
	
	objsToDel : ObjectArray;
	
	realResDet : CM_ReserveDetail;
	realResDetActions : CM_ReserveDetailActions;

begin

	if _ti = null then
		return;
	endif;
	
	if self.myReserveDetail.isTransient then
		realResDet := self.myReserveDetail.pxyGetRealObject;
		if realResDet &lt;&gt; null then
			realResDetActions := realResDet.myReserveDetailActions;
		endif;
	endif;
	
	on Exception do app.handleDeletedObject( exception, tiTrx, invalidObj );
	
	iter := self.allCompletedStopTrx.createIterator;
	while iter.next( tiTrx ) do
		invalidObj := false;
		if not tiTrx.isStopClearedDocAction then
			continue;
		endif;
		if invalidObj then
			continue;
		endif;
		if tiTrx.deleted then
			continue;
		endif;
		stopTrx := tiTrx.CM_StopClearedDocAction;
		if _ti = stopTrx.myTrackedItem then
			//We have cleared a stop for this one, they can unassign it but we do not play with the applied stops and tasks
			return;
		endif;
	endwhile;
	delete iter;
	
	iter := self.allCompletedTaskTrx.createIterator;
	while iter.next( tiTrx ) do
		invalidObj := false;
		if not tiTrx.isTaskCompleteDocAction then
			continue;
		endif;
		if invalidObj then
			continue;
		endif;
		if tiTrx.deleted then
			continue;
		endif;
		taskTrx := tiTrx.CM_TaskCompleteDocAction;
		if _ti = taskTrx.myTrackedItem then
			//We have completed a task for this one, they can unassign it but we do not play with the applied stops and tasks
			return;
		endif;
	endwhile;
	delete iter;
	
	//No related task completions found.  Remove and delete any stops and/or task applied for the ti.
	create objsToDel transient;
	
	foreach docStopApplied in self.allDocumentStopsApplied do
		if docStopApplied.myTrackedItem = _ti then
			objsToDel.add( docStopApplied );
		endif;
	endforeach;
	
	foreach todoApplied in self.allDocumentTasksApplied do
		if todoApplied.myTrackedItem = _ti then
			objsToDel.add( todoApplied );
		endif;
	endforeach;
	
	if not objsToDel.isEmpty then
		objsToDel.purge();
	endif;
	
epilog

	delete objsToDel;
	delete iter;

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="2601b72d-c926-43dd-8e4e-3e8e011ba6c5">
        <updating/>
        <source>setForUpdate(_proxy: CM_DocumentActions) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 November 2016	cnwndl1	Initial creation	TFS 2968

*/

vars

	realDocStop : CM_DocumentStops;
	pxyDocStop : CM_DocumentStops;
	ti : CM_TrackedItem;
	objsToDel : ObjectArray;
	realDocToDo : CM_DocumentToDoTask;
	pxyDocToDo : CM_DocumentToDoTask;
	remarksToApply : StringArray;
	taskToApply : CM_ToDoTaskDescArray;
	stopToApply : CM_StopsTableSet;
begin
	self.getNewTaskDescsToApply(_proxy, remarksToApply,taskToApply ); // ### TFS 3283
	self.getNewStopsTableToApply(_proxy, stopToApply); // ### TFS 3283
	
	inheritMethod(_proxy);
	
	create objsToDel transient;
	
	foreach realDocStop in self.allDocumentStopsApplied do
		pxyDocStop := _proxy.findMatchingStopApplied( realDocStop );
		if pxyDocStop &lt;&gt; null then
			// all good carry on
			continue;
		endif;
		ti := realDocStop.myTrackedItem;
		if ti = null then
			// huh?
			objsToDel.add( realDocStop );
			continue;
		endif;
		if ti.hasBeenMerged then
			continue;
		endif;
		if not self.myReserveDetail.allTrackedItems.includes( ti )
		and not self.myReserveDetail.allTrackedItemsReleased.includes( ti )
		then
			// Its been unassigned
			objsToDel.add( realDocStop );
			continue;
		endif;
	endforeach;
	
	foreach realDocToDo in self.allDocumentTasksApplied do
		pxyDocToDo := _proxy.findMatchingTaskApplied( realDocToDo );
		if pxyDocToDo &lt;&gt; null then
			// all good carry on
			continue;
		endif;
		ti := realDocToDo.myTrackedItem;
		if ti = null then
			// This should never happen, but if it does clean it up whil ewe have the chance
			objsToDel.add( realDocToDo );
			continue;
		endif;
		if ti.hasBeenMerged then
			continue;
		endif;
		if not self.myReserveDetail.allTrackedItems.includes( ti )
		and not self.myReserveDetail.allTrackedItemsReleased.includes( ti )
		then
			// Its been unassigned
			objsToDel.add( realDocToDo );
			continue;
		endif;
	endforeach;
	
	if not objsToDel.isEmpty then
		objsToDel.purge();
	endif;
	
	// TFS 3283 - This must be before setTaskDescsToAdd as it compares proxy to actual
	self.setNewTaskDescsToApply(_proxy, remarksToApply,taskToApply); // ### TFS 3283
	self.setNewStopsTableToApply(_proxy, stopToApply); // ### TFS 3283

epilog

	delete objsToDel;

end;</source>
        <Parameter name="_proxy" type="CM_DocumentActions"/>
    </JadeMethod>
    <JadeMethod name="setMyReserveDetail" id="60ed26e7-20c9-4a61-a2e1-835463df0989">
        <updating/>
        <source>setMyReserveDetail(	_reserveDetail : CM_ReserveDetail ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 September 2016	cnwndl1	Initial creation	TFS 2644 / 2001

*/

vars

begin

	self.myReserveDetail := _reserveDetail;

epilog

end;</source>
        <Parameter name="_reserveDetail" type="CM_ReserveDetail"/>
    </JadeMethod>
</Class>
