    <JadeMethod name="getTotalWeightWidthHeight" id="d9436b4e-57cc-4579-8ebd-235a06f29f5d">
        <source>getTotalWeightWidthHeight(maxWeight: Decimal output; maxWidth: Decimal output; maxHeight: Decimal output): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 March 2013	cnwndl1	Initial creation	Par 31278

*/

vars

	ti : CM_TrackedItem;
	tiArray : CM_TIArray;
	tiWeight : Decimal [12,4];
	
begin

	create tiArray transient;
	self.getTIDataForClearanceCheck(tiArray);
	
	if myWagonClass &lt;&gt; null then
		maxHeight := myWagonClass.overallHeight;
	endif;
	
	maxWeight := self.getTIsWeight(tiArray) + self.getWagonTareWeight();
	
	return (not tiArray.isEmpty);
	
epilog

end;</source>
        <Parameter name="maxWeight" type="Decimal" usage="output"/>
        <Parameter name="maxWidth" type="Decimal" usage="output"/>
        <Parameter name="maxHeight" type="Decimal" usage="output"/>
        <ReturnType type="Boolean"/>
