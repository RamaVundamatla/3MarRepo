    <JadeMethod name="tblVoyTermDtl_queryRowColChg" id="817a51ea-49fc-4437-adfa-63fb6a85da75">
        <controlMethod name="CM_DataTable::queryRowColChg"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblVoyTermDtl_queryRowColChg(table: CM_BaseTable input; newSheet: Integer; newRow: Integer; newCol: Integer):Boolean updating;
//--------------------------------------------------------------
//Created: 26 November 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	hasChanged	: Boolean;
	berth,
	sideTo		: String;
	terminal	: CM_Terminal;
	voyage		: CM_Voyage;
	hmsBerth	: HMS_Berth;
begin
	if table.column = table.columns then
		self.setLoadEndDateTime();
	endif;
	// change of berth to set side-to
	if table.row &gt; table.fixedRows then
		if table.column = 2 then
			terminal := table.accessCell(table.row, 1).itemObject.CM_Terminal;
			voyage := table.accessRow(table.row).itemObject.CM_Voyage;
			berth := table.accessCell(table.row, table.column).text;
			hmsBerth := self.findBerth(terminal, berth);
			hasChanged := false;
			// null voyage is new, take any change of berth
			if voyage = null then
				hasChanged := true;
			elseif voyage.getMyBerth() &lt;&gt; hmsBerth then
				hasChanged := true;
			endif;
			if hasChanged and hmsBerth &lt;&gt; null then
				if hmsBerth.getStarboardBerthed() then
					sideTo := "Starboard";
				else
					sideTo := "Port";
				endif;
			endif;
			if sideTo &lt;&gt; null then
				table.accessCell(table.row, table.column + 1).text := sideTo;
			endif;
		endif;
	endif;

	table.handleDateCellLostFocus(table.row, table.column);
	return true;
end;</source>
        <Parameter name="table" type="CM_BaseTable" usage="input"/>
        <Parameter name="newSheet" type="Integer"/>
        <Parameter name="newRow" type="Integer"/>
        <Parameter name="newCol" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="tblVoyageAdmin_queryRowColChg" id="3d360f45-05ad-4a90-9cf5-248979f496d0">
        <controlMethod name="CM_EntryTable::queryRowColChg"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblVoyageAdmin_queryRowColChg(table: Table input; newSheet: Integer; newRow: Integer; newCol: Integer):Boolean updating;
// CCMS 1124 when tabbing out of the IMO field with no vessel name, look it up
//  if found, set the vessel name and don't allow change, otherwise enable the vessel name
vars
	imo,
	vesselName	: String;
begin
	if self.tblVoyageAdmin.row = 2 then
		imo := self.tblVoyageAdmin.getValueByName(ETRow_IMO).String[1:7];
		vesselName := self.tblVoyageAdmin.getValueByName(ETRow_VesselName).String;
		if imo &lt;&gt; null then
			vesselName := self.findVesselName(imo);
			if vesselName &lt;&gt; null then
				self.tblVoyageAdmin.setValueByName(ETRow_VesselName, vesselName);
				// 33265 stop this name being changed here 
				self.tblVoyageAdmin.disableRowByName(ETRow_VesselName);
			else
				self.tblVoyageAdmin.enableRowByName(ETRow_VesselName);
			endif;
		else
			self.tblVoyageAdmin.enableRowByName(ETRow_VesselName);
		endif;
	endif;

	return true;
end;
</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="newSheet" type="Integer"/>
        <Parameter name="newRow" type="Integer"/>
        <Parameter name="newCol" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
