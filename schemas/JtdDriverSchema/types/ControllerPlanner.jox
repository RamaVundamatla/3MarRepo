	sa.add('cp026_CN_lstTest_dblClick'); //ok
	sa.add('cp028_SOOWF_cmbVoyage_click'); //ok set voyage combo
	sa.add('cp030_SOOWF_picture_click'); // ok click find btn
	// show planning guide
	sa.add('cp012_CN_lstTest_click'); // ok click planning guide toolbar btn on OOW 
	//sa.add('cp014_CN_lstTest_dblClick');
	//sa.add('cp016_SPGF_cmbVoyage_click');
	
	//show OOWC 
	sa.add('cp018_CN_lstTest_click'); // k click OOWC toolbar btn on OOW 
//	sa.add('cp020_CN_lstTest_dblClick');
	sa.add('cp022_SOOWCF_cmbVoyage_click');
	

	//load list
	sa.add('cp032_CN_lstTest_click'); // ok 
	sa.add('cp034_CN_lstTest_dblClick'); // ok 
	sa.add('cp036_SLL_cmbVoyageNoteclick');// ok 
	sa.add('cp038_SLL_picture_click');// ok 
	sa.add('cp040_SLL_fldMain_click');// ok 
	sa.add('cp042_CN_lstTest_click');// ok 
	sa.add('cp044_CN_lstTest_dblClick');// ok 
	sa.add('cp046_SLL_cmbVoyageNoteclick');// ok 
	sa.add('cp048_SLL_picture_click');// ok 
	sa.add('cp050_SLL_fldMain_click');// ok 
	//ship job controller
	sa.add('cp052_CN_lstTest_click');// ok 
	sa.add('cp054_CN_lstTest_dblClick');// ok 
	sa.add('cp056_SJCF_cmbVoyages_click');// ok 
	sa.add('cp058_SJCF_picture_click');// ok 
	sa.add('cp060_CN_lstTest_click');// ok 
	//voyage side profile
	sa.add('cp062_CN_lstTest_dblClick');// ok 
