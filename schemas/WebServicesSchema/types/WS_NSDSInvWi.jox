    <JadeMethod name="setProxyObject" id="57317bb9-3c1c-458c-9bfc-db844f7669ed">
        <updating/>
        <source>setProxyObject(_any : Any) updating;
/*
Purpose:			

Date		Who		Reason
15MAR2022	NAVRA1	TFS 53028
*/


vars
	helper 	: CMIF_InvWi;
	ewsOpsView: CM_EWSActivityOpsview;
begin
	
	inheritMethod(_any);
	
	create helper transient;
	create ewsOpsView transient;
	ewsOpsView.initialiseActivity("","",_any.CM_Object.getMyTerminal(),_any.CM_Object, null,null,false,null);
	helper.initializeForActivity(_any, ewsOpsView);
	
	self.tableName					:= helper.tableName;	
	self.gkey                       := helper.gkey;
	self.facility_gkey	    		:= helper.facility_gkey;
	self.uyv_gkey	    			:= helper.uyv_gkey;
	self.wq_pkey	    			:= helper.wq_pkey;
	self.work_queue_gkey			:= helper.work_queue_gkey;
	self.che_gkey	    			:= helper.che_gkey;
	//navra1 - TFS 51855 - 13th May 2022
	self.nominated_che_gkey			:= helper.nominated_che_gkey; 
	self.move_kind	 				:= helper.move_kind;
	self.move_stage		 			:= helper.move_stage;
	self.carrier_locid   			:= helper.carrier_locid;
	self.carrier_loctype			:= helper.carrier_loctype;
	self.mvhs_t_fetch				:= helper.mvhs_t_fetch;
	self.mvhs_t_put				    := helper.mvhs_t_put;
	self.mvhs_t_discharge			:= helper.mvhs_t_discharge;
	self.mvhs_t_carry_complete		:= helper.mvhs_t_carry_complete;
	self.est_move_time 				:= helper.est_move_time;
	self.mvhs_fetch_che_id			:= helper.mvhs_fetch_che_id;
	self.mvhs_carry_che_id			:= helper.mvhs_carry_che_id;
	self.mvhs_put_che_id			:= helper.mvhs_put_che_id;
	self.pos_loc_gkey				:= helper.pos_loc_gkey;
	self.wi_fetch_time				:= helper.wi_fetch_time;
	self.move_put_time 				:= helper.move_put_time;
	self.move_carry_complete_time 	:= helper.move_carry_complete_time;
	self.move_discharge_time 		:= helper.move_discharge_time;
	//navra1 - TFS-53105  - 10th Aug 2022
	self.claimed_teu				:= helper.claimed_teu;
	self.planned_teu				:= helper.planned_teu;


epilog
	delete helper;
	delete ewsOpsView;
end;
</source>
        <Parameter name="_any" type="Any"/>
    </JadeMethod>
</Class>
