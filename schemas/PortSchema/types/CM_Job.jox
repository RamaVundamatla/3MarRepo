    <JadeMethod name="addJobRequest" id="87c011dd-adaa-4063-a41d-9e0867cabe4d">
        <updating/>
        <source>addJobRequest(	_ti : CM_TrackedItem input; 
				_isReceipt : Boolean; 
				_quantity : Integer;
				_weight : Decimal;
				_passport : CM_Passport input) updating;
//--------------------------------------------------
// Created:	03 September 2003 By: cnwgd1
//--------------------------------------------------
vars

begin

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_isReceipt" type="Boolean"/>
        <Parameter name="_quantity" type="Integer"/>
        <Parameter name="_weight" type="Decimal"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="addTI" id="050dfdea-082b-44d4-b4fe-d24696d3f6fe">
        <updating/>
        <source>addTI(_ti: CM_TrackedItem input; _request: CM_Request) updating;
// 01/04/2010	cnwcs5	par 23383 - pass context info (_request) to updateTICollections 
//									via new parameter (_extra)
// 29 Aug 2012	cnwcs5	par 30292 - use updateObjectEdition instead of updateEdition 
vars

begin

	exclusiveLock(self);

	if (_ti = null or _request = null) then
		app.setContinueCMExceptions(false);
		app.raiseCMException(ERR_TI_LINK_PARAM, null, null);
		return;	
	endif;

	sharedLock(_request);
	exclusiveLock(_ti);

	self.updateTICollections(_ti, _request);	// 01/04/2010 cnwcs5 par 23383

	self.updateObjectEdition(self);	// par 30292
	
	// PAR 11770 Lorcan Send note so screens can update
	app.myEventManager.createSingleObjInfoNoteEvt(self, self.getMyTerminal.getTerminalEvent(RoadJob_Update_Event), self);

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_request" type="CM_Request"/>
    </JadeMethod>
    <JadeMethod name="addToAlerts" id="d97d38da-f672-404b-9993-85147ac06180">
        <interfaceImplements>
            <JadeInterfaceMethod name="IF_AlertAlarm::addToAlerts"/>
        </interfaceImplements>
        <updating/>
        <source>addToAlerts(alert: CM_SystemAlert) updating;
/*

Purpose:	adds alerts self.alerts and sends the note		


Return Value:		


Date		Who		Reason
06 September 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars
	//terminal : CM_Terminal;
begin
	if not self.alerts.includes(alert) then
		self.alerts.add(alert);
	endif;
	
	/*- cnwmd1, CCMS 1871 - No longer required.  app.causeEventForSystemAlertType method is called in CM_SystemAlert::commitAlert()
	terminal := self.getTerminalForAlert;
	if terminal &lt;&gt; null and alert.mySystemAlertType &lt;&gt; null then
		//terminal.causeEvent(alert.mySystemAlertType.type,false,alert); 	//- cnwmd1, CCMS 1871
		app.causeEventForSystemAlertType(alert, terminal); 					//+ cnwmd1 CCMS 1871
	endif;
	*/

epilog

end;</source>
        <Parameter name="alert" type="CM_SystemAlert"/>
    </JadeMethod>
