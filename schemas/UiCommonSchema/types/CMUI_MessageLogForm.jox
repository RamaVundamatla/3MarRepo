    <JadeMethod name="addToolbarControls" id="0d4a8b08-ff48-4ff9-b6b8-e57f466441d0">
        <updating/>
        <source>addToolbarControls() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
06 September 2018	jlger1	Initial creation
25 November 2019	jlgzm1	TFS 47653 Changing how EDI Webservice Monitor displays XML
22 August 2023		navmd1	TFS 59024 Handle JSON messages
13 December 2024	navrv30	JIRA 33578 EUP | Incoming API Logging
*/

vars
	toolbar			: CMUI_Toolbar;
begin
	inheritMethod();
	
	toolbar := self.frmToolbar;
	//toolbar.addButton(self.btnPrint, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnFind, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnFindNext, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnSaveBase, CMUI_Toolbar.Control_Alignment_Left);  //13 December 2024	navrv30	JIRA 33578
	if self.myObject &lt;&gt; null and self.myObject.isKindOf(CM_ActivityHistoryExtInterface) then
		toolbar.addButton(self.btnExportRequest, CMUI_Toolbar.Control_Alignment_Left);
		toolbar.addButton(self.btnExportResponse, CMUI_Toolbar.Control_Alignment_Left);
	elseif self.myObject &lt;&gt; null and self.myObject.isKindOf(CM_EWSActivityOpsview) then // ### TFS 51853 27AUG2021 NAVAB1
		toolbar.addButton(self.btnUnformatted, CMUI_Toolbar.Control_Alignment_Left); // ### TFS 51853 27AUG2021 NAVAB1
		self.unformatted := true; // ### TFS 51853 27AUG2021 NAVAB1
	elseif self.myObject &lt;&gt; null and self.myObject.isKindOf(CM_CamTaskHistory) or self.myObject.isKindOf(CM_EDIFile) then
		if not self.isXMLResponse /* Request/Raw/Internal */ then
			self.btnExportRequest.picture := app.myRoot.getConfig("picExport").Binary;
			toolbar.addButton(self.btnExportRequest, CMUI_Toolbar.Control_Alignment_Left);
		else
			self.btnExportResponse.picture := app.myRoot.getConfig("picExport").Binary;
			toolbar.addButton(self.btnExportResponse, CMUI_Toolbar.Control_Alignment_Left);
		endif;
	elseif self.myXMLString &lt;&gt; null then													// TFS 47653
		if self.isXMLRequest then															// TFS 47653
			toolbar.addButton(self.btnExportRequest, CMUI_Toolbar.Control_Alignment_Left);	// TFS 47653
		endif;
		if self.isXMLResponse then															// TFS 47653
			toolbar.addButton(self.btnExportResponse, CMUI_Toolbar.Control_Alignment_Left);	// TFS 47653
		endif;
	elseif self.clearFormattingOnly then
		toolbar.addButton(self.btnUnformatted, CMUI_Toolbar.Control_Alignment_Left);
	endif;
	
	toolbar.addButton(self.btnCancelBase, CMUI_Toolbar.Control_Alignment_Right);
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
