    </JadeMethod>
    <JadeMethod name="updateQueueEntry" id="62acf692-8700-4d5d-84bc-e081845b6dc3">
        <updating/>
        <source>updateQueueEntry(	_rtQueueEntry : CM_RTQueueEntry;
					
					_reloadTable : Boolean) : Integer updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 Aug 2010	cnwer1	Initial creation
07 Dec 2010 cnwer1	PAR 26511  - 1090 exception
24 Jan 2020 cnwma1	Bug 48273: PEN - 1309 when refreshing (old) VMT
*/

vars
	row,
	removedAtRow: Integer;
	invalidObject : Boolean;
	offsetForOldQueue,
	removedQueueRow,
	oldRow			: Integer;
	newDTOEntry,
	dtoRTQueueEntry : DTO_RTQueueEntry;
	newIndex : Integer;
	reloadTable,
	alwaysAdd				: Boolean;
	currentQueue	: CM_RadioTelemetryQueue;
	oldDtoQueueAndEntries,
	newDtoQueueAndEntries: DTO_QueueAndRTEntries;
	_startOffset : Integer;
begin
	on Exception do app.handleDeletedObject(exception,_rtQueueEntry,invalidObject);
	
	if _rtQueueEntry &lt;&gt; null then       //24.01.2020 cnwma1 #48273
		currentQueue:=_rtQueueEntry.myQueue;
	endif;
	
	if invalidObject then
		
		currentQueue:=self.findQueueByQEntry(_rtQueueEntry);
	endif;
	
	if currentQueue = null then
		return 0 ;
	endif;
	
	row:=1;
	
	self.getDTOEntryAndRow(_rtQueueEntry,dtoRTQueueEntry,oldDtoQueueAndEntries,row);
		
	removedAtRow:=0;
	
	_startOffset:=self.getQueueOffset(currentQueue);
	newDtoQueueAndEntries:=self.allOrderedQueueAndEntries[currentQueue];
	if dtoRTQueueEntry &lt;&gt; null then
		
		removedAtRow:=row;
		
		offsetForOldQueue:=self.getQueueOffset(oldDtoQueueAndEntries.myQueue);
		removedQueueRow:= row-offsetForOldQueue;
		oldDtoQueueAndEntries.allDTORTQueueEntries.removeAt(removedQueueRow);
		delete dtoRTQueueEntry;
	else
		//epr par 26511 7/12/10
		if newDtoQueueAndEntries = null then
			return 0;
		endif;
				

		row :=newDtoQueueAndEntries.allDTORTQueueEntries.size + _startOffset;
		
	endif;
		
	if invalidObject then
		return removedAtRow;
	endif;

	if not self.myVMAgent.queryDisplayRTEntry(_rtQueueEntry) then
		if removedAtRow &lt;&gt; null then
			return removedAtRow;
		else
			return 0;
		endif;
	endif;
	
	reloadTable:=false;
	if removedQueueRow &lt;&gt; 0 and newDtoQueueAndEntries = oldDtoQueueAndEntries then
		oldRow:=removedQueueRow;
	elseif oldDtoQueueAndEntries = null  then
		oldRow:=newDtoQueueAndEntries.allDTORTQueueEntries.size;
	else
		oldRow:=1;
	endif;
	
	newIndex:=self.getIndexForRTQueueEntry(newDtoQueueAndEntries,_rtQueueEntry,oldRow,reloadTable);
		
	//epr par 21996
	if reloadTable then
		return 0;
	endif;
	
	
	alwaysAdd:=self.alwaysDisplayRTQueueEntry(_rtQueueEntry);

	if not alwaysAdd and
		(self.maxDisplayEntries &lt;&gt; null and newIndex &gt; maxDisplayEntries) then
		return 0;
	endif;
	
	newDTOEntry:=self.createDTO_RTQueueEntry(_rtQueueEntry);
	
	//epr JBL got 1090 below with newDTOEntry is null can only assume that is because _rtQueueEntry is now null even
	// though we had checked this previously
	if invalidObject then
		return removedAtRow;
	endif;
	
	if removedAtRow &lt;&gt; 0  then
		newDTOEntry.oldRow:=removedAtRow;
	endif;

	if newIndex &gt; 0 and newIndex &lt;= newDtoQueueAndEntries.allDTORTQueueEntries.size then
		newDtoQueueAndEntries.allDTORTQueueEntries.insert(newIndex,newDTOEntry);
	else
		newIndex:=newDtoQueueAndEntries.allDTORTQueueEntries.size+1;
		newDtoQueueAndEntries.allDTORTQueueEntries.add(newDTOEntry);
	endif;
	
	self.allNewDTOEntries.add(newDTOEntry);
	
	newIndex:=newIndex + _startOffset;
	if newIndex = 0 then
		return removedAtRow;
	endif;
	
	//epr par 25043 19/7/10
	if removedAtRow = 0 then
		return newIndex;
	endif;
	return newIndex.min(removedAtRow);

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_rtQueueEntry" type="CM_RTQueueEntry"/>
        <Parameter name="_reloadTable" type="Boolean"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
</Class>
