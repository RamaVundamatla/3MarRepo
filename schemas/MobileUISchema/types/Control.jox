    <JadeMethod name="translateCaption" id="a2db6f4c-fe9d-4b3a-a7e6-8ac1bd4df882">
        <updating/>
        <source>translateCaption(_id: Integer; _locale: CM_Locale) updating;
//08 January 2010	conkc1


vars
	translation	: XLAT_Translation;
begin

	translation := app.zGetTranslatedText(XLAT_FormCaptions, _id);
	if translation &lt;&gt; null then
		self.setCaptionForTranslation(translation.text);
	endif;
epilog

end;</source>
        <Parameter name="_id" type="Integer"/>
        <Parameter name="_locale" type="CM_Locale"/>
    </JadeMethod>
</GUIClass>
