    <JadeWebServicesMethod name="getConsignees" id="5a3e2f32-daec-4249-9833-3b2ff7f5c9e0">
        <usesRPC>default</usesRPC>
        <source>getConsignees(consigneesRequest : WS_ConsigneesRequest) : WS_ConsigneesResponse webService;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
23 July 2008	cnwkpd1	PAR #17554 - Development of new RIA Web Service application

*/


vars
	response		: WS_ConsigneesResponse;
	completedOK		: Boolean;
	
	cons			: CM_ConsigneeConsignor;
	proxyCons		: WS_ConsigneeConsignor;
	
	failedDAC		: CM_DataAccessController;
	passport		: CM_Passport;
	
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);

	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
	
	passport := app.myPassport;
	
	// Populate Validate response - cloned from CMUI_ComboConsignors
	foreach cons in app.myRoot.allConsigneeConsignors discreteLock do
		if not (cons.isFreightFwdr and consigneesRequest.includeFreightForwarders or
				cons.isConsignee and consigneesRequest.includeConsignees or 
				cons.isConsignor and consigneesRequest.includeConsignors) then
			continue;
		endif;		

		if not cons.canUserAccessSelf(null, failedDAC, passport) then
			continue;
		endif;
		
		if cons.isNotAvailableForEntry then
			continue;
		endif;
		
		create proxyCons transient;
		proxyCons.setProxyFromObject(cons);
		response.allConsignees.add(proxyCons);
	endforeach;

	
	// Got to here, everything is ok
	completedOK := true;
	return response;
	

epilog
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
	
end;</source>
        <wsdlName>getConsignees</wsdlName>
        <Parameter name="consigneesRequest" type="WS_ConsigneesRequest"/>
        <ReturnType type="WS_ConsigneesResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="getConsigneesForSearch" id="79705f35-7ea3-4465-89e8-33596f10ab4d">
        <usesRPC>default</usesRPC>
        <source>getConsigneesForSearch() : WS_ConsigneesResponse webService;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 September 2008	cnwkao1	Initial creation

*/

vars
	consRequest : WS_ConsigneesRequest;
begin
	create consRequest transient;
	consRequest.includeConsignees			:= true;
	consRequest.includeConsignors			:= false;
	consRequest.includeFreightForwarders	:= false; //why not
	return self.getConsignees(consRequest);
	
	
epilog
	delete consRequest;
	
end;</source>
        <wsdlName>getConsigneesForSearch</wsdlName>
        <ReturnType type="WS_ConsigneesResponse"/>
    </JadeWebServicesMethod>
