    <JadeMethod name="setupThumbnailDetails" id="f0120a7d-458a-4722-9249-67fb9f7c89f6">
        <updating/>
        <source>setupThumbnailDetails() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20/07/2009	cnwml2	Initial creation
20/05/2015	cnwdap1	PAR #36206 TFS 324/334 Graphical Representation for Special Stow - special lift used to share special stow's ent table def
*/

vars

	theForm : SOP_TableMaintForm;
begin
  
  	theForm := self.myForm;
	theForm.useProxyObject := true;
	
	//theForm.setTblDataEntRows(ETDef_SpecialStowMaint);				// PAR #36206
	theForm.setTblDataEntRows(ETDef_SpecialLiftMaint);					// PAR #36206
	//12/01/2011 cnwdz2 25840
	//theForm.zClearSortColumns();
	//theForm.zAddSortColumn(ETRow_Code, false);

	theForm.shtTblInput1.caption := 'Details';
	//theForm.initTblInput(theForm.tblInput1, ETDef_SpecialStowMaint);	// PAR #36206
	theForm.initTblInput(theForm.tblInput1, ETDef_SpecialLiftMaint);	// PAR #36206
	theForm.shtTblInput1.visible := true;

	theForm.mulSelect1.formDisplayEntryMethodName := null;
	theForm.mulSelect2.formDisplayEntryMethodName := null;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="showThumbnail" id="cbbac998-0ea4-4e37-ad51-b0318b8eb468">
        <updating/>
        <source>showThumbnail(pSpecialLift : CM_SpecialLift) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 July 2009	cnwml2	Initial creation

*/

vars
	theForm : SOP_TableMaintForm;
begin
  
    theForm := self.myForm;
	theForm.tblInput1.clearValues;

	theForm.tblInput1.setValueByName(ETRow_Code, pSpecialLift.code);
	theForm.tblInput1.setValueByName(ETRow_Description,	pSpecialLift.description);

epilog

end;</source>
        <Parameter name="pSpecialLift" type="CM_SpecialLift"/>
    </JadeMethod>
</Class>
