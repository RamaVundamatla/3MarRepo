    <JadeMethod name="trxUpdateStagedTis" id="dae47ecd-960b-47ca-9362-323f3e9634a7">
        <updating/>
        <source>trxUpdateStagedTis(_reserveDetail : CM_ReserveSelection input; _tarLoc : CM_LocationsController; _tiSet : CM_TISet; _term : CM_Terminal; _passport : CM_Passport input)updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 Jan 2023 navhl20 ChangeRequest 58760:[61583] EUP | VAS Mobile App - [53813.050] VAS Tasks for Release Cargo Work Order

*/

vars
	moveController		: CMIF_MoveController;
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);


	app.setContinueCMExceptions(false);

	beginTransaction;
	
	if _tarLoc &lt;&gt; null then
		create moveController transient;
		moveController.setMyTrackedItem(_tiSet.first);	
		moveController.setAllOtherTrackedItems(_tiSet);
		moveController.allOtherTrackedItems.remove(moveController.myTrackedItem);
		moveController.setMyToPrimaryLocation(_tarLoc);
		moveController.setMoveMode(REAL_MODE);

		if _tarLoc.isKindOf(CM_VoyageController) then
			moveController.isNonCraneVoyageMove := true;
		endif;
		
		app.myUtilityUA.utlUpdateMoveTrackedItem(moveController, _passport);
	endif;

	app.myUtilityUA.utlUpdateStagedTis(_reserveDetail, _tiSet, _term, _passport);
	
	if _passport.noErrors then
		_passport.doDeferredUpdates();	
	endif;
epilog
	self.finaliseActivityWithPassport(_passport);
	delete moveController;
end;</source>
        <Parameter name="_reserveDetail" type="CM_ReserveSelection" usage="input"/>
        <Parameter name="_tarLoc" type="CM_LocationsController"/>
        <Parameter name="_tiSet" type="CM_TISet"/>
        <Parameter name="_term" type="CM_Terminal"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
