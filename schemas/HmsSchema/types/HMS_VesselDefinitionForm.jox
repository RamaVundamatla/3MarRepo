    <JadeMethod name="tblBasicDimension_keyPress" id="301a04e1-f273-4c73-a344-e9353a7f65df">
        <controlMethod name="Table::keyPress"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblBasicDimension_keyPress(table: Table input; keyCode: Integer io) updating;

vars

begin

    // Move cursor down current column if ENTER key is pressed
	if keyCode=13 and tblBasicDimension.row&lt;tblBasicDimension.rows then
		// Deselect current row
		tblBasicDimension.column:=1;
		tblBasicDimension.selected:=false;
		tblBasicDimension.column:=3;
		tblBasicDimension.selected:=false;
		tblBasicDimension.column:=2;
		tblBasicDimension.selected:=false;
		// Select next row down
		tblBasicDimension.row:=tblBasicDimension.row+1;
		// Highlight new row
		tblBasicDimension.rowColumnChg(tblBasicDimension);


		tblBasicDimension.refreshNow;
	elseif keyCode=13 and tblBasicDimension.row=tblBasicDimension.rows then
	// Highlight first row of TblKeyDistances if ENTER key is pressed on last row of tblBasicDimension
		// Deselect current row
		tblBasicDimension.clearAllSelected;

		// Select first row of TblKeyDistances
		tblKeyDistances.row:=2;
		tblKeyDistances.column:=1;
		tblKeyDistances.selected:=true;
		tblKeyDistances.column:=3;
		tblKeyDistances.selected:=true;
		tblKeyDistances.column:=2;
		tblKeyDistances.selected:=true;
		tblKeyDistances.setFocus;
	endif;




end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="keyCode" type="Integer" usage="io"/>
    </JadeMethod>
