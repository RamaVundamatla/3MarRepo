    <JadeMethod name="hasInvoices" id="4ae791e5-68f9-44e1-9958-16b22f3d4026">
        <source>hasInvoices() : Boolean;
// ---------------------------------------------------------------------------
// Created:     22 May 2009 by cnwab1
//
// Changed On   	Changed By  	Reason
