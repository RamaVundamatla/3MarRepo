    <JadeMethod name="setMeasurementValue" id="0f6c698d-2a67-4a95-8aff-811678854d7a">
        <updating/>
        <source>setMeasurementValue(_entRowName: String; _value: Decimal) updating;
/*
Purpose:			Set the object attribute identified by _entRowName to the _value supplied

Parameters:			

Return Value:		

Date		Who		Reason
05/03/2013	cnwdap1	Initial creation PAR #31155 CCMS SFW 1321 Imperial Measurements
*/
vars
	prop : Property;
begin
	//epr TFS 41398 20/2/19 stop the errors
	prop:=self.class.getPropertyInHTree(_entRowName);
	if prop = null then
		return;
	endif;
	
	self.setPropertyValue(_entRowName, _value);
epilog

end;</source>
