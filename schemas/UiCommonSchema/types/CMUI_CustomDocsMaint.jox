    <JadeMethod name="buildCmbCustomAgent" id="4fdbdc7c-457f-4549-b90b-c54dcc81228a">
        <source>buildCmbCustomAgent();
/*
Purpose:			

Date		Who		Reason
11AUG2023	NAVAB1	 CR 59614 TASK 59619
*/

vars
	custAgent : CM_CustomsAgent;
begin
	self.cmbCustomsAgent.clear();
	
	foreach custAgent in app.myRoot.allCustomsAgents discreteLock do
		if not custAgent.isNotAvailableForEntry then
            self.cmbCustomsAgent.addItemObject(custAgent.code &amp;  Tab &amp; custAgent.name, custAgent);
        endif;
    endforeach;
	if self.myCustomDocument &lt;&gt; null then
		custAgent := self.myCustomDocument.myCustomsAgent;
		if custAgent &lt;&gt; null
		and self.cmbCustomsAgent.findObject(custAgent) &lt; 0 then
            self.cmbCustomsAgent.addItemObject(custAgent.code &amp;  Tab &amp; custAgent.name, custAgent);
		
		endif;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="buildCmbDirection" id="0ad3bcad-9f3f-490b-9011-213126924452">
        <source>buildCmbDirection(_custDocType : CM_CustomDocumentType);
/*
Purpose:			

Date		Who		Reason
11AUG2023	NAVAB1	 CR 59614 TASK 59619
*/

vars

begin

	self.cmbDirection.clear();
	
	if _custDocType&lt;&gt; null then
		if _custDocType.direction = CM_CustomDocumentType.CustDocTypeDir_Inward then
			self.cmbDirection.addItemWithData(CM_CustomDocumentType.CustDocTypeDirStr_Inward,CM_CustomDocumentType.CustDocTypeDir_Inward);
			self.cmbDirection.listIndex := 1;
		elseif _custDocType.direction = CM_CustomDocumentType.CustDocTypeDir_Outward then
			self.cmbDirection.addItemWithData(CM_CustomDocumentType.CustDocTypeDirStr_Outward,CM_CustomDocumentType.CustDocTypeDir_Outward);
			self.cmbDirection.listIndex := 1;
		else
			self.cmbDirection.addItemWithData(CM_CustomDocumentType.CustDocTypeDirStr_Inward,CM_CustomDocumentType.CustDocTypeDir_Inward);
			self.cmbDirection.addItemWithData(CM_CustomDocumentType.CustDocTypeDirStr_Outward,CM_CustomDocumentType.CustDocTypeDir_Outward);
		endif;
	else
		self.cmbDirection.addItemWithData(CM_CustomDocumentType.CustDocTypeDirStr_Both,CM_CustomDocumentType.CustDocTypeDir_Both);
		self.cmbDirection.addItemWithData(CM_CustomDocumentType.CustDocTypeDirStr_Inward,CM_CustomDocumentType.CustDocTypeDir_Inward);
		self.cmbDirection.addItemWithData(CM_CustomDocumentType.CustDocTypeDirStr_Outward,CM_CustomDocumentType.CustDocTypeDir_Outward);
	
	endif;
epilog

end;</source>
        <Parameter name="_custDocType" type="CM_CustomDocumentType"/>
    </JadeMethod>
    <JadeMethod name="buildCmbDocType" id="f86dfd6f-40dc-4faf-8ecf-27e68c2169d6">
        <source>buildCmbDocType(_prevDocType : CM_CustomDocumentType io);
/*
Purpose:			

Date		Who		Reason
11AUG2023	NAVAB1	 CR 59614 TASK 59619
29/08/2023	navkc1	CR 59556  Task 59593: UI - Cust Docs Auto Id
*/

vars
	docType : CM_CustomDocumentType;
begin
	self.cmbDocType.clear();
	

	if _prevDocType &lt;&gt; null then
		foreach docType in _prevDocType.allNextDocumentTypes do
			if not docType.notAvailForEntry then
				self.cmbDocType.addItemObject(docType.code &amp;  Tab &amp; docType.description, docType);
			endif;
		endforeach;
	
	else
		foreach docType in self.myTerminal.allCustomDocumentTypes do
			if docType.notAvailForEntry then
				continue;
			endif;
			
			// only show those that are the start of the process
			if docType.allPrevDocumentTypes.isNotEmpty() then
				continue;
			endif;
			
			self.cmbDocType.addItemObject(docType.code &amp;  Tab &amp; docType.description, docType);
		endforeach;
	endif;

	if self.myCustomDocument &lt;&gt; null then
		docType := self.myCustomDocument.myCustomDocumentType;
		if docType &lt;&gt; null
		and self.cmbDocType.findObject(docType) &lt; 0 then
			self.cmbDocType.addItemObject(docType.code &amp;  Tab &amp; docType.description, docType);
		
		endif;
	endif;
	
	if self.cmbDocType.listCount = 1 then
		self.cmbDocType.listIndex := 1;
		_prevDocType := self.cmbDocType.listObject.CM_CustomDocumentType;
	endif;
	
	//29/08/2023	navkc1	CR 59556  Task 59593
	self.doCheckDocTypeIsAutoId(self.cmbDocType.listObject.CM_CustomDocumentType);
epilog

end;</source>
        <Parameter name="_prevDocType" type="CM_CustomDocumentType" usage="io"/>
    </JadeMethod>
    <JadeMethod name="buildCmbHSCode" id="674c4199-b0ba-4f0c-93d6-4a5ae48f6196">
        <source>buildCmbHSCode();
/*
Purpose:			

Date		Who		Reason
11AUG2023	NAVAB1	 CR 59614 TASK 59619
*/

vars
	hsCode : CM_HarmonizedSystem;
begin
	self.cmbHSCodes.clear();
	
	foreach hsCode in app.myRoot.allHSCodesActive discreteLock do
		if not hsCode.notAvailableForEntry then
            self.cmbHSCodes.addItemObject(hsCode.id &amp;  Tab &amp; hsCode.description, hsCode);
        endif;
    endforeach;
	
	if self.myCustomDocument &lt;&gt; null then
		hsCode := self.myCustomDocument.myHSCode;
		if hsCode &lt;&gt; null
		and self.cmbHSCodes.findObject(hsCode) &lt; 0 then
            self.cmbHSCodes.addItemObject(hsCode.id &amp;  Tab &amp; hsCode.description, hsCode);
		
		endif;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="buildCmbLicense" id="44b6d11f-093f-42f3-8da4-ea1a99c9c933">
        <source>buildCmbLicense(_custDocType : CM_CustomDocumentType);
/*
Purpose:			

Date		Who		Reason
11AUG2023	NAVAB1	 CR 59614 TASK 59619
01/09/2023	navkc1	CR 59937 Task 59941: UI - Default Custom License Based on Cargo Location
*/

vars
	docLicense : CM_CustomLicense;
	setDefaultLicense : Boolean;
	firstTi		: CM_TrackedItem;
	terminalArea: CM_TerminalArea;
	defaultLicense : CM_CustomLicense;
	defaultIndex	: Integer;
	
begin
	self.cmbLicense.clear();
	
	//01/09/2023	navkc1	CR 59937 Task 59941
	setDefaultLicense := self.myTerminal.getConfig(DefaultCustDocLicense).Boolean;
	
	firstTi := self.getFirstTi();
	if firstTi &lt;&gt; null then
		terminalArea := firstTi.myTerminalArea;
		if terminalArea &lt;&gt; null then
			defaultLicense := terminalArea.myCustomLicense;
		endif;
	endif;
	
	if _custDocType&lt;&gt; null then
		foreach docLicense in _custDocType.allCustomLicenses do
			if not docLicense.notAvailForEntry then
				self.cmbLicense.addItemObject(docLicense.code &amp;  Tab &amp; docLicense.description, docLicense);
			endif;
		endforeach;
	else
		foreach docLicense in self.myTerminal.allCustomLicenses do
			if not docLicense.notAvailForEntry then
				self.cmbLicense.addItemObject(docLicense.code &amp;  Tab &amp; docLicense.description, docLicense);
			endif;
		endforeach;
	endif;
	
	if self.myCustomDocument &lt;&gt; null then
		docLicense := self.myCustomDocument.myCustomLicense;
		if docLicense &lt;&gt; null
		and self.cmbLicense.findObject(docLicense) &lt; 0 then
			self.cmbLicense.addItemObject(docLicense.code &amp;  Tab &amp; docLicense.description, docLicense);
		
		endif;
	endif;
	
	//01/09/2023	navkc1	CR 59937 Task 59941 - we set it only if custom doc type is slected, and the terminal config says to default a license
	if self.cmbDocType.listIndex &gt; 0 and setDefaultLicense then
		if self.cmbLicense.listCount = 1 then
			self.cmbLicense.listIndex := 1;
			
		//01/09/2023	navkc1	CR 59937 Task 59941
		else
			defaultIndex := self.cmbLicense.findObject(defaultLicense);
			if defaultIndex &gt; 0 then
				self.cmbLicense.listIndex := defaultIndex;
			endif;
		endif;
	endif;
	
epilog

end;</source>
        <Parameter name="_custDocType" type="CM_CustomDocumentType"/>
    </JadeMethod>
