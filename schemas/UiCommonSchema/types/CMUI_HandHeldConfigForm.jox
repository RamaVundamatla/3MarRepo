    <JadeMethod name="loadDataFromObject" id="f206ae4b-bbf4-4a1d-bfed-2c7e74abf8a0">
        <updating/>
        <source>loadDataFromObject(_object : Object) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 October 2016	cnwndl1	Initial creation	TFS 2850 / 2370

*/

vars

	hhConfig : CM_HandHeldConfig;

begin

	if _object.isKindOf( CM_Terminal ) then
		self.lblMainInfo.caption := _object.CM_Terminal.name;
	endif;
	
	//find the saved off config and load it
	hhConfig := self.myTerminal.getHandHeldConfig( null );
	
	self.loadHandHeldConfig(hhConfig);
	
epilog

end;</source>
        <Parameter name="_object" type="Object"/>
    </JadeMethod>
    <JadeMethod name="loadHandHeldConfig" id="4df50a8a-1070-425f-bc3f-3444a7f0b2c1">
        <source>loadHandHeldConfig( _hhConfig : CM_HandHeldConfig );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 October 2016	cnwndl1	Initial creation	TFS 2850 / 2370

*/

vars

	entTableDef : EntTableDef;
	entRow : EntTableRow;
	index : Integer;
	group : EntTableGroup;

begin

	self.mulSearchCrit.myAvailableListBox.clear();
	self.mulSearchCrit.mySelectedListBox.clear();
	
	entTableDef := app.myRoot.myEntTableDataRoot.getEntTableDef(ETDef_HandHeldFind);
	if entTableDef = null then
		return;
	endif;
	
	//set up all the available ones.
	foreach entRow in entTableDef.allEntTableRows do	
		index := self.mulSearchCrit.myAvailableListBox.addItem( self.displayEntryCriteria(entRow) );
		self.mulSearchCrit.myAvailableListBox.itemObject[index] := entRow;
	endforeach;	
	
	if _hhConfig &lt;&gt; null then	
		foreach entRow in _hhConfig.allVisibleSearchRows do
			if entTableDef.allEntTableRows.getEntRowNamed( entRow.name ) = null then
				// Row no longer available.
				continue;
			endif;
			index := self.mulSearchCrit.mySelectedListBox.findStringExact( 1, entRow.getRawHeadingValue);
			if index &lt; 1 then
				index := self.mulSearchCrit.mySelectedListBox.addItem( self.displayEntryCriteria(entRow) );
				self.mulSearchCrit.mySelectedListBox.itemObject[index] := entRow;
				index := self.mulSearchCrit.myAvailableListBox.findStringExact( 1, entRow.getRawHeadingValue);
				if index &gt; 0 then
					self.mulSearchCrit.myAvailableListBox.removeItem( index );
				endif;
			endif;
		endforeach;
	endif;

	self.addCompulsorySearchCriteria( false, _hhConfig );

	
	
	self.mulResultsCol.myAvailableListBox.clear();
	self.mulResultsCol.mySelectedListBox.clear();
	
	entTableDef := app.myRoot.myEntTableDataRoot.getEntTableDef(ETDef_CargoQuickViewHandHeld);
	if entTableDef = null then
		return;
	endif;
	
	//set up all the available ones.
	foreach entRow in entTableDef.allEntTableRows do
		index := self.mulResultsCol.myAvailableListBox.addItem( self.displayEntryCriteria(entRow) );
		self.mulResultsCol.myAvailableListBox.itemObject[index] := entRow;
	endforeach;	
	
	if _hhConfig &lt;&gt; null then	
		foreach entRow in _hhConfig.allVisibleResultsCols do
			if entTableDef.allEntTableRows.getEntRowNamed( entRow.name ) = null then
				// Row no longer available.
				continue;
			endif;
			index := self.mulResultsCol.mySelectedListBox.findStringExact( 1, entRow.getRawHeadingValue);
			if index &lt; 1 then
				index := self.mulResultsCol.mySelectedListBox.addItem( self.displayEntryCriteria(entRow) );
				self.mulResultsCol.mySelectedListBox.itemObject[index] := entRow;
				index := self.mulResultsCol.myAvailableListBox.findStringExact( 1, entRow.getRawHeadingValue);
				if index &gt; 0 then
					self.mulResultsCol.myAvailableListBox.removeItem( index );
				endif;
			endif;
		endforeach;
	endif;

	self.addCompulsoryResultCols( false);
	
	
	//07 Dec 2016	NDL	TFS 3008 / 2370
	self.mulViewTable.myAvailableListBox.clear();
	self.mulViewTable.mySelectedListBox.clear();
	
	group := app.myRoot.myEntTableDataRoot.allEntTableGroups.getAtKey(ETGrp_CargoDetails);
	if group = null then
		return;
	endif;
	
	//set up all the available ones.
	foreach entRow in group.allEntTableRowsByName do
		//skip the duplicates
		if entRow.name = ETRow_BolCombo 
		or entRow.name = ETRow_ProductType
		or entRow.name = ETRow_UpdateConsignee
		or entRow.name = ETRow_LengthCM
		or entRow.name = ETRow_DimTypeText
		or entRow.name = ETRow_DimType
		or entRow.name = ETRow_ReleaseCargoType
		or entRow.name = ETRow_UpdateRemarks
		or entRow.name = ETRow_WidthCM
		or entRow.name = ETRow_Quantity
		then
			continue;
		endif; 
		index := self.mulViewTable.myAvailableListBox.addItem( self.displayEntryCriteria(entRow) );
		self.mulViewTable.myAvailableListBox.itemObject[index] := entRow;
	endforeach;	
	
	if _hhConfig &lt;&gt; null then	
		foreach entRow in _hhConfig.allVisibleViewRows do
			if  group.allEntTableRowsByName.getAtKey( entRow.name ) = null then
				// Row no longer available.
				continue;
			endif;
			index := self.mulViewTable.mySelectedListBox.findStringExact( 1, entRow.getRawHeadingValue);
			if index &lt; 1 then
				index := self.mulViewTable.mySelectedListBox.addItem( self.displayEntryCriteria(entRow) );
				self.mulViewTable.mySelectedListBox.itemObject[index] := entRow;
				index := self.mulViewTable.myAvailableListBox.findStringExact( 1, entRow.getRawHeadingValue);
				if index &gt; 0 then
					self.mulViewTable.myAvailableListBox.removeItem( index );
				endif;
			endif;
		endforeach;
	endif;

	self.addCompulsoryViewRows( false );

epilog

end;</source>
        <Parameter name="_hhConfig" type="CM_HandHeldConfig"/>
    </JadeMethod>
    <JadeMethod name="lstObject_click" id="300e1cdc-25bf-4259-98cf-179aec8ea8a5">
        <controlMethod name="CMUI_ListBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>lstObject_click(listbox: ListBox input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 October 2016	cnwndl1	Initial creation	TFS 2850 / 2370

*/

vars
	obj : Object;
begin
	if listbox.listIndex &gt; 0 then
		self.loadDataFromObject( listbox.itemObject[listbox.listIndex]);
	endif;
epilog

end;</source>
        <Parameter name="listbox" type="ListBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="resetButtons" id="111b5a3d-fb21-45fb-bf3d-06e0d4b3f731">
        <source>resetButtons();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 October 2016	cnwndl1	Initial creation	TFS 2850 / 2370

*/

vars

	canMaintain : Boolean;
	hhConfig : CM_HandHeldConfig;

begin

	canMaintain := app.myCurrentUserCan(self.myTerminal, self.permissionMaint);

	if self.fldDetails.topSheet = self.shtSettings then
		self.btnDelete.enabled := false;
	else
		hhConfig := self.myTerminal.getHandHeldConfig( null );
		if hhConfig &lt;&gt; null then
			self.btnDelete.enabled := canMaintain;
		else
			self.btnDelete.enabled := false;
		endif;
	endif;
	
	self.btnSave.enabled := canMaintain;
	
	self.btnDelete.visible := false; // At the moment this is not required because only allowed one per terminal.

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="10e9d97b-1012-40e3-ac39-85b64333d1bc">
        <updating/>
        <source>setupForm() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 October 2016	cnwndl1	Initial creation	TFS 2850 / 2370

*/

vars

	

begin

	self.minimumHeight := 550;
	self.minimumWidth := 750;

	inheritMethod();
	
	self.setupMultiSelectLists();
	
	self.setupLstObject();
	self.lstObject.listIndex := 1;
	self.lstObject.click(self.lstObject);
	
	self.setupGeneralHHSettingsTable();
	
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.tblHHSettings.enabled := false;
		self.mulSearchCrit.enabled:= false;
		self.mulResultsCol.enabled:= false;
		self.mulViewTable.enabled:= false;	//07 Dec 2016	NDL	TFS 3008 / 2370
	endif;
	
	self.resetButtons();

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupGeneralHHSettingsTable" id="d1dc0e10-818f-4f9e-b6b6-01c101fa67c0">
        <source>setupGeneralHHSettingsTable();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 October 2016	cnwndl1	Initial creation	TFS 2850 / 2370
//28 Nov 2016	cnwrs1	TFS 2866 use new HH config matchFindCargoConsignee
17 May 2017	cnwma1		TFS 3933:STWO - Vehicle Lander - Process Button and Truck Loader Complete Button
*/

vars

	entTableDef : EntTableDef;
	entRow : EntTableRow;
	
	delayTypeGroup	: CM_DelayTypeGroup;
	hhLanderGroundingOpt : Integer;
	int : Integer;
	
	toDoTask : CM_ToDoTaskDesc;
	railHHToDoTaskDesc : String;
	hhTruckLoadScan : Integer;
	
begin

	self.tblHHSettings.top := 1;
	self.tblHHSettings.left := 1;
	self.tblHHSettings.width := self.tblHHSettings.parent.width - 2;
	self.tblHHSettings.height := self.tblHHSettings.parent.height - 2;
	self.tblHHSettings.parentAspect := 3; // Strech both ways

	self.tblHHSettings.warningMethod := 'entTableWarning';
	self.tblHHSettings.optimiseRowHeight := true;
	entTableDef := app.myController.getEntTableDef(	ETDef_TermHHConfig );
	self.tblHHSettings.setEntTableDef(entTableDef, null, 'entTableDefSetupWarning');
	self.tblHHSettings.changeMode := CM_EntryTable.ChangeMode_FirstOnly;
	
	int := self.tblHHSettings.getRowByName(ETRow_ZTableBreak5);
	if int &gt; 0 then
		self.tblHHSettings.accessCell(int,1).fontBold := true;
	endif;
	int := self.tblHHSettings.getRowByName(ETRow_ZTableBreak7);
	if int &gt; 0 then
		self.tblHHSettings.accessCell(int,1).fontBold := true;
	endif;
	int := self.tblHHSettings.getRowByName(ETRow_ZTableBreak12);
	if int &gt; 0 then
		self.tblHHSettings.accessCell(int,1).fontBold := true;
	endif;
	
//	create tmpConfig transient;
//	tmpConfig.setFromPersistentData(self.myTerminal);
	
	foreach entRow in entTableDef.allEntTableRows do
		if entRow.name = ETRow_ZTableBreak5 then
			continue;
		endif;
		if entRow.name = ETRow_ZTableBreak7 then
			continue;
		endif;
		if entRow.name = ETRow_ZTableBreak12 then
			continue;
		endif;
	
		if entRow.name = ETRow_AllowLoadMoreCargo then
			self.tblHHSettings.setValueByName(entRow.name, self.myTerminal.getConfig(AllowLoadMoreCargo).Boolean);
		elseif entRow.name = ETRow_AllowPackMoreCargo then
			self.tblHHSettings.setValueByName(entRow.name, self.myTerminal.getConfig(AllowPackMoreCargo).Boolean);
	
		elseif entRow.name = ETRow_AllowMobileRoadExit then
			self.tblHHSettings.setValueByName(entRow.name, self.myTerminal.getConfig(AllowMobileRoadExit).Boolean); //08/09/2017 TFS#6864 cnwma1
		
		elseif entRow.name = ETRow_AllowUnloadMoreCargo then
			self.tblHHSettings.setValueByName(entRow.name, self.myTerminal.getConfig(AllowUnloadMoreCargo).Boolean);
		elseif entRow.name = ETRow_AllowUnpackMoreCargo then
			self.tblHHSettings.setValueByName(entRow.name, self.myTerminal.getConfig(AllowUnpackMoreCargo).Boolean);
		elseif entRow.name = ETRow_HhDelayTypeGroup then
			delayTypeGroup := self.myTerminal.getConfig(HhDelayTypeGroup).CM_DelayTypeGroup;
			self.myAssistant.comboBoxDelayTypeGroup(self.cmbDelayTypeGrp, delayTypeGroup);
			self.tblHHSettings.setValueByName(entRow.name, self.cmbDelayTypeGrp.text);
		elseif entRow.name = ETRow_HhLanderGroundingOpt then
			hhLanderGroundingOpt := self.myTerminal.getConfig(HhLanderGroundingOpt).Integer;
			self.myAssistant.comboBoxLanderGrounding(self.cmbGrounding);
			self.tblHHSettings.setValueByName( ETRow_HhLanderGroundingOpt, app.hhGroundingEnumToString(hhLanderGroundingOpt) );		
			int := self.cmbGrounding.findStringExact( 1, app.hhGroundingEnumToString(hhLanderGroundingOpt) );
			self.cmbGrounding.listIndex := int;
		elseif entRow.name = ETRow_HhHideTitleBarButtons then // TFS 3809
			self.tblHHSettings.setValueByName(entRow.name, self.myTerminal.getConfig(HhHideTitleBarButtons).Boolean); // TFS 3809
		elseif entRow.name = ETRow_HhErrorBeeps then // 17 May 2017	NDL	TFS 4460
			self.tblHHSettings.setValueByName(entRow.name, self.myTerminal.getConfig(HhErrorBeeps).Boolean);	
		elseif entRow.name = ETRow_HhIncludeHazDet then // 30 May 2017	NDL	TFS 4587
			self.tblHHSettings.setValueByName(entRow.name, self.myTerminal.getConfig(HhIncludeHazDet).Boolean);	
		elseif entRow.name = ETRow_HhMoveConfirmation then
			self.tblHHSettings.setValueByName(entRow.name, self.myTerminal.getConfig(HhMoveConfirmation).Boolean);
		elseif entRow.name = ETRow_HhTruckLoadConfComplete then  // 17/05/2017 cnwma1 TFS #3933
			self.tblHHSettings.setValueByName(entRow.name, self.myTerminal.getConfig(HhTruckLoadConfComplete).Boolean);
		elseif entRow.name = ETRow_HhMoveHideNonSplit then	//02 Mar 2017	NDL	TFS 3298
			self.tblHHSettings.setValueByName(entRow.name, self.myTerminal.getConfig(HhMoveHideNonSplit).Boolean);
		elseif entRow.name = ETRow_HhTaskUseFullDesc then
			self.tblHHSettings.setValueByName(entRow.name, self.myTerminal.getConfig(HhTaskUseFullDesc).Boolean);
		elseif entRow.name = ETRow_HhTruckLoadBolId then	//17 Jul 2017	NDL	TFS 5408
			self.tblHHSettings.setValueByName(entRow.name, self.myTerminal.getConfig(HhTruckLoadBolId).Boolean);
		elseif entRow.name = ETRow_HhTruckLoadScan then
		//	self.tblHHSettings.setValueByName(entRow.name, self.myTerminal.getConfig(HhTruckLoadScan).Boolean);
			//16 Dec 2016	NDL	TFS 3129
			hhTruckLoadScan := self.myTerminal.getConfig(HhTruckLoadScan).Integer;
			self.myAssistant.comboBoxTruckLoadScan(self.cmbScanning);
			self.tblHHSettings.setValueByName( HhTruckLoadScan, app.hhScanningEnumToString(hhTruckLoadScan) );		
			int := self.cmbScanning.findStringExact( 1, app.hhScanningEnumToString(hhTruckLoadScan) );
			self.cmbScanning.listIndex := int;
		//11 May 2017	NDL	TFS 4016
		elseif entRow.name = ETRow_UseAltSelectRulesTL then
			self.tblHHSettings.setValueByName(entRow.name, self.myTerminal.getConfig(UseAltSelectRulesTL).Boolean);
			
		elseif entRow.name = ETRow_RailHHAlwaysCargoFullID then
			self.tblHHSettings.setValueByName(entRow.name, self.myTerminal.getConfig(RailHHAlwaysCargoFullID).Boolean);
		elseif entRow.name = ETRow_RailHHCargoMustPrenote then
			self.tblHHSettings.setValueByName(entRow.name, self.myTerminal.getConfig(RailHHCargoMustPrenote).Boolean);
		elseif entRow.name = ETRow_RailHHAlwaysWagonFullID then
			self.tblHHSettings.setValueByName(entRow.name, self.myTerminal.getConfig(RailHHAlwaysWagonFullID).Boolean);	
		elseif entRow.name = ETRow_RailHHWagonUseReversedID then
			self.tblHHSettings.setValueByName(entRow.name, self.myTerminal.getConfig(RailHHWagonUseReversedID).Boolean);	
		elseif entRow.name = ETRow_RailHHWarnPrenoteHazDiff then
			self.tblHHSettings.setValueByName(entRow.name, self.myTerminal.getConfig(RailHHWarnPrenoteHazDiffer).Boolean);
		elseif entRow.name = ETRow_IgnoreFindCargoConsignee then
			self.tblHHSettings.setValueByName(entRow.name, self.myTerminal.getConfig(IgnoreHHFindCargoConsignee).Boolean);
		elseif entRow.name = ETRow_HhUnPackQtyPreFill then	//10 Feb 2017	NDL	TFS 3022
			self.tblHHSettings.setValueByName(entRow.name, self.myTerminal.getConfig(HhUnPackQtyPreFill).Boolean);
		elseif entRow.name = ETRow_HhSpreadButtons then	//17 Feb 2017	NDL	TFS 3387/3006
			self.tblHHSettings.setValueByName(entRow.name, self.myTerminal.getConfig(HhSpreadButtons).Boolean);
		elseif entRow.name = ETRow_RailHHToDoTask then
			toDoTask := self.myTerminal.getConfig(RailHHToDoTask).CM_ToDoTaskDesc;
			if toDoTask &lt;&gt; null then
				railHHToDoTaskDesc := toDoTask.description;
			endif;
			self.tblHHSettings.setValueByName(entRow.name, railHHToDoTaskDesc);
			self.myAssistant.comboBoxToDoTasks(self.cmbRailToDo, toDoTask);
		elseif entRow.name = ETRow_DischargeHHLanderOption then
			int := self.myTerminal.getConfig(DischargeHHLanderOption).Integer;
			self.myAssistant.comboBoxDischargeHHOptions(self.cmbDisHHLandOpt);
			self.cmbDisHHLandOpt.setIndexForItemData(int);
			self.tblHHSettings.setValueByName(ETRow_DischargeHHLanderOption,self.cmbDisHHLandOpt.text);
		elseif entRow.name = ETRow_UseRelReqAnyVoyLoad then	//16 Jul 2018	NDL	TFS 38679
			self.tblHHSettings.setValueByName(entRow.name, self.myTerminal.getConfig(UseRelReqAnyVoyLoad).Boolean);
		elseif entRow.name = ETRow_HhTUnloadEdit then	//27Aug 2018	NDL	TFS 39769
			self.tblHHSettings.setValueByName(entRow.name, self.myTerminal.getConfig(HhTUnloadEdit).Boolean);
		elseif entRow.name = ETRow_HhTruckLoadByLocn then	//05 Sep 2018	NDL	TFS 39950
			self.tblHHSettings.setValueByName(entRow.name, self.myTerminal.getConfig(HhTruckLoadByLocn).Boolean);
		elseif entRow.name = ETRow_HhAllowLoadUnloaded then	//25 Oct 2018	NDL	TFS 41240
			self.tblHHSettings.setValueByName(entRow.name, self.myTerminal.getConfig(HhAllowLoadUnloaded).Boolean);
		else
			write entRow.name &amp; " has not been coded for in " &amp; method.qualifiedName;
		endif; 
	endforeach;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupLstObject" id="a508b537-5b88-486f-bdb3-a3844d4f6bb5">
        <source>setupLstObject();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 October 2016	cnwndl1	Initial creation	TFS 2850 / 2370

*/

vars

	idx : Integer;

begin

	idx := self.lstObject.addTreeObject(self.myTerminal.code,self.myTerminal,1,true);
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupMultiSelectLists" id="a75b18d9-2869-4445-9103-bb9d9b4dd12b">
        <source>setupMultiSelectLists();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 October 2016	cnwndl1	Initial creation	TFS 2850 / 2370

*/

vars

	entTableDef : EntTableDef;
	group : EntTableGroup;

begin

	//All relates to MOB_HHCargoFind 
	//ETGrp_TrackedItemDetails  //ETDef_ContEnqFind
	
	entTableDef:=app.myRoot.myEntTableDataRoot.getEntTableDef(ETDef_HandHeldFind);
	self.mulSearchCrit.myAvailableListBox.sorted:=true;
	self.mulSearchCrit.mySelectedListBox.sorted:=false;
	self.mulSearchCrit.setupControl(app.getErrorString(Search_criteria), entTableDef.allEntTableRows, CMUI_HandHeldConfigForm::displayEntryCriteria.name);
	self.mulSearchCrit.setVisibleButtons(true,true,true);
	self.mulSearchCrit.myBaseForm := self;
	
	//ETGrp_TrackedItemDetails  //ETDef_CargoQuickViewHandHeld
	entTableDef:=app.myRoot.myEntTableDataRoot.getEntTableDef(ETDef_CargoQuickViewHandHeld);
	self.mulResultsCol.myAvailableListBox.sorted:=true;
	self.mulResultsCol.mySelectedListBox.sorted:=false;
	self.mulResultsCol.setupControl(app.getErrorString(Results_data_columns), entTableDef.allEntTableRows, CMUI_HandHeldConfigForm::displayEntryCriteria.name);
	self.mulResultsCol.setVisibleButtons(true,true,true);
	self.mulResultsCol.myBaseForm := self;
	
	//07 Dec 2016	NDL	TFS 3008 / 2370
	group := app.myRoot.myEntTableDataRoot.allEntTableGroups.getAtKey(ETGrp_CargoDetails);
	self.mulViewTable.myAvailableListBox.sorted:=true;
	self.mulViewTable.mySelectedListBox.sorted:=false;
	self.mulViewTable.setupControl(app.getErrorString(View_item_table), group.allEntTableRowsByName, CMUI_HandHeldConfigForm::displayEntryCriteria.name);
	self.mulViewTable.setVisibleButtons(true,true,true);
	self.mulViewTable.myBaseForm := self;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="skipToAttribute" id="e843ccc6-008a-43c4-ba76-88c8a2a7b846">
        <updating/>
        <source>skipToAttribute(_attributeName: String; _shtName: String) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 October 2016	cnwndl1	Initial creation

*/

vars

	rowIndex : Integer;
	text : String;

begin
	
	if _attributeName &lt;&gt; null then
		foreach rowIndex in 1 to self.tblHHSettings.rows do
			text := self.tblHHSettings.getCellText(rowIndex,1);
			if text = _attributeName then
				self.tblHHSettings.accessRow(rowIndex).selected := true;
				return;
			endif;
		endforeach;
	endif;

epilog

end;</source>
        <Parameter name="_attributeName" type="String"/>
        <Parameter name="_shtName" type="String"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="47a442ae-acb4-45a3-add6-fafae319c41e">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 15 December 2016 08:52:11.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0021527, locale);
	btnCancel.translateCaption(Xlat_0021528, locale);
	btnDelete.translateCaption(Xlat_0021529, locale);
	btnSave.translateCaption(Xlat_0021530, locale);
	lblCargoEnq.translateCaption(Xlat_0021531, locale);
	lblMainInfo.translateCaption(Xlat_0021532, locale);
	lblResults.translateCaption(Xlat_0021533, locale);
	lblViewTable.translateCaption(Xlat_0021565, locale);
	shtResultsCols.translateCaption(Xlat_0021534, locale);
	shtSearchCrit.translateCaption(Xlat_0021535, locale);
	shtSettings.translateCaption(Xlat_0021536, locale);
	shtViewTable.translateCaption(Xlat_0021566, locale);
end;</source>
    </JadeMethod>
    <JadeMethod name="updateCMIFConfigFromForm" id="3e9ad549-6791-4663-9733-2105802c8af8">
        <source>updateCMIFConfigFromForm(_cmif : CMIF_ConfigTerminal input) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 October 2016	cnwndl1	Initial creation
//28 Nov 2016	cnwrs1	TFS 2866 use new HH config matchFindCargoConsignee
17 May 2017	cnwma1	TFS 3933:STWO - Vehicle Lander - Process Button and Truck Loader Complete Button
*/

vars

	obj : Object;
	entRow : EntTableRowTransient;

begin

	foreach obj in self.tblHHSettings.allEntRowTransients do
		entRow := obj.EntTableRowTransient;
		if entRow.name = ETRow_ZTableBreak5 then
			continue;
		endif;
		if entRow.name = ETRow_ZTableBreak7 then
			continue;
		endif;
		if entRow.name = ETRow_ZTableBreak12 then
			continue;
		endif;
		
		if entRow.name = ETRow_AllowLoadMoreCargo then
			_cmif.allowLoadMoreCargo := self.tblHHSettings.getValueByName(ETRow_AllowLoadMoreCargo).Boolean;
		elseif entRow.name = ETRow_AllowPackMoreCargo then
			_cmif.allowPackMoreCargo := self.tblHHSettings.getValueByName(ETRow_AllowPackMoreCargo).Boolean;
		elseif entRow.name = ETRow_AllowUnloadMoreCargo then
			_cmif.allowUnloadMoreCargo := self.tblHHSettings.getValueByName(ETRow_AllowUnloadMoreCargo).Boolean;
		elseif entRow.name = ETRow_AllowUnpackMoreCargo then
			_cmif.allowUnpackMoreCargo := self.tblHHSettings.getValueByName(ETRow_AllowUnpackMoreCargo).Boolean;
		elseif entRow.name = ETRow_AllowMobileRoadExit then
			_cmif.allowMobileRoadExit := self.tblHHSettings.getValueByName(ETRow_AllowMobileRoadExit).Boolean; //08/09/2017 TFS#6864 cnwma1	
		elseif entRow.name = ETRow_HhDelayTypeGroup then
			_cmif.hhDelayTypeGroup := self.cmbDelayTypeGrp.listObject.CM_DelayTypeGroup;
		elseif entRow.name = ETRow_HhLanderGroundingOpt then
			if self.cmbGrounding.listIndex &gt; 0 then
				_cmif.hhLanderGroundingOpt := self.cmbGrounding.itemData[self.cmbGrounding.listIndex];
			else
				_cmif.hhLanderGroundingOpt := 0;
			endif;
		elseif entRow.name = ETRow_HhHideTitleBarButtons then // TFS 3809
			_cmif.hhHideTitleBarButtons := self.tblHHSettings.getValueByName(ETRow_HhHideTitleBarButtons).Boolean; // TFS 3809
		elseif entRow.name = ETRow_HhErrorBeeps then // 17 May 2017	NDL	TFS 4460
			_cmif.hhErrorBeeps := self.tblHHSettings.getValueByName(ETRow_HhErrorBeeps).Boolean; 
		elseif entRow.name = ETRow_HhIncludeHazDet then // 30 May 2017	NDL	TFS 4587
			_cmif.hhIncludeHazDet := self.tblHHSettings.getValueByName(ETRow_HhIncludeHazDet).Boolean; 
		elseif entRow.name = ETRow_HhMoveConfirmation then
			_cmif.hhMoveConfirmation := self.tblHHSettings.getValueByName(ETRow_HhMoveConfirmation).Boolean;
		elseif entRow.name = ETRow_HhTruckLoadConfComplete then  // 17/05/2017 cnwma1 TFS #3933
			_cmif.hhTruckLoadConfComplete := self.tblHHSettings.getValueByName(ETRow_HhTruckLoadConfComplete).Boolean;
		elseif entRow.name = ETRow_HhMoveHideNonSplit then	//02 Mar 2017	NDL	TFS 3298
			_cmif.hhMoveHideNonSplit := self.tblHHSettings.getValueByName(ETRow_HhMoveHideNonSplit).Boolean;
		elseif entRow.name = ETRow_HhTaskUseFullDesc then
			_cmif.hhTaskUseFullDesc := self.tblHHSettings.getValueByName(ETRow_HhTaskUseFullDesc).Boolean;
		elseif entRow.name = ETRow_HhTruckLoadBolId then	//17 Jul 2017	NDL	TFS 5408
			_cmif.hhTruckLoadBolId := self.tblHHSettings.getValueByName(ETRow_HhTruckLoadBolId).Boolean;
		elseif entRow.name = ETRow_HhTruckLoadScan then
			//_cmif.hhTruckLoadScan := self.tblHHSettings.getValueByName(ETRow_HhTruckLoadScan).Boolean;
			if self.cmbScanning.listIndex &gt; 0 then	//19 Dec 2016	NDL	TFS 3129
				_cmif.hhTruckLoadScan := self.cmbScanning.itemData[self.cmbScanning.listIndex];
			else
				_cmif.hhTruckLoadScan := 0;
			endif;
		//11 May 2017	NDL	TFS 4016
		elseif entRow.name = ETRow_UseAltSelectRulesTL then
			_cmif.useAltSelectRulesTL := self.tblHHSettings.getValueByName(ETRow_UseAltSelectRulesTL).Boolean;
		
		elseif entRow.name = ETRow_RailHHAlwaysCargoFullID then
			_cmif.railHHAlwaysCargoFullID := self.tblHHSettings.getValueByName(ETRow_RailHHAlwaysCargoFullID).Boolean;
		elseif entRow.name = ETRow_RailHHCargoMustPrenote then
			_cmif.railHHCargoMustPrenote := self.tblHHSettings.getValueByName(ETRow_RailHHCargoMustPrenote).Boolean;
		elseif entRow.name = ETRow_RailHHAlwaysWagonFullID then
			_cmif.railHHAlwaysWagonFullID := self.tblHHSettings.getValueByName(ETRow_RailHHAlwaysWagonFullID).Boolean;
		elseif entRow.name = ETRow_RailHHWagonUseReversedID then
			_cmif.railHHWagonUseReversedID := self.tblHHSettings.getValueByName(ETRow_RailHHWagonUseReversedID).Boolean;
		elseif entRow.name = ETRow_RailHHWarnPrenoteHazDiff then
			_cmif.railHHWarnPrenoteHazDiffer := self.tblHHSettings.getValueByName(ETRow_RailHHWarnPrenoteHazDiff).Boolean;
		elseif entRow.name = ETRow_DischargeHHLanderOption then
			_cmif.dischargeHHLanderOption := self.cmbDisHHLandOpt.listData;
		elseif entRow.name = ETRow_RailHHToDoTask then
			_cmif.railHHToDoTask := self.cmbRailToDo.listObject.CM_ToDoTaskDesc;
		elseif entRow.name = ETRow_IgnoreFindCargoConsignee then
			_cmif.ignoreHHFindCargoConsignee := self.tblHHSettings.getValueByName(ETRow_IgnoreFindCargoConsignee).Boolean;
		elseif entRow.name = ETRow_HhUnPackQtyPreFill then	//10 Feb 2017	NDL	TFS 3002
			_cmif.hhUnPackQtyPreFill := self.tblHHSettings.getValueByName(HhUnPackQtyPreFill).Boolean;
		elseif entRow.name = ETRow_HhSpreadButtons then	//16 Feb 2017	NDL	TFS 3387/3006
			_cmif.hhSpreadButtons := self.tblHHSettings.getValueByName(HhSpreadButtons).Boolean;
//		8/9/17 MAP TFS6818 - move to voyage config
//		elseif entRow.name = ETRow_HhShowUnplanOptions then
//			_cmif.hhShowUnplanOptions := self.tblHHSettings.getValueByName(ETRow_HhShowUnplanOptions).Boolean;
		elseif entRow.name = ETRow_UseRelReqAnyVoyLoad then	//16 Jul 2018	NDL	TFS 38679
			_cmif.useRelReqAnyVoyLoad := self.tblHHSettings.getValueByName(UseRelReqAnyVoyLoad).Boolean;
		elseif entRow.name = ETRow_HhTUnloadEdit then	//27 Aug 2018	NDL	TFS 39769
			_cmif.hhTUnloadEdit := self.tblHHSettings.getValueByName(HhTUnloadEdit).Boolean;
		elseif entRow.name = ETRow_HhTruckLoadByLocn then	//05 Sep 2018	NDL	TFS 39950
			_cmif.hhTruckLoadByLocn := self.tblHHSettings.getValueByName(HhTruckLoadByLocn).Boolean;
		elseif entRow.name = ETRow_HhAllowLoadUnloaded then	//25 Oct 2018	NDL	TFS 41240
			_cmif.hhAllowLoadUnloaded := self.tblHHSettings.getValueByName(HhAllowLoadUnloaded).Boolean;
		else
			write entRow.name &amp; " has not been coded for in " &amp; method.qualifiedName;
		endif; 
	endforeach;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_cmif" type="CMIF_ConfigTerminal" usage="input"/>
    </JadeMethod>
</GUIClass>
