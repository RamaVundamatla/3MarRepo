    <JadeMethod name="setMyCurrentVoyage" id="2c7c4c7f-5ad4-4955-8587-962289dc38c5">
        <updating/>
        <source>setMyCurrentVoyage(_voyage : CM_Voyage; _resetBaySelector, _resetHoldSelector : Boolean) updating, protected;
// ---------------------------------------------------------------------------
// Created:     18 August 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	oldVoyage,
	newVoyage		: CM_Voyage;
	tmpEDIEvent		: Integer;
begin

	oldVoyage := self.myCurrentVoyage;

	if oldVoyage = _voyage then
		return;
	endif;
	
	if self.myCCPalette &lt;&gt; null then //and app.isValidObject(self.myCCPalette) then 
		self.myCCPalette.unloadForm();
		self.myCCPalette := null;
	endif;
	//24 Jan 2012	NDL	Par 28896
	if self.myCCPaletteLoad &lt;&gt; null then 
		self.myCCPaletteLoad.unloadForm();
		self.myCCPaletteLoad := null;
	endif;
	if self.myCCScreen &lt;&gt; null then // and app.isValidObject(self.myCCScreen) then 
		self.myCCScreen.unloadForm();
		self.myCCScreen := null;
	endif;
	
	if _voyage &lt;&gt; null
	and _voyage.myCellularVoyageStructure = null then
		newVoyage := null;
	else
		newVoyage := _voyage;
	endif;
	
	tmpEDIEvent := self.myTerminal.getTerminalEvent(Voyage_NewEDI_Event);

	if oldVoyage &lt;&gt; null then
		self.myBayDrawingController.clear();
		self.endNotification(oldVoyage, tmpEDIEvent);
	endif;

	if newVoyage = null then
		// set details to null
		self.myCurrentVoyage := null;
		self.cmbVoyage.listObject := null;
		self.cmbBayVoyage.listObject := null;
		self.initSelectorControlsForVoyage(null, true, true);
		return;
	endif;
	
	// setup details for new voyage
	
	self.myCurrentVoyage := newVoyage;
	self.myBayDrawingController.setFromVoyage(newVoyage);
	self.btnActual.value := true;

	if self.cmbVoyage.listObject &lt;&gt; newVoyage and
	   self.cmbVoyage.findObject(newVoyage) &gt; 0 then
		self.cmbVoyage.listObject := newVoyage;
	endif;
	
	if self.cmbBayVoyage.listObject &lt;&gt; newVoyage and
	   self.cmbBayVoyage.findObject(newVoyage) &gt; 0 then
		self.cmbBayVoyage.listObject := newVoyage;
	endif;
	
	self.initSelectorControlsForVoyage(newVoyage, _resetBaySelector, _resetHoldSelector);

	self.allSelectedBays.clear();
	self.allSelectedHolds.clear();

	// we always switch to actual when displaying a new voyage
	if self.displayMode &lt;&gt; ShpDisplayMode_Actual then
		// need to update buttons, etc
		self.switchDisplayMode(ShpDisplayMode_Actual, false);
	endif;

	//cnwjo3 par 23105
	if app.getMyCurrentVoyage() &lt;&gt; newVoyage then
		app.setMyCurrentVoyage(newVoyage);
	endif;
	// 28605 Nov 2011 cnwjre1 enable RORO plan button only if RORO voyage
	self.btnRoRoDeckDef.enabled := (newVoyage.myROROStructure &lt;&gt; null);
	
	self.setCaptionForModes(self.displayMode);

	self.beginNotification(_voyage, tmpEDIEvent, Response_Continuous, null);

end;</source>
        <access>protected</access>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_resetBaySelector" type="Boolean"/>
        <Parameter name="_resetHoldSelector" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setObjFromTblPreferSpecial" id="0d2b36a3-8c31-4adc-b0a9-1719b616f6b8">
        <source>setObjFromTblPreferSpecial(_attrName: String; _value: String; _obj: Object input; _tbl: CM_EntryTable input): Boolean;
// ---------------------------------------------------------------------------
// Created:     20 May 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin

	if _attrName = ETRow_ShipDischCCShowOthers or
	   _attrName = ETRow_ShipLoadCCShowOthers or
	   _attrName = ETRow_ShipLoadJobShowOthers or
	   _attrName = ETRow_ShipLoadPlanShowOthers or
	   _attrName = ETRow_ShipLoadSeqShowOthers then
		_obj.setPropertyValue(_attrName, app.shipShowOtherColorStrToNum(_value));
		return true;
	endif;

	return inheritMethod(_attrName, _value, _obj, _tbl);

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_value" type="String"/>
        <Parameter name="_obj" type="Object" usage="input"/>
        <Parameter name="_tbl" type="CM_EntryTable" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setSelector" id="34fe3cd5-67f1-4255-9c94-b77fc5d00778">
        <updating/>
        <source>setSelector(_theSelector: CMUI_Selector input) updating, protected;
// ---------------------------------------------------------------------------
// Created:		June 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars

begin
	inheritMethod(_theSelector);
	_theSelector.myDefaultVoyage := self.myCurrentVoyage;
	_theSelector.defaultSiteStr := TI_SITE_ONSHIP_str;
end;</source>
