    <JadeMethod name="validateForDelete" id="9c335f47-08c0-4705-b78e-f167cf2c2b65">
        <source>validateForDelete();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29/11/2022 navmv20 TFS CR 55299 TASK 55516: Jade - Write TRX for new file category
*/

vars

begin
	if self.allFileData.isNotEmpty then
        app.raiseCMException1(ERR_CANT_DEL_FILE_CATEGORY,self.code,null,null);
    endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="e3676f8d-97f3-447b-b35d-97ea19f62f1b">
        <source>validateForUpdate();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29/11/2022 navmv20 TFS CR 55299 TASK 55516: Jade - Write TRX for new file category
02 Jan 2023 navtnr20 	TFS CR 56058 Task 56059: Jade - Contracts - New File Category
28/07/2023	navkc1		Bug 59320: EUP - COO - File Category Context
*/

vars
	extingFileDataCategory,
	realFileDataCategory    : CM_FileDataCategory;
begin
	if self.code = null then
        app.raiseCMException(Input_required_field_code, ETRow_Code, self);
    endif;
	
	if not (self.categoryContext = FileCategoryContext_CargoType or
	self.categoryContext =  FileCategoryContext_Contracts or //navtnr20 02-01-2023 TFS 56059
	self.categoryContext = FileCategoryContext_Invoice or
	self.categoryContext = FileCategoryContext_Other or
	self.categoryContext = FileCategoryContext_Voyage or
	self.categoryContext = FileCategoryContext_WorkOrder or
	self.categoryContext = FileCategoryContext_OwnrChg or //28/07/2023	navkc1	Bug 59320
	self.categoryContext = FileCategoryContext_CustDoc // ### TFS CR 56094 TASK 59618 10AUG2023 NAVAB1
	) then
		app.raiseCMException(Input_require_context_field, ETRow_Context,self);
	endif;
	
	realFileDataCategory	:= self.pxyGetRealObject();
	
	extingFileDataCategory := app.myRoot.allFileDataCategories[self.code]; // ### TFS CR 55299 TASK 55985 28DEC2022 NAVAB1
	
	if extingFileDataCategory &lt;&gt; null  // ### TFS CR 55299 TASK 55985 28DEC2022 NAVAB1
	and self.code = extingFileDataCategory.code 
	and (realFileDataCategory  = null 
		or extingFileDataCategory &lt;&gt; realFileDataCategory )	then
		app.raiseCMException1(File_categor_already_exists, self.code, null, null); 
	endif;	
epilog

end;</source>
    </JadeMethod>
</Class>
