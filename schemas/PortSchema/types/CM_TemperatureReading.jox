<Class name="CM_TemperatureReading" id="b3241406-30f7-4ae0-8a0a-71fb3777963c">
    <superclass name="CM_TITransaction"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="tempread"/>
    <ExplicitInverseRef name="myTempReading" id="1683a0e8-d639-40f7-8e41-d2f6c563d8be">
        <updateMode>manual</updateMode>
        <embedded/>
