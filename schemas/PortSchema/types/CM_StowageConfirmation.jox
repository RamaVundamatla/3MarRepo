    <JadeMethod name="getConfirmationType" id="75bf7f43-dff2-431c-bcad-d2a6e5b1ee96">
        <source>getConfirmationType() : String;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 February 2012	cnwdw1	Initial creation
*/
vars
begin
	if self.isLoad then
		return app.getErrorString(CM_Load);
	else
		return app.getErrorString(CM_Discharge);
	endif;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="3409a60b-efed-490b-a26f-1d3270482964">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 November 2011	cnwer1	Initial creation CCMS MES 1033

*/

vars
	details : String;
	invalid , isDischarge: Boolean;
begin
	if _attrName = ETRow_Details  then
		if self.deleted then
			return self.getDeletedDetails();		// 15/10/18 MAP TFS41191
		else
			if self.myVoyageJob &lt;&gt; null
			or self.isForVoyage then // ### TFS CR 56806 TASK 56807 01MAR2023 NAVAB1
				details := self.getConfirmationType() &amp; "- " &amp; app.getErrorString(Confirmed_Location) &amp; Space &amp; self.confirmedLocation;
				if self.confirmedLocation &lt;&gt; self.plannedLocation 
				and self.plannedLocation&lt;&gt; null then // ### TFS CR 56806 TASK 56807 01MAR2023 NAVAB1
					details := details &amp; Space &amp; "(" &amp; app.getErrorString(CM_Planned_Location) &amp; Space &amp; self.plannedLocation &amp; ")";
				endif;
			else
				details := app.getErrorString1(Confirmed_yard_location, self.confirmedLocation);
			endif;

			return details;
		endif;
	elseif _attrName = ETRow_Job then
		return self.jobId;
	elseif _attrName = ETRow_Voyage then
		return self.voyageCode;
	elseif _attrName = ETRow_PlannedLocation then
		return self.plannedLocation;
	elseif _attrName = ETRow_ConfirmedLocation then
		return self.confirmedLocation;
	elseif _attrName = ETRow_StowageType then
		return self.getConfirmationType;
	elseif _attrName = ETRow_Remarks then // 23 Feb 2022 navlw1 TFS #52827
		return self.remarks;
	else
		return inheritMethod(_attrName, _short);
	endif;

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
