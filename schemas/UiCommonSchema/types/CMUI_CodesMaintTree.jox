    <JadeMethod name="handle14025" id="ebafdd92-f591-470b-b7b7-317607f49697">
        <source>handle14025(_exc : Exception; _tooManyLines : Boolean io) : Integer protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 June 2013	cnwndl1	Initial creation

*/

vars

	returnVal		: Integer;

begin

	returnVal := Ex_Pass_Back;
	
	if _exc.errorCode = 14025 then
		if _exc.errorObject = self.lstData then
			_tooManyLines := true;
			if _exc.resumable then
				returnVal := Ex_Resume_Next;
			endif;
		endif;
	endif;

epilog

	return returnVal;

end;</source>
        <access>protected</access>
        <Parameter name="_exc" type="Exception"/>
        <Parameter name="_tooManyLines" type="Boolean" usage="io"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
