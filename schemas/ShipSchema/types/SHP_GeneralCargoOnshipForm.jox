end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doMnuCargoLabelPrint" id="e394693d-f209-44bd-9317-91846b55ed05">
        <source>doMnuCargoLabelPrint();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
26 April 2010	cnwmh5	Initial creation PAR 23821

*/

vars
	tiArray	: CM_ObjectArrayActual;
	obj 	: Object;
	table	: CM_DataTable;
begin

	// select which table we actually want to print for
	if self.tblBOLItems.selected then
		table := self.tblBOLItems;
	elseif self.tblCargo.selected then
		table := self.tblCargo;
	else
		return;
	endif;
		
	create tiArray transient;
	foreach obj in table.allSelectedObjects do
		if obj.isKindOf(CM_TrackedItem) then
			tiArray.add(obj.CM_TrackedItem);
		endif;
	endforeach;

	if self.mnuCargoLabelPrint.userObject &lt;&gt; null then
		if not tiArray.includes(self.mnuCargoLabelPrint.userObject.CM_TrackedItem) then
			tiArray.add( self.mnuCargoLabelPrint.userObject.CM_TrackedItem );
		endif;
	endif;
	
	if tiArray.isEmpty then
		return;
	endif;
	
	self.myAssistant.showCargoIdLabelPrintForm(tiArray);
	
epilog

	delete tiArray;
	
end;</source>
    </JadeMethod>
