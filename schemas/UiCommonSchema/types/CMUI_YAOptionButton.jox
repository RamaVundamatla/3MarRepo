<GUIClass name="CMUI_YAOptionButton" id="d729d108-8528-4eae-b99a-a8cd426344a0">
    <superclass name="CMUI_OptionButton"/>
    <transient/>
    <sharedTransientAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <access>protected</access>
    <DbClassMap file="_usergui"/>
    <PrimAttribute name="isDisableExpiryDate" id="96d68663-3abb-4ce1-9868-af5bda4b0d4d">
        <embedded/>
        <type name="Boolean"/>
        <access>protected</access>
    </PrimAttribute>
    <PrimAttribute name="isExpiryDate" id="add15ba0-5bbd-4c5c-82ff-20e1eece23d1">
        <embedded/>
        <type name="Boolean"/>
        <access>protected</access>
    </PrimAttribute>
    <PrimAttribute name="isInward" id="04a7a996-e38c-4ae6-9910-434bfa87ac9e">
        <embedded/>
        <type name="Boolean"/>
        <access>protected</access>
    </PrimAttribute>
    <PrimAttribute name="isOutward" id="e2cd2e1c-2fce-4742-b40c-044b4ede5a0a">
        <embedded/>
        <type name="Boolean"/>
        <access>protected</access>
    </PrimAttribute>
    <ImplicitInverseRef name="myYAControl" id="20e235b0-abd0-4988-8f77-3af44bd9e8e2">
        <embedded/>
        <type name="CMUI_YardAllocationControl"/>
        <access>protected</access>
    </ImplicitInverseRef>
    <JadeMethod name="click" id="a9690156-9ebd-46ca-92da-79f424cf1909">
        <controlMethod name="OptionButton::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>click(optionbutton: OptionButton input) updating, clientExecution;
// --------------------------------------------------------------------------------
// Created:		15 March 2005 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	inheritMethod(optionbutton);
	
	if self.isInward and self.value then
		self.myYAControl.populateLocationsListbox(true);
	elseif self.isOutward and self.value then
		self.myYAControl.populateLocationsListbox(false);
	elseif self.isExpiryDate then
		self.myYAControl.doExpiryDateOptClick(self.value);
	elseif self.isDisableExpiryDate then
		self.myYAControl.doExpiryDateOptClick(false);
	endif;
end;</source>
        <Parameter name="optionbutton" type="OptionButton" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setYAControl" id="1621e3f1-b7e2-4e68-a924-e7029500399b">
        <updating/>
        <source>setYAControl(	pYAControl:CMUI_YardAllocationControl;
				pIsIn:Boolean;
				pIsOut:Boolean;
				pIsExpiryDate:Boolean;
				pIsDisableExpiryDate:Boolean) updating;
// --------------------------------------------------------------------------------
// Created:		15 March 2005 by cnwdad1
//
// Purpose:		Sets a reference to the receiver's owing Yard Allocation control.
//
// Parameters:	pYAControl - A reference to the Yard Allocation control.
//				pIsIn - True if the inward list of blocks is to be shown.
//				pIsOut - True if the outward list of blocks is to be shown.
//				pIsExpiryDate - True if the receiver is to enable an Expiry Date.
//				pIsDisableExpiryDate - True if the receiver is to disable an Expiry Date.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.myYAControl			:=	pYAControl;
	self.isInward				:=	pIsIn;
	self.isOutward				:=	pIsOut;
	self.isExpiryDate			:=	pIsExpiryDate;
	self.isDisableExpiryDate	:=	pIsDisableExpiryDate;
end;</source>
        <Parameter name="pYAControl" type="CMUI_YardAllocationControl"/>
        <Parameter name="pIsIn" type="Boolean"/>
        <Parameter name="pIsOut" type="Boolean"/>
        <Parameter name="pIsExpiryDate" type="Boolean"/>
        <Parameter name="pIsDisableExpiryDate" type="Boolean"/>
    </JadeMethod>
