    <JadeMethod name="bCancel_click" id="4e94d7d0-577a-4c4c-a8e1-d73074010266">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>bCancel_click(btn: Button input) updating;

vars

begin

	self.modalResult := -1;		// Non-zero result means failed
	self.unloadForm();

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="bOK_click" id="024f50e7-8a7d-43f2-aed2-8cb821fe74e3">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>bOK_click(btn: Button input) updating;
/*

Date		Who		Reason
20 Oct 2011	cnwkpd1	PAR #28510 - Problems logging on in Windows Mobile 6.5 device
	
*/

vars
 	oldMouse:Integer;
begin
	on Exception do app.normalExceptionHandler(exception);
	oldMouse := app.mousePointer;
	password.setFocus;
	
 	if state = OLD_PASS then
	// Par 13796
		//oldPass := password.text.toUpper;		
		oldPass := password.getPasswordText();		// PAR #28510
		/*
    	if not app.getMyUser.isValidPassword(oldPass) then
			app.msgBox( app.getErrorString(ERR_PASSWORD) , "", MB_OKONLY );
			app.mousePointer := oldMouse;
			app.cmsEndLoad;
			return;
		endif;
		*/
		self.setState(NEW_PASS);
		
 	elseif state = NEW_PASS then
		// Par 13796
 		//newPass := password.text.toUpper;
		newPass := password.getPasswordText();		// PAR #28510
 		/*
 		if newPass.length &gt; 10 then
 			app.msgBox( "Password cannot exceed 10 characters", "New Password Too Long", MB_OKONLY );
			app.mousePointer := oldMouse;
			state := OLD_PASS;		
 			return;
 		endif;
 		*/
		self.setState(REPEAT_PASS);		
		
 	elseif state = REPEAT_PASS then
		
		// Get rid of upper casing outside of trx because of strong password.
	 	//repeatPass := password.text.toUpper;
		repeatPass := password.getPasswordText();		// PAR #28510

		app.myTrxUA.trxUpdatePassword(true, app.getMyUserCode, oldPass, newPass, repeatPass, app.myPassport);
		if app.myPassport.trxCompletedOK then
			self.modalResult := 0;
		 	unloadForm;
		 	return;
		endif;
		
		app.showErrorsAsMsgBox(app.myPassport.allErrorWarnings, app.myPassport.noErrors);
		//app.showErrorWarningDialog('xxx', app.myPassport, false);

		self.setState(OLD_PASS);

/*
	 	if repeatPass &lt;&gt; newPass then
			app.msgBox( app.getErrorString(ERR_PSWDS_DIFFER) , "", MB_OKONLY );
			app.mousePointer := oldMouse;
			state := OLD_PASS;
			return;
	 	endif;
	 	beginTransaction;
		app.myUtilityUA.utlUpdatePassword(app.getMyUser, app.getMyUser.edition, newPass);
	 	app.cmsCommitTransaction(_passport);
*/	 	
	 	
 	endif;

epilog
	app.mousePointer := oldMouse;

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="load" id="56aba067-56b6-4db6-a6bc-6464ef38f11b">
        <controlMethod name="Form::load"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>load() updating;

vars

begin

	self.modalResult := -1;		// Non-zero result means failed

	centreWindow;
	caption := "Change Password";
	self.setState(OLD_PASS);

	app.mousePointer := MousePointer_Default;

end;</source>
    </JadeMethod>
    <JadeMethod name="setState" id="20a7673b-afe6-46a5-9dbf-1039ee9e11a7">
        <updating/>
        <source>setState(pState : Integer) updating;
// ---------------------------------------------------------------------------
// Created:     02 July 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	password.text := "";
	self.state := pState;

	if pState = OLD_PASS then
 		prompt.caption := "Enter Current Password:";

	elseif pState = NEW_PASS then
		prompt.caption := "Enter New Password:";

	elseif pState = REPEAT_PASS then
		prompt.caption := "Retype Password:";
	endif;

end;</source>
        <Parameter name="pState" type="Integer"/>
    </JadeMethod>
</GUIClass>
