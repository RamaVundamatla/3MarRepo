<Class name="WS_NSDSRefEquipment" id="e4a27f8b-ea97-41a9-8ff2-d1c406d859c5">
    <superclass name="WS_NSDSObject"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>DATASET - Yard

Mapping 
MTN : 
N4  : ref_equipment

[gkey]							bigint						NOT NULL,
[eqtyp_gkey]					bigint						NOT NULL,
[id]							character varying			NOT NULL,
[class]							character varying			NOT NULL,	//This field is defined as 'class_namechange' in JADE since 'class' is already defined, this hack is taken care in the producer
[life_cycle_state]				character varying			NOT NULL,</text>
    <DbClassMap file="webservice"/>
    <PrimAttribute name="classStr" id="a76ed52d-dc8c-4126-8500-e11c1ffc1725">
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="class_namechange" id="f9c50ff7-be51-430c-a706-526e8a88c121">
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="eqtyp_gkey" id="27ec1e68-98df-40d4-a98b-30b7e30631ad">
        <embedded/>
        <type name="Integer64"/>
    </PrimAttribute>
    <PrimAttribute name="id" id="ccafe7af-927e-4d7c-8676-72bb01a6f85a">
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="life_cycle_state" id="b5b0c034-8533-4f69-99f7-0bd02b9f95c8">
        <type name="String"/>
    </PrimAttribute>
    <JadeMethod name="setProxyObject" id="fe115384-6e2b-4594-9a60-02611db4d2c1">
        <updating/>
        <source>setProxyObject(_any : Any) updating;

/*
Date		Who		Reason
31 Mar 2022	navra1 	TFS53028 	
*/


vars
	helper 	: CMIF_RefEquipment;
	ewsOpsView: CM_EWSActivityOpsview;
begin
	
	inheritMethod(_any);
	
	create helper transient;
	create ewsOpsView transient;
	ewsOpsView.initialiseActivity("","",_any.CM_Object.getMyTerminal(),_any.CM_Object, null,null,false,null);
	helper.initializeForActivity(_any, ewsOpsView);
	
	self.tableName			:= helper.tableName;	
	self.gkey				:= helper.gkey;	
	self.classStr 			:= helper.classStr;
	self.class_namechange 	:= helper.class_namechange;
	self.eqtyp_gkey 		:= helper.eqtyp_gkey;
	self.id 				:= helper.id;
	self.life_cycle_state 	:= helper.life_cycle_state;
	
epilog
	delete helper;
	delete ewsOpsView;
end;</source>
        <Parameter name="_any" type="Any"/>
    </JadeMethod>
</Class>
