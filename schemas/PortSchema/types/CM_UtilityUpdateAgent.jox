    <JadeMethod name="utlUpdateCGAssignmentId" id="56229846-ce1f-4e36-b84b-b8ca6f64acc9">
        <updating/>
        <source>utlUpdateCGAssignmentId( _pxy : CM_CargoGroupAssignment; _passport : CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 July 2018	jlgndl1	Initial creation	TFS 39186

*/

vars

	real : CM_CargoGroupAssignment;
	expectedEdition : Integer;

begin

	self.initialiseActivity();

	_pxy.raiseExceptionIfNotProxy(method);

	app.setContinueCMExceptions(true);

	_pxy.pxyGetRealObjectAndEdition(real, expectedEdition);
	
	if real = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_CargoGroupAssignment.name, null, null);
		return;
	endif;

	app.myValUA.valCargoGroupAssignment(real, _pxy, _passport);
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);

	exclusiveLock(real);

	if _passport.noErrors and real.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'Cargo Group Assignment', null, null);
		return;
	endif;
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(real, true);
	endif;
	
	if _passport.noErrors then
		real.setId( _pxy.id );
	endif;
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(real, false);
	endif;

epilog

end;</source>
        <Parameter name="_pxy" type="CM_CargoGroupAssignment"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
