    <JadeMethod name="doBtnOKClick" id="440da496-b62f-433e-bc24-7855b4c7455e">
        <updating/>
        <source>doBtnOKClick() updating;
// ---------------------------------------------------------------------------
// Created:		August  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 08/04/2011	cnwmh5		PAR #27347 - Add cmsEndLoad or endLoad to epilog so that if error occurs it will not leave it in beginLoad state
// 17 May 2016	cnwns1		TFS 488 - Multi Timezone Support
// 17/11/2021	navpw1		TFS 52375 POL - Can't set Is Externally Monitored via Reefer Monitoring tab in MTN
// ---------------------------------------------------------------------------

vars	
	connectParams			: CMIF_ConnectParams;
	nowTimeStamp,
	connectTimeStamp,		
	localConTimeStamp		: TimeStamp;
	theTI, theProxyTI,
	proxyCOU				: CM_TrackedItem;
	aDate					: Date;
	aTime					: Time;
	aURNumber				: String;
	aNoCharge 				: Boolean;
	loadState				: Boolean;
	externalMonitor			: Boolean;
	txn						: CM_TITransaction;
	result 					: Integer;
begin
	self.mousePointer := Window.MousePointer_HourGlass;
	if self.allTrackedItems.size = 0 then
		return;
	endif;
	nowTimeStamp := app.actualTimeServer;// 17 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	
	aDate := self.tblData.getValueByName(ETRow_Date).Date;
	aTime := self.tblData.getValueByName(ETRow_Time).Time;
	
	//must be at the end of the minute to pass validation as we only accept input to the minute (no seconds)
	
//	aTime.setTime(aTime.hour, aTime.minute, 59, 999);
	aURNumber := self.tblData.getValueByName(ETRow_UserRequestNumber).String;
	aNoCharge := self.tblData.getValueByName(ETRow_NoCharge).Boolean;
	
	externalMonitor := self.tblData.getValueByName(ETRow_HasExternalMonitoring).Boolean;		//cnwmc5 - 19 Oct 2015 - PAR 37057
	
	if aDate.isValid() and aTime.isValid() then							// 17 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		localConTimeStamp.cnEcSetDateAndTime(aDate,aTime);				// 17 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		connectTimeStamp := self.localToSystemTime(localConTimeStamp);	// 17 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	else																// 17 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		connectTimeStamp := nowTimeStamp;								// 17 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	endif;																// 17 May 2016	cnwns1	TFS 488 - Multi Timezone Support

	create connectParams transient;
	if self.startupMode = self.StarupMode_COU then	//set params.myTrackedItem
	 	app.cmsBeginLoad(loadState);
	 		theProxyTI := self.allTrackedItems[1].pxyCreateUpdateProxy();
		app.cmsEndLoad(loadState);
		
		connectParams.locationsController := theProxyTI.getPrimaryLocation(REAL_MODE);
		if self.action = ACTION_CONNECT then
			// get the OID from the combo box
			self.cmbCOUs.text := self.tblData.getValueByName(ETRow_ClipOnUnitID).String;
		
			app.cmsBeginLoad(loadState);
				proxyCOU := self.cmbCOUs.itemObject[self.cmbCOUs.listIndex].CM_TrackedItem.pxyCreateUpdateProxy();
			app.cmsEndLoad(loadState);
		
			connectParams.myOtherTrackedItem := proxyCOU;
		endif;
		
	else											//set allTrackedItems
		foreach theTI in self.allTrackedItems do
			app.cmsBeginLoad(loadState);
				connectParams.allTrackedItems.add(theTI.pxyCreateUpdateProxy());
			app.cmsEndLoad(loadState);
			
			//check time stamp will be after the last txn on the ti
			//have to do this to prevent on going time comaprison errors introduced
			//with the Time EditMask changes (i.e. uses can't input seconds!)
			txn := theTI.allTransactions.last;
			if txn &lt;&gt; null
			and txn.dateTime &gt; connectTimeStamp then
				if txn.dateTime.date = connectTimeStamp.date
				and txn.dateTime.time.hour = connectTimeStamp.time.hour
				and txn.dateTime.time.minute = connectTimeStamp.time.minute then
					//bump it by 1
					connectTimeStamp.setTime(txn.dateTime.time.addSeconds(1));
				endif;
			endif;
		endforeach;
	endif; 

	connectParams.dateTime := connectTimeStamp;
	connectParams.noCharge := aNoCharge;
	connectParams.myTerminal := self.myTerminal;
	connectParams.editMode := CM_ReeferMtn; // ### TFS 52375 17Nov2021 NAVPW1
	
//	the following is set in the trx when allTrackedItems is used or below for COUs	
//	connectParams.myOtherTrackedItem := self.myTrackedItem.getOtherTrackedItem(self.action);
	connectParams.myTrackedItem := theProxyTI;
	if connectParams.myTrackedItem &lt;&gt; null then
		connectParams.locationsController := connectParams.myTrackedItem.myPrimaryActualLocation; // AKB2004AUG added
	endif;
	connectParams.urNumber := aURNumber;
	connectParams.userId := app.getMyUserCode();
	connectParams.action := self.action;
	connectParams.gapController := self.myPowerPoint;
	connectParams.radioTelemetryIgnoreWarnings := self.chkIgnoreWarning.value;
	connectParams.radioTelemetryUser := false;
	
	connectParams.hasExternalMonitoring := externalMonitor;		//cnwmc5 - 19 Oct 2015 - PAR 37057

	//epr TFS 3581 7/3/17 now will show warnings
	// menus with connect power are towerPower
	while true do
		if self.startupMode = self.StarupMode_TowerPower then
			if self.action = ACTION_CONNECT then
				app.myTrxUA.trxUpdateConnect(connectParams, app.myPassport);	
			else
				app.myTrxUA.trxUpdateDisconnect(connectParams, app.myPassport);	
			endif;
		// menus with attach are COU
		elseif self.startupMode = self.StarupMode_COU then
			//set
			if self.action = ACTION_CONNECT then			
				app.myTrxUA.trxUpdateAttach(connectParams, app.myPassport);	
			else
				app.myTrxUA.trxUpdateDetach(connectParams, app.myPassport);	
			endif;
		endif;
	
		if app.myPassport.trxCompletedOK then
			break;
		else
			result :=app.showErrorWarningDialog('Connect', app.myPassport, ErrWarnMode_Update);	
			if app.myPassport.noErrors and
			   result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		return;
	endwhile;
	

	self.doCancel;

epilog

	app.cmsEndLoad(loadState);		// 08/04/2011 cnwmh5 #27347

	delete theProxyTI;
	delete proxyCOU;
	
	if connectParams &lt;&gt; null then
		connectParams.allTrackedItems.purge(); // proxies
		delete connectParams;
	endif;
	self.mousePointer := Window.MousePointer_Default;
end;</source>
    </JadeMethod>
    <JadeMethod name="doBuildAttachCaption" id="2a4ce31a-7bf0-482c-beb6-88c3cdc72f78">
        <updating/>
        <source>doBuildAttachCaption(_theTI: CM_TrackedItem; _theAction: Integer io): String updating;
// ---------------------------------------------------------------------------
// Created:		11 June 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------
vars

	theContainer : CM_Container;
	theCOU, theCaption : String;
	
begin
	if _theTI &lt;&gt; null then
		if _theTI.isKindOf(CM_Container) then
			theContainer := _theTI.CM_Container;
			if theContainer.isPortHole then
				theCOU := theContainer.couId.trimBlanks;
				if theCOU.trimBlanks = null then
					theCOU := "COU";
				endif;
				if theContainer.hasCOU then
					_theAction := ACTION_DISCONNECT;
					theCaption := theContainer.id &amp; " Dettach From " &amp; theCOU ;
				else
					_theAction := ACTION_CONNECT;
					theCaption := theContainer.id &amp; " Attach To " &amp; theCOU;
				endif;
			endif;
		endif;				
	endif;

	return theCaption;
end;</source>
        <Parameter name="_theTI" type="CM_TrackedItem"/>
        <Parameter name="_theAction" type="Integer" usage="io"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="doBuildCaption" id="f5144b5f-3201-4e82-a471-be968fdb7f1a">
        <updating/>
        <source>doBuildCaption() updating;
// ---------------------------------------------------------------------------
// Created:		August  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	if self.singleTIMode then
		if self.startupMode = self.StarupMode_TowerPower then
			self.caption := self.doBuildConnectCaption(self.allTrackedItems[1],self.action);
		endif;				
		if self.startupMode = self.StarupMode_COU then
			self.caption := self.myTerminal.code &amp; " " &amp; self.doBuildAttachCaption(self.allTrackedItems[1],self.action);
		endif;				
	else
		if self.action = ACTION_CONNECT then
			self.caption := self.myTerminal.code &amp; " Connect";
		else
			self.caption := self.myTerminal.code &amp; " Disconnect";
		endif;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="doBuildComboCOUArea" id="5ab43e28-6d5f-4039-82a2-4bfd339cf32f">
        <updating/>
        <source>doBuildComboCOUArea() updating;
// ---------------------------------------------------------------------------
// Created:		August  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	idx : Integer;
	theFilter		: CMQF_TerminalAreas;
	aTermArea : CM_TerminalArea;
	theQryReport	: CM_QryReport;
	theDataLine : String;
	
begin
	self.mousePointer := Window.MousePointer_HourGlass;
	self.cmbCOUArea.clear();

	theQryReport := app.myRoot.myReportMenuRoot.getReportByConstantValue(CM_RepTerminalArea);
	if theQryReport &lt;&gt; null then	
		create theFilter transient;
		theFilter.allTerminals.add(self.myTerminal);
		theFilter.terminalAreaTypes.add(TA_TYPE_COU_STORE_AREA);
		theFilter.terminalAreaTypes.add(TA_TYPE_COU_CRIB_PACK_UNPACK);
		theQryReport.doFilter(theFilter, app.myPassport);
			
		foreach aTermArea in theFilter.allQryTerminalAreas do
			idx := self.cmbCOUArea.addItem(aTermArea.id);
			self.cmbCOUArea.itemObject[idx] := aTermArea;
		endforeach;
	endif;
epilog
	self.mousePointer := Window.MousePointer_Default;

end;</source>
    </JadeMethod>
    <JadeMethod name="doBuildComboCOUs" id="bf88ebfd-76c9-4894-9c73-270bea390568">
        <updating/>
        <source>doBuildComboCOUs(_theArea : CM_TerminalArea) updating;
// ---------------------------------------------------------------------------
// Created:		August  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	aTrackedItem: CM_TrackedItem;
	aController : CM_LocationsController;
	idx			: Integer;
	iter		: Iterator;
	op			: CM_Operator;
begin

	if self.singleTIMode then	//change this to a mode  SINGLE_TI_MODE
		op := self.allTrackedItems[1].myOperator;
	endif;

	if self.startupMode = StarupMode_COU then
		self.cmbCOUs.clear();
		foreach aController in _theArea.allLocationsControllers do
			foreach aTrackedItem in aController.allTrackedItemsById do
				if aTrackedItem.myCargoType.id = TI_CargoType_COU then
					if op = null or op = aTrackedItem.myOperator then
						idx := self.cmbCOUs.addItem(aTrackedItem.id);
						self.cmbCOUs.itemObject[idx] := aTrackedItem;
					endif;
				endif;
			endforeach;
		endforeach;	
	endif;
end;</source>
        <Parameter name="_theArea" type="CM_TerminalArea"/>
    </JadeMethod>
    <JadeMethod name="doBuildComboCargoType" id="ffe0623a-1467-4e0e-9a4a-f6d3c41d1659">
        <source>doBuildComboCargoType();
// ---------------------------------------------------------------------------
// Created:		August  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	aCargoType : CM_CargoType;
	idx : Integer;
begin

	self.cmbCargoType.clear();
	
	foreach aCargoType in app.myRoot.allCargoTypesById do
		// from 31981 skip not-available-for-entry cargo types
		if aCargoType.isNotAvailableForEntry then
			continue;
		endif;
		if self.myTerminal &lt;&gt; null and not aCargoType.allTerminals.includes(self.myTerminal) then
			continue;
		endif;
			
		idx := cmbCargoType.addItem(aCargoType.description);
		cmbCargoType.itemObject[idx] := aCargoType;
	endforeach;
end;</source>
    </JadeMethod>
    <JadeMethod name="doBuildComboPowerPoints" id="a78c29fe-ccc0-479f-a341-e8f18fe1eb81">
        <updating/>
        <source>doBuildComboPowerPoints(_ti: CM_TrackedItem) updating;
// ---------------------------------------------------------------------------
// Created:		August  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	thePowerPoints : ObjectArray;
	anObject : Object;
	aGapController, closeGap : CM_GapController;
	idx : Integer;
	tiX,tiY,ppX,ppY,gapX, gapY, totalPoints: Integer;
	aGridController : CM_LocationsController;
begin
	ppX := 99999;
	ppY := 99999;
	totalPoints := 999999;
	
	aGridController := _ti.getPrimaryLocation(REAL_MODE);
	if aGridController.isKindOf(CM_GridController) then
		tiX := aGridController.CM_GridController.row;
		tiY := aGridController.CM_GridController.column;
	endif;
	
	create thePowerPoints transient;
	self.myTerminalArea.CM_ForkLiftStack.getPowerPoints(thePowerPoints);
	
	self.cmbPowerPoints.clear();
	foreach anObject in thePowerPoints do
		if anObject.isKindOf(CM_GapController) then
			aGapController := anObject.CM_GapController;
			idx := self.cmbPowerPoints.addItem(aGapController.getID);
			self.cmbPowerPoints.itemObject[idx] := aGapController;
			
			// Find the closest power point to the TI
			// we do this by working out the distance in locations controllers in the row and the column from our TI
			// add the row and column difference together and that is the distance away from us
			if aGapController.row &gt;= tiX then
				gapX := aGapController.row - tiX;
			else
				gapX := tiX - aGapController.row;
			endif;
			if aGapController.column &gt;= tiY then
				gapY := aGapController.column - tiY;
			else
				gapY := tiX - aGapController.column;
			endif;
			if (gapY + gapX) &lt; totalPoints then
//			if gapX &lt;= ppX and gapY &lt;= ppY then
//				ppX := gapX;
//				ppY := gapY;
				totalPoints := gapY + gapX;
				closeGap := aGapController;
			endif;
		endif;
	
	endforeach;
	if closeGap &lt;&gt; null then
		self.cmbPowerPoints.text := closeGap.getID;
		self.tblData.setValueByControlName(cmbPowerPoints.name,cmbPowerPoints.text);
	
		self.myPowerPoint := closeGap;
	
	endif;
epilog
	delete thePowerPoints;
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="doBuildComboTIs" id="539eb2c5-093a-46bd-888a-ce2c3af7cb84">
        <source>doBuildComboTIs(_theCargoType : CM_CargoType);
// ---------------------------------------------------------------------------
// Created:		August  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 11 Jan 2011	cnwkpd1		PAR #26678 - Tidy up transient leaks
//							Also removed beginLoad because this will cause locking
//							issues with a Cargo Type with large number of TIs
// ---------------------------------------------------------------------------

vars
	aTrackedItem	 : CM_TrackedItem;
	idx : Integer;
	iter : Iterator;
	loadStateSet : Boolean;
begin

	self.cmbTIs.clear();
//	app.cmsBeginLoad(loadStateSet);
	iter := self.myTerminal.allOnsiteTIsByCargoTypeId.createIterator();
	self.myTerminal.allOnsiteTIsByCargoTypeId.startKeyGeq(_theCargoType.id,null,iter);

	while iter.next(aTrackedItem) do
		if aTrackedItem.myCargoType.id &lt;&gt; _theCargoType.id then
			break;
		endif;
		
		idx := self.cmbTIs.addItem(aTrackedItem.id);
		self.cmbTIs.itemObject[idx] := aTrackedItem;
	endwhile;	
epilog
//	app.cmsEndLoad(loadStateSet);
	delete iter;		// PAR #26678
end;</source>
        <Parameter name="_theCargoType" type="CM_CargoType"/>
    </JadeMethod>
    <JadeMethod name="doBuildConnectCaption" id="001fe29f-7bcd-4b58-a295-416f6ac5ecf4">
        <updating/>
        <source>doBuildConnectCaption(_theTI: CM_TrackedItem; _theAction: Integer): String updating;
// ---------------------------------------------------------------------------
// Created:		11 June 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------
vars

	theContainer : CM_Container;
	theTower, theCaption : String;
	otherTI : CM_TrackedItem;
	
begin
	if _theTI &lt;&gt; null then
		if _theTI.isKindOf(CM_Container) then
			theContainer := _theTI.CM_Container;
			if theContainer.isPortHole then
				theTower := theContainer.towerId.trimBlanks;
				if theTower.trimBlanks = null then
					otherTI := theContainer.getOtherTrackedItem(_theAction);
					if otherTI &lt;&gt; null then
						theTower := otherTI.id;
					else
						theTower := "Tower";
						theCaption := null;
						return theCaption;
					endif;
				endif;
				if _theAction = ACTION_DISCONNECT then
					theCaption := theContainer.id &amp; " Disconnect From " &amp; theTower ;
				else
					theCaption := theContainer.id &amp; " Connect To " &amp; theTower;
				endif;
			else
				if _theAction = ACTION_DISCONNECT then
					theCaption := theContainer.id &amp; " Disconnect From Power";
				elseif _theAction = ACTION_CONNECT then
					theCaption := theContainer.id &amp; " Connect To Power";
				endif;
			endif;
		endif;				
	endif;

	return theCaption;
end;</source>
        <Parameter name="_theTI" type="CM_TrackedItem"/>
        <Parameter name="_theAction" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="doCancel" id="54a0c92d-194b-4f32-a7d6-69cc3987e15a">
        <updating/>
        <source>doCancel()updating;
//-----------------------------------------------------------------------
//
//  Created by: cnwsh3
//
//	Date: 23 September 2003
//
//-----------------------------------------------------------------------

vars

begin
//	not necessary here
//	if self.tblData.hasChanged then
//		self.confirmCancel('my current item');
//	endif;
	self.unloadForm();
end;</source>
    </JadeMethod>
    <JadeMethod name="initControls" id="80c427fc-2bcb-4cbd-9b73-f34d016078a9">
        <updating/>
        <source>initControls() updating;
// ---------------------------------------------------------------------------
// Created:		August  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	self.cmbCargoType.visible := false;
	self.cmbCOUArea.visible := false;
	self.cmbCOUs.visible := false;
	self.cmbTIs.visible := false;
	self.cmbPowerPoints.visible := false;
	self.chkIgnoreWarning.enabled := false;
	self.myPowerPoint := null;
end;</source>
    </JadeMethod>
    <JadeMethod name="initDataTable" id="6edac5b8-372b-48f5-ab2f-2771bda0c166">
        <updating/>
        <source>initDataTable() updating;
// ---------------------------------------------------------------------------
// Created:		August  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 09/08/2010	cnwdap1		PAR #25336 Correct terminal area handling
// 17 May 2016	cnwns1	TFS 488 - Multi Timezone Support
// ---------------------------------------------------------------------------

vars

	entTableControl	: EntTableDef;
	theTable		: CM_EntryTable;
	aTS 			: TimeStamp;
	trackedItem		: CM_TrackedItem;
	ta				: CM_TerminalArea;
	lc				: CM_LocationsController;
begin

	aTS := self.systemToLocalTime(app.actualTimeServer);// 17 May 2016	cnwns1	TFS 488 - Multi Timezone Support

	theTable := self.tblData;
	theTable.rows := 0;
	theTable.optimiseRowHeight := true;
	
	if self.startupMode = self.StarupMode_TowerPower then
		entTableControl := app.myController.getEntTableDef(ETDef_ConnectReefer); 
	elseif self.startupMode = self.StarupMode_COU then
		entTableControl := app.myController.getEntTableDef(ETDef_ConnectCOU); 
	else
		return;
	endif;
	
	theTable.setEntTableDef(entTableControl, null, 'entTableDefSetupWarning');

	theTable.visible := true;
	theTable.changeMode := theTable.ChangeMode_FirstOnly;
	
	if self.allTrackedItems.size &gt; 0 then
		trackedItem := self.allTrackedItems[1];
		lc := trackedItem.getPrimaryLocation(REAL_MODE); //cnwrd1 31313 18.4.13
		if trackedItem.myTerminalArea = null then			
			if lc &lt;&gt; null then
				ta := lc.myTerminalArea;
			endif;
		else
			ta := trackedItem.myTerminalArea;
		endif;
	
		// PAR #25336 we just derived the terminal area above - why then are we referring to the TI's
		// terminal area here when it could be null and we could need to use the location controller's?
		//self.myTerminalArea := trackedItem.myTerminalArea; 									// PAR #25336 
		self.myTerminalArea := ta; 																// PAR #25336 
		//if self.myTerminalArea.isKindOf(CM_ForkLiftStack) then								// PAR #25336 
		if self.myTerminalArea &lt;&gt; null and self.myTerminalArea.isKindOf(CM_ForkLiftStack) and not lc.hasPower then	// PAR #25336  //cnwrd par 31313 if the GBS location has power we are not looking for power from a tower/gap
			self.doBuildComboPowerPoints(trackedItem);
			if trackedItem.isKindOf(CM_Container) then
				if trackedItem.CM_Container.getMyGapPower &lt;&gt; null then
					theTable.setValueByName(ETRow_PowerPoints,trackedItem.CM_Container.getMyGapPower.getID);
				endif;
			endif;
		else
			theTable.hideRowByName(ETRow_PowerPoints,false);
		endif;
	endif;

	// 19/9/2006 (12529) Mohammad
	theTable.setValueByName(ETRow_Date,aTS.date);
	theTable.setValueByName(ETRow_Time,aTS.time);
	
	if self.singleTIMode then
		if self.startupMode = self.StarupMode_COU then
			theTable.disableRowByName(ETRow_CargoType);
			theTable.disableRowByName(ETRow_Id);
			theTable.setValueByName(ETRow_ClipOnUnitID,trackedItem.CM_Container.couId.trimBlanks);
			if self.action = ACTION_DISCONNECT then
				theTable.disableRowByName(ETRow_ClipOnUnitID);
			endif;
		endif;
		
		theTable.setValueByName(ETRow_CargoType,trackedItem.myCargoType.description);
		theTable.disableRowByName(ETRow_CargoType);
		theTable.setValueByName(ETRow_Id,trackedItem.id);
		theTable.disableRowByName(ETRow_Id);
		theTable.setValueByName(ETRow_HasExternalMonitoring, trackedItem.getExternalMonitoring());		//cnwmc5 - 20 Oct 2015 - PAR 37057
		
		//epr TFS 3581 7/3/17
		if not  app.myPassport.myUser.canDo(trackedItem.myTerminal,PmAdmIsExternallyMonitored).Boolean then
			theTable.setRowReadOnly(ETRow_HasExternalMonitoring);
		endif;
				
		self.cmbTIs.text := trackedItem.id;
		self.cmbTIs.setIndexFromObject(trackedItem);
		
		self.cmbCargoType.text := trackedItem.myCargoType.description;

	else
		// set for multiple connect/disconnect
		theTable.hideRowByName(ETRow_CargoType, false);
		theTable.disableRowByName(ETRow_ClipOnUnitID);
	
		theTable.setValueByName(ETRow_Id,"All Selected");
	endif;
	
	self.setColorsForEntryTable(theTable);
	theTable.resetSize();
end;</source>
    </JadeMethod>
    <JadeMethod name="loadDataForFirstTime" id="06068f5a-a82f-4ba5-b2e4-b4d729ce4b9f">
        <updating/>
        <source>loadDataForFirstTime() updating, protected;
// ---------------------------------------------------------------------------
// Created:      29 May 2003 by cnwsgp1
// ---------------------------------------------------------------------------
begin
	
	if self.singleTIMode then
//		return;
	endif;
	self.doBuildComboCargoType();
	self.doBuildComboCOUArea();
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setCheckMode" id="c76ffc2d-53fa-4683-a283-610065b8b859">
        <updating/>
        <source>setCheckMode() updating;
// ---------------------------------------------------------------------------
// Created:		12 June 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------

vars

begin
	if self.startupMode = self.StarupMode_COU or self.allTrackedItems.size = 1 then
		self.singleTIMode := true;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="17b93e1b-81d3-4394-80c0-a2d343e95313">
        <updating/>
        <source>setupForm() updating;
// ---------------------------------------------------------------------------
// Created:		August  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
begin
	inheritMethod();
	
	self.mousePointer := Window.MousePointer_HourGlass;
	self.setCheckMode();
	self.doBuildCaption();
	self.initControls();
	self.initDataTable();

	self.btnOK.setFocus;
	self.doResize();
	self.tblData.optimiseHeadingColumn();
	self.mousePointer := Window.MousePointer_Default;
end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="a5d9f2d2-1d7b-477a-aa0f-0cc1d85bbc0a">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0007326, locale);
	btnCancel.translateCaption(Xlat_0000296, locale);
	btnOK.translateCaption(Xlat_0000297, locale);
	chkIgnoreWarning.translateCaption(Xlat_0000293, locale);
end;</source>
    </JadeMethod>
</GUIClass>
