    <JadeMethod name="getNumTEU" id="1cb84f7b-6a57-4cc5-9eda-477a5237622b">
        <source>getNumTEU() : Real;
// ---------------------------------------------------------------------------
// Created:     26 November 2007 by cnwaer1
//
// Purpose:     Number of 20 foot locations
// ---------------------------------------------------------------------------
vars

	ct : CM_CargoType;
	teu : Decimal[23,2];
begin
	ct := self.myCargoType;
	if ct = null then
		return 1; // SO we get a PAR and can fix it
	endif;
		
	if self.is20 then		
		//epr TFS 2290 7/7/16
		teu := ct.getTEUConversionValue(TEUConversionIndex20);
	elseif self.is30 then
		teu := ct.getTEUConversionValue(TEUConversionIndex30);
	elseif self.is40 then
		teu := ct.getTEUConversionValue(TEUConversionIndex40);
	elseif self.is45 then
		teu := ct.getTEUConversionValue(TEUConversionIndex45);
	elseif self.is53 then
		teu := ct.getTEUConversionValue(TEUConversionIndex53);
	endif;
	if teu = 0 then
		teu := 1;
	endif;
	if ct.teuMultiplier = TEUMultiplierIndexQ then
		teu := teu / self.totalQuantity;
	elseif ct.teuMultiplier = TEUMultiplierIndexW then
		teu := teu / self.totalWeight;
	endif;
	
	return teu;
	

end;</source>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="getNumTEUDeci" id="fbbb1e0e-413e-4f18-8157-22cf45432ed3">
