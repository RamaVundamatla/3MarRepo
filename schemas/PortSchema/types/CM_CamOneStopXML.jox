    <JadeMethod name="makeVGMCertStatSubSectXML" id="f1e53130-4ab2-434e-bb6e-f955a5b59d7e">
        <source>makeVGMCertStatSubSectXML( _ti: CM_TrackedItem; _parentElem : JadeXMLElement input ) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17/08/2016	cnwndl1	Initial creation	TFS 2561 / 2277
19/07/2017	cnwdap1	TFS 4492 SNO VERMAS Changes
*/

vars

	rootElem : JadeXMLElement;
	xmlElem : JadeXMLElement;
	container : CM_Container;			// TFS 4492
	tsUTC : TimeStamp;					// TFS 4492
	
begin

	rootElem := _parentElem.addElement('VGMCertificateStatement');
	
	if _ti = null then
		return;
	endif;
	
	if _ti.isKindOf(CM_Container) and _ti.CM_Container.myVGMDetails &lt;&gt; null then			// TFS 4492
		container := _ti.CM_Container;														// TFS 4492
		xmlElem := rootElem.addElement('MethodOfWeightCalculation');						// TFS 4492
		xmlElem.setText( container.myVGMDetails.vgmCommsType );								// TFS 4492
																							// TFS 4492
		xmlElem := rootElem.addElement('WeightVerificationDate');							// TFS 4492
		if container.myVGMDetails.vgmDeterminationDT &lt;&gt; null then							// TFS 4492
			tsUTC := self.convertTStoUTC( container.myVGMDetails.vgmDeterminationDT );		// TFS 4492
			xmlElem.setText( tsUTC.asXMLFormat );											// TFS 4492
		else																				// TFS 4492
			xmlElem.setText( null );														// TFS 4492
		endif;																				// TFS 4492
	endif;																					// TFS 4492
	
	self.makeWeightCertIPSubSectXML( _ti, rootElem );
	
	self.makeDeclarantSubSectXML( _ti, rootElem );
	
	xmlElem := rootElem.addElement('EDISignature');
	xmlElem.setText( _ti.weightCertifiedName );
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_parentElem" type="JadeXMLElement" usage="input"/>
    </JadeMethod>
