    <JadeMethod name="reinstate" id="82f11cd5-6ac9-43d4-9244-dd418446961c">
        <updating/>
        <source>reinstate(_terminal : CM_Terminal; doSubCompanies: Boolean) updating;

vars
	subCo	: CM_Bank;
	iter	: Iterator;

begin
	if doSubCompanies then
		iter := self.subCompanies.createIterator;
		self.subCompanies.startKeyGeq(_terminal, null, iter);
		while iter.next(subCo) do
			if subCo.terminal &lt;&gt; _terminal then
				break;
			endif;
			subCo.reinstate(_terminal, doSubCompanies);
		endwhile;
	endif;

	if self.isSuspended then
		self.isSuspended := false;
	endif;
epilog
	delete iter;
end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="doSubCompanies" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="resyncChargeSnapshot" id="845acea7-c058-460d-a1cc-4358abe200da">
        <updating/>
        <source>resyncChargeSnapshot(_quantityMap : CM_QuantityMap; _snapshotData : CM_DynamicObject_Snapshot; _snapShotQuantity : CM_SnapshotField; _debtor : CM_Debtor; _quantity : Integer) updating;
// CCMS 1043 Snapshot Summary Invoicing 	Oct 2010 	cnwjre1
//  Snapshot data resynch - update existing invoice lines to match current snapshot summary definition.
// debtor can be null, quantity can be zero
vars
	invLineDesc:  CM_InvoiceLineDesc;
	invLine : CM_InvoiceLine;
	qrm : CM_QuantityRangeMap;
	idx : Integer;
	dateTime	: TimeStamp;
	escalating	: Boolean;
	lineFound	: Boolean;
	quantity	: Integer;
	aSBController : CMIF_ServiceBroker;
	invoiceLines	: CM_InvoiceLineBySeqNumDict;
begin

	create aSBController transient;
	aSBController.myBank := self;
	quantity := _quantity;
	create invoiceLines transient;
	
	if _quantityMap.mappingType = CM_QuantityMap.MapType_Single then
		_quantityMap.getInvLineDescForSingle(aSBController, _quantity);
	else
		_quantityMap.getInvLineDescForEscalating(aSBController, _quantity);
		escalating := true;
	endif;
	dateTime := _snapshotData.mySnapshotData.runDateTime;
	
	// void existing invoice lines if no longer required
	foreach invLine in _snapshotData.allInvoiceLines do
		if _debtor = null then
			invLine.changeStatus(CM_InvoiceLine.STATUS_VOIDED);
			continue;
		endif;
		if invLine.quantity = 0 and
		   not _quantityMap.chargeZero then
			invLine.changeStatus(CM_InvoiceLine.STATUS_VOIDED);
			continue;
		endif;
		lineFound := false;
		foreach invLineDesc in aSBController.allInvoiceLineTypes discreteLock do
			if invLine.invoiceLineDesc = invLineDesc then
				lineFound := true;
				if invLineDesc.isVoid then
					invLine.changeStatus(CM_InvoiceLine.STATUS_VOIDED);
					continue;
				endif;
				break;
			endif;
		endforeach;
		if not lineFound then
			invLine.changeStatus(CM_InvoiceLine.STATUS_VOIDED);
			continue;
		endif;
		invoiceLines.add(invLine);
	endforeach;
	
	// if debtor is now null, nothing more to do
	if _debtor = null then
		return;
	endif;
	
	foreach invLineDesc in aSBController.allInvoiceLineTypes discreteLock do
		idx := idx + 1;
		if invLineDesc = null or invLineDesc.isVoid then
			continue;
		endif;

		qrm := null;
		if idx &lt;= aSBController.allQuantityRangeMaps.size then
			qrm := aSBController.allQuantityRangeMaps[idx].CM_QuantityRangeMap;
		endif;
		if escalating then
			if qrm &lt;&gt; null then
				if _quantity &gt; qrm.rangeEnd then
					quantity := qrm.rangeEnd.Integer - qrm.rangeStart.Integer;
					if qrm.rangeStart &gt; 0 then
						quantity := quantity + 1;
					endif;
				else
					quantity := _quantity - qrm.rangeStart.Integer + 1;
				endif;
			endif;
		endif;
		lineFound := false;
		foreach invLine in invoiceLines do
			if invLine.invoiceLineDesc = invLineDesc then
				lineFound := true;
				invLine.updateFromSnapshotResync(_debtor, qrm, quantity);
				break;
			endif;
		endforeach;
		if not lineFound then
			invLine := invLineDesc.createInvoiceLineSnapshot(dateTime, _debtor, quantity);
			if invLine &lt;&gt; null then
				invLine.setFromQuantityRangeMap(qrm);
				invLine.setSnapShot(_snapshotData, _snapShotQuantity);
			endif;
		endif;

	endforeach;

epilog
	delete aSBController;
	delete invoiceLines;
end;</source>
        <Parameter name="_quantityMap" type="CM_QuantityMap"/>
        <Parameter name="_snapshotData" type="CM_DynamicObject_Snapshot"/>
        <Parameter name="_snapShotQuantity" type="CM_SnapshotField"/>
        <Parameter name="_debtor" type="CM_Debtor"/>
        <Parameter name="_quantity" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setConfig" id="f3b89111-3f6b-4e48-badd-768f94e027ad">
        <updating/>
        <source>setConfig(pCode : String; pValue : Any)updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 January 2019	jlgndl1	Initial creation	TFS 40010

*/

vars

	oldValue : Any;
	newValue : Any;
	changeString : String;
	
begin

	oldValue := self.getStateData( pCode );
	
	self.setStateData( pCode, pValue );
	
	newValue := self.getStateData( pCode );	
	
	
	if oldValue &lt;&gt; newValue then
	
		changeString := " Busness Unit [" &amp; self.terminal.code &amp; "/" &amp; self.code &amp; "] config " &amp; pCode &amp; ", was:'" &amp; oldValue.String &amp; "' now:'" &amp; newValue.String &amp; "'";
		app.createActivityHistory(	ActivityHistoryGeneralSys,	//_type : Integer;
									null,	//_terminal : CM_Terminal;
									null,	//_objectForExtraDetail : Object;
									changeString,	//_description : String;
									true,	//_insideTransaction : Boolean;
									false	//_temp: Boolean
									);
	endif;
	
end;</source>
        <Parameter name="pCode" type="String"/>
        <Parameter name="pValue" type="Any"/>
    </JadeMethod>
