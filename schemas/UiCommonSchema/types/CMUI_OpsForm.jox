    <JadeMethod name="getSpliterRatio" id="7f4003d0-d7c3-4c6c-8072-24f3649aba7c">
        <source>getSpliterRatio(_splitter : CMUI_SplitContainer) : Integer;
//--------------------------------------------------------------
//Created: 15 July 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	pos,
	startPos		: Integer;
	tmpRatio,
	splitterName	: String;
	userWindow		: CM_UserWindow;
begin
	if _splitter = null then
		return null;
	endif;
	
	userWindow := app.getUserWindow(self.name, false);
	
	if userWindow = null then
		return _splitter.leftToRightRatio;
	endif;
	
	startPos := 1;
	pos := 1;
	splitterName := userWindow.xmlInfo.cnEcGetNextTagValueOfName(XMLTag_Splitter &amp; ' ' &amp; self.name &amp; ' ' &amp; _splitter.name, startPos);

	if splitterName &lt;&gt; null then
		tmpRatio := splitterName.cnEcGetNextTagValueOfName(XMLTag_Ratio, pos);
	else
		tmpRatio := _splitter.leftToRightRatio.String;
	endif;

	return tmpRatio.Integer;
	
end;</source>
        <Parameter name="_splitter" type="CMUI_SplitContainer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getTIFromGridPoint" id="ac18b977-2f26-425b-894d-f0e3e759f9bd">
        <source>getTIFromGridPoint(y : Real; _gridPoint : CMUI_GridPoint) : CM_TrackedItem;
//--------------------------------------------------------------
//Created: 19 March 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	theTI	: CM_TrackedItem;
	rtnStr	: String;
	tmpYPos	: Real;
	numTIs,
	idx		: Integer;
	lTIArray : CM_TIArray;
	lDisplayMode : Integer;
begin
	create lTIArray transient;
	
	if self.myCurrentLocation = null then
		return null;
	endif;

	lDisplayMode := self.mySDF.displayMode;

	if lDisplayMode = DISPLAY_MODE_ACTUAL then
		self.myCurrentLocation.getTIs(lTIArray, REAL_MODE, true); // PAR 27749
	elseif lDisplayMode = DISPLAY_MODE_QUEUE then
		self.myCurrentLocation.getTIs(lTIArray, QUEUE_MODE, true); // PAR 27749
	elseif lDisplayMode = DISPLAY_MODE_PLAN then
		self.myCurrentLocation.getTIs(lTIArray, PLANNING_MODE, true); // PAR 27749
	else
		self.myCurrentLocation.getTIs(lTIArray, REAL_MODE, true); // PAR 27749
	endif;
	
	if lTIArray.isEmpty then
		return null;
	endif;
	
	numTIs := lTIArray.size;
	
	foreach idx in 1 to numTIs do
		tmpYPos := _gridPoint.getYPosFromIdx(idx);
		if y &gt;= tmpYPos then
			theTI := lTIArray[idx];
			break;
		endif;
	endforeach;
	
	return theTI;
epilog
	delete lTIArray;
end;</source>
        <Parameter name="y" type="Real"/>
        <Parameter name="_gridPoint" type="CMUI_GridPoint"/>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="getTableString" id="310ab244-d0fb-4977-bd2c-5a00200c497d">
        <source>getTableString(lRoadWLE : CM_WorkListEntry; pBack, pFore : Integer io) : String;
//--------------------------------------------------------------
//Created: Feb 2002 By: cnwgd1
