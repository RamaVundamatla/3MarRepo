    <JadeMethod name="handleNotification" id="a2ffc3c1-3583-4ca7-abff-0368a905026c">
        <source>handleNotification(eventType: Integer; theObject: Object; eventTag: Integer);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 December 2009	cnwndl1	Initial creation	CCMS 1023

*/

vars

	formatSS : CM_OutputFormat_SS;
	index : Integer;
	currentObject : Object;
	snapShotData : CM_SnapshotData;
	startDate : Date;
	endDate : Date;
	row : Integer;
	
begin

	if theObject.isKindOf( CM_SnapshotData ) then
		snapShotData := theObject.CM_SnapshotData;
		if eventType = Object_Delete_Event then
			foreach row in 1 to self.tblData.rows do
				if self.tblData.accessRow(row).itemObject = snapShotData then
					self.tblData.removeItem(row);
					break;
				endif;
			endforeach;
		elseif eventType = Object_Create_Event then
			snapShotData := theObject.CM_SnapshotData;
			formatSS := snapShotData.myOutputFormat_SS;
			if cmbDefinition.listIndex &gt; 0 then
				//get the current one
				currentObject := cmbDefinition.listObject;
			endif;
			if formatSS &lt;&gt; null and formatSS = currentObject then
				if snapShotData.myTerminal = cmbTerminal.listObject.CM_Terminal then
					startDate := txtFromDate.getDate();
					if not startDate.isValid or snapShotData.runDateTime.Date &gt;= startDate then
						endDate := txtToDate.getDate();
						if not endDate.isValid or snapShotData.runDateTime.Date &lt;= endDate then
							self.addSnapshotDataToTable( snapShotData );
						endif;
					endif;
				endif;
			endif;
		endif;
	endif;

	if eventType = EVENT_SummaryTable_Update then
		if theObject.isKindOf( CM_OutputFormat_SS ) then
			formatSS := theObject.CM_OutputFormat_SS;
			index := cmbDefinition.findObject(formatSS);
			if index &lt; 1 then
				// this must be a new one.
				if cmbDefinition.listIndex &gt; 0 then
					//get the current one
					currentObject := cmbDefinition.listObject;
				endif;
				index := cmbDefinition.addItem(formatSS.name);
				cmbDefinition.itemObject[index] := formatSS;
				if currentObject &lt;&gt; null then
					//set back to the one we had selected.
					cmbDefinition.listIndex := cmbDefinition.findObject(currentObject);
				endif;
			endif;
		endif;
		
	elseif eventType = EVENT_SummaryTable_Delete then
		if theObject.isKindOf( CM_OutputFormat_SS ) then
			formatSS := theObject.CM_OutputFormat_SS;
			index := cmbDefinition.findObject(formatSS);
			if index &gt; 0 then
				// we have this one in our combo
				if cmbDefinition.listIndex &lt;&gt; index then
					// but it is not the one that is currently selected, get the current one
					currentObject := cmbDefinition.listObject;
				else
					// and its currently selected.
					if not self.deleting then
						// some one else has caused this
						app.msgBox( app.getErrorString1(Format_deleted_by_user, self.caption), app.getErrorString(Warning), MsgBox_Exclamation_Mark_Icon + MsgBox_OK_Only);
					endif;
				endif;
				self.populateCombos();
				if currentObject &lt;&gt; null then
					//set back to the one we had selected.
					cmbDefinition.listIndex := cmbDefinition.findObject(currentObject);
				endif;
				self.setMaintButtons();
			endif;
		endif;
		
	endif;
	
epilog

end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
