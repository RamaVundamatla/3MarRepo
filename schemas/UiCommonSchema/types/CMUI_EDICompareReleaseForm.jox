    <JadeMethod name="getDBNameForEDIRow" id="7ddd27ee-3cdd-4403-98bc-c6e9c149b459">
        <source>getDBNameForEDIRow(_name :String):String protected;
/*
Date		Who		Reason
01 August 2013	cnwcs5	CCMS POL 2221 / par 32094
*/
vars

begin
	if _name = ETRow_AllowCargoMultiReleases then
		return ETRow_AllowCargoOnMultiRel;
		
	elseif _name = ETRow_AvailabilityGrades then
		return ETRow_AllMTGrades;
			
	elseif _name = ETRow_BookingRef then
		return ETRow_MyBookingRefStock; 
	
	elseif _name = ETRow_CargoTypeDescr then
		return ETRow_CargoType;
		
	elseif _name = ETRow_CargoSubType then
		return ETRow_MyProduct;
		
	elseif _name = ETRow_CheckISOGroup then
		return ETRow_DoISOGroupCheck;
		
	elseif _name = ETRow_Consignor then
		return ETRow_ConsignorCode;
	
	elseif _name = ETRow_ConsignorVoyage then
		return ETRow_ConsignorVoyageCode;
		
	elseif _name = ETRow_DestinationPort then 
		return ETRow_Destination;
		
	elseif _name = ETRow_DestTerminal then
		return ETRow_MyTransferToTerminal;
		
	elseif _name = ETRow_FreightForwarder then
		return ETRow_FreightForwarderCode;
		
	elseif _name = ETRow_HasChanged then
		return ETRow_Ignore;
		
	elseif _name = ETRow_HeavyDuty then
		return ETRow_HeavyRated;
			
	elseif _name = ETRow_Ids then
		return ETRow_IdMask;
		
	elseif _name = ETRow_MessageMode then
		return ETRow_Ignore;
		
	elseif _name = ETRow_OperatorGroup then
		return ETRow_MyOperatorGroup;
		
	elseif _name = ETRow_Quantity then
		return ETRow_TotalRequested;
			
	elseif _name = ETRow_ReleaseTypeStr then
		return ETRow_Type;
	
	
	elseif _name = ETRow_SenderCode then
		return ETRow_Ignore;
		
	elseif _name = ETRow_SubTerminalCode then
		return ETRow_MySubTerminal;
			
	else
		return _name;
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_name" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getEDITrackedItemsInOrder" id="bfe2a207-57a8-4b49-898a-935783e5d6af">
        <source>getEDITrackedItemsInOrder(_ediTIColl : CM_EDITIById; _dd: DynaDictionary input) protected;
/*
Date		Who		Reason
01 August 2013	cnwcs5	CCMS POL 2221 / par 32094(2)
// 05 Dec 2017	jlgrs1	TFS 8195 - SNO - EDI Release Comparison add support for ReleaseRequestMulti
*/
vars
	ediTI	:CM_EDITrackedItem;
	status	:Integer;
begin
	_dd.setMembership (CM_EDIReleaseRequestTI);
	
	_dd.addMemberKey (CM_EDIReleaseRequestTI::messageMode.name, false, false);
	_dd.addMemberKey (CM_EDIReleaseRequestTI::releaseRequestNumber.name, false, false);
	_dd.addMemberKey (CM_EDIReleaseRequestTI::cargoType.name, false, false);
	_dd.addMemberKey (CM_EDIReleaseRequestTI::isoTypeGroup.name, false, false);
	_dd.addMemberKey (CM_EDIReleaseRequestTI::isoType.name, false, false);
	
	_dd.endKeys (true);
	
	foreach ediTI in _ediTIColl do
		status := ediTI.status;
		
		// we don't show loaded of deleted items
		if status = CM_EDITrackedItem.EDI_STATUS_DBLOADED or ediTI.messageMode = CM_EDITrackedItem.EDI_ACTION_DELETE then
			continue;
		endif;
		
		_dd.add (ediTI);
	endforeach;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_ediTIColl" type="CM_EDITIById"/>
        <Parameter name="_dd" type="DynaDictionary" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getEntTableDefName" id="cb7bcc54-1a4b-481e-9c1c-d904434c2d08">
