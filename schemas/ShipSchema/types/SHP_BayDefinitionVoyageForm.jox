    <JadeMethod name="setToViewMode" id="e675c15b-e1b4-407b-a260-9b356e621b50">
        <updating/>
        <source>setToViewMode() updating, protected;
//--------------------------------------------------
// Created:	05 April 2005 By: cnwgd1
//--------------------------------------------------
vars

begin
	if self.isFirstActivateComplete
	and self.mode = self.Mode_View then
		return;
	endif;
	
	self.mode := self.Mode_View;
	self.anythingChangedBay := false;
	self.btnBayEditBay.visible := true;
	self.btnBayApplyBay.visible := false;

	self.setControlsForView();
		
	if self.viewModeOnly
	or self.myCurrentVoyage = null then
		self.btnEditTV.enabled := false;
	elseif self.myCurrentVoyage &lt;&gt; null then
		self.btnEditTV.enabled := true;
	endif;

	self.btnCancelBase.enabled := false;		
	self.btnBayCopy.enabled:= false; // TFS 2198
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupBtnPens" id="3290a03a-053a-4943-9296-b06aa3d65fba">
        <source>setupBtnPens() protected;
// ---------------------------------------------------------------------------
// Created:     12 September 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	atttDict	: CM_DrawingAttributesByCodeDict;
	drawAttr	: CM_DrawingAttribute;
	ls			: Boolean;
	
begin

	atttDict := app.myRoot.allDrawingAttributes;

	app.cmsBeginLoad(ls);	
	
	drawAttr := atttDict[PicTIDoorsAft];
	if drawAttr &lt;&gt; null then
		self.btnPenAftDoors20.setFontFromDrawingAttr(drawAttr);
	endif;
	drawAttr := atttDict[PicTIDoorsAft40];
	if drawAttr &lt;&gt; null then
		self.btnPenAftDoors40.setFontFromDrawingAttr(drawAttr);
	endif;
	drawAttr := atttDict[PicTIMotorAft];
	if drawAttr &lt;&gt; null then
		self.btnPenAftMotor20.setFontFromDrawingAttr(drawAttr);
	endif;
	drawAttr := atttDict[PicTIMotorAft40];
	if drawAttr &lt;&gt; null then
		self.btnPenAftMotor40.setFontFromDrawingAttr(drawAttr);
	endif;

	drawAttr := atttDict[PicTI40Footer];
	if drawAttr &lt;&gt; null then
		self.btnPen40.setFontFromDrawingAttr(drawAttr);
	endif;
	// PAR 16415 CCMS 1029
	drawAttr := atttDict[PicTI30Footer];
	if drawAttr &lt;&gt; null then
		self.btnPen30.setFontFromDrawingAttr(drawAttr);
	endif;
	// PAR 16415 CCMS 1029
	drawAttr := atttDict[PicTI53Footer];
	if drawAttr &lt;&gt; null then
		self.btnPen53.setFontFromDrawingAttr(drawAttr);
	endif;

	// PAR 16882 CCMS 1055
	drawAttr := atttDict[PicTI45Footer];
	if drawAttr &lt;&gt; null then
		self.btnPen45.setFontFromDrawingAttr(drawAttr);
	endif;

	drawAttr := atttDict[PicTIMTOnly];
	if drawAttr &lt;&gt; null then
		self.btnPenEmpty.setFontFromDrawingAttr(drawAttr);
	endif;

/*
	self.btnPenHeavy.fontCharacter	:= 72;
	self.btnPenHeavy.fontColour		:= Red;
	self.btnPenHeavy.fontName		:= "Verdana";
	*/
	drawAttr := atttDict[PicTIHeavy];
	if drawAttr &lt;&gt; null then
		self.btnPenHeavy.setFontFromDrawingAttr(drawAttr);
	endif;
/*
	self.btnPenVoltage.fontCharacter	:= 86;
	self.btnPenVoltage.fontColour		:= Red;
	self.btnPenVoltage.fontName		:= "Verdana";
	*/
	drawAttr := atttDict[PicTIVoltageSingle];
	if drawAttr &lt;&gt; null then
		self.btnPenVoltage.setFontFromDrawingAttr(drawAttr);
	endif;

	drawAttr := atttDict[PicTIConnected];
	if drawAttr &lt;&gt; null then
		self.btnPenPower.setFontFromDrawingAttr(drawAttr);
	endif;

	drawAttr := atttDict[PicTIReefer];
	if drawAttr &lt;&gt; null then
		self.btnPenReefer.setFontFromDrawingAttr(drawAttr);
	endif;

	drawAttr := atttDict[PicTIUnavail];
	if drawAttr &lt;&gt; null then
		self.btnPenUnavail.setFontFromDrawingAttr(drawAttr);
	endif;

	drawAttr := atttDict[PicTIWaterCooled];
	if drawAttr &lt;&gt; null then
		self.btnPenWaterCool.setFontFromDrawingAttr(drawAttr);
	endif;
epilog
	app.cmsEndLoad(ls);
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupForm" id="ecc890c0-b872-49d1-862d-c8ecc064a3d0">
        <updating/>
        <source>setupForm() updating;
//--------------------------------------------------
// Created:	05 April 2005 By: cnwgd1
//--------------------------------------------------
//
// Changed On	By			Reason
// ----------	--------	---------------------------------------------------------
// 05/09/2017	jlgdap1		TFS 6832 AAT Permissions for Voyage Bay Definition
vars
	tmpIntArray : IntegerArray;
begin
	inheritMethod();

	self.toolbarStyle := self.ToolbarStyle_ShowNoHide;	
	self.showToolbar := true;	
	
	//self.viewModeOnly := (not app.myCurrentUserCan(self.myTerminal, PmAdmVoyageDefEdit));		// TFS 6832
	self.viewModeOnly := (not app.myCurrentUserCan(self.myTerminal, PmVoyageBayDefMaint));		// TFS 6832

	//28 July 20101	NDL	Par 25127
	create tmpIntArray transient;
	tmpIntArray.add(J_key_Tab);
	self.tblOnCellDims.registerKeys(tmpIntArray);
	self.tblUnderCellDim.registerKeys(tmpIntArray);
	
	self.initForm();
	
epilog
	delete tmpIntArray;
end;</source>
    </JadeMethod>
    <JadeMethod name="showBayCopyFrame" id="4ea0ba63-c11f-414a-a6d2-7059f250712c">
        <source>showBayCopyFrame();
// ---------------------------------------------------------------------------
// Created:		November 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	theFrame		: Frame;
	aBay			: CM_Bay;
	aVessel			: CM_Vessel;
	tmpVesselCell	: CM_CellularVesselStructure;
	structure		: CM_CellularVoyageStructure;
	failedDAC  :CM_DataAccessController;
	
begin
	if self.myCurrentVoyage &lt;&gt; null then
		structure	:=	self.myCurrentVoyage.myCellularVoyageStructure;
	endif;
	
	if structure &lt;&gt; null then
		aVessel	:=	app.myRoot.allVessels[self.myCurrentVoyage.vesselCode.trimBlanks];
		
		if aVessel = null then
			app.msgBox("Cannot find Vessel for this voyage!", "Vessel Error", MsgBox_Exclamation_Mark_Icon + MsgBox_OK_Only);
			return;
		endif;
		
		if not aVessel.canUserAccessSelf(null, failedDAC,app.myPassport) then
			app.msgBox("You do not have access rights to the Vessel for this voyage!", "Vessel Error", MsgBox_Exclamation_Mark_Icon + MsgBox_OK_Only);
			return;
		endif;
		
		tmpVesselCell	:=	aVessel.myCellularVesselStructure;
		
		if tmpVesselCell = null then
			app.msgBox("Cannot find Vessel for this voyage!", "Vessel Error", MsgBox_Exclamation_Mark_Icon + MsgBox_OK_Only);
			return;
		endif;		
	else
		return;
	endif;
	
	theFrame	:=	self.frmBayCopy;
	
	if theFrame.visible then
		return;
	endif;
	
	// ### Build Vessel Combo
	self.cmbBayCopyVessel.clear();
	self.cmbBayCopyVessel.sorted	:=	false;
	
	if aVessel &lt;&gt; null then
		foreach aBay in tmpVesselCell.allBaysByOrdinal do
			self.cmbBayCopyVessel.addItemObject(aBay.id, aBay);
		endforeach;
	endif;	
	
	// ### Build Voyage Combo
	self.cmbBayCopyVoyage.clear();
	self.cmbBayCopyVoyage.sorted	:=	false;
	
	foreach aBay in structure.allBayVoyagesByOrdinal do
		self.cmbBayCopyVoyage.addItemObject(aBay.id, aBay);
	endforeach;
	
	theFrame.visible	:=	true;
	theFrame.zOrder(1);
	theFrame.centreWindow();
	self.cmbBayCopyVessel.setFocus();
end;</source>
    </JadeMethod>
    <JadeMethod name="showBayIDFrame" id="8dde5ae9-d01f-4d49-b56e-b1b18ad369b1">
        <source>showBayIDFrame();
// ---------------------------------------------------------------------------
// Created:		November 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	aBay : CM_Bay;
	structure : CM_CellularVoyageStructure;	
begin
	if self.myCurrentVoyage &lt;&gt; null then
		structure := self.myCurrentVoyage.myCellularVoyageStructure;
	endif;
	if self.frmGetBayID.visible then
		return;
	endif;
	self.txtGetBayID.text := null;
	self.frmGetBayID.visible := true;
	// ### Build Voyage Combo
	self.cmbgetBayIDBays.clear;
	if structure &lt;&gt; null then
		foreach aBay in structure.allBayVoyagesByOrdinal do
			self.cmbgetBayIDBays.addItemObject(aBay.id,aBay);
		endforeach;
	endif;
	self.frmGetBayID.zOrder(1);
	self.frmGetBayID.centreWindow();
	self.txtGetBayID.setFocus();

end;</source>
    </JadeMethod>
