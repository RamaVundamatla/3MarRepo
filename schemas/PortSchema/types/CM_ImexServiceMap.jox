    <JadeMethod name="getContentsMap" id="e0dadb75-8b3e-42f0-8f9e-bdb511df9b4d">
        <source>getContentsMap(ti : CM_TrackedItem) : CM_ContentsMap;

vars
	cns : CM_ContentsMap;

begin

	if ti.isKindOf(CM_Container) then
		cns := contentsMaps[ti.CM_Container.contentsStatus];
	endif;

	if cns = null then
		cns := contentsMaps[TI_CONTENTS_STATUS_NULL];
	endif;

	return cns;

end;</source>
        <Parameter name="ti" type="CM_TrackedItem"/>
        <ReturnType type="CM_ContentsMap"/>
    </JadeMethod>
    <JadeMethod name="getContentsMapFromTransaction" id="5a6653c6-e8eb-4c90-ae4a-fd6a8b97dfe9">
        <source>getContentsMapFromTransaction(_tran : CM_TITransaction) : CM_ContentsMap;
// ---------------------------------------------------------------------------
// Created:		December 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// Date			Who		Reason
// 23 Oct 2024	navlw1	JIRA-33107: Invoice Logging Use Levels
// 25 Feb 2025	navah1	Story 34141: MTN - Performance Improvements - Review for invLog() Methods
vars
	csDesc		: String;
	cns 		: CM_ContentsMap;
	cs 			: CM_ContentsStatus;
	canLogExtra : Boolean;	//26.02.2025 navah1	#34141
begin
	canLogExtra	:= app.canLogExtraDetail();				//26.02.2025 navah1	#34141
	
	if _tran.contentsStatus &lt;&gt; null then 				//5.3.2025 navma1	#34141
		cns := contentsMaps[_tran.contentsStatus];
		if cns &lt;&gt; null then								
			cs := app.myRoot.allContentsStatuses[_tran.contentsStatus];
			if cs = null then
				csDesc := "Unknown Contents Status";
			else
				csDesc := cs.description;
			endif;
			if canLogExtra then	//26.02.2025 navah1	#34141
				app.invLog("Contents status map found for " &amp; csDesc, LogINFO.String);
			endif;
		endif;
	endif;

	if cns = null then
		if canLogExtra then	//26.02.2025 navah1	#34141
			app.invLog("Contents status map for DEFAULT", LogINFO.String);
		endif;
		cns := contentsMaps[TI_CONTENTS_STATUS_NULL];
	endif;

	return cns;

end;</source>
        <Parameter name="_tran" type="CM_TITransaction"/>
        <ReturnType type="CM_ContentsMap"/>
    </JadeMethod>
    <JadeMethod name="getImexStatus" id="402f0139-4d2a-422e-85ef-2673c62995a9">
        <source>getImexStatus() : CM_IMEXStatus;

vars
	imexStatus	: CM_IMEXStatus;
begin
	if self.imexStatus &lt;&gt; CM_ImexServiceMap.DEFAULT_IMEX_MAP then
		imexStatus := app.myRoot.allImexStatuses[self.imexStatus];
	endif;
	
	return imexStatus;
end;
</source>
        <ReturnType type="CM_IMEXStatus"/>
    </JadeMethod>
    <JadeMethod name="getPath" id="f3b02a09-52da-4c65-b71f-51e1fa666a93">
        <source>getPath() : String;
// 32311
vars
	path	: String;
begin
	if self.imexStatus = CM_ImexServiceMap.DEFAULT_IMEX_MAP then
		path := "Default (ImEx)";
	else
		path := self.imexStatusString;
	endif;
	return self.myProductMap.getPath() &amp; "/" &amp; path;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
