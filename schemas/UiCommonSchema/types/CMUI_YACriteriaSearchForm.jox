    <JadeMethod name="initializeControls" id="ca3e87ca-dc6b-4f34-b648-c78a23b8799e">
        <source>initializeControls();

/*

Purpose:			

Parameters:			

Return Value:		


Date				Who		Reason
04 September 2008	consw1	Initial creation

*/

vars

begin
	self.btnCancelBase.visible := false;
	self.btnSaveBase.visible := false;
	
	self.frmCriteria.visible := false;
	
	// ### TFS CR 55645 TASK 55662 19DEC2022 NAVAB1
	if self.mySearchParameters.isKindOf(CMIF_YACriteriaSearchContract) then
		self.grpStatus.visible := false;
		self.btnDoSearch.caption := app.getErrorString(This_crieria); // 'Use This Crieria';
		self.btnDoSearch.width := 120;
		self.btnDoSearch.left := self.btnDoSearch.left - 40;
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="loadCriteriaFrames" id="7508b311-b99b-4c8b-9ac3-a7bbb97a355f">
        <source>loadCriteriaFrames();

/*

Purpose:		Load Controls for search frame

Parameters:			

Return Value:		


Date				Who		Reason
04 September 2008	consw1	Initial creation

*/

vars
	i: Integer;
	top, left, height, width: Integer;
	criteriaFrame : CMUI_YACriteriaCntl;
	criteria: CM_YACriteria;
	cmifCriteria: CMIF_YACriteriaPriority;
	criterias: Iterator;
	cntlTabIndex: Integer;
	
begin

	top :=  1; 
	left := 1; 
	height := ((self.grpAllCriteria.height - 10) / 10).Integer;
	width := (self.grpAllCriteria.width / 2).Integer;

	cntlTabIndex := self.frmCriteria.tabIndex;

	// Load up the criteria controls max of 20 criteria
	foreach i in 1 to MAX_CRITERIA do 
		if (i = (MAX_CRITERIA / 2) + 1) then
			left := width;	// second column
			top := 1;
		endif;
		criteriaFrame := self.frmCriteria.loadControl(i).CMUI_YACriteriaCntl;
		criteriaFrame.setWidth(width);			
		criteriaFrame.setTabIndex(cntlTabIndex);
		criteriaFrame.move(left, top, width, height);
		criteriaFrame.visible := true;
		criteriaFrame.tag := "true";	// to active three-state booleans 23 Mar 2015	NDL	Par 35886
		top := top + height;
	endforeach;

	self.frmCriteria.visible := false;
	
epilog
	delete criterias;
end;
</source>
    </JadeMethod>
    <JadeMethod name="populateCriteriaFrames" id="47a653dc-55e0-4f1b-9daf-b16274f5e386">
        <source>populateCriteriaFrames( _criteriaArray : CMIF_Array );

/*

Purpose:			

Parameters:			

Return Value:		


Date				Who		Reason
04 September 2008	consw1	Initial creation

*/

vars
	cmifCriteria	: CMIF_YACriteriaPriority;
	criteria		: CM_YACriteria;
	criteriaFrame	: CMUI_YACriteriaCntl;
	i				: Integer;
	iterCriteria	: Iterator;
	
begin
	if self.frmCriteria.getControl(1) = null then
		self.loadCriteriaFrames();
	endif;

	if _criteriaArray &lt;&gt; null then
		iterCriteria := _criteriaArray.createIterator;
	endif;

	foreach i in 1 to MAX_CRITERIA do 
		criteriaFrame := self.frmCriteria.getControl(i).CMUI_YACriteriaCntl;
		criteriaFrame.setMasterControl(self.frmCriteria);	//cnwmc5 - PAR 31255	
		if iterCriteria &lt;&gt; null and iterCriteria.next(cmifCriteria) then
			criteria := cmifCriteria.CMIF_YACriteriaPriority.myProxy.CM_YACriteria;
			criteriaFrame.setCriteria( criteria );
		else
			criteriaFrame.setCriteria( null );
		endif;
	endforeach;
	
epilog
	delete iterCriteria;
end;</source>
        <Parameter name="_criteriaArray" type="CMIF_Array"/>
    </JadeMethod>
    <JadeMethod name="populateDefaultCriteria" id="abda54b7-7706-4f14-ad5b-053da7076980">
        <source>populateDefaultCriteria();

/*

Purpose:		Populate form with default search criteria

Parameters:			

Return Value:		


Date				Who		Reason
05 September 2008	consw1	Initial creation

*/

vars
	cmifCriteria 	: CMIF_YACriteriaPriority;
	criteriaColl	: CMIF_Array;
	criteriaValue	: String;
	criteriaType 	: CM_YACriteriaType;
	itemCode 		: String;
	proxyCriteria	: CM_YACriteria;
	yaConfig		: CM_YAConfig;

begin
	create criteriaColl transient;
	
	yaConfig := self.myTerminal.myYAConfig;

	if yaConfig = null then
		return;
	endif;
	
	foreach criteriaType in yaConfig.allDefaultSearchCriteriaTypes do
		itemCode := criteriaType.description.cnEcUpto(CM_YACriteriaPriority::code.length -1);
		criteriaValue := null;
		if criteriaType.isBooleanType() then
			criteriaValue := CM_YADataBoolean.VALUE_FALSE.String;
		endif;
		create proxyCriteria transient;
		proxyCriteria.setProxy(criteriaType, criteriaValue, itemCode);
		cmifCriteria := proxyCriteria.getTransient();
		criteriaColl.add(cmifCriteria);
	endforeach;
	
	self.populateCriteriaFrames( criteriaColl );

epilog
	if criteriaColl &lt;&gt; null then
		criteriaColl.purge();
	endif;
	delete criteriaColl;
end;</source>
    </JadeMethod>
    <JadeMethod name="populateYACriteria" id="6917ee25-05d5-4c81-9772-146b0a54f8d4">
        <source>populateYACriteria( _yardAllocation : CM_YardAllocation );

/*

Purpose:			Populate form with criteria from given yard allocation

Parameters:			

Return Value:		


Date				Who		Reason
08 September 2008	consw1	Initial creation

*/

vars
	criteria		: CM_YACriteria;
	criteriaColl	: CMIF_Array;
	cmifCriteria	: CMIF_YACriteriaPriority;
	proxyCriteria	: CM_YACriteria;
	
begin
	if _yardAllocation = null then
		self.populateDefaultCriteria();
		return;
	endif;
	
	create criteriaColl transient;

	foreach criteria in	_yardAllocation.allCriteria do
		create proxyCriteria transient;
		proxyCriteria.setProxy(criteria.myYACriteriaType, criteria.myYAData.getDataValue(), criteria.code);
		cmifCriteria := proxyCriteria.getTransient();
		criteriaColl.add(cmifCriteria);
	endforeach;

	self.populateCriteriaFrames( criteriaColl );

epilog
	if criteriaColl &lt;&gt; null then
		criteriaColl.purge();
	endif;
	delete criteriaColl;
end;</source>
        <Parameter name="_yardAllocation" type="CM_YardAllocation"/>
    </JadeMethod>
    <JadeMethod name="set" id="50d15a07-2cea-41ff-bd80-a709c1782aab">
        <updating/>
        <source>set( _searchParams : CMIF_YACriteriaSearch ) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date				Who		Reason
05 September 2008	consw1	Initial creation

*/

vars

begin
	self.mySearchParameters := _searchParams;
	
	if self.mySearchParameters.allSearchCriteria.isEmpty then
		self.populateDefaultCriteria();
	else
		self.populateCriteriaFrames( self.mySearchParameters.allSearchCriteria );
	endif;

	self.optStatusActive.value 	:= true;
	self.optStatusDisable.value := self.mySearchParameters.includeDisabled;
	self.optStatusAll.value 	:= self.mySearchParameters.includeDisabled and self.mySearchParameters.includeActive;

epilog

end;</source>
        <Parameter name="_searchParams" type="CMIF_YACriteriaSearch"/>
    </JadeMethod>
