    <JadeMethod name="setControlsForAddEdit" id="b34c0cf3-fc90-4c33-976f-346907755cb6">
        <updating/>
        <source>setControlsForAddEdit() updating;


//28/08/2018	JLGNS1	Bug 40008: PEN - Restrict Operator Issue
//12/05/2022 navhl20 TFS 53430  EUP - Sub Carrier registration in MTN
vars
	theForm : SOP_TableMaintForm;

begin
  
	theForm := self.myForm;
	theForm.tblInput1.userInputEnabled 	:= true;
	theForm.tblData4.enabled 			:= false;		
	theForm.mulSelect1.userInputEnabled := true;
	theForm.btnAddNew.enabled 			:= true;
	theForm.txtName.enabled 			:= true;
	theForm.txtName.readOnly			:= false;
	theForm.txtEmailName.enabled 		:= true;
	theForm.txtEmailName.readOnly		:= false;
	
	if theForm.mode = theForm.Mode_Add then
	 	theForm.tblData4.clearAllData();
		theForm.tblInput1.clearValues;
		theForm.tblInput1.enableRowByName(ETRow_Code);
		theForm.tblInput1.enableRowByName(ETRow_Description);
		theForm.tblInput1.disableRowByName(ETRow_Vehicles);
		theForm.tblInput1.enableRowByName(ETRow_IsRail);		//+ cnwmd1, CCMS 1067, Par 19710
		theForm.tblInput1.enableRowByName(ETRow_IsRoad);		//+ cnwmd1, CCMS 1067, Par 19710
		theForm.tblInput1.enableRowByName(ETRow_IsSubCarrier);		//12/05/2022 navhl20 TFS 53430
		theForm.tblInput1.enableRowByName(ETRow_MyDebtor);		//+ cnwmd1, CCMS 1067
		theForm.cmbDebtor.setObject(null);						//+ cnwmd1, CCMS 1067
		theForm.tblInput1.setValueByName(ETRow_Colour, White.String);	// 12/6/17 MAP TFS4209
		
		//par 16236 
		theForm.shtMultiSelect1.caption := 'PIN Advice Email Addresses (' &amp; 0.String &amp; ')';
		theForm.shtViewTable1.caption := 'Vehicles (' &amp; 0.String &amp; ')';

		theForm.tblInput1.cnEcResizeContents;
		theForm.tblInput1.setFocus;
		theForm.tblInput1.moveFirst();
		theForm.tblInput1.gotFocus(theForm.tblInput1);	// sets case etc.
		theForm.fldInput.initSheetBackColors(); 
		
	else
		// refresh the data from the newly created proxy
		self.showThumbnail(theForm.myProxyObject.CM_Carrier);
		// cannot update code
		theForm.tblInput1.enableRowByName(ETRow_Code);
		theForm.tblInput1.enableRowByName(ETRow_Description);
		theForm.tblInput1.disableRowByName(ETRow_Vehicles);
		theForm.tblInput1.enableRowByName(ETRow_IsRail);		//+ cnwmd1, CCMS 1067, Par 19710
		theForm.tblInput1.enableRowByName(ETRow_IsRoad);		//+ cnwmd1, CCMS 1067, Par 19710
		theForm.tblInput1.enableRowByName(ETRow_IsSubCarrier);		//12/05/2022 navhl20 TFS 53430
		theForm.tblInput1.enableRowByName(ETRow_MyDebtor);		//+ cnwmd1, CCMS 1067
	endif;
	theForm.tblInput1.disableRowByName(ETRow_FinancialId);		//04.Mar.24 navsp1 TFS 57177
	
end;</source>
    </JadeMethod>
    <JadeMethod name="setCtrlsForView" id="013af78a-ea8b-4821-9b0b-10f7db6f25d5">
