<CollClass name="Array">
    <JadeMethod name="jtdGetRandomMember" id="ec6861e1-4960-4815-b954-d5bfb81c8f1a">
        <source>jtdGetRandomMember() : MemberType;

vars
	needEndLoad : Boolean;
	memberObj : MemberType;
	indx, selfSize : Integer;
	
begin
	if process.isInTransactionState or process.isInLoadState then
		needEndLoad := false;
	else
		beginLoad;
		needEndLoad := true;
	endif;

	sharedLock(self);

	selfSize := self.size;
	if selfSize &lt; 1 then
		return null;
	endif;

	indx := app.random(selfSize);
	if indx &lt; 1 then
		// belts and braces
		indx := 1;
	elseif indx &gt; selfSize then
		// belts and braces
		indx := selfSize;
	endif;

	return self[indx];	
	
epilog
	if needEndLoad then
		endLoad;
	endif;
end;</source>
        <ReturnType type="MemberType"/>
    </JadeMethod>
</CollClass>
