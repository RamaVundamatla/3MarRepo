    <JadeMethod name="addPortsOfCall" id="57030432-1a6d-4460-9c4e-b7a99a2708f3">
        <interfaceImplements>
            <JadeInterfaceMethod name="IF_CMUI_PortCodeSelector::addPorts"/>
        </interfaceImplements>
        <updating/>
        <source>addPortsOfCall(_objectArray : ObjectArray; _areTranshipPorts : Boolean) updating;

	/*
		this method stub has been automatically generated by Jade to satisfy interface implementation requirements
	*/
/*

Purpose:			

Parameters:			

Return Value:		


Date			Who		Reason
29 April 2009	cnwer1	Initial creation
03 Jun 2009		concms1	par 19013 - set active property
*/

vars
	obj : Object;
	port : CM_Port;
	currentIndex,
	newLevel,
	newIndex : Integer;
	displayText : String;
	theListBox : CMUI_ListBox;
	theResult : Integer;	//14 Jan 2020 NDL	TFS 46815
	
begin
	if self.myForm.mode &lt;&gt; self.myForm.Mode_Add and self.myForm.mode &lt;&gt; self.myForm.Mode_Update then
		return;
	endif;
	
	//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxUA.trxPortCodeMakeActiveInactive(_objectArray, true, app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			break;
		else
			theResult := app.showErrorWarningDialog('Make Code Active', app.myPassport, ErrWarnMode_Update);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		return;
		
	endwhile;
	
	
	theListBox:=self.myForm.lstSingleSelect1;
	currentIndex:=theListBox.listIndex;
	newIndex:=currentIndex;
	newLevel:=1;
	if _areTranshipPorts then
		if currentIndex &lt; 0 then
			return;
		endif;
		if theListBox.itemLevel[currentIndex] &lt;&gt; 1 then
			return;
		endif;
		newLevel:=2;
	else
		if currentIndex &gt; 0 and theListBox.itemHasSubItems(currentIndex) then
			newIndex:=theListBox.getNextIndexAtLevel(currentIndex,1,false);
		endif;
	endif;
	
	foreach obj in _objectArray do
		if not obj.isKindOf(CM_Port) then
			continue;
		endif;
		port:=obj.CM_Port;
		displayText:=self.myForm.myAssistant.displayEntryPort(port);
		if currentIndex &lt; 0 then
			theListBox.addTreeObject(displayText,port,newLevel,true);
		else
			theListBox.addObjectAt(displayText,newIndex+1,port,newLevel,true);
		endif;
		//theListBox.addTreeObject(displayText,port,1,true);
	endforeach;

	self.setPortsOfCallChanged(true);
epilog

end;</source>
        <Parameter name="_objectArray" type="ObjectArray"/>
        <Parameter name="_areTranshipPorts" type="Boolean"/>
    </JadeMethod>
