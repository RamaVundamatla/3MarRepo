    <JadeMethod name="initForm" id="27f62859-a41f-410d-8102-08fe5eb04d2e">
        <updating/>
        <source>initForm() updating;
/*
	Purpose:			
	Parameters:			
	Return Value:		

Date				Who		Reason
02 September 2008	concms1	User definable forms
*/
vars
	theTable 	: CM_EntryTable;
	entTableDef	: EntTableDef;
begin
	self.showDataOnStartup 		:= true; 
	self.allowMultiSelectDelete := false;
	
	self.allowAdd	 			:= true;
	self.allowDelete 			:= true;
	//self.allowFilter 			:= false;
	//self.allowPrintCurrent 		:= false;
	self.allowPrintSelected 	:= false;
	self.allowUpdate 			:= true;

	// setup form specific controls for add/editting
	self.setTblDataEntRows(ETDef_FormConfigEnquiry);
	

	//the following is needed to hide the thumbnail (not sure what useTblThumb does seemed to hide all tables
	self.isThumbnailVisible := true;//so as to make this false in the following call
	self.hideShowThumbnail();
	
	self.allowTblDataHide:=false;
epilog

end;</source>
    </JadeMethod>
