    <JadeMethod name="doLoadFromGlobalConstants" id="a72cc4ee-402c-499b-b0c6-923aee6f3d0f">
        <updating/>
        <source>doLoadFromGlobalConstants() updating;
// ---------------------------------------------------------------------------
// Created:     03 January 2002 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin

	app.mousePointer := MousePointer_HourGlass;

//	if self.myEntTableAgent.trxLoadFromGlobalConstants() then
	if self.myEntTableAgent.trxUpdateFromGlobalConstants() then
