    <JadeMethod name="showSeaView" id="5a85ab80-c0d4-4f5e-b6fc-b9ddf0706a4a">
        <source>showSeaView() protected;
//-----------------------------------------
// Created: August 2003 By: cnwgd1
//-----------------------------------------
vars
	form : HMS_SeaView;
begin
	if self.mySeaViewForm &lt;&gt; null then
		self.mySeaViewForm.setFocus();
		self.mySeaViewForm.getMovementsToAddToList();
		return;
	endif;
  	form := app.loadForm(HMS_SeaView, HMS_Assistant, false, false, true, self.myTerminal, self.myMasterMenuAction).HMS_SeaView;
