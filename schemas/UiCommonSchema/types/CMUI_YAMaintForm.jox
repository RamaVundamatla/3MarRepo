    <JadeMethod name="doNoMaintPermDisableControls" id="065d7475-d1ef-4cde-863f-766debd19aeb">
        <source>doNoMaintPermDisableControls();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
// 04/05/2023	navkc1	Bug 57484: EUP - Cargo Allocation Transaction Map Permissions

*/

vars
	control		: Control;
	idx			: Integer;
	ctrlCount	: Integer;
begin
	if app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		return;
	endif;
	
	ctrlCount := self.controlCount();
	
	foreach idx in 1 to ctrlCount do
		control := self.controls(idx);
		
		if 	control.parent.isKindOf(CMUI_YACriteriaCntl) then
			control.parent.CMUI_YACriteriaCntl.doDisableInputControls();
			
			if control.isKindOf(CMUI_OptButtonYACriteriaCtrl) then
				control.enabled := false;
			endif;
			
		elseif	control.isKindOf(TextBox) or
				control.isKindOf(CheckBox) or
				control.isKindOf(ComboBox) or
				control.isKindOf(Button) or
				control.isKindOf(OptionButton) 
				then
				control.enabled := false;
		endif;
	endforeach;
	
	self.btnCancel.enabled := true;

epilog

end;</source>
    </JadeMethod>
