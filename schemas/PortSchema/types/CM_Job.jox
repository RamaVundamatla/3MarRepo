    <JadeMethod name="setMyWorkOrderJobSheet" id="62136ac7-11eb-4957-bbd3-87343f6bbe48">
        <updating/>
        <source>setMyWorkOrderJobSheet(_workOrderJobSheet : CM_WorkOrderJobSheet)updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 Jun 2023 navma1  ChangeRequest 58296: EUP - [Framework] Delivery Dispatch Screen - Linking Road Jobs
29 May 2025	navhl20 Bug MTN-34847: MTN - 1081 (Dead loock) on CM_JobsByRequiredDTPriority
*/

vars

begin
	if _workOrderJobSheet &lt;&gt; null then											//29.05.2025 navhl20 #34847
		self.exclusiveLock(_workOrderJobSheet.allJobsByRequiredDTPriority);
	endif;
	
	self.myJobSheetForWorkOrder := _workOrderJobSheet;
	
	//jlier1 MTN-34200 11/3/24
	if self.myJobSheetForWorkOrder &lt;&gt; null and not self.isTransient then
		self.causeEvent(self.myJobSheetForWorkOrder.myTerminal.getTerminalEvent(WorkOrderJob_Update_Event), false, self);
	endif;
epilog

end;</source>
        <Parameter name="_workOrderJobSheet" type="CM_WorkOrderJobSheet"/>
    </JadeMethod>
