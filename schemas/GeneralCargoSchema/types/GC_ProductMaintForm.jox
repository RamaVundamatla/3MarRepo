    <JadeMethod name="isDuplicateCode" id="498edd19-4e0d-425f-b72b-c763d5019c08">
        <source>isDuplicateCode(_code : String) : Boolean ;
// ---------------------------------------------------------------------------
// Created:     07 October 2002 by cnwth2
//
// Purpose:     
//
// ----------   ----------  --------------------------------------------------
vars
	loopProdCode	: CM_ProductAttributeCode;
	prodAttr		: CM_ProductAttr;

begin
	prodAttr := self.myCurrentProdAttr;
	if prodAttr = null then
		return true;
	endif;
	
	foreach loopProdCode in prodAttr.allCodes do
		if loopProdCode.code = _code then
			app.msgBox('A code with this value has already been entered','Duplicate code', 0);
			self.tblEntCode.setFocus();
			self.tblEntCode.goToRowByName(ETRow_EntCode);
			return true;
			break;
		endif;
	endforeach;
		
	return false;
end;</source>
        <Parameter name="_code" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="loadCloneAttributes" id="406d529c-e73d-478b-971b-183d37bf28d8">
        <source>loadCloneAttributes();
// ---------------------------------------------------------------------------
// Created:     11 October 2002 by cnwth2
//
// Purpose:     
//
// ----------   ----------  --------------------------------------------------
vars
	cargoType	: CM_CargoType;
	pro			: CM_Product;
	prodAttrStr	: String;
	prodAttr	: CM_ProductAttr;
	attrCmb		: CMUI_ComboBox;
	idx			: Integer;
	entRow		: EntTableRow;
	entDef		: EntTableDef;
begin
	pro := self.cmbCloneProduct.listObject.CM_Product;
	if pro = null then
		return;
	endif;
	entDef := self.getAllAttributesDef;
	
	attrCmb := self.cmbCloneAttr;
	attrCmb.clear();
	cargoType := pro.myCargoType;
	
	foreach entRow in entDef.allEntTableRows do
		if cargoType.allAttributesOnProduct.includes(entRow.name) then
		// This is the new one for after 7.4.1 release	
		//if cargoType.getAttributeValue(entRow.name).Boolean then
			prodAttr := pro.getProdAttrFromName(entRow.name);
			if prodAttr.validationType = CM_ProductAttr.ValidationType_Codes then
				idx := attrCmb.addItem(prodAttr.displayName);
				attrCmb.itemObject[idx] := prodAttr;
			endif;
		endif;
	endforeach;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="loadCloneCargoTypes" id="65882100-1184-4864-b141-d911148654ec">
        <source>loadCloneCargoTypes();
// ---------------------------------------------------------------------------
// Created:     11 October 2002 by cnwth2
//
// Purpose:     
//
// Changed On	By			Reason
// ----------   ----------  --------------------------------------------------
// 07/05/2020	jlgdap1		TFS 49252 CPL Cargo Types not showing in System Admin
vars
	cargoTypeDict		: CM_CargoTypesByIdDict;
	productDict			: CM_ProductByOpCodeProCodeDict;
	cargoBOLType		: CM_CargoBOLType;
	cargoType			: CM_CargoType;
	
begin

	create cargoTypeDict transient;
	foreach cargoBOLType in app.myRoot.allCargoTypesById do
		if cargoBOLType.id &gt;= TI_CargoBOLType_Max and 
		   //cargoBOLType.id &lt; TI_CargoBOLType_JMTMax and									// TFS 49252
		   (cargoBOLType.id &lt; TI_CargoBOLType_JMTMax or app.myRoot.isClientCentrePort) and	// TFS 49252
		   cargoBOLType.isKindOf(CM_CargoType) then
			cargoTypeDict.add(cargoBOLType.CM_CargoType); 
		endif;
	endforeach;
	if not cargoTypeDict.isEmpty then
		self.cmbCloneType.listCollection(cargoTypeDict, false, 0);
		cargoType := cargoTypeDict[self.cmbEntCargoType.listObject.CM_CargoType.id];
		self.cmbCloneType.listObject := cargoType;	
	endif;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="loadCloneProducts" id="0081e96b-a13e-40d6-be24-3eeac665f923">
        <source>loadCloneProducts();
// ---------------------------------------------------------------------------
// Created:     11 October 2002 by cnwth2
//
// Purpose:     
//
// ----------   ----------  --------------------------------------------------
vars
	
	cargoType		: CM_CargoType;
	proDict			: CM_ProductByOpCodeProCodeDict;
	pro				: CM_Product;
	
begin
	cargoType := self.cmbCloneType.listObject.CM_CargoType;
	self.cmbCloneProduct.clear();
	if cargoType &lt;&gt; null then
		proDict := cargoType.allProducts;
		if not proDict.isEmpty then
			self.cmbCloneProduct.listCollection(proDict, true, 0);	
			self.cmbCloneProduct.listObject := proDict.first;
		endif;
	endif;
	
	
end;</source>
    </JadeMethod>
    <JadeMethod name="loadCodes" id="96a8ea37-2d80-47c1-b1fb-ba2982f5e6ad">
        <source>loadCodes(_prodAttr : CM_ProductAttr);
// ---------------------------------------------------------------------------
// Created:     04 October 2002 by cnwth2
//
// Purpose:     
//
// ----------   ----------  --------------------------------------------------
vars
	code	: CM_ProductAttributeCode;
	jCell	: JadeTableCell;
	idx		: Integer;
	table	: CM_DataTable;
begin
	table := self.tblAttributes;
	if table.getCellText(table.row, table.getColumnByRowName(ETRow_ValidationType)) &lt;&gt; CM_ProductAttr.ValidationType_Codes then
		return;
	endif;
	
	table.accessCell(table.row, table.getColumnByRowName(ETRow_ColumnCode)).cellControl := self.cmbCode;
	
	self.cmbCode.clear();
	self.cmbCode.addItem(Any_String);
	self.cmbCode.addItem(EditCodeString);
	
	idx := 2;
	foreach code in _prodAttr.allCodes do
		idx := idx + 1;
		self.cmbCode.addItem(code.code &amp; ' - ' &amp; code.description);
		self.cmbCode.itemObject[idx] := code;
	endforeach;
	//set the default code if the attribute has one
	if _prodAttr.validationType = CM_ProductAttr.ValidationType_Codes then
		code := _prodAttr.myCode;
		if code &lt;&gt; null then
//			cmbCode.listObject :=  code;
			// changed to this as if selected code has been changed in code edit, then an exception occurs. 
			cmbCode.listIndex := cmbCode.findObject(code);
			table.setCellText(table.row, table.getColumnByRowName(ETRow_ColumnCode), code.code);
		else
			cmbCode.listIndex := 1;
			table.setCellText(table.row, table.getColumnByRowName(ETRow_ColumnCode), Any_String);
		endif;
	endif;		
end;</source>
        <Parameter name="_prodAttr" type="CM_ProductAttr"/>
    </JadeMethod>
    <JadeMethod name="loadCombos" id="b54ba3ad-6d16-4db8-a7b2-1523aa932812">
        <updating/>
        <source>loadCombos() updating;
// ---------------------------------------------------------------------------
// Created:     02 October 2002 by cnwth2
//
// Purpose:     
//
// Changed On	By			Reason
// ----------   ----------  --------------------------------------------------
// 07/05/2020	jlgdap1		TFS 49252 CPL Cargo Types not showing in System Admin
vars
	opDict				: CM_OperatorByCodeDict;
	cargoTypeArray,
	tmpCargoTypeArray	: CM_CargoTypesByIdDict;
	handlingTypeDict	: CM_HandlingTypesByIdDict;
	cargoTypeObj		: CM_CargoType;
	cargoBOLType		: CM_CargoBOLType;
	op					: CM_Operator;
	listPointer			: Integer;
	
begin
	//////////CARGO TYPES/////////////////////////////
	create tmpCargoTypeArray transient;
	cargoTypeArray := app.myRoot.allCargoTypesById;
	
	foreach cargoBOLType in cargoTypeArray where cargoBOLType.id &gt; TI_CargoBOLType_Max do
		//if cargoBOLType.id &lt; TI_CargoBOLType_JMTMax then									// TFS 49252
		if cargoBOLType.id &lt; TI_CargoBOLType_JMTMax or app.myRoot.isClientCentrePort then	// TFS 49252
			// Added change to take care of behaviour types.
			cargoTypeObj	:=	cargoBOLType.CM_CargoType;
			
//			if cargoTypeObj.myTIBehaviourType.class = CM_TIBehaviourBreakBulkGeneric then
			if cargoTypeObj.isSubCargoTypeRequired then	// CCMS 1080 PAR 19704 July 2009
				tmpCargoTypeArray.add(cargoBOLType.CM_CargoType);
			endif;
//			endif;
		endif;
	endforeach;
	
	cargoTypeObj	:=	null;
	
	if not tmpCargoTypeArray.isEmpty() then
// cnwdad1 17/11/2005 - Changed so that the Cargo Type combobox list starts with an "All" entry.
// We can't use the displayCollection method because the findObject method will only work for
// entries that are currently visible in the list, plus we delete the collection anyway (epilog).
// So, we're now populating the combobox manually.  Each entry's itemData is set to a class
// constant value - either "..._ALL" or "..._OBJECT".
//		self.cmbFiltCargoType.listCollection(tmpCargoTypeArray, false,0);
		self.cmbFiltCargoType.clear();
		
//		listPointer	:=	self.cmbFiltCargoType.addItem(app.getErrorString(CM_LIT_ALL)); // changed so ALL entry stays at top if Product starts with aa...
//		self.cmbFiltCargoType.itemData[listPointer]	:=	self.LIST_ENTRY_ALL;
				
		foreach cargoTypeObj in tmpCargoTypeArray do
			listPointer	:=	self.cmbFiltCargoType.addItem(cargoTypeObj.description);
			self.cmbFiltCargoType.itemObject[listPointer]	:=	cargoTypeObj;
			self.cmbFiltCargoType.itemData[listPointer]		:=	self.LIST_ENTRY_OBJECT;
		endforeach;
			// add here so is at top of list. 		
		self.cmbFiltCargoType.addItemAt(app.getErrorString(CM_LIT_ALL), 1);
		self.cmbFiltCargoType.itemData[1]	:=	self.LIST_ENTRY_ALL;
	
		
		cargoTypeObj	:=	null;
		self.cmbEntCargoType.listCollection(tmpCargoTypeArray, false, 0);
	
		if (app.myCurrentCargoType &lt;&gt; null) and (app.myCurrentCargoType.id &gt; TI_CargoBOLType_Max) 
		and tmpCargoTypeArray.includes(app.myCurrentCargoType)	//in case, when cargo type was edited not to have subcargo types at the same time. CCMS 1080, PAR19704 July 2009
		then
			cargoTypeObj	:=	app.myCurrentCargoType;	
			
			cmbFiltCargoType.listObject	:=	cargoTypeObj;
			cmbEntCargoType.listObject	:=	cargoTypeObj;
			self.myFilterCargoType		:=	cargoTypeObj;
			self.loadProductGroups(cargoTypeObj);
			self.tblSearch.setValueByName(ETRow_CargoType, cargoTypeObj.description);
		else
		//02/04/2009 cnwdz2 PAR19302
		//	cargoTypeObj	:=	null;//tmpCargoTypeArray.first.CM_CargoType;
		//	app.setMyCurrentCargoType(cargoTypeObj);
			self.tblSearch.setValueByName(ETRow_CargoType, app.getErrorString(CM_LIT_ALL));
		endif;
		
		
	endif;
	
	///////OPERATORS//////////////////
	opDict := app.myRoot.allOperators;
	
	if not opDict.isEmpty then
//		self.cmbFiltOperator.displayCollection(opDict, true, 0, null, Any_String);
		self.cmbFiltOperator.displayCollection(opDict, true, 0, null, app.getErrorString(CM_LIT_ALL));
		// Handeled on gotFocus of CMUI_Combo
//		self.cmbEntOperator.listCollection(opDict, true, 0);
		
		if app.myCurrentOperator &lt;&gt; null then
			op := app.myCurrentOperator;
		else
			op := null;
			app.setMyCurrentOperator(op);
		endif;
		
		self.cmbFiltOperator.listObject := op;
		self.cmbEntOperator.setObject(op);
		self.myFilterOperator := op;
		self.tblSearch.setValueByName(ETRow_Operator, self.cmbFiltOperator.text);
	endif;
	
	//////////HANDLING TYPES//////////////////////
	handlingTypeDict := app.myRoot.allHandlingTypes;
	
	if not handlingTypeDict.isEmpty then
		self.cmbFiltHandling.listCollectionWithAny(handlingTypeDict, ETRow_Description);
		self.cmbEntHandling.listCollection(handlingTypeDict, true, 0);
		self.cmbEntHandling.listObject := handlingTypeDict.first;
	endif;
	
	
epilog
	delete tmpCargoTypeArray;
end;</source>
    </JadeMethod>
    <JadeMethod name="loadCommodities" id="58cd8618-5707-4c67-ace5-26afad0c0273">
        <source>loadCommodities(_cargoType : CM_CargoType) protected;

/*

Purpose:			Par 33720 load commodities on change of cargo type

Parameters:			

Return Value:		


Date		Who		Reason
17 March 2014	cnwjre1	Initial creation

*/

vars

begin
	if _cargoType &lt;&gt; null then
		self.myAssistant.comboBoxCommodityMultiSelected(self.cmbCommodity, _cargoType.allCommodities, null);
		self.cmbCommodity.setInitialised(true);
	endif;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_cargoType" type="CM_CargoType"/>
    </JadeMethod>
