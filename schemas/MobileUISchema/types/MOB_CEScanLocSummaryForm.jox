    <JadeMethod name="doScanEnterItem" id="30aec36c-bb77-43a9-9770-c66590b88d78">
        <updating/>
        <source>doScanEnterItem() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21 May 2009	#cnwdz2	 ccms1801

*/

vars
	id		: String;
	ti		: CM_TrackedItem;
begin
	id := self.txt_CargoID.text.trimBlanks.toUpper();
	self.locID := self.txt_LocationID.text.trimBlanks.toUpper();
	if id &lt;&gt; null then
		// Check the scanned item is validate PAR 17308
		if not self.validateCargoID(id) then
			self.txt_CargoID.text := '';
			self.txt_CargoID.setFocus();
			return;
		endif;
		
		ti := self.myMobileDataAgent.findOnsiteCargoByID(id);
		if ti = null then
			app.msgBox(app.getErrorString(Item_NotFound), "", MsgBox_OK_Only);
			return;
		endif;
		
		self.locID := ti.locationId;
	elseif self.locID = null then
		return;
	endif;
    	
	self.loadTable(tbl_Items);
	self.txt_OrderCount.text := self.getLoadCountAsString();
	self.txt_CargoID.text := '';
	self.txt_LocationID.text := '';
	self.txt_CargoID.setFocus();
epilog

end;</source>
    </JadeMethod>
