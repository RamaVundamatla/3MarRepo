    <JadeMethod name="getLocationForVehicleMove" id="fb6c9cb1-f225-4c9c-92c4-3c10bc8d5fd3">
        <source>getLocationForVehicleMove(_vehicle: CM_Vehicle): CM_YardController;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 January 2013	cnwndl1	Initial creation	Par 31102

*/

vars

	ti : CM_TrackedItem;
	job : CM_Job;
	roadJob : CM_RoadJob;
	wle : CM_WorkListEntry;
	sourceLocation : CM_LocationsController;
	ic : CM_LocationsController;

begin

	// If the cargo is targetting a vehicle controller then it must be direct delivery coming from ship...
	if _vehicle &lt;&gt; null then
	
		foreach job in _vehicle.allRoadJobs discreteLock do
			roadJob := job.CM_RoadJob;
			foreach wle in roadJob.workListEntries discreteLock do
				if wle.isReceipt then
					continue;
				endif;
				if wle.status &lt;&gt; WLE_UNACTIONED then
					continue;
				endif;
				ti := wle.myTrackedItem;
				if ti = null or not ti.directDelivery then
					continue;
				endif;
				sourceLocation := ti.myPrimaryActualLocation;
				ic := null;
				if sourceLocation &lt;&gt; null and sourceLocation.isVoyageController then
					ic := sourceLocation.getLocationForVehicleMove( _vehicle );
				endif;
				if ic &lt;&gt; null then
					return ic.CM_YardController;
				endif;
			endforeach;
		endforeach;
		
	endif;


	return inheritMethod(_vehicle);

epilog

end;</source>
        <Parameter name="_vehicle" type="CM_Vehicle"/>
        <ReturnType type="CM_YardController"/>
    </JadeMethod>
    <JadeMethod name="getMachineRuleTerminalArea" id="3d96dbd6-0eee-44d5-a24d-d9caab46c88b">
        <source>getMachineRuleTerminalArea(): CM_TerminalArea;
/*

Purpose:			

Parameters:			

Return Value:		


Date				Who		Reason
24 November 2009	cnwer1	Initial creation Par 21699
// 18/06/2010 		cnwcs4	par 24418 - change of parameters
*/

vars
	roadJob : CM_RoadJob;
begin

	if self.vehicle &lt;&gt; null and self.vehicle.myPrimaryActualLocation &lt;&gt; null then
		// once they are in the yard the vehicles primary locations terminal area is never going to be the vta
		if  self.vehicle.allRoadJobs.size &gt; 0 then
			roadJob:=self.vehicle.allRoadJobs.first.CM_RoadJob;
			
			return roadJob.getYardInterchangeArea();		// par 24418
			
		endif;
	endif;
	
	
	return null;

epilog

end;</source>
        <ReturnType type="CM_TerminalArea"/>
    </JadeMethod>
    <JadeMethod name="getMachineRuleTerminalAreaType" id="d7478fa7-c4ab-4125-9fbb-772f4e87ff8a">
        <source>getMachineRuleTerminalAreaType(): CM_TerminalAreaType;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 February 2010	cnwer1	Initial creation

*/

vars
	roadJob : CM_RoadJob;
	gateArea	: CM_GateArea;
begin

	if self.vehicle &lt;&gt; null and self.vehicle.myPrimaryActualLocation &lt;&gt; null then
		// once they are in the yard the vehicles primary locations terminal area is never going to be the vta
		if  self.vehicle.allRoadJobs.size &gt; 0 then
			roadJob:=self.vehicle.allRoadJobs.first.CM_RoadJob;
			gateArea:= roadJob.getFirstGateAreaIn;
			if gateArea &lt;&gt; null then
				return gateArea.myType;
			endif;
		endif;
	endif;		
			
	return inheritMethod();

epilog

end;</source>
        <ReturnType type="CM_TerminalAreaType"/>
    </JadeMethod>
    <JadeMethod name="getMyTerminal" id="5eab8436-0a8e-4954-951a-b52d1865eeed">
        <source>getMyTerminal(): CM_Terminal;
/*
Purpose:			

Date		Who		Reason
10 February 2022	navab1	TFS 51855
*/

vars
	vvr : CM_VehicleVisitRecord;
begin
	if self.vehicle &lt;&gt; null then
		vvr := self.vehicle.visitRecords.last();
		
		if vvr &lt;&gt; null then
			return vvr.myTerminal;
		endif;
	endif;
	
	return inheritMethod();

epilog

end;</source>
        <ReturnType type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="getMyTerminalArea" id="405b592d-8570-420f-8cba-846f5c7e15df">
        <source>getMyTerminalArea(): CM_TerminalArea;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
11 March 2010	cnwas3	par 22844

*/

vars
	ya 		 : CM_YardController;
	termArea : CM_TerminalArea;
begin
	
	termArea := self.myTerminalArea;
	
	if termArea = null and self.vehicle &lt;&gt; null then
		ya := self.vehicle.myPrimaryActualLocation;
		if ya &lt;&gt; null then
			return ya.myTerminalArea;
		endif;
	endif;
	
	return termArea;

epilog

end;</source>
        <ReturnType type="CM_TerminalArea"/>
    </JadeMethod>
