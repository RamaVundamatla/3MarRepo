    <JadeMethod name="getChanel" id="78870727-8052-4b95-8ccd-dc1949778d78">
        <source>getChanel(_btn : Button; _in : Boolean) : Integer;

vars
	chanel : Integer;
begin
	if _in then
		if _btn = self.btnBoomOpen then
			chanel := 3;
		elseif _btn = self.btnBoomClose then
			chanel := 4;
		elseif _btn = self.btnBoomStop then
			chanel := 5;
		endif;
	else
		if _btn = self.btnBoomOpen then
			chanel := 0;
		elseif _btn = self.btnBoomClose then
			chanel := 1;
		elseif _btn = self.btnBoomStop then
			chanel := 2;
		endif;
	
	endif;

		return chanel;
end;
</source>
        <Parameter name="_btn" type="Button"/>
        <Parameter name="_in" type="Boolean"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
