    <JadeMethod name="jadescriptCSTestStringCompare" id="e741ff11-7575-48ee-9818-779d946b84d1">
        <source>jadescriptCSTestStringCompare();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 January 2026	navcs2	Initial creation

*/

vars
	prof		: JadeProfiler;
	str1, str2,
	str3, str4	: String;
	start		: Decimal[15];
	index		: Integer;
	newWay		: Boolean;
	b1,b2 		: Boolean;
	dts,dte : Decimal[19];
    s,t,u,v : String;
	reps : Integer;
begin
	newWay := false;
	
	app.myRoot.startJadeProfiler(prof,method.getNiceName() ,20,false,'CS',start);
	
	write CrLf &amp; "Starting...";
    reps   := 30000;  // adjust this to get a run length of 1 to 10 seconds

    dts    := app.relativeMachineTime;
	
	write 'Start Time :' &amp; app.actualTimeAppServer.String;
	foreach index in 1 to reps do
		if newWay then
			// To test new method
			str1 := self.randomString(5);
			str2 := self.randomString(5);
			str3 := "Hell@";
			str4 := "Hell@";
			b1 := str1.isEqualIgnoreCase(str2);
			b2 := str3.isEqualIgnoreCase(str4);
		else
			// To test using toUpper like a lot of the codebase
			str1 := self.randomString(5);
			str2 := self.randomString(5);
			str3 := "Hello";
			str4 := "Hello";
			b1 := str1.toUpper() = str2.toUpper();
			b2 := str3.toUpper() = str4.toUpper();
		endif;
		
		/*
		// To test using the  jade compareEql method
		str1 := self.randomString(5);
		str2 := self.randomString(5);
		str3 := "Hello";
		str4 := "Hello";
		write str1.compareEql(str2, true, false, null);
		write str3.compareEql(str4, true, false, null);
		*/
	endforeach;
	
	write 'End Time : ' &amp; app.actualTimeAppServer.String;
    dte := app.relativeMachineTime;
    write "&lt;" &amp; s &amp; "&gt;" &amp; "&lt;" &amp; t &amp; "&gt;";  // to verify the functional results
    write ((dte-dts)/reps).roundedTo(6).String &amp; " ms/rep";
epilog
    write "Finished";
	app.myRoot.stopJadeProfiler(prof, start);
end;</source>
    </JadeMethod>
    <JadeMethod name="jobsheet" id="ec8b871d-969c-4b25-8366-67fcf0f5a63c">
        <source>jobsheet();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 November 2023	navhl20	Initial creation

*/

vars
	iter 			: Iterator;
	term			: CM_Terminal;
	jobSheet		: CM_WorkPointJobSheet;
	workPointType	: CM_WorkPointType;
	type			: String;
begin
	term := app.myRoot.allTerminals['WO'];
	iter := term.allJobSheetsForWorkPoints.createIterator;
	type := "4";
	
	while iter.next(jobSheet) do
		
		if workPointType &lt;&gt; null then
			if jobSheet.getWorkPointType() &lt;&gt; workPointType then
				continue;
			endif;
		else
			if jobSheet.getWorkPointType().type &lt;&gt; type.Integer then
				continue;
			endif;
		endif;
		write jobSheet.externalName;
	endwhile;
epilog

end;</source>
    </JadeMethod>
