    <JadeMethod name="isCoastal" id="4ccd8803-5202-4024-8450-50244bb5be21">
        <source>isCoastal() : Boolean;
// ---------------------------------------------------------------------------
// Created:     30 August 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	myPort	: CM_Port;
	disPort : CM_Port;
begin
	//myPort := app.myRoot.allPorts[self.myTerminal.getConfig(PortDestCode).String];
	//disPort := app.myRoot.allPorts[self.dischargePort];
	
	myPort := app.myRoot.allPorts[self.myTerminal.getConfig(PortDestCode).String];
	disPort := app.myRoot.allPorts[self.dischargePort];
	
	if myPort &lt;&gt; null and 
	   disPort &lt;&gt; null and 
	   myPort.myCountry &lt;&gt; null	and 
	   (myPort.myCountry = disPort.myCountry) then
		return true;
	endif;
	
	return false;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isEmpty" id="6c4aef2e-b3ff-415f-bf87-ee2b2384b7d6">
        <methodInvocation>mapping</methodInvocation>
        <source>isEmpty(set: Boolean; _value: Boolean io) mapping;

vars

begin
	if set then
		app.raiseSetVirtualError(class.name, method.name);
		return;
	else
		_value := (self.contentsStatus = TI_CONTENTS_STATUS_EMPTY);
	endif;

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Boolean" usage="io"/>
    </JadeMethod>
    <JadeMethod name="isHazardous" id="59c0ac15-c539-4c50-9bc8-85f966ae8005">
        <methodInvocation>mapping</methodInvocation>
        <source>isHazardous(set: Boolean; _value: Boolean io) mapping;
// ---------------------------------------------------------------------------
// Created:     10 September 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
/*

Date		Who		Reason
19 May 2010	cnwkpd1	PAR #20728 - remove isValidObject calls for performance
08/03/2011	cnwmh5	PAR #27142 - Change to local variable rather than self for handleDeleteObject exception
*/

vars
	invalid 		: Boolean;
	sShotOf			: CM_Object;
begin
	if set then
		app.raiseSetVirtualError(class.name, method.name);
	else
		sShotOf := self.snapShotOf;
		if sShotOf &lt;&gt; null then
			on Exception do app.handleDeletedObject(exception, sShotOf, invalid);
			_value := sShotOf.CM_TrackedItem.isHazardous;
		endif;
	endif;
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Boolean" usage="io"/>
    </JadeMethod>
    <JadeMethod name="isOverDimensions" id="107e821f-29b2-4285-ba85-c5be6d85b01b">
        <methodInvocation>mapping</methodInvocation>
        <source>isOverDimensions(_set: Boolean; _value: Boolean io) mapping;

/*

Date		Who		Reason
19 May 2010	cnwkpd1	PAR #20728 - remove isValidObject calls for performance

*/

vars
	ti : CM_TrackedItem;
	invalid : Boolean;
	
begin

	if _set then 
		app.raiseSetVirtualError(class.name, method.name);
		return; 
	endif;
	_value := false;

	if self.snapShotOf = null then
		return;
	endif;

	if not snapShotOf.isKindOf(CM_TrackedItem) then
		return;
	endif;

	if self.myUserTISnapShot &lt;&gt; null then
		_value := self.myUserTISnapShot.isOD;
		return;	
	endif;

	ti := snapShotOf.CM_TrackedItem;
	on Exception do app.handleDeletedObject(exception, ti, invalid);
	_value := ti.isOverDimensions;

end;</source>
        <Parameter name="_set" type="Boolean"/>
        <Parameter name="_value" type="Boolean" usage="io"/>
    </JadeMethod>
    <JadeMethod name="isOverridden" id="e0b09947-fcca-4f33-8fb7-fbdad6ab3a6b">
        <source>isOverridden() : Boolean;
/* ---------------------------------------------------------------------------
Created:     09 June 2009 by cnwrs2

Purpose:     Returns true if user has overridden with a user TI SnapShot (PAR 15848)
        
Change Date	Who		Reason

------------------------------------------------------------------------------*/
vars

begin
	return (self.myUserTISnapShot &lt;&gt; null);
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isReefer" id="39c39cb7-4b5c-4412-84a7-fc998127f72c">
        <methodInvocation>mapping</methodInvocation>
        <source>isReefer(_set: Boolean; _value: Boolean io) mapping;

begin
	if _set then
		app.raiseSetVirtualError(class.name, method.name);
		return;
	endif;
	_value := (self.requiresPower or self.requiresTemperature);
	
end;</source>
        <Parameter name="_set" type="Boolean"/>
        <Parameter name="_value" type="Boolean" usage="io"/>
    </JadeMethod>
    <JadeMethod name="isUserGenerated" id="5cb29df0-c256-4308-bfea-3061b06648c9">
        <source>isUserGenerated(): Boolean;
//----------------------------------------------------------------
//	Created:	11 May 2006	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin

	// Deliberately leave this as myTransaction, and not getMyTransaction.
	// If user generated should be sub-class but leave old code here in
	// case of legacy data.  This method reimplemented on sub-class (PAR 15848)
	if self.myTransaction &lt;&gt; null then
		return false;
	endif;
	
	//user generated snap shots don't have transactions
	return true;


end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="linkSnapShotsParentChild" id="b7314fa3-fd1c-46e9-967b-70f80828d104">
        <source>linkSnapShotsParentChild(_parent : CM_TrackedItem; _transType : Integer);
/*

Purpose:			// TFS 40632

Parameters:			

Return Value:		

Date		Who		Reason
04 September 2018	jlgab1	Initial creation

*/

vars
	childSnapShot : CM_TISnapShot;
	childTrans : CM_TITransaction;
	child : CM_TrackedItem;

begin
		self.allChildSnapShots.clear();
		
		if not _parent.isParent() then
			return;
		endif;
		
		foreach child in _parent.allChildren discreteLock do
			childTrans := child.getLastTransOfType(_transType).CM_TITransaction;
			if childTrans&lt;&gt; null then
				childSnapShot := childTrans.mySnapShot.CM_TISnapShot;
				if childSnapShot &lt;&gt; null then
					self.allChildSnapShots.add(childSnapShot);
				endif;
			endif;
		endforeach;

epilog

end;</source>
        <Parameter name="_parent" type="CM_TrackedItem"/>
        <Parameter name="_transType" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="loadPort" id="b4d8f450-597e-4dbe-ae60-bc003542baa0">
        <methodInvocation>mapping</methodInvocation>
        <source>loadPort(set: Boolean; _value: String io) mapping;
// cnwrs1 June 2006 protected the old 3 digit codes
vars
	port : CM_Port;
begin
	if not set then
		if self.loadPort.length = 3 then
			port := app.myRoot.allLocodesByShortCode.getAtKeyGeq(self.loadPort, null);
			if port &lt;&gt; null and port.portCode = self.loadPort then
				_value := port.code;
			else
				_value := self.loadPort;
			endif;
		else
			_value := self.loadPort;
		endif;
	endif;
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="String" usage="io"/>
    </JadeMethod>
