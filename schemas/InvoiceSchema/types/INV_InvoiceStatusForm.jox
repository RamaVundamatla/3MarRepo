    <JadeMethod name="setProxyFromTable" id="e701097b-2b84-4c06-8a96-0a6d527f7858">
        <source>setProxyFromTable(pxyInvStatus : CM_InvoiceStatus input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 February 2019	jlgab1	Initial creation
29 Nov 2022 navvt20  CR 55298 TASK 55548: UI - Add Colour to Invoice Status maintenance.
*/

vars
	description : String;
	colour 		: Integer; // 29 Nov 2022 navvt20 TFS 55548
begin
	description := self.tblEntDetail.getValueByName(ETRow_Description).String;
	colour := self.tblEntDetail.getValueByName(ETRow_Colour).Integer; //29 Nov 2022 navvt20 TFS 55548
	//pxyInvStatus.setProxy(pxyInvStatus.id, pxyInvStatus.priority, description, pxyInvStatus.myInvoiceProcess,null); //29 Nov 2022 navvt20 TFS 55548
	pxyInvStatus.setProxy(pxyInvStatus.id, pxyInvStatus.priority, description, pxyInvStatus.myInvoiceProcess,colour,null); // 29 Nov 2022 navvt20 TFS 55548

epilog

end;</source>
        <Parameter name="pxyInvStatus" type="CM_InvoiceStatus" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setupPermissions" id="18fd95c8-baee-40b7-9ac7-ebbea3849051">
        <updating/>
        <source>setupPermissions() updating;
/*
Purpose:	TFS 39618		
Date				Who			Reason
JANUARY 2019		CNWAB1		Initial creation
*/
vars
	canEdit		: Boolean;
begin
	
	canEdit := app.myPassport.myUser.canDo(null, self.permissionMaint);

	// does the user have maintenance premission for this form
	self.allowAdd		:= false;
	self.allowDelete	:= false;
	self.allowUpdate 	:= canEdit;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="showThumbnailData" id="97536a73-c2af-43a7-9bbf-508d613486b4">
        <updating/>
        <source>showThumbnailData(_status : CM_InvoiceStatus) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 February 2019	jlgab1	Initial creation
29 Nov 2022 navvt20  CR 55298 TASK 55548: UI - Add Colour to Invoice Status maintenance.
*/

vars

	theTable		: CM_ThumbnailTable;
	rowNumber		: Integer; //29 Nov 2022 navvt20 TFS 55548
begin
	theTable := self.tblThumb;

	self.tblThumb.rows := 0;
	self.tblThumb.columns := 2;
	self.showThumbnailForDef(ETDef_InvoiceStatusThumb, _status);
	// Start 29 Nov 2022 navvt20 TFS 55548
	rowNumber:=self.tblThumb.getRowFromHeading(self.tblEntDetail.getHeadingByName(ETRow_Colour));
	if(rowNumber &gt; 0) then 
        self.tblThumb.accessCell(rowNumber,2).text :="";
        self.tblThumb.accessCell(rowNumber,2).backColor := _status.colour;
        self.tblThumb.accessCell(rowNumber,2).foreColor := _status.colour.getInverseColour();
    endif;
	// End 29 Nov 2022 navvt20 TFS 55548
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.btnEditTV.enabled := false;
		self.btnSaveBase.enabled := false;
	endif;

epilog

end;</source>
        <Parameter name="_status" type="CM_InvoiceStatus"/>
    </JadeMethod>
    <JadeMethod name="tblDataShowDataSpecial" id="be88a09d-f5a4-4d13-b56d-2c56ef6c632f">
        <source>tblDataShowDataSpecial(_idxRow: Integer; _obj: Object);
/*

Purpose:            

Parameters:            

Return Value: 
       
Date            Who            Reason
29 Nov 2022 	navvt20 	   CR 55298 TASK 55548: UI - Add Colour to Invoice Status maintenance.
*/
vars
    lInvoiceStatus : CM_InvoiceStatus;
    cell     	   : JadeTableCell;
    colourColumn   : Integer;
begin
    colourColumn := self.tblData.getColumnByRowName(ETRow_Colour);
    lInvoiceStatus := _obj.CM_InvoiceStatus;
    if(_idxRow &lt;&gt; 1) then
        if colourColumn &gt; 0 then    
            cell := self.tblData.accessCell(_idxRow,colourColumn);
            cell.text := null;            
            cell.backColor := lInvoiceStatus.colour;
        endif;
    endif;
    
end;
</source>
        <Parameter name="_idxRow" type="Integer"/>
        <Parameter name="_obj" type="Object"/>
    </JadeMethod>
    <JadeMethod name="tblEntDetail_dblClick" id="2bfb4558-869b-4445-aa64-2b4068f64dc8">
        <controlMethod name="CM_EntryTable::dblClick"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblEntDetail_dblClick(table: CM_EntryTable input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 February 2019	jlgab1	Initial creation

*/

vars
	row	: Integer;

	entTable	: CM_EntryTable;
	calculationType	: CM_CalculationType;
begin

	entTable := table.CM_EntryTable;
	row := entTable.getRow(ETRow_EmailOptions);
	if table.row = row and row &gt; 0 then
			self.doShowEmailForm();
	endif;


epilog

end;</source>
        <Parameter name="table" type="CM_EntryTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="f3b6c4e8-a451-4de6-8dff-5a5adda5302c">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 01 February 2019 15:39:07.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0023199, locale);
end;</source>
    </JadeMethod>
</GUIClass>
