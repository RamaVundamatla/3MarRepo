    <JadeMethod name="validateCodesForSave" id="088afe75-7784-41c5-a22f-5f8c9ff3c579">
        <source>validateCodesForSave() : Boolean;
// ---------------------------------------------------------------------------
// Created:     22 September 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars
	searchCode , strProdAttrCode, errStr	: String;
	tmpTable : CM_DataTable;
	col, idx, idx2, row, numRows : Integer;
	blnDuplicate : Boolean;

begin
	tmpTable := self.tblCodeData;

	row := self.tblCodeData.fixedRows + 1;
	numRows := self.tblCodeData.rows;
	col := tmpTable.getColumnByRowName(ETRow_EntCode);
	
	
	foreach idx in row to numRows do
		searchCode := tmpTable.accessCell(idx, col).text;	
		// search through table row after current row
		if searchCode.length &gt; 10 then 
			app.msgBox('Code values must be 10 Characters or less. Code "' &amp; searchCode &amp; '" needs to be changed','Max Code Length 10 Characters', 0);
			tmpTable.row := idx;		
			return true;
		endif;
		
		foreach idx2 in idx + 1 to numRows do
			strProdAttrCode := tmpTable.accessCell(idx2 , col).text;	
		
			if strProdAttrCode = searchCode then
				blnDuplicate := true;
				errStr := errStr &amp; strProdAttrCode &amp; ', ';  
//				keep checking so can return list				
//				return true;
//				break;
			endif;
			
			if idx2 = numRows then
			// reached last row
				break;
			endif;	
		endforeach;				
	endforeach;
	
	if blnDuplicate then 
		app.msgBox('The following codes have duplicates; ' &amp; CrLf &amp; CrLf &amp; errStr &amp; CrLf &amp; CrLf &amp;  'These will need to be changed before you can save.','Duplicate codes', 0);
		return true;
	else
		return false;
	endif;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateNewCode" id="8cd6a688-3993-4f39-80ef-6cd315deac28">
        <source>validateNewCode(_strCode	: String; _updateRow : Integer) : Boolean;
// ---------------------------------------------------------------------------
// Created:     24 August 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars
	strProdAttrCode	: String;
	tmpTable : CM_DataTable;
	col, idx, row, numRows : Integer;

begin
	tmpTable := self.tblCodeData;

	row := self.tblCodeData.fixedRows + 1;
	numRows := self.tblCodeData.rows;
	col := tmpTable.getColumnByRowName(ETRow_EntCode);
	
	
	foreach idx in row to numRows do
		strProdAttrCode := tmpTable.accessCell(idx, col).text;	
			if strProdAttrCode = _strCode and _updateRow &lt;&gt; idx then
			// if code is same and row is not same then there is a duplicate.
			// may be self so continue
				app.msgBox('A code with this value has already exsists','Duplicate code', 0);
	//			self.tblEntCode.setFocus();
	//			self.tblEntCode.goToRowByName(ETRow_EntCode);
				return true;
				break;
			endif;
	endforeach;
		
	return false;
end;</source>
        <Parameter name="_strCode" type="String"/>
        <Parameter name="_updateRow" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</GUIClass>
