    <JadeMethod name="mwtt_ReadReadyEvent" id="115fb233-e711-4f8e-ab72-77eb2df6e5ec">
        <interfaceImplements>
            <JadeInterfaceMethod name="JadeMultiWorkerTcpTransportIF::readReadyEvent"/>
        </interfaceImplements>
        <source>mwtt_ReadReadyEvent(listener : JadeMultiWorkerTcpTransport input; conn : JadeMultiWorkerTcpConnection input);

	/*
		this method stub has been automatically generated by Jade to satisfy interface implementation requirements
	*/

/*

Purpose:			Receives the "ReadReady" event from the TCP Interface, reads the incoming data, calls the
					interface agent to process the message, and returns the result to the caller

Parameters:			Transport and connection

Return Value:		None


Date		Who		Reason
02 Sep 2008	cnwkpd1	PAR #17832 - Development of CCMS JMTCP01 1024 - Voice Recognition
25 Jun 2015	cnwkpd1	PAR #36286 - Changes for Unicode JADE 

*/

constants
	InputDelim			= #[0D 0A 0A];			// Cr &amp; Lf &amp; Lf (ANSI)
	OutputDelim			= #[0D 0A 0D 0A];		// Cr &amp; Lf &amp; Cr &amp; Lf (ANSI)
	
vars
	inputData,
	outputData		: Binary;
	inputString,
	outputString	: String;
	
begin
	app.writeLog(method.qualifiedName &amp; " " &amp;
					"listener=" &amp; listener.String &amp; " " &amp;
					"conn=" &amp; self.getDiagDescriptionForConn( conn ), LogDEBUG);	//26 Nov 2019	NDL	TFS 47053
	
	inputData := conn.readUntil( InputDelim, 0 );
	
	app.writeLog(method.qualifiedName &amp; " " &amp; "inputData=" &amp; inputData.display, LogDEBUG);	//26 Nov 2019	NDL	TFS 47053
	
	// Process data here
	inputString		:= inputData.ansiToString();		// PAR #36286
	outputString	:= self.myTCPInterfaceAgent.processRequestString( inputString );
	
	// Convert to ANSI binary and add message delimiter
	outputData	:= outputString.asANSI(0) &amp; OutputDelim;	// PAR #36286
	
	app.writeLog(method.qualifiedName &amp; " " &amp; "outputData=" &amp; outputData.display, LogDEBUG);	//26 Nov 2019	NDL	TFS 47053
	
	// And send reply
	conn.writeBinary( outputData );
	
epilog
	
end;</source>
        <Parameter name="listener" type="JadeMultiWorkerTcpTransport" usage="input"/>
        <Parameter name="conn" type="JadeMultiWorkerTcpConnection" usage="input"/>
    </JadeMethod>
