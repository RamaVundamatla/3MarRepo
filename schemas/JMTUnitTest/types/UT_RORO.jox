    <JadeMethod name="tRORODeckPlanLoadAndUnload2A" id="276b3f9b-cde2-4737-88a6-00261b99f208">
        <source>tRORODeckPlanLoadAndUnload2A();
// cnwrs1 
// CCMS 1009 Plans Deck Extract Par 29024 - add children flats
/* Changes

Date		Name	TFS#		Description
============================================================================
07 Nov 2012	cnwrs1	Par 30688 OOTL layouts are missing for proposed
10 Dec 2012	cnwrs1	Par 30873	EDI RORO Deck Plan extract in location order
30 Apr 2013	cnwrs1	Par 31258 EDI RORO Deck Plan extracting OOTL containers in incorrect order
12 Jan 2015	cnwrs1	Par 35504 - Refactor EDI file load for .NET
30 Jun 2016	cnwrs1	Par 38000 extract VGM
03 Sep 2019 jlgka1 	TFS 45332 	STWR - Better Forms and Interfaces for EDI Module
============================================================================*/
constants
	UserDefinedShipManifest	= 'Unit Test RORO Baplie';
	ShipName = "JJRORO";
	VoyageName1 = "VOYSHIP31258_1";
	VoyageName2 = "VOYSHIP31258_2";
	VoyageName3 = "VOYSHIP31258_3";
	TestOperator = 'MSK';
	ContainerId01 = "OOTL9900341";
	ContainerId02 = "OOTL9900342";
	ContainerId03 = "OOTL9900343";
	ContainerId04 = "OOTL9900344";
	ContainerId05 = "OOTL9900345";
	ContainerId06 = "OOTL9900346";
	ContainerId07 = "OOTL9900347";
	ContainerId11 = "BIRU9900351";
	ContainerId12 = "BIRU9900352";
	ContainerId13 = "BIRU9900353";
	ContainerId14 = "BIRU9900354";
	ContainerId15 = "BIRU9900355";
	ContainerId16 = "BIRU9900356";
	ContainerId17 = "BIRU9900357";
	ContainerId18 = "BIRU9900358";
	ContainerId19 = "BIRU9900359";
	ContainerId20 = "BIRU9900360";
	ContainerId21 = "BIRU9900361";
	ContainerId22 = "BIRU9900362";
	ContainerId23 = "BIRU9900363";
	ContainerId24 = "BIRU9900364";
	ContainerId25 = "BIRU9900365";
	ContainerId26 = "BIRU9900366";
	ContainerId27 = "BIRU9900367";
	ContainerId28 = "BIRU9900368";
	ContainerId29 = "BIRU9900369";
	GCCargoId01 = "GCGC2277881";
	GCCargoId02 = "GCGC2277882";
	GCCargoId03 = "GCGC2277883";
	GCCargoId04 = "GCGC2277884";
	FlatId01 = "LMCU0700020";
	FlatId02 = "LMCU0700035";
	FlatId03 = "LMCU0700040";
	FlatId04 = "LMCU0700056";
	FlatId05 = "LMCU0700060";
	FlatId06 = "LMCU0700077";
	FlatId07 = "LMCU0700080";
vars
	theLines : HugeStringArray;
	vessel : CM_Vessel;	 
	voyage1 : CM_Voyage;
	voyage2 : CM_Voyage;
	voyage3 : CM_Voyage;
	voyageCellularStructure : CM_CellularVoyageStructure;
	voyageROROStructure : CM_ROROVoyageStructure;
	voyageDeck : CM_DeckVoyage;
	ediText : String;
	binaryMsg : Binary;
	bSynchronous : Boolean;
	messageType : String;
	fileTypeUser : CM_EDIFileTypeUser;
	container : CM_Container;
	idx : Integer;
	clientRef : String;
	ediControllerAgent : CM_EDIControllerAgent;
	ediFile : CM_EDIFile;
	ediData : CM_EDIData;
	ediDataActual : CM_EDIData;
	ediDataProposed : CM_EDIData;
	xmlBlock : String;
	ediFileType : CM_EDIFileType;
	pxyFileTypeUser : CM_EDIFileTypeUser;
	errorStr : String;
	operator : CM_Operator;
	ediDataParams : CMIF_EDIDataDetails;
	ediTI : CM_EDITrackedItem;
	voyCountLoad : Integer;
	layoutCountLoad : Integer;
	layoutPointCountLoad : Integer;
	tiCountLoad : Integer;
	voyCountExtract : Integer;
	layoutCountExtract : Integer;
	layoutPointCountExtract : Integer;
	tiCountExtract : Integer;
	unloadArray : StringArray512;
	clientRefNum : Integer;
	tempStr : String;
	found : Boolean;
	ti : CM_TrackedItem;
	voyages : CM_VoyageArray;
	voyage : CM_Voyage;
	tiSet		: CM_TISet;
begin
	// initailize
	create ediControllerAgent transient;
	ediControllerAgent.setTerminal(self.getTerminal);
	create pxyFileTypeUser transient;
	operator := app.myRoot.allOperators[TestOperator];
	vessel := self.getVessel(ShipName);
	// the block string below represents the XML of the required user file type definition format.
	xmlBlock := self.xmlDef_DeckPlan(UserDefinedShipManifest);	// cmwrs1 28 July 2011 CCMS 1009
	
	// break up the XML into the proxy CM_EDIFileTypeUser
	pxyFileTypeUser.importMeXML(xmlBlock);
	
	// make sure the required definition name does not already exist.
	fileTypeUser := app.myRoot.allEDIFileTypes[EDIFileType_UserDefined, UserDefinedShipManifest].CM_EDIFileTypeUser;
	if fileTypeUser &lt;&gt; null then
		// if it does exist then delete it.
		app.myTrxDA.trxDeleteEDIFileTypeUser(fileTypeUser, app.myPassport);
		self.assertIsDeleted(fileTypeUser);
		self.assertTrue(app.myPassport.trxCompletedOK());
	endif;
	
	// create the required user definition format.
	app.myTrxCA.trxCreateEDIFileTypeUser(fileTypeUser, pxyFileTypeUser, app.myPassport);
	fileTypeUser := app.myRoot.allEDIFileTypes.getAtKey(EDIFileType_UserDefined, UserDefinedShipManifest).CM_EDIFileTypeUser;
	self.assertNotNullMsg(fileTypeUser, 'User Type ' &amp; UserDefinedShipManifest &amp; ' is missing');

	foreach idx in 1 to 4 do
		clientRef := method.name[1 : ediControllerAgent.ediClientRef.maxLength-1]&amp;idx.String;		// ie 30
		ediControllerAgent.setEdiClientRef(clientRef);
		// make sure all of the objects are deleted and created correctly.
		found := true;
		while found do 
			ediFile := ediControllerAgent.getEDIFile_By_ediClientRef(clientRef);
			found := false;
			if ediFile &lt;&gt; null then
				found := true;
				beginTransaction;
				if ediFile.ediData = null then
					delete ediFile;
				else
					ediData := ediFile.ediData;
					delete ediData;
				endif;
				commitTransaction;
			endif;
		endwhile;
		ediFile := ediControllerAgent.getEDIFile_By_ediClientRef(clientRef);
		self.assertIsDeleted(ediFile);
	endforeach;

	// create first voyage
	self.deleteVoyage(VoyageName1);
	self.assertNull(self.getVoyage(VoyageName1));
	voyage1 := self.addVoyageWithConRORO(VoyageName1, ShipName, TestOperator, TestOperator, null, 0, false, true);
	voyageCellularStructure := voyage1.myCellularVoyageStructure;
	//check cellularStructure created
	self.assertNotNullMsg(voyageCellularStructure, "has cellular structure");
	voyageROROStructure := voyage1.myROROStructure;
	self.assertNotNullMsg(voyageROROStructure, "has roro structure");

	// create second voyage
	self.deleteVoyage(VoyageName2);
	voyage2 := self.getVoyage(VoyageName2);
	self.assertIsDeleted(voyage2);
	voyage2 := self.addVoyageWithConRORO(VoyageName2, ShipName, TestOperator, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString, null, 0, false, true);
	self.assertNotNullMsg(voyage2, 'Add voyage failed');
	voyage2 := self.getVoyage(VoyageName2);
	self.assertNotNull(voyage2);

	// create third voyage
	self.deleteVoyage(VoyageName3);
	voyage3 := self.getVoyage(VoyageName3);
	self.assertIsDeleted(voyage3);
	voyage3 := self.addVoyageWithConRORO(VoyageName3, ShipName, TestOperator, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString, null, 0, false, true);
	self.assertNotNullMsg(voyage3, 'Add voyage failed');
	voyage3 := self.getVoyage(VoyageName3);
	self.assertNotNull(voyage3);

