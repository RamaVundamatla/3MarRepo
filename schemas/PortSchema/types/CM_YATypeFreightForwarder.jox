    <JadeMethod name="getObjects" id="b3ca847f-87a5-4149-8afb-d379d9851bd7">
        <source>getObjects(objects: ObjectLongNameDict input);
//05 August 2008	cnwdw1	
// Return a dict of objects for this criteria type
vars
	dict			: CM_ConsignByCodeDict;
	consign			: CM_ConsigneeConsignor;
begin
	dict := app.myRoot.allConsigneeConsignors;
	foreach consign in dict discreteLock where consign.isFreightFwdr do
		objects[consign.getYAIdentifier] := consign;
	endforeach;
end;</source>
        <Parameter name="objects" type="ObjectLongNameDict" usage="input"/>
    </JadeMethod>
