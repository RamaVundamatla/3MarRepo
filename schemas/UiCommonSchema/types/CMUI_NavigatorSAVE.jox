    <JadeMethod name="getMenuRootSetForItem" id="12173437-14cd-464e-b857-f03fe774eec8">
        <source>getMenuRootSetForItem(_menuRootSet : CM_MenuEntitySet input) protected;
// ---------------------------------------------------------------------------
// Created:     12 February 2003		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	fromEntity		: CM_MenuEntity;
	user			: CM_User;
	ut				: CM_UserTerminal;
	terminal		: CM_Terminal;
	menuRoot		: CM_MenuRoot;
begin

	fromEntity := self.lstTest.listObject.CM_MenuEntity;
	
	if fromEntity = null then
		app.msgBox('Please select something first','Nothing selected',0);
		return;
	endif;
	
	menuRoot := fromEntity.getMyMenuRoot;
	
	if menuRoot = null then
		return;
	endif;
	
	_menuRootSet.add(menuRoot);
end;</source>
        <access>protected</access>
        <Parameter name="_menuRootSet" type="CM_MenuEntitySet" usage="input"/>
    </JadeMethod>
