    <JadeMethod name="doRefreshTblDataObj" id="767b0b0b-035f-40a5-9a20-1085ab910c2d">
        <updating/>
        <source>doRefreshTblDataObj(obj: Object) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
07 October 2024		jlizm1	Initial creation TFS 65881 Cargo enquiry table sometimes not updating on notify

*/

vars
	strObj : CM_StringWithString;
	
begin
	if obj = null or not obj.isKindOf(CM_Object) then
		return;
	endif;
	
	if self.allTblDataObjDict = null then
		return;
	endif;
	
	strObj := self.allTblDataObjDict.getAtKey(obj.getOidString).CM_StringWithString;
	if strObj = null then
		// Not currently held in collection, we'll just leave it as it is. 
		// (might want to add it here, but not sure so leaing current behaviour)
		return;
	endif;
	
	// update obj with latest data
	strObj.set(obj.getOidAsString(), obj.getAttributeStringForDefArray(self.allTblDataEntRows));

epilog

end;</source>
        <Parameter name="obj" type="Object"/>
    </JadeMethod>
    <JadeMethod name="doSearch" id="98a80637-0cd3-4d8a-90d2-571f0a8518ff">
        <updating/>
        <source>doSearch(_searchStr : String; _columnNumber : Integer) : Object updating;
// ---------------------------------------------------------------------------
// Created:		May 2003 By Andrew Bishop cnwab1
//
// Purpose:		pass in a search string, keystroke, and a column number and this will search for the first matching string. Then use that rows OBJECT to selct the row
//				use self.registerFormKeys(null) in the gotFocus and lostFocus to allow key presses, and add the reference to this in the keyDown event
// ---------------------------------------------------------------------------
vars

	theObject	: Object;
	startRow,
	endRow,
	tmpCol,
	idx			: Integer;

begin
	tmpCol		:= _columnNumber;
	if tmpCol = 0 or tmpCol &gt; self.columns then
		tmpCol := 1;
	endif;
	startRow	:= self.fixedRows + 1;
	endRow 		:= self.rows;

	foreach idx in startRow to endRow do
		if self.accessCell(idx, tmpCol).text.startsWith(_searchStr) then
			self.clearAllSelected();
			theObject := self.accessRow(idx).itemObject;
			self.selectObject(theObject, true);

			break;
		endif;
	endforeach;
	
	return theObject;

end;</source>
        <Parameter name="_searchStr" type="String"/>
        <Parameter name="_columnNumber" type="Integer"/>
        <ReturnType type="Object"/>
    </JadeMethod>
    <JadeMethod name="doesMatchFilter" id="bdba54bc-96a3-48ae-a974-41f1af5eced9">
        <source>doesMatchFilter(_allText : HugeStringArray; _rowStr : String) : Boolean;
/*
Purpose:	

Date		Who		Reason
08 December 2025	navab1	JIRA 35966
*/

vars
	filterText, rowStr, scanStr	: String;
	exclude, found : Boolean;
	idx : Integer;

begin
	if _rowStr= null then
		return false;
	endif;
	
	rowStr := _rowStr.toUpper().trimBlanks;
	
	found := false;
	foreach filterText in _allText do : textLoop
		exclude := false;
		filterText := filterText.toUpper().trimBlanks;
		
		// "!2" becomes "2", and exclude any row that has "2" in it.
		if filterText.length() &gt; 1 and filterText[1] = ExclaimationMark then
			exclude := true;
			filterText := filterText[2:end];
		endif;
			
		if rowStr.pos(filterText, 1) &gt; 0 then
		
			found := true;
			if exclude then
				return false;
			else
				break;
			endif;
		elseif exclude then
			found := true;
		endif;
	endforeach;

	return found;
epilog

end;</source>
        <Parameter name="_allText" type="HugeStringArray"/>
        <Parameter name="_rowStr" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
