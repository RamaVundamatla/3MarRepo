        <type name="Date"/>
    </PrimAttribute>
    <PrimAttribute name="scheduledArrivalDateFrom" id="5ca719d2-a318-4b94-b2b4-9583f0c63e52">
        <embedded/>
        <type name="Date"/>
    </PrimAttribute>
    <PrimAttribute name="scheduledArrivalDateTo" id="fb4a4922-612c-40fc-8821-6d10344c3fad">
        <embedded/>
        <type name="Date"/>
    </PrimAttribute>
    <PrimAttribute name="trainCode" id="b4da067d-c660-4d74-b6b9-ca8d99609541">
