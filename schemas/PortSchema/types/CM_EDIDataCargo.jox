    <JadeMethod name="getReceiptTransportMode" id="a9777934-7d84-4f60-b34a-b784865c6606">
        <source>getReceiptTransportMode(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 Oct 2022 navsj20	ChangeRequest 55084: EUP - EDI Administration Usability Requirements
26 Oct 2022 navvt20 ChangeRequest 55084: EUP - EDI Administration Usability Requirements
*/

vars
	ediTi: CM_EDITrackedItem;
begin
	foreach ediTi in self.allEDITrackedItems do
		if ediTi.isKindOf(CM_EDICargoTI) then
			//return ediTi.CM_EDICargoTI.receiptTransportMode.String; // 26 Oct 2022 navvt20 TFS 55084
			return app.transportModeENumToString(ediTi.CM_EDICargoTI.receiptTransportMode); // 26 Oct 2022 navvt20 TFS 55084
		endif;
	endforeach;
	return null;
epilog

end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="loadDB" id="ea4371ba-a1cb-4140-95de-3d92be333ec2">
        <updating/>
        <source>loadDB(_mergeCargo : Boolean; _passport: CM_Passport input) updating;
/*
----------   ----------  --------------------------------------------------
Created:	03 August 2006 By cnwth2

Purpose:	

/* Changes

Date		Name	TFS#		Description
============================================================================
21 Feb 2013	cnwrs1	Par 31143 	EDI TRX not handling dbLoadErrors after no verify errors take 3
08 Oct 2015	cnwrs1	Par 36863 	make EDI consistant times when refreshing progress bar
13 May 2016	cnwns1	TFS 488 	Multi Timezone Support
08 Dec 2016	cnwrs1	TFS 3069 	Par 38428 create an error is the action is not add
21 May 2018	jlgrh7 	TFS 38656 	POE - User Defined EDI Failure-URGENT
03 Sep 2019 jlgka1 	TFS 45332 	STWR - Better Forms and Interfaces for EDI Module
20 Oct 2020	jlgmd1	TFS 50204	Refactor progress updates to superclass method
============================================================================*/
vars

	pxyCargoItem	: CM_TrackedItem;
	ediTI			: CM_EDICargoTI;			// CM_EDITrackedItem;
	updCntrl		: CMIF_TIUpdateController;
	tiSet			: CM_TISet;
	terminal		: CM_Terminal;
	ediTrackedItem			: CM_EDITrackedItem;		//+TFS38656
	done, todo		: Integer;
	
	tmpDict			: DynaDictionary;
	tmpObj			: Object;
	progressTS 		: TimeStamp;
begin
	// Arm our base exception handlers
	on Exception do validationExceptionHandler(exception, _passport);
	
	progressTS := app.actualTimeServer();	// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	app.setContinueCMExceptions(false);
	create tiSet transient;
	terminal := self.getMyTerminal();
	if terminal = null then
		app.raiseCMException1(Err_InvalidTerminal, 'null', null, null);
		return;
	endif;
	
	todo := self.allEDITrackedItems.size;
	done := null;
	self.updateProgress(progressTS, "Loading into JMT...", todo, done, true, _passport);
	
	// PAR 21724 - need to load in location order
	create tmpDict transient;
	tmpDict.setMembership(CM_EDICargoTI);
	tmpDict.addMemberKey(CM_EDICargoTI::locationId.name, false, false);
	tmpDict.endKeys(true);
	
	//self.allEDITrackedItems.copy(tmpDict);																																								//-TFS38656
		
	foreach ediTrackedItem in self.allEDITrackedItems do																																		//+TFS38656 the collection also contains CM_EDISealTI
		if ediTrackedItem.isKindOf(CM_EDICargoTI) then
			tmpDict.add(ediTrackedItem);
		endif;
	endforeach;
																																													
	foreach tmpObj in tmpDict do
		ediTI := tmpObj.CM_EDICargoTI;
		done := done + 1;
		self.updateProgress(progressTS, "Loading into JMT...", todo, done, false, _passport);
		
		if ediTI.messageMode = CM_EDITrackedItem.EDI_ACTION_ADD then
			pxyCargoItem := terminal.createTI(ediTI.myCargoType, true);
			
			ediTI.CM_EDICargoTI.setProxy(pxyCargoItem, ediTI.myEDIData.CM_EDIDataCargo.createToSite, terminal, updCntrl, _passport);
			pxyCargoItem.setSubTerminal(null,null);
			tiSet.add(pxyCargoItem);
		endif;
	endforeach;
	
	self.updateProgress(progressTS, "Loading into JMT...", todo, done, true, _passport);
	
	if tiSet.isEmpty then
		app.writeLog(class.name &amp; " " &amp; method.name &amp;  " no TI's found to load", LogINFO);
		return;
	endif;
	
	updCntrl := app.createTIUpdateControl(TI_UPDMODE_NORMAL, null, null);
	updCntrl.setMyUserObject(self);
	updCntrl.setMyTransientTIs(tiSet);
	_passport.warningsAcknowledged := true;

	app.myTrxCA.trxCreateEDITIsCargo(updCntrl, self, false, _passport); //ccms1845
	
//	if _passport.noErrors then
//		app.myTrxUA.trxSetEDIDataStatus(self, CM_EDIFile.EDI_STATUS_DBLOADED); //ccms1845
//		beginTransaction;
//		status := CM_EDIFile.EDI_STATUS_DBLOADED;
//		app.cmsCommitTransaction(_passport);	
//	endif;

epilog
	delete updCntrl;
	delete tiSet;
	delete tmpDict;
end;</source>
        <Parameter name="_mergeCargo" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
