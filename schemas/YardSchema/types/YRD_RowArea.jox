    <JadeMethod name="drawGridArea" id="caeeb9d4-0ae5-41ff-b5b8-993f1b71c874">
        <updating/>
        <source>drawGridArea() updating, protected;
// ---------------------------------------------------------------------------
// Created:     28 December 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	gridPoint	: CMUI_GridPoint;
	gridFrame	: CMUI_GridAreaFrame;
	lNow : TimeStamp;
	
begin
	gridFrame := self.myGridAreaFrame;
	if gridFrame &lt;&gt; null then

		gridFrame.clearGraphics;
		self.drawSpecialBefore();	
		foreach gridPoint in self.allGridPoints do
			if gridPoint.myLocationsController &lt;&gt; null and not global.isValidObject(gridPoint.myLocationsController) then	// PAR4239 AKB2002NOV
				delete gridPoint;
			else
				gridPoint.drawSelf(gridFrame);
			endif;
		endforeach;
		self.drawSpecialAfter();
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
