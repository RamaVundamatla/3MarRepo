        <updating/>
        <source>utlUpdateHMSResourceUsed(_pxyResourceUsed,_realHMSResourceUsed : HMS_ResourceUsed input; _passport : CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 April 2018	jlger1	Initial creation 37665

*/

vars

begin
	self.initialiseActivity();
	
	// do any pre-validation locks
	if _realHMSResourceUsed =null  then
		return;
	endif;
	
	// do validation
	self.raiseExceptionIfNull(_pxyResourceUsed, 'HMS Resource Used');

