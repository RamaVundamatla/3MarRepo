    <JadeMethod name="loadVoyage" id="8ab59a3a-1477-484b-b827-ed2b83095f42">
        <source>loadVoyage(_voyageProxy:CM_Voyage io) :Boolean protected;

vars
	realObject, proxyObject: CM_Voyage;
	error: CM_Error;
	theTerminal: CM_Terminal;
	voyageGlobal: CM_VoyageGlobal;
	countError,countOK: Integer;
begin
	if _voyageProxy.vesselCode = null then
		app.writeLog(class.name&amp;'::'&amp;method.name&amp;' '&amp;_voyageProxy.code&amp;" ERROR: "&amp;"No Vessel Code.",0);
		return false;
	endif;
	theTerminal := app.myPassport.myTerminal;
	realObject := theTerminal.lookupVoyage (_voyageProxy.code, null, false);
//	if not _voyageProxy.myVoyageGlobal.isTransient then
//		voyageGlobal := _voyageProxy.myVoyageGlobal;
//	endif;
	if realObject = null then
		beginTransaction;
		create voyageGlobal persistent;
		commitTransaction;
//		app.myTrxCA.trxCreateVoyage(_voyageProxy, realObject, _voyageProxy.myVessel, voyageGlobal, false, app.myPassport);
	else
		app.writeLog(class.name&amp;'::'&amp;method.name&amp;' '&amp;_voyageProxy.code&amp;" ERROR: "&amp;"Voyage already exists.",0);
		return false;
	endif;
	if app.myPassport.trxCompletedOK and
	   app.myPassport.allErrorWarnings.size = 0 then
		return true;
	else
		foreach error in app.myPassport.allWarnings do
			app.writeLog(class.name&amp;'::'&amp;method.name&amp;' '&amp;_voyageProxy.code&amp;" WARNING: "&amp;error.text,0);
		endforeach;
		foreach error in app.myPassport.allErrors do
			app.writeLog(class.name&amp;'::'&amp;method.name&amp;' '&amp;_voyageProxy.code&amp;" ERROR: "&amp;error.text,0);
		endforeach;
		return false;
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_voyageProxy" type="CM_Voyage" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="loadVoyageAdd" id="f236c51a-fe10-48de-80f4-c3e5a4277854">
        <source>loadVoyageAdd(_voyageAddProxy:HMS_VoyageAdd io) :Boolean protected;

vars
	realHMSTransaction: HMS_Transaction;
//	realObject, proxyObject: HMS_VoyageAdd;
	error: CM_Error;
	theTerminal: CM_Terminal;
	transController: CMIF_HMS_TransactionController;
//	workingMovementCtrl: CMIF_HMS_WorkingMovement;
	workingVoyageCtrl: CMIF_HMS_WorkingVoyage;
//	countError,countOK: Integer;
begin
	if _voyageAddProxy.myHMSVoyageData = null then
		app.writeLog(class.name&amp;'::'&amp;method.name&amp;' '&amp;_voyageAddProxy.transactionDT.String&amp;" ERROR: "&amp;"No Voyage.",0);
		return false;
	endif;
	beginTransaction;
	create transController transient;
//	create workingMovementCtrl transient;
	create workingVoyageCtrl transient;
//	transController.myWorkingMovement := workingMovementCtrl;
	theTerminal := app.myPassport.myTerminal;

	transController.myWorkingVoyage := workingVoyageCtrl;
	transController.myHMSVoyageData := _voyageAddProxy.myHMSVoyageData;
	transController.myTerminal := _voyageAddProxy.myHMSVoyageData.getMyTerminal();
	transController.type := TRANS_TYPE_HMSVoyageAdd;
	
	realHMSTransaction := transController.createConversionTransaction(app.myPassport);
	if app.myPassport.allErrorWarnings.size = 0 and 
	   realHMSTransaction &lt;&gt; null then
		realHMSTransaction.setPropertyValue("userCode",_voyageAddProxy.userCode);
		realHMSTransaction.setPropertyValue("userName",_voyageAddProxy.userName);
		realHMSTransaction.setPropertyValue("transactionDT",_voyageAddProxy.transactionDT);
		commitTransaction;
		return true;
	else
		abortTransaction;
		foreach error in app.myPassport.allErrors do
			app.writeLog(class.name&amp;'::'&amp;method.name&amp;' '&amp;_voyageAddProxy.transactionDT.String&amp;" ERROR: "&amp;error.text,0);
		endforeach;
		return false;
	endif;
epilog
	delete transController;
	delete workingVoyageCtrl;

end;</source>
        <access>protected</access>
        <Parameter name="_voyageAddProxy" type="HMS_VoyageAdd" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="loadVoyageDelay" id="35dc6e9b-bcbe-45a3-8de1-92104aaba48f">
