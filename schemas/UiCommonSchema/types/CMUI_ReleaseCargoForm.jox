/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
11 August 2009	cnwjk3	Initial creation

*/

vars
	caption,
	hint 		: String;
begin
	hint 	:= 'Enter the cargo IDs to mask with. Can be full or partial cargo or series ids (eg SUDU 20). To enter a negative (NOT), add a "!" before the mask, i.e. !SUDU20. Each id should be on a separate line.';
	caption	:= 'Cargo ID Masking';
	self.idMask := self.myAssistant.showIdMaskWindowFlexi(caption, hint, self.idMask).trimBlanks();
	self.lblIDsMask.caption := self.truncateDisplayString(self.idMask, MAX_IDMASK_DISPLAY_LEN);
epilog

end;</source>
