<CollClass name="CM_JobSet" id="35805bba-668e-4876-a6e6-706805577a7a">
    <memberType name="CM_Job"/>
    <superclass name="CM_ObjectSet"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="operatn"/>
    <JadeMethod name="getFirstInwardsRailJob" id="b6a44bc0-7552-40ea-838c-928ff195e76f">
        <source>getFirstInwardsRailJob() : CM_RailJob;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 March 2024	navpw1	Initial creation TFS: 62857 (62858)

*/

vars
	job		: CM_Job;
	railJob : CM_RailJob;
	
begin
	if self.isEmpty then
		return null;
	endif;
	
	foreach job in self do
		if not job.isRail then
			return  null;
		endif;
		
		railJob := job.CM_RailJob;
		
		if railJob.isRelease then
			continue;
		endif;
		
		return railJob;
		
	endforeach;
	
	return null;

end;</source>
        <ReturnType type="CM_RailJob"/>
    </JadeMethod>
    <JadeMethod name="hasJobsActioned" id="9d55f6bd-884f-4312-8467-04e4ee74dc5d">
        <source>hasJobsActioned() : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 March 2024	navpw1	Initial creation TFS 62777 (62778)

*/

vars
	job : CM_Job;
	
begin
	if self.isEmpty then
		return false;
	endif;
	
	foreach job in self do
		if job.status = JOB_UNACTIONED then
			continue;
		endif;
		
		return true;
		
	endforeach;
	
	return false;
	
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</CollClass>
