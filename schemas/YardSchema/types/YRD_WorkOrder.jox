        <updating/>
        <source>chkSendEmail_change(checkbox: CheckBox input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 Mar 2022 navma1 ChangeRequest 52351: MTN - Work Order Maintenance Refactor - UI

*/

vars

begin

	self.txtEmail.visible := self.chkSendEmail.value;
