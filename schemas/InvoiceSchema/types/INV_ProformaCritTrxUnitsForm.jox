    <JadeMethod name="cmbUnits_click" id="e41f938e-b8e7-4d14-8ec9-62b27f5574ca">
        <controlMethod name="CMUI_ComboBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbUnits_click(combobox: ComboBox input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 July 2012	cnwndl1	Initial creation

*/

vars

begin

	if combobox.parent = self.tblUnits then
		self.tblUnits.setCellText( self.tblUnits.row, self.tblUnits.column, combobox.text);
	endif;

epilog

end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
