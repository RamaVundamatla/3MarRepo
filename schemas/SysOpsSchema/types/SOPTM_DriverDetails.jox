    <JadeMethod name="getStatus" id="2f149742-49b5-431a-a4e6-5f4850b30878">
        <source>getStatus(pStr :String) :Integer;

vars

begin
	if pStr = CM_DriverDetails.Status_Allowed_String then
		return CM_DriverDetails.Status_Allowed;
	elseif pStr = CM_DriverDetails.Status_Suspended_String then
		return CM_DriverDetails.Status_Suspended;
	elseif pStr = CM_DriverDetails.Status_Banned_String then
		return CM_DriverDetails.Status_Banned;
	else
		return 999;
	endif;
end;
</source>
        <Parameter name="pStr" type="String"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="initShtMultiSelect" id="3f81ce89-66ff-4a6f-b138-dd890cc8ca54">
        <source>initShtMultiSelect();

vars

	theForm	: SOP_TableMaintForm;
	
begin

	theForm := self.myForm;
	inheritMethod;	

	theForm.mulSelect1.setVisibleButtons(true,true,false);
	self.setupMultiSelect1( "Carriers",app.myRoot.allCarriers,SOP_TableMaintForm::displayEntryCarrierAvailable.name);	
	theForm.mulSelect2.setVisibleButtons(true,true,false);
	self.setupMultiSelect2( "Vehicles",null,SOP_TableMaintForm::displayEntryVehicleAvailable.name);
end;</source>
    </JadeMethod>
    <JadeMethod name="populateVehicleListboxes" id="67213c8a-af4d-4a7a-a0e7-607fc71aa73d">
        <source>populateVehicleListboxes(pSelectedVehicles :CM_VehicleSet);

vars
	allCarriers				: CM_CarrierByCodeDict;
	allVehiclesForCarriers,
	selectedVehicles		: CM_VehicleSet;
	carrier					: CM_Carrier;
	term : CM_Terminal;		//22 Sep 2020	NDL	TFS 49963
	vehicle : CM_Vehicle;	//22 Sep 2020	NDL	TFS 49963
begin

	term := self.myForm.myTerminal;	//22 Sep 2020	NDL	TFS 49963

	create allCarriers transient;
	create allVehiclesForCarriers transient;
	create selectedVehicles transient;
	myForm.mulSelect1.getSelected(allCarriers);
	foreach carrier in allCarriers do
	//	carrier.vehicles.copy(allVehiclesForCarriers);
		//22 Sep 2020	NDL	TFS 49963
		foreach vehicle in carrier.vehicles where vehicle.myTerminal = term do
			allVehiclesForCarriers.add( vehicle );
		endforeach;
	endforeach;
	
	if pSelectedVehicles = null then							//Par 17777
		myForm.mulSelect2.getSelected(selectedVehicles);
	endif;
	myForm.mulSelect2.setAvailable(allVehiclesForCarriers, true);
	if pSelectedVehicles &lt;&gt; null then
		myForm.mulSelect2.setSelected(pSelectedVehicles);
	else
		removeInvalidVehicles(allCarriers, selectedVehicles); 
		myForm.mulSelect2.setSelected(selectedVehicles);
	endif;
epilog	
	delete allCarriers;
	delete allVehiclesForCarriers;
	delete selectedVehicles;
end;
</source>
        <Parameter name="pSelectedVehicles" type="CM_VehicleSet"/>
    </JadeMethod>
    <JadeMethod name="removeInvalidVehicles" id="c94cb571-490c-45fe-a57e-a21a63edf0e3">
        <source>removeInvalidVehicles(pCarriers :CM_CarrierByCodeDict; pVehicles :CM_VehicleSet io);

vars
	vehicle	: CM_Vehicle;
begin
	foreach vehicle in pVehicles do
		if not pCarriers.includes(vehicle.carrier) then
			pVehicles.remove(vehicle);
		endif;
	endforeach;
end;
</source>
        <Parameter name="pCarriers" type="CM_CarrierByCodeDict"/>
        <Parameter name="pVehicles" type="CM_VehicleSet" usage="io"/>
    </JadeMethod>
    <JadeMethod name="setControlsForAddEdit" id="cb45fc13-42cd-426d-891e-e74ffb9b5c12">
        <updating/>
        <source>setControlsForAddEdit() updating;
//
// Changed On	By			Reason
// ----------	--------	----------------------------------------------
// 18/10/2019	jlgdap1		TFS 46854 SNO Driver Identity Checking for Cargo Release
// 18/03/2025	navhn30		Story MTN-34389: CUX | Terminal Admin - Drivers: Status "Allowed" as default
vars
	theForm : SOP_TableMaintForm;
begin  
 	theForm := self.myForm;
	theForm.tblInput1.userInputEnabled := true;
	
	if not app.getMyUser.canDo(app.myPassport.myTerminal, PmAdmDriverExternalIDMaint) then	// TFS 46854
		theForm.tblInput1.disableRowByName(ETRow_ExternalId);								// TFS 46854
	else																					// TFS 46854
		theForm.tblInput1.enableRowByName(ETRow_ExternalId);								// TFS 46854
		theForm.txtBox01.scrollHorizontal := true;											// TFS 46854
	endif;																					// TFS 46854
	
	if theForm.mode = theForm.Mode_Add then
		theForm.tblInput1.clearValues;
		theForm.tblInput1.enableRowByName(ETRow_Name);
		theForm.tblInput1.enableRowByName(ETRow_Code);
		theForm.tblInput1.enableRowByName(ETRow_SecondaryCode);
		theForm.tblInput1.enableRowByName(ETRow_Status);
		theForm.mulSelect1.userInputEnabled := true;
		theForm.mulSelect2.userInputEnabled := true;
		theForm.myAssistant.comboBoxDriverStatus(theForm.comboBox1, CM_DriverDetails.Status_Allowed_String);	//18.03.25	 navhn30	MTN-34389
		theForm.tblInput1.setValueByName(ETRow_Status, CM_DriverDetails.Status_Allowed_String);
		theForm.tblInput1.setFocus;
		theForm.tblInput1.moveFirst();
	else
		// refresh the data from the newly created proxy
		self.showThumbnail(theForm.myProxyObject.CM_DriverDetails);
		// cannot update code		
		theForm.tblInput1.enableRowByName(ETRow_Name);
		theForm.tblInput1.enableRowByName(ETRow_Code);
		theForm.tblInput1.enableRowByName(ETRow_SecondaryCode);
		theForm.tblInput1.enableRowByName(ETRow_Status);
		theForm.mulSelect1.userInputEnabled := true;
		theForm.mulSelect2.userInputEnabled := true;
	endif;

	

end;</source>
    </JadeMethod>
    <JadeMethod name="setupThumbnailDetails" id="643ebd55-17cb-4d6e-b04f-5356cee0f3cb">
        <updating/>
        <source>setupThumbnailDetails() updating;
//	adm 061008 Par 18067
// Changed On	By			Reason
// ----------	--------	----------------------------------------------
// 18/10/2019	jlgdap1		TFS 46854 SNO Driver Identity Checking for Cargo Releases
vars
		theForm : SOP_TableMaintForm;
begin

	theForm := self.myForm;
	theForm.useProxyObject := true;
	//theForm.setTblDataEntRows(ETDef_DriverMaint);			// TFS 46854
	theForm.setTblDataEntRows(ETDef_DriverThumbNail);		// TFS 46854
	
	theForm.shtTblInput1.caption := 'Details';
	theForm.initTblInput(theForm.tblInput1, ETDef_DriverMaint);	
	theForm.shtTblInput1.visible := true;
	theForm.comboBox1.visible := true;
	
	theForm.myAssistant.comboBoxDriverStatus(theForm.comboBox1, null);
	
	theForm.txtBox01.passwordField := true;					// TFS 46854
	
end;
</source>
    </JadeMethod>
    <JadeMethod name="sheetChange" id="f2d64429-dac9-4b69-9d44-63f173af53dd">
        <updating/>
        <source>sheetChange(folder: Folder input) updating;

vars

begin
	if self.myForm.mulSelect2.isMySheetVisible then
		populateVehicleListboxes(null);
	endif;
end;
</source>
        <Parameter name="folder" type="Folder" usage="input"/>
    </JadeMethod>
    <JadeMethod name="showThumbnail" id="7557bfb5-6019-4d6d-900e-da6220a2cbd2">
        <updating/>
        <source>showThumbnail(pDriver: CM_DriverDetails) updating;
//	adm 061008 Par 18067
// Changed On	By			Reason
// ----------	--------	----------------------------------------------------
// 18/10/2019	jlgdap1		TFS 46854 SNO Driver Identity Checking for Cargo Release
// 17/12/2019	JLGNS1		Bug 48076: SNO - Re: External ID issue
vars
	theForm : SOP_TableMaintForm;
	batNum : String;
begin  
 	theForm := self.myForm;
	theForm.tblInput1.clearValues;

	theForm.tblInput1.setValueByName(ETRow_Name, pDriver.name);
	theForm.tblInput1.setValueByName(ETRow_Code, pDriver.code);
	theForm.tblInput1.setValueByName(ETRow_SecondaryCode, pDriver.secondaryCode);
	theForm.tblInput1.setValueByName(ETRow_Status, pDriver.statusString());
	if pDriver.externalID &lt;&gt; null then									// TFS 46854
		theForm.setEnteredPassword( pDriver.externalID);				// Bug 48076
		theForm.tblInput1.setValueByName(ETRow_ExternalId, "&lt;set&gt;");	// TFS 46854
	endif;																// TFS 46854
	
	theForm.comboBox1.text := pDriver.statusString();
	theForm.mulSelect1.setSelected(pDriver.allCarriers);
	populateVehicleListboxes(pDriver.allVehicleMachines);
end;
</source>
        <Parameter name="pDriver" type="CM_DriverDetails"/>
    </JadeMethod>
</Class>
