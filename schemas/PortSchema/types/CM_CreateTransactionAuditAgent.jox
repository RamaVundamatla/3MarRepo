<Class name="CM_CreateTransactionAuditAgent" id="6ee3647c-257c-4bca-9051-f87c8e245189">
    <superclass name="CM_TransactionAuditAgent"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="cmtrans"/>
    <ExplicitInverseRef name="myUCA" id="224da48f-cf5b-47f6-88fe-3fca474575c4">
        <kind>child</kind>
        <updateMode>automatic</updateMode>
        <embedded/>
        <type name="CM_UtilityCreateAgent"/>
        <access>protected</access>
        <Inverse name="CM_UtilityCreateAgent::myCreateAuditAgent"/>
