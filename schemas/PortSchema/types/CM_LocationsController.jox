    <JadeMethod name="isLocationEmpty" id="39f561de-99d0-4754-b217-ec8bd515c8d9">
        <source>isLocationEmpty() : Boolean;
// -------------------------------------------
// Created 03 May 2005 by cnwdvb1
// -------------------------------------------
vars

begin


	if not self.allTrackedItems.isEmpty() then
		return false;
	endif;
	
	if not self.allPlannedFutureMoves.isEmpty() then
		return false;
	endif;
	
	if not self.allQueuedFutureMoves.isEmpty() then
		return false;
	endif;
	
	if not self.allProductLocations.isEmpty then
		return false;
	endif;
	
	// Par 8830.
	if not self.allPlannedBOLs.isEmpty then
		return false;
	endif;	
	
	return true;


end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
