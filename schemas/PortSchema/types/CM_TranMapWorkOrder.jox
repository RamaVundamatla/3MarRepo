    <JadeMethod name="getServiceBroker" id="43c32d55-d336-46db-9f16-d2676e6718f7">
        <source>getServiceBroker(_theTransaction: CM_WOTransaction) : CM_WorkOrderServiceBroker;
/*
Purpose:	TFS 39237		
Date			Who			Reason
JUNE 2018		CNWAB1		Initial creation
23 Oct 2024 	navlw1  	JIRA-33107: Invoice Logging Use Levels
25 Feb 2025		navah1		Story 34141: MTN - Performance Improvements - Review for invLog() Methods
*/

vars
	theBroker : CM_WorkOrderServiceBroker;
	invalid 		: Boolean;
	canLogExtra		: Boolean;	//28.02.2025 navah1	#34141
begin
	canLogExtra	:= app.canLogExtraDetail();				//28.02.2025 navah1	#34141
	if _theTransaction = null then
		return null;
	endif;
	
	on Exception do app.handleDeletedObject(exception, _theTransaction, invalid);
	
	theBroker := self.allWorkOrderSBs[_theTransaction.type];
	if theBroker &lt;&gt; null then
		if canLogExtra then	//28.02.2025 navah1	#34141
			app.invLog("Work order transaction map found for " &amp; _theTransaction.getTranTypeString(), LogTRACE.String);
		endif;
	endif;
	
	if theBroker = null then
		theBroker := self.allWorkOrderSBs[null]; // DEFAULT
		if canLogExtra then	//28.02.2025 navah1	#34141
			app.invLog("Work order transaction map DEFAULT used", LogTRACE.String);
		endif;
	endif;
	
	
	return theBroker;
end;</source>
        <Parameter name="_theTransaction" type="CM_WOTransaction"/>
        <ReturnType type="CM_WorkOrderServiceBroker"/>
    </JadeMethod>
