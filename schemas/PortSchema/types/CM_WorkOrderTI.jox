    <JadeMethod name="addTrackedItem" id="52f10a97-394d-4bdd-a934-eabfa53e84b0">
        <source>addTrackedItem( _theTI : CM_TrackedItem ; _task : CM_WorkOrderDtl);

/*

Purpose:	add a real tracked item to the work order, from the source (tilist, booking etc) and attach it to the first task 

Parameters:			

Return Value:		


Date		Who		Reason
24/07/2009	cnwrd1	Initial creation
15/05/2018	jlgdap1	TFS 38501 PEL1 Work Order Changes
12/09/2018	jlgdap1	TFS 40157 PEL1 Voyage Change Work Order
20/03/2019	jlgdap1	TFS 43888 PEL1 Container services - Invoice created on Work-Order receival (Cargo Receival) Transaction
17/05/2022	NAVCS2	TFS 53038: MTN - Work Order Maintenance Refactor - PortSchema
23/08/2022  navma1	Bug 54273: MTN - Cargo Work Order - Move Task - 2 Queued moves when the task is actioned
08/02/2023  navma1  ChangeRequest 56457: EUP - Allowing different sets of cargo items per work order task [Refactor]
28 Jun 2023 navma1 Bug 58920: MTN - 1090 Exception when actioning the Release Cargo Work Order for Export Bookings
*/

vars
	theTask   	: CM_WorkOrderDtl;
	txnParams 	: CMIF_WorkOrderTransController;
	theTI 	  	: CM_TrackedItem;
	wodDtl 	  	: CM_WorkOrderDtl;
	tranType  	: Integer;
	woTrans   	: CM_TITransaction;
	createTrans : Boolean;
begin

	theTI := _theTI;
	
	if  theTI = null then
		return;
	endif;
	
	create txnParams transient;
	
	if not theTI.isOnSite then //add only onsite
		if not _task.CM_WorkOrderTIDtl.allowAddNonOnsite(_theTI) then		//28.06.2023 navma1 #58920
			return;
		endif;
	endif;
	

	//11 June 2018 	jlger1	tfs 38947 make sure the ti.allWorkOrders is not set when complete cancelled not approved or user entry
	// dont want to add cargo to a complete or canceled work order.
	if self.taskStatus     = WO_STATUS_COMPLETE    or
		 self.taskStatus   = WO_STATUS_CANCELLED   or
		 self.taskStatus   = WO_STATUS_NOTAPPROVED or
		 self.taskStatus   =  WO_STATUS_USERENTRY then
		return; 
	endif;	

	//07 Feb 2019	NDL	TFS 43282
	foreach wodDtl in self.allWoDtls do
		wodDtl.validateAddTI( theTI );
	endforeach;

	if theTI.isOnWorkOrder( self ) then          /*Pending*/
		//return;								//26.05.2022 navma1 #53038
	endif;
	
	if not self.allTIs.includes( theTI) then
		self.allTIs.add(theTI);
	else
		//return;								//26.05.2022 navma1 #53038
	endif;

	// then add to the first task
	//theTask := self.getFirstTask();			//08.02.2023 navma1 #56457 Task#56458
	theTask   := _task;							//08.02.2023 navma1 #56457 Task#56458
	
	if theTask &lt;&gt; null then
		theTask.CM_WorkOrderTIDtl.addTIAvailable( theTI);
		// TFS 43888 Web Portal creates work orders in Pending Approval status, // TFS 43888
		// so the allTIs are already populated when the source is set up. 		// TFS 43888
		// BUT we don't what these TIs to create transactions just yet - 		// TFS 43888
		// they will get created correctly when the work order is approved		// TFS 43888
		if app.isWebApp and self.taskStatus = WO_STATUS_PENDING then			// TFS 43888
		else																	// TFS 43888
			
			tranType := theTask.getWOTransactionType();
			woTrans  := theTI.getTransactionOfType(tranType);
			
			//23.08.2022 navma1 #54273
			if woTrans &lt;&gt; null then
				if woTrans.isKindOf(CM_WorkOrderAssign) then
					if woTrans.CM_WorkOrderAssign.myWorkOrder &lt;&gt; self then
						createTrans := true;
					endif;
				endif;
			
			else
				createTrans := true;
			endif;
			
			//23.08.2022 navma1 #54273
			if createTrans then	
				txnParams.type 		  := tranType;
				txnParams.myWorkOrder := self;
				theTI.createTransaction(txnParams, app.myPassport);
			endif;
		endif;																	
	endif;

epilog
	delete txnParams;
end;</source>
        <Parameter name="_theTI" type="CM_TrackedItem"/>
        <Parameter name="_task" type="CM_WorkOrderDtl"/>
    </JadeMethod>
    <JadeMethod name="canAccessOnWeb" id="c1c6a14e-21f7-44c0-8855-fb6b86048149">
        <source>canAccessOnWeb(): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 Jan 2020	jlger1	Initial creation 48179
12 Jan 2023	navma1  ChangeRequest 56141: EUP - Refactor and Remove CM_WorkOrderTISource from CM_WorkOrderTI
*/

vars
	ti 			    : CM_TrackedItem;
	failedDAC	    : CM_DataAccessController;
	user			: CM_User;
begin
	
	user := app.getMyUser();						//12.01.2023 navma1 #56141 Task#56147
	
	if not user.canDo(self.myTerminal, PmWebWorkOrdersView)  then			
		return false;
	endif;
	
	
	foreach ti in self.allTIs discreteLock do
		if not ti.canUserAccessSelf(user, failedDAC, app.myPassport) then 
			return false;
		endif;
	endforeach;
	
	
	return inheritMethod;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
