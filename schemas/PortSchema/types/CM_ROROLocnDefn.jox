    <JadeMethod name="isRotationGroupCCLoad" id="316a5b15-50b5-4235-8af5-74a4ba5ba53f">
        <source>isRotationGroupCCLoad() : Boolean;
// ---------------------------------------------------------------------------
// Created:     30 January 2013 by cnwab1
//
// PAR 32785/32012
// If the whole of the rotated discharge is CCd then the load is unrotated.
// If the load is then rotated and load CCd, and then the discharge CC is erased, 
// this rotates the load again (actually nothing happens as the load is already rotated.
// If the whole of the rotated discharge is CCd again we need to check that there is no load CC in the group,
// if there is load CC we should not unrotate the load. If there is no load CC then the load is unrotated.
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	locn : CM_ROROLocnDefn;
	slotController : CM_ROROSlotController;
	roroSlotDefn		: CM_ROROSlotDefn;
	roroSlotDefnVoyage : CM_ROROSlotDefnVoyage;
begin

	if not self.isPlannedRotated then
		return true;
	endif;

	foreach locn in self.allPlannedRotatedLocnDefns discreteLock do
	
		foreach roroSlotDefn in locn.allROROSlotDefnByOrdinal discreteLock do
			roroSlotDefnVoyage:=roroSlotDefn.CM_ROROSlotDefnVoyage;
			slotController:=roroSlotDefnVoyage.mySlotController;
			if slotController = null then
				continue;
			endif;
			
			// Has TIs that are not colour coded
			if  slotController.myRORORequestLoad &lt;&gt; null then
				return true;
			endif;
			
		endforeach;
	
	endforeach;
	
	return false;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isRotationMaster" id="487ae13d-bf6e-4fec-a035-efaf0a93fbc4">
        <source>isRotationMaster() : Boolean;
//----------------------------------------------------------------------
// Created by 	cnwsh3 - 16 November 2011
//
// Implemented version: JMT 7.9.2
// Date  		User  		Change
// 16/11/2011	cnwsh3		CCMS MES 1009 PLAN Interface PAR28479
//							If there are planned rotated location definitions then this is a master rotation.
//----------------------------------------------------------------------
vars

begin
	return (self = self.myPlannedRotatedMaster);
	// PAR 31129 return self.allPlannedRotatedLocnDefns.isNotEmpty();
epilog
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isVerticalOrientation" id="490dc211-e16a-4f22-a906-752a2582bf57">
        <source>isVerticalOrientation() : Boolean;
/*
Purpose:			
Date		Who		Reason
21 April 2011	cnwab1	Initial creation
*/

vars
	x1,x2,y1, y2, lenW, lenH : Integer;
begin
	if self.orientation = 0 then
		x1 := self.myLayout.myPolygonPixels[1].x;
		x2 := self.myLayout.myPolygonPixels[2].x;
		y1 := self.myLayout.myPolygonPixels[2].y;
		y2 := self.myLayout.myPolygonPixels[3].y;
		
		lenW := x2 - x1;
		lenH := y2-y1;
		
		return (lenH &gt; lenW); // higher than the width
	else
		return (self.orientation &lt;&gt; ROROLocn_AftForward and self.orientation &lt;&gt; ROROLocn_OOTL_AF); 
	endif;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isWholeRotationGroupCCDisch" id="8bdfbcbe-5eb2-4923-9dab-ce34d6569be3">
        <source>isWholeRotationGroupCCDisch() : Boolean;
// ---------------------------------------------------------------------------
// Created:     30 January 2013 by cnwab1
//
// CCMS 1320
// Need to check if all the cargo in the rotated group has been colour coded for discharge.
// If it has then we need to unrotate the load view of the same group
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	locn : CM_ROROLocnDefn;
	slotController : CM_ROROSlotController;
	roroSlotDefn		: CM_ROROSlotDefn;
	roroSlotDefnVoyage : CM_ROROSlotDefnVoyage;
	hasTIs : Boolean;
begin

	if not self.isPlannedRotated then
		return true;
	endif;

	foreach locn in self.allPlannedRotatedLocnDefns discreteLock do
	
		foreach roroSlotDefn in locn.allROROSlotDefnByOrdinal discreteLock do
			roroSlotDefnVoyage:=roroSlotDefn.CM_ROROSlotDefnVoyage;
			slotController:=roroSlotDefnVoyage.mySlotController;
			if slotController = null then
				continue;
			endif;
			if not slotController.allTrackedItems.isEmpty()  then
				hasTIs := true;
			endif;
			
			// Has TIs that are not colour coded
			if not slotController.allTrackedItems.isEmpty() 
			and slotController.myRORORequestDischarge = null then
				return false;
			endif;
			
		endforeach;
	
	endforeach;
	
	if not hasTIs then
		return false;
	endif;
	return true;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="773c81b0-cb78-4a70-8697-19546a34faa9">
        <source>pxyCreateUpdateProxy(): SelfType;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 June 2011	cnwer1	Initial creation CCMS MES 1116

*/

vars
	pxyMe : SelfType;
	pxyLayer : CM_DeckLayerLayout;
	pxyDeck : CM_Deck;
	pxyLayout : CM_DeckItemLayout;
	completedOK		: Boolean;
	aSlot : CM_ROROSlotDefn;
		realHaz, pxyHaz : CM_Hazard;
begin
	pxyMe:= inheritMethod();
	
	pxyLayer := self.myDeckLayerLayout.pxyGetProxyObject();	
	pxyDeck := self.myDeck.pxyGetProxyObject();	
	pxyLayout := self.myLayout.pxyGetProxyObject();
	if pxyLayout = null then
		pxyLayout := self.myLayout.pxyCreateUpdateProxy();
	endif;

	
	pxyMe.myDeckLayerLayout := pxyLayer;
	pxyMe.myDeck := pxyDeck;
	pxyLayout.myDeckItem := pxyMe;
	
		
	// ### proxy myAdjacentSlotAft and myAdjacentSlotFwd are set in SetProjectAdjacent
	foreach aSlot in self.allROROSlotDefnByOrdinal  discreteLock do
		app.createUpdateProxy(aSlot);
	endforeach;
	
	pxyMe.setProxyHazards(self.allHazardsAllowed);
	
	completedOK := true;	
	return pxyMe;

epilog
	if not completedOK then			
		delete pxyMe;
	endif;
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="removeRotateLabel" id="29d71608-2173-4129-b6f6-f79dfb7b31cb">
        <updating/>
        <source>removeRotateLabel(_rotateLabel : String) updating;
/*
Purpose:			
Date		Who		Reason
13 July 2011	cnwab1	Initial creation
*/

vars
	labelLen, startPos : Integer;
	roroDeckPrefix, tmpCode : String;
	slotDefn : CM_ROROSlotDefn;
	stateData : CM_StateDataDict;
begin
//	if self.labelManuallyChanged then // PAR 28990 we have added the "R" to stop duplication errors
//		return;
//	endif;
	
	if _rotateLabel = null then
		return;
	endif;
	stateData := self.myDeck.getAllStateDataObject();
	global.getExtraData(stateData,RoRoDeckLabelPrefix,roroDeckPrefix);

	tmpCode := self.code;
	
	labelLen := _rotateLabel.length;
	
	
	startPos := tmpCode.reversePos(_rotateLabel);
	if startPos &gt; 1 then
		if startPos = tmpCode.length() then
			tmpCode := tmpCode[1:startPos -1];
		else
			tmpCode := tmpCode[1:startPos -1] &amp; tmpCode[startPos +1: end];
		endif;
	endif;

	// PAR 30587 self.code := tmpCode;
	self.setCode(tmpCode,true);// PAR 30587 set the graphic as well.
	
	// PAR 28990
	foreach slotDefn in self.allROROSlotDefnByOrdinal discreteLock do
		tmpCode := slotDefn.code;
		
		startPos := tmpCode.reversePos(_rotateLabel);
		if startPos &gt; 1 then
			if startPos = tmpCode.length() then
				tmpCode := tmpCode[1:startPos -1];
			else
				tmpCode := tmpCode[1:startPos -1] &amp; tmpCode[startPos +1: end];
			endif;
		endif;
		
		slotDefn.setCode(tmpCode);
	endforeach;
	
epilog

end;</source>
        <Parameter name="_rotateLabel" type="String"/>
    </JadeMethod>
