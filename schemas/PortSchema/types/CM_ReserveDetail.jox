    <JadeMethod name="validateForDelete" id="e7acac42-e0a7-4d00-ba43-2cf2b0726162">
        <source>validateForDelete( _raiseExc : Boolean ):Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 October 2017	jlgndl1	Initial creation	TFS 7394

*/

vars

begin

	if not self.allTrackedItemsReleased.isEmpty then
		if _raiseExc then
			app.raiseCMException(Not_delet_reser_detai_that_hav, null, self);
		endif;
		return false;
	endif;
	
	return true;

epilog

end;</source>
        <Parameter name="_raiseExc" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateForPack" id="4398b875-a11c-452c-beb9-2828309abbe8">
        <source>validateForPack(_reserveDetail 	: CM_ReserveDetail;
				_trackedItem 	: CM_TrackedItem;
				_quantity 		: Integer;
				_weight 		: Decimal);
				
/*****************************************************
Author		: jlgka1 (Karen Alexander)
Date		: 06 August 2019
TFS#		: 45896
Function	: Copied from CMIF_MobileGenericAgent::validatePackForReserveDetails

*** Changes ***
Date			Name		TFS#		Description
03/09/21		jlier1		51879 		fixed 1086 exception if not reserveSelection
23/06/2023	navkc1	CR 58406 Task 58408: Jade - Release Request All Tracked Items
****************************************************/
vars

	count 				: Integer;
	weight 				: Decimal[16,4];
	localTrackedItem 	: CM_TrackedItem;
	description			: String;
	allTis				: CM_TISet;
begin

	count := 0;
	weight := 0;
	
	create allTis transient; //23/06/2023	navkc1	CR 58406 Task 58408
	
	if _reserveDetail.isPackingChild then
		count := _reserveDetail.getTotalPacked;
		weight := _reserveDetail.getWeightPacked;
		
	else
		_reserveDetail.getAllTrackedItems(allTis, false); //23/06/2023	navkc1	CR 58406 Task 58408
		//foreach localTrackedItem in _reserveDetail.allTrackedItems do
		foreach localTrackedItem in allTis do //23/06/2023	navkc1	CR 58406 Task 58408
			if localTrackedItem.myPrimaryActualLocation &lt;&gt; null and localTrackedItem.myPrimaryActualLocation.isVehicle then
				count := count + localTrackedItem.totalQuantity.max(1);
				weight := weight + localTrackedItem.totalWeight;
			endif;
		endforeach;
	
		foreach localTrackedItem in _reserveDetail.allTrackedItemsReleased do
			count := count + localTrackedItem.totalQuantity.max(1);
			weight := weight + localTrackedItem.totalWeight;
		endforeach;
	endif;
	
	description := _reserveDetail.getTotalRequestedDisplay() &amp; ' x ' &amp; _reserveDetail.getProductISOTypeDescr();
	if _reserveDetail.getMyCargoType = null then
		app.raiseCMException1(Unspecified_Cargo_Type,description,null,null);
	endif;
			
	if count = _reserveDetail.totalRequested  and _reserveDetail.totalRequested &gt; 0 then
		app.raiseCMException1(Already_have_count_for,count.String,null,null);
		return;
	endif;
	if weight = _reserveDetail.weightRequested  and _reserveDetail.weightRequested &gt; 0 then
		app.raiseCMException1(Already_have_weight_request,description,null,null);
		return;
	endif;

	count := count + _quantity;
	weight := weight + _weight;

	if ( count &gt; _reserveDetail.totalRequested and _reserveDetail.totalRequested &gt; 0 )
	or ( weight &gt; _reserveDetail.weightRequested and _reserveDetail.weightRequested &gt; 0 )
	then
		app.raiseCMException1(Quant_weigh_relea_will_excee_r,description,null,null);
		return;
	endif;
epilog
	delete allTis; 
end;</source>
        <Parameter name="_reserveDetail" type="CM_ReserveDetail"/>
        <Parameter name="_trackedItem" type="CM_TrackedItem"/>
        <Parameter name="_quantity" type="Integer"/>
        <Parameter name="_weight" type="Decimal"/>
    </JadeMethod>
