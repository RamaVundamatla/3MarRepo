    <JadeMethod name="setCrossReference" id="582f1c84-c3f5-4a65-9c2e-7f7afc558c07">
        <source>setCrossReference(_coll :DynaDictionary; _obj1 :Object; _obj2 :CM_Object) protected;
/*
Date			Who		Reason
14 July 2011	cnwcs5	Initial creation - par 26557
*/
// 13 Oct 2017	jlgrs1	TFS 5705 - SNO - EDIDataBooking Prenote release Req
vars

begin
	if _obj1 = null or _obj2 = null then
		return;
	endif;
	
	if _coll [_obj1] = null then
		_coll [_obj1] := _obj2;
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_coll" type="DynaDictionary"/>
        <Parameter name="_obj1" type="Object"/>
        <Parameter name="_obj2" type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="setEDITIStatusFromErrors" id="34ef2837-eaca-4491-b539-58637a13e514">
        <source>setEDITIStatusFromErrors(_verifyOnly : Boolean; _passport : CM_Passport);
//
// 10 Nov 2017	jlgrs1	TFS 5705 - SNO - EDIDataBooking Prenote release Req
//
// 28 Nov 2017	jlgrs1	TFS 5705A - SNO - EDIDataBooking Prenote release Req
// 10 Jul 2018	jlgrs1	TFS 38808 - JMT - Full and Partial loading not working correctly
vars
	error : CM_Error;
	newStatus : Integer;
	oldStatus : Integer;
	passport : CM_Passport;
	ediTI : CM_EDITrackedItem;
	invalid : Boolean;
begin
	on Exception do app.handleDeletedObject(exception, ediTI, invalid); //PAR24233 - cnwsh3 skip invalid voyage objects
	passport := _passport;
	foreach error in passport.allErrorWarnings do
		if error.myUserObject = null or
		   not error.myUserObject.isKindOf(CM_EDITrackedItem) then
			continue;
		endif;
		ediTI := error.myUserObject.CM_EDITrackedItem;
		oldStatus := ediTI.status;
		if invalid then
			continue;
		endif;
		if error.errorCode = Voyage_departed or
		   error.errorCode = CannotDeleteBRItem2 then
			newStatus := CM_EDITrackedItem.EDI_STATUS_SKIP_PROCESSING_X;
		else
			if _verifyOnly then
				if error.warningOnly then
					if oldStatus = CM_EDITrackedItem.EDI_STATUS_VERIFIED_ERRORS then
						newStatus := CM_EDITrackedItem.EDI_STATUS_VERIFIED_ERRORS;
					else
						newStatus := CM_EDITrackedItem.EDI_STATUS_VERIFIED_WARNINGS;
					endif;
				else
					newStatus := CM_EDITrackedItem.EDI_STATUS_VERIFIED_ERRORS;
				endif;
			else
				if error.warningOnly then
					if oldStatus = CM_EDITrackedItem.EDI_STATUS_DBLOADED_ERRORS then
						newStatus := CM_EDITrackedItem.EDI_STATUS_DBLOADED_ERRORS;
					else
						newStatus := CM_EDITrackedItem.EDI_STATUS_DBLOADED;
					endif;
				else
					newStatus := CM_EDITrackedItem.EDI_STATUS_DBLOADED_ERRORS;
				endif;
			endif;
		endif;
		if oldStatus = CM_EDITrackedItem.EDI_STATUS_SKIP_PROCESSING_X then
			newStatus := oldStatus;
		endif;
		app.myTrxUA.trxUpdateEDITIStatus(ediTI, newStatus, passport);
	endforeach;

epilog

end;</source>
        <Parameter name="_verifyOnly" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setupBookingHeader" id="0d41d9e4-eeec-47bb-923b-870fb81d47e9">
        <source>setupBookingHeader(_ediBookingHeaderTI : CM_EDIBookingHeaderTI; _cmifEDIBookingRef : CMIF_EDIBookingRef; _realBookingRef : CM_BookingRef io; _cmifBookingRef : CMIF_BookingRef io; _ediBookingHeaderTI_Previous : CM_EDIBookingHeaderTI io) protected;
//
// par26223 cnwrs1 8 nov 2010
//
// 08/04/2011	cnwmh5	PAR #27347 - Add cmsEndLoad or endLoad to epilog so that if error occurs it will not leave it in beginLoad state
// 13 Oct 2017	jlgrs1	TFS 5705 - SNO - EDIDataBooking Prenote release Req
vars
	terminalObj : CM_Terminal;
begin
	terminalObj	:= self.getMyTerminal();
	
	beginLoad;
	_realBookingRef 		:= _ediBookingHeaderTI.findRealBookingRef(terminalObj);
	_cmifBookingRef 		:= _cmifEDIBookingRef.findAndLoadCMIFBookingRefEDI(_ediBookingHeaderTI, _realBookingRef, terminalObj);
	_cmifBookingRef.action 	:= _ediBookingHeaderTI.messageMode;
	endLoad;
	
	_ediBookingHeaderTI_Previous := _ediBookingHeaderTI;
epilog
	endLoad;				// 08/04/2011 cnwmh5 #27347
end;
</source>
        <access>protected</access>
        <Parameter name="_ediBookingHeaderTI" type="CM_EDIBookingHeaderTI"/>
        <Parameter name="_cmifEDIBookingRef" type="CMIF_EDIBookingRef"/>
        <Parameter name="_realBookingRef" type="CM_BookingRef" usage="io"/>
        <Parameter name="_cmifBookingRef" type="CMIF_BookingRef" usage="io"/>
        <Parameter name="_ediBookingHeaderTI_Previous" type="CM_EDIBookingHeaderTI" usage="io"/>
    </JadeMethod>
    <JadeMethod name="setupBookingItem" id="af3d40fa-9035-4c1f-933d-a97e9ba20b6f">
        <source>setupBookingItem(_ediBookingItemTI : CM_EDIBookingItemTI; _realBookingRef : CM_BookingRef; _cmifBookingRef : CMIF_BookingRef input; _allMatchedBRItems : CM_BookingRefItemDict io) : CMIF_BookingRefItem protected;
//
// par26223 cnwrs1 8 nov 2010
//
// 14/07/2011	cnwcs5	par26557 - return CMIF_BookingRefItem
//02 Jul 2012	cnwrs1		Par 29927 EDI Booking Item replace not working
// 13 Oct 2017	jlgrs1	TFS 5705 - SNO - EDIDataBooking Prenote release Req
vars
	singleMatch : Boolean; 				//cnwrs1 CCMS 1882 25 May 2010
	result		: CMIF_BookingRefItem;
begin
	if _cmifBookingRef.action = CM_EDITrackedItem.EDI_ACTION_DELETE then //cnwrs1 CCMS 1882 25 May 2010
		singleMatch := true;
	endif;
	
	if _ediBookingItemTI.sequence &lt;&gt; null then 
		result := _cmifBookingRef.processCMIFItemsFromEDIWithSeq(_ediBookingItemTI, _realBookingRef, singleMatch, _allMatchedBRItems);	//02 Jul 2012	cnwrs1		Par 29927 EDI Booking Item replace not working
	else
		result := _cmifBookingRef.processCMIFItemsFromEDIBooking(_ediBookingItemTI,_allMatchedBRItems);	//02 Jul 2012	cnwrs1		Par 29927 EDI Booking Item replace not working
	endif;

	return result;
end;
</source>
        <access>protected</access>
        <Parameter name="_ediBookingItemTI" type="CM_EDIBookingItemTI"/>
        <Parameter name="_realBookingRef" type="CM_BookingRef"/>
        <Parameter name="_cmifBookingRef" type="CMIF_BookingRef" usage="input"/>
        <Parameter name="_allMatchedBRItems" type="CM_BookingRefItemDict" usage="io"/>
        <ReturnType type="CMIF_BookingRefItem"/>
    </JadeMethod>
    <JadeMethod name="sortLinkedToStart" id="f515552c-af15-4da3-abd1-d3a313748200">
        <source>sortLinkedToStart(	_dinaDict : DynaDictionary input; _linkedIdArray : StringArray input; _allEdiSorted : CM_EDITIArray input
					);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 March 2017	cnwndl1	Initial creation		TFS 3703
// 13 Oct 2017	jlgrs1	TFS 5705 - SNO - EDIDataBooking Prenote release Req
*/

vars
	iter : Iterator;
	idString : String;
	ediTI : CM_EDITrackedItem;
begin
	if _linkedIdArray.isEmpty then
		// should never be empty
		_dinaDict.copy(_allEdiSorted);
		return;
	endif;
	
	//add the linked ones first
	iter := _dinaDict.createIterator;
	while iter.next(ediTI) do
		idString := ediTI.id;
		if _linkedIdArray.includes(idString) then
			_allEdiSorted.add(ediTI);
		endif;
	endwhile;
	delete iter;
	
	//add all the rest
	iter := _dinaDict.createIterator;
	while iter.next(ediTI) do
		if not _allEdiSorted.includes(ediTI) then
			_allEdiSorted.add(ediTI);
		endif;
	endwhile;
	delete iter;
epilog

end;</source>
        <Parameter name="_dinaDict" type="DynaDictionary" usage="input"/>
        <Parameter name="_linkedIdArray" type="StringArray" usage="input"/>
        <Parameter name="_allEdiSorted" type="CM_EDITIArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="updateErrorUserObjects" id="be84d477-ac7a-43e2-a83b-24bb9f1e48ef">
        <source>updateErrorUserObjects(_errors :CM_ErrorSet; _xref :DynaDictionary) protected;
/*
Purpose:			
Parameters:			
Return Value:		

Date		Who		Reason
14 July 2011	cnwcs5	Initial creation - par 26557
// 13 Oct 2017	jlgrs1	TFS 5705 - SNO - EDIDataBooking Prenote release Req
*/
vars
	error			: CM_Error;
	obj, userObject	: Object;
begin
	foreach error in _errors do
		obj := error.myUserObject;
		
		if obj = null or obj.isKindOf (CM_EDITrackedItem) then
			continue;
		endif;
		
		userObject := _xref[obj];
		
		if userObject &lt;&gt; null then
			error.setMyUserObject (userObject);
		endif;
	endforeach;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_errors" type="CM_ErrorSet"/>
        <Parameter name="_xref" type="DynaDictionary"/>
    </JadeMethod>
    <JadeMethod name="verifyEDIDataTIForAction" id="b4de2056-dd3c-432e-826e-1dc82d8b9a5f">
        <source>verifyEDIDataTIForAction(_ediBookingHeaderTI : CM_EDIBookingHeaderTI; _existingBookingRef : CM_BookingRef; _allEDITIs : CM_EDITIById; _passport : CM_Passport input) protected;
//
// par21718 cnwrs1 dec 2009
//
// 13 Oct 2017	jlgrs1	TFS 5705 - SNO - EDIDataBooking Prenote release Req
vars
	exception_EDI_alreadyLoaded	: Boolean;
	err	: CM_Error;
begin
	
	// when there is EDI action loading mode, the _exisitingBookingRef can be created before, and now it can be updated. All in the same EDI file.
	if _ediBookingHeaderTI.messageMode = "" then //par 21396 cnwrs1 Oct 2009
	elseif _ediBookingHeaderTI.messageMode &lt;&gt; CM_EDITrackedItem.EDI_ACTION_ADD and
	   _ediBookingHeaderTI.messageMode &lt;&gt; CM_EDITrackedItem.EDI_ACTION_UPDATE and
	   _ediBookingHeaderTI.messageMode &lt;&gt; CM_EDITrackedItem.EDI_ACTION_DELETE then
		app.raiseCMException1( EDI_Action_Is_Invalid, _ediBookingHeaderTI.messageMode, ETRow_MessageMode, _ediBookingHeaderTI );
		return;	// behaviour as before
	endif;
	
	// cnwrl1 09/10/2009 PAR 212444
	if _ediBookingHeaderTI.messageMode = CM_EDITrackedItem.EDI_ACTION_DELETE and
	   _existingBookingRef = null then
		// change error to warning to stop the whole file being stopped.
		app.raiseCMWarning4(	Object_DoesNotExist_To_Delete,
								app.getString( Booking_reference ),
								_ediBookingHeaderTI.id,
								app.getString( VoyageCode ),
								_ediBookingHeaderTI.getVoyageCode(),
								ETRow_Id,
								_ediBookingHeaderTI,
								null );
		return;
	endif;
	
	// when status is DB Loaded and booking ref number was edited and changed, there is active EDIData_alreadyLoaded exception
	exception_EDI_alreadyLoaded := false;	// We have to check whether it has been added from previous logs.

	foreach err in _passport.allErrors do
		if err.errorCode = EDIData_alreadyLoaded then
			exception_EDI_alreadyLoaded := true;
			break;
		endif;
	endforeach;
	
	if exception_EDI_alreadyLoaded then	
		// it doesn't make sense to check and show more exceptions, when there is EDIData_alreadyLoaded (EDI file already loaded, please reload the file etc.)
		return;	// going out saving time and client's nerves and their ability to read quickly a lot of warnings
	endif;
end;
</source>
        <access>protected</access>
        <Parameter name="_ediBookingHeaderTI" type="CM_EDIBookingHeaderTI"/>
        <Parameter name="_existingBookingRef" type="CM_BookingRef"/>
        <Parameter name="_allEDITIs" type="CM_EDITIById"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="verifyEDITIBookingHeader" id="97c754b2-6224-4086-99aa-8f287c76ce96">
        <source>verifyEDITIBookingHeader(_ediBookingHeaderTI : CM_EDIBookingHeaderTI input; _pxyBookingRef : CM_BookingRef input; _voyage : CM_Voyage io; _passport : CM_Passport input) protected; 
//
// par26223 cnwrs1 5 Nov 2010
//
// 14/07/2011	cnwcs5	par 26557 - various changes
// 09/09/2013   cnwgb1  par 32447 - just clarify that this method is not called when action is delete
// 10 Nov 2017	jlgrs1	TFS 5705 - SNO - EDIDataBooking Prenote release Req
// 27 Jun 2018	jlgrs1	TFS 38352 SNO Invalid Consignor
// 14/09/2018 	JLGNS1	Bug 40384: POL - [Fwd: ##RE-8672## : Bookings for operator not on that Voyage]
// 02 Oct 2020  cnwma1  ChangeRequest 50112: ASPA - GCI Stevedores
vars
	terminal 		: CM_Terminal;
	consignee, 
	consignor 		: CM_ConsigneeConsignor;
	destination, 
	dischargePort	: String;
	customsAgent 	: CM_CustomsAgent;
	packAsInteger 	: Integer;
	ediData 		: CM_EDIData;
	operator 		: CM_Operator;	//Bug 40384
	stevedoreObj    : CM_Stevedore;
begin
	if _ediBookingHeaderTI.messageMode = CM_EDITrackedItem.EDI_ACTION_DELETE then //cnwgb1 9.9.2013 PAR 32447 
        return;
    endif;
 	ediData 	:= _ediBookingHeaderTI.myEDIData;
	terminal 	:= self.getMyTerminal();
	consignee 	:= _ediBookingHeaderTI.getConsign(_ediBookingHeaderTI.consignee);
	stevedoreObj:= _ediBookingHeaderTI.getStevedore(_ediBookingHeaderTI.stevedore); //02.10.2020 cnwma1 TFS #50112
	consignor 	:= _ediBookingHeaderTI.getConsign(_ediBookingHeaderTI.consignor);
	
	if consignor &lt;&gt; null and not consignor.isConsignor then		
		consignor := null;
	endif;
	
	if consignor = null and _ediBookingHeaderTI.consignor &lt;&gt; null then
		if self.getMyTerminal.getConfig(EdiGateDocInvConsignor).Boolean then
			app.raiseCMException1(WARN_GENERIC, 'No matching consignor has been found for the Consignor field value (' &amp;
							_ediBookingHeaderTI.consignor &amp; ') for Id ' &amp; 
							_ediBookingHeaderTI.id &amp; ' does not match.', ETRow_Consignor, _ediBookingHeaderTI);
		else
			app.raiseCMWarning1(WARN_GENERIC, 'No matching consignor has been found for the Consignor field value (' &amp;
							_ediBookingHeaderTI.consignor &amp; ') for Id ' &amp; 
							_ediBookingHeaderTI.id &amp; ' does not match.', ETRow_Consignor, _ediBookingHeaderTI, ediData);
		endif;
	endif;
	
	if consignee = null and _ediBookingHeaderTI.consignee &lt;&gt; null then
		app.raiseCMWarning1(WARN_GENERIC, 'No matching consignee has been found for the Consignee field value (' &amp;
							_ediBookingHeaderTI.consignee &amp; ') for Id ' &amp; 
							_ediBookingHeaderTI.id &amp; ' does not match.', ETRow_Consignee, _ediBookingHeaderTI, ediData);
	endif;
	
	if stevedoreObj = null and _ediBookingHeaderTI.stevedore &lt;&gt; null then          //02.10.2020 cnwma1 TFS #50112
		app.raiseCMException1(WARN_GENERIC, 'No matching Stevedore has been found for the Stevedore field value (' &amp;
							_ediBookingHeaderTI.stevedore &amp; ') for Id ' &amp; 
							_ediBookingHeaderTI.id &amp; ' does not match.', ETRow_Stevedore, _ediBookingHeaderTI);
	endif;
	
	destination := _ediBookingHeaderTI.destinationPort;
	
	// Verify the port names PAR 17342
	if destination.length &gt; _pxyBookingRef.destinationPort.maxLength then
		app.raiseCMException2(ERR_EDI_BR_FIELD, destination, ETRow_DestinationPort, null, _ediBookingHeaderTI);
		destination := destination[1:_pxyBookingRef.destinationPort.maxLength];
	endif;
	dischargePort := _ediBookingHeaderTI.dischargePort;
	if dischargePort.length &gt; _pxyBookingRef.dischargePort.maxLength then
		app.raiseCMException2(ERR_EDI_BR_FIELD, dischargePort, ETRow_DischargePort, null, _ediBookingHeaderTI);
		dischargePort := dischargePort[1:_pxyBookingRef.dischargePort.maxLength];
	endif;
	// cnwrl1 18/02/2010 PAR 22393 
	// search for the tranship original voyage including archived voyages.
	if _ediBookingHeaderTI.customsAgent &lt;&gt; null then		// field is not mandatory
		customsAgent	:= app.myRoot.allCustomsAgents[_ediBookingHeaderTI.customsAgent];
		if customsAgent = null then
			app.raiseCMException2(ERR_EDI_BR_FIELD, _ediBookingHeaderTI.customsAgent, ETRow_CustomsAgent, ETRow_CustomsAgent, _ediBookingHeaderTI);
		endif;
	endif;
	// cnwrl1 16/04/2010 PAR 23624
	// Validate the PackAs field and if valid set up the appropriate integer value.
	if _ediBookingHeaderTI.packAs &lt;&gt; null then
		packAsInteger := app.bookingPackAsStringToEnumb(_ediBookingHeaderTI.packAs);
		if packAsInteger &lt;= null then
			app.raiseCMException2(ERR_EDI_BR_FIELD, _ediBookingHeaderTI.packAs, ETRow_PackAs, ETRow_PackAs, _ediBookingHeaderTI);
		endif;
	endif;
	// get the voyage once instead of twice and make sure it exists!
	if _ediBookingHeaderTI.getVoyageCode() = null then
		// get the terminals null voayage
		_voyage	:= terminal.getNullVoyage;
	else
		// attempt to find the voyage but not archived ones.
		_voyage	:= terminal.lookupVoyage(_ediBookingHeaderTI.getVoyageCode(), null, false);
	endif;
	
	if _voyage = null then
		app.raiseCMException2(Voyage_DoesNotExist_4_Terminal,
								_ediBookingHeaderTI.getVoyageCode().trimBlanks,
								terminal.code,
								ETRow_VoyageCode,
								_ediBookingHeaderTI);
	else			
		//epr par 37090 23/10/15 CCMS 2538 EDI Admin Improvements
		if  _voyage.hasDeparted and not _voyage.isNullVoyage and self.getMyTerminal.getConfig(EdiAddVoyageDepartError).Boolean   then
			app.raiseCMException1(Voyage_departed,_ediBookingHeaderTI.getVoyageCode(),"Voyage Code", _ediBookingHeaderTI);
		endif;
		
		operator := app.myRoot.allOperators[_ediBookingHeaderTI.operatorCode];									//Bug 40384
		if operator &lt;&gt; null then																				//Bug 40384
			if not _voyage.allOperators.includes(operator)
			and not _voyage.isNullVoyage	//19 May 2021	NDL	TFS 50897
			then													//Bug 40384
				app.raiseCMException3 (VB_VALID_VOY,operator.code,_voyage.code, self.class.name, null, null);	//Bug 40384
			endif;																								//Bug 40384
		endif;																									//Bug 40384
		
		// par 29158 - March 2012
		ediData.checkEDICutoff(_voyage.code, _ediBookingHeaderTI.operatorCode, _ediBookingHeaderTI);	// par 29158 - March 2012
	endif;
end;
</source>
        <access>protected</access>
        <Parameter name="_ediBookingHeaderTI" type="CM_EDIBookingHeaderTI" usage="input"/>
        <Parameter name="_pxyBookingRef" type="CM_BookingRef" usage="input"/>
        <Parameter name="_voyage" type="CM_Voyage" usage="io"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="verifyEDITIBookingItem1" id="ab6345f9-5ddf-4079-aa8f-221cd1acb6fe">
        <source>verifyEDITIBookingItem1(_ediBookingHeaderTI : CM_EDIBookingHeaderTI io; _ediBookingItemTI : CM_EDIBookingItemTI io; _passport : CM_Passport input) protected;
// par26223 cnwrs1 5 Nov 2010
/* Changes

Date		Name	TFS#		Description
============================================================================
13 Oct 2017	jlgrs1	TFS 5705 	SNO - EDIDataBooking Prenote release Req
12 Jun 2019	jlgka1	TFS 44416 	PNL Loading Default Cargo Type Settings via EDI
============================================================================*/
vars
	terminal 	: CM_Terminal;
	product		: CM_Product;
begin
	terminal := self.getMyTerminal();
	
	if _ediBookingHeaderTI = null or _ediBookingHeaderTI.id &lt;&gt; _ediBookingItemTI.id then
		app.raiseCMException2(ERR_EDI_BR_FIELD, _ediBookingItemTI.id, ETRow_Id, ETRow_Id, _ediBookingItemTI);
		// so wrong we can't continue
		return; 
	endif;

	// PAR25648 - There are issues with how we are slicing the hazard and undg codes in the COPARN.  
	// Need to review how we are to validate hazards and their undgs but as of 08/09/2010, this is not assigned to 
	// any enhancement. Was - ediBookingItem.validateIMCodesForVerify(); //PAR 22890 - cnwsh3 12/03/2010 
	
	if _ediBookingItemTI.product &lt;&gt; null then
		product := _ediBookingItemTI.getProduct(null, _ediBookingItemTI.product); //jlgka1 TFS 44416
	endif;
	
	if product = null then
		if _ediBookingItemTI.product &lt;&gt; null then
			app.raiseCMException2(ERR_EDI_BR_FIELD, _ediBookingItemTI.product, ETRow_Product, null, _ediBookingItemTI);
		endif;
	endif;
end;
</source>
        <access>protected</access>
        <Parameter name="_ediBookingHeaderTI" type="CM_EDIBookingHeaderTI" usage="io"/>
        <Parameter name="_ediBookingItemTI" type="CM_EDIBookingItemTI" usage="io"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="verifyEDITIBookingItem2" id="16062d74-330c-4156-ba2a-57b7688beeb7">
        <source>verifyEDITIBookingItem2(_ediBookingHeaderTI : CM_EDIBookingHeaderTI; _ediBookingItemTI : CM_EDIBookingItemTI; 
						_pxyBookingRef, _realBookingRef : CM_BookingRef input; _cmifBookingRef : CMIF_BookingRef;
						_passport : CM_Passport input) protected;
//
// par26223 cnwrs1 5 Nov 2010
//
// 13/07/2011	cnwcs5	par 26557 - changed user object saved on errors
//								  - change parameter usage to correctly reflect actual usage
// 03/04/2012	cnwcs5	par 29326 - keep only one reference to the real booking reference
//									use _realBookingRef instead of existingBookingHeader
//23 Oct 2012	cnwrs1	Par 30597 - write NULL if the old discharge port or voyage code is null
// 08/12/2014	cnwdb2	PAR 35364
//25 Jun 2015	cnwrs1	Par 33901/36027 - Default booking commodity
// 10 Nov 2017	jlgrs1	TFS 5705 - SNO - EDIDataBooking Prenote release Req
//04/07/2018    jlgrh7 TFS #39128 ADP - FW: DL for Rotation 1801002901 in production
//14/03/2019	jlgzm1  TFS 43642 Voyage updates to cargo planned to another voyage should error
vars
	terminal 					: CM_Terminal;
	voyage 						: CM_Voyage;
	actionStr 					: String;
	existingEDIBookingHeaderTI 	: CM_EDIBookingHeaderTI;
	existingEDIBookingHeaders 	: ObjectLongNameDict;
	releaseEDIBookingHeaderTI 	: CM_EDIBookingHeaderTI;
	cmifBookingRefItem 			: CMIF_BookingRefItem;
	releases 					: ObjectLongNameDict;
	found 						: Boolean;
	breleaseObj					: CM_BulkRelease;
	iteratorObj					: Iterator;
	chkDateTime					: TimeStamp;
	validCommodity 				: CM_Commodity;		// par26681 cnwrs1 29 Dec 2010
//	commodityError 				: Boolean;			// par26681 cnwrs1 29 Dec 2010
    commodityStr                : String;           //PAR 33710 cnwgb1 23 Dec 2014
	msg 						: String;		//par 30597
	ediData 					: CM_EDIData;
	iter 						: Iterator;			//tfs43642
	realTI						: CM_TrackedItem;	//tfs43642
begin
	terminal := self.getMyTerminal();
	ediData := _ediBookingHeaderTI.myEDIData;
	create existingEDIBookingHeaders transient;
	create releases transient;
	
	chkDateTime.setDate('01/01/3000'.Date);		// PAR 18030  
	
	actionStr := _ediBookingHeaderTI.messageMode;
	
	foreach cmifBookingRefItem in _cmifBookingRef.allCMIF_BRItems do
		if actionStr &lt;&gt; CM_EDITrackedItem.EDI_ACTION_DELETE then
			if _realBookingRef = null then
				cmifBookingRefItem.validateForCreate(_passport);
			else
				cmifBookingRefItem.validateForUpdate(_passport);
			endif;
		endif;
	endforeach;

	if actionStr &lt;&gt; CM_EDITrackedItem.EDI_ACTION_DELETE then
		if _realBookingRef = null then
			_pxyBookingRef.validateForCreate(_passport, _ediBookingHeaderTI, null);	
		else
			_pxyBookingRef.validateForUpdate(_passport, _ediBookingHeaderTI, null);	
		endif;
	endif;
	
	if _realBookingRef &lt;&gt; null then
		if _realBookingRef.dischargePort &lt;&gt; _pxyBookingRef.dischargePort then
			msg := _realBookingRef.dischargePort;
			if msg = null then
				msg := "NULL";
			endif;
			app.raiseCMWarning1(WARN_GENERIC, 'The discharge port for "' &amp; _pxyBookingRef.bookingReference &amp; '" (' 
											&amp; _pxyBookingRef.dischargePort &amp; ') differs to the existing value (' &amp; msg &amp; ').', 
											ETRow_DischargePort, _ediBookingHeaderTI, ediData);
		endif;
		
		if _realBookingRef.voyageCode &lt;&gt; _pxyBookingRef.voyageCode then
			msg := _realBookingRef.voyageCode;
			if msg = null then
				msg := "NULL";
			endif;
			app.raiseCMWarning1(WARN_GENERIC, 'The voyage code for "' &amp; _pxyBookingRef.bookingReference &amp; '" (' 
											&amp; _pxyBookingRef.voyageCode &amp; ') differs to the existing value (' &amp; msg &amp; ').', 
											ETRow_VoyageCode, _ediBookingHeaderTI, ediData);
			//tfs43642
			iter := _realBookingRef.allTIs.createIterator;
			//Are any TIs planned/queued to the original voyage, if true then raise error
			while iter.next(realTI) do
				if (realTI.hasFutureMoveLoadForVoyage(QUEUE_MODE, _realBookingRef.myVoyage) or 
					realTI.hasFutureMoveLoadForVoyage(PLANNING_MODE, _realBookingRef.myVoyage)) then
					app.raiseCMException2(ERR_Booking_Cargo_Plan_Que, realTI.id, realTI.myVoyage.code, ETRow_Voyage, _ediBookingHeaderTI);
				endif;
			endwhile;
			delete iter;
			//tfs43642
			
		endif;
		
	else
		if _ediBookingHeaderTI.myBookingRef &lt;&gt; null then
			app.raiseCMException1(EDIData_alreadyLoaded, null, null, _ediBookingHeaderTI);
		endif;
	endif;
	
	// should the existingBookingHeader not actually be existingBookingRef instead?
	self.verifyEDIDataTIForAction(_ediBookingHeaderTI, _realBookingRef, ediData.allEDITrackedItems, _passport);	//Par 18495. Jan 2009
	
	if _ediBookingHeaderTI.isStockBookingRef = true then
		if _ediBookingItemTI.product = null then
			if _ediBookingItemTI.cargoType = null then 
			//	app.raiseCMException1(REQUIRED_FIELD, app.getErrorString(Product), null, _ediBookingHeaderTI);
				app.raiseCMException1(Input_required_field_Required, app.getErrorString(Product), null, _ediBookingHeaderTI); // cnwdb2	PAR 35364
			endif;
		endif;
	endif;
	
	// Commodity Checks
    // If a commodity has been entered then we must verify it Depending on an EDI config flag we either error or warn. //cnwrs1 par26681 239 dec 2010
//	commodityError 	:= terminal.getConfig(EdiBookingCommodity).Boolean;
    commodityStr := _ediBookingItemTI.commodity;
    if commodityStr = null then
        commodityStr := _ediBookingItemTI.commodityDescription[1:4].trimBlanks.toUpper();				//+TFS39128
    endif;
    
	if commodityStr &lt;&gt; null then
		validCommodity 	:= app.myRoot.allCommodities[commodityStr];
		if validCommodity = null then
//			if commodityError then
				app.raiseCMException1(ERR_INVALID_COMMODITY, _ediBookingItemTI.commodity, app.getString(Commodity), _ediBookingItemTI);
//			else
//				app.raiseCMWarning1(ERR_INVALID_COMMODITY, _ediBookingItemTI.commodity, app.getString(Commodity), _ediBookingItemTI, self);
//			endif;
		else
			// found one but must also be available to be used.
			if validCommodity.isNotAvailableForEntry then
				// The users (in particular CentrePort) want an error not a warning as warning often get missed.
//				if commodityError then
					app.raiseCMException1(Commodity_available_entry, _ediBookingItemTI.commodity, app.getString(Commodity), _ediBookingItemTI);
//				else
//					app.raiseCMWarning1(Commodity_available_entry, _ediBookingItemTI.commodity, app.getString(Commodity), _ediBookingItemTI, self);
//				endif;
			endif;
			// Need to make sure the commodity contains the relevant cargo type.
			if validCommodity.allCargoTypes[_ediBookingItemTI.cargoType] = null											//cnwmc5 - 17 Feb 2016 - PAR 37522
			and _ediBookingItemTI.myCargoType &lt;&gt; null and _ediBookingItemTI.myCargoType.isCommodityRequired then		//cnwmc5 - 18 Feb 2016 - PAR 37522
//				if commodityError then
					app.raiseCMException2(CargoType_NotValid4_Commodity, _ediBookingItemTI.cargoTypeDescr, _ediBookingItemTI.commodity, ETRow_CargoTypeDescr, _ediBookingItemTI);		//cnwmc5 - 17 Feb 2016 - PAR 37522
//				else
//					app.raiseCMWarning2(CargoType_NotValid4_Commodity, _ediBookingHeaderTI.cargoTypeDescr, _ediBookingItemTI.commodity, ETRow_CargoTypeDescr, _ediBookingItemTI, self);
//				endif;
			endif;
		endif;
	endif;

	// Check there is a one to one relationship between booking ref and release number
	existingEDIBookingHeaderTI := existingEDIBookingHeaders[_ediBookingHeaderTI.id].CM_EDIBookingHeaderTI;
	
	if existingEDIBookingHeaderTI &lt;&gt; null then
	
		if existingEDIBookingHeaderTI.releaseRequestNumber &lt;&gt; _ediBookingHeaderTI.releaseRequestNumber then
		//	app.raiseCMException3(ERR_DUPLICATE_KEY,'Booking Reference', _ediBookingHeaderTI.id, " For release request " &amp; existingEDIBookingHeaderTI.releaseRequestNumber, ETRow_ReleaseRequest, _ediBookingHeaderTI);
			app.raiseCMException2(Already_exists35364, _ediBookingHeaderTI.id,existingEDIBookingHeaderTI.releaseRequestNumber, ETRow_ReleaseRequest, _ediBookingHeaderTI); //cnwdb2 PAR 35364

		endif;
	
	else
		existingEDIBookingHeaders[_ediBookingHeaderTI.id] := _ediBookingHeaderTI;	// need to check existingEDIbookingRefs - it is always = null
	endif;
	
	if _ediBookingHeaderTI.releaseRequestNumber &lt;&gt; null then
	
		releaseEDIBookingHeaderTI := releases[_ediBookingHeaderTI.releaseRequestNumber].CM_EDIBookingHeaderTI;
		
		if releaseEDIBookingHeaderTI &lt;&gt; null then
			if releaseEDIBookingHeaderTI.id &lt;&gt; _ediBookingHeaderTI.id then
			//	app.raiseCMException3(ERR_DUPLICATE_KEY,'Bulk Release', _ediBookingHeaderTI.releaseRequestNumber, " For booking reference " &amp; releaseEDIBookingHeaderTI.id, ETRow_ReleaseRequest, _ediBookingHeaderTI);
				app.raiseCMException2(Already_exists35364b, _ediBookingHeaderTI.releaseRequestNumber, releaseEDIBookingHeaderTI.id, ETRow_ReleaseRequest, _ediBookingHeaderTI);
			endif;
		else
			releases[_ediBookingHeaderTI.releaseRequestNumber] := _ediBookingHeaderTI;
		endif;
		
		found := false;
		
		if _realBookingRef &lt;&gt; null then
			foreach breleaseObj in _realBookingRef.allReleaseRequests do
				if breleaseObj.code = _ediBookingHeaderTI.releaseRequestNumber then
					found := true;
				endif;
			endforeach;
		endif;
		
		if (not found) then
			iteratorObj	:=	terminal.allBulkReleasesByCodeDate.createIterator();
			terminal.allBulkReleasesByCodeDate.startKeyGeq(_ediBookingHeaderTI.releaseRequestNumber, chkDateTime, iteratorObj);
			
			while iteratorObj.next(breleaseObj) do
				if breleaseObj.code &lt;&gt; _ediBookingHeaderTI.releaseRequestNumber then
					break;
				else
					terminal.validateBulkReleaseNumber(breleaseObj, 'Bulk Release');
					break;
				endif;
			endwhile;
			
			delete iteratorObj;
		endif;
	endif;
	
	_ediBookingItemTI.validateTemperature();
epilog
	delete existingEDIBookingHeaders;
	delete releases;
	delete iteratorObj;
	delete iter; //tfs43642
end;</source>
        <access>protected</access>
        <Parameter name="_ediBookingHeaderTI" type="CM_EDIBookingHeaderTI"/>
        <Parameter name="_ediBookingItemTI" type="CM_EDIBookingItemTI"/>
        <Parameter name="_pxyBookingRef" type="CM_BookingRef" usage="input"/>
        <Parameter name="_realBookingRef" type="CM_BookingRef" usage="input"/>
        <Parameter name="_cmifBookingRef" type="CMIF_BookingRef"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="verifyHazEDITIs" id="3dc04299-25d7-421a-bead-789e78ca81ba">
        <source>verifyHazEDITIs(_allHazDetails : CM_EDITISet; _cmifBookingRef : CMIF_BookingRef);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 November 2016	cnwndl1	Initial creation	TFS 2843 / 2604
// 13 Oct 2017	jlgrs1	TFS 5705 - SNO - EDIDataBooking Prenote release Req
*/

vars
	ediTI : CM_EDITrackedItem;
	ediHazDetailsTI : CM_EDIHazDetailsTI;
	bookingId : String;
	sequence : String;
	cmifItem : CMIF_BookingRefItem;
	selectedCmifItem : CMIF_BookingRefItem;
begin
	foreach ediTI in _allHazDetails do
		ediHazDetailsTI := ediTI.CM_EDIHazDetailsTI;
		bookingId := ediHazDetailsTI.bookingId;
		sequence := ediHazDetailsTI.bookingItemSeq;
		if _cmifBookingRef &lt;&gt; null then
			foreach cmifItem in _cmifBookingRef.allCMIF_BRItems do
				if cmifItem.sequence = sequence then
					selectedCmifItem := cmifItem;
					break;
				endif;
			endforeach;
		endif;
		if selectedCmifItem = null then
			app.raiseCMException1(Booki_item_with_seque_not_foun, sequence, null, ediTI);
		endif;
		ediHazDetailsTI.verifySelf();
	endforeach;

epilog

end;</source>
        <Parameter name="_allHazDetails" type="CM_EDITISet"/>
        <Parameter name="_cmifBookingRef" type="CMIF_BookingRef"/>
    </JadeMethod>
