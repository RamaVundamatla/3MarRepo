    <JadeMethod name="setWeightColumn" id="ca1e2c2c-6548-4de4-9e12-fb18f5e7fab1">
        <source>setWeightColumn(_bln : Boolean);
// ---------------------------------------------------------------------------
// Created:     13 September 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars
	blnVisible : Boolean;
begin

	blnVisible := _bln;

	if blnVisible = true then 
	// dont make any changes
		return;
	endif;
	
	
	// else hide weight columns and resize fields. 

	self.lblWeightDtl.visible 		:= blnVisible;
	self.lblTotalWeight.visible 	:= blnVisible;
	self.lblGrandTotalsWt.visible 	:= blnVisible;
	self.lblT_1.visible				:= blnVisible;
	self.lblT_2.visible 			:= blnVisible;
	self.lblT.visible 				:= blnVisible;
	self.line3.visible 				:= blnVisible;
	
	self.lblSupplierDtl.left := self.lblSupplierDtl.left + 15;
	self.lblSupplier.left := self.lblSupplier.left + 15;
	self.lblSpeciesDtl.left := self.lblSpeciesDtl.left + 25;
	self.lblSpecies.left := self.lblSpecies.left + 25;
	self.lblGradeDtl.left := self.lblGradeDtl.left + 35;
	self.lblGrade.left := self.lblGrade.left + 35;
	self.lblLengthDtl.left := self.lblLengthDtl.left + 35;
	self.lblLength.left := self.lblLength.left + 35;
	self.lblTypeDtl.left := self.lblTypeDtl.left + 45;
	self.lblType.left := self.lblType.left + 45;
	self.lblTreatmentDtl.left := self.lblTreatmentDtl.left + 45;
	self.lblTreatment.left := self.lblTreatment.left + 45;
	self.lblAvgVol.left := self.lblAvgVol.left + 45;
	self.lblAvg.left := self.lblAvg.left + 50;
	self.lblAvgSED.left := self.lblAvgSED.left + 45;
//	self.lblAvgSED.left := self.lblAvgSED.left + 5;
	self.lblPcsDtl.left := self.lblPcsDtl.left + 45;
	self.lblPcs.left := self.lblPcs.left + 45;
	self.lblJasDtl.left := self.lblJasDtl.left + 45;
	self.lblJas.left := self.lblJas.left + 45;
	
	self.lblTotalSED.left := self.lblTotalSED.left + 45;
	self.lblTotalJas.left := self.lblTotalJas.left + 45;
	self.lblTotalPcs.left := self.lblTotalPcs.left + 45;
	self.lblJas_1.left := self.lblJas_1.left + 45;
	self.lblPcs_1.left := self.lblPcs_1.left + 45;
	self.line1.left := self.line1.left + 45;
	self.line2.left := self.line2.left + 45;
	
	
//	self.lblTotalDtl.left := self.lblTotalDtl.left;

	self.lblGrandTotalJas.left := self.lblGrandTotalJas.left + 45;
	self.lblGrandTotalPcs.left := self.lblGrandTotalPcs.left + 45;
	
	self.lblJas_1_1.left := self.lblJas_1_1.left + 45;
	self.lblPcs_1_1.left := self.lblPcs_1_1.left + 45;

end;</source>
        <Parameter name="_bln" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="sortData" id="bcf656e5-63e1-4995-851b-4ec27c653108">
        <source>sortData(_set : CM_SOHLocationSet) : DynaDictionary protected;
// 24/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls

vars

	dyna	: DynaDictionary;
	soh		: CM_SOHLocation;
	sort	: CMIF_SOHReporter;

begin

	create dyna transient;
	dyna.setMembership(CMIF_SOHReporter);
	dyna.addMemberKey(CMIF_SOHReporter::myVoyage.name, false, false);
	dyna.addMemberKey(CMIF_SOHReporter::lot.name, false, false);
	dyna.addMemberKey(CMIF_SOHReporter::supplier.name, false, false);
	dyna.addMemberKey(CMIF_SOHReporter::place.name, true, false);
	dyna.addMemberKey(CMIF_SOHReporter::length.name, true, false);
	dyna.addMemberKey(CMIF_SOHReporter::myProduct.name, false, false);
	dyna.endKeys(true);
	
	foreach soh in _set do
		create sort transient;
//		sort.myVoyage		:= soh.myLocationsController.CM_LogVoyageController.myLogLot.myLogVoyage;
		sort.myVoyage		:= soh.myLocationsController.CM_LogVoyageController.myLogVoyageStructure.myVoyage;
		sort.myLot			:= soh.myLocationsController.CM_LogVoyageController.myLogLot;
		sort.lot 			:= soh.myLocationsController.CM_LogVoyageController.myLogLot.lotNo;
		sort.mySupplier		:= soh.myProduct.myOperator;
		sort.supplier		:= soh.myProduct.getDisplayStringForAttribute(ETRow_OperatorCode, true);
		sort.place			:= soh.myLocationsController.CM_LogVoyageController.place;
		sort.myProduct		:= soh.myProduct;
		sort.mySOHLocation	:= soh;
		sort.length			:= soh.myProduct.CM_ProductLog.lengthCode.Real;	
		dyna.add(sort);
	endforeach;
	return dyna;
	

end;</source>
        <access>protected</access>
        <Parameter name="_set" type="CM_SOHLocationSet"/>
        <ReturnType type="DynaDictionary"/>
    </JadeMethod>
</GUIClass>
