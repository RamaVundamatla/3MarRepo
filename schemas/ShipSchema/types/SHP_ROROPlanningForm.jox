    <JadeMethod name="getFrameForLayer" id="1a25b777-f7b2-48c2-ab20-389e04d0c071">
        <source>getFrameForLayer(_layer : CM_DeckLayerLayout; _backFrames : ObjectArray) : CMUI_PointDrawingFrame;
// ---------------------------------------------------------------------------
// Created:     07 January 2011 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	obj : Object;
	layerFrame : CMUI_PointDrawingFrame;
begin
	
	foreach obj in _backFrames discreteLock do
		if obj = null then
			continue;
		endif;
		
		layerFrame := obj.CMUI_PointDrawingFrame;
		if layerFrame.userObject = _layer then
			return layerFrame;
		endif;
	
	endforeach;
	
	return null;
epilog

end;</source>
        <Parameter name="_layer" type="CM_DeckLayerLayout"/>
        <Parameter name="_backFrames" type="ObjectArray"/>
        <ReturnType type="CMUI_PointDrawingFrame"/>
    </JadeMethod>
