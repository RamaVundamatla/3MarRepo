    <JadeMethod name="loadPropertyChange" id="5efe518c-9764-47d0-b1ff-51892f7ad073">
        <source>loadPropertyChange(_propertyChangeProxy:HMS_PropertyChange io) :Boolean protected;

vars
	realObject: HMS_Object;
	proxyObject: HMS_PropertyChange;
	error: CM_Error;
	countError,countOK: Integer;
begin
	if _propertyChangeProxy.myTransaction = null then
//		app.writeLog(class.name&amp;'::'&amp;method.name&amp;' '&amp;_propertyChangeProxy.propertyDescription&amp;" ERROR: "&amp;"No Transaction.",0);
		return false;
	endif;
	app.myTrxCA.trxCreateHMSObject(_propertyChangeProxy, realObject, app.myPassport);
	if app.myPassport.trxCompletedOK and
	   app.myPassport.allErrorWarnings.size = 0 then
		beginTransaction;
		realObject.HMS_PropertyChange.set(_propertyChangeProxy.myTransaction,_propertyChangeProxy.propertyDescription,_propertyChangeProxy.propertyValueOld,_propertyChangeProxy.propertyValueNew);
		commitTransaction;
		return true;
	else
		foreach error in app.myPassport.allWarnings do
			app.writeLog(class.name&amp;'::'&amp;method.name&amp;' '&amp;_propertyChangeProxy.String&amp;" WARNING: "&amp;error.text,0);
		endforeach;
		foreach error in app.myPassport.allErrors do
			app.writeLog(class.name&amp;'::'&amp;method.name&amp;' '&amp;_propertyChangeProxy.String&amp;" ERROR: "&amp;error.text,0);
		endforeach;
		return false;
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_propertyChangeProxy" type="HMS_PropertyChange" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
