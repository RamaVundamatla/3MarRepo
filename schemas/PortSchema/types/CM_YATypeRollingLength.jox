    <JadeMethod name="getCriteriaValueForTi" id="add52724-2dda-4e2a-bced-d9d2fb2ed79c">
        <source>getCriteriaValueForTi(_ti: CM_TrackedItem; _criteriaValue: Any output);
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 13 May 2022
TFS#		: 53316
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/
begin
	if _ti.isKindOf(CM_BreakBulkGeneric) then
		//_criteriaValue := _ti.CM_BreakBulkGeneric.rollingLength.asStringJMT;
		_criteriaValue := _ti.CM_BreakBulkGeneric.getRollingLength();	// ### TFS 54021 29June2022 NAVPW1
	endif;
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_criteriaValue" type="Any" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getDataDisplay" id="ed577c3b-e726-40c3-9dcc-bfe1b3a6ddfb">
        <source>getDataDisplay(pDataObj: CM_YAData): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 July 2024	navrv30	Bug 64703: FR | 53383 - Release Request by Type - Cargo Group - Measurement Type

*/

vars
	measureType	: CM_MeasurementType;
	valueStr : String;
begin
	measureType := app.getDefaultMeasurementForType(Type_Length);   //for RollingLength
	valueStr := pDataObj.getDataValue().String;
	if measureType &lt;&gt; null and valueStr &lt;&gt; null then
			valueStr := app.convertMeasurementForDisplay(measureType.shortName, valueStr.Decimal);	
			return valueStr &amp; " " &amp; measureType.shortName;
	endif;
	return valueStr;
epilog

end;</source>
        <Parameter name="pDataObj" type="CM_YAData"/>
        <ReturnType type="String"/>
    </JadeMethod>
