    <JadeMethod name="displaycellText" id="87d241f4-75b3-4016-ae71-4d27b30200c5">
        <source>displaycellText( _row : Integer; _column : Integer ) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 October 2010	cnwndl1	Initial creation

*/

vars

	tableCell : JadeTableCell;
	listBox : CMUI_ListBox;
	index : Integer;
	str : String;
	
begin

	if _row &lt;= self.tblCalendar.fixedRows then
		return;
	endif;
	if _column &lt;= self.tblCalendar.fixedColumns then
		return;
	endif;
		
	tableCell := self.tblCalendar.accessCell(_row,_column);
	listBox := tableCell.cellControl.CMUI_ListBox;
	if listBox &lt;&gt; null then
	
		foreach index in 1 to listBox.listCount do
			if str = null then
				str := listBox.itemText[index];
			else
				str := str &amp; CrLf &amp; listBox.itemText[index];
			endif;
		endforeach;
		
	endif;
	
	self.tblCalendar.setCellText(_row,_column,str);
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_row" type="Integer"/>
        <Parameter name="_column" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doBackNext" id="dcdb97f9-a3cd-4b73-8746-8f9ab9d37450">
        <updating/>
        <source>doBackNext( incr : Integer ) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
01 November 2010	cnwndl1	Initial creation
// 23 May 2016	cnwns1	TFS 488 - Multi Timezone Support
*/

vars

	date : Date;
	timeStampSystem : TimeStamp;
begin

	date := null;
	date.setDate( self.day, self.month, self.year);
	if not date.isValid then
		return;
	endif;
	
	timeStampSystem.cnEcSetDateAndTime(date,TimeStartOfDay);
	date := self.systemToLocalTime(timeStampSystem).date();// 23 May 2016	cnwns1	TFS 488 - Multi Timezone Support

	if incr = -1 then
		if self.cmbPeriod.text = ByDay then
			date := date - 1;
		elseif self.cmbPeriod.text = ByWeek then
			date := date - 7;
		elseif self.cmbPeriod.text = ByMonth then
			date := date.cnEcAddMonths( -1 );
		endif;
	
	elseif incr = 1 then
		if self.cmbPeriod.text = ByDay then
			date := date + 1;
		elseif self.cmbPeriod.text = ByWeek then
			date := date + 7;
		elseif self.cmbPeriod.text = ByMonth then
			date := date.cnEcAddMonths( 1 );
		endif;
	
	endif;
	
	self.txtDate.setDate(date);
	self.doChangeDate( true );

epilog

end;</source>
        <Parameter name="incr" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doChangeDate" id="237d6f3b-586c-4b52-b94e-b162b448c2a5">
        <updating/>
        <source>doChangeDate(_forceRefresh : Boolean) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21 October 2010	cnwndl1	Initial creation
// 23 May 2016	cnwns1	TFS 488 - Multi Timezone Support
*/

vars

	date : Date;
	timeStampLocal : TimeStamp;
	refreshNeeded : Boolean;
begin
	
	if txtDate.getDate.isValid then
		timeStampLocal.cnEcSetDateAndTime(txtDate.getDate,TimeStartOfDay);
		date := self.localToSystemTime(timeStampLocal).date();// 23 May 2016	cnwns1	TFS 488 - Multi Timezone Support

		if self.year &lt;&gt; date.year then
			self.year := date.year;
			refreshNeeded := true;
		endif;
		if self.month &lt;&gt; date.month then
			self.year := date.year;
			self.month := date.month;
			refreshNeeded := true;
		endif;
		if self.day &lt;&gt; date.day then
			self.day := date.day;
			refreshNeeded := true;
		endif;
		
		if refreshNeeded or _forceRefresh then
			self.doRefreshCalendar( true );
		endif;
		
	endif;

epilog

end;</source>
        <Parameter name="_forceRefresh" type="Boolean"/>
    </JadeMethod>
