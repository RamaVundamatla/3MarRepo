    <JadeMethod name="setProxyFromObject" id="bf5491d2-9b77-44a8-b035-a6b6f95975d2">
        <updating/>
        <source>setProxyFromObject(_object: CM_TrackedItem) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 July 2017	jlghl1	Initial creation

*/

vars

begin
	inheritMethod(_object);
	
	self.id := _object.id;
	if _object.isKindOf(CM_Car) then
		self.make := _object.CM_Car.make;							
		self.model := _object.CM_Car.model;						
		self.type := _object.CM_Car.carType;	
		self.year := _object.CM_Car.year;
	endif;
epilog

end;</source>
        <Parameter name="_object" type="CM_TrackedItem"/>
    </JadeMethod>
