    <JadeMethod name="canAddToCargoCounter" id="7b629dd9-a943-43af-ad17-85bba2d85097">
        <source>canAddToCargoCounter() : Boolean;
/*

Purpose:		// TFS 44804	

Parameters:			

Return Value:		

Date		Who		Reason
16 May 2019	jlgab1	Initial creation

*/

vars

begin
	return (self.type = TRANS_TYPE_REASSEMBLY
		or self.type = TRANS_TYPE_RECEIVE
		or self.type = TRANS_TYPE_REC_RAIL
		or self.type = TRANS_TYPE_REC_RAIL_INTER_TERM
		or self.type = TRANS_TYPE_REC_ROAD
		or self.type = TRANS_TYPE_REC_ROAD_INTER_TERM
		or self.type = TRANS_TYPE_REC_SHIP
		or self.type = TRANS_TYPE_EXPORT_RETURNED		
		or self.type = TRANS_TYPE_ReinstateReject
		or self.type = TRANS_TYPE_BUSINESS_U_RECEIVE
		or self.type = TRANS_TYPE_REC_TRANSHIP) ;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="canBeResync" id="f88e2785-4cac-4e72-89bb-8ba61e7aac92">
        <source>canBeResync(_ti : CM_TrackedItem):Boolean;
/*

Purpose:			
		TFS 44804 do not change volume on receival transaction during resync &gt;&gt; Moved to this one 
Parameters:			

Return Value:		

Date		Who		Reason
03 Mar 2020 cnwma1	Bug 48772: ADP - RE: Resyncing Issue in Production
25 Feb 2025 navma1  MTN-34075 MTN | Dead Lock (1081) on CM_JobsByPriorityRequiredDT
*/

vars
	cargoType : CM_CargoType;
begin
	cargoType := _ti.myCargoType;
	
	if  cargoType.isAllowDuplicates  and self.canAddToCargoCounter() then
		// TFS 53522 navsj20
		if  _ti.hasSplitOrMergeTrans then 
			if self.myTerminal.getConfig(AllowTransResyncForAmt).Boolean then
				return true;
			else
				return false;
			endif;
		elseif self.myTerminal.getConfig(AllowTransResyncForAmt).Boolean and (cargoType.isBulk or cargoType.isBreakBulk) then //25.02.2025 navma1 #MTN-34075
			return true;
		endif;
		// TFS 53522 navsj20
	endif;
	return true;
epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
