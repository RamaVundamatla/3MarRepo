        <webService/>
        <type name="String"/>
        <text>A value to display for the field by default when a new record is being created

    
</text>
        <wsdlName>urn:JadeWebServices/JMTWebService/:defaultDescription</wsdlName>
    </PrimAttribute>
    <PrimAttribute name="defaultId" id="1a0aa5a8-bb4a-4e09-ac55-8cacbfb24c8b">
        <xmlType>string	http://www.w3.org/2001/XMLSchema</xmlType>
        <webService/>
        <type name="String"/>
        <text>An internal value to associate with the field by default when a new record
 is being created. Eg if the defaultDescription is "ISO Container" the defaultId would be 1.</text>
        <wsdlName>urn:JadeWebServices/JMTWebService/:defaultId</wsdlName>
