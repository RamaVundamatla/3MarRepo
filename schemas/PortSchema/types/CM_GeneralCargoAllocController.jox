    <JadeMethod name="testIsControllerFullYA" id="f388733a-c2be-4738-bc75-de67dd7c93c8">
        <source>testIsControllerFullYA(_yaAgent: CM_YAAutoplanAgent input): Boolean;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 24/06/2020	jlgdap1		Initial creation TFS 49453 ASPA Satellite View Screen for Flexible Terminal Areas
//
vars
	hasSomeCapacity : Boolean;

begin
	if self.testIsControllerFullTAMaxYA(_yaAgent, hasSomeCapacity) then
		if hasSomeCapacity then
			_yaAgent.myCMIFYAAutoPlan.addLocationForSplitQ(_yaAgent.myCurrentAllocation, self.myGroup);
		endif;
		return true;
	endif;
	
	return false;

epilog

end;</source>
        <Parameter name="_yaAgent" type="CM_YAAutoplanAgent" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateMoveTo" id="a3f32c8a-a289-4ef3-aa4c-f127a7c7585f">
        <source>validateMoveTo(control: CMIF_MoveController input);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 10/06/2020	jlgdap1		Initial creation TFS 49453 ASPA Satellite View Screen for Flexible Terminal Areas
//
vars
	group : CM_GeneralCargoAllocGroup;
	lc : CM_LocationsController;
	lcArray : CM_LCArray;

begin
	if control.isForcedMove then
		return;
	endif;
	if control.myToPrimaryLocation.isKindOf(CM_MachineController) then
		return;
	endif;
	
	inheritMethod(control);
	//return;
	create lcArray transient;
	self.myGroup.allLocations.copy(lcArray);
	
	control.setMyToSecondaryLocations(lcArray);
	
epilog
	delete lcArray;
end;</source>
        <Parameter name="control" type="CMIF_MoveController" usage="input"/>
    </JadeMethod>
</Class>
