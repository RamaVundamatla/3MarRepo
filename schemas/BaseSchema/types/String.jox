	locked			: Integer;
	maxPasteLength	: Integer;
	
begin
	maxPasteLength	:=	clipboardString.maxLength;
	
	if call cnEcOpenClipboard(null) &gt; 0 then
		if call cnEcIsClipboardFormatAvailable(1) &gt; 0 then
			handle := call cnEcGetClipboardData(1);
			locked := call cnEcGlobalLock(handle);
			
			// Ensure that the JADE string is the correct length.
			if call cnEcStringLength(locked) &gt; maxPasteLength then 
				CnEcBaseSchemaException.raise_(CNEC_X_83001, "The clipboard contents are too long; the maximum length is " &amp; maxPasteLength.String &amp; ".");
			else
				// Copy the clipboard data directly into the JADE string.
				call cnEcCopyStringFromClipboard(clipboardString, locked);
			endif;
			
			call cnEcGlobalUnlock(locked);
		else
			CnEcBaseSchemaException.raise_(CNEC_X_83002, "The clipboard does not contain any text.");
		endif;
		
		call cnEcCloseClipboard;
	else
		CnEcBaseSchemaException.raise_(CNEC_X_83003, "Could not open the clipboard.");
	endif;
	
	self	:=	clipboardString;
end;
*/</source>
    </JadeMethod>
    <JadeMethod name="cnEcCopyToClipboard" id="2b1b0f85-f5de-43cb-a718-95eb32935b9d">
        <source>cnEcCopyToClipboard();
// --------------------------------------------------------------------------------
// Created:		30 May 2001 by cnwdad1
//
// Purpose:		Copies the receiver into the clipboard.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	app.copyStringToClipboard(self);
end;
/*
vars
	handle : Integer;
	locked : Integer;

begin
	// Allocate some global memory to copy the string into.
	// The memory must be global and DDE sharable.
	handle	:=	call cnEcGlobalAlloc(#2002, self.length + 1);
	
	// Lock the memory.
	locked	:=	call cnEcGlobalLock(handle);
	
	// Copy the string into the buffer.
	call cnEcCopyStringToClipboard(locked, self);
	call cnEcGlobalUnlock(handle);
	
	if call cnEcOpenClipboard(null) &gt; 0 then
		call cnEcEmptyClipboard;
		
		// Set the clipboard to contain the copy of the text.
		call cnEcSetClipboardData(1, handle);
		call cnEcCloseClipboard;
	else
		CnEcBaseSchemaException.raise_(CNEC_X_83003, "Could not open the clipboard.");
	endif;
end;
*/</source>
    </JadeMethod>
    <JadeMethod name="cnEcDecodeWebData" id="6249aaee-9ee7-4651-893a-b14b60916bb7">
        <updating/>
        <source>cnEcDecodeWebData():String updating;
// --------------------------------------------------------------------------------
// Created:		31 May 2000 by cnwdad1
//
// Purpose:		Replaces all "special" characters within an HTTP string with ASCII
//				characters.  For example, spaces in the HTTP string are represented
//				as %20 - therefore all occurrences of %20% are replaced with a
//				space character.
//
// Parameters:	None
//
// Returns:		String - the decoded web (http) string.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 21/11/2000	cnwdad1		Change to check that each byte of the encoded character
//							is a valid hex character before transforming it.  This
//							is to allow for genuine percent characters in the data.
// 30/01/2003	cnwjha1		Changed to handle the cases 1) where the last character
//							is a %, and 2) where a percent is followed by invalid
//							data, we need to skip to the next percent, not convert
//							the first pair of numbers we come to.
// 20/06/2023	navmd1		Flipped the check of if the charPos was 'less than'
//							length-2 as this method just breaks straight away
// --------------------------------------------------------------------------------
vars
	replacementChar	: Character;
	characterPos	: Integer;
	stringLength	: Integer;
	byteOne			: Character;			// cnwdad1 21/11/2000.
	byteTwo			: Character;			// cnwdad1 21/11/2000.

begin
	// '+' is really a space.
	self.replaceChar("+", " ");
	// '%xx' is really 4'xx'.
	characterPos	:=	self.pos("%", 1);

	while characterPos &gt; 0 do
		if characterPos &gt; self.length-2 then	//jha
			break;								//jha
		endif;									//jha
		
		byteOne			:=	self[characterPos+1];			// cnwdad1 21/11/2000.
		byteTwo			:=	self[characterPos+2];			// cnwdad1 21/11/2000.
		
		if byteOne.isHex and byteTwo.isHex then				// cnwdad1 21/11/2000.
//			replacementChar	:=	(self[characterPos+1].cnEcHexToInt * 16 + self[characterPos+2].cnEcHexToInt).Character;		// cnwdad1 21/11/2000.
			replacementChar	:=	(byteOne.cnEcHexToInt * 16 + byteTwo.cnEcHexToInt).Character;								// cnwdad1 21/11/2000.
			stringLength	:=	self.length;
	
			if (characterPos + 3) &lt;= stringLength then
				self	:=	self[1:characterPos-1] &amp; replacementChar &amp; self[(characterPos + 3):end];
			else
				self	:=	self[1:characterPos-1] &amp; replacementChar;
			endif;
	
			characterPos	:=	self.pos("%", characterPos);
		else												// cnwdad1 21/11/2000.
			// Skip past this "%" character.				// cnwdad1 21/11/2000.
			characterPos	:=	characterPos + 1;			// cnwdad1 21/11/2000.
			characterPos	:=	self.pos("%", characterPos);	//jha
		endif;
	endwhile;

	return self;
end;</source>
        <text>___________________________________________________________________________

              P R O P R I E T A R Y   N O T I C E

This software, in whole and in every part, is proprietary to Jade Software
Corporation Limited at Christchurch, New Zealand and is not to be
reproduced, used or disclosed except upon prior written permission of Jade
Software Corporation Limited.

  COPYRIGHT © JADE SOFTWARE CORPORATION LIMITED 2002 - ALL RIGHTS RESERVED
____________________________________________________________________________</text>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="cnEcDisplayNZPhoneNumber" id="6a810a53-4ec5-4f70-90a6-c9336a56a4a3">
        <source>cnEcDisplayNZPhoneNumber(): String;
// Using self as input, return the number in an appropriate phone number format for New Zealand.
// If not recognised as a valid NZ phone number, just return the number as it was received.
vars
	inputString		: String;
	outputString	: String;
	errorMsg		: String;

begin
	inputString	:=	self;

	if inputString.cnEcValidateNZPhoneNumber(errorMsg) = false then
		return inputString;
	endif;	

	if inputString.length = 9 and inputString[2:1] &lt;&gt; "2" then		// normal 2 digit Std code
		outputString[1:1]	:=	"(";			//  format (0n) 123 4567
		outputString[2:2]	:=	inputString[1:2];
		outputString[4:2]	:=	") "; 			
		outputString[6:3]	:=	inputString[3:3];
		outputString[9:1]	:=	" "; 			
		outputString[10:4]	:=	inputString[6:4];
	endif;	

	if inputString.length = 9 and inputString[2:1] = "2" then		// 6 digit cell phone or pager
		outputString[1:1]	:=	"(";			//  format (02n) 123 456
		outputString[2:3]	:=	inputString[1:3];
		outputString[5:2]	:=	") "; 			
		outputString[7:3]	:=	inputString[4:3];
		outputString[10:1]	:=	" "; 			
		outputString[11:3]	:=	inputString[7:3];
	endif;	 

	if inputString.length = 10 and inputString[2:1] = "2" then		// 7 digit cell phone or pager
		outputString[1:1]	:=	"(";			//  format (02n) 123 4567
		outputString[2:3]	:=	inputString[1:3];
		outputString[5:2]	:=	") "; 			
		outputString[7:3]	:=	inputString[4:3];
		outputString[10:1]	:=	" "; 			
		outputString[11:4]	:=	inputString[7:4];
	endif;	

	if inputString.length = 10 and inputString[2:1] &lt;&gt; "2" then		// 0508 or 0800 or 0900 phone number
		outputString[1:4]	:=	inputString[1:4];	//  format 0800 123 456
		outputString[5:1]	:=	" "; 			
		outputString[6:3]	:=	inputString[5:3];
		outputString[9:1]	:=	" "; 			
		outputString[10:3]	:=	inputString[8:3];
	endif;

	if outputString = "" then			// if nothing else just return the same 
		outputString	:=	inputString;
	endif;	

	return outputString;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="cnEcDisplayNonPrintable" id="35c59078-6536-4f8d-b20b-b3c8bf4fad30">
        <source>cnEcDisplayNonPrintable():String;
// Convert non-printable characters in the receiver to 
// ASCII code equivalents and display in angle brackets.
vars
	charIndex		: Integer;
	returnString	: String;
	theCharacter	: Character;
	receiverLength	: Integer;

begin
	receiverLength	:=	self.length;
	
	while charIndex &lt; receiverLength do
		charIndex		:=	charIndex + 1;
		theCharacter	:=	self[charIndex].Character;

		if theCharacter.isPrintable then
			returnString	:=	returnString &amp; theCharacter;
		else 
			returnString	:=	returnString &amp; "&lt;/" &amp; theCharacter.Integer.String.padLeadingZeros(3) &amp; "&gt;";
		endif;
	endwhile;

	return returnString;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="cnEcEncodeWebData" id="27b85a68-b27e-4c50-a695-9f4125dd6854">
        <source>cnEcEncodeWebData():String;
// --------------------------------------------------------------------------------
// Created:		31 May 2000 by cnwdad1
//
// Purpose:		Replaces all "special" ASCII characters within the string with the
//				HTTP equivalents.  For example, spaces in a string should be
//				represented as %20 in an HTTP string - therefore all occurrences
//				of spaces will be replaced with a %20.
//
// Parameters:	None
//
// Returns:		String - the encoded web (http) string.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 24/09/2004	cnwdad1		A change in JADE 6.0.9 means that the value of the
//							"stringLength" variable is now only evaluated at the
//							beginning of the foreach loop, hence the resetting of
//							the variable's value within the loop is ignored.
//							Changed to use a while loop instead.
// --------------------------------------------------------------------------------
vars
	asciiArray		: CharacterArray;
	httpArray		: StringArray;
	httpIndex		: Integer;
	charIndex		: Integer;
	stringLength	: Integer;
	workString		: String;
	workChar		: Character;

begin
	create asciiArray transient;
	create httpArray transient;

	asciiArray.add(',');
	httpArray.add('%2C');

	asciiArray.add('-');
	httpArray.add('%2D');

	asciiArray.add('"');
	httpArray.add('%22');

	asciiArray.add('$');
	httpArray.add('%24');

	asciiArray.add('&lt;');
	httpArray.add('%3C');

	asciiArray.add('&gt;');
	httpArray.add('%3E');

	asciiArray.add(';');
	httpArray.add('%3B');

	asciiArray.add(':');
	httpArray.add('%3A');

	asciiArray.add('(');
	httpArray.add('%28');	

	asciiArray.add(')');
	httpArray.add('%29');

	asciiArray.add(' ');
	httpArray.add('%20');	//('%A0');	Spaces are each supposed to be represented by "+", but this doesn't seem to work correctly.

	asciiArray.add('&amp;');
	httpArray.add('%26');

	asciiArray.add('!');
	httpArray.add('%21');

	asciiArray.add('#');
	httpArray.add('%23');

	asciiArray.add('%');
	httpArray.add('%25');

	asciiArray.add('^');
	httpArray.add('%5E');

	asciiArray.add('+');
	httpArray.add('%2B');

	asciiArray.add('=');
	httpArray.add('%3D');

	asciiArray.add(';');
	httpArray.add('%3B');

	asciiArray.add(':');
	httpArray.add('%3A');

	asciiArray.add("'");
	httpArray.add('%27');

	asciiArray.add('?');
	httpArray.add('%3F');

	asciiArray.add('/');
	httpArray.add('%2F');

	asciiArray.add('\');
	httpArray.add('%5C');

	asciiArray.add('|');
	httpArray.add('%7C');

	asciiArray.add('`');
	httpArray.add('%60');

	asciiArray.add('~');
	httpArray.add('%7E');

	asciiArray.add('{');
	httpArray.add('%7B');

	asciiArray.add('}');
	httpArray.add('%7D');

	workString		:=	self;
	stringLength	:=	workString.length();

// cnwdad1 24/09/2004 - A change in JADE 6.0.9 means that the value of the "stringLength"
// variable is now only evaluated at the beginning of the foreach loop, hence the resetting
// of the variable's value within the loop is ignored.  Changed to use a while loop instead.
//	foreach charIndex in 1 to stringLength do
//		workChar	:=	workString[charIndex];
//		httpIndex	:=	asciiArray.indexOf(workChar);
//
//		if httpIndex &gt; 0 then
//			workString		:=	workString.cnEcInsertInto(httpArray[httpIndex], charIndex, (charIndex + 1));
//			stringLength	:=	workString.length;
//		endif;
//	endforeach;
	
	charIndex	:=	1;
	
	while charIndex &gt; 0 and charIndex &lt;= stringLength do
		workChar	:=	workString[charIndex];
		httpIndex	:=	asciiArray.indexOf(workChar);

		if httpIndex &gt; 0 then
			workString		:=	workString.cnEcInsertInto(httpArray[httpIndex], charIndex, (charIndex + 1));
			stringLength	:=	workString.length();
		endif;
		
		charIndex	:=	charIndex + 1;
	endwhile;
epilog
	delete asciiArray;
	delete httpArray;
	return workString;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="cnEcEncodeWebDataAndStripCrLf" id="8be51816-f6c5-4e44-aaf9-63265a2ee03f">
        <source>cnEcEncodeWebDataAndStripCrLf():String;
// --------------------------------------------------------------------------------
// Created:		19 January 2001 by cnwdad1
//
// Purpose:		Replaces all "special" ASCII characters within the string with the
//				HTTP equivalents.  For example, spaces in a string should be
//				represented as %20 in an HTTP string - therefore all occurrences
//				of spaces will be replaced with a %20.
//
//				This is a special reimplementaton of String::cnEcEncodeWebData to
//				also handle stripping out Cr and Lf characters.  This is done here
//				to speed up the processing for Tcp/Ip connections etc.
//
// Parameters:	None
//
// Returns:		String - the encoded web (http) string.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 24/09/2004	cnwdad1		A change in JADE 6.0.9 means that the value of the
//							"stringLength" variable is now only evaluated at the
//							beginning of the foreach loop, hence the resetting of
//							the variable's value within the loop is ignored.
//							Changed to use a while loop instead.
// --------------------------------------------------------------------------------
vars
	asciiArray		: CharacterArray;
	httpArray		: StringArray;
	httpIndex		: Integer;
	charIndex		: Integer;
	stringLength	: Integer;
	workString		: String[1000000];
	workChar		: Character;

begin
	create asciiArray transient;
	create httpArray transient;

	asciiArray.add(',');
	httpArray.add('%2C');

	asciiArray.add('-');
	httpArray.add('%2D');

	asciiArray.add('"');
	httpArray.add('%22');

	asciiArray.add('$');
	httpArray.add('%24');

	asciiArray.add('&lt;');
	httpArray.add('%3C');

	asciiArray.add('&gt;');
	httpArray.add('%3E');

	asciiArray.add(';');
	httpArray.add('%3B');

	asciiArray.add(':');
	httpArray.add('%3A');

	asciiArray.add('(');
	httpArray.add('%28');	

	asciiArray.add(')');
	httpArray.add('%29');

	asciiArray.add(' ');
	httpArray.add('%20');	//('%A0');	Spaces are each supposed to be represented by "+", but this doesn't seem to work correctly.

	asciiArray.add('&amp;');
	httpArray.add('%26');

	asciiArray.add('!');
	httpArray.add('%21');

	asciiArray.add('#');
	httpArray.add('%23');

	asciiArray.add('%');
	httpArray.add('%25');

	asciiArray.add('^');
	httpArray.add('%5E');

	asciiArray.add('+');
	httpArray.add('%2B');

	asciiArray.add('=');
	httpArray.add('%3D');

	asciiArray.add(';');
	httpArray.add('%3B');

	asciiArray.add(':');
	httpArray.add('%3A');

	asciiArray.add("'");
	httpArray.add('%27');

	asciiArray.add('?');
	httpArray.add('%3F');

	asciiArray.add('/');
	httpArray.add('%2F');

	asciiArray.add('\');
	httpArray.add('%5C');

	asciiArray.add('|');
	httpArray.add('%7C');

	asciiArray.add('`');
	httpArray.add('%60');

	asciiArray.add('~');
	httpArray.add('%7E');

	asciiArray.add('{');
	httpArray.add('%7B');

	asciiArray.add('}');
	httpArray.add('%7D');

	workString		:=	self;
	stringLength	:=	workString.length();

// cnwdad1 24/09/2004 - A change in JADE 6.0.9 means that the value of the "stringLength"
// variable is now only evaluated at the beginning of the foreach loop, hence the resetting
// of the variable's value within the loop is ignored.  Changed to use a while loop instead.
//	foreach charIndex in 1 to stringLength do
//		workChar	:=	workString[charIndex];
//		
//		if workChar = Cr or workChar = Lf then
//			workString	:=	workString.cnEcInsertInto(null, charIndex, (charIndex + 1));
//		else
//			httpIndex	:=	asciiArray.indexOf(workChar);
//	
//			if httpIndex &gt; 0 then
//				workString		:=	workString.cnEcInsertInto(httpArray[httpIndex], charIndex, (charIndex + 1));
//				stringLength	:=	workString.length;
//			endif;
//		endif;
//	endforeach;
	
	charIndex	:=	1;
	
	while charIndex &gt; 0 and charIndex &lt;= stringLength do
		workChar	:=	workString[charIndex];
		
		if workChar = Cr or workChar = Lf then
			workString	:=	workString.cnEcInsertInto(null, charIndex, (charIndex + 1));
		else
			httpIndex	:=	asciiArray.indexOf(workChar);
	
			if httpIndex &gt; 0 then
				workString		:=	workString.cnEcInsertInto(httpArray[httpIndex], charIndex, (charIndex + 1));
				stringLength	:=	workString.length();
			endif;
		endif;
		
		charIndex	:=	charIndex + 1;
	endwhile;
epilog
	delete asciiArray;
	delete httpArray;
	
	return workString;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="cnEcEncrypt" id="ee5eb802-8d90-414c-ac07-5e3383fab6cb">
        <source>cnEcEncrypt():String;
// --------------------------------------------------------------------------------
// Created:		31 May 2000 by cnwdad1
//
// Purpose:		Provides a one-way encryption of the string.
//
//  To ensure portability (ie. that we get the same result) across architectures
//  that may have different byte ordering, we use a mod 256 to get the logical LSB
//  and build the result into a character string.  This algorithm will work with
//  ANSI or UNICODE strings.  The encryption is one-way.
//
// Parameters:	None
//
// Returns:		The encrypted receiver.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
constants
	// We are hard coding the key so we don't have to generate/derive it for each use.
	CRYPT_KEY	: Integer =	37463 * 1324;

vars
	encryptedResult	: String;
	sourceLength	: Integer;
	charIndex		: Integer;
	encryptChar 	: Character;
 	temp			: Integer;

begin
	encryptedResult		:=	"";

	if self = null then				// Handle special case of empty string.
		encryptedResult[1] := (CRYPT_KEY mod 256).Character;
	else
		sourceLength	:=	self.length;
		charIndex		:=	1;
		encryptChar		:=	self[sourceLength];

		foreach charIndex in 1 to sourceLength do
			temp	:=	(self[charIndex].Integer*CRYPT_KEY + encryptChar.Integer) mod 256;

			if (temp = 0) then
				temp	:=	1;
			endif;

			encryptedResult[charIndex]	:=	temp.Character;
			encryptChar					:=	self[charIndex];
		endforeach;
	endif;

	return encryptedResult;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="cnEcFindReplace" id="034f931f-5da6-4869-a609-f788855e7fb3">
        <source>cnEcFindReplace(pScanFor:String; pReplaceWith:String; pIsFirstOnly:Boolean):String;
// --------------------------------------------------------------------------------
// Created:		01 January 2001 by cnwdad1
//
// Purpose:		The receiver is scanned for occurances of the pScanFor value and
//				these are replaced by the pReplaceWith string.
//
// Parameters:	pScanFor - The substring to search for and replace.
//				pReplaceWith - The value to replace the substring with.
//				pIsFirstOnly - If true, only the first instance of the substring
//					will be replaced.
//
// Returns:		The receiver with the substring(s) replaced.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 09/11/2002	cnwdad1		Changed to handle a null replacement value.
// --------------------------------------------------------------------------------
vars
	posIndex			: Integer;		// Index position in the current field.
	endOfFirstPart		: Integer;		// Points to the end position of the receiver upto the substring to be replaced.
	startOfSecondPart	: Integer;		// Points to the start position of the receiver after the substring to be replaced.
	lengthOfScanFor		: Integer;		// The length of the substring to be replaced.
	lengthOfReplacement	: Integer;		// The length of the replacement substring.
	workString			: String;		// Replacement value of current field.

begin
	workString			:=	self;

	if pScanFor = workString then
		// If the substring is the same as the receiver, then we can save
		// ourselves some work by simply returning the replacement value.
		return pReplaceWith;
	endif;

	lengthOfScanFor		:=	pScanFor.length;
	lengthOfReplacement	:=	pReplaceWith.length;
	posIndex			:=	1;
	
	while true do
		posIndex	:=	workString.pos(pScanFor, posIndex);
		
		if posIndex = 0 then
			break;
		endif;
		
		endOfFirstPart		:=	posIndex - 1;
		startOfSecondPart	:=	posIndex + lengthOfScanFor;
		
		if endOfFirstPart = 0 then
			if workString = pScanFor then								// cnwdad1 09/11/2002.
				workString	:=	pReplaceWith;							// cnwdad1 09/11/2002.
			elseif pReplaceWith = null then								// cnwdad1 09/11/2002.
				workString	:=	workString[startOfSecondPart:end];		// cnwdad1 09/11/2002.
			else														// cnwdad1 09/11/2002.
				workString	:=	pReplaceWith &amp; workString[startOfSecondPart:end];
			endif;														// cnwdad1 09/11/2002.
		else
			if startOfSecondPart &gt; workString.length then
				workString	:=	workString[1:endOfFirstPart] &amp; pReplaceWith;
			else
				workString	:=	workString[1:endOfFirstPart] &amp; pReplaceWith &amp; workString[startOfSecondPart:end];
			endif;
		endif;
		
		if pIsFirstOnly then
			break;
		endif;
		
		posIndex	:=	posIndex + lengthOfReplacement;
	endwhile;
	
	return workString;
end;</source>
        <text>___________________________________________________________________________

              P R O P R I E T A R Y   N O T I C E

This software, in whole and in every part, is proprietary to Jade Software
Corporation Limited at Christchurch, New Zealand and is not to be
reproduced, used or disclosed except upon prior written permission of Jade
Software Corporation Limited.

  COPYRIGHT © JADE SOFTWARE CORPORATION LIMITED 2002 - ALL RIGHTS RESERVED
____________________________________________________________________________</text>
        <Parameter name="pScanFor" type="String"/>
        <Parameter name="pReplaceWith" type="String"/>
        <Parameter name="pIsFirstOnly" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="cnEcFirstToUpper" id="2244d6a8-5eda-4567-bfb3-d97b7b985af2">
        <source>cnEcFirstToUpper():String;
// --------------------------------------------------------------------------------
// Created:		21 November 2003 by cnwdad1
//
// Purpose:		Changes the first character of the receiver to uppercase, and returns
//				the whole string.
//
// Parameters:	None
//
// Returns:		The capitalized receiver.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	returnValue	: String;
	
begin
	returnValue	:=	self;
	returnValue.firstCharToUpper();
	
	return returnValue;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="cnEcFirstUpperRestLower" id="f85c7d2e-2496-4a78-a9d8-000adf912bc0">
        <source>cnEcFirstUpperRestLower();
//	Ensure that the First character in the current string is 
//	always Upper case and the remaining characters are lower case.
begin
	// Empty string - return.

	if self.length &lt; 1 then
		return;
	endif;

	// Single character - convert to upper.

	if self.length = 1 then
		self.toUpper;
		return;
	endif;

	// First character to upper rest to lower case.

	self[1:1].toUpper;
	self[2:end].toLower;

	return;
end;
</source>
    </JadeMethod>
    <JadeMethod name="cnEcGetAnsiDateFormat" id="6018ea11-d6f1-4cb8-8269-bcae59f0f860">
        <source>cnEcGetAnsiDateFormat():Date;
// --------------------------------------------------------------------------------
// Created:		07 November 2000 by cnwdad1
//
// Purpose:		Convert an ANSI type string "2000-12-31" into a Date type.
//
//				Refer to the Date::cnEcGetAnsiFormat method to retrieve an
//				ANSI string from a date.
//
// Parameters:	None
//
// Returns:		The resulting Date (or null).
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	dateResult	: Date;
	
begin
	if self.length = 10 then
		dateResult.setDate(self[9:2].Integer, self[6:2].Integer, self[1:4].Integer);
		return dateResult;
	else
		return null;
	endif;
end;</source>
        <ReturnType type="Date"/>
    </JadeMethod>
    <JadeMethod name="cnEcGetAnsiTimeFormat" id="aff4100f-4214-494f-b00a-2796a7c7021e">
        <source>cnEcGetAnsiTimeFormat():Time;
// --------------------------------------------------------------------------------
// Created:		07 November 2000 by cnwdad1
//
// Purpose:		Convert an ANSI type string "24:59:45" into a Time type.
//
//				Refer to the Time::cnEcGetAnsiFormat method to retrieve an
//				ANSI string from a time.
//
// Parameters:	None
//
// Returns:		The resulting Time (or null).
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	timeResult	: Time;
	
begin
	if self.length = 8 then
		timeResult.setTime(self[1:2].Integer, self[4:2].Integer, self[7:2].Integer, 0);
		return timeResult;
	else
		return null;
	endif;
end;</source>
        <ReturnType type="Time"/>
    </JadeMethod>
    <JadeMethod name="cnEcGetAnsiTimeStampFormat" id="2596e526-3acd-46bb-8b18-5d87ea8e8c3d">
        <source>cnEcGetAnsiTimeStampFormat():TimeStamp;
// --------------------------------------------------------------------------------
// Created:		07 November 2000 by cnwdad1
//
// Purpose:		Convert ANSI type string "2000-12-31 24:59:45" to a TimeStamp type.
//
// Parameters:	None
//
// Returns:		The resulting TimeStamp (or null).
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	timestampResult	: TimeStamp;
	
begin
	if self.length = 19 then
		timestampResult.Date.setDate(self[9:4].Integer, self[6:2].Integer, self[1:4].Integer);
		timestampResult.Time.setTime(self[1:2].Integer, self[4:2].Integer, self[7:2].Integer, 0);
		return timestampResult;
	else
		return null;
	endif;
end;</source>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="cnEcGetArrayOfLines" id="7485dae7-c02f-4988-a079-261fcf3a8a46">
        <source>cnEcGetArrayOfLines(pLineArray:CnEcArray io):Boolean;
// --------------------------------------------------------------------------------
// Created:		08 November 2000 by cnwdad1
//
// Purpose:		Returns an array of every line in the receiver (delimited by Cr or
//				CrLf).
//
// Parameters:	pLineArray (CnEcArray) - The array to populate with the lines.
//
// Returns:		The array of lines (parameter), and true if any lines were found,
//				otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
/*
	The following is an example use of this method:
	
	vars
		paragraph	: String;
		lineArray	: CnEcArray;
		stringLine	: CnEcArrayObject;
	
	begin
		paragraph	:=	"This is my string." &amp; Cr &amp; CrLf &amp; "I want to get each of its lines." &amp; CrLf &amp; "I can use Cr or CrLf." &amp; CrLf;
		
		create lineArray transient;
		
		if paragraph.cnEcGetArrayOfLines(lineArray) then
			foreach stringLine in lineArray do
				write stringLine.getStringValue;
			endforeach;
		else
			write "No lines were found!";
		endif;
	epilog
		delete lineArray;
	end;
*/
vars
	linePos		: Integer;

begin
	pLineArray.clear();

	if self = null then
		return false;
	endif;

	linePos		:=	1;

	while linePos &gt; 0 do
		pLineArray.addString(self.cnEcGetNextLine(linePos));
	endwhile;

	return true;
end;</source>
        <Parameter name="pLineArray" type="CnEcArray" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="cnEcGetHttpValueOfName" id="a7d4e541-462e-46c5-a207-085b5c38f6c8">
        <source>cnEcGetHttpValueOfName(pName:String):String;
// Scans a string for the internet input string "name=value[&amp;]".
vars
	charIndex		: Integer;
	stringLength	: Integer;
	equalPos		: Integer;	// The position of the "=" sign.
	ampersandPos	: Integer;	// The position of the "&amp;" character.

begin
	stringLength	:=	self.length;

	if (stringLength &gt; 1) and (self[stringLength - 1:1] = #"0d") and (self[stringLength:1] = #"0a") then
		stringLength	:=	stringLength - 2;
	endif;

	charIndex	:=	self.pos("&amp;", 1);	// Skip the app name (at the start of the http string).
   	charIndex	:=	charIndex + 1;	

	while charIndex &lt;= stringLength do	: outerLoop
		// Find the next '=' and matching end '&amp;' positions for the next field.

		while true do
			// Get the position of the next '='.
			equalPos	:=	self.pos("=", charIndex);

			// If there are no more '=', then exit.
			if equalPos = 0 then
				return null;
			endif;

			// Get the position of the next '&amp;'.
			ampersandPos	:=	self.pos("&amp;", charIndex);

		  	if ampersandPos = 0 then
				ampersandPos	:=	stringLength + 1;
			endif;

			// If the position of the '&amp;' is less than the position of the
			// '=', then get the next start based on ampersandPos + 1.
			if ampersandPos &gt; equalPos then
				break;
			endif;

			charIndex	:=	ampersandPos + 1;

			if charIndex &gt; stringLength then
				break outerLoop;
			endif;
		endwhile;	

		if self[charIndex:(equalPos - charIndex)] = pName then
			if ampersandPos &gt; equalPos + 1 then
				return self[(equalPos + 1):(ampersandPos - equalPos - 1)];
			else
				return null;
			endif;
		endif;

		charIndex	:=	ampersandPos + 1;
	endwhile;	

	return null;
end;</source>
        <Parameter name="pName" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="cnEcGetNextLine" id="c182fdce-b36d-40fe-9f81-e1699699b739">
        <source>cnEcGetNextLine(pStartPos:Integer io):String;
// --------------------------------------------------------------------------------
// Created:		08 November 2000 by cnwdad1
//
// Purpose:		Returns the next line in the receiver, from the specified starting
//				position.
//
// Parameters:	pStartPos (Integer) - The position from which to start searching
//				for the next line in the receiver.  Position 1 will be assumed if
//				the specified value is zero.
//
// Returns:		The next line in the receiver (parameter), and the start position
//				for the next line in the receiver.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
/*
	The following is an example use of this method:
	
	vars
		paragraph	: String;
		linePos		: Integer;
	
	begin
		paragraph	:=	"This is my string." &amp; Cr &amp; CrLf &amp; "I want to get each of its lines." &amp; CrLf &amp; "I can use Cr or CrLf." &amp; CrLf;
		write paragraph;
		write CrLf;
		linePos		:=	1;
		
		while linePos &gt; 0 do
			write paragraph.cnEcGetNextLine(linePos);
		endwhile;
	end;
*/
vars
	nextLine		: String;
	startPos		: Integer;
	nextPos			: Integer;
	stringLength	: Integer;
	lineLength		: Integer;
	lineEndPos		: Integer;
	
begin
	if self = null then
		return null;
	else
		stringLength	:=	self.length;
	endif;
	
	if startPos &gt; stringLength then
		return null;
	elseif pStartPos = 0 then
		startPos	:=	1;
	else
		startPos	:=	pStartPos;
	endif;
	
	lineEndPos	:=	self.pos(Cr, startPos);
	
	if lineEndPos = 0 then						// No (more) lines are left.
		nextLine	:=	self[startPos:end];
		nextPos		:=	0;
	else
		lineLength	:=	lineEndPos - startPos;
		
		if lineLength = 0 then					// This could be two lines with nothing in between, or the end of the receiver.
			nextLine	:=	null;
			
			if lineEndPos &lt; stringLength then
				nextPos	:=	lineEndPos + 1;
				
				if self[nextPos] = Lf then
					if nextPos = stringLength then		// The receiver must terminate with the found LineFeed, hence there're no more lines.
						nextPos	:=	0;
					else
						nextPos	:=	nextPos + 1;
					endif;
				else
					// Do nothing because this is the start position of the next line.
				endif;
			else
				nextPos	:=	0;
			endif;
		else
			nextLine	:=	self[startPos:lineLength];
			nextPos		:=	lineEndPos;
			
			if nextPos &lt; stringLength then
				nextPos	:=	lineEndPos + 1;
				
				if self[nextPos] = Lf then
					if nextPos = stringLength then		// The receiver must terminate with the found LineFeed, hence there're no more lines.
						nextPos	:=	0;
					else
						nextPos	:=	nextPos + 1;
					endif;
				else
					// Do nothing because this is the start position of the next line.
				endif;
			else	// The receiver must terminate with the found Carriage Return, hence there're no more lines.
				nextPos	:=	0;
			endif;
		endif;
	endif;
	
	pStartPos	:=	nextPos;
	return nextLine;
end;</source>
        <Parameter name="pStartPos" type="Integer" usage="io"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="cnEcGetNextTagValueOfName" id="7ec651df-8425-47f6-b8fd-3d017540406d">
        <source>cnEcGetNextTagValueOfName(pName:String; pStartPos : Integer io):String;
// --------------------------------------------------------------------------------
// Created:		07 June 2000 by cnwdad1
//
// Purpose:		Scans the string for the value of an HTML-type tag, eg. "&lt;NAME&gt;value&lt;/NAME&gt;".
//
// Parameters:	pName (String) - The name of the tag.
//				pStartPos (Integer) - The position in self to start searching
//
// Returns:		String - The value contained within the tag (null if the tag is not found).
//				pStartPos (parameter) - The end position of the closing tag, OR zero
//				if no tag found or if the endTag is at the end of the string.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	tagValue			: String;
	startTag			: String;
	endTag				: String;
	startTagPos			: Integer;
	endTagPos			: Integer;
	tagValueLength		: Integer;
	tagValueStartPos	: Integer;

begin
	tagValue	:=	null;
	startTag	:=	"&lt;" &amp; pName &amp; "&gt;";
	endTag		:=	"&lt;/" &amp; pName &amp; "&gt;";
	
	if pStartPos &lt; 1 then
		pStartPos	:=	1;
	endif;
	
	startTagPos	:=	self.pos(startTag, pStartPos);
	
	// Set pStartPos to 0.  If a tag found then this is reset below
	pStartPos := 0;
	
	if startTagPos &gt; 0 then
		endTagPos	:=	self.pos(endTag, startTagPos);

		if endTagPos &gt; startTagPos then
			tagValueStartPos	:=	startTagPos + startTag.length;
			tagValueLength		:=	endTagPos - tagValueStartPos;

			if tagValueStartPos &gt; 0 and tagValueStartPos &lt;= self.length and (tagValueStartPos + tagValueLength) &lt; self.length then
				tagValue	:=	self[tagValueStartPos:tagValueLength];
				
				// Set pStartPos to the endPosition found
				pStartPos	:= 	endTagPos + endTag.length;
				if pStartPos &gt;= self.length then
					pStartPos := 0;
				endif;
			else
				tagValue	:=	self[tagValueStartPos:end];
			endif;
		endif;
	endif;
epilog
	return tagValue;
end;</source>
        <Parameter name="pName" type="String"/>
        <Parameter name="pStartPos" type="Integer" usage="io"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="cnEcGetNextWord" id="f4e61591-0756-4120-815e-16efb1f29860">
        <source>cnEcGetNextWord(pStartPos:Integer io):String;
// --------------------------------------------------------------------------------
// Created:		08 November 2000 by cnwdad1
//
// Purpose:		Return the next "word" from the receiver and update the position.
//
// Parameters:	pStartPos (Integer) - The position from which to start searching
//				for the next word in the receiver.  Position 1 will be assumed if
//				the specified value is zero.
//
// Returns:		The next word in the receiver (parameter), and the start position
//				for the next word in the receiver.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	stringLength	: Integer;
	theCharacter	: Character;
	theWord			: String;
	isWord			: Boolean;	// flag - found start of word?

begin
	if pStartPos = 0 then
		pStartPos	:=	1;
	endif;

	stringLength	:=	self.length;

	while pStartPos &lt;= stringLength do
		// Get next char and increment position.
		theCharacter	:=	self[pStartPos:1].Character;
		pStartPos		:=	pStartPos + 1;

		// Is char part of a word, incuding a hyphen ?
		if (theCharacter.isAlpha) or (theCharacter = '-' and isWord) then
			isWord	:=	true; // Start of a word.
			theWord	:=	theWord &amp; theCharacter;

			if pStartPos &gt; stringLength then
				return theWord;	// End of a word and text.
			endif;
		else
			// Waiting for start of word, or ...
			if isWord then
				return theWord; // End of a word.
			endif;
		endif;
	endwhile;

	return null;
end;</source>
        <Parameter name="pStartPos" type="Integer" usage="io"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="cnEcGetNumberGroupings" id="44afb242-58e0-481e-9eff-49096e818f8f">
        <source>cnEcGetNumberGroupings(pNumberFormatObj:NumberFormat; pAllGroupings:StringArray io);
// --------------------------------------------------------------------------------
// Created:		22 August 2001 by cnwdad1
//
// Purpose:		Breaks up the receiver into an array of groupings of thousands, in
//				reverse order.  For example, 1000000 (one million), the integer
//				array will end up with the following elements for standard Western
//				number formats:
//
//					Element 1 = "1"
//					Element 2 = "000"
//					Element 3 = "000"
//
// Parameters:	pNumberFormatObj - The numeric format information (locale-based).
//				pAllGroupings - The Integer Array of the receiver's groupings.
//
// Returns:		The Integer Array of groupings.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	numberFormatObj	: NumberFormat;
	allGroupSizes	: IntegerArray;
	defaultSize		: Integer;
	stringValue		: String;
	startPosition	: Integer;
	lastPosition	: Integer;
	charPosition	: Integer;
	charCount		: Integer;
	groupSize		: Integer;
	valueLength		: Integer;
	groupValue		: String;
	
begin
	numberFormatObj	:=	pNumberFormatObj;
	
	if numberFormatObj = null then
		numberFormatObj	:=	app.currentLocaleInfo.numericInfo;
	endif;
	
	pAllGroupings.clear();
	create allGroupSizes transient;
	defaultSize	:=	numberFormatObj.cnEcGetAllGroupings(allGroupSizes);
	stringValue	:=	self;
	valueLength	:=	stringValue.length;
	
	if defaultSize = 0 then
		startPosition	:=	valueLength + 1;
		lastPosition	:=	startPosition;
		
		foreach groupSize in allGroupSizes reversed do
			startPosition	:=	startPosition - groupSize;
			
			if startPosition &lt; 1 and lastPosition &gt; 1 then
				groupValue	:=	stringValue[1:(lastPosition - 1)];
			else
				groupValue	:=	stringValue[startPosition:groupSize];
			endif;
			
			pAllGroupings.insert(1, groupValue);
			
			if startPosition &lt;= 1 then
				break;
			endif;
			
			lastPosition	:=	startPosition;
		endforeach;
	else
		foreach charPosition in valueLength to 1 step -1 do
			groupValue	:=	stringValue[charPosition:1] &amp; groupValue;
			charCount	:=	charCount + 1;
			
			if charCount = defaultSize then
				pAllGroupings.insert(1, groupValue);
				groupValue	:=	null;
				charCount	:=	0;
			endif;
		endforeach;
		
		if groupValue &lt;&gt; null then
			pAllGroupings.insert(1, groupValue);
		endif;
	endif;
epilog
	delete allGroupSizes;
end;</source>
        <Parameter name="pNumberFormatObj" type="NumberFormat"/>
        <Parameter name="pAllGroupings" type="StringArray" usage="io"/>
    </JadeMethod>
    <JadeMethod name="cnEcGetPathOfFileName" id="827e3ff0-57c1-41f8-971d-f384f3e7b04f">
        <source>cnEcGetPathOfFileName():String;
// --------------------------------------------------------------------------------
// Created:		13 June 2007 by cnwdad1
//
// Purpose:		Assuming that the receiver is a full file/path name, this method
//				will drop the file name and return the path name.
//
// Parameters:	None
//
// Returns:		The directory path name, or null.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	separator		: Character;
	separatorPos	: Integer;
	pathName		: String;
	pathLen			: Integer;
	
begin
	if self.trimBlanks() = null then
		return null;
	endif;
	
	separator		:=	global.cnEcGetFileSeparator();
	separatorPos	:=	self.reversePos(separator);
	
	if separatorPos &lt;= 0 or separatorPos = 1 then
		return null;
	endif;
	
	pathLen		:=	separatorPos - 1;
	pathName	:=	self[1:pathLen];
	
	return pathName;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="cnEcGetTagValueOfName" id="8d368ed5-c22c-4391-9066-9c7c827cb27b">
        <source>cnEcGetTagValueOfName(pName:String):String;
// --------------------------------------------------------------------------------
// Created:		07 June 2000 by cnwdad1
//
// Purpose:		Scans the string for the value of an HTML-type tag, eg. "&lt;NAME&gt;value&lt;/NAME&gt;".
//
// Parameters:	pName (String) - The name of the tag.
//
// Returns:		String - The value contained within the tag (null if the tag is not found).
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	startTagPos			: Integer;

begin
	startTagPos	:=	1;
	
	return self.cnEcGetNextTagValueOfName(pName, startTagPos);
end;</source>
        <Parameter name="pName" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="cnEcGetURLParts" id="7a3a0c04-fdf0-43fe-a085-29250e2b63c5">
        <source>cnEcGetURLParts(pProtocol:String io; pServer:String io; pPath:String io):String;
// --------------------------------------------------------------------------------
// Created:		03 August 2000 by cnwdad1
//
// Purpose:		Separates the Server and Path (directory) names from a URL string.
//
//				1. It is assumed that the protocol is qualified with a value of
//				"://" (i.e. "http://www.discoverjade.com").  If this qualifier
//				is not found, then it will be assumed that the URL protocol has
//				not been specified.
//
//				2. The Server name will be assumed to commence immediately following
//				the protocol qualifier, and span upto the first "/".
//
//				3. The Path name will be assumed to be everything following the
//				first "/" in the string (following the Server name).
//
// Parameters:	pProtocol (String) - The protocol specified by the URL name.
//
//				pServer (String) - The name of the Server, between the protocol
//									qualifier and the first "/".
//
//				pPath (String) - The name of the file path, which follows the
//									Server name.
//
// Returns:		Null if the operation was successful, otherwise returns an error message.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
constants
	PROTOCOL_QUALIFIER	: String = "://";

vars
	urlLength		: Integer;
	protocolName	: String;
	serverName		: String;
	serverLength	: Integer;
	serverStartPos	: Integer;
	pathName		: String;
	pathNamePos		: Integer;
	qualifierPos	: Integer;

begin
	if self = null then
		return $CNEC_INVALID_URL_NAME(self);
	endif;

	urlLength		:=	self.length;
	qualifierPos	:=	self.pos(PROTOCOL_QUALIFIER, 1);

	// Server name begins immediately after the protocol qualifier.
	// However, if there's no qualifier then start at the first character.

	if qualifierPos &gt; 0 then
		protocolName	:=	self[1:(qualifierPos - 1)];
		serverStartPos	:=	qualifierPos + PROTOCOL_QUALIFIER.length;
	else
		protocolName	:=	null;
		serverStartPos	:=	1;
	endif;

	if serverStartPos &gt; urlLength then
		return $CNEC_INVALID_URL_NAME(self);
	endif;

	pathNamePos		:=	self.pos("/", serverStartPos);	// Path name begin must begin after the Server name.

	// If the start of the Path name is NOT greater than the start
	// of the Server name, then the URL is no good.

	if (pathNamePos &gt; 0) and (not pathNamePos &gt; serverStartPos) then
		return $CNEC_INVALID_URL_NAME(self);
	endif;

	// If the Path name wasn't found, then the whole string must consist of the Server name.

	if pathNamePos = 0 then
		serverName	:=	self[serverStartPos:end];
		pathName	:=	null;
	else
		serverName	:=	self[serverStartPos:(pathNamePos - serverStartPos)];
		pathName	:=	self[pathNamePos:end];
	endif;

	// Set the return values.

	pProtocol	:=	protocolName;
	pServer		:=	serverName;
	pPath		:=	pathName;
	return null;
end;</source>
        <Parameter name="pProtocol" type="String" usage="io"/>
        <Parameter name="pServer" type="String" usage="io"/>
        <Parameter name="pPath" type="String" usage="io"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="cnEcHexValue" id="1948d719-a1ef-48ed-bad7-a8316223ffe7">
        <source>cnEcHexValue() : Integer;
// return the integer value of the string of hex characters take the
// leading hex characters, maximum of 7 to fit within integer max size,
// return 0 if first character of string is not hex.
vars
	charIndex			: Integer;
	hexValueOfString	: Integer;
	integerValueOfChar	: Integer;
	maximumLength		: Integer;
	multiplier			: Integer;
	substringChar		: Character;
	workString			: String;

begin
	hexValueOfString	:=	0;
	multiplier			:=	1;
	maximumLength		:=	self.length();

	if maximumLength &gt; 7 then
		maximumLength	:=	7;
	endif;
	
	multiplier	:=	16 ^ (maximumLength - 1);
	
	foreach charIndex in 1 to maximumLength do
		workString			:=	self[charIndex:1].toUpper();
		substringChar		:=	workString.Character;
		integerValueOfChar	:=	"0123456789ABCDEF".pos(substringChar, 1);

		if integerValueOfChar = 0 then
			break;
		else
			integerValueOfChar	:=	integerValueOfChar - 1;
			hexValueOfString	:=	hexValueOfString + integerValueOfChar * multiplier;
		endif;

		multiplier	:=	multiplier div 16;
	endforeach;

	return hexValueOfString;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="cnEcIncludesXmlTags" id="435f3b53-060f-4620-bfe9-ff6ca9eb94cc">
        <source>cnEcIncludesXmlTags() : Boolean;
// Author:	cnwka1
// Created:	12 June 2000
//
// Purpose:	
//
// Parameters:
//
// Name		Purpose
// ---------------- -----------------------------------------------
//
// Returns:	
//
vars
	startPos	: Integer;
	endPos		: Integer;
	
begin
    startPos	:= self.pos("&lt;", 1);
    endPos		:= self.pos("&gt;", 1);

    if (startPos &gt; 0 and endPos &gt; 0) and (startPos &lt; endPos) then
        if self[(startPos + 1):1] &lt;&gt; "!" then
	    	return true;
	    endif;
    endif;

    return false;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="cnEcInsertInto" id="9cf50933-e52e-49bf-b159-3c918f51925d">
        <source>cnEcInsertInto(pInsString:String; pInsFrom:Integer; pContinueAfter:Integer):String;
// Insert the pInsString starting at pInsFrom and append the reset of the current
// string from the pContinueAfter of the current string.
//
// NOTE	: We are not checking that the pContinueAfter value is greater than
// pInsFrom - do what you like.
vars
	newString	: String;
	insertPos	: Integer;

begin
	// Make sure that insFrom is not past the end of the current string
	// (add one to allow string to be concatentated).
	if pInsFrom &gt; self.length + 1 then
		insertPos	:=	self.length + 1;
	else
		insertPos	:=	pInsFrom;
	endif;

	// If the insFrom is greater than 1 then we use the current string
	// up to the charcter before the insFrom position.

	if insertPos &gt; 1 then
		newString	:=	self[1:insertPos - 1];
	endif;

	// Insert the insString.
	newString	:=	newString &amp; pInsString;

	// Only include anything in continueAfter if it is not 0 or past
	// the end of the current string.
	if pContinueAfter &gt; 0 and pContinueAfter &lt;= self.length then
		newString	:=	newString &amp; self[pContinueAfter:end];
	endif;

	return newString;
end;</source>
        <Parameter name="pInsString" type="String"/>
        <Parameter name="pInsFrom" type="Integer"/>
        <Parameter name="pContinueAfter" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="cnEcIsMatch" id="5a1a090d-b9ee-415d-bfb7-bf23c037f7aa">
        <source>cnEcIsMatch(pPattern:String):Boolean;
// --------------------------------------------------------------------------------
// Created:		31 March 2005 by cnwdad1
//
// Purpose:		Using pattern matching, test to see if the receiver matches the pattern
//				parameter, which may include wildcard characters.
//
// Parameters:	pPattern - The wildcard pattern (does not NEED to have wildcard characters).
//
// Returns:		True if the receiver matches the pattern, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
constants
	SINGLE_CHAR		: String = "?";
	ANY_CHAR		: String = "*";
	
vars
	selfLen			: Integer;
	patternLen		: Integer;
	selfPos			: Integer;
	patternPos		: Integer;
	selfSave		: Integer;
	patternSave		: Integer;
	patternChar		: Character;
	
begin
	// Try the simplest case first.
	
	if self = pPattern then
		return true;
	endif;
	
	// If the pattern has no wildcards, then just compare the receiver to the pattern.
	
	if pPattern.pos(ANY_CHAR, 1) = 0 and pPattern.pos(SINGLE_CHAR, 1) = 0 then
		return (self = pPattern);
	endif;
	
	// Do the comparison character by character.
	
	selfLen		:=	self.length();
	patternLen	:=	pPattern.length();
	selfPos		:=	1;
	patternPos	:=	1;

	// Match until first ANY_CHAR in the pattern, or the end of the receiver
	while selfPos &lt;= selfLen do
		// If we're still processing the receiver, but have exceeded the pattern, then no match.
		
		if patternPos &gt; patternLen then
			return false;
		endif;
		
		patternChar	:=	pPattern[patternPos:1].Character;
		
		if patternChar = ANY_CHAR then
			break;
		endif;
		
		// Pattern character is not SINGLE_CHAR, and characters don't match, then no match.
		
		if patternChar &lt;&gt; SINGLE_CHAR and self[selfPos:1] &lt;&gt; patternChar then
			return false;
		endif;
		
		selfPos := selfPos + 1;
		patternPos := patternPos + 1;
	
	endwhile;
	
	// Now match wildcard possibilities.
	
	while selfPos &lt;= selfLen do
		// We're at a ANY_CHAR in the pattern.
		
		if patternPos &lt;= patternLen and pPattern[patternPos:1] = ANY_CHAR then
			// And we're at the end of the pattern, then return true.
			
			if patternPos = patternLen then
				return true;
			endif;
			
			// Step over the ANY_CHAR in the pattern.
			
			patternPos	:=	patternPos + 1;
			
			// Save current positions for backtracking.
			
			patternSave	:=	patternPos;
			selfSave	:=	selfPos + 1;
		else
			// If we have a match, then step forward through both receiver and pattern.
			
			if patternPos &lt;= patternLen and (pPattern[patternPos:1] = SINGLE_CHAR or self[selfPos:1] = pPattern[patternPos:1]) then
				patternPos	:=	patternPos + 1;
				selfPos		:=	selfPos + 1;
			else		// Otherwise, restore and backtrack to next position in receiver.
				patternPos	:=	patternSave;
				selfPos		:=	selfSave;
				selfSave	:=	selfSave + 1;
			endif;
		endif;
	endwhile;

	// Finally skip over any trailing ANY_CHARs in the pattern.
	
	while patternPos &lt;= patternLen do
		if pPattern[patternPos:1] = ANY_CHAR then
			patternPos	:=	patternPos + 1;
		else
			break;
		endif;
	endwhile;
	
	// If we have processed the whole pattern, then we have a match.
	
	return (patternPos &gt; patternLen);
end;</source>
        <Parameter name="pPattern" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="cnEcIsNumeric" id="bab460ea-da63-4dec-abe3-378596f35da7">
        <source>cnEcIsNumeric():Boolean;
// --------------------------------------------------------------------------------
// Created:		07 November 2000 by cnwdad1
//
// Purpose:		Returns a boolean flag to indicate whether the receiver contains
//				only numeric characters.
//
// Parameters:	None
//
// Returns:		True of the receiver contains only numeric characters, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 06/06/2008	cnwdad1		Changed to just use the "isReal" method.
// --------------------------------------------------------------------------------
//vars
//	charIndex		: Integer;
//	stringLength	: Integer;
//	thisChar		: Character;
//
begin
	return self.isReal();
	
//	charIndex		:=	1;
//	stringLength	:=	self.length;
//
//	foreach charIndex in 1 to stringLength do
//		thisChar	:=	self[charIndex];
//		
//		if charIndex = 1 and thisChar = "-" then
//			continue;
//		elseif thisChar &lt;&gt; "."				// Allow decimal places...
//		and thisChar &lt;&gt; ","					// but not commans...
//		and (not thisChar.isNumeric)		// or non-numeric characters.
//		then
//			return false;	
//		endif;
//	endforeach;
//	
//	return true;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="cnEcIsValidFileName" id="07ccc50f-f5e9-4855-885e-b715f486a8f0">
        <source>cnEcIsValidFileName():Boolean;
// --------------------------------------------------------------------------------
// Created:		02 September 2002 by cnwdad1
//
// Purpose:		Validates a Windows OS file/directory name.  Note that the name must
//				not include the full path name - each node in the path must be
//				validated individually.  Refer to the String::cnEcIsValidPathName
//				method to validate a whole path name.
//
// Parameters:	None
//
// Returns:		True if the name is a valid Windows file node name, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
constants
	INVALID_CHARACTERS	: String = '\/:*?"&lt;&gt;|';
	
vars
	positionIndex	: Integer;
	
begin
	if self = null then
		return false;
	else
		positionIndex	:=	1;
		self.scanUntil(INVALID_CHARACTERS, positionIndex);
		return (positionIndex = 0);
	endif;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="cnEcIsValidPathName" id="2b217898-c933-4dcc-8d69-b027dfcb4031">
        <source>cnEcIsValidPathName():Boolean;
// --------------------------------------------------------------------------------
// Created:		02 September 2002 by cnwdad1
//
// Purpose:		Validates a Windows OS file/directory path name.
//
// Parameters:	None
//
// Returns:		True if the path name is valid, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
constants
	MINIMUM_DRIVE	: Character = "A";
	MAXIMUM_DRIVE	: Character = "Z";
	
vars
	nodeName		: String;
	nameLength		: Integer;
	driveLetter		: Character;
	startPos		: Integer;
	separatorPos	: Integer;
	separatorChar	: Character;
	
begin
	if self = null then
		return false;
	elseif self.length() &lt; 3 then
		return false;
	endif;
	
	if self[2] &lt;&gt; ":" then
		return false;
	endif;
	
	driveLetter	:=	self[1].toUpper();
	
	if driveLetter &lt; MINIMUM_DRIVE or driveLetter &gt; MAXIMUM_DRIVE then
		return false;
	endif;
	
	separatorChar	:=	global.cnEcGetFileSeparator();
	separatorPos	:=	3;
	startPos		:=	3;
	
	while separatorPos &gt; 1 do
		separatorPos	:=	self.pos(separatorChar, separatorPos);
		
		if separatorPos &gt; startPos then
			nameLength	:=	separatorPos - startPos;
			nodeName	:=	self[startPos:nameLength];
			
			if not nodeName.cnEcIsValidFileName() then
				return false;
			endif;
		endif;
		
		separatorPos	:=	separatorPos + 1;		// Start the next scan from the next position.
		startPos		:=	separatorPos;			// Also reset the start position of the next node name.
	endwhile;
	
	return true;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="cnEcNextDelimitedField" id="07b8eae6-3b65-40b6-a21e-f08f72f95da7">
        <source>cnEcNextDelimitedField(pChar:String; pPos:Integer io):String;
// --------------------------------------------------------------------------------
// Purpose:		Returns the next field in the receiver that is delimited by the
//				requested character.
//
// Parameters:	pChar (String) - The delimiting character.
//				pPos (Integer) - The position from which to find the next delimiter.
//
// Returns:		The word between the two delimiters.  If the word is the last in
//				the receiver, then the remainder of the string will be returned,
//				and the pPos parameter will be reset to "1".
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 30/08/2000	cnwdad1		Changed when checking if the "startPos" is less than
//							the length of the receiver to also check whether it is
//							equal to the length of the receiver.
// --------------------------------------------------------------------------------
vars
	delimiter	: Integer;
	startPos	: Integer;

begin
	startPos	:=	pPos;
	delimiter	:=	self.pos(pChar, startPos);	
	pPos		:=	delimiter + 1;

	if delimiter &gt; startPos then
		return(self[startPos:(delimiter - startPos)]);
	elseif delimiter = startPos then
		return(null);
	else
//		if startPos &lt; self.length then		// cnwdad1 30/08/2000
		if startPos &lt;= self.length then		// cnwdad1 30/08/2000
			return(self[startPos:end]);
		else
			return(null);
		endif;
	endif;
end;</source>
        <Parameter name="pChar" type="String"/>
        <Parameter name="pPos" type="Integer" usage="io"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="cnEcPadLeading" id="5f6440e1-0ddf-4953-911d-8e9665d10142">
        <source>cnEcPadLeading(pPadLength:Integer; pPadCharacter:Character):String;
// -----------------------------------------------------------------------------
// Created:		14 November 2001 by cnwdad1
//
// Purpose:		Pads the beginning of the receiver to the requested length, with
//				the specified character.  If the length of the receiver is equal-
//				to or greater than the requested length, then it will be returned
//				un-padded.
//
// Parameters:	pPadLength - The length to pad the receiver to.
//				pPadCharacter - The character to pad the receiver with.
//
// Returns:		The receiver padded to the requested length.
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------
vars
	returnValue	: String;
	
begin
	if self.length &gt;= pPadLength then
		return self;
	endif;
	
	returnValue	:=	self;
	
	while returnValue.length &lt; pPadLength do
		returnValue	:=	pPadCharacter &amp; returnValue;
	endwhile;

	return returnValue;
end;</source>
        <Parameter name="pPadLength" type="Integer"/>
        <Parameter name="pPadCharacter" type="Character"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="cnEcPadTrailing" id="abfe82ac-8f9f-4874-b5cc-b829031ec873">
        <source>cnEcPadTrailing(pPadLength:Integer; pPadCharacter:Character):String;
// -----------------------------------------------------------------------------
// Created:		14 November 2001 by cnwdad1
//
// Purpose:		Pads the end of the receiver to the requested length, with the
//				specified character.  If the length of the receiver is equal-to
//				or greater than the requested length, then it will be returned
//				un-padded.
//
// Parameters:	pPadLength - The length to pad the receiver to.
//				pPadCharacter - The character to pad the receiver with.
//
// Returns:		The receiver padded to the requested length.
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------
vars
	returnValue	: String;
	
begin
	if self.length &gt;= pPadLength then
		return self;
	endif;
	
	returnValue	:=	self;
	
	while returnValue.length &lt; pPadLength do
		returnValue	:=	returnValue &amp; pPadCharacter;
	endwhile;

	return returnValue;
end;</source>
        <Parameter name="pPadLength" type="Integer"/>
        <Parameter name="pPadCharacter" type="Character"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="cnEcPadzeros" id="3aadb42f-a725-4b32-a5dd-32a024d0f034">
        <source>cnEcPadzeros(pLength:Integer):String;
// Left pad the string with zeros up to length "pLength".
vars
	charIndex		: Integer;
	paddedString	: String;

begin
	charIndex	:=	self.length;

	if charIndex &gt;= pLength then
		return self;
	endif;

	paddedString	:=	self;

	while charIndex &lt; pLength do
		paddedString	:=	'0' &amp; paddedString;
		charIndex		:=	charIndex + 1;
	endwhile;

    return paddedString;
end;</source>
        <Parameter name="pLength" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="cnEcRemoveCrLf" id="63a77bd8-b63b-470a-9feb-7c668d77fe11">
        <updating/>
        <source>cnEcRemoveCrLf() updating;

vars
	newString	: String;

begin
	newString	:=	self;
	newString.cnEcReplaceCrLf(CrLf, CNEC_TEACH_CRLF_PLACE_HOLDER_T);
	newString.cnEcReplaceCrLf(Cr, CNEC_TEACH_CRLF_PLACE_HOLDER_T);
	newString.cnEcReplaceCrLf(Lf, CNEC_TEACH_CRLF_PLACE_HOLDER_T);
	newString.cnEcReplaceCrLf(Tab, "    ");
	self		:=	newString;
end;</source>
    </JadeMethod>
    <JadeMethod name="cnEcRemoveSubstring" id="d690700a-a714-40eb-8eb7-49c0564b0039">
        <source>cnEcRemoveSubstring(pSubstring:String):String;
// --------------------------------------------------------------------------------
// Created:		07 November 2000 by cnwdad1
//
// Purpose:		Returns the receiver string without the specified substring.  Note
//				that this will remove *all* occurrences of the specified substring.
//
// Parameters:	pSubstring (String) - The substring to remove from the receiver.
//
// Returns:		The receiver with its substring(s) stripped out.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	resultString		: String;
	acceleratorPos		: Integer;
	
begin
	if self = null then
		return null;
	endif;
	
	resultString	:=	self;
	acceleratorPos	:=	1;
	resultString	:=	resultString.scanUntil(pSubstring, acceleratorPos);
	
	if acceleratorPos = 0 then
		return resultString;
	else
		acceleratorPos	:=	acceleratorPos + pSubstring.length;
		
		if acceleratorPos &lt;= self.length then
			resultString	:=	resultString &amp; self[acceleratorPos:end];
			resultString	:=	resultString.cnEcRemoveSubstring(pSubstring);		// &lt;&lt;===== Recursive call.
		endif;
	endif;

	return resultString;
end;</source>
        <Parameter name="pSubstring" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="cnEcReplaceCharacter" id="2a7dca3f-3da2-499f-8083-2ffdd51a69af">
        <updating/>
        <source>cnEcReplaceCharacter(pCharacter:Character; pPosition:Integer) updating;
// --------------------------------------------------------------------------------
// Created:		27 February 1999 by cnwdad1
//
// Purpose:		Replaces a single character within the string.
//
// Parameters:	pCharacter (Character) - The character to replace with.
//				pPosition (Integer) - The position in the string to replace with the character.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theString	: String;

begin
	if(self.length &gt; 0)
	and (pPosition &gt; 0)
	and (pPosition &lt;= self.length)
	then
		if (pPosition = 1) then
			theString	:=	pCharacter.String;

			if (self.length &gt; 1) then
				theString	:=	theString &amp; self[2:end];
			endif;
		else
			theString	:=	self[1:(pPosition - 1)] &amp; pCharacter.String;

			if (pPosition &lt; self.length) then
				theString	:=	theString &amp; self[(pPosition + 1):end];
			endif;
		endif;

		self	:=	theString;
	endif;
end;</source>
        <Parameter name="pCharacter" type="Character"/>
        <Parameter name="pPosition" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="cnEcReplaceCrLf" id="4018804d-d0d6-47fb-9ab0-cd3487490b27">
        <updating/>
        <source>cnEcReplaceCrLf(pSearchStr:String; pReplaceStr:String) updating;

vars
	newString	: String;
	posLf		: Integer;

begin
	if self.length &gt; 8000 then
		newString	:=	self[1:8000];
	else
		newString	:=	self;
	endif;

	posLf := newString.pos(pSearchStr, 1);

	if posLf = 0 then
		self	:=	newString;
		return;
	endif;

	while posLf &gt; 0 do
		if newString.length = pSearchStr.length then					// replace entire string 
			newString := " ";
		elseif posLf = 1 then
			newString := newString[1 + pSearchStr.length:end];			// if at start of string, drop
		elseif (posLf + pSearchStr.length) &gt;= newString.length then
			newString := newString[1 : posLf - 1];						// if at end of string, drop - can still get at end tho' e.g. with multiple LFs... see loop below
		else
			newString := newString[1 : posLf - 1] &amp; pReplaceStr &amp; newString[posLf + pSearchStr.length:end];
		endif;

		posLf := newString.pos(pSearchStr, 1);	
	endwhile;

	if pReplaceStr.length &gt; newString.length then
		self	:=	newString;
		return;
	endif;

	posLf := newString.pos(pReplaceStr, newString.length - pReplaceStr.length + 1);

	while posLf &gt; 0 do	// remove markers at end of string
		if newString.length = pReplaceStr.length then
			newString := " ";
			posLf := 0;
		else
			newString := newString[1 : newString.length - pReplaceStr.length];		// if at end, drop
			posLf := newString.pos(pReplaceStr, newString.length - pReplaceStr.length + 1);
		endif;
	endwhile;

	self	:=	newString;
	return;
end;</source>
        <Parameter name="pSearchStr" type="String"/>
        <Parameter name="pReplaceStr" type="String"/>
    </JadeMethod>
    <JadeMethod name="cnEcSetHttpValueOfName" id="d82f68de-6e30-4f5e-abb8-0d219cd43fa8">
        <updating/>
        <source>cnEcSetHttpValueOfName(pName:String; pValue:String):Boolean updating;
// --------------------------------------------------------------------------------
// Created:		09 June 2000 by cnwdad1
//
// Purpose:		Scans the string for the internet input string "name=value[&amp;]", and
//				sets the specified value (for each occurrence) of the field.
//
//				Note that HTTP fields are delimited by a "&amp;" - any such characters
//				in the HTTP string will have been converted into HTTP "special"
//				characters (such as %20 for a space).
//
// Parameters:	pName (String)- The name of the query string field.
//				pValue (String) - The value to which the field will be set.
//
// Returns:		True if the field was found, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 16/07/2001	cnwdad1		Added the return of a boolean flag to indicate whether
//							the HTTP field was actually found.
// --------------------------------------------------------------------------------
vars
	fieldStartPos		: Integer;
	nextFieldStartPos	: Integer;
	valueStartPos		: Integer;
	valueLength			: Integer;
	workString			: String;
	nameToFind			: String;
	isFound				: Boolean;

begin
	isFound			:=	true;
	workString		:=	self;
	nameToFind		:=	J_key_Ampersand.Character &amp; pName &amp; J_key_Equal.Character;
	fieldStartPos	:=	1;

	while fieldStartPos &gt; 0 do
		fieldStartPos	:=	workString.pos(nameToFind, fieldStartPos);

		if fieldStartPos &gt; 0 then
			valueStartPos		:=	fieldStartPos + nameToFind.length;
			nextFieldStartPos	:=	workString.pos(J_key_Ampersand.Character, valueStartPos);

			if nextFieldStartPos = 0 then
				// This must be the last field in the string, so replace everything upto the end of the string.
				workString	:=	workString.cnEcInsertInto(pValue, valueStartPos, (workString.length + 1));
				isFound		:=	true;
			else
				// Replace all text between the field name and the start of the next field.
				workString	:=	workString.cnEcInsertInto(pValue, valueStartPos, nextFieldStartPos);
				isFound		:=	true;
			endif;

			fieldStartPos	:=	nextFieldStartPos;
		endif;
	endwhile;

	self	:=	workString;
epilog
	return isFound;
end;</source>
        <Parameter name="pName" type="String"/>
        <Parameter name="pValue" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="cnEcSetTagValueOfName" id="e3852d38-7490-4b17-8671-3fe71d5d636a">
        <updating/>
        <source>cnEcSetTagValueOfName(pName:String; pValue:String):Boolean updating;
// --------------------------------------------------------------------------------
// Created:		09 June 2000 by cnwdad1
//
// Purpose:		Scans the string for the HTML-type tag string "&lt;tag&gt;value&lt;/tag&gt;",
//				and sets the specified value (for each occurrence) of the field.
//
//				NOTE: If a tag contains any embedded tags, such as in an HTML or
//				an XML message, then those embedded tags will be replaced with
//				the new field value.
//
// Parameters:	pName (String)- The name of the query string field.
//				pValue (String) - The value to which the field will be set.
//
// Returns:		True if the tag was found, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 16/07/2001	cnwdad1		Added the return of a boolean flag to indicate whether
//							the tag was actually found.
// --------------------------------------------------------------------------------
vars
	startTag		: String;
	endTag			: String;
	startTagPos		: Integer;
	endTagPos		: Integer;
	valueStartPos	: Integer;
	workString		: String;
	isFound			: Boolean;

begin
	isFound		:=	false;
	workString	:=	self;
	startTag	:=	J_key_LessThan.Character &amp; pName &amp; J_key_GreaterThan.Character;
	endTag		:=	J_key_LessThan.Character &amp; J_key_Slash.Character &amp; pName &amp; J_key_GreaterThan.Character;
	startTagPos	:=	1;

	while startTagPos &gt; 0 do
		startTagPos	:=	workString.pos(startTag, startTagPos);

		if startTagPos &gt; 0 then
			endTagPos	:=	workString.pos(endTag, startTagPos);

			if startTagPos &gt; 0 and endTagPos &gt; startTagPos then
				valueStartPos		:=	startTagPos + startTag.length;

				// Replace all text between the start tag and the end tag.
				workString	:=	workString.cnEcInsertInto(pValue, valueStartPos, endTagPos);

				startTagPos	:=	endTagPos;		// Look for next occurrence of the tag after this occurrence.
				isFound		:=	true;
			endif;
		endif;
	endwhile;

	self	:=	workString;
epilog
	return isFound;
end;</source>
        <Parameter name="pName" type="String"/>
        <Parameter name="pValue" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="cnEcStripAmpersands" id="b64c5c9e-fcfc-4332-8984-b25792244c32">
        <source>cnEcStripAmpersands():String;
// --------------------------------------------------------------------------------
// Created:		15 August 2006 by cnwdad1
//
// Purpose:		To handle ampersands in the receiver (which is to be displayed in
//				the caption of a label or button) where the default action of
//				underlining the following character is not required.
//
//				Any ampersand followed by a space, or at the end of the string, is
//				replaced by "&amp;&amp;".  Other ampersands are removed.
//
// Parameters:	None
//
// Returns:		The receiver string, with ampersands transformed as described above.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
constants
	AMPERSAND		: String = '&amp;';
	SPACE			: String = ' ';
	
vars
	selfLen			: Integer;
	tempString		: String;
	returnString	: String;
	charPos			: Integer;
	
begin
	// Handle exception cases first
	if self = null or self.pos('&amp;', 1) &lt; 1 then
		return self;
	endif;

	selfLen	:=	self.length;
	charPos	:=	1;
	
	while charPos &lt;= selfLen do
		tempString := self.scanUntil(AMPERSAND, charPos);
		
		// Performance enhancement for long strings
		if tempString &lt;&gt; null then
			returnString := returnString &amp; tempString;
		endif;
		
		// No more ampersands
		if charPos = 0 then
			break;
		endif;
		
		// If the ampersand is at the end of the string, or there's a space following 
		//  it, then replace it with "&amp;&amp;"
		if charPos = selfLen or self[charPos + 1:1] = SPACE then
			returnString := returnString &amp; AMPERSAND &amp; AMPERSAND;
		endif;
		
		// Otherwise skip it
		charPos	:=	charPos + 1;
	endwhile;

	return returnString;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="cnEcStripAtEnd" id="81a22774-0a67-439f-95ce-68a8ddb8ae4d">
        <updating/>
        <source>cnEcStripAtEnd(pMask:String):String updating;
// --------------------------------------------------------------------------------
// Created:		25 January 2001 by cnwdad2
//
// Purpose:		Strips the mask from the receiver, but only if it is at the very
//				end of the string, but not if self is entirely composed of the mask.
//
// Parameters:	pMask - The mask to be stripped out.
//
// Returns:		The stripped string.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	posIndex	: Integer;

begin
	posIndex	:=	self.reversePos(pMask);
	
	if posIndex &lt; 2 then
		return self;
	else
		return self[1:(posIndex - 1)];
	endif;
end;</source>
        <Parameter name="pMask" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="cnEcStripDecimalZeros" id="6c65f3fc-7d99-4074-9d84-c891d7e0b627">
        <source>cnEcStripDecimalZeros():String;
// --------------------------------------------------------------------------------
// Created:		2 July 2002 by cnwdad1
//
// Purpose:		Strips all trailing zeros following the decimal point.  If no
//				decimal point is found, then the whole value is return.
//
// Parameters:	None
//
// Returns:		The stripped decimal as a string.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	resultValue			: String;
	decimalCharacter	: String;
	decimalPosition		: Integer;
	valueLength			: Integer;
	characterPosition	: Integer;
	
begin
	resultValue			:=	self.String;
	decimalCharacter	:=	app.currentLocaleInfo.numericInfo.decimalSeparator;
	decimalPosition		:=	resultValue.pos(decimalCharacter, 1);
	
	if decimalPosition = 0 then
		return resultValue;
	else
		valueLength	:=	resultValue.length();
		
		foreach characterPosition in 1 to valueLength reversed do
			if characterPosition = decimalPosition then
				if decimalPosition = 1 then
					resultValue	:=	"0" &amp; resultValue;
				endif;
				
				characterPosition	:=	decimalPosition - 1;
				break;
				
			elseif resultValue[characterPosition] &lt;&gt; "0" then
				break;
				
			endif;
		endforeach;
	endif;
	
	if characterPosition &lt; valueLength then
		resultValue	:=	resultValue[1:characterPosition];
	endif;
epilog
	return resultValue;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="cnEcSubstringCount" id="5395c304-bcc5-45d4-820d-38b3746a71b6">
        <source>cnEcSubstringCount(pSubString:String):Integer;

vars
	stringCount		: Integer;
	posIndex		: Integer;
	theLengthOfMe	: Integer;		// cnwdad1 14/10/2000.

begin
	if pSubString = null then
		return 0;
	endif;

	theLengthOfMe	:=	self.length;						// cnwdad1 14/10/2000.

	while true do 
		posIndex := self.pos(pSubString, (posIndex + 1));

		if posIndex = null then
			break;	// end
		elseif posIndex = theLengthOfMe then				// cnwdad1 14/10/2000.
			stringCount	:=	stringCount + 1;				// cnwdad1 14/10/2000.
			break;											// cnwdad1 14/10/2000.
		else
			stringCount	:=	stringCount + 1;	// found
		endif;
	endwhile;

	return stringCount;
end;</source>
        <Parameter name="pSubString" type="String"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="cnEcToStringArray" id="156d9be9-aa3f-422e-b41c-50d9cd8408ca">
        <source>cnEcToStringArray(pAllTokens:StringArray io);

begin
	pAllTokens.cnEcParseTokens(self);
end;</source>
        <Parameter name="pAllTokens" type="StringArray" usage="io"/>
    </JadeMethod>
    <JadeMethod name="cnEcUpto" id="42e7fd80-23d9-4831-9c8d-6fd1566a8054">
        <source>cnEcUpto(pMaxLength:Integer):String;
// --------------------------------------------------------------------------------
// Created:		18 April 2001 by cnwdad1
//
// Purpose:		Returns the receiver upto the specified maximum length.  If the
//				specified length is zero, a null value will be returned.
//
// Parameters:	pMaxLength - The maximum length of the receiver to return.
//
// Returns:		The receiver upto the specified length.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if pMaxLength = 0 then
		return null;
	elseif self.length &gt; pMaxLength then
		return self[1:pMaxLength];
	else
		return self;
	endif;
end;</source>
        <Parameter name="pMaxLength" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="cnEcUrlEncode" id="ee4d9f42-dd67-4cc1-8a0f-74521e62f06d">
        <source>cnEcUrlEncode(pParseMethod:Integer):String;
// --------------------------------------------------------------------------------
// Created:		02 February 2001 by cnwdad1
//
// Purpose:		This method will parse and encode a web data string in 10k chunks.
//
// Parameters:	pParseMethod - Specifies which method to use for encoding.  Refer
//					to the String constants for a list of valid options.
//
// Returns:		The encoded result string.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
constants
	DATA_CHUNK_SIZE		: Integer = 10000;
	PARSE_METHOD_JADE	: Integer = 1;
	PARSE_METHOD_DLL	: Integer = 2;

vars
	dataLength		: Integer;
	dataPointer		: Integer;
	workStringArray	: CnEcArray;
	workStringObj	: CnEcArrayObject;
	dataString		: String;
	returnString	: String;

begin
	dataString	:=	self;
	dataLength	:=	dataString.length;

	if dataLength &lt; DATA_CHUNK_SIZE then
		if pParseMethod = PARSE_METHOD_JADE then
			return dataString.cnEcEncodeWebDataAndStripCrLf();
		elseif pParseMethod = PARSE_METHOD_DLL then
			return call cnEcUrlEncode(dataString, 2);
		endif;
	else
		create workStringArray transient;
		dataPointer	:=	1;
		
		while (dataPointer &lt; dataLength) do
			workStringArray.addString(dataString[dataPointer:DATA_CHUNK_SIZE]);
			
			if (dataPointer + DATA_CHUNK_SIZE) &gt; dataLength then
				workStringArray.addString(dataString[dataPointer:end]);
				break;
			else
				dataPointer	:=	dataPointer + DATA_CHUNK_SIZE;
			endif;
		endwhile;
		
		foreach workStringObj in workStringArray do
			if pParseMethod = PARSE_METHOD_JADE then
				returnString	:=	returnString &amp; workStringObj.getStringValue().cnEcEncodeWebDataAndStripCrLf();
			elseif pParseMethod = PARSE_METHOD_DLL then
				returnString	:=	returnString &amp; call cnEcUrlEncode(workStringObj.getStringValue(), 2);
			endif;
		endforeach;
	endif;
	
	return returnString;
epilog
	delete workStringArray;
end;</source>
        <Parameter name="pParseMethod" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="cnEcValidateAsMask" id="530bffc6-9617-48f7-a3e9-0a35c3b660a2">
        <source>cnEcValidateAsMask():Integer;
// --------------------------------------------------------------------------------
// Created:		13 June 1999 by cnwdad1
//
// Purpose:		Validate the characters in a string format mask.
//
// Parameters:	pMask (String) - The mask string.
// Returns:		Integer - The position of an invalid mask character (zero if the mask is valid).
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
/*
	Valid mask characters are:

	Lower case alpha only:			"a"		(a thry z)
	Upper case alpha only:			"A"		(A thru Z)
	Lower case alphanumeric only:	"x"		(a thru z, and 0 thru 9)
	Upper case alphanumeric only:	"X"		(A thru Z, and 0 thru 9)
	Numeric only:					"9"		(1 thru 9)
	Special literal:						(overlying character must match this character.
											Charcters can be things like @, #, $, %, /, + etc.)
*/
constants
	ALPHA_LOWER		: Character = "a";
	ALPHA_UPPER		: Character = "A";
	ALPHANUM_LOWER	: Character = "x";
	ALPHANUM_UPPER	: Character = "X";
	NUMERIC			: Character = "9";

vars
	mask	: String;
	char	: Character;
	pos		: Integer;
	len		: Integer;

begin
	mask	:=	self.trimBlanks;
	len		:=	mask.length;
	pos		:=	1;

	while (pos &lt;= len) do
		char	:=	mask[pos:1].Character;

		if	(not char = ALPHA_LOWER)	and
			(not char = ALPHA_UPPER)	and
			(not char = ALPHANUM_LOWER)	and
			(not char = ALPHANUM_UPPER)	and
			(not char = NUMERIC)		then

			if	(not char = "~")	and
				(not char = "`")	and
				(not char = "!")	and
				(not char = "@")	and
				(not char = "#")	and
				(not char = "$")	and
				(not char = "%")	and
				(not char = "^")	and
				(not char = "&amp;")	and
				(not char = "*")	and
				(not char = "(")	and
				(not char = ")")	and
				(not char = "_")	and
				(not char = "-")	and
				(not char = "+")	and
				(not char = "=")	and
				(not char = "{")	and
				(not char = "}")	and
				(not char = "[")	and
				(not char = "]")	and
				(not char = "|")	and
				(not char = "\")	and
				(not char = "/")	and
				(not char = "?")	and
				(not char = "&lt;")	and
				(not char = "&gt;")	and
				(not char = ",")	and
				(not char = ".")	then

				return pos;
			endif;
		endif;

		pos	:=	pos + 1;
	endwhile;

	return 0;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="cnEcValidateNZPhoneNumber" id="ede68297-3d27-461d-83bf-b74695ac22dc">
        <updating/>
        <source>cnEcValidateNZPhoneNumber(pErrorMessage:String output):Boolean updating;
//   Having converted any alpha in the input to it's numeric equivalent if necessary and removed all delimiters
//   check that the resultant phone number seems reasonable for New Zealand
//   If the resultant number seems O.K. update self with the resultant number, and return true
//   listing any Warnings for changes made in errorMessage.
//
//   If the resultant number seems to be in error, return false, putting the reason in errorMessage and
//   leaving the the original input in self. 
vars
	workChar			: Character;		// Work space for character checking
	updatedInputString	: String;			// Contains the copy of self that we manipulate 
	workString			: String;			// Work area
	warnings			: String;			// Holds the Warning messages if required
	currentPos			: Integer;

begin
	updatedInputString := self;

	// Take care of any lowercase by making them Uppercase.

	updatedInputString := updatedInputString.toUpper;

	// Replace Standard delimiters with spaces.

	updatedInputString.replaceChar("("," ");
	updatedInputString.replaceChar(")"," ");

	workString := updatedInputString;		// Set up for before and after check.
	
	// Replace non-Standard delimiters with spaces.

	updatedInputString.replaceChar("+"," ");
	updatedInputString.replaceChar("#"," ");
	updatedInputString.replaceChar("*"," ");
	updatedInputString.replaceChar("-"," ");
	updatedInputString.replaceChar("["," ");
	updatedInputString.replaceChar("]"," ");
	updatedInputString.replaceChar("{"," ");
	updatedInputString.replaceChar("}"," ");
	updatedInputString.replaceChar("&lt;"," ");
	updatedInputString.replaceChar("&gt;"," ");
	updatedInputString.replaceChar("."," ");
	updatedInputString.replaceChar(","," ");

	if workString &lt;&gt; updatedInputString then
		warnings := warnings &amp; "Non-standard delimiters removed from input. ";
	endif;

	// Check for illegal characters

	currentPos := 1;
	workString := "";

	while currentPos &lt;= updatedInputString.length do
		workChar := updatedInputString[currentPos:1].Character;

		if workChar.isAlpha = false and
			workChar.isNumeric = false and
            workChar.String &lt;&gt; " " then
         		workString := workString &amp; " " &amp; workChar.String;	// Create a space delimited list of all illegal characters found	
        endif;

        currentPos := currentPos + 1;
    endwhile;

	if workString &lt;&gt; "" then
		pErrorMessage :=  "Error - Input contains illegal characters or illegal delimiters for a phone number. - '" &amp; workString &amp; " '.";
		return false;	
    endif;

	// Remove all spaces

	currentPos := 1;
    workString := "";

    while currentPos &lt;= updatedInputString.length do
		if updatedInputString[currentPos:1] &lt;&gt; " " then
			workString := workString &amp; updatedInputString[currentPos:1];	
		endif;
		currentPos := currentPos + 1;
	endwhile;

	updatedInputString := workString; 

	// Check for string starting with 'Phone', 'ph' or 'fax' and remove

	workString := "";

	if updatedInputString[1:5] = "PHONE" then
        workString := updatedInputString[6:updatedInputString.length - 5];
        updatedInputString := workString;
        warnings := warnings &amp; "'Phone' removed from input. ";	
    endif;

    if updatedInputString[1:2] = "PH" then
        workString := updatedInputString[3:updatedInputString.length - 2];
        updatedInputString := workString;
        warnings := warnings &amp; "'Ph' removed from input. ";	
    endif;

    if updatedInputString[1:3] = "FAX" then
        workString := updatedInputString[4:updatedInputString.length - 3];
        updatedInputString := workString;
        warnings := warnings &amp; "'Fax' removed from input. ";	
    endif;

	// Convert any Alpha phone numbers to numeric. (i.e. 0800 DIAL ZM )    

	workString := updatedInputString;

	updatedInputString.replaceChar("A","2");
	updatedInputString.replaceChar("B","2");
	updatedInputString.replaceChar("C","2");
	updatedInputString.replaceChar("D","3");
	updatedInputString.replaceChar("E","3");
	updatedInputString.replaceChar("F","3");
	updatedInputString.replaceChar("G","4");
	updatedInputString.replaceChar("H","4");
	updatedInputString.replaceChar("I","4");
	updatedInputString.replaceChar("J","5");
	updatedInputString.replaceChar("K","5");
	updatedInputString.replaceChar("L","5");
	updatedInputString.replaceChar("M","6");
	updatedInputString.replaceChar("N","6");
	updatedInputString.replaceChar("O","6");
	updatedInputString.replaceChar("P","7");
	updatedInputString.replaceChar("Q","1");
	updatedInputString.replaceChar("R","7");
	updatedInputString.replaceChar("S","7");
	updatedInputString.replaceChar("T","8");
	updatedInputString.replaceChar("U","8");
	updatedInputString.replaceChar("V","8");
	updatedInputString.replaceChar("W","9");
	updatedInputString.replaceChar("X","9");
	updatedInputString.replaceChar("Y","9");
	updatedInputString.replaceChar("Z","1");		

	if updatedInputString &lt;&gt; workString then
	   warnings := warnings &amp; "Alpha characters replaced with Numerics in input. ";
	endif;   

	// Ensure number starts with a zero

    if updatedInputString[1:1] &lt;&gt; "0" then
       pErrorMessage :=  "Error - Phone number must start with an STD code, i.e. start with a zero.";
       return false;
    endif;

	// Check for valid STD codes.

    if updatedInputString[1:1] = "0" then
		if updatedInputString[2:1] = "0" then
	        pErrorMessage :=  "Error - '00' is not a valid STD code in NZ.";
			return false;
	 	endif;

		if updatedInputString[2:1] = "1" then
		    pErrorMessage :=  "Error - '01' is not a valid STD code in NZ.";
			return false;
		endif;

		if updatedInputString[2:1] = "2" then
// cnwdad1 09/04/2001 - Change to also calter for 027 and 029 mobile phone numbers.
//			if updatedInputString[3:1] &lt;&gt; "1" and updatedInputString[3:1] &lt;&gt; "5" and updatedInputString[3:1] &lt;&gt; "6" then
//			   	pErrorMessage :=  "Error - '021', '025' &amp; '026' are the only valid '02' STD codes in NZ.";
			if updatedInputString[3:1] &lt;&gt; "1"
			and updatedInputString[3:1] &lt;&gt; "5"
			and updatedInputString[3:1] &lt;&gt; "6"
			and updatedInputString[3:1] &lt;&gt; "7"
			and updatedInputString[3:1] &lt;&gt; "9"
			then
			   	pErrorMessage :=  "Error - '021', '025', &amp; '026', '027' &amp; '029' are the only valid '02' STD codes in NZ.";
				return false;
			endif;

			if updatedInputString[3:1] = "6" then
	  	     	warnings := warnings &amp; " 026 is a pager number in NZ. ";
			endif;
		endif;

		if updatedInputString[2:1] = "5" and  updatedInputString[3:2] &lt;&gt; "08" then
			pErrorMessage :=  "Error - '0508' is the only valid '05' STD code in NZ.";
			return false;
		endif;

		if updatedInputString[2:1] = "8" and  updatedInputString[3:2] &lt;&gt; "00" then
			pErrorMessage :=  "Error - '0800' is the only valid '08' STD code in NZ.";
			return false;
		endif;
	endif;   

	// ensure that the phone number is long enough, but not too long. 

	if updatedInputString.length &lt; 9 then
		pErrorMessage :=  "Error - Phone number too short - Requires at least 9 digits in NZ.";
		return false;
	endif;

	if updatedInputString[1:2] &lt;&gt; "02" and		
       updatedInputString[1:4] &lt;&gt; "0508" and
       updatedInputString[1:4] &lt;&gt; "0800" and			
       updatedInputString[1:4] &lt;&gt; "0900" and
       updatedInputString.length &gt; 9 then	
		   	pErrorMessage :=  "Error - Phone number too long - Maximum of 9 digits for a normal phone number in NZ.";
			return false;
	endif;

	if updatedInputString[1:4] = "0508" or				// truncate 0800, 0508 &amp; 0900 numbers
       updatedInputString[1:4] = "0800" or
       updatedInputString[1:4] = "0900" then				// to 10 digits.
       	if updatedInputString.length &gt; 10 then
       		warnings := warnings &amp; updatedInputString[1:4] &amp; " number truncated. ";
        	updatedInputString := updatedInputString[1:10];
        endif;

        if updatedInputString.length &lt; 10 then				// check for enough characters in 0800 etc.
        	pErrorMessage :=  "Error - Phone number too short - Requires at least 6 digits after the " &amp; updatedInputString[1:4] &amp; ".";
			return false;
        endif;
	endif;

	if updatedInputString[1:2] = "02" and		
	   updatedInputString.length &gt; 10 then	
     	pErrorMessage :=  "Error - Cell Phone/Pager number too long - Maximum of 10 digits in NZ.";
		return false;
    endif;

	// Ensure first digit of local number not zero

	if updatedInputString[1:4] &lt;&gt; "0508" and
       updatedInputString[1:4] &lt;&gt; "0800" and			
       updatedInputString[1:4] &lt;&gt; "0900" and
       updatedInputString[3:1] = "0" then	
	   	pErrorMessage :=  "Error - '0' invalid number imediately after the STD code in NZ phone number.";
		return false;
    endif;

	// got through all the checking, return any warnings after updating self and end.

	self := updatedInputString;

	if warnings &lt;&gt; "" then	
    	warnings := "Warning: " &amp; warnings;
     	pErrorMessage :=  warnings;
    endif;

    return true;  							
end;</source>
        <Parameter name="pErrorMessage" type="String" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="cnEcXmlExtractFirstTag" id="dd50a055-218c-4714-b22b-d7dbfb4f05d0">
        <source>cnEcXmlExtractFirstTag() : String;

vars
	tag			: String;
	startPos	: Integer;
	endPos		: Integer;
	len			: Integer;
	spacePos	: Integer;
	
begin
	startPos	:= self.pos("&lt;", 1);
    endPos		:= self.pos("&gt;", 1);
    tag			:= "";

    if (startPos &gt; 0 and endPos &gt; 0) and (startPos &lt; endPos) then
    	if self[endPos-1:1] = "/" then
    		// looking for &lt;TAG_NAME/&gt;
    		endPos := endPos - 1;
    	endif;
    	
    	len			:=	(endPos -1 ) - startPos;
    	tag			:=	self[startPos + 1 : len];
        spacePos	:=	tag.pos(" ", 1);
        
        if spacePos &gt; 0 then
        	tag := tag[1 : spacePos -1];
        endif;
    endif;	
    
    return tag;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="cnEcXmlRemoveCDATA" id="633780d3-aa18-4ad5-a444-e8787704cc6f">
        <source>cnEcXmlRemoveCDATA():String;

vars
	dataString	: String;
	pos			: Integer;
	
begin
	dataString := self;

	if dataString[1:9] = "&lt;![CDATA[" then 
		dataString := dataString[10:(dataString.length - 12)];
	endif;

	return dataString;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="cnEcXmlReplaceReservedChars" id="59c370f9-a0f6-49af-8195-4049146ea568">
        <source>cnEcXmlReplaceReservedChars(pIsToChar:Boolean):String;
// --------------------------------------------------------------------------------
// Created:		21 December 2000 by cnwdad1
//
// Purpose:		Converts XML Character Entities contained in the receiver between
//				the characters and their entities.  For example, if converting
//				entities to characters, then a "&amp;amp;" will become "&amp;".  Likewise,
//				if converting characters to entities, then a "&amp;" will become "&amp;amp;".
//
// Parameters:	pIsToChar - If true, then entities will be converted into entities,
//				otherwise entities will be converted into characters.
//
// Returns:		String - The resulting converted string.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
constants
	CHAR_AMPERSAND		: String = 38.Character;
	CHAR_LESS_THAN		: String = 60.Character;
	CHAR_GREATER_THAN	: String = 62.Character;
	CHAR_APOSTROPHE		: String = 39.Character;
	CHAR_QUOTE			: String = 34.Character;
	ENTITY_AMPERSAND	: String = "&amp;amp;";
	ENTITY_LESS_THAN	: String = "&amp;lt;";
	ENTITY_GREATER_THAN	: String = "&amp;gt;";
	ENTITY_APOSTROPHE	: String = "&amp;apos;";
	ENTITY_QUOTE		: String = "&amp;quot;";

vars
	resultString	: String;
	
begin
	resultString	:=	self;
	
	if pIsToChar then
		resultString	:=	resultString.cnEcFindReplace(ENTITY_LESS_THAN, CHAR_LESS_THAN, false);
		resultString	:=	resultString.cnEcFindReplace(ENTITY_GREATER_THAN, CHAR_GREATER_THAN, false);
		resultString	:=	resultString.cnEcFindReplace(ENTITY_QUOTE, CHAR_QUOTE, false);
		resultString	:=	resultString.cnEcFindReplace(ENTITY_APOSTROPHE, CHAR_APOSTROPHE, false);
		resultString	:=	resultString.cnEcFindReplace(ENTITY_AMPERSAND, CHAR_AMPERSAND, false); 
	else
		resultString	:=	resultString.cnEcFindReplace(CHAR_AMPERSAND, ENTITY_AMPERSAND, false);
		resultString	:=	resultString.cnEcFindReplace(CHAR_LESS_THAN, ENTITY_LESS_THAN, false);
		resultString	:=	resultString.cnEcFindReplace(CHAR_GREATER_THAN, ENTITY_GREATER_THAN, false);
		resultString	:=	resultString.cnEcFindReplace(CHAR_QUOTE, ENTITY_QUOTE, false);
		resultString	:=	resultString.cnEcFindReplace(CHAR_APOSTROPHE, ENTITY_APOSTROPHE, false);
	endif;
	
	return resultString;
end;</source>
        <Parameter name="pIsToChar" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="cnEcXmlUseCDATA" id="401d5d02-bf0c-4089-839e-0ea9f3c1a16f">
        <source>cnEcXmlUseCDATA():String;

/*

Date		Who		Reason
20 May 2009	cnwkpd1	CCMS SFW 1073 - PAR #19729 - rewrite to improve performance

*/

constants
	CDATA_Characters	= "&lt;&gt;'&amp;" &amp; '"';

vars
//	charPos		: Integer;
//	cdataString	: String;
//	isCdata		: Boolean;
	pos			: Integer;
	
begin
	if self = null then
		return self;
	endif;
	
	pos := 1;
	self.scanUntil(CDATA_Characters, pos);
	
	if pos = 0 then
		return self;
	else
		return self.makeXMLCData();
	endif;
	
/* 	KPD PAR #19729 - Old code replaced

	cdataString	:=	self;
	isCdata		:=	false;
	charPos		:=	1;
	
	while charPos &lt;= cdataString.length do
		if cdataString[charPos:1] = "&lt;"
		or cdataString[charPos:1] = "&gt;"
		or cdataString[charPos:1] = "'"
		or cdataString[charPos:1] = '"'
		or cdataString[charPos:1] = "&amp;"
		then
			isCdata	:=	true;
			break;	
		endif;
		
		charPos	:=	charPos + 1; 
	endwhile;

	if isCdata then
		cdataString := "&lt;![CDATA[" &amp; cdataString &amp; "]]&gt;";
	endif;

	return cdataString;
*/
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
</PrimType>
