    <JadeMethod name="comboBoxGridDirection" id="b972b558-f994-484d-9e97-eb070c46b25d">
        <source>comboBoxGridDirection(_cmb: CMUI_ComboBox input; _value: Integer);
//----------------------------------------------------------------
//	Created:	01 June 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	cmbData	: Integer;
	idx		: Integer;
begin

	_cmb.clear;
	
	_cmb.addItemWithData(app.getErrorString(Decking_From_First), CM_GridArea.DefaultDeckingFromFirst);
	
	_cmb.addItemWithData(app.getErrorString(Decking_From_Last), CM_GridArea.DefaultDeckingFromLast);
	
	foreach idx in 1 to _cmb.listCount do
		cmbData := _cmb.itemData[idx];
		if cmbData = _value then
			_cmb.listIndex := idx;	
			break;
		endif;				
	endforeach;				

end;</source>
        <Parameter name="_cmb" type="CMUI_ComboBox" usage="input"/>
        <Parameter name="_value" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="comboBoxHMSBerth" id="6679f996-a49a-4cb3-845b-c783e41685cd">
        <source>comboBoxHMSBerth(pCmb : CMUI_ComboBox input; _harbour : HMS_Harbour; _berth : HMS_Berth; _justHarbourBerths : Boolean);
//--------------------------------------------------------------
//Created: March 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	harbour, 
	realHarbour	: HMS_Harbour;
	tmpBerth	: HMS_Berth;
	
begin
	pCmb.clear();

	if (not _justHarbourBerths) then
// cnwdad1 05/06/2007 - implemented the CM_Root::allHMSBerths collection.
/*
		write class.name &amp; '::' &amp; method.name &amp; '  NEED TO REORG - and add allBerths to CM_Root + inverse to CM_Berth';
		foreach tmpBerth in HMS_Berth.instances do
			pCmb.addItemObject(self.displayEntryHMSBerth(tmpBerth), tmpBerth);
		endforeach;
		foreach tmpBerth in HMS_BerthNonHarbour.instances do
			pCmb.addItemObject(self.displayEntryHMSBerth(tmpBerth), tmpBerth);
		endforeach;
*/
		foreach tmpBerth in app.myRoot.allHMSBerths do
			pCmb.addItemObject(self.displayEntryHMSBerth(tmpBerth), tmpBerth);
		endforeach;
		
		if _berth &lt;&gt; null then
			pCmb.cnEcSetObjectIndex(_berth);
		endif;
		
		return;
	endif;
	
	if _harbour = null and _berth = null then
		return;
	endif;
	
	harbour := _harbour;
	
	if harbour = null then
		harbour := _berth.getHarbourReal();
	endif;
	
	if harbour = null then
		return;
	endif;
	
	if harbour.isTransient then
		realHarbour := harbour.pxyGetRealObject;
	else
		realHarbour := harbour;
	endif;

	pCmb.listCollection(realHarbour.allBerths, false, 0);
	
	if _berth &lt;&gt; null then
		pCmb.listIndex := pCmb.findObject(_berth);
	endif;
end;</source>
        <Parameter name="pCmb" type="CMUI_ComboBox" usage="input"/>
        <Parameter name="_harbour" type="HMS_Harbour"/>
        <Parameter name="_berth" type="HMS_Berth"/>
        <Parameter name="_justHarbourBerths" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="comboBoxHMSBerthForRegion" id="eead9711-60ae-4ee7-bbaa-bfbc4bbbad97">
        <source>comboBoxHMSBerthForRegion(pCmb : CMUI_ComboBox input; pRegion :HMS_HarbourRegion; _berth : HMS_Berth);
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 June 2008	cnwer1	Initial creation

*/

vars

	harbourRegion	: HMS_HarbourRegion;
	berth			: HMS_Berth;
begin
	pCmb.clear;
	
	foreach berth in pRegion.allBerthsInRegion do
		pCmb.addItemObject(self.displayEntryHMSBerth(berth), berth);
	endforeach;

	if _berth &lt;&gt; null then
		pCmb.listIndex := pCmb.findObject(_berth);
	endif;	

end;</source>
        <Parameter name="pCmb" type="CMUI_ComboBox" usage="input"/>
        <Parameter name="pRegion" type="HMS_HarbourRegion"/>
        <Parameter name="_berth" type="HMS_Berth"/>
    </JadeMethod>
    <JadeMethod name="comboBoxHMSBerthForTerminal" id="7d8b58ac-5608-40ef-b76c-b8ce66ce9dea">
        <source>comboBoxHMSBerthForTerminal(pCmb : CMUI_ComboBox input; pTerminal :CM_Terminal; _berth : HMS_Berth);

vars
	harbourRegion	: HMS_HarbourRegion;
	berth			: HMS_Berth;
begin
	pCmb.clear;
	
	foreach harbourRegion in pTerminal.allHarbourRegions do
		foreach berth in harbourRegion.allBerthsInRegion do
			pCmb.addItemObject(self.displayEntryHMSBerth(berth), berth);
		endforeach;
	endforeach;
	
	if _berth &lt;&gt; null then
		pCmb.listIndex := pCmb.findObject(_berth);
	endif;
end;
</source>
        <Parameter name="pCmb" type="CMUI_ComboBox" usage="input"/>
        <Parameter name="pTerminal" type="CM_Terminal"/>
        <Parameter name="_berth" type="HMS_Berth"/>
    </JadeMethod>
