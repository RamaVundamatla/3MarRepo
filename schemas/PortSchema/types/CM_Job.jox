    <JadeMethod name="getLocations" id="605e221d-120c-4a0d-b252-bda283e8fea7">
        <source>getLocations(_sl, _tl : String io);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 Jan 2023 navhl20 Bug 61873: FR | 53891 - Mobile App changes for Delivery Dispatch (EP Tickets)
22 Nov 2024	navdap1	MTN-18821 EUP* | FR 53485 - Warehouse Yard Allocation - Mobile App location selection issues
06 Mar 2025 navma1  MTN-34179 MTN | Dead Lock (1081) on CM_WLEArray
*/

vars
	wle 			: CM_WorkListEntry;
	ti				: CM_TrackedItem;
	slArr,	
	tlArr			: StringArray;
	wleArr  		: CM_WLEArray;
	lcActual,
	lcQueued		: CM_LocationsController;
	fullIdActual,
	fullIdQueued,	
	tiLocationId    : String;
begin
	create slArr transient;
	create tlArr transient;
	
	create wleArr transient;
	
	self.workListEntries.copy(wleArr);						//06.03.2025 navma1 #MTN-34179
	
	foreach wle in wleArr discreteLock do					//06.03.2025 navma1 #MTN-34179
		
		if not wle.isCompleted and not wle.isChassis then	//06.03.2025 navma1 #MTN-34179
			ti := wle.myTrackedItem;
			
			if ti &lt;&gt; null then
				
				tiLocationId := ti.locationId;				//06.03.2025 navma1 #MTN-34179
				
				if tiLocationId &lt;&gt; null and not slArr.includes(tiLocationId) then
					slArr.add(tiLocationId); 
				endif;
				
				lcActual := ti.myPrimaryActualLocation;		//06.03.2025 navma1 #MTN-34179
				
				if lcActual &lt;&gt; null then
					fullIdActual := lcActual.getFullId();
					if  fullIdActual &lt;&gt; null and not slArr.includes(fullIdActual) then
						slArr.add(fullIdActual);
					endif;
				endif;
				
				lcQueued := ti.myPrimaryQueuedLocation;		//06.03.2025 navma1 #MTN-34179
				
				if lcQueued &lt;&gt; null then
					fullIdQueued := lcQueued.getFullId();
					if fullIdQueued &lt;&gt; null and not tlArr.includes(fullIdQueued) then
						// MTN-18821 If the WLE has a future job and the future job is to a full warehouse area,
						// just add the terminal area id
						if wle.myFutureMove &lt;&gt; null and wle.myFutureMove.isMoveToFullGCArea then
							tlArr.add(lcQueued.terminalAreaId);
						else
							tlArr.add(fullIdQueued);
						endif;
					endif;
				endif;
			endif;
			
			if wle.locationSource &lt;&gt; null and not slArr.includes(wle.locationSource) then
				slArr.add(wle.locationSource);
			endif;
			
			if wle.locationTarget &lt;&gt; null and not tlArr.includes(wle.locationTarget) then
				tlArr.add(wle.locationTarget);
			endif;
		endif;
	endforeach;
	
	_sl := slArr.concatenate(Comma);
	_tl := tlArr.concatenate(Comma);
epilog
	delete tlArr;
	delete slArr;
	delete wleArr;
end;</source>
        <Parameter name="_sl" type="String" usage="io"/>
        <Parameter name="_tl" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getLocationsStrFromRequests" id="5ce427d8-4a20-4fd0-abdc-fc7af28c4d24">
        <source>getLocationsStrFromRequests(_plannedLocations : String output; _plannedTerminalAreas : String output);
/*

Purpose:		This method go through the requests and build up string for _plannedLocations and _plannedTerminalAreas without dupllicates	

Parameters:			

Return Value:		

Date		Who		Reason
//26/08/2024	navkc1 CR 63588 Task 63589: FR | 53729 - Delivery Dispatch screen - First Warehouse and Number of Warehouse CHANGES

*/

vars
	request 	: CM_Request;
	locationsStrArray,
	tasStrArray : StringArray;
begin
	create locationsStrArray transient;
	create tasStrArray transient;
	
	foreach request in self.allRequests discreteLock do
		request.plannedLocations.asStringArrayByDelimiter(locationsStrArray, Comma);
		request.plannedTerminalAreas.asStringArrayByDelimiter(tasStrArray, Comma);
	endforeach;
	
	locationsStrArray.removeDuplicates();
	tasStrArray.removeDuplicates();
	
	_plannedLocations := locationsStrArray.asCSV(false);
	_plannedTerminalAreas := tasStrArray.asCSV(false);
	
	
epilog
	delete locationsStrArray;
	delete tasStrArray;
end;</source>
        <Parameter name="_plannedLocations" type="String" usage="output"/>
        <Parameter name="_plannedTerminalAreas" type="String" usage="output"/>
    </JadeMethod>
