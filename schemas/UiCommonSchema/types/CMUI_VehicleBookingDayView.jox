    <JadeMethod name="addBookingSlot" id="6f5efb91-9f4a-49f5-9e29-4386790b228d">
        <source>addBookingSlot() protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 April 2013	cnwndl1	Initial creation	Par 31393
// 18 May 2016	cnwns1	TFS 488 - Multi Timezone Support
*/

vars

	slotMaintForm : CMUI_VehicleBookingSlotMaint;
	bookingSlot : CM_VehicleBookingTimeSlot;
	localStartTS : TimeStamp;
	startTS : TimeStamp;
	endTS : TimeStamp;
	date : Date;

begin

	startTS := null;
	endTS := null;

	if self.tblBookings.row &gt; self.tblBookings.fixedRows and self.tblBookings.row &lt;= self.tblBookings.rows then
		bookingSlot := self.tblBookings.accessRow( self.tblBookings.row ).itemObject.CM_VehicleBookingTimeSlot;
	endif;
	
	//21 July 2014	NDL	Par 34435
	if bookingSlot &lt;&gt; null then
		startTS := bookingSlot.bookingTSstart;
		endTS := bookingSlot.bookingTSend;
	else
		date := self.txtDate.getDate;
		if date.isValid then
			localStartTS.setDate(date);
			localStartTS.setTime("00.00".Time);
			startTS := self.localToSystemTime(localStartTS);// 18 May 2016	cnwns1	TFS 488 - Multi Timezone Support
			endTS := startTS;
		endif;
	endif;

	slotMaintForm := app.loadForm(CMUI_VehicleBookingSlotMaint, CMUI_Assistant, false, false, false, self.myTerminal, null).CMUI_VehicleBookingSlotMaint;
	if slotMaintForm &lt;&gt; null then
		slotMaintForm.setMyBookingSlot(null,startTS,endTS);
		slotMaintForm.setMyCallingForm(self);
		slotMaintForm.show;
	endif;

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="addBookingSlotToTable" id="e1d5ce0a-4e93-4ab3-8b04-40d30f3dd66f">
        <source>addBookingSlotToTable( _vvsBooking : CM_VehicleBookingTimeSlot; _insert : Boolean; _indexLine : Integer output; _now : TimeStamp ) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 April 2013	cnwndl1	Initial creation	Par 31393
// 18 May 2016	cnwns1	TFS 488 - Multi Timezone Support
*/

vars

	dataLine : String;
	index : Integer;
	rowBooking : CM_VehicleBookingTimeSlot;
	old : Boolean;
	nextDay : Boolean;
	graceMins : Integer;
	graceTSInterval : TimeStampInterval;
	localTS : TimeStamp;
	systemTS : TimeStamp;
begin

	// apply the filter values...
	if _vvsBooking.isUsed and not self.chkInclUsed.value then
		return;
	endif;
	if _vvsBooking.isUnBookedTimeslot and not self.chkInclUnbooked.value then
		return;
	endif;
	if _vvsBooking.isBookedNotYetUsed and not self.chkInclBooked.value then
		return;
	endif;
	if _vvsBooking.myCarrier &lt;&gt; null then
		if self.myFilterCarrier &lt;&gt; null and self.myFilterCarrier &lt;&gt; _vvsBooking.myCarrier then
			return;
		endif;
	endif;
	if _vvsBooking.myDriver &lt;&gt; null then
		if self.myFilterDriver &lt;&gt; null and self.myFilterDriver &lt;&gt; _vvsBooking.myDriver then
			return;
		endif;
	endif;
	if _vvsBooking.myVehicle &lt;&gt; null then
		if self.myFilterVehicle &lt;&gt; null and self.myFilterVehicle &lt;&gt; _vvsBooking.myVehicle then
			return;
		endif;
	endif;
	
	dataLine := _vvsBooking.getAttributeStringForDefArray(self.tblBookings.allTblDataEntRows);
	if _now &lt;&gt; null then
		graceTSInterval := self.myTerminal.getVSTimeslotGraceTimeInterval( graceMins );
		if graceMins = 0 then
			old := _now &gt; _vvsBooking.bookingTSend;
		else
			old := _now &gt; _vvsBooking.bookingTSend + graceTSInterval;
		endif;
		localTS.cnEcSetDateAndTime(self.txtDate.getDate,TimeStartOfDay);													// 18 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		systemTS := self.localToSystemTime(localTS);																		// 18 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		nextDay := _vvsBooking.bookingTSend.date() &lt;&gt; systemTS.date() and _vvsBooking.bookingTSend.time() &gt; systemTS.time();// 18 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		//nextDay := _vvsBooking.bookingTSend.date &lt;&gt; self.txtDate.getDate and _vvsBooking.bookingTSend.time &gt; "00:00".Time;
	endif;
			
	if _insert then
		foreach index in self.tblBookings.fixedRows to self.tblBookings.rows do
			rowBooking := self.tblBookings.accessRow(index).itemObject.CM_VehicleBookingTimeSlot;
			if rowBooking = null then
				continue;
			endif;
			if rowBooking.bookingTSstart &gt; _vvsBooking.bookingTSstart then
				_indexLine := index;
				break;
			elseif rowBooking.bookingTSstart = _vvsBooking.bookingTSstart then
				if rowBooking.bookingTSend &gt; _vvsBooking.bookingTSend then
					_indexLine := index;
					break;
				endif;
			endif;
		endforeach;
		if _indexLine = 0 then
			_indexLine := self.tblBookings.rows + 1;
		endif;
	else
		_indexLine := self.tblBookings.rows + 1;
	endif;
	
	self.tblBookings.addItemAt(dataLine,_indexLine);
	self.tblBookings.accessRow(_indexLine).itemObject := _vvsBooking;
	if old then
		self.tblBookings.accessRow(_indexLine).backColor := PaleYellow;
	elseif nextDay then
		self.tblBookings.accessRow(_indexLine).backColor := xmlColourNonCurrMth;
	endif;
		
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_vvsBooking" type="CM_VehicleBookingTimeSlot"/>
        <Parameter name="_insert" type="Boolean"/>
        <Parameter name="_indexLine" type="Integer" usage="output"/>
        <Parameter name="_now" type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="addToolbarControls" id="5d2817d5-2ddc-48be-a651-e4b0295e0eed">
        <updating/>
        <source>addToolbarControls() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21 October 2010	cnwndl1	Initial creation

*/

vars

	toolbar	: CMUI_Toolbar;
	filterBar : CMUI_Toolbar;
	
begin

	if self.cmbPeriod.listCount = 0 then
		// no saved window data, need to do the populate.
		self.populateCombos();
	endif;

	inheritMethod();
	
	self.frmPeriod.width := 500;

	toolbar	:=	self.frmToolbar;
	toolbar.addButton(self.btnFilter, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnPrint, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnRefresh, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnToday, CMUI_Toolbar.Control_Alignment_Left);

//	if process.isNDL then
//		toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
//		toolbar.addButton(self.btnGenTemp, CMUI_Toolbar.Control_Alignment_Left);
//	endif;
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addFrame(self.frmPeriod, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);	//18 Mar 2015	NDL	Par 35882
	toolbar.addFrame(self.frmLastVBSUpdate, CMUI_Toolbar.Control_Alignment_Left);	//18 Mar 2015	NDL	Par 35882
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);	//18 Mar 2015	NDL	Par 35882
	toolbar.addFrame(self.frmSearchById, CMUI_Toolbar.Control_Alignment_Left);	//18 Mar 2015	NDL	Par 35882
	
	toolbar.positionToolbarControls();
	
	self.localToolBarResize();
	toolbar.visible := true;

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
