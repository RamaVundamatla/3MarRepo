    <JadeMethod name="isRailBreakBulk" id="c3a46bb3-bf79-4f8a-ba9c-835eb1fd2854">
        <source>isRailBreakBulk():Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 July 2014	cnwndl1	Initial creation	Par 34552

*/

vars

begin

	if not self.isRail then
		return false;
	endif;
	
	if self.myRequest.isDeliveryRequest() then
		if self.myRequest.CM_DeliveryRequest.myCargoType.isBreakBulk() then
			return true;
		endif;
	endif;

	if self.myRequest.isKindOf( CM_TIRequest ) then
		return self.myRequest.CM_TIRequest.isBreakBulk;
	endif;
	
	return false;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isRailBreakBulkRelease" id="26f46a8e-d557-4ccd-a3cd-6acd3fddc2f5">
        <source>isRailBreakBulkRelease():Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
19 September 2013	cnwndl1	Initial creation	par 32479
19 October 2022		jlizm1	TFS 54118 Assigning Releases to Wagons

*/

vars

begin

	if not self.isRail then
		return false;
	endif;
	
	//cnwmc5 - 27 Feb 2014 - PAR 33600
	if self.myRequest.isDeliveryRequest() then
		if self.myRequest.CM_DeliveryRequest.myCargoType.isBreakBulk()
		or self.myRequest.CM_DeliveryRequest.myCargoType.isBulk() then // TFS 54118
			return true;
		endif;
	endif;

	if not self.myRequest.isKindOf( CM_TIRequest ) then
		return false;
	endif;
	
	if self.myTrackedItem = null or not self.myTrackedItem.canMergeBreakBulk then
		return false;
	endif;
	
	return true;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
