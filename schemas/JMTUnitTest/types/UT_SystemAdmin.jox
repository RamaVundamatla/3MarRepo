end;</source>
    </JadeMethod>
    <JadeMethod name="tCountry" id="bee3653a-419f-4fc8-a614-621b0df5b53b">
        <source>tCountry();

/*

Purpose:		

Date			Who		Reason
17/06/2015		cnwmh5	Initial creation

*/

vars

	pxyCountry				: CM_Country;
	country					: CM_Country;
	cmif					: CMIF_Country;
	
	desc					: String;
	
begin

	country := app.myRoot.allCountries["Z("];
		
	if country &lt;&gt; null then
		app.myTrxDA.trxDeleteCountry(country, app.myPassport);
		self.assertNoTrxErrorsOrWarnings();
	endif;
	
	desc := "Michael's DO NOT USE";
	create pxyCountry transient;
	pxyCountry.setProxy("Z(", desc, null, null, false, null);
	create cmif transient;
	cmif.myProxyCountry := pxyCountry;
	cmif.allRealPorts.clear();
	app.myTrxCA.trxCreateCountry(cmif, country, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	delete pxyCountry;
	delete cmif;
	beginLoad;
	pxyCountry := country.pxyCreateUpdateProxy();
	endLoad;
	desc := "REALLY DO NOT USE";
	pxyCountry.setPropertyValue("description", desc);
	pxyCountry.setPropertyValue("isNotAvailableForEntry", true);
	create cmif transient;
	cmif.myProxyCountry := pxyCountry;
	cmif.allRealPorts.clear();
	pxyCountry.ports.copy(cmif.allRealPorts);
	app.myTrxUA.trxUpdateCountry(cmif, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertEqual(country.description, desc);
	self.assertEqual(country.isNotAvailableForEntry, true);

epilog

	delete pxyCountry;
	delete cmif;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tCountryRegion" id="31a7e1ff-aea3-4596-b895-e6c95be8edfd">
        <source>tCountryRegion();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03/08/2023	navkc1	CR 59552   Task 59554: Jade CustDocs - Country Region TRX

*/
constants
	RegionID = "UTCOUNTRYRGN";
	RegionID2 = "UTCOUNTRYRGN2";
	RegionDesc = "UT Country Region";
	RegionDescUpdate = "Updated UT Country Region";
vars
	oriHomeRegion,
	pxyCountryRegion,
	realCountryRegion	: CM_CountryRegion;
	countries			: CM_CountryByCodeDict;
	country1,
	country2,
	country3,
	country4			: CM_Country;
	root				: CM_Root;
	reset				: Boolean;
	oriRegion1,
	oriRegion2,
	oriRegion3,
	oriRegion4			: CM_CountryRegion;
begin
	
	create countries transient;
	
	root := app.myRoot;
	self.assertNotNullMsg(root, "Root is null.");
	
	// ==============================
	// DELETE EXISTING COUNTRY REGION
	// ==============================
	realCountryRegion := self.getCountryRegion(RegionID);
	if realCountryRegion &lt;&gt; null then
		self.deleteCountryRegion(realCountryRegion);
		realCountryRegion := self.getCountryRegion(RegionID);
		self.assertNullMsg(realCountryRegion, "Country Region not deleted");
	endif;
	
	// ==============================
	// GET CURRENT HOME COUNTRY REGION
	// ==============================
	foreach oriHomeRegion in root.allCountryRegions do
		if oriHomeRegion.homeRegion then
			reset := true;
			beginTransaction;
			oriHomeRegion.setPropertyValue("homeRegion", false);
			commitTransaction;
			break;
		endif;
	endforeach;
	
	// ==========================
	// CREATE COUNTRY REGION TEST
	// ==========================
	country1 := root.allCountries["AU"];
	self.assertNotNullMsg(country1, "AU country is null.");
	country2 := root.allCountries["NZ"];
	self.assertNotNullMsg(country2, "NZ country is null.");
	
	oriRegion1 := country1.myCountryRegion;
	oriRegion2 := country2.myCountryRegion;
	
	beginTransaction;
		country1.setPropertyValue("myCountryRegion", null);
		country2.setPropertyValue("myCountryRegion", null);
	commitTransaction;
	
	countries.add(country1);
	countries.add(country2);
	
	create pxyCountryRegion transient;
	
	pxyCountryRegion.setProxy(RegionID, RegionDesc, true, false, countries);
	realCountryRegion := self.addCountryRegion(pxyCountryRegion);
	
	self.assertEqualMsg(realCountryRegion.code, RegionID, "Code not correct.");
	self.assertEqualMsg(realCountryRegion.description, RegionDesc, "Description not correct.");
	self.assertEqualMsg(realCountryRegion.homeRegion, true, "Home Region not correct.");
	self.assertEqualMsg(realCountryRegion.notAvailForEntry, false, "Not Avail For Entry not correct.");
	self.assertEqualMsg(realCountryRegion.allCountries.first().code, country1.code, "Create country collection 1 not correct.");
	self.assertEqualMsg(realCountryRegion.allCountries.last().code, country2.code, "Create  country collection 2 not correct.");
	
	delete pxyCountryRegion;
	
	// ==================================
	// CREATE COUNTRY REGION DUPLICATE ID 
	// ==================================
	create pxyCountryRegion transient;
	
	self.clearExpectedTrxErrors();
	self.expectedTrxErrors.add(CountryRegionCodeInUsed); 
	self.expectedTrxErrors.add(OnlyOneHomeRegion); 
	
	pxyCountryRegion.setProxy(RegionID, RegionDesc, true, false, countries);
	self.addCountryRegion(pxyCountryRegion);
	
	self.clearExpectedTrxErrors();
	
	delete pxyCountryRegion;
	
	beginLoad;
	pxyCountryRegion := realCountryRegion.pxyCreateUpdateProxy();
	endLoad;
	
	countries.clear();
	
	// ==========================
	// UPDATE COUNTRY REGION TEST
	// ==========================
	
	country3 := app.myRoot.allCountries["CA"];
	self.assertNotNullMsg(country1, "CA country is null.");
	country4 := app.myRoot.allCountries["QA"];
	self.assertNotNullMsg(country2, "QA country is null.");
	
	oriRegion3 := country3.myCountryRegion;
	oriRegion4 := country4.myCountryRegion;
	
	beginTransaction;
		country3.setPropertyValue("myCountryRegion", null);
		country4.setPropertyValue("myCountryRegion", null);
	commitTransaction;
	
	countries.add(country3);
	countries.add(country4);
	
	pxyCountryRegion.setProxy(RegionID, RegionDescUpdate, true, true, countries);
	
	self.updateCountryRegion(pxyCountryRegion);
	realCountryRegion := self.getCountryRegion(RegionID);
	
	self.assertNotNullMsg(realCountryRegion, "Country Region is null");
	
	self.assertEqualMsg(realCountryRegion.code, RegionID, "Code not correct.");
	self.assertEqualMsg(realCountryRegion.description, RegionDescUpdate, "Description not correct.");
	self.assertEqualMsg(realCountryRegion.homeRegion, true, "Home Region not correct.");
	self.assertEqualMsg(realCountryRegion.notAvailForEntry, true, "Not Avail For Entry not correct.");
	self.assertEqualMsg(realCountryRegion.allCountries.first().code, country3.code, "Update country collection 3 not correct.");
	self.assertEqualMsg(realCountryRegion.allCountries.last().code, country4.code, "Update country collection 4 not correct.");
	
	delete pxyCountryRegion;
	
	// ==============================
	// COUNTRY REGION VALIDATION TEST
	// ==============================
	
	create pxyCountryRegion transient;
	countries.clear();
	pxyCountryRegion.setProxy(RegionID, RegionDesc, false, false, countries);
	app.myTrxCA.trxCreateCountryregion(pxyCountryRegion, realCountryRegion, app.myPassport);
	
	self.assertTrxError(CountryRegionCodeInUsed);
	
	pxyCountryRegion.setProxy(RegionID2, RegionDesc, true, false, countries);
	app.myTrxCA.trxCreateCountryregion(pxyCountryRegion, realCountryRegion, app.myPassport);
	
	self.assertTrxError(OnlyOneHomeRegion);
	
	delete pxyCountryRegion;
	
	// ==========================
	// DELETE COUNTRY REGION TEST
	// ==========================
	realCountryRegion := self.getCountryRegion(RegionID);
	self.deleteCountryRegion(realCountryRegion);
	realCountryRegion := self.getCountryRegion(RegionID);
	self.assertNullMsg(realCountryRegion, "Country Region not deleted");
	
epilog
	delete countries;
	delete pxyCountryRegion;
	
	beginTransaction;
	if reset then
		oriHomeRegion.setPropertyValue("homeRegion", true);
	endif;
	country1.setPropertyValue("myCountryRegion", oriRegion1);
	country2.setPropertyValue("myCountryRegion", oriRegion2);
	country3.setPropertyValue("myCountryRegion", oriRegion3);
	country4.setPropertyValue("myCountryRegion", oriRegion4);
	commitTransaction;
end;</source>
    </JadeMethod>
    <JadeMethod name="tCustomsAgent" id="71254242-84e7-4683-9e63-e896ac586fbd">
        <source>tCustomsAgent();

/*

Purpose:		Create / Update / Delete Customs Agent

Date			Who		Reason
18/02/2014		cnwmh5	Initial creation

*/

vars

	customsAgent					: CM_CustomsAgent;
	
	updateName						: String;

begin

	// delete / create customs agent
	customsAgent := self.addCustomsAgent("UTMDHCA", "Michaels Customs Agent");
	self.assertNotNull(customsAgent);
	
	// update customs agent
	updateName := customsAgent.name &amp; " 2";
	self.opts.purge();
	self.opts.addAssoc("Name", updateName);
	self.updateCustomsAgent(customsAgent);
	self.assertEqual(customsAgent.name, updateName);
	
	// delete customs agent
	self.deleteCustomsAgent(customsAgent);
	self.assertNotNull(customsAgent);

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="tDamage" id="102d0777-29f2-48b0-9710-748f5bb22c9d">
        <source>tDamage();

/*

Purpose:		Damage Definition and Damage codes

Date			Who		Reason
03/04/2014		cnwmh5	Initial creation

*/

vars

	damageDef					: CM_DamageDefinitionCode;
	
	cargoTypes					: CM_ObjectSet;

	tempStr						: String;
	
begin

	create cargoTypes transient;

	damageDef := self.addDamageDefinition("UTTWISTED", "Unit Test Twisted", cargoTypes);
	self.assertNotNull(damageDef);
	
	tempStr := damageDef.description &amp; " Again";
	self.opts.purge();
	self.opts.addAssoc("Description", tempStr);
	self.updateDamageDefinition(damageDef);
	self.assertEqual(damageDef.description, tempStr);
	
epilog

	delete cargoTypes;

end;</source>
    </JadeMethod>
    <JadeMethod name="tDamageTypes" id="fe2c0f57-1e3e-46ef-b5c3-b8099889b90d">
        <updating/>
        <source>tDamageTypes() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 February 2016	cnwns1	Initial creation
11 July 2022	navak20	TFS 53862 EUP - WMS - Damage Recording Extra Details
TestLink 1-127
*/
constants
	ProductId1		: String = "UTNSCTP1";
	ProductId2		: String = "UTNSCTP2";
    DamageID1 		: String = "BUSTED";
    DamageID2 		: String = "MUNTED";
    DamageID3 		: String = "STUFFED";
    CargoID1 		: String = "AWESOME1";
    CargoID2 		: String = "AWESOME2";
    DamagePosID1 	: String = "INSIDE";
    DamagePosID2 	: String = "BEFORE";
    DamagePosID3 	: String = "AFTER";
vars
	damageDef1		: CM_DamageDefinitionCode;
	damageDef2		: CM_DamageDefinitionCode;
	damageDef3		: CM_DamageDefinitionCode;
	cargoTypes		: CM_ObjectSet;
	cargo1 			: CM_TrackedItem;
	cargo2 			: CM_TrackedItem;
	damageCount 	: Integer;
	cargoType1		: CM_CargoType;
	cargoType2		: CM_CargoType;
	pxyCargoType	: CM_CargoType;
	machineTypes	: CM_ObjectSet;
	bs1 			: CM_BlockStack;
	damagePos1		: CM_DamagePosition;
	damagePos2		: CM_DamagePosition;
	damagePos3		: CM_DamagePosition;
	damInst1 		: CM_DamageInstance;
	pxyDamInst 		: CM_DamageInstance;
	pxyTI			: CM_TrackedItem;
	pxyDraw			: CM_DrawingAttribute;
	product1		: CM_Product;
	operator		: CM_Operator;
	product2		: CM_Product;
begin

	
//In System Ops- create 2 new cargo types 1 that Shows Damages Codes and one that does not.
//In System Admin - Damages Codes. Create 3 new damage codes. 


	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString());
	self.assertNotNull(operator);
	
	self.opts.purge();
	self.opts.addAssoc("ShowDamageCodes",true);
	cargoType1 := self.addCargoType(CargoID1,true);
	self.assertNotNull(cargoType1);
		
	self.assertEqualMsg(cargoType1.showDamageCodes,true,CargoID1 &amp; " cargo type Show damage is wrong");
	
	product1 := self.addProduct(ProductId1, operator, cargoType1);	
	self.assertNotNull(product1);
	
	self.opts.purge();
	self.opts.addAssoc("ShowDamageCodes",false);
	cargoType2 := self.addCargoType(CargoID2, false);
	self.assertNotNull(cargoType2);
	self.assertEqualMsg(cargoType2.showDamageCodes,false, CargoID2 &amp; " cargo type Show damage is wrong");
	
	create cargoTypes transient;
	
	cargoTypes.add(cargoType1);
	cargoTypes.add(cargoType2);
	
	self.deleteDamage(DamageID1);
	self.deleteDamage(DamageID2);
	self.deleteDamage(DamageID3);
	
	damageCount := 	CM_DamageDefinitionCode.instances.size();
	
	damageDef1 := self.addDamageDefinition(DamageID1, "Unit Test Busted up", cargoTypes);
	self.assertNotNull(damageDef1);
	
	damageDef2 := self.addDamageDefinition(DamageID2, "Unit Test Totally Munted", cargoTypes);
	self.assertNotNull(damageDef2);
	
	damageDef3 := self.addDamageDefinition(DamageID3, "Unit Test Completely Stuffed", cargoTypes);
	self.assertNotNull(damageDef3);	
	self.assertEqualMsg(CM_DamageDefinitionCode.instances.size(),damageCount + 3 , "dasmage count wrong after add") ;
	self.assertEqualMsg(cargoType2.allDamageDefinitionCodes.size,3,"cargotype2 add damage definitions didn't work");
	self.assertEqualMsg(cargoType1.allDamageDefinitionCodes.size,3,"cargotype1 add damage definitions didn't work");

	create machineTypes transient;
			
	self.addDamagePosition(DamagePosID1,"Inside cargo",cargoTypes,machineTypes);		
	damagePos1 := self.getRoot.allDamagePositionsByCode.getAtKey(DamagePosID1);
	self.assertNotNullMsg(damagePos1 ,"No " &amp; DamagePosID1);
	
	self.addDamagePosition(DamagePosID2,"Before cargo",cargoTypes,machineTypes);
	damagePos2 := self.getRoot.allDamagePositionsByCode.getAtKey(DamagePosID2);
	self.assertNotNullMsg(damagePos2,"No " &amp; DamagePosID2);
	
	self.addDamagePosition(DamagePosID3,"After cargo",cargoTypes,machineTypes);
	damagePos3 := self.getRoot.allDamagePositionsByCode.getAtKey(DamagePosID3);
	self.assertNotNullMsg( damagePos3,"No " &amp; DamagePosID3);
			
	beginTransaction;	
		cargoType1.setSystemProductType(product1);
	commitTransaction;
	
	product2 := self.addProduct(ProductId2, operator, cargoType2);
	self.assertNotNull(product2);
	
			
	bs1:=self.addBlockStack("UTBSNIK",200,null);
	self.assertNotNullMsg(bs1,"Blockstack is null");
	
	cargo1:=  self.addCargoAtLocation("UTNICK001",cargoType1,self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString),bs1.myLocationsController);	
	self.assertNotNull(cargo1);
	self.assertEqual(cargo1.myPrimaryActualLocation,bs1.myLocationsController);


	cargo2:=  self.addCargoAtLocation("UTNICK002",cargoType2,self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString),bs1.myLocationsController);
	self.assertNotNull(cargo2);
	self.assertEqual(cargo2.myPrimaryActualLocation,bs1.myLocationsController);	
	self.assertTrueMsg(cargo1.myCargoType.showDamageCodes,"Cargo1 showDamage is wrong");
	self.assertFalseMsg(cargo2.myCargoType.showDamageCodes,"Cargo2 showDamage is wrong");

	
	app.myPassport.setWarningsIgnored(true);
	self.addDamage(cargo1, damageDef1.code, damagePos1.code, null, 1, "Some remarks");
	damInst1 := cargo1.allDamageInstancesByTS.first();
	self.assertNotNullMsg(damInst1,"cargo1 is not damaged");	
	self.assertEqualMsg(damInst1.myDamageDefinition,damageDef1,"damInst damage Definition is not damageDef1");
	self.assertEqualMsg(damInst1.myDamagePosition,damagePos1,"damInst damage position is not damagePos1");	
	self.assertTrueMsg(cargoType1.allDamageDefinitionCodes.includes(damageDef1),"CargoType1 does not contain damageDef1");
	self.assertTrueMsg(cargoType1.allDamagePositions.includes(damagePos1),"CargoType1 does not contain damagePos1");
			
	pxyTI := app.createUpdateProxy(cargo1).CM_TrackedItem;
	pxyTI.setPropertyValue(CM_TrackedItem::totalWeight.name, 2000.Decimal);
	pxyDamInst :=  pxyTI.allDamageInstancesByPos.first();	
	pxyDamInst.setMyDamageDefinition(damageDef2);	
	pxyDamInst.setMyDamagePosition(damagePos2);
	// there's a new warning for damage on non-containerised cargo - need to ignore it
	app.myPassport.setWarningsIgnored(true);
	app.myTrxUA.trxUpdateTrackedItem(pxyTI, null, TI_UPDMODE_NORMAL, null, app.myPassport);
	
	self.opts.purge();
	self.opts.addAssoc("RemoveDamageCode",damageDef1);
	self.opts.addAssoc("RemoveDamagePos",damagePos1);
	self.updateCargoType(cargoType1);

	self.assertEqualMsg(cargo1.allDamageInstancesByPos.first.myDamageDefinition,damageDef2,"damInst damage Definition is not damageDef2");		
	self.assertEqualMsg(cargo1.allDamageInstancesByPos.first.myDamagePosition,damagePos2,"damInst damage position is not damagePos2");
	self.assertFalseMsg(cargoType1.allDamagePositions.includes(damagePos1),"CargoType1 contains damagePos1");		
	self.assertFalseMsg(cargoType1.allDamageDefinitionCodes.includes(damageDef1),"CargoType1 contains damageDef1");
	
	
epilog
	delete machineTypes;
	delete cargoTypes;
	delete pxyTI;
	delete pxyDraw;
	delete pxyCargoType;
end;</source>
    </JadeMethod>
    <JadeMethod name="tDataAccessGroups" id="7525d9f8-a27c-4090-9bef-a1a5e94ecd49">
        <source>tDataAccessGroups();

/*

Purpose:		Data Access Groups
				
				Carrier					- DONE
				ConsigneeConsignor		-
				Operator				-
				Organisation			-
				SubTerminal				-

Date			Who		Reason
30/06/2015		cnwmh5	Initial creation

*/

vars

	carrier						: CM_Carrier;
	consigneeOr					: CM_ConsigneeConsignor;
	operator					: CM_Operator;
	organisation				: CM_Organisation;
	subTerminal					: CM_SubTerminal;
	dataAccessController		: CM_DataAccessController;
	
	theSet						: CM_ObjectSetActual;
	emailAddresses				: CM_EmailEntityByTypeNameDict;
	configCMIF					: CMIF_ConfigOperator;
	codeGroups					: CM_CodeGroupsByTypeDict;	

begin

	/**********************************************************************************
	 * Carrier Data Access Group
	 **********************************************************************************/
	
	
	self.deleteDataAccessController("UTMDHCARDA", CM_Carrier.name);
	
	create emailAddresses transient;
	carrier := self.addCarrier("UTMHCAR2", "Michael's UT Carrier2", emailAddresses, false, false, true, null);
	self.assertNotNull(carrier);

	create theSet transient;
	theSet.add(carrier);
	
	app.myTrxCA.trxCreateDataAccessController("UTMDHCARDA", CM_Carrier, theSet, false, true, dataAccessController, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertNotNull(dataAccessController);
	
	theSet.clear();
	dataAccessController.allObjects.copy(theSet);
	carrier := self.addCarrier("UTMHCAR3", "Michael's UT Carrier3", emailAddresses, false, false, true, null);
	self.assertNotNull(carrier);
	theSet.add(carrier);
	
	app.myTrxUA.trxUpdateDataAccessController(dataAccessController, theSet, dataAccessController.mustNotBeIncluded, 
		dataAccessController.includeIfNull, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertEqual(dataAccessController.allObjects.size, 2);
	
	/**********************************************************************************
	 * Consignee/Consignor Data Access Group
	 **********************************************************************************/
	
	
	self.deleteDataAccessController("UTMDHCCDA", CM_ConsigneeConsignor.name);
	
	consigneeOr := self.addConsigneeConsignor("UTMC2", "Michael's Consignee/or 2", true, false, false);
	self.assertNotNull(consigneeOr);
	
	theSet.clear();
	theSet.add(consigneeOr);
	
	app.myTrxCA.trxCreateDataAccessController("UTMDHCCDA", CM_ConsigneeConsignor, theSet, false, true, dataAccessController, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertNotNull(dataAccessController);
	
	theSet.clear();
	dataAccessController.allObjects.copy(theSet);
	consigneeOr := self.addConsigneeConsignor("UTMC3", "Michael's Consignee/or 3", true, false, false);
	self.assertNotNull(consigneeOr);
	theSet.add(consigneeOr);
	
	app.myTrxUA.trxUpdateDataAccessController(dataAccessController, theSet, dataAccessController.mustNotBeIncluded, 
		dataAccessController.includeIfNull, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertEqual(dataAccessController.allObjects.size, 2);
	
	
	/**********************************************************************************
	 * Operator Data Access Group
	 **********************************************************************************/
	
	
	create configCMIF transient;
	create codeGroups transient;
	
	self.deleteDataAccessController("UTMDHOPDA", CM_Operator.name);
	
	self.deleteOperator("UTM3");
	self.deleteOperator("UTMD");
	self.deleteOperator("UTM2");
	operator := self.addOperator("UTM2", "Michael's Operator 2", false, 0, 0, null, false, false, false, false, false, false, 
		false, false, false, false, null, null, codeGroups, false, false, false, null, emailAddresses, null, configCMIF, false, false);
	self.assertNotNull(operator);
	
	theSet.clear();
	theSet.add(operator);
	
	app.myTrxCA.trxCreateDataAccessController("UTMDHOPDA", CM_Operator, theSet, false, true, dataAccessController, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertNotNull(dataAccessController);
	
	theSet.clear();
	dataAccessController.allObjects.copy(theSet);
	operator := self.addOperator("UTM3", "Michael's Operator 3", false, 0, 0, null, false, false, false, false, false, false, 
		false, false, false, false, null, null, codeGroups, false, false, false, null, emailAddresses, null, configCMIF, false, false);
	self.assertNotNull(operator);
	theSet.add(operator);
	
	app.myTrxUA.trxUpdateDataAccessController(dataAccessController, theSet, dataAccessController.mustNotBeIncluded, 
		dataAccessController.includeIfNull, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertEqual(dataAccessController.allObjects.size, 2);
	
	/**********************************************************************************
	 * Organisation Data Access Group
	 **********************************************************************************/
	
	
	self.deleteDataAccessController("UTMDHOGDA", CM_Organisation.name);
	self.deleteOrganisation("UTMDHOG3");
	
	organisation := self.addOrganisation("UTMDHOG2", true);
	self.assertNotNull(organisation);
	
	theSet.clear();
	theSet.add(organisation);
	
	app.myTrxCA.trxCreateDataAccessController("UTMDHOGDA", CM_Organisation, theSet, false, true, dataAccessController, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertNotNull(dataAccessController);
	
	theSet.clear();
	dataAccessController.allObjects.copy(theSet);
	organisation := self.addOrganisation("UTMDHOG3", true);
	self.assertNotNull(organisation);
	theSet.add(organisation);
	
	app.myTrxUA.trxUpdateDataAccessController(dataAccessController, theSet, dataAccessController.mustNotBeIncluded, 
		dataAccessController.includeIfNull, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertEqual(dataAccessController.allObjects.size, 2);
	
	/**********************************************************************************
	 * SubTerminal Data Access Group
	 **********************************************************************************/
	
	
	self.deleteDataAccessController("UTMDHSTDA", CM_SubTerminal.name);
	
	self.deleteSubTerminal("UTMDHST3");
	self.deleteSubTerminal("UTMDHST2");
	subTerminal := self.addSubTerminal("UTMDHST2", 1);
	self.assertNotNull(subTerminal);
	
	theSet.clear();
	theSet.add(subTerminal);
	
	app.myTrxCA.trxCreateDataAccessController("UTMDHSTDA", CM_SubTerminal, theSet, false, true, dataAccessController, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertNotNull(dataAccessController);
	
	theSet.clear();
	dataAccessController.allObjects.copy(theSet);
	subTerminal := self.addSubTerminal("UTMDHST3", 1);
	self.assertNotNull(subTerminal);
	theSet.add(subTerminal);
	
	app.myTrxUA.trxUpdateDataAccessController(dataAccessController, theSet, dataAccessController.mustNotBeIncluded, 
		dataAccessController.includeIfNull, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertEqual(dataAccessController.allObjects.size, 2);
	
epilog

	delete emailAddresses;
	delete theSet;
	delete configCMIF;
	delete codeGroups;

end;</source>
    </JadeMethod>
    <JadeMethod name="tDelayType" id="c2cf7c16-d609-4ee6-b88c-0ba295029bda">
        <source>tDelayType();

/*

Purpose:		Create / Update / Delete Delay Type

Date			Who		Reason
27/02/2014		cnwmh5	Initial creation

*/

vars

	delayType					: CM_DelayType;

begin

	delayType := self.addDelayType("UTMDHDelayType");
	self.assertNotNull(delayType);

	self.opts.purge();
	self.opts.addAssoc("RequiresMachine", true);
	self.opts.addAssoc("RequiresWorkpoint", true);
	self.updateDelayType(delayType);
	self.assertEqual(delayType.requiresMachine, true);
	self.assertEqual(delayType.requiresWorkpoint, true);
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="tDelayTypeGroup" id="64ba35b0-30ce-4d55-ab35-e01458453ec1">
        <source>tDelayTypeGroup();

/*

Purpose:		

Date			Who		Reason
09/10/2015		cnwmh5	Initial creation

*/

vars

	delayTypeGroup					: CM_DelayTypeGroup;
	pxyDelayTypeGroup				: CM_DelayTypeGroup;
	delayType						: CM_DelayType;
	
	theDelayTypes					: CM_DelayTypeSet;

begin

	delayType := self.addDelayType("UTMDHDT1");
	self.assertNotNull(delayType);
	
	delayTypeGroup := app.myRoot.allDelayTypeGroups["UTMDHDTG1"];
	if delayTypeGroup &lt;&gt; null then
		app.myTrxDA.trxDeleteDelayTypeGroup(delayTypeGroup, app.myPassport);
		self.assertNoTrxErrorsOrWarnings();
	endif;
	
	create theDelayTypes transient;
	create pxyDelayTypeGroup transient;
	pxyDelayTypeGroup.setProxy(app.myRoot, "UTMDHDTG1", theDelayTypes);
	
	app.myTrxCA.trxCreateDelayTypeGroup(pxyDelayTypeGroup, delayTypeGroup, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	delete pxyDelayTypeGroup;
	
	beginLoad;
	pxyDelayTypeGroup := delayTypeGroup.pxyCreateUpdateProxy();
	pxyDelayTypeGroup.allDelayTypes.add(delayType);
	pxyDelayTypeGroup.setPropertyValue("myRoot", delayTypeGroup.myRoot);
	endLoad;
	
	app.myTrxUA.trxUpdateDelayTypeGroup(pxyDelayTypeGroup, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	self.assertEqual(delayTypeGroup.allDelayTypes.size, 1);

epilog

	delete theDelayTypes;
	delete pxyDelayTypeGroup;

end;</source>
    </JadeMethod>
    <JadeMethod name="tDeliveryParty" id="f97a2da7-6d70-423c-b61f-4a271a4800a5">
        <source>tDeliveryParty();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 June 2022	jlier1	Initial creation 53678
02 Sept 2022	navkc1	ChangeRequest 54564(54372.020): Alternate address for Debtor
*/
constants
	DpCode = "UTDELPAR";
	DpName = "UT Delivery Party";
	AddressCode = "UTHOME";
	AddressDescr = "Unit Test Home Description";
	Address1 = "Unit Test address 1";
	Address2 = "Unit Test Adress 2";
	Address3 = "Unit Test Address 3";
	Region = "Unit Test Region";
	City = "Unit Test City";
	PostCode = "Unit Test PostCode";
	CountryCode = "NZL";
	DeliveryInstructions = "Unit Test delivery instructions to the front door, knock 3 times they ring the door bell";
vars
	pxyDeliveryParty,
	realDeliveryParty : CM_DeliveryParty;
	selectedTerminals : CM_TerminalSet;
	pxyAddress : CM_Address;
	countryCode : String;
begin

	realDeliveryParty:=app.myRoot.allDeliveryParties[DpCode];
	if realDeliveryParty &lt;&gt; null then
		beginTransaction;
		delete realDeliveryParty;
		commitTransaction;
	endif;

	create selectedTerminals transient;
	selectedTerminals.add(self.getTerminal());
	
	create pxyDeliveryParty transient;
	
	pxyDeliveryParty.setProxy(DpCode,DpName,false,selectedTerminals);
	self.assertEqual(pxyDeliveryParty.name,DpName);
	self.assertEqual(pxyDeliveryParty.code,DpCode);
	self.assertEqual(pxyDeliveryParty.nafe,false);
	self.assertEqual(pxyDeliveryParty.allTerminals.first, selectedTerminals.first);
	
	create pxyAddress transient;
	
	pxyAddress.setProxy(AddressCode,
							AddressDescr,
							Address1,
							Address2,
							Address3,
							Region,
							PostCode,
							CountryCode,
							City,
							"",				//navra1 - TFS 57086 - 1st May 2023
							DeliveryInstructions,
							true,
							false,	// 02/09/22	navkc1	#54564(54372.020)
							null);
	
	pxyDeliveryParty.allAddresses.add(pxyAddress);
	
	self.assertEqual(pxyAddress.description,AddressDescr);
	self.assertEqual(pxyAddress.code,AddressCode);
	self.assertEqual(pxyAddress.addr1,Address1);
	self.assertEqual(pxyAddress.addr2,Address2);
	self.assertEqual(pxyAddress.addr3,Address3);
	self.assertEqual(pxyAddress.postCode,PostCode);
	self.assertEqual(pxyAddress.region,Region);
	self.assertEqual(pxyAddress.city,City);
	self.assertEqual(pxyAddress.countryCode,CountryCode);
	self.assertEqual(pxyAddress.deliveryInstructions,DeliveryInstructions);
	self.assertEqual(pxyDeliveryParty.allAddresses.first, pxyAddress);
							
							

	app.myTrxCA.trxCreateDeliveryParty(pxyDeliveryParty,realDeliveryParty,app.myPassport);
	self.assertNoTrxErrors();
	
	self.assertEqual(realDeliveryParty.code ,pxyDeliveryParty.code);
	self.assertEqual(realDeliveryParty.name, pxyDeliveryParty.name);
	self.assertEqual(realDeliveryParty.nafe,pxyDeliveryParty.nafe);
	self.assertEqual(realDeliveryParty.allTerminals.size,1);
	self.assertEqual(realDeliveryParty.allTerminals.first, pxyDeliveryParty.allTerminals.first);
	self.assertEqual(realDeliveryParty.allAddresses.size,1);
	
	self.assertEqual(realDeliveryParty.allAddresses.first.description,pxyAddress.description);
	self.assertEqual(realDeliveryParty.allAddresses.first.code,pxyAddress.code);
	self.assertEqual(realDeliveryParty.allAddresses.first.addr1,pxyAddress.addr1);
	self.assertEqual(realDeliveryParty.allAddresses.first.addr2,pxyAddress.addr2);
	self.assertEqual(realDeliveryParty.allAddresses.first.addr3,pxyAddress.addr3);
	self.assertEqual(realDeliveryParty.allAddresses.first.postCode,pxyAddress.postCode);
	self.assertEqual(realDeliveryParty.allAddresses.first.region,pxyAddress.region);
	self.assertEqual(realDeliveryParty.allAddresses.first.city,pxyAddress.city);
	self.assertEqual(realDeliveryParty.allAddresses.first.countryCode,pxyAddress.countryCode);
	self.assertEqual(realDeliveryParty.allAddresses.first.deliveryInstructions,pxyAddress.deliveryInstructions);
	//self.assertEqual(realDeliveryParty.allAddresses.first, pxyDeliveryParty.allAddresses.first);
	delete pxyDeliveryParty;
	
	beginLoad;
	pxyDeliveryParty:=realDeliveryParty.pxyCreateUpdateProxy();
	endLoad;
	
	self.assertNotNull(pxyDeliveryParty);
	self.assertEqual(pxyDeliveryParty.allAddresses.size, 1);
	pxyAddress:=pxyDeliveryParty.allAddresses.first;
	pxyAddress.setProxy(AddressCode,
								AddressDescr  &amp; " update",
								Address1 &amp; " update",
								Address2 &amp; " update",
								Address3 &amp; " update",
								Region  &amp; " update",
								PostCode  &amp; "-M",
								CountryCode,
								City  &amp; " update",
								"",				//navra1 - TFS 57086 - 1st May 2023
								DeliveryInstructions &amp; " update",
								true,
								false, 	// 02/09/22	navkc1	#54564(54372.020)
								null);
	
	
	app.myTrxUA.trxUpdateDeliveryParty(pxyDeliveryParty,app.myPassport);
	self.assertNoTrxErrors();
	
	self.assertEqual(realDeliveryParty.code ,pxyDeliveryParty.code);
	self.assertEqual(realDeliveryParty.name, pxyDeliveryParty.name);
	self.assertEqual(realDeliveryParty.nafe,pxyDeliveryParty.nafe);
	self.assertEqual(realDeliveryParty.allTerminals.size,1);
	self.assertEqual(realDeliveryParty.allTerminals.first, pxyDeliveryParty.allTerminals.first);
	self.assertEqual(realDeliveryParty.allAddresses.size,1);
	
	self.assertEqual(realDeliveryParty.allAddresses.first.description,AddressDescr  &amp; " update");
	self.assertEqual(realDeliveryParty.allAddresses.first.code,AddressCode);
	self.assertEqual(realDeliveryParty.allAddresses.first.addr1,Address1 &amp; " update");
	self.assertEqual(realDeliveryParty.allAddresses.first.addr2,Address2 &amp; " update");
	self.assertEqual(realDeliveryParty.allAddresses.first.addr3,Address3 &amp; " update" );
	self.assertEqual(realDeliveryParty.allAddresses.first.postCode,PostCode  &amp; "-M");
	self.assertEqual(realDeliveryParty.allAddresses.first.region,Region  &amp; " update");
	self.assertEqual(realDeliveryParty.allAddresses.first.city,City  &amp; " update");
	self.assertEqual(realDeliveryParty.allAddresses.first.countryCode,pxyAddress.countryCode);
	self.assertEqual(realDeliveryParty.allAddresses.first.deliveryInstructions,DeliveryInstructions &amp; " update");
	//self.assertEqual(realDeliveryParty.allAddresses.first, pxyDeliveryParty.allAddresses.first);
	delete pxyDeliveryParty;
	
	app.myTrxDA.trxDeleteDeliveryParty(realDeliveryParty,app.myPassport);
	self.assertNoTrxErrors();
	
	
	
epilog
	delete pxyDeliveryParty;
	delete selectedTerminals;
end;</source>
    </JadeMethod>
    <JadeMethod name="tDeliveryRelReason" id="341e637f-ea28-41ec-83e7-289f4055188e">
        <source>tDeliveryRelReason();

/*

Purpose:		

Date			Who		Reason
12/10/2015		cnwmh5	Initial creation

*/

vars

	deliveryRelReason				: CM_DeliveryReleaseReason;
	pxyDeliveryRelReason			: CM_DeliveryReleaseReason;
	
	desc							: String;

begin

	deliveryRelReason := app.myRoot.allDeliveryReasonselReasons[666];
	if deliveryRelReason &lt;&gt; null then
		app.myTrxDA.trxDeleteDeliveryRelReason(deliveryRelReason, app.myPassport);
		self.assertNoTrxErrorsOrWarnings();
	endif;
	
	create pxyDeliveryRelReason transient;
	pxyDeliveryRelReason.setProxy(666, "Michael's Deliv Reason");
	app.myTrxCA.trxCreateDeliveryRelReason(pxyDeliveryRelReason, deliveryRelReason, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	delete pxyDeliveryRelReason;
	
	desc := deliveryRelReason.description &amp; " - Chg";
	
	beginLoad;
	pxyDeliveryRelReason := deliveryRelReason.pxyCreateUpdateProxy();
	endLoad;
	
	pxyDeliveryRelReason.setPropertyValue("description", desc);
	app.myTrxUA.trxUpdateDeliveryReleaseReason(pxyDeliveryRelReason, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertEqual(deliveryRelReason.description, desc);	

epilog

	delete pxyDeliveryRelReason;

end;</source>
    </JadeMethod>
    <JadeMethod name="tEmailAddress" id="931a78e7-b8e9-4770-a7c0-60ce259993a7">
        <source>tEmailAddress();

/*

Purpose:		Create / Update / Delete email address

Date			Who		Reason
19/02/2014		cnwmh5	Initial creation

*/

vars

	emailAddress				: CM_EmailAddress2;

begin

	self.deleteEmailAddress("MDH Unit Test 2", app.getBitbucketEmailAddress2());

	// delete / add email address
	emailAddress := self.addEmailAddress("MDH Unit Test", app.getBitbucketEmailAddress2());
	self.assertNotNull(emailAddress);
	
	// update email address
	self.opts.purge();
	self.opts.addAssoc("Name", "MDH Unit Test 2");
	self.updateEmailAddress(emailAddress);
	self.assertEqual(emailAddress.name, "MDH Unit Test 2");

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="tEmailGroup" id="be3dbffb-9853-4ab9-acd3-e97c2c51a068">
        <source>tEmailGroup();

/*

Purpose:		

Date			Who		Reason
22/06/2015		cnwmh5	Initial creation

*/

vars

	emailGroup						: CM_EmailGroup;
	pxyEmailGroup					: CM_EmailGroup;
	emailAddress					: CM_EmailAddress2;
	
	allSelected						: CM_EmailAddress2ByNameDict;
	
begin

	emailGroup := app.myRoot.allEmailEntities[2, "UT Email Group MDH"].CM_EmailGroup;
	if emailGroup &lt;&gt; null then
		app.myTrxDA.trxDeleteEmailGroup(emailGroup, app.myPassport);
		self.assertNoTrxErrorsOrWarnings();
	endif;
	
	create allSelected transient;
	
	create pxyEmailGroup transient;
	pxyEmailGroup.setProxyForEmailGroup("UT Email Group MDH", allSelected);
	
	app.myTrxCA.trxCreateEmailGroup(pxyEmailGroup, emailGroup, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertNotNull(emailGroup);

	delete pxyEmailGroup;
	
	beginLoad;
	pxyEmailGroup := emailGroup.pxyCreateUpdateProxy();
	endLoad;
	
	// delete / add email address
	emailAddress := self.addEmailAddress("MDH Unit Test 2", app.getBitbucketEmailAddress2());
	self.assertNotNull(emailAddress);
	
	// update email address
	self.opts.purge();
	self.opts.addAssoc("Name", "MDH Unit Test 2");
	self.updateEmailAddress(emailAddress);
	self.assertEqual(emailAddress.name, "MDH Unit Test 2");
	
	allSelected.add(emailAddress);
	allSelected.copy(pxyEmailGroup.allEmailAddresses);
	
	app.myTrxUA.trxUpdateEmailGroup(pxyEmailGroup, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertEqual(emailGroup.allEmailAddresses.size, 1);
	
epilog

	delete allSelected;
	delete pxyEmailGroup;

end;</source>
    </JadeMethod>
    <JadeMethod name="tEventStreamDataSelection" id="8a35a5d4-5a31-4ce9-99e1-f5839fead6d6">
        <source>tEventStreamDataSelection();
/*

Purpose:			The data selected by the 'EventStream' is governed by the 'CM_EventStreamEventType'
					objects for the whole system, so this test relies on no-one dicking with the system
					wide set up of these objects.

Parameters:			

Return Value:		

Date		Who		Reason
06 July 2020	jlgndl1	Initial creation TFS 49590
14 July 2020	NDL	Extended for HMS_Transactions
31 Oct  2022 navcs2 54621
*/

constants
	
	DefName			: String = "UT_EventStreamData";
	DefURL			: String = "fake.url.com";
	DefEmail		: String = "fakeEmail@jadelogistics.com";
	DefAuth			: String = "Auth";
	
vars

	shouldPushObject : Boolean;
	obj : CM_Object;
	esDefinition : CM_EventStreamDefinition;
	esDefinitionDict : CM_EventStreamDefinitionDict;
	
	iter : Iterator;
	audit : CM_AuditObject;
	count : Integer;
	subClasses : ClassNDict;
	subClass : Class;
	eventTrx : CM_EventTransaction;
	tiTrx : CM_TITransaction;
	hmsTrx : HMS_Transaction;
	
	auditConfigs : CM_AuditConfigDictByClassName;
	auditConfig : CM_AuditConfig;
	selectedAudits : CM_ObjectSetActual;
	eventTypes : CM_EventTypeSet;
	eventType : CM_EventType;
	selectedEvents : CM_ObjectSetActual;
	tiTransTypes : CM_TransactionTypeSet;
	transType : CM_TransactionType;
	selectedTiTrans : CM_ObjectSetActual;
	hmsTransTypes : CM_TransactionTypeSet;
	selectedHMSTrans : CM_ObjectSetActual;
	
	realEventStreamDef : CM_EventStreamDefinition;
	pxyEventStreamDef : CM_EventStreamDefinition;
	pxyESEventTypes : CM_EventStreamEventTypeDict;
	pxyESEventType : CM_EventStreamEventType;

begin

	//clean up from previous run if required
	realEventStreamDef := CM_PushEventsRoot.firstInstance.allEventStreamDefinitions[DefName];
	if realEventStreamDef &lt;&gt; null then
		app.myTrxDA.trxDeleteEventStreamDef(realEventStreamDef, app.myPassport);
	endif;

	//set up for this run
	create esDefinitionDict transient;
	foreach esDefinition in CM_EventStreamDefinition.instances do
		if esDefinition.isActive then
			esDefinitionDict.add( esDefinition );
		endif;
	endforeach;
	//de-activate all Event Stream Definitions.
	foreach esDefinition in esDefinitionDict do
		beginTransaction;
		esDefinition.setPropertyValue( CM_EventStreamDefinition::isActive.name, false );
		commitTransaction;
	endforeach;
	
	shouldPushObject := app.myRoot.shouldPushObject( obj );
	self.assertTrueMsg( not shouldPushObject, "Null object, should not want to be pushed!" );
	
	//Attempt to push the last 10 audit objects with no active EventStreamEventDefinitions in the system
	create auditConfigs transient;
	create selectedAudits transient;
	iter := CM_AuditObject.instances.createIterator;
	while iter.back( audit ) do
		auditConfig := audit.myAuditConfig;
		auditConfigs.addNoDuplicates( auditConfig, false );
		count := count + 1;
		if count &gt; 10 then
			break;
		endif;
		selectedAudits.add( audit );
		shouldPushObject := app.myRoot.shouldPushObject( audit );
		self.assertTrueMsg( not shouldPushObject, "Audit object [" &amp; count.String &amp; "], should not want to be pushed - nothing active!" );
	endwhile;
	
	//Attempt to push the last 10 events for each of the event classes with no active EventStreamEventDefinitions in the system
	create eventTypes transient;
	create selectedEvents transient;
	create subClasses transient;
	CM_EventTransaction.getAllSubclassesAnywhere(subClasses);
	foreach subClass in subClasses do
		delete iter;
		count := 0;
		iter := subClass.instances.createIterator;
		while iter.back( eventTrx ) do
			eventType := eventTrx.myEventType;
			eventTypes.addNoDuplicates( eventType, false );
			count := count + 1;
			if count &gt; 10 then
				break;
			endif;
			selectedEvents.add(eventTrx);
			shouldPushObject := app.myRoot.shouldPushObject( eventTrx );
			if shouldPushObject then
				write "jlirs1 "&amp;class.name&amp;'::'&amp;method.name&amp;' 118 '&amp;eventTrx.String&amp;' '&amp;eventTrx.myTerminal.String&amp;' '&amp;shouldPushObject.String;
			endif;
			self.assertTrueMsg( not shouldPushObject, subClass.name &amp; " object [" &amp; count.String &amp; "], should not want to be pushed - nothing active!" );
		endwhile;
	endforeach;
	
	//Attempt to push the last 10 ti transactions for each of the ti transaction classes with no active EventStreamEventDefinitions in the system
	create tiTransTypes transient;
	create selectedTiTrans transient;
	subClasses.clear();
	CM_TITransaction.getAllSubclassesAnywhere(subClasses);
	foreach subClass in subClasses do
		delete iter;
		count := 0;
		iter := subClass.instances.createIterator;
		while iter.back( tiTrx ) do
			transType := tiTrx.getTransactionType;
			tiTransTypes.addNoDuplicates( transType, false );
			count := count + 1;
			if count &gt; 10 then
				break;
			endif;
			selectedTiTrans.add( tiTrx );
			shouldPushObject := app.myRoot.shouldPushObject( tiTrx );
			self.assertTrueMsg( not shouldPushObject, subClass.name &amp; " object [" &amp; count.String &amp; "], should not want to be pushed - nothing active!" );
		endwhile;
	endforeach;
	
	//Attempt to push the last 10 hms transactions for each of the hms transaction classes with no active EventStreamEventDefinitions in the system
	create hmsTransTypes transient;
	create selectedHMSTrans transient;
	subClasses.clear();
	HMS_Transaction.getAllSubclassesAnywhere(subClasses);
	foreach subClass in subClasses do
		delete iter;
		count := 0;
		iter := subClass.instances.createIterator;
		while iter.back( hmsTrx ) do
			transType := hmsTrx.getTransactionType;
			hmsTransTypes.addNoDuplicates( transType, false );
			count := count + 1;
			if count &gt; 10 then
				break;
			endif;
			selectedHMSTrans.add( hmsTrx );
			shouldPushObject := app.myRoot.shouldPushObject( hmsTrx );
			self.assertTrueMsg( not shouldPushObject, subClass.name &amp; " object [" &amp; count.String &amp; "], should not want to be pushed - nothing active!" );
		endwhile;
	endforeach;
	
	//Attempt to push a tracked item directly (not a valid object to push) with no active EventStreamEventDefinitions in the system
	shouldPushObject := app.myRoot.shouldPushObject( CM_TrackedItem.lastInstance );
	self.assertTrueMsg( not shouldPushObject, "CM_TrackedItem.lastInstance, should not want to be pushed - nothing active! (and not a valid class to push)" );
	
	//Attempt to push a vehicle visit record directly (not a valid object to push) with no active EventStreamEventDefinitions in the system
	shouldPushObject := app.myRoot.shouldPushObject( CM_VehicleVisitRecord.lastInstance );
	self.assertTrueMsg( not shouldPushObject, "CM_VehicleVisitRecord.lastInstance, should not want to be pushed - nothing active! (and not a valid class to push)" );
	
	//Now add an Event Stream Definition that is for all of the types found just above and make it active
	create pxyESEventTypes transient;
	foreach auditConfig in auditConfigs do
		create pxyESEventType transient;
		pxyESEventType.setProxy(auditConfig.getDescription &amp; " Created", CM_EventStreamEventType.EVENT_TYPE_AUDIT, auditConfig, AuditCreated);
		pxyESEventTypes.add(pxyESEventType);
		create pxyESEventType transient;
		pxyESEventType.setProxy(auditConfig.getDescription &amp; " Updated", CM_EventStreamEventType.EVENT_TYPE_AUDIT, auditConfig, AuditUpdated);
		pxyESEventTypes.add(pxyESEventType);
		create pxyESEventType transient;
		pxyESEventType.setProxy(auditConfig.getDescription &amp; " Deleted", CM_EventStreamEventType.EVENT_TYPE_AUDIT, auditConfig, AuditDeleted);
		pxyESEventTypes.add(pxyESEventType);
	endforeach;
	foreach eventType in eventTypes do
		create pxyESEventType transient;
		pxyESEventType.setProxy( eventType.name, CM_EventStreamEventType.EVENT_TYPE_EVENT, eventType, eventType.type );
		pxyESEventTypes.add( pxyESEventType );
	endforeach;
	foreach transType in tiTransTypes do
		create pxyESEventType transient;
		pxyESEventType.setProxy(transType.description, CM_EventStreamEventType.EVENT_TYPE_TRANSACTION, transType, 0);
		pxyESEventTypes.add(pxyESEventType);
	endforeach;
	foreach transType in hmsTransTypes do
		create pxyESEventType transient;
		pxyESEventType.setProxy(transType.description, CM_EventStreamEventType.EVENT_TYPE_HMS, transType, 0);
		pxyESEventTypes.add(pxyESEventType);
	endforeach;
	
	create pxyEventStreamDef transient;
	pxyEventStreamDef.setProxy(DefName, DefURL, true, 5, DefEmail, DefAuth);
	
	app.myTrxCA.trxCreateEventStreamDef(pxyEventStreamDef, realEventStreamDef, pxyESEventTypes, app.myPassport);
	self.assertTrueMsg( realEventStreamDef &lt;&gt; null, "Event Stream Def failed to create " &amp; app.myPassport.getErrorsAndWarningsAsString );
	
	//Try the tracked item again when we have an active def (still an invalid object type to push)
	shouldPushObject := app.myRoot.shouldPushObject( CM_TrackedItem.lastInstance );
	self.assertTrueMsg( not shouldPushObject, "CM_TrackedItem.lastInstance, should still not want to be pushed - not a valid class to push" );
	
	//Try the vehicle visit record again when we have an active def (still an invalid object type to push)
	shouldPushObject := app.myRoot.shouldPushObject( CM_VehicleVisitRecord.lastInstance );
	self.assertTrueMsg( not shouldPushObject, "CM_VehicleVisitRecord.lastInstance, should still not want to be pushed - not a valid class to push" );
	
	//Try and push all the objects we had previously, but this time with a valid def that is active.
	foreach obj in selectedAudits do
		shouldPushObject := app.myRoot.shouldPushObject( obj );
		self.assertTrueMsg( shouldPushObject, "Audit object [" &amp; obj.String &amp; "], should now want to be pushed - included and active" );
	endforeach;
	
	foreach obj in selectedEvents do
		shouldPushObject := app.myRoot.shouldPushObject( obj );
		eventTrx := obj.CM_EventTransaction;
		if not shouldPushObject then
			write "jlirs1 "&amp;class.name&amp;'::'&amp;method.name&amp;' 229 '&amp;eventTrx.String&amp;' '&amp;eventTrx.myTerminal.String&amp;' '&amp;shouldPushObject.String;
		endif;
		self.assertTrueMsg( shouldPushObject, "Event Trx object [" &amp; obj.String &amp; "], should now want to be pushed - included and active" );
	endforeach;
	
	// Only push the TI Transactions if the terminal is not null
	// 31 Oct  2022 navcs2 54621
	foreach obj in selectedTiTrans do
		shouldPushObject := app.myRoot.shouldPushObject( obj );
		if obj.getMyTerminal &lt;&gt; null then
			self.assertTrueMsg( shouldPushObject, "TI Transaction object [" &amp; obj.String &amp; "], should now want to be pushed - included and active" );
		endif;
	endforeach;
	
	// Only push the TI Transactions if the terminal is not null
	// 31 Oct  2022 navcs2 54621
	foreach obj in selectedHMSTrans do
		shouldPushObject := app.myRoot.shouldPushObject( obj );
		if obj.getMyTerminal &lt;&gt; null then
			self.assertTrueMsg( shouldPushObject, "TI Transaction object [" &amp; obj.String &amp; "], should now want to be pushed - included and active" );
		endif;
	endforeach;
	
	//All good, clean up
	realEventStreamDef := CM_PushEventsRoot.firstInstance.allEventStreamDefinitions[DefName];
	app.myTrxDA.trxDeleteEventStreamDef(realEventStreamDef, app.myPassport);

epilog

	//re-activate the Event Stream Definitions we de-activated.
	abortTransaction;
	if esDefinitionDict &lt;&gt; null and not esDefinitionDict.isEmpty then
		foreach esDefinition in esDefinitionDict do
			beginTransaction;
			esDefinition.setPropertyValue( CM_EventStreamDefinition::isActive.name, true );
			commitTransaction;
		endforeach;
	endif;
	
	if pxyESEventTypes &lt;&gt; null and pxyESEventTypes.isNotEmpty then
		pxyESEventTypes.purge( );
	endif;
	delete pxyESEventTypes;
	delete pxyEventStreamDef;

	delete esDefinitionDict;
	delete iter;
	delete subClasses;
	delete eventTypes;
	delete auditConfigs;
	delete tiTransTypes;
	delete selectedAudits;
	delete selectedEvents;
	delete selectedTiTrans;
	delete selectedHMSTrans;
	delete hmsTransTypes;

end;</source>
    </JadeMethod>
    <JadeMethod name="tEventStreamDataSelection2" id="77babd7c-ea80-468f-ba6c-ffee54e82054">
        <source>tEventStreamDataSelection2();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 July 2020	jlgndl1	Initial creation	TFS 49747

*/

constants
	
	DefName			: String = "UT_EventStreamData2";
	DefURL			: String = "fake.url.com";
	DefEmail		: String = "fakeEmail@jadelogistics.com";
	DefAuth			: String = "Auth";
	
	TrainCode : String = "TFS49747";
	WagonCode : String = "PK9747";
	RailAreaId : String = "UT_JRA5";
	TiID : String = "ESDS4974701";
	BS1 : String = "BS49747";
	
vars

	esDefinition : CM_EventStreamDefinition;
	esDefinitionDict : CM_EventStreamDefinitionDict;
	
	auditConfig : CM_AuditConfig;
	eventType : CM_EventType;
	transType : CM_TransactionType;

	realEventStreamDef : CM_EventStreamDefinition;
	pxyEventStreamDef : CM_EventStreamDefinition;
	pxyESEventTypes : CM_EventStreamEventTypeDict;
	pxyESEventType : CM_EventStreamEventType; 
	
	train: CM_Train;
	pxyTrain : CM_Train;
	railArea : CM_Rail;
	wagon : CM_Wagon;
	wagonClass : CM_WagonClass;
	allTrackedItems : CM_TIByIdDups;
	
	pxyMaster : CM_WagonMaster;
	wagonMaster : CM_WagonMaster;
	railLine : CM_RailLine;
	now : TimeStamp;
	trainSet : CM_TrainSet;
	ti : CM_TrackedItem;
	bs : CM_BlockStack;
	eventTrx : CM_EventTransaction;
	tiTrx : CM_TITransaction;
	audit : CM_AuditObject;
	shouldPushObject : Boolean;
	peCont : CM_PushEventsController;
	oldLoggingLevel	: Integer;
	
begin

	//clean up from previous run if required
	realEventStreamDef := CM_PushEventsRoot.firstInstance.allEventStreamDefinitions[DefName];
	if realEventStreamDef &lt;&gt; null then
		app.myTrxDA.trxDeleteEventStreamDef(realEventStreamDef, app.myPassport);
	endif;
	
	self.deleteTrain(TrainCode,null);
	wagonMaster := self.getRoot.allWagonMasters[WagonCode];
	if wagonMaster &lt;&gt; null then
		self.deleteWagonMasterAndWagons( wagonMaster );
	endif;
	self.deleteRailArea(RailAreaId);
	self.deleteTerminalArea( BS1 );
	
	
	
	//set up for this run
	create esDefinitionDict transient;
	foreach esDefinition in CM_EventStreamDefinition.instances do
		if esDefinition.isActive then
			esDefinitionDict.add( esDefinition );
		endif;
	endforeach;
	//de-activate all Event Stream Definitions.
	foreach esDefinition in esDefinitionDict do
		beginTransaction;
		esDefinition.setPropertyValue( CM_EventStreamDefinition::isActive.name, false );
		commitTransaction;
	endforeach;
	
	bs := self.addBlockStack( BS1, 3, 3 );
	
	train := self.addTrain(TrainCode,null);
	self.assertNotNullMsg(train, "For some reason couldn't create train");
	railArea := self.addRailArea(RailAreaId, 4, 5);
	self.assertNotNullMsg(railArea, "For some reason couldn't create rail area");
	railLine := railArea.allRailLinesByIndex.first;  //hope this works
	wagonClass := app.getMyRoot.allWagonClasses.getAtKey("PK");
	create pxyMaster transient;
	pxyMaster.setProxy(	WagonCode, wagonClass, CM_Carrier.firstInstance, 450, 60000, 15000 );
	pxyMaster.setPropogateChanges(false);
	app.myTrxCA.trxCreateWagonMaster( pxyMaster, wagonMaster, app.myPassport );
	create allTrackedItems transient;
	wagon := self.addWagonToTrainOption2(train, wagonMaster, allTrackedItems, false);
	self.assertNotNullMsg(wagon,"Couldn't create a wagon - " &amp; app.myPassport.getAllErrorsWarningsAsString);
	pxyTrain := app.createUpdateProxy(train).CM_Train;
	now := app.actualTimeServer;// 12 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	pxyTrain.setProxyDetails(now);
	self.ignoreTrxWarnings(true);
	app.myTrxUA.trxUpdateTrain(pxyTrain, false, app.myPassport);
	self.assertTrueMsg(app.myPassport.allErrorWarnings.isEmpty(), "Train Update Errors &gt;&gt;&gt; " &amp; app.myPassport.getAllErrorsWarningsAsString());
	railLine.switchPositions(wagon, 01);	
	self.assertTrueMsg(app.myPassport.allErrorWarnings.isEmpty(), "Train Switch Errors &gt;&gt;&gt; " &amp; app.myPassport.getAllErrorsWarningsAsString());
	app.myTrxUA.trxUpdateWagonConfirmTrain(null, true, train, true, app.myPassport);  //in
	self.assertTrueMsg(app.myPassport.allErrorWarnings.isEmpty(), "Train Confirm IN Errors &gt;&gt;&gt; " &amp; app.myPassport.getAllErrorsWarningsAsString());
	
	
	ti := self.createContainer(TiID, "2200", "MT", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString), false);
	self.move(ti, bs.myLocationsController);
	
	app.myTrxUA.trxUpdateWagonConfirmTrain(null, false, train, true, app.myPassport);  //out
	self.assertTrueMsg(app.myPassport.allErrorWarnings.isEmpty(), "Train Confirm OUT Errors &gt;&gt;&gt; " &amp; app.myPassport.getAllErrorsWarningsAsString());
	create trainSet transient;
	trainSet.add(train);
	app.myTrxUA.trxUpdateTrainsDeparture(trainSet, app.myPassport); 
	self.assertTrueMsg(app.myPassport.allErrorWarnings.isEmpty(), "Train Depart Errors &gt;&gt;&gt; " &amp; app.myPassport.getAllErrorsWarningsAsString());
	

	//Now add an Event Stream Definition and make it active
	create pxyESEventTypes transient;
	
	create pxyESEventType transient;
	auditConfig := app.myRoot.allAuditConfigs["CM_Train"];	// Train Audit
	pxyESEventType.setProxy(auditConfig.getDescription &amp; " Updated", CM_EventStreamEventType.EVENT_TYPE_AUDIT, auditConfig, AuditUpdated);
	pxyESEventTypes.add(pxyESEventType);
	
	create pxyESEventType transient;
	eventType := app.myRoot.allEventTypesByType[23];	//Train Arrived
	pxyESEventType.setProxy( eventType.name, CM_EventStreamEventType.EVENT_TYPE_EVENT, eventType, eventType.type );
	pxyESEventTypes.add( pxyESEventType );
	
	create pxyESEventType transient;
	transType := app.myRoot.allTransactionTypes[5];	//Cargo Move
	pxyESEventType.setProxy(transType.description, CM_EventStreamEventType.EVENT_TYPE_TRANSACTION, transType, 0);
	pxyESEventTypes.add(pxyESEventType);
	
	create pxyEventStreamDef transient;
	pxyEventStreamDef.setProxy(DefName, DefURL, true, 5, DefEmail, DefAuth);
	
	app.myTrxCA.trxCreateEventStreamDef(pxyEventStreamDef, realEventStreamDef, pxyESEventTypes, app.myPassport);
	self.assertTrueMsg( realEventStreamDef &lt;&gt; null, "Event Stream Def failed to create " &amp; app.myPassport.getErrorsAndWarningsAsString );
	
	oldLoggingLevel := app.logLevel;
	app.changeLogLevel( LogTRACE );
	create peCont transient;
	peCont.setPropertyValue( CM_PushEventsController::eventLogFrequency.name, 1 );
	
	foreach tiTrx in ti.allTransactions do
		shouldPushObject := app.myRoot.shouldPushObject( tiTrx );
		self.assertTrueMsg( shouldPushObject = ( tiTrx.getTransactionType = transType ),"TI Transaction object [" &amp; tiTrx.String &amp; "], wrong shouldPushObject value!" );
		peCont.sendMsgWithParams( CM_PushEventsController::doCheckAndPushObject.name, tiTrx, null);
	endforeach;
	
	foreach eventTrx in train.allTransactions do
		shouldPushObject := app.myRoot.shouldPushObject( eventTrx );
		self.assertTrueMsg( shouldPushObject = ( eventTrx.myEventType = eventType ),"Event Transaction object [" &amp; eventTrx.String &amp; "], wrong shouldPushObject value!" );
		peCont.sendMsgWithParams( CM_PushEventsController::doCheckAndPushObject.name, eventTrx, null);
	endforeach;
	
	foreach audit in train.allAuditObjectsForClass do
		shouldPushObject := app.myRoot.shouldPushObject( audit );
		self.assertTrueMsg( shouldPushObject = ( audit.myAuditConfig = auditConfig and audit.type = AuditUpdated ),"Event Transaction object [" &amp; audit.String &amp; "], wrong shouldPushObject value!" );
		peCont.sendMsgWithParams( CM_PushEventsController::doCheckAndPushObject.name, audit, null);
	endforeach;
	
	//All good, clean up
	realEventStreamDef := CM_PushEventsRoot.firstInstance.allEventStreamDefinitions[DefName];
	app.myTrxDA.trxDeleteEventStreamDef(realEventStreamDef, app.myPassport);

epilog
	app.changeLogLevel(oldLoggingLevel);

	//re-activate the Event Stream Definitions we de-activated.
	abortTransaction;
	if esDefinitionDict &lt;&gt; null and not esDefinitionDict.isEmpty then
		foreach esDefinition in esDefinitionDict do
			beginTransaction;
			esDefinition.setPropertyValue( CM_EventStreamDefinition::isActive.name, true );
			commitTransaction;
		endforeach;
	endif;
	
	if pxyESEventTypes &lt;&gt; null and pxyESEventTypes.isNotEmpty then
		pxyESEventTypes.purge( );
	endif;
	delete pxyESEventTypes;
	delete pxyEventStreamDef;

	delete esDefinitionDict;
	
	delete pxyMaster;
	delete trainSet;
	delete pxyTrain;
	delete allTrackedItems;
	delete peCont;
	
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tEventStreamDefinition" id="6b4ab810-451f-495b-919d-f65fc8e70453">
        <source>tEventStreamDefinition();
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
24 January 2020		jlgzm1	Initial creation TFS 47920 Event Stream Admin JMT UI
06 Jul 2020	NDL	TFS 49590 changes

*/
constants
	DefName			: String = "UT_EventSteamDef";
	DefNameUpd		: String = "UT_EventSteamDefUpdated";
	DefURL			: String = "fake.url.com";
	DefEmail		: String = "fakeEmail@jadelogistics.com";
	DefAuth			: String = "Og==";
	DefUpdate		: String = "Updated";
	
	Event1			: String = "User login";
	Event2			: String = "User logoff";
	Transaction1	: String = "Received - Road";
	Transaction2	: String = "Released - Rail";
	Audit1			: String = "Debtor Updated";
	Audit2			: String = "Charge Created";
	
	
vars
	realEventStreamDef	: CM_EventStreamDefinition;
	pxyEventStreamDef	: CM_EventStreamDefinition;
	pxyESEventTypes		: CM_EventStreamEventTypeDict;
	pxyESEventType		: CM_EventStreamEventType;
	root 				: CM_PushEventsRoot;
	numDefs				: Integer;	// Original size of eventStreamDefiniton collection
	
	allEventTypesByName : CM_EventTypeByNameDict;
	eventType1 : CM_EventType;
	eventType2 : CM_EventType;
	trxType1 : CM_TransactionType;
	trxType2 : CM_TransactionType;
	auditConfig : CM_AuditConfig;
	auditConfig1 : CM_AuditConfig;
	auditConfigKeyType1 : Integer;
	auditConfig2 : CM_AuditConfig;
	auditConfigKeyType2 : Integer;
	
begin
	//#############################
	//Clean up after previous runs	
	//#############################
	
	root := CM_PushEventsRoot.firstInstance();
	self.assertNotNullMsg(root, "CM_PushEventsRoot");
	realEventStreamDef := root.allEventStreamDefinitions[DefName];
	if realEventStreamDef &lt;&gt; null then
		app.myTrxDA.trxDeleteEventStreamDef(realEventStreamDef, app.myPassport);
		self.assertNoTrxErrorsOrWarnings();
	endif;
	realEventStreamDef := root.allEventStreamDefinitions[DefNameUpd];
	if realEventStreamDef &lt;&gt; null then
		app.myTrxDA.trxDeleteEventStreamDef(realEventStreamDef, app.myPassport);
		self.assertNoTrxErrorsOrWarnings();
	endif;
	numDefs := root.allEventStreamDefinitions.size();
	
	create allEventTypesByName transient;
	app.myRoot.allEventTypesByType.copy( allEventTypesByName );
	eventType1 := allEventTypesByName.getAtKey( Event1 );
	eventType2 := allEventTypesByName.getAtKey( Event2 );
	trxType1 := app.myRoot.allTransactionTypesByDesc.getAtKey( Transaction1 );
	trxType2 := app.myRoot.allTransactionTypesByDesc.getAtKey( Transaction2 );
	
	foreach auditConfig in app.myRoot.allAuditConfigs discreteLock do
		if auditConfig.getDescription = "Debtor" then
			auditConfig1 := auditConfig;
			auditConfigKeyType1 := AuditUpdated;
			continue;
		elseif auditConfig.getDescription = "Charge" then
			auditConfig2 := auditConfig;
			auditConfigKeyType1 := AuditCreated;
			continue;
		endif;
	endforeach;
	
	//################################
	// Create New EventStreamDefiniton
	//################################

	create pxyESEventTypes transient;
	
	create pxyESEventType transient;
	pxyESEventType.setProxy(Event1, CM_EventStreamEventType.EVENT_TYPE_EVENT, eventType1, eventType1.type);
	pxyESEventTypes.add(pxyESEventType);
	
	create pxyESEventType transient;
	pxyESEventType.setProxy(Transaction1, CM_EventStreamEventType.EVENT_TYPE_TRANSACTION, trxType1, 0);
	pxyESEventTypes.add(pxyESEventType);
	
	create pxyESEventType transient;
	pxyESEventType.setProxy(Audit1, CM_EventStreamEventType.EVENT_TYPE_AUDIT, auditConfig1, auditConfigKeyType1);
	pxyESEventTypes.add(pxyESEventType);
	
	create pxyEventStreamDef transient;
	pxyEventStreamDef.setProxy(DefName, DefURL, false, 5, DefEmail, DefAuth);
	
	app.myTrxCA.trxCreateEventStreamDef(pxyEventStreamDef, realEventStreamDef, pxyESEventTypes, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertEqualMsg(numDefs+1, root.allEventStreamDefinitions.size, "AllEventStreamDefinitions size should have increased by one");
	realEventStreamDef := root.allEventStreamDefinitions[DefName];
	self.assertTrueMsg(realEventStreamDef&lt;&gt;null, "EventStreamDeiniton not found in collection");
	self.assertEqualMsg(realEventStreamDef.allEventStreamEventTypes.size(), 3, "EventStreamDef created with incorrect number of subscripbed events");
	
	delete pxyEventStreamDef;
	pxyESEventTypes.purge();
	
	
	
	//#############################
	// Create Invalid Definitions
	//##############################
	
	create pxyEventStreamDef transient;
	pxyEventStreamDef.setProxy("", DefURL, false, 5, DefEmail, DefAuth);
	app.myTrxCA.trxCreateEventStreamDef(pxyEventStreamDef, realEventStreamDef, pxyESEventTypes, app.myPassport);
	self.assertTrxErrorMsg(Input_required_field_name, "Expecting error for null name");
	
	pxyEventStreamDef.setProxy("This,isA:bad|name", DefURL, false, 5, DefEmail, DefAuth);
	app.myTrxCA.trxCreateEventStreamDef(pxyEventStreamDef, realEventStreamDef, pxyESEventTypes, app.myPassport);
	self.assertTrxErrorMsg(Field_contains_invalid_chars, "Expecting invalid character error");
	
	pxyEventStreamDef.setProxy(DefNameUpd, DefURL, false, 5, "bad@@email.com", DefAuth);
	app.myTrxCA.trxCreateEventStreamDef(pxyEventStreamDef, realEventStreamDef, pxyESEventTypes, app.myPassport);
	self.assertTrxErrorMsg(Email_addres_invali_double_sig, "Expecting invalid email error");

	pxyEventStreamDef.setProxy(DefName, DefURL, false, 5, DefEmail, DefAuth);
	app.myTrxCA.trxCreateEventStreamDef(pxyEventStreamDef, realEventStreamDef, pxyESEventTypes, app.myPassport);
	//self.assertTrxErrorMsg(DuplicateItem, "Expecting duplicate name error");
	//Expecting duplicate name error :  Expecti_duplica_name_error
	self.assertTrxErrorMsg(Event_stream_defini_alread_exi, "Expecting duplicate name error");
	delete pxyEventStreamDef;
	pxyESEventTypes.purge();
	
	
	//################################
	// Update EventStreamDefiniton
	//################################
	
	realEventStreamDef := root.allEventStreamDefinitions[DefName];
	self.assertNotNull(realEventStreamDef);
	
	create pxyESEventType transient;
	pxyESEventType.setProxy(Event1, CM_EventStreamEventType.EVENT_TYPE_EVENT, eventType1, eventType1.type);
	pxyESEventTypes.add(pxyESEventType);
	create pxyESEventType transient;
	pxyESEventType.setProxy(Event2, CM_EventStreamEventType.EVENT_TYPE_EVENT, eventType2, eventType2.type);
	pxyESEventTypes.add(pxyESEventType);
	
	create pxyESEventType transient;
	pxyESEventType.setProxy(Transaction1, CM_EventStreamEventType.EVENT_TYPE_TRANSACTION, trxType1, 0);
	pxyESEventTypes.add(pxyESEventType);
	create pxyESEventType transient;
	pxyESEventType.setProxy(Transaction2, CM_EventStreamEventType.EVENT_TYPE_TRANSACTION, trxType2, 0);
	pxyESEventTypes.add(pxyESEventType);
	
	create pxyESEventType transient;
	pxyESEventType.setProxy(Audit1, CM_EventStreamEventType.EVENT_TYPE_AUDIT, auditConfig1, auditConfigKeyType1);
	pxyESEventTypes.add(pxyESEventType);
	create pxyESEventType transient;
	pxyESEventType.setProxy(Audit2, CM_EventStreamEventType.EVENT_TYPE_AUDIT, auditConfig2, auditConfigKeyType2);
	pxyESEventTypes.add(pxyESEventType);
	
	pxyEventStreamDef :=  app.createUpdateProxy(realEventStreamDef).CM_EventStreamDefinition;
	pxyEventStreamDef.setProxy(DefName&amp;DefUpdate, DefURL&amp;DefUpdate, false, 3, DefEmail&amp;DefUpdate, DefAuth);
	
	app.myTrxUA.trxUpdateEventStreamDef(pxyEventStreamDef, pxyESEventTypes, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	assertEqualMsg(numDefs+1, root.allEventStreamDefinitions.size, "AllEventStreamDefinitions size should not have changed from an update");
	
	realEventStreamDef := root.allEventStreamDefinitions[DefName];
	self.assertNullMsg(realEventStreamDef, "EventStreamDeiniton should not have old name after update");
	
	realEventStreamDef := root.allEventStreamDefinitions[DefNameUpd];
	self.assertTrueMsg(realEventStreamDef&lt;&gt;null, "EventStreamDeiniton not found in collection");
	self.assertEqualMsg(realEventStreamDef.allEventStreamEventTypes.size(), 6, "EventStreamDef created with incorrect number of subscripbed events");
	
	
	//################################
	// Delete EventStreamDefiniton
	//################################
	
	realEventStreamDef := root.allEventStreamDefinitions[DefNameUpd];
	self.assertTrueMsg(realEventStreamDef &lt;&gt; null, "EventStreamDefinition not found in PushEventsRoot Collection");
	app.myTrxDA.trxDeleteEventStreamDef(realEventStreamDef, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	realEventStreamDef := root.allEventStreamDefinitions[DefNameUpd];
	self.assertNullMsg(realEventStreamDef, "EventStreamDeiniton not deleted");
	
	
	
epilog

	if pxyESEventTypes &lt;&gt; null and pxyESEventTypes.isNotEmpty then
		pxyESEventTypes.purge( );
	endif;
	delete pxyESEventTypes;
	delete pxyEventStreamDef;
	delete allEventTypesByName;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tFTPEntity" id="c8c33b73-f99c-47d0-8459-6c542027de6d">
        <source>tFTPEntity();
/*

Purpose:			

Date		Who		Reason
11 November 2015	cnwmk3	Initial creation
// 17 Sep 2019	jlgrs1	TFS 46087 JMT implement SFTP.
*/
constants
    DestinationDir                      : String = "IN";
	ID                                  : String = "UT_FTP";
	Passwrd                             : String = "Password";
	FTPServerName                       : String = "UT_Server";
	SourceDir                           : String = "OUT";
	UsrID                               : String = "UT_USER";
vars
    proxyFTPEntity                      : CM_FTPEntity;
	realFTPEntity                       : CM_FTPEntity;
	proxyUpdateFTPEntity                : CM_FTPEntity;
begin
    realFTPEntity := app.myRoot.allFTPEntities[ID];
	if realFTPEntity &lt;&gt; null then
        app.myTrxDA.trxDeleteFTPEntity(realFTPEntity, app.myPassport);
	endif;
	
    create proxyFTPEntity transient;
	proxyFTPEntity.setProxy(DestinationDir, ID, Passwrd, FTPServerName, SourceDir, UsrID, true, false, 0, 0, 0, 0, 0, true, true, null, null, null);
    app.myTrxCA.trxCreateFTPEntity(proxyFTPEntity, realFTPEntity, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	beginLoad;
	proxyUpdateFTPEntity := realFTPEntity.pxyCreateUpdateProxy();
	endLoad;
	proxyUpdateFTPEntity.setPropertyValue("userId", "NEW_USER");
	app.myTrxUA.trxUpdateFTPEntity(proxyUpdateFTPEntity, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
epilog
    delete proxyFTPEntity;
	delete proxyUpdateFTPEntity;
end;</source>
    </JadeMethod>
    <JadeMethod name="tGeneratorType" id="cb84c494-1297-40ee-9f4e-eb7f6e7a240d">
        <source>tGeneratorType();
// jlgmd1
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 July 2016	cnwrh7	Initial creation

*/

vars
	generatorType : CM_GeneratorType;
