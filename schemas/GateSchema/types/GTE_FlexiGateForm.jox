vars

begin
	return (self.txtDriverCode.text &lt;&gt; null or self.txtRegno.text &lt;&gt; null or self.cmbCarrier.listIndex &gt; 0 or self.cmbGateLanes.listIndex &gt; 0 or self.txtState.text &lt;&gt; null);
