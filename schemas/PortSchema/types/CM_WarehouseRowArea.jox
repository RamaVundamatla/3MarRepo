<Class name="CM_WarehouseRowArea" id="15a96b8b-4593-48c5-a47e-96ce1f2da5b0">
    <superclass name="CM_RowArea"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="location"/>
    <JadeMethod name="availableLocationsForType" id="2331f23c-61a0-4b54-8fbb-39ebde1a93ae">
        <source>availableLocationsForType(_cmifSearchTypes: CMIF_SearchTypes; _locationsArray: Collection input);
// ---------------------------------------------------------------------------
// Created:     12 August 2002 by cnwth2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

	rowController : CM_RowController;

begin

	foreach rowController in self.allRowControllersById do
		if rowController.doesAllowType(_cmifSearchTypes, false) then
			_locationsArray.add(rowController);
		endif;
	endforeach;

end;</source>
        <Parameter name="_cmifSearchTypes" type="CMIF_SearchTypes"/>
        <Parameter name="_locationsArray" type="Collection" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getLocationsController" id="c34d0a10-5d6c-41a3-815d-9341bd2a8b42">
        <source>getLocationsController(): CM_LocationsController;
//
//

vars

begin
	
	
	if self.allRowControllersById.size &lt;&gt; 1 then
		return inheritMethod();
	endif;
	//if the rowArea had just one row controller we'll allow a move to the area
	return self.allRowControllersById.first();
	
end;</source>
        <ReturnType type="CM_LocationsController"/>
    </JadeMethod>
    <JadeMethod name="hasLocationsControllers" id="0f1fb0db-bdbd-44c5-bded-34cf82ab1737">
        <source>hasLocationsControllers() : Boolean;
// --------------------------------------------------------------------------------
// Created:		11 April 2005 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return self.getLocationsController() &lt;&gt; null;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
