    <JadeMethod name="determineFutureMoveIndex" id="1f5ffa1c-e43d-4808-95a8-70931ca8361e">
        <source>determineFutureMoveIndex(moveType :  Integer) : Integer;
/*
 ------------------------------------------------------------------------
Created:			06 August 2002 by cnwdwq1
Purpose:			Figure out the array index based on the move type passed in
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/
vars

begin
	if moveType = TI_FutureMoveOverstow then
		return 1;	//INSERT at head of the list
	else
		return 0;	//This means add to end.
	endif;
end;</source>
        <Parameter name="moveType" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
