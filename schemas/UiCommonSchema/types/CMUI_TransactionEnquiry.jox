    <JadeMethod name="tblTrans_dblClick" id="acd56403-4faf-4a6c-a6cf-ef3bd3ac5c59">
        <controlMethod name="CM_DataTable::dblClick"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblTrans_dblClick(table: Table input) updating;
// -------------------------------------------
// Created 21 September 2005 by cnwdvb1
// -------------------------------------------
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 12/11/2019	jlgzm1		TFS 47428 hidden sort/row columns being displayed 
// ---------------------------------------------------------------------------
vars
	
	tbl 			: CM_DataTable;
	newSortColumn 	: Integer;
	entRow			: EntTableRow;
	sortKeyCol 		: Integer;			// TFS 47428
	rowKeyCol		: Integer;			// TFS 47428
	
begin

	
	self.doShowInformation();
	
	//08 Jun 2010	NDL	Par 23498
	if table.row = table.fixedRows then
	
		// Two sort columns on this one. Primary sort key is column 1 'SortKey' to define sections,
		//							default sort key column 2 'Row Key' carries original default order.
		// i.e. order loaded.
		// Double click resets second key only, so that the table sorts with teh sub sections.
		
		tbl := table.CM_DataTable;
		newSortColumn := tbl.column;
		// possible for sort/row keys to not be in columns 1 and 2
		sortKeyCol := tbl.getColumnByRowName(ETRow_SortKey);	// TFS 47428
		rowKeyCol := tbl.getColumnByRowName(ETRow_RowKey);		// TFS 47428
		
		if tbl.getCellText(sortKeyCol,newSortColumn) = app.getErrorString(DateStr) then
			newSortColumn := rowKeyCol;
		endif;
		
		tbl.sortColumn[1]	:= sortKeyCol;   
		tbl.sortAsc[1]		:= true;
		tbl.sortCased[1]	:= false;
		
		if tbl.sortColumn[2] &lt;&gt; newSortColumn then
			tbl.sortColumn[2]	:= newSortColumn;
			tbl.sortAsc[2] := true;
		else
			tbl.sortAsc[2] := not tbl.sortAsc[2];
		endif;
		
		//Sort column by it's input type
		//TFS41954 4/12/18 jlgzm1 - TimeStamps were being sorted as a String 
		entRow := tbl.allTblDataEntRows[newSortColumn];
		if entRow &lt;&gt; null then
			tbl.sortType[2] := tbl.convertInputTypeToSortType(entRow.inputType);
		endif;
		
		tbl.resort;
		
	endif;

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
