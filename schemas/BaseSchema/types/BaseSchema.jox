    <JadeMethod name="cnEcInitializePhoneMessage" id="6b748d43-4df1-4cdc-bac6-dafe709aa131">
        <updating/>
        <source>cnEcInitializePhoneMessage() updating;
// --------------------------------------------------------------------------------
// Created:		05 August 2000 by cnwdad1
//
// Purpose:		Finalize method for the Phone Message application.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	app.cnActivateKarmaControl(Cn_Fat_Client, null, null);
	on Exception do self.cnEcXHandler(exception) global;
	
	app.myCnCntrl.setDeadlockRetryLimit(10);
	self.cnEcInitializeBaseSchema();
	
	if app.getSkinCollection() &lt;&gt; null and app.getSkinCollection().cnEcIsNotEmpty() then
		app.setSkin(app.getSkinCollection()[1]);
	endif;
end;</source>
    </JadeMethod>
