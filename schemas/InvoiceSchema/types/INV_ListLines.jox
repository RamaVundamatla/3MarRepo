/*
Purpose:			

Date		Who		Reason
07 August 2023	navab1	BUG 59699
12 Sep 2023 	navhl20 ChangeRequest 59376: CPL - Invoice Generation Clocking (avg 25 secs)
04 Aug 2025		navbs1 	Story MTN-35314: MTN | Pagination - Invoice Line List
09 Sep 2025		navbs1 	Bug 35962: MTN | Invoice Lines Form displaying empty rows when rows are added from Selector form
*/

vars

begin
	inheritMethod();

	self.btnNew.bubbleHelp := app.getErrorString(Invoice_line_NEW); // ### TFS BUG 59699 07AUG2023 NAVAB1
