    <JadeMethod name="shiftEntry" id="f2a9663a-db61-4e48-a7b7-fb966201b661">
        <updating/>
        <source>shiftEntry(toPosition : CM_Object) updating;
/*
Shifts this entry to another R/T queue OR Entry.
If toPosition is an entry, we move current entry AHEAD of the passed in object.
NOTE: The toEntry maybe a completely different queue!
*/
vars
	toQueue 	: CM_RadioTelemetryQueue;
	toEntry		: CM_RTQueueEntry;
	task		: CM_RTQueueTask;
	terminal	: CM_Terminal;
	origQueue	: CM_RadioTelemetryQueue;
begin
	if toPosition.isKindOf(CM_RTQueueEntry) then
		toEntry := toPosition.CM_RTQueueEntry;
	elseif toPosition.isKindOf(CM_RadioTelemetryQueue) then
		toQueue := toPosition.CM_RadioTelemetryQueue;
	else
		//ERROR! Unknown type! We cannot shift this.
		app.setContinueCMExceptions(false);
		app.raiseCMException(ERR_QENTRY_NO_Q, null, null);
		return;
	endif;
	//---------------
	//Check the status of this Entry, can it be moved? //epr par 35115 23/10/14
	//---------------
/*	epr TFS 327231/3/17  we can do this now
	if status &lt;&gt; ENTRY_UNACTIONED and status &lt;&gt; ENTRY_USER_HELD and status &lt;&gt;  ENTRY_SYSTEM_HELD then
		app.setContinueCMExceptions(false);
		app.raiseCMException2(ERR_QENTRY_NOT_UA, id, self.myQueue.id, null, null);
		return;
	endif;*/
	origQueue := self.myQueue;
	exclusiveLock(origQueue);
	//-----------------
 	//Queue processing follows
	//-----------------
	if toQueue &lt;&gt; null then
		exclusiveLock(toQueue);
		//-------------
		//Do the move
		//-------------
		toQueue.addQueueEntry(self);
	endif;
	//-----------------
 	//Entry processing follows
	//-----------------
	if toEntry &lt;&gt; null then
		if toEntry.myQueue &lt;&gt; origQueue then
			//-------------
			//Different Queue, shift first.
			//-------------
			exclusiveLock(toEntry.myQueue);
			//-------------
			//Shift self to new Queue.
			//-------------
			toEntry.myQueue.addQueueEntry(self);
		endif;
		//--------------
		//Entry is now in correct queue.
		//Position self in array in correct position.
		//--------------
		toEntry.myQueue.shiftQueueEntry(self, toEntry);
	endif;
	//-----------------
	//Make sure our tasks are ok
	//-----------------
	// Trying to stop bad queue reference for over stow task. DVB 13/04/05
	foreach task in self.allTasks where not task.isOverstowTask do
		exclusiveLock(task);
		task.refreshTaskQueue();
	endforeach;
	
//	terminal := app.getMyTerminal();
	terminal := origQueue.getMyTerminal();
	if terminal &lt;&gt; null then
		self.causeEvent(terminal.getTerminalEvent(RTQueueEntry_Update_Event), false, origQueue);
		// epr par 25043 19/7/10
		app.myEventManager.createSingleObjInfoNoteEvt(origQueue , terminal.getTerminalEvent(Event_Update_Queue_Entry), self );

		
	endif;

end;</source>
        <Parameter name="toPosition" type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="shouldAuditProperty" id="7a84d4a1-88d1-49a7-a03d-911a1f56b2f2">
        <source>shouldAuditProperty(_rootClass: Class; _property: Property): Boolean protected;
/// ---------------------------------------------------------------------------
// Created:		November 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	propName	: String;
	
begin
	propName := _property.name;

	if propName = 'allTasks'  
	or propName = 'myJob' 
	or propName = 'myWorkListEntry'  then
	   	return false;
	endif;
	
	return inheritMethod(_rootClass, _property);
end;</source>
        <access>protected</access>
        <Parameter name="_rootClass" type="Class"/>
        <Parameter name="_property" type="Property"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="sortExceptionHandler" id="b7d42517-2dcc-41a5-93eb-499aee86590a">
        <source>sortExceptionHandler(_exObj : Exception): Integer;
//----------------------------------------------------------------
//	Created:	20 February 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin

	if _exObj.errorCode = 1310 then
		return Ex_Abort_Action;
	else
		return Ex_Pass_Back;
	endif;

end;</source>
        <Parameter name="_exObj" type="Exception"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="sortMyOverstowTasks" id="16d838e2-fcd2-4a82-a8ff-abe4caae1204">
        <updating/>
        <source>sortMyOverstowTasks(_controller : CMIF_MoveController) updating;

/*

Date		Who		Reason
17 Feb 2009	cnwkpd1	PAR #18743 - CCMS 1784 - Voice Directed Changes for Twin Lift
					Renamed as part of refactoring methods
26 May 2009	cnwkpd1	PAR #19662 - Allow for scenario where new overstow move created
					is a duplicate of an existing move (which has been manually moved back 
					during the processing of this queue entry).  Do this by allowing duplicates
					in the sort, and by ensuring completd tasks end up first in the list
					after the sort.
					
29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
*/

vars
	task			: CM_RTQueueTask;
	orgTi			: CM_TrackedItem;
	lc,tmpLC				: CM_LocationsController;
	index,
	row,
	col				: Integer;
	dyna			: DynaDictionary;
	sort			: CMIF_TaskSorter;
	workingFromFront: Boolean;
	iter			: Iterator;
	
begin
	if _controller.isForkLiftOverStow then
		workingFromFront := _controller.CMIF_AutoMovePlan.workingFromFront;
	else
		workingFromFront := true;
	endif;
	if self.allTasks.size &lt;= 2 then
		//--------------
		//Only 1 or 2 tasks here, probably pickup/setdown. Quit now
		//--------------
		return;
	endif;

	create dyna transient;
	dyna.setMembership(CMIF_TaskSorter);
	dyna.addMemberKey('rowPos', workingFromFront, true);
	dyna.addMemberKey('pos', true, true);
	dyna.addMemberKey('colPos', true, true);
	dyna.addMemberKey('taskType', false, true);
	dyna.endKeys(true);								// PAR #19662 - allow duplicates
	
	orgTi := self.myWorkListEntry.myTrackedItem;
	
	lc := orgTi.getPrimaryLocation(REAL_MODE);
	row := lc.CM_GridController.row;
	col	:= lc.CM_GridController.column;
	
	foreach task in self.allTasks do
		
		if task.ti = null then //cnwrd1  needs fixing further
			continue;
		endif;	
		
		index := lc.allTrackedItems.indexOf(task.ti);	
		if index = 0 then
			if _controller.isForkLiftOverStow  then
				lc		:= task.ti.getPrimaryLocation(REAL_MODE);
				index	:= lc.allTrackedItems.indexOf(task.ti);
				row		:= lc.CM_GridController.row;			
				col		:= lc.CM_GridController.column;
			else
				tmpLC:=task.ti.getPrimaryLocation(REAL_MODE);
				index	:= tmpLC.allTrackedItems.indexOf(task.ti);
				row		:= tmpLC.CM_GridController.row;			
				col		:= tmpLC.CM_GridController.column;
			//	app.raiseCMException2(TrackedItemNotOverStowing, task.ti.id,orgTi.id, null, null);
			//	return;
			endif;
		endif;
		create sort transient;
		sort.myRTTask := task;
		sort.pos := index;
		sort.rowPos := row;
		sort.colPos := col;
		sort.taskType := task.taskType;
		dyna.add(sort);
	endforeach;
		
	// ############################
	// clean out our existing tasks and repopulate in the new order
	// ############################
	index := self.allTasks.size;
	while index &gt; 0 do
		task := self.allTasks[index];
		task.setMyEntry(null);
		task.relatedTasks.clear;
		index := index -1;
	endwhile;
	
	// PAR #19662 - go through sorted list twice, once for completed tasks,
	// once for others
	iter := dyna.createIterator();
	while iter.next(sort) do
		if sort.myRTTask.status = TASK_COMPLETE then
			self.addTask(sort.myRTTask);
		endif;
	endwhile;
	
	iter.reset();
	while iter.next(sort) do
		if sort.myRTTask.status &lt;&gt; TASK_COMPLETE then
			self.addTask(sort.myRTTask);
		endif;
	endwhile;

	
epilog
	if dyna &lt;&gt; null then
		dyna.purge;
		delete dyna;
	endif;
	delete iter;
	
end;</source>
        <Parameter name="_controller" type="CMIF_MoveController"/>
    </JadeMethod>
    <JadeMethod name="statusString" id="1c683d58-cdfe-4324-9319-6e27dad5bf81">
        <methodInvocation>mapping</methodInvocation>
        <source>statusString(set: Boolean; value: String io) mapping;
//Returns a nice description for messages
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------------------
// 26/11/2012	cnwdap1		PAR #30762 CCMS QNS 2233 Just return "Held" for ENTRY_SYSTEM_HELD"
//22 Apr 201% NDL	Par 36014
vars

begin
	if set then
		app.raiseSetVirtualError(class.name, method.name);
		return;
	endif;
	if self.status = ENTRY_COMPLETE  then
		value := app.getErrorString(Complete);//"Complete";
	elseif self.status = ENTRY_ERROR  then
		value := app.getErrorString(Error);//"Error!";
	elseif self.status = ENTRY_USER_HELD  then
		value := app.getErrorString(Manually_held);
	elseif self.status = ENTRY_NULL  then
		value := app.getErrorString(Null);//"null";
	elseif self.status = ENTRY_SYSTEM_HELD  then
		//value := "System Held";						// PAR #30762
		value := app.getErrorString(System_held);								
	elseif self.status = ENTRY_UNACTIONED  then
		value := app.getErrorString(Unactioned);//"Unactioned";
	elseif self.status = ENTRY_WORKING  then
		value := app.getErrorString(Working);//"Working";
	else
		value := app.getErrorString(Unknown);//"Unknown!";
	endif;

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="value" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="switchJob" id="436cbc55-370d-4001-9d26-76d10d6d2d32">
        <updating/>
