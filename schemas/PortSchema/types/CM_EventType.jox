    <JadeMethod name="setProxy" id="9d590f14-7309-4a3f-aac1-202bcdf965be">
        <updating/>
        <source>setProxy(_type 		: Integer;
		_name,
		_descr,
 		_className	: String;
		_colour 	: Integer;
		_category	: Integer;	// 29 Oct 2009	NDL	Par 21519
		_root		: CM_Root;
		_amountDecimalPlaces : Integer;
		_isFromToDateTimeRequired : Boolean;
		_unitDescription : String) updating;
/*
----------   ----------  --------------------------------------------------
Created:	13 February 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	pxyInterestedWarning		: CM_InterestedWarning;
	pxyError 				: Object;
	errorCode			: Integer;
begin
	self.raiseExceptionIfNotTransient(method);
	
	self.type 			:= _type;
	self.name 			:= _name;
	self.description 	:= _descr;
	self.colour			:= _colour;
	self.category		:= _category;	// 29 Oct 2009	NDL	Par 21519
	self.myRoot 		:= _root;
	self.amountDecimalPlaces :=_amountDecimalPlaces; //epr par 36902 14/6/15
	self.isFromToDateTimeRequired := _isFromToDateTimeRequired;	//nds TFS 3047 13/01/17		
	self.unitDescription := _unitDescription;					//nds TFS 3047 13/01/17		
	if self.type &gt; EVT_MAX_JMT then
		if self.category = WARNING_EVENT then
			self.classNameToCreate := CMEVT_OverriddenWarning.name;
		elseif self.category = TRAIN_EVENT then	// 29 Oct 2009	NDL	Par 21519
			self.classNameToCreate := CMEVT_TrainTransaction.name;		
		endif;
	else
		self.classNameToCreate := _className;
	endif;
	
	
	
end;


</source>
        <Parameter name="_type" type="Integer"/>
        <Parameter name="_name" type="String"/>
        <Parameter name="_descr" type="String"/>
        <Parameter name="_className" type="String"/>
        <Parameter name="_colour" type="Integer"/>
        <Parameter name="_category" type="Integer"/>
        <Parameter name="_root" type="CM_Root"/>
        <Parameter name="_amountDecimalPlaces" type="Integer"/>
        <Parameter name="_isFromToDateTimeRequired" type="Boolean"/>
        <Parameter name="_unitDescription" type="String"/>
    </JadeMethod>
