    <JadeMethod name="checkData" id="102fb6db-79d2-4ef6-b99a-58920c7d7c3b">
        <updating/>
        <source>checkData():String updating, protected;

vars
	returnValue		: String;
	heightRequired	: Integer;
	numberOfLegends	: Integer;
	
begin
	if self.isInPainter() then
		numberOfLegends	:=	self.allGraphLegends.size();
		
		heightRequired	:=	(numberOfLegends + 1) * (self.graphLabelHeight + 2);
	
		if self.isShowTestData and numberOfLegends = 0 then
			self.setDefaultsInPainter();
		endif;
	
		if heightRequired &gt; self.height then
			returnValue	:=	"Too many Legends to display";
			return returnValue;
		endif;
	else
		if self.myGraph = null then
			returnValue	:=	"No associated graph";
			return returnValue;
		endif;		

		heightRequired	:=	(self.myGraph.allGraphLegends.size() + 1) * (self.graphLabelHeight + 2);
	
		if heightRequired &gt; self.height then
			returnValue := "Too many Legends to display";
			return returnValue;
		endif;
	endif;									

	return returnValue;
end;</source>
        <access>protected</access>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="createLegendLines" id="b3d3758a-d13a-4926-8de9-b721f75556ba">
        <updating/>
        <source>createLegendLines() updating, protected;

vars
	numberOfLegends		: Integer;
	position			: Integer;
	colorCount			: Integer;
	lineColor			: Integer;
	leftCoordinate		: Integer;
	rightCoordinate		: Integer;
	topCoordinate		: Integer;
	bottomCoordinate	: Integer;
	colorArrayObj		: IntegerArray;
	legendText			: String;
	
begin
	create colorArrayObj transient;
	
	if self.myGraph &lt;&gt; null then	
		numberOfLegends	:=	self.myGraph.allGraphLegends.size();
	else
		numberOfLegends	:=	self.allGraphLegends.size();
	endif;
	
	self.drawTextRotation := 0;
	
	if self.myGraph &lt;&gt; null then
		colorCount	:=	self.myGraph.allGraphColors.size(); 
		
		foreach position in 1 to colorCount do
			lineColor	:=	self.myGraph.allGraphColors[position]; 
			
			if (not colorArrayObj.includes(lineColor)) then
				colorArrayObj.add(lineColor);
			endif;
		endforeach;
	else
		if self.isShowTestData then
			colorArrayObj.add(Blue);
			colorArrayObj.add(Red);
			colorArrayObj.add(Green);
		endif;				
	endif;
	
	colorCount			:=	colorArrayObj.size();
	bottomCoordinate	:=	self.graphLabelHeight;
	
	foreach position in 1 to numberOfLegends do
		leftCoordinate		:=	3;
		rightCoordinate		:=	leftCoordinate + self.graphLabelHeight;
		topCoordinate		:=	bottomCoordinate + 2;
		bottomCoordinate	:=	topCoordinate + self.graphLabelHeight;		
		
		if position &lt;= colorCount then 
			lineColor	:=	colorArrayObj[position];
		else
			lineColor	:=	0;		
		endif;
		
		self.drawFillColor	:=	lineColor;		
		self.drawFilledRectangle(leftCoordinate, topCoordinate, rightCoordinate, bottomCoordinate, lineColor);
		
		if self.myGraph &lt;&gt; null then
			legendText	:=	self.myGraph.allGraphLegends[position];
		else
			legendText	:=	self.allGraphLegends[position];
		endif; 	
			
		self.drawTextAt(legendText, (self.graphLabelHeight * 2), topCoordinate, Black);
	endforeach;
epilog
	delete colorArrayObj;	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="drawGraph" id="61fe4c81-4fd6-4ab0-b664-c1718d9c4fe5">
        <updating/>
        <source>drawGraph() updating;

vars
	errorMessage	: String;
	
begin
	inheritMethod();
	
	errorMessage	:=	self.checkData();

	if errorMessage = null then
		self.autoRedraw	:=	true;
		self.createLegendLines();
	else
		self.doDataError(errorMessage);
	endif;		
end;</source>
    </JadeMethod>
    <JadeMethod name="myLegend" id="49767027-159a-4443-ab78-87bc3e6775ac">
        <methodInvocation>mapping</methodInvocation>
        <source>myLegend(set: Boolean; _value: CnEcGraphLegend io) mapping;
// --------------------------------------------------------------------------------
// Created:		07 January 2002 by cnwdad1
//
// Purpose:		Mapping method to raise an exception if an attempt is made to access
//				the legend reference from this legend.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
// adm 200509 Par 19207  change abstract exception class
begin
	if set then
		CnEcBaseSchemaException.raise_(CNEC_X_12006, "A graph legend cannot itself have a legend.");
	endif;
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="CnEcGraphLegend" usage="io"/>
    </JadeMethod>
    <JadeMethod name="setDefaultsInPainter" id="4c04b896-76f8-4007-bfdc-288be8dcf0d9">
        <updating/>
        <source>setDefaultsInPainter() updating, protected;

begin
	if self.graphTitle = null then
		self.graphTitle	:=	self.name &amp; " - Sample data";
	endif;
	
	self.allGraphLegends.add("Test Legend One");
	self.allGraphLegends.add("Test Legend Two");
	self.allGraphLegends.add("Test Legend Three");
	
	if self.height &lt; 50 then
		self.height	:=	50;
	endif;
	
	if self.width &lt; 100 then
		self.width	:=	100;
	endif;
	
	self.transparent	:=	false;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setGraph" id="6402ece2-9d8f-405d-ae80-7523f24b1ee1">
        <updating/>
        <source>setGraph(pGraphObj:CnEcGraph; pGraphTitle:String) updating;
// --------------------------------------------------------------------------------
// Created:		07 January 2002 by cnwdad1
//
// Purpose:		Sets a reference to the graph control which the legend is
//				associated to.
//
// Parameters:	pGraphObj - The legend's associated graph control.
//				pGraphTitle - The title of the graph control.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if pGraphTitle = null then
		self.graphTitle	:=	pGraphTitle;
	else
		self.graphTitle	:=	pGraphTitle &amp; " " &amp; $CNEC_GRAPH_LEGEND;
	endif;
	
	self.myGraph	:=	pGraphObj;
end;</source>
        <Parameter name="pGraphObj" type="CnEcGraph"/>
        <Parameter name="pGraphTitle" type="String"/>
    </JadeMethod>
