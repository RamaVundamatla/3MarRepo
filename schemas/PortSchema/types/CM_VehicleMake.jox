    <JadeMethod name="setProxy" id="4b5aec59-20e2-4b35-8db2-e96567b27c6b">
        <updating/>
        <source>setProxy(_make : String) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 January 2013	cnwmc5	Initial creation HAT 2189

*/

vars

begin
	self.raiseExceptionIfNotTransient(method);

	self.make 			:= _make;
	self.myDutyDocRoot 	:= app.myDutyDocRoot;
epilog

end;</source>
        <Parameter name="_make" type="String"/>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="228d2e44-5ab7-46cc-9d77-d1ada6110c99">
        <source>validateForCreate();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 January 2013	cnwmc5	Initial creation HAT 2189

*/

vars

begin
	if app.myDutyDocRoot.allVehicleMakes[self.make] &lt;&gt; null then 
		app.raiseCMException1(VB_DUPLICATED_ITEM, self.make, null, null);
		return;
	endif;
	
	validateMe();
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="f5632bf5-1f94-48c1-bac1-d1588b1b63c7">
