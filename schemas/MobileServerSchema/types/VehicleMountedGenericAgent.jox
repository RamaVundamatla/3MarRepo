    <JadeMethod name="checkDeviceID" id="dfd8516e-a98e-45fc-a05e-32e8feb04c30">
        <source>checkDeviceID(): Boolean  protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14 October 2010	cnwer1	Initial creation

*/

vars
	machineID : String;
	machine 	: CM_Machine;
begin

	// PAR #23022 - add in check for numeric device id
	if not self.myRTDevice.id.isInteger then
		machine := self.myRTDevice.getMachine();
		if machine &lt;&gt; null then
			machineID := machine.id;
		else
			machineID := self.myRTDevice.id;
		endif;
		app.raiseCMException1(ERR_MACH_NON_NUM_RT, machineID, null, null);
		return false;
	endif;

	return true;
epilog

end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="checkSendUpdateNote" id="1966c0ed-9382-4b81-9387-b261eaa4dfa9">
        <source>checkSendUpdateNote(_rtQueueEntry : CM_RTQueueEntry) : Boolean protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
07 December 2010	cnwer1	Initial creation

*/

vars
	invalidUserInfo,
	invalidDtoRTQueueEntry	: Boolean;
	currentQueueTask : CM_RTQueueTask;
	workingRTQueueEntry : CM_RTQueueEntry;
	dtoRTQueueEntry : DTO_RTQueueEntry;
	objectEdition : Integer;
begin

		
	invalidUserInfo:=false;
	on Exception do app.handleDeletedObject(exception,currentQueueTask,invalidUserInfo);
	on Exception do app.handleDeletedObject(exception,workingRTQueueEntry,invalidUserInfo);
	on Exception do app.handleDeletedObject(exception,dtoRTQueueEntry,invalidDtoRTQueueEntry); //cnwrd1 par 27652 1.6.2011
	
	
	//check if the rtQueueEntry is one we are working in which case
	//if the source of target has changed force an send
	
	foreach currentQueueTask in self.myMachine.allCurrentWorkingQueueTasks do
		if currentQueueTask.myEntry = _rtQueueEntry then
			return true;
		endif;
		
	endforeach;
	
	if invalidUserInfo then
		return true;
	endif;
	
	
	invalidUserInfo:=false;
	//epr par 26597 14/12/10 
	if not self.showingTaskList or not isBusy then
		//if its not a current task 
		dtoRTQueueEntry:=self.myMachQEntryTableSynchAgent.doFindDTOEntryByEntry(_rtQueueEntry);
		if dtoRTQueueEntry &lt;&gt; null then
			//7/3/2011 - noticed in handleDeleteObject exception handler changed want to resume next need to back sure the correct
			// varable is set now
			workingRTQueueEntry:=dtoRTQueueEntry.myRealQueueEntry.CM_RTQueueEntry;
			objectEdition:=workingRTQueueEntry.edition;
			if invalidUserInfo then
				return true;
			endif;
		endif;
	endif;

	
	workingRTQueueEntry:=null;
	invalidUserInfo:=false;
	invalidDtoRTQueueEntry := false; //cnwrd1 par 27652 1.6.2011
	dtoRTQueueEntry:=self.myVMInterface.getWorkingDTOEntry;
	if dtoRTQueueEntry &lt;&gt; null then
		workingRTQueueEntry:=dtoRTQueueEntry.myRealQueueEntry.CM_RTQueueEntry;
	endif;
	if workingRTQueueEntry &lt;&gt; null then
		objectEdition:=workingRTQueueEntry.edition;
	endif;

	if invalidUserInfo or invalidDtoRTQueueEntry then //cnwrd1 par 27652 1.6.2011
		return true;
	endif;
	if workingRTQueueEntry = _rtQueueEntry then
		return true;
	endif;
	
	invalidUserInfo:=false;
	invalidDtoRTQueueEntry := false; //cnwrd1 par 27652 1.6.2011
	dtoRTQueueEntry:=self.myVMInterface.getWorkingTwinDTOEntry;
	if dtoRTQueueEntry &lt;&gt; null then
		workingRTQueueEntry:=dtoRTQueueEntry.myRealQueueEntry.CM_RTQueueEntry;
	endif;
	if workingRTQueueEntry &lt;&gt; null then
		objectEdition:=workingRTQueueEntry.edition;
	endif;
	
	if invalidUserInfo or invalidDtoRTQueueEntry then //cnwrd1 par 27652 1.6.2011
		return true;
	endif;
	if workingRTQueueEntry = _rtQueueEntry then
		return true;
	endif;
				
	return false;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_rtQueueEntry" type="CM_RTQueueEntry"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="checkTruckSwap" id="c5cc72de-c146-44d4-9458-eb8474f56a57">
        <source>checkTruckSwap(_rtTask: CM_RTQueueTask input; _twinTask: CM_RTQueueTask input; _setdownLoc: String; _twinSetdownLoc: String) : Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
07 November 2013	cnwrd1	Initial creation

*/

vars
	setdownLoc,
	twinSetdownLoc : CM_LocationsController;
	theTerminal : CM_Terminal;
	result : Boolean;	
	foundHeight : Integer;
	newTruck : CM_Vehicle;
	newRoadJob : CM_RoadJob;
	newVehicleVisit : CM_VehicleVisitRecord;
	wle1, 
	wle2 		: CM_WorkListEntry;
	aRequest 	: CM_Request;
	aWle,
	swapWle1,
	swapWle2 : CM_WorkListEntry;	
begin
	

	// want to check if we are a truck release
	// and we have changed the target location of our move to another truck.
	
	if not _rtTask.myEntry.myJob.isKindOf(CM_RoadJob) then
		return true;
	endif;
	
	
	if _twinTask &lt;&gt; null then
		return true; //for now not supported.
	endif;
	// should be the same as the first task but 
	/*if not _twinTask.myEntry.myJob.isKindOf(CM_RoadJob) then
		return true;
	endif;*/
	
	theTerminal := self.myMachine.myTerminal;
	
	theTerminal.findLocationFromString(_setdownLoc,true,setdownLoc,foundHeight);

	if setdownLoc = null then
		return true;
	endif;
	
	if setdownLoc = _rtTask.targetLocation then
		return true; // setting down in the same place as it should.
	endif;
	
	if not setdownLoc.isKindOf(CM_VehicleController) then
		return true; //moving to something not a truck 
	endif;
	
	
	// then we need to swap tasks/wles/requests betwen trucks
	
	newTruck := setdownLoc.CM_VehicleController.vehicle;
	newRoadJob := newTruck.allRoadJobs.first.CM_RoadJob; // should be only 1 job for a truck..
	
	//app.showErrorWarningDialog('Road Ops', app.myPassport, ErrWarnMode_Delete + ErrWarnMode_CanAckWarnings);


	
	wle1 := _rtTask.myEntry.myWorkListEntry;
	
	
	if newRoadJob = null then
		return true;
	endif;
	
	foreach aRequest in newRoadJob.allRequests do
		
		if aRequest.isReleaseType then
			aWle := aRequest.allWorkListEntries.first;
			if aWle.status = WLE_COMPLETED then
				continue;
			endif;
			
			if swapWle1 = null then
				swapWle1 := aWle;
			else
				swapWle2 := aWle;
			endif;			
		endif;
	endforeach;

	
	if swapWle2 &lt;&gt; null then
		wle2 := app.showTruckCargoSwap( wle1, newRoadJob);
	else
		wle2 := swapWle1;
	endif;

	
	if wle2 &lt;&gt; null and wle1 &lt;&gt; null
	and wle1 &lt;&gt; wle2	//06 Aug 2019	NDL	TFS 42876
	then
		app.myTrxUA.trxSwapTruckTasks(wle1,wle2, app.myPassport);
		
		if app.myPassport.hasErrorsOrWarnings then
			return false;
		else
			return true;
		endif;
	else 
		return true;
	endif;

	return true;
epilog

end;</source>
        <Parameter name="_rtTask" type="CM_RTQueueTask" usage="input"/>
        <Parameter name="_twinTask" type="CM_RTQueueTask" usage="input"/>
        <Parameter name="_setdownLoc" type="String"/>
        <Parameter name="_twinSetdownLoc" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="createErrorsFromPassport" id="7a9ff092-fd4f-4394-87f2-339857e0649a">
        <source>createErrorsFromPassport(_errorMsgs: DTO_HandHeldGateErrorDict input): Boolean protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 June 2010	cnwer1	Initial creation

*/

vars
	hasErrors : Boolean;
	error 		: CM_Error;
	result		: Integer;
begin
	
	if self.myVMInterface = null then
		if _errorMsgs &lt;&gt; null then
			return inheritMethod(_errorMsgs);
		endif;
	else
		
		hasErrors:=true;
		if not app.myPassport.trxCompletedOK then
			//create hand held errors
			
			result:=self.myVMInterface.doSendErrorMessages();
			//epr TFS 7294 10/10/17
			if app.myPassport.noErrors or (app.myPassport.hasWarnings and result = IDOK) then
				hasErrors:=false;
			endif;
		endif;
	endif;
	
	return hasErrors;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_errorMsgs" type="DTO_HandHeldGateErrorDict" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doAcceptRTQueueEntries" id="803529ca-f705-4d17-ad35-6bb1c9cf864b">
        <source>doAcceptRTQueueEntries(_rtQueueEntries : CM_RTQueueEntryArray input) : Boolean;
/*

Date		Who		Reason
06 August 2014	cnwer1	Initial creation PAR

*/

vars
	result : Boolean;
begin
		// PAR 20338 18807
	app.myPassport.setupForDeadlockReplay(-100, 2000);

	while true do

		result:=self.doAcceptRTQueueEntriesBody(_rtQueueEntries);
		
		if app.myPassport.noTrxReplayAllowed() then	//15 Jan 2013	NDL	Par 30920
			break;
		endif;

	endwhile;
	
	return result;
epilog
	process.setPersistentDeadlockPriority(0);
	app.myPassport.replayingDeadlocks := false;

end;</source>
        <Parameter name="_rtQueueEntries" type="CM_RTQueueEntryArray" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doAcceptRTQueueEntriesBody" id="ae5446a0-835d-4ffd-8e7e-93538030903b">
        <source>doAcceptRTQueueEntriesBody(_rtQueueEntries : CM_RTQueueEntryArray input) : Boolean protected;
/*

Date		Who		Reason
06 August 2014	cnwer1	Initial creation PAR

*/

vars
	result : Boolean;
begin
	
	while true do
		self.initialiseForNewRequest(null);
	
		app.myTrxRT.trxAcceptRTQueueEntries(_rtQueueEntries,self.myMachine,app.myPassport);
	
		if app.myPassport.hadReplayableDeadlock() then	//15 Jan 2013	NDL	Par 30920
			break;
		endif;
		
		if app.myPassport.trxCompletedOK then
			return true;
			break;
		endif;
		result:= self.createErrorsFromPassport(null);
		if result then
			break;
		else
			continue;
		endif;
	endwhile;
	
	return false;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_rtQueueEntries" type="CM_RTQueueEntryArray" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doAcceptTasks" id="282c7ed6-de69-435a-9f14-f2bc591a73cf">
        <updating/>
        <source>doAcceptTasks(	_rtQueueTasks: CM_RTQueueTaskArray input;
				_sideAccessDirection : Integer input;
				_tandemLift : Boolean;
				_errorMsgs: DTO_HandHeldGateErrorDict input) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06/05/2010	cnwer1	Initial creation
21/02/2011	cnwdap1	PAR #27037 If a container on a ship was auto-planned and queued to a yard location,
								and a vehicle picked the job up while it was not in discharge mode, the
								container was moved to the vehicle with a "Move - Pickup" transaction, but
								did not get a "Received - Ship" or "Wharfage" transaction created
								Fix this by doing the 'receiveFromShip processing when picking up the container
23 Feb 2010 cnwer1	PAR 28126
*/

vars
	uncompleteTask,
	rtQueueTask 	: CM_RTQueueTask;
	ti, twinTI		: CM_TrackedItem;
	receivalTrans	: CM_TITransaction;
	twinID			: String;
	
begin

	rtQueueTask:=_rtQueueTasks.first;
	if rtQueueTask = null then
		self.addError(Please_Select_An_Item_Fiirst,app.getErrorString(Please_Select_An_Item_Fiirst),null);
		return;
	endif;
	
	//epr par 35898 14/5/15 - redundant does this down in the trx layer now

	inheritMethod(_rtQueueTasks, _sideAccessDirection, _tandemLift,_errorMsgs);
	
	if not app.myPassport.trxCompletedOK then
		self.resetMyOverstowRTEntry;
		return;
	endif;

	if self.getMyRTVehicleConfig.overstowMoveMode = CM_RTVehicleConfig.OSTOW_AUTOPLAN then
		self.resetMyOverstowRTEntry;
		return;
	endif;
	
	if app.myPassport.noErrors and
		self.myMachine.currentQueueTask &lt;&gt; null then
		self.resetMyOverstowRTEntry;
		return;
	
	endif;
	
	self.allOverstowedTasks.clear;
	self.currentOverstowedTask:=null;
	//epr par 34895 27/1/15 
	foreach rtQueueTask in _rtQueueTasks do
		if rtQueueTask.taskType = TASK_DIRECTOR and rtQueueTask.status = TASK_COMPLETE then
			uncompleteTask:=rtQueueTask.myEntry.getFirstUncompletedTask();
			if uncompleteTask &lt;&gt; null and not self.allOverstowedTasks.includes(uncompleteTask) then
				allOverstowedTasks.add(uncompleteTask);
			endif;
		else
			if not self.allOverstowedTasks.includes(rtQueueTask) then
				allOverstowedTasks.add(rtQueueTask);
			endif;
		endif;
		
	endforeach;
	
	if not self.getManualOverstowMoveCargo(_rtQueueTasks) then
		self.resetMyOverstowRTEntry;
	endif;
	
epilog

end;</source>
        <Parameter name="_rtQueueTasks" type="CM_RTQueueTaskArray" usage="input"/>
        <Parameter name="_sideAccessDirection" type="Integer" usage="input"/>
        <Parameter name="_tandemLift" type="Boolean"/>
        <Parameter name="_errorMsgs" type="DTO_HandHeldGateErrorDict" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doAutomaticGetNextTask" id="7a948701-3528-4571-81f7-a2d1f9a85dd8">
        <updating/>
        <source>doAutomaticGetNextTask() : Boolean protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 May 2010	cnwer1	Initial creation

*/

vars

begin
