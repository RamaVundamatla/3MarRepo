    <JadeMethod name="doMoveTrackedItemsWithSplit" id="08c707ad-7d40-4d51-ba2b-fa533b2dd872">
        <updating/>
        <source>doMoveTrackedItemsWithSplit(_tis: CM_TISet; _errTis: CM_TISet input; _control: CMIF_MoveController input; _passport: CM_Passport input) updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 May 2022	navam1	Initial creation
//TFS 53390
*/

vars

begin
	inheritMethod(_tis, _errTis, _control, _passport);
	
	if _passport.noErrors()  then
		_passport.doTrxPostActions();		
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_tis" type="CM_TISet"/>
        <Parameter name="_errTis" type="CM_TISet" usage="input"/>
        <Parameter name="_control" type="CMIF_MoveController" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="handleCargoGroupDetlGeneration" id="ca49ea5d-0625-4e0b-a3f5-9e96fd779f08">
        <updating/>
        <source>handleCargoGroupDetlGeneration(_includeNotes : Boolean) updating;
/*
Purpose:			

Date		Who		Reason
12JUL2023	NAVAB1	 BUG 58853
*/

vars
	trxPA : CMIF_TrxPostAction;
	cargoGroup : CM_CargoGroup;
	voyages : CM_VoyageSet;
	voyage : CM_Voyage;

begin

	if app.myPassport.trxCompletedOK()  then
	
		// ### TFS BUG 58853 03JUL2023 NAVAB1 - get the voyages whilst we can
		if _includeNotes then
			create voyages transient;
			foreach trxPA in app.myPassport.allTrxPostActions where trxPA.isCargoGroup() do
			
				cargoGroup := trxPA.CMIF_TrxActionCargoGroup.myCargoGroup;
				if cargoGroup &lt;&gt; null then
					cargoGroup.getCargoGroupMyVoyage(voyages);
				endif;
			endforeach;
		endif;
	
		app.myPassport.doTrxPostActions();		
		
		if _includeNotes then
			foreach voyage in voyages discreteLock do
				voyage.causeEvent( app.myPassport.myTerminal.getTerminalEvent(EVENT_CARGOGROUP_UPDATE), true, cargoGroup );	
			endforeach;
		endif;
	endif;	
epilog
	delete voyages;
end;</source>
        <Parameter name="_includeNotes" type="Boolean"/>
    </JadeMethod>
