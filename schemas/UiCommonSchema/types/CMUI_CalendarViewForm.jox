    <JadeMethod name="populateCombos" id="b185c8fd-ec9a-484a-9902-f08549a1229e">
        <source>populateCombos();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21 October 2010	cnwndl1	Initial creation
//21 Apr 2016	cnwns1	TFS 488 - Multi Timezone Support

*/

vars
	date : Date;
	pos : Integer;
	dayType : CM_DayType;
begin

	self.cmbPeriod.clear();
	self.cmbPeriod.width := 100;
	
	self.cmbPeriod.addItem( ByDay );
	self.cmbPeriod.addItem( ByWeek );
	self.cmbPeriod.addItem( ByMonth );
	
	self.cmbPeriod.listIndex := self.cmbPeriod.findStringExact( 1, ByMonth );	// default
	
	self.populateFilterDayTypes();	
	self.populateFilterCalendars();
	
	//21 Apr 2016	cnwns1	TFS 488 - Multi Timezone Support
	date := app.actualTimeServer().date();
	
	self.setDayListArray( date.lastMonday );

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="populateFilterCalendars" id="5f45876f-7e46-4513-88f6-5c189e9e4c7b">
        <source>populateFilterCalendars();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 March 2011	cnwndl1	Initial creation

*/

vars

begin

	if self.myTerminal &lt;&gt; null then
		self.mulCalendar.setupControl(app.getErrorString(Calendar),self.myTerminal.allCalendars,CMUI_CalendarViewForm::displayCalendar.name);
	else
		self.mulCalendar.setupControl(app.getErrorString(Calendar),app.myRoot.allCalendars,CMUI_CalendarViewForm::displayCalendar.name); 
	endif;
	self.mulCalendar.setSelected(self.allSelectedCalendars); 
	
	self.mulCalendar.multiSelect	:= ListBox.MultiSelect_Extended;
	
epilog

end;</source>
