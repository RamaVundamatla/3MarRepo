    <JadeMethod name="populateBolCombo" id="bcb97f3f-df7a-4f53-8d15-10a21a27270f">
        <source>populateBolCombo(_voyage : CM_Voyage) protected;

/*

Purpose:		33497 BOL search via combo box
				revised 33881 to get all BOL numbers for cargo from the voyage
Parameters:			

Return Value:		


Date		Who		Reason
27 February 2014	cnwjre1	Initial creation

*/

vars
	voyageBolNumbers	: StringArray;
	bolNumber			: String;
begin
	self.cmbBOL.clear();
	if _voyage &lt;&gt; null then
		create voyageBolNumbers transient;
		_voyage.getImportBOLNumbers(voyageBolNumbers);
		foreach bolNumber in voyageBolNumbers do
			self.cmbBOL.addItem(bolNumber);
		endforeach;
	endif;
epilog
	delete voyageBolNumbers;
end;</source>
        <access>protected</access>
        <Parameter name="_voyage" type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="populateCashReceiptCombo" id="594cbb1b-562d-4bdd-b362-2007f2abc9d9">
        <source>populateCashReceiptCombo(_terminal : CM_Terminal; _clearTextbox : Boolean ) protected;

/*

Purpose:			33497 receipt number search via combo box

Parameters:			

Return Value:		


Date		Who		Reason
27/02/2014	cnwjre1	Initial creation
29/02/2016	cnwdap1	PAR #37608 14025 exception at Gulftainer Umn Qasr - too many cash receipts to display in a combo
*/

vars
	invNumber	: String;
	bank		: CM_Bank;
	allBanks    : CM_BankSet;	//03 Jul 2019	NDL	TFS 45296
	receipt		: CM_CashReceipt;
	finIO		: CM_ExtFinanceIO;
	maxNumber	: Boolean;							// PAR #37608
	idx			: Integer;							// PAR #37608
	addBankCode : Boolean;
	baseStr		: String;
	recNum		: String;
	term 		: CM_Terminal;
	bankCode 	: String;
begin
	on Exception do app.handleUE14025(exception, maxNumber);		// PAR #37608
	if not self.cmbReceiptNo.enabled then							// PAR #37608
		return;														// PAR #37608
	endif;															// PAR #37608
	
	if _clearTextbox then
		self.txtReceiptNo.text := null;
	endif;
	
	create allBanks transient;
	
	self.cmbReceiptNo.clear();
	if _terminal = null then
		bank := self.cmbBanks.listObject.CM_Bank;
		if bank &lt;&gt; null then
			allBanks.add( bank );
		else
			foreach idx in 1 to self.cmbTerminals.listCount do
				term := self.cmbTerminals.itemObject[idx].CM_Terminal;
				if term = null then
					continue;
				endif;
				foreach bank in term.companies where bank.isBusinessUnit do
					allBanks.add( bank );
				endforeach;
			endforeach;
		endif;
		if allBanks.size &gt; 1 then
			addBankCode := true;
		endif;
		
		foreach bank in allBanks do
			if addBankCode then
				baseStr := bank.code &amp; "/";
			else
				baseStr := null;
			endif;
		
			foreach receipt in bank.allCashReceipts discreteLock do
				invNumber := baseStr &amp; receipt.getExternalInvoiceNumber;
				if invNumber &lt;&gt; null then
					self.cmbReceiptNo.itemObject[self.cmbReceiptNo.addItem(invNumber)] := receipt;
				endif;
			endforeach;
		endforeach;
		
	else
		bank := self.cmbBanks.listObject.CM_Bank;
		if bank &lt;&gt; null then
			allBanks.add( bank );
		else
			foreach bank in _terminal.companies where bank.isBusinessUnit do
				allBanks.add( bank );
			endforeach;
		endif;
		// 36355 ADP external receipt number is derived so receipts are not in bank.allCashReceiptsById, use allCashReceipts instead
		finIO := _terminal.getConfig(FinancialIOClass).CM_ExtFinanceIO;
		if allBanks.size &gt; 1 then
			addBankCode := true;
		endif;
		if finIO &lt;&gt; null and finIO.class = CM_ADPInterface then
			foreach bank in allBanks do
				if addBankCode then
					baseStr := bank.code &amp; "/";
				else
					baseStr := null;
				endif;
				foreach receipt in bank.allCashReceipts discreteLock do
					recNum := baseStr &amp; receipt.getExternalInvoiceNumber;
					if recNum &lt;&gt; null then
						self.cmbReceiptNo.itemObject[self.cmbReceiptNo.addItem(recNum)] := receipt;
						if maxNumber then
							break;
						endif;
					endif;
				endforeach;
			endforeach;
			
		elseif finIO &lt;&gt; null and finIO.class = CM_DefaultFinanceIO then				// PAR #37608
			self.cmbReceiptNo.sorted := false;										// PAR #37608
			foreach bank in allBanks do
				if addBankCode then
					baseStr := bank.code &amp; "/";
				else
					baseStr := null;
				endif;
				foreach receipt in bank.allCashReceipts reversed do						// PAR #37608
					recNum := baseStr &amp; receipt.getExternalInvoiceNumber;
					if recNum &lt;&gt; null then
						idx := self.cmbReceiptNo.addItem(recNum);	// PAR #37608
						if maxNumber then													// PAR #37608
							break;															// PAR #37608
						endif;																// PAR #37608
						self.cmbReceiptNo.itemObject[idx] := receipt;						// PAR #37608
					endif;
				endforeach;																// PAR #37608
			endforeach;
			
		else
			foreach bank in allBanks do
				if addBankCode then
					baseStr := bank.code &amp; "/";
				else
					baseStr := null;
				endif;
				foreach receipt in bank.allCashReceiptsById discreteLock do
					recNum := baseStr &amp; receipt.getExternalInvoiceNumber;
					if recNum &lt;&gt; null then
						self.cmbReceiptNo.itemObject[self.cmbReceiptNo.addItem(recNum)] := receipt;
						if maxNumber then
							break;
						endif;
					endif;
				endforeach;
			endforeach;
			
		endif;
		
	endif;
	
	if maxNumber then																// PAR #37608
		self.cmbReceiptNo.clear();
		self.cmbReceiptNo.addItem( app.getErrorString( Too_many_list ) );
		self.cmbReceiptNo.listIndex := 1;
		app.msgBox(	app.getErrorString(NbrCashReceiptsReachedMaxSize), 				// PAR #37608
					app.getErrorString(Cash_receipts), 								// PAR #37608
					MsgBox_Exclamation_Mark_Icon	);								// PAR #37608
	endif;																			// PAR #37608
epilog
	self.cmbReceiptNo.sorted := true;												// PAR #37608
	delete allBanks;
end;</source>
        <access>protected</access>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_clearTextbox" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="populateCmbBank" id="33442087-c7c5-4e92-90e1-ae9a852b298e">
        <source>populateCmbBank(_terminal : CM_Terminal) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 July 2019	jlgndl1	Initial creation	TFS 45286

*/

vars
	
	index : Integer;
	bank : CM_Bank;
	defaultBank : CM_Bank;

begin
	
	self.cmbBanks.clear();
	index := self.cmbBanks.addItem( app.getErrorString( AnyString ) );
	
	if _terminal &lt;&gt; null then
		
		foreach bank in _terminal.companies where bank.isBusinessUnit do
			index := self.cmbBanks.addItem( bank.code );
			self.cmbBanks.itemObject[index] := bank;
		endforeach;
		
		index := 0;
		defaultBank := _terminal.getDefaultCompanyBank();
		if defaultBank &lt;&gt; null then
			index := self.cmbBanks.findObject( defaultBank );
		endif;
	
	endif;
	
	if index &lt; 0 then
		index := 1;
	endif;
	
	self.cmbBanks.listIndex := index;
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="populateVoyageCombo" id="520e96ba-3345-405c-83cf-26c915647272">
        <source>populateVoyageCombo(_terminal : CM_Terminal) protected;

/*

Purpose:			33497 voyage search via combo box

Parameters:			

Return Value:		


Date		Who		Reason
27 February 2014	cnwjre1	Initial creation

*/

vars
	voyage	: CM_Voyage;
	voyages	: CM_VoyageSet;
begin
	create voyages transient;
	self.cmbBolVoyage.clear();
	if _terminal &lt;&gt; null then
		_terminal.getAllCurrentVoyages(voyages, true, false, false);
		foreach voyage in voyages do
			self.cmbBolVoyage.itemObject[self.cmbBolVoyage.addItem(voyage.code)] := voyage;
		endforeach;
	endif;
epilog
	delete voyages;
end;</source>
        <access>protected</access>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="searchBusUnitDateColls" id="94653284-1a5d-4019-a2ab-d3eeebf8a078">
        <source>searchBusUnitDateColls(	allCashTrx : CM_CashDict input;
						selectedDebtor : CM_Debtor;
						selectedTerminal : CM_Terminal;
						includeConsolidated : Boolean;
						includePayments : Boolean;
						includeProformas : Boolean;
						includeReceipts : Boolean;
						includeCredits : Boolean;
						startDate : Date;
						endDate : Date;
						startDateIsValid : Boolean;
						endDateIsValid : Boolean;
						bolNumber : String;
						voyageCode : String;
						customsNumber : String;
						receiptNumber : String;
						cargoId : String;
						bankObj : CM_Bank;
						recPayMeth : CM_PaymentMethod;
						refPayMeth : CM_PaymentMethod
						);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 July 2019	jlgndl1	Initial creation	TFS 45296

*/

vars

	allBanks : CM_BankSet;
	bank : CM_Bank;
	debtorTerminal : CM_DebtorTerminal;
	term : CM_Terminal;
	iter : Iterator;
	cash : CM_Cash;
	cashCredit	: CM_CashCredit;
	creditDetail	: CM_CashCreditDetail;
	startObjectCR : CM_CashReceipt;
	startObjectCC : CM_CashCredit;
	startTimeStamp : TimeStamp;
	
	allDebtorTerminals : CM_DebtorTerminalSet;
	cashBank : CM_Bank;
	terms : CM_TerminalByCodeDict;

begin
	//selectedDebtor = null, means any debtor
	//term = null, means any terminal
	//bankObj = null, means any bank ( business unit )
	
	if startDateIsValid then
		startTimeStamp.setDate(startDate);
		startTimeStamp.setTime("00:00:00".Time);
	endif;
	
	create terms transient;
	app.getMyUser.getTerminals(terms);
	
	//Will be using bank collections for cash receipts and cash credits, so find the Banks first..
	create allBanks transient;
	if includeReceipts or includeCredits then
		if bankObj &lt;&gt; null then
			allBanks.add( bankObj );
		elseif selectedTerminal &lt;&gt; null then
			//just terminal based get the associated BUs
			foreach bank in selectedTerminal.companies where bank.isBusinessUnit do
				allBanks.add( bank );
			endforeach;
		elseif selectedDebtor &lt;&gt; null then
			//just debtor based, find his terminals and then associated BUs
			foreach debtorTerminal in selectedDebtor.allDebtorTerminals do
				term := debtorTerminal.myTerminal;
				if not terms.includes( term ) then
					continue;
				endif;
				foreach bank in term.companies where bank.isBusinessUnit do
					allBanks.add( bank );
				endforeach;
			endforeach;
		else
			//completely open	
			foreach term in terms do
				foreach bank in term.companies where bank.isBusinessUnit do
					allBanks.add( bank );
				endforeach;
			endforeach;
		endif;
	
		//Use the banks we found to get the Cash Receipts and Cash Credits
		foreach bank in allBanks do
		
			if includeReceipts then
				iter := bank.allCashReceipts.createIterator();
				if startDateIsValid then
					startObjectCR := bank.allCashReceipts.getAtKeyGeq( startTimeStamp );
					if startObjectCR &lt;&gt; null then
						iter.startAtObject( startObjectCR );
					endif;
				endif;
				
				if not startDateIsValid or startObjectCR &lt;&gt; null then
					while iter.next( cash ) do
						if endDateIsValid then
							if cash.dateTime.Date &gt; endDate then
								break;
							endif;
						endif;
						
						if cash.CM_CashReceipt.myTerminal = null then
							//WTF! This happened in testing, probably crap data in DMAST 
							continue;
						endif;
						if not includeCashReceiptItem( 	cash.CM_CashReceipt,	//cash : CM_CashReceipt;
														recPayMeth,	//recPayMeth : CM_PaymentMethod;
														bolNumber,	//bolNumber : String;
														voyageCode,	//voyageCode : String;
														customsNumber,	//customsNumber : String;
														receiptNumber,	//receiptNumber : String;
														cargoId,	//cargoId : String;
														bankObj,	//bank : CM_Bank
														selectedDebtor	//dr : CM_Debtor
														) then
							continue;
						endif;
						allCashTrx.add( cash );
					endwhile;
				endif;
				delete iter;
			endif;
			
			if includeCredits then
				iter := bank.allCashCredits.createIterator();
				if startDateIsValid then
					startObjectCC := bank.allCashCredits.getAtKeyGeq( startTimeStamp );
					if startObjectCC &lt;&gt; null then
						iter.startAtObject( startObjectCC );
					endif;
				endif;
				
				if not startDateIsValid or startObjectCC &lt;&gt; null then
					while iter.next( cash ) do
						if endDateIsValid then
							if cash.dateTime.Date &gt; endDate then
								break;
							endif;
						endif;
						if bankObj &lt;&gt; null and cash.CM_CashCredit.myBank &lt;&gt; bankObj then
							continue;
						endif;
						
						allCashTrx.add( cash );
						cashCredit := cash.CM_CashCredit;
						foreach creditDetail in cashCredit.allDerivedFromCreditDetails do
							allCashTrx.add(creditDetail);
						endforeach;
					endwhile;
				endif;
				
				delete iter;
					
			endif;
		
		
		endforeach;
		
	endif;
	
	if includeConsolidated or includePayments or includeProformas then
		//These guys are found on debtor terminal collections (not on banks).
		//so build a collection of Debtor Terminals
		create allDebtorTerminals transient;
		if selectedDebtor &lt;&gt; null and selectedTerminal &lt;&gt; null then
			//one specific debtor terminal only
			debtorTerminal := selectedDebtor.allDebtorTerminals.getAtKey( selectedTerminal );
			allDebtorTerminals.add( debtorTerminal );
		elseif selectedDebtor &lt;&gt; null then
			//all debtor terminals for one specific debtor
			selectedDebtor.allDebtorTerminals.copy( allDebtorTerminals );
		elseif selectedTerminal &lt;&gt; null then
			//all debtor terminals for one specific terminal
			selectedTerminal.allDebtorTerminals.copy( allDebtorTerminals );
		else
			//open slather
			foreach term in terms do
				term.allDebtorTerminals.copy( allDebtorTerminals );
			endforeach;
		endif;
		
		//OK here we go
		foreach debtorTerminal in allDebtorTerminals do
			if includeConsolidated then
				if not debtorTerminal.allConsolidatedCashTrx.isEmpty then
					iter := debtorTerminal.allConsolidatedCashTrx.createIterator();
					while iter.next( cash ) do
						if not includeConsolidatedItem( 	cash,	//cash : CM_Cash;
															includePayments,	//includePayments : Boolean;
															includeReceipts,	//includeReceipts : Boolean;
															recPayMeth,	//recPayMeth : CM_PaymentMethod;
															refPayMeth,	//refPayMeth : CM_PaymentMethod;
															bolNumber,	//bolNumber : String;
															voyageCode,	//voyageCode : String;
															customsNumber,	//customsNumber : String;
															receiptNumber,	//receiptNumber : String;
															cargoId,	//cargoId : String;
															startDateIsValid,	//startDateIsValid : Boolean;
															startDate,	//startDate : Date;
															bankObj,	//bank : CM_Bank
															selectedDebtor	//dr : CM_Debtor
															) then
							continue;
						endif;
						
						if endDateIsValid then
							if cash.dateTime.Date &gt; endDate then
								break;
							endif;
						endif;
						
						allCashTrx.add( cash );
						
					endwhile;
					delete iter;
				endif;
			endif;
		
			if includePayments or includeProformas then	//10 Jul 2019	NDL	TFS 45296
				iter := debtorTerminal.allCashPayments.createIterator();
				while iter.next( cash ) do
					if not includePayments then
						if not cash.isProformaPayment then
							continue;
						endif;
					elseif not includeProformas then
						if cash.isProformaPayment then
							continue;
						endif;
					endif;
					if startDateIsValid then
						if cash.dateTime.Date &lt; startDate then
							continue;
						endif;
					endif;
					if endDateIsValid then
						if cash.dateTime.Date &gt; endDate then
							break;
						endif;
					endif;
					// 33983 extend the selective search to payments as well
					if not cash.CM_CashPayment.matches(bolNumber, voyageCode, customsNumber, receiptNumber, cargoId) then
						continue;
					endif;
					if bankObj &lt;&gt; null then
						cashBank := cash.CM_CashPayment.getBank();
						if cashBank &lt;&gt; null and cashBank &lt;&gt; bankObj then
							continue;
						endif;
					endif;
					allCashTrx.add( cash );
				endwhile;
				delete iter;
			endif;
			
		endforeach;
	
	endif;

epilog

	delete allBanks;
	delete allDebtorTerminals;
	delete iter;
	delete terms;

end;</source>
        <Parameter name="allCashTrx" type="CM_CashDict" usage="input"/>
        <Parameter name="selectedDebtor" type="CM_Debtor"/>
        <Parameter name="selectedTerminal" type="CM_Terminal"/>
        <Parameter name="includeConsolidated" type="Boolean"/>
        <Parameter name="includePayments" type="Boolean"/>
        <Parameter name="includeProformas" type="Boolean"/>
        <Parameter name="includeReceipts" type="Boolean"/>
        <Parameter name="includeCredits" type="Boolean"/>
        <Parameter name="startDate" type="Date"/>
        <Parameter name="endDate" type="Date"/>
        <Parameter name="startDateIsValid" type="Boolean"/>
        <Parameter name="endDateIsValid" type="Boolean"/>
        <Parameter name="bolNumber" type="String"/>
        <Parameter name="voyageCode" type="String"/>
        <Parameter name="customsNumber" type="String"/>
        <Parameter name="receiptNumber" type="String"/>
        <Parameter name="cargoId" type="String"/>
        <Parameter name="bankObj" type="CM_Bank"/>
        <Parameter name="recPayMeth" type="CM_PaymentMethod"/>
        <Parameter name="refPayMeth" type="CM_PaymentMethod"/>
    </JadeMethod>
    <JadeMethod name="searchUsingCashReceiptObj" id="21d41115-fd7e-42d0-9dae-396f8633d56e">
        <source>searchUsingCashReceiptObj(	allCashTrx : CM_CashDict input;
							includeConsolidated : Boolean;
							includePayments : Boolean;
							includeProformas : Boolean;
							includeReceipts : Boolean;
							includeCredits : Boolean;
							startDate : Date;
							endDate : Date;
							startDateIsValid : Boolean;
							endDateIsValid : Boolean;
							useDates : Boolean;
							bolNumber : String;
							voyageCode : String;
							customsNumber : String;
							receiptNumber : String;
							cargoId : String;
							cashReceiptObj : CM_CashReceipt;
							bankObj : CM_Bank;
							recPayMeth : CM_PaymentMethod;
							refPayMeth : CM_PaymentMethod
							);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 July 2019	jlgndl1	Initial creation	TFS 45296

*/

vars

	drTerm : CM_DebtorTerminal;
	iter : Iterator;
	cash : CM_Cash;
	cashPayment	: CM_CashPayment;
	cashCredit	: CM_CashCredit;
	creditDetail	: CM_CashCreditDetail;
	cashBank : CM_Bank;

begin
	
	if cashReceiptObj &lt;&gt; null then
	
		drTerm := cashReceiptObj.myDebtorTerminal;
		
		if includeConsolidated and drTerm &lt;&gt; null then
			if not drTerm.allConsolidatedCashTrx.isEmpty then
				iter := drTerm.allConsolidatedCashTrx.createIterator();
				while iter.next( cash ) do
					if not includeConsolidatedItem( 	cash,	//cash : CM_Cash;
														includePayments,	//includePayments : Boolean;
														includeReceipts,	//includeReceipts : Boolean;
														recPayMeth,	//recPayMeth : CM_PaymentMethod;
														refPayMeth,	//refPayMeth : CM_PaymentMethod;
														bolNumber,	//bolNumber : String;
														voyageCode,	//voyageCode : String;
														customsNumber,	//customsNumber : String;
														receiptNumber,	//receiptNumber : String;
														cargoId,	//cargoId : String;
														startDateIsValid,	//startDateIsValid : Boolean;
														startDate,	//startDate : Date;
														bankObj,	//bank : CM_Bank
														null	//dr : CM_Debtor
														) then
						continue;
					endif;
					
					if endDateIsValid then
						if cash.dateTime.Date &gt; endDate then
							break;
						endif;
					endif;
					
					allCashTrx.add( cash );
					
				endwhile;
				delete iter;
			endif;
		endif;
		
		if includeReceipts then
			cash := cashReceiptObj;
			while true do
				if startDateIsValid then
					if cash.dateTime.Date &lt; startDate then
						break;
					endif;
				endif;
				if endDateIsValid then
					if cash.dateTime.Date &gt; endDate then
						break;
					endif;
				endif;
				if not includeCashReceiptItem( 	cash.CM_CashReceipt,	//cash : CM_CashReceipt;
												recPayMeth,	//recPayMeth : CM_PaymentMethod;
												bolNumber,	//bolNumber : String;
												voyageCode,	//voyageCode : String;
												customsNumber,	//customsNumber : String;
												receiptNumber,	//receiptNumber : String;
												cargoId,	//cargoId : String;
												bankObj,	//bank : CM_Bank
												null	//dr : CM_Debtor
												) then
					break;
				endif;
				allCashTrx.add( cash );
				break;
			endwhile;
		endif;
		
		if ( includePayments or includeProformas )and not cashReceiptObj.allCashPayments.isEmpty then
			iter := cashReceiptObj.allCashPayments.createIterator();
			while iter.next( cash ) do
				if not includePayments then
					if not cash.isProformaPayment then
						continue;
					endif;
				elseif not includeProformas then
					if cash.isProformaPayment then
						continue;
					endif;
				endif;
				if startDateIsValid then
					if cash.dateTime.Date &lt; startDate then
						continue;
					endif;
				endif;
				if endDateIsValid then
					if cash.dateTime.Date &gt; endDate then
						break;
					endif;
				endif;
				if not cash.CM_CashPayment.matches(bolNumber, voyageCode, customsNumber, receiptNumber, cargoId) then
					continue;
				endif;
				if bankObj &lt;&gt; null then
					cashBank := cash.CM_CashPayment.getBank();
					if cashBank &lt;&gt; null and cashBank &lt;&gt; bankObj then
						continue;
					endif;
				endif;
				allCashTrx.add( cash );
			endwhile;
			delete iter;
			
		endif;
		
		if includeCredits and not cashReceiptObj.allDerivedFromCashCredits.isEmpty then
			iter := cashReceiptObj.allDerivedFromCashCredits.createIterator();
			while iter.next( cash ) do
				if startDateIsValid then
					if cash.dateTime.Date &lt; startDate then
						continue;
					endif;
				endif;
				if endDateIsValid then
					if cash.dateTime.Date &gt; endDate then
						break;
					endif;
				endif;
				if bankObj &lt;&gt; null and cash.CM_CashCredit.myBank &lt;&gt; bankObj then
					continue;
				endif;
					
				allCashTrx.add( cash );
				cashCredit := cash.CM_CashCredit;
				foreach creditDetail in cashCredit.allDerivedFromCreditDetails do
					allCashTrx.add(creditDetail);
				endforeach;
			endwhile;	
			delete iter;

		endif;
	
		return;
		
	endif;

epilog

end;</source>
        <Parameter name="allCashTrx" type="CM_CashDict" usage="input"/>
        <Parameter name="includeConsolidated" type="Boolean"/>
        <Parameter name="includePayments" type="Boolean"/>
        <Parameter name="includeProformas" type="Boolean"/>
        <Parameter name="includeReceipts" type="Boolean"/>
        <Parameter name="includeCredits" type="Boolean"/>
        <Parameter name="startDate" type="Date"/>
        <Parameter name="endDate" type="Date"/>
        <Parameter name="startDateIsValid" type="Boolean"/>
        <Parameter name="endDateIsValid" type="Boolean"/>
        <Parameter name="useDates" type="Boolean"/>
        <Parameter name="bolNumber" type="String"/>
        <Parameter name="voyageCode" type="String"/>
        <Parameter name="customsNumber" type="String"/>
        <Parameter name="receiptNumber" type="String"/>
        <Parameter name="cargoId" type="String"/>
        <Parameter name="cashReceiptObj" type="CM_CashReceipt"/>
        <Parameter name="bankObj" type="CM_Bank"/>
        <Parameter name="recPayMeth" type="CM_PaymentMethod"/>
        <Parameter name="refPayMeth" type="CM_PaymentMethod"/>
    </JadeMethod>
    <JadeMethod name="selectCashReceipt" id="b0fec594-95ff-40f9-a260-574bb284bd3a">
        <source>selectCashReceipt( _context : Control );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 July 2019	jlgndl1	Initial creation	TFS 45296

*/

vars

	cashReceipt : CM_CashReceipt;
	finIO : CM_ExtFinanceIO;
	recNo : String;
	index : Integer;	
	allBanks : CM_BankSet;
	bank : CM_Bank;
	terminal : CM_Terminal;
	msg : String;
	stringToCheck : String;

begin

	finIO := self.myTerminal.getConfig(FinancialIOClass).CM_ExtFinanceIO;

	if _context = self.cmbReceiptNo then
		//clicked on combo item, populate term dr bu dates and text
		cashReceipt := self.cmbReceiptNo.listObject.CM_CashReceipt;
		if cashReceipt = null then
			self.txtReceiptNo.text := null;
			return;
			
		else	
			recNo := cashReceipt.getExternalInvoiceNumber;
			self.txtReceiptNo.text := recNo;
			self.setDrTermBuDates( cashReceipt );
			
		endif;
		
	elseif _context = self.txtReceiptNo then
		//lost focus on text box, see if we can find receipt then, populate term dr bu dates and combo
		
		recNo := self.txtReceiptNo.text.trimBlanks();
		
		if recNo = null then
			//trying to clear it
			self.cmbReceiptNo.listIndex := -1;
			return;
		endif;
		
		if self.cmbReceiptNo.listCount = 1 and self.cmbReceiptNo.itemText[1] = app.getErrorString( Too_many_list ) then
			self.cmbReceiptNo.listIndex := 1;
			return;
		endif;
		
		//get the banks in play
		create allBanks transient;
		bank := self.cmbBanks.listObject.CM_Bank;
		terminal := self.cmbTerminals.listObject.CM_Terminal;
		
		if bank &lt;&gt; null then
			allBanks.add( bank );
		elseif terminal &lt;&gt; null then
			foreach bank in terminal.companies where bank.isBusinessUnit do
				allBanks.add( bank );
			endforeach;
		else
			foreach index in 1 to self.cmbTerminals.listCount do
				terminal := self.cmbTerminals.itemObject[index].CM_Terminal;
				if terminal = null then
					continue;
				endif;
				foreach bank in terminal.companies where bank.isBusinessUnit do
					allBanks.add( bank );
				endforeach;
			endforeach;
		endif;
		
		if self.txtReceiptNo.enabled then
			//optomist, check combo first
			if bank &lt;&gt; null then	
				index := self.cmbReceiptNo.findStringExact( 1, recNo );
				if index &gt; 0 then
					self.cmbReceiptNo.listIndex := index;
					cashReceipt := self.cmbReceiptNo.listObject.CM_CashReceipt;
				endif;
			else
				foreach bank in allBanks do
					stringToCheck := bank.code &amp; "/" &amp; recNo;
					index := self.cmbReceiptNo.findStringExact( 1, stringToCheck );
					if index &gt; 0 then
						self.cmbReceiptNo.listIndex := index;
						cashReceipt := self.cmbReceiptNo.listObject.CM_CashReceipt;
						break;
					endif;
				endforeach;
			endif;
		endif;
		
		if cashReceipt = null then
			if finIO &lt;&gt; null and finIO.class = CM_ADPInterface then
				//nothing else for this guy, would be too slow, there is no dict to check
				return;
			endif;
			
			// the rest have keys, so only one look up per bank / terminal combination
			foreach bank in allBanks do
				cashReceipt := bank.allCashReceiptsById[ recNo ];
				if cashReceipt &lt;&gt; null then
					break;
				endif;
			endforeach;
		
		endif;
		
		if cashReceipt &lt;&gt; null then
			self.setDrTermBuDates( cashReceipt );
			index := self.cmbReceiptNo.findObject( cashReceipt );
			if index &gt; 0 then
				self.cmbReceiptNo.listIndex := index;
			else
				self.cmbReceiptNo.listIndex := -1;
			endif;
		else
			self.cmbReceiptNo.listIndex := -1;
		endif;
		
		if self.cmbReceiptNo.listIndex &lt; 0 then
			msg := self.cmbDebtors.text &amp; "/" &amp; self.cmbTerminals.text &amp; "/" &amp; self.cmbBanks.text &amp; CrLf;
			msg := msg &amp; self.lblReceiptNo.caption &amp; " " &amp; recNo &amp; CrLf;
			msg := msg &amp; app.getErrorString(Not_known);
			app.msgBox( msg, app.getErrorString(Not_known), MsgBox_OK_Only );
		endif;
				
	endif;


epilog

	delete allBanks;

end;</source>
        <Parameter name="_context" type="Control"/>
    </JadeMethod>
    <JadeMethod name="setDrTermBuDates" id="46a95b3e-a3e2-4f59-94c6-71ce5e4b2e53">
        <source>setDrTermBuDates( cashReceipt : CM_CashReceipt );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 July 2019	jlgndl1	Initial creation

*/

vars

	debtor : CM_Debtor;
	terminal : CM_Terminal;
	bank : CM_Bank;
	index : Integer;
	startDate: Date;
	endDate : Date;

begin

	if cashReceipt &lt;&gt; null then
		if cashReceipt.myDebtorTerminal &lt;&gt; null then
			debtor := cashReceipt.myDebtorTerminal.myDebtor;
			terminal := cashReceipt.myDebtorTerminal.myTerminal;
		endif;
		if debtor &lt;&gt; null then
			index := self.cmbDebtors.findObject( debtor );
			if index &lt; 1 then
				index := 1;
			endif;
		else
			index := 1;
		endif;
		if self.cmbDebtors.listIndex &lt;&gt; index then
			self.cmbDebtors.listIndex := index;
		endif;
		
		if terminal &lt;&gt; null then
			index := self.cmbTerminals.findObject( terminal );
			if index &lt; 1 then
				index := 1;
			endif;
		else
			index := 1;
		endif;
		if self.cmbTerminals.listIndex &lt;&gt; index then
			self.cmbTerminals.listIndex := index;	
		endif;
		
		self.populateCmbBank( terminal );
		
		bank := cashReceipt.myBank;
		index := self.cmbBanks.findObject( bank );
		if index &lt; 1 then
			index := 1;
		endif;
		if self.cmbBanks.listIndex &lt;&gt; index then
			self.cmbBanks.listIndex := index;
		endif;
		
		cashReceipt.getFirstLastRelatedDates( startDate, endDate );
		self.txtFromDate.setDate( startDate - 1 );
		self.txtToDate.setDate( endDate + 1 );
		
	endif;

epilog

end;</source>
        <Parameter name="cashReceipt" type="CM_CashReceipt"/>
    </JadeMethod>
    <JadeMethod name="setInitialControlValues" id="78b98e39-707f-4258-9149-f720e0ac18c0">
        <updating/>
        <source>setInitialControlValues() updating, protected;
/*
Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06/08/2012	cnwndl1	Initial creation	Par 29968
02/03/2016	cnwdap1	PAR #37608 Added a receipt number text box for sites with more than 32,000 cash receipts
//TFS2333 	cnwns1	Multi-timezone issues
18/10/2017	MAP		Added tax column	TFS7357
*/

vars

	index : Integer;
	headings : String;
	today : Date;
	day : Integer;
	startDate : Date;
	term : CM_Terminal;
	terms : CM_TerminalByCodeDict;
//	bank : CM_Bank;							// PAR #37608

begin

	self.setNavigatorHeading( self.caption );

	//self.showToolbar := false;
	self.frmMain.borderStyle := 0;
	self.frmMain.top := 0;
	self.frmMain.left := 0;
	
	self.frmTables.borderStyle := 0;
	
	self.minimumHeight := 400;
	self.minimumWidth := 700;
	
	self.myAssistant.comboBoxCashDebtors( self.cmbDebtors, null, self.myDebtor, true );
	
	self.cmbTerminals.clear();
	self.cmbTerminals.addItem( Any_String );
	
	create terms transient;
	app.getMyUser.getTerminals(terms);
	foreach term in terms do
		if not term.isCashOnlyEnabled then
			continue;
		endif;
		index := self.cmbTerminals.addItem( term.name );
		self.cmbTerminals.itemObject[ index ] := term;
	endforeach;
	if self.myTerminal &lt;&gt; null then
		self.cmbTerminals.listIndex := self.cmbTerminals.findObject(self.myTerminal);
	endif;
	if self.cmbTerminals.listIndex &lt; 1 then
		self.cmbTerminals.listIndex := 1;
	endif;
	self.txtReceiptNo.visible := false;							// PAR #37608
	self.showHideReceiptCombo();								// PAR #37608
	self.populateVoyageCombo(self.myTerminal);		// 33497
	self.populateCmbBank(self.myTerminal);	//03 Jul 2019	NDL	TFS 45296
	self.populateCashReceiptCombo(self.myTerminal, true);	// 33497
	
	
	
	self.tblCash.rows := 1;
	self.tblCash.fixedRows := 1;
	self.tblCash.columns := 7;
	self.tblCash.fixedColumns := 0; // TFS 7357
	self.tblCash.alignment := Table.Alignment_Left_Top;
	self.tblCash.accessColumn(5).alignment := Table.Alignment_Left_Bottom;
	self.tblCash.accessColumn(6).alignment := Table.Alignment_Right_Bottom;
	self.tblCash.accessCell(1,5).alignment := Table.Alignment_Left_Top;
	self.tblCash.accessCell(1,6).alignment := Table.Alignment_Left_Top;
	headings := app.getErrorString(DateStr) &amp; Tab &amp; app.getErrorString(Debtor_GC) &amp; Tab &amp; app.getErrorString(Terminal) &amp; Tab &amp; "Exported " &amp; Tab &amp; app.getErrorString(CM_Type) &amp; Tab &amp; app.getErrorString(Amount) &amp; Tab &amp; app.getErrorString(Tax);
	self.tblCash.setCellText(1,1,headings);
	self.tblCash.accessRow(1).fontBold := true;
	self.tblCash.accessColumn(4).width := 70;
	self.tblCash.accessColumn(4).alignment := Table.Alignment_Center_Top;
	self.tblCash.accessColumn(7).alignment := Table.Alignment_Right_Bottom;
	self.tblCash.accessCell(1, 7).alignment := Table.Alignment_Left_Top;
	self.tblCash.accessColumn(7).width := self.tblCash.accessColumn(6).width;
	self.tblCash.accessColumn(7).visible := false;
	self.tblCash.selectMode := Table.SelectMode_WholeRows; // TFS 7611

	today := self.systemToLocalTime(app.actualTimeServer).date();//TFS2333
	
	if process.isJLGAB1() then // TFS 38732
			startDate := today; // TFS 38732
	
	else // TFS 38732  
		day := today.day;
		if day &lt; 15 then
			startDate := ( today - 20 ).Date;
			startDate.setDate( 1, startDate.month, startDate.year );	// 1st iof last month
		else
			startDate.setDate( 1, today.month, today.year ); // 1st of this month.
		endif;
	endif;

	self.txtFromDate.setDate( startDate );
	self.txtToDate.setDate( today );
	
	self.myAssistant.comboBoxMethodOfPayment( self.cmbRecPayMeth, true );
	self.cmbRecPayMeth.listIndex := 1;
	self.doClickCashReceived();
	
	self.myAssistant.comboBoxMethodOfPayment( self.cmbRefPayMeth, true );
	self.cmbRefPayMeth.listIndex := 1;
	self.doClickCashRefund();
	
	self.lblSearchCrit.caption := " ";
	self.showSearchFrame;
	// 33983 after 33885 no journals or refunds, drop/move the controls in code at this stage
	self.chkIncludeRef.visible := false;
	self.cmbRefPayMeth.visible := false;
	self.chkIncludePay.top := chkIncludeRef.top;
	self.chkIncludePro.top := self.chkIncludePay.top + 18;
	self.chkIncludeCred.top := self.chkIncludePro.top + 18;
	 // ### TFS 50421 17SEP2021 NAVAB1 self.frmCashReceipt.top := 320;	//18 Dec 2019	NDL	TFS 47284
	self.frmCashReceipt.visible := true;
		 // ### TFS 50421 17SEP2021 NAVAB1 self.frmSearch.height := 495;	//18 Dec 2019	NDL	TFS 47284

epilog

	delete terms;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setMyDebtor" id="17fb9449-50a7-49d6-89b6-f293427d3602">
        <updating/>
        <source>setMyDebtor( _myDebtor : CM_Debtor ) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 August 2012	cnwndl1	Initial creation	Par 29968

*/

vars

begin

	self.myDebtor := _myDebtor;

epilog

end;</source>
        <Parameter name="_myDebtor" type="CM_Debtor"/>
    </JadeMethod>
    <JadeMethod name="setSearchCriteriaLabel" id="6a7d1c6c-ac0b-4b18-9536-9bfc6b1f3adb">
        <updating/>
        <source>setSearchCriteriaLabel() updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10/08/2012	cnwndl1	Initial creation	Par 29968
02/03/2016	cnwdap1	PAR #37608 Added a receipt number text box for sites with &gt; 32,000 cash receipts
*/

constants
	TAB : String = "      ";
vars

	str : String;
	fromDate : Date;
	toDate : Date;
	bolNumber	: String;
	voyageCode	: String;
	customsNumber	: String;
	receiptNumber	: String;
	cargoId		: String;
	cashReceiptObj : CM_CashReceipt;

begin

	str := app.getErrorString(Filter_criteria_used);
	if self.cmbDebtors.text &lt;&gt; null then
		str := str &amp; CrLf &amp; TAB &amp; lblCashDebtor.caption &amp; Tab &amp;  " = " &amp; self.cmbDebtors.text;
	endif;
	if self.cmbTerminals.text &lt;&gt; null then
		str := str &amp; CrLf &amp; TAB &amp; lblTerminal.caption  &amp; Tab &amp;   " = " &amp; self.cmbTerminals.text;
	endif;
	if self.cmbBanks.text &lt;&gt; null then	//03 Jul 2019	NDL	TFS 45296
		str := str &amp; CrLf &amp; TAB &amp; lblBank.caption  &amp; Tab &amp;   " = " &amp; self.cmbBanks.text;
	endif;
	
	fromDate := self.txtFromDate.getDate();
	toDate := self.txtToDate.getDate();
	if not fromDate.isValid and not toDate.isValid then
		//do nothing
	elseif fromDate.isValid and toDate.isValid then
		str := str &amp; CrLf &amp; TAB &amp; app.getErrorString2( MOVE_FROMTO, fromDate.asStringJMT, toDate.asStringJMT);
	elseif fromDate.isValid then
		str := str &amp; CrLf &amp; TAB &amp; app.getErrorString( CM_From )&amp; " " &amp;  fromDate.asStringJMT;
	elseif toDate.isValid then
	str := str &amp; CrLf &amp; TAB &amp; app.getErrorString( CM_To )&amp; " " &amp;  toDate.asStringJMT;
	endif;
	
	if self.chkIncludeArch.value then
		str := str &amp; CrLf &amp; TAB &amp; chkIncludeArch.caption;
	endif;
	if self.chkAddTotal.value then
		str := str &amp; CrLf &amp; TAB &amp; chkAddTotal.caption;
	endif;
	if self.chkIncludeRec.value then
		str := str &amp; CrLf &amp; TAB &amp; chkIncludeRec.caption &amp; ", " &amp; app.getErrorString(Payment_method) &amp; " = " &amp; self.cmbRecPayMeth.text;
	endif;
	if self.chkIncludeRef.value then
		str := str &amp; CrLf &amp; TAB &amp; chkIncludeRef.caption &amp; ", " &amp; app.getErrorString(Payment_method) &amp; " = " &amp; self.cmbRefPayMeth.text;
	endif;
	if self.chkIncludePay.value then
		str := str &amp; CrLf &amp; TAB &amp; chkIncludePay.caption;
	endif;
	if self.chkIncludePro.value then
		str := str &amp; CrLf &amp; TAB &amp; chkIncludePro.caption;
	endif;
	if self.chkIncludeCred.value then
		str := str &amp; CrLf &amp; TAB &amp; chkIncludeCred.caption;
	endif;
	
	voyageCode := self.cmbBolVoyage.text;
	if voyageCode &lt;&gt; null then
		str := str &amp; CrLf &amp; TAB &amp; lblVoyBol.caption  &amp; Tab &amp;   " = " &amp; voyageCode;
	endif;
	bolNumber := self.cmbBOL.text;
	if bolNumber &lt;&gt; null then
		str := str &amp; CrLf &amp; TAB &amp; lblBOL.caption  &amp; Tab &amp;   " = " &amp; bolNumber;
	endif;
	customsNumber := self.txtCEN.text;
	if customsNumber &lt;&gt; null then
		str := str &amp; CrLf &amp; TAB &amp; lblCEN.caption  &amp; Tab &amp;   " = " &amp; customsNumber;
	endif;
	if self.cmbReceiptNo.enabled and self.cmbReceiptNo.listObject &lt;&gt; null then
		cashReceiptObj := self.cmbReceiptNo.listObject.CM_CashReceipt;
		if cashReceiptObj &lt;&gt; null then
			receiptNumber := cashReceiptObj.getExternalInvoiceNumber.toUpper();	
		endif;
	else														// PAR #37608
		receiptNumber := self.txtReceiptNo.text.trimBlanks;		// PAR #37608
	endif;														// PAR #37608
	if receiptNumber &lt;&gt; null then
		str := str &amp; CrLf &amp; TAB &amp; lblReceiptNo.caption  &amp; Tab &amp;   " = " &amp; receiptNumber;
	endif;
	// 33879 cargo id not shown
	cargoId := self.txtCargoIds.text.toUpper();
	if cargoId &lt;&gt; null then
		str := str &amp; CrLf &amp; TAB &amp; lblCargoIds.caption  &amp; Tab &amp;   " = " &amp; cargoId;
	endif;
	
	self.lblSearchCrit.caption := str;
	self.doResize();

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="d6e54b67-2881-4300-aa51-c032d95d6b0e">
        <updating/>
        <source>setupForm() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06 August 2012	cnwndl1	Initial creation	par 29968

*/

vars

begin

	self.showToolbar := true;
	self.toolbarStyle := self.ToolbarStyle_ShowNoHide;
	self.mnuContext.visible:=false; //epr TFS 2343 28/7/16
	inheritMethod();
	
	if not app.isCashOnlyEnabled then
		self.unloadForm;
		return;
	endif;
	
	self.setInitialControlValues();
	
	self.beginClassNotification(CM_CashReceipt, false, Any_System_Event, Response_Continuous, null);
	self.beginClassNotification(CM_CashPayment, false, Any_System_Event, Response_Continuous, null);
	
	self.addToolbarControls();
	
	// TFS 38524
	if self.myQueryWorkOrder &lt;&gt; null then
		self.chkAddTotal.value := false; // TFS 39349
		self.lblSearchCrit.caption := self.myQueryWorkOrder.getCashReceiptList(false); // TFS 39349
		self.chkIncludePay.value := true; // ### TFS 51924 07SEP2021 NAVAB1
		self.chkIncludePro.value := true; // ### TFS 51924 07SEP2021 NAVAB1
		self.chkIncludeRec.value := true; // ### TFS 51924 07SEP2021 NAVAB1
		
		self.doSearch();
	endif;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="showAuditForm" id="2f25174d-bf60-4c8d-93e3-986a84050034">
        <source>showAuditForm(_receipt : CM_CashReceipt) protected;
//	34227 show cash receipt debtor change
vars
	cma : INV_AuditsInvoices;

begin

	app.mousePointer := MP_HOURGLASS;

	create cma;
	cma.myCurrentCashReceipt := _receipt;
	cma.setMode(2);		// show qualified audits
	cma.myTerminal := self.myTerminal;
	cma.createMyAssistant(INV_Assistant);
	cma.show;

epilog
	app.mousePointer := MP_DEFAULT;
end;</source>
        <access>protected</access>
        <Parameter name="_receipt" type="CM_CashReceipt"/>
    </JadeMethod>
    <JadeMethod name="showCashCredit" id="6ba93419-8d34-4f01-8a87-4053eefc740b">
        <source>showCashCredit(_receipt : CM_CashReceipt);
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 Jul 2019	jlgsl4	TFS 44274 - Cash Credit
18 Sep 2019	cnwma1	Bug 46582: Cash Credit are not being accounted for correctly
*/
vars

	creditForm		: INV_CashCredit;
begin
	create creditForm transient;
	creditForm.myTerminal    := self.myTerminal;
	creditForm.myCashReceipt := _receipt;      
	creditForm.setMyCurrentBank(_receipt.myBank);     // TFS 44274
	creditForm.show();

end;
