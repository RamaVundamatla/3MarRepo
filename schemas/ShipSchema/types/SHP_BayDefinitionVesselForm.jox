    <JadeMethod name="setColorsFromController" id="3e7ffca3-66b5-48ac-84cd-a16da1a56841">
        <updating/>
        <source>setColorsFromController(_colorControl: CM_ColorController) updating;
// ---------------------------------------------------------------------------
// Created:		July 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars
	tmpBackColor	: Integer;
begin
	inheritMethod(_colorControl);
	
	tmpBackColor := self.backColor;

	self.frmGetBayID.backColor		:= tmpBackColor;
