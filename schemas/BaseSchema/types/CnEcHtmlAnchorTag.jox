  COPYRIGHT © JADE SOFTWARE CORPORATION LIMITED 2004 - ALL RIGHTS RESERVED
____________________________________________________________________________
Specifies the definition of a hyperlink.</text>
    <DbClassMap file="basehtml"/>
    <PrimAttribute name="anchorHref" id="2553ec7f-d255-4bac-a740-3c1832c5d4d8">
        <length>256</length>
        <embedded/>
        <type name="String"/>
        <text>Identifies the destination URL, which can be a bookmark, an HTML page,
or a web address.</text>
    </PrimAttribute>
    <PrimAttribute name="anchorName" id="69006fc6-efa7-4b90-8e2e-878633755069">
        <type name="String"/>
        <text>Identifies the bookmark at this location.</text>
    </PrimAttribute>
    <PrimAttribute name="anchorTarget" id="4a4ff8fc-84ad-4bee-9915-0ed6225b5a30">
        <type name="String"/>
        <text>Identifies a specific frame in the link destination.  Only provide a value
if the link is to be displayed within the requested frame.  A value of
"_self" directs the link to the current page.</text>
    </PrimAttribute>
    <PrimAttribute name="anchorTitle" id="f5b9754c-90f9-4d2f-8c4f-5888f7753d5b">
        <type name="String"/>
        <text>Identifies a name for the link that is displayed when the mouse passes over
the link, otherwise the link address (URL) is displayed.</text>
    </PrimAttribute>
    <PrimAttribute name="anchorValue" id="b1b17e1d-5c9f-4239-b73b-a2f6b1e0f8a7">
        <type name="String"/>
        <text>This value is what is displayed in the browser (underlined), and is what
the user will click to go to the link.  This may be plain text, or another
HTML tag, such as an &lt;IMG&gt; tag to display an image as the hyperlink.</text>
    </PrimAttribute>
    <JadeMethod name="buildTagBody" id="d23968da-6834-4902-a059-d5999caea898">
        <source>buildTagBody(): String protected;
// --------------------------------------------------------------------------------
// Created:		02 December 2001 by cnwdad1
//
// Purpose:		Refer to the CnEcHtmlTagObject implementation.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	htmlString	: String;

begin
	htmlString	:=	'HREF="' &amp; self.anchorHref &amp; '"';

	if self.anchorName &lt;&gt; null then
		htmlString	:=	htmlString &amp; ' NAME="' &amp; self.anchorName &amp; '"';
	endif;

	if self.anchorTarget &lt;&gt; null then
		htmlString	:=	htmlString &amp; ' TARGET="' &amp; self.anchorTarget &amp; '"';
	endif;

	if self.anchorTitle &lt;&gt; null then
		htmlString	:=	htmlString &amp; ' TITLE="' &amp; self.anchorTitle &amp; '"';
	endif;

	htmlString	:=	htmlString &amp; inheritMethod();
	htmlString	:=	htmlString &amp; '&gt;' &amp; self.anchorValue;

	return htmlString;
end;</source>
        <access>protected</access>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getHtml" id="19ab7b1b-f3f2-4515-9947-951052ab5a43">
        <source>getHtml(): String;
// --------------------------------------------------------------------------------
// Created:		30 April 2000 by cnwdad1
//
// Purpose:		Refer to the CnEcHtmlTagObject implementation.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return '&lt;A ' &amp; self.buildTagBody() &amp; '&lt;/A&gt;' &amp; CrLf;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
</Class>
