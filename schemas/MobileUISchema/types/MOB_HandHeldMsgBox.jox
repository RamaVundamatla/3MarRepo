    <JadeMethod name="checkAccelerator" id="24438519-f47f-493d-b731-96700b86804b">
        <source>checkAccelerator(_buttonObj: Button; _searchFor: Integer): Boolean protected;
// --------------------------------------------------------------------------------
// Created:		25 January 2006 by cnwdad1
//
// Purpose:		Returns true if btn is visible and its caption contains "&amp;" followed
//				by the character represented by searchFor.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	charPos	: Integer;
	
begin
    if not _buttonObj.visible or _buttonObj.caption = null or _searchFor = 0 then
    	return false;
    else
    	charPos	:=	_buttonObj.caption.pos("&amp;",1);
    	return charPos &lt;&gt; null and charPos &lt; _buttonObj.caption.length and _buttonObj.caption[charPos+1:1].toUpper = _searchFor.Character;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_buttonObj" type="Button"/>
        <Parameter name="_searchFor" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doResize" id="55a38c5b-c275-4fae-aac3-ba9bc71d5e44">
        <updating/>
        <source>doResize() updating, protected;
// --------------------------------------------------------------------------------
// Created:		25 January 2006 by cnwdad1
//
// Purpose:		Resizes the receiver's contents to the desired dimensions.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
constants
	WIDTH = 240;
	Dummy = "Dummy";
	Margin = 5;
vars
	textHeightForWidth,
	textHeight : Integer;	
	screenWidth,
	screenHeight: Integer;
	lblHeight, frmHeight : Integer;
	btnHeight : Integer;
	activeFormMargin : Integer;
begin
	
	if app.myVMAgent &lt;&gt; null then
		self.getVehicleMountedScreenSize(screenWidth,screenHeight);
		
		if screenWidth &gt; 400 then
			self.width:=400;
		else
			self.width:=screenWidth;
		endif;
	else
		self.width:=WIDTH;	
		if self.useHHResizeCode then	//26 Feb 2015	NDL	Par 35604
			if self.resizedMargin &gt; 2 or app.activeForm = null then
				activeFormMargin := self.resizedMargin;
			else
				activeFormMargin := app.activeForm.MOB_HandHeldForm.resizedMargin;
				self.drawFontSize :=  app.activeForm.drawFontSize;
			endif;
			if activeFormMargin &gt; 2 then
				self.width := 150 * activeFormMargin;
				self.height := 50 * activeFormMargin;
				self.lblText.fontSize := self.drawFontSize;
				self.btnDialog1.fontSize := self.drawFontSize;
				self.btnDialog2.fontSize := self.drawFontSize;
				self.btnDialog3.fontSize := self.drawFontSize;
			endif;
		endif;
		
	endif;
	
	//epr par 33025
	btnHeight:=self.btnDialog1.getTextHeight(self.btnDialog1.caption);
	btnHeight:= btnHeight + (Margin *2);
	self.btnDialog1.height:=btnHeight;
	self.btnDialog2.height:=btnHeight;
	self.btnDialog3.height:=btnHeight;
	self.frmBtns.height:=btnHeight + (Margin *2);
	
	textHeightForWidth := self.getTextHeightForWidth(self.aMessage, self.clientWidth );	//08 Apr 2015	NDL	Par 36007
	textHeight:= self.lblText.getTextHeight(Dummy);
	lblHeight:=(textHeightForWidth + (textHeight * 3));
	frmHeight:=lblHeight + btnDialog1.clientHeight +20; 


	
	if activeFormMargin &gt; 2 then	//26 Feb 2015	NDL	Par 35604
		if frmHeight + 30 &gt; self.height then
			self.height := frmHeight + 30;	//08 Apr 2015	NDL	Par 36007
		endif;
	else
		//epr par 33025
		self.height := frmHeight + 30;	//08 Apr 2015	NDL	Par 36007
	endif;

	
end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="handleAmpersands" id="e43c227e-57ee-4285-a6f0-094e8499c97e">
        <source>handleAmpersands(text : String) : String ;
//03 June 2008	cnwdw1	
//
// To handle ampersands in the receiver (which is to be displayed in
// the caption of a label or button) where the default action of
// underlining the following character is not required.
// Any ampersand followed by a space, or at the end of the string, is
// replaced by "&amp;&amp;".  Other ampersands are removed.

constants
	AMPERSAND		: String = '&amp;';
	SPACE			: String = ' ';
	
vars
	textLen			: Integer;
	tempString		: String;
	returnString	: String;
	charPos			: Integer;
	
begin
	// Handle exception cases first
	if text = null or text.pos('&amp;', 1) &lt; 1 then
		return text;
	endif;

	textLen	:=	text.length;
	charPos	:=	1;
	
	while charPos &lt;= textLen do
		tempString := text.scanUntil(AMPERSAND, charPos);
		
		// Performance enhancement for long strings
		if tempString &lt;&gt; null then
			returnString := returnString &amp; tempString;
		endif;
		
		// No more ampersands
		if charPos = 0 then
			break;
		endif;
		
		// If the ampersand is at the end of the string, or there's a space following 
		//  it, then replace it with "&amp;&amp;"
		if charPos = textLen or text[charPos + 1:1] = SPACE then
			returnString := returnString &amp; AMPERSAND &amp; AMPERSAND;
		endif;
		
		// Otherwise skip it
		charPos	:=	charPos + 1;
	endwhile;

	return returnString;
end;</source>
        <Parameter name="text" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
