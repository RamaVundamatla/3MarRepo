    <JadeMethod name="btnSend_click" id="3cc2a345-90f7-42e9-a7ce-afc7cd82227b">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnSend_click(btn: Button input) updating;
// --------------------------------------------------------------------------------
// Created:		05 August 2000 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	app.mousePointer	:=	Busy;
	self.doFormUpdate();
epilog
	app.mousePointer	:=	Idle;
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnSpellCheck_click" id="10aede12-48e7-495a-ae13-ac88e5fa6c66">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnSpellCheck_click(btn: Button input) updating;
// --------------------------------------------------------------------------------
// Created:		31 March 2003 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	app.mousePointer	:=	Busy;
	
	if (not txtMessage.cnEcDoSpellCheck()) then
		app.msgBox("The spell checking is complete.", "Spelling", MsgBox_Information_Icon + MsgBox_OK_Only);
	endif;
epilog
	app.mousePointer	:=	Idle;
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
