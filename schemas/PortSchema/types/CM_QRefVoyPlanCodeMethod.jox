    <JadeMethod name="setComboValues" id="882290ae-629b-4a91-95da-3042e89fdefd">
        <source>setComboValues(_combo: ComboBox input; _params: CM_QueryCriteriaLineHolder; _queryOperator: CM_QueryOperator; _passport: CM_Passport);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 June 2015	cnwndl1	Initial creation	Par 36338

*/

vars
	op		: CM_VoyagePlanningCode;
	coll	: CM_VoyagePlanCodeByCodeDict;
	qrl		: CM_QReferenceLookup;
	term : CM_Terminal;
	
begin
	_combo.clear();
	
	term := app.getMyTerminalDO_NOT_USE;
	
	if term &lt;&gt; null then
		coll := term.allVoyagePlanningCodes;
	else
		return;
	endif;
		
	foreach op in coll do
		_combo.itemObject[_combo.addItem(op.code &amp; Tab &amp; op.description)] := op;
	endforeach;

	if CM_QReferenceLookup.hasInstance(_queryOperator) then
		qrl := _queryOperator.CM_QReferenceLookup;
		if global.isValidObject(qrl.mySelectionValue) then
			_combo.listObject := qrl.mySelectionValue;
		endif;
	endif;

epilog
	
end;</source>
        <Parameter name="_combo" type="ComboBox" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_queryOperator" type="CM_QueryOperator"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="translateToDisplayValue" id="e028d458-5814-4e86-89fe-4925fd467138">
        <source>translateToDisplayValue(_value: Any): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 June 2015	cnwndl1	Initial creation	Par 36338

*/

vars

begin 
	if _value.isKindOf(CM_VoyagePlanningCode) then
		if _value &lt;&gt; null then
			return _value.CM_VoyagePlanningCode.code;
		else
			return null;
		endif;
	else
		return _value.String;
	endif;

epilog

end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="translateToSearchValue" id="c5fe530f-f5a4-41f1-977e-386d780a6367">
        <source>translateToSearchValue(_value: Any): Any;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 June 2015	cnwndl1	Initial creation	Par 36338

*/

vars
		
begin
	if _value &lt;&gt; null then
		if _value.isKindOf(Collection) then	
			return _value;
		endif;
	
		if _value.isKindOf(CM_VoyagePlanningCode) then
			return _value.CM_VoyagePlanningCode;
		endif;
	endif;
	
	// assume _value is port code
	return app.myRoot.allPorts[_value.String];
epilog

end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="translateToSearchValueForWeb" id="6995484f-b3d6-457a-a3f6-54260b7708f9">
        <source>translateToSearchValueForWeb(_value: Any; _sending : Boolean): Any;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 09/09/2019	jlgdap1		Initial creation TFS 45769 JMT Web Portal selector query parameters
//
vars
	terminal : CM_Terminal;
	vpc : CM_VoyagePlanningCode;

begin
	if _value.isKindOf(CM_VoyagePlanningCode) then
		return _value.CM_VoyagePlanningCode.code;
		
	elseif _value.isKindOf(String) then
		if not _sending then
			terminal := app.myPassport.myTerminal;
			if terminal &lt;&gt; null then
				vpc := terminal.allVoyagePlanningCodes[_value.String];
				if vpc &lt;&gt; null then
					return vpc;
				endif;
			endif;
		endif;
		
		return _value.String;
		
	endif;
	
	return inheritMethod(_value, _sending);

epilog

end;</source>
        <Parameter name="_value" type="Any"/>
        <Parameter name="_sending" type="Boolean"/>
        <ReturnType type="Any"/>
    </JadeMethod>
</Class>
