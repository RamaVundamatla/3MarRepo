    <JadeMethod name="create" id="bc6b7c85-1b81-4165-ab64-e82ea5b0dd31">
        <updating/>
        <source>create() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 January 2009	cnwjk3	Initial creation

*/

vars

begin
