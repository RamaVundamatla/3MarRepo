    <JadeMethod name="initialise" id="540080bd-0c89-439f-adc4-d1b2ec125654">
        <updating/>
        <source>initialise(_groupCount : Integer io) updating;
vars
	tmcQuantity : CMIF_TMCQuantityGroupDefault;
begin
	self.myTMCController := self.myGroup.myTMCController;	// April 2010, cnwjre1, par 23659, invoice transaction map extract enhancements for Tranship IMEX status
	self.hidePictures := self.myTMCController.hidePictures;

	create tmcQuantity;
	tmcQuantity.myGroup := self;
	tmcQuantity.myQuantityMap := self.myServiceBroker.myChildQuantityMap;
	tmcQuantity.myServiceMap := self.myServiceBroker;
	tmcQuantity.itemName := tmcQuantity.getItemName();
	tmcQuantity.extractName := tmcQuantity.getExtractDetails();	// 23659
	tmcQuantity.initialise(_groupCount);
	
	_groupCount:= _groupCount  + 1; //epr TFS 3051 2/12/16
end;</source>
        <Parameter name="_groupCount" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="setControllerCurrent" id="7bc42b5d-aeab-4dfd-8b7c-5d429bb7a7d6">
        <source>setControllerCurrent() ;
// April 2010, cnwjre1, par 23659, invoice transaction map extract enhancements for Tranship IMEX status
vars
	aTransSB : CM_ServiceBroker;
	aCommMap : CM_CommodityMap;
	aDM : CM_DebtorMap;
	isEvent, isVTMIS : Boolean;
	isBOL : Boolean;	//04 Nov 2019	NDL TFS 47100
begin
	inheritMethod();

	aTransSB := self.myServiceBroker;
	
	if aTransSB.isKindOf(CM_TransServiceBroker) then
		aCommMap := aTransSB.CM_TransServiceBroker.commodityMap;
	elseif aTransSB.isKindOf(CM_ResourceServiceBroker) then
		isVTMIS := true;
	elseif aTransSB.isKindOf(CM_EventServiceBroker) then
		isEvent := true;
	elseif aTransSB.isKindOf(CM_MoveServiceBroker) then
		aCommMap := aTransSB.CM_MoveServiceBroker.commodityMap;
	elseif aTransSB.isKindOf(CM_BOLServiceBroker) then
		isBOL := true;
	else
		return;
	endif;

	myTMCController.myCurrentMapDebtor := self.myDebtorMap;

	if isVTMIS then
		myTMCController.myCurrentMapTMVoyage := self.myServiceBroker.CM_ResourceServiceBroker.myTransMap;
		myTMCController.myCurrentMapServiceBroker := self.myServiceBroker;
	elseif isEvent then
		myTMCController.myCurrentMapTMEvent := self.myServiceBroker.CM_EventServiceBroker.myTranMap;
		myTMCController.myCurrentMapServiceBroker := self.myServiceBroker;
	elseif isBOL then	//04 Nov 2019	NDL TFS 47100
		myTMCController.myCurrentMapTMBOL := self.myServiceBroker.CM_BOLServiceBroker.myTransMap;
		myTMCController.myCurrentMapServiceBroker := self.myServiceBroker;
	else
	
		myTMCController.myCurrentMapServiceBroker := aTransSB;
		myTMCController.myCurrentMapCommodity := aCommMap;
		myTMCController.myCurrentMapContents := aCommMap.contentsMap;
		myTMCController.myCurrentMapIMEX := myTMCController.myCurrentMapContents.imexMap;
		myTMCController.myCurrentMapProduct := myTMCController.myCurrentMapIMEX.myProductMap;
		myTMCController.myCurrentMapProdGrp := myTMCController.myCurrentMapProduct.myProductGroupMap;
		myTMCController.myCurrentMapTIService := myTMCController.myCurrentMapProdGrp.myCargoTypeMap;
		myTMCController.myCurrentMapTM := myTMCController.myCurrentMapTIService.transactionMap;

	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="setEnableObjects" id="ee1242de-2e03-4499-9bd2-9486725b31d4">
        <source>setEnableObjects(form: INV_TransactionMap io);

vars

begin

	inheritMethod(form);

	form.menuSItemDelete.visible := false;
	form.btnDelete.enabled := false;
	
	if self.myServiceBroker.isKindOf(CM_MoveServiceBroker) 
	or self.myServiceBroker.isKindOf(CM_TransServiceBroker) then // TFS 3926 added IF
	
		form.btnCopy.enabled :=  form.myCurrentMapDebtor &lt;&gt; null ;
		form.mnuCopy.visible := app.myCurrentUserCan(form.myTerminal, form.permissionMaint); // TFS 2198 CNWAB1;
		form.btnCopy.enabled := app.myCurrentUserCan(form.myTerminal, form.permissionMaint); // TFS 2198 CNWAB1;
		form.mnuReplace.visible := app.myCurrentUserCan(form.myTerminal, form.permissionMaint); // TFS 2198 CNWAB1;
		form.btnReplace.enabled := app.myCurrentUserCan(form.myTerminal, form.permissionMaint); // TFS 2198 CNWAB1;
		
		//28 Dec 2018	NDL	TFS 41958 - Don't enabled when there is nothing to copy.
		if self.myServiceBroker.isKindOf(CM_TransServiceBroker) then
			if self.myServiceBroker.CM_TransServiceBroker.allDebtorMapsByDebtor.isEmpty then
				form.mnuReplace.visible := false; 
				form.btnReplace.enabled := false; 
				form.mnuCopy.visible := false; 
				form.btnCopy.enabled := false;
			endif;
		endif;
	else
	
		// TFS 3926 - by default turn these off, this functionality is for the cargo transaction map
		form.mnuReplace.visible := false; 
		form.btnReplace.enabled := false; 
		form.mnuCopy.visible := false; 
		form.btnCopy.enabled := false; 
	endif;
	
	
	if self.myServiceBroker.isKindOf(CM_MoveServiceBroker) then
		form.modePropertyNew := INV_TransactionMap.ModeProperty_Null;
		form.modePropertyUpdate := INV_TransactionMap.ModeProperty_Debtor;
		form.modePropertyDelete := INV_TransactionMap.ModeProperty_Move;
	elseif self.myServiceBroker.isKindOf(CM_TransServiceBroker) then // TFS 3926 added IF
		form.modePropertyNew := INV_TransactionMap.ModeProperty_Null;
		form.modePropertyUpdate := INV_TransactionMap.ModeProperty_Debtor;
		form.modePropertyDelete := INV_TransactionMap.ModeProperty_Null;
	endif;
end;</source>
        <Parameter name="form" type="INV_TransactionMap" usage="io"/>
    </JadeMethod>
    <JadeMethod name="setMyCurrent" id="92d70591-1e9e-45c2-aeb2-8f030b711dec">
        <updating/>
        <source>setMyCurrent(form: INV_TransactionMap io) updating;
// ---------------------------------------------------------------------------
// Created:		February 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	aTransSB : CM_ServiceBroker;
	aCommMap : CM_CommodityMap;
	aDM : CM_DebtorMap;
	isEvent, isVTMIS, isWorkOrder : Boolean;
	isBOL : Boolean;	 //07 Nov 2019	NDL	TFS 47100
begin
	inheritMethod(form);

	form.myTMCDebtor := self;

	aTransSB := self.myServiceBroker;
	
	if aTransSB.isKindOf(CM_TransServiceBroker) then
		aCommMap := aTransSB.CM_TransServiceBroker.commodityMap;
	elseif aTransSB.isKindOf(CM_ResourceServiceBroker) then
		isVTMIS := true;
	elseif aTransSB.isKindOf(CM_EventServiceBroker) then
		isEvent := true;
	elseif aTransSB.isKindOf(CM_WorkOrderServiceBroker) then // TFS 39236
		isWorkOrder := true; // TFS 39236
	elseif aTransSB.isKindOf(CM_BOLServiceBroker) then //07 Nov 2019	NDL	TFS 47100
		isBOL := true; //07 Nov 2019	NDL	TFS 47100
	elseif aTransSB.isKindOf(CM_MoveServiceBroker) then
		aCommMap := aTransSB.CM_MoveServiceBroker.commodityMap;
	else
		return;
	endif;

	form.myCurrentMapDebtor := self.myDebtorMap;

	if isVTMIS then
		form.myCurrentMapTMVoyage := self.myServiceBroker.CM_ResourceServiceBroker.myTransMap;
		form.myCurrentMapServiceBroker := self.myServiceBroker;
	elseif isEvent then
		form.myCurrentMapTMEvent := self.myServiceBroker.CM_EventServiceBroker.myTranMap;
		form.myCurrentMapServiceBroker := self.myServiceBroker;
	elseif isWorkOrder then // TFS 39236
		form.myCurrentMapTMWorkOrder := self.myServiceBroker.CM_WorkOrderServiceBroker.myTransMap;
		form.myCurrentMapServiceBroker := self.myServiceBroker;
	elseif isBOL then //07 Nov 2019	NDL	TFS 47100
		form.myCurrentMapTMBOL := self.myServiceBroker.CM_BOLServiceBroker.myTransMap;
		form.myCurrentMapServiceBroker := self.myServiceBroker;
	else
	
		form.myCurrentMapServiceBroker := aTransSB;
		form.myCurrentMapCommodity := aCommMap;
		form.myCurrentMapContents := aCommMap.contentsMap;
		form.myCurrentMapIMEX := form.myCurrentMapContents.imexMap;
		form.myCurrentMapProduct := form.myCurrentMapIMEX.myProductMap;
		form.myCurrentMapProdGrp := form.myCurrentMapProduct.myProductGroupMap;
		form.myCurrentMapTIService := form.myCurrentMapProdGrp.myCargoTypeMap;
		form.myCurrentMapTM := form.myCurrentMapTIService.transactionMap;

	endif;
end;</source>
        <Parameter name="form" type="INV_TransactionMap" usage="io"/>
    </JadeMethod>
</Class>
