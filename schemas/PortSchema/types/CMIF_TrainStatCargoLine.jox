    <JadeMethod name="addTi" id="1f3d5654-23dc-464b-a1aa-49bee45b070a">
        <updating/>
        <source>addTi(	_inward : Boolean;
		_ti : CM_TrackedItem;
		_teu : Real;
		_weight : Decimal
		) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 November 2009	cnwndl1	Initial creation	Par 21519

*/

vars

begin

	if _inward then
		self.allTisInward.add(_ti);
		//self.itemsIn := self.itemsIn + 1;
		self.itemsIn := self.itemsIn + _ti.totalQuantity;	//10 Sep 2013	NDL	Par 32172
		self.teuIn := self.teuIn + _teu;
		self.weightIn := self.weightIn + _weight; 
	else
		self.allTisOutward.add(_ti);
		//self.itemsOut := self.itemsOut + 1;
		self.itemsOut := self.itemsOut + _ti.totalQuantity;	//10 Sep 2013	NDL	Par 32172
		self.teuOut := self.teuOut + _teu;
		self.weightOut := self.weightOut + _weight; 
	endif;
	
epilog

end;</source>
        <Parameter name="_inward" type="Boolean"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_teu" type="Real"/>
        <Parameter name="_weight" type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="addWLE" id="8ea53ae6-b48e-4070-83c5-9d128b409415">
        <updating/>
        <source>addWLE(_wle : CM_WorkListEntry) updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15/11/2010	cnwdap1	Initial creation PAR #23794 CCMS MES 1102
*/
vars
	ti		: CM_TrackedItem;
	isoType	: CM_ISOType;

begin
	self.itemsOut := self.itemsOut + 1;
	
	ti := _wle.getMyTrackedITem();
	if ti &lt;&gt; null then
		self.teuOut 	:= self.teuOut + ti.getNumTEU;
		self.weightOut 	:= self.weightOut + ti.totalWeight;
	else		
		if CM_DeliveryRequest.hasInstance(_wle.myRequest) then
			isoType := app.myRoot.allISOTypes[_wle.myRequest.CM_DeliveryRequest.isoType];
			if isoType = null then
				self.teuOut := self.teuOut + 1;
			else
				if isoType.is20ftLong then
					self.teuOut := self.teuOut + 1;
				else
					self.teuOut := self.teuOut + 2;
				endif;
				self.weightOut := self.weightOut + isoType.myISOTypeGroup.maxTareWeight;
			endif;
		else
			self.teuOut := self.teuOut + 1;
		endif;
	endif;
epilog

end;</source>
        <Parameter name="_wle" type="CM_WorkListEntry"/>
    </JadeMethod>
    <JadeMethod name="getLineStrings" id="c11ba931-5665-4f18-9666-ae4d9c37e25f">
        <source>getLineStrings(	_type : String output;	
				_totItemsIn : String output;
				_totTeuIn : String output;
				_totWeightIn : String output;
				_totItemsOut : String output;
				_totTeuOut : String output;
				_totWeightOut : String output;
				_useSeperator : Boolean
				);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 November 2009	cnwndl1	Initial creation	Par 21519

*/

vars
	
begin
	
	_type := type;
	_totItemsIn := self.itemsIn.asStringJMTWithOptionalCommas(_useSeperator,true);
	_totTeuIn := self.teuIn.Integer.asStringJMTWithOptionalCommas(_useSeperator,true);
	_totWeightIn := self.weightIn.Integer.asStringJMTWithOptionalCommas(_useSeperator,true);
	_totItemsOut := self.itemsOut.asStringJMTWithOptionalCommas(_useSeperator,true);
	_totTeuOut := self.teuOut.Integer.asStringJMTWithOptionalCommas(_useSeperator,true);
	_totWeightOut := self.weightOut.Integer.asStringJMTWithOptionalCommas(_useSeperator,true);
	
epilog

end;</source>
        <Parameter name="_type" type="String" usage="output"/>
        <Parameter name="_totItemsIn" type="String" usage="output"/>
        <Parameter name="_totTeuIn" type="String" usage="output"/>
        <Parameter name="_totWeightIn" type="String" usage="output"/>
        <Parameter name="_totItemsOut" type="String" usage="output"/>
        <Parameter name="_totTeuOut" type="String" usage="output"/>
        <Parameter name="_totWeightOut" type="String" usage="output"/>
        <Parameter name="_useSeperator" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setBaseDetails" id="ba2650a0-4f6f-46c0-b52c-c8d9fb685816">
