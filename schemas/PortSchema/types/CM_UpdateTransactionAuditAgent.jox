    <JadeMethod name="audUpdateGeneric" id="d57fdbb9-2462-49f2-a296-201f4b2e598a">
        <updating/>
        <source>audUpdateGeneric(subject : CM_Object; beforeAudit : Boolean) : CM_AuditObject updating;
// ---------------------------------------------------------------------------
// Created:     12 March 2001 by cnwrs2
//
// Purpose:
// 16 Oct 2019 cnwma1	Bug 46974: JMT - Auditing Transients while creating Proforma     
// ---------------------------------------------------------------------------
vars
	s 	: String;
	ao	: CM_AuditObject;
	
begin
	if subject = null then
		self.beforeText := null;
		return ao;
	endif;
	
	if subject.isTransient or app.isInProformaMode then //16.10.2019 cnwma1 #46974
		return ao;
	endif;
	
	if beforeAudit then
		self.beforeText := subject.getAuditText();
		return ao;
	endif;
	s := subject.getAuditText();
	ao := app.myAA.auditUpdateTrx(subject, self.beforeText  , s);

	return ao;

end;</source>
        <Parameter name="subject" type="CM_Object"/>
        <Parameter name="beforeAudit" type="Boolean"/>
        <ReturnType type="CM_AuditObject"/>
    </JadeMethod>
    <JadeMethod name="audUpdateGenericKnownProperty" id="6c8fc112-905c-4767-bdb8-d7e8e217b7d6">
        <updating/>
        <source>audUpdateGenericKnownProperty(subject : CM_Object; _props : PropertyNDict;  beforeAudit : Boolean) : CM_AuditObject updating;
/*
Purpose:	Use this if you know the properties that have been changed, or if you only want to target certain properties.
				Performance enhancement

Date		Who		Reason
13 March 2024	navab1	BUG 62926
*/

vars

	s 	: String;
	ao	: CM_AuditObject;
	
begin
	if subject = null then
		self.beforeText := null;
		return ao;
	endif;
	
	if subject.isTransient or app.isInProformaMode then 
		return ao;
	endif;
	
	if beforeAudit then
		self.beforeText := subject.getAuditTextKnownProperty(_props);
		return ao;
	endif;
	s := subject.getAuditTextKnownProperty(_props);
	ao := app.myAA.auditUpdateTrx(subject, self.beforeText  , s);

	return ao;


epilog

end;</source>
        <Parameter name="subject" type="CM_Object"/>
        <Parameter name="_props" type="PropertyNDict"/>
        <Parameter name="beforeAudit" type="Boolean"/>
        <ReturnType type="CM_AuditObject"/>
    </JadeMethod>
    <JadeMethod name="audUpdateGenericWithExtraInfo" id="269a80b0-368e-43cd-b72c-fb594d6cc5d3">
        <source>audUpdateGenericWithExtraInfo(pSubject : CM_Object; _extraInfo : String);
/* ---------------------------------------------------------------------------
Created:	31/10/2017	by jlgrh7

TFS 6947        POL - Missing Audit records for bookings
   
Change Date		Who		Reason
16 Oct 2019 	cnwma1	Bug 46974: JMT - Auditing Transients while creating Proforma
------------------------------------------------------------------------------*/
vars
	s : String;

begin

	if pSubject = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Subject for audit is null');
		return;
	endif;
	
	if pSubject.isTransient  then //16.10.2019 cnwma1 #46974
		return ;
	endif;
	
	s := pSubject.getAuditText();
	//app.myAA.auditCreateTrx(pSubject, s, _extraInfo);
	app.myAA.auditUpdateTrxExtra(pSubject, s, _extraInfo);
	//app.myAA.auditUpdateTrxExtraInfo(pSubject, s, _extraInfo);

end;</source>
        <Parameter name="pSubject" type="CM_Object"/>
        <Parameter name="_extraInfo" type="String"/>
    </JadeMethod>
    <JadeMethod name="audUpdateTALocation" id="344219ee-cfe4-4d90-bf56-fc9a5f018542">
        <updating/>
        <source>audUpdateTALocation(_subject   : CM_TerminalAreaMaster;
					_before    : Boolean;
					_locations : Collection;
					_locType, 
					_locMode   : Integer; 
					_details   : String): CM_AuditTALocations updating;
// ---------------------------------------------------------------------------
// Created:     02 March 2011 by cnwcs5 CCMS CPL 2027/PAR 27126
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 16 Oct 2019 cnwma1	Bug 46974: JMT - Auditing Transients while creating Proforma
// ---------------------------------------------------------------------------
vars
	str 	: String;
	audit	: CM_AuditTALocations;
	set		: CM_LCSet;
	any		: Any;
begin
	if _subject = null then
		self.beforeText := null;
		return null;
	endif;
	
	if _subject.isTransient  then //16.10.2019 cnwma1 #46974
		return null ;
	endif;

	if _before then
		self.beforeText := _subject.getAuditText();
		return null;
	endif;
	
	str 	:= _subject.getAuditText();
	
	if _locations.isKindOf (CM_LCSet) then
		audit 	:= app.myAA.auditUpdateTALocationsTrx(_subject, self.beforeText, str, _locations.CM_LCSet, _locType, _locMode, _details);
	else
		create set transient;
		
		if _locations &lt;&gt; null then
			foreach any in _locations do
				if any.isKindOf (CM_LocationsController) then
					set.add (any.CM_LocationsController);
				endif;
			endforeach;
		endif;
		
		audit := app.myAA.auditUpdateTALocationsTrx(_subject, self.beforeText, str, set, _locType, _locMode, _details);
	endif;	

	return audit;
epilog
	delete set;
end;</source>
        <Parameter name="_subject" type="CM_TerminalAreaMaster"/>
        <Parameter name="_before" type="Boolean"/>
        <Parameter name="_locations" type="Collection"/>
        <Parameter name="_locType" type="Integer"/>
        <Parameter name="_locMode" type="Integer"/>
        <Parameter name="_details" type="String"/>
        <ReturnType type="CM_AuditTALocations"/>
    </JadeMethod>
</Class>
