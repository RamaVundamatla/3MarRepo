    <JadeMethod name="tblData_contextMenu" id="be88cdac-e06f-4cef-b1f8-bdc1a1dfbd63">
        <controlMethod name="Table::contextMenu"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblData_contextMenu(table: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating;
// -------------------------------------------
// Created 30 November 2005 by cnwdvb1
// -------------------------------------------
vars

begin
	self.mnuColumnOrganiser.userObject := table;
	if app.isAllowedToInspect() then
		self.mnuInspectObj.visible := true;
	else
		self.mnuInspectObj.visible := false;
	endif;
	
	if self.myCurrentWagonMaster &lt;&gt; null then	//06 Jul 2009	NDL	CCMS 1067
		self.buildMasterWagonMenu();
	elseif self.myCurrentTiMaster &lt;&gt; null then
		self.buildMasterTIMenu (self.myCurrentTiMaster );
	else
		self.mnuTIMaster.visible := false;
	endif;
	
	return self.showContextMenu(self.mnuContextTbl, table, conwin, mouse, x, y);


end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="tblData_dblClick" id="bad1f371-cb59-4c06-9825-4c1cb53abe24">
        <controlMethod name="CM_DataTable::dblClick"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblData_dblClick(table: Table input) updating;
// -------------------------------------------
// Created 30 November 2005 by cnwdvb1
// -------------------------------------------
vars
theRow	: Integer;
begin
	theRow := table.row;
	
	if theRow &lt;= 0 then
		return;
	endif;
	
	if theRow = 1 then
		self.zTblDataResort();
	else
	
		// TFS 2734 CNWAB1
		if not app.myCurrentUserCan(null, self.permissionMaint) then
			return;
		endif;
	
		self.openTiMasterMaintForm(true);
	endif;

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
