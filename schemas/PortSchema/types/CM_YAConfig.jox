    </JadeMethod>
    <JadeMethod name="setForCreate" id="65903ee4-20f2-4a98-98ca-c57c001c8ec9">
        <updating/>
        <source>setForCreate(_proxyYAConfig: CM_YAConfig; _configOpts : CMIF_YAConfig) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date			Who		Reason
29 July 2008	consw1	Initial creation
04/03/2010		cnwcs5	par 22718 - create vogae config
08/06/2010		cnwdap1	CCMS 1116 tranship changes - change In Transit creation to Tranship
05/12/2011		cnwmh5	#28798 - Remove code that deals with Hook Code and Hook Code Link as it has already been called from 
						setForUpdate.  Note that this doesn't use the normal way which would be to call setForCreate from the 
						udpate method. 
*/

vars
	imexConfig 		: CM_YAIMEXConfig;
	railConfig 		: CM_YARailConfig;
	voyageConfig	: CM_YAVoyageConfig;
	proxyLinkObj	: CM_HookLink;
begin
	self.myTerminal	:= _proxyYAConfig.myTerminal;
	
	self.setForUpdate(_proxyYAConfig, _configOpts);

	self.autoPlanOverstowRule := _proxyYAConfig.autoPlanOverstowRule;
	
	//  Create and append IMEX configs

	create imexConfig persistent;
	imexConfig.setForCreate(self, TI_IMEX_STATUS_EXPORT, null);

	create imexConfig persistent;
	imexConfig.setForCreate(self, TI_IMEX_STATUS_IMPORT, null);

	create imexConfig persistent;
	imexConfig.setForCreate(self, TI_IMEX_STATUS_STORAGE, null);

	create imexConfig persistent;
	imexConfig.setForCreate(self, TI_IMEX_STATUS_TRANSHIP, null);		// PAR #23645 CCMS 1116
	
	create imexConfig persistent;											//cnwmc5 par 29560
	imexConfig.setForCreate(self, TI_IMEX_STATUS_REMAINONBOARD, null);		//cnwmc5 par 29560

	create imexConfig persistent;
	imexConfig.setForCreate(self, TI_IMEX_STATUS_NULL, null);

	create railConfig persistent;
	railConfig.setForCreate(self, TI_IMEX_STATUS_IMPORT, null);

	create voyageConfig persistent;								// 04/03/2010 cnwcs5 par 22718
	voyageConfig.setForCreate (self, TI_IMEX_STATUS_EXPORT, null);	// 04/03/2010 cnwcs5 par 22718
	
epilog

end;</source>
        <Parameter name="_proxyYAConfig" type="CM_YAConfig"/>
        <Parameter name="_configOpts" type="CMIF_YAConfig"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="2795f976-ac43-4a27-80f7-42d8a4ad3f02">
        <updating/>
        <source>setForUpdate(_proxyYAConfig: CM_YAConfig; _configOpts : CMIF_YAConfig) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 Jul 2008	consw1	Initial creation
16 Jun 2022	navhl20	TFS 53765 EUP - Warehouse Yard Allocation Desktop Application
27 Aug 2025	navdap1	MTN-35615 ENS | Bulk Creation of Yard Allocations
*/

vars
	proxyLinkObj : CM_HookLink;
	changeString : String;
begin	
	if self.autoPlanOverstowRule &lt;&gt; _proxyYAConfig.autoPlanOverstowRule then
		//06 Mar 2015	NDL	Par 35816
		changeString := "CM_YAConfig.autoPlanOverstowRule, was:'" &amp; self.autoPlanOverstowRule.String &amp; "' now:'" &amp; _proxyYAConfig.autoPlanOverstowRule.String &amp; "'";
		app.createActivityHistory(	ActivityHistoryGeneralSys,	//_type : Integer;
						self.myTerminal,	//_terminal : CM_Terminal;
						null,	//_objectForExtraDetail : Object;
						changeString,	//_description : String;
						true,	//_insideTransaction : Boolean;
						false	//_temp: Boolean
						);
		self.autoPlanOverstowRule := _proxyYAConfig.autoPlanOverstowRule;
	endif;

	self.myTerminal.setAutoPlanAllowLogging( _configOpts.autoPlanAllowLogging);
	self.myTerminal.setAutoPlanningEnabled( _configOpts.autoPlanEnabled);
	self.myTerminal.setAutoPlanGenSwapForYardInt( _configOpts.autoPlanGenerateSwapForYardInt);
	self.myTerminal.setAutoPlanGenerateSwapJob( _configOpts.autoPlanGenerateSwapJob);
	self.myTerminal.setAutoPlanPreNotifyEmail( _configOpts.autoPlanPreNotiEmail);
	self.myTerminal.setAutoPlanPreNotifications( _configOpts.autoPlanPreNotifications);
	self.myTerminal.setAutoPlanUseOverstowRules( _configOpts.autoPlanUseOverstowRules);
	self.myTerminal.setAutoPlanUserRestrictions( _configOpts.autoPlanUserRestrictions);
	self.myTerminal.setAutoPlanYAGroupedBlocks( _configOpts.autoPlanYAGroupedBlocks);
	self.myTerminal.setFillOption( _configOpts.fillOption);
	self.myTerminal.setAutoPlanMTReleaseStrategy(_configOpts.autoPlanMTReleaseStrategy); // PAR 23677
	self.myTerminal.setAutoPlanUsePriorityLookup(_configOpts.autoPlanUsePriorityLookup); // PAR 24673
	self.myTerminal.setAutoPlanOsIgnorePandQ( _configOpts.autoPlanOsIgnorePandQ);	//16 Jan 2018	NDL	TFS 42292
	self.myTerminal.setAutoPlanAllowFullGCArea(_configOpts.autoPlanAllowFullGCArea);  //16 June 2022 navhl20 TFS 53765

	self.myTerminal.setAutoPlanUseBestPickDirector( _configOpts.autoPlanUseBestPickDirector); //cnwrd1 par 28628 2.11.11
	self.myTerminal.allRTAllocationCriteriaTypes.clear;
	_configOpts.allRTAllocationCriteriaTypes.copy( self.myTerminal.allRTAllocationCriteriaTypes );
	
	self.allDefaultCriteriaTypes.clear;
	_proxyYAConfig.allDefaultCriteriaTypes.copy(self.allDefaultCriteriaTypes);

	self.allDefaultSearchCriteriaTypes.clear;
	_proxyYAConfig.allDefaultSearchCriteriaTypes.copy(self.allDefaultSearchCriteriaTypes);

	self.allDefaultBulkCriteriaTypes.clear;													// MTN-35615
	_proxyYAConfig.allDefaultBulkCriteriaTypes.copy(self.allDefaultBulkCriteriaTypes);		// MTN-35615

	if _proxyYAConfig.myYAOverstowHookCode = null then
		delete self.myYAOverstowHookCode;
	else
		proxyLinkObj	:=	_proxyYAConfig.myYAOverstowHookCodeLink;
		
		if proxyLinkObj &lt;&gt; null then
			// need to set to the new persistent object
			proxyLinkObj.setLinkObject(self);
		endif;
		
		if self.myYAOverstowHookCode = null then
			create self.myYAOverstowHookCode persistent;
			self.myYAOverstowHookCode.setForCreate(_proxyYAConfig.myYAOverstowHookCode);
		else
			self.myYAOverstowHookCode.setForUpdate(_proxyYAConfig.myYAOverstowHookCode);
		endif;
	endif;
	
	if app.myYAAgent &lt;&gt; null then
		if app.myYAAgent.myCurrentTerminal &lt;&gt; null then	
			if app.myYAAgent.myCurrentTerminal = self.myTerminal then
				app.myYAAgent.useOverstowRules := _configOpts.autoPlanUseOverstowRules;				
			endif;
		endif;
	endif;
	
end;</source>
        <Parameter name="_proxyYAConfig" type="CM_YAConfig"/>
        <Parameter name="_configOpts" type="CMIF_YAConfig"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="585c0cb5-8527-435c-b271-4e6d60ee7c05">
        <updating/>
        <source>setProxy(_terminal : CM_Terminal; _templateCriteriaTypeColl, _searchCriteriaTypeColl, _bulkCriteriaTypeColl : CM_YACriteriaTypeArray ; _yaOverstowHookCode : String) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date			Who		Reason
31 July 2008	consw1	Initial creation
25 Aug 2025		navdap1	MTN-35615 Bulk Creation of Yard Allocations
*/

vars
	userName : String;
begin
	self.myTerminal := _terminal;
	
	self.allDefaultCriteriaTypes.clear;
	if _templateCriteriaTypeColl &lt;&gt; null then
		_templateCriteriaTypeColl.copy(self.allDefaultCriteriaTypes);
	endif;

	self.allDefaultSearchCriteriaTypes.clear;
	if _searchCriteriaTypeColl &lt;&gt; null then
		_searchCriteriaTypeColl.copy(self.allDefaultSearchCriteriaTypes);
	endif;
	
	// MTN-35615 Default Criteria for Bulk Yard Allocation creation
	self.allDefaultBulkCriteriaTypes.clear;
	if _bulkCriteriaTypeColl &lt;&gt; null then
		_bulkCriteriaTypeColl.copy(self.allDefaultBulkCriteriaTypes);
	endif;

	userName	:=	app.getMyUser().userName.cnEcUpto(10);
	
	if self.myYAOverstowHookCode = null then
		create self.myYAOverstowHookCode transient;
		self.myYAOverstowHookCode.setForProxy(self.myTerminal.code, app.myRoot.allHookTypes[HookType_YardAllocationOS]);
		self.myYAOverstowHookCode.createProxyHookLinkForParent(HookType_YardAllocationOS, self);
		self.myYAOverstowHookCode.setJadeCodeForProxy(_yaOverstowHookCode, userName);
	else
		self.myYAOverstowHookCode.setForProxy(self.myTerminal.code, app.myRoot.allHookTypes[HookType_YardAllocationOS]);
		self.myYAOverstowHookCode.setJadeCodeForProxy(_yaOverstowHookCode, userName);
	endif;
	

epilog

end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_templateCriteriaTypeColl" type="CM_YACriteriaTypeArray"/>
        <Parameter name="_searchCriteriaTypeColl" type="CM_YACriteriaTypeArray"/>
        <Parameter name="_bulkCriteriaTypeColl" type="CM_YACriteriaTypeArray"/>
        <Parameter name="_yaOverstowHookCode" type="String"/>
    </JadeMethod>
    <JadeMethod name="testYAOverstowTI" id="c421c69d-6c4b-40c8-a54e-c4b1554c368f">
        <source>testYAOverstowTI( _trackedItem: CM_TrackedItem) : Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 September 2011	cnwrd1	Initial creation

*/

vars
	result : Boolean;
	theTI : CM_TrackedItem;
begin
	
	if self.myYAOverstowHookCode = null then
		return false;
	endif;
	
	theTI := _trackedItem;

	result := app.myHookAgent.runHookLinkPublic(HookType_YardAllocationOS, self ,self, theTI).Boolean;

	return result;
epilog

end;</source>
        <Parameter name="_trackedItem" type="CM_TrackedItem"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validate" id="4e13ee26-7d77-4373-ab36-de375c591c9c">
        <source>validate( _configOpts : CMIF_YAConfig );
/*
Date			Who		Reason
29 Jul 2008	consw1	Initial creation
24 Jun 2013	cnwcs5	par 31719 - validate hook code
26 Aug 2025	navdap1	MTN-35615 ENS | Bulk Creation of Yard Allocations
*/
vars
	hookCode :CM_HookCode;
begin
	if self.myTerminal = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Terminal', null, null);
		app.raiseCMException(Input_required_field_terminal, null, null); // cnwdb2	PAR 35364
		return;
	endif;

	if  _configOpts.fillOption &lt;&gt; YAFillOption_InOrder and 
		_configOpts.fillOption &lt;&gt; YAFillOption_Alternating and 
		_configOpts.fillOption &lt;&gt; YAFillOption_BestPick and 
		_configOpts.fillOption &lt;&gt; YAFillOption_FIFO then
		
		app.raiseCMException2(ERR_INVALID_VALUE,"Fill Option"," ",null,null);
	endif;
	
	if _configOpts.allRTAllocationCriteriaTypes.size &gt; CM_Terminal.RT_CriteriaLimit then
		app.raiseCMException1(RT_Criteria_Too_Many, CM_Terminal.RT_CriteriaLimit.String, null, null);
	endif;
	
	// MTN-35615 Can't have more than 10 Bulk Yard Allocation criteria
	if self.allDefaultBulkCriteriaTypes.size &gt; 10 then
		app.raiseCMWarning1(Bulk_YA_Too_Many_Criteria, self.allDefaultBulkCriteriaTypes.size.String, null, null, null);
	endif;
	
	if self.autoPlanOverstowRule = app.getErrorStringShortText(CMUI_YAConfigForm_HookCode).Integer + 1 then
		hookCode := self.myYAOverstowHookCode;

		if hookCode &lt;&gt; null then
			hookCode.validateForUpdate;
		endif;
	endif;
epilog

end;</source>
        <Parameter name="_configOpts" type="CMIF_YAConfig"/>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="1b5e6e30-948d-46a1-a07b-0c7d9776bbab">
        <source>validateForCreate( _configOpts : CMIF_YAConfig );

/*

Purpose:			

Parameters:			

Return Value:		


Date			Who		Reason
29 July 2008	consw1	Initial creation
14/06/2022    	navds20     TFS 53760 DuplicateItem not Translatable
*/

vars

begin
	self.validate( _configOpts );

	if self.myTerminal.myYAConfig &lt;&gt; null then
		//app.raiseCMException2(DuplicateItem, 'Yard Allocation Configuration', self.myTerminal.code, null, null); //14.06.2022 navds20 53760
		// Yard Allocation Configuration already exists for %1 : Yard_alloca_config_alread_exis
		app.raiseCMException1(Yard_alloca_config_alread_exis, self.myTerminal.code, null, null); //14.06.2022 navds20 53760
	endif;

epilog

end;</source>
