22 November 2010	cnwrd1	Initial creation
//cwnrd1 par 25900 22.11.2010
*/

vars
	count : Integer;
	wle	: CM_WorkListEntry;
	
begin
	foreach wle in self.allWorkListEntries discreteLock where wle.status &lt;&gt; WLE_COMPLETED do
