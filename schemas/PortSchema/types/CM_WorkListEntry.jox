    <JadeMethod name="getMoveMethodRulesForNewTarget" id="6d7231e1-da2d-4435-824e-492fe68dea92">
        <source>getMoveMethodRulesForNewTarget(_newTargetLC : CM_LocationsController; _allPossibleMoveMethodRules : CM_RTMoveMethodRuleSet input);
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 March 2011	cnwer1	Initial creation

*/

vars
	machine : CM_Machine;
	iter 	: Iterator;
	originalSourceLoc,
	lastGroundedLocation : CM_LocationsController;
	newMultiRule 	: CM_RTQueueMultiRule;
	moveMethodRule 		: CM_RTMoveMethodRule;
	allMachineTypeGroups : CM_MachineTypeGroupArray;
	terminal : CM_Terminal;
	currentRTQueueEntry, rtQueueEntry : CM_RTQueueEntry;
begin

	//write method.name;
	if _newTargetLC = null then
		return;
	endif;
	
	if self.allRTQueueEntries.size = 0 then
		return;
	endif;
	
	self.getLastGroundedLocation(machine,lastGroundedLocation);
	//write lastGroundedLocation;
	//write machine;
	terminal:=self.getMyTerminal;
	originalSourceLoc:=self.getOriginalTaskSourceLoc();
	
	newMultiRule:=terminal.getRTQueueMultiRule(lastGroundedLocation,_newTargetLC);
	
	//write newMultiRule;
	if newMultiRule = null then
		return;
	endif;

	create allMachineTypeGroups transient;
	currentRTQueueEntry:=null;
	foreach rtQueueEntry in self.allRTQueueEntries discreteLock do
		allMachineTypeGroups.add(rtQueueEntry.getMyMachineTypeGroup);
		if rtQueueEntry.status &lt;&gt; ENTRY_COMPLETE then
			currentRTQueueEntry:=rtQueueEntry;
			break;
		endif;
	endforeach;
	
	//write  currentRTQueueEntry;
	if currentRTQueueEntry = null then
		//all entries are complete shouldn't be here at all
		return;
	endif;
	//add all the rules available default to the default one

	iter:=newMultiRule.allDefaultRTMoveMethodRules.createIterator;
	if machine &lt;&gt; null then
		while iter.next(moveMethodRule) do
			//see  if currentEntry and machine type match rule
			if moveMethodRule.myRTMoveMethod.isValidForEntryAndMachine(currentRTQueueEntry,machine,lastGroundedLocation,allMachineTypeGroups) then
				_allPossibleMoveMethodRules.add(moveMethodRule);
			endif;	
		endwhile;
		
		delete iter;
		
		iter:=newMultiRule.allOtherRTMoveMethodRules.createIterator;
		while iter.next(moveMethodRule) do
			if moveMethodRule.myRTMoveMethod.isValidForEntryAndMachine(currentRTQueueEntry,machine,lastGroundedLocation,allMachineTypeGroups) then
				_allPossibleMoveMethodRules.add(moveMethodRule);
			endif;
		endwhile;
		
	else
		newMultiRule.allDefaultRTMoveMethodRules.copy(_allPossibleMoveMethodRules);
		newMultiRule.allOtherRTMoveMethodRules.copy(_allPossibleMoveMethodRules);
	endif;
	
	
	
	
epilog
	delete allMachineTypeGroups;
	delete iter;

end;</source>
        <Parameter name="_newTargetLC" type="CM_LocationsController"/>
        <Parameter name="_allPossibleMoveMethodRules" type="CM_RTMoveMethodRuleSet" usage="input"/>
    </JadeMethod>
