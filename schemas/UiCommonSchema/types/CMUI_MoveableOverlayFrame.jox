    <JadeMethod name="mouseUp" id="a7d7e275-d9a4-43d4-9728-308bea52bd07">
        <controlMethod name="CMUI_MoveableFrame::mouseUp"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mouseUp(frame: Frame input; button: Integer; shift: Integer; x: Real; y: Real) updating;
// ---------------------------------------------------------------------------
// Created:     06 January 2009 by cnwab1
//
