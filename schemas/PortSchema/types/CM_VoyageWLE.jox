    <JadeMethod name="getLiftTotals" id="56e81afa-5ac1-43dd-9fd4-eee48b2fdd70">
        <updating/>
        <source>getLiftTotals(_done, _notDone : Real io) updating;
// ---------------------------------------------------------------------------
// Created:		26 February 2008 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
begin
	if self.status = WLE_COMPLETED then
		if self.isTwinLift then
			_done := _done + 0.5;	//each wle twin counts for half
		else
			_done := _done + 1;
		endif;
	else
		if self.isTwinLift then
			_notDone := _notDone + 0.5;	//each wle twin counts for half
		else
			_notDone := _notDone + 1;
		endif;
	
	endif;
end;</source>
        <Parameter name="_done" type="Real" usage="io"/>
        <Parameter name="_notDone" type="Real" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getLinkedWLE" id="4b0864c7-a04e-4ec9-aba8-b28645b2a548">
        <source>getLinkedWLE(): CM_WorkListEntry;
//----------------------------------------------------------------
//	Created:	19 February 2004	by Jason Chapman  (cnwjc2)
//	Should return the load WLE for a SOB only.  self is the discharge wle
//
// Changed On	By			Reasn
// ----------	--------	--------------------------------------
// 29/11/2021	navdap1		TFS 52360 SAL Direct Prenote to Voyage Incorrect Job Values
// 07/12/2021	navdap1		TFS 52293 SAL Direct Loading - Making Job Direct Delivery
//----------------------------------------------------------------
vars
	ourJob		: CM_Job;
	wle			: CM_WorkListEntry;
begin

	ourJob := self.job;	
	
	if self.job = null then
		return null;
	endif;
	//if ourJob.getMyTerminal.getConfig(DirectTruck2VesselMult).Boolean then// TFS 52360	// TFS 52293
	if ourJob.isDirectDeliveryJob then										// TFS 52360	// TFS 52293
		return null;														// TFS 52360
	endif;																	// TFS 52360
	
	foreach wle in ourJob.workListEntries do
		if wle = self then
			continue;
		endif;
		if wle.myTrackedItem = self.myTrackedItem
		and (not wle.isReceipt) then
			return wle;
		endif;
	endforeach;
	
	return null;

end;</source>
        <ReturnType type="CM_WorkListEntry"/>
    </JadeMethod>
    <JadeMethod name="getLoadPort" id="7cc18ce8-7c44-427e-bff7-9003927f9a80">
