    <JadeMethod name="isISOTypeRotatable" id="5e803438-4289-4da4-81b9-ceeb94bdf896">
        <source>isISOTypeRotatable(_isoTypeObj : CM_ISOType output) : Boolean;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 10/10/2025	navdap1		Initial creation MTN-36141 AAT | RotaBox Creation (EDI/API/Manual)
//
vars
	isoTypeObj : CM_ISOType;

begin
	if self.isoType &lt;&gt; null then
		isoTypeObj := app.myRoot.allISOTypes[self.isoType];
		if isoTypeObj &lt;&gt; null and isoTypeObj.isRotatable() then
			_isoTypeObj := isoTypeObj;
			return true;
		endif;
	endif;
	
	return false;
epilog

end;</source>
        <Parameter name="_isoTypeObj" type="CM_ISOType" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
