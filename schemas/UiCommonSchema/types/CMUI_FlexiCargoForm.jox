    <JadeMethod name="isVVRUpdatable" id="f4c039d8-c366-4496-855d-4d6e6404b409">
        <source>isVVRUpdatable() : Boolean;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12/08/2009	cnwjk3	Initial creation
17/03/2010	cnwdap1	PAR #23199 Attachment form's myRealGTEEntity doesn't have a myVehicleVisitRecord, but its parent does
*/
vars
	vvr	: CM_VehicleVisitRecord;

begin
	// PAR #23199 derive vehicle visit record from myRealGTEEntity or myRealGTEEntity.myParent
	if self.isFlexiGateForm and self.myRealGTEEntity &lt;&gt; null then
		if app.isValidObject(self.myParentForm) and self.isKindOf(self.myParentForm.class) then
			vvr := self.myRealGTEEntity.myParent.myVehicleVisitRecord;
		else
			vvr := self.myRealGTEEntity.myVehicleVisitRecord;
		endif;
	endif;
		
	 if self.isFlexiGateForm and
		self.myRealGTEEntity &lt;&gt; null and 
		not self.myRealGTEEntity.isReEditable() and
	    //self.myRealGTEEntity.myVehicleVisitRecord &lt;&gt; null and					// PAR #23199
		//self.myRealGTEEntity.myVehicleVisitRecord.isUpdatable = false then	// PAR #23199
	    vvr &lt;&gt; null and															// PAR #23199
		vvr.isUpdatable = false then											// PAR #23199
		return false;
	endif;
	
	//+cnwml2 PAR24989
	if self.permissionMaint &lt;&gt; 0 then
		return app.myPassport.myUser.canDo(self.myTerminal, self.permissionMaint);
	else
		return true;
	endif;
	
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="loadSubCargoCommodityCombos" id="effa49c5-81cc-4123-8b41-d15d0024d0ee">
        <updating/>
        <source>loadSubCargoCommodityCombos(_cargoType, _existingCargoType : CM_CargoType; _cmbSubCargo, _cmbCommodity : CMUI_FieldComboBox input) updating, protected;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21/08/2009	cnwjk3	Initial creation
28/10/2009	cnwdap1	PAR #20964 Reload commodity combo if cargo type changes
					Method signature changed to include _existingCargoType
23/03/2010	cnwdap1	PAR #22938 click the commodity combo if we've loaded a default commodity type
*/
vars
	commodity 	: CM_Commodity;
	prod		: CM_Product;	 
begin
	if _cargoType &lt;&gt; null then
		prod := _cmbSubCargo.getObject().CM_Product;
		
		_cmbSubCargo.listCollection(_cargoType.allProducts, true, ComboBox.DisplayCollection_Forward);
		_cmbSubCargo.setForObject(prod);
		
		if _cmbCommodity &lt;&gt; null then 
			if _cmbCommodity.getObject = null or _cargoType &lt;&gt; _existingCargoType then				// PAR #20964
				if _cargoType.isCommodityRequired and not _cargoType.allCommodities.isEmpty then	// PAR #20964
					commodity := _cmbCommodity.getObject().CM_Commodity;							// cnwjk3 PAR 21665 23/11/09
					_cmbCommodity.listCollection(_cargoType.allCommodities, true, ComboBox.DisplayCollection_Forward);
					_cmbCommodity.setForObject(commodity);											// cnwjk3 PAR 21665 23/11/09
					
					// Only set the default commodity when we haven't managed to successfully 
					// restore one that was set previously
					if _cmbCommodity.getObject() = null then										// cnwjk3 PAR 21665 23/11/09
						_cmbCommodity.setForObject(_cargoType.allCommodities[_cargoType.defaultCommodityCode]);
						// PAR #22938 and call the click event to display reefer properties if required
						_cmbCommodity.click(_cmbCommodity);
					endif;
				else
					commodity := _cmbCommodity.getObject().CM_Commodity;
					_cmbCommodity.listCollection(app.myRoot.allCommodities, true, 0);
					_cmbCommodity.setForObject(commodity);
				endif;
			endif;
		endif;
	else
		if _cmbCommodity &lt;&gt; null then 
			commodity := _cmbCommodity.getObject().CM_Commodity;
			_cmbCommodity.listCollection(app.myRoot.allCommodities, true, 0);
			_cmbCommodity.setForObject(commodity);
		endif;
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_cargoType" type="CM_CargoType"/>
        <Parameter name="_existingCargoType" type="CM_CargoType"/>
        <Parameter name="_cmbSubCargo" type="CMUI_FieldComboBox" usage="input"/>
        <Parameter name="_cmbCommodity" type="CMUI_FieldComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="onBookingRefChange" id="7f28269e-dbea-4c6b-bdea-947faa24adc9">
        <updating/>
        <source>onBookingRefChange(_id : String) : Boolean updating, protected;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17/04/2009	cnwjk3	Initial creation
22/09/2016	cnwdap1	TFS 2651 New parameters for getBookingRefFromCode method
*/
vars 
	cmObject : CM_Object;						// TFS 2651
	preNote : CM_TrackedItem;

begin
	if _id  &lt;&gt; null /*and self.myBookingRefItem = null*/ then
		//cnwjo3 par 25148
		//if self.myPxyGTEEntity &lt;&gt; null and self.myPxyGTEEntity.isKindOf(CMGTE_Receival) and self.myPxyGTEEntity.CMGTE_Receival.bookingReferenceItem = null then	// TFS 2651
		if self.myPxyGTEEntity &lt;&gt; null and self.myPxyGTEEntity.isKindOf(CMGTE_Receival) and self.myPxyGTEEntity.CMGTE_Receival.bookingReferenceItem = null 			// TFS 2651
		and self.myPxyGTEEntity.CMGTE_Receival.bookingReference = _id then																							// TFS 2651
			return false;
		else
			//self.myBookingRefItem := self.myAssistant.getBookingRefFromCode(_id);		// TFS 2651
			//if self.myBookingRefItem = null then										// TFS 2651
			cmObject := self.myAssistant.getBookingRefFromCode(_id, true);				// TFS 2651
			if cmObject = null then														// TFS 2651
				return false;
			else
				if cmObject.isKindOf(CM_BookingRefItem) then							// TFS 2651
					self.myBookingRefItem := cmObject.CM_BookingRefItem;				// TFS 2651
					self.doLoadBookingRefItems(self.myBookingRefItem);
					self.setFieldsFromBookingItem();
					if self.myBookingRefItem.allTIs.size = 1 and self.myBookingRefItem.allTIs.first.isPreNote then	// TFS 2651
						if self.myTerminal.getConfig(AutoShowSinglePrenote).Boolean then		// TFS 2651
							self.myTI := self.myBookingRefItem.allTIs.first;					// TFS 2651
							self.setFieldsFromPreNote(self.myTI);								// TFS 2651
						endif;																	// TFS 2651
					endif;																		// TFS 2651
				elseif cmObject.isKindOf(CM_TrackedItem) then							// TFS 2651
					self.myTI := cmObject.CM_TrackedItem;								// TFS 2651
					delete self.myPxyGTEEntity;											// TFS 2651
					self.myPxyGTEEntity := null;										// TFS 2651
					self.setFieldsFromPreNote(self.myTI);								// TFS 2651
				endif;																	// TFS 2651
				return true;
			endif;
		endif;
	else
		return false;
	endif;
epilog
	app.mousePointer := Window.MousePointer_Default;
end;</source>
        <access>protected</access>
        <Parameter name="_id" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
