    <JadeMethod name="tbx_CacheCon_dblClick" id="2cf269b1-5e27-4b4c-9885-7f867589e426">
        <controlMethod name="TextBox::dblClick"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tbx_CacheCon_dblClick(textbox: TextBox input) updating;

vars
	string : String;
	time   : Time;
begin
	whatIs;
	string := getCacheConcurrencyInfo();
	tbx_CacheCon.text := CrLf &amp; tbx_CacheCon.text &amp; time.String &amp; CrLf &amp; string;
	tbx_CacheCon.text := tbx_CacheCon.text &amp; CrLf &amp; 'Global Exceptions ' &amp; app.globalExceptionCount.String &amp; ' ' &amp; 
	                     app.lastGlobalException.String &amp; CrLf &amp;
	                     'Tcp Exceptions ' &amp; app.tcpExceptionCount.String &amp; ' ' &amp; 
	                     app.lastTcpException.String &amp; CrLf &amp; CrLf;
end;</source>
        <Parameter name="textbox" type="TextBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="unload" id="912cb6c9-907e-490a-b01a-93c06f7195df">
        <controlMethod name="Form::unload"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>unload() updating;

vars
	tcp : TcpIpConnection;
begin
	beginTransientTransaction;
	foreach tcp in v_tcpHandler.v_tcpArray do
		delete tcp;
	endforeach;
	commitTransientTransaction;
	app.myListener := null;
end;</source>
    </JadeMethod>
    <JadeMethod name="userNotify" id="2551b5d8-3ac0-4d1b-bb7c-a74fba96dfec">
        <controlMethod name="Form::userNotify"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>userNotify(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating, clientExecution;

vars

begin
	if eventType = Statusline_Message then
		sl_Status.caption := userInfo.String;
		return;
	endif;
end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
    <JadeMethod name="whatIs" id="5735a3be-f2f4-48d0-869c-4be12028aaf8">
        <updating/>
        <source>whatIs() updating;

vars

begin
	tbx_CacheCon.text := app.dbPath &amp; CrLf &amp; app.getIniFileName &amp; CrLf &amp; '** Server **' &amp; CrLf;
	tbx_CacheCon.text := tbx_CacheCon.text &amp; whatIsOnTheServer &amp; CrLf &amp; '** Application Server **' &amp; CrLf;
	tbx_CacheCon.text := tbx_CacheCon.text &amp; whatIsOnTheApplicationServer &amp; CrLf &amp; '** Presentation Client **' &amp; CrLf;
	tbx_CacheCon.text := tbx_CacheCon.text &amp; whatIsOnThePresentationClient &amp; CrLf;
	tbx_CacheCon.text := tbx_CacheCon.text &amp; "Infomation from all machines " &amp; CrLf;
	tbx_CacheCon.text := tbx_CacheCon.text &amp; v_tcpHandler.getSystemInformationOnMachines &amp; CrLf &amp; CrLf;
end;</source>
    </JadeMethod>
    <JadeMethod name="whatIsOnTheApplicationServer" id="dcd5d2c0-298d-4918-85e1-978a27ab9b6b">
        <updating/>
        <source>whatIsOnTheApplicationServer() : String updating;

vars
	reply : String;
	data  : String;
	file  : File;
begin
	reply := 'DB Path - ' &amp; app.dbPath &amp; CrLf &amp;
	        'Application Server INI File - ' &amp; app.getIniFileNameAppServer &amp; CrLf &amp;
	        'Application Server Install Directory - ' &amp; app.getJadeInstallDirAppServer;
	create file;
	file.kind := File.Kind_Unknown_Text; // 3/3/16  cnwns1 PAR 36286 unicode version
	file.usePresentationFileSystem := false;
	file.fileName := app.getIniFileNameAppServer;
	file.mode := File.Mode_Input;
	file.open;
	data := file.readString(file.fileLength);
	file.close;
	reply := reply &amp; CrLf &amp; data;
	return reply;
epilog

	delete file;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="whatIsOnThePresentationClient" id="9c57864c-f57b-47f3-86d2-a1ac6d2399f9">
        <updating/>
        <source>whatIsOnThePresentationClient() : String updating;

vars
	reply : String;
	data  : String;
	file  : File;
begin
	reply := 'DB Path - ' &amp; app.dbPath &amp; CrLf &amp;
	        'Client INI File - ' &amp; app.getIniFileName &amp; CrLf &amp;
	        'Client Install Directory - ' &amp; app.getJadeInstallDir;
	create file;
	file.kind := File.Kind_Unknown_Text; // 3/3/16  cnwns1 PAR 36286 unicode version
	file.fileName := app.getIniFileName;
	file.mode := File.Mode_Input;
	file.open;
	data := file.readString(file.fileLength);
	file.close;
	reply := reply &amp; CrLf &amp; data;
	return reply;
epilog

	delete file;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
