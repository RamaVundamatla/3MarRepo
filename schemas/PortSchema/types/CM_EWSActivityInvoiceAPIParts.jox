    <JadeMethod name="setForCreate" id="5e289ec6-c4d4-4f5a-b384-677272d91e6b">
        <updating/>
        <source>setForCreate(_proxy: SelfType) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 November 2023	navra1	Initial creation for TFS 54090 - EUP | EUP | Interface - MTN Invoicing Oracle &lt;&lt;54090&gt;&gt;(CR 61356/Task 61377)

*/

vars

begin
	inheritMethod(_proxy);
	
	self.messagePartStr := _proxy.messagePartStr;
	self.partNumber := _proxy.partNumber;
	self.partSendResponse := _proxy.partSendResponse;
	self.partSendResponseStr := _proxy.partSendResponseStr;
	self.sendDT := _proxy.sendDT;
	self.myEWSInvoiceMessageParent := _proxy.myEWSInvoiceMessageParent;
	self.statusStr := _proxy.statusStr;
	self.status := _proxy.statusStr;											//navra1 - 26th Feb 2024 - DEFECT 62247
	self.partUniqueRefNumber := _proxy.partUniqueRefNumber;
	self.response := _proxy.response;
	self.request := _proxy.request; 
	self.responseCode := _proxy.partSendResponse;
	self.createdUser := _proxy.createdUser;
	self.created := _proxy.created;
	self.direction := _proxy.direction;
	self.interfaceName := _proxy.interfaceName;
	self.myExtWebserviceDef := _proxy.myExtWebserviceDef;
	self.description := _proxy.description;
	self.interfaceName := _proxy.interfaceName;

epilog

end;</source>
        <Parameter name="_proxy" type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="4831661f-ed39-4523-9d74-cda51f5be6af">
        <updating/>
        <source>setForUpdate(_proxy: SelfType) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 November 2023	navra1	Initial creation for  TFS 54090 - EUP | EUP | Interface - MTN Invoicing Oracle &lt;&lt;54090&gt;&gt;(CR - 61414, Task - 61415 &amp; 61415)

*/

vars

begin
	inheritMethod(_proxy);
	self.partProcessResponse := _proxy.partProcessResponse;
	self.responseDT := _proxy.responseDT;
	self.partProcessResponseStr :=_proxy.partProcessResponseStr;
	self.statusStr := _proxy.statusStr;
	self.status := _proxy.statusStr;											//navra1 - 26th Feb 2024 - DEFECT 62247
	self.myExtWebserviceDef := _proxy.myExtWebserviceDef;
	self.direction := _proxy.direction;
	self.interfaceName := _proxy.interfaceName;
	self.request:= _proxy.request;		
	self.response := _proxy.response;
	self.responseCode := _proxy.responseCode;
	self.partUniqueRefNumber := _proxy.partUniqueRefNumber;	
	self.description := _proxy.description;
epilog

end;</source>
        <Parameter name="_proxy" type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setProxyOnReceive" id="54be05e6-d283-4760-b2d8-018c7d146274">
        <updating/>
        <source>setProxyOnReceive(_uniqueNumber: String; _requestMessage: String; _processingResult : String; _responseCode: Integer; _responseMessage : String; _extWebServiceDef : CM_ExternalWebServiceDef) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 November 2023	navra1	Initial creation for TFS 54090 - EUP | EUP | Interface - MTN Invoicing Oracle &lt;&lt;54090&gt;&gt;(CR 61356/Task 61377)

*/

vars

begin
	self.myTerminal :=  app.myPassport.myTerminal;
	self.myRoot:=app.myRoot;
	self.createdUser := app.getMyUserCode();
	self.created := app.actualTimeServer();
	
	self.direction := self.DIRECTION_RECEIVE;
	self.request:= _requestMessage;		
	self.response := _responseMessage;	
	self.responseCode:=_responseCode;	
	self.partUniqueRefNumber := _uniqueNumber;	
	self.myExtWebserviceDef := _extWebServiceDef;
	self.interfaceName := ExternalWebServiceInvoiceAPI;
	self.description := self.DIRECTION_RECEIVE &amp;  "-EWSActivityInvoiceAPIResp-" &amp; Space &amp; self.partUniqueRefNumber;
	self.interfaceName := ExternalWebServiceInvoiceAPI;
	self.statusStr := CM_EWSActivityInvoiceAPIParts.RECEIVE_STATUS;																				//navra1 - 26th Feb 2024 - DEFECT 62247
	self.status := CM_EWSActivityInvoiceAPIParts.RECEIVE_STATUS;																				//navra1 - 26th Feb 2024 - DEFECT 62247
	
epilog

end;</source>
        <Parameter name="_uniqueNumber" type="String"/>
        <Parameter name="_requestMessage" type="String"/>
        <Parameter name="_processingResult" type="String"/>
        <Parameter name="_responseCode" type="Integer"/>
        <Parameter name="_responseMessage" type="String"/>
        <Parameter name="_extWebServiceDef" type="CM_ExternalWebServiceDef"/>
    </JadeMethod>
    <JadeMethod name="setProxyOnSend" id="90c5f0d2-6a91-4434-8f86-2ac2c212e106">
        <updating/>
        <source>setProxyOnSend(_eWSInvoiceMessageParent : CM_EWSActivityInvoiceAPI; _messageSent : String; _sendResponse : Integer; _sendResponseStr : String; _msgStatusStr : String; _extWebServiceDef : CM_ExternalWebServiceDef;_requestName : String) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 November 2023	navra1	Initial creation for TFS 54090 - EUP | EUP | Interface - MTN Invoicing Oracle &lt;&lt;54090&gt;&gt;(CR 61356/Task 61377)
16/9/24 	jlier1	TFS 65962 : CR 65949 NSW | Dynamic Integration Development
*/

vars
	invoice : CM_Invoice;
	jsonHelper : JadeJson;
	invoiceMessageFull : CMIF_InvoiceExtractFullObject;
	transientObjs : ObjectArray;
	hadException : Boolean;
begin
	if _eWSInvoiceMessageParent.myInvoice &lt;&gt; null then
		self.myTerminal :=  _eWSInvoiceMessageParent.myInvoice.myTerminal;
	else
		self.myTerminal:= _eWSInvoiceMessageParent.myTerminal;
	endif;
	
	self.myRoot:=app.myRoot;
	self.createdUser := app.getMyUserCode();
	self.created := app.actualTimeServer();
	
	self.direction := self.DIRECTION_SEND;
	self.myEWSInvoiceMessageParent := _eWSInvoiceMessageParent;
	self.messagePartStr := _messageSent;
	self.partNumber := _eWSInvoiceMessageParent.allEWSMessageParts.size() + 1;
	self.partSendResponse := _sendResponse;
	self.partSendResponseStr := _sendResponseStr;
	self.sendDT := app.actualTimeServer();	
	self.requestName:=_requestName;
	create jsonHelper transient;
	create transientObjs transient;	
	app.writeLog("Actual Message - " &amp; app.actualTimeServer.asStringJMT &amp; "-"	&amp; _messageSent, LogINFO);
	on Exception do app.handleJSONParsingException(exception, hadException);
	invoiceMessageFull := jsonHelper.parse(_messageSent, CMIF_InvoiceExtractFullObject, transientObjs).CMIF_InvoiceExtractFullObject;
	
	if invoiceMessageFull &lt;&gt; null and invoiceMessageFull.metaData &lt;&gt; null then
		self.partUniqueRefNumber := invoiceMessageFull.metaData.invoiceMessageUniqueIdentifier;
	else
		self.partUniqueRefNumber:=_requestName;
	endif;
	//DONT RECONSTRUCT THE UNIQUE ID, YOU ALREADY HAVE IT IN THE MESSAGE, SO GET IT FROM THAT
	//invoice := _eWSInvoiceMessageParent.myInvoice;
	//self.partUniqueRefNumber := invoice.bank.code &amp; "-" &amp; invoice.myTerminal.code &amp; "-" &amp; invoice.externalNumber &amp; "-" &amp; invoice.sequenceNum.String &amp; "-" &amp;  _eWSInvoiceMessageParent.attemptNumber.String &amp; "-" &amp; (_eWSInvoiceMessageParent.allEWSMessageParts.size() + 1).String;
	
	self.statusStr := _msgStatusStr;
	self.status := _msgStatusStr;						//navra1 - 26th Feb 2024 - DEFECT 62247
	self.response := _sendResponseStr;
	self.request := _messageSent;
	self.responseCode := _sendResponse;
	self.myExtWebserviceDef := _extWebServiceDef;	
	self.description := self.DIRECTION_SEND &amp;  "-EWSActivityInvoiceAPI-" &amp; self.partUniqueRefNumber;
	self.interfaceName := ExternalWebServiceInvoiceAPI;
	
epilog
	if transientObjs &lt;&gt; null then
		transientObjs.purge();
	endif;
	delete transientObjs;
	delete jsonHelper;

end;</source>
        <Parameter name="_eWSInvoiceMessageParent" type="CM_EWSActivityInvoiceAPI"/>
        <Parameter name="_messageSent" type="String"/>
        <Parameter name="_sendResponse" type="Integer"/>
        <Parameter name="_sendResponseStr" type="String"/>
        <Parameter name="_msgStatusStr" type="String"/>
        <Parameter name="_extWebServiceDef" type="CM_ExternalWebServiceDef"/>
        <Parameter name="_requestName" type="String"/>
    </JadeMethod>
    <JadeMethod name="updateProxy" id="1efbe3dc-63f3-49eb-8cbe-c6ea15e0e437">
        <updating/>
        <source>updateProxy(_responseDate : String; _invoiceProcessingResult: String; _responseMessage : String) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 November 2023	navra1	Initial creation for  TFS 54090 - EUP | EUP | Interface - MTN Invoicing Oracle &lt;&lt;54090&gt;&gt;(CR - 61414, Task - 61415 &amp; 61415)

*/

vars

begin
	self.responseDT := _responseDate.TimeStamp;
	//if conversion was not possible from the string we got, record current time
	if self.responseDT.String="*invalid*" then
		self.responseDT := app.actualTimeServer();
	endif;
	
	if _invoiceProcessingResult = "SUCCESS" then
		self.statusStr := CM_EWSActivityInvoiceAPIParts.INV_API_PART_STAT_SUCCESS;
		self.status := CM_EWSActivityInvoiceAPIParts.INV_API_PART_STAT_SUCCESS;				//navra1 - 26th Feb 2024 - DEFECT 62247
		self.partProcessResponse := 200;
	else
		self.statusStr := CM_EWSActivityInvoiceAPIParts.INV_API_PART_STAT_ERROR;
		self.status := CM_EWSActivityInvoiceAPIParts.INV_API_PART_STAT_ERROR;				//navra1 - 26th Feb 2024 - DEFECT 62247
		self.partProcessResponse := 500;
	endif;
	
	self.partProcessResponseStr := _responseMessage;

epilog

end;</source>
        <Parameter name="_responseDate" type="String"/>
        <Parameter name="_invoiceProcessingResult" type="String"/>
        <Parameter name="_responseMessage" type="String"/>
    </JadeMethod>
</Class>
