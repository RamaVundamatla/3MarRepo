    <JadeMethod name="deleteHarbour" id="14af4f63-ef83-4897-92de-7c9c283b48bd">
        <source>deleteHarbour(_harbourId : String);

/*

Purpose:			Delete a harbour	

Date				Who		Reason
20 December 2011	cnwmh5	Initial creation

*/

vars

	hmsObject 			: HMS_Object;
	movementPath		: HMS_MovementPath;
	pathSegment			: HMS_PathSegment;
	checkPoint			: HMS_CheckPoint;
	region				: HMS_HarbourRegion;

begin

	hmsObject := app.myRoot.allHarbours[_harbourId];
	if hmsObject &lt;&gt; null then
		//beginTransaction;
		
		foreach checkPoint in hmsObject.HMS_Harbour.allCheckPoints do
			self.deleteCheckPoint(checkPoint.code, hmsObject.HMS_Harbour);
		endforeach;
		
		foreach movementPath in hmsObject.HMS_Harbour.allMovementPaths do
			self.deleteHarbourMovementPath(movementPath);
		endforeach;
		
		foreach pathSegment in hmsObject.HMS_Harbour.allPathSegments do
			self.deletePathSegment(pathSegment);
		endforeach;
		
		foreach region in hmsObject.HMS_Harbour.allRegions do
			self.deleteWaypoint(region);
		endforeach;
		
	
		app.myTrxDA.trxDeleteHMSObject(hmsObject, app.myPassport);
		self.assertNoTrxErrorsOrWarnings();
		//commitTransaction;
	endif;		

epilog

end;</source>
        <Parameter name="_harbourId" type="String"/>
    </JadeMethod>
