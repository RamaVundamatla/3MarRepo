    <JadeMethod name="resolveInterchangeArea" id="92c0096b-45df-4094-993d-15ec99af170a">
        <source>resolveInterchangeArea(_propertyName : String; _key : String) : Object;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 January 2026	naviv1	Initial creation

*/

vars
	terminal : CM_Terminal;
	ta : CM_TAByIdDict;
	icArea : CM_TerminalArea;
begin
	if _propertyName = CM_InterchangeArea::myTerminal.name then
		return app.myRoot.allTerminals[_key];
	elseif _propertyName = CM_InterchangeArea::id.name then
		terminal := self.getMyTerminal();
		ta := terminal.getAllTAsOfType(TA_TYPE_YARD_INTERCHANGE);
		icArea := ta[_key].CM_YardInterchangeArea;
		return icArea;
		//return terminal.allTerminalAreasByTypeId[TA_TYPE_YARD_INTERCHANGE,_key];
	endif;
	return null;
epilog

end;</source>
        <Parameter name="_propertyName" type="String"/>
