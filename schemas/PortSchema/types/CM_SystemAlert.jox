    <JadeMethod name="add" id="20a148ca-13a7-4a4f-b1b9-bb2e2880fbf1">
        <updating/>
        <source>add() updating;
//Adds this transient to the alert manager, we commit ourselves at
//end or abort transaction.
vars
begin
	//The alertManager is TRANSIENT, and therefore unaffected by
	//begin/end transaction calls.
	//The alerts are also transient.
 	app.alertManager.addAlert(self);
end;</source>
    </JadeMethod>
    <JadeMethod name="addLogEntry" id="03a6199b-789c-4083-9f24-4e33fa629dd5">
        <updating/>
        <source>addLogEntry(str : String) updating;
//Simple method to add a log entry to this object.
//We use it to determine who or why we did what we did!
// 14/12/2010	cnwcs5	ccms mes 1112 / par 24464 - format time correctly
vars
	now : TimeStamp;
begin
	if self.logDetails = null then
		create self.logDetails transient;
	endif;
	now := app.actualTimeServer();	// 16 Sept 2016	cnwns1	TFS 488 - Multi Timezone Support
	//Add the date/Time to the value added.
	self.logDetails.add(now.date.shortFormatJMT() &amp; " " &amp; now.time.asStringJMT() &amp; " " &amp; str);	// 14/12/2010 cnwcs5 ccms mes 1112 / par 24464
end;</source>
        <Parameter name="str" type="String"/>
    </JadeMethod>
    <JadeMethod name="commitAlert" id="cb68807b-e94b-4ace-844d-0e4655f4889e">
        <updating/>
        <source>commitAlert() updating;
//Adds this alert to the terminal's list of PERSISTANT alerts.
vars
	tmpTerminal	: CM_Terminal;
begin

	tmpTerminal := self.myTerminal;

	if tmpTerminal = null then
		if self.getLinkedTo() = null then
			tmpTerminal := app.getMyTerminalDO_NOT_USE();
		//epr par 25504 - alert alarms were not being raised
		elseif self.getLinkedTo.respondsTo(IF_AlertAlarm) then
			tmpTerminal:=self.getLinkedTo.IF_AlertAlarm.getTerminalForAlert;
		endif;
		self.myTerminal := tmpTerminal;
	endif;
	
	if tmpTerminal = null then
		self.myRoot := app.myRoot;
	endif;
	
	app.causeEventForSystemAlertType(self, tmpTerminal); 	//+ cnwmd1 CCMS 1871
	
	/*if tmpTerminal = null then //cnwmd1 - commented out this section, and copied relevant parts above in order to tidy up.
		self.myRoot := app.myRoot;
		
		//Moved to app.causeEventForSystemAlertType  //cnwmd1 CCMS 1871
		tmpRoot := app.myRoot;
		self.myRoot := tmpRoot;
		//if not self.getLinkedTo() &lt;&gt; null and tmpRoot &lt;&gt; null then
		if tmpRoot &lt;&gt; null then
			tmpRoot.causeEvent(EventSystemAlertAdd, false, self);
		endif;
		//End of move
		
//	else
		//tmpTerminal.causeEvent(tmpTerminal.getTerminalEvent(EventTerminalAlertAdd), false, self); //- cnwmd1, CCMS 1871
	//	app.causeEventForSystemAlertType(self, tmpTerminal); //+ cnwmd1 CCMS 1871
	endif;*/
end;</source>
    </JadeMethod>
    <JadeMethod name="create" id="e7ffbb79-5e89-4139-85ce-80b02806fa0d">
        <updating/>
        <source>create() updating;
//Constructor.
vars
	now : TimeStamp;
begin
	dateTime := app.actualTimeServer();
	userCode := app.userName;	//Safe here, we have 30 bytes
	//-----------------
	//If there is no alert manager, create one now!
	//-----------------
	if app.alertManager = null then
		create app.alertManager transient;
	endif;	
	
end;</source>
    </JadeMethod>
    <JadeMethod name="delete" id="b38f165a-1030-4d4a-adff-ee0a5601cce2">
        <updating/>
        <source>delete() updating;

// Created by cnwdvb1 on 22 November 2006

vars

	alertManager : CM_AlertManager;
	invalid: Boolean;

begin

	if self.logDetails &lt;&gt; null then
		delete self.logDetails;
	endif;
	
// cnwdad1 20/05/2010 - When testing PAR #24275 by running "tTestPrenote" Unit Test, found
// that this method was leaking transient CM_FailedToAutoplan" objects.
	
	on Exception do app.handleDeletedObject(exception, self.linkedTo, invalid);
	
	if self.linkedTo &lt;&gt; null and self.linkedTo.isTransient() then
		delete self.linkedTo;
	endif;
	
	// Par 12588
	if not self.isTransient then
		return;
	endif;
	/* AKB see CM_AlertManager::commitAlert which now does a PURGE that calls this DELETE and teh code below crashes, 
		was previously being handled by exception handler in CM_AlertManager::commitAlert which has been removed by TH in May2007.
		
		
	alertManager := app.alertManager;
	
	if alertManager = null then
		return;
	endif;
	
	if alertManager.alerts.includes(self) then
		alertManager.alerts.remove(self);
	endif;
*/
end;</source>
    </JadeMethod>
    <JadeMethod name="emailNotifications" id="432cdbb7-9dcc-4f1e-bc7b-dfe344d53d1f">
        <source>emailNotifications();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06 May 2010	cnwmd1	Initial creation
Could not use the existing method 

*/

vars
	addresses, subject, message, fromAddress : String;
	notifyAddresses : CM_EmailEntityByTypeNameDict;
	alertType : CM_SystemAlertType;
begin
	alertType := self.mySystemAlertType;
	notifyAddresses := alertType.allNotifyEmailAddresses;
	if notifyAddresses.size = 0 then
		return;
	endif;
	
	addresses := notifyAddresses.getNames;
	subject := alertType.description;
	message := self.details;
	fromAddress := app.myRoot.getConfig(AutoSendersEmailAddress).String;
	
	app.myTrxCA.trxCreateEmailSendRequest(	subject,
											addresses,
											fromAddress,
											null, 
											null,
											subject,
											message,
											null,
											null,
											null,
											null,
											EmailSource_System,
											null,
											app.myPassport);
											
	if not app.myPassport.trxCompletedOK then
		app.remoteErrorWarningToAlert('Could not send email', 
		null,  app.myPassport.allErrors, null, false, true);
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="erase" id="3a4474c5-7c9b-4ca9-96b0-f28a1570bcf1">
        <updating/>
        <source>erase(_eraseLevel:	Integer) updating;

vars
	alerts : CM_SystemAlertByDateTime;
	tmpRoot	: CM_Root;
	tmpTerminal	: CM_Terminal;
	linkedObject : CM_Object;
begin
	exclusiveLock(self);
//	alerts := app.getMyTerminal().systemAlerts;
//	if alerts.includes(self) then
//		alerts.remove(self);
//	endif;
	
	if logDetails &lt;&gt; null then
		delete logDetails;
		logDetails := null;
	endif;
	linkedObject:=self.getLinkedTo();
	if linkedObject &lt;&gt; null then
		if linkedObject.respondsTo(IF_AlertAlarm) then
			linkedObject.IF_AlertAlarm.removeFromAlerts(self);	
		endif;
		if linkedObject.isKindOf(CM_FailedToAutoplan) then		// 27/04/2009 cnwar2 #19401, #19524, #19522
			delete linkedObject;
		endif;
	endif;
	
	if (not self.isTransient) then
		tmpTerminal := self.myTerminal;
		if tmpTerminal &lt;&gt; null then
			tmpTerminal.causeEvent(tmpTerminal.getTerminalEvent(EventTerminalAlertDelete), false, self);
		endif;
		tmpRoot := self.myRoot;
		if tmpRoot &lt;&gt; null then
			tmpRoot.causeEvent(EventSystemAlertDelete, false, self);
		endif;
	endif;

	inheritMethod(_eraseLevel);
end;</source>
        <Parameter name="_eraseLevel" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="cb468d06-b5e5-44f1-bb27-20fc5ee5e186">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*

Purpose:			


Return Value:		


Date		Who		Reason
10 Nov 2006	cnwer1	Initial creation - PAR#xxxx
14 Mar 2011	cnwkpd1	PAR #27142 - Correct handleDeletedObject exception arming
// 10 May 2016	cnwns1	TFS 488 - Multi Timezone Support
*/

vars
	linkedTo	: CM_Object;
	invalidLinked,
	invalidYA	: Boolean;
	ya			: CM_YardAllocation;
	str			: String;
	returnVal	: String;
	
begin
	if _attrName = ETRow_Severity  then
		return null;
	elseif _attrName = ETRow_Terminal or _attrName.toLower = ETRow_Terminal then
		if self.myTerminal = null then
			//return 'System';
			return app.getErrorString(System_GC);
		else
			return self.myTerminal.code;
		endif;	
	elseif _attrName =	ETRow_Date or _attrName.toLower =	ETRow_Date then
		return self.systemToLocalTime(self.dateTime).shortCurrentLocaleFormat.String;// 10 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	elseif _attrName =  ETRow_Detail then
		return self.details;
	elseif _attrName = ETRow_Remarks 	then
		return self.remarks;
	elseif _attrName = ETRow_Reviewed 	then
		return self.reviewed.cnEcGetTableCheckBoxValue();
	elseif _attrName = ETRow_ReviewedBy 	then
		return self.reviewedBy;
	elseif _attrName = ETRow_ReviewedDate then
		return self.systemToLocalTime(self.reviewedDateTime).shortCurrentLocaleFormat.String;// 10 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	elseif _attrName = ETRow_FailedYA then
		linkedTo := self.getLinkedTo();
		if linkedTo &lt;&gt; null then
			on Exception do app.handleDeletedObject(exception, linkedTo, invalidLinked);		// PAR #27142
			if linkedTo.isKindOf(CM_YardAllocation) then
				str := linkedTo.CM_YardAllocation.code;
				if invalidLinked then
					return app.getErrorString(No_Space_Deleted);
				else
					return app.getErrorString1(No_Space, str);
				endif;
			endif;

			if linkedTo.isKindOf(CM_FailedToAutoplan) then										// PAR #27142
				ya := linkedTo.CM_FailedToAutoplan.myFirstYAFailure;
				if ya &lt;&gt; null then
					on Exception do app.handleDeletedObject(exception, ya, invalidYA);
					str := ya.code;
					if invalidYA then			
						return app.getErrorString(No_Space_Deleted);
					else
						return app.getErrorString1(No_Space, str);
					endif;
				endif;
			endif;
		endif;
		return app.getErrorString(No_Allocation);
		
	elseif _attrName = ETRow_ImexStatus  then
		linkedTo := self.getLinkedTo();
		if linkedTo.isKindOf(CM_FailedToAutoplan) then		// 27/04/2009 cnwar2 #19401, #19524, #19522
			return app.getIMEXStringFromIMEXStatus(linkedTo.CM_FailedToAutoplan.autoplanIMEXStatus);
		endif;
		return self.myTrackedItem.getDisplayStringForAttribute(_attrName, _short);
	elseif _attrName = ETRow_FailDate then
		return self.systemToLocalTime(self.dateTime).asStringJMT();  //par 19618 cnwjo3// 10 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	elseif self.myTrackedItem &lt;&gt; null then
		return self.myTrackedItem.getDisplayStringForAttribute(_attrName, _short);
	else
		return ""; // CCMS 1030
		//return inheritMethod(_attrName, _short);
	endif;

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getLastLogEntry" id="ac09151f-e5eb-4c27-9b1d-6b108135d57f">
        <source>getLastLogEntry() : String;
/*
 ------------------------------------------------------------------------
Created:			16 October 2001 by cnwdwq1
Purpose:			
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/
vars

begin
	if self.logDetails = null then
		return null;
	endif;
	return self.logDetails.last;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getLinkedTo" id="5a05452b-1e98-4a6e-b301-9df39edf13aa">
        <source>getLinkedTo(): CM_Object;

/*

Date		Who		Reason
19 May 2010	cnwkpd1	PAR #20728 - remove isValidObject calls for performance

*/

vars
	invalid 		: Boolean;
	ed				: Integer;
	
begin
	if self.linkedTo = null then
		return null;
	endif;
	
	on Exception do app.handleDeletedObject(exception, self.linkedTo, invalid);
	// dereference to check it is valid
	ed := self.linkedTo.edition();
	
	if invalid then
		return null;
	else
		return self.linkedTo;
	endif;

end;</source>
        <ReturnType type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="getMyReserveSelection" id="e817abad-3cc3-4581-8bad-301948b04a14">
        <source>getMyReserveSelection(reserveDetail : CM_ReserveDetail):CM_ReserveSelection;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
11 January 2012	cnwndl1	Initial creation	Par 28953
03 July 2025	naviv1	MTN-35171 : MTN - Optimize Satellite View Screen to Handle Large Volumes of Failed Auto Plan Alerts Efficiently
*/

vars
	invalid 		 : Boolean;
	reserveSelection : CM_ReserveSelection;
	ed				 : Integer;
begin

	on Exception do app.handleDeletedObject( exception, reserveDetail, invalid);
	
	ed := reserveDetail.edition();
	if not invalid and reserveDetail.isKindOf( CM_ReserveSelection ) then	
		reserveSelection := reserveDetail.CM_ReserveSelection;
	endif;

epilog

	return reserveSelection;

end;
</source>
        <Parameter name="reserveDetail" type="CM_ReserveDetail"/>
        <ReturnType type="CM_ReserveSelection"/>
    </JadeMethod>
    <JadeMethod name="getMyTerminal" id="9184760f-fac6-4a8e-a077-9b22c9dcaefa">
        <source>getMyTerminal(): CM_Terminal;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 May 2016	cnwns1	Initial creation

*/

vars

begin
	return self.myTerminal;

epilog

end;</source>
        <ReturnType type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="hasDetails" id="27d4118f-5981-4c82-8d52-2400b341b6b1">
        <methodInvocation>mapping</methodInvocation>
        <source>hasDetails(set: Boolean; _value: Boolean io) mapping;

vars

begin
	if set then
		app.raiseSetVirtualError(class.name, method.name);
		return;
	endif;
	if logDetails = null then
		_value := false;
		return;
	endif;
	_value := (logDetails.numStrings &gt; 0);
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Boolean" usage="io"/>
    </JadeMethod>
    <JadeMethod name="isType" id="3552afb7-734d-4ae1-b853-247a25c98a02">
        <source>isType(alertType: Integer): Boolean;
//11 November 2008	cnwdw1	
// Return true if this alert is of type alertType
vars

begin
	return self.mySystemAlertType &lt;&gt; null and self.mySystemAlertType.type = alertType;
end;</source>
        <Parameter name="alertType" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
