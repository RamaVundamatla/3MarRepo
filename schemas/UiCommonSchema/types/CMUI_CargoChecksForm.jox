    <JadeMethod name="setSealsTableForViewMode" id="e4c1cf2c-56ce-4510-b735-8bd03ff80232">
        <updating/>
        <source>setSealsTableForViewMode( allSealTypes : CM_SealTypeSet; ti : CM_TrackedItem ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 May 2014	cnwndl1	Initial creation	Par 34076
29 Jan 2024	jlier1	 TFS  62168
*/

vars

	sealType : CM_SealType;
	index : Integer;
	sealTi : CM_SealTI;

begin

	tblSeals.selectMode := Table.SelectMode_None;
	tblSeals.columns := 3;
	tblSeals.rows := 2;
	
	tblSeals.fixedRows := 2;
	tblSeals.fixedColumns := 1;
	tblSeals.accessCell(1,1).mergeCells := Table.MergeCells_Merge;

	tblSeals.setCellText(1,1,app.getErrorString1(Seal_check_mode, app.sealCheckTypeEnumToString(SEAL_CHECK_VIEW) ) );
	tblSeals.accessCell(1,1).alignment := Table.Alignment_Center_Middle;
	self.tblSeals.accessRow(1).height:=20;
	tblSeals.accessRow(2).alignment := Table.Alignment_Center_Middle;
	tblSeals.accessRow(2).fontBold := true;
	self.tblSeals.accessRow(2).height:=20;
	tblSeals.accessCell(2,2).mergeCells := Table.MergeCells_Merge;
	tblSeals.setCellText(2,1,app.getErrorString(CM_Type) );
	tblSeals.accessCell(2,1).alignment := Table.Alignment_Center_Middle;
	tblSeals.setCellText(2,2,app.getErrorString(Viewed));
	
	
	self.tblSeals.defaultRowHeight := 45;
	self.tblSeals.stretch:=Table.Stretch_None;
	
	foreach sealType in allSealTypes do
		index := tblSeals.addItem(sealType.description);
		if ti &lt;&gt; null then
			sealTi := ti.getSealTI(sealType);
		endif;
		if sealTi &lt;&gt; null then
			tblSeals.accessRow(index).itemObject := sealTi;
		else
			tblSeals.accessRow(index).itemObject := sealType;
		endif;
		self.setupCargoCheckTableYesNoBtns(self.tblSeals, index);
		
	endforeach;

epilog

end;</source>
        <Parameter name="allSealTypes" type="CM_SealTypeSet"/>
        <Parameter name="ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="setTopSheetTo" id="7ce0b0ab-66ac-4b1c-95f5-b5fb6e84a0e8">
        <updating/>
        <source>setTopSheetTo( _sht : CMUI_Sheet input ) updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21/05/2014	cnwndl1	Initial creation 34076
21/04/2015	cnwdap1	PAR #36094 CCMS SFW 1413 TFS 313 Cold Store Enhancements
06/04/2023	jlizm1	TFS 57098 EUP Seal numbers on trucks
07/02/2024	jlizm1	TFS 62142 Perform checks from voyage ops live
*/

vars

	cargoType : CM_CargoType;

begin

	_sht.visible := true;
	
	self.fldMain.topSheet := _sht;
	self.btnBack.parent :=  _sht;
	self.btnSave.parent :=  _sht;
	self.chkToDo.parent :=  _sht;
	
	self.chkToDo.visible := false;
	self.chkToDo.value := false;
	
	self.shtCargoChecks.visible := false;
	self.btnComplete.visible :=  false;
	self.lblConfirmLocation.visible := false;
	self.cmbConfirmLocation.visible := false;
	
	if self.myCurrentCheckItem &lt;&gt; null and self.myCurrentCheckItem.myToDoTaskDesc &lt;&gt; null then
		if self.myTrackedItem &lt;&gt; null then
			cargoType := self.myTrackedItem.myCargoType;
		elseif self.myGTEReceival &lt;&gt; null then
			cargoType := app.myRoot.allCargoTypesById[self.myGTEReceival.cargoType];
		endif;
		
		self.chkToDo.caption := self.myCurrentCheckItem.myToDoTaskDesc.description;
		self.chkToDo.visible := cargoType &lt;&gt; null and self.myCurrentCheckItem.myToDoTaskDesc.allCargoTypes.includes(cargoType);
		
		if self.myTrackedItem &lt;&gt; null then
			if self.myTrackedItem.allToDoTasksToDo.includesToDoDesc( self.myCurrentCheckItem.myToDoTaskDesc.code ) then
				self.chkToDo.visible := false;
			endif;
		elseif self.myGTEReceival &lt;&gt; null then
			if self.myGTEReceival.allToDoTasks.includes( self.myCurrentCheckItem.myToDoTaskDesc ) then
				self.chkToDo.visible := false;
			endif;
		endif;
		
	endif;
	
	if _sht = self.shtDamage then
		self.displayDamages();
	elseif _sht = self.shtSeals then
		self.displayTblSeals();
	elseif _sht = self.shtDimensions then
		self.displayDimensions();
	elseif _sht = self.shtWeight then
		self.displayWeight();
	elseif _sht = self.shtSpecialLifts then
		self.displaySpecialLifts();
	elseif _sht = self.shtTemperature then					// PAR #36094
		self.displayTemperature();							// PAR #36094
	endif;

epilog

end;</source>
        <Parameter name="_sht" type="CMUI_Sheet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setVoyageDetails" id="0bdfaf39-ff49-470a-85ed-bb108caf7e46">
        <updating/>
        <source>setVoyageDetails(_voyage : CM_Voyage; _transferType : Integer) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date					Who		Reason
07 February 2024		jlizm1	Initial creation TFS 62142 Perform checks from voyage ops live

*/

vars

begin
	self.myVoyage 		:= _voyage;
	self.myTransferType := _transferType;
	
epilog

end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_transferType" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setupCargoCheckTable" id="c9be5530-4870-4a85-952a-35f334e56467">
        <updating/>
        <source>setupCargoCheckTable() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06/05/2014	cnwndl1	Initial creation	Par 34076 	
15/07/2014	cnwdap1	PAR #34568 CCMS SFW 1389 Alternative Id Cargo Check
21/04/2015	cnwdap1	PAR #36094 CCMS SFW 1413 TFS 313 Cold Store Enhancements
01/08/2017	cnwdap1	TFS 5609 SNO Road Gate Check Criteria
30/01/2018	jlgdap1	TFS 36611 PEN Cannot Check Hazard
31/01/2024	jlika1	TFS 62154 62155 CUX | Photo Checks for Foreman Live
06/04/2024	jlizm1	TFS 57098 EUP Seal numbers on trucks
10/06/2024	jlika1	TFS 64158 CUX | Configurability of Foreman checks for onboard cargo
*/

vars

	cargoCheck 		: CM_CargoCheck;
	item			: CM_CargoCheckItem;
	idx				: Integer;
	jadeCol			: JadeTableColumn;
	jadeCell		: JadeTableCell;
	str				: String;
	setting			: CM_TICargoChecks;
	cmifAutoPlan	: CMIF_YAAutoPlan;
	change			: Real;
	dummyTI			: CM_TrackedItem;
	cargoType 		: CM_CargoType;

begin
	
	// create an auto plan for checking criteria
	if self.myTrackedItem &lt;&gt; null then
		create cmifAutoPlan as CMIF_YAAutoPlanNormal transient;
		cmifAutoPlan.attachTI(self.myTrackedItem);
		
	elseif self.myGTEReceival &lt;&gt; null then
		cargoType := app.myRoot.allCargoTypesById[self.myGTEReceival.cargoType];
		create cmifAutoPlan as CMIF_YAAutoPlanSenario transient;
		create dummyTI as cargoType.myClassToCreate transient;
		dummyTI.setCargoType(self.myGTEReceival.cargoType);
		dummyTI.setMyProduct(self.myGTEReceival.myProduct);		
		cmifAutoPlan.attachTI(dummyTI);
		dummyTI.setPxyFromCMGTE_Receival( self.myGTEReceival, app.myPassport );
		cmifAutoPlan.CMIF_YAAutoPlanSenario.requiresPower := self.myGTEReceival.isReefer;		// PAR #36094
		cmifAutoPlan.CMIF_YAAutoPlanSenario.populateFromReceival(self.myGTEReceival);				// TFS 5609
	
	elseif self.myVehicleVisit &lt;&gt; null then
		self.setupForTruckSealChecks();
		return;
	endif;
	
	if self.myCargoChecks = null or self.myCargoChecks.allCargoCheckItems.isEmpty then
		self.unloadForm;
		return;
	endif;
	
	
	// load table with current context Cargo Check Items
	foreach item in self.myCargoChecks.allCargoCheckItems discreteLock do
	
		if item.requiredExtraInfo &lt;&gt; null 
		and not item.requiredExtraInfo.isOneOf(	EXTRA_INFO_SEALS, 
												EXTRA_INFO_DAMAGE, 
												EXTRA_INFO_DIMENSION, 
												EXTRA_INFO_WEIGHT, 
												EXTRA_INFO_SPECIAL_LIFT, 
												EXTRA_INFO_ALTERNATIVE_ID, 				// PAR #34568
												EXTRA_INFO_TEMPERATURE,					// PAR #35094
												EXTRA_INFO_HAZARD_SYMBOLS,				// TFS 36611
												EXTRA_INFO_PHOTO) then		
			continue;
		endif;
		
		// does this tracked item match the cargo check criteria?
		if cmifAutoPlan &lt;&gt; null and not item.doesTIMatchMe(cmifAutoPlan) then
			continue;
		endif;

		idx := self.tblCargoChecks.addItem(item.name);
		self.tblCargoChecks.accessRow(idx).itemObject := item;
		
		// set cell control according to item's required extra info
		// if item is required, add two buttons Yes/No
		if item.required then	
			self.setupCargoCheckTableYesNoBtns( self.tblCargoChecks, idx );	
		else	
			//jlier1 TFS 62168 29/1/24
			// add a button
			self.tblCargoChecks.accessCell(idx, self.ColumnValue).picture := self.btnTick.createPicture(false, false, 32);
			// merge the second and third columns
			self.setupCargoCheckTableMergeCells( idx );	
		endif;
		
	endforeach;
	
	// PAR #36094 If we hav no cargo checks in the table (because they've been filtered out by criteria			// PAR #36904
	// on the check) just unload the form - otherwise we get a blank form showing, which is silly				// PAR #36904
	if not self.shouldShowLocationCheck() and self.tblCargoChecks.rows = self.tblCargoChecks.fixedRows then		// PAR #36904
		self.unloadForm;																						// PAR #36904
		return;																									// PAR #36904
	endif;																										// PAR #36904
		
	self.tblCargoChecks.tabKey := J_key_Tab;

epilog

	delete cmifAutoPlan;
	delete dummyTI;

end;</source>
    </JadeMethod>
    <JadeMethod name="setupCargoCheckTableMergeCells" id="5cd5f91f-af96-4b98-ac1b-14eebf3dc4b8">
        <updating/>
        <source>setupCargoCheckTableMergeCells( _row : Integer ) updating, protected;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 May 2014	cnwndl1	Initial creation	Par 34076

*/

vars
	jadeCell : JadeTableCell;

begin
	jadeCell := self.tblCargoChecks.accessCell(_row, self.ColumnValue);
	jadeCell.mergeCells := self.tblCargoChecks.MergeCells_Merge;
	jadeCell.alignment := Table.Alignment_Center_Middle; 
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_row" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setupCargoCheckTableYesNoBtns" id="e4c7a3ed-7b22-4158-b069-cb95dc19d373">
        <updating/>
        <source>setupCargoCheckTableYesNoBtns( _table : CM_DataTable input; _row : Integer ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 May 2014	cnwndl1	Initial creation	Par 34076

*/

vars
	jadeCell : JadeTableCell;
    obj             : Object;               //MTN-34506
    ti              : CM_TrackedItem;       //MTN-34506
    cargoCheckItem  : CM_CargoCheckItem;    //MTN-34506
    cargoCheck      : CM_CargoCheck;        //MTN-34506
begin
	jadeCell := _table.accessCell(_row, self.ColumnValue);
    
    /*  MTN-34506 - navsp1 - in progress
    obj := self.tblCargoChecks.accessRow(_row).itemObject;
    if obj.isKindOf(CM_CargoCheckItem) then
        cargoCheckItem:= obj.CM_CargoCheckItem;
        cargoCheck  := cargoCheckItem.myCargoCheck;
        ti := self.myTrackedItem;
        if ti &lt;&gt; null then
            if ti.isCargoCheckComplete(cargoCheck.context) then           
                jadeCell.picture := self.btnTickDown.createPicture(false, false, 32);
            else
                jadeCell.picture := self.btnTick.createPicture(false, false, 32);
            endif;
        endif;
    endif;
    */
	jadeCell.picture := self.btnTick.createPicture(false, false, 32);
	jadeCell.mergeCells := _table.MergeCells_NotAvailable;
	jadeCell.alignment := Table.Alignment_Center_Middle;  
	jadeCell.foreColor:=_table.backColor;
	jadeCell := _table.accessCell(_row, self.ColumnValueExtra);
	jadeCell.picture := self.btnCross.createPicture(false, false, 32);
	jadeCell.mergeCells := _table.MergeCells_NotAvailable;
	jadeCell.alignment := Table.Alignment_Center_Middle;  
	jadeCell.foreColor:=_table.backColor;
epilog

end;</source>
        <Parameter name="_table" type="CM_DataTable" usage="input"/>
        <Parameter name="_row" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setupChildSelectTable" id="afb58c17-96bd-4b97-8d6d-adda1ecbbd2e">
        <updating/>
        <source>setupChildSelectTable() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
01 Feb 2024			jlizm1	Initial creation TFS 62142 Perform checks from voyage ops live
10 Jun 2024			jlika1	TFS 64158 CUX | Configurability of Foreman checks for onboard cargo
*/
vars
	table 			: CM_DataTable;
	ti 				: CM_TrackedItem;
	idx 			: Integer;
	jadeCell		: JadeTableCell;
	childCargoNA	: CM_TISet;
begin
	if self.myCargoChecks = null or self.myCargoChecks.allCargoCheckItems.isEmpty then
		// there are no checks to do, so just unload form
		self.unloadForm;
		return;
	endif;
	
	self.grpMain.visible := false;
	self.grpCargoSelect.visible := true;
	
	table := self.tblChildCargo;
	table.visible := true;
	table.clear();
	table.rows := 0;
	table.fixedRows := 0;
	table.columns := 2;
	table.selectMode := Table.SelectMode_None;
	table.defaultRowHeight := self.btnCheck.height.Integer + 3;
	table.columnWidth[2] := self.btnCheck.width.Integer + 9;
	
	create childCargoNA transient;
	
	foreach ti in self.allChildCargo do		
		if ti.hasCargoChecksByContext(self.myCargoChecks.context) then			
			idx := table.addItem(ti.id);	
			jadeCell := table.accessCell(idx, self.ColumnValue);
			if ti.isCargoCheckComplete(self.myCargoChecks.context) then
				jadeCell.picture := self.btnCheckDown.createPicture(false, false, 24);
			else
				jadeCell.picture := self.btnCheck.createPicture(false, false, 24);
			endif;			
			
			jadeCell.mergeCells := table.MergeCells_NotAvailable;
			jadeCell.alignment := Table.Alignment_Center_Middle; 
			table.accessRow(idx).itemObject := ti;
		else
			childCargoNA.add(ti);
		endif;		
	endforeach;
	
	foreach ti in childCargoNA do
		idx := table.addItem(ti.id);	
		jadeCell := table.accessCell(idx, self.ColumnValue);		
		jadeCell.picture := self.btnCheckNA.createPicture(false, false, 24);		
		jadeCell.enabled := false;
		jadeCell.mergeCells := table.MergeCells_NotAvailable;
		jadeCell.alignment := Table.Alignment_Center_Middle;		
		table.accessRow(idx).itemObject := ti;
		
		app.myTrxUA.trxUpdateTICheckCompleted(self.myCargoChecks.context, true, ti, self.effectiveDT, app.myPassport);		//20.02.2024 navhl20 #62525
	endforeach;
		
	if self.myParentTI &lt;&gt; null and self.myParentTI.isCargoCheckComplete(self.myCargoChecks.context) then
		self.btnCheckParent.value := true;
	endif;
		
	if self.isAllChildChecksComplete then
		self.btnCheckParent.enabled := true;
	else
		self.btnCheckParent.enabled := false;
	endif;
	
	if childCargoNA.size = self.allChildCargo.size  then 
		self.btnCheckParent.enabled := true;
	endif;	
	
epilog
	delete childCargoNA;
end;</source>
    </JadeMethod>
    <JadeMethod name="setupForTruckSealChecks" id="92d1e9d1-41c5-4d2d-b10a-7426ef4c6ce0">
        <updating/>
        <source>setupForTruckSealChecks() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
06 April 2023		jlizm1	Initial creation TFS 57098 EUP Seal numbers on trucks
13 September 2023	jlizm1	TFS 59985 Truck Seals design changes

*/

vars

	sealType : CM_SealType;
	index : Integer;
	sealTi : CM_SealTI;
	vvr : CM_VehicleVisitRecord;
	mess : String;
	truckSealTypes : CM_SealTypeSet;

begin
	
	self.shtSeals.visible := true;
	self.fldMain.topSheet := self.shtSeals;
	
	self.btnBack.visible := false;
	self.btnSave.parent :=  self.shtSeals;
	
	self.chkToDo.visible := false;
	self.chkToDo.value := false;
	
	self.shtCargoChecks.visible := false;
	self.btnComplete.visible :=  false;
	
	vvr := self.myVehicleVisit;
	
	if vvr = null then
		mess := app.getErrorString(There_nothi_selec_perfo_seal_c);
		app.msgBox( mess, app.getErrorString(Error) , MsgBox_OK_Only);
		return;
	endif;
	
	if tblSeals.rows - tblSeals.fixedRows = 0 then
		mess := app.getErrorString(No_Seal_types_for_cargo_type);//"No Seal types declared for cargo type that are available for entry.";
		app.msgBox( mess, app.getErrorString(Error) , MsgBox_OK_Only);
		return;
	endif;

	if vvr.myRoadJob &lt;&gt; null and vvr.myRoadJob.isRelease then
		self.sealCheckType := self.myTerminal.sealCheckTruckLoad;
	else
		self.sealCheckType := self.myTerminal.sealCheckTruckDischarge;
	endif;
	
	if self.sealCheckType = SEAL_CHECK_DEFAULT.Integer then
		self.sealCheckType := SEAL_CHECK_NONE;
	endif;
	
	tblSeals.clear();
	
	create truckSealTypes transient;
	foreach sealType in app.myRoot.allTruckSealTypes do
		if sealType.notAvailableForEntry then
			continue;
		endif;
		truckSealTypes.add(sealType);
	endforeach;
	
	if self.sealCheckType = SEAL_CHECK_NONE  then // 1
		self.setSealsTableForNoneMode();

	elseif self.sealCheckType = SEAL_CHECK_VIEW then	// 2
		self.setSealsTableForViewMode( truckSealTypes, null );	// sealName column and Yes / No  columns only
	
	elseif self.sealCheckType = SEAL_CHECK_FULL then	// 3
		self.setSealsTableForFullMode( truckSealTypes, null );	// type and value columns only
	
	elseif self.sealCheckType = SEAL_CHECK_STRICT then	//4
		self.setSealsTableForStrictMode( truckSealTypes, null );	// type and value columns only
	
	else
		mess := app.getErrorString(Invalid_seal_check_type) &amp; " [" &amp; self.sealCheckType.String &amp; "]" &amp; CrLf &amp; app.getErrorString(Pleas_ensur_that_seals_check_v);
		app.msgBox( mess, app.getErrorString(Error) , MsgBox_OK_Only);
		
	endif;
	
epilog
	delete truckSealTypes;
end;</source>
    </JadeMethod>
    <JadeMethod name="setupForVoyageOpsChecks" id="70c9cb4a-b04c-4bdf-9009-ad66e571faf5">
        <updating/>
        <source>setupForVoyageOpsChecks() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
01 February 2024	jlizm1	Initial creation TFS 62142 Perform checks from voyage ops live

*/

vars
	children : CM_TISet;
	
begin
	self.grpMain.visible := false;
	self.grpCargoSelect.visible := true;
	
	if self.myTrackedItem = null then
		return;
	endif;
	
	if not self.allChildCargo.isEmpty then
		return;
	endif;
	
	if self.myCargoChecks = null or self.myCargoChecks.allCargoCheckItems.isEmpty then
		self.unloadForm;
		return;
	endif;
	
	create children transient;
	
	if self.myTrackedItem.isChild then
		self.myParentTI := self.myTrackedItem.myParent;
		self.myParentTI.getAllChildren(children);
		self.lblParentCargoId.caption := app.getErrorString(ContainerID);
		self.lblChildToCheck.caption := app.getErrorString(Child_cargo_check);
		
	elseif self.myTrackedItem.isOnTrailer then
		self.myParentTI := self.myTrackedItem.getCurrentTrailer;
		self.myParentTI.CM_TILC.getAllOnboardTIs(children);
		self.lblChildToCheck.caption := app.getErrorString(Onboard_cargo_check);

		if self.myParentTI.isMAFI then
			self.lblParentCargoId.caption := app.getErrorString(MAFI_ID);
		else
			self.lblParentCargoId.caption := app.getErrorString(Trailer_ID);
		endif;
		
	elseif self.myTrackedItem.isContainer then
		self.myParentTI := self.myTrackedItem;
		self.myParentTI.getAllChildren(children);
		self.lblParentCargoId.caption := app.getErrorString(ContainerID);
		self.lblChildToCheck.caption := app.getErrorString(Child_cargo_check);
		
	elseif self.myTrackedItem.isChassis then
		self.myParentTI := self.myTrackedItem;
		self.myParentTI.CM_TILC.getAllOnboardTIs(children);
		self.lblChildToCheck.caption := app.getErrorString(Onboard_cargo_check);
		
		if self.myParentTI.isMAFI then
			self.lblParentCargoId.caption := app.getErrorString(MAFI_ID);
		else
			self.lblParentCargoId.caption := app.getErrorString(Trailer_ID);
		endif;
	endif;		

	
	if children.isEmpty then
		// we're just a single cargo item so go straight to checks
		self.grpMain.visible := true;
		self.grpCargoSelect.visible := false;
		self.buildCmbConfirmLocation(self.myTrackedItem);
		return;
	endif;
	
	self.lblDesc3.caption := self.myParentTI.id &amp; " " &amp; self.myParentTI.cargoTypeDescr;
	children.copy(self.allChildCargo);
	self.btnCheckParent.userObject := self.myParentTI;
	self.buildCmbConfirmLocation(self.myParentTI);
	
epilog
	delete children;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="7ae4ff67-b2bc-42a3-adb6-b9ec77c3e430">
        <updating/>
        <source>setupForm() updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06/05/2014	cnwndl1	Initial creation	Par 34076
06/04/2023	jlizm1	TFS 57098 EUP Seal numbers on trucks
01/02/2024	jlizm1	TFS 62142 Perform checks from voyage ops live
10/06/2024	jlika1	TFS 64158 CUX | Configurability of Foreman checks for onboard cargo
21/11/2024	jlizm1	MTN 33013 Retain Cargo Check form size and position
*/
vars

	desc1 : String;
	desc2 : String;

begin

	if not app.myPassport.allWarnings.isEmpty then
		self.allGTEWarningsToIgnore.copyErrors( app.myPassport.allWarnings );
		app.myPassport.clearErrorsWarnings();
	endif;
	
	create self.myAssistant as CMUI_Assistant;
	self.myAssistant.myTerminal := self.myTerminal;

	self.handleMenusForModalDisplay;

	self.width := 400;
	self.minimumWidth := 300;
	self.height := 450;
	
	self.grpMain.left := 1;
	self.grpMain.top := 1;
	self.grpMain.height := self.clientHeight - 2;
	self.grpMain.width := self.clientWidth - 2;
	self.grpMain.parentAspect := 3;
	
	self.grpCargoSelect.left := 1;
	self.grpCargoSelect.top := 1;
	self.grpCargoSelect.height := self.clientHeight - 2;
	self.grpCargoSelect.width := self.clientWidth - 2;
	self.grpCargoSelect.parentAspect := 3;
	
	self.centreOverParent(1);
	
	if self.isVoyageOpsContext then
		self.setupForVoyageOpsChecks();
	endif;
	
	inheritMethod();
	
	self.getXMLSettingsForSetup();
	
	self.clickBack( null );

	if self.myTrackedItem &lt;&gt; null then
		self.txtCargoId.text := self.myTrackedItem.id;
		
		self.myTrackedItem.getShortDescriptions( desc1, desc2  );
		self.lblDesc1.caption := desc1;
		self.lblDesc2.caption := desc2;
		
	elseif self.myGTEReceival &lt;&gt; null then
		self.txtCargoId.text := self.myGTEReceival.id;
		self.lblDesc1.caption := self.myGTEReceival.getCargoTypeDescription;
		self.lblDesc2.caption := null;
	
	elseif self.myVehicleVisit &lt;&gt; null then
		self.lblCargoId.visible := false;
		self.txtCargoId.visible := false;
		self.lblDesc1.caption := app.getErrorString(Carrier) &amp; ": " &amp; self.myVehicleVisit.carrierCode;
		self.lblDesc2.caption := app.getErrorString(Truck) &amp; ": " &amp; self.myVehicleVisit.regNumber;
		
	endif;
	
	self.lblConfirmLocation.visible := false;
	self.cmbConfirmLocation.visible := false;
	
	self.initCargoChecksTable();
	
	if grpMain.visible then
		// normal checks
		self.setupCargoCheckTable();
	elseif grpCargoSelect.visible then
		// voyage ops checks
		self.setupChildSelectTable();
	endif;
	
	if self.shouldShowLocationCheck() then
		self.lblConfirmLocation.visible := true;
		self.cmbConfirmLocation.visible := true;
	endif;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="shouldShowLocationCheck" id="ff7f9b24-cd22-4f9c-bacf-784730e31ecf">
        <source>shouldShowLocationCheck() : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date					Who		Reason
07 February 2024		jlizm1	Initial creation TFS 62142 Perform checks from voyage ops live

*/

vars
	item : CM_CargoCheckItem;
	
begin
	// Location Check is only valid in voyage ops live checks
	if not self.isVoyageOpsContext then
		return false;
	endif;
	
	// only need to check location on the parent cargo, not child or onboard cargo
	if not self.isCheckingMainCargo then
		return false;
	endif;
	
	// location check must be the last check to be done, so all required checks need to be completed first
	if not self.requiredChecksComplete then
		return false;
	endif;
	
	// only show location check if required
	foreach item in self.myCargoChecks.allCargoCheckItems discreteLock do
		if item.requiredExtraInfo = EXTRA_INFO_LOCATION_CHECK then
			return true;
		endif;
	endforeach;
	
	return false;
	
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="showAdvCargoDamageForm" id="47813411-5a32-4634-90f2-9aa5efe56f3f">
        <updating/>
        <source>showAdvCargoDamageForm() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 Feb 2025	navnk30	JIRA 33887: MTN | Road Gate In Checks throws error for damage check that is Inappropriate.
11 Feb 2025	navnk30	JIRA 33889: CUX | Voyage Ops Live Form cargo checks Form - Unable to Save Keep on loading.

*/

vars
	pxyGteEntity	: CMGTE_Entity;
begin
	if self.myGTEReceival &lt;&gt; null then								//11.02.2025 navnk30 JIRA 33889
		pxyGteEntity := self.myGTEReceival.pxyGetProxyObject();
		
		if pxyGteEntity = null then
			beginLoad;
				pxyGteEntity := self.myGTEReceival.pxyCreateUpdateProxy();
			endLoad;
		endif;
		
		self.myAssistant.showDamageEntryForm(self, CMUI_DamageCodesAdvanceForm.Mode_Update, self.myTerminal, pxyGteEntity, null, pxyGteEntity.allDamageInstancesByPos, null, true);
		self.updateDamages(null, null, false, self.myTerminal);
	elseif self.myTrackedItem &lt;&gt; null then							//11.02.2025 navnk30 JIRA 33889
		self.myAssistant.showDamageEntryForm(self, CMUI_DamageCodesAdvanceForm.Mode_Update, self.myTerminal, null, self.myTrackedItem, null, null, true);
	endif;
epilog
	if app.isValidObject(pxyGteEntity) then
		delete pxyGteEntity;
	endif;
end;</source>
    </JadeMethod>
