    <JadeMethod name="create" id="3f66f314-824a-4f00-997e-f8afeffc8ecc">
        <updating/>
        <source>create() updating;

// Note that we do not expect this class to be subclassed!
// If it ever is, the following line will not find the jtdAllProfileText method
// in the methods dictionary of the subclass (unless it has been reimplemented)
// in which case jtdMyProfileTextMethod will be null and the driver will not be
// able to see any profiles.
// For this reason, if we cannot find a jtdAllProfileText method, we display an
// error message and terminate.

begin
	self.jtdMyProfileTextMethod := self.class.rootType.jtdGetMethods["jtdAllProfileText"];
	
	if self.jtdMyProfileTextMethod = null then
		// this call to jtdErrorMsg will terminate the app
		self.jtdErrorMsg("Cannot find method jtdAllProfileText on class " &amp; self.class.name &amp;
			" in schema " &amp; currentSchema.name &amp; '.' &amp; CrLf &amp; CrLf &amp; "This suggests that" &amp;
			" the driver framework has been modified or is incomplete." &amp; CrLf &amp;
			"Without this method, the driver framework cannot function properly.", true);
	endif;
	
	self.jtdGetEventNumbers;
end;</source>
    </JadeMethod>
