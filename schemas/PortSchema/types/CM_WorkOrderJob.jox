    <JadeMethod name="getRegNumber" id="571209f0-d44b-4276-8030-7eabaa4923ba">
        <source>getRegNumber():CM_Job;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 Sep 2023 navhl20 Bug 60615: MTN - Release by type work order job is not appearing on the Delivery dispatch screen

*/

vars
	wle	: CM_WorkListEntry;
	job : CM_Job;
begin
	if self.workListEntries.first.isKindOf(CM_WOWLE) then
		wle := self.workListEntries.first.CM_WOWLE.myOperationalWLE;
		if wle &lt;&gt; null and wle.isKindOf(CM_YardWLE) then
			job := wle.job;
		endif;
	endif;
	return job;
epilog

end;</source>
        <ReturnType type="CM_Job"/>
    </JadeMethod>
    <JadeMethod name="getRequiredByDT" id="8e6139c8-979c-4136-b020-0259bea3537b">
        <source>getRequiredByDT(): TimeStamp;

/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 Jul 2022	navcs2	Initial creation ChangeRequest 53038: MTN - Work Order Maintenance Refactor - PortSchema
25 Apr 2023 navma1	Bug 57739: PNL - Radio Telemetry Queues not working for multi move delivery requests (new issues)
*/

vars

begin

	if self.myWODtl &lt;&gt; null  then								//25.04.2023 navma1 #57739
		return self.myWODtl.requiredByDT;
	else
		return self.allRequests.first.getRequiredByDT();
	endif;
	
	

epilog

end;</source>
