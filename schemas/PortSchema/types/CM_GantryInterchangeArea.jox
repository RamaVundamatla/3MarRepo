    <JadeMethod name="findLocation" id="f3c79144-08f0-4e72-a40d-afb67a83b644">
        <source>findLocation(_strs: StringArray; _noException: Boolean; _foundLC: CM_LocationsController io; _foundHeight: Integer io);
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06 November 2009	cnwer1	Initial creation

*/

vars
tmpStr : String;
	rowStrLength	: Integer;
	isTruckLane : Boolean;
	colStr, rowStr : String;
	rtgColumn : CM_RTGColumn;
	row : CM_GridRow;
begin

	if _strs.isEmpty then
		return;
	endif;
	// ### REMOVE TA id from front of string
	tmpStr := _strs[1];
	if tmpStr.length = self.id.length then // par #12776 16/10/2006
		return;
	else
		if tmpStr[1:self.id.length] = self.id then
			tmpStr := tmpStr[self.id.length + 1:end];
		endif;
	endif;
	
	//epr par 21526 - rows can be upto 4 characters 
	/*
		get row label length
		start at end less the min of 4 (the row label max that can be entered) or
		tStr length less 1 (assume col label is atleast 1 char)
	*/
	
	//label length for rows should all be the same
	//rowStrLength := self.allGridRows.first.label.length;
	rowStrLength:=4.min(tmpStr.length-1);
	while rowStrLength &gt;=1  do
		rowStr:=tmpStr[(tmpStr.length  - rowStrLength) + 1:end];
		row:=self.allGridRowsByLabel[rowStr];
		if row &lt;&gt; null then
			break;
		endif;
		rowStrLength:=rowStrLength-1;
	endwhile;
	
	if row = null then
		return;
	endif;
	
	
	colStr := tmpStr[1:tmpStr.length-rowStrLength];
	rowStr := tmpStr[(tmpStr.length-rowStrLength) + 1:end];

	if _foundLC = null then
		_foundLC := self.allGridControllersByName[rowStr &amp; colStr];
	endif;
epilog

end;</source>
        <Parameter name="_strs" type="StringArray"/>
        <Parameter name="_noException" type="Boolean"/>
        <Parameter name="_foundLC" type="CM_LocationsController" usage="io"/>
        <Parameter name="_foundHeight" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getAssociatedTerminalArea" id="78b73adf-e7be-49ff-b4c3-1d657c688d76">
        <source>getAssociatedTerminalArea() : CM_TerminalArea;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 September 2009	cnwer1	Initial creation

*/

vars
	ta : CM_TerminalArea;
	realICArea : CM_GantryInterchangeArea;
begin
	if not self.isTransient then
		realICArea:=self;
	else
		realICArea:=self.pxyGetRealObject;
	endif;
	if realICArea &lt;&gt; null then
		ta:=realICArea.allAssociatedTerminalAreas.first;
		if ta = null then
			return null;
		else
			return ta;
		endif;
	endif;
	
	return null;
	
epilog

end;</source>
        <ReturnType type="CM_TerminalArea"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="76066415-2437-4ba4-8fe0-0e84862cf1b6">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 August 2009	cnwer1	Initial creation
26 Jun 2025  navbs1	Story 35185: MTN - Refactor Required to Stop Using getDisplayStringForAttribute() for Known Attributes

*/

vars
	ta : CM_TerminalArea;
	
begin
	if _attrName = ETRow_TerminalArea then
		ta:=self.getAssociatedTerminalArea();
		if ta = null then
			return null;
		else
			return ta.id;
		endif;
		
	elseif _attrName = ETRow_InterchangePosition then
		return self.interchangePosition.toGantryInterchangePosString;
	else
		return inheritMethod(_attrName,_short);
	endif;
	
epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getNiceName" id="81fdec84-8158-4b6e-a0ad-4591665b3799">
        <source>getNiceName(): String;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 September 2009	cnwer1	Initial creation

*/

vars
	ta : CM_TerminalArea;
	niceName : String;
begin
	ta:=self.getAssociatedTerminalArea();
	if ta &lt;&gt; null then
		niceName:= ta.id;
		if self.interchangePosition = CM_RTGArea.ICPosition_BeforeRow1 then
			niceName:=niceName &amp; Space &amp; ta.CM_RTGArea.topLabel;
		elseif self.interchangePosition = CM_RTGArea.ICPosition_AfterLastRow then
			niceName:=niceName &amp; Space &amp;  ta.CM_RTGArea.bottomLabel;
		endif;
		niceName:= niceName;
		return niceName;
	else
		return inheritMethod;
	endif;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
