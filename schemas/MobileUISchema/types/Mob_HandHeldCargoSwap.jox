    <JadeMethod name="init" id="76255c20-c09b-4e22-8008-d36a2b9fdb58">
        <updating/>
        <source>init(_wle: CM_WorkListEntry; job: CM_RoadJob) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
07 November 2013	cnwrd1	Initial creation

*/

vars
	aRequest : CM_Request;
	aWle,
	swapWle1,
	swapWle2 : CM_WorkListEntry;
	cargoDetails : String;
begin

	//wle is the cargo we are working

	
	frmFirstItem.caption := 'Truck ' &amp; _wle.job.CM_RoadJob.myVehicle.code &amp; CrLf &amp; 'Cargo ' &amp; _wle.myTrackedItem.id;
	
	//job has the cargo we need to pick from to swap with.
	
	foreach aRequest in job.allRequests do
		
		if aRequest.isReleaseType then
			aWle := aRequest.allWorkListEntries.first;
			if aWle.status = WLE_COMPLETED then
				continue;
			endif;
			
			if swapWle1 = null then
				swapWle1 := aWle;
			else
				swapWle2 := aWle;
			endif;			
		endif;
	
	endforeach;
	
	lSwapWithTruck.caption := 'With Truck : ' &amp; job.CM_RoadJob.myVehicle.code ;
	
	if swapWle1 &lt;&gt; null then
	
		if swapWle1.myTrackedItem &lt;&gt; null then
			cargoDetails := swapWle1.myTrackedItem.id;
		else
			cargoDetails := swapWle1.myRequest.getDisplayStringForAttribute(ETRow_CargoDetails, true);
		endif;
			
		btnCargo1.caption :=  cargoDetails;
		btnCargo1.userObject := swapWle1;
	endif;
	btnCargo1.value := true;
	
	if swapWle2 &lt;&gt; null then
	
		cargoDetails := null;		
	
		if swapWle2.myTrackedItem &lt;&gt; null then
			cargoDetails := swapWle2.myTrackedItem.id;
		else
			cargoDetails := swapWle2.myRequest.getDisplayStringForAttribute(ETRow_CargoDetails, true);
		endif;
		
		btnCargo2.caption :=  cargoDetails;
		btnCargo2.userObject := swapWle2;
	endif;
	
	self.setMySwapWle();
epilog

end;</source>
        <Parameter name="_wle" type="CM_WorkListEntry"/>
        <Parameter name="job" type="CM_RoadJob"/>
    </JadeMethod>
    <JadeMethod name="setMySwapWle" id="ccbafdb3-324b-4abb-a235-d9bb010a3c9e">
        <updating/>
        <source>setMySwapWle() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 November 2013	cnwrd1	Initial creation

*/

vars

begin

	if self.btnCargo1.value then
		self.mySwapWLE := self.btnCargo1.userObject.CM_WorkListEntry;
		else
		self.mySwapWLE := self.btnCargo2.userObject.CM_WorkListEntry;
	endif;
epilog

end;</source>
    </JadeMethod>
