    <JadeMethod name="addBerthPreference" id="4ae5bd0c-8ac6-453f-961f-a970fc143ddb">
        <updating/>
        <source>addBerthPreference(_berthPref : HMS_BerthPreference) updating;
//--------------------------------------------------
// Created:	24 March 2004 By: cnwgd1
//--------------------------------------------------
vars

begin

	if _berthPref = null then
		return;
	endif;

	if (not self.allBerthPrefByName.includes(_berthPref)) then
		self.allBerthPrefByName.add(_berthPref);
	endif;
	
	if (not self.allBerthPrefByOrder.includes(_berthPref)) then
		self.allBerthPrefByOrder.add(_berthPref);
	endif;	
	
end;</source>
        <Parameter name="_berthPref" type="HMS_BerthPreference"/>
    </JadeMethod>
    <JadeMethod name="cloneMySelf" id="d0f1f286-8285-4983-9479-ed1bb869bb54">
        <source>cloneMySelf(_transient : Boolean) : SelfType;
//--------------------------------------------------
// Created:	25 March 2004 By: cnwgd1
//--------------------------------------------------
vars
	tmpResType : HMS_ResourceTypeForMovement;
	newHarbourData : HMS_VesselDataHarbour;
	berthPref : HMS_BerthPreference;
begin
	
	newHarbourData := self.cloneSelf(_transient);
	newHarbourData.myHarbour := self.myHarbour;
	newHarbourData.myLineCompany := self.myLineCompany;
	newHarbourData.myShippingAgent := self.myShippingAgent;
	newHarbourData.myTidalClassArrival := self.myTidalClassArrival;
	newHarbourData.myTidalClassDeparture := self.myTidalClassDeparture;
	newHarbourData.myVesselCategoryIn := self.myVesselCategoryIn;
	newHarbourData.myVesselCategoryOut := self.myVesselCategoryOut;

	foreach berthPref in self.allBerthPrefByOrder do
		newHarbourData.allBerthPrefByOrder.add(berthPref.cloneMySelf(_transient));
	endforeach;

	foreach tmpResType in self.allMovementResourcesByMovement do
		newHarbourData.allMovementResourcesByMovement.add(tmpResType.cloneMySelf(_transient));
	endforeach;
			
	return newHarbourData;
end;</source>
        <Parameter name="_transient" type="Boolean"/>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="exportAsXMLDocGetChildRefKey" id="31235ac9-3a78-4fd8-9d43-321599f229d6">
        <source>exportAsXMLDocGetChildRefKey(_property: Property input) : Property;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 April 2012	cnwer1	Initial creation CCMS MES 1035

*/

vars

begin

	if _property = HMS_VesselDataHarbour::myHarbour then
		return HMS_Harbour::code;
	elseif _property = HMS_VesselDataHarbour::myLineCompany then
		return HMS_LineCompany::code;
	elseif _property = HMS_VesselDataHarbour::myShippingAgent then
		return CM_ShippingAgent::code;
	elseif _property = HMS_VesselDataHarbour::myTidalClassArrival then
		return HMS_TidalClass::code;
	elseif _property = HMS_VesselDataHarbour::myTidalClassDeparture then
		return HMS_TidalClass::code;
	elseif _property = HMS_VesselDataHarbour::myVesselCategoryIn then
		return HMS_VesselCategory::code;
	elseif _property = HMS_VesselDataHarbour::myVesselCategoryOut then
		return  HMS_VesselCategory::code;
	endif;
	
	return inheritMethod(_property);
	

epilog

end;</source>
        <Parameter name="_property" type="Property" usage="input"/>
        <ReturnType type="Property"/>
    </JadeMethod>
    <JadeMethod name="exportAsXMLInverseRef" id="92cc0ecd-b69a-4271-a8d5-1dd4a9e4801a">
        <source>exportAsXMLInverseRef(_property: Reference): Integer protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
01 April 2011	cnwer1	Initial creation

*/

vars

begin
	
	if _property = HMS_VesselDataHarbour::myLineCompany then
		return ExportAsChild;
	elseif _property = HMS_VesselDataHarbour::myShippingAgent then
		return ExportAsChild;
	elseif _property = HMS_VesselDataHarbour::myTidalClassArrival then
		return ExportAsChild;
	elseif _property = HMS_VesselDataHarbour::myTidalClassDeparture then
		return ExportAsChild;
	elseif _property = HMS_VesselDataHarbour::myVesselCategoryIn then
		return ExportAsChild;
	elseif _property = HMS_VesselDataHarbour::myVesselCategoryOut then
		return ExportAsChild;
	elseif _property = HMS_VesselDataHarbour::myHarbour then
		return ExportAsChild;
	elseif _property = HMS_VesselDataHarbour::allMovementResourcesByMovement then
		return ExportAsParent;	
	elseif _property = HMS_VesselDataHarbour::allBerthPrefByOrder then
		return ExportAsParent;
	endif;
	
	return inheritMethod(_property);

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_property" type="Reference"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getDefaultBerth" id="763ecb6c-d450-4f43-b13e-84f5d33df31b">
        <source>getDefaultBerth(): HMS_Berth;
//--------------------------------------------------
// Created:	21 December 2004 By: cnwgd1
//--------------------------------------------------
vars
	berthPref : HMS_BerthPreference;
begin
	if self.allBerthPrefByOrder.isEmpty then
		return null;
	endif;
	
	berthPref := self.allBerthPrefByOrder.first;
	
	return berthPref.getMyBerth;

end;</source>
        <ReturnType type="HMS_Berth"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="39653b66-8c50-4313-b95f-f8138f86d508">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
//--------------------------------------------------
// Created:	22 December 2004 By: cnwgd1
//--------------------------------------------------
vars

begin
	if _attrName = ETRow_TidalModelType 
	or _attrName = ETRow_Description
	or _attrName = ETRow_Code then
		return self.myHarbour.getDisplayStringForAttribute(_attrName, _short);

	elseif _attrName = ETRow_MyTidalClassArrival
	or _attrName = ETRow_MyTidalClass then
		if self.myTidalClassArrival &lt;&gt; null then
			return self.myTidalClassArrival.description;
		else
			return null;
		endif;			 	
	elseif _attrName = ETRow_MyTidalClassDept then
		if self.myTidalClassDeparture &lt;&gt; null then
			return self.myTidalClassDeparture.description;
		else
			return null;
		endif;			 
	elseif _attrName = ETRow_MyDefaultLineCompany then
		if self.myLineCompany &lt;&gt; null then
			return self.myLineCompany.description;
		else
			return null;
		endif;		
	elseif _attrName = ETRow_MyShippingAgentDefault then
		if self.myShippingAgent &lt;&gt; null then
			return self.myShippingAgent.description;
		else
			return null;
		endif;	
	elseif _attrName = ETRow_MyVesselCategoryIn then
		if self.myVesselCategoryIn &lt;&gt; null then
			return self.myVesselCategoryIn.description;
		else
			return null;
		endif;	
	elseif _attrName = ETRow_MyVesselCategoryOut then
		if self.myVesselCategoryOut &lt;&gt; null then
			return self.myVesselCategoryOut.description;
		else
			return null;
		endif;
	else
		return inheritMethod(_attrName, _short);
	endif;
end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getRemarks" id="3913f200-6397-4a78-9bf3-13434fdf7c06">
        <source>getRemarks() : String;
//--------------------------------------------------
// Created:	26 July 2005 By: cnwgd1
//--------------------------------------------------
vars

begin
	if self.remarksPilotOnly = null then
		return null;
	endif;
	if app.myPassport.myUser.canDo(app.myPassport.myTerminal, PmHMSPilotView) then
		return self.myHarbour.description &amp; ': ' &amp; self.remarksPilotOnly;
	endif;	

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getXMLDefinitionString" id="4d22597c-9bc8-4847-a9fc-e8de269c5334">
        <source>getXMLDefinitionString() : String;
//--------------------------------------------------
// Created:	06 October 2005 By: cnwgd1
//--------------------------------------------------
vars
	harbour,
	lineCo,
	agent,
	tcArr,
	tcDepart,
	catIn,
	catOut,
	xml : String;
	tmpBerthPref : HMS_BerthPreference;
	tmpMoveResource : HMS_ResourceTypeForMovement;
begin
	if self.myLineCompany &lt;&gt; null then
		lineCo := self.myLineCompany.code;
	endif;
	if self.myShippingAgent &lt;&gt; null then
		agent := self.myShippingAgent.code;
	endif;
	if self.myTidalClassArrival &lt;&gt; null then
		tcArr := self.myTidalClassArrival.code;
	endif;
	if self.myTidalClassDeparture &lt;&gt; null then
		tcDepart := self.myTidalClassDeparture.code;
	endif;
	if self.myVesselCategoryIn &lt;&gt; null then
		catIn := self.myVesselCategoryIn.code;
	endif;
	if self.myVesselCategoryOut &lt;&gt; null then
		catOut := self.myVesselCategoryOut.code;
	endif;
	if self.myHarbour &lt;&gt; null then
		harbour := self.myHarbour.code;
	endif;	
	
	xml := "&lt;VDH&gt;&lt;bp&gt;" &amp; self.berthPriority.String &amp; "&lt;/bp&gt;&lt;et&gt;" &amp; self.estTieUpTime.String &amp;
			 "&lt;/et&gt;&lt;er&gt;" &amp;  self.excludeReport.Integer.String &amp; "&lt;/er&gt;&lt;ic&gt;" &amp; self.initialVoyageCount.String &amp;
			 "&lt;/ic&gt;&lt;ie&gt;" &amp; self.isPilotExempt.Integer.String &amp; "&lt;/ie&gt;&lt;mh&gt;" &amp; harbour &amp;
			 "&lt;/mh&gt;&lt;lc&gt;" &amp; lineCo &amp; "&lt;/lc&gt;&lt;da&gt;" &amp; agent &amp;
			 "&lt;/da&gt;&lt;ta&gt;" &amp; tcArr &amp; "&lt;/ta&gt;&lt;td&gt;" &amp; tcDepart &amp;
			 "&lt;/td&gt;&lt;ci&gt;" &amp; catIn &amp; "&lt;/ci&gt;&lt;co&gt;" &amp; catOut &amp;
			 "&lt;/co&gt;&lt;ng&gt;" &amp; self.numLCrewLetGo.String &amp; "&lt;/ng&gt;&lt;nu&gt;" &amp; self.numLCrewTieUp.String &amp;
			 "&lt;/nu&gt;&lt;ti&gt;" &amp; self.numTugsIn.String &amp; "&lt;/ti&gt;&lt;to&gt;" &amp; self.numTugsOut.String &amp;
			 "&lt;/to&gt;&lt;rp&gt;" &amp; self.remarksPilotOnly.String &amp; "&lt;/rp&gt;";	
			 
	foreach tmpMoveResource in self.allMovementResourcesByMovement do
		xml := xml &amp; tmpMoveResource.getXMLDefinitionString();
	endforeach;

	foreach tmpBerthPref in self.allBerthPrefByOrder do
		xml := xml &amp; tmpBerthPref.getXMLDefinitionString();
	endforeach;	
	
	xml := xml &amp; "&lt;/VDH&gt;";
	
	return xml;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="importFromXMLDocReference" id="5d48461c-c864-4a0a-8a79-73df103e7f4d">
        <updating/>
        <source>importFromXMLDocReference(_property: Property; _xmlElement: JadeXMLElement input) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 April 2012	cnwer1	Initial creation CCMS MES 1035

*/

vars
	berthElement,
	harbourElement,
	childElement : JadeXMLElement;
	allChildElements : JadeXMLElementArray;
	resourceTypeForMovement : HMS_ResourceTypeForMovement;
	berthPreference : 	HMS_BerthPreferenceVesselData;
	harbour : HMS_Harbour;
begin
	if _property = HMS_VesselDataHarbour::myLineCompany then
		//ExportAsChild;
		childElement:=_xmlElement.getElementByTagName(HMS_LineCompany::code.name);	
		if childElement &lt;&gt; null then
			self.myLineCompany:=app.myRoot.allLineCompanies[childElement.textData];
		endif;
	elseif _property = HMS_VesselDataHarbour::myShippingAgent then
		// ExportAsChild;
		childElement:=_xmlElement.getElementByTagName(CM_ShippingAgent::code.name);	
		if childElement &lt;&gt; null then
			self.myShippingAgent:=app.myRoot.allShippingAgentsByCode[childElement.textData];
		endif;
	elseif _property = HMS_VesselDataHarbour::myTidalClassArrival then
		// ExportAsChild;
		childElement:=_xmlElement.getElementByTagName(HMS_TidalClass::code.name);	
		if childElement &lt;&gt; null then
			self.myTidalClassArrival:=app.myRoot.allTidalClasses[childElement.textData];
		endif;
	elseif _property = HMS_VesselDataHarbour::myTidalClassDeparture then
		// ExportAsChild;
		childElement:=_xmlElement.getElementByTagName(HMS_TidalClass::code.name);	
		if childElement &lt;&gt; null then
			self.myTidalClassDeparture:=app.myRoot.allTidalClasses[childElement.textData];
		endif;
	elseif _property = HMS_VesselDataHarbour::myVesselCategoryIn then
		// ExportAsChild;
		childElement:=_xmlElement.getElementByTagName(HMS_VesselCategory::code.name);	
		if childElement &lt;&gt; null then
			self.myVesselCategoryIn:=app.myRoot.allVesselCategories[childElement.textData];
		endif;
	elseif _property = HMS_VesselDataHarbour::myVesselCategoryOut then
		// ExportAsChild;
		childElement:=_xmlElement.getElementByTagName(HMS_VesselCategory::code.name);	
		if childElement &lt;&gt; null then
			self.myVesselCategoryOut:=app.myRoot.allVesselCategories[childElement.textData];
		endif;
	elseif _property = HMS_VesselDataHarbour::myHarbour then
		// ExportAsChild;
		childElement:=_xmlElement.getElementByTagName(HMS_Harbour::code.name);	
		if childElement &lt;&gt; null then
			self.myHarbour:=app.myRoot.allHarbours[childElement.textData];
		endif;
	elseif _property = HMS_VesselDataHarbour::allMovementResourcesByMovement then
		// ExportAsParent;	
		create allChildElements transient;
		_xmlElement.getAllElementsByTagName(HMS_ResourceTypeForMovement.name,allChildElements);
		foreach childElement in allChildElements do
			create resourceTypeForMovement transient;
			self.allMovementResourcesByMovement.add(resourceTypeForMovement);
			resourceTypeForMovement.importFromXMLDoc(childElement);
		endforeach;
	elseif _property = HMS_VesselDataHarbour::allBerthPrefByOrder then
		// ExportAsChild;
		create allChildElements transient;
		_xmlElement.getAllElementsByTagName(HMS_BerthPreferenceVesselData.name,allChildElements);
		foreach childElement in allChildElements do
			create berthPreference transient;
			self.allBerthPrefByOrder.add(berthPreference);
			berthPreference.importFromXMLDoc(childElement);
			// had to do it this way because berths are keyed on a collection on harbour so have to determine harbour
			// will not be set yet as works through the xml in alpha order
			berthElement:=childElement.getElementByTagName(HMS_BerthPreferenceVesselData::myBerth.name).getElementByTagName(HMS_Berth::code.name);	
			harbourElement:=_xmlElement.parentElement.getElementByTagName(HMS_VesselDataHarbour::myHarbour.name).getElementByTagName(HMS_Harbour::code.name);
			if harbourElement &lt;&gt; null and berthElement &lt;&gt; null then
				harbour:=app.myRoot.allHarbours[harbourElement.textData];
				if harbour &lt;&gt; null then
					berthPreference.setMyBerth(harbour.allBerths[berthElement.textData]);
				endif;
			endif;
		endforeach;
	endif;


	

epilog
	delete allChildElements;
end;</source>
        <access>protected</access>
        <Parameter name="_property" type="Property"/>
        <Parameter name="_xmlElement" type="JadeXMLElement" usage="input"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="47474afc-250c-40e9-9446-bd118829ec1b">
        <source>pxyCreateUpdateProxy(): SelfType;
//--------------------------------------------------
// Created:	21 December 2004 By: cnwgd1
//--------------------------------------------------
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy

vars
	tmpBerthPref : HMS_BerthPreference;
	theProxy : SelfType;
	tmpMovementResource : HMS_ResourceTypeForMovement;
	completedOK		: Boolean;
	
begin
	theProxy :=  inheritMethod();

	theProxy.myLineCompany := self.myLineCompany;	
	theProxy.myShippingAgent := self.myShippingAgent;
	theProxy.myTidalClassArrival := self.myTidalClassArrival;
	theProxy.myTidalClassDeparture := self.myTidalClassDeparture;
	theProxy.myVesselCategoryIn := self.myVesselCategoryIn;
	theProxy.myVesselCategoryOut := self.myVesselCategoryOut;
		
	foreach tmpBerthPref in self.allBerthPrefByOrder do
		theProxy.allBerthPrefByOrder.add(tmpBerthPref.pxyCreateUpdateProxy());
	endforeach;
	
	foreach tmpMovementResource in self.allMovementResourcesByMovement do
		theProxy.allMovementResourcesByMovement.add(tmpMovementResource.pxyCreateUpdateProxy());
	endforeach;

	theProxy.allBerthPrefByOrder.copy(theProxy.allBerthPrefByName);
	
	theProxy.myHarbour := self.myHarbour;
	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return theProxy;
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete theProxy;
	endif;	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="removeBerthPreference" id="7bc8ec54-8a68-418e-b346-b79e58c52f8e">
        <updating/>
        <source>removeBerthPreference(_berthPref : HMS_BerthPreference) updating;
//--------------------------------------------------
// Created:	24 March 2004 By: cnwgd1
//--------------------------------------------------
vars

begin

	if _berthPref = null then
		return;
	endif;
	
	if self.allBerthPrefByName.includes(_berthPref) then
		self.allBerthPrefByName.remove(_berthPref);
	endif;
	
	if self.allBerthPrefByOrder.includes(_berthPref) then
		self.allBerthPrefByOrder.remove(_berthPref);
	endif;	
	
end;</source>
        <Parameter name="_berthPref" type="HMS_BerthPreference"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="7a260593-c1dc-4ea7-a252-5b9b9187ee68">
        <updating/>
        <source>setForUpdate(_pxyVesselDataHarbour : HMS_VesselDataHarbour; _passport : CM_Passport input)updating;
//--------------------------------------------------------------
//Created: 22 July 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	berthPref,
	realBerthPref 		: HMS_BerthPreferenceVesselData;
	tmpBerthPref		: HMS_BerthPreference;
	tmpToDeleteArray 	: HMS_BerthPrefArray;
	tmpMoveResourceDict	: HMS_MovementResourceByMovement;
	realMovementResource,
	movementResource,
	tmpMovementResource	: HMS_ResourceTypeForMovement;
begin
	
	inheritMethod(_pxyVesselDataHarbour, _passport);
	
	self.myHarbour := _pxyVesselDataHarbour.myHarbour;
	self.myLineCompany := _pxyVesselDataHarbour.myLineCompany;	
	self.myShippingAgent := _pxyVesselDataHarbour.myShippingAgent;
	self.myVesselCategoryIn := _pxyVesselDataHarbour.myVesselCategoryIn;
	self.myVesselCategoryOut := _pxyVesselDataHarbour.myVesselCategoryOut;
	self.myTidalClassArrival := _pxyVesselDataHarbour.myTidalClassArrival;
	self.myTidalClassDeparture := _pxyVesselDataHarbour.myTidalClassDeparture;
							
	create tmpToDeleteArray transient;
	self.allBerthPrefByName.copy(tmpToDeleteArray);
		
	self.allBerthPrefByOrder.clear();
	self.allBerthPrefByName.clear();
	
	//Update the berth preferences and their order
	foreach tmpBerthPref in _pxyVesselDataHarbour.allBerthPrefByOrder do
		berthPref := tmpBerthPref.HMS_BerthPreferenceVesselData;
		if berthPref.isTransient then
			realBerthPref := berthPref.pxyGetRealObject();
			if realBerthPref &lt;&gt; null then
				if tmpToDeleteArray.includes(realBerthPref) then
					tmpToDeleteArray.remove(realBerthPref);
				endif;
				//unpdate it
				realBerthPref.setForUpdate(berthPref, _passport);
			else //Create newbee
				create realBerthPref persistent;
				realBerthPref.setForCreate(berthPref, _passport);
			endif;
			self.addBerthPreference(realBerthPref);
		else
			self.addBerthPreference(berthPref);		
			if tmpToDeleteArray.includes(berthPref) then
				tmpToDeleteArray.remove(berthPref);
			endif;
		endif;	
	endforeach;
	
	//Delete the unwanted berth preferences
	tmpToDeleteArray.purge();
	
	
	create tmpMoveResourceDict transient;
	self.allMovementResourcesByMovement.copy(tmpMoveResourceDict);
		
	self.allMovementResourcesByMovement.clear();
	
	
	foreach tmpMovementResource in _pxyVesselDataHarbour.allMovementResourcesByMovement do
		movementResource := tmpMovementResource;
		if movementResource.isTransient then
			realMovementResource := movementResource.pxyGetRealObject();
			if realMovementResource &lt;&gt; null then
				if tmpMoveResourceDict.includes(realMovementResource) then
					tmpMoveResourceDict.remove(realMovementResource);
				endif;
				//unpdate it
				realMovementResource.setForUpdate(movementResource, _passport);
			else //Create newbee
				create realMovementResource persistent;
				realMovementResource.setForCreate(movementResource, _passport);
			endif;
			self.allMovementResourcesByMovement.add(realMovementResource);
		else
			self.allMovementResourcesByMovement.add(realMovementResource);		
			if tmpMoveResourceDict.includes(movementResource) then
				tmpMoveResourceDict.remove(movementResource);
			endif;
		endif;	
	endforeach;
	
	//Delete the unwanted resource movements
	tmpMoveResourceDict.purge();
	
	self.berthPriority 		:= _pxyVesselDataHarbour.berthPriority;
	self.estTieUpTime 		:= _pxyVesselDataHarbour.estTieUpTime;
	self.excludeReport 		:= _pxyVesselDataHarbour.excludeReport;
	self.initialVoyageCount := _pxyVesselDataHarbour.initialVoyageCount;
	self.isPilotExempt 		:= _pxyVesselDataHarbour.isPilotExempt;
	self.numLCrewLetGo 		:= _pxyVesselDataHarbour.numLCrewLetGo;
	self.numLCrewTieUp 		:= _pxyVesselDataHarbour.numLCrewTieUp;
	self.numTugsIn 			:= _pxyVesselDataHarbour.numTugsIn;
	self.numTugsOut 		:= _pxyVesselDataHarbour.numTugsOut;
	self.remarksPilotOnly 	:= _pxyVesselDataHarbour.remarksPilotOnly;

epilog
	delete tmpToDeleteArray;
	delete tmpMoveResourceDict;	
end;</source>
        <Parameter name="_pxyVesselDataHarbour" type="HMS_VesselDataHarbour"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="8db909e4-a501-4777-acbd-4d871ad94858">
        <updating/>
        <source>setProxy(	_pilotRemarks : String;
			_excludeReport : Boolean;
			_pilotExempt : Boolean;
			_estTieUpTime : Integer;
			_crewLetGo : Integer;
			_crewTieUp : Integer;
			_numTugsIn : Integer;
			_numTugsOut : Integer;
			_berthPriority : Integer;
			_numHistVisits : Integer;
			_harbour : HMS_Harbour;
			_lineCompany : HMS_LineCompany;
			_shippingAgent : CM_ShippingAgent;
			_vesselCategoryIn : HMS_VesselCategory;
			_vesselCategoryOut : HMS_VesselCategory;
			_tidalClassArrival : HMS_TidalClass;
			_tidalClassDept : HMS_TidalClass)updating;
//--------------------------------------------------
// Created:	06 April 2005 By: cnwgd1
//--------------------------------------------------
begin
	self.raiseExceptionIfNotTransient(method);
	
	self.remarksPilotOnly		:=	_pilotRemarks;
	self.excludeReport			:=	_excludeReport;
	self.isPilotExempt			:=	_pilotExempt;
	self.estTieUpTime			:=	_estTieUpTime;
	self.numLCrewLetGo			:=	_crewLetGo;
	self.numLCrewTieUp			:=	_crewTieUp;
	self.numTugsIn				:=	_numTugsIn;
	self.numTugsOut				:=	_numTugsOut;
	self.berthPriority			:=	_berthPriority;
	self.initialVoyageCount		:=	_numHistVisits;
	self.myHarbour				:=	_harbour;
	self.myLineCompany			:=	_lineCompany;	
	self.myShippingAgent		:=	_shippingAgent;
	self.myVesselCategoryIn		:=	_vesselCategoryIn;
	self.myVesselCategoryOut	:=	_vesselCategoryOut;
	self.myTidalClassArrival	:=	_tidalClassArrival;
	self.myTidalClassDeparture	:=	_tidalClassDept;
end;</source>
        <Parameter name="_pilotRemarks" type="String"/>
        <Parameter name="_excludeReport" type="Boolean"/>
        <Parameter name="_pilotExempt" type="Boolean"/>
        <Parameter name="_estTieUpTime" type="Integer"/>
        <Parameter name="_crewLetGo" type="Integer"/>
        <Parameter name="_crewTieUp" type="Integer"/>
        <Parameter name="_numTugsIn" type="Integer"/>
        <Parameter name="_numTugsOut" type="Integer"/>
        <Parameter name="_berthPriority" type="Integer"/>
        <Parameter name="_numHistVisits" type="Integer"/>
        <Parameter name="_harbour" type="HMS_Harbour"/>
        <Parameter name="_lineCompany" type="HMS_LineCompany"/>
        <Parameter name="_shippingAgent" type="CM_ShippingAgent"/>
        <Parameter name="_vesselCategoryIn" type="HMS_VesselCategory"/>
        <Parameter name="_vesselCategoryOut" type="HMS_VesselCategory"/>
        <Parameter name="_tidalClassArrival" type="HMS_TidalClass"/>
        <Parameter name="_tidalClassDept" type="HMS_TidalClass"/>
    </JadeMethod>
    <JadeMethod name="setProxyFromDefaults" id="933e48c0-3518-4ee4-9bbb-c56221159b63">
        <updating/>
        <source>setProxyFromDefaults(_harbour: HMS_Harbour) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
16 Jul 2024 	navcs2 	Bug 65201: CUX - Missing vessel details when creating a vessel/voyage via Voyage API

*/

vars

begin
	self.myTidalClassArrival 	:= app.myRoot.allTidalClasses.first;
	self.myTidalClassDeparture 	:= app.myRoot.allTidalClasses.first;
	self.myHarbour				:= _harbour;
epilog

end;</source>
        <Parameter name="_harbour" type="HMS_Harbour"/>
    </JadeMethod>
    <JadeMethod name="setProxyFromProxy" id="773f6bdb-aa99-413a-8024-c1d365f94829">
        <updating/>
        <source>setProxyFromProxy(_pxyVesselDataHarbour: HMS_VesselDataHarbour; _passport: CM_Passport input) updating;
//--------------------------------------------------
// Created:	22 September 2005 By: cnwgd1
//--------------------------------------------------
vars
	pxyResourceType,
	resourceType : HMS_ResourceTypeForMovement;
	pxyBerthPref,
	tmpBerthPref : HMS_BerthPreference;
	
begin
	self.setProxy(	_pxyVesselDataHarbour.remarksPilotOnly,
					_pxyVesselDataHarbour.excludeReport,
					_pxyVesselDataHarbour.isPilotExempt,
					_pxyVesselDataHarbour.estTieUpTime,
					_pxyVesselDataHarbour.numLCrewLetGo,
					_pxyVesselDataHarbour.numLCrewTieUp,
					_pxyVesselDataHarbour.numTugsIn,
					_pxyVesselDataHarbour.numTugsOut,
					_pxyVesselDataHarbour.berthPriority,
					_pxyVesselDataHarbour.initialVoyageCount,
					_pxyVesselDataHarbour.myHarbour,
					_pxyVesselDataHarbour.myLineCompany,
					_pxyVesselDataHarbour.myShippingAgent,
					_pxyVesselDataHarbour.myVesselCategoryIn,
					_pxyVesselDataHarbour.myVesselCategoryOut,
					_pxyVesselDataHarbour.myTidalClassArrival,
					_pxyVesselDataHarbour.myTidalClassDeparture);

	// Get the berth preferences and their order
	self.allBerthPrefByOrder.clear();
	
	foreach tmpBerthPref in _pxyVesselDataHarbour.allBerthPrefByOrder do
		create pxyBerthPref as tmpBerthPref.class transient;
		
		pxyBerthPref.setProxy(	tmpBerthPref.defaultBowMark,
								tmpBerthPref.defaultBridgeMark,
								tmpBerthPref.defaultSternMark,
								tmpBerthPref.orientation,
								tmpBerthPref.getMyBerth(),
								app.myPassport);
								
		self.allBerthPrefByOrder.add(pxyBerthPref);
	endforeach;

	// Get the movement resources
	foreach resourceType in _pxyVesselDataHarbour.allMovementResourcesByMovement do
		pxyResourceType := self.allMovementResourcesByMovement[resourceType.movementType];
		
		if pxyResourceType = null then
			create pxyResourceType transient;
			self.allMovementResourcesByMovement.add(pxyResourceType);
		endif;
		
		pxyResourceType.setProxy(	resourceType.movementType,
									resourceType.numTugsForMovement,
									resourceType.myHarbour,
									resourceType.allResourceTypes);
	endforeach;
	
end;</source>
        <Parameter name="_pxyVesselDataHarbour" type="HMS_VesselDataHarbour"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setProxyResourceType" id="0744fbb0-b9ea-42d5-93bf-c876ddc8fdb4">
        <source>setProxyResourceType(_pxyVoyageHMSData : HMS_VoyageData input;
					 _movementType : String);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 March 2018	jlger1	Initial creation tfs 37663 web portal create

*/

vars
	pxyMoveResource,
	moveResource 	: HMS_ResourceTypeForMovement;
begin
	 moveResource:= self.allMovementResourcesByMovement[_movementType];
	 create pxyMoveResource transient;
	 if moveResource = null then
		 pxyMoveResource.setProxy(_movementType, null, self.myHarbour, null);	
	 else
		  pxyMoveResource.setProxy(_movementType, moveResource.numTugsForMovement, self.myHarbour, moveResource.allResourceTypes);	
	endif;
	 _pxyVoyageHMSData.allDefaultMovementResources.add(pxyMoveResource);  
epilog

end;</source>
        <Parameter name="_pxyVoyageHMSData" type="HMS_VoyageData" usage="input"/>
        <Parameter name="_movementType" type="String"/>
    </JadeMethod>
    <JadeMethod name="setProxyVDHFromXML" id="5ccf48ea-5521-4148-96ba-c3a112f480cb">
        <updating/>
        <source>setProxyVDHFromXML(_theXML : String; _harbour : HMS_Harbour) updating;
//--------------------------------------------------
// Created:	07 October 2005 By: cnwgd1
//--------------------------------------------------
vars
	tmpStr,
	tmpCode : String;
	tmpRoot : CM_Root;
	pos : Integer;
	tmpBerth : HMS_Berth;
	pxyBerthPref : HMS_BerthPreferenceVesselData;
	pxyRTM : HMS_ResourceTypeForMovement;
begin

	if _harbour = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Null harbour');
		return;
	endif;
	if _theXML = null then
		return;
	endif;	
	
	tmpRoot := app.myRoot;

	self.myHarbour := _harbour;
	
	self.berthPriority 		:= _theXML.cnEcGetTagValueOfName("bp").Integer;
	self.estTieUpTime 		:= _theXML.cnEcGetTagValueOfName("et").Integer;
	self.excludeReport 		:= _theXML.cnEcGetTagValueOfName("er").Integer.Boolean;
	self.initialVoyageCount := _theXML.cnEcGetTagValueOfName("ic").Integer;
	self.isPilotExempt 		:= _theXML.cnEcGetTagValueOfName("ie").Integer.Boolean;
	self.numLCrewLetGo 		:= _theXML.cnEcGetTagValueOfName("ng").Integer;
	self.numLCrewTieUp 		:= _theXML.cnEcGetTagValueOfName("nu").Integer;
	self.numTugsIn 			:= _theXML.cnEcGetTagValueOfName("ti").Integer;
	self.numTugsOut 		:= _theXML.cnEcGetTagValueOfName("to").Integer;
	self.remarksPilotOnly 	:= _theXML.cnEcGetTagValueOfName("rp");

	tmpCode := _theXML.cnEcGetTagValueOfName('lc');
	if tmpCode &lt;&gt; null then	
		self.myLineCompany := tmpRoot.allLineCompanies[tmpCode];
	endif;

	tmpCode := _theXML.cnEcGetTagValueOfName('da');
	if tmpCode &lt;&gt; null then	
		self.myShippingAgent := tmpRoot.allShippingAgentsByCode[tmpCode];
	endif;	

	tmpCode := _theXML.cnEcGetTagValueOfName('ci');
	if tmpCode &lt;&gt; null then	
		self.myVesselCategoryIn := tmpRoot.allVesselCategories[tmpCode];
	endif;		
			
	tmpCode := _theXML.cnEcGetTagValueOfName('co');
	if tmpCode &lt;&gt; null then	
		self.myVesselCategoryOut := tmpRoot.allVesselCategories[tmpCode];
	endif;	

	tmpCode := _theXML.cnEcGetTagValueOfName('ta');
	if tmpCode &lt;&gt; null then	
		self.myTidalClassArrival := tmpRoot.allTidalClasses[tmpCode];
	endif;	

	tmpCode := _theXML.cnEcGetTagValueOfName('td');
	if tmpCode &lt;&gt; null then	
		self.myTidalClassDeparture := tmpRoot.allTidalClasses[tmpCode];
	endif;
	
	// create default movement resources
	pos := 1;
	while (pos &gt; 0) do
		tmpStr := _theXML.cnEcGetNextTagValueOfName("RTM", pos); 
		if tmpStr = null then
			break;
		endif;

		tmpCode := tmpStr.cnEcGetTagValueOfName('mt');		
		if self.allMovementResourcesByMovement[tmpCode] &lt;&gt; null then
			// one already exists for this movement type
			continue;
		endif;
		
		create pxyRTM transient;
		pxyRTM.setProxyVDHFromXML(tmpStr, tmpCode, _harbour);
		self.allMovementResourcesByMovement.add(pxyRTM);
	endwhile;				

	// create berth preferences
	pos := 1;
	while (pos &gt; 0) do
		tmpStr := _theXML.cnEcGetNextTagValueOfName("BTHP", pos); 
		if tmpStr = null then
			break;
		endif;

		tmpCode := tmpStr.cnEcGetTagValueOfName('bth');
		if tmpCode &lt;&gt; null then
			tmpBerth := _harbour.allBerths[tmpCode];
		endif;
			
		if tmpBerth = null then
			continue;
		endif;
		
		if self.allBerthPrefByName.includesKey(tmpBerth.code) then
			// one already exists for this berth
			continue;
		endif;
		
		create pxyBerthPref transient;
		pxyBerthPref.setProxyVDHFromXML(tmpStr, tmpBerth);
		self.allBerthPrefByOrder.add(pxyBerthPref);
	endwhile;					
	
end;</source>
        <Parameter name="_theXML" type="String"/>
        <Parameter name="_harbour" type="HMS_Harbour"/>
    </JadeMethod>
    <JadeMethod name="validateMe" id="50d0f8c6-6ec1-49e3-93de-485dd7335864">
        <source>validateMe(_passport: CM_Passport input);
//--------------------------------------------------
// Created:	21 December 2004 By: cnwgd1
//06 Oct 2017	cnwma1  TFS #7257 JMT - Refactoring - Commodity Planning
//14/06/2022    navds20     TFS 53760 DuplicateItem not Translatable
//--------------------------------------------------
vars
	tmpCode			: String;
	tmpVDH			: HMS_VesselDataHarbour;
	realVDH			: HMS_VesselDataHarbour;
	existingVDH		: HMS_VesselDataHarbour;
	tmpMoveResource	: HMS_ResourceTypeForMovement;
	tmpBerthPref	: HMS_BerthPreference;
	
begin
	if self.myHarbour = null then
		app.raiseCMException(Input_required_field_harbour, ETRow_MyHarbour, null); // cnwdb2	PAR 35364
		return;	//03 Apr 2017	NDL	TFS 3941

	else
		tmpCode := self.myHarbour.code;
	endif;	

	if self.myVesselData = null then
		app.raiseCMException(Input_required_field_vessel, ETRow_MyVessel, null); // cnwdb2	PAR 35364
	endif;
	
	if self.myHarbour.isTidalClassValidated then    //06.10.2017	cnwma1  TFS #7257
		if self.myTidalClassArrival = null then
			app.raiseCMException1(Input_required_field_tidClsArv,  tmpCode , ETRow_MyTidalClassArrival, null); // cnwdb2	PAR 35364
		endif;
	
		if self.myTidalClassDeparture = null then
			app.raiseCMException1(Input_required_field_tdeClsDep,  tmpCode , ETRow_MyTidalClassDept, null); // cnwdb2	PAR 35364
		endif;			
	endif;
	
	//---------------------------------------------------------------------------
	// Check for duplicates
	//---------------------------------------------------------------------------
	if self.isTransient then
		realVDH	:=	self.pxyGetRealObject();
	endif;
	
	foreach tmpVDH in self.myVesselData.allVesselDataForHarbour do
		if tmpVDH = self then
			continue;
		endif;
		
		if tmpVDH = realVDH then
			continue;
		endif;
		
		if tmpVDH.isTransient then
			existingVDH	:=	tmpVDH.pxyGetRealObject();
		endif;
		
		if existingVDH &lt;&gt; null then
			if existingVDH = realVDH then
				continue;
			endif;
		endif;
		
		if tmpVDH.myHarbour = self.myHarbour then
			// app.raiseCMException2(DuplicateItem, 'Harbour Details', self.myHarbour.description, ETRow_MyHarbourForVD, null); //14.06.2022 navds20 53760
			//  Harbour Details already exists for %1 :  Harbour_details_already_exists
			app.raiseCMException1(Harbour_details_already_exists, self.myHarbour.description, ETRow_MyHarbourForVD, null); //14.06.2022 navds20 53760
			return;
		endif;
	endforeach;
	
	foreach tmpMoveResource in self.allMovementResourcesByMovement do
		tmpMoveResource.validateMe(_passport);
	endforeach;
	
	foreach tmpBerthPref in self.allBerthPrefByOrder do
		tmpBerthPref.validateMe(_passport);
	endforeach;
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
</Class>
