    <JadeMethod name="loadDataForFirstTime" id="9e2faf65-4020-47b4-b937-fda0e02e70a2">
        <updating/>
        <source>loadDataForFirstTime() updating, protected;
// ---------------------------------------------------------------------------
// Created:     29 July 2008 by cnwab1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	regKeys : IntegerArray;

begin
	inheritMethod();
	
	create regKeys transient;
	regKeys.add(J_key_F3);
	regKeys.add(J_key_F4);
	regKeys.add(J_key_F5);
	regKeys.add(J_key_F6);
	regKeys.add(J_key_F7);
	regKeys.add(J_key_F8);
	regKeys.add(J_key_F9);
	regKeys.add(J_key_F10);
	self.addRegisteredKeys(regKeys);

	// PAR 18556 the hotkey settings on these are overiding the ones that we are using.
	// Should have used these on the form, but will make invisible for now.
	self.btnCancelBase.visible := false;
	self.btnSaveBase.visible := false;

epilog
	delete regKeys;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="loadPrinterCombo" id="e2c15bac-9c54-4a1a-b2d2-25513704821f">
        <source>loadPrinterCombo();
//11 September 2009	cnwml2
// Changed On	By			Reason
// ----------	--------	-------------------------------------------------
//19/12/2013	cnwdap1		PAR #32849 CCMS PEN 2321 Security Gate - vehicle visit record may not have a gate yet

vars
	//printerDef : CM_PrinterDef;
	gate : CM_Gate;
	gateArea : CM_GateArea;
	obj : Object;
	oa : CM_ObjectArray;
	lc : CM_LaneController;
	
	//existingPrinter : CM_PrinterDef;
	existingPrinterName : String;
	printerName : String;
	index : Integer;
	
begin

	//03 Sep 2012	NDL	Par 30286
	if self.printerIsUserSelected and self.cmbPrinter.listIndex &gt; 0 then
		existingPrinterName := self.cmbPrinter.text;
	endif;

	self.cmbPrinter.zOrder(1); //epr TFS 5466 18/8/17
	//8.2.2 version 18 June 2013	NDL	Par 31842
	self.myAssistant.comboBoxPrintersLocal( self.cmbPrinter, existingPrinterName );
	
	gate := self.cmbGate.listObject.CM_Gate;
	if gate &lt;&gt; null then											// PAR #32849
		gateArea := gate.getFirstAGate_IN;
		
		create oa transient;
		gateArea.getAllLaneControllers(oa);
		foreach obj in oa do
			lc := obj.CM_LaneController;
			if lc.getLaneNumber = self.cmbGateLanes.text.Integer then
				printerName := lc.getPrinterPhysicalName;
				if printerName &lt;&gt; null then
					index := self.cmbPrinter.findStringExact( 1, printerName );
					if index &gt; 0 then
						self.cmbPrinter.listIndex := index;
					endif;
				endif;
				return;
			endif;
		endforeach;
	endif;															// PAR #32849
	
epilog
	delete oa;
end;	</source>
    </JadeMethod>
    <JadeMethod name="lstAVGrade_displayRow" id="fa28e59d-2794-4674-9504-c915f61576da">
