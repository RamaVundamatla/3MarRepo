    <JadeMethod name="includeObject" id="33e43eb2-3612-4a7c-9317-91dde15f25f1">
        <updating/>
        <source>includeObject(_obj: Object; _passport: CM_Passport): Boolean updating;
// --------------------------------------------------------------------------------
// Created:		24 April 2006 by cnwdad1
//
// Purpose:		Refer to superclass implementation.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.includeNotAvailableEntries then
		return true;
	else
		return not _obj.CM_Stevedore.notAvailableForEntry;
	endif;
end;</source>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="initShtMultiSelect" id="27bf3d0c-0130-4a69-aedc-2fa4b1e314dc">
        <source>initShtMultiSelect();
//-----------------------------------------
// Created: April 2004 By: cnwgd1
//-----------------------------------------
vars
	theForm	: SOP_TableMaintForm;
	tmpCol : ObjectSet;
begin

	theForm := self.myForm;
	inheritMethod;	
	
	theForm.lstSingleSelect1.visible :=true;
	
	create tmpCol transient;
	app.myRoot.getEmailAddresses(tmpCol,false);
	self.setupMultiSelect1("Contacts",tmpCol,SOP_TableMaintForm::displayEntryEmailAddress.name);	

	theForm.mulSelect2.formDisplayEntryMethodName := null;
epilog
	delete tmpCol;

end;</source>
    </JadeMethod>
