    <JadeMethod name="getDisplayStringForAttribute" id="e33e1430-e0eb-4b28-bf00-ee7c3ca84b78">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
//--------------------------------------------------
// Created:	05 December 2005 By: cnwgd1
//--------------------------------------------------
vars

begin
	if _attrName = ETRow_MyVesselType  then
		return self.vesselTypeDesc;
	elseif _attrName = ETRow_Group
	or _attrName = ETRow_GroupDescription  then
		return self.groupDescription;
	elseif self.myVoyage &lt;&gt; null then
		return self.myVoyage.getDisplayStringForAttribute(_attrName, _short);
	else
		return inheritMethod(_attrName, _short);
	endif;

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="groupDescription" id="ed7553d8-4029-44eb-ae10-38089505d831">
        <methodInvocation>mapping</methodInvocation>
        <source>groupDescription(set: Boolean; _value: String io) mapping;
//--------------------------------------------------
// Created:	05 December 2005 By: cnwgd1
//--------------------------------------------------
vars

begin
	if set then
		// set code here
	else
		// get code here
		if self.group = self.InPort then
			_value := app.getErrorString(In_Port);
		elseif self.group = self.Sailed then
			_value := app.getErrorString(Sailed);
		else
			_value := app.getErrorString(To_Arrive);
		endif;
	endif;


end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="includesMovementTo" id="4b776fbe-2587-49ea-a771-c5007490d141">
        <source>includesMovementTo( _berth : HMS_Berth;
					_dtStart : TimeStamp;
					_dtEnd : TimeStamp
					):Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 October 2012	cnwndl1	Initial creation	Par 30490

*/

vars

	tmpHMSVoyData : HMS_VoyageData;
	berth : HMS_Berth;
	nextBerth : HMS_Berth;
	tmpMove : HMS_Movement;
	nextMove : HMS_Movement;

begin

	if self.myVoyage &lt;&gt; null then
		tmpHMSVoyData := self.myVoyage.myHMSVoyageData;
		if tmpHMSVoyData &lt;&gt; null then
			foreach tmpMove in tmpHMSVoyData.allVoyageMovements do
				berth := tmpMove.getMyBerth;
				if berth = null then
					continue;
				endif;
				if berth = _berth then
					// movement is for this berth
					if tmpMove.occursOnDTNEW &gt; _dtEnd then
						//occurred after this our time frame
						continue;
					endif;
					
					nextMove := tmpMove.myNextMovement;
					if nextMove &lt;&gt; null then
						if nextMove.occursOnDTNEW &lt; _dtStart then
							//left current before our time frame
							continue;
						endif;
					endif;
					return true;
				endif;									
			endforeach;
		endif;
	endif;

	return false;

epilog

end;</source>
        <Parameter name="_berth" type="HMS_Berth"/>
        <Parameter name="_dtStart" type="TimeStamp"/>
        <Parameter name="_dtEnd" type="TimeStamp"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setFromVoyage" id="ee768b27-d1fb-456e-84be-99deb0ef5b37">
        <updating/>
        <source>setFromVoyage(_voyage : CM_Voyage) updating;
//--------------------------------------------------
// Created:	05 December 2005 By: cnwgd1
//--------------------------------------------------
vars
	inPortStatus : String;
	tmpVeseslType : HMS_VesselType;
	tmpHMSData : HMS_VoyageData;
	tmpBerth : HMS_Berth;
begin
	if _voyage = null then
		return;
	endif;
	self.myVoyage := _voyage;

	tmpHMSData := _voyage.myHMSVoyageData;			
	// Vessel Call
	if tmpHMSData &lt;&gt; null then
		tmpVeseslType := tmpHMSData.myVesselType;
		
		if tmpVeseslType &lt;&gt; null then	
			self.vesselTypeDesc := tmpVeseslType.description;
		endif;
	endif;
	
	if self.vesselTypeDesc = null then
		// cargo vessel call
		self.vesselTypeDesc := _voyage.getVoyageTypeString();
	endif;

	inPortStatus := _voyage.getInPortStatusDescription();

	if inPortStatus = app.getErrorString(In_Port) then
		self.group := self.InPort;
	elseif inPortStatus = app.getErrorString(Sailed) then
		self.group := self.Sailed;
	else
		self.group := self.ToArrive;
	endif;
	
	tmpBerth := _voyage.getMyBerth();
	if tmpBerth &lt;&gt; null then
		self.berthCode := tmpBerth.code;
	endif;
	
end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
    </JadeMethod>
</Class>
