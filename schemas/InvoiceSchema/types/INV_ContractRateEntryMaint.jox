    <JadeMethod name="translateForm" id="b3e202e8-1e79-444f-a9c1-93f6898876cf">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 08 March 2023 08:02:36.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0025607, locale);
	btnClose.translateCaption(Xlat_0025608, locale);
	btnSave.translateCaption(Xlat_0025609, locale);
	chkMaximum.translateCaption(Xlat_0025610, locale);
	lblEnd.translateCaption(Xlat_0025611, locale);
	lblFrom.translateBubbleHelp(Xlat_0025788, locale);
	lblFrom.translateCaption(Xlat_0025612, locale);
	lblRate.translateCaption(Xlat_0025613, locale);
	lblStart.translateCaption(Xlat_0025614, locale);
	lblTo.translateBubbleHelp(Xlat_0025789, locale);
	lblTo.translateCaption(Xlat_0025615, locale);
	txtFrom.translateBubbleHelp(Xlat_0025790, locale);
	txtTo.translateBubbleHelp(Xlat_0025791, locale);
end;</source>
    </JadeMethod>
