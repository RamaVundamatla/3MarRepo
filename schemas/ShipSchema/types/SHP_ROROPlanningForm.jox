    <JadeMethod name="switchWorkingMode" id="b0e006ce-5635-4244-87dc-a68edd1fc6a8">
        <updating/>
        <source>switchWorkingMode(_newMode : Integer) updating;
// ---------------------------------------------------------------------------
// Created:     16 September 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	oldMode	: Integer;
	needRedraw	: Boolean;
	
begin

	oldMode := self.modeWork;
	
	if oldMode = _newMode then
		return;
	endif;
	
	self.doClearTopDrawingFrame(true);
	self.hasChanged := false;
	self.modeWork := _newMode;
	self.myROROPlanDrawController.modeWork := _newMode;
	if _newMode = self.WorkMode_Job then
		if oldMode = self.WorkMode_CustomSeq or
		   oldMode = self.WorkMode_Plan then
			needRedraw := true;
		endif;
		self.setModeWorkJob();
		
		if self.myCurrentVoyage &lt;&gt; null then
			self.myCurrentVoyage.causeEvent(self.myTerminal.getTerminalEvent(ShowHide_VoyageAllocationsCC),true,false);//cnwas3 par26840a	
		endif;

	elseif _newMode = self.WorkMode_Plan then
		self.setModeWorkPlanning();
		if self.myCurrentVoyage &lt;&gt; null then
			self.myCurrentVoyage.causeEvent(self.myTerminal.getTerminalEvent(ShowHide_VoyageAllocationsCC),true,false);//cnwas3 par26840a
		endif;

	elseif _newMode = self.WorkMode_None then
		if oldMode = self.WorkMode_CustomSeq or
		   oldMode = self.WorkMode_Plan then
			needRedraw := true;
		endif;
		self.setModeWorkNone();
		if self.myCurrentVoyage &lt;&gt; null then
			self.myCurrentVoyage.causeEvent(self.myTerminal.getTerminalEvent(ShowHide_VoyageAllocationsCC),true,true);//cnwas3 par26840a	
		endif;

	else
		app.raiseUnexpectedProgramError(class.name, method.name, app.getErrorString(Invalid_mode) &amp; ' (' &amp; _newMode.String &amp; ')');
		return;
	endif;

	self.setCaption(self.setCaptionForModesGetView(self.modeView));
	if self.mySideViewForm &lt;&gt; null then
		self.mySideViewForm.setModeWork();
	endif;



end;</source>
        <Parameter name="_newMode" type="Integer"/>
    </JadeMethod>
