    <JadeMethod name="formatInField" id="820a35d9-6261-48dd-93e5-b918405fb996">
        <source>formatInField(	inString : String; 
				type : String ; 
				itemLength : Integer; 
				itemDecimals : Integer; 
				decimalsKeyed : Boolean	) : String;
//  inString is Linc screen output, type is Linc edit, itemLength and itemDecimals are Linc item length
//  and decimals.  The method returns a string formatted as a Jade item, based on the inputs

vars
	count		: Integer;
	inputLength	: Integer;
	pointer		: Integer;

	testString	: String;
	workString	: String;
	signString	: String;
	tempString	: String;
	outString	: String;
	
begin
//	do alphanumeric
	if type = 'A' then	
		outString := inString.padBlanks(itemLength);
//  numeric
	else
		inputLength := inString.length;

		//	Ignore trailing sign (decimals) by reducing the
		//	input length

		if	inString[inputLength:1]	=	'+'	or
			inString[inputLength:1]	=	'-'	then
			inputLength	:=	inputLength	-	1;
		endif;	

		testString := inString[inputLength];
		workString := inString;
        outString := '';
        signString:= '';
//  check for sign (last digit overpunch)
		pointer := "{ABCDEFGHI".pos(testString, 1);
		if pointer &gt; 0 then
        	testString := "0123456789"[pointer];
        	tempString := workString[1:inputLength -1];
        	workString := tempString &amp; testString;
        else
	        pointer := "}JKLMNOPQR".pos(testString, 1);
			if pointer &gt; 0 then
  		      	signString := '-';
    	    	testString := "0123456789"[pointer];
    	    	tempString := workString[1:inputLength - 1];
     		   	workString := tempString &amp; testString;
       		 endif;
       	endif;
// do decimals, if any.  No decimal character in input
		if itemDecimals &gt; 0 then
			count := itemLength - itemDecimals;

			//	if decimals are keyed (+ format) then the data is returned
			//	with a leading space - ignore
			if decimalsKeyed then
				tempString := workString[2:count] &amp; '.' &amp; workString[count+2:itemDecimals];
			else
				tempString := workString[1:count] &amp; '.' &amp; workString[count+1:itemDecimals];
			endif;
			workString := tempString;
		endif;
// strip leading zeros off.  Decimal cast doesn't work with leading zeros
    	count := 1;
    	while count &lt; itemLength do
    		testString := workString[count];
    		if testString &lt;&gt; '0' then
    			break;
    		endif;
    		count := count + 1;
    	endwhile;
    	tempString := workString[count:end];
//  add any sign last
    	outString := signString &amp; tempString;
	endif;					// end of type test
	return outString;
end;</source>
        <Parameter name="inString" type="String"/>
        <Parameter name="type" type="String"/>
        <Parameter name="itemLength" type="Integer"/>
        <Parameter name="itemDecimals" type="Integer"/>
        <Parameter name="decimalsKeyed" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getErrors" id="29ba97e8-acaa-4712-83f9-af850cf91f29">
        <source>/*******************************************************
*
* Description : return the errors from the noforms buffer
*
* Parameters :	None
*
* Return :		errors (String)
*
* History :		pjs	17/12/96	Initial version
*
*******************************************************/
getErrors() : String ;

vars
	inLength : Integer;

begin
	// skip over the "ERRORSnn" at the start.....and return the rest

	inLength := noformsData.length;

	return noformsData[9:inLength];

	// thats it!
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getIspec" id="352f856d-73c4-44b6-a243-3e41238cb0b3">
        <source>/*******************************************************
*
* Description : return the ispec from the noforms buffer
*
* Parameters :	None
*
* Return :		ispecName (String)
*
* History :		pjs	17/12/96	Initial version
*
*******************************************************/
getIspec() : String ;

begin
	// at this stage the 2K buffer from the host should be set up (noformsData)
	//  so we can simply extract the ispec name from here

	return noformsData[1:5];

	// thats it!
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getResult" id="baa7b3e3-a627-4454-81b1-9db4341d3fa1">
        <updating/>
        <source>/*******************************************************
*
* Description : return the result  from host connectivity services 
*
* Parameters :	responsedata - data indicating repsonse
*				
* Return :		result - (integer)
*						1   - HCS_Valid_Ispec
*						2   - HCS_Ispec_Errors 
*                       3   - HCS_Timed_Out
*                       4   - HCS_Awaiting_HostReply 
*
*
* History :		pjs	16/12/96	Initial version
*
*******************************************************/
getResult(dataIn : String) :Integer updating ;  

// returns the result from the host transaction  and set up the 2K noforms
// string if required ie its a valid ispec or has errors

begin
	// we can determine whether or not we have been passed data from the host
	// or a specific value indicating something by the length of the string

	if dataIn.length &lt; 2 then
	 	return dataIn.Integer;
	else //   data returned from host either valid or errors

  		// setup the noforms data returned

  		noformsData := dataIn;		

		// and check to see what response to give			

		if dataIn[1:6] = "ERRORS" then
			return HCS_Ispec_Errors;
		else
			return HCS_Valid_Ispec;
		endif;	
	endif;  // of length  &lt; 2 
end;</source>
        <Parameter name="dataIn" type="String"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getValue" id="b90db607-0c2e-486f-b9f7-84cda0ad2e43">
        <updating/>
        <source>/*******************************************************
*
* Description : get the value for a specific field (from the host data)
*
* Parameters :	ispec Name  - name of ispec 
*               field Name  - field Name
*
* Return :		None
*
* History :		pjs	16/12/96	Initial version
*
*******************************************************/
getValue(ispecName : String; fieldName : String ): String updating;

// get the value in the noforms data 

vars
	lincIspec : CnEcLincIspecDef;
	lincField : CnEcLincFieldDef;
	subLen : Integer;
	subPos : Integer;
	intReturn : Integer;
	formattedValue : String;
	workString :String;

begin
	// first get the field definition object 

	lincIspec := myLincSystemDef.allLincIspecDefs [ispecName.toLower];
	if lincIspec = null then
		intReturn := app.msgBox(("No internal data for field" &amp; ispecName &amp; "/" &amp; fieldName),"Internal Problem",MsgBox_Exclamation_Mark_Icon);
		return " ";
	endif;	

	lincField := lincIspec.allLincFieldDefs [fieldName.toLower];
	if lincField = null then
		intReturn := app.msgBox(("No internal data for field" &amp; ispecName &amp; "/" &amp; fieldName),"Internal Problem",MsgBox_Exclamation_Mark_Icon);
		return " ";
	endif;

	// now we can set up the return value based on the details for this data item

	workString := noformsData[lincField.offset:lincField.trueLength];
	formattedValue := formatInField(workString, lincField.type, lincField.length, lincField.decimals, lincField.decimalsKeyed);

    return formattedValue; 
end;</source>
        <Parameter name="ispecName" type="String"/>
        <Parameter name="fieldName" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getValueCopyFrom" id="a28edf1c-a664-44a5-b34d-7f0d25b04c8f">
        <updating/>
        <source>getValueCopyFrom(ispecName : String; fieldName : String ): HugeStringArray updating;

vars
	lincIspec : CnEcLincIspecDef;
	lincField : CnEcLincFieldDef;
	intLen : Integer;
	intPos : Integer;
	intReturn : Integer;
	intArrayIndex : Integer;
	strFormattedValue : String;
	strWorkString : String;
	staValues	: HugeStringArray;

begin
	// first get the field definition object 

	lincIspec := myLincSystemDef.allLincIspecDefs [ispecName.toLower];
	if lincIspec = null then
		intReturn := app.msgBox(("No internal data for ispec " &amp; ispecName ),"Internal Problem",MsgBox_Exclamation_Mark_Icon);
		return null;
	endif;	

	lincField := lincIspec.allLincFieldDefs [fieldName.toLower];
	if lincField = null then
		intReturn := app.msgBox(("No internal data for field" &amp; ispecName &amp; "/" &amp; fieldName),"Internal Problem",MsgBox_Exclamation_Mark_Icon);
		return null;
	endif;

	// now we can set up the return array of values

	create staValues transient;

	while intArrayIndex &lt; lincField.copyFromOccurs do
		intArrayIndex := intArrayIndex + 1;

	 	// now format the data out
 	 	// first - calculate the offset 

		intPos := (lincField.offset +  (lincField.copyFromGroupLength * (intArrayIndex - 1))) ; 

	 	// now extract and format the data

 	 	strWorkString := noformsData[intPos:lincField.length];
		staValues.add(formatInField(strWorkString, lincField.type, lincField.length, lincField.decimals, lincField.decimalsKeyed));
	endwhile;

    return staValues;
end;</source>
        <Parameter name="ispecName" type="String"/>
        <Parameter name="fieldName" type="String"/>
        <ReturnType type="HugeStringArray"/>
    </JadeMethod>
    <JadeMethod name="setupData" id="43eae93a-87c6-4308-954e-418c0247ece6">
        <updating/>
        <source>setupData(indata : String) updating;

begin
	noformsData:= indata;
end;</source>
        <Parameter name="indata" type="String"/>
    </JadeMethod>
</Class>
