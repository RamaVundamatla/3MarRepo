    <JadeMethod name="createBuyLineManager" id="d17dbf1d-2e20-4dcb-90de-fd6d4b853661">
        <updating/>
        <source>createBuyLineManager(	pBuyLineAdminEmailAddress : String;
						pBuyLineETLpassword : String;
						pBuyLineOPSId : Integer;
						pBuyLinePath : String;
						pBuyLineRpassword : String;
						pBuyLineServer : String;
						pTimeOut : Integer;
						pBuyLineVpassword : String;
						pBNZBuyLineMgrNew : CnEcBNZBuyLineMgr output) updating;

vars
	managerObj	: CnEcBNZBuyLineMgr;
	
begin
	create managerObj;
	
	managerObj.initializeMe(pBuyLineAdminEmailAddress,
							pBuyLineETLpassword,
							pBuyLineOPSId,
							pBuyLinePath,
							pBuyLineRpassword,
							pBuyLineServer,
							pTimeOut,
							pBuyLineVpassword,
							self);		
							
	self.myBuyLineMgr := managerObj;	
	pBNZBuyLineMgrNew := managerObj;
end;</source>
        <Parameter name="pBuyLineAdminEmailAddress" type="String"/>
        <Parameter name="pBuyLineETLpassword" type="String"/>
        <Parameter name="pBuyLineOPSId" type="Integer"/>
        <Parameter name="pBuyLinePath" type="String"/>
        <Parameter name="pBuyLineRpassword" type="String"/>
        <Parameter name="pBuyLineServer" type="String"/>
        <Parameter name="pTimeOut" type="Integer"/>
        <Parameter name="pBuyLineVpassword" type="String"/>
        <Parameter name="pBNZBuyLineMgrNew" type="CnEcBNZBuyLineMgr" usage="output"/>
    </JadeMethod>
    <JadeMethod name="createCnEcXmlExcludedClasses" id="5b1b6e72-e3d6-4fc6-af1f-31b3dbf3f492">
        <source>createCnEcXmlExcludedClasses(pSchemaName : String; pExcludedClassObj : CnEcXmlExcludedClasses io): String;

vars
	allExcludedClasses	: CnEcXmlExcludedClasses;
	
begin
	if self.allXmlExcludedClassesBySchema.getAtKey(pSchemaName) = null then
		create allExcludedClasses;
		allExcludedClasses.initializeMe(pSchemaName,self);
		pExcludedClassObj := allExcludedClasses; 
	else
		return "'" &amp; pSchemaName &amp; "' already exists. ";
	endif;		
end;</source>
        <Parameter name="pSchemaName" type="String"/>
        <Parameter name="pExcludedClassObj" type="CnEcXmlExcludedClasses" usage="io"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="createReleaseHistoryMaster" id="92b83eb1-3c8d-4605-8dd5-f56abb2b149e">
