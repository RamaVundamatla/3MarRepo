    <JadeMethod name="checkIfDefaultYACode" id="41e60b50-f432-41ee-bb3f-264ca26fcaa4">
        <source>checkIfDefaultYACode(pStr :String) :Boolean;
// adm 080609 Par 19637 defaultYACodeChanged
vars

begin
	if self.code = null
	or pStr = self.code
	or (self.myYATemplate &lt;&gt; null // the Template combo may not be set at this point
		and pStr &amp; " - " &amp; self.myYATemplate.code = self.code) then
		return true;
	endif;
end;
</source>
        <Parameter name="pStr" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="clearDepartedVoyages" id="01fa087c-86b0-43b7-bcc9-3adc424aa645">
        <updating/>
        <source>clearDepartedVoyages() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 June 2011	cnwndl1	Initial creation	Par 27786

*/

vars

	criteria : CM_YACriteria;
	obj : Object;
	action : Boolean;
	hasLiveVoyage : Boolean;
	allObjects : CM_ObjectSet;
	termAreasCopy : CM_TerminalAreaSet;
	termArea : CM_TerminalArea;
	
begin

	if not self.expiryType = YAExpiryType_VoyageClear then
		//should never happen...
		return;
	endif;
	
	foreach criteria in self.allCriteria do
		if criteria.myYACriteriaType.type = YACriteriaType_Voyage then
			create allObjects transient;
			criteria.myYAData.CM_YADataObjects.copyAllObjects(allObjects);
			foreach obj in allObjects do
				if obj.CM_Voyage.hasDeparted() then
					// need to remove this association
					criteria.myYAData.CM_YADataObjects.allObjects.remove(obj);
					action := true;
				else
					hasLiveVoyage := true;
				endif;
			endforeach;
		endif;
	endforeach;
	
	if hasLiveVoyage then
		// this one is actually still in use by at least one (non departed) voyage.
		return;
	endif;
	
	// If we got this far there are no associated voyages left.
	// So get rid of the Ranges too ( locations )		
	create termAreasCopy transient;
	if not self.allTerminalAreas.isEmpty then
		self.allTerminalAreas.copy( termAreasCopy );
	endif;
	
	self.allYardControllers.clear();
	self.allYABlocksIn.purge();
	self.allYABlocksOut.purge();
	self.allTerminalAreas.clear();
	
	foreach termArea in allTerminalAreas do
		termArea.causeEvent(self.myTerminal.getTerminalEvent(EVENT_REFRESH_GRID_AREA),false,null);
	endforeach;
	
	//06 Sep 2011	NDL Par 28111
	self.projected20 := 0;
	self.projected30 := 0;
	self.projected40 := 0;
	self.projected45 := 0;
	self.projected53 := 0;
	self.projectedGC := 0;	//31 Mar 2021	NDL	TFS 49912

epilog

	if action then
		self.myTerminal.causeEvent(self.myTerminal.getTerminalEvent(Event_YardAllocationUpdate), false, self);	
	endif;

	delete allObjects;
	delete termAreasCopy;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="cloneCriteria" id="37a31fa6-e30a-44ba-ba24-62fb5d2410f9">
        <source>cloneCriteria(_realAllocation: CM_YardAllocation) protected;

// Created by cnwdvb1 on 07 August 2006

vars

	newCriteria,
	criteria : CM_YACriteria;

begin

	foreach criteria in _realAllocation.allCriteria discreteLock do
		create newCriteria persistent;
		newCriteria.setForUpdate(criteria);
		newCriteria.setYardAllocation(self);
	endforeach;
		

end;</source>
        <access>protected</access>
        <Parameter name="_realAllocation" type="CM_YardAllocation"/>
    </JadeMethod>
