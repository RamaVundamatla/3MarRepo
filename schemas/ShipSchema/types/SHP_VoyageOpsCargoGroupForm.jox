    <JadeMethod name="addNewCargoGroup" id="bd3f233f-ed15-4282-83cd-7e5d9f756c3a">
        <updating/>
        <source>addNewCargoGroup(_cargoGroup : CM_CargoGroup) updating;
/*
Purpose:			

Date		Who		Reason
03 Jul 2023	navab1	 // ### TFS BUG 58853 03JUL2023 NAVAB1
20/02/2024 	navcs2 	MTN-29368 EUP | Transaction Instrumentation - Voyage Discharge
14 Jan 2026 navhl20 Bug MTN-35897: PEN - System Locking Errors (1000010 - Unknown message)
*/

vars
	cgDetail 		: CM_CargoGroupDetail;
	rowIdx			: Integer;
	ti 				: CM_TrackedItem;
	currentTable 	: CM_DataTable;
begin
	foreach cgDetail in _cargoGroup.allCargoGroupDetails  discreteLock do
	
		if cgDetail.myVoyage &lt;&gt; self.myCurrentVoyage then
			continue;
		endif;
		
		if cgDetail.site = TI_SITE_ONSITE then
			currentTable := self.tblOnsite;
		elseif cgDetail.site = TI_SITE_OFFSITE then
			currentTable := self.tblOffsite;
		elseif cgDetail.site = TI_SITE_ONSHIP then
			currentTable := self.tblOnship;
		else
			currentTable := self.tblPreNote;
		endif;
	
		ti := cgDetail.getFirstTIForVoyage(self.myCurrentVoyage);
		self.loadCargoForTable(ti, rowIdx, currentTable, false, true);
	
	endforeach;

	self.allDisplayedTIs.tryAdd(_cargoGroup);
	self.beginNotification(_cargoGroup, Object_Update_Event, Response_Continuous, Object_Update_Event);
epilog
	
end;</source>
        <Parameter name="_cargoGroup" type="CM_CargoGroup"/>
    </JadeMethod>
    <JadeMethod name="addToolbarControls" id="941b0dd6-2f7f-44ec-a5ec-f65feda716f6">
        <updating/>
        <source>addToolbarControls() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 April 2022	navds20	Initial creation TFS 53388

*/

vars
	toolbar : CMUI_Toolbar;
begin
	inheritMethod();
	toolbar := self.frmToolbar;
	toolbar.addButton(self.btnCargoGrouping, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnExpandAll, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnRecalculateCargoGroup, CMUI_Toolbar.Control_Alignment_Left);
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="btnCargoGrouping_click" id="b7389fd4-0e54-4d8b-ad1a-d4128a34ed5e">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnCargoGrouping_click(btn: Button input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 April 2022	navds20	Initial creation
28 Nov   2022	navkc1	ChangeRequest 55408: MTN - Cargo Group Ops Form - Only show cargo groups by default
08 Dec	 2022	navkc1	ChangeRequest 55409: MTN - Voyage Ops Form - Pagination of tables
*/

vars
	userWindow	: CM_UserWindow;
begin
	if self.btnCargoGrouping.value then
		self.isInCargoGrouping := true;
		// 12/12/2022	navkc1	#55409 - In cargo group mode, we don't allow limiting number of rows, set them to false
		self.performLimitNumOfRow := false;
		self.chkNumOfRowPerTable.value := false;
		self.chkNumOfRowPerTable.visible := false;
	else
		self.isInCargoGrouping := false;
		// 12/12/2022	navkc1	#55409 - In non cargo group mode, we allow limiting number of rows. Set the value from users setting
		self.chkNumOfRowPerTable.visible := true;
		userWindow := app.getUserWindow(self.name, false);
		
		if userWindow &lt;&gt; null then
			self.chkNumOfRowPerTable.value := userWindow.xmlInfo.cnEcGetTagValueOfName(self.chkNumOfRowPerTable.name).Boolean;
			self.txtNumOfRow.text := userWindow.xmlInfo.cnEcGetTagValueOfName(self.txtNumOfRow.name).String;
			//self.performLimitNumOfRow := self.chkNumOfRowPerTable.value and self.performHybrid;
			self.performLimitNumOfRow := self.chkNumOfRowPerTable.value; //30/07/2025	navkc1 JIRA MTN 35478
		else
			//self.performLimitNumOfRow := self.chkNumOfRowPerTable.value and self.performHybrid;
			self.performLimitNumOfRow := self.chkNumOfRowPerTable.value; //30/07/2025	navkc1 JIRA MTN 35478
		endif;
		
		// self.btnExpandAll_click(self.btnExpandAll); // 28/11/2022	navkc1	#55408 - Changed to expand only, nothing to do
	endif;
	
	// 12/12/2022	navkc1	#55409 - Do validate performance first so we have correct settings before proceeding any further
	self.validatePeformance(true, self.btnCargoGrouping); 
	self.doClickCargoGrouping();
	
	
epilog

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnExpandAll_click" id="b8b24239-776f-4d52-b0a0-8859c4681d99">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnExpandAll_click(btn: Button input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 April 2022	navds20	Initial creation
28 Nov   2022	navkc1	ChangeRequest 55408: MTN - Cargo Group Ops Form - Only show cargo groups by default
*/

vars

begin
	/* // 28/11/2022	navkc1	#55408 - Changed to expand only
	if isInCargoGrouping then
		self.doClickCollapseAll();
	else
		self.btnExpandAll.value:=false;
		self.btnExpandAll.caption:= "Collapse All";
	endif;
	*/
	
	// 28/11/2022	navkc1	#55408 - Changed to expand only
	if self.isInCargoGrouping then
		self.doClickCollapseAll();
	endif;
	
epilog

end;</source>
