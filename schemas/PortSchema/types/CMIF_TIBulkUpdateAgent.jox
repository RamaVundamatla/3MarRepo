        <updating/>
        <source>init(_tis : CM_TISet) updating;
/*
Purpose:			

Date		Who		Reason
08 May 2024	navab1	CR 64033 TASK 64035
*/

vars

begin
	_tis.copy(self.allTIs);
epilog

end;</source>
        <Parameter name="_tis" type="CM_TISet"/>
