    <JadeMethod name="isDevelopmentSystem" id="b58935b9-89d7-451a-a0f3-9664c35ad2a9">
        <source>isDevelopmentSystem():Boolean;
// --------------------------------------------------------------------------------
// Created:		07 February 2006 by cnwdad1
//
// Purpose:		Returns a boolean flag to indicate whether the application that is
//				running is a development system (as opposed to a deployed production
//				system).
//
// Parameters:	None
//
// Returns:		True if the application is the development system, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return true;
	
	if self.myRoot &lt;&gt; null then
//		return (app.myRoot.systemMode = CM_Root.SystemMode_Dev);
	endif;
	
	return false;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
