    <JadeMethod name="isGuineaPig" id="6ca87b9d-fb1a-4a84-a508-d4d7da071c59">
        <source>isGuineaPig() : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 February 2025	navmd1	Initial creation

*/

vars
	mdiParent	: Form;
begin
	mdiParent := self.getMdiFrame();
	if not mdiParent.isKindOf(DEV_SourceCompareForm) then
		return false;
	endif;
	
	return mdiParent.DEV_SourceCompareForm.isGuineaPig();
