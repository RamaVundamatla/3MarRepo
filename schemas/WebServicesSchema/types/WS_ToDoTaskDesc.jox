<Class name="WS_ToDoTaskDesc" id="92656db0-5b49-4381-b077-4e9cf858f649">
    <superclass name="WS_ProxyObject"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>Represents a task to be completed against a Tracked Item</text>
    <DbClassMap file="webservice"/>
    <PrimAttribute name="description" id="66865c21-4b37-41c0-ad80-a8dfbedc74a9">
        <type name="String"/>
        <text>Full description of the ToDo task ex.Requires Washing</text>
    </PrimAttribute>
    <PrimAttribute name="shortDesc" id="29077ca0-d78a-41fe-8ce2-ced057662676">
        <length>16</length>
        <embedded/>
        <type name="String"/>
        <text>Short Description of ToDo Task ex.WASH</text>
    </PrimAttribute>
    <JadeMethod name="setProxyFromObject" id="7d0f04e7-27eb-4c65-bebe-87244ff7c6d4">
        <updating/>
        <source>setProxyFromObject(_object: CM_ToDoTaskDesc) updating;
/*

Date		Who		Reason
09 May 2014	cnwer1	Initial creation PAR

*/

vars

begin
	inheritMethod(_object);
	self.description:=_object.description;
	self.shortDesc:=_object.shortDescription;

epilog

end;</source>
        <Parameter name="_object" type="CM_ToDoTaskDesc"/>
    </JadeMethod>
</Class>
