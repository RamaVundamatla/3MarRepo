    <JadeMethod name="setPriorLogControllerOID" id="3b95745b-923d-4ed6-a69e-60d07c07be6b">
        <updating/>
        <source>setPriorLogControllerOID(_locationsController : CM_LocationsController) updating, protected;

/*

Purpose:		C3 CCMS 1134 record OID of previous location if log controller	

Parameters:			

Return Value:		


Date		Who		Reason
20 October 2014	cnwrd1	Initial creation

*/

vars

begin

