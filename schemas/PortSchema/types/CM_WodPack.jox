    <JadeMethod name="pxyCreateUpdateProxy" id="ea62a288-5530-44ce-bd85-7fe192a07a32">
        <source>pxyCreateUpdateProxy(): SelfType;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
12 Aug 2009	cnwmd1	Initial creation
20/04/2011	cnwmh5	PAR #27401 - Add code to handle prossible exceptions occurring when	trying to create the proxy
10 Sep 2021 navma1  ChangeRequest 51002: MTN - Web Portal Cargo Work Orders
12 Jan 2023	navma1  ChangeRequest 56141: EUP - Refactor and Remove CM_WorkOrderTISource from CM_WorkOrderTI
18 Apr 2023 navhl20 ChangeRequest 55442:[57629] EUP - Pack Cargo Work Order - Enhancement
05 Jul 2024 navhl20	ChangeRequest 61368: EUP* | Adding Pack Reserve Child to Packing Work order Release Request
*/

vars
	pxy 		    : SelfType;
	proxySource     : CM_WorkOrderTISource;
	completedOK		: Boolean;
begin
	pxy := inheritMethod();
	
	self.allPackingTIs.copy(pxy.allPackingTIs);    //10.09.2021 navma1 #51002
	pxy.myBookingRef	 := self.myBookingRef;
	pxy.myConsignee 	 := self.myConsignee;
	pxy.myConsignor 	 := self.myConsignor;
	pxy.myContentsStatus := self.myContentsStatus;
	pxy.myDischargePort  := self.myDischargePort;
	pxy.myOperator 		 := self.myOperator;
	pxy.mySubTerminal 	 := self.mySubTerminal;
	pxy.myVoyage 		 := self.myVoyage;
	pxy.myReleaseRequest := self.myReleaseRequest;		//18.4.2023 navhl20 #55442[57629]
	pxy.myReserveDetail	 := self.myReserveDetail;		//05.07.2024 navhl20 #61368
	
	/*
	12.01.2023 navma1 #56141 Task#56147
	proxySource := app.createUpdateProxy(self.mySource).CM_WorkOrderTISource;
	proxySource.setMyParent(pxy);
	*/
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return pxy;
	
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete pxy;
	endif;
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="b63ed407-d1eb-4341-923e-d59eb70351ce">
        <updating/>
        <source>setForCreate(_pxyWoDDtl: CM_WorkOrderDtl io; realWorkOrder : CM_WorkOrder) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date   	Who		Reason
24 Jul 2009		cnwrd1	Initial creation
12 Jan 2023		navma1  ChangeRequest 56141: EUP - Refactor and Remove CM_WorkOrderTISource from CM_WorkOrderTI
*/

vars
	realTISource : CM_WorkOrderTISource;
begin
	inheritMethod(_pxyWoDDtl, realWorkOrder);
	
	/*
	12.01.2023 navma1 #56141 Task#56147
	if _pxyWoDDtl.CM_WodPack.mySource.isTransient then //should be here
		create realTISource persistent;
		realTISource.setForCreate(_pxyWoDDtl.CM_WodPack.mySource ) ;
		realTISource.setMyParent ( self );
	endif;
	*/


epilog

end;</source>
        <Parameter name="_pxyWoDDtl" type="CM_WorkOrderDtl" usage="io"/>
        <Parameter name="realWorkOrder" type="CM_WorkOrder"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="a5a80a6a-c5f1-4c68-af6e-16553f6f69a9">
        <updating/>
        <source>setForUpdate(_pxyWoDDtl: CM_WorkOrderDtl) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 Jul 2009	cnwrd1	Initial creation
31 May 2021 navma1  ChangeRequest 51002: MTN - Web Portal Cargo Work Orders
12 Jan 2023	navma1  ChangeRequest 56141: EUP - Refactor and Remove CM_WorkOrderTISource from CM_WorkOrderTI
18 Apr 2023 navhl20 ChangeRequest 55442:[57629] EUP - Pack Cargo Work Order - Enhancement
05 Jul 2024 navhl20	ChangeRequest 61368: EUP* | Adding Pack Reserve Child to Packing Work order Release Request
*/

vars
	pxyPackWo :CM_WodPack;
begin
	inheritMethod(_pxyWoDDtl);
	 
	pxyPackWo := _pxyWoDDtl.CM_WodPack;  //06.05.2021 navma1 #51051
	
	self.commodity	       			 := pxyPackWo.commodity ;
	self.contentsStatus    			 := pxyPackWo.contentsStatus ;
	self.imexStatus        			 := pxyPackWo.imexStatus ;
	self.myBookingRef      			 := pxyPackWo.myBookingRef ;
	self.myConsignee       			 := pxyPackWo.myConsignee ;
	self.myConsignor 	   			 := pxyPackWo.myConsignor ;
	self.myContentsStatus  			 := pxyPackWo.myContentsStatus ;
	self.myDischargePort   			 := pxyPackWo.myDischargePort ;
	self.myOperator  	   			 := pxyPackWo.myOperator ;
	self.mySubTerminal     			 := pxyPackWo.mySubTerminal ;
	self.myVoyage  					 := pxyPackWo.myVoyage ;	
	self.isSelectedItemsPackingChild := pxyPackWo.isSelectedItemsPackingChild;
	self.myReleaseRequest			 := pxyPackWo.myReleaseRequest;									//18.4.2023 navhl20 #55442[57629]
	self.myReserveDetail			 := pxyPackWo.myReserveDetail;									//05.07.2024 navhl20 #61368
	
	if pxyPackWo.allPackingTIs &lt;&gt; null and  not pxyPackWo.allPackingTIs.isEmpty then
		self.allPackingTIs.clear();
		pxyPackWo.allPackingTIs.copyNoDuplicates(self.allPackingTIs,false);							//10.09.2021 navma1 #51002
	endif;
	
	/*
	12.01.2023 navma1 #56141 Task#56147
	if self.mySource &lt;&gt; null then
		self.mySource.setForUpdate(pxyPackWo.mySource ) ;	
	endif;
	*/
epilog

end;</source>
        <Parameter name="_pxyWoDDtl" type="CM_WorkOrderDtl"/>
    </JadeMethod>
    <JadeMethod name="setProxyWodPack" id="9c7d5b16-26c9-4fe4-9849-ae8e07dabe34">
        <updating/>
        <source>setProxyWodPack(_packingTIs 	: CM_TISet;
				_bookingRef 	: CM_BookingRef;
				_consignee 		: CM_ConsigneeConsignor;
				_consignor		: CM_ConsigneeConsignor;
				_contentsStatus : CM_ContentsStatus;
				_dischargePort  : CM_Port;
				_operator 		: CM_Operator;
				_subTerminal 	: CM_SubTerminal;
				_voyage 		: CM_Voyage;
				_commodity 		: String; //Should be the code
				_imexStatus 	: Integer;
				_releaseRequest	: CM_BulkRelease;
				_reserveDetail	: CM_ReserveDetail;
				_isSelectedItemsPackingChild : Boolean) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 Aug 2009	cnwmd1	Initial creation
10 Sep 2021 navma1 	ChangeRequest 51002: MTN - Web Portal Cargo Work Orders
18 Apr 2023 navhl20 ChangeRequest 55442:[57629] EUP - Pack Cargo Work Order - Enhancement
05 Jul 2024 navhl20	ChangeRequest 61368: EUP* | Adding Pack Reserve Child to Packing Work order Release Request
*/

vars

begin
	//10.09.2021 navma1 #51002
	if _packingTIs &lt;&gt; null and  not _packingTIs.isEmpty &lt;&gt; null then
		_packingTIs.copyNoDuplicates(self.allPackingTIs,false);
	endif;

	self.myBookingRef 				 := _bookingRef;
	self.myConsignee 				 := _consignee;
	self.myConsignor 				 := _consignor;
	self.myContentsStatus 			 := _contentsStatus;
	self.myDischargePort 			 := _dischargePort;
	self.myOperator 				 := _operator;
	self.mySubTerminal 				 := _subTerminal;
	self.myVoyage 					 := _voyage;
	self.commodity 				 	 := _commodity[1:4];
	self.imexStatus 				 := _imexStatus;
	self.isSelectedItemsPackingChild := _isSelectedItemsPackingChild;
	self.myReleaseRequest			 := _releaseRequest;					//18.4.2023 navhl20 #55442[57629]
	self.myReserveDetail			 := _reserveDetail;						//05.07.2024 navhl20 #61368
epilog

end;</source>
        <Parameter name="_packingTIs" type="CM_TISet"/>
        <Parameter name="_bookingRef" type="CM_BookingRef"/>
        <Parameter name="_consignee" type="CM_ConsigneeConsignor"/>
        <Parameter name="_consignor" type="CM_ConsigneeConsignor"/>
        <Parameter name="_contentsStatus" type="CM_ContentsStatus"/>
        <Parameter name="_dischargePort" type="CM_Port"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_subTerminal" type="CM_SubTerminal"/>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_commodity" type="String"/>
        <Parameter name="_imexStatus" type="Integer"/>
        <Parameter name="_releaseRequest" type="CM_BulkRelease"/>
        <Parameter name="_reserveDetail" type="CM_ReserveDetail"/>
        <Parameter name="_isSelectedItemsPackingChild" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="skipTiValidation" id="ec1f8f11-4176-454c-b8c9-33f7e92d718a">
        <source>skipTiValidation(): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 Apr 2023 navma1  ChangeRequest 55442:[54989] EUP - Pack Cargo Work Order - Enhancement

*/

vars
	bulkRelease : CM_BulkRelease;
begin
	
	bulkRelease := self.myReleaseRequest;
	
	if bulkRelease &lt;&gt; null then
		if self.myReleaseRequest.releaseByType then
			return true;
		endif;
	endif;
	
	return false;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validate" id="1631bd6c-9668-4dd3-ada3-baaf6dfd1741">
        <source>validate()protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14 Aug 2009	cnwmd1	Initial creation
10 Sep 2021 navma1  ChangeRequest 51002: MTN - Web Portal Cargo Work Orders
04 Nov 2021 navma1  ChangeRequest 52249: MTN - Web Portal Cargo Work Orders - Cargo Type Checking when Adding a To Do Task
08 Feb 2023 navma1  ChangeRequest 56457: EUP - Allowing different sets of cargo items per work order task [Refactor]
18 Apr 2023 navma1  ChangeRequest 55442:[54989] EUP - Pack Cargo Work Order - Enhancement
28 May 2024 navma1	Bug 64224: MTN - DeadLocks Caused by Future Actors
08 Jul 2024 navhl20	ChangeRequest 61368: EUP* | Adding Pack Reserve Child to Packing Work order Release Request
*/

vars
	ti 			: CM_TrackedItem;
	bulkRelease	: CM_BulkRelease;
begin
	inheritMethod();					
	
	if self.allPackingTIs.isEmpty and  self.skipTiValidation = false then										//17.04.2023 navma1 #55442:[54989]
		app.raiseCMException1(Input_required_field_Required, app.getErrorString(Packing_Child), null, null); 
	endif;
	
	if self.myVoyage = null then
		app.raiseCMException1(Input_required_field_Required, app.getErrorString(Voyage), null, null); 
	endif;
	
	if self.commodity = null then
		app.raiseCMException1(Input_required_field_Required, app.getErrorString(Commodity), null, null); 
	endif;
	
	if self.myOperator = null then
		app.raiseCMException1(Input_required_field_Required, app.getErrorString(Operator), null, null); 
	endif;
	
	foreach ti in self.allSelectedTIs discreteLock do							//28.05.2024 navma1 #64224
		if not ti.isKindOf(CM_Container) and ti.hasChildren = true then
			app.raiseCMException(Parent_cargo_must_packab_conta, null, null);
		endif;
	endforeach;
	
	bulkRelease := self.myReleaseRequest;																		//08.07.2024 navhl20 #61368
	if bulkRelease &lt;&gt; null and bulkRelease.releaseByType then													//08.07.2024 navhl20 #61368
		if self.myReserveDetail = null then
			app.raiseCMException(Please_select_release_detail,null,null);
		endif;
	endif;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
</Class>
