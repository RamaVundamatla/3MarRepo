    <JadeMethod name="setFilterValues" id="b9b6b356-bde0-4ff5-a4a7-43c44ea11332">
        <updating/>
        <source>setFilterValues() updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
13 September 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars
	dateFrom, dateTo : Date;
	timeFrom, timeTo : Time;
	now : TimeStamp;
	localFromTS, localToTS: TimeStamp;
begin
	
	self.filterFromTS:=null;
	self.filterToTS:=null;
	self.filterFaultType:=null;
	self.filterStatus:=null;
	self.filterMachine:=null;
	self.filterMachineType:=null;
	self.filterUser:=null;
	now := app.actualTimeServer();	// cnwmp6 TFS 488 - Multi timezone changes 13/4/16
	
	dateFrom:= tblSearch.getValueByName(ETRow_FromDate).Date;
	timeFrom := tblSearch.getValueByName(ETRow_FromTime).Time;
	dateTo:= tblSearch.getValueByName(ETRow_ToDate).Date;
	timeTo:=tblSearch.getValueByName(ETRow_ToTime).Time;
	
	if dateFrom &lt;&gt; null then
		localFromTS.setDate(dateFrom);
		localFromTS.setTime(timeFrom);
		//self.filterFromTS.setDate(dateFrom);		// cnwmp6 TFS 488 - Multi timezone changes 12/4/16
		//self.filterFromTS.setTime(timeFrom);
		self.filterFromTS := self.localToSystemTime(localFromTS);
	endif;
	if dateTo &lt;&gt; null then
		localToTS.setDate(dateTo);
		localToTS.setTime(timeTo);
		//self.filterToTS.setDate(dateTo);			// cnwmp6 TFS 488 - Multi timezone changes 12/4/16
		//self.filterToTS.setTime(timeTo);
		self.filterToTS := self.localToSystemTime(localToTS);
	endif;

	self.filterLastXHours:=tblSearch.getValueByName(ETRow_LastXhours).Integer;
	
	//do this in the tblSearch lost focus but just for testing
	if self.filterLastXHours &gt; 0 then
		self.filterToTS:=now;
		self.filterFromTS:=self.filterToTS.addHours(-filterLastXHours);
	endif;
	
	if self.cmbFaultType.listIndex &gt; 0 then
		self.filterFaultType:=self.cmbFaultType.listObject.CM_FaultType;
	endif;
	if self.cmbFaultStatus.listIndex &gt; 0 then
		self.filterStatus:=self.cmbFaultStatus.listObject.CM_FaultStatus;
	endif;
	if self.cmbMachine.listIndex &gt; 0 then
		self.filterMachine:=self.cmbMachine.listObject.CM_Machine;
	endif;
	if self.cmbMachineType.listIndex &gt; 0 then
		self.filterMachineType:=self.cmbMachineType.listObject.CM_MachineType;
	endif;
	if self.cmbUser.listIndex &gt; 0 then
		self.filterUser:=self.cmbUser.listObject.CM_User;
	endif;

	
	
	

epilog

end;</source>
    </JadeMethod>
