    <JadeMethod name="calcEstActFromWPOpHrs" id="7a4021b2-02b4-48e6-8a45-02f0267c1725">
        <source>calcEstActFromWPOpHrs(_returnNotSet : Boolean output):TimeStamp;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 April 2012	cnwndl1	Initial creation	Par 29369

*/

vars

	maxRate : Decimal [4,1];
	currentNetRate : Decimal [4,1];
	startTime : TimeStamp;
	endTime : TimeStamp;
	minsToGo : Integer;
	timeInterval : TimeStampInterval;
	delays : CM_ObjectSet;
	delayDict : CM_DelayByStartDTDict;
	delay : CM_Delay;
	overlapTimeInterval : TimeStampInterval;

begin

	_returnNotSet := false;	//20 Sep 2012	NDL	Par 30389

	startTime := app.actualTimeServer;
	if self.movesIncomplete &lt; 1 then
		endTime := self.myJobSheet.CM_VoyageJobSheet.getWPOpHrsWorkEnded;
		if endTime &lt; startTime then
			return endTime;
		else
			return startTime;
		endif;
	endif;

	//	currentNetRate := self.myJobSheet.CM_VoyageJobSheet.getKPINetRate.roundedTo(1);
	maxRate := 999.9;	//07 Aug 2012	NDL	Par 30161
	currentNetRate := maxRate.min( self.myJobSheet.CM_VoyageJobSheet.getKPINetRate(self).roundedTo(1));//07 Aug 2012	NDL	Par 30161
	
	if currentNetRate &lt;&gt; 0 then
		minsToGo := (( self.movesIncomplete / currentNetRate ) * 60 ).Integer;
		timeInterval.set(0, 60000 * minsToGo );
	else
		_returnNotSet := true;	//20 Sep 2012	NDL	Par 30389
	endif;
	
	endTime := startTime + timeInterval;
	
	create delays transient;
	create delayDict transient;
	
	while true do
	
		delays.clear();
		
		self.myJobSheet.CM_VoyageJobSheet.getDelaysOverlapping( delays, startTime, endTime );
		if delays.isEmpty then
			//There ARE no delays currently entered that would extend this estimate.
			break;
		endif;
		delayDict.clear();
		delays.copy(delayDict);
		//OK we have some current or future delays that need processing.
		// process the first one and try again. (they might be duplicates.)
		delay := delayDict.first.CM_Delay;
		//find the time interval these two currently overlap by
		overlapTimeInterval := delay.getOverlapInterval( startTime, endTime );
		if overlapTimeInterval = null then
			break;
		endif;
		
		//increment our timestamps and try again.
		if delay.startDT &lt; startTime then
			// Delay starts before the beginning of our check period
			startTime := startTime + overlapTimeInterval;
		else
			startTime := delay.startDT + overlapTimeInterval;
		endif;
		endTime := endTime + overlapTimeInterval;
		
	endwhile;
	
	return endTime;
	

epilog

	delete delays;
	delete delayDict;
	
end;</source>
        <Parameter name="_returnNotSet" type="Boolean" usage="output"/>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
