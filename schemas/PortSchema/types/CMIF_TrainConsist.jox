    <JadeMethod name="create" id="f3252f94-e66d-40e6-a552-ec51d5499e1b">
        <updating/>
        <source>create() updating, protected;
// --------------------------------------------------------------------------------
// Created:		18 February 2010 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	create self.allWagonsToAdd transient;
	create self.allWagonsToDelete transient;
	create self.allWagonsToUpdate transient;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="delete" id="d5bbd1c0-7c27-4b3f-89bf-e2a9db7c4df5">
        <updating/>
        <source>delete() updating, protected;
// --------------------------------------------------------------------------------
// Created:		17 February 2010 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	cmifTIObj : CMIF_TIObject;
	invalid : Boolean;
	originalPxy : CM_TrackedItem;
	
begin

	on Exception do app.handleDeletedObject( exception, originalPxy, invalid );	//31 Aug 2020	NDL	TFS 49864 - found during testing
	
	foreach cmifTIObj in self.allPrenotesToProcess do
		if cmifTIObj.isKindOf( CMIF_Receival ) then	//31 Aug 2020	NDL	TFS 49864 - found during testing
			originalPxy := cmifTIObj.CMIF_Receival.myOriginalProxyTI;
		endif;
		cmifTIObj.deleteMyOriginalProxyTI();
	endforeach;

	self.allPrenotesToProcess.purge();

	self.allWagonsToAdd.purge();
	self.allWagonsToDelete.purge();
	self.allWagonsToUpdate.purge();
	
	delete self.allWagonsToAdd;
	delete self.allWagonsToDelete;
	delete self.allWagonsToUpdate;
	delete self.myProxyTrain;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="fixPassportErrors" id="f3ef1b64-a460-409a-bb30-8c7d249f7b67">
        <source>fixPassportErrors( _passport : CM_Passport);

/*

Purpose:	par 28809 - sometimes edi jump to line has null object	to work from due to transients during verfication process getting deleted.

Parameters:			

Return Value:		


Date		Who		Reason
16 March 2012	cnwrd1	Initial creation

*/

vars
	cmifObj 	: CMIF_TIObject;
	cmifPrenote : CMIF_PreNote;
	error 		: CM_Error;
	aTI			: CM_TrackedItem;
begin

	//return;
	
	foreach error in _passport.allErrorWarnings do
		if error.myUserObject = null then 
			continue;
		endif;
		
		if error.myUserObject.isKindOf(CM_TrackedItem) and error.myUserObject.isTransient then
			//no easy way back from this to the cmif_prenote or the cm_ediprenote!?
			aTI := error.myUserObject.CM_TrackedItem;
			
			foreach cmifObj in self.allPrenotesToProcess do
				if cmifObj.isKindOf(CMIF_PreNote) then
					cmifPrenote := cmifObj.CMIF_PreNote;
					if cmifPrenote.myProxyTrackedItem = aTI then
						error.setMyUserObject(cmifPrenote.myUserObject);
						break;
					endif;				
				endif;
			endforeach;
			
		endif;
	endforeach;

	
epilog

end;</source>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="getCargoFromTerminal" id="45da6353-96de-42ec-9038-37c9acf4c65e">
        <source>getCargoFromTerminal(_cargoType:Integer; _cargoId:String):CM_TrackedItem;
// --------------------------------------------------------------------------------
// Created:		17 March 2010 by cnwdad1
//
// Purpose:		Fetches a Cargo item from the Terminal.
//
// Parameters:	_cargoType - The Cargo Type Description.
//				_cargoId - The Cargo id.
//
// Returns:		A reference to the found Cargo item, or null.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	cargoObj	: CM_TrackedItem;
	
begin
	if self.myTerminal = null then
		app.raiseCMException(Terminal_reference_set, ETRow_Id, null);
	else
		cargoObj	:=	self.myTerminal.allNotifiedTIsByCargoTypeId[_cargoType,
																	_cargoId.toUpper()];
	endif;
	
	return cargoObj;
end;</source>
        <Parameter name="_cargoType" type="Integer"/>
        <Parameter name="_cargoId" type="String"/>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="getCurrentTrain" id="73768a6b-b4ba-47c5-a354-4772c484b329">
        <source>getCurrentTrain():CM_Train;
// --------------------------------------------------------------------------------
// Created:		10 March 2010 by cnwdad1
//
// Purpose:		Returns a reference to the current Train.
//
// Parameters:	None
//
// Returns:		A referene to a Train object, or null.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.trainAction = CM_EDITrackedItem.EDI_ACTION_DELETE then
		return self.myRealTrain;
	else
		return self.myProxyTrain;
	endif;
end;</source>
        <ReturnType type="CM_Train"/>
    </JadeMethod>
    <JadeMethod name="getEDIWagonMatching" id="8b3495d1-cd1f-43c3-9f96-ef89bb7aaf30">
        <source>getEDIWagonMatching( _wagon : CM_Wagon ):CM_EDIWagonTI;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 March 2015	cnwndl1	Initial creation	Par 35828

*/

vars

	ediWagon : CM_EDIWagonTI;
	invalidObj : Boolean;

begin

	if self.myEDIDataTrainConsist = null or _wagon = null then
		return null;
	else
		on Exception do app.handleDeletedObject( exception, self.myEDIDataTrainConsist, invalidObj );
		ediWagon := self.myEDIDataTrainConsist.getEDIWagonMatching( _wagon );
	endif;
	
	return ediWagon;

epilog

end;</source>
        <Parameter name="_wagon" type="CM_Wagon"/>
        <ReturnType type="CM_EDIWagonTI"/>
    </JadeMethod>
    <JadeMethod name="getTrainFromTerminal" id="432b6c00-3986-4ed6-94f4-655dcbf1bd99">
        <source>getTrainFromTerminal(_code:String; _scheduledDT:TimeStamp):CM_Train;
// --------------------------------------------------------------------------------
// Created:		18 February 2010 by cnwdad1
//
// Purpose:		Fetches a Train from the Terminal.
//
// Parameters:	_code - The Train code.
//				_scheduledDT - The Train's scheduled arrival date/time.
//
// Returns:		A reference to the found Train, or null.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return self.myTerminal.allTrainsOnTerminal[_code, _scheduledDT];
end;</source>
        <Parameter name="_code" type="String"/>
        <Parameter name="_scheduledDT" type="TimeStamp"/>
        <ReturnType type="CM_Train"/>
    </JadeMethod>
    <JadeMethod name="isMatchingTrain" id="76d3e96e-0b35-4482-844e-8d55757d4699">
        <source>isMatchingTrain(_trainCode:String; _arrivalDT:TimeStamp):Boolean;
// --------------------------------------------------------------------------------
// Created:		09 March 2010 by cnwdad1
//
// Purpose:		Returns a boolean flag to indicate whether the specified train
//				details match those of this Train Consist.
//
// Parameters:	_trainCode - The Train Code identifier.
//				_arrivalDT - The train's scheduled arrival date.
//
// Returns:		True of the train details match, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.trainAction = CM_EDITrackedItem.EDI_ACTION_ADD then
		return (self.myProxyTrain.code = _trainCode and self.myProxyTrain.scheduledArrivalDT = _arrivalDT);
	else
		return (self.myRealTrain.code = _trainCode and self.myRealTrain.scheduledArrivalDT = _arrivalDT);
	endif;
end;</source>
        <Parameter name="_trainCode" type="String"/>
        <Parameter name="_arrivalDT" type="TimeStamp"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isWagonAlreadyUsed" id="f293ffe0-5275-40b3-af2b-7eec8a3ec9e0">
        <source>isWagonAlreadyUsed(_wagonNumber:String):Boolean;
// --------------------------------------------------------------------------------
// Created:		29 March 2010 by cnwdad1
//
// Purpose:		Returns a boolean flag to indicate whether the specified Wagon Number
//				has already been handled by this Train Consist.
//
// Parameters:	_wagonNumber - The Wagon ID.
//
// Returns:		True if the Wagon has already been used, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.allWagonsToAdd[_wagonNumber, self.scheduledArrivalDT] &lt;&gt; null then
		return true;
	elseif self.allWagonsToDelete[_wagonNumber, self.scheduledArrivalDT] &lt;&gt; null then
		return true;
	elseif self.allWagonsToUpdate[_wagonNumber, self.scheduledArrivalDT] &lt;&gt; null then
		return true;
	endif;
	
	return false;
end;</source>
        <Parameter name="_wagonNumber" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isWagonOnTrain" id="90a1c806-0863-4ed2-8599-b819b5fcbe27">
        <source>isWagonOnTrain(_wagonNumber:String):Boolean;
// --------------------------------------------------------------------------------
// Created:		10 March 2010 by cnwdad1
//
// Purpose:		Returns a boolean flag to indicate whether the specified Wagon is
//				(or will be) attached to the current Train.
//
// Parameters:	_wagonNumber - The Wagon ID.
//
// Returns:		True if the Wagon is (or will be) attached to the current train,
//				otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	wagonObj	: CM_Wagon;
	allStrings	: StringArray;
	wagonCode	: String;
	
begin
	if _wagonNumber.cnContains(Space) then
		create allStrings transient;
		allStrings	:=	_wagonNumber.cnGetTokens(Space);
		
		// Wagon Number is in position 1 and Slot Number (optional) in position 2.
		if allStrings.size() &gt; 1 then	// Should always be the case!
			wagonCode	:=	allStrings[1];
		else
			wagonCode	:=	_wagonNumber;
		endif;
	else
		wagonCode	:=	_wagonNumber;
	endif;
	
	if self.trainAction = CM_EDITrackedItem.EDI_ACTION_DELETE then
		if self.myRealTrain &lt;&gt; null then
			wagonObj	:=	self.myRealTrain.allWagonsByIdInward[wagonCode];
		endif;
	else
		if self.myProxyTrain &lt;&gt; null then
			wagonObj	:=	self.myProxyTrain.allWagonsByIdInward[wagonCode];
		endif;
	endif;
	
	if wagonObj = null then
		wagonObj	:=	self.allWagonsToAdd.getAtKeyLeq(wagonCode, null);
		
		if wagonObj = null then
			wagonObj	:=	self.allWagonsToUpdate.getAtKeyLeq(wagonCode, null);
		endif;
	endif;
	
	if wagonObj &lt;&gt; null and wagonObj.id = wagonCode then
		return true;
	endif;
	
	return false;
epilog
	delete allStrings;
end;</source>
        <Parameter name="_wagonNumber" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
