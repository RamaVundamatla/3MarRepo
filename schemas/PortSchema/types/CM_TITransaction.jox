    <JadeMethod name="cloneForTrackedItem" id="643b37d0-5256-4e80-bdf5-3fae32d50b3b">
        <updating/>
        <source>cloneForTrackedItem(_ti : CM_TrackedItem ; _transient : Boolean) : SelfType updating;
// -----------------------------------------------------------------------------
// Created:		10 April 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
vars 
	clone : CM_TITransaction;
begin
	clone := self.cloneSelf(_transient);
	clone.cloneForTrackedItemRefs(_ti, self);
	return clone;
end;</source>
