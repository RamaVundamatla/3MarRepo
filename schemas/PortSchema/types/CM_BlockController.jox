    <JadeMethod name="calculateFIFODate" id="ee51d5c8-0c41-46f7-b2a6-9c08da51152b">
        <source>calculateFIFODate() : Date;
//Returns the received date of the earliest TI in this Stack
//If stack is MT, returns current Date.
vars
	sortedByDate	:	CM_TIByReceiveDT;
	ti	:	CM_TrackedItem;
	now	:	Date;
begin
	if self.allTrackedItems.isEmpty then
		return now;
	endif;

	create sortedByDate transient;
	//----------------
	//Painful, but no other way!
	//----------------
	foreach ti in allTrackedItems do
		if not ti.receivedDT.isValid then
			continue;
		endif;
		sortedByDate.add(ti);		
	endforeach;

	if sortedByDate.isEmpty then
		return now;
	endif;
	//----------------
	//Return the received DT of the 1st TI
	//----------------
	return sortedByDate.first.receivedDT.date;
epilog
	delete sortedByDate;
end;</source>
        <ReturnType type="Date"/>
    </JadeMethod>
    <JadeMethod name="calculateFIFODateDuringMove" id="6c564e13-b8b6-4764-883a-da55fce536d5">
        <source>calculateFIFODateDuringMove( _inward : Boolean; _moveTi : CM_TrackedItem );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 March 2018	jlgndl1	Initial creation	TFS 37759

*/

vars

	blockStack			 : CM_BlockStack;
	bsEffectiveFIFODate  : Date;
	tiReceiveDate 		 : Date;
	termArea			 : CM_TerminalArea;	
begin

	if _moveTi = null then
		return;
	endif;
	
	tiReceiveDate := _moveTi.receivedDT.Date;
	if not tiReceiveDate.isValid then
		return;
	endif;
	
	termArea := self.myTerminalArea;
	
	if termArea = null or not termArea.isBlockStack then
		return;
	endif;
	
	blockStack 			:= termArea.CM_BlockStack;
	bsEffectiveFIFODate := blockStack.effectiveFIFODate;
	
	if _inward then
		//We are moving this ti into the blockstack
		
		if not bsEffectiveFIFODate.isValid then
			//No current date, use this one.
			blockStack.setFIFODateDuringMove( tiReceiveDate );
		
		elseif tiReceiveDate &lt; bsEffectiveFIFODate then
			//This guy will be the earliest received in the BS, so update the date.
			blockStack.setFIFODateDuringMove( tiReceiveDate );
			
		else
			//This guy is not the earliest received or was received the same day as the earliest
			// so nothing to do here
		endif;
		
		return;
		
	else
		//We are moving this ti out of the blockstack
		if bsEffectiveFIFODate.isValid and tiReceiveDate &gt; bsEffectiveFIFODate then
			//This guy is not currently the earliest received in the BS, so nothing to do.
			
		else
			//This guy is the earliest received or was received the same day as the earliest
			//We do actually need to re-calculate in case the date has changed
			blockStack.calculateFIFODate();
			
		endif;
		
		return;
		
	endif;
	

epilog

end;</source>
        <Parameter name="_inward" type="Boolean"/>
        <Parameter name="_moveTi" type="CM_TrackedItem"/>
    </JadeMethod>
