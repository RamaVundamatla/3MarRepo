	dynaDict.setMembership(CM_InvoiceLine);
	dynaDict.addExternalKey(String,300,false,false);
	dynaDict.endKeys(true);
	foreach invLine in invoice.invoiceLines discreteLock do
		dynaDict.putAtKey(invLine.externalRef4,invLine);
	endforeach;
	
	create invoiceLines transient;
	
	lastDisplayValue:=dynaDict.first.CM_InvoiceLine.externalRef4;
	iter:=dynaDict.createIterator;
	while iter.next(invoiceLine) do
		
		financialDimensions:= iter.getCurrentKey(1).String;
		if financialDimensions &lt;&gt; lastDisplayValue then
			//add the json stuff 
			//contentID:=contentID+1;
			write totalQuantity.String &amp; Tab &amp;  totalAmount.String &amp;  Tab &amp; invoiceLines.size.String;
			//body:=body &amp; CrLf &amp; self.getNSWInvoiceLinesHeaderText(headerID,baseURL,contentID.String) &amp; CrLf;
			firstInvoiceLine:=invoiceLines.first;
			//invoiceLineGrpJSON:=getNSWInvoiceLinesBodyText(jdo,firstInvoiceLine,contentID.String,financialDimensions,totalAmount,totalQuantity);
			//body:=body &amp; invoiceLineGrpJSON &amp; CrLf; 
			
			lastDisplayValue:=financialDimensions;
			invoiceLines.clear;	
			totalQuantity:=0;
			totalAmount:=0;
		endif;
		invoiceLines.add(invoiceLine);
	//	write invoiceLine.externalRef4;
		totalQuantity:=totalQuantity + invoiceLine.quantity;
		totalAmount:=totalAmount + invoiceLine.totalAmount;
	endwhile;
	
	if invoiceLines.first &lt;&gt; null then
		//contentID:=contentID+1;
		write totalQuantity.String &amp; Tab &amp;  totalAmount.String &amp;  Tab &amp; invoiceLines.size.String;
		//body:=body &amp; CrLf &amp; self.getNSWInvoiceLinesHeaderText(headerID,baseURL,contentID.String) &amp; CrLf;
		firstInvoiceLine:=invoiceLines.first;
		//invoiceLineGrpJSON:=getNSWInvoiceLinesBodyText(jdo,firstInvoiceLine,contentID.String,financialDimensions,totalAmount,totalQuantity);
	//	body:=body &amp; invoiceLineGrpJSON &amp; CrLf; 	
	endif;
	
	//return;*/
	//	invoice:="2216.1280299".asOid.CM_Invoice; //51503 Credit NOTE
	//	invoice:="2216.1279723".asOid.CM_Invoice;
		write invoice.sequenceNum;
	transientInvoice := invoice.cloneForConsolidation();	
	
	invoice.getInvLinesConsExternalRef4(transientInvoice);
	isCreditReturn:=invoice.status = CM_Invoice.INVOICE_POSTED_CREDIT_ERROR or	
					invoice.status = CM_Invoice.INVOICE_POSTED_CREDIT_PENDING;
	foreach invoiceLine in transientInvoice.invoiceLines do
		if isCreditReturn  and  invoiceLine.voided then
		
			invoiceLine.setStatus(CM_InvoiceLine.STATUS_NORMAL);
		endif;
		
	//	write invoiceLine.lineTotal;
	//	write invoiceLine.totalAmount;
	//	invoiceLine.setStatus(CM_InvoiceLine.STATUS_NORMAL);
	//	write invoiceLine.getTaxAmountForLine;
	
		write invoiceLine.getLineDescNarration;
		if invoiceLine.getGLCode &lt;&gt; null then
		//	write invoiceLine.getGLCode.code;
		endif;
		//write invoiceLine.taxCode;
		
		write invoiceLine.quantity;
		write invoiceLine.totalAmount/invoiceLine.quantity;
		//write invoiceLine.getRate;
		write invoiceLine.taxValue;
		write invoiceLine.invoiceLineDesc.unitNarration;
	endforeach;
	
	//return;
	delete transientInvoice;
	
	invoice:="2216.607596".asOid.CM_Invoice; //60347 invoice - cargo transactions
//	invoice:="2216.1277891".asOid.CM_Invoice; // 61029 invoice - hms transactions
	transientInvoice := invoice.cloneForConsolidation();	
	
	invoice.getInvLinesConsExternalRef4(transientInvoice);
write invoice.sequenceNum;
	foreach invoiceLine in transientInvoice.invoiceLines do
	//	if isCreditReturn  and  invoiceLine.voided then
		
