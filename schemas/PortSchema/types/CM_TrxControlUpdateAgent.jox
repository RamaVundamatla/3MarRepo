    <JadeMethod name="trxAddFile" id="bfc1f6e7-e1eb-4bb5-9208-8dbf19672dd5">
        <updating/>
        <source>trxAddFile(_parent 			: CM_Object; 
			_fileName   	: String; 
			_description	: String; 
			_heading		: String;
			_category       : CM_FileDataCategory;
			_remarks 		: String;
			_context		: Integer;		//22.2.2023 navhl20	#56625[56517]
			_passport 		: CM_Passport input) updating;

/*
Created:     11 November 2002 by cnwrs2

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 Mar 2022 navma1	ChangeRequest 52821: EUP - Documents Linked to Cargo Types
05 Dec 2022 navvt20 TFS CR 55299 Task 55520: UI - File Load and File Attachment UI changes
15 Feb 2023 navds21 ChangeRequest 56625:[56517] EUP - Print Documents at Kiosk
22 May 2023	navmk20	Bug 58087: FR | EUP 54086 - Invoicing - Maintenance Enhancements 090.h
*/
vars
	f			: File;
	fileData	: CM_FileData;
	terminal 	: CM_Terminal;
begin

	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);


	app.setContinueCMExceptions(true);
	
	create f transient;
	app.myValCA.valAddFile(_parent, _fileName, f);
	
	if (not self.checkValidationWithPassport(_passport)) then
		return;
	endif;

	app.setContinueCMExceptions(false);

	beginTransaction;

	create fileData persistent;
	//fileData.setForCreate(_parent, _passport.userCode, f, _description,_heading);								  // 5 Dec 2022 navvt20 TFS 55520
	//fileData.setForCreate(_parent, _passport.userCode, _category, _remarks,f, _description,_heading); 		  //5 Dec 2022 navvt20 TFS 55520		//22.2.2023 navhl20	#56625[56517]
	fileData.setForCreate(_parent, _passport.userCode, _category, _remarks,f, _description,_heading,_context); 	  //22.2.2023 navhl20	#56625[56517]		
	
	//22.03.2022 navma1 #52821
	if _passport.noErrors and _parent &lt;&gt; null then
		_parent.causeEvent(EventFileAdd, false, fileData);
		if _parent.isKindOf(CM_CargoBOLType) then
			self.updateObjectEdition (_parent);	
		elseif _parent.isKindOf(CM_WorkOrder) then
			//jlier1 29/5/25 MTN-34591 
			terminal:=_parent.getMyTerminal;
			if terminal &lt;&gt; null then
				app.myEventManager.createSingleObjInfoNoteEvt(_parent, terminal.getTerminalEvent(Event_WorkOrder_Update),  _parent);
			endif;
		endif;
	endif;
	
	// START - 22.5.2023 navmk20	TFS 58087
	if _passport.noErrors then
		app.myUtilityCA.myCreateAuditAgent.audCreateGeneric(fileData);
	endif;
	// END - 22.5.2023 navmk20	TFS 58087
	
epilog
	self.finaliseActivityWithPassport(_passport);
	delete f;
end;</source>
        <Parameter name="_parent" type="CM_Object"/>
        <Parameter name="_fileName" type="String"/>
        <Parameter name="_description" type="String"/>
        <Parameter name="_heading" type="String"/>
        <Parameter name="_category" type="CM_FileDataCategory"/>
        <Parameter name="_remarks" type="String"/>
        <Parameter name="_context" type="Integer"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxAddHMSResourceUsed" id="b913e468-e052-446e-b843-6001966e4126">
        <updating/>
        <source>trxAddHMSResourceUsed(_pxyObject : HMS_ResourceUsed input; _movement : HMS_VoyageMovement input; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     14 June 2012 by cnwjre1
//
// Purpose:     Add an HMS resource used to a voyage movement without going through the unnecessary update of the movemen
//
// Parameters:  Proxy resource usage, persistent movement, passport
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	beginTransaction;

	app.myUtilityUA.utlAddHMSResourceUsed(_pxyObject, _movement, _passport);

epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_pxyObject" type="HMS_ResourceUsed" usage="input"/>
        <Parameter name="_movement" type="HMS_VoyageMovement" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxAddToCargoGroup" id="4bc80a59-ef77-443a-addb-76e4e902d98e">
        <updating/>
        <source>trxAddToCargoGroup(	_cargoGroup : CM_CargoGroup io;
					_realTIToAdd : CM_TrackedItem io;
					_moveLocation : CM_LocationsController input;
					_cgsToComplete : CM_TISet;
					_completeAssignment : CM_CargoGroupAssignment input;
					_passport : CM_Passport input
					) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 June 2015	cnwndl1	Initial creation	Par 36338
14 Mar 2024 navhl20 ChangeRequest 62861: EUP | Retrospective Operations - [54177.090] - UnPack
*/

vars

	terminal : CM_Terminal;
	moveController	: CMIF_MoveController;
	txn : CM_TITransaction;
	ti : CM_TrackedItem;
	cgToComplete : CM_CargoGroup;
	
begin

	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(false);
	
	if _realTIToAdd = null then
		app.raiseCMException( Please_select_cargo_itemPOP, null, null );
		return;
	endif;
	
	if _realTIToAdd.isOffSite() then
		app.raiseCMException( Cargo_offsite_cannot_moved, null, null );
		return;
	endif;
	
	if _moveLocation = null then
		app.raiseCMException( Input_required_field_locn, null, null );
		return;
	endif;
	
	terminal := _realTIToAdd.myTerminal;
	
	// set up the move controller
	
	if _realTIToAdd.isChild then
		// Will be doing an unpack
	else
		if _realTIToAdd.myPrimaryActualLocation &lt;&gt; _moveLocation then
			create moveController transient;
			moveController.setMyTrackedItem( _realTIToAdd );
			moveController.setMyToPrimaryLocation(_moveLocation);
			moveController.setMoveMode(REAL_MODE);
		endif;
	endif;

	// Start the transaction
	beginTransaction;
	
	_passport.useTIDictDeferUpdate := true;	//03 Mar 2020	NDL	TFS 48719
	_passport.useTITransactionDeferUpdate := true;	//03 Mar 2020	NDL	TFS 48719
	
	if not _cargoGroup.allAssignedTrackedItems.includes(_realTIToAdd) then
		app.myUtilityUA.utlCargoGroupAddTi( _cargoGroup, _realTIToAdd, _passport );
		
		if _passport.hasErrors then
			return;
		endif;
	endif;
	
	if _realTIToAdd.isChild then
		app.myUtilityUA.utlUpdateUnpackCargo(_realTIToAdd, _moveLocation, _realTIToAdd.totalQuantity, _realTIToAdd.totalWeight, null, _passport);	//14.03.2024 navhl20 #62861
	elseif moveController &lt;&gt; null then
		app.myUtilityUA.utlUpdateMoveTrackedItem(moveController, _passport);
	endif;
	
	if _passport.hasErrors then
		return;
	endif;
	
	//11 Jul 2018	NDL	TFS 39186
	foreach ti in _cgsToComplete do
		cgToComplete := ti.CM_CargoGroup;
		app.myUtilityCA.utlCreateCGComplete( cgToComplete, txn, _passport);
		if _passport.hasErrors then
			return;
		endif;
	endforeach;
	
	//11 Jul 2018	NDL	TFS 39186
	if _completeAssignment &lt;&gt; null then
		_completeAssignment.setCompleted( app.actualTimeAppServer );
	endif;
	
	_passport.doDeferredUpdates();	//03 Mar 2020	NDL	TFS 48719

epilog

//	delete cgProxy;
	delete moveController;
	
	self.finaliseActivityWithPassport(_passport);
	
end;</source>
        <Parameter name="_cargoGroup" type="CM_CargoGroup" usage="io"/>
        <Parameter name="_realTIToAdd" type="CM_TrackedItem" usage="io"/>
        <Parameter name="_moveLocation" type="CM_LocationsController" usage="input"/>
        <Parameter name="_cgsToComplete" type="CM_TISet"/>
        <Parameter name="_completeAssignment" type="CM_CargoGroupAssignment" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
