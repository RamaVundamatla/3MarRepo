Return Value:		

Date		Who		Reason
23 December 2022	navhl20	ChangeRequest 54350:[54269] EUP - VAS Work Orders Selector Query

*/

vars

begin
	self.myFilterClass := CM_WOTransaction;

epilog

end;</source>
