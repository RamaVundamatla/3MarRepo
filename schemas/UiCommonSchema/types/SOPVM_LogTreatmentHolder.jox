    <JadeMethod name="loadTreeViewArray" id="8c40d13f-931f-4e96-aab5-3684062027e2">
        <source>loadTreeViewArray(_collection: Collection input; _level: Integer; _form: CMUI_CodesMaintTree; _parent : SOP_ViewModelObject);
// -----------------------------------------------------------------------------
// Created:		12 March 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
vars
	iter : Iterator;
	code : CM_Code;
begin
	_collection.add(self);

	if self.myObject &lt;&gt; null then
		iter := self.myObject.CM_CodeGroupLogSpecs.allLogTreatments.createIterator();
		while iter.next(code) do
			code.loadTreeViewArray(_collection, _level + 1, _form, self);
		endwhile;
	endif;
epilog 
	delete iter;
end;</source>
        <Parameter name="_collection" type="Collection" usage="input"/>
        <Parameter name="_level" type="Integer"/>
        <Parameter name="_form" type="CMUI_CodesMaintTree"/>
        <Parameter name="_parent" type="SOP_ViewModelObject"/>
    </JadeMethod>
</Class>
