    <JadeMethod name="doFrameDrawScroll" id="2375480e-32ca-4eda-8c42-556fda8bbd08">
        <source>doFrameDrawScroll(_direction : Integer; _value : Integer);
/*
Purpose:			
Date		Who		Reason
21 April 2011	cnwab1	Initial creation
*/

vars

	obj : Object;
	layerFrame : CMUI_PointDrawingFrame;
begin
	self.repositionAllBackFrames();
	return;
	
	
	



	foreach obj in self.allBackgroundFrames reversed, discreteLock do
		layerFrame := obj.CMUI_PointDrawingFrame;
		layerFrame.left := self.frmScrollable.myDrawingFrame.left;
		layerFrame.top := self.frmScrollable.myDrawingFrame.top;
				layerFrame.zOrder(0);
	endforeach;
epilog

end;</source>
