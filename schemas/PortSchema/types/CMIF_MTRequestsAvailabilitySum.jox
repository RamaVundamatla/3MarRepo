    <JadeMethod name="setFromBR" id="2f97283c-51f2-40a3-b0fe-7b0978f7fef0">
        <updating/>
        <source>setFromBR(_bulkRel: CM_BulkRelease; _setKeys: Boolean) updating;
//----------------------------------------------------------------
//	Created:	08 November 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	outstanding		: Integer;
	tmpBR			: CM_BulkRelease;
	avaGrades		: IntegerArray;
	firstAvaGrade	: Integer;
	isoTypeGroup	: CM_ISOTypeGroup;
	invalidISOGroup : Boolean;
begin
	tmpBR := _bulkRel;
	
	avaGrades := tmpBR.getAllAvailabilityGrades();
	
	if avaGrades &lt;&gt; null and (not avaGrades.isEmpty) then
		firstAvaGrade := avaGrades.first;
	endif;
	
	self.allBulkReleases.add(tmpBR);
	
	if _setKeys then
		self.operatorCode			:= tmpBR.getOperatorCode;
		self.operatorDesc			:= tmpBR.getOperatorDesc;
		self.isoGroupCode			:= tmpBR.getISOGroupCode;
		self.isoGroupDesc			:= tmpBR.getISOGroupDesc;
		self.avaGradeId				:= firstAvaGrade;
	endif;

	isoTypeGroup := tmpBR.getISOGroup(); //30/09/2011 cnwdz2 Par 28148
	on Exception do app.handleDeletedObject(exception, isoTypeGroup, invalidISOGroup);
	
	if self.isoGroupReportOrder = null and isoTypeGroup &lt;&gt; null then
		self.isoGroupReportOrder := isoTypeGroup.reportGroupOrder;	//kind of a key //30/09/2011 cnwdz2 Par 28148
	endif;
	
	outstanding := tmpBR.getTotalStorageEmpties;
	
	if tmpBR.status = BR_ACTIVE then
		if tmpBR.type = BR_TYPE_ROAD then												// 29 Dec 2010	NDL	Par 26650
			self.totalTransportRequests := self.totalTransportRequests + outstanding;	// 29 Dec 2010	NDL	Par 26650
			self.totalRoadRequests := self.totalRoadRequests + outstanding;				// 29 Dec 2010	NDL	Par 26650
			
		elseif tmpBR.type = BR_TYPE_RAIL then											// 29 Dec 2010	NDL	Par 26650
			self.totalTransportRequests := self.totalTransportRequests + outstanding;	// 29 Dec 2010	NDL	Par 26650
			self.totalRailRequests := self.totalRailRequests + outstanding;				// 29 Dec 2010	NDL	Par 26650
			
		elseif tmpBR.type = BR_TYPE_SHIP then
			self.totalShippingRequests := self.totalShippingRequests + outstanding;
			
		elseif tmpBR.type = BR_TYPE_PACKING then
			self.totalGeneralCargoRequests := self.totalGeneralCargoRequests + outstanding;
		else
			//for debugging - not for display
			self.totalOtherBR := self.totalOtherBR + 1;
			app.writeStatement('CNWJC2 ' &amp; class.name &amp; " " &amp; method.name &amp;  " BR not categorised (" &amp; tmpBR.type.String &amp; ").  Total = " &amp; self.totalOtherBR.String);
		endif;
		
	elseif tmpBR.status = BR_PENDING then
		
		self.totalPendingRequests := self.totalPendingRequests + outstanding;
	
	else
		//for debugging - not for display
		self.totalOtherBR := self.totalOtherBR + 1;
		app.writeStatement('CNWJC2 ' &amp; class.name &amp; " " &amp; method.name &amp;  " BR not categorised (status).  Total = " &amp; self.totalOtherBR.String);
	endif;
end;</source>
        <Parameter name="_bulkRel" type="CM_BulkRelease"/>
        <Parameter name="_setKeys" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setFromTI" id="fb0f4366-d9ca-43f5-a1ce-b687e6078597">
        <updating/>
        <source>setFromTI(_ti: CM_Container; _setKeys: Boolean) updating;
//----------------------------------------------------------------
//	Created:	08 November 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	todoTask		: CM_ToDoTask;
	taskDesc		: CM_ToDoTaskDesc;
	tiTA			: CM_TerminalArea;
	isoGrp			: CM_ISOTypeGroup;
begin
	
	self.allTrackedItems.add(_ti);
	
	if _setKeys then
		self.operatorCode	:= _ti.operatorCode;
		//self.operatorDesc	:= _ti.operatorDescription;
		//par16574--inorder to truncate operateDescription
		self.operatorDesc:=_ti.operatorDescription[1:35];
		self.isoGroupCode	:= _ti.isoTypeGroup;
		self.isoGroupDesc	:= _ti.isoTypeGroupDesc;
		self.avaGradeId		:= _ti.availabilityGrade;
	endif;

	//if self.isoGroupReportOrder = null then //- cnwmd1, Par 22321
	//	self.isoGroupReportOrder := _ti.getISOTypeGroupReportOrder();	//kind of a key
	
	isoGrp := _ti.getISOTypeGroup; //+ cnwmd1 Par 22321 - Key type changed from integer to string in the TI
	if self.isoGroupReportOrder = null and isoGrp &lt;&gt; null then
		self.isoGroupReportOrder := isoGrp.reportGroupOrder;	//kind of a key
	endif;	

	tiTA := _ti.myTerminalArea;
	
	if _ti.site = TI_SITE_ONSITE then
		self.totalOnSite := self.totalOnSite + 1;
	endif;
	
	if _ti.isAvailable then
		self.totalAvailable := self.totalAvailable + 1;
		//no tasks or stops so...
		return;
	endif;
	
//	if _ti.getAllStops().size &lt;&gt; 0 then		// cnwrl1 14/12/2009 PAR 21889 - what it was
	if _ti.getAllActiveStopsSize &lt;&gt; 0 then
		self.totalWithStops := self.totalWithStops + 1;
	endif;
	
	foreach todoTask in _ti.allToDoTasksToDo do
		taskDesc := todoTask.toDoTaskDesc;
		if taskDesc = null then
			continue;
		endif;
		if taskDesc.emptyReportColumn = MTReportTaskColumn_Wash then	//WASH
			if tiTA &lt;&gt; null and
			tiTA.type = TA_TYPE_WASH_AREA then
				self.inAreaTask01 := self.inAreaTask01 + 1;
			endif;
			self.awaitingTask01 := self.awaitingTask01 + 1;
		elseif 	taskDesc.emptyReportColumn = MTReportTaskColumn_Repair then			//REPAIR
			if tiTA &lt;&gt; null and
			tiTA.type = TA_TYPE_REPAIR then
				self.inAreaTask02 := self.inAreaTask02 + 1;
			endif;
			self.awaitingTask02 := self.awaitingTask02 + 1;
		elseif 	taskDesc.emptyReportColumn = MTReportTaskColumn_Pretrip then			//PRETRIP
			if tiTA &lt;&gt; null and
			tiTA.type = TA_TYPE_PTI then
				self.inAreaTask03 := self.inAreaTask03 + 1;
			endif;
			self.awaitingTask03 := self.awaitingTask03 + 1;
		elseif taskDesc.emptyReportColumn = MTReportTaskColumn_PTIRepair then			//PTI Repair
		
			self.awaitingTask04 := self.awaitingTask04 + 1;
		elseif 	taskDesc.emptyReportColumn = MTReportTaskColumn_Survey then				//Survey
			
			self.awaitingTask05 := self.awaitingTask05 + 1;
		endif;

	endforeach;
	
end;</source>
        <Parameter name="_ti" type="CM_Container"/>
        <Parameter name="_setKeys" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setReportGroupFromSelf" id="4146ede9-c3b5-4703-bc0b-4e4e62c9cc2a">
        <source>setReportGroupFromSelf(_reportGroup: CM_ReportGroup input);
//----------------------------------------------------------------
//	Created:	09 November 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin
	
	if _reportGroup.label = 'isoGroupCode' then
		_reportGroup.sortOrder := self.isoGroupReportOrder;
		_reportGroup.heading := "ISO Group ";
		_reportGroup.description := self.isoGroupDesc;
	elseif _reportGroup.label = 'operatorCode' then
	
		_reportGroup.heading := "Operator ";
		_reportGroup.description := self.operatorDesc;
	elseif _reportGroup.label = 'avaGradeId' then
		
		_reportGroup.heading := "Availabilty Grade ";
		_reportGroup.description := self.avaGradeDesc;
	endif;
	

end;</source>
        <Parameter name="_reportGroup" type="CM_ReportGroup" usage="input"/>
    </JadeMethod>
    <JadeMethod name="shippingRequestsDisplay" id="4982cae9-81eb-44f1-92b0-088842d350f0">
        <source>shippingRequestsDisplay() : String;
//----------------------------------------------------------------
//	Created:	16 01 2007	by Yi Liu  (cnwyl1)
//	Reason: CCMS 1498 for Port Otago
//----------------------------------------------------------------
vars

begin
	if self.totalShippingRequests &lt;&gt; 0 then
		return self.totalShippingRequests.String;
	endif;
end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
