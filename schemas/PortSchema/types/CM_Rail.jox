    <JadeMethod name="validate" id="1a446ec2-1069-44af-9c6e-bc6fcb679589">
        <source>validate() protected;

vars
	
begin

	if self.id.trimBlanks = null then
	//	app.raiseCMException1(REQUIRED_FIELD, app.getErrorString(Rail_area_id), null, null);
		app.raiseCMException1(Input_required_field_Required, app.getErrorString(Rail_area_id), null, null); // cnwdb2	PAR 35364


	endif;
	
	self.validateRailLinesAndJobs;
	
	inheritMethod();

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="validateForDelete" id="50055414-bd27-4e9d-9403-71af8684e834">
        <source>validateForDelete();
// ---------------------------------------------------------------------------
// Created:		November  2001 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	railLine	: CM_RailLine;
	theID : String;
begin
	if self.type = TA_TYPE_RAILWAY_TRACK then
		theID := app.myPassport.myTerminal.getConfig(DefRailOpsArea).String;
		if theID = self.id then
	//		app.raiseCMException(ERR_USED_IN_CONFIG,null, null);
			app.raiseCMException3(ERR_USED_IN_CONFIG,app.getErrorString(CM_Rail_Area), self.id,app.getErrorString(Terminal) &amp; " " &amp; app.myPassport.myTerminal.code,null, null);
			return;
		endif;
	endif;


	foreach railLine in self.allRailLinesByIndex do
		if (not railLine.allWagons.isEmpty) then
			app.raiseCMException(ERR_LC_HAS_WAGON, null, null);
			break;
		endif;
	endforeach;

	inheritMethod();

end;</source>
    </JadeMethod>
    <JadeMethod name="validateMoveLabourRestriction" id="72d969bb-8c47-4e35-8ba9-7f4c47cbef03">
        <source>validateMoveLabourRestriction(control : CMIF_MoveController);
/*
 ------------------------------------------------------------------------
Created:			27 July 2001 by cnwdwq1
Purpose:			
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/
vars
begin
	sharedLock(self);
	
	if self.labourRestriction = null then
		//No worries
		return;
	endif;
	
	// moved to CM_LabourRestriction::createWarning
	//if control.isRadioTelemetryMove then
	//	self.labourRestriction.createWarningAsAlert(WARN_RESTRICT_LABOUR);
	//endif;
	
	//---------------------
	//We also need to create a Warning for the FROM portion of this move
	//---------------------
	self.labourRestriction.createWarning(control);
epilog
	unlock(self);
end;</source>
        <Parameter name="control" type="CMIF_MoveController"/>
    </JadeMethod>
    <JadeMethod name="validateRailLinesAndJobs" id="b8bf7486-c080-4d44-a000-690d2630c7d3">
        <source>validateRailLinesAndJobs();
//********************************************************************
//
// Created by: cnwsh3
//
// Date: 24 September 2004
//
//********************************************************************
vars
	railLine : CM_RailLine;
	rail : CM_Rail;
	obj : Object;
	railJob : CM_RailJob;
begin
	//----------------------------------------------------------------------------------------------------
	// Check to confirm there are no rail jobs on any part of the railway track as they
	// get blown away when the rail lines are redefined.	
	//----------------------------------------------------------------------------------------------------
	rail := self.pxyGetRealObject();
	if rail &lt;&gt; null then
		foreach obj in rail.allRailJSInOut do
			if obj.isKindOf(CM_RailJSInOutRake) then
				if obj.CM_RailJSInOutRake.railJobs.size &gt; 0 then
					app.raiseCMException1(RailJobsOnRailwayTrack, rail.id, null, null);
					break;
				endif;
			endif;
		endforeach;
	
	//----------------------------------------------------------------------------------------------------
	//Check there are no wagons any of the rail lines before we blow them away and redefine
	//the lines.	
	//----------------------------------------------------------------------------------------------------
		foreach railLine in rail.allRailLines do
			if railLine.allWagons.size &gt; 0 then
				app.raiseCMException1(WagonsExistOnRailLine, railLine.id, null, null);
				break;
			endif;
		endforeach;
	endif;
	
end;</source>
    </JadeMethod>
</Class>
