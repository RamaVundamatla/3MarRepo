    <JadeMethod name="calculateTitleWidths" id="8f3e0332-cfec-4ddd-90e8-beb3da46ec34">
        <source>calculateTitleWidths(_locnStatsTable : CM_LocnStatsTable io; _yamTable : CM_YAMTable io; _totalWidth, _usedWidth, _qInWidth, _qOutWidth, _freeWidth, _projectedWidth, _planInWidth, _planOutWidth, _priorityWidth, _deckingWidth, _seqWidth, _ifNoLocFoundWidth, _overstowRuleWidth, _allowOthersWidth : Integer output);
// --------------------------------------------------------------------------------
// Created:		29 Janurary 2009 by cnwjo3
//
// Purpose:		get all the values of the columns to save in userWindow xmlInfo
//
vars
	prop : String;
	colPointer : Integer;
	dataTable : CM_DataTable;
begin
	if _locnStatsTable &lt;&gt; null then
		dataTable := _locnStatsTable;
	else
		dataTable := _yamTable;
	endif;
	
	foreach prop in dataTable.allTblDataColPropertyNames do
		if prop = ETRow_Total20 or prop = ETRow_Total30 or prop = ETRow_Total40 or prop = ETRow_Total45 or prop = ETRow_Total53 or prop = ETRow_ColTotalTotal then
			colPointer := dataTable.getColumnByRowName(prop);
			if colPointer &gt; 0 then
				_totalWidth := _totalWidth + dataTable.accessColumn(colPointer).width;
			endif;
		elseif prop = ETRow_Used20 or prop = ETRow_Used30 or prop = ETRow_Used40 or prop = ETRow_Used45 or prop = ETRow_Used53 or prop = ETRow_ColTotalUsed then
			colPointer := dataTable.getColumnByRowName(prop);
			if colPointer &gt; 0 then
				_usedWidth := _usedWidth + dataTable.accessColumn(colPointer).width;
			endif;
		elseif prop = ETRow_QueuedIn20 or prop = ETRow_QueuedIn30 or prop = ETRow_QueuedIn40 or prop = ETRow_QueuedIn45 or prop = ETRow_QueuedIn53 or prop = ETRow_ColTotalQIn then
			colPointer := dataTable.getColumnByRowName(prop);
			if colPointer &gt; 0 then
				_qInWidth := _qInWidth + dataTable.accessColumn(colPointer).width;
			endif;						
		elseif prop = ETRow_QueuedOut20 or prop = ETRow_QueuedOut30 or prop = ETRow_QueuedOut40 or prop = ETRow_QueuedOut45 or prop = ETRow_QueuedOut53 or prop = ETRow_ColTotalQOut then
			colPointer := dataTable.getColumnByRowName(prop);
			if colPointer &gt; 0 then
				_qOutWidth := _qOutWidth + dataTable.accessColumn(colPointer).width;
			endif;						
		elseif prop = ETRow_Free20 or prop = ETRow_Free30 or prop = ETRow_Free40 or prop = ETRow_Free45 or prop = ETRow_Free53 or prop = ETRow_ColTotalFree then
			colPointer := dataTable.getColumnByRowName(prop);
			if colPointer &gt; 0 then
				_freeWidth := _freeWidth + dataTable.accessColumn(colPointer).width;
			endif;						
		elseif prop = ETRow_Projected20 or prop = ETRow_Projected30 or prop = ETRow_Projected40 or prop = ETRow_Projected45 or prop = ETRow_Projected53 or prop = ETRow_ColTotalProjected then
			colPointer := dataTable.getColumnByRowName(prop);
			if colPointer &gt; 0 then
				_projectedWidth := _projectedWidth + dataTable.accessColumn(colPointer).width;
			endif;						
		elseif prop = ETRow_PlannedIn20 or prop = ETRow_PlannedIn30 or prop = ETRow_PlannedIn40 or prop = ETRow_PlannedIn45 or prop = ETRow_PlannedIn53 or prop = ETRow_ColTotalPlanIn then
			colPointer := dataTable.getColumnByRowName(prop);
			if colPointer &gt; 0 then
				_planInWidth := _planInWidth + dataTable.accessColumn(colPointer).width;
			endif;						
		elseif prop = ETRow_PlannedOut20 or prop = ETRow_PlannedOut30 or prop = ETRow_PlannedOut40 or prop = ETRow_PlannedOut45 or prop = ETRow_PlannedOut53 or prop = ETRow_ColTotalPlanOut then
			colPointer := dataTable.getColumnByRowName(prop);
			if colPointer &gt; 0 then
				_planOutWidth := _planOutWidth + dataTable.accessColumn(colPointer).width;
			endif;						
		elseif prop = ETRow_PriorityValue then
			colPointer := dataTable.getColumnByRowName(prop);
			if colPointer &gt; 0 then
				_priorityWidth := _priorityWidth + dataTable.accessColumn(colPointer).width;
			endif;						
		elseif prop = ETRow_DeckingSequence then  //deckingsequence = seq
			colPointer := dataTable.getColumnByRowName(prop);
			if colPointer &gt; 0 then
				_seqWidth := _seqWidth + dataTable.accessColumn(colPointer).width;
			endif;
		elseif prop = ETRow_Stacking then   //stacking = decking
			colPointer := dataTable.getColumnByRowName(prop);
			if colPointer &gt; 0 then
				_deckingWidth := _deckingWidth + dataTable.accessColumn(colPointer).width;
			endif;						
		elseif prop = ETRow_AllowOthers then
			colPointer := dataTable.getColumnByRowName(prop);
			if colPointer &gt; 0 then
				_allowOthersWidth := _allowOthersWidth + dataTable.accessColumn(colPointer).width;
			endif;	
		elseif prop = ETRow_IfNoLocationFound then
			colPointer := dataTable.getColumnByRowName(prop);
			if colPointer &gt; 0 then
				_ifNoLocFoundWidth := _ifNoLocFoundWidth + dataTable.accessColumn(colPointer).width;
			endif;	
		elseif prop = ETRow_OverstowRule then
			colPointer := dataTable.getColumnByRowName(prop);
			if colPointer &gt; 0 then
				_overstowRuleWidth := _overstowRuleWidth + dataTable.accessColumn(colPointer).width;
			endif;
			
		endif;
	endforeach;
end;</source>
        <Parameter name="_locnStatsTable" type="CM_LocnStatsTable" usage="io"/>
        <Parameter name="_yamTable" type="CM_YAMTable" usage="io"/>
        <Parameter name="_totalWidth" type="Integer" usage="output"/>
        <Parameter name="_usedWidth" type="Integer" usage="output"/>
        <Parameter name="_qInWidth" type="Integer" usage="output"/>
        <Parameter name="_qOutWidth" type="Integer" usage="output"/>
        <Parameter name="_freeWidth" type="Integer" usage="output"/>
        <Parameter name="_projectedWidth" type="Integer" usage="output"/>
        <Parameter name="_planInWidth" type="Integer" usage="output"/>
        <Parameter name="_planOutWidth" type="Integer" usage="output"/>
        <Parameter name="_priorityWidth" type="Integer" usage="output"/>
        <Parameter name="_deckingWidth" type="Integer" usage="output"/>
        <Parameter name="_seqWidth" type="Integer" usage="output"/>
        <Parameter name="_ifNoLocFoundWidth" type="Integer" usage="output"/>
        <Parameter name="_overstowRuleWidth" type="Integer" usage="output"/>
        <Parameter name="_allowOthersWidth" type="Integer" usage="output"/>
    </JadeMethod>
    <JadeMethod name="canResizeOthers" id="4d4cfed8-e60d-44f2-b69f-e0c8d5abc5e4">
        <interfaceImplements>
            <JadeInterfaceMethod name="IF_CMUI_RectangleHandler::canResizeOthers"/>
        </interfaceImplements>
        <source>canResizeOthers(_rect: CMUI_ResizableRectFrame input; _x, _y : Real);

	/*
		this method stub has been automatically generated by Jade to satisfy interface implementation requirements
	*/
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28 August 2009	cnwer1	Initial creation

*/

vars
	cmifMachineWorkzone,otherMachineWZs : CMIF_MachineWorkzone;
	otherWorkZoneFrame : CMUI_ResizableRectFrame;
	allOtherMachineWZs : ObjectArray;
	adjustment : Integer;
	startPos : Real;
begin
	if _rect.name = self.frmWorkZone.name then
		if self.myCurrentDrawingController = null then
			return;
		endif;
		
		cmifMachineWorkzone:=_rect.userObject.CMIF_MachineWorkzone;
		if cmifMachineWorkzone = null then
			return;
		endif;
		
	
		
		create allOtherMachineWZs transient;
		adjustment:=_rect.drawWidth.Integer +1;

		if cmifMachineWorkzone.rotated90 then
			startPos:=_y;
		else
			startPos:=_x;
		endif;
		self.myCurrentDrawingController.YRD_GridOViewDrawingController.findOtherMachineWorkzones(startPos+  _rect.getAdjustedLeft,adjustment,cmifMachineWorkzone,allOtherMachineWZs, true,true);
		if allOtherMachineWZs.size &gt; 0 then
			otherMachineWZs:=allOtherMachineWZs.first.CMIF_MachineWorkzone;
			otherWorkZoneFrame:=otherMachineWZs.myWorkzoneFrame.CMUI_ResizableRectFrame;
			if otherWorkZoneFrame &lt;&gt; null then
				otherWorkZoneFrame.zOrder(1);
			endif;
		endif;
	endif;
epilog
	delete allOtherMachineWZs;

end;</source>
        <Parameter name="_rect" type="CMUI_ResizableRectFrame" usage="input"/>
        <Parameter name="_x" type="Real"/>
        <Parameter name="_y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="clearSelectedRegionObjs" id="360d6eb1-4d25-4d51-a5e1-f605c784651e">
        <source>clearSelectedRegionObjs();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
26 September 2011	cnwndl1	Initial creation	Par 28236

*/

vars

begin

	self.allSelectedRegionLocs.clear();	// location controllers.
	
	if not self.allSelectedRegionObjs.isEmpty then
		// transient objects that carry the co-ordinants on the screen
		//of the user selected 'region'(s)
		self.allSelectedRegionObjs.purge();
	endif;
	
	self.clearGraphics();

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="clearYAMFilter" id="9efc4950-f260-4417-a682-69ed247084dd">
        <source>clearYAMFilter( _rebuildTable : Boolean );

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 January 2012	cnwndl1	Initial creation	Par 28889

*/

vars

begin
	inheritMethod( _rebuildTable );
	
	if self.allColumnFilters &lt;&gt; null and not self.allColumnFilters.isEmpty then
		self.allColumnFilters.replaceAllFiltersForTable( self.tblYAM, null );
	endif;
	
	if _rebuildTable then
		self.tblYAM.applyColumnFilter( null );
	endif;

epilog

end;</source>
        <Parameter name="_rebuildTable" type="Boolean"/>
    </JadeMethod>
