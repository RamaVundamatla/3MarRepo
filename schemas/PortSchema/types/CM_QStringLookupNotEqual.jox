//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin
	return self.selectionValue;


end;</source>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="getSearchValueStr" id="dadadab5-e2db-4622-b5bf-c2fbead45f3d">
        <source>getSearchValueStr(_prop: CM_QueryProperty): String;
// ---------------------------------------------------------------------------
// Created:     07 December 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin
	return selectionValue;


end;</source>
        <Parameter name="_prop" type="CM_QueryProperty"/>
        <ReturnType type="String"/>
    </JadeMethod>
