    <JadeMethod name="exportAsXMLInverseRef" id="65df0a7a-a85f-401b-841d-b1d4708cfe17">
        <source>exportAsXMLInverseRef(_property: Reference): Integer protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
01 April 2011	cnwer1	Initial creation

*/

vars

begin
	if _property = CM_HatchLid::allBays then
		return ExportAsChild;
	elseif _property = CM_HatchLid::allHolds then
		return ExportAsChild;
	endif;
	return inheritMethod(_property);

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_property" type="Reference"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getDefinitionXML" id="9d26c0a6-912d-4c3d-a551-8a8c8b0869ea">
        <source>getDefinitionXML() : String;
// ---------------------------------------------------------------------------
// Created:		February 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	aBay : CM_Bay;
	hml : String;
begin
	hml := "&lt;AH&gt;" &amp; self.getGridDefinitionXML();
	foreach aBay in self.allBays do
		hml := hml &amp; "&lt;BO&gt;" &amp; aBay.ordinalBay.String &amp; "&lt;/BO&gt;";
	endforeach;
	hml := hml &amp; "&lt;/AH&gt;";

	return hml;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDescription" id="503a07f2-f110-4faa-96ea-226a40648917">
        <source>getDescription(_bay : CM_Bay) : String;
// ---------------------------------------------------------------------------
// Created:		August 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	aString : String;
	ordinal : Integer;
	aCell : CM_CellDefn;
begin

	if _bay = null then
		return null;
	endif;
	
	ordinal := _bay.allHatchLids.indexOf(self);
	aString := ordinal.String &amp; " - ";
	
	aCell := _bay.allCellsOnDeckByOrdinal[self.ordinalODStartCell];
	if aCell &lt;&gt; null then
		aString := aString &amp; " " &amp; aCell.id;
	else
		aString := aString &amp; " NA";
	endif;

	aCell := _bay.allCellsOnDeckByOrdinal[self.ordinalODEndCell];
	if aCell &lt;&gt; null then
		aString := aString &amp; " - " &amp; aCell.id;
	else
		aString := aString &amp; " - NA";
	endif;
	return aString;
end;</source>
        <Parameter name="_bay" type="CM_Bay"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDrawingPosEndX" id="7ce95a87-2eda-42c4-b2ac-02e7bd808f1b">
        <source>getDrawingPosEndX(_bay : CM_Bay; _cellWidth : Integer) : Integer;
// ---------------------------------------------------------------------------
// Created:     05 July 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpOrdinal	: Integer;
	tmpCell		: CM_CellDefn;
	tmpX		: Integer;
begin

	tmpOrdinal := self.ordinalODEndCell;
	if tmpOrdinal &lt;&gt; 0 then
		tmpCell := _bay.allCellsOnDeckByOrdinal[tmpOrdinal];
	endif;

	if tmpCell = null then
		tmpOrdinal := self.ordinalUDEndCell;
		if tmpOrdinal &lt;&gt; 0 then
			tmpCell := _bay.allCellsUnderDeckByOrdinal[tmpOrdinal];
		endif;
	endif;
	
	if tmpCell &lt;&gt; null then
		tmpX := tmpCell.getDrawingPosX(_cellWidth) + _cellWidth;

		if self.endsMidCell then
			tmpX := tmpX - (_cellWidth / 2).Integer;
		endif;
	endif;

	return tmpX;
end;</source>
        <Parameter name="_bay" type="CM_Bay"/>
        <Parameter name="_cellWidth" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getDrawingPosStartX" id="8094cdc4-dcd5-46ba-b6db-51dbf7f0998a">
        <source>getDrawingPosStartX(_bay : CM_Bay; _cellWidth : Integer) : Integer;
// ---------------------------------------------------------------------------
// Created:     05 July 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpOrdinal	: Integer;
	tmpCell		: CM_CellDefn;
	tmpX		: Integer;
begin

	tmpOrdinal := self.ordinalODStartCell;
	if tmpOrdinal &lt;&gt; 0 then
		tmpCell := _bay.allCellsOnDeckByOrdinal[tmpOrdinal];
	endif;
	
	if tmpCell = null then
		tmpOrdinal := self.ordinalUDStartCell;
		if tmpOrdinal &lt;&gt; 0 then
			tmpCell := _bay.allCellsUnderDeckByOrdinal[tmpOrdinal];
		endif;
	endif;
	
	if tmpCell &lt;&gt; null then
		tmpX := tmpCell.getDrawingPosX(_cellWidth);

		if self.startsMidCell then
			tmpX := tmpX + (_cellWidth / 2).Integer;
		endif;
	endif;

	return tmpX;
end;</source>
        <Parameter name="_bay" type="CM_Bay"/>
        <Parameter name="_cellWidth" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getExtraInfo" id="327d1247-c6fb-4268-ac26-404310258abd">
        <source>getExtraInfo(_dataContainer : CM_DataContainer);
// ---------------------------------------------------------------------------
// Created:		January 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 25 June 2003 sgp			Use CM_DataContainer to hold data
// 29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
// ---------------------------------------------------------------------------

vars
	aBay : CM_Bay;
	aHold : CM_Hold;
	aCell : CM_CellDefn;
	theString : String;
	aJob : CM_VoyageJob;
	block : CM_DataContainerBlock;
	
begin
	foreach aHold in self.allHolds do
		theString := theString &amp; aHold.ordinalHold.String.padLeadingZeros(2) &amp; " " ;
	endforeach;
	
	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getErrorString(CM_Holds), DC_Label, 1, null);
	block.addNewItem(theString, DC_Data, 1, null);

	foreach aJob in self.allVoyageHatchLidJobs do
		block := _dataContainer.addNewBlock;
		block.addNewItem(app.getErrorString(CM_Job_GC), DC_Label, 1, aJob);
		if aJob.myUserJobType &lt;&gt; null then
			block.addNewItem(aJob.jobNum &amp; " " &amp; aJob.myUserJobType.name, DC_Data, 1, aJob);
		else
			block.addNewItem(aJob.jobNum , DC_Data, 1, aJob);
		endif;
	endforeach;
	
	theString := null;
	foreach aBay in self.allBays do
		theString := theString &amp; aBay.id &amp; " " ;
	endforeach;
	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getErrorString(CM_Bays), DC_Label, 1, null);
	block.addNewItem(theString, DC_Data, 1, null);

	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getErrorString(CM_Ends_Mid_Cell), DC_Label, 1, null);
	block.addNewItem(app.getYesNo(self.endsMidCell), DC_Data, 1, null);

	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getErrorString(CM_Starts_Mid_Cell), DC_Label, 1, null);
	block.addNewItem(app.getYesNo(self.startsMidCell), DC_Data, 1, null);

	theString := null;
	foreach aCell in self.allBays.first.allCellsOnDeckByOrdinal do
		if aCell.ordinal &gt;= self.ordinalODStartCell and aCell.ordinal &lt;= self.ordinalODEndCell then
			theString := theString &amp; aCell.id &amp; " " ;
		endif;
	endforeach;
	
	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getErrorString(CM_OD_Cells), DC_Label, 1, null);
	block.addNewItem(theString, DC_Data, 1, null);

	theString := null;
	foreach aCell in self.allBays.first.allCellsUnderDeckByOrdinal do
		if aCell.ordinal &gt;= self.ordinalUDStartCell and aCell.ordinal &lt;= self.ordinalUDEndCell then
			theString := theString &amp; aCell.id &amp; " " ;
		endif;
	endforeach;
	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getErrorString(CM_UD_Cells), DC_Label, 1, null);
	block.addNewItem(theString, DC_Data, 1, null);

end;</source>
        <Parameter name="_dataContainer" type="CM_DataContainer"/>
    </JadeMethod>
    <JadeMethod name="getGridDefinitionArray" id="ae35ba10-f025-4b79-a2e4-948443014dc2">
        <source>getGridDefinitionArray(_data : BinaryArray200 input);
// ---------------------------------------------------------------------------
// Created:		March 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars
	startOrdinal,
	endOrdinal		: Integer;
	theBay			: CM_Bay;
	theCell			: CM_CellDefn;
begin

	if self.ordinalODStartCell &lt;&gt; null then
		startOrdinal := self.ordinalODStartCell;
	else
		// some ports do not specify the under deck in Version 6 of JMT.
		// this code use the under deck cell ordinal to get the UD Cell ID and use that to find the corresponding OD cell ordinal
		if (not self.allBays.isEmpty) then
			theBay := self.allBays.first;
			if theBay &lt;&gt; null then
				theCell := theBay.allCellsUnderDeckByOrdinal[self.ordinalUDStartCell];
				theCell := theBay.allCellsOnDeck[theCell.id];
				if theCell &lt;&gt; null then
					startOrdinal := theCell.ordinal;
				endif;
			endif;
		endif;
	endif;
	if self.ordinalODEndCell &lt;&gt; null then
		endOrdinal := self.ordinalODEndCell;
	else
		// some ports do not specify the under deck in Version 6 of JMT.
		// this code use the under deck cell ordinal to get the UD Cell ID and use that to find the corresponding OD cell ordinal
		if not self.allBays.isEmpty then
			theBay := self.allBays.first;
			if theBay &lt;&gt; null then
				theCell := theBay.allCellsUnderDeckByOrdinal[self.ordinalUDEndCell];
				theCell := theBay.allCellsOnDeck[theCell.id];
				if theCell &lt;&gt; null then
					endOrdinal := theCell.ordinal;
				endif;
			endif;
		endif;
	endif;

	_data.addString(GridData_HatchLid &amp; GridData_Delimiter &amp;
			  startOrdinal.String &amp; GridData_Delimiter &amp;
			  endOrdinal.String &amp; GridData_Delimiter &amp;
			  self.ordinalUDStartCell.String &amp; GridData_Delimiter &amp;
			  self.ordinalUDEndCell.String &amp; GridData_Delimiter &amp;
			  self.startsMidCell.Integer.String &amp; GridData_Delimiter &amp;
			  self.endsMidCell.Integer.String &amp; GridData_Delimiter &amp;
			  self.getOidStringForObject(self));


end;</source>
        <Parameter name="_data" type="BinaryArray200" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getGridDefinitionXML" id="ef09ef80-2f63-4314-b020-302f4eef1fbc">
        <source>getGridDefinitionXML() : String ;
// ---------------------------------------------------------------------------
// Created:		March 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	s1, s2, s3, s4, s5, s6, s7, theXML : String;
	theBay : CM_Bay;
	theCell : CM_CellDefn;
begin

	if self.ordinalODStartCell &lt;&gt; null then
		s1 := self.ordinalODStartCell.String;
	else
		// some ports do not specify the under deck in Version 6 of JMT.
		// this code use the under deck cell ordinal to get the UD Cell ID and use that to find the corresponding OD cell ordinal
		if not self.allBays.isEmpty then
			theBay := self.allBays.first;
			if theBay &lt;&gt; null then
				theCell := theBay.allCellsUnderDeckByOrdinal[self.ordinalUDStartCell];
				theCell := theBay.allCellsOnDeck[theCell.id];
				if theCell &lt;&gt; null then
					s1 := theCell.ordinal.String;
				endif;
			endif;
		endif;
	endif;
	if self.ordinalODEndCell &lt;&gt; null then
		s2 := self.ordinalODEndCell.String;
	else
		// some ports do not specify the under deck in Version 6 of JMT.
		// this code use the under deck cell ordinal to get the UD Cell ID and use that to find the corresponding OD cell ordinal
		if not self.allBays.isEmpty then
			theBay := self.allBays.first;
			if theBay &lt;&gt; null then
				theCell := theBay.allCellsUnderDeckByOrdinal[self.ordinalUDEndCell];
				theCell := theBay.allCellsOnDeck[theCell.id];
				if theCell &lt;&gt; null then
					s2 := theCell.ordinal.String;
				endif;
			endif;
		endif;
	endif;

	s3 := self.ordinalUDStartCell.String;
	s4 := self.ordinalUDEndCell.String;
	s5 := self.startsMidCell.Integer.String;
	s6 := self.endsMidCell.Integer.String;
	s7 := getOidStringForObject(self);
	
	theXML := "&lt;ODS&gt;" &amp; s1 &amp; "&lt;/ODS&gt;&lt;ODE&gt;" &amp; s2 &amp; "&lt;/ODE&gt;" &amp; 
						 "&lt;UDS&gt;" &amp; s3 &amp; "&lt;/UDS&gt;&lt;UDE&gt;" &amp;  s4 &amp; "&lt;/UDE&gt;" &amp; 
						"&lt;SMC&gt;" &amp;  s5 &amp; "&lt;/SMC&gt;&lt;EMC&gt;" &amp;  s6 &amp; "&lt;/EMC&gt;&lt;LO&gt;" &amp; s7 &amp; "&lt;/LO&gt;";
	return theXML;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getHatchPrimaryBay" id="d3efbfce-6b3a-47d6-8dd8-2479b843b023">
        <source>getHatchPrimaryBay() : CM_Bay;
/*
------------------------------------------------------------------------
Created:			03 February 2003 by cnwdwq1
Purpose:			Dave Q's code
Parameters:		See Method signature above. Special comment:
Returns:			See Method signature above. Special comment:
Changed On		Changed By		Reason
------------	------------	-----------------------------------------
														
------------------------------------------------------------------------
*/
vars
	bay : CM_Bay;
begin
	foreach bay in self.allBays do
		if bay.ordinalBay = self.ordinalStartBay then
			return bay;
		endif;
	endforeach;
	return null;
end;</source>
        <ReturnType type="CM_Bay"/>
    </JadeMethod>
