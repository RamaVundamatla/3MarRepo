    <JadeMethod name="updateTICollections" id="cbce0b17-5212-4a7b-9b2e-1d1212613475">
        <updating/>
        <source>updateTICollections(_trackedItem: CM_TrackedItem; _extra :Any) updating;
/*
Purpose:			
Parameters:			
Return Value:		

Date		Who		Reason
16 July 2009	cnwrd1	Initial creation
01/04/2010		cnwcs5	par 23383 - new parameter (_extra) not used
*/

vars

begin
	inheritMethod(_trackedItem, _extra);	// 01/04/2010 cnwcs5 par 23383
	
	// check to see if we have a job for this todo task already?
	
	if (not app.myPassport.noErrors) then
		return;
	endif;
	
	if (not self.allTrackedItems.includes(_trackedItem)) then
			self.allTrackedItems.add(_trackedItem);	
	endif;

epilog

end;</source>
        <Parameter name="_trackedItem" type="CM_TrackedItem"/>
        <Parameter name="_extra" type="Any"/>
    </JadeMethod>
</Class>
