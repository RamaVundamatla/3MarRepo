    <JadeMethod name="getShiftTranslate" id="f5883e76-db9f-4dd4-be89-6cb8442e57e7">
        <source>getShiftTranslate(_mess : Integer) : String;
// ---------------------------------------------------------------------------
// Created:     09 April 2009 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	capt : String;
	translation : XLAT_Translation;
begin

	translation := app.zGetTranslatedText(XLAT_FormCaptions, _mess);
	if translation &lt;&gt; null then
		capt := translation.text;
	else
