    <JadeMethod name="setControlsForAddEdit" id="5a66db9b-d0ab-47e7-9df7-6e3557426375">
        <updating/>
        <source>setControlsForAddEdit() updating;
/* ---------------------------------------------------------------------------
Created:	07 August 2008	by cnwvu1

Purpose:	
        
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars
	theForm : SOP_TableMaintForm;
	
begin
  
	theForm := self.myForm;
	theForm.tblInput1.userInputEnabled := true;

			
	if theForm.mode = theForm.Mode_Add then
		theForm.tblInput1.clearValues;
		theForm.tblInput1.enableRowByName(ETRow_Code);
		theForm.tblInput1.enableRowByName(ETRow_Description);
		theForm.tblInput1.enableRowByName(ETRow_Type);
		
		theForm.tblInput1.moveFirst();
		theForm.tblInput1.setFocus;
		
	else
		// cannot update code
		theForm.tblInput1.disableRowByName(ETRow_Code); //epr TFS 2328 14/7/16
		theForm.tblInput1.enableRowByName(ETRow_Description);
		theForm.tblInput1.enableRowByName(ETRow_Type);
		
		// refresh the data from the newly created proxy
		self.showThumbnail(theForm.myProxyObject.CM_GeneratorType);
		
 	endif;
	
	//18 Mar 2014	NDL	Par 33268
	if theForm.mode = theForm.Mode_Add then
		self.setConvertedDisplayValue( theForm.tblInput1, ETRow_DefaultWeight,  0, self.weightType );
	else
		self.setConvertedDisplayValue( theForm.tblInput1, ETRow_DefaultWeight,  theForm.myProxyObject.CM_GeneratorType.defaultWeight, self.weightType );
	endif;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="setGeneratorTypeCombo" id="04ce101a-18bc-461a-b15a-352d1b3124f6">
        <source>setGeneratorTypeCombo( _cmb : ComboBox input );
/* ---------------------------------------------------------------------------
Created:	07 August 2008	by cnwvu1

Purpose:	
        
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars

begin

	_cmb.clear;
	
	_cmb.addItem(GeneratorType_NoseMounted);
	_cmb.addItem(GeneratorType_UnderSlung);
	_cmb.addItem(GeneratorType_StandAlone);


end;</source>
        <Parameter name="_cmb" type="ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setupThumbnailDetails" id="6d7232bb-7271-41e6-93a2-2abcf2541c40">
        <updating/>
        <source>setupThumbnailDetails() updating;
/* ---------------------------------------------------------------------------
Created:	07 August 2008	by cnwvu1

Purpose:	
        
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars
	theForm : SOP_TableMaintForm;

begin
  
	theForm :=self.myForm;
  	
	theForm.useProxyObject := true;
	theForm.setTblDataEntRows(ETDef_GenTypeMaint);
	//12/01/2011 cnwdz2 25840
	//theForm.zClearSortColumns();
	//theForm.zAddSortColumn(ETRow_Code, false);

	theForm.shtTblInput1.caption := 'Details';
	theForm.initTblInput(theForm.tblInput1, ETDef_GenTypeMaint);
	theForm.shtTblInput1.visible := true;
	self.setGeneratorTypeCombo( theForm.cmbGeneratorType );
	
	theForm.mulSelect1.formDisplayEntryMethodName := null;
	theForm.mulSelect2.formDisplayEntryMethodName := null;

end;</source>
    </JadeMethod>
    <JadeMethod name="showThumbnail" id="a7bfe15f-2ac4-44f0-b192-f7125be8014a">
        <updating/>
        <source>showThumbnail( _generatorType: CM_GeneratorType ) updating;
/* ---------------------------------------------------------------------------
Created:	08 August 2008	by cnwvu1

Purpose:	
        
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars
	theForm : SOP_TableMaintForm;
	
begin
  
	theForm := self.myForm;
	theForm.tblInput1.clearValues;
	theForm.tblInput1.setValueByName(ETRow_Code, _generatorType.code);
	theForm.tblInput1.setValueByName(ETRow_Description, _generatorType.description);
	
	theForm.tblInput1.setValueByName(ETRow_Type, self.getGeneratorTypeComboText(_generatorType) );
	theForm.cmbGeneratorType.text := self.getGeneratorTypeComboText(_generatorType);
	
	//18 Mar 2014	NDL	Par 33268
	self.setConvertedDisplayValue( theForm.tblInput1, ETRow_DefaultWeight,  _generatorType.defaultWeight, self.weightType );
	
	theForm.tblData.accessColumn(2).width := 130;
	

end;</source>
        <Parameter name="_generatorType" type="CM_GeneratorType"/>
    </JadeMethod>
</Class>
