    <JadeMethod name="idVerify" id="4920ea74-cbb8-4857-9975-61e19a2dd0a4">
        <source>idVerify(_terminal : CM_Terminal): String;
//
// 15/07/2010	cnwdap1		PAR #25021 review use of isImport/isExport for tranships
// 24/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
//15 May 2013	cnwrs1	par31549 stop removal of unused options
//
vars
	trackedItem	: CM_TrackedItem;
	message		: String;
	value		: Integer;
	
begin
	value	:=	self.VALID;
	trackedItem	:=	_terminal.allOnsiteTIsByCargoTypeId[TI_CargoType_Container, id];
	
	if trackedItem = null then
		value	:=	self.WARNING;
		message :=	"Container is not onsite.";
//	elseif trackedItem.operatorStop = false then CCMS 1017 changed to 
//	elseif trackedItem.checkStopApplies(TI_Stop_Operator, TI_Stop_Area_General) = false then
	elseif not (trackedItem.isStopSetToBeProcessed(StopProcessOpImpDeliverRel) or 
		trackedItem.isStopSetToBeProcessed(StopProcessOpImpReleasePIN)) then
		value	:=	self.WARNING;
		message :=	"Container does not have stop loaded.";
	elseif not (trackedItem.isImport or trackedItem.isTranshipItem) then	// PAR #25021 // cnwdad1 09/04/2010 - PAR #22153.
		value	:=	self.ERROR;
		message :=	"Container is not an import or T/Ship.";				// PAR #25021
	endif;
	
	return value.String &amp; message;
end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="messageModeVerify" id="f71f35d7-0244-44cf-9628-ff0998a52a09">
        <source>messageModeVerify(_terminal: CM_Terminal);
// ---------------------------------------------------------------------------
// Created:     29 May 2002 by cnwdf1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	if self.messageMode = "" then
		//app.raiseCMException1(REQUIRED_FIELD, 'message Mode', 'messageMode', self);
	else
		if self.messageMode = CM_EDITrackedItem.EDI_ACTION_ADD
		or self.messageMode = CM_EDITrackedItem.EDI_ACTION_UPDATE
		or self.messageMode = CM_EDITrackedItem.EDI_ACTION_DELETE
		then
			
		else
		//	app.raiseCMException1(REQUIRED_FIELD, 'cargo type', 'tiType', self);
			app.raiseCMException(Input_required_field_cargoType, 'tiType', self); // cnwdb2	PAR 35364


		endif;
	endif;
end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
