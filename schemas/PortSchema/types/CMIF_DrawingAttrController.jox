    <JadeMethod name="handleCommodityGroup" id="3bb899d9-3e3c-4717-97ab-8dfdf7a66168">
        <source>handleCommodityGroup(_commodityCode : String; _code : String output; _color :Integer output; _object : Object output) protected;
// ---------------------------------------------------------------------------
// Created:     26 August 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	iter		: Iterator;
	codeCodeKey,
	groupCode,
	groupCodeKey,
	trimCode,
	theCode,
	codeKey		: String;
	theColor,
	colorKey	: Integer;
	tmpGroup		: CM_CommodityGroup;
	tmpCommodity	: CM_Commodity;
	theObject : Object;
begin

	trimCode := _commodityCode.trimBlanks;

	if trimCode = null then
		_code 	:= null;
		_color	:= NullColour;
		return;
	endif;

	iter := self.myIterCommodity;
	self.allCommodities.startKeyGeq(trimCode, null, iter);
	self.allCommodities.getIteratorKeys(codeCodeKey, groupCode, iter);

	theCode		:= null;
	theColor	:= NullColour;
	
	if codeCodeKey = trimCode then
		// found the commodity type so get the group out of the group key
		
		iter := self.myIterCommodityGroup;
		self.allCommodityGroups.startKeyGeq(groupCode, 0, iter);
		self.allCommodityGroups.getIteratorKeys(groupCodeKey, colorKey, iter);
		if groupCodeKey = groupCode then
			// found the right one
			theCode		:= groupCodeKey;
			theColor	:= colorKey;
			iter.next(theObject);
		else
			// this should not be necessary as should have been
			// added below but done for belts and braces
			tmpGroup := self.myRoot.allCommodityGroups[groupCode];
			if tmpGroup &lt;&gt; null then
				if not self.allCommodityGroups.includes(tmpGroup) then
					self.allCommodityGroups.add(tmpGroup);
					self.beginNotification(tmpGroup, EVENT_CODE_COLOUR_CHANGE, Response_Continuous, null);
				endif;
				theCode		:= groupCode;
				theColor	:= tmpGroup.colour;
				theObject := tmpGroup;
			endif;
		endif;

	else
		tmpCommodity := self.myRoot.allCommodities[trimCode];
		if tmpCommodity &lt;&gt; null then
			self.allCommodities.add(tmpCommodity);
			tmpGroup := tmpCommodity.myCommodityGroup;
			if tmpGroup &lt;&gt; null then
				if (not self.allCommodityGroups.includes(tmpGroup)) then
					self.allCommodityGroups.add(tmpGroup);
					self.beginNotification(tmpGroup, EVENT_CODE_COLOUR_CHANGE, Response_Continuous, null);
				endif;
				theCode		:= tmpGroup.code;
				theColor	:= tmpGroup.colour;
				theObject := tmpGroup;
			endif;
		else
			// TFS 37556
			tmpGroup := self.myRoot.allCommodityGroups[_commodityCode];
			if tmpGroup &lt;&gt; null then
				self.allCommodityGroups.addNoDuplicates(tmpGroup, false);
				self.beginNotification(tmpGroup, EVENT_CODE_COLOUR_CHANGE, Response_Continuous, null);
				theCode		:= groupCode;
				theColor	:= tmpGroup.colour;
				theObject := tmpGroup;
			endif;

		endif;

	endif;

	_code	:= theCode;
	_color	:= theColor;
	_object := theObject;

end;</source>
        <access>protected</access>
        <Parameter name="_commodityCode" type="String"/>
        <Parameter name="_code" type="String" usage="output"/>
        <Parameter name="_color" type="Integer" usage="output"/>
        <Parameter name="_object" type="Object" usage="output"/>
    </JadeMethod>
