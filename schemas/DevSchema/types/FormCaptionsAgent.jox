    <JadeMethod name="compareOldNewCodeForDiffs" id="bd19034d-ba56-4213-9240-64a6970abc93">
        <source>compareOldNewCodeForDiffs() : Boolean;

/*

Purpose:		Compare the old and the new code for any differences	

Date			Who		Reason
10/02/2012		cnwmh5	Initial creation
16/03/2015		cnwmh5	Transient Leaks
*/

vars


	file						: File;
	obj							: Object;
	newFile						: File;
	diffFile					: File;
	fileNodeObj					: FileNode;
	fileFolder1					: FileFolder;
	fileFolder2					: FileFolder;
	
	jdo							: JadeDynamicObject;
	jdoTest						: JadeDynamicObject;
	
	dictOld  					: DynaDictionary;
	dictNew  					: DynaDictionary;
	
	allFilesOld					: FileNodeArray;
	allFilesNew					: FileNodeArray;
	
	currentClassName			: String;
	currentMethodName			: String;
	attribute					: String;
	text						: String;
	propertyType				: String;
	fileName					: String;
	
	isCommentedOut				: Boolean;
	differenceFound				: Boolean;
	diffFileCreated				: Boolean;
	newFieldFileCreated			: Boolean;

begin
	
	// get the files in the specified directory
	create allFilesOld transient;
	create allFilesNew transient;
		
	// load the details from *Schema-NEW.txt
	delete fileFolder1;
	create fileFolder1 transient;
	fileFolder1.usePresentationFileSystem := self.fileFolder.usePresentationFileSystem;
	fileFolder1.fileName := self.fileFolder.fileName;
	fileFolder1.mask := "*Schema-Original-ToBeCompared.txt";
	if not fileFolder1.isValidPathName(fileFolder1.fileName) or not fileFolder1.isAvailable() then
		app.log('Unable to find ' &amp; self.fileFolder.fileName);
		return false;
	endif;
	allFilesOld := fileFolder1.files();

	foreach fileNodeObj in allFilesOld do
	
		if fileNodeObj.fileName.cnContains("PortSchema") then
			continue;
		endif;
	
		if dictOld &lt;&gt; null then
			dictOld.purge;
		endif;
		delete dictOld;
		create dictOld transient;
		dictOld.setMembership(JadeDynamicObject);
		dictOld.addExternalKey(String, 35, false, true);					// class name
		dictOld.addExternalKey(String, 35, false, true);					// method name
		dictOld.addExternalKey(String, 35, false, false);					// attribute
		dictOld.addExternalKey(String, 35, false, true);					// type   e.g. caption or bubbleHelp
		dictOld.endKeys(false);
		
		self.createJDOForComparisonMethod(fileNodeObj.File, dictOld);
		
		// load the details from *-FormCaptions-partial-NEW.txt
		allFilesNew.clear();
		delete file;
		create file transient;
		fileName := app.getFileName(fileNodeObj.fileName);
		file.fileName := self.fileFolder.fileName &amp; "\" &amp; fileName[1:fileName.length - 17] &amp; "-FormCaptions-partial-ToBeCompared.txt";
		write file.fileName;
		if not file.isAvailable then
			app.log("Unable to find file " &amp; file.fileName);
			return false;
		endif;
		allFilesNew.add(file);
		
		if dictNew &lt;&gt; null then
			dictNew.purge;
		endif;
		delete dictNew;
		create dictNew transient;
		dictNew.setMembership(JadeDynamicObject);
		dictNew.addExternalKey(String, 35, false, true);					// class name
		dictNew.addExternalKey(String, 35, false, true);					// method name
		dictNew.addExternalKey(String, 35, false, false);					// attribute
		dictNew.addExternalKey(String, 35, false, true);					// type   e.g. caption or bubbleHelp
		dictNew.endKeys(false);
		
		self.createJDOForComparisonMethod(file, dictNew);
		
		// Create the *-DIFF-NEW file
		delete diffFile;
		create diffFile transient;
		diffFile.fileName := self.fileFolder.fileName &amp; "\" &amp; fileName[1:fileName.length - 17] &amp; "-DIFFS.txt";
		if diffFile.isAvailable then
			diffFile.purge;
		endif;
		diffFile.writeLine("class" &amp; Tab &amp; "method" &amp; Tab &amp; "commented" &amp; Tab &amp; "attribute" &amp; Tab &amp; "old text" &amp; Tab &amp; "new text");
	
		diffFileCreated := false;
		newFieldFileCreated := false;
		
		foreach obj in dictOld do
			jdo := obj.JadeDynamicObject;
			currentClassName := jdo.getPropertyValue("className").String;
			currentMethodName := jdo.getPropertyValue("methodName").String;
			attribute := jdo.getPropertyValue("attribute").String; 
			propertyType := jdo.getPropertyValue("propertyType").String;
			text := jdo.getPropertyValue("text").String;
			
			jdoTest := dictNew[currentClassName, currentMethodName, attribute, propertyType].JadeDynamicObject;
			if jdoTest = null then
			//	newFile.writeLine(currentClassName &amp; Tab &amp; currentMethodName &amp; Tab &amp; isCommentedOut.String &amp; Tab &amp; 
			//		propertyType &amp; Tab &amp; attribute &amp; Tab &amp; text);
			//	newFieldFileCreated := true;
			else
				if jdoTest.getPropertyValue("text").String.trimBlanks() &lt;&gt; text.trimBlanks() then
					diffFile.writeLine(currentClassName &amp; Tab &amp; currentMethodName &amp; Tab &amp; isCommentedOut.String &amp; Tab &amp; 
						propertyType &amp; Tab &amp; attribute &amp; Tab &amp; text &amp; Tab &amp; jdoTest.getPropertyValue("text").String);
					diffFileCreated := true;
				endif;
			endif;
						
		endforeach;
		
		if not diffFileCreated then
			diffFile.purge;
		else
			differenceFound := true;
		endif;
				
	endforeach;
	
	return differenceFound;
	
epilog

	if dictOld &lt;&gt; null then
		dictOld.purge;
	endif;
	delete dictOld;
	
	if dictNew &lt;&gt; null then
		dictNew.purge;
	endif;
	delete dictNew;

	delete file;
	delete newFile;
	delete diffFile;
	delete fileFolder1;
	delete fileFolder2;
	delete allFilesNew;
	delete allFilesOld;

end;
</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="compareOldNewConstantsIDs" id="3b7dccc8-543d-4859-b905-f207041979ac">
        <source>compareOldNewConstantsIDs() : Boolean;

/*

Purpose:		Compare the old and the new constants for differences in the id's	

Date			Who		Reason
10/02/2012		cnwmh5	Initial creation

*/

vars

	file						: File;
	outputFile					: File;
	jdo							: JadeDynamicObject;
	
	dictOld  					: DynaDictionary;
	
	oldFileStr					: StringArray;
	
	differenceFound				: Boolean;
	line						: String;
	constantName				: String;
	id							: Integer;
	tempStr						: String;

begin
	
	create dictOld transient;
	dictOld.setMembership(JadeDynamicObject);
	dictOld.addExternalKey(String, 65, false, false);					// Constant Name
	dictOld.endKeys(false);
		
	// load the details from PortSchema.scm
	create file transient;
	file.usePresentationFileSystem := self.fileFolder.usePresentationFileSystem;
	file.kind := File.Kind_Unknown_Text;	// 3/3/16 cnwmp6 PAR 36286 unicode version
	file.fileName := self.fileFolder.fileName &amp; "\PortSchema.scm";
	if not file.isAvailable() then
		return false;
	endif;
	
	while not file.endOfFile do
		line := file.readLine();
		if not line.cnContains("Integer = ") then
			continue;
		endif;
		
		tempStr := line[1:line.pos(":", 1) - 1];
		tempStr.cnReplaceString(Tab, "");
		constantName := tempStr;
		tempStr := line[line.pos("=", 1) + 2:line.length-2];
		id := tempStr.Integer;
		
		jdo := dictOld[constantName].JadeDynamicObject;
		if jdo = null then
			create jdo transient;
			jdo.addProperty("constantName", String);
			jdo.setPropertyValue("constantName", constantName);
			jdo.addProperty("id", Integer);
			jdo.setPropertyValue("id", id);
			dictOld.putAtKey(constantName, jdo);
		endif;
	endwhile;
	
	// read the new file
	delete file;
	create file transient;
	file.kind := File.Kind_Unknown_Text; // 26/2/16  cnwns1 PAR 36286 unicode version
	file.usePresentationFileSystem := self.fileFolder.usePresentationFileSystem;
	file.fileName := self.fileFolder.fileName &amp; "\PortSchema-FormCaptions-partial.scm";
	if not file.isAvailable() then
		return false;
	endif;
	
	// create the output file
	create outputFile transient;
	outputFile.usePresentationFileSystem := self.fileFolder.usePresentationFileSystem;
	outputFile.fileName := self.fileFolder.fileName &amp; "\PortSchema-DIFFS.txt";
	if outputFile.isAvailable() then
		outputFile.purge;
	endif;	
	outputFile.writeLine("old name" &amp; Tab &amp; "old id" &amp; Tab &amp; 'new name' &amp; Tab &amp; 'new id');
	
	while not file.endOfFile do
	
		line := file.readLine();
		
		if not line.cnContains("Integer = ") then
			continue;
		endif;
		
		tempStr := line[1:line.pos(":", 1) - 1];
		tempStr.cnReplaceString(Tab, "");
		constantName := tempStr;
		tempStr := line[line.pos("=", 1) + 2:line.length-2];
		id := tempStr.Integer;
		
		jdo := dictOld[constantName].JadeDynamicObject;
		if jdo &lt;&gt; null then
			if jdo.getPropertyValue("id").Integer &lt;&gt; id then
				outputFile.writeLine(jdo.getPropertyValue("constantName").String &amp; Tab &amp; jdo.getPropertyValue("id").String &amp; Tab &amp; 
					constantName &amp; Tab &amp; id.String);
				differenceFound := true;
			endif;
		endif;
		
	endwhile;
	file.close();
	outputFile.close();
		
	if not differenceFound then
		outputFile.purge;
	endif;
	
	return differenceFound;
	
epilog

	if dictOld &lt;&gt; null then
		dictOld.purge;
	endif;
	delete dictOld;
	
	delete file;
	delete outputFile;
	

end;
</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="convertFilesSoCanProgCompare" id="75199ecd-b0af-4318-a3ad-faaa0102d62a">
        <source>convertFilesSoCanProgCompare() : Boolean;

/*

Purpose:		Convert the extracted translateForm methods and what translate process created so can
				programmatically compare for differences

Date			Who		Reason
10/12/2012		cnwmh5	Initial creation
16/03/2015		cnwmh5 	Transient Leaks
*/

vars
	
	
	schema					: Schema;
	klass					: Class;
	obj						: Object;
	
	file					: File;
	outputFile				: File;
	
	fileFolder1				: FileFolder;
	fileFolder2				: FileFolder;
	fileNodeObj				: FileNode;
	
	allFiles				: FileNodeArray;
	filesPartial			: FileNodeArray;
	filesSource				: FileNodeArray;
	
	returnOK				: Boolean;
	
begin
	
	
	schema := rootSchema.getSchema("SchemaComparisonUtility");
	if schema = null then
		app.log("Unable to find SchemaComparisonUtility");
		return false;
	endif;
	
	klass := schema.getClass("SchemaComparisonUtility");
	if klass = null then
		app.log("Unable to find JadeScript");
		return false;
	endif;
	
	create obj as klass transient;
		
	// get the files in the specified directory
	create allFiles transient;
	
	delete fileFolder1;
	create fileFolder1 transient;
	fileFolder1.usePresentationFileSystem := self.fileFolder.usePresentationFileSystem;
	fileFolder1.fileName := self.fileFolder.fileName;
	if not fileFolder1.isValidPathName(fileFolder1.fileName) or not fileFolder1.isAvailable() then
		app.log('Unable to find ' &amp; fileFolder1.fileName);
		return false;
	endif;
	
	create filesSource transient;
	fileFolder1.mask := "*Schema.scm";
	filesSource := fileFolder1.files();
	filesSource.copy(allFiles);
	
	delete fileFolder2;
	create fileFolder2 transient;
	fileFolder2.usePresentationFileSystem := self.fileFolder.usePresentationFileSystem;
	fileFolder2.fileName := self.fileFolder.fileName;
	if not fileFolder2.isValidPathName(fileFolder2.fileName) or not fileFolder2.isAvailable() then
		app.log('Unable to find ' &amp; fileFolder2.fileName);
		return false;
	endif;
	
	foreach fileNodeObj in allFiles do
	
		if fileNodeObj.fileName.cnContains("PortSchema") then
			continue;
		endif;
	
		delete file;
		create file transient;
		file.usePresentationFileSystem := self.fileFolder.usePresentationFileSystem;
		file.kind := File.Kind_Unknown_Text; // 26/2/16  cnwns1 PAR 36286 unicode version
		file.fileName := fileNodeObj.fileName;
		
		delete outputFile;
		create outputFile transient;
		outputFile.usePresentationFileSystem := self.fileFolder.usePresentationFileSystem;
		outputFile.fileName := self.fileFolder.fileName &amp; "\" &amp; app.getFileName(file.fileName);
		outputFile.fileName := outputFile.fileName[1:outputFile.fileName.length - 4] &amp; "-Original-ToBeCompared.txt";
		if outputFile.isAvailable then
			outputFile.purge;
		endif;
		write outputFile.fileName &amp; Tab &amp; file.fileName;
	
		obj.sendMsgWithIOParams('sortSCMByClassMethodWithParams', file, outputFile);
	
	endforeach;
	
	allFiles.clear();
	
	create filesPartial transient;
	fileFolder2.mask := "*-FormCaptions-partial.scm";
	filesPartial := fileFolder2.files();
	filesPartial.copy(allFiles);	
	
	foreach fileNodeObj in allFiles do
	
		if fileNodeObj.fileName.cnContains("PortSchema") then
			continue;
		endif;
	
		delete file;
		create file transient;
		file.usePresentationFileSystem := self.fileFolder.usePresentationFileSystem;
		file.kind := File.Kind_Unknown_Text; // 26/2/16  cnwns1 PAR 36286 unicode version	
		file.fileName := fileNodeObj.fileName;
		
		delete outputFile;
		create outputFile transient;
		outputFile.usePresentationFileSystem := self.fileFolder.usePresentationFileSystem;
		outputFile.fileName := self.fileFolder.fileName &amp; "\" &amp; app.getFileName(file.fileName);
		outputFile.fileName := outputFile.fileName[1:outputFile.fileName.length - 4] &amp; "-ToBeCompared.txt";
		if outputFile.isAvailable then
			outputFile.purge;
		endif;
		write outputFile.fileName &amp; Tab &amp; file.fileName;
	
		obj.sendMsgWithIOParams('sortSCMByClassMethodWithParams', file, outputFile);
	
	endforeach;
	
	return true;
	
epilog
	
	delete file;
	delete outputFile;
	
	delete obj;
	
	delete allFiles;
	delete filesPartial;
	delete filesSource;
	
	delete fileFolder1;
	delete fileFolder2;
		
end;
</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="create" id="08738f39-baa3-4a6e-9a3a-4ff00ef746d6">
