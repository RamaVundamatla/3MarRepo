    <JadeMethod name="deleteIspecs" id="efa8cf5f-5eee-4850-ab2d-4cf28b5b801f">
        <updating/>
        <source>deleteIspecs() updating;

vars
	lincIspec	:CnEcLincIspecDef;

begin
	// Handle database deletion exceptions
	on SystemException do deleteExceptionHandler(exception);
	on LockException   do deleteExceptionHandler(exception);

	foreach lincIspec in allLincIspecDefs do
		lincIspec.deleteFields;
		delete lincIspec;
	endforeach;
end;</source>
    </JadeMethod>
