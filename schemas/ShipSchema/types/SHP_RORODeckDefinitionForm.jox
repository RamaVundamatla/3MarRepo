    <JadeMethod name="initFrmLabelLine" id="43eb9af6-dc53-4eae-a18c-4f46e5b95042">
        <source>initFrmLabelLine();
// ---------------------------------------------------------------------------
// Created:     10 January 2011 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin

	self.frameLabelLineV.parent := self.frmScrollable;
	self.frameLabelLineV.move(self.frmScrollable.myVLabels.left, self.frmScrollable.myVLabels.top,self.frmScrollable.myVLabels.width, self.frmScrollable.myVLabels.height);
	self.frameLabelLineV.zOrder(1);
	self.frameLabelLineV.autoRedraw := true;

	
	self.frameLabelLineH.parent := self.frmScrollable;
	self.frameLabelLineH.move(self.frmScrollable.myHLabels.left, self.frmScrollable.myHLabels.top,self.frmScrollable.myHLabels.width, self.frmScrollable.myHLabels.height);
	self.frameLabelLineH.zOrder(1);
	self.frameLabelLineH.autoRedraw := true;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="keyDown" id="2b03bf27-6938-4315-a250-3ea5848617b1">
        <controlMethod name="Form::keyDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>keyDown(keyCode: Integer io; shift: Integer) updating;
// ---------------------------------------------------------------------------
// Created:     06 January 2011 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	
	// PAR 28155
	if keyCode = J_key_Z and shift.isControlKeyPressed and not shift.isShiftKeyPressed and not shift.isAltKeyPressed then
		self.doBtnDrawUndoClick();
	endif;
	
	if keyCode = CMUI_Key_F3
		and not app.isControlKeyDown()
		and not app.isAltKeyDown()
		and not app.isShiftKeyDown()
		then
		
		self.doShowROROLayersForm();
	endif;
	// PAR 27773
	if keyCode = CMUI_Key_F6
				// PAR 28787 and not app.isControlKeyDown()
		and not app.isAltKeyDown()
		and not app.isShiftKeyDown()
		and self.mode &lt;&gt; self.Mode_View
		then
		self.btnMultiSelect.value := not self.btnMultiSelect.value;
		self.doSetMultiSelectMode(self.mnuGrpMulti);
	endif;
	if keyCode = J_key_DownArrow 
		// PAR 28787		and not app.isControlKeyDown()
		and not app.isAltKeyDown()
		then
		if app.isShiftKeyDown() 
		and not app.isControlKeyDown() then // PAR 28787
			self.doFrameDrawKeyArrowUpDown(5);
		// PAR 28787
		elseif app.isShiftKeyDown() 
		and app.isControlKeyDown() then
			self.doFrameDrawKeyArrowUpDown(20);
		else
			self.doFrameDrawKeyArrowUpDown(1);
		endif;
	endif;
	if keyCode = J_key_UpArrow 
				// PAR 28787 and not app.isControlKeyDown()
		and not app.isAltKeyDown()
		then
		if app.isShiftKeyDown() 
		and not app.isControlKeyDown() then // PAR 28787
			self.doFrameDrawKeyArrowUpDown(-5);
		// PAR 28787
		elseif app.isShiftKeyDown() 
		and app.isControlKeyDown() then
			self.doFrameDrawKeyArrowUpDown(-20);
		else
			self.doFrameDrawKeyArrowUpDown(-1);
		endif;
	endif;
	
	if keyCode = J_key_LeftArrow 
			// PAR 28787	and not app.isControlKeyDown()
		and not app.isAltKeyDown()
		then
		if app.isShiftKeyDown() 
		and not app.isControlKeyDown() then // PAR 28787
			self.doFrameDrawKeyArrowLeftRight(-5);
		// PAR 28787
		elseif app.isShiftKeyDown() 
		and app.isControlKeyDown() then
			self.doFrameDrawKeyArrowLeftRight(-20);
		else
			self.doFrameDrawKeyArrowLeftRight(-1);
		endif;
	endif;
	if keyCode = J_key_RightArrow 
		// PAR 28787		and not app.isControlKeyDown()
		and not app.isAltKeyDown()
		then
		if app.isShiftKeyDown() 
		and not app.isControlKeyDown() then // PAR 28787
			self.doFrameDrawKeyArrowLeftRight(5);
		// PAR 28787
		elseif app.isShiftKeyDown() 
		and app.isControlKeyDown() then
			self.doFrameDrawKeyArrowLeftRight(20);
		else
			self.doFrameDrawKeyArrowLeftRight(1);
		endif;
	endif;
	
	inheritMethod(keyCode,shift);
epilog

end;</source>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="lblScale_dblClick" id="10c22468-7605-4044-b44a-38d780e5da03">
        <controlMethod name="Label::dblClick"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>lblScale_dblClick(label: Label input) updating;
