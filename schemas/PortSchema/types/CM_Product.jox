    <JadeMethod name="createProductAttribute" id="054d73a8-0fab-4dc0-96ce-6161ee2cb8e9">
        <source>createProductAttribute(_class : Class; 
					_name,
					_displayName : String) : CM_ProductAttr protected;
// ---------------------------------------------------------------------------
// Created:     01 October 2002 by cnwth2
//
// Purpose:     
//
// ----------   ----------  --------------------------------------------------
vars
	attrDef	: CM_ProductAttr;
begin

	if self.isTransient then
		create attrDef as _class transient;
	else
		create attrDef as _class persistent;
	endif;
	
	attrDef.initialize(_name, _displayName);
	
	return attrDef;	
end;</source>
        <access>protected</access>
        <Parameter name="_class" type="Class"/>
        <Parameter name="_name" type="String"/>
        <Parameter name="_displayName" type="String"/>
        <ReturnType type="CM_ProductAttr"/>
    </JadeMethod>
    <JadeMethod name="createProductAttributes" id="fd425c24-0b8d-4374-87f1-d864a032df01">
        <updating/>
        <source>createProductAttributes() updating;
// ---------------------------------------------------------------------------
// Created:     01 October 2002 by cnwth2
//
// Purpose:     
//
//	27 Jan 2009 - add if .. = null before creating - RJS
// 30.1.09 - changed CM_ProdAttrInteger to CM_ProdAttrDecimal for height, weight, length and width -  par #18821
// 20/03/2014	cnwdap1		PAR #33606 CCMS SFW 1366 Bulk - create stowage factor attribute
// ----------   ----------  --------------------------------------------------
vars

begin
		
	if self.myWidthString = null then
		self.myWidthString 	:= self.createProductAttribute(CM_ProdAttrString, ETRow_MyWidthString, 	'Width Text').CM_ProdAttrString;
	endif;
	
	if self.myHeightString = null then
		self.myHeightString := self.createProductAttribute(CM_ProdAttrString, ETRow_MyHeightString, 'Height Text').CM_ProdAttrString;
	endif;
	
	if self.myLengthString = null then
		self.myLengthString := self.createProductAttribute(CM_ProdAttrString, ETRow_MyLengthString, 'Length Text').CM_ProdAttrString;
	endif;
	
	if self.myWidth = null then
		self.myWidth 		:= self.createProductAttribute(CM_ProdAttrDecimal, ETRow_MyWidth, 		'Width (cm)').CM_ProdAttrDecimal;
	endif;
	
	if self.myHeight = null then
		self.myHeight 		:= self.createProductAttribute(CM_ProdAttrDecimal, ETRow_MyHeight, 		'Height (cm)').CM_ProdAttrDecimal;
	endif;
	
	if self.myLength = null then
		self.myLength 		:= self.createProductAttribute(CM_ProdAttrDecimal, ETRow_MyLength, 		'Length (cm)').CM_ProdAttrDecimal;
	endif;
	
	if self.myQuantity = null then
		self.myQuantity 	:= self.createProductAttribute(CM_ProdAttrInteger, ETRow_MyQuantity, 	'Quantity (pieces)').CM_ProdAttrInteger;
	endif;
	
	if self.myVolume = null then
		self.myVolume 		:= self.createProductAttribute(CM_ProdAttrDecimal, ETRow_MyVolume, 		'Volume (m3)').CM_ProdAttrDecimal;
	endif;
	
	if self.myDensityDec = null then																												// ### TFS 52193 22Nov2021 NAVPW1
		self.myDensityDec 	:= self.createProductAttribute(CM_ProdAttrDecimal, ETRow_MyDensity,		'Density (Kg per m3)').CM_ProdAttrDecimal;		// ### TFS 52193 22Nov2021 NAVPW1
	endif;
	
	if self.myWeight = null then
		self.myWeight 		:= self.createProductAttribute(CM_ProdAttrDecimal, ETRow_MyWeight, 		'Weight (Kg)').CM_ProdAttrDecimal;
	endif;
	
	if self.myType = null then
		self.myType 		:= self.createProductAttribute(CM_ProdAttrString, ETRow_MyType, 		'Type').CM_ProdAttrString;
	endif;
	
	if self.myStowageFactor = null then																													// PAR #33606
		self.myStowageFactor	:= self.createProductAttribute(CM_ProdAttrDecimal, ETRow_MyStowageFactor, 'Stowage Factor (m3/MT)').CM_ProdAttrDecimal;	// PAR #33606
	endif;																																				// PAR #33606
	
end;</source>
    </JadeMethod>
    <JadeMethod name="delete" id="26232b10-330c-4371-8beb-53e2cc526df8">
        <updating/>
        <source>delete() updating;
//
// 15 May 2017	cnwrs1	TFS 3698 add CM_Product and CM_FTPEntity auditing
//
vars
	
begin

	//04 Apr 2019	NDL	TFS 44194
	if app.myAlternateDict &lt;&gt; null then
		app.myAlternateDict.setProductDictNeedsRefresh();
	endif;
	
	self.resetAuditsDuringDelete();	//25 Jan 2021	NDL	TFS 50152

end;
</source>
    </JadeMethod>
    <JadeMethod name="displayForXlation" id="23510ae3-f040-4a87-80a1-918301c5eb8a">
        <source>displayForXlation(_codeFirst: Boolean): String;
//
//15 Jul 2014	Par 34567	CCMS 2346 add EDI Xlation for Cargo Type and Cargo Sub Type
//
//13 May 2016	cnwrs1	TFS 1987 CargoSubType EDI Xlation
vars

begin
	if _codeFirst then
		return self.code.trimBlanks&amp;' ('&amp;self.description.trimBlanks&amp;')' &amp; ' ['&amp;self.myCargoType.description&amp;']';
	else
		return self.description.trimBlanks&amp;' ('&amp;self.code.trimBlanks&amp;')' &amp; ' ['&amp;self.myCargoType.description&amp;']';
	endif;
end;
</source>
        <Parameter name="_codeFirst" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="exportMyReferencesXML" id="9653aeaa-e0ac-491f-b857-407596d25f98">
        <source>exportMyReferencesXML(_file: File; objArray: ObjectArray io);
// ---------------------------------------------------------------------------
// Created:     09 February 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin
//	if self.myColour &lt;&gt; null then
//		_file.writeLine("&lt;myColour&gt;");
//		self.myColour.exportMeXML(_file, objArray, true, true);
//		_file.writeLine("&lt;/myColour&gt;");
//	endif;
	
	if self.myDensityDec &lt;&gt; null then								// ### TFS 52193 22Nov2021 NAVPW1
		_file.writeLine("&lt;"&amp;CM_Product::myDensityDec.name&amp;"&gt;");		// ### TFS 52193 22Nov2021 NAVPW1
		self.myDensityDec.exportMeXML(_file, objArray, true, true);	// ### TFS 52193 22Nov2021 NAVPW1
		_file.writeLine("&lt;/"&amp;CM_Product::myDensityDec.name&amp;"&gt;");	// ### TFS 52193 22Nov2021 NAVPW1
	endif;
	
	if self.myHandlingType &lt;&gt; null then
		_file.writeLine("&lt;"&amp;CM_Product::myHandlingType.name&amp;"&gt;" &amp; self.myHandlingType.id.String &amp; "&lt;/"&amp;CM_Product::myHandlingType.name&amp;"&gt;");
	endif;
	
	if self.myHeight &lt;&gt; null then
		_file.writeLine("&lt;"&amp;CM_Product::myHeight.name&amp;"&gt;");
		self.myHeight.exportMeXML(_file, objArray, true, true);
		_file.writeLine("&lt;/"&amp;CM_Product::myHeight.name&amp;"&gt;");
	endif;
	
	if self.myHeightString &lt;&gt; null then
		_file.writeLine("&lt;"&amp;CM_Product::myHeightString.name&amp;"&gt;");
		self.myHeightString.exportMeXML(_file, objArray, true, true);
		_file.writeLine("&lt;/"&amp;CM_Product::myHeightString.name&amp;"&gt;");
	endif;
	
	if self.myLength &lt;&gt; null then
		_file.writeLine("&lt;"&amp;CM_Product::myLength.name&amp;"&gt;");
		self.myLength.exportMeXML(_file, objArray, true, true);
		_file.writeLine("&lt;/"&amp;CM_Product::myLength.name&amp;"&gt;");
	endif;
	
	if self.myLengthString &lt;&gt; null then
		_file.writeLine("&lt;"&amp;CM_Product::myLengthString.name&amp;"&gt;");
		self.myLengthString.exportMeXML(_file, objArray, true, true);
		_file.writeLine("&lt;/"&amp;CM_Product::myLengthString.name&amp;"&gt;");
	endif;
	
	if self.myQuantity &lt;&gt; null then
		_file.writeLine("&lt;"&amp;CM_Product::myQuantity.name&amp;"&gt;");
		self.myQuantity.exportMeXML(_file, objArray, true, true);
		_file.writeLine("&lt;/"&amp;CM_Product::myQuantity.name&amp;"&gt;");
	endif;
	
	if self.myType &lt;&gt; null then
		_file.writeLine("&lt;"&amp;CM_Product::myType.name&amp;"&gt;");
		self.myType.exportMeXML(_file, objArray, true, true);
		_file.writeLine("&lt;/"&amp;CM_Product::myType.name&amp;"&gt;");
	endif;
	
	if self.myVolume &lt;&gt; null then
		_file.writeLine("&lt;"&amp;CM_Product::myVolume.name&amp;"&gt;");
		self.myVolume.exportMeXML(_file, objArray, true, true);
		_file.writeLine("&lt;/"&amp;CM_Product::myVolume.name&amp;"&gt;");
	endif;
	
	if self.myWeight &lt;&gt; null then
		_file.writeLine("&lt;"&amp;CM_Product::myWeight.name&amp;"&gt;");
		self.myWeight.exportMeXML(_file, objArray, true, true);
		_file.writeLine("&lt;/"&amp;CM_Product::myWeight.name&amp;"&gt;");
	endif;
	
	if self.myWidth &lt;&gt; null then
		_file.writeLine("&lt;"&amp;CM_Product::myWidth.name&amp;"&gt;");
		self.myWidth.exportMeXML(_file, objArray, true, true);
		_file.writeLine("&lt;/"&amp;CM_Product::myWidth.name&amp;"&gt;");
	endif;
	
	if self.myWidthString &lt;&gt; null then
		_file.writeLine("&lt;"&amp;CM_Product::myWidthString.name&amp;"&gt;");
		self.myWidthString.exportMeXML(_file, objArray, true, true);
		_file.writeLine("&lt;/"&amp;CM_Product::myWidthString.name&amp;"&gt;");
	endif;

end;</source>
        <Parameter name="_file" type="File"/>
        <Parameter name="objArray" type="ObjectArray" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getAllProductAttributes" id="74f842c5-df35-4f0d-877e-0fb3589911e3">
        <source>getAllProductAttributes(_allAttributes : ObjectSet input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 February 2018	jlger1	Initial creation web portal will now display the correct product attributes

*/

vars
	allProperties : PropertyNDict;
	prop  : Property;
	propertyAttribute : CM_ProductAttr;
	superclass : Class;
begin
	if _allAttributes = null then
		return;
	endif;
	
	allProperties :=self.class.getProperties;
	foreach prop in allProperties do
		if not prop.type.isKindOf(Class) then
			continue;
		endif;
		superclass:=prop.type.Class.getSuperclass;
		
		if  prop.type.name = CM_ProductAttr.name or superclass &lt;&gt; null and superclass.name = CM_ProductAttr.name then
			propertyAttribute:=self.getPropertyValue(prop.name).CM_ProductAttr;
			
			if propertyAttribute &lt;&gt; null and propertyAttribute.getIsViewable() then							
				_allAttributes.add(propertyAttribute);
			endif;
			
			
			
		endif;
	endforeach;
		
epilog

end;</source>
        <Parameter name="_allAttributes" type="ObjectSet" usage="input"/>
    </JadeMethod>
