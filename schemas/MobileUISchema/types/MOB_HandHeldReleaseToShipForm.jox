    <JadeMethod name="userNotify" id="21f918a0-2378-44d1-8311-af7a33ab6e76">
        <controlMethod name="Form::userNotify"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>userNotify(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;
begin
	app.mousePointer :=	Busy;
	self.doUserNotify(eventType, theObject, eventTag, userInfo);
epilog
	app.mousePointer :=	Idle;
end;
</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
    <JadeMethod name="validateForm" id="808d1d2e-d836-4631-91cd-a40e6500ebb5">
        <source>validateForm() : Boolean;
begin
	// Make sure 4 cells are selected (each row has two cells) for twin lift
	if self.isTwinLift and self.tblCraneXferArea.selectedCount &lt;&gt; 4 then
		self.msgBox("You need to select two tracked items for a twin lift", app.getErrorString(Error), MsgBox_Exclamation_Mark_Icon, false);
		self.tblCraneXferArea.setFocus();
		return false;
	endif;
	// Make sure 2 cells are selected (each row has two cells) for normal lift
	if not self.isTwinLift and self.tblCraneXferArea.selectedCount &lt;&gt; 2 then
		self.msgBox("You need to select a single tracked item", app.getErrorString(Error), MsgBox_Exclamation_Mark_Icon, false);
		self.tblCraneXferArea.setFocus();
		return false;
	endif;

	return true;
end;
</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</GUIClass>
