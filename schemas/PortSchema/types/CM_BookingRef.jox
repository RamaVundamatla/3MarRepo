    <JadeMethod name="getStatusString" id="e83d974d-cc50-4cbb-9d94-5a4b296a8b30">
        <source>getStatusString() : String;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
11 Dec 2008	cnwer1	Initial creation
27 May 2009	cnwkpd1	PAR #19785 - CCMS SFW 1079 - Booking Reference Status changes

*/

vars

begin
	return app.bookingRefStatusEnumToString(self.status);
/*	
	// Booking Status
	if self.status = self.BookingRefStatus_Active then
		return app.getErrorString(Active);
	elseif self.status = self.BookingRefStatus_Completed then
		return app.getErrorString(Completed);
	elseif self.status = self.BookingRefStatus_Closed then
		return app.getErrorString(Closed);
	elseif self.status = self.BookingRefStatus_Pending then 
		return app.getErrorString(Pending);
	endif;
		
	return null;
*/
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getStevedoreCode" id="7fc09985-3165-41be-8b40-2f7505cb8a4c">
