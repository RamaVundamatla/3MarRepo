        <source>loadWharf(_wharfProxy:HMS_Wharf io) :Boolean protected;

vars
	realObject, proxyObject: HMS_Wharf;
	error: CM_Error;
	countError,countOK: Integer;
begin
	realObject := _wharfProxy.getHarbourReal.allWharves[_wharfProxy.code];
	if realObject = null then
		app.myTrxCA.trxCreateWharf(_wharfProxy, realObject, app.myPassport);
	else
		app.writeLog(class.name&amp;'::'&amp;method.name&amp;' '&amp;_wharfProxy.code&amp;" ERROR: "&amp;"Wharf already exists.",0);
		return false;
	endif;
	if app.myPassport.trxCompletedOK and
	   app.myPassport.allErrorWarnings.size = 0 then
		return true;
	else
		foreach error in app.myPassport.allWarnings do
			app.writeLog(class.name&amp;'::'&amp;method.name&amp;' '&amp;_wharfProxy.code&amp;" WARNING: "&amp;error.text,0);
		endforeach;
		foreach error in app.myPassport.allErrors do
			app.writeLog(class.name&amp;'::'&amp;method.name&amp;' '&amp;_wharfProxy.code&amp;" ERROR: "&amp;error.text,0);
		endforeach;
		return false;
	endif;
epilog

end;</source>
