    <JadeMethod name="valBookingRef" id="553a04e7-9a6a-4300-bf46-fcc31e60e898">
        <updating/>
        <source>valBookingRef(pProxyBookingRef : CM_BookingRef input; _passport : CM_Passport input; pUserObject : Object) updating;
// ---------------------------------------------------------------------------
// Created:     14 February 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	
begin

	self.raiseExceptionIfNull(pProxyBookingRef, 'Booking Reference Proxy');
	pProxyBookingRef.raiseExceptionIfNotTransient(method);

	if pProxyBookingRef.allBookingRefItems.size = 0 then
		app.raiseCMException(Must_Add_Equipment,app.getErrorString(BookingRef),null);
	
	endif;
	
	pProxyBookingRef.validateForCreate(_passport, pUserObject, null);
	
epilog
	
	
end;</source>
