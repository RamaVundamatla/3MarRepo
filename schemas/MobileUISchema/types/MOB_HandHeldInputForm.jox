<GUIClass name="MOB_HandHeldInputForm" id="8617094b-b39b-473f-b4b0-6daa009469b0">
    <superclass name="MOB_HandHeldForm"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <ImplicitInverseRef name="lblCaption" id="2bc24528-b187-4233-92a4-9253690e6692">
        <embedded/>
        <type name="MOB_Label"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="tblInfo" id="e59c9979-f7c6-4435-bf23-5179cc9dca5f">
