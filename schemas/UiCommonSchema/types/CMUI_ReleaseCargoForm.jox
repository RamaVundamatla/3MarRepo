    <JadeMethod name="txtReleaseQty_hasLostFocus" id="6bb44bd6-36af-490f-a105-c7aa78835eb8">
        <controlMethod name="CMUI_FieldFrame::hasLostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtReleaseQty_hasLostFocus(_fieldFrame: CMUI_FieldFrame input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 Dec 2023	navsp1	Initial creation TFS 61547
24 Jul 2024	navpw1	TFS: 61525 (61527) - If the vbs items not null and has a max weight then do not overwrite the fields
03 Dec 2024	navdap1	MTN-33495 MTN - Any Id checkbox is getting unchecked when updating the release quantity
*/

vars
	vbsProcess : CM_VBSProcess;
	
begin
	if _fieldFrame.CMUI_FieldTextBox.getString().asIntegerJMT &lt;&gt; null and self.isByTypeByQuantity then
		vbsProcess := self.myTerminal.getMyVBSProcess();
		
		if vbsProcess &lt;&gt; null and																				// ### TFS 65399 26Jul2024 NAVPW1
			vbsProcess.isVbsSlotValidation and self.myVbsti &lt;&gt; null and self.myVbsti.maxWeight &gt; 0 
		then																									// ### TFS 61525 (61527) 18Jul2024 NAVPW1
		else																									// ### TFS 61525 (61527) 18Jul2024 NAVPW1
			self.txtReleaseWeight.setValue(null);
			self.chkAnyAmount.setValue(false);
			if not self.isByTypeByQuantity() then		// MTN-33495
				self.chkAnyId.setValue(false);
				self.chkAnyIdChanged();
			endif;
		endif;
		self.txtNumItems.setValue(_fieldFrame.CMUI_FieldTextBox.getString().asIntegerJMT);	//26.Jan.24 navsp1 TFS 62064
	endif;
epilog

end;</source>
        <Parameter name="_fieldFrame" type="CMUI_FieldFrame" usage="input"/>
    </JadeMethod>
    <JadeMethod name="txtReleaseWeight_hasLostFocus" id="6de859a8-ecb8-46ff-b02c-408a06445d6d">
        <controlMethod name="CMUI_FieldFrame::hasLostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtReleaseWeight_hasLostFocus(_fieldFrame: CMUI_FieldFrame input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
13 December 2023	navsp1	Initial creation TFS 61547
24 July 2024		navpw1	TFS: 61525 (61527) - If the vbs items not null and has a max weight then do not overwrite the fields

*/

vars
	vbsProcess : CM_VBSProcess;
	
begin
	if _fieldFrame.CMUI_FieldMeasureTable.getString().asDecimalJMT &lt;&gt; null and self.isByTypeByQuantity then
		vbsProcess := self.myTerminal.getMyVBSProcess();
		
		if vbsProcess &lt;&gt; null and																				// ### TFS 65399 26Jul2024 NAVPW1
			vbsProcess.isVbsSlotValidation and self.myVbsti &lt;&gt; null and self.myVbsti.maxWeight &gt; 0 
		then																									// ### TFS 61525 (61527) 18Jul2024 NAVPW1
		else																									// ### TFS 61525 (61527) 18Jul2024 NAVPW1
			self.txtReleaseQty.setValue(null);
			self.chkAnyId.setValue(true);
			self.chkAnyAmount.setValue(true);
			self.chkAnyIdChanged();
		endif;
	endif;
epilog

end;</source>
        <Parameter name="_fieldFrame" type="CMUI_FieldFrame" usage="input"/>
    </JadeMethod>
    <JadeMethod name="txtRelease_hasLostFocus" id="56bcc886-c7c3-4291-8379-142fd3e4ab3a">
        <controlMethod name="CMUI_FieldFrame::hasLostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtRelease_hasLostFocus(_fieldFrame: CMUI_FieldFrame input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06 August 2009	cnwjk3	Initial creation

*/

vars

	msg : String;

begin
	if _fieldFrame.CMUI_FieldTextBox.getString() &lt;&gt; null then 
		if self.myBulkRelease = null then
			self.onReleaseRefChanged(_fieldFrame.CMUI_FieldTextBox.getString());
		elseif self.txtRelease.getString() &lt;&gt; self.myBulkRelease.code then
			self.onReleaseRefChanged(_fieldFrame.CMUI_FieldTextBox.getString());
		endif;
		
		//14 Feb 2017	NDL	TFS 3368
		if self.myBulkRelease &lt;&gt; null and not self.myBulkRelease.validateExpiryDateNow( msg ) then
			//error will have already been displayed within "onReleaseRefChanged" just need to clear the fields.
			self.doClearReleaseItems();
			_fieldFrame.setFocus;
			return;
		endif;
		
	else
	//	if txtCargoIDvalue.CMUI_TextBox.text = null then//cnwas3 PAR 21307
			self.doClearReleaseItems();
			
	//	endif;
	endif;
	
	
	
epilog

end;</source>
        <Parameter name="_fieldFrame" type="CMUI_FieldFrame" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateByTypeByWeightByQty" id="3f28de44-3410-4c35-92ef-4c7d84bf25ab">
        <source>validateByTypeByWeightByQty() protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 December 2023	navsp1	Initial creation TFS 61547
19/02/2025	navcs2  MTN-34062 - EUP | Release by Weight - further issues
*/

vars

begin
	if self.isByTypeByWeight then
		if self.txtReleaseWeight.getConvertedValue() = null then						// 19/02/2025 navcs2 MTN-34062
			app.raiseCMException1(REQUIRED_FIELD, "'Release Weight'", null, null);
		endif;
	/*//09.Jan.2023 navsp1 TFS 61547 / Task 61999
	elseif self.isByTypeByQuantity then		
		if self.txtReleaseQuantity.getString().asIntegerJMT = null and self.txtReleaseWeight.getString().asDecimalJMT = null then
			app.raiseCMException1(REQUIRED_FIELD, "'Release Weight' or 'Release Quantity'", null, null);
		endif;*/
	endif;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
</GUIClass>
