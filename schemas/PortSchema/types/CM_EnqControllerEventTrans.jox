    <JadeMethod name="allowsSnapShotEdit" id="c3d0eb94-6818-442a-bac3-799651b62b04">
        <source>allowsSnapShotEdit(): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 February 2021	navndl1	Initial creation	TFS 50835

