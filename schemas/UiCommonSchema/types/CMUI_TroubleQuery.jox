	self.lstTerminals.addItemObject("T08 - Houston",null);
	self.lstTerminals.addItemObject("T09 - Los Angeles",null);
	self.lstTerminals.addItemObject("T10 - Tacoma",null);
	self.lstTerminals.addItemObject("T11 - Oakland",null);
