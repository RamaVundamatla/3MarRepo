    <JadeMethod name="create" id="bfe70e73-2d84-4a26-ba2e-fd7d8ebb99d4">
        <updating/>
        <source>create() updating;
// ---------------------------------------------------------------------------
// Created:     10 December 2009 by cnwcs5
// Purpose:     CCMS 1028 - summary mappings
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	
	self.className	:= CM_BookingRef.name;
	
epilog

end;</source>
