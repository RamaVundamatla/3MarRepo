    <JadeMethod name="btnClose_click" id="97fb76c7-a9b3-4273-9503-97ac69d1ce68">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnClose_click(btn: Button input) updating;

begin
	app.mousePointer	:=	Busy;
	terminate;		// This will terminate the whole application, including closing any of the open forms.
epilog
	app.mousePointer	:=	Idle;
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
