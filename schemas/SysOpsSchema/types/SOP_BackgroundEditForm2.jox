        <controlMethod name="Table::displayRow"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>lstTable_displayRow(table: Table input; theSheet: Integer; obj: Object; theRow: Integer; bcontinue: Boolean io):String updating;

// cnwdvb1 07 February 2003 

vars
	isSelected	: Boolean;
	
begin

	// Added to screen for requests.
	if not obj.Class.inheritsFrom(BGP_Request) then
		return null;
	endif;
	
	isSelected	:=	table.CMUI_ListTable.allSelectedObjects.includes(obj);
	
	if isSelected then
		return TableCheckBox_Selected  &amp; Tab &amp; obj.Class.text.cnEcGetTagValueOfName('display');
	else
		return  TableCheckBox_NotSelected &amp; Tab &amp; obj.Class.text.cnEcGetTagValueOfName('display');
	endif;	
end;</source>
