<Class name="WS_SubTerminal" id="98a275f7-7f76-4081-a785-1956c7d23149">
    <superclass name="WS_ProxyObject"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>Represents Sub Terminals inside the Terminal</text>
    <DbClassMap file="webservice"/>
    <PrimAttribute name="code" id="f188fb7f-f336-4ae2-81a9-88f7d141086b">
        <length>31</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
        <text>Sub Terminal code </text>
    </PrimAttribute>
    <PrimAttribute name="type" id="48c9da8a-06a2-4996-9534-eb158bae8f87">
        <length>31</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
        <text>Sub Terminal Type ex: Depot,Marine, Warehouse</text>
    </PrimAttribute>
    <JadeMethod name="setProxyFromObject" id="4fd1c152-2737-487b-9705-d109acad52ec">
        <updating/>
        <source>setProxyFromObject(_object: CM_SubTerminal) updating;

/*
----------   ----------  --------------------------------------------------
Created:	22 April 2009 By cnwdz2

Purpose:	CCMS1735: 

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
begin
	inheritMethod(_object);
	
	self.code	:=	_object.code;
	self.type	:=	app.subTerminalTypeEnumToString(_object.type);
end;</source>
        <Parameter name="_object" type="CM_SubTerminal"/>
    </JadeMethod>
</Class>
