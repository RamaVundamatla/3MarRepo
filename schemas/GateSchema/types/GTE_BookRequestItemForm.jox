    <JadeMethod name="hasErrors" id="6b8ca821-0f6a-4d2b-923a-c1d1f14c1ef4">
        <source>hasErrors(_display : Boolean) : Boolean;
// --------------------------------------------------------------------------------
// Created:		26 May 2009 by cnwjo3
//
// Purpose:		check that the values on the items for is valid, display errors if not doing a 'checkHasChanged'
vars
	passport 	: CM_Passport;
	cargoType	: CM_CargoType;
begin
	passport := app.myPassport;

	on CM_Exception do addExceptionHandler(exception, passport);
	
	app.setContinueCMExceptions(true);
	
	passport.clearErrorsWarnings();
	
	cargoType := self.cmbCargoType.myObject.CM_CargoType;
	
	if cargoType = null then
		app.raiseCMException(Unspecified_Cargo_Type,app.getErrorString(Unspecified_Cargo_Type),null);
	endif;
	
	if cargoType &lt;&gt; null then
		if cargoType.id = TI_CargoType_Container then
			//if self.cmbIsotype.myObject = null then														//-cnwml2 PAR21082
			if self.cmbIsoType.listObject = null and self.cmbIsoGroup.myObject = null then					//+cnwml2 PAR21082
			//	app.raiseCMException(Unspecified_ISO_Type,app.getErrorString(Unspecified_ISO_Type),null);	//-cnwml2 PAR21082
				app.raiseCMException(Unspecified_ISO, app.getErrorString(Unspecified_ISO), null);			//+cnwml2 PAR21082
			endif;
		//else																								//-cnwml2 PAR20173 SFW CCMS 1091
		else
			if cargoType &lt;&gt; null and						// par 22672 - use combo as proxy not updated yet
				cargoType.isSubCargoTypeRequired then		// par 22672 - use combo as proxy not updated yet
				if self.cmbProduct.myObject = null then
					app.raiseCMException(Unspecified_product,app.getErrorString(Unspecified_product),null);
				endif;
			endif;
		endif;
	endif;
	
	if passport.hasErrors() then
		if _display then
			app.showErrorWarningDialog(self.caption, passport,ErrWarnMode_Add);
			return true;
		else
			return true;
		endif;
	else
		return false;
	endif;
epilog
	app.setContinueCMExceptions(false);
end;</source>
        <Parameter name="_display" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="hideCDGeneralGroupBox" id="dd34d091-2317-4902-bb9b-c20aafedd37c">
