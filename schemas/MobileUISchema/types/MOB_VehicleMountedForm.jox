	*/
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28 April 2010	cnwer1	Initial creation

*/

vars
	accessObject : Object;
begin
	if self.tblMoveInfo.columns &lt; 2 then
		return null;
	endif;
	accessObject:=self.tblMoveInfo.accessColumn(2).itemObject;
	
	if accessObject = null then
		return null;
	endif;

	if not accessObject.isKindOf(CM_TrackedItem) then
