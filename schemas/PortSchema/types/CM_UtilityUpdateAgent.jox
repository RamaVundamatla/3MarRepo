    <JadeMethod name="utlUpdateCMIF_LogStockAlloc" id="fb2bc537-0e6e-495e-b611-2098abfebeed">
        <source>utlUpdateCMIF_LogStockAlloc(_cmifAllocSet: CMIF_LogStockOrderAllocSet; _passport : CM_Passport input);
//--------------------------------------------------------------
//Created: July 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	iFaceAlloc : CMIF_StockOrderAllocation;
begin
	self.initialiseActivity();
	app.setContinueCMExceptions(true);

	app.myValUA.valCMIF_LogStockAlloc(_cmifAllocSet, _passport);

	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;

	app.setContinueCMExceptions(false);
	
	foreach iFaceAlloc in _cmifAllocSet do
		if iFaceAlloc.canAllocateToOrder then
			iFaceAlloc.doUpdate(_passport);
			if (not _passport.noErrors) then
				return;
			endif;
			global.causeEvent(LogVoyageOps_Update_Event, false, iFaceAlloc.myLogStockOrderLine);
			global.causeEvent(LogVoyageOps_Update_Event, false, iFaceAlloc.myStockOrderSummary);			
		endif;
	endforeach;
	
end;</source>
        <Parameter name="_cmifAllocSet" type="CMIF_LogStockOrderAllocSet"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateCMObject" id="2536a04c-9754-4a6b-90ac-8665c23bde7a">
        <updating/>
        <source>utlUpdateCMObject(_pxyCMObject : CM_Object; _passport : CM_Passport input) updating;
//-----------------------------------------
//Created: April 2005 By: cnwgd1
//-----------------------------------------
vars
	realObject : CM_Object;
	expectedEdition : Integer;
begin

	self.initialiseActivity();

	app.setContinueCMExceptions(true);
	_pxyCMObject.raiseExceptionIfNotProxy(method);
	_pxyCMObject.validateUpdate(_passport);

	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);
	_pxyCMObject.pxyGetRealObjectAndEdition(realObject, expectedEdition);
	app.setContinueCMExceptions(true);

	if realObject = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, _pxyCMObject.getName, null, null);
		return;
	endif;
	
	exclusiveLock(realObject);

	if _passport.noErrors and realObject.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, realObject.getDisplayDetails(true), null, null);
		return;
	endif;
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realObject, true);
	endif;
	
	if _passport.noErrors then
		realObject.setForUpdateFromProxy(_pxyCMObject, _passport);
	endif;
	
	if _passport.noErrors then
		//realObject.causeCMEvent(realObject.EventMode_Update);
		self.myUpdateAuditAgent.audUpdateGeneric(realObject, false);
	endif;
	
end;</source>
        <Parameter name="_pxyCMObject" type="CM_Object"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
