    <JadeMethod name="trxUpdateWagonLoadComplete" id="cc59df9f-339a-4b36-8dc4-bf29ecf0630e">
        <updating/>
        <source>trxUpdateWagonLoadComplete(_wagon : CM_Wagon input; _completeWagonLoad: Boolean; _passport : CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date					Who		Reason
04 November 2022		jlizm1	Initial creation TFS 54118 Assigning Releases to Wagons
14 March    2025    	navbk1  Defect 34242: Halt Timer is displayed when clicking on Done on an Any Amount Rail Job

*/

vars

begin
	
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);


	app.setContinueCMExceptions(false);
	
	_passport.useEventDeferUpdate		  := true;									//14.02.25 navbk1 #33829

	beginTransaction;

	app.myUtilityUA.utlUpdateWagonLoadComplete(_wagon, _completeWagonLoad, _passport);		//14.03.25 navbk1 #34242
	
	if app.myPassport.hasErrors then
		return;
	endif;
	
	if _completeWagonLoad then														//14.02.25 navbk1 #33829
		_wagon.createTransaction(app.actualTimeServer, EVT_WagonLoadComplete, _wagon.myTrainOutwards, null, null, false, null, null, null);
	endif;
	
	if _passport.noErrors then														//14.02.25 navbk1 #33829
		_passport.doDeferredUpdates();	
	endif;

epilog

	self.finaliseActivityWithPassport(_passport);

end;</source>
        <Parameter name="_wagon" type="CM_Wagon" usage="input"/>
        <Parameter name="_completeWagonLoad" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
