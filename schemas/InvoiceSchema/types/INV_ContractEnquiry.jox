    <JadeMethod name="doBtnCopyClick" id="3ed53730-27c0-41f7-a12c-b5785d2e7da5">
        <source>doBtnCopyClick();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 March 2023	navkc1	Initial creation CR #55652 Task 57014: UI - Contract Copy UI

*/

vars
	contract		: CM_InvoiceContract;
	
	form			: INV_ContractCopyForm;
	
begin
	
	contract := self.tblData.accessRow(self.tblData.row).itemObject.CM_InvoiceContract;
	
	if contract = null then
