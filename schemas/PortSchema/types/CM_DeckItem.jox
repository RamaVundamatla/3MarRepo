18 July 2013	cnwer1	Initial creation PAR 31936

*/

vars

begin
	if _viewMode = ShpDisplayMode_ColCodeLoad then
		self.getAllTIsRoB(_tis, true, false);
	elseif _viewMode = ShpDisplayMode_ColCodeDisch then
		self.getAllTIs(REAL_MODE,_tis, true);
	endif;
epilog

