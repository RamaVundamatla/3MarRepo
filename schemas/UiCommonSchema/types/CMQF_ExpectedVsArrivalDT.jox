<Class name="CMQF_ExpectedVsArrivalDT">
    <JadeMethod name="setFromAgent" id="6a689b9b-38ff-42b4-a698-763401464282">
        <updating/>
        <source>setFromAgent(_agent: CMUI_ReportAgent input) updating;
//12 February 2010	cnwml2


vars
	text : String;
begin
	inheritMethod(_agent);

	text := _agent.getValueByNameIfVisible(ETRow_ArrivedEarlierThan).String;
	self.arrivedEarlierThan := text.Integer;
	text := _agent.getValueByNameIfVisible(ETRow_ArrivedLaterThan).String;
	self.arrivedLaterThan := text.Integer;

epilog

end;</source>
        <Parameter name="_agent" type="CMUI_ReportAgent" usage="input"/>
    </JadeMethod>
</Class>
