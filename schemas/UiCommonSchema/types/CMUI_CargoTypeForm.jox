    <JadeMethod name="setupForm" id="614af073-3501-45e0-af97-0b5df5f07ba6">
        <updating/>
        <source>setupForm() updating;
// ---------------------------------------------------------------------------
// Created:     24 October 2002		cnwth2	
//
// Purpose:
// Changed On By Reason
// ---------- ---------- --------------------------------------------------
// 03/03/2022  navak20   #52821 - 020 Cargo Type Maint File List
// ----------   ----------  ----------------------------------------     
			 
// ----------   ----------  --------------------------------------------------
vars
	theWidth			: Integer;
	entTableDef	: EntTableDef;
begin
	self.buildTEUMultiplierCombo();
	inheritMethod();

	self.lblSysType.caption := 'System defined cargo type - no default values';

	self.sptDataFilter.setLeftToRightRatioAndResize(35);
	self.sptThumbEdit.showRightControl(60, true);
	self.sptThumbEdit.setLeftToRightRatio(60);
	self.tblDefaultValues.left := 0;
	self.tblDefaultValues.top := 5;
	self.tblDefaultValues.width := self.tblDefaultValues.parent.width;
	self.tblDefaultValues.height := self.tblDefaultValues.parent.height;
	self.tblDefaultValues.stretchHeight := true;
	self.tblDefaultValues.stretchWidth := true;
	self.setColorsForTable(self.tblDefaultValues);
	self.tblThumb.stretchToParent := true;
	self.frmDetailsTop.backColor := self.backColor;
	
	//20 May 2021	NDL	TFS 51243
	entTableDef := app.myController.getEntTableDef( ETDef_RecipeView );
	self.tblRecipes.setTblDataEntRowsFromDef(entTableDef);
	self.tblRecipes.selectMode := Table.SelectMode_CurrentRow;
	self.tblRecipes.selectionType := self.tblRecipes.SelectionType_Row;
	self.tblRecipes.multiSelect := self.tblRecipes.MultiSelect_None;
	self.shtRecipes.visible := true;	//20 May 2021	NDL	TFS 51243
	
	// CCMS 1080. Par 19704. May 2009 cnwvu1
	self.fldEdit.visible	:= true;
	self.fldEdit.top	:= 0;
	self.fldEdit.left	:= 0;
	self.chkShowNotAvail.value := false;
	self.initMultiSelect();	
	self.btnAttachment.enabled := false;	//03.03.2022  navak20	TFS #52821
	
	self.frmTableFilter.setCallbackMethod(CMUI_CargoTypeForm::doFilterTable.name); //25/06/2024	navkc1 CR 64823 Task 64824
	
end;</source>
    </JadeMethod>
    <JadeMethod name="setupPermissions" id="53c3c6dc-dbe5-48df-a7cd-71587da677ab">
        <updating/>
        <source>setupPermissions() updating;
// ---------------------------------------------------------------------------
// Created:     16 March 2005 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	canMaint,
	allowWarehousing		: Boolean;
	
begin
	//th2 22/05/2007 - the previous inheritMethod call below here was incorrect - it made it possible to add
	//new cargo types without having the general cargo module!
	
	// cnwdad1 06/08/2007 - Added change so that cargo types can be added or deleted with the Voyage
	// Commodity Planning module.
	
	allowWarehousing	:=	app.getMyUser().canDo(self.myTerminal, Mod_GeneralCargo) ;
	canMaint := app.getMyUser.canDo(self.myTerminal, self.permissionMaint);
	
	self.allowAdd	 := allowWarehousing and canMaint;
	self.allowDelete := allowWarehousing and canMaint;
	self.allowUpdate := canMaint;
end;</source>
    </JadeMethod>
    <JadeMethod name="showHideCargoUniqueness" id="cd257c9c-64de-466d-b918-893d4e56c766">
        <updating/>
        <source>showHideCargoUniqueness() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 May 2022	navds20	ChangeRequest 53508: EUP - Cargo Uniqueness - UI
1 Sept 2022 navvt20 Bug 54683: MTN - Cargo Types screen shows cargo group setting attributes even if the system doesn't have cargo group License
01 May 2023	jlizm1	TFS 55453 Cargo uniqueness by subtype
*/

vars
	tmpRow	: Integer;
	tbl		: CM_EntryTable;
	currentValue : Boolean;
	cargoType	: CM_CargoType;
	entTableRow	: EntTableRowTransient;
begin

	tbl		:= self.tblEntDetail;
	tmpRow	:= tbl.row;
	currentValue	:= tbl.getValue(tmpRow).Boolean;
	
	
	if not currentValue then
		tbl.hideRowByName(ETRow_UseCGForUniqueness, false);
		tbl.hideRowByName(ETRow_UseSubTypeForUniqueness, false);
		return;
	endif;
	
	if app.isCargoGroupEnabled then
		tbl.showRowByName(ETRow_UseCGForUniqueness, false);
	endif;
	
	tbl.showRowByName(ETRow_UseSubTypeForUniqueness, false);
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="showHideCommodityCode" id="99ff6c8d-fbfe-493f-8895-1df45b593646">
        <source>showHideCommodityCode() protected;
/* ---------------------------------------------------------------------------
Created:	18 May 2009	by cnwvu1

Purpose:	
   
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars
	tmpRow	: Integer;
	tbl		: CM_EntryTable;
	
begin

	tbl		:= self.tblEntDetail;
	tmpRow	:= tbl.row;
	if tbl.getValue(tmpRow).Boolean then
		tbl.showRowByName(ETRow_DefaultCommodityCode, false);
		self.shtCommodityEnableDisable(SHT_COMMODITY_ENABLE, null, null);
	else
		tbl.hideRowByName(ETRow_DefaultCommodityCode, false);
		self.shtCommodityEnableDisable(SHT_COMMODITY_DISABLE, null, null);
	endif;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="showHideControlForUserCargoTyp" id="f853f43d-ae06-4baf-aea1-4e66c062866c">
        <source>showHideControlForUserCargoTyp( _cargoType : CM_CargoType; _productType : Integer; _tbl : CM_BaseTable input) protected;
/* ---------------------------------------------------------------------------
Created:	09 July 2009	by cnwvu1

Purpose:	CCMS 1080 PAR19704. //show hide controlls for trailers, vehicles etc. 
   
Change Date		Who			Reason
09/03/2010		cnwdap1		PAR #22938 New _cargoType parameter, show reefer definition rows if we are track as vehicle
22/03/2010		cnwdap1		PAR #22995 Allow Break-Bulk with no cargo subtypes to have reefer properties
06/05/2014		cnwdap1		PAR #33606 CCMS SFW 1366 Bulk - allow Track as Vehicle to have cargo subtypes
24/07/2017		cnwma1		TSS #4475: Issues with editing Cargo Types
21 July 2022 	navvt20 	ChangeRequest 53917: MTN - Cargo Types TEUs for GC
06/09/2024		jlizm1		TFS 65952 NSW Dynamics Integration - ISO Type Group and Cargo Type external references
------------------------------------------------------------------------------*/
vars
	
begin

	if _tbl = null then
		return;
	endif;
	
	if _tbl = self.tblEntDetail then	// Edit/Add mode
		_tbl.CM_EntryTable.showRowByName(ETRow_IsDynamicallyCreated, false);
		_tbl.CM_EntryTable.showRowByName(ETRow_DefaultHandlingType, false);
		_tbl.CM_EntryTable.showRowByName(ETRow_ExternalReference, false);
		
		// PAR #22938 default to hiding reefer definition rows
		_tbl.CM_EntryTable.hideRowByName(ETRow_Reefer, false);
		_tbl.CM_EntryTable.hideRowByName(ETRow_Powered, false);
		_tbl.CM_EntryTable.hideRowByName(ETRow_Integral, false);
		_tbl.CM_EntryTable.hideRowByName(ETRow_Fan, false);
		
		//02 Jun 2015	NDL	Par 36338
		if _cargoType &lt;&gt; null and _cargoType.id = TI_CargoType_Container then
			_tbl.CM_EntryTable.hideRowByName(ETRow_TeuConversionGC, false);
			_tbl.CM_EntryTable.hideRowByName(ETRow_TeuConversionGCBreakBulk, false); // 21 July 2022 navvt20 53917
			_tbl.CM_EntryTable.hideRowByName(ETRow_TeuConversionGCBulk, false); // 21 July 2022 navvt20 53917
			_tbl.CM_EntryTable.showRowByName(ETRow_TeuConversion20, false);
			_tbl.CM_EntryTable.showRowByName(ETRow_TeuConversion30, false);
			_tbl.CM_EntryTable.showRowByName(ETRow_TeuConversion40, false);
			_tbl.CM_EntryTable.showRowByName(ETRow_TeuConversion45, false);
			_tbl.CM_EntryTable.showRowByName(ETRow_TeuConversion53, false);
		else
			_tbl.CM_EntryTable.showRowByName(ETRow_TeuConversionGC, false);
			_tbl.CM_EntryTable.hideRowByName(ETRow_TeuConversion20, false);
			_tbl.CM_EntryTable.hideRowByName(ETRow_TeuConversion30, false);
			_tbl.CM_EntryTable.hideRowByName(ETRow_TeuConversion40, false);
			_tbl.CM_EntryTable.hideRowByName(ETRow_TeuConversion45, false);
			_tbl.CM_EntryTable.hideRowByName(ETRow_TeuConversion53, false);
		endif;
		
		// PAR #22995 show reefer definitions for Break-Bulk with no cargo sub-types
		if _productType = ProductType_BreakBulk or _productType = ProductType_PieceBreakBulk then
			if (_cargoType = null and _tbl.CM_EntryTable.getValueByName(ETRow_IsSubCargoTypeRequired).Boolean = false) or _cargoType.mySystemProductType &lt;&gt; null then
				_tbl.CM_EntryTable.showRowByName(ETRow_Reefer, false);
				_tbl.CM_EntryTable.showRowByName(ETRow_Powered, false);
				_tbl.CM_EntryTable.showRowByName(ETRow_Integral, false);
				_tbl.CM_EntryTable.showRowByName(ETRow_Fan, false);
			endif;
		elseif _productType = ProductType_CargoGroup then	//02 Jun 2015	NDL	Par 36338
			_tbl.CM_EntryTable.hideRowByName(ETRow_DefaultHandlingType, false);
			_tbl.CM_EntryTable.hideRowByName(ETRow_IsDynamicallyCreated, false);
			_tbl.CM_EntryTable.hideRowByName(ETRow_TeuConversionGC, false);
			_tbl.CM_EntryTable.hideRowByName(ETRow_TeuMultiplier, false);
		endif;	
		
		
			
	elseif _tbl = self.tblThumb then	// view mode
		//navra1 - TFS 63624 - 15th Apr 2024 - start
		if not _cargoType.useTareCargoWeight then
			_tbl.CM_ThumbnailTable.hideRowFromHeading(self.tblEntDetail.getHeadingByName(ETRow_AutoTareCargoWeightCalc));
		endif;
		//navra1 - TFS 63624 - 15th Apr 2024 - end
		
		_tbl.CM_ThumbnailTable.showRowFromHeading(self.tblEntDetail.getHeadingByName(ETRow_IsDynamicallyCreated));
		_tbl.CM_ThumbnailTable.showRowFromHeading(self.tblEntDetail.getHeadingByName(ETRow_DefaultHandlingType));
		_tbl.CM_ThumbnailTable.showRowFromHeading(self.tblEntDetail.getHeadingByName(ETRow_ExternalReference));
		
		// PAR #22938 default to hiding reefer definition rows
		_tbl.CM_ThumbnailTable.hideRowFromHeading(self.tblEntDetail.getHeadingByName(ETRow_Reefer));
		_tbl.CM_ThumbnailTable.hideRowFromHeading(self.tblEntDetail.getHeadingByName(ETRow_Powered));
		_tbl.CM_ThumbnailTable.hideRowFromHeading(self.tblEntDetail.getHeadingByName(ETRow_Integral));
		_tbl.CM_ThumbnailTable.hideRowFromHeading(self.tblEntDetail.getHeadingByName(ETRow_Fan));
		
		//02 Jun 2015	NDL	Par 36338
		if _cargoType &lt;&gt; null and _cargoType.id = TI_CargoType_Container then
			_tbl.CM_ThumbnailTable.hideRowFromHeading(self.tblEntDetail.getHeadingByName(ETRow_TeuConversionGC));
			_tbl.CM_ThumbnailTable.hideRowFromHeading(self.tblEntDetail.getHeadingByName(ETRow_TeuConversionGCBreakBulk)); // 21 July 2022 navvt20 53917
			_tbl.CM_ThumbnailTable.hideRowFromHeading(self.tblEntDetail.getHeadingByName(ETRow_TeuConversionGCBulk)); // 21 July 2022 navvt20 53917
			_tbl.CM_ThumbnailTable.showRowFromHeading(self.tblEntDetail.getHeadingByName(ETRow_TeuConversion20));
			_tbl.CM_ThumbnailTable.showRowFromHeading(self.tblEntDetail.getHeadingByName(ETRow_TeuConversion30));
			_tbl.CM_ThumbnailTable.showRowFromHeading(self.tblEntDetail.getHeadingByName(ETRow_TeuConversion40));
			_tbl.CM_ThumbnailTable.showRowFromHeading(self.tblEntDetail.getHeadingByName(ETRow_TeuConversion45));
			_tbl.CM_ThumbnailTable.showRowFromHeading(self.tblEntDetail.getHeadingByName(ETRow_TeuConversion53));
		else
			_tbl.CM_ThumbnailTable.showRowFromHeading(self.tblEntDetail.getHeadingByName(ETRow_TeuConversionGC));
			_tbl.CM_ThumbnailTable.hideRowFromHeading(self.tblEntDetail.getHeadingByName(ETRow_TeuConversion20));
			_tbl.CM_ThumbnailTable.hideRowFromHeading(self.tblEntDetail.getHeadingByName(ETRow_TeuConversion30));
			_tbl.CM_ThumbnailTable.hideRowFromHeading(self.tblEntDetail.getHeadingByName(ETRow_TeuConversion40));
			_tbl.CM_ThumbnailTable.hideRowFromHeading(self.tblEntDetail.getHeadingByName(ETRow_TeuConversion45));
			_tbl.CM_ThumbnailTable.hideRowFromHeading(self.tblEntDetail.getHeadingByName(ETRow_TeuConversion53));
		endif;
	
		// PAR #22995 show reefer definitions for Break-Bulk with no cargo sub-types
		if _productType = ProductType_BreakBulk or _productType = ProductType_PieceBreakBulk then
			if (_cargoType = null and _tbl.CM_EntryTable.getValueByName(ETRow_IsSubCargoTypeRequired).Boolean = false) or _cargoType.mySystemProductType &lt;&gt; null then
				_tbl.CM_ThumbnailTable.showRowFromHeading(self.tblEntDetail.getHeadingByName(ETRow_Reefer));
				_tbl.CM_ThumbnailTable.showRowFromHeading(self.tblEntDetail.getHeadingByName(ETRow_Powered));
				_tbl.CM_ThumbnailTable.showRowFromHeading(self.tblEntDetail.getHeadingByName(ETRow_Integral));
				_tbl.CM_ThumbnailTable.showRowFromHeading(self.tblEntDetail.getHeadingByName(ETRow_Fan));
			endif;
		elseif _productType = ProductType_CargoGroup then	//02 Jun 2015	NDL	Par 36338
			_tbl.CM_ThumbnailTable.hideRowFromHeading(self.tblEntDetail.getHeadingByName(ETRow_DefaultHandlingType));
			_tbl.CM_ThumbnailTable.hideRowFromHeading(self.tblEntDetail.getHeadingByName(ETRow_IsDynamicallyCreated));
			_tbl.CM_ThumbnailTable.hideRowFromHeading(self.tblEntDetail.getHeadingByName(ETRow_TeuConversionGC));
			_tbl.CM_ThumbnailTable.hideRowFromHeading(self.tblEntDetail.getHeadingByName(ETRow_TeuMultiplier));
		endif;
		//Start  21 July 2022 navvt20 53917
		if _productType = ProductType_BreakBulk then
				_tbl.CM_ThumbnailTable.hideRowFromHeading(self.tblEntDetail.getHeadingByName(ETRow_TeuConversionGC));
				_tbl.CM_ThumbnailTable.hideRowFromHeading(self.tblEntDetail.getHeadingByName(ETRow_TeuConversionGCBulk));
		elseif _productType = ProductType_Bulk then
				_tbl.CM_ThumbnailTable.hideRowFromHeading(self.tblEntDetail.getHeadingByName(ETRow_TeuConversionGC));
				_tbl.CM_ThumbnailTable.hideRowFromHeading(self.tblEntDetail.getHeadingByName(ETRow_TeuConversionGCBreakBulk));
		endif;
		
		// End 21 July 2022 navvt20 53917
	endif;

	if _productType &lt;&gt; ProductType_Trailer and _productType &lt;&gt; ProductType_Vehicle then
		return;	// there are no specific requirements to hide controls for user cargo types
	endif;
	
	// Start 21 July 2022 navvt20 53917
	if _productType = ProductType_BreakBulk  then
            //if (_cargoType = null and _tbl.CM_EntryTable.getValueByName(ETRow_IsSubCargoTypeRequired).Boolean = false) or _cargoType.mySystemProductType &lt;&gt; null then
				 
                _tbl.CM_ThumbnailTable.hideRowFromHeading(self.tblEntDetail.getHeadingByName(ETRow_TeuConversionGC));
				_tbl.CM_ThumbnailTable.hideRowFromHeading(self.tblEntDetail.getHeadingByName(ETRow_TeuConversionGCBulk));
				_tbl.CM_ThumbnailTable.showRowFromHeading(self.tblEntDetail.getHeadingByName(ETRow_TeuConversionGCBreakBulk));
	elseif _productType = ProductType_Bulk then
				_tbl.CM_ThumbnailTable.hideRowFromHeading(self.tblEntDetail.getHeadingByName(ETRow_TeuConversionGC));
				_tbl.CM_ThumbnailTable.hideRowFromHeading(self.tblEntDetail.getHeadingByName(ETRow_TeuConversionGCBreakBulk));
				_tbl.CM_ThumbnailTable.showRowFromHeading(self.tblEntDetail.getHeadingByName(ETRow_TeuConversionGCBulk));
    endif;
	
	if _productType = ProductType_PieceBreakBulk then
		_tbl.CM_ThumbnailTable.hideRowFromHeading(self.tblEntDetail.getHeadingByName(ETRow_TeuConversionGCBreakBulk));
		_tbl.CM_ThumbnailTable.hideRowFromHeading(self.tblEntDetail.getHeadingByName(ETRow_TeuConversionGC));
	endif;
	// END 21 July 2022 navvt20 53917
	// ---------------------------------------------------------------
	// 				now, there are Trailer or Vehicle
	// ---------------------------------------------------------------
	
	if _tbl = self.tblEntDetail then	// Edit/Add mode
		//_tbl.CM_EntryTable.hideRowByName(ETRow_IsSubCargoTypeRequired, false);											// PAR #33606
		//_tbl.CM_EntryTable.hideRowByName(ETRow_NumberOfProducts, false);													// PAR #33606
		if _productType = ProductType_Trailer then
			_tbl.CM_EntryTable.hideRowByName(ETRow_IsCommodityRequired, false);
			_tbl.CM_EntryTable.hideRowByName(ETRow_DefaultCommodityCode, false);
			_tbl.CM_EntryTable.hideRowByName(ETRow_IsSubCargoTypeRequired, false);											// PAR #33606
			_tbl.CM_EntryTable.hideRowByName(ETRow_NumberOfProducts, false);												// PAR #33606
		endif;
		_tbl.CM_EntryTable.hideRowByName(ETRow_IsDynamicallyCreated, false);
		_tbl.CM_EntryTable.hideRowByName(ETRow_DefaultHandlingType, false);
		
		// PAR #22938 show reefer defintion rows for track as vehicle
		if _productType = ProductType_Vehicle and (_cargoType = null or _cargoType.mySystemProductType &lt;&gt; null) then
			_tbl.CM_EntryTable.showRowByName(ETRow_Reefer, false);
			_tbl.CM_EntryTable.showRowByName(ETRow_Powered, false);
			_tbl.CM_EntryTable.showRowByName(ETRow_Integral, false);
			_tbl.CM_EntryTable.showRowByName(ETRow_Fan, false);
		endif;
	
	elseif _tbl = self.tblThumb then	// view mode
		//_tbl.CM_ThumbnailTable.hideRowFromHeading(self.tblEntDetail.getHeadingByName(ETRow_IsSubCargoTypeRequired));		// PAR #33606
		//_tbl.CM_ThumbnailTable.hideRowFromHeading(self.tblEntDetail.getHeadingByName(ETRow_NumberOfProducts));			// PAR #33606
		if _productType = ProductType_Trailer then
			//_tbl.CM_ThumbnailTable.hideRowFromHeading(self.tblEntDetail.getHeadingByName(ETRow_IsCommodityRequired));    //24.07.2017 cnwma1 TFS #4475
			//_tbl.CM_ThumbnailTable.hideRowFromHeading(self.tblEntDetail.getHeadingByName(ETRow_DefaultCommodityCode));  //24.07.2017 cnwma1 TFS #4475
			_tbl.CM_ThumbnailTable.hideRowFromHeading(self.tblEntDetail.getHeadingByName(ETRow_IsSubCargoTypeRequired));	// PAR #33606
			_tbl.CM_ThumbnailTable.hideRowFromHeading(self.tblEntDetail.getHeadingByName(ETRow_NumberOfProducts));			// PAR #33606
		endif;
		_tbl.CM_ThumbnailTable.hideRowFromHeading(self.tblEntDetail.getHeadingByName(ETRow_IsDynamicallyCreated));
		_tbl.CM_ThumbnailTable.hideRowFromHeading(self.tblEntDetail.getHeadingByName(ETRow_DefaultHandlingType));
		
		// PAR #22938 show reefer defintion rows for track as vehicle
		if _productType = ProductType_Vehicle and _cargoType &lt;&gt; null and _cargoType.mySystemProductType &lt;&gt; null then
			_tbl.CM_ThumbnailTable.showRowFromHeading(self.tblEntDetail.getHeadingByName(ETRow_Reefer));
			_tbl.CM_ThumbnailTable.showRowFromHeading(self.tblEntDetail.getHeadingByName(ETRow_Powered));
			_tbl.CM_ThumbnailTable.showRowFromHeading(self.tblEntDetail.getHeadingByName(ETRow_Integral));
			_tbl.CM_ThumbnailTable.showRowFromHeading(self.tblEntDetail.getHeadingByName(ETRow_Fan));
		endif;
	
	endif;
	
end;</source>
        <access>protected</access>
        <Parameter name="_cargoType" type="CM_CargoType"/>
        <Parameter name="_productType" type="Integer"/>
        <Parameter name="_tbl" type="CM_BaseTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="showHideControlsTblEntDetail" id="06754635-b9bc-4a12-89c6-26280ef69f8d">
        <source>showHideControlsTblEntDetail(_trackAs : Integer) protected;
/* ---------------------------------------------------------------------------
Created:	18 May 2009	by cnwvu1

Purpose:	shows and hides controls for user defined cargo type.
			_trackAs - keeps value from cmbProductType (Trask As)
			If _traskAs = -1 - means cargoType.productTytpe value
   
Change Date	Who			Reason
23/11/2009	cnwmh5		PAR21657 - For ISO Container we don't show "Track As"
10/03/2010	cnwdap1		PAR #22938 New parameter for showHideControlForUserCargoTyp method
24/03/2014	cnwdap1		PAR #33606 CCMS SFW 1366 Bulk - only show Track As and Default measurement types for Bulk
21 July 2022 navvt20 	ChangeRequest 53917: MTN - Cargo Types TEUs for GC
------------------------------------------------------------------------------*/

vars
	cargoType	: CM_CargoType;
	tbl			: CM_EntryTable;
	
begin
	tbl := self.tblEntDetail;
	cargoType := self.myCurrentObject.CM_CargoType;

	if cargoType &lt;&gt; null and cargoType.isSystemCargoBOLType then
	
		tbl.hideRowByName(ETRow_IsSubCargoTypeRequired, false);
		tbl.hideRowByName(ETRow_IsCommodityRequired, false);
		tbl.hideRowByName(ETRow_DefaultCommodityCode, false);
		tbl.hideRowByName(ETRow_NumberOfProducts, false);
	
	else //user defined cargo
		// show isSubCargoTypeRequired
		tbl.showRowByName(ETRow_IsSubCargoTypeRequired, false);
		if cargoType &lt;&gt; null and cargoType.hasProductTypes() then
			tbl.disableRowByName(ETRow_IsSubCargoTypeRequired);
		else
			tbl.enableRowByName(ETRow_IsSubCargoTypeRequired);
		endif;
		// show number of subcargo types
		if cargoType &lt;&gt; null and cargoType.isSubCargoTypeRequired then
			tbl.showRowByName(ETRow_NumberOfProducts, false);
		else
			tbl.hideRowByName(ETRow_NumberOfProducts, false);
		endif;
		
		// commodity
		tbl.showRowByName(ETRow_IsCommodityRequired, false);
		if cargoType &lt;&gt; null and cargoType.isCommodityRequired then
			tbl.showRowByName(ETRow_DefaultCommodityCode, false);	//CCMS 1080 - visible for superuser

		else	//when cargoType = null - adding a new cargo type OR isCommodityRequired = false
			tbl.hideRowByName(ETRow_DefaultCommodityCode, false);
		endif;
	
	endif;

	// 23/11/2009 cnwmh5 PAR21657 - Start
	// if ISO Container then don't show Trakc As
	if cargoType &lt;&gt; null and cargoType.classNameToCreate = CM_Container.name then
		tbl.hideRowByName(ETRow_ProductType, false);
		tbl.showRowByName(ETRow_IsCommodityRequired, false);
	else
		tbl.showRowByName(ETRow_ProductType, false);
	endif;
	// 23/11/2009 cnwmh5 PAR21657 - End
	
	//show hide controlls for trailers, vehicles etc. CCMS 1080, PAR 19704 July 2009
	if _trackAs &gt; -1 then
		self.showHideControlForUserCargoTyp(cargoType, _trackAs, tbl);
	elseif cargoType &lt;&gt; null then	
		self.showHideControlForUserCargoTyp(cargoType, cargoType.productType, tbl);	
	endif;

	tbl.disableRowByName(ETRow_NumberOfProducts);	// always disabled
	tbl.hideRowByName(ETRow_DrawAttribute, false);	// make it always hidden - there is system info. ccms 1080, Par19704.

	self.shtCommodityEnableDisable(null, cargoType, _trackAs);		// show or hide shtCommodity. CCMS 1080, PAR 19704, 20316. July 2009
	
	self.tblEntDetail.cnEcResizeContents();
	
	
	
	if self.cmbBehaviourType.listIndex  = -1 then
		if _trackAs = ProductType_Trailer then
			self.cmbBehaviourType.listObject:=app.myRoot.allTIBehaviourTypes[TIBehaviourType_TermTrailer];
			self.cmbBehaviourType.lostFocus(self.cmbBehaviourType);
		elseif _trackAs = ProductType_Vehicle then			
			self.cmbBehaviourType.listObject:=app.myRoot.allTIBehaviourTypes[TIBehaviourType_Car];
			self.cmbBehaviourType.lostFocus(self.cmbBehaviourType);
		endif;
	endif;
	
	//Start navtnr20 29-06-2022 53917
	tbl.hideRowByName(ETRow_TeuConversionGCBreakBulk,false); 
	tbl.hideRowByName(ETRow_TeuConversionGCBulk,false);
	tbl.showRowByName(ETRow_TeuConversionGC,false);
	if self.cmbProductType.listIndex &lt;&gt; -1 then
		if _trackAs &lt;&gt; -1 then
			 if _trackAs = ProductType_Bulk then		
				self.cmbTEUMulti.text := app.getErrorString(CM_Weight);
				self.cmbTEUMulti.lostFocus(self.cmbTEUMulti);
				tbl.showRowByName(ETRow_TeuConversionGCBulk,false);
				tbl.hideRowByName(ETRow_TeuConversionGC,false);
			 elseif _trackAs = ProductType_BreakBulk then
				self.cmbTEUMulti.text := app.getErrorString(CM_Quantity);
				self.cmbTEUMulti.lostFocus(self.cmbTEUMulti);
				tbl.showRowByName(ETRow_TeuConversionGCBreakBulk,false);
				tbl.hideRowByName(ETRow_TeuConversionGC,false);
			 else 
				if _trackAs = ProductType_CargoGroup then
					tbl.hideRowByName(ETRow_TeuConversionGC,false);
					tbl.hideRowByName(ETRow_IsSubCargoTypeRequired, false);					//29.Aug.2023 navsp1 TFS 58664
				endif;
				self.cmbTEUMulti.text := app.getErrorString(ValueOfOne);
				self.cmbTEUMulti.lostFocus(self.cmbTEUMulti);
			 endif;
		else
			if (cargoType &lt;&gt; null and cargoType.productType = ProductType_BreakBulk and not cargoType.classNameToCreate = CM_Container.name) then 
				tbl.showRowByName(ETRow_TeuConversionGCBreakBulk,false);
				tbl.hideRowByName(ETRow_TeuConversionGC,false);
				
			elseif  (cargoType &lt;&gt; null and cargoType.productType = ProductType_Bulk) then
				tbl.showRowByName(ETRow_TeuConversionGCBulk,false);
				tbl.hideRowByName(ETRow_TeuConversionGC,false);
			
			elseif (cargoType &lt;&gt; null and (cargoType.productType = ProductType_CargoGroup or cargoType.classNameToCreate = CM_Container.name))then
					 tbl.hideRowByName(ETRow_TeuConversionGC,false);
			endif;
		endif;
	endif;
	//end navtnr20 29-06-2022 53917
		
	if (cargoType &lt;&gt; null and cargoType.isBulkProduct) or _trackAs = ProductType_Bulk then	// PAR #33606
		tbl.showRowByName(ETRow_TrackBy, false);											// PAR #33606
		tbl.showRowByName(ETRow_DefaultWeightType, false);									// PAR #33606
		tbl.showRowByName(ETRow_DefaultVolumeType, false);									// PAR #33606
	else																					// PAR #33606
		tbl.hideRowByName(ETRow_TrackBy, false);											// PAR #33606
		tbl.hideRowByName(ETRow_DefaultWeightType, false);									// PAR #33606
		tbl.hideRowByName(ETRow_DefaultVolumeType, false);									// PAR #33606
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_trackAs" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="showHideControlsTblThumb" id="9ebc5499-1cc7-4b16-a23d-1d5d5edb1ddd">
        <source>showHideControlsTblThumb() protected;
/* ---------------------------------------------------------------------------
Created:	18 May 2009	by cnwvu1

Purpose:	shows and hides controls for user defined cargo type.

Change Date	Who			Reason
23/11/2009	cnwmh5		PAR21657 - If ISO Container don't show "Track As"
10/03/2010	cnwdap1		PAR #22938 New parameter for showHideControlForUserCargoTyp method
24/03/2014	cnwdap1		PAR #33606 CCMS SFW 1366 Bulk - only show Track By and Default measurements for bulk
14 July 2022 navvt20 	ChangeRequest 53917: MTN - Cargo Types TEUs for GC
09/08/2022   navds20	ChangeRequest 54219: EUP - Cargo Group to be mandatory
30 Aug 2022  navvt20 	Bug 54683: MTN - Cargo Types screen shows cargo group setting attributes even if the system doesn't have cargo group License
01/05/2023	jlizm1		TFS 55453 Cargo uniqueness by subtype
11 July 2023 navmv20 CR 58244 Task 58245: UI - Multiple Operators
------------------------------------------------------------------------------*/
vars
	cargoType	: CM_CargoType;
	tbl			: CM_ThumbnailTable;

begin

	tbl := self.tblThumb;
	cargoType := self.myCurrentObject.CM_CargoType;
	tbl.showRowFromHeading(self.tblEntDetail.getHeadingByName(ETRow_Font));
	tbl.showRowFromHeading(self.tblEntDetail.getHeadingByName(ETRow_DrawColour));
	tbl.showRowFromHeading(self.tblEntDetail.getHeadingByName(ETRow_Character));
	
	// START 21 July 2022 navvt20 53917
	if cargoType.productType = ProductType_BreakBulk then
		 tbl.hideRowFromHeading(self.tblEntDetail.getHeadingByName(ETRow_TeuConversionGC));
		 tbl.hideRowFromHeading(self.tblEntDetail.getHeadingByName(ETRow_TeuConversionGCBulk));
	elseif cargoType.productType = ProductType_Bulk then
		 tbl.hideRowFromHeading(self.tblEntDetail.getHeadingByName(ETRow_TeuConversionGC));
		 tbl.hideRowFromHeading(self.tblEntDetail.getHeadingByName(ETRow_TeuConversionGCBreakBulk));
	else
		tbl.hideRowFromHeading(self.tblEntDetail.getHeadingByName(ETRow_TeuConversionGCBreakBulk));
		tbl.hideRowFromHeading(self.tblEntDetail.getHeadingByName(ETRow_TeuConversionGCBulk));
    endif;
	 // END 21 July 2022 navvt20 53917
	 
	// START 02/06/2022 navvt20 TFS 53751 &amp; 53758
	if (cargoType.productType = ProductType_Vehicle or cargoType.productType = ProductType_Trailer) then
		tbl.hideRowFromHeading(self.tblEntDetail.getHeadingByName(ETRow_AllowDuplicates));
		tbl.hideRowFromHeading(self.tblEntDetail.getHeadingByName(ETRow_UseCGForUniqueness));
	endif;
	// END 02/06/2022 navvt20 TFS 53751 &amp; 53758
	
	// START 30 Aug 2022 navvt20 TFS 54683
	if app.isCargoGroupEnabled and cargoType.allowDuplicates
		and (cargoType.productType = ProductType_Bulk or cargoType.productType = ProductType_BreakBulk) then
		tbl.showRowFromHeading(self.tblEntDetail.getHeadingByName(ETRow_UseCGForUniqueness));
	else
		tbl.hideRowFromHeading(self.tblEntDetail.getHeadingByName(ETRow_UseCGForUniqueness));
	endif;
	//END  30 Aug 2022 navvt20 TFS 54683
	
	// TFS 55453
	if cargoType.allowDuplicates
	and (cargoType.productType = ProductType_Bulk or cargoType.productType = ProductType_BreakBulk) then
		tbl.showRowFromHeading(self.tblEntDetail.getHeadingByName(ETRow_UseSubTypeForUniqueness));
	else
		tbl.hideRowFromHeading(self.tblEntDetail.getHeadingByName(ETRow_UseSubTypeForUniqueness));
	endif;
	
	//start 09/08/2022 navds20 TFS 54219
	if not app.isCargoGroupEnabled or cargoType.productType = ProductType_CargoGroup then
		tbl.hideRowFromHeading(self.tblEntDetail.getHeadingByName(ETRow_IsCargoGroupRequired));
	 //11/07/2023 navmv20 CR 58244 Task 58245 - start
		tbl.hideRowFromHeading(self.tblEntDetail.getHeadingByName(ETRow_AllowMultiOperators));
	elseif cargoType.isCargoGroupRequired then
		tbl.showRowFromHeading(self.tblEntDetail.getHeadingByName(ETRow_AllowMultiOperators));
	else
		tbl.hideRowFromHeading(self.tblEntDetail.getHeadingByName(ETRow_AllowMultiOperators));
	//11/07/2023 navmv20 CR 58244 Task 58245 - end
	endif;
	//end 09/08/2022 navds20 TFS 54219
		
	
	if cargoType.isSystemCargoBOLType then
		tbl.hideRowFromHeading(self.tblEntDetail.getHeadingByName(ETRow_IsSubCargoTypeRequired));
		tbl.hideRowFromHeading(self.tblEntDetail.getHeadingByName(ETRow_IsCommodityRequired));
		tbl.hideRowFromHeading(self.tblEntDetail.getHeadingByName(ETRow_DefaultCommodityCode));
		tbl.hideRowFromHeading(self.tblEntDetail.getHeadingByName(ETRow_NumberOfProducts));
		
	else
		// CCMS 1080 - user defined cargo types - hidden for JMT release, visible for superuser
		tbl.showRowFromHeading(self.tblEntDetail.getHeadingByName(ETRow_IsSubCargoTypeRequired));
		tbl.showRowFromHeading(self.tblEntDetail.getHeadingByName(ETRow_IsCommodityRequired));
		if cargoType.isCommodityRequired then
			tbl.showRowFromHeading(self.tblEntDetail.getHeadingByName(ETRow_DefaultCommodityCode));
		else
			tbl.hideRowFromHeading(self.tblEntDetail.getHeadingByName(ETRow_DefaultCommodityCode));
		endif;
		
		if cargoType.isSubCargoTypeRequired then
			tbl.showRowFromHeading(self.tblEntDetail.getHeadingByName(ETRow_NumberOfProducts));
		else
			tbl.hideRowFromHeading(self.tblEntDetail.getHeadingByName(ETRow_NumberOfProducts));
		endif;
	//	tbl.hideRowFromHeading(self.tblEntDetail.getHeadingByName(ETRow_Font));
	//	tbl.hideRowFromHeading(self.tblEntDetail.getHeadingByName(ETRow_DrawColour));
	//	tbl.hideRowFromHeading(self.tblEntDetail.getHeadingByName(ETRow_Character));
		
	endif;

	if cargoType &lt;&gt; null then	//show hide controlls for trailers, vehicles etc. CCMS 1080, PAR 19704 July 2009
		self.showHideControlForUserCargoTyp(cargoType, cargoType.productType, tbl);	
		// 23/11/02009 cnmwh5 PAR21657 - Start
		if cargoType.classNameToCreate = CM_Container.name then
			tbl.hideRowFromHeading(self.tblEntDetail.getHeadingByName(ETRow_ProductType));
		endif;
		// 23/11/2009 cnwmh5 PAR21657
	endif;

	tbl.hideRowFromHeading(self.tblEntDetail.getHeadingByName(ETRow_DrawAttribute));	// make it always hidden - there is system info. ccms 1080, Par19704.
	
	if cargoType &lt;&gt; null and cargoType.isBulkProduct then										// PAR #33606
		tbl.showRowFromHeading(self.tblEntDetail.getHeadingByName(ETRow_TrackBy));				// PAR #33606
		tbl.showRowFromHeading(self.tblEntDetail.getHeadingByName(ETRow_DefaultWeightType));	// PAR #33606
		tbl.showRowFromHeading(self.tblEntDetail.getHeadingByName(ETRow_DefaultVolumeType));	// PAR #33606
	else																						// PAR #33606
		tbl.hideRowFromHeading(self.tblEntDetail.getHeadingByName(ETRow_TrackBy));				// PAR #33606
		tbl.hideRowFromHeading(self.tblEntDetail.getHeadingByName(ETRow_DefaultWeightType));	// PAR #33606
		tbl.hideRowFromHeading(self.tblEntDetail.getHeadingByName(ETRow_DefaultVolumeType));	// PAR #33606
	endif;																						// PAR #33606
	
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="showHideMultipleOperators" id="438db501-da71-4af4-bcde-23cc2f817c1e">
        <source>showHideMultipleOperators();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 July 2023 navmv20 CR 58244 Task 58245: UI - Multiple Operators

*/

vars
	tmpRow	: Integer;
	tbl		: CM_EntryTable;
	
begin

	tbl		:= self.tblEntDetail;
	tmpRow	:= tbl.row;
	if tbl.getValue(tmpRow).Boolean then
		tbl.showRowByName(ETRow_AllowMultiOperators, false);
	else
		tbl.hideRowByName(ETRow_AllowMultiOperators, false);
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="showHideReeferProperties" id="ca1313cf-5057-4043-a6f8-cb5963e62040">
        <updating/>
        <source>showHideReeferProperties() updating, protected;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22/03/2010	cnwdap1	Initial creation PAR #22995
*/
vars
	tmpRow	: Integer;
	tbl		: CM_EntryTable;
	
begin

	tbl		:= self.tblEntDetail;
	tmpRow	:= tbl.row;
	if tbl.getValue(tmpRow).Boolean then
		tbl.hideRowByName(ETRow_Reefer, false);
		tbl.hideRowByName(ETRow_Powered, false);
		tbl.hideRowByName(ETRow_Integral, false);
		tbl.hideRowByName(ETRow_Fan, false);
	else
		if tbl.getValueByName(ETRow_ProductType).String = ProductType_BreakBulkStr or tbl.getValueByName(ETRow_ProductType).String = ProductType_PieceBreakBulkStr then
			tbl.showRowByName(ETRow_Reefer, false);
			tbl.showRowByName(ETRow_Powered, false);
			tbl.showRowByName(ETRow_Integral, false);
			tbl.showRowByName(ETRow_Fan, false);
		endif;
	endif;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="showHideTblAttributes" id="2cf20744-4ab4-4cbb-9a69-231fa5050f10">
        <updating/>
        <source>showHideTblAttributes() updating, protected;
/* ---------------------------------------------------------------------------
Created:	22 May 2009	by cnwvu1

Purpose:	
   
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars
	tmpRow	: Integer;
	tbl		: CM_EntryTable;
	currentValue : Boolean;
	cargoType	: CM_CargoType;
	
begin

	tbl		:= self.tblEntDetail;
	tmpRow	:= tbl.row;
	currentValue	:= tbl.getValue(tmpRow).Boolean;
	
	self.showProductTypeAttributes( not currentValue );
	
	cargoType := self.myCurrentObject.CM_CargoType;
	self.displayProductDefaultsNew(cargoType, self.cmbProductType.listData);

	if currentValue then
		tbl.showRowByName(ETRow_NumberOfProducts, false);
	else
		tbl.hideRowByName(ETRow_NumberOfProducts, false);
	endif;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="showProductTypeAttributes" id="9dc25822-e94b-4859-9d15-9759582c70fd">
        <source>showProductTypeAttributes(_show : Boolean) protected;
/* ---------------------------------------------------------------------------
Created:	22 May 2009	by cnwvu1

Purpose:	Product Type means Sub Cargo Type
   
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars
	
begin
	
	if _show then
		self.tblAttributes.visible		:= true;	// show attribute values for cargo types without sub cargo types
		self.tblDefaultValues.visible	:= false;
	else
		self.tblAttributes.visible		:= false;
		self.tblDefaultValues.visible	:= true;	// show default values for cargo types having sub cargo types
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="_show" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="showThumbnailData" id="36ce82ff-29b8-4630-a8b2-8a444b2f2bbc">
        <updating/>
        <source>showThumbnailData(obj: Object) updating;
// ---------------------------------------------------------------------------
// Created:     02 October 2002 by cnwth2
//
// Purpose:     
//
// Changed On	By			Reason
// ----------   ----------  --------------------------------------------------
// 19/03/2014	cnwdap1		PAR #33606 CCMS SFW 1366 Bulk
vars
	cargoType		: CM_CargoType;
begin

	cargoType := obj.CM_CargoType;
	//if cargoType.id &gt; TI_CargoBOLType_Max then				// PAR #33606
	if not cargoType.isSystemCargoBOLType then					// PAR #33606
		self.lblSysType.visible := false;
	else
		self.lblSysType.visible := true;
	endif;
	
	self.tblThumb.rows := 0;
	self.tblThumb.columns := 2;

	self.showThumbnailForDef(ETDef_CargoTypeThumb, cargoType);
	self.setNavigatorHeading(cargoType.description);

	self.setMultiSelectForCargoType(false);	//PAR 19704, CCMS 1080 May 2008
	
	self.setShtBlendingRecipes(false);	//20 May 2021	NDL	TFS 51243
	
	self.tblThumb.cnEcResizeContents();
	
	//epr TFS 7756 16/2/18 tiding up product attributes for web portal
	self.tblAttributes.visible:=false;
	self.tblDefaultValues.visible:=false;
	if cargoType &lt;&gt; null then
		self.displayProductDefaultsNew(cargoType,cargoType.productType);
	endif;
end;</source>
        <Parameter name="obj" type="Object"/>
    </JadeMethod>
    <JadeMethod name="showThumbnailForDef" id="ad72c098-7ee6-4e83-9c2f-17288ac64fcd">
        <source>showThumbnailForDef(pDefName: String; _obj: CM_Object);
/*

Purpose:			


Return Value:		


Date		Who		Reason
04 April 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars
	row				: Integer;
	drawAttr		: CM_DrawingAttribute;
	table 			: CM_ThumbnailTable;
	hasDrawAttr 	: Boolean;
	entTableDef		: EntTableDef;
	entTableRow		: EntTableRow;
	productTypeHeading,
	colourHeading,
	characterHeading,
	graphicHeading : String;	
	cargoType : CM_CargoType;
	newPicture : Binary;
	w,h : Integer;
begin

	inheritMethod(pDefName, _obj);
	drawAttr := _obj.CM_CargoType.myDrawingAttribute;
	hasDrawAttr:=drawAttr &lt;&gt; null;
	table :=  self.tblThumb;
	if hasDrawAttr then
		self.cmbChar.fontName := drawAttr.fontName;
		/*
			Date		Who		Reason
		17 July 2008   cnwdz2   Par16782 - check if the font character has been specified.
		*/
		if drawAttr.fontCharacter &gt;= 1 and drawAttr.fontCharacter &lt;= 255 then
			self.cmbChar.listIndex := drawAttr.fontCharacter;
		endif;
	endif;	
	
	//getting entTableRow headings for cells text - should be translated according to locale. ccsm 1080 May 2009
	entTableDef := app.myController.getEntTableDef(pDefName);
	foreach entTableRow in entTableDef.allEntTableRows do
		if entTableRow.name = ETRow_ProductType then
			productTypeHeading := entTableRow.getHeading(null, null, app.myCurrentLocale);
		elseif entTableRow.name = ETRow_DrawColour then
			colourHeading := entTableRow.getHeading(null, null, app.myCurrentLocale);
		elseif entTableRow.name = ETRow_Character then
			characterHeading := entTableRow.getHeading(null, null, app.myCurrentLocale);
		elseif entTableRow.name = ETRow_BehaviourType then
			graphicHeading := entTableRow.getHeading(null, null, app.myCurrentLocale);
		endif;
	endforeach;
	
	foreach row in 1 to table.rows do
		//if hasDrawAttr and table.getCellText(row,1) = 'Colour' then
		if hasDrawAttr and table.getCellText(row,1) = colourHeading then
			table.accessCell(row,2).backColor := drawAttr.colour;
		//elseif hasDrawAttr and table.getCellText(row,1) = 'Character' then
		elseif hasDrawAttr and table.getCellText(row,1) = characterHeading then
			table.accessCell(row,2).fontName := drawAttr.fontName;
			table.accessCell(row,2).text := self.cmbChar.text;
			table.accessCell(row,2).foreColor := drawAttr.colour;
		//elseif table.getCellText(row,1) = 'Product Type' then
		elseif table.getCellText(row,1) = productTypeHeading then	// ccms 1080 May 2009. Need to get translated caption from EntTableDef
			table.accessCell(row,2).text := _obj.CM_CargoType.getProductTypeString();
		endif;
	endforeach;
	
	self.showHideControlsTblThumb();	//PAR 19704, CCMS 1080. May 2009 cnwvu1

	//cnwjo3 ccms 1018, make row taller and place image.
	foreach row in 1 to table.rows do
		if table.getCellText(row,1) = graphicHeading then
			table.accessRow(row).visible := false;  //cnwjo3 par 22963
			if self.myCurrentObject &lt;&gt; null and self.myCurrentObject.isKindOf(CM_CargoType) then
				cargoType := self.myCurrentObject.CM_CargoType;
				//cnwjo3 par 22963
				if cargoType.myTIBehaviourType &lt;&gt; null and cargoType.myTIBehaviourType.myGraphic &lt;&gt; null and cargoType.myTIBehaviourType.myGraphic.allCommands.size &gt; 0 then
					newPicture := self.drawCargoGraphic(cargoType.myTIBehaviourType.myGraphic,table.backColor);
					table.accessCell(row,2).picture := newPicture;
					table.accessCell(row,2).text := null;
					newPicture.pictureSize(w,h);
					table.accessRow(row).height := h;
					table.accessRow(row).visible := true;  //cnwjo3 par 22963
				endif;
			endif;
		endif;
	endforeach;
	
	
	
epilog

end;</source>
        <Parameter name="pDefName" type="String"/>
        <Parameter name="_obj" type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="shtCommodityEnableDisable" id="f41c4884-9ec8-473e-a7b6-c7ec863efc85">
        <source>shtCommodityEnableDisable( _forcedEnableDisable : Integer; _cargoType : CM_CargoType; _trackAs : Integer ) protected;
/* ---------------------------------------------------------------------------
Created:	20 July 2009	by cnwvu1

Purpose:	CCMS1080, PAR19704 - user-defined cargo types
			Managing shtCommodity in one place:

			_forcedEnable - comes, when tick / untick Commodity Required combobox - highest priority
				_forcedEnableDisable = 1 - enable
				_forcedEnableDisable = 2 - disable
				
			_trackAs - comes, when changing Track As combobox
			
			_cargoType - all other cases, looking at existing cargo type
			
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars

begin

	//02 Jun 2015	NDL	Par 36338
	if _trackAs = ProductType_CargoGroup or ( _cargoType &lt;&gt; null and _cargoType.productType = ProductType_CargoGroup ) then	
		self.shtCommodities.enabled := false;
		self.shtDmgePosition.enabled := false;
		self.shtSeals.enabled := false;
		self.shtRecipes.enabled := false;	//20 May 2021	NDL	TFS 51243
		return;
	else
		self.shtDmgePosition.enabled := true;
		self.shtSeals.enabled := true;
	endif;
	
	//20 May 2021	NDL	TFS 51243
	if _cargoType &lt;&gt; null and ( _cargoType.isBreakBulk or _cargoType.isBulk ) then
		self.shtRecipes.enabled := true;
	else
		self.shtRecipes.enabled := false;
	endif;

	if _forcedEnableDisable &lt;&gt; null then	//comes, when tick / untick Commodity Required combobox 
		
		if _forcedEnableDisable = self.SHT_COMMODITY_ENABLE then
			self.shtCommodities.enabled := true;
		elseif _forcedEnableDisable = self.SHT_COMMODITY_DISABLE then
			self.shtCommodities.enabled := false;
		else
			app.raiseUnexpectedProgramError( class.name, method.name, 'unknown state for shtComodities' );
		endif;
		
		
	elseif _trackAs &gt; -1 then		//comes, when changing Track As combobox
	
		if _trackAs = ProductType_Trailer then	// when combobox gets a value, it means there is no system cargo type (combobox is disabled)
			self.shtCommodities.enabled	:= false;
		else
			self.shtCommodities.enabled := self.tblEntDetail.getValueByName(ETRow_IsCommodityRequired).Boolean;
		endif;
	
	
	else		// other cases, looking at current exisiting cargo type
	
		if _cargoType = null then	// it = null, when creating a new cargo type
			self.shtCommodities.enabled := false;
		else
			self.shtCommodities.enabled := _cargoType.isCommodityRequired;
		endif;

	endif;
	
end;</source>
        <access>protected</access>
        <Parameter name="_forcedEnableDisable" type="Integer"/>
        <Parameter name="_cargoType" type="CM_CargoType"/>
        <Parameter name="_trackAs" type="Integer"/>
    </JadeMethod>
