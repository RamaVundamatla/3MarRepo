<Class name="CM_MenuHdrSystem" id="239f4646-6b7c-42ee-80e8-17ab15714055">
    <superclass name="CM_MenuHdr"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="cmenu"/>
    <JadeMethod name="create" id="815caa5c-9ddd-468d-b304-7a5299652ea6">
        <updating/>
        <source>create() updating;
// ---------------------------------------------------------------------------
// Created:     27 November 2002		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin
	self.type := MenuType_HeaderSystem;
	self.isSystemMenuItem := true;
end;</source>
    </JadeMethod>
    <JadeMethod name="outputAsXML" id="6fcc5041-ba39-4922-9482-7440e4cbcf6b">
        <source>outputAsXML(_xmlHdrTag : String) : String;
// ---------------------------------------------------------------------------
// Created:     02 September 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	xmlStr,	
	childStr	: String;
	menEnt		: CM_MenuEntity;
	
begin

	foreach menEnt in self.allChildren do
		if (not menEnt.isKindOf(CM_MenuItem)) or menEnt.isKindOf(CM_QryReportUser) then
			continue;
		endif;
		childStr := childStr &amp; 
			self.formatAsXML(XMLTag_Id, menEnt.CM_MenuItem.menuId);
	endforeach;

	if childStr &lt;&gt; null then
		childStr := self.formatAsXMLPrefix(XMLTag_Children) &amp;
					childStr &amp;
					self.formatAsXMLSuffix(XMLTag_Children);
	endif;
		
	xmlStr := self.formatAsXMLPrefix(_xmlHdrTag) &amp; 
			self.formatAsXML(XMLTag_Id, self.menuId) &amp;
			self.formatAsXML(XMLTag_Heading, self.heading) &amp;
			self.formatAsXML(XMLTag_PictureButton, self.pictureStringButton) &amp; 
			self.formatAsXML(XMLTag_PictureButtonDown, self.pictureStringButtonDown) &amp; 
			self.formatAsXML(XMLTag_PictureIcon, self.pictureStringIcon) &amp; 
			self.formatAsXML(XMLTag_ToolTip, self.toolTip) &amp; 
			childStr &amp;
			self.formatAsXMLSuffix(_xmlHdrTag);
	
	return xmlStr;

end;</source>
        <Parameter name="_xmlHdrTag" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setFromXMLReportHdr" id="b4bc0d25-9d3a-4f12-ab7b-ea389a50b95c">
        <updating/>
        <source>setFromXMLReportHdr(_str : String; _root : CM_MenuRootReportForRoot; _constValue : Integer) updating;
// ---------------------------------------------------------------------------
// Created:     26 November 2002		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	idPrefix	: String;
begin


	self.constantValue			:= _constValue;
	self.heading				:= _str.cnEcGetTagValueOfName(XMLTag_Heading);
	self.menuId					:= _str.cnEcGetTagValueOfName(XMLTag_Id);

	self.pictureStringButton	:= _str.cnEcGetTagValueOfName(XMLTag_PictureButton);
	self.pictureStringButtonDown:= _str.cnEcGetTagValueOfName(XMLTag_PictureButtonDown);
	self.pictureStringIcon		:= _str.cnEcGetTagValueOfName(XMLTag_PictureIcon);
	self.toolTip				:= _str.cnEcGetTagValueOfName(XMLTag_ToolTip);

	self.myParent	:= _root;	// This may get reset later in CM_MenuHdr::setChildrenFromXML
	self.myMenuReportRoot	:= _root;
end;</source>
        <Parameter name="_str" type="String"/>
        <Parameter name="_root" type="CM_MenuRootReportForRoot"/>
        <Parameter name="_constValue" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="df7cf3a0-48de-46a8-9026-8f76634cf9b4">
        <updating/>
        <source>setProxy(_constValue : Integer; _heading : String; _expand : Boolean;
		 _pictureButton, _pictureButtonDown, _pictureIcon : String; _hdrPrefix : String) updating;

vars
	theMenuId	: String;
	
begin

	if _constValue &lt;&gt; null then
		theMenuId := _hdrPrefix &amp; _constValue.String;
	endif;

	self.setProxyMenuHdr(_constValue, theMenuId, _heading, _expand, _pictureButton, _pictureButtonDown,_pictureIcon);
	
end;</source>
        <Parameter name="_constValue" type="Integer"/>
        <Parameter name="_heading" type="String"/>
        <Parameter name="_expand" type="Boolean"/>
        <Parameter name="_pictureButton" type="String"/>
        <Parameter name="_pictureButtonDown" type="String"/>
        <Parameter name="_pictureIcon" type="String"/>
        <Parameter name="_hdrPrefix" type="String"/>
    </JadeMethod>
</Class>
