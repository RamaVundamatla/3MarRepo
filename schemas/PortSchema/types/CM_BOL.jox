    <JadeMethod name="shareLockSelfAndChildren" id="3d788be3-2678-4e86-ae20-da44f0a0d1e4">
        <source>shareLockSelfAndChildren();
// ---------------------------------------------------------------------------
// Created:     30 October 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	ti	: CM_TrackedItem;
begin
	inheritMethod();
	
	foreach ti in self.allTrackedItems do
		ti.shareLockSelfAndChildren();
	endforeach;
	
	if self.myExtension &lt;&gt; null then
		self.myExtension.shareLockSelfAndChildren();
	endif;

end;</source>
