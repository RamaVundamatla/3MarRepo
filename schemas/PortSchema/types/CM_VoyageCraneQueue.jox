    <JadeMethod name="locateMachine" id="61e578b5-e470-4999-aea0-ce90f4d8862b">
        <source>locateMachine(mach : CM_Machine) : CM_RadioTelemetryQueue;

vars

begin
	if mach = self.crane then
		return self;
	endif;
	return inheritMethod(mach);
end;</source>
