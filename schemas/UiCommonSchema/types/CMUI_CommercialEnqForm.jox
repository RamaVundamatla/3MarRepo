    <JadeMethod name="addDataToContSumAllOpsFF" id="aef7804d-47b8-4646-b77b-2ec6b1f4fa6d">
        <source>addDataToContSumAllOpsFF() : Boolean;
// ---------------------------------------------------------------------------
// Created:     05 March 2008 by cnwaer1
//
// Purpose:     
// ---------------------------------------------------------------------------
constants
	LineSep = 3;
vars
	tmpSheet 		: JadeTableSheet;
	tmpSum 			: CMIF_CommercialQuerySmry;
	currentRow,
	col				: Integer;
	queryHeader 	: CMIF_CommercialQueryHeader;
	tmpDescr,
	prevCode		: String;
	prevRowType		: Integer;
begin

	tmpSheet := self.tblData.accessSheet(2);
	queryHeader := self.myQueryHdr;

	tmpSheet.rows := tmpSheet.fixedRows;

//	if queryHeader.allSums.size &lt;&gt; 0 and queryHeader.totalFF = 0 and  queryHeader.totalOperators = 0 then
	prevCode := ' ';
	prevRowType := 0;
	
	foreach tmpSum in self.myQueryHdr.allSums do
		if prevRowType &lt;&gt; tmpSum.rowType then
			// row type has changed
			if prevRowType &lt;&gt; 0 then
				self.addTotalSumObjects(prevRowType);
				currentRow := tmpSheet.addItem('');
				tmpSheet.accessRow(currentRow).backColor := White;
				tmpSheet.accessRow(currentRow).height := LineSep;
				tmpSheet.accessCell(currentRow, 1).text := "";
			endif;
			if tmpSum.rowType = self.myQueryHdr.SumRow_Operator then
				tmpDescr := "Operators";
			else
				tmpDescr := "Freight Forwarders";
			endif;
			currentRow := tmpSheet.addItem(tmpDescr);
			tmpSheet.accessRow(currentRow).fontBold := true;
			tmpSheet.accessRow(currentRow).backColor:= LightBlue;
		endif;
		
		if prevCode &lt;&gt; tmpSum.rowSortCode then
			// We have a new operator or FF
			if tmpSum.rowType = self.myQueryHdr.SumRow_Operator then
				if tmpSum.myOperator = null then
					tmpDescr := '&lt; unknown &gt;';
				else
					tmpDescr := tmpSum.myOperator.description;
				endif;
			else
				if tmpSum.myFreightForwarder = null then
					tmpDescr := '&lt; unknown &gt;';
				else
					tmpDescr := tmpSum.myFreightForwarder.description;
				endif;
			endif;
			currentRow := tmpSheet.addItem(tmpDescr);
		
			if currentRow mod 2 &lt;&gt; 0 then
				tmpSheet.accessRow(currentRow).backColor := self.colorRow1;
			else 
				tmpSheet.accessRow(currentRow).backColor := self.colorRow2;
			endif;
		endif;
			
		// Now handle the columns
		if tmpSum.imexStatus = 1 then // IMPORT
			if tmpSum.contentsStatus = 1 then // FULL CONTAINER
				col := ColumnNumbContainerSummaryGrp1 + tmpSum.cntrType;
			elseif tmpSum.contentsStatus = 3 then // EMPTY CONTINER
				col := ColumnNumbContainerSummaryGrp2 + tmpSum.cntrType;
			endif;	
		elseif tmpSum.imexStatus = 2 then // EXPORT
			if tmpSum.contentsStatus = 1 then // FULL CONTAINER
				col := ColumnNumbContainerSummaryGrp3 + tmpSum.cntrType;
			elseif tmpSum.contentsStatus = 3 then // EMPTY CONTINER
				col := ColumnNumbContainerSummaryGrp4 + tmpSum.cntrType;
			endif;	
		endif;
		if tmpSum.num &gt; 0 then
			// we can have a dummy row
			tmpSheet.accessCell(currentRow, col).text := tmpSum.num.Integer.asStringJMT;
			tmpSheet.accessCell(currentRow, col).itemObject := tmpSum;
		endif;
		
		prevCode := tmpSum.rowSortCode;
		prevRowType := tmpSum.rowType;
	endforeach;	
	
	if prevRowType &lt;&gt; 0 then
		self.addTotalSumObjects(prevRowType);
	endif;

	return true;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="addDataToTblContainersDtl" id="4906e91b-8ed0-4f30-baf2-b8d5fa09bf52">
        <source>addDataToTblContainersDtl( ) : Boolean;
// ---------------------------------------------------------------------------
// Created:     27 November 2007 by cnwaer1
//
// Purpose:     
// ---------------------------------------------------------------------------
constants
	LineSep = 5;
vars
	tmpSheet 		: JadeTableSheet;
	tmpDtl 			: CMIF_CommercialQueryDtl;
	tmpTDtl 		: CMIF_CommercialQueryDtlTotal;
	iter			: Iterator;
	numServices,
	lastService,
	row,
	col,
	idx,
	rowTotalRel,
	rowTotalRec 	: Integer;
	transDesc 		: String;
	tmpService 		: CM_TransactionType;
	firstService,
	firstTime 		: Boolean;
begin
	tmpSheet := self.tblData.accessSheet(1);
	firstTime := true;
	firstService := true;
	rowTotalRel := 15;
	rowTotalRec := 8;
	iter := self.myQueryHdr.allDtls.createIterator();
	while iter.next(tmpDtl) do
		if tmpDtl.cargoType &lt;&gt; TI_CargoType_Container then
			continue;
		endif;
		// Display Table Constant Data 		
		if firstTime then
			tmpSheet.rows := tmpSheet.fixedRows;
			tmpSheet.addItem('Receivals' &amp; Tab &amp; 'Road' );
			tmpSheet.addItem('' &amp; Tab &amp; 'Rail');
			tmpSheet.addItem('' &amp; Tab &amp; 'Sea');
			tmpSheet.addItem('' &amp; Tab &amp; 'Transships');
			tmpSheet.addItem('' &amp; Tab &amp; 'Other');		
			
			// added total line and an other while time as separator
			tmpSheet.accessRow(tmpSheet.addItem('' &amp; Tab &amp; 'Total')).backColor := Gray;
			tmpSheet.accessRow(tmpSheet.addItem('')).backColor := White;
			self.tblData.accessedRow.height := LineSep;
			
			tmpSheet.addItem('Releases' &amp; Tab &amp; 'Road');
			tmpSheet.addItem('' &amp; Tab &amp; 'Rail');
			tmpSheet.addItem('' &amp; Tab &amp; 'Sea');
			tmpSheet.addItem('' &amp; Tab &amp; 'Transships');
			tmpSheet.addItem('' &amp; Tab &amp; 'Other');
		
			// added total line and an other while time as separator
			tmpSheet.accessRow(tmpSheet.addItem('' &amp; Tab &amp; 'Total')).backColor := Gray;
			tmpSheet.accessRow(tmpSheet.addItem('')).backColor := White;
			self.tblData.accessedRow.height := LineSep;
			
			foreach tmpService in self.myQueryHdr.allServices do
				if firstService then
					firstService := false;
					tmpSheet.addItem('Services' &amp; Tab &amp; 'Service ' &amp; tmpService.description);
				else
					tmpSheet.addItem(Tab &amp; 'Service ' &amp; tmpService.description);
				endif;
			endforeach;
			firstTime := false;
		endif;
		// Display Dtl object in the table	
		if (tmpDtl.type = CMIF_CommercialQueryEntity.DtlType_Receival or
		   tmpDtl.type = CMIF_CommercialQueryEntity.DtlType_Release) then
			row := 2 + ((tmpDtl.type - 1) * 7) + tmpDtl.subType;
			
		elseif tmpDtl.type = CMIF_CommercialQueryEntity.DtlType_Services then
			idx := self.myQueryHdr.allServices.indexOf(app.myRoot.allTransactionTypes[tmpDtl.subType]);	
			row := 	16 + idx ;
		else
			continue;
		endif;
		col := 2 + tmpDtl.columnType;
		
		tmpSheet.accessCell(row, col).text := tmpDtl.num.Integer.asStringJMT;
		tmpSheet.accessCell(row, col).itemObject := tmpDtl;
	endwhile;
	
	// Display Total objects in the table
	delete iter;		// PAR #26678
	iter := self.myQueryHdr.allTotalDlts.createIterator;
	while iter.next(tmpTDtl) do
		if tmpTDtl.cargoType &lt;&gt; TI_CargoType_Container then
			continue;
		endif;
		if tmpTDtl.type = CMIF_CommercialQueryEntity.DtlType_Receival then
			row := rowTotalRec;
		elseif tmpTDtl.type = CMIF_CommercialQueryEntity.DtlType_Release then
			row := rowTotalRel;
		endif;
		col := 2 + tmpTDtl.columnType;
		tmpSheet.accessCell(row, col).text := tmpTDtl.num.Integer.asStringJMT;
		tmpSheet.accessCell(row, col).itemObject := tmpTDtl;
	endwhile;
	
	//Adding color to the table
	row := tmpSheet.fixedRows + 1;
	while row &lt;= tmpSheet.rows do
		if row &lt;&gt; 8 and row &lt;&gt; 9 and row &lt;&gt; 15 and row &lt;&gt; 16 then
			if row mod 2 &lt;&gt; 0 then
				tmpSheet.accessRow(row).backColor := self.colorRow1;
			else 
				tmpSheet.accessRow(row).backColor := self.colorRow2;
			endif;
		endif;
		row := row + 1;
	endwhile;
	//------------------------
	return not firstTime;

epilog
	delete iter;		// PAR #26678

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="addDataToTblContainersSum" id="7771de3b-8c2f-40de-a1d6-3e6a38e02db5">
        <source>addDataToTblContainersSum() : Boolean;
// ---------------------------------------------------------------------------
// Created:     15 February 2008 by cnwaer1
//
// Purpose:     
// ---------------------------------------------------------------------------
constants
	LineSep = 3;
vars
	tmpSheet 		: JadeTableSheet;
	tmpSum 			: CMIF_CommercialQuerySmry;
	tmpTSum 		: CMIF_CommercialQuerySmryTotal;
	iter			: Iterator;
	numServices,
	lastService,
	curentRow,
	col,
	idx 			: Integer;
	transDesc		: String;
	tmpService 		: CM_TransactionType;
	ff				: CM_ConsigneeConsignor;
	op				: CM_Operator;
	tempDictFF 		: CMIF_CommercialQrySumDict;
begin
	tmpSheet := self.tblData.accessSheet(2);
	curentRow := tmpSheet.fixedRows;

	if self.myQueryHdr.totalFF &lt;&gt; 0 then 
		self.tblData.accessSheet(2).rows := curentRow + self.myQueryHdr.allFreightForwarders.size + 3 ;
		curentRow := curentRow + 1;
		tmpSheet.accessRow(curentRow).fontBold := true;
		tmpSheet.accessRow(curentRow).backColor:= LightBlue;
		tmpSheet.accessCell(curentRow, 1).text := "Freight Forwarders";
		foreach ff in self.myQueryHdr.allFreightForwarders do
			delete iter;		// PAR #26678
			iter := self.myQueryHdr.allSums.createIterator;
			curentRow := curentRow + 1;
			//Adding color to the Freight Forwarders part of sheet
			if curentRow mod 2 &lt;&gt; 0 then
				tmpSheet.accessRow(curentRow).backColor := self.colorRow1;
			else 
				tmpSheet.accessRow(curentRow).backColor := self.colorRow2;
			endif;
			//----------------------------
			tmpSheet.accessCell(curentRow, 1).text := ff.description;
			while iter.next(tmpSum) do
				if tmpSum.cargoType &lt;&gt; TI_CargoType_Container or tmpSum.rowType &lt;&gt; 1 then
					continue;
				endif;
				if tmpSum.myFreightForwarder = ff then
					if tmpSum.imexStatus = 1 then // IMPORT
						if tmpSum.contentsStatus = 1 then // FULL CONTAINER
							col := ColumnNumbContainerSummaryGrp1 + tmpSum.cntrType;
						elseif tmpSum.contentsStatus = 3 then // EMPTY CONTINER
							col := ColumnNumbContainerSummaryGrp2 + tmpSum.cntrType;
						endif;	
					elseif tmpSum.imexStatus = 2 then // EXPORT
						if tmpSum.contentsStatus = 1 then // FULL CONTAINER
							col := ColumnNumbContainerSummaryGrp3 + tmpSum.cntrType;
						elseif tmpSum.contentsStatus = 3 then // EMPTY CONTINER
							col := ColumnNumbContainerSummaryGrp4 + tmpSum.cntrType;
						endif;	
					endif;
					//write curentRow.String&amp; "-" &amp;col.String;
					tmpSheet.accessCell(curentRow, col).text := tmpSum.num.Integer.asStringJMT;
					tmpSheet.accessCell(curentRow, col).itemObject := tmpSum;
				else
					continue;
				endif;
			endwhile;
		endforeach;
		curentRow := curentRow + 1;
		tmpSheet.accessRow(curentRow).backColor := White;
		tmpSheet.accessRow(curentRow).height := LineSep;
		tmpSheet.accessCell(curentRow, 1).text := "";
		curentRow := curentRow + 1;
		tmpSheet.accessRow(curentRow).fontBold := true;
		tmpSheet.accessRow(curentRow).backColor := Gray;
		tmpSheet.accessCell(curentRow, 1).text := "Total";
		// adding the total summs objects
		delete iter;		// PAR #26678
		iter := self.myQueryHdr.allTotalSums.createIterator;
		while iter.next(tmpTSum) do
			if tmpTSum.cargoType &lt;&gt; TI_CargoType_Container or tmpTSum.rowType &lt;&gt; 1 then
				continue;
			endif;
			if tmpTSum.imexStatus = 1 then // IMPORT
				if tmpTSum.contentsStatus = 1 then // FULL CONTAINER
					col := ColumnNumbContainerSummaryGrp1 + tmpTSum.cntrType;
				elseif tmpTSum.contentsStatus = 3 then // EMPTY CONTINER
					col := ColumnNumbContainerSummaryGrp2 + tmpTSum.cntrType;
				endif;	
			elseif tmpTSum.imexStatus = 2 then // EXPORT
				if tmpTSum.contentsStatus = 1 then // FULL CONTAINER
					col := ColumnNumbContainerSummaryGrp3 + tmpTSum.cntrType;
				elseif tmpTSum.contentsStatus = 3 then // EMPTY CONTINER
					col := ColumnNumbContainerSummaryGrp4 + tmpTSum.cntrType;
				endif;	
			endif;
			//process.debug;
			tmpSheet.accessCell(curentRow, col).text := tmpTSum.num.Integer.asStringJMT;
			tmpSheet.accessCell(curentRow, col).itemObject := tmpTSum;
		endwhile;
	endif;
	
	if self.myQueryHdr.totalOperators &lt;&gt; 0 then 
		if self.myQueryHdr.totalFF &lt;&gt; 0 then 
			self.tblData.accessSheet(2).rows :=curentRow + self.myQueryHdr.allOperators.size +4 ;
			curentRow := curentRow + 1;
			tmpSheet.accessRow(curentRow).backColor := White;
			tmpSheet.accessRow(curentRow).height := LineSep;
			tmpSheet.accessCell(curentRow, 1).text := "";
		else
			self.tblData.accessSheet(2).rows :=curentRow + self.myQueryHdr.allOperators.size +3 ;
		endif;
		curentRow := curentRow + 1;
		tmpSheet.accessRow(curentRow).fontBold := true;
		tmpSheet.accessRow(curentRow).backColor:= LightBlue;
		tmpSheet.accessCell(curentRow, 1).text := "Operators";
		foreach op in self.myQueryHdr.allOperators do
			delete iter;		// PAR #26678
			iter := self.myQueryHdr.allSums.createIterator;
			curentRow := curentRow + 1;
			// adding color to the operators part of sheet
			if curentRow mod 2 &lt;&gt; 0 then
				tmpSheet.accessRow(curentRow).backColor := self.colorRow1;
			else 
				tmpSheet.accessRow(curentRow).backColor := self.colorRow2;
			endif;
			//------------------------------
			tmpSheet.accessCell(curentRow, 1).text := op.description;
			while iter.next(tmpSum) do
				if tmpSum.cargoType &lt;&gt; TI_CargoType_Container or tmpSum.rowType &lt;&gt; 2 then
					continue;
				endif;
				if tmpSum.myOperator = op then
					if tmpSum.imexStatus = 1 then // IMPORT
						if tmpSum.contentsStatus = 1 then // FULL CONTAINER
							col := ColumnNumbContainerSummaryGrp1 + tmpSum.cntrType;
						elseif tmpSum.contentsStatus = 3 then // EMPTY CONTINER
							col := ColumnNumbContainerSummaryGrp2 + tmpSum.cntrType;
						endif;	
					elseif tmpSum.imexStatus = 2 then // EXPORT
						if tmpSum.contentsStatus = 1 then // FULL CONTAINER
							col := ColumnNumbContainerSummaryGrp3 + tmpSum.cntrType;
						elseif tmpSum.contentsStatus = 3 then // EMPTY CONTINER
							col := ColumnNumbContainerSummaryGrp4 + tmpSum.cntrType;
						endif;	
					endif;
					tmpSheet.accessCell(curentRow, col).text := tmpSum.num.Integer.asStringJMT;
					tmpSheet.accessCell(curentRow, col).itemObject := tmpSum;
				else
					continue;
				endif;
			endwhile;
		endforeach;
		curentRow := curentRow + 1;
		tmpSheet.accessRow(curentRow).backColor := White;
		tmpSheet.accessRow(curentRow).height := LineSep;
		tmpSheet.accessCell(curentRow, 1).text := "";
		curentRow := curentRow + 1;
		tmpSheet.accessRow(curentRow).fontBold := true;
		tmpSheet.accessRow(curentRow).backColor:= Gray;
		tmpSheet.accessCell(curentRow, 1).text := "Total";
		// adding the total summs objects
		delete iter;		// PAR #26678
		iter := self.myQueryHdr.allTotalSums.createIterator;
		while iter.next(tmpTSum) do
			if tmpTSum.cargoType &lt;&gt; TI_CargoType_Container or tmpTSum.rowType &lt;&gt; 2 then
				continue;
			endif;
			if tmpTSum.imexStatus = 1 then // IMPORT
				if tmpTSum.contentsStatus = 1 then // FULL CONTAINER
					col := ColumnNumbContainerSummaryGrp1 + tmpTSum.cntrType;
				elseif tmpTSum.contentsStatus = 3 then // EMPTY CONTINER
					col := ColumnNumbContainerSummaryGrp2 + tmpTSum.cntrType;
				endif;	
			elseif tmpTSum.imexStatus = 2 then // EXPORT
				if tmpTSum.contentsStatus = 1 then // FULL CONTAINER
					col := ColumnNumbContainerSummaryGrp3 + tmpTSum.cntrType;
				elseif tmpTSum.contentsStatus = 3 then // EMPTY CONTINER
					col := ColumnNumbContainerSummaryGrp4 + tmpTSum.cntrType;
				endif;	
			endif;
				
			tmpSheet.accessCell(curentRow, col).text := tmpTSum.num.Integer.asStringJMT;
			tmpSheet.accessCell(curentRow, col).itemObject := tmpTSum;
		endwhile;
	endif;
	return true;
	
epilog
	delete iter;		// PAR #26678
		
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="addDataToTblOtherCargo" id="a4b6bb37-d617-486a-9af7-d4afcad00b3a">
        <source>addDataToTblOtherCargo() : Boolean;
// ---------------------------------------------------------------------------
// Created:     06 December 2007 by cnwaer1
//
// Purpose:     
// ---------------------------------------------------------------------------
constants
	LineSep = 5;
vars
	numStr,
	transDesc			: String;
	cargoTypeFirstRow,
	serviceFirstRow,
	idx, i ,
	numServices,
	lastService,
	row, 
	col,
	cType,
	previousRows,
	initialRow			: Integer;
	tmpSheet			: JadeTableSheet;
	cargoType 			: CM_CargoType;
	iter				: Iterator;
	tmpDtl 				: CMIF_CommercialQueryDtl;
	firstTime,
	firstService 		: Boolean;
	tmpService 			: CM_TransactionType;
begin
	
	tmpSheet := self.tblData.accessSheet(3);
	tmpSheet.rows := tmpSheet.fixedRows;
	previousRows :=2;
	numServices := self.myQueryHdr.allServices.size();
	foreach cargoType in self.myQueryHdr.allCargoTypes where cargoType.id &lt;&gt; TI_CargoType_Container do
		cType := cargoType.id;
		firstTime := true;
		firstService := true;
		delete iter;		// PAR #26678
		iter := self.myQueryHdr.allDtls.createIterator();
		self.myQueryHdr.allDtls.startKeyGeq(cargoType.description, null, null,  null, iter);
		
		while iter.next(tmpDtl)  do
			if  tmpDtl.cargoType &lt;&gt; cType then
				break;
			endif;
			if firstTime then 
				firstTime := false;
				cargoTypeFirstRow := tmpSheet.addItem(cargoType.description); 
				tmpSheet.accessRow(cargoTypeFirstRow).backColor:= LightBlue;
								
				tmpSheet.addItem(Tab &amp; 'Receivals' &amp; Tab &amp; 'Road' );
				tmpSheet.addItem(Tab &amp; '' &amp; Tab &amp; 'Rail');
				tmpSheet.addItem(Tab &amp; '' &amp; Tab &amp; 'Sea' );
				tmpSheet.addItem(Tab &amp; '' &amp; Tab &amp; 'Transships');
				tmpSheet.addItem(Tab &amp; '' &amp; Tab &amp; 'Other');
										
				tmpSheet.accessRow(tmpSheet.addItem('')).backColor := White;
				self.tblData.accessedRow.height := LineSep;
																		
				tmpSheet.addItem(Tab &amp; 'Releases' &amp; Tab &amp; 'Road' );
				tmpSheet.addItem(Tab &amp; '' &amp; Tab &amp; 'Rail');
				tmpSheet.addItem(Tab &amp; '' &amp; Tab &amp; 'Sea');
				tmpSheet.addItem(Tab &amp; '' &amp; Tab &amp; 'Transships');
				tmpSheet.addItem(Tab &amp; '' &amp; Tab &amp; 'Other');
																		
				tmpSheet.accessRow(tmpSheet.addItem('')).backColor := White;
				self.tblData.accessedRow.height := LineSep;
				
				foreach tmpService in self.myQueryHdr.allServices do
					if firstService then
						firstService := false;
						serviceFirstRow := tmpSheet.addItem(Tab &amp;'Services' &amp; Tab &amp; 'Service ' &amp; tmpService.description);
					else
						tmpSheet.addItem(Tab &amp; Tab &amp; 'Service ' &amp; tmpService.description);
					endif;
				endforeach;
			endif;
			//add data
			if (tmpDtl.type = CMIF_CommercialQueryEntity.DtlType_Receival or
				tmpDtl.type = CMIF_CommercialQueryEntity.DtlType_Release) then
				row := 1 + previousRows + ((tmpDtl.type - 1) * 6) + tmpDtl.subType;		
			elseif tmpDtl.type = CMIF_CommercialQueryEntity.DtlType_Services then
				idx := self.myQueryHdr.allServices.indexOf(app.myRoot.allTransactionTypes[tmpDtl.subType]);
				row := 	1 + previousRows + 12 + idx ;
			else
				continue;
			endif;
			col := tmpDtl.columnType - 2;
			tmpSheet.accessCell(row, col).text := tmpDtl.num.Integer.asStringJMT;
			tmpSheet.accessCell(row, col).itemObject := tmpDtl;
		endwhile;
		initialRow := previousRows;
		if not firstTime then
			previousRows := 1+ previousRows + 12 + numServices;
		endif;
		// adding color to the table
		i := initialRow + 2;
		while i &lt;=  previousRows do
			if i &lt;&gt; (initialRow + 7) and i &lt;&gt; (initialRow + 13) then
				if i mod 2 &lt;&gt; 0 then
					tmpSheet.accessRow(i).backColor := self.colorRow1;
				else 
					tmpSheet.accessRow(i).backColor := self.colorRow2;
				endif;
			endif;
			i := i+ 1;
		endwhile;	
	endforeach;
	
	if previousRows &gt; 2 then 
		return true;
	else
		return false;
	endif;

epilog
	delete iter;		// PAR #26678
		
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
