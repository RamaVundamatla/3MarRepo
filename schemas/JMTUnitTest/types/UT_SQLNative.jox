    <JadeMethod name="tGetValidSQLTimestamp" id="bb0304ae-23c5-46e6-b263-0d46ab9df01e">
        <source>tGetValidSQLTimestamp();
// jlgmd1
// cnwkpd1
// cnwdz2	
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28 October 2010	#cnwdz2	 

*/

vars
	validTimestamp,
	timestamp : TimeStamp;
	validTime,
	invalidTime : Time;
	
	validDate,
	datePrior1901,
	invalidDate : Date;
begin
	validTime := "00:40:00.000".Time;
	invalidTime := "60:00:00.000".Time;
	
	validDate := "28/10/2010".Date;
	datePrior1901 := "28/10/1900".Date;
	invalidDate   := "28/22/1900".Date;
	
	//test null timestamp
	timestamp := null;
	self.assertEqual(timestamp.getValidSQLTimeStamp2005(), null);
	self.assertEqual(timestamp.getValidSQLTimestamp(), null);
	
	//test valid timestamp
	timestamp.setDate(validDate);
	timestamp.setTime(validTime);
	self.assertEqual(timestamp.getValidSQLTimeStamp2005(), "2010-10-28 00:40:00.000".TimeStamp);
	self.assertEqual(timestamp.getValidSQLTimestamp(), "2010-10-28 00:40:00.000");
	
	//test valid Date and invalid time
	timestamp.setTime(invalidTime);
	self.assertEqual(timestamp.getValidSQLTimeStamp2005(), null);
	self.assertEqual(timestamp.getValidSQLTimestamp(), null);
	
	//test valid Date and null time
	timestamp.setTime(null);	
	self.assertEqual(timestamp.getValidSQLTimeStamp2005(), "2010-10-28 00:00:00.000".TimeStamp);
	self.assertEqual(timestamp.getValidSQLTimestamp(), "2010-10-28 00:00:00.000");
	
	// test invalid date and null time
	timestamp.setDate(invalidDate);	
	self.assertEqual(timestamp.getValidSQLTimeStamp2005(), null);
	self.assertEqual(timestamp.getValidSQLTimestamp(), null);

	//test invalid date and valid time
	timestamp.setTime(validTime);
	self.assertEqual(timestamp.getValidSQLTimeStamp2005(), validTime.TimeStamp);
	self.assertEqual(timestamp.getValidSQLTimestamp(), "00:40:00.000");
	
	//test null date and valid time
	timestamp.setDate(null);
	self.assertEqual(timestamp.getValidSQLTimeStamp2005(), validTime.TimeStamp);
	self.assertEqual(timestamp.getValidSQLTimestamp(), "00:40:00.000");
	
	//test date prior to 1901 and valid time
	timestamp.setDate(datePrior1901);
	self.assertEqual(timestamp.getValidSQLTimeStamp2005(), "1901/01/01".Date.TimeStamp);
	self.assertEqual(timestamp.getValidSQLTimestamp(), "1901-01-01 00:00:00.000");
	
	//test date prior to 1901 and null time
	timestamp.setDate(datePrior1901);
	timestamp.setTime(null);
	self.assertEqual(timestamp.getValidSQLTimeStamp2005(), "1901/01/01".Date.TimeStamp);
	self.assertEqual(timestamp.getValidSQLTimestamp(), "1901-01-01 00:00:00.000");
	
epilog

end;</source>
    </JadeMethod>
</Class>
