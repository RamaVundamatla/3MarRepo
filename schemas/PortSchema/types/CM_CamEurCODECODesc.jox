    <JadeMethod name="availableCargoTypes" id="dd00f22d-5136-44d5-bedf-1dfb13d71d51">
        <source>availableCargoTypes(_classColl : ClassColl input);
//
// 15 May 2014	cnwrs1	Par 34159 - include Chassis in Codeco
//
vars

begin
	_classColl.add(CM_Container);
end;
</source>
        <Parameter name="_classColl" type="ClassColl" usage="input"/>
    </JadeMethod>
    <JadeMethod name="create" id="8c5392cd-72c4-4f9d-8f21-9ef6c9e774b7">
        <updating/>
        <source>create() updating;
//----------------------------------------------------------------
//	Created:	15 May 2008	cnwrs1 CCMS1690
//----------------------------------------------------------------
vars

begin
	self.name := "UN/EDIFACT Codeco Europe";
	self.type := EDIFileTypeCams_EurCodeco;
end;</source>
    </JadeMethod>
    <JadeMethod name="getEDIBundle" id="4af17bd0-462e-4747-adce-79941e7b410a">
        <source>getEDIBundle(): Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 January 2025	navkc1	JIRA Story MTN-33491: MTN | License - EDI Bundles Methods

*/

vars

begin
	
	return CM_EDIFileType.EDI_Bundle_CUSTOM;

epilog

end;</source>
