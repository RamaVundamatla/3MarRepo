    <JadeMethod name="cleanup" id="1634bc98-231d-4527-bee4-7c9145fa6a27">
        <updating/>
        <source>cleanup(numCleaned: Integer io) updating;

/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
28 September 2022	navcs2	ChangeRequest 54344: EUP - VAS Work Orders - Jobs

*/

vars

begin

	if self.status = JOB_COMPLETE then
		numCleaned := numCleaned +1;
		self.erase(0);
		return;
	endif;

epilog

end;</source>
        <Parameter name="numCleaned" type="Integer" usage="io"/>
