    <JadeMethod name="addPxyRailHHToTask" id="d97060f6-692e-4f2f-96a7-26cc71a7eb32">
        <source>addPxyRailHHToTask(_dtoContainer : DTO_ContainerInfo input);
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 November 2009	cnwer1	Initial creation

*/

vars
	pxyTI : CM_TrackedItem;
	toDoTaskRail : CM_ToDoTaskDesc;
begin
	pxyTI:=_dtoContainer.myPxyTrackedItem;
	
	if pxyTI = null then
		return;
	endif;
	
	toDoTaskRail:= self.myTerminal.getConfig(RailHHToDoTask).CM_ToDoTaskDesc;

	if toDoTaskRail = null then
		return ;
	endif;
	
	if  pxyTI.hasToDoTaskToDoWithCode(toDoTaskRail.code) then
		return;
	endif;
	
	pxyTI.addToDoTask(toDoTaskRail.description,app.myPassport);

epilog

end;</source>
        <Parameter name="_dtoContainer" type="DTO_ContainerInfo" usage="input"/>
    </JadeMethod>
    <JadeMethod name="buildTIsForInwards" id="c696712e-e66e-4b1d-84e0-c68bc60b5baa">
        <source>buildTIsForInwards(_dtoWagon : DTO_Wagon;
				_errorMsgs 	: DTO_HandHeldGateErrorDict input) protected;
/*
----------   ----------  --------------------------------------------------
Created:	02 November 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	backEndWagonPos,
	dtoWagonPos			: DTO_WagonPosition;
	tiType				: Integer;
	numNew,
	numExisting			: Integer;
	realWagon			: CM_Wagon;
	tiArray				: CM_TIArray;
begin
	//create and set proxy tracked items////////////////////////////////////////////
	foreach dtoWagonPos in _dtoWagon.allDTOWagonPositions do
		//2/07/2009 cnwdz2 20160
		self.doSetProxyTI(dtoWagonPos.myDTOWagon, dtoWagonPos.myDTOContainer, tiType, _errorMsgs);
		
		if tiType = self.NEW_TI_ON_WAGON then
			numNew := numNew + 1;
		elseif tiType = self.EXISTING_TI_ON_WAGON then
			numExisting := numExisting + 1;
		endif;	
	endforeach;
	
	//Because entering a completely new container is valid, the following will make sure
	//that if they enter the ID of an existing container INCORRECTLY, that it won't just blow it away
	//and create a new one with the wrong ID and terminal default values. 
	//In other words, the number of ID matches must equal the number of containers already on the wagon
//PAR 19710 	realWagon := self.myTerminal.allWagons[_dtoWagon.wagonID];
	if _dtoWagon.myTrain &lt;&gt; null then
		realWagon := _dtoWagon.myTrain.allWagonsByIdInward[_dtoWagon.wagonID];
	endif;

	if realWagon &lt;&gt; null then
		create tiArray transient;
		realWagon.getAllTrackedItems(true, tiArray, false);
		if numExisting &lt;&gt; tiArray.size then
			self.addError(Numbe_conta_enter_that_match_e, app.getErrorString2(Numbe_conta_enter_that_match_e, numExisting.String, tiArray.size.String), _errorMsgs); //- cnwmd1, Par 20524
			return;
		endif;
	endif;
	
		
epilog
	delete tiArray;
end;


</source>
        <access>protected</access>
        <Parameter name="_dtoWagon" type="DTO_Wagon"/>
        <Parameter name="_errorMsgs" type="DTO_HandHeldGateErrorDict" usage="input"/>
    </JadeMethod>
    <JadeMethod name="buildWagonForInwards" id="2f2baf51-322d-4f60-9b8a-f504b9a84cf9">
        <source>buildWagonForInwards(_dtoWagon 		 : DTO_Wagon;
					_wagonUpdateCtrl : CMIF_WagonUpdateController input;
					_errorMsgs 		 : DTO_HandHeldGateErrorDict input) protected;
/*
----------   ----------  --------------------------------------------------
Created:	02 November 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
02 Oct 2020  cnwma1 	 ChangeRequest 50112: ASPA - GCI Stevedores	
----------   ----------  --------------------------------------------------
*/
vars
	pxyWagon,
	realWagon			: CM_Wagon;
	tiArray				: CM_TIArray;
	numConfirmed		: Integer;
	error				: CM_Error;
	wagonClassStr	 	: String;
	wagonClass			: CM_WagonClass;
begin
	//create and set proxy wagon////////////////////////////////////////

// PAR 19710 	realWagon := self.myTerminal.allWagons[_dtoWagon.wagonID, null];
	//14 Oct 2009	NDL	Par 21123
	if _dtoWagon.myTrain = null then
		self.addError(Train_selected_NO, app.getErrorString(Train_selected_NO), _errorMsgs);
		return;
	endif;
	realWagon := _dtoWagon.myTrain.allWagonsByIdInward[_dtoWagon.wagonID];
	
	_wagonUpdateCtrl.ignoreTIsAlreadyOnsite := true;
	_wagonUpdateCtrl.confirmWagonInwards := true;
	
	if realWagon = null then//create it
		//create pxyWagon transient;
		create pxyWagon as _dtoWagon.myWagonClass.getWagonVisitClassToCreate() transient;	//15 Mar 2013	NDL	Par 31278
		_wagonUpdateCtrl.mode := Mode_Add;
		_wagonUpdateCtrl.myProxyWagon 	:= pxyWagon;//associate immediately to ensure subsiquent deletion (in epilog of calling method)
	else
		pxyWagon := realWagon.pxyCreateUpdateProxy();
		_wagonUpdateCtrl.myProxyWagon 	:= pxyWagon;//associate immediately to ensure subsiquent deletion (in epilog of calling method)
		_wagonUpdateCtrl.mode := Mode_Update;
		_wagonUpdateCtrl.expectedEditionWagon := realWagon.edition;
		
		//check that the number confirmed is not less than the number phyically present
		//it can be more (we create new cargo) but shouldn't ever be less as that would blow away the exisiting containers
		create tiArray transient;
		realWagon.getAllTrackedItems(true, tiArray, false);
		numConfirmed := _dtoWagon.getNumConfirmed;
		if tiArray.size &gt; numConfirmed then
			self.addError(There_conta_curre_this_wagon_h, app.getErrorString2(There_conta_curre_this_wagon_h,tiArray.size.String, numConfirmed.String), _errorMsgs);
			return;
		endif;
	endif;
	
	if _wagonUpdateCtrl.mode = Mode_Add then // PAR 20992
		//th2 added 2/07/2007 for PAR 14374 - moved wagon validation outside the wagon setProxy
		//as this was raising an error, which is at this point unhandled
		//wagonClassStr := app.myPassport.myTerminal.getWagonClassFromId(_dtoWagon.wagonID);

		// PAR 23542 - moved the wagon class stuff inside for new only, if updating then will already have a wagon class
		wagonClassStr := app.myRoot.getWagonClassViaHookCode(app.myPassport.myTerminal,_dtoWagon.wagonID,null); //20 Jul 2009 NDL CCMS 1067
		if wagonClassStr = null then
			self.addError(ERR_INVALID_WAGONNO, app.getErrorString1(ERR_INVALID_WAGONNO, _dtoWagon.wagonID), _errorMsgs);
			return;
		endif;
		wagonClass := app.myRoot.allWagonClasses[wagonClassStr];
		if wagonClass = null then
			self.addError(ERR_KEY_NOT_FOUND, app.getErrorString2(ERR_KEY_NOT_FOUND, wagonClassStr, "Wagon Classes"), _errorMsgs);
			return;
		endif;
	endif;
	
	pxyWagon.setProxy(self.myTerminal, 
					_dtoWagon.wagonID, 
					_dtoWagon.myWagonClass, 
					_dtoWagon.myTrain,
					_dtoWagon.myTrain, 
					null, 
					null, 
					null, 
					null, 
					null,
					null,    	//02.10.2020 cnwma1 TFS #50112
					null);      //02.10.2020 cnwma1 TFS #50112 
	
	if not app.myPassport.allErrors.isEmpty then
		foreach error in app.myPassport.allErrors do
			self.addError(error.errorCode,error.text, _errorMsgs);
		endforeach;
		app.myPassport.createAlertsFromErrors(EVENT_AT_HandHeldAlert, self.myRTDevice);
		return;
	endif;
		
	_wagonUpdateCtrl.setBasicDetails(	_wagonUpdateCtrl.mode,	//_mode : Integer;
										_dtoWagon.myRailLine,	//_rake : CM_RailLine;
										_dtoWagon.myTrain,	//_train : CM_Train;
										_dtoWagon.position,	//_wagonPosition : Integer
										false//_trainMode : Boolean;
										);
	
epilog
	delete tiArray;
end;


</source>
        <access>protected</access>
        <Parameter name="_dtoWagon" type="DTO_Wagon"/>
        <Parameter name="_wagonUpdateCtrl" type="CMIF_WagonUpdateController" usage="input"/>
        <Parameter name="_errorMsgs" type="DTO_HandHeldGateErrorDict" usage="input"/>
    </JadeMethod>
    <JadeMethod name="buildWagonPositionsForInwards" id="e028aeb6-5ce3-472c-a07e-8f08146010c8">
        <source>buildWagonPositionsForInwards(_dtoWagon 		: DTO_Wagon;
						_wagonUpdateCtrl : CMIF_WagonUpdateController input) protected;
/*
----------   ----------  --------------------------------------------------
Created:	02 November 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	pos,
	wagonLength			: Integer;
	pxyTI				: CM_TrackedItem;
	dtoWagonPos			: DTO_WagonPosition;
	wagonPosition		: CMIF_TIWagonPosition;
	tis : CM_TIArray;	//14 Oct 2014	NDL	Par 35040

begin

	create tis transient;	//14 Oct 2014	NDL	Par 35040
	//////////////////////////////////////////////////////////////////////////
	//create CMIF_Wagon positions - one for each 10ft pos/////////////////////
	wagonLength := _dtoWagon.myWagonClass.getLenInUnits;	
	foreach pos in 1 to wagonLength do : wagonPosLoop
	
		pxyTI := null;
		tis.clear();	//14 Oct 2014	NDL	Par 35040
		//th2 - slightly ugly loop here, but less than 10 items so doesn't warrent dict by position at this stage
		//find the dtoWagonPosition that relates to pos

		foreach dtoWagonPos in _dtoWagon.allDTOWagonPositions do : dtoWagonPosLoop
			if dtoWagonPos.position = pos then
				pxyTI := dtoWagonPos.myDTOContainer.myPxyTrackedItem;
				
				if CM_Container.hasInstance(pxyTI) then
					_wagonUpdateCtrl.allTrackedItems.add(pxyTI);
				endif;
	
				break dtoWagonPosLoop;
			endif;
		endforeach;
		
		create wagonPosition transient;
		tis.add(pxyTI);	//14 Oct 2014	NDL	Par 35040
		wagonPosition.setDetails(true, true, pos, _dtoWagon.myRailLine, tis);	//14 Oct 2014	NDL	Par 35040
		_wagonUpdateCtrl.allWagonPositions.add(wagonPosition);
		
	
	endforeach;

epilog
	//14 Oct 2014	NDL	Par 35040
	delete tis;
	
end;


</source>
        <access>protected</access>
        <Parameter name="_dtoWagon" type="DTO_Wagon"/>
        <Parameter name="_wagonUpdateCtrl" type="CMIF_WagonUpdateController" usage="input"/>
    </JadeMethod>
    <JadeMethod name="createHandHeldAlert" id="d4c94cf7-3590-419e-a211-b670ac7c8abc">
        <source>createHandHeldAlert(_wagonID, _descr : String);
/*
----------   ----------  --------------------------------------------------
Created:	15 September 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	wagon			: CM_Wagon;
	linkedObj		: CM_Object;
begin
// PAR 19710	wagon := self.myTerminal.allWagons[_wagonID, null];
	wagon := self.myTerminal.getLatestWagonByCode(_wagonID);
	
	if wagon &lt;&gt; null then
		linkedObj := wagon.allRailJobs.first;
	endif;
	
	if linkedObj = null then
		linkedObj := self.myRTDevice;	
	endif;
	
	if app.myPassport.myTerminal = null then
		app.myPassport.setMyTerminal(self.myTerminal);
	endif;
	
	app.myPassport.createAlert(SEVERE_ERROR, 
				'Sent from hand held ' &amp; self.myRTDevice.id &amp; ': ' &amp; _descr,
				EVENT_AT_HandHeldAlert,
				linkedObj);
	
	beginTransaction;
	app.commitAlert();
	commitTransaction;

end;


</source>
        <Parameter name="_wagonID" type="String"/>
        <Parameter name="_descr" type="String"/>
    </JadeMethod>
    <JadeMethod name="doAcceptWagonInwards" id="24702ecb-090c-42da-b1ee-be166f882de1">
        <source>doAcceptWagonInwards(	_dtoWagon : DTO_Wagon;
						_insertNewWagon  : Boolean;
						_errorMsgs 	: DTO_HandHeldGateErrorDict input);
/*
----------   ----------  --------------------------------------------------
Created:	30 October 2006 By cnwth2

Purpose:	The confirmation process here is slightly different from the outwards rail and gate confirmation
			in that we are not just comparing the entered data against the database and raising errors,
			we are potentially creating new containers, or if an id matches, updating it.
			
			If an existing id matches and the wagon position is different, we'll move the container.
			If there's a wagon position conflict between existing and new containers we just display 
			error messages.

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
	
vars
	
	realWagon			: CM_Wagon;
	dtoWagon			: DTO_Wagon;
	dtoWagonPos			: DTO_WagonPosition;
	wagonUpdateCtrl 	: CMIF_WagonUpdateController;
	error				: CM_Error;
	loadState			: Boolean;
	deleteSet			: CM_ObjectSet;
	sessionInfo			: CM_String;
begin
	app.cmsBeginLoad(loadState);
	app.myPassport.clearErrorsWarnings; //epr 17258 1/7/08 this is only cleared in transaction initialisation but checked in validateWagonForInwards etc
	self.initialiseForNewRequest(_errorMsgs);  //cnwjo3 par 24636
	create wagonUpdateCtrl transient;
	//th2 after discussion with AKB - up to controller to autoplan
	wagonUpdateCtrl.doAutoPlan := false;
	//build transient structures and validate everything///////////////////////
	self.validateWagonForInwards(_dtoWagon, _errorMsgs);
	if (not _errorMsgs.isEmpty) then
		return;
	endif;
	
	self.buildWagonForInwards(_dtoWagon, wagonUpdateCtrl, _errorMsgs);
	if (not _errorMsgs.isEmpty) then
		return;
	endif;
	
	self.buildTIsForInwards(_dtoWagon, _errorMsgs);
	//th2 on 29/06/2007 for PAR#14359 - somehow it can get here and the dtoWagon still has no wagon class
	//and no errors are raised. Could not reproduce this, but put this in anyway
	if _dtoWagon.myWagonClass = null then
		//self.addError(Full_Replacement_Message, 'Unrecognised wagon class (' &amp; _dtoWagon.wagonID &amp; ')', _errorMsgs);//- cnwmd1, Par 20524
		self.addError(Unrecognis_wagon_class, _dtoWagon.wagonID, _errorMsgs); 
		
	endif;
	
	if (not _errorMsgs.isEmpty) then
		return;
	endif;
	
	self.buildWagonPositionsForInwards(_dtoWagon, wagonUpdateCtrl);
	
	//////////////////////////////////////////////////////////////////////////
	//drop locks and call trx/////////////////////////////////////////////////
	app.cmsEndLoad(loadState);
	//app.myPassport.setWarningsIgnored(true);
//wagonUpdateCtrl.allWagonPositions.inspectModal;
	if wagonUpdateCtrl.mode = Mode_Add then
		wagonUpdateCtrl.insertWagon:=_insertNewWagon;
		app.myTrxCA.trxCreateWagonFromCMIF(wagonUpdateCtrl, realWagon, false, app.myPassport);
	elseif wagonUpdateCtrl.mode = Mode_Update then	
		
		realWagon:=wagonUpdateCtrl.myProxyWagon.pxyGetRealObject;
		app.myTrxUA.trxUpdateWagonFromCMIF(wagonUpdateCtrl, false, app.myPassport);
	endif;
	app.cmsEndLoad(loadState);

	if (not app.myPassport.trxCompletedOK) then
		//turn the errors into alert for the controller 
		//AND turn then into errors to be passed back to the hand held
		foreach error in app.myPassport.allErrors do
			self.addError(error.errorCode,error.text, _errorMsgs);
		endforeach;
		app.myPassport.createAlertsFromErrors(EVENT_AT_HandHeldAlert, self.myRTDevice);
		
	endif;

	dtoWagon:=_dtoWagon;
	dtoWagon.myWagon:=realWagon;
	//sessionInfo:=self.allSessionUpdates.getAtKey[ 		]
	//self.allSessionUpdates.add( wagonUpdateCtrl.myRailLine.getOidString,realWagon.getOidString);
epilog


	delete wagonUpdateCtrl.myProxyWagon;
	//epr 17258 1/7/08  are deleted on destructor for myDTOContainer don't delete here
	
	
	if wagonUpdateCtrl &lt;&gt; null then
		wagonUpdateCtrl.allWagonPositions.purge();
	//	wagonUpdateCtrl.allTrackedItems.purge();
	endif;
	
	delete wagonUpdateCtrl;
	
	app.cmsEndLoad(loadState);

end;


</source>
        <Parameter name="_dtoWagon" type="DTO_Wagon"/>
        <Parameter name="_insertNewWagon" type="Boolean"/>
        <Parameter name="_errorMsgs" type="DTO_HandHeldGateErrorDict" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doAcceptWagonOutwards" id="af494c03-761e-409b-8b08-82f9d7191a50">
        <source>doAcceptWagonOutwards(_dtoWagon : DTO_Wagon;
				_errorMsgs 	: DTO_HandHeldGateErrorDict input);
/*
----------   ----------  --------------------------------------------------
Created:	30 October 2006 By cnwth2

Purpose:	The confirmation process here is slightly different from the outwards rail and gate confirmation
			in that we are not just comparing the entered data against the database and raising errors,
			we are potentially creating new containers, or if an id matches, updating it.
			
			If an existing id matches and the wagon position is different, we'll move the container.
			If there's a wagon position conflict between existing and new containers we just display 
			error messages

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	railJob				: CM_RailJob;
	realWagon 			: CM_Wagon;
	wagonPos 			: DTO_WagonPosition;
	error				: CM_Error;

begin
	self.initialiseForNewRequest(_errorMsgs);  //cnwjo3 par 24636
	
	//validate wagon info////////////////////////////////////////////////
	if _dtoWagon.wagonID = null then
	//	self.addError(REQUIRED_FIELD, app.getErrorString1(REQUIRED_FIELD, 'Wagon ID'), _errorMsgs);
		self.addError(Input_required_field_WgnId, app.getErrorString(Input_required_field_WgnId), _errorMsgs); // cnwdb2	PAR 35364
		return;
	endif;
	
// PAR 19710	realWagon := self.myTerminal.allWagons[_dtoWagon.wagonID];
	realWagon := _dtoWagon.myTrain.allWagonsByIdOutward[_dtoWagon.wagonID];
	
	
	
	if realWagon = null then
		self.addError(1, 'Wagon with id "' &amp; _dtoWagon.wagonID &amp; '" does not match any wagon currently in the terminal.', _errorMsgs);
		return;
	endif;
	
	//app.myPassport.setWarningsIgnored(true);
	app.myTrxUA.trxUpdateWagonConfirmOut(null, realWagon, true, app.myPassport);
	
	foreach wagonPos in _dtoWagon.allDTOWagonPositions do
		self.doConfirmDamage(wagonPos.myDTOContainer,null,null,_errorMsgs);//container,damageRemarks,damageDict,errorMsgs
	endforeach;
	if (not app.myPassport.trxCompletedOK) then
		//turn the errors into alert for the controller 
		//AND turn then into errors to be passed back to the hand held
		foreach error in app.myPassport.allErrors do
			self.addError(error.errorCode,error.text, _errorMsgs);
		endforeach;
		app.myPassport.createAlertsFromErrors(EVENT_AT_HandHeldAlert, self.myRTDevice);
	endif;


end;


</source>
        <Parameter name="_dtoWagon" type="DTO_Wagon"/>
        <Parameter name="_errorMsgs" type="DTO_HandHeldGateErrorDict" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doConfirmContainerInwards" id="f35406fd-1239-4f14-b5dd-0216b99cfd36">
        <source>doConfirmContainerInwards(_dtoWagon 	: DTO_Wagon;
						_wagonPos		: DTO_WagonPosition input;
						_errorMsgs 		: DTO_HandHeldGateErrorDict input);
/*
----------   ----------  --------------------------------------------------
Created:	13 September 2006 By cnwth2

Purpose:	Because we are potentially updating the database to reflect what they have 
			entered here (rather than just checking it matches with the database) the information
			can't really be wrong - just defficient. Therefore we just check they've entered an id and
			an ISO type - thats it.
			The TIs get created when the click 'Accept' button (which calls doAcceptWagonInwards)

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	realTI				: CM_TrackedItem;
	backEndWagonPos		: DTO_WagonPosition;
	wagonIdx			: Integer;
begin
	if _wagonPos = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Null DTO_WagonPosition object passed in.');
		return;
	endif;
	
	if _wagonPos.myDTOContainer.containerId = null then	
		//self.addError(REQUIRED_FIELD, app.getErrorString1(REQUIRED_FIELD, 'Container ID'), _errorMsgs);
		//treat as awaiting info
		_wagonPos.myDTOContainer.isoTypeCode 	:= null;
		_wagonPos.myDTOContainer.customsSeal	:= null;
		_wagonPos.myDTOContainer.operatorSeal	:= null;
		_wagonPos.myDTOContainer.shipperSeal	:= null;
		_wagonPos.myDTOContainer.hazardousChecked := false;
		_wagonPos.myDTOContainer.damageRemarks 	:= null;
		
		_wagonPos.myDTOContainer.confirmed 		:= false;
		_wagonPos.myDTOContainer.hadErrors 		:= false;
		return;
	endif;
	
	if _wagonPos.myDTOContainer.isoTypeCode = null then
	//	self.addError(REQUIRED_FIELD, app.getErrorString1(REQUIRED_FIELD, 'ISO Type'), _errorMsgs);
		self.addError(Input_required_field_IsoType, app.getErrorString(Input_required_field_IsoType), _errorMsgs);
		
		

	endif;
	
	if (not _wagonPos.myDTOContainer.hazardousChecked) then
		self.addError(Err_HazCheck_Required, app.getErrorString1(Err_HazCheck_Required, _wagonPos.myDTOContainer.containerId), _errorMsgs);
	endif;
	
	wagonIdx :=  _dtoWagon.allDTOWagonPositions.indexOf(_wagonPos);
	if _dtoWagon.allDTOWagonPositions.size &gt; wagonIdx then
		backEndWagonPos := _dtoWagon.allDTOWagonPositions[wagonIdx + 1,1];
		backEndWagonPos.isBackEnd := _wagonPos.myDTOContainer.is40;
		backEndWagonPos.setButtonCaption();
	endif;
	
	self.getValidContainerInwards(_wagonPos);
	
	
	
	
epilog
	if _wagonPos.myDTOContainer &lt;&gt; null then
		_wagonPos.myDTOContainer.confirmed := _errorMsgs.isEmpty;
		_wagonPos.myDTOContainer.hadErrors := not _errorMsgs.isEmpty;
	endif;
end;


</source>
        <Parameter name="_dtoWagon" type="DTO_Wagon"/>
        <Parameter name="_wagonPos" type="DTO_WagonPosition" usage="input"/>
        <Parameter name="_errorMsgs" type="DTO_HandHeldGateErrorDict" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doConfirmContainerOutwards" id="e7d36f7e-bd44-42cf-bec2-56693736bec5">
        <source>doConfirmContainerOutwards(_dtoWagon 	: DTO_Wagon;
						_wagonPos	: DTO_WagonPosition input;
						_errorMsgs 		: DTO_HandHeldGateErrorDict input);
/*
----------   ----------  --------------------------------------------------
Created:	13 September 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	container	: CM_Container;
	loopTi,
	realTI		: CM_TrackedItem;
	realWagon	: CM_Wagon;
	tiArray		: CM_TIArray;
	backEndWagonPos		: DTO_WagonPosition;
	
begin
	if _wagonPos.myDTOContainer = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Null DTO_ContainerInfo object passed in.');
		return;
	endif;
	
	if _wagonPos.myDTOContainer.containerId = null then	
		//self.addError(REQUIRED_FIELD, app.getErrorString1(REQUIRED_FIELD, 'Container ID'), _errorMsgs);
		//treat as awaiting info
		_wagonPos.myDTOContainer.isoTypeCode 	:= null;
		_wagonPos.myDTOContainer.customsSeal	:= null;
		_wagonPos.myDTOContainer.operatorSeal	:= null;
		_wagonPos.myDTOContainer.shipperSeal	:= null;
		_wagonPos.myDTOContainer.hazardousChecked := false;
		_wagonPos.myDTOContainer.damageRemarks 	:= null;
		
		_wagonPos.myDTOContainer.confirmed 		:= false;
		_wagonPos.myDTOContainer.hadErrors 		:= false;
		return;
	endif;
	
	self.getValidContainerOutwards(_dtoWagon,_wagonPos,_errorMsgs);
	if (not _errorMsgs.isEmpty) then
		return;
	endif;	
	
	
	if _wagonPos.myDTOContainer.myRealTrackedItem = null then
		self.addError(Err_ID_No_Match, app.getErrorString1(Err_ID_No_Match, _wagonPos.myDTOContainer.idx.String), _errorMsgs);
	else
	
		//_wagonPos.myDTOContainer.myRealTrackedItem := realTI;
		if (not _wagonPos.myDTOContainer.hazardousChecked) then
			self.addError(Err_HazCheck_Required, app.getErrorString1(Err_HazCheck_Required, _wagonPos.myDTOContainer.containerId), _errorMsgs);
		endif;
		
		if _dtoWagon.allDTOWagonPositions.size &gt; _wagonPos.position then
			backEndWagonPos := _dtoWagon.allDTOWagonPositions[_wagonPos.position + 1,1];
			backEndWagonPos.isBackEnd := _wagonPos.myDTOContainer.is40;
			backEndWagonPos.setButtonCaption();
		endif;
		
	endif;
	
	if _wagonPos.myDTOContainer &lt;&gt; null then
		_wagonPos.myDTOContainer.confirmed := (_wagonPos.myDTOContainer.myRealTrackedItem &lt;&gt; null and _errorMsgs.isEmpty);
		_wagonPos.myDTOContainer.hadErrors := not _errorMsgs.isEmpty;
	endif;
	
epilog
	delete tiArray;
end;</source>
        <Parameter name="_dtoWagon" type="DTO_Wagon"/>
        <Parameter name="_wagonPos" type="DTO_WagonPosition" usage="input"/>
        <Parameter name="_errorMsgs" type="DTO_HandHeldGateErrorDict" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doConfirmDamage" id="04d39ba0-684c-4c5a-b616-0249338e616c">
        <source>doConfirmDamage(_containerInfo: DTO_ContainerInfo; _damageRemarks: String; _damageDict: CM_DamageInstanceByDmgePos/*CM_DamageInstanceByLocDict*/; _errorMsgs: DTO_HandHeldGateErrorDict input);
/*

Purpose:			


Return Value:		


Date		Who		Reason
23 November 2007	cnwer1	Initial creation - PAR#xxxx
26/08/2009 			cnwsh3 	CCMS SFW1066 PAR20321 - Recording Damage Details Changes.
					Changed the method signature to use CM_DamageInstanceByDmgePos
*/
vars

	pxyTI : CM_TrackedItem;
	error			: CM_Error;
begin
	self.initialiseForNewRequest(_errorMsgs);  //cnwjo3 par 24636
	
	//inheritMethod(_containerInfo, _damageRemarks, _damageDict, _errorMsgs);
	pxyTI:=_containerInfo.myPxyTrackedItem;
	
	if pxyTI = null then
		return;
	endif;
	
	if _containerInfo.damageRemarks &lt;&gt; null then
		pxyTI.setRemarks(_containerInfo.damageRemarks, true);//add to existing remarks
	endif;
	//might be actually setting damaged to false here
	// 26/08/2009 	cnwsh3 		CCMS SFW1066 PAR20321 - Recording Damage Details Changes.
	//pxyTI.setDamaged(_containerInfo.damageRemarks &lt;&gt; null or (not pxyTI.allDamageInstances.isEmpty));
	pxyTI.setDamaged(_containerInfo.damageRemarks &lt;&gt; null or (not pxyTI.allDamageInstancesByPos.isEmpty));
	
	//app.myPassport.setWarningsIgnored(true);
	app.myTrxUA.trxUpdateTIDamage(pxyTI, app.myPassport);
	
	self.createErrorsFromPassport(_errorMsgs);


epilog

end;</source>
        <Parameter name="_containerInfo" type="DTO_ContainerInfo"/>
        <Parameter name="_damageRemarks" type="String"/>
        <Parameter name="_damageDict" type="CM_DamageInstanceByDmgePos"/>
        <Parameter name="_errorMsgs" type="DTO_HandHeldGateErrorDict" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doGetWagonDetailsIn" id="97c70cfd-7d7c-4b1b-b99f-e7cf09adb95f">
        <source>doGetWagonDetailsIn(_dtoWagon	: DTO_Wagon input;
					_infoStr	: String output);
/*
----------   ----------  --------------------------------------------------
Created:	13 September 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	wagon			: CM_Wagon;
	dtoWagonPos		: DTO_WagonPosition;
	dtoContainer	: DTO_ContainerInfo;
	
	wagonClassStr 	: String;
	wagonClass		: CM_WagonClass;
	idx,
	lengthUnit,
	stackHeight,
	maxStackHeight : Integer;
	wagonController	: CM_WagonController;
	ti				: CM_TrackedItem;

	isPrevios40			: Boolean;
	dtoWagonsToDelete : ObjectSet;
begin

	// PAR 19710
	if _dtoWagon.myTrain = null then
		_infoStr := ': unrecognised train';
		return;
	endif;

	create dtoWagonsToDelete transient;
	//_dtoWagon.allDTOWagonPositions.copy(dtoWagonsToDelete);
	//_dtoWagon.allDTOWagonPositions.purge();
	
	
	if _dtoWagon.wagonID &lt;&gt; null then
// PAR 19710 		wagon := self.myTerminal.allWagons[_dtoWagon.wagonID];
		wagon := _dtoWagon.myTrain.allWagonsByIdInward[_dtoWagon.wagonID];	
	elseif _dtoWagon.position &gt; 0 and _dtoWagon.myRailLine &lt;&gt; null then
		if _dtoWagon.position &gt; _dtoWagon.myRailLine.allWagons.size then
			_infoStr := 'No wagon in that position';
		
			return;
		else
			wagon:= _dtoWagon.myRailLine.allWagons[_dtoWagon.position];
			if wagon &lt;&gt; null then
				_dtoWagon.myTrain:=wagon.myTrainInwards;
			endif;
		endif;
	endif;
	
	
	if wagon = null then
		//wagonClassStr := self.myTerminal.getWagonClassFromId(_dtoWagon.wagonID);
		wagonClassStr := app.myRoot.getWagonClassViaHookCode(self.myTerminal,_dtoWagon.wagonID,null); //20 Jul 2009 NDL CCMS 1067
		wagonClass := app.myRoot.allWagonClasses[wagonClassStr];
		if wagonClass = null then
			_infoStr := '"' &amp; wagonClassStr &amp; '" is an unrecognised wagon class';
			return;
		endif;
		_dtoWagon.myWagonClass := wagonClass;
		_infoStr := '"' &amp; _dtoWagon.wagonID &amp; '": new wagon';
	else
		
		_dtoWagon.setMyWagon(wagon);
		_dtoWagon.myTrain		:= wagon.myTrainInwards;
		_dtoWagon.position 		:= wagon.getMyPosition();	
		if wagon.myRailLine &lt;&gt; null then
			_dtoWagon.myRailLine 	:= wagon.myRailLine;
		endif;
		_infoStr := '"' &amp; _dtoWagon.wagonID &amp; '": existing wagon';
	endif;	
		
	stackHeight:=1;
	wagonClass:=_dtoWagon.myWagonClass;

	_dtoWagon.buildDTOWagonPositions();
	return;
	//Based on the wagon class length, generate available slots for the containers.
	//N/B. the following basically ignores the 'number20s' and 'number40s' on wagon class
	//because it's for the handheld. Assumes every location is a 10ft slot, so effectivly
	//skipping every second one to get each new container, although it still checks 
	//that the location following is not the 10ft backend of a 40ft.
	idx := null;
	foreach lengthUnit in 1 to wagonClass.getLenInUnits step 2 do
		stackHeight:=1;
		if lengthUnit + 1 &gt; wagonClass.getLenInUnits then
			//there's only one 10ft slot left - doesn't qualify as a valid container pos
			break;
		endif;
		idx := idx + 1;
		
		dtoWagonPos:=_dtoWagon.getDTOWagonPosition(idx,stackHeight);
		if dtoWagonsToDelete.includes(dtoWagonPos) then
			dtoWagonsToDelete.remove(dtoWagonPos);
		endif;
		
	/*	dtoWagonPos:=_dtoWagon.allDTOWagonPositions[idx,stackHeight];
		if dtoWagonPos = null then
			create dtoWagonPos transient;
		endif;
		
		if dtoWagonsToDelete.includes(dtoWagonPos) then
			dtoWagonsToDelete.remove(dtoWagonPos);
		endif;
		dtoContainer:=dtoWagonPos.myDTOContainer;
		if dtoContainer &lt;&gt; null and wagon = null then
			delete dtoContainer;
		endif;
		if dtoContainer = null  then
			create dtoContainer transient;
		endif;
	
		
		dtoWagonPos.idx := idx;
		dtoContainer.idx := idx;
		dtoWagonPos.myDTOWagon := _dtoWagon;
		dtoWagonPos.myDTOContainer := dtoContainer;
		dtoWagonPos.stackHeight:=1;
			*/
			
		dtoWagonPos.position := lengthUnit;
		dtoWagonPos.isBackEnd:=isPrevios40;
		
		isPrevios40:=false;
		//also poulate with existing TI if there is one at the location
		if wagon &lt;&gt; null and 
		   (not wagon.allLocationsControllersArray.isEmpty) and
		   (wagon.allLocationsControllersArray.size &gt;= lengthUnit) then
			wagonController := wagon.allLocationsControllersArray[lengthUnit];
			if wagonController &lt;&gt; null then
				
				while stackHeight &lt;= wagonClass.maxNumInStack do
					//get the DTO wagon position
					if wagonController.allTrackedItems.size &lt; stackHeight then
						//create empty position
						
					else
					
					endif;
					
					ti := wagonController.allTrackedItems.first;
					if ti &lt;&gt; null and 
					   ti.myPrimaryActualLocation = wagonController then //check that it's not a 'backend'
						dtoContainer.setMyRealTrackedItem(ti);
	
						isPrevios40:=ti.isForty;
						if dtoContainer.containerId &lt;&gt; null and dtoContainer.myPxyTrackedItem &lt;&gt; null and 
							ti.id	 = dtoContainer.containerId  then
							continue;
						endif;
						dtoContainer.setSelfFromTI;
				
						dtoContainer.myPxyTrackedItem.setPxyForRailHandHeld(dtoContainer.containerId,
													dtoContainer.isoTypeCode,
													dtoContainer.customsSeal,
													dtoContainer.operatorSeal,
													dtoContainer.shipperSeal,
													dtoContainer.allDamageInstancesByDmgePos);
													// 26/08/2009 	cnwsh3 		CCMS SFW1066 PAR20321 - Recording Damage Details Changes.
													
													
					else
						if dtoContainer.containerId &lt;&gt; null then
							delete dtoWagonPos.myDTOContainer;
							create dtoWagonPos.myDTOContainer transient;
						endif;
					
					endif;
					stackHeight:=stackHeight+1;
				endwhile;
				
			endif;
		endif;		
		
		
			
		
		
	endforeach;
	
	
epilog
	if dtoWagonsToDelete &lt;&gt; null then
		dtoWagonsToDelete.purge;
		delete dtoWagonsToDelete;
	endif;
end;


</source>
        <Parameter name="_dtoWagon" type="DTO_Wagon" usage="input"/>
        <Parameter name="_infoStr" type="String" usage="output"/>
    </JadeMethod>
    <JadeMethod name="doGetWagonDetailsOut" id="127fe5d1-bcb0-4d44-bec2-ddaed991e7af">
        <source>doGetWagonDetailsOut(_dtoWagon	: DTO_Wagon input;
					_infoStr	: String output);
/*
----------   ----------  --------------------------------------------------
Created:	13 September 2006 By cnwth2

Purpose:	If a matching wagonID is entered, create data transfer wagon position transients
			foreach 20ft container position on the wagon (calulated from the number of 10ft slots for 
			the wagon class.

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	wagon			: CM_Wagon;
	dtoWagonPos		: DTO_WagonPosition;
	dtoContainer	: DTO_ContainerInfo;
	wagonClass		: CM_WagonClass;
	idx,
	lengthUnit		: Integer;
	wagonController	: CM_WagonController;
	ti				: CM_TrackedItem;
begin

	// PAR 19710
	if _dtoWagon.myTrain = null then
		_infoStr := ': unrecognised train';
		return;
	endif;

	_dtoWagon.allDTOWagonPositions.purge();
	
	
	
// PAR 19710	wagon := self.myTerminal.allWagons[_dtoWagon.wagonID];
	wagon := _dtoWagon.myTrain.allWagonsByIdOutward[_dtoWagon.wagonID];
	
	if wagon = null then
		if _dtoWagon.position &gt; 0 and _dtoWagon.myRailLine &lt;&gt; null then
			if _dtoWagon.position &gt; _dtoWagon.myRailLine.allWagons.size then
				_infoStr := 'No wagon in that position';
			
				return;
			else
				wagon:= _dtoWagon.myRailLine.allWagons[_dtoWagon.position];
				if wagon &lt;&gt; null then
					if wagon.myTrainOutwards = null or wagon.myTrainOutwards &lt;&gt; _dtoWagon.myTrain then
						_infoStr := 'No outward wagon in that position for this train';
						wagon:=null;
					endif;
					//epr par 23666 14/4/10
					/*if wagon &lt;&gt; null then
						if wagon &lt;&gt; null and not wagon.confirmedOutwards then
							wagon:=null;
						endif;
					endif;*/
				endif;
			endif;
			
		
		endif;
			
		
	endif;
	if wagon = null then
		_infoStr := '"' &amp; _dtoWagon.wagonID &amp; '": unrecognised wagon';
		return;
	endif;
	
	
	_infoStr := '"' &amp; _dtoWagon.wagonID &amp; '": existing wagon';
	_dtoWagon.setMyWagon(wagon);
	_dtoWagon.position := wagon.getMyPosition();
	wagonClass := wagon.myWagonClass;
	
		
	_dtoWagon.myWagonClass := wagonClass;
	//Based on the wagon class length, generate available slots for the containers.
	//N/B. the following basically ignores the 'number20s' and 'number40s' on wagon class
	//because it's for the handheld. Assumes every location is a 10ft slot, so effectivly
	//skipping every second one to get each new container, although it still checks 
	//that the location following is not the 10ft backend of a 40ft.
	idx := null;
	foreach lengthUnit in 1 to wagonClass.getLenInUnits step 2 do
		if lengthUnit + 1 &gt; wagonClass.getLenInUnits then
			//there's only one 10ft slot left - doesn't qualify as a valid container pos
			break;
		endif;
		
		wagonController := wagon.allLocationsControllersArray[lengthUnit];
		if wagonController = null then
			continue;
		endif;
		
		ti := wagonController.allTrackedItems.first;
		if ti &lt;&gt; null and ti.myPrimaryActualLocation &lt;&gt; wagonController then //check that it's not a 'backend'
			continue;
		endif;
		
		create dtoWagonPos transient;
		create dtoContainer transient;
		idx := idx + 1;
		dtoWagonPos.idx 			:= idx;
		dtoContainer.idx 			:= idx;
		dtoWagonPos.myDTOWagon 		:= _dtoWagon;
		dtoWagonPos.myDTOContainer 	:= dtoContainer;
		dtoWagonPos.position 		:= lengthUnit;
		dtoWagonPos.stackHeight:=1;
		
		dtoContainer.setMyRealTrackedItem(ti);
		dtoContainer.setSelfFromTI;
	/*	if ti &lt;&gt; null then
			
			dtoContainer.myPxyTrackedItem.setPxyForRailHandHeld(dtoContainer.containerId,
									dtoContainer.isoTypeCode,
									dtoContainer.customsSeal,
									dtoContainer.operatorSeal,
									dtoContainer.shipperSeal,
									dtoContainer.allDamageInstancesByDmgePos);
		endif;
									// 26/08/2009 	cnwsh3 		CCMS SFW1066 PAR20321 - Recording Damage Details Changes.
								
		*/
		//don't update the dtoContainer attributes from the container as Gdansk wants the user to
		//enter these from scratch and then we confirm they are correct.
		//This situation is different from the inward confirmation where we are potentially updating the database
		//to reflect what they enter
	endforeach;
	
	
end;


</source>
        <Parameter name="_dtoWagon" type="DTO_Wagon" usage="input"/>
        <Parameter name="_infoStr" type="String" usage="output"/>
    </JadeMethod>
    <JadeMethod name="doSetProxyTI" id="376b763f-32c5-405f-a5c5-1d690c303b7c">
        <source>doSetProxyTI(_dtoWagon 	    : DTO_Wagon; //2/07/2009 cnwdz2 20160
			_containerInfo	: DTO_ContainerInfo input;
			_tiType			: Integer output;
			_errorMsgs 		: DTO_HandHeldGateErrorDict input) protected;
/*
----------   ----------  --------------------------------------------------
Created:	13 September 2006 By cnwth2

Purpose:	creates a pxyTI from the data transfer tracked item transient

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	error		: DTO_HandHeldGateError;
	realTI,
	pxyTI		: CM_TrackedItem;
	
	inJob		: Boolean;
	loadState	: Boolean;
	wagonController : CM_WagonController;
begin
	_tiType := self.NO_TI_ON_WAGON;
	if _containerInfo = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Null DTO_ContainerInfo object passed in.');
		return;
	endif;
	
	if _containerInfo.containerId = null then
		//can assume there is no container in this position if they havn't enetered anything
		return;
	endif;

	//cnwjo3 par 24921.  validate defaults have been set up in Terminal Config for Rail TIs
	if _containerInfo.myPxyTrackedItem &lt;&gt; null then
		self.validateTermDefaultSettings(_containerInfo.myPxyTrackedItem,_errorMsgs);
	endif;	
	
	//try to find the ti onsite or notified
	realTI := self.myTerminal.lookupTrackedItem(_containerInfo.containerId, TI_CargoType_Container, TI_STATE_NORMAL, null, false); //PAR 18971 cnwgb1 21.5.09
	if realTI = null then
		realTI := self.myTerminal.lookupTrackedItem(_containerInfo.containerId, TI_CargoType_Container, TI_STATE_NOTIFIED, null, false); //PAR 18971 cnwgb1 21.5.09
	endif;
	
	
	pxyTI:=_containerInfo.myPxyTrackedItem;
	realTI:=_containerInfo.myRealTrackedItem;
	
	if realTI = null then
	//	create pxyTI as CM_Container transient;
		pxyTI.setPxyFromDefaultTI(self.myTerminal, TI_CargoType_Container, _containerInfo.containerId, null, null); 
		_tiType := self.NEW_TI_ON_WAGON;
		pxyTI.changeState(TI_STATE_NORMAL,app.myPassport); // AKB2006NOV
	else
		//epr 20508 29/9/09 could of already created it here and we got an error message
	/*	pxyTI := app.myProxyManager.getProxyObject(realTI).CM_TrackedItem;
		if pxyTI = null then
			pxyTI := app.createUpdateProxy(realTI).CM_TrackedItem;
		endif;*/
		//2/07/2009 cnwdz2 20160
		if realTI.myPrimaryActualLocation = null then
			_tiType := self.NEW_TI_ON_WAGON;
		elseif not realTI.myPrimaryActualLocation.isWagon() then
			_tiType := self.NEW_TI_ON_WAGON;
		else
			wagonController := realTI.myPrimaryActualLocation.CM_WagonController;
			if _dtoWagon.myWagon &lt;&gt; wagonController.myWagon then
				_tiType := self.NEW_TI_ON_WAGON;
			else
				_tiType := self.EXISTING_TI_ON_WAGON;
			endif;
		endif;
		
	endif;

	pxyTI.setPxyForRailHandHeld(_containerInfo.containerId,
								_containerInfo.isoTypeCode,
								_containerInfo.customsSeal,
								_containerInfo.operatorSeal,
								_containerInfo.shipperSeal,
									null);
							//	_containerInfo.allDamageInstancesByDmgePos);
								
								// 26/08/2009 	cnwsh3 		CCMS SFW1066 PAR20321 - Recording Damage Details Changes.
								//_containerInfo.myPxyTrackedItem.allDamageInstances);
							//	_containerInfo.myPxyTrackedItem.allDamageInstancesByPos);

	_containerInfo.myPxyTrackedItem := pxyTI;
	//_containerInfo.allDamageInstances.clear();
	//_containerInfo.myPxyTrackedItem.allDamageInstances.copy(_containerInfo.allDamageInstances);
	
end;</source>
        <access>protected</access>
