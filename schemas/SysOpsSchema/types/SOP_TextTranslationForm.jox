    <JadeMethod name="displayTranslatableText" id="c22fec39-281b-4d3a-9a1a-0dd8e0c62513">
        <updating/>
        <source>displayTranslatableText(table : CM_TextTranslationTable input; _partsDone : Integer io) updating, protected;

vars
	boolean : Boolean;
	translatableText : XLAT_TranslatableText;
	rowIdx : Integer;
//	allTranslatableText : XLAT_TranslatableTextByNumber;
	searchResults: XLAT_SearchResults;

begin
	tblTranslations.rows := tblTranslations.fixedRows;

	// get search results for the category
	searchResults := self.myAgent.allSearchResults[table.myTranslationCategory.constantCategoryName];

	table.rows := table.fixedRows;

	// now populate the table with the results
	foreach translatableText in searchResults.allTranslatableText do
		table.displayTranslatableText(translatableText, 0, colorRow1, colorRow2);
//		zUpdateProgressMonitor(_partsDone);		// cnwrl1 03/11/2009 PAR 21295 - what it was
		// cnwrl1 03/11/2009 PAR 21295 - start of coding
		// if the cancel button has been press then skip the loading of the tables
		boolean	:= zUpdateProgressMonitor(_partsDone);
		if not boolean then
			break;
		endif;
		// cnwrl1 03/11/2009 PAR 21295 - end of coding
		_partsDone := _partsDone + 1;
	endforeach;
	
epilog
// restore table row selections (currently single selection, but could be changed to handle multiple)
	if self.myTranslatableText &lt;&gt; null and table.findObjectInRow(self.myTranslatableText, rowIdx) then
		table.selectRow(rowIdx, false);
	endif;
	self.setSheetCaptions(table.mySheet, self.myLocale);
	self.setSheetFocus();
end;</source>
        <access>protected</access>
        <Parameter name="table" type="CM_TextTranslationTable" usage="input"/>
        <Parameter name="_partsDone" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="displayTranslations" id="1f3779b2-4973-47a9-aa48-e8036b970f6f">
        <updating/>
        <source>displayTranslations()protected, updating;

// Created:	21 Aug 2006 By: RBarr	
// Display each locale defined in the system, with any corresponding translations
// 10 Feb 2015	NDL	Par 33263
// 22/11/2023	navhn30		ChangeRequest 53372: MTN - Improvements to JMTSUPPORT User Abilities

constants
	ShortTextDisplayRatio = 0.3;
	Col_LocaleWidth	= 180;
	MidGray = #888888;
	
vars
	tableObj		: Table;
	remainingWidth 	: Integer;
	translation 	: XLAT_Translation;
	row				: Integer;
	locale			: CM_Locale;
	text			: String;
	constantName	: String;
	shortText		: String;
	i : Integer;
	
begin
	tableObj		:=	tblTranslations;
	tableObj.rows	:=	tableObj.fixedRows;

	// check for deleted object
	if app.isValidObject(self.myTranslatableText) = false or self.myTranslatableText = null then
		return;
	endif;

	tableObj.fixedRows		:=	1;
	tableObj.fixedColumns	:=	1;
	
	if self.myTranslatableText.usesShortText then
		tableObj.columns := Col_ShortText;
	else
		tableObj.columns := Col_Text;
	endif;
	
	tableObj.show3D		:=	Table.Show3D_Not3D;
	tableObj.selectMode	:=	Table.SelectMode_None;
	tableObj.tabStop	:=	false;
	tableObj.fixed3D	:=	false;
	tableObj.rows		:=	tableObj.fixedRows;
	tableObj.setCellText(1, 1, "Locale" &amp; Tab &amp; "Constant (dbl click to copy)"&amp; Tab &amp; "Text" &amp; Tab &amp; "Short Text");
	
	// populate translations table, one row per defined locale
	foreach locale in self.myRoot.allLocales do
		translation	:=	self.myTranslatableText.getTranslationText(locale, constantName, text, shortText);
		row			:=	tableObj.addItem(locale.vLocaleIdAndDescription &amp; Tab &amp; constantName &amp; Tab &amp; text &amp; Tab &amp; shortText);
		tableObj.accessRow(row).itemObject	:=	locale;
		
		if locale.localeId = StandardTextLocaleStr then
			if self.isDeveloperMode then
				tableObj.accessRow(row).foreColor := Blue;
			else
				tableObj.accessRow(row).foreColor := MidGray;
			endif;
		endif;
	endforeach;
	
	
		// set column widths, depending upon whether or not the category uses shortText
/*	tableObj.columnWidth[self.Col_Locale]	:=	Col_LocaleWidth;
	tableObj.columnWidth[self.Col_Constant]	:=	Col_LocaleWidth;
	
	remainingWidth	:=	tableObj.clientWidth - Col_LocaleWidth;
	
	if tableObj.columns = Col_ShortText then
		// split available space between text and short text
		tableObj.columnWidth[Col_ShortText]	:=	(remainingWidth * ShortTextDisplayRatio).rounded;
		tableObj.columnWidth[Col_Text]	:=	remainingWidth - tableObj.columnWidth[Col_ShortText];
	else
		tableObj.columnWidth[Col_Text]	:=	remainingWidth;
	endif; */
		

	// allow user to traverse table in update mode 
	if self.mode = self.Mode_Update then
		setTranslationTableInputType(Table.InputType_TextBox);
	endif;

	tableObj.rowHeight[1]	:=	20;
	
	if not (app.isAllowedToInspect() or app.isDevelopmentSystem()) then
		tableObj.accessColumn(self.Col_Constant).visible	:=	false;			// 22.11.23		navhn30 	#TFS 53372
	endif;
	
end;</source>
