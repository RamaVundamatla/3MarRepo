    <JadeMethod name="initialise" id="561739a3-1579-4c61-a88c-df4f1e585b26">
        <source>initialise(_bank : CM_Bank);

vars
	pgMap : CM_ProductGroupMap;
begin

	pgMap := self.allProductGroupMaps[null]; // default;
	if pgMap = null then
		create pgMap;
		pgMap.setMyProductGroup(null); // default
		pgMap.myCargoTypeMap := self;
	endif;
	pgMap.initialise(_bank);

end;</source>
        <Parameter name="_bank" type="CM_Bank"/>
    </JadeMethod>
    <JadeMethod name="replaceInvoiceLineTypes" id="f747f933-225d-4ebf-983e-7a32547875dc">
        <source>replaceInvoiceLineTypes(_oldILD : CM_InvoiceLineDesc; _newILD : CM_InvoiceLineDesc) : Integer;
// 32311
vars
	count	: Integer;
	groupMap		: CM_ProductGroupMap;
begin
	foreach groupMap in self.allProductGroupMaps do
		count := count + groupMap.replaceInvoiceLineTypes(_oldILD, _newILD);
	endforeach;
	return count;
end;
</source>
        <Parameter name="_oldILD" type="CM_InvoiceLineDesc"/>
        <Parameter name="_newILD" type="CM_InvoiceLineDesc"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="965d9953-bf5f-4beb-a879-c6d24a2a84ff">
        <updating/>
        <source>setForCreate(_pxyTIServiceMap : CM_TIServiceMap) updating;
// ---------------------------------------------------------------------------
// Created:		August 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	_pxyTIServiceMap.raiseExceptionIfNotTransient(method);
	self.raiseExceptionIfTransient(method);
	
	self.className := _pxyTIServiceMap.className;
	self.myCargoType := _pxyTIServiceMap.myCargoType;
	self.transactionMap := _pxyTIServiceMap.transactionMap;
	
	self.initialise(_pxyTIServiceMap.transactionMap.bank);

end;</source>
        <Parameter name="_pxyTIServiceMap" type="CM_TIServiceMap"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="2187f83f-92ab-400e-8d6a-9cf72002e013">
        <updating/>
        <source>setProxy(_className : String; _tranMap : CM_TranMap; _cargoType : CM_CargoType) updating;
