    <JadeMethod name="doGetCurrentSettings" id="f185727d-8d14-4364-943d-be400bd54e4b">
        <updating/>
        <source>doGetCurrentSettings() updating, protected;

/*

Purpose:			Get the current settings from the database.  To allow for picking
					up changes following notifications.


Return Value:		None


Date		Who		Reason
12 Mar 2008	cnwkpd1	PAR #16010 - CCMS Otago 1502 - Thin Client RT Enhancements

*/

vars
	errorStr 				: String;
	sysColorBackGeneral		: Integer;
	sysColorForeGeneral		: Integer;
	sysColorBackTable		: Integer;
	sysColorForeTable		: Integer;
	userColorBackGeneral	: Integer;
	userColorForeGeneral	: Integer;
	userColorBackTable		: Integer;
	userColorForeTable		: Integer;
	portLogo				: Binary;

begin
	app.myRTGuiAgent.getCurrentSettings(sysColorBackGeneral,
										sysColorForeGeneral,
										sysColorBackTable,
										sysColorForeTable,
										userColorBackGeneral,
										userColorForeGeneral,
										userColorBackTable,
										userColorForeTable,
										self.aMachineCode,
										self.aMachineLiftType,
										self.aPrimaryQueueId,
										self.aNumberOfAvailableQEntries,
										self.aCanChangeQueue,
										self.aCanRunSelectorQueries,
										self.aShowNumberOfQueueEntries,
										portLogo,
										self.aState,
										self.aResetState,
										errorStr,
										self.aLastTs,
				   /*
					Date		Who		Reason			
					20 Aug 2008	cnwdz2	Par 17782 CCMS Otago 1722 - Thin Client RT Changes:
				   */
										self.aRTQueueAfterSetdown);
										
										
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doKeyDown" id="710d6b16-0a6c-440c-85f6-0effbbdc711e">
        <updating/>
