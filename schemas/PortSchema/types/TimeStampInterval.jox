<PrimType name="TimeStampInterval">
    <JadeMethod name="asHours" id="c3e45f9b-227a-417a-8d74-a63ac5c3e07f">
        <source>asHours():Real;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
05 April 2012	cnwndl1	Initial creation	Par 29369

*/

vars

	mins : Real;
	hrs : Real;

begin

	mins := self.asMinutes();
	hrs := (mins / 60);

	return hrs;

epilog

end;</source>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="asMinutes" id="5992259f-d251-4bf5-bf2a-daa4d33f7234">
        <source>asMinutes():Real;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
05 April 2012	cnwndl1	Initial creation	Par 29369

*/

vars

	milliSecs : Integer64;

begin

	milliSecs := self.getMilliseconds();
	return ( milliSecs / 60000 );

epilog

end;</source>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="asStringJMT" id="9138d872-bd7c-45d9-8fb6-8b27428e1475">
        <source>asStringJMT() : String;
/* ---------------------------------------------------------------------------
Created:     27 May 2008 by cnwrs2

Purpose:     
    
Date		Who		Reason
------------------------------------------------------------------------------*/
vars

begin
	return self.String;
	
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="asStringJSON" id="d414511f-1743-4d50-a19f-a1dbcc138707">
        <source>asStringJSON() : String;
/*

Purpose:			Return the receiver formatted for JSON

Parameters:			None

Return Value:		JSON string representing the receiver

Date		Who		Reason
14 Feb 2017	cnwkpd1	TFS 3369 - Push Events application

*/

vars

begin
	if self = null then
		return "null";
	else
		return '"' &amp; self.String &amp; '"';
	endif;
	
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="inDaysAndPartOf" id="30a34c1f-8536-449e-9a9c-a3804bdc5094">
        <source>inDaysAndPartOf() : Real;
//
// cnwrs1 par 26283 01 dec 2010
//
vars
	val : Real;
begin
	val := self.getMilliseconds() / (3600.0 * 24.0 * 1000.0);//).Real;
//	write self.String &amp; ' '&amp; val.String;
	return val;
end;
</source>
        <ReturnType type="Real"/>
    </JadeMethod>
</PrimType>
