    <JadeMethod name="markSlotsAsDischargeCC" id="178f2a9b-ac92-4c5a-b155-a0a8c13041b8">
        <source>markSlotsAsDischargeCC(_allSlots : CM_SlotControllerArray; _loadCC : CMIF_LoadColorCode input; _attribute : String);
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17/05/2011	cnwmh5 	Initial creation

*/

vars
	allObjectEditions : CM_ObjectByOidEditionDict;
	slot : CM_SlotController;
begin
	
	create allObjectEditions transient;
	
	foreach slot in _allSlots do
		allObjectEditions.add(slot);
	endforeach;
	
	app.myTrxUA.trxUpdateSlotRequestAttribute(_allSlots, null, false, allObjectEditions, _attribute,  _loadCC, app.myPassport);
	self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());
	
epilog
	
	delete allObjectEditions;

end;</source>
