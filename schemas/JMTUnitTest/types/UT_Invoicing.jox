	_iso.add("4200");
	_comm.add("GENL");
	_ids.add("GENL4X22446");
	_iso.add("4200");
	_comm.add("GENL");
	
	// ### REEFERS, alternate 20 and 40 so if limited, get at least one of each
	_ids.add("REEF2X22334");
	_iso.add("2232");
	_comm.add("REEF");
	_ids.add("REEF4X22334");
	_iso.add("4332");
	_comm.add("REEF");
