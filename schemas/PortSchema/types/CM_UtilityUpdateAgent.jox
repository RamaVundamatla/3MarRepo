    <JadeMethod name="utlUpdateDebtorNode" id="5dfd3876-dc7b-4e29-9371-8f9c17c0311e">
        <source>utlUpdateDebtorNode(_debtorNodeController: CMIF_DebtorNode; _passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:		August 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	proxyDebtorNode, realDebtorNode:CM_DebtorNode;
	expectedEdition:Integer;
	codeChanged:Boolean;
	eventStr : String;
	theTerminal : CM_Terminal;
	
begin

	self.initialiseActivity();
	proxyDebtorNode := _debtorNodeController.myPxyDebtorNode;
	proxyDebtorNode.raiseExceptionIfNotProxy(method);

	app.setContinueCMExceptions(true);

	proxyDebtorNode.pxyGetRealObjectAndEdition(realDebtorNode, expectedEdition);
	
	if realDebtorNode = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_DebtorNode.name, null, null);
		return;
	endif;

	app.myValUA.valDebtorNode(realDebtorNode, proxyDebtorNode);
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);

	exclusiveLock(realDebtorNode);

	if _passport.noErrors and realDebtorNode.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'DebtorNode', null, null);
		return;
	endif;
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realDebtorNode, true);
	endif;
	
	if _passport.noErrors then
		realDebtorNode.setForUpdate(_debtorNodeController);
	endif;

	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realDebtorNode, false);
	endif;
	if _passport.noErrors then
		app.myRoot.causeEvent(EVENT_DEBTORNODE_UPDATE,false,realDebtorNode);
	endif;

end;</source>
        <Parameter name="_debtorNodeController" type="CMIF_DebtorNode"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateDebtorSuspenders" id="86d9faa1-5532-49c7-93ae-85f79fba2f95">
        <source>utlUpdateDebtorSuspenders(_pxyDebtor : CM_DebtorNode; _passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:		August 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	realDebtorNode:CM_DebtorNode;
	expectedEdition:Integer;
	codeChanged:Boolean;
	eventStr : String;
	theTerminal : CM_Terminal;
	
begin

	self.initialiseActivity();
	_pxyDebtor.raiseExceptionIfNotProxy(method);

	app.setContinueCMExceptions(true);

	_pxyDebtor.pxyGetRealObjectAndEdition(realDebtorNode, expectedEdition);
	
	if realDebtorNode = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_DebtorNode.name, null, null);
		return;
	endif;

	app.myValUA.valDebtorNode(realDebtorNode, _pxyDebtor); // PAR 10974 added in
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);

	exclusiveLock(realDebtorNode);

	if _passport.noErrors and realDebtorNode.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'DebtorNode', null, null);
		return;
	endif;
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realDebtorNode, true);
	endif;
	
	if _passport.noErrors then
		if _pxyDebtor.isSuspended then
			realDebtorNode.suspend();
		else
			realDebtorNode.reinstate(false);
		endif;
	endif;

	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realDebtorNode, false);
	endif;
	if _passport.noErrors then
		app.myRoot.causeEvent(EVENT_DEBTORNODE_UPDATE,false,realDebtorNode);
	endif;

end;</source>
        <Parameter name="_pxyDebtor" type="CM_DebtorNode"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateDebtorType" id="82b12571-9721-4a38-84f5-9a44ac900297">
        <source>utlUpdateDebtorType( _proxyDebtorType : CM_DebtorType; 	_passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:	4 April 2008 By Graeme Black cnwgb1
// ---------------------------------------------------------------------------
vars
	cancelSave		: Boolean;
	realDebtorType	: CM_DebtorType;
	expectedEdition	: Integer;
	oldCode			: String;
	oldDesc			: String;
	
begin

	self.initialiseActivity();

	_proxyDebtorType.raiseExceptionIfNotProxy(method);

	app.setContinueCMExceptions(true);

	_proxyDebtorType.pxyGetRealObjectAndEdition(realDebtorType, expectedEdition);
	
	if realDebtorType = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_DebtorType.name, null, null);
		return;
	endif;

	app.myValUA.valDebtorType(realDebtorType, _proxyDebtorType);
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);

	exclusiveLock(realDebtorType);

	if _passport.noErrors and realDebtorType.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'Debtor Type', null, null);
		return;
	endif;
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realDebtorType, true);
	endif;
	
	oldCode := realDebtorType.code;
	oldDesc := realDebtorType.description;
	
	if _passport.noErrors then
		realDebtorType.setForUpdate(_proxyDebtorType);
	endif;
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realDebtorType, false);
	endif;
	
	if _passport.noErrors then
		app.myRoot.debtorTypeQueryPropertyUpdate(realDebtorType, oldCode, oldDesc);
	endif;

	
end;</source>
        <Parameter name="_proxyDebtorType" type="CM_DebtorType"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateDeckItemLayout" id="5b1a8c51-5a97-4314-9ffc-3b299af500df">
        <updating/>
        <source>utlUpdateDeckItemLayout(_pxyItemLayout : CM_DeckItemLayout; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     April 2011 ANDREW BISHOP
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	realObject		: CM_DeckItemLayout;
	expectedEdition	: Integer;

begin

	self.initialiseActivity();
	
	// do any pre-validation locks
	
	// do validation
	self.raiseExceptionIfNull(_pxyItemLayout, 'Proxy Layer is NULL');

	app.setContinueCMExceptions(true);
	
	realObject := self.getRealObjectAndEditionCheck(_pxyItemLayout, 'Deck Item Layout ', _passport).CM_DeckItemLayout;

	if _passport.noErrors then
		// This is only required if the class is being auditted
		//self.myUpdateAuditAgent.audUpdateGeneric(realObject, true);
	endif;

	if _passport.noErrors then
		// do updates
		realObject.setForUpdate(_pxyItemLayout);
	endif;

	if _passport.noErrors then
		// This is only required if the class is being auditted
	//	self.myUpdateAuditAgent.audUpdateGeneric(realObject, false);
	endif;

end;</source>
        <Parameter name="_pxyItemLayout" type="CM_DeckItemLayout"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateDeckItemRemarks" id="d7e246eb-e0c3-4956-b8d0-eb2b29da2233">
        <source>utlUpdateDeckItemRemarks(_deckItem :CM_DeckItem input; _theRemarks : String; _passport : CM_Passport input);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 April 2012	cnwndl1	Initial creation	Par 29444

*/

vars
	expectedEdition		: Integer;
	
begin

	self.initialiseActivity();
	
	if _deckItem = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, _deckItem.code, null, null);
		return;
	endif;

	exclusiveLock(_deckItem);

	if (not _passport.noErrors) then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'Deck Item', null, null);
		return;
	endif;
	
	if _deckItem.remarks &lt;&gt; _theRemarks then
		app.myAA.auditUpdate(_deckItem, "remarks", _theRemarks);
		_deckItem.setRemarks(_theRemarks);
	endif;



end;</source>
        <Parameter name="_deckItem" type="CM_DeckItem" usage="input"/>
        <Parameter name="_theRemarks" type="String"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateDeckLayerLayout" id="220fa943-c43c-47e6-a18e-ad17af147aa4">
        <updating/>
        <source>utlUpdateDeckLayerLayout(_pxyLayer : CM_DeckLayerLayout input; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     April 2011 ANDREW BISHOP
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	realDeckLayerLayout		: CM_DeckLayerLayout;
	expectedEdition	: Integer;
	pxyDeckItemLayout, realDeckItemLayout : CM_DeckItemLayout;
	delObjs : ObjectArray;
	reorderObjs : CM_RORODeckItemLayoutArray;
	pxyLocn, realLocn : CM_ROROLocnDefn;
begin
	self.initialiseActivity();
	
	// do any pre-validation locks
	
	// do validation
	self.raiseExceptionIfNull(_pxyLayer, 'Proxy Layer is NULL');

	app.setContinueCMExceptions(true);
	
	realDeckLayerLayout := self.getRealObjectAndEditionCheck(_pxyLayer, 'Proxy Deck Layer', _passport).CM_DeckLayerLayout;
	if _passport.noErrors then
		// This is only required if the class is being auditted
		//self.myUpdateAuditAgent.audUpdateGeneric(realDeckLayerLayout, true);
	endif;

	if _passport.noErrors then
		// do updates
		realDeckLayerLayout.setForUpdate(_pxyLayer);
	endif;
	
	
	// ### LAYER GRAPHICS
	// ## DELETE those that have been removed
	create delObjs transient;
	foreach realDeckItemLayout in realDeckLayerLayout.allDeckItemLayouts discreteLock do
		pxyDeckItemLayout := realDeckItemLayout.pxyGetProxyObject();
		// IF the real obj has no proxy then delete it.
		if pxyDeckItemLayout = null then
			delObjs.add(realDeckItemLayout);
		endif;
	endforeach;
	delObjs.purge;

	// ### LAYER GRAPHICS
	// ## ADD or UPDATE
	create reorderObjs transient;
	foreach pxyDeckItemLayout in _pxyLayer.allDeckItemLayouts discreteLock do
		realDeckItemLayout := pxyDeckItemLayout.pxyGetRealObject();
		if realDeckItemLayout = null then
			app.myUtilityCA.utlCreateDeckItemLayout(pxyDeckItemLayout, realDeckItemLayout, _passport);
		else
			self.utlUpdateDeckItemLayout(pxyDeckItemLayout, _passport);
		endif;
		if realDeckItemLayout &lt;&gt; null then
			reorderObjs.add(realDeckItemLayout);
		endif;
	endforeach;

	// need to re order the graphics. The proxy has the correct order as taken from the UI
	realDeckLayerLayout.matchOrderOfItemLayouts(reorderObjs);
	foreach pxyLocn in _pxyLayer.allROROLocnDefnByOrdinal  discreteLock do
		realLocn := pxyLocn.pxyGetRealObject();
		if realLocn &lt;&gt; null then
			realLocn.setForUpdate(pxyLocn, _passport);
		endif;
	endforeach;

	if _passport.noErrors then
		// This is only required if the class is being auditted
		//self.myUpdateAuditAgent.audUpdateGeneric(realDeckLayerLayout, false);
	endif;
	

epilog
	delete delObjs;
	delete reorderObjs;
end;</source>
        <Parameter name="_pxyLayer" type="CM_DeckLayerLayout" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateDeckOptionsApplyRules" id="4bd5559f-09f0-4255-9eb4-d80580d05b2a">
        <updating/>
        <source>utlUpdateDeckOptionsApplyRules(_pxyDeckingOptions: CM_YADeckingOptions; _updateToLevel: Integer; _passport: CM_Passport input) updating;
//----------------------------------------------------------------
//	Created:	27 April 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	isSetup					: Boolean;
	tmpReal					: CM_YADeckingOptions;
	realDeckingOptions		: CM_YADeckingOptions;
	pxyDeckingOptions		: CM_YADeckingOptions;
	requiredEdition			: Integer;
	
begin
	app.setContinueCMExceptions(false);
	pxyDeckingOptions := _pxyDeckingOptions;

	if pxyDeckingOptions = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'proxy rules are null');
		return;
	endif;

	//what's this for?
	pxyDeckingOptions.pxyGetRealObjectAndEdition(tmpReal, requiredEdition);

	pxyDeckingOptions.validateForDecking();	//add validation - test if NOK for decking

	if _passport.hasErrors then
		return;
	endif;

	app.myUtilityUA.utlUpdateDeckingOptions(pxyDeckingOptions, realDeckingOptions, _updateToLevel, _passport);
	
	if _passport.hasErrors then
		return;
	endif;
	
	self.raiseExceptionIfNull(realDeckingOptions, "Persistent DeckingOptions");

	//apply rules to YALocationCells
	app.myUtilityUA.utlApplyDeckingRule(realDeckingOptions, _passport);
end;</source>
        <Parameter name="_pxyDeckingOptions" type="CM_YADeckingOptions"/>
        <Parameter name="_updateToLevel" type="Integer"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateDeckingOptions" id="e1e498b1-cd94-4c65-96a9-73a376abe4ed">
        <source>utlUpdateDeckingOptions(_pxyDeckingOptions: CM_YADeckingOptions; _realDeckingOptions: CM_YADeckingOptions output; _updateToLevel: Integer; _passport : CM_Passport input);
//----------------------------------------------------------------
//	Created:	12 April 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	expectedEdition		: Integer;
	isNew				: Boolean;
	pxyDeckingOptions	: CM_YADeckingOptions;
begin
	self.initialiseActivity();
	app.setContinueCMExceptions(true);
	pxyDeckingOptions := _pxyDeckingOptions;
	pxyDeckingOptions.raiseExceptionIfNotTransient(method);	//may not be a proxy
	pxyDeckingOptions.pxyGetRealObjectAndEdition(_realDeckingOptions, expectedEdition);
	
	if _realDeckingOptions = null then

		create _realDeckingOptions as pxyDeckingOptions.class persistent;
		expectedEdition := _realDeckingOptions.edition;
		isNew	:=	true;
	else
		isNew	:=	false;
	endif;

	app.myValUA.valDeckingOptions(_realDeckingOptions, pxyDeckingOptions);
	
	if (not self.checkValidationWithPassport(_passport)) then
		return;	
	endif;

	app.setContinueCMExceptions(false);

	exclusiveLock(_realDeckingOptions);

	if _passport.noErrors and _realDeckingOptions.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'Decking Options', null, null);
		return;
	endif;
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(_realDeckingOptions, true);
	endif;
	
	if _passport.noErrors then
		if isNew then
			_realDeckingOptions.setForCreate(pxyDeckingOptions);
		else
			_realDeckingOptions.setForUpdate(pxyDeckingOptions, _updateToLevel);
		endif;
	endif;

	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(_realDeckingOptions, false);
	endif;
epilog
	//delete pxyDeckingOptions; epr 1/7/10 par 24724 is deleted elsewhere do not delete
end;</source>
        <Parameter name="_pxyDeckingOptions" type="CM_YADeckingOptions"/>
        <Parameter name="_realDeckingOptions" type="CM_YADeckingOptions" usage="output"/>
        <Parameter name="_updateToLevel" type="Integer"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateDefinedText" id="fc38d1a1-e8fb-4e4d-9aaa-4d4aed9567f0">
        <updating/>
        <source>utlUpdateDefinedText(_pxyDefinedText	: CM_DefinedText io;
						_passport 			: CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		 Reason
10 October 2022		navvt20  ChangeRequest 53424: MTN - MOB - Input Remarks - Jade

*/

vars
	realDT 			: CM_DefinedText;
	expectedEdition : Integer;
begin
	self.initialiseActivity();
	
	self.raiseExceptionIfNull(_pxyDefinedText, 'Defined Text proxy');
	
	_pxyDefinedText.pxyGetRealObjectAndEdition(realDT, expectedEdition);
	self.raiseExceptionIfNull(realDT, 'Defined Text');
	
	_pxyDefinedText.validateForUpdate();
	
	if not _passport.noErrors then
		return;
	endif;
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realDT, true);
	endif;
	
	realDT.setForUpdate(_pxyDefinedText);
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realDT, false);
	endif;
epilog

end;</source>
        <Parameter name="_pxyDefinedText" type="CM_DefinedText" usage="io"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateDefrostDict" id="83fad982-f652-4da2-801a-29f70f84085e">
        <source>utlUpdateDefrostDict(_ti: CM_TrackedItem; _passport : CM_Passport input);
//----------------------------------------------------------------
//	Created:	27 January 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
// 09/12/2009	cnwdap1		CCMS MES 1007 Any tracked item could now be a reefer - check subcargo type for non-containers
// 11/03/2010	cnwdap1		PAR #22938 Correct reefer checking
vars
	//reefer: CM_Container;		// CCMS 1007
	reefer: CM_TrackedItem;		// CCMS 1007
begin

	self.initialiseActivity();
	
	if CM_Container.hasInstance(_ti) or (_ti.isReefer)then	// PAR #22938
		//reefer := _ti.CM_Container;	// CCMS 1007
		reefer := _ti;					// CCMS 1007
	else
		//app.writeLog("This tracked item is not a reefer container (" &amp; _ti.id &amp; ")" , LogAlways);	// CCMS 1007
		app.writeLog("This tracked item is not a reefer (" &amp; _ti.id &amp; ")" , LogINFO);				// CCMS 1007
		return;
	endif;
	
	reefer.updateDefrostDict();
	
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateDelReqFromResDetail" id="709e3b78-b800-4403-936d-8383d7ab129a">
        <source>utlUpdateDelReqFromResDetail(_delReq : CM_DeliveryRequest input; _resDetail : CM_ReserveSelection input; _passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:		September 2004 By Andrew Bishop cnwab1
//
// Purpose:		PAR 15358
//
// ---------------------------------------------------------------------------
vars
	theTerminal : CM_Terminal;
	tmpCMIF : CMIF_Request;
	origAmount : Integer;
begin

	self.initialiseActivity();

	exclusiveLock(_delReq);
	create tmpCMIF transient;
	_resDetail.setInterfaceBP(tmpCMIF);
	
	if _passport.noErrors then
		origAmount := _delReq.totalRequested;
		_delReq.setFromCMIF_Request(tmpCMIF);
		_delReq.totalRequested := origAmount;
	endif;

	if _passport.noErrors then
		_delReq.myJob.causeTerminalEvent(CM_Job.Event_Mode_Update);
	endif;
epilog
	delete tmpCMIF;
end;</source>
        <Parameter name="_delReq" type="CM_DeliveryRequest" usage="input"/>
        <Parameter name="_resDetail" type="CM_ReserveSelection" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateDelay" id="90ebf28b-eaa3-4fdf-884c-f159ac0e4ec0">
        <source>utlUpdateDelay(_proxy : CM_Delay; _passport : CM_Passport input);
/*
----------   ----------  --------------------------------------------------
Created:	21 February 2007 By cnwmo1

Purpose:	

Changed On   Changed By  Reason

08/11/2012	cnwcs5		par 30519 - cause notification	
21 Sep 2020 cnwma1 		ChangeRequest 49906: MTN - Ops View External Webservice
----------  ----------  --------------------------------------------------
*/
vars
	expectedEdition			: Integer;
	delay					: CM_Delay;
	oldVoyage, newVoyage	: CM_Voyage;
begin
	self.initialiseActivity();

	_proxy.raiseExceptionIfNotProxy(method);

	app.setContinueCMExceptions(true);

	_proxy.pxyGetRealObjectAndEdition(delay, expectedEdition);

	if delay = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_DelayType.name, null, null);
		return;
	endif;
	
	app.myValUA.valDelay(delay, _proxy);
	
	if (not self.checkValidationWithPassport(_passport)) then
		return;		// note that this gets "ignored" in the eplog
	endif;

	app.setContinueCMExceptions(false);

	self.exclusiveLock(delay);
	
	if _passport.noErrors and delay.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, app.getErrorString (Delay), null, null);
		return;
	endif;
		
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(delay, true);
	endif;
		
	if _passport.noErrors then
		// save off old voyage in case voyage changes on delay as both voyages will need to send out notes
		oldVoyage := delay.myVoyage;
	
		delay.setForUpdate(_proxy);
	endif;
	
	if _passport.noErrors then
		// save off old voyage in case voyage changes on delay as both voyages will need to send out notes
		newVoyage := delay.myVoyage;
		
		self.myUpdateAuditAgent.audUpdateGeneric(delay, false);
		
		if oldVoyage = newVoyage then
			if newVoyage &lt;&gt; null then
				// simple update - no change of voyage
				newVoyage.causeEvent (newVoyage.myTerminal.getTerminalEvent(EVENT_DELAY_UPDATE), false, delay);
			endif;
		else
			// change of voyage ... somehow
			if oldVoyage &lt;&gt; null then
				// delay removed from this voyage
				oldVoyage.causeEvent (oldVoyage.myTerminal.getTerminalEvent(EVENT_DELAY_DELETE), false, delay);
			endif;
			
			if newVoyage &lt;&gt; null then
				// Delay added to this voyage
				newVoyage.causeEvent (newVoyage.myTerminal.getTerminalEvent(EVENT_DELAY_CREATE), false, delay);
			endif;
		endif;
		
		//21.09.2020 cnwma1 TFS #49906
		if _passport.isOpsViewEnabled(delay.getMyTerminal()) then
			delay.createOpsViewEWSActivity(BGP_OpsViewWSRequest.OPS_ACTION_UPDATE,
										  BGP_OpsViewWSRequest.OPS_TYPE_DELAY,
										  delay);
		endif;
		//21.09.2020 cnwma1 TFS #49906
	endif;
	
epilog
			
	
end;
</source>
        <Parameter name="_proxy" type="CM_Delay"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateDelayType" id="8cb12d2f-aa95-45c3-85e2-f358bf00671d">
        <source>utlUpdateDelayType(pProxyDelayType : CM_DelayType; _passport : CM_Passport input);
/*
----------   ----------  --------------------------------------------------
Created:	31 January 2007 By cnwmo1

Purpose:	

Changed On   Changed By  Reason
21 Sep 2020 cnwma1 ChangeRequest 49906: MTN - Ops View External Webservice
----------   ----------  --------------------------------------------------
*/
vars
	cancelSave		:Boolean;
	expectedEdition	:Integer;
	realDelayType	: CM_DelayType;
begin
	self.initialiseActivity();

	pProxyDelayType.raiseExceptionIfNotProxy(method);

	app.setContinueCMExceptions(true);

	pProxyDelayType.pxyGetRealObjectAndEdition(realDelayType, expectedEdition);

	if realDelayType = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_DelayType.name, null, null);
		return;
	endif;
	
	app.myValUA.valDelayType(realDelayType, pProxyDelayType);
	
	if (not self.checkValidationWithPassport(_passport)) then
		return;		// note that this gets "ignored" in the eplog
	endif;

	app.setContinueCMExceptions(false);

	exclusiveLock(realDelayType);
	
	if _passport.noErrors and realDelayType.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'Delay Type', null, null);
		return;
	endif;
		
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realDelayType, true);
	endif;
		
	if _passport.noErrors then
		realDelayType.setForUpdate(pProxyDelayType);
	endif;
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realDelayType, false);
	endif;
	
	//21.09.2020 cnwma1 TFS #49906
	if _passport.noErrors then
		if _passport.isOpsViewEnabled(null) then
			realDelayType.createOpsViewEWSActivity(BGP_OpsViewWSRequest.OPS_ACTION_UPDATE,
												  BGP_OpsViewWSRequest.OPS_TYPE_DELAYTYPE,
												  realDelayType);
		endif;
	endif;
	//21.09.2020 cnwma1 TFS #49906
epilog
			
	
end;
</source>
        <Parameter name="pProxyDelayType" type="CM_DelayType"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
