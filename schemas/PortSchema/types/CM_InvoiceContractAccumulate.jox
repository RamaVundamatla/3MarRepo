        <source>accumulatInvoiceLineTrans(_invLine : CM_InvoiceLine) updating;
/*
Purpose:			

Date		Who		Reason
24 January 2023	navab1	TFS CR 55624 TASK 55700 
*/

vars
	tran : CM_TITransaction;
begin
	
	// ### JIRA 33348 22NOV2024 NAVAB1
	tran := _invLine.myTransactionTI;
	self.allContributingTransactions.tryAddIfNotNull(tran);
epilog

end;</source>
        <Parameter name="_invLine" type="CM_InvoiceLine"/>
    </JadeMethod>
