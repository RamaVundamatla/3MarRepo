    <JadeMethod name="addToolbarControls" id="c2c17e48-4027-4443-b389-4281593270f8">
        <updating/>
        <source>addToolbarControls() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
01 June 2011	cnwer1	Initial creation CCMS MES 1116

*/

vars
	toolbar : CMUI_Toolbar;
begin
	inheritMethod();

	toolbar := self.frmToolbar;
	
	toolbar.addButton(self.btnExportXML,CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnExportXMLDeck,CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnImportXML,CMUI_Toolbar.Control_Alignment_Left);
	
	toolbar.addButton(self.btnROROConfig,CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnDeckSorting,CMUI_Toolbar.Control_Alignment_Left);
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="btnDeckSorting_click" id="d189ac45-f81c-4100-84bb-862f628e4c71">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnDeckSorting_click(btn: Button input) updating;
// Dec 2011		cnwjre1	Par 28687 after CCMS 1035, implement RORO vessel deck re-ordering
vars

begin
	self.doShowDeckSortingForm();
end;
</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
