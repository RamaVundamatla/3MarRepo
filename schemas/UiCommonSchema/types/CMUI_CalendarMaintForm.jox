    <JadeMethod name="showButtons" id="6466610f-4807-4510-a949-4c66e3ff8d72">
        <source>showButtons();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 October 2010	cnwndl1	Initial creation

*/

vars

	maintAllowed : Boolean;
begin

	if not self.tblDayData.allSelectedObjects.isEmpty then
		maintAllowed := ( app.getMyUser.canDo(null, PmAdmCalendarMaint) or app.getMyUser.canDo(self.myTerminal, PmAdmCalTermMaint) );
		self.btnRemDate.enabled := maintAllowed;
		self.btnUpdDate.enabled := maintAllowed and self.tblDayData.allSelectedObjects.size = 1;
		return;
	endif;
	
	self.btnRemDate.enabled := false;
	self.btnUpdDate.enabled := false;

epilog

end;</source>
