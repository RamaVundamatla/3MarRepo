    <JadeMethod name="setForUpdate" id="5d7035b5-9dc7-4506-907b-7332dca51645">
        <updating/>
        <source>setForUpdate( _proxy : CM_EDICUSCARRule) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21 May 2014	cnwrd1	Initial creation

*/

vars

begin
	self.raiseExceptionIfTransient (method);
	
	self.function	:= _proxy.function;
	self.item		:= _proxy.item;
	self.value		:= _proxy.value;
	self.todoTask 	:= _proxy.todoTask;
	self.matchText	:= _proxy.matchText;
	
epilog

end;</source>
        <Parameter name="_proxy" type="CM_EDICUSCARRule"/>
    </JadeMethod>
