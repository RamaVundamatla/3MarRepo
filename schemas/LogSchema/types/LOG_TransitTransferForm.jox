    <JadeMethod name="setupForm" id="7033cc8d-f07d-4afd-832a-9faac4b37f12">
        <updating/>
        <source>setupForm() updating;

vars

	entTableControl	: EntTableDef;
	cargoType		: CM_CargoBOLType;
begin

	self.toolbarStyle := self.ToolbarStyle_ShowNoHide;
	self.showToolbar := true;
	
	cargoType := app.myRoot.allCargoTypesById[TI_CargoType_Log];
	
	self.optSpecs.caption := app.getTerminologyAlternate(cargoType,
														 self.myTerminal,
							 							 CM_TerminologyOperator,
							 							 CM_TermExpressionSingular,
							 							 ETRow_Operator) &amp; ' / Specs / Length';

	self.tblSelection.setTerminologyRelevant(cargoType, self.myTerminal);	
	entTableControl := app.myController.getEntTableDef(ETDef_TransitSelection);
	self.tblSelection.optimiseRowHeight := true;	
	self.tblSelection.setEntTableDef(entTableControl, null, 'entTableDefSetupWarning');
	self.tblSelection.optimiseHeadingColumn();
	
	entTableControl := app.myController.getEntTableDef(ETDef_TransitToSelection);
	self.tblActionData.optimiseRowHeight := true;
	self.tblActionData.setEntTableDef(entTableControl, null, 'entTableDefSetupWarning');
	self.tblActionData.optimiseHeadingColumn();
	
	self.tblSelectData.setTerminologyRelevant(cargoType, self.myTerminal);		
	self.tblSelectData.optimiseRowHeight := true;
	self.tblSelectData.selectionType := CM_BaseTable.SelectionType_Row;
	self.tblSelectData.autoSize := Table.AutoSize_Column;
	
	self.centreWindow;
	self.setCaption(self.caption);

end;</source>
    </JadeMethod>
    <JadeMethod name="sortAndDisplay" id="8e2e30f0-c043-4c8c-8303-ebb1a2da6ab3">
        <source>sortAndDisplay() protected;

vars

	def		: CMIF_DocketLogDef;
	str		: String;
	tmpArray : EntTableRowArray;
begin

	self.tblSelectData.rows := 1;
	tmpArray := self.tblSelectData.allTblDataEntRows;
	
	foreach def in self.allDocketLogDef do
		// PAR 10353
		str := def.getAttributeStringForDefArray(tmpArray);
		if str &lt;&gt; null then
			self.tblSelectData.addItemObject(def, str);
		endif;
	endforeach;	

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="splitTisByBOL" id="4c45821d-61d3-4fe3-8e79-2f6c7716fa85">
        <source>splitTisByBOL(_allTis : CM_TISet; _allCMIFs : CMIF_Array input) protected;

vars

	helper	: CMIF_DocketLocationHelper;
	ti		: CM_TrackedItem;
	iter	: Iterator;

begin
	
	iter := _allCMIFs.createIterator;
	foreach ti in _allTis do
		iter.reset();
		while iter.next(helper) do
			if helper.myBOL.number = ti.myReleaseBOL.number then
				break;
			endif;
			helper := null;
		endwhile;
		if helper = null then
			create helper transient;
			helper.myBOL := ti.myReleaseBOL;
			_allCMIFs.add(helper);
		endif;
		helper.addTI(ti);
	endforeach;
	
epilog
	delete iter;
end;</source>
        <access>protected</access>
        <Parameter name="_allTis" type="CM_TISet"/>
        <Parameter name="_allCMIFs" type="CMIF_Array" usage="input"/>
    </JadeMethod>
