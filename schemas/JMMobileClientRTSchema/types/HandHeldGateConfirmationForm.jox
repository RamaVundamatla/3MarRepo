    <JadeMethod name="btnBoomClose_click" id="46bc329e-4856-4ad9-9dbe-6ddf72ae64c9">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnBoomClose_click(btn: Button input) updating;

vars
	gate : Integer;
	chanel : Integer;
	errorMsgs				: MobileHandHeldThin::DTO_HandHeldGateErrorDict;
begin
	self.getGateAndChanel(gate, chanel, btn);
	
	create errorMsgs transient;
	app.myHandHeldGateGuiAgent.doOperateBoom(gate, chanel,errorMsgs);
	delete errorMsgs;
end;
</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnBoomOpen_click" id="d43f193d-858b-4b5c-9ab5-d01fc2349fe3">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnBoomOpen_click(btn: Button input) updating;

vars
	gate : Integer;
	chanel : Integer;
	errorMsgs				: MobileHandHeldThin::DTO_HandHeldGateErrorDict;
begin
	self.getGateAndChanel(gate, chanel, btn);
	
	create errorMsgs transient;
	app.myHandHeldGateGuiAgent.doOperateBoom(gate, chanel,errorMsgs);
	if not errorMsgs.isEmpty() then
		self.doApplyErrors(errorMsgs);
	endif;
	
	delete errorMsgs;
end;
</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
