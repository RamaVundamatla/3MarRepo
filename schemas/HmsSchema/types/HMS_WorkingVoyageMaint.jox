    <JadeMethod name="cbxOtherBerth_displayEntry" id="3200884f-d5c6-4add-a99b-fc26ef679945">
        <controlMethod name="CMUI_ComboBox::displayEntry"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cbxOtherBerth_displayEntry(combobox: ComboBox input; obj: Any; lstIndex: Integer):String updating;

vars
 	berthPref:	HMS_BerthPreference;
 	tmpData : HMS_VesselDataHarbour;
begin
	if self.myCurrentVessel = null then
		return null;
	endif;
	if self.myCurrentVessel.myHMSVesselData = null then
		return null;
	endif;	
	// Check to see if a preferred berth obj exists for this berth for this vessel
	tmpData := self.myCurrentVessel.myHMSVesselData.allVesselDataForHarbour[self.myHarbour];
	if tmpData = null then
		return obj.HMS_Berth.description;
	endif;
	
	berthPref := tmpData.allBerthPrefByName.getAtKey(obj.HMS_Berth.description);
	if berthPref = null then
		// Berth is not in preference list - add to other berths list
		return obj.HMS_Berth.description;
	else
		// Berth is already in preference list - DO NOT add to other berths list.
		return null;
	endif;
end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
        <Parameter name="obj" type="Any"/>
        <Parameter name="lstIndex" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
