    <JadeMethod name="getPwForUse" id="6b9977e4-1f5b-4cd1-90ba-4ae34fdeb608">
        <source>getPwForUse(_context: String): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 September 2021	navndl1	Initial creation	TFS 51920

*/

vars

begin

	if _context = CM_SFTPEntity::passPhrase.name then
		return app.pwDeCode( self, self.passPhrase );
	endif;
	
	return inheritMethod(_context);

epilog

end;</source>
        <Parameter name="_context" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
