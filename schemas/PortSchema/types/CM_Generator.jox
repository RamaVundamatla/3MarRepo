    <JadeMethod name="setFuelledDetails" id="db88da19-a976-444f-926e-a1599f6fc1cd">
        <updating/>
        <source>setFuelledDetails() updating;
// ---------------------------------------------------------------------------
// Created:     21 September 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	trans	: CM_TITransaction;

begin

	//trans := self.getLastTransOfType(TRANS_TYPE_FUELED);
	trans := getLastTransOfClass(CM_Fuel);	//22 Mar 2016	NDL	TFS 1694
	
	if trans = null then
		self.fuelledDT := null;
	else
		self.fuelledDT := trans.dateTime;
	endif;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="setLocationsFromParent" id="88ff7490-98ff-42c4-ac3c-f79f9e26650f">
