    <JadeMethod name="getStartPoints" id="2eac316f-906c-4ecc-9ac2-392db4755686">
        <source>getStartPoints(x,y : Real output);
/*

Purpose:			


Return Value:		


Date		Who		Reason
14 December 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars
	bottom,left : Boolean;
begin
	if self.isHorizontal(bottom) then
		//start x at the left most point
		y:=0;
		if bottom then
			//start y at the top
			x:=0;
		else	
			x:=	self.myLabelFrame.clientHeight;
			//start y at the bottom
			
		endif;
	elseif self.isVertical(left) then
		//start y at the bottom most point
		x:=0;//self.myLabelFrame.clientHeight;
		y:=self.myLabelFrame.clientWidth;
		/*if left then
			//start x at client width
			write "here " &amp; self.myLabelFrame.clientWidth.String;
			
		else
			//start x at right
			y:=0;
		endif;*/
	endif;

epilog

end;</source>
        <Parameter name="x" type="Real" usage="output"/>
        <Parameter name="y" type="Real" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getTimeForX" id="5415c9db-6677-4d62-abb2-730d8ebc2c55">
        <source>getTimeForX(_x : Real) : TimeStamp;
/*

Purpose:			


Return Value:		


Date		Who		Reason
17 January 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars
	ts : TimeStamp;
	diffMins,
	diffSecs: Real;
	diffMinsStr : String;
	time : Time;
begin
	
	diffMins :=((_x/(scaleNoLines * getLegendSpace)) * self.scaleMins);
	diffSecs:=diffMins - diffMins.Integer;
	ts:=startTime.addMinutes(diffMins.Integer);
	time:=null;
	diffSecs:=diffSecs * 60 * 1000;
	diffSecs:=diffSecs.abs;
	time:=time + diffSecs.rounded;
	ts:=ts + time;
	return ts;
epilog

end;</source>
        <Parameter name="_x" type="Real"/>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="getXForTime" id="9d863af5-93b8-4540-90f5-78a19b73fdd6">
        <source>getXForTime(_timeStamp : TimeStamp) : Real;
/*

Purpose:			


Return Value:		


Date		Who		Reason
20 December 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars
	startX,timeX : Real;
	minsToAdd : Integer;
	diffDays : Integer;
	diffTime : Time;
	diffMins : Real;
	posNeg : Integer;
begin

	diffMins:=startTime.minutesDiff(_timeStamp);
	//avoid the division by zero error
	if scaleMins = 0 then
		return 0;
	endif;
	timeX:=((diffMins/self.scaleMins) * (scaleNoLines* getLegendSpace));
	return timeX;
	
epilog

end;</source>
        <Parameter name="_timeStamp" type="TimeStamp"/>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="initControl" id="21dd7629-6c55-44e6-a0f9-58918045f118">
        <updating/>
        <source>initControl(_myLabelFrame : CMUI_ScrollableLabelsFrame;
			_startTime,
			_endTime : TimeStamp;
			_scaleNoLines : Integer;
			_zoom : Real;
			_screenSize : Integer) : Boolean updating;

vars
	hasChanged : Boolean;
begin
	
	self.myLabelFrame:=_myLabelFrame;

	//Set up scrollable label
	self.myLabelFrame.drawMode 		:= self.myLabelFrame.DrawMode_Copy;
	self.myLabelFrame.drawFontName	:= 'Arial';	
	self.myLabelFrame.drawFontSize	:= 8;
	self.myLabelFrame.borderStyle	:= self.myLabelFrame.BorderStyle_Single;//Single;	
	self.myLabelFrame.ignoreSkin:=true;
	//just for testing
	
	hasChanged:=self.startTime &lt;&gt; _startTime;
	self.setStartTime(_startTime);
	
	if not hasChanged then
		hasChanged:=self.originalEndTime &lt;&gt;_endTime;
	endif;
	self.originalEndTime:=_endTime;
	self.setEndTime(originalEndTime.addMinutes(5));
	//i.e. 10 lines represents 10 mins etc
	scaleNoLines := _scaleNoLines; //i.e. 10 lines 
	zoom := _zoom; // 10 mins
	self.screenSize:=_screenSize - 12;// - app.getVerticalScrollbarWidth ;

	return hasChanged;
epilog

end;</source>
        <Parameter name="_myLabelFrame" type="CMUI_ScrollableLabelsFrame"/>
        <Parameter name="_startTime" type="TimeStamp"/>
        <Parameter name="_endTime" type="TimeStamp"/>
        <Parameter name="_scaleNoLines" type="Integer"/>
        <Parameter name="_zoom" type="Real"/>
        <Parameter name="_screenSize" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
