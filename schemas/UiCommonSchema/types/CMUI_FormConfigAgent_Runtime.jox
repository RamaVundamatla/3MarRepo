<Class name="CMUI_FormConfigAgent_Runtime" id="00bdd57f-b44a-44c3-96f1-a95d930bba5b">
    <superclass name="CMUI_FormConfigAgent"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="uicommon"/>
    <JadeMethod name="customiseForm" id="0f2c50d8-1904-406b-a8fa-8a33dabb4f2b">
        <source>customiseForm(_form: CM_BaseForm input);
// ---------------------------------------------------------------------------
// Created:     04 September 2008 by concms1
// Purpose:     User definable forms - CCMS 1011
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	config	:CM_FormConfigForm;
begin
	// set the form dimensions - do it first to avoid issues with parent aspect
	config := self.getFormConfiguration;

	if config.width &gt; 0 then
		if config.width &lt; _form.minimumWidth then
			_form.minimumWidth := config.width.Integer;
		endif;
		
		_form.clientWidth	:= config.width.Integer; 
	endif;
	if config.height &gt; 0 then
		_form.clientHeight	:= config.height.Integer; 
		
		if config.height &lt; _form.minimumHeight then
			_form.minimumHeight := config.height.Integer;
		endif;
	endif;
	
	inheritMethod(_form);


epilog

end;</source>
        <Parameter name="_form" type="CM_BaseForm" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getFormConfiguration" id="c80d5039-64c4-4cbe-887f-8c1de8892635">
        <source>getFormConfiguration(): CM_FormConfigForm protected;
// ---------------------------------------------------------------------------
// Created:     04 September 2008 by concms1
// Purpose:     User definable forms - CCMS 1011
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	return self.myFormConfiguration;
epilog

end;</source>
        <access>protected</access>
        <ReturnType type="CM_FormConfigForm"/>
    </JadeMethod>
</Class>
