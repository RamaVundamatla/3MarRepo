    <JadeMethod name="removeYardAllocation" id="41168743-d48c-4196-8221-296dc21c499f">
        <updating/>
        <source>removeYardAllocation(_yalloc : CM_YardAllocation) updating;
// ---------------------------------------------------------------------------
// Created:		April 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	tmpPoint : Point;
	x1,x2,y1,y2,idx : Integer;
	yalloc : CM_YardAllocation;
	iterator : Iterator;
	obj : Object;
	yalColour : Integer;
begin
	yalloc := _yalloc;

	iterator := self.allObjects.createIterator();
	
	while iterator.next(obj) do
		yalloc := obj.CM_YardAllocation;
		if yalloc = _yalloc then
			self.allObjects.getIteratorKeys(x1, y1, x2, y2, iterator);
			self.allObjects.removeKeyEntry(x1, y1, x2, y2,yalloc);
			continue;
		endif;

	endwhile;		
epilog
	delete iterator; //epr par 18417 3/11/08
end;</source>
        <Parameter name="_yalloc" type="CM_YardAllocation"/>
    </JadeMethod>
    <JadeMethod name="resizeRectFrame" id="508d43f1-7d4e-4446-8697-355737409623">
        <source>resizeRectFrame(_rect: CMUI_ResizableRectFrame input);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 Feb 2009	cnwjk3	Initial creation
11 May 2023	navdap1	TFS 57711 FR | 53485 EUP - Warehouse Yard Allocation - Satellite view location selection issues
*/

vars
	x1,
	y1,
	x2,
	y2 			: Integer;
	oldx1,
	oldy1,
	oldx2,
	oldy2 		: Integer;
	objs 		: ObjectArray;
	isRoRoArea	: Boolean;
	obj : Object;
	firstObj : Object;
	xy1, xy2 : Point;
begin
	_rect.getIntPoints(x1, y1, x2, y2);
	oldx1 := x1; 
	oldx2 := x2;
	oldy1 := y1;
	oldy2 := y2;
	
	self.getDrawingController().normaliseRectanglePoints(x1, y1, x2, y2);

	// Get list of all bounding rectangles touched by the rectangle frame
	create objs transient;		
	self.getDrawingController().getSelectionBoundsForRect(x1, y1, x2, y2, objs, true);	
	if objs.size() &gt; 0 then
		if objs.size() = 1 then
			//epr par 30613 24/10/12 can't add  interchange areas to YA
			if objs[1].isKindOf(CM_YardInterchangeArea) then
				_rect.visible :=  false;
			else
			
				// Constrain the frame to the size of the bounding rectangle, if need be.					
				self.getDrawingController().constrainPointsToSelectBounds(objs[1], x1, y1, x2, y2);			
				isRoRoArea := objs[1].isKindOf(CM_RoRoLaneArea);			// cnwjk3 ccms 1018 25/01/10
			endif;
		else
			if self.containsOnlyIrregularBlockLCs(objs) then
				// More than one irregular block is included so constrain to the first
				// PAR 34205 self.getDrawingController().constrainPointsToSelectBounds(objs[1], x1, y1, x2, y2);				
				self.getDrawingController().constrainPointsToSelectBounds(objs, x1, y1, x2, y2); // PAR 34205 changed to passing in the collection, not just the first item in the collection			
			else
				// The rectangle includes more than one terminal area, so hide it
				_rect.visible := false;
			endif;
		endif;
	else
		// No terminal areas are within the rectangle, so hide it.
		_rect.visible := false;
	endif;
	
	if _rect.visible then
		if isRoRoArea then												// cnwjk3 ccms 1018 25/01/10
			if self.snapRectPointsToRoRoLanes(x1, y1, x2, y2) then		// cnwjk3 ccms 1018 25/01/10
				_rect.resizeByPoints(x1, y1, x2, y2);					// cnwjk3 ccms 1018 25/01/10
			else														// cnwjk3 ccms 1018 25/01/10
				_rect.visible := false;									// cnwjk3 ccms 1018 25/01/10
			endif;														// cnwjk3 ccms 1018 25/01/10
		else
			firstObj := objs.first;	//13 May 2016	NDL	TFS 1986/1909
		//	if self.snapRectPointsToGrid(x1, y1, x2, y2) then
			if self.snapRectPointsToGrid(x1, y1, x2, y2) or firstObj.isKindOf(CM_IrregularBlockController) then	//13 May 2016	NDL	TFS 1986/1909
				//13 May 2016	NDL	TFS 1986/1909
				firstObj := objs.first;
				if firstObj.isKindOf(CM_IrregularBlockController) then
					//obj := self.getDrawingController.getObjectAndPointsForPosition( x1+2, y1+2, xy1, xy2,null).Object;						// TFS 57711
					obj := self.getDrawingController.getObjectAndPointsForPosition( x1+2, y1+2, xy1, xy2, CM_IrregularBlockController).Object;	// TFS 57711
					if obj &lt;&gt; firstObj then
						//we must be trying to create a rectangle over partial areas, reset to just the first one.
						self.getDrawingController.getPointsForObject(firstObj,xy1,xy2);	
						x1 := xy1.x;
						y1 := xy1.y;
						x2 := xy2.x;
						y2 := xy2.y;	
					endif;
				endif;
				
				_rect.resizeByPoints(x1, y1, x2, y2);
			else
				_rect.visible := false;
			endif;
		endif;
	endif;

	// Check to see if the rectangle overlaps others, which isn't allowed	
	if _rect.visible then
		if self.checkRectOverlap(_rect, x1, y1, x2, y2) then
			//_rect.visible := false;
			_rect.top := _rect.origTop;
			_rect.left := _rect.origLeft;
			_rect.width := _rect.origWidth;
			_rect.height := _rect.origHeight;
		endif;
	endif;
	
epilog
	delete objs;
end;</source>
        <Parameter name="_rect" type="CMUI_ResizableRectFrame" usage="input"/>
    </JadeMethod>
    <JadeMethod name="selectAllYALocationText" id="d31739bf-787f-4f53-8e5b-6eb7ff710092">
        <source>selectAllYALocationText();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
23 February 2009	cnwjk3	Initial creation

*/

vars

begin
	self.form.YRD_SatelliteViewForm.txtYALocation.selLength := self.form.YRD_SatelliteViewForm.txtYALocation.text.length();
epilog

end;</source>
