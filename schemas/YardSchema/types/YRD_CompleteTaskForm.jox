    <JadeMethod name="doOK" id="06ea96f2-d8b1-4ceb-856c-78b3fadf88ae">
        <updating/>
        <source>doOK() updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
11 February 2011	cnwer1	Initial creation

*/

vars

begin

	if self.cmbMach.visible and (self.optPickupTask.value or self.optPickSetTask.value) then
	
		if self.cmbMach.listObject = null then
			app.msgBox(app.getErrorString(Please_select_task_machine),app.getErrorString(Error),MsgBox_OK_Only);
			return;
		endif;
	endif;
	
	if self.cmbIMV.visible and (self.optPickupTask.value or self.optPickSetTask.value)then
		if self.cmbIMV.listObject = null then
			app.msgBox(app.getErrorString(Please_select_IMV_machine),app.getErrorString(Error),MsgBox_OK_Only);
			return;
		endif;
	
	endif;
	
	
	inheritMethod();

epilog

end;</source>
    </JadeMethod>
