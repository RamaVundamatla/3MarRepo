    <JadeMethod name="getDataTypeFromDefName" id="feb1d9b3-49c5-46d6-a5a0-0b670f5a5243">
        <source>getDataTypeFromDefName(_name: String): Integer;
//
// cnwrs1 sept 2009 CCMS Messina 1008 par21718
//
// 13 Oct 2017	jlgrs1	TFS 5705 - SNO - EDIDataBooking Prenote release Req
vars

begin
	if _name = ETDef_EDITIBookingHeader then
		return EDIDataType_BookingHeader;
	elseif _name = ETDef_EDITIBookingItem then
		return EDIDataType_BookingItem;
	elseif _name = ETDef_EDITITaskRemarkTI or
		_name = ETDef_EDITITaskActionBookings then 
		return EDIDataType_ReqBookToDo;
	elseif _name = ETDef_EDIHazDetailsBooking then
		return EDIDataType_TIHazDets;
	elseif _name = ETDef_EDITIPrenote then
		return EDIDataType_Prenote;
	elseif _name = ETDef_EDIHazDetailsTI then
		return EDIDataType_TIHazDets;
	elseif _name = ETDef_EDITISeal then
		return EDIDataType_TISeal;
	elseif _name = ETDef_EDITIRequestHeader then
		return EDIDataType_RequestHeader;
	elseif _name = ETDef_EDITIRequestDetail then
		return EDIDataType_RequestDetail;
	elseif _name = ETDef_EDITIRequestCriteria then
		return EDIDataType_RequestCriteria;
	elseif _name = ETDef_EDITITaskRemarkTI
		or  _name = ETDef_EDITITaskActionRelReq then
		return EDIDataType_ReqBookToDo;
	endif;
epilog

end;</source>
        <Parameter name="_name" type="String"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStrForDefName" id="cefdc3a3-3be3-444b-add6-751e65e4e2e7">
        <source>getDisplayStrForDefName(_name: String): String;
//
// 13 Oct 2017	jlgrs1	TFS 5705 - SNO - EDIDataBooking Prenote release Req
//
vars

begin
	if _name = ETDef_EDITIBookingHeader then
		return app.getErrorString(Booking_header);
	elseif _name = ETDef_EDITIBookingItem then
		return app.getErrorString(Booking_Item);
	elseif _name = ETDef_EDITITaskRemarkTI or		//06 Oct 2016	NDL	TFS 2001 / 2792
	   _name = ETDef_EDITITaskActionBookings then //27/4/17 epr TFS 4139 
		return app.getErrorString(Tasks_apply);
	elseif _name = ETDef_EDITIPrenote then
		return app.getErrorString(Prenote);
	elseif _name = ETDef_EDIHazDetailsBooking then	//21 Nov 2016	NDL	TFS 2843 / 2604 //27/4/17	epr TFS 4139
		return app.getErrorString(Hazardous_details);
	elseif _name = ETDef_EDIHazDetailsTI then
		return app.getErrorString(Hazardous_details);
	elseif _name = ETDef_EDITISeal then
		return "Seals";
	elseif _name = ETDef_EDITIRequestHeader then
		return app.getErrorString(Request_header);
	elseif _name = ETDef_EDITIRequestDetail then
		return app.getErrorString(Request_detail);
	elseif _name = ETDef_EDITIRequestCriteria then
		return app.getErrorString(Request_criteria);
	elseif _name = ETDef_EDITITaskRemarkTI or
	   _name = ETDef_EDITITaskActionRelReq then
		return app.getErrorString(Tasks_apply);
	endif;
end;
</source>
        <Parameter name="_name" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getEDIChildDataTypes" id="31c6bcdc-7756-4266-bfeb-6bcdcf71b6a4">
        <source>getEDIChildDataTypes(_types: IntegerArray input);
