    <JadeMethod name="showMergeBreakBulkForm" id="2dda5822-6e5f-46c5-875d-acb2eda8e933">
        <source>showMergeBreakBulkForm( _ti : CM_TrackedItem );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 May 2013	cnwndl1	Initial creation	CCMS 2274 Break Bulk

*/

vars

	form : CMUI_MergeBreakBulkForm;
	msg : String;

begin

	if _ti = null then
		msg := app.getErrorString(No_Cargo_selected);
	elseif not _ti.canMergeBreakBulk then	//24 Jun 2013
		msg := app.getErrorString(No_merge_cargo_not_BB);
	elseif not _ti.isOnSite then	//14 Jun 2013	NDL	Par 31826
		msg := app.getErrorString1(ERR_TI_NOT_ONSITE,_ti.id);
	endif;
	if msg &lt;&gt; null then
		app.msgBox(msg,app.getErrorString(Error),MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
		return;
	endif;

	form := app.loadForm(CMUI_MergeBreakBulkForm, CMUI_Assistant, false, false, true, self.myTerminal, null).CMUI_MergeBreakBulkForm;
	if form = null then
		return;
	endif;	
	
	if form.setMyTrackedItem(_ti) then
		form.showModal();
	endif;

epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="showMoveAmountForm" id="bcc9c38d-d84b-431b-a274-c8c01d73b6f0">
        <source>showMoveAmountForm(_moveController : CMIF_MoveController input ) : Boolean;
/*

Purpose:			Allow user to enter the desired quantity of splittable cargo to move

Parameters:			

Return Value:		

Date			Who		Reason
10 July 2019	jlgzm1	jlgzm1	TFS 42863 MSL - Direct Release Between RORO Voyages and Rail - Breakbulk

*/

vars
	
	ti : CM_TrackedItem;
	quantity : Integer;
	form : CMUI_MoveAmountForm;
	weight : Decimal[14,4];
	wle : CM_WorkListEntry;
	
begin
	
	ti := _moveController.myTrackedItem;
	
	if ti = null or _moveController = null then
		return true;
	endif;
	
	
	if not (ti.myCargoType.isBreakBulkMulti or ti.myCargoType.isBulkMulti) then
		return true;
	endif;
	
	app.mousePointer := Form.MousePointer_Default;
	
	create form transient;
	form.myTrackedItem:= ti;
	if _moveController.myToPrimaryLocation &lt;&gt; null then
		form.targetLocation:=_moveController.myToPrimaryLocation.getFullId;
	endif;
	
	wle := _moveController.myWorkListEntry;
	if wle &lt;&gt; null then
		if ti.myCargoType.isBreakBulkMulti then
		form.txtQuantity.text := (ti.totalQuantity.min(wle.quantity)).String;
		elseif ti.myCargoType.isTrackByWeight then
			form.txtQuantity.text := (ti.totalWeight.min(wle.weight)).String;
		elseif ti.myCargoType.isTrackByVolume and ti.getDensity() &lt;&gt; 0 then
			form.txtQuantity.text := (ti.totalVolume.min(wle.weight / ti.getDensity())).String;
		endif;
	endif;
	
		
	if form.showModal &lt;&gt; IDOK then
		return false;
	endif;
	if form.byQuantity then
		_moveController.setQuantity (form.getQuantity);
	else
		_moveController.setWeight( form.getWeightMovedKgs);
	endif;
	
	return true;
	
epilog

end;</source>
        <Parameter name="_moveController" type="CMIF_MoveController" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="showMoveAmountFormForRoadOps" id="fe5af18a-5374-4ee8-923c-dbb57cc70f3d">
        <updating/>
        <source>showMoveAmountFormForRoadOps(_moveController : CMIF_MoveController input; _moveMode : Integer; _result : Boolean output) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 15/10/2021	navdap1		TFS 51935 SAL Direct Loading Partial Prenoted Cargo from Truck to Vessel
//
vars
	ti : CM_TrackedItem;
	form : CMUI_MoveAmountForm;
	wle : CM_WorkListEntry;
	tempMoveController : CMIF_MoveController;

begin
	ti := _moveController.myTrackedItem;
	
	if ti = null or _moveController = null then
		_result := false;
		return;
	endif;
	
	
	if not (ti.myCargoType.isBreakBulkMulti or ti.myCargoType.isBulkMulti) then
		_result := false;
		return;
	endif;
	
	app.mousePointer := Form.MousePointer_Default;
	tempMoveController := app.myMoveController;
	app.myMoveController := _moveController;
	
	create form transient;
	form.myTrackedItem:= ti;
	if _moveController.myToPrimaryLocation &lt;&gt; null then
		form.targetLocation:=_moveController.myToPrimaryLocation.getFullId;
	endif;
	
	wle := _moveController.myWorkListEntry;
	if wle &lt;&gt; null then
		if ti.myCargoType.isBreakBulkMulti then
		form.txtQuantity.text := (ti.totalQuantity.min(wle.quantity)).String;
		elseif ti.myCargoType.isTrackByWeight then
			form.txtQuantity.text := (ti.totalWeight.min(wle.weight)).String;
		elseif ti.myCargoType.isTrackByVolume and ti.getDensity() &lt;&gt; 0 then
			form.txtQuantity.text := (ti.totalVolume.min(wle.weight / ti.getDensity())).String;
		endif;
	endif;
	
		
	if form.showModal &lt;&gt; IDOK then
		_result := false;
		return;
	endif;
	if form.byQuantity then
		_moveController.setQuantity (form.getQuantity);
	else
		_moveController.setWeight( form.getWeightMovedKgs);
	endif;
	
	_result := true;
epilog
	app.myMoveController := tempMoveController;
end;</source>
        <Parameter name="_moveController" type="CMIF_MoveController" usage="input"/>
        <Parameter name="_moveMode" type="Integer"/>
        <Parameter name="_result" type="Boolean" usage="output"/>
    </JadeMethod>
    <JadeMethod name="showMoveCargoFromJobForm" id="08c2d2a2-0d95-4015-9834-0fcb32e5059d">
        <source>showMoveCargoFromJobForm(_voyageJob : CM_VoyageJob; _selectedWLEs : CM_WLESet);
// --------------------------------------------------------------------------------
// Created:		31 August 2010 by cnwjo3
//
// Purpose:		Open CMUI_MoveCargoFromJobForm and setup properties
//				CCMS 1178 PAR 23366
//
vars
	moveCargoForm : CMUI_MoveCargoFromJobForm;
begin

	if _voyageJob = null then
		return;
	endif;
	
	
	moveCargoForm:=app.loadForm(CMUI_MoveCargoFromJobForm, CMUI_Assistant, false, false, false, self.myTerminal, null).CMUI_MoveCargoFromJobForm;
	
	if moveCargoForm = null then
		return;
	endif;
	
	moveCargoForm.setMyVoyageJob(_voyageJob);
	moveCargoForm.copySelectedWLEs(_selectedWLEs);
	moveCargoForm.setFormParent(app.mainForm);
	
	moveCargoForm.show();	
end;</source>
        <Parameter name="_voyageJob" type="CM_VoyageJob"/>
        <Parameter name="_selectedWLEs" type="CM_WLESet"/>
    </JadeMethod>
    <JadeMethod name="showMoveItForm" id="43617e38-7bcc-4062-ba1f-5ac772773b3b">
        <source>showMoveItForm(_tiArray : CM_TIArray input; _initMoveMode : Integer);
//--------------------------------------------------
// Created:	November 2003 By: cnwgd1
//--------------------------------------------------
// Changed On	By			Reason
// ----------	--------	------------------------
// 17/01/2018	jlgdap1		TFS 36658 STWR Cargo Scanning Enhancements
//							Ensure mode is PLANNING only for cargo groups
vars
	form 		: CMUI_MoveToForm;
	ti			: CM_TrackedItem;
	moveMode	: Integer;
	activeForm : Form;
begin
	//cnwmc5 - 30 Nov 2015 - PAR 37016
	if _tiArray.isEmpty then
		return;
	endif;

	foreach ti in _tiArray do
		if ti &lt;&gt; null and ti.isCargoGroupItem then	//08 Jun 2015	NDL	Par 36338
			continue;
		endif;
		if ti &lt;&gt; null and ti.state &lt;&gt; TI_STATE_NOTIFIED then   // CCMS DPH 2346 - Should be able to Plan prenotes move moveit
			if ti.site &lt;&gt; TI_SITE_ONSITE and ti.site &lt;&gt; TI_SITE_ONSHIP then
				app.raiseCMException1(INVALID_MOVE_REQUEST, app.getErrorString1(UiInternalMoveNotPermitted, ti.id), null, null);		
				return;
			endif;
		endif;
	endforeach;
	
	
	activeForm:=app.activeForm;
	
	
	form := app.loadForm(CMUI_MoveToForm, CMUI_Assistant, false, false, false, self.myTerminal, null).CMUI_MoveToForm;	
	if form = null then
		return;
	endif;
	
	//18 July 2014	NDL	Par 34602
	moveMode := _initMoveMode;
	if _tiArray.first.isChild then
		moveMode := AUTO_PLAN_ONLY_MODE;
	elseif _tiArray.first.isCargoGroupItem and _initMoveMode = PLANNING_MODE then	// TFS 36658
		moveMode := PLANNING_MODE;													// TFS 36658
		form.isCargoGroup := true;													// TFS 36658
	endif;
	
	//jlier1 TFS 53515 25/5/22
	if activeForm &lt;&gt; null and activeForm.class = CMUI_CargoReview then
		form.showVoyageLocations:=true;
	endif;
	
	
	form.setMyTerminal(self.myTerminal);
	form.setMyTrackedItems(_tiArray);
	form.initMoveType := moveMode;
	form.show;

end;</source>
        <Parameter name="_tiArray" type="CM_TIArray" usage="input"/>
        <Parameter name="_initMoveMode" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="showMovementMaintForm" id="7b0cccaf-b54f-406a-9652-ecca32e7929a">
        <source>showMovementMaintForm(_realMovement : HMS_VoyageMovement; _resUsed : HMS_ResourceUsed; _masterMenuAction : CMUI_MenuAction;
					 _thumbnailOnly, _doEdit, _doAddShift, _doDelete : Boolean);
//--------------------------------------------------------------
//Created: 28 April 2004 By: cnwgd1
//--------------------------------------------------------------
vars
	form : CM_TableViewForm;
	menuAction : CMUI_MenuAction;
begin

	app.raiseUnexpectedProgramError(class.name, method.name, 'Replaced by self.showVoyageMovementsForm');
	return;
	
	if _realMovement &lt;&gt; null then
		if _realMovement.isTransient then
			app.raiseCMException1(ProxyAlreadyExists, _realMovement.getName(), null, null);
			return;
		endif;
	endif;
	
	menuAction := app.myController.createMenuAction(PmHMSMovementsView, null, _masterMenuAction, self.myTerminal);
	if menuAction = null then
		return;
	endif;
	
	form := menuAction.goToObject(null, null, false, null).CM_TableViewForm;
	if form = null then
		return;
	endif;

	if _realMovement &lt;&gt; null then
		form.setPropertyValue("myInitResourceUsed",_resUsed); // CCMS 1350
		form.showWithObject(_realMovement, _thumbnailOnly, _doEdit);
		if _doAddShift
		and form.btnNewTV.enabled then
			form.btnNewTV.click(form.btnNewTV);
		elseif _doDelete then
			form.btnCancelBase.click(form.btnCancelBase);
		endif;
	else
		form.show();
	endif;	

end;</source>
        <Parameter name="_realMovement" type="HMS_VoyageMovement"/>
        <Parameter name="_resUsed" type="HMS_ResourceUsed"/>
        <Parameter name="_masterMenuAction" type="CMUI_MenuAction"/>
        <Parameter name="_thumbnailOnly" type="Boolean"/>
        <Parameter name="_doEdit" type="Boolean"/>
        <Parameter name="_doAddShift" type="Boolean"/>
        <Parameter name="_doDelete" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="showMultiSelectForm" id="b9b1068b-311b-46cc-a876-c9f34c82d98a">
        <source>showMultiSelectForm(_caption : String;
					_itemsAvailable : Collection;
					_itemsSelected : Collection input;
					_isEnabled  : Boolean;
					_showOrderButtons : Boolean;
					_performanceItems : Collection input) : Integer;
//--------------------------------------------------
// Created:	18 April 2005 By: cnwgd1
// 21 May 2024	navnk30		Bug 64160: MTN - COO (Cargo Review screen showing up wrong Free Storage Days)
//--------------------------------------------------
vars
	form : CMUI_MultiSelectForm;
begin

	if _itemsSelected = null
	or _itemsAvailable = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Null collection');
		return null;
	endif;
	
	create form;
	form.mulSelect.setupControl(null, _itemsAvailable, CMUI_MultiSelectForm::displayDetail.name);	//21.05.2024 navnk30 #64160
	//form.mulSelect.formDisplayEntryMethodName := CMUI_MultiSelectForm::displayDetail.name; 		//21.05.2024 navnk30 #64160
	form.mulSelect.setAvailable(_itemsAvailable, false);
	form.mulSelect.userInputEnabled := _isEnabled;
	form.allSelectedItems := _itemsSelected;	
	form.setCaption(_caption);
	form.setAssistantAndTerminalRefs(self, self.myTerminal);
	form.showOrderButtons:=_showOrderButtons; //jlier1	TFS  53515 12/5/22
	// jlier1 TFS 53515 2/6/22
	form.setPerformanceItems(_performanceItems);
	
	form.centreWindow;
	form.showModal;

	return form.modalResult;

end;</source>
        <Parameter name="_caption" type="String"/>
        <Parameter name="_itemsAvailable" type="Collection"/>
        <Parameter name="_itemsSelected" type="Collection" usage="input"/>
        <Parameter name="_isEnabled" type="Boolean"/>
        <Parameter name="_showOrderButtons" type="Boolean"/>
        <Parameter name="_performanceItems" type="Collection" usage="input"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="showMultiSplitForm" id="e114f297-e33f-4762-bf00-e032fcaaec0b">
        <source>showMultiSplitForm( _ti : CM_TrackedItem );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 June 2020	jlgndl1	Initial creation	TFS 49401

*/

vars

	form : CMUI_MultiCargoSplit;
	msg : String;

begin

	if _ti = null then
		msg := app.getErrorString(No_Cargo_selected);
	elseif not _ti.canSplitTotalQuantity then
		msg := app.getErrorString(No_split_cargo_not_BB);
	endif;
	if msg &lt;&gt; null then
		app.msgBox(msg,app.getErrorString(Error),MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
		return;
	endif;

	form := app.loadForm(CMUI_MultiCargoSplit, CMUI_Assistant, false, false, true, self.myTerminal, null).CMUI_MultiCargoSplit;
	if form = null then
		return;
	endif;	
	
	if form.setMyTrackedItem(_ti) then
		form.showModal();
	endif;

epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="showObjMatchesCriteriaListForm" id="c177456b-62df-456a-a839-3a473c5af609">
