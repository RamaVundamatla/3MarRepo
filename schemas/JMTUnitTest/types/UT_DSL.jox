    <JadeMethod name="addHazardClass" id="a760ef3d-d563-4350-aa3c-50f8d2f6615e">
        <source>addHazardClass(_hazardClassId, _hazardClassDesc, _alternateCode : String; _notAvailableForEntry : Boolean) : CM_HazardClass;

/*

Purpose:		Add a Hazard Code

Date			Who		Reason
09/12/2011		cnwmh5	Initial creation
12/05/2015		cnwdap1	PAR #36206 TFS 324/334 Graphical Representation of Hazard Class
*/

vars

	pxyHazardClass					: CM_HazardClass;
	hazardClass						: CM_HazardClass;
	
begin

	self.deleteHazardClass(_hazardClassId);

	create pxyHazardClass transient;
	
	pxyHazardClass.setProxy(_hazardClassId,					// Id / Code
							 _hazardClassDesc,				// Description
							 _alternateCode,				// alternateCode
							 0, 							// colour
						     _notAvailableForEntry); 		// not available for entry
												  
	//app.myTrxCA.trxCreateHazardClass(pxyHazardClass, hazardClass, app.myPassport);		// PAR #36206
	app.myTrxCA.trxCreateHazardClass(pxyHazardClass, hazardClass, null, app.myPassport);	// PAR #36206
	self.assertNoTrxErrorsOrWarnings();
	return hazardClass;

epilog
	delete pxyHazardClass;
	
end;</source>
        <Parameter name="_hazardClassId" type="String"/>
        <Parameter name="_hazardClassDesc" type="String"/>
        <Parameter name="_alternateCode" type="String"/>
        <Parameter name="_notAvailableForEntry" type="Boolean"/>
        <ReturnType type="CM_HazardClass"/>
    </JadeMethod>
