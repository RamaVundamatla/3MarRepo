/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 September 2014	cnwndl1	Initial creation

*/

vars

begin

	app.cnEcInitializeBaseSchema();
	app.cnEcSetXmlSchema("PortSchema");

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="populateClasses" id="30adf562-6ff3-44c5-9515-b9d6f93091bc">
        <updating/>
        <source>populateClasses() protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 September 2014	cnwndl1	Initial creation

*/

vars

	classArray : CnClassArray;
	class : Class;
	objSet : ObjectSet;
	schema : Schema;
	formClass : Class;
	index : Integer;
	rowIndex : Integer;

begin

	schema := rootSchema.getSchema("SysOpsSchema");
	formClass := schema.getClass("SOP_TableMaintForm");

	self.tblClasses.clear();
	self.tblClasses.rows := 1;
	self.tblClasses.fixedRows := 1;
	self.tblClasses.columns := 2;
	self.tblClasses.setCellText( 1,1,"Nice Name" &amp; Tab &amp; "Selected Count");
	self.tblClasses.accessRow(1).fontBold := true;

	create classArray transient;			
	classArray.add(CM_Carrier);				
	classArray.add(CM_Commodity);			
	classArray.add(CM_ConsigneeConsignor);	
	classArray.add(CM_CustomsAgent);		
	classArray.add(CM_DamageDefinitionCode);
	classArray.add(CM_DamagePosition);		
	classArray.add(CM_EmailAddress2);		
	classArray.add(CM_HazardClass);			
	classArray.add(CM_ISOType);				
	classArray.add(CM_ISOTypeGroup);		
	classArray.add(CM_Operator);			
	classArray.add(CM_OperatorGroup);		
	classArray.add(CM_Organisation);		
	classArray.add(CM_Port);				
	classArray.add(CM_PrinterDef);			
	classArray.add(CM_ResourceType);		
	classArray.add(CM_ShippingAgent);		
	classArray.add(CM_ShippingLine);		
	classArray.add(CM_StopsTable);			
	classArray.add(CM_TemperatureConversion);
	classArray.add(CM_TempRange);			
	classArray.add(CM_ToDoTaskDesc);		
	classArray.add(CM_Trade);				
	classArray.add(CM_UNDangerousGoods);	
	classArray.add(CM_VehicleColour);		
	classArray.add(CM_VehicleMake);			
	classArray.add(CM_VehicleModel);		
	classArray.add(CM_VehicleType);			
	classArray.add(CM_WagonClass);			
	
	foreach class in classArray do
		index := index + 1;
		self.getSelectedObjects( class, objSet );
		if objSet = null then
			rowIndex := self.tblClasses.addItem( self.getNiceDisplay(class,null) &amp; Tab &amp; "  ");
		else
			rowIndex := self.tblClasses.addItem( self.getNiceDisplay(class,null) &amp; Tab &amp; objSet.size.String);
			self.tblClasses.accessRow( rowIndex ).backColor := Yellow;
		endif;
		self.tblClasses.accessRow( rowIndex ).itemObject := class;
	endforeach;
	
	self.myCurrentClass := null;
	self.populateInstances( null, null );
	
	self.fldBaseCode.topSheet := self.shtClasses;
	
epilog

	delete classArray;
	

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="populateFormats" id="a664f970-cf47-46c9-9147-212172884658">
        <updating/>
        <source>populateFormats() protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 September 2014	cnwndl1	Initial creation

*/

vars

	schema : Schema;
	format : CnEcXmlFormat;
	xmlFormatColl : CnEcXmlFormatDict;

begin

	self.cmbFormat.clear();
	
	schema := app.myCnEcXmlSchema;
	create xmlFormatColl transient;
	app.myBaseRoot.getAllFormatsForSchema( xmlFormatColl, schema.name );
	
	foreach format in xmlFormatColl do
		if format.schemaName &lt;&gt; schema.name then
			continue;
		endif;
		if format.formatName = "Default OID" then
			continue;
		endif;
		if format.formatName = "Default Full Attribute" then
			continue;
		endif;
		self.cmbFormat.addItem( format.formatName );
	endforeach;
	
	if self.cmbFormat.listCount = 1 then
		self.cmbFormat.listIndex := 1;
		self.cmbFormat.enabled := false;
	endif;

epilog

	delete xmlFormatColl;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="populateInstances" id="198ceb8e-e0c2-4c8c-b4b1-eb321de7f893">
        <updating/>
        <source>populateInstances( _class : Class; _niceName : String ) protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 September 2014	cnwndl1	Initial creation

*/

vars

	objSet : ObjectSet;
	obj : Object;
	index : Integer;
	transObjSet : ObjectSet;
	str : String;
	allSelected : Boolean;

begin

	self.chkSelectAll.value := false;
	self.myCurrentClass := _class;

	self.tblObjects.clear();
	self.shtObjects.enabled := true;
	
	if _class = null then
		self.shtObjects.enabled := false;
		return;
	endif;
	
	self.tblObjects.rows := 1;
	self.tblObjects.fixedRows := 1;
	self.tblObjects.columns := 2;
	self.tblObjects.sortColumn[1] := 2;
	self.tblObjects.accessColumn( 1 ).width := 50;
	self.tblObjects.setCellText(1,1, " " &amp; Tab &amp; _niceName );
	self.tblObjects.accessRow(1).fontBold := true;
	
	self.getSelectedObjects( _class, objSet );
	
	if objSet &lt;&gt; null and not objSet.isEmpty then
		allSelected := true;
		
		create transObjSet transient;
		if _class = CM_Organisation then
			CM_ExternalOrganisation.instances.copy(transObjSet);
			CM_InternalOrganisation.instances.copy(transObjSet);
		else
			_class.instances.copy(transObjSet);
		endif;
		
		foreach obj in transObjSet do
			if objSet.includes( obj ) then
				str := self.getNiceDisplay( _class, obj );
				index := self.tblObjects.addItem( '1' &amp; Tab &amp; str );
				self.tblObjects.accessRow(index).itemObject := obj;
			else
				str := self.getNiceDisplay( _class, obj );
				index := self.tblObjects.addItem( '0' &amp; Tab &amp; str );
				self.tblObjects.accessRow(index).itemObject := obj;
				allSelected := false;
			endif;
			if self.tblObjects.rows &gt;= 31999 then
				app.msgBox("More than 32000 items in collection, only 32000 displayed.","Warning",MsgBox_OK_Only);
				break;
			endif;
		endforeach;
		
		self.chkSelectAll.value := allSelected;

	else
	
		create transObjSet transient;
		if _class = CM_Organisation then
			CM_ExternalOrganisation.instances.copy(transObjSet);
			CM_InternalOrganisation.instances.copy(transObjSet);
		else
			_class.instances.copy(transObjSet);
		endif;
		
		foreach obj in transObjSet do
			str := self.getNiceDisplay( _class, obj );
			index := self.tblObjects.addItem( '0' &amp; Tab &amp; str );
			self.tblObjects.accessRow(index).itemObject := obj;
			if self.tblObjects.rows &gt;= 31999 then
				app.msgBox("More than 32000 items in collection, only 32000 displayed.","Warning",MsgBox_OK_Only);
				break;
			endif;
		endforeach;	
		
	endif;

epilog

	delete transObjSet;

end;</source>
        <access>protected</access>
        <Parameter name="_class" type="Class"/>
        <Parameter name="_niceName" type="String"/>
    </JadeMethod>
    <JadeMethod name="selectClass" id="2e160c6f-1090-4979-89db-20540d08ed08">
        <updating/>
        <source>selectClass() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 September 2014	cnwndl1	Initial creation

*/

vars

	class : Class;
	niceName : String;

begin

	class := self.tblClasses.accessRow( self.tblClasses.row ).itemObject.Class;
	if class &lt;&gt; null then
		niceName := self.tblClasses.getCellText( self.tblClasses.row, 1 );
		self.populateInstances( class, niceName &amp; "(s)" );
		self.fldBaseCode.topSheet := self.shtObjects;
	endif;

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="selectFile" id="e7b788ed-decc-4799-9950-9f4de38e38e9">
        <updating/>
        <source>selectFile(pTextBox : TextBox io) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 September 2014	cnwndl1	Initial creation

*/

vars
 	fileOpenObj	: CMDFileOpen;
 	textboxObj	: TextBox;
 	
begin
	textboxObj	:=	pTextBox;
	create fileOpenObj transient;
	
	if fileOpenObj.open() = 0 then
		textboxObj.text := fileOpenObj.fileName;
	else
		textboxObj.text := "";
	endif;
epilog
	delete fileOpenObj;	
end;</source>
        <access>protected</access>
        <Parameter name="pTextBox" type="TextBox" usage="io"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="22ae56d7-4691-4153-a2d7-002f7aad3eba">
