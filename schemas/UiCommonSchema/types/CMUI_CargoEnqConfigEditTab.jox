    <JadeMethod name="doCancel" id="9989b741-c17a-4001-9b51-2fd6a4e3ae93">
        <updating/>
        <source>doCancel() updating;

vars

begin
	self.cancelled := true;

	unloadForm;
end;
</source>
    </JadeMethod>
    <JadeMethod name="doSave" id="fb0e0421-9f65-431c-85ac-f2f712aeab5c">
        <updating/>
        <source>doSave() updating;
// myUserConfigTab is a transient so can update it directly
vars
	isOK	: Boolean;
	tabDescription,
	tabName	: String;
begin

	tabDescription := txtTabName.text.trimBlanks();
	tabName := tabDescription;
	if tabDescription &lt;&gt; null then
		isOK := self.myConfigForm.checkForDuplicates(tabDescription, self.myUserConfigTab);
		if not isOK then
			app.msgBox(app.getErrorString1(Already_used_tab_name, tabDescription), app.getErrorString(Error), MsgBox_OK_Only);
			return;
		endif;

		if self.myUserConfigTab = null then
			create self.myUserConfigTab transient;
		else
			tabName := self.myUserConfigTab.name;
		endif;
		self.myUserConfigTab.setup(tabDescription, tabName, 0, self.myUserCargoType);
	endif;
	
	unloadForm();
end;
</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="3decab42-a7c6-49d9-af81-91771c4caa92">
        <updating/>
        <source>setupForm() updating;

vars

begin
	if self.myUserConfigTab = null then
		self.caption := app.getErrorString(Add_Tab);
	else
		self.caption := app.getErrorString(Rename_Tab);
		self.txtTabName.text := self.myUserConfigTab.description;
	endif;

	inheritMethod();
end;
</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="f236b5b1-d82f-4c04-bb8c-8746ca72afd2">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0016848, locale);
	btnCancel.translateCaption(Xlat_0016864, locale);
	btnSave.translateCaption(Xlat_0016865, locale);
	lblTabName.translateCaption(Xlat_0016866, locale);
end;</source>
    </JadeMethod>
</GUIClass>
