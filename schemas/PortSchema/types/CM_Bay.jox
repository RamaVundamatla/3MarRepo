    <JadeMethod name="setProxy" id="19104e5c-ee41-433a-a853-4983b20ab0b3">
        <updating/>
        <source>setProxy(_id,_idBay40,_lashFromTier,_unlashFromTier,_remarks:String;
		_ordinalBay,_bayType,_maxPileWeight20IB,_maxPileWeight20OB,_maxPileWeight40IB,_maxPileWeight40OB,_maxPileWeightUD,_numOfPlugs,_ordinalHold:Integer;
		_athwartships,_fortyFootBay,_fortyFootOnly,_useCellTierODSequencing,_useCellTierUDSequencing, _useCellTierODSequencing40, _useCellTierUDSequencing40,_isTwinLiftOD,_isTwinLiftUD :Boolean;
		_theHold : CM_Hold; _fortyFiveFootBay,_fortyFiveFootOnly: Boolean) updating;
// ---------------------------------------------------------------------------
// Created:     12 June 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin

	self.athwartships := _athwartships;
	self.bayType := _bayType;
	self.fortyFootBay := _fortyFootBay;
	self.fortyFootOnly := _fortyFootOnly;
	self.fortyFiveFootBay := _fortyFiveFootBay;
	self.fortyFiveFootOnly := _fortyFiveFootOnly;
//	self.hasRemarks := _hasRemarks;
	self.id := _id;
	self.idBay40 := _idBay40;
	self.lashFromTier := _lashFromTier;
	self.isTwinLiftOD := _isTwinLiftOD;
	self.isTwinLiftUD := _isTwinLiftUD;
	self.maxPileWeight20IB := _maxPileWeight20IB;
	self.maxPileWeight20OB := _maxPileWeight20OB;
	self.maxPileWeight40IB := _maxPileWeight40IB;
	self.maxPileWeight40OB := _maxPileWeight40OB;
	self.maxPileWeightUD := _maxPileWeightUD;
	self.numOfPlugs := _numOfPlugs;
	self.ordinalBay := _ordinalBay;
//	self.ordinalHold := _ordinalHold;
	self.remarks := _remarks.trimBlanks;
	self.unlashFromTier := _unlashFromTier;
	self.useCellTierODSequencing := _useCellTierODSequencing;
	self.useCellTierUDSequencing := _useCellTierUDSequencing;
	self.useCellTierODSequencing40 := _useCellTierODSequencing40;
	self.useCellTierUDSequencing40 := _useCellTierUDSequencing40;
	self.myHold := _theHold;
end;</source>
