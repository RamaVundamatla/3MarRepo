    <JadeMethod name="tUSCustomsMessageAction" id="60afe415-6b2a-4b8d-9902-165471428313">
        <source>tUSCustomsMessageAction();
//
//14 August 2017	jlgrs1	Initial creation
//
constants
	USER_DEF_NAME : String = "JMTInternalUSCustomsMessage";
	CONTAINERID : String = "SARG1234543";
	VOYAGECODE = 'VOY27418';
	VESSELNAME = 'SHIP27418';
	OPERATORCODE = 'MSK';
	BookingId1 = 'BK27418';
	BlockStackName	= 'BS26728';
	BOLID : String = 'BOLIN_22345';
	STOP_ID	: Integer = 304;
	STOP_ID_OTH	: Integer = 305;
vars
	ediFileObj : CM_EDIFile;
	ediDataObj : CM_EDIData;
	vessel : CM_Vessel;
	voyage : CM_Voyage;
	operator : CM_Operator;
	bs : CM_BlockStack;
	container : CM_Container;
	bolIn : CM_BOLIn;
	stopsTable : CM_StopsTable;
	stopsTableOther : CM_StopsTable;
	passportObj : CM_Passport;
	ediText : String;
	errorMsg : String;
begin
	passportObj := app.myPassport;
	stopsTable := app.myRoot.allStopsTable[STOP_ID];
	stopsTableOther := app.myRoot.allStopsTable[STOP_ID_OTH];
	beginTransaction;							// 28/07/2014 cnwmh5
	stopsTable.setPropertyValue("isNotAvailableForEntry", false);
	stopsTableOther.setPropertyValue("isNotAvailableForEntry", false);
	commitTransaction;
	operator := self.getOperator(OPERATORCODE);
	self.deleteVoyage(VOYAGECODE);
	voyage := self.getVoyage(VOYAGECODE);
	self.assertIsDeleted(voyage);
	self.deleteVessel(VESSELNAME);
	vessel := self.getVessel(VESSELNAME);
	self.assertIsDeleted(vessel);
	self.deleteContainer(CONTAINERID);
	container := self.getTrackedItem(CONTAINERID).CM_Container;
	self.assertIsDeleted(container);
	vessel := self.addVesselCellular(VESSELNAME,
										operator);
	self.assertNotNullMsg(vessel, 'Add vessel failed');
	
	voyage := self.addVoyageWithContainerStructur(VOYAGECODE,
													VESSELNAME,
													OPERATORCODE,
													self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	self.assertNotNullMsg(voyage, 'Add voyage failed');
	self.deleteTerminalArea(BlockStackName);
	bs := self.getTerminalArea(BlockStackName).CM_BlockStack;
	self.assertIsDeleted(bs);

	// Delete and add the required bookings
	self.opts.addAssoc('Stock', true);
	self.opts.addAssocIfNotNull(ETRow_PackAs, app.getString(PackAs_LCL));
	self.deleteBooking(BookingId1);
	container := self.addContainerOnShip(CONTAINERID, operator, "4102", "GOLD", BookingId1, voyage, self.getTerminal.getConfig(PortDestCode).String, "010682").CM_Container;
	bs := addBlockStack(BlockStackName, 100, null);
	self.opts.addAssoc('IsForcedMove', true);
	self.move(container, bs);
	self.deleteBOL(BOLID, null);
	bolIn := self.addBOL(BOLID, voyage, operator, null, self.getTerminal).CM_BOLIn;
	ediText :=
'&lt;?xml version="1.0"?&gt;
&lt;JMTInternalUSCustomsMessage xmlns:xsi="http://www.jademasterterminallogistics.com/JMTInternal" xsi:noNamespaceSchemaLocation="JMTInternalUSCustomsMessage.xsd"&gt;
	&lt;AllUSCustomsMessage&gt;
		&lt;USCustomsMessage&gt;
			&lt;postedDate/&gt;
			&lt;controlNumber/&gt;
			&lt;quantity/&gt;
			&lt;billOfLading&gt;'&amp;BOLID&amp;'&lt;/billOfLading&gt;
			&lt;cargoTypeDescr/&gt;
			&lt;description/&gt;
			&lt;dispositionCode&gt;3C&lt;/dispositionCode&gt;
			&lt;ediFileVoyageCode/&gt;
			&lt;entryNumber/&gt;
			&lt;entryType/&gt;
			&lt;fullOrMT/&gt;
			&lt;id&gt;'&amp;CONTAINERID&amp;'&lt;/id&gt;
			&lt;messageMode&gt;A&lt;/messageMode&gt;
			&lt;portForeign/&gt;
			&lt;portInBond/&gt;
			&lt;portInTransit/&gt;
			&lt;portOfEntry&gt;NZPOE&lt;/portOfEntry&gt;
			&lt;remarks/&gt;
			&lt;vesselCode&gt;'&amp;VESSELNAME&amp;'&lt;/vesselCode&gt;
			&lt;vesselName&gt;'&amp;VESSELNAME&amp;'&lt;/vesselName&gt;
			&lt;voyageCode&gt;'&amp;VOYAGECODE&amp;'&lt;/voyageCode&gt;
			&lt;voyageOperator&gt;MSK&lt;/voyageOperator&gt;
			&lt;postedTime/&gt;
			&lt;processedDT/&gt;
		&lt;/USCustomsMessage&gt;
	&lt;/AllUSCustomsMessage&gt;
&lt;/JMTInternalUSCustomsMessage&gt;';

	ediFileObj := self.ediLoadFileName(ediText, EDIFileType_Unknown, USER_DEF_NAME, USER_DEF_NAME&amp;method.name);

	self.assertNotNull(ediFileObj);
	self.assertEqualMsg(true, passportObj.allErrors.isEmpty(), passportObj.getAllErrorsWarningsAsString());	// cnwrl1 25/08/2010 PAR 25559
	self.assertNotNull(ediFileObj.ediData);		// cnwrl1 25/08/2010 PAR 25559
	self.ediVerify(ediFileObj);
	errorMsg := "Verify Failed" &amp; CrLf &amp; passportObj.getErrorsAsString();
	// Status 3 is verify status and 14 is verified with warnings.
//	self.assertIsOneOf(	ediFileObj.fileStatus,
//						errorMsg,
//						CM_EDIFile.EDI_STATUS_VERIFIED,
//						CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS);
	self.assertEqualMsg(ediFileObj.fileStatus, CM_EDIFile.EDI_STATUS_VERIFIED, errorMsg);
	ediDataObj := ediFileObj.ediData;
	self.ediDBLoad(ediFileObj);
//	self.assertIsOneOf(	ediFileObj.fileStatus,
//						"Load Failed",
//						CM_EDIFile.EDI_STATUS_DBLOADED,
//						CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL);
	errorMsg := "DB Load Failed" &amp; CrLf &amp; passportObj.getErrorsAsString();
	self.assertEqualMsg(ediFileObj.fileStatus, CM_EDIFile.EDI_STATUS_DBLOADED, errorMsg);
	if ediFileObj.fileStatus = CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL then
		write "EDI message not fully loaded - needs a re-run.";
	endif;
	self.assertEqualMsg(ediDataObj.allEDITrackedItems.size, 1, "incorrect number of EDI trackedItems");
	container := self.getTrackedItem(CONTAINERID).CM_Container;
	self.assertNotNull(container);
	self.assertEqualMsg(container.remarks.trimBlanks, "Created by unit test UT_EDIJMTInternal::tUSCustomsMessageAction"&amp;CrLf, "wrong remarks");
epilog
	beginTransaction;							// 28/07/2014 cnwmh5
	stopsTable.setPropertyValue("isNotAvailableForEntry", true);
	stopsTableOther.setPropertyValue("isNotAvailableForEntry", true);
	commitTransaction;
end;
</source>
    </JadeMethod>
    <JadeMethod name="tVGM" id="5269b80a-c95d-48d7-a720-6e0b05d30765">
        <source>tVGM();
//
//05 Apr 2016	cnwrs1	TFS 1600 VERMAS EDI
//
constants
	USER_DEF_NAME : String = "JMTInternalVGM";
vars
	ediFileObj : CM_EDIFile;
	ediDataObj : CM_EDIData;
	passportObj : CM_Passport;
	ediText : String;
	errorMsg : String;
	tempStr : String;
	ti : CM_TrackedItem;
	weight : Decimal[14,4];
begin
	self.deleteContainer("UTCL0111");
	self.deleteContainer("UTCL0121");
	self.deleteContainer("UTCL0131");
	self.deleteContainer("UTCL0141");
	self.createContainer("UTCL0111", "2200", "GENL", self.getOperator("MSK"), false);
	self.createContainer("UTCL0121", "2200", "GENL", self.getOperator("MSK"), false);
	self.createContainer("UTCL0131", "2200", "GENL", self.getOperator("MSK"), false);
	self.createContainer("UTCL0141", "2200", "GENL", self.getOperator("MSK"), false);
	passportObj	:=	app.myPassport;
	ediText :=
'
&lt;?xml version="1.0"?&gt;
&lt;JMTInternalVGM xmlns:xsi="http://www.jademasterterminallogistics.com/JMTInternal" xsi:noNamespaceSchemaLocation="JMTInternalVGM.xsd"&gt;
  &lt;AllVerifiedGrossMass&gt;
    &lt;VerifiedGrossMass&gt;
      &lt;totalWeight&gt;25000.0000&lt;/totalWeight&gt;
      &lt;cargoTypeDescr&gt;ISO Container&lt;/cargoTypeDescr&gt;
      &lt;id&gt;UTCL0111&lt;/id&gt;
      &lt;weightCertifiedReference&gt;Kazakhstan Weight Ltd&lt;/weightCertifiedReference&gt;
      &lt;weightCertifiedName&gt;Borat Sagdiyev&lt;/weightCertifiedName&gt;
    &lt;/VerifiedGrossMass&gt;
    &lt;VerifiedGrossMass&gt;
      &lt;totalWeight&gt;26000.0000&lt;/totalWeight&gt;
      &lt;cargoTypeDescr&gt;ISO Container&lt;/cargoTypeDescr&gt;
      &lt;id&gt;UTCL0121&lt;/id&gt;
      &lt;weightCertifiedReference&gt;Kazakhstan Other Weight Ltd&lt;/weightCertifiedReference&gt;
      &lt;weightCertifiedName&gt;Borat Sagdiyev&lt;/weightCertifiedName&gt;
    &lt;/VerifiedGrossMass&gt;
    &lt;VerifiedGrossMass&gt;
      &lt;totalWeight&gt;27000.0000&lt;/totalWeight&gt;
      &lt;cargoTypeDescr&gt;ISO Container&lt;/cargoTypeDescr&gt;
      &lt;id&gt;UTCL0131&lt;/id&gt;
      &lt;weightCertifiedReference&gt;Kazakhstan Weight Ltd&lt;/weightCertifiedReference&gt;
      &lt;weightCertifiedName&gt;Borat Sagdiyev&lt;/weightCertifiedName&gt;
    &lt;/VerifiedGrossMass&gt;
    &lt;VerifiedGrossMass&gt;
      &lt;totalWeight&gt;28000.0000&lt;/totalWeight&gt;
      &lt;cargoTypeDescr&gt;ISO Container&lt;/cargoTypeDescr&gt;
      &lt;id&gt;UTCL0141&lt;/id&gt;
      &lt;weightCertifiedReference&gt;Kazakhstan Other Weight Ltd&lt;/weightCertifiedReference&gt;
      &lt;weightCertifiedName&gt;Borat Sagdiyev&lt;/weightCertifiedName&gt;
    &lt;/VerifiedGrossMass&gt;
  &lt;/AllVerifiedGrossMass&gt;
&lt;/JMTInternalVGM&gt;
';
	ediFileObj := self.ediLoadFileName(ediText, EDIFileType_Unknown, USER_DEF_NAME, USER_DEF_NAME&amp;method.name);

	self.assertNotNull(ediFileObj);
	self.assertEqualMsg(true, passportObj.allErrors.isEmpty(), passportObj.getAllErrorsWarningsAsString());	// cnwrl1 25/08/2010 PAR 25559
	self.assertNotNull(ediFileObj.ediData);		// cnwrl1 25/08/2010 PAR 25559
	self.ediVerify(ediFileObj);
	errorMsg := "Verify Failed" &amp; CrLf &amp; passportObj.getErrorsAsString();
	// Status 3 is verify status and 14 is verified with warnings.
//	self.assertIsOneOf(	ediFileObj.fileStatus,
//						errorMsg,
//						CM_EDIFile.EDI_STATUS_VERIFIED,
//						CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS);
	self.assertEqualMsg(ediFileObj.fileStatus, CM_EDIFile.EDI_STATUS_VERIFIED, errorMsg);
	ediDataObj := ediFileObj.ediData;
	self.ediDBLoad(ediFileObj);
//	self.assertIsOneOf(	ediFileObj.fileStatus,
//						"Load Failed",
//						CM_EDIFile.EDI_STATUS_DBLOADED,
//						CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL);
	errorMsg := "DB Load Failed" &amp; CrLf &amp; passportObj.getErrorsAsString();
	self.assertEqualMsg(ediFileObj.fileStatus, CM_EDIFile.EDI_STATUS_DBLOADED, errorMsg);
	
	if ediFileObj.fileStatus = CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL then
		write "EDI message not fully loaded - needs a re-run.";
	endif;
	self.assertEqualMsg(ediDataObj.allEDITrackedItems.size, 4, "incorrect number of EDI trackedItems");
	ti := self.getTrackedItem("UTCL0111");
	self.assertNotNull(ti);
	weight := 25000;
	self.assertEqualMsg(ti.totalWeight.String, weight.String, "incorrect weight");
	self.assertEqualMsg(ti.isWeightCertified, true, "weight not certified");
	self.assertEqualMsg(ti.weightCertifiedReference, "KAZAKHSTAN WEIGHT LTD", "incorrect Weight Certified Reference");
    self.assertEqualMsg(ti.weightCertifiedName, "BORAT SAGDIYEV", "incorrect Weight Certified Name");
	ti := self.getTrackedItem("UTCL0121");
	self.assertNotNull(ti);
	weight := 26000;
	self.assertEqualMsg(ti.totalWeight.String, weight.String, "incorrect weight");
	self.assertEqualMsg(ti.isWeightCertified, true, "weight not certified");
	self.assertEqualMsg(ti.weightCertifiedReference, "KAZAKHSTAN OTHER WEIGHT LTD", "incorrect Weight Certified Reference");
    self.assertEqualMsg(ti.weightCertifiedName, "BORAT SAGDIYEV", "incorrect Weight Certified Name");
	ti := self.getTrackedItem("UTCL0131");
	self.assertNotNull(ti);
	weight := 27000;
	self.assertEqualMsg(ti.totalWeight, weight, "incorrect weight");
	self.assertEqualMsg(ti.isWeightCertified, true, "weight not certified");
	self.assertEqualMsg(ti.weightCertifiedReference, "KAZAKHSTAN WEIGHT LTD", "incorrect Weight Certified Reference");
    self.assertEqualMsg(ti.weightCertifiedName, "BORAT SAGDIYEV", "incorrect Weight Certified Name");
	ti := self.getTrackedItem("UTCL0141");
	self.assertNotNull(ti);
	weight := 28000;
	self.assertEqualMsg(ti.totalWeight, weight, "incorrect weight");
	self.assertEqualMsg(ti.isWeightCertified, true, "weight not certified");
	self.assertEqualMsg(ti.weightCertifiedReference, "KAZAKHSTAN OTHER WEIGHT LTD", "incorrect Weight Certified Reference");
    self.assertEqualMsg(ti.weightCertifiedName, "BORAT SAGDIYEV", "incorrect Weight Certified Name");
end;</source>
    </JadeMethod>
    <JadeMethod name="tVGMAction" id="dc31c522-206a-4b7f-8d2e-c1a35112ba2c">
        <source>tVGMAction();
//
//14 August 2017	jlgrs1	Initial creation
// 10 Sep 2019	cnwrs1	TFS 46030
//
constants
	USER_DEF_NAME : String = "JMTInternalVGM";
	CONTAINERID : String = "SARG1234543";
	VOYAGECODE = 'VOY27418';
	VESSELNAME = 'SHIP27418';
	OPERATORCODE = 'MSK';
	BookingId1 = 'BK27418';
	BlockStackName	= 'BS26728';
vars
	ediFileObj : CM_EDIFile;
	ediDataObj : CM_EDIData;
	vessel : CM_Vessel;
	voyage : CM_Voyage;
	operator : CM_Operator;
	bs : CM_BlockStack;
	container : CM_Container;
	passportObj : CM_Passport;
	ediText : String;
	errorMsg : String;
	isDoClearanceCheck : Boolean;
begin
	isDoClearanceCheck := self.getMyTerminal.myHarbour.isDoClearanceCheck;
	self.setHarbourIsDoClearanceCheck(false);
	passportObj := app.myPassport;
	operator := self.getOperator(OPERATORCODE);
	self.deleteVoyage(VOYAGECODE);
	voyage := self.getVoyage(VOYAGECODE);
	self.assertIsDeleted(voyage);
	self.deleteVessel(VESSELNAME);
	vessel := self.getVessel(VESSELNAME);
	self.assertIsDeleted(vessel);
	self.deleteContainer(CONTAINERID);
	container := self.getTrackedItem(CONTAINERID).CM_Container;
	self.assertIsDeleted(container);
	vessel := self.addVesselCellular(VESSELNAME,
										operator);
	self.assertNotNullMsg(vessel, 'Add vessel failed');
	
	voyage := self.addVoyageWithContainerStructur(VOYAGECODE,
													VESSELNAME,
													OPERATORCODE,
													self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	self.assertNotNullMsg(voyage, 'Add voyage failed');
	self.deleteTerminalArea(BlockStackName);
	bs := self.getTerminalArea(BlockStackName).CM_BlockStack;
	self.assertIsDeleted(bs);

	// Delete and add the required bookings
	self.opts.addAssoc('Stock', true);
	self.opts.addAssocIfNotNull(ETRow_PackAs, app.getString(PackAs_LCL));
	self.deleteBooking(BookingId1);
	container := self.addContainerOnShip(CONTAINERID, operator, "4102", "GOLD", BookingId1, voyage, self.getTerminal.getConfig(PortDestCode).String, "010682").CM_Container;
	bs := addBlockStack(BlockStackName, 100, null);
	self.opts.addAssoc('IsForcedMove', true);
	self.move(container, bs);
	ediText :=
'&lt;?xml version="1.0"?&gt;
&lt;JMTInternalVGM xmlns:xsi="http://www.jademasterterminallogistics.com/JMTInternal" xsi:noNamespaceSchemaLocation="JMTInternalVGM.xsd"&gt;
	&lt;AllVerifiedGrossMass&gt;
		&lt;VerifiedGrossMass&gt;
			&lt;totalWeight&gt;4231&lt;/totalWeight&gt;
			&lt;cargoTypeDescr&gt;ISO Container&lt;/cargoTypeDescr&gt;
			&lt;description/&gt;
			&lt;fullOrMT/&gt;
			&lt;id&gt;'&amp;CONTAINERID&amp;'&lt;/id&gt;
			&lt;messageMode&gt;A&lt;/messageMode&gt;
			&lt;vgmAuthSignature/&gt;
			&lt;vgmCommsType/&gt;
			&lt;vgmDocumentDetails/&gt;
			&lt;vgmEDITransmission/&gt;
			&lt;vgmElectronicMail/&gt;
			&lt;vgmMail/&gt;
			&lt;vgmPhone&gt;1234567890&lt;/vgmPhone&gt;
			&lt;vgmTelefax/&gt;
			&lt;vgmTelephone/&gt;
			&lt;weightCertifiedName/&gt;
			&lt;weightCertifiedReference/&gt;
			&lt;vgmDeterminationDT/&gt;
			&lt;vgmDocsIssuedDT/&gt;
		&lt;/VerifiedGrossMass&gt;
	&lt;/AllVerifiedGrossMass&gt;
&lt;/JMTInternalVGM&gt;';

	ediFileObj := self.ediLoadFileName(ediText, EDIFileType_Unknown, USER_DEF_NAME, USER_DEF_NAME&amp;method.name);

	self.assertNotNull(ediFileObj);
	self.assertEqualMsg(true, passportObj.allErrors.isEmpty(), passportObj.getAllErrorsWarningsAsString());	// cnwrl1 25/08/2010 PAR 25559
	self.assertNotNull(ediFileObj.ediData);		// cnwrl1 25/08/2010 PAR 25559
	self.ediVerify(ediFileObj);
	errorMsg := "Verify Failed" &amp; CrLf &amp; passportObj.getErrorsAsString();
	// Status 3 is verify status and 14 is verified with warnings.
//	self.assertIsOneOf(	ediFileObj.fileStatus,
//						errorMsg,
//						CM_EDIFile.EDI_STATUS_VERIFIED,
//						CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS);
	self.assertEqualMsg(ediFileObj.fileStatus, CM_EDIFile.EDI_STATUS_VERIFIED, errorMsg);
	ediDataObj := ediFileObj.ediData;
	self.ediDBLoad(ediFileObj);
//	self.assertIsOneOf(	ediFileObj.fileStatus,
//						"Load Failed",
//						CM_EDIFile.EDI_STATUS_DBLOADED,
//						CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL);
	errorMsg := "DB Load Failed" &amp; CrLf &amp; passportObj.getErrorsAsString();
	self.assertEqualMsg(ediFileObj.fileStatus, CM_EDIFile.EDI_STATUS_DBLOADED, errorMsg);
	if ediFileObj.fileStatus = CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL then
		write "EDI message not fully loaded - needs a re-run.";
	endif;
	self.assertEqualMsg(ediDataObj.allEDITrackedItems.size, 1, "incorrect number of EDI trackedItems");
	container := self.getTrackedItem(CONTAINERID).CM_Container;
	self.assertNotNull(container);
	self.assertNotEqualMsg(container.getMyVGMDetails(), null, "incorrect hasVGMDetails");
	self.assertEqualMsg(container.getMyVGMDetails().vgmPhone, "1234567890", "VGM Phone incorrect");
	self.assertEqualMsg(container.remarks.trimBlanks, "Created by unit test UT_EDIJMTInternal::tVGMAction"&amp;CrLf, "wrong remarks");
epilog
	self.setHarbourIsDoClearanceCheck(isDoClearanceCheck);
end;
</source>
    </JadeMethod>
    <JadeMethod name="tVehicleAction" id="ad1bd7d5-6ee9-4427-b306-348c61382c4b">
        <source>tVehicleAction();
//
//14 August 2017	jlgrs1	Initial creation
//
constants
	USER_DEF_NAME : String = "JMTInternalVehicle";
	VEHICLE : String = "UT_Vehicle";
vars
	ediFileObj : CM_EDIFile;
	ediDataObj : CM_EDIData;
	passportObj : CM_Passport;
	vehicle : CM_Vehicle;
	ediText : String;
	errorMsg : String;
begin

	passportObj := app.myPassport;
	self.deleteVehicle(VEHICLE);
	vehicle := self.getVehicle(VEHICLE);
	self.assertIsDeleted(vehicle);
	ediText :=
'&lt;?xml version="1.0"?&gt;
&lt;JMTInternalVehicle xmlns:xsi="http://www.jademasterterminallogistics.com/JMTInternal" xsi:noNamespaceSchemaLocation="JMTInternalVehicle.xsd"&gt;
	&lt;AllVehicle&gt;
		&lt;Vehicle&gt;
			&lt;maxGross/&gt;
			&lt;tareWeight/&gt;
			&lt;action&gt;A&lt;/action&gt;
			&lt;cargoTypeDescr/&gt;
			&lt;carrierCode&gt;DOUG&lt;/carrierCode&gt;
			&lt;description/&gt;
			&lt;fullOrMT/&gt;
			&lt;id/&gt;
			&lt;messageMode&gt;A&lt;/messageMode&gt;
			&lt;notAvailable/&gt;
			&lt;regNumber&gt;'&amp;VEHICLE&amp;'&lt;/regNumber&gt;
			&lt;state/&gt;
		&lt;/Vehicle&gt;
	&lt;/AllVehicle&gt;
&lt;/JMTInternalVehicle&gt;';

	ediFileObj := self.ediLoadFileName(ediText, EDIFileType_Unknown, USER_DEF_NAME, USER_DEF_NAME&amp;method.name);

	self.assertNotNull(ediFileObj);
	self.assertEqualMsg(true, passportObj.allErrors.isEmpty(), passportObj.getAllErrorsWarningsAsString());	// cnwrl1 25/08/2010 PAR 25559
	self.assertNotNull(ediFileObj.ediData);		// cnwrl1 25/08/2010 PAR 25559
	self.ediVerify(ediFileObj);
	errorMsg := "Verify Failed" &amp; CrLf &amp; passportObj.getErrorsAsString();
	// Status 3 is verify status and 14 is verified with warnings.
//	self.assertIsOneOf(	ediFileObj.fileStatus,
//						errorMsg,
//						CM_EDIFile.EDI_STATUS_VERIFIED,
//						CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS);
	self.assertEqualMsg(ediFileObj.fileStatus, CM_EDIFile.EDI_STATUS_VERIFIED, errorMsg);
	ediDataObj := ediFileObj.ediData;
	self.ediDBLoad(ediFileObj);
//	self.assertIsOneOf(	ediFileObj.fileStatus,
//						"Load Failed",
//						CM_EDIFile.EDI_STATUS_DBLOADED,
//						CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL);
	errorMsg := "DB Load Failed" &amp; CrLf &amp; passportObj.getErrorsAsString();
	self.assertEqualMsg(ediFileObj.fileStatus, CM_EDIFile.EDI_STATUS_DBLOADED, errorMsg);
	if ediFileObj.fileStatus = CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL then
		write "EDI message not fully loaded - needs a re-run.";
	endif;
	self.assertEqualMsg(ediDataObj.allEDITrackedItems.size, 1, "incorrect number of EDI trackedItems");
	vehicle := self.getVehicle(VEHICLE);
	self.assertNotNull(vehicle);
	self.assertEqualMsg(vehicle.carrierCode, "DOUG", "wrong carrier code");
end;
</source>
    </JadeMethod>
    <JadeMethod name="tVoyage" id="539aca1f-0acd-40e3-b30b-f1bb4738c95d">
        <source>tVoyage();
//
// 27 Aug 2014	cnwrs1	Par 34702 - Add support for JMT XML
//
// 10 Sep 2019	cnwrs1	TFS 46030
//
constants
	VESSEL_CODE	: String = "Ship001C";
	VOYAGE_CODE	: String = "VOY002084";
	TestOperator = 'MSK';
	USER_DEF_NAME : String = "JMTInternalVoyage";
vars
	ediFileObj : CM_EDIFile;
	ediDataObj : CM_EDIData;
	passportObj : CM_Passport;
	ediText : String;
	errorMsg : String;
	vessel : CM_Vessel;
	voyage : CM_Voyage;
	aDate : Date;
	dDate : Date;
	globalVoyage : CM_VoyageGlobal;
	isDoClearanceCheck : Boolean;
begin
	isDoClearanceCheck := self.getMyTerminal.myHarbour.isDoClearanceCheck;
	self.setHarbourIsDoClearanceCheck(false);
	globalVoyage := app.myRoot.allVoyagesGlobal[VOYAGE_CODE];
	if globalVoyage &lt;&gt; null then
		beginTransaction;
		globalVoyage.erase(NORMAL_ERASE);
		commitTransaction;
	endif;
	passportObj	:=	app.myPassport;
	self.deleteVoyage(VOYAGE_CODE);
	voyage := self.getVoyage(VOYAGE_CODE);
	self.assertIsDeleted(voyage);
	
	self.deleteVessel(VESSEL_CODE);
	vessel := self.getVessel(VESSEL_CODE);
	self.assertIsDeleted(vessel);
	
	// now set up cleanly
	self.opts.addAssoc(UTVS_Bays, 24);
	vessel := self.addVesselCellular(VESSEL_CODE, self.getOperator(TestOperator));
	self.assertNotNullMsg(vessel, 'Add vessel failed');

	self.opts.addAssoc("useHMSData", true);		// 9/9/19 MAP
	aDate := aDate.cnEcAddDays(-3); // 3 days ago

	self.opts.addAssoc("dateArrival", aDate);
	dDate := aDate.addDays(4); // 1 day a go
	self.opts.addAssoc("dateDeparture", dDate);
	voyage	:= self.addVoyageWithContainerStructur(VOYAGE_CODE,
													VESSEL_CODE,
													TestOperator, 
													self.getProfileSetting( UT_Profile.P_SHIPPING_LINE ).asString);
	self.assertNotNullMsg( voyage, 'Add voyage failed' );
	voyage := self.getVoyage(VOYAGE_CODE);
	self.assertNotNull(voyage);
	aDate := aDate.cnEcAddDays(-1); // 3 days ago
	dDate := dDate.cnEcAddDays(20); // 3 days ago
	ediText :=
'
&lt;?xml version="1.0" encoding="UTF-8"?&gt;
&lt;JMTInternalVoyage&gt;
&lt;AllVoyage&gt;
&lt;Voyage&gt;
&lt;cargoTypeDescr&gt;ISO Container&lt;/cargoTypeDescr&gt;
&lt;id&gt;00000001&lt;/id&gt;
&lt;inwardCode&gt;'&amp;VOYAGE_CODE&amp;'S&lt;/inwardCode&gt;
&lt;messageMode&gt;A&lt;/messageMode&gt;
&lt;operatorCode&gt;MAERSK&lt;/operatorCode&gt;
&lt;shippingLineCode&gt;AZL&lt;/shippingLineCode&gt;
&lt;tradeDesc&gt;Unit Test Trade&lt;/tradeDesc&gt;
&lt;vesselName&gt;'&amp;VESSEL_CODE&amp;'&lt;/vesselName&gt;
&lt;voyageCode&gt;'&amp;VOYAGE_CODE&amp;'&lt;/voyageCode&gt;
&lt;scheduledArrivalDT&gt;'&amp;aDate.format('dd MMMM yyyy')&amp;', 00:00:00&lt;/scheduledArrivalDT&gt;
&lt;scheduledDepartureDT&gt;'&amp;dDate.format('dd MMMM yyyy')&amp;', 00:00:00&lt;/scheduledDepartureDT&gt;
&lt;AllPort&gt;
&lt;Port&gt;
&lt;position&gt;3&lt;/position&gt;
&lt;cargoTypeDescr&gt;ISO Container&lt;/cargoTypeDescr&gt;
&lt;id&gt;AUSYD&lt;/id&gt;
&lt;messageMode&gt;A&lt;/messageMode&gt;
&lt;voyageCode&gt;'&amp;VOYAGE_CODE&amp;'&lt;/voyageCode&gt;
&lt;/Port&gt;
&lt;Port&gt;
&lt;position&gt;1&lt;/position&gt;
&lt;cargoTypeDescr&gt;ISO Container&lt;/cargoTypeDescr&gt;
&lt;id&gt;NZAKL&lt;/id&gt;
&lt;messageMode&gt;A&lt;/messageMode&gt;
&lt;voyageCode&gt;'&amp;VOYAGE_CODE&amp;'&lt;/voyageCode&gt;
&lt;/Port&gt;
&lt;Port&gt;
&lt;position&gt;2&lt;/position&gt;
&lt;cargoTypeDescr&gt;ISO Container&lt;/cargoTypeDescr&gt;
&lt;id&gt;SGSIN&lt;/id&gt;
&lt;messageMode&gt;A&lt;/messageMode&gt;
&lt;voyageCode&gt;'&amp;VOYAGE_CODE&amp;'&lt;/voyageCode&gt;
&lt;/Port&gt;
&lt;/AllPort&gt;
&lt;/Voyage&gt;
&lt;/AllVoyage&gt;
&lt;/JMTInternalVoyage&gt;
';
	ediFileObj := self.ediLoadFileName(ediText, EDIFileType_Unknown, USER_DEF_NAME, USER_DEF_NAME&amp;method.name);

	self.assertNotNull(ediFileObj);
	self.assertEqualMsg(true, passportObj.allErrors.isEmpty(), passportObj.getAllErrorsWarningsAsString());	// cnwrl1 25/08/2010 PAR 25559
	self.assertNotNull(ediFileObj.ediData);		// cnwrl1 25/08/2010 PAR 25559
	self.ediVerify(ediFileObj);
	errorMsg := "Verify Failed" &amp; CrLf &amp; passportObj.getErrorsAsString();
	// Status 3 is verify status and 14 is verified with warnings.
//	self.assertIsOneOf(	ediFileObj.fileStatus,
//						errorMsg,
//						CM_EDIFile.EDI_STATUS_VERIFIED,
//						CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS);
	self.assertEqualMsg(ediFileObj.fileStatus, CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS, errorMsg);
	ediDataObj := ediFileObj.ediData;
	self.ediDBLoad(ediFileObj);
//	self.assertIsOneOf(	ediFileObj.fileStatus,
//						"Load Failed",
//						CM_EDIFile.EDI_STATUS_DBLOADED,
//						CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL);
	errorMsg := "DB Load Failed" &amp; CrLf &amp; passportObj.getErrorsAsString();
	self.assertEqualMsg(ediFileObj.fileStatus, CM_EDIFile.EDI_STATUS_DBLOADED, errorMsg);
	
	//09 Nov 2017	NDL	TFS 7407
	voyage := self.getVoyage(VOYAGE_CODE);
	self.assertTrueMsg( voyage &lt;&gt; null, "Voyage not found pre date checks");
	self.assertTrueMsg( voyage.estimatedArrivalDT.Date = aDate, "Voyage estimated arrival date not set correctly");
	self.assertTrueMsg( voyage.estimatedDepartureDT.Date = dDate, "Voyage estimated departure date not set correctly");
	
	
	if ediFileObj.fileStatus = CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL then
		write "EDI message not fully loaded - needs a re-run.";
	endif;
	self.assertEqualMsg(ediDataObj.allEDITrackedItems.size, 4, "incorrect number of EDI trackedItems");
epilog
	self.setHarbourIsDoClearanceCheck(isDoClearanceCheck);
end;
</source>
    </JadeMethod>
    <JadeMethod name="tVoyageAction" id="a792c5ca-58af-4a09-84d2-745b7b6e4bcf">
        <source>tVoyageAction();
//
//14 August 2017	jlgrs1	Initial creation
// 31 July 2018	jlgrh7 TFS 39472 Internal EDI Format for Voyage doesn't allow the entry of Valid Operators
// 10 Sep 2019	cnwrs1	TFS 46030
//
constants
	USER_DEF_NAME : String = "JMTInternalVoyage";
	VESSEL_CODE	: String = "Ship001C";
	VOYAGE : String = "VOY002084";
vars
	ediFileObj : CM_EDIFile;
	ediDataObj : CM_EDIData;
	passportObj : CM_Passport;
	operator : CM_Operator;
	voyage : CM_Voyage;
	ediText : String;
	errorMsg : String;
	now : TimeStamp;
	str : String;
	isDoClearanceCheck : Boolean;
begin
	isDoClearanceCheck := self.getMyTerminal.myHarbour.isDoClearanceCheck;
	self.setHarbourIsDoClearanceCheck(false);
	passportObj := app.myPassport;
	self.deleteVoyage(VOYAGE);
	voyage := self.getVoyage(VOYAGE);
	self.assertIsDeleted(voyage);
	ediText :=
'&lt;?xml version="1.0"?&gt;
&lt;JMTInternalVoyage xmlns:xsi="http://www.jademasterterminallogistics.com/JMTInternal" xsi:noNamespaceSchemaLocation="JMTInternalVoyage.xsd"&gt;
	&lt;AllVoyage&gt;
		&lt;Voyage&gt;
			&lt;isNonPlannedVoyage/&gt;
			&lt;isNonWorkedVoyage/&gt;
			&lt;shipPlanningStructure/&gt;
			&lt;position/&gt;
			&lt;cargoTypeDescr/&gt;
			&lt;description/&gt;
			&lt;fullOrMT/&gt;
			&lt;id/&gt;
			&lt;inwardCode&gt;UT_Voy02&lt;/inwardCode&gt;
			&lt;messageMode&gt;A&lt;/messageMode&gt;
			&lt;operatorCode&gt;MSK&lt;/operatorCode&gt;
			&lt;shippingLineCode&gt;AZL&lt;/shippingLineCode&gt;
			&lt;tidalClassArrival/&gt;
			&lt;tidalClassDeparture/&gt;
			&lt;tradeDesc&gt;Unit Test Trade&lt;/tradeDesc&gt;
			&lt;vesselName&gt;'&amp;VESSEL_CODE&amp;'&lt;/vesselName&gt;
			&lt;voyageCode&gt;'&amp;VOYAGE&amp;'&lt;/voyageCode&gt;
			&lt;arriveTime/&gt;
			&lt;departureDT/&gt;
			&lt;scheduledArrivalDT&gt;'&amp;now.asStringJMT&amp;'&lt;/scheduledArrivalDT&gt;
			&lt;scheduledDepartureDT&gt;'&amp;now.addHours(1).asStringJMT&amp;'&lt;/scheduledDepartureDT&gt;
			&lt;allValidOperatorCodes&gt;MSK HLL ZIM&lt;/allValidOperatorCodes&gt;
		&lt;/Voyage&gt;
	&lt;/AllVoyage&gt;
&lt;/JMTInternalVoyage&gt;';

	ediFileObj := self.ediLoadFileName(ediText, EDIFileType_Unknown, USER_DEF_NAME, USER_DEF_NAME&amp;method.name);

	self.assertNotNull(ediFileObj);
	self.assertEqualMsg(true, passportObj.allErrors.isEmpty(), passportObj.getAllErrorsWarningsAsString());	// cnwrl1 25/08/2010 PAR 25559
	self.assertNotNull(ediFileObj.ediData);		// cnwrl1 25/08/2010 PAR 25559
	self.ediVerify(ediFileObj);
	errorMsg := "Verify Failed" &amp; CrLf &amp; passportObj.getErrorsAsString();
	// Status 3 is verify status and 14 is verified with warnings.
//	self.assertIsOneOf(	ediFileObj.fileStatus,
//						errorMsg,
//						CM_EDIFile.EDI_STATUS_VERIFIED,
//						CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS);
	self.assertEqualMsg(ediFileObj.fileStatus, CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS, errorMsg);
	ediDataObj := ediFileObj.ediData;
	self.ediDBLoad(ediFileObj);
//	self.assertIsOneOf(	ediFileObj.fileStatus,
//						"Load Failed",
//						CM_EDIFile.EDI_STATUS_DBLOADED,
//						CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL);
	errorMsg := "DB Load Failed" &amp; CrLf &amp; passportObj.getErrorsAsString();
	self.assertEqualMsg(ediFileObj.fileStatus, CM_EDIFile.EDI_STATUS_DBLOADED, errorMsg);
	if ediFileObj.fileStatus = CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL then
		write "EDI message not fully loaded - needs a re-run.";
	endif;
	self.assertEqualMsg(ediDataObj.allEDITrackedItems.size, 1, "incorrect number of EDI trackedItems");
	voyage := self.getVoyage(VOYAGE);
	self.assertNotNull(voyage);
	self.assertEqualMsg(voyage.inwardCode, "UT_Voy02", "wrong inwardcode");
	foreach operator in voyage.allOperators do
		str := str&amp;operator.code&amp;' ';
	endforeach;
	self.assertEqualMsg(str, "HLL MSK ZIM ", "wrong allOperators");
epilog
	self.setHarbourIsDoClearanceCheck(isDoClearanceCheck);
end;
</source>
    </JadeMethod>
    <JadeMethod name="tVoyageHMS" id="66d692fa-4773-4811-8351-174e61cb9ed6">
        <source>tVoyageHMS();
// cnwrs1
//
// 14 July 2015	cnwrd1	Par 36509 - Added HMS data
// 10 Sep 2019	cnwrs1	TFS 46030
//
constants
	VESSEL_CODE	: String = "Ship001C";
	VOYAGE_CODE	: String = "VOY002084";
	TestOperator = 'MSK';
	USER_DEF_NAME : String = "JMTInternalWhatEver";
vars
	ediFileObj : CM_EDIFile;
	ediDataObj : CM_EDIData;
	passportObj : CM_Passport;
	ediText : String;
	errorMsg : String;
	vessel : CM_Vessel;
	voyage : CM_Voyage;
	aDate : Date;
	dDate : Date;
	isDoClearanceCheck : Boolean;
begin
	isDoClearanceCheck := self.getMyTerminal.myHarbour.isDoClearanceCheck;
	self.setHarbourIsDoClearanceCheck(false);
	passportObj	:=	app.myPassport;
	self.deleteVoyage(VOYAGE_CODE);
	voyage := self.getVoyage(VOYAGE_CODE);
	self.assertIsDeleted(voyage);
	
	self.deleteVessel(VESSEL_CODE);
	vessel := self.getVessel(VESSEL_CODE);
	self.assertIsDeleted(vessel);
	
	// now set up cleanly
	vessel := self.addVesselCellular(VESSEL_CODE, self.getOperator(TestOperator));
	self.assertNotNullMsg(vessel, 'Add vessel failed');

	voyage	:= self.addVoyageWithContainerStructur(VOYAGE_CODE,
													VESSEL_CODE,
													TestOperator, 
													self.getProfileSetting( UT_Profile.P_SHIPPING_LINE ).asString);
	self.assertNotNullMsg( voyage, 'Add voyage failed' );
	voyage := self.getVoyage(VOYAGE_CODE);
	self.assertNotNull(voyage);
	aDate := aDate.cnEcAddDays(-3); // 3 days ago
	dDate := dDate.cnEcAddDays(20); // 3 days ago
	ediText :=
'
&lt;?xml version="1.0" encoding="UTF-8"?&gt;
&lt;JMTInternalVoyage&gt;
&lt;AllVoyage&gt;
&lt;Voyage&gt;
&lt;cargoTypeDescr&gt;ISO Container&lt;/cargoTypeDescr&gt;
&lt;id&gt;00000001&lt;/id&gt;
&lt;inwardCode&gt;VOY002084S&lt;/inwardCode&gt;
&lt;messageMode&gt;A&lt;/messageMode&gt;
&lt;operatorCode&gt;MSK&lt;/operatorCode&gt;
&lt;shippingLineCode&gt;AZL&lt;/shippingLineCode&gt;
&lt;tradeDesc&gt;Unit Test Trade&lt;/tradeDesc&gt;
&lt;vesselName&gt;'&amp;VESSEL_CODE&amp;'&lt;/vesselName&gt;
&lt;voyageCode&gt;'&amp;VOYAGE_CODE&amp;'&lt;/voyageCode&gt;
&lt;scheduledArrivalDT&gt;'&amp;aDate.format('dd MMMM yyyy')&amp;', 00:00:00&lt;/scheduledArrivalDT&gt;
&lt;scheduledDepartureDT&gt;'&amp;dDate.format('dd MMMM yyyy')&amp;', 00:00:00&lt;/scheduledDepartureDT&gt;
&lt;tidalClassArrival&gt;E&lt;/tidalClassArrival&gt;
&lt;tidalClassDeparture&gt;E&lt;/tidalClassDeparture&gt;
&lt;AllPort&gt;
&lt;Port&gt;
&lt;position&gt;3&lt;/position&gt;
&lt;cargoTypeDescr&gt;ISO Container&lt;/cargoTypeDescr&gt;
&lt;id&gt;AUSYD&lt;/id&gt;
&lt;messageMode&gt;A&lt;/messageMode&gt;
&lt;voyageCode&gt;'&amp;VOYAGE_CODE&amp;'&lt;/voyageCode&gt;
&lt;/Port&gt;
&lt;Port&gt;
&lt;position&gt;1&lt;/position&gt;
&lt;cargoTypeDescr&gt;ISO Container&lt;/cargoTypeDescr&gt;
&lt;id&gt;NZAKL&lt;/id&gt;
&lt;messageMode&gt;A&lt;/messageMode&gt;
&lt;voyageCode&gt;'&amp;VOYAGE_CODE&amp;'&lt;/voyageCode&gt;
&lt;/Port&gt;
&lt;Port&gt;
&lt;position&gt;2&lt;/position&gt;
&lt;cargoTypeDescr&gt;ISO Container&lt;/cargoTypeDescr&gt;
&lt;id&gt;SGSIN&lt;/id&gt;
&lt;messageMode&gt;A&lt;/messageMode&gt;
&lt;voyageCode&gt;'&amp;VOYAGE_CODE&amp;'&lt;/voyageCode&gt;
&lt;/Port&gt;
&lt;/AllPort&gt;
&lt;/Voyage&gt;
&lt;/AllVoyage&gt;
&lt;/JMTInternalVoyage&gt;
';
	ediFileObj := self.ediLoadFileName(ediText, EDIFileType_Unknown, USER_DEF_NAME, USER_DEF_NAME&amp;method.name);

	self.assertNotNull(ediFileObj);
	self.assertEqualMsg(true, passportObj.allErrors.isEmpty(), passportObj.getAllErrorsWarningsAsString());	// cnwrl1 25/08/2010 PAR 25559
	self.assertNotNull(ediFileObj.ediData);		// cnwrl1 25/08/2010 PAR 25559
	self.ediVerify(ediFileObj);
	errorMsg := "Verify Failed" &amp; CrLf &amp; passportObj.getErrorsAsString();
	// Status 3 is verify status and 14 is verified with warnings.
//	self.assertIsOneOf(	ediFileObj.fileStatus,
//						errorMsg,
//						CM_EDIFile.EDI_STATUS_VERIFIED,
//						CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS);
	self.assertEqualMsg(ediFileObj.fileStatus, CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS, errorMsg);
	ediDataObj := ediFileObj.ediData;
	self.ediDBLoad(ediFileObj);
//	self.assertIsOneOf(	ediFileObj.fileStatus,
//						"Load Failed",
//						CM_EDIFile.EDI_STATUS_DBLOADED,
//						CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL);
	errorMsg := "DB Load Failed" &amp; CrLf &amp; passportObj.getErrorsAsString();
	self.assertEqualMsg(ediFileObj.fileStatus, CM_EDIFile.EDI_STATUS_DBLOADED, errorMsg);
	
	if ediFileObj.fileStatus = CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL then
		write "EDI message not fully loaded - needs a re-run.";
	endif;
	self.assertEqualMsg(ediDataObj.allEDITrackedItems.size, 4, "incorrect number of EDI trackedItems");
epilog
	self.setHarbourIsDoClearanceCheck(isDoClearanceCheck);
end;
</source>
    </JadeMethod>
    <JadeMethod name="tWagonAction" id="e0bc6db3-4b31-4a19-9b48-95e73b0a6911">
        <source>tWagonAction();
//
//14 August 2017	jlgrs1	Initial creation
//
constants
	USER_DEF_NAME : String = "JMTInternalWagon";
	WAGON : String = "UTWAGON_01";
	TRAIN : String = "UTTRAIN01";
vars
	ediFileObj : CM_EDIFile;
	ediDataObj : CM_EDIData;
	passportObj : CM_Passport;
	carrier : CM_Carrier;
	train : CM_Train;
	wagon : CM_Wagon;
	ediText : String;
	errorMsg : String;
	now : TimeStamp;
begin
	passportObj := app.myPassport;
	train := self.getTrain(TRAIN, null);
	self.assertNotNull(train);
	wagon := self.getWagon(WAGON, train);
	self.deleteWagonAndAssociatedObjs(wagon);
	self.tTrainAction();
	train := self.getTrain(TRAIN, null);
	self.assertNotNull(train);
	carrier := CM_Carrier.firstInstance;
	self.assertIsDeleted(wagon);
	ediText :=
'&lt;?xml version="1.0"?&gt;
&lt;JMTInternalWagon xmlns:xsi="http://www.jademasterterminallogistics.com/JMTInternal" xsi:noNamespaceSchemaLocation="JMTInternalWagon.xsd"&gt;
	&lt;AllWagon&gt;
		&lt;Wagon&gt;
			&lt;maxCargoHeight/&gt;
			&lt;maxCargoWeight/&gt;
			&lt;tareWeight/&gt;
			&lt;carrierCode&gt;'&amp;carrier.code&amp;'&lt;/carrierCode&gt;
			&lt;description&gt;Stuff&lt;/description&gt;
			&lt;fullOrMT/&gt;
			&lt;messageMode&gt;A&lt;/messageMode&gt;
			&lt;trainCode&gt;'&amp;TRAIN&amp;'&lt;/trainCode&gt;
			&lt;wagonClass&gt;UK&lt;/wagonClass&gt;
			&lt;wagonNumber&gt;'&amp;WAGON&amp;'&lt;/wagonNumber&gt;
			&lt;wagonSeals&gt;:WAGON SEAL=WSeal01:&lt;/wagonSeals&gt;
			&lt;scheduledArrivalDT&gt;'&amp;now.asStringJMT&amp;'&lt;/scheduledArrivalDT&gt;
		&lt;/Wagon&gt;
	&lt;/AllWagon&gt;
&lt;/JMTInternalWagon&gt;';

	ediFileObj := self.ediLoadFileName(ediText, EDIFileType_Unknown, USER_DEF_NAME, USER_DEF_NAME&amp;method.name);

	self.assertNotNull(ediFileObj);
	self.assertEqualMsg(true, passportObj.allErrors.isEmpty(), passportObj.getAllErrorsWarningsAsString());	// cnwrl1 25/08/2010 PAR 25559
	self.assertNotNull(ediFileObj.ediData);		// cnwrl1 25/08/2010 PAR 25559
	self.ediVerify(ediFileObj);
	errorMsg := "Verify Failed" &amp; CrLf &amp; passportObj.getErrorsAsString();
	// Status 3 is verify status and 14 is verified with warnings.
//	self.assertIsOneOf(	ediFileObj.fileStatus,
//						errorMsg,
//						CM_EDIFile.EDI_STATUS_VERIFIED,
//						CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS);
	self.assertEqualMsg(ediFileObj.fileStatus, CM_EDIFile.EDI_STATUS_VERIFIED, errorMsg);
	ediDataObj := ediFileObj.ediData;
	self.ediDBLoad(ediFileObj);
//	self.assertIsOneOf(	ediFileObj.fileStatus,
//						"Load Failed",
//						CM_EDIFile.EDI_STATUS_DBLOADED,
//						CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL);
	errorMsg := "DB Load Failed" &amp; CrLf &amp; passportObj.getErrorsAsString();
	self.assertEqualMsg(ediFileObj.fileStatus, CM_EDIFile.EDI_STATUS_DBLOADED, errorMsg);
	if ediFileObj.fileStatus = CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL then
		write "EDI message not fully loaded - needs a re-run.";
	endif;
	self.assertEqualMsg(ediDataObj.allEDITrackedItems.size, 1, "incorrect number of EDI trackedItems");
	wagon := self.getWagon(WAGON, train);
	self.assertNotNull(wagon);
	self.assertEqualMsg(wagon.getSealNumbersOnly, "WSeal01", "wrong seal Number");
	self.assertEqualMsg(wagon.myCarrier, carrier, "wrong carrier");

end;
</source>
    </JadeMethod>
    <JadeMethod name="uMultiFieldUpdate" id="f6442e14-963e-4294-b997-93d920df2844">
        <source>uMultiFieldUpdate();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 March 2020	jlgndl1	Initial creation	TFS 48776 testing

*/

constants

	USER_DEF_NAME : String = "JMTInternalCargoFieldUpdate";
	CargoIdBase : String = "MULF48776";
	BSName : String = "BSMULF";
	
vars

	numberOfItems : Integer;
	allTisCreated : CM_TIArray;
	bs : CM_BlockStack;
	container : CM_Container;
	tiId: String;
	index : Integer;
	operator : CM_Operator;
	ti : CM_TrackedItem;
	ediText : String;
	ediFileObj : CM_EDIFile;
	
	ediControllerAgent : CM_EDIControllerAgent;
	binaryMsg : Binary;
	bSynchronous : Boolean;
	messageType : String;
	clientRef : String;

begin

	self.deleteTerminalArea( BSName );

	numberOfItems := 10;
	
	operator := self.getOperator(UT_Profile.P_OPERATOR);
	
	bs := self.addBlockStack( BSName, numberOfItems + 10, null);
	self.assertTrueMsg( bs &lt;&gt; null, BSName &amp; " block stack not created");
	
	create allTisCreated transient;
	//create Onsite Cargo
	
	self.opts.purge;
	foreach index in 1 to numberOfItems do
		tiId := CargoIdBase &amp; index.padLeadingWith("0",2);
		container := self.addContainerAtLocation(tiId, operator, "2200", "MT", TI_IMEX_STATUS_EXPORT, bs);
		self.assertTrueMsg( container &lt;&gt; null, tiId &amp; " on-site container not created");
		allTisCreated.add( container );
		self.updateTI( container );
		self.deleteStops(container);
	endforeach;
	
	ediText := '&lt;?xml version="1.0" encoding="UTF-8"?&gt;
	&lt;JMTInternalCargoFieldUpdate&gt;
	&lt;AllCargoFieldUpdate&gt;';
	foreach ti in allTisCreated do
		ediText := ediText &amp; '&lt;CargoFieldUpdate&gt;&lt;cargoTypeDescr&gt;ISO Container&lt;/cargoTypeDescr&gt;&lt;fieldName&gt;cargoWeightChange&lt;/fieldName&gt;&lt;fieldValue&gt;+10&lt;/fieldValue&gt;&lt;id&gt;';
		ediText := ediText &amp; ti.id &amp; '&lt;/id&gt;&lt;/CargoFieldUpdate&gt;';
	endforeach;
	ediText := ediText &amp; '&lt;/AllCargoFieldUpdate&gt;
	&lt;/JMTInternalCargoFieldUpdate&gt;';
	
/*  //Std Testing style	
//	process.profiler.start();
	ediFileObj := self.ediLoadFileName(ediText, EDIFileType_Unknown, USER_DEF_NAME, USER_DEF_NAME&amp;method.name);
	
	self.ediVerify(ediFileObj);
	
	self.ediDBLoad(ediFileObj);
//	process.profiler.stop();
//	process.profiler.report();

	*/
	
	//Web testing style
	create ediControllerAgent transient;
	ediControllerAgent.setTerminal(self.getTerminal);
	
	binaryMsg := ediText.Binary;
	bSynchronous := true;		// true = load, false = queue
	messageType := "JMTInternalCargoFieldUpdate";						
	clientRef := method.name;		
	ediControllerAgent.setEdiClientRef(clientRef);
		
	// Load and DB load the message
	app.setIsFromEDIviaWeb( true );
//	process.profiler.start();
	ediControllerAgent.loadMessageFromWeb(System_EDIFileType, binaryMsg, ediFileObj, bSynchronous, null);
//	process.profiler.stop();
//	process.profiler.report();

epilog

	app.setIsFromEDIviaWeb( false );
	
	delete ediControllerAgent;
	delete allTisCreated;


end;</source>
    </JadeMethod>
    <JadeMethod name="xmlDef_WagonRelease" id="99c8af76-079f-44b9-bca0-9b111207f5df">
        <source>xmlDef_WagonRelease() : String protected;
