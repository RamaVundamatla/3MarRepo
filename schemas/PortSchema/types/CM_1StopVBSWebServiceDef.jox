    <JadeMethod name="isForTerminal" id="2894fec7-a47a-418f-9abc-36e1b9c4f50f">
        <source>isForTerminal(_terminal: CM_Terminal): Boolean;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 05/12/2022	navdap1		Initial creation TFS 55159 MTN - Export CAMS to JSON API Endpoint
//
vars

begin
	return self.myTerminal = _terminal;

epilog

end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setExtras" id="1d7127e8-eb6d-4565-99d3-58d3cfc1caea">
        <updating/>
        <source>setExtras(	_terminal : CM_Terminal;
			_baseEndPointGate : String;
			_cid : String;
			_senderCode : String;
			_baseEndPointSlots : String;
			_authKey : String;
			_customerID : String;
			_facilityId : String	) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 December 2021	navpw1	Initial creation TFS: 52268

*/

begin
	self.baseEndpoint := _baseEndPointGate;
	self.baseEndPointGateEvent := _baseEndPointGate;
	self.cid := _cid;
	self.senderCode := _senderCode;
	self.baseEndPointBookingSlots := _baseEndPointSlots;
	self.authKey := _authKey;
	self.customerCode := _customerID;
	self.facilityId := _facilityId;
	
	self.myTerminal := _terminal;
epilog

end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_baseEndPointGate" type="String"/>
        <Parameter name="_cid" type="String"/>
        <Parameter name="_senderCode" type="String"/>
        <Parameter name="_baseEndPointSlots" type="String"/>
        <Parameter name="_authKey" type="String"/>
        <Parameter name="_customerID" type="String"/>
        <Parameter name="_facilityId" type="String"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="5e01c312-a65f-416e-92c0-4bc74056c4da">
        <updating/>
        <source>setForUpdate(_extWebService: CM_1StopVBSWebServiceDef) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 December 2021	navpw1	Initial creation TFS: 52268

*/

begin
	inheritMethod(_extWebService);
	
	self.baseEndPointGateEvent := _extWebService.baseEndPointGateEvent;
	self.cid := _extWebService.cid;
	self.senderCode := _extWebService.senderCode;
	self.baseEndPointBookingSlots := _extWebService.baseEndPointBookingSlots;
	self.authKey := _extWebService.authKey;
	self.customerCode := _extWebService.customerCode;
	self.facilityId := _extWebService.facilityId;
	
	self.myTerminal := _extWebService.myTerminal;
	
	//Check terminal for webservices of the same type that are active and unset them
end;</source>
        <Parameter name="_extWebService" type="CM_1StopVBSWebServiceDef"/>
    </JadeMethod>
