    <JadeMethod name="setWeighbridgeLabel" id="a6445b06-bdc7-4a35-90b1-4c888c9c02ba">
        <source>setWeighbridgeLabel(_timedOut : Boolean);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 March 2017	cnwns1	Initial creation
2/10/2017  jlgns1 TFS 6865 PKT - Weighbridge Connection Issue
19 April 2018	jlgns1 Bug 38134: PKT - Weight Discrepancy
*/

vars
	weighBridgeStatus : String;
	setFields : Boolean;
begin
		
	if _timedOut then													//Bug 38134
		weighBridgeStatus := app.getErrorString(Warning_weighbridge);	//Bug 38134	
		self.lblWeibridge.caption := weighBridgeStatus;					//Bug 38134
	else																//Bug 38134
		if  self.myWeightInterfaceController &lt;&gt; null and self.myWeightInterfaceController.hasValidConnection then
			weighBridgeStatus := self.myWeightInterfaceController.getWeighBridgeDetails;						//TFS 6865 
			if self.lblWeibridge.caption &lt;&gt;  weighBridgeStatus or self.btnGetWeight.visible &lt;&gt; true then		//TFS 6865 
				self.lblWeibridge.caption :=  weighBridgeStatus;												//TFS 6865 
				self.btnGetWeight.visible := true;						//Bug 38134
				self.txtWeightIN.setFieldsEnabled( self.allowManualWeight );	//19 Apr 2017	NDL	TFS 4126		
				self.lblWeighbridgeMessage.visible := app.getMyUser.isSuperUser;	//19 Apr 2017	NDL	TFS 4126
				self.enableFields(true);
				setFields := true;
			endif;																								//TFS 6865 
		else
			weighBridgeStatus := self.weighbridgeLblValue;														//TFS 6865 
			if self.lblWeibridge.caption &lt;&gt; weighBridgeStatus or self.btnGetWeight.visible &lt;&gt; false then		//TFS 6865 
				self.lblWeibridge.caption := weighBridgeStatus;													//TFS 6865 
				self.btnGetWeight.visible := false;
				self.txtWeightIN.setFieldsEnabled( self.allowManualWeight ); // After confirmation from Salman
				if  self.txtWeightIN.getMeasurementType &lt;&gt; null then	//Bug 38134
					self.txtWeightIN.setValue(0);						//Bug 38134
				endif;													//Bug 38134
				self.lblWeighbridgeMessage.visible := false;
				self.enableFields(true);
				setFields := true;
			endif;																								//TFS 6865 
		endif;
	endif;
	
	app.writeLog(self.name &amp; "_" &amp; method.name &amp; "_" &amp; weighBridgeStatus.removeCrLfs() &amp; "_Caption_Set=" &amp; setFields.String, LogDEBUG);	//25 Nov 2019	NDL	TFS 47053
	
epilog

end;</source>
        <Parameter name="_timedOut" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="c01c7602-4d94-4a39-87d5-d51cf17b3685">
        <updating/>
        <source>setupForm() updating;
// ---------------------------------------------------------------------------
// Created:     09 December 2016 by cnwns1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//24/01/17          cnwns1          TFS3153:PKT - Bulk Process - WeighBridge Integration
//2/10/2017         jlgns1 			TFS 6865 PKT - Weighbridge Connection Issue
//24/10/17	        jlgns1			TFS 7308	PKT - Road Job Cancellation Issue	
//19 April 2018	    jlgns1 			Bug 38134: PKT - Weight Discrepancy
// 08/06/2022 		navhl20 		TFS 53430  EUP - Sub Carrier registration in MTN
// ---------------------------------------------------------------------------

vars
	hideArea	: Boolean;
	hideBat 	: Boolean;
	securityGate: Boolean;					
	measure 	: CM_MeasurementType;		
	hasWeighBridge : Boolean;
	myLane 		: CM_GateAreaLaneController;
	form : CM_BaseForm;	//19 Jul 2021	NDL	TFS 51575
begin

	inheritMethod();
	
	self.weighbridgeLblValue := self.lblWeibridge.caption;
	
	self.allowManualWeight := app.getMyUser.canDo(self.myTerminal,PmGteBulkWeighMan);
	
	//Start 08/06/2022 navhl20 TFS 53430
	self.isSubCarrierEnabled := self.myTerminal.getConfig(IsSubCarrierEnabled).Boolean;
	self.isSubCarrierMandatory := self.myTerminal.getConfig(IsSubCarrierRequired).Boolean;
	if isSubCarrierEnabled then
		self.lblSubCarrier.visible := true;
		self.cmbSubCarrier.visible := true;
		self.initSubCarrierCombo;
	endif;
	//End 08/06/2022 navhl20 TFS 53430
	
	create self.myBulkGateAgent transient;
	
	//19 Jul 2021	NDL	TFS 51575
	if self.myTerminal.getConfig(BulkGateVersion2).Boolean then
		form := app.loadForm(GTE_NewBulkGateForm_In, GTE_Assistant, false, false, false, self.myTerminal, null).GTE_NewBulkGateForm_In;
		if form &lt;&gt; null then
			form.show();
			self.unloadForm;
			return;
		endif;
	endif;
	
	self.myVBSProcess := self.myTerminal.getMyVBSProcess();	// ### TFS 54049 (55841) 04May2023 NAVPW1
	
	self.myBulkGateAgent.myTerminal := self.myTerminal;
	
	hasWeighBridge := self.myBulkGateAgent.setSerialWeighbridge(IN_YO);
	
	self.myBulkGateAgent.getGateFromSetup;	
	
	if hasWeighBridge then
		self.setupWeightInterface(); 			
		self.cmbGate.listIndex := self.cmbGate.findObject(self.myBulkGateAgent.myGate);
		
		self.cmbGateLanes.listIndex := self.cmbGateLanes.findObject(self.myBulkGateAgent.myGateAreaLaneController);
		self.lblWeibridge.caption := app.getErrorString(Connection_starting);	//Bug 38134
		self.btnGetWeight.visible := false;										//Bug 38134
		
	else								//TFS 6865 
		self.setWeighbridgeLabel(false);		//TFS 6865 						//Bug 38134
	endif;								//TFS 6865 
	
	self.setNavigatorHeading(self.caption);	
	self.initCarrierInterchCombos();
	
	self.doBuildGateCombo();	
	
	self.loadPrinterCombo();
	
	self.allowGateInByCargoID := self.myTerminal.getConfig(AllowBulkGateInById).Boolean;	
	
	if self.myTerminal.getConfig(AllowBulkGateInByType).Boolean then
		self.initCargoTypeCombo();
		self.cmbCargoTypes.visible := true;	
		self.lblCargoType.visible := true;	
	else
		self.cmbCargoTypes.visible := false;
		self.lblCargoType.visible := false;		
	endif;
	
	self.lblDirection.caption := Empty_String;
	self.lblDirectionIcon.caption := Empty_String;
	
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.btnSave.enabled := false;
		self.btnGetWeight.enabled := false;
		self.enableFields(false);
		self.txtVisitNumber.setFocus();
	endif;
	
	self.detailsChangedVehicle := false;	
	
	if not app.myCurrentUserCan(self.myTerminal, PmGteCanPrintFlexiGate) then
		self.btnPrint.enabled := false;
		self.btnPrint.bubbleHelp := app.getErrorString(Not_have_permi_selec_print);
		self.cmbPrinter.enabled := false;
		self.cmbPrinter.bubbleHelp := app.getErrorString(Not_have_permi_print);
	endif;
	
	self.btnPrint.visible := false;//cnwas3
	
	if not app.myCurrentUserCan(self.myTerminal, PmGteBulkInMaint) then
		self.btnSave.enabled := false;
		self.btnSave.bubbleHelp := app.getErrorString(Not_have_permi_creat_road_Job);
		//self.btnCancel.enabled := false;											//TFS 7308
	endif;
	
	if not app.myCurrentUserCan(self.myTerminal, PmGteGateCanCancelFlexiJob) then	//TFS 7308
		self.btnCancel.enabled := false;											//TFS 7308
	endif;																			//TFS 7308
	
	
	hideArea := self.myTerminal.getConfig(GateInOutHideArea).Boolean; 	
	self.lblInterchange.visible := not hideArea; 						
	self.cmbInterchange.visible := not hideArea; 						
	if self.myTerminal.getConfig(ShowVehicleState).Boolean then 
		self.lblState.visible := true;
		self.txtState.visible := true;
	else
		self.lblState.visible := false;
		self.txtState.visible := false;
	endif;  
	
	if self.myTerminal.getConfig(KnownTruckDriverRequired).Boolean then
		self.myAssistant.comboBoxVehicleObj(self.cmbRegNo,null,null);
		self.cmbDriver.visible:=true;
		self.cmbRegNo.visible:=true;
		self.cmbRegNo.zOrder(1);
		self.txtRegno.visible:=false;
		self.txtDriverCode.visible := false;
		self.lblDriverName.visible := false;		
		self.txtDriverName.visible := false;
	else
		self.cmbDriver.visible:=false;
		self.cmbRegNo.visible:=false;
		self.txtRegno.visible:=true;
		self.txtDriverCode.visible := true;
		self.lblDriverName.visible := true;		
		self.txtDriverName.visible := true;
		if self.myTerminal.getConfig(HideRGateDriverCodeName).Boolean then 
			self.lblDriverCode.visible := false;
			self.txtDriverCode.visible := false;
			self.lblDriverName.visible := false;		
			self.txtDriverName.visible := false;
		endif; 
	endif;

	self.txtWeightIN.setup(Type_Weight, self.backColor);	
	self.txtWeightIN.selectMode := Table.SelectMode_None;	
	
	measure := app.getDefaultMeasurementForType(Type_Weight);														
	self.txtWeightIN.setValues(app.convertMeasurementForDisplay(measure.shortName,0) &amp; Space &amp; measure.shortName);	
	
	hideBat := self.myTerminal.getConfig(GateInOutHideBatNumber).Boolean;
	securityGate := self.myTerminal.getConfig(SiteHasSecurityGate).Boolean;			
	self.lblRFID.visible := not hideBat and not securityGate;						
	self.cmbRFID.visible := not hideBat and not securityGate;						
	if not hideBat  and not securityGate then										
		self.myAssistant.comboBoxRFIDTag(self.cmbRFID,self.myTerminal, null);
		self.beginNotification(global, self.myTerminal.getTerminalEvent(Event_RFIDTagFree), Response_Continuous, null);
		self.beginNotification(global, self.myTerminal.getTerminalEvent(Event_RFIDTagInUse), Response_Continuous, null);
	endif;
	
	//11 Apr 2017	NDL	TFS 4078
	if self.myBulkGateAgent.myGateAreaLaneController = null then
		self.myBulkGateAgent.setGateAreaLaneController(cmbGateLanes.listObject.CM_GateAreaLaneController);
	endif;
	
	if self.grpTop.isInPainter() then
	 	self.grpTop.zOrder(1);
	else
		self.grpTop.transparent := true;
	endif;
	
	//19 Apr 2017	NDL	TFS 4126
	if  self.myWeightInterfaceController &lt;&gt; null and self.myWeightInterfaceController.hasValidConnection then
		self.txtWeightIN.setFieldsEnabled( self.allowManualWeight );	
	else
		//self.txtWeightIN.setFieldsEnabled( app.getMyUser.canDo(self.myTerminal,PmGteBulkInMaint) );
		self.txtWeightIN.setFieldsEnabled( self.allowManualWeight ); // After confirmation from Salman
	endif;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="setupWeightInterface" id="9d321b30-53f4-4268-bf8c-ac52539cadd4">
        <updating/>
        <source>setupWeightInterface()protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 February 2017	cnwns1	Initial creation
19 April 2018	jlgns1 Bug 38134: PKT - Weight Discrepancy
*/

constants

vars
	lWeighBridge	: CM_WeighBridgeObj;
	profileString	: String;
	iniFileName		: String;
	
begin
	lWeighBridge:= self.myBulkGateAgent.myWeighBridge;
	
	if lWeighBridge = null or lWeighBridge.mySerialDetails = null then
		return;
	endif;
	// In development only, check ini file for dummy weighing interface
	executeWhen JMTDevelopmentEnvironment;																							//Bug 38134
		if app.msgBox("Dev only simulation" &amp; CrLf &amp; "Click YES then run app DevSchema MachineWeighSimulator to activate" &amp; CrLf &amp;	//Bug 38134
			"Click NO to continue as normal", "Weighing Simulation", MsgBox_Yes_No) = MsgBox_Return_Yes then						//Bug 38134
			create self.myWeightInterfaceController as CM_SerialWeightIntControllerXX transient;									//Bug 38134
		endif;																														//Bug 38134
	endExecuteWhen;																													//Bug 38134
		
	if self.myWeightInterfaceController = null then
		create self.myWeightInterfaceController transient;
	endif;
	
	self.myWeightInterfaceController.initializeWithSerialDetails(lWeighBridge.mySerialDetails);
		
	self.myWeightInterfaceController.setWeightCallerInterface(self.IF_TCPWeightCallerInterface);
	
	if self.myWeightInterfaceController &lt;&gt; null then
		self.myWeightInterfaceController.startListening;		
	endif;
		
	self.hasWeightInterfaceError:=false;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
