    <JadeMethod name="setupEDI" id="a6c1c09d-1075-431f-bb7b-f00c518abc85">
        <source>setupEDI();
//----------------------------------------------------------------
//	Created:	26 August 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	int,
	addCount	: Integer;
begin

	app.myTrxUA.trxSetupEDI(int, addCount, app.myPassport);

	if app.myPassport.noErrors then
		if addCount &gt; 0 then
			app.writeLog(addCount.String &amp; " new EDI formats added.", LogINFO);
		endif;
	endif;
epilog
	app.myPassport.clearErrorsWarnings();
end;</source>
    </JadeMethod>
    <JadeMethod name="unLoadFile" id="3bfbe741-0405-4e1b-9897-1647f5bb3033">
        <source>unLoadFile(_ediFile : CM_EDIFile io) : Boolean;
// ---------------------------------------------------------------------------
// Created:		19 February 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------
//  manual only - no BGPs
vars
	tempEdiData:CM_EDIData; 
begin

	if tryLock(_ediFile, Exclusive_Lock, Transaction_Duration, LockTimeout_Server_Defined) then
		beginTransaction;
		tempEdiData := _ediFile.ediData;
		_ediFile.unload;
		if tempEdiData &lt;&gt; null then
			// cnwrs1 Par 24207 ccms 1117 11 May 2010
//			if tempEdiData.singleDataFile then
//				_ediFile.ediData := null;
//			else
			tempEdiData.unload;
			delete tempEdiData;
//			endif;
		endif;
		delete _ediFile;
		app.cmsCommitTransaction(app.myPassport);
		return true;
	endif;
	return false;
	
epilog	
	if isLockedByMe(_ediFile) then
		unlock(_ediFile);
	endif;
end;</source>
        <Parameter name="_ediFile" type="CM_EDIFile" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validationExceptionHandler" id="dde74bf7-3808-40ff-b785-d44f40728f92">
        <updating/>
        <source>validationExceptionHandler(exObj: Exception; _passport : CM_Passport input): Integer updating, protected;
// --------------------------------------------------------------------------------
// Parameters:	The exception object
// --------------------------------------------------------------------------------
vars

begin

	if exObj.isKindOf(CM_Exception) and exObj.CM_Exception.isWarning then
		app.addWarningFullPassport(exObj.errorCode, exObj.extendedErrorText, exObj.CM_Exception.userString, exObj.CM_Exception.myUserObject, _passport);
		return Ex_Continue;
	endif;
	if exObj.isKindOf(CM_Exception) then
		app.addErrorFullPassport(exObj.errorCode, exObj.extendedErrorText, exObj.CM_Exception.userString, exObj.CM_Exception.myUserObject, _passport);
		if exObj.continuable then
			return Ex_Continue;
		endif;
	endif;
	return Ex_Pass_Back;
end;</source>
        <access>protected</access>
        <Parameter name="exObj" type="Exception"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="verifyEdiData" id="e0612d92-e870-4650-bc07-9a789026b165">
        <source>verifyEdiData(_ediData : CM_EDIData input) : Boolean;

// cnwdvb1 04 February 2003 
/*
Date		Who		Reason
05/12/2011  cnwrs1  CCMS POL 2122 / PAR 28696 - add support for EDI Partial release Request processing
07/08/2012	cnwcs5	par 30136 - reworked code
21 Jan 2015 cnwma1  PAR 37389 - JH - Out of Sequence file query - High
19 Apr 2016	cnwrs1	TFS 1600 VERMAS EDI
20 Nov 2017	jlgrs1	TFS 5705 - SNO - EDIDataBooking Prenote release Req
24 Nov 2017	jlgrs1	TFS 5705A - SNO - EDIDataBooking Prenote release Req
15 Feb 2018	jlgrs1	TFS 36951 JMT Prenote Partial for GateDoc
23 Feb 2018	jlgrs1	TFS 36963 - add tranlog timings
08 May 2018	jlgrs1	TFS 36425 SingleLine Booking partial processing not working
27 Sep 2018	jlgrs1	TFS 40627 STWR Make EDI MultiThreaded Stage 4
02 Aug 2023	navsp1	Bug 59622: EUP - Manifest Processing - Truck - Create
12 Aug 2025	navdap1	MTN-35604 NSW - Partial Load Voyage EDI
*/
vars
	fileName : String; 
	supportEmail : String; 
	sendersEmail : String; 
	msg : String;
	tmpEdiDataType	: Integer;
	passport : CM_Passport;
	terminal : CM_Terminal;
	tmpStr : String;
	errorSet : CM_ErrorSet;
	issueMapping : CM_EDIIssueMapping;
	fileType : CM_EDIFileType;
	voyage : CM_Voyage;																//navra1 - CR-65068/Task-64641 - Auto Comparison - 15th July 2024	
begin
	create errorSet transient;
	if _ediData = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'EDI Data For Verification (' &amp; self.myTerminal.code &amp; ')', null, null);
		app.raiseCMException1(Input_required_field_EdiDtaVer, self.myTerminal.code , null, null); // cnwdb2	PAR 35364
	endif;
	
	if _ediData.myEDIFile &lt;&gt; null then // ccms1117 cnwrs1 29 Apr 2010
		fileName := _ediData.myEDIFile.fileName; // ccms1117 cnwrs1 29 Apr 2010
	endif;
	
	if self.tryLock(_ediData, Exclusive_Lock, Session_Duration, LockTimeout_Immediate) then																	 //21/01/2015 cnwma1 PAR #37389

		if app.isSpecial() or _ediData.canBeVerified or self.canBeOutSequenceValid(_ediData.status) then	
			tmpStr := _ediData.class.name&amp;' '&amp;method.qualifiedName;
			app.writeLog(tmpStr&amp;' '&amp;_ediData.getVoyageCode&amp;' '&amp;_ediData.fileName, LogINFO);	//25 Nov 2019	NDL	TFS 47053
			
			self.cnStartTransaction(tmpStr[1:60]);
			_ediData.verifyAll();
		
			// ### TFS CR 64617 TASK 64637 16JUL2024 NAVAB1
			if _ediData.status = CM_EDIFile.EDI_STATUS_VERIFIED_ERRORS then
				if self.isBGPAuto then // ### TFS BUG 65389 01AUG2024 NAVAB1
					terminal := self.myTerminal;
					if terminal &lt;&gt; null
					and terminal.allEDIIssues.isNotEmpty() then
						fileType := _ediData.getEDIFileType();
						if fileType &lt;&gt; null then
							issueMapping := terminal.allEDIIssueMappings[fileType];
							if issueMapping.myEDIIssue.includeVerifyIssue then
								issueMapping.myEDIIssue.sendEmail(_ediData);
							endif;
						endif;
					endif;
				endif;
			endif; 
			
			//navra1 - CR-65068/Task-64641 - Auto Comparison - 15th July 2024 - start			
			if _ediData.ediDataType = EDIDataType_LoadList then
				voyage := self.myTerminal.lookupVoyage(_ediData.CM_EDIDataLoadList.getVoyageCode(), null, false);
				if voyage &lt;&gt; null then
					if voyage.myVoyageProcess.isAutomaticProcess() then
						if _ediData.CM_EDIDataLoadList.listType = 'L' then
							voyage.myVoyageProgress.progressStage(CM_VoyageStage.VoyStage_LoadListLoad, _ediData, null, CM_VoyageStage.Type_Load);						//navra1 - MTN-34829 - 8th May 2025
						elseif _ediData.CM_EDIDataLoadList.listType = 'D' then																							//navra1 - MTN-34903 - 15th May 2025
							voyage.myVoyageProgress.progressStage(CM_VoyageStage.VoyStage_DischListLoad, _ediData, null, CM_VoyageStage.Type_Discharge);				//navra1 - MTN-34829 - 8th May 2025
						endif;
					endif;
				endif;
			endif;
			//navra1 - CR-65068/Task-64641 - Auto Comparison - 15th July 2024 - end
			
			if _ediData.status = CM_EDIFile.EDI_STATUS_VERIFIED or
				_ediData.status = CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS or 
				_ediData.status = CM_EDIFile.EDI_STATUS_VERIFY_ERRORS_X then //epr tfs 2292
				return true;
			else
				if self.isBGPAuto then
					supportEmail := app.myRoot.getConfig(AutoSupportEmailAddress).String;
					sendersEmail := app.myRoot.getConfig(AutoSendersEmailAddress).String;
					
					// write to log
					app.writeLog('Auto verify failure ' &amp; fileName, LogINFO);
					
					//epr tfs 2292 8/7/16 report the correct failed status
					if  _ediData.status = CM_EDIFile.EDI_STATUS_VERIFIED_ERRORS then						
						msg		:= fileName &amp; " failed with status " &amp;	self.displayStatus(_ediData.status);
					else
						msg		:= fileName &amp; " failed with unexpected status " &amp; self.displayStatus(_ediData.status);
					endif;
					
					passport := app.myPassport;
					passport.moveErrorsToSet(errorSet);  //02.Aug.2023 navsp1 TFS 59622
					// raise alert
					app.remoteErrorWarningToAlert('Auto verify failure. ' &amp; msg, null, passport.allErrorWarnings, null, false, true );
					// send email
					app.myTrxCA.trxCreateEmailSendRequest('EDI', supportEmail, sendersEmail, null, null, 'Auto verify failure', msg,
															null, null, null, null, EmailSource_EDI, null, passport );
					passport.moveErrorsToSet(errorSet);	 //02.Aug.2023 navsp1 TFS 59622
					passport.addErrorsFromSet(errorSet); //02.Aug.2023 navsp1 TFS 59622
				endif;
			endif;
		endif;
	endif;
	
	tmpEdiDataType := _ediData.getEDIDataType;
	terminal := self.myTerminal;
	
	if tmpEdiDataType = EDIDataType_GateDocument then
		return true;
	endif;
	if (tmpEdiDataType = EDIDataType_BookingMultiLine or
		tmpEdiDataType = EDIDataType_BookingSingleLine) and 
		terminal.getConfig(EdiBookingAllowPartial).Boolean then	//par 26223 cnwrs1 30 nov 2010
		return true;
	endif;
	
	if (tmpEdiDataType = EDIDataType_ReleaseRequest or
		tmpEdiDataType = EDIDataType_RequestMultiLine) and 
		terminal.getConfig(EdiReleaseAllowPartial).Boolean then	//ccms 2122 05 Dec 2011
		return true;
	endif;
	
	// MTN-35604 partial Voyage loading
	if tmpEdiDataType = EDIDataType_Voyage and
		terminal.getConfig(EdiVoyageAllowPartial).Boolean then
		return true;
	endif;

	return false;
epilog
	if _ediData &lt;&gt; null then	//par 28390 cnwrs1 03 nov 2011 unit testing
		self.unlock(_ediData);
	endif;
	if tmpStr &lt;&gt; null then
		self.cnEndTransaction();
	endif;
	delete errorSet;
end;
</source>
        <Parameter name="_ediData" type="CM_EDIData" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="voyageCustomsRequest" id="483c45ec-b544-4f25-8bc5-0de8a85be576">
        <updating/>
        <source>voyageCustomsRequest() updating;
//----------------------------------------------------------------
//	Created:	17 February 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
/*
Date		Who		Reason
08 Jul 2008	cnwkpd1	PAR #17494 - Stop 1090 from epilog when no edi data to process
02 Aug 2012	cnwcs5	par 30136 - change usage of loadEDIDb _ediData parameter
*/
vars
	ediConfig		: CM_EDIConfig;
	ediData			: CM_EDIData;
	lockedEdiData	: CM_EDIData;			// PAR #17494
	allEDIData		: CM_EDIDataArray;
	
begin
	self.isBGPAuto := true;
	self.isEmailNotified := false;
	if self.myTerminal = null then
		app.raiseCMException1(Err_InvalidTerminal, null, null, null);
		return;
	endif;
	
	ediConfig := self.myTerminal.myEdiConfig;
	
	if ediConfig = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'cannot continue without EDI Config object for terminal');
		return;
	endif;
	
	create allEDIData transient;
	ediConfig.getAllEDIDataForType(EDIDataType_CustomStop, allEDIData);
	
	foreach ediData in allEDIData do
		if self.tryLock(ediData, Share_Lock, Session_Duration, LockTimeout_Immediate) then
			lockedEdiData	:=	ediData;
			app.writeLog('DB loading Data For Terminal ' &amp; self.myTerminal.code, LogINFO);
			self.loadEdiDb(null, ediData, false);
			self.unlock(ediData);
			lockedEdiData	:=	null;
		else
			app.writeLog('Attempted DB load failed - could not get a lock of ' &amp; ediData.getName(), LogINFO);
		endif;
	endforeach;
epilog
	if lockedEdiData &lt;&gt; null then		// PAR #17494
		self.unlock(lockedEdiData);
	endif;
	
	delete allEDIData;
end;</source>
    </JadeMethod>
    <JadeMethod name="voyageOperatorRequest" id="c10f2c12-4e68-46aa-9c0a-b78299fe8d94">
        <updating/>
        <source>voyageOperatorRequest() updating;
// --------------------------------------------------------------------------------
// Created:		11 June 2010 by cnwdad1
//
// Purpose:		This method is a copy of voyageCustomsRequest.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 02 Aug 2012	cnwcs5		par 30136 - change usage of loadEDIDb _ediData parameter
// --------------------------------------------------------------------------------
vars
	ediConfig		: CM_EDIConfig;
	ediData			: CM_EDIData;
	lockedEdiData	: CM_EDIData;
	allEDIData		: CM_EDIDataArray;
	
begin
	self.isBGPAuto := true;
	self.isEmailNotified := false;
	
	if self.myTerminal = null then
		app.raiseCMException1(Err_InvalidTerminal, null, null, null);
		return;
	endif;
	
	ediConfig := self.myTerminal.myEdiConfig;
	
	if ediConfig = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'cannot continue without EDI Config object for terminal');
		return;
	endif;
	
	create allEDIData transient;
	ediConfig.getAllEDIDataForType(EDIDataType_OperatorStop, allEDIData);
	
	foreach ediData in allEDIData do
		if self.tryLock(ediData, Share_Lock, Session_Duration, LockTimeout_Immediate) then
			lockedEdiData	:=	ediData;
			app.writeLog('DB loading Data For Terminal ' &amp; self.myTerminal.code, LogINFO);
			self.loadEdiDb(null, ediData, false);
			self.unlock(ediData);
			lockedEdiData	:=	null;
		else
			app.writeLog('Attempted DB load failed - could not get a lock of ' &amp; ediData.getName(), LogINFO);
		endif;
	endforeach;
epilog
	if lockedEdiData &lt;&gt; null then
		self.unlock(lockedEdiData);
	endif;
	
	delete allEDIData;
end;</source>
    </JadeMethod>
    <JadeMethod name="voyageStopRequest" id="fc89ea9a-745b-4b84-af2c-dcba3ecf3fb1">
        <updating/>
        <source>voyageStopRequest(_voyage :CM_Voyage)updating;
/*
Date			Who		Reason
21 June 2011	cnwcs5	Initial creation - par 27167
02 Aug 2012		cnwcs5	par 30136
*/
vars
	config		: CM_EDIConfig;
begin
	self.isBGPAuto 			:= true;
	self.isEmailNotified 	:= false;
	
	if self.myTerminal = null then
		app.raiseCMException1(Err_InvalidTerminal, null, null, null);
		return;
	endif;
	
	if _voyage = null then
		app.raiseCMException1(ERR_INVALID_VOYAGE, null, null, null);
		return;
	endif;
	
	config := self.myTerminal.myEdiConfig;
	
	if config = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'cannot continue without EDI Config object for terminal');
		return;
	endif;
	
	self.processEventReqStops_OnShip (_voyage);
epilog

end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="xHandleMakeException" id="80240295-71a9-45f4-9a5a-8210dea15ad9">
        <source>xHandleMakeException(_except : Exception; _directory: String; _problem : Boolean output) : Integer protected;
/*

Purpose:	PAR	26810 	Handle an exception on calling system make call when
            setting up EDI errors and loaded subdirectories.

Parameters:			

Return Value:		

Date		Who		Reason
27 January 2012	cnwgb1	Initial creation

*/

vars
    message : String;

begin
    _problem := true;
    message := 'Failed to create EDI Directory ' &amp; _directory &amp; ' Error(' &amp; _except.errorCode.asStringJMT &amp;')';
	app.writeLog( message, LogINFO);
    app.createAlert(message, true);

epilog
    return Ex_Resume_Next;

end;</source>
        <access>protected</access>
        <Parameter name="_except" type="Exception"/>
        <Parameter name="_directory" type="String"/>
        <Parameter name="_problem" type="Boolean" usage="output"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="xHandler" id="9c60be83-6d08-4d8f-a653-fd19d9e90028">
        <updating/>
        <source>xHandler(exObj : Exception) : Integer protected, updating;
//
// cnwdvb1 12 February 2003 
//
// 08 Nov 2016	cnwrs1	TFS 2913 Par 38341 EDI files that are open are not being processed
vars
	msg : String;
begin
	abortTransaction;
	
	if not self.isEmailNotified and not exObj.errorCode = 1027 and not exObj.errorCode = 5012 and not exObj.errorCode = 5030 then
		app.myTrxCA.trxCreateEmailSendRequest('EDI',
												app.myRoot.getConfig(AutoSupportEmailAddress).String,
												app.myRoot.getConfig(AutoSendersEmailAddress).String, 
												null, null,
												'Auto failure', 'Error processing EDI files in background - Error(' &amp; exObj.errorCode.String &amp; ')  ' &amp; exObj.extendedErrorText,
												null, null, null, null, 
												EmailSource_EDI,
												null, 
												app.myPassport);
												
		if not app.myPassport.trxCompletedOK then
			app.writeLog('Sending email from EDI agent failed', LogINFO);
		endif;
		
		self.isEmailNotified := true;
	endif;
	if exObj.errorCode = 5030 then
		app.myPassport.hadEDIFileError := true;
		msg := 'Error processing EDI file in background - Error('&amp;exObj.errorCode.String&amp;') '&amp;exObj.extendedErrorText;
		app.writeLog(msg, LogINFO);
	endif;
	return Ex_Pass_Back;
end;</source>
        <access>protected</access>
        <Parameter name="exObj" type="Exception"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="xmlExceptionHandler" id="c8338b0f-07cc-455e-b32b-21064065f2dc">
        <source>xmlExceptionHandler(_exObj: Exception): Integer;
//----------------------------------------------------------------
//	Created:	02 August 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin

	//we know this malformed xml so...

	return Ex_Resume_Next;

end;</source>
        <Parameter name="_exObj" type="Exception"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
</Class>
