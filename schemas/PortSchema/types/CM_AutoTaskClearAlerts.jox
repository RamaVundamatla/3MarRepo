    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>&lt;display&gt;Clear Alerts/Activity/Current Menu Reports&lt;/display&gt;</text>
