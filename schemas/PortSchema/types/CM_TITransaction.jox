    <JadeMethod name="setForDelete" id="a52e1995-0bd5-48cb-a137-7fc4622e3a97">
        <updating/>
        <source>setForDelete(_reason: String) updating;
// ---------------------------------------------------------------------------
// Created:     24 March 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
// 18 Dec 2012	cnwcs5 CCMS SFW 1294 /par 30855
vars

begin 
	if (not self.deleted) 
	and not app.isUnitTestGarbageCollect
	and not self.isKindOf(CM_CAMSAudit) then								//cnwmc5 - 14 Oct 2013 - PAR 32746
	//epr par 35197 10/11/14
		if self.myTerminal &lt;&gt; null and self.myTerminal.getConfig (CamsCreateTrxAudit).Boolean then		// par 30855
			self.createCAMSAuditTransaction (AuditDeleted, self, app.myPassport);	// par 30855
		endif;																// par 30855
	endif;

	self.deleted := true;
	self.deletedReason := _reason;					// 15/10/18 MAP TFS41191
	self.deletedByUser := app.getMyUserCode();

end;</source>
        <Parameter name="_reason" type="String"/>
    </JadeMethod>
    <JadeMethod name="setForResourceUsageUpdate" id="1bdf5adf-5e9d-4f1f-99e0-2a0bd8c42f7c">
        <updating/>
        <source>setForResourceUsageUpdate() updating;
/* ---------------------------------------------------------------------------
Created:     23 August 2010 by cnwrs2

Purpose:	CCMS 1093 - Re-implemented on CM_TITransaction to update date for edi sending
			(PAR 24065).
        
Change Date	Who		Reason
18 Dec 2012	cnwcs5 CCMS SFW 1294 /par 30855
------------------------------------------------------------------------------*/
vars

begin 
	inheritMethod();

	if self.myTerminal &lt;&gt; null and
	   self.myTerminal.getConfig (CamsCreateTrxAudit).Boolean then		// par 30855
		self.createCAMSAuditTransaction (AuditUpdated, self, app.myPassport);	// par 30855
	endif;																// par 30855
end;</source>
    </JadeMethod>
    <JadeMethod name="setForUpdateQVW" id="ad925957-b775-4d17-9c71-79d50eb458bb">
        <updating/>
        <source>setForUpdateQVW(_controller : CMIF_TiTransactionResync; _passport : CM_Passport input) updating;
/*
Purpose: Resync the total quantity / total volume / total weight in the Receive Road type of transactions 
		 after changing / reducing amount of Unloaded TI (via HandHeld).
		 At the time of coding, this applies on SPLITTABLE (BreakBulk) type of CARGO

Date		Who		TFS		Reason
12 Dec 2019	jlgdi1	47879	Initial creation
23 Oct 2024	navlw1	JIRA-33107: Invoice Logging Use Levels
25 Feb 2025	navah1	Story 34141: MTN - Performance Improvements - Review for invLog() Methods
*/

vars
	previousTrans : CM_TITransaction;
	ti : CM_TrackedItem;
	fieldsChanged : String;
	logText	: String;
	canLogExtra	: Boolean;	//28.02.2025 navah1	#34141
begin
	canLogExtra	:= app.canLogExtraDetail();				//28.02.2025 navah1	#34141
	ti 			:= _controller.myTrackedItem;
	
	if not ti.myCargoType.isBreakBulkMulti then
		return;
	endif;

	self.savePreviousVersion();
	if (self.previousVersions &lt;&gt; null) and (self.previousVersions.size  &gt; 0) then
		previousTrans:= self.previousVersions[1];
	endif;
	
	if _controller.updateQuantity and (self.totalQuantity &lt;&gt; ti.totalQuantity) then
		self.totalQuantity := ti.totalQuantity;
		fieldsChanged := fieldsChanged &amp; " " &amp;  CM_TrackedItem::totalQuantity.name;		
	endif;
	
	if _controller.updateVolume and (self.totalVolume &lt;&gt; ti.getMyTotalVolume) then
		self.totalVolume := ti.getMyTotalVolume;
		fieldsChanged := fieldsChanged &amp; " " &amp;  CM_TrackedItem::totalVolume.name;
	endif;
	
	if _controller.updateWeight and (self.totalWeight &lt;&gt; ti.totalWeight) then
		self.totalWeight := ti.totalWeight;
		fieldsChanged := fieldsChanged &amp; " " &amp;  CM_TrackedItem::totalWeight.name;
	endif;
	
	if previousTrans &lt;&gt; null then
		if fieldsChanged = null then
			self.previousVersions.remove(previousTrans);
			delete previousTrans;
		else
			previousTrans.setExtraData(TrnsExtraDataAuditInfo, "Re-sync updated transaction" &amp; fieldsChanged );
		endif;
	endif;
	if canLogExtra then	//28.02.2025 navah1	#34141
		app.invLog(" ", LogINFO.String);			// blank line before it to break up each transaction
		logText := "'" &amp; self.typeString &amp; "' Transaction";
		if self.myTrackedItem &lt;&gt; null then
			logText := logText &amp; " " &amp; self.myTrackedItem.id;
		endif;
		logText := logText &amp; " " &amp; self.dateTime.asStringJMT;
		app.invLog(logText, LogTRACE.String);
	endif;
end;</source>
        <Parameter name="_controller" type="CMIF_TiTransactionResync"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setForUpdateResync" id="738b3254-e234-4388-9523-bde74c6707c3">
        <updating/>
        <source>setForUpdateResync(_controller:CMIF_TiTransactionResync; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:		18 December 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
17/08/2017	jlgkpd1	TFS #5725 - If nothing is changed, then delete the created previousTrans
05/06/2019	jlgdap1	TFS 44554 AAT Stevedore Data Access
03/3/2020   cnwma1  Bug 48772: ADP - RE: Resyncing Issue in Production
02/10/2020  cnwma1  ChangeRequest 50112: ASPA - GCI Stevedores
04/04/2023	navmk20	Task 57433: Country of Origin - Transactions Resync
20/06/2023	navkc1	CR 55653 Task 58724: EUP - Re evaluate Contract Id
23 Oct 2024	navlw1	JIRA-33107: Invoice Logging Use Levels
25 Feb 2025	navah1	Story 34141: MTN - Performance Improvements - Review for invLog() Methods
*/

vars
	logText,
	fieldsChanged	    : String;
	ti 				    : CM_TrackedItem;
	bu 				    : CM_Bank;
	previousTrans 		: CM_TITransaction;
	currentTrailerType  : String;
	currentCountryOfOrigin   : CM_Country; // 4.4.2023 navmk20 TFS 57433
	stevedoreObj        : CM_Stevedore;
	steveCode,slCode           : String;
	canLogExtra	: Boolean;	//28.02.2025 navah1	#34141
begin
	canLogExtra	:= app.canLogExtraDetail();				//28.02.2025 navah1	#34141 
	//epr TFS 2996 8/12/16
	self.savePreviousVersion();
	if self.previousVersions &lt;&gt; null and self.previousVersions.size  &gt; 0 then
		previousTrans:= self.previousVersions[1];
	endif;
	
	ti := _controller.myTrackedItem;
	
	if _controller.updateBusinessUnit then
		if self.companyCode &lt;&gt; ti.companyCode then
			self.companyCode := ti.companyCode;
			if ti.companyOid &lt;&gt; null and ti.companyOid.terminal &lt;&gt; self.myTerminal then
				self.myTerminal := null;
				self.myTerminal := ti.companyOid.terminal;
				fieldsChanged   := fieldsChanged &amp; " " &amp;  CM_TrackedItem::companyCode.name;
			endif;
		endif;
	endif;
	
	if _controller.updateCommodity then
		if self.commodity &lt;&gt; ti.commodity then
			self.commodity := ti.commodity;
			fieldsChanged  := fieldsChanged &amp; " " &amp;  CM_TrackedItem::commodity.name;
		endif;
	endif;
	
	if _controller.updateConsignee then
		if self.consignee &lt;&gt; ti.consignee then
			self.consignee := ti.consignee;
			fieldsChanged  := fieldsChanged &amp; " " &amp;  CM_TrackedItem::consignee.name;
		endif;
	endif;
	
	if _controller.updateConsignor then
		if self.consignor &lt;&gt; ti.consignor then
			self.consignor := ti.consignor;
			fieldsChanged  := fieldsChanged &amp; " " &amp;  CM_TrackedItem::consignor.name;
		endif;
	endif;
	
	if _controller.updateFreightForwarder then
		if self.freightForwarderCode &lt;&gt; ti.freightForwarderCode then
			self.freightForwarderCode := ti.freightForwarderCode;
			fieldsChanged 			  := fieldsChanged &amp; " " &amp;  CM_TrackedItem::freightForwarderCode.name;
		endif;
	endif;
	
	if _controller.updateContents then
		if ti.isContainer() or ti.isTILC then //jlier1 TFS 65208 15/7/24
			if self.contentsStatus &lt;&gt; ti.getContentsStatus then
				self.contentsStatus := ti.getContentsStatus;
				fieldsChanged 		:= fieldsChanged &amp; " " &amp;  CM_Container::contentsStatus.name;
			endif;
		endif;
	endif;
	
	if _controller.updateCustomsAgent then
		if ti.myCustomsAgent &lt;&gt; null then
			if self.customsAgentCode &lt;&gt; ti.myCustomsAgent.code then
				self.customsAgentCode := ti.myCustomsAgent.code;
				fieldsChanged         := fieldsChanged &amp; " " &amp;  CM_TrackedItem::myCustomsAgent.name;
			endif;
		elseif self.customsAgentCode &lt;&gt; null then
			self.customsAgentCode := null;
			fieldsChanged         := fieldsChanged &amp; " " &amp;  CM_TrackedItem::myCustomsAgent.name;
		endif;
	endif;
	
	if _controller.updateDestinationPort then
		if self.destinationPort &lt;&gt; ti.destinationPort then
			self.destinationPort := ti.destinationPort;
			fieldsChanged 		 := fieldsChanged &amp; " " &amp;  CM_TrackedItem::destinationPort.name;
		endif;
	endif;
	
	if _controller.updateDischargePort then
		if self.dischargePort &lt;&gt; ti.dischargePort then
			self.dischargePort := ti.dischargePort;
			fieldsChanged 	   := fieldsChanged &amp; " " &amp;  CM_TrackedItem::dischargePort.name;
		endif;
	endif;
	
	if _controller.updateImexStatus then
		if self.imExStatus &lt;&gt; ti.getImExStatus()then
			self.imExStatus := ti.getImExStatus();
			fieldsChanged   := fieldsChanged &amp; " " &amp;  CM_TrackedItem::imexStatus.name;
		endif;
	endif;
	
	if _controller.updateOperator then
		if self.operatorCode &lt;&gt; ti.operatorCode then
			self.operatorCode := ti.operatorCode;
			fieldsChanged 	  := fieldsChanged &amp; " " &amp;  CM_TrackedItem::operatorCode.name;
		endif;
	endif;
	
	if _controller.updateQuantity then
		if self.canBeResync(ti) then  						//03.03.2020 cnwma1 #48772
			if self.totalQuantity &lt;&gt; ti.totalQuantity then
				self.totalQuantity := ti.totalQuantity;
				fieldsChanged      := fieldsChanged &amp; " " &amp;  CM_TrackedItem::totalQuantity.name;
			endif;
		endif;
	endif;
	
	if _controller.updateVolume then
		if self.canBeResync(ti) then  						//03.03.2020 cnwma1 #48772
			if self.totalVolume &lt;&gt; ti.getMyTotalVolume  then
				self.totalVolume := ti.getMyTotalVolume;
				fieldsChanged    := fieldsChanged &amp; " " &amp;  CM_TrackedItem::totalVolume.name;
			endif;
		endif;
	endif;
	
	if _controller.updateWeight then
		if self.canBeResync(ti) then  						//03.03.2020 cnwma1 #48772
			if self.totalWeight &lt;&gt; ti.totalWeight then
				self.totalWeight := ti.totalWeight;
				fieldsChanged    := fieldsChanged &amp; " " &amp;  CM_TrackedItem::totalWeight.name;
			endif;
		endif;
	endif;
	
	if _controller.updateLength then
		if self.totalLength &lt;&gt; ti.length then
			self.totalLength := ti.length;
			fieldsChanged    := fieldsChanged &amp; " " &amp;  CM_TrackedItem::length.name;
		endif;
	endif;
	
	if _controller.updateStevedore then														// TFS 44554
		/*
		if self.stevedoreCode &lt;&gt; ti.stevedoreCode then										// TFS 44554
			self.stevedoreCode := ti.stevedoreCode;											// TFS 44554
			fieldsChanged 	   := fieldsChanged &amp; " "  &amp; CM_TrackedItem::stevedoreCode.name;// TFS 44554
		endif;																				// TFS 44554
		*/
		//02.10.2020 cnwma1 TFS #50112
		stevedoreObj := self.getTIStevedore();
		if stevedoreObj &lt;&gt; null then
			steveCode := stevedoreObj.code;
		endif;
		if self.stevedoreCode &lt;&gt; steveCode then										
			self.stevedoreCode := steveCode;											
			fieldsChanged 	   := fieldsChanged &amp; " "  &amp; CM_TrackedItem::stevedoreCode.name;
		endif;
		//02.10.2020 cnwma1 TFS #50112
	endif;																					// TFS 44554
	
	//29 Oct 2020	NDL	TFS 50113 - Very small window to allow update of this.
	if _controller.updateTrailerType then
		currentTrailerType := ti.getCurrentTrailerType;
		if currentTrailerType &lt;&gt; null and self.getTrailerType &lt;&gt; currentTrailerType then
			if self.isKindOf( CM_ReceiveRoad ) then
				self.CM_ReceiveRoad.setTrailerTypeCode( currentTrailerType );											
				fieldsChanged 	   := fieldsChanged &amp; " "  &amp; CM_ReceiveRoad::trailerTypeCode.name;
			elseif self.isKindOf( CM_ReleaseRoad ) then
				self.CM_ReleaseRoad.setTrailerTypeCode( currentTrailerType );											
				fieldsChanged 	   := fieldsChanged &amp; " "  &amp; CM_ReleaseRoad::trailerTypeCode.name;
			//27 Nov 2020	NDL	TFS 50422
			elseif self.isKindOf( CM_TrailerDischarge ) then
				self.CM_TrailerDischarge.setTrailerTypeCode( currentTrailerType );											
				fieldsChanged 	   := fieldsChanged &amp; " "  &amp; CM_TrailerDischarge::trailerTypeCode.name;
			//27 Nov 2020	NDL	TFS 50422
			elseif self.isKindOf( CM_TrailerLoad ) then
				self.CM_TrailerLoad.setTrailerTypeCode( currentTrailerType );											
				fieldsChanged 	   := fieldsChanged &amp; " "  &amp; CM_TrailerLoad::trailerTypeCode.name;
			endif;
		endif;																				
	endif;	
		
	// Start - 4.4.2023 navmk20 TFS 57433
	if _controller.updateCountryOfOrigin then 
		currentCountryOfOrigin := ti.myCountryOfOrigin;
		if self.myCountryOfOrigin &lt;&gt; currentCountryOfOrigin then
			self.myCountryOfOrigin := currentCountryOfOrigin;
			fieldsChanged  := fieldsChanged &amp; " Country Of Origin";
		endif;																			
	endif;
	// End - 4.4.2023 navmk20 TFS 57433
	
	 // ### TFS BUG 56663 23FEB2023 NAVAB1
	if _controller.updateShippingLine then	
		slCode := ti.getShippingLineCode();
		if self.shippingLineCode &lt;&gt; slCode then
			self.shippingLineCode := slCode;
			fieldsChanged  := fieldsChanged &amp; " Shipping Line";
		endif;
	
	endif;
	
	//20/06/2023	navkc1	CR 55653 Task 58724
	if _controller.updateContractId then
		if self.contractId &lt;&gt; ti.contractId then
			self.contractId := ti.contractId;
			fieldsChanged := fieldsChanged &amp; " Contract Id";
		endif;
	endif;
	
	//04/10/2024	navkc1	JIRA 32999
	if _controller.updateHsCode then
		if self.hsCode &lt;&gt; ti.hsCode then
			self.hsCode := ti.hsCode;
			fieldsChanged := fieldsChanged &amp; " HS Code";
		endif;
	endif;
	
	if previousTrans &lt;&gt; null then
		if fieldsChanged = null then
			self.previousVersions.remove(previousTrans);
			delete previousTrans;			// TFS #5725
		else
			previousTrans.setExtraData(TrnsExtraDataAuditInfo,"Re-sync updated transaction" &amp; fieldsChanged );
		endif;
	endif;
	
	if canLogExtra then	//28.02.2025 navah1	#34141
		app.invLog(" ", LogINFO.String);			// blank line before it to break up each transaction
		logText := "'" &amp; self.typeString &amp; "' Transaction";
		if self.myTrackedItem &lt;&gt; null then
			logText := logText &amp; " " &amp; self.myTrackedItem.id;
		endif;
		logText := logText &amp; " " &amp; self.dateTime.asStringJMT;
		app.invLog(logText, LogTRACE.String);
	endif;
	
	bu := self.getBusinessUnitObject();
	
	if bu = null then
		if canLogExtra then	//28.02.2025 navah1	#34141
			app.invLog("No business unit, no charge", LogINFO.String);
		endif;
		return;
	endif;
	
	 // ### JIRA 35228 11JUL2025 NAVAB1
	if self.myTerminal &lt;&gt; null
	and not self.myTerminal.getConfig(FinancialsEnabled).Boolean then
			app.invLog("Financials Are Not Enabled, No Charging Will Occur",LogTRACE.String); // navlw1 #JIRA-33692  
		return;
	endif;
	
	bu.createChargeCargoResync(self, _controller);
end;</source>
        <Parameter name="_controller" type="CMIF_TiTransactionResync"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setFreightForwarderForUpgrade" id="5b1b41c1-17d2-46ab-a08c-e3cb7d570261">
        <updating/>
        <source>setFreightForwarderForUpgrade() updating;
/* ---------------------------------------------------------------------------
Created:     06 June 2008 by cnwrs2

Purpose:    PAR 16898 - Added FF code to this class.  Need to set for existing
			data for 7.6.2 release.  This method can be delted once the 7.6.2
			upgrade has been completed.
        
Change Date	Who		Reason
11/03/2011	cnwmh5	PAR #27142 - Change to local variable rather than self for handleDeleteObject exception
------------------------------------------------------------------------------*/
vars
	invalidTI	: Boolean;
	ti			: CM_TrackedItem;
begin

	// if already set or TI is null then return
	ti := self.myTrackedItem;
	if self.freightForwarderCode &lt;&gt; null or 
	  ti = null then
		return;
	endif;
	
	on Exception do app.handleDeletedObject(exception, ti, invalidTI);
	
	self.freightForwarderCode := ti.freightForwarderCode;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setFromCMIF_TITransactionCntrl" id="a1c3f584-e9d1-4ffb-b683-233a9eca8fe3">
        <updating/>
        <source>setFromCMIF_TITransactionCntrl(_tiTransCntrl : CMIF_TITransactionController;
							_passport : CM_Passport input)updating;
//--------------------------------------------------------------
//Created: 11 October 2002 By: cnwgd1
//
//	Changes
//				PAR 16898 - RJS June 2008 - add FF
//--------------------------------------------------------------
// 18 Dec 2012	cnwcs5 CCMS SFW 1294 /par 30855
// 07 Dec 2022 navma1 ChangeRequest 52499: MTN - Improve the performance of the Edi file verification process.
vars
	oldDeleted	: Boolean;
begin 
	if _tiTransCntrl = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Null _tiTransCntrl passed to method. Contact Developer.');
		return;
	endif;

	oldDeleted 					:= self.deleted;
	self.ammended 				:= _tiTransCntrl.ammended;
	self.dateTime 				:= _tiTransCntrl.dateTime;
	self.deleted 				:= _tiTransCntrl.deleted;
	self.freightForwarderCode	:= _tiTransCntrl.freightForwarderCode;			//PAR 16898 - RJS June 2008
	self.noCharge 				:= _tiTransCntrl.noCharge;
	self.operatorCode 			:= _tiTransCntrl.operatorCode.trimBlanks();
	self.superseded 			:= _tiTransCntrl.superseded;
	self.type 					:= _tiTransCntrl.type;
	self.myToDoTask				:= _tiTransCntrl.myToDoTask;					//31 Dec 2009	NDL	CCMS MES 1006
	self.urNumber 				:= _tiTransCntrl.urNumber;
	self.userGenerated 			:= _tiTransCntrl.userGenerated;
	self.userId 				:= _tiTransCntrl.userId.trimBlanks().toUpper();
	
	self.setMyTrackedItem(_tiTransCntrl.myTrackedItem, _tiTransCntrl );

	self.operatorCode 			:= _tiTransCntrl.operatorCode.trimBlanks(); // ### TFS CR 58263 TASK 58264 22JAN2024 NAVAB1 - Ownership Change might have the previous operator

	//th2 PAR 11962 - 1090 on _tiTransCntrl.myOtherTrackedItem if user defined todo task
	//with pack/unpack/repack etc transactrion type
	if self.hasOtherTrackedItem and _tiTransCntrl.myOtherTrackedItem &lt;&gt; null then
		self.setOtherTrackedItem(_tiTransCntrl.myOtherTrackedItem);
	endif;

	self.updateTI(_passport);
	
	if _tiTransCntrl.deleted and (oldDeleted &lt;&gt; _tiTransCntrl.deleted) then
		// deleting a transaction that was not previously deleted
		if _tiTransCntrl.myTerminal.getConfig (CamsCreateTrxAudit).Boolean then		// par 30855
			self.createCAMSAuditTransaction (AuditDeleted, self, app.myPassport);	// par 30855
		endif;																		// par 30855
	endif;


	//epr TFS 2996 7/12/16
	if _tiTransCntrl.totalQuantity &gt; 0 then
		self.totalQuantity := _tiTransCntrl.totalQuantity;
	endif;
	if _tiTransCntrl.totalWeight &gt; 0 then
		self.totalWeight := _tiTransCntrl.totalWeight;
	endif;
	if _tiTransCntrl.totalVolume &gt; 0 then // TFS 7031
		self.totalVolume := _tiTransCntrl.totalVolume; // TFS 7031
	endif;
	
	//10 Sep 2019	NDL	TFS 42882
	if _tiTransCntrl.isKindOf(CMIF_MoveTransactionController) then
		self.isDirectReleaseMove := _tiTransCntrl.CMIF_MoveTransactionController.isDirectReleaseMove;
	endif;
	
	//07.12.2022 navma1 #52499
	if not app.myPassport.isInEdiVerifyMode then
		// CNWAB1 FEB2017 - For logs created the KPI cargo counter as the received transaction is created.
		// TFS 44804 JLGAB1 MAY2019 - Now will do KPI cargo counter for all cargo types as the receival transaction is created.
		if self.myTrackedItem&lt;&gt; null then // TFS 44804
			self.myTrackedItem.createCargoCounterKPI(self);
		
		endif;
		
		self.setContextInfo();	//14 Sep 2015	NDL	Par 36900
	endif;

end;</source>
        <Parameter name="_tiTransCntrl" type="CMIF_TITransactionController"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setFromCMIF_TIUpdateController" id="57abb572-5e8e-4a8a-ab79-16fdfee499b9">
        <updating/>
        <source>setFromCMIF_TIUpdateController(_tiUpdateCntrlr : CMIF_TIUpdateController; _passport : CM_Passport) updating;
//--------------------------------------------------------------
//Created: 01 October 2002 By: cnwgd1
//--------------------------------------------------------------
vars

begin

end;</source>
        <Parameter name="_tiUpdateCntrlr" type="CMIF_TIUpdateController"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setFromNoInfoEdit" id="6410ab6e-b0c2-49af-b68c-cc44383c5283">
        <updating/>
        <source>setFromNoInfoEdit(_theTI : CM_TrackedItem; _editTrans : CM_TITransaction) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 September 2009	cnwrd1	Initial creation

*/

vars

begin

	self.myTrackedItem := _theTI;
	
	self.commodity 		:= _editTrans.commodity ; 
	self.totalWeight 	:= _editTrans.totalWeight;
	self.voyage 		:= _editTrans.voyage;	
	self.voyageCode		:= _editTrans.voyageCode;		// PAR 24432 	
	self.operatorCode 	:= _editTrans.operatorCode;

epilog

end;</source>
        <Parameter name="_theTI" type="CM_TrackedItem"/>
        <Parameter name="_editTrans" type="CM_TITransaction"/>
    </JadeMethod>
    <JadeMethod name="setFromTrackedItem" id="08672e7f-d50b-43a1-8eb1-c49b0a781238">
        <updating/>
        <source>setFromTrackedItem(_ti : CM_TrackedItem ; _tiTransCntrl :  CMIF_TITransactionController  ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
18 October 2022		jlier1	Initial creation 55140
28 November 2022	jlizm1	TFS 55280 Harmonized System Codes
13 Jan 2023 		navvt20	TFS 55625 TFS CR 55625 Task 55658: Jade - Contract Id TRX
04 Oct 2023			navma1 ChangeRequest 59638: EUP | Ship Operations in DD - [54176.010] - [Receive] Work Order Detail Grouping
10 May 2024			jlika1	TFS 63958 CUX | MAFI - MAFI Fields on Cargo Invoice Allocations and Transactions - Transactions
17 Sep 2024			jlizm1	TFS 66088 Parent Mafi id is required on cargo transaction
*/

vars
	totQ 	: Integer;
	totV 	: Decimal [16,4];
	totW 	: Decimal [14,4];
	lc   	: CM_LocationsController;
	trailer	: CM_TILC;
begin
	
	self.setCargoGroupId( _ti.getMyCargoGroupId );	//04 May 2017	NDL	TFS 4274
	self.setMyVoyageRelivant(_ti.myVoyage);
	self.commodity 			:= _ti.commodity;
	self.companyCode 		:= _ti.companyCode;
	self.consignee 			:= _ti.consignee;
	if _ti.myCustomsAgent &lt;&gt; null then
		self.customsAgentCode	:= _ti.myCustomsAgent.code;
	endif;
	self.consignor 			:= _ti.consignor;
	self.freightForwarderCode	:= _ti.freightForwarderCode;	// PAR 16898 - RJS June 2008
	self.id		 			:= _ti.id;
	self.loadPort 			:= _ti.loadPort;
	self.dischargePort 		:= _ti.dischargePort;
	self.destinationPort 	:= _ti.destinationPort;
	self.imExStatus 		:= _ti.getImExStatus;
	self.transitStatus 		:= _ti.getTransitStatus;
	self.operatorCode 		:= _ti.operatorCode.trimBlanks;
	self.hsCode				:= _ti.hsCode;	// TFS 55280
	
	if _tiTransCntrl &lt;&gt; null then
		if not _tiTransCntrl.hasBeenUpdated then //epr TFS 2996 8/12/16
			_tiTransCntrl.getTrxQVWvalues( totQ, totV, totW );	//06 Nov 2014	NDL	Par 35015
			self.totalQuantity 		:= totQ;
			self.totalVolume		:= totV;
			self.totalWeight 		:= totW;
		endif;
	else
		self.totalQuantity 		:= _ti.totalQuantity;
		self.totalVolume		:= _ti.getMyTotalVolume;
		self.totalWeight 		:= _ti.totalWeight;
	endif;
	
	self.totalLength 		:= _ti.length; // PAR 31615
	self.isWeightCertified	:= _ti.isWeightCertified;				//+cnwml2 MSL CCMS 1017
	
	//20 Aug 2019	NDL	TFS 46161 - Cargo being mergde directly off ship to yard was populating the wrong vpoyage
	
	if _tiTransCntrl &lt;&gt; null then						//04.10.2023 navma1 #59638
		lc := _tiTransCntrl.myOriginatingLocation;
	endif;
	
	if _ti.myCargoType.allowDuplicates
	and lc &lt;&gt; null
	and lc.isVoyageController
	then
		self.voyage 		:=  lc.CM_VoyageController.myVoyage;
		if self.voyage &lt;&gt; null then
			self.setMyVoyageRelivant( self.voyage );
			self.voyageCode	:= self.voyage.code;
		endif;
	else
		self.voyage 		:= _ti.myVoyage;
		self.voyageCode 	:= _ti.voyageCode;		// PAR 24432
	endif;
	
	self.isNoInfo			:= _ti.isNoInfo; //cnwrd1 par 17542
	
	self.state 				:= _ti.state; // cnwrd1 par 22624 3.5.2010 
	
	// ### TFS 55271 31Oct2022 NAVPW1
	self.allDebtorsByType.clear();	//19 Jul 2017	NDL	TFS 5458
	_ti.allDebtorsByType.copy(self.allDebtorsByType); //22 May 2008 cnwgb1 CP CCMS 1047 PAR 16666
	// ### TFS 55271 31Oct2022 NAVPW1
	self.contentsStatus := _ti.getContentsStatus;

	//27 July 2010	NDL	Par 23056
	if _ti.isChild then
		self.setExtraData(TrnsExtraDataChild, true.Integer);
	endif;
	self.tareWeight 	   := _ti.weightTare;				//15 Nov 2016	NDL	TFS 2959 / 2420
	self.cargoWeight	   := _ti.weightCargo;				//15 Nov 2016	NDL	TFS 2959 / 2420
	
	self.stevedoreCode     := _ti.stevedoreCode;			// TFS 44554
	self.billOfLading      := _ti.billOfLading;				// 46043
	self.shippingLineCode  := _ti.getShippingLineCode();	// 14.07.2022 navsrk20 53195	
	self.myCountryOfOrigin := _ti.myCountryOfOrigin;
	
	self.setContractFromTI(_ti); // ### TFS 57512 12APR2023 NAVAB1 
	
	self.setINCOTermFromTI(_ti); // ### TFS CR 64873 TASK 65509 06AUG2024 NAVAB1
	
	if _ti.isOnTrailer then
		self.parentTrailerTypeCode := _ti.getCurrentTrailerType();
		
		trailer := _ti.getCurrentTrailer();
		
		if trailer &lt;&gt; null then
			self.parentTrailerId := trailer.id;
			self.parentOnboardQuantity := trailer.getAllOnboardTIsCount();
		endif;
	endif;
	
	if	_ti.isTILC() or 
		_ti.isContainer() //02/10/2025	navkc1 JIRA 36151
		then
		
		//02/10/2025	navkc1 JIRA 36151
		if _ti.isTILC() then
			self.onboardQuantity := _ti.CM_TILC.getAllOnboardTIsCount();
			self.onboardCosingeeCosingnors := _ti.CM_TILC.getOnboardConsigneeConsignor();
		endif;
		
		//self.onboardCargoTypes := _ti.CM_TILC.getOnboardCargoTypes(); //02/10/2025	navkc1 JIRA 36151
		self.onboardCargoTypes := _ti.getOnboardCargoTypes(); //02/10/2025	navkc1 JIRA 36151
		self.onboardSubTypes := _ti.getOnboardSubTypes();
	endif;
	
epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_tiTransCntrl" type="CMIF_TITransactionController"/>
    </JadeMethod>
    <JadeMethod name="setInvalidReference" id="9f795e65-6b48-41b9-bcbc-5308df321ea1">
        <updating/>
        <executionLocation>server</executionLocation>
        <source>setInvalidReference(_pName: String; _fixit: Boolean) updating, serverExecution;
// cnwrs1 mar 2005 know voyages can be invalid
vars

begin
	if _pName = CM_TITransaction::voyage.name or
	   _pName = CM_Connect::otherTrackedItem.name then // can be in other transactions as well, none are inversed
		return;
	else
		inheritMethod(_pName, _fixit);
	endif;
end;</source>
        <Parameter name="_pName" type="String"/>
        <Parameter name="_fixit" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setMyCountryOfOrigin" id="08ca3e3d-06f3-4e01-9542-72757d8718aa">
