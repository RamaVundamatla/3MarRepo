    <JadeMethod name="getCCEventJSON" id="eedccf00-a94e-4411-ad40-a2d145354292">
        <source>getCCEventJSON() : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 August 2019	jlger1	Initial creation

*/

vars
	ccStuff : CMIF_CCStuff;
	json : String;
	jsonHelper		: CMIF_JsonHelper;
	otherTI : CM_TrackedItem;
	ccEventType : String;
begin
	ccEventType:=self.getCCEventType;
	if ccEventType = null then
		return null;
	endif;
	
	if self.myTrackedItem = null then
		return null;
	endif;
	
	if self.myTrackedItem.externalProfileSecret = null then
		return null;
	endif;

	otherTI:=self.getOtherTrackedItem;
	if otherTI = null then
		return null ;
	endif;
	
	if otherTI.externalProfileSecret = null then
		return null;
	endif;
	
	create ccStuff transient;
	ccStuff.parentSecretId :=self.myTrackedItem.externalProfileSecret;
	ccStuff.childrenSecretIds.add(otherTI.externalProfileSecret);
	
	ccStuff.deserializeJSON(json);
	
	create jsonHelper transient;

	json:= jsonHelper.formatJsonString(json);
	
	return CN_LEFT_BRACKET &amp; json  &amp;  CN_RIGHT_BRACKET;
epilog
	delete ccStuff;
	delete jsonHelper;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getCCEventType" id="d9672810-e814-40a8-9a25-58e26994dd66">
        <source>getCCEventType(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 August 2019	jlger1	Initial creation

*/

vars

	otherTI : CM_TrackedItem;
begin
	if self.action &lt;&gt; ACTION_PACK_CHILD then
		return null;
	endif;

	otherTI:=self.getOtherTrackedItem;
	if otherTI = null then
		return null;
	endif;
	
	if otherTI.externalProfileSecret = null then
		return null;
	endif;
	
	return CC_EventType_Packed;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="f7ab1008-51dd-46fe-b353-ad8c02f0dbe1">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 June 2010	cnwndl1	Initial creation	Par 23498

*/

vars
	packAmount,
	lDetail : String;
	otherTI,
	theTI	: CM_TrackedItem;
begin

	if _attrName = ETRow_Details  then
		if self.deleted then
			return self.getDeletedDetails();		// 15/10/18 MAP TFS41191
			
		else
			theTI := self.myTrackedItem;
			otherTI := self.getOtherTrackedItem();
			lDetail := "Packed ";
			packAmount:= self.getPackAmount;
			if packAmount &lt;&gt; null then
				lDetail:=lDetail &amp; packAmount &amp; " x ";
			endif;
			if self.action = ACTION_PACK_CHILD then
				if otherTI &lt;&gt; null then
					lDetail := lDetail &amp; " " &amp; otherTI.id;
				endif;
				lDetail := lDetail &amp; " into ";
				if theTI &lt;&gt; null then
					lDetail := lDetail &amp; " " &amp; theTI.id;
				endif;
			elseif self.action = ACTION_PACK_INTO then
				if theTI &lt;&gt; null then
					lDetail := lDetail &amp; " " &amp; theTI.id;
				endif;
				lDetail := lDetail &amp; " into ";
				if otherTI &lt;&gt; null then
					lDetail := lDetail &amp; " " &amp; otherTI.id;
				endif;
			endif;
		
			lDetail := lDetail &amp; " " &amp; self.urNumber.String;			
			
			//epr TFS 2897 5/12/16
			if self.documentName &lt;&gt; null then
				lDetail := lDetail &amp; ". " &amp; self.documentContext &amp; " release is " &amp; self.documentName;
			endif;
			
			return lDetail;
			
		endif;

	elseif _attrName = ETRow_PackedInto then
		theTI := self.myTrackedItem;
		otherTI := self.getOtherTrackedItem();
		if self.action = ACTION_PACK_CHILD then
			if theTI &lt;&gt; null then
				lDetail := theTI.id;
			endif;
		elseif self.action = ACTION_PACK_INTO then
			if otherTI &lt;&gt; null then
				lDetail := otherTI.id;
			endif;
		endif;
		return lDetail;
		
	elseif _attrName = ETRow_Action then
		return self.action.asStringJMT();

	else
		return inheritMethod(_attrName, _short);
	
	endif;

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getEnquiryRow" id="7342363c-80a3-4083-940b-eed24ba5e37a">
        <source>getEnquiryRow(): String;
// ---------------------------------------------------------------------------
// Created:  May  2001 By Andrew Bishop cnwab1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
19 May 2010	cnwkpd1	PAR #20728 - remove isValidObject calls for performance

*/

vars
	lDetail : String;
	otherTI,
	theTI	: CM_TrackedItem;
	
begin

	theTI := self.myTrackedItem;
//	if (not global.isValidObject(theTI)) then
//		theTI := null;
//	endif;

	otherTI := self.getOtherTrackedItem();
//	if (not global.isValidObject(otherTI)) then
//		otherTI := null;
//	endif;
	
	lDetail := inheritMethod();
	lDetail := lDetail &amp; "Packed ";

	if self.action = ACTION_PACK_CHILD then
		if otherTI &lt;&gt; null then
			lDetail := lDetail &amp; " " &amp; otherTI.id;
		endif;
		lDetail := lDetail &amp; " into ";
		if theTI &lt;&gt; null then
			lDetail := lDetail &amp; " " &amp; theTI.id;
		endif;
	elseif self.action = ACTION_PACK_INTO then
		if theTI &lt;&gt; null then
			lDetail := lDetail &amp; " " &amp; theTI.id;
		endif;
		lDetail := lDetail &amp; " into ";
		if otherTI &lt;&gt; null then
			lDetail := lDetail &amp; " " &amp; otherTI.id;
		endif;
	endif;

	if lDetail &lt;&gt; "" then
		lDetail := lDetail &amp; " " &amp; self.urNumber.String;
	else
		lDetail := self.urNumber.String;
	endif;			
	
	return lDetail;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
