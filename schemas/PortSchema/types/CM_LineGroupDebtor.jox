    <JadeMethod name="setForUpdate" id="29e2716b-9389-4e03-8d05-ffede439a690">
        <updating/>
        <source>setForUpdate(_proxyLineGroupDebtor : CM_LineGroupDebtor) updating;
// ---------------------------------------------------------------------------
// Created:     15 March 2002 by cnwdf1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	self.debtor := _proxyLineGroupDebtor.debtor;
	self.code := _proxyLineGroupDebtor.code;
end;</source>
        <Parameter name="_proxyLineGroupDebtor" type="CM_LineGroupDebtor"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="9b65563b-9aee-4db6-8a54-4400e1d21f64">
        <updating/>
        <source>setProxy(_shippingLineCode, _shipPortGroupCode : String; _debtor : CM_DebtorNode) updating;
// ---------------------------------------------------------------------------
// Created:     15 March 2002 by cnwdf1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	debtorCode	: String;
begin


	if _debtor &lt;&gt; null then
		debtorCode := _debtor.name.trimBlanks;
	endif;

	self.code	:= _shippingLineCode.trimBlanks &amp; ' ' &amp; 
				   _shipPortGroupCode.trimBlanks &amp; ' ' &amp;
				   debtorCode;
				   
	self.debtor := _debtor;
end;</source>
        <Parameter name="_shippingLineCode" type="String"/>
        <Parameter name="_shipPortGroupCode" type="String"/>
        <Parameter name="_debtor" type="CM_DebtorNode"/>
    </JadeMethod>
</Class>
