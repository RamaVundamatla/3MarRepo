    <JadeMethod name="getLogDocketDataDef" id="23f115c5-e4ae-4823-a73b-043dab2652b5">
        <source>getLogDocketDataDef() : EntTableDef;
// ---------------------------------------------------------------------------
// Created:     14 January 2003		cnwth2	
