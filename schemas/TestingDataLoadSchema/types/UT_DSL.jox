    <JadeMethod name="getTrackedItemByCargoType" id="538c6a91-3f74-4855-b336-f0e337412315">
        <source>getTrackedItemByCargoType(_id: String; _cargoType: Integer): CM_TrackedItem;
//18 September 2008	cnwdw1	
// 16/05/2011	cnwmh5	Change so that returns the correct ti as tiSet includes partial matches as well
// 06 Sep 2016	cnwrs1	TFS 2586 dont always include archived voyages and lookup reveresed even if we found data in non reverese lookup
vars
	tiSet		: CM_TISet;
	ti			: CM_TrackedItem;
	returnTI	: CM_TrackedItem;	
begin
	returnTI := null;
	create tiSet transient;
	self.getTerminal.lookupAllTIsOfIdCargoType(_id, _cargoType, tiSet, false, false, null);
	////app.writeLog("!!!!! _id: " &amp; _id &amp; ' tiSet.size: ' &amp; tiSet.size.String &amp; " !!!!!", LogAlways);			// 29/08/2012 cnwmh5 - Can be removed
	if tiSet.size &gt; 0 then
		foreach ti in tiSet do			// 16/05/2011 cnwmh5
			if ti.id = _id then
				returnTI := ti;
				break;
			endif;
		endforeach;	
	endif;
	return returnTI;
epilog
	delete tiSet;
end;</source>
        <Parameter name="_id" type="String"/>
        <Parameter name="_cargoType" type="Integer"/>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
