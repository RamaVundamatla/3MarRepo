    <JadeMethod name="getAddressBookItems" id="06c7ef90-0b17-4ac0-b33b-30f6070b1668">
        <updating/>
        <source>getAddressBookItems(itemType:Integer; array1:StringArray io; array2:StringArray io; maxItems:Integer; itemCount:Integer io) updating;
	// Method returns address book entries in arrays of variable length strings.

vars
	_p1 : Integer;
	_p2 : Integer;

begin

	_p1 := itemType;
	_p2 := maxItems;


	_jadeActiveXMethodio('GetAddressBookItems', '', 1, _p1, array1, array2, _p2, itemCount);

end;</source>
        <Parameter name="itemType" type="Integer"/>
        <Parameter name="array1" type="StringArray" usage="io"/>
        <Parameter name="array2" type="StringArray" usage="io"/>
        <Parameter name="maxItems" type="Integer"/>
        <Parameter name="itemCount" type="Integer" usage="io"/>
    </JadeMethod>
