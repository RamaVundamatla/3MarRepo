    <JadeMethod name="runGarbageCollection" id="2927c7c5-a0bd-4b5b-ab01-8c179da7f7ea">
        <source>runGarbageCollection( _date : Date; _terminal : CM_Terminal);

/*

Purpose:	run BGP garbage collect , similar to jadescript rungarbagecollect		

Parameters:			_date = date to run up too

Return Value:		


Date		Who		Reason
08 March 2012	cnwrd1	Initial creation
TFS 6960 jlgns1 8/11/17 QNS - Disk space issues and house keeping inside JMT
20 September 2022 navmv20 ChangeRequest 53403: MTN - Garbage Collection of Release Request
13 Feb 2023		  navhl20 ChangeRequest 54900:[56518] EUP - Garbage Collection for Document Attachments
21 Jul 2023 	  navhl20 ChangeRequest 58158: EUP | [Framework] - Delivery Dispatch Garbage Collection
11 Aug 2025		  navhl20 Story MTN-35650: TPT | Uploading of Photos into MTN Production | 2 | Thin Client Changes
*/

vars
	bgpRequest				: BGP_DatabasePurgeRequest;
	date					: Date;
//	terminal				: CM_Terminal;
//	sleepInterval			: Integer;
	voyage,
	location,
	docket,
	offsite,
	prenote,
	bookingRef,
//	reefer,
	discrep,
	machine, 
	sundry,
	xlation,
	ddExtractHistory,
	lockTransactions,
	ediData,
	yardAllocationLogs,
	jmtReports,
	logCheckScaleHdr,
	vehicleVisit,
	cargoPhoto,
	eventRequests,
	nsActivity				: Boolean;
	dutyDocs				: Boolean;
	vehicleBookingSlots		: Boolean;
	cargoGroups				: Boolean;
	maxDurationMinutes		: Integer;
	truncateEDIInfoXML 		: Boolean;	//13 Sep 2021	NDL	TFS 51718
	purgeSecGateUnknTrucks	: Boolean;	// ### TFS 51994 01Oct2021 NAVPW1
	purgeReleaseRequests    : Boolean;  //16/09/2022 navmv20 TFS 53403
	purgeAttachCargoTypes   : Boolean;  
	purgeAttachContracts    : Boolean;  
	purgeAttachInvoices     : Boolean;  
	purgeAttachVoyages      : Boolean;  
	purgeAttachWorkOrders   : Boolean;  
	purgeWorkOrderJobSheet	: Boolean;
	purgeVisitPhotos		: Boolean;
	purgeAgGatewayMessages	: Boolean;	//navra1 - MTN-35875- 5th Sep 2025-2
//
//23/05/2012	cnwrs1	Par 29613
//
begin

	voyage					:= false;
	location				:= false;
	docket					:= false;
	offsite					:= false;
	prenote					:= false;
	bookingRef				:= false;
	nsActivity				:= false;	// ### TFS 50669 06AUG2021 NAVAB1
	discrep					:= false;
	machine					:= false;
	sundry					:= false;
	xlation					:= false;
	ddExtractHistory		:= false;
	lockTransactions		:= false;
	ediData					:= false;
	yardAllocationLogs		:= false;
	jmtReports				:= false;
	logCheckScaleHdr		:= false;
	vehicleVisit			:= false;
	cargoPhoto 				:= false;
	eventRequests			:= false;	//23/05/2012	cnwrs1	Par 29613
	cargoGroups				:= false;
	truncateEDIInfoXML		:= false;
	purgeSecGateUnknTrucks	:= false;	// ### TFS 51994 01Oct2021 NAVPW1
	purgeReleaseRequests    := false;   //16/09/2022 navmv20 TFS 53403
	purgeAttachCargoTypes   := false;  // 13/02/2023 navhl20 #54900[56518]
	purgeAttachContracts    := false;  // 13/02/2023 navhl20 #54900[56518]
	purgeAttachInvoices    	:= false;  // 13/02/2023 navhl20 #54900[56518]
	purgeAttachVoyages    	:= false;  // 13/02/2023 navhl20 #54900[56518]
	purgeAttachWorkOrders   := false;  // 13/02/2023 navhl20 #54900[56518]
	purgeWorkOrderJobSheet	:= false;	//21.7.2023 navhl20 #58158
	purgeVisitPhotos		:= false;	//11.08.2025 navhl20 #35650
	purgeAgGatewayMessages	:= false;	//navra1 - MTN-35875- 5th Sep 2025-2
	
	date := _date;
	
	if not date.isValid then
		self.assertTrueMsg( false, 'The data set is invalid');
		return;
	endif;
	
	if self.opts.includesKey("VOYAGE") then
		voyage := self.opts.bool("VOYAGE");
	endif;	
	
	if self.opts.includesKey("CARGOPHOTO") then
		cargoPhoto := self.opts.bool("CARGOPHOTO");
	endif;		
	
	if self.opts.includesKey("VEHICLEVISIT") then
		vehicleVisit := self.opts.bool("VEHICLEVISIT");
	endif;		
	
	if self.opts.includesKey("LOGCHECKSCALEHDR") then
		logCheckScaleHdr := self.opts.bool("LOGCHECKSCALEHDR");
	endif;		
	
	if self.opts.includesKey("JMTREPORTS") then
		jmtReports := self.opts.bool("JMTREPORTS");
	endif;		
	
	if self.opts.includesKey("YARDALLOCATIONLOGS") then
		yardAllocationLogs := self.opts.bool("YARDALLOCATIONLOGS");
	endif;		
	
	if self.opts.includesKey("EDIDATA") then
		ediData := self.opts.bool("EDIDATA");
	endif;		
	
	if self.opts.includesKey("LOCKTRANSACTIONS") then
		lockTransactions := self.opts.bool("LOCKTRANSACTIONS");
	endif;		
	
	if self.opts.includesKey("DDEXTRACTHISTORY") then
		ddExtractHistory := self.opts.bool("DDEXTRACTHISTORY");
	endif;		
	
	if self.opts.includesKey("XLATION") then
		xlation := self.opts.bool("XLATION");
	endif;	
	
	if self.opts.includesKey("SUNDRY") then
		sundry := self.opts.bool("SUNDRY");
	endif;		
	
	if self.opts.includesKey("MACHINE") then
		machine := self.opts.bool("MACHINE");
	endif;		
	
	if self.opts.includesKey("DISCREP") then
		discrep := self.opts.bool("DISCREP");
	endif;	
	
//	if self.opts.includesKey("REEFER") then
//		reefer := self.opts.bool("REEFER");
//	endif;	

	if self.opts.includesKey("LOCATION") then
		location := self.opts.bool("LOCATION");
	endif;	
	
	if self.opts.includesKey("DOCKET") then
		docket := self.opts.bool("DOCKET");
	endif;	
	
	if self.opts.includesKey("NSACTIVITY") then // ### TFS 50669 06AUG2021 NAVAB1
		nsActivity := self.opts.bool("NSACTIVITY"); // ### TFS 50669 06AUG2021 NAVAB1
	endif;	
	
	if self.opts.includesKey("OFFSITE") then
		offsite := self.opts.bool("OFFSITE");
	endif;	
	
	if self.opts.includesKey("PRENOTE") then
		prenote := self.opts.bool("PRENOTE");
	endif;		
	
	if self.opts.includesKey("BOOKINGREF") then
		bookingRef := self.opts.bool("BOOKINGREF");
	endif;
	
	if self.opts.includesKey("DUTYDOCS") then
		dutyDocs := self.opts.bool("DUTYDOCS");
	endif;
	
	if self.opts.includesKey("VEHICLESCHED") then
		vehicleBookingSlots := self.opts.bool("VEHICLESCHED");
	endif;
	
	if self.opts.includesKey("CARGOGROUPS") then
		cargoGroups := self.opts.bool("CARGOGROUPS");
	endif;
	
	//14 Sep 2021	NDL	TFS 51718
	if self.opts.includesKey("TRUNCATEEDIINFO") then
		truncateEDIInfoXML := self.opts.bool("TRUNCATEEDIINFO");
	endif;
	
	//TFS 6960 jlgns1 8/11/17 QNS - Disk space issues and house keeping inside JMT
	if self.opts.includesKey("MAXDURATIONMINUTES") then
		maxDurationMinutes := self.opts.int("MAXDURATIONMINUTES");
	endif;
	
	//16/09/2022 navmv20 TFS 53403 - start
	if self.opts.includesKey('RELEASEREQUESTS') then
		purgeReleaseRequests :=self.opts.bool('RELEASEREQUESTS');
	endif;
	//16/09/2022 navmv20 TFS 53403 - end
	
	if self.opts.includesKey('ATTACHCARGOTYPES') then				//13/02/2023 navhl20 #54900[56518]
		purgeAttachCargoTypes :=self.opts.bool('ATTACHCARGOTYPES');
	endif;
	if self.opts.includesKey('ATTACHCONTRACTS') then				//13/02/2023 navhl20 #54900[56518]
		purgeAttachContracts :=self.opts.bool('ATTACHCONTRACTS');
	endif;
	if self.opts.includesKey('ATTACHINVOICES') then					//13/02/2023 navhl20 #54900[56518]
		purgeAttachInvoices :=self.opts.bool('ATTACHINVOICES');
	endif;
	if self.opts.includesKey('ATTACHVOYAGES') then					//13/02/2023 navhl20 #54900[56518]
		purgeAttachVoyages :=self.opts.bool('ATTACHVOYAGES');
	endif;
	if self.opts.includesKey('ATTACHWORKORDERS') then				//13/02/2023 navhl20 #54900[56518]
		purgeAttachWorkOrders :=self.opts.bool('ATTACHWORKORDERS');
	endif;
	if self.opts.includesKey('WOJOBSHEET') then						//21.7.2023 navhl20 #58158
		purgeWorkOrderJobSheet :=self.opts.bool('WOJOBSHEET');
	endif;
	
	if self.opts.includesKey('VisitPhotos') then						//11.08.2025 navhl20 #35650
		purgeVisitPhotos := self.opts.bool('VisitPhotos');
	endif;
	
	if self.opts.includesKey('AGGATEWAYMESSAGES') then						//navra1 - MTN-35875- 5th Sep 2025-2
		purgeAgGatewayMessages := self.opts.bool('AGGATEWAYMESSAGES');
	endif;
	
//	app.initialize;
	
//	sleepInterval	:= null; tfs 6960
//	terminal		:= self.getTerminal();

	if _terminal = null then
		return;
	endif;
	
	app.myPassport.setMyTerminal(_terminal);
	//app.myPassport.setMyUserFromCode( SUPERUSER_Str );
	
	create bgpRequest transient;

	
	bgpRequest.initDatabasePurge(	app.myPassport.myUser, _terminal, date,
									voyage, location, docket, offsite, prenote, bookingRef,
									nsActivity, discrep, machine, sundry, xlation, ddExtractHistory, // ### TFS 50669 06AUG2021 NAVAB1
									lockTransactions, ediData, yardAllocationLogs, jmtReports,
									logCheckScaleHdr, vehicleVisit, cargoPhoto, eventRequests,
									dutyDocs, cargoGroups, vehicleBookingSlots, false,
									truncateEDIInfoXML,	//13 Sep 2021	NDL	TFS 51718
									maxDurationMinutes,
									purgeSecGateUnknTrucks, // ### TFS 51994 01Oct2021 NAVPW1
									purgeReleaseRequests,	// 16/09/2022 navmv20 TFS 53403
									purgeAttachCargoTypes,  // 13/02/2023 navhl20 #54900[56518]
									purgeAttachContracts,  // 13/02/2023 navhl20 #54900[56518]
									purgeAttachInvoices,  // 13/02/2023 navhl20 #54900[56518]
									purgeAttachVoyages,  // 13/02/2023 navhl20 #54900[56518]
									purgeAttachWorkOrders,  // 13/02/2023 navhl20 #54900[56518])
									purgeWorkOrderJobSheet,	//21.7.2023 navhl20 #58158
									purgeVisitPhotos,		//11.08.2025 navhl20 #35650
									purgeAgGatewayMessages	//navra1 - MTN-35875- 5th Sep 2025-2
									);
	bgpRequest.action();
	
epilog
	delete bgpRequest;
end;</source>
        <Parameter name="_date" type="Date"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="setBackupPath" id="5cd81c79-35b0-41f1-99e9-000943387fa0">
        <source>setBackupPath( _backUpConfigObj : CM_Backup; _newBackupPath : String ) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 January 2016	cnwndl1	Initial creation	Par 37296

*/

vars

	proxyBackup : CM_Backup;
	ls : Boolean;

begin

	self.assertTrueMsg( _backUpConfigObj &lt;&gt; null, "CM_Backup object not found when attempting to change 'Backup path' to '" &amp; _newBackupPath &amp; "'");

	app.cmsBeginLoad(ls);
	proxyBackup := _backUpConfigObj.pxyCreateUpdateProxy();
	app.cmsEndLoad(ls);
	proxyBackup.setProxy(	null,	//_binaryBackupPath : String; 
							_newBackupPath,	//_dbBackupPath : String; 
							_backUpConfigObj.journalLocalBackupPath,	//_journalLocalBackupPath : String; 
							null,	//_binaryRemoteBackupPath : String; 
							_backUpConfigObj.dbRemoteBackupPath,	//_dbRemoteBackupPath : String; 
							_backUpConfigObj.journalRemoteBackupPath,	//_journalRemoteBackupPath : String; 
							_backUpConfigObj.dbCompress,	//_dbCompress : Boolean;
							null,	//_dbOverwrite : Boolean;
							null,	//_dbVerify : Boolean;
							_backUpConfigObj.debug,	//_debug : Boolean;
							_backUpConfigObj.journalCompress,	//_journalCompress : Boolean;
							_backUpConfigObj.journalVerify,	//_journalVerify : Boolean;
							_backUpConfigObj.purgeDBJournals,	//_purgeDBJournals : Boolean;
							_backUpConfigObj.purgeLocalJournal,	//_purgeLocalJournals : Boolean;
							_backUpConfigObj.purgeRemoteJournals,	//_purgeRemoteJournals : Boolean;
							_backUpConfigObj.purgeSDSJournals,	//_purgeSDSJournals : Boolean; 
							_backUpConfigObj.journalNumber,	//_journalNumber : Integer;
							_backUpConfigObj.purgeJournalDays,	//_purgeLogDays : Integer;
							_backUpConfigObj.sdsSecondaryBackup,	//_sdsSecondaryBackup : Boolean;
							_backUpConfigObj.databaseWorkers	//_databaseWorkers : Integer
							) ;
	app.myTrxUA.trxUpdateBackup(proxyBackup, app.myPassport);
	
	self.assertTrueMsg( _backUpConfigObj.dbBackupPath = _newBackupPath, "CM_Backup object update of 'Backup path' to '" &amp; _newBackupPath &amp; "' failed. " &amp; app.myPassport.getErrorsAndWarningsAsString);

epilog

	delete proxyBackup;
	app.cmsEndLoad(ls);

end;</source>
        <access>protected</access>
        <Parameter name="_backUpConfigObj" type="CM_Backup"/>
        <Parameter name="_newBackupPath" type="String"/>
    </JadeMethod>
    <JadeMethod name="tActionBgpDeferChargeReqNoExc" id="84beeceb-e72f-4cb9-91a3-bcd538e59edf">
        <source>tActionBgpDeferChargeReqNoExc();
/*

Purpose:			Actions a BGP Request that has a null tracked item. This is to test how the request handles exceptions.
					Was raising a 1090, 1048, 1048, 1026 eception as it continues silently and aborts transactions.
					This unit tests tests that this is fixed and the request runs and updates correctly.

Parameters:			NONE

Return Value:		NONE

Date			Who		Reason
25 June 2024	navpw1	Initial creation TFS 64445 (64446)
02 July 2024	navpw1	TFS: 64445 (64995) - Improved unit test to check bgp request properties are set to the correct values.
												Added regex to check 1090 exception has been raised and code can continue execution without anymore exceptions raised.

*/

constants
	REF								: String = "64445";
	UT_CargoTypeAbr 				: String = "PAPER";
	UT_CargoId						: String = "UT" &amp; REF &amp; "-1";
	UT_BlockstackId					: String = "UT" &amp; REF;
	
vars
	bgpController					: BGP_DeferredChargingController;
	deferredChargesRoot				: CM_DeferredChargingRoot;
	request							: BGP_DeferredChargingRequest;
	terminal						: CM_Terminal;
	cargoType						: CM_CargoType;
	trackedItem						: CM_TrackedItem;
	blockStack						: CM_BlockStack;
	transaction						: CM_Transaction;
	moveTransaction					: CM_Move;
	regexAlertExceptionHandlerStr	: JadeRegexPattern;
	matches							: JadeRegexMatch;
	iter,
	tranIter						: Iterator;
	completedOk,
	success							: Boolean;
	isMatch							: Boolean;
	requestsSizeInitial				: Integer;
	allLogs							: HugeStringArray;
	logStr,
	exceptionCodesStr				: String;
	
begin
	//Create Regex Pattern
	create regexAlertExceptionHandlerStr transient;
	regexAlertExceptionHandlerStr
        .setIgnoreCase(true)
        .setExplicitCapture(true)
        .compile("^.*(exception){1}.*(alertExceptionHandler){1}.*(\({1}(?'ExceptionCode'[0-9]{4})\){1}){1}$");
	
	//Get the BGP Controller
	bgpController := BGP_DeferredChargingController.firstInstance;
	self.assertTrueMsg(bgpController &lt;&gt; null, "No BGP_DeferredChargingController found!");
	
	//Grab terminal
	terminal := self.getMyTerminal();
	
	//Grab Cargo Type
	cargoType := app.myRoot.allCargoTypesById.getCargoTypeByAbbreviation(UT_CargoTypeAbr);
	
	//CleanUp Data
	self.deleteCargo(UT_CargoId, cargoType);
	self.deleteTerminalArea(UT_BlockstackId);
	
	deferredChargesRoot := bgpController.myDeferredChargesRoot;
	
	//Create Blockstack
	blockStack := self.addBlockStack(UT_BlockstackId, 100, null);
	self.assertNotNullMsg(blockStack, "blockstack");
	
	//Create TI
	trackedItem := self.createCargo(UT_CargoId, null, null, self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString), false, cargoType.id);
	self.assertNotNullMsg(trackedItem, "trackedItem");
	
	//Move TI
	self.moveCargo(trackedItem, null, blockStack.myLocationsController, app.myPassport);
	
	//Grab a created transaction.
	tranIter := trackedItem.allTransactions.createIterator;
	
	while tranIter.next(transaction) do
		if transaction.getType &lt;&gt; TRANS_TYPE_MOVE then
			continue;
		endif;
		
		moveTransaction := transaction.CM_Move;
		break;
		
	endwhile;
	
	self.assertNotNullMsg(moveTransaction, "moveTransaction");
	
	//Remove Reference to ti
	beginTransaction;
	moveTransaction.setPropertyValue(CM_Move::myTrackedItem.name, null);
	commitTransaction;
	
	self.assertNullMsg(moveTransaction.myTrackedItem, "moveTransaction.myTrackedItem");
	
	//Arbitarilly create requests fior these 1 trx
	beginTransaction;
	create request persistent;
	request.setTransaction(moveTransaction);
	commitTransaction;
	
	self.assertTrueMsg( deferredChargesRoot.allNewDeferredReqs.size &gt;= 1, "BGP_DeferredChargingRoot hasn't got the requests on it!" );
	
	requestsSizeInitial := deferredChargesRoot.allNewDeferredReqs.size;
	
	//Action this request in the context of the unit test app
	success := request.action();
	
	self.assertTrueMsg(success, "BGP Deferred Charging Request failed which was not expected");
	
	//Checks if our current reqs size has one less as we should have processed one.
	self.assertTrueMsg(deferredChargesRoot.allNewDeferredReqs.size = requestsSizeInitial -1, "Requests size mismatch Expected: '" &amp; (requestsSizeInitial -1).String &amp; "' | Actual: '" &amp; deferredChargesRoot.allNewDeferredReqs.size.String &amp; "'");
	
	beginTransaction;
	delete moveTransaction;
	commitTransaction;
	
	self.assertIsDeletedMsg(moveTransaction, "moveTransaction");
	
	allLogs := app.getLogger().getPropertyValue("allLogs").HugeStringArray;
	
	foreach logStr in allLogs do
		isMatch := regexAlertExceptionHandlerStr.match(logStr, matches);
		if not isMatch then
			delete matches;
			continue;
		endif;
		
		exceptionCodesStr &amp;= matches.getCaptureByName("ExceptionCode").value &amp; ", ";
		delete matches;
		
	endforeach;
	
	if exceptionCodesStr &lt;&gt; "" then
		exceptionCodesStr := exceptionCodesStr.stripTrailingChar(Comma);
		
	endif;
	
	self.assertTrueMsg(exceptionCodesStr = "", "Exceptions Encountered: '" &amp; exceptionCodesStr &amp;"' | Expected: 'NONE'");
	
	//Assert BGP Request
	self.assertTrueMsg(request.beingActioned, "Expecting request to be marked as currently being actioned");
	self.assertFalseMsg(request.hasFailed, "Expecting request to be marked as success");
	
	completedOk := true;
	
epilog
	delete iter;
	delete tranIter;
	delete regexAlertExceptionHandlerStr;
	
	if not completedOk then
		beginTransaction;
		delete moveTransaction;
		commitTransaction;
	endif;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tBGPKinerja" id="b52c17f5-881a-4bd2-9f47-a85ee2afb6b2">
        <source>tBGPKinerja();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 September 2018	jlgma1	Initial creation

*/

vars
	bgpManager					: BGP_Manager;
	bgpGeneric 					: BGP_ExternalWSController;
	autoTask					: CM_AutoTask;
	autoSchedule				: CM_AutoSchedule;
	
	tiSet						: CM_TISet;

	bgpManagerName				: String;
begin
	//find task
	autoTask := app.myRoot.allAutoTasks["BGP_SAPWSRequest","KINERJA"];
	if autoTask &lt;&gt; null then
		autoSchedule := autoTask.allAutoSchedules.first;
		///beginTransaction;
			//autoSchedule.allAutoTasks.add(autoTask);
		//commitTransaction;
		autoSchedule.runTasks(null, null);
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="tBGPMiscellaneousTrxs" id="a5f7f616-a2da-4b18-bb4d-ee689b1447d2">
        <source>tBGPMiscellaneousTrxs();

/*

Purpose:		trxCreateBGPRequestFromTask
				trxUpdateBGPControllerPre
				trxUpdateBGPControllerPost

/* Changes

Date		Name	TFS#	Description
============================================================================
24/06/2015	cnwmh5			Initial creation
16/04/2019	jlgka1	43863	Added Recurring Value default in existing unit test.
============================================================================*/
constants
	RecurValue 		: Integer = 1; // jlgka1 TFS 43863
vars
	bgpManager		: BGP_Manager;
	bgpGeneric 		: BGP_GenericController;
	cont1			: CM_Container;
	cont2			: CM_Container;
	bs				: CM_BlockStack;
	operator		: CM_Operator;
	toDoTaskDesc	: CM_ToDoTaskDesc;
	pxyAutoTask		: CM_AutoTaskExpiredWash;
	autoTask		: CM_AutoTask;
	autoSchedule	: CM_AutoSchedule;
	tmpClass 		: Class;
	request			: BGP_Request;
	bgpController 	: BGP_TimerController;	
	tiSet			: CM_TISet;
	bgpManagerName	: String;
	washTS			: TimeStamp;
	ts				: TimeStamp;
begin

	operator := app.myRoot.allOperators["MSL"];
	self.assertNotNull(operator);
	
	toDoTaskDesc := app.myRoot.allToDoTaskDescsByShortDesc["WASH"];
	self.assertNotNull(toDoTaskDesc);
	
	self.setTerminalConfig(WashWarnDays, "-2");
	// create task
	autoTask := app.myRoot.allAutoTasks[BGP_AutoProcessExpiredWash.name, "UT EXPIRED WASH TASK2"];
	if autoTask &lt;&gt; null then
		autoSchedule := autoTask.allAutoSchedules.first;
		app.myTrxDA.trxDeleteAutoTask(autoTask, app.myPassport);
		self.assertNoTrxErrorsOrWarnings();
	endif;
	
	create pxyAutoTask transient;
	pxyAutoTask.setValueForRow(ETRow_BgpAutoDescription,"UT EXPIRED WASH TASK2");
	pxyAutoTask.setValueForRow(ETRow_BgpAutoUser, app.myRoot.allUsers["ADMIN"]);
	pxyAutoTask.setValueForRow(ETRow_BgpAutoTerminals, self.getTerminal());
	pxyAutoTask.setValueForRow(ETRow_ToDoTaskDesc, toDoTaskDesc);
	app.myTrxCA.trxCreateAutoTask(pxyAutoTask, autoTask, app.myPassport);
	self.assertNotNull(autoTask);

	
	// create BGP Task and Schedule
	ts := app.cnGetServerTime();
	ts.date.addDays(-1);
	ts.setTime("00:00:00".Time);
	autoSchedule := self.addAutoSchedule("UT MDH DUMMY", ts, RecurValue); // jlgka1 TFS 43863
	beginTransaction;
	autoSchedule.allAutoTasks.add(autoTask);
	commitTransaction;
	
	app.setIsBackGroundApp(true);
	
	tmpClass := self.getClass(autoTask.requestClassName);
	self.assertNotNull(tmpClass);
	
	bgpController := BGP_AutoTimerController.firstInstance;
	app.myTrxCA.trxCreateBGPRequestFromTask(tmpClass, request, autoTask, null, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	app.myTrxUA.trxUpdateBGPControllerPre(bgpController, app.actualTimeServer, request, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	request.action();
	app.myTrxUA.trxUpdateBGPControllerPost(bgpController, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
epilog

	if bgpManager &lt;&gt; null then	
		bgpManager.terminateProcessing(app.myPassport.userCode);
	endif;
	
	self.unlock(autoTask);
	app.setIsBackGroundApp(false);
	if autoTask &lt;&gt; null then
		self.unlock(autoTask);
	endif;
	beginTransaction;
	delete request;
	commitTransaction;
	
	delete tiSet;
	delete pxyAutoTask;

end;</source>
    </JadeMethod>
    <JadeMethod name="tBgpDataExtract" id="e84d7259-ef2d-4278-b376-856cf29f7fdc">
        <source>tBgpDataExtract();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 October 2024	navsp1	Initial creation JIRA 23326

*/
constants
	DEFINITION		= "UT_BGPDATAEXTRACT";
	BgpManagerName 	= "UT_DATAEX";
vars
	proxyBGPRequest,
	bgpRequest		: BGP_ExternalDBRequest;
	terminal		: CM_Terminal;
	extDef			: CM_DataDumpExtractDef;
	bgpManager		: BGP_Manager;
	proxyCMIF		: CMIF_BGPManagerChildren;
	bgpController 	: BGP_Controller;
begin	
	//Terminal
	terminal := self.getMyTerminal();
	
	//Definition
	extDef := app.myRoot.allDataDumpExtractDefs[DEFINITION];
	self.assertNotNull(extDef);
	
	//BGP Manager
	bgpManager := app.myRoot.allBGPManagers[BgpManagerName];
	if bgpManager = null then
		self.opts.purge();
		self.opts.addAssoc("IsServer", true);
		bgpManager := self.addBGPManager(BgpManagerName);
	endif;
	self.assertNotNull(bgpManager);
	
	create proxyCMIF transient;
	proxyCMIF.allClasses.add(BGP_ExternalDBRequest.name);
	proxyCMIF.myUser := app.myRoot.allUsers["ADMIN"];
	
	bgpController := bgpManager.allBGPControllers.first;
	app.myTrxUA.trxUpdateBGPControllerSetup(bgpController, proxyCMIF, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	//Extract Definition All
	create proxyBGPRequest transient;
	proxyBGPRequest.setProxy(app.myPassport.myUser, terminal, BGP_ExternalDBRequest.Extract_Def_All, null, app.isSpecial());
	app.myTrxCA.trxCreateBGPExtDBRequest(proxyBGPRequest, bgpRequest, extDef, app.myPassport);
	
	self.assertTrueMsg( bgpRequest &lt;&gt; null, "No request created - check Alerts for reason" );
	self.assertEqual(bgpRequest.extractType, BGP_ExternalDBRequest.Extract_Def_All.String);	
	
	//Extract Definition Changes
	bgpRequest := null;
	delete proxyBGPRequest;
	create proxyBGPRequest transient;
	proxyBGPRequest.setProxy(app.myPassport.myUser, terminal, BGP_ExternalDBRequest.Extract_Def_Changes, null, app.isSpecial());
	app.myTrxCA.trxCreateBGPExtDBRequest(proxyBGPRequest, bgpRequest, extDef, app.myPassport);
	
	self.assertTrueMsg( bgpRequest &lt;&gt; null, "No request created - check Alerts for reason" );
	self.assertEqual(bgpRequest.extractType, BGP_ExternalDBRequest.Extract_Def_Changes.String);
	
	//Extract Classes All
	bgpRequest := null;
	delete proxyBGPRequest;
	create proxyBGPRequest transient;
	proxyBGPRequest.setProxy(app.myPassport.myUser, terminal, BGP_ExternalDBRequest.Extract_Classes_All, null, app.isSpecial());
	app.myTrxCA.trxCreateBGPExtDBRequest(proxyBGPRequest, bgpRequest, extDef, app.myPassport);
	
	self.assertTrueMsg( bgpRequest &lt;&gt; null, "No request created - check Alerts for reason" );
	self.assertEqual(bgpRequest.extractType, BGP_ExternalDBRequest.Extract_Classes_All.String);
	
	//Extract Classes Changes
	bgpRequest := null;
	delete proxyBGPRequest;
	create proxyBGPRequest transient;
	proxyBGPRequest.setProxy(app.myPassport.myUser, terminal, BGP_ExternalDBRequest.Extract_Classes_Changed, null, app.isSpecial());
	app.myTrxCA.trxCreateBGPExtDBRequest(proxyBGPRequest, bgpRequest, extDef, app.myPassport);
	
	self.assertTrueMsg( bgpRequest &lt;&gt; null, "No request created - check Alerts for reason" );
	self.assertEqual(bgpRequest.extractType, BGP_ExternalDBRequest.Extract_Classes_Changed.String);	
	
	//Clear all created requests
	if global.isValidObject(bgpController) then
		bgpController.myBGPManager.doClearAllRequests(bgpController);
	endif;	

epilog

	delete proxyCMIF;
	delete proxyBGPRequest;
	self.deleteBGPManager(BgpManagerName);
end;</source>
    </JadeMethod>
    <JadeMethod name="tCheckProcessExpiredWash" id="66952882-9194-42dd-8d9b-2f91169057c5">
        <source>tCheckProcessExpiredWash();

/*

Purpose:		Check Process Expired Wash

/* Changes

Date		Name	TFS#	Description
============================================================================
18/02/2015	cnwmh5			Initial creation
16/04/2019	jlgka1	43863	Added Recurring Value default in existing unit test.
============================================================================*/
constants
	RecurValue 		: Integer = 1; // jlgka1 TFS 43863
vars
	bgpManager		: BGP_Manager;
	bgpGeneric 		: BGP_GenericController;
	cont1			: CM_Container;
	cont2			: CM_Container;
	bs				: CM_BlockStack;
	operator		: CM_Operator;
	toDoTaskDesc	: CM_ToDoTaskDesc;
	pxyAutoTask		: CM_AutoTaskExpiredWash;
	autoTask		: CM_AutoTask;
	autoSchedule	: CM_AutoSchedule;	
	tiSet			: CM_TISet;
	bgpManagerName	: String;
	washTS			: TimeStamp;
	ts				: TimeStamp;
begin

	operator := app.myRoot.allOperators["MSL"];
	self.assertNotNull(operator);
	
	toDoTaskDesc := app.myRoot.allToDoTaskDescsByShortDesc["WASH"];
	self.assertNotNull(toDoTaskDesc);
	
	// create the blockstack to hold the containers
	bs := self.addBlockStack("UTMHJ01", 199, null);
	self.assertNotNull(bs);
	
	washTS := app.cnGetServerTime();
	//washTS := washTS.addDays(-1);
	washTS.setDate("32/01/2015".Date);
		
	// create the 2 required containers
	self.opts.purge();
	self.opts.addAssoc("WashDT", washTS.String);
	cont1 := self.addContainerAtLocation("UTMDH000123", operator, "2031", "REEF", TI_IMEX_STATUS_IMPORT, bs.allLocationsControllers.first);
	self.assertNotNull(cont1);
	self.updateTI(cont1);	
	
	self.opts.purge();
	self.opts.addAssoc("WashDT", washTS.String);
	cont2 := self.addContainerAtLocation("UTMDH000124", operator, "BBLK", "GENL", TI_IMEX_STATUS_IMPORT, bs.allLocationsControllers.first);
	self.assertNotNull(cont2);
	self.updateTI(cont2);
	
	self.setTerminalConfig(WashWarnDays, "-2");
	// create task
	autoTask := app.myRoot.allAutoTasks[BGP_AutoProcessExpiredWash.name, "UT EXPIRED WASH TASK"];
	if autoTask &lt;&gt; null then
		autoSchedule := autoTask.allAutoSchedules.first;
		app.myTrxDA.trxDeleteAutoTask(autoTask, app.myPassport);
		self.assertNoTrxErrorsOrWarnings();
	endif;
	
	create pxyAutoTask transient;
	pxyAutoTask.setValueForRow(ETRow_BgpAutoDescription,"UT EXPIRED WASH TASK");
	pxyAutoTask.setValueForRow(ETRow_BgpAutoUser, app.myRoot.allUsers["ADMIN"]);
	pxyAutoTask.setValueForRow(ETRow_BgpAutoTerminals, self.getTerminal());
	pxyAutoTask.setValueForRow(ETRow_ToDoTaskDesc, toDoTaskDesc);
	app.myTrxCA.trxCreateAutoTask(pxyAutoTask, autoTask, app.myPassport);
	self.assertNotNull(autoTask);
	
	// create BGP Task and Schedule
	ts := app.cnGetServerTime();
	ts.date.addDays(-1);
	ts.setTime("00:00:00".Time);
	
	autoSchedule := self.addAutoSchedule("UT PROCESS WASH", ts, RecurValue); // jlgka1 TFS 43863
	beginTransaction;
	autoSchedule.allAutoTasks.add(autoTask);
	commitTransaction;
	
	
	
	// create the BGPManager
	self.opts.purge();
	self.opts.addAssoc("IsServer", true);
	bgpManager := self.addBGPManager("UT PROCESS EXPIRED WASH");
	self.assertNotNull(bgpManager);

	// create Process Wash
	bgpGeneric := bgpManager.allBGPControllers.first.BGP_GenericController;
	self.updateBGPGenericControllerProc(bgpGeneric);
	
	// run the task
	autoSchedule.runTasks(null, null);
	
	// start the bgp process
	bgpManager.startBackGroundApp(bgpGeneric, false);
	
	// need to sleep for a minute to make sure that the process gets run
	process.sleep(60000);
	
	// check the containers to see that todo task is set correctly
	self.assertEqualMsg(cont1.allToDoTasksToDo.size, 1, cont1.id &amp; " should have 1 To Do Task");
	self.assertEqualMsg(cont1.allToDoTasksToDo.first.toDoTaskDesc, toDoTaskDesc, cont1.id &amp; " does not have a " &amp; 
		toDoTaskDesc.description &amp; " To Do Task");
	self.assertEqualMsg(cont2.allToDoTasksToDo.size, 0, cont2.id &amp; " should have no To Do Task");
	
epilog

	if bgpManager &lt;&gt; null then	
		bgpManager.terminateProcessing(app.myPassport.userCode);
	endif;
	
	delete tiSet;
	delete pxyAutoTask;

end;</source>
    </JadeMethod>
    <JadeMethod name="tCheckVisitPhotosGC" id="55ba7e0f-aa3c-43c7-80aa-b1254f830143">
        <source>tCheckVisitPhotosGC();
/*

Purpose: To check garbage collection for Vvisit photos working as expected.			

Parameters:			

Return Value:		

Date		Who		Reason
11 Aug 2025 navhl20 Story MTN-35652: TPT | Uploading of Photos into MTN Production | 4 | Unit Tests
21 Nov      2025	navsp1	MTN-36650 Integrate DotNet Image Library for Automatic Thumbnail Generation in Thin Client
*/

vars
	vvr					: CM_VehicleVisitRecord;
	photoDesc 			: String;
	photo 				: Binary;
	resourcesForm 		: PictureResourcesForm;
	gate 				: CM_Gate;
	proxyPhoto, 
	newPhoto   			: CM_Photo;
    thumbPhoto          : Binary;                                        //MTN-36650
begin
	gate := self.getGate(self.getProfileSetting(UT_Profile.P_DGATE).asString);
	vvr := self.addVehicleVisitRecord("UTTRK35652","HM","HM1",gate.name.asStringJMT);	
	photoDesc := "a photo descrption for UUT35652";
	
	resourcesForm := PictureResourcesForm.createPrintForm();
	photo := resourcesForm.picExamplePhoto.picture;
    thumbPhoto  := self.createThumbnailContent(photo);                  //MTN-36650
	
	create proxyPhoto transient;
	proxyPhoto.setDescription(photoDesc);
	proxyPhoto.setMyParent(vvr);
	
	proxyPhoto.setPhotoContent(photo);
	//proxyPhoto.setThumbnailContent(photo);                            //MTN-36650	- automatically create in PortSchema::CM_Photo::setForUpdate
	
	app.myTrxCA.trxCreateVisitPhoto(proxyPhoto, newPhoto, app.myPassport);
	self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());
	
	self.assertEqual(newPhoto.description, "a photo descrption for UUT35652");
	self.assertEqual(newPhoto.getPhotoContent(), photo);
	self.assertEqual(newPhoto.getThumbnailContent(), thumbPhoto);       //MTN-36650
	
	self.assertTrue(vvr.allAttachments.size &gt; 0);
	self.assertTrue(vvr.allAttachments.includes(newPhoto));
	self.assertTrue(vvr.numAttachments(CM_Attachment.Type_Photo) = 1);
	
	self.opts.purge;
	self.opts.addAssoc('VisitPhotos', true);
	
	self.runGarbageCollection(app.actualTimeServer.date.addDays(1), self.getTerminal());
	self.assertNoTrxErrorsOrWarnings();
	
	self.assertEqualMsg(vvr.allAttachments.size , 0, "Attched photo not purged");
	
	self.clearExpectedTrxErrors();
	app.myTrxUA.trxUpdateVVRCancel(vvr,"testing",app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
epilog
	delete resourcesForm;
	delete proxyPhoto;
end;</source>
    </JadeMethod>
    <JadeMethod name="tCheckVisitWithPhotosGC" id="389a307e-cdd5-4086-806d-08ccc63d4a44">
        <source>tCheckVisitWithPhotosGC();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 Aug 2025 navhl20 Story MTN-35652: TPT | Uploading of Photos into MTN Production | 4 | Unit Tests
21 Nov      2025	navsp1	MTN-36650 Integrate DotNet Image Library for Automatic Thumbnail Generation in Thin Client
*/

vars
	vvr					: CM_VehicleVisitRecord;
	photoDesc 			: String;
	photo 				: Binary;
	resourcesForm 		: PictureResourcesForm;
	gate 				: CM_Gate;
	proxyPhoto, 
	newPhoto   			: CM_Photo;
    thumbPhoto          : Binary;                                        //MTN-36650
begin
	gate := self.getGate(self.getProfileSetting(UT_Profile.P_DGATE).asString);
	vvr := self.addVehicleVisitRecord("UTTRK35652-2","HM","HM1",gate.name.asStringJMT);	
	photoDesc := "a photo descrption for UUT35652 new one";
	
	resourcesForm := PictureResourcesForm.createPrintForm();
	photo := resourcesForm.picExamplePhoto.picture;
    thumbPhoto  := self.createThumbnailContent(photo);                  //MTN-36650
	
	create proxyPhoto transient;
	proxyPhoto.setDescription(photoDesc);
	proxyPhoto.setMyParent(vvr);
	
	proxyPhoto.setPhotoContent(photo);
	//proxyPhoto.setThumbnailContent(photo);                            //MTN-36650	- automatically create in PortSchema::CM_Photo::setForUpdate
	
	app.myTrxCA.trxCreateVisitPhoto(proxyPhoto, newPhoto, app.myPassport);
	self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());
	
	self.assertEqual(newPhoto.description, "a photo descrption for UUT35652 new one");
	self.assertEqual(newPhoto.getPhotoContent(), photo);
	self.assertEqual(newPhoto.getThumbnailContent(), thumbPhoto);       //MTN-36650
	
	self.assertTrue(vvr.allAttachments.size &gt; 0);
	self.assertTrue(vvr.allAttachments.includes(newPhoto));
	self.assertTrue(vvr.numAttachments(CM_Attachment.Type_Photo) = 1);
	
	self.opts.purge;
	self.opts.addAssoc('VEHICLEVISIT', true);
	
	beginTransaction;
		vvr.setTimeIn(app.actualTimeServer.date.addYears(-11),null);
	commitTransaction;
	
	self.runGarbageCollection(app.actualTimeServer.date.addYears(-10), self.getTerminal());
	self.assertNoTrxErrorsOrWarnings();
	
	self.assertFalse(newPhoto = null or app.isValidObject(newPhoto));
epilog
	delete resourcesForm;
	delete proxyPhoto;
end;</source>
    </JadeMethod>
    <JadeMethod name="tEUPConstructLoadCOMsg" id="e56649c3-63df-4bcd-bb91-de4a12e32086">
        <source>tEUPConstructLoadCOMsg();
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
15 August 2024		navmd1	Initial creation TFS 61725

*/

constants
	TruckId				= "TFS61725";
	FreightForwarderId	= "61725";
	ReleaseNum			= "TFS61725";
	BaseCargoId			= "TFS61725";
	LoadCOMessageIdent	= "TransportCreation";		// This is dumb and shouldn't be hard coded like this, it should be a class constant at least!
	DateRegex			= '"Date":"(\d{4}\-\d{2}\-\d{2}T00:00:00Z)"';
vars
	term				: CM_Terminal;
	carrier				: CM_Carrier;
	truck				: CM_Vehicle;
	cmif				: CMIF_JsonLoadNotificationEUP;
	vvr, pxyVvr			: CM_VehicleVisitRecord;
	jsonStr				: String;
	freightForwarder	: CM_ConsigneeConsignor;
	release				: CM_BulkRelease;
	cargoSet			: CM_TISet;
	cargoType			: CM_CargoType;
	cargoSubType		: CM_Product;
	oper				: CM_Operator;
	gate				: CM_Gate;
	vbs					: CM_VehicleBookingTimeSlot;
	lc					: CM_LocationsController;
	wleWithWarnings		: CM_WLEArray;
	apiMapper			: CMIF_ApiMapper;
	transformErrors		: String;
	matches				: JadeRegexResult;
	now					: TimeStamp;
	logLevel			: Integer;
	expected			: String;
begin
	logLevel := app.logLevel;
	//app.changeLogLevel(LogTRACE);

	// Clean up
	self.deleteVehicle(TruckId);
	self.deleteConsigneeConsignor(FreightForwarderId);
	self.deleteCargo(BaseCargoId&amp;"-1", "PAPER");
	self.deleteCargo(BaseCargoId&amp;"-2", "PAPER");
	self.deleteCargo(BaseCargoId&amp;"-3", "PAPER");
	self.deleteCargo(BaseCargoId&amp;"-4", "PAPER");
	self.deleteCargo(BaseCargoId&amp;"-5", "PAPER");
	
	// Set up
	term := self.getMyTerminal();
	self.assertNotNullMsg(term, "Terminal Code not set/invalid in UT Profile");
	carrier := self.getCarrier(self.getProfileSetting(UT_Profile.P_CARRIER).asString);
	self.assertNotNullMsg(carrier, "Carrier Code not set/invalid in UT Profile");
	oper := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	self.assertNotNullMsg(oper, "Operator Code not set/invalid in UT Profile");
	gate := self.getGate(self.getProfileSetting(UT_Profile.P_DGATE).asString);
	self.assertNotNullMsg(gate, "Gate Code not set/invalid in UT Profile");
	
	cargoType := self.getCargoType("PAPER");
	self.assertNotNullMsg(cargoType, "Cargo Type PAPER");
	cargoSubType := cargoType.allProducts.findProductByCode("ROLLS");
	self.assertNotNullMsg(cargoSubType, "Cargo Sub Type ROLLS not found for PAPER");
	
	truck := self.addVehicle(TruckId, carrier, term);
	self.assertNoTrxErrorsOrWarnings();
	self.assertNotNullMsg(truck, "Error creating Truck");
	
	self.opts.purge();
	self.opts.addAssoc(ETRow_IsInternal, true);
	freightForwarder := self.addConsigneeConsignor(FreightForwarderId, method.name, false, false, true);
	self.assertNotNullMsg(freightForwarder, "Error creating Freight Forwarder (Consignee/or)");
	
	create cargoSet transient;
	lc := term.allTerminalAreas.first.allLocationsControllers.first;
	cargoSet.add(self.addCargoAtLocation(BaseCargoId&amp;"-1", cargoSubType, oper, lc));
	cargoSet.add(self.addCargoAtLocation(BaseCargoId&amp;"-2", cargoSubType, oper, lc));
	cargoSet.add(self.addCargoAtLocation(BaseCargoId&amp;"-3", cargoSubType, oper, lc));
	cargoSet.add(self.addCargoAtLocation(BaseCargoId&amp;"-4", cargoSubType, oper, lc));
	cargoSet.add(self.addCargoAtLocation(BaseCargoId&amp;"-5", cargoSubType, oper, lc));
	self.assertEqualMsg(cargoSet.size, 5, "Not all cargo created");
	
	self.opts.purge();
	self.opts.addAssoc("TotalRequested", 1);
	self.opts.addAssoc("FreightForwarder", freightForwarder.code);
	release := self.addReleaseById(ReleaseNum, BR_TYPE_ROAD, cargoSet);
	self.assertNotNullMsg(release, "Release Request not created successfully");
	
	// A bit of a bodge, but it'll do
	self.opts.purge();
	self.opts.addAssoc("ReleaseRequest", release);
	vbs := self.addVehicleBookingAdv(TruckId);
	self.assertNotNullMsg(vbs, "Vehicle Booking Time Slot not created successfully");
	
	self.opts.purge();
	self.opts.addAssoc("VehicleBookingTS", vbs);
	vvr := self.addVehicleVisitRecord(TruckId, null, null, gate.name);
	self.assertNotNullMsg(vvr, "Vehicle Visit Record not created successfully");
	
	self.opts.purge();
	self.opts.addAssoc("_direction", Release);
	self.opts.addAssoc("SubType", cargoSubType.code);
	self.opts.addAssoc(UTTI_BulkRelease, release);
	self.createGateEntity(vvr, cargoType.abbreviation, BaseCargoId&amp;"-1", null, oper.code, null, 1);
	self.createGateEntity(vvr, cargoType.abbreviation, BaseCargoId&amp;"-2", null, oper.code, null, 1);
	self.createGateEntity(vvr, cargoType.abbreviation, BaseCargoId&amp;"-3", null, oper.code, null, 1);
	self.createGateEntity(vvr, cargoType.abbreviation, BaseCargoId&amp;"-4", null, oper.code, null, 1);
	self.createGateEntity(vvr, cargoType.abbreviation, BaseCargoId&amp;"-5", null, oper.code, null, 1);
	
	// Gate-In
	pxyVvr := app.createUpdateProxy(vvr).CM_VehicleVisitRecord;
	app.myPassport.setWarningsIgnored(true);
	app.myTrxCA.trxCreateInOutFlexiJob(pxyVvr, vvr, null, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	delete pxyVvr;
	
	self.moveVehicleToYard(truck);
	self.workVehicle(vvr);
	
	self.assertEqualMsg(truck.locationsController.allTrackedItems.size, 5, "Number of Cargo on truck");
	
	// Gate-Out
	self.roadExit(vvr);	
	
	// Tests
	// Check LoadCO message
	create cmif transient;
	cmif.setFromVehicleVisit(vvr);
	jsonStr := cmif.getJSON();
	self.assertNotNullMsg(jsonStr, "No JSON message created");
	app.writeLog(jsonStr, LogTRACE);
	
	create apiMapper transient;
	jsonStr := apiMapper.transformOutgoingMessage(CMIF_ApiMapper.CUSTOMER_EUP, LoadCOMessageIdent, jsonStr, JadeHTTPConnection.Verb_POST, transformErrors);
	self.assertNullMsg(transformErrors, "API Mapper '"&amp;LoadCOMessageIdent&amp;"' Transform");
	
	self.assertEqualMsg(JadeRegex@findAll(jsonStr, DateRegex, false, true, matches), 2, "Regex Matches" &amp; CrLf &amp; DateRegex &amp; CrLf &amp; jsonStr);
	expected := now.localToUTCTime.date.TimeStamp.asJSONFormat();	// 2024-09-02T00:00:00.000Z
	expected := expected[1:expected.length-5] &amp; "Z";				// 2024-09-02T00:00:00Z
	self.assertEqualMsg(matches.at(1).at(1).value, expected, "Dossier/Date not converted to UTC as expected");
	expected := vbs.bookingTSstart.localToUTCTime.date.TimeStamp.asJSONFormat();	// 2024-09-03T00:00:00.000Z
	expected := expected[1:expected.length-5] &amp; "Z";								// 2024-09-03T00:00:00Z
	self.assertEqualMsg(matches.at(2).at(1).value, expected, "Mission/Load/Date not converted to UTC as expected");

epilog
	delete cmif;
	delete cargoSet;
	delete pxyVvr;
	delete wleWithWarnings;
	delete apiMapper;
	delete matches;
	
	app.changeLogLevel(logLevel);
end;</source>
    </JadeMethod>
    <JadeMethod name="tFileGarbageCollect" id="9a89c90d-8811-4fa3-af6e-bd71060c7c3a">
        <source>tFileGarbageCollect();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 February 2023	navhl20 ChangeRequest 54900:[56518] EUP - Garbage Collection for Document Attachments
10 Jul 2025 navah1	Task 35253: MTN - Fix tFileGarbageCollect Unit Test
*/

constants
	REF: String  =  "TFS56518";
vars
	tI1, tI2			: CM_TrackedItem;
	workOrder,delWO		: CM_WorkOrder;
	useYardJobsSetting	: Any;
	job 				: CM_Job;
	wle					: CM_WOWLE;
	tiSet				: CM_TISet;
	parent	 	 		: CM_WorkOrder;
	fileData 	 		: CM_FileData;
	date				: TimeStamp;
	logDir				: String;
	fileCategory		: CM_FileDataCategory;
	file1,										//10.07.2025 navah1 #35253
	file2				: File;                 //10.07.2025 navah1 #35253
begin
	// Set the config to use yard jobs for the terminal	
	useYardJobsSetting := self.getTerminal.getConfig(UseYardJobsCargoWO);
	
	beginTransaction;
	self.getTerminal.setConfig(UseYardJobsCargoWO, true);
	commitTransaction;
	
	delWO := app.getMyTerminalDO_NOT_USE.allWorkOrders['UTWO'&amp;REF];
	if delWO &lt;&gt; null then
		foreach fileData in delWO.allFiles do 
			app.myTrxDA.trxDeleteFile(delWO,fileData,app.myPassport);
		endforeach;
	endif;
	
	// Delete the old work order and create containers to add
	self.deleteWorkOrderNoValidation('UTWO'&amp;REF);

	self.deleteContainer("UTCNT01");
	self.deleteContainer("UTCNT02");
	
	tI1 := self.addContainerOpts("UTCNT01", "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));	
	tI2 := self.addContainerOpts("UTCNT02", "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));		
	
	create tiSet transient;
	tiSet.add(tI1);					
	tiSet.add(tI2);					

	// Setup the work order options
	self.opts.purge();
	self.opts.addAssoc('TotalReq', 2);
	self.opts.addAssoc('TargetTA', "UTBS2" &amp; REF);
	self.opts.addAssoc('CargoList', "UTCNT01" &amp; "," &amp; "UTCNT02");
	self.opts.addAssoc('DtRequired', app.actualTimeServer().addDays(2).String);
	self.opts.addAssoc('DtStart', app.actualTimeServer().addDays(1).String);	
	self.opts.addAssoc('TaskType',WO_TASK_RECEIVE );
	
	// Create the work order
	workOrder := self.addWorkOrder('UTWO'&amp;REF, WO_STATUS_USERENTRY,tiSet);	
	self.assertNotNullMsg(workOrder, "The Work order is null");
	
	parent	:= workOrder;
	//logDir	:= app.getAppServerLogDir() &amp; '/tmpFiles/'; //10.07.2025 navah1 #35253
	/*create file transient;
	file.mode := File.Mode_Input;
	file.openOutput(logDir &amp; "UTTest56518.txt");
	file.close();*/
	//10.07.2025 navah1 #35253 Start
	logDir := app.getTempDir();
	create file1 transient;  
	create file2 transient;  
	file1.openOutput(logDir &amp; "UTTest56518.txt");  
	file1.close();
	file2.openOutput(logDir &amp; "UTTest56518-1.txt"); 
	file2.close(); 
	//10.07.2025 navah1 #35253 End
	fileCategory := app.myRoot.allFileDataCategories["WO01"];
	app.myTrxUA.trxAddFile(parent,logDir &amp; "UTTest56518.txt", "My Test File", "My test File", fileCategory, "My test File",0,app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	app.myTrxUA.trxAddFile(parent,logDir &amp; "UTTest56518-1.txt", "My Test File - 1", "My test File - 1", fileCategory, "My test File - 1",0,app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	self.assertEqualMsg(workOrder.allFiles.size , 2, "Attched files are not equal to 2");
	
	fileData := workOrder.allFiles.first.CM_FileData;
	beginTransaction;  
	fileData.setPropertyValue(CM_FileData::dateTime.name,app.actualTimeServer.addYears(-2));
	commitTransaction;
	
	self.opts.purge;
	self.opts.addAssoc('ATTACHWORKORDERS', true);
	
	self.runGarbageCollection(app.actualTimeServer.date.addYears(-1), self.getTerminal());
	self.assertNoTrxErrorsOrWarnings();
	
	self.assertEqualMsg(workOrder.allFiles.size , 1, "Attched files are not equal to 1");

epilog
	beginTransaction;
	self.getTerminal.setConfig(UseYardJobsCargoWO, useYardJobsSetting);
	commitTransaction;
	//10.07.2025 navah1 #35253 Start
	if file1.isAvailable() then
		file1.purge();
	endif;
	if file2.isAvailable() then
		file2.purge();
	endif;
	delete file1;
	delete file2;
	//10.07.2025 navah1 #35253 End
	delete tiSet;
end;</source>
    </JadeMethod>
    <JadeMethod name="tNSWOnePortVesselMovePartial" id="36f7a076-6f64-42fd-a2f9-bfb5ac229525">
        <source>tNSWOnePortVesselMovePartial();
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 05/08/2025	navdap1		Initial creation MTN-35605 NSW - Load Partial Voyage EDI
// 18/09/2025	navdap1		MTN-36071 MTN - OnePort messages showing errors
//
constants
	VesselNameA = "AFRICAN CORMORANT";
	LloydsNumberA = "9978641";
	VoyageCodeA_1 = "142372";
	VoyageCodeA_2 = "142378";
	
	VesselNameB = "ZIM Hawk";
	LloydsNumberB = "9960498";
	VoyageCodeB_1 = "142575";
	VoyageCodeB_2 = "142580";
	VoyageCodeB_3 = "142585";
	VoyageCodeB_4 = "142590";
	
	LloydsNumberC = "9960538";
	VoyageCodeC_1 = "142579";
	VoyageCodeC_2 = "142779";
	
	VesselNameD = "UT_ONEPORTD";
	LloydsNumberD = "9747777";
	VoyageCodeD_1 = "143250";
	VoyageCodeD_2 = "143255";
	VoyageCodeD_3 = "143260";
	
	VesselNameE = "UT_ONEPORTE";
	LloydsNumberE = "9747778";
	VoyageCodeE_1 = "143270";
	VoyageCodeE_2 = "143275";
	
	VesselNameF = "UT_ONEPORTF";
	LloydsNumberF = "9747779";
	VoyageCodeF_1 = "143580";
	VoyageCodeF_2 = "143585";
	
	OperatorCode = "UT42";
	UserDefinedFormat = "Unit Test Voyage";
	UDFVoyage1 = "DAVEHUDF01";
	UDFVoyage2 = "DAVEHUDF02";
	UDFVoyage3 = "DAVEHUDF03";

vars
	terminalCode : String;
	terminal : CM_Terminal;
	root : CM_Root;
	operator : CM_Operator;
	trade : CM_Trade;
	shippingLine : CM_ShippingLine;
	vessel : CM_Vessel;
	harbour : HMS_Harbour;
	harbourData : HMS_VesselDataHarbour;
	tidalClassArr, tidalClassDep : HMS_TidalClass;
	allowPartialLoad : Boolean;
	wharf : HMS_Wharf;
	berthArray : StringArray;
	berth : HMS_Berth;
	berthCode : String;
	startingPos : Integer;
	resultString : String;
	extWebServiceDef : CM_ExternalWebServiceDef;
	activeWebServiceDef : CM_APIEndpointServiceDef;
	defVoyageProcess : String;
	utVoyProcess : CM_VoyageProcessDefault;
	lastSuccessfullTS : TimeStamp;
	bgp : BGP_OnePortRequest;
	ediFile : CM_EDIFile;
	ediData : CM_EDIData;
	ediTI : CM_EDITrackedItem;
	movementTI : CM_EDIQshipsMovementTI;
	vesselTI : CM_EDIQshipsVesselTI;
	udf : CM_EDIFileTypeUser;
	messageType, clientRef, ediText : String;
	idx : Integer;
	ediControllerAgent : CM_EDIControllerAgent;
	voyage : CM_Voyage;
	movement : HMS_VoyageMovement;

begin
	terminalCode := self.getProfileSetting(UT_Profile.P_TERMINAL).asString;
	terminal := app.myRoot.allTerminals[terminalCode];
	self.assertNotNullMsg(terminal, "No terminal set, unable to run test");
	
	allowPartialLoad := self.setTerminalConfig(EdiVoyageAllowPartial, true).Boolean;
	
	root := self.getRoot();
	operator := root.allOperators[OperatorCode];
	if operator = null then
		operator := self.addOperator(OperatorCode, "UT_" &amp; OperatorCode &amp; " Desc", false, null, null, null, false, false, false, false, false, false, false, false, false, false, null, null, null, null, false, false, null, null, null, null, false, false);
		self.assertTrueMsg(operator &lt;&gt; null,"Operator is null");
	endif;
	
	// Delete things first
	self.deleteVessel(VesselNameA);
	self.deleteVessel(VesselNameB);
	self.deleteVessel(VesselNameD);
	self.deleteVessel(VesselNameE);
	self.deleteVessel(VesselNameF);
	self.deleteVoyage(VoyageCodeA_1);
	self.deleteVoyage(VoyageCodeA_2);
	self.deleteVoyage(VoyageCodeB_1);
	self.deleteVoyage(VoyageCodeB_2);
	self.deleteVoyage(VoyageCodeB_3);
	self.assertNullMsg(self.getVoyage(VoyageCodeA_1), VoyageCodeA_1);
	self.assertNullMsg(self.getVoyage(VoyageCodeA_2), VoyageCodeA_2);
	self.assertNullMsg(self.getVoyage(VoyageCodeB_1), VoyageCodeB_1);
	self.assertNullMsg(self.getVoyage(VoyageCodeB_2), VoyageCodeB_2);
	self.assertNullMsg(self.getVoyage(VoyageCodeB_3), VoyageCodeB_3);
	self.assertNullMsg(self.getVoyage(VoyageCodeB_4), VoyageCodeB_4);
	self.assertNullMsg(self.getVoyage(VoyageCodeC_1), VoyageCodeC_1);
	self.assertNullMsg(self.getVoyage(VoyageCodeC_2), VoyageCodeC_2);
	self.assertNullMsg(self.getVoyage(VoyageCodeD_1), VoyageCodeD_1);
	self.assertNullMsg(self.getVoyage(VoyageCodeD_2), VoyageCodeD_2);
	self.assertNullMsg(self.getVoyage(VoyageCodeE_1), VoyageCodeE_1);
	self.assertNullMsg(self.getVoyage(VoyageCodeE_2), VoyageCodeE_2);
	self.assertNullMsg(self.getVoyage(VoyageCodeF_1), VoyageCodeF_1);
	self.assertNullMsg(self.getVoyage(VoyageCodeF_2), VoyageCodeF_2);
	
	self.deleteVoyage(UDFVoyage1);
	self.deleteVoyage(UDFVoyage2);
	self.deleteVoyage(UDFVoyage3);
	self.assertNullMsg(self.getVoyage(UDFVoyage1), UDFVoyage1);
	self.assertNullMsg(self.getVoyage(UDFVoyage2), UDFVoyage2);
	self.assertNullMsg(self.getVoyage(UDFVoyage3), UDFVoyage3);
	
	self.opts.purge();
	
	operator := app.myRoot.allOperators.getAtKey("DOUG");
	trade	 := app.myRoot.allTradesByDescription.getAtKey("UT Michaels Trade");
	shippingLine := app.myRoot.allShippingLines.getAtKey("DAVE");
	
	// Add Vessel - AFRICAN CORMORANT
	self.opts.purge();
	//self.opts.addAssoc("isBarge",true);
	self.opts.addAssoc("VesselTrade",trade);
	self.opts.addAssoc(ETRow_LloydsNumber,LloydsNumberA);
	self.opts.addAssoc("ShippingLine",shippingLine);
	self.opts.addAssoc(ETRow_CallSign,"PART");
	self.opts.addAssoc("YearOfBuild",2020);
	
	vessel := self.addVesselGeneralCargo(VesselNameA, self.getOperator("MON"), 10);
	self.assertNotNullMsg(vessel, "Vessel " &amp; VesselNameA);
	self.assertNotNullMsg(vessel.myHMSVesselData, "Vessel " &amp; VesselNameA &amp; " HMS Data");
	self.assertNotNullMsg(vessel.myDefaultTrade, "Vessel Trade");
	self.assertNotNullMsg(vessel.myHMSVesselData.myDefaultShippingLine, "Vessel Shipping Line");
	
	// Check the vessel has tidal classes
	harbour := terminal.myHarbour;
	harbourData := vessel.myHMSVesselData.allVesselDataForHarbour[harbour];
	tidalClassArr := root.allTidalClasses["E"];
	tidalClassDep := root.allTidalClasses["C"];
	self.assertEqualMsg(tidalClassArr , harbourData.myTidalClassArrival, "tidal class arrival mismatch");
	self.assertEqualMsg(tidalClassDep , harbourData.myTidalClassDeparture, "tidal class departure mismatch");
	
	// Add Vessel - ZIM HAWK
	self.opts.purge();
	self.opts.addAssoc("VesselTrade",trade);
	self.opts.addAssoc(ETRow_LloydsNumber,LloydsNumberB);
	self.opts.addAssoc("ShippingLine",shippingLine);
	self.opts.addAssoc(ETRow_CallSign,"PORT");
	self.opts.addAssoc("YearOfBuild",2021);
	
	vessel := self.addVesselGeneralCargo(VesselNameB, self.getOperator("MSC"), 10);
	self.assertNotNullMsg(vessel, "Vessel " &amp; VesselNameB);
	self.assertNotNullMsg(vessel.myHMSVesselData, "Vessel " &amp; VesselNameB &amp; " HMS Data");
	self.assertNotNullMsg(vessel.myDefaultTrade, "Vessel Trade");
	self.assertNotNullMsg(vessel.myHMSVesselData.myDefaultShippingLine, "Vessel Shipping Line");
	
	// Check the vessel has tidal classes
	harbourData := vessel.myHMSVesselData.allVesselDataForHarbour[harbour];
	tidalClassArr := root.allTidalClasses["E"];
	tidalClassDep := root.allTidalClasses["C"];
	self.assertEqualMsg(tidalClassArr , harbourData.myTidalClassArrival, "tidal class arrival mismatch");
	self.assertEqualMsg(tidalClassDep , harbourData.myTidalClassDeparture, "tidal class departure mismatch");
	
	// Add Vessel UT_ONEPORTD - VesselNameD
	self.opts.purge();
	self.opts.addAssoc("VesselTrade",trade);
	self.opts.addAssoc(ETRow_LloydsNumber,LloydsNumberD);
	self.opts.addAssoc("ShippingLine",shippingLine);
	self.opts.addAssoc(ETRow_CallSign,"PORA");
	self.opts.addAssoc("YearOfBuild",2021);
	
	vessel := self.addVesselGeneralCargo(VesselNameD, self.getOperator("MSC"), 10);
	self.assertNotNullMsg(vessel, "Vessel " &amp; VesselNameD);
	self.assertNotNullMsg(vessel.myHMSVesselData, "Vessel " &amp; VesselNameD &amp; " HMS Data");
	self.assertNotNullMsg(vessel.myDefaultTrade, "Vessel Trade");
	self.assertNotNullMsg(vessel.myHMSVesselData.myDefaultShippingLine, "Vessel Shipping Line");
	
	// Check the vessel has tidal classes
	harbourData := vessel.myHMSVesselData.allVesselDataForHarbour[harbour];
	tidalClassArr := root.allTidalClasses["E"];
	tidalClassDep := root.allTidalClasses["C"];
	self.assertEqualMsg(tidalClassArr , harbourData.myTidalClassArrival, "tidal class arrival mismatch");
	self.assertEqualMsg(tidalClassDep , harbourData.myTidalClassDeparture, "tidal class departure mismatch");
	
	// Add Vessel UT_ONEPORTE - VesselNameE
	self.opts.purge();
	self.opts.addAssoc("VesselTrade",trade);
	self.opts.addAssoc(ETRow_LloydsNumber,LloydsNumberE);
	self.opts.addAssoc("ShippingLine",shippingLine);
	self.opts.addAssoc(ETRow_CallSign,"PORA");
	self.opts.addAssoc("YearOfBuild",2021);
	
	vessel := self.addVesselGeneralCargo(VesselNameE, self.getOperator("MSC"), 10);
	self.assertNotNullMsg(vessel, "Vessel " &amp; VesselNameE);
	self.assertNotNullMsg(vessel.myHMSVesselData, "Vessel " &amp; VesselNameE &amp; " HMS Data");
	self.assertNotNullMsg(vessel.myDefaultTrade, "Vessel Trade");
	self.assertNotNullMsg(vessel.myHMSVesselData.myDefaultShippingLine, "Vessel Shipping Line");
	
	// Check the vessel has tidal classes
	harbourData := vessel.myHMSVesselData.allVesselDataForHarbour[harbour];
	tidalClassArr := root.allTidalClasses["E"];
	tidalClassDep := root.allTidalClasses["C"];
	self.assertEqualMsg(tidalClassArr , harbourData.myTidalClassArrival, "tidal class arrival mismatch");
	self.assertEqualMsg(tidalClassDep , harbourData.myTidalClassDeparture, "tidal class departure mismatch");
	
	// Add Vessel UT_ONEPORTF - VesselNameF
	self.opts.purge();
	self.opts.addAssoc("VesselTrade",trade);
	self.opts.addAssoc(ETRow_LloydsNumber,LloydsNumberF);
	self.opts.addAssoc("ShippingLine",shippingLine);
	self.opts.addAssoc(ETRow_CallSign,"PORA");
	self.opts.addAssoc("YearOfBuild",2021);
	
	vessel := self.addVesselGeneralCargo(VesselNameF, self.getOperator("MSC"), 10);
	self.assertNotNullMsg(vessel, "Vessel " &amp; VesselNameF);
	self.assertNotNullMsg(vessel.myHMSVesselData, "Vessel " &amp; VesselNameF &amp; " HMS Data");
	self.assertNotNullMsg(vessel.myDefaultTrade, "Vessel Trade");
	self.assertNotNullMsg(vessel.myHMSVesselData.myDefaultShippingLine, "Vessel Shipping Line");
	
	// Check the vessel has tidal classes
	harbourData := vessel.myHMSVesselData.allVesselDataForHarbour[harbour];
	tidalClassArr := root.allTidalClasses["E"];
	tidalClassDep := root.allTidalClasses["C"];
	self.assertEqualMsg(tidalClassArr , harbourData.myTidalClassArrival, "tidal class arrival mismatch");
	self.assertEqualMsg(tidalClassDep , harbourData.myTidalClassDeparture, "tidal class departure mismatch");
	
	// Wharf and berths
	wharf := harbour.allWharves["WF01"];
	if wharf = null then
		wharf := self.addWharf("WF01","OnePort Test wharf", harbour, 1600, 100);
	endif;
	
	// Berths, just in case they're missing
	create berthArray transient;	
	berthArray.add("105");
	berthArray.add("106");
	berthArray.add("107");
	berthArray.add("108");
	startingPos := null;
	foreach berthCode in berthArray do
		berth := harbour.allBerths[berthCode];
		if berth = null then	
			addBerth(berthCode, berthCode, harbour, startingPos, 100, 2.5, false, wharf);
		endif;
		startingPos += 100;
	endforeach;
	
	// Set the Voyage Process
	utVoyProcess := CM_VoyageProcessDefault.firstInstance;
	defVoyageProcess := self.setTerminalConfig(DefaultVoyageProcess, utVoyProcess.code).String;	
	
	// Get the 'old' NSW endpoint (we use this one because we can force errors on invalid vessels)
	extWebServiceDef := app.myRoot.allExternalWebServices["NSW 'Old' OnePort Vessel Movements"];
	if extWebServiceDef &lt;&gt; null then
		beginTransaction;
		extWebServiceDef.setActive(true);
		commitTransaction;
	endif;
	self.assertNotNullMsg(extWebServiceDef, "(NSW 'Old' OnePort Vessel Movements) external webservice is null/ not available/ changed");
	self.assertTrueMsg(extWebServiceDef.isAPIDef, "extWebServiceDef.isAPIDef");
	activeWebServiceDef := extWebServiceDef.CM_APIEndpointServiceDef;
	
	/////////////
	// First test - a OnePort message with no errors that should load, verify and DB load cleanly
	/////////////
	resultString := self.zNSWOnePortPartialLoadNoError(VesselNameA, VesselNameB, VoyageCodeA_1, VoyageCodeB_1, LloydsNumberA, LloydsNumberB);
	
	lastSuccessfullTS := activeWebServiceDef.getLastSuccessfulTS(terminal);//lastSuccessfullTS; //MTN-36366
	create bgp transient;
	ediFile := bgp.processOnePortResponse(resultString, null, activeWebServiceDef, lastSuccessfullTS, terminal);
	delete bgp;
	self.assertNotNullMsg(ediFile, "Test 1 - EDI File is null");
	self.assertNoTrxErrorsOrWarnings();
	ediData := ediFile.ediData;
	self.assertNotNullMsg(ediData, "Test 1 - No EDI Data has been created");
	
	ediData.verifyEDIDataTIs(app.myPassport);
	self.assertIsOneOf(ediData.status, "Test 1 - Status should be Verified - " &amp; ediData.status.String &amp; " " &amp; app.myPassport.getErrorsAsString, CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS, CM_EDIFile.EDI_STATUS_VERIFIED );
	self.assertEqualMsg(ediData.allErrorWarnings.size, 0, app.myPassport.getAllErrorsAndWarningsAsStr &amp; CrLf &amp; "No errors or warnings should occur");
	
	ediData.loadDB(true, app.myPassport);
	self.assertEqualMsg(ediData.status, CM_EDIFile.EDI_STATUS_DBLOADED, "Test 1 - Status should be DB Loaded");
	// The individual EDI TIs will all be VERIFIED
	foreach ediTI in ediData.allEDITrackedItems do
		self.assertTrueMsg(ediTI.status = CM_EDIFile.EDI_STATUS_VERIFIED, "Test 1 - EDI Tracked Item " &amp; ediTI.String &amp; " status is " &amp; ediTI.status.String);
	endforeach;
	self.assertNotNullMsg(self.getVoyage(VoyageCodeA_1), "Test 1 - " &amp; VoyageCodeA_1);
	self.assertNotNullMsg(self.getVoyage(VoyageCodeB_1), "Test 1 - " &amp; VoyageCodeB_1);
	
	//////////////
	// Second test - a OnePort message with one voyage that should load OK, and one that should error
	//////////////
	resultString := self.zNSWOnePortPartialLoadError1(VesselNameA, VoyageCodeA_2, VoyageCodeC_1, LloydsNumberA, LloydsNumberC);
	
	lastSuccessfullTS := activeWebServiceDef.getLastSuccessfulTS(terminal);//lastSuccessfullTS; //MTN-36366;
	create bgp transient;
	ediFile := bgp.processOnePortResponse(resultString, null, activeWebServiceDef, lastSuccessfullTS, terminal);
	delete bgp;
	self.assertNotNullMsg(ediFile, "Test 2 - EDI File is null");
	self.assertNoTrxErrorsOrWarnings();
	ediData := ediFile.ediData;
	self.assertNotNullMsg(ediData, "Test 2 - No EDI Data has been created");
	
	ediData.verifyEDIDataTIs(app.myPassport);
	self.assertIsOneOf(ediData.status, "Test 2 - Status should be Verified Errors - " &amp; ediData.status.String &amp; " " &amp; app.myPassport.getErrorsAsString, CM_EDIFile.EDI_STATUS_VERIFIED_ERRORS);
	// There should be a CM_EDIQshipsVoyageTI that's at VERIFIED and a CM_EDIQshipsVoyageTI that's at VERIFIED_ERRORS
	foreach ediTI in ediData.allEDITrackedItems do
		if ediTI.isVoyageTI then
			if ediTI.getVoyageCode = VoyageCodeA_2 then
				self.assertTrueMsg(ediTI.status = CM_EDIFile.EDI_STATUS_VERIFIED, "Test 2 - Voyage EDI TI for " &amp; VoyageCodeC_1 &amp; " has the wrong status - " &amp; ediTI.status.String &amp; ", should be " &amp; CM_EDIFile.EDI_STATUS_VERIFIED.String);
				// All related EDI TIs (vessel and movements) should also be at VERIFIED
				vesselTI := ediTI.CM_EDIQshipsVoyageTI.myQshipsVesselTI;
				self.assertTrueMsg(vesselTI.status = CM_EDIFile.EDI_STATUS_VERIFIED, "Test 2 - Vessel EDI TI for " &amp; vesselTI.vesselName &amp; " has the wrong status - " &amp; vesselTI.status.String &amp; ", should be " &amp; CM_EDIFile.EDI_STATUS_VERIFIED.String);
				foreach movementTI in ediTI.CM_EDIQshipsVoyageTI.allQshipsMovementTIs do
					self.assertTrueMsg(movementTI.status = CM_EDIFile.EDI_STATUS_VERIFIED, "Test 2 - Movement EDI TI for " &amp; movementTI.moveType &amp; " has the wrong status - " &amp; movementTI.status.String &amp; ", should be " &amp; CM_EDIFile.EDI_STATUS_VERIFIED.String);
				endforeach;
			elseif ediTI.getVoyageCode = VoyageCodeC_1 then
				self.assertTrueMsg(ediTI.status = CM_EDIFile.EDI_STATUS_VERIFIED_ERRORS, "Test 2 - Voyage EDI TI for " &amp; VoyageCodeA_2 &amp; " has the wrong status - " &amp; ediTI.status.String &amp; ", should be " &amp; CM_EDIFile.EDI_STATUS_VERIFIED_ERRORS.String);
				// All related EDI TIs (vessel and movements) should also be at VERIFIED_ERRORS
				vesselTI := ediTI.CM_EDIQshipsVoyageTI.myQshipsVesselTI;
				self.assertNullMsg(vesselTI, "Test 2 - Vessel EDI TI for " &amp; ediTI.CM_EDIVoyageTI.vesselName &amp; " is not null!");
				foreach movementTI in ediTI.CM_EDIQshipsVoyageTI.allQshipsMovementTIs do
					self.assertTrueMsg(movementTI.status = CM_EDIFile.EDI_STATUS_VERIFIED_ERRORS, "Test 2 - Movement EDI TI for " &amp; movementTI.moveType &amp; " has the wrong status - " &amp; movementTI.status.String &amp; ", should be " &amp; CM_EDIFile.EDI_STATUS_VERIFIED_ERRORS.String);
				endforeach;
			endif;
		endif;
	endforeach;
	
	ediData.loadDB(true, app.myPassport);
	self.assertEqualMsg(ediData.status, CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL, "Test 2 - Status should be DB Loaded Partial");
	self.assertNotNullMsg(self.getVoyage(VoyageCodeA_1), "Test 2 - " &amp; VoyageCodeA_1);
	
	/////////////
	// Third test - A user-defined voyage file with 2 voyages that should DB Load OK
	/////////////
	udf := app.myRoot.allEDIFileTypeUsersByName[UserDefinedFormat];
	self.assertNotNullMsg(udf, "Test 3 - User Defined File 'Unit Test Voyage'");
	
	create ediControllerAgent transient;
	ediControllerAgent.setTerminal(terminal);
	
	// Delete stuff to start with
	// Voyages
	self.deleteVoyage(UDFVoyage1);
	self.deleteVoyage(UDFVoyage2);
	// Any EDI data that is still there
	messageType := UserDefinedFormat[1 : udf.name.maxLength];
	idx := idx + 1;
	clientRef := method.name[1 : ediControllerAgent.ediClientRef.maxLength-1]&amp;idx.String;
	ediControllerAgent.setEdiClientRef(clientRef);
	ediFile := ediControllerAgent.getEDIFile_By_ediClientRef(clientRef);
	if ediFile &lt;&gt; null then
		beginTransaction;
		if ediFile.ediData = null then
			delete ediFile;
		else
			ediData := ediFile.ediData;
			delete ediData;
		endif;
		commitTransaction;
	endif;
	ediFile := ediControllerAgent.getEDIFile_By_ediClientRef(clientRef);
	self.assertIsDeleted(ediFile);
	
	// Now load the user-defined data
	ediText := self.zUDFVoyagePartialLoadNoError();
	ediFile := self.ediLoadFileName(ediText, EDIFileType_UserDefined, UserDefinedFormat, UserDefinedFormat &amp; method.name);
	self.assertNotNullMsg(ediFile, "Test 3 - First User-Defined Voyage File");
	
	// Verify
	self.ediVerify(ediFile);
	self.assertIsOneOf(ediFile.fileStatus, "Test 3 - First User-Defined Voyge File did not verify " &amp; app.myPassport.getErrorsAndWarningsAsString, CM_EDIFile.EDI_STATUS_VERIFIED, CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS);
	
	// And DB Load
	self.ediDBLoad(ediFile);
	self.assertEqualMsg(ediFile.fileStatus, CM_EDIFile.EDI_STATUS_DBLOADED, "Test 3 - First User-Defined Voyage File didn't DB Load " &amp; app.myPassport.getErrorsAndWarningsAsString);
	self.assertNotNullMsg(self.getVoyage(UDFVoyage1), "Test 3 - " &amp; UDFVoyage1);
	self.assertNotNullMsg(self.getVoyage(UDFVoyage2), "Test 3 - " &amp; UDFVoyage2);
	
	//////////////
	// Fourth test - a user-defined voyage file with one successful voyage and one voyage that has errors
	//////////////
	
	// Delete stuff - Voyages
	self.deleteVoyage(UDFVoyage1);
	self.deleteVoyage(UDFVoyage2);
	// EDI data
	idx := idx + 1;
	clientRef := method.name[1 : ediControllerAgent.ediClientRef.maxLength-1]&amp;idx.String;
	ediControllerAgent.setEdiClientRef(clientRef);
	ediFile := ediControllerAgent.getEDIFile_By_ediClientRef(clientRef);
	if ediFile &lt;&gt; null then
		beginTransaction;
		if ediFile.ediData = null then
			delete ediFile;
		else
			ediData := ediFile.ediData;
			delete ediData;
		endif;
		commitTransaction;
	endif;
	ediFile := ediControllerAgent.getEDIFile_By_ediClientRef(clientRef);
	self.assertIsDeleted(ediFile);
	
	// Now load the user-defined data
	ediText := self.zUDFVoyagePartialLoadError1();
	ediFile := self.ediLoadFileName(ediText, EDIFileType_UserDefined, UserDefinedFormat, UserDefinedFormat &amp; method.name);
	self.assertNotNullMsg(ediFile, "Test 4 - Second User-Defined Voyage File");
	
	// Verify
	self.ediVerify(ediFile);
	self.assertEqualMsg(ediFile.fileStatus, CM_EDIFile.EDI_STATUS_VERIFIED_ERRORS, "Test 4 - Second User-Defined Voyage File is not Verify errors " &amp; app.myPassport.getErrorsAndWarningsAsString);
	
	// And DB Load
	self.ediDBLoad(ediFile);
	self.assertEqualMsg(ediFile.fileStatus, CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL, "Test 4 - Second User-Defined Voyage File didn't DB Load Partially " &amp; app.myPassport.getErrorsAndWarningsAsString);
	self.assertNotNullMsg(self.getVoyage(UDFVoyage1), "Test 4 - " &amp; UDFVoyage1);
	self.assertNullMsg(self.getVoyage(UDFVoyage2), "Test 4 - " &amp; UDFVoyage2);
	
	/////////////
	// Fifth test - a OnePort message with 3 voyages, the first should error and the next 2 should work
	/////////////
	resultString := self.zNSWOnePortPartialLoadError2(VoyageCodeC_2, LloydsNumberC, VoyageCodeB_2, VoyageCodeB_3, VesselNameB, LloydsNumberB);
	
	lastSuccessfullTS := activeWebServiceDef.getLastSuccessfulTS(terminal);//lastSuccessfullTS; //MTN-36366;
	create bgp transient;
	ediFile := bgp.processOnePortResponse(resultString, null, activeWebServiceDef, lastSuccessfullTS, terminal);
	delete bgp;
	self.assertNotNullMsg(ediFile,"Test 5 - EDI File is null");
	self.assertNoTrxErrorsOrWarnings();
	ediData := ediFile.ediData;
	self.assertNotNullMsg(ediData, "Test 5 - No EDI Data has been created");
	
	ediData.verifyEDIDataTIs(app.myPassport);
	self.assertIsOneOf(ediData.status, "Test 5 - Status should be Verified Errors - " &amp; ediData.status.String &amp; " " &amp; app.myPassport.getErrorsAsString, CM_EDIFile.EDI_STATUS_VERIFIED_ERRORS);
	// There should be a CM_EDIQshipsVoyageTI that's at VERIFIED_ERRORS for voyage code 143250 and the  other CM_EDIQshipsVoyageTIs should be at VERIFIED
	foreach ediTI in ediData.allEDITrackedItems do
		if ediTI.isVoyageTI then
			if ediTI.getVoyageCode = VoyageCodeC_2 then
				self.assertTrueMsg(ediTI.status = CM_EDIFile.EDI_STATUS_VERIFIED_ERRORS, "Test 5 - Voyage EDI TI for " &amp; VoyageCodeC_2 &amp; " has the wrong status - " &amp; ediTI.status.String &amp; ", should be " &amp; CM_EDIFile.EDI_STATUS_VERIFIED.String);
				// All related EDI TIs (vessel and movements) should also be at VERIFIED
				vesselTI := ediTI.CM_EDIQshipsVoyageTI.myQshipsVesselTI;
				self.assertNullMsg(vesselTI, "Test 5 - Vessel EDI TI for " &amp; ediTI.CM_EDIVoyageTI.vesselName &amp; " is not null!");
				foreach movementTI in ediTI.CM_EDIQshipsVoyageTI.allQshipsMovementTIs do
					self.assertTrueMsg(movementTI.status.isOneOf(CM_EDIFile.EDI_STATUS_VERIFIED_ERRORS, CM_EDIFile.EDI_STATUS_UNPROCESSED), "Test 5 - Movement EDI TI for " &amp; movementTI.moveType &amp; " has the wrong status - " &amp; movementTI.status.String);
				endforeach;
			else
				self.assertTrueMsg(ediTI.status = CM_EDIFile.EDI_STATUS_VERIFIED, "Test 5 - Voyage EDI TI for " &amp; ediTI.getVoyageCode &amp; " has the wrong status - " &amp; ediTI.status.String &amp; ", should be " &amp; CM_EDIFile.EDI_STATUS_VERIFIED.String);
				// All related EDI TIs (vessel and movements) should also be at VERIFIED_ERRORS
				vesselTI := ediTI.CM_EDIQshipsVoyageTI.myQshipsVesselTI;
				self.assertTrueMsg(vesselTI.status = CM_EDIFile.EDI_STATUS_VERIFIED, "Test 5 - Vessel EDI TI for " &amp; vesselTI.vesselName &amp; " has the wrong status - " &amp; vesselTI.status.String &amp; ", should be " &amp; CM_EDIFile.EDI_STATUS_VERIFIED.String);
				foreach movementTI in ediTI.CM_EDIQshipsVoyageTI.allQshipsMovementTIs do
					self.assertTrueMsg(movementTI.status = CM_EDIFile.EDI_STATUS_VERIFIED, "Test 5 - Movement EDI TI for " &amp; movementTI.moveType &amp; " has the wrong status - " &amp; movementTI.status.String &amp; ", should be " &amp; CM_EDIFile.EDI_STATUS_VERIFIED.String);
				endforeach;
			endif;
		endif;
	endforeach;
	
	ediData.loadDB(true, app.myPassport);
	self.assertEqualMsg(ediData.status, CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL, "Test 5 - Status should be DB Loaded Partial");
	voyage := self.getVoyage(VoyageCodeC_2);
	self.assertNullMsg(voyage, "Test 5 - Voyage " &amp; VoyageCodeC_2);
	self.assertNotNullMsg(self.getVoyage(VoyageCodeB_2), "Test 5 - " &amp; VoyageCodeB_2);
	self.assertNotNullMsg(self.getVoyage(VoyageCodeB_3), "Test 5 - " &amp; VoyageCodeB_3);
	
	/////////////
	// Sixth test - a OnePort message with 5 voyages, where the 1st, 2nd and 5th should work, and the 3rd and 4th fail
	/////////////
	resultString := self.zNSWOnePortPartialLoadError3(VesselNameD, LloydsNumberD, VoyageCodeD_1, VoyageCodeD_2, VoyageCodeD_3, LloydsNumberC, VoyageCodeC_1, VoyageCodeC_2);
	lastSuccessfullTS := activeWebServiceDef.getLastSuccessfulTS(terminal);//lastSuccessfullTS; //MTN-36366;
	create bgp transient;
	ediFile := bgp.processOnePortResponse(resultString, null, activeWebServiceDef, lastSuccessfullTS, terminal);
	delete bgp;
	self.assertNotNullMsg(ediFile,"Test 6 - EDI File is null");
	self.assertNoTrxErrorsOrWarnings();
	ediData := ediFile.ediData;
	self.assertNotNullMsg(ediData, "Test 6 - No EDI Data has been created");
	
	ediData.verifyEDIDataTIs(app.myPassport);
	self.assertIsOneOf(ediData.status, "Test 6 - Status should be Verified Errors - " &amp; ediData.status.String &amp; " " &amp; app.myPassport.getErrorsAsString, CM_EDIFile.EDI_STATUS_VERIFIED_ERRORS);
	
	// EDI Voyage TIs for VoyageCodeD_1, VoyageCodeD_2 and VoyageCodeD_3 should be Verified, for VoyageCodeC_1 and VoyageCodeC_2 should be Verified Errors
	foreach ediTI in ediData.allEDITrackedItems where ediTI.isVoyageTI do
		if ediTI.CM_EDIVoyageTI.getVoyageCode.isOneOf(VoyageCodeD_1, VoyageCodeD_2, VoyageCodeD_3) then
			self.assertEqualMsg(ediTI.status, CM_EDIFile.EDI_STATUS_VERIFIED, "EDI Status for " &amp; ediTI.CM_EDIVoyageTI.getVoyageCode);
		elseif ediTI.CM_EDIVoyageTI.getVoyageCode.isOneOf(VoyageCodeC_1, VoyageCodeC_2) then
			self.assertEqualMsg(ediTI.status, CM_EDIFile.EDI_STATUS_VERIFIED_ERRORS, "EDI Status for " &amp; ediTI.CM_EDIVoyageTI.getVoyageCode);
		endif;
	endforeach;
	
	ediData.loadDB(true, app.myPassport);
	self.assertEqualMsg(ediData.status, CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL, "Test 6 - Status should be DB Loaded Partial");
	voyage := self.getVoyage(VoyageCodeC_1);
	self.assertNullMsg(voyage, "Test 6 - Voyage " &amp; VoyageCodeC_1);
	voyage := self.getVoyage(VoyageCodeC_2);
	self.assertNullMsg(voyage, "Test 6 - Voyage " &amp; VoyageCodeC_2);
	self.assertNotNullMsg(self.getVoyage(VoyageCodeD_1), "Test 6 - " &amp; VoyageCodeD_1);
	self.assertNotNullMsg(self.getVoyage(VoyageCodeD_2), "Test 6 - " &amp; VoyageCodeD_2);
	self.assertNotNullMsg(self.getVoyage(VoyageCodeD_3), "Test 6 - " &amp; VoyageCodeD_3);
	
	///////////////
	// Seventh test - a Voyage user-defined file with 3 voyages, where the first should error and the next 2 should work
	///////////////
	ediControllerAgent.setTerminal(terminal);
	
	// Delete stuff to start with
	// Voyages
	self.deleteVoyage(UDFVoyage1);
	self.deleteVoyage(UDFVoyage2);
	self.deleteVoyage(UDFVoyage3);
	// Any EDI data that is still there
	messageType := UserDefinedFormat[1 : udf.name.maxLength];
	idx := idx + 1;
	clientRef := method.name[1 : ediControllerAgent.ediClientRef.maxLength-1]&amp;idx.String;
	ediControllerAgent.setEdiClientRef(clientRef);
	ediFile := ediControllerAgent.getEDIFile_By_ediClientRef(clientRef);
	if ediFile &lt;&gt; null then
		beginTransaction;
		if ediFile.ediData = null then
			delete ediFile;
		else
			ediData := ediFile.ediData;
			delete ediData;
		endif;
		commitTransaction;
	endif;
	ediFile := ediControllerAgent.getEDIFile_By_ediClientRef(clientRef);
	self.assertIsDeleted(ediFile);
	
	// Now load the user-defined data
	ediText := self.zUDFVoyagePartialLoadError2();
	ediFile := self.ediLoadFileName(ediText, EDIFileType_UserDefined, UserDefinedFormat, UserDefinedFormat &amp; method.name);
	self.assertNotNullMsg(ediFile, "Test 7 - Third User-Defined Voyage File");
	
	// Verify
	self.ediVerify(ediFile);
	self.assertEqualMsg(ediFile.fileStatus, CM_EDIFile.EDI_STATUS_VERIFIED_ERRORS, "Test 7 - Third User-Defined Voyage File is not Verify errors " &amp; app.myPassport.getErrorsAndWarningsAsString);
	
	// And DB Load
	self.ediDBLoad(ediFile);
	self.assertEqualMsg(ediFile.fileStatus, CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL, "Test 7 - Third User-Defined Voyage File didn't DB Load Partially " &amp; app.myPassport.getErrorsAndWarningsAsString);
	self.assertNotNullMsg(self.getVoyage(UDFVoyage2), "Test 7 - " &amp; UDFVoyage2);
	self.assertNotNullMsg(self.getVoyage(UDFVoyage3), "Test 7 - " &amp; UDFVoyage3);
	
	//////////////
	// Eighth test - a Voyage user-defined file with 5 voyages, where the 1st, 2nd and 5th should work, and the 3rd and 4th fail
	//////////////
	
	ediControllerAgent.setTerminal(terminal);
	
	// Delete stuff to start with
	// Voyages
	self.deleteVoyage(UDFVoyage1);
	self.deleteVoyage(UDFVoyage2);
	self.deleteVoyage(UDFVoyage3);
	// Any EDI data that is still there
	messageType := UserDefinedFormat[1 : udf.name.maxLength];
	idx := idx + 1;
	clientRef := method.name[1 : ediControllerAgent.ediClientRef.maxLength-1]&amp;idx.String;
	ediControllerAgent.setEdiClientRef(clientRef);
	ediFile := ediControllerAgent.getEDIFile_By_ediClientRef(clientRef);
	if ediFile &lt;&gt; null then
		beginTransaction;
		if ediFile.ediData = null then
			delete ediFile;
		else
			ediData := ediFile.ediData;
			delete ediData;
		endif;
		commitTransaction;
	endif;
	ediFile := ediControllerAgent.getEDIFile_By_ediClientRef(clientRef);
	self.assertIsDeleted(ediFile);
	
	// Now load the user-defined data
	ediText := self.zUDFVoyagePartialLoadError3();
	ediFile := self.ediLoadFileName(ediText, EDIFileType_UserDefined, UserDefinedFormat, UserDefinedFormat &amp; method.name);
	self.assertNotNullMsg(ediFile, "Test 8 - Fourth User-Defined Voyage File");
	
	// Verify
	self.ediVerify(ediFile);
	self.assertEqualMsg(ediFile.fileStatus, CM_EDIFile.EDI_STATUS_VERIFIED_ERRORS, "Test 8 - Fourth User-Defined Voyage File is not Verify errors " &amp; app.myPassport.getErrorsAndWarningsAsString);
	
	// And DB Load
	self.ediDBLoad(ediFile);
	self.assertEqualMsg(ediFile.fileStatus, CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL, "Test 8 - Fourth User-Defined Voyage File didn't DB Load Partially " &amp; app.myPassport.getErrorsAndWarningsAsString);
	self.assertNotNullMsg(self.getVoyage(UDFVoyage1), "Test 8 - " &amp; UDFVoyage1);
	self.assertNotNullMsg(self.getVoyage(UDFVoyage2), "Test 8 - " &amp; UDFVoyage2);
	self.assertNotNullMsg(self.getVoyage(UDFVoyage3), "Test 8 - " &amp; UDFVoyage3);
	
	/////////////
	// Ninth test - a OnePOrt message that updates an existing voyage
	/////////////
	resultString := self.zNSWOnePortPartialLoadUpdate(VoyageCodeA_1, LloydsNumberA, VesselNameA);
	
	lastSuccessfullTS := activeWebServiceDef.getLastSuccessfulTS(terminal);//lastSuccessfullTS; //MTN-36366;
	create bgp transient;
	ediFile := bgp.processOnePortResponse(resultString, null, activeWebServiceDef, lastSuccessfullTS, terminal);
	delete bgp;
	self.assertNotNullMsg(ediFile,"Test 9 - EDI File is null");
	self.assertNoTrxErrorsOrWarnings();
	ediData := ediFile.ediData;
	self.assertNotNullMsg(ediData, "Test 9 - No EDI Data has been created");
	
	ediData.verifyEDIDataTIs(app.myPassport);
	self.assertIsOneOf(ediData.status, "Test 9 - Status should be Verified - " &amp; ediData.status.String &amp; " " &amp; app.myPassport.getErrorsAsString, CM_EDIFile.EDI_STATUS_VERIFIED, CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS);
	// There should be a CM_EDIQshipsVoyageTI that's at VERIFIED for voyage code 142372
	foreach ediTI in ediData.allEDITrackedItems do
		if ediTI.isVoyageTI then
			if ediTI.getVoyageCode = VoyageCodeA_1 then
				self.assertTrueMsg(ediTI.status = CM_EDIFile.EDI_STATUS_VERIFIED, "Test 9 - Voyage EDI TI for " &amp; VoyageCodeA_1 &amp; " has the wrong status - " &amp; ediTI.status.String &amp; ", should be " &amp; CM_EDIFile.EDI_STATUS_VERIFIED.String);
				// All related EDI TIs (vessel and movements) should also be at VERIFIED
				vesselTI := ediTI.CM_EDIQshipsVoyageTI.myQshipsVesselTI;
				self.assertNotNullMsg(vesselTI, "Test 9 - Vessel EDI TI for " &amp; ediTI.CM_EDIVoyageTI.vesselName &amp; " is null!");
				foreach movementTI in ediTI.CM_EDIQshipsVoyageTI.allQshipsMovementTIs do
					self.assertTrueMsg(movementTI.status = CM_EDIFile.EDI_STATUS_VERIFIED, "Test 9 - Movement EDI TI for " &amp; movementTI.moveType &amp; " has the wrong status - " &amp; movementTI.status.String);
				endforeach;
			endif;
		endif;
	endforeach;
	
	ediData.loadDB(true, app.myPassport);
	self.assertEqualMsg(ediData.status, CM_EDIFile.EDI_STATUS_DBLOADED, "Test 9 - Status should be DB Loaded");
	voyage := self.getVoyage(VoyageCodeA_1);
	self.assertNotNullMsg(voyage, "Test 9 - Voyage " &amp; VoyageCodeA_1);
	// Voyage departure date should have been changed to 15 August 2025
	self.assertTrueMsg(voyage.departedDT.date = "15 August 2025".Date, "Departure date for " &amp; VoyageCodeA_1 &amp; " is incorrect - " &amp; voyage.departedDT.date.format("dd MMM yyyy") &amp; ", should be 15 August 2025");
	foreach movement in voyage.myHMSVoyageData.allVoyageMovements where movement.moveType = HMSMovementTypeDeparture do
		self.assertTrueMsg(movement.occursOnDTNEW.date = "15 August 2025".Date, "Departure movement date for " &amp; VoyageCodeA_1 &amp; " is incorrect - " &amp; movement.occursOnDTNEW.date.format("dd MMM yyyy") &amp; ", should be 15 August 2025");
	endforeach;	
	
epilog
	delete berthArray;
	delete bgp;
	delete ediControllerAgent;
end;</source>
    </JadeMethod>
    <JadeMethod name="tNSWOnePortVesselMoveStatus" id="4dfc14cb-be13-4b19-b845-3ff1d8234dff">
        <source>tNSWOnePortVesselMoveStatus();
/*

Purpose:			This UT tests the process of one port movement response map the movement status correctly
					e.g.
					One Port MovementStatus		MTN Status		In Used
					===================================================
					Booked						Planned			Yes
					Completed					Confirm Plan	No
					Confirmed					Actual			Yes
					
					When processing the response, expect
					Booked &gt; mapped to Planned
					Completed is not processed, as it's not in used
					Confirmed &gt; mapped to Actual

Parameters:			

Return Value:		

Date		Who		Reason
//02/12/2025	navkc1 JIRA 36177 NSW | OnePort API - Change voyage creation criteria Unit Tests

*/
constants
	Ref = "UT63";
	VessCode 	= "63842";
	VoyCode 	= "468631";
	
	// Arrival, status Confirmed &gt; Actual
	// Shift, status Completed &gt; Confirmed plan (not used so to be ignored)
	//Departure, status Booked &gt; Planned  
	MovementString = '[
   {
    "movementID": 10983,
    "sourceMovementID": 10983,
    "visitID": '&amp;VoyCode&amp;',
    "sourceVisitID": '&amp;VoyCode&amp;',
    "voyageNoIn": "V. 2464",
    "voyageNoOut": "V. 2464",
    "port": "AUPKL",
    "vesselIMO": '&amp;VessCode&amp;',
    "vesselName": '&amp;VessCode&amp;',
    "fromLocation": "",
    "toLocation": "106",
    "purpose": "D",
    "agentCode": "WSS",
    "vesselOperator": "",
    "expectedStartTime": "2024-08-06T10:31:00",
    "clearBerthTime": "2024-08-06T10:15:00",
    "secureBerthTime":null,
    "movementType": "Arrival", 
    "status": "Confirmed",
    "createdTime": "2024-08-05T02:43:05.2430509",
    "lastModifiedTime": "2024-08-06T10:48:04.3473873",
	"commercialOperator" : "'&amp;Ref&amp;'"
  },
  {
    "movementID": 10982,
    "sourceMovementID": 10982,
    "visitID": '&amp;VoyCode&amp;',
    "sourceVisitID": '&amp;VoyCode&amp;',
    "voyageNoIn": "V. 2464",
    "voyageNoOut": "V. 2464",
    "port": "AUPKL",
    "vesselIMO": '&amp;VessCode&amp;',
    "vesselName": "'&amp;VessCode&amp;'",
    "fromLocation": "106",
    "toLocation": "107",
    "purpose": "D",
    "agentCode": "WSS",
    "vesselOperator": "",
    "expectedStartTime": "2024-08-07T17:00:00",
    "clearBerthTime":"2024-08-07T17:59:00",
    "secureBerthTime": "2024-08-07T17:55:00",
    "movementType": "Shift",
    "status": "Completed",
    "createdTime": "2024-08-06T02:42:04.7962951",
    "lastModifiedTime": "2024-08-06T18:11:41.4068009",
	"commercialOperator" : "'&amp;Ref&amp;'"
  },
  {
    "movementID": 10983,
    "sourceMovementID": 10983,
    "visitID": '&amp;VoyCode&amp;',
    "sourceVisitID": '&amp;VoyCode&amp;',
    "voyageNoIn": "V. 2464",
    "voyageNoOut": "V. 2464",
    "port": "AUPKL",
    "vesselIMO": '&amp;VessCode&amp;',
    "vesselName": '&amp;VessCode&amp;',
    "fromLocation": "106",
    "toLocation": "",
    "purpose": "D",
    "agentCode": "WSS",
    "vesselOperator": "",
    "expectedStartTime": "2024-08-08T10:30:00",
    "clearBerthTime": "2024-08-08T10:14:00",
    "secureBerthTime":null,
    "movementType": "Departure",
    "status": "Booked",
    "createdTime": "2024-08-07T02:42:05.2430509",
    "lastModifiedTime": "2024-08-07T10:47:04.3473873",
	"commercialOperator" : "'&amp;Ref&amp;'"
  }
  ]';
vars
	status					: CM_NameValuePair;
	term					: CM_Terminal;
	newStatuses, 
	existingStatuses		: CM_NameValuePairDict;
	extWebServiceDef		: CM_ExternalWebServiceDef;
	activeWebServiceDef 	: CM_APIEndpointServiceDef;
	resultString 			: String;
	edifile					: CM_EDIFile;
	bgp						: BGP_OnePortRequest;
	lastSuccessfullTS 		: TimeStamp;
	harbour					: HMS_Harbour;
	wharf					: HMS_Wharf;
	berth					: HMS_Berth;		
	berthArray				: StringArray;
	startingPos 			: Integer;
	berthCode				: String;
	ediData 				: CM_EDIData;
	defVoyageProcess 		: String;
	utVoyProcess 			: CM_VoyageProcessDefault;
	vessel					: CM_Vessel;
	root 					: CM_Root;
	harbourData				: HMS_VesselDataHarbour;
	tidalClassArr,
	tidalClassDep			: HMS_TidalClass;
	shippingLine 			: CM_ShippingLine;
	trade 					: CM_Trade;
	voyage 					: CM_Voyage;
	hmsData					: HMS_VoyageData;
	hmsMovementArrival,
	hmsMovementDep,
	hmsMovementShift		: HMS_VoyageMovement;
begin
	// Get Terminal 
		term := self.getMyTerminal();
		
	// Get existing One Port Statuses
		create existingStatuses transient;
		term.allOnePortStatuses.copy(existingStatuses);
		
	// Detach from terminal so we don't mess up with existing data. Gonna link them back together in epilog
		beginTransaction;
			foreach status in existingStatuses do
				term.allOnePortStatuses.tryRemove(status);
			endforeach;
		commitTransaction;
		
		// Create valid statuses
		create newStatuses transient;
		
		create status transient;
		status.createNewPair("Booked", MovementStatus_Planned.String &amp; "|1");				// Booked to Planned - In used
		newStatuses.add(status);
		
		create status transient;
		status.createNewPair("Completed", MovementStatus_ConfirmedPlan.String &amp; "|0");		// Completed to Confirmed Planned - Not used
		newStatuses.add(status);
		
		create status transient;
		status.createNewPair("Confirmed", MovementStatus_Actual.String &amp; "|1");				// Confrimed to Actual - IN used
		newStatuses.add(status);
		
		app.myTrxUA.trxUpdateOnePortStatuses(term, newStatuses, app.myPassport);
		self.assertNoTrxErrors();
	
	root := app.myRoot;
	
	// Delete things first
	self.deleteVessel(VessCode);
	self.opts.purge();
	
	trade	 := root.allTradesByDescription.getAtKey("Doug World");
	shippingLine := root.allShippingLines.getAtKey("DOUG");
	
	//Add Vessel
	self.opts.purge();
	self.opts.addAssoc("isBarge",true);
	self.opts.addAssoc("VesselTrade",trade);
	self.opts.addAssoc(ETRow_LloydsNumber,VessCode);
	self.opts.addAssoc("ShippingLine",shippingLine);
	self.opts.addAssoc(ETRow_CallSign,"Doofus");
	self.opts.addAssoc("YearOfBuild",2020);
	
	vessel := self.addVesselGeneralCargo(VessCode, self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString), 10);
	self.assertNotNullMsg(vessel, "Vessel " &amp; VessCode);
	self.assertNotNullMsg(vessel.myHMSVesselData, "Vessel " &amp; VessCode &amp; " HMS Data");
	
	// Check the vessel has tidal classes
	harbour := term.myHarbour;
	harbourData := vessel.myHMSVesselData.allVesselDataForHarbour[harbour];
	tidalClassArr := root.allTidalClasses["E"];
	tidalClassDep := root.allTidalClasses["C"];
	self.assertEqualMsg(tidalClassArr , harbourData.myTidalClassArrival, "tidal class arrival mismatch");
	self.assertEqualMsg(tidalClassDep , harbourData.myTidalClassDeparture, "tidal class departure mismatch");
	
	//set to what the unit test needed
	utVoyProcess := CM_VoyageProcessDefault.firstInstance;
	defVoyageProcess := self.setTerminalConfig(DefaultVoyageProcess, utVoyProcess.code).String;	
	
	extWebServiceDef := app.myRoot.allExternalWebServices["NSW 'Old' OnePort Vessel Movements"];
	if extWebServiceDef &lt;&gt; null then
		beginTransaction;
		extWebServiceDef.setActive(true);
		commitTransaction;
	endif;
	self.assertNotNullMsg(extWebServiceDef, "(NSW 'Old' OnePort Vessel Movements) external webservice is null/ not available/ changed");
	self.assertTrueMsg(extWebServiceDef.isAPIDef, "extWebServiceDef.isAPIDef");
	activeWebServiceDef := extWebServiceDef.CM_APIEndpointServiceDef;

	// wharf
	wharf := harbour.allWharves["WF01"].HMS_Wharf;
	if wharf = null then
		wharf := self.addWharf("WF01","OnePort Test wharf", harbour, 1600, 100);
	endif;
	
	// berth Just incase the berth is missing
	create berthArray transient;	
	berthArray.add("105");
	berthArray.add("106");
	berthArray.add("107");
	berthArray.add("108");	
	startingPos := 0;
	foreach berthCode in berthArray do
		berth := harbour.allBerths[berthCode];
		if berth = null then	
			addBerth(berthCode, berthCode, harbour, startingPos, 100, 2.5, false, wharf);
		endif;
		startingPos += 100;
	endforeach;
	
	resultString := MovementString;

	//Process response string
	lastSuccessfullTS := activeWebServiceDef.getLastSuccessfulTS(term);//lastSuccessfullTS; //MTN-36366;
	create bgp transient;
	edifile := bgp.processOnePortResponse(resultString, null, activeWebServiceDef, lastSuccessfullTS, term);
	self.assertNotNullMsg(edifile,"EDI File is null");
	self.assertNoTrxErrorsOrWarnings();
	ediData := edifile.ediData;
	self.assertNotNullMsg(ediData, "No edidata has been created.");	
	
	ediData.verifyEDIDataTIs(app.myPassport);
	self.assertIsOneOf(ediData.status, "Status should be Verified - " &amp; ediData.status.String, CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS, CM_EDIFile.EDI_STATUS_VERIFIED );
	self.assertEqualMsg(ediData.allErrorWarnings.size, 0, "No error's or warning should occurs");	
	
	ediData.loadDB(true, app.myPassport);
	self.assertEqualMsg(ediData.status, CM_EDIFile.EDI_STATUS_DBLOADED, "Status should be DB Loaded");	
	delete bgp;
	
	voyage := term.allVoyagesByCode.getAtKeyGeq(VoyCode, null);
	self.assertNotNullMsg(voyage, "Voyage should not be null");
	self.assertEqualMsg(voyage.displayOption, VoyageDisplayDefault, "The display option should be the default one");
	
	//Verify HMS movements
	hmsData	:= voyage.myHMSVoyageData;
	self.assertNotNullMsg(hmsData, "HMS data should not be null");
	self.assertEqualMsg(hmsData.allVoyageMovements.size, 2, "Voyage movement size should be 2. We send in 3 status but 1 of them is not in used so should be ignored.");
	
	hmsMovementArrival 	:= hmsData.getMovementForMoveType(HMSMovementTypeArrival);
	self.assertNotNullMsg(hmsMovementArrival, "No Arrival movemnet");
	self.assertTrueMsg(hmsMovementArrival.moveStatusNEW = MovementStatus_Actual, "Arrival Movement status should be Actual. That's what we are mapping into.");

	hmsMovementShift 	:= hmsData.getMovementForMoveType(HMSMovementTypeShift);
	self.assertNullMsg(hmsMovementShift, "We should not get Shift movement status as it's not currently in used in the mapping.");
	
	hmsMovementDep 		:= hmsData.getMovementForMoveType(HMSMovementTypeDeparture);
	self.assertNotNullMsg(hmsMovementDep, "No Departure Movement");
	self.assertTrueMsg(hmsMovementDep.moveStatusNEW = MovementStatus_Planned, "Departure Movement status should be Planned. That's what we are mapping into.");
	
epilog
	beginTransaction;
		term.allOnePortStatuses.purge(); // Delete those created in this unit test
		
		// Link the original statues back to terminal
		foreach status in existingStatuses do
			term.addOnePortStatus(status);
		endforeach;
		
		if extWebServiceDef &lt;&gt; null then
			extWebServiceDef.setActive(false);
		endif;
	commitTransaction;
	
	self.deleteVessel(VessCode);
	
	if newStatuses &lt;&gt; null then
		newStatuses.purge();
	endif;
	
	delete newStatuses;
	delete existingStatuses;
	app.allExtOAuthTokens.purge();
	delete bgp;
	delete berthArray;
end;</source>
    </JadeMethod>
    <JadeMethod name="tNSWOnePortVesselMovements" id="959a654f-1290-4ffb-af6f-cb6d1c30b414">
