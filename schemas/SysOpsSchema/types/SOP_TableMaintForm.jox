//
// ---------------------------------------------------------------------------
vars
	
begin

	self.myPlaceHolderObject := self.myCurrentTableItem.getPlaceHolderObject();
	
	if self.myPlaceHolderObject = null then
		inheritMethod();
	endif;

end;</source>
    </JadeMethod>
