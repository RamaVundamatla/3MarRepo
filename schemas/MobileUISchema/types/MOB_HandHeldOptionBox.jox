    <JadeMethod name="btnDialog1_click" id="f53302a6-ead3-4efa-92ca-7ea0d6d7da2f">
        <updating/>
        <source>btnDialog1_click(btn: Button input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
26 August 2010	cnwndl1	Initial creation

*/

vars

begin
	
	//OK;
	
	if opt1.value then
		self.modalResult := 1;
	elseif opt2.value then
		self.modalResult := 2;
	elseif opt3.value then
		self.modalResult := 3;
	elseif opt3.value then
		self.modalResult := 4;
	else
		self.modalResult := 0;
	endif;
	
	self.unloadForm();

epilog

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doResize" id="7774e569-5c7c-49df-bec2-295d53c19235">
        <updating/>
        <source>doResize() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
26 Aug 2010	cnwndl1	Initial creation
16 Dec 2013	cnwkpd1	PAR #33170 - Fix positioning of the Alert and Cancel buttons on Windows Mobile
22 Feb 2016	NDL	Par 37564 

*/

constants

	WIDTH = 239;
	Dummy = "Dummy";
	
vars

	textHeightForWidth,
	textHeight : Integer;
	lblWidth : Real;
	lblLeft : Real;
	lblHeight, frmHeight : Real;
	lastUsed : Real;
	stdGap : Real;
	stdFontSize : Real;
	stdHeight : Real;
	
begin

	self.clientWidth := WIDTH;
	
	self.setResizeableMarginAndFontSize();
	stdGap :=  self.resizedMargin;
	stdFontSize := self.drawFontSize;
	stdHeight := self.getStdControlHeight;
	
	//05 May 2016	NDL TFS 1936
	self.lblText.borderStyle := 0;
	self.lblText.top := stdGap;
	self.lblText.parentAspect := 0;
	self.lblText.left := stdGap;
	self.lblText.width := self.clientWidth - ( stdGap * 2);
	self.lblText.height := self.lblText.getTextHeightForWidth(lblText.caption, self.lblText.width.Integer ) + 2;
	
	self.lblOpt1.fontSize := stdFontSize;
	self.lblOpt2.fontSize := stdFontSize;
	self.lblOpt3.fontSize := stdFontSize;
	self.lblOpt4.fontSize := stdFontSize;
	
//	self.opt1.top := 2;
	self.opt1.top := self.lblText.top +  self.lblText.height + stdGap;	//05 May 2016	NDL TFS 1936
	self.opt1.left := 2;
	self.opt1.width := self.opt1.height;
	
	lblLeft := self.opt1.width + self.opt1.left + 2;
	lblWidth := self.fraMain.width - lblLeft - 2;
	
	textHeightForWidth := self.getTextHeightForWidth(lblOpt1.caption, lblWidth.Integer );
	textHeight:= self.lblOpt1.getTextHeight(Dummy);
	lblHeight:=(textHeightForWidth + (textHeight * .75));
	
	self.lblOpt1.top := self.opt1.top + 1;
	self.lblOpt1.parentAspect := 0;
	self.lblOpt1.left := lblLeft;
	self.lblOpt1.width := lblWidth;
	self.lblOpt1.height := lblHeight;
	
	lastUsed := self.lblOpt1.top + self.lblOpt1.height + stdGap;
	
	if self.lblOpt2.caption.trimBlanks &lt;&gt; null then
	
		textHeightForWidth := self.getTextHeightForWidth(lblOpt2.caption, lblWidth.Integer );
		lblHeight:=(textHeightForWidth + (textHeight * .75));
		
		self.opt2.top := lastUsed;
		self.opt2.left := self.opt1.left;
		self.opt2.width := self.opt1.width;
		
		self.lblOpt2.top := self.opt2.top + 1;
		self.lblOpt2.parentAspect := 0;
		self.lblOpt2.left := lblLeft;
		self.lblOpt2.width := lblWidth;
		self.lblOpt2.height := lblHeight;
		
		lastUsed := self.lblOpt2.top + self.lblOpt2.height + stdGap;
	
	else
		self.opt2.visible := false;
		self.lblOpt2.visible := false;
		
	endif;
	
	if self.lblOpt3.caption.trimBlanks &lt;&gt; null then
	
		textHeightForWidth := self.getTextHeightForWidth(lblOpt3.caption, lblWidth.Integer );
		lblHeight:=(textHeightForWidth + (textHeight * .75));
		
		self.opt3.top := lastUsed;
		self.opt3.left := self.opt1.left;
		self.opt3.width := self.opt1.width;
		
		self.lblOpt3.top := self.opt3.top + 1;
		self.lblOpt3.parentAspect := 0;
		self.lblOpt3.left := lblLeft;
		self.lblOpt3.width := lblWidth;
		self.lblOpt3.height := lblHeight;
		
		lastUsed := self.lblOpt3.top + self.lblOpt3.height + stdGap;
	
	else
		self.opt3.visible := false;
		self.lblOpt3.visible := false;
		
	endif;
	
	if self.lblOpt4.caption.trimBlanks &lt;&gt; null then
	
		textHeightForWidth := self.getTextHeightForWidth(lblOpt4.caption, lblWidth.Integer );
		lblHeight:=(textHeightForWidth + (textHeight * .75));
		
		self.opt4.top := lastUsed;
		self.opt4.left := self.opt1.left;
		self.opt4.width := self.opt1.width;
		
		self.lblOpt4.top := self.opt4.top + 1;
		self.lblOpt4.parentAspect := 0;
		self.lblOpt4.left := lblLeft;
		self.lblOpt4.width := lblWidth;
		self.lblOpt4.height := lblHeight;
		
		lastUsed := self.lblOpt4.top + self.lblOpt4.height + stdGap;
	
	else
		self.opt4.visible := false;
		self.lblOpt4.visible := false;
		
	endif;
	
	frmHeight := lastUsed + btnDialog1.height + stdGap;

	// PAR #33170 - Changed order to ensure form is resized before the frame height is set
	self.clientHeight:=(frmHeight + stdGap).Integer;
	fraMain.height:=frmHeight;
	

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setOptions" id="fb300b28-e81b-4d57-9e36-a3abd3a85c91">
        <updating/>
        <source>setOptions(_message1: String; _message2: String; _message3: String; _message4: String; _defaultOpt : Integer; _title: String) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
26 August 2010	cnwndl1	Initial creation

*/

vars

begin

	self.lblOpt1.caption :=	_message1;
	self.lblOpt2.caption :=	_message2;
	self.lblOpt3.caption :=	_message3;
	self.lblOpt4.caption :=	_message4;
	
	if _defaultOpt = 1 then
		self.opt1.value := true;
	elseif _defaultOpt = 2 then
		self.opt2.value := true;
	elseif _defaultOpt = 3 then
		self.opt3.value := true;
	elseif _defaultOpt = 4 then
		self.opt4.value := true;
	endif;
	
	self.aTitle :=	_title;

epilog

end;</source>
        <Parameter name="_message1" type="String"/>
        <Parameter name="_message2" type="String"/>
        <Parameter name="_message3" type="String"/>
        <Parameter name="_message4" type="String"/>
        <Parameter name="_defaultOpt" type="Integer"/>
        <Parameter name="_title" type="String"/>
    </JadeMethod>
    <JadeMethod name="setupFormLayout" id="b5a16a34-d2fb-4522-95fd-f993ed6b1634">
        <updating/>
        <source>setupFormLayout() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
26 August 2010	cnwndl1	Initial creation

*/

vars

begin

	

//	self.lblText.visible := false;	//05 May 2016	NDL	TFS 1936 
	self.aIsKeyStrokeReceived :=	false;
	//05 May 2016	NDL	TFS 1936 
	if self.aTitle.length &lt; 25 then
		self.caption :=	self.aTitle;
	else
		self.caption  := app.getErrorString(Select_option);
		self.lblText.caption := self.aTitle;
	endif;

	btnDialog1.caption := app.getErrorString(CM_OK);
	btnDialog2.visible := false;
	btnDialog3.visible := false;

	btnDialog1.setFocus();

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="translateForm" id="1bf159e2-1fe8-4693-ac2a-fbf600203880">
        <updating/>
        <source>translateForm(locale : CM_Locale) updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	
begin
	// Determine the locale for translations.
	inheritMethod(locale);
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0017603, locale);
//	lblOpt1.translateCaption(Xlat_0015229, locale);
//	lblOpt2.translateCaption(Xlat_0015230, locale);
//	lblOpt3.translateCaption(Xlat_0015231, locale);
//	lblOpt4.translateCaption(Xlat_0015232, locale);
end;</source>
        <Parameter name="locale" type="CM_Locale"/>
    </JadeMethod>
</GUIClass>
