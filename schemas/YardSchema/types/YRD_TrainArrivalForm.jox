    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <ImplicitInverseRef name="chkRunArrivTasks" id="c52df57f-78f3-4531-879f-4938f5c63e86">
        <embedded/>
        <type name="CMUI_CheckBox"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="chkRunEDIProc" id="4c715be2-936e-45eb-b77f-52318379340d">
        <embedded/>
        <type name="CMUI_CheckBox"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="lblTrainArrival" id="0ffe227f-5a2a-41d3-98d3-5b261c5bd850">
        <embedded/>
        <type name="CMUI_Label"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="mskTrainArrDT" id="5d16fb44-6680-4f84-9fd6-cc5178927415">
        <embedded/>
        <type name="CMUI_DateMask"/>
    </ImplicitInverseRef>
