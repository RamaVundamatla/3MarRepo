    <JadeMethod name="cancelJob" id="4d7d2977-8585-43e8-8e92-560b3f3efee8">
        <updating/>
        <source>cancelJob() updating;
begin
	if workerProcess &lt;&gt; null then
		system.interruptUser(node, workerProcess);
	endif;

	endNotificationForSubscriber(self);
	progressDialog.showProgress("Cancel pending...", "", "");
	logMsg("[Dump Journals cancelled by user]");

	while app.isValidObject(workerProcess) do
		app.doWindowEvents(1000); // Wait a second, but allow another cancel to be pressed
	endwhile;
	
	jdFinish();
end;
</source>
    </JadeMethod>
    <JadeMethod name="closeProgressDialog" id="ed3acc57-c944-4e10-8164-c0e51c8419e5">
        <updating/>
        <source>closeProgressDialog() updating;

vars

begin
	progressDialog.unloadForm;
	delete progressDialog;
	progressDialog := null;

end;
</source>
    </JadeMethod>
    <JadeMethod name="dumpJournals" id="317af20d-1c82-4be3-8def-88fa5e40d3fa">
        <updating/>
        <source>dumpJournals(path : String; outputFileName : String; startJournal : Integer; endJournal : Integer; startTime, endTime : TimeStamp) updating;
vars
begin

	jdInit();

	beginTransientTransaction;
	create job sharedTransient;
	job.fileName := outputFileName;
	job.journalPath := path;
	job.startJournal := startJournal;
	job.endJournal := endJournal;
	if startTime &lt;&gt; null then
		logMsg("Set filter range: " &amp; startTime.String &amp; " - " &amp; endTime.String);
		job.filterStartTime := startTime;
		job.filterEndTime := endTime;
	endif;
	commitTransientTransaction;
	workerProcess := app.startAppMethod(currentSchema.name, app.name, "dumpJournals", job, false);
	if workerProcess = null then
		logMsg("*** " &amp; app.name &amp; "::" &amp; "dumpJournals initiation FAILED ***");
	else
		logMsg("[" &amp;app.name &amp; "::" &amp; "dumpJournals initiated]");
		beginNotification(workerProcess, AAControl.JobCompletedEvent, Response_Continuous, JobCompleted);
		beginNotification(workerProcess, AAControl.JobAbortedEvent, Response_Continuous, JobAborted);
		beginNotification(workerProcess, AAControl.StartJournalEvent, Response_Continuous, JournalStart);
		beginNotification(workerProcess, AAControl.MissingJournalEvent, Response_Continuous, JournalMissing);
	endif;

end;</source>
        <Parameter name="path" type="String"/>
        <Parameter name="outputFileName" type="String"/>
        <Parameter name="startJournal" type="Integer"/>
        <Parameter name="endJournal" type="Integer"/>
        <Parameter name="startTime" type="TimeStamp"/>
        <Parameter name="endTime" type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="jdFinish" id="cdf05148-0f7c-49c4-8035-b3c7d9abe9b0">
        <updating/>
        <source>jdFinish() updating;
begin

	endNotificationForSubscriber(self);
	closeProgressDialog();

	beginTransientTransaction;
	delete job;
	commitTransientTransaction;

end;</source>
    </JadeMethod>
    <JadeMethod name="jdInit" id="f589bc39-b77d-4a6f-961a-d6e672de96b5">
        <updating/>
        <source>jdInit() updating;
begin

	showProgressDialog();

end;</source>
    </JadeMethod>
    <JadeMethod name="logMsg" id="10837342-1c73-40da-81b7-434e59d81309">
        <source>logMsg(msg : String);
vars
	t 	: Time;
	txt	: String;
	idx : Integer;
begin

	// If text getting too big, cut it back
	while txtLog.text.length &gt; 20000 do
		txt := txtLog.text;
		idx := txt.pos(Cr&amp;Lf, 1);
		txtLog.text := txtLog.text[idx+2:end];
	endwhile;

	if txtLog.text.length &gt; 0 then
		txtLog.text := txtLog.text &amp; CrLf;
	endif;
	txtLog.text := txtLog.text &amp; t.String &amp; "&gt; " &amp; msg;

	txtLog.scrollVertPos := Max_Integer; // show end of text

end;
</source>
        <Parameter name="msg" type="String"/>
    </JadeMethod>
    <JadeMethod name="mnuClear_click" id="2c33a352-b39f-455a-b903-6f386c512bb3">
        <controlMethod name="MenuItem::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mnuClear_click(menuItem: MenuItem input) updating;

vars

begin
	txtLog.text := null;
end;
</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="mnuDumpJournals_click" id="0b0fee0e-74dc-44f7-9810-7164951122e9">
        <controlMethod name="MenuItem::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mnuDumpJournals_click(menuItem: MenuItem input) updating;
vars
	dialog 			: AAParamDialog;
	path			: String;
	startJournal	: Integer;
	endJournal		: Integer;
	startTime		: TimeStamp;
	endTime			: TimeStamp;
	fileName 		: String;
	result			: Integer;
begin

	create dialog;
	result := dialog.showModal;
	
	if result = 1 then
		path := dialog.journalDirectory;
		fileName := dialog.outputFileName;
		startJournal := dialog.startJournal;
		endJournal := dialog.endJournal;
		startTime := dialog.filterStartTime;
		endTime := dialog.filterEndTime;
		dumpJournals(path, fileName, startJournal, endJournal, startTime, endTime);
	endif;
	
epilog
	delete dialog;
end;
</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
