    <JadeMethod name="makeArrCarrSectXML" id="a93f5907-83f7-48ea-a2d2-309dc898a7c5">
        <source>makeArrCarrSectXML( _ti : CM_TrackedItem; _voyage : CM_Voyage; _parentElem : JadeXMLElement input ) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 August 2016	cnwndl1	Initial creation	TFS 2561 / 2277

*/

vars

	rootElem : JadeXMLElement;
	xmlElem : JadeXMLElement;
	voyage : CM_Voyage;
	
begin

	rootElem := _parentElem.addElement('ArrivalCarrier');
	
	if _ti &lt;&gt; null then
	
		self.makeArrCarrTypeSubSectXML( _ti, rootElem );
		
		self.makeArrCarrTruckSubSectXML( _ti, rootElem );
		
		voyage := _ti.myImportVoyage;
	
	elseif _voyage &lt;&gt; null then
	
		voyage := _voyage;
		
	endif;
	
	if voyage &lt;&gt; null then
	
		self.makeArrCarrVesselSubSectXML( _ti, voyage, rootElem );
	
	endif;
	
	
epilog

end;</source>
