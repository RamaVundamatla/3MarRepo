    <JadeMethod name="commentsShowHideControls" id="b630d6a5-27b6-4958-a8a9-7e3f1c43964f">
        <source>commentsShowHideControls(_show :Boolean)protected;
// ---------------------------------------------------------------------------
// Created:     07 March 2011 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	self.frmComments.visible	:= _show;
	
	self.btnPrint.enabled		:= not _show;
	self.btnExportCSVQE.enabled	:= not _show;
	self.btnQuery.enabled		:= not _show;
	self.btnResetSearch.enabled	:= not _show;
	self.btnRefresh.enabled		:= not _show;
	self.btnSelectAll.enabled	:= not _show;
	self.btnComment.enabled		:= not _show;
	
	self.cmbTerminalArea.enabled	:= not _show;
	self.txtQDateStart.enabled		:= not _show;
	self.txtQDateEnd.enabled		:= not _show;
	self.tblData.enabled			:= not _show;
	
	self.txtComment.text	:= null;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_show" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="create" id="65c128bd-c76d-405c-89b4-2c81b72365b6">
        <updating/>
        <source>create() updating;
// ---------------------------------------------------------------------------
// Created:     07 March 2011 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	self.permissionView		:= PmAdmAuditTALocationView;
	self.permissionMaint	:= PmAdmAuditTALocationMaint; // TFS 2198
	
	self.daysToGoBack		:= 7;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doAddComments" id="b5cb42df-9204-4a4a-af72-b97e54ff2c49">
        <source>doAddComments()protected;
// ---------------------------------------------------------------------------
// Created:     07 March 2011 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	audit	:CM_AuditTALocations;
begin
	// show comments for the selected audit - there may be &gt; 1 selecetd but we
	// will take bulk edit approach
	audit := self.tblData.accessRow (tblData.row).itemObject.CM_AuditTALocations;
	
	self.commentsShowHideControls (true);

	if audit &lt;&gt; null then
		self.txtComment.text := audit.remarks;
	endif;

	self.frmComments.zOrder(1);
	self.txtComment.setFocus;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
