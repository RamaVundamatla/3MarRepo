        <source>setFileName(_filename : String) updating;
/* 
---------------------------------------------------------------------------
 Created:     J Harliwich               

 Purpose:     MES1011

 Parameters:  None

 Returns:     Nothing

 Changed On   Changed By  Reason
 ----------   ----------  --------------------------------------------------
//27 Oct 2015	cnwrs1	Par37082 special file name longer than 30 chars
