		_stateInfo.guiState	:= self.Error;
		return false;
	endif;
	
	self.setMediatorState(self.LoggedOn_Reset);
	_stateInfo.guiState := self.LoggedOn_Reset;
	
	return true;
end;</source>
        <Parameter name="_dtoColors" type="DTO_Colours" usage="input"/>
        <Parameter name="_stateInfo" type="DTO_StateInfo" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setdown" id="b649ed86-eb34-48e1-abb8-e7e416ca73e5">
        <updating/>
        <source>setdown(_setDownLocation : String; _tandemTIid : String; _dto : DTO_EnquiryGradingTasks input; _stateInfo : DTO_StateInfo input) : Boolean updating;
// -------------------------------------------
