    <JadeMethod name="isCMIFDataMatch" id="acf31847-d6ec-4e83-baf6-9b34f8649b09">
        <source>isCMIFDataMatch(_cmifAutoPlan: CMIF_YAAutoPlan; _yaData: CM_YADataInteger): Boolean;
// -------------------------------------------
// Created 27 May 2005 by cnwdvb1
