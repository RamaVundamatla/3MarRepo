    <JadeMethod name="doesRequireSnapShot" id="edf78b5c-5af1-4a4c-a812-c649c9149811">
        <methodInvocation>mapping</methodInvocation>
        <source>doesRequireSnapShot(set: Boolean; _value: Boolean io) mapping;
/*
Purpose:	TFS 40336		
Date				Who			Reason
SEPTEMBER 2018		CNWAB1		Initial creation
*/
vars

begin
	if set then
		app.raiseSetVirtualError(class.name, method.name);
	else
		_value := true;
	endif;

end;</source>
