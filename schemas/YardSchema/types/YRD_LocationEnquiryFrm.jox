    <JadeMethod name="doMenuCargoPackClick" id="df312483-0e99-466d-bbda-2f6c4d92be3c">
        <source>doMenuCargoPackClick();
//----------------------------------------------------------------
//	Created:	14 August 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------

vars

	lPackUnpack	: YRD_PackUnpack;
	anObject	: Object;
	theTI 		: CM_Container;
	frm			: Form;
begin
	anObject := self.myCurrentObject;
	if anObject = null then 
		return;
	endif;
	
	if not anObject.isKindOf(CM_Container) then
		return;
	endif;
	
	theTI := anObject.CM_Container;
	lPackUnpack := app.loadForm(YRD_PackUnpack,
								CMUI_Assistant,
								false,
								false,
								false,
								self.myTerminal,
								null).YRD_PackUnpack;
								
	//create lPackUnpack;
	//lPackUnpack.centreWindow;
	lPackUnpack.myTI := theTI;
	lPackUnpack.setMyTerminal(self.myTerminal);
//	lPackUnpack.myTerminalArea := self.myCurrentTerminalArea;
	lPackUnpack.show;



end;</source>
    </JadeMethod>
    <JadeMethod name="doMnuAreaFullClick" id="48d6986e-03d7-4643-928d-527ff69b9496">
        <updating/>
        <source>doMnuAreaFullClick(menuItem: MenuItem input) updating;
//----------------------------------------------------------------
//	Created:	19 November 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	result	: Integer;
	isFull	: Boolean;
begin
	inheritMethod(menuItem);

	if self.filterTerminalArea = null then
		return;
	endif;

	if (not self.filterTerminalArea.isKindOf(CM_BlockStack)) then
		return;			
	endif;

	//if its not checked - we must be setting it to full so...
	isFull := not menuItem.checked;

	self.sharedLock(self.filterTerminalArea);

	while true do
		app.myTrxUA.trxUpdateBlockstackFull(self.filterTerminalArea.CM_BlockStack, isFull, app.myPassport);
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			break;
		else
			result := app.showErrorWarningDialog('Change Block Stack Full flag.', app.myPassport, ErrWarnMode_Update + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
		endif;
		break;
	endwhile;

epilog
	self.unlock(self.filterTerminalArea);		
end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
