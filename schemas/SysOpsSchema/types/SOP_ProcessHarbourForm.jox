    <JadeMethod name="doDelete" id="ec448015-ccdd-4d88-b727-d0e1efc9a6af">
        <source>doDelete();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 May 2018	jlgndl1	Initial creation	TFS 38560

*/

vars

	harbour : HMS_Harbour;
	processHarbour : CM_ProcessHarbour;
	obj: CM_Object;

begin

	harbour := self.cmbHarbour.listObject.HMS_Harbour;

	if harbour &lt;&gt; null then
		processHarbour := self.myVoyageProcess.allProcessHarbours.getAtKey( self.myVoyageProcess, harbour );
	endif;
	
	if processHarbour &lt;&gt; null then
		obj := processHarbour;
		app.myTrxDA.trxDeleteCMObject( obj, app.myPassport );
	endif;
	
	self.populateCombos( harbour );

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doUpdate" id="6eb24aec-0910-42d2-8025-5a2fd22c5d4f">
        <source>doUpdate();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17/05/2018	jlgndl1	Initial creation	TFS 38560
27/08/2018	jlgdap1	TFS 40488 PEL1 Resources for Shift Movements
17/09/2018	jlgdap1	TFS 40488 PEL1 Resources for Shift Movements
14 Nov 2018	NDL	TFS 41980 - remove bunches of controls no longer used...
*/

vars

	harbour : HMS_Harbour;
	processHarbour : CM_ProcessHarbour;
	proxy : CM_ProcessHarbour;
	load : Boolean;
	add : Boolean;
	result : Integer;
	shiftResources : HMS_ResourceByTypeDict;			// TFS 40488
	obj : Object;										// TFS 40488
	resource : HMS_Resource;							// TFS 40488
	equipResources : HMS_ResourceTypeByCodeDict;	//23 Nov 2018	NDL	TFS 41980
	extensionResources : HMS_ResourceByTypeDict;	//18 Feb 2019	NDL	TFS 43374

begin

	harbour := self.cmbHarbour.listObject.HMS_Harbour;
	if harbour = null then
		app.msgBox( app.getErrorString(Must_select_harbour), app.getErrorString(Error), MsgBox_OK_Only );
		return;
	endif;
	
	if self.myVoyageProcess = null then
		app.msgBox( app.getErrorString(Voyage_process_selected), app.getErrorString(Error), MsgBox_OK_Only );
		return;
	endif;
	
	create shiftResources transient;								// TFS 40488
	self.lstShiftResources.getSelected(shiftResources);				// TFS 40488
	
	//18 Feb 2019	NDL	TFS 43374
	create extensionResources transient;
	self.lstExtResources.getSelected(extensionResources);
	
	//23 Nov 2018	NDL	TFS 41980
	create equipResources transient;
	self.lstEquipResources.getSelected(equipResources);	
	
	if self.cmbResForWater = null
	and shiftResources.isEmpty
	and equipResources.isEmpty 	//23 Nov 2018	NDL	TFS 41980
	and extensionResources.isEmpty	//18 Feb 2019	NDL	TFS 43374
	then
		app.msgBox( app.getErrorString(Resources_selected), app.getErrorString(Error), MsgBox_OK_Only );
		return;
	endif;
	
	processHarbour := self.myVoyageProcess.allProcessHarbours.getAtKey( self.myVoyageProcess, harbour );
	if processHarbour = null then
		add := true;
		create proxy transient;
		proxy.setProxyKeys(	harbour,	//_myHarbour : HMS_Harbour;
							self.myVoyageProcess	//_myVoyageProcess : CM_VoyageProcess
							);
	else
		app.cmsBeginLoad(load);
		proxy := processHarbour.pxyCreateUpdateProxy();
		app.cmsEndLoad(load);
	endif;
	
	
	
	proxy.setProxyData(	self.cmbResForWater.listObject.HMS_ResourceType,//_myHMSResourceForWater : HMS_ResourceType
						shiftResources,									//_allHMSResourcesForShift : HMS_ResourceByTypeDict	// TFS 40488
						equipResources,	//_allHMSResourcesForEquip : HMS_ResourceByTypeDict		//23 Nov 2018	NDL	TFS 41980	
						extensionResources,	//_allHMSResourcesForExt : HMS_ResourceByTypeDict	//18 Feb 2019	NDL	TFS 43374
						self.cmbResBillAdj.listObject.HMS_Resource // TFS 42241
						);
							
	while true do
		if add then
			app.myTrxCA.trxCreateProcessHarbour( proxy, processHarbour, app.myPassport );
		else
			app.myTrxUA.trxUpdateProcessHarbour( proxy, app.myPassport );
		endif;
	
		if not app.myPassport.trxCompletedOK then
			result := app.showErrorWarningDialog("Process Harbour", app.myPassport, ErrWarnMode_AddUpdate);
			if app.myPassport.noErrors and result = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		break;
		
	endwhile;
	
	self.populateCombos( harbour );
	self.setupResources(harbour);					// TFS 40488

epilog

	app.cmsEndLoad(load);
	delete proxy;
	delete shiftResources;							// TFS 40488
end;</source>
    </JadeMethod>
    <JadeMethod name="populateCmbHarbours" id="b2e149c4-a3b4-41cd-80b8-e282ee829189">
        <source>populateCmbHarbours();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 May 2018	jlgndl1	Initial creation	TFS 38560

*/

vars

begin

	self.cmbHarbour.clear();
	
	self.cmbHarbour.listCollection( app.myRoot.allHarbours, true, 0 );
	
	self.populateCombos( null );
	self.populateComboExtension( null); // TFS 42241
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="populateComboExtension" id="b616e801-ef39-4358-994d-3676dff3b630">
        <source>populateComboExtension( _harbour : HMS_Harbour );
/*
Purpose:	TFS 42241		
Date				Who			Reason
NOVEMBER 2018		CNWAB1		Initial creation
*/

vars

	allResources : HMS_ResourcesByCodeDict;
	resource : HMS_Resource;
	iter : Iterator;
	resourceStr : String;
	
	resourceType : HMS_ResourceType;
	resourceTypeStr : String;
	
	processHarbour : CM_ProcessHarbour;

begin

	self.cmbResBillAdj.clear();
	
	if _harbour = null then
		return;
	else
		
		iter := _harbour.allResources.createIterator;
		while iter.next( resource ) do
			if resource.myResourceType &lt;&gt; null then
				resourceStr := resource.description &amp; " (" &amp; resource.myResourceType.code &amp; ")";
			else
				resourceStr := resource.description;
			endif;
				self.cmbResBillAdj.itemObject[ self.cmbResBillAdj.addItem( resourceStr ) ] := resource;
			
		endwhile;
		delete iter;
		
		processHarbour := self.myVoyageProcess.allProcessHarbours.getAtKey( self.myVoyageProcess, _harbour );
		
		if processHarbour &lt;&gt; null then
			if processHarbour.myHMSResourceForExtension &lt;&gt; null then
				self.cmbResBillAdj.listIndex := self.cmbResBillAdj.findObject( processHarbour.myHMSResourceForExtension );
			endif;
		endif;
		
	endif;

epilog

	delete iter;

end;</source>
        <Parameter name="_harbour" type="HMS_Harbour"/>
    </JadeMethod>
    <JadeMethod name="populateCombos" id="0741f344-3089-472d-a22f-792ab1089bb6">
        <source>populateCombos( _harbour : HMS_Harbour );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17/05/2018	jlgndl1	Initial creation	TFS 38560
27/08/2018	jlgdap1	TFS 40488 PEL1 Resources for Shift Movements
//13 Nov 2018	NDL	TFS 41980 - Remove use of some local resource refs
*/

vars

	allResources : HMS_ResourcesByCodeDict;
	resource : HMS_Resource;
	iter : Iterator;
	resourceStr : String;
	
	resourceType : HMS_ResourceType;
	resourceTypeStr : String;
	
	processHarbour : CM_ProcessHarbour;

begin

	self.cmbResForWater.clear();
	
	if _harbour = null then
		self.btnDelete.visible := false;
		self.btnUpdate.visible := false;
		return;
		
	else
		self.btnDelete.visible := true;
		self.btnUpdate.visible := true;
		
		self.btnDelete.enabled := false;
		self.btnUpdate.enabled := false;
		
		iter := app.myRoot.allResourceTypes.createIterator;
		while iter.next( resourceType ) do
			if resourceType.hasResourceForHarbour(_harbour) then
				resourceTypeStr := self.myAssistant.displayEntryHMSResourceType( resourceType );
				self.cmbResForWater.itemObject[ self.cmbResForWater.addItem( resourceTypeStr ) ] := resourceType;
			endif;
		endwhile;
		delete iter;
		
		processHarbour := self.myVoyageProcess.allProcessHarbours.getAtKey( self.myVoyageProcess, _harbour );
		
		if processHarbour &lt;&gt; null then
			if processHarbour.myHMSResourceForWater &lt;&gt; null then
				self.cmbResForWater.listIndex := self.cmbResForWater.findObject( processHarbour.myHMSResourceForWater );
			endif;
			
			self.btnDelete.enabled := allowUpdate;
			
		endif;
		
		self.btnUpdate.enabled := allowUpdate;
	
	endif;

epilog

	delete iter;

end;</source>
        <Parameter name="_harbour" type="HMS_Harbour"/>
    </JadeMethod>
    <JadeMethod name="setMyVoyageProcess" id="b322e8d3-37ff-4acb-ba12-3f81cce6ecfe">
