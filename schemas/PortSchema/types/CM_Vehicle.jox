    <JadeMethod name="getMatchingCargoOnBoard" id="e863eac4-a39f-4603-b43e-f4eba3d2f844">
        <source>getMatchingCargoOnBoard( _cargoType : CM_CargoType; _id : String ):CM_Cargo;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 August 2018	jlgndl1	Initial creation	TFS 39769

*/

vars

	ti : CM_TrackedItem;

begin

	if not _cargoType.allowDuplicates then
		return null;
	endif;

	foreach ti in self.locationsController.allTrackedItems discreteLock do
		if ti.id = _id and ti.myCargoType = _cargoType then
			return ti.CM_Cargo;
		endif;
	endforeach;
	
	return null;

epilog

end;</source>
        <Parameter name="_cargoType" type="CM_CargoType"/>
        <Parameter name="_id" type="String"/>
        <ReturnType type="CM_Cargo"/>
    </JadeMethod>
    <JadeMethod name="getMeasurementStringForAttrib" id="8fb7a7ca-cf10-4308-bc8b-0cdaebda96c6">
        <source>getMeasurementStringForAttrib(_attrName: String; _measureType: String; _short: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 March 2014	cnwndl1	Initial creation

*/

vars

begin

	if _attrName = ETRow_TareKilos then
		return app.convertMeasurementForDisplay(_measureType, self.tareKilos);
	elseif _attrName = ETRow_MaxGrossLadenWeight then
		return app.convertMeasurementForDisplay(_measureType, self.maxGrossLadenWeight);
	endif;
	
	return inheritMethod(_attrName, _measureType, _short);

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_measureType" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
