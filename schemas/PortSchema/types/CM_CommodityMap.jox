    <JadeMethod name="replaceInvoiceLineTypes" id="c3a252d8-6538-4c99-a884-26d59a19a535">
        <source>replaceInvoiceLineTypes(_oldILD : CM_InvoiceLineDesc; _newILD : CM_InvoiceLineDesc) : Integer;
// 32311
vars
	count	: Integer;
	broker		: CM_TransServiceBroker;
	moveMap		: CM_MoveServiceBroker;
begin
	foreach broker in self.allTransServiceBrokersByType do
		count := count + broker.replaceInvoiceLineTypes(_oldILD, _newILD);
	endforeach;
	foreach moveMap in self.moveMap do
		count := count + moveMap.replaceInvoiceLineTypes(_oldILD, _newILD);
	endforeach;

	return count;
end;
</source>
        <Parameter name="_oldILD" type="CM_InvoiceLineDesc"/>
        <Parameter name="_newILD" type="CM_InvoiceLineDesc"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setCommodityCode" id="446b86d5-0d69-4249-816d-cdab9f531fad">
        <updating/>
        <source>setCommodityCode(_newCode : String) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 06/12/2018	jlgdap1		Initial creation TFS 42083 PEL1 Cargo Transaction Map - Commodity update
