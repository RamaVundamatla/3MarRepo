    <JadeMethod name="displayTable" id="fa9fe3e7-717c-4f8b-91b2-59709c042e1c">
        <updating/>
        <source>displayTable() updating;
// ---------------------------------------------------------------------------
// Created:		September  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//17 Oct 2017	cnwma1  TFS #7431 JMT - Refactoring - Drawing Attributes Labels
// ---------------------------------------------------------------------------

vars
	aDrawingAttribute :	CM_DrawingAttribute;
	idx : Integer;
	aControl : ComboBox; //Control;
	theCode : String;
begin
/*
beginTransaction;
aDrawingAttribute := app.myRoot.allDrawingAttributes["PicTACrane"];
if aDrawingAttribute &lt;&gt; null then
	delete aDrawingAttribute;
	write "YES";
endif;
commitTransaction;
*/
	foreach aDrawingAttribute in app.myRoot.allDrawingAttributes do
		
		theCode := aDrawingAttribute.code;
		if (theCode[1:15].toUpper = "PICTICARGOTYPE_" and theCode.length &gt; 15)
		or theCode[1:10].toUpper = "CARGOTYPE_" 
		or theCode[1:12].toUpper = "HAZARDCLASS_" // JLGAB1 16/10/17
		or theCode[1:12].toUpper = "SPECIALSTOW_" then // JLGAB1 16/10/17
		
		if (theCode[1:15].toUpper = "PICTICARGOTYPE_" and theCode.length &gt; 15) then
			//write theCode;
		endif;
			continue;//draw attr for system cargo type, special stows
		endif;
		
		//theCode := aDrawingAttribute.getLabel();  //17.10.2017	cnwma1  TFS #7431
		theCode := aDrawingAttribute.label;         //17.10.2017	cnwma1  TFS #7431
	
		idx := self.tblAttributes.addItem(theCode &amp; Tab &amp; 
														aDrawingAttribute.code &amp; Tab &amp; // JLGAB1 16/10/17
														aDrawingAttribute.fontName 	&amp; Tab &amp; 
														aDrawingAttribute.fontCharacter.Character &amp; Tab &amp; 
														aDrawingAttribute.fontCharacter.String &amp; Tab 
													//	aDrawingAttribute.fontCharacter.String
														); 

//write theCode;		
		self.tblAttributes.accessCell(idx,Col_Character).fontName := aDrawingAttribute.fontName;
		self.tblAttributes.accessCell(idx,Col_Character).fontSize := 12;
		self.tblAttributes.accessCell(idx,Col_Character).foreColor := aDrawingAttribute.colour;
		self.tblAttributes.accessCell(idx,Col_Character).text := aDrawingAttribute.fontCharacter.Character;
		self.tblAttributes.accessCell(idx,Col_Colour).backColor := aDrawingAttribute.colour;
		self.tblAttributes.accessCell(idx,Col_Colour).foreColor := aDrawingAttribute.colour.getInverseColour;
		self.tblAttributes.accessRow(idx).itemObject := aDrawingAttribute;
		self.tblAttributes.userInputEnabled := false;// JLGAB1 16/10/17
// JLGAB1 16/10/17		self.tblAttributes.accessCell(idx,Col_Attribute).inputType := Table.InputType_TextBox;
		
		aControl := self.cmbFont.getControl(idx);
		if aControl = null then
			aControl := self.cmbFont.loadControl(idx).ComboBox;
		endif;
		self.doBuildCmbFont(aControl);
		self.tblAttributes.accessCell(idx,Col_Font).cellControl := aControl;
		aControl.text := aDrawingAttribute.fontName.trimBlanks;
		
		aControl := self.cmbCharacter.getControl(idx);
		if aControl = null then
			aControl := self.cmbCharacter.loadControl(idx).ComboBox;
		endif;
		self.doBuildCmbCharacter(aControl,aDrawingAttribute.fontName);
		self.tblAttributes.accessCell(idx,Col_Character).cellControl := aControl;
		aControl.text := aDrawingAttribute.fontCharacter.Character;
		

		aControl.listIndex := aDrawingAttribute.fontCharacter;

	endforeach;
	
	// JLGAB1 16/10/17 this table sort was in INITTABLE. Moved it here because the IDX in the code above ended up with some 
	// JLGAB1 16/10/17 lines sharing the same combo box
	
	self.tblAttributes.sortColumn[self.Col_Attribute] := 1;
	self.tblAttributes.sortAsc[self.Col_Attribute] := true;
	self.tblAttributes.sortCased[self.Col_Attribute] := true;
	self.tblAttributes.doResort();
	
end;</source>
    </JadeMethod>
