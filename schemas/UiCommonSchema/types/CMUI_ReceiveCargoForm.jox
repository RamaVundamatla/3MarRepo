    <JadeMethod name="onBOLNumberChange" id="30a247c8-64bc-4941-8acb-4ce471f31411">
        <updating/>
        <source>onBOLNumberChange(_id: String): Boolean updating, protected;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21/01/2010	cnwjre1 copied from onBookingRefChange
04/02/2010	cnwjre1	picker code added
*/

vars
	bolFound : Boolean;
	bolDetail : CM_BOLDtl;
begin
	// if the BOL number field is disabled, don't bother doing anything here
	if not txtBOLNumber.enabled then
		return false;
	endif;
	// if an edit, stop the picker showing at either the start or on cancel
	if self.updateMode = self.Mode_Update then
		if app.activeControl = btnSave or
		   app.activeControl = btnCancel then
			return false;
		endif;
	endif;
	
	// Stop the picker popping up when the bol number hasn't changed
	if self.myBOLDtl &lt;&gt; null and self.myBOLDtl.myBOL.number = self.txtBOLNumber.getString() then
		
		// combo may not be loaded at start?
		if self.myBOLDtl &lt;&gt; null and self.cmbBOLItem.getEmbeddedControl.CMUI_FieldComboBoxControl.listIndex = -1 then
			self.doLoadBOLItems(self.myBOLDtl);
		endif;
		return false;
	endif;
	
	if _id  &lt;&gt; null then
		self.myBOLDtl := self.myAssistant.getBOLInDetailFromNumber(BOLType_GeneralBillOfLading, _id);
		if self.myBOLDtl = null then
			return false;
		else
			self.myBOL := self.myBOLDtl.myBOL;
			self.doLoadBOLItems(self.myBOLDtl);
			self.setFieldsFromBOLDetail();
			self.onCargoTypeChange;
			self.setBOLDimensionDetails();					// 11/01/2011 cnwmh5 #26710
			return true;
		endif;
		/* pre-picker code
		self.myBOL := self.myTerminal.getBOLInByNumber(_id, BOLType_GeneralBillOfLading);
		if self.myBOL = null then
			return false;
		else
			if self.myBOLDtl = null then
				self.myBOLDtl := self.myBOL.allBOLDtls.first;	// ** temp while no picker
			endif;
			self.doLoadBOLItems(self.myBOLDtl);
			self.setFieldsFromBOLDetail();
			self.onCargoTypeChange;
			return true;
		endif;
		*/
	else
		return false;
	endif;
	
	return bolFound; 
epilog
	app.mousePointer := MousePointer_Default;
end;</source>
        <access>protected</access>
        <Parameter name="_id" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="onBookingRefChange" id="92175bc4-4d46-4f64-a125-fee7a0fab34a">
        <updating/>
        <source>onBookingRefChange(_id: String): Boolean updating, protected;
/*
Date		Who		Reason
29/07/2009	cnwjk3	Initial creation
30/11/2009	cnwmh5	PAR 21687 - remove test for booking found, this test should not be
					enforced.  Will in a later release be configurable
08/03/2010	cnwdap1	PAR #22593 Set focus back to booking item field
*/
vars
	bookingFound : Boolean;
begin

	// if the booking reference field is disabled, don't bother doing anything here
	if not txtBookingRef.enabled then
		return false;
	endif;
	// 27727 Mar 2012 pre-notes don't use booking ref items and don't want to update the form from the booking ref
	// 		when it has already been populated from the pre-note
	if self.isPreNoteForm and self.updateMode = self.Mode_Update and self.myBookingRefItem = null then
		return false;
	endif;
	
	// Stop the picker popping up when the booking ref hasn't changed
	if self.myBookingRefItem &lt;&gt; null and self.myBookingRefItem.myBookingReference.bookingReference = self.txtBookingRef.getString() then
		// If coming from  flexigate New Item will not have loaded the combo yet
		if self.myBookingRefItem &lt;&gt; null and self.cmbBRItem.getEmbeddedControl.CMUI_FieldComboBoxControl.listIndex = -1 then
			self.doLoadBookingRefItems(self.myBookingRefItem);
		endif;
		return false;
	endif;
	
	bookingFound := inheritMethod(_id);
	
	if bookingFound then				//+cnwml2 PAR24460
		// PAR #22593 set focus on booking item combo 
		self.cmbBRItem.getEmbeddedControl.setFocus;
	endif;
	
	return bookingFound; 
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_id" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="onCargoGroupIDChange" id="42768db3-aa83-45da-84d5-d9cd32bfd450">
        <updating/>
        <source>onCargoGroupIDChange(_cargoGroupID : String) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 May 2022	jlier1	Initial creation 53515
30 Aug 2023	navrv30	ChangeRequest 59418: EUP - Cargo Group Creation -  Operator

*/

vars
	terminal : CM_Terminal;
	cargoGroup : CM_CargoGroup;
	msg : String;
	creatCargoGroup : CMUI_CargoGroupCreateFormModal;
	cargoGroupTypeCount : Integer;
	iter : Iterator;
	obj : Object;
begin

	terminal := self.myTerminal;
	if self.myTerminal = null then
		return;
	endif;
		
	if _cargoGroupID = null then
		return;
	endif;
	
	cargoGroup := self.myTerminal.getCargoGroupItem( _cargoGroupID ).CM_CargoGroup;
	if cargoGroup &lt;&gt; null and cargoGroup.id &lt;&gt; _cargoGroupID then
		cargoGroup := null;
	endif;
	
	if cargoGroup = null then
		cargoGroupTypeCount:=0;
		iter:=self.myTerminal.allCargoBOLTypes.createIterator;
		while iter.next(obj) do
			if not obj.isKindOf(CM_CargoType) then
				continue;
			endif;
			if obj.CM_CargoType.productType = ProductType_CargoGroup then
				cargoGroupTypeCount:=cargoGroupTypeCount+1;
			endif;
			if cargoGroupTypeCount &gt; 1 then
				break;
			endif;
		endwhile;
		if cargoGroupTypeCount = 1 then
			return;
		endif;
		msg := app.getErrorString1(Cargo_group_not_found_want_cre,_cargoGroupID);
		if app.msgBox( msg, app.getErrorString(Continue), MsgBox_Yes_No ) = MsgBox_Return_Yes then
			creatCargoGroup := app.loadForm(CMUI_CargoGroupCreateFormModal, CMUI_Assistant, false, false, true, self.myTerminal, null).CMUI_CargoGroupCreateFormModal;
			creatCargoGroup.setCargoGroupId( _cargoGroupID );
// ### TFS CR 59942 TASK 59943 08SEP2023 NAVAB1			if self.cmbOperatorCode.listObject &lt;&gt; null then   												//30.8.2023	navrv30	#59418
// ### TFS CR 59942 TASK 59943 08SEP2023 NAVAB1				creatCargoGroup.cmbGCOper.setObject( self.cmbOperatorCode.listObject );                     //30.8.2023	navrv30	#59418
			creatCargoGroup.passedOperator := self.cmbOperatorCode.listObject.CM_Operator;             //30.8.2023	navrv30	#59418
			creatCargoGroup.passedVoyage := self.cmbVoyageCode.listObject.CM_Voyage; // ### TFS CR 59942 TASK 59943 04SEP2023 NAVAB1
// ### TFS CR 59942 TASK 59943 08SEP2023 NAVAB1			endif;
			if   creatCargoGroup.showModal() = IDOK then
				cargoGroup:= creatCargoGroup.userObject.CM_CargoGroup;
				if cargoGroup &lt;&gt; null then
					self.txtCargoGroupID.userObject:=cargoGroup;
					self.txtCargoGroupID.setValue(cargoGroup.id);
				else
					self.txtCargoGroupID.setValue(null);
				endif;
				
				// ### TFS CR 59942 TASK 59943 04SEP2023 NAVAB1
				if creatCargoGroup.cmbGCOper.listObject &lt;&gt; null then
					if self.cmbOperatorCode.findObject(creatCargoGroup.cmbGCOper.listObject) &gt; 0 then
						self.cmbOperatorCode.listObject := creatCargoGroup.cmbGCOper.listObject;
					endif;
				endif;
			else
				self.txtCargoGroupID.setValue(null);
				
			endif;
		else	
			self.txtCargoGroupID.setValue(null);
		endif;
	else
		self.txtCargoGroupID.userObject:=cargoGroup;
	
	endif;

epilog
	delete iter;
end;</source>
        <access>protected</access>
        <Parameter name="_cargoGroupID" type="String"/>
    </JadeMethod>
    <JadeMethod name="onCargoIdChange" id="084f019c-a920-42cd-a73b-8f1f52bd00fc">
        <updating/>
        <source>onCargoIdChange(_id : String) updating, protected;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19/08/2009	cnwjk3	Initial creation
29/03/2010	cnwdap1	PAR #23261 set focus correctly when disabling Number of Items field
18/05/2010	cnwcs5	par 25178 - refactored code into findTIMaster method so it could be called from &gt;1 place
26/01/2011	cnwdap1	PAR #26785 Only rebuild form from ent def if required - in Messina, this was causing problems
						with the Dimensions fields not being initialised correctly
02/02/2011	cnwdap1	PAR #26862 Reverse PAR #26785 changes - the ent table def needs to be rebuilt unconditionally
						for seals changes, where we only want to display the seals fields if we actually have a cargo id
07/02/2013	cnwmh5	#31080 - Add additional code so if from prenote form and prenote exists then opens Cargo Enquiry in edit
						mode else standard add.
30/06/2014	cnwdap1	PAR #34483 CCMS DPH 2384 Allow attachments on ship forms
04/08/215	cnwdap1	PAR #36421 Hazardous Materials Handling - disable Attachments button if we are using the new hazardous children form
28/07/2016	cnwdap1	TFS #2384 Hazardous Materials Handling - re-enable Attachments button if we are using the new hazardous children form
17/11/2016	cnwdap1	TFS 2842 STWR Hazardous Details Enhancements
09/09/2022  navds20 TFS Bug 54615: CUX - Road Gate not retaining pre-noted HAZ info
14/12/2023	navcs2	ChangeRequest 57539: CUX | Multiple Prenotes Unique by Booking Reference
14/07/2025  navvk1  MTN-34845: SNO - Different focus of the cursor in Road Gate

*/
vars
	master 		: CM_TIMaster;
	cargoType 	: CM_CargoType;
	range		: CM_ContRange;
	prenote		: CM_TrackedItem;
	msg : String;
	noIdChange  : Boolean; // MTN-34845
	
begin
	//02 Mar 2015	NDL	Par 35766
	if _id.length &gt; 20 then
		msg := app.getErrorString2(Field_Value_Too_Long, self.txtCargoID.myLabel.caption,"20");
		app.msgBox( msg, app.getErrorString(Error), MsgBox_OK_Only );
		self.txtCargoID.setFocus();
		return;
	endif;
	
	if (_id = self.existingCargoID and not self.myTerminal.getConfig(PrenoteUniqBooking).Boolean) or
    self.isMakeLCLForm then					// 36670 Sep 2015 the code below is to find prenotes and for make LCL overwrites the entered BOL incorrectly
	   /*or self.isOnshipForm*/ 									// PAR #34483
		return;
	endif;
	
	// 14 July 2025 MTN-34845
	if _id = self.existingCargoID then 
		noIdChange := true; 
	endif; 
	
	master := self.findTIMaster (_id);
	
	if master &lt;&gt; null then
		self.setFieldsFromItem(master);
	else
		// there may be a container range we should default to
		range	:= app.myRoot.lookupContainerRange(_id);
		
		if range &lt;&gt; null then
			if range.tareKilos &lt;&gt; null then
				//self.txtTareWeight.setValue(range.tareKilos.Decimal.asStringWeightJMT());			// PAR #31155
				self.tblTareWeight.setValueDefault(range.tareKilos.String);							// PAR #31155
			endif;
			
			// 15/07/2014 cnwar2 #34563
			if range.isoType &lt;&gt; null and self.cmbISOType &lt;&gt; null then
				self.cmbISOType.setForObject(app.myRoot.allISOTypes[range.isoType]);
				self.doISOTypeChange();
			endif;
			if range.coolingType &lt;&gt; null and self.cmbCoolingType &lt;&gt; null then
				self.cmbCoolingType.setForText(app.coolingTypeENumToString(range.coolingType, false));
			endif;
			if range.coolingType &lt;&gt; null and self.cmbVoltageType &lt;&gt; null then
				self.cmbVoltageType.setForText(app.voltageTypeENumToString(range.coolingType, false));
			endif;
			
		endif;
	endif;
	
	self.existingCargoID := _id;

	self.btnAdditionalDet.enabled := _id &lt;&gt; null;
	self.btnAttachments.enabled := _id &lt;&gt; null;		// TFS #2384 and not self.myTerminal.getConfig(UseDetailedHazEntry).Boolean;	// PAR #36421
	self.btnDamage.enabled:= _id &lt;&gt; null;
	self.btnPhotos.enabled:=_id &lt;&gt; null;
	self.btnHazards.enabled := _id &lt;&gt; null;			// TFS 2842
	
	
	//start 09/09/2022 navds20 TFS 54615
	if self.myTerminal.getConfig(UseDetailedHazEntry).Boolean then
			self.btnHazards.enabled := false;
	endif;
	//end 09/09/2022 navds20 TFS 54615

	self.prefillFromLastVisit(_id);	//06 Nov 2012	NDL	Par 30691
	
	// 30047 Aug 2012 if the current item is a prenote and the new id doesn't exist, this is just a change to the current prenote id
	//	don't need to do anything else (don't refresh the form and keep any seals etc details)
	if self.myPxyGTEEntity &lt;&gt; null or (self.isPreNoteForm or self.isRailPreNoteForm) then					// 07/02/2013 cnwmh5 #31080
		cargoType := self.cmbType.getObject.CM_CargoType;
		if self.isGeneralCargo() then
		
		//	if cargoType &lt;&gt; null then
			if cargoType &lt;&gt; null and ( not cargoType.isAllowDuplicates ) then //12 Sep 2013	NDL	Par 32479 - multi pre-note break bulk on train
				prenote := self.myTerminal.lookupTrackedItem(_id, cargoType.id, TI_STATE_NOTIFIED, null, false);
				// TFS 2651 if the prenote we found isn't for the current booking, then ignore it								// TFS 2651
				if prenote &lt;&gt; null and prenote.myBookingRefItem &lt;&gt; self.myBookingRefItem and self.myBookingRefItem &lt;&gt; null then	// TFS 2651
					prenote := null;																							// TFS 2651
				endif;																											// TFS 2651
			endif;
		else
			prenote := self.findPrenoteContainer(_id);
		endif;
		if prenote = null and  (cargoType &lt;&gt; null and not cargoType.isAllowDuplicates ) then //epr TFS 1707 6/4/16
			//cnwmc5 - 24 Oct 2013 - PAR 31630
			prenote := self.findOnSiteTI(_id);
			if prenote &lt;&gt; null then
				//app.raiseCMException3(ERR_TI_ONSITE, prenote.cargoTypeDescr, prenote.id, prenote.myTerminal.code, null, null);
				//12 Sep 2014	NDL	Par 33946
				if self.myCurrentVehicleVisit &lt;&gt; null and not self.myCurrentVehicleVisit.isUpdatable then
					//Don't care we are just re-displaying, the controls are disabled anyway.
				else
					msg := app.getErrorString3(ERR_TI_ONSITE, prenote.cargoTypeDescr, prenote.id, prenote.myTerminal.code);
					app.msgBox( msg, "Pre Notification", MsgBox_OK_Only );
				endif;
			endif;
			return;
		endif;
	endif;		// end 30047
	
	// 07/02/2013 cnwmh5 #31080 - if prenote exists then need to open Cargo Enquiry in edit mode
	//if prenote &lt;&gt; null and self.isPreNoteForm or self.isRailPreNoteForm then
	if prenote &lt;&gt; null and (self.isPreNoteForm or self.isRailPreNoteForm) then		// TFS 2449 07/2016 was getting an error on rail prenote from the line abve
		if self.myTerminal.getConfig( PrenoteUniqBooking ).Boolean then				// 14/12/2023	navcs2	ChangeRequest 57539
			// No error do nothing 													// 14/12/2023	navcs2	ChangeRequest 57539
		elseif app.msgBox(app.getErrorString1(WARNING_TI_PRE_NOTED_EDIT, prenote.id), "Pre Notification Error", MsgBox_Yes_No + MsgBox_Information_Icon) = MsgBox_Return_Yes then
			self.changed := false;
			self.doCancel();
			if CM_TrackedItem.hasInstance(prenote) then
				self.myParentForm.myAssistant.showCargoEnquiryForm(prenote.CM_TrackedItem, self.myParentForm.myMasterMenuAction, true, true);
			endif;			
		else
			if not self.myTerminal.getConfig( AllowDuplicatePreNotes ).Boolean	//19 Sep 2016	NDL	TFS 2650 / 2001
			or not prenote.myCargoType.allowDuplicates	//19 Sep 2016	NDL	TFS 2650 / 2001
			then	//19 Sep 2016	NDL	TFS 2650 / 2001
				self.txtCargoID.CMUI_FieldTextBox.setValue(null);
				self.txtCargoID.setFocus();
				self.initFieldsForEntDefName(self.currentEntTableDef, false);
				if not app.getMyUser.canDo(self.myTerminal, PmAdmOpExpReleaseNumEdit) then //cnwrd1 par 29485 30.4.2012
					self.txtOpExRelNbr.visible := false;
				endif; 
			endif;	//19 Sep 2016	NDL	TFS 2650 / 2001
		endif;
		return;
	endif;
	
	//21 Sep 2010	NDL	Par 25608, force re-evaluation of what seals fields to display.
	//set the tab order to the next one, instead of the first one
	if not process.isJLGAB1 then // every time you enter a range of new Ids it sets focused to the first field, top left corner, quite annoying
		// 14 July 2025 MTN-34845 navvk1 - we have focus bug, so we always want to set focus on the first field.
		if not (noIdChange and self.existingCargoID = null) then
			self.initFieldsForEntDefName(self.currentEntTableDef, false);			//+cnwml2 PAR26043	// PAR #26785	// PAR #26862
		endif;
	endif;
	
	self.onContainerIdChange(_id, null);

	self.setNumItemsCaptionAndEnabled( existingCargoType );	//04 Mar 2014	NDL	Par 33596
	
	self.showHideWeighButton();	//13 Mar 2104	NDL	Par 33268
	
	if not app.getMyUser.canDo(self.myTerminal, PmAdmOpExpReleaseNumEdit) then //cnwrd1 par 29485 30.4.2012
		self.txtOpExRelNbr.visible := false;
	endif;
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_id" type="String"/>
    </JadeMethod>
    <JadeMethod name="onCargoSubTypeChanged" id="7efc564c-108b-43e0-ac51-5650cd4f4234">
        <updating/>
        <source>onCargoSubTypeChanged() updating, protected;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 August 2009	cnwjk3	Initial creation
23/11/2009	cnwmh5	PAR21492 - Add updating of Type combobox
17/02/2010	cnwdap1	PAR #22397 new parameter for setDimTyepDetails method
20/2/2018 	cnwer1	dimension type already done on filter details
14/03/2017	jlgrh7 TFS #37566	C3 - Default Commodities
*/
vars
	subType : CM_Product;
	defaultCommodity : CM_Commodity;																									//+TFS37547
begin
	
	subType:=self.cmbSubCargo.getObject().CM_Product;
	if self.existingCargoSubType = subType then
		return;
	endif;
	self.doFilterDetailsBySubCargoType(subType);
	self.doShowPicture();
	self.existingCargoSubType := subType;
	
	self.setNumItemsCaptionAndEnabled( self.existingCargoType );	//04 Mar 2014	NDL	Par 33596
	
	self.showHideWeighButton();	//13 Mar 2104	NDL	Par 33268
	
	//epr par 36025 16/4/15
	if self.existingCargoType &lt;&gt; null then
		if self.existingCargoType.isBulkByWeight then
			self.calculateTotalWeight(self.tblTotalWeight);
		elseif self.existingCargoType.isBulkByVolume then
			self.calculateTotalWeight(self.tblTotalVolume);
		endif;
	endif;
	
	if	subType &lt;&gt; null  then																																						//+TFS37566  Begins Looking for Cargo's subtype default commodity																											
		defaultCommodity :=  app.myRoot.allCommodities[subType.defaultCommodityCode];
		self.cmbCommodity.setForObject(defaultCommodity);	
	endif;																																															//+TFS37566 Ends
	
	self.setTotalVolumeFromProdAttrQty();	//10 Jun 2016	NDL	TFS 2141
	
epilog
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="onCargoTypeChange" id="828509e6-dfa5-4b75-ae9b-9fb5d321b9d7">
        <updating/>
        <source>onCargoTypeChange() protected, updating;
/*
Date		Who		Reason
17/07/2009	cnwdap1	Initial creation
28/10/2009	cnwdap1	PAR #20964 New parameter to loadSubCargoCommodityCombos
23/11/2009	cnwdap1	PAR #21658 For Trailer and Vehicle Cargo Types, show length/width/height dimensions fields
15/12/2009	cnwdap1	PAR #22006 Don't bother doing anything in here if we have no cargo type
04/02/2010	cnwdap1	PAR #21867 Treat "track as vehicle" cargo types the same as the system "CAR" cargo type
15/02/2010	cnwdap1	PAR #22088 Open Dimensions section for system cargo type Timber
23/03/2010	cnwdap1	PAR #22775 Clear existing cargo sub type reference if we've changed cargo type
13/05/2013	cnwdap1	PAR #31472 Create LCL Cargo - show height/length/width
12/10/2015  cnwma1  PAR #36519 Booking Calculations
20/02/2018 	cnwer1	TFS 7756 opening of sections already handled
13/11/2019	jlgsl4	TFS 47373 - PEN - Save-Next prevents use of Remarks Additional
23/06/2023	navpw1	TFS: 57812 (58798) - Automatically set itemised true when duplicates are not allowed
*/
vars
	cargoType, type	: CM_CargoType;
	nullTI			: Boolean;
	invalidTypes	: ObjectArray;
	combo			: CMUI_FieldComboBoxControl;
	idx				: Integer;
	obj				: Object;
	bookingItem,	br	: CM_BookingRefItem;
	parentForm		: CMUI_ReceiveCargoForm;
	commodityCode      : String;
	reason			: String; //05/04/2024	navkc1 Bug 63509

begin
	cargoType := cmbType.getObject.CM_CargoType;
	
	if cargoType = self.existingCargoType or cargoType = null then	// #22006 don't do anything in here if we have no cargo type  //PAR21862
		return;
	endif;
	
	// Do we want to null our myTI reference as well? If we're a rail cargo form, the myTI will be trasient
	// and the same as the mtproxyTrackedItem - in this case we need to null it
	if self.myTI &lt;&gt; null and self.myTI.isTransient and self.myTI = self.myProxyTrackedItem then
		nullTI := true;
	endif;
	
	// PAR #22775 and clear our myCargoSubType reference as well
	self.existingCargoSubType := null;
	
	if self.myProxyTrackedItem &lt;&gt; null and cargoType &lt;&gt; null and cargoType.id &lt;&gt; self.myProxyTrackedItem.cargoType then
		if self.myProxyTrackedItem.isKindOf(CM_Container) and not cargoType.id = TI_CargoType_Container then
			self.myProxyTrackedItem.erase(NORMAL_ERASE);
			self.myProxyTrackedItem := null;
		elseif not self.myProxyTrackedItem.isKindOf(CM_Container) and cargoType.isISOType then
			self.myProxyTrackedItem.erase(NORMAL_ERASE);
			self.myProxyTrackedItem := null;
		endif;
		
		if nullTI then
			self.myTI := null;
		endif;
	endif;
	
	self.createNewProxy(); // --&gt; TFS 47373
	//if self.myProxyTrackedItem = null and cargoType &lt;&gt; null then
		//epr CCMS 2274 create ti as the class defined on the cargo type
	//	create self.myProxyTrackedItem as cargoType.CM_CargoType.myClassToCreate transient;
	//endif; // &lt;-- TFS 47373
	
	// populate product type combo and commodity
	self.loadSubCargoCommodityCombos(cargoType, self.existingCargoType, self.cmbSubCargo, self.cmbCommodity);
	// populate generator and trailer types 
	self.loadGeneratorAndTrailerCombos(cargoType);

	// Decide whether to show/hide Dimension details and filter what to show based on product attributes
	self.doFilterDetailsByCargoType(cargoType);
	self.decideEntDefType(self.existingCargoType &lt;&gt; cargoType);

	self.setNumItemsCaptionAndEnabled( cargoType );	//04 Mar 2014	NDL	Par 33596
	
	self.doSetSubTerminal();
		
	// cnwjk3 - added this to fix problem of cargotype combo not being set when editing attachments
	self.cmbType.setForObject(cargoType);
	
	// What sort of cargo type are we? If we're a system one, or one on which we base our proxy creation type on,
	// disable the cmbType - can't change from a for instance Container to General Cargo, or Trailer to Generator
	if cargoType &lt;&gt; null and self.updateMode = self.Mode_Update then
		if cargoType.id = TI_CargoType_Generator or cargoType.isTrailer or cargoType.isISOType then
			self.cmbType.enabled := false;
		else
			self.cmbType.enabled := true;
			
			// filter out the other system types from the combo
			create invalidTypes transient;
			combo := cmbType.getEmbeddedControl.CMUI_FieldComboBoxControl;
			foreach idx in 1 to combo.listCount do
				type := combo.itemObject[idx].CM_CargoType;
				if type.id = TI_CargoType_Generator or type.isTrailer or type.isISOType then
					invalidTypes.add(type);
				endif;
			endforeach;
			foreach obj in invalidTypes do
				combo.removeObject(obj);
			endforeach;
		endif;
	endif;
		
	self.existingCargoType := cargoType;


	self.showHideWeighButton();	//13 Mar 2104	NDL	Par 33268
	//epr par 36025 16/4/15
	if self.existingCargoType &lt;&gt; null then
		if not self.existingCargoType.isSubCargoTypeRequired  then
			if self.existingCargoType.isBulkByWeight then
				self.calculateTotalWeight(self.tblTotalWeight);
			elseif self.existingCargoType.isBulkByVolume then
				self.calculateTotalWeight(self.tblTotalVolume);
			endif;
		endif;
	endif;
	
	if self.name ="CMUI_ReceiveCargoFormModal" then						 // 12/10/2015 cnwma1 PAR #36519	
		if self.myParentForm.isKindOf(CMUI_ReceiveCargoForm) then
			parentForm	:= self.myParentForm.CMUI_ReceiveCargoForm;
			bookingItem	:= parentForm.cmbBRItem.getObject.CM_BookingRefItem; 
			if cmbCommodity.getObject.CM_Commodity &lt;&gt; null then
				commodityCode := self.cmbCommodity.getObject.CM_Commodity.code;
			endif;
			if bookingItem &lt;&gt; null then
				br:= bookingItem.myBookingReference.getMatchingItem(cargoType,commodityCode,self.cmbISOType.getObject.CM_ISOType,self.cmbProdType.getString, null, null, null, null, null, reason); // ### TFS 56707 (56712) 05Apr2023 NAVPW1
				
				if br &lt;&gt; null then
					self.cmbBRItem.listCollection(br.myBookingReference.allBookingRefItems, true, 0);
					self.cmbBRItem.setForObject(br);
					self.txtBookingRef.setValue(br.myBookingReference.bookingReference);
				else
					self.cmbBRItem.clear;
					self.txtBookingRef.setValue(null);
					self.myBookingRefItem := null;
				endif;
			endif;
		endif;
	endif;																	 // 12/10/2015 cnwma1 PAR #36519	
	
	// ### TFS 57812 (58798) 22Jun2023 NAVPW1
	if not cargoType.allowDuplicates then
		self.chkItemised.getEmbeddedControl.CheckBox.value := true;
	else
		self.chkItemised.getEmbeddedControl.CheckBox.value := false;
	endif;
	// ### TFS 57812 (58798) 22Jun2023 NAVPW1
	
epilog
	delete invalidTypes;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="onCommodityChange" id="a915df08-d4d9-4712-90f1-132db7917e66">
        <updating/>
        <source>onCommodityChange() protected, updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 July 2009	cnwdap1	Initial creation
*/
vars
	
begin
	self.decideEntDefType(false);
	
	//04 Mar 2014	NDL	Par 33596 - No longer required
/*	//31 Jul 2013	NDL	Par 32102
/*	if self.isOnshipForm
	or self.isRailPreNoteForm	//19 Aug 2013	NDL	Par 32169
	or self.isMakeLCLForm	//10 Dec 2013	NDL	Par 32854
	then
		self.txtNumItems.setMyCaption(app.getErrorString(CM_Total_Quantity));
	endif; */
	
	self.doSetSubTerminal();
	
	//cnwmc5 - 13/27 August 2014 - PAR 34590/34818
	self.clearReeferDetails();
	
epilog
	
end;</source>
