    <JadeMethod name="translateToSearchValue" id="f797ebfb-16b5-4cfa-983f-f26bfb8da513">
        <source>translateToSearchValue(_value: Any): Any;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02/12/2009	cnwdap1	Initial creation
*/
