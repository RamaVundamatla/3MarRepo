    <JadeMethod name="updateBOLNumber" id="b5508e74-20e3-4cd6-b0dd-b5220c9e9156">
        <updating/>
        <source>updateBOLNumber(_bolNumber : String) updating, protected;
// cnwrs1 PAR dec 2006 to allow Centreport to keep the Billoflading in step with the myReceivalBOL.number
// it is assumed that self.myReceivalBOL and myVoyage are not null
vars
	bolIn : CM_BOLIn;
	intFaceBOLIn : CMIF_BOLIn;
	control : CMIF_TIUpdateController;
begin
	if not self.getCreateBOL then //CCMS 1100 Mar 2008 cnwrs1
		return;
	endif;
	if self.billOfLading = _bolNumber and 
	   self.myReceivalBOL.number = _bolNumber then
		return;
	endif;
	bolIn := self.myVoyage.allBOLInByTypeStatusNumDT.getAtKeyGeq(BOLType_GeneralBillOfLading, BOL_STATUS_NORMAL, _bolNumber, null);
	if bolIn = null then //th2 temporary back stop for change over of BOL types
		bolIn := self.myVoyage.allBOLInByTypeStatusNumDT.getAtKeyGeq(BOLType_GeneralDocket, BOL_STATUS_NORMAL, _bolNumber, null);
	else
		if bolIn.number &lt;&gt; _bolNumber then //par 14260 June 2007
			bolIn := self.myVoyage.allBOLInByTypeStatusNumDT.getAtKeyGeq(BOLType_GeneralDocket, BOL_STATUS_NORMAL, _bolNumber, null);
		endif;
	endif;
	// Sep 2011 null bolIn test added from CCMS 1776 testing
	if bolIn &lt;&gt; null and
	   bolIn.number &lt;&gt; _bolNumber then
		bolIn := null;
	endif;
	if bolIn = null then
		// create a new bol and shift us to that bolIn
		create intFaceBOLIn transient;
		intFaceBOLIn.bolNumber := _bolNumber;
		intFaceBOLIn.bolType := BOLType_GeneralBillOfLading;
		intFaceBOLIn.myTerminal := self.myTerminal;
		intFaceBOLIn.myVoyage := self.myVoyage;
		intFaceBOLIn.operatorCode := self.operatorCode;
		intFaceBOLIn.myOperator := app.myRoot.allOperators[self.operatorCode];
		intFaceBOLIn.transportMode := TI_TRANSMODE_SHIP;
		intFaceBOLIn.headerOnly := true;
		intFaceBOLIn.mySubTerminal := self.mySubTerminal;  	// Sep 2011 from CCMS 1776 testing
		create control transient;
		control.setMyUserObject(self);
		// Sep 2011 3rd param changed from null to control from CCMS 1776 testing
		app.myUtilityCA.utlCreateBOLInWithTIs(intFaceBOLIn, bolIn, control, app.myPassport);
		if not app.myPassport.checkValidation() then
			return;
		endif;
		// PAR 23147 - now return the BOL from the utl above
	endif;
	if bolIn = null then
		app.raiseCMException1(ERR_NO_OBJECT, "No BOL Object", null, null);
		return;
	endif;
	if bolIn.number &lt;&gt; self.myReceivalBOL.number then
		self.myReceivalBOL := bolIn;
		//29 jan 2013	NDL	Par 31102
		if bolIn &lt;&gt; null then
			self.setDirectDelivery( bolIn.directDelivery, true );
		endif;
	endif;
epilog
	delete intFaceBOLIn;
	delete control;
end;
</source>
        <access>protected</access>
        <Parameter name="_bolNumber" type="String"/>
    </JadeMethod>
    <JadeMethod name="validateColour" id="8c4fc089-3d77-4d99-8281-e78c22bdd833">
        <updating/>
        <source>validateColour() updating, protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 23/09/2013	cnwdap1		Initial creation PAR #32215 CCMS DPH 2290 New Car Attributes
//
vars
	colours 		: StringArray;
	col				: String;
	sortedColours	: CM_VehicleColourByColour;
	sortedColour	: CM_VehicleColour;

begin
	if not self.myTerminal.getConfig(ValidateColour).Boolean then
		return;
	endif;
	
	create colours transient;
	create sortedColours transient;
	self.colour.getTokensForDelimiter(Space, colours);
	foreach col in colours do
		sortedColour := app.myDutyDocRoot.allVehicleColours[col];
		if sortedColour = null then
			app.raiseCMException1(ERR_INVALID_COLOURCODE, col, "colour", null);
		else
			sortedColours.addNoDuplicates(sortedColour, false);
		endif;
	endforeach;
	
	// now get colours in alphabetical order and build self.colour from them
	col := null;
	foreach sortedColour in sortedColours do
		if col &lt;&gt; null then
			col := col &amp; Space;
		endif;
		col := col &amp; sortedColour.colour;
	endforeach;
	self.colour := col;
	
epilog
	delete colours;
	delete sortedColours;
end;</source>
        <access>protected</access>
    </JadeMethod>
