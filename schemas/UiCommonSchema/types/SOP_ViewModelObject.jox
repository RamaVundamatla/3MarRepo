    <JadeMethod name="setupThumbnailDetails_Code" id="ae847568-9b9e-4b03-9d2b-02d62f33732d">
        <source>setupThumbnailDetails_Code() protected;
// -----------------------------------------------------------------------------
// Created:		12 March 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
begin
	self.myForm.shtTblInput1.caption := 'Details';
	self.myForm.shtTblInput1.visible := true;
	self.myForm.shtMultiSelect1.visible := false;
	self.myForm.shtMultiSelect2.visible := false;
	self.myForm.shtMultiSelect3.visible := false;

	self.myForm.initTblInput(myForm.tblInput1, ETDef_CodeMaint);
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="showThumbnail" id="1a655854-3ba1-4ccb-a6dc-132506475655">
        <updating/>
        <source>showThumbnail( _obj : CM_Object) updating;
// -----------------------------------------------------------------------------
// Created:		11 March 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
begin
end;</source>
        <Parameter name="_obj" type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="showThumbnail_Code" id="d3ef68da-fbb8-4b41-b66d-c34f33902c71">
        <updating/>
        <source>showThumbnail_Code(_obj : CM_Code) updating, protected;
// -----------------------------------------------------------------------------
// Created:		12 March 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
begin
	self.setupThumbnailDetails_Code();
	self.myForm.sptThumbEdit.enabled := true;

	self.myForm.tblInput1.enabled := true;

	self.myForm.tblInput1.clearValues;
	self.myForm.tblInput1.setValueByName(ETRow_Code, _obj.code);
	self.myForm.tblInput1.setValueByName(ETRow_Description, _obj.description);
	self.myForm.tblInput1.setValueByName(ETRow_NotAvailableForEntry, _obj.notAvailableForEntry);
end;</source>
        <access>protected</access>
        <Parameter name="_obj" type="CM_Code"/>
    </JadeMethod>
</Class>
