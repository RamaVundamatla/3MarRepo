/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26/02/2023	navkc1 CR 59577 Task 62410: Jade - New TRX for HS Taric

*/

vars

begin
	self.myHSSubCode := _parent;

epilog

end;</source>
        <Parameter name="_parent" type="CM_HSCodeSubCode"/>
    </JadeMethod>
    <JadeMethod name="shouldAuditProperty" id="066aac77-f03e-4f39-b7e5-5066843221f7">
        <source>shouldAuditProperty(_rootClass: Class; _property: Property): Boolean protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26/02/2023	navkc1 CR 59577 Task 62410: Jade - New TRX for HS Taric

*/

vars
	propName	: String;
begin
	
	if _property = null then
		return false;
	endif;
	
	propName := _property.name;
	
	if propName = CM_HSCodeTaric::myHSSubCode.name then
		return false;
	else
		return inheritMethod(_rootClass, _property);
	endif;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_rootClass" type="Class"/>
        <Parameter name="_property" type="Property"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="0c4045cf-8707-4176-a790-7d7814dd5250">
        <source>validateForCreate();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26/02/2023	navkc1 CR 59577 Task 62410: Jade - New TRX for HS Taric

*/

vars

begin
	inheritMethod();
	
	self.validateForUpdate();
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="b6d912e2-97d2-47ca-8153-4fc9b440bd2f">
        <source>validateForUpdate();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26/02/2023	navkc1 CR 59577 Task 62410: Jade - New TRX for HS Taric

*/

vars
	realHS,
	existingHS : CM_HSCodeTaric;
	subCode : CM_HSCodeSubCode;
	
begin
	inheritMethod();
	
	
	if self.id = null then
		app.raiseCMException(Input_required_field_Id, null, null);
		return;
	endif;
	
	if self.id.length &lt;= 8 then
		app.raiseCMException2(Field_length_characters_long, self.id &amp; ": " &amp; app.getErrorString(Id), "&gt; 8", null, null);
	endif;
	
	if self.myHSSubCode = null then
		subCode := app.myRoot.allHSSubCodes[self.id[1:8]];
		if subCode = null then
			app.raiseCMException2(Related_obj_does_not_exist, app.getErrorString(Sub_code), self.id[1:8], null, null);
		endif;
	endif;
	
	realHS := self.pxyGetRealObject();
	existingHS := app.myRoot.allHSTaricCodes[self.id];
	
	if existingHS &lt;&gt; null and (realHS = null or existingHS &lt;&gt; realHS) then
		app.raiseCMException3(ERR_DuplicateItemWith, app.getErrorString(Taric_code), app.getErrorString(Id), self.id, null, null);
		return;
	endif;
	
	if self.description = null then
		app.raiseCMException(Input_required_field_Desc, null, null);
	endif;

epilog

end;</source>
    </JadeMethod>
</Class>
