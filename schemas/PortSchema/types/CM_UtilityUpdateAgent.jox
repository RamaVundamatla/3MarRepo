    <JadeMethod name="utlUpdateRTTaskDirectoLocation" id="d7881e15-4117-4ae6-9700-704788553da1">
        <source>utlUpdateRTTaskDirectoLocation(_locationsController : CM_LocationsController;
								_rtTask : CM_RTQueueTask input;
								_isDirectorSource : Boolean;
								_passport : CM_Passport input);
// adm 110609 Par 18942
vars

begin
	if _isDirectorSource then
		_rtTask.setSourceLocation(_locationsController);
	else
		
		_rtTask.setTargetLocation( _locationsController);
	endif;
	_rtTask.myEntry.causeEvent(_locationsController.myTerminal.getTerminalEvent(RTQueueEntry_Update_Event), true, null);
	_rtTask.myEntry.sendNotesForRelatedEntry(); //epr 27/4/10 CCMS 1099
	
end;
</source>
        <Parameter name="_locationsController" type="CM_LocationsController"/>
        <Parameter name="_rtTask" type="CM_RTQueueTask" usage="input"/>
        <Parameter name="_isDirectorSource" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateRTTaskICLocation" id="0e792da3-9c3a-4629-b7ec-f3e93ea38fd7">
        <source>utlUpdateRTTaskICLocation(_locationsController : CM_LocationsController; _rtTask : CM_RTQueueTask input;  _passport : CM_Passport input);
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 February 2011	cnwer1	Initial creation
12 Oct 2016	cnwkpd1	TFS 2815 - JADE 7.1.08 causeEvent changes

*/

vars
	moveController	: CMIF_MoveController;
begin
	self.initialiseActivity();
	
	app.setContinueCMExceptions(true);
	
	//validate the final target location 
	create moveController transient;
	moveController.setMoveMode(QUEUE_MODE);
	moveController.isRadioTelemetryMove := true;
	moveController.setMyTrackedItem(_rtTask.ti);
	moveController.setMyToPrimaryLocation(_locationsController);
	moveController.updatePassportAndUser(_passport);
	// Do some funky validation.
	app.myValUA.valRTTaskTarget(moveController, _locationsController);
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	_rtTask.changeTargetLocation(moveController,true);
	
	//cnwrd1 13.5.2011
//	_rtTask.ti.causeEvent(Object_Update_Event, false, self);
	self.updateObjectEdition(_rtTask.ti);

epilog

end;</source>
        <Parameter name="_locationsController" type="CM_LocationsController"/>
        <Parameter name="_rtTask" type="CM_RTQueueTask" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateRTTaskTargetLocation" id="79ddfce7-e6b2-4a58-9c96-0ea14064d1d7">
        <source>utlUpdateRTTaskTargetLocation(	_locationsController : CM_LocationsController;
								_rtTask : CM_RTQueueTask input; 
								_newMoveMethodRule 	: CM_RTMoveMethodRule;
								_passport : CM_Passport input);
/* -------------------------------------------
// Created 13 October 2003 by cnwdvb1
//
// -------------------------------------------

26 Jan 2011	 EPR	 PAR 26495 - changes made if the target location has changed to be somewhere that required re-queuing this is done
20 Feb 2024 navhl20 ChangeRequest 62525: EUP | Retrospective Operations - [54177.060] - Cargo &amp; Truck Checks
*/
vars

	moveController	: CMIF_MoveController;
	oldRTQueueMoveMethod,
	newRTQueueMoveMethod : CM_RTMoveMethod;
	sourceLoc 		: CM_LocationsController;
	terminal 		: CM_Terminal;
	wle 			: CM_WorkListEntry;
	ti 				: CM_TrackedItem;
	rtTask, workingTask			: CM_RTQueueTask;
	entryDescription, theAlertDetails : String;
	isAlertRequired : Boolean;
	alert				: CM_SystemAlert;
	lc : CM_LocationsController;
	rtQueueArbiter : CM_RTQueueArbiter;
	qFM				: CM_FutureMoveQueued;
	rtQEntry 		: CM_RTQueueEntry;
	lcs				: CM_LCSet;
begin

	self.initialiseActivity();
	
	ti:=_rtTask.ti;
	wle:=_rtTask.myEntry.myWorkListEntry;
	
	if _rtTask.isOverstowTaskAuto then
		rtTask:=_rtTask;
	else
		rtTask := wle.allRTQueueEntries.last.allTasks.last;
	endif;
	//rtTask:=_rtTask;
	//set up the move controller 
	create moveController transient;
	moveController.setMoveMode(QUEUE_MODE);
	moveController.isRadioTelemetryMove := true;
	moveController.setMyTrackedItem(ti);
	moveController.setMyToPrimaryLocation(_locationsController);
	moveController.setMyMachine(rtTask.machine);
	moveController.updatePassportAndUser(_passport);
		
	oldRTQueueMoveMethod:=rtTask.myEntry.getRTMoveMethod;

	//check if the move method is going to change
	sourceLoc:=wle.getOriginalTaskSourceLoc;
	terminal:=rtTask.getMyTerminal;
	
	if _newMoveMethodRule = null then
		newRTQueueMoveMethod:= terminal.getRTMoveMethod(sourceLoc,_locationsController);
		
		//cnwrd1 par 27995 25.8.2011
		// newRTQueueMoveMethod should be the default MMR for this move, we may have switched from the default but just amending the target without chaning TA's
		// so if we have an old MMR and we dont have a new MMR ( if we changed to a different ta we would have a new one)
		if oldRTQueueMoveMethod &lt;&gt; null and newRTQueueMoveMethod &lt;&gt; oldRTQueueMoveMethod then
			newRTQueueMoveMethod := oldRTQueueMoveMethod;
		endif;		
	else
		newRTQueueMoveMethod:=_newMoveMethodRule.myRTMoveMethod;
	endif;
	

	//app.setContinueCMExceptions(false);	
	//if it will then give users a warning
	if oldRTQueueMoveMethod &lt;&gt; newRTQueueMoveMethod	 then
		// we can't requeue automatic overstow tasks.
		if _rtTask.isOverstowTaskAuto then
			app.raiseCMException(Cannot_multi_machine_ostow,null,null);
			return;
		else
			app.raiseCMWarning(Warn_move_method_re_queue,null,null,null);
		endif;
		
	elseif _rtTask.isPlanOnPickupNoTarget then  //cnwrd1 par 27638 30.5.2011
		//drop into requeue code?
	else
		//we know this should be the the final task lets get it anyway 
		
		// Do some  validation with the move controller
		// not not done if we are unqueueing and re-queuing because creating the queue entry does this already
		app.myValUA.valRTTaskTarget(moveController, _locationsController);
		
		if not self.checkValidationWithPassport(_passport) then
			return;
		endif;
		
		// if same move method i.e. was just straddle and still just a straddle move then can just change the rtqueue tasks target location
		rtTask.changeTargetLocation(moveController,true);
		return;
	endif;
	
	entryDescription:=rtTask.myEntry.entryDescription;
	isAlertRequired:=rtTask.alertRequired(sourceLoc);

	qFM := wle.myFutureMove.CM_FutureMoveQueued;
	
	create lcs transient;
	qFM.allLocationsControllers.copy(lcs);
	
	create rtQueueArbiter transient;
	rtQueueArbiter.requeueWithMoveMethod(wle,_locationsController,_newMoveMethodRule);
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	qFM := wle.myFutureMove.CM_FutureMoveQueued;
	qFM.resetLocations(moveController);
	ti.refreshMyFutureLocations(QUEUE_MODE,null);

	foreach lc in lcs discreteLock do
		moveController.doUpdateDisplayEvent(lc);
	endforeach;
	moveController.doUpdateDisplayEvent(_locationsController);
	
	theAlertDetails:=entryDescription  &amp; app.getErrorString1(Target_location_changed, _locationsController.getFullId);
	//need to raise an alert and edit the ti transaction to indicate the target location has changed
	if isAlertRequired then
		create alert;
		alert.details :=  theAlertDetails;
		alert.setSeverity(SEVERE_INFO);
		alert.myTerminal := terminal;
		alert.add;		
	endif;
	
	app.createEditTransaction(ti,theAlertDetails,null,_passport); 				//20.02.2024 navhl20 #62525

	foreach rtQEntry in wle.allRTQueueEntries discreteLock  do 
		foreach workingTask in rtQEntry.allTasks discreteLock do
			if workingTask.status &lt;&gt; TASK_COMPLETE and workingTask.machine &lt;&gt; null then
				workingTask.machine.sendBroadcastMessage(app.getErrorString1(Target_location_changed, _locationsController.getFullId), false);
				//epr TFS 4620 16/6/16 
				workingTask.machine.addInfoToHistory(CM_MachineInfoHistory.InfoType_ChangeTarget,  workingTask,null,null);
			endif;
		endforeach;
	endforeach;

	

epilog
	delete moveController;
	delete rtQueueArbiter;
	delete lcs;
end;</source>
        <Parameter name="_locationsController" type="CM_LocationsController"/>
        <Parameter name="_rtTask" type="CM_RTQueueTask" usage="input"/>
        <Parameter name="_newMoveMethodRule" type="CM_RTMoveMethodRule"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateRTVehicleConfig" id="11d97219-8fc6-47b3-98a5-212a28e22450">
        <source>utlUpdateRTVehicleConfig(_pxyRTVehicleConfig : CM_RTVehicleConfig input; _allCriteria : CMIF_Array input; _passport : CM_Passport input);
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 May 2010	cnwer1	Initial creation

*/

vars
	realRTVehicleConfig :  CM_RTVehicleConfig;
begin
	self.initialiseActivity();
	
	realRTVehicleConfig:=_pxyRTVehicleConfig.pxyGetRealObject;
	
	realRTVehicleConfig.setForUpdate(_pxyRTVehicleConfig);
	
	//06 Mar 2015	NDL	Par 35816
	if _passport.noErrors then
		realRTVehicleConfig.addActivityRecord( false );
	endif;
	
	// and persist the criteria. CCMS MES 1080 PAR 24294	15/09/2010
	if _passport.noErrors and _allCriteria &lt;&gt; null then
		realRTVehicleConfig.persistCriteria(_allCriteria, _passport);
	endif;
	
epilog

end;</source>
        <Parameter name="_pxyRTVehicleConfig" type="CM_RTVehicleConfig" usage="input"/>
        <Parameter name="_allCriteria" type="CMIF_Array" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateRackShelfInterchange" id="7ad2e46c-bcb1-4c13-9720-0b5a193b1ace">
        <updating/>
        <source>utlUpdateRackShelfInterchange(_shelves: CM_RackShelfControllerSet; _ica : CM_InterchangeArea) updating;
/*
Purpose:			
Date				Who			Reason
SEPT 2013		CNWAB1		Initial creation
*/


vars
	shelf : CM_RackShelfController;
	ta : CM_TerminalArea;
begin

	self.initialiseActivity();
	
	foreach shelf in _shelves discreteLock do
		if app.myPassport.noErrors then
			self.myUpdateAuditAgent.audUpdateGeneric(shelf, true);
		endif;
	
		if app.myPassport.noErrors then
			shelf.setForUpdateICA(_ica);
		endif;
	
		if app.myPassport.noErrors then
			self.myUpdateAuditAgent.audUpdateGeneric(shelf, false);

			// NOTIFICATION this will redraw the shelf
			app.myEventManager.createSingleObjInfoNoteEvt(shelf.myTerminalArea,app.myPassport.myTerminal.getTerminalEvent(EVENT_TI_MOVE),shelf);
			
		endif;
	
	endforeach;
	

end;</source>
        <Parameter name="_shelves" type="CM_RackShelfControllerSet"/>
        <Parameter name="_ica" type="CM_InterchangeArea"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateRackShelfMaxCapacity" id="fb8a8f89-fd26-4628-85ce-2dc42a248d72">
        <updating/>
        <source>utlUpdateRackShelfMaxCapacity(_shelves: CM_RackShelfControllerSet; _capacity : Integer) updating;
/*
Purpose:			
Date				Who			Reason
SEPT 2013		CNWAB1		Initial creation
*/


vars
	shelf : CM_RackShelfController;
	ta : CM_TerminalArea;
begin

	self.initialiseActivity();
	
	foreach shelf in _shelves discreteLock do
		if app.myPassport.noErrors then
			self.myUpdateAuditAgent.audUpdateGeneric(shelf, true);
		endif;
	
		if app.myPassport.noErrors then
			shelf.setForUpdateMaximums(_capacity, shelf.maximumWeight, shelf.defaultCapacity);
		endif;
	
		if app.myPassport.noErrors then
			self.myUpdateAuditAgent.audUpdateGeneric(shelf, false);

			// NOTIFICATION this will redraw the shelf
			app.myEventManager.createSingleObjInfoNoteEvt(shelf.myTerminalArea,app.myPassport.myTerminal.getTerminalEvent(EVENT_TI_MOVE),shelf);
			
		endif;
	
	endforeach;
	

end;</source>
        <Parameter name="_shelves" type="CM_RackShelfControllerSet"/>
        <Parameter name="_capacity" type="Integer"/>
    </JadeMethod>
