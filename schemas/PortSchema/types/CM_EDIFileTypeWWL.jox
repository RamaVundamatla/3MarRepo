<Class name="CM_EDIFileTypeWWL" id="d6f70792-e219-4f5d-aad7-e1c5a0be3c69">
    <superclass name="CM_EDIFileType"/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <abstract/>
    <DbClassMap file="edi"/>
    <JadeMethod name="getEDIBundle" id="bd3044b1-2eec-4512-acf7-57e725744267">
        <source>getEDIBundle(): Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 January 2025	navkc1	JIRA Story MTN-33491: MTN | License - EDI Bundles Methods

*/

vars

begin
	
	return self.EDI_Bundle_CUSTOM;

epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getRecordInfo" id="3b085870-3510-427e-99c1-3ac0ee010512">
        <source>getRecordInfo(_record : String; _fields : StringArray input);
//----------------------------------------------------------------
//	Created:	Dec 2007 cnwrs1
//----------------------------------------------------------------
//
// 			Should take any hex 7E separated variable string and put variables into string array
// 			The string array is a list of delimited records.
// Note:  	Only good for short strings
// 			Sub class should know what each field is and take care of translating strings into something meaningful
// ---------------------------------------------------------------------------
constants
	FD:String = #"7E"; //field delimiter
vars
	field,
	length,
	endPos,
	startPos	: Integer;
	
	value,
	strRec		: String;
begin
	strRec := _record;
	_fields.clear();
	
	startPos := 1;
	endPos := 1;
	field := 1;

	while startPos &lt;= strRec.length do
		//find end of field
		endPos := strRec.pos(FD , startPos) - 1;
		
		//get the value
		if endPos &gt;= startPos then	//field to add
			length := (endPos+1)- startPos;	
			value := strRec[startPos:length].trimBlanks;
			
		elseif endPos = -1 then		//last field
			length := (strRec.length)- startPos;	// was legth+1 cnwrs1 Aug 2006 par 12245
			value := strRec[startPos:length].trimBlanks;
		
		else
			value := null;
		endif;
		
		//check for use of '"', then correct it (we may have found an non-delimiting comma).
		if value[1] = '"' then
			//set new startPos to after the first '"'
			startPos := strRec.pos('"', startPos)+1;
			
			//set new endPos to before the next '"'
			endPos := strRec.pos('"', startPos) - 1;
			
			//could just be a single "
			if endPos = -1 then
				//backup 1
				startPos := startPos - 1;
				
				//look for end of field
				endPos := strRec.pos(FD, startPos+1) - 1;
				
				//check for last
				if endPos = -1 then
					endPos := startPos;
				endif;
			
			endif;
			
			length := (endPos+1)- startPos;	
			value := strRec[startPos:length].trimBlanks;
			
			//reset endPos to before the comma after the '"' (where it would be normally)
			endPos := strRec.pos(FD, endPos+1) - 1;
		endif;
		
		
		//deal with it
		if self.isIgnoredValue(value) then
			_fields.add(null);	
		else
			_fields.add(value.trimBlanks[1:62]); //par 13088 cnwrs1 dec 2006	
		endif;
		
		if endPos = -1 then //there are no more commas, we have the last field
			break;
		else
			startPos := endPos + 2;
			field := field + 1;
		endif;
	endwhile;	
end;</source>
        <Parameter name="_record" type="String"/>
        <Parameter name="_fields" type="StringArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="isIgnoredValue" id="c5ccab78-52e8-4b76-abfd-479b5417740f">
        <source>isIgnoredValue(_strValue: String): Boolean;
///----------------------------------------------------------------
//	Created:	Dec 2007 cnwrs1
//----------------------------------------------------------------
vars

begin

	if _strValue = "" then
		return true;
	else
		return false;
	endif;
	
end;</source>
        <Parameter name="_strValue" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="processFile" id="bebc8fd9-2c0a-4d45-84b1-747920718786">
        <updating/>
        <source>processFile(_ediFile: CM_EDIFile input) updating, protected;
//----------------------------------------------------------------
//	Created:	Dec 2007 cnwrs1
//----------------------------------------------------------------
// 18 Jan 2019	jlgrs1	TFS 41659 42276 STWR Make EDI MultiThreaded Stage 8
// 07 Apr 2019	jlgrs1	TFS 41913 STWR - Reconfiguration of the EDI Operation form to better handle EDI collection locks while loading 
//
vars

begin

	app.writeLog("A yet to be identified WWL file has been loaded.", LogINFO);

end;</source>
        <access>protected</access>
        <Parameter name="_ediFile" type="CM_EDIFile" usage="input"/>
    </JadeMethod>
</Class>
