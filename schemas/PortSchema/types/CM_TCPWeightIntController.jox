    </JadeMethod>
    <JadeMethod name="doOpen" id="bc18fcaf-fbab-40b1-915c-c031db8875f5">
        <updating/>
        <source>doOpen() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 August 2016	cnwrh7	Initial creation

*/

vars
	logString  : String;
begin
	self.diagnosticLog(method.qualifiedName&amp;" myConn.remotePort= "&amp;myTCPConnection.remotePort.String); 				//debug in dev envi
	if self.myTCPConnection &lt;&gt; null then
		self.myTCPConnection.open();								//step1  connection open
		self.updateConnectionStatus();	
		self.doWriteBinary(myTCPConnection);				//step2 connection write
	else
		logString := method.qualifiedName &amp; Tab &amp; "No TCP/IP connection";
		self.diagnosticLog (logString);
	endif;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doReadBinary" id="d7826d72-70fd-4599-a8c3-9cd8c0b47ff3">
        <source>doReadBinary(_tcp : TcpIpConnection);
/*

Purpose:			
Reading weight data (Binary lenght is fixed as 509) passing back
Parameters:			

Return Value:		

Date		Who		Reason
24 August 2016	cnwrh7	Initial creation

*/
constants
	GetDataLength = 509;
vars
	binResponse	:	Binary;
	logString			: 	String;
begin
	logString := method.qualifiedName &amp; Tab&amp; "Received Data from " &amp; _tcp.remoteName  &amp;  "; the connection port # " &amp; _tcp.remotePort.String; 
	self.diagnosticLog (logString) ;
	binResponse := _tcp.readBinary(GetDataLength);
	logString := method.qualifiedName &amp; Tab &amp; "TCP/IP Binary reponse = " &amp; binResponse.display();
	self.diagnosticLog (logString);
	self.getIscaleWeight(binResponse);
epilog
	if _tcp &lt;&gt; null then
		logString := method.qualifiedName &amp; Tab &amp; "Closing TCP/IP connection";				//Connection Closed at the end
		self.diagnosticLog(logString );
		_tcp.close;
	endif;
end;</source>
        <Parameter name="_tcp" type="TcpIpConnection"/>
    </JadeMethod>
    <JadeMethod name="doWriteBinary" id="c3c71746-f148-4713-988d-393f9fe494bf">
        <source>doWriteBinary(_tcp : TcpIpConnection);
/*

Purpose:			

Getting the command of asking weight ready 

Parameters:			

Return Value:		

Date		Who		Reason
25 August 2016	cnwrh7	Initial creation

*/

vars
		kc													: CnKarmaCntrl;
		localIPAdd									: String;
		lastDigital									: String;
		getWeightBytes						: ByteArray;
		getWeightMessage    				: Binary;
		i														: Integer;
begin
	self.diagnosticLog(method.qualifiedName&amp;" myConn.remotePort= "&amp;myTCPConnection.remotePort.String); 				//Debug only will remove later
	create getWeightBytes transient;								//Based on the example and document from iScale
	getWeightBytes[1] 		:= 255.Byte;								//start byte
	getWeightBytes[2] 		:= 6.Byte;									//format version of this command
	getWeightBytes[3]		:= 10.Byte;								//command "Get Data"
	getWeightBytes[4] 	:= 1.Byte;									//length of data send in command	--(lowest byte)
	getWeightBytes[5] 		:= 0.Byte;									//length of data send in command --(higher byte)
	getWeightBytes [6] 	:= 0.Byte;									//length of data send in command --(higher byte)
	getWeightBytes [7] 	:= 0.Byte;									//length of data send in command --(highest byte)
//	getWeightBytes [8] 	:= lastDigital.Byte;				//ID of device sending command --(Depnding on situation) Need Device ID here???
	getWeightBytes [8] 	:= 5.Byte;									//ID of device sending command --(Depnding on situation) Need Device ID here???
	getWeightBytes [9] 	:= 255.Byte;								//end byte
	i :=1;
	 while i &lt;= getWeightBytes.size do 
			getWeightMessage := getWeightMessage &amp; getWeightBytes[i].Binary;
			i:= i+1;
	endwhile;
	_tcp.writeBinary(getWeightMessage);													//step2		write binary
	self.doReadBinary(self.myTCPConnection);											//step3		connection read
epilog
	delete getWeightBytes;
	//delete kc;
end;</source>
        <Parameter name="_tcp" type="TcpIpConnection"/>
    </JadeMethod>
    <JadeMethod name="getIscaleWeight" id="47a82247-e74c-4361-8bff-0666d13039da">
        <source>getIscaleWeight(_binResponse : Binary);
/*

Purpose:			
Retrieve weight data starts from 109 from the binary data passing back 
Parameters:			

Return Value:		

Date		Who		Reason
16 September 2016	cnwrh7	Initial creation

*/
constants
	WeightDataStartPoint = 109;			 //4 Byte in the return buffer binary start from postion 109
	Delimiter : String = " ";
vars
	weightDataString					: String;
	int 												: Integer;
	weightRealValue					: Real;
	weightDeciValueInTonne	: Decimal[15,3];			//unit Tonne
	weightDeciValueInKg			: Decimal[15,3];			//unit	Kg
	logString									: String;
	iScaleWeightDataTrans					: CMIF_IscaleWeightDataWrap;
begin
	logString := method.qualifiedName; 
	self.diagnosticLog(logString);
	int :=0;
	while int &lt;=3 do																											//we need 4 Byte in the return buffer binary start from postion 109
		weightDataString := weightDataString &amp; _binResponse[WeightDataStartPoint+int: 1].asHex.String &amp; Delimiter;
		int := int +1 ;
	endwhile;
	weightDataString := weightDataString.trimRight(); 										//remove last Delimiter
	create iScaleWeightDataTrans transient;															//use c# dll file to do data convertion
	if iScaleWeightDataTrans.convertFunction(weightDataString, weightRealValue) then
		weightDeciValueInTonne := weightRealValue.Decimal;							//Weight in Tonne
		weightDeciValueInKg	:= weightDeciValueInTonne*1000;						//Weight in Kg
	else
		logString := method.qualifiedName &amp; Tab &amp; "Response Binary can not be converted successfully.";
		self.diagnosticLog (logString);
	endif;
	if weightDeciValueInKg &gt;= 0 then
		self.myTCPWeightCallerInterface.sendWeight (weightDeciValueInKg);
	else
		self.raiseWeightICException(0,"Unknown command received from iScale device: '" &amp; "The value is null" &amp; "'");
	endif;
epilog
	delete iScaleWeightDataTrans;
end;</source>
        <Parameter name="_binResponse" type="Binary"/>
    </JadeMethod>
    <JadeMethod name="handleConnectionException" id="e87f5461-7872-4f94-a0e1-bc94624b5a5f">
        <updating/>
        <source>handleConnectionException(_connectionException : ConnectionException) : Integer updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 August 2016	cnwrh7	Initial creation

*/

vars

begin
	self.diagnosticLog(method.qualifiedName &amp; " errorCode=" &amp; _connectionException.errorCode.String &amp; " " &amp; "errorItem=" &amp; _connectionException.errorItem &amp; " " &amp; "extendedErrorText=" &amp; _connectionException.extendedErrorText);
	
	self.raiseWeightICException(0,"errorCode=" &amp; _connectionException.errorCode.String &amp; " " &amp; "errorItem=" &amp; _connectionException.errorItem &amp; " " &amp; "extendedErrorText=" &amp; _connectionException.extendedErrorText &amp; " ");
	
	//return Ex_Pass_Back;
	return Ex_Abort_Action;
epilog

end;</source>
        <Parameter name="_connectionException" type="ConnectionException"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="initializeWithTcpDetails" id="e87dd4d4-d41b-4231-a9c4-349a9748a0d4">
        <updating/>
        <source>initializeWithTcpDetails(_tcpDetails: CM_DeviceTCPConnectionDetails) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 August 2016	cnwrh7	Initial creation

*/
constants
		MinTimeout = 500;
vars
		
begin
		self.diagnosticLog(method.qualifiedName &amp; " myTCPDetails=" &amp; self.myTCPConnection.String &amp; " connectingState=" &amp; self.connectingState.String);
		
		if self.myTCPConnection &lt;&gt; null then
			if self.connectingState = self.TCPConnecting then
					self.raiseWeightICException(0,"Attempting to initialize but you are connecting");
					return;
				else
					delete self.myTCPConnection;
			endif;
		endif;
		
		//setting TCP Connection Details to get ready
		create self.myTCPConnection as TcpIpConnection transient;
		
		self.myTCPConnection.name := _tcpDetails.tcpAddress;
		self.myTCPConnection.port := _tcpDetails.tcpPortNumber;
		self.myTCPConnection.timeout := _tcpDetails.tcpTimeOut;
		self.myTCPConnection.usePresentationClient := _tcpDetails.useTCPPresentationClient;
		
		if not _tcpDetails.isTransient then
				self.myTCPDetails := _tcpDetails;
		endif;
		
		self.connectingState := self.TCPDisconnected;						//connection state as 0 for openAsynch method
	
		self.diagnosticLog(method.qualifiedName &amp; " myTCPDetails=" &amp; self.myTCPConnection.String &amp; " connectingState=" &amp; self.connectingState.String);
epilog

end;</source>
        <Parameter name="_tcpDetails" type="CM_DeviceTCPConnectionDetails"/>
    </JadeMethod>
    <JadeMethod name="raiseWeightICException" id="b4bc49c3-49e0-4622-9773-a1575ea51c5a">
        <source>raiseWeightICException(_exceptionCode : Integer; _exceptionData : String);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 August 2016	cnwrh7	Initial creation

*/

vars

begin
	app.writeLog("CM_TCPWeightInterfaceController: " &amp; _exceptionCode.String &amp; " " &amp; _exceptionData,0);
	if tcpConnectReady then
		self.myTCPWeightCallerInterface.handleWeightICException(_exceptionCode,_exceptionData);
	endif;
end;

</source>
        <Parameter name="_exceptionCode" type="Integer"/>
        <Parameter name="_exceptionData" type="String"/>
    </JadeMethod>
    <JadeMethod name="setWeightCallerInterface" id="5e8808d4-bf72-4b1e-9e7d-4a290db5833b">
        <updating/>
        <source>setWeightCallerInterface(_weightCallerInterface : IF_TCPWeightCallerInterface) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 August 2016	cnwrh7	Initial creation

*/

vars

begin
	self.myTCPWeightCallerInterface := _weightCallerInterface;
	
	if self.myTCPWeightCallerInterface = null then
		self.tcpConnectReady := false;
	else
		self.tcpConnectReady := true;
	endif;
	
epilog

end;</source>
        <Parameter name="_weightCallerInterface" type="IF_TCPWeightCallerInterface"/>
    </JadeMethod>
    <JadeMethod name="updateConnectionStatus" id="18682a81-24cc-480e-861b-2c63b6d98801">
        <updating/>
        <source>updateConnectionStatus() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 August 2016	cnwrh7	Initial creation

*/
vars

begin
		if self.myTCPConnection = null then
			self.connectingState := TCPDisconnected;//0
		elseif self.myTCPConnection.state = TCPConnected  then
			self.connectingState := TCPConnected;//2
		elseif self.myTCPConnection.state = TCPConnecting then
			self.connectingState := TCPConnecting; //1
		elseif self.myTCPConnection.state = TCPDisconnecting then
			self.connectingState := TCPDisconnecting;//3
		elseif self.myTCPConnection.state = TCPDisconnected then
			self.connectingState := TCPDisconnected; //0
		endif;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
</Class>
