    <JadeMethod name="queryRowColumnChg" id="9a4dbfc9-80b2-409e-9e15-acc2a008addd">
        <source>queryRowColumnChg(_table :Table; _row, _col :Integer):Boolean;
/*

Date		Who		Reason
06 September 2011	cnwcs5	Initial creation - CCMS MES 1033 / par 27951 RORO KPI
*/
vars

begin
	if _row &lt;= _table.fixedRows then
		return false;
	endif;

	return true;
epilog

