    <JadeMethod name="mnuEditOperator_click" id="e2f62a8f-fb2b-44b8-8fc1-237a1b5fa910">
        <controlMethod name="MenuItem::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mnuEditOperator_click(menuItem: MenuItem input) updating;
/*
Purpose:	

Date		Who		Reason
19 March 2025	navab1	JIRA 34233
*/

vars

	operator : CM_Operator;
	
	cutoff,rowCutoff : CM_ReceivalCutoffVoyage;
	row, idx, idy : Integer;
	oper : CM_Operator;
	table : CM_DataTable;
begin
	cutoff := menuItem.userObject.CM_ReceivalCutoffVoyage;
	
	if cutoff &lt;&gt; null then
		oper := cutoff.myOperator;
		if oper = null then
			return;
		endif;
		
		operator := self.showOperatorPicker;
		if operator = null then
			return;
		endif;
		
		
		table :=  self.tblVoyageCutoffs;
		
		idx := table.fixedRows + 1;
		idy := table.rows;
		
		foreach row in idx to idy reversed do
			rowCutoff := table.accessRow(row).itemObject.CM_ReceivalCutoffVoyage;
			
			if rowCutoff &lt;&gt; null
			and rowCutoff.myOperator = oper then
				rowCutoff.setProxyOperator(operator);
				table.accessCell(row,2).text := operator.code;
			endif;
		
		endforeach;
	endif;

epilog

end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
