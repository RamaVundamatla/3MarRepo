    <JadeMethod name="doAddUpdateRTMoveMethodRule" id="6ea5efd6-1d5c-4ea7-a8a5-3f39d23453c7">
        <updating/>
        <source>doAddUpdateRTMoveMethodRule(_isAdd : Boolean) updating;
/*

Purpose:			Working in proxies should get proxy obj on row and setProxy 

Parameters:			

Return Value:		


Date		Who		Reason
03 February 2010	cnwer1	Initial creation

*/

vars
	pxyObj, oldPxy : CM_RTMoveMethodRule;
	moveMethod : CM_RTMoveMethod;
	sourceICArea,
	targetICArea : CM_InterchangeArea;
	rowIdx : Integer;
begin

	on CM_Exception do app.validationExHandler(exception, app.myPassport);
	app.setContinueCMExceptions(true);
	app.myPassport.clearErrorsWarnings();
	
	if self.cmbMoveMethod.listIndex &gt; 0 then
		moveMethod	:=self.cmbMoveMethod.itemObject[self.cmbMoveMethod.listIndex].CM_RTMoveMethod;
	endif;
	
	if moveMethod = null then
		app.raiseCMException(Required_Machine_Move_Method, null, null);
		return;
	endif;
	
	
	if _isAdd then
		//validate does not already exist 
		//self.myProxyMultiRule.allDefaultRTMoveMethodRules[moveMethod]
		if self.myProxyMultiRule.allDefaultRTMoveMethodRules[moveMethod] &lt;&gt; null then
			app.raiseCMException(Duplicate_Move_method,null,null);
			return;
		endif;
		
		if self.myProxyMultiRule.allOtherRTMoveMethodRules[moveMethod] &lt;&gt; null then
			app.raiseCMException(Duplicate_Move_method,null,null);
			return;
		endif;
		create pxyObj transient;
	else
		if self.tblMoveRules.row &lt;= self.tblMoveRules.fixedRows then
			return;
		endif;
		pxyObj:=self.tblMoveRules.accessRow(self.tblMoveRules.row).itemObject.CM_RTMoveMethodRule;
		oldPxy:=pxyObj.cloneSelf(true);
		oldPxy.setProxy(null,pxyObj.myRTMoveMethod,pxyObj.isDefault,pxyObj.shortDescription,pxyObj.mySourceICArea,pxyObj.myTargetICArea,pxyObj.queuingRule);
	endif;
	
	if pxyObj = null then
		return;
	endif;
	
	
	
	if self.cmbSourceIC.listIndex &gt; 0 then
		sourceICArea:=self.cmbSourceIC.itemObject[self.cmbSourceIC.listIndex].CM_InterchangeArea;
	endif;
	
	if self.cmbTargetIC.listIndex &gt; 0 then
		targetICArea:=self.cmbTargetIC.itemObject[self.cmbTargetIC.listIndex].CM_InterchangeArea;
	endif;
		
	
	pxyObj.setProxy(	self.myProxyMultiRule,
						moveMethod,
						self.chkDefault.value,
						self.txtShortDesc.text,
						sourceICArea,
						targetICArea,
						self.cmbQueuingRule.text	);
	
	
	pxyObj.validateUpdate(app.myPassport);
	
	
	
	if not app.myPassport.hasErrors then 
		self.loadTableFromProxy();
		if self.tblMoveRules.findObjectInRow(pxyObj,rowIdx) then
			 self.tblMoveRules.row:=rowIdx;
			 self.doSelectRTMoveMethodRule;
		endif;
	endif;
epilog
	
	if app.myPassport.hasErrors then
		app.showErrorWarningDialog(	app.getErrorString( Booking_Item ),
												app.myPassport,
												ErrWarnMode_AddUpdate  );
		// adding delete the proxy
		if _isAdd then
			delete pxyObj;
		else
			if pxyObj &lt;&gt; null then
		// updatefailed validation revert to old data
			pxyObj.setProxy(self.myProxyMultiRule,
							oldPxy.myRTMoveMethod,
							oldPxy.isDefault,
							oldPxy.shortDescription,
							oldPxy.mySourceICArea,
							oldPxy.myTargetICArea,
							oldPxy.queuingRule);
			endif;
		endif;
	else
		hasUnsavedChanges:=true;
		
	endif;


	delete oldPxy;
end;</source>
        <Parameter name="_isAdd" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doBaseFormCancel" id="3a67855c-458c-4221-8301-37091a758777">
        <updating/>
        <source>doBaseFormCancel() updating, protected;

// Created by cnwdvb1 on 05 September 2006

vars

begin
	if self.hasUnsavedChanges then
		if app.msgBox(app.getErrorString(Unsaved_data), "",MsgBox_Yes_No) = MsgBox_Return_No then
			return;
		endif;
	endif;
	self.unloadForm();

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doBaseFormSave" id="1edb5deb-1709-4d93-aabc-2c4bb6acd7f0">
        <updating/>
        <source>doBaseFormSave() updating, protected;

// Created by cnwdvb1 on 05 September 2006

vars

	realRule,
	pxyRule		: CM_RTQueueMultiRule;
	passport	: CM_Passport;
	result		: Integer;
	success		: Boolean;

begin

	passport := app.myPassport;
	
	if self.myProxyMultiRule = null then
		app.msgBox(app.getErrorString(Select_Machin_Rule_Type),app.getErrorString(Errors),MsgBox_OK_Only);
		return;
	endif;
	
	if self.myRule = null then
		while true do
			app.myTrxCA.trxCreateRTQueueMultiRule(self.myProxyMultiRule, realRule, passport);
			if passport.trxCompletedOK() then
				success := true;
				break;
			else
				result := app.showErrorWarningDialog('Rules', app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
				if app.myPassport.noErrors and
					result = IDOK then
					// there must have just been warnings that the user has acknoledged so ..
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
			endif;
			break;
		endwhile;
	else
		while true do
			app.myTrxUA.trxUpdateRTQueueMultiRule(self.myProxyMultiRule, passport);
			if passport.trxCompletedOK() then
				success := true;
				break;
			else
				result := app.showErrorWarningDialog('Rules', app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
				if app.myPassport.noErrors and
					result = IDOK then
					// there must have just been warnings that the user has acknoledged so ..
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
			endif;
			break;
		endwhile;
	endif;
	
epilog
	
	if success then
		self.unloadForm();
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doRemoveRTMoveMethodRule" id="e75daee0-a823-46d8-938c-c9ab1b6db76e">
        <updating/>
        <source>doRemoveRTMoveMethodRule() updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 February 2010	cnwer1	Initial creation

*/

vars
	pxyObj : CM_RTMoveMethodRule;
begin
	if self.tblMoveRules.row &lt;= self.tblMoveRules.fixedRows then
		return;
	endif;
	pxyObj:=self.tblMoveRules.accessRow(self.tblMoveRules.row).itemObject.CM_RTMoveMethodRule;
	
	hasUnsavedChanges:=true;
	delete pxyObj;
	self.loadTableFromProxy();
epilog

end;</source>
    </JadeMethod>
