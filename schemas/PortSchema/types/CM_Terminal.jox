    </JadeMethod>
    <JadeMethod name="createVehicleBookingTerm" id="57b9ded2-1bad-4b8c-ab51-d1e155acdf86">
        <source>createVehicleBookingTerm():CM_VehicleBookingTerminal;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 April 2013	cnwndl1	Initial creation	Par 35342

*/

vars

	vbRoot : CM_VehicleBookingRoot;
	vbTerm : CM_VehicleBookingTerminal;

begin

	vbRoot := app.myVehicleBookingRoot;
	
	//05 Dec 2014	NDL	Par 35342
	if vbRoot = null then
		if CM_VehicleBookingRoot.instances.isEmpty then
			create vbRoot;
		endif;
		app.setMyVehicleBookingRoot();
	endif;
	
	if vbRoot = null then
		return null;
	endif;
	
	vbTerm := self.getMyVehicleBookingTerminal;
	if vbTerm = null then
		vbTerm := vbRoot.createVehicleBookingTerm(self);
	endif;
	
	return vbTerm;

epilog

end;</source>
        <ReturnType type="CM_VehicleBookingTerminal"/>
    </JadeMethod>
    <JadeMethod name="createWorkPointTypeShip" id="89dbe908-2efc-44a2-900e-e84be7cc6539">
        <source>createWorkPointTypeShip():CM_WorkPointType;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 May 2023		navma1	ChangeRequest 57712:[54558] EUP - Delivery Dispatch – Adding Work Point Types

*/

vars
