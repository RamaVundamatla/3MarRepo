	xdbFeature.setupAndBuildSet(CM_Wagon::dateTime.name, "CM_Wagon", "dateTime", "CM_Wagon", _features); 
	
	create xdbFeature transient;
	xdbFeature.setupAndBuildSet(CM_Wagon::hasRemarks.name, "CM_Wagon", "hasRemarks", "CM_Wagon", _features); 
	
	create xdbFeature transient;
	xdbFeature.setupAndBuildSet(CM_Wagon::hasTrackedItems.name, "CM_Wagon", "hasTrackedItems", "CM_Wagon", _features);
	
	//epr TFS 3418 13/3/17 added get location id which has rail line and wagon pos and remove rail line
	create xdbFeature transient;
	xdbFeature.setupAndBuildSet(CM_Wagon::getLocationId.name, "CM_Wagon", "getLocationId", "CM_Wagon", _features);
	
	create xdbFeature transient;
	xdbFeature.setupAndBuildSet(CM_Wagon::id.name, "CM_Wagon", "id", "CM_Wagon", _features); 
	
	create xdbFeature transient;
	xdbFeature.setupAndBuildSet(CM_Wagon::maxCargoHeight.name, "CM_Wagon", "maxCargoHeight", "CM_Wagon", _features); 
	
	create xdbFeature transient;
	xdbFeature.setupAndBuildSet(CM_Wagon::maxCargoWeight.name, "CM_Wagon", "maxCargoWeight", "CM_Wagon", _features); 
	
	create xdbFeature transient;
	xdbFeature.setupAndBuildSet(CM_Wagon::myCarrier.name, "CM_Wagon", "myCarrier", "CM_Wagon", _features); 
	
	create xdbFeature transient;
	xdbFeature.setupAndBuildSet(CM_Wagon::myDestinationPort.name, "CM_Wagon", "myDestinationPort", "CM_Wagon", _features); 
	
	create xdbFeature transient;
	xdbFeature.setupAndBuildSet(CM_Wagon::myOriginPort.name, "CM_Wagon", "myOriginPort", "CM_Wagon", _features); 
	
	//epr TFS 3418 13/3/17
	//create xdbFeature transient;
	//xdbFeature.setupAndBuildSet(CM_Wagon::myRailLine.name, "CM_Wagon", "myRailLine", "CM_Wagon", _features); 
	
	create xdbFeature transient;
	xdbFeature.setupAndBuildSet(CM_Wagon::myTerminal.name, "CM_Wagon", "myTerminal", "CM_Wagon", _features); 
	
	create xdbFeature transient;
	xdbFeature.setupAndBuildSet(CM_Wagon::myTerminalDeparted.name, "CM_Wagon", "myTerminalDeparted", "CM_Wagon", _features); 
	
	create xdbFeature transient;
	xdbFeature.setupAndBuildSet(CM_Wagon::myTrainInwards.name, "CM_Wagon", "myTrainInwards", "CM_Wagon", _features); 
	
	create xdbFeature transient;
	xdbFeature.setupAndBuildSet(CM_Wagon::myTrainOutwards.name, "CM_Wagon", "myTrainOutwards", "CM_Wagon", _features); 
	
	
/*	epr TFS 3418 13/3/17 exposing the wagon class code so don't need the object also don't need wagon master

	create xdbFeature transient;
	xdbFeature.setupAndBuildSet(CM_Wagon::myWagonClass.name, "CM_Wagon", "myWagonClass", "CM_Wagon", _features); 
	
	create xdbFeature transient;
	xdbFeature.setupAndBuildSet(CM_Wagon::myWagonMaster.name, "CM_Wagon", "myWagonMaster", "CM_Wagon", _features); */

	create xdbFeature transient;
	xdbFeature.setupAndBuildSet(CM_Wagon::remarks.name, "CM_Wagon", "remarks", "CM_Wagon", _features); 
	
	create xdbFeature transient;
	xdbFeature.setupAndBuildSet(CM_Wagon::tareWeight.name, "CM_Wagon", "tareWeight", "CM_Wagon", _features); 
	
	create xdbFeature transient;
	xdbFeature.setupAndBuildSet(CM_Wagon::wagonClassCode.name, "CM_Wagon", "wagonClassCode", "CM_Wagon", _features); 
	
	create xdbFeature transient;
	xdbFeature.setupAndBuildSet(CM_Wagon::getStevedoreCodeReceive.name, "CM_Wagon", "stevedoreCodeRecieve", "", _features);   //02.10.2020 cnwma1 TFS #50112
	
	create xdbFeature transient;
	xdbFeature.setupAndBuildSet(CM_Wagon::getStevedoreCodeRelease.name, "CM_Wagon", "stevedoreCodeRelease", "", _features);  //02.10.2020 cnwma1 TFS #50112
	
epilog

end;</source>
