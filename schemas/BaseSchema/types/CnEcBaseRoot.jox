    <JadeMethod name="createTLesson" id="c5069166-659f-47d9-8ac2-f86570e167ba">
        <updating/>
        <source>createTLesson(	pName 				: String;
				pFormName 			: String;
				pNextLessonName 	: String;
				pText 				: String;
