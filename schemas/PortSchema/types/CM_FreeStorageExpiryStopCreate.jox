<Class name="CM_FreeStorageExpiryStopCreate" id="55a6dea4-215d-4d8c-a63c-29ecaa8f4b74">
    <superclass name="CM_OfflineFutureActor"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="backgroundprocess"/>
    <ImplicitInverseRef name="myTrackedItem" id="ce838907-d586-4d94-8d80-fba551d38104">
        <embedded/>
        <type name="CM_TrackedItem"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <JadeMethod name="doAction" id="f4d43a4b-6e79-4e70-8143-3b2e0876cba7">
        <updating/>
        <source>doAction(): Boolean updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 May 2013	cnwjre1	Initial creation

*/

vars

	invalid : Boolean;	//11 Feb 2019	NDL	TFS 43318
	
begin
	if self.myTrackedItem = null then
		return true;
	endif;

	if not self.getAndLockValidObject(self.myTrackedItem, Share_Lock, invalid) then
		return true;
	endif;
	
	// do the actual process - apply a stop of the configured type
	// for now just log that this method has been called
	
	 app.writeLog(method.qualifiedName &amp; " for " &amp; self.myTrackedItem.id, LogDEBUG);	//26 Nov 2019	NDL	TFS 47053
	return true;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getActionFutureDate" id="367c9594-8a7c-418f-80c9-196828cae11e">
        <source>getActionFutureDate() : TimeStamp;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 June 2024	navra1	Initial creation for //navra1 - TFS 60149/Task 64732 - 24th June 2024

*/

vars

begin
	return  self.actionTimeStamp;
epilog

end;</source>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="getAnniversaryDate" id="8692c064-de04-4181-9b18-be2ba101c485">
        <source>getAnniversaryDate() : TimeStamp;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 June 2024	navra1	Initial creation for //navra1 - TFS 60149/Task 64732 - 24th June 2024

*/

vars

begin	
	if self.myTrackedItem &lt;&gt; null then
		return self.myTrackedItem.getFutureStorageAnniversary().TimeStamp;
	else
		return null;
	endif;
epilog

end;</source>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
