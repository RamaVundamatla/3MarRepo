    <JadeMethod name="doViewItem" id="5e01a430-3919-49ac-8849-48b693a2ca66">
        <source>doViewItem(_ediData : CM_EDIData io):CMUI_EDIForm protected;	//par 27392 13 Apr 2011
// ---------------------------------------------------------------------------
// Created:     26 April 2010 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 13/09/2010	cnwcs5		par 25665 - allow view of multiple customs or operator stops
// ---------------------------------------------------------------------------
vars

	coll	:ObjectArray;	// 13/09/2010 cnwcs5 par 25665
begin
	_ediData := self.getSelectedEDIData;
	
	if _ediData = null then
		return null;
	endif;
	
	coll 	:= self.tblData.allSelectedObjects;		// 13/09/2010 cnwcs5 par 25665
	//epr CPL 957 EDI Administration improvements 19/10/15
	return self.myEDIAgent.showEDIFormWithColl (coll, self.myMasterMenuAction, false);	
	
epilog

end;</source>
