    <JadeMethod name="trxDeleteHoldVessel" id="a6d9328d-809e-4625-9d4b-910fad5ce347">
        <updating/>
        <source>trxDeleteHoldVessel(_vesselHold : CM_VesselHold io; _passport : CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 February 2013	cnwer1	Initial creation 
14/07/2025	naviv1	35226	MTN - Usage of Iterator.getCurrentKeys  
*/

vars
	newBayOrdinal,
	newHoldOrdinal,
	numBays	: Integer;
	holdOrdinal,
	bayOrdinal : Integer;
	realVesselStructure : CM_CellularVesselStructure;
	iter : Iterator;
	bays,
	holds : DynaDictionary;
	hold	: CM_Hold;
	bay : CM_Bay;
	id : String;
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);


	app.setContinueCMExceptions(false);
	
	
	numBays:=_vesselHold.allBays.size;
	holdOrdinal:=_vesselHold.ordinalHold;
	if _vesselHold.allBays.first &lt;&gt; null then
		bayOrdinal:= _vesselHold.allBays.first.ordinalBay;
	endif;
	realVesselStructure:=_vesselHold.myCellularVesselStructure;
	// get new Holds &amp; ids
	
	//get new bays &amp; ids
	
	// Start the transaction
	beginTransaction;

	_vesselHold.allBays.purge;
	_vesselHold.erase(NORMAL_ERASE);
	
	if _passport.hasErrors then
		return;
	endif;
	
	create holds transient;
	holds.setMembership(CM_Hold);
	holds.addExternalKey(Integer,4, false,false);
	holds.endKeys(false);
	foreach hold in realVesselStructure.allHolds do
		if hold.ordinalHold &lt; holdOrdinal then
			continue;
		endif;
		holds.putAtKey(hold.ordinalHold- 1,hold);
	endforeach;
	
	iter:=holds.createIterator;
	while iter.next(hold) do
		iter.getCurrentKeys(newHoldOrdinal); //MTN-35226
		hold.CM_VesselHold.updateOrdinalNoDups(newHoldOrdinal);
		if _passport.hasErrors then
			return;
		endif;
	endwhile;
	delete iter;
	
	create bays transient;
	bays.setMembership(CM_Bay);
	bays.addExternalKey(Integer,4, false,false); //ordinal
	bays.addExternalKey(String,20, false,false); //id
	bays.endKeys(false);
	
	foreach bay in realVesselStructure.allBaysByOrdinal do
		if bay.ordinalBay &lt; bayOrdinal then
			continue;
		endif;
		newBayOrdinal:=bay.ordinalBay- numBays;
		id := ((newBayOrdinal *2) -1).padLeadingWith("0",2);
		bays.putAtKey(bay.ordinalBay- numBays,id,bay);
	endforeach;
	
	iter:=bays.createIterator;
	while iter.next(bay) do
		iter.getCurrentKeys(newBayOrdinal,id); //MTN-35226
		bay.CM_BayDefn.updateOrdinalIdsNoDups(newBayOrdinal,id);
	
		if _passport.hasErrors then
			return;
		endif;
	endwhile;
	
	realVesselStructure.setNumberSlotsDefined(); // PAR 32286 added during testing
epilog	
	delete iter;
	delete holds;
	delete bays;
	self.finaliseActivityWithPassport(_passport);

end;</source>
        <Parameter name="_vesselHold" type="CM_VesselHold" usage="io"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
