    <JadeMethod name="getDisplayForInUseValidation" id="51954557-1b66-490e-a330-5df2c4d4c5a6">
        <source>getDisplayForInUseValidation(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 November 2012	cnwndl1	Initial creation	Par 30767

*/

vars

	tempStr : String;

begin

	if self.myTerminal &lt;&gt; null then
		tempStr :=	app.getString( Terminal ) &amp; Space &amp; self.myTerminal.code &amp; ' / ';
	endif;
	
	tempStr :=	tempStr &amp; self.code &amp; " [" &amp; app.getErrorString(ProForma_allocation) &amp; "]";
	

epilog

	return tempStr;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
</Class>
