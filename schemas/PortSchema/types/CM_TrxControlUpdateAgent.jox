    <JadeMethod name="trxUpdatePackCargo" id="3b42f665-a92a-4819-a345-b356b84e489c">
        <updating/>
        <source>trxUpdatePackCargo(	_parentCargo : CM_TrackedItem input;
					_packCargo : CM_TrackedItem io;
					_packQuantity : Integer;
					_packWeight : Decimal;
					_setParentFromChild : Boolean;	//16 Jul 2014	NDL	Par 34571
					_packRelease : CM_BulkRelease input; //epr TFS 2897 need to set pack release when packing
					_packReserve : CM_ReserveDetail input;	//20 Mar 2017	NDL	TFS 3667
					_updateParentCommodity : Boolean;
					_retroDT  : TimeStamp;
					_passport : CM_Passport input) updating;
/*

Date		Who		Reason
30 June 2014	cnwer1	Initial creation PAR 34472
13/09/2021	jlier1	TFS 51879 - updating parent commodity after pack
18 Mar 2024 navhl20 ChangeRequest 62863: EUP | Retrospective Operations - [54177.100] - Pack
*/

vars

begin
// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(false);
	
	_passport.useTIDictDeferUpdate := true;
	_passport.useTITransactionDeferUpdate := true;
	
	beginTransaction;
	
	//16 July 2014	NDL	Par 34571
	if _setParentFromChild then
		app.myUtilityUA.utlUpdateParentFromFirstChild(	_parentCargo,
														_packCargo,
														_passport);
		if not _passport.noErrors() then
			return;
		endif;
	endif;

	//The proxy TI should have its original untouched children and the two TI_Arrays contain what is to add and what is to remove.
	//Move controller is for unpacking to a location..... more work to be done.
	app.myUtilityUA.utlUpdatePackCargo(	_parentCargo,
										_packCargo,
										_packQuantity,
										_packWeight,
										_packRelease,
										_packReserve,
										_updateParentCommodity,
										_retroDT,								//19.03.2024 navhl20 #62863
										_passport);
	
	if _passport.noErrors() then
		_passport.doDeferredUpdates();
	endif;
epilog
	self.finaliseActivityWithPassport(_passport);

end;</source>
        <Parameter name="_parentCargo" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_packCargo" type="CM_TrackedItem" usage="io"/>
        <Parameter name="_packQuantity" type="Integer"/>
        <Parameter name="_packWeight" type="Decimal"/>
        <Parameter name="_setParentFromChild" type="Boolean"/>
        <Parameter name="_packRelease" type="CM_BulkRelease" usage="input"/>
        <Parameter name="_packReserve" type="CM_ReserveDetail" usage="input"/>
        <Parameter name="_updateParentCommodity" type="Boolean"/>
        <Parameter name="_retroDT" type="TimeStamp"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxUpdatePackMasterPack" id="fe99db5d-4540-4406-a6fb-cd9af7c7e61c">
        <updating/>
        <source>trxUpdatePackMasterPack(_theMoveController : CMIF_MoveController input;
					_noCharge : Boolean;
					_thePackTIs, _theUnpackTIs : CM_TIArray;
					_unpackFromRelease : Boolean;
					_theProxyMasterpackTI : CM_TrackedItem input;
					_newMasterpack : CM_TrackedItem output;
					_passport : CM_Passport input) updating;
vars

begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(false);
	
	_passport.useTIDictDeferUpdate := true;
	_passport.useTITransactionDeferUpdate := true;
	
	beginTransaction;

	//The proxy TI should have its original untouched children and the two TI_Arrays contain what is to add and what is to remove.
	//Move controller is for unpacking to a location..... more work to be done.
	app.myUtilityCA.utlCreateAndPackMasterpack(_theMoveController,_noCharge, _thePackTIs, 
								_theUnpackTIs, _unpackFromRelease,
								_theProxyMasterpackTI, 
								_newMasterpack,
								_passport);
								
	if _passport.noErrors() then
		_passport.doDeferredUpdates();
	endif;

epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_theMoveController" type="CMIF_MoveController" usage="input"/>
