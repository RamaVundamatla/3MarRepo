    <JadeMethod name="avgAbortTransMin" id="fe67b6ce-4061-4451-8f38-509e11de5afa">
        <methodInvocation>mapping</methodInvocation>
        <source>avgAbortTransMin(set: Boolean; _value: Integer io) mapping;
/*
------------------------------------------------------------------------
Created:			16 October 2003 by cnwdwq1
Purpose:			
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/

vars
	pvDet : CM_GlobalProcessDetail;
	value,
	diff : Integer64;
	sampTime : Real;
begin
	if set then
		return;
	endif;
	_value := 0;
	sampTime := self.sampleTimeDifference;
	if sampTime = 0 then
		return;
	endif;
	if sampTime &lt; 1 then
		sampTime := 1;
	endif;
	pvDet := self.myPreviousDetail;
	if pvDet = null then
		return;
	endif;
	diff := (self.statsNumAbortedTrans- pvDet.statsNumAbortedTrans).abs;
	value := diff div sampTime;
	if value &gt; Max_Integer then
		_value := Max_Integer;
	else
		_value := value.Integer;
	endif;
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Integer" usage="io"/>
    </JadeMethod>
