    <JadeMethod name="deleteCurrentJobEntry" id="7f8a04ed-82e6-4c49-ade7-8ef4d8ec2761">
        <updating/>
        <source>deleteCurrentJobEntry(_vvr : CM_VehicleVisitRecord;_reason : String) updating;
//--------------------------------------------------------------
//
// Created:     16 Oct 2017 by jlgns1
//--------------------------------------------------------------
//Confirm deletion of the current WLE for the RoadJob
//We have to do a number of things here..
//If the job is a receipt of a TI, we have to MOVE the TI to the LOGICAL delete
//area of the system, &amp; adjust the roadJob etc accordingly,
//If the job is a release, we simply amend the request etc.
//18/10/17 jlgns1 TFS 7115 PKT - Vehicle visit dispute occurs at GATE OUT
vars
	result		: Integer;
	wleArray 	: CM_WLEArray;
	wle			: CM_WorkListEntry;
		
begin
    	
	create wleArray transient;
	_vvr.vehicle.allRoadJobs.first.workListEntries.copy(wleArray ); 	
	if wleArray.isEmpty then
		return;
	endif;
	
	foreach wle in wleArray discreteLock do
		while true do
			app.myTrxDA.trxDeleteJobEntry(wle, _reason, app.myPassport); 
			if app.myPassport.trxCompletedOK then
				break;
			else
				result := app.showErrorWarningDialog(app.getErrorString(XLAT_Road_operations), app.myPassport, ErrWarnMode_Delete + ErrWarnMode_CanAckWarnings);
				if app.myPassport.noErrors and
				   result = IDOK then
					// there must have just been warnings that the user has acknoledged so ..
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
			endif;
			break;
		endwhile;
	endforeach;

epilog
	delete wleArray;
	
end;</source>
        <Parameter name="_vvr" type="CM_VehicleVisitRecord"/>
        <Parameter name="_reason" type="String"/>
    </JadeMethod>
    <JadeMethod name="doCancel" id="b8e87ad4-13f1-4333-af39-c8e7c7acea66">
        <updating/>
        <source>doCancel(): Boolean updating;
//-----------------------------------------------------------------------
//  Created by: cnwsh3
//
//	Date: 24 September 2003
//-----------------------------------------------------------------------
// 04/12/2012	cnwcs5	par 30413 - remove reference to deleted control
vars

begin
	return inheritMethod();
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doCancelVVR" id="43bf3c3c-02e0-4216-b28e-8875bbdc4b0d">
        <updating/>
        <source>doCancelVVR() updating;
/*
Date		Who		Reason
24 February 2012	cnwrd1	Initial creation
//18/10/17 jlgns1 TFS 7115 PKT - Vehicle visit dispute occurs at GATE OUT
*/

vars
	vehicle: 	CM_Vehicle;
	form: 		GTE_VehicleTurnaroundReason;
	vvr 		: CM_VehicleVisitRecord;
	result:		Integer;
begin
	
	if not app.myCurrentUserCan(self.myTerminal, PmGteGateCanCancelFlexiJob) then
		return;
	endif;
	
	vvr := self.myCurrentObject.CM_VehicleVisitRecord;
	
	if vvr = null then
		return;
	endif;
		
	if vvr.isBulkGateVVR then		
		form := app.loadForm(GTE_VehicleTurnaroundReason, 
							GTE_Assistant, 
							false, false, true, 
							self.myTerminal, null).GTE_VehicleTurnaroundReason;
		result := form.showModal();
		if result = IDOK then
			if vvr.myRoadJob = null and vvr.isUpdatable and not vvr.isCancelled then		
				self.doVehicleVisitCancel(vvr,form.txtReason.text);
			else	
				if  vvr.status = CM_VehicleVisitRecord.Status_Unverified then
					if vvr.myRoadJob = null then
						self.doUpdateChangeStatus(vvr);
					else
						self.deleteCurrentJobEntry(vvr,form.txtReason.text);
					endif;
				endif;
			endif;
		else
			return;
		endif;		
	else
		if  vvr.status &lt;&gt; vvr.Status_Cancelled then							
			form := app.loadForm(GTE_VehicleTurnaroundReason, 
							GTE_Assistant, 
							false, false, true, 
							self.myTerminal, null).GTE_VehicleTurnaroundReason;
			result := form.showModal();
			if result = IDOK then
				self.doVehicleVisitCancel(vvr, form.txtReason.text);
			else
				return;
			endif;
		endif;
	endif;
	
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doChangeInspectionStatus" id="ac767b9d-2643-475c-a37d-2b3ead2d059a">
        <updating/>
        <source>doChangeInspectionStatus(_newStatus : String; _isIn : Boolean) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		        Who		Reason
13 December 2022	navmp20	ChangeRequest 55580: EUP - Inspection App checks - Interface and MTN changes
30 March	2023	navsp1	Bug 57269: FR | 53667 - EUP - Inspection App checks - Bulk Edit
*/

vars
	pxyVVR, 
	vvr 		: CM_VehicleVisitRecord;
	theReturn 	: Integer;
	pxyVVRSet 	: CM_VehicleVisitRecordSet;
	obj			: Object;
begin
	
	//30.March.2023 navsp1 TFS 57269 - &gt;&gt;&gt;&gt;
	app.myPassport.setMyTerminal(self.myTerminal);
	
	create pxyVVRSet transient;	
	foreach obj in self.tblData.allSelectedObjects do
		if obj.isKindOf(CM_VehicleVisitRecord) then
			pxyVVR := app.createUpdateProxy(obj.CM_VehicleVisitRecord).CM_VehicleVisitRecord;
			if pxyVVR &lt;&gt; null then
				pxyVVR.updateGateCheckDetails(_isIn, _newStatus, app.actualTimeServer);
				pxyVVRSet.add(pxyVVR);
			endif;			
		endif;		
	endforeach;
	//30.March.2023 navsp1 TFS 57269 - &lt;&lt;&lt;&lt;
	
	while true do
		app.myTrxUA.trxUpdateVehicleVisitFlexis(pxyVVRSet, app.myPassport);//30.March.2023 navsp1 TFS 57269
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			break;
		else
			theReturn := app.showErrorWarningDialog(app.getErrorString(Change_status), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				// there must have just been warnings that the user has acknowledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			return;
		endif;
		break;
	endwhile;
epilog
	if pxyVVRSet &lt;&gt; null then
		pxyVVRSet.purge();
	endif;
	delete pxyVVRSet;
end;</source>
        <Parameter name="_newStatus" type="String"/>
        <Parameter name="_isIn" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doDisAssocBooking" id="6d0b62de-942b-4268-b7a6-9d366d6930cd">
        <updating/>
        <source>doDisAssocBooking(menuItem: MenuItem input) updating, protected;
/*

Purpose:			Disassociates a vehicle booking time slot from a vehicle visit record

Parameters:			menuItem	MenuItem	The menu item to use to get the vehicle booking time slot from

Return Value:		NONE

Date		Who		Reason
19 May 2023	navpw1	Initial creation TFS: 54049 (55843)

*/

vars
	vvr			: CM_VehicleVisitRecord;
	vbts		: CM_VehicleBookingTimeSlot;
	theReturn	: Integer;
	
begin
    vvr := self.myCurrentObject.CM_VehicleVisitRecord;
	
	if vvr &lt;&gt; null then
		if vvr.allVehicleBookingSlots.isEmpty then
			return;
		endif;
		
		vbts := vvr.allVehicleBookingSlots.first;
		
	endif;
	
	if vbts = null then
		return;
	endif;
	
	while true do
		app.myTrxUA.trxDisassocVehicleBookingVvr(vbts, app.myPassport);
		
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			break;
		else
			theReturn := app.showErrorWarningDialog(app.getErrorString(Vehicle_schedul_booking_slot), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				// there must have just been warnings that the user has acknowledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			return;
		endif;
		break;
	endwhile;
	
end;</source>
        <access>protected</access>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doFilterTable" id="0e1a934a-832e-4799-895a-5b8d77973673">
        <updating/>
        <source>doFilterTable() protected, updating;
/*

Purpose:			Filters the table using the text entered

Parameters:			NONE

Return Value:		NONE

Date		Who		Reason
18 May 2023	navpw1	Initial creation TFS: 54049 (55843)

*/

vars
	filterText		: String;
	rowIdx,
	colIdx,
	start			: Integer;
	cell			: JadeTableCell;
	cellText		: String;
begin
	//filterText := self.txtFilterBox.text.toUpper();
	filterText := self.frmTableFilter.txtFilterBox.text.toUpper(); //25/06/2024	navkc1 CR 64823 Task 64824
	
	if (filterText = "") then
		self.clearFilter();
		return;
	else
		//self.btnClearFilter.enabled := true;
		self.frmTableFilter.btnClearFilter.enabled := true; //25/06/2024	navkc1 CR 64823 Task 64824
	endif;
	/*
	start := self.tblData.fixedRows + 1;
	foreach rowIdx in start to self.tblData.rows do	: rowLoop
		self.tblData.accessRow(rowIdx);
		foreach colIdx in 1 to self.tblData.columns do
			cell := self.tblData.accessCell(rowIdx, colIdx);
			cellText := cell.text.toUpper;
			if cellText.length &gt; 0 and cellText.pos(filterText, 1) &gt; 0 then
				self.tblData.accessedRow.visible := true;
				continue rowLoop;
			endif;
		endforeach;
		self.tblData.accessedRow.visible := false;
	endforeach;
	*/
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doMnuReprint" id="2cc8f454-9b2b-44d7-accd-9d024219793f">
        <updating/>
        <source>doMnuReprint() updating;
/*
Purpose:			Reprint the Driver Instructions for the selected Vehicle Visit record

Parameters:			

Return Value:		

Date		Who		Reason
25/11/2011	cnwdap1	Initial creation PAR #28733 CCMS SFW 1261
08/02/2012	cnwdap1	PAR #29097 Reprint report name is now configurable
//8.2.2 version 19 June 2013	NDL	Par 31842
*/
vars
	printCopies		: Integer;
	printConfirm	: GTE_PrintConfirmationForm;
	vvr				: CM_VehicleVisitRecord;
	reportName		: String;					// PAR #29097
	msg : String;
	defaultPrinterName : String;
	
	tiClone					 : CM_TrackedItem;										//+TFS2899
	ti 							: CM_TrackedItem;										//+TFS2899
	tiClones 				: CM_TISet;														//+TFS2899
	localTIs					: CM_TISet;														//+TFS2899
	repFormatDict 	: CM_ReportFormatMatchCritDict;		//TFS2899
begin
	if self.myCurrentObject = null then
		return;
	endif;
	
	defaultPrinterName := app.printer.getPrinterName;  //epr par 32899
	
	vvr := self.myCurrentObject.CM_VehicleVisitRecord;
	printCopies := 1;
	//12 Jun 2015	NDL - checking par 36197, Messina don't have "isClientMessina" set anyway, so no one should be using this
//	if app.myRoot.isClientMessina then
//		printCopies := self.myTerminal.getConfig(GateReceiptCopies).Integer;
//	endif;
	
	if self.myTerminal.getConfig(DisplayPrintConfirmation).Boolean then
		create printConfirm transient;
		printConfirm.setPrintDetails(printCopies, self.printerName, self);
		printCopies := printConfirm.showModal;
	endif;
	
	if printCopies &gt; 0 then 
		reportName := myTerminal.getConfig(GateReprintDriverIns).String;																							// PAR #29097
		if reportName = null then																																	// PAR #29097
			reportName := DefRep_GateReprintDriverInst;																												// PAR #29097
		endif;
		if not app.validatePrinterName( self.printerName, true, true ) then
			msg := app.getErrorString1( Printer_not_known_locally_2, self.printerName);
			app.msgBox( msg, app.getErrorString(Warning), MsgBox_OK_Only );
			self.printerName := null;
		endif;
		
		//if self.myTerminal.hasAltDriverInstructFormats() = 0 then																	//+TFS2899
		vvr.reprintDriverDetails(printCopies, self.myTerminal.getConfig(PrintPreview).Boolean, self.myTerminal, reportName, null, self.printerName);				// PAR #29097
		/*
		else
			create localTIs transient;
			create tiClones transient;
			vvr.allReceivedTrackedItems.copy(localTIs);
			foreach ti in vvr.allReleasedTrackedItems do
				if localTIs.includes(ti) then
					tiClone := ti.cloneSelf(true);
					tiClones.add(tiClone);
					localTIs.addNoDuplicates( tiClone, false );
				else			
					localTIs.addNoDuplicates( ti, false );
				endif;
			endforeach;
			if localTIs.isEmpty then
				vvr.reprintDriverDetails(printCopies, self.myTerminal.getConfig(PrintPreview).Boolean, self.myTerminal, reportName, null, self.printerName);				// PAR #29097 Still doing this
			else	
				create repFormatDict transient;
				vvr.myTerminal.getAltDriverInstructFormats( repFormatDict, CM_ReportFormatMatchCriteria.DriverCriteriaInt);
				return;
			endif;
		endif;
		*/
	endif;
		
epilog
	app.printer.setPrinter( defaultPrinterName ); //epr par 32899 01/11/13
end;</source>
    </JadeMethod>
    <JadeMethod name="doPrint" id="2463cfc9-202d-48f5-8556-68cf40af3ede">
        <updating/>
        <source>doPrint() updating;
//--------------------------------------------------
// Created:	17 February 2004 By: cnwgd1
//--------------------------------------------------
// 04/12/2012	cnwcs5	par 30413 - trabslations
vars
	dialog				: CMUI_ReceiptCopies;
	currentVisitRecord 	: CM_VehicleVisitRecord;
	cvSet 				: CM_VehicleVisitRecordSet;
begin
	create cvSet transient;
	
	if not self.tblData.visible then
		cvSet.add(self.myCurrentObject.CM_VehicleVisitRecord);
	else
		self.tblData.allSelectedObjects.copy(cvSet);
	endif;
	
	if cvSet &lt;&gt; null then
		foreach currentVisitRecord in cvSet do
			if currentVisitRecord = null then	
				app.msgBox(app.getErrorString (GTE_VehcileVisit_Msg2), app.getErrorString (Receipt), MsgBox_Exclamation_Mark_Icon);	
				return;
			endif;

			app.mousePointer := MousePointer_HourGlass;	
			
			//currentVisitRecord.printReceipt(1, true, self.myTerminal, self.myTerminal.getRoadReceiptReport(), null, null);//par13812
			//12 Dec 2013	NDL	Par 33184
			currentVisitRecord.printRoadReceipt(	1,	//_copies : Integer;
													true,	//_printPreview : Boolean;
													null	//_printerLogicalName : String												
													);
		endforeach;
	else
		app.msgBox(app.getErrorString (GTE_VehcileVisit_Msg2), app.getErrorString (Receipt), MsgBox_Exclamation_Mark_Icon);	
		return;
	endif;
epilog
	delete dialog;
	delete cvSet;
	
	app.mousePointer := MousePointer_Default;
end;</source>
    </JadeMethod>
    <JadeMethod name="doPrintJRWReport" id="c2afdeaa-08f2-4d74-9e6b-0bf9c3b10baa">
        <source>doPrintJRWReport();
//----------------------------------------------------------------
//	Created:	01 April 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
/*
Changed On	Changed By	Reason
----------	----------	--------------------------------------------------
16 Mar 2010	consw1		PAR #22886 - Leaking report transients
04/12/2012	cnwcs5		par 30413 - translations
*/
constants
	ReportName	= 'CM_VehicleVisitAnalysis';
	
vars
	jrwManager		: JadeReportWriterManager;
	jrwReport		: JadeReportWriterReport;
	jadeReport		: JadeReport;
	jrwTransient	: CM_JRWVehicleVisit;
	tmpVisit		: CM_VehicleVisitRecord;
	numRows,
	i				: Integer;
	cargoType 		: CM_CargoType;
begin

	jrwManager 	:= app.createReportWriterManager();
	jrwReport 	:= jrwManager.getReport(ReportName);

	if jrwReport = null then
		app.msgBox(app.getErrorString (GTE_VehicleVisit_Msg3), app.getErrorString (GTE_VehicleVisit_Msg4), MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	
	jrwTransient := app.myQAFilter.createJRWTransient(CM_JRWVehicleVisit).CM_JRWVehicleVisit;
	
	if jrwTransient = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Failed to create JRW transient singleton');
		return;
	endif;
	
	//set the selection criteria now
	jrwTransient.dateFrom	:= self.filterTimeIn.date().String;
	jrwTransient.dateTo		:= self.filterTimeOut.date().String;
	
	cargoType := app.myRoot.allCargoTypesById[self.filterCargoType];// 25/02/2009 cnwrd1 #18926 (CCMS 1695)
	if cargoType &lt;&gt; null then
		jrwTransient.cargoType	:= 	cargoType.description;
	endif;
	
	jrwTransient.allVehicleVisitRecords.clear();
	
	
	numRows := self.tblData.rows;
	
	foreach i in self.tblData.fixedRows + 1 to numRows do
		tmpVisit := self.tblData.accessRow(i).itemObject.CM_VehicleVisitRecord;
		if tmpVisit = null then
			continue;
		endif;
		
		jrwTransient.allVehicleVisitRecords.add(tmpVisit);
	endforeach;
	

	
	create jadeReport transient;
	
	app.printer.printPreview := false;

	jrwReport.setOutputDestination(JadeReportWriterReport.PRINTER);
	
	jadeReport.description := jrwReport.name;

	app.printer.setReport(jadeReport);
	jrwReport.run();

	app.printPreview(jadeReport, true);
epilog
	abortTransaction;		// to clear any locks held by the report writer
	
	delete jrwReport;
	delete jrwTransient;
	delete jrwManager;
end;</source>
    </JadeMethod>
    <JadeMethod name="doPrintVehicleTurnReport" id="b835f606-f4ee-4f76-8dc4-a04611e1e81e">
        <source>doPrintVehicleTurnReport();

// 04/12/2012	cnwcs5	par 30413 - remove redundant code, translations
vars
	table	:CM_DataTable;
begin
	table := self.tblData;
	if table.rows = table.fixedRows  then
		app.msgBox(app.getErrorString (GTE_VehicleVisit_Msg1),  app.getErrorString (Report_Problem) , MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	
	self.doPrintJRWReport();

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doRefresh" id="100207c2-ee1c-4339-8f4d-40d9eb234728">
        <updating/>
        <source>doRefresh() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 October 2013	cnwndl1	Initial creation

*/

vars

begin
	inheritMethod();
	
	if self.allColumnFilters &lt;&gt; null and not self.allColumnFilters.isEmpty then
		if self.allColumnFilters.includesFiltersFor( self.tblData ) then
			self.allColumnFilters.replaceAllFiltersForTable( self.tblData, null );
			self.applyColumnFilter( self.tblData );
		endif;
	endif;

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doRegenerateBarrier" id="2425fef7-1b02-4b71-b8a1-97268b6747f4">
        <updating/>
        <source>doRegenerateBarrier(_inward : Boolean) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 May 2023	jlier1	Initial creation 57936

*/

vars
	vvr       : CM_VehicleVisitRecord;
	theReturn : Integer;
begin

	while true do
		app.myTrxCA.trxRegenerateBarrierCode(self.myCurrentObject.CM_VehicleVisitRecord, _inward, app.myPassport);
		if  not app.myPassport.trxCompletedOK then
			theReturn := app.showErrorWarningDialog(app.getErrorString(Error), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				// there must have just been warnings that the user has acknowledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			return;
		endif;
		break;
	endwhile;

epilog

end;</source>
        <Parameter name="_inward" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSendBarrerCode" id="02bf8a83-9f64-43d5-ae11-5236de2d3ef8">
        <updating/>
        <source>doSendBarrerCode(_inward : Boolean) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 September 2023	jlier1	Initial creation 60590
14/02/2024	navcs2	Bug 62454: FR | 53667 - Inspection App - Resend Message discrepancy

*/

vars
	pxyRequest			: BGP_APIWSRequest;
	bgpRequest 			: BGP_ExternalWSRequest;
	
begin
	create pxyRequest transient;
	pxyRequest.setDetails(self.myCurrentObject.CM_VehicleVisitRecord, null,null, self.myCurrentObject.CM_VehicleVisitRecord.myTerminal, BGP_APIWSRequest.Type_Barrier);		// 28.06.2023	navcs2	#58433:[58454]
	pxyRequest.setBarrierIn(_inward);	// 14/02/2024	navcs2	Bug 62454
	while true do
		app.myTrxCA.trxCreateBGPRequestExtWS(pxyRequest, bgpRequest,app.myPassport);
		if app.showTrxErrorDialog(app.getErrorString(Error)) then 
			continue;
		endif;
		break;
	endwhile;
	
	//show a message that the 
	if app.myPassport.trxCompletedOK then
		app.msgBox(app.getErrorString(Succe_creat_backg_task_send_ba),app.getErrorString(Information),MsgBox_OK_Only);
	endif;

epilog
	delete pxyRequest;
end;</source>
        <Parameter name="_inward" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSendInspection" id="e4bfdc51-65db-433e-84ea-77137d1bf106">
        <updating/>
        <source>doSendInspection(_vvr : CM_VehicleVisitRecord) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		        Who		Reason
13 December 2022	navmp20	ChangeRequest 55580: EUP - Inspection App checks - Interface and MTN changes
14/02/2024			navcs2 	Bug 62454: FR | 53667 - Inspection App - Resend Message discrepancy
*/

vars
	vvr       : CM_VehicleVisitRecord;
	theReturn : Integer;
begin
	vvr := _vvr;
	while true do
		app.myTrxUA.trxUpdateVVRInspection(vvr, app.myPassport);			// 14/02/2024			navcs2 	Bug 62454
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			global.beep;
			break;
		else
			theReturn := app.showErrorWarningDialog(app.getErrorString(Change_status), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				// there must have just been warnings that the user has acknowledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			return;
		endif;
		break;
	endwhile;
epilog

end;</source>
        <Parameter name="_vvr" type="CM_VehicleVisitRecord"/>
    </JadeMethod>
    <JadeMethod name="doSendToReport" id="c8562a93-04f2-4724-aa47-0228674a0f57">
        <source>doSendToReport(_obj : Object);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 Aug 2025	navhl20 Story MTN-35650: TPT | Uploading of Photos into MTN Production | 2 | Thin Client Changes

*/

vars
	jrwReportName	: String;
	selectedOnly,
	printPreview	: Boolean;
	arrayCheck		: ObjectArray;
	pathList		: StringArray;
	outputType		: Integer;
	filePath		: String;
begin
	app.isReportWriter := true;
	create pathList transient;
	pathList.add( CM_JRWVehicleVisit::allVehicleVisitRecords.name );
	
	//Get the report we want to send our invoice items to and find out whether we want a print preview.
	if app.getReportToSendItems(CM_VehicleVisitView, pathList, selectedOnly , jrwReportName, printPreview, outputType, filePath) then
		//Have to ensure we don't have multiples so check this out here.
		create arrayCheck transient;
		arrayCheck.add(_obj);
		
		app.sendItemsToReport(CM_JRWVehicleVisit, arrayCheck, jrwReportName, printPreview, outputType, filePath);
	endif;
epilog
	delete arrayCheck;
	delete pathList;
	app.isReportWriter := false;
end;</source>
        <Parameter name="_obj" type="Object"/>
    </JadeMethod>
    <JadeMethod name="doShowCargoReview" id="83eb71f2-75d6-414a-852f-e1778b61c9a2">
        <source>doShowCargoReview();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27/09/2023	navkc1	CR 60428 Task 60702: UI - Cargo Review Option in Transport UI

*/

vars
	cgReviewForm			: CMUI_CargoReview;
	criteriaLine			: CM_SelectorCriteriaLine;
	qdef					: CM_QueryDefinition;
	vvr						: CM_VehicleVisitRecord;
	criteriaLines			: CM_SelectorCriteriaLineArray;
	sa						: StringArray;
	ti						: CM_TrackedItem;
begin
	
	if self.tblData.allSelectedObjects.isEmpty() then
		return;
	endif;
	
	cgReviewForm := app.loadForm(CMUI_CargoReview, CMUI_Assistant, true, true, false, self.getMyTerminal(), null).CMUI_CargoReview;
	
	if cgReviewForm = null then
		return;
	endif;
	
	qdef := app.myRoot.allQueryDefinitionObjects[CM_QueryDefinition.TrackedItem_Query_Type, CM_QueryDefinition.TrackedItem_Query_Mode];
	
	if qdef = null then
		return;
	endif;
	
	vvr := self.tblData.allSelectedObjects.first().CM_VehicleVisitRecord;
	
	ti := vvr.getFirstTrackedItemObj(); //27/05/2024	navkc1 Bug 64295
	
	create criteriaLines transient;
	create sa transient;
	
	foreach vvr in self.tblData.allSelectedObjects as CM_VehicleVisitRecord do
		sa.add(vvr.visitNumber);
	endforeach;
	
	criteriaLine := qdef.createCriteriaLine(CM_TrackedItem::getVehicleVisitNumber.name, CM_QueryOperator.Operator_Range, sa.asCSV(false));
	criteriaLines.add(criteriaLine);
	
	criteriaLine := qdef.createCriteriaLine(CM_TrackedItem::site.name, CM_QueryOperator.Operator_Equal, TI_SITE_ONSITE_str);
	criteriaLines.add(criteriaLine);
	
	////27/05/2024	navkc1 Bug 64295
	if ti &lt;&gt; null then
		criteriaLine := null;
		if ti.isTrailer() then
			criteriaLine := qdef.createCriteriaLine(CM_TrackedItem::getOnboardStatus.name, CM_QueryOperator.Operator_Equal, app.getErrorString(Trailer));
		elseif ti.isMAFI() then
			criteriaLine := qdef.createCriteriaLine(CM_TrackedItem::getOnboardStatus.name, CM_QueryOperator.Operator_Equal, app.getErrorString(Mafi));
		endif;
		
		if criteriaLine &lt;&gt; null then
			criteriaLines.add(criteriaLine);
		endif;
	endif;
	
	cgReviewForm.createCriteriaLinesFromParent(criteriaLines);
	cgReviewForm.setParentForm(self);
	cgReviewForm.show();
	cgReviewForm.autoDoCustDocFromParent(); //23/02/2023	navkc1 CR 62580 Task 62581
epilog
	delete criteriaLines;
	delete sa;
end;</source>
    </JadeMethod>
    <JadeMethod name="doShowPhotoForm" id="7b22feb6-563d-4344-b787-06b21bbcd9a9">
        <source>doShowPhotoForm();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 Aug 2025	navhl20 Story MTN-35650: TPT | Uploading of Photos into MTN Production | 2 | Thin Client Changes
*/

vars
	photoForm 	: CMUI_CargoPhotosForm;
	photos 		: ObjectArray;
begin

	if self.myCurrentObject = null or
	   (not self.myCurrentObject.isKindOf(CM_VehicleVisitRecord)) then
		return;
	endif;
	
	self.myAssistant.showPhotosForm(null, null, null, self.myCurrentObject.CM_VehicleVisitRecord, photos, self.myMasterMenuAction);
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doThumbnailDClick" id="28e63211-8a9d-410d-abcb-344a00f6e0c4">
        <source>doThumbnailDClick();
// ---------------------------------------------------------------------------
// Created:     Sept 2013 ANDREW BISHOP
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//	32585 Oct 2013 covers this
// ---------------------------------------------------------------------------

vars
	found 			: Boolean;
	table 			: Table;
	cellValue,tiID 	: String;
	ti, theTI 			: CM_TrackedItem;
	strPos, row		: Integer;
	tiSet 			: CM_TISet;
	vvr 			: CM_VehicleVisitRecord;
begin

	table := self.tblThumb;
	if table.row &lt; 1 then 
		return;
	endif;
		
	cellValue := table.accessCell(table.row,CM_EntryTable.ColumnHeading).text;
	row := table.row;
	while cellValue = null and row &gt; 1 do
		row 		:= row -1;
		cellValue 	:= table.accessCell(row, CM_EntryTable.ColumnHeading).text;
	endwhile;

	// ### GET THE TI AND SHOW ENQUIRY
		
	if cellValue.trimBlanks() = "ID" then
		vvr:= self.myCurrentObject.CM_VehicleVisitRecord;
		
		strPos	:= 1;
		tiID 	:= table.accessCell(table.row, CM_EntryTable.ColumnValue).text.scanUntil(" ", strPos);
		if tiID &lt;&gt; null then
			foreach ti in vvr.allReceivedTrackedItems do
				if ti.myCargoType.isBreakBulkMulti then
					if tiID.pos(ti.id,1 ) &gt; 0 then
						theTI:=ti;
						break;
					endif;
				endif;
				if ti.id = tiID then
					theTI:=ti;
					break;
				endif;
			endforeach;
			// ### ONSITE
			if theTI = null then 		
				foreach ti in vvr.allReleasedTrackedItems do
					if ti.myCargoType.isBreakBulkMulti then
						if tiID.pos(ti.id,1 ) &gt; 0 then
							theTI:=ti;
							break;
						endif;
					endif;
					if ti.id = tiID then
						theTI:=ti;
						break;
					endif;
				endforeach;
			endif;
			
			// ### OFFSITE		
			if theTI &lt;&gt; null then 
				self.myAssistant.showCargoEnquiryForm(theTI, self.myMasterMenuAction, true, false);		
			endif;
			
		endif;
	
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="doUpdateBarrierInTime" id="017c7d62-e270-43c0-93e5-3e40a4223172">
        <source>doUpdateBarrierInTime();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 May 2023	jlier1	Initial creation 57936

*/

vars
	form : GTE_EditBarrierInTimeForm;
	theReturn : Integer;
	newBarrierDT : TimeStamp;
	vvr : CM_VehicleVisitRecord;
begin	
	vvr := self.myCurrentObject.CM_VehicleVisitRecord;
	
	if vvr = null then
		return;
	endif;

	form := app.loadForm(GTE_EditBarrierInTimeForm, 
							GTE_Assistant, 
							false, false, true, 
							self.myTerminal, null).GTE_EditBarrierInTimeForm;
	if  form.showModal() &lt;&gt; IDOK then
		return;
	endif;
	
	newBarrierDT.setDate(form.txtBarrierInDate.getDate());
	newBarrierDT.setTime(form.txtBarrierInTime.getTime());
	
	newBarrierDT:=self.localToSystemTime(newBarrierDT);
	if not newBarrierDT.isValid() then
		return;
	endif;
	
	while true do
		app.myTrxUA.trxUpdateBarrierInTime(vvr,newBarrierDT,false, app.myPassport);
		if not app.myPassport.trxCompletedOK then
			theReturn := app.showErrorWarningDialog(app.getErrorString(Change_status), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;	
			return;
		endif;
		break;
	endwhile;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doUpdateChangeStatus" id="e3cf712e-62a6-4169-a5a8-9e62b3ccb912">
        <updating/>
        <source>doUpdateChangeStatus(_vvr : CM_VehicleVisitRecord input) updating;
// ---------------------------------------------------------------------------
// Created:     16 October 2017 by jlgns1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
////18/10/17 jlgns1 TFS 7115 PKT - Vehicle visit dispute occurs at GATE OUT
// ---------------------------------------------------------------------------

vars
	theReturn : Integer;
begin
	if _vvr = null then
		return;
	endif;
	while true do
		app.myTrxUA.trxUpdateInOutGateStatus(_vvr,CMGTE_Entity.Status_Cancelled, app.myPassport);
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			global.beep;
			break;
		else
			theReturn := app.showErrorWarningDialog(app.getErrorString(Change_status), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			return;
		endif;
		break;
	endwhile;

epilog

end;</source>
        <Parameter name="_vvr" type="CM_VehicleVisitRecord" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doVbsSlotClick" id="195c834f-e649-445a-bfbf-218060fd8e10">
        <updating/>
        <source>doVbsSlotClick(menuItem: MenuItem input) updating, protected;
/*

Purpose:			Disassociates a vehicle booking time slot from a vehicle visit record

Parameters:			menuItem	MenuItem	The menu item to use to get the vehicle booking time slot from

Return Value:		NONE


Date		Who		Reason
19 May 2023	navpw1	Initial creation TFS: 54049 (55843)

*/

vars
	theReturn	: Integer;
	vbts		: CM_VehicleBookingTimeSlot;
	
begin	
	if menuItem.userObject = null then
		return;
	endif;
	
	vbts := menuItem.userObject.CM_VehicleBookingTimeSlot;
	
	while true do
		app.myTrxUA.trxDisassocVehicleBookingVvr(vbts, app.myPassport);
		
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			break;
		else
			theReturn := app.showErrorWarningDialog(app.getErrorString(Vehicle_schedul_booking_slot), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				// there must have just been warnings that the user has acknowledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			return;
		endif;
		break;
	endwhile;
	
end;</source>
        <access>protected</access>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doVehicleVisitCancel" id="c62ff71b-0ff8-4f9a-b1af-3105c1471778">
        <updating/>
        <source>doVehicleVisitCancel(_vvr : CM_VehicleVisitRecord;_reason :String) updating, protected;
/*
Date		Who		Reason
24 February 2012	cnwrd1	Initial creation
//18/10/17 jlgns1 TFS 7115 PKT - Vehicle visit dispute occurs at GATE OUT
*/
vars
	theReturn	: Integer;
	aVVR 		: CM_VehicleVisitRecord;
begin
	aVVR := _vvr;
	
//	if	aVVR.myRoadJob &lt;&gt; null and not aVVR.isUpdatable then
	if	aVVR.myRoadJob &lt;&gt; null and not aVVR.isUpdatable and not aVVR.isBulkGateVVR then		
		while true do
			app.myTrxUA.trxUpdateVVRCancelWithJob(aVVR, _reason, app.myPassport);
			
			if app.myPassport.trxCompletedOK then
					// Clear errors/warnings from form and err/warnings window
					self.clearErrorWarnings();
					break;
			else
					theReturn := app.showErrorWarningDialog(app.getErrorString(GateInOut), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
					if app.myPassport.noErrors and
					   theReturn = IDOK then
							// there must have just been warnings that the user has acknoledged so ..
							app.myPassport.warningsAcknowledged     := true;
							continue;
					endif;
					self.setAllErrorWarnings(app.myPassport);       // copies errors to this form and shows in err/warnings window
					return;
			endif;
			break;
		endwhile;	
	
		return;
	endif;
		
	while true do
		app.myTrxUA.trxUpdateVVRCancel(aVVR, _reason, app.myPassport);
		
        if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			break;
        else
			theReturn := app.showErrorWarningDialog(app.getErrorString(GateInOut), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
					// there must have just been warnings that the user has acknoledged so ..
					app.myPassport.warningsAcknowledged     := true;
					continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);       // copies errors to this form and shows in err/warnings window
			return;
        endif;
        break;
	endwhile;	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_vvr" type="CM_VehicleVisitRecord"/>
        <Parameter name="_reason" type="String"/>
    </JadeMethod>
    <JadeMethod name="getExtraPermissions" id="9389037e-0e05-4188-b488-5623974c3c10">
