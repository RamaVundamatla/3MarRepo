    <JadeMethod name="getReportParamValueType" id="f8d239c6-0e4f-44fa-a4a4-153b745cd437">
        <source>getReportParamValueType(_paramValue : String) : Integer;
/*

Purpose:			Used when validating user input matches the expected report parameter type

Parameters:			

Return Value:		

Date				Who		Reason
07 October 2022		navmv20	Bug 53554: MTN - Web Portal - Missing Validation when running the report
30 November 2022	navmd1	TFS 55643 Moved from JMTUserInterfaceService::findReportParamValueType

*/

vars

begin
	if _paramValue.isInteger then
		return Integer.number;
	elseif _paramValue.cnIsBoolean then
		return Boolean.number;
	elseif _paramValue.isDecimal then
		return Decimal.number;
	elseif _paramValue.isAlpha and _paramValue.length = 1 then
		return Character.number;
	endif;
	
	return String.number;
epilog

end;</source>
        <Parameter name="_paramValue" type="String"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getSelectedActualVoyage" id="198e92da-e164-4c18-930a-bca6f942d2a7">
        <source>getSelectedActualVoyage(): CM_VoyageGlobal;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 September 2008	cnwkao1	Initial creation - based on WebSchema implementation

*/

vars
	tmpStr			: String;
	globalVoyage	: CM_VoyageGlobal;
	reportParam		: WS_ReportParameter;
	
begin

	reportParam := self.allWSReportParams.getAtKey(ETRow_VoyageActual);
	if reportParam &lt;&gt; null then
		tmpStr := reportParam.value;
	endif;	
	
	//global.getExtraData(self.allQueryCriteria, ETRow_VoyageActual, tmpStr);
	
	globalVoyage := tmpStr.asOid.CM_VoyageGlobal;
	
	return globalVoyage;

end;</source>
        <ReturnType type="CM_VoyageGlobal"/>
    </JadeMethod>
