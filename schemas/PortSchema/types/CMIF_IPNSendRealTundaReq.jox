	_realRequest.nomorPpk := self.nomorPpk;
	_realRequest.nomorPpkbTunda := self.nomorPpkbTunda;
	_realRequest.prosentase := self.prosentase;
	_realRequest.tanggalMulaiTunda := self.tanggalMulaiTunda;
	_realRequest.tanggalSelesaiTunda := self.tanggalSelesaiTunda;
	_realRequest.tarifTVariabel := self.tarifTVariabel;
	_realRequest.tarifTetap := self.tarifTetap;

epilog

