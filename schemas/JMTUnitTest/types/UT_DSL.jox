    <JadeMethod name="releaseAssignCargo" id="4ac37733-ea14-46d2-bee9-f72bf226c9e8">
        <source>releaseAssignCargo(_release : CM_BulkRelease; _allTIPins : CM_StringDict; _ti: CM_TrackedItem);
//04 November 2009	cnwml2
//+cnwml2 MSL CCMS 1012
//23/06/2023	navkc1	CR 58406 Task 58408: Jade - Release Request All Tracked Items

vars
	pxyBulkRelease : CM_BulkRelease;
	cmif_BulkRelease : CMIF_BulkRelease;
	skipTotalRequested : Boolean;
	
begin
	
	if _release.isTransient() then
		pxyBulkRelease := _release;
	else
		pxyBulkRelease	:=	app.createUpdateProxy(_release).CM_BulkRelease;
	endif;
	pxyBulkRelease.allReserveDetails.first.CM_ReserveSelection.allTrackedItems.add(_ti);
	//pxyBulkRelease.allReserveDetails.first.CM_ReserveSelection.setTotalRequested(pxyBulkRelease.allReserveDetails.first.CM_ReserveSelection.allTrackedItems.size);
	if self.opts.includesKey(UT_OPTS_SkipTotalRequested) and self.opts.bool(UT_OPTS_SkipTotalRequested) then
		skipTotalRequested := true;
	endif;
	
	if not skipTotalRequested then
		pxyBulkRelease.allReserveDetails.first.CM_ReserveSelection.setTotalRequested(pxyBulkRelease.allReserveDetails.first.CM_ReserveSelection.getAllTrackedItemsSize(false)); //23/06/2023	navkc1	CR 58406 Task 58408
	endif;
	
	pxyBulkRelease.allTrackedItemsAssigned.add(_ti);	
	app.myTrxUA.trxUpdateBulkRelease(pxyBulkRelease, _allTIPins, app.myPassport); //cnwrd1 par 25594 10.12.2010

	self.assertNoTrxErrorsOrWarnings();
	
epilog
	delete pxyBulkRelease;
end;</source>
        <Parameter name="_release" type="CM_BulkRelease"/>
        <Parameter name="_allTIPins" type="CM_StringDict"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="releaseAssignCargoWithWaybill" id="4b72bb7e-9420-4c16-adb3-84ad91ab7798">
        <updating/>
        <source>releaseAssignCargoWithWaybill(_release : CM_BulkRelease; _ti: CM_TrackedItem)updating;
//04 November 2009	cnwml2
//+cnwml2 MSL CCMS 1012
//23/06/2023	navkc1	CR 58406 Task 58408: Jade - Release Request All Tracked Items
vars
	pxyBulkRelease : CM_BulkRelease;
	cmif_BulkRelease : CMIF_BulkRelease;
begin
	
	if _release.isTransient() then
		pxyBulkRelease := _release;
	else
		pxyBulkRelease	:=	app.createUpdateProxy(_release).CM_BulkRelease;
	endif;
	pxyBulkRelease.allReserveDetails.first.CM_ReserveSelection.allTrackedItems.add(_ti);
	//pxyBulkRelease.allReserveDetails.first.CM_ReserveSelection.setTotalRequested(pxyBulkRelease.allReserveDetails.first.CM_ReserveSelection.allTrackedItems.size);
	pxyBulkRelease.allReserveDetails.first.CM_ReserveSelection.setTotalRequested(pxyBulkRelease.allReserveDetails.first.CM_ReserveSelection.getAllTrackedItemsSize(false)); //23/06/2023	navkc1	CR 58406 Task 58408
	pxyBulkRelease.allTrackedItemsAssigned.add(_ti);	
	pxyBulkRelease.setAllowCargoOnMultipleRelease(true);
	app.myTrxUA.trxUpdateBulkRelease(pxyBulkRelease,null, app.myPassport); //cnwrd1 par 25594 10.12.2010

	self.assertNoTrxErrorsOrWarnings();
	
epilog
	delete pxyBulkRelease;
end;</source>
        <Parameter name="_release" type="CM_BulkRelease"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="releaseAssignCargoWithoutWay" id="dc6b7056-1b5f-44ac-a3d0-a5b7632a8138">
        <updating/>
        <source>releaseAssignCargoWithoutWay(_release : CM_BulkRelease; _ti: CM_TrackedItem)updating;
//04 November 2009	cnwml2
//+cnwml2 MSL CCMS 1012
//23/06/2023	navkc1	CR 58406 Task 58408: Jade - Release Request All Tracked Items
vars
	pxyBulkRelease : CM_BulkRelease;
	cmif_BulkRelease : CMIF_BulkRelease;
begin
	
	if _release.isTransient() then
		pxyBulkRelease := _release;
	else
		pxyBulkRelease	:=	app.createUpdateProxy(_release).CM_BulkRelease;
	endif;
	pxyBulkRelease.allReserveDetails.first.CM_ReserveSelection.allTrackedItems.add(_ti);
	//pxyBulkRelease.allReserveDetails.first.CM_ReserveSelection.setTotalRequested(pxyBulkRelease.allReserveDetails.first.CM_ReserveSelection.allTrackedItems.size);
	pxyBulkRelease.allReserveDetails.first.CM_ReserveSelection.setTotalRequested(pxyBulkRelease.allReserveDetails.first.CM_ReserveSelection.getAllTrackedItemsSize(false)); //23/06/2023	navkc1	CR 58406 Task 58408
	pxyBulkRelease.allTrackedItemsAssigned.add(_ti);	
	pxyBulkRelease.setAllowCargoOnMultipleRelease(false);
	app.myTrxUA.trxUpdateBulkRelease(pxyBulkRelease, null,  app.myPassport); //cnwrd1 par 25594 10.12.2010

	self.assertExceptionRaised(ERR_CARGO_MULTIPLE_REL, "multiple cargo on releases");
	
	//self.assertNoTrxErrorsOrWarnings();
	
epilog
	delete pxyBulkRelease;
end;</source>
        <Parameter name="_release" type="CM_BulkRelease"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="removeCraneFromAllVoyages" id="7422949e-7207-4b07-90fc-344253f5e9cc">
        <source>removeCraneFromAllVoyages(_crane : CM_Crane io; terminal : CM_Terminal);

/*

Purpose:			Remove the crane from any voyages that it might be attached to

Date				Who		Reason
21 November 2011	cnwmh5	Initial creation

*/

vars

	voyageSet			: CM_VoyageSet;
	tmpVoyageSet		: CM_VoyageSet;
	voyage				: CM_Voyage;
	jobSheet			: CM_JobSheet;
	queue				: CM_VoyageCraneQueue;
	obj					: Object;
	
	queues				: ObjectArray;

begin

	// Shouldn't ever happen but I'm paranoid.  If no terminal then ignore
	if terminal = null then
		return;
	endif;

	// get all the voyages for the terminal
	create voyageSet transient;
	create tmpVoyageSet transient;
	terminal.getAllCargoVoyages(tmpVoyageSet);
	tmpVoyageSet.copyNoDuplicates(voyageSet, false);
	tmpVoyageSet.clear();
	terminal.getAllCellularVoyages(tmpVoyageSet, true, false);
	tmpVoyageSet.copyNoDuplicates(voyageSet, false);
	tmpVoyageSet.clear();
	terminal.getAllCurrentVoyages(tmpVoyageSet, true, false, true);
	tmpVoyageSet.copyNoDuplicates(voyageSet, false);
	
	// read through all the voayge and remove the crane if it exists
	beginTransaction;
	foreach voyage in voyageSet discreteLock where voyage.allJobSheets.isNotEmpty() do
		jobSheet := voyage.allJobSheets[_crane.id];
		if jobSheet &lt;&gt; null then
			delete jobSheet;
		endif;
	endforeach;
	commitTransaction;
	
	// remove the crane from any queues it still remains in 
	if _crane.allCraneQueues.isNotEmpty() then
		create queues transient;
		_crane.allCraneQueues.copy(queues);
		beginTransaction;
		foreach obj in queues discreteLock do
			queue := obj.CM_VoyageCraneQueue;
			queue.setPropertyValue('crane', null);
		endforeach;
		commitTransaction;
	endif;
	
epilog

	delete voyageSet;
	delete tmpVoyageSet;
	delete queues;

end;</source>
        <Parameter name="_crane" type="CM_Crane" usage="io"/>
        <Parameter name="terminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="removeMergeIterCollection" id="c9270927-a686-4bfd-95d9-50b2f3aff6e6">
        <source>removeMergeIterCollection(_dictionary : Dictionary);

/*

Purpose:		Remove the passed in collection from a mergeIterator if it
				exists.

Date			Who		Reason
02/12/2014		cnwmh5	Initial creation

*/

vars

	index 				: Integer;

begin

	if self.myMergeIter = null then
		return;
	endif;
	
	foreach index in 1 to self.myMergeIter.getCollectionCount() do
	
		if myMergeIter.getCollectionAt(index) = _dictionary then
			self.myMergeIter.removeCollection(_dictionary);
			break;
		endif;
	
	endforeach;

epilog

end;</source>
        <Parameter name="_dictionary" type="Dictionary"/>
    </JadeMethod>
    <JadeMethod name="removeQueuesFromGateAreas" id="bf616908-07ff-49c9-979e-4e6aa75d4942">
        <source>removeQueuesFromGateAreas(_gate :CM_Gate)protected;
// ---------------------------------------------------------------------------
// Created:     18 June 2010 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	coll	:CM_ObjectSet;
	obj		:Object;
	queue	:CM_RadioTelemetryQueue;
begin
	create coll transient;
	_gate.getAllGateAreas (coll);
	
	beginTransaction;
	
	foreach obj in coll do 
		
		if not queue.isKindOf (CM_SubQueue) then
			continue;
		endif;
		
		foreach queue in obj.CM_GateArea.allSubRTQueues do
			queue.CM_SubQueue.allMoveFromTAMasters.removeIfPresent (obj.CM_GateArea);
			queue.CM_SubQueue.allMoveToTAMasters.removeIfPresent (obj.CM_GateArea);
		endforeach;
	endforeach;
	
	commitTransaction;
epilog
	delete coll;
end;</source>
        <access>protected</access>
        <Parameter name="_gate" type="CM_Gate"/>
    </JadeMethod>
