    <JadeMethod name="doBaseFormSave" id="47925880-d3c1-4643-b3f8-d8bca0472d48">
        <updating/>
        <source>doBaseFormSave() updating, protected;
// -------------------------------------------
// Created 07 November 2003 by cnwdvb1
// -------------------------------------------
vars

begin

	app.mousePointer := MousePointer_HourGlass;
	self.myCaller.getData(self.frmSelect.getTargetLocationAsStr(), self.type);
	app.mousePointer := MousePointer_Default;
	self.unloadForm();

epilog	
	app.mousePointer := MousePointer_Default;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doResize" id="24f6f1f4-e9d2-406c-b603-6371b1118e36">
        <updating/>
        <source>doResize() updating;
// -------------------------------------------
// Created 07 November 2003 by cnwdvb1
// -------------------------------------------
vars

begin
			
	if self.frmSelect.visible then
		self.frmSelect.top 	:= self.frmToolbar.height;
	endif;
	inheritMethod();
	
end;</source>
    </JadeMethod>
