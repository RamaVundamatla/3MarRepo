    <JadeMethod name="handleJSONException" id="cf6d2e84-a0e9-4e30-8ecd-ac0a2fad783f">
        <source>handleJSONException(_exc : Exception; _parsingError : Boolean io; _errorText, _extendedErrorText : String io) :  Integer protected;
/*

Purpose:			If we ever create a 'JSON' file type then this should be moved down to that level

Parameters:			

Return Value:		

Date			Who		Reason
15 August 2023	navmd1	Initial creation TFS 59811
13 October 2023	navmd1	Suppress string too long errors as well

*/

constants
	JSONErrorRangeStart	: Integer = 11100;
	JSONErrorRangeEnd	: Integer = 11199;
	StringTooLong		: Integer = 1035;

vars
	returnVal		: Integer;
	
begin
	_parsingError := false;

	// Not an exception we care about
	if (_exc.errorCode &lt; JSONErrorRangeStart or _exc.errorCode &gt; JSONErrorRangeEnd) and not _exc.errorCode = StringTooLong then
		returnVal := Ex_Pass_Back;
		return returnVal;
	endif;
	
	// Must be a JSON exception to get this far
	_parsingError := true;
	returnVal := Ex_Resume_Next;
	
	_errorText := "Code :" &amp; _exc.errorCode.String &amp; ". " &amp; _exc.text;
	_extendedErrorText := _exc.extendedErrorText;
	
	app.writeLog(method.qualifiedName &amp; " (" &amp; _exc.errorCode.String &amp; ") " &amp; _errorText &amp; CrLf &amp; _extendedErrorText, LogERROR);
epilog
	return returnVal;
	
end;</source>
        <access>protected</access>
        <Parameter name="_exc" type="Exception"/>
        <Parameter name="_parsingError" type="Boolean" usage="io"/>
        <Parameter name="_errorText" type="String" usage="io"/>
        <Parameter name="_extendedErrorText" type="String" usage="io"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="hasEDIActionForCustomsMessage" id="a88792d8-96ab-4d8a-99cf-3c0c465a47b6">
        <source>hasEDIActionForCustomsMessage(_dispositionCode : String) : Boolean;
//----------------------------------------------------------------------
// Created by 	cnwsh3
// Date 		25 September 2009
//
// Implemented version: JMT 7.7.3
// Date  		User  		Change
// 25/09/2009 	cnwsh3 		CCMS SFW1044 PARXXXX - AMS changes
//----------------------------------------------------------------------
vars
	ediAction : CM_EDIAction;
	dispositionFound : Boolean;
begin
	foreach ediAction in self.allEDIActions where ediAction.keyword = _dispositionCode do
		if ediAction.hasValidActionType() then
			return true;
		endif;
	endforeach;
	return false;
epilog
end;</source>
        <Parameter name="_dispositionCode" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
