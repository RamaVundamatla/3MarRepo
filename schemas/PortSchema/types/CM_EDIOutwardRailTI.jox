    <JadeMethod name="getTranslationForIMEX" id="45a96f36-c7a7-4204-90bf-8e8e413ab67d">
        <source>getTranslationForIMEX(ti : CM_TrackedItem) : String;
//--------------------------------------------------------------
//Created: December 2001 By: cnwgd1
//--------------------------------------------------------------
// 15/07/2010	cnwdap1		PAR #25021 review use of isImport/isExport for tranships
vars
    str : String;
begin

	if ti.isExport then
		 str := "EXP";
	elseif ti.isImport then
		 str := "IMP";
	elseif ti.isRehandle then
		 str := "DLR";
	elseif ti.isSOB then
		 str := "SOB";
	elseif ti.isInTransitOnShip then
		 str := "Transit";
	elseif ti.isStorage then 
		 str := "Storage";
	elseif ti.isTranshipItem then		// PAR #25021
		str := "Tranship";				// PAR #25021
	endif;
	return str;
end;</source>
        <Parameter name="ti" type="CM_TrackedItem"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getVoyageCode" id="921df55c-e0c8-47ab-87b9-bf613cfc83b6">
