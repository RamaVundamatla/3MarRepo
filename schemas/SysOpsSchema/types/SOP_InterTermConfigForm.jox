    <JadeMethod name="setupForAdd" id="81328f25-b3bb-4847-b3c0-b2671816157e">
        <updating/>
        <source>setupForAdd() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
01 February 2010	conkc1	Initial creation

*/

vars

begin
	cmbConfigName.visible  := false;
	tbxConfigName.left     := cmbConfigName.left;
	tbxConfigName.top      := cmbConfigName.top;
	tbxConfigName.visible  := true;
	tbxConfigName.enabled  := true;
	tbxRelNumber.readOnly  := false;
	btnSave.enabled        := true;
	
	self.myInterTerminalConfig := null;

	doLoadTerminalAreas;
	
	self.lstDestination.clear;

	self.grpMultiSelect.formDisplayEntryMethodName := SOP_InterTermConfigForm::getTerminalAreaName.name;
	self.grpMultiSelect.setAvailable(self.allAvailableTerminalAreas, true); 
	self.grpMultiSelect.setSelected(self.allSelectedTerminalAreas);

	enableControls;
	self.resetMyReferences;
	btnDelete.enabled := false;
	btnEdit.enabled   := false;
	btnAdd.enabled    := false;	//29 Mar 2011	NDL	Par 25686
	tbxConfigName.setFocus;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupForEdit" id="6efcd967-e8a0-4eba-8b93-6e99f08df392">
        <updating/>
        <source>setupForEdit() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 February 2010	conkc1	Initial creation

*/

vars

begin
	cmbConfigName.visible  := true;
	cmbConfigName.enabled  := false;
	tbxConfigName.visible  := false;
	tbxRelNumber.readOnly  := true;
	enableControls;
	btnSave.enabled        := true;
	btnOk.visible          := false;

