    <JadeMethod name="isWeight_Compare" id="4e71703f-7a93-4cd0-896c-4221e12aef20">
        <source>isWeight_Compare(range: Object; weight: Integer): Boolean;
//
// Changed On	By			Reason
// ----------	--------	---------------------------------------------------
// 10/06/2013	cnwdap1		PAR #31721 Imperial Measurements on Yard Allcoation What If
begin
	//return weight &gt;= range.CM_WeightRange.lower and																						// PAR #31721
	//	   weight &lt;= range.CM_WeightRange.upper;																							// PAR #31721
	return weight &gt;= app.convertMeasurementForStorage(range.CM_WeightRange.myMeasurementType.shortName, range.CM_WeightRange.lower) and		// PAR #31721
		   weight &lt;= app.convertMeasurementForStorage(range.CM_WeightRange.myMeasurementType.shortName, range.CM_WeightRange.upper);		// PAR #31721
end;</source>
        <Parameter name="range" type="Object"/>
        <Parameter name="weight" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isWeight_Match" id="a19abe9b-4fa1-47ef-98e3-2b4443953a9d">
        <source>isWeight_Match(_yaData: CM_YADataObjects): Boolean;
// -------------------------------------------
// Created 31 May 2005 by cnwdvb1
// -------------------------------------------
vars

	weight	: Decimal[14,4];
	range	: Object;

begin

	weight := self.theTotalWeight;
	
	// Only priorities will be empty.
	if _yaData.isEmpty() then
		return true;
	endif;
	
	return _yaData.visitObjectsUntilTrue(self, CMIF_YAAutoPlanSenario::isWeight_Compare, weight);

end;</source>
        <Parameter name="_yaData" type="CM_YADataObjects"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="populateCriteriaFromRequest" id="63f6a491-770b-402a-81f4-e71836d6cf8b">
        <updating/>
        <source>populateCriteriaFromRequest( request : CM_DeliveryRequest ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 February 2014	cnwndl1	Initial creation	Par 33439 - CCMS 2311

*/

vars

	int			: Integer;
	availGrade	: CM_MTGrade;
	isoType 	: CM_ISOType;
	isoGroup 	: CM_ISOTypeGroup;
	criteria 	: CM_YACriteria;
	consignee	: CM_ConsigneeConsignor;
	consignor 	: CM_ConsigneeConsignor;
	voyage 		: CM_Voyage;
	operator	: CM_Operator;
	commodity 	: CM_Commodity;
	carrier 	: CM_Carrier;
	objSet 		: ObjectSet;
	root   		: CM_Root;
begin

	create objSet transient;

	root := app.myRoot;
	
	if request.isoGroup &lt;&gt; null
	or request.isoType &lt;&gt; null
	or request.myCargoType &lt;&gt; null and request.myCargoType = root.allCargoTypesById[ TI_CargoType_Container ]
	then
		create criteria transient;
		objSet.clear();
		objSet.add(root.allCargoTypesById[ TI_CargoType_Container ]);
		criteria.setProxy(root.allYACriteriaTypes[YACriteriaType_CargoType], objSet, null);
		self.allScenarioCriteria.add( criteria );
	else
		if request.myCargoType &lt;&gt; null then
			create criteria transient;
			objSet.clear();
			objSet.add(request.myCargoType);
			criteria.setProxy(root.allYACriteriaTypes[YACriteriaType_CargoType], objSet, null);
			self.allScenarioCriteria.add( criteria );
		endif;
	endif;
	
	if request.isoGroup &lt;&gt; null then
		isoGroup := root.allISOTypeGroups[request.isoGroup];
		if isoGroup &lt;&gt; null then
			create criteria transient;
			objSet.clear();
			objSet.add(isoGroup);
			criteria.setProxy(root.allYACriteriaTypes[YACriteriaType_ISOGroup], objSet, null);
			self.allScenarioCriteria.add( criteria );
		endif;
	endif;
	
	if request.isoType &lt;&gt; null then
		isoType := root.allISOTypes[request.isoType];
		if isoType &lt;&gt; null then
			create criteria transient;
			objSet.clear();
			objSet.add(isoType);
			criteria.setProxy(root.allYACriteriaTypes[YACriteriaType_ISO], objSet, null);
			self.allScenarioCriteria.add( criteria );
		endif;
	endif;
	
	if request.consignee &lt;&gt; null then
		consignee := root.allConsigneeConsignors[request.consignee];
		if consignee &lt;&gt; null then
			create criteria transient;
			objSet.clear();
			objSet.add(consignee);
			criteria.setProxy(root.allYACriteriaTypes[YACriteriaType_Consignee], objSet, null);
			self.allScenarioCriteria.add( criteria );
		endif;
	endif;
	
	if request.voyageCode &lt;&gt; null then
		voyage := request.getVoyage;
		if voyage &lt;&gt; null then
			create criteria transient;
			objSet.clear();
			objSet.add(voyage);
			criteria.setProxy(root.allYACriteriaTypes[YACriteriaType_Voyage], objSet, null);
			self.allScenarioCriteria.add( criteria );
		endif;
	endif;
	
	if request.operatorCode &lt;&gt; null then
		operator := root.allOperators[request.operatorCode];
		if operator &lt;&gt; null then
			create criteria transient;
			objSet.clear();
			objSet.add(operator);
			criteria.setProxy(root.allYACriteriaTypes[YACriteriaType_OperatorItem], objSet, null);
			self.allScenarioCriteria.add( criteria );
		endif;
	endif;
	
	if not request.allAvailabilityGrades.isEmpty then
		create criteria transient;
		objSet.clear();
		//request.allAvailabilityGrades.copy(objSet);
		// 35012 copy availability grade objects instead
		foreach int in request.allAvailabilityGrades do
			availGrade := root.allAvailabilityGrades[int];
			if availGrade &lt;&gt; null then
				objSet.add(availGrade);
			endif;
		endforeach;
		criteria.setProxy(root.allYACriteriaTypes[YACriteriaType_AvGrade], objSet, null);
		self.allScenarioCriteria.add( criteria );
	endif;
	
	if request.billOfLading &lt;&gt; null then
		create criteria transient;
		criteria.setProxy(root.allYACriteriaTypes[YACriteriaType_BOL], request.billOfLading, null);
		self.allScenarioCriteria.add( criteria );
	endif;
	
	if request.clean then
		create criteria transient;
		criteria.setProxy(root.allYACriteriaTypes[YACriteriaType_Clean], true, null);
		self.allScenarioCriteria.add( criteria );
	endif;
	
	if request.commodity &lt;&gt; null then
		commodity := root.allCommodities.getAtKey(request.commodity);
		create criteria transient;
		objSet.clear();
		objSet.add(commodity);
		criteria.setProxy(root.allYACriteriaTypes[YACriteriaType_Commodity], objSet, null);
		self.allScenarioCriteria.add( criteria );
	endif;
	
	if request.heavyRated then
		create criteria transient;
		criteria.setProxy(root.allYACriteriaTypes[YACriteriaType_HeavyDuty], true, null);
		self.allScenarioCriteria.add( criteria );
	endif;
	
	if request.mySubCargoType &lt;&gt; null then
		create criteria transient;
		objSet.clear();
		objSet.add( request.mySubCargoType);
		criteria.setProxy(root.allYACriteriaTypes[YACriteriaType_Product], objSet, null);
		self.allScenarioCriteria.add( criteria );
	endif;
	
	if request.myOriginatingBulkRelease &lt;&gt; null then
	
		if request.myOriginatingBulkRelease.consignorCode &lt;&gt; null then
			consignor := root.allConsigneeConsignors[request.myOriginatingBulkRelease.consignorCode];
			if consignor &lt;&gt; null then
				create criteria transient;
				objSet.clear();
				objSet.add(consignor);
				criteria.setProxy(root.allYACriteriaTypes[YACriteriaType_Consignor], objSet, null);
				self.allScenarioCriteria.add( criteria );
			endif;
		endif;
		
		if request.myOriginatingBulkRelease.carrierId &lt;&gt; null then
			carrier := root.allCarriers[request.myOriginatingBulkRelease.carrierId];
			if carrier &lt;&gt; null then
				create criteria transient;
				objSet.clear();
				objSet.add(carrier);
				criteria.setProxy(root.allYACriteriaTypes[YACriteriaType_Carrier], objSet, null);
				self.allScenarioCriteria.add( criteria );
			endif;
		endif;
		
		if request.myOriginatingBulkRelease.myBookingRefStock &lt;&gt; null then
			create criteria transient;
			objSet.clear();
			objSet.add(request.myOriginatingBulkRelease.myBookingRefStock);
			criteria.setProxy(root.allYACriteriaTypes[YACriteriaType_BookingRef], objSet, null);
			self.allScenarioCriteria.add( criteria );
		endif;
	endif;
	
epilog
	delete objSet;
end;</source>
        <Parameter name="request" type="CM_DeliveryRequest"/>
    </JadeMethod>
    <JadeMethod name="populateCriteriaFromReserveSel" id="023e14e2-fd70-4199-8448-f90121abb832">
        <updating/>
        <source>populateCriteriaFromReserveSel(_reserveSelection : CM_ReserveSelection) updating;
/*

Date		Who		Reason
11 November 2014	cnwer1	Initial creation PAR
*/

vars
	int			  : Integer;
	availGrade	  : CM_MTGrade;
	objSet 		  : ObjectSet;
	criteria 	  : CM_YACriteria;
	consignee 	  : CM_ConsigneeConsignor;
	dischargePort : String;
	port 		  : CM_Port;
	root          : CM_Root;
	reserveCT     : CM_CargoType;
	reserveIsoType: CM_ISOType;
	bulkRelease   : CM_BulkRelease;
begin
	
	if _reserveSelection = null then
		return;
	endif;
	
	root 			:= app.myRoot;
	reserveCT		:= _reserveSelection.myCargoType;
	reserveIsoType  := _reserveSelection.myISOType;
	
	create objSet transient;
	
	if reserveCT &lt;&gt; null then
		create criteria transient;
		objSet.clear();
		objSet.add(reserveCT);
		criteria.setProxy(root.allYACriteriaTypes[YACriteriaType_CargoType], objSet, null);
		self.allScenarioCriteria.add( criteria );	
	endif;
	
	
	if reserveIsoType &lt;&gt; null
	or _reserveSelection.myISOGroup &lt;&gt; null and reserveCT = null then
		create criteria transient;
		objSet.clear();
		objSet.add(root.allCargoTypesById[ TI_CargoType_Container ]);
		criteria.setProxy(root.allYACriteriaTypes[YACriteriaType_CargoType], objSet, null);
		self.allScenarioCriteria.add( criteria );
	endif;
	
	
	if _reserveSelection.myISOGroup &lt;&gt; null then
		create criteria transient;
		objSet.clear();
		objSet.add(_reserveSelection.myISOGroup);
		criteria.setProxy(root.allYACriteriaTypes[YACriteriaType_ISOGroup], objSet, null);
		self.allScenarioCriteria.add( criteria );
		
	endif;
	
	if reserveIsoType &lt;&gt; null then
		create criteria transient;
		objSet.clear();
		objSet.add(reserveIsoType);
		criteria.setProxy(root.allYACriteriaTypes[YACriteriaType_ISO], objSet, null);
		self.allScenarioCriteria.add( criteria );
		
		if reserveIsoType.myISOTypeGroup &lt;&gt; null then  // ### PAR 37093
			create criteria transient; 				   // ### PAR 37093
			objSet.clear(); 						   // ### PAR 37093
			objSet.add(reserveIsoType.myISOTypeGroup); // ### PAR 37093
			criteria.setProxy(root.allYACriteriaTypes[YACriteriaType_ISOGroup], objSet, null); // ### PAR 37093
			self.allScenarioCriteria.add( criteria );  // ### PAR 37093
		endif;
	endif;
	
	if _reserveSelection.myProduct &lt;&gt; null then
		create criteria transient;
		objSet.clear();
		objSet.add( _reserveSelection.myProduct);
		criteria.setProxy(root.allYACriteriaTypes[YACriteriaType_Product], objSet, null);
		self.allScenarioCriteria.add( criteria );
	endif;
	
	if _reserveSelection.getConsigneeCode &lt;&gt; null then
		consignee := root.allConsigneeConsignors[_reserveSelection.getConsigneeCode ];
		if consignee &lt;&gt; null then
			create criteria transient;
			objSet.clear();
			objSet.add(consignee);
			criteria.setProxy(root.allYACriteriaTypes[YACriteriaType_Consignee], objSet, null);
			self.allScenarioCriteria.add( criteria );
		endif;
	endif;
	
	if _reserveSelection.getMyVoyage &lt;&gt; null then
		create criteria transient;
		objSet.clear();
		objSet.add(_reserveSelection.getMyVoyage);
		criteria.setProxy(root.allYACriteriaTypes[YACriteriaType_Voyage], objSet, null);
		self.allScenarioCriteria.add( criteria );
	endif;
	
	if _reserveSelection.getOperator &lt;&gt; null then
		create criteria transient;
		objSet.clear();
		objSet.add(_reserveSelection.getOperator);
		criteria.setProxy(root.allYACriteriaTypes[YACriteriaType_OperatorItem], objSet, null);
		self.allScenarioCriteria.add( criteria );
	endif;
	
	if not _reserveSelection.allAvailabilityGrades.isEmpty then
		create criteria transient;
		objSet.clear();
		//request.allAvailabilityGrades.copy(objSet);
		// 35012 copy availability grade objects instead
		foreach int in _reserveSelection.allAvailabilityGrades do
			availGrade := root.allAvailabilityGrades[int];
			if availGrade &lt;&gt; null then
				objSet.add(availGrade);
			endif;
		endforeach;
		criteria.setProxy(root.allYACriteriaTypes[YACriteriaType_AvGrade], objSet, null);
		self.allScenarioCriteria.add( criteria );
	endif;

	if _reserveSelection.clean then
		create criteria transient;
		criteria.setProxy(root.allYACriteriaTypes[YACriteriaType_Clean], true, null);
		self.allScenarioCriteria.add( criteria );
	endif;
	
	if _reserveSelection.myBOLIn &lt;&gt; null then
		create criteria transient;
		criteria.setProxy(root.allYACriteriaTypes[YACriteriaType_BOL],  _reserveSelection.myBOLIn.number, null);
		self.allScenarioCriteria.add( criteria );
	endif;
	
	if _reserveSelection.heavyRated then
		create criteria transient;
		criteria.setProxy(root.allYACriteriaTypes[YACriteriaType_HeavyDuty], true, null);
		self.allScenarioCriteria.add( criteria );
	endif;
	
	dischargePort :=_reserveSelection.getDischargePort;
	if dischargePort &lt;&gt; null then
		port := root.allPorts[dischargePort];
		if port &lt;&gt; null then
			create criteria transient;
			objSet.clear();
			objSet.add(port);
			criteria.setProxy(root.allYACriteriaTypes[YACriteriaType_DischargePort], objSet, null);
			self.allScenarioCriteria.add( criteria );
		endif;
	endif;
	
	bulkRelease := _reserveSelection.myReserveHeader;
	
	if bulkRelease &lt;&gt; null then
		if _reserveSelection.myReserveHeader.carrierId &lt;&gt; null then
			create criteria transient;
			objSet.clear();
			objSet.add(bulkRelease.getCarrier);
			criteria.setProxy(root.allYACriteriaTypes[YACriteriaType_Carrier], objSet, null);
			self.allScenarioCriteria.add( criteria );
			
		endif;
		
		if bulkRelease.myConsignor &lt;&gt; null then
			create criteria transient;
			objSet.clear();
			objSet.add(bulkRelease.myConsignor);
			criteria.setProxy(root.allYACriteriaTypes[YACriteriaType_Consignor], objSet, null);
			self.allScenarioCriteria.add( criteria );
		endif;
	endif;
	
epilog
	delete objSet;
end;</source>
        <Parameter name="_reserveSelection" type="CM_ReserveSelection"/>
    </JadeMethod>
    <JadeMethod name="populateFromReceival" id="fcaf6fe4-d352-4ee2-a1b7-0682d8f14e0c">
        <updating/>
        <source>populateFromReceival(_receival : CMGTE_Receival) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 31/07/2017	jlgdap1		Initial creation TFS 5609 SNO Road Gate Check Criteria
// 04 Nov 2020  cnwma1 		ChangeRequest 50112: ASPA - GCI Stevedores
vars

begin
	_receival.allTIHazards.copy(self.allHazards);
	self.availabilityGrade  := _receival.getAvailabilityGrade;
	self.billOfLading 		:= _receival.billOfLading;
	self.cargoHeight 		:= _receival.height.String;
	self.cargoLength 		:= (_receival.dimLenFront + _receival.dimLenRear).String;
	self.cargoWidth 		:= (_receival.dimWidthLeft + _receival.dimWidthRight).String;
	self.colour 			:= _receival.colour;
	self.curtainsIn 		:= _receival.curtainsIn;
	self.directDelivery 	:= _receival.directDelivery;
	self.id 				:= _receival.id;
	self.isOverDimensions	:= _receival.isOverDimensions;
	self.mark 				:= _receival.mark;
	self.myCommodity 		:= app.myRoot.allCommodities[_receival.commodity];
	self.myConsignee 		:= app.myRoot.allConsigneeConsignors[_receival.consigneeCode];
	self.myConsignor 	    := app.myRoot.allConsigneeConsignors[_receival.consignorCode];
	self.myDischargePort	:= app.myRoot.allPorts[_receival.dischargePort];
	self.myIMEXStatus 		:= app.myRoot.allImexStatuses[_receival.imexStatus];
	self.myLoadPort 		:= app.myRoot.allPorts[_receival.loadPort];
	self.myOperator 		:= _receival.getOperatorObject;
	self.myTranshipToPort   := _receival.myTranshipToPort;
	self.myVoyage 			:= _receival.myTerminal.lookupVoyage(_receival.voyageCode, null, false);
	if self.myVoyage &lt;&gt; null then
		self.myVoyageOperator := self.myVoyage.allVoyageIOperators[self.myOperator];
		self.myVoyageTrade := self.myVoyage.myTrade;
	endif;
	self.recTransMode   := _receival.receiptTransportMode;
	self.requiresPower  := _receival.isReefer;
	self.theTotalWeight := _receival.weightTotal;
	self.stevedore      := _receival.stevedoreCode;               //04.11.2020 cnwma1 TFS #50112
	if _receival.myVehicleVisitRecord &lt;&gt; null then
		self.myCarrier := _receival.myVehicleVisitRecord.getMyCarrier;
	endif;
	
	if _receival.isKindOf(CMGTE_Container) then
		self.isClean   := _receival.CMGTE_Container.clean;
		self.myISOType := app.myRoot.allISOTypes[_receival.CMGTE_Container.isoType];
		if self.myISOType &lt;&gt; null then
			self.myISOTypeGroup := self.myISOType.myISOTypeGroup;
		endif;
	elseif _receival.isKindOf(CMGTE_Car) then
		self.carType 		 := _receival.CMGTE_Car.carType;
		self.isNewVehicle    := _receival.CMGTE_Car.isNew;
		self.isSelfPropelled := _receival.CMGTE_Car.selfPropelled;
		self.nbrDoors 		 := _receival.CMGTE_Car.nbrDoors;
		self.vehicleYear     := _receival.CMGTE_Car.year;
		self.myVehicleMake   := app.myDutyDocRoot.allVehicleMakes[_receival.CMGTE_Car.make];
		self.myVehicleModel  := app.myDutyDocRoot.allVehicleModels[_receival.CMGTE_Car.model];
		self.myVehicleType   := app.myDutyDocRoot.allVehicleTypes[_receival.CMGTE_Car.carType];
	endif;
epilog

end;</source>
        <Parameter name="_receival" type="CMGTE_Receival"/>
    </JadeMethod>
    <JadeMethod name="setMeasurementValue" id="d90276cd-61a9-4d18-a81e-5c80d24201e5">
        <updating/>
        <source>setMeasurementValue(_entRowName: String; _value: Decimal) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 10/06/2013	cnwdap1		Initial creation PAR #31721 Imperial Measurements on Yard Allcoation What If
//
vars
	measure	: CM_MeasurementType;

begin
//	measure := app.getDefaultMeasurementForType(Type_Linear);
	if _entRowName = (ETRow_WeightTotal) then
		self.theTotalWeight := _value;
	elseif _entRowName = ETRow_CargoHeight then
		measure := app.getDefaultMeasurementForType(Type_Height);
		self.cargoHeight := measure.removeDecimalZeros(_value.String);
	elseif _entRowName = ETRow_CargoLength then
		measure := app.getDefaultMeasurementForType(Type_Length);
		self.cargoLength := measure.removeDecimalZeros(_value.String);
	elseif _entRowName = ETRow_CargoWidth then
		measure := app.getDefaultMeasurementForType(Type_Width);
		self.cargoWidth := measure.removeDecimalZeros(_value.String);
	else
		inheritMethod(_entRowName, _value);
	endif;

epilog

end;</source>
        <Parameter name="_entRowName" type="String"/>
        <Parameter name="_value" type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="totalWeight" id="385e1178-6919-4593-af30-f65b54d55254">
        <source>totalWeight(): Decimal;
// -------------------------------------------
// Created 31 May 2005 by cnwdvb1
// -------------------------------------------
vars

begin
	return self.theTotalWeight;


end;</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
</Class>
