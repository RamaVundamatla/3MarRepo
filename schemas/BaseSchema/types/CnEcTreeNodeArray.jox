    <DbClassMap file="basemap"/>
    <JadeMethod name="getLastIndex" id="54bf9baf-51ca-48cc-9645-dbab23656b0e">
        <source>getLastIndex():Integer;
// --------------------------------------------------------------------------------
// Created:		13 November 2005 by cnwdad1
//
// Purpose:		Returns the list index of the last entry in the last node.
//
// Parameters:	None
//
// Returns:		The list index of the last list entry.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	treeNodeObj	: CnEcTreeNode;
	
begin
	treeNodeObj	:=	self.last();
	
	if treeNodeObj.hasChildNodes() then
		return treeNodeObj.getLastIndex();
	else
		return treeNodeObj.listIndex;
	endif;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
</CollClass>
