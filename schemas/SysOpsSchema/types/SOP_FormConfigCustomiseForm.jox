    <JadeMethod name="doDragDrop" id="31b20aea-1d28-4fe2-a3ec-12b8df778ed1">
        <updating/>
        <source>doDragDrop(control: Control input; win: Window input; x,y: Real) updating, protected;
/*
	Purpose:			
	Parameters:			
	Return Value:		

Date		Who		Reason
30 July 2008	concms1	Initial creation
*/

vars

begin
	if control &lt;&gt; win and win.Control.parent &lt;&gt; control then
		app.beep; 
	elseif control = win then
		// dropping on ourself.
		self.setControlPosition (win.Control, win.left + (x - self.dragOffsetX), win.top + (y - self.dragOffsetY), true);
	else
		self.setControlPosition (win.Control, (x - self.dragOffsetX),(y - self.dragOffsetY), true);
	endif;
	
	self.highlightSelectedControl;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="control" type="Control" usage="input"/>
        <Parameter name="win" type="Window" usage="input"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
