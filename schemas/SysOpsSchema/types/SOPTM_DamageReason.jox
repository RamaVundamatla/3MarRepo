    <JadeMethod name="includeObject" id="4a49f08a-9229-411f-891d-0be0c8025218">
        <updating/>
        <source>includeObject(_obj: Object; _passport: CM_Passport): Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 June 2022	navds20	ChangeRequest 53862: EUP - WMS - Damage Recording Extra Details

*/

vars

begin
	if self.includeNotAvailableEntries then
		return true;
	else
		return not _obj.CM_DamageReason.isNotAvalableForEntry;
	endif;

epilog

end;</source>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
