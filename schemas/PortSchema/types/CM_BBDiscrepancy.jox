    <JadeMethod name="getCCEventProperties" id="0eb04909-6599-43cb-902c-aa6549b32dbc">
        <source>getCCEventProperties(ccEvent: CMIF_CCEvent) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 August 2019	jlgndl1	Initial creation	TFS 45963

*/

vars

	oldWeight : Decimal[14,4];
	newWeight : Decimal[14,4];
begin

	oldWeight := self.totalWeight;
	newWeight := self.newTotalWeight;

	inheritMethod(ccEvent);
	
	ccEvent.addMass( "oldWeight", oldWeight.asStringJMT );
	ccEvent.addMass( "newWeight", newWeight.asStringJMT) ;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="ccEvent" type="CMIF_CCEvent"/>
    </JadeMethod>
    <JadeMethod name="getCCEventType" id="da0be771-1c89-486e-a9d7-24fcf7a4f44f">
