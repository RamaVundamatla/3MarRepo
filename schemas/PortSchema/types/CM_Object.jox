    <JadeMethod name="getHeadingStringForDefArray" id="0e5ab73b-328d-4371-b256-821fd48e8692">
        <source>getHeadingStringForDefArray(_array : EntTableRowArray) : String;
// THIS NEEDS TO BE MOVED BUT NOT SURE WHERE AT THIS STAGE - 
// see equivalent method on CM_ContianerEnqForm (UICommonSchema)
// ---------------------------------------------------------------------------
// Created:     09 April 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	entRow		: EntTableRow;
	tmpStr,
	rtnStr		: String;
	firstTime	: Boolean;

begin

	firstTime := true;
	foreach entRow in _array do
		tmpStr := entRow.getHeading(null, null, app.myCurrentLocale);
		if firstTime then
			firstTime := false;
			rtnStr := tmpStr;
		else
			rtnStr := rtnStr &amp; Tab &amp; tmpStr;
		endif; 
	endforeach;

	return rtnStr;
	
end;</source>
