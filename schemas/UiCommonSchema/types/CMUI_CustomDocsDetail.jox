    <JadeMethod name="unload" id="c1aed3f6-8413-4a58-b8c0-9fb67a57aadf">
        <controlMethod name="Form::unload"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>unload() updating;
/*
Purpose - 	
Who - NAVAB1
Date - 15AUG2023
ADO - CR 59615 TASK 59620 	
*/

vars

begin
	inheritMethod();
	
	if self.mode &lt;&gt; CMUI_CustomDocsMaint.Cargo_Review_Mode then  // ### TFS CR 60052 TASK 60054 25AUG2023 NAVAB1
		delete self.myProxyDetail;
		self.allCustomDetails.purge();
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="updateSubDetail" id="8d0cad0d-df84-419d-86f7-0411460da4be">
        <source>updateSubDetail();
/*
Purpose - 	
Who - NAVAB1
Date - 15AUG2023
ADO - CR 59615 TASK 59620 	
*/

vars

	custDocDtl : CM_CustomDocumentDetail;
	weight, volume, portion : Decimal[23,4];
	quantity, col : Integer;
	include : Boolean;
	theDataLine : String;
	ti : CM_TrackedItem;
	ct : CM_CargoType;
begin
	if self.tblData.row &lt;= self.tblData.fixedRows then
		return;
	endif;
	
	custDocDtl := self.tblData.accessRow(self.tblData.row).itemObject.CM_CustomDocumentDetail;
	
	ti := custDocDtl.myTrackedItem;
	ct := ti.myCargoType;
	
	
	/*
	if ct.isBulk() then
		if ct.isBulkByVolume() then
			weight := custDocDtl.clearedWeight;
			volume := self.txtClearedCargoVolume.getConvertedValue().Decimal;
			if volume &lt;= 0 
			or volume &gt; ti.totalVolume then
				app.msgBox(app.getErrorString(Trans_volum_shoul_great_than_n),app.getErrorString(Problem), MsgBox_OK_Only);
				self.txtClearedCargoVolume.setValue(ti.totalVolume);
				self.txtClearedCargoVolume.setFocus();
				return;
			endif;
		else
			weight := self.txtClearedCargoWeight.getConvertedValue().Decimal;
			volume := custDocDtl.clearedVolume;
			if weight &lt;= 0 
			or weight &gt; ti.totalWeight then
				app.msgBox(app.getErrorString(Transfer_weight_Should_be_Grea),app.getErrorString(Problem), MsgBox_OK_Only);
				self.txtClearedCargoWeight.setValue(ti.totalWeight);
				self.txtClearedCargoWeight.setFocus();
				return;
			endif;
		endif;
		quantity := custDocDtl.clearedQuantity;
	
	else
		quantity := self.txtClearedCargoQuantity.text.Integer;
		weight := custDocDtl.clearedWeight;
		volume := custDocDtl.clearedVolume;
		if quantity &lt;= 0 
		or quantity &gt; ti.totalQuantity then
			app.msgBox(app.getErrorString(Trans_quant_shoul_great_than_n),app.getErrorString(Problem), MsgBox_OK_Only);
			self.txtClearedCargoQuantity.text := ti.totalQuantity.String;
			self.txtClearedCargoQuantity.setFocus();
			return;
		endif;
	
	endif;
	*/
	
	if ct.isBulk() then
		if ct.isBulkByVolume() then
//			weight := cood.transferredWeight;
			volume := self.txtClearedCargoVolume.getConvertedValue().Decimal;
			if volume &lt;= 0 
			or volume &gt; ti.totalVolume then
				app.msgBox(app.getErrorString(Trans_volum_shoul_great_than_n),app.getErrorString(Problem), MsgBox_OK_Only);
				self.txtClearedCargoVolume.setValue(ti.totalVolume);
				self.txtClearedCargoVolume.setFocus();
				return;
			endif;
			
			// ### TFS BUG 64115 13MAY2024 NAVAB1
			portion := volume/ self.totalVolume;
			weight := self.totalWeight * portion;
			
			self.txtClearedCargoWeight.setValue(weight);
		else
			weight := self.txtClearedCargoWeight.getConvertedValue().Decimal;
			
			
//			volume := cood.transferredVolume;
			if weight &lt;= 0 
			or weight &gt; ti.totalWeight then
				app.msgBox(app.getErrorString(Transfer_weight_Should_be_Grea),app.getErrorString(Problem), MsgBox_OK_Only);
				self.txtClearedCargoWeight.setValue(ti.totalWeight);
				self.txtClearedCargoWeight.setFocus();
				return;
			endif;
			
			// ### TFS BUG 64115 13MAY2024 NAVAB1
			portion := weight/ self.totalWeight;
			volume := self.totalVolume * portion;
			
			self.txtClearedCargoVolume.setValue(volume);
				
		endif;
		
		quantity := custDocDtl.clearedQuantity;

			
	else
		quantity := self.txtClearedCargoQuantity.text.Integer;

		
		
		if quantity &lt;= 0 
		or quantity &gt; ti.totalQuantity then
			app.msgBox(app.getErrorString(Trans_quant_shoul_great_than_n),app.getErrorString(Problem), MsgBox_OK_Only);
			self.txtClearedCargoQuantity.text := ti.totalQuantity.String;
			self.txtClearedCargoQuantity.setFocus();
			return;
		endif;
		
		// ### TFS BUG 64115 13MAY2024 NAVAB1
		portion := quantity/ self.totalQuantity;
		weight := self.totalWeight * portion;
		volume := self.totalVolume * portion;
		
		self.txtClearedCargoWeight.setValue(weight);
		self.txtClearedCargoVolume.setValue(volume);
	
	endif;
	
	
	
	col := self.tblData.getColumnByRowName(ETRow_IncludeChk);
	self.tblData.accessCell(self.tblData.row,col);
	include := self.tblData.accessedCell.text = true.cnEcGetTableCheckBoxValue ;

	custDocDtl.setProxyTransfers(weight, volume, quantity,include); // ### TFS CR 60424 TASK 60549 26SEP2023 NAVAB1

	if not custDocDtl.validateIncluded() then
		app.msgBox("Cannot be included, is not included in pevious document",app.getErrorString(Problem),MsgBox_OK_Only);
		return;
	endif;
	
	
	theDataLine := custDocDtl.getAttributeStringForDefArray(self.tblData.allTblDataEntRows);
	self.tblData.accessCell(self.tblData.row, 1).text := theDataLine;

	self.displayContentTotals(self.myCustDocDetail);  // ### TFS CR 60424 TASK 60549 26SEP2023 NAVAB1 custDocDtl);



epilog

end;</source>
    </JadeMethod>
</GUIClass>
