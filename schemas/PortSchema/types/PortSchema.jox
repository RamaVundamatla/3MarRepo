    <JadeMethod name="isOtherColumnIncludedForReport" id="cae1b883-51a3-426a-90b6-2ff42d320516">
        <source>isOtherColumnIncludedForReport() : Boolean;
// -------------------------------------------------------------------------------
// Created:     21 May 2008 by cnwvu1
//
// Purpose:     Checks whether the 30, 45 or 53 ISO Type footers are included for 
//				reports and have be populated in the column "Other"
// -------------------------------------------------------------------------------

vars
	isOwn	: Boolean;
	
begin

	if app.is30IncludedForReportsAsColumn( isOwn ) then
		if not isOwn then
			return true;
		endif;
	endif;
	if app.is45IncludedForReportsAsColumn( isOwn ) then
		if not isOwn then
			return true;
		endif;
	endif;
	if app.is53IncludedForReportsAsColumn( isOwn ) then
		if not isOwn then
			return true;
		endif;
	endif;
	
	return false;
	
end;
</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
