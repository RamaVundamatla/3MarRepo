    <JadeMethod name="getDataDisplay" id="ab5125d4-17e2-49fd-97fd-396bde7fa7b3">
        <source>getDataDisplay(pDataObj: CM_YAData): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
30 July 2024	navrv30	Bug 64703: FR | 53383 - Release Request by Type - Cargo Group - Measurement Type
20 Sep 2024		navnk30	Bug 66178: EUP | Rel Req YA Criteria Labels
27 Mar 2025		navah1	Bug 34448: Weight Flexi (kg) in the Yard Allocation Maintenance form is not saving correctly on the description
*/

constants
	Range_Separator : String = "-";
vars
	measureType		: CM_MeasurementType;
	valueStr,
	weightFromStr,
	weightToStr, 
	token,							   //27.03.2025 navah1 #34448
	weightStr		: String; 		   //27.03.2025 navah1 #34448
	pos 			: Integer;
	tokens 			: StringArray;	   //27.03.2025 navah1 #34448
	pattern			: CMIF_YAPattern;  //27.03.2025 navah1 #34448
begin
	create pattern transient; 		   //27.03.2025 navah1 #34448
	create tokens transient;  		   //27.03.2025 navah1 #34448
	
	measureType := app.getDefaultMeasurementForType(Type_Weight);
	valueStr := pDataObj.getDataValue().String;
	
	/*if measureType &lt;&gt; null and valueStr &lt;&gt; null then		//20.09.2024 navnk30 #66178 START
			valueStr := app.convertMeasurementForDisplay(measureType.shortName, valueStr.Decimal);	
			return valueStr &amp; " " &amp; measureType.shortName;
	endif;*/
	/* //27.03.2025 navah1 #34448
	pos := 1;
	weightFromStr	:= valueStr.scanUntil(Range_Separator, pos);
	pos += 1;
	weightToStr		:= valueStr.scanUntil(Range_Separator, pos);
	if measureType &lt;&gt; null and valueStr &lt;&gt; null then
		weightFromStr := app.convertMeasurementForDisplay(measureType.shortName, weightFromStr.Decimal);
		weightToStr := app.convertMeasurementForDisplay(measureType.shortName, weightToStr.Decimal);
		return weightFromStr &amp; " " &amp; measureType.shortName &amp; " " &amp; Range_Separator &amp; " " &amp; weightToStr &amp; " " &amp; measureType.shortName;
	endif;													//20.09.2024 navnk30 #66178 END
	*/
	if measureType &lt;&gt; null and valueStr &lt;&gt; null then  		//27.03.2025 navah1 #34448
		pattern.getTokens(valueStr, tokens);  
		foreach token in tokens do
			token := token.trimBlanks();
			pos := 1;
			weightFromStr := token.scanUntil(Range_Separator, pos);
			weightFromStr := app.convertMeasurementForDisplay(measureType.shortName, weightFromStr.Decimal);
			pos += 1;
			weightToStr	:= token.scanUntil(Range_Separator, pos);
			weightToStr := app.convertMeasurementForDisplay(measureType.shortName, weightToStr.Decimal);
			weightStr := weightStr &amp; weightFromStr &amp; " " &amp; measureType.shortName &amp; " " &amp; Range_Separator &amp; " " &amp; weightToStr &amp; " " &amp; measureType.shortName &amp; ', ';
		endforeach;	  
		return weightStr.truncatedAt(weightStr.length-2); 
	endif;
	
	return valueStr;
epilog
	delete pattern; //27.03.2025 navah1 #34448
	delete tokens;  //27.03.2025 navah1 #34448
end;</source>
        <Parameter name="pDataObj" type="CM_YAData"/>
        <ReturnType type="String"/>
    </JadeMethod>
