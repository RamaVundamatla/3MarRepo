    <JadeMethod name="setParentPackingLineFromCMIF" id="b2c88cfa-647c-4032-9ff7-275b1b81201b">
        <updating/>
        <source>setParentPackingLineFromCMIF(_isoType : String; _totalRequested : Integer) updating;
/*
Date		Who		Reason
23/04/2012	cnwdap1	Initial creation PAR #29475 CCMS PNL 2155
25/09/2012	cnwcs5	par 30390 - remove voyageCode property
*/
vars
	isoType 	: CM_ISOType;
	root		: CM_Root;
begin
	root				:= app.myRoot;
	self.myCargoType	:= root.allCargoTypesById[TI_CargoType_Container];
	isoType 			:= root.allISOTypes[_isoType];
	self.myISOType 		:= isoType;
	self.packType 		:= self.PackType_Parent;
	self.totalRequested := _totalRequested;
epilog

end;</source>
