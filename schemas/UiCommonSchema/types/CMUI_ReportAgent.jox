    <JadeMethod name="printReport" id="2eb7d8fa-b977-4176-b794-91f301e7c215">
        <source>printReport(_jadeReport : JadeReport input) protected;
// -------------------------------------------
// Created 30 November 2004 by cnwdvb1
// -------------------------------------------
vars

	thePrinterName		: String;
	iter				: Iterator;
	printer				: CM_PrinterDef;
	findPrinterValue	: Integer;


begin

	app.printer.abort();
	// Par 9677 Changed the code to not set printer to default.
	
	if app.isWebApp then
	/*	iter := app.myRoot.allPrinterDefsByLogicalName.createIterator();
		while iter.next(printer) do
			if printer.printerIsPDF then
				break;
			endif;
			printer := null;
		endwhile;*/
		
		printer := app.getPDFPrinter();

		if printer = null then
			app.raiseCMException(PDF_Printer_required,null, null);
			return;
		endif;
		
		thePrinterName := printer.physicalPrinterName;
		findPrinterValue :=  app.printer.setPrinter(thePrinterName);

		if findPrinterValue &lt;&gt; 0 then
			app.raiseCMException(Unable_locate_pdf_printer,null, null);
			app.writeLog(method.qualifiedName &amp; " setPrinter returned " &amp; findPrinterValue.String, LogINFO);		// TFS 39204 - Log the returned value to help work out whats going on
			return;
		endif;

		app.printer.setPrintFileName(self.fileName);

	endif;
	app.printer.printPreview := false;
	app.printerFixPAR34782(_jadeReport);
	app.printer.printReport(_jadeReport);

epilog	

	delete iter;

end;</source>
        <access>protected</access>
        <Parameter name="_jadeReport" type="JadeReport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="runBackgroundReport" id="b1c46c9d-9da7-4ef6-be73-0ac2212efa2f">
        <source>runBackgroundReport(_filterObject 	: CMQF_FilterReports;
					_qryReport 		: CM_QryReport;
					_processingOption : Integer;
					_profName 		: String;
					_pxyMenuUserReport : CM_MenuUserReport input;
