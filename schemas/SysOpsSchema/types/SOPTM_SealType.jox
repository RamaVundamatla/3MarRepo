<Class name="SOPTM_SealType" id="f8e3e81a-5fe0-421f-a1c7-9979b7c3a7db">
    <superclass name="SOP_TableMaintItem"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
