    <JadeMethod name="doRefreshOperationalCriteria" id="21ba232f-9a96-4ed0-adc4-c344c4431443">
        <source>doRefreshOperationalCriteria();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 March 2009	cnwrd1	Initial creation

allOperationalCriteria can be out of step with the form values for criteria maintanance so redo.
// cnwrd1 par 19091 17.3.09
*/

vars
	i 				: Integer;
	criteriaCtrl	: CMUI_YACriteriaCntl;	
	criteriaType 	: CM_YACriteriaType;
	proxyCriteria	: CM_YACriteria;	
	itemCode 		: String;	
	value			: Any;
	cmifCriteria 	: CMIF_YACriteriaPriority;
begin

	self.allOperationalCriteria.purge();
	
	while true do
		i := i + 1;
		criteriaCtrl := self.frmCriteria.getControl(i);
		if criteriaCtrl = null then
			break;
		endif;
		if criteriaCtrl.visible then
			criteriaType := 	criteriaCtrl.getCriteriaType();
			if criteriaType &lt;&gt; null then
				create proxyCriteria transient;
				itemCode := criteriaType.description.cnEcUpto(CM_YACriteriaPriority::code.length -1);
				//epr TFS 1822 28/4/16
				value := criteriaCtrl.getValue();
			
				proxyCriteria.setProxy(criteriaType, value, itemCode);
				cmifCriteria := proxyCriteria.getTransient();
				self.allOperationalCriteria.add(cmifCriteria);
			endif;
			
		endif;
	endwhile;

epilog

end;</source>
    </JadeMethod>
