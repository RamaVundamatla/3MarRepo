    <JadeMethod name="getISOGroupStringCode" id="f5733915-ece7-40e7-9d29-8d785e3b0959">
        <source>getISOGroupStringCode() : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 Jan 2017	cnwrh7	Initial creation TFS2929
13 Mar 2017	cnwrs1	TFS3648 add other Release Request fields
25 Mar 2024 navma1	ChangeRequest 63141: MTN - Code Refactor to improve finding matching cargo items using reserve details
*/

vars
	isoType : CM_ISOType;
	isoGrp  : CM_ISOTypeGroup;
begin
	
	isoGrp := self.myISOGroup;										//25.03.2024 navma1 #63141
	if isoGrp &lt;&gt; null then
		return isoGrp.code;
	endif;
	
	isoType := self.myISOType;
	if isoType &lt;&gt; null and 	isoType.myISOTypeGroup &lt;&gt; null then		//25.03.2024 navma1 #63141
		return isoType.myISOTypeGroup.code;
	endif;
	
	return null;
epilog

end;</source>
        <ReturnType type="String"/>
