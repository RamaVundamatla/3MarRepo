    <JadeMethod name="create" id="b18fda73-d390-467c-a410-952fba260f9a">
        <updating/>
        <source>create() updating;
// ---------------------------------------------------------------------------
// Created:     15 March 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

// need to change these when permissions worked out
	self.permissionView  := PmAdmRestrictionsView;
	self.permissionMaint := PmAdmRestrictionsMaint;
	
	self.helpFileName := HelpFile_Logs;

end;</source>
    </JadeMethod>
    <JadeMethod name="doOptDocketClick" id="88a056e0-ca74-44cc-9f0b-6cdffc7bb818">
        <source>doOptDocketClick();
// ---------------------------------------------------------------------------
// Created:     01 March 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if (not tblSelection.visible) then
		tblSelection.visible := true;
		txtDetails.visible := true;
		tblSelectionData.visible := false;
	endif;

	tblSelection.rows := 0;
	tblSelection.addAttribute('supplier', 'Supplier', Table.InputType_TextBox, 0, true);
	tblSelection.addAttribute('docket', 'Docket No', Table.InputType_TextBox, 0, true);
	tblSelection.cnEcResizeContents();

end;</source>
    </JadeMethod>
    <JadeMethod name="doOptFileClick" id="f95351ef-ec72-470a-b495-4bb2e248d82d">
        <source>doOptFileClick();
// ---------------------------------------------------------------------------
// Created:     01 March 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	tblSelectionData.visible := true;
	tblSelection.visible := false;
	txtDetails.visible := false;

	tblSelectionData.rows := 0;
	tblSelectionData.columns := 3;
	
	tblSelectionData.addItem('User' &amp; Tab &amp; 'Date/Time' &amp; Tab &amp; 'Num Tickets');
	tblSelectionData.addItem('alan' &amp; Tab &amp; '21 Jan 02 12:56' &amp; Tab &amp; '17');
	tblSelectionData.addItem('alan' &amp; Tab &amp; '21 Jan 02 14:23' &amp; Tab &amp; '55');
	tblSelectionData.addItem('alan' &amp; Tab &amp; '21 Jan 02 18:56' &amp; Tab &amp; '3');
	
	tblSelectionData.fixedRows := 1;

end;</source>
    </JadeMethod>
