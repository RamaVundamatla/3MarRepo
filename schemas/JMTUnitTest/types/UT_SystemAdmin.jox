    <JadeMethod name="tAutoSchedule" id="8c8fea80-8462-4cdf-b573-52014892092e">
        <source>tAutoSchedule();
/*

Purpose:			

/* Changes

Date		Name	TFS#	Description
============================================================================
14/04/2014	cnwma1			Initial creation
16/04/2019	jlgka1	43863	Added Recurring Value default in existing unit test.
============================================================================*/
constants
	RecurValue	: Integer = 1;	// jlgka1 TFS 43863
vars
	autoSched	: CM_AutoSchedule;
	runTS		: TimeStamp;	
begin

	runTS := runTS.addDays(6);
	runTS := runTS.addMonths(-1);
	runTS.setTime("07:00:00".Time);

	autoSched :=self.addAutoSchedule("UT_AutoSch", runTS, RecurValue); // jlgka1 TFS 43863
	self.assertNotNull(autoSched);
	
	updateAutoSchedule(autoSched);
	self.assertEqual(autoSched.dayOfMonth,"21".asStringJMT);
	

	// De_Active AutoSchedule 
	app.myTrxUA.trxUpdateAutoScheduleRunTs(autoSched,10,app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="tAvailabilityGrade" id="fcfc7995-7461-4821-bbc0-a10c1cef8269">
        <source>tAvailabilityGrade();
/*

Purpose:	Unit Test for AvailabilityGrade		

Date		Who		Reason
27/02/2014	cnwma1	Initial creation

*/

vars
	availabilityGrade 	: CM_MTGrade;
	terminalSet			  : CM_TerminalSet;
	availDesc			: String;
begin

	// Prepare Terminal Set 
	create terminalSet transient;
	terminalSet.add(app.myRoot.allTerminals["UT"]);
	terminalSet.add(app.myRoot.allTerminals["MA"]);
	
	self.opts.purge();
	self.opts.addAssoc("TerminalSet",terminalSet);
	
	
	//Create Availability grade
	availabilityGrade	:= self.addAvailabilityGrade(55,
													"UT:Grade55 SOKN",
													true,
													true);
	self.assertNotNull(availabilityGrade);
	
	// update Commodity Group
	availDesc := availabilityGrade.description &amp; "_UP_UT";
	self.opts.purge();
	self.opts.addAssoc("availDesc", availDesc);
	self.updateAvailabilityGrade(availabilityGrade);
	self.assertEqual(availabilityGrade.description, availDesc);
	
epilog
	delete terminalSet;
end;</source>
    </JadeMethod>
    <JadeMethod name="tBoom" id="70e0a369-ad71-47f6-85b0-00a8c930ca0f">
        <source>tBoom();

/*

Purpose:		Add / Update / Delete Boom (On Terminal)

Date			Who		Reason
21/03/2014		cnwmh5	Initial creation

*/

vars

	boom				: CM_Boom;

begin

	boom := self.addBoom("BOOMMH", "Michael's Boom", "127.0.0.1", 1111);
