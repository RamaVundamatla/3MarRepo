    <JadeMethod name="setAllAvailable" id="185932f6-b7f7-416f-8418-aa6a2fb53bdf">
        <updating/>
        <source>setAllAvailable(	_selectedObjs : ObjectArray;
					_default : Object;
					_objectTypeString : String;
					_form : Form;
					_displayObjMethName : String
					) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06 July 2011	cnwndl1	Initial creation	Par 26476

*/

vars

begin

	self.allAvailable.clear();
	self.mySelectedObject := null;

	if not _selectedObjs.isEmpty then
		_selectedObjs.copy( self.allAvailable );
	endif;
	
	if _default &lt;&gt; null then
		self.mySelectedObject := _default;
	endif;
	
	self.objectTypeString := _objectTypeString;
	
	self.myCallerForm := _form;
	self.displayObjMethName := _displayObjMethName;

epilog

end;</source>
        <Parameter name="_selectedObjs" type="ObjectArray"/>
        <Parameter name="_default" type="Object"/>
        <Parameter name="_objectTypeString" type="String"/>
        <Parameter name="_form" type="Form"/>
        <Parameter name="_displayObjMethName" type="String"/>
    </JadeMethod>
    <JadeMethod name="setupControls" id="c0708bf0-5151-4a07-9fa5-c64e3f801397">
        <updating/>
        <source>setupControls() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06 July 2011	cnwndl1	Initial creation	par 26476

*/

vars
	
	index : Integer;
	obj : Object;
	str : String;

begin
						
	self.doResizeControls(true);
						
	foreach obj in self.allAvailable do
		str := self.myCallerForm.sendMsgWithParams( self.displayObjMethName, obj ).String;
		index := self.lstItems.addItem( str );
		 self.lstItems.itemObject[index] := obj;
	endforeach;
	
	if self.mySelectedObject &lt;&gt; null then
		self.lstItems.listIndex := self.lstItems.findObject( self.mySelectedObject );
	endif;
	
	if self.lstItems.listCount = 1 and self.lstItems.listIndex = -1 then
		self.lstItems.listIndex := 1;
		self.updateSelection();
	endif;
						
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="80965c43-ffd2-4fdc-be8e-827cc214b187">
        <updating/>
        <source>setupForm() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06 July 2011	cnwndl1	Initial creation	Par 26476

*/

vars

begin

	inheritMethod();
	
	self.setupCmdButtons( 2, app.getErrorString(CM_OK), app.getErrorString(Cancel), null, null, null );
	
	self.setupControls();
	
	if self.lstItems.listCount &lt; 2 then
		self.unloadForm();
	endif;

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="translateForm" id="a25c61e5-c94b-4237-b336-66733f83128b">
        <updating/>
        <source>translateForm(locale : CM_Locale) updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	
begin
	// Determine the locale for translations.
	inheritMethod(locale);
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0016642, locale);
	lblInstruct.translateCaption(Xlat_0016643, locale);
end;</source>
        <Parameter name="locale" type="CM_Locale"/>
    </JadeMethod>
    <JadeMethod name="updateSelection" id="4122b689-6645-4d2c-8a16-fabd852f01c6">
        <updating/>
        <source>updateSelection()updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06 July 2011	cnwndl1	Initial creation	Par 26476

*/

vars

	obj : Object;

begin

	obj := self.lstItems.listObject;
	self.mySelectedObject := obj;

epilog

end;</source>
    </JadeMethod>
