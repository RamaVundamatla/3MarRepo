    <JadeMethod name="validateConfig" id="b44ac3a1-7e4f-428c-a405-ef0b7ae0a616">
        <source>validateConfig();
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24/08/2012	cnwndl1	Initial creation
09/08/2017	jlgdap1	TFS 5740 AAT Changes to Pro Forma Invoices
19/03/2020  cnwma1  Bug 48897: SNO - New cargo enquiry screen
*/

vars

begin

	self.validateReport(self.cashReceiptReport);
	self.validateReport(self.cashInvReceiptReport);
	self.validateReport(self.cashProformaReport);			
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="validateReport" id="3bb03207-b904-4396-ba12-0aff6f1eb455">
        <source>validateReport(_reportName : String);

/*

Purpose:			Validate JRW Report name.  Null is valid.
					NOTE: If the the report name entered is the same as the default report name in global constants,
					then we aren't passing value to store.  Be aware of this if we change our minds about null being a valid 
					value as opposed to an exception.

Parameters:			Report name

Return Value:		None


Date		Who		Reason
23 Feb 2010	consw1	PAR #21156 - Gate Config Report Names
16 Mar 2010	consw1	PAR #22886 - Leaking report transients
14 Jul 2011 cnwjre1	PAR 27851 printing to lineflow, report names can have options delimited by '?'
*/

vars
	pos		: Integer;
	reportName	: String;
	jrwManager	: JadeReportWriterManager;
	jrwReport	: JadeReportWriterReport;
	dotMatrxReport : Class;
	
begin
	if _reportName = null then
		return;
	endif;

	// 27851 check for trailing options on the name
	reportName := _reportName;
	pos := _reportName.pos("?", 1);
	if pos &gt; 0 and pos &lt; _reportName.length then
		reportName := _reportName[1:pos-1];
	endif;
	jrwManager := app.createReportWriterManager();
	
	jrwReport  := jrwManager.getReport(reportName);
	
	if jrwReport = null then
		//12 Nov 2012	NDL	Par 30682
		dotMatrxReport := currentSchema.getSchema("UiCommonSchema").getClass(reportName);
		if dotMatrxReport &lt;&gt; null then
			return;
		endif;
		app.raiseCMException1(Report_not_found, reportName, null, null);
	endif;
	
epilog
	delete jrwReport;
	delete jrwManager;
end;</source>
        <Parameter name="_reportName" type="String"/>
    </JadeMethod>
</Class>
