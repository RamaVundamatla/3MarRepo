<Class name="CM_Reassembly" id="74dd989f-f421-44aa-827b-6e24403e1ab4">
    <superclass name="CM_Receive"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="receive"/>
    <ExplicitInverseRef name="myDisassemblyTransaction" id="7cf52429-61f9-425f-a12f-e8cd7fc164c3">
        <updateMode>automatic</updateMode>
        <embedded/>
        <type name="CM_Disassembly"/>
        <access>readonly</access>
        <Inverse name="CM_Disassembly::allReassemblyTransactions"/>
    </ExplicitInverseRef>
    <JadeMethod name="getDisplayString" id="bfea47f2-fd92-4ec7-b53a-302c768294ca">
        <source>getDisplayString(): String;
// ---------------------------------------------------------------------------
// Created:     29 August 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if self.myDisassemblyTransaction = null then
		return inheritMethod;
	endif;
	
	return 'Created from ' &amp; self.myDisassemblyTransaction.myTrackedItem.id;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="bbc3d2c0-cfbb-4d7c-9998-1cdda44045c6">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 June 2010	cnwndl1	Initial creation	Par 23498

*/

vars
	lDetail : String;
begin

	if _attrName = ETRow_Details  then
		if self.deleted then
			return self.getDeletedDetails();		// 15/10/18 MAP TFS41191
			
		else
			return self.getDisplayString();
			
		endif;
							
	elseif _attrName = ETRow_CreatedFrom then
		if self.myDisassemblyTransaction = null then
			return null;
		else	
			return self.myDisassemblyTransaction.myTrackedItem.id;
		endif;
	else
		return inheritMethod(_attrName, _short);
	
	endif;

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getEnquiryRow" id="86b3ffa1-320b-4b88-a075-232b749afb99">
        <source>getEnquiryRow(): String;
// ---------------------------------------------------------------------------
// Created:     31 March 2003 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	return inheritMethod &amp; self.getDisplayString();

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getReceiveTypeforCC" id="9acfaf1b-ace8-4007-86df-6097228795d1">
