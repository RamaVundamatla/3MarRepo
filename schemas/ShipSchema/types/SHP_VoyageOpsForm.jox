    <JadeMethod name="doMnuTasksAddClick" id="d87689f1-4468-4291-b610-e5a8aa6e70dd">
        <updating/>
        <source>doMnuTasksAddClick(menuItem: MenuItem input) updating, protected;
/*
----------   ----------  --------------------------------------------------
Created:	23 May 2006 By cnwth2

Purpose:	PAR 11791 - Bulk update of tasks and stops - overhaulled

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	tmpTI 			: CM_TrackedItem;
	taskDesc 		: CM_ToDoTaskDesc;
	tiSet			: CM_TISet;
	result			: Integer;
begin
	
	if menuItem = null then
		return;
	else
		taskDesc := menuItem.userObject.CM_ToDoTaskDesc;
	endif;

	tmpTI := self.mnuCargo.userObject.CM_TrackedItem;
	if tmpTI = null then
		return;
	endif;
	
	create tiSet transient;
	self.getCurrentlySelectedTIs(tiSet);
	
	if (not tiSet.includes(tmpTI)) then
		tiSet.add(tmpTI);
	endif;
	
	while true do
		app.myTrxUA.trxUpdateTIToDoTaskAddBulk(taskDesc, tiSet, app.myPassport);
		if app.myPassport.trxCompletedOK then
			break;
		else
			result := app.showErrorWarningDialog('Add Todo Task', app.myPassport, ErrWarnMode_Add + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				// there must have just been warnings that the user has acknowledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			
		endif;
		
		break;
	endwhile;

epilog
	delete tiSet;
end;</source>
        <access>protected</access>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doMnuTasksCompleteClick" id="f6a84446-0f3c-4ee0-a7f0-a465f4a80631">
        <updating/>
        <source>doMnuTasksCompleteClick(menuItem: MenuItem input) updating, protected;
/*
----------   ----------  --------------------------------------------------
Created:	23 May 2006 By cnwth2

Purpose:	PAR 11791 - Bulk update of tasks and stops - overhaulled

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	tmpTI 			: CM_TrackedItem;
	taskDesc 		: CM_ToDoTaskDesc;
	realTiSet			: CM_TISet;
	result			: Integer;
	ti				: CM_TrackedItem;
	tiTask 			: CM_ToDoTask;
	pxyTiSet 		: CM_TISet;
	resourceUsageProxys : CM_ResourceTypeUsageSet;
begin
	
	if menuItem = null then
		return;
	endif;
	
	if menuItem.userObject = null then
		return;
	endif;
	
	taskDesc := menuItem.userObject.CM_ToDoTaskDesc;
	
	tmpTI := self.mnuCargo.userObject.CM_TrackedItem;
	if tmpTI = null then
		return;
	endif;
	
	create realTiSet transient;
	self.getCurrentlySelectedTIs(realTiSet);
	
	if (not realTiSet.includes(tmpTI)) then
		realTiSet.add(tmpTI);
	endif;
	
	create pxyTiSet transient;
		//+cnwml2 MSL CCMS 1017
		
	//31 Dec 2009 NDL CCMS MES 1006	- Common code migrated up to assistant
	if not self.myAssistant.doTaskProxySetForComplete( taskDesc.code, pxyTiSet, tmpTI, realTiSet, resourceUsageProxys) = IDOK then
		return;
	endif;
				
	while true do
		app.myTrxUA.trxUpdateTIToDoTaskCmpltBulk(taskDesc, pxyTiSet, resourceUsageProxys, app.myPassport);
		if app.myPassport.trxCompletedOK then
			break;
		else
			result := app.showErrorWarningDialog('Complete Todo Task', app.myPassport, ErrWarnMode_Add + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				// there must have just been warnings that the user has acknowledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		break;
	endwhile;

epilog

	if pxyTiSet &lt;&gt; null and not pxyTiSet.isEmpty then
		pxyTiSet.purge;
	endif;
	delete pxyTiSet;

	delete realTiSet;
	
end;</source>
        <access>protected</access>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doMnuTasksRemoveClick" id="8e87c6df-5a04-49c6-823d-5e9120a3bc42">
        <updating/>
        <source>doMnuTasksRemoveClick(menuItem: MenuItem input) updating, protected;
/*
----------   ----------  --------------------------------------------------
Created:	23 May 2006 By cnwth2

Purpose:	PAR 11791 - Bulk update of tasks and stops - overhaulled

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	tmpTI 			: CM_TrackedItem;
