    </JadeMethod>
    <JadeMethod name="xHandlerInterface" id="3198b6b4-5eae-494a-ae4b-3c8afccf292a">
        <source>xHandlerInterface(pExceptionObj:Exception):Integer protected;
// --------------------------------------------------------------------------------
// Created:		14 October 2005 by cnwdad1
//
// Purpose:		General exception handler which allows the Service Provider to respond
//				(in the event of an exception) with the details of what went wrong.
//
// Parameters:	pExceptionObj - A Reference to the exception object.
//
// Returns:		The exception flag indicating how to dispose of the exception.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
constants
	NO_RESPONSE		: Integer = 11051;
	REMOTE_ERROR	: Integer = 11052;
	
vars
	errorCode		: Integer;
	errorMessage	: String;
	titleMsg		: String;
	
begin
	errorCode	:=	pExceptionObj.errorCode;
	
	if errorCode = NO_RESPONSE then
		titleMsg		:=	"The Mobile Server database is not available";
		errorMessage	:=	"Connection to Mobile Server database cannot be established. Contact your system administrator.";
	elseif errorCode = REMOTE_ERROR then
		titleMsg		:=	"The Mobile Server database encountered an error";
		errorMessage	:=	"An error occurred on the Mobile Server database:" &amp; CrLf &amp; CrLf &amp;
							process.getErrorText(errorCode) &amp; CrLf &amp; CrLf &amp;
							"Contact your system administrator.";
	else
		errorMessage := process.getErrorText(errorCode);
	endif;
	
	errorMessage	:=	errorMessage &amp; CrLf &amp; pExceptionObj.extendedErrorText;
	
	// if called from the app
	abortTransaction;
	
	if pExceptionObj.isAppError() then
//		app.msgBox(errorMessage, "Application Error", MsgBox_Exclamation_Mark_Icon + MsgBox_OK_Only);
		return Ex_Abort_Action;	
	elseif pExceptionObj.isSoapError() then
//		app.msgBox(errorMessage, "SOAP Error", MsgBox_Exclamation_Mark_Icon + MsgBox_OK_Only);
		return Ex_Abort_Action;	
	else
		return Ex_Pass_Back;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="pExceptionObj" type="Exception"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
</Class>
