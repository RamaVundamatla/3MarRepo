    <JadeMethod name="checkExportScreenData" id="60a5d516-e566-4529-bc8b-32fe5e787cc8">
        <source>checkExportScreenData() : Boolean protected;

vars
	outputFileName		: String;
	outputNoidFileName	: String;
	formatName			: String;
	
begin
	lblInstruct.caption := "";
	outputFileName 		:= txtInput.text;
	outputNoidFileName 	:= txtInputNoid.text;  
	formatName 		:= cmbInputFormat.text;

	if formatName = "" then
		lblInstruct.caption := lblInstruct.caption &amp; "Must select an XML Format. " &amp; CrLf;	
	endif;
	
	if outputFileName = "" then
		lblInstruct.caption := lblInstruct.caption &amp; "Must have a Main Output File. " &amp; CrLf;	
	endif;
	
	if outputNoidFileName = "" then
		lblInstruct.caption := lblInstruct.caption &amp; "Must have a NOID Output File. " &amp; CrLf;	
	endif;

	if outputFileName &lt;&gt; "" and outputFileName = outputNoidFileName then
		lblInstruct.caption := lblInstruct.caption &amp; "You may NOT make the Main Output file name the same as the NOID Output file name. " &amp; CrLf;	
	endif;
	
	if lblInstruct.caption &lt;&gt; "" then
		return false;
	else
		return true;
	endif;
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="checkImportScreenData" id="a9fe4b4a-656b-404e-a01e-0b8dd616af70">
        <source>checkImportScreenData() : Boolean protected;

vars
	inputFileName	: String;
	noidFileName	: String;
	errorFileName	: String;
	logFileName		: String;
	hubbleId		: String;
	formatName		: String;
	fileObj			: File;
	baseRootObj 	: CnEcBaseRoot;
	
begin
	lblInstruct.caption	:= "";
	inputFileName 		:= txtInput.text;
	noidFileName 		:= txtInputNoid.text;  
	errorFileName 		:= txtError.text;
	logFileName 		:= txtLog.text;
	hubbleId 			:= txtHubbleId.text;
	formatName 			:= cmbInputFormat.text;
	baseRootObj			:= CnEcBaseRoot.firstInstance;

	create fileObj transient;
	fileObj.fileName := inputFileName;
	
	if fileObj.isAvailable() then
	else
		lblInstruct.caption := lblInstruct.caption &amp; "Unable to access Main Input file selected. " &amp; CrLf;	
	endif;

	if formatName = "" then
		lblInstruct.caption := lblInstruct.caption &amp; "Must select an XML Format. " &amp; CrLf;	
	endif;

	if hubbleId = "" then
		lblInstruct.caption := lblInstruct.caption &amp; "Must enter a unique Hubble Id. " &amp; CrLf;	
	endif;

	if noidFileName &lt;&gt; "" then 
		fileObj.fileName := noidFileName;
		
		if fileObj.isAvailable() then
		else
			lblInstruct.caption := lblInstruct.caption &amp; "Unable to access Noid file selected. " &amp; CrLf;	
		endif;
	endif;

	if errorFileName = "" then
		txtError.text := hubbleId &amp; "_Error.txt";
		errorFileName := txtError.text; 	
	endif;
	
	if logFileName = "" then
		txtLog.text := hubbleId &amp; "_Log.txt";
		logFileName := txtLog.text; 		
	endif;
	
	if errorFileName = logFileName then
		lblInstruct.caption := lblInstruct.caption &amp; "It is unwise to make the log file name the same as the error file name. " &amp; CrLf;	
	endif;
	
	if baseRootObj &lt;&gt; null then
		if baseRootObj.allXmlOidTables.size() &gt; 0 then
			if baseRootObj.allXmlOidTables.getAtKey(hubbleId) &lt;&gt; null then
				lblInstruct.caption := lblInstruct.caption &amp; "Hubble Id entered is already in use by someone else. " &amp; CrLf;		
			endif;
		endif;		
	endif; 

	if lblInstruct.caption &lt;&gt; "" then
		return false;
	else
		return true;
	endif;
epilog
	delete fileObj;	
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="enableControls" id="8c011e54-dcf0-4203-9564-c489f8b842cf">
        <updating/>
        <source>enableControls()updating, protected;

begin
	if optImport.value then
		self.caption			:= "Hubble - IMPORT";
		lblInstruct.caption		:= "Input File (Main),  XML Format,  Input Kind and Hubble Id are required fields";
		lblInput.caption		:= "Input File (Main)";
		lblInputNoid.caption	:= "Input File (NOID)";
		cmbInputKind.enabled	:= true;
		lblInputKind.enabled	:= true;
		btnImport.enabled		:= true;
		btnExport.enabled		:= false;
		txtHubbleId.enabled		:= true;
		lblHubbleId.enabled		:= true;
		txtLog.enabled			:= true;
		lblLog.enabled			:= true;
		txtError.enabled		:= true;
		lblError.enabled		:= true;
		txtObjectsPer.enabled	:= true;
		lblObjectsPer.enabled	:= true;
	else
		self.caption			:= "Hubble - EXPORT";
		lblInstruct.caption		:= "Output File (Main), Output File (NOID) and XML Format are required fields";
		lblInput.caption		:= "Output File (Main)";
		lblInputNoid.caption	:= "Output File (NOID)";
		cmbInputKind.enabled	:= false;
		lblInputKind.enabled	:= false;
		btnImport.enabled		:= false;
		btnExport.enabled		:= true;
		txtHubbleId.enabled		:= false;
		lblHubbleId.enabled		:= false;
		txtLog.enabled			:= true;
		lblLog.enabled			:= true;
		txtError.enabled		:= false;
		lblError.enabled		:= false;
		txtObjectsPer.enabled	:= false;
		lblObjectsPer.enabled	:= false;
	endif;	
end;</source>
        <access>protected</access>
    </JadeMethod>
