    <JadeMethod name="isMTPoolParty_Match" id="e8602d86-b903-412b-b7d4-637ca3ec2a83">
        <source>isMTPoolParty_Match(_yaData: CM_YADataObjects): Boolean;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 20/12/2016	cnwdap1		Initial creation TFS 3040 SNO Empty Container Pool Management
//
vars
	bulkRelease : CM_BulkRelease;
	poolParty : CM_MTPoolingParty;

begin
	if _yaData.isEmpty then
		return true;
	endif;
	
	if self.myReserveSelection &lt;&gt; null and self.myReserveSelection.myReserveHeader &lt;&gt; null then
		bulkRelease := self.myReserveSelection.myReserveHeader;
		if _yaData.includes(bulkRelease.myPoolingParty) then
			return true;
		endif;
	endif;
	
	return false;
	
epilog

end;</source>
