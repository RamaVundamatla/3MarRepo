	if self.myCurrentVehicle = null then
		return;
	endif;
	
	vvr := self.myCurrentVehicle.getCurrentVisit();
	
	if vvr = null then
		return;
	endif;
	
	self.doChangeInspectionStatus(CM_VehicleVisitRecord.InspectionCompleted, true, vvr);
epilog

end;</source>
