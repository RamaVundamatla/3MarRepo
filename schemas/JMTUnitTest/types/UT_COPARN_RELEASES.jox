    <JadeMethod name="tCoparnAutoEmailTest" id="d75a8110-cbd6-4065-baf3-875907777249">
        <updating/>
        <source>tCoparnAutoEmailTest() updating;
/*

Date		Who		Reason
02 May 2016	cnwer1	Initial creation PAR
// 12 May 2016		cnwns1			TFS 488 - Multi Timezone Support
//13 May 2016	cnwrs1	TFS 1987 CargoSubType EDI Xlation
// 31 Oct 2017	jlgrs1	TFS 5705 - SNO - EDIDataBooking Prenote release Req
*/

constants	
	VESSEL		= 'UT_VCOPARN';
	VOYAGE		= 'UT_VCOPARN1';
	RELEASE1	= 'UT_COPARN_R001';
	OPERATOR	= 'MSK';
	SENDER1		= 'MSKCP';	SENDER2 = 'MAEUCP'; 
	PARTY		= 'Maersk Coparn Unit Tests';
	PARTY2 = 'Christina Coparn Unit Tests';
	CONSIGNOR 	= 'UTCOP';
	CONSIGNEE	= 'UTCOE';
	MT = '4'; FULL = '5';
		ADDITIONAL_TEXT	= "//PREASSIGNED CONTAINER TCLU2214123";
	ISOTYPE 		= '22G1';
	QUANTITY		= 8;
vars
	operator			:CM_Operator;
	ediParty	:CM_EDIParty;
	consign				:CM_ConsigneeConsignor;
	rules		:CM_EDIPartyCoparnRules;
	code, vesselCode, voyageCode		:String;
	now,
	ts1, ts2			:TimeStamp;
	voyage	:CM_Voyage;
	foundMatch	:Boolean;

	text	:String;
	ediFile	:CM_EDIFile;
	ediData	:CM_EDIData;
	ediTI	:CM_EDITrackedItem;
	ediAgent	: CM_EDIControllerAgent;
	result : Boolean;
	sysAlert : CM_SystemAlert;
	ediItem : CM_EDITrackedItem;
begin
	// disable cutoffs - they can stop a loadDB 
	self.disableAllEDIVoyageCutoffs;
	
	code := self.getTerminal.code;

	self.deleteReleaseRequest (RELEASE1); 	
	
		vesselCode := VESSEL &amp; code;
	voyageCode	:= VOYAGE &amp; code;
	
	self.deleteVoyage(voyageCode);
	self.deleteVessel(vesselCode);
	
	operator := self.getOperator (OPERATOR);
	
	self.assertNotNullMsg (operator, 'Operator '&amp;OPERATOR&amp;' does not exist');
	// now make sure all the translations we need are there
	self.deleteEDIInwardXlation ('GP', XLATION_TYPE_MTGRADE_BYOP, operator, null);
	self.deleteEDIInwardXlation ('DAIRY', XLATION_TYPE_MTGRADE_BYOP, operator, null);
	self.deleteEDIInwardXlation ('CHILLED', XLATION_TYPE_MTGRADE_BYOP, operator, null);
	self.deleteEDIInwardXlation ('RF', XLATION_TYPE_MTGRADE_BYOP, operator, null);
	self.deleteEDIInwardXlation ('5049000221', XLATION_TYPE_CONSIGNEE_BYOP, operator, null);
	self.deleteEDIInwardXlation ('5046240346', XLATION_TYPE_CONSIGNEE_BYOP, operator, null);
	
	self.createEDIXlation ('GP', 0.String, XLATION_TYPE_MTGRADE_BYOP, true, operator, null);
	self.createEDIXlation ('DAIRY', 1.String, XLATION_TYPE_MTGRADE_BYOP, true, operator, null);
	// these next translations have parameters
	self.createEDIXlation ('CHILLED', 19.String, XLATION_TYPE_MTGRADE_BYOP, true, operator, null, -2.Real, -2.Real, null.String);
	self.createEDIXlation ('CHILLED', 17.String, XLATION_TYPE_MTGRADE_BYOP, true, operator, null, -1.7.Real, -1.7.Real, null.String);
	self.createEDIXlation ('RF', 39.String, XLATION_TYPE_MTGRADE_BYOP, true, operator, null, -22.Real, -22.Real, "JORDAN");

	if not self.createEDIXlation ('5049000221', CONSIGNEE, XLATION_TYPE_CONSIGNEE_BYOP, true, operator, null) then
		self.assertEqualMsg (1, 2, 'Consignor xlation could not be created');
	endif;
	 
	if not self.createEDIXlation ('5046240346', CONSIGNEE, XLATION_TYPE_CONSIGNEE_BYOP, true, operator, null) then
		self.assertEqualMsg (1, 2, 'Consignor xlation could not be created');
	endif;
	// makes sure the operator can use ALL availability grades
	beginTransaction;
	self.clearOperatorCodeGroups (operator, CodeGroup_AvailabilityGrade);
	commitTransaction;
	
	// this voyage will be used in most files
	self.createVesselVoyage (voyageCode, vesselCode, operator);
	
	// we need one of these so create one
	consign := app.myRoot.allConsigneeConsignors [CONSIGNOR];
	
	if consign = null then
		consign := self.addConsigneeConsignor (CONSIGNOR, CONSIGNOR, true, true, true);
	endif;
	
	consign := app.myRoot.allConsigneeConsignors [CONSIGNEE];
	
	if consign = null then
		consign := self.addConsigneeConsignor (CONSIGNEE, CONSIGNEE, true, true, true);
	endif;
	
	// better create the EDI Party	
	self.deleteVoyage ('UT_HOLD' &amp; code);	// force voyage to be re-created without edi cutoffs
	// set up a party like MSK
	ediParty	:= self.createEDIPartyAndRules ('UT_HOLD' &amp; code, 'UT_HOLD' &amp; code, PARTY, PARTY, SENDER1, SENDER2, operator, false);
	rules		:= ediParty.getRulesForFileType (EDIFileType_Coparn).CM_EDIPartyCoparnRules;
	
	// change voyafge arrival/departure dates so we don't get cutoff errors
	voyage := self.getVoyage (voyageCode);
	
	if voyage &lt;&gt; null then
		ts1.setDate (ts1.date+7);
		beginTransaction;
		voyage.setArrivalDT (ts1);
		voyage.setDepartureDT (null);
		commitTransaction;
	endif;
	
	ts1 := app.actualTimeServer;// 12 May 2016		cnwns1			TFS 488 - Multi Timezone Support
	ts2 := app.actualTimeServer;// 12 May 2016		cnwns1			TFS 488 - Multi Timezone Support
	now	:= app.actualTimeServer;// 12 May 2016		cnwns1			TFS 488 - Multi Timezone Support
	
	ts1.setDate (ts1.date-2);
	ts1.setTime ('09:00'.Time);
	ts2.setDate (ts1.date+1);
	ts2.setTime ('15:00'.Time);
	
	self.setTerminalConfig(EdiReleaseAllowPartial, false);
	self.setTerminalConfig(EdiBookingAllowPartial, false);

	text := self.zCoparn_mtrel_withid (SENDER2, vesselCode, vesselCode, CONSIGNOR, RELEASE1, ADDITIONAL_TEXT, ISOTYPE, QUANTITY.String, ts1, ts2,MT);
	ediFile := self.ediLoadFileName(text, EDIFileType_Coparn, "COPARN", "COPARN"&amp;method.name);
	
	self.assertNotNull(ediFile);
	
	// ---------------------------------------
	// find the release request ediData
	// ---------------------------------------
	if ediFile.ediData.isKindOf(CM_EDIDataGateDoc) or
	   ediFile.ediData.isKindOf(CM_EDIDataReleaseRequest) then
		ediData := ediFile.ediData;
	else
		ediData := ediFile.allEDIData.first;
	endif;
	
	self.assertNotNullMsg (ediData, 'No edi data for release requests');
	
	// ---------------------------------------
	// find the edi tracked item
	// ---------------------------------------
//	ediTI := ediData.allEDITrackedItems.first.CM_EDIRequestHeaderTI;
	foreach ediItem in ediData.allEDITrackedItems do
		if  ediItem.isKindOf(CM_EDIRequestHeaderTI) then
			ediTI := ediItem.CM_EDIRequestHeaderTI;
			break;
		endif;
		if  ediItem.isKindOf(CM_EDIReleaseRequestTI) then
			ediTI := ediItem.CM_EDIReleaseRequestTI;
			break;
		endif;
	endforeach;
	
	self.assertNotNullMsg (ediTI, 'EDI tracked items not created');
	
	create ediAgent transient;
	ediAgent.setPropertyValue(CM_EDIControllerAgent::isBGPAuto.name,true);
	ediAgent.setTerminal(self.getTerminal());
	
	//ediData := _ediFile.ediData;
	result 	:= ediAgent.verifyEdiData(ediData);
	
	ediAgent.loadEdiDb(ediFile,ediData,false);
	self.assertEqual(ediData.status, CM_EDIFile.EDI_STATUS_DBLOADED);
	sysAlert:=self.getTerminal.allSystemAlertsByDateTime.last;
	
	if sysAlert &lt;&gt; null and sysAlert.dateTime &gt; now.addMinutes(-1) then
		if sysAlert.details.pos("Auto database load failure EDI_LOAD_" &amp; method.name,1) &gt; 0 then
			self.assertTrueMsg(false,"System alert incorrrectly created for db loaded edi file");
		endif;
	endif;
	
epilog
	delete ediAgent;
end;</source>
        <text>MTN-36111</text>
    </JadeMethod>
    <JadeMethod name="tCoparnReleaseEGMMeasureType" id="4cd1a7b5-b702-42b8-8d72-14215668ebd3">
        <updating/>
        <source>tCoparnReleaseEGMMeasureType() updating;
// navra1
/*
Date					Who			Reason
23rd Aug 2022 			navra1		Initial creation - TFS 55813
*/
constants
	ShipName = "CCMS1913";
	VoyageName = "CCMS1913VOY";
	RELEASE1 = 'ACD0278846';
	OPERATOR = 'ANL';
	SENDER1	= 'ANLCOPARN';
	SENDER2 = 'ANL';
	PARTY1 = 'Anl Coparn Unit Tests';
	PARTY2 = 'Anl Coparn Unit Tests2';	
vars
	vessel: CM_Vessel;
	voyage: CM_Voyage;
	ediFile : CM_EDIFile;
	releaseReq : CM_BulkRelease;
	releaseItem : CM_ReserveDetail;
	text : String;
	releaseItems : Integer;
	tempStr : String;
	operator : CM_Operator;
	code : String;
	ediParty : CM_EDIParty;
	rules : CM_EDIPartyCoparnRules;
	ts1	: TimeStamp;
	ts2	: TimeStamp;
	
	proxyTI, ti, ti2: CM_TrackedItem;	
	ediItem : CM_EDITrackedItem;
	ediData : CM_EDIData;
	ediTIDetail : CM_EDIRequestDetailTI;
	noOfSuccess : Integer;
begin
	// disable cutoffs - they can stop a loadDB 
	self.disableAllEDIVoyageCutoffs;
	code := self.getTerminal.code;	
	self.deleteVoyage(VoyageName);
	self.deleteVessel(ShipName);
	operator := self.getOperator (OPERATOR);
	self.assertNotNullMsg (operator, 'Operator '&amp;OPERATOR&amp;' does not exist');
	self.deleteEDIInwardXlation ('GP', XLATION_TYPE_MTGRADE_BYOP, operator, null);
	self.deleteEDIOutwardXlation (0.String, XLATION_TYPE_MTGRADE_BYOP, operator, null);	
	
	self.deleteContainer("HEAU0000001");
	proxyTI := createContainer("HEAU0000001", "2230", "CHOC", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString),true); // REEFER
	proxyTI.CM_Container.setPxyControlledAtmosphere(20, 30, true);
	proxyTI.setTemperature(5.0);
	ti := self.addContainerFromProxy(proxyTI); 
	assertTrueMsg(ti.CM_Container.getCurtainsIn &lt;&gt; null, "Heavy Container not created");	
	
	self.deleteContainer("LIGU0000001");
	proxyTI := createContainer("LIGU0000001", "2230", "CHOC", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString),true); // REEFER	
	proxyTI.CM_Container.setPxyControlledAtmosphere(20, 30, true);
	proxyTI.setTemperature(5.0);
	ti := self.addContainerFromProxy(proxyTI); 
	assertTrueMsg(ti.CM_Container.getCurtainsIn &lt;&gt; null, "Light Container not created");
	
	beginTransaction;
		self.clearOperatorCodeGroups (operator, CodeGroup_AvailabilityGrade);
	commitTransaction;
	
	self.createVesselVoyage( VoyageName,ShipName, operator);
	self.deleteEDIParty(PARTY2);
	
	ediParty := self.createEDIPartyAndRules('UT_HOLD' &amp; code, 'UT_HOLD' &amp; code, PARTY1, PARTY1, SENDER1, SENDER2, operator, false);
	rules := ediParty.getRulesForFileType(EDIFileType_Coparn).CM_EDIPartyCoparnRules;
	
	voyage := self.getVoyage(VoyageName);	
	
	self.setTerminalConfig(EdiReleaseAllowPartial, false);
	self.setTerminalConfig(EdiBookingAllowPartial, false);

	text :=
"UNB+UNOA:2+"&amp;OPERATOR&amp;"+NZOTAGO+161123:1947+RLO1969992++COPARN'
UNH+1+COPARN:D:03A:UN'
BGM+12+"&amp;RELEASE1&amp;"+9'
DTM+137:201611231947:203'
RFF+BN:"&amp;RELEASE1&amp;"'
TDT+20+"&amp;VoyageName&amp;"+1++"&amp;OPERATOR&amp;"+++9445526:::"&amp;ShipName&amp;"'
LOC+9+NZPOE:139:6'
LOC+11+NZTRG'
NAD+MS+"&amp;OPERATOR&amp;"'
NAD+MR+:160:87'
EQD+CN+HEAU0000001+2230+++4'
EQN+1'
MEA+AAE+EGW+KGM:26020'
TMP+5+12.0:CEL'
FTX+AAA+++CHOC'
FTX+QQD++1'
EQD+CN+LIGU0000001+2230+++4'
EQN+1'
MEA+AAE+EGW+KGM:2620'
TMP+5+12.0:CEL'
FTX+AAA+++CHOC'
FTX+QQD++1'
UNT+28+1'
UNZ+3+RLO1969992'
EOF";

	ediFile := self.ediLoadFileName(text, EDIFileType_Unknown, "COPARN", "COPARN"&amp;method.name);	
	self.assertNotNull(ediFile);
	self.ediVerify(ediFile);
	tempStr	:= 'Verify failed' &amp; CrLf &amp; app.myPassport.getErrorsAsString;
	self.assertEqualMsg(ediFile.fileStatus, CM_EDIFile.EDI_STATUS_VERIFIED, tempStr);
	self.ediDBLoad(ediFile);
	tempStr	:= 'DB Load failed' &amp; CrLf &amp; app.myPassport.getErrorsAsString;
	self.assertEqualMsg(ediFile.fileStatus, CM_EDIFile.EDI_STATUS_DBLOADED, tempStr);	
	
	ediData := ediFile.ediData;				
	
	noOfSuccess := 0;
	foreach ediItem in ediData.allEDITrackedItems do	
		if ediItem.isKindOf(CM_EDIRequestDetailTI) then					
			ediTIDetail := ediItem.CM_EDIRequestDetailTI;				
			if ediTIDetail.id = 'HEAU0000001' then
				self.assertTrueMsg(ediTIDetail.heavyDuty = true, "HEAU0000001's heavy duty flag was not set to true");
				noOfSuccess := noOfSuccess+1;
			endif;
			if ediTIDetail.id = 'LIGU0000001' then
				self.assertTrueMsg(ediTIDetail.heavyDuty = false, "LIGU0000001's heavy duty flag was not set to false");
				noOfSuccess := noOfSuccess+1;
			endif;
		endif;															
	endforeach;	
	
	self.assertTrueMsg(noOfSuccess = 2, "There were container(S) missing, there should have been 2 in the EDI");

end;
</source>
        <text>MTN-36111</text>
