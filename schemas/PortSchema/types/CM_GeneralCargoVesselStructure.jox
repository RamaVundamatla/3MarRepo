    <JadeMethod name="exportAsXMLInverseRef" id="619dc90d-97ef-4cc4-a29b-33ba80d1b366">
        <source>exportAsXMLInverseRef(_property: Reference): Integer protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 July 2013	cnwndl1	Initial creation	Par 31965

*/

vars

begin

	if _property = CM_GeneralCargoVesselStructure::allHoldLocnDefnByHatchPlace then
		return ExportAsParent;
	endif;
	
	return inheritMethod(_property);

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_property" type="Reference"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getXMLDefinitionString" id="bfaa41d5-bad7-4f58-a077-af403f058ffa">
        <source>getXMLDefinitionString(): String;
//--------------------------------------------------
// Created:	28 March 2006 By: cnwgd1
//--------------------------------------------------
vars
	xml : String;
begin

	xml := inheritMethod().String;

//	xml := xml &amp; "&lt;nht&gt;" &amp; self.numberOfHatches.String &amp; "&lt;/nht&gt;";
	
	return xml;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="importFromXMLDocReference" id="caff96fc-c017-4806-80f1-c8711fc4a26a">
        <updating/>
        <source>importFromXMLDocReference(_property: Property; _xmlElement: JadeXMLElement input) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 July 2013	cnwndl1	Initial creation	Par 31965

*/

vars

	childElement : JadeXMLElement;
	allChildElements : JadeXMLElementArray;
	pxyGCHoldLocnDef : CM_GCHoldLocationDefn;

begin

	if _property = CM_GeneralCargoVesselStructure::allHoldLocnDefnByHatchPlace then
		create allChildElements transient;
		_xmlElement.getAllElementsByTagName(CM_GCHoldLocationDefn.name,allChildElements);
		foreach childElement in  allChildElements do
			create pxyGCHoldLocnDef transient;
			pxyGCHoldLocnDef.importFromXMLDoc(childElement);
			pxyGCHoldLocnDef.setMyGCVesselStructure(self);
		endforeach;
	endif;
	
	inheritMethod(_property, _xmlElement);

epilog

	delete allChildElements;	//30 May 2019	NDL	TFS 44773

end;</source>
        <access>protected</access>
        <Parameter name="_property" type="Property"/>
        <Parameter name="_xmlElement" type="JadeXMLElement" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="2c33795f-bd94-4c9e-9063-d6bbc450305d">
        <updating/>
        <source>setForCreate(_proxyVessel: CM_GeneralCargoVesselStructure; _passport: CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 July 2013	cnwndl1	Initial creation	Par 31965

*/

vars

	pxyGCLocnDefn : CM_GCHoldLocationDefn;
	realGCLocnDefn : CM_GCHoldLocationDefn;
	deleteUs : ObjectSet;	//30 May 2019	NDL	TFS 44773

begin

	inheritMethod(_proxyVessel, _passport);
	
	//should only be there in a create if its XML generated data
	create deleteUs transient;	//30 May 2019	NDL	TFS 44773
	foreach pxyGCLocnDefn in _proxyVessel.allHoldLocnDefnByHatchPlace do
		if self.allHoldLocnDefnByHatchPlace[pxyGCLocnDefn.hatch,pxyGCLocnDefn.place] = null then
			create realGCLocnDefn persistent;
			pxyGCLocnDefn.setMyGCVesselStructure(null);	
			realGCLocnDefn.setForUpdate(pxyGCLocnDefn);
			realGCLocnDefn.setMyGCVesselStructure(self);
			deleteUs.add( pxyGCLocnDefn );	//30 May 2019	NDL	TFS 44773
		endif;
	endforeach;
	
	//30 May 2019	NDL	TFS 44773
	if not deleteUs.isEmpty then
		deleteUs.purge();
	endif;

epilog

	delete deleteUs;	//30 May 2019	NDL	TFS 44773

end;</source>
        <Parameter name="_proxyVessel" type="CM_GeneralCargoVesselStructure"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
