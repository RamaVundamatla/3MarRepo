vars

begin
	return true;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="04b90393-eb11-43fe-9424-e93fd899bcfa">
        <source>pxyCreateUpdateProxy(): SelfType;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 March 2014	cnwndl1	Initial creation	Par 33268

*/

vars
	proxy	:SelfType;
	completedOK		: Boolean;
begin
	proxy :=  inheritMethod();

	proxy.myWeighBridge	:= self.myWeighBridge;
	
	completedOK := true;			
	return proxy;
epilog
	if not completedOK then			
		delete proxy;
	endif;

end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="142c0b7b-9325-4a26-bb99-972448095f37">
        <updating/>
        <source>setForUpdate(_proxy: CM_LDWeighBridge) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 March 2014	cnwndl1	Initial creation	Par 33268

*/

vars

begin

	self.myWeighBridge	:= _proxy.myWeighBridge;
	
	inheritMethod(_proxy);

epilog

end;</source>
        <Parameter name="_proxy" type="CM_LDWeighBridge"/>
    </JadeMethod>
    <JadeMethod name="setWeighBridge" id="f775ea42-2f73-4605-bfca-fc68e78c5875">
        <updating/>
        <source>setWeighBridge( _myWeighBridge : CM_WeighBridgeObj ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 March 2014	cnwndl1	Initial creation	Par 33268
//22/03/17 cnwns1 TFS3153:PKT - Bulk Process - WeighBridge Integration
*/

vars

begin
//	self.raiseExceptionIfNotTransient (method);
	
	if self.myWeighBridge &lt;&gt; _myWeighBridge then
		self.myWeighBridge := _myWeighBridge;
	endif;
epilog

end;</source>
        <Parameter name="_myWeighBridge" type="CM_WeighBridgeObj"/>
    </JadeMethod>
    <JadeMethod name="validate" id="f0036e20-683d-4c3d-ba31-c57c3c8d1467">
        <source>validate(_passport: CM_Passport input) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 March 2014	cnwndl1	Initial creation	Par 33268

*/

vars

begin
	inheritMethod(_passport);

	if self.myWeighBridge = null then
		app.raiseUnexpectedProgramError (self.class.name, method.name, 'Weigh Bridge required');
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
</Class>
