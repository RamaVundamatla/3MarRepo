    <JadeMethod name="emailNotify" id="9d0f4367-9000-4d1b-aff1-3db0ffbe2068">
        <source>emailNotify(_objectEmail: CM_ObjectEmail; _isDelete: Boolean; _object: CM_Object input);
/*
Purpose - 	
Who - NAVAB1
Date - 16JUL2024
ADO -  CR 64617 TASK 64637
*/

vars
	fromAddress, bodyStr	: String;
	headerSet : CM_FileDataStorageHdrSet;
	passport : CM_Passport;
	errorSet : CM_ErrorSet;
begin

	if _objectEmail = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'object email is null');
		return;
	endif;

	fromAddress := app.myRoot.getConfig(AutoSendersEmailAddress).String;

	bodyStr := self.getObjectEmailBody(_objectEmail);
	
	// we need to include the  EDI errors in the body message, but we do not want the email TRX seeing the EDI errors as a reason to stop.
	// copy the current errors to local set and put them back after the TRX
	create errorSet transient;
	passport := app.myPassport;
	passport.moveErrorsToSet(errorSet);

	app.myTrxCA.trxCreateEmailSendRequest(_objectEmail.name,
															_objectEmail.getToAddresses(),
															fromAddress, 
															_objectEmail.getCcAddresses,
															_objectEmail.getBccAddresses,
															self.getObjectEmailSubject(_objectEmail),
															bodyStr,
															null, null, null, null, EmailSource_EDIIssue, null, app.myPassport );	
															
	passport.moveErrorsToSet(errorSet);
	passport.addErrorsFromSet(errorSet); 

epilog
	delete errorSet;
end;
</source>
        <Parameter name="_objectEmail" type="CM_ObjectEmail"/>
        <Parameter name="_isDelete" type="Boolean"/>
        <Parameter name="_object" type="CM_Object" usage="input"/>
    </JadeMethod>
    <JadeMethod name="erase" id="e5d029fe-5eb4-4185-8b4f-b5b6c3a8bb8b">
        <updating/>
        <source>erase(_eraseLevel: Integer) updating;
//----------------------------------------------------------------
//	Created:	26 August 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
// 06/12/2011	cnwcs5		ccms pol 2122 / PAR 28696
vars
	file			:CM_EDIFile;
	otherEDIData	:CM_EDIData;
begin
	//do this first to close dead lock window - don't wait for jade automatic update
	//this is train consist
	self.allEDITrackedItems.purge();
	
	// there is a parent child between ediData and ediFile so if we delete the edidata jade will
	// delete the ediFile.  if there is &gt; ediData for the file then detach the receiver
	file := self.myEDIFile;
	// it is possible for the file to be null if we are loading a multi-data edi file 
	// and at the end of processing we find that it is empty and should be deleted
	if file &lt;&gt; null then 
		if file.ediData = self then
			// we need to replace this reference with one from the array of secondary edi data
			otherEDIData := file.allEDIData.first;
			
			if otherEDIData &lt;&gt; null then
				// make this the main edi data
				file.allEDIData.remove (otherEDIData);
				
				file.ediData := otherEDIData;
				
			endif;
		elseif file.ediData &lt;&gt; null then
			// remove receiver from allEDIData so the file does not get deleted
			file.allEDIData.remove (self);
		endif;
	endif;
	
	inheritMethod(_eraseLevel);


end;</source>
        <Parameter name="_eraseLevel" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="fileName" id="a8510c97-daa3-4acf-9015-fd09657e4da7">
        <methodInvocation>mapping</methodInvocation>
        <source>fileName(set: Boolean; _value: String io) mapping;
// ---------------------------------------------------------------------------
// Created:		20 June 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------
// 12 Aug 2016	cnwrs1	Par 38117 make deleted EDI for finable
vars
	ediFile	: CM_EDIFile;
begin
	if set then
		return;
	endif;
	
	if self.myEDIFile &lt;&gt; null then // not self.ediFileArray.isEmpty then // ccms1117 cnwrs1 29 Apr 2010
		ediFile := self.myEDIFile; // ediFileArray.last; // ccms1117 cnwrs1 29 Apr 2010
		if ediFile &lt;&gt; null then
			if ediFile.fileName.length &gt; 60 then
				_value := "..." &amp; ediFile.fileName.reverse[1:57].reverse;
			else	
				_value := ediFile.fileName.reverse[1:60].reverse;
			endif;
		else
			_value := null;
		endif;
	endif;
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="fileVersion" id="c819047a-4fe8-4ead-bdef-b91cd4a9186f">
        <methodInvocation>mapping</methodInvocation>
        <source>fileVersion(set: Boolean; _value: String io) mapping;
// ---------------------------------------------------------------------------
// Created:		20 June 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------

vars
	ediFile	: CM_EDIFile;
begin
	if set then
		return;
	endif;
	
	if self.myEDIFile &lt;&gt; null then // not self.ediFileArray.isEmpty then // ccms1117 cnwrs1 29 Apr 2010
		ediFile := self.myEDIFile; // ediFileArray.last; // ccms1117 cnwrs1 29 Apr 2010
		if ediFile &lt;&gt; null 
		and ediFile.myEDIFileType &lt;&gt; null then
			_value := ediFile.myEDIFileType.name[1:35];
		else
			_value := " ";
		endif;
	endif;
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="String" usage="io"/>
    </JadeMethod>
