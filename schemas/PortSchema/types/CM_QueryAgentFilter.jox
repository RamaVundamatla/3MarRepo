    <JadeMethod name="qryVoyageRowSummary" id="4b558563-ed18-4793-8b99-822b8efbb2ad">
        <updating/>
        <source>qryVoyageRowSummary(_filter : CMQF_FilterReports input; _passport : CM_Passport) : Integer updating;
// ---------------------------------------------------------------------------
// Created:     28 August 2002 by cnwth2
//
// Purpose:     
//
// ----------   ----------  --------------------------------------------------
vars
	numSelected			: Integer;
	jrwTrans			: CM_JRWSOHLocation;
	sohFilter			: CMQF_SOHReporter;
	voyage				: CM_Voyage;
	globalVoyage		: CM_VoyageGlobal;
	rowLoadoutDict		: CMIF_RowLoadoutBySOHLocDict;
	rowLoadout			: CMIF_RowLoadout;
	sohReporter			: CMIF_SOHReporter;
	tmpDict				: CM_VoyageByArrivalDTTerminal;			
begin
	
	on CM_BreakOutException do self.xHandlerBreakOut(exception);
		
	sohFilter := _filter.CMQF_SOHReporter;
	jrwTrans := self.createJRWTransient(CM_JRWSOHLocation).CM_JRWSOHLocation;
	jrwTrans.allSOHReporters.clear();
	
	globalVoyage := sohFilter.getMyVoyageGlobalAllocated;
	if globalVoyage = null then
		return null;
	endif;
	//get voyage's allocated row's loadout details
	tmpDict := globalVoyage.allVoyages;
	create rowLoadoutDict transient;
	foreach voyage in tmpDict where sohFilter.allTerminals.includes(voyage.myTerminal) do
		if voyage.myLogVoyageStructure &lt;&gt; null then		
			voyage.getRowLoadoutDetails(TI_CargoType_Log, rowLoadoutDict);
		endif;
	endforeach;
	
	//get the SOHReporter objects as per a normal LogProductLocation report
	_filter.filterObjects(jrwTrans.allSOHReporters, _passport);

	//assing the query criteria so it may be displayed in the report
//	sohFilter.allTerminals.copy(jrwTrans.allTerminals);
	jrwTrans.setAllTerminals(sohFilter.allTerminals);
	jrwTrans.blockLength 	:= _filter.blockLength;
	jrwTrans.baseDate		:= _filter.baseDate;
	jrwTrans.ageType		:= _filter.ageType;
	jrwTrans.myOperator 	:= sohFilter.myOperator;
	jrwTrans.myLogSpecies 	:= sohFilter.getMyLogSpecies;
	jrwTrans.myLogGrade 	:= sohFilter.getMyLogGrade;
	jrwTrans.myLogType 		:= sohFilter.getMyLogType;
	jrwTrans.myLogTreatment := sohFilter.getMyLogTreatment;
	jrwTrans.myLogLength 	:= sohFilter.getMyLogLength;
	
	foreach sohReporter in jrwTrans.allSOHReporters do
		rowLoadout := rowLoadoutDict[sohReporter.mySOHLocation];
		if rowLoadout &lt;&gt; null then
			sohReporter.loadoutRowQuantity := rowLoadout.quantity;
			sohReporter.loadoutRowVolume := rowLoadout.volume;
			sohReporter.loadoutRowWeight := rowLoadout.weight;
		endif;	
	endforeach;
	
	numSelected := jrwTrans.allSOHReporters.size;

epilog
//process.debug;

	if rowLoadoutDict &lt;&gt; null then
		rowLoadoutDict.purge;
	endif;
	delete rowLoadoutDict;
	return numSelected;
end;</source>
        <Parameter name="_filter" type="CMQF_FilterReports" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="qryVoyageSideProfile" id="12d7758c-5d4d-4687-8196-c6cc25ed1aa3">
        <updating/>
        <source>qryVoyageSideProfile(_filter : CMQF_FilterReports input; _passport : CM_Passport) : Integer updating;
// -------------------------------------------
