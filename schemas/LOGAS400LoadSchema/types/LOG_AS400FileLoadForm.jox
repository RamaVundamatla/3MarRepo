    <JadeMethod name="displayErrorMessage" id="a98b5e2d-9cc2-4085-8489-5c913b166374">
        <source>displayErrorMessage(_message : String) protected;

vars

begin

	if 	self.myFileLoadAgent.allErrors.size &gt; 0 then
		app.msgBox(_message, "Warnings", MsgBox_OK_Cancel);
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="_message" type="String"/>
    </JadeMethod>
    <JadeMethod name="doDelete" id="fcdaeaad-a01e-4fc4-9d4a-82fec7c76c63">
        <updating/>
        <source>doDelete() updating, protected;

vars

begin

	if self.mySelectedFileLoad &lt;&gt; null then
		app.mousePointer := MousePointer_HourGlass;	
		self.myFileLoadAgent.doFileLoadDelete(self.mySelectedFileLoad);
		loadTable();
		self.txtID.text := null;
	endif;
	
epilog

	app.mousePointer := MousePointer_Default;	

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doDocketLoad" id="e901b68b-da8b-436c-ad65-8255e3569fe8">
        <updating/>
        <source>doDocketLoad() protected, updating;

vars

	defaultCarrier, defaultTruck : String;

begin

	if self.mySelectedFileLoad &lt;&gt; null then
		app.mousePointer := MousePointer_HourGlass;	
		defaultCarrier := self.tblDefault.getValueByName(ETRow_Carrier).String;
		defaultTruck := self.tblDefault.getValueByName(ETRow_Vehicle).String;
		self.myFileLoadAgent.doDocketLoad(self.mySelectedFileLoad, defaultCarrier, defaultTruck, progressBar);
		loadTable();
	endif;

epilog	
	if self.myFileLoadAgent.allErrors.size &gt; 0 then
		displayErrorMessage('Errors were encountered  during docket load. Please view ' &amp; app.getLogFilename &amp; ' for details');
	endif;
	app.mousePointer := MousePointer_Default;	

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doFileLoad" id="7fb83cef-7006-41fa-9323-b71e7835d530">
        <updating/>
        <source>doFileLoad() protected, updating;

vars

	id, docketFile, logFile, terminal	: String;

begin

	app.mousePointer := MousePointer_HourGlass;	
	id := self.txtID.text;
	docketFile := self.txtDocketFile.text;
	logFile := self.txtLogFile.text;
	terminal := self.cmbTerminals.text;

	self.myFileLoadAgent.doFileLoad(id, docketFile, logFile, terminal);

epilog

	if self.myFileLoadAgent.allErrors.size &gt; 0 then
		displayErrorMessage('Errors were encountered  during file load. Please view ' &amp; app.getLogFilename &amp; ' for details');
	endif;
	initForm();
	app.mousePointer := MousePointer_Default;	
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doLogLoad" id="a700235a-b8d3-4ad7-8bed-d52ea7df4a6f">
        <updating/>
        <source>doLogLoad() protected, updating;

vars

begin

	if self.mySelectedFileLoad &lt;&gt; null then
		app.mousePointer := MousePointer_HourGlass;	
		self.myFileLoadAgent.doLogLoad(self.mySelectedFileLoad, progressBar);
		loadTable();
	endif;

epilog	

	if self.myFileLoadAgent.allErrors.size &gt; 0 then
		displayErrorMessage('Errors were encountered  during log load. Please view ' &amp; app.getLogFilename &amp; ' for details');
	endif;
	app.mousePointer := MousePointer_Default;	


end;</source>
        <access>protected</access>
    </JadeMethod>
