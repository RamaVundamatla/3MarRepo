    <JadeMethod name="setForCreateFromTIs" id="b9591862-714d-4b73-b3c7-93fdd7b15755">
        <updating/>
        <source>setForCreateFromTIs(_tiDict: CM_TIByIdDict; _ediConfig: CM_EDIConfig input; _realEdiFile: CM_EDIFile input; _userCode: String) updating; // cnwrs1 Par 24207 ccms 1117 11 May 2010
//----------------------------------------------------------------
//	Created:	19 January 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
// 07 Apr 2019	jlgrs1	TFS 41913 STWR - Reconfiguration of the EDI Operation form to better handle EDI collection locks while loading 
//
vars
	ti : CM_TrackedItem;
begin
	inheritMethod(_tiDict, _ediConfig, _realEdiFile, _userCode); // cnwrs1 Par 24207 ccms 1117 11 May 2010
	
	ti := _tiDict.first;

	if ti &lt;&gt; null then
		self.voyageCode := ti.voyageCode;
	endif;
end;</source>
        <Parameter name="_tiDict" type="CM_TIByIdDict"/>
        <Parameter name="_ediConfig" type="CM_EDIConfig" usage="input"/>
        <Parameter name="_realEdiFile" type="CM_EDIFile" usage="input"/>
        <Parameter name="_userCode" type="String"/>
    </JadeMethod>
    <JadeMethod name="setForCreateFromVoyage" id="20e5692e-e3f2-4746-ba78-c1d7a612b0b2">
        <updating/>
        <source>setForCreateFromVoyage(_voyage : CM_Voyage; 
					  _useInwardsCode : Boolean;							// TFS 6851
					  _ediConfig : CM_EDIConfig input;
					  _planType	: Integer;
					  _realEdiFile : CM_EDIFile input;
					  _userCode, _shipperCode : String;
					  _cargoOperator :CM_Operator) updating;
//----------------------------------------------------------------
//	Created:	23 September 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
// cnwrs1 par 27733 17 June 2011 - fix memory leak with transinet voyage jobs
// 21/03/2012	cnwcs5	CCMS POL 2144 / Par 29312 - Extract Baplie by Operator
// 31/05/2012	cnwcs5	CCMS SFW 1284 - EDI BGP Split - use setStatus instead of status := 
// 24/04/2013	cnwcs5	par 30652 - remove resynch/resynchObject method calls
// 19/09/2017	jlgdap1	TFS 6851 SSL Set voyage code correctly if using inwards code
// 07 Apr 2019	jlgrs1	TFS 41913 STWR - Reconfiguration of the EDI Operation form to better handle EDI collection locks while loading 
//
vars
	ti					: CM_TrackedItem;
	tiDict,
	tmpTIDict			: CM_TIByCargoTypeIdDict;
	bulkReleases		: ObjectArray;
begin
	self.setForCreateNoProxy(_ediConfig, EDIDataType_BayPlan, null, _realEdiFile, _userCode); // cnwrs1 Par 24207 ccms 1117 11 May 2010
	
	self.voyageCode		:= _voyage.code;
	if _useInwardsCode then									// TFS 6851
		self.voyageCode := _voyage.inwardCode;				// TFS 6851
	endif;													// TFS 6851
	
	if _voyage.myOperator &lt;&gt; null then
		self.operatorCode := _voyage.myOperator.code;
	endif;
	
	self.vesselName		:= _voyage.vesselName;
	self.arriveTime		:= _voyage.arrivedDT;
	self.departTime		:= _voyage.departedDT;
	self.fromPort		:= self.ediConfig.myTerminal.getConfig(PortDestCode).String;
	
	self.setStatus (CM_EDIFile.EDI_STATUS_EXTRACTED);	// CCMS SFW 1284 - May 2012
	
	self.shipperCode 	:= _shipperCode; //par16270 cnwrs1 mar 2008
		
	if _planType = ACTUAL_BAYPLANS then
		//------------------
		//	ACTUAL
		//------------------
		tiDict := _voyage.allOnshipTIsByCargoTypeId;
		
		foreach ti in tiDict do
			if _cargoOperator &lt;&gt; null and ti.myOperator &lt;&gt; _cargoOperator then	// par 29312 - march 2012
				continue;
			endif;
			
			//cnwmc5 - 20 Jan 2016 - PAR 37023
			if not ti.myPrimaryActualLocation.isSlotController() then
				continue;
			endif;
			
			self.processTIs(ti, ACTUAL_BAYPLANS);
		endforeach;
		
	elseif _planType = PROPOSED_BAYPLANS then
		if _voyage.myCellularVoyageStructure &lt;&gt; null then
			//------------------
			//	PROPOSED
			//------------------
			create tmpTIDict transient;
			
			_voyage.myCellularVoyageStructure.getProposedBayPlanTIs(tmpTIDict);
			
			foreach ti in tmpTIDict do
			
				if _cargoOperator &lt;&gt; null and ti.myOperator &lt;&gt; _cargoOperator then	// par 29312 - march 2012
					continue;
				endif;
				
				self.processTIs(ti, PROPOSED_BAYPLANS);
			endforeach;
		else
			tiDict := _voyage.allOnsiteTIsByCargoTypeId;
			
			foreach ti in tmpTIDict do
				
				if _cargoOperator &lt;&gt; null and ti.myOperator &lt;&gt; _cargoOperator then	// par 29312 - march 2012
					continue;
				endif;
				
				self.processTIs(ti, PROPOSED_BAYPLANS);
			endforeach;
		endif;
	endif;

epilog
	create bulkReleases transient;
	
	if tmpTIDict&lt;&gt; null then
		foreach ti in tmpTIDict do
			if ti.isTransient then
				bulkReleases.add(ti);
				ti.allJobsShipReceive.purge;	//cnwrs1 par 27733 fix leak
				ti.allJobsShipRelease.purge;
			endif;
		endforeach;
	endif;
	
	delete tmpTIDict;
	bulkReleases.purge;
	delete bulkReleases;		// PAR #27874
end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_useInwardsCode" type="Boolean"/>
        <Parameter name="_ediConfig" type="CM_EDIConfig" usage="input"/>
        <Parameter name="_planType" type="Integer"/>
        <Parameter name="_realEdiFile" type="CM_EDIFile" usage="input"/>
        <Parameter name="_userCode" type="String"/>
        <Parameter name="_shipperCode" type="String"/>
        <Parameter name="_cargoOperator" type="CM_Operator"/>
    </JadeMethod>
