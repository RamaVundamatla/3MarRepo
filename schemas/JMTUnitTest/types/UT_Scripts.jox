end;</source>
    </JadeMethod>
    <JadeMethod name="uUnpackTrackedItem" id="3803c86f-54a2-44ba-a5d4-74f2f6562a13">
        <source>uUnpackTrackedItem();
//18 September 2008	cnwdw1	
//
vars
	trackedItemId: String;
	ti, child: CM_TrackedItem;
	unpackTIs: CM_TIArray;
begin
	trackedItemId := "id";
	read trackedItemId;
	ti := getTrackedItem(trackedItemId);
	
	assertNotNull(ti);
	
	create unpackTIs transient;
	foreach child in ti.allChildren do
		unpackTIs.add(child);
	endforeach;
	
	self.unpackContainer(ti, unpackTIs);
	
	assertTrue(ti.allChildren.size = 0);

	
epilog
	delete unpackTIs;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="uUnqueueTrackedItem" id="2340045e-fada-4dab-8f47-ecc708f2fd35">
        <source>uUnqueueTrackedItem();
//18 September 2008	cnwdw1	
//
vars
	trackedItemId: String;
begin
	trackedItemId := "id";
	read trackedItemId;
	unqueueTI(getTrackedItem(trackedItemId));
end;</source>
    </JadeMethod>
    <JadeMethod name="uVerifyXLATCaptionsForDebug" id="91317b40-7901-46e8-8b1f-b23edf5108b8">
        <source>uVerifyXLATCaptionsForDebug();
/*

Purpose:			DO NOT RUN IN DMAST

Parameters:			

Return Value:		

Date		Who		Reason
29 February 2024	navpw1	Initial creation

*/

vars
	verAdmin					: UT_Verification_Admin;
	
	userSummaryDict				: CM_AssociationDict;
	association					: CM_Association;
	summary						: String;
	iter						: Iterator;
	line						: String;
	user						: String;
	
begin
	create userSummaryDict transient;
	create verAdmin transient;
	
	if not app.isDevelopmentSystemMain() and not app.isUnicode then
		userSummaryDict.clear();
		verAdmin.sendMsgWithIOParams('vGenXLATFormMethod', userSummaryDict);
		line := userSummaryDict.str("CNWMH5");
		userSummaryDict.removeAssoc("CNWMH5");
		iter := userSummaryDict.createIterator();
		summary := "";
		while iter.next(association) do
			userSummaryDict.getIteratorKeys(user, iter);
//			write 'user: ' &amp; user &amp; Tab &amp; 'summary: ' &amp; association.asStringWithoutFailures();
			summary := summary &amp; CrLf &amp; user &amp; "@jadeworld.com" &amp; CrLf &amp; association.asStringWithoutFailures() &amp; CrLf; //association.asString;	// 24/03/2011 cnwmh5
			//self.emailReports(association.asString, "XLAT Form Constants Missing for " &amp; user, 0, testRunner);			//cnwmc5 - 12/10/2012
			self.logMessage("XLAT Form Constants Missing for " &amp; user);
			self.logMessage(association.asString);
		endwhile;
		if line &lt;&gt; null then
			userSummaryDict.clear();
			userSummaryDict.addAssociation("CNWMH5", line);
			summary := "";
			iter.reset;
			while iter.next(association) do
				userSummaryDict.getIteratorKeys(user, iter);
//				write 'user: ' &amp; user &amp; Tab &amp; 'summary: ' &amp; association.asStringWithoutFailures();
				summary := summary &amp; CrLf &amp; user &amp; "@jadeworld.com" &amp; CrLf &amp; association.asStringWithoutFailures() &amp; CrLf; //association.asString;	// 24/03/2011 cnwmh5
				//self.emailReports(association.asString, "XLAT Form Constants Missing", 2, testRunner);			//cnwmc5 - 12/10/2012
				self.logMessage("XLAT Form Constants Missing");
				self.logMessage(association.asString);
			endwhile;
		endif;
	endif;
	
epilog
	delete userSummaryDict;	
	delete verAdmin;
	delete iter;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="uZClearOutTerminalUsers" id="667cfed0-6b6e-4b6a-be36-0ce6674c7c7c">
        <source>uZClearOutTerminalUsers();
/*
Purpose:			get rid of unwanted users on a terminal
Date		Who		Reason
16 September 2016	NAVAB1	Initial creation
*/

vars
	term : CM_Terminal;
	user : String;
	userterm : CM_UserTerminal;
begin
	term := app.myRoot.allTerminals["BISH"];
	user := "CNWAB";
	
	foreach userterm in term.allUserTerminals discreteLock do
		if userterm.myUser.code[1:5] = user 
		or userterm.myUser.code[1:5] = "BGPUSER" then
			continue;
		endif;
		
		beginTransaction;
		userterm.erase(NORMAL_ERASE);
		commitTransaction;
	endforeach;
	

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="uZapTrackedItem" id="1661c623-ee88-4b4c-9142-5c910e5122cd">
        <source>uZapTrackedItem();
//18 September 2008	cnwdw1	
//
vars
	trackedItemId: String;
	ti: CM_TrackedItem;
begin
	trackedItemId := "id or oid";
	read trackedItemId;
	ti := getTrackedItem(trackedItemId);
	if ti = null then
		ti := trackedItemId.asOid.CM_TrackedItem;
	endif;
	assertNotNull(ti);
	
	zapTrackedItem(ti);
end;</source>
    </JadeMethod>
