//--------------------------------------------------
// Created:	06 May 2005 By: cnwgd1
//--------------------------------------------------
vars
	str : String;
	idx : Integer;
begin

	str := _tiLCType.getAttributeStringForDefArray(self.tblData.allTblDataEntRows);
	idx := self.tblData.addItemObject(_tiLCType, str);

	self.tblDataDisplayColourColumn(idx, _tiLCType.colour);
					
end;</source>
        <Parameter name="_tiLCType" type="CM_TILCType"/>
    </JadeMethod>
