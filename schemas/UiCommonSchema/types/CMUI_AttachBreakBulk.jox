    <JadeMethod name="getAvailableRowsForProduct" id="b50292d0-c560-492c-bf6a-e5782c68d23b">
        <source>getAvailableRowsForProduct();
// ---------------------------------------------------------------------------
// Created:     16 October 2002		cnwth2	
//
// Purpose:     Populates the cmbWHRows with warehouse rows that are valid for the selected cargo type
//				and product
//			 
// ----------   ----------  --------------------------------------------------
vars
	cargoType		: CM_CargoType;
	product			: CM_Product;
	termArea		: CM_TerminalArea;
	row,
	origRow			: CM_LocationsController;
	searchType		: CMIF_SearchTypes;			
	rowSet			: CM_LCSet;
begin
	origRow := self.cmbLC.listObject.CM_LocationsController;
	
	self.cmbLC.clear();
	cargoType := self.cmbCargoType.listObject.CM_CargoType;
	product := self.cmbProduct.listObject.CM_Product;
	termArea := self.cmbTerminalArea.listObject.CM_TerminalArea;

	if cargoType = null or
		termArea = null then
		return;
	endif;	
	
	create searchType transient;
	create rowSet transient;
	
	searchType.myOperator := self.aMyOperator;
	searchType.myCargoType := cargoType;
	searchType.myProduct := product;
	
	termArea.availableLocationsForType(searchType, rowSet);
	
	if not rowSet.isEmpty then
		self.cmbLC.listCollection(rowSet, false, 0);
			
		if origRow &lt;&gt; null and rowSet.includes(origRow) then
			self.cmbLC.listObject := origRow;
			self.tblItem.setValueByName(ETRow_Row, origRow.getID);
		else
			row := rowSet.first.CM_LocationsController;
			self.cmbLC.listObject := row;
			self.tblItem.setValueByName(ETRow_Row, row.getID);
		endif;
	else
		self.tblItem.setValueByName(ETRow_Row, null);
	endif;
	

epilog
	delete searchType;	
	delete rowSet;
end;</source>
    </JadeMethod>
