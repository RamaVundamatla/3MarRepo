/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 March 2011	cnwer1	Initial creation

*/

vars

begin

	self.doUserNotify(eventType,theObject,eventTag,userInfo);
epilog

end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
