<PrimType name="String">
    <JadeMethod name="getReverseToken" id="a3fc40d1-c790-49bb-a57f-5bf915ec78aa">
        <updating/>
        <source>getReverseToken(pos: Integer io) : String updating;

vars
	length : Integer;
	found  : Boolean;
	token  : String;
begin
	length := self.length;
	if pos &lt;= 0 then
		return '';
	endif;

	if pos &gt; length then
		pos := length;
	endif;

	while pos &gt; 0 do

		if self [ pos : 1 ] &lt;&gt; ' ' and self [ pos : 1 ] &lt;&gt; Tab then
			found := true;
			token := token &amp; self [ pos : 1 ];
		else
			if found then
				break;
			endif;
		endif;
		pos := pos - 1;

	endwhile;

	return token;

end;</source>
        <Parameter name="pos" type="Integer" usage="io"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getToken" id="bbb54cf4-83c8-4595-94a9-f2fe9c87c32b">
        <updating/>
        <source>getToken(pos: Integer io) : String updating;

vars

	length : Integer;
	found  : Boolean;
	token  : String;
begin
	length := self.length;
	if pos &gt;= length then
		return '';
	endif;

	while pos &lt;= length do
		if self [ pos : 1 ] &lt;&gt; ' ' and self [ pos : 1 ] &lt;&gt; Tab then
			found := true;
			token := token &amp; self [ pos : 1 ];
		else
			if found then
				break;
			endif;
		endif;
		pos := pos + 1;

	endwhile;

	return token;

end;</source>
        <Parameter name="pos" type="Integer" usage="io"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTokenX" id="4241d587-74d0-4c2f-a131-4b591eab4787">
        <updating/>
        <source>getTokenX(_pos: Integer io) : String updating;
constants
	Delimiter : String = ' ' &amp; Tab;
vars
	pos    : Integer;
	token  : String;
begin

	pos := _pos;
	if pos &gt;= self.length then
		return '';
	endif;

	token := self.scanUntil(Delimiter, pos);
	_pos := _pos + token.length + 1; 
	return token;

end;</source>
        <Parameter name="_pos" type="Integer" usage="io"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="padLeading" id="a06665f4-d864-4916-bffc-4fb4a69128df">
        <updating/>
        <source>padLeading(_length : Integer) : String updating;

vars
	st    : String;
	index : Integer;
	size  : Integer;

begin
	size := self.length;
	if _length &lt;= size then
		return self;
	endif;
	st := '                    '[1 : (_length - size)];
	st := st &amp; self;
	return st;
end;</source>
        <Parameter name="_length" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
</PrimType>
