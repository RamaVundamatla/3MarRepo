    <JadeMethod name="isOpsViewData" id="b8754a53-1409-4752-af55-a96689574f42">
        <source>isOpsViewData(): Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 Dec 2021	navab1	Initial creation
06 Mar 2025 navma1  MTN-34179 MTN | Dead Lock (1081) on CM_WLEArray
*/

vars
	awle : CM_WorkListEntry;
	wleTI : CM_TrackedItem;

begin


	if self.workListEntries.isEmpty then
		return false;	
	endif;

	foreach awle in self.workListEntries discreteLock do 
	
		wleTI := awle.myTrackedItem;

		if wleTI &lt;&gt; null 
		and (wleTI.isOpsViewData()) then // ### TFS 51853 02DEC2021 NAVAB1
			return true;
		endif;
	endforeach;
	
	return false;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
