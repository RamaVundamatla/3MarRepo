    <JadeMethod name="setYardLocations" id="719049e6-f038-4dba-86a6-19a463e41477">
        <source>setYardLocations(tmpTA: CM_TerminalArea);
/*
Purpose:			
Date		Who		Reason
19 September 2013	cnwab1	Initial creation
*/

vars
	col : Collection;
begin
	// PAR 32308
	if tmpTA.isKindOf(CM_IrregularBlockArea) then

		self.allLCsSet.clear();  
		tmpTA.CM_IrregularBlockArea.getValidLCsCollectionForMove(self.allLCsSet); // This gets all the shelves
		col := tmpTA.getLCsCollectionForDisplay(); // This gets all the racks. The getTIs on a rack gets all the cargo in all the shelves on the rack
		
		col.copyNoDups(self.allLCsSet);
		self.myAssistant.comboBoxLocationControllers(self.cmbFiltYardLocn, self.allLCsSet, false);
		
		
	else
		inheritMethod(tmpTA);
	endif;
	

epilog

end;</source>
        <Parameter name="tmpTA" type="CM_TerminalArea"/>
    </JadeMethod>
    <JadeMethod name="setupContextMenuItems" id="4521e62b-2a47-44d7-8bf6-0a0e268be3ff">
        <updating/>
        <source>setupContextMenuItems(conwin: Window input) updating;
// ---------------------------------------------------------------------------
// Created:     23 July 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	taType 	: Integer;
	ourLocation : CM_LocationsController;
	lTI 	: CM_TrackedItem;
	tmpMenu	: MenuItem;
	user	: CM_User;
	//wagon : CM_Wagon;
begin
	user := app.getMyUser;
	if self.myStartupObject &lt;&gt; null and CM_BoxcarWagonController.hasInstance( self.myStartupObject) then	//08 Apr 2013	NDL	Par 31278
		self.mnuColourLegend.visible := false;
	else
		self.zCloneMenu(self.mnuTblVCloneDataTbl, self.mnuColourLegend, false);	// ccms 1573 - adding colour legend
	endif;
	
	inheritMethod(conwin);


	self.mnuGridPlanLoad.visible := false;
	self.mnuGridPlanDischarge.visible := false;
	self.mnuReceiveCargo.visible := false;
	self.mnuReleaseCargo.visible := false;
	self.mnuInterTerminalRel.visible := false;
	self.mnuCargoPack.visible := false;
	self.mnuDeleteSelected.visible := false;					
	self.mnuOverlapping.visible := false;
	self.mnuFIFODate.visible := false;	
	self.mnuAreaFull.visible := false;	
	self.mnuShowAlphabetised.visible := false;
	self.mnuTblVDockSearch.visible := false;
	self.mnuConfig.visible := false;	// CCMS 1776
	self.mnuCreateInBoxcar.visible := false;
	
	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.mnuShowAlphabetised.visible := true;
		self.mnuTransactions.visible := true;
		self.mnuShowAlphabetised.visible := true;
		self.mnuAuditEnquiry.visible := true;
		self.mnuTALocnAudit.visible := true;
		self.mnuRestrictions.visible := true;
		if user &lt;&gt; null and user.canDo(self.myTerminal, PmAdmAuditTALocationView) then
			self.zCloneMenu (self.mnuTblVCloneDataTbl, self.mnuTALocnAudit, false);
		endif;
		self.zCloneMenu(self.mnuTblVCloneDataTbl, self.mnuRestrictions, false);		
		return;
	endif;

									
	if self.filterTerminalArea &lt;&gt; null then
		if self.filterTerminalArea.isKindOf(CM_BlockStack) then
			self.mnuOverlapping.visible := true;
			self.mnuOverlapping.checked := self.filterTerminalArea.CM_BlockStack.isOverlapped;
			
			self.mnuAreaFull.visible := true;
			self.mnuAreaFull.checked := self.filterTerminalArea.testIsFull();
			
			self.mnuFIFODate.visible := true;									
			ourLocation := self.filterTerminalArea.getLocationsController();
		else
			ourLocation := self.filterYardLocation;
		endif;
		taType := self.filterTerminalArea.type;
	endif;
	
	//epr TFS 47132 17/12/19
	if self.myCurrentObject &lt;&gt; null and self.myCurrentObject.isKindOf(CM_TrackedItem) then	
		lTI := self.myCurrentObject.CM_TrackedItem;
	endif;
					
	if conwin = tblData then
		if taType = TA_TYPE_RECTRANS then
			self.mnuReceiveCargo.visible := true;
		elseif taType = TA_TYPE_DELETE then
		//	self.mnuDeleteSelected.visible
			self.mnuDeleteSelected.visible := true and app.getMyUser.canDo( self.myTerminal, PmAdmCargoDelete );	//04 Nov 2013	NDL	Par 32837			
		elseif taType = TA_TYPE_RELTRANS then
			self.mnuReleaseCargo.visible := true;
		elseif taType = TA_TYPE_DEPOT_LCL and lTI.isKindOf(CM_Container) then
			self.mnuCargoPack.visible := true;
			self.mnuCargoPack.caption := lTI.id &amp; " Pack/Unpack";
		elseif taType = TA_TYPE_INTERTERM_TRANS_AREA and app.myRoot.isInterTerminalTransferEnabled() then
			self.mnuInterTerminalRel.visible := true;
		endif;
		
		if ourLocation &lt;&gt; null and app.myMoveController &lt;&gt; null then
			self.doContextForShipPlanning(ourLocation);
		endif;
	endif;
	
	self.doContextForBoxcar();	//08 Apr 2013
	
	//if app.myCurrentVoyage &lt;&gt; null then
	//cnwjo3 par 23105
	if app.getMyCurrentVoyage &lt;&gt; null then
		self.mnuGridTBA.visible := true;
		tmpMenu := self.zCloneMenu(self.mnuTblVCloneDataTbl, self.mnuGridTBA, false);		
	else
		self.mnuGridTBA.visible := false;
	endif;

	// 08/03/2011 cnwcs5 - new menu button - View Terminal Area Audit Details
	if user &lt;&gt; null and user.canDo(self.myTerminal, PmAdmAuditTALocationView) then
		self.zCloneMenu (self.mnuTblVCloneDataTbl, self.mnuTALocnAudit, false);
	endif;



	self.doMnuYardAllocBuild(self.zCloneMenu(self.mnuTblVCloneDataTbl, self.mnuYardAllocations, false));
	//self.doMnuYardAllocBuild(self.mnuYardAllocations);
	self.zCloneMenu(self.mnuTblVCloneDataTbl, self.mnuCreateInBoxcar, false);
	self.zCloneMenu(self.mnuTblVCloneDataTbl, self.mnuRestrictions, false);		
	
	self.zCloneMenu(self.mnuTblVCloneDataTbl, self.mnuGridPlanLoad, false);
	self.zCloneMenu(self.mnuTblVCloneDataTbl, self.mnuGridPlanDischarge, false);
	self.zCloneMenu(self.mnuTblVCloneDataTbl, self.mnuInterTerminalRel, false);
	self.zCloneMenu(self.mnuTblVCloneDataTbl, self.mnuReceiveCargo, false);
	self.zCloneMenu(self.mnuTblVCloneDataTbl, self.mnuReleaseCargo, false);
	self.zCloneMenu(self.mnuTblVCloneDataTbl, self.mnuCargoPack, false);
	self.zCloneMenu(self.mnuTblVCloneDataTbl, self.mnuDeleteSelected, false);	
	self.zCloneMenu(self.mnuTblVCloneDataTbl, self.mnuOverlapping, false);
	self.zCloneMenu(self.mnuTblVCloneDataTbl, self.mnuAreaFull, false);	
	self.zCloneMenu(self.mnuTblVCloneDataTbl, self.mnuFIFODate, false);	

	self.mnuDEVQuickCargo.visible := (app.isSpecial and (self.filterTerminalArea.isKindOf(CM_BlockStack) or self.filterTerminalArea.isKindOf(CM_IrregularBlockArea)));
	self.zCloneMenu(self.mnuTblVCloneDataTbl, self.mnuDEVQuickCargo, false);	

	

end;</source>
        <Parameter name="conwin" type="Window" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="e97390c0-7c02-4265-abe3-adbdf20df4eb">
        <updating/>
        <source>setupForm() updating;
// ---------------------------------------------------------------------------
// Created:		May 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars

begin
	inheritMethod();
	self.mnuConfig.visible := false;
	self.frmToolbarCombos.visible:=false; //epr TFS 47132 17/12/19
	//epr TFS 47132 30/12/19
	if not self.useSelectorTable then
		if self.myStartupObject &lt;&gt; null then
		
	
			if self.myStartupObject.isKindOf(CM_Voyage) then
				self.filterVoyage := self.myStartupObject.CM_Voyage;
				//self.zDoSearch();
			elseif self.myStartupObject.isKindOf(CM_TerminalArea) then
				self.setFilterTerminalArea(self.myStartupObject.CM_TerminalArea);
				// set terminal area TYPE
				//epr TFS 2701 21/9/16
				self.cmbFiltTAType.setIndexFromObject(self.filterTerminalArea.myType);
			//	self.cmbFiltTAType.listObject := self.filterTerminalArea.myType;
	
				// set the terminal AREA
				self.myCurrentObject := self.myStartupObject;
				self.doBuildComboTermArea();
				//self.zDoSearch();
			elseif self.myStartupObject.isKindOf(CM_BoxcarWagonController) then	//04 Apr 2013	NDL	Par 31278
				if self.cmbFiltTermArea.listIndex &gt; 0 then
					self.tblSearch.setValueByControlName(self.cmbFiltTermArea.name, self.cmbFiltTermArea.text);
				endif;
				if self.cmbFiltYardLocn.listIndex &gt; 0 then
					self.tblSearch.setValueByControlName(self.cmbFiltYardLocn.name, self.cmbFiltYardLocn.text);
				endif;
				self.cmbFiltTiType.listIndex := -1;
				self.tblSearch.setValueByControlName(self.cmbFiltTiType.name, null);
			
			endif;
			
		endif;
	endif;
		
	self.setFormHeading();
	btnPrintTV.visible		:=	false;
	btnExportCSVTV.visible	:=	false;
	
	//epr 11/3/14 removing voyage commodity planning as part of bulk CCMS 1366
	
	
	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.btnMoveIt.enabled:= false;
		
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="showColourLegend" id="90e4cdd2-a759-4510-91b9-3f83eacd13d3">
        <source>showColourLegend();
//----------------------------------------------------------------
//	Created:	23 August 2007	by cnwvu1
//----------------------------------------------------------------
vars
	colLegend	: CMUI_ColourLegend;
begin

	create colLegend;
	self.setNavigatorHeading(colLegend.caption); 
	colLegend.centreWindow;
	
	colLegend.addLegendItem( app.getErrorString(LabourOnBlockRestriction), Blue, LightRed, null, false );
	
	colLegend.showModal;

epilog
	delete colLegend;

end;
</source>
    </JadeMethod>
