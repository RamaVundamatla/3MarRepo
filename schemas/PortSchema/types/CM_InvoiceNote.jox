    <JadeMethod name="delete" id="2e9fde08-2cbf-44a4-a789-baa29ea0f491">
        <updating/>
        <source>delete() updating;
/*

Purpose:			Code to run when deleting an Invoice note

Parameters:			NONE

Return Value:		NONE

Date		Who		Reason
03 February 2022	navpw1	Initial creation TFS: 52752

*/

begin
