    <JadeMethod name="getFirstStagingLocation" id="e38adae0-31d2-4eff-92c6-24d5bb854e45">
        <source>getFirstStagingLocation(): CM_LocationsController;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 July 2021	jlier1	Initial creation TFS 51626 
23/06/2023	navkc1	CR 58406 Task 58408: Jade - Release Request All Tracked Items
*/

vars
	ti : CM_TrackedItem;
	allTis : CM_TISet; 
begin
	create allTis transient; //23/06/2023	navkc1	CR 58406 Task 58408
	self.getAllTrackedItems(allTis, false); //23/06/2023	navkc1	CR 58406 Task 58408
	//foreach ti in self.allTrackedItems discreteLock do
	foreach ti in allTis discreteLock do //23/06/2023	navkc1	CR 58406 Task 58408
		if  ti.isStagedFor( self.myReserveHeader ) then
			return ti.myPrimaryActualLocation;
		endif;
	endforeach;
	
	return null;
epilog
	delete allTis; //23/06/2023	navkc1	CR 58406 Task 58408
end;</source>
        <ReturnType type="CM_LocationsController"/>
    </JadeMethod>
    <JadeMethod name="getFirstTI" id="27256b3d-0627-41a7-930b-62aa5c67ff1a">
        <source>getFirstTI(_checkCargoGroup : Boolean) : CM_TrackedItem;
/*

Purpose:		This method returns the first tracked item of the TI collection (self.allTrackedItems and myCargoGroup.allAssignedTrackedItems)	

Parameters:			

Return Value:		

Date		Who		Reason
23/06/2023	navkc1	CR 58406 Task 58408: Jade - Release Request All Tracked Items
16 Apr 2025	navhl20	MTN-34595 	DPH - Release Staging – Improve Performance of getRoadReleaseSummary() API
*/

vars
	firstTi 	: CM_TrackedItem;
	cargoGroup	: CM_CargoGroup;
begin
	
	firstTi := self.allTrackedItems.first();
	
	if not _checkCargoGroup or firstTi &lt;&gt; null or self.isAllocationById()   then
		return firstTi;
	endif;
	
	cargoGroup := self.myCargoGroup;								//16.04.2025 navhl20 #34595
	if cargoGroup &lt;&gt; null then										//16.04.2025 navhl20 #34595
		firstTi := cargoGroup.allAssignedTrackedItems.first();		//16.04.2025 navhl20 #34595
	endif;
	
	return firstTi;
	
epilog

end;</source>
        <Parameter name="_checkCargoGroup" type="Boolean"/>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
