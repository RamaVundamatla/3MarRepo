    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="sysops"/>
    <PrimAttribute name="maxHeight" id="d9887ffe-844f-418c-807a-fab3f7e58221">
        <embedded/>
        <type name="Integer"/>
        <access>readonly</access>
    </PrimAttribute>
    <ImplicitInverseRef name="myPxyGridRow" id="fae41c07-1137-439f-9832-9bf846bf37b3">
