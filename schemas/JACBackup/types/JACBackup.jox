    <JadeMethod name="doDumpStack" id="f9f02ecd-6bb9-4f03-af20-8271d8eb8121">
        <source>doDumpStack(exObj: Exception);
// ---------------------------------------------------------------------------
// Created:     12 December 2000 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	stackDump: CnStackDump;
	
begin

	app.writeLog(class.name &amp; '::' &amp; method.name &amp; ' Dumping stack for ' &amp; exObj.String, LogAlways);

	create stackDump transient;
	stackDump.dumpStack(exObj);
	
epilog
	delete stackDump;
	
end;</source>
        <Parameter name="exObj" type="Exception"/>
    </JadeMethod>
    <JadeMethod name="exitLogFile" id="23dc9c5c-99e4-4bb4-ad68-efb89918d815">
