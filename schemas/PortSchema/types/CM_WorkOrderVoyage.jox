Return Value:		

Date		Who		Reason
27 September 2021	jlier1	Initial creation 51963

*/

vars
	woDtl : CM_WorkOrderDtl;
begin
	inheritMethod();
	if self.isTransient then
		return;
	endif;
	foreach woDtl in self.allWoDtls discreteLock do
		woDtl.actionForPendingApproval(self.myVoyage);
	endforeach;
epilog

end;</source>
