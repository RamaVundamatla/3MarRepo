    <JadeMethod name="copyToRealWSObject" id="8b1df92a-fae0-44ab-a710-1e8eb92d4c8c">
        <source>copyToRealWSObject(_realRequest: KRF_CheckInRequest input;
				   _createdObjects : ObjectSet input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 Feb 2019	jlgsl4	TFS 40360 - KiwiRail EDI message

*/

vars

begin
	inheritMethod(_realRequest, _createdObjects);
	
	create _realRequest.checkIn transient;
	_createdObjects.add(_realRequest.checkIn);
	self.checkIn.copyToRealWSObject(_realRequest.checkIn, _createdObjects);

	create _realRequest.metadata transient;
	_createdObjects.add(_realRequest.metadata);
	self.metadata.copyToRealWSObject(_realRequest.metadata, _createdObjects);

epilog

end;</source>
        <Parameter name="_realRequest" type="KRF_CheckInRequest" usage="input"/>
        <Parameter name="_createdObjects" type="ObjectSet" usage="input"/>
    </JadeMethod>
