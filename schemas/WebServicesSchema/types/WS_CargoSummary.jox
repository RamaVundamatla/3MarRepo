    <JadeMethod name="setHazDetails" id="69b52a5b-8761-4fc5-b425-4d36d1868c56">
        <updating/>
        <source>setHazDetails(_trackedItem: CM_TrackedItem) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 July 2021	jlier1	Initial creation TFS 51626

*/

vars

begin
	self.hazDetails:=_trackedItem.getAllHazardsAsString();
epilog

end;</source>
        <Parameter name="_trackedItem" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="setProxyFromObject" id="91a61900-d0ac-4ef5-a82f-fd34cc8970af">
        <updating/>
        <source>setProxyFromObject(_trackedItem: CM_TrackedItem) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 August 	2019	jlgns1	Initial creation
06 Aug 2019	JLGNS1	ChangeRequest 45293: JMT Handheld Apps - Release Staging Jade
26 Aug 2019	cnwma1	ChangeRequest 46185: PNL - Tasks, Grades and Marks via REST API
27 Jun 2022	jlika1	TFS 53971 - MTN - Rail Confirm App to React
17 Aug 2022	jlier1	TFS 54591 - MTN - Rail Confirm App - Differences on Selected cargo page
18 Sep 2023	jlika1	TFS 58150 EUP | FR 54539 - KeyMark: Total Quantity, Dimensions columns missing from Warehouse Multi Move
22 Mar 2024	navcs2	ChangeRequest 63087: CUX FR* | Tk62873 CARGO APIs POST/PUT/GET - Additional Fields requested - GoLCrit - 01
11 Apr 2024 navsaa30 Defect 63326: CUX - Fix 63087 Additional /Cargo fields
12 Dec 2024 navbk1   Bug 33662: MTN - Some Attributes are Missing From Multi Move Cargo Mobile App
09 May 2025	navhl20 Bug MTN-34743: MSL -- On confirming a cargo item in the location check app on requerying it still shows as not confirmed
03 Jun 2025	navhl20 CR MTN-35026: MTN - Optimize Performance of getCargoInLocation Web Service in Location Check Mobile App
*/

vars
	product : CM_Product;
begin
	inheritMethod(_trackedItem);

	self.cargoId 			:= _trackedItem.id;
	self.alternativeId		:= _trackedItem.alternativeId;				     //jlier1 TFS 53249 14/4/22
	self.amount  			:= _trackedItem.getTotalAmountDisplay;	
	self.bookingId			:= _trackedItem.bookingReference;				 // 12.12.2024 navbk1 #33662
	self.cargoTypeId 		:= _trackedItem.cargoType;
	self.currentLocation 	:= _trackedItem.getPrimaryLocationId(REAL_MODE);
	self.productDescription := _trackedItem.getProductDescription;
	self.cargoGroupId		:= _trackedItem.getMyCargoGroupId; 				 //TFS 51626 jler1 30//7/21
	self.mark				:= _trackedItem.mark;							 //jlier1 TFS 51683 12/8/21
	self.colour				:= _trackedItem.getColour(); 					 //jlier1 TFS 51683 12/8/21
	self.site				:= app.siteEnumToString(_trackedItem.site);      //26.08.2019 cnwma1 TFS #46185
	product 				:= _trackedItem.myProduct;
	
	if product &lt;&gt; null and product.getProdAttrFromName(ETRow_MyQuantity) &lt;&gt; null then 
		self.quantity		:=_trackedItem.quantity.asStringJMT;
	endif;
	self.totalWeight		:=_trackedItem.getDefaultMeasureTotalWeight(); //jlier1 TFS 54703 20/10/22
	self.commodityCode		:=_trackedItem.commodity;  						//jlier1	TFS  52366 11/11/21
	
	//jlier1 TFS 52385 16/11/21
	if app.myPassport.myTerminal.getConfig(HhIncludeHazDet).Boolean then
		self.setHazDetails(_trackedItem);
	endif;
	
	if _trackedItem.isContainer then
		self.isoLength		:= _trackedItem.getLengthInUnits().Integer * 10;
		self.isoTypeId		:= _trackedItem.CM_Container.isoType;
	else
		self.isoLength		:= 10;
	endif;
	
	self.dimensions			:= _trackedItem.getDimensionsDisplay(); 				//jlier1 TFS 55404 28/11/22
	self.markNumber			:= _trackedItem.markNumber; 							//jlier1 TFS 56807 17/1/22
	self.orderNumber 		:= _trackedItem.orderNumber;						// 22/03/2024 navcs2 ChangeRequest 63087
	self.cargoDescription   := _trackedItem.description;						// 12.12.2024 navbk1 #33662
	self.secondaryBarcodeId	:= _trackedItem.secondaryBarcodeId;					// 12.12.2024 navbk1 #33662
	self.grammage			:= _trackedItem.getGrammage().asStringJMT();		// 12.12.2024 navbk1 #33662
	self.grade 				:= _trackedItem.getGrade();							// 12.12.2024 navbk1 #33662
	self.diameter 			:= _trackedItem.getDiameter().asStringJMT();		// 12.12.2024 navbk1 #33662
	self.rollingLength 		:= _trackedItem.getRollingLength().asStringJMT();	// 12.12.2024 navbk1 #33662
	self.totalQuantity 		:= _trackedItem.totalQuantity;						// 12.12.2024 navbk1 #33662
epilog

end;</source>
        <Parameter name="_trackedItem" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="setPxyFromObjCargoLocation" id="615302ba-958f-44f2-92d2-300625a9e367">
        <updating/>
        <source>setPxyFromObjCargoLocation(_trackedItem: CM_TrackedItem) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 Jun 2025	navhl20 CR MTN-35026: MTN - Optimize Performance of getCargoInLocation Web Service in Location Check Mobile App

*/

vars

begin
	self.cmObjectEdition	:= _trackedItem.edition();
	self.cmObjectId			:= _trackedItem.getOidAsString();
	self.cargoId 			:= _trackedItem.id;
	self.alternativeId		:= _trackedItem.alternativeId;
	if _trackedItem.getLastTransOfClass(CM_LocationCheck) &lt;&gt; null then
		self.isConfirmed := true;
	endif;
epilog

end;</source>
        <Parameter name="_trackedItem" type="CM_TrackedItem"/>
    </JadeMethod>
</Class>
