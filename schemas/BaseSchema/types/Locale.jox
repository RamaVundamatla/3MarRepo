<Class name="Locale">
    <JadeMethod name="cnEcGetSchema" id="22f6e115-d1f8-4fba-aede-026bce5bad29">
        <source>cnEcGetSchema():Schema;
// --------------------------------------------------------------------------------
// Created:		23 April 2009 by cnwdad1
//
// Purpose:		Returns a reference to the receiver's Schema.
//
// Parameters:	None
//
// Returns:		A reference to the receiver's Schema.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return self.schema;
end;</source>
        <ReturnType type="Schema"/>
    </JadeMethod>
</Class>
