    <JadeMethod name="setDelayType" id="9162d37e-0ac0-4224-a1da-4680ba7ea9a4">
        <updating/>
        <source>setDelayType() updating, protected;
/*
Purpose:			
Parameters:			
Return Value:		

Date		Who		Reason
24 April 2011	cnwcs5	Initial creation - CCMS 1132/par 27316
*/
vars
	delay	:CM_Delay;
	type	:CM_DelayType;
begin
	delay := self.getDelay;
	
	if delay = null then
		self.delayType := self.Unknown_Value;
	else
		type := delay.myDelayType;
		
		if type = null then
			self.delayType := self.Unknown_Value;
		else
			self.delayType := type.description;
		endif;
	endif;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="updateFromEvent" id="c4103b0f-e6aa-4726-8a16-6a1caa74a64a">
        <updating/>
        <source>updateFromEvent(_event :CM_EventTransaction)updating;
// ---------------------------------------------------------------------------
// Created:     01 April 2011 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	type		:Integer;
	delay		:CM_Delay;
	machine		:CM_Machine;
	ts			:TimeStamp;
begin
	type := _event.type;
	
	if type = EVT_DelayStart then
		delay := _event.CMEVT_DelayStart.myDelay;
	elseif type = EVT_DelayEnd then
		delay := _event.CMEVT_DelayEnd.myDelay;
	else
		// coding error
		return;
	endif;
	
	machine 	:= delay.myMachine;
	
	if machine = null then
		app.raiseUnexpectedProgramError (self.class.name, method.name, "Machine cannot be null");
	endif;
	
	ts			:= _event.dateTime;
	
	if self.machine &lt;&gt; machine then
		self.machine := machine;
	endif;

	if self.dateTime &lt;&gt; ts then 
		self.dateTime := ts;
	endif;
	
	self.setDelayType;
epilog

end;</source>
        <Parameter name="_event" type="CM_EventTransaction"/>
    </JadeMethod>
</Class>
