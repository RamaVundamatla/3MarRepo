    <JadeMethod name="setPropertyFromStringValue" id="e68dc87f-c160-4343-9ddd-6ecba69d7306">
        <updating/>
        <source>setPropertyFromStringValue(_property : Property; _value : Any) updating, protected;
// ---------------------------------------------------------------------------
// Created:     07 August 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	propType	: Type;

begin

	if _property.isKindOf(Reference) then
		if _value = null then
			self.setPropertyValue(_property.name, null);
		elseif _value.isKindOf(Object) then
			self.setPropertyValue(_property.name, _value.Object);
		else
			self.setPropertyValue(_property.name, null);
		endif;
	else
		propType := _property.type;
	
		if propType = Boolean then
			self.setPropertyValue(_property.name, _value.Boolean);
		elseif propType = Integer then
			self.setPropertyValue(_property.name, _value.Integer);
		elseif propType = Decimal then
			self.setPropertyValue(_property.name, _value.Decimal);
		elseif propType = Real then
			self.setPropertyValue(_property.name, _value.Real);
		elseif propType = Date then
			self.setPropertyValue(_property.name, _value.Date);
		elseif propType = Time then
			self.setPropertyValue(_property.name, _value.Time);
		elseif propType = String then
			self.setPropertyValue(_property.name, _value);
		elseif propType = Binary then
			self.setPropertyValue(_property.name, _value.Binary);
		endif;			
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="_property" type="Property"/>
        <Parameter name="_value" type="Any"/>
    </JadeMethod>
