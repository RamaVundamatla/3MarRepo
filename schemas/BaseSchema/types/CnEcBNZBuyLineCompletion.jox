    <DbClassMap file="basemsg"/>
    <ExplicitInverseRef name="myAuthorisation" id="91c5fee3-6c68-45af-a7cf-a8e1338594b0">
        <embedded/>
        <type name="CnEcBNZBuyLineAuthorisation"/>
        <access>readonly</access>
        <Inverse name="CnEcBNZBuyLineAuthorisation::myCompletion"/>
    </ExplicitInverseRef>
    <JadeMethod name="buildMessage" id="0f9c5799-8906-4826-b0bc-cbbe6a2b62ce">
        <source>buildMessage(pMessage: String io): String;

vars
	errorMessage	: String;
	
begin
	errorMessage := self.checkData();
	
	if errorMessage &lt;&gt; "" then
		return errorMessage;
	endif;
	
	pMessage := self.messType &amp; self.MESSAGE_DELIMITER;
	pMessage := pMessage &amp; self.oPSId.String &amp; self.MESSAGE_DELIMITER;
	pMessage := pMessage &amp; self.seqNum.String &amp; self.MESSAGE_DELIMITER;
	pMessage := pMessage &amp; "" &amp; self.MESSAGE_DELIMITER;
	pMessage := pMessage &amp; self.amount.String &amp; self.MESSAGE_DELIMITER;
	pMessage := pMessage &amp; self.cardNum.String &amp; self.MESSAGE_DELIMITER;
	pMessage := pMessage &amp; "" &amp; self.MESSAGE_DELIMITER;
	pMessage := pMessage &amp; self.currency.String;
	
	return null;
end;</source>
        <Parameter name="pMessage" type="String" usage="io"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="checkData" id="100b0986-792a-4a7d-b145-e9b86f769712">
        <source>checkData(): String;

vars
	errorMessage : String;
	
begin
	errorMessage := errorMessage &amp; self.checkOPSId();
	errorMessage := errorMessage &amp; self.checkSeqNum();
	errorMessage := errorMessage &amp; self.checkAmount();
	errorMessage := errorMessage &amp; self.checkCardNum();
	errorMessage := errorMessage &amp; self.checkCurrency();
	
	if self.myAuthorisation = null then
		errorMessage := errorMessage &amp; "No 'Authorisation' associated with this Completion.  ";
	endif;
epilog
	return errorMessage;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="create" id="b5985967-9ab2-4eb4-a61a-69c8e28d0eca">
        <updating/>
        <source>create() updating;

begin
	self.messType := "C";
	
	self.setCurrency("");
	
	self.setOPSId();
	//self.setSequenceNumber();
	self.setMyMgr();
end;</source>
    </JadeMethod>
    <JadeMethod name="getTrxString" id="cafbdaf9-8d0c-4ad5-9818-3e683cb599fb">
        <source>getTrxString(): String;

begin
	return "Completion";
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setSequenceNumber" id="0213bcca-bea8-4334-86d6-1a5007c43f65">
        <updating/>
        <source>setSequenceNumber() updating;

begin
	if self.myAuthorisation &lt;&gt; null then
		self.seqNum := self.myAuthorisation.getSeqNum();
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="updateMe" id="7d4c3b3a-c269-48a7-9d0a-7d615176c08a">
        <updating/>
        <source>updateMe(	pAmount : Integer;
			pCardNum : String;
			pMyAuthorisation : CnEcBNZBuyLineAuthorisation) updating;

begin
	if self.amount &lt;&gt; pAmount then
		self.amount := pAmount;
	endif;
	
	if self.cardNum &lt;&gt; pCardNum then
		self.cardNum := pCardNum;
	endif;
	
	if self.myAuthorisation &lt;&gt; pMyAuthorisation then
		self.myAuthorisation := pMyAuthorisation;
		self.setSequenceNumber(); 
	endif;		
end;</source>
        <Parameter name="pAmount" type="Integer"/>
        <Parameter name="pCardNum" type="String"/>
        <Parameter name="pMyAuthorisation" type="CnEcBNZBuyLineAuthorisation"/>
    </JadeMethod>
</Class>
