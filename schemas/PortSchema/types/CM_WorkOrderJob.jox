    <JadeMethod name="getSpecialStow" id="e02840ae-99de-4111-88c9-bc6b05826432">
        <source>getSpecialStow():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 Oct 2023 navhl20 ChangeRequest 60090: EUP | Ship Operations in DD - [54176.020] -[Receive] Allocate Jobs to Gangs and Gangs to Holds
25 Mar 2024 navhl20 ChangeRequest 62300: EUP | 53729 - Delivery Dispatch Screen - outstanding issues - 2
10 Apr 2024 navhl20 ChangeRequest 63251: FR | 53729 - Delivery Dispatch screen - Further issues and Remedial work - 1
20 May 2024 navhl20 Bug 64191: EUP - Lock and Freeze issue
06 Mar 2025 navma1  MTN-34179 MTN | Dead Lock (1081) on CM_WLEArray
*/

vars
	ti				: CM_TrackedItem;
	str				: String;
	invalidObject	: Boolean;
	req				: CM_Request;
	resDtl			: CM_ReserveDetail;
	objset			: CM_ObjectSet;
	isShipGrp		: Boolean;
begin
	on Exception do app.handleDeletedObject(exception, ti, invalidObject);
	
	create objset transient;
	if self.allTrackedItems.isNotEmpty() then
		isShipGrp := self.isInGrpCriteria(WOJG_SpecialStowInt);	//20.05.2024 navhl20 #64191
		
		if isShipGrp then
			ti := self.allTrackedItems.first;
			return ti.specialStow;
		else
			foreach ti in self.allTrackedItems discreteLock  do		//06.03.2025 navma1 #MTN-34179
				invalidObject := false;
				ti.edition;
				
				if invalidObject then
					continue;
				endif;
				objset.tryAddIfNotNull(ti.getSpecialStow());
			endforeach;
		
			if objset.isNotEmpty then
				return objset.listString(Comma,CM_SpecialStow::code.name);
			endif;
		endif;
	else
		//25.03.2024 navhl20 #62300
		req := self.allRequests.first;
		resDtl := req.myReserveDetail;
		if resDtl &lt;&gt; null and resDtl.isKindOf(CM_ReserveSelection) then
			str := resDtl.CM_ReserveSelection.getMatchingCriteriaAsString(Comma,YACriteriaType_SpecialStow);
		endif;
	endif;
	return str;
epilog
	delete objset;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTonnage" id="951440e4-9003-4522-8613-3f256586422f">
        <source>getTonnage(): Decimal;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 Nov 2023 navhl20 ChangeRequest 61514: EUP | Ship Operations in DD - [54176.040] - [Release] Allocation List
10 Apr 2024 navhl20 ChangeRequest 63251: FR | 53729 - Delivery Dispatch screen - Further issues and Remedial work - 1
06 Mar 2025 navma1  MTN-34179 MTN | Dead Lock (1081) on CM_WLEArray
*/

vars
	ti				: CM_TrackedItem;
	weight			: Decimal[14,4];
	wod				: CM_WorkOrderTIDtl;
	transport		: Integer;
	measure			: CM_MeasurementType;
	unit			: String;
	invalidObject	: Boolean;
	edition			: Integer;
begin
	on Exception do app.handleDeletedObject(exception, ti, invalidObject);
	
	if self.allTrackedItems.isNotEmpty() then
		foreach ti in self.allTrackedItems discreteLock do
			
			invalidObject := false;
			edition := ti.edition;
			
			if invalidObject then
				continue;
			endif;
			weight := weight + ti.totalWeight;
		endforeach;
		return weight;
	endif;
	
	return null;
epilog

end;</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="getTotalQuantity" id="214e43dd-09e7-4f93-90a4-6420656680e4">
        <source>getTotalQuantity(): Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 Nov 2023 navhl20 ChangeRequest 61514: EUP | Ship Operations in DD - [54176.040] - [Release] Allocation List 
18 Jan 2024 navhl20 ChangeRequest 62066: EUP | Ship Operations in DD - FR - 01
10 Apr 2024 navhl20 ChangeRequest 63251: FR | 53729 - Delivery Dispatch screen - Further issues and Remedial work - 1
21 Aug 2024 navhl20	Bug 65424: EUP | 53729 - WO Jobs - Split Pack or Unpack job issues
06 Mar 2025 navma1  MTN-34179 MTN | Dead Lock (1081) on CM_WLEArray
*/

vars
	ti				: CM_TrackedItem;
	quant			: Integer;
	invalidObject	: Boolean;
	edition,
	transport		: Integer;
	req				: CM_Request;
begin
	on Exception do app.handleDeletedObject(exception, ti, invalidObject);
	
	if self.allTrackedItems.isNotEmpty() then						//18.01.2024 navhl20 #62066
		foreach ti in self.allTrackedItems  discreteLock do			//06.03.2025 navma1 #MTN-34179
			
			invalidObject := false;
			edition       := ti.edition;
			
			if invalidObject then
				continue;
			endif;
			
			quant := quant + ti.totalQuantity;
		endforeach;
		return quant;
	else															//18.01.2024 navhl20 #62066
		return inheritMethod();
	endif;
	return null;
epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getTotalReq" id="b9bc7239-cea8-4b56-898a-96c624e6e1cd">
        <source>getTotalReq(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 May 2023	navhl20	ChangeRequest 57714:[57764] EUP - Delivery Dispatch – Gate
11 Sep 2024 navma1  Bug 65777: EUP | 53729 - Delivery Dispatch Screen - wrong WO info when multiple in one Job

*/

vars
	wod : CM_WorkOrderTIDtl;
	wo	: CM_WorkOrder;
begin
	
	wod := self.myWODtl;
	
	if wod &lt;&gt; null then
		wo := wod.getMyParent();
		
		if wo &lt;&gt; null and wo.isWorkOrderTi then
			if wo.CM_WorkOrderTI.totalRequired &gt; 0 then
				return wo.CM_WorkOrderTI.totalRequired.asStringJMT;
			endif;
		endif;
	endif;
	
	return null;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTrainNumber" id="c0ee4de4-74c5-464f-b6f2-e009ca6eecc6">
