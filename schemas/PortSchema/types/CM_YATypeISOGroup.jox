    </JadeMethod>
    <JadeMethod name="getObjects" id="b5cf3b28-c1c6-4079-8ff9-0e793ad70d4f">
        <source>getObjects(objects: ObjectLongNameDict input);
//05 August 2008	cnwdw1	
// Return a dict of objects for this criteria type
vars
	isoGroup: CM_ISOTypeGroup;
begin
	foreach isoGroup in app.myRoot.allISOTypeGroups do
		objects[isoGroup.getYAIdentifier] := isoGroup;
	endforeach;
end;</source>
        <Parameter name="objects" type="ObjectLongNameDict" usage="input"/>
    </JadeMethod>
