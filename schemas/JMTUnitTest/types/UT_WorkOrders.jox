    <JadeMethod name="tWODJobGroup" id="cbb28a2e-fdf5-4745-9766-6231bedf54ca">
        <source>tWODJobGroup();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 Oct 2023	navhl20	ChangeRequest 59638: EUP | Ship Operations in DD - [54176.010] - [Receive] Work Order Detail Grouping
06 May 2024 navhl20 ChangeRequest 63971: FR | 54176 - Ship operations in Delivery Dispatch screen
*/

constants
	REF: String  =  "59638";
vars
	voyage 	  			: CM_Voyage;
	vessel				: CM_Vessel;
	grpMethod 			: CM_WorkOrderJobGroupMethod;
	term,termWO	  		: CM_Terminal;
	dyna	  			: DynaDictionary;
	woSet				: CM_WorkOrderDtlSet;
	useYardJobsSetting,
	canAutoActionTiWo	: Any;
	pxyWod,
	wod					: CM_WorkOrderDtl;
	pxyWorkOrder,
	workOrder			: CM_WorkOrder;
	wodArr				: CM_WorkOrderDtlArray;
	tiSet				: CM_TISet;
	ti					: CM_TrackedItem;
	count				: Integer;
	cargoType 			: CM_CargoType;
	woActionIF 			: CMIF_WorkOrderAction;
	realJob				: CM_Job;
begin
	term 	  := self.getTerminal();
	
	// Set the config to use yard jobs for the terminal and allow AutoActioning
	useYardJobsSetting := term.getConfig(UseYardJobsCargoWO);
	canAutoActionTiWo := term.getConfig(AllowAutoActionCargoWo);
	
	beginTransaction;
	term.setConfig(UseYardJobsCargoWO, true);
	term.setConfig(AllowAutoActionCargoWo, false);
	commitTransaction;
	
	// Delete the old work order and create containers to add
	self.deleteWorkOrderNoValidation("UTHLRELRAIL" &amp; REF);
	
	termWO 	  := app.myRoot.allTerminals['WO'];
	voyage    := termWO.allVoyagesByCode['DUB-B-002',"17 November 2023, 21:27:00.000".TimeStamp];
	
	create dyna transient;
	create woSet transient;
	
	grpMethod := termWO.allWOJobGroupMethods['DUB-A',termWO];
	
	grpMethod.actionWOGrouping(voyage,woSet,dyna,null);				//06.05.2024 navhl20 #63971
	
	create tiSet transient;
	dyna.copy(tiSet);
	
	self.opts.purge();
	self.opts.addAssoc('TotalReq', 2);
	self.opts.addAssoc('RequiredByDT', app.actualTimeServer().addDays(2).String);
	self.opts.addAssoc('transportMode',TI_TRANSMODE_RAIL);
	self.opts.addAssoc('VoyageObj',voyage);
	
	// Create the work order
	create pxyWod as CM_WodReceive transient;
	self.xCreateWorkOrderDetail(pxyWod,WO_TASK_RECEIVE,null,tiSet,null);
	
	create wodArr transient;
	wodArr.add(pxyWod);
	
	create pxyWorkOrder as CM_WorkOrderTI transient;
	self.xCreateWorkOrder(pxyWorkOrder,workOrder,"UTHLRELRAIL" &amp; REF,WO_STATUS_USERENTRY,wodArr);
	
	wod := workOrder.allWoDtls.first;
	
	self.xApproveWorkOrder(workOrder);
	create woActionIF transient;
	woActionIF.myWorkOrderDtl 		 := wod;
	woActionIF.numberFromKnownCargo  := wod.CM_WorkOrderTIDtl.allSelectedTIs.size;
	woActionIF.useYardJobs			 := term.isUseYardJobsForCargoWo();
	app.myTrxUA.trxWorkOrderAction(woActionIF,realJob,grpMethod, app.myPassport);
	self.assertEqualMsg(workOrder.allWoDtls.size,3,"Should have two Workorder Details");
epilog
	beginTransaction;
	self.getTerminal.setConfig(UseYardJobsCargoWO, useYardJobsSetting);
	self.getTerminal.setConfig(AllowAutoActionCargoWo, canAutoActionTiWo);
	commitTransaction;
	delete dyna;
	delete woSet;
	pxyWorkOrder.allWoDtls.purge;
	delete pxyWorkOrder;
	delete wodArr;
	delete tiSet;
	delete woActionIF;
end;</source>
    </JadeMethod>
    <JadeMethod name="tWOEstimateNoCashModule" id="5ec68b20-d3cc-4009-a1f5-889807bdf16f">
        <source>tWOEstimateNoCashModule();
/*
Purpose: TFS 52237  Work Orders. Work Order estimates do not requrie cash module.

Date		Who		Reason
22NOV2021	NAVAB1	TFS 52237
12 Jan 2023	navma1  ChangeRequest 56141: EUP - Refactor and Remove CM_WorkOrderTISource from CM_WorkOrderTI
08 Feb 2023 navma1  ChangeRequest 56457:[56458] EUP - [Refactor] - Allowing different sets of cargo items per work order task
18 Apr 2023 navhl20 ChangeRequest 57569:[57601] EUP - [Framework] Refactor Actioning Work Order Tasks
02 Jun 2023 navma1  ChangeRequest 58296: EUP - [Framework] Delivery Dispatch Screen - Linking Road Jobs
*/

constants

	WO_NUM 		= "WO-AB001";
	BS_ID1		= "UTBS1";
	BS_ID2 		= "UTBS2";
	CONT_ID1	= "WONU2111011";
	CONT_ID2 	= "WONU2111012";
	INV_TYPE 	= "UT_InvWOMove";
	INVLINETYPE = "UT_LineTypeWOMove";
	TRANMAP 	= 'UT_WOMove';
	SERVICE		= "UT_ServiceWOMove";
	CALCTYPE 	= 'CCT00';
	DEBTOR 		= "UT_DEBTOR_AB";
vars
	blockStack,
	washStack 		: CM_BlockStack;
	ti 				: CM_TrackedItem;
	operator 		: CM_Operator;
	debtor1			: CM_Debtor;
	services		: CM_ServiceByNameDict;
	service1,
	service2		: CM_Service;
	calcType		: CM_CalculationType;
	invType			: CM_InvoiceDesc;
	invLineType1	: CM_InvoiceLineDesc;
	bank 			: CM_Bank;
	cashonly 		: Boolean;
	tiSet			: CM_TISet;
	wodArr			: 	CM_WorkOrderDtlArray;
	pxyWod,
	wod				: 	CM_WorkOrderDtl;
	pxyWorkOrder,
	workOrder		: 	CM_WorkOrder;
begin

	cashonly := app.isCashOnlyEnabled;
	
	// ### TURN OFF CASH
	app.setPropertyValue("isCashOnlyEnabled",false);
	deleteWorkOrderNoValidation(WO_NUM);

	deleteTerminalArea(BS_ID1);
	blockStack := addBlockStack(BS_ID1, 10, null);
	deleteTerminalArea(BS_ID2);
	washStack := addBlockStack(BS_ID2, 10, null);
	
	self.deleteContainer(CONT_ID1);
	self.deleteContainer(CONT_ID2);
	

	self.deleteInvoiceTransactionMap(1, TRANMAP);
	self.deleteInvoiceType(INV_TYPE);
	self.deleteInvoiceService(SERVICE, FORCED_ERASE);
	self.deleteInvoiceLineType(INVLINETYPE, FORCED_ERASE);

	bank := self.getTerminal().getDefaultCompanyBank();
	
	create services transient;
	invType := self.createInvoiceType(INV_TYPE, InvoiceTypeGeneral);
	self.assertNotNullMsg(invType, "Invoice type " &amp; INV_TYPE &amp; " not created");

	calcType := app.myRoot.allCalculationTypesByCode[CALCTYPE];		// cargo weight kilos
	self.assertNotNullMsg(calcType, "Calculation type " &amp; CALCTYPE &amp; " not found");
	
	service1 := self.createInvoiceService(SERVICE,"Value of 1", calcType, null);
	self.assertNotNullMsg(service1, SERVICE &amp; " not created");
 	services.add(service1);
	
	// charges customs agent
	invLineType1 := self.createInvoiceLineType(INVLINETYPE, calcType, invType, services, "SDT1");
	self.assertNotNullMsg(invLineType1, INVLINETYPE &amp; " not created");
	
	// agent and debtor, set rates
	self.deleteDebtor(DEBTOR);

	debtor1 := self.addDebtor(DEBTOR, PaymentType_PostPay).CM_Debtor;
	self.assertNotNullMsg(debtor1,"Debtor Create Failed");
	
	operator := self.addOperator("UTAB", "Empty Pool Party Test Operator 1", false, 0, 0, debtor1, false, false, false, false, false, false, false, false, false, false, null, null, null, false, false, false, null, null, 0, null, false, false);
	self.assertNotNullMsg(operator,"Operator Create Failed");
	

	self.setServiceRate(service1, debtor1, "01/01/2021".Date, 0.10);
	service2 := bank.services["UT_ServiceX9"];
	self.setServiceRate(service2, debtor1, "01/01/2021".Date, 100.00);

	// Transaction map to charge receive as fixed charge and per-weight charge, and storage as per-weight
	self.xLoadTranMapWorkOrder();	
	
	create tiSet transient;
	ti := self.addContainerOpts(CONT_ID1, "2200", "APPL", operator);	
	move(ti, blockStack);
	tiSet.add(ti);					//12.01.2023 navma1 #56141 Task#56147
	
	ti := self.addContainerOpts(CONT_ID2, "2200", "APPL", operator);		
	move(ti, blockStack);
	tiSet.add(ti);					//12.01.2023 navma1 #56141 Task#56147

	self.opts.purge();
	self.opts.addAssoc('TotalReq', 2);
	self.opts.addAssoc('TargetTA', BS_ID2);
	self.opts.addAssoc('RequiredByDT', app.actualTimeServer().addDays(2).String);

	self.opts.addAssoc('TaskType',WO_TASK_MOVE );  // for task type to add.

	
	// lets add a basic user entry work order
	create pxyWod as CM_WodMove transient;
	
	self.xCreateWorkOrderDetail(pxyWod,WO_TASK_MOVE,null,tiSet,null);
	
	create wodArr transient;
	wodArr.add(pxyWod);
	
	create pxyWorkOrder as CM_WorkOrderTI transient;
	self.xCreateWorkOrder(pxyWorkOrder,workOrder,WO_NUM,WO_STATUS_USERENTRY,wodArr);
	
	wod := workOrder.allWoDtls.first;
	self.assertNotNull(workOrder);
	
	//test the work order main stuff
	self.assertEqual(workOrder.taskStatus ,  WO_STATUS_USERENTRY);
	//self.assertEqual(workOrder.totalRequired ,  2);									//06.03.2023 navma1 #56457:[56458]
	self.assertEqual(workOrder.id , WO_NUM );
	self.assertNotNull(workOrder.startAtDT);
	self.assertNotNull(workOrder.requiredByDT);
	self.assertNotNull(workOrder.enteredByDT);
	self.assertNotNull(workOrder.myOrganisation);

	//now test the source
	self.assertEqual(workOrder.allWoDtls.first.CM_WorkOrderTIDtl.allSelectedTIs.listString(Comma,CM_TrackedItem::id.name) ,
					 CONT_ID1 &amp; "," &amp; CONT_ID2);										//08.02.2023 navma1 #56457:[56458]
	
	// and the tasks
	self.assertEqual(workOrder.allWoDtls.size , 1);
	self.assertEqual(workOrder.allWoDtls.first.autoQueueTask , false);
	
	
	// #################################
	// #### THERE SHOULD BE AN ESTIMATE
	// #################################
	self.assertNotNullMsg(workOrder.myCashReceipt,"Work Order Estimate Not Created, cash receipt");

	
	
epilog
	app.setPropertyValue("isCashOnlyEnabled",cashonly);
	delete services;
	delete tiSet;
	self.resetDefaultTranMap();
	pxyWorkOrder.allWoDtls.purge;
	delete pxyWorkOrder;
	delete wodArr;
end;</source>
    </JadeMethod>
    <JadeMethod name="tWOReleaseShip" id="a981716e-03c5-406d-9315-83aa6dc1388b">
        <updating/>
        <source>tWOReleaseShip() updating;
/*

Purpose:			
A release Ship cargo work order attached with a booking and the booking item to the work order detail
and to ensure work order created correctly
Parameters:			

Return Value:		

Date		Who		Reason
21 Aug 2023	navrv30	Initial creation

*/

constants
	REF: String  =  "1234";
	//WOID : String  = 'UT'&amp;REF&amp;'JRE1';
	//REF		: String  = '58730';
	WOID 	: String  = 'UT'&amp;REF&amp;'SHP';
	VoyageName	: String  = 'UTWORECIEVESHIP';
	BookRef1			= "UT_BK_001";
vars
	tI1, tI2		:	CM_TrackedItem;
	useYardJobsSetting,
	canAutoActionTiWo	: 	Any;
	tiSet				:	CM_TISet;
	//releaseRequest		:	CM_BulkRelease;
	taSource			:	CM_TerminalArea;
	code				: 	String;
	relTime				:	TimeStamp;
	wodArr				: 	CM_WorkOrderDtlArray;
	pxyWod,
	wod					: 	CM_WorkOrderDtl;
	pxyWorkOrder,
	workOrder			: 	CM_WorkOrder;
	voyage 			: 	CM_Voyage;
	
	vessel 			:	CM_Vessel;
	term			:	CM_Terminal;
	dischargePort 	:	CM_Port;
	loadPort 		:	CM_Port;
	booking			:	CM_BookingRef;
begin
	/*
	** Setup Section, create the work order with a release cargo task with multiple tracked items
	*/
	
	
	// Set the config to use yard jobs for the terminal and allow AutoActioning
	useYardJobsSetting := self.getTerminal.getConfig(UseYardJobsCargoWO);
	canAutoActionTiWo := self.getTerminal.getConfig(AllowAutoActionCargoWo);
	
	beginTransaction;
	self.getTerminal.setConfig(UseYardJobsCargoWO, true);
	self.getTerminal.setConfig(AllowAutoActionCargoWo, false);
	commitTransaction;
	
	self.deleteBooking(BookRef1);
	self.deleteWorkOrderNoValidation(WOID);
	self.deleteVoyage(VoyageName);
	self.deleteTrackedItem(self.getTrackedItem("UTCONT1"), false);
	self.deleteTrackedItem(self.getTrackedItem("UTCONT2"), false);
	// terminal
	term := self.getTerminal();	
	
	// vessel and voyage
	vessel := self.addVesselWithHolds("UTLWVES"&amp;REF, 2, 2);
	voyage := self.addVoyageWithGeneralCargoStruc("UTLWVOY"&amp;REF, vessel.name, vessel.myOperator.code, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 0);
	self.assertNotNull(voyage);
	dischargePort := voyage.myTrade.allPortRotations.last.myPort;
	loadPort := voyage.myTrade.allPortRotations.first.myPort;
	
	self.opts.purge();
	self.opts.addAssoc('number', 10);
	booking := self.addBookingForContainer(BookRef1, self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString), voyage, "NZAKL", "2200", "MT");
	assertNotNull(booking);
	
	//Creating cargos for detail -1
	self.opts.purge();
	self.opts.addAssoc(UTTI_BookingRef, BookRef1);
	tI1 := self.addPrenotedContainer(booking.allBookingRefItems.first,"UTCONT1");
	tI2 := self.addPrenotedContainer(booking.allBookingRefItems.first,"UTCONT2");	
	
	create tiSet transient;
	tiSet.add(tI1);
	tiSet.add(tI2);
	// Create the Release
	self.opts.purge();
	self.opts.addAssoc("ISOGroup", "1001");
	self.opts.addAssoc("FullRelease", true);
	self.opts.addAssoc("CanBeHiLoCube", true);
	//self.opts.addAssoc("CreateDeliveryRequest", true);
	self.opts.addAssoc("TerminalArea",taSource );
	self.opts.addAssoc('Booking',booking.bookingReference );
	self.opts.addAssoc('TotalReq', 2);
	self.opts.addAssoc('TargetTA', "UTBS2" &amp; REF);
	self.opts.addAssoc('CargoList', "UTCONT1" &amp; "," &amp; "UTCONT2");
	self.opts.addAssoc('RequiredByDT', app.actualTimeServer().addDays(2).String);
	self.opts.addAssoc('TaskType',WO_TASK_RELEASE );
	self.opts.addAssoc('bulkReleaseCode', code);
	self.opts.addAssoc('bulkReleaseDT', relTime);
	self.opts.addAssoc('transObj', voyage.code);
	self.opts.addAssoc('dtArrived', voyage.arrivedDT);
	self.opts.addAssoc('transportMode',TI_TRANSMODE_SHIP);	
	
	// Create the work order
	create pxyWod as CM_WodRelease transient;
	
	self.xCreateWorkOrderDetail(pxyWod,WO_TASK_RELEASE,null,tiSet,null);
	create wodArr transient;
	wodArr.add(pxyWod);
	
	create pxyWorkOrder as CM_WorkOrderTI transient;
	self.xCreateWorkOrder(pxyWorkOrder,workOrder,WOID,WO_STATUS_USERENTRY,wodArr);
	
	wod := workOrder.allWoDtls.first;
	
	self.xCheckWorkOrder(wod,WO_STATUS_USERENTRY,2,TRANS_TYPE_WO_TIREL_CREATED,false,false);
	
	// Action and Approve the work order
	self.xApproveWorkOrder(workOrder);
	self.xActionWorkOrder(workOrder);
	self.xCheckWorkOrder(wod,WO_STATUS_APPROVED,2,TRANS_TYPE_WO_TIREL_UPDATED,true,false);
	
	// Check each job has a WLE
	/*foreach job in wod.CM_WorkOrderTIDtl.allJobs do
		self.assertTrue(job.getNumWLEs &gt; 0);
		self.assertNotNull(job.getWLEForTI(tI1));
		self.assertNotNull(job.getWLEForTI(tI2));
	endforeach;*/
	
epilog
	beginTransaction;
	self.getTerminal.setConfig(UseYardJobsCargoWO, useYardJobsSetting);
	self.getTerminal.setConfig(AllowAutoActionCargoWo, canAutoActionTiWo);
	commitTransaction;
	delete tiSet;
	pxyWorkOrder.allWoDtls.purge;
	delete pxyWorkOrder;
	delete wodArr;
end;

</source>
    </JadeMethod>
    <JadeMethod name="tWOYardJob" id="ca27c2d8-a2e5-426a-bd87-468da4f12760">
        <source>tWOYardJob();

/*

Purpose:			
A test to ensure that the new Work order job types can 

Parameters:			

Return Value:		

Date			Who		Reason
15/06/2022		navcs2	ChangeRequest 53038: MTN - Work Order Maintenance Refactor - PortSchema
12 Jan 2023		navma1  ChangeRequest 56141: EUP - Refactor and Remove CM_WorkOrderTISource from CM_WorkOrderTI
28 Mar 2023 	navhl20	ChangeRequest 56614:[56615] EUP - Allow Multi ToDo Tasks Description on Cargo ToDo Work Order
18 Apr 2023 	navhl20 ChangeRequest 57569:[57601] EUP - [Framework] Refactor Actioning Work Order Tasks
02 Jun 2023 navma1  ChangeRequest 58296: EUP - [Framework] Delivery Dispatch Screen - Linking Road Jobs
*/
constants
	REF = UT_DSL.TFS53038;
vars
	blockstack1, blockstack2	:	CM_BlockStack;
	tI1, tI2, tI3				:	CM_TrackedItem;
	tiSet						:	CM_TISet;
	useYardJobsSetting			:	Any;
	terminal					: 	CM_Terminal;
	toDoTaskDesc				: 	CM_ToDoTaskDesc;
	toDoTaskDescSet				:	CM_ToDoTaskDescSet;
	taskID						:	Integer;
	wodArr						: 	CM_WorkOrderDtlArray;
	pxyWod						: 	CM_WorkOrderDtl;
	pxyWorkOrder,
	workOrder					: 	CM_WorkOrder;
begin

	deleteWorkOrderNoValidation('UTWO'&amp;REF);
	
	self.deleteContainer("UTCNT1" &amp; REF);
	self.deleteContainer("UTCNT2" &amp; REF);
	self.deleteContainer("UTCNT3" &amp; REF);
	
	terminal := self.getTerminal();
	
	useYardJobsSetting := self.getTerminal.getConfig(UseYardJobsCargoWO);
	
	beginTransaction;
		self.getTerminal.setConfig(UseYardJobsCargoWO, true);
	commitTransaction;
	
	tI1 := self.addContainerOpts("UTCNT1" &amp; REF, "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));	
	tI2 := self.addContainerOpts("UTCNT2" &amp; REF, "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));		
	tI3 := self.addContainerOpts("UTCNT3" &amp; REF, "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));		
	
	create tiSet transient;
	tiSet.add(tI1);					//12.01.2023 navma1 #56141 Task#56147
	tiSet.add(tI2);					//12.01.2023 navma1 #56141 Task#56147
	tiSet.add(tI3);					//12.01.2023 navma1 #56141 Task#56147
	
	// ToDo Job
	toDoTaskDesc := self.xAddToDoTask("Todo",TODO_TYPE_GROUP_TI);  
	
	taskID := app.myRoot.allToDoTaskDescsByShortDesc.indexOf(toDoTaskDesc);
		
	self.opts.purge();
	self.opts.addAssoc('TaskType',WO_TASK_TODO );
	self.opts.addAssoc('toDoTaskID', taskID);
	self.opts.addAssoc('TotalReq', 3);
	self.opts.addAssoc('RequiredByDT', app.actualTimeServer().addDays(2).String);
	
	create toDoTaskDescSet transient;
	toDoTaskDescSet.add(toDoTaskDesc);
	create pxyWod as CM_WodToDo transient;
	
	self.xCreateWorkOrderDetail(pxyWod,WO_TASK_TODO,toDoTaskDescSet,tiSet,null);
	
	create wodArr transient;
	wodArr.add(pxyWod);
	
	create pxyWorkOrder as CM_WorkOrderTI transient;
	self.xCreateWorkOrder(pxyWorkOrder,workOrder,'UTWO'&amp;REF,WO_STATUS_USERENTRY,wodArr);
	
	xApproveWorkOrder(workOrder);
	xActionWorkOrder(workOrder);
	
	delete toDoTaskDescSet;
	delete pxyWod;
	delete wodArr;
	delete pxyWorkOrder;
	
	deleteWorkOrderNoValidation('UTWO'&amp;REF);
	
	// Move Job
	deleteTerminalArea("UTBS1" &amp; REF);
	blockstack1 := addBlockStack("UTBS1" &amp; REF, 10, null);
	deleteTerminalArea("UTBS2" &amp; REF);
	blockstack2 := addBlockStack("UTBS2" &amp; REF, 10, null);
	
	self.opts.purge();
	self.opts.addAssoc('TaskType',WO_TASK_MOVE );
	self.opts.addAssoc('TotalReq', 3);
	self.opts.addAssoc('targetTA', blockstack1.id);									//28.3.2023 navhl20	#56614[56615]
	self.opts.addAssoc('DtRequired', app.actualTimeServer().addDays(2).String);
	self.opts.addAssoc('DtStart', app.actualTimeServer().addDays(1).String);	
	
	create pxyWod as CM_WodMove transient;
	
	self.xCreateWorkOrderDetail(pxyWod,WO_TASK_MOVE,toDoTaskDescSet,tiSet,null);
	
	create wodArr transient;
	wodArr.add(pxyWod);
	
	create pxyWorkOrder as CM_WorkOrderTI transient;
	self.xCreateWorkOrder(pxyWorkOrder,workOrder,'UTWO'&amp;REF,WO_STATUS_USERENTRY,wodArr);
	
	xApproveWorkOrder(workOrder);
	xActionWorkOrder(workOrder);
	
	deleteWorkOrderNoValidation('UTWO'&amp;REF);
	
	// Pack Job
	
	/**
	deleteTerminalArea("UTBS1" &amp; REF);
	blockstack1 := addBlockStack("UTBS1" &amp; REF, 10, null);
	deleteTerminalArea("UTBS2" &amp; REF);
	blockstack2 := addBlockStack("UTBS2" &amp; REF, 10, null);
	
	self.opts.purge();
	self.opts.addAssoc('TaskType',WO_TASK_PACK );
	self.opts.addAssoc('TotalReq', 3);
	self.opts.addAssoc('CargoList', "UTCNT1" &amp; REF &amp; "," &amp; "UTCNT2" &amp; REF &amp; "," &amp; "UTCNT3" &amp; REF);
	
	self.opts.addAssoc('DtRequired', app.actualTimeServer().addDays(2).String);
	self.opts.addAssoc('DtStart', app.actualTimeServer().addDays(1).String);	
	
	workOrder := self.addWorkOrder('UTWO'&amp;REF, WO_STATUS_USERENTRY);
	
	xApproveWorkOrder(workOrder);
	xActionWorkOrder(workOrder);
	
	write terminal.allWorkOrderJobs.size();
	
	deleteWorkOrderNoValidation('UTWO'&amp;REF);
	*/
	
	assertTrue(terminal.allWorkOrderJobs.size &gt; 0);
	
epilog
	beginTransaction;
		self.getTerminal.setConfig(UseYardJobsCargoWO, useYardJobsSetting);
	commitTransaction;
	delete tiSet;
	pxyWorkOrder.allWoDtls.purge;
	delete pxyWorkOrder;
	delete wodArr;
end;</source>
    </JadeMethod>
    <JadeMethod name="uCargoJobReleaseRailByType" id="692d94d8-af40-452e-8b6c-e83e11604dde">
        <source>uCargoJobReleaseRailByType();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 Aug 2023	ChangeRequest 59218: EUP | Handle Work order for Release Rail by Type

*/
constants
	REF 			: String = UT_DSL.TFS59218.String;
	Train 			: String = 'UTTR'&amp;REF;
	Wagon	 		: String = "WA-"&amp;REF&amp;"_1";
	RailAreaId 		: String = "UTRA1";
	BlockStack 		: String = "UTBS2" &amp; REF;
	WagonClass		: String = "BX";
	WOID 			: String = 'UT'&amp;REF&amp;'JRR1';
	CargoId1		: String = "UTSTL1"&amp;REF;
	CargoId2		: String = "UTCNT2"&amp;REF;
	CargoId3		: String = "UTSTL3"&amp;REF;
	CargoId4		: String = "UTCNT4"&amp;REF;
vars
	term 					: CM_Terminal;
	useYardJobsSetting,
	canAutoActionTiWo		: Any;
begin

	term := self.getMyTerminal();
	// Set the config to use yard jobs for the terminal and allow AutoActioning
	useYardJobsSetting := term.getConfig(UseYardJobsCargoWO);
	canAutoActionTiWo  := term.getConfig(AllowAutoActionCargoWo);
	
	beginTransaction;
		term.setConfig(UseYardJobsCargoWO, true);
		term.setConfig(AllowAutoActionCargoWo, true);
	commitTransaction;
	
	self.deleteWorkOrderNoValidation(WOID);
	
	self.deleteContainer(CargoId1);
	self.deleteContainer(CargoId2);
	self.deleteContainer(CargoId3);
	self.deleteContainer(CargoId4);
	
epilog
	beginTransaction;
		term.setConfig(UseYardJobsCargoWO, useYardJobsSetting);
		term.setConfig(AllowAutoActionCargoWo, canAutoActionTiWo);
	commitTransaction;
end;</source>
    </JadeMethod>
    <JadeMethod name="uCargoNoJobMoveSingle" id="4428e3b5-5c79-4d40-8ca0-9be321ae8f9a">
        <source>uCargoNoJobMoveSingle();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 Jan 2023	navma1  	ChangeRequest 56141: EUP - Refactor and Remove CM_WorkOrderTISource from CM_WorkOrderTI
18 Apr 2023 navhl20 	ChangeRequest 57569:[57601] EUP - [Framework] Refactor Actioning Work Order Tasks
*/

constants
	REF = UT_DSL.TFS53038;
	WOID : String  = 'UT'&amp;REF&amp;'NJMV1';
vars
	blockstack1, 
	blockstack2,
	blockstack3					: CM_BlockStack;
	tI1, tI2					: CM_TrackedItem;
	pxyWorkOrder			    : CM_WorkOrder;
	tiSet						: CM_TISet;
	pxyWod						: CM_WorkOrderDtl;
	operator					: CM_Operator;
	realWorkOrder				: CM_WorkOrder;
	wodArr						: CM_WorkOrderDtlArray;
begin
	
	operator  := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	self.deleteWorkOrderNoValidation(WOID);
	
	deleteTerminalArea("UTBS1" &amp; REF);
	deleteTerminalArea("UTBS2" &amp; REF);
	deleteTerminalArea("UTBS3" &amp; REF);
	
	blockstack1 := addBlockStack("UTBS1" &amp; REF, 10, null);
	blockstack2 := addBlockStack("UTBS2" &amp; REF, 10, null);
	blockstack3 := addBlockStack("UTBS3" &amp; REF, 10, null);
	
	self.deleteContainer("UTCNT1" &amp; REF);
	self.deleteContainer("UTCNT2" &amp; REF);
	
	create tiSet transient;
	tI1 := self.addContainerOpts("UTCNT1" &amp; REF, "2200", "APPL",operator );	
	move(tI1, blockstack1);
	tiSet.add(tI1);
	
	tI2 := self.addContainerOpts("UTCNT2" &amp; REF, "2200", "APPL", operator);		
	move(tI2, blockstack1);
	tiSet.add(tI2);
	
	self.opts.purge();
	self.opts.addAssociation('TotalRequired',tiSet.size);
	self.opts.addAssoc('TargetTA', "UTBS2" &amp; REF);
	self.opts.addAssoc('AutoRTQ', true);
	
	/*
	1- Create Work Order
	*/
	create pxyWod as CM_WodMove transient;
	
	self.xCreateWorkOrderDetail(pxyWod,WO_TASK_MOVE,null,tiSet,null);
	
	create wodArr transient;
	wodArr.add(pxyWod);
	
	create pxyWorkOrder as CM_WorkOrderTI transient;
	self.xCreateWorkOrder(pxyWorkOrder,realWorkOrder,WOID,WO_STATUS_USERENTRY,wodArr);
	
	self.assertNotNull(realWorkOrder);
	self.assertEqual(realWorkOrder.allWoDtls.size,1);
	self.assertEqualMsg(realWorkOrder.allTransactions.size,1 , "Transaction Not Created");
	self.assertEqualMsg(realWorkOrder.allWoDtls.first.CM_WorkOrderDtl.allWODtlTransactions.size,1 , "Transaction Not Created");
epilog
	delete tiSet;
	pxyWorkOrder.allWoDtls.purge;
	delete pxyWorkOrder;
	delete wodArr;
end;</source>
    </JadeMethod>
    <JadeMethod name="uCheckInstructionIssued" id="23101af9-5cb2-4880-9cac-6e2a5a79cd53">
        <source>uCheckInstructionIssued();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 Nov 2022 navtnr20 ChangeRequest 54967: EUP - INB/OUT - Operational Instructions
12 Jan 2023	navma1  ChangeRequest 56141: EUP - Refactor and Remove CM_WorkOrderTISource from CM_WorkOrderTI
18 Apr 2023 navhl20 ChangeRequest 57569:[57601] EUP - [Framework] Refactor Actioning Work Order Tasks
*/
constants
	Ref						: String		= UT_DSL.TFS54967;
	INTERNAL				: String 		= "INTERNAL";
	EXTERNAL				: String 		= "EXTERNAL";
	EXTERNALUPD				: String		= "EXTERNAL UPDATE";
	WorkOrder				: String		= "work" &amp; Ref;
	Code 					: String		= "Code";
	Description				: String		= "Descr";
	Isnot 					: Boolean		= false;
vars
	realInstruction	 : CM_InstructionsIssued;
	myInstruction 	 : CM_InstructionType;
	tiSet			 : CM_TISet;
	wodArr			 : CM_WorkOrderDtlArray;
	pxyWod,
	wod				 : CM_WorkOrderDtl;
	pxyWorkOrder,
	workOrder		 : CM_WorkOrder;
	toDoTaskDesc	 : CM_ToDoTaskDesc;
	taskID			 : Integer;
	toDoTaskDescSet	 : CM_ToDoTaskDescBySortKey;
	tI1,
	tI2				 : CM_TrackedItem;
begin
	deleteWorkOrder(WorkOrder);
	self.deleteInstructionType(myInstruction);
	
	self.deleteContainer("UTCNT1" &amp; Ref);
	self.deleteContainer("UTCNT2" &amp; Ref);
	
	tI1 := self.addContainerOpts("UTCNT1" &amp; Ref, "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));	
	tI2 := self.addContainerOpts("UTCNT2" &amp; Ref, "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));		
	
	create tiSet transient;
	tiSet.add(tI1);
	tiSet.add(tI2);	
	
	toDoTaskDesc := self.xAddToDoTaskTI(); 
	taskID := toDoTaskDesc.code;
	
	create toDoTaskDescSet transient;
	
	toDoTaskDescSet.add(toDoTaskDesc);
	
	self.addToDoTaskResource("UTMARESTRA",
											 "UT MA Resource",
											 "MAN",
											 1,
											 false,
											 true,
											 toDoTaskDescSet
											 );

	self.opts.addAssoc('toDoTaskID', taskID);
	//Create work order
	create pxyWod as CM_WodToDo transient;
	
	self.xCreateWorkOrderDetail(pxyWod,WO_TASK_TODO,null,tiSet,null);
	
	create wodArr transient;
	wodArr.add(pxyWod);
	
	create pxyWorkOrder as CM_WorkOrderTI transient;
	self.xCreateWorkOrder(pxyWorkOrder,workOrder,WorkOrder,WO_STATUS_USERENTRY,wodArr);
	self.assertNotNull(workOrder);
	
	//create myInstruction 
	myInstruction := self.createInstructionType(Code,Description,false,Isnot);
	
	//Creating
	realInstruction := self.createInstructionIssued(INTERNAL,EXTERNAL,myInstruction,workOrder);
	self.assertEqual(realInstruction.internalInstructions, INTERNAL);
	self.assertEqual(realInstruction.externalInstruction,EXTERNAL);
	
	//updating
	self.updateInstructionIssued(EXTERNALUPD,realInstruction);
	self.assertNotNull(realInstruction);
	self.assertEqual(realInstruction.externalInstruction, EXTERNALUPD);
epilog
	delete tiSet;
	pxyWorkOrder.allWoDtls.purge;
	delete pxyWorkOrder;
	delete wodArr;
	delete toDoTaskDescSet;
end;</source>
    </JadeMethod>
    <JadeMethod name="uCleanupAnyIdAnyAmtData" id="7c77696c-fa1f-4014-bb3f-e6e22b6d4433">
        <source>uCleanupAnyIdAnyAmtData();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 September 2024	navpw1	Initial creation

*/

vars
	loopVar : Integer;
	
begin
	loopVar := 1;
	while loopVar &lt;= 100 do
		self.deleteTrackedItem(self.getTrackedItem("UT65623" &amp; "-" &amp; loopVar.String), false);
		loopVar += 1;
	endwhile;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="uRecRoadPerformanceTest1" id="1f2733d1-f9ff-4461-a6ee-e4cc4f44044d">
        <updating/>
        <source>uRecRoadPerformanceTest1()updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 March 2024	navhl20	Initial creation

*/

constants
	REF: String    =  "001";
	COUNT :Integer = 150;
	WOID : String  = 'UT'&amp;REF&amp;'PT';
vars
	useYardJobsSetting,
	canAutoActionTiWo	: Boolean;
	tiSet				: CM_TISet;
	wodArr				: CM_WorkOrderDtlArray;
	pxyWod,
	wod					: CM_WorkOrderDtl;
	pxyWorkOrder,
	workOrder			: CM_WorkOrder;
	idx					: Integer;
	voyage				: CM_Voyage;
	vessel 				: CM_Vessel;
	booking				: CM_BookingRef;
	term				: CM_Terminal;
	prof     				: JadeProfiler;
	clock					: String;
	folder					: String;
begin
	/*
	** Setup Section, create the work order with a receive cargo task with multiple tracked items
	*/
	
	//if process.isMohamed then
		clock  := app.clock.String;
		folder := global.getJadeInstallDirServer().replace( CN_C_BIN, CN_C_MISC );
		prof   := process.profiler;	
		prof.methodCount := 30;
		prof.fileName := folder &amp;"\MA" &amp; '\'  &amp;"uRecRoadPerformanceTest1 -" &amp; clock &amp;".csv";
		prof.clearMethodCache();
		prof.reportStatistics := true;
		prof.reportTotalTime := true;
		prof.reportLoadTime := true;
		prof.profileRemoteExecutions := true;
		prof.reportActualTime := true;
		prof.reportCacheStatistics := true;
		prof.reportInCSVFormat := true;
		prof.reportLoadTime := true;
		prof.reportMethodSize := true;
		prof.reportStatistics := true;

		prof.start;
	//endif;
	
	term := self.getTerminal();
	
	// Set the config to use yard jobs for the terminal and allow AutoActioning
	useYardJobsSetting := term.getConfig(UseYardJobsCargoWO).Boolean;
	canAutoActionTiWo := term.getConfig(AllowAutoActionCargoWo).Boolean;
	
	if not useYardJobsSetting then
		self.setTerminalConfig(UseYardJobsCargoWO, true);
	endif;
	
	if not canAutoActionTiWo then
		self.setTerminalConfig(AllowAutoActionCargoWo, true);
	endif;
	
	self.deleteWorkOrderNoValidation(WOID);
	self.deleteBooking("UT_HLBK" &amp; REF);
	self.deleteVoyage("HLVOY"&amp;REF);
	self.deleteVessel("HLVES"&amp;REF);
	
	vessel := self.addVesselWithHolds("HLVES"&amp;REF, 2, 2);
	voyage := self.addVoyageWithGeneralCargoStruc("HLVOY"&amp;REF, vessel.name, vessel.myOperator.code,	self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 0);
	
	self.opts.purge();
	self.opts.addAssoc('number', COUNT);
	booking := self.addBookingForContainer("UT_HLBK" &amp; REF, self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString), voyage, "NZAKL", "2200", "MT");
	assertNotNull(booking);
	
	foreach idx in 1 to COUNT do
		self.deleteContainer("UT" &amp; REF &amp; idx.String);
		self.addPrenotedContainer(booking.allBookingRefItems.first,"UT" &amp; REF &amp; idx.String);
	endforeach;	
	
	create tiSet transient;
	booking.allTIs.copy(tiSet);
	
	self.opts.purge();
	self.opts.addAssoc('RequiredByDT', app.actualTimeServer().addDays(2).String);
	self.opts.addAssoc('booking', booking.bookingReference);
	self.opts.addAssoc('transportMode', TI_TRANSMODE_ROAD);
	self.opts.addAssoc('transObj', voyage.code);
	self.opts.addAssoc('dtArrived', voyage.arrivedDT);
	// Create the work order
	create pxyWod as CM_WodReceive transient;
	
	self.xCreateWorkOrderDetail(pxyWod,WO_TASK_RECEIVE,null,tiSet,null);
	
	create wodArr transient;
	wodArr.add(pxyWod);
	
	create pxyWorkOrder as CM_WorkOrderTI transient;
	self.xCreateWorkOrder(pxyWorkOrder,workOrder,WOID,WO_STATUS_USERENTRY,wodArr);
	
	wod := workOrder.allWoDtls.first;
	self.xCheckWorkOrder(wod,WO_STATUS_USERENTRY,COUNT,TRANS_TYPE_WO_TIREC_CREATED,false,false);
epilog
	delete tiSet;
	if pxyWorkOrder &lt;&gt; null then
		pxyWorkOrder.allWoDtls.purge;
	endif;
	delete pxyWorkOrder;
	delete wodArr;
	
	if prof &lt;&gt; null then
		prof.report;
	endif;
end;</source>
    </JadeMethod>
