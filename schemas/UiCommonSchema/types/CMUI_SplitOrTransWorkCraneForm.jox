    </JadeMethod>
    <JadeMethod name="displayCraneDetails" id="6cc41db8-041d-4732-a4ce-767284ec7f04">
        <source>displayCraneDetails();
// --------------------------------------------------------------------------------
// Created:		31 August 2010 by cnwjo3
//
// Purpose:		display the crane id at top label
//
vars

begin
	if self.myWorkPoint &lt;&gt; null then
		self.lblCurrentCrane.caption := app.getErrorString1(SplitTransfer_CurrentCrane,self.myWorkPoint.IF_VoyageWorkPoint.getID);
	else
		self.lblCurrentCrane.caption := "";
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="doCargoEdit" id="36f8c2ad-a2c5-4ccc-ac15-41183754343f">
        <source>doCargoEdit();
// --------------------------------------------------------------------------------
// Created:		23 September 2010 by cnwjo3
//
// Purpose:		
//
vars
	ti : CM_TrackedItem;
	tiArray : ObjectArray;
	voyageWLE : CM_VoyageWLE;
	table : CM_DataTable;
	rowIdx : Integer;
begin
	table := self.tblCargoList;
	
	create tiArray transient;
	
	foreach rowIdx in 1 to table.rows do
		if table.accessRow(rowIdx).itemObject &lt;&gt; null and table.accessRow(rowIdx).selected then
			voyageWLE := table.accessRow(rowIdx).itemObject.CM_VoyageWLE;
			if voyageWLE.myTrackedItem &lt;&gt; null then
				ti := voyageWLE.myTrackedItem;
				tiArray.add(ti);
			endif;
		endif;
	endforeach;
	
	if tiArray.size = 1 then
		self.myAssistant.showCargoEnquiryForm(ti,null,true,true);
	elseif tiArray.size &gt; 1 then
		self.myAssistant.showCargoEnquiryForTIs(ti,tiArray,null,true);
	endif;
	
epilog
	delete tiArray;
end;</source>
    </JadeMethod>
    <JadeMethod name="doCargoEnquiry" id="86126c78-607e-4360-9f14-7af05d6c8137">
        <source>doCargoEnquiry();
// --------------------------------------------------------------------------------
// Created:		20 September 2010 by cnwjo3
//
// Purpose:		
//
vars
	ti : CM_TrackedItem;
	tiArray : ObjectArray;
	voyageWLE : CM_VoyageWLE;
	table : CM_DataTable;
	rowIdx : Integer;
begin
	table := self.tblCargoList;
	
	create tiArray transient;
	
	if self.myAssistant = null then
		//do nothing...
	else
		foreach rowIdx in 1 to table.rows do
			if table.accessRow(rowIdx).itemObject &lt;&gt; null and table.accessRow(rowIdx).selected then
				if table.accessRow(rowIdx).itemObject.isKindOf(CM_VoyageWLE) then
					voyageWLE := table.accessRow(rowIdx).itemObject.CM_VoyageWLE;
					if voyageWLE.myTrackedItem &lt;&gt; null then
						ti := voyageWLE.myTrackedItem;
						tiArray.add(ti);
					endif;
				endif;
			endif;
		endforeach;
		
		if tiArray.size = 1 then
			self.myAssistant.showCargoEnquiry(ti);
		elseif tiArray.size &gt; 1 then
			self.myAssistant.showCargoEnquiryForTIs(ti,tiArray,null,false);
		endif;
	endif;
epilog
	delete tiArray;
end;</source>
    </JadeMethod>
    <JadeMethod name="doCraneChange" id="5b285a3a-291a-49ce-a39c-ad882b5bbf1b">
        <updating/>
        <source>doCraneChange() updating;
// --------------------------------------------------------------------------------
// Created:		31 August 2010 by cnwjo3
//
// Purpose:		Crane has been changed.  Need to update the New Job ID
//
vars

begin
	self.currentVoyageJobSheet := null; // PAR 25968
	self.setNewJobIDtxtValue(self.cmbCrane.listObject.CM_Object);
end;</source>
    </JadeMethod>
    <JadeMethod name="doInspectObject" id="4a122cea-a28b-432c-822f-963e114daa32">
        <source>doInspectObject();
// --------------------------------------------------------------------------------
// Created:		20 September 2010 by cnwjo3
//
// Purpose:		
//
vars
	table : CM_DataTable;
begin
	table := self.tblCargoList;
	
	if table.accessRow(table.row).itemObject &lt;&gt; null then
		table.accessRow(table.row).itemObject.inspect;
	endif;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doOK" id="fd5eec1b-979f-43ce-92c7-399feda588c5">
        <updating/>
        <source>doOK() updating;
// --------------------------------------------------------------------------------
// Created:		31 August 2010 by cnwjo3
//
// Purpose:		
//
// Changed On	By			Reason
// ----------	----------	-------------------------------------------------------
// 19/12/2019	jlgdap1		TFS 47144 JMT Refactor OOW Job Split Transfer
// 24 May 2024	navnk30		Bug 64065: CPL - Order of work - Unable to transfer job with single container
vars
	mode : Integer;
	tmpJobArray,
	tmpJobWithWarnings: CM_VoyageJobArray;
	tmpVoyageJSTo :  CM_VoyageJobSheet;
	voyageWLE : CM_VoyageWLE;
	rowIdx : Integer;
	tbl : CM_DataTable;
	requests : CM_RequestSet;
	wles : CM_WLESet;
	result : Integer;
	newJobInfo : String;
	saveOK,
	selectAll, alljobs : Boolean;
	msg : String;
	tmpJob : CM_VoyageJob;
	targetJob : CM_VoyageJob;
	
begin
	tbl := self.tblCargoList;
	
	create tmpJobArray transient;
	create tmpJobWithWarnings transient;
	create requests transient;
	create wles transient;
	saveOK :=false;
	tmpVoyageJSTo := self.currentVoyageJobSheet;

	if tmpVoyageJSTo = null then
		return;
	endif;	

	if self.txtNewJobID.text.length &lt; 1 then
		return;
	endif;
	
	if self.tblCargoList.getNumSelectedRows() = self.myVoyageJob.workListEntries.size then // TFS 8158
		self.chkMoveJob.value := true; // TFS 8158
	elseif self.tblCargoList.visible = false and self.myVoyageJob.workListEntries.size = 1 then	//24.05.2024 navnk30 #64065
		self.chkMoveJob.value := true;
	endif;
	
	if tmpVoyageJSTo.allJobsByJobNum.size &gt; 0 then
		tmpJob := tmpVoyageJSTo.allJobsByJobNum[self.txtNewJobID.text];
		if tmpJob &lt;&gt; null then
			if self.myVoyageJob.jobType &lt;&gt; tmpJob.jobType then
				//Load vs Discharge
				msg := app.getErrorString2(Not_transfer_from, self.myVoyageJob.jobTypeId, tmpJob.jobTypeId);
				app.msgBox( msg ,app.getErrorStringShortText(SplitTransfer_JobExists), MsgBox_OK_Only );
				return;
			endif;
			if self.myVoyageJob.class &lt;&gt; tmpJob.class then
				//Hold vs LOLO
				msg := app.getErrorString2(Not_transfer_from, self.myVoyageJob.getJobClassNiceString, tmpJob.getJobClassNiceString);
				app.msgBox( msg ,app.getErrorStringShortText(SplitTransfer_JobExists), MsgBox_OK_Only );
				return;
			endif;	
								targetJob := tmpJob;
/*
			if not self.chkMoveJob.value then // TFS 8157
				msg := app.getErrorString1(Alread_exists_Add_to_Job, self.txtNewJobID.text);
				if app.msgBox( msg ,app.getErrorStringShortText(SplitTransfer_JobExists), MsgBox_Yes_No) = MsgBox_Return_Yes then
					targetJob := tmpJob;
				else
					return;
				endif;	
			endif;
			*/
		endif;	
	endif;
	
	if self.chkUnplan.value = true and self.chkUnqueue.value = true then
		mode := PLANNING_MODE;
	elseif self.chkUnqueue.value = true then
		mode := QUEUE_MODE;
	elseif self.chkUnplan.value = true then
		mode := UNPLAN_MODE;
	else
		mode := REAL_MODE;
	endif;
	
	if self.allVoyageJobs.size  &gt; 1 then
		self.allVoyageJobs.copy(tmpJobArray);
		// TFS 3646 jobDesc := 'all jobs'; // PAR 30416
		alljobs := true; // TFS 3646
	else
		tmpJobArray.add(self.myVoyageJob);
		// TFS 3646 jobDesc := "whole of job " &amp; self.myVoyageJob.jobNum; // PAR 30416
		alljobs:= false; // TFS 3646
	endif;
	
//	if tbl.selectedCount = 0 or self.chkMoveJob.value then
	if tbl.selectedCount = 0  then
		if self.chkMoveJob.value then
			// PAR 25968
			 // PAR 30416
// TFS 3646			if app.msgBox("MOVE " &amp; jobDesc &amp; " to crane " &amp; tmpVoyageJSTo.crane &amp; "?","",MsgBox_Yes_No+MsgBox_Question_Mark_Icon) = MsgBox_Return_Yes then
			if alljobs then
				if app.msgBox(app.getErrorString1(Move_jobs_crane,tmpVoyageJSTo.crane),"",MsgBox_Yes_No+MsgBox_Question_Mark_Icon) = MsgBox_Return_Yes then
					selectAll := true;
					saveOK:=true;
				else					// TFS 47144
					return;				// TFS 47144
				endif;
			else
				//if app.msgBox(app.getErrorString2(Move_whole_crane,tmpVoyageJSTo.crane, self.myVoyageJob.jobNum),"",MsgBox_Yes_No+MsgBox_Question_Mark_Icon) = MsgBox_Return_Yes then		//24.05.2024 navnk30 #64065
				if app.msgBox(app.getErrorString2(Move_whole_crane, self.myVoyageJob.jobNum, tmpVoyageJSTo.crane),"",MsgBox_Yes_No+MsgBox_Question_Mark_Icon) = MsgBox_Return_Yes then		//24.05.2024 navnk30 #64065
					selectAll := true;
					saveOK:=true;
				else					// TFS 47144
					return;				// TFS 47144
				endif;
			endif;
		else // make this - Transfer ALL job items to crane " &amp; tmpVoyageJSTo.crane &amp; "?"
			if app.msgBox(app.getErrorString1(WLES_TRANSFER_ALL, tmpVoyageJSTo.crane),"",MsgBox_Yes_No+MsgBox_Question_Mark_Icon) = MsgBox_Return_Yes then
				selectAll := true;
				saveOK:=true;
			else						// TFS 47144
				return;					// TFS 47144
			endif;
		endif;
	endif;	
	
	foreach rowIdx in 1 to tbl.rows do
		if CM_VoyageWLE.hasInstance(tbl.accessRow(rowIdx).itemObject) then
			if tbl.accessRow(rowIdx).selected or selectAll then
				voyageWLE := tbl.accessRow(rowIdx).itemObject.CM_VoyageWLE;
				requests.addNoDuplicates(voyageWLE.myRequest,false);	//14 Mar 2011	NDL	Par 27144
				wles.addNoDuplicates(voyageWLE,false); // TFS 3558
			endif;
		endif;
	endforeach;
	
	if requests.size &gt; 0 or tmpJobArray.size &gt;  1  or self.chkMoveJob.value 
	or (self.mode = self.Mode_Transfer and tmpJobArray.size = 1) then				// TFS 47144
		while true do
		// TFS 8158 added allJobs
			newJobInfo := app.myTrxUA.trxTransferVoyageJobsToCrane(alljobs, tmpJobArray, tmpJobWithWarnings, tmpVoyageJSTo, mode, requests,wles, self.txtNewJobID.text,self.chkMoveJob.value, targetJob, app.myPassport); // PAR 25968 pass in MOVE
			
			if app.myPassport.trxCompletedOK then
				if newJobInfo &lt;&gt; null then
					app.msgBox(newJobInfo,null,MsgBox_Information_Icon);  //inform user what has actually happened
				endif;
				saveOK:=true;
				break;
			else
				result := app.showErrorWarningDialog(self.caption, app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnSkipErr);
				if result = IDOK then
					app.mousePointer := MousePointer_HourGlass;
					// there must have just been warnings that the user has acknoledged so ..
					app.myPassport.warningsAcknowledged	:= true;
					// only reprocess the jobs that had warnings.
					tmpJobArray.clear;
					tmpJobWithWarnings.copy(tmpJobArray);				
					tmpJobWithWarnings.clear;	
					continue;
				endif;
			endif;
			break;			
		endwhile;
	endif;
	
	//epr TFS 830 lets not close the form if there are errors 
	if saveOK then
		inheritMethod();
	endif;
epilog
	delete tmpJobArray;
	delete tmpJobWithWarnings;
	delete requests;
	delete wles;
end;</source>
    </JadeMethod>
    <JadeMethod name="doSort" id="a77b2fb0-b001-4996-9ed7-aef0148dab8a">
        <source>doSort();
// --------------------------------------------------------------------------------
// Created:		01 September 2010 by cnwjo3
//
// Purpose:		
//
vars
	tbl : CM_DataTable;
begin
	tbl := self.tblCargoList;
	tbl.sortAsc[1] := true;
	tbl.sortColumn[1] := tbl.getColumnByRowName(ETRow_SeqNumAsString);
	tbl.sortType[1]:=Table.SortType_Numeric;
	tbl.resort();
	tbl.accessSheet(1).displaySorting := Table.DisplaySorting_AllColumns;
end;</source>
    </JadeMethod>
    <JadeMethod name="doTableContextMenu" id="262531b8-f2b4-4757-8bde-78ed097c5c9b">
        <updating/>
        <source>doTableContextMenu(table: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating;
// --------------------------------------------------------------------------------
// Created:		20 September 2010 by cnwjo3
//
// Purpose:		
//
vars
	x1,y1 : Real;
begin
	x1 := x;
	y1 := y;
	
	conwin.windowToScreen(x1, y1);
	self.screenToWindow(x1, y1);   // convert x, y relative to form	
	
	self.mnuInspectObject.visible := app.isAllowedToInspect;

	self.popupMenu(self.mnuContextMenu, x1.Integer, y1.Integer);	
	
	return false;
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doTableDblClick" id="61063848-dfed-46dd-a63f-325e8875e539">
        <source>doTableDblClick(table: Table input);
// --------------------------------------------------------------------------------
// Created:		20 September 2010 by cnwjo3
//
// Purpose:		open up cargo enquiry screen
//
vars
	ti : CM_TrackedItem;
	voyageWLE : CM_VoyageWLE;
begin
	
	if table.accessRow(table.row).itemObject &lt;&gt; null then
		voyageWLE := table.accessRow(table.row).itemObject.CM_VoyageWLE;
		ti := voyageWLE.myTrackedItem;
	endif;
	
	if ti &lt;&gt; null then
		self.myAssistant.showCargoEnquiry(ti);
	endif;
	
epilog
	
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doTableMouseDown" id="977e3b91-75b0-430f-aec7-8e7f825f665a">
        <updating/>
        <source>doTableMouseDown(table: Table input; button: Integer; shift: Integer; x: Real; y: Real) updating;
// --------------------------------------------------------------------------------
// Created:		23 September 2010 by cnwjo3
//
// Purpose:		do automatic selection if necessary
//
vars
	rowIdx : Integer;
begin
	if table.row &lt;= table.fixedRows then
	else
		//we only go into SELECT TO END mode when we enter the screen with only 1 selected
		//and the ctrl key (shift = 2) has not been pressed
		if self.wleSelectMode = self.WLE_SELECTTOEND and shift &lt; 2 then
			foreach rowIdx in table.row to table.rows do
				table.accessRow(rowIdx).selected := true;
			endforeach;
		endif;
	endif;
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="button" type="Integer"/>
