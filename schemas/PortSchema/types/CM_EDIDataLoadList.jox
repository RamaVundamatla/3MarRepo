    <JadeMethod name="getEDITIType" id="c5df466b-c73c-4738-a4ea-156fe9ef1204">
        <source>getEDITIType(_ediDataType : Integer): Class;
//----------------------------------------------------------------
//	Created:	28 January 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
// 15 Jun 2017	cnwrs1	TFS 4462 SNO add Terminal Operator, Unknown Seal and support multiple seals
vars
	ediTI		: CM_EDITrackedItem;
begin
	if _ediDataType =  EDIDataType_TISeal then
		return CM_EDISealTI;
	else
		ediTI := self.allEDITrackedItems.first;
		if CM_EDICargoTI.hasInstance(ediTI) then
			return CM_EDICargoTI;
		else
			return CM_EDILoadListTI;
		endif;
	endif;
end;</source>
        <Parameter name="_ediDataType" type="Integer"/>
        <ReturnType type="Class"/>
    </JadeMethod>
