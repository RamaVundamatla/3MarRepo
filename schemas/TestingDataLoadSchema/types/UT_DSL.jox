    <JadeMethod name="addStraddleStack" id="ff332946-05a3-4607-b467-ec77739d3424">
        <source>addStraddleStack(_name: String; _rows,_columns,_height: Integer): CM_StraddleStack;
//01 September 2008	cnwdw1	 
//
begin
	return self.addStraddleStackEx(_name, _rows, _columns, _height);
end;</source>
        <Parameter name="_name" type="String"/>
        <Parameter name="_rows" type="Integer"/>
        <Parameter name="_columns" type="Integer"/>
        <Parameter name="_height" type="Integer"/>
        <ReturnType type="CM_StraddleStack"/>
    </JadeMethod>
    <JadeMethod name="addStraddleStackEx" id="5b0b1959-b64a-4507-9d06-be174fa9e1b5">
        <source>addStraddleStackEx(_name: String; _rows,_columns,_height: Integer): CM_StraddleStack;
//01 September 2008	cnwdw1	 
// 12/08/2011	cnwmh5	Remove _opts from signature as not used
// 12/05/2014   cnwma1  Add Default Interchange Area Opts
// 22/10/2015	cnwmh5	Add ability to add gaps
vars

	pxyStraddleStack: CM_StraddleStack;
	pxyGridCol: CM_GridColumn;
	pxyGridRow: CM_GridRow;
	pxyStackCntrl: CM_StackController;
	column, row: Integer;
	label: String;
	pDO: CM_YADeckingOptionsTA;
	realTA 	: CM_TerminalAreaMaster;
	pxyGap : CM_GapController;
	
	gapRowColumnArray	: StringArray;
	
	pxyTA				: CM_TerminalAreaMaster;
	pxyCMIFTerminalArea	: CMIF_GridArea;
	use40ftIds			: Boolean;
	withPower			: Boolean;
	
	defaultInterchangeArea	: CM_InterchangeArea;
	icArray 		: CM_InterchangeAreaArray;
	
begin
	self.deleteTerminalArea(_name);
	
	use40ftIds := self.opts.bool("use40ftIds");			// 26/08/2011 cnwmh5
	
	withPower := self.opts.bool("WITHPOWER");	//cnwrd1 20.10.2011 - of you want your gridded area to have power set this!
	
	gapRowColumnArray := self.opts.obj("GapRowColumn").StringArray;				// 22/10/2015 cnwmh5
	
	defaultInterchangeArea := self.opts.obj("DefaultYIC").CM_InterchangeArea;
	
	if self.opts.obj("InterChangeAreaArray") &lt;&gt; null  then
		create icArray transient;
		if self.opts.obj("InterChangeAreaArray").isKindOf (CM_InterchangeArea) then
			icArray.add(self.opts.obj("InterChangeAreaArray").CM_InterchangeArea);
		elseif self.opts.obj("InterChangeAreaArray").isKindOf (ObjectArray) then
			self.opts.obj("InterChangeAreaArray").ObjectArray.copy (icArray);
		endif;
	endif;
	
	create pxyStraddleStack transient;
	pxyStraddleStack.setProxy(_name, 
					"",
					TA_TYPE_STRADDLE_STACK, 
					_rows, 
					_columns, 
					_height,
					true, 
					self.getTerminal,
					false,
					false,
					false,
					0, false, false, false, false, false, 
					icArray,
					defaultInterchangeArea, 
					false, use40ftIds, 
					"West", "East", "North", "Sourth");

	// cnwma1  12/05/2014 add default interchage Area
	
	if self.opts.includesKey("DefaultYIC") then
		pxyStraddleStack.setPropertyValue(CM_StraddleStack::myDefaultInterchangeArea.name, self.opts.obj("DefaultYIC").CM_YardInterchangeArea);
	endif;
	///////////////////
	
	create pDO transient;
	pDO.setProxy(false, true, pxyStraddleStack);
	pDO.setProxyRules(DeckingRule_Default, DeckingRule_Default);
	
	foreach row in 1 to _rows do
		label := row.stringWithLeadingZeros(2);
		create pxyGridRow transient;
		pxyGridRow.setForProxy(row, label, pxyStraddleStack);
		foreach column in 1 to _columns do
			label := column.stringWithLeadingZeros(4);
			pxyGridCol := pxyStraddleStack.allGridColumns[column].CM_GridColumn;
			if pxyGridCol = null then
				create pxyGridCol transient;
				pxyGridCol.setForProxy(column, label, pxyStraddleStack);
			endif;
			
			if gapRowColumnArray = null or not gapRowColumnArray.includes(label &amp; "," &amp; row.stringWithLeadingZeros(2)) then
				create pxyStackCntrl transient;
				pxyStackCntrl.setForProxy(PAD_AVAILABLE, 
								NORMAL_USE, 
								pxyGridRow.row, 
								pxyGridCol.column,
								pxyGridRow.label &amp; pxyGridCol.label,
								2,
								withPower,
								false,
								null,
								pxyStraddleStack, false,null, false, null, false, null);
		
	
				pxyStackCntrl.setForProxyGridController(pxyGridRow.label &amp; pxyGridCol.label, 
									pxyGridCol,
									pxyGridRow,
									2);
	
				pxyStackCntrl.setCanTwinLiftWithNext(true);
				pxyStackCntrl.setCanTwinLiftWithPrev(true);
			else
				create pxyGap transient;
				pxyGap.setForProxy(PAD_AVAILABLE, 
								NORMAL_USE, 
								pxyGridRow.row, 
								pxyGridCol.column,
								pxyGridRow.label &amp; pxyGridCol.label,
								2,
								withPower,
								false,
								null,
								pxyStraddleStack, false,null, false, null, false, null);
		
	
				pxyGap.setForProxyGridController(pxyGridRow.label &amp; pxyGridCol.label, 
									pxyGridCol,
									pxyGridRow,
									2);
									
				pxyGap.setCanTwinLiftWithNext(true);
				pxyGap.setCanTwinLiftWithPrev(true);
			
			endif;
		endforeach;
	endforeach;

	// 26/08/2011 cnwmh5
	pxyTA := pxyStraddleStack;
	// only do this if use40ftIds is set as returns correct location but slightly different format
	if use40ftIds then
		create pxyCMIFTerminalArea transient;
		pxyCMIFTerminalArea.numRows :=  _rows;
		pxyCMIFTerminalArea.numColumns := _columns;
		pxyCMIFTerminalArea.myPxyTerminalAreaMaster := pxyStraddleStack;
		pxyCMIFTerminalArea.startNumColumn := 1;
		pxyCMIFTerminalArea.startNumRow := 1;
		pxyCMIFTerminalArea.labelLengthCol := 4;
		pxyCMIFTerminalArea.labelLengthRow := 4;
		pxyCMIFTerminalArea.use40ftIds := use40ftIds;
		pxyCMIFTerminalArea.createProxyStructure();
		pxyTA := pxyCMIFTerminalArea.myPxyTerminalAreaMaster;
	endif;
		
	app.myTrxCA.trxCreateTerminalArea(pxyTA, realTA, app.myPassport);				// 26/08/2011 cnwmh5
	self.assertNoTrxErrorsOrWarnings();
	
	return realTA.CM_StraddleStack;
epilog
	delete pxyStraddleStack;
	delete pxyCMIFTerminalArea;
	if app.isValidObject(pDO) then
		delete pDO;
	endif;
end;</source>
        <Parameter name="_name" type="String"/>
        <Parameter name="_rows" type="Integer"/>
        <Parameter name="_columns" type="Integer"/>
        <Parameter name="_height" type="Integer"/>
        <ReturnType type="CM_StraddleStack"/>
    </JadeMethod>
    <JadeMethod name="addStraddleTwin" id="18b64baf-0aab-4adf-ae1e-0a7054c92b38">
        <source>addStraddleTwin(_name: String; _deviceId: Integer; _taAccess: StringArray; _queue: String): CM_Machine;
//07 January 2009	cnwdw1	
//
begin
	self.opts.addAssoc("MachineLiftType", TWIN_LIFT);
	return self.addMachine(MACHINETYPE_STRADDLE, _name, _deviceId, _taAccess, _queue);
end;</source>
        <Parameter name="_name" type="String"/>
        <Parameter name="_deviceId" type="Integer"/>
        <Parameter name="_taAccess" type="StringArray"/>
        <Parameter name="_queue" type="String"/>
        <ReturnType type="CM_Machine"/>
    </JadeMethod>
    <JadeMethod name="addSubBlockStack" id="80080822-fc62-441b-a59d-e709a2ee4890">
        <source>addSubBlockStack(_gridArea : CM_GridArea; _subBlockLocations : CM_LCArray) : CM_SubBlockStack;

/*

Purpose:		Add a Sub Block 

Date			Who		Reason
07/02/2014		cnwmh5	Initial creation

*/

vars

	theRegion						: CMIF_GridTARegion;
	subBlockStack					: CM_SubBlockStack;
	location						: CM_LocationsController;

begin

	create theRegion transient;
	
	foreach location in _subBlockLocations do
		theRegion.allLocationControllers.add(location);
	endforeach;
	theRegion.id := theRegion.allLocationControllers.first.getID();
	theRegion.myGridArea := _gridArea;
	theRegion.isStockControlled := true;
	
	app.myTrxCA.trxCreateSubBlockStack(theRegion, subBlockStack, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	return subBlockStack;

epilog

	delete theRegion;

end;</source>
        <Parameter name="_gridArea" type="CM_GridArea"/>
        <Parameter name="_subBlockLocations" type="CM_LCArray"/>
        <ReturnType type="CM_SubBlockStack"/>
    </JadeMethod>
    <JadeMethod name="addSubTerminal" id="b83392e7-be17-420b-936a-292ca15113af">
        <source>addSubTerminal( _subTermCode : String; _type :Integer ) : CM_SubTerminal;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
15 October 2010	cnwndl1	Initial creation

*/

vars

	subTermProxy : CM_SubTerminal;
	subTerm : CM_SubTerminal;
	bank : CM_Bank;
	
	description			: String;
		
begin

	self.deleteSubTerminal(_subTermCode);
	
	description := _subTermCode;
	if self.opts.includesKey("description") then
		description := self.opts.str("description");
	endif;

	create subTermProxy transient;
	subTermProxy.setProxy(	_subTermCode,
							description,
							_type,
							self.getTerminal,
							null,	//_debtor : CM_Debtor //03 Dec 2014	NDL	Par 35295
							null,	//_selectedAvailGrades : CM_MTGradeByCodeDict;	//13 Oct 2010	NDL Par 23991
							null	//_selectedToDoDescs : CM_ToDoTaskDescByCode	//13 Oct 2010	NDL Par 23991
							);
							
	if self.opts.includesKey("Bank") then
		bank := self.opts.obj("Bank").CM_Bank;
		subTermProxy.setMyBank(bank);
	endif;
							
	app.myTrxCA.trxCreateSubTerminal(subTermProxy, subTerm, app.myPassport);
	self.assertTrueMsg(subTerm &lt;&gt; null, "Sub terminal " &amp; _subTermCode &amp; " not created!");	
	
	return subTerm;

epilog

	delete subTermProxy;

end;</source>
        <Parameter name="_subTermCode" type="String"/>
        <Parameter name="_type" type="Integer"/>
        <ReturnType type="CM_SubTerminal"/>
    </JadeMethod>
    <JadeMethod name="addSubTerminalWorkAreaDef" id="587887a4-f832-4267-a6c6-cb7b3da62ed3">
        <source>addSubTerminalWorkAreaDef( subTerm : CM_SubTerminal; _selectedAreas : ObjectSet input ) : CM_SubTerminalAreaDef;
/*

Purpose:			
						_selectedAreas should contain CM_LocationsController(s)
								and/or CM_GridObject(s) and/or CM_TerminalArea(s).
Parameters:			

Return Value:		

Date		Who		Reason
03 December 2014	cnwndl1	Initial creation

*/

vars

	pxySubTerminalAreaDef : CM_SubTerminalAreaDef;
	realSubTerminalAreaDef : CM_SubTerminalAreaDef;



begin

	create pxySubTerminalAreaDef transient;
	pxySubTerminalAreaDef.setProxy(	subTerm.code.trimBlanks[1:10],	//_code : String;
									subTerm.description,	//_description : String;
									true,	//_notAvailable : Boolean;
									_selectedAreas,	//_allSelectedObjects : ObjectSet;
									subTerm,	//_mySubTerminal : CM_SubTerminal;
									self.getTerminal	//_myTerminal : CM_Terminal
									);
	app.myTrxCA.trxCreateSubTerminalAreaDef(pxySubTerminalAreaDef, realSubTerminalAreaDef, app.myPassport);
	self.assertTrueMsg( app.myPassport.noErrors, "Associated areas def not created " &amp; app.myPassport.getErrorsAsString);
	self.assertTrueMsg( realSubTerminalAreaDef &lt;&gt; null, subTerm.code &amp; " associated areas def not created");

	return realSubTerminalAreaDef;
	
epilog

	delete pxySubTerminalAreaDef;

end;</source>
        <Parameter name="subTerm" type="CM_SubTerminal"/>
        <Parameter name="_selectedAreas" type="ObjectSet" usage="input"/>
        <ReturnType type="CM_SubTerminalAreaDef"/>
    </JadeMethod>
    <JadeMethod name="addTAAreaToQueue" id="0231bb23-5d26-415c-ab44-b677a5f22d5c">
        <source>addTAAreaToQueue(_queue : CM_SubQueue; _fromArea, _toArea : CM_TerminalArea);
/*

Purpose:			

Parameters:			

Return Value:		


Date			Who		Reason
14 March 2011	cnwer1	Initial creation
08/04/2011		cnwmh5	PAR #27347 - Add cmsEndLoad or endLoad to epilog so that if error occurs it will not leave it in beginLoad state
*/

vars
	proxyQueue : CM_SubQueue;
	theParent : CM_SubQueue;
begin
	if _queue = null then
		return;
	endif;
	beginLoad;
	proxyQueue := _queue.pxyCreateUpdateProxy;
	endLoad;
	if _fromArea &lt;&gt; null then
		proxyQueue.allMoveFromTAMasters.add(_fromArea);
	endif;
	
	if _toArea &lt;&gt; null then
		proxyQueue.allMoveToTAMasters.add(_toArea);
	endif;
	
	
	app.myTrxUA.trxUpdateRTQueue(proxyQueue, null, app.myPassport);
epilog
	endLoad;				// 08/04/2011 cnwmh5 #27347
	delete proxyQueue;

end;</source>
        <Parameter name="_queue" type="CM_SubQueue"/>
        <Parameter name="_fromArea" type="CM_TerminalArea"/>
        <Parameter name="_toArea" type="CM_TerminalArea"/>
    </JadeMethod>
    <JadeMethod name="addTIHazard" id="ce4f296b-15ec-4450-909d-4538ef2f747e">
        <source>addTIHazard(_ti: CM_TrackedItem; _hazard: String; _limitedQuantity: Boolean);
//01 September 2008	cnwdw1	
//
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------
// 11/06/2015	cnwdap1		PAR #36421 Changed signature for CM_TIHazard::setProxy
vars
	proxyTI: CM_TrackedItem;
	hazard: CM_TIHazard;
begin
	proxyTI := app.createUpdateProxy(_ti).CM_TrackedItem;
	create hazard transient;
	//hazard.setProxy(_hazard, 'Hazard', "", proxyTI, _limitedQuantity);		// PAR #36421
	//hazard.setProxy(_hazard, 'Hazard', "", proxyTI, _limitedQuantity, null);	// PAR #36421								// TFS 2842
	hazard.setProxy(_hazard, 'Hazard', "", proxyTI, _limitedQuantity, null, NULL_TEMPERATURE, MarinePollutant_Null, null);	// TFS 2842
	app.myTrxUA.trxUpdateTrackedItem(proxyTI, 'Automatic', TI_UPDMODE_NORMAL, null, app.myPassport);
	self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());
epilog
	delete hazard;
	delete proxyTI;
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
