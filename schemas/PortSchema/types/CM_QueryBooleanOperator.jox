begin
	return true;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setSearchValue" id="35d6611d-9b8e-4517-9c49-4ba5d2215e92">
        <updating/>
        <source>setSearchValue(_value: Any) updating;
// ---------------------------------------------------------------------------
// Created:     05 March 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars

begin

	self.searchValue := null;
	self.notApplicable := false;
	
	if _value &lt;&gt; null and _value.isKindOf(Boolean) then // par 18123
		self.searchValue := _value.Boolean;
			
	elseif _value &lt;&gt; null and _value.isKindOf(Integer) then //23 Mar 2015	NDL	Par 35886
		if _value.Integer = CM_YADataBoolean.VALUE_FALSE then
			self.searchValue := false;	
		elseif _value.Integer = CM_YADataBoolean.VALUE_TRUE then
			self.searchValue := true;	
		elseif _value.Integer = CM_YADataBoolean.VALUE_EITHER then
			self.notApplicable := true;
		endif;
		
	elseif _value &lt;&gt; null and _value.isKindOf(String) then //23 Mar 2015	NDL	Par 35886
		if _value.String = true.getYesNo() then
			self.searchValue := true;
		elseif _value.String = app.getErrorString(NotApplicable) then
			self.notApplicable := true;
		endif;
		
	endif;
end;</source>
        <Parameter name="_value" type="Any"/>
    </JadeMethod>
    <JadeMethod name="validateForRT" id="3f660882-ffe5-409d-afc4-b063e78f476c">
        <source>validateForRT( _queryName, _propName : String );
// -------------------------------------------------------------------------------------
// Created:	28 April 2008 by cnwvu1
//
// Purpose:	Queries for RT must only use the operations having only one searching value.
//			A set of selected values is not valid for the RT Drivers screen. 
// -------------------------------------------------------------------------------------

vars

begin

	return;
	
end;
</source>
        <Parameter name="_queryName" type="String"/>
        <Parameter name="_propName" type="String"/>
    </JadeMethod>
