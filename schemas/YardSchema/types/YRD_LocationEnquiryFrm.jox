    <JadeMethod name="createDefaultCritLineHolder" id="eaae06e5-9bb9-4be3-bc60-ce4cdc87ec70">
        <updating/>
        <source>createDefaultCritLineHolder(_cargoType: CM_CargoBOLType input; _object: Object) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 December 2019	jlger1	Initial creation TFS 47132
01 June 2022	navtnr20	ChangeRequest 53204: EUP - GEN/REP/INB - Additional Cargo Field – Shipping Line - UI
19 Aug 2022 navtnr20 ChangeRequest 54441: EUP - Additional Field - Country of Origin
*/

vars
	qDef : CM_QueryDefinition;
	terminalArea : CM_TerminalArea;
	taType : CM_TerminalAreaType;
	location : CM_LocationsController;
	critLine : CM_SelectorCriteriaLine;
	voyageCode : String;
	cargoType : CM_CargoBOLType;
begin
	
	delete self.myEnqController;
	create self.myEnqController as CM_EnqControllerTI transient;
	create self.myEnqController.allObjects as  CM_TISet transient;
	delete self.myCriteriaLineHolder;
	create self.myCriteriaLineHolder;
	
	if _object &lt;&gt; null then
		if _object.isKindOf(CM_TerminalArea) then
			terminalArea:=_object.CM_TerminalArea;
		elseif _object.isKindOf(CM_LocationsController) then
			location:=_object.CM_LocationsController;
			terminalArea:=_object.CM_LocationsController.getMyTerminalArea;
		elseif _object.isKindOf(CM_Voyage) then
			self.filterVoyage:=_object.CM_Voyage;
			voyageCode:=_object.CM_Voyage.code;
		elseif _object.isKindOf(CM_SOHLocation) then
			terminalArea:=_object.CM_SOHLocation.myTerminalArea;
			location:=_object.CM_SOHLocation.myLocationsController;
		endif;
	endif;

	if terminalArea &lt;&gt; null then
		taType := terminalArea.myType;
		self.filterTAType:=taType;
		self.setFilterTerminalArea(terminalArea);
		self.filterYardLocation:=location;
	endif;
	
	
	qDef := app.myRoot.allQueryDefinitionObjects[CM_QueryDefinition.TrackedItem_Query_Type,null];
	self.doCreateCriteriaLine(qDef, self.myCriteriaLineHolder, CM_TrackedItem::myTerminal.name, CM_QueryOperator.Operator_Equal, self.myTerminal);		
	critLine:=self.doCreateCriteriaLine(qDef, self.myCriteriaLineHolder, CM_TrackedItem::site.name, CM_QueryOperator.Operator_Equal, TI_SITE_ONSITE);	
	critLine.setUnavailableAtRunTime;
	self.doCreateCriteriaLine(qDef, self.myCriteriaLineHolder, CM_TrackedItem::getTAType.name, CM_QueryOperator.Operator_Equal,taType);
	self.doCreateCriteriaLine(qDef, self.myCriteriaLineHolder, CM_TrackedItem::myTerminalArea.name, CM_QueryOperator.Operator_Equal,terminalArea);
	self.doCreateCriteriaLine(qDef,  self.myCriteriaLineHolder, CM_TrackedItem::myPrimaryActualLocation.name, CM_QueryOperator.Operator_Equal, location);
	self.doCreateCriteriaLine(qDef, self.myCriteriaLineHolder, CM_TrackedItem::cargoType.name, CM_QueryOperator.Operator_Equal, null);
	self.doCreateCriteriaLine(qDef, self.myCriteriaLineHolder, CM_TrackedItem::id.name, CM_QueryOperator.Operator_StartsOrEndsWith,null);
	self.doCreateCriteriaLine(qDef, self.myCriteriaLineHolder, CM_TrackedItem::alternativeId.name, CM_QueryOperator.Operator_StartsWith, null);
	self.doCreateCriteriaLine(app.myRoot.allQueryDefinitionObjects[CM_QueryDefinition.TrackedItem_Query_Type,TI_CargoType_Container], self.myCriteriaLineHolder, CM_Container::isoType.name, CM_QueryOperator.Operator_Equal, null);
	self.doCreateCriteriaLine(qDef, self.myCriteriaLineHolder, CM_TrackedItem::operatorCode.name, CM_QueryOperator.Operator_Equal, null);
	self.doCreateCriteriaLine(qDef,  self.myCriteriaLineHolder, CM_TrackedItem::voyageCode.name, CM_QueryOperator.Operator_Equal, voyageCode);
	self.doCreateCriteriaLine(qDef,  self.myCriteriaLineHolder,CM_TrackedItem::getShippingLineCode.name.String,CM_QueryOperator.Operator_Equal,null);	// 01.07.2022 navtnr20 TFS 53204
	self.doCreateCriteriaLine(qDef, self.myCriteriaLineHolder,CM_TrackedItem::getCountryOfOriginCode.name,CM_QueryOperator.Operator_Equal,null);		//19.08.2022 navtnr20 54441
	self.setTblSearchFromSelector();

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_cargoType" type="CM_CargoBOLType" usage="input"/>
        <Parameter name="_object" type="Object"/>
    </JadeMethod>
    <JadeMethod name="doBuildComboTermArea" id="c42aa913-c5c6-44e1-87af-731086dcf857">
        <updating/>
        <source>doBuildComboTermArea() updating;
// ---------------------------------------------------------------------------
// Created:		July 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars

begin
	if self.useSelectorTable then
		//epr TFS 47132 17/12/19
		return;
	endif;
	cmbFiltTermArea.gotFocus(cmbFiltTermArea);
	self.myAssistant.comboBoxTerminalArea(cmbFiltTermArea, self.filterTerminalArea.myType.type, self.filterTerminalArea);
	cmbFiltTermArea.lostFocus(cmbFiltTermArea);

	self.cmbFiltTermArea.listObject := self.myCurrentObject;
	self.setFilterTerminalArea(self.myCurrentObject.CM_TerminalArea);
	self.setNotifications();	//Par14787

end;</source>
    </JadeMethod>
    <JadeMethod name="doClonedMenuClickSpecial" id="7fea080f-d486-408c-926b-2051128b531c">
        <updating/>
        <source>doClonedMenuClickSpecial(menuItem: MenuItem input) updating, protected;
//----------------------------------------------------------------
//	Created:	14 August 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
// 15/06/2010			cnwcs5	par 24342 - no longer using CMUI_StopsListTable

vars
	obj	: Object;
begin
	//We need to be a TrackedItem to go through here as opposed to a CM_BOL object.
//	if not self.isMyCurrentObjectTrackedItem then
//		app.raiseCMException1(ERR_Item_Not_TrackedItem, self.myCurrentObject.getName, null, null);
//	endif;

	obj := menuItem.userObject;
	
	if menuItem.helpKeyword = "LOAD" or menuItem.helpKeyword = "DISCHARGE" or menuItem.helpKeyword = "QUEUE" then
		if self.myCurrentObject &lt;&gt; null then	//06 Dec 2019	NDL	TFS 46875
			self.doMnuUnplanClick(menuItem);
			return;	//06 Dec 2019	NDL	TFS 46875
		endif;
		
/*	par 24342
	elseif CM_StopsTable.hasInstance(obj) then
		self.doMnuTiStopsClick(obj.CM_StopsTable, menuItem);	
		return; */
	elseif CM_ToDoTaskDesc.hasInstance(obj) then
		if self.todoTaskMode = TASK_MODE_ADD then
			self.doMenuTaskAddClick(obj.CM_ToDoTaskDesc);
		elseif self.todoTaskMode = TASK_MODE_COMPLETE then
			self.doMenuTaskCompleteClick(obj.CM_ToDoTaskDesc);
		elseif self.todoTaskMode = TASK_MODE_REMOVE then
			self.doMenuTaskRemoveClick(obj.CM_ToDoTaskDesc);
		else
			app.raiseUnexpectedProgramError(class.name, method.name, 'invalid todoTaskMode');
		endif;
		return;
	elseif CM_MTGrade.hasInstance(obj) then
		self.doMnuSetGradeClick(obj.CM_MTGrade, menuItem);	
		return;		
	elseif menuItem.helpKeyword = 'YAChild' then
		self.doYardAllocationMenuClick(menuItem);
		return;
	endif;
	
	if self.myCurrentObject &lt;&gt; null then // TFS 43424 If there is no cargo in the list you will get a developer error in this call.
		inheritMethod(menuItem);	//21 Aug 2018	NDL	TFS 40035
	endif;


epilog

end;</source>
        <access>protected</access>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doContextForBoxcar" id="d52778da-7e8d-4d28-8580-907ba80bd269">
        <source>doContextForBoxcar();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 April 2013	cnwndl1	Initial creation	Par 31278

*/

vars

	wagon : CM_Wagon;

begin

	if self.myStartupObject = null then
		return;
	endif;
	

	if CM_BoxcarWagonController.hasInstance( self.myStartupObject) then
		wagon := self.myStartupObject.CM_BoxcarWagonController.myWagon;
		if wagon &lt;&gt; null and wagon.confirmed and not wagon.confirmedOutwards then
			self.mnuCreateInBoxcar.visible := true;
			self.mnuCreateInBoxcar.userObject := wagon;
			self.mnuCreateInBoxcar.caption := app.getErrorString1(Create_cargo_boxcar,wagon.id);
		endif;
		
		self.mnuRestrictions.visible := false;
		self.mnuTALocnAudit.visible := false;
		self.mnuGridTBA.visible := false;
		
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doContextForShipPlanning" id="bb9b7f82-51e0-4684-a1d5-fca1ebfaf95c">
        <source>doContextForShipPlanning(_ourLocation : CM_LocationsController);
//-----------------------------------------
//Created: June 2003 By: cnwgd1
//-----------------------------------------
vars
	locnString : String;
	lTI : CM_TrackedItem;
begin
	if _ourLocation = null and app.myMoveController = null then
		return;
	endif;
	// DISCHARGE
	if app.myDraggedTrackedItem &lt;&gt; null then
		if app.myDraggedTrackedItem.getPrimaryLocation(PLANNING_MODE) &lt;&gt; null then
			self.mnuGridPlanDischarge.userObject := null;
			self.mnuGridPlanDischarge.visible := false;
		else
			if app.myMoveController.mySlotRequest &lt;&gt; null and app.myMoveController.mySlotRequest.myJob &lt;&gt; null then
				// YES!
				if app.myMoveController.mySlotRequest.isDischarge  then
					self.mnuGridPlanDischarge.caption := "Plan Discharge " &amp; app.myDraggedTrackedItem.id;
					self.mnuGridPlanDischarge.userObject := _ourLocation;
					self.mnuGridPlanDischarge.visible := true;
				endif;
			// PAR 28365
			elseif app.myMoveController.myVoyageRequest &lt;&gt; null and app.myMoveController.myVoyageRequest.myJob &lt;&gt; null then
				// YES!
				if app.myMoveController.myVoyageRequest.isDischarge  then
					self.mnuGridPlanDischarge.caption := "Plan Discharge " &amp; app.myDraggedTrackedItem.id;
					self.mnuGridPlanDischarge.userObject := _ourLocation;
					self.mnuGridPlanDischarge.visible := true;
				endif;
			endif;
		endif;
	elseif (self.myCurrentObject &lt;&gt; null and self.myCurrentObject.isKindOf(CM_TrackedItem))  then // load
		lTI := self.myCurrentObject.CM_TrackedItem;
		// LOAD
		if app.myMoveController.mySlotRequest &lt;&gt; null and app.myMoveController.mySlotRequest.myJob &lt;&gt; null then
			// YES!
			if app.myMoveController.mySlotRequest.isLoad then
				// 24442 add bulk plan load
				app.myMoveController.setMyTrackedItem(lTI);
				app.myMoveController.setMyOriginatingLocation(_ourLocation);
				if self.tblData.allSelectedObjects.size &gt; 1 then
					self.mnuGridPlanLoad.caption := "Plan Load Selected Cargo";
				else
					locnString := app.myMoveController.mySlotRequest.mySlotController.myVoyage.code &amp; " ";
					locnString := locnString &amp; app.myMoveController.mySlotRequest.mySlotController.getStowageId(lTI);
					self.mnuGridPlanLoad.caption := "Plan Load To " &amp; locnString;
					self.mnuGridPlanLoad.userObject := _ourLocation;
				endif;
				self.mnuGridPlanLoad.visible := true;
			endif;
		// PAR 28365
		elseif app.myMoveController.myVoyageRequest &lt;&gt; null and app.myMoveController.myVoyageRequest.myJob &lt;&gt; null then
			// YES!
			if app.myMoveController.myVoyageRequest.isLoad then
				// 24442 add bulk plan load
				app.myMoveController.setMyTrackedItem(lTI);
				app.myMoveController.setMyOriginatingLocation(_ourLocation);
				if self.tblData.allSelectedObjects.size &gt; 1 then
					self.mnuGridPlanLoad.userObject := self.tblData;
					self.mnuGridPlanLoad.caption := "Plan Load Selected Cargo";
				else
					locnString := app.myMoveController.myVoyageRequest.CM_RORORequest.myROROController.myVoyage.code &amp; " ";
					locnString := locnString &amp; app.myMoveController.myVoyageRequest.CM_RORORequest.myROROController.getStowageId(lTI);
					self.mnuGridPlanLoad.caption := "Plan Load To " &amp; locnString;
					self.mnuGridPlanLoad.userObject := _ourLocation;
				endif;
				self.mnuGridPlanLoad.visible := true;
			endif;
		endif;
	endif;	

end;</source>
        <Parameter name="_ourLocation" type="CM_LocationsController"/>
    </JadeMethod>
    <JadeMethod name="doCreateCargoInBoxcar" id="96005e03-6584-4151-9282-d88612098549">
        <source>doCreateCargoInBoxcar( _wagon : CM_Wagon );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 March 2013	cnwndl1	Initial creation	Par 31278
10 Apr 2023 	navhl20 ChangeRequest 56628:[54992] EUP - Receive Cargo Form- Enhancement
*/

vars

begin

