    <JadeMethod name="archive" id="3620965c-e584-4328-8b2f-85a195a89d33">
        <updating/>
        <source>archive(_cmifArchiveVoy: CMIF_ArchiveVoyage; _passport: CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 Mar 2020 cnwma1 Bug 48863: JMT - Voyage Archive, Non Worked Cargo Issue

*/

vars
	objArray	   : ObjectArray;
	obj			   : Object;
	moveController : CMIF_MoveController;
	theMonitor     : CMIF_Monitor;
	tiArray        : CM_TIArray;
begin
	exclusiveLock(self);
	
	if _cmifArchiveVoy.myMonitor &lt;&gt; null then
		theMonitor := _cmifArchiveVoy.myMonitor;
	endif;
	
	//----------------------
	//Process each bayplan
	//----------------------
	if theMonitor &lt;&gt; null then
		theMonitor.updateProgress(app.getErrorString(ProcessingBayPlans) &amp; '...', null, null);
	endif;
	
	create moveController transient; //create once - used to unplan/unqueue TIs in slot
	create objArray       transient;
	create tiArray        transient;
	
	self.allLocationsByOrdinal.copy(objArray);
	foreach obj in objArray do
		if obj.isKindOf(CM_GeneralCargoController) then
			obj.CM_GeneralCargoController.archive(_cmifArchiveVoy, moveController,tiArray, _passport);
		endif;
	endforeach;
	
epilog
	delete moveController;
	delete objArray;
	delete tiArray;
end;
</source>
        <Parameter name="_cmifArchiveVoy" type="CMIF_ArchiveVoyage"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="convertToPopulateLocnDefnNames" id="fb532d7a-9825-4a62-bd72-48eb6fab547c">
        <source>convertToPopulateLocnDefnNames();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 July 2013	cnwndl1	Initial creation	Par 31965

*/

vars

	locCont : CM_GeneralCargoController;

begin

	foreach locCont in self.allLocationsByHatchPlace do
		if locCont.name = null then
			beginTransaction;
			locCont.convertToPopulateLocnDefnName();
			commitTransaction;
		endif;
	endforeach;

epilog

end;</source>
    </JadeMethod>
