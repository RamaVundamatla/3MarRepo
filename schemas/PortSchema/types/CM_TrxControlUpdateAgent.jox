	if params = null then
		app.raiseCMException2(MethodWithNullParam, method.name, "Attach Parameters", null, null);
	endif;
	if params.myTrackedItem = null then
		app.raiseCMException2(MethodWithNullParam, method.name, "Attach  Parameters: allTrackedItems", null, null);
	endif;	

	app.setContinueCMExceptions(false);
		
	beginTransaction;
