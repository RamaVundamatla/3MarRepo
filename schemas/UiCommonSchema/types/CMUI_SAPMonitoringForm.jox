    <JadeMethod name="includeObject" id="d16af76e-ee81-49d4-8ce3-d466094df6e8">
        <source>includeObject(	_inv : CM_Invoice;
				_localFromDate : TimeStamp;
				_localToDate : TimeStamp
				):Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 November 2018	jlgndl1	Initial creation	TFS 42116

*/

vars

	sapTrxDate : TimeStamp;

begin

	if _inv.paymentType = PaymentType_AutoCollection then
		if _inv.status &lt;&gt; CM_Invoice.INVOICE_POSTED then
			return false;
		endif;
		if _inv.paymentStatus &lt;&gt; CM_Invoice.INVOICE_PAYMENT_PAID then
			return false;
		endif;
	elseif _inv.paymentType = PaymentType_PostPay then
	//	if _inv.status &lt;&gt; CM_Invoice.INVOICE_PENDING then
		if _inv.status &lt;&gt; CM_Invoice.INVOICE_PENDING and _inv.status &lt;&gt; CM_Invoice.INVOICE_POSTED then	//09 Apr 2019	NDL	TFS 44192
			return false;
		endif;
	//	if _inv.paymentStatus &lt;&gt; CM_Invoice.INVOICE_PAYMENT_NOTPAID then
		if _inv.paymentStatus &lt;&gt; CM_Invoice.INVOICE_PAYMENT_NOTPAID and _inv.paymentStatus &lt;&gt; CM_Invoice.INVOICE_PAYMENT_PAID then	//11 Apr 2019	NDL	TFS 44192
			return false;
		endif;
	elseif _inv.paymentType = PaymentType_PrePay then
		//if _inv.status &lt;&gt; CM_Invoice.INVOICE_PENDING then
		if _inv.status &lt;&gt; CM_Invoice.INVOICE_PENDING and _inv.status &lt;&gt; CM_Invoice.INVOICE_POSTED then	//09 Apr 2019	NDL	TFS 44192
			return false;
		endif;
		if _inv.paymentStatus &lt;&gt; CM_Invoice.INVOICE_PAYMENT_PAID then
			return false;
		endif;
	else
		return false;
	endif;

	sapTrxDate := _inv.getSapTransactionDTLocalTZ();
	if sapTrxDate &lt; _localFromDate then
		return false;
	elseif sapTrxDate &gt; _localToDate then
		return false;
	endif;
	
	return true;

epilog

end;</source>
        <Parameter name="_inv" type="CM_Invoice"/>
        <Parameter name="_localFromDate" type="TimeStamp"/>
        <Parameter name="_localToDate" type="TimeStamp"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
