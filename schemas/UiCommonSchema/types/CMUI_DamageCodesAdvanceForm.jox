    <JadeMethod name="updateItem" id="5253de80-d70f-4d2c-af6e-351583ea38c8">
        <source>updateItem();
//----------------------------------------------------------------------
// Created by 	cnwsh3
// Date 		06 August 2009
//
// Implemented version: JMT 7.7.3
// Date  		User  		Change
// 06/08/2009 	cnwsh3 		CCMS SFW1066 PAR20321 - Recording Damage Details Changes.
// 06 July 2022	navak20	TFS 53862 EUP - WMS - Damage Recording Extra Details
// 31/08/2023	navcs2		Bug 60155: EUP | FR 54536 - Damage and Repair CAMS - Items found WP1
// 05 Feb 2025	navnk30		JIRA 33887: MTN | Road Gate In Checks throws error for damage check that is Inappropriate.
//----------------------------------------------------------------------
vars
	damageInstance : CM_DamageInstance;
	damagePosition 	: CM_DamagePosition;
	damageCode     	: CM_DamageDefinitionCode;			
	isNewDamage		: Boolean;
	quantity,
	idx 	 	   	: Integer; 
	severity		: CM_DamageSeverity;		// 11.07.2022 navak20 TFS 53862	//Change this when the CM_DamageSeverity class is created.  It will be CM_DamageSeverity object.
	
	damageRemarks			: String;			// July 6, 2022 navak20 TFS 53862
	damageStatus	: Integer;					// July 6, 2022 navak20 TFS 53862		
	damageResponsible : CM_DamageParty;			// July 6, 2022 navak20 TFS 53862
	damageLocation 	: CM_DamagePlace;			// July 6, 2022 navak20 TFS 53862
	damageSize		: String;					// July 6, 2022 navak20 TFS 53862
	damageReason 	: CM_DamageReason;			// July 6, 2022 navak20 TFS 53862
	damageDateTime		: TimeStamp;				// July 6, 2022 navak20 TFS 53862
	repairedReason	: CM_RepairReason;			// 06.07.2022 navak20 TFS 53862
	repairedRemarks	: String;					// 06.07.2022 navak20 TFS 53862
	repairedDateTime : TimeStamp;				// 06.07.2022 navak20 TFS 53862
	pxyTI				: CM_TrackedItem;
begin
	if self.mySelectedItem = null then
		app.msgBox('Please Select a Damage Entry', 'Select Item', 0);
		return;
	endif;
	
	damageInstance 	:= self.mySelectedItem;
	damagePosition 	:= self.cmbPosition.listObject.CM_DamagePosition;
	damageCode 		:= self.cmbDamage.listObject.CM_DamageDefinitionCode;
	quantity 		:= self.txtQuantity.text.Integer;
	isNewDamage		:= self.optYes.value;
	severity 		:= self.cmbSeverity.listObject.CM_DamageSeverity;		// 11.07.2022 navak20 TFS 53862

	damageRemarks := self.txtDamageRemarks.text;					// July 6, 2022 navak20 TFS 53862
	damageSize := self.txtSize.getConvertedValue().String;					// July 6, 2022 navak20 TFS 53862
	damageResponsible := self.cmbResponsible.listObject.CM_DamageParty;		// July 6, 2022 navak20 TFS 53862
	damageLocation := self.cmbLocation.listObject.CM_DamagePlace;			// July 6, 2022 navak20 TFS 53862
	damageStatus := app.damageStatusStringToEnum(self.cmbStatus.text);		// July 6, 2022 navak20 TFS 53862
	damageReason := self.cmbDamageReason.listObject.CM_DamageReason;		// July 6, 2022 navak20 TFS 53862
	damageDateTime.setDate(self.damageDate.getDate());							// July 6, 2022 navak20 TFS 53862
	damageDateTime.setTime(self.damageTime.getTime());							// July 6, 2022 navak20 TFS 53862
	repairedReason := self.cmbRepairedReason.listObject.CM_RepairReason;		// 08.07.2022 navak20 TFS 53862
	repairedRemarks := self.txtRepairedRemarks.text;							// 08.07.2022 navak20 TFS 53862
	repairedDateTime.setDate(self.repairedDate.getDate());					// 08.07.2022 navak20 TFS 53862
	repairedDateTime.setTime(self.repairedTime.getTime());					// 08.07.2022 navak20 TFS 53862
	
	if repairedDateTime &lt;&gt; null and  repairedDateTime &lt; damageDateTime then									// 31/08/2023	navcs2	Bug 60155
		app.raiseCMException(Repai_date_canno_befor_damage ,null, self);		// 31/08/2023	navcs2	Bug 60155
	endif;																		// 31/08/2023	navcs2	Bug 60155
	
	if repairedDateTime &gt; app.actualTimeServer() then
		app.raiseCMException(Repair_date_time_cannot_future, repairedDateTime.asStringJMT, null);
	endif;
	
	if self.myProxyMasterItem.isKindOf(CM_TrackedItem) then				//05.02.2025 navnk30 JIRA 33887
		pxyTI := self.myProxyMasterItem.CM_TrackedItem;
	endif;
	//damageInstance.setProxy(self.myProxyMasterItem.CM_TrackedItem, 	//05.02.2025 navnk30 JIRA 33887
	damageInstance.setProxy(pxyTI, 
							null, 
							damageCode, 
							damagePosition, 
							damageRemarks, 
							isNewDamage, 
							quantity, 
							severity,
							null,//_locationStr 	: String	01 Mar 2016	NDL	TFS 1593
							damageLocation, damageResponsible, damageReason, repairedReason, damageSize.Decimal, damageDateTime, damageStatus.Integer, repairedRemarks, repairedDateTime	//July 1, 2022 navak20 TFS 53862
							);
	//Update the entry in the data table.
	self.tblDamage.updateItemObject(damageInstance, self.colorRow1, self.colorRow2, app.myPassport);
epilog
	
end;</source>
    </JadeMethod>
</GUIClass>
