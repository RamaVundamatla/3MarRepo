    <JadeMethod name="getAuditText" id="7bcef2d0-8bd3-4811-8a16-50c5dfc83d5a">
        <source>getAuditText(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 December 2016	cnwma1	Initial creation

*/

vars
	txt,
	tmpStr	: String;

begin
	txt[10000] 	:= '*';
	txt 		:= null;
	txt 		:= inheritMethod();
	
	if self.getAccrualTypeDescription() &lt;&gt; null then
		tmpStr := self.getAccrualTypeDescription();
		txt := txt &amp; 'Accural Type' &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp;tmpStr &amp; AuditStringSeparator;
	endif;
	
	tmpStr := null;
	if self.myInvTermsOfTrade &lt;&gt; null then
		tmpStr :=self.myInvTermsOfTrade.description;
		txt := txt &amp;'Terms'&amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp;tmpStr &amp; AuditStringSeparator;
	endif;
	
	tmpStr := null;
	if self.invoiceKey =CM_InvoiceDesc.Key_None then
		tmpStr := app.getErrorString(None);
//		txt := txt &amp; 'Separate Invoice For' &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp;tmpStr &amp; AuditStringSeparator;
	elseif self.invoiceKey =CM_InvoiceDesc.Key_CargoItem then
		tmpStr := app.getErrorString(CargoItem_Name);
//		txt := txt &amp; 'Separate Invoice For' &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp;tmpStr &amp; AuditStringSeparator;
	elseif self.invoiceKey =CM_InvoiceDesc.Key_Voyage then
		tmpStr := app.getErrorString(Voyage);
//		txt := txt &amp; 'Separate Invoice For' &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp;tmpStr &amp; AuditStringSeparator;
	elseif self.invoiceKey =CM_InvoiceDesc.Key_VoyageGroup then // ### TFS 51219 25MAY2021 NAVAB1
		tmpStr := app.getErrorString(Voyage_group);
//		txt := txt &amp; 'Separate Invoice For' &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp;tmpStr &amp; AuditStringSeparator;
	else 
		tmpStr := app.getErrorString(BillOfLading);
//		txt := txt &amp; 'Separate Invoice For' &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp;tmpStr &amp; AuditStringSeparator;
	endif;

	txt := txt &amp; 'Separate Invoice For' &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp;tmpStr &amp; AuditStringSeparator;
	
	
	tmpStr := null;
	if self.invoiceType = InvoiceTypeStorage then
		tmpStr :="Yes";
		txt := txt &amp;'Is Storage Invoice (BGP Task)'&amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp;tmpStr &amp; AuditStringSeparator;
	else
		tmpStr := "No";
		txt := txt &amp;'Is Storage Invoice (BGP Task)'&amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp;tmpStr &amp; AuditStringSeparator;
	endif;
	
	tmpStr := null;
	if self.triggerOnAction = InvTypeTrigger_Release then
		tmpStr :=app.invTypeTriggerEnumToString( self.triggerOnAction );
		txt := txt &amp;'Trigger on Action'&amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp;tmpStr &amp; AuditStringSeparator;

	endif;
	
	tmpStr := null;
	if self.company &lt;&gt; null then
		tmpStr := self.company.mailingName;
		txt := txt &amp; app.getErrorString(CM_Business_Unit) &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp;tmpStr &amp; AuditStringSeparator;
	endif;
	
	tmpStr := null;
	if self.arrNarrationDesc.size&gt;0 then
		
		tmpStr := tmpStr &amp;arrNarrationDesc[1];
		tmpStr := tmpStr &amp;self.getDisplayStringNarr(2) &amp;CrLf;
		
		tmpStr := tmpStr &amp;arrNarrationDesc[3];
		tmpStr := tmpStr &amp;self.getDisplayStringNarr(4) &amp;CrLf;
		
		tmpStr := tmpStr &amp; arrNarrationDesc[5];
		tmpStr := tmpStr &amp; self.getDisplayStringNarr(6) &amp;CrLf;
		
		tmpStr := tmpStr &amp; arrNarrationDesc[7];
		tmpStr := tmpStr &amp; self.getDisplayStringNarr(8) &amp;CrLf;
		
		tmpStr := tmpStr &amp; arrNarrationDesc[9];
		tmpStr := tmpStr &amp; self.getDisplayStringNarr(10) &amp;CrLf;
		txt := txt &amp;'Narration'&amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp;tmpStr &amp; AuditStringSeparator;
	endif;
	return txt;
epilog

end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
