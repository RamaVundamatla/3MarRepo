    <JadeMethod name="set" id="dae94acb-5d8c-4123-949a-863adb666047">
        <updating/>
        <source>set(_method : JadeMethod; _property : Property; _parent : DEV_REOWsdlClass) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
13 May 2019		jlgmd1	Initial creation TFS 39667 - JMT - API Documentation

*/

vars
	size,
	idx			: Integer;
	signature	: String;
begin
	
	if _method &lt;&gt; null then
		// Our feature will be a method
		self.name := _method.name;
		
		// Now just getting the first line is a good idea in theory, but we have a tend to put large signatures over multiple lines... so we need to cater for that
		idx := 1;
		signature := _method.getSource().scanUntil(")", idx);
		signature := signature &amp; _method.getSource().scanUntil(";", idx) &amp; ";";
		self.signature := signature; 
	elseif _property &lt;&gt; null then
		// Our feature will be a property
		self.name := _property.name;
		self.type := _property.type.name;
		
		// Set the size to what we see in the IDE, not whats in the database
		size := _property.getLength();
		if size &gt; 0 then
			size := size - 1;
		endif;
		
		self.size := size;
		
	endif;
	
	self.myWSDLClass := _parent;
	
	self.updateMethodInputs();
epilog

end;</source>
        <Parameter name="_method" type="JadeMethod"/>
        <Parameter name="_property" type="Property"/>
        <Parameter name="_parent" type="DEV_REOWsdlClass"/>
    </JadeMethod>
