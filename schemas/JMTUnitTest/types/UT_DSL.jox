    <JadeMethod name="autoplanDischargeItems" id="3e0d0119-0d7e-4278-b88b-9f4517c092f9">
        <source>autoplanDischargeItems(_voyage : CM_Voyage; _terminalArea : CM_TerminalArea; _crane : CM_Crane);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 May 2011	cnwmh5	Initial creation

*/

vars
	jobSheet : CM_JobSheet;
	job:CM_Job;
	req : CM_Request;
	wle : CM_WorkListEntry;
	location : CM_LocationsController;
	trackedItem : CM_TrackedItem;
begin
	
	location := _terminalArea.allLocationsControllers.first;

	jobSheet := _voyage.allJobSheets[_crane.id];
	foreach job in _voyage.allVoyageJobs  discreteLock do
	
		// Discharge ONLY
		if not job.CM_VoyageJob.isDischarge then
			continue;
		endif;
		
		//### for each ti 
		foreach req in job.allRequests discreteLock do
			foreach wle in req.allWorkListEntries discreteLock do
				self.movePlannedWLE(wle.myTrackedItem, location, wle);
			endforeach;
		endforeach;
	endforeach;
	
	// CHECK DISCHARGE
	if not self.opts.includesKey("DontCheckHere") then
		foreach job in _voyage.allVoyageJobs  discreteLock do
		
			// Discharge ONLY
			if not job.CM_VoyageJob.isDischarge then
				continue;
			endif;
			
			foreach wle in job.workListEntries do
				trackedItem := wle.myTrackedItem;
				if trackedItem &lt;&gt; null then
					self.assertTrueMsg((trackedItem.myPrimaryPlannedLocation &lt;&gt; null), trackedItem.id &amp; " Did not plan discharge");
				endif;
				
			endforeach;
		endforeach;
	endif;
	
epilog
	
end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_terminalArea" type="CM_TerminalArea"/>
        <Parameter name="_crane" type="CM_Crane"/>
    </JadeMethod>
    <JadeMethod name="autoplanTIs" id="c6ec61ae-e5c9-464c-9db5-3dba91bb4bef">
        <source>autoplanTIs(_tiArray	: CM_TIArray);
/*
Purpose:			
Date		Who		Reason
23 September 2013	NAVAB1	Initial creation
*/

vars
	
	params : CMIF_AutoplanParams;
	moveMode : Integer;
	ignoreErrors : Boolean;
	
begin

	moveMode := PLANNING_MODE;
	if self.opts.includesKey("MoveMode") then	//20 Jun 2016	NDL	TFS 2172
		moveMode := self.opts.int("MoveMode");
	endif;
	if self.opts.includesKey("IgnoreErrors") then	//20 Jun 2016	NDL	TFS 2172
		ignoreErrors := self.opts.bool("IgnoreErrors");
	endif;

	create params transient;
	_tiArray.copy(params.allTrackedItems);
	params.moveMode := moveMode;
	params.myTerminalArea := null;
	params.showWarningWhenNoPlan := false;
	app.myTrxUA.trxUpdateAutoplanTrackedItems(params, app.myPassport);
	
	if not ignoreErrors then
		self.assertNoTrxErrorsOrWarnings();
	endif;

epilog
	delete params;
end;</source>
        <Parameter name="_tiArray" type="CM_TIArray"/>
    </JadeMethod>
    <JadeMethod name="autoplanWLE" id="379ce4ce-7644-4594-a9da-fe4c9144aa53">
        <source>autoplanWLE( _wle : CM_WorkListEntry);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
30 January 2013	cnwrd1	Initial creation

*/

vars
	wleArray,
	wlesWithWarnings	: CM_WLEArray;
begin
	create wleArray transient;
	create wlesWithWarnings transient;
	wleArray.add(_wle);

	app.myTrxUA.trxUpdateWLEsAutoplan(wleArray, wlesWithWarnings, QUEUE_MODE, app.myPassport);		
	
	self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());
epilog
	delete wleArray;
	delete wlesWithWarnings;
end;</source>
        <Parameter name="_wle" type="CM_WorkListEntry"/>
    </JadeMethod>
    <JadeMethod name="basicCreateCM_ToDoTaskDesc" id="397684e9-3a0c-4955-99a1-351cd4ca3721">
        <source>basicCreateCM_ToDoTaskDesc(_lDescription, 
							_sDescription			 : String;
							_trxTypeObjOnCompletion  : CM_TransactionType;
							_trxTypeObjOnCreation 	 : CM_TransactionType; //cnwrs1 CCMS 1826 29 July 2010
							_resourceType 			 : CM_ResourceType
							)						 :CM_ToDoTaskDesc protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
11 Jan 2010	cnwndl1	Initial creation	CCMS MES 1006
6/11/2019	JLGNS1	ChangeRequest 46721: PEN - CAMIR Message Processing
02/11/2022 	navds20 ChangeRequest 56635:[54261] EUP - Todo Task Resources Maintenance
*/

vars

	todo : CM_ToDoTaskDesc;
	proxy : CM_ToDoTaskDesc;
	real : CM_ToDoTaskDesc;
	lEmptyReportColumn : Integer;
	rtnValue : Boolean;

	
	lSortKey : Integer;
	lReportDescription : String;
	lShortDescription : String;
	
	selectedCargoTypes : ObjectArray;
	requiresWO    	   : Boolean;
	requiredExtraInfo    : String;
	selectedResourceTypes : CM_ObjectSet;	
	
begin

	foreach todo in app.myRoot.allToDoTaskDescriptions do
		if todo.description &lt;&gt; _lDescription then
			continue;
		endif;
		return todo;
	endforeach;
    
	lSortKey				:=	0;
	lReportDescription		:=	null;
	lShortDescription		:= _sDescription;
	
	if lShortDescription = null then
		lShortDescription		:=	"UT_Test";
	endif;
	
	requiresWO				:=  false;
	requiredExtraInfo       :=  "";

	create proxy transient;
		
	create selectedCargoTypes transient;
	selectedCargoTypes.add(app.myRoot.allCargoTypesById[ TI_CargoType_Container ]);
	create selectedResourceTypes transient;
	
	if _resourceType &lt;&gt; null then
		selectedResourceTypes.add(_resourceType);
	endif;

	proxy.setProxy(_lDescription, lShortDescription, lSortKey, lReportDescription, lEmptyReportColumn,
					_trxTypeObjOnCompletion, _trxTypeObjOnCreation, selectedCargoTypes, 
					selectedResourceTypes, requiresWO,requiredExtraInfo,
					null,null,TODO_TYPE_GROUP_TI,null,null,false);	//02/11/2022 navds20 TFS #56635[54261]
	
	app.myTrxCA.trxCreateToDoTaskDesc(proxy, real, app.myPassport);
	
	return real;
	
epilog

	delete selectedCargoTypes;
	delete selectedResourceTypes;
	delete proxy;
	
	
end;</source>
        <access>protected</access>
        <Parameter name="_lDescription" type="String"/>
        <Parameter name="_sDescription" type="String"/>
        <Parameter name="_trxTypeObjOnCompletion" type="CM_TransactionType"/>
        <Parameter name="_trxTypeObjOnCreation" type="CM_TransactionType"/>
        <Parameter name="_resourceType" type="CM_ResourceType"/>
        <ReturnType type="CM_ToDoTaskDesc"/>
    </JadeMethod>
    <JadeMethod name="calculateTerminalAreaStats" id="072f7db4-42ae-432f-8b40-68e80e781fcd">
        <source>calculateTerminalAreaStats(_ta: CM_TerminalArea);
//04 September 2008	cnwdw1	
//
vars
	termAreaSet : CM_TerminalAreaSet;
	yaBlockSet: CM_YABlockSet;
	oa: ObjectArray;
begin
	create termAreaSet transient;
	termAreaSet.add(_ta);
	create yaBlockSet transient;
	app.myTrxUA.trxCalcLocationStats(termAreaSet,yaBlockSet, oa, app.myPassport);
	self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());
epilog
	delete yaBlockSet;
	delete termAreaSet;
end;</source>
        <Parameter name="_ta" type="CM_TerminalArea"/>
    </JadeMethod>
    <JadeMethod name="calculateYABlockStats" id="14652069-e68a-4944-b85b-9f684ba3d04c">
        <source>calculateYABlockStats(_ya: CM_YardAllocation);
//04 September 2008	cnwdw1	
//
vars
	yaBlock: CM_YABlock;
	yaBlockSet: CM_YABlockSet;
	termAreaSet : CM_TerminalAreaSet;
	oa: ObjectArray;
begin
	create yaBlockSet transient;
	foreach yaBlock in _ya.allYABlocksIn do
			yaBlockSet.add(yaBlock);
	endforeach;
	create termAreaSet transient;
	app.myTrxUA.trxCalcLocationStats(termAreaSet, yaBlockSet, oa, app.myPassport);
	self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());
epilog
	delete yaBlockSet;
	delete termAreaSet;
end;</source>
        <Parameter name="_ya" type="CM_YardAllocation"/>
    </JadeMethod>
    <JadeMethod name="checkTIForTxnOfType" id="8dd03b10-90c9-46a6-a7cf-2355711d7f9a">
        <source>checkTIForTxnOfType(_ti : CM_TrackedItem; _txnType : Integer);

/*

Purpose:		Check ti for transaction types passed to it	

Date			Who		Reason
15/08/2012  	cnwmh5	Initial creation

*/

vars

	tiTransaction		: CM_TITransaction;
	msg					: String;
	
begin
	
	tiTransaction := _ti.getLastTransOfType(_txnType);
	if tiTransaction = null then
		msg := app.myRoot.allTransactionTypes[_txnType].description &amp; " transaction not created for " &amp; _ti.id;
	endif;
	self.assertNullMsg(msg, msg);

epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_txnType" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="checkTIsForTxnOfType" id="2655763b-a1c4-44df-8799-f5d20e4fdc2b">
        <source>checkTIsForTxnOfType(_tis : Collection; _txnType : Integer);

/*

Purpose:		Check tis for transaction types passed to it	

Date			Who		Reason
15/08/2012  	cnwmh5	Initial creation

*/

vars

	obj					: Object;
	ti					: CM_TrackedItem;
	
	iter				: Iterator;
	
begin
	
	iter := _tis.createIterator;
	while iter.next(obj) do
		ti := obj.CM_TrackedItem;
		self.checkTIForTxnOfType(ti, _txnType);
	endwhile;

epilog
	delete iter;
end;</source>
        <Parameter name="_tis" type="Collection"/>
        <Parameter name="_txnType" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="checkTrxResult" id="cd798795-4b1c-440c-8ad2-bc5e1c0e1e8d">
        <source>checkTrxResult();
//17 November 2008	cnwdw1	
// 05/08/2011 cwnmh5 Change to use class version of opts
// 13/08/2012 cnwmh5 Change to exit if Jade error found irrespective of whether self.IgnoreErrors is set
vars
	error : CM_Error;
begin
	foreach error in app.myPassport.allErrors do
		if error.errorCode &lt;= app.myRoot.baseErrorNum then
			self.assertTrueMsg(false, error.text);
			return;
		endif;	
	endforeach;
	
	if not self.opts.bool( self.IgnoreErrors ) then
		self.assertNoTrxErrorsOrWarnings();
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="checkVoyageMyVessel" id="bac29be5-3741-4941-800b-dd937716936c">
        <source>checkVoyageMyVessel(_voyage : CM_Voyage; _proxy : Boolean);

/*

Purpose:		Check that the created voyages myVessel is getting set correctly.  Currently have an issue where overnight it's not getting 
				updated correctly, but running it through the GUI and from a script it works.  So issue is overnight and this is for logging
				the details as it runs to see if there is a pattern.


Date			Who		Reason
20/June/2013	cnwmh5	Initial creation

*/

vars

	vessel 					: CM_Vessel;
	terminal				: CM_Terminal;

	terminalDtls			: String;
	myVesselDtls			: String;
	vesselDtls				: String;
	proxyDtls				: String;
	
begin

	terminalDtls := null;
	terminal := _voyage.getMyTerminal();
	if terminal &lt;&gt; null then
		terminalDtls := terminal.code &amp; Tab &amp; terminal.name;
	endif;
	
	myVesselDtls := null;
	if _voyage.myVessel &lt;&gt; null then
		myVesselDtls := _voyage.myVessel.code &amp; Tab &amp; _voyage.myVessel.name;
	endif;
	
	vesselDtls := null;
	vessel := app.myRoot.allVessels[_voyage.vesselCode];
	if vessel &lt;&gt; null then
		vesselDtls := vessel.code &amp; Tab &amp; vessel.name;
	endif;	
	
	if _proxy then
		proxyDtls := 'Proxy';
	else
		proxyDtls := "Real";
	endif;
	
//	app.writeLog(proxyDtls &amp; Tab &amp; "terminal: " &amp; Tab &amp; terminalDtls &amp; Tab &amp; 'voyage: ' &amp; _voyage.code &amp; Tab &amp; _voyage.description &amp; Tab &amp; 'voyage vessel: ' &amp; Tab &amp; 
//		_voyage.vesselCode &amp; Tab &amp; _voyage.vesselName &amp; Tab &amp; 'voyage myVessel: ' &amp; Tab &amp; myVesselDtls &amp; Tab &amp; "vessel: " &amp; Tab &amp; vesselDtls, LogINFO);
	

epilog

end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_proxy" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="cleanUpRail" id="fbf0e236-ddfe-47f9-b194-1861a8677564">
        <source>cleanUpRail(_wagonCode1: String;_wagonCode2 : String; _trainCode: String; _railAreaId: String) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 March 2020	jlgndl1	Initial creation	TFS 47004 - moved up from subclass

*/

vars

	wagonMaster	: CM_WagonMaster;

begin

	wagonMaster	:=	self.getRoot.allWagonMasters[_wagonCode1];
	if wagonMaster &lt;&gt; null then
		self.deleteWagonMasterAndWagons(wagonMaster);
	endif;
	
	if _wagonCode2&lt;&gt; null then
		wagonMaster	:=	self.getRoot.allWagonMasters[_wagonCode2]; // ### TFS 51219 18JUN2021 NAVAB1
		if wagonMaster &lt;&gt; null then
			self.deleteWagonMasterAndWagons(wagonMaster);
		endif;
	endif;
	
	self.deleteTrain(_trainCode, null);
	self.deleteRailArea(_railAreaId);

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_wagonCode1" type="String"/>
        <Parameter name="_wagonCode2" type="String"/>
        <Parameter name="_trainCode" type="String"/>
        <Parameter name="_railAreaId" type="String"/>
    </JadeMethod>
    <JadeMethod name="cleanupOfflineActors" id="9a130dd6-f0f3-476e-9a99-72c6bde0b8cd">
        <source>cleanupOfflineActors();
// call at either the start or end of processing to remove all CM_OfflineFutureActors with no-longer valid parents
vars
	root	: CM_Root;
	futureActor	: CM_OfflineFutureActor;
begin
	root := app.myRoot;

	beginTransaction;
	foreach futureActor in root.allOfflineFutureActors do
		if not global.isValidObject(futureActor.myParentObject) then
			delete futureActor;
		endif;
	endforeach;
	commitTransaction;
end;
</source>
    </JadeMethod>
