end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setRemarks" id="ce49f79d-2739-440b-a4d1-c82d69a4c366">
        <updating/>
        <source>setRemarks() updating;

vars

begin
	remarks := "Line " &amp; invoiceLine.sequenceNum.String &amp; " status changed to ";
	if newStatus = CM_InvoiceLine.STATUS_NORMAL then
		remarks := remarks &amp; "Normal";
	elseif newStatus = CM_InvoiceLine.STATUS_VOIDED then
		remarks := remarks &amp; "Void";
	endif;
end;</source>
    </JadeMethod>
</Class>
