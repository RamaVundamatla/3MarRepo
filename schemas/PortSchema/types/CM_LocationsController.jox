        <source>getTiTxnTypesForMoveFromToLC(_toController : CM_LocationsController; _intArray : IntegerArray input; _moveController : CMIF_MoveController);
// ---------------------------------------------------------------------------
// Created:     06 January 2004 by cnwrs2
//
// Purpose:     Setup the transactions to be added for a move from this location to
//				another LC.  In most cases we should put the transactions in the
//				method getTiTxnTypesForMoveToFromLC but we need this so that
//				Wellington can specify specific transactions from moves from some
//				of their own LC classes to JMT classes
// ---------------------------------------------------------------------------
vars

begin

end;</source>
