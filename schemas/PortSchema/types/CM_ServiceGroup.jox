	inheritMethod(_pxyService);

end;</source>
        <Parameter name="_pxyService" type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="shouldAuditProperty" id="ca5853d8-1b19-4d09-9ff2-85538517ff22">
        <source>shouldAuditProperty(_rootClass: Class; _property: Property): Boolean protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 December 2016	cnwma1	Initial creation

*/

vars
		propName	: String;
begin
	if _property = null then
		return false;
	endif;
	
	propName := _property.name;
	
	if	propName = CM_ServiceGroup::myChildQuantityMap.name or
		propName = CM_ServiceGroup::myTaxCode.name
		then
		return false;
	else
		return inheritMethod(_rootClass, _property);
	endif;
	


end;</source>
        <access>protected</access>
        <Parameter name="_rootClass" type="Class"/>
        <Parameter name="_property" type="Property"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateDuplicates" id="8e13ac14-7b63-49ee-b640-9ff50c5f840e">
        <source>validateDuplicates();
// ---------------------------------------------------------------------------
// Created:		24 July 2007 By Andrew Bishop cnwab1
//
// Purpose:		
// 08/12/2014   cnwdb2	PAR #35364
// 07/05/2017 	cnwrh7  TFS4689       #STWO - Load Services Issue
// ---------------------------------------------------------------------------
vars
	duplicateMe : CM_ServiceObject;
begin
	duplicateMe := self.bank.serviceObjects[self.name];
	
	if duplicateMe &lt;&gt; null and duplicateMe &lt;&gt; self then
	//	if duplicateMe.group = self.group  then																																																//-TFS4689  Only Allow One Group no matter where
		//	app.raiseCMException3(ERR_DUPLICATE_KEY,"Service",self.name,"Within the same group '" &amp;duplicateMe.group.name &amp; "'." ,null,null);
			app.raiseCMException2(Already_exists_service_smeGrp,self.name,duplicateMe.group.name ,null,null); // cnwdb2 PAR 35364
	endif;

end;</source>
    </JadeMethod>
</Class>
