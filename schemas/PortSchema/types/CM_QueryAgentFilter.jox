/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 June 2021	navndl1	Initial creation	TFS 51245

*/

vars

	numSelected : Integer;
	jrwTrans : CM_JRWLocationActivity;
	
begin


	on CM_BreakOutException do self.xHandlerBreakOut(exception);
	
	jrwTrans := self.createJRWTransient(CM_JRWLocationActivity).CM_JRWLocationActivity;
	
	_filter.populateFromLocActivities( true );
	
	numSelected := _filter.allCMIFLocationInventoryLines.size; 
	
	if not _filter.allCMIFLocationInventoryLines.isEmpty then
