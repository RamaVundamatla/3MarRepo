    <JadeMethod name="doFilterTable" id="47cfb6da-41b5-4218-9d00-8cdf127105d8">
        <source>doFilterTable();
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
21 July 2025		jlizm1	Initial creation MTN 35281 Add filter to merge cargo form

*/

vars
	filterText 	: String;
	rowIdx		: Integer;
	start		: Integer;
	obj 		: Object;
	idStr		: String;
	
begin

	filterText := self.frmTableFilter.txtFilterBox.text.toUpper();
	self.tblTargets.clearAllSelected();
	
	if (filterText = "") then
		self.frmTableFilter.btnClearFilter.enabled := false;
		self.tblTargets.topRow := 1;
		return;
	else
		self.frmTableFilter.btnClearFilter.enabled := true;
	endif;
	
	start := self.tblTargets.fixedRows + 1;
	
	foreach rowIdx in start to self.tblTargets.rows do
		obj := self.tblTargets.accessRow(rowIdx).itemObject;
		if obj &lt;&gt; null then
			idStr := obj.CM_TrackedItem.id.toUpper;
		else
			idStr := null;
		endif;
		
		if idStr.length &gt; 0 and idStr.pos(filterText, 1) &gt; 0 then
			self.tblTargets.accessedRow.visible := true;
		else
			self.tblTargets.accessedRow.visible := false;
		endif;	
	endforeach;
	
	self.tblTargets.topRow := 1;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doOK" id="e4a41a8a-49c4-4405-8a2d-8ac24c5f01d3">
        <updating/>
        <source>doOK() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 May 2013	cnwndl1	Initial creation	CCMS 2274 Break Bulk

*/

vars

begin

	if not self.mergeBreakBulk() then
		return;
	endif;
	
	inheritMethod();

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doResize" id="42bdd980-cdb5-40ee-9f28-e0f59c93f11d">
        <updating/>
        <source>doResize() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 May 2013	cnwndl1	Initial creation	CCMS 2274 Break Bulk

*/

vars

begin

	self.grpMain.top := 1;
	self.grpMain.left := 1;

	// 33643 allow resize so that the cargo id in the table header shows OK
	self.grpMain.width := self.width - 20;
	self.grpMain.height  := self.height - 80;
	
	inheritMethod();

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="mergeBreakBulk" id="8596bea5-487a-4808-8768-a1b04bb02aa8">
        <updating/>
        <source>mergeBreakBulk():Boolean protected, updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 May 2013	cnwndl1	Initial creation	CCMS 2274 Break Bulk

*/

vars

	allTisToMerge : CM_TISet;
	theReturn : Integer;

begin

	create allTisToMerge transient;
	if not self.validate( allTisToMerge ) then
		return false;
	endif;
	
	while true do 
	
		app.myTrxUA.trxMergeBreakBulk(	self.myTrackedItem.CM_Cargo,	//_targetTi : CM_BreakBulkGeneric;
										allTisToMerge,	//_allItemsToBeMerged : CM_TISet;
										app.myPassport	//_passport : CM_Passport input
										);
	
		
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			global.beep;		// 33643 add confirmation if OK
			self.clearErrorWarnings();
			break;
			
		else
			theReturn := app.showErrorWarningDialog(app.getErrorString(Merge_breakbulk), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			return false;
		endif;
		break;
		
	endwhile;

	return true;

epilog

	delete allTisToMerge;

end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="populateTblTargets" id="58077dd5-c8f4-47c1-b868-21be1b593133">
        <updating/>
        <source>populateTblTargets()updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 May 2013	cnwndl1	Initial creation	CCMS 2274 Break Bulk
05/03/2015	cnwmh5	Transient Leak
01/05/2023	jlizm1	TFS 55453 Cargo uniqueness by subtype

*/

vars

	iter : Iterator;
	ti : CM_TrackedItem;
	startObject : Object;
	cargoType : Integer;
	operator : CM_Operator;
	location : CM_LocationsController;
	allTis : CM_TIArray;
	msg, tblString : String;
	index : Integer;
	showWeight : Boolean;
	uniqueBySubtype : Boolean;
	subtype : String;
	
begin

	create allTis transient;

	if self.myTrackedItem &lt;&gt; null
	and self.myTrackedItem.myCargoType &lt;&gt; null
	and self.myTrackedItem.myCargoType.allowDuplicates
	then

		cargoType := self.myTrackedItem.cargoType;
		operator := self.myTrackedItem.myOperator;
		location := self.myTrackedItem.myPrimaryActualLocation;
		subtype := self.myTrackedItem.getCargoSubTypeCode;
		uniqueBySubtype := self.myTrackedItem.myCargoType.useCargoSubtypeForUniqueness;
		startObject := self.myTerminal.allOnsiteTIsByCargoTypeId.getAtKeyGeq( cargoType,null);
		
		if startObject &lt;&gt; null then
			iter := self.myTerminal.allOnsiteTIsByCargoTypeId.createIterator;
			iter.startAtObject( startObject );
			while iter.next( ti ) do
				if ti.cargoType &lt;&gt; cargoType then
					break;
				endif;
				if ti = self.myTrackedItem then
					continue;
				endif;
				if ti.myOperator &lt;&gt; operator then
					continue;
				endif;
				if ti.myPrimaryActualLocation &lt;&gt; location then
					continue;
				endif;
				if ti.isBulkByQuantity and ti.totalQuantity &lt; 1 then
					continue;
				endif;
				if (ti.isBulkByVolume or ti.isBulkByWeight) and ti.totalWeight = 0 then
					continue;
				endif;
				if uniqueBySubtype and ti.getCargoSubTypeCode &lt;&gt; subtype then
					continue;
				endif;
				
				allTis.add(ti);
			endwhile;
			delete iter;
		endif;
	
	endif;
	
	if allTis.isEmpty then
		msg := app.getErrorString(No_Match_break_bulk_for_merge);
		app.msgBox(msg,app.getErrorString(Error),MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
		self.unloadForm();
		return;
	endif;
	
	//epr CCMS 1366 7/4/14
	showWeight:=(self.myTrackedItem.isBulkByWeight or self.myTrackedItem.isBulkByVolume);
	
	self.tblTargets.clear();
	self.tblTargets.fixedColumns := 0;
	self.tblTargets.columns := 1;
	self.tblTargets.rows := 1;
	self.tblTargets.fixedRows := 1;
	self.tblTargets.selectMode := Table.SelectMode_Default;
	self.tblTargets.setCellText(1,1,app.getErrorString1(Select_cargo_to_merge_into, self.myTrackedItem.id));
	self.tblTargets.accessCell(1,1).fontBold := true;
	

	
	foreach ti in allTis do
		tblString:=ti.id;
		if showWeight then
			tblString:=tblString &amp;  " (" &amp; ti.myCargoType.getBulkTrackByDisplayForWeight( ti.totalWeight, ti.getDensity, true) &amp; ")";
		else
			tblString:=tblString &amp; " (" &amp; ti.totalQuantity.String &amp; ")";
		endif;
		index := self.tblTargets.addItem(tblString);
		self.tblTargets.accessRow(index).itemObject := ti;
	endforeach;

epilog

	delete iter;
	delete allTis;

end;</source>
    </JadeMethod>
    <JadeMethod name="setMyTrackedItem" id="4b767c84-00c3-4e5a-a276-4e4900ca4203">
        <updating/>
        <source>setMyTrackedItem( _ti : CM_TrackedItem ):Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 May 2013	cnwndl1	Initial creation	CCMS 2274 Break Bulk

*/

vars

	msg : String;

begin

	self.myTrackedItem := _ti;
	
	if _ti &lt;&gt; null and _ti.canMergeBreakBulk then
		self.lblExistingCargo.caption := _ti.id &amp; " (" &amp; _ti.totalQuantity.String &amp; ")";
		return true;
		
	else
		self.lblExistingCargo.caption := null;
		if _ti = null then
			msg := app.getErrorString(No_Cargo_selected);
		else
			msg := app.getErrorString(No_merge_cargo_not_BB);
		endif;
		app.msgBox(msg,app.getErrorString(Error),MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
		self.unloadForm();
		return false;
		
	endif;

epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="f148c6f8-ff3b-4f92-ad82-a696613d36ee">
        <updating/>
        <source>setupForm() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 May 2013	cnwndl1	Initial creation	CCMS 2274 Break Bulk
21 Jul 2025	jlizm1	MTN 35281 Add filter to merge cargo form

*/

vars

begin

	inheritMethod();
	
	self.populateTblTargets();
	
	self.frmTableFilter.setupControl(self.tblTargets, null);
	self.frmTableFilter.zOrder(1);
	self.frmTableFilter.setCallbackMethod(CMUI_MergeBreakBulkForm::doFilterTable.name);
	self.frmTableFilter.setSkipControlFilter(true);

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="fa2c185b-dcb7-4d71-b03d-d55b14ede9d9">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 27 May 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0019087, locale);
	lblExistingCargo.translateCaption(Xlat_0019088, locale);
end;</source>
    </JadeMethod>
    <JadeMethod name="validate" id="fb8e5127-aaa8-4064-8a8d-12480d036dc9">
        <source>validate( _allTisToMerge : CM_TISet input):Boolean protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 May 2013	cnwndl1	Initial creation	CCMS 2274 Break Bulk

*/

vars

	index : Integer;
	msg : String;
	jadeRow : JadeTableRow;
	ti : CM_TrackedItem;

begin

	foreach index in 1 to self.tblTargets.rows do
		jadeRow := self.tblTargets.accessRow(index);
		if jadeRow.selected then
			ti := jadeRow.itemObject.CM_TrackedItem;
			if ti &lt;&gt; null then
				_allTisToMerge.add(ti);
			endif;
		endif;
	endforeach;

	if _allTisToMerge.isEmpty then
		msg := app.getErrorString(CMUI_Nothing_Selected);
		app.msgBox(msg,app.getErrorString(Error),MsgBox_OK_Only);
		return false;
	endif;
	
	return true;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_allTisToMerge" type="CM_TISet" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</GUIClass>
