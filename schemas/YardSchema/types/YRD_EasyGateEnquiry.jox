    <JadeMethod name="getResultSet" id="47de6b8f-3e62-4dbb-a8f9-89b7b389e2dc">
        <updating/>
        <source>getResultSet(_iterator : Iterator input; 
			 _operator : CM_Operator; 
			 _cargoID : String; 
			 _vehicleID : String;
			 _startTimestamp : TimeStamp; 
			 _objectSet : CM_ObjectSetActual io;
			 _interTermMove : CM_InterTerminalMove input) updating;
/*

Purpose:			iterates through collection and selects matching objects

Parameters:			

Return Value:		


Date				Who		Reason
19 February 2010	conkc1	Initial creation

*/
vars
	interTermMove  : CM_InterTerminalMove;
	endTimestamp   : TimeStamp;
begin

//	endTimestamp.setDate(vToDate);
//	endTimestamp.setTime('23:59:59.99'.Time);
	endTimestamp := self.localToSystemTime((vToDate + 1).TimeStamp);	// 5/5/16 cnwmp6 TFS 488 - Multi timezone support

	_iterator.startAtObject(_interTermMove);
	while _iterator.next(interTermMove) do

		if interTermMove.vehiclePickupDT &gt;= endTimestamp then
			break;
		endif;

		if matchCriteria(interTermMove, _operator, _cargoID, _vehicleID) = true then
			if _objectSet.includes(interTermMove) = false then
				_objectSet.add(interTermMove);
			endif;
		endif;

	endwhile;
epilog

end;</source>
        <Parameter name="_iterator" type="Iterator" usage="input"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_cargoID" type="String"/>
        <Parameter name="_vehicleID" type="String"/>
        <Parameter name="_startTimestamp" type="TimeStamp"/>
        <Parameter name="_objectSet" type="CM_ObjectSetActual" usage="io"/>
        <Parameter name="_interTermMove" type="CM_InterTerminalMove" usage="input"/>
    </JadeMethod>
