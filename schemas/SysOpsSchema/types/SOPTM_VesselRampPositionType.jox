    <JadeMethod name="doSave" id="bf8c01db-c494-4399-a5ec-86b4f24f12c6">
        <updating/>
        <source>doSave(): Boolean updating;
/*
Date		    Who			Reason
11 April 2011	cnwas3	  Initial creation: CCMS 1031
*/


vars
	proxyRampPositionType	: CM_VesselRampPositionType;
	theForm 				: SOP_TableMaintForm;	
	code,
	description,
	remarks,
	contentType 			: String;
	isAvailableForEntry : Boolean;
begin
  	theForm 				:= self.myForm;   	
	code					:=	theForm.tblInput1.getValueByName(ETRow_Code).String;
	description 			:=	theForm.tblInput1.getValueByName(ETRow_Description).String;
	remarks 				:= theForm.tblInput1.getValueByName(ETRow_Remarks).String;
	isAvailableForEntry	:=	theForm.tblInput1.getValueByName(ETRow_IsAvailableForEntry).Boolean;
  	
	if theForm.myProxyObject = null then
		if theForm.mode = theForm.Mode_Add then
			create theForm.myProxyObject as CM_VesselRampPositionType transient;
		else
			app.raiseUnexpectedProgramError(class.name, method.name, 'Proxy object is null for update');
			return false;
		endif;
	endif;
	
	proxyRampPositionType := theForm.myProxyObject.CM_VesselRampPositionType;
	proxyRampPositionType.setProxyForRampPositionType(code,description,remarks,isAvailableForEntry,app.myRoot);
	
	
	if theForm.mode = theForm.Mode_Add then
		app.myTrxCA.trxCreateVesselRampPosType(proxyRampPositionType, theForm.myCurrentObject, app.myPassport);
	elseif theForm.mode = theForm.Mode_Update then
		app.myTrxUA.trxUpdateVesselRampPosType(proxyRampPositionType, app.myPassport);
	else
		app.raiseUnexpectedProgramError(class.name, method.name, '  Invalid mode (' &amp; theForm.mode.String &amp; ')');
		return false;
	endif;
	return app.myPassport.trxCompletedOK();
	
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
