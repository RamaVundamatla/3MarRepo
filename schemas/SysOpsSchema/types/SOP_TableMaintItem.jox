	if	localButton &lt;&gt; null then
		localButton.visible := false;
	endif;
	form.tblCheckItems.parent := form.shtSingleSelect1;	// ccms 1071 cnwdap1 10/02/2010
	form.tblCheckItems.visible := false;						// ccms 1071 cnwdap1 10/02/2010
	
	form.cmbMul7.visible:=false;
