<Class name="CM_EDIFileTypeX12EDI3014010" id="b5943c05-6e29-4bc3-b1bc-1e549bd2a1f2">
    <superclass name="CM_EDIFileTypeX12EDI301"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="edi"/>
    <JadeMethod name="create" id="3e94b53e-2b74-44e5-9aa0-44e2c1eaf7b9">
        <updating/>
        <source>create() updating;
//
//  Created by cnwrs1 May 2008
//
vars

begin
	self.name := "X12 301 - Confirmation (Ocean)";
	self.type := EDIFileTypeX12_301_4010;
end;</source>
    </JadeMethod>
    <JadeMethod name="findEDIDataType" id="b7eea959-f982-4fc9-a819-c6cfd0ba68f0">
        <source>findEDIDataType(_ediDataClass: Class io; _dataType, _fileTypeCode: Integer io); // cnwrs1 Par 24207 ccms 1117 11 May 2010
//
//  Created by cnwrs1 May 2008
// cnwrd1 ccms 2317 changed to CM_EDIDataBooking and EDIDataType_BookingMultiLine
// 23 Apr 2018	jlgrs1	TFS 8296 add release req and prenotes to X12 301
vars

begin
//	_ediDataClass := CM_EDIDataBooking;
//	_dataType := EDIDataType_BookingMultiLine; 
	_ediDataClass := CM_EDIDataGateDoc;
	_dataType := EDIDataType_GateDocument; 
	_fileTypeCode := self.type;
end;</source>
        <Parameter name="_ediDataClass" type="Class" usage="io"/>
        <Parameter name="_dataType" type="Integer" usage="io"/>
        <Parameter name="_fileTypeCode" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getEDIPartyRules" id="5672b6d5-bed1-44c1-b5e5-7cd7db613766">
        <source>getEDIPartyRules(_ediParty: CM_EDIParty): CM_EDIPartyRules protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 June 2015	cnwma1	Initial creation

*/

vars

begin
	if _ediParty = null then
		return null;
	endif;
	
	return _ediParty.getRulesForFileType (EDIFileTypeX12_301_4010);

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_ediParty" type="CM_EDIParty"/>
        <ReturnType type="CM_EDIPartyRules"/>
    </JadeMethod>
    <JadeMethod name="getUseN1SH" id="7e706821-642b-4f0b-86e7-d12b76e916a9">
        <source>getUseN1SH(_operatorCode : String) : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 June 2015	cnwma1	Initial creation

*/

vars
	useN1Sh 			: Boolean;
	senderParty			: CM_EDIParty;
	senderPartyRules 	: CM_EDIPartyRules;	
	terminal 			: CM_Terminal;
begin	
	terminal 		:= app.myPassport.myTerminal;
	
	if _operatorCode &lt;&gt; null and terminal &lt;&gt; null then
        senderParty := terminal.allEDIPartiesBySenderCode[_operatorCode];

		if senderParty &lt;&gt; null then
			senderPartyRules 	:= self.getEDIPartyRules (senderParty);
		endif;
		
		
		if senderPartyRules &lt;&gt; null and senderPartyRules.isKindOf(CM_EDIPartyX12301Rules) then  
			useN1Sh := senderPartyRules.CM_EDIPartyX12301Rules.useN1SH;			
		endif;
				
	endif;

	return useN1Sh;
epilog

end;</source>
        <Parameter name="_operatorCode" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getXlatedVoyageCode" id="f95cf0c3-10b6-4bac-b897-b48dc2bc3df6">
        <source>getXlatedVoyageCode(	_operator : CM_Operator; 
						_voyCode : String;
						_vesselValue : String;
						_lloydsNumber : String;
						_callSign : String
						):String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 Apr 2016	cnwndl1	Initial creation	TFS 1801
21 Aug 2018	jlggb1	TFS 40081 Penn Booking translations going to an Inwards voyage translation
*/

vars
	
	vesselCode : String;
	foundMatch : Boolean;
	vessel : CM_Vessel;
	vesselName : String;
	returnVoyageCode : String;

begin

	if _operator = null then
		returnVoyageCode :=  _voyCode.trimBlanks[1:30];
		return returnVoyageCode;
	else
		vesselCode := _operator.getXlationSystemCode(_vesselValue, XLATION_TYPE_VESSEL_BYOP, foundMatch);
	endif;
	if not foundMatch then	
		vessel := app.myRoot.allVesselsByName[_vesselValue];
	else
		vessel := app.myRoot.allVessels[vesselCode];
	endif;
	if vessel &lt;&gt; null then
		vesselName := vessel.name;
	endif;
	
	returnVoyageCode := _operator.getXlationSystemCode_VoyageEx(_voyCode, vesselName, _lloydsNumber, _callSign, 1, foundMatch);				
	
	return returnVoyageCode;
	
epilog

end;</source>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_voyCode" type="String"/>
        <Parameter name="_vesselValue" type="String"/>
        <Parameter name="_lloydsNumber" type="String"/>
        <Parameter name="_callSign" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="processFile" id="79223b4f-d928-4968-8759-28894701ef22">
        <updating/>
        <source>processFile(_ediFile : CM_EDIFile input) updating, protected;
//
//  Created by cnwrs1 May 2008
//
// 07 Mar 2013	cnwcs5	CCMS POL 2097 / par 31259 - commodity xlations
// 29/01/2014 	cnwrd1 CCMS 2317 DPH change for multi line booking 
//cnwrd1 ccms 2317 par 33539
//12 Jan 2015	cnwrs1	Par 35504 - Refactor EDI file ad for .NET
//03 Mar 2015   cnwma1  PAR #35779 1035 in CM_EDIFileTypeX12EDI3014010::processFile
//03 Jul 2015 	cnwma1  PAR #36337  CCMS 2502 TFS 375  DPH - Consignor in the N1*SH
//10 Sep 2015	cnwrs1	Par 32883 - EDI File Type sequence number
//24 Sep 2015   cnwma1  PAR #36904  ISO Type - (EDI X12 301 Y4 segment) not showing in Jade (Seaboard)
//01 Oct 2015   cnwma1	PAR #36917 Missing EDI 301 File
//08 Oct 2015	cnwrs1	Par 36863 - make EDI consistant times when refreshing progress bar
// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
// 04 Aug 2016	cnwrs1	Par 38117 make deleted EDI for finable
// 01 Sep 2016	cnwrs1	TFS 2609 change to handle multiple bookings per file
// 27 Apr 2018	jlgrs1	TFS 8296 add release req and prenotes to X12 301
// 01 May 2018	jlgrs1	TFS 38321 add commodity details to prenotes
// 08 May 2018	jlgrs1	TFS 36425 SingleLine Booking partial processing not working
// 08 Aug 2018	jlgrh7 TFS 39646 PEN - FW: Crowley Bookings - for multiple REEF commodities but Jade is showing a commodity of GEN.
// 18 Jan 2019	jlgrs1	TFS 41659 42276 STWR Make EDI MultiThreaded Stage 8
// 08 Apr 2019	jlgrs1	TFS 41913 STWR - Reconfiguration of the EDI Operation form to better handle EDI collection locks while loading
// 17 May 2019	jlgzm1	TFS 44770 1090 errors from loading 'Delete' messages
// 25/07/2019 	JLGNS1	Bug 45796: PEN - Cargo Remarks in Release Request via X12 301 edi file
// 19/4/2024	jlier1 TFS  63253 - Temperatures not loading if set before LX loop -  Booking ISO Type not set. Prenotes default weight to ISOType tare weight if no weight in file. Prenote not getting the correct prenote.
// 23 Jun 2025	navnk30	JIRA 34167: PEN - Some bookings coming in correctly with size, others not
constants
	ProgressBarRefresh	: Integer = 2000;	
	SeaFreight 	= 'SFL';
	SeaFreight2 = "SEAF";
vars
	msgHelper			: CMIF_EDIX12Helper;
	ediTI : CM_EDITrackedItem;
	ediBookingItemTI : CM_EDIBookingItemTI;
	ediBookingHeaderTI : CM_EDIBookingHeaderTI;
	passport			: CM_Passport;
	operatorOid			: CM_Operator;
	aCommodity			: CM_Commodity;
	untCount			: Integer;
	bookingNo			: String;
	numMsgs				: Integer;
	msgCount			: Integer;
	lineStr				: String;
	fileID				: String;
	message				: String;
	currentTag			: String;
	operatorCode		: String;
	lloydsNumber		: String;
	callSign			: String;
	haz					: String;
	undg				: String;
	mtCmdty				: String;
	defCmdty			: String;
	refCmdty			: String;
	hazCmdty			: String;
	actionStr			: String;
	isoType				: String;
	opCode				: String;
	freightForwarder	: String;
	numTI				: Integer;
	ediID				: String;
	consignor			: String;
	consignee			: String;
	dischPort			: String;
	destPort			: String;
	loadPort			: String;
	remarks				: String;
	ediweight			: Integer;
	length				: Integer;
	width				: Integer;
	height				: Integer;
	volume				: Decimal[20,3];
	commodDesc			: String;
	commod				: String;
	voyCode				: String;
	vessCode			: String;
	hazCodes			: StringArray;
	foundMatch			: Boolean;
	seaFreightProcessing : Boolean;
	y4Loop				: Boolean;
	lxLoop				: Boolean;
	atmosHumidity 		: String;
	atmosVent 			: String;
	messMode 			: String;
	portCodeString		: String;
	portDescString		: String;
	aPort 				: CM_Port;
	quantity 			: String;
	packageType 		: String;
	unitQualifier		: String;
	theLines : HugeStringArray;
	useN1SH	  			: Boolean;
	ediRequestHeaderTI : CM_EDIRequestHeaderTI;
	ediRequestItemTI : CM_EDIRequestDetailTI;
	ediPrenoteTI : CM_EDIPrenoteTI;
	ediPrenotes : CM_EDITIById;
	allST_EDI_Tis : CM_EDITIById;
	isoTypeObj : CM_ISOType;
	temperature : Real;
	date : Date;
	time : Time;
	str : String;
	creationTS : TimeStamp;
	sequence : String;
	sender : String;
	recipient : String;
	sequenceNumber : Integer;
	progressInt	: TimeStampInterval;
	progressTS : TimeStamp;
	ediPartyRules : CM_EDIPartyX12301Rules;
	useEDIDataGateDoc : Boolean;
	ediData : CM_EDIData;
	cargoID : String;
	cargoPrefix : String;
	ediHazDets : CM_EDIHazDetailsTI;
	hazDescription : String;
	
	r4Loop : Boolean;									//+TFS39646Starts
	setTemperature : Real;
	defHeaderTemperature : Real;
	itemTemperature : Real;
	tempeArray : RealArray;
	processedTINum  : Integer;
	isoTypeArray : StringArray;
	itemISOType : String;
begin
	processedTINum := 1;
	progressTS := app.actualTimeServer();// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	create hazCodes transient;
	create ediPrenotes transient;
	create allST_EDI_Tis transient;
	create isoTypeArray transient;
	create tempeArray  transient;	
	temperature := NULL_TEMPERATURE;
	passport := app.myPassport;
	if passport.myTerminal.getConfig(EdiBookingCommodity).Boolean then
		app.getTerminalDefCmdty(mtCmdty, defCmdty, refCmdty, hazCmdty);
	endif;
	ediData := _ediFile.ediData;
//	ediDataBookingRef := _ediFile.ediData.CM_EDIDataBooking;
	fileID := _ediFile.fileName.getFileName();       
	
	create msgHelper transient;
	msgHelper.setEDIFile(_ediFile);
	
	create theLines transient;
	self.rawDataToHSA(_ediFile, theLines);
	numMsgs	:= theLines.size;
	foreach lineStr in theLines do
		msgCount	:=	msgCount + 1;
		progressInt := app.actualTimeServer() - progressTS;// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		if passport.myCMIFMonitor &lt;&gt; null  and (progressInt.getMilliseconds &gt;= ProgressBarRefresh) then
			passport.myCMIFMonitor.updateProgressWithCaption("Processing File Data", numMsgs, msgCount, "Loading EDI file Step 3 of 3.");
			progressTS := app.actualTimeServer();// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		endif;
		msgHelper.setNextMessage(lineStr);	//set the current message
		message := msgHelper.currentMessage;
		currentTag := msgHelper.currentTag;
//write class.name&amp;'::'&amp;method.name&amp;' '&amp;currentTag;
		if currentTag = "ISA" then
			untCount := untCount + 1;
			msgHelper.setNextField(); //i01
			msgHelper.setNextField(); //i02
			msgHelper.setNextField(); //i03
			msgHelper.setNextField(); //i04
			msgHelper.setNextField(); //i05
			msgHelper.setNextField(); //i06
			sender := msgHelper.currentSubItem;
			ediPartyRules := self.getTheEDIPartRules(sender).CM_EDIPartyX12301Rules;
			if ediPartyRules &lt;&gt; null then
				useEDIDataGateDoc := ediPartyRules.getX12301EDIDataStyle;
			endif;
			useEDIDataGateDoc := true;
			seaFreightProcessing := false;
			msgHelper.setNextField(); //i07
			msgHelper.setNextField(); //i08
			recipient := msgHelper.currentSubItem;
			msgHelper.setNextField(); //i09
			str := msgHelper.currentSubItem;
			date.setDate(str[5:2].Integer, str[3:2].Integer, str[1:2].Integer); 
			msgHelper.setNextField(); //i10
			str := msgHelper.currentSubItem;
			time.setTime(str[1:2].Integer, str[3:2].Integer, 0, 0);
			creationTS.setDate(date);
			creationTS.setTime(time);
			msgHelper.setNextField(); //i11
			msgHelper.setNextField(); //i12
			msgHelper.setNextField(); //i13
			sequence := msgHelper.currentSubItem;
			sequenceNumber := sequence.Integer; // Interchange Control Number
			if _ediFile.ediData.status &lt;&gt; CM_EDIFile.EDI_STATUS_OUTOFSEQUENCE and
			   not self.processSenderRecipientSeq(sender, recipient, "X12-301", "", _ediFile.ediData.fileName, creationTS, sequence, _ediFile.ediData, passport.myTerminal) then
				ediData.status := CM_EDIFile.EDI_STATUS_OUTOFSEQUENCE;
			endif;
		elseif currentTag = "GS" then
		elseif currentTag = "ST" then //Transaction Set Header 
		elseif currentTag = "B1" then  //Beginning Segment for Booking or Pick-u
			msgHelper.setNextField(); //Standard Carrier Alpha Code
			useN1SH := self.getUseN1SH(msgHelper.currentSubItem.trimBlanks);				   //03/06/2015 cnwma1 PAR #36337
			operatorCode := app.myRoot.getXlationSystemOperatorCode(operatorOid, msgHelper.currentSubItem, foundMatch); // cnwrd1 par 19675 14.5.09
			if operatorCode &lt;&gt; null then
				operatorCode := operatorCode[1:4];
				operatorOid := app.myRoot.allOperators[operatorCode];
				
				// we are running 2 processing options here probably based on the operator code
//				if not useEDIDataGateDoc then			
					if operatorCode = SeaFreight then // set as constant
						seaFreightProcessing := true;
					else
						seaFreightProcessing := false;
					endif;
//				endif;
			endif;
			msgHelper.setNextField(); //Shipment Identification Number
			msgHelper.setNextField(); //date
			// *** do something with the 'EDI Messafe Send Date/Time
			msgHelper.setNextField(); //Reservation Action Code
			actionStr := msgHelper.currentSubItem;  //Store the action so we know what to do when getting to the 
			actionStr := actionStr.removeCrLfs;
	//		if actionStr = "N" then
			if actionStr = "N" or actionStr = "A" then	//04 Dec 2017	NDL	TFS 8174
				messMode :=  CM_EDITrackedItem.EDI_ACTION_ADD;
			endif;
	//		if actionStr = "U" then
			if actionStr = "U" or actionStr = "C" then	//04 Dec 2017	NDL	TFS 8174
				messMode :=  CM_EDITrackedItem.EDI_ACTION_UPDATE;
			endif;
			if actionStr = "D" then
				messMode :=  CM_EDITrackedItem.EDI_ACTION_DELETE;
			endif;			
			if ediBookingHeaderTI = null or 
			   bookingNo &lt;&gt; ediBookingHeaderTI.id then
				create ediBookingHeaderTI;
				allST_EDI_Tis.add(ediBookingHeaderTI);
				ediBookingHeaderTI.setMyEDIData(ediData);
				ediBookingHeaderTI.operatorCode := operatorCode[1:4];
				ediBookingHeaderTI.messageMode := messMode;
			endif;
		elseif currentTag = "G61" then //Contact
		elseif currentTag = "Y6" then //Authentication
		elseif currentTag = "Y3" then //Space Confirmation
			msgHelper.setNextField(); //booking number
			bookingNo := msgHelper.currentSubItem; //could be booking number here!
			if (ediBookingHeaderTI = null or 
			   bookingNo &lt;&gt; ediBookingHeaderTI.id) and
			   ediBookingHeaderTI.id &lt;&gt; null then
				create ediBookingHeaderTI;
				allST_EDI_Tis.add(ediBookingHeaderTI);
				ediBookingHeaderTI.setMyEDIData(ediData);
				ediBookingHeaderTI.operatorCode := operatorCode[1:4];
				ediBookingHeaderTI.messageMode := messMode;
			endif;
			if ediBookingHeaderTI &lt;&gt; null and
			   ediBookingHeaderTI.id = null then
				ediBookingHeaderTI.setId(bookingNo);
			endif;
			msgHelper.setNextField(); //Standard Carrier Alpha Code
			if operatorCode = null then
				operatorCode := app.myRoot.getXlationSystemOperatorCode(operatorOid, msgHelper.currentSubItem, foundMatch); // cnwrd1 par 19675 14.5.09
				if ediBookingHeaderTI &lt;&gt; null then
					ediBookingHeaderTI.operatorCode := operatorCode[1:4];
				endif;
				if operatorCode &lt;&gt; null then
					opCode := operatorCode[1:4];
					operatorOid := app.myRoot.allOperators[opCode];
//					if not useEDIDataGateDoc then			
						if operatorCode = SeaFreight2 then // set as constant
							seaFreightProcessing := true;
						else
							seaFreightProcessing := false;
						endif;
//					endif;
				endif;
			endif;
		elseif currentTag = "Y4" then //Container Release
			hazCodes.clear; // clear this first.
			msgHelper.setNextField(); //booking number
			msgHelper.setNextField(); //booking number
			msgHelper.setNextField(); //date
			msgHelper.setNextField(); //standard point location code
			msgHelper.setNextField(); //number of containers
			numTI := msgHelper.currentSubItem.Integer;
			msgHelper.setNextField(); //equipment type
			//removed par 34338 cnwrd1   //24/09/2015   cnwma1 PAR #36904   uncomment this part because it stopping reading the IsoType type from Y4
			if operatorOid &lt;&gt; null then    																							//24/09/2015   cnwma1 PAR #36904
				isoType := operatorOid.getXlationSystemCode(msgHelper.currentSubItem, XLATION_TYPE_ISOTYPE_BYOP, foundMatch)[1:4];   
			else
				isoType := msgHelper.currentSubItem.trimBlanks[1:4];
			endif;
			
			while isoTypeArray.size &lt; numTI do
					isoTypeArray.add(isoType);
			endwhile;
					
			if not y4Loop and
			   (actionStr = "N" or
			   actionStr = "A" or
			   actionStr = "C" or	//08 Dec 2017	NDL	TFS 8174
			   actionStr = "U") then
				hazCodes.clear;
				create ediBookingItemTI;
				allST_EDI_Tis.add(ediBookingItemTI);
				ediBookingItemTI.setForCreateNew(ediData);
				ediBookingItemTI.setCargoType(TI_CargoType_Container);
				if ediBookingHeaderTI &lt;&gt; null then
					ediBookingItemTI.myParent := ediBookingHeaderTI;
				endif;
				ediBookingItemTI.setId(bookingNo);     											//01/10/2015 cnwma1 PAR #36917
				//ediBookingItemTI.operatorCode 	:= operatorCode;
				//ediBookingItemTI.isoType := isoType[1:4]; //cnwrd1 par 34286			//-TFS39646
				//ediBookingItemTI.operatorCode 	:= opCode;
				if seaFreightProcessing then //cnwrd1 par 34929 set line item count to 1 if not seafreight
					ediBookingItemTI.number := numTI;
				else
					ediBookingItemTI.number := 1;
				endif;
				ediBookingItemTI.setVoyageCode( voyCode );									
			endif;
			if ediPartyRules &lt;&gt; null and
			   ediPartyRules.relReqY4 then
				if ediRequestHeaderTI = null or
				   ediRequestHeaderTI.releaseRequestNumber &lt;&gt; bookingNo then
					create ediRequestHeaderTI;
					allST_EDI_Tis.add(ediRequestHeaderTI);
					ediRequestHeaderTI.releaseRequestNumber := bookingNo;
					ediRequestHeaderTI.setForCreateNew(ediData);
					ediRequestHeaderTI.setCargoType(TI_CargoType_Container);
					ediRequestHeaderTI.messageMode := messMode;
					ediRequestHeaderTI.bookingRef := bookingNo;
					ediRequestHeaderTI.consignee := consignee[1:30];  
					ediRequestHeaderTI.consignor := consignor[1:30];  
					ediRequestHeaderTI.dischargePort := dischPort;
					ediRequestHeaderTI.destinationPort := destPort;
					ediRequestHeaderTI.vesselName := vessCode;
					ediRequestHeaderTI.operatorCode := operatorCode;
					ediRequestHeaderTI.setVoyageCode(voyCode);
					ediRequestHeaderTI.remarks := remarks;
					ediRequestHeaderTI.releaseByType := true;
					ediRequestHeaderTI.mtRelease := true;
					ediRequestHeaderTI.senderCode := sender;
				endif;
				create ediRequestItemTI;
				allST_EDI_Tis.add(ediRequestItemTI);
				ediRequestItemTI.myParent := ediRequestHeaderTI;
				ediRequestItemTI.setForCreateNew(ediData);
				ediRequestItemTI.releaseRequestNumber := bookingNo;
				ediRequestItemTI.setDescription(ediBookingItemTI.description);
				ediRequestItemTI.subTerminalCode := ediBookingItemTI.subTerminalCode;
				//ediRequestItemTI.isoType := ediBookingItemTI.isoType;			//-TFS39646
				ediRequestItemTI.isoType := isoType[1:4];											//+TFS39646
				ediRequestItemTI.isoTypeGroup := ediBookingItemTI.isoTypeGroup;
				ediRequestItemTI.quantity := numTI;
				numTI := 0;
			endif;
			y4Loop := true;  //processing a 'release'
		elseif currentTag = "W09" then //Equipment and Temperature
			
			msgHelper.setNextField(); // equipment Description code
			msgHelper.setNextField(); // Temperature
			if msgHelper.currentSubItem &lt;&gt; null then
				temperature := msgHelper.currentSubItem.Real;
			endif;
			
			//+TFS39646 starts
			msgHelper.setNextField(); //unit or basis for measurement code
			if temperature &lt;&gt; NULL_TEMPERATURE then
				if msgHelper.currentSubItem = "CE" then
					setTemperature :=  temperature;
				elseif msgHelper.currentSubItem = "FA" then
					setTemperature :=  app.temperatureConversion(false, temperature);
				endif;
			else
				setTemperature := NULL_TEMPERATURE;
			endif;
			
			if r4Loop and not lxLoop  then									//W09 in  R4 Loop
				defHeaderTemperature := setTemperature;
			endif;
			
			if not y4Loop and not r4Loop then
				itemTemperature := setTemperature;				//W09 in LX Loop
			endif;
			
			if y4Loop and not r4Loop and not lxLoop then	//W09 in Y4 Loop
				while tempeArray.size &lt; numTI do
					tempeArray.add(setTemperature);
				endwhile;
			endif;
			
			/*				//-TFS39646
			msgHelper.setNextField(); //unit or basis for measurement code
			if temperature &lt;&gt; NULL_TEMPERATURE then
				if msgHelper.currentSubItem = "CE" then
					ediBookingItemTI.temperature := temperature;
				elseif msgHelper.currentSubItem = "FA" then
					ediBookingItemTI.temperature := app.temperatureConversion(false, temperature);
				endif;
			endif;
			*/
			
			//temperature := NULL_TEMPERATURE;
			msgHelper.setNextField(); //Temperature
			msgHelper.setNextField(); //Unit or bases of measurement code
			msgHelper.setNextField(); //free form message
			msgHelper.setNextField(); // vent setting code
			msgHelper.setNextField(); // percent
			//** atmosphere humidity			
			atmosHumidity := msgHelper.currentSubItem;
				
			msgHelper.setNextField(); // quantity
			//** atmosphere vent m3/hr
			atmosVent := msgHelper.currentSubItem;
			if ediBookingItemTI &lt;&gt; null and	 // TFS44770
			   ediBookingItemTI.temperature &lt;&gt; NULL_TEMPERATURE and
			   ediBookingItemTI.commodity = defCmdty then
				ediBookingItemTI.commodity := refCmdty;
			endif;
		elseif currentTag = "N9" then //Reference Identification
			msgHelper.setNextField(); //Reference Identification Qualifier
			if msgHelper.currentSubItem = "BN" then //booking ref
				msgHelper.setNextField(); //Reference Identification
				ediID := msgHelper.currentSubItem;
				if bookingNo = null then
					bookingNo := ediID;
				endif;
				if (ediBookingHeaderTI = null or 
				   bookingNo &lt;&gt; ediBookingHeaderTI.id) and
				   ediBookingHeaderTI.id &lt;&gt; null then
					create ediBookingHeaderTI;
					allST_EDI_Tis.add(ediBookingHeaderTI);
					ediBookingHeaderTI.setMyEDIData(ediData);
					ediBookingHeaderTI.operatorCode := operatorCode[1:4];
					ediBookingHeaderTI.messageMode := messMode;
				endif;
			elseif msgHelper.currentSubItem = "BN" then //bol number
			endif;	
		elseif currentTag = "R2A" then //Route Information with Preference
		elseif currentTag = "N1" then //Name
			msgHelper.setNextField(); //Entity Identifier Code
			if msgHelper.currentSubItem = "ZZ" then //mutually defined so unknown
			elseif msgHelper.currentSubItem = "SH" then //shipper
				msgHelper.setNextField(); //Name
				//useN1SH :=self.getUseN1SH(operatorCode);				   //03/06/2015 cnwma1 PAR #36337
				
				if useN1SH then
					consignor := operatorOid.getXlationSystemCode(msgHelper.currentField, XLATION_TYPE_CONSIGNEE_BYOP, foundMatch); //03/06/2015 cnwma1 PAR #36337
					if ediBookingHeaderTI &lt;&gt; null then
						ediBookingHeaderTI.consignor := consignor[1:30];  // cnwma1 03/03/2015  PAR #35779
					endif;
				endif;
			elseif msgHelper.currentSubItem = "CI" then //consignor
				msgHelper.setNextField(); //Name
				if not seaFreightProcessing then
					consignor := msgHelper.currentSubItem;
					if ediBookingHeaderTI &lt;&gt; null then
						ediBookingHeaderTI.consignor := consignor[1:30];  // cnwma1 03/03/2015  PAR #35779
					endif;
				endif;
			elseif msgHelper.currentSubItem = "CN" then //consignee
				msgHelper.setNextField(); //Name
				
				if not seaFreightProcessing then
					//consignor := msgHelper.currentSubItem;			//03/06/2015 cnwma1 PAR #36337
				//else
					consignee := msgHelper.currentSubItem;
					if ediBookingHeaderTI &lt;&gt; null then
						ediBookingHeaderTI.consignee := consignee[1:30];  // cnwma1 03/03/2015  PAR #35779
					endif;
				endif;
			elseif msgHelper.currentSubItem = "FW" then //Freight Forwarder	
				freightForwarder := msgHelper.currentSubItem;
			elseif msgHelper.currentSubItem = "N1" then //Notify Party no. 1
			endif;
		elseif currentTag = "N2" then //Additional Name Information
		elseif currentTag = "N3" then //Address Information
		elseif currentTag = "N4" then //Geographic Location
		elseif currentTag = "R4" then //Port or Terminal
			msgHelper.setNextField(); //Port or Terminal Function Code
			if msgHelper.currentSubItem = "1" then //Final Port of Discharge (Operational)
			elseif msgHelper.currentSubItem = "D" then //Port of Discharge (Operational)
				msgHelper.setNextField(); //Location Qualifier
				msgHelper.setNextField(); //Location Identifier
				
				portCodeString := msgHelper.currentSubItem;
				msgHelper.setNextField(); //Location Identifier
				portDescString := msgHelper.currentSubItem;

	
				if portCodeString.cnEcIsNumeric then
					//need to check the K or D schedule port code here.
					aPort := app.myRoot.lookupScheduleDKPortCode(portCodeString, portDescString);
					
					if aPort &lt;&gt; null then
						dischPort := aPort.code;
						if ediBookingHeaderTI &lt;&gt; null then
							ediBookingHeaderTI.dischargePort := dischPort;
						endif;
					else
						if operatorOid &lt;&gt; null then
							dischPort := operatorOid.getXlationSystemCode(portCodeString, XLATION_TYPE_PORT_BYOP, foundMatch)[1:5];
							if ediBookingHeaderTI &lt;&gt; null then
								ediBookingHeaderTI.dischargePort := dischPort;
							endif;
						else
							dischPort := portCodeString.trimBlanks[1:5];
							if ediBookingHeaderTI &lt;&gt; null then
								ediBookingHeaderTI.dischargePort := dischPort;
							endif;
						endif;
					endif;
				else				
					if operatorOid &lt;&gt; null then
						dischPort := operatorOid.getXlationSystemCode(portCodeString, XLATION_TYPE_PORT_BYOP, foundMatch)[1:5];
						if ediBookingHeaderTI &lt;&gt; null then
							ediBookingHeaderTI.dischargePort := dischPort;
						endif;
					else
						dischPort := portCodeString.trimBlanks[1:5];
						if ediBookingHeaderTI &lt;&gt; null then
							ediBookingHeaderTI.dischargePort := dischPort;
						endif;
					endif;
				endif;
				r4Loop := true;
			elseif msgHelper.currentSubItem = "E" then //Place of Delivery (Contractual)
				msgHelper.setNextField(); //Location Qualifier
				msgHelper.setNextField(); //Location Identifier
				portCodeString := msgHelper.currentSubItem;
				msgHelper.setNextField(); //Location Identifier
				portDescString := msgHelper.currentSubItem;

				if portCodeString.cnEcIsNumeric then
					//need to check the K or D schedule port code here.
					aPort := app.myRoot.lookupScheduleDKPortCode(portCodeString, portDescString);
					
					if aPort &lt;&gt; null then
						destPort := aPort.code;
						if ediBookingHeaderTI &lt;&gt; null then
							ediBookingHeaderTI.destinationPort := destPort;
						endif;
					else
						if operatorOid &lt;&gt; null then
							destPort := operatorOid.getXlationSystemCode(portCodeString, XLATION_TYPE_PORT_BYOP, foundMatch)[1:5];
							if ediBookingHeaderTI &lt;&gt; null then
								ediBookingHeaderTI.destinationPort := destPort;
							endif;
						else
							destPort := portCodeString.trimBlanks[1:5];
							if ediBookingHeaderTI &lt;&gt; null then
								ediBookingHeaderTI.destinationPort := destPort;
							endif;
						endif;
					endif;
				else				
					if operatorOid &lt;&gt; null then
						destPort := operatorOid.getXlationSystemCode(portCodeString, XLATION_TYPE_PORT_BYOP, foundMatch)[1:5];
						if ediBookingHeaderTI &lt;&gt; null then
							ediBookingHeaderTI.destinationPort := destPort;
						endif;
					else
						destPort := portCodeString.trimBlanks[1:5];
						if ediBookingHeaderTI &lt;&gt; null then
							ediBookingHeaderTI.destinationPort := destPort;
						endif;
					endif;
				endif;
				
				// ** also have name
			elseif msgHelper.currentSubItem = "L" then //Port of Loading (Operational)
				msgHelper.setNextField(); //Location Qualifier
				msgHelper.setNextField(); //Location Identifier
				
				portCodeString := msgHelper.currentSubItem;
				msgHelper.setNextField(); //Location Identifier
				portDescString := msgHelper.currentSubItem;
	
				if portCodeString.cnEcIsNumeric then
					//need to check the K or D schedule port code here.
					aPort := app.myRoot.lookupScheduleDKPortCode(portCodeString, portDescString);
					
					if aPort &lt;&gt; null then
						loadPort := aPort.code;
					else
						if operatorOid &lt;&gt; null then
							loadPort := operatorOid.getXlationSystemCode(portCodeString, XLATION_TYPE_PORT_BYOP, foundMatch)[1:5];
						else
							loadPort := portCodeString.trimBlanks[1:5];
						endif;
					endif;
				else				
					if operatorOid &lt;&gt; null then
						loadPort := operatorOid.getXlationSystemCode(portCodeString, XLATION_TYPE_PORT_BYOP, foundMatch)[1:5];
					else
						loadPort := portCodeString.trimBlanks[1:5];
					endif;
				endif;

			elseif msgHelper.currentSubItem = "P" then //Dispatching Pool (Operational)
			elseif msgHelper.currentSubItem = "R" then //Place of Receipt (Contractual)
			endif;
		elseif currentTag = "DTM" then //Date/Time Reference
		elseif currentTag = "H3" then //Special Handling Instructions
		elseif currentTag = "EA" then //Equipment Attributes
		elseif currentTag = "LX" then //Assigned Number
//			if y4Loop then 
//			elseif not seaFreightProcessing then
			msgHelper.setNextField();
			if y4Loop and ediBookingItemTI &lt;&gt; null then //jlgzm1 tfs41734
				ediBookingItemTI.number := 1;
				//jlier1 TFS 63253 19/4/24 - the temperature not set if the WO segment before teh d3 loop
				if ediBookingItemTI.temperature = null or ediBookingItemTI.temperature = NULL_TEMPERATURE  and defHeaderTemperature &lt;&gt; null then										
					ediBookingItemTI.temperature := defHeaderTemperature;
				endif;
			endif;
				//jlier1 TFS 63253 19/4/24 
			if ediBookingItemTI &lt;&gt; null and ediBookingItemTI.isoType = null  then				
				ediBookingItemTI.isoType := itemISOType;	
			endif;
			
			if not seaFreightProcessing and
			   not y4Loop and
			   msgHelper.currentSubItem &lt;&gt; "999" then
				lxLoop := true; //we dont have a Y4 look so we try an LX loop we get info from V1/L5
				if actionStr = "N" or
				   actionStr = "A" or 
				   actionStr = "C"	or//08 Dec 2017	NDL	TFS 8174
				   actionStr = "U" then
					hazCodes.clear;
					create ediBookingItemTI;
					allST_EDI_Tis.add(ediBookingItemTI);
					ediBookingItemTI.setForCreateNew(ediData);
					ediBookingItemTI.setCargoType(TI_CargoType_Container);  //** noooo probably not
					if ediBookingHeaderTI &lt;&gt; null then
						ediBookingItemTI.myParent := ediBookingHeaderTI;
					endif;
					//jlier1 TFS 63253 19/4/24 
					if defHeaderTemperature &lt;&gt; null then
						ediBookingItemTI.temperature := defHeaderTemperature;
					endif;
					//ediBookingItemTI.operatorCode 	:= operatorCode;
					//ediBookingItemTI.isoType := isoType[1:4];  //probably dont have any of this yet //cnwrd1 par 34286				//-TFS39646
					//ediBookingItemTI.operatorCode 	:= opCode;
					ediBookingItemTI.number := 1; //cnwrd1 par 34929 set line item count to 1
					ediBookingItemTI.setId(bookingNo);     									// 01/10/2015 cnwma1 PAR #36917
					ediBookingItemTI.setVoyageCode(voyCode);				
				endif;
			endif;
			y4Loop := false; // now at the end of the Y4 loop more importantly after the L5 part of that loop so the next L5 is booking remarks
			r4Loop := false;
			// this could be the start of another loop of booking lines :/
			ediPrenoteTI := null;
		elseif currentTag = "N7" then //Equipment Details
			msgHelper.setNextField(); //1 - Equipment initial
			cargoPrefix := msgHelper.currentSubItem;
			msgHelper.setNextField(); //2 - Equipment number
			cargoID := cargoPrefix &amp; msgHelper.currentSubItem;
			msgHelper.setNextField(); //3 - Weight
			msgHelper.setNextField(); //4 - Weigth Qualifier
			msgHelper.setNextField(); //5 - Tare Weight
			msgHelper.setNextField(); //6 - Weigth Allowance
			msgHelper.setNextField(); //7 - Dunnage
			msgHelper.setNextField(); //8 - Volume
			msgHelper.setNextField(); //9 - Volume unit qualifier
			msgHelper.setNextField(); //10 - ownership code
			msgHelper.setNextField(); //11 - Equipment Description Code
			msgHelper.setNextField(); //12 - Standard Carrier Alpha code
			msgHelper.setNextField(); //13 - Temperature control
			msgHelper.setNextField(); //14 - Position
			msgHelper.setNextField(); //15 - Equipment Length
			msgHelper.setNextField(); //16 - Tare Qualifier Code
			msgHelper.setNextField(); //17 - Weigh unit Code
			msgHelper.setNextField(); //18 - Equipment Number Check Digit
			cargoID := cargoID &amp; msgHelper.currentSubItem;
			msgHelper.setNextField(); //19 - Type of Service Code
			msgHelper.setNextField(); //20 - Heigth
			msgHelper.setNextField(); //21 - Width
			msgHelper.setNextField(); //22 - Equipment Type
			// seafreight cargo type (ISO Type?) - in field 22.
			//if seaFreightProcessing then //34338 cnwrd1 removed
			if operatorOid &lt;&gt; null then
				itemISOType := operatorOid.getXlationSystemCode(msgHelper.currentSubItem, XLATION_TYPE_ISOTYPE_BYOP, foundMatch)[1:4];
			else
				itemISOType := msgHelper.currentSubItem.trimBlanks[1:4];
			endif;
			
			//endif;
						
			msgHelper.setNextField(); //23 - Standard Carrier Alpha code			
			msgHelper.setNextField(); //24 - Car Type Code
			ediPrenoteTI := null;
			if cargoID &lt;&gt; null and
			   ediPrenotes[cargoID] = null and
			   ediPartyRules &lt;&gt; null and
			   ediPartyRules.prenoteN7 then
				create ediPrenoteTI;
				allST_EDI_Tis.add(ediPrenoteTI);
				ediPrenoteTI.setForCreateNew(ediData);
				ediPrenoteTI.setCargoType(TI_CargoType_Container);
				ediPrenoteTI.setId(cargoID);
				ediPrenoteTI.bookingRef := bookingNo;
				ediPrenoteTI.operatorCode:= operatorCode;
				if itemISOType &lt;&gt; null then
					ediPrenoteTI.isoType :=itemISOType;
				else
					ediPrenoteTI.isoType := isoType[1:4];
				endif;
				ediPrenoteTI.dischargePort := dischPort;
				//jlier1 TFS 63253 19/4/24 - if weight is null and have isoType set the weight from the tare weight
				if ediweight = null then
					isoTypeObj := app.myRoot.allISOTypes[ediPrenoteTI.isoType];
					if isoTypeObj &lt;&gt; null then
						ediPrenoteTI.weight:=isoTypeObj.tareKilos;
					endif;
				else
					ediPrenoteTI.weight := ediweight;
				endif;
			
				ediPrenoteTI.commodity := commod;
				ediPrenoteTI.commodityDescription := commodDesc[1:30];
				
				//jlier1 TFS 63253 19/4/24 
				if defHeaderTemperature &lt;&gt; null then
					ediPrenoteTI.temperature:=defHeaderTemperature;
				endif;
				ediPrenotes.add(ediPrenoteTI);
			endif;
		elseif currentTag = "K1" then //Remarks
			msgHelper.setNextField(); //Free-Form Message
			remarks := msgHelper.currentSubItem;
			if ediBookingHeaderTI &lt;&gt; null then
				ediBookingHeaderTI.remarks	:= remarks;
			endif;
			//should have our ediBookingItemTI for this loop now.
			if ediBookingItemTI &lt;&gt; null then
				ediBookingItemTI.remarks := remarks;
			endif;
			
			if ediRequestHeaderTI &lt;&gt; null then			//Bug 45796
				ediRequestHeaderTI.remarks := remarks;	//Bug 45796
			endif;										//Bug 45796
			if ediRequestItemTI &lt;&gt; null then			//Bug 45796
				ediRequestItemTI.remarks := remarks;	//Bug 45796
			endif;										//Bug 45796
			
			
			
		elseif currentTag = "L0" then //Line Item - Quantity and Weight
			msgHelper.setNextField(); //Lading Line Item Number
			msgHelper.setNextField(); //Billed/Rated-as Quantity
			msgHelper.setNextField(); //Billed/Rated-as Quantity
			msgHelper.setNextField(); //Weight
			ediweight := msgHelper.currentSubItem.Integer;			
			if ediPrenoteTI &lt;&gt; null then
				ediPrenoteTI.weight := ediweight;
			endif;
			msgHelper.setNextField(); //Weight Qualifier
			msgHelper.setNextField(); //Volume
			volume := msgHelper.currentSubItem.Real;
			msgHelper.setNextField(); //Volume Unit Qualifier
			unitQualifier := msgHelper.currentSubItem.String;
			
			if unitQualifier = 'E' then
				// units of cubic feet!! Convert with system type
				volume := app.convertMeasurementForStorage('ft3',volume);
			endif;
			
			msgHelper.setNextField(); //Lading Quantity
			quantity := msgHelper.currentSubItem.String;	
			msgHelper.setNextField(); //Packaging Form Code
			packageType := msgHelper.currentSubItem.String;	
			msgHelper.setNextField(); //Dunnage Description
			commodDesc := msgHelper.currentSubItem.trimBlanks().removeCrLfs;
			
			//+TFS39646
			if ediBookingItemTI &lt;&gt; null then
				if itemTemperature &lt;&gt; null then															// get item temerature 
					ediBookingItemTI.temperature := itemTemperature;
					itemTemperature := null;																		//reset item temerature for next one
				elseif defHeaderTemperature &lt;&gt; null then										
					ediBookingItemTI.temperature := defHeaderTemperature;
				elseif tempeArray &lt;&gt; null and tempeArray.size &lt;&gt; 0 and  processedTINum  &lt;= tempeArray.size then
					ediBookingItemTI.temperature :=  tempeArray[processedTINum];
				endif;
				
				if itemISOType &lt;&gt; null then																			//get item iso type 
					ediBookingItemTI.isoType :=itemISOType;
					itemISOType := null; 																					//reset item isotype for next one
				elseif  isoTypeArray &lt;&gt; null and isoTypeArray.size &lt;&gt; 0 and  processedTINum  &lt;= isoTypeArray.size then	
					ediBookingItemTI.isoType :=  isoTypeArray[processedTINum];
				elseif isoType &lt;&gt; null then				//23JUN2025 navnk30 JIRA-34167
					ediBookingItemTI.isoType := isoType[1:4];
				endif;
				
				processedTINum := 	processedTINum+1;
			endif;

			if commodDesc &lt;&gt; null then
				if operatorOid &lt;&gt; null then
					commod := operatorOid.getXlationSystemCode_Commodity(commodDesc, foundMatch, NULL_TEMPERATURE)[1:4];
				else
					commod := commodDesc[1:4];
				endif;
			else
				if not seaFreightProcessing then			
					if ediBookingItemTI &lt;&gt; null and // TFS44770
					   ediBookingItemTI.temperature = NULL_TEMPERATURE then
						if defCmdty &lt;&gt; null then
							commod := defCmdty;
						endif;
					else
						if refCmdty &lt;&gt; null then
							commod := refCmdty;
						endif;
					endif;
				endif;
			endif;
			if commod &lt;&gt; null then
				aCommodity := app.myRoot.allCommodities[commod];
			endif;
			if ediBookingItemTI &lt;&gt; null then
			//tmpCommodity := app.myRoot.allCommodities[entryTable.getValue(row).String];
			//tmpCommodity.allCargotypes size = 1 
				if aCommodity &lt;&gt; null then
					//we have a commodity object
					if aCommodity.allCargoTypes.size = 1 then					
						//it only has 1 cargo type so we will assume that one
						ediBookingItemTI.setCargoType( aCommodity.allCargoTypes.first.id);
					else //more than 1
						if aCommodity.allCargoTypes[ediBookingItemTI.cargoType] &lt;&gt; null then
							// we include the 'default' ISO container so we'll stick with that
						else
							// we dont include ISO container and know that is wrong so we will pick the first one.
							ediBookingItemTI.setCargoType( aCommodity.allCargoTypes.first.id);
						endif;
					endif;
				endif;
				if commodDesc &lt;&gt; null then
					ediBookingItemTI.commodityDescription := commodDesc[1:30]; //cnwrd1 par 34286
				endif;
				ediBookingItemTI.commodity 		:= commod[1:4]; //cnwrd1 par 34286
				ediBookingItemTI.weight 			:= ediweight;
				ediBookingItemTI.volume			:= volume;
			endif;
			msgHelper.setNextField(); //Weight Unit Code
			msgHelper.setNextField(); //Type of Service Code
			msgHelper.setNextField(); //Quantity
			msgHelper.setNextField(); //Packaging Form Code
			msgHelper.setNextField(); //Yes/No Condition or Response Code
		elseif currentTag = "L5" then //Description, Marks and Numbers
			msgHelper.setNextField(); //Lading Line Item Number
			msgHelper.setNextField(); //Lading Description
//			if seaFreightProcessing then
//				if y4Loop then
			if (seaFreightProcessing and
			    y4Loop) or
			   not seaFreightProcessing then
				commodDesc := msgHelper.currentSubItem.trimBlanks().removeCrLfs;
				if commodDesc &lt;&gt; null then
					if operatorOid &lt;&gt; null and
					   ediBookingItemTI &lt;&gt; null then // TFS44770
						commod := operatorOid.getXlationSystemCode_Commodity(commodDesc, foundMatch, ediBookingItemTI.temperature)[1:4];
					else
						commod := commodDesc[1:4];
					endif;
				else
					if ediBookingItemTI.commodity &lt;&gt; hazCmdty then
						if ediBookingItemTI.temperature = NULL_TEMPERATURE then
							if defCmdty &lt;&gt; null then
								commod := defCmdty;
							endif;
						else
							if refCmdty &lt;&gt; null then
								commod := refCmdty;
							endif;
						endif;
					endif;
				endif;
				if commod &lt;&gt; null then
					aCommodity := app.myRoot.allCommodities[commod];
				endif;
				if ediBookingItemTI &lt;&gt; null then
					if aCommodity &lt;&gt; null then
						//we have a commodity object
						if aCommodity.allCargoTypes.size = 1 then					
							//it only has 1 cargo type so we will assume that one
							ediBookingItemTI.setCargoType( aCommodity.allCargoTypes.first.id);
						else //more than 1
							if aCommodity.allCargoTypes[ediBookingItemTI.cargoType] &lt;&gt; null then
								// we include the 'default' ISO container so we'll stick with that
							else
								// we dont include ISO container and know that is wrong so we will pick the first one.
								ediBookingItemTI.setCargoType( aCommodity.allCargoTypes.first.id);
							endif;
						endif;
					else
						if not seaFreightProcessing then
							if ediBookingItemTI.temperature = NULL_TEMPERATURE then
								if ediBookingItemTI.commodity &lt;&gt; hazCmdty then
									if defCmdty &lt;&gt; null then
										commod := defCmdty;
									endif;
								else
									if hazCmdty &lt;&gt; null then
										commod := hazCmdty;
									endif;
								endif;
							else
								if refCmdty &lt;&gt; null then
									commod := refCmdty;
								endif;
							endif;
						endif;
					endif;
					if commodDesc &lt;&gt; null then
						ediBookingItemTI.commodityDescription := commodDesc[1:30]; //cnwrd1 par 34286
					endif;
					ediBookingItemTI.commodity 		:= commod[1:4];//cnwrd1 par 34286
//				else
					// booking remarks?
				endif;
				//jlier1 TFS  63253 - prenote note getting the commodity set
				if ediPrenoteTI &lt;&gt; null then
					ediPrenoteTI.commodityDescription:=commodDesc;
					ediPrenoteTI.commodity:=commod[1:4];
				endif;
				
			endif;
			
		elseif currentTag = "L4" then //Measurement
			msgHelper.setNextField(); //length
			length := msgHelper.currentSubItem.Integer;
			msgHelper.setNextField(); //width
			width := msgHelper.currentSubItem.Integer;
			msgHelper.setNextField(); //height
			height := msgHelper.currentSubItem.Integer;
			msgHelper.setNextField(); //Measurement Unit Qualifier
				
			
			if ediBookingItemTI &lt;&gt; null then
				ediBookingItemTI.length 	:=	length;
				ediBookingItemTI.width		:= 	width;
				ediBookingItemTI.height 	:= 	height;				
			endif;
			
			if msgHelper.currentSubItem = 'C' then //Centimeters
			elseif msgHelper.currentSubItem = 'E' then //Feet
			elseif msgHelper.currentSubItem = 'N' then //Inches
			elseif msgHelper.currentSubItem = 'X' then //Meters
			endif;
		elseif currentTag = "L1" then //Rate and Charges
		elseif currentTag = "H1" then //Hazardous Material
			msgHelper.setNextField(); //Hazardous Material Code		 - UNDG number	 
			undg := msgHelper.currentSubItem; //cnwrd1 par 34446
			msgHelper.setNextField(); //Hazardous Material Class Code  - Haz code
			haz := msgHelper.currentField; //cnwrd1 par 34446
			hazCodes.add(haz &amp; ":+" &amp; undg);
			if hazCmdty &lt;&gt; null and
			   (commod = defCmdty or
			    commod = refCmdty) then
				commod := hazCmdty;
					commod := hazCmdty;
				ediBookingItemTI.commodity := hazCmdty;
				if ediPrenoteTI &lt;&gt; null then
					ediPrenoteTI.commodity := hazCmdty;
				endif;
			endif;
			msgHelper.setNextField(); //Hazardous Material Code Qualifier
			msgHelper.setNextField(); //Hazardous Material Description
			hazDescription := msgHelper.currentField;
			msgHelper.setNextField(); //Hazardous Material Contact
			msgHelper.setNextField(); //Hazardous Materials Page
			msgHelper.setNextField(); //Flashpoint Temperature
			msgHelper.setNextField(); //Unit or Basis for Measurement Code
			msgHelper.setNextField(); //Packing Group Code
			if ediBookingItemTI &lt;&gt; null then //cnwrd1 par 34446
				ediBookingItemTI.imCodes.add(haz &amp; ":+" &amp; undg);
			endif;
			if ediPrenoteTI &lt;&gt; null then
				create ediHazDets;
				ediHazDets.setId(ediPrenoteTI.id);
				ediHazDets.setMyParent(ediPrenoteTI);
				ediHazDets.setMyEDIData(ediData);
				ediHazDets.undgCodes := undg;
				ediHazDets.code := haz;
				ediHazDets.setDescription(hazDescription);
			endif;
		elseif currentTag = "H2" then //Additional Hazardous Material Descripti
		elseif currentTag = "V1" then //Vessel Identification
			msgHelper.setNextField(); //vessel code
			lloydsNumber := msgHelper.currentSubItem;
			msgHelper.setNextField(); //vessel name
			vessCode := msgHelper.currentSubItem;
			if ediBookingHeaderTI &lt;&gt; null then
				ediBookingHeaderTI.vesselName := vessCode;
			endif;
			msgHelper.setNextField(); //country code
			msgHelper.setNextField(); //voyage code
			voyCode := msgHelper.currentSubItem;
			if ediBookingHeaderTI &lt;&gt; null then
				ediBookingHeaderTI.setVoyageCode(voyCode);
				ediBookingHeaderTI.setRawVoyageCode(voyCode);
			endif;
			//15 Apr 2016	NDL	TFS 1801
			voyCode := getXlatedVoyageCode(	operatorOid,		//_operator : CM_Operator; 
											voyCode,		//_voyCode : String;
											vessCode,		//_vesselValue : String;
											lloydsNumber,		//_lloydsNumber : String;
											callSign		//_callSign : String
											);
		elseif currentTag = "V9" then //Event Detail
		elseif currentTag = "SE" then //Transaction Set Trailer
			//check if the last ediBookingItemTI has isoType if not set from the N7
			if ediBookingItemTI &lt;&gt; null and ediBookingItemTI.isoType = null then	
				ediBookingItemTI.isoType:=itemISOType;
			endif;
			
			
			foreach ediTI in allST_EDI_Tis do
				ediTI.setVoyageCode(voyCode);
				if ediTI.isKindOf(CM_EDIBookingHeaderTI) then
					ediBookingHeaderTI := ediTI.CM_EDIBookingHeaderTI;
					ediBookingHeaderTI.setRawVoyageCode(voyCode);
					ediBookingHeaderTI.vesselName := vessCode;
				elseif ediTI.isKindOf(CM_EDIBookingItemTI) then
					ediBookingItemTI := ediTI.CM_EDIBookingItemTI;
				elseif ediTI.isKindOf(CM_EDIRequestHeaderTI) then
					ediRequestHeaderTI := ediTI.CM_EDIRequestHeaderTI;
					ediRequestHeaderTI.consignee := consignee[1:30];  
					ediRequestHeaderTI.consignor := consignor[1:30];  
					ediRequestHeaderTI.dischargePort := dischPort;
					ediRequestHeaderTI.destinationPort := destPort;
					ediRequestHeaderTI.vesselName := vessCode;
					if ediRequestHeaderTI.subTerminalCode = null and
					   ediPartyRules.myDefaultSubTerminal &lt;&gt; null then
						ediRequestHeaderTI.subTerminalCode	:= ediPartyRules.myDefaultSubTerminal.code;
					endif;
					if ediRequestHeaderTI.carrierCode = null and
					   ediPartyRules.myDefaultCarrier &lt;&gt; null then
						ediRequestHeaderTI.carrierCode := ediPartyRules.myDefaultCarrier.code;
					endif;
					if ediRequestHeaderTI.deliveryReason = null and
					   ediPartyRules.defaultDeliveryReasonCode &lt;&gt; null then
						ediRequestHeaderTI.deliveryReason := ediPartyRules.defaultDeliveryReasonCode;
					endif;
					if ediRequestHeaderTI.releaseType = null and
					   ediPartyRules.defaultReleaseType &lt;&gt; null then
						ediRequestHeaderTI.releaseType := app.releaseRequestTypeEnumToString(ediPartyRules.defaultReleaseType);
						ediRequestHeaderTI.releaseTypeStr := ediRequestHeaderTI.releaseType;
					endif;
					if ediRequestHeaderTI.statusBulkRelease = null then
						ediRequestHeaderTI.statusBulkRelease := app.releaseStatusEnumToString(ediPartyRules.defaultReleaseStatus);
					endif;
				elseif ediTI.isKindOf(CM_EDIRequestDetailTI) then
					ediRequestItemTI := ediTI.CM_EDIRequestDetailTI;
					isoTypeObj := app.myRoot.allISOTypes[ediRequestItemTI.isoType];
					if isoTypeObj &lt;&gt; null then
						if isoTypeObj.isReefer then
							if ediRequestItemTI.availabilityGrades = null and
							   ediPartyRules.defaultAvailabilityGrade &lt;&gt; null then
								ediRequestItemTI.availabilityGrades := ediPartyRules.defaultAvailabilityGradeReefer.String;
							endif;
						else
							if ediRequestItemTI.availabilityGrades = null and
							   ediPartyRules.defaultAvailabilityGrade &lt;&gt; null then
								ediRequestItemTI.availabilityGrades := ediPartyRules.defaultAvailabilityGrade.String;
							endif;
						endif;
					endif;
				elseif ediTI.isKindOf(CM_EDIPrenoteTI) then
					ediPrenoteTI := ediTI.CM_EDIPrenoteTI;
					ediPrenoteTI.consignee := consignee[1:30];  
					ediPrenoteTI.consignor := consignor[1:30];  
					ediPrenoteTI.dischargePort := dischPort;
					ediPrenoteTI.destinationPort := destPort;
					ediPrenoteTI.vesselName := vessCode;
				endif;
			endforeach;
//			ediBookingHeaderTI := null;
			ediBookingItemTI := null;
			ediRequestHeaderTI := null;
			ediRequestItemTI := null;
			ediPrenoteTI := null;
			allST_EDI_Tis.clear();
		elseif currentTag = "GE" then 
		elseif currentTag = "IEA" then 
		endif;
	endforeach;
	
	
	
epilog
	delete theLines;
	delete msgHelper;
	delete hazCodes;
	delete ediPrenotes;
	delete allST_EDI_Tis;
	delete tempeArray;			//+TFS39646
	delete isoTypeArray;			//+TFS39646
end;
</source>
        <access>protected</access>
        <Parameter name="_ediFile" type="CM_EDIFile" usage="input"/>
    </JadeMethod>
</Class>
