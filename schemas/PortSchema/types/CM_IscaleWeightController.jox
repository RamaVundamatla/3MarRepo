    <JadeMethod name="getWeight" id="7695b701-402b-44e7-aee3-71755d24f9a3">
        <source>getWeight(_binResponse : Binary) : Decimal protected;
/*

Purpose:			
Retrieve weight data starts from 109 from the binary data passing back 
Parameters:			

Return Value:		

Date		Who		Reason
16 September 2016	cnwrh7	Initial creation

*/
constants
	WeightDataStartPoint = 109;			 //4 Byte in the return buffer binary start from postion 109
	Delimiter : String = " ";
vars
	weightDataString					: String;
	int 												: Integer;
	weightRealValue					: Real;
	weightDeciValueInTonne	: Decimal[15,3];			//unit Tonne
	weightDeciValueInKg			: Decimal[15,3];			//unit	Kg
	logString									: String;
	iScaleWeightDataTrans					: CMIF_IscaleWeightDataWrap;
begin
	logString := method.qualifiedName; 
	self.diagnosticLog(logString);
	int :=0;
	while int &lt;=3 do																											//we need 4 Byte in the return buffer binary start from postion 109
		weightDataString := weightDataString &amp; _binResponse[WeightDataStartPoint+int: 1].asHex.String &amp; Delimiter;
		int := int +1 ;
	endwhile;
	weightDataString := weightDataString.trimRight(); 										//remove last Delimiter
	create iScaleWeightDataTrans transient;															//use c# dll file to do data convertion
	if iScaleWeightDataTrans.convertFunction(weightDataString, weightRealValue) then
		weightDeciValueInTonne := weightRealValue.Decimal;							//Weight in Tonne
		weightDeciValueInKg	:= weightDeciValueInTonne*1000;						//Weight in Kg
	else
		logString := method.qualifiedName &amp; Tab &amp; "Response Binary can not be converted successfully.";
		self.diagnosticLog (logString);
	endif;
	if weightDeciValueInKg &gt;= 0 then
		return weightDeciValueInKg;
	else
		self.raiseWeightICException(0,"Unknown command received from iScale device: '" &amp; "The value is null" &amp; "'");
	endif;
epilog
	delete iScaleWeightDataTrans;

end;</source>
        <access>protected</access>
        <Parameter name="_binResponse" type="Binary"/>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="getWeightCommand" id="7d838b1a-36a4-4948-b95b-658a4fa495fd">
        <source>getWeightCommand(): Binary protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 March 2019	jlger1	Initial creation

*/

vars
	getWeightBytes						: ByteArray;
		getWeightMessage    				: Binary;
		i														: Integer;
begin
		create getWeightBytes transient;								//Based on the example and document from iScale
	getWeightBytes[1] 		:= 255.Byte;								//start byte
	getWeightBytes[2] 		:= 6.Byte;									//format version of this command
	getWeightBytes[3]		:= 10.Byte;								//command "Get Data"
	getWeightBytes[4] 	:= 1.Byte;									//length of data send in command	--(lowest byte)
	getWeightBytes[5] 		:= 0.Byte;									//length of data send in command --(higher byte)
	getWeightBytes [6] 	:= 0.Byte;									//length of data send in command --(higher byte)
	getWeightBytes [7] 	:= 0.Byte;									//length of data send in command --(highest byte)
//	getWeightBytes [8] 	:= lastDigital.Byte;				//ID of device sending command --(Depnding on situation) Need Device ID here???
	getWeightBytes [8] 	:= 5.Byte;									//ID of device sending command --(Depnding on situation) Need Device ID here???
	getWeightBytes [9] 	:= 255.Byte;								//end byte
	i :=1;
	 while i &lt;= getWeightBytes.size do 
			getWeightMessage := getWeightMessage &amp; getWeightBytes[i].Binary;
			i:= i+1;
	endwhile;
	return getWeightMessage;

epilog
	delete getWeightBytes;
end;</source>
        <access>protected</access>
        <ReturnType type="Binary"/>
    </JadeMethod>
</Class>
