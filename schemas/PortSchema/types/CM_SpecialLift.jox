    <JadeMethod name="setForCreate" id="1c9e511d-dbdf-4518-a86a-b2c222f07d2d">
        <updating/>
        <source>setForCreate(pProxySpecialLift : CM_SpecialLift)updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 July 2009	cnwml2	Initial creation

*/

vars

begin
	pProxySpecialLift.raiseExceptionIfNotTransient(method);
	
	setForUpdate(pProxySpecialLift);
	
	self.myRoot := app.myRoot;
epilog

end;</source>
        <Parameter name="pProxySpecialLift" type="CM_SpecialLift"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="a813de99-cffa-4bae-9274-cd5520494467">
        <updating/>
        <source>setForUpdate(pProxySpecialLift : CM_SpecialLift)updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 July 2009	cnwml2	Initial creation

*/

vars

begin
	self.code := pProxySpecialLift.code.trimBlanks;
	self.description := pProxySpecialLift.description.trimBlanks;
epilog

end;</source>
        <Parameter name="pProxySpecialLift" type="CM_SpecialLift"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="de49a4ef-6d33-4b78-b21b-954591f52e3c">
        <updating/>
        <source>setProxy(pName, pDescription: String)updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 July 2009	cnwml2	Initial creation

*/

vars

begin
	self.raiseExceptionIfNotTransient(method);

	self.code 			:= pName[1:5].trimBlanks;
	self.description 	:= pDescription[1:30].trimBlanks;
	self.myRoot 		:= app.myRoot;
epilog

end;</source>
        <Parameter name="pName" type="String"/>
        <Parameter name="pDescription" type="String"/>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="1a5e42e9-ee27-40c2-8da9-5e67c28fe587">
        <source>validateForCreate();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 July 2009	cnwml2	Initial creation

*/

vars

begin
	if app.myRoot.allSpecialLifts[self.code] &lt;&gt; null then 
		app.raiseCMException1(VB_DUPLICATED_ITEM, self.code, null, null);
	endif;

	self.validateMe;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="1d908a52-485e-4bae-8788-1e53942faf28">
        <source>validateForUpdate();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 July 2009	cnwml2	Initial creation

*/

vars

begin
	self.validateMe;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="validateMe" id="b818f428-2c46-4fa6-af6b-535f97e5bb61">
        <source>validateMe() protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 July 2009	cnwml2	Initial creation

*/

vars

begin
	if self.code.trimBlanks = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Special Lift Code', null, null);
		app.raiseCMException(Input_required_field_speclLift, null, null); // cnwdb2	PAR 35364


	endif;
	if self.description.trimBlanks = null then
//		app.raiseCMException1(REQUIRED_FIELD, 'Special Lift Description', null, null);
		app.raiseCMException(Input_required_field_specLftD, null, null); // cnwdb2	PAR 35364
	endif;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
</Class>
