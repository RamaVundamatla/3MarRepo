    </JadeMethod>
    <JadeMethod name="getClassChangesNumber" id="018b27f1-9b88-4f1e-bbc8-192ce5537b91">
        <updating/>
        <source>getClassChangesNumber(_className: String; _strArray : StringArray io): Integer updating;
/*
// 17 Jun 2014	cnwrs1	Par 34413 lost updates in DSS
*/
begin
	//	check that we have a selection manager
	if self.mySelectionManager = null then
		create self.mySelectionManager transient;
	endif;
	return (self.mySelectionManager.getClassChangesNumber(_className, _strArray));	//07 Jan 2014	NDL	Par 33264
end;
</source>
        <Parameter name="_className" type="String"/>
        <Parameter name="_strArray" type="StringArray" usage="io"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
