	cargo1.setDestinationPort ("NZWEL");
	commitTransaction;
	// ### 20 REEFERS
	cargo2 := self.addCargoAtLocationDetailed(CargoID2, cargoTypeObj, cargoSubType, bs.myLocationsController, "NZCHC", TI_IMEX_STATUS_EXPORT, voyage, operator);
