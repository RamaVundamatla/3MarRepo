vars

begin

	self.myRoot := app.myRoot;

end;</source>
    </JadeMethod>
    <JadeMethod name="setProxy" id="6071a8f5-e55e-47ba-92dd-f11e1cee0393">
        <updating/>
        <source>setProxy(pName, pDescription: String) updating;
// ---------------------------------------------------------------------------
// Created:     13 May 2003 by cnwsb1
// ---------------------------------------------------------------------------
begin
	self.raiseExceptionIfNotTransient(method);

	self.code 			:= pName[1:4].trimBlanks;
	self.description 	:= pDescription[1:30].trimBlanks;
	self.myRoot 		:= app.myRoot;
end;</source>
        <Parameter name="pName" type="String"/>
        <Parameter name="pDescription" type="String"/>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="2c9b48ac-3ba3-4a75-aad6-8ad5469ea3eb">
        <source>validateForCreate();
// ---------------------------------------------------------------------------
// Created:     13 May 2003 by cnwsb1
// ---------------------------------------------------------------------------
begin
	if app.myRoot.allPreDefinedRemarks[self.code] &lt;&gt; null then
		app.raiseCMException1(VB_DUPLICATED_ITEM, self.code, null, null);
	endif;

	self.validateMe;
end;</source>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="9579dba1-1383-417e-a31b-11f0eb60fecd">
        <source>validateForUpdate();
// ---------------------------------------------------------------------------
// Created:     13 May 2003 by cnwsb1
// ---------------------------------------------------------------------------
begin
	self.validateMe;
end;</source>
    </JadeMethod>
    <JadeMethod name="validateMe" id="86f43eb6-85bb-45ee-abc3-70f0ee96a668">
        <source>validateMe() protected;
// ---------------------------------------------------------------------------
// Created:     13 May 2003 by cnwsb1
// ---------------------------------------------------------------------------
begin
	if self.code.trimBlanks = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'PredefinedRemark Code', null, null);
		app.raiseCMException(Input_required_field_predRemCd, null, null); // cnwdb2	PAR 35364


	endif;
	if self.description.trimBlanks = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'PredefinedRemark Description', null, null);
		app.raiseCMException(Input_required_field_preRemDes, null, null); // cnwdb2	PAR 35364
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
</Class>
