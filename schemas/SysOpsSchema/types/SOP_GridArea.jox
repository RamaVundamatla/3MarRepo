begin
	return (RowSpacing * (self.scaleXFactor - 1)).Integer;

epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="insertGridColumn" id="ad5aa0bd-2610-4649-9b26-b1e1b146b9a0">
        <source>insertGridColumn(_gridCol : SOP_GridColumn input; _column : Integer);
// ---------------------------------------------------------------------------
// Created:		02 May 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------

vars
	labelStr,
	lastColNum					: String;
	ident40Ft					: String;
	theColumn			: Integer;
	sopGridRow			: CMUI_GridRow;
	gridPoint			: SOP_GridPoint;
	pxyGridColumn		: CM_GridColumn;
	pxyGridPoint		: SOP_GridPoint;
	pxyGridArea			: CM_GridArea;
	pxyGridController	: CM_GridController;
begin
	pxyGridArea := self.getGridArea();
	//move existing columns up one
	foreach theColumn in self.allGridColumns.size to _column step -1 do
		self.allGridColumns[theColumn].SOP_GridColumn.setColumn(theColumn+1);
	endforeach;
	
	create pxyGridColumn transient;
	pxyGridColumn.setForProxy(_column, "_" &amp; _column.String.padLeadingZeros(4), pxyGridArea);
	_gridCol.setForCreate(self, pxyGridColumn);
	
	//create gridPoints
	foreach sopGridRow in self.allGridRows do
		create pxyGridPoint transient;
		if CM_RTGArea.hasInstance(pxyGridArea) then
			create pxyGridController as CM_RTGController transient;
		else
			create pxyGridController as CM_StackController transient;			
		endif;
		pxyGridController.setForProxy(PAD_AVAILABLE,
									NORMAL_USE,
									sopGridRow.row,
									_gridCol.column,
									sopGridRow.label &amp; _gridCol.myPxyGridColumn.label,
									SOP_GridPoint.DefaultWidth,
									false,
									false,
									null,
									pxyGridArea, false, null, false, null, false, null);
									
		pxyGridPoint.setForCreate(self, pxyGridController, null);
		//create gridPoint transient;
		//gridPoint.setForCreate(theWidth, self.maxRowHeight, theRow, _column, null, self, null, LOC_Display_Available);
	endforeach;
	
end;


</source>
        <Parameter name="_gridCol" type="SOP_GridColumn" usage="input"/>
        <Parameter name="_column" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="insertGridRow" id="1d85189c-881b-457e-a437-c50e34c76c89">
        <source>insertGridRow(_gridRow : SOP_GridRow input; _row : Integer);
// ---------------------------------------------------------------------------
// Created:		02 May 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------

vars
	labelStr,
	lastRowNum					: String;
	ident40Ft					: String;
	currentRow,
	theRow			: Integer;
	sopGridCol		: CMUI_GridColumn;
	pxyGridRow		: CM_GridRow;
	pxyGridPoint	: SOP_GridPoint;
	pxyGridArea		: CM_GridArea;
	pxyGridController	: CM_GridController;
begin
	pxyGridArea := self.getGridArea();
	if pxyGridArea = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Null proxy grid area.');
		return;
	endif;
	
	//move existing rows up one
	foreach theRow in self.allGridRows.size to _row step -1 do
		self.allGridRows[theRow].SOP_GridRow.setRow(theRow+1);
	endforeach;
	
	create pxyGridRow transient;
	pxyGridRow.setForProxy(_row, '_' &amp; _row.String, pxyGridArea);
	_gridRow.setForCreate(self, pxyGridRow);
	
	//create gridPoints
	foreach sopGridCol in self.allGridColumns do
		create pxyGridPoint transient;
		if CM_RTGArea.hasInstance(pxyGridArea) then
			create pxyGridController as CM_RTGController transient;
		else
			create pxyGridController as CM_StackController transient;			
		endif;
		pxyGridController.setForProxy(PAD_AVAILABLE,
									NORMAL_USE,
									_gridRow.row,
									sopGridCol.column,
									_gridRow.label &amp; sopGridCol.SOP_GridColumn.myPxyGridColumn.label,
									SOP_GridPoint.DefaultWidth,
									false,
									false,
									null,
									pxyGridArea, false, null, false, null, false, null);
									
		pxyGridPoint.setForCreate(self, pxyGridController, null);
	endforeach;
	
	
end;


</source>
        <Parameter name="_gridRow" type="SOP_GridRow" usage="input"/>
        <Parameter name="_row" type="Integer"/>
    </JadeMethod>
