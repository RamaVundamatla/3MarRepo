vars

begin
	return true;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setDetailsFromCMIF" id="787aac7d-65df-4ef5-a769-270fd871602f">
        <updating/>
        <source>setDetailsFromCMIF(_eventType: CM_EventType; _cmifEventTrx: CMIF_LogoutEventCtrl) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17/02/2025	navkc1 JIRA Bug MTN-33582: MTN | Event Charging Refactor

*/

vars
	eventLogin 		: CMEVT_Login;
	excOccurred		: Boolean;	
begin
	
	on CM_Exception do app.handleTransactionMapError(exception, excOccurred);
	
	eventLogin := _cmifEventTrx.myEventLogin;
	
	if 	eventLogin &lt;&gt; null and
		eventLogin.userCode = self.userCode and
		eventLogin.myEventLogout = null then
		
		self.setEventLogin(eventLogin);
	endif;
	
	inheritMethod(_eventType, _cmifEventTrx);

epilog
	on CM_Exception do null;
	
end;</source>
        <Parameter name="_eventType" type="CM_EventType"/>
        <Parameter name="_cmifEventTrx" type="CMIF_LogoutEventCtrl"/>
    </JadeMethod>
    <JadeMethod name="setEventLogin" id="98682882-02d6-4992-a8d8-c5aefdb13b5a">
        <updating/>
        <source>setEventLogin(_eventLogin : CMEVT_Login input) updating;
// ---------------------------------------------------------------------------
// Created:     09 October 2007 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	self.myEventLogin := _eventLogin;
	_eventLogin.setTimeLoggedOn(self.dateTime);
end;</source>
        <Parameter name="_eventLogin" type="CMEVT_Login" usage="input"/>
    </JadeMethod>
</Class>
