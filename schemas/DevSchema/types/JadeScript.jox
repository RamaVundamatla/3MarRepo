    <JadeMethod name="eprTest34068" id="028c0e95-c5b8-425e-90aa-d6371db546e3">
        <source>eprTest34068();
/*

Date		Who		Reason
06 November 2014	cnwer1	Initial creation PAR

*/

vars

		sm: CM_SmtpConnection;
	i: Integer;
	str : String;
	toUser:  String;
	tmpDir		: String;
	attachment	: CnAttachment;
	log			: File;
	pos			: Integer;							// 04/10/2013 cnwmh5
begin

	app.initialize;
	app.writeLog("*****Sending email - start:" &amp; CrLf &amp; Tab &amp; "sendEmail: " &amp; "eryan@jadeworld.com", LogINFO);
	
	
	toUser := "rsargent@jadeworld.com";								// cnwma1-10/11/2014
	//toUser := "eryan@jadeworld.com";
	//toUser := toUser &amp; app.masterAddress.toUpper();			//cnwmc5 - 12/10/2012
	write "Send Email to: " &amp; toUser;
	
	str := app.myRoot.getConfig(SystemTitle).String;
	
	//if str.cnContains("DMAST") then
	//	str := str.replaceWord("DMAST", "EMAST");
	//endif;
		
	create sm;	
	sm.encodingType:=CM_SmtpConnection.Base64;
	sm.setLoggingRequired(true);

	sm.name			:= "smtp.cnw.co.nz";
	//sm.sendFrom		:= "JMTUnitTest@jadeworld.com";	
	
	///str := "cnwdmast@jadeworld.com";								// 04/10/2013 cnwmh5
	pos := 2;
	str := app.cnGetServerMiscPath()[3:end];
//write str;
	str := str[1:end].scanUntil("\", pos) &amp; "@jadeworld.com";
//write str;	
	sm.sendFrom		:= str;
	sm.sendTo		:= toUser.toLower;
//	str := app.myRoot.getConfig(SystemTitle).String;
	
	sm.subject		:=	"Test par 34068 ";
    sm.message		:=	"Si sottolinea che i dati  forniti  dal report in oggetto sono da considerarsi puramente stimati e la loro fedeltŕ strettamente dipendente da quanto inserito a sistem";
	

	app.writeLog("*****Sending email:" &amp; CrLf &amp;
		Tab &amp; "To: " &amp; sm.sendTo &amp; CrLf &amp; 
		Tab &amp; "From: " &amp; sm.sendFrom &amp; CrLf &amp;
		Tab &amp; "Subject: " &amp; sm.subject &amp; CrLf &amp;
		Tab &amp; "Message: " &amp; sm.message &amp; CrLf &amp;
		Tab &amp; "Via : " &amp; sm.name,
		LogINFO);

    sm.send; 

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="eprTestAPITransformOut" id="22caeaaa-2ed1-4e08-baa9-356cbd76faa1">
        <source>eprTestAPITransformOut();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 May 2023	jlier1	Initial creation

*/

vars
	apiMapper : CMIF_ApiMapper;
	jsonPostData: String;
	jdo : JadeDynamicObject;
	startDate : TimeStamp;
	json,errors, startUTC,endUTC : String;
	tso : TimeStampOffset;
	jj : JadeJson;
begin
	
	/*create jdo transient;
		
	jdo.addProperty("FreeSelect1_NoHeading",String);
	jdo.setPropertyValue("FreeSelect1_NoHeading","JBL");
	jdo.addProperty("LP_Truck",String);
	jdo.setPropertyValue("LP_Truck","ER23423");
	jdo.addProperty("AccesKey_RCN",String);
	jdo.setPropertyValue("AccesKey_RCN","32454");
	jdo.addProperty("AccesKey_RCN",String);
	jdo.setPropertyValue("AccesKey_RCN","32454");
	jdo.addProperty("AccesKey_StartDate",TimeStamp);
	jdo.setPropertyValue("AccesKey_StartDate",startDate);
	jdo.addProperty("AccesKey_EndDate",TimeStamp);
	jdo.setPropertyValue("AccesKey_EndDate",startDate.addDays(7));
	jdo.addProperty("DefaultKeyGroupCode",String);
	jdo.setPropertyValue("DefaultKeyGroupCode","Gate1");*/
	
	//tso.setFromLocalTimeStamp(startDate,tso.getUTCBias);
	create jj transient;
	startUTC:= jj.generateJson(startDate,JadeJson.Format_Json_Microsoft);
	tso.setFromLocalTimeStamp(startDate.addDays(7),tso.getUTCBias);
	endUTC:=jj.generateJson(tso,JadeJson.Format_Json_Newton);
	write startUTC;
	//jdo.deserializeJSON(json);
	
	json:='{ "FreeSelect1_NoHeading" : "JBL",
			  "LP Truck" : "ER23332",
			  "AccesKey_RCN" : "23440",
			  "AccesKey_StartDate" : ' &amp; startUTC &amp; ',"AccesKey_EndDate" : ' &amp; endUTC &amp;',"DefaultKeyGroupCode":"Gate1"}';
	
	
	write json;
	
	create apiMapper transient;
	jsonPostData := apiMapper.transformOutgoingMessage(CMIF_ApiMapper.CUSTOMER_EUP,"VehicleInspection",json,JadeHTTPConnection.Verb_POST,errors);
	
	write jsonPostData;
epilog
	delete apiMapper;
	delete jdo;
end;</source>
    </JadeMethod>
    <JadeMethod name="eprTestAuditText" id="ef6a7bab-d9f8-4000-a4f9-a23167127cb5">
        <source>eprTestAuditText();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 January 2019	jlger1	Initial creation

*/

vars
	auditObject : CM_AuditObject;
	aoi	: CM_AuditObjectImage;
	beforeTxt, afterTxt,
	before , after : String;
begin
	auditObject := " 3410.56724168".asOid.CM_AuditObject;
	beforeTxt:="allWorkOrderTransactions^0^^bolNumber^0^^dischargePort^5^GRAEF^estimatedEndTS^4^null^estimatedStartTS^4^null^imexStatus^1^2^loadPort^0^^myBerth^11^Berth - SEA^myCargoSubType^15^Product - ALAMB^myCargoType^19^Cargo Type - Aceros^myCommodity^4^null^myConsignee^25^Consignee Consignor - ALO^myConsignor^27^Consignee Consignor - GBCC1^myFreightForwarder^27^Consignee Consignor - ABFFD^myLocationsController^33^General Cargo Controller - 0202 2^myOperator^14^Operator - BGP^myPermitRequest^18^Wod Permit Request^myTrackedItem^4^null^myVoyageCargoRequest^4^null^myWorkOrderTransaction^4^null^myWorkpoint^4^null^numGangs^1^1^permitType^1^2^rkbmNumber^0^^specialStow^0^^totalQuantity^3^120^totalVolume^6^0.0000^totalWeight^10^11000.0000^transferType^1^1^weightCargo^6^0.0000^weightTare^6^0.0000^isComplete^2^No^myRelatedPermitRequest^4^null^myResourceUsed^4^null^myTowingVoyage^4^null^autoQueueTask^2^No^detailType^1^2^myParent^4^null^requiredByDT^4^null^startByDT^4^null^taskID^0^^";//^Additional Cargo Request ALIG^1018^allWorkOrderTransactions^0^^bolNumber^0^^dischargePort^5^DEAWR^estimatedEndTS^4^null^estimatedStartTS^4^null^imexStatus^1^2^loadPort^5^DEAWR^myBerth^11^Berth - SEA^myCargoSubType^30^Product - 12   9152445  75LAER^myCargoType^29^Cargo Type - Aluminium Ingots^myCommodity^24^Commodity - GENL General^myConsignee^27^Consignee Consignor - ABCDF^myConsignor^27^Consignee Consignor - GBCC1^myFreightForwarder^25^Consignee Consignor - CCS^myLocationsController^33^General Cargo Controller - 0202 2^myOperator^14^Operator - MSC^myPermitRequest^18^Wod Permit Request^myTrackedItem^4^null^myVoyageCargoRequest^4^null^myWorkOrderTransaction^4^null^myWorkpoint^4^null^numGangs^1^1^permitType^1^1^rkbmNumber^0^^specialStow^0^^totalQuantity^1^0^totalVolume^6^0.0000^totalWeight^6^0.0000^transferType^1^1^weightCargo^6^0.0000^weightTare^6^0.0000^isComplete^2^No^myRelatedPermitRequest^4^null^myResourceUsed^4^null^myTowingVoyage^4^null^autoQueueTask^2^No^detailType^1^2^myParent^4^null^requiredByDT^4^null^startByDT^4^null^taskID^0^^";
	afterTxt:="allWorkOrderTransactions^0^^bolNumber^0^^dischargePort^5^GRAEF^estimatedEndTS^4^null^estimatedStartTS^4^null^imexStatus^1^2^loadPort^0^^myBerth^11^Berth - SEA^myCargoSubType^15^Product - ALAMB^myCargoType^19^Cargo Type - Aceros^myCommodity^4^null^myConsignee^25^Consignee Consignor - ABO^myConsignor^27^Consignee Consignor - GBCC1^myFreightForwarder^27^Consignee Consignor - ABFFD^myLocationsController^33^General Cargo Controller - 0202 2^myOperator^14^Operator - BGP^myPermitRequest^18^Wod Permit Request^myTrackedItem^4^null^myVoyageCargoRequest^4^null^myWorkOrderTransaction^4^null^myWorkpoint^4^null^numGangs^1^1^permitType^1^2^rkbmNumber^0^^specialStow^0^^totalQuantity^3^130^totalVolume^6^0.0000^totalWeight^10^11000.0000^transferType^1^1^weightCargo^6^0.0000^weightTare^6^0.0000^isComplete^2^No^myRelatedPermitRequest^4^null^myResourceUsed^4^null^myTowingVoyage^4^null^autoQueueTask^2^No^detailType^1^2^myParent^4^null^requiredByDT^4^null^startByDT^4^null^taskID^0^^";
	write auditObject.auditText;
	create aoi transient;
	aoi.initialise(null, AuditUpdated, auditObject,auditObject.auditText , auditObject.postAuditText);
	aoi.getAuditText(before, after);
	write before;
	write after;
epilog
	delete aoi;
end;</source>
    </JadeMethod>
