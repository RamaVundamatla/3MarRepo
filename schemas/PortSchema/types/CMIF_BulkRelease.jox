    <JadeMethod name="getOperatorGroup" id="90778f48-bb15-4659-b260-142bd752c2fb">
        <source>getOperatorGroup() : CM_OperatorGroup protected;
// ---------------------------------------------------------------------------
// Created:     23 October 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	tmpOperatorGroup	: CM_OperatorGroup;
	
begin

	if self.operatorGroupCode &lt;&gt; null then
		tmpOperatorGroup := app.myRoot.allOperatorGroups[self.operatorGroupCode];
		if tmpOperatorGroup = null then
			app.raiseCMException1(ERR_INVALID_OPERATOR_GROUP, self.operatorGroupCode, 'operatorGroup', null);
		endif;
	endif;

	return tmpOperatorGroup;
	
end;</source>
        <access>protected</access>
        <ReturnType type="CM_OperatorGroup"/>
    </JadeMethod>
