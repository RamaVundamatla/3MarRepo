<Class name="CM_MachineType">
    <JadeMethod name="importPLXMLReference" id="46afd361-49ae-4373-985b-25fc57912a61">
        <source>importPLXMLReference(_name, _theCode, _referencesBlock: String): Object;

vars

begin
	if _name = CM_MachineType::myRoot.name then
		return app.myRoot;
	else
		return null;
	endif;
end;</source>
