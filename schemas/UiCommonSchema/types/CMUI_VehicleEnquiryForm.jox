    <JadeMethod name="setFilterValues" id="63fe330b-55a6-4491-ae8b-9aaa085f92c7">
        <updating/>
        <source>setFilterValues() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 October 2017	jlgndl1	Initial creation	TFS 7216

*/

vars

begin
	
	self.myFilterCarrier := self.cmbFiltCarr.listObject.CM_Carrier;
	if self.cmbFiltNA.listIndex = -1 then
		self.filterNA := 1; //default value of Available ONLY
	else
		self.filterNA := self.cmbFiltNA.itemData[ self.cmbFiltNA.listIndex ];
	endif;
	self.filterRegNo := tblSearch.getValueByName(ETRow_FilterRego).String.toUpper[1:12].removeTabCrLfs();
	self.filterState := tblSearch.getValueByName(ETRow_FilterState).String[1:10];
	
epilog

end;</source>
