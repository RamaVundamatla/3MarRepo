<Class name="CMIF_JsonInstructionEUP" id="7fa01eb8-2932-4d88-a1b1-be696aef7259">
    <superclass name="CMIF_JsonTransform"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="edi"/>
    <PrimAttribute name="code" id="5dccd6df-b4e3-438b-b42e-90f5543a7659">
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="description" id="20b68272-5ced-44cd-b157-3101f1086f02">
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="internalRemark" id="fd01d4ff-7337-46b1-bf39-6f9ec7f89775">
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="remark" id="d5b09365-8ecd-4da8-b73f-b19dc755488f">
        <type name="String"/>
    </PrimAttribute>
    <JadeMethod name="setFromInstrucitonsIssued" id="8ffdb7d7-f802-47e8-89b4-46ba0bcb18bd">
        <updating/>
        <source>setFromInstrucitonsIssued(_instruction : CM_InstructionsIssued) updating;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 24 July 2023
TFS#		: 55938
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/


begin
	self.code := _instruction.getInstructionCode();
	self.description := _instruction.getInstructionDesc();
	self.internalRemark := _instruction.internalInstructions;
	self.remark := _instruction.externalInstruction;
end;</source>
        <Parameter name="_instruction" type="CM_InstructionsIssued"/>
    </JadeMethod>
</Class>
