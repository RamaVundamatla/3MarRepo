    <JadeMethod name="jcc1Startup" id="75f1f4ea-3ba3-47d3-a4fa-2d6d70d733a4">
        <updating/>
        <source>jcc1Startup() updating;

begin
	startCreators;			app.doWindowEvents(60000);
	startRap;				app.doWindowEvents(10000);
	syncMasterThinbin;		app.doWindowEvents(10000);
	syncThinbin;			app.doWindowEvents(10000);
	startAppServers;		app.doWindowEvents(10000);
	startControllerApp;		app.doWindowEvents(10000);
	doPerfMonLogStart;		app.doWindowEvents(10000);
	startDriverApps;		app.doWindowEvents(10000);
end;</source>
