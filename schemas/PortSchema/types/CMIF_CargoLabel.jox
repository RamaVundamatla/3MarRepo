    <JadeMethod name="isVehicle" id="d020933d-5fdc-41b7-99a6-750590e60117">
        <source>isVehicle() : Boolean;
// 37549 return true if the cargo type is a vehicle
vars

	cargoType	: CM_CargoType;
	result		: Boolean;
	
begin

	if self.myTrackedItem &lt;&gt; null then
		cargoType := self.myTrackedItem.myCargoType;
		if cargoType &lt;&gt; null and
		   cargoType.productType = ProductType_Vehicle then
			result := true;
		endif;
	endif;
	
	return result;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setDetails" id="e2297254-131a-4ccf-8355-46ec825ea914">
        <updating/>
        <source>setDetails( _cargoObject : CM_Object;
			_cargoId : String;
			_myTerminal : CM_Terminal;
			_myQryReport : CM_QryReport;
			_myUser : CM_User
			) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 January 2010	cnwndl1	Initial creation	CCMS MES 1004

*/

vars

begin

	self.cargoId := _cargoId;
	
	if _cargoObject &lt;&gt; null then
		if _cargoObject.isKindOf(CM_TrackedItem) then
			self.myTrackedItem := _cargoObject.CM_TrackedItem;
		elseif _cargoObject.isKindOf(CM_BookingRef) then
			self.myBookingRef := _cargoObject.CM_BookingRef;
		elseif _cargoObject.isKindOf(CM_BOL) then
			self.myBOL := _cargoObject.CM_BOL;
		elseif _cargoObject.isKindOf(CMGTE_Receival) then
			self.myGateReceival := _cargoObject.CMGTE_Receival;
		elseif _cargoObject.isKindOf(CMGTE_ReceivalByType) then			// 10/12/2010 cnwmh5 #26556
			self.myGateReceivalByType := _cargoObject.CMGTE_ReceivalByType;
		endif;
	endif;
	
	self.myTerminal := _myTerminal;
	self.myQryReport := _myQryReport;
	self.myRequestingUser := _myUser;
	
epilog

end;</source>
        <Parameter name="_cargoObject" type="CM_Object"/>
        <Parameter name="_cargoId" type="String"/>
        <Parameter name="_myTerminal" type="CM_Terminal"/>
        <Parameter name="_myQryReport" type="CM_QryReport"/>
        <Parameter name="_myUser" type="CM_User"/>
    </JadeMethod>
</Class>
