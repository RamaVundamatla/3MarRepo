    <JadeMethod name="initDemoData" id="adc5d1b1-9058-40f3-9ae3-63fb2bf0cf81">
        <source>initDemoData();
// ---------------------------------------------------------------------------
// Created:     01 March 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
initDemoForRowAllocate();
return;

end;</source>
    </JadeMethod>
    <JadeMethod name="initDemoForRowAllocate" id="ba72bdb8-95bb-4c04-a3fe-7b675d151c16">
        <source>initDemoForRowAllocate();
// ---------------------------------------------------------------------------
// Created:     15 April 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	tblSelectionData.visible := true;
	txtDetails.visible := false;
	tblSelectionData.move(txtDetails.left, txtDetails.top, txtDetails.width, 
						  txtDetails.height);


	tblSelection.rows := 0;
	tblSelection.addAttribute('supplier', 'Supplier', Table.InputType_TextBox, 0, true);
	tblSelection.addAttribute('species', 'Species', Table.InputType_TextBox, 0, true);
	tblSelection.addAttribute('grade', 'Grade', Table.InputType_TextBox, 0, true);
	tblSelection.addAttribute('type', 'Type', Table.InputType_TextBox, 0, true);
	tblSelection.addAttribute('treatment', 'Treatment', Table.InputType_TextBox, 0, true);
	tblSelection.addAttribute('length', 'Length', Table.InputType_TextBox, 0, true);
	tblSelection.cnEcResizeContents();

	tblSelectionData.rows := 0;
	tblSelectionData.columns := 4;
	
	tblSelectionData.addItem('Row' &amp; Tab &amp; 'Mean SED' &amp; Tab &amp; 'Total Vol' &amp; Tab &amp; 'Available Vol');
	tblSelectionData.addItem('A12' &amp; Tab &amp; '17' &amp; Tab &amp; '700' &amp; Tab &amp; '700');
	tblSelectionData.addItem('B56' &amp; Tab &amp; '22' &amp; Tab &amp; '220' &amp; Tab &amp; '220');
	tblSelectionData.addItem('F23' &amp; Tab &amp; '14' &amp; Tab &amp; '1400' &amp; Tab &amp; '600');
	
	tblSelectionData.fixedRows := 1;

	tblActionData.addAttribute('volume', 'Volume To Allocate', Table.InputType_TextBox, 0, true);
	tblActionData.cnEcResizeContents();

	tblAllocated.rows := 0;
	tblAllocated.columns := 4;

	tblAllocated.addItem('Row' &amp; Tab &amp; 'Mean SED' &amp; Tab &amp; 'Total Vol' &amp; Tab &amp; 'Allocated Vol');
	tblAllocated.addItem('A12' &amp; Tab &amp; '17' &amp; Tab &amp; '800' &amp; Tab &amp; '600');
	
	tblAllocated.fixedRows := 1;
	
	txtRequired.text := '900';
	txtAllocated.text := '600';

end;</source>
    </JadeMethod>
