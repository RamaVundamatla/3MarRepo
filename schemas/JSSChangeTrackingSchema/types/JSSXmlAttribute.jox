        <Inverse name="JSSXmlElement::allAttributesByName"/>
    </ExplicitInverseRef>
    <PrimAttribute name="reference" id="cca61800-b5d3-4f39-861c-6a07552177c1">
        <length>31</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="attributeValueQuoted" id="47c0ec16-3bb2-4beb-b305-68e55a15203d">
        <source>attributeValueQuoted(): String;
/*
*/
begin
	if self.attributeValue.pos('"', 1) &gt; 0 then
		return ("'" &amp; self.attributeValue &amp; "'");
	else
		return ('"' &amp; self.attributeValue &amp; '"');
	endif;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="changeAttributeName" id="707ef606-b8e5-40c0-83ed-95ea79963f04">
        <updating/>
        <source>changeAttributeName(pNewAttributeName: String) updating;
/*
*/
begin
	attributeName := pNewAttributeName;
end;</source>
        <Parameter name="pNewAttributeName" type="String"/>
    </JadeMethod>
    <JadeMethod name="createAttribute" id="a35942aa-369f-4e21-9f52-8762adcc4558">
        <updating/>
        <source>createAttribute(pName: String; pValue: String; pMyElement: JSSXmlElement) updating;
/*
*/
vars
	entity: JSSXmlEntity;
	externalClass: Class;
begin
	self.attributeName := pName.trimBlanks;
	if pValue[1:1] = "&amp;" and pValue[pValue.length:1] = ";" then
		entity := pMyElement.myDocument.allEntitiesByName[pValue[2:pValue.length - 2]];
		if entity = null then
			self.attributeValue := pValue.trimBlanks;
		else
			self.attributeValue := entity.value;
			self.reference := pValue[2:pValue.length - 2];
		endif;
	else
		self.attributeValue := pValue.trimBlanks;
	endif;
	self.myElement := pMyElement;
end;</source>
        <Parameter name="pName" type="String"/>
        <Parameter name="pValue" type="String"/>
        <Parameter name="pMyElement" type="JSSXmlElement"/>
    </JadeMethod>
    <JadeMethod name="generateXmlString" id="f3fba466-9718-48eb-a86e-0e69fd82a71a">
        <source>generateXmlString(): String;
/*
*/
begin
	return(" " &amp; self.attributeName &amp; '=' &amp; self.attributeValueQuoted());
//	return(" " &amp; self.attributeName &amp; '="' &amp; self.attributeValue &amp; '"');
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
</Class>
