    <JadeMethod name="createQuickCargoGC" id="f180296e-6947-4870-aa79-0232fa80a07a">
        <updating/>
        <source>createQuickCargoGC(_lc : CM_IrregularBlockController; _numItems : Integer; _cargoType		: CM_CargoType) updating;
/*
Purpose:			
Date				Who			Reason
AUGUST 2011		CNWAB1		Initial creation
*/


vars

	aTerm : CM_Terminal;
	aRoot : CM_Root;
	aVoy : CM_Voyage;
	realTI,
	pxyTI			: CM_TrackedItem;
	cargoType		: CM_CargoType;
	passport		: CM_Passport;
	moveController	: CMIF_MoveController;
	state			: Integer;
	slot : CM_LocationsController;
	tmpID : String;
	subT : CM_SubTerminal;
	idx : Integer;
	commCode : String;
begin

 
	aTerm := self.myTerminal;
	aVoy	:= aTerm.getNullVoyage();
 
	//lets make cargo
	passport := app.myPassport;
	passport.setMyTerminal(aTerm);
	if _cargoType = null then
		cargoType	:= aTerm.getFirstNonSystemCargoType().CM_CargoType;
	else
		cargoType := _cargoType;
	endif;
	
	if not cargoType.allCommodities.isEmpty() and not cargoType.abbreviation = "CONT" then
		commCode := cargoType.allCommodities.first.code;
	else
		commCode := "GENL";
	endif;
//	cargoType := "2083.342".asOid.CM_CargoType; // BreakBulk
	state := TI_STATE_NORMAL;

	
	create moveController transient;
	foreach idx in 1 to _numItems do
		moveController.setMyToPrimaryLocation(_lc);
		tmpID := self.getNextQuickCargoID(cargoType.id);
		
		pxyTI := aTerm.createTI(cargoType, true);
		pxyTI.zSetPxyTerminal(aTerm);

		pxyTI.setCargoType(cargoType.id);
		pxyTI.setMyProduct(cargoType.allProducts.first);
		pxyTI.setMyOperator(app.myRoot.allOperators["MSC"]);
		if pxyTI.myOperator = null then
			pxyTI.setMyOperator(app.myRoot.allOperators["MSL"]);
		endif;
		if pxyTI.myOperator = null then
			pxyTI.setMyOperator(app.myRoot.allOperators.first);
		endif;
		pxyTI.setCommodity(commCode);
		pxyTI.setImExStatus(TI_IMEX_STATUS_EXPORT);
		pxyTI.setMyVoyage(aVoy, passport);
		pxyTI.changeState(state, passport);
		pxyTI.setWeight(12999, null,passport);
		pxyTI.setTotalWeight(12999, null,passport);
		pxyTI.setMyTotalVolume(1767);	// cnwdw1 27868
		//pxyTI.zSetPxyCompany(aTerm.getConfig(DefCompany).CM_Bank);
		pxyTI.zSetPxyCompany(aTerm.getDefaultCompanyBank);//17 Apr 2012 NDL	Par 29393
		pxyTI.zSetPxyDischargePort(aTerm.getConfig(PortDestCode).String);
		if app.isSubTerminalsOn(self.myTerminal) then
			subT := aTerm.getDefaultSubTerminal(CM_SubTerminal.Type_TrackedItem,
																	0,	
																	TI_IMEX_STATUS_IMPORT,
																	commCode,
																	true); 
			pxyTI.setSubTerminal(subT,null);
		endif;
		pxyTI.zSetPxyId(tmpID);
		app.myTrxCA.trxCreateTIWithMove(pxyTI, realTI, moveController, passport); // this deletes the pxyTI
	endforeach;

epilog

	delete moveController;

end;</source>
        <Parameter name="_lc" type="CM_IrregularBlockController"/>
        <Parameter name="_numItems" type="Integer"/>
        <Parameter name="_cargoType" type="CM_CargoType"/>
    </JadeMethod>
    <JadeMethod name="delete" id="ac07917b-56b4-49c9-8ec1-a8e2dfdb7d8d">
        <updating/>
        <source>delete() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 Jan 2025	navnk30	JIRA 19801: MTN - Audits on Terminal Area Definitions

*/

vars

begin
	self.resetAuditsDuringDelete();
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="findAllYABlockLocations" id="fec139c4-d3b7-4c2f-bdf6-441db30993e7">
        <source>findAllYABlockLocations(_topLeft, _bottomRight: CM_IrregularBlockController input; _locations: CM_LCArray io);
/*
Purpose:			
Date		Who		Reason
06 Sep 2013	cnwab1	Initial creation
23 Oct 2024	navdap1	MTN-19757 EUP* | FR 53485 - Warehouse Yard Allocation - Satellite view location selection issues
*/

vars
	startRow, endRow, startCol, endCol : Integer;
	lc : CM_LocationsController;
	shelf, theShelf : CM_RackShelfController;
	rack : CM_IrregularBlockController;
	allowFullGCArea : Boolean;		// MTN-19757
begin
	allowFullGCArea := self.getMyTerminal.getAutoPlanAllowFullGCArea;	// MTN-19757

	if _topLeft.isShelf then

		shelf := _topLeft.CM_RackShelfController;
		startCol := shelf.myLocation.region.first.x;
		startRow := shelf.myLocation.region.first.y;
		//epr par 35915 15/4/15
		if _bottomRight = null then
			shelf:=_topLeft.CM_RackShelfController;
			endCol:=startCol;
			endRow:=startRow;
		else
			shelf := _bottomRight.CM_RackShelfController;
			endCol := shelf.myLocation.region.last.x;
			endRow := shelf.myLocation.region.last.y;
		endif;
		
		// self.allLocationsControllers is racks only NO shelves
		foreach lc in self.allLocationsControllers discreteLock do
			rack := lc.CM_IrregularBlockController;
			if rack.region.first.x &lt; startCol 
			or rack.region.first.x &gt; endCol then
				continue;
			endif;
			if rack.region.first.y &lt; startRow 
			or rack.region.first.y &gt; endRow then
				continue;
			endif;
	 
			if rack.allSubLocations.isEmpty() then
			else
				//epr par 35915 15/4/15
				foreach theShelf in rack.allSubLocations discreteLock do
					if theShelf.locationOrdinal &gt;= _topLeft.locationOrdinal and
						theShelf.locationOrdinal &lt;= shelf.locationOrdinal then
						_locations.add(theShelf);
					endif;
				endforeach;
			endif;
		endforeach;
	
	else
		startCol := _topLeft.region.first.x;
		startRow := _topLeft.region.first.y;
		//epr par 35915 15/4/15
		if _bottomRight = null then
			endCol:=startCol;
			endRow:=startRow;
		else
			endCol := _bottomRight.region.last.x;
			endRow := _bottomRight.region.last.y;
		endif;
		// self.allLocationsControllers is racks only NO shelves
		foreach lc in self.allLocationsControllers discreteLock do
			rack := lc.CM_IrregularBlockController;
			if rack.region.first.x &lt; startCol 
			or rack.region.first.x &gt; endCol then
				continue;
			endif;
			if rack.region.first.y &lt; startRow 
			or rack.region.first.y &gt; endRow then
				// MTN-19757 another condition to catch little areas that are first in y but not first in x
				// or last in y but not last in x
				if allowFullGCArea and (rack.region.first.y + 1 = startRow) and _topLeft &lt;&gt; _bottomRight then
					// add it in
				elseif allowFullGCArea and rack.region.last.y &gt; endRow and _topLeft &lt;&gt; _bottomRight then
					// add it in
				else
					continue;
				endif;
			endif;
			
			if rack.allSubLocations.isEmpty() then
				_locations.add(rack);
			else
				rack.allSubLocations.copy(_locations);
			endif;
		endforeach;
	endif;
epilog

end;</source>
        <Parameter name="_topLeft" type="CM_IrregularBlockController" usage="input"/>
        <Parameter name="_bottomRight" type="CM_IrregularBlockController" usage="input"/>
        <Parameter name="_locations" type="CM_LCArray" usage="io"/>
    </JadeMethod>
    <JadeMethod name="findLocation" id="16ff3a38-591c-47ab-94b4-90159041bcb4">
        <source>findLocation(_strs: StringArray; _noException : Boolean; _foundLC: CM_LocationsController io; _foundHeight: Integer io);
// Find the location with a id of _strs.first 
vars
	tStr : String;
	lc : CM_LocationsController;
	shelfString : String;
	rackLC : CM_IrregularBlockController;
	
begin
	//20 Feb 2014	NDL	Par 33550
	//inheritMethod(_strs, _noException, _foundLC, _foundHeight);
	_foundLC := null;	//20 Feb 2014	NDL	Par 33550
	_foundHeight := NULLINDEX;	//20 Feb 2014	NDL	Par 33550
	
	if _strs.isEmpty then
		return;
	endif;
	tStr := _strs[1].trimBlanks;

	if tStr = null then
		return;
	endif;	
	
	foreach lc in self.allLocationsControllers do
		if lc.getID() = tStr then
			_foundLC := lc;
			break;
		endif;
	endforeach;	
	
	//23 Aug 2013	NDL	Par 32308
	if _foundLC &lt;&gt; null and _foundLC.isRack then
		rackLC := _foundLC.CM_IrregularBlockController;
		
		if _strs.size &gt; 1 then
			_foundLC := null; //epr par 35915 13/4/15
			shelfString := _strs[2].trimBlanks;
			foreach lc in rackLC.allSubLocations do
				if lc.ident = shelfString then
					_foundLC := lc;
					break;
				endif;
			endforeach;
		endif;
	endif;
epilog

end;</source>
        <Parameter name="_strs" type="StringArray"/>
        <Parameter name="_noException" type="Boolean"/>
        <Parameter name="_foundLC" type="CM_LocationsController" usage="io"/>
        <Parameter name="_foundHeight" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="findLocationFromString" id="7e8b1499-6917-42a8-95b2-2b7326f35012">
        <source>findLocationFromString(_locnStr : String; _foundLC: CM_LocationsController output);
/*
Purpose:			
Date		Who		Reason
06 September 2013	cnwab1	Initial creation
*/

vars
	lc : CM_LocationsController;

begin
	
	foreach lc in self.allLocationsControllers do
		if lc.getID() = _locnStr then
			_foundLC := lc;
			break;
		endif;
	endforeach;	
epilog

end;</source>
        <Parameter name="_locnStr" type="String"/>
        <Parameter name="_foundLC" type="CM_LocationsController" usage="output"/>
    </JadeMethod>
    <JadeMethod name="findYABlock" id="59a15360-dce5-46a7-aed1-390a17ac1896">
        <source>findYABlock(_locationText: String; _topLeftLC: CM_LocationsController output; _bottomRightLC: CM_LocationsController output; _taViewPos : CM_TerminalAreaViewPosition): Boolean;
//16 February 2009	cnwdw1	
//

// VALID YA Location String values - 
// GC03 FLAT 			This is a single Irregular LC, if it is a rack then it auto means all shelves in that rack
// GC03 R1-R22		This is a block of Irregular LCs, if they are racks then it auto means all shelves in that rack
// GC03 R1 02-05		This is a single Rack with shelves 02 to 05
// GC03 R1-R22 02-05	This is a block of Irregular LCs, if they are racks then with shelves 02 to 05

//16 Jun 2022 	navhl20		TFS 53765 EUP - Warehouse Yard Allocation Desktop Application
//11 May 2023	navdap1		TFS 57711 FR | 53485 EUP - Warehouse Yard Allocation - Satellite view location selection issues

vars
	text: StringArray;
	rackRange : StringArray;
	shelfRange : StringArray;
	height: Integer;
	bottomShelfLC : CM_LocationsController;
	x1, y1, z1 : Integer;
	allRacks : CM_IrregularBlockLCsByRegion;
	lc 	: CM_LocationsController;
	rack : CM_IrregularBlockController;
begin

	_topLeftLC := null;
	_bottomRightLC := null;
	
	//15Feb2023 navsp1 TFS 56543
	//Find lowest and highest x,y co-ordinates
	create allRacks transient;
	foreach lc in self.allLocationsControllers discreteLock do
		rack := lc.CM_IrregularBlockController;		
		rack.getSortKeys(x1, y1, z1);
		allRacks.putAtKey(x1, y1, z1, rack);
	endforeach;
	_topLeftLC := allRacks.first;				// TFS 57711
	_bottomRightLC := allRacks.last;			// TFS 57711
	
	if _locationText &lt;&gt; null then
		text := _locationText.trimBlanks.cnGetTokens(" ");	//23 Aug 2013	NDL	Par 32308
		
		rackRange :=  text[1].trimBlanks.cnGetTokens("-");	
		if text.size = 2 then
			shelfRange :=  text[2].trimBlanks.cnGetTokens("-");	
		endif;
		
		if rackRange.size = 2 then
			if shelfRange &lt;&gt; null then
				self.findLocationFromString(rackRange[1], _topLeftLC);
				_topLeftLC := _topLeftLC.CM_IrregularBlockController.getSubLocationFromString(shelfRange[1]);
				self.findLocationFromString(rackRange[2], _bottomRightLC);
				//epr par 35915 15/4/15
				if shelfRange.size = 1 then
					bottomShelfLC := _bottomRightLC.CM_IrregularBlockController.getSubLocationFromString(shelfRange[1]);
				else
					bottomShelfLC := _bottomRightLC.CM_IrregularBlockController.getSubLocationFromString(shelfRange[2]);
				endif;
				if bottomShelfLC = null then
					bottomShelfLC:=_bottomRightLC.CM_IrregularBlockController.allSubLocations.last;
				endif;
				if bottomShelfLC &lt;&gt; null then
					_bottomRightLC:=bottomShelfLC;
				endif;	
			else
				self.findLocationFromString(rackRange[1], _topLeftLC);
				self.findLocationFromString(rackRange[2], _bottomRightLC);
			endif;
		else
			self.findLocation(text, true, _topLeftLC, height);
			_bottomRightLC := _topLeftLC;
		endif;
	endif;
	return _topLeftLC &lt;&gt; null;
epilog
	delete text;
	delete rackRange;
	delete shelfRange;
	delete allRacks;			//15Feb2023 navsp1 TFS 56543
end;</source>
        <Parameter name="_locationText" type="String"/>
        <Parameter name="_topLeftLC" type="CM_LocationsController" usage="output"/>
        <Parameter name="_bottomRightLC" type="CM_LocationsController" usage="output"/>
        <Parameter name="_taViewPos" type="CM_TerminalAreaViewPosition"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getAllLCsWithCargo" id="5bfcac73-3919-4a7f-b805-f5bf09e5431a">
        <source>getAllLCsWithCargo(_locationControllerArray: ObjectArray io);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 December 2014	cnwndl1	Initial creation	Par 35295

*/

vars
	locController : CM_LocationsController;
	irregCont : CM_IrregularBlockController;
	rackShelf : CM_RackShelfController;
begin
	
	foreach locController in self.allLocationsControllers discreteLock do
		// sub controllers can have cargo too.
		if locController.isKindOf( CM_IrregularBlockController) then
			irregCont := locController.CM_IrregularBlockController;
			foreach rackShelf in irregCont.allSubLocations discreteLock do
				// no tracked items then don't require it
				if rackShelf.allTrackedItems.isEmpty then
					continue;
				endif;
				// if not already in the array then add to the array
				if not _locationControllerArray.includes(rackShelf) then
					_locationControllerArray.add(rackShelf);
				endif;
			endforeach;
		endif;
	
		// no tracked items then don't require it
		if locController.allTrackedItems.isEmpty then
			continue;
		endif;
		// if not already in the array then add to the array
		if not _locationControllerArray.includes(locController) then
			_locationControllerArray.add(locController);
		endif;
	endforeach;
	
epilog

end;</source>
        <Parameter name="_locationControllerArray" type="ObjectArray" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getAllLocationsControllers" id="615475ac-cc91-491a-87f5-3284eca02e37">
        <source>getAllLocationsControllers(_locationControllerArray: ObjectArray io);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 August 2013	cnwndl1	Initial creation

*/

vars

	locController : CM_LocationsController;
	shelf : CM_RackShelfController;

begin

	inheritMethod(_locationControllerArray);
	
	foreach locController in self.allLocationsControllers discreteLock do
		// no tracked items then don't require it
		if not locController.isRack then
			continue;
		endif;
		// if not already in the array then add to the array
		foreach shelf in locController.CM_IrregularBlockController.allSubLocations discreteLock do
			if not _locationControllerArray.includes(shelf) then
				_locationControllerArray.add(shelf);
			endif;
		endforeach;
	endforeach;

epilog

end;</source>
        <Parameter name="_locationControllerArray" type="ObjectArray" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getAllLocationsTrackedItems" id="ac6b7c15-020b-43d2-a657-192ce549d714">
        <source>getAllLocationsTrackedItems(_objectSet: Collection input);
/*
Purpose:			
Date		Who		Reason
17 September 2013	cnwab1	Initial creation
17/9/25  			 jlier1 MTN-35637
*/

vars
	locationControllerArray: ObjectArray;
	lc : CM_LocationsController;
	obj : Object;
begin

	create locationControllerArray transient;
	
	self.getAllLCsWithCargo(locationControllerArray);
	
	foreach obj in locationControllerArray discreteLock do
		lc := obj.CM_LocationsController;
		
		lc.allTrackedItems.copy(_objectSet);
	
	endforeach;
 

epilog
	delete locationControllerArray;
end;</source>
        <Parameter name="_objectSet" type="Collection" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getAuditChildSubjects" id="cad3644c-7230-4400-a05f-be883919a1e1">
        <source>getAuditChildSubjects(_childAuditSubjectNames: StringArray input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 Jan 2025	navnk30	JIRA 19801: MTN - Audits on Terminal Area Definitions

*/

vars
	locController	: CM_LocationsController;
begin
	inheritMethod(_childAuditSubjectNames);
	foreach locController in self.allLocationsControllers do
		_childAuditSubjectNames.add(locController.asStringJMT());
	endforeach;
epilog

end;</source>
        <Parameter name="_childAuditSubjectNames" type="StringArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getAuditText" id="3c59f62a-4d35-4cbb-9bb5-c4dace620c82">
        <source>getAuditText(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 Jan 2025	navnk30	JIRA 19801: MTN - Audits on Terminal Area Definitions

*/

vars
	auditText 		: String;
	locController	: CM_LocationsController;
begin
	auditText[10000] := "*";
	auditText := null;
	auditText := inheritMethod();
	
	foreach locController in self.allLocationsControllers do
		auditText := auditText &amp; locController.getAuditText();
	endforeach;
	return auditText;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDefaultColumnLabels" id="664c67d8-229c-464d-9cfa-4d2892c0c459">
        <source>getDefaultColumnLabels(columnLabels : StringArray);
// Create collection of default labels
// If necessary add new defaults to the end of an existing collection of labels
vars
	indexes : IntegerArray;
	i : Integer;
begin
	create indexes transient;
	indexes[1] := 0;
	indexes[2] := 0;
	indexes[3] := 0;
	foreach i in 1 to self.columns do
		if i &gt; columnLabels.size then
			columnLabels[i] := (indexes[1]+65).Character &amp; (indexes[2]+65).Character &amp; (indexes[3]+65).Character;
			if self.columns &lt;= 26 then
				columnLabels[i] := columnLabels[i][3];
			elseif self.columns &lt;= 676 then
				columnLabels[i] := columnLabels[i][2] &amp; columnLabels[i][3];
			endif;
		endif;
		// Do some base 26 arithmetic
		indexes[3] := indexes[3] + 1;
		if indexes[3] = 26 then
			indexes[3] := 0;
			indexes[2] := indexes[2] + 1;
			if indexes[2] = 26 then
				indexes[2] := 0;
				indexes[3] := indexes[3] + 1;
			endif;
		endif;
	endforeach;
end;
</source>
        <Parameter name="columnLabels" type="StringArray"/>
    </JadeMethod>
    <JadeMethod name="getDefaultRowLabels" id="8227bc90-68b3-4ebf-96de-dfd2b411eb45">
        <source>getDefaultRowLabels(rowLabels : StringArray);
// Create a collection a row labels.
// If necessary add new defaults to the end of an existing collection of labeks
vars
	i : Integer;
	length : Integer;
begin
	length := self.rows.String.length();
	foreach i in 1 to self.rows do
		if rowLabels.size &lt; i then
			rowLabels[i] := i.String.cnEcPadzeros(length);
		endif;
	endforeach;
end;
</source>
        <Parameter name="rowLabels" type="StringArray"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="0290a000-2b85-42c9-87ea-77595bd19af8">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 August 2009	cnwer1	Initial creation

*/

vars

begin
	if _attrName = ETRow_NumberOfRows then
		return self.rows.asStringJMT;
	elseif  _attrName = ETRow_NumberOfCols then
		return self.columns.asStringJMT;
	elseif _attrName = ETRow_Unit then
		return self.unit.asStringJMT;
	else
		return inheritMethod(_attrName, _short);
	endif;

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getIncrementedLocationName" id="5dcaaafc-0bd9-4818-b39b-41e5a041debf">
        <source>getIncrementedLocationName( _str : String ):String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 August 2013	cnwndl1	Initial creation	Par 32308

*/

vars

	pos : Integer;
	char : Character;
	baseString : String;
	intArray : IntegerArray;
	lc : CM_LocationsController;
	stringEnd : String;

begin

	foreach pos in 1 to _str.length do
		char := _str[pos].Character;
		if char.isAlpha then
			baseString := baseString &amp; char.String;
		endif;
	endforeach;
	
	create intArray transient;
	foreach lc in self.allLocationsControllers do
		if lc.ident.pos(baseString,1) &lt;&gt; 1 then
			continue;
		endif;
		if lc.ident = baseString then
			continue;
		endif;
		stringEnd := lc.ident[baseString.length + 1:end].trimBlanks;
		if stringEnd.isInteger then
			intArray[stringEnd.Integer] := stringEnd.Integer;
		endif;
	endforeach;
	
	
	foreach pos in 1 to intArray.size do
		if intArray[pos] &lt;&gt; pos then
			return baseString &amp; pos.String;
		endif;
	endforeach;
	
	return baseString &amp; (intArray.size + 1 ).String;

epilog

	delete intArray;

end;</source>
        <Parameter name="_str" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getLCSet" id="a534b1d9-4515-4196-82ae-2c6cf90b1a7e">
        <source>getLCSet(): CM_LCSet;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 June 2014	cnwrd1	Initial creation for par 34211

*/

vars
	primaryController,
	subController 		: CM_LocationsController;
	lcSet : CM_LCSet;
begin
	create lcSet transient;
	
	foreach primaryController in self.allLocationsControllers do
		lcSet.add(primaryController);
		
		if primaryController.isKindOf(CM_IrregularBlockController) then
			foreach subController in primaryController.CM_IrregularBlockController.allSubLocations do
				lcSet.add(subController);
			endforeach;
		endif;
	
	endforeach;
	
	return lcSet;
end;</source>
        <ReturnType type="CM_LCSet"/>
    </JadeMethod>
    <JadeMethod name="getLocationRegions" id="7593e6ef-49a4-4678-a5fb-53d85cb2dcbe">
        <source>getLocationRegions(regions : ObjectArray io);
// Return the collection of location regions in this area
vars
	location: CM_LocationsController;
	region: PointArray;
begin
	foreach location in self.allLocationsControllers do
		create region transient;
		location.CM_IrregularBlockController.region.copy(region);
		regions.add(region);
	endforeach;
end;
</source>
        <Parameter name="regions" type="ObjectArray" usage="io"/>
    </JadeMethod>
