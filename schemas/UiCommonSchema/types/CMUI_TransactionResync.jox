    <JadeMethod name="createInvoiceAlert" id="d8075df0-d7b8-41f5-b200-379759eb605e">
        <updating/>
        <source>createInvoiceAlert() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 May 2022	navsj20	TFS 53522

*/

vars
	alert: CM_SystemAlert;  
	_detail: String;		
begin
	create alert transient;
	_detail := getInvoiceAlertDetails(); 
	alert.details := app.getErrorString(Split_Or_Merge_Trans_Resynced) &amp; CrLf &amp; _detail;
	alert.addLogEntry(_detail);
	alert.setSeverity(SEVERE_WARNING);
	alert.setMySystemAlertType(app.myRoot.allSystemAlertTypes[EVENT_AT_INVOICE]);
	alert.add;
	app.commitAlert();
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doBtnSaveClick" id="a523eeeb-5070-40c2-ab80-113121a94c61">
        <updating/>
        <source>doBtnSaveClick() updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 04/06/2019	jlgdap1		Initial creation TFS 44554 AAT Stevedore Data Access
//20/09/2019 	JLGNS1		Bug 46339 JMT - Event transaction does not resync
//19 Sep 2022 	navsj20		Bug 54864: MTN - Resync Event Transaction Issue
//04 Apr 2023	navmk20		Task 57433: Country of Origin - Transactions Resync
//20/06/2023	navkc1		CR 55653 Task 58724: EUP - Re evaluate Contract Id

vars
	txn : CM_Transaction;
	controller : CMIF_TiTransactionResync;
	logger	: CMIF_Logger;
	returnValue : Integer;
	voyage : CM_Voyage;											//navra1 - TFS 65376 - 31st July 2024 - 1
	trans : CM_Transaction;										//navra1 - TFS 65376 - 31st July 2024 - 1
	voyageProgress : CM_VoyageProgress;							//navra1 - TFS 65376 - 31st July 2024 - 1
	trackedItem : CM_TrackedItem;								//navra1 - TFS 65376 - 31st July 2024 - 1

begin
	create controller transient;
	
	controller.myTrackedItem := self.myTrackedItem;
	controller.updateBusinessUnit := self.chkRPbusUnit.value;
	controller.updateCommodity := self.chkRPcomm.value;
	controller.updateConsignee := self.chkRPcon.value;
	controller.updateConsignor := self.chkRPconor.value;
	controller.updateContents := self.chkRPcontents.value;
	controller.updateCustomsAgent := self.chkRPcustAg.value;
	controller.updateDestinationPort := self.chkRPdestPort.value;
	controller.updateDischargePort := self.chkRPdischPort.value;
	controller.updateImexStatus := self.chkRPimex.value;
	controller.updateOperator := self.chkRPoperator.value;
	controller.updateQuantity := self.chkRPquantity.value;
	controller.updateVolume := self.chkRPvolume.value;
	controller.updateLength := self.chkRPLength.value; // PAR 31615
	controller.updateWeight := self.chkRPweight.value;
	controller.updateFreightForwarder := self.chkRPfreightForwarder.value;	//Bug 38935
	controller.updateStevedore := self.chkRPstevedore.value;
	controller.updateTrailerType := self.chkRPtrailerType.value;	//29 Oct 2020	NDL	TFS 50113
	controller.updateShippingLine := self.chkRPshippingLine.value; // ### TFS BUG 56663 23FEB2023 NAVAB1
	controller.updateCountryOfOrigin := self.chkRPCountryOfOrigin.value; // 4.4.2023 navmk20 TFS 57433
	controller.updateContractId := self.chkRPContractId.value;	//20/06/2023	navkc1	CR 55653 Task 58724
	controller.updateHsCode := self.chkRPHSCode.value; //04/10/2024	navkc1	JIRA 32999
	controller.readonly := self.chkReadOnly.value;  // ### TFS 2682
	controller.logging := self.chkRPLog.value;
	if controller.logging then
		create logger transient;
		app.setLogger(logger);
	endif;
	
	self.allTransactions.copy(controller.allTransactions);
	self.myParentForm.CMUI_TransactionEnquiry.setupNotesForTransactions(controller);
	
	while true do
		app.myTrxUA.trxUpdateRsyncTrans(controller, app.myPassport);
		if app.myPassport.trxCompletedOK then
			global.beep;
			//navsj20 TFS 53522
			if self.myTerminal.getConfig(AllowTransResyncForAmt).Boolean and controller.myTrackedItem &lt;&gt; null and controller.myTrackedItem.hasSplitOrMergeTrans 	//19 Sep 2022	navsj20	TFS 54864
			and (controller.updateVolume or controller.updateWeight or controller.updateQuantity) then
				createInvoiceAlert();
			endif;
			//navsj20 TFS 53522
			break;
		else
			returnValue := app.showErrorWarningDialog("Transaction Resync", app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   returnValue = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			return;
		endif;
		break;
	endwhile;
	
	if app.myPassport.trxCompletedOK then
		txn := controller.allTransactions.last;
		if txn &lt;&gt; null then
			self.myParentForm.CMUI_TransactionEnquiry.endNotification(txn, self.myTerminal.getTerminalEvent(EVENT_TRAN_RESYNC));
		endif;
		if not self.chkReadOnly.value then
			self.setupFormControls;//BUG 46339 
		endif;
	endif;
	if logger &lt;&gt; null then
		self.doShowInvoiceLogging(logger);
	endif;

epilog
	delete controller;
	if logger &lt;&gt; null then
		app.setLogger(null);	// this deletes the 'logger' instance
	endif;
	
	//navra1 - MTN-34829 - 8th May 2025
	/*//navra1 - TFS 65376 - 31st July 2024 - 1 start
	foreach trans in self.allTransactions as CM_Transaction do
		if trans.isKindOf(CM_TITransaction) then
			voyage := trans.CM_TITransaction.getVoyage();
			trackedItem := trans.CM_TITransaction.myTrackedItem;
			if voyage &lt;&gt; null and trackedItem  &lt;&gt; null then
				break;
			endif;
		endif;
	endforeach;	
	if voyage &lt;&gt; null and voyage.myVoyageProcess &lt;&gt; null and voyage.myVoyageProcess.isAutomaticProcess() then
		if trackedItem &lt;&gt; null then
			voyageProgress := voyage.myVoyageProgress;
			if voyageProgress &lt;&gt; null and voyageProgress.pauseProgress &lt;&gt; true then										//navra1 - CR 65823 - 6th Sep 2024
				voyageProgress.progressStage(CM_VoyageStage.VoyStage_InvoiceGenerated, null, trackedItem.myOperator);
			endif;
		endif;
	endif;
	//navra1 - TFS 65376 - 31st July 2024 - 1 end*/
	//navra1 - MTN-34829 - 8th May 2025
end;</source>
    </JadeMethod>
    <JadeMethod name="doShowInvoiceLogging" id="d83dd7d7-c372-463f-9659-b400a2933c0c">
        <source>doShowInvoiceLogging(_logger : CMIF_Logger) protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 04/06/2019	jlgdap1		Initial creation TFS 44554 AAT Steverdore Data Access
//20/09/2019 	JLGNS1	Bug 46339 JMT - Event transaction does not resync
vars
	captionText : String;
	transType : String;
	dateTime : TimeStamp;
	lDetails : CMUI_SystemAlertsDetails;
	dataContainer : CM_DataContainer;
	tableAgent : CMUI_TableAgent;
	trans : CM_Transaction;

begin
	if _logger = null then
		return;
	endif;
	
	// Update the navigator
	self.setNavigatorHeading("Charging"); 
	create lDetails;
	create dataContainer transient;
	
	_logger.getLogsAsBlocks(dataContainer);
	
	lDetails.centreWindow();
	
	create tableAgent transient;
	dataContainer.headerColour	:=	self.colorHeadingColumn;
	dataContainer.valueColour	:=	self.colorValueColumn;
	dataContainer.displayMode	:=	2;
	trans := self.allTransactions.first.CM_Transaction;				//BUG 46339 
	captionText := "Charge logging ";
	if trans &lt;&gt; null then
		captionText := captionText &amp; "for ";
		if trans.isKindOf(CM_TITransaction) and
		   trans.CM_TITransaction.myTrackedItem &lt;&gt; null then
			captionText := captionText &amp; trans.CM_TITransaction.myTrackedItem.id &amp; " ";
		endif;
		if trans.isKindOf(CM_EventTransaction) then
			transType := trans.CM_EventTransaction.getName();
			dateTime := trans.CM_EventTransaction.dateTime;
		elseif trans.isKindOf(CM_TITransaction) then
			transType := trans.CM_TITransaction.typeString;
			dateTime := trans.CM_TITransaction.dateTime;
		elseif trans.isKindOf(HMS_VTMISTransaction) then
			transType := app.myRoot.allTransactionTypes[Trans_Type_ResourceCharged].description;
			dateTime := trans.HMS_VTMISTransaction.transactionDT;
		endif;
		captionText := captionText &amp; transType &amp; " " &amp; dateTime.asStringJMT;
	endif;
	lDetails.show();
	lDetails.displayMode := CMUI_SystemAlertsDetails.DisplayMode_TransactionLog;
	lDetails.setCaption(captionText);
	tableAgent.addDataToTable(	dataContainer,
								lDetails.tblAlerts,
								true,
								2,
								false,
								1,
								1,
								1,
								1, 
								CMUI_SystemAlertsDetails.DisplayMode_TransactionLog,
								true);	

	lDetails.setMyTerminal(self.myTerminal);

epilog
	delete tableAgent;
	delete dataContainer;
end;</source>
        <access>protected</access>
        <Parameter name="_logger" type="CMIF_Logger"/>
    </JadeMethod>
    <JadeMethod name="getInvoiceAlertDetails" id="8a36b26c-787e-4ec6-b6c3-40943f9b036c">
        <updating/>
        <source>getInvoiceAlertDetails(): String updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 May 2022	navsj20	TFS 53522

*/


vars
	invoiceAlertDetails : String;
	transType : String;
	dateTime : TimeStamp;
	trans : CM_Transaction;
begin
	foreach trans in self.allTransactions as CM_Transaction do
	//trans := self.allTransactions.first.CM_Transaction;				 
	if trans &lt;&gt; null then
		if trans.isKindOf(CM_TITransaction) and
		   trans.CM_TITransaction.myTrackedItem &lt;&gt; null then
			invoiceAlertDetails &amp;= trans.CM_TITransaction.myTrackedItem.id &amp; " ";
		endif;
		if trans.isKindOf(CM_EventTransaction) then
			transType := trans.CM_EventTransaction.getName();
			dateTime := trans.CM_EventTransaction.dateTime;
		elseif trans.isKindOf(CM_TITransaction) then
			transType := trans.CM_TITransaction.typeString;
			dateTime := trans.CM_TITransaction.dateTime;
		elseif trans.isKindOf(HMS_VTMISTransaction) then
			transType := app.myRoot.allTransactionTypes[Trans_Type_ResourceCharged].description;
			dateTime := trans.HMS_VTMISTransaction.transactionDT;
		endif;
		invoiceAlertDetails &amp;= " " &amp; transType &amp; " " &amp; dateTime.asStringJMT &amp; CrLf;
	endif;
	endforeach;
	return invoiceAlertDetails;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setTIAndTransactions" id="ee55f644-0a6e-48a0-8a39-da58ba663e4b">
        <updating/>
        <source>setTIAndTransactions(_ti : CM_TrackedItem; _objArray : ObjectArray; _mode : Integer) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 04/06/2019	jlgdap1		Initial creation TFS 44554 AAT Stevedore Data Access
//
vars

begin
	self.myTrackedItem := _ti;
	_objArray.copy(self.allTransactions);
	self.mode := _mode;
epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_objArray" type="ObjectArray"/>
        <Parameter name="_mode" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="bcfbc942-c942-445f-a0e2-b692fc45e6f8">
        <updating/>
        <source>setupForm() updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 04/06/2019	jlgdap1		Initial creation TFS 44554 AAT Stevedore Data Access
//20/09/2019 	JLGNS1		Bug 46339 JMT - Event transaction does not resync

vars

begin
	inheritMethod();
	
	self.doResyncWarning := true;	//12 Mar 2020	NDL	TFS 48847
	self.setupFormControls();
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupFormControls" id="bd0bf520-6248-4a7b-8487-fb51a9167865">
        <updating/>
        <source>setupFormControls() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 September 2019		jlgns1	Initial creation
//20/09/2019 	JLGNS1	Bug 46339 JMT - Event transaction does not resync
*/

vars

begin
    if self.mode = CMUI_TransactionEnquiry.Mode_CargoItem_Enquiry 
	or self.mode = CMUI_TransactionEnquiry.Mode_Cargo_Transaction_Enquiry then
		self.setupFormForCargo();
	else
		self.setupFormForOthers();
	endif;
	
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.btnSave.enabled := false;
		self.frmResync.enabled := false;
		self.btnSelectAll.enabled := false;
	endif;
end;
</source>
    </JadeMethod>
    <JadeMethod name="setupFormForCargo" id="ebb5b95b-3817-48d8-be29-62f058bba8bf">
        <updating/>
        <source>setupFormForCargo() updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 04/06/2019	jlgdap1		Initial creation TFS 44554 AAT Stevedore Data Access
// 04/03/2020   cnwma1		Bug 48772: ADP - RE: Resyncing Issue in Production
// 05/04/2023	navmk20		Task 57433: Country of Origin - Transactions Resync
// 20/06/2023	navkc1		CR 55653 Task 58724: EUP - Re evaluate Contract Id
// 04/10/2024	navkc1		JIRA 32999 POB - Add HSCode to Transaction Resync
//
constants
	Blank = "    ";
	Multi = "****";
	
vars
	toolTip1, 
	toolTip2 		  : String;
	allChildControls  : CnEcControlArray;
	control			  : Control;
	anObj 			  : Object;
	txn 			  : CM_TITransaction;
	ti 				  : CM_TrackedItem;
	packUnpackWarning : Boolean; 
	tiArray			  : ObjectArray;
	measureType 	  : CM_MeasurementType;
	priorValue 		  : Real;
	displayValue 	  : String;
	canBeResynced : Boolean;	//11 Mar 2020	NDL	TFS 48847
	msg : String;	//11 Mar 2020	NDL	TFS 48847
	trxObj : Object;	//11 Mar 2020	NDL	TFS 48847
	shippingLine : String;
	countryOfOriginDesc : String; //5.4.2023 navmk20 TFS 57433
	
begin
	toolTip2 := app.getErrorString5(TranEnqToolTip2, Cr, Cr&amp;Tab, Cr, "'     '", "'****'");
	toolTip1 := app.getErrorString4(TranEnqToolTip1, Cr, Cr&amp;Tab, "'     '", "'****'");
	
	create allChildControls transient;
	self.frmResync.cnEcGetAllChildControls(allChildControls, false);
	//self.frmResync.height := 466;		// 5.4.2023 navmk20 TFS 57433
	//self.frmResync.height := 485; 		// 5.4.2023 navmk20 TFS 57433
	//self.frmResync.height := 500;		//20/06/2023	navkc1	CR 55653 Task 58724
	self.frmResync.height := 550;		//04/10/2024	navkc1	JIRA 32999
	
	self.btnSelectAll.visible := true;
	foreach control in allChildControls do
		if control.name = self.chkRPLog.name then
			control.top := self.frmResync.height - 40;
			self.chkReadOnly.top := self.chkRPLog.top;
			self.chkReadOnly.enabled := self.chkRPLog.value;
		else
			if control.isKindOf(CheckBox) then
				control.CheckBox.value:=false;
			endif;
		endif;
		control.visible := true;
	endforeach;

	if self.lblRPBusUnitT.bubbleHelp &lt;&gt; toolTip2  then
		self.lblRPBusUnitT.bubbleHelp := toolTip2;
		self.lblRPcommT.bubbleHelp := toolTip2;
		self.lblRPconT.bubbleHelp := toolTip2;
		self.lblRPconorT.bubbleHelp := toolTip2;
		self.lblRPcontentsT.bubbleHelp := toolTip2;
		self.lblRPcustAgT.bubbleHelp := toolTip2;
		self.lblRPdestPortT.bubbleHelp := toolTip2;
		self.lblRPdischPortT.bubbleHelp := toolTip2;
		self.lblRPimexT.bubbleHelp := toolTip2;
		self.lblRPopT.bubbleHelp := toolTip2;
		self.lblRPquantityT.bubbleHelp := toolTip2;
		self.lblRPvolumeT.bubbleHelp := toolTip2;
		self.lblRPweightT.bubbleHelp := toolTip2;
		self.lblRPlengthT.bubbleHelp := toolTip2;
		self.lblRPffT.bubbleHelp := toolTip2;	//Bug 38935
		self.lblRPsteveT.bubbleHelp := toolTip2;
		self.lblRPtrailTypeT.bubbleHelp := toolTip2;	//29 Oct 2020	NDL	TFS 50113
		self.lblRPshippingLineT.bubbleHelp := toolTip2; // ### TFS BUG 56663 23FEB2023 NAVAB1
		self.lblRPCountryOfOriginT.bubbleHelp := toolTip2; //5.4.2023 navmk20 TFS 57433
		self.lblRPContractIdT.bubbleHelp := toolTip2; //20/06/2023	navkc1	CR 55653 Task 58724
		self.lblRPHSCodeT.bubbleHelp := toolTip2; //04/10/2024	navkc1	JIRA 32999
	endif;
	if self.lblRPBusUnitC.bubbleHelp &lt;&gt; toolTip1 then
		self.lblRPBusUnitC.bubbleHelp := toolTip1;
		self.lblRPcommC.bubbleHelp := toolTip1;
		self.lblRPconC.bubbleHelp := toolTip1;
		self.lblRPconorC.bubbleHelp := toolTip1;
		self.lblRPcontentsC.bubbleHelp := toolTip1;
		self.lblRPcustAgC.bubbleHelp := toolTip1;
		self.lblRPdestPortC.bubbleHelp := toolTip1;
		self.lblRPdischPortC.bubbleHelp := toolTip1;
		self.lblRPimexC.bubbleHelp := toolTip1;
		self.lblRPopC.bubbleHelp := toolTip1;
		self.lblRPquantityC.bubbleHelp := toolTip1;
		self.lblRPvolumeC.bubbleHelp := toolTip1;
		self.lblRPweightC.bubbleHelp := toolTip1;
		self.lblRPlengthC.bubbleHelp := toolTip1;
		self.lblRPffC.bubbleHelp := toolTip1;	//Bug 38935		
		self.lblRPsteveC.bubbleHelp := toolTip1;
		self.lblRPtrailTypeC.bubbleHelp := toolTip1;	//29 Oct 2020	NDL	TFS 50113 
		self.lblRPshippingLineC.bubbleHelp := toolTip1; // ### TFS BUG 56663 23FEB2023 NAVAB1
		self.lblRPCountryOfOriginC.bubbleHelp := toolTip1; //5.4.2023 navmk20 TFS 57433
		self.lblRPContractIdC.bubbleHelp := toolTip1; //20/06/2023	navkc1	CR 55653 Task 58724
		self.lblRPHSCodeC.bubbleHelp := toolTip1; //04/10/2024	navkc1	JIRA 32999
	endif;
	self.lblRPBusUnitT.caption := Blank;
	self.lblRPcommT.caption := Blank;
	self.lblRPconT.caption := Blank;
	self.lblRPconorT.caption := Blank;
	self.lblRPcontentsT.caption := Blank;
	self.lblRPcustAgT.caption := Blank;
	self.lblRPdestPortT.caption := Blank;
	self.lblRPdischPortT.caption := Blank;
	self.lblRPimexT.caption := Blank;
	self.lblRPopT.caption := Blank;
	self.lblRPquantityT.caption := Blank;
	self.lblRPvolumeT.caption := Blank;
	self.lblRPweightT.caption := Blank;
	self.lblRPlengthT.caption := Blank;
	self.lblRPffT.caption := Blank;		//Bug 38935	
	self.lblRPsteveT.caption := Blank;
	self.lblRPtrailTypeT.caption := Blank;	//29 Oct 2020	NDL	TFS 50113
	self.lblRPshippingLineT.caption := Blank; // ### TFS BUG 56663 23FEB2023 NAVAB1
	self.lblRPCountryOfOriginT.caption := Blank; //5.4.2023 navmk20 TFS 57433
	self.lblRPContractIdT.caption := Blank; //20/06/2023	navkc1	CR 55653 Task 58724
	self.lblRPHSCodeT.caption := Blank; //04/10/2024	navkc1	JIRA 32999

	self.lblRPBusUnitC.caption := Blank;
	self.lblRPcommC.caption := Blank;
	self.lblRPconC.caption := Blank;
	self.lblRPconorC.caption := Blank;
	self.lblRPcontentsC.caption := Blank;
	self.lblRPcustAgC.caption := Blank;
	self.lblRPdestPortC.caption := Blank;
	self.lblRPdischPortC.caption := Blank;
	self.lblRPimexC.caption := Blank;
	self.lblRPopC.caption := Blank;
	self.lblRPquantityC.caption := Blank;
	self.lblRPvolumeC.caption := Blank;
	self.lblRPweightC.caption := Blank;
	self.lblRPlengthC.caption := Blank;
	self.lblRPffC.caption := Blank;		//Bug 38935	
	self.lblRPsteveC.caption := Blank;
	self.lblRPtrailTypeC.caption := Blank;	//29 Oct 2020	NDL	TFS 50113 
	self.lblRPshippingLineC.caption := Blank; // ### TFS BUG 56663 23FEB2023 NAVAB1
	self.lblRPCountryOfOriginC.caption := Blank; //5.4.2023 navmk20 TFS 57433
	self.lblRPContractIdC.caption := Blank; //20/06/2023	navkc1	CR 55653 Task 58724
	self.lblRPHSCodeC.caption := Blank; //04/10/2024	navkc1	JIRA 32999

	self.lblRPBusUnitT.foreColor := Grey;
	self.lblRPcommT.foreColor := Grey;
	self.lblRPconT.foreColor := Grey;
	self.lblRPconorT.foreColor := Grey;
	self.lblRPcontentsT.foreColor := Grey;
	self.lblRPcustAgT.foreColor := Grey;
	self.lblRPdestPortT.foreColor := Grey;
	self.lblRPdischPortT.foreColor := Grey;
	self.lblRPimexT.foreColor := Grey;
	self.lblRPopT.foreColor := Grey;
	self.lblRPquantityT.foreColor := Grey;
	self.lblRPvolumeT.foreColor := Grey;
	self.lblRPweightT.foreColor := Grey;
	self.lblRPlengthT.foreColor := Grey;
	self.lblRPffT.foreColor := Grey;		//Bug 38935
	self.lblRPsteveT.foreColor := Grey;
	self.lblRPtrailTypeT.foreColor := Grey;	//29 Oct 2020	NDL	TFS 50113
	self.lblRPshippingLineT.foreColor := Grey; // ### TFS BUG 56663 23FEB2023 NAVAB1
	self.lblRPCountryOfOriginT.foreColor := Grey;	//5.4.2023 navmk20 TFS 57433
	self.lblRPContractIdT.foreColor := Grey; //20/06/2023	navkc1	CR 55653 Task 58724
	self.lblRPHSCodeT.foreColor := Grey; //04/10/2024	navkc1	JIRA 32999
	
	
	packUnpackWarning := false;	//TFS41053
	canBeResynced := true; //11 Mar 2020	NDL	TFS 48847
	
	create tiArray transient;
	foreach anObj in self.allTransactions do
		txn := anObj.CM_TITransaction;
		ti := txn.myTrackedItem;
		if not tiArray.includes(ti) then
			tiArray.add(ti);
		endif;
		
		//11 Mar 2020	NDL	TFS 48847
		if canBeResynced then
			canBeResynced := txn.canBeResync(ti);
		endif;
		
		//If is a pack/unpack transaction on a container, a resync may not make sense //TFS41053
		if ti &lt;&gt; null and ti.isParent and ti.isKindOf(CM_Container) then
			if txn.isKindOf(CM_Pack) or txn.isKindOf(CM_Unpack) then
				packUnpackWarning := true;
			endif;
		endif;
		
		if self.lblRPBusUnitT.caption &lt;&gt; txn.companyCode and self.lblRPBusUnitT.caption &lt;&gt; Blank then
			self.lblRPBusUnitT.caption := Multi;
		elseif txn.companyCode &lt;&gt; null then
			self.lblRPBusUnitT.caption := txn.companyCode;
		endif;
		if self.lblRPcommT.caption &lt;&gt; txn.commodity and self.lblRPcommT.caption &lt;&gt; Blank then
			self.lblRPcommT.caption := Multi;
		elseif txn.commodity &lt;&gt; null then
			self.lblRPcommT.caption := txn.commodity;
		endif;
		if self.lblRPconT.caption &lt;&gt; txn.consignee and self.lblRPconT.caption &lt;&gt; Blank then
			self.lblRPconT.caption := Multi;
		elseif txn.consignee &lt;&gt; null then
			self.lblRPconT.caption := txn.consignee;
		endif;
		if self.lblRPconorT.caption &lt;&gt; txn.consignor and self.lblRPconorT.caption &lt;&gt; Blank then
			self.lblRPconorT.caption := Multi;
		elseif txn.consignor &lt;&gt; null then
			self.lblRPconorT.caption := txn.consignor;
		endif;
		if self.lblRPcontentsT.caption &lt;&gt; txn.getContentsStatusDesc(false) and self.lblRPcontentsT.caption &lt;&gt; Blank then
			self.lblRPcontentsT.caption := Multi;
		elseif txn.getContentsStatusDesc(false) &lt;&gt; null then
			self.lblRPcontentsT.caption := txn.getContentsStatusDesc(false);
		endif;
		if self.lblRPcustAgT.caption &lt;&gt; txn.customsAgentCode and self.lblRPcustAgT.caption &lt;&gt; Blank then
			self.lblRPcustAgT.caption := Multi;
		elseif txn.customsAgentCode &lt;&gt; null then
			self.lblRPcustAgT.caption := txn.customsAgentCode;
		endif;
		if self.lblRPdestPortT.caption &lt;&gt; txn.destinationPort and self.lblRPdestPortT.caption &lt;&gt; Blank then
			self.lblRPdestPortT.caption := Multi;
		elseif txn.destinationPort &lt;&gt; null then
			self.lblRPdestPortT.caption := txn.destinationPort;
		endif;
		if self.lblRPdischPortT.caption &lt;&gt; txn.dischargePort and self.lblRPdischPortT.caption &lt;&gt; Blank then
			self.lblRPdischPortT.caption := Multi;
		elseif txn.dischargePort &lt;&gt; null then
			self.lblRPdischPortT.caption := txn.dischargePort;
		endif;
		if self.lblRPimexT.caption &lt;&gt; txn.getImExStatusStringDesc(true) and self.lblRPimexT.caption &lt;&gt; Blank then
			self.lblRPimexT.caption := Multi;
		elseif txn.getImExStatusStringDesc(true) &lt;&gt; null then
			self.lblRPimexT.caption := txn.getImExStatusStringDesc(true);
		endif;
		if self.lblRPopT.caption &lt;&gt; txn.operatorCode and self.lblRPopT.caption &lt;&gt; Blank then
			self.lblRPopT.caption := Multi;
		elseif txn.operatorCode &lt;&gt; null then
			self.lblRPopT.caption := txn.operatorCode;
		endif;
		if self.lblRPffT.caption &lt;&gt; txn.freightForwarderCode and self.lblRPffT.caption &lt;&gt; Blank then	//Bug 38935
			self.lblRPffT.caption := Multi;																//Bug 38935
		elseif txn.freightForwarderCode &lt;&gt; null then													//Bug 38935
			self.lblRPffT.caption := txn.freightForwarderCode;											//Bug 38935
		endif;																							//Bug 38935
		if self.lblRPsteveT.caption &lt;&gt; txn.stevedoreCode and self.lblRPsteveT.caption &lt;&gt; Blank then
			self.lblRPsteveT.caption := Multi;
		elseif txn.stevedoreCode &lt;&gt; null then
			self.lblRPsteveT.caption := txn.stevedoreCode;
		endif;
		
		//29 Oct 2020	NDL	TFS 50113
	//	if txn &lt;&gt; null and ( txn.isKindOf(CM_ReceiveRoad) or txn.isKindOf(CM_ReleaseRoad) or txn.isKindOf(CM_SubTerminalReceive) or txn.isKindOf(CM_SubTerminalRelease) ) then
		if txn &lt;&gt; null and ( txn.isKindOf(CM_ReceiveRoad) or txn.isKindOf(CM_ReleaseRoad) or txn.isKindOf(CM_TrailerLoad) or txn.isKindOf(CM_TrailerDischarge) ) then	//21 Dec 2020	NDL	TFS 50422
			if self.lblRPtrailTypeT.caption &lt;&gt; txn.getTrailerType and self.lblRPtrailTypeT.caption &lt;&gt; Blank then
				self.lblRPtrailTypeT.caption := Multi;
			elseif txn.getTrailerType &lt;&gt; null then
				self.lblRPtrailTypeT.caption := txn.getTrailerType;
			endif;
		endif;

		 // ### TFS BUG 56663 23FEB2023 NAVAB1
		if self.lblRPshippingLineT.caption &lt;&gt; txn.shippingLineCode 
		and self.lblRPshippingLineT.caption &lt;&gt; Blank then
			self.lblRPshippingLineT.caption := Multi;
		elseif txn.shippingLineCode &lt;&gt; null then
			self.lblRPshippingLineT.caption := txn.shippingLineCode;
		endif;
		
		// Start - 5.4.2023 navmk20 TFS 57433
		if txn.myCountryOfOrigin &lt;&gt; null and txn.myCountryOfOrigin.description &lt;&gt; null then
			if self.lblRPCountryOfOriginT.caption &lt;&gt; txn.myCountryOfOrigin.description
			and self.lblRPCountryOfOriginT.caption &lt;&gt; Blank then
				self.lblRPCountryOfOriginT.caption := Multi;
			elseif txn.myCountryOfOrigin &lt;&gt; null then
				self.lblRPCountryOfOriginT.caption := txn.myCountryOfOrigin.description;
			endif;
		endif;
		// End - 5.4.2023 navmk20 TFS 57433
		
		//20/06/2023	navkc1	CR 55653 Task 58724 --&gt;
		if self.lblRPContractIdT.caption &lt;&gt; txn.contractId and self.lblRPContractIdT.caption &lt;&gt; Blank then
			self.lblRPContractIdT.caption := Multi;
		elseif txn.contractId &lt;&gt; null then
			self.lblRPContractIdT.caption := txn.contractId;
		endif;
		//20/06/2023	navkc1	CR 55653 Task 58724 &lt;--
		
		//04/10/2024	navkc1	JIRA 32999 --&gt;
		if self.lblRPHSCodeT.caption &lt;&gt; txn.hsCode and self.lblRPHSCodeT.caption &lt;&gt; Blank then
			self.lblRPHSCodeT.caption := Multi;
		elseif txn.hsCode &lt;&gt; null then
			self.lblRPHSCodeT.caption := txn.hsCode;
		endif;
		//04/10/2024	navkc1	JIRA 32999 &lt;--
		
		if self.lblRPquantityT.caption &lt;&gt; txn.totalQuantity.String and self.lblRPquantityT.caption &lt;&gt; Blank then
			self.lblRPquantityT.caption := Multi;
		elseif txn.totalQuantity.String &lt;&gt; null then
			self.lblRPquantityT.caption := txn.totalQuantity.String;
		endif;
		
		measureType  := app.getDefaultMeasurementForType(Type_Volume);
		priorValue   := txn.totalVolume;
		displayValue := app.convertMeasurementForDisplay(measureType.shortName, priorValue.Decimal) &amp; Space &amp; measureType.shortName;
		if self.lblRPvolumeT.caption &lt;&gt; displayValue and self.lblRPvolumeT.caption &lt;&gt; Blank then
			self.lblRPvolumeT.caption := Multi;
		elseif displayValue &lt;&gt; null then
			self.lblRPvolumeT.caption := displayValue;
		endif;
		
		measureType  := app.getDefaultMeasurementForType(Type_Weight);
		priorValue   := txn.totalWeight;
		displayValue := app.convertMeasurementForDisplay(measureType.shortName, priorValue.Decimal) &amp; Space &amp; measureType.shortName;
		if self.lblRPweightT.caption &lt;&gt; displayValue and self.lblRPweightT.caption &lt;&gt; Blank then
			self.lblRPweightT.caption := Multi;
		elseif displayValue &lt;&gt; null then
			self.lblRPweightT.caption := displayValue;
		endif;
		
		measureType  := app.getDefaultMeasurementForType(Type_Length);
		priorValue   := txn.totalLength;
		displayValue := app.convertMeasurementForDisplay(measureType.shortName, priorValue.Decimal) &amp; Space &amp; measureType.shortName;
		if self.lblRPlengthT.caption &lt;&gt; displayValue and self.lblRPlengthT.caption &lt;&gt; Blank then
			self.lblRPlengthT.caption := Multi;
		elseif displayValue &lt;&gt; null then
			self.lblRPlengthT.caption := displayValue;
		endif;
		
	endforeach;

	foreach anObj in tiArray do
		ti := anObj.CM_TrackedItem;	
		
		//11 Mar 2020	NDL	TFS 48847
		if canBeResynced then
			foreach trxObj in self.allTransactions do
				txn := trxObj.CM_TITransaction;
				if not txn.canBeResync(ti) then
					canBeResynced := false;
					break;
				endif;
			endforeach;
		endif;
		
		if self.lblRPBusUnitC.caption &lt;&gt; ti.companyCode and self.lblRPBusUnitC.caption &lt;&gt; Blank then
			self.lblRPBusUnitC.caption := Multi;
		elseif ti.companyCode &lt;&gt; null then
			self.lblRPBusUnitC.caption := ti.companyCode;
		endif;
		if self.lblRPBusUnitT.caption &lt;&gt; self.lblRPBusUnitC.caption then
			self.lblRPBusUnitT.foreColor := Red;
		endif;
		if self.lblRPcommC.caption &lt;&gt; ti.commodity and self.lblRPcommC.caption &lt;&gt; Blank then
			self.lblRPcommC.caption := Multi;
		elseif ti.commodity &lt;&gt; null then
			self.lblRPcommC.caption := ti.commodity;
		endif;
		if self.lblRPcommT.caption &lt;&gt; self.lblRPcommC.caption then
			self.lblRPcommT.foreColor := Red; 
		endif;
		if self.lblRPconC.caption &lt;&gt; ti.consignee and self.lblRPconC.caption &lt;&gt; Blank then
			self.lblRPconC.caption := Multi;
		elseif ti.consignee &lt;&gt; null then
			self.lblRPconC.caption := ti.consignee;
		endif;
		if self.lblRPconT.caption &lt;&gt; self.lblRPconC.caption then
			self.lblRPconT.foreColor := Red; 
		endif;
		if self.lblRPconorC.caption &lt;&gt; ti.consignor and self.lblRPconorC.caption &lt;&gt; Blank then
			self.lblRPconorC.caption := Multi;
		elseif ti.consignor &lt;&gt; null then
			self.lblRPconorC.caption := ti.consignor;
		endif;
		if self.lblRPconorT.caption &lt;&gt; self.lblRPconorC.caption then 
			self.lblRPconorT.foreColor := Red; 
		endif;
		if self.lblRPcontentsC.caption &lt;&gt; ti.getContentsStatusDesc(false) and self.lblRPcontentsC.caption &lt;&gt; Blank then
			self.lblRPcontentsC.caption := Multi;
		elseif ti.getContentsStatusDesc(false) &lt;&gt; null then
			self.lblRPcontentsC.caption := ti.getContentsStatusDesc(false);
		endif;
		if self.lblRPcontentsC.caption &lt;&gt; self.lblRPcontentsT.caption then
			self.lblRPcontentsT.foreColor := Red; 
		endif;
		if self.lblRPcustAgC.caption &lt;&gt; ti.getMyCustomsAgentDesc(false) and self.lblRPcustAgC.caption &lt;&gt; Blank then
			self.lblRPcustAgC.caption := Multi;
		elseif ti.getMyCustomsAgentDesc(false) &lt;&gt; null then
			self.lblRPcustAgC.caption := ti.getMyCustomsAgentDesc(false);
		endif;
		if self.lblRPcustAgT.caption &lt;&gt; self.lblRPcustAgC.caption then
			self.lblRPcustAgT.foreColor := Red; 
		endif;
		if self.lblRPdestPortC.caption &lt;&gt; ti.destinationPort and self.lblRPdestPortC.caption &lt;&gt; Blank then
			self.lblRPdestPortC.caption := Multi;
		elseif ti.destinationPort &lt;&gt; null then
			self.lblRPdestPortC.caption := ti.destinationPort;
		endif;
		if self.lblRPdestPortT.caption &lt;&gt; self.lblRPdestPortC.caption then
			self.lblRPdestPortT.foreColor := Red;
		endif;
		if self.lblRPdischPortC.caption &lt;&gt; ti.dischargePort and self.lblRPdischPortC.caption &lt;&gt; Blank then
			self.lblRPdischPortC.caption := Multi;
		elseif ti.dischargePort &lt;&gt; null then
			self.lblRPdischPortC.caption := ti.dischargePort;
		endif;
		if self.lblRPdischPortT.caption &lt;&gt; self.lblRPdischPortC.caption then
			self.lblRPdischPortT.foreColor := Red; 
		endif;
		if self.lblRPimexC.caption &lt;&gt; ti.getImExStatusStringDesc(true) and self.lblRPimexC.caption &lt;&gt; Blank then
			self.lblRPimexC.caption := Multi;
		elseif ti.getImExStatusStringDesc(true) &lt;&gt; null then
			self.lblRPimexC.caption := ti.getImExStatusStringDesc(true);
		endif;
		if self.lblRPimexT.caption &lt;&gt; self.lblRPimexC.caption then
			self.lblRPimexT.foreColor := Red; 
		endif;
		if self.lblRPopC.caption &lt;&gt; ti.operatorCode and self.lblRPopC.caption &lt;&gt; Blank then
			self.lblRPopC.caption := Multi;
		elseif ti.operatorCode &lt;&gt; null then
			self.lblRPopC.caption := ti.operatorCode;
		endif;
		if self.lblRPopT.caption &lt;&gt; self.lblRPopC.caption then
			self.lblRPopT.foreColor := Red; 
		endif;
		
		if self.lblRPffC.caption &lt;&gt; ti.freightForwarderCode and self.lblRPffC.caption &lt;&gt; Blank then	//Bug 38935
			self.lblRPffC.caption := Multi;															//Bug 38935
		elseif ti.freightForwarderCode &lt;&gt; null then													//Bug 38935
			self.lblRPffC.caption := ti.freightForwarderCode;										//Bug 38935
		endif;																						//Bug 38935
		if self.lblRPffT.caption &lt;&gt; self.lblRPffC.caption then										//Bug 38935
			self.lblRPffT.foreColor := Red; 														//Bug 38935
		endif;																						//Bug 38935
		if self.lblRPsteveC.caption &lt;&gt; ti.stevedoreCode and self.lblRPsteveC.caption &lt;&gt; Blank then
			self.lblRPsteveC.caption := Multi;
		elseif ti.getStevedore &lt;&gt; null then
			self.lblRPsteveC.caption := ti.stevedoreCode;
		elseif ti.stevedoreCodeRecieve &lt;&gt; null and txn.isKindOf(CM_Receive) then   //04.11.2020 cnwma1 TFS #50112
			self.lblRPsteveC.caption := ti.stevedoreCodeRecieve;
		elseif ti.stevedoreCodeRelease &lt;&gt; null and txn.isKindOf(CM_Release) then   //04.11.2020 cnwma1 TFS #50112
			self.lblRPsteveC.caption := ti.stevedoreCodeRelease;
		endif;
		if self.lblRPsteveT.caption &lt;&gt; self.lblRPsteveC.caption then
			self.lblRPsteveT.foreColor := Red;
		endif;
		
		//29 Oct 2020	NDL	TFS 50113 
		if self.lblRPtrailTypeC.caption &lt;&gt; ti.getCurrentTrailerType and self.lblRPtrailTypeC.caption &lt;&gt; Blank then	
			self.lblRPtrailTypeC.caption := Multi;
		elseif ti.getCurrentTrailerType &lt;&gt; null then
			self.lblRPtrailTypeC.caption := ti.getCurrentTrailerType;
		endif;
		 
		//29 Oct 2020	NDL	TFS 50113 	
		if self.lblRPtrailTypeT.caption &lt;&gt; self.lblRPtrailTypeC.caption and self.lblRPtrailTypeC.caption &lt;&gt; Blank then			
			self.lblRPtrailTypeT.foreColor := Red;
		endif;

		
		
		// ### TFS BUG 56663 23FEB2023 NAVAB1
		shippingLine := ti.getShippingLineCode;
		if self.lblRPshippingLineC.caption &lt;&gt; shippingLine 
		and self.lblRPshippingLineC.caption &lt;&gt; Blank then	
			self.lblRPshippingLineC.caption := Multi;
		elseif shippingLine &lt;&gt; null then
			self.lblRPshippingLineC.caption := shippingLine;
		endif;
		if self.lblRPshippingLineT.caption &lt;&gt; self.lblRPshippingLineC.caption 
		and self.lblRPshippingLineC.caption &lt;&gt; Blank then			
			self.lblRPshippingLineT.foreColor := Red;
		endif;
		
		// Start - 5.4.2023 navmk20 TFS 57433
		if ti.myCountryOfOrigin &lt;&gt; null and ti.myCountryOfOrigin.description &lt;&gt; null then
			countryOfOriginDesc := ti.myCountryOfOrigin.description;
			if self.lblRPCountryOfOriginC.caption &lt;&gt; countryOfOriginDesc
			and self.lblRPCountryOfOriginC.caption &lt;&gt; Blank then	
				self.lblRPCountryOfOriginC.caption := Multi;
			elseif countryOfOriginDesc &lt;&gt; null then
				self.lblRPCountryOfOriginC.caption := countryOfOriginDesc;
			endif;
		endif;
		
		if self.lblRPCountryOfOriginT.caption &lt;&gt; self.lblRPCountryOfOriginC.caption
		and self.lblRPCountryOfOriginC.caption &lt;&gt; Blank then			
			self.lblRPCountryOfOriginT.foreColor := Red;
		endif;
		// End - 5.4.2023 navmk20 TFS 57433
		
		//20/06/2023	navkc1	CR 55653 Task 58724 --&gt;
		if self.lblRPContractIdC.caption &lt;&gt; ti.contractId and self.lblRPContractIdC.caption &lt;&gt; Blank then
			self.lblRPContractIdC.caption := Multi;
		elseif ti.contractId &lt;&gt; null then
			self.lblRPContractIdC.caption := ti.contractId;
		endif;
		
		if self.lblRPContractIdT.caption &lt;&gt; self.lblRPContractIdC.caption and self.lblRPContractIdC.caption &lt;&gt; Blank then
			self.lblRPContractIdT.foreColor := Red;
		endif;
		//20/06/2023	navkc1	CR 55653 Task 58724 &lt;--
		
		//04/10/2024	navkc1	JIRA 32999 --&gt;
		if self.lblRPHSCodeC.caption &lt;&gt; ti.hsCode and self.lblRPHSCodeC.caption &lt;&gt; Blank then
			self.lblRPHSCodeC.caption := Multi;
		elseif ti.hsCode &lt;&gt; null then
			self.lblRPHSCodeC.caption := ti.hsCode;
		endif;
		
		if self.lblRPHSCodeT.caption &lt;&gt; self.lblRPHSCodeC.caption and self.lblRPHSCodeC.caption &lt;&gt; Blank then
			self.lblRPHSCodeT.foreColor := Red;
		endif;
		//04/10/2024	navkc1	JIRA 32999 &lt;--
		
		if self.lblRPquantityC.caption &lt;&gt; ti.totalQuantity.String and self.lblRPquantityC.caption &lt;&gt; Blank then
			self.lblRPquantityC.caption := Multi;
		elseif ti.totalQuantity.String &lt;&gt; null then
			self.lblRPquantityC.caption := ti.totalQuantity.String;
		endif;
 		if self.lblRPquantityT.caption &lt;&gt; self.lblRPquantityC.caption then
			self.lblRPquantityT.foreColor := Red; 
		endif;
		
		// PAR 31615
		measureType  := app.getDefaultMeasurementForType(Type_Volume);
		priorValue   := ti.getMyTotalVolume;
		displayValue := app.convertMeasurementForDisplay(measureType.shortName, priorValue.Decimal) &amp; Space &amp; measureType.shortName;
		if self.lblRPvolumeC.caption &lt;&gt; displayValue and self.lblRPvolumeC.caption &lt;&gt; Blank then
			self.lblRPvolumeC.caption := Multi;
		elseif displayValue &lt;&gt; null then
			self.lblRPvolumeC.caption := displayValue;
		endif;
		if self.lblRPvolumeT.caption &lt;&gt; self.lblRPvolumeC.caption then
			self.lblRPvolumeT.foreColor := Red; 
		endif;
		
		measureType  := app.getDefaultMeasurementForType(Type_Weight);
		priorValue   := ti.totalWeight;
		displayValue := app.convertMeasurementForDisplay(measureType.shortName, priorValue.Decimal) &amp; Space &amp; measureType.shortName;
		if self.lblRPweightC.caption &lt;&gt; displayValue and self.lblRPweightC.caption &lt;&gt; Blank then
			self.lblRPweightC.caption := Multi;
		elseif displayValue.String &lt;&gt; null then
			self.lblRPweightC.caption := displayValue;
		endif;
		if self.lblRPweightT.caption &lt;&gt; self.lblRPweightC.caption then
			self.lblRPweightT.foreColor := Red; 
		endif;
		
		measureType  := app.getDefaultMeasurementForType(Type_Length);
		priorValue   := ti.length;
		displayValue := app.convertMeasurementForDisplay(measureType.shortName, priorValue.Decimal) &amp; Space &amp; measureType.shortName;
		if self.lblRPlengthC.caption &lt;&gt; displayValue and self.lblRPlengthC.caption &lt;&gt; Blank then
			self.lblRPlengthC.caption := Multi;
		elseif displayValue &lt;&gt; null then
			self.lblRPlengthC.caption := displayValue;
		endif;
		if self.lblRPlengthT.caption &lt;&gt; self.lblRPlengthC.caption then
			self.lblRPlengthT.foreColor := Red; 
		endif;
		
		// Break-Bulk cannot change quantity
	//	if ti.myCargoType.isBreakBulkMulti then
	//		self.chkRPquantity.enabled := false;
	//	endif;
		// Bulk cannot change weight or volume
	//	if ti.myCargoType.isBulk then
	//		self.chkRPweight.enabled := false;
	//		self.chkRPvolume.enabled := false;
	//	endif;
		
		
	endforeach;
	
	// TFS 53522 navsj20
	if canBeResynced then      																	    
		if ti.hasSplitOrMergeTrans then
			self.doResyncWarning:=true; 
		else                                    												   
			self.doResyncWarning:=false;                                                            
		endif;
		if self.myTerminal.getConfig(AllowTransResyncForAmt).Boolean then
			lblHeading.caption := app.getErrorString(Resync_Cargo_Hdr);
		endif;
	// TFS 53522 navsj20
	//11 Mar 2020	NDL	TFS 48847
	elseif self.doResyncWarning and not canBeResynced then 										
		self.chkRPquantity.enabled := false;
		self.chkRPweight.enabled := false;
		self.chkRPvolume.enabled := false;
		if self.allTransactions.size &gt; 1 or tiArray.size &gt; 1 then
			//warning
			msg := app.getErrorString(Have_selec_multi_trans_resyn_m);
			app.msgBox( msg, app.getErrorString(Warning), MsgBox_OK_Only);
			self.doResyncWarning := false;	//12 Mar 2020	NDL	TFS 48847
		endif;	
	endif;

	self.chkRPLog.visible  := true;
	self.frmResync.visible := true;
	//self.height 		   := 740;                        //03.03.2020 cnwma1 #48772		//5.04.2023 navmk20 TFS 57433
	self.height 		   := 850;                        									//5.04.2023 navmk20 TFS 57433
	self.btnSelectAll.top  := self.frmResync.top + self.frmResync.height + 10;
	self.btnSave.top       := self.btnSelectAll.top;
	self.btnClose.top      := self.btnSelectAll.top;

	if packUnpackWarning then //TFS41053
		app.msgBox(app.getErrorString(WARN_pack_unpack_resync), app.getErrorString(Warning), MsgBox_Exclamation_Mark_Icon);
	endif;

epilog
	delete allChildControls;
	delete tiArray;
end;</source>
    </JadeMethod>
    <JadeMethod name="setupFormForOthers" id="49cada98-c702-4816-9076-c387e94fa42d">
        <updating/>
        <source>setupFormForOthers() updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 04/06/2019	jlgdap1		Initial creation TFS 44554 AAT Stevedore Data Access
//20/09/2019 	JLGNS1	Bug 46339 JMT - Event transaction does not resync
vars
	allChildControls : CnEcControlArray;
	control	: Control;

begin
	// hide all controls on the form except the buttons and log option
	create allChildControls transient;
	self.frmResync.cnEcGetAllChildControls(allChildControls, false);
	foreach control in allChildControls do
		if control.name = self.chkRPLog.name then
			control.visible := true;
			control.top := 20;
		else
			control.visible := false;
		endif;
	endforeach;
	self.btnSelectAll.visible := false;
	self.frmResync.height := 60;
	self.frmResync.visible := true;

	self.chkRPLog.visible := true;
	self.chkReadOnly.top := self.chkRPLog.top;
	self.chkReadOnly.visible := true;
	
	self.lblHeading.caption := app.getErrorString(This_option_allows_rsyn_trans);	//BUG 46339 
	self.lblHeading.height := 16;													//BUG 46339 
	self.frmResync.top := self.lblHeading.top + self.lblHeading.height;				//BUG 46339 
		
	self.btnClose.top := self.frmResync.top + self.frmResync.height + 10;
	self.btnSave.top := self.btnClose.top;
	self.height := self.btnClose.top + self.btnClose.height + 50;
	self.centreWindow();															//BUG 46339 
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="d8c13f3e-3010-4c0d-b491-035549714145">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 10 October 2024 11:59:18.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0023587, locale);
	btnClose.translateCaption(Xlat_0023588, locale);
	btnSave.translateCaption(Xlat_0023589, locale);
	btnSelectAll.translateCaption(Xlat_0023590, locale);
	chkRPContractId.translateCaption(Xlat_0026110, locale);
	chkRPCountryOfOrigin.translateCaption(Xlat_0025903, locale);
	chkRPHSCode.translateCaption(Xlat_0026988, locale);
	chkRPLength.translateCaption(Xlat_0023591, locale);
	chkRPLog.translateCaption(Xlat_0023592, locale);
	chkRPbusUnit.translateCaption(Xlat_0023593, locale);
	chkRPcomm.translateCaption(Xlat_0023594, locale);
	chkRPcon.translateCaption(Xlat_0023595, locale);
	chkRPconor.translateCaption(Xlat_0023596, locale);
	chkRPcontents.translateCaption(Xlat_0023597, locale);
	chkRPcustAg.translateCaption(Xlat_0023598, locale);
	chkRPdestPort.translateCaption(Xlat_0023599, locale);
	chkRPdischPort.translateCaption(Xlat_0023600, locale);
	chkRPfreightForwarder.translateCaption(Xlat_0023601, locale);
	chkRPimex.translateCaption(Xlat_0023602, locale);
	chkRPoperator.translateCaption(Xlat_0023603, locale);
	chkRPquantity.translateCaption(Xlat_0023604, locale);
	chkRPshippingLine.translateCaption(Xlat_0025733, locale);
	chkRPstevedore.translateCaption(Xlat_0023605, locale);
	chkRPtrailerType.translateCaption(Xlat_0024105, locale);
	chkRPvolume.translateCaption(Xlat_0023606, locale);
	chkRPweight.translateCaption(Xlat_0023607, locale);
	chkReadOnly.translateCaption(Xlat_0023608, locale);
	lblHeading.translateCaption(Xlat_0023889, locale);
	lblRPCargo.translateCaption(Xlat_0023610, locale);
