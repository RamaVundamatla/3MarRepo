    <JadeMethod name="validateForMove" id="946abde2-0112-43ea-b6b1-f2fc382198ea">
        <source>validateForMove(_controller : CMIF_MoveController; _passport : CM_Passport input);
//--------------------------------------------------------------
//Created: 27 May 2002 By: cnwgd1
//--------------------------------------------------------------
//	Changed On		Changed By		Reason
//	--------------	--------------	-------------------------------------------
//	20/02/2024		jlizm1			TFS 62467 CUX Warning when setdown to MAFI heap
//	---------------------------------------------------------------------------
vars
	mode : Integer;
	isDirectorMove : Boolean;
	aFM : CM_FutureMove;
	ti  : CM_TrackedItem;
	targetId : String;
	
begin
	
	mode := _controller.moveMode;
	isDirectorMove := _controller.isDirectorMove;
	ti := _controller.myTrackedItem;
	
	if _controller.isUndoMove 
	or _controller.isFullyUnplan then
		if _controller.isForcedMove then
			//This is a forced moved, let it through
			return;
		endif;
		
		//Validate for undo move then return
		if mode = QUEUE_MODE then
			 //epr par 25573 7/2/2011
			if self.isCompleteForJob and self.myFutureMove = null then 
				app.raiseCMException3(ERR_QUEUE_WLE_STAT, self.getTreeDescription(), 'complete', 'unqueued', null, null);			
				return;
			endif;				
			if self.queue = null then
				if _controller.doNotAddQueuedMovesToRTQueue = false then  // PAR 8774 JC
					//epr 34406 26/6/14 had wle with future move and no queue this stopped me from unqueing and deleting the future move
				//	app.raiseCMException2(ERR_JOB_NOT_QUEUED_PLANNED, self.getTreeDescription, 'queued', null, null);			
				endif;
			elseif self.areAllEntryTasksEqStatus(TASK_SYS_HELD) or self.areAllEntryTasksEqStatus(TASK_USER_HELD) then	//22 Apr 2015	NDL	Par 36014
				//it's held for action in the RT queue
				app.raiseCMWarning3(WARN_WLE_Assigned, self.getTreeDescription(), 'Held', self.queueId, null, null, self);			
			endif;
		elseif mode = PLANNING_MODE then
			if self.myTrackedItem &lt;&gt; null then
				if  self.status = WLE_COMPLETED and self.myFutureMove = null then // ### PAR 9406
					app.raiseCMException3(ERR_QUEUE_WLE_STAT, self.getTreeDescription(), 'complete', 'unplanned', null, self);			
					return;
				endif;		
				if self.myTrackedItem.allPlannedFutureMoves.isEmpty then //&lt;&lt;--carry on if not empty then FM will be deleted
					//not planned
					app.raiseCMException2(ERR_JOB_NOT_QUEUED_PLANNED, self.getTreeDescription, 'planned', null, null);			
				endif;
			endif;			
			
			/*			
			Date		Who		Reason			
			26 Aug 2008	cnwdz2	Par 16632 Display an error message if users try to unplan a job
										  that contains one or more queued cargoes.			
			*/
			if self.myFutureMove &lt;&gt; null then	
				if not self.myFutureMove.canUnplanFutureMove() then													
					app.raiseCMException2(ERR_UNPLAN_QUEUED_JOB, ti.id, ti.getPrimaryLocationId(REAL_MODE),null, null);			
					return;
				endif;
			endif;	
			
		endif;	
		return;
	endif;
	
	if mode = REAL_MODE then
		targetId :=  self.getFinalTaskTargetLocId();
		
		if targetId.startsWith(CM_RTQueueTask.TASK_TARGET_MAFI)
		and (_controller.myToPrimaryLocation = null
		or not _controller.myToPrimaryLocation.isMAFIController)then
			app.raiseCMWarning(Location_not_mafi, null, null, null);
		endif;
	endif;
	
	if self.myTrackedItem = null then
		app.setContinueCMExceptions(false);
		if mode = QUEUE_MODE and CM_DeliveryRequest.hasInstance(self.myRequest) then
			app.raiseCMException2(ERR_NO_SOURCE_LOCATION, self.getTreeDescription, 'Queued', null, null);		
		else
			app.raiseCMException1(ERR_WLE_NO_TI, self.getTreeDescription, null, null);
		endif;
		return;		
	endif;
	
	//th2 for PAR 14427
	if CM_WagonController.hasInstance(_controller.myToPrimaryLocation) and 
	   self.myTrackedItem.site = TI_SITE_ONSHIP then
		app.raiseCMWarning1(WARN_TI_STILL_ONSHIP,self.myTrackedItem.id, null, null, self.myTrackedItem);
	endif;
	
	self.validateSameTIForMove(_controller);
		
	if self.myTrackedItem.myCargoType.hasToDoRequests and
	   (not self.checkToDoComplete(false)) then
		app.raiseCMException3(ERR_TODOTASKS, 'unactioned', app.getErrorString(Completed).toLower, self.getTreeDescription, null, null);	
	endif;

	if mode = QUEUE_MODE then
		//epr par 25573 7/2/2011
	//	if self.isCompleteForJob and self.myFutureMove = null and not self.isChassisToRelease then 	//epr par 341047 20/5/14
		if self.isCompleteForJob and self.myFutureMove = null and not self.isChassisToRelease and not _controller.isHHInTransitMove then //11 Sep 2017	NDL	TFS 6887
			app.setContinueCMExceptions(false);
			app.raiseCMException3(ERR_QUEUE_WLE_STAT, self.getTreeDescription(), 'complete', 'queued', null, null);			
			return;			
		endif;
		
		//epr par 36229 17/7/17 removed references to RadioTelemetryEnabled 
		if _controller.myToPrimaryLocation = null then
			app.raiseCMException3(ERR_QUEUE_WLE_STAT, self.getTreeDescription(), 'not planned', 'queued', null, null);					
		endif;
	elseif mode = PLANNING_MODE and self.isCompleteForJob and self.status &lt;&gt; WLE_UNACTIONED then // and self.status = WLE_COMPLETED then //epr par 37028 6/1/16  
		app.setContinueCMExceptions(false);
		app.raiseCMException3(ERR_QUEUE_WLE_STAT, self.getTreeDescription(), 'complete', 'planned', null, null);			
		return;	
	else
		// must be in real mode and therefore they may be returning the original TI so carry on	
	endif;


	if self.job &lt;&gt; null and self.job.jobType = BOLType_Log then//or self.job.jobType = BOLType_General then
		if self.myBOL = null then
			app.raiseCMException(VB_NOT_PLANNED, null, null);							
		elseif self.myBOL.myPlannedLocation = null then
			app.raiseCMException(VB_NOT_PLANNED, null, null);
		endif;
	endif;

	self.validateForRelease(_passport);

end;</source>
        <Parameter name="_controller" type="CMIF_MoveController"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateForQDeliveryRequest" id="eb745c11-c176-46ac-8990-9215500c52b4">
        <source>validateForQDeliveryRequest(_termArea : CM_TerminalArea);
//--------------------------------------------------------------
//Created: 05 February 2003 By: cnwgd1
//--------------------------------------------------------------
vars

begin

	if _termArea = null then
		app.setContinueCMExceptions(false);
		app.raiseCMException1(ERR_INVALID_TA_ID, 'null', null, null);
		return;	
	endif;
	
	// 23676 04/2010 handle change of queued type by requiring manual unqueue first
	if self.isQueued then
		app.raiseCMException(Must_unque_befor_sourc_loc, null, null);
		return;
	endif;
	
	// 18/02/2010	cnwjre1	CCMS 1101 can now queue to gridded areas - skip this test
	/*
	//	if (not _termArea.isKindOf(CM_BlockStack)) then
	if (not _termArea.isSingleLCType) then
		app.setContinueCMExceptions(false);
		app.raiseCMException1(ERR_INVALID_TA_ID, _termArea.id &amp; "  is NOT a block stack", null, null);
		return;	
	endif;
	*/
	
	// 18/02/2010	cnwjre1	CCMS 1101 can now queue to gridded areas - modify this test to be only those areas where
	//		getMyLocationsController has a valid method implementation
	if _termArea.isSingleLCType() then
		if _termArea.getMyLocationsController.numTIs = 0 then
			//----------------
			//NO TI's in the stack
			//----------------
			app.setContinueCMExceptions(false);
			app.raiseCMException1(ERR_SOURCE_EMPTY, _termArea.id, null, null);
			return;		
		endif;
	endif;

end;</source>
        <Parameter name="_termArea" type="CM_TerminalArea"/>
    </JadeMethod>
    <JadeMethod name="validateForRakeRelease" id="b2b1edf8-ca4c-4b99-aa53-3189af0c8fe3">
        <source>validateForRakeRelease();
//--------------------------------------------------------------
//Created: 07 April 2003 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	
	if self.isReceipt and (self.status &lt;&gt; WLE_COMPLETED) then
		app.raiseCMException1(VB_UNACTIONED_RECEIPT, self.job.jobId &amp; " (incomplete workListEntry: " &amp; self.getFullDescription()&amp; ')', null, null);	
	elseif self.status &lt;&gt; WLE_COMPLETED then
		app.raiseCMException1(VB_UNACTIONED_RELEASE, self.job.jobId &amp; " (incomplete workListEntry: " &amp; self.getFullDescription() &amp; ')', null, null);
	endif;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="validateForRelease" id="328b4a9b-c9c9-4a1e-bf56-6e1126ad4d12">
        <source>validateForRelease(_passport : CM_Passport input);
//--------------------------------------------------------------
//Created: 27 May 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	requestType : Integer;
	tmpRequest	: CM_Request;
	tmpTI		: CM_TrackedItem;
begin

	if self.status &lt;&gt; WLE_UNACTIONED then
		// already tested, may be returning job
		return;
	endif;
	
	tmpTI := self.myTrackedItem;
	
	if tmpTI = null then
		app.raiseCMException1(ERR_WLE_NO_TI, self.job.jobId, null, null);
		return;
	endif;
	//FD Added the following for validating road releases.	
	requestType := self.getRequestType();
	tmpRequest  := self.myRequest;
	
	if requestType = REQ_ISO_RELEASE or   requestType = REQ_TI_RELEASE then   	
		if tmpRequest &lt;&gt; null and tmpTI.releaseRequest &lt;&gt; tmpRequest then
			tmpTI.testAgainstRequest(tmpRequest);
		endif;
	endif;

end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateForRemoveTI" id="e7d23554-8d71-42b1-9ecb-88e8e9f8d060">
        <source>validateForRemoveTI();
// ---------------------------------------------------------------------------
// Created:		22 July 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------

vars

begin
	if self.myTrackedItem = null then 
		//already unassigned ti return
		return;
	endif;
	
	if not self.status = WLE_UNACTIONED then
		//can not unassign if not unactioned wle
		app.raiseCMException(Unassign_Unactioned_Job,null,null);
		return;
	endif;
	
	//epr 14/3/13 30908 - no longer unexpected error
	if not self.allRTQueueEntries.isEmpty then
		app.raiseCMException(Please_unque_before_unassign,null,null);
		return;
	endif;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="validateForTurnAround" id="30adbe51-5079-46c7-be85-2dd1ee6484d1">
        <source>validateForTurnAround();
//--------------------------------------------------------------
//Created: 11 February 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	reqType	: Integer;
begin

	if (not self.isUnactionedTIReceipt) or
	   (not self.allRTQueueEntries.isEmpty) then
		app.raiseCMException1(ERR_TURNAROUND, self.getFullDescription, null, null);
	endif;		
	
	if self.myTrackedItem = null or
	   self.myRequest.CM_TIRequest.trackedItem = null then
		app.raiseCMException1(ErrorOnStore_NullTIForRequest, self.id, null, null);
	endif;
	
	if app.myPassport.hasErrors then
		return;
	endif;
		
	app.raiseCMWarning1(VB_CONV_JOB, self.myTrackedItem.id, null, null, self.myTrackedItem);

end;</source>
    </JadeMethod>
    <JadeMethod name="validateForUpdateQueue" id="6f671133-12e1-4481-b137-dd748a00bbe8">
        <source>validateForUpdateQueue();
// ---------------------------------------------------------------------------
// Created:		February  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	lController : CM_LocationsController;
begin
	if self.myTrackedItem = null then
		//must be a Director task
		return;
	endif;
	
	lController := self.myTrackedItem.getPrimaryLocation(REAL_MODE);
	if lController = null then
		app.raiseCMException1(Err_InvalidLocation,"(Source is null)", "",null);
		return;
	endif;

end;</source>
    </JadeMethod>
