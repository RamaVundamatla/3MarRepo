        <updating/>
        <source>btnCHelpId_click(jadeMask: JadeMask input) updating;
// --------------------------------------------------------------------------------
// Created:		05 November 2009 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
