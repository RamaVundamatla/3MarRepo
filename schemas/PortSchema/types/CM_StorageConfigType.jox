    <JadeMethod name="evaluateDaysCalendar" id="cbb23d7d-b2d7-445b-b51f-3894b81e6c32">
        <source>evaluateDaysCalendar(	_term : CM_Terminal;
						_startTimeStamp: TimeStamp;
						_endTimeStamp: TimeStamp;
						_workingDays : Boolean;
						_compulsoryDays : Boolean;
						_tiTrx : CM_TITransaction
						): Real;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 November 2017	jlgndl1	Initial creation	TFS 7032
23 Oct 2024	navlw1	JIRA-33107: Invoice Logging Use Levels
25 Feb 2025	navah1	Story 34141: MTN - Performance Improvements - Review for invLog() Methods
*/

vars
	found	: Boolean;
	result	: Integer;
	storageConfig	: CM_StorageConfig;
	calendar		: CM_Calendar;
	endDate : Date;
	startDate : Date;
	canLogExtra	: Boolean;	//27.02.2025 navah1	#34141
begin
	canLogExtra	:= app.canLogExtraDetail();				//27.02.2025 navah1	#34141
	if _workingDays then
		storageConfig := _term.myStorageConfig;
		if storageConfig &lt;&gt; null then
			calendar := storageConfig.myWorkingDaysCalendar;
			if calendar &lt;&gt; null then
				result := calendar.getBusinessDaysBetween(_startTimeStamp, _endTimeStamp);
				if canLogExtra then	//27.02.2025 navah1	#34141
					app.invLog(method.qualifiedName &amp; " from 'Days Excluded Calendar', result=" &amp; result.String, LogINFO.String);
				endif;
				found := true;
			endif;
		endif;
	endif;
	
	if _compulsoryDays then
		storageConfig := _term.myStorageConfig;
		if storageConfig &lt;&gt; null then
			endDate :=  _endTimeStamp.Date;
			startDate := _startTimeStamp.Date;
			result := storageConfig.getNumWorkAndCompChargeDays( startDate, endDate, _tiTrx );
			if canLogExtra then	//27.02.2025 navah1	#34141
				app.invLog(method.qualifiedName &amp; " from 'Days Excluded Calendar' and 'Compulsory Days Calendar', result=" &amp; result.String, LogINFO.String);
			endif;
			found := true;
		endif;
	endif;
	
	if not found then
		if (_startTimeStamp.isValid and _endTimeStamp.isValid) then // TFS 1626
			result := _endTimeStamp.date - _startTimeStamp.date;
			if canLogExtra then	//27.02.2025 navah1	#34141
				app.invLog(method.qualifiedName &amp; " result=" &amp; result.String &amp; " from _end=" &amp; _endTimeStamp.String &amp; " _start=" &amp; _startTimeStamp.String, LogINFO.String);
			endif;
		endif;
	endif;
	
	return result;
	
end;
</source>
        <Parameter name="_term" type="CM_Terminal"/>
        <Parameter name="_startTimeStamp" type="TimeStamp"/>
        <Parameter name="_endTimeStamp" type="TimeStamp"/>
        <Parameter name="_workingDays" type="Boolean"/>
        <Parameter name="_compulsoryDays" type="Boolean"/>
        <Parameter name="_tiTrx" type="CM_TITransaction"/>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="evaluateDaysOnsiteAtCalendar" id="19f1a586-ae64-48db-9ffa-e02696c90df6">
        <source>evaluateDaysOnsiteAtCalendar(	_bank : CM_Bank;	
							_startTimeStamp: TimeStamp;
							_endTimeStamp: TimeStamp;
							_workingDays : Boolean;
							_compulsoryDays : Boolean;
							_tiTrx : CM_TITransaction
							): Real;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 November 2017	jlgndl1	Initial creation	TFS 7032
//Renamed 02 Mar 2020 TFS 48759 to make it clear only used for INV_CALC_TYPE_DAYS_ONSITE_AT
08 Mar 2022 jlier1 	TFS 52924
01/08/2023	navkc1	CR 59342  Task 59500: Jade - Storage Charging for Additional Storage
29/02/2023	navkc1 CR 61899 Task 61901: Jade - Storage Logic Changes
23 Oct 2024	navlw1	JIRA-33107: Invoice Logging Use Levels
25 Feb 2025	navah1	Story 34141: MTN - Performance Improvements - Review for invLog() Methods
*/

vars
	days			: Real;
	includeLastDay,
	found			: Boolean;
	startTime,
	endTime			: TimeStamp;
	storageConfig	: CM_StorageConfig;
	calendar		: CM_Calendar;
	storageDetail 	: CM_StorageDetail;
	ti 				: CM_TrackedItem;
	canLogExtra		: Boolean;	//27.02.2025 navah1	#34141
begin
	canLogExtra		:= app.canLogExtraDetail();				//27.02.2025 navah1	#34141
	storageConfig 	:= _bank.terminal.myStorageConfig;
	startTime 		:= _startTimeStamp;
	endTime 		:= _endTimeStamp;
	
	//29/02/2023	navkc1 CR 61899 Task 61901
	if _tiTrx &lt;&gt; null then
		ti := _tiTrx.myTrackedItem;
	endif;
	
	//29/02/2023	navkc1 CR 61899 Task 61901
	if ti &lt;&gt; null then
		storageDetail := ti.getMatchingFreeStorageDetail(null);
	endif;
	
	//29/02/2023	navkc1 CR 61899 Task 61901
	if storageDetail &lt;&gt; null then
		includeLastDay := storageDetail.includeLastDay;
	elseif storageConfig &lt;&gt; null then
		includeLastDay := storageConfig.includeLastDay;
	endif;
	
	// config include last day option
	//if storageConfig &lt;&gt; null then
		// 31932 don't adjust the startTime here from the storage config options - done in free storage calculation or in CM_Storage::getStartDateTimeFromConfig
		//if not storageConfig.includeLastDay then
		if not includeLastDay then //29/02/2023	navkc1 CR 61899 Task 61901
			endTime := endTime.addDays(-1);	// take the date back one day 
		endif;
	//endif;
			
	if _workingDays and
	   storageConfig &lt;&gt; null then
		calendar := storageConfig.myWorkingDaysCalendar;
		if calendar &lt;&gt; null then
			days := calendar.getBusinessDaysBetween(startTime, endTime);
			if canLogExtra then	//27.02.2025 navah1	#34141
				app.invLog(method.qualifiedName &amp; " from 'Days Excluded Calendar', result=" &amp; days.String, LogINFO.String);
			endif;
			found := true;
		endif;
		
	elseif _compulsoryDays then	//22 Sep 2017	NDL	TFS 7032
		if storageConfig &lt;&gt; null then
			days := storageConfig.getNumWorkAndCompChargeDays( startTime.Date, endTime.Date, _tiTrx );
			if canLogExtra then	//27.02.2025 navah1	#34141
				app.invLog(method.qualifiedName &amp; " from 'Days Excluded Calendar' and 'Compulsory Days Calendar', result=" &amp; days.String, LogINFO.String);
			endif;
			found := true;
		endif;
		
	endif;

	if not found then
		days := (endTime.date - startTime.date);
	endif;
	
	if startTime.time &lt; _bank.onsiteStorageChargeTime then
		days := days + 1;
	endif;
	if endTime.time &lt; _bank.onsiteStorageChargeTime then
		days := days - 1;
	endif;
	if days &lt; 0 then
		days := 0;
	endif;

	// 31528 May 2013 the pre-812 code (evaluateDaysOnsite) unconditionally added 1 to the days - restore this behaviour for Otago storage
//	if storageConfig = null then
	//02 Mar 2020	NDL TFS 48710
	//26 Jun 2020	NDL	TFS 49600 - Unconditionally restrict double dipping code to Port Otago
//	if app.myRoot.isClientPortOtago then
		/*
		//01/08/2023	navkc1	CR 59342  Task 59500
		if _tiTrx &lt;&gt; null
		and _tiTrx.isKindOf(CM_Storage)
		and _tiTrx.CM_Storage.startTransaction &lt;&gt; null
		and not _tiTrx.CM_Storage.startTransaction.isKindOf(CM_Storage) then
			//We have a receive, don't add one here
		else
			//8/3/22 jlier1 TFS 52924
			 diffHours := startTime.differenceInHours(endTime);
			 if diffHours &gt;= 24 then
				  days := days + 1;
			 endif;
		
		//	days := days + 1;
		endif;
		*/
		
		//01/08/2023	navkc1	CR 59342  Task 59500
		if _tiTrx &lt;&gt; null and _tiTrx.prevTransIsChargeableStorage() then
			days := days + 1;
		endif;
		
	//endif;

	return days;
end;</source>
        <Parameter name="_bank" type="CM_Bank"/>
        <Parameter name="_startTimeStamp" type="TimeStamp"/>
        <Parameter name="_endTimeStamp" type="TimeStamp"/>
        <Parameter name="_workingDays" type="Boolean"/>
        <Parameter name="_compulsoryDays" type="Boolean"/>
        <Parameter name="_tiTrx" type="CM_TITransaction"/>
        <ReturnType type="Real"/>
    </JadeMethod>
