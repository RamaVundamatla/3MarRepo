    <JadeMethod name="btnAudits_click" id="046e7e46-f57d-4b2d-b899-b2250ff63c7b">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnAudits_click(btn: Button input) updating;
/*
Purpose - 	
Who - NAVAB1
Date - 15AUG2023
ADO - CR 59615 TASK 59620 	
*/


vars
	detail : CM_CustomDocumentDetail;
begin

	detail := self.tblData.allSelectedObjects.first.CM_CustomDocumentDetail;
	
	if detail = null then
		detail:= self.myCustDocDetail;
	else
		if detail.pxyIsProxy() then
			detail := detail.pxyGetRealObject().CM_CustomDocumentDetail;
		endif;
	endif;
	if detail = null then
		return;
	endif;
	
	app.viewAuditFormModal(detail, self.myAssistant.class, self.myTerminal);
	

epilog

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
