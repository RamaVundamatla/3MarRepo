    <JadeMethod name="doMarkPointOnCurrentPoly" id="9d20a72c-8820-4103-a44e-4430024b1aac">
        <source>doMarkPointOnCurrentPoly(_pointIdx : Integer; _layout : CM_DeckItemLayout);
/*
Purpose:			
Date		Who		Reason
15 August 2011	cnwab1	Initial creation
*/

vars

begin

	// PAR 28008
	
	if _layout = null then
		return;
	endif;
	
	if _pointIdx &lt;= _layout.myPolygonPixels.size then
		if self.frmScrollable.myDrawingFrame.CMUI_PointDrawingFrame.setCurrentPoint(_layout.myPolygonPixels[_pointIdx]) then
		self.frmScrollable.myDrawingFrame.CMUI_PointDrawingFrame.doBtnRefreshClick();
		endif;
	endif;
epilog

end;</source>
