    <JadeMethod name="initFromUserWindow" id="d4b74601-8aa7-4e6e-b8f9-ea647880ee4b">
        <updating/>
        <source>initFromUserWindow(_userWindow: CM_UserWindow) updating;
/*
----------   ----------  --------------------------------------------------
Created:	01 March 2007 By cnwmo1

Purpose:	

Changed On   Changed By  Reason
27/07/2022	 navkc1		 ChangeRequest 53629: PNL-Cargo Comparison - Different fields save on close for Load List and Discharge List.		
----------   ----------  --------------------------------------------------
*/
vars
	userWindow		: CM_UserWindow;
	theXML, theXMLValue : String;
begin
	inheritMethod(_userWindow);
	
	if _userWindow = null then
		return;
	endif;
	theXML := _userWindow.xmlInfo;
	//par 25235 cnwrs1 3 Aug 2010
	//self.availableXML := theXML.cnEcGetTagValueOfName('Availablefields');		// 27/07/2022	navkc1	#53629
	
	self.loadXML := theXML.cnEcGetTagValueOfName('Load');		// 27/07/2022	navkc1	#53629
	self.dischargeXML:= theXML.cnEcGetTagValueOfName('Discharge');		// 27/07/2022	navkc1	#53629
	self.availableXML := self.loadXML;		// 27/07/2022	navkc1	#53629, default to Load fields
	
//	self.chkIgnoreISO.value 		:= theXML.cnEcGetTagValueOfName(self.chkIgnoreISO.name).Boolean;
//	self.chkISOGroup.value 			:= theXML.cnEcGetTagValueOfName(self.chkISOGroup.name).Boolean;
//	self.chkIgnoreBooking.value 	:= theXML.cnEcGetTagValueOfName(self.chkIgnoreBooking.name).Boolean;
//	self.chkIgnoreCmdty.value 		:= theXML.cnEcGetTagValueOfName(self.chkIgnoreCmdty.name).Boolean;
//	self.chkIgnoreDestPor.value 	:= theXML.cnEcGetTagValueOfName(self.chkIgnoreDestPor.name).Boolean;
//	self.chkIgnoreDisPort.value 	:= theXML.cnEcGetTagValueOfName(self.chkIgnoreDisPort.name).Boolean;
//	self.chkIgnoreCnsgnee.value 	:= theXML.cnEcGetTagValueOfName(self.chkIgnoreCnsgnee.name).Boolean;
//	self.chkIgnoreHaz.value 		:= theXML.cnEcGetTagValueOfName(self.chkIgnoreHaz.name).Boolean;
//	self.chkIgnoreHum.value 		:= theXML.cnEcGetTagValueOfName(self.chkIgnoreHum.name).Boolean;
//	self.chkIgnoreODim.value 		:= theXML.cnEcGetTagValueOfName(self.chkIgnoreODim.name).Boolean;
//	self.chkIgnoreOp.value 			:= theXML.cnEcGetTagValueOfName(self.chkIgnoreOp.name).Boolean;
//	self.chkIgnoreTemp.value 		:= theXML.cnEcGetTagValueOfName(self.chkIgnoreTemp.name).Boolean;
//	self.chkIgnoreVent.value 		:= theXML.cnEcGetTagValueOfName(self.chkIgnoreVent.name).Boolean;
//	self.chkIgnoreWC.value 			:= theXML.cnEcGetTagValueOfName(self.chkIgnoreWC.name).Boolean;
//	self.chkIgnoreWeight.value 		:= theXML.cnEcGetTagValueOfName(self.chkIgnoreWeight.name).Boolean;
//	self.chkIgnoreSealNum.value 	:= theXML.cnEcGetTagValueOfName(self.chkIgnoreSealNum.name).Boolean;
//	self.chkIgnoreCA.value 			:= theXML.cnEcGetTagValueOfName(self.chkIgnoreCA.name).Boolean;
//	self.chkIgnoreCargTyp.value 	:= theXML.cnEcGetTagValueOfName(self.chkIgnoreCargTyp.name).Boolean;		// 10/02/2009 cnwar2 CCMS1797 (PAR18881)

	
	//update field check boxes
//	self.chkUpdateBookRef.value 	:= theXML.cnEcGetTagValueOfName(self.chkUpdateBookRef.name).Boolean;
//	self.chkUpdateCmdty.value 		:= theXML.cnEcGetTagValueOfName(self.chkUpdateCmdty.name).Boolean;
//	self.chkUpdateDest.value 		:= theXML.cnEcGetTagValueOfName(self.chkUpdateDest.name).Boolean;
//	self.chkUpdateDisPort.value 	:= theXML.cnEcGetTagValueOfName(self.chkUpdateDisPort.name).Boolean;
//	self.chkUpdateCnsgnee.value 	:= theXML.cnEcGetTagValueOfName(self.chkUpdateCnsgnee.name).Boolean;
//	self.chkUpdateHum.value 		:= theXML.cnEcGetTagValueOfName(self.chkUpdateHum.name).Boolean;
//	self.chkUpdateISO.value 		:= theXML.cnEcGetTagValueOfName(self.chkUpdateISO.name).Boolean;
//	self.chkUpdateOper.value 		:= theXML.cnEcGetTagValueOfName(self.chkUpdateOper.name).Boolean;
//	self.chkUpdateTemp.value 		:= theXML.cnEcGetTagValueOfName(self.chkUpdateTemp.name).Boolean;
//	self.chkUpdateVent.value 		:= theXML.cnEcGetTagValueOfName(self.chkUpdateVent.name).Boolean;
//	self.chkUpdateWC.value 			:= theXML.cnEcGetTagValueOfName(self.chkUpdateWC.name).Boolean;
//	self.chkUpdateWeight.value 		:= theXML.cnEcGetTagValueOfName(self.chkUpdateWeight.name).Boolean;
//	self.chkUpdateSealNum.value		:= theXML.cnEcGetTagValueOfName(self.chkUpdateSealNum.name).Boolean;
//	self.chkUpdateCargTyp.value		:= theXML.cnEcGetTagValueOfName(self.chkUpdateCargTyp.name).Boolean;		// 10/02/2009 cnwar2 CCMS1797 (PAR18881)
//	self.chkUpdateVoy.value			:= theXML.cnEcGetTagValueOfName(self.chkUpdateVoy.name).Boolean;	// 26 Apr 2010	NDL Par 23912

	
	//19 May 2010	NDL	Par 24243
	self.chkInclOtherVoy.value		:= theXML.cnEcGetTagValueOfName(self.chkInclOtherVoy.name).Boolean;
	self.chkExclImport.value		:= theXML.cnEcGetTagValueOfName(self.chkExclImport.name).Boolean;
	self.chkExclEmpty.value			:= theXML.cnEcGetTagValueOfName(self.chkExclEmpty.name).Boolean;
//	self.chkISOGroup.value := theXML.cnEcGetTagValueOfName(self.chkISOGroup.name).Boolean;	//par25235 cnwrs1 03 aug 2010
	self.chkTranshipAdd.value := theXML.cnEcGetTagValueOfName(self.chkTranshipAdd.name).Boolean;	//par25235 cnwrs1 03 aug 2010
	
	//23 Feb 2021	NDL	TFS 50834
	if _userWindow.xmlInfo.cnEcGetTagValueOfName(self.chkCurrentVoys.name) &lt;&gt; null then
		self.chkCurrentVoys.value := _userWindow.xmlInfo.cnEcGetTagValueOfName(self.chkCurrentVoys.name).Boolean;	
	endif;
	
end;
</source>
        <Parameter name="_userWindow" type="CM_UserWindow"/>
    </JadeMethod>
