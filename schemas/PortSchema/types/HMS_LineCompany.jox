    <JadeMethod name="createAutoCharge" id="49283816-75ea-4b7f-8aca-5c256f5374b6">
        <source>createAutoCharge(_harbour : HMS_Harbour; _movement : HMS_VoyageMovement input) : HMS_ResourceUsed;
// ---------------------------------------------------------------------------
// Created:		February 2005 By Andrew Bishop cnwab1
//
// Purpose:		If a resource used is found that matches our resource type and 
//				that has no resource and is ticked as InContract then update it
//
// ---------------------------------------------------------------------------

vars
	aRes : HMS_Resource;
	pxyResUsed, aResUsed : HMS_ResourceUsed;
	poc : Boolean;
	actionTS : TimeStamp;
	numCrew : Real;
begin
	aRes := self.getResourceForHarbourMovement(_harbour, _movement.moveType);
	// No resource - no charging
	if aRes &lt;&gt; null then
	
		// go charge!
		aResUsed := _movement.getMatchingINContractResUsed(aRes); // Is it part of the contract
		if aResUsed = null then
			// no in contract resource used setup, so check if already charged in contract.
			aResUsed := _movement.getMatchingUsedResUsed(aRes, self,true); // Has it already been charged?
			if aResUsed = null then
				// ### already charged out of contract?
				aResUsed := _movement.getMatchingUsedResUsed(aRes, self,false); // Has it already been charged?
				if aResUsed = null then
					// not charged, created charge OUT of contract
					create aResUsed persistent;
					_movement.allResourceUsed.add(aResUsed);
				else
					// already charged - do nothing
					return null;
				endif;
			else
				return null;
			endif;
		else
			poc := aResUsed.partOfContract;
		endif;
			
		pxyResUsed := aResUsed.pxyGetProxyObject(); // ### PAR 10996
		if pxyResUsed = null then // ### PAR 10996
			create pxyResUsed transient;
		endif;

		 // ## PAR 10356 pass in action date and qty
		 actionTS := aResUsed.fromDateTime; // may have overridden on screen
		 if not actionTS.isValid() then
		 	actionTS := _movement.occursOnDTNEW; // else default
		 endif;
		 numCrew := aResUsed.unitsUsed; // may have overridden on screen
		 if numCrew = 0 then
		 	numCrew := _movement.numLineCrewRequired; // else default
		 endif;
		pxyResUsed.setProxy(_harbour, aRes.myResourceType,aRes,null,actionTS,aResUsed.toDateTime,numCrew,poc,null,null); 
		pxyResUsed.setHMSObject(self);
		
		aResUsed.setForCreate(pxyResUsed, app.myPassport);
	endif;

	return aResUsed;
epilog
	delete pxyResUsed;

end;</source>
        <Parameter name="_harbour" type="HMS_Harbour"/>
        <Parameter name="_movement" type="HMS_VoyageMovement" usage="input"/>
        <ReturnType type="HMS_ResourceUsed"/>
    </JadeMethod>
