    <JadeMethod name="setTableDataDiffMethods" id="3b52abb7-4c08-4616-9490-c4d1fb1b3d77">
        <source>setTableDataDiffMethods(_searchString : String; _table : CM_DataTable input) ;
// ### JIRA 36455 23OCT2026 NAVAB1
vars
	schema 			: DEV_Schema;
	class 			: DEV_Class;
	devMethod 		: DEV_Method;
	addedSchema,
	addedClass 		: Boolean;
	currentMethod	: Method;
	systemSchema	: Schema;
	systemClass		: Class;
	systemMethod	: Method;
	showResolved	: Boolean;
	jadeRegexReplacePat : JadeRegexPattern;
	classCount,							//30.07.2025 navah1 #34749
	methodCount,						//30.07.2025 navah1 #34749
	classIndex,							//30.07.2025 navah1 #34749
	schemaIndex		: Integer;      	//30.07.2025 navah1 #34749
	lineData : String;
begin
//	showResolved := self.chkShowResolved.value;
	app.mousePointer := Form.MousePointer_HourGlass;
	
	create jadeRegexReplacePat transient;
	jadeRegexReplacePat.compile("[\r\n\t\s]");
	jadeRegexReplacePat.setIgnoreCase(true);
	jadeRegexReplacePat.setExplicitCapture(true);
	
	
	_table.rows := 0;
	_table.columns := 7;
	_table.addItemObject(null,"Schema" &amp; Tab &amp; "Class" &amp; Tab &amp; "Method" &amp; Tab &amp; "Modified By" &amp; Tab &amp; "Modified Date" &amp; Tab &amp; "Signature" &amp; Tab &amp; "Misc" );
	_table.fixedRows := 1;
	_table.fixedColumns := 0;
	_table.sortType[5]   := Table.SortType_TimeStamp;
	_table.selectMode := Table.SelectMode_CurrentRow;
	
	/*
	* Differing Methods
	*/
	foreach schema in self.allSchemas do
		systemSchema := rootSchema.getSchema(schema.name);
		addedSchema := false;
		classCount := 0; //30.07.2025 navah1 #34749
		
		foreach class in schema.allClasses where class.reason = DEV_SourceCompareReportAgent.Object_Link do
			systemClass := systemSchema.getClass(class.name);
			addedClass := false;
			methodCount := 0; //30.07.2025 navah1 #34749
			foreach devMethod in class.allMethods where devMethod.reason = DEV_SourceCompareReportAgent.Object_Different do
				
				// If someone else has already looked at this method, then don't display it
				if devMethod.resolvedBy &lt;&gt; null and not showResolved then
					continue;
				endif;
				
				systemMethod := systemClass.getMethod(devMethod.name);
				if _searchString &lt;&gt; null then
					// Filter by Usercode (assumes users start with 'nav')
					if _searchString.startsWith__("nav") 
					or _searchString.startsWith__("NAV") 
					or _searchString.startsWith__("jlg") 
					or  _searchString.startsWith__("jli") 
					or _searchString.startsWith__("cnw") 
					or _searchString = "JadeLoader" 
					or _searchString = "&lt;unknown&gt;"then
						if devMethod.modifiedBy &lt;&gt; _searchString and (systemMethod &lt;&gt; null and systemMethod.getModifiedByJMT &lt;&gt; _searchString) then 
							continue;
						endif;
					else
						// Filter by method text
						if devMethod.desc.pos(_searchString, 1) = 0 then
							continue;
						endif;
					endif;
				endif;
				
				lineData := schema.name &amp; Tab &amp; class.name &amp; Tab &amp; devMethod.name &amp; Tab &amp; devMethod.modifiedBy &amp; Tab &amp; devMethod.modifiedTimeStamp.cnFormat_DDMMYY_hhmm &amp; Tab &amp; devMethod.desc &amp; Tab &amp; devMethod.miscData   ;
				
				
				methodCount += 1; //30.07.2025 navah1 #34749
				self.beginNotification(devMethod, Object_Update_Event, Response_Continuous, null);  
				
				_table.addItemObject(devMethod, lineData);
			endforeach;
			
		endforeach;
		
	endforeach;
	
epilog
	delete jadeRegexReplacePat;
		app.mousePointer := Form.MousePointer_Default;

end;</source>
        <Parameter name="_searchString" type="String"/>
        <Parameter name="_table" type="CM_DataTable" usage="input"/>
    </JadeMethod>
</Class>
