<CollClass name="Collection">
    <JadeMethod name="jssIsNotEmpty" id="058c7458-003b-4391-a36e-aaacea78d40d">
        <source>jssIsNotEmpty():Boolean;
// --------------------------------------------------------------------------------
// Created:		08 February 2001 by cnwdad1
//
// Purpose:		To check whether the receiver has any members.
//
// Parameters:	None
//
// Returns:		True if the receiver has any members, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return (not self.isEmpty());
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</CollClass>
