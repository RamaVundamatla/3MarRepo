    <JadeMethod name="picAppStat_dblClick" id="c351bf65-7c93-4477-8ddc-fae818b04803">
        <controlMethod name="Picture::dblClick"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>picAppStat_dblClick(pict: Picture input) updating;

vars
	filePic : CMDFileOpen;
begin
	create filePic;
	filePic.filter := "Pictures(*.bmp;*.ico)|*.bmp;*.ico|All files|*.*";
	if filePic.open = 0 then
		picAppStat.picture := app.loadPicture(filePic.fileName);
	endif;
	delete filePic;
end;</source>
        <Parameter name="pict" type="Picture" usage="input"/>
    </JadeMethod>
    <JadeMethod name="txtAppDesc_mouseDown" id="5ca8a578-b27c-4496-bd38-94d61915ad2b">
        <controlMethod name="TextBox::mouseDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtAppDesc_mouseDown(textbox: TextBox input; button: Integer; shift: Integer; x: Real; y: Real) updating;

vars

begin
	textbox.dragMode := 1;
end;</source>
        <Parameter name="textbox" type="TextBox" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
