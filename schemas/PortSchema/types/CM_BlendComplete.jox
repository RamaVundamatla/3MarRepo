    <JadeMethod name="getBlendedDescription" id="5a0677c7-4b7e-40a6-ba9c-84fab9d7781a">
        <source>getBlendedDescription():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 June 2021	navndl1	Initial creation	TFS 51243

*/

vars

begin

	if self.myParentBlendTrx &lt;&gt; null then
		return self.myParentBlendTrx.getBlendedDescription();
	endif;
	
	return app.getErrorString( TransType_227 );

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
