    <JadeMethod name="sh3GetVoyagesWithLots" id="8ac5f51e-60a3-4a84-9478-e477e0439973">
        <source>sh3GetVoyagesWithLots();
//----------------------------------------------------------------------
//  Created by cnwsh3
//	Date 15 December 2008
//
// Implemented version:
// 
//----------------------------------------------------------------------
vars
	voy : CM_Voyage;
	loc : CM_LocationsController;
	logLot : CM_LogLot;
	prod : CM_SOHLocation;
begin
	foreach voy in CM_Voyage.instances where voy.myLogVoyageStructure &lt;&gt; null do
		if voy.myLogVoyageStructure.allLogLots.isNotEmpty() then
			foreach logLot in voy.myLogVoyageStructure.allLogLots where logLot.allLocationsByHatchPlace.isNotEmpty() do
				foreach loc in logLot.allLocationsByHatchPlace where loc.allProductLocations.isNotEmpty() do
					//write 'inner loop';
					foreach prod in loc.allProductLocations where prod.allTrackedItems.isNotEmpty() do
						write voy.code;
					endforeach;
				endforeach;
			endforeach;
			//voy.myLogVoyageStructure.inspect();
		endif;
	endforeach;
epilog
write 'terminado';
end;</source>
    </JadeMethod>
    <JadeMethod name="sh3GlobalConstantForStringChec" id="2dc563bb-63c7-493c-b79a-dd7d8123d2ab">
        <source>sh3GlobalConstantForStringChec();
vars
	sch 		: Schema;
	constDict 	: ConstantNDict;
	cat 		: ConstantCategory;
	const 		: Constant;
	str 		: String;
	tag,
	constName,
	newStr 		: String;
	lengthStr,
	pos 		: Integer;
begin
	//CHECK GLOBAL CONSTANT XMLS FOR A STRING
	sch := currentSchema;
	tag := 'wagon';
	lengthStr := tag.length;
	cat := sch.getConstantCategory('EntTableRows');
	
	constDict := cat.getConstants;
	foreach const in constDict do
		str := const.text;
		constName := str.cnEcGetTagValueOfName('ConstantName').toLower;
		if constName = null then
			continue;
		endif;
		pos := 1;
		while pos &lt;&gt; 0 do
			if (constName[1:1] = tag[1:1]) and (constName.length &gt; 1) then
				constName := constName[2:end];
			endif;
			pos := 1;
			constName.scanUntil(tag[1:1], pos);
			if pos = 0 then
				break;
			endif;
			constName := constName[pos:end];
			if constName.length &lt; tag.length then
				break;
			endif;
			newStr := constName[1:lengthStr];
			if  newStr = tag then
				app.writeStatement( const.name);
				break;
			endif;
		endwhile;
	endforeach;
end;</source>
    </JadeMethod>
    <JadeMethod name="sh3ListExposedFields" id="ac686fee-8168-494c-ae0b-efda871a944d">
        <source>sh3ListExposedFields();
//  find all entries in all views for class CM_JRWInvoice
//derived from jreFindClassInView JadeScript
vars
	portScm,
	rws	: Schema;
	root	: Object;
	allViews,
	allTypes,
	allFeatures	: MemberKeyDictionary;
	view	: Object;
	type	: Object;
	feature	: Object;
	viewName,
	typeName,
	featureName,
	propType: String;
	cls		: Class;
	property	: Property;

begin
	rws := rootSchema.getSchema("JadeReportWriterSchema");
	if rws = null then
		app.writeStatement(method.name&amp;" no report writer schema");
		return;
	endif;
	root := rws.getClass("JRDRoot").firstInstance;
	if root = null then
		app.writeStatement(method.name&amp;" no report writer root");
		return;
	endif;
	
	portScm := rootSchema.getSchema("PortSchema");
	allViews := root.getPropertyValue("allReportingViews").MemberKeyDictionary;
	foreach view in allViews do
		viewName := view.getPropertyValue("name").String;
		allTypes := view.getPropertyValue("allReportingTypeDefns").MemberKeyDictionary;
		//type.
		foreach type in allTypes do
			typeName := type.getPropertyValue("typeName").String;
			if typeName = "CM_JRWInvoice" then
				write "CM_JRWInvoice is in " &amp; viewName;
			endif;
		endforeach;
	endforeach;
epilog
end;
</source>
    </JadeMethod>
