<Class name="CnEcXmlExcludedClasses" id="6b78f3cc-8499-4088-b024-3440fa9ec6b6">
    <superclass name="CnEcXML"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
