begin
	table := self.tblGateLanes;
	
	table.setTblDataEntRowsFromDef(app.myController.getEntTableDef (ETDef_GateLanesTable));

	table.selectMode 			:= Table.SelectMode_CurrentRow;
	table.disallowColumnSorter	:= true;
	
	col := table.getColumnByRowName (ETRow_Lane_printer);
	
	if col &gt; 0 then
		table.accessColumn (col).cellControl	:= cmbPrinter;
	endif;
	
	col := table.getColumnByRowName (ETRow_Lane_scale);
	
	if col &gt; 0 then
		table.accessColumn (col).cellControl	:= cmbWeighBridge;
