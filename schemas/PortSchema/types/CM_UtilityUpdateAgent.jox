    <JadeMethod name="utlUpdateRootTALevels" id="88ea64a2-ce87-431e-88a2-ef6ac86612b0">
        <source>utlUpdateRootTALevels(_theColours : IntegerArray; _passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:		August 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars

begin
	self.initialiseActivity();
	
	if _theColours.size &lt;&gt; 21 then
		return;
	endif;
	app.myRoot.setForUpdateTALevels(_theColours);

	app.myEventManager.createSingleObjInfoNoteEvt(app.myRoot, EVENT_ColourStackHeightsUpdate, null);					
	
	
end;</source>
