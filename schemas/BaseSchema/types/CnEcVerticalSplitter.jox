    <DbClassMap file="_usergui"/>
    <ImplicitInverseRef name="myDragControl" id="6a03cc08-c2cd-442d-98be-3bcacc880f6f">
        <embedded/>
        <type name="Control"/>
        <access>protected</access>
    </ImplicitInverseRef>
    <JadeMethod name="mouseDown" id="0d96ce83-d5d6-4246-8828-044ec1cf7391">
        <updating/>
        <source>mouseDown(frame : Frame input; button : Integer; shift : Integer; x : Real; y : Real) updating;
// --------------------------------------------------------------------------------
// Created:		11 August 1999 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 14 Nov 00	cnwrs2		Add if self.myDragControl = null.  Copy fix from JAS for
//							problem with lost mouseup when app focus is lost (by KPD)
// --------------------------------------------------------------------------------
vars

begin
	if (button = Window.MouseButton_Left) then
		if self.myDragControl = null then
			self.myDragControl := self.loadControl(form.controlCount + 1);
		endif;
		
		self.myDragControl.visible	:=	true;
		self.myDragControl.move(self.left, self.top, self.width, self.height);
		self.myDragControl.CnEcVerticalSplitter.caption	:=	'';
		self.myDragControl.zOrder(1);
	endif;

	inheritMethod(frame, button, shift, x, y);
end;</source>
        <Parameter name="frame" type="Frame" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="mouseMove" id="7eb9cefa-6152-4ffb-a527-bdb35cc50a7c">
        <updating/>
        <source>mouseMove(frame : Frame input; button : Integer; shift : Integer; x : Real; y : Real) updating;
// --------------------------------------------------------------------------------
// Created:		11 August 1999 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	minWidth, minHeight : Integer;
begin
	if (button = Window.MouseButton_Left) then
		if (self.myDragControl &lt;&gt; null) and self.parent.Control.canResize(x.Integer, 0, minWidth, minHeight) then
			self.myDragControl.move((self.left + x), self.myDragControl.top, self.myDragControl.width, self.myDragControl.height);
		elseif self.myDragControl &lt;&gt; null then
			self.myDragControl.move(minWidth, self.myDragControl.top, self.myDragControl.width, self.myDragControl.height);
		endif;
	endif;

	inheritMethod(frame, button, shift, x, y);
end;</source>
        <Parameter name="frame" type="Frame" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="mouseUp" id="58d153d4-316e-4a10-bb85-d9cf6028bd1c">
        <updating/>
        <source>mouseUp(frame : Frame input; button : Integer; shift : Integer; x : Real; y : Real) updating;
// --------------------------------------------------------------------------------
// Created:		11 August 1999 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	minWidth, minHeight : Integer;
begin
	if (button = Window.MouseButton_Left) then
		if (self.myDragControl &lt;&gt; null) and self.parent.Control.canResize(x.Integer, 0, minWidth, minHeight) then
			self.move(self.myDragControl.left, self.top, self.width, self.height);
			delete self.myDragControl;
			self.visible	:=	true;
			self.zOrder(1);
			self.parent.cnEc_MouseUp(self, button, shift, x, y);
		else
			self.move(minWidth, self.top, self.width, self.height);
			delete self.myDragControl;
			self.visible	:=	true;
			self.zOrder(1);
			self.parent.cnEc_MouseUp(self, button, shift, x, y);
		endif;
	endif;

	inheritMethod(frame, button, shift, x, y);
end;</source>
        <Parameter name="frame" type="Frame" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="windowCreated" id="d983e336-9877-492a-bf76-0dbd70b280f4">
        <updating/>
        <source>windowCreated(cntrl : Control input; persistCntrl : Control) updating;
// --------------------------------------------------------------------------------
// Created:		11 August 1999 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars

begin
	//cnwmc5 - PAR #31051
	if not self.isInPainter then
		if not app.isUsingSkin() then
			self.bevelOuter			:=	Frame.Bevel_Raised;
			self.bevelOuterWidth	:=	1;
			self.boundaryBrush		:=	Frame.BoundaryBrush_Solid;
			self.borderStyle		:=	Window.BorderStyle_None;
			self.bevelInner			:=	Frame.Bevel_None;
		else
			self.skinCategoryName	:= "vgrip";
		endif;
	endif;
	
	self.height				:=	self.parent.height;
	self.bevelInnerWidth	:=	0;
	self.boundaryWidth		:=	0;
	self.caption			:=	'';
	self.width				:=	5;
	self.mousePointer		:=	Window.MousePointer_WE;
	inheritMethod(cntrl, persistCntrl);
	
end;</source>
        <Parameter name="cntrl" type="Control" usage="input"/>
        <Parameter name="persistCntrl" type="Control"/>
    </JadeMethod>
