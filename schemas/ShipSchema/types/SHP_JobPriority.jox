    <JadeMethod name="checkForDuplicates" id="a22fdbaa-6c5e-4b77-84c3-f5f139a962d6">
        <source>checkForDuplicates(_jobPriority : CM_JobPriority ; _currentIndex : Integer) : Boolean;

vars
	fromIDX, toIDX, idx, currentCraneType : Integer;
	list : CM_QueueListBox;
	tmpJobPriority : CM_JobPriority;
begin
	list := self.lstJobPriority;
	
	fromIDX := 1;
	toIDX := list.listCount();


	foreach idx in fromIDX to toIDX do
		if list.itemLevel[idx] = self.LevelCrane then
			currentCraneType := list.itemData[idx];
			continue;
		endif;

		if list.itemLevel[idx] = self.LevelJobType or
			list.itemLevel[idx] = self.LevelPriority then
			if idx = _currentIndex then
				break;
			endif;
		endif;
	endforeach;
	
	foreach idx in fromIDX to toIDX do	
		if list.itemLevel[idx] = self.LevelJobType then
			tmpJobPriority := list.itemObject[idx].CM_JobPriority;
			if _jobPriority.jobType = tmpJobPriority.jobType and not
				_jobPriority.craneType = currentCraneType then
				return true;
			endif;
		endif;
	endforeach;
	
	return false;
end;</source>
        <Parameter name="_jobPriority" type="CM_JobPriority"/>
        <Parameter name="_currentIndex" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="checkForJobType" id="4f62796d-3625-4eb2-947d-9a3f34ed68f5">
        <source>checkForJobType(_jobPriority : CM_JobPriority ; _currentIndex : Integer) : Boolean;

vars
	fromIDX, toIDX, idx, 
	currentCraneType,
	currentPriority, 
	currentJobType,
	tmpCraneType,
	tmpPriority,
	tmpJobType : Integer;
	list : CM_QueueListBox;
begin
	list := self.lstJobPriority;
	
	fromIDX := 1;
	toIDX := list.listCount();
	
	if _jobPriority.jobType = JobTypePriority_SOB or 
		_jobPriority.jobType = JobTypePriority_Crane1 or
		_jobPriority.jobType = JobTypePriority_Crane2 then
		return false;
	endif;

	foreach idx in fromIDX to toIDX do
		
		if list.itemLevel[idx] = self.LevelCrane then
			currentCraneType := list.itemData[idx];
		endif;

		if list.itemLevel[idx] = self.LevelPriority then
			currentPriority := list.itemData[idx];
		endif;
		
		if list.itemLevel[idx] = self.LevelJobType or
			list.itemLevel[idx] = self.LevelPriority or
			list.itemLevel[idx] = self.LevelCrane then
			if idx = _currentIndex then
				break;
			endif;
		endif;
	endforeach;
	
	foreach idx in fromIDX to toIDX do	
	
		if list.itemLevel[idx] = self.LevelCrane then
			tmpCraneType := list.itemData[idx];
		endif;
		if list.itemLevel[idx] = self.LevelPriority then
			tmpPriority := list.itemData[idx];
		endif;
		
		if list.itemLevel[idx] = self.LevelJobType then 
		
			tmpJobType := list.itemData[idx];
			if tmpJobType = JobTypePriority_SOB or 
				tmpJobType = JobTypePriority_Crane1 or
				tmpJobType = JobTypePriority_Crane2 then
				continue;
			endif;
			if tmpCraneType = currentCraneType and tmpPriority = currentPriority then
				if _jobPriority.jobType &lt; JobTypePriority_LoadDLR20 and
					tmpJobType &gt;= JobTypePriority_LoadDLR20 then
					return true;
				elseif  _jobPriority.jobType &gt;= JobTypePriority_LoadDLR20 and
					tmpJobType &lt; JobTypePriority_LoadDLR20 then
					return true;
				endif;
			endif;
		endif;
	endforeach;

	return false;
end;</source>
        <Parameter name="_jobPriority" type="CM_JobPriority"/>
        <Parameter name="_currentIndex" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
