    <JadeMethod name="setupForm" id="77f7b003-f161-432a-a22b-bbe5df4a9d88">
        <updating/>
        <source>setupForm() updating;
//12 August 2008	cnwdw1	
vars
	
begin
	inheritMethod();

	self.tblFailAutoPlan.visible:=false;
	self.tblFailRequest.visible:=false;	//11 Jan 2012	NDL	Par 28953
	self.tblYAM.visible:=false;
	self.tblLocnStats.visible:=false;
	self.picCargo.visible 			:=  false;
	
	self.txtYALocation.case := TextBox.Case_Upper;
	self.btnYALocSave.default := false;
	self.btnYALocCancel.default := false;
	self.txtYALocation.selectionStyle := TextBox.SelectionStyle_SelectAllAlways;
	self.frmWorkZone.visible:=false;

	self.frmProgressCtr.move(0,0,self.frmModalDialog.clientWidth,self.frmModalDialog.clientHeight);
	self.frmModalDialog.backColor := self.backColor;
	self.btnModalDefault.visible := false;
	self.pbProgressBar.top := 38;
	self.lblModalInfo.top := self.pbProgressBar.top + self.pbProgressBar.height + 2;
	self.pbProgressBar.zOrder(0);
	self.frmModalDialog.zOrder(1);
	self.frmModalDialog.visible := false;
	self.frmModalDialog.backColor := self.backColor;
	self.frmModalDialog.centreWindow;
	
	//26 Sep 2011	NDL	Par 28236
	self.mnuPref2.visible := true;	//new version used in this form.

	self.mnuCapacity.visible := true; // JLGAB1 TFS 49959
	
	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.btnAddYA.enabled:= false;
		self.btnDeleteYA.enabled:= false;
		self.btnEditYA.enabled:= false;
		self.tblYAM.userInputEnabled := false;
		self.tblYAM.readOnly := true;
		self.dkbGridArea.myDrawingFrame.myDragSelectFrame.enabled := false;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="showColumnOrganiser" id="5e03cb88-fccf-4a49-b046-4432a7d73266">
        <updating/>
        <source>showColumnOrganiser(_dataTable : CM_DataTable input)updating;
//-----------------------------------------------------------------------
//
//  Created by: cnwsh3
//
//	Date: 18 September 2003
//
//-----------------------------------------------------------------------
begin
	if _dataTable = null then
		return;
	endif;
	
	if _dataTable = tblLocnStats or _dataTable = tblYAM then
		_dataTable.showColumnOrgSizesForm(self.myTerminal, null);
	else
// cnwdad1 20/03/2009 - PAR 19193.
		inheritMethod(_dataTable);
	endif;
end;</source>
