<CollClass name="CM_FileDataStorageHdrSet" id="46bcf9a6-fe68-4b3f-b299-fa6a1cb7b046">
    <memberType name="CM_FileDataStorageHeader"/>
    <superclass name="CM_ObjectSet"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="backgroundprocess"/>
    <JadeMethod name="swapFileData" id="437c551c-c0ea-48ec-a4da-ff912ef18b54">
        <lockReceiver/>
        <updating/>
        <source>swapFileData(_allFilesNew : CM_FileDataStorageHdrSet input)updating;
// -------------------------------------------
// Created 22 November 2005 by cnwdvb1
// -------------------------------------------
vars
	tmpFileData : CM_FileDataStorageHeader;
begin
	
	if _allFilesNew = null then
		return;
	endif;
	
	foreach tmpFileData in self discreteLock do
		self.remove(tmpFileData);
		_allFilesNew.add(tmpFileData);
	endforeach;

end;</source>
        <Parameter name="_allFilesNew" type="CM_FileDataStorageHdrSet" usage="input"/>
    </JadeMethod>
</CollClass>
