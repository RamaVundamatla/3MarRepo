    <JadeMethod name="getDateShortFormat" id="68d5a002-0d3e-4b73-8fc5-0dab8bd09d23">
        <source>getDateShortFormat() : String;
// ---------------------------------------------------------------------------
// Created:     04 April 2006 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpDateInfo	: DateFormat;
	yearStr		: String;
	sep			: String;
	str			: String;

begin

	tmpDateInfo := app.currentLocaleInfo.dateInfo;
	
	sep := tmpDateInfo.separator;
	
	if tmpDateInfo.showFullCentury then
		yearStr := 'yyyy';
	else
		yearStr := 'yy';
	endif;

	if tmpDateInfo.shortFormatOrder = DateFormat.MonthDayYear then
		str := 'MM' &amp; sep &amp; 'dd' &amp; sep &amp; yearStr;
	elseif tmpDateInfo.shortFormatOrder = DateFormat.DayMonthYear then
		str := 'dd' &amp; sep &amp; 'MM' &amp; sep &amp; yearStr;
	elseif tmpDateInfo.shortFormatOrder = DateFormat.YearMonthDay then
		str := yearStr &amp; sep &amp; 'MM' &amp; sep &amp; 'dd';
	else
		// the default
		str := 'dd' &amp; sep &amp; 'MM' &amp; sep &amp; yearStr;
	endif;

	return str;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTimeShortFormat" id="42857a5b-37da-4472-837a-03ad4621ffc5">
        <source>getTimeShortFormat(_includeSeconds : Boolean) : String;
// ---------------------------------------------------------------------------
// Created:     16 June 2008 by cnwrs2
//
// Purpose:     Need to allow for different seperators
// ---------------------------------------------------------------------------
vars
	tmpTimeInfo	: TimeFormat;
	sep			: String;
	str			: String;

begin
	tmpTimeInfo := app.currentLocaleInfo.timeInfo;
	
	sep := tmpTimeInfo.separator;
	
	if _includeSeconds then
		str := 'HH' &amp; sep &amp; 'mm' &amp; sep &amp; 'ss';
	else
		str := 'HH' &amp; sep &amp; 'mm';
	endif;

	return str;
end;</source>
        <Parameter name="_includeSeconds" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="initialize" id="a0604e82-ca4e-46bf-93d7-f6ada283ce1d">
        <updating/>
        <source>initialize() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
30 August 2010	cnwkpd1	PAR #23525 - System performance enhancements

*/

vars

begin
	inheritMethod();

	create self.jmtCurrentLocaleInfo transient;
	currentSchema.getLocaleFullInfo( currentSchema.getCurrentLocaleId, self.jmtCurrentLocaleInfo );

epilog

end;</source>
    </JadeMethod>
