    <JadeMethod name="setComboValues" id="28792767-0c7b-4f8a-ae57-36234123a1d6">
        <source>setComboValues(_combo: ComboBox input; _params: CM_QueryCriteriaLineHolder; _queryOperator: CM_QueryOperator; _passport: CM_Passport);
/*
Purpose:			
Parameters:			
Return Value:		

Date		Who		Reason
========================================================
08/02/2010	cnwcs5	CCMS 1925/PAR 22295 Release Summaries (Initial creation)
*/
vars
	type	: CM_ISOType;
	coll	: CM_ISOTypeByCodeDict;
begin
	_combo.clear();
	
	coll := app.myRoot.allISOTypes;
	
	foreach type in coll do
		_combo.itemObject[_combo.addItem(type.code &amp; Tab &amp; type.description)] := type;
	endforeach;

	if CM_QStringLookup.hasInstance(_queryOperator) then
		_combo.listObject := coll[_queryOperator.CM_QStringLookup.selectionValue];
		
	elseif CM_QStringLookupNotEqual.hasInstance(_queryOperator) then
		_combo.listObject := coll[_queryOperator.CM_QStringLookupNotEqual.selectionValue];	
	endif;
end;</source>
        <Parameter name="_combo" type="ComboBox" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_queryOperator" type="CM_QueryOperator"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="translateToDisplayValue" id="16ffc3f8-ba69-441a-abc0-aee259d687ef">
        <source>translateToDisplayValue(_value: Any): String;
/*
Purpose:			
Parameters:			
Return Value:		

Date		Who		Reason
========================================================
08/02/2010	cnwcs5	CCMS 1925/PAR 22295 Release Summaries (Initial creation)
*/
vars

begin
	if _value.isKindOf(CM_ISOType) then
		if _value &lt;&gt; null then
			return _value.CM_ISOType.code;
		else
			return null;
		endif;
	else
		return _value.String;
	endif;

epilog

end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="translateToSearchValue" id="6bc797f7-9019-40a4-8620-7a38ff27485a">
        <source>translateToSearchValue(_value: Any): Any;
/*
Purpose:			
Parameters:			
Return Value:		

Date		Who		Reason
========================================================
08/02/2010	cnwcs5	CCMS 1925/PAR 22295 Release Summaries (Initial creation)
*/
vars

begin
	if _value &lt;&gt; null then
		if _value.isKindOf(Collection) then	
			return _value;
		endif;
	
		if _value.isKindOf(CM_ISOType) then
			return _value.CM_ISOType;
		endif;
	endif;
	
	return app.myRoot.allISOTypes[_value.String];
epilog

end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="Any"/>
    </JadeMethod>
</Class>
