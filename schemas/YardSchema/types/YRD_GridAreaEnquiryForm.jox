    <JadeMethod name="tblGridAreaInfo_mouseMove" id="393eb002-959d-4374-9675-bbabfa6f1d61">
        <controlMethod name="Table::mouseMove"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblGridAreaInfo_mouseMove(table: Table input; button: Integer; shift: Integer; x: Real; y: Real) updating;
// ---------------------------------------------------------------------------
// Created:		October 2003 By Andrew Bishop cnwab1
//
// Purpose:		was playing with un docking the extra info table
//
// ---------------------------------------------------------------------------

vars

begin
	return;

	if button = Window.MouseButton_Left 
	and table.dragMode &lt;&gt; DragMode_Drag
	and app.dragDetected(x, y, self.origXPos, self.origYPos) then
		table.dragMode := DragMode_Drag;
		self.frmInfoDrag.move(self.tblGridAreaInfo.left,self.tblGridAreaInfo.top,self.tblGridAreaInfo.width,self.tblGridAreaInfo.height);
		self.frmInfoDrag.visible := true;
//		table.dragCursor := null;
	endif;
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
