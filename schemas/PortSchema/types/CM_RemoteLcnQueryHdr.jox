<Class name="CM_RemoteLcnQueryHdr" id="18b23086-907d-4573-b9e7-00b7b7696e06">
    <superclass name="CM_RemoteDataHdr"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>&lt;display&gt;Location Query&lt;/display&gt;</text>
    <DbClassMap file="remoteDataProcessing"/>
    <CompAttribute name="allLcns" id="3ca1631c-39f9-498a-9b05-ce013319b6c7">
        <type name="StringArray"/>
        <access>readonly</access>
    </CompAttribute>
    <PrimAttribute name="tagAttributes" id="08eae7fe-51b8-4a38-95ee-3c485d15e032">
        <length>31</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="doVersionControl" id="4ad3c915-5d7b-45e6-8e49-8a14df61abb4">
        <source>doVersionControl(_error : Integer output; _errorTxt : String output) : String protected;

// cnwdvb1 07 May 2003 

vars

begin

	if self.theVersion = 1 then
		return self.getLcnQueryResponse(_error, _errorTxt);
	elseif self.theVersion &gt;= 2 then
		return self.getLcnQueryResponseNew(_error, _errorTxt);
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="_error" type="Integer" usage="output"/>
        <Parameter name="_errorTxt" type="String" usage="output"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDocketDetail" id="7b0554e2-c912-4d6d-8242-38aa9914729f">
        <source>getDocketDetail(_sohLocation : CM_SOHLocation; _bolSet : CM_BOLSet input) protected;

vars
	bol		: CM_BOL;
	tmpSet	: CM_BOLSet;
begin

		// this is a virtual collection (very bad) Thanks Kevin
	tmpSet := _sohLocation.allReceivalBOLs;

	foreach bol in tmpSet do
		if not _bolSet.includes(bol) then
			_bolSet.add(bol);
		endif;
	endforeach;	

epilog
	delete tmpSet;
end;</source>
        <access>protected</access>
        <Parameter name="_sohLocation" type="CM_SOHLocation"/>
        <Parameter name="_bolSet" type="CM_BOLSet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getLcnQueryResponse" id="115d80d9-a130-4579-b4a7-9265da8a6e66">
        <source>getLcnQueryResponse(_error : Integer output; _errorTxt : String output) : String protected;
// 29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls

vars

	type,
	class 			: String;
	theResponse		: String;
	myTerminal		: CM_Terminal;
	errStr,
	lcnId,
	detail,
	areaId			: String;
	location		: CM_LocationsController;
	analysis		: CM_SOHLocation;
	isFound			: Boolean;
	allDockets		: CM_BOLSet;
	pos,
	logConstant,
	taType			: Integer;
	ti				: CM_TrackedItem;
	area			: CM_TerminalArea;
	bol				: CM_BOL;
		
begin

	create allDockets transient;
	self.getAttributes(self.tagAttributes, class, type);
	self.getLogConstant(class, logConstant, taType);
	if logConstant = 0 then
		_error := Err_InvalidClass;
		_errorTxt := app.getErrorString1(Err_InvalidClass, class);
		return null;
	endif;
	
	if type &lt;&gt; Type_Lcn then
		_error := Err_InvalidType;
		_errorTxt := app.getErrorString1(Err_InvalidType, type);
		return null;
	endif; 
	
	myTerminal := app.myPassport.myTerminal;
	if myTerminal = null then
		_error 		:= Err_InvalidTerminal;
		_errorTxt	:= app.getErrorString1(Err_InvalidTerminal, terminal);
		return null;
	endif;

	if self.allLcns.size &gt; 0 then
		theResponse := 
		self.formatAsXMLPrefix(XML_BDY) &amp; 
		self.formatAsXMLPrefix(XML_LCNQRYRSP);
				
		foreach detail in self.allLcns do
			pos := 1;
			areaId		:= detail.scanUntil(',', pos);
			lcnId		:= detail[pos + 1: end];
			area := myTerminal.allTerminalAreas[areaId];
			location := area.getLocationsControllerFromId(lcnId);
			if location = null then
				errStr := errStr &amp; ', ' &amp; lcnId;
			else
				theResponse := theResponse &amp; '&lt;' &amp; XML_LCN &amp; ' class=' &amp; class &amp; ' type="LCN"' &amp; '&gt;' &amp; CrLf &amp;
				self.formatAsXML(XML_TERMINAL, self.terminal) &amp; 
				self.formatAsXML(XML_ID, areaId &amp; ',' &amp; lcnId);
				foreach analysis in location.allProductLocations where analysis.allTrackedItems.size &gt; 0 do
					theResponse := theResponse &amp; self.formatAsXMLPrefix(XML_LCNSOH);
					theResponse := theResponse &amp; self.formatAsXML(XML_SOH, analysis.getDetailForRemoteQuery());
					self.getDocketDetail(analysis, allDockets);
					theResponse := theResponse &amp; 
					'&lt;' &amp; XML_TIDTLS &amp; ' class=' &amp; class &amp; ' type="FULL"' &amp; '&gt;' &amp; CrLf;
					foreach ti in analysis.allTrackedItems do
						theResponse := theResponse &amp; self.formatAsXML(XML_TI, ti.getDetailForRemoteQuery(Type_Full, self.theVersion));
					endforeach;
					theResponse := theResponse &amp; self.formatAsXMLSuffix(XML_TIDTLS) &amp; self.formatAsXMLSuffix(XML_LCNSOH);
				endforeach;
				theResponse := theResponse &amp; '&lt;' &amp; XML_BOL &amp; ' class=' &amp; class &amp; '&gt;' &amp; CrLf;
				foreach bol in allDockets do
					
					theResponse := theResponse &amp; self.formatAsXML(XML_BOLHDR, bol.getDetailForRemoteQuery(self.theVersion)); 
				endforeach;
				theResponse := theResponse &amp; self.formatAsXMLSuffix(XML_BOL);
				isFound := true;
				theResponse := theResponse &amp; self.formatAsXMLSuffix(XML_LCN);
			endif;
		endforeach;

		if errStr.length &gt; 2 then
			_error := Err_LocationNotFound;
			_errorTxt := app.getErrorString1(Err_LocationNotFound, null) &amp; errStr[3 : end];
		endif;
		
		if isFound then
			return theResponse &amp; self.formatAsXMLSuffix(XML_LCNQRYRSP) &amp; self.formatAsXMLSuffix(XML_BDY);
		endif;
	endif;
	return null;
epilog
	
	delete allDockets;
end;</source>
        <access>protected</access>
        <Parameter name="_error" type="Integer" usage="output"/>
        <Parameter name="_errorTxt" type="String" usage="output"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getLcnQueryResponseNew" id="ff789c94-320a-49a0-a1cc-1b6ab348c3c2">
        <source>getLcnQueryResponseNew(_error : Integer output; _errorTxt : String output) : String protected;

/*

Date		Who		Reason
23 Dec 2010	cnwkpd1	PAR #26678 - Tidy up transient leaks
29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
*/

vars

	type,
	class 			: String;
	theResponse		: String;
	myTerminal		: CM_Terminal;
	errStr,
	lcnId,
	detail,
	areaId			: String;
	location		: CM_LocationsController;
	analysis		: CM_SOHLocation;
	isFound, 
	isFound2		: Boolean;
	allDockets		: CM_BOLSet;
	pos,
	logConstant,
	taType			: Integer;
	ti				: CM_TrackedItem;
	area			: CM_TerminalArea;
	bol				: CM_BOL;
	iter			: Iterator;
		
begin

	create allDockets transient;
	self.getAttributes(self.tagAttributes, class, type);
	self.getLogConstant(class, logConstant, taType);
	if logConstant = 0 then
		_error := Err_InvalidClass;
		_errorTxt := app.getErrorString1(Err_InvalidClass, class);
		return null;
	endif;

	if type &lt;&gt; Type_Lcn and type &lt;&gt; Type_LcnBol and type &lt;&gt; Type_LcnTkts then
		_error := Err_InvalidType;
		_errorTxt := app.getErrorString1(Err_InvalidType, type);
		return null;
	endif; 
	
	myTerminal := app.myPassport.myTerminal;
	if myTerminal = null then
		_error 		:= Err_InvalidTerminal;
		_errorTxt	:= app.getErrorString1(Err_InvalidTerminal, terminal);
		return null;
	endif;

	if self.allLcns.size &gt; 0 then
		theResponse := 
		self.formatAsXMLPrefix(XML_BDY) &amp; 
		self.formatAsXMLPrefix(XML_LCNQRYRSP);
				
		foreach detail in self.allLcns do
			isFound2 := false;
			pos := 1;
			areaId		:= detail.scanUntil(',', pos).trimBlanks;
			if detail.length &lt; (pos + 1) then
				continue;
			endif;
			lcnId		:= detail[pos + 1: end].trimBlanks;
			delete iter;		// PAR #26678
			iter := myTerminal.allTerminalAreas.createIterator();
		//	foreach area in myTerminal.allTerminalAreas where area.type = taType do
			while iter.next(area) do
				if area.type &lt;&gt; taType then
					continue;
				endif;
				if areaId &lt;&gt; '*' and area.getID().trimBlanks() &lt;&gt; areaId then
					continue;
				endif;
				foreach location in area.allLocationsControllers do
					allDockets.clear();
					if lcnId &lt;&gt; '*' and location.getID().trimBlanks() &lt;&gt; lcnId then
						continue;
					endif;
					beginLoad;
					
					theResponse := theResponse &amp; '&lt;' &amp; XML_LCN &amp; ' class=' &amp; class &amp; ' type=' &amp; type &amp; '&gt;' &amp; CrLf &amp;
								self.formatAsXML(XML_TERMINAL, self.terminal) &amp; 
								self.formatAsXML(XML_ID, area.getID() &amp; ',' &amp; location.getID());

					// ccms 1119, par 27433 - new fields for LcnQueryRsp. 02/05/2011			
					if self.theVersion.Integer &gt;= 8 then
						theResponse := theResponse &amp; 
							self.formatAsXML(XML_SUPPLIER,		location.getDisplayStringForAttribute(ETRow_Operator, false)) &amp;
							self.formatAsXML(XML_SPECIES,		location.getDisplayStringForAttribute(ETRow_LogSpecies, false)) &amp;
							self.formatAsXML(XML_GRADE,			location.getDisplayStringForAttribute(ETRow_LogGrade, false)) &amp;
							self.formatAsXML(XML_STATUS,		location.getDisplayStringForAttribute(ETRow_Status, false)) &amp;	// 27957
							self.formatAsXML(XML_LOGTYPE,		location.getDisplayStringForAttribute(ETRow_LogType, false)) &amp;
							self.formatAsXML(XML_TREATMENT,		location.getDisplayStringForAttribute(ETRow_LogTreatment, false)) &amp;	// 27957
							self.formatAsXML(XML_LENGTH,		location.getDisplayStringForAttribute(ETRow_LogLength, false)) &amp;
							self.formatAsXML(XML_CHECKSCALED,	location.CM_LogController.checkScaled.String ) &amp;
							self.formatAsXML(XML_DOCKETCHECKED,	location.CM_LogController.docketChecked.String ) &amp;
							self.formatAsXML(XML_INSPECTED,		location.CM_LogController.isInspected.String ) &amp;
							self.formatAsXML(XML_FUMIGATED,		location.CM_LogController.isFumigated.String ) &amp;
							self.formatAsXML(XML_LCNCOMMENT,	location.getDisplayStringForAttribute(ETRow_Comment, false)) &amp;
							self.formatAsXML(XML_TOTALVOLUME,	location.getDisplayStringForAttribute(ETRow_TotalVolume, false)) &amp;
							self.formatAsXML(XML_TOTALWEIGHT,	location.getDisplayStringForAttribute(ETRow_TotalWeight, false)) &amp;
							self.formatAsXML(XML_TOTALPIECES,	location.getDisplayStringForAttribute(ETRow_NumItems, false)); 
					endif;

					foreach analysis in location.allProductLocations where analysis.allTrackedItems.size &gt; 0 do
						theResponse := theResponse &amp; self.formatAsXMLPrefix(XML_LCNSOH);
						theResponse := theResponse &amp; self.formatAsXML(XML_SOH, analysis.getDetailForRemoteQuery());
						if type = Type_LcnTkts then
							theResponse := theResponse &amp; 
							'&lt;' &amp; XML_TIDTLS &amp; ' class=' &amp; class &amp; ' type="FULL"' &amp; '&gt;' &amp; CrLf;
							foreach ti in analysis.allTrackedItems do
								theResponse := theResponse &amp; self.formatAsXML(XML_TI, ti.getDetailForRemoteQuery(Type_Full, self.theVersion));
							endforeach;
							theResponse := theResponse &amp; self.formatAsXMLSuffix(XML_TIDTLS);
						endif;
						theResponse := theResponse &amp; self.formatAsXMLSuffix(XML_LCNSOH);
						if type = Type_LcnTkts or type = Type_LcnBol then 
							self.getDocketDetail(analysis, allDockets);
						endif;
					endforeach;
					
					if (type = Type_LcnTkts or type = Type_LcnBol) and allDockets.size &gt; 0 then 
						theResponse := theResponse &amp; '&lt;' &amp; XML_BOL &amp; ' class=' &amp; class &amp; '&gt;' &amp; CrLf;
						foreach bol in allDockets do
							theResponse := theResponse &amp; self.formatAsXML(XML_BOLHDR, bol.getDetailForRemoteQuery(self.theVersion)); 
						endforeach;
						theResponse := theResponse &amp; self.formatAsXMLSuffix(XML_BOL);
					endif;
					
					isFound := true;
					isFound2 := true;
					theResponse := theResponse &amp; self.formatAsXMLSuffix(XML_LCN);
					
					endLoad;
				endforeach;
//			endforeach;
			endwhile;
			if not isFound2 then
				errStr := errStr &amp; ', ' &amp; lcnId;
			endif;
		endforeach;
		
		if errStr.length &gt; 2 then
			_error := Err_LocationNotFound;
			_errorTxt := app.getErrorString1(Err_LocationNotFound, null) &amp; errStr[3 : end];
		endif;

		if isFound then
			return theResponse &amp; self.formatAsXMLSuffix(XML_LCNQRYRSP) &amp; self.formatAsXMLSuffix(XML_BDY);
		endif;
	endif;
	return null;
epilog
	endLoad;
	delete allDockets;
	delete iter;
end;</source>
        <access>protected</access>
        <Parameter name="_error" type="Integer" usage="output"/>
        <Parameter name="_errorTxt" type="String" usage="output"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getMessageResponseType" id="68e32a9e-3f42-444b-8513-d604d4d15277">
        <source>getMessageResponseType(): String;

vars

begin
	return CM_RemoteDataManager.LCNQUERYRSP;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="processExternal" id="aee1c69d-f4ac-462b-a6da-451c1ae2bcce">
        <updating/>
        <source>processExternal(_parseAgent: CM_RemoteParseAgent io): String updating;

vars

	err			: Integer;
	errTxt		: String;
	response	: String;
	headerCast	: CM_RemoteDataHdr;

begin

	response := inheritMethod(_parseAgent);
	if response = null then
		if _parseAgent.createLcnQueryDetail(self) then
			response := self.doVersionControl(err, errTxt);
			return self.doBuildMessage(self.xmlResponse(err, errTxt) &amp; response);
		endif;
		response := app.getErrorString1(Err_XML, 'location query');
		return self.doBuildMessage(self.xmlResponse(Err_XML , response));
	endif;
	headerCast := self;
	return self.doBuildMessage(self.xmlDefaultResponse(headerCast, Err_XML , response));
			
end;</source>
        <Parameter name="_parseAgent" type="CM_RemoteParseAgent" usage="io"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setProxyForLcnQueryHdr" id="295ab96a-4f8b-43bd-a19b-5a099f409429">
        <updating/>
        <source>setProxyForLcnQueryHdr(_tagAttributes : String; _allLcns : StringArray) updating;

vars

begin

	self.raiseExceptionIfNotTransient(method);
	self.tagAttributes := _tagAttributes;
	_allLcns.copy(self.allLcns);

end;</source>
        <Parameter name="_tagAttributes" type="String"/>
        <Parameter name="_allLcns" type="StringArray"/>
    </JadeMethod>
</Class>
