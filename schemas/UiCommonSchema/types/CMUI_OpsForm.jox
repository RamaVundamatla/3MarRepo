    <JadeMethod name="lstJobs_mouseDown" id="bbd34aed-bfde-4d84-a8af-961326177892">
        <controlMethod name="ListBox::mouseDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>lstJobs_mouseDown(listbox: ListBox input; button: Integer; shift: Integer; x: Real; y: Real) updating;
// ---------------------------------------------------------------------------
// Created:		January  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	obj			: CM_Object;
	listPointer	: Integer;
	
begin
	// sgp 15 July 2003 : select the clicked item here instead of in the
	// click method so that it is selected before a drag drop.
	
	if button = Window.MouseButton_Left then
		obj := listbox.listObject.CM_Object;
		
		if self.myCurrentListObject &lt;&gt; obj then
			//clean up
			//if shift.bitAnd(1) &lt;&gt; 0 then
				self.updateSelectedJobs(obj, shift);			
				self.lstJobsChange(obj);			
			//else
			//	self.updateSelectedJobs(obj, shift);						
			//	self.lstJobsChange(obj);
			//endif;			
		endif;
	elseif button = Window.MouseButton_Right then
		if app.isDevelopmentSystem() and shift.cnEcIsCtrlKey() then
			listPointer	:=	listbox.getListIndex(x, y);
			
			if listPointer &lt;&gt; CNEC_NULL_INDEX then
				obj	:=	listbox.itemObject[listPointer].CM_Object;
				
				if obj &lt;&gt; null then
					obj.inspect();
				endif;
			endif;
		endif;
	endif;

	self.dragMode := DragMode_None;	
	
	if button = 1 then
		self.origXPos := x;
		self.origYPos := y;
	endif;
end;</source>
        <Parameter name="listbox" type="ListBox" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="lstJobs_mouseMove" id="eaba6616-7fbe-4775-a0e7-ef5e138a8b9c">
        <controlMethod name="ListBox::mouseMove"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>lstJobs_mouseMove(listbox: ListBox input; button: Integer; shift: Integer; x: Real; y: Real) updating;
//--------------------------------------------------------------
//Created: 02 April 2003 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	self.lstJobShowToolTip(x,y);
	if button &lt;&gt; 1 then
		return;
	endif;
	if self.myCurrentListObject = null then
		return;
	endif;
	if app.dragDetected(x, y, origXPos, origYPos) then
		self.lstJobsMouseMoveEvent(button, shift, x, y);
		origXPos := null;
		origYPos := null;
	endif;
end;</source>
        <Parameter name="listbox" type="ListBox" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="lstJobs_pictureClick" id="45cd4681-1e42-47ed-9949-681a3b9a591f">
        <controlMethod name="CM_QueueListBox::pictureClick"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>lstJobs_pictureClick(listbox: ListBox input; picIndex: Integer; whatClicked: Integer) updating;
//--------------------------------------------------
// Created:	23 February 2004 By: cnwgd1
//--------------------------------------------------
vars

begin
	if whatClicked = listbox.PictureClick_PlusMinus
	or whatClicked = listbox.PictureClick_ItemPicture then
		listbox.clearAllSelected();
		listbox.listIndex := picIndex;
		listbox.itemSelected[picIndex] := true;
		self.lstJobsChange(listbox.listObject.CM_Object);
	endif;
end;</source>
        <Parameter name="listbox" type="ListBox" usage="input"/>
        <Parameter name="picIndex" type="Integer"/>
        <Parameter name="whatClicked" type="Integer"/>
    </JadeMethod>
