    <JadeMethod name="getErrorStringShortText" id="59695080-3c64-4818-837e-a33a946bc2c8">
        <source>getErrorStringShortText(errorCode : Integer) : String;

//Created by: cnwjo3
//Purpose: Get the shorttext of the translatable string for headings and titles

vars
	errMsg : XLAT_Translation;
	errStr : String;	
begin

	if errorCode &lt; self.baseErrorNum then
		return self.getJadeErrorString(errorCode);
	endif;

	errMsg := self.zGetTranslatedText(XLAT_Exceptions, errorCode);
	if errMsg.shortText &lt;&gt; null then
		return errMsg.shortText;
	endif;
	
	return "";
end;</source>
        <Parameter name="errorCode" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getExtension" id="f754f10b-e059-4527-83b0-821db860654c">
        <source>getExtension(_outputDestination : Integer) : String;
// -------------------------------------------
// Created 05 March 2004 by cnwdvb1
// -------------------------------------------
vars

begin

	if _outputDestination = JadeReportWriterReport.CSV then
		return '.csv';
	elseif _outputDestination = JadeReportWriterReport.HTML then
		return '.html';
	elseif _outputDestination = JadeReportWriterReport.RTF then
	return '.rtf';
	elseif _outputDestination = JadeReportWriterReport.XML then
	return '.xml';
	elseif _outputDestination = CM_QryReport.PDF_Format then
		return '.pdf';
	else
		return '.txt';
	endif;
	


end;</source>
        <Parameter name="_outputDestination" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getFileBinaryFromServerBin" id="99ed9fcb-9567-4395-bb33-59b4aff2fd43">
        <executionLocation>server</executionLocation>
        <source>getFileBinaryFromServerBin(_binName: String):Binary serverExecution;
//----------------------------------------------------------------
//	Created:	19 November 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	bin		: Binary;
	binDir	: String;
	theFile	: File;

begin
	binDir := app.getJadeInstallDir();
	create theFile transient;  
	theFile.kind := File.Kind_Binary;
	theFile.mode := File.Mode_Input;
	theFile.fileName := binDir &amp; "\" &amp; _binName;
	
	if theFile.tryOpen() then
		bin := theFile.readBinary(theFile.fileLength());
	else
		//so that we don't end up uncompressing nothing
		bin := "null".Binary;
	endif;
	
// cnwdad1 25/02/2009 - PAR #18366.
//	return bin.compress;
	return bin.compressToBinary(Binary.Compression_ZLib);
epilog
	theFile.close();
	delete theFile;
end;</source>
        <Parameter name="_binName" type="String"/>
        <ReturnType type="Binary"/>
    </JadeMethod>
    <JadeMethod name="getFileLastModified" id="6ada5a0a-8e64-47e3-8868-dc1fb2dd96b9">
        <source>getFileLastModified(	_filePath : String;
						_modifiedTS : TimeStamp io );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 September 2013	cnwndl1	Initial creation	Par 32466

*/

vars

	file		: File;

begin

	_modifiedTS.setDate(null);
	_modifiedTS.setTime(null);
	
	if _filePath = null then
		return;
	endif;
	
	create file transient;
	file.fileName					:= _filePath;
	file.mode						:=	File.Mode_Input;
	file.shareMode					:=	File.Share_Read;
	file.kind						:=	File.Kind_Binary;
	
	/*if not file.isAvailable() then
		return;
	endif;*/
	
	
	if not file.tryOpen then
		return;
	else
		//There is an existing file.
		_modifiedTS.setDate( file.lastModifiedTime.Date );
		_modifiedTS.setTime( file.lastModifiedTime.Time );
		file.close;
	endif;

epilog
	
	delete file;
	
end;</source>
        <Parameter name="_filePath" type="String"/>
        <Parameter name="_modifiedTS" type="TimeStamp" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getFileLastModifiedWithWait" id="5f66e2f0-cd00-494f-bbba-f09fee24ff08">
        <source>getFileLastModifiedWithWait(	_filePath : String;
								_modifiedTS : TimeStamp io;
								_wait, _tryFor : Integer		);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
//11/07/2024	navkc1 CR 64837 Task 64852: Jade - Cash API Binary PDF
//
vars
	file		: File;
	tries 		: Integer;

begin
	_modifiedTS.setDate(null);
	_modifiedTS.setTime(null);
	
	if _filePath = null then
		return;
	endif;
	
	create file transient;
	file.fileName					:= _filePath;
	file.mode						:=	File.Mode_Input;
	file.shareMode					:=	File.Share_Read;
	file.kind						:=	File.Kind_Binary;
	
	if file.isAvailable() then
		while true do
			if not file.tryOpen then
				process.sleep(_wait);
			else
				//There is an existing file.
				_modifiedTS.setDate( file.lastModifiedTime.Date );
				_modifiedTS.setTime( file.lastModifiedTime.Time );
				file.close;
			endif;
			tries := tries + 1;
			if tries &gt; _tryFor then
				break;
			endif;
		endwhile;
	endif;

epilog
	delete file;
end;</source>
        <Parameter name="_filePath" type="String"/>
        <Parameter name="_modifiedTS" type="TimeStamp" usage="io"/>
        <Parameter name="_wait" type="Integer"/>
        <Parameter name="_tryFor" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getFileName" id="a1f59dbf-304d-4d7f-9aee-c864d8700999">
        <source>getFileName(_filePath: String): String;

vars

	tmp	: String;
	c	: Character;
	i	: Integer;

begin

	i := _filePath.length;
	while i &gt; 0 do
		c := _filePath[i];
		if c = '/' or c='\' then
			break;
		endif;
		tmp := tmp &amp; c;
		i := i - 1;
	endwhile;
	return tmp.reverse();
	

end;</source>
        <Parameter name="_filePath" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getFilePath" id="15a570c2-4504-4942-9e96-425789748996">
        <source>getFilePath(_defaultPath, _defaultExtension, _defaultFileName : String; openMode : Boolean) : String;
// -------------------------------------------
// Created 23 November 2004 by cnwdvb1
// -------------------------------------------
vars

	fileDialog	 		: CMDFileOpen;
	fileDialogSave	 	: CMDFileSave;
	fileString			: String;

begin

	if openMode then
		create fileDialog transient;
		fileDialog.initDir := _defaultPath;
		fileDialog.filter := _defaultExtension;
		fileDialog.fileName := _defaultFileName;
		if fileDialog.open() = 0 then
			return fileDialog.fileName;
		endif;
	else	// save dialog	ccms 1051 cnwvu1
		create fileDialogSave transient;
		fileDialogSave.initDir := _defaultPath;
		fileDialogSave.filter := _defaultExtension;
		fileDialogSave.fileName := _defaultFileName;
		if fileDialogSave.open() = 0 then
			return fileDialogSave.fileName;
		endif;
	endif;
	
	return null;

epilog
	if openMode then
		delete fileDialog;
	else
		delete fileDialogSave;
	endif;
end;</source>
        <Parameter name="_defaultPath" type="String"/>
        <Parameter name="_defaultExtension" type="String"/>
        <Parameter name="_defaultFileName" type="String"/>
        <Parameter name="openMode" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getFileStatus" id="d91628e6-b0b9-49d9-87de-2b096111ebd4">
        <source>getFileStatus(_fileName: String; _clientPath: String; _serverPath: String; _sizeToDownload: Integer output): Integer;
/*

Purpose:			


Return Value:		


Date		Who		Reason
04 May 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars
	rtnStatus,
	localSize,
	serverSize		: Integer;
	fileToCheck		: String;
	localLastModifiedTime, serverLastModifiedTime: TimeStamp;
begin
	fileToCheck := _clientPath &amp; _fileName;
	if not global.checkFileExists(fileToCheck, true, localSize, localLastModifiedTime) then
		rtnStatus := FileStatus_AbsentClient;
	endif;
	
	fileToCheck := _serverPath &amp; _fileName;
	if not global.checkFileExistsServer(fileToCheck, serverSize, serverLastModifiedTime) then
		rtnStatus := FileStatus_AbsentEverywhere;
	endif;		
	
	if rtnStatus = null then
		if (serverSize /1024).Integer &lt;&gt; (localSize / 1024).Integer and
		   serverLastModifiedTime &gt; localLastModifiedTime then
			rtnStatus := FileStatus_OutOfDate;
		else
			rtnStatus := FileStatus_OK;
		endif;
	endif;
	
	_sizeToDownload := serverSize;
	return rtnStatus;
epilog

end;</source>
        <Parameter name="_fileName" type="String"/>
        <Parameter name="_clientPath" type="String"/>
        <Parameter name="_serverPath" type="String"/>
        <Parameter name="_sizeToDownload" type="Integer" usage="output"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getFormCaptionsString" id="0a9be504-606d-4c71-9dad-feb4b91db8dc">
        <source>getFormCaptionsString(errorCode : Integer) : String;

// 17/03/2010	cnwdad1		Par #23212 - Caption translations don't have a "base" number.
vars
	errMsg : XLAT_Translation;
begin

// cnwdad1 17/03/2010 - There is no "base" number for caption
// translations, only for exception translations.
//	if errorCode &lt; self.baseErrorNum then
//		return self.getJadeErrorString(errorCode);
//	endif;

	errMsg := self.zGetTranslatedText(XLAT_FormCaptions, errorCode);
	if errMsg &lt;&gt; null then
		if app.useShortErrorMsg and errMsg.shortText &lt;&gt; null then
			return errMsg.shortText;
		endif;
		return errMsg.text;	
	endif;
//	return "Error " &amp; errorCode.String &amp; ": Unknown message";	// cnwrl1 22/05/2009 PAR 19668 - CCMS 1814
	return "Error " &amp; errorCode.String &amp; UnknownMessage;
end;</source>
        <Parameter name="errorCode" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getFormText" id="ce088365-c201-4824-9373-af75caca96bc">
        <source>getFormText(captionId : Integer; cntrl : Control; propertyName : String):String;

vars
	translation	: XLAT_Translation;
	text	 	: String;
begin

	translation	:= zGetTranslatedText(XLAT_FormCaptions, captionId);
	
	if translation &lt;&gt; null then
		text := translation.text;
	
	else
		// fall-back, show text defined in painter
		if cntrl.class.getProperty(propertyName) &lt;&gt; null then
			text := cntrl.getPropertyValue(propertyName).String;
		endif;
	endif;
	
	return text;
end;</source>
        <Parameter name="captionId" type="Integer"/>
        <Parameter name="cntrl" type="Control"/>
        <Parameter name="propertyName" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getFreeBatNumber" id="30c6f9fc-742f-4f9f-aa84-e562a76408e3">
        <source>getFreeBatNumber(): String;
//----------------------------------------------------------------
//	Created:	14 June 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	bat : CM_BatNumber;
	terminal	: CM_Terminal;	
begin
	terminal := self.getMyTerminalDO_NOT_USE();
	
	if terminal = null then
		return null;
	endif;
	
	foreach bat in terminal.batNumbers do
		if not bat.testInUse(terminal) then
			return bat.code;
		endif;
	endforeach;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getFreeSpaceForDisk" id="94ea1d42-edd8-48b6-87ba-3f0d54aa6bb0">
        <executionLocation>server</executionLocation>
        <source>getFreeSpaceForDisk(_dbDrive : String; _freeSpaceOnDisk, _totalBytesOnDisk, _totalFreeBytesOnDisk : Decimal output; _inKB : Boolean) serverExecution;
/*
	Returns the free space on disk for the passed in disk drive.
	you should fully qualify the disk (i.e. "c:\". You can pass in a directory as well and it will still work.
	FreeSpaceOnDisk is the amont of space this thread can allocate
	TotalBytesOnDisk is the disk's size
	TotalFreeBytesOnDisk is the overall total free space on the disk, 99% of time it will == FreeSpaceOnDisk.
	Returns the values in either Kb, or Mb
	DQ November 2003.
*/
constants
	MegaBytes : Integer = 1024*1024;
	KiloBytes : Integer = 1024;
vars
	freeBytesAvailable, totalNumberOfBytes, totalFreeBytes : Binary;
	freeBytesAvailableLow, freeBytesAvailableHigh,
	totalNumberOfBytesLow, totalNumberOfBytesHigh,
	totalNumberOfFreeBytesLow, totalNumberOfFreeBytesHigh : Integer;
	bytesAvailable : Decimal[20];
	totalBytes : Decimal[20];
	bytesFreeAvailable : Decimal[20];
	bigUns : Decimal[20];
begin
	bigUns := 2.0^32;

	call getDiskFreeSpaceEx(_dbDrive, freeBytesAvailable, totalNumberOfBytes, totalFreeBytes);

	freeBytesAvailableLow := freeBytesAvailable[1:4].Integer;
	freeBytesAvailableHigh := freeBytesAvailable[5:4].Integer;
	
	totalNumberOfBytesLow := totalNumberOfBytes[1:4].Integer;
	totalNumberOfBytesHigh := totalNumberOfBytes[5:4].Integer;
	
	totalNumberOfFreeBytesLow := totalFreeBytes[1:4].Integer;
	totalNumberOfFreeBytesHigh := totalFreeBytes[5:4].Integer;

	if freeBytesAvailableLow &lt; 0 then
		bytesFreeAvailable := freeBytesAvailableLow.abs + freeBytesAvailableHigh * bigUns + (2.0^31);
	else
		bytesFreeAvailable := freeBytesAvailableLow + freeBytesAvailableHigh * bigUns;
	endif;
	if totalNumberOfBytesLow &lt; 0 then
		totalBytes := totalNumberOfBytesLow.abs + totalNumberOfBytesHigh * bigUns + (2.0^31);
	else
		totalBytes := totalNumberOfBytesLow + totalNumberOfBytesHigh * bigUns;
	endif;

	if totalNumberOfFreeBytesLow &lt; 0 then
		bytesAvailable := totalNumberOfFreeBytesLow.abs + totalNumberOfFreeBytesHigh * bigUns + (2.0^31);
	else
		bytesAvailable := totalNumberOfFreeBytesLow + totalNumberOfFreeBytesHigh * bigUns;
	endif;
	
	if _inKB then
		_freeSpaceOnDisk := bytesFreeAvailable / KiloBytes;
		_totalBytesOnDisk := totalBytes / KiloBytes;
		_totalFreeBytesOnDisk := bytesAvailable / KiloBytes;
	else
		_freeSpaceOnDisk := bytesFreeAvailable / MegaBytes;
		_totalBytesOnDisk := totalBytes / MegaBytes;
		_totalFreeBytesOnDisk := bytesAvailable / MegaBytes;
	endif;
end;</source>
        <Parameter name="_dbDrive" type="String"/>
        <Parameter name="_freeSpaceOnDisk" type="Decimal" usage="output"/>
        <Parameter name="_totalBytesOnDisk" type="Decimal" usage="output"/>
        <Parameter name="_totalFreeBytesOnDisk" type="Decimal" usage="output"/>
        <Parameter name="_inKB" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getGlobalConstantText" id="4a2b6ae8-2f3b-4446-a4b2-3aef829f233b">
        <source>getGlobalConstantText(_categoryName : String; _constantName  :String) : String;
// return the text of the global constant in the given category
vars
	category : ConstantCategory;
	const : Constant;

	text	: String;
begin
	category := currentSchema.getCategory(_categoryName);
	if category = null then
		return null;
	endif;

	const := category.getConstants[_constantName];
	if const &lt;&gt; null then
		text := const.text;
	endif;

	return text;
end;
</source>
        <Parameter name="_categoryName" type="String"/>
        <Parameter name="_constantName" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
