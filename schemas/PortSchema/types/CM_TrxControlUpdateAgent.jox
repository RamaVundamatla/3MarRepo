    <JadeMethod name="trxUpdateDocketErrorType" id="7c3110b6-e8b0-425f-8b48-8c8fa26b43b9">
        <updating/>
        <source>trxUpdateDocketErrorType(_proxyLogDocketError : CM_DocketErrorType; _passport : CM_Passport input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 January 2010	cnwas3	Initial creation ccms 1110

*/

vars
	realLogDocketError : CM_DocketErrorType;
	expectedEdition:Integer;

begin

	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(false);

	beginTransaction;

	_proxyLogDocketError.raiseExceptionIfNotProxy(method);

	app.setContinueCMExceptions(true);

	_proxyLogDocketError.pxyGetRealObjectAndEdition(realLogDocketError, expectedEdition);
	
	if realLogDocketError = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_LoggingOrganisation.name, null, null);
		return;
	endif;

	self.raiseExceptionIfNull(_proxyLogDocketError,app.getErrorString(Docket_error_proxy));
	self.raiseExceptionIfNull(realLogDocketError, app.getErrorString(Docket_error_existing));
	_proxyLogDocketError.raiseExceptionIfNotProxy(method);
	if realLogDocketError.code = _proxyLogDocketError.code then
		_proxyLogDocketError.validateForUpdate();
	else
		_proxyLogDocketError.validateForCreate();
	endif;
	
	if (not self.checkValidationWithPassport(_passport)) then
		return;		// note that this gets "ignored" in the eplog
	endif;


	app.setContinueCMExceptions(false);

	exclusiveLock(realLogDocketError);

	if _passport.noErrors and realLogDocketError.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, app.getErrorString(Docket_error), null, null);
		return;
	endif;
	
	if _passport.noErrors then
		app.myUtilityUA.myUpdateAuditAgent.audUpdateGeneric(realLogDocketError, true);
	endif;
	
	if _passport.noErrors then
		realLogDocketError.setForUpdate(_proxyLogDocketError);
	endif;

	if _passport.noErrors then
		app.myUtilityUA.myUpdateAuditAgent.audUpdateGeneric(realLogDocketError, false);
	endif;

epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_proxyLogDocketError" type="CM_DocketErrorType"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxUpdateDoorDirectionRule" id="c0a68b32-3b52-4b6a-b05e-4350dd975b1e">
        <updating/>
        <source>trxUpdateDoorDirectionRule(_pxyDDRule : CM_DoorDirectionRule; _realDDRule : CM_DoorDirectionRule input; _lcSet : CM_LCSet input; _passport : CM_Passport input) updating;

// cnwdvb1 15 January 2003 

vars
	aTA : CM_TerminalArea;
	
begin

	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);


	app.setContinueCMExceptions(true);
	
	app.myValUA.valDoorDirectionRule(_pxyDDRule, _lcSet);
	
	if not _passport.noErrors() then
		return;
	endif;
	
	app.setContinueCMExceptions(true);
	// Start the transaction
	beginTransaction;
	app.myUtilityUA.utlUpdateDoorDirectionRule(_pxyDDRule, _lcSet, _passport);
	
	if _passport.noErrors() then
		aTA := _realDDRule.myTerminalArea;
		aTA.causeEvent( aTA.myTerminal.getTerminalEvent(Event_TALocation_Update), false, _realDDRule );
	endif;
	
epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
