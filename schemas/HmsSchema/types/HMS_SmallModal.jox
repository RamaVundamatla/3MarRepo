<GUIClass name="HMS_SmallModal" id="a7f553e8-95a2-4b65-b744-348e3ad31030">
    <superclass name="CM_BaseForm"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <JadeMethod name="addToolbarControls" id="b8fc6013-3be2-434b-a658-f1cbc7cb49f3">
        <updating/>
        <source>addToolbarControls() updating, protected;
//--------------------------------------------------
// Created:	22 January 2004 By: cnwgd1
//--------------------------------------------------
vars
	toolbar		: CMUI_Toolbar;
begin
	inheritMethod();
	
	toolbar := self.frmToolbar;
	toolbar.addButton(self.btnSaveBase, CMUI_Toolbar.Control_Alignment_Left);	
	toolbar.addButton(self.btnCancelBase, CMUI_Toolbar.Control_Alignment_Right);
	toolbar.visible := true;
	toolbar.positionToolbarControls();

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doBaseFormCancel" id="edb0b0ee-3fbf-416c-8abf-89c8ec110baa">
        <updating/>
        <source>doBaseFormCancel() updating, protected;
//--------------------------------------------------
// Created:	22 January 2004 By: cnwgd1
//--------------------------------------------------
