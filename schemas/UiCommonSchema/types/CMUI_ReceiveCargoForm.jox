        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnAttachments_click(btn: Button input) updating;
/*
Date		Who		Reason
30 July 2009	cnwdap1	Initial creation
22 Oct 2019	jlgsl4	TFS 46767 - PEN - GenSet Trailer Linking
*/
vars
	listObject : Object; // TFS 46767 - 31/10/2019 enable autocreation for 100

begin
	if self.cargoIDs.size &gt; 1 then
		//14 Nov 2013	NDL	Par 32955
		return;
	endif;
	listObject := self.cmbAttachments.listObject; // --&gt; TFS 46767 - can be CM_TIMasterGenerator only if System Admin AutoLinkRefTraGen is true
	if listObject &lt;&gt; null and listObject.isKindOf(CM_TIMasterGenerator) then
		self.showTIMasterGenEditForm(listObject.CM_TIMasterGenerator); // CM_TIMasterGenerator so show edit form
		return;
	endif; // &lt;-- TFS 46767	
	self.doShowAttachmentsForm();
	self.cmbType.enabled := false;	// 20 May 2011	NDL	Par 27504	If we have been to the attachments form we must have a pxy, so may not change the cargo type.
epilog

end;</source>
