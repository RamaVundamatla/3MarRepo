    <JadeMethod name="getUserWindow" id="bdf1a150-21bf-4261-8556-6909e4948285">
        <source>getUserWindow(_windowName : String; _createIfAbsent : Boolean) : CM_UserWindowForOpen;
// ---------------------------------------------------------------------------
// Created:     06 May 2004 by cnwrs2
//
// Purpose:     PAR 25509 - Implement saved window settings for Mobile Devices
//
// ---------------------------------------------------------------------------
// ***************************************************************************
// This is similar to method UiCommonSchema::UiCommonSchema::getUserWindow.  
// Changes to this method may also need to be done in that method
// ***************************************************************************
vars
	user			: CM_User;
	transUserWindow,
	realUserWindow	: CM_UserWindowForOpen;
begin

	transUserWindow := self.allUserWindows[_windowName].CM_UserWindowForOpen;
	if transUserWindow &lt;&gt; null then
		return transUserWindow;
	endif;
	
	user := self.getMyUser();
	if user = null then
		return null;
	endif;
	
	realUserWindow := user.allUserWindowsForOpen[_windowName];
	if realUserWindow = null then
		if _createIfAbsent then
			create transUserWindow as CM_UserWindowForOpen transient;
			transUserWindow.setProxy(user, 
								_windowName,
								null, null, null, null, null, null);
		else
			return null;
		endif;
	else
		transUserWindow := realUserWindow.cloneSelf(true);
	endif;
	
	self.allUserWindows.add(transUserWindow);
	
	return transUserWindow;
	
end;</source>
        <Parameter name="_windowName" type="String"/>
        <Parameter name="_createIfAbsent" type="Boolean"/>
        <ReturnType type="CM_UserWindowForOpen"/>
    </JadeMethod>
    <JadeMethod name="handleManagementException" id="97a700c9-2a05-4f83-bef6-2479644d185f">
        <source>handleManagementException(_exc : Exception) : Integer;

/*

Purpose:			Handle a specific JADE exception that can occur when a management message is
					ignored because a thin client device is currently in reconnect state

Parameters:			Exception object

Return Value:		Standard exception return code


Date		Who		Reason
01 Apr 2011	cnwkpd1	PAR #27039 - 14177 exceptions regularly causing dumps at Messina

*/

vars
	returnVal		: Integer;
	logMessage		: String;
	
begin
	returnVal := Ex_Pass_Back;
	if _exc.errorCode = 14177 then
		logMessage := method.qualifiedName() &amp; " errorCode=" &amp; _exc.errorCode.String;
		if _exc.resumable then
			logMessage := logMessage &amp; ", returning Ex_Resume_Next";
			returnVal := Ex_Resume_Next;
		else
			abortTransaction;
			abortTransientTransaction;
			logMessage := logMessage &amp; ", transaction aborted, returning Ex_Abort_Action";
			returnVal := Ex_Abort_Action;
		endif;

		app.writeLog(logMessage, LogERROR);	//26 Nov 2019	NDL	TFS 47053
	endif;
	
	
epilog
	return returnVal;
	
end;</source>
        <Parameter name="_exc" type="Exception"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
