epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupThumbnailDetails" id="2c83cbb3-a6a2-42d0-8df3-06dbcc9b702d">
        <updating/>
        <source>setupThumbnailDetails() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 Apr 2023 navhl20	ChangeRequest 57712:[54552] EUP - Delivery Dispatch – Adding Work Point Types

*/

vars
	theForm	: SOP_TableMaintForm;
begin
	theForm := self.myForm;
	theForm.useProxyObject := true;
	theForm.setTblDataEntRows(ETDef_WorkPointTypeMaint);
	
	theForm.shtTblInput1.caption := app.getErrorString(Details);
	theForm.initTblInput(theForm.tblInput1, ETDef_WorkPointTypeMaint);
	theForm.shtTblInput1.visible := true;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="showThumbnail" id="15ebcbd8-567c-4091-ab07-5549445cb03c">
        <updating/>
        <source>showThumbnail(_workPointType : CM_WorkPointType) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 Apr 2023 navhl20	ChangeRequest 57712:[54552] EUP - Delivery Dispatch – Adding Work Point Types
25 May 2023 navhl20	Bug 58151:[58152] EUP - System Work Point Type Ship can be edited
*/

vars
	theForm : SOP_TableMaintForm;
begin
	theForm := self.myForm;
	theForm.tblInput1.clearValues();
	
	theForm.loadCmbWPType(app.getWorkPointTypeString(_workPointType.type));
	theForm.tblInput1.setValueByName(ETRow_Code, 			_workPointType.code);
	theForm.tblInput1.setValueByName(ETRow_Description, 	_workPointType.description);
	theForm.tblInput1.setValueByName(ETRow_Type, 			app.getWorkPointTypeString(_workPointType.type));
	theForm.tblInput1.setValueByName(ETRow_NotAvailForEntry, _workPointType.notAvailableForEntry);
	theForm.tblInput1.setValueByName(ETRow_IsSystemType,	 _workPointType.isSystemType);
	
	theForm.mulSelect1.setSelected(_workPointType.allWorkPoints);
	theForm.mulSelect1.cnEcResizeContents();
	
	if _workPointType.code = "SHIP" and _workPointType.type = WORK_POINT_TYPE_SHIP then										//25.5.2023 navhl20 #58151[58152]
		theForm.btnEditTV.enabled := false;
		theForm.btnDeleteTV.enabled := false;
	else
		theForm.btnEditTV.enabled := true;
		theForm.btnDeleteTV.enabled := true;
	endif;
epilog

end;</source>
        <Parameter name="_workPointType" type="CM_WorkPointType"/>
    </JadeMethod>
</Class>
