    <JadeMethod name="validateCreditNoteFromInvoice" id="c9168010-51a3-4d8c-9464-13fd996b62dc">
        <source>validateCreditNoteFromInvoice();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 January 2023	navkc1	Initial creation TFS CR 55305 Task 55533: Jade - Invoice Credit Note Jade Code

*/

vars

begin
	
	if not self.isPostedOrReversal() then
		app.raiseCMWarning1(Invoice_status_not_posted, self.sequenceNum.String, null, null, null);
