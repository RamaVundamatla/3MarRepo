    <JadeMethod name="reset" id="f4048f0a-4c59-428d-ac85-13d225c2c2d5">
        <updating/>
        <source>reset() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
22 June 2023	navmd1	Initial creation TFS 56062 Clear all values

*/

vars
	
begin
	self.cashOnly := false;
	self.defaultInvoiceJRW := null;
	self.interTerminalCode := null;
	self.myCurrencyType := null;
	self.myLocale := null;
	self.organizationCode := null;
	self.paymentType := PaymentType_None;
epilog

end;</source>
    </JadeMethod>
