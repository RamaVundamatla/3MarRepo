<Class name="DTO_ContainerSearchInfo" id="e07d6ef2-5899-419c-a3d2-d94165f39822">
    <superclass name="DTO_Object"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="mobileServer"/>
    <PrimAttribute name="containerId" id="618ac5ff-7554-448d-85b9-2aaf301151dc">
        <length>31</length>
        <embedded/>
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="currentLocationID" id="fde3fa11-e558-475a-9be5-04f91a18cc12">
        <length>31</length>
        <embedded/>
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="queuedLocationID" id="30900dad-d38c-4a3c-9ed4-b19262fea16e">
        <length>31</length>
        <embedded/>
        <type name="String"/>
    </PrimAttribute>
    <JadeMethod name="setFromPersistent" id="d3df2bad-f73d-473e-acb5-52f3d74b5b1b">
        <updating/>
        <source>setFromPersistent(_obj: CM_Container) updating;

/*

Purpose:			


Return Value:		


Date		Who		Reason
29 Feb 2008	cnwkpd1	PAR #16010 - CCMS Otago 1502 - Thin Client RT Enhancements

*/

vars
	primLoc			: CM_LocationsController;
	
begin
	inheritMethod(_obj);
	
	self.containerId		:= _obj.id;
	primLoc := _obj.myPrimaryActualLocation;
	if primLoc = null then
		self.currentLocationID	:= null;
	else
		self.currentLocationID	:= primLoc.getFullIdForTI(false);
	endif;
	self.queuedLocationID	:= _obj.queuedLocnId;
	

epilog

end;</source>
        <Parameter name="_obj" type="CM_Container"/>
    </JadeMethod>
</Class>
