    <JadeMethod name="getTypeName" id="d3994568-9e50-4a42-bbac-4126c0a22cb3">
        <source>getTypeName(): String;
// --------------------------------------------------------------------------------
// Created:		16 March 2005 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 20/10/2014	cnwdap1		PAR #34998 Include measurement type code in YA description
// --------------------------------------------------------------------------------
vars
	measure : CM_MeasurementType;														// PAR #34998
	code 	: String;																	// PAR #34998

begin
	measure := app.getDefaultMeasurementForType(Type_Linear);							// PAR #34998
	if measure &lt;&gt; null then																// PAR #34998
		code := Space &amp; Left_Round_Bracket &amp; measure.shortName &amp; Right_Round_Bracket;	// PAR #34998
	endif;																				// PAR #34998
	
	//return "Container Length";														// PAR #34998
	return "Container Length" &amp; code;													// PAR #34998
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="isCMIFDataMatch" id="a66e0f39-2e5d-4a49-8dde-015f7101d670">
        <source>isCMIFDataMatch(_cmifAutoPlan : CMIF_YAAutoPlan; _yaData : CM_YAData) : Boolean;
// -------------------------------------------
// Created 10 May 2005 by cnwdvb1
// -------------------------------------------
vars
	yaDataObjects: CM_YADataObjects;
begin

	if _yaData.isKindOf(CM_YADataPattern) then
		create yaDataObjects transient;
		self.resolvePatternEx(_yaData.CM_YADataPattern.pattern, yaDataObjects.allObjects);	
		return _cmifAutoPlan.isContainerLength_Match(yaDataObjects);
	endif;
	
	return false;
epilog
	if yaDataObjects &lt;&gt; null then
		yaDataObjects.allObjects.purge;
	endif;
	delete yaDataObjects;
end;</source>
        <Parameter name="_cmifAutoPlan" type="CMIF_YAAutoPlan"/>
        <Parameter name="_yaData" type="CM_YAData"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isSnapShotDataMatch" id="68ab08a9-ccd4-4b5c-9cbb-fc67bbff7d88">
        <source>isSnapShotDataMatch(_criteria: CM_YACriteria; _yaType: Integer; _propertyValue: String): Boolean;

vars

begin
	if _yaType &lt;&gt; self.type then
		return false;
	endif;
	
	if _criteria.myYAData.CM_YADataPattern.pattern = _propertyValue or
	   _criteria.myYAData.CM_YADataPattern.pattern = null then
		return true;
	endif;
	
	return false;
end;
</source>
        <Parameter name="_criteria" type="CM_YACriteria"/>
        <Parameter name="_yaType" type="Integer"/>
        <Parameter name="_propertyValue" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isStorageDetailMatch" id="8f02e011-1472-4c88-b05e-1d5f87bcde5e">
        <source>isStorageDetailMatch(_criteria : CM_YACriteria; _ti: CM_TrackedItem; _tiTrx : CM_TITransaction): Boolean;
// CCMS 1295 free storage days
vars
	matchValue	: Integer;
	yaDataObjects: CM_YADataObjects;
	obj			: Object;
	cmifContLength	: CMIF_ContainerLength;

begin
//	matchValue := _ti.getActualLength().Integer;		// 20, 30, 40 etc
	
	if _tiTrx &lt;&gt; null and _tiTrx.myTrackedItem &lt;&gt; null then	//13 Nov 2019	NDL	TFS 47344
		matchValue := _tiTrx.myTrackedItem.getActualLength().Integer;	// length not kept on the generic transaction
	else
		matchValue := _ti.getActualLength().Integer;		// 20, 30, 40 etc
	endif;
	
	// specific or default value
	if _criteria.myYAData.isKindOf(CM_YADataPattern) then
		// check default first
		if _criteria.myYAData.CM_YADataPattern.pattern = null then
			return true;
		endif;
		create yaDataObjects transient;
		self.resolvePatternEx(_criteria.myYAData.CM_YADataPattern.pattern, yaDataObjects.allObjects);
		foreach obj in yaDataObjects.allObjects do
			cmifContLength := obj.CMIF_ContainerLength;
			if cmifContLength.length = matchValue then
				return true;
			endif;
		endforeach;
	endif;

	return false;
epilog
	if yaDataObjects &lt;&gt; null then
		yaDataObjects.allObjects.purge;
	endif;
	delete yaDataObjects;
end;
</source>
        <Parameter name="_criteria" type="CM_YACriteria"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_tiTrx" type="CM_TITransaction"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="resolvePattern" id="38464a4b-b247-4a80-81e8-75606206ed86">
        <source>resolvePattern(_pattern: String; _objectSet: ObjectSet input; _rasieException: Boolean);
//01 August 2008	cnwdw1	
// Container length criteria can only be a list of commma separated conatiner lengths 
vars
begin
	self.resolvePatternEx(_pattern, _objectSet);
	
	return;
	// The resolve pattern builds up a set of transient objects, but when resolving as part of saving the
	// criteria we don't want these transients
epilog	
	_objectSet.purge();
end;</source>
        <Parameter name="_pattern" type="String"/>
        <Parameter name="_objectSet" type="ObjectSet" usage="input"/>
        <Parameter name="_rasieException" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="resolvePatternEx" id="538241fc-1de3-43c8-97a3-ca03da53fa2c">
        <source>resolvePatternEx(_pattern: String; _objectSet: ObjectSet input);
//01 August 2008	cnwdw1	
// Container length criteria can only be a list of commma separated conatiner lengths 
vars
	token: String;
	tokens: StringArray;
	pattern: CMIF_YAPattern;
	containerLength: CMIF_ContainerLength;
begin
	create pattern transient;
	pattern.setPattern(_pattern, CMIF_YAPattern.YAPattern_Wildcard);
	
	create tokens transient;
	pattern.getTokens(pattern.pattern, tokens);
	foreach token in tokens do
		token.replace('!', '');
		if not token.cnEcIsNumeric then
			//app.raiseCMException2(ErrYACriteriaNotFound, _pattern, self.getTypeName, null, null);
			app.raiseCMException2(ErrYACriteriaNotFound, _pattern, self.description, null, null);	//09 Oct 2013	NDL	Par 32456
		else
			if token &lt;&gt; "20" and token &lt;&gt; "30" and token &lt;&gt; "40" and token &lt;&gt; "45" and token &lt;&gt; "53" then
				app.raiseCMException2(ErrYACriteriaNotFound, _pattern, self.getTypeName, null, null);
			else
				create containerLength transient;
				containerLength.setLength(token.Integer);
				_objectSet.add(containerLength);
			endif;
		endif;
	endforeach;
epilog
	delete tokens;
	delete pattern;
end;</source>
        <Parameter name="_pattern" type="String"/>
        <Parameter name="_objectSet" type="ObjectSet" usage="input"/>
    </JadeMethod>
</Class>
