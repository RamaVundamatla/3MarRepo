    <JadeMethod name="tDriverDetails" id="c25b9f9a-ce29-4e75-ac25-b46a2c0e7227">
        <source>tDriverDetails();
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
21 June 2024		jlizm1	Initial creation TFS 63908 Allow duplicate driver names

*/
constants
	DriverCode1 : String = "UTZ1";
	DriverCode2	: String = "UTZ2";
	DriverName	: String = "UT Driver Z";
	
vars
	origAllDupsSetting 	: Boolean;
	driver1 			: CM_DriverDetails;
	driver2 			: CM_DriverDetails;
	pxyDriver 			: CM_DriverDetails;
	carriers			: CM_CarrierByCodeDict;
	vehicles			: CM_VehicleSet;
	foundError			: CM_Error;
	
begin
	origAllDupsSetting := self.getMyTerminal.getConfig(AllowDupDriverNames).Boolean;
	
	self.deleteDriverDetails(DriverCode1);
	self.deleteDriverDetails(DriverCode2);
	
	self.setTerminalConfig(AllowDupDriverNames, false);
	
	create carriers transient;
	create vehicles transient;
	
	create pxyDriver transient;
	pxyDriver.setProxy(DriverName, DriverCode1, null, CM_DriverDetails.Status_Allowed, null, self.getTerminal(), carriers, vehicles);
	
	app.myTrxCA.trxCreateDriverDetails(pxyDriver, driver1, app.myPassport);
	self.assertNoTrxErrors();
	self.assertTrueMsg(driver1 &lt;&gt; null, "Failed to create Driver 1");
	
	delete pxyDriver;
	create pxyDriver transient;
	pxyDriver.setProxy(DriverName, DriverCode2, null, CM_DriverDetails.Status_Allowed, null, self.getTerminal(), carriers, vehicles);
	app.myTrxCA.trxCreateDriverDetails(pxyDriver, driver2, app.myPassport);
	foundError := app.myPassport.allErrors.first();
	self.assertTrueMsg(foundError &lt;&gt; null, "Should have errored creating driver 2");
	self.assertEqualMsg(foundError.errorCode, VB_DUPLICATED_ITEM, "Driver2 Error should be because of duplicate name");
	self.assertTrueMsg(driver2 = null, "Should have failed to create Driver 2, but didn't");
	
	self.setTerminalConfig(AllowDupDriverNames, true);
	
	delete pxyDriver;
	create pxyDriver transient;
	pxyDriver.setProxy(DriverName, DriverCode2, null, CM_DriverDetails.Status_Allowed, null, self.getTerminal(), carriers, vehicles);
	
	app.myTrxCA.trxCreateDriverDetails(pxyDriver, driver1, app.myPassport);
	self.assertNoTrxErrors();
	self.assertTrueMsg(driver1 &lt;&gt; null, "Failed to create Driver 2");
	
	self.deleteDriverDetails(DriverCode1);
	self.deleteDriverDetails(DriverCode2);
	
	
epilog
	self.setTerminalConfig(AllowDupDriverNames, origAllDupsSetting);
	
	delete carriers;
	delete vehicles;
	delete pxyDriver;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tHazardSegregationMaint" id="78496a1f-88f7-4f51-80f0-a2a8de76b023">
        <source>tHazardSegregationMaint();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 August 2021	navndl1	Initial creation	Migrated portion of a test that otherwise
			achieved nothing and took 40 minutes to do it.

*/

vars

	terminal : CM_Terminal;
	pxySegCondition : CM_SegregationCondition;
	segCondition : CM_SegregationCondition;
	segMatrixAgent : CMIF_SegregationMatrixAgent;
	file : File;
	block : String;

begin

	terminal := self.getTerminal;
	self.assertTrueMsg(terminal &lt;&gt; null, "failed to find terminal - in setup");
	
	beginTransaction;
	terminal.allSegRulesByEntity1Entity2.purge();
	terminal.allSegregationConditions.purge();
	commitTransaction;
	
	// create segregation conditions
	create pxySegCondition as app.getSegCondClassForType(Segregation_Type_Yard) transient;
	pxySegCondition.setProxy("*", "Dangerous Goods List", 1235687, true, true, 1, 1, 0);
	app.myTrxCA.trxCreateSegregationCond(pxySegCondition, segCondition, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertNotNull(segCondition);
	delete pxySegCondition;
	
	create pxySegCondition as app.getSegCondClassForType(Segregation_Type_Yard) transient;
	pxySegCondition.setProxy("1", "Away From", 1005687, true, true, 2, 2, 0);
	app.myTrxCA.trxCreateSegregationCond(pxySegCondition, segCondition, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertNotNull(segCondition);
	delete pxySegCondition;
	
	create pxySegCondition as app.getSegCondClassForType(Segregation_Type_Yard) transient;
	pxySegCondition.setProxy("2", "Separated from", 1555687, true, true, 6, 6, 0);
	app.myTrxCA.trxCreateSegregationCond(pxySegCondition, segCondition, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertNotNull(segCondition);
	delete pxySegCondition;
	
	create pxySegCondition as app.getSegCondClassForType(Segregation_Type_Yard) transient;
	pxySegCondition.setProxy("3", "Far From", 1235600, true, true, 8, 8, 0);
	app.myTrxCA.trxCreateSegregationCond(pxySegCondition, segCondition, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertNotNull(segCondition);
	delete pxySegCondition;
	
	create pxySegCondition as app.getSegCondClassForType(Segregation_Type_Yard) transient;
	pxySegCondition.setProxy("4", "Separated longiudinally by compartment", 1200687, false, false, 0, 0, 0);
	app.myTrxCA.trxCreateSegregationCond(pxySegCondition, segCondition, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertNotNull(segCondition);
	delete pxySegCondition;
	
	create segMatrixAgent transient;
	segMatrixAgent.ruleType := Segregation_Type_Yard;
	segMatrixAgent.allSegMatrixTransByColRow.purge;
	segMatrixAgent.allSegMatrixTransByRowCol.purge();
	
	file := self.xSegMatrixImportFile();
	file.kind := File.Kind_Unknown_Text;
	file.mode := File.Mode_Input;	
	
	block := file.readString(file.fileLength);
	segMatrixAgent.importMeXML(block);
	
	app.myTrxUA.trxImportFullSegMatrix(segMatrixAgent, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertTrue(terminal.allSegregationRules.size &gt; 0);
	self.assertEqual(terminal.allSegregationRules.first.mySegregationCondition.type, Segregation_Type_Yard);

	//successful so clean up
	beginTransaction;
	terminal.allSegRulesByEntity1Entity2.purge();
	terminal.allSegregationConditions.purge();
	commitTransaction;
	
epilog

	delete segMatrixAgent;
	delete file;
	delete pxySegCondition;

end;</source>
    </JadeMethod>
    <JadeMethod name="tMTStorageSubTerminal" id="d57c6dda-8e02-454c-a256-29d6a6f78988">
        <updating/>
        <source>tMTStorageSubTerminal() updating;
/*

Purpose:			TFS 2149

Date		Who		Reason
22 June 2016	cnwmk3	Initial creation

*/
constants
	SubTerm1					= "UT_Depot01";
	SubTerm2					= "UT_Terminal";
	BookingRefr					= "BOOKING2149";
	Voyage1						= "VOY2149";
	VesselCode					= "DIAM";
	Prenote1					= "PRENOTE2149";
	TruckId						= "TRK2149";
	
vars
	depot						: CM_SubTerminal;
	subTerminal					: CM_SubTerminal;
	terminal					: CM_Terminal;
	booking						: CM_BookingRef;
	operator					: CM_Operator;
	voyage						: CM_Voyage;
	ti							: CM_TrackedItem;
	vvr							: CM_VehicleVisitRecord;
	errorTxt					: String;
	isSubTerminalsOn			: Any;
	
begin
	isSubTerminalsOn := self.setTerminalConfig(IsSubTerminalsOn, true);
	
	// Delete SubTerminals
	 self.deleteSubTerminal(SubTerm1);
	 self.deleteSubTerminal(SubTerm2);
	//Create SubTerminals
	depot := self.addSubTerminal(SubTerm1,1);
	self.assertNotNull(depot);
	subTerminal := self.addSubTerminal(SubTerm2,2);
	self.assertNotNull(subTerminal);
	
	// Setup Sub-Terminal defaults
	terminal := self.getTerminal();
	beginTransaction;
	if terminal.getConfig(MySubTerminalForExportFull).CM_SubTerminal &lt;&gt; subTerminal then
		terminal.setConfig(MySubTerminalForExportFull, subTerminal);
	endif;
	if terminal.getConfig(MySubTerminalForExportMTY).CM_SubTerminal &lt;&gt; subTerminal then
		terminal.setConfig(MySubTerminalForExportMTY, subTerminal);
	endif;
	if terminal.getConfig(MySubTerminalForImportFull).CM_SubTerminal &lt;&gt; subTerminal then
		terminal.setConfig(MySubTerminalForImportFull, subTerminal);
	endif;
	if terminal.getConfig(MySubTerminalForImportMTY).CM_SubTerminal &lt;&gt; subTerminal then
		terminal.setConfig(MySubTerminalForImportMTY, subTerminal);
	endif;
	if terminal.getConfig(MySubTerminalForStorageFull).CM_SubTerminal &lt;&gt; subTerminal then
		terminal.setConfig(MySubTerminalForStorageFull, subTerminal);
	endif;
	if terminal.getConfig(MySubTerminalForStorageMTY).CM_SubTerminal &lt;&gt; depot then
		terminal.setConfig(MySubTerminalForStorageMTY, depot);
	endif;
	if terminal.getConfig(MySubTerminalForImportGen).CM_SubTerminal &lt;&gt; subTerminal then
		terminal.setConfig(MySubTerminalForImportGen, subTerminal);
	endif;
	if terminal.getConfig(MySubTerminalForExportGen).CM_SubTerminal &lt;&gt; subTerminal then
		terminal.setConfig(MySubTerminalForExportGen, subTerminal);
	endif;
	if terminal.getConfig(MySubTerminalForStorageGen).CM_SubTerminal &lt;&gt; subTerminal then
		terminal.setConfig(MySubTerminalForStorageGen, subTerminal);
	endif;
	if terminal.getConfig(MySubTerminalForOther).CM_SubTerminal &lt;&gt; depot then
		terminal.setConfig(MySubTerminalForOther, depot);
	endif;
	commitTransaction;
		
	//	Create a booking for some containers (Export, non-empty).
	self.deleteVoyage(Voyage1);
	self.deleteBooking(BookingRefr);
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	voyage := self.addVoyageWithContainerStructur(Voyage1, VesselCode, operator.code, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	booking := self.addBookingForContainer(BookingRefr, operator, voyage, "NZAKL", "2200", "APPL");
	self.assertNotNull(booking);
	
	//	Create a Pre-Note for that booking, make sure the booking prefills all details except the Cargo ID.
	ti := self.addPrenotedContainer(booking.allBookingRefItems.first, Prenote1);
	self.assertNotNull(ti);
	//	Check the Sub-Terminal on the Pre-Note after creation, should not be the MT Storage one.
	self.assertEqual(ti.mySubTerminal.code, subTerminal.code);
	
	//	 Gate in the container, check the Sub-Terminal. Should correctly match the Export non-empty default.
	self.deleteVehicle(TruckId);
	vvr := self.gateInPrenote(TruckId, "", "", ti, self.getGate(self.getProfileSetting(UT_Profile.P_DGATE).asString));
	self.assertNotNull(vvr);
	ti := self.getTrackedItem(Prenote1);
	self.assertEqual(ti.mySubTerminal.code, subTerminal.code);
	
	self.workVehicle(vvr);
	self.roadExit(vvr);
	
	depot := app.myRoot.allSubTerminals["UT_Depot"];
	self.assertNotNull(depot);
epilog
	self.setTerminalConfig(IsSubTerminalsOn, isSubTerminalsOn);
	beginTransaction;
	terminal.setConfig(MySubTerminalForExportFull, depot);
	terminal.setConfig(MySubTerminalForExportMTY, depot);
	terminal.setConfig(MySubTerminalForImportFull, depot);
	terminal.setConfig(MySubTerminalForImportMTY, depot);
	terminal.setConfig(MySubTerminalForStorageFull, depot);
	terminal.setConfig(MySubTerminalForStorageMTY, depot);
	terminal.setConfig(MySubTerminalForImportGen, depot);
	terminal.setConfig(MySubTerminalForExportGen, depot);
	terminal.setConfig(MySubTerminalForStorageGen, depot);
	terminal.setConfig(MySubTerminalForOther, depot);
	commitTransaction;
end;</source>
    </JadeMethod>
    <JadeMethod name="tNSWOnePortStatusMaint" id="2fac6b77-9bf0-4bd9-80f9-51b3d830a19e">
        <updating/>
        <source>tNSWOnePortStatusMaint() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02/12/2025	navkc1 JIRA 36177 NSW | OnePort API - Change voyage creation criteria Unit Tests

*/

vars
	newStatuses,
	existingStatuses	: CM_NameValuePairDict;
	term				: CM_Terminal;
	status				: CM_NameValuePair;
	idx					: Integer;
begin
	
	// Get Terminal
		term := self.getMyTerminal(); 
		
	// Get existing One Port Statuses
		create existingStatuses transient;
		term.allOnePortStatuses.copy(existingStatuses);
		
	// Detach from terminal so we don't mess up with existing data. Gonna link them back together in epilog
		beginTransaction;
			foreach status in existingStatuses do
				term.allOnePortStatuses.tryRemove(status);
			endforeach;
		commitTransaction;
	create newStatuses transient;
	
	// Create invalid statuses
		create status transient;
		status.createNewPair("Expected", "-1|1"); // -1 is invalid in MTN, 1 is being used, expecting to get an error
		newStatuses.add(status);
		
		create status transient;
		status.createNewPair("Denied", "-1|0");	// -1 is invalid in MTN, 0 is not being used, shouldn't get error for this
		newStatuses.add(status);
		
		create status transient;
		status.createNewPair("Denied", "-1|0");	// Duplicate status, should get an error
		newStatuses.add(status);
		
	// Call TRX, validate errors
		self.expectedTrxErrors.clear();
		self.expectedTrxErrors.add(OnePortDuplicateStatus);
		self.expectedTrxErrors.add(OnePortInvalidMTNStatus);
		app.myTrxUA.trxUpdateOnePortStatuses(term, newStatuses, app.myPassport);
		
		self.assertTrxErrorMsg(OnePortDuplicateStatus, "Should get an exception for duplicate status 'Denied'");
		self.assertTrxErrorMsg(OnePortInvalidMTNStatus, "Should get an exception for incorrect MTN status for 'Expected'");
		self.expectedTrxErrors.clear();
		
	// Clear and get ready for next test
		newStatuses.purge();
	
	// Create valid statuses
		create status transient;
		status.createNewPair("Booked", MovementStatus_Planned.String &amp; "|1");
		newStatuses.add(status);
		
		create status transient;
		status.createNewPair("Cancelled", MovementStatus_Cancelled.String &amp; "|1");
		newStatuses.add(status);
		
		create status transient;
		status.createNewPair("Completed", MovementStatus_Actual.String &amp; "|1");
		newStatuses.add(status);
		
		create status transient;
		status.createNewPair("Confirmed", MovementStatus_Actual.String &amp; "|0");
		newStatuses.add(status);
		
		create status transient;
		status.createNewPair("Expected", "-1|0"); 
		newStatuses.add(status);
		app.myTrxUA.trxUpdateOnePortStatuses(term, newStatuses, app.myPassport);
		self.assertNoTrxErrorsOrWarnings();
		
	// Check statuses
		self.assertTrueMsg(term.allOnePortStatuses.size() = 5, "Should have 5 statuses created");
		// Booked, valid, in used
		status := term.allOnePortStatuses["Booked"];
		self.assertNotNullMsg(status, "Failed to get Booked status");
		idx := 1;
		self.assertTrueMsg(app.isValidHMSMovementStatus(status.value.scanUntil("|", idx).Integer) = true, "Booked should have a valid status");
		self.assertTrueMsg(status.value.endsWith("|1") = true, "Booked should be in used");
		
		// Cancelled, valid, in used
		status := term.allOnePortStatuses["Cancelled"];
		self.assertNotNullMsg(status, "Failed to get Cancelled status");
		idx := 1;
		self.assertTrueMsg(app.isValidHMSMovementStatus(status.value.scanUntil("|", idx).Integer) = true, "Cancelled should have a valid status");
		self.assertTrueMsg(status.value.endsWith("|1") = true, "Cancelled should be in used");
		
		// Completed, valid, in used
		status := term.allOnePortStatuses["Completed"];
		self.assertNotNullMsg(status, "Failed to get Completed status");
		idx := 1;
		self.assertTrueMsg(app.isValidHMSMovementStatus(status.value.scanUntil("|", idx).Integer) = true, "Completed should have a valid status");
		self.assertTrueMsg(status.value.endsWith("|1") = true, "Completed should be in used");
		
		// Confirmed, valid, not in used
		status := term.allOnePortStatuses["Confirmed"];
		self.assertNotNullMsg(status, "Failed to get Confirmed status");
		idx := 1;
		self.assertTrueMsg(app.isValidHMSMovementStatus(status.value.scanUntil("|", idx).Integer) = true, "Confirmed should have a valid status");
		self.assertTrueMsg(status.value.endsWith("|0") = true, "Confirmed should not be in used");
		
		// Expected, in valid, not in used
		status := term.allOnePortStatuses["Expected"];
		self.assertNotNullMsg(status, "Failed to get Expected status");
		idx := 1;
		self.assertTrueMsg(app.isValidHMSMovementStatus(status.value.scanUntil("|", idx).Integer) = false, "Expected should have an invalid status");
		self.assertTrueMsg(status.value.endsWith("|0") = true, "Expected should not be in used");
		
epilog
	
	beginTransaction;
		term.allOnePortStatuses.purge(); // Delete those created in this unit test
		
		// Link the original statues back to terminal
		foreach status in existingStatuses do
			term.addOnePortStatus(status);
		endforeach;
	commitTransaction;
	
	newStatuses.purge();
	delete newStatuses;
	delete existingStatuses;
end;</source>
    </JadeMethod>
    <JadeMethod name="tPAR20377_EmailDefaults" id="a8ea9f96-d8b2-4d0c-9de1-7abaccf15e5e">
        <source>tPAR20377_EmailDefaults();
// cnwrs1 - for emails

/*
Purpose:		This method will check that when a terminal is created that the email defaults are set up correctly.
Date				Who		Reason
03 August 2009		cnwrl1	Initial creation as part of PAR 20377
18/04/2011			cnwmh5	Add delete of iter
*/
	
//constants
//	TerminalCode		= 'UT';
//	TerminalName		= 'Unit Test';
	
vars
	emailType			: Integer;
	pinDefaultEmail		: CM_PINObjectDefaultEmail;
	cm_Terminal			: CM_Terminal;
	emailStringArray	: StringArray;
	typeStringArray		: StringArray;
//	cargoBOLTypeArray	: CM_CargoBOLTypeArray;
	iter1				: Iterator;
	tempStr				: String;
	
begin
	// This test assumes the terminal UT exists
//	cm_Terminal	:= app.myRoot.allTerminals[ TerminalCode ];
	cm_Terminal	:= self.getTerminal;
	self.assertNotNullMsg( cm_Terminal, 'Terminal' );
	
	/*
	// Now create the required terminal
	create cargoBOLTypeArray transient;
	app.myRoot.allCargoTypesById.copy( cargoBOLTypeArray );
	app.myRoot.allBOLTypes.copy( cargoBOLTypeArray );
	cm_Terminal	:= app.myRoot.createTerminal(	TerminalCode,
												TerminalName,
												cargoBOLTypeArray,
												TI_CargoType_Container,
												TI_CargoType_Null,
												TI_CargoType_Container,
												app.actualTimeServer.date );
	self.assertNotNullMsg( cm_Terminal, 'Terminal' );
	*/
	
	// Set up the test arrays of correct values.
	create emailStringArray transient;
	create typeStringArray transient;
	
	emailStringArray.add( ReleaseRequest_AddPin );						// ie 'Release Request Add Pin'
	typeStringArray.add( PINEmail_Object_BR );
	
	emailStringArray.add( ReleaseRequest_DeletePin );					// ie 'Release Request Delete Pin'
	typeStringArray.add( PINEmail_Object_BR );
	
	emailStringArray.add( ReleaseRequest_Import );						// ie 'Import Release'
	typeStringArray.add( PINEmail_Object_TI );
	
	emailStringArray.add( ReleaseRequest_ImportDeleted );				// ie 'Import Release Deleted'
	typeStringArray.add( PINEmail_Object_TI );
	
	emailStringArray.add( ReleaseRequest_Prenote );						// ie 'Prenote'
	typeStringArray.add( PINEmail_Object_TI );
	
	emailStringArray.add( ReleaseRequest_PrenoteDeleted );				// ie 'Prenote Deleted'
	typeStringArray.add( PINEmail_Object_TI );
	
	emailStringArray.add( ReleaseRequest_CustomsPrenote );				// ie 'Customs Inspection Prenote'
	typeStringArray.add( PINEmail_Object_TI );
	
	emailStringArray.add( ReleaseRequest_StatusPending );				// ie 'Release Request Status Change From Active To Pending'
	typeStringArray.add( PINEmail_Object_BR );
	
	emailStringArray.add( ReleaseRequest_StatusActive );				// ie 'Release Request Status Change To Active'
	typeStringArray.add( PINEmail_Object_BR );
	
	// now do the required validation.
	
	// Check that the terminal has the correct number of email default settings.
	tempStr	:= 'The Terminal Email Default setting for Type = ';
	foreach emailType in PINEmail_ReleaseRequest to PINEmail_ReleaseStatusActive do
		pinDefaultEmail	:= cm_Terminal.getEmailDefaultsSettings( emailType );
		self.assertNotNullMsg( pinDefaultEmail, tempStr &amp; emailType.display );
	endforeach;
	
	// Check each of the email default names are correct.
	emailType	:= null;
	tempStr		:= 'The Terminal Email Default name is not correct for Type = ';
	iter1		:= cm_Terminal.allPINObjectEmailDefaults.createIterator;
	while iter1.next( pinDefaultEmail ) do : pinDefaultEmail_loop
		emailType	:= emailType + 1;
		self.assertEqualMsg(	pinDefaultEmail.name.display,
								emailStringArray[ emailType ].display,
								tempStr &amp; emailType.display );
	endwhile pinDefaultEmail_loop;
	delete iter1;						// 08/04/2011 cnwmh5 
	
	// Check each of the email default objectType are correct.
	emailType	:= null;
	tempStr		:= 'The Terminal Email Default objectType is not correct for Type = ';
	iter1		:= cm_Terminal.allPINObjectEmailDefaults.createIterator;
	while iter1.next( pinDefaultEmail ) do : pinDefaultEmail_loop
		emailType	:= emailType + 1;
		self.assertEqualMsg(	pinDefaultEmail.objectType.display,
								typeStringArray[ emailType ].display,
								tempStr &amp; emailType.display );
	endwhile pinDefaultEmail_loop;
	
epilog
	delete iter1;
	delete emailStringArray;
	delete typeStringArray;
//	delete cargoBOLTypeArray;
	
end;
</source>
    </JadeMethod>
    <JadeMethod name="tPolLabourOnBlockLights" id="8e91e2a5-edda-4c84-bd89-5caeed88c4ed">
        <source>tPolLabourOnBlockLights();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
23 September 2019	jlgndl1	Initial creation	TFS 46576 - Replicates the call normally made in Port Otagos
												Hook Code  / Hook Type - Labour Restriction Changed

*/
constants

	Directory = '\\cnwchcm24\cnwpod$\Testing\'; 
	RequestFile = 'jade.csv';
	ResponseFileName = 'jaderesp.csv';
	TimeoutSecs = 2;
	
vars

	terminal : CM_Terminal;
	
	ssA : CM_StraddleStack;
	ssC : CM_StraddleStack;
	
	labRestrictA : CM_LabourRestriction;
	labRestrictC : CM_LabourRestriction;
	
	locationControllersA : ObjectArray;
	locationControllersC : ObjectArray;
	
	newLCs :CM_LCArray;
	gridRow : CM_GridRow;
	lc : CM_LocationsController;
	
	strResponse : String;
	pos1 : Integer;
	pos2 : Integer;
	pos3 : Integer;
	pos4 : Integer;
	pos5 : Integer;
	pos6 : Integer;
	pos7 : Integer;

begin

	beginTransaction;
	app.myRoot.setClient(Client_PortOtago);
	commitTransaction;

	terminal := self.getMyTerminal();
	
	self.deleteTerminalArea("A");
	self.deleteTerminalArea("C");
	
	ssA := self.addStraddleStack("A", 20, 4, 2 );
	//Aplha East - AE = rows 1- 9
	//Aplha Sub Station - ASUB = rows 10-13
	//Aplha West - AW = rows 14-20 
	ssC := self.addStraddleStack("C", 29, 4, 2 );
	//Charlie South - CS = rows 1-13
	//Charlie Sub Station - CSUB = rows 14-16
	//Charlie North - CN = rows 17-24
	//Charlie PTI - CPTI = rows 25-29
	
	self.assertTrueMsg( ssA &lt;&gt; null, "Straddle Stack Area 'A' not created in setup");
	self.assertTrueMsg( ssC &lt;&gt; null, "Straddle Stack Area 'C' not created in setup");
	
	labRestrictA := self.addLabourRestriction( "TA_A", ssA, false );
	self.assertTrueMsg( labRestrictA &lt;&gt; null, "Labour Restrict on all of Straddle Stack Area 'A' not created in setup");
	
	create newLCs transient;
	create locationControllersA transient;
	create locationControllersC transient;
	
	ssA.getAllLocationsControllers( locationControllersA );
	locationControllersA.copy( newLCs );
	strResponse := terminal.handleWarningLights7( ssA, newLCs, Directory,  RequestFile, ResponseFileName, TimeoutSecs );
	
	pos1 := strResponse.pos("AE=1",1);
	self.assertTrueMsg( pos1 &gt; 0, "Test 1 - AE value not set to 1");
	pos2 := strResponse.pos("AW=1",1);
	self.assertTrueMsg( pos2 &gt; 0, "Test 1 - AW value not set to 1");
	pos3 := strResponse.pos("ASUB=1",1);
	self.assertTrueMsg( pos3 &gt; 0, "Test 1 - ASUB value not set to 1");
	pos4 := strResponse.pos("CS=0",1);
	self.assertTrueMsg( pos4 &gt; 0, "Test 1 - CS value not set to 0");
	pos5 := strResponse.pos("CN=0",1);
	self.assertTrueMsg( pos5 &gt; 0, "Test 1 - CN value not set to 0");
	pos6 := strResponse.pos("CSUB=0",1);
	self.assertTrueMsg( pos6 &gt; 0, "Test 1 - CSUB value not set to 0");
	pos7 := strResponse.pos("CPTI=0",1);
	self.assertTrueMsg( pos7 &gt; 0, "Test 1 - CPTI value not set to 0");
	self.assertTrueMsg( pos7 &gt; pos6 and pos6 &gt; pos5 and pos5 &gt; pos4 and pos4 &gt; pos3 and pos3 &gt; pos2 and pos2 &gt; pos1, "Output in an incorrect order.");
		
	labRestrictC := self.addLabourRestriction( "TA_C", ssC, false );
	self.assertTrueMsg( labRestrictC &lt;&gt; null, "Labour Restrict on all of Straddle Stack Area 'C' not created in setup");
	
	ssC.getAllLocationsControllers( locationControllersC );
	newLCs.clear();
	locationControllersC.copy( newLCs );
	strResponse := terminal.handleWarningLights7( ssC, newLCs, Directory,  RequestFile, ResponseFileName, TimeoutSecs );
	
	pos1 := strResponse.pos("AE=1",1);
	self.assertTrueMsg( pos1 &gt; 0, "Test 2 - AE value not set to 1");
	pos2 := strResponse.pos("AW=1",1);
	self.assertTrueMsg( pos2 &gt; 0, "Test 2 - AW value not set to 1");
	pos3 := strResponse.pos("ASUB=1",1);
	self.assertTrueMsg( pos3 &gt; 0, "Test 2 - ASUB value not set to 1");
	pos4 := strResponse.pos("CS=1",1);
	self.assertTrueMsg( pos4 &gt; 0, "Test 2 - CS value not set to 1");
	pos5 := strResponse.pos("CN=1",1);
	self.assertTrueMsg( pos5 &gt; 0, "Test 2 - CN value not set to 1");
	pos6 := strResponse.pos("CSUB=1",1);
	self.assertTrueMsg( pos6 &gt; 0, "Test 2 - CSUB value not set to 1");
	pos7 := strResponse.pos("CPTI=1",1);
	self.assertTrueMsg( pos7 &gt; 0, "Test 2 - CPTI value not set to 1");
	self.assertTrueMsg( pos7 &gt; pos6 and pos6 &gt; pos5 and pos5 &gt; pos4 and pos4 &gt; pos3 and pos3 &gt; pos2 and pos2 &gt; pos1, "Output in an incorrect order.");
	
	self.deleteLabourRestriction( labRestrictA );
	newLCs.clear();
	strResponse := terminal.handleWarningLights7( ssA, newLCs, Directory,  RequestFile, ResponseFileName, TimeoutSecs );
	pos1 := strResponse.pos("AE=0",1);
	self.assertTrueMsg( pos1 &gt; 0, "Test 3 - AE value not set to 0");
	pos2 := strResponse.pos("AW=0",1);
	self.assertTrueMsg( pos2 &gt; 0, "Test 3 - AW value not set to 0");
	pos3 := strResponse.pos("ASUB=0",1);
	self.assertTrueMsg( pos3 &gt; 0, "Test 3 - ASUB value not set to 0");
	pos4 := strResponse.pos("CS=1",1);
	self.assertTrueMsg( pos4 &gt; 0, "Test 3 - CS value not set to 1");
	pos5 := strResponse.pos("CN=1",1);
	self.assertTrueMsg( pos5 &gt; 0, "Test 3 - CN value not set to 1");
	pos6 := strResponse.pos("CSUB=1",1);
	self.assertTrueMsg( pos6 &gt; 0, "Test 3 - CSUB value not set to 1");
	pos7 := strResponse.pos("CPTI=1",1);
	self.assertTrueMsg( pos7 &gt; 0, "Test 3 - CPTI value not set to 1");
	
	self.deleteLabourRestriction( labRestrictC );
	newLCs.clear();
	strResponse := terminal.handleWarningLights7( ssC, newLCs, Directory,  RequestFile, ResponseFileName, TimeoutSecs );
	pos1 := strResponse.pos("AE=0",1);
	self.assertTrueMsg( pos1 &gt; 0, "Test 4 - AE value not set to 0");
	pos2 := strResponse.pos("AW=0",1);
	self.assertTrueMsg( pos2 &gt; 0, "Test 4 - AW value not set to 0");
	pos3 := strResponse.pos("ASUB=0",1);
	self.assertTrueMsg( pos3 &gt; 0, "Test 4 - ASUB value not set to 0");
	pos4 := strResponse.pos("CS=0",1);
	self.assertTrueMsg( pos4 &gt; 0, "Test 4 - CS value not set to 0");
	pos5 := strResponse.pos("CN=0",1);
	self.assertTrueMsg( pos5 &gt; 0, "Test 4 - CN value not set to 0");
	pos6 := strResponse.pos("CSUB=0",1);
	self.assertTrueMsg( pos6 &gt; 0, "Test 4 - CSUB value not set to 0");
	pos7 := strResponse.pos("CPTI=0",1);
