    <JadeMethod name="setDirectDeliveryUpdate" id="3c15aadc-db86-4c6d-ac60-783f024417c7">
        <updating/>
        <source>setDirectDeliveryUpdate(_originatingWle : CM_WorkListEntry; _prenoteTI : CM_TrackedItem; _job : CM_Job) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 14/10/2021	navdap1		Initial creation TFS 51935 SAL Direct Loading Partial Prenoted Cargo from Truck to Vessel
// 10/11/2021	navdap1		TFS 52360 SAL Direct Prenote to Voyage Incorrect Job Values
// 10/12/2021	navdap1		TFS 52293 SAL Direct Loading - Marking Job as Direct Delivery. Changed signature
//
vars

begin
	if _prenoteTI.isBulkByQuantity and self.isKindOf(CM_VoyageWLE) then										// TFS 52360
		self.CM_VoyageWLE.setSubSeqNum(self.quantity);														// TFS 52360
	elseif (_prenoteTI.isBulkByWeight or _prenoteTI.isBulkByVolume) and self.isKindOf(CM_VoyageWLE) then	// TFS 52360
		self.CM_VoyageWLE.setSubSeqNum(self.weight.Integer);												// TFS 52360
	endif;																									// TFS 52360
	self.quantity := _originatingWle.quantity;
	self.weight := _originatingWle.weight;
	self.myDirectDeliveryParentWLE := _originatingWle;
	self.locationSource := _originatingWle.locationSource;
	
	self.job := _job;				// TFS 52293
	self.myTrackedItem := _originatingWle.myTrackedItem;
epilog

end;</source>
        <Parameter name="_originatingWle" type="CM_WorkListEntry"/>
        <Parameter name="_prenoteTI" type="CM_TrackedItem"/>
        <Parameter name="_job" type="CM_Job"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="defcfdbb-cda0-49e1-a2b6-a4870e57abbe">
        <updating/>
        <source>setForCreate(_job : CM_Job; _request : CM_Request) updating;
// ---------------------------------------------------------------------------
// Created:     08 March 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	self.job		:= _job;
	self.myRequest	:= _request;

	if self.job &lt;&gt; null then
		self.job.updateStatus();
	endif;
end;</source>
        <Parameter name="_job" type="CM_Job"/>
        <Parameter name="_request" type="CM_Request"/>
    </JadeMethod>
    <JadeMethod name="setForTranshipUpdate" id="ed093d6c-32df-4f58-8569-f20a1895b944">
        <updating/>
        <source>setForTranshipUpdate( _ti: CM_TrackedItem; _bol: CM_BOL; /*_fm: CM_FutureMove;*/ _jobS: CM_JobSheet; _req: CM_Request ) updating;
// ---------------------------------------------------------------------------
// Created:     10 January 2007 by cnwvu1
//
// Purpose:     
// ---------------------------------------------------------------------------

vars

begin

	self.setMyTrackedItem( _ti );
	self.myBOL			:= _bol;
//	self.myFutureMove	:= _fm;		automatic reference
	self.myJobSheet		:= _jobS;
