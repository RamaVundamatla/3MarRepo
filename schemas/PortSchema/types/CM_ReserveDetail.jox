    <JadeMethod name="setBookingRefItemReference" id="fa136e35-fcfd-4b3b-aa90-64fc17b87b6d">
        <source>setBookingRefItemReference(_pxyReserve:CM_ReserveDetail; _cmifBooking:CMIF_BookingRef);
// --------------------------------------------------------------------------------
// Created:		30 May 2008 by cnwdad1
//
// Purpose:		
//
// Parameters:	_pxyReserve 	- Proxy object for receiver
//				_cmifBooking 	- Booking Reference Item for which the receiver was created.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 20/02/2012	cnwcs5		par 28756 - refactoring
// --------------------------------------------------------------------------------
vars
	cmifBookingItem	: CMIF_BookingRefItem;
	bookingItem		: CM_BookingRefItem;
	ti				: CM_TrackedItem;
	coll, collRel	: CM_TISet;
begin
	if _cmifBooking = null then
		return;
	endif;
	
	// store tracked items collections in local variable (avoid repeated getPropertyValue)
	coll 	:= self.allTrackedItems;
	collRel	:= self.allTrackedItemsReleased;
	
	foreach cmifBookingItem in _cmifBooking.allCMIF_BRItems do
		if cmifBookingItem.myReserveDetail = _pxyReserve then
			// this cmifBooking item relates to pxyReserve
			bookingItem	:=	cmifBookingItem.myRealBookingRefItem;	
			
			if bookingItem &lt;&gt; null then
				// link the booking item and the reserve detail
				bookingItem.setMyReserveDetail(self);
				// attach booking TIs to the reserve detail
				foreach ti in bookingItem.allTIs where ti.state &lt;&gt; TI_STATE_NOTIFIED do
					if not (coll.includes(ti) or collRel.includes(ti)) then
						coll.add(ti);
					endif;
				endforeach;
			endif;
		endif;
	endforeach;
end;</source>
        <Parameter name="_pxyReserve" type="CM_ReserveDetail"/>
        <Parameter name="_cmifBooking" type="CMIF_BookingRef"/>
    </JadeMethod>
    <JadeMethod name="setCargoGroup" id="3ab83367-89f9-4214-a405-71da5d5481a8">
