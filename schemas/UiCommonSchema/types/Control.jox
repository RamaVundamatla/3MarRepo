<GUIClass name="Control">
    <JadeMethod name="doChangedCompareForEntryTable" id="fcac0f0d-2f4d-443d-9067-9ea00e4d6b9b">
        <updating/>
        <source>doChangedCompareForEntryTable() updating;
// ---------------------------------------------------------------------------
// Created:     06 October 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpCntrl	: Window;
begin
	tmpCntrl := self.parent;
	if tmpCntrl &lt;&gt; null and CM_EntryTable.hasInstance(tmpCntrl) then
		tmpCntrl.CM_EntryTable.doChangedComparismForControl(self.name);
	endif;
end;</source>
    </JadeMethod>
