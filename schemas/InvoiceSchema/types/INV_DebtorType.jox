end;</source>
    </JadeMethod>
    <JadeMethod name="doSave" id="e73dd186-4342-4b4c-bc53-7c215e057820">
        <updating/>
        <source>doSave(): Boolean updating;
// ---------------------------------------------------------------------------
// Created:	2 April 2008 By Graeme Black cnwgb1
// ---------------------------------------------------------------------------
vars
	proxyDebtorType : CM_DebtorType;
	rtnValue		: Boolean;
	isStorage		: Boolean;
	errObj			: CM_Error;
	navObject		: CMUI_NavigatorObject;
	colour 			: Integer;
	id				: Integer;
	table			: CM_EntryTable;
	theReturn 		: Integer;
    theDebtors 		: CM_DebtorSet; 
	aDefDebtor		: CM_Debtor;
begin
	table := self.tblEntDetail;

	// Get or make a proxy
	if self.mode = Mode_Add then
		create proxyDebtorType transient;
	elseif self.mode = Mode_Update then
		proxyDebtorType := self.myProxyObject.CM_DebtorType;
	else
		return false;
	endif;
	
	//Update the proxy
	
	create theDebtors transient;
	self.msgDebtors.getSelected(theDebtors);
	// Add default debtor to selected debtors if not present
	aDefDebtor := self.cmbDebtor.listObject.CM_Debtor;
	if  aDefDebtor &lt;&gt; null and not theDebtors.includes(aDefDebtor) then
		theDebtors.add(aDefDebtor);
	endif;
	
	proxyDebtorType.setProxy(
		self.tblEntDetail.getValueByName(ETRow_Code).String.toUpper(),		// TFS 2070 enfore upper-case
	    self.tblEntDetail.getValueByName(ETRow_Description).String,
		self.cmbDebtor.listObject.CM_Debtor,
		theDebtors,
		self.tblEntDetail.getValueByName(ETRow_IsNotAvailableForEntryCk).Boolean);
		
		// Call the helper objects to actually update using the proxy
	while true do
	 	if self.mode = Mode_Add then
			app.myTrxCA.trxCreateDebtorType(proxyDebtorType,  self.myCurrentObject, app.myPassport);
		elseif self.mode = Mode_Update then
			app.myTrxUA.trxUpdateDebtorType(proxyDebtorType, app.myPassport); 
		endif;
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			//global.beep;
			return true;
		else
			theReturn := app.showErrorWarningDialog("Debtor Type", app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors 
			and theReturn = IDOK then
				// there must have just been warnings that the user has acknowledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			return false;
		endif;
		break;
	endwhile;
	
epilog
	if self.mode = Mode_Add then
		delete proxyDebtorType;
	endif;
	delete theDebtors;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
