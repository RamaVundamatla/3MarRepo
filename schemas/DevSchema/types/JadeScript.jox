    <JadeMethod name="dataDumpExtractExtractHistory" id="c6fb6de6-93d3-43e8-bc70-a167dd6c8ca5">
        <source>dataDumpExtractExtractHistory();

constants
	DDxDefDescription = "RS SQL NATIVE";
vars
	def : CM_DataDumpExtractDef;
	hist : CM_DataDumpExtractHistory;
	startDateTime : TimeStamp;
	endDateTime : TimeStamp;
	startDate, endDate : Date;
	file, fileA, fileU, fileD : File;
	str : String;
begin
	app.initialize;
	def := app.myRoot.allDataDumpExtractDefs[DDxDefDescription];
	if def = null then
	write "Invalid def";
		return;
	endif;
	create file transient;
	file.mode := File.Mode_Output;
	file.fileName := 'C:\temp\POL\Par34849\'&amp;DDxDefDescription&amp;'.log';
	file.open;
	create fileA transient;
	fileA.mode := File.Mode_Output;
	fileA.fileName := 'C:\temp\POL\Par34849\'&amp;DDxDefDescription&amp;'A.log';
	fileA.open;
	create fileD transient;
	fileD.mode := File.Mode_Output;
	fileD.fileName := 'C:\temp\POL\Par34849\'&amp;DDxDefDescription&amp;'D.log';
	fileD.open;
	create fileU transient;
	fileU.mode := File.Mode_Output;
	fileU.fileName := 'C:\temp\POL\Par34849\'&amp;DDxDefDescription&amp;'U.log';
	fileU.open;
	startDate.setDate(31,08,2014);
	endDate.setDate(31,08,2014);
	startDateTime.setDate(startDate);
	startDateTime.setTime("06.05.48.0".Time);
	endDateTime.setDate(endDate);
	endDateTime.setTime("09.05.49.999".Time);
	foreach hist in def.allDataDumpExtractHistory do
		if hist.extractedFromDateTime &gt; startDateTime and
		   hist.extractedFromDateTime &lt; endDateTime then
			file.writeLine(hist.startDateTime.String&amp;' from '&amp;hist.extractedFromDateTime.String&amp;' to '&amp;hist.extractedUpToDateTime.String&amp;' adds='&amp;hist.numCreates.String&amp;' dels'&amp;hist.numDeletes.String&amp;' '&amp;hist.numUpdates.String&amp;' ');
			foreach str in hist.addOids do
				fileA.writeLine(str);
			endforeach;
			foreach str in hist.deleteOids do
				fileD.writeLine(str);
			endforeach;
			foreach str in hist.updateOids do
				fileU.writeLine(str);
			endforeach;
		endif;
	endforeach;
	file.close();
	fileA.close();
	fileD.close();
	fileU.close();
epilog
	delete file;
	delete fileA;
	delete fileD;
	delete fileU;
end;
</source>
    </JadeMethod>
    <JadeMethod name="dataDumpExtractSingleObject" id="176c4ea1-9709-4ec3-8ac9-0d92e12a1509">
        <source>dataDumpExtractSingleObject();
// ---------------------------------------------------------------------------
// Created:     Aug 2006 cnwrs1
//
// Purpose:		The test extract selects one object (the lastInstance)
//				of each class in the definition, and extracts it in the
//				same way as the full extract.  Doesn't test Deletes.
// ---------------------------------------------------------------------------
constants
	DDxDefDescription = "Joe's Test SQL Native";
vars
	agent : CM_DataDumpExtractionAgent;
	object : CM_Object;
begin
	app.initialize;
	app.myPassport.setMyUserFromCode("SUPERUSER");
	object := "2367.1".asOid.CM_Object;	
	create agent transient;
	agent.initialise("", true, false);
	agent.doExtractTestSingleObject(
			DDxDefDescription,
			//CM_DataDumpExtractDef.FmtXML_Generic);
			CM_DataDumpExtractDef.FmtExternalDatabase, object);
	agent.finalise;
	
epilog
	delete agent;
end;</source>
    </JadeMethod>
    <JadeMethod name="dataDumpExtractTIs" id="3a2c163e-d78f-46f0-ae24-cba15d96adde">
        <source>dataDumpExtractTIs();

vars
	tr : CM_TITransaction;
	startDateTime : TimeStamp;
	endDateTime : TimeStamp;
	startDate, endDate : Date;
	number : Integer;
	iter : Iterator;
begin
	app.initialize;
	startDate.setDate(12,03,2025);
	endDate.setDate(13,03,2025);
	startDateTime.setDate(startDate);
	startDateTime.setTime("20.00.0.0".Time);
	endDateTime.setDate(endDate);
	endDateTime.setTime("23.59.59.999".Time);
	if app.msgBox("Start Date ="&amp;startDateTime.String&amp;' End Date ='&amp;endDateTime.String, "Error Invalid Date",MsgBox_Yes_No + MsgBox_Question_Mark_Icon) = MsgBox_Return_No then
		return;
	endif;
	iter := CM_Terminal.firstInstance.allTITransactions.createIterator;
	CM_Terminal.firstInstance.allTITransactions.startKeyGeq(startDateTime, 277, iter);
	while iter.next(tr) do
		if tr.dateTime &gt; endDateTime then
			break;
		endif;
		number := number + 1;
		//beginTransaction;
		//tr.updateObjectEdition(tr);	// par 30292
		//commitTransaction;
	endwhile;
	app.msgBox((number).String&amp;" Start Date ="&amp;startDateTime.String&amp;' End Date ='&amp;endDateTime.String, "Warning end position", 0);
epilog
	delete iter;
end;
</source>
    </JadeMethod>
    <JadeMethod name="dataDumpExtractTestSingle" id="bbf9090e-ca1d-451a-8395-04fcec841337">
        <source>dataDumpExtractTestSingle();
// ---------------------------------------------------------------------------
// Created:     03 June 2003 by cnwsb1
//
// Purpose:		The test extract selects one object (the lastInstance)
//				of each class in the definition, and extracts it in the
