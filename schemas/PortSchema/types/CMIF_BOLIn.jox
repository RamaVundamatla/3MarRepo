    <JadeMethod name="hasDocketErrors" id="52d4d381-3e0a-4845-a428-e92ba1a83035">
        <source>hasDocketErrors(): Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 March 2010	cnwas3	ccms 1110 par 22210

*/

vars

begin
	if not self.allDocketErrors.isEmpty() then
		return true;
	endif;
	
	return false;

epilog

end;</source>
