    <JadeMethod name="checkRangeTable" id="f7b17f0d-8e9e-4e67-8f8f-33d357883944">
        <updating/>
        <source>checkRangeTable() updating, protected;
//	CCMS SFW 1279 May 2012 Storage Escalating Charges
vars
	aRow,value, lastValue : Integer;
	table	: Table;
begin

	table := self.tblRange;
	aRow := table.row;
	
	if aRow &gt; 2 then
		value := table.accessCell(aRow - 1, self.COLUMN_TO).text.Integer;
		lastValue := table.accessCell(aRow - 2, self.COLUMN_TO).text.Integer;
		
		if value &lt; lastValue then
			global.beep;
			table.row := aRow - 1;
			if lastValue = MAX_VALUE then
				table.accessCell(aRow -1, self.COLUMN_TO).text := "";
			endif;
		else
			if value &lt; MAX_VALUE then
				table.accessCell(aRow, self.COLUMN_FROM).text := (value + 1).String;
			endif;
		endif;
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="checkRangeTableEscalating" id="b07ff897-0b26-4aee-95c1-9920ada0c0c0">
        <updating/>
        <source>checkRangeTableEscalating() updating, protected;
//	CCMS SFW 1279 May 2012 Storage Escalating Charges
vars
	row, col,
	toValue, lastToValue	: Integer;
	fromValue, lastFromValue	: Integer;
	table	: Table;
begin

	table := self.tblRange;
	row := table.row;
	col := table.column;
	
	if row &gt; 2 then
		toValue := table.accessCell(row, self.COLUMN_TO).text.Integer;
		lastToValue := table.accessCell(row - 1, self.COLUMN_TO).text.Integer;
		fromValue := table.accessCell(row, self.COLUMN_FROM).text.Integer;
		lastFromValue := table.accessCell(row - 1, self.COLUMN_FROM).text.Integer;
		
		if fromValue &lt; lastFromValue then
			global.beep;
			if lastFromValue = MAX_VALUE then
				table.accessCell(row -1, self.COLUMN_FROM).text := "";
			endif;
		endif;
		if col = self.COLUMN_PER_DAYS then
			if toValue &lt; fromValue then
				global.beep;
			endif;
		endif;
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
