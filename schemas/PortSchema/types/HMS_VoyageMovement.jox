    <JadeMethod name="populateFromWodMarineServDept" id="8f356d2d-ae45-4766-a949-379bb1fe50ba">
        <updating/>
        <source>populateFromWodMarineServDept( _wodMarineServicesDepart : CM_WodMarineServicesDepart ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 September 2018	jlgndl1	Initial creation	TFS 40810

*/

vars

	voyage : CM_Voyage;
	voyageData : HMS_VoyageData;
	loa : Decimal[6,2];

begin

	self.bowMarkTo := _wodMarineServicesDepart.bowMarkTo;
	self.draftAft := _wodMarineServicesDepart.draftAft;
	self.draftFwd := _wodMarineServicesDepart.draftFwd;

	voyage := self.getMyVoyage();
	if voyage &lt;&gt; null then
		voyageData := voyage.myHMSVoyageData;
		if voyageData &lt;&gt; null then
			loa := voyageData.dim_LengthOverall;
		endif;
	endif;
	
	self.sternMarkTo := self.bowMarkTo + loa;

epilog

end;</source>
        <Parameter name="_wodMarineServicesDepart" type="CM_WodMarineServicesDepart"/>
    </JadeMethod>
    <JadeMethod name="populateFromWodMarineServInit" id="1c0b6aa6-4882-423f-8692-efe76f5ee73a">
        <updating/>
        <source>populateFromWodMarineServInit( _wodMarineServicesInitial : CM_WodMarineServicesInitial) updating;
/*

Purpose:			// TFS 40236

Parameters:			

Return Value:		

Date		Who		Reason
13 August 2018	jlgab1	Initial creation

*/

vars
	voyage : CM_Voyage;
	
begin
	self.bowMarkTo := _wodMarineServicesInitial.bowMarkTo;
	self.draftAft := _wodMarineServicesInitial.draftAft;
	self.draftFwd := _wodMarineServicesInitial.draftFwd;
	
	if _wodMarineServicesInitial.myBerth&lt;&gt; null then
		self.myBerth := _wodMarineServicesInitial.myBerth;
	endif;
	
	if self.myHMSVoyageData &lt;&gt; null then
		self.myHMSVoyageData.setHasRamp(_wodMarineServicesInitial.hasRamp); // TFS 40236
	endif;

	voyage := self.getMyVoyage(); // TFS 40236
	if voyage &lt;&gt; null then // TFS 40236
		voyage.setStarboardBerthed(_wodMarineServicesInitial.starboardBerthed); // TFS 40236
	endif;
	
	//epr TFS 42627 19/12/18
	self.sternMarkTo := _wodMarineServicesInitial.getSternMark();


epilog

end;
</source>
        <Parameter name="_wodMarineServicesInitial" type="CM_WodMarineServicesInitial"/>
    </JadeMethod>
    <JadeMethod name="populateFromWodShiftMovement" id="770e5902-37a1-43bf-819f-7384e6d72eed">
        <updating/>
        <source>populateFromWodShiftMovement( _wodShiftMove : CM_WodShiftMovement ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18/05/2018	jlgndl1	Initial creation	TFS 38664
23/05/2018	jlgdap1	TFS 38560 PEL1 Voyage Work Orders
19/10/2021  navma1  Bug 52154: SAL – Starboard side to Port side change in Shift Request from the Web Portal is not working
*/

vars
	voyage : CM_Voyage;
begin
	// default to SHIFT movement
	self.moveType 				 := HMSMovementTypeShift;					// TFS 38560
	//directly stored data
	self.bowMarkTo 				  := _wodShiftMove.bowMarkTo;
	self.draftAft				  := _wodShiftMove.draftAft;
	self.draftFwd 				  := _wodShiftMove.draftFwd;
	self.occursOnDTNEW 		      := _wodShiftMove.occursOnDT;				// TFS 38560
	self.relativeOrderTimeLines   := _wodShiftMove.relativeOrderTimeLines;
	self.relativeOrderTimePlaunch := _wodShiftMove.relativeOrderTimePlaunch;
	self.relativeOrderTimeTugs    := _wodShiftMove.relativeOrderTimeTugs;
	self.sternMarkTo 			  := _wodShiftMove.sternMarkTo;
	self.myBerthPrevious    	  := _wodShiftMove.myFromBerth;
	self.myBerth 		    	  := _wodShiftMove.myToBerth;
	self.chargeForMove			  := true; 							//epr 9/8/18 default to true when creating movements
	
	if _wodShiftMove.starboardBerthed then							//19.10.2021 navma1 #52154
		self.sideTo := OrientStarboardSideTo;
	else
		self.sideTo := OrientPortSideTo;
	endif;
	
	if self.myHMSVoyageData &lt;&gt; null then
		self.myShippingAgent := self.myHMSVoyageData.myShippingAgent;
		self.myLineCompany   := self.myHMSVoyageData.myLineCompany;
	endif;
	
	//derived data.
	self.myHarbour 				   := _wodShiftMove.getHarbour();
	self.myHMSVoyageData 		   := _wodShiftMove.getMyHMSVoyageData();
	
	if self.myHMSVoyageData &lt;&gt; null then
		self.myTidalClass := self.myHMSVoyageData.myTidalClass;
		self.myHMSVoyageData.setHasRamp(_wodShiftMove.hasRamp); 	// TFS 40236
	endif;

	voyage := self.getMyVoyage(); 									// TFS 40236
	if voyage &lt;&gt; null then 											// TFS 40236
		voyage.setStarboardBerthed(_wodShiftMove.starboardBerthed); // TFS 40236
		self.myShippingLine  := voyage.myShippingLine; 				// TFS 40236 from testing
	endif;
epilog

end;</source>
        <Parameter name="_wodShiftMove" type="CM_WodShiftMovement"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="51b4722c-9674-49ec-bfda-0a633e3098b6">
        <source>pxyCreateUpdateProxy(): SelfType;
//--------------------------------------------------
// Created:	05 April 2004 By: cnwgd1
//--------------------------------------------------
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy
// 23/04/2019	jlgsl4		TFS 44438 - PEL1 - Multiple Pilot Launches for one movement
// 15/09/2023	navdap1		TFS 59472 EUP | FR 56588 Berth planning by bollards Remedial

vars
	tmpResUsed : HMS_ResourceUsed;
	proxy : HMS_VoyageMovement;
	completedOK		: Boolean;
	tmpMvmntPilotDetails : HMS_MovementPilotDetails; // TFS 44438	
begin
	proxy := inheritMethod();
	proxy.myContact := self.myContact;
	proxy.myHarbour := self.myHarbour;
	proxy.myHMSVoyageData := self.myHMSVoyageData;
	proxy.myLineCompany := self.myLineCompany;
//	proxy.myPilot := self.myPilot;
	
	// 31 Oct 2018	NDL	TFS 41662
	proxy.setUnusedMyPilotRefToNull();	
	//proxy.allPilots.clear(); // --&gt; TFS 44438
	//if not self.allPilots.isEmpty then
	//	self.allPilots.copy( proxy.allPilots );
	//endif; // &lt;-- TFS 44438
	proxy.allMovementPilotDetails.clear(); // --&gt; TFS 44438
	foreach tmpMvmntPilotDetails in self.allMovementPilotDetails do
		proxy.allMovementPilotDetails.add(tmpMvmntPilotDetails.pxyCreateUpdateProxy);
	endforeach; // &lt;-- TFS 44438

	/*if self.getUnConvertedMyPilotRef &lt;&gt; null then // to allow for conversion of old data using single pilots to multi pilot format // --&gt; TFS 44438
		proxy.allPilots.addNoDuplicates( self.getUnConvertedMyPilotRef, false );
	endif;*/ // &lt;-- TFS 44438

	//proxy.myPilotLaunch := self.myPilotLaunch; // TFS 44438
	proxy.myShippingAgent := self.myShippingAgent;
	proxy.myShippingLine := self.myShippingLine;
	proxy.myMaster:=self.myMaster; //epr par 18551 27/11/08
	proxy.sternMarkTo := self.sternMarkTo;
	
	self.allTugsUsed.copy(proxy.allTugsUsed);
		
	foreach tmpResUsed in self.allResourceUsed do
		proxy.allResourceUsed.add(tmpResUsed.pxyCreateUpdateProxy);
	endforeach;
	
	// TFS 59472 If the voyage has a work order, and that work order gets processed as part of voyage creation,
	// we end up in here and didn't set bollard details. This was the only circumstance where we end up here
	// while creating movements
	proxy.bowToBollard		:= self.bowToBollard;
	proxy.bridgeToBollard	:= self.bridgeToBollard;
	proxy.sternToBollard	:= self.sternToBollard;
	proxy.myBowBollard		:= self.myBowBollard;
	proxy.myBridgeBollard	:= self.myBridgeBollard;
	proxy.mySternBollard	:= self.mySternBollard;
	// TFS 59472 end
	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return proxy;
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete proxy;
	endif;	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="requiresMarineServices" id="c0a5e25b-92f3-40d0-bbb0-748c389594be">
        <source>requiresMarineServices() : Boolean;
//--------------------------------------------------
// Created:	03 December 2004 By: cnwgd1
//--------------------------------------------------
//Determine if we need marine services (pilot and tugs) based on where we
//are going from and to
/*

Date		Who		Reason
30 Mar 2008	cnwkpd1	PAR #16367 - Change to use reworked HMS_VoyageMovement::getVoyageMovementPrevious
10 Sep 2021 navma1  ChangeRequest 51002: MTN - Web Portal Cargo Work Orders
*/

vars
   priorMove : HMS_VoyageMovement;
begin
	if self.getMyBerth() &lt;&gt; null then
		if self.getMyBerth().noMarineServices = true then	
			//Don't need MS to go here
			priorMove := self.getVoyageMovementPrevious();		// PAR #16367
			if priorMove &lt;&gt; null
			and  priorMove.getMyBerth() &lt;&gt; null              //10.09.2021 navma1 #51002
			and priorMove.getMyBerth().noMarineServices = false then
				//We are moving from somewhere that requires MS
				return true;
	   		else
	   			return false;
	   		endif;
	   	endif;
	endif;
	
	return true;
	
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setArchiveStatus" id="b41e52dd-10f0-4d3a-8634-8df1a86385aa">
        <updating/>
        <source>setArchiveStatus(_archiveDT : TimeStamp)updating, protected;
//--------------------------------------------------------------
//Created: 28 July 2003 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	self.archived := true;
	self.archivedDT := _archiveDT;

	if (not self.archivedDT.isValid) then
		self.archivedDT := app.serverTimestampAtTrxStart;
	endif;	

end;</source>
        <access>protected</access>
        <Parameter name="_archiveDT" type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="setBollardDetails" id="7763a716-eacf-431c-8f46-58b3016ced93">
        <updating/>
        <source>setBollardDetails(_bowToBollard,_bridgeToBollard,_sternToBollard : Decimal;
				  _myBowBollard, _myBridgeBollard, _mySternBollard : HMS_Resource) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 October 2022	navsj20	ChangeRequest 54739: EUP - PLAN - Berth planning by bollards


*/

vars

begin
	self.bowToBollard		:=	_bowToBollard;
	self.bridgeToBollard	:=	_bridgeToBollard;
	self.sternToBollard		:=	_sternToBollard;	
	self.myBowBollard		:=	_myBowBollard;
	self.myBridgeBollard	:=	_myBridgeBollard;
	self.mySternBollard		:=	_mySternBollard;
epilog

end;</source>
        <Parameter name="_bowToBollard" type="Decimal"/>
        <Parameter name="_bridgeToBollard" type="Decimal"/>
        <Parameter name="_sternToBollard" type="Decimal"/>
        <Parameter name="_myBowBollard" type="HMS_Resource"/>
        <Parameter name="_myBridgeBollard" type="HMS_Resource"/>
        <Parameter name="_mySternBollard" type="HMS_Resource"/>
    </JadeMethod>
    <JadeMethod name="setBowMarkValue" id="b391fbef-7e60-48f2-bf82-c7f3203da4c7">
        <updating/>
        <source>setBowMarkValue(_bowMark : Decimal) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 July 2018	jlgrh7	Initial creation TFS39468 STWO - Issue with moving vessels to berth ANCHOR

*/

vars

begin
	self.bowMarkTo := _bowMark;
epilog

end;</source>
        <Parameter name="_bowMark" type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="setDefaultResourcesUsed" id="705c6fdd-3588-40d4-95d0-5c0935474932">
        <updating/>
        <source>setDefaultResourcesUsed(_transient : Boolean; _passport : CM_Passport input) updating, protected;
//--------------------------------------------------
// Created:	21 February 2005 By: cnwgd1
//--------------------------------------------------
// Changed On	By			Reason
// ----------	--------	-------------------------------------------------------------
// 24/01/2014	cnwdap1		PAR #33337 CCMS PTR 2214 HMS Enhancements
// 20/10/2015   cnwma1      PAR #36638 movement maintenance throws an error of 1090
// 08/09/2023	jlika1		TFS 60370	POB - QShips Voyage Data EDI Status Stuck at Verifying or DB Load Failed
vars
	newResourceUsed 			: HMS_ResourceUsed;
	tmpVDHarbour				: HMS_VesselDataHarbour;
	tmpHMSVessel				: HMS_VesselData;
	tmpResource					: HMS_Resource;
	tmpResourceType				: HMS_ResourceType;
	tmpMoveResource				: HMS_ResourceTypeForMovement;
	lastVoyage 					: CM_Voyage;
	lastVoyageData				: HMS_VoyageData;
	lastMovement				: HMS_VoyageMovement;
	berthageArrival2Departure 	: Boolean;
	vesselCode					: String;
	terminal					: CM_Terminal;
begin
	// jlika1 TFS 60370 --&gt;
	if app.myPassport.myTerminal = null then
		terminal := self.myHMSVoyageData.getMyTerminal();
		if terminal = null then
			terminal := app.myRoot.allTerminals.first;
		endif;
	else 
		terminal := app.myPassport.myTerminal;	
	endif;
	// jlika1 TFS 60370 &lt;--

	//CCMS1299 create default resources from vessel resource used
	if self.myHMSVoyageData.allDefaultMovementResources.isEmpty then						// PAR #33337
		tmpHMSVessel := self.getMyHMSVesselData();
		if tmpHMSVessel &lt;&gt; null then
			tmpVDHarbour := tmpHMSVessel.allVesselDataForHarbour[self.myHarbour];
		endif;
	
		if tmpVDHarbour = null then
			return;
		endif;
	endif;																					// PAR #33337

	if not self.myHMSVoyageData.allDefaultMovementResources.isEmpty then					// PAR #33337
		tmpMoveResource := self.myHMSVoyageData.allDefaultMovementResources[self.moveType];	// PAR #33337
	elseif tmpVDHarbour &lt;&gt; null then														// jlika1 TFS 60370
		tmpMoveResource := tmpVDHarbour.allMovementResourcesByMovement[self.moveType];
	endif;																					// PAR #33337
//	berthageArrival2Departure := self.myHMSVoyageData.myVoyage.doBerthageArrivalToDeparture(false);
	berthageArrival2Departure := terminal.getConfig(InvoiceHMSNoShiftCharge).Boolean;		// jlika1 TFS 60370

	if tmpMoveResource &lt;&gt; null then
		
		// where possible set default resource to that of last voyage
		if tmpVDHarbour &lt;&gt; null then														// PAR #33337
			lastVoyage := tmpVDHarbour.myHarbour.getVesselsLastVoyage(tmpHMSVessel.myVessel.code);
		else 
			if self.getMyVessel &lt;&gt; null then											    //20/10/2015 cnwma1 PAR #36638
				vesselCode := self.getMyVessel.code;
			else
				vesselCode :=self.myHMSVoyageData.myVoyage.vesselCode;                      //20/10/2015 cnwma1 PAR #36638
			endif;
			lastVoyage := self.myHarbour.getVesselsLastVoyage(vesselCode);					// PAR #33337  //20/10/2015 cnwma1 PAR #36638
		endif;																				// PAR #33337
		
		if lastVoyage &lt;&gt; null then
			lastVoyageData := lastVoyage.myHMSVoyageData;
		endif;				
		if lastVoyageData &lt;&gt; null then
			lastMovement := lastVoyageData.getMovementForMoveType(self.moveType);
		endif;		
		
		self.numContractTugs := tmpMoveResource.numTugsForMovement; // PAR 10373
	
		foreach tmpResourceType in tmpMoveResource.allResourceTypes do : resTypeLoop

			// ### if necessary do not create shift berthage
			if berthageArrival2Departure
			and self.moveType = HMSMovementTypeShift then
				foreach tmpResource in tmpResourceType.allResources do
					// ### if necessary do not create shift berthage
					if tmpResource.isResourceForClass(HMS_ResourceForWharf) then
						continue resTypeLoop;
					endif;
				endforeach;
			
			endif;


			if _transient then
				create newResourceUsed transient;
			else
				create newResourceUsed persistent;				
			endif;
			self.allResourceUsed.add(newResourceUsed);
			if lastMovement &lt;&gt; null then
				tmpResource := lastMovement.getDefaultResourceForType(tmpResourceType);
			else
				tmpResource := null;			
			endif;
			newResourceUsed.setDefaultForMovement(true, tmpResource, tmpResourceType, _passport);
		endforeach;	
		
	endif;		
	
end;</source>
        <access>protected</access>
        <Parameter name="_transient" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setForCreateMovement" id="460d52f9-5d3e-423c-94b1-77581fdc29f4">
        <updating/>
        <source>setForCreateMovement(_pxyObj, prevMovement : HMS_VoyageMovement; _calculateSteamingTime : Boolean; _passport: CM_Passport input) updating;
//--------------------------------------------------
// Created:	08 April 2004 By: cnwgd1
//--------------------------------------------------
vars

begin

	if self.myHMSVoyageData = null then	
		// shift movement set voyage data
		self.myHMSVoyageData := _pxyObj.myHMSVoyageData;
	else
		self.sternMarkTo := self.myHMSVoyageData.dim_LengthOverall;
	endif;
	
	if self.myHMSVoyageData.myVoyage.myVoyageGlobalArrival &lt;&gt; null then
		self.myVoyageGlobal := self.myHMSVoyageData.myVoyage.myVoyageGlobalArrival;
	else
		self.myVoyageGlobal := self.myHMSVoyageData.myVoyage.myVoyageGlobalDeparture;
	endif;

	inheritMethod(_pxyObj, prevMovement, _calculateSteamingTime, _passport);	
	
	//10 Dec 2018	NDL	TFS 42043
	if self.moveType = HMSMovementTypeShift then
		//If we are a new shift movement, and there is a pre-existing cancelled shift movement
		// that is not linked to a replacement, link it up. 
		self.findAndLinkCancelledShift();
	endif;
	
	self.createTransaction(TRANS_TYPE_AddMovement, null, _pxyObj, _passport);		
	
end;</source>
        <Parameter name="_pxyObj" type="HMS_VoyageMovement"/>
        <Parameter name="prevMovement" type="HMS_VoyageMovement"/>
        <Parameter name="_calculateSteamingTime" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setForUpdateMovement" id="9e39a67a-2c71-4ca3-a007-d9eb19eb72a7">
        <updating/>
        <source>setForUpdateMovement(_pxyVoyageMovement : HMS_VoyageMovement; _passport : CM_Passport input; _validateTimes : Boolean; _filterTimesForward : Boolean) updating;
//-----------------------------------------
// Created: March 2004 By: cnwgd1
//-----------------------------------------
// 30 Aug 2012	cnwcs5	par 30292 - use updateObjectEdition instead of updateEdition 
// 25/07/2018	jlgdap1	TFS 39741 PEL1 Marine Service Timings Changes
// 23 Apr 2019	jlgsl4	TFS 44438 - PEL1 - Multiple Pilot Launches for one movement
//11 Oct 2021 jlier1	TFS 51963 removed inaportnet
//14/09/2022  navgm20 	ChangeRequest 54739: EUP - PLAN - Berth planning by bollards
vars
 	newPermResourceUsed		: HMS_ResourceUsed;
 	permResourceUsed		: HMS_ResourceUsed;
 	pxyResourceUsed			: HMS_ResourceUsed;
 	permResourceToDeleteSet	: HMS_ResourceUsedSet;
 	newMmvntPilotDetails	: HMS_MovementPilotDetails; // TFS 44438
 	permMmvntPilotDetails	: HMS_MovementPilotDetails; // TFS 44438
 	pxyMmvntPilotDetails	: HMS_MovementPilotDetails;	// TFS 44438
	permMmvntPilotDtlsToDelSet : HMS_MovementPilotDetailsSet;	// TFS 44438
	voyageBerth,
	movementBerth			: HMS_Berth;
	voyage					: CM_Voyage;
begin
	inheritMethod(_pxyVoyageMovement, _passport, _validateTimes, _filterTimesForward);
	
	if (not app.isConverting) then
		// Do the change comparison before the update
		self.createTransaction(TRANS_TYPE_EditMovement, null, _pxyVoyageMovement, _passport);
		self.createTrans_AdjustMoveTime(null, _pxyVoyageMovement, _passport);
	endif;
	voyage := self.myHMSVoyageData.myVoyage;
	
 	// Deselect tugs that are no longer selected
 	self.allTugsUsed.clear();
 	_pxyVoyageMovement.allTugsUsed.copy(self.allTugsUsed);
 	
	self.aftClearanceTo 		:= _pxyVoyageMovement.aftClearanceTo;
	self.bowMarkTo 				:= _pxyVoyageMovement.bowMarkTo;
	self.chargeForMove			:= _pxyVoyageMovement.chargeForMove;
    self.draftFwd 				:= _pxyVoyageMovement.draftFwd;	//4.1.1 Draft enhancement
    self.draftAft 				:= _pxyVoyageMovement.draftAft;
	self.foreClearanceFrom 		:= _pxyVoyageMovement.foreClearanceFrom;
	self.foreClearanceTo		:= _pxyVoyageMovement.foreClearanceTo;
	self.isAgentDefault 		:= _pxyVoyageMovement.isAgentDefault;
	self.locationPilotLaunch 	:= _pxyVoyageMovement.locationPilotLaunch;
	self.locationTug 			:= _pxyVoyageMovement.locationTug;
	self.numContractTugs 		:= _pxyVoyageMovement.numContractTugs; // PAR 10373
	
    //self.moveDTActual			:= _pxyVoyageMovement.moveDTActual;
    //self.moveDTPlanned			:= _pxyVoyageMovement.moveDTPlanned;

	self.numLineCrewRequired 		:= _pxyVoyageMovement.numLineCrewRequired;
	self.overlapsWharfSection 		:= _pxyVoyageMovement.overlapsWharfSection;
	self.pilotExempt				:= _pxyVoyageMovement.pilotExempt;
	self.relativeOrderTimeLines		:= _pxyVoyageMovement.relativeOrderTimeLines;
	self.relativeOrderTimePlaunch	:= _pxyVoyageMovement.relativeOrderTimePlaunch;
	self.relativeOrderTimeTugs		:= _pxyVoyageMovement.relativeOrderTimeTugs;
	self.shipsMaster				:= _pxyVoyageMovement.shipsMaster;
	self.sideTo						:= _pxyVoyageMovement.sideTo;
	
	self.sternMarkTo				:= _pxyVoyageMovement.sternMarkTo;
	//14/09/2022 navgm20 TFS 54739- Start
	self.bowToBollard				:= _pxyVoyageMovement.bowToBollard;
	self.sternToBollard				:= _pxyVoyageMovement.sternToBollard;
	self.bridgeToBollard			:= _pxyVoyageMovement.bridgeToBollard;
	self.myBowBollard				:= _pxyVoyageMovement.myBowBollard;
	self.mySternBollard				:= _pxyVoyageMovement.mySternBollard;
	self.myBridgeBollard			:= _pxyVoyageMovement.myBridgeBollard;
	//14/09/2022 navgm20 TFS 54739- End
 	// Update references
 //	self.myPilot 			:= _pxyVoyageMovement.myPilot;
	
	// 31 Oct 2018	NDL	TFS 41662
	self.setUnusedMyPilotRefToNull();
	/* self.allPilots.clear(); // --&gt; TFS 44438
	if not _pxyVoyageMovement.allPilots.isEmpty then
		_pxyVoyageMovement.allPilots.copy( self.allPilots );
	endif;
	if _pxyVoyageMovement.getUnConvertedMyPilotRef() &lt;&gt; null then // to allow for conversion of single pilots to multi pilot
		self.allPilots.addNoDuplicates( _pxyVoyageMovement.getUnConvertedMyPilotRef(), false );
	endif;*/ // &lt;-- TFS 44438

 	self.myMaster 			:= _pxyVoyageMovement.myMaster;
 	//self.myPilotLaunch 		:= _pxyVoyageMovement.myPilotLaunch; // TFS 44438
 	self.myLineCompany 		:= _pxyVoyageMovement.myLineCompany;
 	self.myShippingAgent 	:= _pxyVoyageMovement.myShippingAgent;
 	self.myShippingLine		:= _pxyVoyageMovement.myShippingLine;
 	self.myContact 			:= _pxyVoyageMovement.myContact;
	//done in the inheritMethod lets not do it again
 	//self.setMyBerth(_pxyVoyageMovement.myBerth);
 	self.myHarbour 			:= _pxyVoyageMovement.myHarbour;

	if not app.isConverting then
	 	if moveType = HMSMovementTypeArrival then
		 	// Update voyage arrival date if this is an arrival movement
	 		voyage.setArrivalDepartureDT(_pxyVoyageMovement.occursOnDTNEW,
	 										voyage.departedDT,
											_validateTimes);
	 	elseif self.moveType = HMSMovementTypeDeparture then
		 	// Update voyage departure date if this is a departure movement
	 		voyage.setArrivalDepartureDT(voyage.arrivedDT,
	 										_pxyVoyageMovement.occursOnDTNEW,
											_validateTimes);
	 	endif;
	endif; 
 //epr 43823 18/3/19 payment type needs to be set before resources are updated and potentially charged if gen inv now was ticked only do it when updated
	if _pxyVoyageMovement.pxyGetRealObject &lt;&gt; null then
		
		if self.moveType = HMSMovementTypeArrival or self.moveType = HMSMovementTypeShift then
			movementBerth := self.getMyBerth();
			voyageBerth   := voyage.getMyBerth();
			
			if movementBerth &lt;&gt; null and  movementBerth.paymentType &lt;&gt; voyage.paymentType 
			and voyage.paymentType = PaymentType_None then // TFS 41281 update the voyage payment type from the current berth, unless it has been changed
				voyage.setPaymentType(movementBerth.paymentType);		// 26/6/18 MAP TFS39250
			endif;
			if self.moveType = HMSMovementTypeArrival and voyageBerth &lt;&gt; movementBerth then
				voyage.setMyBerth(movementBerth);
			endif;
			
		endif;
	endif; 
 
 	// Update set of allResourceUsed
  	create permResourceToDeleteSet transient;

  	self.allResourceUsed.copy(permResourceToDeleteSet);
 	self.allResourceUsed.clear();
 
	foreach	pxyResourceUsed in _pxyVoyageMovement.allResourceUsed do
 		// Check to see if a permanent resource used object exists for this
 		// working pxyResourceUsed object.
 		
 		//Should only be processing proxies but you never know
 		if pxyResourceUsed.isTransient then
	 		permResourceUsed := pxyResourceUsed.pxyGetRealObject;
	 	else
	 		permResourceUsed := pxyResourceUsed;
	 	endif;
	 	
 		if permResourceUsed = null then
 			// Create new permanent resource used object
 			create newPermResourceUsed;
			// Add resource to perm coll 
			self.allResourceUsed.add(newPermResourceUsed);
			pxyResourceUsed.setProxyFromDateFromMovement(self); // ### PAR 10220
			// Create 'Resource Booking' Tranaction
			newPermResourceUsed.setForCreate(pxyResourceUsed, _passport);
  		else
  			// Add resource to perm coll still used
  			permResourceToDeleteSet.remove(permResourceUsed);
  			self.allResourceUsed.add(permResourceUsed);
			pxyResourceUsed.setProxyFromDateFromMovement(self); // ### PAR 10220
  			permResourceUsed.setForUpdate(pxyResourceUsed, _passport);
  		endif;
		
  		permResourceUsed := null;
  	endforeach;

  	// Archive all permResourceUsed objs marked for deletion
  	foreach permResourceUsed in permResourceToDeleteSet do
  		permResourceUsed.cancelBooking(self, _passport);
  	endforeach;

 	// --&gt; TFS 44438 - Update allMovementPilotDetails
  	create permMmvntPilotDtlsToDelSet transient;

  	self.allMovementPilotDetails.copy(permMmvntPilotDtlsToDelSet);
 	self.allMovementPilotDetails.clear();
 
	foreach	pxyMmvntPilotDetails in _pxyVoyageMovement.allMovementPilotDetails do
 		// Check to see if a permanent movementPilotDetails object exists for the
 		// working pxyMmvntPilotDetails object.
 		
 		//Should only be processing proxies but you never know
 		if pxyMmvntPilotDetails.isTransient then
	 		permMmvntPilotDetails := pxyMmvntPilotDetails.pxyGetRealObject;
	 	else
	 		permMmvntPilotDetails := pxyMmvntPilotDetails;
	 	endif;	 	
 		if permMmvntPilotDetails = null then
 			// Create new permanent movementPilotDetails object
 			create newMmvntPilotDetails;
			// Add movementPilotDetails to permanent collection
			self.allMovementPilotDetails.add(newMmvntPilotDetails);
			// Set newMmvntPilotDetails attributes
			newMmvntPilotDetails.setForCreate(pxyMmvntPilotDetails, _passport);
  		else
  			// Add movementPilotDetails to permanent collection still used
  			permMmvntPilotDtlsToDelSet.remove(permMmvntPilotDetails);
  			self.allMovementPilotDetails.add(permMmvntPilotDetails);
  			permMmvntPilotDetails.setForUpdate(pxyMmvntPilotDetails, _passport);
  		endif;
  		permMmvntPilotDetails := null;
  	endforeach;
	
	foreach pxyMmvntPilotDetails in permMmvntPilotDtlsToDelSet do
		delete pxyMmvntPilotDetails; // delete the to-be-deleted movement pilot details
	endforeach; // &lt;-- TFS 44438
	
	
	// TFS 39741 Update any Marine Service Timings for this movement if we've been made Actual
	if self.moveStatus = MovementStatus_Actual and self.myMarineServiceTimings &lt;&gt; null then
		foreach permResourceUsed in self.allResourceUsed do
			if permResourceUsed.myResource = null then
				continue;
			endif;
			if permResourceUsed.myResource.isResourceForClass(HMS_ResourceForPilot) then
				self.myMarineServiceTimings.setPilotDateTimes(permResourceUsed.fromDateTime, false, false, true);
			elseif permResourceUsed.myResource.isResourceForClass(HMS_ResourceForTug) then
				self.myMarineServiceTimings.setTugFromToDateTimes(permResourceUsed.fromDateTime, permResourceUsed.toDateTime, false, false, true);
			endif;
		endforeach;
	endif;
	// TFS 39741 end
	
	
	
// cnwdad1 09/01/2007 - Remove the check of the conversion flag.
	if self.myHMSVoyageData = null then	//19 Nov 2018	NDL	TFS 42043
	else
		self.updateObjectEdition(self.myHMSVoyageData);	// par 30292
	endif;
	
	//19 Nov 2018	NDL	TFS 42043
	if _pxyVoyageMovement.isCancelled() then
		self.moveType := _pxyVoyageMovement.moveType;
		//17 Dec 2018	NDL	TFS 42583
		self.myHMSVoyageData := null;
		self.myVoyageGlobal := null;	
		self.myNextMovement := null;
		self.myPreviousMovement := null;
	endif;
	
epilog
	delete permResourceToDeleteSet;
	delete permMmvntPilotDtlsToDelSet; // TFS 44438
end;</source>
        <Parameter name="_pxyVoyageMovement" type="HMS_VoyageMovement"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <Parameter name="_validateTimes" type="Boolean"/>
        <Parameter name="_filterTimesForward" type="Boolean"/>
    </JadeMethod>
