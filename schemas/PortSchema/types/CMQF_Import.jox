<Class name="CMQF_Import" id="f2f65576-f09a-44c3-ab56-ba14a6eb4dfc">
    <superclass name="CMQF_TrackedItem"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="query"/>
    <JadeMethod name="filterObjects" id="a6a86c9d-ee8d-4def-ab4e-7c91caea2a20">
        <updating/>
        <source>filterObjects(_collection: Collection input; _passport: CM_Passport) updating;
//----------------------------------------------------------------
//	Created:	20 January 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	ta			: CM_TerminalArea;
	ti			: CM_TrackedItem;
	lc			: CM_LocationsController;
	terminal	: CM_Terminal;
	breakOut	: Boolean;
begin

	ta := self.getMyTerminalArea;

	if ta &lt;&gt; null then
		foreach lc in ta.allLocationsControllers discreteLock do :locLoop
			foreach ti in lc.allTrackedItems discreteLock do
				if self.checkStatusIncludesObject(ti, _passport, breakOut) then
//				if self.includesObject(ti, _passport, breakOut) then
					if not _collection.includes(ti) then
						_collection.add(ti);
						//self.sumWeight := self.sumWeight + ti.weight;					//-cnwml2 MSL CCMS 1017
						self.sumWeight := self.sumWeight + ti.totalWeight;				//+cnwml2 MSL CCMS 1017	
					endif;
				endif;
				
//				if breakOut then
//					break locLoop;
//				endif;
			endforeach;
		endforeach;
		return;
	endif;
	
	foreach terminal in self.allTerminals do : terminalLoop
		//need to scan onsite, onship, notified as default when no ta specified
		
		//search onsite ti's
		//TI_STATE_NORMAL
		foreach ti in terminal.allOnsiteTIsByIdCargoType discreteLock do
			if self.checkStatusIncludesObject(ti, _passport, breakOut) then
//			if self.includesObject(ti, _passport, breakOut) then
				if not _collection.includes(ti) then
					_collection.add(ti);
					//self.sumWeight := self.sumWeight + ti.weight;					//-cnwml2 MSL CCMS 1017
					self.sumWeight := self.sumWeight + ti.totalWeight;				//+cnwml2 MSL CCMS 1017
				endif;
				
//				if breakOut then
//					break terminalLoop;
//				endif;
			endif;
		endforeach;
		
		//search notified ti's
		//TI_STATE_NOTIFIED
		foreach ti in terminal.allNotifiedTIsByIdCargoType discreteLock do
			if self.checkStatusIncludesObject(ti, _passport, breakOut) then
//			if self.includesObject(ti, _passport, breakOut) then
				if not _collection.includes(ti) then
					_collection.add(ti);
					//self.sumWeight := self.sumWeight + ti.weight;					//-cnwml2 MSL CCMS 1017
					self.sumWeight := self.sumWeight + ti.totalWeight;				//+cnwml2 MSL CCMS 1017
				endif;
			endif;
//			if breakOut then
//				break terminalLoop;
//			endif;
		endforeach;
		
		//search onship ti's for selected voyage
		//TI_STATE_ONSHIP
		if self.getMyVoyage &lt;&gt; null then
			foreach ti in self.getMyVoyage.allOnshipTIsByIdCargoType discreteLock do
				if self.checkStatusIncludesObject(ti, _passport, breakOut) then
//				if self.includesObject(ti, _passport, breakOut) then
					if not _collection.includes(ti) then
						_collection.add(ti);
						//self.sumWeight := self.sumWeight + ti.weight;					//-cnwml2 MSL CCMS 1017
						self.sumWeight := self.sumWeight + ti.totalWeight;				//+cnwml2 MSL CCMS 1017
					endif;
				endif;
				
//				if breakOut then
//					break terminalLoop;
//				endif;
			endforeach;
		endif;
	endforeach;
end;</source>
        <Parameter name="_collection" type="Collection" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="includesObject" id="a7360c43-ac96-4b63-9cd3-9d0ee85f1e6d">
        <updating/>
        <source>includesObject(_ti: CM_TrackedItem; _passport: CM_Passport; _breakOut: Boolean output): Boolean updating, protected;
//----------------------------------------------------------------
//	Created:	20 January 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
// 15/07/2010	cnwdap1		PAR #25021 review use of isImport/isexport for tranships
// 03/10/2010	cnwdap1		PAR #25932 Correct tranship handling (ONLY interested in the import relationship of a tranship)
// 21/10/2010	cnwdap1		PAR #25861 Only check self.myVoyage if we actually have one (running the report for ALL voyages was missing some tranships because self.myVoyage was null)
vars

begin

	if (not CM_Log.hasInstance(_ti)) and
	_ti.myParent = null and
	//(_ti.isImport or _ti.isTranshipItem) and 		// PAR 25021: the inheritMethod checks flag to see if t/ships are included or not
	//(_ti.isImport or (_ti.isTranshipItem and _ti.myImportVoyage = self.myVoyage)) and 	// PAR #25932 only match on import voyage
	(_ti.isImport or (_ti.isTranshipItem and (self.getMyVoyage = null or _ti.myImportVoyage = self.getMyVoyage))) and 	// PAR #25861
	inheritMethod(_ti, _passport, _breakOut)then
		return true;
	endif;

	return false;

end;</source>
        <access>protected</access>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <Parameter name="_breakOut" type="Boolean" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
