    <JadeMethod name="createOwnershipChange" id="fdf005d3-eab3-4944-a3eb-80ecfb900226">
        <updating/>
        <source>createOwnershipChange()updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 July 2023 navtnr20	TFS CR 58233	Task 58235: UI - Change of Ownership Maint
19 July 2023 navmv20 CR 58239 Task 58241: UI- Open COO Maint in Update mode
30/11/2023	navkc1 ChangeRequest 58254 Task 58255: UI - New Permission
*/

vars
	pxyCOO, realCOO 		: CM_OwnershipChange;
	theReturn : Integer;
	terminal				: CM_Terminal;
	newOperator,storageCgargeOpe,currentOperator : CM_Operator;
	incoterm : CM_InvoiceINCOTerm;
	frightForward	: CM_ConsigneeConsignor;
	refNumber,remarks,condition : String;
	addFreeDays,ownershipFreeDays : Integer;
	scheduleTSstart , freeStorageExpNewTS		: TimeStamp;
	freeStorageExpNew : Date;
	invoiceContract : CM_InvoiceContract;								//navra1 - TFS 64874 - 14th Aug 2024		
	debtorInvoiceContracts : CM_InvContractByBankIdDict;					//navra1 - DEFECT 65798 - 29th Aug 2024
	invoiceContractExists : Boolean;					//navra1 - DEFECT 65798 - 29th Aug 2024
begin
	self.mousePointer := Window.MousePointer_HourGlass;
	if self.cmbNewOperator.listIndex &lt;&gt; -1 then
		newOperator := self.cmbNewOperator.itemObject[self.cmbNewOperator.listIndex].CM_Operator;		
	endif;
	
	if self.cmbCurrentOperator.listIndex &lt;&gt; -1 then
		currentOperator := self.cmbCurrentOperator.itemObject[self.cmbCurrentOperator.listIndex].CM_Operator;		
	endif;		
	
	if self.cmbIncoTerm.listIndex &lt;&gt; -1 then
		incoterm := self.cmbIncoTerm.itemObject[self.cmbIncoTerm.listIndex].CM_InvoiceINCOTerm;
	endif;
	
	if self.cmbFrightForwarder.listIndex &lt;&gt; -1 then
		frightForward := self.cmbFrightForwarder.itemObject[self.cmbFrightForwarder.listIndex].CM_ConsigneeConsignor;
	endif;
	
	if self.cmbStorageOperator.listIndex &lt;&gt; -1 then
		storageCgargeOpe := self.cmbStorageOperator.itemObject[self.cmbStorageOperator.listIndex].CM_Operator;
	endif;
	
	if self.txtRefNumber &lt;&gt; null then
		refNumber := self.txtRefNumber.text.String;
	endif;
	scheduleTSstart.setDate(self.mskCOOFromStart.text.asDateJMT());
	scheduleTSstart.setTime(self.mskCOOFromStartTime.text.asTimeJMT());
	addFreeDays := self.txtAddFreeDaysNew.text.Integer;
	
	if self.txtRemarks &lt;&gt; null then
		remarks := self.txtRemarks.text.String;
	endif;
	
	if self.txtCondition &lt;&gt; null then
		condition := self.txtCondition.text.String;
	endif;
	terminal := self.getMyTerminal;
	
	// ### TFS BUG 64680 17JUNE024 NAVAB1 - set the free storage exp for new Op on COO
	freeStorageExpNew := self.displayFreeStorageExpiry.caption.asDateJMT();
	freeStorageExpNewTS.setDate(freeStorageExpNew);
	
	if self.cmbInvoiceContract.listIndex &lt;&gt; -1 then																			//navra1 - TFS 64874 - 14th Aug 2024
		invoiceContract := self.cmbInvoiceContract.itemObject[self.cmbInvoiceContract.listIndex].CM_InvoiceContract;		//navra1 - TFS 64874 - 14th Aug 2024
	endif;																													//navra1 - TFS 64874 - 14th Aug 2024
	
	create pxyCOO transient;
	pxyCOO.setProxy(refNumber , null,condition,app.getMyUserCode(),self.localToSystemTime(scheduleTSstart),null,freeStorageExpNewTS,null,addFreeDays, null, // ### TFS CR 58263 TASK 58264 30JAN2024 NAVAB1
																			null,null,null,remarks,frightForward,incoterm,newOperator,currentOperator,null,storageCgargeOpe,null,terminal, invoiceContract);	//navra1 - TFS 64874 - 14th Aug 2024
	//19/07/2023 navmv20 CR 58239 Task 58241 - start
	if mode = Cargo_Review_Mode then
		self.createOwnershipChangeDtl(pxyCOO);
	else
	//19/07/2023 navmv20 CR 58239 Task 58241- end
		while true do
			app.myTrxCA.trxCreateOwnershipChange(pxyCOO, realCOO, app.myPassport);
			if app.myPassport.trxCompletedOK then
				self.clearErrorWarnings();
				app.msgBox(app.getErrorString(Ownersh_change_created_sucessf), app.getErrorString(Message),MsgBox_OK_Only);
				self.myOwnershipChange := realCOO;
				if self.myOwnershipChange &lt;&gt; null  then
					self.btnAddItems.enabled := true;
					self.btnRemove.enabled := true;
					self.btnUpdate.enabled := true;
					self.btnAttachment.enabled := true;
					self.btnInvoiceIssus.enabled := true;
					//30/11/2023	navkc1 ChangeRequest 58254 Task 58255
					self.btnApprove.enabled := app.myCurrentUserCan(self.myTerminal, PmInvOwnershipChangeApprove);
					self.btnAudits.enabled := true;
					//self.txtFilCOODetail.enabled := true; //25/06/2024	navkc1 CR 64823 Task 64824
				endif;
				self.updateMode := true;
				self.startNotifications();
				
				
				break;
			else
				theReturn := app.showErrorWarningDialog(app.getErrorString(Ownersh_change_create), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
				if app.myPassport.noErrors and
				   theReturn = IDOK then
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
				self.setAllErrorWarnings(app.myPassport);
			endif;
			break;
		endwhile;
	endif; //19/07/2023 navmv20 CR 58239 Task 58241
epilog
	self.mousePointer := Window.MousePointer_Default;
	delete pxyCOO;
end;</source>
    </JadeMethod>
    <JadeMethod name="createOwnershipChangeDtl" id="6d5c57ac-ee75-425f-a041-fb1096f3e049">
        <updating/>
        <source>createOwnershipChangeDtl(_pxyCOO : CM_OwnershipChange input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 July 2023 navmv20 CR 58239 Task 58241: UI- Open COO Maint in Update mode
30/11/2023	navkc1 ChangeRequest 58254 Task 58255: UI - New Permission
*/

vars
	realCOO 		 : CM_OwnershipChange;
	cmifOwnershipDtl : CMIF_OwnershipChangeDetail;
	theReturn        : Integer;
begin
	if self.mode &lt;&gt; Cargo_Review_Mode then
		return;
	endif;

	create cmifOwnershipDtl transient;
	self.allProxyDetailsForCreate.copy(cmifOwnershipDtl.allPxyOwnershipChangeDetails);
	
	while true do
		app.myTrxCA.trxCreateOwnershipChangeAndDtl(_pxyCOO, realCOO,cmifOwnershipDtl, app.myPassport);
		if app.myPassport.trxCompletedOK then
			self.clearErrorWarnings();
			app.msgBox(app.getErrorString(Ownersh_change_created_sucessf), app.getErrorString(Message),MsgBox_OK_Only);
			self.myOwnershipChange := realCOO;
			if self.myOwnershipChange &lt;&gt; null  then
				self.btnAddItems.enabled := true;
				self.btnRemove.enabled := true;
				self.btnUpdate.enabled := true;
				self.btnAttachment.enabled := true;
				self.btnInvoiceIssus.enabled := true;
				//30/11/2023	navkc1 ChangeRequest 58254 Task 58255
				self.btnApprove.enabled := app.myCurrentUserCan(self.myTerminal, PmInvOwnershipChangeApprove);
				self.btnAudits.enabled := true;
				self.btnSaveDetails.enabled := true; // ### TFS CR 64164 TASK 64179 27MAY2024 NAVAB1

				//self.txtFilCOODetail.enabled := true; //25/06/2024	navkc1 CR 64823 Task 64824
			endif;
			self.updateMode := true;
			self.mode := ""; // not cargo review mode any more
			self.allProxyDetailsForCreate.clear(); // this has proxies if we came from the cargo review screen.
			self.allSubProxyDetails.purge(); // ### TFS BUG 64115 13MAY2024 NAVAB1
			delete self.myProxyOwnershipChange; // ### TFS BUG 64115 13MAY2024 NAVAB1
			self.displayHeader();
			self.displayDetails();
			self.startNotifications();
			break;
		else
			theReturn := app.showErrorWarningDialog(app.getErrorString(Ownersh_change_create), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);
		endif;
		break;
	endwhile;
epilog

end;</source>
        <Parameter name="_pxyCOO" type="CM_OwnershipChange" usage="input"/>
    </JadeMethod>
    <JadeMethod name="createPxyDetailForUpdate" id="8550a5eb-b9a6-4f38-bb0e-680e71e50f5e">
        <source>createPxyDetailForUpdate();
/*
Purpose:			

Date		Who		Reason
27 May 2024	navab1	// ### TFS CR 64164 TASK 64180 27MAY2024 NAVAB1
*/

vars
	row, col : Integer;
	includeIt : Boolean;
	realDtl, pxyDtl : CM_OwnershipChangeDetail;
begin

	if self.mode &lt;&gt; self.Cargo_Review_Mode then
		self.allProxyDetailsForInclude.purge();
		foreach row in 2 to self.tblData.rows do
			realDtl := self.tblData.accessRow(row).itemObject.CM_OwnershipChangeDetail;
			if realDtl = null then
				continue;		
			endif;
			pxyDtl := app.createUpdateProxy(realDtl).CM_OwnershipChangeDetail;
			
			col := self.tblData.getColumnByRowName(ETRow_Include);
			if col &gt; 0 then
				self.tblData.accessCell(row,col);
				includeIt := self.tblData.accessedCell.text = true.cnEcGetTableCheckBoxValue;
			else
				includeIt := self.chkSelectAll.value; // ### TFS BUG 64841 26JUN2024 NAVAB1
			endif;
			pxyDtl.setInclude(includeIt);
			
			self.allProxyDetailsForInclude.add(pxyDtl);
		endforeach;
		
		self.updateOwnershipChangeDetails();
	else
		foreach row in 2 to self.tblData.rows do
			pxyDtl := self.tblData.accessRow(row).itemObject.CM_OwnershipChangeDetail;
			if pxyDtl = null then
				continue;		
			endif;
			col := self.tblData.getColumnByRowName(ETRow_Include);
			if col &gt; 0 then
				self.tblData.accessCell(row,col);
				includeIt := self.tblData.accessedCell.text = true.cnEcGetTableCheckBoxValue;
			else
				includeIt := self.chkSelectAll.value; // ### TFS BUG 64841 26JUN2024 NAVAB1
			endif;
			
			pxyDtl.setInclude(includeIt);
		endforeach;
	endif;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="createPxyDetails" id="d0d2485f-b740-469d-a947-ac2e38f70a15">
        <source>createPxyDetails();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 July 2023 navmv20 CR 58239 Task 58241: UI- Open COO Maint in Update mode
11 August 2023 navmv20 Bug 59697: EUP - Change of Ownership Cargo Review - Able to create COO for Offsite Cargo
*/

vars
	ti, subTI         : CM_TrackedItem;
	cgti : CM_CargoGroup;
	pxyOwnershipDetail, subPxyDetail : CM_OwnershipChangeDetail;
	myTrackedItem : CM_TrackedItem;
	storageDetail : CM_StorageDetail;
	totalWeight,
	totalVolume : Decimal[14,4]; //11/08/2023 navmv20 Bug 59697
	totalQuantity : Integer; //11/08/2023 navmv20 Bug 59697
begin
		
	foreach ti in self.allTiSet do
		create pxyOwnershipDetail transient;
		//11/08/2023 navmv20 Bug 59697 - start
		totalWeight := ti.getOnSiteOnShipWeight();
		totalVolume := ti.getOnSiteOnShipVolume();
		totalQuantity := ti.getOnSiteOnShipQuantity();
		
		//pxyOwnershipDetail.setProxy(ti.totalWeight,ti.totalVolume,ti.totalQuantity,true,self.myOwnershipChange,null,ti);
		pxyOwnershipDetail.setProxy(totalWeight,totalVolume,totalQuantity,true,self.myOwnershipChange,null,ti);
		//11/08/2023 navmv20 Bug 59697 - end
		self.allProxyDetailsForCreate.add(pxyOwnershipDetail);
		tblData.addObject(pxyOwnershipDetail);
		
		
		// ### TFS BUG 64115 13MAY2024 NAVAB1
		if ti.isCargoGroupItem then
			cgti := ti.CM_CargoGroup;
			foreach subTI in cgti.allAssignedTrackedItems discreteLock do
			
				create subPxyDetail transient;
				totalWeight := subTI.totalWeight;
				totalVolume := subTI.totalVolume;
				totalQuantity := subTI.totalQuantity;
				
				subPxyDetail.setProxy(totalWeight,totalVolume,totalQuantity,true,null,pxyOwnershipDetail, subTI);		
				self.allSubProxyDetails.add(subPxyDetail);
			
			endforeach;
		endif;
		
	endforeach;
		
	ti := self.allTiSet.first;
	self.cmbCurrentOperator.listIndex :=self.cmbCurrentOperator.findStringExact(1, ti.operatorDescription);
	self.cmbCurrentOperator.enabled := false;
	
	self.getFreeStorageForOldOperator();
	self.getFreeStoExpForOldOperator();//20/05/2024	navkc1 Bug 64186
	self.getFreeStoExpForOriOperator();//20/05/2024	navkc1 Bug 64186
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="createPxyOwnershipChange" id="a312d1aa-d7a7-4a31-bd97-7c77aa7dbf56">
        <updating/>
        <source>createPxyOwnershipChange()updating;
/*
Purpose - 	
Who - NAVAB1
Date - 13MAY2024
ADO -  BUG 64115
*/

vars
	terminal				: CM_Terminal;
	newOperator,storageCgargeOpe,currentOperator : CM_Operator;
	incoterm : CM_InvoiceINCOTerm;
	frightForward	: CM_ConsigneeConsignor;
	refNumber,remarks,condition : String;
	addFreeDays : Integer;
	scheduleTSstart 		: TimeStamp;
	invoiceContract : CM_InvoiceContract;					//navra1 - TFS 64874 - 14th Aug 2024
begin
	self.mousePointer := Window.MousePointer_HourGlass;
		
	delete self.myProxyOwnershipChange;
		
	if self.cmbNewOperator.listIndex &lt;&gt; -1 then
		newOperator := self.cmbNewOperator.itemObject[self.cmbNewOperator.listIndex].CM_Operator;
	endif;
	
	if self.cmbCurrentOperator.listIndex &lt;&gt; -1 then
		currentOperator := self.cmbCurrentOperator.itemObject[self.cmbCurrentOperator.listIndex].CM_Operator;
	endif;
	
	if self.cmbIncoTerm.listIndex &lt;&gt; -1 then
		incoterm := self.cmbIncoTerm.itemObject[self.cmbIncoTerm.listIndex].CM_InvoiceINCOTerm;
	endif;
	
	if self.cmbFrightForwarder.listIndex &lt;&gt; -1 then
		frightForward := self.cmbFrightForwarder.itemObject[self.cmbFrightForwarder.listIndex].CM_ConsigneeConsignor;
	endif;
	
	if self.cmbStorageOperator.listIndex &lt;&gt; -1 then
		storageCgargeOpe := self.cmbStorageOperator.itemObject[self.cmbStorageOperator.listIndex].CM_Operator;
	endif;
	
	if self.txtRefNumber &lt;&gt; null then
		refNumber := self.txtRefNumber.text.String;
	endif;
	scheduleTSstart.setDate(self.mskCOOFromStart.text.asDateJMT());
	scheduleTSstart.setTime(self.mskCOOFromStartTime.text.asTimeJMT());
	addFreeDays := self.txtAddFreeDaysNew.text.Integer;
	
	if self.txtRemarks &lt;&gt; null then
		remarks := self.txtRemarks.text.String;
	endif;
	
	if self.txtCondition &lt;&gt; null then
		condition := self.txtCondition.text.String;
	endif;
	terminal := self.getMyTerminal;
	
	if self.cmbInvoiceContract.listIndex &lt;&gt; -1 then																			//navra1 - TFS 64874 - 14th Aug 2024
		invoiceContract := self.cmbInvoiceContract.itemObject[self.cmbInvoiceContract.listIndex].CM_InvoiceContract;		//navra1 - TFS 64874 - 14th Aug 2024
	endif;																													//navra1 - TFS 64874 - 14th Aug 2024
	
	create self.myProxyOwnershipChange transient;
	self.myProxyOwnershipChange.setProxy(refNumber , null,condition,app.getMyUserCode(),self.localToSystemTime(scheduleTSstart),null,null,null,addFreeDays, null, // ### TFS CR 58263 TASK 58264 30JAN2024 NAVAB1
																			null,null,null,remarks,frightForward,incoterm,newOperator,currentOperator,null,storageCgargeOpe,null,terminal, invoiceContract); //navra1 - TFS 64874 - 14th Aug 2024
epilog
	self.mousePointer := Window.MousePointer_Default;

end;</source>
    </JadeMethod>
    <JadeMethod name="displayDetails" id="962f61c8-c876-46c1-a0e1-65a4b0750123">
        <source>displayDetails();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 July 2023 navtnr20	TFS CR 58233	Task 58235: UI - Change of Ownership Maint
19 July 2023 navmv20 CR 58239 Task 58241: UI- Open COO Maint in Update mode
07 August 2023 navmv20 CR 59391 Task 59392: COO Maint Show Sub Details
*/

vars
	tbl					: CM_DataTable;
	idx					: Integer;
	str 				: String;
	ownershipChangeDetail,
	subDetail			: CM_OwnershipChangeDetail; //07/08/2023 navmv20 CR 59391 Task 59392
	theDataLine : String;
begin
	tbl := self.tblData;
	tbl.rows := tbl.fixedRows;
	if self.myOwnershipChange &lt;&gt; null then //19/07/2023 navmv20 CR 58239 Task 58241
		foreach ownershipChangeDetail in self.myOwnershipChange.allDetails do
			str := ownershipChangeDetail.getAttributeStringForDefArray(tbl.allTblDataEntRows);
			idx := tbl.addItem(str);
			tbl.accessRow(idx).itemObject := ownershipChangeDetail;
			
			//07/08/2023 navmv20 CR 59391 Task 59392 - start
			tbl.accessRow(idx).backColor := ColourBlue;
			if self.chkShowSubDtls.value then
				foreach subDetail in ownershipChangeDetail.allSubDetails do
					str := subDetail.getAttributeStringForDefArray(tbl.allTblDataEntRows);
					idx := tbl.addItem(str);
					tbl.accessRow(idx).itemObject := subDetail;
					tbl.accessRow(idx).enabled := false;
				endforeach;
			endif;
			//07/08/2023 navmv20 CR 59391 Task 59392 - end
		endforeach;
	//19/07/2023 navmv20 CR 58239 Task 58241 - start
	elseif self.allProxyDetailsForCreate.isNotEmpty and not self.updateMode then
		foreach ownershipChangeDetail in allProxyDetailsForCreate do
			str := ownershipChangeDetail.getAttributeStringForDefArray(tbl.allTblDataEntRows);
			idx := tbl.addItem(str);
			tbl.accessRow(idx).itemObject := ownershipChangeDetail;
			tbl.accessRow(idx).backColor := ColourBlue; //07/08/2023 navmv20 CR 59391 Task 59392
		endforeach;
	endif;
	//19/07/2023 navmv20 CR 58239 Task 58241 - end
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="displayHeader" id="f54207ae-3eef-48dc-8960-a4a2274fb1f3">
        <source>displayHeader();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 July 2023 navtnr20	TFS CR 58233	Task 58235: UI - Change of Ownership Maint
19 July 2023 navmv20 CR 58239 Task 58241: UI- Open COO Maint in Update mode
*/

vars
	localTS,storageEXp : TimeStamp;
	myOwnershipDetail : CM_OwnershipChangeDetail;
	myTrackedItem, pxyTi : CM_TrackedItem;
	storageDetail : CM_StorageDetail;
begin
	self.txtRefNumber.text	:= self.myOwnershipChange.refNumber;
	localTS := self.systemToLocalTime(self.myOwnershipChange.dateTimeCOO);
	self.mskCOOFromStart.setDate(localTS.date);
	self.mskCOOFromStartTime.setTime(localTS.time);
	storageEXp	:= self.systemToLocalTime(self.myOwnershipChange.storageExpiryOperatorNew);
	self.displayFreeStorageExpiry.caption := storageEXp.date.asStringJMT;
	self.txtAddFreeDaysNew.text	:= self.myOwnershipChange.freeDaysOperatorNew.String; // ### TFS CR 58263 TASK 58264 20FEB2024 NAVAB1
	self.cmbNewOperator.listObject 	:= self.myOwnershipChange.myOperatorNew;
	self.txtRemarks.text		:= self.myOwnershipChange.remarks;
	self.cmbIncoTerm.listObject	:= self.myOwnershipChange.myIncoterm;
	self.txtCondition.text		:= self.myOwnershipChange.condition;
	if self.cmbFrightForwarder.findObject(self.myOwnershipChange.myFreightForwarder) &gt; 0 then
		self.cmbFrightForwarder.listObject	:= self.myOwnershipChange.myFreightForwarder;
	endif;
	if self.cmbStorageOperator.findObject(self.myOwnershipChange.myOperatorStorage) &gt; 0 then
		self.cmbStorageOperator.listObject	:= self.myOwnershipChange.myOperatorStorage;
	else
	endif;
	self.cmbCurrentOperator.listObject 	:= self.myOwnershipChange.myOperatorOld;

	self.getFreeStorageForNewOperator(); //19/07/2023 navmv20 CR 58239 Task 58241
	self.getFreeStorageForOldOperator(); //19/07/2023 navmv20 CR 58239 Task 58241
	self.getFreeStoExpForOldOperator(); //20/05/2024	navkc1 Bug 64186
	self.getFreeStoExpForOriOperator();//20/05/2024	navkc1 Bug 64186
epilog
	delete pxyTi;
end;</source>
    </JadeMethod>
    <JadeMethod name="displayStatus" id="6eb84694-36f9-4387-bf34-8837aa2a763b">
        <source>displayStatus();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 July 2023 navtnr20	TFS CR 58233	Task 58235: UI - Change of Ownership Maint
09 August 2023 navmv20 CR 59391 Task 59417: COO Maint Include Changes
14 September 2023 navmv20 Bug 60217: EUP - COO - Release Request - Message not displaying weight as per measurement type displayed
*/

vars
	ownershipChangeDetail : CM_OwnershipChangeDetail;
	col, row , quantity,transferedQuantity : Integer;
	weight, volume,transferedweight, transferedvolume : Decimal [23,4];
	ownershipChangeDetailSet : CM_OwnershipChangeDetailSet; //09/08/2023 navmv20 CR 59391 Task 59417
	weightStr, volumeStr, transferedWeightStr, transferedVolumeStr : String; //14/09/2023 navmv20 Bug 60217
begin
	
	//09/08/2023 navmv20 CR 59391 Task 59417 - start
	/*col := tblData.getColumnByHeading(ETRow_Include);
	foreach row in 2 to self.tblData.rows do
	
		tblData.accessRow(row);
		ownershipChangeDetail := tblData.accessedRow.itemObject.CM_OwnershipChangeDetail;
		tblData.accessCell(row,col);*/
	//if tblData.accessedCell.text = true.cnEcGetTableCheckBoxValue then
	if self.allProxyDetailsForInclude.isNotEmpty and self.updateMode then // ### TFS CR 64164 TASK 64180 27MAY2024 NAVAB1
		ownershipChangeDetailSet := self.allProxyDetailsForInclude ;// ### TFS CR 59614 TASK 59619 11AUG2023 NAVAB1
	elseif self.myOwnershipChange &lt;&gt; null then 
		ownershipChangeDetailSet := self.myOwnershipChange.allDetails;
	elseif self.allProxyDetailsForCreate.isNotEmpty and not self.updateMode then
		ownershipChangeDetailSet := self.allProxyDetailsForCreate ;
	endif;
	
	if ownershipChangeDetailSet &lt;&gt; null then // ### TFS CR 64164 TASK 64180 27MAY2024 NAVAB1
		foreach ownershipChangeDetail in ownershipChangeDetailSet do
			if ownershipChangeDetail.myTrackedItem &lt;&gt; null and ownershipChangeDetail.included then
		//09/08/2023 navmv20 CR 59391 Task 59417 - end
				quantity := quantity + ownershipChangeDetail.myTrackedItem.totalQuantity;
				weight 	:= weight	 + ownershipChangeDetail.myTrackedItem.totalWeight;
				volume  := volume 	+ 	ownershipChangeDetail.myTrackedItem.totalVolume;
				transferedQuantity := transferedQuantity + ownershipChangeDetail.transferredQuantity;
				transferedweight 	:= transferedweight	 + ownershipChangeDetail.transferredWeight;
				transferedvolume  := transferedvolume 	+ 	ownershipChangeDetail.transferredVolume;
			endif;
		endforeach;
	endif;

	//14/09/2023 navmv20 Bug 60217 - start
	//weightStr := app.getWeightForDefaultDisplay(weight);
	weightStr := app.convertMeasurementForDisplay(self.myMeasurementTypeForWeight.shortName, weight) &amp; " " &amp; self.myMeasurementTypeForWeight.shortName; //27/01/2025	navkc1 JIRA Bug MTN-33535
	//volumeStr := app.getVolumeForDefaultDisplay(volume);
	volumeStr := app.convertMeasurementForDisplay(self.myMeasurementTypeForVolume.shortName, volume) &amp; " " &amp; self.myMeasurementTypeForVolume.shortName; //27/01/2025	navkc1 JIRA Bug MTN-33535
	//transferedWeightStr := app.getWeightForDefaultDisplay(transferedweight);
	transferedWeightStr := app.convertMeasurementForDisplay(self.myMeasurementTypeForWeight.shortName, transferedweight) &amp; " " &amp; self.myMeasurementTypeForWeight.shortName; //27/01/2025	navkc1 JIRA Bug MTN-33535
	//transferedVolumeStr := app.getVolumeForDefaultDisplay(transferedvolume);
	transferedVolumeStr := app.convertMeasurementForDisplay(self.myMeasurementTypeForVolume.shortName, transferedvolume) &amp; " " &amp; self.myMeasurementTypeForVolume.shortName; //27/01/2025	navkc1 JIRA Bug MTN-33535
	//14/09/2023 navmv20 Bug 60217 - end
	
	
	//14/09/2023 navmv20 Bug 60217 - start
	/*self.statusBar.caption :=  " Current Quantity " &amp; quantity.String 
		&amp;" Current Weight "&amp; weight.String &amp; " Current Volume "&amp; volume.String &amp;" | "&amp; " Transfer Quantity " &amp;transferedQuantity.String 
		&amp;" Transfer Weight "&amp; transferedweight.String &amp; " Transfer Volume "&amp;transferedvolume.String;*/
	self.statusBar.caption :=  " Current Quantity " &amp; quantity.asStringJMT() &amp;
		" Current Weight " &amp; weightStr &amp; 
		" Current Volume "&amp; volumeStr &amp; " | " &amp; 
		" Transfer Quantity " &amp;transferedQuantity.asStringJMT() &amp;
		" Transfer Weight "&amp; transferedWeightStr &amp; 
		" Transfer Volume "&amp;transferedVolumeStr;
	//14/09/2023 navmv20 Bug 60217 - end
		
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doApprove" id="f0bd461b-a0e8-4e1d-95cb-2b05fe88a061">
        <source>doApprove(_reapproval : Boolean);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30/11/2023	navkc1 ChangeRequest 58254 Task 61099: UI - Ownership Change Approved

*/

vars
	ownership		: CM_OwnershipChange;
	theReturn		: Integer;
	approvalDialog	: CMUI_COOApproveDialog;
	cmifAgent		: CMIF_COOAgent;
begin
	create cmifAgent transient;
	
	ownership := self.myOwnershipChange;
	ownership.doCreateCMIFAgent(cmifAgent); // ### JIRA 19351 30SEP2024 NAVAB1
	cmifAgent.reapproval := _reapproval; // ### JIRA 33015 04OCT2024 NAVAB1
	
	if not _reapproval then // ### JIRA 19351 30SEP2024 NAVAB1
		if ownership = null then
			app.msgBox(app.getErrorString(Record_selected), app.getErrorString(Warning),MsgBox_OK_Only);
			return;
		endif;
		
		if app.msgBox(app.getErrorString(Confir_approv_select_owners_ch), "Confirm?", MsgBox_Yes_No + MsgBox_Question_Mark_Icon) = MsgBox_Return_No then
			return;
		endif;
		
// ### JIRA 19351 30SEP2024 NAVAB1		ownership.doCreateCMIFAgent(cmifAgent);
		
		if cmifAgent.hasCargoToBeSplitted() then
			create approvalDialog transient;
			approvalDialog.myParentForm := self;
			approvalDialog.setMyTerminal(self.myTerminal);
			approvalDialog.myCmifCooAgent := cmifAgent;
			approvalDialog.showModal();
			
			if self.dialogFailed then
				return;
			endif;	
		endif;
	endif;
	
	while true do
		app.myTrxUA.trxUpdateOwnershipChangeApprov(ownership, app.myPassport, cmifAgent);
		if app.myPassport.trxCompletedOK then
			if not _reapproval then // ### JIRA 19351 30SEP2024 NAVAB1
				global.beep;
				app.msgBox(app.getErrorString(Ownersh_change_approve_success), app.getErrorString(Message),MsgBox_OK_Only);
			endif;
			self.doPermissions();
			break;
		else
			theReturn := app.showErrorWarningDialog(app.getErrorString(Ownership_change_approve), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
				  theReturn = IDOK then
				  app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			return;
		endif;
		
		break;
	endwhile;
	
epilog
	delete cmifAgent;
end;</source>
        <Parameter name="_reapproval" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doAttachment" id="8df98527-4828-41ec-8b0d-117ffc1f541b">
        <source>doAttachment();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 July 2023 navtnr20	TFS CR 58233	Task 58237: UI - COO Attachments
*/

vars
	form : CMUI_FileAttachmentsFormModal;
begin

	form := app.loadForm(CMUI_FileAttachmentsFormModal, CMUI_Assistant, false, false, false, self.myTerminal, self.myMasterMenuAction).CMUI_FileAttachmentsFormModal;
	if form = null then
		return;
	endif;
	
	form.setMyParent(self.myOwnershipChange);
	
	form.showModal;
end;</source>
    </JadeMethod>
    <JadeMethod name="doBtnInvoiceIssueClick" id="68f720f0-87ee-4417-85e6-60cba661e270">
        <source>doBtnInvoiceIssueClick();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08/12/2023	navkc1 ChangeRequest 58261 Task 58260: Jade - COO Invoice Issues Send Email

*/

vars
	invoiceForm 	: CM_BaseForm;
	menuAction 		: CMUI_MenuAction;
	invoiceLines 	: CM_InvoiceLineBySeqNumDict;
	ownership		: CM_OwnershipChange;
	cooFinancial	: CM_OwnershipChangeFinancial;
begin
	
	create invoiceLines transient;
	
	ownership := self.myOwnershipChange;
	
	if ownership = null then
		return;
	endif;
	
	foreach cooFinancial in ownership.allFinancialIssues do
		invoiceLines.add(cooFinancial.myInvoiceLine);
	endforeach;
	
	if invoiceLines.isEmpty() then
		app.msgBox(app.getErrorString(NoInvIssuesInCoo), app.getErrorString(Warning),MsgBox_OK_Only);
		return;
	endif;
	
	menuAction := app.myController.createMenuAction(PmAdmInvoicelinesView, null, null, self.myTerminal);
	if menuAction = null then
		return;
	endif;
	
	invoiceForm := menuAction.goToObject(null, null, false, null);
	if invoiceForm = null then
		return;
	endif;
	
	invoiceForm.sendMsgWithParams("populateInvLinesCollection", invoiceLines);
	invoiceForm.show(); 
	
epilog
	delete invoiceLines;
end;</source>
    </JadeMethod>
    <JadeMethod name="doBtnRemove" id="eb6e7efe-b329-4fc4-b1b0-ca2260a24a43">
        <updating/>
        <source>doBtnRemove() updating;
/*
Purpose:			

Date		Who		Reason
21 July 2023	navab1	 CR 58246 TASK 59242 
*/

vars
	theReturn : Integer;
	ownership : CM_OwnershipChangeDetail;
begin
	// ### TFS BUG 59640 03AUG2023 NAVAB1 - check is selected
	if  self.tblData.row &lt;=  self.tblData.fixedRows then
		return;
	endif;
	
	if self.tblData.accessRow( self.tblData.row).selected then
		ownership := self.tblData.accessedRow.itemObject.CM_OwnershipChangeDetail;
	endif;
	
	if ownership = null then
		app.msgBox(app.getErrorString(Record_selected), app.getErrorString(Warning),MsgBox_OK_Only);
		return;
	endif;
	if ownership &lt;&gt; null then
		while true do
			app.myTrxDA.trxDeleteOwnershipChangeDetail(ownership, app.myPassport);
			if app.myPassport.trxCompletedOK then
				// Clear errors/warnings from form and err/warnings window
				self.clearErrorWarnings();
				global.beep;
				break;
			else
				theReturn := app.showErrorWarningDialog("COO Detail", app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
				if app.myPassport.noErrors and
				   theReturn = IDOK then
					// there must have just been warnings that the user has acknoledged so ..
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
				self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
				return;
			endif;
			break;
		endwhile;

	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doBtnUpdate" id="ddce6faa-ef48-4017-a5d4-3d35bdda97f2">
        <updating/>
        <source>doBtnUpdate() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 August 2023	navmv20	CR 59391 Task 59392: COO Maint Show Sub Details

*/

vars
	form : CMUI_OwnershipChangeDetail;
	bank :CM_Bank;
	ownership : CM_OwnershipChangeDetail;
	ti : CM_TrackedItem;
	ct : CM_CargoType;
begin

	self.allProxyDetailsForInclude.purge(); // ### TFS CR 64164 TASK 64179 27MAY2024 NAVAB1 - use this for 'include' TRX update, however if going to detail UI need to get rid of the update proxies.

	ownership := self.tblData.accessRow(self.tblData.row).itemObject.CM_OwnershipChangeDetail;
	if ownership = null then
		app.msgBox(app.getErrorString(Record_selected), app.getErrorString(Warning),MsgBox_OK_Only);
		return;
	endif;
	
	if ownership &lt;&gt; null then
		// ### TFS CR 58230 TASK 58231 26JUL2023 NAVAB1
		ti := ownership.myTrackedItem;
		if not ti.isCargoGroupItem then
			ct := ti.myCargoType;
			if not ct.allowDuplicates then
				app.msgBox(app.getErrorString(This_cargo_item_not_split_need), app.getErrorString(Warning),MsgBox_OK_Only);
				return;
			endif;
		endif;
		
		form := app.loadForm(CMUI_OwnershipChangeDetail, CMUI_Assistant, false, false,false, self.myTerminal,null).CMUI_OwnershipChangeDetail;
		
		// ### TFS BUG 64115 13MAY2024 NAVAB1
		if self.mode = self.Cargo_Review_Mode then
			if form &lt;&gt; null then
				form.updateMode := false;
				form.setProxyForCargoReview(ownership);
				form.setMyOwnershipChange(self.myProxyOwnershipChange);
				if ownership.myOwnershipChange = null then
					ownership.setOwnershipChange(self.myProxyOwnershipChange);
				endif;
				ownership.allSubDetails.copy(form.detailsSet);
			endif;
		else
			if form &lt;&gt; null then
				form.updateMode := true;
				form.setMyCOODetail(ownership);
				form.setMyOwnershipChange(self.myOwnershipChange);
//				form.show(); // ### TFS BUG 64115 13MAY2024 NAVAB1  showModal;
			endif;
		endif;
		if form &lt;&gt; null then
			self.myDetailForm := form; // ### TFS BUG 64115 13MAY2024 NAVAB1
			form.myMaintForm := self; // ### TFS BUG 64115 13MAY2024 NAVAB1
			form.centreWindow();
			form.show(); // ### TFS BUG 64115 13MAY2024 NAVAB1  showModal;
			
			/*
			if self.mode = self.Cargo_Review_Mode then
				self.resetCOOTransferredAmounts(ownership);
				self.displayDetails();
				self.displayStatus();
			endif;
			*/
		endif;
	endif;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doCmbCurrentOperator" id="b18ee13d-b98f-444a-adce-c3e800ab6064">
        <source>doCmbCurrentOperator();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 July 2023 navtnr20	TFS CR 58233	Task 58235: UI - Change of Ownership Maint
*/

vars
	operator : CM_Operator;
begin
	foreach operator in app.myRoot.allOperators do
		if not operator.isNotAvailableForEntry then
            cmbCurrentOperator.addItemObject(operator.code &amp;  Tab &amp; operator.description, operator);// ### TFS BUG 59634 03AUG2023 NAVAB1
        endif;
    endforeach;
	if self.myOwnershipChange &lt;&gt; null then
		operator := self.myOwnershipChange.myOperatorOld;
		if operator &lt;&gt; null
		and self.cmbCurrentOperator.findObject(operator) &lt; 0 then
            cmbCurrentOperator.addItemObject(operator.code &amp;  Tab &amp; operator.description, operator);// ### TFS BUG 59634 03AUG2023 NAVAB1
		
		endif;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doCmbFreightFwdr" id="ef6e3447-0d49-4353-aefa-92cb3ad5bf42">
        <source>doCmbFreightFwdr();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 July 2023 navtnr20	TFS CR 58233	Task 58235: UI - Change of Ownership Maint
*/

vars
	consign : CM_ConsigneeConsignor;
begin
	foreach consign in app.myRoot.allConsigneeConsignors do
		if not consign.isNotAvailableForEntry then
			if consign.isFreightFwdr then
				cmbFrightForwarder.addItemObject(consign.code &amp;  Tab &amp; consign.description, consign);// ### TFS BUG 59634 03AUG2023 NAVAB1
			endif;
		endif;
	endforeach;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doCmbIncoTerm" id="5d4f1fe1-c488-460d-a0ea-65d2dbd2dceb">
        <source>doCmbIncoTerm();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason

06 July 2023 navtnr20	TFS CR 58233	Task 58235: UI - Change of Ownership Maint
*/

vars
	incoTerm : CM_InvoiceINCOTerm;
	bank : CM_Bank;
begin
	bank 	:= self.myTerminal.getDefaultCompanyBank;
	self.cmbIncoTerm.clear;	
	foreach incoTerm in bank.allInvoiceINCOTerms do
		self.cmbIncoTerm.addItem(incoTerm.code &amp; Tab &amp; incoTerm.description);// ### TFS BUG 59634 03AUG2023 NAVAB1
		self.cmbIncoTerm.itemObject[self.cmbIncoTerm.newIndex] := incoTerm;
	endforeach;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doCmbNewOpDebtorInvContracts" id="bdf7372d-e92b-4c45-b157-72e50a2ca1cc">
        <source>doCmbNewOpDebtorInvContracts();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 August 2024	navra1	Initial creation for //navra1 - TFS 64874 - 14th Aug 2024
30 August 2024	navra1	BUG 65896 - EUP - Ownership Change Contract Remove Message/DEFECT 65800 - EUP - Ownership Change Enquiry - Invoice Contract warning erroneously coming up

*/

vars	
	newOperator : CM_Operator;
	debtorInvoiceContracts : CM_InvContractByBankIdDict;
	invoiceContract : CM_InvoiceContract;	
	invoiceContractListIdx : Integer;
begin	
	self.cmbInvoiceContract.clear();
	if self.myOwnershipChange &lt;&gt; null then
		newOperator := self.myOwnershipChange.myOperatorNew;
		if newOperator &lt;&gt; null and newOperator.debtor &lt;&gt; null then
			debtorInvoiceContracts  := newOperator.debtor.allInvoiceContracts;
			foreach invoiceContract in debtorInvoiceContracts where invoiceContract.myTerminal.code = self.myTerminal.code do				//navra1 - DEFECT 65798 - 29th Aug 2024
				if invoiceContract.active = true then		
					self.cmbInvoiceContract.addItemObject(invoiceContract.contractId, invoiceContract);					
				endif;
			endforeach;
			
			invoiceContractListIdx := self.cmbInvoiceContract.findObject(self.myOwnershipChange.myInvoiceContract);
		endif;
	endif;
	
	if invoiceContractListIdx &lt;&gt; null then
		self.cmbInvoiceContract.listIndex := invoiceContractListIdx;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doCmbNewOperator" id="a71be884-1934-4afd-973e-7e39a603d744">
        <source>doCmbNewOperator();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 July 2023 navtnr20	TFS CR 58233	Task 58235: UI - Change of Ownership Maint
*/

vars
	operator  : CM_Operator;
	allowSameOp: Boolean;
begin	
	foreach operator in app.myRoot.allOperators do
		if not operator.isNotAvailableForEntry then
            cmbNewOperator.addItemObject(operator.code &amp;  Tab &amp; operator.description, operator);// ### TFS BUG 59634 03AUG2023 NAVAB1
        endif;
    endforeach;
	
	if self.myOwnershipChange &lt;&gt; null then
		operator := self.myOwnershipChange.myOperatorNew;
		if operator &lt;&gt; null
		and self.cmbNewOperator.findObject(operator) &lt; 0 then
            cmbNewOperator.addItemObject(operator.code &amp;  Tab &amp; operator.description, operator);// ### TFS BUG 59634 03AUG2023 NAVAB1
		
		endif;
	endif;
epilog

end;</source>
    </JadeMethod>
