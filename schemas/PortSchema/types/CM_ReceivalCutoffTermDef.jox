    <JadeMethod name="getDisplayStringForAttribute" id="0f8ad47e-a990-45f4-ac1d-176334bb6ddf">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;

/*
Date		Who		Reason
22 May 2009	cnwar2	Initial creation
28/02/2012	cnwcs5	par 29158 - EDI Booking Cutoffs
17/03/2012	cnwcs5	par 29257 - conversion of extension object properties
*/
vars
	text, str	: String;
	criteria	: CM_ReceivalCutoffCriteria;
	array		: IntegerArray;
	int			: Integer;
	agent		: CM_EDIControllerAgent;
begin
	if _attrName = ETRow_Criteria or _attrName = ETRow_CriteriaDblClick then
		if self.isCARGOType then	// par 29158 - Feb 2012
			foreach criteria in self.allCriteria do
				text := text &amp; criteria.getListDisplay &amp; " ";
			endforeach;
		elseif self.isEDIType then		// par 29158 - Feb 2012
			array := allEDIDataTypes;	// par 29257 - march 2012
			
			create agent transient;
			
			foreach int in array do
				if int = EDIDataType_All then
					text := text &amp; app.getErrorString (CM_LIT_ALL) &amp; " ";
				else
					text := text &amp; agent.getEDIDisplayStrForType (int) &amp; " ";
				endif;
			endforeach;
		endif;
		
		return text;
	elseif _attrName = ETRow_CriteriaType then
		return self.getCriteriaTypeDesc;
		
	elseif _attrName = ETRow_DefaultRelativeTo then
		return app.defRelativeToEnumToString(self.defaultRelativeTo);
	elseif _attrName = ETRow_DefaultCutoffPN then // 28/03/2025	navkc1	JIRA Defect Sub-task MTN-34498
		return self.defaultCutoffPN.asStringJMT();
	elseif _attrName = ETRow_DefaultEarliestReceivePN then	// 28/03/2025	navkc1	JIRA Defect Sub-task MTN-34498
		return self.defaultEarliestReceivalPN.asStringJMT();
	endif; 

	return inheritMethod(_attrName, _short);
epilog
	delete agent;
end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="isCARGOType" id="0f5c57b2-e548-43c0-bc13-94b9d2bf83e3">
