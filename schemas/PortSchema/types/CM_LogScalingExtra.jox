<Class name="CM_LogScalingExtra" id="042d9c3e-f718-488a-8dc9-d3c3840dadf2">
    <superclass name="CM_LogScalingData"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="bol"/>
    <ExplicitInverseRef name="myLogScalingHdr" id="6e46b4e8-97bc-4ee6-bbda-6d7ba1fc7ce6">
        <kind>child</kind>
        <transientToPersistentAllowed/>
        <updateMode>manual</updateMode>
        <embedded/>
        <type name="CM_LogScalingHdr"/>
        <access>readonly</access>
        <Inverse name="CM_LogScalingHdr::allLogScalingExtra"/>
    </ExplicitInverseRef>
    <PrimAttribute name="scalerCode" id="55b712bd-5ab4-4b84-8675-e77f273c314c">
        <length>11</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="scalingFinishTime" id="19fbeac4-1650-4e3d-9fd5-8eab0114214f">
        <embedded/>
        <type name="TimeStamp"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="scalingStartTime" id="9cd46a12-b62a-44eb-b0ff-56bfbb683efe">
        <embedded/>
        <type name="TimeStamp"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="setForCreate" id="0659a053-6b86-468b-ad7c-df8f614c8cc0">
        <updating/>
        <source>setForCreate(_pxyLogScalingExtra : CM_LogScalingExtra; _hdr : CM_LogScalingHdr) updating;

// cnwdvb1 11 June 2003 

vars

begin

	self.setForUpdate(_pxyLogScalingExtra);
	self.myLogScalingHdr	:= _hdr;

end;</source>
        <Parameter name="_pxyLogScalingExtra" type="CM_LogScalingExtra"/>
        <Parameter name="_hdr" type="CM_LogScalingHdr"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="d7c7e10f-e748-408d-a282-e509d93718ab">
        <updating/>
        <source>setForUpdate(_pxyLogScalingExtra : CM_LogScalingExtra) updating;

// cnwdvb1 11 June 2003 

vars

begin

	self.scalerCode			:= _pxyLogScalingExtra.scalerCode;
	self.scalingStartTime	:= _pxyLogScalingExtra.scalingStartTime;
	self.scalingFinishTime	:= _pxyLogScalingExtra.scalingFinishTime;
	
end;</source>
        <Parameter name="_pxyLogScalingExtra" type="CM_LogScalingExtra"/>
    </JadeMethod>
    <JadeMethod name="setHdrForProxy" id="e03402ce-5d58-459d-b13b-c7130fec1336">
        <updating/>
        <source>setHdrForProxy(_hdr : CM_LogScalingHdr) updating;

// cnwdvb1 11 June 2003 

vars

begin

	self.myLogScalingHdr := _hdr;

end;</source>
        <Parameter name="_hdr" type="CM_LogScalingHdr"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="399d079b-953c-4d5f-a134-a3032a994501">
        <updating/>
        <source>setProxy(_logScalingHdr : CM_LogScalingHdr; _scalerCode : String; _startTime, _finishTime : TimeStamp) updating;

// cnwdvb1 11 June 2003 

vars

begin

	self.scalerCode 		:= _scalerCode;
	self.scalingStartTime 	:= _startTime;
	self.scalingFinishTime	:= _finishTime;
	
	self.myLogScalingHdr	:= _logScalingHdr;

end;</source>
        <Parameter name="_logScalingHdr" type="CM_LogScalingHdr"/>
        <Parameter name="_scalerCode" type="String"/>
        <Parameter name="_startTime" type="TimeStamp"/>
        <Parameter name="_finishTime" type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="validate" id="8e0ffda9-e5b2-4754-95d5-8d99cd12b72f">
        <source>validate();

// cnwdvb1 12 June 2003 

vars

begin

	if self.scalerCode = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Scaler Code', 'scalercode', null);
		app.raiseCMException(Input_required_field_scalerCod, 'scalercode', null); // cnwdb2	PAR 35364
	endif;
	
	if not self.scalingStartTime.isValid then
		app.raiseCMException1(AutoScheduleDateError, 'Scaling Start Time', 'scalingStartTime', null);
	endif;
	
	if not self.scalingFinishTime.isValid then
		app.raiseCMException1(AutoScheduleDateError, 'Scaling Finish Time', 'scalingStartTime', null);
	endif;
	
	if self.scalingFinishTime &lt; self.scalingStartTime then
		app.raiseCMException2(InvalidAttrForUpdate, 'Scaling Finish Time', 'Finish time must be after start time', null, null);
	endif;

end;</source>
    </JadeMethod>
</Class>
