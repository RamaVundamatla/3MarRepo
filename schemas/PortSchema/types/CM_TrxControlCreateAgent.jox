    <JadeMethod name="trxCreateVoyages" id="fd7d02d5-d91c-40db-93ee-25169ab5ecc3">
        <updating/>
        <source>trxCreateVoyages(_proxyVoyage:CM_VoyageSet input; _newVoyage:CM_VoyageSet output; _realVessel : CM_VesselSet input; 
_realVoyGlobal : CM_VoyageGlobalSet; _createSPS : Boolean input; _passport : CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
23 March 2023	navlw1	Initial creation TFS: 57242 create multiple voyages

*/

vars
	pxyVoyage,
	realVoyage		: CM_Voyage;
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(false);
	// Start the transaction
	beginTransaction;

	// Perform the operation
	if not _proxyVoyage.isEmpty then
		foreach pxyVoyage in _proxyVoyage do
			//Did not implement for global voyage as not needed at the moment // ### TFS 57242 22Mar2023 NAVPW1
			app.myUtilityCA.utlCreateVoyage(pxyVoyage, realVoyage, pxyVoyage.vessel, null, false, _passport);
			if _passport.noErrors and _newVoyage &lt;&gt; null then
				_newVoyage.add(realVoyage);
			endif;
		endforeach;
	endif;
epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
