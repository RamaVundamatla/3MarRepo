    <JadeMethod name="isPattern" id="70a3a40d-0e65-472f-84d2-338fd622180d">
        <source>isPattern(_pattern: CMIF_YAPattern io): Boolean;
// ---------------------------------------------------------------------------
// Created:     02 June 2009 by concms1
// Purpose:     Par 19520 - allow for null voyage
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin 
	if _pattern.pattern = NULL_VOYAGE_CODE then
		return  false;
	endif; 
	
	return inheritMethod(_pattern);

epilog

end;</source>
        <Parameter name="_pattern" type="CMIF_YAPattern" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isSnapShotDataMatch" id="26bfee78-df10-4c83-9e32-6002825653ec">
        <source>isSnapShotDataMatch(_criteria: CM_YACriteria; _yaType: Integer; _propertyValue: String): Boolean;

vars
	obj		: Object;
begin
	if _yaType &lt;&gt; self.type then
		return false;
	endif;
	
	foreach obj in _criteria.myYAData.CM_YADataObjects.allObjects do
		if obj.CM_Voyage.code = _propertyValue then
			return true;
		endif;
	endforeach;
	
	if _criteria.myYAData.isKindOf(CM_YADataPattern) and
	   _criteria.myYAData.CM_YADataPattern.pattern = null then
		return true;
	endif;
	
	return false;
end;
</source>
        <Parameter name="_criteria" type="CM_YACriteria"/>
        <Parameter name="_yaType" type="Integer"/>
        <Parameter name="_propertyValue" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
