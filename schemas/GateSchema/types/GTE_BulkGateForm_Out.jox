    <JadeMethod name="doCashOnlyValidation" id="40157341-7806-46a1-80d4-adfcc589c98e">
        <source>doCashOnlyValidation(_allProformaLines : ObjectSet input) : Boolean protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason

*/

vars
	result : Integer;
begin
	
	while true do
		//could of got warnings must clear this
		_allProformaLines.clear;
		app.myValUA.valCashCollectionForVVR(self.myBulkGateAgent.myRealVVR,true,true,_allProformaLines,app.myPassport);
		if not app.myPassport.trxCompletedOK then
			result := app.showErrorWarningDialog(app.getErrorString(Errors), app.myPassport, ErrWarnMode_AddUpdate+ ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
				result = IDOK then
				app.myPassport.warningsAcknowledged := true;
				continue;
			else
				return false;
			endif;
		endif;
		break;
	endwhile;
	
	return true;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_allProformaLines" type="ObjectSet" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doChangeGate" id="e2bae41d-e6f2-4fa6-8611-3bb02c7f5c5b">
        <source>doChangeGate(_gate: CM_Gate) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason

Everytime the gate combo is changed, we need to update the gate lanes and enable/disable gate lane combo
depending on whether or not the gate has lanes.  Might as well push all programmatic changes through this method.

*/

vars

begin
	self.cmbGate.listObject := _gate;
	self.myBulkGateAgent.setGate(_gate);
	self.onGateChange();
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_gate" type="CM_Gate"/>
    </JadeMethod>
    <JadeMethod name="doPreSaveValidation" id="fb8276a1-eb6a-4202-bc7e-8516b99c3885">
        <updating/>
        <source>doPreSaveValidation( _scaleWeight : Decimal output; _cargoWeight : Decimal output ):Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 December 2016	cnwndl1	Initial creation	TFS 2867

*/

vars

	realVVR : CM_VehicleVisitRecord;
	edition : Integer;
	invalid : Boolean;
	vehicle : CM_Vehicle;
	wle 	: CM_WorkListEntry;
	gte 	: CMGTE_Entity;
	vvrd 	: CM_VehicleVisitRecordDetail;
	cargoWeight : Decimal[16,4];  // in kilos
	arrivalWeight : Decimal[16,4];  // in kilos
	reserveDetail : CM_ReserveDetail;

begin

			
    self.myBulkGateAgent.myRealVVR := getVvrFromTable();
	
	if self.myBulkGateAgent.myRealVVR = null then
		app.raiseCMException(Invalid_vehicle_visit_record, "Null_vehicle_visit_record", null);
		return false;
	endif;
		
	if self.txtWeightOUT.getRawValue() = null then
		app.raiseCMException(Input_required_field_weight, "Weight Null", null);
		self.txtWeightOUT.setFocus;
		return false;
	endif;
	
	
	if 	self.txtWeightOUT.getConvertedValue() = 0 then	
		app.raiseCMException(Total_weight_should_not_zero, "Weight Zero", null);
		self.txtWeightOUT.setFocus;
		return false;
	endif;
	
	_scaleWeight := self.txtWeightOUT.getConvertedValue();
		
	
	on Exception do app.handleDeletedObject(exception,realVVR,invalid);
	realVVR := self.myBulkGateAgent.myRealVVR;
	if realVVR &lt;&gt; null then
		edition := realVVR.edition;
		if invalid then	
			self.clearForm();
			self.myBulkGateAgent.myPxyGTEEntity := null;
			app.raiseCMException(Invalid_Gate_Entity, "Invalid_Gate_Entity", null);
			return false;
		endif;
	else
		app.raiseCMException(Invalid_vehicle_visit_record, "Invalid_vehicle_visit_record", null);
		return false;
	endif;

	if realVVR.vehicle &lt;&gt; null then
		vehicle := realVVR.vehicle;
	else
		app.raiseCMException2(ERR_IsNotValid,app.getErrorString(Vehicle),null, "Vehicle", null);
		return false;
	endif;
	
	if vehicle.allRoadJobs.size &gt; 0 and vehicle.allRoadJobs.first.workListEntries.size &gt; 0 then
		wle :=	vehicle.allRoadJobs.first.workListEntries.first;
	else
		app.raiseCMException(Work_list_entry_ref, "Work_list_entry_ref", null);
		return false;
	endif;
	
	if realVVR.allGateEntities.size &gt; 0 then
		gte := realVVR.allGateEntities.first;
	else
		app.raiseCMException1(Truck_Has_No,app.getErrorString(Gate_entity), "Truck_Has_No,Gate_entity", null);
		return false;
	endif;
	
	vvrd := realVVR.getBulkGateIn(null);
	if vvrd &lt;&gt; null then
		arrivalWeight := vvrd.getExtraInfo_BulkGateInOrOut;
		cargoWeight :=   arrivalWeight - _scaleWeight; 	
		if cargoWeight &lt; 0 then
			_cargoWeight := cargoWeight.abs();
		else
			_cargoWeight := cargoWeight;
		endif;
	else
		app.raiseCMException1(Err_Is_Null,app.getErrorString(Vehicle_visit_record_detail),"VVRD_is_Null",null);
		return false;
	endif;
		
	if gte.isCMGTE_Receival and  arrivalWeight &lt;= _scaleWeight then
		app.raiseCMException(Exit_weigh_must_less_than_arri, "WeightTooHigh", null);
		return false;
	endif;
	
	if gte.isCMGTE_Release and arrivalWeight &gt;= _scaleWeight then
		app.raiseCMException(Exit_weigh_must_more_than_arri, "WeightTooLow", null);
		return false;
	endif;
	
	//15 Nov 2017	NDL	TFS 7820
	if gte.isCMGTE_Release then
		reserveDetail := gte.CMGTE_Release.myReserveDetail;
		if reserveDetail &lt;&gt; null then
			if reserveDetail.isBulkMulti then
				if reserveDetail.validateWeightQuantityAdd(	0, _cargoWeight, true ) &lt;&gt; null then
					return false;
				endif;
			endif;
		endif;
	elseif gte.isCMGTE_Receival then
		gte.CMGTE_Receival.validateBooking( false );
		if app.myPassport.hasErrors then
			return false;
		endif;
	endif;
	
	return true;

epilog

end;</source>
        <Parameter name="_scaleWeight" type="Decimal" usage="output"/>
        <Parameter name="_cargoWeight" type="Decimal" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doQueryUnload" id="a5b00a42-00ce-4cf1-ae29-d26992b0c625">
        <updating/>
        <source>doQueryUnload() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 April 2018	jlgns1	Initial creation
19 April 2018	jlgns1 Bug 38134: PKT - Weight Discrepancy
*/
constants
	MaxWaitTime = 5000;
vars
	endWaitTime : Decimal[20];
	maxWaitTime : Integer;
begin
    if self.myWeightInterfaceController &lt;&gt; null then
		// Need to delay the actual form close and weight interface controller delete until all pending
		// serial port communications are complete
		
		self.myWeightInterfaceController.stopListening;
		self.visible := false;
		endWaitTime := app.relativeMachineTime() + maxWaitTime;
		
		while not self.myWeightInterfaceController.isOkToDelete() do
			app.writeLog(method.qualifiedName &amp; " waiting for serial port operations to complete", LogDEBUG);	//25 Nov 2019	NDL	TFS 47053
			app.doWindowEvents(1000);
			if app.relativeMachineTime() &gt; endWaitTime then
				app.writeLog(method.qualifiedName &amp; " maximum wait time exceeded, exiting", LogDEBUG);	//25 Nov 2019	NDL	TFS 47053
				break;
			endif;
		endwhile;
	endif;
end;
</source>
    </JadeMethod>
    <JadeMethod name="doRefresh" id="212919d2-00b7-42b3-a164-60abad82537c">
        <updating/>
        <source>doRefresh() updating, protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------

vars

begin
	self.loadDataForFirstTime();
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doSave" id="4409c561-1a4f-452a-8613-7d13584986e3">
        <updating/>
        <source>doSave() : Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 December 2016	cnwndl1	Initial creation	TFS 2867
16 June 2025		navhn30	 Story MTN-35044: MTN - DeadLock Retry Required for trxProcessBulkGateOut
*/

vars

	result 			: Integer; 
	realVVR 		: CM_VehicleVisitRecord;
	
	defaultPrinterName : String;
	newScaleWeight 	: Decimal[16,4];  // in kilos
	rawScaleWeight	: Decimal[16,4];  // in kilos
	cargoWeight 	: Decimal[16,4];  // in kilos
	printCopies		: Integer;
	doPrintReciept	: Boolean;	//9 Jan 17 NDS
	
begin	
	
	if not doPreSaveValidation( newScaleWeight, cargoWeight ) then
		return false;
	endif;		
		
	defaultPrinterName := app.printer.getPrinterName;
	doPrintReciept := self.chkReceiptReq.value;	//9 Jan 17 NDS
	
	rawScaleWeight := self.myBulkGateAgent.retrievedWeight;
	
	
	while true do
		app.myTrxCA.trxProcessBulkGateOut( self.myBulkGateAgent, newScaleWeight,rawScaleWeight, cargoWeight, app.myPassport);
		
		if app.myPassport.hadDeadlock = true then	// 16.06.2025  navhn30 	MTN-35044
			return false;
		endif;
		
        if app.myPassport.trxCompletedOK then
			self.clearForm();
            break;
        else												
			if app.myPassport.noErrors() and app.myPassport.noWarnings then  // Can happen with attachments		
				app.myPassport.warningsAcknowledged     := true;												
				continue;																									
			endif;																								

			result := app.showErrorWarningDialog(app.getErrorString(Bulk_gate_out), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
					app.myPassport.warningsAcknowledged     := true;
					continue;
			endif;
			return false;
        endif;
        break;	
	endwhile;
		
	realVVR := self.myBulkGateAgent.myRealVVR;		
		
		
	if realVVR &lt;&gt; null and doPrintReciept then
		printCopies := self.myTerminal.getConfig(GateReceiptCopies).Integer;
		if printCopies &gt; 0 then
			realVVR.printRoadReceipt(	printCopies,	
										self.myTerminal.getConfig(PrintPreview).Boolean,
										null);
		endif;
	endif;	
		
	return true;
	
epilog
		
	app.printer.setPrinter( defaultPrinterName );
	app.myPassport.clearErrorsToIgnore(); 
	
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSaveDLRT" id="7f945209-3d4f-406e-b048-4c6b1f63f68f">
        <updating/>
        <source>doSaveDLRT() updating;
/*

Purpose:			DLRT = DEAD LOCK RE-TRY. If get a dead lock the transaction will be aborted and this method will pause, loop round and retry the TRX. It will do this 10 times

Parameters:			

Return Value:		

Date		Who		Reason
16 June 2025	navhn30	 Story MTN-35044: MTN - DeadLock Retry Required for trxProcessBulkGateOut
03/11/2025 jlier1 	MTN-34531 - Deadlock retry for everyone
*/

vars
	localCaption : String;
begin

	localCaption := self.caption;
	
	//set up the silent deadlock handler to attempt to retry
	app.myPassport.setupForDeadlockReplay(220, 3000);
	app.myPassport.silentDeadlockLimit := 10;	
	
	self.mousePointer := Window.MousePointer_HourGlass;
	
	while true do	
		//call the code that was originally in this method
		self.doSave();
		
		if app.myPassport.noTrxReplayAllowed() then		
			if app.myPassport.hadDeadlock then //had a deadlock and reached the limit show the deadlock error
				app.showErrorWarningDialog(app.getErrorString(Bulk_gate_out), app.myPassport, ErrWarnMode_Update + ErrWarnMode_CanAckWarnings);
			endif;
			break;
		endif;
		
		self.updateCaptionDeadlockRetry(localCaption);
		
	endwhile;

	
epilog

	//set the silent deadlock handler back to the default values i.e. OFF
	
	app.myPassport.resetSilentDeadlockHandler;
	self.caption := localCaption;
	self.mousePointer := Window.MousePointer_Default;

end;</source>
    </JadeMethod>
    <JadeMethod name="doTblItemsContextMenu" id="cc8db426-db73-443d-a53c-735cf5c37d06">
        <updating/>
        <source>doTblItemsContextMenu(_conwin : Window input; _x : Integer; _y : Integer):Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 April 2018	jlgns1	Initial creation
19 April 2018	jlgns1 Bug 38134: PKT - Weight Discrepancy
*/

vars
	xLeft 	: Real;
	yTop	: Real;
begin

	xLeft := _x;
	yTop := _y;
	self.mnuDeleteCurrentEntry.visible :=  app.myCurrentUserCan(self.myTerminal, self.permissionMaint);
	self.mnuInspectObj.visible := app.isAllowedToInspect();
	_conwin.windowToScreen(xLeft, yTop);
	self.screenToWindow(xLeft, yTop);   // convert x, y relative to form
	self.popupMenu(self.mnuTableContext, xLeft.Integer, yTop.Integer);
	return false;

epilog

end;</source>
        <Parameter name="_conwin" type="Window" usage="input"/>
        <Parameter name="_x" type="Integer"/>
        <Parameter name="_y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doUnload" id="7f10e510-7a19-4f1a-a475-019277387525">
        <updating/>
        <source>doUnload() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 April 2018	jlgns1	Initial creation
19 April 2018	jlgns1 Bug 38134: PKT - Weight Discrepancy
*/

vars

begin
	self.endNotificationForSubscriber(self);
	
    self.myBulkGateAgent.deletePxyGTEEntity();
		
	if self.myWeightInterfaceController &lt;&gt; null and not self.myWeightInterfaceController.isOkToDelete then
		app.writeLog(method.qualifiedName &amp; " Serial port has not closed within 5 second, Modal dialog shown", LogDEBUG);	//25 Nov 2019	NDL	TFS 47053
		app.doWindowEvents(0);																														//Bug 38134
		//app.msgBox(self.caption &amp; CrLf &amp; "closing Serial port connection, click OK to continue",app.getErrorString(Error_warning_messages),0);	//Bug 38134
	endif;
		
	delete self.myWeightInterfaceController;
		
	delete	self.myBulkGateAgent;
end;
</source>
    </JadeMethod>
    <JadeMethod name="doUpdateChangeStatus" id="ff02fc26-8eeb-4dbe-920a-1845d99222cf">
        <updating/>
        <source>doUpdateChangeStatus() updating;
// ---------------------------------------------------------------------------

//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	theReturn : Integer;
begin
	if self.myBulkGateAgent.myRealVVR = null then
		return;
	endif;
	while true do
		app.myTrxUA.trxUpdateInOutGateStatus(self.myBulkGateAgent.myRealVVR,CMGTE_Entity.Status_Cancelled, app.myPassport);
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			global.beep;
			break;
		else
			theReturn := app.showErrorWarningDialog(app.getErrorString(Change_status), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			return;
		endif;
		break;
	endwhile;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doVehicleVisitCancel" id="e9595eab-f790-43c9-a77a-5f502c27084e">
        <updating/>
        <source>doVehicleVisitCancel(_reason :String) updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason

*/

vars
	theReturn	: Integer;
begin
	while true do
		app.myTrxUA.trxUpdateVVRCancel(self.myBulkGateAgent.myRealVVR, _reason, app.myPassport);
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			break;
		else
			theReturn := app.showErrorWarningDialog(app.getErrorString(GateInOut), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
				theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged     := true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);       // copies errors to this form and shows in err/warnings window
			return;
        endif;
	break;
	endwhile;	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_reason" type="String"/>
    </JadeMethod>
    <JadeMethod name="enableActionButtons" id="b319047c-ec3d-4f60-8a66-658d274c871e">
        <source>enableActionButtons(_enabled : Boolean) protected;
// ---------------------------------------------------------------------------
// Created:     07 October 2008 by cnwab1
//
// Changed On   	Changed By  	Reason
