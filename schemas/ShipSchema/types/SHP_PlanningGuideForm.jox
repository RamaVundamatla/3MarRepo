        <updating/>
        <source>cmbVoyage_click(combobox: ComboBox input) updating;
// ---------------------------------------------------------------------------
// Created:		January 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	// ON THIS CLICK THE WINDOWEVENTS ARE BEING IGNORED EVEN THOUGH THEY ARE TOLD TO BE DONE.
	// THIS IS AN ATTEMPT TO GET AROUND THIS.
//	self.causeEvent(self.Redraw_Now,true,null);
	self.doComboVoyageClick();
end;</source>
