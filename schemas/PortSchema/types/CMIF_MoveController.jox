    <JadeMethod name="setMoveMode" id="cba43b7d-88f2-4f46-8142-9ca2886e2181">
        <updating/>
        <source>setMoveMode(mode : Integer) updating;
/*
 ------------------------------------------------------------------------
Created:			26 July 2001 by cnwdwq1
Purpose:			
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/
begin
	if mode &lt;&gt; REAL_MODE and mode &lt;&gt; PLANNING_MODE and mode &lt;&gt; QUEUE_MODE and mode &lt;&gt; QUEUE_PLAN_ON_PICKUP then  //cnwrd1 par 26734 CCMS 2014 plan on pickup
		app.setContinueCMExceptions(false);
	//	app.raiseCMException(ERR_INVALID_MODE, null, null);
		app.raiseCMException1( Invalid_move_mode_passed, method.qualifiedName, null, null );	//13 Apr 2021	NDL	TFS 50906
		return;
	endif;
	if self.isUndoMove and mode = REAL_MODE and isPostMoveCleanup = false then
		app.setContinueCMExceptions(false);
		app.raiseCMException(InvalidModeForUnplan, null, null);
		return;		
	endif;
	self.moveMode := mode;
end;</source>
        <Parameter name="mode" type="Integer"/>
    </JadeMethod>
