    <JadeMethod name="tblNNCargo_contextMenu" id="d1e1f049-97e9-4d05-a07e-6937c6ca3ab2">
        <controlMethod name="Table::contextMenu"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
