<Class name="CM_YATypeVoyageBerth" id="ccdc7719-de49-4e34-a305-ee98e69bf80d">
    <superclass name="CM_YACriteriaType"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <access>protected</access>
    <DbClassMap file="yardAllocations"/>
    <JadeMethod name="getAllCriteriaValues" id="ae62c74e-3a2a-43ce-8690-fa14c3f31163">
        <source>getAllCriteriaValues(_terminalObj:CM_Terminal; _allCriteriaValues: ObjectSet input; _filter : Integer; _allDependentObjs : CM_ObjectArray);
// --------------------------------------------------------------------------------
// Created:		07 March 2005 by cnwdad1
//
// Purpose:		Refer to superclass implementation.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//17 September 2013	cnwmc5	PAR 31255 - allowing dependent objects the criteria is based on.
// --------------------------------------------------------------------------------
vars
	terminalObj	: CM_Terminal;
	
begin
	terminalObj	:=	_terminalObj;
	
	if terminalObj = null and app.isDevelopmentSystem() then
		terminalObj	:=	CM_Terminal.firstInstance();
	endif;
	
	if terminalObj &lt;&gt; null and terminalObj.myHarbour &lt;&gt; null then
		terminalObj.myHarbour.allBerths.copy(_allCriteriaValues);
	endif;
end;</source>
        <Parameter name="_terminalObj" type="CM_Terminal"/>
        <Parameter name="_allCriteriaValues" type="ObjectSet" usage="input"/>
        <Parameter name="_filter" type="Integer"/>
        <Parameter name="_allDependentObjs" type="CM_ObjectArray"/>
    </JadeMethod>
    <JadeMethod name="getDataDisplay" id="be936bc6-9bc9-4f3e-830c-97703b4f142a">
        <source>getDataDisplay(pDataObj : CM_YAData) : String;
//01 August 2008	cnwdw1
begin
	return pDataObj.CM_YADataObjects.getDataDisplay(self);
end;</source>
        <Parameter name="pDataObj" type="CM_YAData"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplay" id="d02486ee-e758-43d1-a889-40d63966a20d">
        <source>getDisplay(dataObj : Object) : String;
//01 August 2008	cnwdw1
begin
	return dataObj.HMS_Berth.code;
end;</source>
        <Parameter name="dataObj" type="Object"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getObjects" id="c322d250-acef-4f50-9bfd-17f4a85bdaef">
        <source>getObjects(objects: ObjectLongNameDict input);
//03 August 2008	cnwdw1	
// Return a dict of objects for this criteria type
vars
	berth: HMS_Berth;
	terminal: CM_Terminal;
begin
	terminal := app.getMyTerminalDO_NOT_USE();
	if terminal.myHarbour &lt;&gt; null then
		foreach berth in terminal.myHarbour.allBerths do
			objects[berth.getYAIdentifier] := berth;
		endforeach;
	endif;
end;</source>
        <Parameter name="objects" type="ObjectLongNameDict" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getTypeName" id="7ca8b064-f758-4478-847f-6300636b9c8a">
        <source>getTypeName(): String;
// --------------------------------------------------------------------------------
// Created:		16 March 2005 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return "Voyage Berth";
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
