    <JadeMethod name="getFirstNonEquipmentTI" id="3c334682-8a63-439f-994c-6a30547990d9">
        <source>getFirstNonEquipmentTI():CM_TrackedItem;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 April 2015	cnwndl1	Initial creation	Par 36111

*/

vars

	iter : Iterator;
	ti : CM_TrackedItem;

begin

	if self.isEmpty then
		return null;
		
	else
		iter := self.createIterator;
		while iter.next( ti ) do
			if not ti.isEquipment then
				return ti;
			endif;
		endwhile;
		
	endif;
	
	return null;

epilog

	delete iter;

end;</source>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="includesBulkOrBreakBulk" id="d16aabfb-20de-48d5-9285-bc36e94b401d">
        <source>includesBulkOrBreakBulk():Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 August 2017	jlgndl1	Initial creation	TFS 5701

*/

vars

	iter : Iterator;
	ti : CM_TrackedItem;

begin

	iter := self.createIterator;
	while iter.next( ti ) do
		if ti.isKindOf(CM_Bulk) then
			return true;
		elseif ti.isKindOf(CM_BreakBulk) then
			return true;
		endif;
	endwhile;
	
	return false;

epilog

	delete iter;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isEmptyOrContainsOnlyEquipment" id="8c6c1206-8286-42df-9f18-963ecdd74737">
        <source>isEmptyOrContainsOnlyEquipment():Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 April 2015	cnwndl1	Initial creation	Par 36111

*/

vars

	iter : Iterator;
	ti : CM_TrackedItem;

begin

	if self.isEmpty then
		return true;
		
	else
		iter := self.createIterator;
		while iter.next( ti ) do
			if not ti.isEquipment then
				return false;
			endif;
		endwhile;
		
	endif;
	
	return true;

epilog

	delete iter;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</CollClass>
