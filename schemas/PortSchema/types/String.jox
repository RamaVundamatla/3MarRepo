    </JadeMethod>
    <JadeMethod name="splitIntoNumbersLetters" id="55ac8c9d-c1d5-444c-a275-a39376cea737">
        <source>splitIntoNumbersLetters(_letters : String output; _numbers : Integer output);
// ---------------------------------------------------------------------------
// Created:		03 August 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	idx, len : Integer;
	part, num, lett : String;
begin
	len := self.length();
	
	foreach idx in 1 to len do
		part := self[idx:1];
		if part.cnEcIsNumeric() then
			num:= num &amp; part;
		else
			lett := lett &amp; part;
		endif;
	endforeach;
	_letters := lett;
	if num.length() &gt; 8 then
		num := num[1:8];
	endif;
	_numbers := num.Integer;
end;</source>
        <Parameter name="_letters" type="String" usage="output"/>
        <Parameter name="_numbers" type="Integer" usage="output"/>
    </JadeMethod>
    <JadeMethod name="splitToMultiLine" id="7211be0a-0469-4ea5-bfdc-bd89b717d0a7">
        <source>splitToMultiLine() : String;
//Changes comma separated items into crlf separated items
vars
	aStr : String;
begin
	aStr := self;
	aStr.replaceChar(",", Cr);
	aStr.replaceChar(" ", Lf);
	return aStr;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="splitToSingleLine" id="a148feaa-a2ee-4df4-abbc-9359b0133f95">
        <source>splitToSingleLine() : String;
//converts crlf separated items into comma separated items
vars
	aStr, bStr : String;
	idx : Integer;
begin
	aStr := self;

	aStr.replaceChar(Cr, ",");
	aStr.replaceChar(Lf, " ");
	aStr := aStr.trimRight;

	// XPOSE 1879 from here
	// ReplaceString does not deal with spaces, so remove spaces
	foreach idx in 1 to aStr.length do
		if aStr[idx:1] &lt;&gt; " " then
			bStr := bStr &amp; aStr[idx:1];
		endif;		
	endforeach;
	
	// if they have entered blank lines there will be lots of commas, at the first double comma the C++ exits loosing any data after that
	bStr := bStr.replaceString(",,",",");
	bStr := bStr.replaceString(",,",",");
	bStr := bStr.replaceString(",,",",");
	bStr := bStr.replaceString(",,",",");
	
	aStr := bStr;
	// XPOSE 1879 to here
	
	return aStr;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="startsWith" id="bd315ed6-e374-4a4f-ad9f-50298db4d2ec">
        <source>startsWith(_start : String) : Boolean;
// -----------------------------------------------------------------------------
// Created:		07 May 2002 by cnwka1
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
vars
	len : Integer;
begin
	if _start = null then
		//You want to search for nuffink, fine, WE'LL GIVE YOU NOTHING (hah), I mean everything! :-)
		return true;	
	endif;
	len := _start.length;
	if len &gt; self.length then 
		return false;
	endif;
	
	return (self[1:len] = _start);
end;</source>
        <Parameter name="_start" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="startsWith_Regex" id="b94a7281-e576-4e5a-80af-0fb9e3fd6250">
        <source>startsWith_Regex(_start : String; _ignoreCase : Boolean) : Boolean;
/*

Purpose:			Slower than startsWith &amp; startsWith__

Parameters:			

Return Value:		

Date		Who		Reason
03 October 2023	navpw1	Initial creation

*/

vars

begin
	if _start = null then
		//You want to search for nuffink, fine, WE'LL GIVE YOU NOTHING (hah), I mean everything! :-)
		return true;	
	endif;
	
	return JadeRegex@isMatch(self, "^" &amp; _start &amp; ".*", _ignoreCase);
	
epilog

end;</source>
        <Parameter name="_start" type="String"/>
        <Parameter name="_ignoreCase" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="string_To_JMT_Translation" id="f646d829-b5d4-4a76-83ba-8878d0f3e4f8">
        <updating/>
        <source>string_To_JMT_Translation( _whatForStr : String; _forTranslation : Integer  ) updating;

/*

Purpose:		This method will take self (a string) and then if the supplied string is contained in self
				will subtitute the translated string instead of the the supplied string.
				If anything does not work then self is returned as it was.

Date				Who		Reason
22 May 2009			cnwrl1	Initial creation as part of PAR 19668 - CCMS 1814 - Interface History

*/
	
vars
	pos				: Integer;
	tempStr			: String;
	
begin
	// do some sanity validation.
	if self = null or _whatForStr = null or _forTranslation = null then
		return;
	endif;
	
	pos	:= self.pos( _whatForStr, 1 );
	if pos = null then
		// not found in string.
		return;
	endif;
	
	// Attempt to find translation.
	tempStr	:= app.getErrorString( _forTranslation );
	if tempStr = null or tempStr.pos( UnknownMessage, 1 ) &lt;&gt; null then
		// no translation found
		return;
	endif;
	
	// Now replace the whatFor part of self with the found translation string.
	if pos &gt; 1 then
		self	:=	self[ 1 : pos - 1 ] &amp;							// up to string being translated
					tempStr &amp;										// translated part
					self[ pos + _whatForStr.length : end ];			// rest of the string
	else
		self	:=	tempStr &amp;										// translated part
					self[ pos + _whatForStr.length : end ];			// rest of the string
	endif;
	
epilog
	
end;
</source>
        <Parameter name="_whatForStr" type="String"/>
        <Parameter name="_forTranslation" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="stripAbove7E" id="33095cec-5ccc-4436-b537-9c0c700bc3c7">
        <source>stripAbove7E() : String;

vars
	aStr, bStr : String;
	idx : Integer;
begin
	aStr := self;

	// ReplaceString does not deal with spaces, so remove spaces
	foreach idx in 1 to aStr.length do
		if aStr[idx:1].Character.Integer &gt; 126  then
		else
			bStr := bStr &amp; aStr[idx:1];
		endif;		
	endforeach;
	return bStr;
end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="stripAlpha" id="a6c7082f-d57f-469b-a2f5-3f3426f2f855">
        <source>stripAlpha() : String;
// -----------------------------------------------------------------------------
// Created:		December 2005 cnwrs1
//
// Purpose:		Strips any alpha characters from the string and returns an 
//				integer String.
//
// Parameters:	None
//
// Returns:		String only containing numeric characters
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
vars
	aStr, bStr : String;
	idx : Integer;
begin
	aStr := self;

	// ReplaceString does not deal with spaces, so remove spaces
	foreach idx in 1 to aStr.length do
		if aStr[idx:1].Character.isNumeric()  then
			bStr := bStr &amp; aStr[idx:1];
		endif;		
	endforeach;
	return bStr;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="stripInvalidFileNameCharacters" id="886132b0-1ae6-48a8-ae95-29c323eccda8">
        <source>stripInvalidFileNameCharacters() : String;
// TFS 2353 par 37844
vars
	result	: String;
	i		: Integer;
	s		: String;
begin
	result := "";
	if self &lt;&gt; null then
		foreach i in 1 to self.length do
			s := self[i];
			if not s.isOneOf('&lt;', '&gt;', ':', '"', '/', '\', '|', '?', '*') then
				result := result &amp; s;
			endif;
		endforeach;
	endif;
	return result;
end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="stripLeadingAlpha" id="f269b3fd-1fd7-4626-977b-f47e4194d43d">
        <source>stripLeadingAlpha() : Integer;
// -----------------------------------------------------------------------------
// Created:		09 April 2002 by cnwka1
//
// Purpose:		Strips any leading alpha characters off the front of the string and returns the 
//				trailing integer.
//
// Parameters:	None
//
// Returns:		an Integer to the value of what is left in the string or Zero
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
vars
	pos, result : Integer;
begin
	
	pos := 1;
	self.scanUntil('0123456789', pos);
	if pos = 0 then
		result := 0;
	else
		result := self[pos:end].Integer;
	endif;
	return result;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="stripLeadingZeroes" id="377f0534-8ab6-4d8c-a5d1-3bb9c6750750">
        <source>stripLeadingZeroes(): String;
//28 October 2008	cnwdw1	
// Purpose:		Strips any leading 0's from the string
// Returns:		If no leading zeroes returns self otherwise a new string without leading zeroes
vars
	pos: Integer;
begin
	pos := 1;
	self.scanWhile('0', pos);
	if pos = 0 then
		return self;
	endif;
	return self[pos:end];
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="stripTrailingChar" id="44b07515-dd1b-4d3a-a92a-9b5f2c38e2fe">
        <source>stripTrailingChar( charToStrip : Character ):String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 May 2012	cnwndl1	Initial creation	Par 28368

*/

vars
	len : Integer;
	idx : Integer;
	str : String;

begin
	str := self.trimRight;
	len := str.length;
	
	foreach idx in len to 1 step -1 do
		if str[idx] = charToStrip then
			str := str[1:idx-1];
		else
			break;
		endif;
	endforeach;
	
	return str;
end;</source>
        <Parameter name="charToStrip" type="Character"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="stripTrailingColon" id="f723c195-3e54-43a9-8a4d-d37f23db43b3">
        <source>stripTrailingColon():String;
// ---------------------------------------------------------------------------
// Created:     24 November 2009 by cnwcs5
// Purpose:     CCMS 1028 - summary mappings
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	len : Integer;
	idx : Integer;
	str : String;
begin
	str := self.trimRight;
	len := str.length;
	
	foreach idx in len to 1 step -1 do
		if str[idx] = ":" then
			str := str[1:idx-1];
		else
			break;
		endif;
	endforeach;
	
	return str;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="stripTrailingSlashes" id="baaad98f-7025-46b4-bff0-29ed94a1469b">
        <source>stripTrailingSlashes() : String;
// ---------------------------------------------------------------------------
// Created:     28 July 2003 by cnwsb1
//
// Purpose:		Removes any number of trailing slashes
//				eg. 'C:\Temp\\ ' --&gt;  'C:\Temp'
// ---------------------------------------------------------------------------
vars
	len : Integer;
	idx : Integer;
	str : String;

begin
	str := self.trimRight;
	len := str.length;
	
	foreach idx in len to 1 step -1 do
		if str[idx] = "\" or str[idx] = "/" then
			str := str[1:idx-1];
		else
			break;
		endif;
	endforeach;
	
	return str;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="substituteDirectory" id="ff8efa9e-c192-46b4-9f6c-4ea9a431273c">
        <source>substituteDirectory():String;
/*
Purpose:		This method will check the supplied file directory to see if it contains %MISCDIR% (any case),
				if it does then the run time correct miscellaneous directory will be substituted in the
				directory path instead of the string %MiscDir%.
				This method is NOT to use app.cnGetClientMiscPath until JadeCare Start PAR 579 is fixed.

Date		Who		Reason
22 Nov 2012	cnwcs5	Initial creation - par 30618 - replaces CM_Root substituteDirectory
*/
vars
	miscPathStr,
	result			: String;
	pos				: Integer;
	
begin
	pos	:= self.toUpper.pos( MiscDir, 1 );

	if pos = null then
		// nothing to change
		return self;
	endif;
	
	// get the current server miscellaneous directory
	miscPathStr	:= app.getJadeInstallDirAppServer.toLower;
	
	miscPathStr.cnReplaceString( CN_C_BIN, CN_C_MISC );
	
	// now subtitute this instead of the %MISCDIR part (length of 9)
	if ( pos + 9 ) &gt; self.length then
		result	:= self[ 1 : pos - 1 ] &amp; miscPathStr;
		
	elseif pos &gt; 1 then
		result 	:= self[ 1 : pos - 1 ] &amp; miscPathStr &amp; self[ pos + 9 : end ];
		
	else
		result	:= miscPathStr &amp; self[ pos + 9 : end ];
	endif;
	
	return result;
epilog
	
end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="substituteParams" id="bb47331a-ba2b-4f8c-a07e-3a14cd317e52">
        <source>substituteParams(params : HugeStringArray) : String;

// Returns a new string which is self with all %n parameters
// substituted from the values in the supplied string array

vars
	paramIndex, originalMsgLen, i, copyFromPos : Integer;
	originalMsg, substitutedMsg : String;
	currentChar, nextChar : Character;
	
begin
	copyFromPos := 1;
	originalMsg := self;
	originalMsgLen := originalMsg.length;
	substitutedMsg := null;
	
	foreach i in 1 to originalMsgLen do
		currentChar := originalMsg[i];
		if i + 1 &lt;= originalMsgLen then
			nextChar := originalMsg[i + 1];
		else
			nextChar := null;
		endif;
		
		if currentChar = '%' and nextChar &gt;= '1' and nextChar &lt;= '9' then
			paramIndex := nextChar.Integer - '0'.Integer;
			substitutedMsg := substitutedMsg &amp; originalMsg[copyFromPos : i - copyFromPos];
			if paramIndex &lt;= params.size then
				substitutedMsg := substitutedMsg &amp; params[paramIndex].trimBlanks;
			endif;
			i := i + 2;
			copyFromPos := i;
		endif;
	endforeach;
	
	if copyFromPos &lt;= originalMsgLen then
		substitutedMsg := substitutedMsg &amp; originalMsg[copyFromPos : i - copyFromPos];
	endif;

	return substitutedMsg;

end;</source>
        <Parameter name="params" type="HugeStringArray"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="trailingString" id="edc3ec5c-fbb6-4ecb-b247-18b4dbded686">
        <source>trailingString(pFrom : Integer) : String;
// ---------------------------------------------------------------------------
// Created:     06 December 2000 by cnwrs2
//
// Purpose:     Returns the trailing segement of a string from a
//				nominated starting position.
//
// Parameters:  The start position
//
// Returns:     The trailing string
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if pFrom &gt; self.length then
		return null;
	else
		return self[pFrom:end];
	endif;

end;</source>
        <Parameter name="pFrom" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="trimBlankCharacters" id="1f704a9a-81ec-4802-bd54-de4446f3fa0e">
        <source>trimBlankCharacters(): String;

begin
	return trimCharacters(Blank_Characters);
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="trimCharacters" id="94eadaca-dd8b-4af4-af1b-452527ec02e4">
        <source>trimCharacters(chars: String): String;

/*

Date		Who		Reason
20 May 2009	cnwkpd1	PAR #18983 - Fix error in code for return value of 0 from scanWhile

*/

vars
	outstr			: String;
	i				: Integer;
	pos				: Integer;

begin
	if self = null then
		return null;
	endif;

	i := 1;
	self.scanWhile(chars, i);

	if i = 0 then
		return null;
	else
		outstr := self[i:end].reverse;
	endif;

	i := 1;
	outstr.scanWhile(chars, i);

	if i = 0 then
		return null;
	else
		return outstr[i:end].reverse;
	endif;

end;</source>
        <Parameter name="chars" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="trimPortCode" id="1e0142ef-d41a-4b27-b0cd-6fa207c50339">
        <source>trimPortCode() :  String;
/*

Purpose:	Trims the new 5 char port code to the old 3 char port code		


Return Value:		


Date		Who		Reason
11 September 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars
	tmpStr : String;
begin
	if self.length &lt;&gt; 5 then
		return self;
	endif;
	
	return self[3:end];


epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="trimWhiteSpace" id="b8315b57-c8a2-4279-ae76-7e27582a3de2">
        <source>trimWhiteSpace() : String;
/*

Purpose:			Trim leading and triling "white space" from the receiver

Parameters:			None

Return Value:		self with any leading and trailing "white space" characters removed

Date		Who		Reason
26 Oct 2011	cnwkpd1	Framework performance issues
	
*/

vars

begin
	return self.trimBlanks().trimBlankCharacters();
	
end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="truncateStartToMaxLengthOf" id="ac2d922c-a385-494b-ad84-1bfa3e875059">
        <source>truncateStartToMaxLengthOf( _maxLength : Integer ):String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 October 2013	cnwndl1	Initial creation	Par 32874

*/

vars

	startPos : Integer;

begin

	if self = null or _maxLength &lt; 1 then
		return null;
	endif;

	if self.length &gt; _maxLength then
		startPos := self.length - ( _maxLength - 1 );
		return self[startPos:end];
	endif;
	
	return self;

epilog

end;</source>
        <Parameter name="_maxLength" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="truncateWithDotDotDot" id="bab3d9b8-0820-4823-9e7d-f559cb1e6963">
        <source>truncateWithDotDotDot(_length : Integer) : String;
/*
----------   ----------  --------------------------------------------------
Created:	28 August 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	workStr		: String;
	len			: Integer;
begin
	len := self.length;
	if len &lt;= _length or len &lt;= 3 or _length &lt; 4 then
		return self;
	endif;
	
	return self[1:_length - 3] &amp; '...';
	

end;


</source>
        <Parameter name="_length" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="truncatedAt" id="a2f9be7d-ef19-4b73-b859-57c4ea79c37d">
        <source>truncatedAt(maxLen : Integer) : String;
// ---------------------------------------------------------------------------
// Created:     16 January 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	s : String;
	
begin

	s := self.trimBlanks;

	if maxLen &lt; 1 or s.length &lt;= maxLen then
		return s;
	endif;

	return s[1 : maxLen];
	
end;</source>
        <Parameter name="maxLen" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="writeToFile" id="6c8527de-1262-4af6-a08c-6baf1b10e935">
        <source>writeToFile(pFileName:String):Boolean;
// --------------------------------------------------------------------------------
// Created:		21 June 2005 by cnwdad1
//
// Purpose:		Write the receiver to a disk file.
//
// Parameters:	pFileName - The name of the file.
//
// Returns:		True of the write was successful, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	fileObj		: File;
	
begin
	create fileObj transient;
	fileObj.mode		:=	File.Mode_Output;	// 1/3/16 cnwmp6 PAR 36286 unicode version
	fileObj.fileName	:=	pFileName;
	fileObj.writeString(self);
	
	return true;
epilog
	delete fileObj;		// The file will be automatically closed.
end;</source>
        <Parameter name="pFileName" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="xmlReplaceReservedChars" id="582dcf27-d107-4481-a8e0-53b3853b7393">
        <source>xmlReplaceReservedChars(_isToXML : Boolean):String;
// ---------------------------------------------------------------------------
// Created:     11 May 2004 by cnwrs2
//
// Purpose:		Converts XML Character Entities contained in the receiver between
//				the characters and their entities.  For example, if converting
//				entities to characters, then a "&amp;amp;" will become "&amp;".  Likewise,
//				if converting characters to entities, then a "&amp;" will become "&amp;amp;".
//
// Parameters:	_isToXML - If true, then characters will be converted into entities,
//				otherwise entities will be converted into characters.
//
// Returns:		String - The resulting converted string.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
constants
	CHAR_AMPERSAND		: String = 38.Character;
	CHAR_LESS_THAN		: String = 60.Character;
	CHAR_GREATER_THAN	: String = 62.Character;
	CHAR_APOSTROPHE		: String = 39.Character;
	CHAR_QUOTE			: String = 34.Character;
	ENTITY_AMPERSAND	: String = "&amp;amp;";
	ENTITY_LESS_THAN	: String = "&amp;lt;";
	ENTITY_GREATER_THAN	: String = "&amp;gt;";
	ENTITY_APOSTROPHE	: String = "&amp;apos;";
	ENTITY_QUOTE		: String = "&amp;quot;";

vars
	resultString	: String;
	
begin
	resultString	:=	self;
	
	if _isToXML then
		resultString	:=	resultString.cnEcFindReplace(CHAR_AMPERSAND, ENTITY_AMPERSAND, false);
		resultString	:=	resultString.cnEcFindReplace(CHAR_LESS_THAN, ENTITY_LESS_THAN, false);
		resultString	:=	resultString.cnEcFindReplace(CHAR_GREATER_THAN, ENTITY_GREATER_THAN, false);
		resultString	:=	resultString.cnEcFindReplace(CHAR_QUOTE, ENTITY_QUOTE, false);
		resultString	:=	resultString.cnEcFindReplace(CHAR_APOSTROPHE, ENTITY_APOSTROPHE, false);
	else
		resultString	:=	resultString.cnEcFindReplace(ENTITY_LESS_THAN, CHAR_LESS_THAN, false);
		resultString	:=	resultString.cnEcFindReplace(ENTITY_GREATER_THAN, CHAR_GREATER_THAN, false);
		resultString	:=	resultString.cnEcFindReplace(ENTITY_QUOTE, CHAR_QUOTE, false);
		resultString	:=	resultString.cnEcFindReplace(ENTITY_APOSTROPHE, CHAR_APOSTROPHE, false);
		resultString	:=	resultString.cnEcFindReplace(ENTITY_AMPERSAND, CHAR_AMPERSAND, false); 
	endif;
	
	return resultString;
end;</source>
        <Parameter name="_isToXML" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="xmlReplaceTagData" id="50d33b97-6999-4fb8-b157-d830ad45ba2e">
        <source>xmlReplaceTagData(_xmlTag, _replacementData : String) : String;

/*

Purpose:			Replaces the data for a tag in an xml string with another value.

Parameters:			XML tag and new data value.

Return Value:		Converted string.


Date		Who		Reason
30 Nov 2009	consw1	PAR #21593 - Development of CCMS MES 1014 - RDT ITS Interface

*/

vars
	endTag				: String;
	endTagPos			: Integer;
	newString			: String;
	oldString			: String;
	oldStringPos		: Integer;
	startTag			: String;
	startTagPos			: Integer;
	tagLength			: Integer;
	
begin
	if self = null then
		return null;
	endif;

	oldString		:= self;
	oldStringPos	:= 1;
	
	startTag		:= "&lt;" &amp; _xmlTag &amp; "&gt;";
	endTag			:= "&lt;/" &amp; _xmlTag &amp; "&gt;";
	
	tagLength		:= startTag.length;
	startTagPos		:= 1;
	
	while true do
		startTagPos	:= self.pos(startTag, startTagPos);
		if startTagPos = 0 then
			break;
		endif;
		endTagPos := self.pos(endTag, startTagPos + tagLength);
		if endTagPos = 0 then
			break;
		endif;
		newString := newString &amp; oldString[oldStringPos:(startTagPos - oldStringPos + 1)] &amp; _xmlTag &amp; "&gt;" &amp; _replacementData;
		oldStringPos := endTagPos;
		startTagPos := endTagPos + tagLength + 1;
	endwhile;
	
	if oldStringPos &lt; oldString.length() then
		newString := newString &amp; oldString[oldStringPos:end];
	endif;

	return newString;
	
epilog

end;</source>
        <Parameter name="_xmlTag" type="String"/>
        <Parameter name="_replacementData" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
</PrimType>
