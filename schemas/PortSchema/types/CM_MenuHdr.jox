    <JadeMethod name="getItemsWithNoChildren" id="f017cdc1-c8ce-414e-b02d-da8bdd50b4b6">
        <source>getItemsWithNoChildren(_delSet: CM_MenuEntitySet input);
// ---------------------------------------------------------------------------
// Created:     16 April 2003 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if self.allChildren.isEmpty then
		_delSet.add(self);
	else
		inheritMethod(_delSet);
	endif;

end;</source>
        <Parameter name="_delSet" type="CM_MenuEntitySet" usage="input"/>
    </JadeMethod>
