    <JadeMethod name="doDiscrepancy" id="fabbc64a-a6ab-4c23-bc69-6ba2393bddca">
        <updating/>
        <source>doDiscrepancy()protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 Nov 2013	cnwndl1	Initial creation	Par 33073
17 May 2023	jlika1	TFS 56398 EUP - OUT - Overlanded Cargo Handling - Web
*/

vars

	newQty : Integer;
	theReturn : Integer;
	newTotalWeight : Decimal[14,4];
	newCargoWeight : Decimal[14,4];		//25 Jan 2018	NDL	TFS 36697
	newTareWeight : Decimal[14,4];		//25 Jan 2018	NDL	TFS 36697
	reason : String;

begin
	//epr refactored validation into trx for the tfs 1502 
	newQty := self.txtNewQuantity.text.trimBlanks.Integer;
	newTotalWeight := self.getWeightMovedKgs;
	if self.tblCargoWeight.visible and self.tblTareWeight.visible then	//26 Jan 2018	NDL	TFS 36697
		newCargoWeight := self.tblCargoWeight.getConvertedValue();	//25 Jan 2018	NDL	TFS 36697
		newTareWeight := self.tblTareWeight.getConvertedValue();	//25 Jan 2018	NDL	TFS 36697
	endif;
	reason := self.txtReason.text.trimBlanks;
	while true do 
	
		app.myTrxUA.trxBreakBulkOverage(self.myTrackedItem, self.class.name, newQty, newTotalWeight, newCargoWeight, newTareWeight, reason, false, false, false, app.myPassport);
		
		if app.myPassport.trxCompletedOK then
			self.setMyTrackedItem( null );
			self.populateTrackedItem();
			return;		
		else
			theReturn := app.showErrorWarningDialog(app.getErrorString(BreakBulkDiscrepancy), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			
		endif;
		
		return;
		
	endwhile;
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doResizeControls" id="23710275-802e-424a-a3b4-15d151207c9d">
        <updating/>
        <source>doResizeControls( _initialSetup : Boolean ) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 February 2015	cnwndl1	Initial creation

*/

vars

	cTop : Real;
	stdWidth : Real;
	halfWidth : Real;
	qtrWidth : Real;
	cWidth : Real;
	stdHeight : Real;
	cHeight : Real;
	cLeft : Real;
	tabIndex : Integer;

begin

	self.setResizeableMarginAndFontSize();
	stdWidth := self.clientWidth - self.resizedMargin - self.resizedMargin;
//	halfWidth := ( stdWidth / 2 ) - self.resizedMargin;
//	qtrWidth := ( stdWidth / 4 ) - self.resizedMargin;
	halfWidth := ( (stdWidth / 10) * 4 ) - self.resizedMargin;
	qtrWidth := ( ( stdWidth / 10 ) * 4 ) - self.resizedMargin;
	stdHeight := self.getStdControlHeight;
	
	cTop := self.resizedMargin;
	cWidth := stdWidth - self.resizedMargin - stdHeight;
	cHeight := stdHeight;
	tabIndex := 4000;
	
	if _initialSetup then
		self.txtCargoId.setAndIncrementTabIndex( tabIndex );
		self.txtCargoId.visible := true;
	endif;
	self.txtCargoId.move( 	self.resizedMargin,
							cTop,
							cWidth,
							cHeight );
						 
	cWidth := self.getStdControlHeight();
	if _initialSetup then
		self.btnPartCargoId.setAndIncrementTabIndex( tabIndex );
		self.btnPartCargoId.visible := true;
	endif;
	self.btnPartCargoId.move(	self.txtCargoId.left + self.txtCargoId.width + self.resizedMargin,
								cTop,
								cWidth,
								cHeight );
								
	cTop := cTop + self.txtCargoId.height + self.resizedMargin;
	cWidth := stdWidth;
	if _initialSetup then
		self.lblCargoType.setAndIncrementTabIndex( tabIndex );
		self.lblCargoType.visible := true;
	endif;
	self.lblCargoType.move(	self.resizedMargin,
								cTop,
								cWidth,
								cHeight );
								
	cTop := cTop + self.lblCargoType.height + self.resizedMargin;
	if _initialSetup then
		self.lblCargoDesc.setAndIncrementTabIndex( tabIndex );
		self.lblCargoDesc.visible := true;
	endif;
	self.lblCargoDesc.move(	self.resizedMargin,
								cTop,
								cWidth,
								cHeight );
								
	cTop := cTop + self.lblCargoDesc.height + cHeight;
	cWidth := qtrWidth;
	if _initialSetup then
		self.lblQuantity.setAndIncrementTabIndex( tabIndex );
		self.lblQuantity.visible := true;
	endif;
	self.lblQuantity.move(	self.resizedMargin,
								cTop,
								cWidth,
								cHeight );
	
	
	cLeft := self.lblQuantity.left + self.lblQuantity.width + self.resizedMargin;
	cWidth := halfWidth;
	if _initialSetup then
		self.txtNewQuantity.setAndIncrementTabIndex( tabIndex );
		self.txtNewQuantity.visible := true;
	endif;
	self.txtNewQuantity.move(	cLeft,
								cTop,
								cWidth,
								cHeight );
								
	cLeft := self.txtNewQuantity.left + self.txtNewQuantity.width + self.resizedMargin;
	cWidth := qtrWidth;
	if _initialSetup then
		self.lblQuantityChg.setAndIncrementTabIndex( tabIndex );
		self.lblQuantityChg.visible := true;
	endif;
	self.lblQuantityChg.move(	cLeft,
								cTop,
								cWidth,
								cHeight );
								
	cTop := cTop + self.lblQuantity.height + self.resizedMargin;
	cWidth := qtrWidth;
	if _initialSetup then
		self.lblTotalWeight.setAndIncrementTabIndex( tabIndex );
		self.lblTotalWeight.visible := true;
	endif;
	self.lblTotalWeight.move(	self.resizedMargin,
								cTop,
								cWidth,
								cHeight );
	
	cLeft := self.txtNewQuantity.left;
	cWidth := halfWidth;
	if _initialSetup then
		self.tblNewWeight.setAndIncrementTabIndex( tabIndex );
		self.tblNewWeight.visible := true;
	endif;
	self.tblNewWeight.move(	cLeft,
							cTop,
							cWidth,
							cHeight + self.resizedMargin // extra height to allow combo to be seen in measurement control
							);
							
	cLeft := self.lblQuantityChg.left;
	cWidth := qtrWidth;
	if _initialSetup then
		self.lblTotalWtChg.setAndIncrementTabIndex( tabIndex );
		self.lblTotalWtChg.visible := true;
	endif;
	self.lblTotalWtChg.move(	cLeft,
								cTop,
								cWidth,
								cHeight );
							
	
	//25 Jan 2018	NDL	TFS 36697
	cTop := cTop + self.tblNewWeight.height + self.resizedMargin;
	cWidth := qtrWidth;
	if _initialSetup then
		self.lblCargoWeight.setAndIncrementTabIndex( tabIndex );
		self.lblCargoWeight.visible := true;
	endif;
	self.lblCargoWeight.move(	self.resizedMargin,
								cTop,
								cWidth,
								cHeight );
	
	cLeft := self.tblNewWeight.left;
	cWidth := halfWidth;
	if _initialSetup then
		self.tblCargoWeight.setAndIncrementTabIndex( tabIndex );
		self.tblCargoWeight.visible := true;
	endif;
	self.tblCargoWeight.move(	cLeft,
								cTop,
								cWidth,
								cHeight + self.resizedMargin // extra height to allow combo to be seen in measurement control
								);
							
	cLeft := self.lblTotalWtChg.left;
	cWidth := qtrWidth;
	if _initialSetup then
		self.lblCargoWtChg.setAndIncrementTabIndex( tabIndex );
		self.lblCargoWtChg.visible := true;
	endif;
	self.lblCargoWtChg.move(	cLeft,
								cTop,
								cWidth,
								cHeight );

								
	cTop := cTop + self.tblCargoWeight.height + self.resizedMargin;
	cWidth := qtrWidth;
	if _initialSetup then
		self.lblTareWeight.setAndIncrementTabIndex( tabIndex );
		self.lblTareWeight.visible := true;
	endif;
	self.lblTareWeight.move(	self.resizedMargin,
								cTop,
								cWidth,
								cHeight );
	
	cLeft := self.tblCargoWeight.left;
	cWidth := halfWidth;
	if _initialSetup then
		self.tblTareWeight.setAndIncrementTabIndex( tabIndex );
		self.tblTareWeight.visible := true;
	endif;
	self.tblTareWeight.move(	cLeft,
								cTop,
								cWidth,
								cHeight + self.resizedMargin // extra height to allow combo to be seen in measurement control
								);
							
	cLeft := self.lblCargoWtChg.left;
	cWidth := qtrWidth;
	if _initialSetup then
		self.lblTareWtChg.setAndIncrementTabIndex( tabIndex );
		self.lblTareWtChg.visible := true;
	endif;
	self.lblTareWtChg.move(	cLeft,
							cTop,
							cWidth,
							cHeight );
	////////////////////
								
	cTop := cTop + self.tblTareWeight.height + self.resizedMargin;
	cWidth := stdWidth;
	if _initialSetup then
		self.lblReason.setAndIncrementTabIndex( tabIndex );
		self.lblReason.visible := true;
	endif;
	self.lblReason.move(	self.resizedMargin,
							cTop,
							cWidth,
							cHeight );
	
	cTop := cTop + self.lblReason.height + self.resizedMargin;
	if _initialSetup then
		self.txtReason.setAndIncrementTabIndex( tabIndex );
		self.txtReason.visible := true;
	endif;
	self.txtReason.move(	self.resizedMargin,
							cTop,
							stdWidth,
							cHeight );
							
	inheritMethod( _initialSetup );
	self.setupTblNewWeight();
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_initialSetup" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="eventWeightChange" id="091a209d-2cfa-48e6-946b-d16cacd75a50">
        <source>eventWeightChange();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 November 2013	cnwndl1	Initial creation	Par 33073

*/

vars

	dec : Decimal [16,4];
	weight : Decimal [16,4];
	diff : Decimal [16,4];
	
	measure : CM_MeasurementType;
	convertedDiff : String;
	cargoWeight : Decimal [16,4];
	cargoWeightDiff : Decimal [16,4];
	tareWeight : Decimal [16,4];
	tareWeightDiff : Decimal [16,4];
begin

	if self.myTrackedItem = null then
		self.lblTotalWtChg.caption := null;
		self.lblCargoWtChg.caption := null;
		self.lblTareWtChg.caption := null;
		return;
	endif;
	
	weight := self.myTrackedItem.totalWeight;
	dec :=  self.getWeightMovedKgs(); //epr tfs 1502 handle bulk by volume
	diff := (dec - weight);
	if diff = 0 then
		self.lblTotalWtChg.caption := null;
	else
		measure := app.myRoot.allMeasurementTypesByShortName['kg'];
		convertedDiff := app.convertMeasurementForDisplay( measure.shortName, diff);
		self.lblTotalWtChg.caption := convertedDiff;
	//	self.lblTotalWtChg.caption := self.myTrackedItem.myCargoType.getBulkTrackByDisplayForWeight(diff,self.myTrackedItem.getDensity,false);
	endif;
	
	//25 Jan 2018	NDL	TFS 36697
	if self.tblCargoWeight.visible then
		measure := app.myRoot.allMeasurementTypesByShortName[self.tblCargoWeight.getUnit];
		cargoWeight := self.myTrackedItem.weightCargo;
		dec := self.tblCargoWeight.getConvertedValue();
		cargoWeightDiff := (dec - cargoWeight);
		if cargoWeightDiff = 0 then
			self.lblCargoWtChg.caption := null;
		else
			convertedDiff := app.convertMeasurementForDisplay( measure.shortName, cargoWeightDiff);
			self.lblCargoWtChg.caption := convertedDiff;
		endif;
	endif;
	
	if self.tblTareWeight.visible then
		measure := app.myRoot.allMeasurementTypesByShortName[self.tblTareWeight.getUnit];
		tareWeight := self.myTrackedItem.weightTare;
		dec := self.tblTareWeight.getConvertedValue();
		tareWeightDiff := (dec - tareWeight);
		if tareWeightDiff = 0 then
			self.lblTareWtChg.caption := null;
		else
			convertedDiff := app.convertMeasurementForDisplay( measure.shortName, tareWeightDiff);
			self.lblTareWtChg.caption := convertedDiff;
		endif;
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getWeightMovedKgs" id="6e02858d-bdd9-4dad-8033-458f4d0a80c7">
        <source>getWeightMovedKgs() : Decimal;
/*

Date		Who		Reason
19 March 2014	cnwer1	Initial creation TFS 1502

*/

vars
	ct : CM_CargoType;
	kgValue, volume  : Decimal[14,4];

begin
	if self.myTrackedItem = null then
		return null;
	endif;
	
	if self.myTrackedItem.isBulkByVolume then
		volume:=self.tblNewWeight.getConvertedValue();
		kgValue:= volume * self.myTrackedItem.getDensity;

	else
		kgValue:=self.tblNewWeight.getConvertedValue();
	endif;

	//28 Mar 2018	NDL	TFS 37621 - have to be able to set it zero
//	if kgValue = null then
//		return self.myTrackedItem.totalWeight;
//	endif;
	return kgValue;
epilog

end;</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
