    <JadeMethod name="tCheckJsonSanitiseFieldsRegex" id="88d3274c-f410-4683-8114-93c27c7be501">
        <source>tCheckJsonSanitiseFieldsRegex();
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
21 October 2024		navmd1	Initial creation TFS 59895 / MTN-14636

*/

constants
	// Microsoft OAuth response
	JsonString1				= '{
  "token_type": "Bearer",
  "expires_in": 3599,
  "ext_expires_in": 3599,
  "access_token": "eyJ0eXAiOiJKV1QiLCJub25jZSI6Im1vSzlXOXE2MmNXeXh6bGlZd3FRT0xiTV82SFpLS1FWdjRhQm9QaURVN0EiLCJhbGciOiJSUzI1NiIsIng1dCI6IjNQYUs0RWZ5Qk5R.SnipBecauseThisIsWayToLong.feMv85mq0cROHQHf4Q"
}';
	ExpectedString1			= '{
  "token_type": "Bearer",
  "expires_in": 3599,
  "ext_expires_in": 3599,
  "access_token": "************"
}';

	// Microsoft OAuth request
	NotJsonString1			= "client_id=8be1b478-fa9b-4ace-8464-929e5134f45c&amp;client_secret=ElA8Q~ErWgJcTmD-afF5n~ZzrkeqUcbUE1kEBa9d&amp;grant_type=client_credentials&amp;scope=https://integration-api-test.euroports.com/Full.Access/.default";
	ExpectedNotJsonString1	= "client_id=8be1b478-fa9b-4ace-8464-929e5134f45c&amp;client_secret=************&amp;grant_type=client_credentials&amp;scope=https://integration-api-test.euroports.com/Full.Access/.default";
	NotJsonString2			= "client_id=8be1b478-fa9b-4ace-8464-929e5134f45c&amp;client_secret=ElA8Q~ErWgJcTmD-afF5n~ZzrkeqUcbUE1kEBa9";
	ExpectedNotJsonString2	= "client_id=8be1b478-fa9b-4ace-8464-929e5134f45c&amp;client_secret=************";
	
	
	// General password fields (same as what the XML one was doing previously)
	JsonString2				= '{
	"password": "I am a password",
	"oldPass":"I am an oldPass",
	"newPass": "I am a newPass",
	"newPass2":"I am the second new password",
	"someOtherFieldWithPasswordInIt": "Unknown, so not sanitised",
	"SomethingWithnewPassInTheMiddle": "Same with this one"
}';
	ExpectedString2			= '{
	"password": "************",
	"oldPass":"************",
	"newPass": "************",
	"newPass2":"************",
	"someOtherFieldWithPasswordInIt": "Unknown, so not sanitised",
	"SomethingWithnewPassInTheMiddle": "Same with this one"
}';

	// and just a smoosh of all the above for good measure
	CompletelyNonSensical	= NotJsonString1 &amp; CrLf &amp; "[" &amp; CrLf &amp; JsonString1 &amp; "," &amp; CrLf &amp; JsonString2 &amp; CrLf &amp; "]" &amp; CrLf &amp; NotJsonString1 &amp; CrLf &amp; NotJsonString2;
	ExpectedCompletelyNonSensical	= ExpectedNotJsonString1 &amp; CrLf &amp; "[" &amp; CrLf &amp; ExpectedString1 &amp; "," &amp; CrLf &amp; ExpectedString2 &amp; CrLf &amp; "]" &amp; CrLf &amp; ExpectedNotJsonString1 &amp; CrLf &amp; ExpectedNotJsonString2;
vars
	jsonString		: String;
begin

	jsonString := JMTJadeJson@sanitiseSensitiveFields4Loging(JsonString1);
	self.assertEqualMsg(jsonString, ExpectedString1, "Check JMTJadeJson regex for access_token");
	self.logMessage("access_token replaced successfully");

	jsonString := JMTJadeJson@sanitiseSensitiveFields4Loging(NotJsonString1);
	self.assertEqualMsg(jsonString, ExpectedNotJsonString1, "Check JMTJadeJson regex for client_secret");
	jsonString := JMTJadeJson@sanitiseSensitiveFields4Loging(NotJsonString2);
	self.assertEqualMsg(jsonString, ExpectedNotJsonString2, "Check JMTJadeJson regex for client_secret");
	self.logMessage("client_secret replaced successfully");

	jsonString := JMTJadeJson@sanitiseSensitiveFields4Loging(JsonString2);
	self.assertEqualMsg(jsonString, ExpectedString2, "Check JMTJadeJson regex for password, oldPass, newPass or newPass2");
	self.logMessage("password, oldPass, newPass and newPass2 replaced successfully");
	
	jsonString := JMTJadeJson@sanitiseSensitiveFields4Loging(CompletelyNonSensical);
	self.assertEqualMsg(jsonString, ExpectedCompletelyNonSensical, "Check JMTJadeJson regex for combination of all the above");
	self.logMessage("Silly nonsensical smoosh replaced successfully");
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="tCheckMethodsHaveOwner" id="91a39e1e-1466-4aeb-a3e6-c6bb376ee12c">
        <source>tCheckMethodsHaveOwner();

/*

Purpose:			Check to see that runnable unit tests have owner	

Date				Who		Reason
10 November 2011	cnwmh5	Initial creation

*/

vars

	klass				: Class;
	meth				: Method;
	
	classes				: ClassColl;
	methodsDict			: MethodNDict;
	
	tokens				: StringArray512;
	missingOwnerArray,
	excludeMethods		: StringArray;
	
	methodSource		: String;
	line				: String;
	token				: String;
	linePos 			: Integer;
	found				: Boolean;
	pos2				: Integer;
	
begin

	create tokens transient;
	create missingOwnerArray transient;
	create excludeMethods transient;
	
	// get UT_DSL class
	klass := currentSchema.getClass("UT_DSL");
	self.assertNotNull(klass);
	
	// create classes
	create classes transient;
	classes.add(klass);
	klass.allLocalSubclasses(classes);
	
	excludeMethods.add(UT_Template::uTemplate_Cargo.name);
	excludeMethods.add(UT_Template::uTemplate_Invoicing.name);
	
	foreach klass in classes do
	
		methodsDict := klass.cnGetMethods();
		
		foreach meth in methodsDict where meth.isRunnableUnitTestMethod() do
			if excludeMethods.includes(meth.name) then
				continue;
			endif;
			found := false;
			linePos := 1;
			meth.getSource.cnEcGetNextLine(linePos);
			while linePos &gt; 0 do
				line :=  meth.getSource.cnEcGetNextLine(linePos);
				if (line[1:9] = 'constants' and line.trimBlanks().length = 9) or 		
						(line[1:4] = "vars" and line.trimBlanks().length = 4) then
					break;
				endif;
				line.replaceChar(Tab, ' ');
				tokens.clear;
				line.getTokensForDelimiter(" ", tokens);
				foreach token in tokens do
					if token.toUpper().cnContains("CNW") 
					or token.toUpper().cnContains("JLG") 
					or token.toUpper().cnContains("JLI") 
					or token.toUpper().cnContains("NAV") then
						found := true;
						break;
					endif;
				endforeach;
			endwhile;
			
			if not found then 
				missingOwnerArray.add(klass.name &amp; "::" &amp; meth.name);
			endif;			
			
		endforeach;
	
	endforeach;
		
	// check to see if anything was found
	if not missingOwnerArray.isEmpty then
		app.writeLog(CrLf &amp; "The following method(s) have no owner" &amp; CrLf &amp; 
		missingOwnerArray.concatenate(CrLf), LogINFO);
		self.assertNull(missingOwnerArray);
	endif;
	
epilog
	delete excludeMethods;
	delete classes;
	delete tokens;
	delete missingOwnerArray;
	
end;</source>
        <text>MTN-36427</text>
    </JadeMethod>
    <JadeMethod name="tCheckReportHeaderPictures" id="0b127d6c-ad4c-4c54-8d4b-774f68a714fc">
        <source>tCheckReportHeaderPictures();
// jlgmd1
/*

Purpose:			Check that any release report definitions have the correct stretch setting on the logo pictures

Date		Who		Reason
15 Oct 2012	cnwkpd1	PAR #30605 - Fix incorrect picture stretch setting

*/

vars
	rep				: Object;	// JRDReport;
	section			: Any;	// JRDReportSection;
	frame			: Any;	// JRDReportFrame;
	field			: Any;	// JRDOutputField;
	agent 			: Class;
	views,
	templates,
	reports 		: StringArray;
	jrwSchema		: Schema;
	jrdPicClass		: Class;
	sectionType		: Integer;
	
begin
	create views transient;
	create templates transient;
	create reports transient;
	
	agent := rootSchema.getSchema("DevSchema").getClass("DEV_ReleaseExtractAgent");
	agent.sendTypeMsgWithIOParams("getJRWDetails", views, templates, reports);
	
	jrwSchema := rootSchema.getSchema("JadeReportWriterSchema");
	jrdPicClass := jrwSchema.getClass("JRDPictureOutputField");
	
	foreach rep in jrwSchema.getClass("JRDReport").instances where reports.includes(rep.getPropertyValue("name").String) do
	
		foreach section in rep.getPropertyValue("allReportSections").Collection discreteLock do : sectionLoop
		
			sectionType := section.Object.getPropertyValue("sectionType").Integer;
			if sectionType = 1 /* JRDReportSection.SECTION_REPORT_HEADER */ or
			   sectionType = 2 /* JRDReportSection.SECTION_PAGE_HEADER */ then
			   
				foreach frame in section.Object.getPropertyValue("allSectionFrames").Collection discreteLock do
				
					foreach field in frame.Object.getPropertyValue("allReportFields").Collection where field.isKindOf(jrdPicClass) do
					
						self.assertEqualMsg(field.Object.getPropertyValue("stretch").Integer, Picture.Stretch_Pic_Proportional, 
											"Released JRW Report " &amp; rep.getPropertyValue("name").String &amp; " has a picture with an incorrect stretch value");
						
					endforeach;
					
				endforeach;
				
			endif;
		
		endforeach;
	
	endforeach;
	
epilog
	delete views;
	delete templates;
	delete reports;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tCheckTITransUpdateTI" id="3f0d24f3-5325-4495-8180-134b11d4d4c0">
        <source>tCheckTITransUpdateTI();
// cnwmh5
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 April 2015	cnwmc5	Initial creation	PAR 35925

*/

vars
	
	notFoundColl	: ClassColl;
	clsColl 		: ClassColl;
	
	cls				: Class;
	mthd			: Method;
	
	msg				: String;
	
begin

	create clsColl transient;
	create notFoundColl transient;
	
	CM_TITransaction.allSubclasses(clsColl);
	
	foreach cls in clsColl do
		mthd := cls.getMethod("updateTI");
		
		if mthd &lt;&gt; null
		and not mthd.getSource().cnContains("inheritMethod") then
			notFoundColl.add(cls);
		endif;
	endforeach;
	
	if notFoundColl.isNotEmpty then
		foreach cls in notFoundColl do
			msg := msg &amp; cls.name &amp; " does NOT contain 'inheritMethod'." &amp; CrLf;
		endforeach;
	endif;
	
	self.assertEqualMsg(notFoundColl.size, 0, msg);
	
epilog

	delete clsColl;
	delete notFoundColl;
end;</source>
    </JadeMethod>
    <JadeMethod name="tCheckTestNamesCorrect" id="754f3b45-32f4-41c1-a771-5d49fc23860e">
        <source>tCheckTestNamesCorrect();

/*

Purpose:			

Date			Who		Reason
05 August 2011	cnwmh5	Initial creation
29 Aug 2022	jlika1	TFS 54420 - PRP - Enstructure - Financial Requirements
*/

constants
	
	Capitals		: String = "ABCDEFGHIJKLMNOPQRSTUVWXYZ";

vars

	klass			: Class;
	
	meth			: Method;
	
	methodsDict		: MethodNDict;
	classes			: ClassColl;
	failingMethods	: StringArray;
	methodsToIgnore	: StringArray;
	
begin

	// get the class
	klass := currentSchema.getClass("UT_DSL");
	assertNotNull(klass);
	
	// known methods to ignore
	create methodsToIgnore transient;
	methodsToIgnore.add("UT_EDI::tranship_XML_Defn");	
	methodsToIgnore.add("UT_RT_OPS::testRTGReAutoPlanOnRTMachines");
	methodsToIgnore.add("UT_TrackedItem::tranMapLoadMDHReeferMon");
		
	// get all the subclasses
	create classes transient;
	klass.allLocalSubclasses(classes);
	
	create failingMethods transient;
	
	// go throught the class
	foreach klass in classes do
		
		// Get all methods for the class
		methodsDict := klass.cnGetMethods();
		
		foreach meth in methodsDict do
			
			if meth.name[1:1] &lt;&gt; "t" then
				continue;
			endif;
			
			if methodsToIgnore.includes(klass.name &amp; "::" &amp; meth.name) then
				continue;
			endif;
			
			if (meth.name[1:7] = 'tranMap' or meth.name[1:8] = 'transMap') and 
					(klass.name = "UT_Cash" or klass.name = "UT_Invoicing" or klass.name = "UT_EventTransaction" or klass.name = "UT_Contract") then
				continue;
			endif;			
			
			if Capitals.pos(meth.name[2:1], 1) = 0 then
				failingMethods.add(klass.name &amp; "::" &amp; meth.name);
			endif;
			
		endforeach;
		
	endforeach;
	
	if failingMethods.size &gt; 0 then
		app.writeLog(failingMethods.concatenate(CrLf), LogINFO);						// 29/11/2012 cnwmh5
		self.assertEqual(failingMethods.size, 0);
	endif;
	
epilog

	delete methodsToIgnore;
	delete failingMethods;
	delete classes;

end;</source>
    </JadeMethod>
    <JadeMethod name="tCheckTransMapResetToDefault" id="11d739cb-8482-4710-b86f-476fa9f30fea">
        <source>tCheckTransMapResetToDefault();

/*

Purpose:			

Parameters:			

Return Value:		


Date			Who		Reason
18 April 2013	cnwmh5	Initial creation

*/

constants

	CheckForTransactionMapLoad		: String = "transactionMapLoad";
	CheckForResetDefaultTransMap	: String = "resetDefaultTranMap";
	
vars

	klass							: Class;
	meth							: Method;
	methodUsage						: UM_MethodPropertyUsage;
	
	tempMethodsDict					: MethodNDict;
	failingMethodsDict				: MethodNDict;
	classes							: ClassColl;
	methodsToIgnore					: StringArray;
	
	iter							: Iterator;
	
	count							: Integer;
	allRefsSize						: Integer;
	currentCount					: Integer;
	methodSource					: String;
	found							: Boolean;
	oneRead							: Boolean;
	lowestLevelChecked				: Integer;

begin

	// get the class we require to check from
	klass := currentSchema.getClass('UT_UnitTest');
	if klass = null then
		return;
	endif;
	
	// setup the classes array to hold the class and subclass
	create classes transient;
	klass.allLocalSubclasses(classes);
	
	// get the method
	foreach klass in classes do
		meth := klass.getMethodInHTree(CheckForTransactionMapLoad);
		if meth &lt;&gt; null then
			break;
		endif;
	endforeach;
	
	if meth = null then
		return;
	endif;
	
	// methods to ignore
	create methodsToIgnore transient;
	methodsToIgnore.add("UT_DSL::loadTranMap");
	methodsToIgnore.add("UT_FreeStorage::unitTestBeforeClass");
	methodsToIgnore.add("UT_Invoicing::unitTestBeforeClass");
	methodsToIgnore.add("UT_Cash::tCashModule");
	methodsToIgnore.add('UT_Pelindo::tPelindo1TAT_1');
	methodsToIgnore.add('UT_Pelindo::tPelindo1TAT_2');
	methodsToIgnore.add('UT_Pelindo::tPelindo1TAT_3');
	methodsToIgnore.add('UT_Pelindo::tPelindo1TAT_1A');
	
	// get the method tree for the method usage
	create methodUsage transient;
	methodUsage.clearCollections(true);
	methodUsage.setCurrentMethod(meth);
	methodUsage.addMethodToList(meth, 1, false);

	create tempMethodsDict transient;
	create failingMethodsDict transient;
	
	// work out how has resetDefaultTranMap in it's tree
	iter := methodUsage.allRefs.createIterator;
	count := 0;
	allRefsSize := methodUsage.allRefs.size;
	while iter.next(meth) do
	
		write meth.name;
	
		if meth.name = 'tBOLInvoicing' then
			write 'debug';
		endif;
		
		// greater than number of refs then time to leave
		count := count + 1;
		if count &gt; allRefsSize then
			break;
		endif;
		
		// transactionMapLoad record don't care get next method
		if methodUsage.refsByLevel[count] = 1 then
			continue;
		endif;
		
		while true do
			
			// greater than number of refs then time to leave
			if count + 1 &gt; allRefsSize then
				break;
			endif;
			
			// get the end of the tree and then we can work backwards to level 2
			if (methodUsage.refsByLevel[count + 1] &lt; methodUsage.refsByLevel[count]) or 
					(methodUsage.refsByLevel[count + 1] = methodUsage.refsByLevel[count]) then
				break;
			endif;
			
			iter.next(meth);
			count := count + 1;
			
		endwhile;
		
		// initialise the following
		currentCount := count;
		lowestLevelChecked := 0;
		tempMethodsDict.clear();
		found := false;
		oneRead := false;
		
		// work out who doesn't have resetDefaultTransMap in epilog
		while true do
			
			// have processed one so dont want those at the same level or higher			
			if oneRead then
				if lowestLevelChecked &gt; 0 and methodUsage.refsByLevel[count] &gt;= lowestLevelChecked then
					iter.back(meth);
					count := count - 1;
					continue;
				endif;
			endif;
			
			// ignore these methods
			if methodsToIgnore.includes(meth.schemaType.name &amp; "::" &amp; meth.name) then
				break;
			endif;
		
			// methods schemaType is unit test class so process
			if classes.includes(meth.schemaType.Class) then
				
				// cehck to see if it's a runnable unit test
				if meth.isRunnableUnitTestMethod then
					tempMethodsDict.add(meth);
				endif;
				
				// check to see of resetDefaultTransMap is found
				methodSource := self.removeCommentsFromSource(meth.getSource);
				if methodSource.cnContains(CheckForResetDefaultTransMap) then
					found := true;				
				endif;
				
				// stop at this level
				if methodUsage.refsByLevel[count] = 2 then
					break;
				endif;
				
			endif;
				
			// set the lowest level check so dont check levels &gt;= as not required
			if lowestLevelChecked = 0 or methodUsage.refsByLevel[count] &lt; lowestLevelChecked then
				lowestLevelChecked := methodUsage.refsByLevel[count];
			endif;
			
			// get previous meth and update required fields
			iter.back(meth);
			count := count - 1;
			oneRead := true;
		
		endwhile;
		
		// not found so copy to failing dict
		if not found then
			tempMethodsDict.copy(failingMethodsDict);
		endif;
		
		// position us back to the correct record to continue
		while count &lt; currentCount do
			iter.next(meth);
			count := count + 1;
		endwhile;
		
	endwhile;
	
	// if there are any failing then need to know what they are and fail the test
	if not failingMethodsDict.isEmpty then
		app.writeLog("The following test(s) do not implement resetDefaultTranMap in their epilog:", LogINFO);
		foreach meth in failingMethodsDict do
			app.writeLog(meth.String &amp; Tab &amp; meth.schemaType.schema.name &amp; " :: " &amp; meth.schemaType.name &amp; " :: " &amp; meth.name, LogINFO);
		endforeach;
	endif;
	
	self.assertEqual(failingMethodsDict.size, 0);
	
epilog

	delete failingMethodsDict;
	delete tempMethodsDict;
	delete classes;
	delete methodsToIgnore;
	delete methodUsage;
	delete iter;	
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tMultiErrorCodeHandling" id="4a456124-2806-4676-935f-a71413593e11">
        <source>tMultiErrorCodeHandling();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 September 2012	cnwndl1	Initial creation	Par 30633

*/

vars

	excStartValue : Boolean;
	errorCodes : IntegerArray;
	mess : String;
	output : String;

begin

	excStartValue := app.continueCMExceptions;

	create errorCodes transient;
	errorCodes.add(70000);
	errorCodes.add(70000);
	errorCodes.add(80000);
	errorCodes.add(80001);
	
	mess := "The definitive error message.";
	//should be related to error codes 70000, 80000 &amp; 80001";

	on Exception do multiExcHandler(exception);
	
	app.setContinueCMExceptions(true);
	app.raiseMultiReasonExcOrWarning( errorCodes, mess, true, null,  null ); // Warning mode
	
	on Exception do null;
	
	output := app.myPassport.getAllErrorsWarningsAsString;
	self.assertTrueMsg(app.myPassport.allErrors.isEmpty,"Errors raised in Warning mode");
	self.assertTrueMsg(not app.myPassport.allErrorWarnings.isEmpty,"No Warnings raised in Warning mode");
	self.assertTrueMsg( output.pos(mess,1) &gt; 1,"Definitive message not included in Warning mode");
	self.assertTrueMsg( output.pos("70000",1) &gt; 1,"Error number 70000 not included in Warning mode");
	self.assertTrueMsg( output.pos("80000",1) &gt; 1,"Error number 80000 not included in Warning mode");
	self.assertTrueMsg( output.pos("80001",1) &gt; 1,"Error number 80001 not included in Warning mode");
	
	app.myPassport.clearErrorsWarnings();
	
	on Exception do multiExcHandler(exception);
	
	app.setContinueCMExceptions(true);
	app.raiseMultiReasonExcOrWarning( errorCodes, mess, false, null,  null );	//Error mode
	
	on Exception do null;
	
	output := app.myPassport.getAllErrorsWarningsAsString;
	self.assertTrueMsg(not app.myPassport.allErrors.isEmpty,"No Errors raised in Error mode");
	self.assertTrueMsg( output.pos(mess,1) &gt; 1,"Definitive message not included in Error mode");
	self.assertTrueMsg( output.pos("70000",1) &gt; 1,"Error number 70000 not included in Error mode");
	self.assertTrueMsg( output.pos("80000",1) &gt; 1,"Error number 80000 not included in Error mode");
	self.assertTrueMsg( output.pos("80001",1) &gt; 1,"Error number 80001 not included in Error mode");
	
	app.myPassport.clearErrorsWarnings();


epilog

	app.setContinueCMExceptions(excStartValue);
	delete errorCodes;

end;</source>
    </JadeMethod>
    <JadeMethod name="tWebPrimitiveLocaleConversion" id="01881e44-20a8-40fd-8d43-995c2b254941">
        <source>tWebPrimitiveLocaleConversion();
/*
//cnwndl1
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 October 2012	cnwndl1	Initial creation	Par 30622

	In the Web Interface (RIA version) there is no context of what locale is
	being used at the client end.  I.e. It unconditionally expects dates to D/M/Y
	
	New Primitive methods on date, Time and TimeStamp allow the Server end which may be using a locale that does
	not support this date format to present the data correctly, 'String' methods convert String responses 
	back as well.
// 12 May 2016	cnwns1	TFS 488 - Multi Timezone Support
*/

vars

	inTimeStamp : TimeStamp;
	inDate : Date;
	inTime : Time;
	
	workString : String;
	inMilliSecondString : String;
	
	outTimeStamp : TimeStamp;
	outDate : Date;
	outTime : Time;

begin

	inTimeStamp := app.actualTimeServer;// 12 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	inDate := inTimeStamp.date;
	inTime := inTimeStamp.time;
	inMilliSecondString := inTime.milliSecond.String;
	
	//Time testing
	workString := inTime.asStringForWebInterface;
	self.assertTrueMsg( workString.length = 8, "Time String is not 8 characters long, incorrect format for web - test 1.");
	self.assertTrueMsg( workString[1:2].isInteger, "Time String hours not Integer, incorrect format for web - test 1.");
	self.assertTrueMsg( workString[1:2].Integer = inTime.hour, "Time String hours not pos 1 &amp; 2, incorrect format for web - test 1.");
	self.assertTrueMsg( workString[3:1] = ":", "Time String seperator not ':', incorrect format for web - test 1. '" &amp; workString &amp; "'");
	self.assertTrueMsg( workString[4:2].isInteger, "Time String minutes not Integer, incorrect format for web - test 1.");
	self.assertTrueMsg( workString[4:2].Integer = inTime.minute, "Time String minutes not pos 4 &amp; 5, incorrect format for web - test 1.");
	self.assertTrueMsg( workString[6:1] = ":", "Time String seperator not ':', incorrect format for web - test 1. '" &amp; workString &amp; "'");
	self.assertTrueMsg( workString[7:2].isInteger, "Time String seconds not Integer, incorrect format for web - test 1.");
	self.assertTrueMsg( workString[7:2].Integer = inTime.second, "Time String seconds not pos 7 &amp; 8, incorrect format for web - test 1.");
	
	outTime := workString.asTimeFromWebInterface;	
	self.assertTrueMsg( outTime.isValid, "outTime is not valid time - test 1.");
	self.assertTrueMsg( inTime.hour = outTime.hour, "outTime 'hour' is not correct - test 1.");
	self.assertTrueMsg( inTime.minute = outTime.minute, "outTime 'minute' is not correct - test 1.");
	self.assertTrueMsg( inTime.second = outTime.second, "outTime 'second' is not correct - test 1.");
	
	workString := inTime.format("HHmm");
	outTime := workString.asTimeFromWebInterface;	
	self.assertTrueMsg( outTime.isValid, "outTime is not valid time - test 2.");
	self.assertTrueMsg( inTime.hour = outTime.hour, "outTime 'hour' is not correct - test 2.");
	self.assertTrueMsg( inTime.minute = outTime.minute, "outTime 'minute' is not correct - test 2.");
	
	workString := inTime.format("HH:mm");
	outTime := workString.asTimeFromWebInterface;	
	self.assertTrueMsg( outTime.isValid, "outTime is not valid time - test 3.");
	self.assertTrueMsg( inTime.hour = outTime.hour, "outTime 'hour' is not correct - test 3.");
	self.assertTrueMsg( inTime.minute = outTime.minute, "outTime 'minute' is not correct - test 3.");
	
	workString := inTime.format("HHmmss");
	outTime := workString.asTimeFromWebInterface;	
	self.assertTrueMsg( outTime.isValid, "outTime is not valid time - test 4.");
	self.assertTrueMsg( inTime.hour = outTime.hour, "outTime 'hour' is not correct - test 4.");
	self.assertTrueMsg( inTime.minute = outTime.minute, "outTime 'minute' is not correct - test 4.");
	self.assertTrueMsg( inTime.second = outTime.second, "outTime 'second' is not correct - test 4.");
	
	workString := inTime.format("HH:mm:ss");
	outTime := workString.asTimeFromWebInterface;	
	self.assertTrueMsg( outTime.isValid, "outTime is not valid time - test 5.");
	self.assertTrueMsg( inTime.hour = outTime.hour, "outTime 'hour' is not correct - test 5.");
	self.assertTrueMsg( inTime.minute = outTime.minute, "outTime 'minute' is not correct - test 5.");
	self.assertTrueMsg( inTime.second = outTime.second, "outTime 'second' is not correct - test 5.");
	
	workString := inTime.format("HH:mm:ss.") &amp; inMilliSecondString[1:1];
	outTime := workString.asTimeFromWebInterface;	
	self.assertTrueMsg( outTime.isValid, "outTime is not valid time - test 6.");
	self.assertTrueMsg( inTime.hour = outTime.hour, "outTime 'hour' is not correct - test 6.");
	self.assertTrueMsg( inTime.minute = outTime.minute, "outTime 'minute' is not correct - test 6.");
	self.assertTrueMsg( inTime.second = outTime.second, "outTime 'second' is not correct - test 6.");
	self.assertTrueMsg( inTime.milliSecond.String[1:1] = outTime.milliSecond.String, "outTime 'milliSecond' is not correct - test 6.");
	
	workString := inTime.format("HH:mm:ss.") &amp; inMilliSecondString[1:2];
	outTime := workString.asTimeFromWebInterface;	
	self.assertTrueMsg( outTime.isValid, "outTime is not valid time - test 7.");
	self.assertTrueMsg( inTime.hour = outTime.hour, "outTime 'hour' is not correct - test 7.");
	self.assertTrueMsg( inTime.minute = outTime.minute, "outTime 'minute' is not correct - test 7.");
	self.assertTrueMsg( inTime.second = outTime.second, "outTime 'second' is not correct - test 7.");
	self.assertTrueMsg( inTime.milliSecond.String[1:2] = outTime.milliSecond.String, "outTime 'milliSecond' is not correct - test 7.");
	
	workString := inTime.format("HH:mm:ss.") &amp; inMilliSecondString;
	outTime := workString.asTimeFromWebInterface;	
	self.assertTrueMsg( outTime.isValid, "outTime is not valid time - test 8.");
	self.assertTrueMsg( inTime.hour = outTime.hour, "outTime 'hour' is not correct - test 8.");
	self.assertTrueMsg( inTime.minute = outTime.minute, "outTime 'minute' is not correct - test 8.");
	self.assertTrueMsg( inTime.second = outTime.second, "outTime 'second' is not correct - test 8.");
	self.assertTrueMsg( inTime.milliSecond = outTime.milliSecond, "outTime 'milliSecond' is not correct - test 8.");

	//Date Testing
	workString := inDate.asStringForWebInterface;
	self.assertTrueMsg( workString.length = 10, "Date String is not 10 characters long, incorrect format for web - test 9.");
	self.assertTrueMsg( workString[1:2].isInteger, "Date String day not Integer, incorrect format for web - test 9.");
	self.assertTrueMsg( workString[1:2].Integer = inDate.day, "Date String day not pos 1 &amp; 2, incorrect format for web - test 9.");
	self.assertTrueMsg( workString[3:1] = "/", "Date String seperator not '/', incorrect format for web - test 9. '" &amp; workString &amp; "'");
	self.assertTrueMsg( workString[4:2].isInteger, "Date String month not Integer, incorrect format for web - test 9.");
	self.assertTrueMsg( workString[4:2].Integer = inDate.month, "Date String month not pos 4 &amp; 5, incorrect format for web - test 9.");
	self.assertTrueMsg( workString[6:1] = "/", "Date String seperator not '/', incorrect format for web - test 9. '" &amp; workString &amp; "'");
	self.assertTrueMsg( workString[7:4].isInteger, "Date String year not Integer, incorrect format for web - test 9.");
	self.assertTrueMsg( workString[7:4].Integer = inDate.year, "Date String year not pos 7 - 10, incorrect format for web - test 9.");
	
	outDate := workString.asDateFromWebInterface;	
	self.assertTrueMsg( outDate.isValid, "outDate is not valid date - test 9.");
	self.assertTrueMsg( inDate.day = outDate.day, "outDate 'day' is not correct - test 9.");
	self.assertTrueMsg( inDate.month = outDate.month, "outDate 'month' is not correct - test 9.");
	self.assertTrueMsg( inDate.year = outDate.year, "outDate 'year' is not correct - test 9.");
	
	//TimeStamp testing
	workString := inTimeStamp.asStringForWebInterface;
	self.assertTrueMsg( workString.length = 19, "TimeStamp String is not 10 characters long, incorrect format for web - test 10.");
	self.assertTrueMsg( workString[1:2].isInteger, "TimeStamp String day not Integer, incorrect format for web - test 10.");
	self.assertTrueMsg( workString[1:2].Integer = inTimeStamp.date.day, "TimeStamp String day not pos 1 &amp; 2, incorrect format for web - test 10.");
	self.assertTrueMsg( workString[3:1] = "/", "TimeStamp String seperator not '/', incorrect format for web - test 10. '" &amp; workString &amp; "'");
	self.assertTrueMsg( workString[4:2].isInteger, "TimeStamp String month not Integer, incorrect format for web - test 10.");
	self.assertTrueMsg( workString[4:2].Integer = inTimeStamp.date.month, "TimeStamp String month not pos 4 &amp; 5, incorrect format for web - test 10.");
	self.assertTrueMsg( workString[6:1] = "/", "TimeStamp String seperator not '/', incorrect format for web - test 10. '" &amp; workString &amp; "'");
	self.assertTrueMsg( workString[7:4].isInteger, "TimeStamp String year not Integer, incorrect format for web - test 10.");
	self.assertTrueMsg( workString[7:4].Integer = inTimeStamp.date.year, "TimeStamp String year not pos 7 - 10, incorrect format for web - test 10.");
	self.assertTrueMsg( workString[11:1] = " ", "TimeStamp String seperator not ' ', incorrect format for web - test 10. '" &amp; workString &amp; "'");	
	self.assertTrueMsg( workString[12:2].isInteger, "TimeStamp String hours not Integer, incorrect format for web - test 10.");
	self.assertTrueMsg( workString[12:2].Integer = inTimeStamp.time.hour, "TimeStamp String hours not pos 12 &amp; 13, incorrect format for web - test 10.");
	self.assertTrueMsg( workString[14:1] = ":", "TimeStamp String seperator not ':', incorrect format for web - test 1. '" &amp; workString &amp; "'");
	self.assertTrueMsg( workString[15:2].isInteger, "TimeStamp String minutes not Integer, incorrect format for web - test 10.");
	self.assertTrueMsg( workString[15:2].Integer = inTimeStamp.time.minute, "TimeStamp String minutes not pos 15 &amp; 16, incorrect format for web - test 10.");
	self.assertTrueMsg( workString[17:1] = ":", "TimeStamp String seperator not ':', incorrect format for web - test 10. '" &amp; workString &amp; "'");
	self.assertTrueMsg( workString[18:2].isInteger, "TimeStamp String seconds not Integer, incorrect format for web - test 10.");
	self.assertTrueMsg( workString[18:2].Integer = inTimeStamp.time.second, "TimeStamp String seconds not pos 18 &amp; 19, incorrect format for web - test 10.");
	
	outTimeStamp := workString.asTimeStampFromWebInterface;	
	self.assertTrueMsg( outTimeStamp.isValid, "outTimeStamp is not valid time stamp - test 11.");
	self.assertTrueMsg( outTimeStamp.date.isValid, "outTimeStamps date is not valid - test 11.");
	self.assertTrueMsg( outTimeStamp.time.isValid, "outTimeStamps time is not valid - test 11.");
	self.assertTrueMsg( inDate.day = outTimeStamp.date.day, "outTimeStamps 'day' is not correct - test 11.");
	self.assertTrueMsg( inDate.month = outTimeStamp.date.month, "outTimeStamps 'month' is not correct - test 11.");
	self.assertTrueMsg( inDate.year = outTimeStamp.date.year, "outTimeStamps 'year' is not correct - test 11.");
	self.assertTrueMsg( inTime.hour = outTimeStamp.time.hour, "outTimeStamps 'hour' is not correct - test 11.");
	self.assertTrueMsg( inTime.minute = outTimeStamp.time.minute, "outTimeStamps 'minute' is not correct - test 11.");
	self.assertTrueMsg( inTime.second = outTimeStamp.time.second, "outTimeStamps 'second' is not correct - test 11.");
	
	workString := inTimeStamp.asStringForWebInterface[1:10]; //truncated so no time showing
	outTimeStamp := workString.asTimeStampFromWebInterface;	
	self.assertTrueMsg( outTimeStamp.isValid, "outTimeStamp is not valid time stamp - test 12.");
	self.assertTrueMsg( outTimeStamp.date.isValid, "outTimeStamps date is not valid - test 12.");
	self.assertTrueMsg( outTimeStamp.time.isValid, "outTimeStamps time is not valid - test 12.");
	self.assertTrueMsg( outTimeStamp.date = inDate, "outTimeStamps date is incorrect - test 12.");
	self.assertTrueMsg( outTimeStamp.time = "00:00:00".Time, "outTimeStamps time is incorrect - test 12.");
	
	workString := inTimeStamp.asStringForWebInterface[1:13]; // truncated so partial time which is invalid.
	outTimeStamp := workString.asTimeStampFromWebInterface;	
	self.assertTrueMsg( outTimeStamp.isValid, "outTimeStamp is not valid time stamp - test 13.");
	self.assertTrueMsg( outTimeStamp.date.isValid, "outTimeStamps date is not valid - test 13.");
	self.assertTrueMsg( outTimeStamp.time.isValid, "outTimeStamps time is not valid - test 13.");
	self.assertTrueMsg( outTimeStamp.date = inDate, "outTimeStamps date is incorrect - test 13.");
	self.assertTrueMsg( outTimeStamp.time = "00:00:00".Time, "outTimeStamps time is incorrect - test 13.");

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="uCheckCodeForBeginEndLoad" id="f16dc421-6a82-48a9-b992-e15bf5624d99">
        <source>uCheckCodeForBeginEndLoad();

/*

Purpose:			Checks the code to see that there is either a app.cmsEndLoad or endLoad in the epilog

Parameters:			

Return Value:		


Date			Who		Reason
14 April 2011	cnwmh5	Initial creation

*/

vars

	schema				: Schema;
	cls					: Class;
	meth				: Method;

	schemas				: SchemaColl;
	classes				: ClassColl;
	failingMethods		: MethodColl;
	
	failingStr			: String;

begin

	// get the schemas to check.  All subschemas including/under PortSchema
	create schemas transient;
	schema := rootSchema.getSchema("PortSchema");
	schemas.add(schema);
	schema.allSubschemas(schemas);
	
	create failingMethods transient;
	
	// check each schema
	foreach schema in schemas do
	
		// get the classes for the schema
		delete classes;
		classes := schema.getAllClasses(true);
		if classes.isEmpty then
			continue;
		endif;
	
		// check to see if the class's method has cmsBeginLoad, cmsEndLoad, beginLoad or endLoad
		foreach cls in classes where cls.schema = schema do
			self.findBeginEndLoadMethods(cls, failingMethods);
		endforeach;
	
	endforeach;

	if not failingMethods.isEmpty() then
		foreach meth in failingMethods do
			failingStr := failingStr &amp; meth.schemaType.name &amp; Tab &amp; meth.name &amp; CrLf;
		endforeach;
		app.writeLog(failingStr, LogINFO);
	endif;
	
	assertEqual(failingMethods.size, 0);
		
epilog

	delete schemas;
	delete classes;
	delete failingMethods;
	
end;</source>
        <text>&lt;?xml version="1.0"?&gt;
&lt;UT_Additional&gt;
  &lt;Categories&gt;
    &lt;Category CanDelete="false"&gt;SCHEDULE_Weekly&lt;/Category&gt;
  &lt;/Categories&gt;
&lt;/UT_Additional&gt;</text>
    </JadeMethod>
    <JadeMethod name="uCheckForHardCodedIds" id="a2770fa3-40ee-479c-a14e-01c5e55503ca">
        <source>uCheckForHardCodedIds();

/*

Purpose:		Check for hardcoding of products, cargo types and to do tasks	

Date			Who		Reason
27/06/2013		cnwmh5	Initial creation

*/

vars

	klass				: Class;
	meth				: Method;
	localVar 			: JadeLocalVar;
	value				: Any;
	portSchema			: Schema;
	
	classes				: ClassColl;
	methodsDict			: MethodNDict;
	globalConstDict		: ConstantNDict;
	
	iter				: Iterator;
	
	itemsFoundArray		: StringArray512;
	itemsToCheckArray	: StringArray512;
	methodsToIgnore		: StringArray512;
	
	str					: String;
	msgStr				: String;
	methodSource		: String;
	found				: String[10];
	index				: Integer;
	pos					: Integer;
	posCrLf				: Integer;
	attrib				: String;
	tempStr				: String;
	
	length				: Integer;
	sourceLine			: String;	
	posSearchText		: Integer;
	posOpenSqBracket	: Integer;
	posCloseSqBracket	: Integer;
	textToCheck			: String;
	posCommented		: Integer;
	digitCount			: Integer;

begin

	// get PortSchema
	portSchema := rootSchema.getSchema("PortSchema");
	assertNotNull(portSchema);
	
	// get the global constants
	globalConstDict := portSchema.cnGetGlobalConstants();
	
	// methods to ignore
	create methodsToIgnore transient;
	methodsToIgnore.add("UT_JMTCodeVerification::uCheckForHardCodedIds");
	
	// get the class
	klass := currentSchema.getClass("UT_DSL");
	assertNotNull(klass);
	
	// get all the subclasses
	create classes transient;
	classes.add(klass);
	klass.allLocalSubclasses(classes);
	
	create itemsFoundArray transient;
	
	// read through all the class methods source code to see if any of the no nos are found
	foreach klass in classes do
		
		methodsDict := klass.cnGetMethods();
		delete iter;
		iter := methodsDict.createIterator;
		while iter.next(meth) do
		
			// check see if method to ignore
			if methodsToIgnore.includes(klass.name &amp; '::' &amp; meth.name) then
				continue;
			endif;
		
			methodSource := meth.getSource();
			
			if not methodSource.cnContains(".allCargoTypesById") then
				continue;
			endif;
			
			length := methodSource.length;
			posCrLf := -1;
			
			// Read the source and see what is currently already defined
			// read through the file getting current constants
			while true do
			
				if methodSource &lt;&gt; null then
					if posCrLf = -1 then
						posCrLf := 1;
					else
						posCrLf := posCrLf + 2;
					endif;
					if (posCrLf + 2) &gt; methodSource.length then
						break;
					endif;
					methodSource := methodSource[posCrLf:end];
				endif;
			
				posCrLf := 1;
				posCrLf := methodSource.pos(CrLf, posCrLf);
				if posCrLf = 0 or (posCrLf + 1) &gt; length then
					break;
				endif;
				sourceLine := methodSource[1:posCrLf];	
				
				// check to see if search text on the line if not then next line
				posSearchText := sourceLine.pos(".allCargoTypesById", 1);
				if posSearchText = 0 then
					continue;
				endif;
				
				// check to see if [ after search text, if not then don't require
				posOpenSqBracket := sourceLine.pos("[", posSearchText);
				if posOpenSqBracket = 0 then
					continue;
				endif;
				
				// check the text to see if harcoded number
				posOpenSqBracket := posOpenSqBracket + 1;
				textToCheck := sourceLine.scanUntil("]", posOpenSqBracket).trimBlanks;
				
				// following code is fine in these methods
				if (klass.name = "UT_Stops" and (meth.name = "tCCMS1791_PAR20466" or meth.name = "tStopsTableTemplateTest")) or 
						(klass.name = "UT_PackUnpack" and meth.name = "tPackWeightCheckMobile") then
					continue;
				endif;
							
				// check to see if it's a class constant
				if klass.findConstant(textToCheck) &lt;&gt; null and klass.findConstantInSuperschema(textToCheck) &lt;&gt; null then
					continue;
				endif;
			
				// check to see if global constant
				if globalConstDict[textToCheck] &lt;&gt; null then
					continue;
				endif;
			
				digitCount := 0;
				foreach index in 1 to textToCheck.length do
					if textToCheck[index].isNumeric then
						digitCount := digitCount + 1;
					endif;
				endforeach;
				
				// check to see if uses .getCargoTypeIDFromAbbrev
				if sourceLine.cnContains(".getCargoTypeIDFromAbbrev") then
					continue;
				endif;
				
				// check if passed in and check passed in code
				
				
				app.writeLog(klass.name &amp; '::' &amp; meth.name &amp; Tab &amp; textToCheck &amp; Tab &amp; klass.findConstant(textToCheck).String &amp; Tab &amp; 
					klass.findConstantInSuperschema(textToCheck).String &amp; Tab &amp; portSchema.findGlobalConstantInBranch(textToCheck).String &amp; Tab &amp; 
					globalConstDict[textToCheck].String, LogINFO);
			
				// add to the array of items found
				if not itemsFoundArray.includes(klass.name &amp; '::' &amp; meth.name) then
					itemsFoundArray.add(klass.name &amp; '::' &amp; meth.name);
				endif;
				
			endwhile;
			
			
			
			
		
		endwhile;
		
	endforeach;
	
	foreach str in itemsFoundArray do
		msgStr := msgStr &amp; str &amp; CrLf;
	endforeach;
	
	assertEqualMsg(itemsFoundArray.size, 0, msgStr);
	

epilog

	delete iter;
	delete classes;
	delete itemsFoundArray;
	delete methodsToIgnore;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="xChangedAttribArray" id="d25c4f14-18e7-4f0a-854d-2a1678462c27">
        <source>xChangedAttribArray(_line : String; _epilog : Boolean; _changedAttribArray : StringArray512 io) : String;

/*

Purpose:		Check / Populate the attribute which have been changed

Date			Who		Reason
29/04/2014		cnwmh5	Initial creation
23/07/2014		cnwmh5	Rewrite to handle things better

*/

vars

	tempLine						: String;
	tempLine2						: String;
	pos								: Integer;
	pos1							: Integer;
	attrib	 						: String;
	scanChar						: Character;
	scanFor							: String;
	methodName						: String;

begin

	tempLine := _line;
	tempLine := tempLine.replaceString(" ", "");
	attrib := null;

	pos := tempLine.pos(".setConfig", 1);
	///write pos.String;
	methodName := tempLine.scanUntil("(", pos);
	methodName := methodName[2:end];
	///write methodName;
	attrib := tempLine.scanUntil(",)", pos).trimBlanks();
	
	if attrib.length &lt;= 1 then
		return null;
	endif;
	attrib := attrib[2:end].trimBlanks();
	///write attrib;
	
	if not _epilog then
		if not _changedAttribArray.includes(attrib) then
			_changedAttribArray.add(attrib);
			return attrib;
		endif;
	else
		if not _changedAttribArray.includes(attrib) then
			return attrib;
		endif;
	endif;
	
	return null;
	
epilog

end;
</source>
        <Parameter name="_line" type="String"/>
        <Parameter name="_epilog" type="Boolean"/>
        <Parameter name="_changedAttribArray" type="StringArray512" usage="io"/>
        <ReturnType type="String"/>
    </JadeMethod>
