    <JadeMethod name="erase" id="411c46c7-7bce-4e85-bddf-998d1c927e9d">
        <updating/>
        <source>erase(_eraseLevel: Integer) updating;
//NFS 3711: We now need to get rid of all visit records
//relating to this truck before deleting it

vars
	vvr : CM_VehicleVisitRecord;
begin
	exclusiveLock(self);
	
	//self.visitRecords.purge;	// ### TFS 51994 01Oct2021 NAVPW1
	
	// ### TFS 51994 01Oct2021 NAVPW1
	foreach vvr in self.visitRecords do
		vvr.erase(_eraseLevel);
	endforeach;
	// ### TFS 51994 01Oct2021 NAVPW1

	inheritMethod(_eraseLevel);

end;</source>
        <Parameter name="_eraseLevel" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="findLocation" id="1b0187a9-5a4c-41f5-815e-04cbaa697c11">
