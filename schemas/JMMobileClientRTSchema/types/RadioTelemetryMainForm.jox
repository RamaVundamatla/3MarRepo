    </JadeMethod>
    <JadeMethod name="doToDoTaskUpdate" id="78344556-175b-4411-aea9-6225a49a743d">
        <updating/>
        <source>doToDoTaskUpdate() protected, updating;
// -------------------------------------------
// Created 30 January 2006 by cnwdvb1
// -------------------------------------------
vars
	errorStr		: String;
	allTasksObj		: ObjectSet;
	
begin
	self.aWarnings	:=	false;
	
	create allTasksObj transient;
	tblDataToDo.getChangedTasks(allTasksObj);
	
	while true do
		if app.myRTGuiAgent.updateToDoTasksForTI(self, allTasksObj, errorStr, self.aState, self.aWarnings) then
			self.aIsSaveRequired	:=	false;
			self.updateFromState();
		else
			if self.showMessage(errorStr, true) then
				continue;
			endif;
		endif;
		
		break;
	endwhile;
epilog
	delete allTasksObj;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doUpdateGrade" id="adcbf691-cce9-4447-ac28-e21c43478666">
        <updating/>
        <source>doUpdateGrade(_gradeCode:Integer):Boolean updating, protected;
// --------------------------------------------------------------------------------
// Created:		03 February 2006 by cnwdad1
//
// Purpose:		Updates the Grade with the specified code (parameter) to make it the
//				current Grade for the current contains.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	errorStr	: String;
	
begin
	self.aWarnings	:=	false;

	// Darrell, don't check for null as 0 is valid	
//	if _gradeCode = null then
//		return false;
//	endif;
	
	while true do
		if app.myRTGuiAgent.updateGradeForTI(self, _gradeCode, errorStr, self.aState, self.aWarnings) then
			self.aIsSaveRequired	:=	false;
			self.updateFromState();
		else
			if self.showMessage(errorStr, true) then
				continue;
			endif;
		endif;
		
		break;
	endwhile;
	
	return true;
end;</source>
        <access>protected</access>
        <Parameter name="_gradeCode" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doUpdateToDoTaskTs" id="46532ce4-9308-4cc2-b24c-76d28059c60e">
        <updating/>
        <source>doUpdateToDoTaskTs(_taskCode:Integer; _timeStamp:TimeStamp):Boolean protected, updating;
// -------------------------------------------
// Created 31 January 2006 by cnwdvb1
// -------------------------------------------
vars
	errorStr		: String;
	
begin
	self.aWarnings	:=	false;
	
	if app.myRTGuiAgent.updateToDoTaskTs(self, _taskCode, _timeStamp, errorStr, self.aState, self.aWarnings) then
		self.aIsSaveRequired	:=	false;
		self.updateFromState();
		return true;
	else
		if self.showMessage(errorStr, true) then
			return false;
		endif;
	endif;
	
	return true;
end;</source>
        <access>protected</access>
        <Parameter name="_taskCode" type="Integer"/>
        <Parameter name="_timeStamp" type="TimeStamp"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doUserNotify" id="9e48f66e-9f83-4e99-b2c4-dc69a7397a8d">
        <updating/>
        <source>doUserNotify(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating, protected;

/*

Date		Who		Reason
24 Jan 2006	cnwdvb1	Created 
12 Mar 2008	cnwkpd1	PAR #16010 - CCMS Otago 1502 - Thin Client RT Enhancements

*/

begin
	if not self.aIsLoggedOn then
		return;
	endif;

	if eventType = Event_Delete_Queue_Entry then
		self.setAviOnOff(false);
		self.updateViewCaption();						// PAR #16010
		
	elseif eventType = EVENT_MACH_BROADCAST_MSG then
		self.showMessage(userInfo.String, false);
		
	elseif eventType = EVENT_MACHQUEUE_ALTERED then
		self.doGetCurrentSettings();					// PAR #16010
		self.tableOptionsDetailsPopulate();
		self.tableQueueEntriesInitialize();
		self.makeEnquiryTableVisible(self.tblEnquiry);
		self.setEnquiryScrollButtons();
		self.showMessage(userInfo.String, false);
	
	elseif eventType = Event_Add_Queue_Entry then
		self.setAviOnOff(true);
		self.updateViewCaption();						// PAR #16010

	endif;
end;</source>
        <access>protected</access>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
