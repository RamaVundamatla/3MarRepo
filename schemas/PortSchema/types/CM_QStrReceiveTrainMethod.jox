    <JadeMethod name="getTrainsForTerminal" id="c8658814-925d-4a7e-9d1c-0cac0601d8e5">
        <source>getTrainsForTerminal( _term : CM_Terminal; _trainDict : CM_TrainByDepatureDTDict input );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 April 2021	navndl1	Initial creation	TFS 50906

*/

constants
	
vars

	train : CM_Train;
	trainSet : CM_TrainSet;
	
begin

	if _term = null then
		return;
	endif;
	
	create trainSet transient;
	_term.getValidLocationActivityObjs( trainSet, null, null, null );

	trainSet.copy( _trainDict );

epilog

	delete trainSet;

end;</source>
        <Parameter name="_term" type="CM_Terminal"/>
        <Parameter name="_trainDict" type="CM_TrainByDepatureDTDict" usage="input"/>
    </JadeMethod>
