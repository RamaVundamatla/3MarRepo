    <JadeMethod name="validateMe" id="9fedbcf7-b03d-4a37-b93d-9c79a873572e">
        <source>validateMe();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 January 2013	cnwmc5	Initial creation HAT 2189

*/

vars

begin
	if self.make = null then
	//	app.raiseCMException1(REQUIRED_FIELD, app.getErrorString(Make), null, null);
		app.raiseCMException1(Input_required_field_Required, app.getErrorString(Make), null, null); // cnwdb2	PAR 35364


	endif;
epilog

end;</source>
    </JadeMethod>
