		self.tblResponseCodes.addItem(Tab &amp; "No Content (204)");
		self.tblResponseCodes.addItem(Tab &amp; "Not Found (404)");
		self.tblResponseCodes.addItem(Tab &amp; "OK (200)");
		self.tblResponseCodes.addItem(Tab &amp; "Unauthorised (401)");
		self.tblResponseCodes.addItem(Tab &amp; "System Error (500)");		
	endif;
	
	self.chkAllResponseCodes.value := true;
	
	self.doSelectUnselectAll(true, self.tblResponseCodes);
epilog
	
end;</source>
