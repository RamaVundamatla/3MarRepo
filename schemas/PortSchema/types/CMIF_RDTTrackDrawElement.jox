    <JadeMethod name="drawFace" id="7383b96d-8f45-4e87-8a5e-37815bb02026">
        <source>drawFace(_x1: Real; _y1: Real; _x2: Real; _y2: Real; _frame: Frame input; _scaleFactor: Real; _isLandscape: Boolean; _flipH: Boolean; _flipV: Boolean; _mode : Integer) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 June 2010	cnwjk3	Initial creation

*/

constants
	//       	  --BBGGRR
	Brown 		= #00000099;
vars
	railYOffsetPixels,
	railHeightPixels,
	sleeperWidthPixels,
	sleeperHeightPixels,
	gapHeightPixels,
	sx, sy,
	x1, y1,
	x2, y2			: Real;
	count			: Integer;
begin
	x1 := _x1;
	y1 := _y1;
	x2 := _x2;
	y2 := _y2;
	
	sleeperHeightPixels := self.getSizeInPixels(1, _scaleFactor);
	sleeperWidthPixels := self.getSizeInPixels(1, _scaleFactor);
	gapHeightPixels := self.getSizeInPixels(1, _scaleFactor);
	railHeightPixels := self.getSizeInPixels(.5, _scaleFactor);
	railYOffsetPixels := self.getSizeInPixels(4.7, _scaleFactor);
		
	self.gridPointsToElementPoints(x1, y1, x2, y2, _scaleFactor, _isLandscape, _flipH, _flipV);

	
	_frame.drawFillColor := Black;
	
	// Draw the rail
	_frame.drawFilledRectangle(x1, y1 + railYOffsetPixels, x2, y1 + railYOffsetPixels + railHeightPixels, Black);
		
	// Draw the sleepers
	_frame.drawFillColor := Brown;
	sx := x1;
	foreach count in 1 to 5 do
		if count = 1 then
			sx := sx + gapHeightPixels / 2;
		else
			sx := sx + gapHeightPixels;
		endif;
		_frame.drawFilledRectangle(sx, y1 + railYOffsetPixels + railHeightPixels, sx + sleeperWidthPixels, y1 + railYOffsetPixels + railHeightPixels + sleeperHeightPixels, Brown);
		sx := sx + sleeperWidthPixels;
	endforeach;
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_x1" type="Real"/>
        <Parameter name="_y1" type="Real"/>
        <Parameter name="_x2" type="Real"/>
        <Parameter name="_y2" type="Real"/>
        <Parameter name="_frame" type="Frame" usage="input"/>
        <Parameter name="_scaleFactor" type="Real"/>
        <Parameter name="_isLandscape" type="Boolean"/>
        <Parameter name="_flipH" type="Boolean"/>
        <Parameter name="_flipV" type="Boolean"/>
        <Parameter name="_mode" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="drawTopDown" id="071ab1e4-7d76-4de2-9af7-271a17811978">
        <source>drawTopDown(_x1: Real; _y1: Real; _x2: Real; _y2: Real; _frame: Frame input; _scaleFactor: Real; _isLandscape: Boolean; _flipH: Boolean; _flipV: Boolean; _mode : Integer) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 May 2010	cnwjk3	Initial creation

*/
constants
	//       	  --BBGGRR
	Brown 		= #00000099;
vars
	railXOffsetPixels,
	railWidthPixels,
	sleeperWidthPixels,
	sleeperHeightPixels,
	gapHeightPixels,
	sx, sy,
	x1, y1,
	x2, y2			: Real;
	count			: Integer;
begin
	x1 := _x1;
	y1 := _y1;
	x2 := _x2;
	y2 := _y2;
	
	sleeperHeightPixels := self.getSizeInPixels(1, _scaleFactor);
	sleeperWidthPixels := self.getSizeInPixels(4, _scaleFactor);
	gapHeightPixels := self.getSizeInPixels(1, _scaleFactor);
	railXOffsetPixels := self.getSizeInPixels(.5, _scaleFactor);
	railWidthPixels := self.getSizeInPixels(.5, _scaleFactor);
		
	self.gridPointsToElementPoints(x1, y1, x2, y2, _scaleFactor, _isLandscape, _flipH, _flipV);

	
	_frame.drawFillColor := Brown;
	
	if _isLandscape then
		// Draw the sleepers
		sx := x1;
		foreach count in 1 to 5 do
			if count = 1 then
				sx := sx + gapHeightPixels / 2;
			else
				sx := sx + gapHeightPixels;
			endif;
			_frame.drawFilledRectangle(sx, y1, sx + sleeperHeightPixels, y2, Brown);
			sx := sx + sleeperHeightPixels;
		endforeach;
		
		// Draw the rails
		_frame.drawFillColor := Black;
		_frame.drawFilledRectangle(x1, y1 + railXOffsetPixels, x2, y1 + railXOffsetPixels + railWidthPixels, Black);
		_frame.drawFilledRectangle(x1, y2 - railXOffsetPixels, x2, y2 - railXOffsetPixels - railWidthPixels, Black);
	else
		// Draw the sleepers
		sy := y1;
		foreach count in 1 to 5 do
			if count = 1 then
				sy := sy + gapHeightPixels / 2;
			else
				sy := sy + gapHeightPixels;
			endif;
			_frame.drawFilledRectangle(x1, sy, x2, sy + sleeperHeightPixels, Brown);
			sy := sy + sleeperHeightPixels;
		endforeach;
		
		// Draw the rails
		_frame.drawFillColor := Black;
		_frame.drawFilledRectangle(x1 + railXOffsetPixels, y1, x1 + railXOffsetPixels + railWidthPixels, y2, Black);
		_frame.drawFilledRectangle(x2 - railXOffsetPixels, y1, x2 - railXOffsetPixels - railWidthPixels, y2, Black);
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_x1" type="Real"/>
        <Parameter name="_y1" type="Real"/>
        <Parameter name="_x2" type="Real"/>
        <Parameter name="_y2" type="Real"/>
        <Parameter name="_frame" type="Frame" usage="input"/>
        <Parameter name="_scaleFactor" type="Real"/>
        <Parameter name="_isLandscape" type="Boolean"/>
        <Parameter name="_flipH" type="Boolean"/>
        <Parameter name="_flipV" type="Boolean"/>
        <Parameter name="_mode" type="Integer"/>
    </JadeMethod>
</Class>
