    <JadeMethod name="setForCreate" id="4aaea9c5-f726-4792-a18d-e25fc5a05b1c">
        <updating/>
        <source>setForCreate(_proxyExtractDef: CM_DataDumpExtractDef) updating;
// ---------------------------------------------------------------------------
// Created:     27 May 2003 by cnwsb1
// ---------------------------------------------------------------------------
vars
	proxyClass : CM_DataDumpExtractClass;

begin
	self.setCommon(_proxyExtractDef);
	
	foreach proxyClass in _proxyExtractDef.allDataDumpExtractClasses do
		self.createExtractClass(proxyClass);
	endforeach;
end;</source>
        <Parameter name="_proxyExtractDef" type="CM_DataDumpExtractDef"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="1bc00359-c31a-41b8-a147-42d5712e662b">
        <updating/>
        <source>setForUpdate(_proxyExtractDef: CM_DataDumpExtractDef) updating;
// ---------------------------------------------------------------------------
// Created:     27 May 2003 by cnwsb1
// ---------------------------------------------------------------------------
// 29/08/2012	cnwcs5	par 30292 - use updateObjectEdition instead of updateEdition
vars
	proxyExtractClass : CM_DataDumpExtractClass;
	realExtractClass : CM_DataDumpExtractClass;
	psqlColumn  : CM_DataDumpSQLColumn;
	sqlColumn  : CM_DataDumpSQLColumn;
	expectedEdition : Integer;
	toDelete : CM_DataDumpExtractClassSet;
	sortedRealExtractClasses : CM_DataDumpExtractClassArray;

begin
	create sortedRealExtractClasses transient;
	self.updateObjectEdition (self);	// par 30292

	self.setCommon(_proxyExtractDef);
	
	create toDelete transient;
	exclusiveLock(self.allDataDumpExtractClasses);
	self.allDataDumpExtractClasses.copy(toDelete);
	
	// 1. Create new extract classes, update existing ones
	foreach proxyExtractClass in _proxyExtractDef.allDataDumpExtractClasses do
		proxyExtractClass.pxyGetRealObjectAndEdition(realExtractClass, expectedEdition);
		if realExtractClass = null then
			realExtractClass := self.createExtractClass(proxyExtractClass);
			foreach psqlColumn in proxyExtractClass.allDataDumpSQLColumns do
				create sqlColumn persistent;
				sqlColumn.setForCreate(psqlColumn);
				realExtractClass.allDataDumpSQLColumns.add(sqlColumn);
			endforeach;
		else
			toDelete.remove(realExtractClass);
			exclusiveLock(realExtractClass);
			if realExtractClass.edition &lt;&gt; expectedEdition then
				app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'dataDumpExtractClass', null, null);
				return;
			endif;
			realExtractClass.setForUpdate(proxyExtractClass);
		endif;

		sortedRealExtractClasses.add(realExtractClass);
	endforeach;
	
	// 2. Delete missing extract classes
	foreach realExtractClass in toDelete do
		realExtractClass.allDataDumpSQLColumns.purge;
		delete realExtractClass;
	endforeach;
	
	// 3. Make the array sequence the same as the proxy array sequence
	self.allDataDumpExtractClasses.updateSameAsArray(sortedRealExtractClasses);
	
epilog
	delete toDelete;
	delete sortedRealExtractClasses;
end;</source>
        <Parameter name="_proxyExtractDef" type="CM_DataDumpExtractDef"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="f12f3f81-e8d2-48cf-a68b-1c6d5720d2e4">
        <updating/>
        <source>setProxy(_description: String; _extractFormat: Integer; _isActive, _createSQLStatements: Boolean;
		_fileFolderName, _edbConnectionString, 
		_edbPassword, _edbServerName, _edbUserName, _edbMachineDSN: String;
		_oidColumnName : String; _oidFormat : Integer; 
		_sqlDatabaseName : String; _sqlServerVersion : String;
		_definitionModified : Boolean;
		_useSQLControlTable : Boolean;
		_terminal: CM_Terminal;
		_alertLimit : Integer;
		_ignoreDeletesFromUser : CM_User	//07 Jan 2014	NDL	Par 33264
		) updating;
// ---------------------------------------------------------------------------
// Created:     27 May 2003 by cnwsb1
// ---------------------------------------------------------------------------
begin
	self.raiseExceptionIfNotTransient(method);
	
	self.description         := _description[1:self.description.maxLength].trimBlanks;
	self.extractFormat       := _extractFormat;
	self.fileFolderName      := _fileFolderName[1:self.fileFolderName.maxLength].trimBlanks.stripTrailingSlashes;
	self.edbConnectionString := _edbConnectionString.trimBlanks;
	self.edbUserName         := _edbUserName[1:self.edbUserName.maxLength].trimBlanks;
//	self.edbPassword         := _edbPassword[1:self.edbPassword.maxLength].trimBlanks;
	self.setProxyPw( _edbPassword, null );	//07 Sep 2021	NDL	TFS 51926
	self.edbServerName       := _edbServerName[1:self.edbServerName.maxLength].trimBlanks;
	self.edbMachineDSN       := _edbMachineDSN[1:self.edbMachineDSN.maxLength].trimBlanks;
	self.oidColumnName       := _oidColumnName;
	self.oidFormat           := _oidFormat;
	self.sqlDatabaseName     := _sqlDatabaseName;
	self.sqlServerVersion    := _sqlServerVersion;
	self.createSQLStatements := _createSQLStatements;
	self.definitionModified  := _definitionModified;
	self.useSQLControlTable  := _useSQLControlTable;
	self.isActive            := _isActive;
	self.myTerminal          := _terminal;
	self.alertLimit 		 := _alertLimit;
	self.ignoreDeletesFromUser := _ignoreDeletesFromUser;	//07 Jan 2014	NDL	Par 33264
end;</source>
        <Parameter name="_description" type="String"/>
        <Parameter name="_extractFormat" type="Integer"/>
        <Parameter name="_isActive" type="Boolean"/>
        <Parameter name="_createSQLStatements" type="Boolean"/>
        <Parameter name="_fileFolderName" type="String"/>
        <Parameter name="_edbConnectionString" type="String"/>
        <Parameter name="_edbPassword" type="String"/>
        <Parameter name="_edbServerName" type="String"/>
        <Parameter name="_edbUserName" type="String"/>
        <Parameter name="_edbMachineDSN" type="String"/>
        <Parameter name="_oidColumnName" type="String"/>
        <Parameter name="_oidFormat" type="Integer"/>
        <Parameter name="_sqlDatabaseName" type="String"/>
        <Parameter name="_sqlServerVersion" type="String"/>
        <Parameter name="_definitionModified" type="Boolean"/>
        <Parameter name="_useSQLControlTable" type="Boolean"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_alertLimit" type="Integer"/>
        <Parameter name="_ignoreDeletesFromUser" type="CM_User"/>
    </JadeMethod>
