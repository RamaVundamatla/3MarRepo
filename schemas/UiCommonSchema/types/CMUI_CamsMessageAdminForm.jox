    <JadeMethod name="setupResponseCodeTbl" id="e76118c4-48a8-46da-97b9-0cd329c7ff2d">
        <source>setupResponseCodeTbl();
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
04 July 2024	navcs2	ChangeRequest 63797: EUP | CAMS Search for outgoing messages - CAMS Message Enquiry

*/

vars

begin
	if self.tblResponseCodes.rows &lt; 1 then
		self.tblResponseCodes.clear;
