Return Value:		

Date		Who		Reason
21 May 2021	navndl1	Initial creation	TFS 51243

*/

vars

begin

	self.myCargoType := _cargoType;

epilog

end;</source>
        <Parameter name="_cargoType" type="CM_CargoType"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="16ad2041-d763-4080-879f-d12c95585f5f">
        <updating/>
        <source>setProxy(	_canFactor : Boolean;
			_code : String;
			_description : String;
			_myCargoType : CM_CargoType;
			_myProduct : CM_Product;
			_defaultQuantity : Integer;
			_defaultVolume : Decimal;
			_defaultWeight : Decimal;
			_instructions : String
			) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 May 2021	navndl1	Initial creation	TFS 51243

*/

vars

begin
	
	self.code := _code;
	self.description := _description;
	
	self.canFactor := _canFactor;
	
	self.defaultQuantity := _defaultQuantity;
	self.defaultVolume := _defaultVolume;
	self.defaultWeight := _defaultWeight;
	self.instructions := _instructions;
	
	self.myProduct := _myProduct;
	self.myCargoType := _myCargoType;

epilog

end;</source>
        <Parameter name="_canFactor" type="Boolean"/>
        <Parameter name="_code" type="String"/>
        <Parameter name="_description" type="String"/>
        <Parameter name="_myCargoType" type="CM_CargoType"/>
        <Parameter name="_myProduct" type="CM_Product"/>
        <Parameter name="_defaultQuantity" type="Integer"/>
