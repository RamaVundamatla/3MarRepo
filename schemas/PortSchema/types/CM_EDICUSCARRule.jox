        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getFunctionCode" id="584d9bcd-2ab5-45b7-bbef-2b762111214a">
        <source>getFunctionCode(_description :String):Integer;

/*

Purpose:			

Parameters:			

Return Value:		
/* Changes

Date		Name	TFS#		Description
============================================================================
21 May 2014	cnwrd1				Initial creation
20 May 2019	jlgka1	42732		PNL - CUSCAR (Bayplan-Style)
============================================================================*/
begin

	if _description = self.Function_LOC_1_1_TODO_Desc then
		return self.Function_LOC_1_1_TODO;
	elseif _description = self.Function_FTX_1_1_RemarksDesc then
		return self.Function_FTX_1_1_Remarks;
	elseif _description = self.Function_NAD_1_1_ConsigneeDesc then
		return self.Function_NAD_1_1_Consignee;
	elseif _description = self.Function_FTX_1_1_DescriptDesc then	//29 Jan 2020	NDL	TFS 48360
		return self.Function_FTX_1_1_Description;
	else
		return null;
	endif;
	
epilog

end;</source>
        <Parameter name="_description" type="String"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getFunctionDescription" id="d6da0c70-1b06-4f6b-90f6-c674188971c9">
        <source>getFunctionDescription():String;

/*

Purpose:			

Parameters:			

Return Value:		
/* Changes

Date		Name	TFS#		Description
============================================================================
21 May 2014	cnwrd1				Initial creation
20 May 2019	jlgka1	42732		PNL - CUSCAR (Bayplan-Style)
============================================================================*/

vars
	code : Integer;
begin

	code := self.function;
	
	if code = self.Function_LOC_1_1_TODO then
		return self.Function_LOC_1_1_TODO_Desc;
	elseif code = self.Function_NAD_1_1_Consignee then
		return self.Function_NAD_1_1_ConsigneeDesc;
	elseif code = self.Function_FTX_1_1_Remarks then
		return self.Function_FTX_1_1_RemarksDesc;
		
	elseif code = self.Function_FTX_1_1_Description then	//29 Jan 2020	NDL	TFS 48360
		return self.Function_FTX_1_1_DescriptDesc;
	
	else
		return null;
	endif;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
