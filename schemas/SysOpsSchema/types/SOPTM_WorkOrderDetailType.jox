    <JadeMethod name="showThumbnail" id="9cd2b5f5-f99b-4d33-9dd0-3db53552661e">
        <updating/>
        <source>showThumbnail(pObj: CM_WorkOrderDetailType) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 Sep 2021 navma1 ChangeRequest 51925: SAL - Web Portal Cargo Work Orders

*/

vars
	tbl			: CM_EntryTable;
begin

	if pObj = null then
		return;
	endif;
	
	tbl := self.myForm.tblInput1;
	
	tbl.setValueByName(ETRow_Description, pObj.description);
	tbl.setValueByName(ETRow_RequiresApproval, pObj.requiresApproval);
	tbl.setValueByName(ETRow_Type, pObj.getWorkOrderTypeDescription);
	
epilog

end;</source>
        <Parameter name="pObj" type="CM_WorkOrderDetailType"/>
    </JadeMethod>
</Class>
