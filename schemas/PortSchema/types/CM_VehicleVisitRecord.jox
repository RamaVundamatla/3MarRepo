    <JadeMethod name="getBulkVisitType" id="41bf53bf-01a3-4f3b-a6b9-4f5e0b34e5b4">
        <source>getBulkVisitType() : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 January 2017	cnwns1	Initial creation

*/

vars
	hasReceive : Boolean;
	hasRelease : Boolean;
begin
    hasReceive := self.allReceivedTrackedItems.size &gt; 0;
	if not self.allGateEntities.isEmpty then  //27.07.2017 cnwma1
		hasRelease := self.allGateEntities.first.isRelease ;
	endif;
	if hasRelease and hasReceive then
		return app.getErrorString(Both);
	elseif hasReceive then
		return app.getErrorString(ReceivalStr);
	elseif hasRelease then
		return app.getErrorString(Release);
	else
		return null;
	endif;
end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
