    <JadeMethod name="outputAsCSV" id="abeba220-0a6a-4c29-b05a-62e43f27e5ad">
        <updating/>
        <source>outputAsCSV(_defaultFileName : String; _openThisFile : Boolean) updating;
// ---------------------------------------------------------------------------
// Created:     13 March 2007 by cnwrs2
//
// Purpose:     
// _openThisFile parameter added for scripted call for tranship extract 23659
// ---------------------------------------------------------------------------
vars
	fileName	: String;
	filePath	: String;
	file		: File;

begin

	// TFS 2352 par 37844 clean up the file name first
	fileName := _defaultFileName.stripInvalidFileNameCharacters();

	if _openThisFile then
		filePath := fileName;
	else
	// pass null path so opens where last open at
		filePath := app.getFilePath(null, '*.csv', fileName, false);
	endif;

	if filePath = null then
		return;
	endif;	
	
	if filePath.toLower.pos('.csv', 1) &lt;= 0 then
		filePath := filePath &amp; '.csv';
	endif;
	
	create file transient;
	file.fileName := filePath;
	file.mode := File.Mode_Output;
	if _openThisFile then
		file.usePresentationFileSystem := false;
	endif;

	if (not file.tryOpen) then
		app.raiseCMException1(FileUnavailable, file.fileName, null, null);	
		return;
	endif;
		
	self.myTMCController.transhipOutputOnly := self.transhipOutputOnly;		// for internal tranship-only extract
	self.exportCargoCSV(file, null);
	
epilog
	if file &lt;&gt; null then
		file.close;
		delete file;
	endif;

end;</source>
        <Parameter name="_defaultFileName" type="String"/>
        <Parameter name="_openThisFile" type="Boolean"/>
    </JadeMethod>
