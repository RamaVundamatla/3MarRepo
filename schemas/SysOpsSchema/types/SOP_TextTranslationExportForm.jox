    <JadeMethod name="cmbLocale_displayRow" id="f616b4ca-1c34-448a-80d2-8666aefb42a7">
        <controlMethod name="ComboBox::displayRow"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbLocale_displayRow(
			combobox: ComboBox input; 
			obj: Object; 
			lstIndex: Integer; 
			bcontinue: Boolean io):String updating;

vars
	locale : CM_Locale;
begin
	locale := obj.CM_Locale;
	if locale &lt;&gt; agent.myRoot.allLocales[StandardTextLocale.padLeadingWith("0", 4)] then
		return obj.CM_Locale.vLocaleIdAndDescription;
	endif;
end;
</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
        <Parameter name="obj" type="Object"/>
        <Parameter name="lstIndex" type="Integer"/>
        <Parameter name="bcontinue" type="Boolean" usage="io"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="doBaseFormCancel" id="7e4e952e-31ce-4e77-b6f0-f0707366dc02">
        <updating/>
        <source>doBaseFormCancel() updating, protected;

/*
Purpose:	To make sure the alt+C key gets actioned correctly.

Date				Who		Reason
09 November 2009	cnwrl1	Initial creation as part of PAR 21253
*/
	
vars
	
begin
