    <JadeMethod name="doBtnModalOpt1Click" id="4dec66db-de4a-4fd5-868a-f1fff729618f">
        <updating/>
        <source>doBtnModalOpt1Click() updating;
//--------------------------------------------------------------
//Created: 11 June 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	obj : Object;
begin
	inheritMethod();
	if self.cmbOpt1.visible then
		obj := self.cmbOpt1.listObject;
		if obj &lt;&gt; null then
			if obj.isKindOf(CM_LocationsController) then
				// receive cargo
				self.doReceiveCargo(obj.CM_LocationsController);
				self.zTblDataSortAndShow(true);
			endif;
		endif;
		self.frmModalDialog.visible := false;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="doBtnSummariseAll" id="4431a9be-eb18-4a5f-855d-78e6df04eab5">
        <source>doBtnSummariseAll();

/*

Purpose:		
Parameters:		
Return Value:	

Date				Who		Reason
17 February 2009	cnwrl1	Initial creation (CCMS SFW 1047 - Totals Only Lists)

*/
	
vars
	coll				: ObjectSet;
	
begin
	app.mousePointer	:= Busy;
	create coll transient;
	
	// Get a collection of ALL the objects to pass to the Summary Definition form.
	self.tblData.getAllRowObjects( coll );
	self.myAssistant.showXTABSummaryDefinitionForm( coll, false, false, false, true );
	
epilog
	delete coll;
	app.mousePointer	:= Idle;
	
end;
</source>
    </JadeMethod>
