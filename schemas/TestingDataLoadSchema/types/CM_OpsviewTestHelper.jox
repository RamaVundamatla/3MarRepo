    <JadeMethod name="getOpsviewHelperCargoNumber" id="06a30b55-2507-4fca-aba4-1f744c6a336b">
        <updating/>
        <source>getOpsviewHelperCargoNumber():Integer updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 July 2022	navsp1	Initial creation TFS#53956

*/

vars
begin

    
    beginTransaction;
    self.nextCargoNumber := self.nextCargoNumber + 1;
    commitTransaction;

    return self.nextCargoNumber;
end;

</source>
