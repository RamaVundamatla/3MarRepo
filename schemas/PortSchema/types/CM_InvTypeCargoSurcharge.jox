    <JadeMethod name="validateMe" id="cbc90209-5b09-47bc-872d-1f7f8430f666">
        <source>validateMe();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 April 2018	jlgndl1	Initial creation	TFS 37822

*/

vars

	realForCheck : CM_InvTypeCargoSurcharge;
	existing : CM_InvTypeCargoSurcharge;

begin

	if self.surchargeRate &lt;= 0 then
		app.raiseCMException(Surch_rate_must_great_than_zer, null,null);
	endif;

	if self.mySurchargesAndExemptions = null then
		app.raiseCMException(Current_surcharge_exemptions, null,null);
		return;
	endif;
	
	if self.getCargoSurchargeInvLineType = null then
		app.raiseCMException(Surcha_invoic_line_type_select, null,null);
		return;
	endif;
	
	if self.myCargoType = null then
 // ### TFS 51219 03JUN2021 NAVAB1		app.raiseCMException(Select_cargo_type_continu, null,null);
		 // ### TFS 51219 03JUN2021 NAVAB1return;
	endif;
	
	//20 Jun 2018	NDL	TFS 39305
	if self.allSelectedInvLineTypes.isEmpty then
		app.raiseCMException(Must_have_least_selec_invoi_li,null,null);
		return;
	elseif self.allSelectedInvLineTypes.includes( self.getCargoSurchargeInvLineType ) then
		app.raiseCMException(Select_not_incl_Inv_Line, null, null );
		return;
	endif;
	
	if self.isTransient then
		realForCheck := self.pxyGetRealObject();
	else
		realForCheck := self;
	endif;
	
	existing := self.mySurchargesAndExemptions.allInvTypeCargoSurcharges.getAtKey( self.myCargoType, self.mySubCargoType, self.myCommodity );
	if existing = null or existing = realForCheck then
		//we can carry on.
	else
		//This key is already used.
		app.raiseCMException(Surch_rate_alrea_exist_this_ca, null,null);
		return;
	endif;

epilog

end;</source>
    </JadeMethod>
