//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
// 27/02/2011	cnwdap1		PAR #27100 Set tranship discharge port if we're an onsite tranship
vars
	tbl			: CM_EntryTable;
	ti			: CM_TrackedItem;		// PAR #27100
	transhipTbl	: CM_EntryTable;		// PAR #27100

begin
	if not CM_EntryTable.hasInstance(combobox.parent) then
		return;
	endif;

	tbl := combobox.parent.CM_EntryTable;

	combobox.doChangedCompareForEntryTable();
	
	self.cmbTranship.setObjectAndVoyageDischPort(combobox.listObject.CM_Port,self.cmbVoyage.listObject.CM_Voyage);

	// PAR #27100 change the cmbExpTshipDisch
	if CM_TrackedItem.hasInstance(self.myCurrentObject) and combobox.listObject &lt;&gt; null then
		ti := self.myCurrentObject.CM_TrackedItem;
		if ti.isTranshipOutbound() then
			self.cmbExpTshipDisch.setObjectAndVoyage(combobox.listObject.CM_Port, self.cmbVoyage.listObject.CM_Voyage);
			transhipTbl := self.getTableForRow(ETRow_TranshipDischargePort);
			if transhipTbl &lt;&gt; null then
				// we need to populate the tranship table so bulk editing works correctly
				// and also to repopulate with the current TI's details if we've shown previous details
				self.showThumbnailDataForSheet(self.getEditSheetForIndex(transhipTbl.name[transhipTbl.name.length:1].Integer), false);
				transhipTbl.setChangeMode(transhipTbl.ChangeMode_All);
				transhipTbl.setValue(transhipTbl.getRowByName(ETRow_TranshipDischargePort), combobox.listObject.CM_Port.code);
			endif;
			
			if self.doingMultiEdit then
				self.cmbExpTshipDisch.doChangedCompareForEntryTable();
			elseif self.myProxyObject &lt;&gt; null then 
				self.myProxyObject.CM_TrackedItem.setTranshipDischargePort(combobox.listObject.CM_Port);
			endif;
		endif;
	endif;
	// PAR #27100 end
end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="cmbExpTshipDisch_lostFocus" id="0234fe9a-2f69-46bb-b544-74def1473042">
        <controlMethod name="CMUI_ComboBoxObject::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbExpTshipDisch_lostFocus(combobox: ComboBox input) updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27/02/2011	cnwdap1	Initial creation PAR #27100 Change Discharge port also if we're an onsite tranship
*/
vars
	ti			: CM_TrackedItem;
	generalTbl	: CM_EntryTable;

begin
	if combobox.listObject = null then
		return;
	endif;
	combobox.doChangedCompareForEntryTable();
	
	if CM_TrackedItem.hasInstance(self.myCurrentObject) then
		ti := self.myCurrentObject.CM_TrackedItem;
		if ti.isTranshipOutbound() then
			self.cmbDisPort.setObjectAndVoyage(combobox.listObject.CM_Port, self.cmbVoyage.listObject.CM_Voyage);
			generalTbl := self.getTableForRow(ETRow_DischargePort);
			if generalTbl &lt;&gt; null then
				// we need to populate the general table so bulk editing works correctly
				// and also to repopulate with the current TI's details if we've shown previous details
				self.showThumbnailDataForSheet(self.getEditSheetForIndex(generalTbl.name[generalTbl.name.length:1].Integer), false);
				generalTbl.setChangeMode(generalTbl.ChangeMode_All);
				generalTbl.setValue(generalTbl.getRowByName(ETRow_DischargePort), combobox.listObject.CM_Port.code);
			endif;
			
			if self.doingMultiEdit then
				self.cmbDisPort.doChangedCompareForEntryTable();
			elseif self.myProxyObject &lt;&gt; null then
				self.myProxyObject.CM_TrackedItem.setDischargePort(combobox.listObject.CM_Port.code);
			endif;
		endif;
	endif;
epilog

end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="cmbExpTshipVoy_displayEntry" id="2d38a4a0-07a5-47d8-bb6d-a882572e31df">
        <controlMethod name="ComboBox::displayEntry"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbExpTshipVoy_displayEntry(combobox: ComboBox input; obj: Any; lstIndex: Integer):String updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 June 2010	cnwdap1	Initial creation
*/
vars

begin
	if obj.CM_Voyage.myTerminal.hasDuplicateCodeVoyages (obj.CM_Voyage.code) then
		return obj.CM_Voyage.code &amp; " " &amp; obj.CM_Voyage.arrivedDT.reportDisplay;
	else
		return obj.CM_Voyage.code;
	endif;
epilog

end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
        <Parameter name="obj" type="Any"/>
        <Parameter name="lstIndex" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="cmbExpTshipVoy_lostFocus" id="9dac0804-8794-4704-b22c-68f6aeffdc79">
        <controlMethod name="CMUI_ComboBox::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbExpTshipVoy_lostFocus(combobox: ComboBox input) updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28/06/2010	cnwdap1	Initial creation PAR #24516
*/
vars
	tbl			: CM_EntryTable;
	
begin
	if (not CM_EntryTable.hasInstance(combobox.parent)) then
		return;
	endif;
	
	tbl := combobox.parent.CM_EntryTable;	
	
	if combobox.listObject &lt;&gt; null then
		tbl.setValueByControlName(combobox.name, combobox.listObject.CM_Voyage.code);
		self.cmbExpTshipDisch.setObjectAndVoyage(self.cmbExpTshipDisch.listObject.CM_Port,combobox.listObject.CM_Voyage);
		self.cmbExpTshipDest.setObject(self.cmbExpTshipDest.listObject.CM_Port);
	else
		tbl.setValueByControlName(combobox.name, null);
	endif;
	combobox.doChangedCompareForEntryTable();
epilog

end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
