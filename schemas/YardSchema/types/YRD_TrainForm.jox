    <JadeMethod name="doBtnCrgFcstDef" id="28a7a953-bb50-4815-844f-663e710cef12">
        <source>doBtnCrgFcstDef();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 April 2022	navak20	Initial creation 	TFS 53142 Cargo Forecast on Voyage &amp; Train
*/

vars
	form : CMUI_CargoForecastForm;
begin
	if self.mySelectedTrain = null then	
		app.msgBox(app.getErrorString(Select_train_for_cf),app.getErrorString(Cargo_Forecast), MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	
	form := app.loadForm(CMUI_CargoForecastForm, YRD_Assistant, false, false, false, self.myTerminal, null).CMUI_CargoForecastForm;		//13.05.2022 navsrk	53142
	if form = null then
		return;		//13.05.2022 navsrk	53142
	endif;
	if form &lt;&gt; null then
		form.setMyObject(self.mySelectedTrain);
		form.setParentForm(self);
		form.show();
	endif;
epilog

end;</source>
