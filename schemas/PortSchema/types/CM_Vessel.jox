    <JadeMethod name="setVoyageNumberForTerminal" id="3d472b16-bb57-46a3-922e-f57dd43cae1c">
        <source>setVoyageNumberForTerminal(_terminal : CM_Terminal; _voyageNumber : Integer);
// ---------------------------------------------------------------------------
// Created:     02 June 2007 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpVesselTerminal	: CM_VesselTerminalData;
begin
	if _terminal = null then
		app.raiseCMException2(MethodWithNullParam, method.name, '_terminal', null, null);
		return;
	endif;
	
	tmpVesselTerminal := self.getVesselTerminalData(_terminal, true);
	
	tmpVesselTerminal.setNextNumber(_voyageNumber);

end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_voyageNumber" type="Integer"/>
    </JadeMethod>
