    <JadeMethod name="addErrorMessEmptyTag" id="b02ce224-ed53-41cc-b1c7-0a6f99e22668">
        <source>addErrorMessEmptyTag(	_parentTagSet : String; _tagSetName : String; _ediFile: CM_EDIFile input ) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 October 2016	cnwndl1	Initial creation	TFS 2718 / 2536

*/

vars

begin

	self.addFileErrors("&lt;" &amp; _tagSetName &amp; "&gt; within &lt;" &amp; _parentTagSet &amp; "&gt; is empty.", 1, _ediFile);

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_parentTagSet" type="String"/>
        <Parameter name="_tagSetName" type="String"/>
        <Parameter name="_ediFile" type="CM_EDIFile" usage="input"/>
    </JadeMethod>
    <JadeMethod name="addErrorMessNoMatchingObj" id="86258abf-e477-4c26-88f6-d89cd75a440d">
        <source>addErrorMessNoMatchingObj( _objectType : String; _parentTagSet : String; _tagSetName : String; _str : String; _ediFile: CM_EDIFile input ) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 October 2016	cnwndl1	Initial creation	TFS 2718 / 2536

*/

vars

begin

	self.addFileErrors("&lt;" &amp; _tagSetName &amp; "&gt; within &lt;" &amp; _parentTagSet &amp; "&gt; with a value of '" &amp; _str &amp; "' could not be resolved to a '" &amp; _objectType &amp; "' object in JMT.", 1, _ediFile);

epilog

end;</source>
