    <JadeMethod name="validateForUpdate" id="8ed884a3-1678-48ef-860f-d5ccbf230772">
        <source>validateForUpdate();
// ---------------------------------------------------------------------------
// Created:     Aug 2004 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 04 July 2011	cmwrs1		CCMS1150 - backup sds notification
// 15/12/2014   cnwdb2	    PAR 35364
// 01/05/2019	jlgzm1		TFS 43523 Journal path should be outside backup path
// ---------------------------------------------------------------------------

vars
	pos : Integer;
	pathName, 
	jPathName,				//TFS 43523
	jRPathName: String;		//TFS 43523

	entDef : EntTableDef;	//TFS 43523
	entRow : EntTableRow;	//TFS 43523
	backupStr : String;		//TFS 43523
	journalStr : String;	//TFS 43523

begin

	if self.dbBackupPath = null then
		app.raiseCMException(Input_required_field_bckUpData, null, null); // cnwdb2	PAR 35364
	else
		pathName := self.dbBackupPath.replace('/','\');
		if not pathName.cnEcIsValidPathName then
			app.raiseCMException1(File_path_valid, self.dbBackupPath, null, null);
		endif;
		pos := pathName.reversePos("\");
		if pos &gt; 3 then
			app.raiseCMException1(File_path_notroot, self.dbBackupPath, null, null);
		endif;
		
	endif;
	if self.journalLocalBackupPath = null then
		app.raiseCMException(Input_required_field_bckUpJurn, null, null); // cnwdb2	PAR 35364
	endif;
		
	// tfs43523 start
	// journal path should not be within backup path, 
	// because the backup process deletes everything pior to beginning backup,
	// and fails if a journal file is in use.
	
	//for error string
	entDef := app.myRoot.myEntTableDataRoot.getEntTableDef(ETDef_BackupMaint);
	entRow := entDef.getEntTableRow( ETRow_BackupPath );
	if entRow &lt;&gt; null then
		backupStr := entRow.getHeading(null, null, app.myCurrentLocale);
	endif;
	
	if self.dbBackupPath &lt;&gt; null and self.journalLocalBackupPath &lt;&gt; null then
		pathName := self.dbBackupPath.replace('/','\');
		jPathName := self.journalLocalBackupPath.replace('/','\');
		if jPathName = pathName or jPathName.pos(pathName &amp; "\", 1) &gt; 0 then
		
			entRow := entDef.getEntTableRow( ETRow_JournalPath );
			if entRow &lt;&gt; null then
				journalStr := entRow.getHeading(null, null, app.myCurrentLocale);
			endif;
			app.raiseCMException4(Journal_path_within_backup, journalStr, self.journalLocalBackupPath, backupStr, self.dbBackupPath, null, null);
			
		endif;
	endif;

	if self.dbBackupPath &lt;&gt; null and self.journalRemoteBackupPath &lt;&gt; null then
		pathName := self.dbBackupPath.replace('/','\');
		jRPathName := self.journalRemoteBackupPath.replace('/','\');
		if jRPathName = pathName or jRPathName.pos(pathName &amp; "\", 1) &gt; 0 then
		
			entRow := entDef.getEntTableRow( ETRow_JournalRemotePath );
			if entRow &lt;&gt; null then
				journalStr := entRow.getHeading(null, null, app.myCurrentLocale);
			endif;
			app.raiseCMException4(Journal_path_within_backup, journalStr, self.journalRemoteBackupPath, backupStr, self.dbBackupPath, null, null);
			
		endif;
	endif;
	//tfs43523 end
	
end;</source>
    </JadeMethod>
</Class>
