    <JadeMethod name="makeHazardousSectXML" id="0ddc4a2d-f6a0-4bda-a15d-49d9c3fecd25">
        <source>makeHazardousSectXML( _ti : CM_TrackedItem; _parentElem : JadeXMLElement input ) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 August 2016	cnwndl1	Initial creation	TFS 2561 / 2277
24 Oct 2019	NDL	TFS 46293 - One stop new rule, now want one 'HazardousInformation' tag set per hazard, and no other changes.

*/

vars

	rootElem : JadeXMLElement;
	xmlElem : JadeXMLElement;
	haz : CM_Hazard;
	
begin

//	rootElem := _parentElem.addElement('HazardousInformation');
	
	if _ti = null then
		rootElem := _parentElem.addElement('HazardousInformation');	//24 Oct 2019	NDL	TFS 46293 - retain existing behaviour of creating an empty tag set if no TI
		return;
	endif;
	
	if _ti.allTIHazards.isEmpty then
		rootElem := _parentElem.addElement('HazardousInformation');	//24 Oct 2019	NDL	TFS 46293 - retain existing behaviour of creating an empty tag set if no Hazards
		return;
	endif;
	
	foreach haz in _ti.allTIHazards do
		rootElem := _parentElem.addElement('HazardousInformation');	//24 Oct 2019	NDL	TFS 46293 - Create a new tag set for each set of hazards.
	/*	
		xmlElem := rootElem.addElement('FlashPoint');
		xmlElem.setText( null );
	*/	
		xmlElem := rootElem.addElement('IMDG_Class');
		xmlElem.setText( haz.code );
	/*	
		xmlElem := rootElem.addElement('IMDG_Page');
		xmlElem.setText( null );
		
		xmlElem := rootElem.addElement('IMDG_Version');
		xmlElem.setText( null );
	*/	
		xmlElem := rootElem.addElement('UNDG_Number');
		xmlElem.setText( haz.CM_TIHazard.getUNDGCode1 );
		
		xmlElem := rootElem.addElement('PackingGroup');
		xmlElem.setText( haz.CM_TIHazard.packingGroup );
	/*	
		xmlElem := rootElem.addElement('EmergencyScheduleNumber');
		xmlElem.setText( null );
		
		xmlElem := rootElem.addElement('MedicalFirstAidGuide');
		xmlElem.setText( null );
		
		xmlElem := rootElem.addElement('DGLabel');
		xmlElem.setText( null );
		
		xmlElem := rootElem.addElement('TechnicalName');
		xmlElem.setText( null );
	*/	
		xmlElem := rootElem.addElement('AdditionalInformation');
		xmlElem.setText( haz.description );
	/*	
		xmlElem := rootElem.addElement('NetWeightOfHazard');
		xmlElem.setText( null );
		
		xmlElem := rootElem.addElement('ContactName');
		xmlElem.setText( null );
		
		xmlElem := rootElem.addElement('ContactPhone');
		xmlElem.setText( null );
		
		xmlElem := rootElem.addElement('ContactFax');
		xmlElem.setText( null );
		
		xmlElem := rootElem.addElement('ContactMobileNumber');
		xmlElem.setText( null );
		
		xmlElem := rootElem.addElement('ContactEmail');
		xmlElem.setText( null );
	*/
	endforeach;
	
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_parentElem" type="JadeXMLElement" usage="input"/>
    </JadeMethod>
    <JadeMethod name="makeLineOpAddrSubSectXML" id="15f7f6db-3b20-4520-b648-ccdd9478477c">
        <source>makeLineOpAddrSubSectXML( _oper : CM_Operator; _parentElem : JadeXMLElement input ) protected;
/*

Purpose:			

