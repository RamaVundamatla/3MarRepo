/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
12 February 2009	cnwjk3	SFW1030

*/

vars

begin
		if keyCode = J_key_DownArrow or keyCode = J_key_UpArrow then
			self.doYAMTableSelection();
		endif;
epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="451a6d3a-cf3f-4066-a53b-70a43c8dd143">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 11 September 2020 14:42:40.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0010442, locale);
	btnAddYA.translateBubbleHelp(Xlat_0010443, locale);
	btnAddYA.translateCaption(Xlat_0010444, locale);
	btnDeleteYA.translateBubbleHelp(Xlat_0010445, locale);
