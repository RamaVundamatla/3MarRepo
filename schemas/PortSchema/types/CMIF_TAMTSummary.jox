    <JadeMethod name="balance" id="910c18ad-ca64-4ef2-80d6-b13ee8990406">
        <methodInvocation>mapping</methodInvocation>
        <source>balance(set: Boolean; _value: Integer io) mapping;
//----------------------------------------------------------------
//	Created:	16 February 2006	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin
	if set then
		// set code here
		return;
	else
		// get code here
		_value := (self.numInArea - self.numRequired);
	endif;

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="balanceDisplay" id="8072b152-9512-491d-8367-9c722f848493">
        <source>balanceDisplay(): String;
//----------------------------------------------------------------
//	Created:	16 February 2006	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin

	if self.balance &lt;&gt; 0
	or self.numInArea &lt;&gt; 0
	or self.numRequired &lt;&gt; 0 then
		return self.balance.String;
	else
		return "";
	endif;
	
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
