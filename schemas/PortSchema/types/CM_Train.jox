    <JadeMethod name="getNumTEU" id="01e8ad94-58bc-4dff-b281-e8d66f8724cc">
        <source>getNumTEU(_isReceived : Boolean) : Real;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
13 July 2009	cnwmd1	Initial creation

*/

vars
	ti 		: CM_TrackedItem;
	tis 	: CM_TIArray;
	teus 	: Real;
	invalid	: Boolean;
	
begin
	create tis transient;
	
	self.getAllTrackedItems(_isReceived, tis);
	
	on Exception do app.handleDeletedObject (exception, ti, invalid);		// 14/03/2013 cnwar2 #30563
	foreach ti in tis do
		teus := teus + ti.getNumTEU();
	endforeach;
	
	return teus;
epilog
	delete tis;
end;</source>
        <Parameter name="_isReceived" type="Boolean"/>
        <ReturnType type="Real"/>
