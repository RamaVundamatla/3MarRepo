    <JadeMethod name="pxyCreateUpdateProxy" id="800d6404-bc44-41a2-bedc-ecc069846762">
        <source>pxyCreateUpdateProxy(): SelfType;
// ---------------------------------------------------------------------------
// Created:     01 June 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy

vars
	
	pxy		: CM_QryReportUser;
	completedOK		: Boolean;
		
begin
	pxy := inheritMethod();
	
	pxy.mySelectorQuery := self.mySelectorQuery;
	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return pxy;
	
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete pxy;
	endif;	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="acd62c4c-d04b-45f6-bbc8-6923c27db9e4">
        <updating/>
        <source>setForCreate(_proxy : SelfType; 
			_parent : CM_MenuEntity input; 
			_pos : Integer;
			_menuRoot : CM_MenuRoot input) updating;
// ---------------------------------------------------------------------------
// Created:     27 November 2002		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

	user	: CM_User;

begin
	inheritMethod(_proxy, _parent, _pos, _menuRoot);
	
	user := app.getMyUser();
	if user &lt;&gt; null then
		user.addReportToUserTerminalSecRole(self);
	endif;

//	self.setForUpdate(_proxy);

end;</source>
        <Parameter name="_proxy" type="SelfType"/>
        <Parameter name="_parent" type="CM_MenuEntity" usage="input"/>
        <Parameter name="_pos" type="Integer"/>
        <Parameter name="_menuRoot" type="CM_MenuRoot" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="48d2039f-23bc-4d9d-96c8-3f698d69b27b">
        <updating/>
        <source>setForUpdate(_proxy: SelfType) updating;
// ---------------------------------------------------------------------------
// Created:     27 November 2002		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

	menuUserDtl				: CM_MenuUserDtl;
	menuUserItem			: CM_MenuUserItem;
	
begin	
	
	// DVB changed. 25/01/2005 Can't check self during create
	// because haven't set report type param yet.
	if _proxy.reportType = self.ReportType_Selector then
		self.mySelectorQuery := _proxy.mySelectorQuery;
	else//belts and braces
		self.mySelectorQuery := null;
	endif;
	
	self.heading			:= _proxy.reportName;
	self.reportName 		:= _proxy.reportName;
	self.reportDescription	:= _proxy.reportDescription;
	self.reportType := _proxy.reportType;
	self.assignFilterClassName();
	
	self.viewRows.clear;
	_proxy.viewRows.copy(self.viewRows);
	
	self.allVisibleRows.clear;
	_proxy.allVisibleRows.copy(self.allVisibleRows);
	
	self.jrwReportName.clear;
	_proxy.jrwReportName.copy(self.jrwReportName);

	self.jrwReportProfileName.clear;
	_proxy.jrwReportProfileName.copy(self.jrwReportProfileName);
	
	app.myRoot.myReportMenuRoot.addQryReportToUserMenu(self);
	
	foreach menuUserItem in self.allMenuUserItems do
		if menuUserItem.heading &lt;&gt; self.reportName then
			menuUserItem.setHeading(self.reportName);
		endif;
	endforeach;
	
	inheritMethod(_proxy);
	
end;</source>
        <Parameter name="_proxy" type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="9b658629-f622-4462-98fc-9f7b26f5c788">
