    <JadeMethod name="validateVoyage" id="38cd5d84-1276-4974-a9bd-fdb19ca2c7c5">
        <source>validateVoyage(_terminal : CM_Terminal; _voyageCode : String ) : CM_Voyage protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 17/04/2018	jlgdap1		Initial creation TFS 38135 PEL1 Inaportnet Integration (Web Service Provider)
// 11/10/2021	jlier1		TFS 51963

vars
	voyage : CM_Voyage;
	status : CM_VoyageStatus;

begin
	voyage := _terminal.allVoyagesByExternalCode[_voyageCode];
	if voyage = null then
		//epr TFS 40629 7/9/18
		return null;
	endif;
	if voyage &lt;&gt; null and voyage.voyageCodeExternal &lt;&gt; _voyageCode then
		app.raiseCMException1(Voyage_external_code_invalid, _voyageCode, null, null);
	endif;
	// voyage must be Inaportnet process
	//if not voyage.isInaportnetVoyageProcess then
		app.raiseCMException2(Voyage_Not_Inaportnet, voyage.code, voyage.voyageCodeExternal, null, null);
	//endif;
	// and must be at the defined status
	self.validateVoyageStatusForMsg( voyage );

epilog
	return voyage;
end;</source>
        <access>protected</access>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_voyageCode" type="String"/>
        <ReturnType type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="validateVoyageStatusForMsg" id="bcda271d-c687-4e70-8e6a-f7898512b372">
        <source>validateVoyageStatusForMsg( _voyage : CM_Voyage ): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 May 2018	jlgndl1	Initial creation	TFS 38135
6 Dec 2018 jlger1 	TFs 42341 - don't need to check use has access to next status anymore &amp; if no valid next status can just return
*/

vars

	validStatuses : IntegerArray;
	voyageStatus : CM_VoyageStatus;
	currentStatus : Integer;
	voyageStatusStr : String;
	newVoyageStatus : CM_VoyageStatus;
begin
	if _voyage = null then
		return true;
	endif;
		
	
	create validStatuses transient;
	self.getValidCurrentStatuses( validStatuses );
	
	//epr TFS 42341 11/12/18
	if validStatuses.isEmpty then
		return true;
	endif;
	voyageStatusStr := app.getErrorString(Null);
	voyageStatus := _voyage.getVoyageStatusObject;
	if voyageStatus &lt;&gt; null then
		currentStatus := voyageStatus.id;
		voyageStatusStr := voyageStatus.description;
	endif;
	if not validStatuses.includes( currentStatus ) then
		app.raiseCMException2( Voyage_incorr_status_this_acti, _voyage.code, voyageStatusStr, null, null );
		return false;
	endif;
	
	return true;

epilog

	delete validStatuses;

end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
