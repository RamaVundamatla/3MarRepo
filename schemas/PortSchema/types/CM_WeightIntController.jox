    <JadeMethod name="closeConnection" id="f9d567d2-257d-491b-bcac-a6a0fdc963e5">
        <updating/>
        <source>closeConnection() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 August 2016	cnwrh7	Initial creation

*/

vars
	invalid : Boolean;
begin
	if self.myConnection = null then
		return;
	endif;
	
	on Exception do app.handleDeletedObject(exception,self.myConnection,invalid);	//Bug 38134

	self.diagnosticLog(method.qualifiedName &amp; " myConnection= " &amp; self.myConnection.String &amp; " connectingState= " &amp; self.myConnection.state.String);
	
	if self.myConnection.state = Connection.Connected then
		self.myConnection.close();
	endif;
	
epilog

end;</source>
    </JadeMethod>
