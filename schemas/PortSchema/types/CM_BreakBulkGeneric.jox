    <JadeMethod name="isPalletByDefault" id="5aeeb61c-29db-47f7-9542-59121f6d6e09">
        <source>isPalletByDefault():Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 Jan 2020	jlgndl1	Initial creation	TFS 48248
28 May 2024 navma1	Bug 64224: MTN - DeadLocks Caused by Future Actors
*/

vars
	cargoType : CM_CargoType;
	product	  : CM_Product;
begin

	cargoType := self.myCargoType;		//28.05.2024 navma1 #64224
	product   := self.myProduct;		//28.05.2024 navma1 #64224
	
	if ( product   &lt;&gt; null and product.myHandlingType &lt;&gt; null 		   and product.myHandlingType.isPallet ) 			//30 Jan 2020	NDL	TFS 48246
	or ( cargoType &lt;&gt; null and cargoType.myDefaultHandlingType &lt;&gt; null and cargoType.myDefaultHandlingType.isPallet )	//28.05.2024 navma1 #64224
	then
		return true;
	endif;
	
	return false;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="mergeBreakBulkGeneric" id="01cb0353-1617-4358-8ccc-42fb89ef4fcc">
        <updating/>
        <source>mergeBreakBulkGeneric(_control : CMIF_MoveController input;
					   _mergeToCargo : CM_BreakBulkGeneric input) protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26/04/2013	cnwer1	Initial creation CCMS DPH 2274
24/02/2017	cnwdap1	TFS 3489 LNX DLR/SOB
23 May 2022 Navds20 ChangeRequest 53504: EUP - Cargo Uniqueness - PortSchema
12 Jun 2025 navhn30 Bug 35040: TPT - Instructions are lost when splitting cargo
12 Dec 2025 navsp1  MTN-36700  STWO - Damage Photos Not Visible for Multi-Quantity Cargo IDs After Full Discharge
13 Jan 2025 navsp1  MTN-36949  MTN - Image attached when discharging last part of break-bulk cargo item is not saved
*/

vars
	origLocn 	: CM_LocationsController;
	passport : CM_Passport; 
	moveQuantity : Integer;
	moveWLE : CM_WorkListEntry;
	ti 		: CM_TrackedItem;
	tiSet : CM_TISet;
	storageConfig	: CM_StorageConfig;
begin
	passport:=_control.myPassport;
	
	// PAR 36472	
	storageConfig := self.myTerminal.myStorageConfig;
	if storageConfig &lt;&gt; null and storageConfig.includesTriggerType(CargoSplitMerge) then
		self.createStorageTransaction(_control,passport);
		if not passport.noErrors() then
			return;
		endif;
	endif;
	
	moveQuantity:=_control.quantity;
	
	//if no move controller quantity set then moving the entire amount
	if moveQuantity = 0 then
		moveQuantity := self.totalQuantity;
	endif;
	
	//22 Jun 2015	NDL	Par 36338
	if self.myCargoGroup &lt;&gt; null then
		//self.myCargoGroup.removeAssignedCargo( self, passport );	//23 May 2022 Navds20 TFS 53504
		if self.myCargoType.useCargoGroupForUniqueness then 		//23 May 2022 Navds20 TFS 53504
			self.myCargoGroup.addAssignedCargo( self, passport );	//23 May 2022 Navds20 TFS 53504
		endif;														//23 May 2022 Navds20 TFS 53504
	endif;
	
	//29 Nov 2016	NDL	TFS 3016 / 2549
	self.handleMergeDocActions(	self, _mergeToCargo );
	
	// PAR 37403 - if the break bulk item is being packed, we do not need any of the split/merge stuff.
	// PAR 37403 - If a break bulk cargo item that can be split/merged is packed into a container it does not ask 'how much', the whole thing is packed.
	if _control.myPackToTI &lt;&gt; null then
		if _mergeToCargo = self and self.myParent = _control.myPackToTI then
			return; 
		endif;
	endif;
	
    //Moved here to copy the attachments before the purge operation                                     //MTN-36949 
	//Merge the attachments                                                             //MTN-36700     //MTN-36949
    self.handleMergeAttachments(_mergeToCargo);                                         //MTN-36700     //MTN-36949
     
	self.mergeSetQVW(_control,_mergeToCargo);
		
	if self.id &lt;&gt; _mergeToCargo.id then
		_mergeToCargo.updateDetailsFromCargoMulti(true,self,true,true,true,true,passport);// ### JIRA 35283 30JUN2025 NAVAB1
		create tiSet transient;
		_mergeToCargo.findAllDuplicateTIs(tiSet);
		foreach ti in tiSet do
			ti.updateDetailsFromCargoMulti(true,self,true,true,true,true,passport);// ### JIRA 35283 30JUN2025 NAVAB1
		endforeach;
	endif;	
		
	if  not _mergeToCargo.isOnSite and _mergeToCargo.releasedDT &lt;&gt; null  then
		_mergeToCargo.setLastReleasedDT(app.actualTimeServer);
	endif;
	
	if _mergeToCargo.isOnSite and _mergeToCargo.receivedDT &lt;&gt; null  then
		_mergeToCargo.setLastReceivedDT(app.actualTimeServer);
	endif;	
	
	origLocn:=self.myPrimaryActualLocation;
	moveWLE:=_control.myWorkListEntry;
	// this is the 
	if self.totalQuantity = 0 then
		self.checkMergeRT(_control);
		//self.mergeNullRefs( _mergeToCargo,moveWLE);					// TFS 3489
		self.mergeNullRefs(_mergeToCargo, moveWLE, _control);			// TFS 3489
		//epr par 33195 16/12/13
		if moveWLE &lt;&gt; null and moveWLE.myRequest &lt;&gt; null and moveWLE.myRequest.isKindOf(CM_DeliveryRequest) then
			moveWLE.myRequest.CM_DeliveryRequest.removeBulkReleaseTI(self);
		endif;
	endif;
	
	//this will make sure all new transactions are on the new cargo merged into
	_control.setMyTrackedItem(_mergeToCargo);
	_control.myOriginalTI := self;	//26 Nov 2020	NDL	TFS 50422
	_control.setMyOriginatingLocation(origLocn);
    
	if  moveWLE &lt;&gt; null  then
		//epr par 35702 CCMS 2457 17/2/15
		if _control.isRTMultiMove and not _control.isRTPickupTask and _control.myRTQueueEntry &lt;&gt; null and _control.myRTQueueEntry.myBreakBulkMaster &lt;&gt; null and
			_control.myRTQueueEntry.myBreakBulkMaster.areAllTasksEqualStatus(TASK_COMPLETE)   then
			self.splitMergeUpdateWLEsTI(moveWLE,_mergeToCargo,_control);
		else
			if moveWLE.quantity &gt; moveQuantity then //32337
				self.splitMergeCreateNewWLE(_control,moveWLE,_mergeToCargo,true);
			else
				//move the wle to mergeToCargo
				self.splitMergeUpdateWLEsTI(moveWLE,_mergeToCargo,_control);
			endif;
		endif;
	endif;
	
	self.handleMergeReserveDetail( _mergeToCargo );	//26 Feb 2018	NDL	TFS 37026 - after the weight etc has been updated
	
	self.handleMergeCustomDocDetail(_mergeToCargo, moveQuantity); // ### TFS CR 59942 TASK 59943 04SEP2023 NAVAB1    

	if app.myPassport.isOpsViewEnabled(self.myTerminal) then // ### TFS 53105 08JUN2022 NAVAB1
		self.createOpsViewEWSActivity(BGP_OpsViewWSRequest.OPS_ACTION_UPDATE,BGP_OpsViewWSRequest.OPS_TYPE_TRACKEDITEM, self); // ### TFS 53105 08JUN2022 NAVAB1
	endif;
	
	if self.isZombie() then			//12.06.2025	navhn30		MTN-35040
		if self.myInstructions &lt;&gt; null then
			self.myInstructions.erase(NORMAL_ERASE);
		endif;
	endif;
epilog
	delete tiSet;

end;</source>
        <access>protected</access>
        <Parameter name="_control" type="CMIF_MoveController" usage="input"/>
        <Parameter name="_mergeToCargo" type="CM_BreakBulkGeneric" usage="input"/>
    </JadeMethod>
    <JadeMethod name="mergeIntoDifferentId" id="165a024b-9649-41b9-9132-27f8cc3b9d8b">
        <updating/>
        <source>mergeIntoDifferentId( _targetTi : CM_BreakBulkGeneric io; _passport : CM_Passport input )updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 May 2013	cnwndl1	Initial creation

*/

vars

	cmifMoveController : CMIF_MoveController;

begin

	create cmifMoveController transient;
	cmifMoveController.setMoveMode( REAL_MODE );
	cmifMoveController.setMyToPrimaryLocation( self.myPrimaryActualLocation );
	cmifMoveController.setMyPassport( _passport );
	
	self.mergeBreakBulkGeneric(	cmifMoveController,	//_control : CMIF_MoveController input;
								_targetTi	//_mergeToCargo : CM_BreakBulkGeneric input
								);

epilog

	delete cmifMoveController;

end;</source>
        <Parameter name="_targetTi" type="CM_BreakBulkGeneric" usage="io"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="mergeSetQVW" id="28a848a5-cd77-4de7-8e77-f719b6146fc4">
        <updating/>
        <source>mergeSetQVW(_control: CMIF_MoveController input; _mergeToTI: CM_TrackedItem input) updating, protected;
/*

Date		Who		Reason
11 Mar 2014	cnwer1	Initial creation PAR
03 May 2018 JLGNS1	Bug 38457: DQM - Dry Bulk - ( Gate in and Merge )
28 May 2024 navma1	Bug 64224: MTN - DeadLocks Caused by Future Actors
*/

vars
	oldMergeQuantity,
	oldQuantity,
	moveQuantity 	   : Integer;
	adjustedVolume,newVolume,oldVolume,oldMergeVolume		: Real;
	adjustedWeight,newWeight,oldWeight,oldMergeWeight 		: Decimal[14,4];
	oldCargoWeight, oldMergeCargoWeight 					: Decimal[14,4];	//18 Jan 2018	NDL	TFS 36697	
	oldTareWeight, oldMergeTareWeight 						: Decimal[14,4];	//18 Jan 2018	NDL	TFS 36697
	adjustedQuantity   : Integer;
	useTareCargoWeight : Boolean;
begin
	
	moveQuantity:=_control.quantity;
	
	//if no move controller quantity set then moving the entire amount
	if moveQuantity = 0 then
		moveQuantity := self.totalQuantity;
	endif;
	
	oldQuantity := self.totalQuantity;
	oldVolume	:= self.totalVolume;
	oldWeight   := self.totalWeight;
	
	useTareCargoWeight := self.myCargoType.useTareCargoWeight;			//28.05.2024 navma1 #64224
	
	if useTareCargoWeight then	//Bug 38457
		oldCargoWeight := self.weightCargo;	//18 Jan 2018	NDL	TFS 36697
		oldTareWeight  := self.weightTare;	//18 Jan 2018	NDL	TFS 36697
	endif;									//Bug 38457
	
	oldMergeQuantity := _mergeToTI.totalQuantity;
	oldMergeVolume   := _mergeToTI.totalVolume;
	oldMergeWeight   := _mergeToTI.totalWeight;
	
	if useTareCargoWeight then							//Bug 38457		//28.05.2024 navma1 #64224
		oldMergeCargoWeight := _mergeToTI.weightCargo;	//18 Jan 2018	NDL	TFS 36697
		oldMergeTareWeight  := _mergeToTI.weightTare;	//18 Jan 2018	NDL	TFS 36697
	endif;												//Bug 38457
	
	adjustedQuantity:=self.totalQuantity - moveQuantity;
	
	if self.getMyTotalVolume &lt;&gt; 0 and self.totalQuantity &gt; 0 then
		// apportion weight based on the quantity
		if self.totalQuantity = 0 then
			newVolume := ((moveQuantity) * self.getMyTotalVolume);	//07 Oct 2013	NDL	Par 32722
		else
			newVolume := ((moveQuantity / self.totalQuantity) * self.getMyTotalVolume);	//07 Oct 2013	NDL	Par 32722
		endif;
	endif;
	adjustedVolume	:= self.getMyTotalVolume - newVolume;
	if adjustedVolume &lt; 0 then 
		adjustedVolume := 0; //07 Oct 2013	NDL	Par 32722
	endif;
	
	if self.totalWeight &lt;&gt; 0 and self.totalQuantity &gt; 0 then						//+cnwml2 MSL CCMS 1017
		// apportion weight based on the quantity
		if self.totalQuantity = 0 then
			newWeight := ((moveQuantity) * self.totalWeight);									//+cnwml2 MSL CCMS 1017
		else
			newWeight := ((moveQuantity / self.totalQuantity) * self.totalWeight);										// PAR #32323
		endif;
	endif;
	
	adjustedWeight := self.totalWeight - newWeight;	
	
	_mergeToTI.setTotalQuantity(_mergeToTI.totalQuantity + moveQuantity);
	_mergeToTI.setMyTotalVolume( _mergeToTI.totalVolume + newVolume);
	_mergeToTI.setTotalWeightWithoutTrans(_mergeToTI.totalWeight +newWeight);
	
	if useTareCargoWeight then												//Bug 38457		//28.05.2024 navma1 #64224
		_mergeToTI.setWeightCargo(_mergeToTI.weightCargo + oldCargoWeight);	//18 Jan 2018	NDL	TFS 36697
		_mergeToTI.setWeightTare(_mergeToTI.weightTare   + oldTareWeight);	//18 Jan 2018	NDL	TFS 36697
	endif;																	//Bug 38457
	
	self.setTotalQuantity(adjustedQuantity);
	self.setMyTotalVolume(adjustedVolume);
	self.setTotalWeightWithoutTrans(adjustedWeight);
	
	// ### JIRA 35213 27JUN2025 NAVAB1 	self.splitMergeChargesByFactor(oldWeight, oldVolume, newWeight, newVolume, oldQuantity, _control.quantity,_mergeToTI); // TFS 7311 // ### JIRA 34760 30APR2025 NAVAB1
	if adjustedQuantity = 0 then // self is about to become a zombie
		self.mergeChargesByFactor(_mergeToTI); 
	else
		self.splitChargesByFactor(oldWeight, oldVolume, newWeight, newVolume, oldQuantity, _control.quantity,_mergeToTI);
	endif;
	
	self.createMergeTransactons(	_mergeToTI,
									oldQuantity, oldVolume, oldWeight, oldCargoWeight, oldTareWeight,
									oldMergeQuantity ,oldMergeVolume, oldMergeWeight, oldMergeCargoWeight, oldMergeTareWeight,
									false, _control,
									_control.myPassport);
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_control" type="CMIF_MoveController" usage="input"/>
        <Parameter name="_mergeToTI" type="CM_TrackedItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="packageBulk" id="c53b19e1-4dcb-4de5-a178-5626683fabb8">
        <updating/>
        <source>packageBulk( _sourceTi : CM_Bulk input;
			 _quantity : Integer;
			 _grossWeight : Decimal;
			 _cargoWeight : Decimal;
			 _tareWeight : Decimal;
			 _passport : CM_Passport input;
			 _preMergeQuantity : Integer output; 
			 _preMergeVolume : Real output; 
			 _preMergeWeight : Decimal output;
			 _preMergeCargoWeight : Decimal output;
			 _preMergeTareWeight : Decimal output;
			 _bbIsNew : Boolean	//18 Feb 2020	NDL	TFS 48532
			 ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 April 2014	cnwndl1	Initial creation

*/

vars

	oldQuantity : Integer;
	oldVolume : Real; 
	oldWeight : Decimal[14,4];
	oldCargoWeight : Decimal[14,4];
	oldTareWeight : Decimal[14,4];
	newVolume : Decimal [16,4];
	newQuantity : Integer;
	newWeight : Decimal[14,4];
	newCargoWeight : Decimal[14,4];
	newTareWeight : Decimal[14,4];

begin

//	if self.totalWeight = 0 then
	if _bbIsNew then		//18 Feb 2020	NDL	TFS 48532
		// its a newly created one
		oldQuantity := 0;
		oldVolume := 0; 
		oldWeight := 0;
		oldCargoWeight := 0;
		oldTareWeight := 0;
		
		newQuantity := _quantity;
		newWeight := _quantity * _grossWeight;
		newCargoWeight := _quantity * _cargoWeight;
		newTareWeight := _quantity * _tareWeight;
		
		
	else
		//it was already existing merge the values in
		oldQuantity := self.totalQuantity;
		oldVolume := self.totalVolume; 
		oldWeight := self.totalWeight;
		oldCargoWeight := self.weightCargo;
		oldTareWeight := self.weightTare;
		
		_preMergeQuantity := oldQuantity; 
		_preMergeVolume := oldVolume; 
		_preMergeWeight := oldWeight;
		_preMergeCargoWeight := oldCargoWeight;
		_preMergeTareWeight := oldTareWeight;
	
		newQuantity := oldQuantity + _quantity;
		newWeight := oldWeight + (_quantity * _grossWeight);
		newCargoWeight := oldCargoWeight + (_quantity * _cargoWeight);
		newTareWeight := oldTareWeight + (_quantity * _tareWeight);
	
	endif;
	
	self.setTotalQuantity(newQuantity);
	self.setTotalWeightWithoutTrans(newWeight);
	self.setWeightCargo(newCargoWeight);
	self.setWeightTare(newTareWeight);
	if self.getDensity &gt; 0 then
		newVolume :=  newWeight / self.getDensity;
	endif;
	self.setMyTotalVolume(newVolume);
	
	

epilog

end;</source>
        <Parameter name="_sourceTi" type="CM_Bulk" usage="input"/>
        <Parameter name="_quantity" type="Integer"/>
        <Parameter name="_grossWeight" type="Decimal"/>
        <Parameter name="_cargoWeight" type="Decimal"/>
        <Parameter name="_tareWeight" type="Decimal"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <Parameter name="_preMergeQuantity" type="Integer" usage="output"/>
        <Parameter name="_preMergeVolume" type="Real" usage="output"/>
        <Parameter name="_preMergeWeight" type="Decimal" usage="output"/>
        <Parameter name="_preMergeCargoWeight" type="Decimal" usage="output"/>
        <Parameter name="_preMergeTareWeight" type="Decimal" usage="output"/>
        <Parameter name="_bbIsNew" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="eea20163-05c9-4af4-a14b-248a5b655331">
        <source>pxyCreateUpdateProxy(): SelfType;
/*

Purpose:			Creates an Update proxy that sets additional/extra fields

Parameters:			NONE

Return Value:		SelfType: Returns an object of its own type

Date		Who		Reason
30 June 2022	navpw1	Initial creation TFS: 54021

*/

vars
	proxyTI : CM_BreakBulkGeneric;
	
begin
	proxyTI := inheritMethod();
	
	proxyTI.setDiameter(self.getDiameter());
	proxyTI.setGrade(self.getGrade());
	proxyTI.setGrammage(self.getGrammage());
	proxyTI.setRollingLength(self.getRollingLength());
	
	return proxyTI;

end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
