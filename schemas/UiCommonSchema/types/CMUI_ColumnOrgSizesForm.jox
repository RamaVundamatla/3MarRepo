    <JadeMethod name="doResize" id="e5f76bdf-df37-4805-a160-cdac9488d33e">
        <updating/>
        <source>doResize() updating;
//--------------------------------------------------
// Created:	21 August 2003 By: cnwgd1
//--------------------------------------------------
vars
	tmpLeft	: Real;
	tmpTop	: Real;
	
begin
	// cnwdad1 15/12/2008 - Commented out inherit because it causes weird behaviour, and just
	// tell the multi selectors to sort themselves out.
	//inheritMethod();
	self.fldMain.top := self.frmToolbar.height; // 19.05.2022 navsrk20 #TFS 53471 
	self.fldMain.height := self.btnResetJMT.top - self.fldMain.top - 10; // 19.05.2022 navsrk20 #TFS 53471 
	mulColumns.cnEcResizeContents();
	mulColumns.repositionAfterResize();
	mulSizes.cnEcResizeContents();
	mulSizes.repositionAfterResize();
	
	tmpTop	:=	self.btnResetJMT.top;
	
	//22 dec 2011	NDl	Par 28889
	self.doResizeFilterSheet();
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doResizeFilterSheet" id="ed17a9aa-aebf-4415-a536-52a4711d0ba6">
        <source>doResizeFilterSheet() protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 December 2011	cnwndl1	Initial creation	Par 28889

*/

vars

	tmpLeft : Real;
	tmpTop : Real;
	tmpWidth : Real;
	tmpHeight : Real;
	gap : Real;
	startGap : Real;
	endGap : Real;
	totalGap : Real;
	btnGap : Real;

begin

	//work down from the top, until we reach the table.
	tmpLeft := 0;
	tmpTop := 0;
	tmpWidth := shtColumnFilter.width;
	tmpHeight := shtColumnFilter.height;
	gap := 5;	
	self.frmFilter.move(	tmpLeft,
							tmpTop,
							tmpWidth,
							tmpHeight );
	
	tmpLeft := 1;
	tmpHeight := 23;
	tmpTop := gap;
	tmpWidth := 145;
	self.btnClearAll.move(	tmpLeft,
							tmpTop,
							tmpWidth,
							tmpHeight );
							
	tmpLeft := self.btnClearAll.left + self.btnClearAll.width + gap;
	tmpWidth := shtColumnFilter.width - ( tmpLeft + 2 ) ;
	self.btnShow.move(	tmpLeft,


						tmpTop,
						tmpWidth,
						tmpHeight );
	
	tmpLeft := 1;
	tmpHeight := 20;
	tmpTop := self.btnClearAll.top + btnClearAll.height + gap;
	tmpWidth := self.frmFilter.width - 2;
		
	self.cmbColumnFilter.move(	tmpLeft,
								tmpTop,
								tmpWidth,
								tmpHeight );
								
	tmpLeft := 0;
	tmpTop := self.cmbColumnFilter.top + cmbColumnFilter.height + gap;
	tmpWidth := frmFilter.width;
	tmpHeight := frmFilter.height - tmpTop;	
	self.frmFilterValues.move(	tmpLeft,
								tmpTop,
								tmpWidth,
								tmpHeight );
									
	self.lblShowFilter.move(	tmpLeft,
								tmpTop,
								tmpWidth,
								tmpHeight );
									
	tmpHeight := 17;
	tmpTop := gap;
	tmpWidth := ( self.frmFilter.width - 4 ) / 2;
	self.optTableData.move(	tmpLeft,
							tmpTop,
							tmpWidth,
							tmpHeight );
							
	tmpLeft := tmpWidth + 2;
	self.optUserData.move(	tmpLeft,
							tmpTop,
							tmpWidth,
							tmpHeight );
							
	
	tmpLeft := 1;
	tmpWidth := self.frmFilter.width - 2;
	tmpHeight := 21;
	tmpTop := self.optTableData.top + self.optTableData.height + gap;
	self.txtFilter.move(	tmpLeft,
							tmpTop,
							tmpWidth,
							tmpHeight );
							
	//work up from bottom until we reach the table.	
	
	tmpHeight := 23;
	tmpTop := self.frmFilterValues.height - ( tmpHeight + gap );
	tmpWidth := 110;
	self.btnUnselectAll.move(	tmpLeft,
						tmpTop,
						tmpWidth,
						tmpHeight );
						
	tmpLeft := self.frmFilter.width - ( tmpWidth + 1 );
	self.btnUpdFilter.move(	tmpLeft,
							tmpTop,
							tmpWidth,
							tmpHeight );
	
	startGap := self.btnUnselectAll.left + self.btnUnselectAll.width;
	endGap := self.btnUpdFilter.left;
	totalGap := endGap - startGap;
	btnGap :=  (( totalGap - ( tmpWidth * 2 ) ) / 3 );
	
	tmpLeft := startGap + btnGap;
	self.btnSelectAll.move(	tmpLeft,
							tmpTop,
							tmpWidth,
							tmpHeight );
							
	tmpLeft := self.btnSelectAll.left + tmpWidth + btnGap;
	self.btnRemFilter.move(	tmpLeft,
							tmpTop,
							tmpWidth,
							tmpHeight );
													
	tmpLeft := 1;
	tmpTop := self.txtFilter.top;
	tmpWidth := self.frmFilter.width - 2;
	tmpHeight := self.btnUnselectAll.top - ( gap + tmpTop );
	
	self.tblFilterValues.move(	tmpLeft,
								tmpTop,
								tmpWidth,
								tmpHeight );

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doSave" id="c42dfc2c-18f9-4604-920f-5f968fcfb82e">
        <updating/>
        <source>doSave() :Boolean updating, protected;
//--------------------------------------------------------------
//Created: 14 January 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	allTableRows	: EntTableRowArray;
	
begin
	create allTableRows transient;
	
	self.getSelectedHeadings(allTableRows);
	self.myDataTable.setColumnsFromOrganiser(allTableRows, null);
	self.myDataTable.setSortColumnsForMaxNumCols();
	self.myDataTable.refreshMe();
	
// cnwdad1 16/06/2009 - PAR #19937.
	if self.chkSystem.value then
		self.doSaveSystemDefault(allTableRows);
	endif;
	
	//21 Dec 2011	NDL	Par 28889
	if columnFiltersUpdated then
		self.myDataTable.form.updateTableColumnFilters( self.myDataTable, self.allFilterColumns );
	endif;
	
	return true;
epilog
	delete allTableRows;
end;
/*
	self.allTblDataEntRows.clear();
	self.mulColumns.getSelected(self.allTblDataEntRows);
	self.mulSizes.getSelected(self.allTblDataEntRows);
	
	if self.chkSystem.value then
		self.doSaveSystemDefault();
	endif;
	
	// check for column removed
	allOldRowsObj	:=	self.myDataTable.allTblDataEntRows;
	
	foreach entRowObj in allOldRowsObj do
		oldRow	:=	oldRow + 1;
		newRow	:=	self.allTblDataEntRows.indexOf(entRowObj);
		
		if newRow &lt;&gt; oldRow then
			// visible column has changed
			isChanged	:=	true;
			break;
		endif;
	endforeach;
	
	if (not isChanged) then
		// check for any new column
		newRow	:=	0;
		oldRow	:=	0;
		
		foreach entRowObj in self.allTblDataEntRows do
			newRow	:=	newRow + 1;
			oldRow	:=	allOldRowsObj.indexOf(entRowObj);
			
			if newRow &lt;&gt; oldRow then
				// visible column has changed
				isChanged	:=	true;
				break;
			endif;
		endforeach;
	endif;
	
	if isChanged then
		// set the columns and resorts the table
		self.myDataTable.setColumnsFromOrganiser(self.allTblDataEntRows,null);
	elseif isSortChanged then
		// resort only handled here
		if self.myDataTable &lt;&gt; null then
			self.myDataTable.setSortColumnsForMaxNumCols();
			isChanged	:=	true;
		endif;
	endif;
	
	return isChanged; // form handles visible column changes
*/</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSaveSystemDefault" id="06237d9a-be8a-4d9d-919c-553db14c1c8f">
        <updating/>
        <source>doSaveSystemDefault(_allTableRows:EntTableRowArray)updating, protected;
//--------------------------------------------------------------
//Created: 09 May 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	viewObj		: EntTableView;
	tableDefObj	: EntTableDef;
	theResult : Integer;	//13 Jan 2020 NDL	TFS 46815
	
begin
	// First, save the Column Organiser's Default View.
	
	viewObj		:=	self.myEntTableDef.allEntTableViews[SystemDefault];
	
	if viewObj = null then
		create viewObj transient;
		viewObj.setProxy(SystemDefault, 'System Default');
	endif;
	
	//13 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxUA.trxResetSystemDefForView(viewObj, _allTableRows, self.myEntTableDef, app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			break;
		else
			theResult := app.showErrorWarningDialog('System Default', app.myPassport, ErrWarnMode_Update);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		return;
		
	endwhile;
	
	if viewObj.isTransient() then
		delete viewObj;
	endif;
	
	// Next, save the Data Table's Default View.
	
	tableDefObj	:=	app.myRoot.myEntTableDataRoot.allEntTableDefs[ETDef_YAMDataTbl];
	viewObj		:=	tableDefObj.allEntTableViews[SystemDefault];
	
	if viewObj = null then
		create viewObj transient;
		viewObj.setProxy(SystemDefault, 'System Default');
	endif;
	
	theResult := 0;
	//13 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxUA.trxResetSystemDefForView(viewObj, _allTableRows, tableDefObj, app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			break;
		else
			theResult := app.showErrorWarningDialog('System Default', app.myPassport, ErrWarnMode_Update);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		break;
		
	endwhile;
	
	
epilog
	if viewObj.isTransient() then
		delete viewObj;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_allTableRows" type="EntTableRowArray"/>
    </JadeMethod>
    <JadeMethod name="doSelectColumnToFilter" id="b9ea46fd-4125-4269-975e-f79f534d3cb9">
        <updating/>
        <source>doSelectColumnToFilter()protected, updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 December 2011	cnwndl1	Initial creation	Par 28889

*/

vars

	pos : Integer;
	str : String;
	strArray : StringArray;
	intArray : IntegerArray;
	index : Integer;
	column : Integer;
	entableRowHeading : String;
	colFilter : CM_ColumnFilter;

begin

	self.selectFilterUpdated := false;
	self.txtFilter.text := null;
	self.optTableData.value := true;
	self.optUserData.value := false;
	self.changeFilterOptions();

	//set up the table for the filter values
	self.tblFilterValues.fixedRows := 1;
	self.tblFilterValues.rows := 1;
	self.tblFilterValues.fixedColumns := 0;
	self.tblFilterValues.columns := 3;
	self.tblFilterValues.accessColumn(1).inputType := Table.InputType_CheckBox;
	
	// set up the column headings for the table of filter values
	self.tblFilterValues.accessCell(1,1).inputType := Table.InputType_None;
	self.tblFilterValues.setCellText(1,1, "Include" &amp; Tab &amp; "Value" &amp; Tab &amp; "Items");
	
	self.tblFilterValues.zAddSortColumn("Value", false);
	
	// get the data values from the data table.	
	if self.myDataTable = null then
		return;
	endif;
	
	if self.cmbColumnFilter.text.trimBlanks = null then
		return;
	endif;

	if self.cmbColumnFilter.listIndex &gt; 0 then
		entableRowHeading := self.cmbColumnFilter.itemObject[ self.cmbColumnFilter.listIndex ].EntTableRow.getHeading(self.myDataTable.myTerminologyCargoBOLType, self.myDataTable.myTerminologyTerminal, app.myCurrentLocale);
	endif;
	column := self.myDataTable.getColumnByHeading( self.cmbColumnFilter.text );
	if column = 0 and self.cmbColumnFilter.listIndex &gt; 0 then
		// maybe its using the short description...
		column := self.myDataTable.allTblDataEntRows.indexOf( self.cmbColumnFilter.itemObject[ self.cmbColumnFilter.listIndex ].EntTableRow );
	endif;
		
	create strArray transient;
	create intArray transient;
	self.getFilterValuesFromSource( column, strArray, intArray );
	
	if strArray.isEmpty then
		 return;
	endif;
	
	// find the current Column Filter if there is one.
	colFilter := self.allFilterColumns.getColumnFilter( self.myDataTable, column, entableRowHeading);
	
	// add in the filter value lines
	pos := 0;
	foreach str in strArray do
		pos := pos + 1;
		if colFilter &lt;&gt; null and not colFilter.userEntered and colFilter.includesFilterValue( str ) then
			index := self.tblFilterValues.addItem( "1" &amp; Tab &amp; str &amp; Tab &amp; intArray[pos].String);
		else
			index := self.tblFilterValues.addItem( "0" &amp; Tab &amp; str &amp; Tab &amp; intArray[pos].String);
		endif;
	endforeach;	
	self.tblFilterValues.sortAscending := true;
	self.tblFilterValues.resortTableByColumn(2);
	
	
	if colFilter &lt;&gt; null and colFilter.userEntered then
		//user entered value.
		self.txtFilter.text := colFilter.filterValues.first;
		self.optUserData.value := true;
		self.optTableData.value := false;
		self.changeFilterOptions();
	endif;
	
	

epilog

	self.lblShowFilter.visible := self.cmbColumnFilter.listIndex &lt; 1;

	self.enabledFilterButtons();
	delete strArray;
	delete intArray;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="enabledFilterButtons" id="2f4c715c-d695-42bc-a34a-c3df6d595a71">
        <source>enabledFilterButtons();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 December 2011	cnwndl1	Initial creation	Par 28889

*/

vars

begin

	if self.cmbColumnFilter.listIndex &gt; 0 then
		self.btnSelectAll.enabled := true;
		self.btnUnselectAll.enabled := true;
		self.btnUpdFilter.enabled := self.selectFilterUpdated;
		if self.cmbColumnFilter.itemForeColor[self.cmbColumnFilter.listIndex] = Red then
			self.btnRemFilter.enabled := true;
		else
			self.btnRemFilter.enabled := false;
		endif;
	else
		self.btnSelectAll.enabled := false;
		self.btnUnselectAll.enabled := false;
		self.btnUpdFilter.enabled := false;
		self.btnRemFilter.enabled := false;
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="fldMain_sheetChg" id="c2f26939-e7d7-4f0d-a6c8-8b7ee484b19f">
        <controlMethod name="Folder::sheetChg"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>fldMain_sheetChg(folder: Folder input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 December 2011	cnwndl1	Initial creation

*/

vars

begin

	if folder.topSheet = self.shtColumnFilter then	//20 Dec 2011	NDL	Par 28889
		self.showFilterSheet();
	else
		//13/01/2011 cnwdz2 25840
		self.btnResetJMT.visible := true;
		self.btnResetSys.visible := true;
		self.chkSystem.visible := true;
	endif;

epilog

end;</source>
        <Parameter name="folder" type="Folder" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getAllEntTableRows" id="1621a45b-88c4-4688-83de-d721c3865c5a">
        <source>getAllEntTableRows(_allRowsObj:EntTableRowArray input) protected;
// --------------------------------------------------------------------------------
// Created:		26 June 2009 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	entRowObj	: EntTableRow;
	arrayObj	: EntTableRowArray;
	
begin
	// This method gets all the available columns for the table
	if self.myDataTable = null then
		return;
	endif;
	
	// add any hiden rows
	if self.myDataTable &lt;&gt; null then
		if self.myDataTable.myEntTableView = null then
			arrayObj	:=	self.myDataTable.allTblDataEntRows;
		else
			// If table has a view only show those available to that view
			// view is set if CM_DataTable::setTblDataEntRowsFromView is called.
			arrayObj	:=	self.myEntTableView.allEntTableRows;
		endif;
	endif;
	
	foreach entRowObj in arrayObj do
		//in situations where there are hidden rows, we don't want to allow them to be organised.
		if not entRowObj.visible then
			continue;
		endif;
		
		if entRowObj.name = ETRow_MySubTerminal and not app.isSubTerminalsOn(self.myTerminal) then
			continue;
		endif;
		
		_allRowsObj.add(entRowObj);
	endforeach;
end;</source>
        <access>protected</access>
        <Parameter name="_allRowsObj" type="EntTableRowArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getFilterDetailsForDisplay" id="d7e88f4b-9da9-4581-8b60-44cdda3851f5">
        <source>getFilterDetailsForDisplay():String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 February 2012	cnwndl1	Initial creation

*/

vars

	returnString : String;
	filter : CM_ColumnFilter;

begin

	returnString := null;

	foreach filter in self.allFilterColumns do
		returnString := returnString &amp; "    " &amp; filter.getFilterDetailsAsString() &amp; CrLf;
	endforeach;
	
	if returnString = null then
	else
		returnString := CrLf &amp; CrLf &amp; returnString;
	endif;

	return returnString;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getFilterValuesFromSource" id="69e68430-7830-40cc-950b-09eea3671fc7">
        <source>getFilterValuesFromSource(  _column : Integer; _strArray : StringArray io;  _intArray : IntegerArray io ) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 December 2011	cnwndl1	Initial creation	Par 28889

*/

vars

	startRow : Integer;
	endRow : Integer;
	rowIndex : Integer;
	str : String;
	includedPos : Integer;
	checkRowObject : Boolean;
	rowObject : Object;
	
begin

	if self.myDataTable = null then
		return;
	endif;
	
	if _column &lt; 1 then
		return;
	endif;

	startRow := self.myDataTable.fixedRows + 1;
	endRow := self.myDataTable.rows;
	
	if endRow &lt;= startRow then
		return;
	endif;
	
	if self.myDataTable.isKindOf( CM_YAMTable ) then
		checkRowObject := true;
	endif;
	
	
	foreach rowIndex in startRow to endRow do
		if checkRowObject then
			rowObject := self.myDataTable.accessRow(rowIndex).itemObject;
			if rowObject = null or not rowObject.isKindOf( CM_YardAllocation ) then
				continue;
			endif;
		endif;
		str := self.myDataTable.getCellText( rowIndex, _column ).trimBlanks;
		if str = null then
			str := CM_ColumnFilter.NullString;
		endif;
		if str.length &gt; 50 then
			str := str[1:50] &amp; "...";
		endif;
		if _strArray.isEmpty then
			includedPos := 0;
		else
			includedPos := _strArray.indexOf(str);
		endif;
		if includedPos = 0 then
			_strArray.add( str );
			_intArray.add( 1 );
		else
			_intArray[includedPos] := _intArray[includedPos] + 1;
		endif;
	endforeach;
	

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_column" type="Integer"/>
        <Parameter name="_strArray" type="StringArray" usage="io"/>
        <Parameter name="_intArray" type="IntegerArray" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getSelectedHeadings" id="03a47cd1-6406-4efd-badb-eda2a390a56f">
        <source>getSelectedHeadings(_allTableRows:EntTableRowArray input);
/* ---------------------------------------------------------------------------
Created:     27 January 2009 by cnwrs2

Purpose:	Populate the specified string array parameter with the names of
			the selected headings.
        
Change Date	Who		Reason

------------------------------------------------------------------------------*/
vars
	tableDefObj		: EntTableDef;
	tableRowObj		: EntTableRow;
	allSelectedRows	: EntTableRowArray;
	allColumns		: EntTableRowArray;
	allSizes		: EntTableRowArray;
	headingObj		: EntTableRow;
	sizeObj			: EntTableRow;
	
begin

	tableDefObj	:=	app.myRoot.myEntTableDataRoot.getEntTableDef(ETDef_YAMDataTbl);
	
	create allSelectedRows transient;
	create allColumns transient;
	create allSizes transient;
	
	// Get rows that the Users have no say in whether they are shown.
	
	tableRowObj	:=	tableDefObj.getEntTableRow(ETRow_HideShow);
	
	if tableRowObj &lt;&gt; null then
		allSelectedRows.add(tableRowObj);
	endif;
	
	tableRowObj	:=	tableDefObj.getEntTableRow(ETRow_Code);
	
	if tableRowObj &lt;&gt; null then
		allSelectedRows.add(tableRowObj);
	endif;
	
	// Now get the optional rows.
	
	mulColumns.getSelected(allColumns);
	mulSizes.getSelected(allSizes);
	
	foreach headingObj in allColumns do
		if headingObj.name = ETRow_FreeSpace
		or headingObj.name = ETRow_TotalPlanIn
		or headingObj.name = ETRow_TotalPlanOut
		or headingObj.name = ETRow_TotalProjected
		or headingObj.name = ETRow_QueuedIn
		or headingObj.name = ETRow_QueuedOut
		or headingObj.name = ETRow_TotalSpace
		or headingObj.name = ETRow_UsedSpace
	//	or headingObj.name = ETRow_Stacking
	//	or headingObj.name = ETRow_DeckingSequence
		then
			foreach sizeObj in allSizes do
				tableRowObj	:=	null;
				
				if headingObj.name = ETRow_FreeSpace then
					if sizeObj.name = ETRow_20s then
						tableRowObj	:=	tableDefObj.getEntTableRow(ETRow_Free20);
					elseif sizeObj.name = ETRow_30s then
						tableRowObj	:=	tableDefObj.getEntTableRow(ETRow_Free30);
					elseif sizeObj.name = ETRow_40s then
						tableRowObj	:=	tableDefObj.getEntTableRow(ETRow_Free40);
					elseif sizeObj.name = ETRow_45s then
						tableRowObj	:=	tableDefObj.getEntTableRow(ETRow_Free45);
					elseif sizeObj.name = ETRow_53s then
						tableRowObj	:=	tableDefObj.getEntTableRow(ETRow_Free53);
					elseif sizeObj.name = ETRow_ColTotals then //cnwjo3 par 21189
						tableRowObj	:=	tableDefObj.getEntTableRow(ETRow_ColTotalFree);
					endif;
					
				elseif headingObj.name = ETRow_TotalPlanIn then
					if sizeObj.name = ETRow_20s then
						tableRowObj	:=	tableDefObj.getEntTableRow(ETRow_PlannedIn20);
					elseif sizeObj.name = ETRow_30s then
						tableRowObj	:=	tableDefObj.getEntTableRow(ETRow_PlannedIn30);
					elseif sizeObj.name = ETRow_40s then
						tableRowObj	:=	tableDefObj.getEntTableRow(ETRow_PlannedIn40);
					elseif sizeObj.name = ETRow_45s then
						tableRowObj	:=	tableDefObj.getEntTableRow(ETRow_PlannedIn45);
					elseif sizeObj.name = ETRow_53s then
						tableRowObj	:=	tableDefObj.getEntTableRow(ETRow_PlannedIn53);
					elseif sizeObj.name = ETRow_ColTotals then //cnwjo3 par 21189
						tableRowObj	:=	tableDefObj.getEntTableRow(ETRow_ColTotalPlanIn);
					endif;

				elseif headingObj.name = ETRow_TotalPlanOut then
					if sizeObj.name = ETRow_20s then
						tableRowObj	:=	tableDefObj.getEntTableRow(ETRow_PlannedOut20);
					elseif sizeObj.name = ETRow_30s then
						tableRowObj	:=	tableDefObj.getEntTableRow(ETRow_PlannedOut30);
					elseif sizeObj.name = ETRow_40s then
						tableRowObj	:=	tableDefObj.getEntTableRow(ETRow_PlannedOut40);
					elseif sizeObj.name = ETRow_45s then
						tableRowObj	:=	tableDefObj.getEntTableRow(ETRow_PlannedOut45);
					elseif sizeObj.name = ETRow_53s then
						tableRowObj	:=	tableDefObj.getEntTableRow(ETRow_PlannedOut53);
					elseif sizeObj.name = ETRow_ColTotals then //cnwjo3 par 21189
						tableRowObj	:=	tableDefObj.getEntTableRow(ETRow_ColTotalPlanOut);
					endif;

				elseif headingObj.name = ETRow_TotalProjected then
					if sizeObj.name = ETRow_20s then
						tableRowObj	:=	tableDefObj.getEntTableRow(ETRow_Projected20);
					elseif sizeObj.name = ETRow_30s then
						tableRowObj	:=	tableDefObj.getEntTableRow(ETRow_Projected30);
					elseif sizeObj.name = ETRow_40s then
						tableRowObj	:=	tableDefObj.getEntTableRow(ETRow_Projected40);
					elseif sizeObj.name = ETRow_45s then
						tableRowObj	:=	tableDefObj.getEntTableRow(ETRow_Projected45);
					elseif sizeObj.name = ETRow_53s then
						tableRowObj	:=	tableDefObj.getEntTableRow(ETRow_Projected53);
					elseif sizeObj.name = ETRow_ColTotals then //cnwjo3 par 21189
						tableRowObj	:=	tableDefObj.getEntTableRow(ETRow_ColTotalProjected);
					endif;

				elseif headingObj.name = ETRow_QueuedIn then
					if sizeObj.name = ETRow_20s then
						tableRowObj	:=	tableDefObj.getEntTableRow(ETRow_QueuedIn20);
					elseif sizeObj.name = ETRow_30s then
						tableRowObj	:=	tableDefObj.getEntTableRow(ETRow_QueuedIn30);
					elseif sizeObj.name = ETRow_40s then
						tableRowObj	:=	tableDefObj.getEntTableRow(ETRow_QueuedIn40);
					elseif sizeObj.name = ETRow_45s then
						tableRowObj	:=	tableDefObj.getEntTableRow(ETRow_QueuedIn45);
					elseif sizeObj.name = ETRow_53s then
						tableRowObj	:=	tableDefObj.getEntTableRow(ETRow_QueuedIn53);
					elseif sizeObj.name = ETRow_ColTotals then //cnwjo3 par 21189
						tableRowObj	:=	tableDefObj.getEntTableRow(ETRow_ColTotalQIn);
					endif;
					
				elseif headingObj.name = ETRow_QueuedOut then
					if sizeObj.name = ETRow_20s then
						tableRowObj	:=	tableDefObj.getEntTableRow(ETRow_QueuedOut20);
					elseif sizeObj.name = ETRow_30s then
						tableRowObj	:=	tableDefObj.getEntTableRow(ETRow_QueuedOut30);
					elseif sizeObj.name = ETRow_40s then
						tableRowObj	:=	tableDefObj.getEntTableRow(ETRow_QueuedOut40);
					elseif sizeObj.name = ETRow_45s then
						tableRowObj	:=	tableDefObj.getEntTableRow(ETRow_QueuedOut45);
					elseif sizeObj.name = ETRow_53s then
						tableRowObj	:=	tableDefObj.getEntTableRow(ETRow_QueuedOut53);
					elseif sizeObj.name = ETRow_ColTotals then //cnwjo3 par 21189
						tableRowObj	:=	tableDefObj.getEntTableRow(ETRow_ColTotalQOut);
					endif;
					
				elseif headingObj.name = ETRow_TotalSpace then
					if sizeObj.name = ETRow_20s then
						tableRowObj	:=	tableDefObj.getEntTableRow(ETRow_Total20);
					elseif sizeObj.name = ETRow_30s then
						tableRowObj	:=	tableDefObj.getEntTableRow(ETRow_Total30);
					elseif sizeObj.name = ETRow_40s then
						tableRowObj	:=	tableDefObj.getEntTableRow(ETRow_Total40);
					elseif sizeObj.name = ETRow_45s then
						tableRowObj	:=	tableDefObj.getEntTableRow(ETRow_Total45);
					elseif sizeObj.name = ETRow_53s then
						tableRowObj	:=	tableDefObj.getEntTableRow(ETRow_Total53);
					elseif sizeObj.name = ETRow_ColTotals then //cnwjo3 par 21189
						tableRowObj	:=	tableDefObj.getEntTableRow(ETRow_ColTotalTotal);
					endif;
					
				elseif headingObj.name = ETRow_UsedSpace then
					if sizeObj.name = ETRow_20s then
						tableRowObj	:=	tableDefObj.getEntTableRow(ETRow_Used20);
					elseif sizeObj.name = ETRow_30s then
						tableRowObj	:=	tableDefObj.getEntTableRow(ETRow_Used30);
					elseif sizeObj.name = ETRow_40s then
						tableRowObj	:=	tableDefObj.getEntTableRow(ETRow_Used40);
					elseif sizeObj.name = ETRow_45s then
						tableRowObj	:=	tableDefObj.getEntTableRow(ETRow_Used45);
					elseif sizeObj.name = ETRow_53s then
						tableRowObj	:=	tableDefObj.getEntTableRow(ETRow_Used53);
					elseif sizeObj.name = ETRow_ColTotals then //cnwjo3 par 21189
						tableRowObj	:=	tableDefObj.getEntTableRow(ETRow_ColTotalUsed);
					endif;
				endif;
				
				if tableRowObj &lt;&gt; null then
					allSelectedRows.add(tableRowObj);
				endif;
			endforeach;
			
		elseif headingObj.name = ETRow_Stacking then
			tableRowObj	:=	tableDefObj.getEntTableRow(ETRow_Stacking);
			
			if tableRowObj &lt;&gt; null then
				allSelectedRows.add(tableRowObj);
			endif;
			
		elseif headingObj.name = ETRow_DeckingSequence then
			tableRowObj	:=	tableDefObj.getEntTableRow(ETRow_DeckingSequence);
			
			if tableRowObj &lt;&gt; null then
				allSelectedRows.add(tableRowObj);
			endif;

		elseif headingObj.name = ETRow_PriorityValue then
			tableRowObj	:=	tableDefObj.getEntTableRow(ETRow_PriorityValue);
			
			if tableRowObj &lt;&gt; null then
				allSelectedRows.add(tableRowObj);
			endif;

		//cnwjo3, par 20135
		elseif headingObj.name = ETRow_AllowOthers then
			tableRowObj	:=	tableDefObj.getEntTableRow(ETRow_AllowOthers);
			
			if tableRowObj &lt;&gt; null then
				allSelectedRows.add(tableRowObj);
			endif;
		//cnwjo3, par 20135
		elseif headingObj.name = ETRow_OverstowRule then
			tableRowObj	:=	tableDefObj.getEntTableRow(ETRow_OverstowRule);
			
			if tableRowObj &lt;&gt; null then
				allSelectedRows.add(tableRowObj);
			endif;
		//cnwjo3, par 20135
		elseif headingObj.name = ETRow_IfNoLocationFound then
			tableRowObj	:=	tableDefObj.getEntTableRow(ETRow_IfNoLocationFound);
			
			if tableRowObj &lt;&gt; null then
				allSelectedRows.add(tableRowObj);
			endif;
			
		//05 Jan 2012	NDL	Par 28889
		elseif self.myDataTable.isGenFilterableYAMcolumn( headingObj.name ) then
			tableRowObj	:=	tableDefObj.getEntTableRow(headingObj.name);
			if tableRowObj &lt;&gt; null then
				allSelectedRows.add(tableRowObj);
			endif;
			
		endif;
		
		
	endforeach;
	
	allSelectedRows.copy(_allTableRows);
epilog
	delete allColumns;
	delete allSizes;
	delete allSelectedRows;
end;</source>
        <Parameter name="_allTableRows" type="EntTableRowArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="initMultiSelectShts" id="3975e1e0-bee7-40e9-9c39-c1794a64bee2">
        <source>initMultiSelectShts()protected;
//--------------------------------------------------
// Created:	08 September 2005 By: cnwgd1
//--------------------------------------------------
vars
	tmpMulSel : CMUI_MultiSelectGroupBox;
begin
	tmpMulSel := self.mulColumns;
	tmpMulSel.availableHeading := 'Available Columns';
	tmpMulSel.selectedHeading := 'Selected Columns &amp;&amp; Order';
	tmpMulSel.formDisplayEntryMethodName := CMUI_ColumnOrgSizesForm::displayMultiSelectAvailable.name;
	tmpMulSel.myBaseForm := self;
	tmpMulSel.myAvailableListBox.sorted := false;		
	tmpMulSel.mySelectedListBox.sorted := false;
	tmpMulSel.mySelectedListBox.allowDragDrop := true;	
	tmpMulSel.displayOrderBtns(true, true);
	tmpMulSel.multiSelect := ListBox.MultiSelect_Extended;
	
	tmpMulSel := self.mulSizes;
	tmpMulSel.availableHeading := 'Available Sizes';
	tmpMulSel.selectedHeading := 'Selected Sizes &amp;&amp; Order';
	tmpMulSel.formDisplayEntryMethodName := CMUI_ColumnOrgSizesForm::displayMultiSelectAvailable.name;
	tmpMulSel.myBaseForm := self;
	tmpMulSel.myAvailableListBox.sorted := false;		
	tmpMulSel.mySelectedListBox.sorted := false;
	tmpMulSel.mySelectedListBox.allowDragDrop := true;	
	tmpMulSel.displayOrderBtns(true, true);
	tmpMulSel.multiSelect := ListBox.MultiSelect_Extended;
	
	
	
epilog
	
end;</source>
        <access>protected</access>
    </JadeMethod>
