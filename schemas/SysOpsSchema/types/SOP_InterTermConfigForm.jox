    <JadeMethod name="setupForm" id="bddb8fac-d357-4cf0-b1f5-a9562b669175">
        <updating/>
        <source>setupForm() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
01 February 2010	conkc1	Initial creation

*/
vars

	terminalObj      : CM_Terminal;
	interTermConfig  : CM_InterTerminalConfig;
	index            : Integer;
	
begin
	inheritMethod();

	self.handleViewMode(true);

	terminalObj	:=	self.myTerminal;
	
	if terminalObj = null then
		app.raiseUnexpectedProgramError(class.name, method.name, "No Terminal has been selected.");
		self.unloadForm();
		return;
	endif;

	self.clearAll;

	self.cmbConfigName.clear;
	foreach interTermConfig in terminalObj.allInterTerminalConfigs do
		index := self.cmbConfigName.addItem(interTermConfig.configName);
		self.cmbConfigName.itemObject[index] := interTermConfig;
	endforeach;

	self.doLoadDeliveryReasons;
	
	self.doLoadConsignees;
	
	
	if self.cmbConfigName.listCount = 0 then
		setupForAdd;
		setupFormWithObject(Mode_Add);
		self.vMode := Mode_Add;
		tbxConfigName.enabled := false;
		btnAdd.setFocus;
	else
		self.disableControls;	
	endif;

	if app.isSubTerminalsOn(self.myTerminal) then
		lblSubTerminal.visible := true;
		cmbSubTerminal.visible := true;
		self.myAssistant.comboBoxSubTerminal(cmbSubTerminal, null, self.myTerminal); 	
	else
		lblSubTerminal.visible := false;
		cmbSubTerminal.visible := false;
	endif;
	
	self.grpMultiSelect.mySelectedListBox.tabIndex  := self.chxAutoAssign.tabIndex - 1;
	self.grpMultiSelect.myAvailableListBox.tabIndex := self.chxAutoAssign.tabIndex - 2;

		
	self.centreWindow();


	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupFormWithObject" id="29a14e10-da7d-4f31-b3e2-5fd1c4a30774">
        <updating/>
        <source>setupFormWithObject(_mode : Integer) updating;
/*

Purpose:			Process the selection of a Config Name Object

Parameters:			

Return Value:		

Date				Who		Reason
02 February 2010	conkc1	Initial creation

*/
vars
	index             : Integer;
	gate              : CM_Gate;
	terminalInfo      : CM_InterTermTargetTermInfo;
	proxyterminalInfo : CM_InterTermTargetTermInfo;

begin 

	self.doLoadTerminalAreas;

	self.grpMultiSelect.formDisplayEntryMethodName := SOP_InterTermConfigForm::getTerminalAreaName.name;
	self.grpMultiSelect.setAvailable(self.allAvailableTerminalAreas, true); 
	self.grpMultiSelect.setSelected(self.allSelectedTerminalAreas);
	
	self.cmbDefaultGate.clear;
	foreach gate in self.myTerminal.allGates where gate.isOutGate = true do
		index := self.cmbDefaultGate.addItem(gate.name);
		self.cmbDefaultGate.itemObject[index] := gate;
	endforeach;

	lstDestination.clear;
	if _mode = Mode_Add then
		return;
	endif;

	self.cmbDefaultGate.listIndex := self.cmbDefaultGate.findObject(self.myInterTerminalConfig.myGate);
	if self.cmbDefaultGate.listIndex &gt; 0 then
		self.cmbDefaultGate.click(self.cmbDefaultGate);
	endif;
	//
	// Create proxy for each CM_InterTermTargetTermInfo
	//
	self.allInterTermTargetTermInfo.clear;
	foreach terminalInfo in self.myInterTerminalConfig.allInterTermTargetTermInfo do

		proxyterminalInfo := terminalInfo.createProxy;
		if terminalInfo.autoPlanAtDestTerminal = true then
			index := self.lstDestination.addItem(terminalInfo.myTargetTerminal.code &amp; ', ' &amp; 'Auto Plan at Destination');
		else
			index := self.lstDestination.addItem(terminalInfo.myTargetTerminal.code &amp; ', ' &amp; terminalInfo.myDefaultTargetTermArea.id);
		endif;
		
		self.lstDestination.itemObject[index] := proxyterminalInfo;
		self.allInterTermTargetTermInfo.add(proxyterminalInfo);

	endforeach;

	if self.myInterTerminalConfig.myRelease &lt;&gt; null then

		tbxRelNumber.text := self.myInterTerminalConfig.myRelease.code;
		self.myConsignee  := app.myRoot.allConsigneeConsignors[self.myInterTerminalConfig.myRelease.consigneeCode];
		self.cmbConsignee.listIndex := self.cmbConsignee.findObject(self.myConsignee);
		if self.cmbConsignee.listIndex &gt; 0 then
			self.myConsignee := self.cmbConsignee.listObject.CM_ConsigneeConsignor;
		else
			self.myConsignee := null;
		endif;

		self.cmbSubTerminal.listIndex := self.cmbSubTerminal.findObject(self.myInterTerminalConfig.myRelease.mySubTerminal);
		if self.cmbSubTerminal.listIndex &gt; 0 then
			self.cmbSubTerminal.click(self.cmbSubTerminal);
		endif;

		self.txtConsignorVoy.text := self.myInterTerminalConfig.myRelease.consignorVoyageCode;
		/*
		self.cmbConsignorVoy.listIndex := self.cmbConsignorVoy.findObject(self.myInterTerminalConfig.myRelease.myVoyage);
		if self.cmbConsignorVoy.listIndex &gt; 0 then
			self.cmbConsignorVoy.click(self.cmbConsignorVoy);
		endif;*/
		
		self.myDeliveryReleaseReason := app.myRoot.allDeliveryReasonselReasons[self.myInterTerminalConfig.myRelease.deliveryReasonCode];
		self.cmbDeliveryReasn.listIndex := self.cmbDeliveryReasn.findObject(self.myDeliveryReleaseReason);
		if self.cmbDeliveryReasn.listIndex &gt; 0 then
			self.cmbDeliveryReasn.click(self.cmbDeliveryReasn);
		endif;

	else
		self.cmbConsignee.listIndex     := -1;
		self.cmbSubTerminal.listIndex   := -1;
		//self.cmbConsignorVoy.listIndex  := -1;
		self.cmbDeliveryReasn.listIndex := -1;
		self.myConsignee := null;
	endif;

	chxAutoAssign.value   := self.myInterTerminalConfig.autoAssignCargoOnMoveIn;
	chxAutoUnassign.value := self.myInterTerminalConfig.autoUnassignCargoOnMoveOut;

	self.handleViewMode(true);

epilog

end;</source>
        <Parameter name="_mode" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="showDestinationTerminalForm" id="4ebe1d91-8111-48b4-9a50-82839056f500">
        <updating/>
        <source>showDestinationTerminalForm(_mode : Integer) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 February 2010	conkc1	Initial creation

*/
vars

	destinationTerminalForm	: SOP_DestinationTerminalForm;
	interTerminalInfo       : CM_InterTermTargetTermInfo;
	returnValue             : Integer;
	index                   : Integer;
	string                  : String;
	
begin
	create destinationTerminalForm;
	//
	// Add new destination terminal Build set of terminals not to show on the form
	//
	foreach interTerminalInfo in self.allInterTermTargetTermInfo do
		destinationTerminalForm.allUsedTerminals.add(interTerminalInfo.myTargetTerminal);
	endforeach;

	if _mode = Mode_Add then

		destinationTerminalForm.myEditTerminal := null;

	elseif _mode = Mode_Edit then
		destinationTerminalForm.myEditTerminal      := self.myEditTerminal;
		destinationTerminalForm.myInterTerminalInfo := self.myInterTerminalInfo;
	else

	endif;
	//
	// Can not use ourself
	//
	destinationTerminalForm.allUsedTerminals.add(self.myTerminal);
	
	destinationTerminalForm.setAssistantAndTerminalRefs(self.myAssistant, self.myAssistant.myTerminal);
	destinationTerminalForm.myInterTerminalConfig := self.myInterTerminalConfig;
	destinationTerminalForm.vMode := _mode;

	returnValue := destinationTerminalForm.showModal();
	//
	// Check for cancel
	//
	if returnValue = -1 then
		return;
	endif;
	
	self.vDestinationAutoPlan        := destinationTerminalForm.chxAutoPlan.value;
	self.vDestinationTerminal        := destinationTerminalForm.vDestinationTerminal;
	self.vDestinationDefaultTermArea := destinationTerminalForm.vDefaultTerminalArea;

	if self.vDestinationTerminal = null then
		return;
	endif;

	if _mode = Mode_Add then
		create myInterTerminalInfo transient;
	else
		self.lstDestination.removeItem(lstDestination.findObject(myInterTerminalInfo));
		self.allInterTermTargetTermInfo.remove(myInterTerminalInfo);
	endif;

	myInterTerminalInfo.updateProxy(self.vDestinationAutoPlan, self.vDestinationDefaultTermArea, self.vDestinationTerminal);
	
	string := self.vDestinationTerminal.code;
	if self.myInterTerminalInfo.autoPlanAtDestTerminal = true then
		string := string &amp; ', Auto Plan at destination';
	else
		string := string &amp; ', Default Terminal Area : ' &amp;  self.myInterTerminalInfo.myDefaultTargetTermArea.id;
	endif;

	index := lstDestination.addItem(string);
	lstDestination.itemObject[index] := myInterTerminalInfo;
	self.allInterTermTargetTermInfo.add(myInterTerminalInfo);

epilog

end;</source>
        <Parameter name="_mode" type="Integer"/>
    </JadeMethod>
