    <JadeMethod name="getNewVolumeFromStrings" id="587dff32-4a02-4aac-8558-d64d8dae0b8e">
        <source>getNewVolumeFromStrings() : Decimal;
//-----------------------------------------------------------------------
//	Created:	21 July 2006 Lorcan Bolster  (cnwlb1/lorcan)
//  Removed since 792: re-instated 19/03/2012 cnwjre1 as is used in report writer reports
//-----------------------------------------------------------------------
vars
	str : String;
	vol : Decimal[12,4];
	
begin

	str :=  self.fieldsValues.getAsEditPair();
	//epr par 36422 22/6/15
	if str.toUpper.pos (CM_TrackedItem::volume.name.toUpper, 1) &lt;&gt; 0 then
		str := str[str.toUpper.pos (CM_TrackedItem::volume.name.toUpper, 1):end];
		if str.pos ("=&gt; ", 1) &lt;&gt; 0 then
			str := str[str.pos ("=&gt; ", 1)+3:end];
			vol := str.Decimal;
		endif;
	endif;
	
	return vol;
end;</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="getWeightChanges" id="0fd77a7e-b64e-4cfb-95b9-bb225311ff1a">
        <source>getWeightChanges(): String;
//----------------------------------------------------------------------
//  Created by cnwsh3
//	Date 21 November 2008
//
// Implemented version:
// 
//----------------------------------------------------------------------
vars
	str : String;
	ti : CM_TrackedItem;
	oldValue,
	newValue : String;
	i : Integer;
	field : String;
begin
	ti := self.myTrackedItem;
	foreach i in 1 to self.fieldsValues.size  do
		self.getFieldValues(i, field, oldValue, newValue);
		//if field = CM_TrackedItem::weight.name then					//-cnwml2 MSL CCMS 1017
		if field = CM_TrackedItem::totalWeight.name then				//+cnwml2 MSL CCMS 1017
		   	if oldValue = null then
				oldValue := 'null';
			endif;
			if newValue = null then
				newValue := 'null';
			endif;
			if str = null then
				str := oldValue &amp; '&gt;&gt;'&amp; newValue;
			else
				str := str &amp; CrLf &amp; oldValue &amp; '&gt;&gt;'&amp; newValue;
			endif;
		endif;
	endforeach;
	return str;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getYardAllocationMatchString" id="69dfd47f-0d23-4393-af84-5295eeb4af32">
        <source>getYardAllocationMatchString() : String;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22/09/2011	cnwdap1	Initial creation PAR #28223 CCMS MSL 1024
*/
vars

begin
	if self.yardAllocationMatch = AllocationStatus_Matched then
		return AllocationStatus_MatchedStr;
	elseif self.yardAllocationMatch = AllocationStatus_NoAlloc then
		return AllocationStatus_NoAllocStr;
	elseif self.yardAllocationMatch = AllocationStatus_OutOf then
		return AllocationStatus_OutOfStr;
	elseif self.yardAllocationMatch = AllocationStatus_Undefined then
		return AllocationStatus_UndefinedStr;
	endif;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="hasCamProtocolTrigger" id="165765dc-4d60-4f4b-9eb8-bb24b6e9319b">
        <source>hasCamProtocolTrigger(_triggers :CM_CamEditTriggerFieldDict) :Boolean;

vars
	
	altProperties : StringArray;
	array	: HugeStringArray;
	trigger	: CM_CamEditTriggerField;
	str,
 	prop, propAlternate 	: String;
	length, lengthAlt	: Integer;
begin
	create altProperties transient;
	create array transient;
	self.fieldsValues.getStrings(array);
	foreach trigger in _triggers do
		prop	:= trigger.systemName;
		length	:= prop.length;
		
		altProperties.clear;
		if  prop 		= "allTIHazards" then				// PAR 21349 some items get stored not quite as expected, so look both ways
			propAlternate 	:= "hazardList";
			lengthAlt 		:= propAlternate.length;
		elseif  prop 	= "allDamageInstances" then			
			propAlternate 	:= "allDamageInstancesByPos";
			lengthAlt 		:= propAlternate.length;
		elseif prop  = "Any VGM Details" then
			altProperties.add(CM_TrackedItem::isWeightCertified.name);
			altProperties.add(CM_TrackedItem::weightCertifiedName.name);
			altProperties.add(CM_TrackedItem::weightCertifiedReference.name);
		elseif prop = "Any Weight Field" then
			altProperties.add(CM_TrackedItem::totalWeight.name);
			altProperties.add(CM_TrackedItem::weightCargo.name);
			altProperties.add(CM_TrackedItem::weightDeclared.name);
			altProperties.add(CM_TrackedItem::weightTare.name);
		//17 Jan 2020	NDL TFS 48249
		elseif prop = "Pallet Detail" then
			altProperties.add(CM_PalletDetailsTI::heatTreated.name);
			altProperties.add(CM_PalletDetailsTI::myPalletType.name);
			altProperties.add(CM_PalletDetailsTI::storeOnPallets.name);
			
		//25 Aug 2020	NDL	TFS 49916
		elseif self.myTrackedItem &lt;&gt; null and self.isEntTableSpecialProductAttr( prop ) then
			//These props can be translated by the users for each cargo type. (currently just 'width', 'height' and 'length', are used, but could extend)
			propAlternate := self.myTrackedItem.getProductAttrNameAuditEdit( prop );
			lengthAlt 		:= propAlternate.length;
		
		else
			propAlternate := null;
		endif;
		
		foreach str in array do
			if  str[1:length] 	= prop then
				return true;
			endif;
			if propAlternate 	&lt;&gt; null 			and 	// PAR 21349 some items get stored not quite as expected, so look both ways
				str[1:lengthAlt] = propAlternate  	then
				return true;
			endif;
			
			//epr TFS 2395 20/7/16
			if not altProperties.isEmpty then
				foreach propAlternate in altProperties do
					if  str[1:propAlternate.length] = propAlternate then
						return true;
					endif;
				endforeach;
				propAlternate:=null;						
			endif;
				
		endforeach;
	endforeach;
epilog
	delete array;
	delete altProperties;
end;
</source>
        <Parameter name="_triggers" type="CM_CamEditTriggerFieldDict"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="hasSedChanged" id="f62208d0-017a-4047-950c-2bb063c409e3">
        <source>hasSedChanged( _oldSedMean, _newSedMean : Decimal output ) : Boolean;
// --------------------------------------------------------------------------------------------------------------------
// Created:     20 Feb 2008 by cnwvu1
// --------------------------------------------------------------------------------------------------------------------
vars
	ti				: CM_TrackedItem;
	tmpOldSedMean,
	tmpNewSedMean	: String;
	
begin

	ti := self.myTrackedItem;
	if not ti.isKindOf( CM_Log ) then
		return false;	// sed is for logs
	endif;
	
	if self.getFieldValuesByField( CM_Log::sedMean, ti.CM_Log, tmpOldSedMean, tmpNewSedMean ) then
		_oldSedMean := tmpOldSedMean.Real;
		_newSedMean := tmpNewSedMean.Real;
		return true;
	else
		return false;
	endif;

end;
</source>
        <Parameter name="_oldSedMean" type="Decimal" usage="output"/>
        <Parameter name="_newSedMean" type="Decimal" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
