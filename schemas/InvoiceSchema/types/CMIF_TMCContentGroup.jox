<Class name="CMIF_TMCContentGroup" id="668ea093-da77-4d6c-9b93-44c3ffad59d1">
    <superclass name="CMIF_TMCGroup"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="invoice"/>
    <ImplicitInverseRef name="myContentMap" id="91ab3898-d921-4e2a-b505-c9478b438433">
        <embedded/>
        <type name="CM_ContentsMap"/>
    </ImplicitInverseRef>
    <JadeMethod name="getItemLevel" id="f4e576d6-d4bb-4693-b539-e472db4e14a7">
