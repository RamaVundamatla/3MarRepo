        <updating/>
        <source>doRefresh() updating, protected;

vars

begin
	self.populateTable();
	if self.useTableInfo then
		if self.mnuContextHide.caption = self.MNU_MACRO_HIDE then
			//self.doTblDataRowColChange(tblData);	** to do - refresh the macro info for the current table line
