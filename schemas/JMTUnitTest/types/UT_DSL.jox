        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="addContainers" id="a38661ed-913b-47c9-a3a1-bd288fb8e241">
        <updating/>
        <source>addContainers(_objectArray : ObjectArray) updating;
/*

Purpose:	pass in array of 	CM_AssociationDict objects will then create the containers and 
								put them in a grid area 

Parameters:			

Return Value:		


Date		Who		Reason
22 December 2008	cnwer1	Initial creation

*/

vars
	obj : Object;
	assoc : CM_AssociationDict;
	id,
	commodityCode,
	operatorName,
	isoCode: String;
	ti : CM_TrackedItem;
	gridArea : CM_GridArea;
	row,
	col : Integer;
begin

	foreach  obj in _objectArray do
		assoc := obj.CM_AssociationDict;
		self.opts.clear();
		assoc.copy(self.opts);
		id := assoc.str("ID");
		commodityCode := assoc.str("Commodity");
		operatorName := assoc.str("Operator");
		isoCode := assoc.str("ISO");
		
		ti := self.addContainerOpts(id, isoCode,commodityCode , self.getOperator(operatorName));
		self.assertTrue(ti &lt;&gt; null);
		// move the container into grid area if option is included
		if assoc.includesKey("LOC_TA") then
			gridArea:= assoc["LOC_TA".toUpper()].asObject.CM_GridArea;
			row:=assoc.int("LOC_ROW");
			col:=assoc.int("LOC_COL");
			// Move in a ti
			move(ti, gridArea.allGridControllersByRowColumn[		row, col]);
			assertLocationHasTI(gridArea.allGridControllersByRowColumn[		row, col], ti);
		endif;
	endforeach;

epilog

end;</source>
        <Parameter name="_objectArray" type="ObjectArray"/>
    </JadeMethod>
